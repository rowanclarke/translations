\id PSA  
\h MEZMURLAR 
\toc1 MEZMURLAR 
\toc2 MEZMURLAR 
\toc3 MEZMURLAR 
\mt1 MEZMURLAR  
\c 1  
\q1
\v 1 Ne mutlu kötülerin öğüdüyle yürümeyen,  
\q2 günahkârların yolunda durmayan,  
\q2 alaycıların sandalyesinde oturmayan insana.   
\q1
\v 2 Ancak onun zevki Yahve’nin\f + \fr 1:2 \ft “Yahve” Tanrı’nın asıl ismidir, diğer çevirilerde bazen “RAB=EFENDİ” (tamamı büyük harflerle) olarak çevrilir.\f* Yasası'dır.  
\q2 gece gündüz onun üzerinde  
\q2 derin derin düşünür.   
\q1
\v 3 O kişi akarsu kıyısına dikilmiş ağaca benzer,  
\q2 meyvesini mevsiminde verir,  
\q2 yaprağı da solmaz.  
\q2 Ne yaparsa başarır.   
\q1
\v 4 Kötüler böyle değildir,  
\q2 ancak rüzgârın savurduğu saman çöpü gibidirler.   
\q1
\v 5 Bu nedenle kötüler yargılanınca ayakta kalamaz,  
\q2 günahkârlar doğrular topluluğunda duramaz.   
\q1
\v 6 Çünkü Yahve doğruların yolunu bilir,  
\q2 ancak kötülerin yolu yok olur.   
\c 2  
\q1
\v 1 Uluslar neden öfkeleniyor,  
\q2 halklar neden boş düzen kuruyor?   
\q1
\v 2 Dünyanın kralları ayağa kalkıyor,  
\q2 hükümdarlar birbiriyle öğütleşiyor,  
\q2 Yahve’ye ve Mesihi’ne\f + \fr 2:2 \ft “Meshedilmiş” kelimesi “Mesih” kelimesiyle aynıdır\f* karşı.   
\q1
\v 3 “Koparalım onların bağlarını” diyorlar,  
\q2 “İplerini üzerimizden atalım.”   
\q1
\v 4 Göklerde oturan gülecek.  
\q2 Efendi\f + \fr 2:4 \ft “Efendi” olarak tercüme edilen sözcük “Adonay”dır.\f* onlarla alay edecek.   
\q1
\v 5 O zaman hiddetle konuşacak onlara,  
\q2 gazabıyla onları dehşete düşürecek:   
\q1
\v 6 “Ben Kralımı kutsal dağım Siyon'a oturttum.”   
\q1
\v 7 Kararı bildireceğim:  
\q2 Yahve bana, “Sen benim oğlumsun” dedi.  
\q2 “Bugün ben senin baban oldum.   
\q1
\v 8 Dile benden, mirasın olarak sana ulusları,  
\q2 mülk olarak yeryüzünün en uzak köşelerini vereyim.   
\q1
\v 9 Onları demir sopayla kıracaksın,  
\q2 çömlekçi kabı gibi parçalayacaksın.”   
\q1
\v 10 Ey krallar, şimdi akıllı olun.  
\q2 Ey dünya hâkimleri, ders alın.   
\q1
\v 11 Yahve’ye korkuyla hizmet edin,  
\q2 titreyerek sevinin.   
\q1
\v 12 Oğul'a içtenlikle saygı gösterin ki\f + \fr 2:12 \ft veya Oğul'u öpün\f* öfkelenmesin,  
\q2 yoksa yolunuzda mahvolursunuz.  
\q2 Çünkü hiddeti yakında alevlenecek.  
\q2 Ne mutlu O'na sığınanlara.   
\c 3  
\d David’in oğlu Avşalom'dan kaçtığı zaman yazdığı mezmur  
\q1
\v 1 Ey Yahve, düşmanlarım nasıl da çoğaldı!  
\q2 Bana karşı ayaklananlar çoktur.   
\q1
\v 2 Canım için birçoğu,  
\q2 “Tanrı\f + \fr 3:2 \ft “Tanrı” olarak tercüme edilen İbranice kelime “אֱלֹהִ֑ים” (Elohim)’dir.\f* katında ona yardım yoktur” diyor. \qs Selah.\qs*   
\q1
\v 3 Ama sen, ey Yahve, çevremde kalkansın,  
\q2 yüceliğim ve başımı yükselten sensin.   
\q1
\v 4 Yahve’ye seslenirim,  
\q2 kutsal dağından bana yanıt verir. Selah.   
\q1
\v 5 Yattım ve uyudum.  
\q2 Uyandım, çünkü Yahve bana destek oldu.   
\q1
\v 6 Her yönden bana karşı koyan  
\q2 on binlerden korkmam.   
\q1
\v 7 Kalk, ey Yahve!  
\q2 Tanrım, kurtar beni!  
\q1 Çünkü sen tüm düşmanlarımın çene kemiğine vurdun.  
\q2 Kötülerin dişlerini kırdın.   
\q1
\v 8 Kurtuluş Yahve’nindir.  
\q2 Kutsaman halkının üzerinde olsun! Selah.   
\c 4  
\q1
\v 1 Seslenince yanıtla beni, doğruluğumun Tanrısı!  
\q2 Beni sıkıntımdan kurtar.  
\q2 Bana merhamet et ve duamı duy.   
\q1
\v 2 Ey insanoğulları, ne zamana dek yüceliğim utanca çevrilecek?  
\q2 Boş şeyleri sevip yalanın peşinden mi gideceksiniz? Selah.   
\q1
\v 3 Ama Yahve’nin tanrısal olanı kendine ayırdığını bilin.  
\q2 Kendisine seslenince Yahve beni duyar.   
\q1
\v 4 Titreyin ve günah işlemeyin.  
\q2 Yatağınızda yüreğinizi yoklayın ve sakin olun. Selah.   
\q1
\v 5 Doğruluk kurbanları sunun.  
\q2 Yahve’ye güvenin.   
\q1
\v 6 “Bize kim iyilik gösterecek?” diyenler çoktur.  
\q2 Yüzünün ışığı üzerimizde parlasın, ey Yahve.   
\q1
\v 7 Yüreğime verdiğin sevinç,  
\q2 onların tahıllarının ve yeni şaraplarının çoğaldığı zamankinden fazladır.   
\q1
\v 8 Esenlik içinde hem yatar, hem uyurum.  
\q2 Çünkü yalnız sen, ey Yahve,  
\q2 güvenlik içinde yaşatırsın beni.   
\c 5  
\d Müzik şefi için - Telli sazlarla - David'in mezmuru  
\q1
\v 1 Sözlerime kulak ver, ey Yahve.  
\q2 İçine daldığım düşünceleri gör.   
\q1
\v 2 Feryadıma kulak ver, ey Kralım ve Tanrım;  
\q2 çünkü sana dua ediyorum.   
\q1
\v 3 Sabahları sesimi işiteceksin, ey Yahve,  
\q2 sabahları dileklerimi önüne serip umutla bekleyeceğim.   
\q1
\v 4 Çünkü sen kötülükten hoşlanan bir Tanrı değilsin.  
\q2 Kötülük seninle yaşayamaz.   
\q1
\v 5 Kibirliler önünde duramaz.  
\q2 Kötülüğün tüm işçilerinden nefret edersin.   
\q1
\v 6 Yalan söyleyenleri yok edersin.  
\q2 Yahve kana susamış ve düzenbaz adamdan nefret eder.   
\q1
\v 7 Bense senin sevgi dolu iyiliğinin bolluğuyla evine gireceğim.  
\q2 Sana saygıyla kutsal tapınağına doğru eğileceğim.   
\q1
\v 8 Ey Yahve, düşmanlarıma karşı doğruluğunla bana yol göster.  
\q2 Yolunu önümde düzle.   
\q1
\v 9 Çünkü ağızlarında sadakat yoktur.  
\q2 Yürekleri yıkımdır.  
\q2 Boğazları açık bir mezar.  
\q2 Dilleriyle yaltaklanırlar.   
\q1
\v 10 Onları suçlu çıkar, ey Tanrım!  
\q2 Kendi öğütleriyle düşsünler.  
\q2 İsyanlarının çokluğunda onları kov,  
\q2 çünkü sana karşı isyan ettiler.   
\q1
\v 11 Ama sana sığınanların hepsi sevinsinler.  
\q2 Her zaman sevinç çığlıkları atsınlar, çünkü onları savunan sensin.  
\q2 Adını sevenler de sende sevinçle coşsunlar.   
\q1
\v 12 Çünkü sen doğru kişiyi kutsayacaksın, ey Yahve  
\q2 çevresini kalkan gibi lütfunla saracaksın.   
\c 6  
\d Müzik şefi için - Sekiz telli sazlarla - David'in mezmuru  
\q1
\v 1 Ey Yahve, öfkenle beni azarlama,  
\q2 beni gazabınla terbiye etme.   
\q1
\v 2 Acı bana, ey Yahve, çünkü bitkinim.  
\q2 Ey Yahve, iyileştir beni, çünkü kemiklerim sızlıyor.   
\q1
\v 3 Canım da büyük bir ıstırap içinde.  
\q2 Ama sen, ey Yahve, ne zamana dek?   
\q1
\v 4 Ey Yahve, dön. Canımı özgür kıl,  
\q2 iyilik dolu sevgin uğruna beni kurtar.   
\q1
\v 5 Çünkü senin anılman ölümün içinde yoktur.  
\q2 Şeol'de\f + \fr 6:5 \ft Şeol ölüler diyarıdır. \f* sana kim şükredecek?   
\q1
\v 6 İnlemekten yoruldum.  
\q2 Her gece yatağım su içinde.  
\q2 Gözyaşlarımla döşeğimi ıslatıyorum.   
\q1
\v 7 Gözüm kederden sönüyor,  
\q2 bütün düşmanlarımdan ötürü yaşlanıyor.   
\q1
\v 8 Ey kötülük yapanların hepsi benden uzak durun,  
\q2 çünkü Yahve ağlayışımı duydu.   
\q1
\v 9 Yahve yalvarışımı işitti.  
\q2 Yahve duamı kabul edecektir.   
\q1
\v 10 Bütün düşmanlarım utanıp dehşet içinde kalacak.  
\q2 Dönecekler, ansızın rezil olacaklar.   
\c 7  
\d Benyaminli Kûş'un sözlerine ilişkin David’in Yahve’ye okuduğu şigayon  
\q1
\v 1 Ey Yahve, Tanrım, sana sığınıyorum.  
\q2 Peşime düşenlerin hepsinden kurtar beni, özgür kıl.   
\q1
\v 2 Kurtaracak kimse yok diye,  
\q2 aslan gibi canımı parçalamasınlar,  
\q2 paramparça etmesinler onu.   
\q1
\v 3 Ey Yahve, Tanrım, eğer şunu yaptıysam,  
\q2 eğer elimde kötülük varsa,   
\q1
\v 4 benimle barış içinde olan birine kötülükle karşılık verdiysem  
\q2 (evet, sebepsiz yere düşmanımı soyduysam),   
\q1
\v 5 düşman canımın peşine düşsün ve ele geçirsin beni,  
\q2 hayatımı yere çalsın,  
\q2 yüceliğimi toza katsın. Selah.   
\q1
\v 6 Öfkeyle kalk, ey Yahve.  
\q2 Düşmanlarımın öfkesine karşı yüksel.  
\q2 Benim için uyan. Yargıyı sen buyurdun.   
\q1
\v 7 Uluslar topluluğu çevreni sarsın.  
\q2 Yücelerden onları yönet.   
\q1
\v 8 Yahve halkları yargılar,  
\q2 beni doğruluğuma göre yargıla, ey Yahve,  
\q2 dürüstlüğüme göre.   
\q1
\v 9 Kötülerin kötülüğü son bulsun,  
\q2 ama doğru olanı pekiştir,  
\q2 onların akıllarını ve yüreklerini araştıran adil Tanrı’dır.   
\q1
\v 10 Benim kalkanım Tanrı’yla olmaktır,  
\q2 yüreği doğru olanı O kurtarır.   
\q1
\v 11 Tanrı adil bir yargıçtır,  
\q2 evet, her gün öfkelenen bir Tanrı’dır.   
\q1
\v 12 Biri tövbe etmezse kılıcını biler,  
\q2 eğip yayını gerer.   
\q1
\v 13 Ona karşı ölüm silahlarını hazırlamıştır.  
\q2 Alevli okları hazırdır.   
\q1
\v 14 İşte\f + \fr 7:14 \ft “İşte”, “הִנֵּה” kelimesinden gelir ve bakmak, farkına varmak, gözlemlemek, görmek veya dik dik bakmak anlamına gelir. Genellikle bir ünlem olarak kullanılır.\f* o kişi, kötülük sancısı çekiyor.  
\q2 Kötülüğe gebe kalıp,  
\q2 yalan doğurdu.   
\q1
\v 15 Bir çukur kazdı,  
\q2 kazdığı çukura kendisi düştü.   
\q1
\v 16 Neden olduğu bela kendisine dönecek.  
\q2 Zorbalığı kendi başına inecek.   
\q1
\v 17 Doğruluğundan ötürü Yahve’ye şükredeceğim,  
\q2 yüce Yahve'nin adını ilahilerle öveceğim.   
\c 8  
\d Müzik şefi için - Gittit üzerine - David’in mezmuru  
\q1
\v 1 Ey Efendimiz Yahve,  
\q2 ne yüce adın var bütün yeryüzünde!  
\q2 Görkemini göklerin üstüne yükselttin!   
\q1
\v 2 Sana düşman olanlardan ötürü,  
\q2 düşmanı ve öç alanı susturmak için  
\q2 çocukların ve bebeklerin dudaklarından gücü kurdun.   
\q1
\v 3 Senin göklerini, ellerinin eserini,  
\q2 koyduğun ay ve yıldızları düşününce dedim:   
\q1
\v 4 “İnsan ne ki, onu düşünesin?  
\q2 İnsanoğlu nedir ki, ona değer veresin?”   
\q1
\v 5 Onu meleklerden\f + \fr 8:5 \ft İbranice: Elohim. Burada kullanılan Elohim kelimesi genellikle “Tanrı” anlamına gelir, ancak “tanrılar”, “beyler” veya “melekler” anlamına da gelebilir. Septuagint burada “melekler” olarak okunur. Ayrıca İbraniler 2:7’deki Septuagint’ten alıntıya da bakın.\f* biraz aşağı kıldın,  
\q2 ve onu yücelik ve saygınlıkla taçlandırdın.   
\q1
\v 6 Ellerinin işleri üzerinde onu hâkim kıldın.  
\q2 Her şeyi ayaklarının altına serdin.   
\q1
\v 7 Tüm koyunları ve sığırları,  
\q2 kır hayvanlarını,   
\q1
\v 8 Gökteki kuşları, denizdeki balıkları,  
\q2 denizlerin yollarından geçen her şeyi.   
\q1
\v 9 Ey Efendimiz Yahve,  
\q2 ne yüce adın var bütün yeryüzünde!   
\c 9  
\d Müzik şefi için - “Oğulun Ölümü” makamında - David’in mezmuru  
\q1
\v 1 Bütün yüreğimle Yahve’ye şükredeceğim.  
\q2 Şaşkınlık verici işlerinin hepsini anlatacağım.   
\q1
\v 2 Sende sevinip coşacağım.  
\q2 Adına ilahiler söyleyeceğim, ey Yüceler Yücesi.   
\q1
\v 3 Düşmanlarım geri çekilirken,  
\q2 senin önünde tökezleyip yok oluyorlar.   
\q1
\v 4 Çünkü haklı davamı sen gördün.  
\q2 Tahtında oturur adil şekilde yargılarsın.   
\q1
\v 5 Ulusları azarladın.  
\q2 Kötüleri yok ettin.  
\q2 Adlarını sonsuza dek sildin.   
\q1
\v 6 Düşman sonsuz yıkıma uğradı.  
\q2 Yerinden söküp attığın kentlerin anıları bile yok oldu.   
\q1
\v 7 Ama Yahve sonsuza dek hüküm sürer.  
\q2 Tahtını yargı için hazırlamıştır.   
\q1
\v 8 Dünyayı doğrulukla yargılayacak.  
\q2 O, halkları doğrulukla yargılayacaktır.   
\q1
\v 9 Yahve ezilenler için bir sığınak,  
\q2 sıkıntılı zamanlarda yüksek bir kuledir.   
\q1
\v 10 Adını bilenler sana güvenecekler,  
\q2 çünkü sen, ey Yahve, seni arayanları terk etmezsin.   
\q1
\v 11 Siyon'da oturan Yahve’yi ilahilerle övün,  
\q2 yaptıklarını halklar arasında ilan edin.   
\q1
\v 12 Çünkü kanın öcünü alan onları hatırlar.  
\q2 Mazlumların feryadını unutmaz.   
\q1
\v 13 Bana merhamet et, ey Yahve.  
\q2 Benden nefret edenler yüzünden çektiğim acıyı gör,  
\q2 beni ölümün kapılarından kaldır da,   
\q1
\v 14 övgülerinin tümünü gösterebileyim.  
\q2 Siyon kızının kapılarında kurtarışınla sevineceğim.   
\q1
\v 15 Uluslar kazdıkları çukura düştüler.  
\q2 Gizledikleri ağ kendi ayaklarına takıldı.   
\q1
\v 16 Yahve kendisini tanıttı.  
\q2 Yargısını gerçekleştirdi.  
\q2 Kötü kişi kendi ellerinin işiyle tuzağa düştü. Higayon - Selah.   
\q1
\v 17 Kötüler Şeol'e\f + \fr 9:17 \ft Şeol ölüler diyarıdır. \f* döndürüleceklerdir.  
\q2 Tanrı’yı unutan tüm uluslar da.   
\q1
\v 18 Çünkü yoksullar hep unutulmayacak,  
\q2 mazlumun umudu sonsuza dek yok olmayacak.   
\q1
\v 19 Kalk, ey Yahve! İnsan galip çıkmasın.  
\q2 Uluslar senin önünde yargılansın.   
\q1
\v 20 Onları korkut, ey Yahve.  
\q2 Uluslar, yalnızca insan olduklarını bilsinler. Selah.   
\c 10  
\q1
\v 1 Neden uzakta duruyorsun, ey Yahve?  
\q2 Sıkıntı zamanlarında neden kendini saklıyorsun?   
\q1
\v 2 Kötüler kibirle mazlumları avlıyor.  
\q2 Mazlumlar kötülerin kurduğu tuzağa düşüyor.   
\q1
\v 3 Çünkü kötü kişi yüreğindeki arzularla övünür.  
\q2 Açgözlüleri yüceltir ve Yahve’yi yerer.   
\q1
\v 4 Kötü kişi gururlu yüzüyle,  
\q2 düşüncelerinde Tanrı'ya yer vermez.   
\q1
\v 5 Kötünün yolları hep bolluk içindedir.  
\q2 Kibirlidir ve senin yasaların onun gözlerinden uzaktır.  
\q2 Düşmanlarının hepsini küçümser.   
\q1
\v 6 Yüreğinden, “Ben sarsılmam.  
\q2 Hiçbir devirde sıkıntıya düşmem.” der.   
\q1
\v 7 Ağzı lanet, hile ve zulümle dolu.  
\q2 Dilinin altında kötülük ve fesat vardır.   
\q1
\v 8 Köylerin yakınında pusuda bekler.  
\q2 Pusuda masumu öldürür.  
\q2 Gözlerini gizlice çaresize dikmiştir.   
\q1
\v 9 Pusuya yatmış aslan gibi, gizlice pusudadır.  
\q2 Çaresizi yakalamak için yatıp bekler.  
\q2 Çaresizi ağına çekip yakalar.   
\q1
\v 10 Çaresiz onun gücünün altında  
\q2 Çöküp ezilir.   
\q1
\v 11 Yüreğinden, “Tanrı unuttu” der.  
\q2 “Yüzünü gizledi,  
\q2 hiçbir zaman görmeyecek.”   
\q1
\v 12 Kalk, ey Yahve!  
\q2 Tanrım, elini kaldır!  
\q2 Çaresizi unutma.   
\q1
\v 13 Kötü kişi neden Tanrı'yı suçlasın?  
\q2 Yüreğinden “Tanrı hesap sormaz” desin.   
\q1
\v 14 Ama sen sıkıntı ve kederi görürsün.  
\q2 Onu eline almayı düşünürsün.  
\q2 Mağdura ve babasızlara yardım edersin.   
\q1
\v 15 Kötünün kolunu kır.  
\q2 Kötüye gelince, kötülüğü kalmayıncaya kadar ondan hesabını sor.   
\q1
\v 16 Yahve sonsuza dek Kraldır!  
\q2 Uluslar O'nun diyarından yok olacak.   
\q1
\v 17 Yahve, alçakgönüllülerin dileğini duydun.  
\q2 Onların yüreğini hazırlayacaksın.  
\q2 Kulağını onlara açacaksın,   
\q1
\v 18 Yetimlerin ve ezilenlerin yargısını vermek için,  
\q2 öyle ki toprak olan insan artık bir daha dehşet saçmasın.   
\c 11  
\d Müzik şefi için - David’in mezmuru  
\q1
\v 1 Ben Yahve’ye sığınırım.  
\q2 Nasıl olur da canıma, “Kuş gibi dağa kaç” dersiniz?   
\q1
\v 2 Çünkü işte, kötüler yaylarını geriyor.  
\q2 Karanlıkta dürüst yüreklileri vurmak için,  
\q2 Oklarını kiriş üzerine yerleştirdiler.   
\q2
\v 3 Temeller yıkılırsa,  
\q2 doğru kişi ne yapabilir?   
\q1
\v 4 Yahve kutsal tapınağındadır.  
\q2 Yahve gökte tahtındadır.  
\q2 O’nun gözleri bakar.  
\q2 Gözleri insanoğullarını sınar.   
\q1
\v 5 Yahve doğru kişiyi sınar,  
\q2 ama O'nun canı kötüden ve zorbalığı sevenden nefret eder.   
\q1
\v 6 Kötülerin üzerine kızgın korlar yağdıracak;  
\q2 ateş, kükürt ve kavurucu rüzgâr onların kâsesine düşen pay olacak.   
\q1
\v 7 Çünkü Yahve doğrudur.  
\q2 Doğruluğu sever.  
\q2 Doğru kişi O’nun yüzünü görecek.   
\c 12  
\d Müzik şefi için - Sekiz telli sazlarla  
\q1
\v 1 Yardım et, ey Yahve, çünkü tanrısal kişi kalmadı.  
\q2 İnsanoğulları arasında sadık olanlar tükeniyor.   
\q1
\v 2 Herkes komşusuna yalan söylüyor.  
\q2 Yaltaklanan dudaklarla, çift yürekle konuşuyorlar.   
\q1
\v 3 Yahve tüm yaltaklanan dudakları,  
\q2 ve övünen dilleri kessin.   
\q1
\v 4 Onlar, “Dilimizle galip geleceğiz.  
\q2 Dudaklarımız bizimdir.  
\q2 Kim bizim üzerimizde efendidir?” derler.   
\q1
\v 5 “Mazlumların ezilmesinden ve yoksulların iniltilerinden ötürü,  
\q2 şimdi kalkacağım” diyor Yahve,  
\q1 “Ona kötülük edenlerden kurtarıp güvenli bir yere koyacağım.”   
\q1
\v 6 Yahve’nin sözleri kusursuzdur,  
\q2 toprak ocakta eritilmiş,  
\q2 yedi kez arıtılmış gümüşe benzer.   
\q1
\v 7 Sen onları koruyacaksın, ey Yahve.  
\q2 Onları bu kuşaktan daima koruyacaksın.   
\q1
\v 8 Alçaklık insanoğulları arasında yüceltildiğinde,  
\q2 kötüler her yanda dolaşır.   
\c 13  
\d Müzik şefi için - David’in mezmuru  
\q1
\v 1 Ne zamana dek, ey Yahve?  
\q2 Beni sonsuza dek mi unutacaksın?  
\q2 Yüzünü benden daha ne kadar gizleyeceksin?   
\q1
\v 2 Her gün yüreğimde keder var,  
\q2 ne zamana dek canımı teselli edeceğim?  
\q2 Ne zamana dek düşmanım bana karşı zafer kazanacak?   
\q1
\v 3 Bak ve yanıt ver bana, ey Tanrım Yahve.  
\q2 Gözlerime ışık ver ki, ölüm uykusuna yatmayayım,   
\q1
\v 4 öyle ki, düşmanım, “Onu yendim” demesin,  
\q2 Düştüğümde düşmanlarım sevinmesin.   
\q1
\v 5 Ama ben senin sevgi dolu iyiliğine güveniyorum.  
\q2 Yüreğim senin kurtuluşunla seviniyor.   
\q1
\v 6 Yahve’ye ezgiler söyleyeceğim,  
\q2 çünkü bana iyilik etti.   
\c 14  
\d Müzik Şefi için David’in mezmuru  
\q1
\v 1 Akılsız yüreğinde, “Tanrı yoktur” dedi.  
\q2 Yozlaştılar,  
\q2 iğrenç işler yaptılar.  
\q2 İyilik eden kimse yok.   
\q1
\v 2 Anlayan, Tanrı’yı arayan birisi var mı diye,  
\q2 Yahve gökten insanoğullarına baktı,   
\q1
\v 3 hepsi saptı.  
\q2 Hepsi birlikte yozlaştılar.  
\q2 İyilik eden kimse yok, bir kişi bile yok.   
\q1
\v 4 Kötülük edenlerin hiçbirinin bilgisi yok mu?  
\q2 Halkımı ekmek yer gibi yiyorlar.  
\q2 Yahve’yi çağırmıyorlar.   
\q1
\v 5 Orada dehşet içinde kaldılar.  
\q2 Çünkü Tanrı doğruların kuşağının yanındadır.   
\q1
\v 6 Yoksulların tasarısını engellersiniz,  
\q2 ama onun sığınağı Yahve’dir.   
\q1
\v 7 Ah, keşke İsrael'in kurtuluşu Siyon'dan gelseydi!  
\q2 Yahve halkının servetini geri döndürdüğünde,  
\q2 o zaman Yakov sevinecek ve İsrael coşacak.   
\c 15  
\d David’in mezmuru  
\q1
\v 1 Ey Yahve, tapınağında kim oturabilir?  
\q2 Kutsal dağında kim yaşayabilir?   
\q1
\v 2 Kusursuzca yürüyen, doğru olanı yapan,  
\q2 yüreğinde gerçeği söyleyen,   
\q1
\v 3 Böylesi iftira etmez,  
\q2 dostuna kötülük etmez,  
\q2 komşusuna kara çalmaz.   
\q1
\v 4 Aşağılık insanı hor görür,  
\q2 ama Yahve'den korkanlara saygı duyar.  
\q2 Kendi zararına ant içse bile, andını bozmaz.   
\q1
\v 5 Parasını tefeciye vermez,  
\q2 suçsuza karşı rüşvet almaz.  
\q2 Bunları yapan asla sarsılmaz.   
\c 16  
\d David'in şiiri  
\q1
\v 1 Koru beni, ey Tanrı,  
\q2 çünkü sana sığınıyorum.   
\q1
\v 2 Canım, Yahve’ye şöyle dedi:  
\q2 “Efendim sensin.  
\q2 Senden ayrı bana iyilik yoktur.”   
\q1
\v 3 Yeryüzündeki kutsallara gelince,  
\q2 harikadır onlar, bütün zevkim onlardadır.   
\q1
\v 4 Başka ilâha armağan sunanların kederi çoğalacak.  
\q2 Onların kan sunularını ben sunmayacağım,  
\q2 ne de adlarını ağzıma alacağım.   
\q1
\v 5 Yahve payımı, kâsemi belirledi.  
\q2 Benim hissemi güvende tutan sensin.   
\q1
\v 6 Sınırlar hoş yerlerde düştü bana.  
\q2 Evet, iyi bir mirasım var.   
\q1
\v 7 Bana öğüt veren Yahve’yi yücelteceğim.  
\q2 Evet, geceleyin yüreğim beni uyarır.   
\q1
\v 8 Yahve’yi hep önüme koydum.  
\q2 O benim sağımda olduğu için sarsılmam.   
\q1
\v 9 Bu nedenle yüreğim coşku dolu, dilim sevinir.  
\q2 Bedenim de güvenlik içinde yaşar.   
\q1
\v 10 Çünkü sen canımı Şeol'e\f + \fr 16:10 \ft Şeol ölüler diyarıdır. \f* terk etmeyeceksin,  
\q2 kutsalının çürümesine izin vermeyeceksin.   
\q1
\v 11 Bana yaşam yolunu göstereceksin.  
\q2 Bol sevinç senin huzurundadır.  
\q2 Sağ elinde sonsuz zevkler vardır.   
\c 17  
\d David’in bir duasıdır.  
\q1
\v 1 Ey Yahve, haklı yakarışımı işit.  
\q2 Hileli dudaklardan çıkmayan duama kulak ver.   
\q1
\v 2 Hükmüm senin huzurundan çıksın.  
\q2 Senin gözlerin adalete baksın.   
\q1
\v 3 Yüreğimi denedin.  
\q2 Geceleyin beni ziyaret ettin.  
\q2 Beni yokladın ama hiçbir şey bulmadın.  
\q2 Ağzımdan itaatsiz söz çıkarmamaya kararlıyım.   
\q1
\v 4 İnsanların yaptıklarına gelince,  
\q2 senin dudaklarının sözüyle,  
\q2 şiddet yollarından kendimi uzak tuttum.   
\q1
\v 5 Adımlarım senin yollarını sımsıkı tuttu.  
\q2 Ayaklarım kaymadı.   
\q1
\v 6 Sana seslendim, çünkü bana yanıt verirsin, Tanrım.  
\q2 Kulak ver bana.  
\q2 Sözümü duy.   
\q1
\v 7 İyilikle dolu muhteşem sevgini göster,  
\q2 sana sığınanları sağ elinle düşmanlarından kurtaran sensin.   
\q1
\v 8 Gözbebeğin gibi koru beni.  
\q2 Beni kanatlarının gölgesinde sakla,   
\q1
\v 9 bana baskı yapan kötülerden,  
\q2 Etrafımı saran ölümcül düşmanlarımdan.   
\q1
\v 10 Duygusuz yüreklerini kapatırlar.  
\q2 Ağızlarıyla gururla konuşurlar.   
\q1
\v 11 Artık adımlarımızın çevresini sardılar.  
\q2 Bizi yere çalmak için gözlerini diktiler.   
\q1
\v 12 Avına karşı doyumsuz bir aslan,  
\q2 pusuya yatmış genç bir aslan gibi.   
\q1
\v 13 Kalk, ey Yahve, onunla uğraş.  
\q2 Yere çal onu.  
\q2 Kılıcınla kurtar canımı kötülerden,   
\q1
\v 14 elinle insanlardan, ey Yahve,  
\q2 payı bu yaşamda olan dünya insanlarından.  
\q2 Değer verdiklerinin karnını doyurursun.  
\q2 Oğulların bolluk içindedir,  
\q2 onlar da çocukları için servet biriktirirler.   
\q1
\v 15 Bana gelince, yüzünü doğrulukla göreceğim.  
\q2 Uyandığımda senin suretini görmeye doyacağım.   
\c 18  
\d Müzik şefi için - Yahve’nin hizmetkârı David'in mezmuru - Yahve kendisini bütün düşmanlarının pençesinden ve Saul'un elinden kurtardığı gün David Yahve’ye şu ezgiyi okudu:  
\q1
\v 1 Seni seviyorum, ey Yahve, gücüm sensin.   
\q1
\v 2 Yahve benim kayam, kalem ve kurtarıcımdır,  
\q2 Tanrım, kayam, sığındığımdır,  
\q2 kalkanım ve kurtuluşumun boynuzu, yüksek kulem.   
\q1
\v 3 Övülmeye layık olan Yahve’yi çağırırım,  
\q2 ve kurtulurum düşmanlarımdan.   
\q1
\v 4 Ölüm ipleri sarmıştı beni.  
\q2 Tanrısızlık selleri beni ürküttü.   
\q1
\v 5 Şeol'ün\f + \fr 18:5 \ft Şeol ölüler diyarıdır.\f* ipleri çevremdeydi.  
\q2 Ölüm tuzakları üzerime indi.   
\q1
\v 6 Sıkıntı içinde Yahve’yi çağırdım,  
\q2 Tanrım’a haykırdım.  
\q2 Duydu sesimi tapınağından.  
\q2 Önündeki feryadım kulaklarına erişti.   
\q1
\v 7 O zaman yeryüzü sarsılıp titredi.  
\q2 Dağların temelleri de yerinden oynadı,  
\q2 çünkü Yahve öfkelenmişti.   
\q1
\v 8 Burnundan duman yükseldi.  
\q2 Ağzından yakıp tüketen bir ateş çıktı.  
\q2 Ondan korlar tutuştu.   
\q1
\v 9 Gökleri yarıp indi.  
\q2 Ayakları altında koyu bir karanlık vardı.   
\q1
\v 10 Bir keruva binip uçtu.  
\q2 Ve rüzgârın kanatları üzerinde süzüldü.   
\q1
\v 11 Karanlığı kendisine saklanacak yer,  
\q2 karanlık suları, gökyüzünün koyu bulutlarını,  
\q2 çevresine çardak yaptı.   
\q1
\v 12 Önündeki parıltıdan dolu ve alevli korlarla,  
\q2 O’nun koyu bulutları geçti.   
\q1
\v 13 Yahve gökte gürledi.  
\q2 Yüceler Yücesi ses verdi,  
\q2 dolu ve alevli korlarla.   
\q1
\v 14 Oklarını gönderip onları dağıttı.  
\q2 Onları büyük yıldırımlarla bozguna uğrattı.   
\q1
\v 15 Ey Yahve senin azarlamandan,  
\q2 burnundan çıkan güçlü soluktan,  
\q2 suların yatakları göründü,  
\q2 dünyanın temelleri belirdi.   
\q1
\v 16 Yukarıdan gönderdi.  
\q2 Beni tuttu.  
\q2 Beni çok sulardan çıkardı.   
\q1
\v 17 Beni güçlü düşmanımdan,  
\q2 benden nefret edenlerden kurtardı.  
\q2 Çünkü onlar benden çok güçlüydüler.   
\q1
\v 18 Felaket günümde üzerime geldiler,  
\q2 ama Yahve bana destek çıktı.   
\q1
\v 19 Beni geniş bir yere çıkardı.  
\q2 Kurtardı beni çünkü benden hoşlandı.   
\q1
\v 20 Yahve doğruluğuma göre ödüllendirdi beni.  
\q2 Ellerimin temizliğine göre bana karşılık verdi.   
\q1
\v 21 Çünkü Yahve'nin yollarını tuttum,  
\q2 ve kötülükle Tanrım’dan uzaklaşmadım.   
\q1
\v 22 Çünkü O'nun bütün ilkeleri önümdedir.  
\q2 Kurallarını kendimden uzaklaştırmadım.   
\q1
\v 23 O’nunla suçsuzum.  
\q2 Günahımdan kendimi uzak tuttum.   
\q1
\v 24 Bu nedenle Yahve beni doğruluğuma göre,  
\q2 ellerimin O’nun gözündeki temizliğine göre ödüllendirdi.   
\q1
\v 25 Merhametli olana merhametini,  
\q2 kusursuz olana kusursuzluğunu gösterirsin.   
\q1
\v 26 Pak olana paklığını,  
\q2 çarpık olana sertliğini gösterirsin.   
\q1
\v 27 Çünkü mazlum insanları kurtarırsın,  
\q2 ama kibirli gözleri alaşağı edersin.   
\q1
\v 28 Işığımı sen yakacaksın ey Yahve.  
\q2 Tanrım karanlığımı aydınlatacaksın.   
\q1
\v 29 Çünkü senin sayende akıncıların üstüne çıkarım,  
\q2 Tanrım’la surları aşarım.   
\q1
\v 30 Tanrı'ya gelince, O’nun yolu kusursuzdur.  
\q2 Yahve’nin sözü sınandı.  
\q2 O, kendisine sığınan herkese kalkandır.   
\q1
\v 31 Çünkü Yahve'den başka Tanrı kimdir?  
\q2 Tanrımız’dan başka kaya kimdir?   
\q2
\v 32 O Tanrı ki, beni güçle donatır ve yolumu kusursuz kılar.   
\q1
\v 33 Ayaklarımı geyik ayakları gibi eder,  
\q2 beni yüksek yerlerime diker.   
\q1
\v 34 Ellerime savaşmayı öğretir,  
\q2 kollarımla tunç bir yayı gereyim diye.   
\q1
\v 35 Bana kurtuluşunun kalkanını da verdin.  
\q2 Sağ elin destekler beni.  
\q2 Senin sevecenliğin beni büyük etti.   
\q1
\v 36 Adımlarımın yerini genişlettin,  
\q2 ayaklarım kaymadı.   
\q1
\v 37 Düşmanlarımı kovalayıp onlara yetişirim,  
\q2 onlar yok olana dek geri dönmem.   
\q1
\v 38 Onları ezerim, kalkamazlar,  
\q2 ayaklarımın altına serilirler.   
\q1
\v 39 Çünkü savaş için bana güç verdin.  
\q2 Bana karşı çıkanları bana boyun eğdirdin.   
\q1
\v 40 Benden nefret edenleri yok edeyim diye,  
\q2 düşmanlarımın sırtını bana çevirttin.   
\q1
\v 41 Feryat ettiler ama kurtaracak kimse yoktu,  
\q2 Yahve’yi bile çağırdılar ama O yanıt vermedi.   
\q1
\v 42 O zaman onları yelin önündeki toz gibi ezdim.  
\q2 Onları sokak çamuru gibi dışarı fırlattım.   
\q1
\v 43 Halkın çekişmelerinden beni kurtardın.  
\q2 Beni ulusların başı yaptın.  
\q2 Tanımadığım bir halk bana hizmet edecek.   
\q1
\v 44 Duyar duymaz benim sözümü dinleyecekler.  
\q2 Yabancılar bana boyun eğecekler.   
\q1
\v 45 Yabancılar yok olup gidecek,  
\q2 kalelerinden titreyerek çıkacaklar.   
\q1
\v 46 Yahve yaşıyor! Kayam’a övgüler olsun!  
\q2 Kurtuluşumun Tanrısı yücelsin!   
\q1
\v 47 Benim için öç alan,  
\q2 halkları bana boyun eğdiren Tanrı O’dur.   
\q1
\v 48 Düşmanlarımdan kurtarır.  
\q2 Bana karşı çıkanların üstüne çıkarırsın beni.  
\q2 Beni zorbadan kurtarırsın.   
\q1
\v 49 Bunun için uluslar arasında sana şükredeceğim, ey Yahve,  
\q2 adını ilahilerle öveceğim.   
\q1
\v 50 O, kralına büyük bir kurtuluş verir,  
\q2 meshedilmiş olanına, David ve soyuna,\f + \fr 18:50 \ft veya tohum\f*  
\q2 sonsuza dek sevgi dolu iyiliğini gösterir.   
\c 19  
\d Müzik şefi için - David’in mezmuru  
\q1
\v 1 Gökler Tanrı'nın görkemini bildirir.  
\q2 Gök boşluğu ellerinin eserini sergiler.   
\q1
\v 2 Gün güne söz söyler,  
\q2 gece geceye bilgi gösterir.   
\q1
\v 3 Ne konuşma ne de dil vardır,  
\q2 sesleri duyulmaz.   
\q1
\v 4 Sesleri tüm yeryüzüne,  
\q2 sözleri dünyanın sonuna dek ulaşır.  
\q1 Göklerde güneş için çadır kurdu Tanrı.   
\q1
\v 5 Gerdekten çıkan güveye benzer güneş,  
\q2 yarışını koşan güçlü bir adam gibi sevinir.   
\q1
\v 6 Göklerin bir ucundan çıkar,  
\q2 öbür ucuna dek döner.  
\q2 Sıcaklığından hiçbir şey saklanmaz.   
\q1
\v 7 Yahve'nin yasası kusursuzdur, canı tazeler.  
\q2 Yahve’nin antlaşması emindir, saf kişiyi bilge kılar.   
\q1
\v 8 Yahve’nin kuralları doğrudur, yüreği sevindirir.  
\q2 Yahve’nin buyruğu paktır, gözleri aydınlatır.   
\q1
\v 9 Yahve korkusu temizdir, sonsuza dek kalıcıdır.  
\q2 Yahve’nin ilkeleri gerçektir ve tamamıyla doğrudur.   
\q1
\v 10 Altından, bol miktarda saf altından daha çok arzu edilir,  
\q2 baldan, süzme petek balından daha tatlıdır.   
\q1
\v 11 Üstelik hizmetkârını uyaran onlardır.  
\q2 Onlara uyanların ödülü büyüktür.   
\q1
\v 12 Kusurlarını kim fark edebilir?  
\q2 Gizli kusurlarımdan dolayı beni bağışla.   
\q1
\v 13 Hizmetkârını bilerek işlenen günahlardan uzak tut.  
\q2 Üzerimde hakimiyet kurmasınlar.  
\q2 O zaman doğru olurum.  
\q2 Büyük isyandan suçsuz ve masum çıkarım.   
\q1
\v 14 Ağzımdan çıkan sözler ve yüreğimin düşüncesi  
\q2 senin önünde kabul görsün,  
\q2 ey Yahve, kayam ve kurtarıcım.   
\c 20  
\d Müzik şefi için- David’in mezmuru  
\q1
\v 1 Yahve sıkıntılı gününde sana yanıt versin.  
\q2 Yakov'un Tanrısı'nın adı seni yükseltsin,   
\q1
\v 2 kutsal yerden sana yardım göndersin,  
\q2 Siyon’dan destek versin.   
\q1
\v 3 Bütün sunularını hatırlasın,  
\q2 yakmalık sunularını kabul etsin. Selah.   
\q1
\v 4 Sana yüreğine göre versin,  
\q2 ve bütün öğütlerini yerine getirsin.   
\q1
\v 5 Senin kurtarışında zafer kazanacağız.  
\q2 Tanrı’nın adıyla sancaklarımızı dikeceğiz.  
\q2 Yahve bütün dileklerini yerine getirsin.   
\q1
\v 6 Şimdi biliyorum ki, Yahve meshettiğini kurtarıyor.  
\q2 Sağ elinin kurtarıcı gücüyle,  
\q2 kutsal cennetten ona yanıt veriyor.   
\q1
\v 7 Bazıları savaş arabalarına, bazıları atlara güvenir,  
\q2 ama biz Tanrımız Yahve’nin adına güveniriz.   
\q1
\v 8 Onlar eğildiler ve düştüler,  
\q2 ama biz kalktık ve dik durduk.   
\q1
\v 9 Kurtar, ey Yahve!  
\q2 Seslendiğimizde Kral bize yanıt versin!   
\c 21  
\d Müzik şefi için David’in mezmuru  
\q1
\v 1 Kral senin gücüne sevinir, ey Yahve!  
\q2 Kurtarışınla ne büyük sevinç duyar!   
\q1
\v 2 Yüreğinin isteğini ona verdin,  
\q2 dudaklarının dileğini geri çevirmedin. Selah.   
\q1
\v 3 Çünkü iyilik bereketleriyle onu karşıladın.  
\q2 Başına saf altından taç koydun.   
\q1
\v 4 Senden yaşam istedi,  
\q2 sonsuza dek sürecek uzun günler verdin ona.   
\q1
\v 5 Senin kurtarışınla yüceliği büyüktür.  
\q2 Ona saygınlık ve yücelik giydirdin.   
\q1
\v 6 Çünkü sen onu daima en kutsanmış kıldın.  
\q2 Huzurunda onu sevinçle coşturdun.   
\q1
\v 7 Çünkü kral Yahve’ye güvenir,  
\q2 Yüceler Yücesi'nin sevgi dolu iyiliği sayesinde sarsılmaz.   
\q1
\v 8 Elin bütün düşmanlarını bulacak.  
\q2 Sağ elin senden nefret edenleri bulacaktır.   
\q1
\v 9 Öfkelendiğin zaman onları kızgın fırına çevireceksin.  
\q2 Yahve gazabıyla onları yutacak.  
\q2 Ateş onları yiyip bitirecektir.   
\q1
\v 10 Onların soyunu yeryüzünden,  
\q2 gelecek kuşaklarını insanoğulları arasından yok edeceksin.   
\q1
\v 11 Çünkü sana karşı kötülük etmeye niyetlendiler.  
\q2 Sana karşı başarılı olamayacak bir kötülük tasarladılar.   
\q1
\v 12 Çünkü sırtlarını döndüreceksin,  
\q2 gerilmiş yayını yüzlerine doğrulttuğunda.   
\q1
\v 13 Gücünle yüksel, ey Yahve,  
\q2 ezgiler söyleyip kudretini övelim.   
\c 22  
\d Müzik şefi için - “Tan Geyiği” makamında - David’in mezmuru  
\q1
\v 1 Tanrım, Tanrım, beni neden bıraktın?  
\q2 Neden bana yardım etmekten, iniltimin sözlerinden bu kadar uzaksın?   
\q1
\v 2 Tanrım, gündüz çağırıyorum ama yanıt vermiyorsun,  
\q2 geceleyin ve sessiz kalmıyorum.   
\q1
\v 3 Oysa sen kutsalsın,  
\q2 meskenini İsrael'in övgüleri üzerine kurarsın.   
\q1
\v 4 Atalarımız sana güvendi.  
\q2 Güvendiler ve sen de onları kurtardın.   
\q1
\v 5 Sana seslendiler ve kurtuldular.  
\q2 Sana güvendiler ve hayal kırıklığına uğramadılar.   
\q1
\v 6 Ama toprak kurduyum ben, insan değilim,  
\q2 insanların yüz karasıyım, halkın hor gördüğü biri.   
\q1
\v 7 Beni görenlerin hepsi benimle alay ediyor.  
\q2 Dudaklarıyla beni aşağılıyorlar. Başlarını sallayıp şöyle diyorlar:   
\q1
\v 8 “Yahve’ye güvendi.  
\q2 Onu kurtarsın.  
\q2 Madem ondan hoşlanıyor, onu kurtarsın bakalım!”   
\q1
\v 9 Oysa beni rahimden sen çıkardın.  
\q2 Ana kucağındayken güvenmemi sağladın.   
\q1
\v 10 Ana rahminden sana teslim edildim.  
\q2 Doğumumdan beri Tanrım sensin.   
\q1
\v 11 Benden uzak durma, çünkü sıkıntı yakın.  
\q2 Çünkü yardım edecek kimse yok.   
\q1
\v 12 Birçok boğalar beni kuşattı.  
\q2 Başan'ın güçlü boğaları çevremi sardı.   
\q1
\v 13 Bana karşı ağızlarını sonuna kadar açıyorlar,  
\q2 avını parçalayan aslanlar gibi kükrüyorlar.   
\q1
\v 14 Su gibi dökülüyorum.  
\q2 Bütün kemiklerim eklemlerinden çıktı.  
\q2 Yüreğim balmumu gibi,  
\q2 içimde eriyor.   
\q1
\v 15 Gücüm çömlek parçası gibi kurudu.  
\q2 Dilim damağıma yapışıyor.  
\q2 Beni ölüm toprağına yatırdın.   
\q1
\v 16 Çünkü köpekler çevremi sardı.  
\q2 Kötüler sürüsü beni kuşattı.  
\q2 Ellerimi ve ayaklarımı deldiler.\f + \fr 22:16 \ft Ölü Deniz Tomarları. Masoretik Metinde şöyle yazar: “Bir aslan gibi, ellerimi ve ayaklarımı iğneliyorlar.\f*   
\q1
\v 17 Bütün kemiklerimi sayabilirim.  
\q2 Gözlerini dikmiş, bana bakıyorlar.   
\q1
\v 18 Giysilerimi aralarında paylaşıyorlar.  
\q2 Elbisem için kura çekiyorlar.   
\q1
\v 19 Ama sen, ey Yahve, uzak durma!  
\q2 Sensin benim yardımcım. Bana yardım etmek için acele et!   
\q1
\v 20 Canımı kılıçtan,  
\q2 değerli yaşamımı köpeğin gücünden kurtar.   
\q1
\v 21 Aslanın ağzından kurtar beni!  
\q2 Evet, beni yaban öküzlerinin boynuzlarından kurtardın.   
\q1
\v 22 Adını kardeşlerime duyuracağım.  
\q2 Topluluğun ortasında seni öveceğim.   
\q1
\v 23 Ey Yahve'den korkanlar, O’nu övün!  
\q2 Ey Yakov soyu, O'nu yüceltin!  
\q2 Ey İsrael soyu, O'ndan korkun!   
\q1
\v 24 Çünkü O, mazlumun sıkıntısını küçümsemedi, tiksinmedi.  
\q2 Yüzünü de ondan gizlemedi;  
\q2 ama mazlum O’na seslenince, O sesini duydu.   
\q1
\v 25 Büyük toplulukta övgüm sendendir.  
\q2 O’ndan korkanların önünde adaklarımı yerine getireceğim.   
\q1
\v 26 Alçakgönüllüler yiyip doyacak.  
\q2 O’nu arayanlar Yahve'ye şükredecekler.  
\q2 Yürekleriniz sonsuza dek yaşasın.   
\q1
\v 27 Yeryüzünün bütün uçları hatırlayacak ve Yahve’ye dönecek.  
\q2 Ulusların bütün soyları senin önünde tapınacaklar.   
\q1
\v 28 Çünkü krallık Yahve’nindir.  
\q2 Uluslar üzerinde hükümdar O’dur.   
\q1
\v 29 Dünyanın bütün zenginleri yiyecek ve tapınacaklar.  
\q2 Toprağa inen herkes O’nun önünde eğilecek,  
\q2 canını hayatta tutamayanlar bile.   
\q1
\v 30 Gelecek kuşaklar O’na hizmet edecek.  
\q2 Sonraki kuşaklara Efendi anlatılacak.   
\q1
\v 31 Gelip O'nun doğruluğunu henüz doğmamış halka bildirecekler.  
\q2 Çünkü bunu O yaptı.   
\c 23  
\d David’in mezmuru  
\q1
\v 1 Yahve benim çobanımdır,  
\q2 hiç eksiğim olmaz.   
\q1
\v 2 Beni yeşil çayırlarda yatırır.  
\q2 Sakin suların yanına götürür.   
\q1
\v 3 Canımı onarır.  
\q2 Adı uğruna doğruluk yollarında bana rehberlik eder.   
\q1
\v 4 Ölüm gölgesindeki vadiden geçsem bile,  
\q2 kötülükten hiç korkmam, çünkü sen benimlesin.  
\q1 Senin asan, değneğin,  
\q2 onlar rahatlatır beni.   
\q1
\v 5 Düşmanlarımın huzurunda,  
\q2 önüme sofra kurarsın.  
\q1 Başımı yağla meshedersin.  
\q2 Kâsem taşmakta.   
\q1
\v 6 Kesinlikle hayatımın bütün günlerinde iyilik ve sevgi izleyecek beni,  
\q2 ve daima Yahve’nin evinde oturacağım.   
\c 24  
\d David’in mezmuru  
\q1
\v 1 Yahve’nindir yeryüzü, doluluğuyla birlikte.  
\q2 Dünya ve onda oturanlar.   
\q1
\v 2 Çünkü O’dur onu denizlerin üzerinde kuran,  
\q2 taşkınlar üzerinde durduran.   
\q1
\v 3 Yahve’nin dağına kim çıkabilir?  
\q2 Kim O’nun kutsal yerinde durabilir?   
\q1
\v 4 Elleri temiz, yüreği pak olan;  
\q2 canını yalana kaptırmamış,  
\q2 hileyle yemin etmemiştir böylesi.   
\q1
\v 5 O kişi Yahve’nin bereketini,  
\q2 kurtuluşunun Tanrısı’ndan gelen doğruluğu alacaktır.   
\q1
\v 6 Bu O'nu arayanların kuşağıdır,  
\q2 senin yüzünü arayanların— Yakov gibi. Selah.   
\q1
\v 7 Kaldırın başınızı, ey kapılar!  
\q2 Yükselin, ey ebedi kapılar,  
\q2 yücelik Kralı içeri girsin.   
\q1
\v 8 Kimdir o Yücelik Kralı?  
\q2 Yahve’dir O, güçlü ve kudretli,  
\q2 Yahve savaşta kudretlidir.   
\q1
\v 9 Kaldırın başınızı, ey kapılar,  
\q2 yükselin ey ebedi kapılar,  
\q2 yücelik Kralı içeri girsin.   
\q1
\v 10 Kimdir o yücelik Kralı?  
\q2 Ordular Yahvesi, yücelik Kralı O’dur! Selah.   
\c 25  
\d David’in mezmuru  
\q1
\v 1 Ey Yahve, canımı sana kaldırıyorum.   
\q1
\v 2 Tanrım, sana güvendim,  
\q2 utandırma beni.  
\q2 Düşmanlarımın bana galip gelmesine izin verme.   
\q1
\v 3 Seni bekleyen hiç kimse utanmayacak.  
\q2 Sebepsiz yere hainlik edenler utanacaklar.   
\q1
\v 4 Bana yollarını göster, ey Yahve.  
\q2 Bana yönlerini bildir.   
\q1
\v 5 Bana kendi gerçeğinde yol göster ve öğret,  
\q2 çünkü sen kurtuluşumun Tanrısı’sın,  
\q2 bütün gün seni bekliyorum.   
\q1
\v 6 Ey Yahve, sevecen merhametlerini ve sevgi dolu iyiliğini hatırla,  
\q2 çünkü onlar eski zamanlardan beri aynıdır.   
\q1
\v 7 Gençlik günahlarımı ve gençlik isyanlarımı anma.  
\q2 Beni sevgi dolu iyiliğinle,  
\q2 iyiliğine göre hatırla, ey Yahve.   
\q1
\v 8 Yahve iyi ve doğrudur,  
\q2 bu nedenle günahkârlara yolu gösterir.   
\q1
\v 9 Alçakgönüllülere adalet yolunda yol gösterecek.  
\q2 Kendi yolunu onlara öğretecek.   
\q1
\v 10 Antlaşmasını ve tanıklıklarını tutanlar için,  
\q2 Yahve’nin bütün yolları sevgi dolu iyilik ve gerçektir.   
\q1
\v 11 Adın uğruna, ey Yahve,  
\q2 günahımı bağışla, çünkü günahım büyüktür.   
\q1
\v 12 Yahve'den korkan adam kimdir?  
\q2 Yahve ona seçeceği yolu bildirecektir.   
\q1
\v 13 Onun canı rahat edecek.  
\q2 Soyu ülkeyi miras alacaktır.   
\q1
\v 14 Yahve’nin dostluğu kendisinden korkanlarladır.  
\q2 Onlara antlaşmasını gösterecektir.   
\q1
\v 15 Gözlerim hep Yahve’nin üstündedir,  
\q2 çünkü ayaklarımı ağdan O çıkarır.   
\q1
\v 16 Bana yüzünü çevir ve merhamet et,  
\q2 çünkü kimsesiz ve dertliyim.   
\q1
\v 17 Yüreğimin darlıkları çoğaldı.  
\q2 Beni sıkıntılarımdan kurtar.   
\q1
\v 18 Çektiğim sıkıntıları ve acıları gör de,  
\q2 bütün günahlarımı bağışla.   
\q1
\v 19 Düşmanlarıma bak, çünkü çokturlar.  
\q2 Şiddetle benden nefret ediyorlar.   
\q1
\v 20 Canımı koru, kurtar beni.  
\q2 Hayal kırıklığına uğramayayım, çünkü sana sığınıyorum.   
\q1
\v 21 Beni dürüstlük ve doğruluk korusun,  
\q2 çünkü seni bekliyorum.   
\q1
\v 22 Ey Tanrı, İsrael'i bütün sıkıntılarından kurtar.   
\c 26  
\d David’in mezmuru  
\q1
\v 1 Beni yargıla, ey Yahve, çünkü dürüstlüğümle yürüdüm.  
\q2 Sarsılmadan Yahve'ye güvendim.   
\q1
\v 2 Beni dene, ey Yahve, sına beni.  
\q2 Yüreğimi ve aklımı yokla.   
\q1
\v 3 Çünkü sevgi dolu iyiliğin gözlerimin önündedir.  
\q2 Senin gerçeğinde yürüdüm.   
\q1
\v 4 Hilekâr adamlarla oturmadım,  
\q2 ikiyüzlülerin arasına da girmem.   
\q1
\v 5 Kötülük yapanlar topluluğundan nefret ederim,  
\q2 kötülerle birlikte oturmam.   
\q1
\v 6 Ellerimi masumiyetle yıkar,  
\q2 sunağının etrafında dönerim, ey Yahve,   
\q1
\v 7 ta ki, şükran sesini duyurayım  
\q2 ve tüm harika işlerini anlatayım.   
\q1
\v 8 Ey Yahve, oturduğun evi,  
\q2 görkeminin bulunduğu yeri severim.   
\q1
\v 9 Canımı günahkârlarla,  
\q2 hayatımı kana susamış adamlarla bir araya getirme.   
\q1
\v 10 Kötülük ellerindedir,  
\q2 sağ elleri rüşvetle doludur.   
\q1
\v 11 Ama ben dürüstlüğümle yürüyeceğim.  
\q2 Beni kurtar ve bana merhamet et.   
\q1
\v 12 Ayağım düzlükte durur.  
\q2 Topluluklarda Yahve'yi yücelteceğim.   
\c 27  
\d David’in mezmuru  
\q1
\v 1 Yahve benim ışığım ve kurtuluşumdur.  
\q2 Kimden çekineyim?  
\q1 Yahve yaşamımın gücüdür.  
\q2 Kimden korkayım?   
\q1
\v 2 Kötüler etimi yemek için üzerime geldiklerinde,  
\q2 hasımlarım ve düşmanlarım bile tökezlediler ve düştüler.   
\q1
\v 3 Bana karşı bir ordu konaklasa,  
\q2 yüreğim korkmaz.  
\q2 Bana karşı savaş açılsa,  
\q2 yine de güvenimi korurum.   
\q1
\v 4 Yahve'den tek bir şey diledim ve onu ararım:  
\q2 Yahve’nin güzelliğini görüp,  
\q2 O’nun tapınağında hayran olmak için,  
\q2 hayatımın bütün günlerinde Yahve’nin evinde oturmaktır.   
\q1
\v 5 Çünkü sıkıntı gününde beni gizlice çardağında tutacak.  
\q2 Beni çadırının gizli yerinde saklayacak.  
\q2 Kaya üzerinde beni yükseltecek.   
\q1
\v 6 Artık başım çevremdeki düşmanlarımın üzerinde yükselecek.  
\q2 O’nun çadırında sevinç kurbanları sunacağım.  
\q2 Ezgilerle, ilahilerle Yahve’yi öveceğim.   
\q1
\v 7 Sesimle çağırdığımda duy, ey Yahve.  
\q2 Bana merhamet et, yanıtla beni.   
\q1
\v 8 “Yüzümü ara” dediğin zaman,  
\q2 yüreğim sana, “Yüzünü arıyorum, ey Yahve” dedi.   
\q1
\v 9 Yüzünü benden gizleme.  
\q2 Hizmetkârını öfkeyle uzaklaştırma.  
\q2 Yardımcım sen oldun.  
\q2 Bırakma, terk etme beni,  
\q2 ey kurtuluşumun Tanrısı.   
\q1
\v 10 Babamla annem beni terk ettiğinde,  
\q2 Yahve beni yukarı kaldırır.   
\q1
\v 11 Bana kendi yolunu öğret, ey Yahve.  
\q2 Düşmanlarımdan ötürü bana doğru yolda rehber ol.   
\q1
\v 12 Beni hasımlarımın keyfine bırakma,  
\q2 Çünkü yalancı tanıklar karşıma dikildi,  
\q2 şiddet soluyorlar.   
\q1
\v 13 Yaşayanlar diyarında Yahve’nin iyiliğini göreceğimden  
\q2 ben hâlâ eminim.   
\q1
\v 14 Yahve’yi bekle.  
\q2 Güçlü ol ve yüreğin cesaretli olsun.  
\q2 Evet, Yahve'yi bekle.   
\c 28  
\d David’in mezmuru  
\q1
\v 1 Ey Yahve, sana sesleniyorum,  
\q2 kayam benim, kulak tıkama sesime,  
\q2 bana karşı sessiz kalırsan,  
\q2 çukura inenler gibi olurum.   
\q1
\v 2 Sana haykırdığımda,  
\q2 ellerimi En Kutsal Yerine doğru kaldırdığımda,  
\q2 dileklerimin sesini duy.   
\q1
\v 3 Beni kötülerle, kötülüğün işçileriyle aynı yere çekme.  
\q2 Onlar komşularıyla barış konuşurlar ama yüreklerinde kötülük vardır.   
\q1
\v 4 Onlara yaptıklarına göre, işledikleri kötülüğün karşılığına göre ver.  
\q2 Ellerinin işlerine göre onlara ver.  
\q2 Onlara hak ettiklerinin karşılığını ver.   
\q1
\v 5 Madem Yahve’nin işlerine,  
\q2 ellerinin işine saygı duymuyorlar,  
\q2 Yahve onları yıkacak ve bina etmeyecektir.   
\q1
\v 6 Yahve’ye övgüler olsun,  
\q2 çünkü dileklerimin sesini duydu.   
\q1
\v 7 Yahve benim gücüm ve kalkanımdır.  
\q2 Yüreğim O’na güvendi ve yardım buldum.  
\q2 Bu nedenle yüreğim coşuyor.  
\q2 Ezgimle O’na şükredeceğim.   
\q1
\v 8 Yahve onların gücüdür.  
\q2 O, meshettiğinin kurtuluş kalesidir.   
\q1
\v 9 Halkını kurtar,  
\q2 mirasını kutsa.  
\q2 Onların çobanı ol,  
\q2 ve onları daima taşı.   
\c 29  
\d David’in mezmuru  
\q1
\v 1 Ey kudretli olanın oğulları, Yahve’ye verin,  
\q2 Yahve’ye yücelik ve güç verin.   
\q1
\v 2 Adından ötürü yüceliği Yahve’ye verin.  
\q2 Kutsal düzen içinde Yahve’ye tapının.   
\q1
\v 3 Yahve'nin sesi suların üstündedir.  
\q2 Yücelik Tanrısı,  
\q2 Yahve birçok sular üstünde gürlüyor.   
\q1
\v 4 Yahve'nin sesi güçlüdür.  
\q2 Yahve’nin sesi heybetle doludur.   
\q1
\v 5 Yahve’nin sesi sedir ağaçlarını kırar.  
\q2 Evet, Yahve Lübnan sedirlerini parçalar.   
\q1
\v 6 Onları buzağı gibi,  
\q2 Lübnan’ı ve Siryon’u yaban öküzü yavrusu gibi sıçratır.   
\q1
\v 7 Yahve’nin sesi şimşek gibi çakar.   
\q1
\v 8 Yahve'nin sesi çölü sarsar.  
\q2 Yahve Kadeş Çölü’nü sarsar.   
\q1
\v 9 Yahve’nin sesi geyikleri doğurtur,  
\q2 ormanları çıplak bırakır.  
\q2 O’nun tapınağındaki her şey “Yücesin!” diyor.   
\q1
\v 10 Yahve Tufan'da tahtına oturdu.  
\q2 Evet, Yahve sonsuza dek Kral olarak oturur.   
\q1
\v 11 Yahve halkına güç verir.  
\q2 Yahve halkını esenlikle kutsar.   
\c 30  
\d Tapınak adanırken söylenen bir ilahi  
\m David’in mezmuru  
\q1
\v 1 Seni överim, ey Yahve, çünkü beni ayağa kaldırdın,  
\q2 düşmanlarımı bana sevindirmedin.   
\q1
\v 2 Ey Yahve Tanrım, sana seslendim,  
\q2 ve bana şifa verdin.   
\q1
\v 3 Ey Yahve, canımı Şeol'den\f + \fr 30:3 \ft Şeol ölüler diyarıdır.\f* çıkardın.  
\q2 Çukura inmeyeyim diye beni hayatta tuttun.   
\q1
\v 4 Ey O’nun kutsalları, Yahve’yi ilahilerle övün.  
\q2 O'nun kutsal adına şükredin.   
\q1
\v 5 Çünkü öfkesi bir an içindir.  
\q2 Lütfu ise bir ömür.  
\q1 Ağlayış bir gece kalabilir,  
\q2 ama sabahleyin sevinç gelir.   
\q1
\v 6 Bense, bolluk içinde şöyle dedim:  
\q2 “Asla sarsılmayacağım.”   
\q1
\v 7 Ey Yahve, lütfunla dağımı sağlamlaştırdın;  
\q2 ama sen yüzünü gizleyince sıkıntı duydum.   
\q1
\v 8 Ey Yahve, sana seslendim.  
\q2 Efendime rica ettim:   
\q1
\v 9 “Eğer çukura inersem, yıkımımın ne yararı olur?  
\q2 Toprak seni över mi?  
\q2 Senin gerçeğini ilan eder mi?   
\q1
\v 10 Duy, ey Yahve, bana merhamet et.  
\q2 Yardımcım ol, ey Yahve!”   
\q1
\v 11 Yasımı benim için raksa çevirdin.  
\q2 Çulumu çıkardın ve bana sevinç giydirdin,   
\q1
\v 12 ta ki yüreğim seni ilahilerle övsün ve susmasın.  
\q2 Ey Yahve Tanrım, sana daima şükredeceğim!   
\c 31  
\d Müzik şefi için - David’in mezmuru  
\q1
\v 1 Ey Yahve, sana sığınıyorum,  
\q2 hiçbir zaman beni hayal kırıklığına uğratma.  
\q2 Beni kendi doğruluğunla kurtar.   
\q1
\v 2 Kulak ver bana.  
\q2 Beni tez kurtar.  
\q2 Bana güçlü bir kaya,  
\q2 beni kurtarmak için sığınacak ev ol.   
\q1
\v 3 Çünkü sen benim kayam ve kalemsin,  
\q2 bu nedenle, adın uğruna bana yol göster ve bana rehber ol.   
\q1
\v 4 Benim için gizlice kurdukları ağdan beni çekip çıkar,  
\q2 çünkü sen benim kalemsin.   
\q1
\v 5 Ruhumu ellerine emanet ediyorum.  
\q2 Gerçeğin Tanrısı, ey Yahve, beni kurtar.   
\q1
\v 6 Yalancı putlara saygı duyanlardan nefret ederim,  
\q2 ancak Yahve’ye güvenirim.   
\q1
\v 7 Senin sevgi dolu iyiliğinle sevinip coşacağım,  
\q2 çünkü çektiğim sıkıntıyı gördün.  
\q2 Canımı sıkıntılar içinde bildin.   
\q1
\v 8 Beni düşmanın eli içinde kapatmadın.  
\q2 Ayaklarımı geniş bir yere yerleştirdin.   
\q1
\v 9 Bana merhamet et, ey Yahve, çünkü sıkıntıdayım.  
\q2 Gözüm, canım, bedenim kederden eriyip gidiyor.   
\q1
\v 10 Çünkü ömrüm kederle geçti,  
\q2 yıllarım iniltiyle,  
\q2 suçumdan ötürü gücüm tükeniyor.  
\q2 Kemiklerim eriyip gidiyor.   
\q1
\v 11 Bütün düşmanlarım yüzünden  
\q2 komşularıma karşı büsbütün aşağılık birisi,  
\q2 tanıdıklarım için dehşet oldum.  
\q2 Beni sokakta görenler benden kaçar oldu.   
\q1
\v 12 Ölü bir adam gibi yüreklerinden unutulup gittim.  
\q2 Kırık bir çömlek gibiyim.   
\q1
\v 13 Çünkü birçok insanın iftiralarını duydum,  
\q2 her tarafta dehşet içinde.  
\q2 Onlar bana karşı düzen kurarken,  
\q2 canımı almak için anlaştılar.   
\q1
\v 14 Ama ben sana güveniyorum, ey Yahve.  
\q2 “Tanrım sensin” dedim.   
\q1
\v 15 Vakitlerim senin elinde.  
\q2 Beni düşmanlarımın elinden ve bana zulmedenlerden kurtar.   
\q1
\v 16 Yüzün hizmetkârının üzerinde parlasın.  
\q2 Beni sevgi dolu iyiliğinle kurtar.   
\q1
\v 17 Hayal kırıklığına uğramayayım, ey Yahve, çünkü seni çağırdım.  
\q2 Kötüler hayal kırıklığına uğrasınlar.  
\q2 Şeol'de\f + \fr 31:17 \ft Şeol ölüler diyarıdır.\f* sessiz kalsınlar.   
\q1
\v 18 Yalan söyleyen dudaklar sessiz kalsın,  
\q2 doğruların aleyhinde küstahça,  
\q2 Gurur ve küçümsemeyle konuşurlar.   
\q1
\v 19 Senden korkanlar için sakladığın,  
\q2 sana sığınanlar için yaptığın,  
\q2 İnsanoğlunun önündeki, iyiliğin ne büyüktür!   
\q1
\v 20 Onları huzurunun barınağında,  
\q2 insanların tuzaklarından gizlersin.  
\q2 Kavgacı dillerden bir çardakta onları saklarsın.   
\q1
\v 21 Yahve’ye övgüler olsun,  
\q2 çünkü güçlü bir kentte  
\q2 bana şaşılası sevgi dolu iyiliğini gösterdi.   
\q1
\v 22 Bana gelince, aceleyle, “Gözlerinin önünden atıldım” dedim.  
\q2 Yine de sana seslendiğimde dileklerimin sesini duydun.   
\q1
\v 23 Yahve’yi sevin, ey O’nun kutsalları!  
\q2 Yahve sadıkları korur,  
\q2 kibirli davrananlara tam karşılığını verir.   
\q1
\v 24 Ey sizler, Yahve’ye umut bağlayanlar, hepiniz,  
\q2 güçlü olun ve yüreğiniz cesaretli olsun.   
\c 32  
\d David’in mezmuru - Maskil  
\q1
\v 1 Ne mutlu itaatsizliği bağışlanmış,  
\q2 günahı örtülmüş olan insana.   
\q1
\v 2 Ne mutlu Yahve tarafından suçu sayılmayan,  
\q2 ruhunda hile olmayan insana.   
\q1
\v 3 Sustuğumda gün boyu inlemelerimden  
\q2 kemiklerim eridi.   
\q1
\v 4 Gece gündüz elin üzerimde ağırdı.  
\q2 Yaz sıcağında gücüm tükendi. Selah.   
\q1
\v 5 Günahımı sana itiraf ettim.  
\q2 Suçumu saklamadım.  
\q1 “Yahve'ye isyanlarımı itiraf edeceğim” dedim.  
\q2 Günahımın suçunu bağışladın. Selah.   
\q1
\v 6 Bunun için, bulunabileceğin sırada,  
\q2 tanrısal olan herkes sana dua etsin.  
\q2 Büyük sular taştığında kesinlikle ona erişemezler.   
\q1
\v 7 Sensin benim sığınağım.  
\q2 Beni sıkıntıdan korursun.  
\q2 Beni kurtuluş ezgileriyle kuşatırsın. Selah.   
\q1
\v 8 Eğiteceğim seni, gideceğin yolu sana öğreteceğim.  
\q2 Gözüm üzerinde, sana öğüt vereceğim.   
\q1
\v 9 Anlayışsız at ya da katır gibi olmayın.  
\q2 Onları tutmak için gem ve dizgin olmazsa,  
\q2 sana yaklaşamazlar.   
\q1
\v 10 Çok keder gelir kötülerin başına,  
\q2 ama güveni Yahve olanı sevgi dolu iyilik kuşatacaktır.   
\q1
\v 11 Ey doğrular, Yahve ile sevinin ve coşun!  
\q2 Ey yüreği doğru olanlar, sevinçle haykırın!   
\c 33  
\q1
\v 1 Ey doğrular, Yahve ile sevinin!  
\q2 Doğrulara övgü yaraşır.   
\q1
\v 2 Lir çalarak Yahve’ye şükredin.  
\q2 On telli arpla O'nu ilahilerle övün.   
\q1
\v 3 O’na yeni bir ezgi söyleyin.  
\q2 Sevinç çığlığıyla ustaca çalın!   
\q1
\v 4 Çünkü Yahve’nin sözü doğrudur.  
\q2 Bütün işlerini sadakatle yapar.   
\q1
\v 5 Doğruluğu ve adaleti sever.  
\q2 Dünya Yahve’nin sevgi dolu iyiliğiyle doludur.   
\q1
\v 6 Gökler Yahve’nin sözüyle,  
\q2 onların bütün orduları ağzının soluğuyla yaratıldı.   
\q1
\v 7 Denizin sularını bir yığın gibi toplar.  
\q2 Derinliklerini ambarlarda yığar.   
\q1
\v 8 Bütün yeryüzü Yahve'den korksun.  
\q2 Dünyada yaşayan herkes O’na hayranlık duysun.   
\q1
\v 9 Çünkü O söyledi ve oldu.  
\q2 O buyurdu ve sağlam durdu.   
\q1
\v 10 Yahve ulusların öğüdünü boşa çıkarır.  
\q2 Halkların düşüncelerini hiç eder.   
\q1
\v 11 Yahve’nin öğüdü sonsuza dek,  
\q2 yüreğinin düşünceleri tüm kuşaklar boyunca yerinde durur.   
\q1
\v 12 Ne mutlu Tanrısı Yahve olan ulusa,  
\q2 kendi mirası olarak seçtiği halka.   
\q1
\v 13 Yahve gökten bakar.  
\q2 Bütün insanoğullarını görür.   
\q1
\v 14 Yaşadığı yerden yeryüzünde yaşayanların tümünü gözler.   
\q1
\v 15 Her birinin yüreğine biçim veren,  
\q2 onların bütün işlerini tartan O’dur.   
\q1
\v 16 Asker çokluğuyla kurtulan kral yoktur.  
\q2 Ne de büyük gücüyle kurtulan bir yiğit vardır.   
\q1
\v 17 Güvenlik için at boştur,  
\q2 büyük gücüne karşın kimseyi kurtarmaz.   
\q1
\v 18 İşte, Yahve’nin gözü kendisinden korkanların,  
\q2 O’nun sevgi dolu iyiliğine umut bağlayanların üzerindedir.   
\q1
\v 19 Böylece onları ölümden kurtarır,  
\q2 kıtlık içinde onları yaşatır.   
\q1
\v 20 Canımız Yahve’yi bekler.  
\q2 O bizim yardımımız ve kalkanımızdır.   
\q1
\v 21 Yüreğimiz O’nda sevinç bulur,  
\q2 çünkü biz O'nun kutsal adına güvendik.   
\q1
\v 22 Madem umudumuz sende,  
\q2 sevgi dolu iyiliğin üzerimizde olsun, ey Yahve!   
\c 34  
\d David’in mezmuru Avimelek’in önünde kendini deli gibi gösterip kovulduğu, Gittiği zaman  
\q1
\v 1 \f + \fr 34:1 \ft Mezmurlar 34, her ayetin alfabedeki bir harfle başladığı (Alef'ten Tav'a doğru sıralanmış) bir akrostiş şiirdir.\f* Yahve’yi her zaman öveceğim.  
\q2 O’nun övgüsü hep ağzımda olacak.   
\q1
\v 2 Canım Yahve ile övünür.  
\q2 Alçakgönüllüler bunu duyup sevinsin.   
\q1
\v 3 Yahve'yi benimle birlikte övün.  
\q2 Adını hep birlikte yüceltelim.   
\q1
\v 4 Yahve’yi aradım ve bana yanıt verdi,  
\q2 ve beni tüm korkularımdan kurtardı.   
\q1
\v 5 O’na baktılar, ışıl ışıl parladılar.  
\q2 Yüzlerini asla utanç kaplamayacak.   
\q1
\v 6 Bu yoksul adam yakardı ve Yahve onu duydu,  
\q2 ve onu bütün sıkıntılarından kurtardı.   
\q1
\v 7 Yahve’nin meleği kendisinden korkanların çevresinde,  
\q2 ordugâh kurar, onları kurtarır.   
\q1
\v 8 Tadın ve görün, Yahve ne iyidir.  
\q2 Ne mutlu O'na sığınan insana.   
\q1
\v 9 Yahve'den korkun, ey O’nun kutsalları,  
\q2 çünkü O'ndan korkanların eksiği olmaz.   
\q1
\v 10 Genç aslanlar muhtaç olur, açlık çekerler,  
\q2 ama Yahve’yi arayanlar hiçbir iyilikten yoksun kalmaz.   
\q1
\v 11 Gelin ey çocuklar, beni dinleyin.  
\q2 Size Yahve korkusunu öğreteyim.   
\q1
\v 12 Kimdir yaşamı arzulayan kişi,  
\q2 iyilik görmek için uzun günler seven?   
\q1
\v 13 Dilini kötülükten,  
\q2 dudaklarını yalan söylemekten uzak tutsun.   
\q1
\v 14 Kötülükten uzak durun, iyilik yapın.  
\q2 Esenliği arayın ve ardınca gidin.   
\q1
\v 15 Yahve’nin gözleri doğruların üzerindedir.  
\q2 Kulakları onların feryadını duyar.   
\q1
\v 16 Yahve’nin yüzü kötülük yapanlara karşıdır,  
\q2 onların anılarını yeryüzünden kesip atar.   
\q1
\v 17 Doğrular feryat eder, Yahve duyar,  
\q2 onları bütün sıkıntılarından kurtarır.   
\q1
\v 18 Yahve yüreği kırık olanlara yakındır,  
\q2 ruhu ezilmiş olanları kurtarır.   
\q1
\v 19 Doğrunun dertleri çoktur,  
\q2 ama Yahve onu hepsinden kurtarır.   
\q1
\v 20 Bütün kemiklerini korur.  
\q2 Onlardan hiçbiri kırılmaz.   
\q1
\v 21 Kötüyü kötülük öldürür.  
\q2 Doğru kişiden nefret edenler mahkûm olurlar.   
\q1
\v 22 Yahve hizmetkârının canını kurtarır.  
\q2 O’na sığınanların hiçbiri mahkûm olmaz.   
\c 35  
\d David’in mezmuru  
\q1
\v 1 Ey Yahve, benimle çekişenlerle sen çekiş,  
\q2 bana karşı savaşanlarla sen savaş.   
\q1
\v 2 Küçük ve büyük kalkanı al,  
\q2 yardımım için ayağa kalk.   
\q1
\v 3 Mızrağı savur ve beni kovalayanları engelle.  
\q2 Canıma, “Senin kurtuluşun benim.” de.   
\q1
\v 4 Canımı almak isteyenler hayal kırıklığına uğrayıp rezil olsunlar.  
\q2 Bana kötülük düşünenler geri dönüp şaşkına dönsünler.   
\q1
\v 5 Rüzgârın önündeki saman çöpü gibi olsunlar,  
\q2 Yahve’nin meleği onları sürsün.   
\q1
\v 6 Yolları karanlık ve kaygan olsun,  
\q2 Yahve'nin meleği onların peşlerine düşsün.   
\q1
\v 7 Çünkü nedensiz yere benim için ağlarını çukurda gizlediler.  
\q2 Hiçbir sebep yokken canıma çukur kazdılar.   
\q1
\v 8 Habersiz yıkım üzerine gelsin.  
\q2 Gizlediği ağ kendisini yakalasın.  
\q2 O yıkımın içine kendisi düşsün.   
\q1
\v 9 Canım Yahve’de sevinç bulacak.  
\q2 O’nun kurtarışıyla sevinecek.   
\q1
\v 10 Bütün kemiklerim şöyle diyecek:  
\q2 “Senin gibisi var mı, ey Yahve,  
\q2 yoksulu kendisine göre çok güçlü olanın elinden,  
\q2 yoksulu, muhtacı soyguncudan kurtaran?”   
\q1
\v 11 Yalancı tanıklar ayağa kalkıyor.  
\q2 Bilmediğim şeyleri bana soruyorlar.   
\q1
\v 12 Canımı kederlendirmek için,  
\q2 iyiliğe karşı bana kötülük ediyorlar.   
\q1
\v 13 Ben ise, onlar hastalandıklarında çul kuşanırdım.  
\q2 Oruçla canımı alçaltırdım.  
\q2 Duam kendi bağrıma dönerdi.   
\q1
\v 14 Onlara dostum ya da kardeşimmiş gibi davranırdım.  
\q2 Annesi için yas tutan birisi gibi yas tutarak yere kapanırdım.   
\q1
\v 15 Ama benim sıkıntım karşısında sevindiler ve bir araya toplandılar.  
\q2 Saldırganlar bana karşı toplandılar ve ben bunu bilmiyordum.  
\q2 Bana saldırdılar ve durmadılar.   
\q1
\v 16 Ziyafetlerdeki kirli soytarılar gibi,  
\q2 bana dişlerini gıcırdattılar.   
\q1
\v 17 Ey Efendim, ne zamana dek bakacaksın?  
\q2 Canımı onların yok edişinden,  
\q2 yaşamımı genç aslanlardan kurtar.   
\q1
\v 18 Büyük toplantıda sana şükürler sunacağım.  
\q2 Kalabalığın ortasında seni öveceğim.   
\q1
\v 19 Düşmanlarım haksız yere bana karşı sevinmesinler;  
\q2 benden nedensiz yere nefret edenler,  
\q2 göz kırpmasınlar.   
\q1
\v 20 Çünkü onlar esenlikten söz etmezler,  
\q2 ama ülkenin sakin insanlarına karşı  
\q2 hileli sözler uydururlar.   
\q1
\v 21 Bana karşı ağızlarını sonuna kadar açtılar.  
\q2 “Oh! Oh! Gözümüz bunu gördü!” diyorlar.   
\q1
\v 22 Sen bunu gördün, ey Yahve. Sessiz kalma.  
\q2 Ey Efendim benden uzak durma.   
\q1
\v 23 Ey Tanrım, uyan, kalk ve savun beni!  
\q2 Ey Efendim, benim için gayrete gel!   
\q1
\v 24 Doğruluğuna göre beni haklı çıkar, ey Yahve Tanrım.  
\q2 Bana karşı sevinmelerine izin verme.   
\q1
\v 25 Yüreklerinde, “Oh! Dileğimiz buydu,  
\q2 onu yuttuk!” demesinler.   
\q1
\v 26 Felaketime sevinenler,  
\q2 hayal kırıklığına uğrayıp şaşkına dönsünler.  
\q2 Bana karşı kendilerini yüceltenler,  
\q2 utanç ve rezilliğe bürünsünler.   
\q1
\v 27 Haklı davamı destekleyenler,  
\q2 sevinçle haykırıp coşsunlar.  
\q2 Sürekli şöyle desinler:  
\q2 “Hizmetkârının bolluk içinde olmasından hoşlanan  
\q2 Yahve yücelsin!”   
\q1
\v 28 Dilim gün boyu senin doğruluğundan,  
\q2 övgülerinden söz edecek.   
\c 36  
\d Müzik şefi için- Yahve’nin hizmetkârı David’in mezmuru  
\q1
\v 1 Kötünün itaatsizliği hakkında yüreğimde bir esin var:  
\q2 “Gözünde Tanrı korkusu yoktur.”   
\q1
\v 2 Kendini beğendiği için,  
\q2 günahını fark edemez ve ondan nefret etmez.   
\q1
\v 3 Ağzının sözleri kötülük ve hiledir.  
\q2 Akıllı olmayı ve iyilik yapmayı bırakmıştır.   
\q1
\v 4 Yatağında kötülük tasarlar.  
\q2 Kendini iyi olmayan bir yola sokar.  
\q2 Kötülükten nefret etmez.   
\q1
\v 5 Sevgi dolu iyiliğin, ey Yahve, göklerdedir.  
\q2 Sadakatin gökyüzüne ulaşır.   
\q1
\v 6 Doğruluğun Tanrı'nın dağları,  
\q2 yargıların büyük derinlik gibidir.  
\q2 Ey Yahve, insanı ve hayvanı koruyan sensin.   
\q1
\v 7 Sevgi dolu iyiliğin ne değerli, ey Tanrı!  
\q2 İnsanoğulları kanatlarının gölgesine sığınır.   
\q1
\v 8 Evinin bolluğuyla bol bol doyacaklar.  
\q2 Senin zevklerinin ırmağından onlara içireceksin.   
\q1
\v 9 Çünkü yaşamın kaynağı sendedir.  
\q2 Senin ışığında ışığı göreceğiz.   
\q1
\v 10 Seni tanıyanlara sevgi dolu iyiliğini,  
\q2 yüreği doğru olanlara karşı doğruluğunu sürdür.   
\q1
\v 11 Gururlunun ayağının bana karşı gelmesine,  
\q2 kötünün elinin beni kovmasına izin verme.   
\q1
\v 12 Orada kötülük yapanlar düştü.  
\q2 Yıkıldılar ve kalkamazlar.   
\c 37  
\d David’in mezmuru  
\q1
\v 1 Kötülük edenler yüzünden üzülme,  
\q2 haksızlık yapanlara da özenme.   
\q1
\v 2 Çünkü yakında ot gibi biçilecekler,  
\q2 yeşil bitki gibi solup gidecekler.   
\q1
\v 3 Yahve’ye güven ve iyilik et.  
\q2 Ülkede otur ve güvenli otlakların tadını çıkar.   
\q1
\v 4 Yahve’den de zevk al,  
\q2 O da sana yüreğinin dileklerini verecektir.   
\q1
\v 5 Yolunu Yahve'ye teslim et.  
\q2 O’na güven,  
\q2 O da şunu yapacaktır:   
\q1
\v 6 Doğruluğunu ışık gibi,  
\q2 hakkını öğlen güneşi gibi parlatacaktır.   
\q1
\v 7 Yahve’de dinlen, O’nu sabırla bekle.  
\q2 Üzülme işi yolunda olup da,  
\q2 kötü planlarını gerçekleştiren kişi için.   
\q1
\v 8 Kızmaktan vazgeç, öfkeyi bırak.  
\q2 Üzülme, bu yalnızca kötülüğe sürükler.   
\q1
\v 9 Çünkü kötülük edenler kesilip atılacak,  
\q2 ama Yahve’yi bekleyenler ülkeyi miras alacak.   
\q1
\v 10 Kısa bir süre sonra kötüler yok olacak.  
\q2 Yerini arasan bile artık orada bulunmayacak.   
\q1
\v 11 Ama alçakgönüllüler ülkeyi miras alacaklar,  
\q2 taşkın esenlikten tad alacaklar.   
\q1
\v 12 Kötü doğruya karşı düzen kurar,  
\q2 ve ona diş gıcırdatır.   
\q1
\v 13 Efendi ona güler,  
\q2 çünkü onun gününün geldiğini görür.   
\q1
\v 14 Kötüler kılıç çekip yaylarını gerdiler,  
\q2 yoksulları ve muhtaçları yere sermek,  
\q2 yolu doğru olanları öldürmek için.   
\q1
\v 15 Onların kılıcı kendi yüreklerine girecek,  
\q2 yayları kırılacaktır.   
\q1
\v 16 Doğrunun azı,  
\q2 birçok kötünün bolluğundan daha iyidir.   
\q1
\v 17 Çünkü kötülerin gücü kırılacak,  
\q2 ama Yahve doğrulara destek olur.   
\q1
\v 18 Yahve kusursuz olanların günlerini bilir.  
\q2 Onların mirası daima kalıcıdır.   
\q1
\v 19 Kötülük zamanında hayal kırıklığına uğramayacaklar.  
\q2 Kıtlık günlerinde doyurulacaklar.   
\q1
\v 20 Ama kötüler yok olacaklar.  
\q2 Yahve’nin düşmanları kırların güzelliğine benzeyecek.  
\q2 Duman gibi dağılıp yok olacak.   
\q1
\v 21 Kötü kişi ödünç alır da geri vermez,  
\q2 ama doğru kişi cömertçe verir.   
\q1
\v 22 Çünkü O’nun kutsadıkları ülkeyi miras alacak.  
\q2 O’nun lanetledikleri kesilip atılacaktır.   
\q1
\v 23 İnsanın adımları Yahve tarafından pekiştirilir.  
\q2 Onun yolundan hoşnuttur.   
\q1
\v 24 Tökezlese de düşmez,  
\q2 çünkü elinden tutan Yahve’dir.   
\q1
\v 25 Gençtim, şimdi yaşlandım,  
\q2 yine de doğruların terk edildiğini,  
\q2 ve de çocuklarının ekmek dilendiğini hiç görmedim.   
\q1
\v 26 Bütün gün merhametle davranır ve ödünç verir.  
\q2 Onun soyu kutsanır.   
\q1
\v 27 Kötülükten uzak dur, iyilik et.  
\q2 Sonsuza dek güven içinde yaşa.   
\q1
\v 28 Çünkü Yahve adaleti sever,  
\q2 kutsallarını terk etmez.  
\q2 Onlar daima korunur,  
\q2 ama kötülerin soyu kesilip atılacak.   
\q1
\v 29 Doğrular ülkeyi miras alacak,  
\q2 ve daima içinde yaşayacaklar.   
\q1
\v 30 Doğrunun ağzı bilgelik konuşur.  
\q2 Dili adaleti söyler.   
\q1
\v 31 Tanrısı’nın yasası yüreğindedir.  
\q2 Adımlarından hiçbiri kaymaz.   
\q1
\v 32 Kötü doğruyu gözetler,  
\q2 onu öldürmenin yolunu arar.   
\q1
\v 33 Yahve onu kötünün eline bırakmaz,  
\q2 yargılandığında onu mahkûm etmez.   
\q1
\v 34 Yahve'yi bekle, O’nun yolunu tut,  
\q2 ülkeyi miras almak için seni yükseltecektir.  
\q2 Kötüler kesilip atıldığı zaman, bunu göreceksin.   
\q1
\v 35 Kötüyü büyük güç içinde gördüm,  
\q2 yeşil bir ağaç gibi bittiği yerde yayılmış.   
\q1
\v 36 Ama gelip geçti işte, artık o yok.  
\q2 Onu aradım ama bulunamadı.   
\q1
\v 37 Kusursuz adamın üzerine bir nişan koy, doğru adama bak,  
\q2 çünkü gelecek esenlik adamınındır.   
\q1
\v 38 İsyan edenlere gelince, onlar hep birlikte yok edilecekler.  
\q2 Kötülerin geleceği kesilip atılacaktır.   
\q1
\v 39 Ama doğruların kurtuluşu Yahve'dendir.  
\q2 O, sıkıntı zamanlarında onların kalesidir.   
\q1
\v 40 Yahve onlara yardım eder ve onları kurtarır.  
\q2 Onları kötülerin elinden kurtarıp özgür kılar,  
\q2 çünkü O’na sığındılar.   
\c 38  
\d Anma sunusu için David’in mezmuru  
\q1
\v 1 Ey Yahve, öfkenle beni azarlama,  
\q2 gazapla beni yola getirme.   
\q1
\v 2 Çünkü okların beni deldi,  
\q2 elin üzerime ağır basıyor.   
\q1
\v 3 Öfken yüzünden bedenime rahat yok,  
\q2 günahımdan ötürü kemiklerimde de hiç sağlık kalmadı.   
\q1
\v 4 Çünkü kötülüklerim başımı aştı.  
\q2 Ağır bir yük gibi, bana çok ağır geldiler.   
\q1
\v 5 Akılsızlığım yüzünden,  
\q2 yaralarım iğrenç ve irinlidir.   
\q1
\v 6 Acı çekiyorum, iki büklüm eğildim.  
\q2 Bütün gün yas içindeyim.   
\q1
\v 7 Çünkü belim ateşle dolu.  
\q2 Bedenimde hiçbir rahat yok.   
\q1
\v 8 Baygınım ve alabildiğine yaralıyım.  
\q2 Yüreğimin acısından inliyorum.   
\q1
\v 9 Ey Efendim, bütün dileğim senin önündedir.  
\q2 İnlemelerim senden gizli değil.   
\q1
\v 10 Yüreğim çarpıyor.  
\q2 Gücüm tükeniyor.  
\q2 Gözlerimin feri de beni terk etti.   
\q1
\v 11 Sevenlerim ve dostlarım felaketimden uzak duruyorlar.  
\q2 Akrabalarım da uzakta durmaktalar.   
\q1
\v 12 Canımı almanın yolunu arayanlar da tuzak kuruyorlar.  
\q2 Zararımı arayanlar kötü söz söylüyorlar,  
\q2 gün boyu hileler düşünüyorlar.   
\q1
\v 13 Ama ben sağır biri gibi duymuyorum.  
\q2 Ağzını açmayan dilsiz gibiyim.   
\q1
\v 14 Ağzında yanıt olmayan,  
\q2 duymayan biri gibiyim.   
\q1
\v 15 Çünkü ben sana güveniyorum, ey Yahve.  
\q2 Sen yanıtlayacaksın, ey Efendi Tanrım.   
\q1
\v 16 Çünkü dedim ki, “Benden ötürü sevinmesinler,  
\q2 ayağım kayınca böbürlenmesinler.”   
\q1
\v 17 Çünkü ben düşmek üzereyim.  
\q2 Kederim hep önümde.   
\q1
\v 18 Çünkü suçumu itiraf ederim.  
\q2 Günahımdan ötürü üzgünüm.   
\q1
\v 19 Ama düşmanlarım güçlü ve çoktur.  
\q2 Benden nedensiz yere nefret edenler çoktur.   
\q1
\v 20 İyiliğe karşılık kötülük yapanlar bana karşıdırlar,  
\q2 çünkü ben iyilik peşindeyim.   
\q1
\v 21 Beni bırakma, ey Yahve!  
\q2 Ey Tanrım, benden uzak durma.   
\q1
\v 22 Tez yardım et bana,  
\q2 ey Efendim, kurtuluşum benim.   
\c 39  
\d Müzik Şefi Yedutun için - David’in mezmuru  
\q1
\v 1 Şöyle dedim: “Dilimle günah işlemeyeyim diye  
\q2 yollarıma dikkat edeceğim.  
\q2 Kötü kişi karşımdayken,  
\q2 ağzıma gem vuracağım.”   
\q1
\v 2 Dilimi tutup sessiz kaldım.  
\q2 İyilik için bile sustum.  
\q2 Acım katlandı.   
\q1
\v 3 Yüreğim yandı içimde.  
\q2 Derin derin düşünürken ateş alevlendi.  
\q2 Dilimle dedim:   
\q1
\v 4 “Ey Yahve, bana sonumu göster,  
\q2 günlerimin ölçüsü nedir?  
\q2 Ne kadar kırılgan olduğumu bana bildir.   
\q1
\v 5 İşte günlerimi bir karış kıldın.  
\q2 Ömrüm senin önünde bir hiç gibidir.  
\q2 Besbelli herkes bir soluktur.” Selah.   
\q1
\v 6 “Her insan kuşkusuz gölge gibi dolaşır.  
\q2 Gerçekten boş yere didinir durur.  
\q2 Yığar ama onu kimin toplayacağını bilmez.   
\q1
\v 7 Şimdi, ey Efendim, ben neyi bekliyorum?  
\q2 Umudum sende.   
\q1
\v 8 Beni bütün suçlarımdan kurtar.  
\q2 Akılsızların beni ayıplamasına izin verme.   
\q1
\v 9 Sustum,  
\q2 ağzımı açmadım.  
\q2 Çünkü sen bunu yaptın.   
\q1
\v 10 Kamçını benden uzaklaştır.  
\q2 Elinin vuruşuyla mahvoldum.   
\q1
\v 11 İnsanı suçundan ötürü  
\q2 azarlayıp yola getirdiğinde,  
\q2 servetini güve gibi tüketirsin.  
\q2 Kesinlikle her insan yalnızca bir soluktur.” Selah.   
\q1
\v 12 “Duamı işit, ey Yahve, feryadıma kulak ver.  
\q2 Gözyaşlarıma sessiz kalma.  
\q2 Çünkü senin yanında ben bir garibim.  
\q2 Bütün atalarım gibi bir yabancı.   
\q1
\v 13 Beni esirge de gücüme kavuşayım,  
\q2 göçüp yok olmadan önce.”   
\c 40  
\d Müzik şefi için - David’in mezmuru  
\q1
\v 1 Yahve’yi sabırla bekledim.  
\q2 Bana döndü ve feryadımı duydu.   
\q1
\v 2 Beni korkunç bir çukurdan, balçıktan çıkardı,  
\q2 ayaklarımı bir kaya üzerinde durdurdu.  
\q2 Ayakta durabileceğim sağlam bir yer verdi.   
\q1
\v 3 Ağzıma yeni bir ezgi,  
\q2 Tanrımız’a bir övgü ilahisi koydu.  
\q2 Birçokları bunu görüp korkacak,  
\q2 ve Yahve’ye güvenecekler.   
\q1
\v 4 Ne mutlu Yahve’ye güvenen insana,  
\q2 kibirlilere, yalana sapanlara saygı duymayana.   
\q1
\v 5 Ey Yahve, Tanrım, yaptığın harikalar,  
\q2 bize yönelik düşüncelerin ne çoktur.  
\q2 Onlar sana geri bildirilemezler.  
\q2 İlan edip anlatmak istesem,  
\q2 sayılamayacak kadar çoktur.   
\q1
\v 6 Kurban ve sunuyu istemedin.  
\q2 Kulaklarımı açtın.  
\q2 Yakmalık sunu ve günah sunusunu da istemedin.   
\q1
\v 7 O zaman şöyle dedim: “İşte geldim.  
\q2 Kutsal Yazı tomarında benim için yazılmıştır.   
\q1
\v 8 İsteğini yerine getirmekten zevk alırım, ey Tanrım.  
\q2 Yasan yüreğimin içindedir.”   
\q1
\v 9 Büyük toplulukta doğruluk müjdesini ilan ettim.  
\q2 İşte, dudaklarımı mühürlemeyeceğim,  
\q2 ey Yahve, sen bilirsin.   
\q1
\v 10 Doğruluğunu yüreğimin içinde saklamadım.  
\q2 Sadakatini ve kurtuluşunu ilan ettim.  
\q2 Sevgi dolu iyiliğini ve gerçeğini büyük topluluktan gizlemedim.   
\q1
\v 11 Sevecen merhametlerini benden esirgeme, ey Yahve.  
\q2 Sevgi dolu iyiliğin ve gerçeğin beni hep korusun.   
\q1
\v 12 Çünkü sayısız kötülük çevremi sardı.  
\q2 Suçlarım beni ele geçirdi, artık başımı kaldıramıyorum.  
\q2 Onlar başımdaki saçlardan daha çoktur.  
\q2 Yüreğim beni bıraktı.   
\q1
\v 13 Ey Yahve, beni kurtarmaya razı ol.  
\q2 Ey Yahve, tez yardımıma koş.   
\q1
\v 14 Canımı almanın yolunu arayanlar,  
\q2 hepsi hayal kırıklığına uğrayıp utansınlar.  
\q2 Acı çekmemden zevk duyanlar,  
\q2 geri dönüp rezil olsunlar.   
\q1
\v 15 Bana, “Oh! Oh” çekenler  
\q2 utançlarından perişan olsunlar.   
\q1
\v 16 Seni arayanların hepsi  
\q2 sende sevinip coşsunlar.  
\q2 Kurtarışını sevenler sürekli şöyle söylesin: “Yahve yücelsin!”   
\q1
\v 17 Ama ben yoksul ve muhtacım.  
\q2 Efendim beni düşünsün.  
\q2 Sen benim yardımcım ve kurtarıcımsın.  
\q2 Gecikme, ey Tanrım.   
\c 41  
\d Müzik şefi için- David’in mezmuru  
\q1
\v 1 Ne mutlu yoksulu düşünen insana.  
\q2 Yahve kurtarır onu kötü günde.   
\q1
\v 2 Yahve onu korur ve yaşatır.  
\q2 Yeryüzünde onu kutsar.  
\q2 Onu düşmanlarının keyfine bırakmaz.   
\q1
\v 3 Yahve hasta yatağında ona destek olur,  
\q2 hastalık yatağından kaldırır onu.   
\q1
\v 4 “Ey Yahve, bana merhamet et!” dedim.  
\q2 “Beni iyileştir, çünkü sana karşı günah işledim.”   
\q1
\v 5 Düşmanlarım bana karşı kötülük konuşuyor:  
\q2 “Ne zaman ölecek ve adı yok olacak?”   
\q1
\v 6 Eğer biri beni görmeye gelirse yalan konuşuyor.  
\q2 Yüreği kendine kötülük biriktiriyor.  
\q2 Dışarı çıktığında bunu söylüyor.   
\q1
\v 7 Benden nefret edenlerin hepsi bana karşı fısıldaşıyor.  
\q2 Benim için en kötüsünü düşünüyorlar.   
\q1
\v 8 “Kötü bir hastalık bulaştı ona” diyorlar.  
\q2 “İşte yattı, bir daha kalkamaz.”   
\q1
\v 9 Ekmeğimi yiyen,  
\q2 güvendiğim yakın dostum bile,  
\q2 bana karşı topuklarını kaldırdı.   
\q1
\v 10 Ama sen, ey Yahve, bana merhamet et,  
\q2 beni kaldır ki, onlara karşılığını vereyim.   
\q1
\v 11 Bununla benden hoşnut olduğunu bileceğim.  
\q2 Çünkü düşmanım bana galip gelemeyecek.   
\q1
\v 12 Bana gelince, dürüstlüğümde bana destek olur,  
\q2 sonsuza dek beni huzurunda durdurursun.   
\q1
\v 13 İsrael'in Tanrısı Yahve'ye öncesizlikten sonsuza dek,  
\q2 övgüler olsun!  
\q2 Amin ve amin.   
\c 42  
\d Müzik şefi için - Korahoğulları’nın Maskili  
\q1
\v 1 Geyiğin akarsuları özlediği gibi,  
\q2 canım da seni öyle özler, ey Tanrı.\f + \fr 42:1 \ft “Tanrı” olarak tercüme edilen İbranice kelime “אֱלֹהִ֑ים” (Elohim)’dir.\f*   
\q1
\v 2 Canım Tanrı'ya, yaşayan Tanrı'ya susadı.  
\q2 Ne zaman gelip Tanrı'nın önünde görüneceğim?   
\q1
\v 3 Gözyaşlarım gece gündüz yemeğim oldu,  
\q2 bana sürekli “Tanrın nerede?” diye soruyorlar.   
\q1
\v 4 Şunları hatırlıyor, canımı içime döküyorum;  
\q2 sevinç ve övgü sesiyle nasıl gider,  
\q2 Kutsal Günü kutlayan toplulukla birlikte,  
\q2 onları Tanrı'nın evine nasıl götürürdüm.   
\q1
\v 5 Neden umutsuzsun, ey canım?  
\q2 Neden içim huzursuz?  
\q2 Tanrı’ya umut bağla!  
\q2 Çünkü kurtaran varlığınla yardımcım olduğun için  
\q2 O’nu yine de öveceğim.   
\q1
\v 6 Ey Tanrım, canım iç varlığımda umutsuzluk içinde.  
\q2 Bu yüzden Yarden diyarından,  
\q2 Hermon dağlarından, Misar Tepesi’nden seni hatırlıyorum.   
\q1
\v 7 Çağlayanların ses çıkarınca derin derinliğe sesleniyor.  
\q2 Bütün dalgaların ve sellerin üzerimden geçti.   
\q1
\v 8 Yahve\f + \fr 42:8 \ft “Yahve” Tanrı’nın asıl ismidir, diğer çevirilerde bazen “RAB=EFENDİ” (tamamı büyük harflerle) olarak çevrilir.\f* gündüz vakti  
\q2 sevgi dolu iyiliğini buyurur.  
\q2 Gece vakti O’nun ezgisi,  
\q2 yaşamımın Tanrısı’na dua benimledir.   
\q1
\v 9 Kayam olan Tanrı'ya diyeceğim: “Beni neden unuttun?  
\q2 Düşmanın zulmü yüzünden neden yas tutuyorum?”   
\q1
\v 10 Düşmanlarım kemiklerime saplanmış bir kılıç gibi,  
\q2 hakaret ediyorlar,  
\q2 bana sürekli “Tanrın nerede?” diye soruyorlar.   
\q1
\v 11 Neden umutsuzsun, ey canım?  
\q2 Neden içim huzursuz?  
\q2 Tanrı’ya umut bağla! Çünkü yine de O’nu öveceğim,  
\q2 yüzümün kurtuluşu ve Tanrım O’dur.   
\c 43  
\q1
\v 1 Davamı gör, ey Tanrım,  
\q2 tanrısız ulusa karşı davamı savun.  
\q2 Beni hileci ve kötü insanlardan kurtar.   
\q1
\v 2 Çünkü sen benim gücümün Tanrısı’sın.  
\q2 Beni neden reddettin?  
\q2 Düşmanın zulmünden ötürü neden yas tutayım?   
\q1
\v 3 Işığını ve gerçeğini gönder.  
\q2 Bana yol göstersinler.  
\q2 Beni kutsal dağına, çadırına götürsünler.   
\q1
\v 4 O zaman Tanrı'nın sunağına,  
\q2 büyük sevincim olan Tanrım'a gideceğim.  
\q2 Seni arpla öveceğim, Tanrım, Tanrım benim.   
\q1
\v 5 Neden umutsuzluk içindesin, ey canım?  
\q2 Neden içim huzursuz?  
\q2 Tanrı’ya umut bağla!  
\q2 Çünkü yine O’nu öveceğim.  
\q2 Kurtarıcım, yardımcım, Tanrım benim.   
\c 44  
\d Müzik şefi için - Korahoğulları’nın Maskili  
\q1
\v 1 Kulaklarımızla duyduk, ey Tanrı,  
\q2 atalarımız onların günlerinde, eski günlerde,  
\q2 yaptığın işi bize anlattı.   
\q1
\v 2 Ulusları elinle kovdun,  
\q2 ama onları diktin.  
\q2 Halkları kırdın,  
\q2 ama onları yaydın.   
\q1
\v 3 Çünkü ülkeyi kendi kılıçlarıyla mülk edinmediler,  
\q2 onları kurtaran kendi kolları da değildi.  
\q2 Ancak senin sağ elin, kolun ve yüzünün ışığıydı.  
\q2 Çünkü sen onları kayırdın.   
\q1
\v 4 Ey Tanrı, sensin benim Kralım.  
\q2 Yakov için zaferleri buyur!   
\q1
\v 5 Senin sayende düşmanlarımızı devireceğiz.  
\q2 Bize karşı ayaklananları senin adınla ezeceğiz.   
\q1
\v 6 Çünkü ben yayıma güvenmem,  
\q2 kılıcım da beni kurtarmaz.   
\q1
\v 7 Ama sensin bizi düşmanlarımızdan kurtaran,  
\q2 bizden nefret edenleri utandıran.   
\q1
\v 8 Bütün gün Tanrı'yla övünürüz.  
\q2 Adına daima şükrederiz. Selah.   
\q1
\v 9 Ama şimdi sen bizi reddettin ve bizi utandırdın,  
\q2 ordularımızla yola çıkmıyorsun.   
\q1
\v 10 Bizi düşmanın önünde geri döndürüyorsun.  
\q2 Bizden nefret edenler kendileri için yağma topluyorlar.   
\q1
\v 11 Bizi yenilecek koyun gibi ettin,  
\q2 bizi ulusların arasına dağıttın.   
\q1
\v 12 Halkını bedavaya sattın,  
\q2 satışından da hiçbir şey kazanmadın.   
\q1
\v 13 Bizi komşularımıza yüzkarası,  
\q2 çevremizdekiler için eğlence ve alay konusu ettin.   
\q1
\v 14 Halklar arasında baş sallansın diye,  
\q2 bizi ulusların diline düşürdün.   
\q1
\v 15 Rezilliğim gün boyu gözümün önünde,  
\q2 utanç yüzümü kaplıyor,   
\q1
\v 16 hakaret ve sövgüde bulunanın alayıyla,  
\q2 düşmanın ve intikamcının yüzünden.   
\q1
\v 17 Bütün bunlar başımıza geldi,  
\q2 yine de seni unutmadık.  
\q2 Antlaşmana ihanet etmedik.   
\q1
\v 18 Yüreğimiz geriye dönmedi,  
\q2 adımlarımız da senin yolundan sapmadı,   
\q1
\v 19 oysa sen bizi çakalların yerinde ezdin,  
\q2 Üstümüzü ölümün gölgesiyle örttün.   
\q1
\v 20 Eğer Tanrımız'ın adını unuttuysak,  
\q2 ya da ellerimizi yabancı bir ilâha uzattıysak,   
\q1
\v 21 Tanrı bunu araştırmaz mıydı?  
\q2 Çünkü O, yürekteki gizleri bilir.   
\q1
\v 22 Evet, senin uğruna bütün gün öldürülüyoruz.  
\q2 Kasaplık koyunlar gibi görülüyoruz.   
\q1
\v 23 Uyan!  
\q2 Neden uyuyorsun ey Efendim?\f + \fr 44:23 \ft “Efendi” olarak tercüme edilen sözcük “Adonay”dır. \f*  
\q2 Kalk!  
\q2 Bizi sonsuza dek reddetme.   
\q1
\v 24 Neden yüzünü gizliyorsun?  
\q2 Çektiğimiz acıyı, üzerimizdeki baskıyı unutacak mısın?   
\q1
\v 25 Çünkü canımız toprağa kadar eğildi.  
\q2 Bedenimiz toprağa yapıştı.   
\q1
\v 26 Kalk, yardım et bize.  
\q2 Sevgi dolu iyiliğin uğruna bizi kurtar.   
\c 45  
\d Müzik şefi için - “Zambaklar” makamında Korahoğulları’nın Maskili - Bir düğün ilahisi  
\q1
\v 1 Yüreğim asil bir temayla dolup taşıyor.  
\q2 Kral için okuyorum şiirlerimi.  
\q2 Dilim usta bir yazarın kalemi gibidir.   
\q1
\v 2 Sen insanoğullarının en harikasısın.  
\q2 Dudakların lütufla meshedilmiş.  
\q2 Bunun için Tanrı seni sonsuza dek kutsamış.   
\q1
\v 3 Ey kudretli, kılıcını beline,  
\q2 ihtişamını ve heybetini kuşan.   
\q1
\v 4 Gerçek, alçakgönüllülük ve doğruluk uğruna,  
\q2 heybetinle zaferle ilerle.  
\q2 Sağ elin harika işler sergilesin.   
\q1
\v 5 Okların sivridir.  
\q2 Kral düşmanlarının yüreğine saplanır,  
\q2 uluslar altında yıkılır.   
\q1
\v 6 Tahtın sonsuza dek kalıcıdır, ey Tanrı.  
\q2 Krallığının asası adalet asasıdır.   
\q1
\v 7 Doğruluğu sevdin ve kötülükten nefret ettin.  
\q2 Bunun için Tanrı, senin Tanrın,  
\q2 seni akranlarından daha çok sevinç yağıyla meshetti.   
\q1
\v 8 Bütün giysilerin mür, öd ve tarçın kokar.  
\q2 Fildişi saraylardan telli çalgılar seni sevindirir.   
\q1
\v 9 Kral kızları senin saygın kadınların arasındadır.  
\q2 Kraliçe, Ofir altınları içinde senin sağında duruyor.   
\q1
\v 10 Dinle kızım, düşün ve kulak ver.  
\q2 Halkını, babanın evini de unut.   
\q1
\v 11 Böylece Kral senin güzelliğini arzulayacak,  
\q2 saygı duy O'na, çünkü efendin O'dur.   
\q1
\v 12 Sur kızı bir hediyeyle geliyor.  
\q2 Halkın zenginleri senin lütfunu dileyecekler.   
\q1
\v 13 Tüm ihtişamıyla kral kızı içerdedir.  
\q2 Giysileri altınla dokunmuştur.   
\q1
\v 14 İşlemeli giysiler içinde kralın huzuruna çıkarılacak.  
\q2 Onu takip eden arkadaşları, el değmemiş kızlar sana getirilecek.   
\q1
\v 15 Sevinç ve coşkuyla götürülecekler.  
\q2 Kralın sarayına girecekler.   
\q1
\v 16 Oğulların atalarının yerini alacak.  
\q2 Onları bütün dünyaya beyler yapacaksın.   
\q1
\v 17 Adını kuşaklar boyu anımsatacağım.  
\q2 Bunun için halklar daima sana şükredecekler.   
\c 46  
\d Müzik şefi için - Alamot\f + \fr 46:0 \ft Alamot bir müzik terimidir.\f* - Korahoğulları ezgisi  
\q1
\v 1 Tanrı sığınağımız ve gücümüzdür,  
\q2 sıkıntıda hemen yardıma hazırdır.   
\q1
\v 2 Bu nedenle, dünya altüst olsa,  
\q2 dağlar denizlerin bağrına yıkılsa,   
\q1
\v 3 suları kükreyip çalkalansa,  
\q2 kabaran deniz dağları titretse bile,  
\q2 biz korkmayız. Selah.   
\q1
\v 4 Bir ırmak var ki,  
\q2 suları Tanrı kentini,  
\q1 Yüceler Yücesi'nin kutsal çadırlarını sevindirir.   
\q1
\v 5 Tanrı onun ortasındadır. Sarsılmaz o.  
\q2 Gün doğarken Tanrı ona yardım eder.   
\q1
\v 6 Uluslar hiddetlendi. Krallıklar sarsıldı.  
\q2 O sesini yükseltince dünya eriyip gitti.   
\q1
\v 7 Ordular Yahvesi bizimledir.  
\q2 Yakov’un Tanrısı bizim sığınağımızdır. Selah.   
\q1
\v 8 Gelin, Yahve’nin işlerini görün,  
\q2 yeryüzünde ne büyük yıkımlar yaptı.   
\q1
\v 9 Dünyanın ucuna kadar savaşları durdurur.  
\q2 Yayı kırar, mızrağı parçalar.  
\q2 Savaş arabalarını ateşte yakar.   
\q1
\v 10 “Sakin olun, bilin ki, Tanrı benim!  
\q2 Uluslar arasında yüceleceğim.  
\q2 Yeryüzünde yüceleceğim.”   
\q1
\v 11 Ordular Yahvesi bizimledir.  
\q2 Yakov’un Tanrısı bizim sığınağımızdır. Selah.   
\c 47  
\d Müzik şefi için - Korahoğulları’nın mezmuru  
\q1
\v 1 Ey bütün uluslar, el çırpın.  
\q2 Zafer sesiyle Tanrı'ya sesinizi yükseltin!   
\q1
\v 2 Çünkü Yüce Yahve muhteşemdir.  
\q2 O, tüm dünyanın üzerinde büyük Kral’dır.   
\q1
\v 3 Ulusları altımıza,  
\q2 halkları ayaklarımızın altına serdi.   
\q1
\v 4 Sevdiği Yakov’un yüceliği olan mirasımızı,  
\q2 O bizim için seçti. Selah.   
\q1
\v 5 Tanrı yüksek sesle,  
\q2 Yahve boru sesiyle yükseldi.   
\q1
\v 6 Tanrı'yı ezgilerle övün! Övün!  
\q2 Kralımız’ı ezgilerle övün! Övün!   
\q1
\v 7 Çünkü Tanrı tüm dünyanın Kralı’dır.  
\q2 Anlayışla övün.   
\q1
\v 8 Tanrı ulusların üzerinden hüküm sürer.  
\q2 Tanrı kutsal tahtında oturur.   
\q1
\v 9 Avraham’ın Tanrısı’na halk olmak üzere,  
\q2 halkların beyleri bir araya toplandılar.  
\q2 Çünkü yeryüzünün kalkanları Tanrı’ya aittir.  
\q2 O çok yücedir!   
\c 48  
\d İlahi - Korahoğulları’nın mezmuru  
\q1
\v 1 Yahve büyüktür, Tanrımız’ın kentinde,  
\q2 kutsal dağında övülmeye çok lâyıktır.   
\q1
\v 2 Yüksekliği güzel, tüm dünyanın sevinci,  
\q2 kuzey taraflarındaki Siyon Dağı,  
\q2 Büyük Kral’ın kenti.   
\q1
\v 3 Tanrı onun kalelerinde kendini sığınak olarak gösterdi.   
\q1
\v 4 Çünkü işte, krallar toplandılar,  
\q2 birlikte geçtiler.   
\q1
\v 5 Onu görünce hayrete düştüler.  
\q2 Dehşet içinde  
\q2 aceleyle kaçıştılar.   
\q1
\v 6 Doğum sancısı çeken bir kadın gibi,  
\q2 orada onları bir titreme aldı.   
\q1
\v 7 Doğu rüzgârıyla Tarşiş'in gemilerini parçalarsın.   
\q1
\v 8 Nasıl duyduysak öyle gördük,  
\q2 Ordular Yahvesi'nin kentinde, Tanrımız’ın kentinde.  
\q1 Tanrı onu sonsuza dek pekiştirecektir. Selah.   
\q1
\v 9 Ey Tanrı, tapınağının ortasında,  
\q2 senin sevgi dolu iyiliğini düşündük.   
\q1
\v 10 Adın gibi, ey Tanrı,  
\q2 övgün de yeryüzünün dört bir bucağına kadar öyledir.  
\q2 Sağ elin doğrulukla doludur.   
\q1
\v 11 Siyon Dağı sevinsin!  
\q2 Yahuda kızları senin hükümlerinden ötürü coşsunlar.   
\q1
\v 12 Siyon'un çevresinde gezin, etrafını dolanın.  
\q2 Kulelerini sayın.   
\q1
\v 13 Surlarına dikkatle bakın.  
\q2 Saraylarını düşünün ki,  
\q2 gelecek kuşağa anlatasınız.   
\q1
\v 14 Çünkü bu Tanrı sonsuza dek bizim Tanrımız’dır.  
\q2 Ölüme dek O bize yol gösterecektir.   
\c 49  
\d Müzik şefi için - Korahoğulları’nın mezmuru  
\q1
\v 1 Ey bütün halklar, şunu işitin,  
\q2 ey bütün dünya sakinleri,   
\q1
\v 2 hem aşağıdakiler hem yüksektekiler,  
\q2 zengin ve yoksul birlikte dinleyin.   
\q1
\v 3 Ağzım bilgelik sözleri konuşacak.  
\q2 Yüreğim anlayış dile getirecek.   
\q1
\v 4 Özdeyişe kulak vereceğim.  
\q2 Bilmecemi arpla çözeceğim.   
\q1
\v 5 Kötü günlerde neden korkayım ki,  
\q2 alçakların kötülüğü beni kuşattığında?   
\q1
\v 6 Mallarına güveniyorlar,  
\q2 zenginliklerinin çokluğuyla övünüyorlar;   
\q1
\v 7 onların hiçbiri kardeşini kurtaramaz,  
\q2 Tanrı’ya onun için fidye veremez.   
\q1
\v 8 Çünkü canlarının kurtuluşu pahalıdır,  
\q2 hiçbir şey bedelini karşılayamaz.   
\q1
\v 9 Yoksa sonsuza dek yaşar insan,  
\q2 çürüme yüzü görmezdi.   
\q1
\v 10 Çünkü insan bilgelerin öldüğünü görür;  
\q2 budala ve akılsız da aynı şekilde yok olur,  
\q2 mallarını başkalarına bırakırlar.   
\q1
\v 11 İçlerindeki düşünce,  
\q2 meskenlerinin tüm kuşaklar boyunca,  
\q2 evlerinin daima kalacağıdır.  
\q2 Topraklarına kendi adlarını verirler.   
\q1
\v 12 Ama insan zenginliğine rağmen dayanamaz.  
\q2 Yok olup giden hayvanlara benzer.   
\q1
\v 13 Akılsızların,  
\q2 ve onların dediklerini onaylayanların varacakları yer budur. Selah.   
\q1
\v 14 Onlar Şeol'e\f + \fr 49:14 \ft Şeol ölüler diyarıdır.\f* atanmış sürüye benzer.  
\q2 Ölüm onlara çobanlık edecektir.  
\q2 Doğrular sabahleyin onlara hâkim olacak.  
\q2 Konutlarından çok uzakta,  
\q2 güzellikleri Şeol'de\f + \fr 49:14 \ft Şeol ölüler diyarıdır. \f* çürüyecektir.   
\q1
\v 15 Ama Tanrı canımı Şeol'ün\f + \fr 49:15 \ft Şeol ölüler diyarıdır.\f* ölüler elinden kurtaracak.  
\q2 Çünkü beni kabul edecektir. Selah.   
\q1
\v 16 Bir adam zengin olursa,  
\q2 evinin görkemi artarsa korkma.   
\q1
\v 17 Çünkü öldüğünde yanında hiçbir şey götüremez.  
\q2 Görkemi onun ardınca inmez.   
\q1
\v 18 Gerçi yaşarken canını kutsadıysa da—  
\q2 kendin için iyilik ettiğinde insanlar seni överler—   
\q1
\v 19 atalarının nesline gidecektir.  
\q2 Işığı bir daha göremeyecekler.   
\q1
\v 20 Anlayıştan yoksun zenginlik sahibi olan insan,  
\q2 yok olup giden hayvanlara benzer.   
\c 50  
\d Asaf’ın mezmuru  
\q1
\v 1 Kudretli Olan Tanrı, Yahve konuşuyor,  
\q2 gün doğumundan gün batımına kadar yeryüzüne sesleniyor.   
\q1
\v 2 Güzelliğin kusursuzluğu Siyon'dan,  
\q2 Tanrı parlıyor.   
\q1
\v 3 Tanrımız geliyor ve susmuyor.  
\q2 Önününde ateş yiyip bitiriyor.  
\q2 Çevresi şiddetli fırtınayla kaplı.   
\q1
\v 4 Yukarıdaki göklere sesleniyor,  
\q2 halkını yargılamak için yeryüzüne:   
\q1
\v 5 “Benimle kurban sunarak antlaşma yapan,  
\q2 kutsallarımı yanıma toplayın.”   
\q1
\v 6 Gökler O’nun doğruluğunu ilan edecek,  
\q2 çünkü yargıç Tanrı'nın kendisidir. Selah.   
\q1
\v 7 “Ey halkım, dinle de konuşayım.  
\q2 Ey İsrael, sana karşı tanıklık edeyim.  
\q2 Ben Tanrı'yım, senin Tanrın’ım.   
\q1
\v 8 Kurbanlarından ötürü seni azarlamıyorum.  
\q2 Yakmalık sunuların sürekli önümde.   
\q1
\v 9 Ne ahırından bir boğaya,  
\q2 ne de ağıllarından tekelere ihtiyacım var.   
\q1
\v 10 Çünkü tüm orman hayvanları,  
\q2 binlerce dağlardaki sığırlar benimdir.   
\q1
\v 11 Dağların bütün kuşlarını bilirim.  
\q2 Kırdaki yabani hayvanlar benimdir.   
\q1
\v 12 Aç olsam sana söylemezdim,  
\q2 çünkü dünya ve içindeki her şey benimdir.   
\q1
\v 13 Ben boğa eti yer miyim?  
\q2 Ya da keçilerin kanını içer miyim?   
\q1
\v 14 Tanrı'ya şükran kurbanı sun.  
\q2 Yüceler Yücesi’ne adaklarını öde.   
\q1
\v 15 Sıkıntılı gününde beni çağır.  
\q2 Seni kurtarırım ve sen de beni yüceltirsin.”   
\q1
\v 16 Ama kötüye Tanrı şöyle diyor:  
\q2 “Kurallarımı ilan etmeye,  
\q2 antlaşmamı ağzına almaya ne hakkın var?   
\q1
\v 17 Yola getirilmekten nefret ettiğin için,  
\q2 sözlerimi arkana mı atacaksın?   
\q1
\v 18 Bir hırsız görünce ona uyuyor,  
\q2 zina edenlerle bir oluyorsun.”   
\q1
\v 19 “Kötülüğe ağzını veriyorsun  
\q2 dilinle hile uyduruyorsun.   
\q1
\v 20 Oturup kardeşinin aleyhinde konuşuyor,  
\q2 kendi annenin oğluna iftira ediyorsun.   
\q1
\v 21 Sen bunları yaptın, bense sustum.  
\q2 Beni de tıpkı kendin gibi mi sandın.  
\q2 Seni azarlıyor, gözlerinin önünde seni suçluyorum.”   
\q1
\v 22 “Ey siz Tanrı’yı unutanlar, şimdi şunu iyi tartın,  
\q2 yoksa sizi parçalarım, kurtaran kimse olmaz.   
\q1
\v 23 Kim şükran kurbanını sunarsa beni yüceltir;  
\q2 kendisine Tanrı’nın kurtuluşunu göstermem için yolunu hazırlamış olur.”   
\c 51  
\d Müzik şefi için. Bat-Şeva’nın yanına girdikten sonra Peygamber Natan ona geldiği zaman, David’in mezmuru  
\q1
\v 1 Ey Tanrım, sevgi dolu iyiliğin uyarınca merhamet et bana.  
\q2 Sevecen merhametinin bolluğuna göre sil isyanlarımı.   
\q1
\v 2 Beni suçumdan büsbütün yıka.  
\q2 Beni günahımdan temizle.   
\q1
\v 3 Çünkü isyanlarımı biliyorum.  
\q2 Günahım sürekli karşımda.   
\q1
\v 4 Sana karşı ve yalnızca sana karşı günah işledim,  
\q2 senin gözünde kötü olanı yaptım,  
\q2 bunun için söylediklerinde haklı,  
\q2 yargılarında adilsin.   
\q1
\v 5 İşte, ben suç içinde doğdum.  
\q2 Annem günah içinde bana hamile kaldı.   
\q1
\v 6 İşte, sen yürekten gerçeği istiyorsun.  
\q2 Bilgelik öğret bana en derinliklerimde.   
\q1
\v 7 Beni mercanköşk otuyla arındır, temiz olayım.  
\q2 Yıka beni, kardan beyaz olayım.   
\q1
\v 8 Sevinç ve coşkuyu duyur bana,  
\q2 öyle ki, kırdığın kemikler sevinsin.   
\q1
\v 9 Günahlarıma karşı yüzünü ört,  
\q2 bütün suçlarımı sil.   
\q1
\v 10 Bende temiz bir yürek yarat, ey Tanrım.  
\q2 İçimdeki doğru ruhu tazele.   
\q1
\v 11 Beni huzurundan atma,  
\q2 ve Kutsal Ruhun’u benden alma.   
\q1
\v 12 Kurtuluş sevincini bana geri ver.  
\q2 İstekli bir ruhla bana destek ol.   
\q1
\v 13 O zaman isyan edenlere senin yollarını öğreteceğim.  
\q2 Günahkârlar sana geri dönecek.   
\q1
\v 14 Beni kan dökme suçundan kurtar,  
\q2 ey Tanrı, kurtuluşumun Tanrısı.  
\q2 Dilim senin doğruluğunu yüksek sesle ezgilerle söylesin.   
\q1
\v 15 Ey Efendim, dudaklarımı aç.  
\q2 Ağzım senin övgünü ilan etsin.   
\q1
\v 16 Çünkü sen kurbandan hoşlanmazsın,  
\q2 yoksa sunardım sana.  
\q2 Yakmalık sunudan zevk almazsın.   
\q1
\v 17 Tanrı'nın kurbanları kırık bir ruhtur.  
\q2 Ey Tanrı, sen kırık ve pişman bir yüreği hor görmezsin.   
\q1
\v 18 Siyon'a iyi arzunla iyilik et.  
\q2 Yeruşalem’in surlarını yap.   
\q1
\v 19 O zaman doğruluk kurbanlarından,  
\q2 yakmalık sunulardan ve tümüyle yakmalık sunulardan zevk alırsın.  
\q2 O zaman sunağında boğalar sunulur.   
\c 52  
\d Müzik şefi için David’in Maskili Edomlu Doek gelip Saul’a “David Ahimelek’in evine girdi” diye bildirdiği zaman.  
\q1
\v 1 Neden kötülükle övünürsün, ey zorba?  
\q2 Tanrı’nın sevgi dolu iyiliği kalıcıdır.   
\q1
\v 2 Dilin yıkım tasarlar,  
\q2 keskin bir ustura gibi hileyle çalışır.   
\q1
\v 3 İyilikten çok kötülüğü,  
\q2 doğruyu konuşmaktan çok yalanı seversin. Selah.   
\q1
\v 4 Ey seni aldatıcı dil,  
\q2 yıkıcı her sözü seversin.   
\q1
\v 5 Tanrı da seni sonsuza dek yıkacak.  
\q2 Seni alıp çadırından çıkaracak,  
\q2 seni yaşayanlar diyarından kovacak. Selah.   
\q1
\v 6 Doğru kişi de bunu görüp korkacak,  
\q2 ve ona gülüp şöyle diyecek:   
\q1
\v 7 “İşte, Tanrı'yı kendine kuvvet edinmeyen,  
\q2 zenginliğinin bolluğuna güvenen,  
\q2 Kötülüğünde güçlenen adam budur.”   
\q1
\v 8 Ama ben Tanrı'nın evindeki yeşil zeytin ağacı gibiyim.  
\q2 Sonsuza dek Tanrı'nın sevgi dolu iyiliğine güvenirim.   
\q1
\v 9 Yaptıkların için daima sana şükredeceğim.  
\q2 Kutsallarının önünde senin adına umut bağlarım,  
\q2 çünkü adın iyidir.   
\c 53  
\d Müzik şefi için - Mahalat makamında David’in Maskili  
\q1
\v 1 Akılsız, yüreğinde “Tanrı yoktur” dedi.  
\q2 Yozlaştılar ve iğrenç şeyler yaptılar.  
\q2 İyilik eden kimse yok.   
\q1
\v 2 Anlayan, Tanrı’yı arayan birinin olup olmadığını görmek için,  
\q2 Tanrı gökten insanoğullarına baktı.   
\q1
\v 3 Hepsi geri döndü.  
\q2 Birlikte kirlendiler.  
\q2 İyilik eden kimse yok, bir kişi bile.   
\q1
\v 4 Kötülük edenlerin bilgisi yok mu?  
\q2 Halkımı ekmek yer gibi yiyor,  
\q2 Tanrı'yı çağırmıyorlar.   
\q1
\v 5 Korkunun olmadığı yerde çok korktular.  
\q2 Çünkü Tanrı sana karşı ordugâh kuranın kemiklerini dağıttı.  
\q2 Onları utandırdın,  
\q2 çünkü Tanrı onları reddetti.   
\q1
\v 6 Keşke İsrael'in kurtuluşu Siyon'dan gelseydi!  
\q2 Tanrı, halkını sürgünden geri getirince,  
\q2 Yakov sevinecek,  
\q2 İsrael coşacak.   
\c 54  
\d Müzik şefi için - Telli sazlarla David’in Maskili Zifliler gelip Saul’a: “David aramızda gizleniyor” dedikleri zaman  
\q1
\v 1 Ey Tanrı, adınla kurtar beni.  
\q2 Gücünle beni haklı çıkar.   
\q1
\v 2 Ey Tanrı, duamı duy.  
\q2 Ağzımdan çıkan sözlere kulak ver.   
\q1
\v 3 Çünkü yabancılar bana karşı ayaklandı.  
\q2 Zorbalar canımın peşindeler.  
\q2 Tanrı’yı önlerine koymadılar. Selah.   
\q1
\v 4 İşte, Tanrı benim yardımcımdır.  
\q2 Canıma destek olan Efendim’dir.   
\q1
\v 5 Düşmanlarıma yaptıkları kötülüğün karşılığını verecektir.  
\q2 Onları kendi gerçeğinle yok et.   
\q1
\v 6 Sana gönülden kurban sunacağım.  
\q2 Ey Yahve adına şükredeceğim,  
\q2 çünkü adın iyidir.   
\q1
\v 7 Çünkü beni her sıkıntıdan kurtardı.  
\q2 Gözüm düşmanlarıma karşı zaferi gördü.   
\c 55  
\d Müzik şefi için - Telli sazlarla David’in Maskili  
\q1
\v 1 Ey Tanrı, duamı dinle.  
\q2 Yalvarışımdan kendini saklama.   
\q1
\v 2 Dikkatini ver, yanıtla beni.  
\q2 Sıkıntı ve inilti içinde huzursuzum   
\q1
\v 3 düşmanın sesi, kötünün zulmü yüzünden.  
\q2 Çünkü üstüme sıkıntı getiriyorlar.  
\q2 Öfkeyle bana kin besliyorlar.   
\q1
\v 4 Yüreğim sızlıyor içimde.  
\q2 Ölüm dehşeti çöktü üzerime.   
\q1
\v 5 Üzerime korku ve titreme geldi.  
\q2 Dehşet içimi sardı.   
\q1
\v 6 “Keşke güvercin gibi kanatlarım olsaydı!” dedim.  
\q2 Uçup gider, rahatlardım.   
\q1
\v 7 İşte, o zaman uzaklara gider,  
\q2 çölde konaklardım. Selah.   
\q1
\v 8 “Sert rüzgârdan ve kasırgadan  
\q2 hemen sığınağa koşardım.”   
\q1
\v 9 Akıllarını ve dillerini karıştır, ey Efendim,  
\q2 çünkü kentte şiddet ve çekişme gördüm.   
\q1
\v 10 Gece gündüz kent surları üzerinde geziniyorlar.  
\q2 Kötülük ve gaddarlık kentin içindedir.   
\q1
\v 11 Yıkıcı güçler onun içindedir.  
\q2 Tehdit ve yalanlar sokaklardan çıkmaz.   
\q1
\v 12 Çünkü beni aşağılayan bir düşman değildi,  
\q2 yoksa buna katlanabilirdim.  
\q2 Benden nefret eden de bir hasım değildi,  
\q2 yoksa ondan gizlenirdim.   
\q1
\v 13 Ama sendin, benim gibi biri,  
\q2 arkadaşım ve yakın dostum.   
\q1
\v 14 Birlikte tatlı tatlı dostluk ederdik.  
\q2 Toplulukla Tanrı'nın evine yürürdük.   
\q1
\v 15 Ölüm üzerlerine ansızın gelsin.  
\q2 Diri diri Şeol'e\f + \fr 55:15 \ft Şeol ölüler diyarıdır. \f* insinler.  
\q2 Çünkü kötülük onların arasında, evlerinin içindedir.   
\q1
\v 16 Bense, Tanrı'ya seslenirim.  
\q2 Yahve kurtarır beni.   
\q1
\v 17 Akşam, sabah ve öğle vakti sıkıntı içinde feryat ederim.  
\q2 O sesimi duyar.   
\q1
\v 18 Bana karşı yapılan savaştan  
\q2 esenlik içinde kurtarır canımı,  
\q2 gerçi bana karşı çıkanlar da çoktur.   
\q1
\v 19 Sonsuzluktan beri tahtında oturan Tanrı,  
\q2 işitecek ve onlara karşılık verecektir. Selah.  
\q2 Onlar asla değişmez,  
\q2 Tanrı’dan da korkmazlar.   
\q1
\v 20 Dostlarına karşı elini kaldırdı,  
\q2 yaptığı antlaşmayı bozdu.   
\q1
\v 21 Ağzı tereyağı gibi sakin,  
\q2 ama yüreği savaşçıdır.  
\q2 Sözleri yağdan yumuşak,  
\q2 ama onlar yalın kılıçtırlar.   
\q1
\v 22 Yükünü Yahve’ye bırak,  
\q2 O sana destek olur.  
\q2 Doğrunun sarsılmasına  
\q2 asla izin vermez.   
\q1
\v 23 Ama sen, ey Tanrı,  
\q2 Onları yıkım çukuruna indireceksin.  
\q2 Kana susamış ve hilekâr adamlar  
\q2 günlerinin yarısını bile yaşayamayacaklar.  
\q2 Bense sana güvenirim.   
\c 56  
\d Müzik şefi için “Uzak Yabanıl Fıstık Ağaçlarındaki Güvercin” makamında David’in Miktamı - Gar Kenti’nde Filistliler onu yakaladığı zaman  
\q1
\v 1 Ey Tanrı merhamet et bana,  
\q2 çünkü insan beni yutmak istiyor.  
\q2 Gün boyu bana saldırıp baskı yapıyor.   
\q1
\v 2 Düşmanlarım gün boyu beni yutmak istiyorlar,  
\q2 çünkü bana karşı gururla savaşanlar çoktur.   
\q1
\v 3 Korktuğumda,  
\q2 sana güvenirim.   
\q1
\v 4 Tanrı’ya, sözünü överim.  
\q2 Tanrı’ya güvenirim, korkmam.  
\q2 İnsan bana ne yapabilir?   
\q1
\v 5 Gün boyu sözlerimi çarpıtıyorlar.  
\q2 Bana karşı bütün düşünceleri kötülük içindir.   
\q1
\v 6 Kötülük için anlaşıp pusuya yatıyorlar,  
\q2 adımlarımı izleyip,  
\q2 canımı almaya hevesleniyorlar.   
\q1
\v 7 Onlar kötülükle mi kurtulacaklar?  
\q2 Ey Tanrı, öfkeyle halkları yere çal.   
\q1
\v 8 Avare avare dolaşmalarımı saydın.  
\q2 Gözyaşlarımı kabına koydun.  
\q2 Onlar senin kitabında değil mi?   
\q1
\v 9 Seslendiğim gün düşmanlarım geri çekilecek.  
\q2 Biliyorum, Tanrı benden yanadır.   
\q1
\v 10 Tanrı’ya, sözünü överim.  
\q2 Yahve’ye, sözünü överim.   
\q1
\v 11 Tanrı'ya güvenirim, korkmam.  
\q2 İnsan bana ne yapabilir?   
\q1
\v 12 Ey Tanrı, adakların üzerimdedir,  
\q2 sana şükran kurbanları sunacağım.   
\q1
\v 13 Çünkü canımı ölümden kurtardın,  
\q2 ayaklarımın kaymasına engel oldun,  
\q2 öyle ki, yaşayanların ışığında Tanrı'nın önünde yürüyeyim.   
\c 57  
\d Müzik şefi için - “Yok etme” makamında David’in Miktamı Saul’dan kaçıp mağaraya sığındığı zaman  
\q1
\v 1 Merhamet et bana, ey Tanrı, bana merhamet et,  
\q2 çünkü canım sana sığınıyor.  
\q2 Felaket geçene dek  
\q2 kanatlarının gölgesine sığınacağım.   
\q1
\v 2 Yüce Tanrı'ya,  
\q2 benim için isteklerimi yerine getiren Tanrı’ya sesleniyorum.   
\q1
\v 3 Gökten gönderip beni kurtaracak,  
\q2 beni kovalayanı azarlayacak. Selah.  
\q2 Tanrı sevgi dolu iyiliğini ve gerçeğini gönderecektir.   
\q1
\v 4 Canım aslanların arasında.  
\q2 Yakıcı insanoğulları arasında yatıyorum,  
\q2 dişleri mızrak ve ok,  
\q2 dilleri keskin bir kılıçtır.   
\q1
\v 5 Ey Tanrı, göklerin üstünde yücel!  
\q2 Yüceliğin tüm yeryüzünü kaplasın!   
\q1
\v 6 Adımlarıma ağ kurdular.  
\q2 Canım çöktü.  
\q2 Önüme çukur kazdılar.  
\q2 İçine kendileri düştüler. Selah.   
\q1
\v 7 Yüreğim değişmez, ey Tanrı.  
\q2 Yüreğim değişmez.  
\q2 Ezgiler, ilahiler söyleyeceğim.   
\q1
\v 8 Uyan, ey görkemim! Uyan, ey ut ve arp!  
\q2 Şafağı ben uyandırayım.   
\q1
\v 9 Halkların arasında sana şükredeceğim ey Efendim.  
\q2 Uluslar arasında seni ilahilerle öveceğim.   
\q1
\v 10 Çünkü senin muazzam sevgi dolu iyiliğin göklere,  
\q2 gerçeğin gökyüzüne ulaşır.   
\q1
\v 11 Ey Tanrı, göklerin üstünde yücel!  
\q2 Yüceliğin tüm yeryüzünü kaplasın!   
\c 58  
\d Müzik şefi için - “Yok Etme” makamında David’in Miktamı  
\q1
\v 1 Ey siz susanlar, gerçekten doğrulukla mı konuşursunuz?  
\q2 Ey insanoğulları, kusursuzca mı yargılarsınız?   
\q1
\v 2 Hayır, yüreğinizde haksızlık tasarlarsınız.  
\q2 Yeryüzünü ellerinizin zorbalığıyla ölçersiniz.   
\q1
\v 3 Kötüler ana rahmindeyken yoldan saparlar.  
\q2 Doğdukları andan itibaren dik başlıdırlar,  
\q2 yalan söylerler.   
\q1
\v 4 Onların zehiri yılanın zehiri gibidir,  
\q2 kulağını tıkayan sağır bir kobraya benzerler,   
\q1
\v 5 büyücülerin sesine kulak vermez,  
\q2 büyücü ne kadar hünerli olursa olsun.   
\q1
\v 6 Ey Tanrı, kır onların ağızlarındaki dişleri.  
\q2 Sök genç aslanların azı dişlerini, ey Yahve.   
\q1
\v 7 Akıp giden su gibi yok olup gitsinler.  
\q2 Yaylarını gerdiklerinde oklarının ucu kırılsın.   
\q1
\v 8 Eriyip giden salyangoz gibi,  
\q2 güneşi görmeden düşük çocuk gibi olsunlar.   
\q1
\v 9 Kazanlarınız diken ateşini daha duymadan,  
\q2 yeşili de, tutuşmuş olanı da süpürüp atacaktır.   
\q1
\v 10 Doğru kişi alınan öcü görünce sevinecek.  
\q2 Ayaklarını kötünün kanıyla yıkayacak,   
\q1
\v 11 o zaman insanlar şöyle diyecekler:  
\q2 “Kuşkusuz doğruların ödülü var.  
\q2 Kuşkusuz yeryüzünü yargılayan bir Tanrı var.”   
\c 59  
\d Müzik şefi için - “Yok Etme” makamında David’in Miktamı - Saul’un David’i öldürtmek için adam gönderip evini gözetlediği zaman  
\q1
\v 1 Kurtar beni düşmanlarımdan, ey Tanrım.  
\q2 Bana karşı ayaklananlardan beni yükseğe çıkar.   
\q1
\v 2 Kurtar beni kötülüğün işçilerinden.  
\q2 Kurtar beni kana susamış insanlardan.   
\q1
\v 3 Çünkü işte, canım için pusuya yatmış bekliyorlar.  
\q2 Güçlüler bana karşı toplanıyorlar,  
\q2 itaatsizliğim ya da günahımdan dolayı değil, ey Yahve.   
\q1
\v 4 Suç işlemediğim halde bana saldırmaya hazırlanıyorlar.  
\q2 Bana yardım etmek için kalk ve bak!   
\q1
\v 5 Sen, Ordular Tanrısı Yahve, İsrael'in Tanrısı,  
\q2 ulusları cezalandırmak için uyan.  
\q2 Bu kötü hainlere merhamet gösterme. Selah.   
\q1
\v 6 Akşamleyin köpekler gibi uluyarak geri dönerler,  
\q2 kentte dolaşırlar.   
\q1
\v 7 İşte, ağızlarıyla kusuyorlar.  
\q2 Dudaklarında kılıç var,  
\q2 “Bizi kim duyacak ki?” diyorlar.   
\q1
\v 8 Ama sen, ey Yahve, onlara gülersin.  
\q2 Bütün uluslarla eğlenirsin.   
\q1
\v 9 Ey Gücüm, sana bakıyorum,  
\q2 çünkü Tanrı benim yüksek kulemdir.   
\q1
\v 10 Tanrım sevgi dolu iyiliğiyle önümde yürüyecek.  
\q2 Tanrı düşmanlarıma zaferle bakmamı sağlayacak.   
\q1
\v 11 Öldürme onları, yoksa halkım unutur.  
\q2 Gücünle onları dağıt ve alaşağı et,  
\q2 ey kalkanımız olan Efendi.   
\q1
\v 12 Ağızlarının günahı ve dudaklarının sözleri için,  
\q2 ettikleri lanetler ve söyledikleri yalanlar için,  
\q2 kibirleri onları yakalasın.   
\q1
\v 13 Öfkeyle tüket onları.  
\q2 Tüket onları, yok olsunlar.  
\q2 Bilsinler ki, yeryüzünün sonlarına kadar  
\q2 Yakov’da hüküm süren Tanrı’dır. Selah.   
\q1
\v 14 Akşam dönsünler.  
\q2 Köpek gibi ulusunlar, kentte dolaşsınlar.   
\q1
\v 15 Yiyecek bulmak için bir aşağı bir yukarı gezinsinler,  
\q2 doymazlarsa bütün gece bekleyecekler.   
\q1
\v 16 Bense gücüne ezgiler söyleyeceğim.  
\q2 Evet, sabahları sevgi dolu iyiliğini yüksek sesle ezgiyle dile getireceğim.  
\q2 Çünkü sen benim yüksek kulem,  
\q2 sıkıntılı günümde sığınağım oldun.   
\q1
\v 17 Seni ilahilerle öveceğim, ey gücüm.  
\q2 Çünkü Tanrı benim yüksek kulemdir, merhametimin Tanrısı’dır.   
\c 60  
\d Müzik şefi için - “Antlaşma Zambağı” makamında David’in öğretici Miktamı David’in Aram-Naharayimliler ve Aram-Sovalılar’la çarpıştığı ve Yoav geri dönüp Tuz Vadisi’nde on iki bin Edomlu öldürdüğü zaman  
\q1
\v 1 Ey Tanrı, bizi reddettin ve yıktın.  
\q2 Öfkelendin,  
\q2 bizi eski halimize döndür.   
\q1
\v 2 Ülkeyi salladın, yarıklar açtın  
\q2 çatlaklarını düzle,  
\q2 çünkü yer sarsılıyor.   
\q1
\v 3 Halkına zor şeyler gösterdin.  
\q2 Bize sersemleten şarabı içirdin.   
\q1
\v 4 Gerçek uğruna sergilensin diye,  
\q2 senden korkanlara sancak verdin. Selah.   
\q1
\v 5 Sevdiklerin kurtulsun diye,  
\q2 sağ elinle kurtar ve yanıt ver bize.   
\q1
\v 6 Tanrı kutsal yerinden şöyle konuştu:  
\q2 “Zafer kazanacağım.  
\q2 Şekem'i böleceğim,  
\q2 Sukkot Vadisi’ni ölçeceğim.   
\q1
\v 7 Gilad benimdir, Manaşşe de benim.  
\q2 Efraim de başımın siperi,  
\q2 Yahuda asamdır.   
\q1
\v 8 Moav yıkanma leğenimdir.  
\q2 Edom'un üzerine çarığımı atacağım.  
\q2 Filist üzerine zaferle haykıracağım.”   
\q1
\v 9 Kim beni surlu kente götürecek?  
\q2 Bana kim Edom'a kadar yol gösterecek?   
\q1
\v 10 Ey Tanrı, sen bizi reddetmedin mi?  
\q2 Ordularımızla yola çıkmıyorsun, ey Tanrı.   
\q1
\v 11 Düşmana karşı bize yardım et,  
\q2 çünkü insanın yardımı boştur.   
\q1
\v 12 Tanrı’yla yiğitlik ederiz,  
\q2 çünkü düşmanlarımızı ezecek olan O’dur.   
\c 61  
\d Müzik şefi için - Telli sazlarla - David’in mezmuru  
\q1
\v 1 Ey Tanrı, feryadımı duy,  
\q2 duamı dinle.   
\q1
\v 2 Yüreğim bunaldığında sana seslenirim  
\q2 yeryüzünün öbür ucundan.  
\q2 Beni benden daha yüksek olan kayaya götür.   
\q1
\v 3 Çünkü sen bana sığınak,  
\q2 düşmana karşı güçlü bir kule oldun.   
\q1
\v 4 Sonsuza dek çadırında kalayım.  
\q2 Kanatlarının koruması altına sığınayım. Selah.   
\q1
\v 5 Çünkü sen, ey Tanrı, adaklarımı duydun.  
\q2 Adından korkanların mirasını bana verdin.   
\q1
\v 6 Kralın ömrünü uzat.  
\q2 Onun yılları kuşaklar boyunca sürsün,   
\q1
\v 7 sonsuza dek Tanrı'nın huzurunda tahta otursun.  
\q2 Sevgi dolu iyiliğini ve gerçeğini sapta ki, onu korusunlar.   
\q1
\v 8 Böylece daima ismine ilahiler söyleyeceğim,  
\q2 ta ki, adaklarımı her gün yerine getirebileyim.   
\c 62  
\d Müzik şefi Yedutun için - David’in mezmuru  
\q1
\v 1 Canım yalnız Tanrı'da dinlenir.  
\q2 Kurtuluşum O’ndandır.   
\q1
\v 2 Kayam, kurtuluşum ve kalem yalnız O’dur.  
\q2 Asla şiddetli sarsılmam.   
\q1
\v 3 Eğik bir duvar, sallanan bir çit gibi,  
\q2 ne vakte kadar, hepiniz bir adamı ezmek için,  
\q2 ona saldıracaksınız?   
\q1
\v 4 Bütün düşünceleri onu bulunduğu yücelikten  
\q2 Aşağıya atmaktır.  
\q2 Yalanlardan zevk alırlar.  
\q2 Ağızlarıyla kutsarken,  
\q2 İçlerinden lanet okurlar. Selah.   
\q1
\v 5 Ey canım, sessizce yalnız Tanrı’yı bekle,  
\q2 çünkü umudum O’ndandır.   
\q1
\v 6 Kayam, kurtuluşum ve kalem yalnız O’dur.  
\q2 Sarsılmam.   
\q1
\v 7 Kurtuluşum ve onurum Tanrı'yladır.  
\q2 Gücümün kayası ve sığınağım Tanrı'dadır.   
\q1
\v 8 Ey halkım, O'na her zaman güven.  
\q2 Yüreğini O’nun önünde dök.  
\q2 Tanrı bizim için bir sığınaktır. Selah.   
\q1
\v 9 Kesinlikle aşağı tabakadaki insanlar yalnızca bir soluktur;  
\q2 yukarı tabakadaki insanlar da bir yalan.  
\q2 Onlar tartıda kaldırıldıklarında,  
\q2 birlikte soluktan daha hafiftir.   
\q1
\v 10 Gaddarlığa güvenmeyin.  
\q2 Soygunculukla övünmeyin.  
\q2 Zenginlik artarsa,  
\q2 ona gönül bağlamayın.   
\q1
\v 11 Tanrı bir kez konuştu;  
\q2 Ben şunu iki kez işittim:  
\q2 Güç Tanrı’ya aittir.   
\q1
\v 12 Sevgi dolu iyilik de sana aittir, ey Efendim,  
\q2 çünkü sen herkesi yaptığı işe göre ödüllendirirsin.   
\c 63  
\d Yahuda kırlarında bulunduğu zaman - David’in mezmuru  
\q1
\v 1 Ey Tanrım, sensin benim Tanrım.  
\q2 Gayretle seni arıyorum.  
\q2 Canım sana susamış.  
\q2 Bedenim seni özlüyor,  
\q2 kurak, yorucu, susuz bir diyarda.   
\q1
\v 2 Kutsal yerde sana baktım,  
\q2 gücünü ve görkemini görmek için.   
\q1
\v 3 Dudaklarım seni över,  
\q2 çünkü senin sevgi dolu iyiliğin yaşamdan daha iyidir.   
\q1
\v 4 Yaşadığım sürece seni böyle yücelteceğim.  
\q2 Senin adınla ellerimi kaldıracağım.   
\q1
\v 5 Canım zengin yiyeceklere doyar gibi doyacak.  
\q2 Ağzım neşeli dudaklarla seni övecek.   
\q1
\v 6 Seni yatağımda hatırladığımda,  
\q2 gece nöbetlerinde seni düşünürüm.   
\q1
\v 7 Çünkü sen bana yardımcı oldun.  
\q2 Kanatlarının gölgesinde sevineceğim.   
\q1
\v 8 Canım sana yakın durur.  
\q2 Sağ elin bana destek olur.   
\q1
\v 9 Ama yok etmek için canımı arayanlar,  
\q2 yerin diplerine inecekler.   
\q1
\v 10 Onlar kılıcın gücüne teslim edilecekler.  
\q2 Çakallara yem olacaklar.   
\q1
\v 11 Ama kral Tanrı’yla sevinecek.  
\q2 O’nunla ant içenlerin hepsi O'nu övecekler,  
\q2 yalan söyleyenlerin ağızlarıysa susturulacak.   
\c 64  
\d Müzik şefi için - David’in mezmuru  
\q1
\v 1 Yakındığımda sesimi duy, ey Tanrı.  
\q2 Yaşamımı düşman korkusundan koru.   
\q1
\v 2 Kötülerin gizli tasarılarından,  
\q2 fesat işleyenlerin gürültücü kalabalığından sakla beni.   
\q1
\v 3 Dillerini kılıç gibi keskinleştiren,  
\q2 ölümcül sözlerle oklarını kuran,   
\q1
\v 4 masum insanları vurmak için pusuda yatan onlardır.  
\q2 Ansızın onu vururlar hiç korkmadan.   
\q1
\v 5 Kötü tasarılar için birbirlerini teşvik ederler.  
\q2 Gizlice tuzak kurmaktan söz ederler.  
\q2 “Onları kim görecek ki?” derler.   
\q1
\v 6 “Kusursuz bir plan yaptık!” deyip,  
\q2 adaletsizlik için düzen kurarlar.  
\q2 Besbelli insanın aklı ve yüreği kurnazdır.   
\q1
\v 7 Ama Tanrı onlara ok atacaktır.  
\q2 Ansızın bir okla vurulacaklar.   
\q1
\v 8 Kendi dilleri onları yıkıma uğratacak.  
\q2 Onları gören herkes başını sallayacak.   
\q1
\v 9 Bütün insanlar korkacak.  
\q2 Tanrı’nın işini ilan edecekler,  
\q2 O’nun yaptıklarını bilgece ölçüp tartacaklar.   
\q1
\v 10 Doğru kişi Yahve'de sevinecek,  
\q2 O’na sığınacaktır.  
\q2 Yüreği doğru olanların hepsi O'nu övecekler!   
\c 65  
\d Müzik şefi için - David’in mezmuru - İlahi  
\q1
\v 1 Ey Tanrı, Siyon'da seni övgü bekliyor.  
\q2 Adaklar yerine getirilecek.   
\q1
\v 2 Ey Sen duayı işiten,  
\q2 bütün insanlar Sana gelecek.   
\q1
\v 3 Günahlar beni bunalttı,  
\q2 ama Sen suçlarımızın kefaretini ödedin.   
\q1
\v 4 Ne mutlu, avlularında otursun diye  
\q2 seçip yaklaştırdığın insana.  
\q2 Evinin, kutsal tapınağının  
\q2 iyiliğiyle doyacağız.   
\q1
\v 5 Müthiş doğruluk işleriyle bizi yanıtlarsın.  
\q2 Ey kurtuluşumuzun Tanrısı.  
\q2 Ey Sen, dünyanın bütün uçlarının,  
\q2 uzak denizde bulunanların umudusun.   
\q1
\v 6 Güçle kuşanmış olarak,  
\q2 kuvvetinle dağlara biçim veren,   
\q1
\v 7 denizlerin kükremesini,  
\q2 dalgalarının uğultusunu,  
\q2 ve ulusların kargaşasını yatıştıran sensin.   
\q1
\v 8 Uzaklarda oturanlar da  
\q2 senin harikalarından korkarlar.  
\q2 Sabahın şafağını ve akşamı sevinç ezgileriyle çağırırsın.   
\q1
\v 9 Yeryüzünü ziyaret edip onu sularsın.  
\q2 Onu çok zenginleştirirsin.  
\q2 Tanrı’nın nehri suyla doludur.  
\q2 Onlara tahıl sağlarsın,  
\q2 çünkü bunu sen buyurdun.   
\q1
\v 10 Saban yarıklarını bolca sular,  
\q2 sırtlarını düzeltirsin.  
\q2 Yağmurlar yumuşatır,  
\q2 onu mahsulle kutsarsın.   
\q1
\v 11 Yılı bolluğunla taçlandırırsın.  
\q2 Arabaların bereketle dolup taşar.   
\q1
\v 12 Çöller yeşillikle taşar.  
\q2 Tepeler neşeye bürünür.   
\q1
\v 13 Otlaklar sürülerle kaplanır.  
\q2 Vadiler de buğdayla örtünür.  
\q2 Sevinçle bağrışır, ezgi söylerler.   
\c 66  
\d Müzik şefi için - İlahi - Mezmur  
\q1
\v 1 Ey bütün yeryüzü,  
\q2 Tanrı’ya, sevinçle haykırın!   
\q1
\v 2 Adının yüceliğine ilahi söyleyin!  
\q2 Görkem ve övgü sunun!   
\q1
\v 3 “İşlerin ne muhteşemdir!” deyin Tanrı’ya,  
\q2 “Gücünün büyüklüğünden  
\q2 düşmanların önünde boyun eğiyor.   
\q1
\v 4 Bütün yeryüzü sana tapınacak,  
\q2 sana ilahi söyleyip  
\q2 Adına ezgiler söyleyecekler.” Selah.   
\q1
\v 5 Gelin ve Tanrı'nın yaptıklarını görün.  
\q2 İnsanlar adına muhteşem bir yapıt.   
\q1
\v 6 Denizi kuru toprağa çevirdi.  
\q2 Onlar ırmağı yürüyerek geçtiler.  
\q2 Orada O’nda sevindik.   
\q1
\v 7 O, kudretiyle sonsuza dek hüküm sürer.  
\q2 Gözleri ulusları gözler.  
\q2 Asiler O’na karşı baş kaldırmasın. Selah.   
\q1
\v 8 Ey halklar, Tanrımız’ı övün!  
\q2 Övgüsünün sesini duyurun,   
\q1
\v 9 Diriler arasında yaşamımızı koruyan,  
\q2 ayaklarımızın kaymasına izin vermeyen O’dur.   
\q1
\v 10 Sen bizi sınadın, ey Tanrı.  
\q2 Gümüş arıtır gibi, arıttın bizi.   
\q1
\v 11 Bizi zindana verdin.  
\q2 Sırtımıza yük koydun.   
\q1
\v 12 İnsanların başımıza çıkmasına izin verdin.  
\q2 Ateşin ve suyun içinden geçtik,  
\q2 ama bizi bolluğun bulunduğu yere getirdin.   
\q1
\v 13 Yakmalık sunularla tapınağına geleceğim.   
\q1
\v 14 Sıkıntıdayken ağzımın söylemiş olduğu,  
\q2 dudaklarımın sana vaat ettiği adaklarımı yerine getireceğim.   
\q1
\v 15 Sana yakmalık sunu olarak semiz hayvanlar sunacağım,  
\q2 koçlarla birlikte, boğalar, keçiler sunacağım. Selah.   
\q1
\v 16 Ey Tanrı'dan korkanlar, gelin ve dinleyin.  
\q2 Canım için neler yapmış olduğunu bildireyim.   
\q1
\v 17 Ağzımla O’na yakardım.  
\q2 Dilimle O övüldü.   
\q1
\v 18 Günaha yüreğimde yer verseydim,  
\q2 Efendi dinlemezdi.   
\q1
\v 19 Ama kesinlikle, Tanrı dinledi.  
\q2 Duamın sesini işitti.   
\q1
\v 20 Duamı geri çevirmeyen,  
\q2 sevgi dolu iyiliğini benden esirgemeyen  
\q2 Tanrı'ya övgüler olsun!   
\c 67  
\d Müzik şefi için - Telli sazlarla - Mezmur - İlahi  
\q1
\v 1 Tanrı bize merhamet etsin ve bizi kutsasın,  
\q2 yüzüyle üzerimize ışık saçtırsın. Selah.   
\q1
\v 2 Öyle ki, yeryüzünde yolun,  
\q2 bütün uluslar arasındaki kurtuluşun bilinsin.   
\q1
\v 3 Halklar seni övsün, ey Tanrı.  
\q2 Bütün halklar seni övsün.   
\q1
\v 4 Uluslar sevinsin, sevinçle ezgi söylesin,  
\q2 çünkü halkları adaletle yargılarsın,  
\q2 yeryüzündeki uluslara hükmedersin. Selah.   
\q1
\v 5 Halklar seni övsün, ey Tanrı.  
\q2 Bütün halklar seni övsün.   
\q1
\v 6 Yeryüzü mahsulünü verdi.  
\q2 Tanrı, bizim Tanrımız, bizi kutsasın.   
\q1
\v 7 Tanrı bizi kutsasın.  
\q2 Bütün dünya uçları O’ndan korksun.   
\c 68  
\d Müzik şefi için - David’in mezmuru- İlahi  
\q1
\v 1 Tanrı kalksın!  
\q2 Düşmanları dağılsın!  
\q2 O’ndan nefret edenler önünden kaçsınlar.   
\q1
\v 2 Dumanın dağıldığı gibi,  
\q2 onları öyle dağıt.  
\q2 Ateşin önünde eriyen balmumu gibi,  
\q2 kötüler Tanrı'nın önünde öyle yok olsun.   
\q1
\v 3 Ama doğrular sevinsin.  
\q2 Tanrı'nın önünde coşsunlar.  
\q2 Evet, neşeyle coşsunlar.   
\q1
\v 4 Tanrı'ya ilahi söyleyin! O’nun adına ezgiler söyleyin!  
\q2 Bulutlar üzerine binmiş olanı yüceltin:  
\q2 Yah’dır, O’nun adı!  
\q2 O’nun önünde coşun!   
\q1
\v 5 Kutsal konutundaki Tanrı,  
\q2 yetimin babası ve dul kadınların savunucusudur.   
\q1
\v 6 Tanrı yalnızlara aile kurar.  
\q2 Tutsakları ezgi söyleyerek dışarı çıkarır,  
\q2 ama isyan edenler güneşin kavurduğu ülkede yaşar.   
\q1
\v 7 Ey Tanrı, halkının önüne çıktığında,  
\q2 çölde yürüdüğünde... Selah.   
\q1
\v 8 Yer sarsıldı,  
\q2 ve Sina Tanrısı’nın önünde gökten yağmur yağdı,  
\q2 Tanrı’nın, İsrael’in Tanrısı önünde.   
\q1
\v 9 Sen, ey Tanrı, bol yağmur gönderdin.  
\q2 Yorulduğu zaman mirasına kuvvet verdin.   
\q1
\v 10 Topluluğun orada yaşadı.  
\q2 Sen, ey Tanrı, iyiliğini yoksullar için hazırladın.   
\q1
\v 11 Efendi sözünü duyurdu.  
\q2 Bunu ilan edenler büyük bir topluluktu.   
\q1
\v 12 “Orduların kralları kaçıyor! Kaçıyorlar!”  
\q2 Evde bekleyen kadın ganimeti bölüştürür,   
\q1
\v 13 sen kamp ateşinin arasında uyurken,  
\q2 tüyleri altın renkli,  
\q2 kanatları gümüşle kaplanmış bir güvercin gibi parlarsın.   
\q1
\v 14 Her Şeye Gücü Yeten orada kralları dağıttığında,  
\q2 Salmon'a kar yağdı.   
\q1
\v 15 Başan Dağları heybetli dağlardır.  
\q2 Başan Dağları sarptır.   
\q1
\v 16 Ey sarp dağlar, neden kıskançlıkla bakıyorsunuz?  
\q2 Tanrı'nın hüküm sürmek için seçtiği dağa?  
\q2 Evet, Yahve sonsuza dek orada oturacak.   
\q1
\v 17 Tanrı'nın savaş arabaları on binlerce, binlerce bindir.  
\q2 Efendi, Sina Dağı'ndan kutsal yere kadar onların ortasındadır.   
\q1
\v 18 Yükseğe çıktın.  
\q2 Tutsakları götürdün.  
\q2 İnsanlardan, isyan edenlerden bile armağanlar aldın,  
\q2 oraya yerleşmek için ey Yah Tanrı.   
\q1
\v 19 Her gün yüklerimizi taşıyan Efendi’ye,  
\q2 kurtuluşumuz olan Tanrı’ya övgüler olsun. Selah.   
\q1
\v 20 Tanrı bizim için kurtuluş Tanrısı’dır.  
\q2 Ölümden kurtarış, Efendi Yahve’ye aittir.   
\q1
\v 21 Ama Tanrı düşmanlarının başını,  
\q2 suçunda ısrar edenin kıllı kafasını ezer.   
\q1
\v 22 Efendi şöyle dedi: “Seni Başan'dan geri getireceğim.  
\q2 Seni yeniden denizin derinliklerinden geri getireceğim,   
\q1
\v 23 öyle ki, ayağını kana batırıp onları ezesin,  
\q2 köpeklerinin dili de senin düşmanlarından payını alsın.”   
\q1
\v 24 Ey Tanrı, senin alaylarını  
\q2 Tanrım’ın, Kralım'ın kutsal yere doğru alaylarını gördüler.   
\q1
\v 25 Tef çalan kızlar arasında,  
\q2 önde okuyucular, arkada çalgıcılar yürüdü.   
\q1
\v 26 “Topluluklarda Tanrı'yı,  
\q2 İsrael topluluğunda Efendi’yi övün!”   
\q1
\v 27 Onların hükümdarı küçük Benyamin,  
\q2 Yahuda beyleri ve topluluğu,  
\q2 Zevulun beyleri ve Naftali beyleri oradadırlar.   
\q1
\v 28 Senin gücünü Tanrı buyurdu.  
\q2 Bizim için yaptıklarını güçlendir, ey Tanrı.   
\q1
\v 29 Yeruşalem'deki tapınağın uğruna,  
\q2 krallar sana hediyeler getirecek.   
\q1
\v 30 Azarla kamışlar arasında yaşayan vahşi hayvanı,  
\q2 halkların buzağılarını ve boğalar sürüsünü.  
\q2 Gümüş külçe getirenleri alçalt,  
\q2 savaştan zevk alan ulusları dağıt.   
\q1
\v 31 Mısır'dan beyler gelecek.  
\q2 Etiyopya ellerini Tanrı'ya uzatmak için acele edecek.   
\q1
\v 32 Ey yeryüzünün krallıkları, Tanrı'ya ezgi söyleyin!  
\q2 Efendi’ye ilahiler söyleyin—Selah—   
\q1
\v 33 kadim göklerin göğü üstüne binmiş olana.  
\q2 İşte, sesini ortaya koyuyor, heybetli sesini.   
\q1
\v 34 Gücü Tanrı'ya atfedin!  
\q2 O’nun yüceliği İsrael'in üzerindedir,  
\q2 gücü göklerdedir.   
\q1
\v 35 Kutsal yerlerinde muhteşemsin, ey Tanrı.  
\q2 İsrael'in Tanrısı halkına güç ve kudret verir.  
\q2 Övgüler olsun Tanrı’ya!   
\c 69  
\d Müzik şefi için - “Zambaklar” makamında - David’in mezmuru  
\q1
\v 1 Kurtar beni ey Tanrı,  
\q2 çünkü sular boynuma kadar geldi!   
\q1
\v 2 Ayak basılacak yerin olmadığı  
\q2 derin bataklığa batmaktayım.  
\q2 Sellerin beni aştığı derin sulara geldim.   
\q1
\v 3 Ağlamaktan yoruldum.  
\q2 Boğazım kurudu.  
\q2 Gözlerim Tanrı’yı aramayı bırakıyor.   
\q1
\v 4 Nedensiz yere benden nefret edenler  
\q2 başımın saçından çoktur.  
\q2 Beni yok etmek isteyen haksız düşmanlarım güçlüdür.  
\q2 Almadığım şeyi geri vermem gerekiyor.   
\q1
\v 5 Ey Tanrı, akılsızlığımı biliyorsun.  
\q2 Günahlarım senden gizli değil.   
\q1
\v 6 Seni bekleyenler benim yüzümden utanmasın,  
\q2 ey Orduların Efendisi Yahve.  
\q2 Ey İsrael'in Tanrısı benim yüzümden  
\q2 seni arayanlar rezil olmasın.   
\q1
\v 7 Çünkü senin uğruna aşağılanmaya katlandım.  
\q2 Utanç yüzümü kapladı.   
\q1
\v 8 Kardeşlerime yabancı,  
\q2 annemin çocuklarına el oldum.   
\q1
\v 9 Çünkü senin evinin gayreti beni tüketti.  
\q2 Sana edilen hakaretler benim üzerime düştü.   
\q1
\v 10 Ağlayıp oruç tuttuğumda,  
\q2 bu da bana ayıp sayıldı.   
\q1
\v 11 Giysimi çul yaptığımda,  
\q2 onlar için bir masal oldum.   
\q1
\v 12 Kent kapısında oturanlar hakkımda konuşuyorlar.  
\q2 Sarhoşların şarkısı oldum.   
\q1
\v 13 Bense ey Yahve, uygun zamanda duam sanadır.  
\q2 Ey Tanrı, sevgi dolu iyiliğinin bolluğuyla,  
\q2 kurtarışının gerçeğiyle yanıtla beni.   
\q1
\v 14 Beni çamurdan kurtar, batmayayım.  
\q2 Benden nefret edenlerden ve derin sulardan kurtulayım.   
\q1
\v 15 Sel suları beni boğmasın,  
\q2 derinlik beni yutmasın,  
\q2 çukur üzerime ağzını kapamasın.   
\q1
\v 16 Yanıtla beni, ey Yahve, çünkü sevgi dolu iyiliğin iyidir.  
\q2 Sevecen merhametlerinin bolluğuna göre bana yönel.   
\q1
\v 17 Yüzünü hizmetkârından gizleme,  
\q2 çünkü sıkıntıdayım.  
\q2 Bana tez yanıt ver!   
\q1
\v 18 Canıma yaklaş ve onu kurtar.  
\q2 Düşmanlarımdan ötürü beni fidyeyle kurtar.   
\q1
\v 19 Bana edilen hakareti, utancı, rezaleti bilirsin.  
\q2 Düşmanlarımın hepsi senin önündedir.   
\q1
\v 20 Aşağılanma kalbimi kırdı ve içim ağırlaştı.  
\q2 Acıyacak birilerini aradım ama yoktu,  
\q2 teselli edecek kimseyi bulamadım.   
\q1
\v 21 Yiyecek için bana zehir verdiler.  
\q2 Susadığımda içmem için bana sirke verdiler.   
\q1
\v 22 Önlerindeki sofra tuzak olsun,  
\q2 bu onlara ceza ve kapan olsun.   
\q1
\v 23 Gözleri kararsın ki göremesinler.  
\q2 Sırtları hep bükük olsun.   
\q1
\v 24 Gazabını üzerlerine dök.  
\q2 Öfkenin şiddeti onlara yetişsin.   
\q1
\v 25 Yaşadıkları yer ıssız olsun.  
\q2 Çadırında oturan olmasın.   
\q1
\v 26 Çünkü yaraladığın insana zulmediyorlar.  
\q2 Yaraladığın insanın acısını anlatıyorlar.   
\q1
\v 27 Onların cezalarına ceza kat.  
\q2 Senin doğruluğuna girmelerine izin verme.   
\q1
\v 28 Onlar yaşam kitabından silinsinler,  
\q2 doğrularla birlikte yazılmasınlar.   
\q1
\v 29 Bense acı ve sıkıntı içindeyim.  
\q2 Senin kurtarışın, ey Tanrı, beni korusun.   
\q1
\v 30 Tanrı'nın adını bir ezgiyle öveceğim,  
\q2 O’nu şükranla yücelteceğim.   
\q1
\v 31 Yahve’yi bir öküzden,  
\q2 boynuzlu, tırnaklı bir boğadan  
\q2 daha çok memnun eder bu.   
\q1
\v 32 Alçakgönüllüler bunu gördü ve sevindi.  
\q2 ey Tanrı'yı arayan sizler, yüreğiniz yaşasın.   
\q1
\v 33 Çünkü Yahve yoksulu duyar,  
\q2 kendi tutsak halkını hor görmez.   
\q1
\v 34 Gök ve yeryüzü,  
\q2 denizler ve içinde kımıldayan her şey O’nu övsün!   
\q1
\v 35 Çünkü Tanrı Siyon'u kurtaracak,  
\q2 Yahuda kentlerini yeniden inşa edecek.  
\q2 Onlar oraya yerleşip mülk edinecekler.   
\q1
\v 36 Hizmetkârının çocukları da onu miras alacaklar.  
\q2 O’nun adını sevenler orada oturacaklar.   
\c 70  
\d Müzik şefi için - Anma sunusu için - David’in mezmuru  
\q1
\v 1 Ey Tanrı, beni kurtarmak için acele et.  
\q2 Yardımıma koş, ey Yahve.   
\q1
\v 2 Canımı arayanlar  
\q2 hayal kırıklığına uğrayıp  
\q2 şaşkına dönsünler.  
\q2 Mahvolmamı isteyenler  
\q2 rezil olup geri dönsünler.   
\q1
\v 3 Bana “Oh! Oh!” diyenler  
\q2 utançlarından geri dönsünler.   
\q1
\v 4 Bütün seni arayanlar  
\q2 sende sevinip coşsunlar.  
\q2 Senin kurtarışını sevenler sürekli,  
\q2 “Tanrı yücelsin!” desinler.   
\q1
\v 5 Bense yoksul ve muhtacım.  
\q2 Tez bana gel, ey Tanrı.  
\q2 Sensin benim yardımcım ve kurtarıcım.  
\q2 Geç kalma ey Yahve.   
\c 71  
\q1
\v 1 Sana sığınıyorum, ey Yahve.  
\q2 Hayal kırıklığına uğratma beni hiçbir zaman.   
\q1
\v 2 Beni kendi doğruluğunla kurtar,  
\q2 bana yardım et.  
\q2 Kulak ver bana ve beni kurtar.   
\q1
\v 3 Her zaman gidebileceğim  
\q2 sığınacak kayam ol.  
\q2 Kurtulmam için buyruk ver,  
\q2 çünkü kayam ve kalem sensin benim.   
\q1
\v 4 Ey Tanrı, kurtar beni,  
\q2 kötünün, haksızın, zalimin elinden.   
\q1
\v 5 Çünkü benim umudum,  
\q2 gençliğimden beri güvendiğim  
\q2 sensin, ey Efendi Yahve.   
\q1
\v 6 Ana rahminden beri sana güvendim.  
\q2 Beni ana rahminden çıkaran sensin.  
\q2 Seni hep öveceğim.   
\q1
\v 7 Birçokları için şaşılacak biriyim,  
\q2 ama sen benim güçlü sığınağımsın.   
\q1
\v 8 Ağzım senin övgünle,  
\q2 gün boyu senin yüceliğinle dolu olacak.   
\q1
\v 9 Yaşlılığımda beni reddetme.  
\q2 Gücüm tükendiğinde beni bırakma.   
\q1
\v 10 Çünkü düşmanlarım hakkımda konuşuyor.  
\q2 Canımı gözleyenler birlikte düzen kuruyorlar.   
\q1
\v 11 “Tanrı onu terk etti” diyorlar.  
\q2 “Peşine düşün ve yakalayın, çünkü onu kurtaracak kimse yok.”   
\q1
\v 12 Ey Tanrı, benden uzak durma.  
\q2 Tanrım, yardımıma koş.   
\q1
\v 13 Beni suçlayanlar hayal kırıklığıyla yok olsunlar.  
\q2 Bana zarar vermek isteyenleri,  
\q2 rezillik ve utanç kaplasın.   
\q1
\v 14 Ama ben hep umut ederim,  
\q2 övgülerine övgü eklerim.   
\q1
\v 15 Ağzım senin doğruluğunu,  
\q2 tam ölçüsünü bilmesem de,  
\q2 tüm gün senin kurtuluşundan söz edecek.   
\q1
\v 16 Efendi Yahve’nin büyük işleriyle geleceğim.  
\q2 Senin doğruluğundan,  
\q2 yalnızca senin doğruluğundan söz edeceğim.   
\q1
\v 17 Ey Tanrı, gençliğimden beri bana öğrettin.  
\q2 Şimdiye dek şaşılası işlerini ilan ettim.   
\q1
\v 18 Evet, yaşlanıp saçlarıma ak düşse de, ey Tanrı  
\q2 Gücünü gelecek kuşağa,  
\q2 büyüklüğünü gelecek olanların hepsine bildirene dek,  
\q2 beni bırakma,   
\q1
\v 19 Ey Tanrı, doğruluğun göklere erişiyor.  
\q2 Büyük işler yaptın.  
\q2 Senin gibisi var mı, ey Tanrı?   
\q1
\v 20 Sen ki, bize çok acı dertler gösterdin,  
\q2 beni yaşatacak,  
\q2 yerin derinliklerinden bizi yeniden çıkaracaksın.   
\q1
\v 21 Saygınlığımı artır,  
\q2 beni yeniden rahatlat.   
\q1
\v 22 Ben de seni sadakatinden ötürü  
\q2 seni arpla öveceğim, ey Tanrım.  
\q2 Lirle sana ilahiler söyleyeceğim, ey İsrael'in Kutsalı.   
\q1
\v 23 Dudaklarım sevinçle haykıracak!  
\q2 Kurtarmış olduğun canım  
\q2 seni ezgilerle övecek!   
\q1
\v 24 Dilim de bütün gün senin doğruluğundan söz edecek,  
\q2 çünkü bana zarar vermek isteyenler,  
\q2 hayal kırıklığına uğrayıp kahroldular.   
\c 72  
\d Solomon’un mezmuru  
\q1
\v 1 Ey Tanrı, adaletini krala,  
\q2 doğruluğunu kral oğluna ver.   
\q1
\v 2 Halkını doğrulukla,  
\q2 yoksullarını adaletle yargılasın.   
\q1
\v 3 Dağlar halka bolluk getirsin.  
\q2 Tepeler doğruluğun meyvesini versin.   
\q1
\v 4 Halkının yoksullarına hakkını versin.  
\q2 Muhtaçların çocuklarını kurtarsın,  
\q2 zalimi parçalasın.   
\q1
\v 5 Güneş ve ay durdukça,  
\q2 tüm nesiller boyunca senden korksunlar.   
\q1
\v 6 Yeni biçilmiş çayıra düşen yağmur gibi,  
\q2 toprağı sulayan bol yağmurlar gibi olsun.   
\q1
\v 7 Onun günlerinde doğrular serpilip gelişsin,  
\q2 ay yok olana dek esenlik çoğalsın.   
\q1
\v 8 Denizden denize,  
\q2 ırmak'tan dünyanın sonlarına dek hüküm sürsün.   
\q1
\v 9 Çölde yaşayanlar önünde eğilsin.  
\q2 Düşmanları toz yalasın,   
\q1
\v 10 Tarşiş ve ada kralları ona haraç getirsin.  
\q2 Saba ve Seva kralları armağanlar sunsun.   
\q1
\v 11 Bütün krallar önünde yere kapansın.  
\q2 Bütün uluslar ona hizmet etsin.   
\q1
\v 12 Çünkü yardım için haykıran muhtacı,  
\q2 destekçisi olmayan yoksulu kurtarır.   
\q1
\v 13 Yoksula ve muhtaca merhamet eder.  
\q2 Muhtaçların canlarını kurtarır.   
\q1
\v 14 Canlarını baskı ve şiddetten kurtarır.  
\q2 Gözünde onların kanı değerlidir.   
\q1
\v 15 Onlar yaşasınlar ve ona Saba altınından verilsin.  
\q2 Onun için sürekli dua etsinler.  
\q2 Bütün gün onu kutsasınlar.   
\q1
\v 16 Ülkenin her yerinde tahıl bolluğu olsun.  
\q2 Meyvesi Lübnan gibi dalgalansın.  
\q2 Toprağın çayırı gibi serpilip gelişsin.   
\q1
\v 17 Adı sonsuza dek dursun.  
\q2 Güneş durdukça adı dursun.  
\q2 İnsanlar onun tarafından kutsansın.  
\q2 Bütün uluslar ona kutsanmış desinler.   
\q1
\v 18 İsrael'in Tanrısı, Yahve Tanrı'ya övgüler olsun.  
\q2 Şaşılacak işler yapan yalnızca O’dur.   
\q1
\v 19 O'nun yüce adına sonsuza dek övgüler olsun!  
\q2 Bütün yeryüzü O’nun yüceliğiyle dolsun!  
\q2 Amin ve amin.   
\p
\v 20 Böylece Yişay oğlu David'in duası sona erer.   
\c 73  
\d Asaf’ın mezmuru  
\q1
\v 1 Tanrı\f + \fr 73:1 \ft “Tanrı” olarak tercüme edilen İbranice kelime “אֱלֹהִ֑ים” (Elohim)’dir.\f* kesinlikle İsrael’e,  
\q2 yüreği temiz olanlara karşı iyidir.   
\q1
\v 2 Ama benim ayaklarım neredeyse tükenmişti.  
\q2 Adımlarım az kalsın kaymıştı.   
\q1
\v 3 Çünkü kötülerin bolluk içinde olduğunu görünce,  
\q2 kibirlileri kıskandım.   
\q1
\v 4 Çünkü ölümlerinde çırpınma yoktur,  
\q2 güçleri sağlamdır.   
\q1
\v 5 İnsan yüklerinden özgürdürler,  
\q2 öteki insanlar gibi dertli de değiller.   
\q1
\v 6 Bu nedenle gurur onların boynundaki zincir gibi,  
\q2 şiddet onları saran bir giysi gibidir.   
\q1
\v 7 Gözleri şişmanlıktan dışarı fırlamış,  
\q2 akılları kibrin sınırlarını aşmıştır.   
\q1
\v 8 Alay ederler ve kötü niyetle konuşurlar.  
\q2 Kibirle, baskıyla tehdit ederler.   
\q1
\v 9 Ağızlarını göklere çevirdiler.  
\q2 Dilleri yeryüzünde dolaşır.   
\q1
\v 10 Bu nedenle onların halkları onlara geri döner,  
\q2 bolluk sularından içerler.   
\q1
\v 11 Onlar, “Tanrı nereden biliyor?” derler.  
\q2 “Yüceler Yücesi'nde bilgi var mı?”   
\q1
\v 12 İşte, kötüler bunlardır.  
\q2 Daima rahatlar ve zenginliklerini artırırlar.   
\q1
\v 13 Gerçekten yüreğimi boşuna temizlemişim,  
\q2 ellerimi masumiyetle yıkamışım,   
\q1
\v 14 gün boyunca sıkıntı çektim,  
\q2 her sabah cezalandırıldım.   
\q1
\v 15 Eğer “Ben böyle konuşayım” deseydim,  
\q2 işte, senin çocuklarının nesline ihanet etmiş olurdum.   
\q1
\v 16 Bunu anlamaya çalıştığımda,  
\q2 bana çok acı verdi,   
\q1
\v 17 Ta ki, Tanrı’nın tapınağına girip,  
\q2 onların sonunu anlayana kadar.   
\q1
\v 18 Gerçekten onları kaygan yerlere koyarsın.  
\q2 Onları yıkıma atarsın.   
\q1
\v 19 Nasıl da ansızın yok oluyorlar!  
\q2 Dehşet içinde büsbütün süpürülüp atıldılar.   
\q1
\v 20 Uyanınca görülen bir rüya gibi,  
\q2 sen de ey Efendi,\f + \fr 73:20 \ft “Efendi” olarak tercüme edilen sözcük “Adonay”dır.\f*  
\q2 uyanınca onların hayallerini hor göreceksin.   
\q1
\v 21 Çünkü canım acı çekiyordu.  
\q2 Yüreğim buruktu.   
\q1
\v 22 Bense o denli akılsız ve bilgisiz,  
\q2 önünde vahşi bir hayvan gibiydim.   
\q1
\v 23 Ama yine de sürekli seninleyim.  
\q2 Sağ elimden tuttun.   
\q1
\v 24 Öğüdünle bana yol gösterirsin,  
\q2 sonunda beni yüceliğe alırsın.   
\q1
\v 25 Gökte kimim var?  
\q2 Yeryüzünde senden başkasını istemem.   
\q1
\v 26 Bedenim ve yüreğim tükeniyor,  
\q2 ama Tanrı yüreğimin gücü,  
\q2 sonsuza dek bana düşen paydır.   
\q1
\v 27 Çünkü işte, senden uzak olanlar yok olur.  
\q2 Sana sadakatsiz olanların hepsini yok ettin.   
\q1
\v 28 Ama Tanrı'ya yaklaşmak benim için iyidir.  
\q2 Senin bütün işlerini bildireyim diye,  
\q2 Efendi Yahve’yi\f + \fr 73:28 \ft “Yahve” Tanrı’nın asıl ismidir, diğer çevirilerde bazen “RAB=EFENDİ” (tamamı büyük harflerle) olarak çevrilir.\f* kendime sığınak yaptım.   
\c 74  
\d Asaf’ın Maskili  
\q1
\v 1 Ey Tanrı, neden bizi sonsuza dek reddettin?  
\q2 Otlağının koyunlarına karşı öfken  
\q2 neden için için yanıyor?   
\q1
\v 2 Eskiden satın aldığın topluluğunu,  
\q2 mirasın olmak üzere kurtardığın oymağı,  
\q2 üzerinde yaşadığın Siyon Dağı’nı hatırla.   
\q1
\v 3 Ayaklarını sonsuz yıkıntılara doğru kaldır,  
\q2 düşman kutsal yerde her kötülüğü etti.   
\q1
\v 4 Düşmanların senin toplantı yerinin ortasında kükrüyor.  
\q2 İşaret olarak kendi bayraklarını diktiler.   
\q1
\v 5 Gür bir ormanı kesen  
\q2 baltalı adamlar gibi davrandılar.   
\q1
\v 6 Şimdi onun bütün oyma işlerini  
\q2 balta ve çekiçlerle kırıyorlar.   
\q1
\v 7 Tapınağını yakıp yıktılar.  
\q2 Adını taşıyan konutu kirlettiler.   
\q1
\v 8 Yüreklerinde, “Onları tamamen ezeceğiz” dediler.  
\q2 Ülkede Tanrı'ya tapınılan her yeri yaktılar.   
\q1
\v 9 Hiçbir mucizevi belirti görmüyoruz.  
\q2 Artık peygamber yok,  
\q2 içimizde ne kadar süreceğini bilen de yok.   
\q1
\v 10 Düşman ne zamana dek azarlayacak, ey Tanrı?  
\q2 Düşman sonsuza dek mi senin ismine sövecek?   
\q1
\v 11 Elini, sağ elini niçin geri çekiyorsun?  
\q2 Onu göğsünden çıkar ve onları yakıp kül et!   
\q1
\v 12 Ama Tanrı eski zamanlardan beri Kralım’dır,  
\q2 tüm yeryüzünde kurtuluş sağlar.   
\q1
\v 13 Gücünle denizi yardın.  
\q2 Sulardaki deniz canavarlarının kafasını kırdın.   
\q1
\v 14 Sen Livyatan'ın başlarını parçaladın.  
\q2 Onu yiyecek olarak insanlara ve çöl canlılarına verdin.   
\q1
\v 15 Sen pınarı ve kaynağı fışkırttın.  
\q2 Güçlü ırmakları kuruttun.   
\q1
\v 16 Gündüz senindir, gece de senin.  
\q2 Işığı ve güneşi sen hazırladın.   
\q1
\v 17 Yeryüzünün bütün sınırlarını sen belirledin.  
\q2 Yazı ve kışı yaratan sensin.   
\q1
\v 18 Düşmanın seninle alay ettiğini unutma, ey Yahve.  
\q2 Akılsız bir halk senin adına küfretti.   
\q1
\v 19 Kendi kumrunun canını canavarlara teslim etme.  
\q2 Yoksullarının yaşamını sonsuza dek unutma.   
\q1
\v 20 Antlaşmanı say,  
\q2 çünkü yeryüzünün karanlık yerleri  
\q2 Zorbalık inleriyle dolmuş.   
\q1
\v 21 Ezilen utanç içinde geri dönmesin.  
\q2 Yoksul ve muhtaçlar senin adını yüceltsinler.   
\q1
\v 22 Kalk, ey Tanrı! Kendi davanı savun.  
\q2 Akılsızın bütün gün seninle nasıl alay ettiğini hatırla.   
\q1
\v 23 Düşmanlarının sesini unutma.  
\q2 Sana karşı ayaklananların patırtısı sürekli yükseliyor.   
\c 75  
\d Müzik şefi için - “Yok Etme” makamında - Asaf’ın mezmuru - İlahi  
\q1
\v 1 Sana şükrederiz ey Tanrı.  
\q2 Şükrederiz, çünkü adın yakındır.  
\q2 İnsanlar senin şaşılası işlerini anlatırlar.   
\q1
\v 2 Belirlenen vakti seçtiğimde,  
\q2 kusursuzca ben yargılayacağım.   
\q1
\v 3 Yeryüzünde oturanların tümü sarsılıyor.  
\q2 Onun direklerini sağlam bir şekilde ben tutuyorum. Selah.   
\q1
\v 4 Kibirlilere, “Övünmeyin!”,  
\q2 kötülere, “Boynuzu yukarı kaldırmayın” dedim.   
\q1
\v 5 “Boynuzunuzu kaldırmayın.  
\q2 Sert boyunla konuşmayın.”   
\q1
\v 6 Çünkü ne doğudan, ne de batıdan,  
\q2 ne de güneyden gelir yükselme.   
\q1
\v 7 Yargıç ancak Tanrı'dır.  
\q2 Birini alçaltır, ötekini yükseltir.   
\q1
\v 8 Çünkü Yahve’nin elinde bir kase var,  
\q2 baharatla karıştırılmış köpüklü şarapla dolu.  
\q2 Ondan döker.  
\q2 Gerçekten dünyanın kötüleri  
\q2 onun tortusuna dek yalayıp içerler.   
\q1
\v 9 Bense daima bunu ilan edeceğim,  
\q2 Yakov'un Tanrısı'nı ilahilerle öveceğim.   
\q1
\v 10 Kötülerin bütün boynuzlarını kıracağım,  
\q2 doğruların boynuzlarıysa yükseltilecektir.   
\c 76  
\d Müzik şefi için - Telli sazlarla - Asaf’ın mezmuru - İlahi  
\q1
\v 1 Yahuda'da Tanrı bilinir.  
\q2 İsrael'de adı büyüktür.   
\q1
\v 2 Konutu Şalem’dedir,  
\q2 meskeni Siyon'da.   
\q1
\v 3 Orada yayın alevli oklarını,  
\q2 kalkanı, kılıcı ve savaş silahlarını kırdı. Selah.   
\q1
\v 4 Ne yüce, ne muhteşemsin,  
\q2 av dağlarından daha yüce.   
\q1
\v 5 Yiğitler yağmalanmış halde yatıyor,  
\q2 son uykuya yattılar.  
\q2 Hiçbir savaş eri elini kaldıramaz.   
\q1
\v 6 Ey Yakov'un Tanrısı, sen azarlayınca,  
\q2 savaş arabası da atlar da ölüm uykusuna daldılar.   
\q1
\v 7 Yalnız sensin korkulması gereken.  
\q2 Öfkelendiğinde kim karşında durabilir?   
\q1
\v 8 Yeryüzünde acı çekenleri kurtarmak için  
\q2 Tanrı yargılamaya kalktığında,   
\q1
\v 9 Yargını gökten bildirdin,  
\q2 yer korktu ve sustu. Selah.   
\q1
\v 10 Elbette insanın gazabı seni över.  
\q2 Gazabından sağ kurtulanlar dizginlendi.   
\q1
\v 11 Tanrınız Yahve’ye adak adayın,  
\q2 onları yerine getirin!  
\q2 Armağanlar sunun korkulması gereken O’na,  
\q2 ey siz çevresindekiler.   
\q1
\v 12 O, beylerin ruhunu kırar.  
\q2 Yeryüzü kralları O’ndan korkar.   
\c 77  
\d Müzik Şefi Yedutun için - Asaf’ın mezmuru  
\q1
\v 1 Haykırışım Tanrı’yadır!  
\q2 Yardım için,  
\q2 beni duysun diye Tanrı'ya haykırırım.   
\q1
\v 2 Sıkıntılı günde Efendi’yi aradım.  
\q2 Geceleyin elimi açtım ve gevşemedi.  
\q2 Canım teselli edilmeyi reddetti.   
\q1
\v 3 Tanrı'yı anıyorum ve inliyorum.  
\q2 Yakınıyorum ve ruhum bunalmış durumda. Selah.   
\q1
\v 4 Göz kapaklarımı açık tutuyorsun.  
\q2 Konuşamayacak kadar çok sıkıntılıyım.   
\q1
\v 5 Eski günleri,  
\q2 geçmiş devirlerin yıllarını düşünmekteyim.   
\q1
\v 6 Gece ilahimi hatırlıyorum.  
\q2 Kendi yüreğimi düşünüyorum;  
\q2 ruhum inceden inceye soruyor:   
\q1
\v 7 “Efendi bizi sonsuza dek mi reddedecek?  
\q2 Bir daha lütuf göstermeyecek mi?   
\q1
\v 8 O’nun sevgi dolu iyiliği sonsuza dek mi yok oldu?  
\q2 Nesiller boyunca verdiği söz boşa mı çıkıyor?   
\q1
\v 9 Tanrı lütufkâr olmayı unuttu mu?  
\q2 Merhametini öfkeyle geri mi çekti?” Selah.   
\q1
\v 10 Sonra şöyle düşündüm:  
\q2 “Yüceler Yücesi'nin sağ elinin yıllarını anacağım.”   
\q1
\v 11 Yah'ın yaptıklarını hatırlayacağım;  
\q2 çünkü senin eski harikalarını anarım.   
\q1
\v 12 Ben de senin bütün işlerin üzerinde derin derin düşünürüm,  
\q2 yaptıklarını dikkate alırım.   
\q1
\v 13 Senin yolun, ey Tanrı, kutsal yerdedir.  
\q2 Hangi ilâh Tanrı kadar büyüktür?   
\q1
\v 14 Sen harikalar yaratan Tanrı’sın.  
\q2 Gücünü halklar arasında bildirdin.   
\q1
\v 15 Halkını kolunla,  
\q2 Yakov ve Yosef’in oğullarını kurtardın. Selah.   
\q1
\v 16 Sular seni gördü, ey Tanrı.  
\q2 Sular seni gördü ve çalkalandı.  
\q2 Derinlikler de sarsıldı.   
\q1
\v 17 Bulutlar suyunu boşalttı.  
\q2 Gökler gök gürültüsüyle ses verdi.  
\q2 Okların da etrafta ışık çaktı.   
\q1
\v 18 Gürleyişinin sesi kasırgadaydı.  
\q2 Şimşekler dünyayı aydınlattı.  
\q2 Yer titredi ve sarsıldı.   
\q1
\v 19 Senin yolun denizden geçiyordu;  
\q2 yolların büyük sulardaydı.  
\q2 Ayak izlerin belli değildi.   
\q1
\v 20 Moşe ve Aron’un eliyle,  
\q2 halkını sürü gibi güttün.   
\c 78  
\d Asaf’ın Maskili  
\q1
\v 1 Öğrettiğime kulak verin, ey halkım.  
\q2 Ağzımdan çıkan sözlere kulaklarınızı çevirin.   
\q1
\v 2 Ağzımı bir benzetmeyle açacağım.  
\q2 Eskilerin sırlarını söyleyeceğim,   
\q1
\v 3 onları işittik ve bildik,  
\q2 atalarımız bize anlattı.   
\q1
\v 4 Onları çocuklarından saklamayacağız,  
\q2 Yahve’nin övgülerini,  
\q2 gücünü ve yaptığı şaşılası işleri,  
\q2 gelecek kuşağa anlatacağız.   
\q1
\v 5 Çünkü Yakov'la bir antlaşma yaptı,  
\q2 İsrael'de bir öğreti atadı,  
\q2 atalarımıza bunları çocuklarına öğretmelerini buyurdu.   
\q1
\v 6 Gelecek nesiller, hatta doğmamış çocuklar bilsin de,  
\q2 onlar da kalkıp kendi çocuklarına anlatsınlar.   
\q1
\v 7 Böylece umutlarını Tanrı'ya bağlasınlar,  
\q2 Tanrı’nın yaptıklarını unutmasınlar,  
\q2 buyruklarını tutsunlar.   
\q1
\v 8 Ataları gibi inatçı ve asi,  
\q2 yürekleri vefasız,  
\q2 ruhları Tanrı’ya sadakatsiz bir nesil olmasınlar.   
\q1
\v 9 Silahlı, yay taşıyan Efraim'in çocukları,  
\q2 savaş gününde geri döndüler.   
\q1
\v 10 Tanrı'nın antlaşmasına uymadılar,  
\q2 O’nun yasasında yürümeyi reddettiler.   
\q1
\v 11 O’nun yaptıklarını,  
\q2 onlara göstermiş olduğu şaşılası işlerini unuttular.   
\q1
\v 12 Mısır diyarında, Soan kırında,  
\q2 atalarımızın önünde şaşılacak işler yaptı.   
\q1
\v 13 Denizi yardı ve onları içinden geçirdi.  
\q2 Suları yığın gibi durdurdu.   
\q1
\v 14 Gündüzleri bulutla,  
\q2 gece boyu ateş ışığıyla onlara yol gösterdi.   
\q1
\v 15 Çölde kayaları yardı,  
\q2 derinliklerden geliyormuşçasına onlara bol bol içirdi.   
\q1
\v 16 Kayadan dereler çıkardı,  
\q2 suları ırmaklar gibi akıttı.   
\q1
\v 17 Yine de O’na karşı günah işlemeye devam ettiler.  
\q2 En Yüce Olan'a isyan ettiler.   
\q1
\v 18 İştahlarına göre yemek isteyerek,  
\q2 yüreklerinde Tanrı’yı denediler.   
\q1
\v 19 Tanrı'ya karşı konuşup,  
\q2 “Tanrı çölde sofra kurabilir mi?” dediler.   
\q1
\v 20 “İşte kayaya vurdu ve sular fışkırdı,  
\q2 ırmaklar taştı.  
\q2 Ekmek de verebilir mi?  
\q2 Halkına et sağlayabilir mi?”   
\q1
\v 21 Bunun üzerine Yahve işitip öfkelendi.  
\q2 Yakov'a karşı ateş tutuştu,  
\q2 ve öfke İsrael'e karşı yükseldi,   
\q1
\v 22 Çünkü Tanrı'ya inanmadılar,  
\q2 O’nun kurtarışına güvenmediler.   
\q1
\v 23 Yine de yukarıda göklere buyurdu,  
\q2 göklerin kapılarını açtı.   
\q1
\v 24 Yemek için üzerlerine man yağdırdı,  
\q2 onlara gökten yiyecek verdi.   
\q1
\v 25 İnsanlar meleklerin ekmeğini yedi.  
\q2 Onlara doyasıya yiyecek gönderdi.   
\q1
\v 26 Gökte doğu rüzgârını estirdi.  
\q2 Gücüyle güney rüzgârına yol gösterdi.   
\q1
\v 27 Üzerlerine toz gibi et,  
\q2 denizlerin kumu gibi kanatlı kuşlar yağdırdı.   
\q1
\v 28 Onları ordugâhlarının ortasına,  
\q2 oturdukları yerlerin çevresine düşürdü.   
\q1
\v 29 Böylece yediler ve iyice doydular.  
\q2 Onlara dilediklerini verdi.   
\q1
\v 30 Arzularından vazgeçmediler.  
\q2 Yiyecekleri hâlâ ağızlarındayken   
\q1
\v 31 Tanrı'nın öfkesi onlara karşı yükseldi,  
\q2 en şişmanlarından bazılarını öldürdü,  
\q2 İsrael'in gençlerini yere serdi.   
\q1
\v 32 Bütün bunlara rağmen yine günah işlediler,  
\q2 O’nun şaşılası işlerine inanmadılar.   
\q1
\v 33 Bu yüzden günlerini boşlukla,  
\q2 yıllarını dehşetle tüketti.   
\q1
\v 34 Kendilerini öldürdüğü zaman O'nu araştırdılar.  
\q2 Geri döndüler ve gayretle Tanrı'yı aradılar.   
\q1
\v 35 Tanrı'nın kayaları olduğunu,  
\q2 yüce Tanrı’nın kurtarıcıları olduğunu hatırladılar.   
\q1
\v 36 Ama ağızlarıyla O'nu överken,  
\q2 dilleriyle O’na yalan söylediler.   
\q1
\v 37 Çünkü yürekleri O’nunla doğru değildi,  
\q2 ne de O’nun antlaşmasına sadıklardı.   
\q1
\v 38 Ama O, merhametli davranarak  
\q2 kötülüğü bağışladı ve onları yok etmedi.  
\q2 Evet, birçok kez öfkesini yatıştırdı,  
\q2 gazabını tümüyle uyandırmadı.   
\q1
\v 39 Onların yalnızca insan olduğunu hatırladı,  
\q2 geçip giden ve bir daha dönmeyen bir yel.   
\q1
\v 40 Çölde O’na kaç kez isyan ettiler,  
\q2 ıssız yerde O’nu gücendirdiler!   
\q1
\v 41 Dönüp dönüp Tanrı'yı denediler,  
\q2 ve İsrael'in Kutsalı’nı kışkırttılar.   
\q1
\v 42 O’nun elini, düşmandan kurtardığı günü hatırlamadılar.   
\q1
\v 43 Mısır'da gerçekleştirdiği belirtileri,  
\q2 Soan bölgesindeki şaşılası işleri,   
\q1
\v 44 ırmaklarını ve akarsularını,  
\q2 içmesinler diye kana çevirdi.   
\q1
\v 45 Aralarına onları yiyip bitiren sinek sürüleri,  
\q2 onları yok eden kurbağalar gönderdi.   
\q1
\v 46 Onların mahsullerini tırtıla,  
\q2 emeğini çekirgeye verdi.   
\q1
\v 47 Bağlarını doluyla,  
\q2 yabanıl incir ağaçlarını kırgınla yok etti.   
\q1
\v 48 Hayvanlarını doluya,  
\q2 sürüleri yakıcı yıldırımlara teslim etti.   
\q1
\v 49 Kızgın öfkesini üzerlerine,  
\q2 gazap, hışım ve sıkıntı,  
\q2 bir alay kötülük meleği gönderdi.   
\q1
\v 50 Öfkesine yol açtı,  
\q2 canlarını ölümden esirgemedi,  
\q2 yaşamlarını vebaya teslim etti,   
\q1
\v 51 Mısır'da ilk doğanların hepsini,  
\q2 Ham'ın çadırlarındaki güçlerinin ilkini vurdu.   
\q1
\v 52 Ama kendi halkını koyun gibi götürdü,  
\q2 çölde onları sürü gibi güttü.   
\q1
\v 53 Onları güvenlik içinde götürdü ve korkmadılar.  
\q2 Ama deniz düşmanlarını alt etti.   
\q1
\v 54 Onları kendi tapınağının sınırına,  
\q2 sağ elinin götürdüğü bu dağa getirdi.   
\q1
\v 55 Önlerinden ulusları da kovdu,  
\q2 onlara miras olarak sırayla pay verdi,  
\q2 İsrael oymaklarını çadırlarında oturttu.   
\q1
\v 56 Ama yine de Yüce Tanrı'yı deneyip O’na isyan ettiler.  
\q2 O’nun tanıklıklarını tutmadılar.   
\q1
\v 57 Ataları gibi geri dönüp hainlik yaptılar.  
\q2 Aldatıcı bir yay gibi eğrildiler.   
\q1
\v 58 Çünkü yüksek yerleriyle O'nu öfkelendirdiler,  
\q2 oyma suretleriyle O’nu kıskandırdılar.   
\q1
\v 59 Tanrı bunu duyunca öfkelendi,  
\q2 İsrael'den büsbütün iğrendi,   
\q1
\v 60 Böylece insanlar arasında kurduğu çadırı,  
\q2 Şilo çadırını terk etti,   
\q1
\v 61 gücünü sürgüne,  
\q2 yüceliğini düşmanın eline teslim etti.   
\q1
\v 62 Halkını da kılıca teslim etti,  
\q2 mirasına öfkelenmişti.   
\q1
\v 63 Gençlerini ateş yuttu.  
\q2 El değmemiş kızların düğün şarkısı yoktu.   
\q1
\v 64 Kâhinleri kılıçla düştüler,  
\q2 dul karıları ağlayamadı.   
\q1
\v 65 Bunun üzerine Efendi uykudan uyanan biri gibi,  
\q2 şaraptan bağıran güçlü bir adam gibi uyandı.   
\q1
\v 66 Düşmanlarını arkadan vurdu.  
\q2 Onları sonsuz utanç içinde bıraktı.   
\q1
\v 67 Üstelik Yosef'in çadırını da reddetti,  
\q2 Efraim oymağını seçmedi,   
\q1
\v 68 Ama Yahuda oymağını,  
\q2 sevdiği Siyon Dağı’nı seçti.   
\q1
\v 69 Tapınağını yükseklikler gibi,  
\q2 sonsuza dek kurduğu yeryüzü gibi yaptı.   
\q1
\v 70 Ve hizmetkârı David'i seçti;  
\q2 onu koyun ağıllarından aldı,   
\q1
\v 71 Halkı Yakov’u ve mirası İsrael’in çobanı olmak üzere,  
\q2 onu yavru kuzuların peşinden getirdi.   
\q1
\v 72 Böylece yüreğinin dürüstlüğüne göre onların çobanı oldu,  
\q2 becerikli elleriyle onlara yol gösterdi.   
\c 79  
\d Asaf’ın mezmuru  
\q1
\v 1 Ey Tanrı, uluslar senin mirasına girdiler.  
\q2 Kutsal tapınağını kirlettiler.  
\q2 Yeruşalem’i taş yığınlarına döndürdüler.   
\q1
\v 2 Hizmetkârlarının cesetlerini gökteki kuşlara,  
\q2 kutsallarının etini yeryüzündeki hayvanlara yem olsun diye verdiler.   
\q1
\v 3 Kanlarını Yeruşalem'in çevresine su gibi döktüler.  
\q2 Onları gömecek kimse yok.   
\q1
\v 4 Komşularımıza yüz karası,  
\q2 etrafımızdakilere eğlence ve alay konusu olduk.   
\q1
\v 5 Ne zamana dek, ey Yahve?  
\q2 Sonsuza dek kızgın mı kalacaksın?  
\q2 Kıskançlığın ateş gibi yanacak mı?   
\q1
\v 6 Öfkeni seni tanımayan ulusların üzerine,  
\q2 senin adını anmayan krallıkların üzerine dök.   
\q1
\v 7 Çünkü onlar Yakov'u yuttular,  
\q2 yurdunu yok ettiler.   
\q1
\v 8 Atalarımızın suçlarını bize karşı tutma.  
\q2 Sevecen merhametlerin bizimle tez buluşsun,  
\q2 çünkü çok muhtacız.   
\q1
\v 9 Adının yüceliği uğruna bize yardım et,  
\q2 ey kurtuluşumuzun Tanrısı.  
\q2 Adın uğruna bizi kurtar ve günahlarımızı bağışla.   
\q1
\v 10 Uluslar neden “Nerede onların Tanrısı?” desin?  
\q2 Hizmetkârlarının dökülen kanının intikamı alındığı,  
\q2 gözlerimizin önünde, uluslar arasında bilinsin.   
\q1
\v 11 Tutsakların iniltisi senin önüne gelsin.  
\q2 Gücünün büyüklüğüne göre, ölüme mahkûm olanları koru.   
\q1
\v 12 Komşularımıza sana ettikleri hakaretin aşağılanmasını,  
\q2 onların bağrına yedi kat geri öde, ey Efendimiz.   
\q1
\v 13 Böylece biz, senin halkın ve otlağının koyunları,  
\q2 sana daima şükredeceğiz.  
\q2 Tüm nesiller boyunca seni daima öveceğiz.   
\c 80  
\d Müzik şefi - “Zambaklar Antlaşması” makamında - Asaf’ın mezmuru  
\q1
\v 1 Duy bizi, ey İsrael’in Çobanı,  
\q2 Yosef'i sürü gibi güden,  
\q2 keruvlar üzerinde oturan sensin,  
\q2 saç ışığını.   
\q1
\v 2 Efraim, Benyamin ve Manaşşe'nin önünde  
\q2 uyandır gücünü!  
\q2 Gel ve kurtar bizi!   
\q1
\v 3 Ey Tanrı, bizi döndür,  
\q2 yüzün parlasın,  
\q2 biz de kurtuluruz.   
\q1
\v 4 Ordular Tanrısı Yahve,  
\q2 halkının duasına karşı daha ne kadar öfkeleneceksin?   
\q1
\v 5 Onları gözyaşı ekmeğiyle besledin,  
\q2 onlara içmeleri için bol miktarda gözyaşı verdin.   
\q1
\v 6 Bizi komşularımızla çekişme kaynağı haline getirdin.  
\q2 Düşmanlarımız kendi aralarında gülüşüyorlar.   
\q1
\v 7 Bizi döndür, ey Ordular Tanrısı.  
\q2 Yüzün parlasın,  
\q2 biz de kurtuluruz.   
\q1
\v 8 Mısır'dan bir asma getirdin.  
\q2 Ulusları kovdun ve onu diktin.   
\q1
\v 9 Onun için toprağı temizledin.  
\q2 Derin kök saldı ve ülkeyi doldurdu.   
\q1
\v 10 Dağlar onun gölgesiyle kaplandı.  
\q2 Dalları Tanrı’nın sedirleri gibiydi.   
\q1
\v 11 Dalları denize,  
\q2 filizleri nehre kadar uzandı.   
\q1
\v 12 Duvarlarını neden yıktın,  
\q2 yoldan geçen herkes onu neden koparıyor?   
\q1
\v 13 Ormandan çıkan domuz onu harap ediyor.  
\q2 Kırdaki yabanıl hayvanlar ondan besleniyor.   
\q1
\v 14 Sana yalvarıyoruz, ey Ordular Tanrısı, geri dön  
\q2 gökten aşağıya bak ve gör bu asmayı,   
\q1
\v 15 sağ elinin diktiği çubuğu,  
\q2 Kendin için kuvvetlendirdiğin dalı ziyaret et.   
\q1
\v 16 Ateşle yandı.  
\q2 Kesildi.  
\q2 Senin azarlamanla yok olup gidiyorlar.   
\q1
\v 17 Senin elin, sağ elinin adamı üzerinde,  
\q2 kendin için kuvvetlendirdiğin insanoğlunun üzerinde olsun.   
\q1
\v 18 Böylece senden ayrılmayacağız.  
\q2 Canlandır bizi, biz de senin adını çağıralım.   
\q1
\v 19 Ey Ordular Tanrısı Yahve, bizi döndür,  
\q2 yüzün parlasın, biz de kurtuluruz.   
\c 81  
\d Müzik şefi için - Gittit üzerine - Asaf’ın mezmuru  
\q1
\v 1 Gücümüz olan Tanrı'ya yüksek sesle ilahi söyleyin!  
\q2 Yakov'un Tanrısı'na sevinçle haykırın!   
\q1
\v 2 Bir ilahi yükseltin,  
\q2 tefi, arpla birlikte hoş liri buraya getirin.   
\q1
\v 3 Yeni Ay’da, dolunayda,  
\q2 bayram günümüzde boru çalın.   
\q1
\v 4 Çünkü bu İsrael için bir yasadır,  
\q2 Yakov'un Tanrısı'nın bir fermanıdır.   
\q1
\v 5 Mısır diyarından çıktığı zaman,  
\q2 bunu Yosef için bir antlaşma olarak belirledi.  
\q2 Orada bilmediğim bir dili duydum.   
\q1
\v 6 “Onun omzunu yükten kurtardım.  
\q2 Elleri küfeden kurtuldu.   
\q1
\v 7 Sıkıntıda çağırdın ve sizi kurtardım.  
\q2 Gök gürültüsünün gizli yerinden sana yanıt verdim.  
\q2 Seni Meriva sularında sınadım.” Selah.   
\q1
\v 8 “Dinle ey halkım, size tanıklık edeceğim.  
\q2 Ey İsrael, eğer beni dinlersen!   
\q1
\v 9 Sende yabancı bir ilâh olmayacak,  
\q2 yabancı bir ilâha tapmayacaksın.   
\q1
\v 10 Ben senin Tanrın Yahve'yim,  
\q2 seni Mısır diyarından kim çıkardı?  
\q2 Ağzını iyice aç da onu doldurayım.   
\q1
\v 11 Ama halkım sesimi dinlemedi.  
\q2 İsrael beni istemedi.   
\q1
\v 12 Ben de onları yüreklerindeki inatçılığın ardından salıverdim,  
\q2 kendi öğütlerince yürüsünler diye.   
\q1
\v 13 Keşke halkım beni dinleseydi,  
\q2 İsrael benim yollarımda yürüseydi!   
\q1
\v 14 Düşmanlarını hemen boyun eğdirir,  
\q2 elimi düşmanlarına karşı çevirirdim.   
\q1
\v 15 Yahve'den nefret edenler O'nun önünde sinerdi,  
\q2 onların cezası sonsuza dek sürerdi.   
\q1
\v 16 Ve onu buğdayın en iyisiyle de beslerdim.  
\q2 Seni kayadan bal ile doyururdum.”   
\c 82  
\d Asaf’ın mezmuru  
\q1
\v 1 Tanrı büyük toplantıyı yönetir.  
\q2 İlahlar arasında hükmeder.   
\q1
\v 2 “Ne vakte kadar haksızca yargılayacak,  
\q2 kötüden yana taraf tutacaksınız?” Selah.   
\q1
\v 3 “Zayıfı, yoksulu ve yetimi savunun.  
\q2 Yoksulun ve ezilenin hakkını koruyun.   
\q1
\v 4 Güçsüzü, muhtaç olanı kurtarın.  
\q2 Onları kötülerin elinden özgür kılın.”   
\q1
\v 5 Bilmiyorlar ve anlamıyorlar.  
\q2 Karanlıkta ileri geri yürüyorlar.  
\q2 Yeryüzünün bütün temelleri sarsılıyor.   
\q1
\v 6 “Sizler ilâhlarsınız” dedim.  
\q2 “Hepiniz Yüceler Yücesi'nin oğullarısınız.   
\q1
\v 7 Yine de insanlar gibi öleceksiniz,  
\q2 hükümdarlardan biri gibi düşeceksiniz.”   
\q1
\v 8 Kalk, ey Tanrı, yeryüzünü yargıla,  
\q2 çünkü bütün ulusları sen miras alacaksın.   
\c 83  
\d İlahi - Asaf’ın mezmuru  
\q1
\v 1 Ey Tanrı, susma.  
\q2 Sessiz ve sakin kalma, ey Tanrı.   
\q1
\v 2 Çünkü işte, düşmanların ayağa kalkıyor.  
\q2 Senden nefret edenler başlarını kaldırdılar.   
\q1
\v 3 Halkına karşı kurnazca düzen kuruyorlar.  
\q2 Değer verdiğin insanlara karşı öğütleşiyorlar.   
\q1
\v 4 “Gelin” diyorlar, “Onları ulus olarak yok edelim.  
\q2 Öyle ki, İsrael’in adı bir daha anılmasın.”   
\q1
\v 5 Tek bir akılla düzen kudular.  
\q2 Sana karşı ittifak oluşturdular.   
\q1
\v 6 Edom'un ve İsmailoğulları'nın çadırları,  
\q2 Moavlılar ve Hagarlılar,   
\q1
\v 7 Geval, Ammon ve Amalek,  
\q2 Filist ve Sur halkı,   
\q1
\v 8 Aşur da onlara katıldı.  
\q2 Lut'un çocuklarına yardım ettiler. Selah.   
\q1
\v 9 Onlara Midyan’a, Kişon Irmağı’nda  
\q2 Sisera’ya ve Yavin’e yaptığının aynısını yap,   
\q1
\v 10 Onlar En-dor’da yok oldular.  
\q2 Toprak için gübre gibi oldular.   
\q1
\v 11 Onların soylularını Orev ve Zeev gibi,  
\q2 beylerini Zevah ve Salmunna’ya yaptığın gibi yap.   
\q1
\v 12 Onlar ki, “Tanrı'nın otlaklarını  
\q2 kendimize mülk edinelim” dediler.   
\q1
\v 13 Tanrım, onları çalı gibi,  
\q2 rüzgârın önündeki saman çöpü gibi yap.   
\q1
\v 14 Ormanı yakan ateş gibi,  
\q2 dağları tutuşturan alev gibi,   
\q1
\v 15 fırtınanla onların peşlerine düş,  
\q2 kasırganla dehşet içinde bırak onları.   
\q1
\v 16 Yüzlerini şaşkınlıkla kaplat,  
\q2 ta ki, adını arasınlar, ey Yahve.   
\q1
\v 17 Sonsuza dek hayal kırıklığı içinde kalsınlar,  
\q2 dehşete düşsünler.  
\q2 Şaşkınlık içinde kalıp yok olsunlar,   
\q1
\v 18 bilsinler ki, yalnız sen, adı Yahve olan,  
\q2 tüm yeryüzü üzerinde En Yüce’dir.   
\c 84  
\d Müzik şefi için - Gittit üzerine - Korahoğulları’nın mezmuru  
\q1
\v 1 Ey Ordular Yahvesi,  
\q2 meskenlerin ne kadar güzeldir!   
\q1
\v 2 Canım Yahve’nin avlularını,  
\q2 bayılırmış gibi özlüyor.  
\q2 Yüreğim ve bedenim yaşayan Tanrı’ya haykırıyor.   
\q1
\v 3 Serçe bile bir yuva,  
\q2 kırlangıç yavrularını koyabilecek bir yuva buldu,  
\q2 senin sunaklarının yanında,  
\q2 ey Ordular Yahvesi, Kralım ve Tanrım benim.   
\q1
\v 4 Ne mutlu senin evinde oturanlara.  
\q2 Sürekli seni överler. Selah.   
\q1
\v 5 Ne mutlu, gücü sende olanlara,  
\q2 yüreklerini Siyon’u ziyaret etmeye koyanlara.   
\q1
\v 6 Ağlama Vadisi'nden geçerken orayı pınarlara çevirirler.  
\q2 Sonbahar yağmuru onu bereketle kaplar.   
\q1
\v 7 Gittikçe güçlenirler.  
\q2 Her biri Siyon'da Tanrı'nın önünde görünür.   
\q1
\v 8 Ordular Tanrısı ey Yahve, duamı duy.  
\q2 Dinle, ey Yakov'un Tanrısı. Selah.   
\q1
\v 9 Ey kalkanımız olan Tanrı, bak,  
\q2 meshettiğinin yüzünü gör.   
\q1
\v 10 Çünkü, avlularında bir gün, bin günden iyidir.  
\q2 Kötülük çadırlarında oturmaktansa,  
\q2 Tanrım’ın evinin kapıcısı olmayı yeğlerim.   
\q1
\v 11 Çünkü Yahve Tanrı bir güneş, bir kalkandır.  
\q2 Yahve lütuf ve yücelik verir.  
\q2 Suçsuz olarak yürüyenlerden hiçbir iyiliği esirgemez.   
\q1
\v 12 Ey Ordular Yahvesi,  
\q2 ne mutlu sana güvenen insana.   
\c 85  
\d Müzik şefi için - Korahoğulları’nın mezmuru  
\q1
\v 1 Ey Yahve, ülkene iyilik ettin.  
\q2 Yakov'un zenginliğini geri getirdin.   
\q1
\v 2 Halkının suçunu bağışladın.  
\q2 Bütün günahlarını örttün. Selah.   
\q1
\v 3 Bütün gazabını uzaklaştırdın.  
\q2 Öfkenin kızgınlığından geri döndün.   
\q1
\v 4 Döndür bizi, kurtuluşumuzun Tanrısı,  
\q2 bize olan öfkeni dindir.   
\q1
\v 5 Sonsuza dek bize kızgın mı kalacaksın?  
\q2 Öfkeni tüm nesillere yayacak mısın?   
\q1
\v 6 Halkın sende sevinsin diye,  
\q2 bizi yeniden diriltmeyecek misin?   
\q1
\v 7 Bize sevgi dolu iyiliğini göster, ey Yahve.  
\q2 Kurtuluşunu bize bağışla.   
\q1
\v 8 Yahve Tanrı’nın ne söyleyeceğini dinleyeceğim.  
\q2 Çünkü halkına, kutsallarına esenlik konuşacak,  
\q2 ama onlar bir daha akılsızlığa dönmesinler.   
\q1
\v 9 Kesinlikle O'nun kurtarışı, kendisinden korkanlara yakındır;  
\q2 ta ki görkem topraklarımızda otursun.   
\q1
\v 10 Merhamet ve gerçek buluştular.  
\q2 Doğruluk ve esenlik öpüştüler.   
\q1
\v 11 Gerçek yerden bitecek.  
\q2 Doğruluk gökten aşağıya bakacak.   
\q1
\v 12 Evet, Yahve iyi olanı verecek.  
\q2 Diyarımız, artarak ürün verecektir.   
\q1
\v 13 Doğruluk O’nun önünden gidecektir,  
\q2 adımlarına yol hazırlayacaktır.   
\c 86  
\d David’in duası  
\q1
\v 1 Duy, ey Yahve, yanıtla beni,  
\q2 çünkü ben yoksul ve muhtacım.   
\q1
\v 2 Canımı koru, çünkü ben tanrısal biriyim.  
\q2 Sen Tanrım, sana güvenen hizmetkârını kurtar.   
\q1
\v 3 Bana merhamet et, ey Efendim,  
\q2 çünkü bütün gün sana sesleniyorum.   
\q1
\v 4 Hizmetkârının canını sevindir,  
\q2 çünkü canımı sana kaldırıyorum, ey Efendim.   
\q1
\v 5 Çünkü sen iyisin, bağışlamaya hazırsın, ey Efendi  
\q2 seni çağıran herkese karşı  
\q2 boldur sevgi dolu iyiliğin.   
\q1
\v 6 Duamı duy, ey Yahve.  
\q2 Dileklerimin sesine kulak ver.   
\q1
\v 7 Sıkıntılı günümde seni çağırırım,  
\q2 çünkü sen beni yanıtlarsın.   
\q1
\v 8 İlahlar arasında senin gibisi yoktur, ey Efendim,  
\q2 işlerin de benzersizdir.   
\q1
\v 9 Yarattığın bütün uluslar gelip sana tapınacaklar, ey Efendim.  
\q2 Adını yüceltecekler.   
\q1
\v 10 Çünkü sen büyüksün ve şaşılası işler yaparsın.  
\q2 Yalnız Tanrı sensin.   
\q1
\v 11 Ey Yahve, yolunu bana öğret.  
\q2 Senin gerçeğinde yürüyeyim.  
\q2 Adından korkmak için yüreğimi tam kıl.   
\q1
\v 12 Ey Efendi Tanrım, bütün yüreğimle seni öveceğim.  
\q2 Adını daima yücelteceğim.   
\q1
\v 13 Çünkü bana karşı sevgi dolu iyiliğin büyüktür.  
\q2 Canımı Şeol'ün\f + \fr 86:13 \ft Şeol ölüler diyarıdır. \f* derinliğinden kurtardın.   
\q1
\v 14 Ey Tanrı, gururlular bana karşı ayağa kalktılar.  
\q2 Zorbalar takımı canımın peşine düştü,  
\q2 kendi önlerinde sana saygıları yoktur.   
\q1
\v 15 Ama sen, ey Efendim merhametli ve lütufkâr bir Tanrı’sın.  
\q2 Yavaş öfkelenirsin, sevgi dolu iyiliğin ve gerçeğin boldur.   
\q1
\v 16 Bana dön de merhamet et!  
\q2 Gücünü hizmetkârına ver.  
\q2 Hizmetkârının oğlunu kurtar.   
\q1
\v 17 Bana iyiliğinin bir işaretini göster,  
\q2 ta ki, benden nefret edenler bunu görüp utansınlar,  
\q2 çünkü sen, ey Yahve, bana yardım ettin ve beni teselli ettin.   
\c 87  
\d Korahoğulları’nın mezmuru - İlahi 
\v 1 Onun temeli kutsal dağlardadır.   
\q1
\v 2 Yahve Siyon'un kapılarını  
\q2 Yakov'un bütün konutlarından daha çok sever.   
\q1
\v 3 Ey Tanrı kenti,  
\q2 senin hakkında görkemli şeyler söylenir. Selah.   
\q1
\v 4 Beni tanıyanlar arasında Rahav'ı\f + \fr 87:4 \ft Rahav Mısır'a atıf yapmaktadır.\f* ve Babil'i kaydedeceğim.  
\q2 İşte, Filist, Sur ve Etiyopya:  
\q2 “Bu da orada doğmuştur.”   
\q1
\v 5 Siyon için şöyle denecek: “Bu ve şu onda doğmuştur.”  
\q2 En Yüce Olan’ın kendisi onu pekiştirecektir.   
\q1
\v 6 Yahve ulusları yazarken sayacak,  
\q2 “Bu orada doğmuştur.” Selah.   
\q1
\v 7 Dans edenlerle şarkı söyleyenler şöyle diyecek:  
\q2 “Bütün kaynaklarım sendedir.”   
\c 88  
\d Korahoğulları’nın mezmuru - İlahi - Müzik şefi için - “Mahalat Leannot” makamında - Ezrahlı Heman Maskili  
\q1
\v 1 Ey Yahve, kurtuluşumun Tanrısı,  
\q2 gündüz ve gece senin önünde yakardım.   
\q1
\v 2 Duam senin önüne gelsin.  
\q2 Yakarışıma kulağını eğ.   
\q1
\v 3 Çünkü canım sıkıntılarla dolu.  
\q2 Hayatım Şeol'e\f + \fr 88:3 \ft Şeol ölüler diyarıdır.\f* yaklaştı.   
\q1
\v 4 Çukura inenler arasında sayılıyorum.  
\q2 Yardımcısı olmayan biri gibiyim,   
\q1
\v 5 ölüler arasına ayrılmış,  
\q2 artık hatırlamadığın,  
\q2 Mezarda yatan öldürülmüşler gibiyim.  
\q2 Onlar senin elinden ayrılmıştır.   
\q1
\v 6 Beni en derin çukura,  
\q2 en karanlık derinliklerde koydun.   
\q1
\v 7 Gazabının ağırlığı üzerimdedir.  
\q2 Bütün dalgalarınla beni ezdin. Selah.   
\q1
\v 8 Dostlarımı benden aldın.  
\q2 Beni onlara iğrenç kıldın.  
\q2 Kapatıldım ve kaçamıyorum.   
\q1
\v 9 Kederden gözlerim sönüyor.  
\q2 Her gün seni çağırdım, ey Yahve.  
\q2 Ellerimi sana açtım.   
\q1
\v 10 Harikalarını ölülere mi göstereceksin?  
\q2 Göçüp gitmiş olan ruhlar mı kalkıp seni övecek? Selah.   
\q1
\v 11 Sevgi dolu iyiliğin mezarda,  
\q2 sadakatin yıkım diyarında mı ilan edilir?   
\q1
\v 12 Harikaların karanlıkta,  
\q2 sadakatin unutulmuşluk diyarında mı bilinir?   
\q1
\v 13 Ama ben ey Yahve, sana yakardım.  
\q2 Sabahleyin duam huzuruna gelir.   
\q1
\v 14 Ey Yahve, canımı neden reddediyorsun?  
\q2 Neden yüzünü benden gizliyorsun?   
\q1
\v 15 Gençliğimden beri dertliyim ve ölmeye hazırım.  
\q2 Senin dehşetlerine katlanırken, şaşkınım.   
\q1
\v 16 Şiddetli öfken üzerime çöktü.  
\q2 Dehşetlerin beni yok etti.   
\q1
\v 17 Bütün gün su gibi çevremi sardılar.  
\q2 Beni tamamen içine aldılar.   
\q1
\v 18 Sevgiliyi, dostu benden uzaklaştırdın,  
\q2 dostlarım da karanlıktadır.   
\c 89  
\d Ezrahlı Eytan’ın Maskili  
\q1
\v 1 Yahve’nin sevgi dolu iyiliğini daima ezgilerle öveceğim.  
\q2 Senin sadakatini bütün kuşaklara ağzımla duyuracağım.   
\q1
\v 2 Doğrusu şunu derim:  
\q2 “Sevgi sonsuza dek durur.  
\q2 Gökleri sen kurdun.  
\q2 Senin sadakatin onlardadır.”   
\q1
\v 3 “Seçtiğim kişiyle antlaşma yaptım,  
\q2 hizmetkârım David’e ant içtim:   
\q1
\v 4 ‘Senin soyunu daima sürdüreceğim,  
\q2 tahtını bütün nesiller için kuracağım.’” Selah.   
\q1
\v 5 Ey Yahve, gökler harikalarını,  
\q2 sadakatini de kutsallar topluluğunda överler.   
\q1
\v 6 Göklerde kim Yahve’yle kıyaslanabilir?  
\q2 Göksel varlıkların oğulları arasında  
\q2 Yahve’ye benzeyen kimdir?   
\q1
\v 7 Kutsallar topluluğunda çok heybetli bir Tanrı’dır,  
\q2 çevresinde olanların hepsinden korkunçtur.   
\q1
\v 8 Ey Yahve, Ordular Tanrısı,  
\q2 senin gibi güçlü olan kimdir?  
\q2 Ey Yah, sadakatin de çevrendedir.   
\q1
\v 9 Denizin gururuna hükmedersin.  
\q2 Dalgaları kabardığında onları sakinleştirirsin.   
\q1
\v 10 Rahav'ı öldürülmüş bir adam gibi parçaladın.  
\q2 Güçlü kolunla düşmanlarını dağıttın.   
\q1
\v 11 Gökler senindir.  
\q2 Dünya ve onun doluluğuyla birlikte,  
\q2 yeryüzü de senindir.  
\q2 Onları sen kurdun.   
\q1
\v 12 Kuzeyi ve güneyi sen yarattın.  
\q2 Tabor ve Hermon senin adınla sevinirler.   
\q1
\v 13 Güçlü kolun var.  
\q2 Elin kuvvetlidir, sağ elin yücedir.   
\q1
\v 14 Doğruluk ve adalet tahtının temelidir.  
\q2 Sevgi dolu iyilik ve gerçek yüzünün önünden gider.   
\q1
\v 15 Ne mutlu seni alkışlamayı öğrenen halka.  
\q2 Senin varlığının ışığında yürürler, ey Yahve.   
\q1
\v 16 Bütün gün senin adınla sevinirler.  
\q2 Senin doğruluğunla yükselirler.   
\q1
\v 17 Çünkü sen onların gücünün yüceliğisin.  
\q2 Senin lütfunla, boynuzumuz yükselir.   
\q1
\v 18 Çünkü kalkanımız Yahve’ye aittir,  
\q2 Kralımız İsrael'in Kutsalı'na.   
\q1
\v 19 Sonra kutsallarına görümde konuşup şöyle dedin:  
\q2 “Savaşçıya güç verdim.  
\q2 Bir genci halkın arasından yükselttim.   
\q1
\v 20 Hizmetkârım David'i buldum.  
\q2 Onu kutsal yağımla meshettim,   
\q1
\v 21 elimi onunla pekiştireceğim.  
\q2 Kolum da onu güçlendirecektir.   
\q1
\v 22 Hiçbir düşman ondan haraç almayacak.  
\q2 Hiçbir kötü kişi onu ezmeyecektir.   
\q1
\v 23 Düşmanlarını onun önünde yere sereceğim,  
\q2 ondan nefret edenleri vuracağım.   
\q1
\v 24 Ama sadakatim ve sevgi dolu iyiliğim onunla birlikte olacak.  
\q2 Onun boynuzu benim adımla yükselecektir.   
\q1
\v 25 Elini de deniz üzerine,  
\q2 sağ elini ırmakların üzerine koyacağım.   
\q1
\v 26 Bana şöyle seslenecek: ‘Sen benim Babamsın,  
\q2 Tanrım ve kurtuluşumun kayası!’   
\q1
\v 27 Ben de onu ilk oğlum,  
\q2 dünya krallarının en yücesi olarak atayacağım.   
\q1
\v 28 Ona olan sevgi dolu iyiliğimi sonsuza dek sürdüreceğim.  
\q2 Onunla antlaşmamı sabit kılacağım.   
\q1
\v 29 Soyunu da sonsuza dek kalıcı,  
\q2 tahtını göğün günleri gibi yapacağım.   
\q1
\v 30 Eğer çocukları yasamı terkederse,  
\q2 kurallarıma göre yürümezlerse;   
\q1
\v 31 eğer yasalarımı çiğnerlerse,  
\q2 buyruklarımı tutmazlarsa;   
\q1
\v 32 o zaman günahlarını değnekle,  
\q2 kötülüklerini sopayla cezalandıracağım.   
\q1
\v 33 Ama sevgi dolu iyiliğimi ondan tümüyle geri almam.  
\q2 Sadakatimi boşa çıkarmam.   
\q1
\v 34 Antlaşmamı bozmayacak,  
\q2 dudaklarımın söylediklerini değiştirmeyeceğim.   
\q1
\v 35 Bir kere kutsallığım üzerine ant içtim,  
\q2 David'e yalan söylemeyeceğim.   
\q1
\v 36 Onun soyu sonsuza dek,  
\q2 tahtı önümde güneş gibi duracak.   
\q1
\v 37 Gökyüzündeki sadık tanık ay gibi,  
\q2 sonsuza dek duracak.” Selah.   
\q1
\v 38 Ama sen reddettin ve attın.  
\q2 Meshettiğine öfkelendin.   
\q1
\v 39 Hizmetkârının antlaşmasından vazgeçtin.  
\q2 Onun tacını toz toprakla kirlettin.   
\q1
\v 40 Onun bütün surlarını yıktın.  
\q2 Kalelerini harabeye çevirdin.   
\q1
\v 41 Yoldan geçen herkes onu soydu.  
\q2 Komşuları için bir utanç haline geldi.   
\q1
\v 42 Düşmanlarının sağ elini yükselttin.  
\q2 Bütün düşmanlarını sevindirdin.   
\q1
\v 43 Kılıcının ağzını da döndürdün,  
\q2 savaşta ona destek olmadın.   
\q1
\v 44 Onun ihtişamına son verdin,  
\q2 tahtını yere çaldın.   
\q1
\v 45 Gençlik günlerini kısalttın.  
\q2 Onu utançla kapladın. Selah.   
\q1
\v 46 Ne vakte kadar, ey Yahve?  
\q2 Kendini sonsuza dek mi gizleyeceksin?  
\q2 Ne vakte kadar, gazabın ateş gibi yanacak?   
\q1
\v 47 Zamanımın ne kadar kısa olduğunu hatırla,  
\q2 insanoğullarının hepsini ne denli boş yaratmışsın!   
\q1
\v 48 Yaşayıp da ölümü görmeyen,  
\q2 Şeol'ün\f + \fr 89:48 \ft Şeol ölüler diyarıdır.\f* gücünden canını kurtaran biri var mı? Selah.   
\q1
\v 49 Ey Efendim, nerede o eski sevgi dolu iyiliğin,  
\q2 sadakatinle David’e ant içttiğin?   
\q1
\v 50 Unutma, ey Efendi, hizmetkârının aşağılanmasını,  
\q2 bütün güçlü halkların alaylarını nasıl bağrımda taşıdığımı,   
\q1
\v 51 düşmanların onunla alay ettiler, ey Yahve,  
\q2 meshettiğinin ayak izleriyle alay ettiler.   
\q1
\v 52 Sonsuza dek övgüler olsun Yahve’ye.  
\q2 Amin ve Amin.   
\c 90  
\d Tanrı\f + \fr 90:0 \ft “Tanrı” olarak tercüme edilen İbranice kelime “אֱלֹהִ֑ים” (Elohim)’dir.\f* adamı Moşe’nın duası  
\q1
\v 1 Ey Efendi,\f + \fr 90:1 \ft “Efendi” olarak tercüme edilen sözcük “Adonay”dır.\f* bütün kuşaklar boyunca  
\q2 sen bizim meskenimiz oldun.   
\q1
\v 2 Dağlar doğmadan önce,  
\q2 sen yeryüzünü ve dünyayı yaratmadan önce,  
\q2 öncesizlikten sonsuza dek, Tanrı sensin.   
\q1
\v 3 İnsanı yıkıp şöyle dersin:  
\q2 “Geri dönün, insanoğulları.”   
\q1
\v 4 Çünkü senin gözünde bin yıl geçmiş dün gibi,  
\q2 gece nöbeti gibidir.   
\q1
\v 5 Uyuduklarında onları süpürürsün.  
\q2 Sabahleyin biten ot gibidirler.   
\q1
\v 6 Sabahleyin filizlenip yeşerir,  
\q2 akşama doğru solup kurur.   
\q1
\v 7 Çünkü senin öfkenle tükeniriz.  
\q2 Gazabınla şaşkına döneriz.   
\q1
\v 8 Kötülüklerimizi önüne,  
\q2 gizli günahlarımızı senin varlığının ışığına koydun.   
\q1
\v 9 Çünkü bütün günlerimiz senin gazabında geçiyor.  
\q2 Yıllarımızı bir soluk gibi bitirmekteyiz.   
\q1
\v 10 Yıllarımızın günleri yetmiş,  
\q2 ya da gücünle sekseni bulursa,  
\q2 yine de onların en parlak zamanı emek ve kederdir,  
\q2 çünkü çabuk geçiyor ve uçup gidiyoruz.   
\q1
\v 11 Öfkenin gücünü,  
\q2 gazabını sana duyulan korkuya göre kim bilebilir?   
\q1
\v 12 Öyleyse bize günlerimizi saymayı öğret,  
\q2 öyle ki, bilge bir yürek kazanalım.   
\q1
\v 13 Acı, ey Yahve!\f + \fr 90:13 \ft “Yahve” Tanrı’nın asıl ismidir, diğer çevirilerde bazen “RAB=EFENDİ” (tamamı büyük harflerle) olarak çevrilir.\f*  
\q2 Ne vakte kadar?  
\q2 Hizmetkârlarına merhamet et!   
\q1
\v 14 Sabahleyin bizi sevgi dolu iyiliğinle doyur,  
\q2 öyle ki, tüm günlerimiz boyunca sevinip mutlu olalım.   
\q1
\v 15 Bizi sıkıntıya soktuğun günler kadar,  
\q2 lötülük gördüğümüz yıllar kadar bizi sevindir.   
\q1
\v 16 İşin hizmetkârlarına,  
\q2 yüceliğin onların çocuklarına görünsün.   
\q1
\v 17 Tanrımız Yahve’nin lütfu üzerimizde olsun.  
\q2 Ellerimizin işini bizim için pekiştir.  
\q2 Evet, ellerimizin işini pekiştir.   
\c 91  
\q1
\v 1 Yüceler Yücesi'nin gizli yerinde oturan  
\q2 Her Şeye Gücü Yeten’in gölgesinde dinlenir.   
\q1
\v 2 Yahve için derim: “O benim sığınağım ve kalemdir,  
\q2 Tanrım’dır, O’na güvenirim.”   
\q1
\v 3 Çünkü O seni avcı tuzağından,  
\q2 ölümcül salgından kurtarır.   
\q1
\v 4 Seni kanatlarıyla örter.  
\q2 O’nun kanatları altına sığınırsın.  
\q2 O’nun sadakati senin kalkanın ve siperindir.   
\q1
\v 5 Ne gecenin dehşetinden korkarsın,  
\q2 ne de gündüz uçan oktan,   
\q1
\v 6 ne karanlıkta dolaşan salgın hastalıktan,  
\q2 ne de öğle vakti bitiren yıkımdan.   
\q1
\v 7 Yanında bin kişi,  
\q2 sağında on bin kişi düşebilir,  
\q2 ama sana yaklaşmaz.   
\q1
\v 8 Sen yalnız gözlerinle bakacak,  
\q2 kötülerin cezasını göreceksin.   
\q1
\v 9 Çünkü sen Yahve’yi sığınak,  
\q2 En Yüce Olan’ı kendine konut edindiğin için,   
\q1
\v 10 başına kötülük gelmeyecek,  
\q2 evine felaket yaklaşmayacak.   
\q1
\v 11 Çünkü tüm yollarında seni korusunlar diye,  
\q2 senin için meleklerini sorumlu kılacak,   
\q1
\v 12 ayağın bir taşa çarpmasın diye,  
\q2 seni elleri üzerinde taşıyacaklar,   
\q1
\v 13 aslanın ve kobranın üzerine basacaksın.  
\q2 Genç aslanı ve yılanı ayaklarının altında çiğneyeceksin.   
\q1
\v 14 “Sevgisini bana bağladığı için onu kurtaracağım.  
\q2 Adımı bildiği için onu yücelteceğim.   
\q1
\v 15 Beni çağıracak, ben de ona yanıt vereceğim.  
\q2 Sıkıntıda onun yanında olacağım.  
\q2 Onu kurtaracak ve yücelteceğim.   
\q1
\v 16 Onu uzun ömürle doyuracağım,  
\q2 ona kurtarışımı göstereceğim.”   
\c 92  
\d Mezmur - Şabat Günü için ilahi  
\q1
\v 1 Yahve’ye şükretmek,  
\q2 ey Yüceler Yücesi, adını ilahilerle övmek,   
\q1
\v 2 sabahları sevgi dolu iyiliğini,  
\q2 her gece sadakatini,   
\q1
\v 3 on telli sazla, arpla,  
\q2 lirin ezgisiyle duyurmak ne iyidir.   
\q1
\v 4 Çünkü, ey Yahve, işinle beni sevindirdin.  
\q2 Senin ellerinin işleriyle zafer kazanıyorum.   
\q1
\v 5 İşlerin ne büyüktür, ey Yahve!  
\q2 Düşüncelerin çok derindir.   
\q1
\v 6 Akılsız insan bilmez,  
\q2 budala da bunu anlamaz:   
\q1
\v 7 Kötüler ot gibi bitse de,  
\q2 kötülük edenlerin tümü serpilip gelişse de,  
\q2 onlar sonsuza dek yok edilecekler.   
\q1
\v 8 Ama sen, ey Yahve, sonsuza dek yücelerdesin.   
\q1
\v 9 Çünkü işte, senin düşmanların, ey Yahve,  
\q2 çünkü işte, düşmanların yok olacak.  
\q2 Bütün kötülük yapanlar dağılacaktır.   
\q1
\v 10 Ama sen benim boynuzumu  
\q2 yaban öküzünki gibi yükselttin.  
\q2 Taze yağla meshedildim.   
\q1
\v 11 Gözüm düşmanlarımı da gördü.  
\q2 Kulaklarım bana karşı çıkan kötü düşmanları duydu.   
\q1
\v 12 Doğrular palmiye ağacı gibi serpilip gelişecektir.  
\q2 Lübnan'daki sedir ağacı gibi büyüyecektir.   
\q1
\v 13 Onlar Yahve’nin evine dikilmişlerdir.  
\q2 Tanrımız’ın avlularında serpilip gelişeceklerdir.   
\q1
\v 14 Onlar yaşlılıklarında da meyve verecekler.  
\q2 Taze ve yemyeşil olacaklar,   
\q1
\v 15 ta ki, Yahve’nin doğru olduğunu göstersinler.  
\q2 O benim kayamdır,  
\q2 ve O’nda hiç haksızlık bulunmaz.   
\c 93  
\q1
\v 1 Yahve hüküm sürüyor!  
\q2 İhtişamla kuşanmış!  
\q2 Yahve kudretle donanmış.  
\q1 Dünya da pekiştirilmiş, sarsılmaz.   
\q1
\v 2 Tahtın eskiden beri kurulmuştur.  
\q2 Sen sonsuzluktansın.   
\q1
\v 3 Seller yükseldi, ey Yahve,  
\q2 seller sesini yükseltti.  
\q2 Seller, dalgalarını yükseltti.   
\q1
\v 4 Bol suların seslerinin üstünde,  
\q2 denizin kudretli dalgalarından çok,  
\q2 yücelerdeki Yahve kudretlidir.   
\q1
\v 5 Kuralların sağlam durur.  
\q2 Kutsallık evini süsler,  
\q2 sonsuza dek, ey Yahve.   
\c 94  
\q1
\v 1 Ey Yahve, sen öcün sahibi olan Tanrı’sın,  
\q2 ey öcün sahibi olan Tanrı, parla.   
\q1
\v 2 Kalk, ey yeryüzünün yargıcı.  
\q2 Küstahlara hak ettikleri karşılığı ver.   
\q1
\v 3 Ey Yahve, kötüler ne zamana dek,  
\q2 ne zamana dek zafer kazanacaklar?   
\q1
\v 4 Küstahça sözler saçıyorlar.  
\q2 Kötülük edenlerin hepsi övünüyorlar.   
\q1
\v 5 Ey Yahve, halkını parçalıyorlar,  
\q2 mirasına eziyet ediyorlar.   
\q1
\v 6 Dul kadını ve garibi katlediyorlar,  
\q2 yetimleri öldürüyorlar.   
\q1
\v 7 “Yah görmez” diyorlar,  
\q2 “Yakov'un Tanrısı dikkate almaz.”   
\q1
\v 8 Ey sizler, halk arasındaki akılsızlar, dikkat edin,  
\q2 siz ey ahmaklar, ne zaman akıllanacaksınız?   
\q1
\v 9 Kulağı yerleştiren duymaz mı?  
\q2 Göze biçim veren görmez mi?   
\q1
\v 10 Ulusları terbiye eden, cezalandırmaz mı?  
\q2 İnsana öğreten bilir.   
\q1
\v 11 Yahve insanın düşüncelerinin,  
\q2 boş olduğunu bilir.   
\q1
\v 12 Ey Yah, ne mutlu terbiye ettiğin,  
\q2 yasanı öğrettiğin insana.   
\q1
\v 13 Kötüler için çukur kazılıncaya dek,  
\q2 sıkıntılı günlerde ona rahat verirsin.   
\q1
\v 14 Çünkü Yahve halkını geri çevirmez,  
\q2 mirasını da bırakmaz.   
\q1
\v 15 Çünkü yargı adalete dönecektir.  
\q2 Dürüst yüreklilerin hepsi onu izleyecektir.   
\q1
\v 16 Kötülere karşı benim için kim kalkacak?  
\q2 Kötülük edenlere karşı kim beni savunacak?   
\q1
\v 17 Yahve yardımcım olmasaydı,  
\q2 canım hemen sessizlik içinde çökerdi.   
\q1
\v 18 “Ayağım kayıyor!” dediğimde,  
\q2 sevgi dolu iyiliğin beni ayakta tuttu, ey Yahve.   
\q1
\v 19 İçimdeki düşüncelerin çokluğunda,  
\q2 senin avutmaların canımı sevindiriyor.   
\q1
\v 20 Yasayla kötülük eden şer tahtı,  
\q2 seninle paydaşlık içinde olur mu?   
\q1
\v 21 Doğru insanın canına karşı toplanıyorlar,  
\q2 masum kanı mahkûm ediyorlar.   
\q1
\v 22 Ama Yahve benim yüksek kulem oldu,  
\q2 Tanrım sığındığım kaya oldu.   
\q1
\v 23 kötülüklerini başlarına döndürdü,  
\q2 kendi kötülükleriyle onları kesip atacaktır.  
\q2 Tanrımız Yahve onları kesip atacaktır.   
\c 95  
\q1
\v 1 Gelin, Yahve'ye ezgiler söyleyelim.  
\q2 Kurtuluşumuzun kayasına yüksek sesle haykıralım!   
\q1
\v 2 Şükranla huzuruna çıkalım.  
\q2 O’nu ezgilerle yüceltelim!   
\q1
\v 3 Çünkü Yahve büyük Tanrı’dır,  
\q2 tüm ilâhların üstünde büyük Kral’dır.   
\q1
\v 4 Yerin derinlikleri O’nun elindedir.  
\q2 Dağların tepeleri de O’nundur.   
\q1
\v 5 Deniz O’nundur ve onu yaratan kendisidir.  
\q2 Karaya biçim veren O’nun elleridir.   
\q1
\v 6 Gelin, tapınalım, eğilelim.  
\q2 Yaratıcımız Yahve'nin önünde diz çökelim,   
\q1
\v 7 çünkü Tanrımız O’dur.  
\q2 Biz O’nun otlağının halkı,  
\q2 gözetimindeki koyunlarız.  
\q2 Keşke bugün O’nun sesini duysanız!   
\q1
\v 8 Meriva'da ve o gün Masa Çölü’nde olduğu gibi  
\q2 yüreğinizi katılaştırmayın,   
\q1
\v 9 atalarınız beni denediklerinde,  
\q2 beni sınadıklarında, işimi de görmüşlerdi.   
\q1
\v 10 Kırk yıl boyunca o kuşakla kederlendim,  
\q2 “Bunlar, yürekleri kusurlu bir halktır” dedim.  
\q2 “Yollarımı bilmediler.”   
\q1
\v 11 Bunun için öfkemle ant içtim:  
\q2 “Benim dinlenme yerime girmeyecekler.”   
\c 96  
\q1
\v 1 Yahve’ye yeni bir ezgi söyleyin!  
\q2 Tüm yeryüzü Yahve’ye ezgi söyleyin.   
\q1
\v 2 Ezgi söyleyin Yahve’ye!  
\q2 Adını yüceltin!  
\q2 Kurtarışını günden güne duyurun!   
\q1
\v 3 Görkemini uluslar arasında,  
\q2 şaşılası işlerini bütün halklar arasında ilan edin.   
\q1
\v 4 Çünkü Yahve büyüktür, fazlasıyla övülmeye layıktır!  
\q2 Bütün ilâhlardan çok O’ndan korkulmalıdır.   
\q1
\v 5 Çünkü halkların bütün ilâhları puttur,  
\q2 gökleri yaratansa Yahve’dir.   
\q1
\v 6 Saygınlık ve ululuk O’nun önündedir.  
\q2 Güç ve güzellik O’nun tapınağındadır.   
\q1
\v 7 Ey ulusların soyları, Yahve’ye verin,  
\q2 yüceliği ve gücü Yahve’ye verin.   
\q1
\v 8 Adından ötürü yüceliği Yahve’ye verin.  
\q2 Sunu getirip avlularına girin.   
\q1
\v 9 Yahve’ye kutsal düzen içinde tapının.  
\q2 Önünde titreyin, tüm yeryüzü.   
\q1
\v 10 Uluslar arasında, “Yahve hüküm sürüyor” deyin.  
\q2 Dünya da pekiştirilmiştir, sarsılmaz.  
\q2 Halkları adaletle yargılar.   
\q1
\v 11 Gökler sevinsin, yeryüzü coşsun.  
\q2 Deniz ve içindeki doluluk gürlesin!   
\q1
\v 12 Kır ve içindekilerin tümü coşsun!  
\q2 O zaman ormandaki bütün ağaçlar,  
\q2 sevinçle şarkı söyleyecek,   
\q1
\v 13 Yahve’nin önünde,  
\q2 çünkü O geliyor,  
\q2 yeryüzünü yargılamaya geliyor.  
\q2 Dünyaya doğrulukla,  
\q2 halklara gerçeğiyle hükmedecek.   
\c 97  
\q1
\v 1 Yahve hükmediyor, coşsun yeryüzü!  
\q2 Bütün adalar sevinsin!   
\q1
\v 2 Bulutlar ve karanlık çevresindedir.  
\q2 Doğruluk ve adalet O’nun tahtının temelidir.   
\q1
\v 3 O’nun önünden ateş yürüyor,  
\q2 düşmanlarını her yandan yakıyor.   
\q1
\v 4 Şimşeği dünyayı aydınlatır.  
\q2 Yeryüzü görüp titrer.   
\q1
\v 5 Yahve’nin önünde,  
\q2 tüm yeryüzünün Efendisi önünde dağlar balmumu gibi eridi.   
\q1
\v 6 Gökler O’nun doğruluğunu ilan eder.  
\q2 Bütün halklar O’nun yüceliğini gördü.   
\q1
\v 7 Oyma putlara hizmet edenlerin hepsi,  
\q2 putlarıyla övünenler, utansınlar.  
\q2 Ey bütün ilâhlar,\f + \fr 97:7 \ft LXX'te “ilâhlar” yerine “melekler” ifadesi yer alıyor.\f* O’na tapın!   
\q1
\v 8 Siyon duydu ve sevindi.  
\q2 Senin hükümlerinden ötürü, ey Yahve,  
\q2 Yahuda kızları coştu.   
\q1
\v 9 Çünkü, ey Yahve, tüm yeryüzünde En Yüce Olan sensin.  
\q2 Bütün ilâhların üstünde çok yücesin.   
\q1
\v 10 Ey sizler, Yahve’yi sevenler, kötülükten nefret edin!  
\q2 O, kutsallarının canlarını korur.  
\q2 Onları kötülerin elinden kurtarır.   
\q1
\v 11 Doğru için ışık,  
\q2 yüreği dürüst olanlara sevinç ekilmiştir.   
\q1
\v 12 Ey doğrular, Yahve’de sevinin!  
\q2 O’nun kutsal Adına şükredin.   
\c 98  
\d Mezmur  
\q1
\v 1 Yahve’ye yeni bir ezgi söyleyin,  
\q2 çünkü O şaşılası şeyler yaptı!  
\q2 Sağ eli ve kutsal kolu kendisi için kurtuluş sağladı.   
\q1
\v 2 Yahve kurtarışını bildirdi.  
\q2 Doğruluğunu ulusların önünde açıkça gösterdi.   
\q1
\v 3 İsrael halkına olan sevgi dolu iyiliğini ve sadakatini hatırladı.  
\q2 Yeryüzünün bütün uçları Tanrımız’ın kurtarışını gördü.   
\q1
\v 4 Ey bütün yeryüzü Yahve’ye sevinçle haykırın!  
\q2 Neşeyle ortalığı çınlatın, ezgiler söyleyin!   
\q1
\v 5 Arpla Yahve’ye ezgiler söyleyin,  
\q2 arp ve melodiyle ezgiler söyleyin.   
\q1
\v 6 Borularla ve koç boynuzu sesiyle,  
\q2 Kral olan Yahve’nin önünde sevinçle haykırın.   
\q1
\v 7 Deniz doluluğuyla,  
\q2 dünya ve onda oturanlar gürlesin.   
\q1
\v 8 Irmaklar el çırpsın.  
\q2 Dağlar hep birlikte sevinçle haykırsın.   
\q1
\v 9 Yahve’nin önünde ezgi söylesinler,  
\q2 çünkü O geliyor, yeryüzüne hükmetmeye.  
\q1 Dünyayı doğrulukla,  
\q2 halklara adaletle hükmedecek.   
\c 99  
\q1
\v 1 Yahve hüküm sürüyor! Titresin halklar.  
\q2 Keruvlar arasında tahtında oturmuş.  
\q2 Sarsılsın yeryüzü.   
\q1
\v 2 Yahve Siyon'da büyüktür.  
\q2 O, bütün halkların üstünde yücedir.   
\q1
\v 3 Büyük ve heybetli adını övsünler.  
\q2 O Kutsal’dır!   
\q1
\v 4 Kral’ın gücü adaleti de sever.  
\q2 Doğruluğu sen kurarsın.  
\q2 Yakov'da adalet ve doğruluğu sen gerçekleştirirsin.   
\q1
\v 5 Tanrımız Yahve’yi yüceltin.  
\q2 Ayaklarının taburesinde tapının.  
\q2 O Kutsal’dır!   
\q1
\v 6 Moşe'yle Aron O’nun kâhinleri arasındaydı.  
\q2 Samuel adını çağıranlar arasındaydı.  
\q2 Yahve’yi çağırdılar, O da onlara yanıt verdi.   
\q1
\v 7 Bulut sütunu içinde onlarla konuştu.  
\q2 O’nun tanıklıklarını ve kendilerine vermiş olduğu kuralları tuttular.   
\q1
\v 8 Ey Tanrımız Yahve, sen onlara yanıt verdin,  
\q2 yaptıklarının karşılığını ödetmiş olsan da,  
\q2 onları bağışlayan bir Tanrı oldun.   
\q1
\v 9 Tanrımız Yahve’yi yüceltin.  
\q2 Kutsal dağında tapının,  
\q2 çünkü Tanrımız Yahve kutsaldır!   
\c 100  
\d Şükran Mezmuru  
\q1
\v 1 Ey bütün diyarlar, Yahve’ye sevinçle haykırın!   
\q1
\v 2 Yahve’ye sevinçle hizmet edin.  
\q2 O’nun huzuruna ezgilerle gelin.   
\q1
\v 3 Bilin ki, Yahve Tanrı’dır.  
\q2 Bizi yaratan O’dur ve biz de O’nunuz.  
\q2 O’nun halkı, otlağının koyunlarıyız.   
\q1
\v 4 Şükranla kapılarına,  
\q2 övgüyle avlularına girin.  
\q2 Şükredin O’na, adını yüceltin.   
\q1
\v 5 Çünkü Yahve iyidir.  
\q2 Sevgi dolu iyiliği sonsuzdur,  
\q2 sadakati tüm kuşaklar boyunca sürer.   
\c 101  
\d David’in mezmuru  
\q1
\v 1 Sevgi dolu iyiliğini ve adaletini ezgiyle söyleyeceğim.  
\q2 Seni ilahilerle öveceğim, ey Yahve.   
\q1
\v 2 Temiz bir yaşam sürdürmeye dikkat edeceğim.  
\q2 Bana ne zaman geleceksin?  
\q2 Evimin içinde pak bir yürekle yürüyeceğim.   
\q1
\v 3 Hiçbir rezil şeyi gözümün önüne koymayacağım.  
\q2 Güvenilmez insanların işlerinden nefret ederim.  
\q2 Bana tutunmayacaklar.   
\q1
\v 4 Sapık yürek benden uzak olsun.  
\q2 Kötülükle işim olmaz.   
\q1
\v 5 Komşusuna gizlice kara çalanı sustururum.  
\q2 Katlanamam küstah ve kibirli insana.   
\q1
\v 6 Gözlerim ülkedeki sadıkların üzerinde olacak,  
\q2 ta ki, benimle otursunlar.  
\q2 Kusursuzca yürüyen kişi,  
\q2 bana hizmet edecek.   
\q1
\v 7 Hileci kişi evimde oturmayacak.  
\q2 Yalan söyleyen, gözümün önünde durmayacak.   
\q1
\v 8 Her sabah ülkedeki bütün kötüleri yok edeceğim,  
\q2 Yahve’nin kentinden kötülüğün tüm işçilerini kesip atacağım.   
\c 102  
\d Zayıf düşen ve derdini Yahve’ye döken mazlumun duası  
\q1
\v 1 Duamı duy, ey Yahve!  
\q2 Feryadım sana ulaşsın.   
\q1
\v 2 Sıkıntılı günümde yüzünü benden saklama.  
\q2 Kulağını bana çevir.  
\q2 Çağırdığım gün bana hemen yanıt ver.   
\q1
\v 3 Çünkü günlerim duman gibi tükeniyor.  
\q2 Kemiklerim meşale gibi yanıyor.   
\q1
\v 4 Yüreğim ot gibi kurudu, soldu,  
\q2 ekmek yemeyi unuttum.   
\q1
\v 5 İniltimin sesinden,  
\q2 kemiklerim derime yapışıyor.   
\q1
\v 6 Çölde yaşayan kaşıkçı kuşu gibiyim.  
\q2 Çorak yerlerin baykuşu oldum.   
\q1
\v 7 Gözlüyorum, damda yalnız kalan bir serçeye döndüm.   
\q1
\v 8 Düşmanlarım bütün gün beni aşağılıyor.  
\q2 Bana kızgın olanlar adımı lanet için kullanıyorlar.   
\q1
\v 9 Külü ekmek gibi yedim,  
\q2 içeceğime gözyaşları karıştırdım,   
\q1
\v 10 senin öfken ve gazabın yüzünden,  
\q2 çünkü sen beni kaldırıp yere çaldın.   
\q1
\v 11 Günlerim uzayan gölge gibi.  
\q2 Ot gibi kurudum.   
\q1
\v 12 Ama sen, ey Yahve, sonsuza dek kalıcısın,  
\q2 ünün tüm kuşaklar boyunca sürer.   
\q1
\v 13 Sen kalkıp Siyon'a merhamet edeceksin,  
\q2 çünkü ona acıma vakti geldi.  
\q2 Evet, belirlenen zaman geldi.   
\q1
\v 14 Çünkü hizmetkârların onun taşlarından zevk alırlar,  
\q2 onun tozuna acırlar.   
\q1
\v 15 Böylece uluslar Yahve’nin adından,  
\q2 yeryüzü krallarının tümü görkeminden korkacaklar.   
\q1
\v 16 Çünkü Yahve Siyon'u bina etti.  
\q2 Yüceliğiyle göründü.   
\q1
\v 17 Yoksulun duasına yanıt verdi,  
\q2 onların duasını küçümsemedi.   
\q1
\v 18 Bu, gelecek kuşak için yazılacak.  
\q2 yaratılacak bir halk Yah'ı övecek,   
\q1
\v 19 Çünkü O yücelerdeki kutsal yerinden aşağıya baktı.  
\q2 Yahve gökten yeryüzünü gördü,   
\q1
\v 20 tutsakların iniltilerini duymak,  
\q2 ölüme mahküm edilenleri serbest bırakmak için.   
\q1
\v 21 Böylece Yahve’ye hizmet etmek için  
\q2 halklar ve krallıklar bir araya toplanınca,   
\q1
\v 22 Siyon’da Yahve’nin adını,  
\q2 Yeruşalem’de övgüsünü ilan etsinler.   
\q1
\v 23 Yol boyunca gücümü zayıflattı.  
\q2 Günlerimi kısalttı.   
\q1
\v 24 “Ey Tanrım, beni günlerimin ortasında alma” dedim.  
\q2 “Senin yılların tüm kuşaklar boyuncadır.   
\q1
\v 25 Yeryüzünün temelini eskiden sen attın.  
\q2 Gökler senin ellerinin işidir.   
\q1
\v 26 Onlar yok olacak, ama sen duracaksın.  
\q2 Evet, hepsi bir giysi gibi eskiyecek.  
\q2 Onları bir kaftan gibi değiştireceksin, onlar da değişecek.   
\q1
\v 27 Ama sen aynısın.  
\q2 Yıllarının sonu yoktur.   
\q1
\v 28 Hizmetkârlarının çocukları devam edecek.  
\q2 Onların soyu senin önünde sağlamlaştırılacak.”   
\c 103  
\d David’in mezmuru  
\q1
\v 1 Yahve’yi öv, ey canım!  
\q2 İçimde var olan her şey, O’nun kutsal adını övsün!   
\q1
\v 2 Yahve’yi öv, ey canım,  
\q2 iyiliklerinin hiçbirini unutma.   
\q1
\v 3 Bütün günahlarını bağışlayan,  
\q2 bütün hastalıklarını iyileştiren,   
\q1
\v 4 canını yıkımdan kurtaran,  
\q2 sana sevgi dolu iyilikle  
\q2 sevecen merhametler tacı giydiren,   
\q1
\v 5 arzunu iyi şeylerle doyuran O’dur,  
\q2 böylece gençliğin kartalınki gibi yenilenir.   
\q1
\v 6 Yahve ezilenlerin tümüne  
\q2 hak ve adalet sağlar.   
\q1
\v 7 Kendi yollarını Moşe’ye,  
\q2 işlerini İsrael’in çocuklarına bildirdi.   
\q1
\v 8 Yahve merhametli ve lütufkârdır,  
\q2 öfkelenmekte yavaş, sevgi dolu iyiliği boldur.   
\q1
\v 9 Hep suçlamaz;  
\q2 sonsuza dek öfkeli kalmaz.   
\q1
\v 10 Bize günahlarımıza göre davranmadı,  
\q2 ne de kötülüklerimizin karşılığını ödetti.   
\q1
\v 11 Çünkü gökler yeryüzünden ne kadar yüksekse,  
\q2 kendisinden korkanlara karşı  
\q2 sevgi dolu iyiliği de o kadar büyüktür.   
\q1
\v 12 Doğu batıdan ne kadar uzaksa,  
\q2 isyanlarımızı bizden o kadar uzaklaştırdı.   
\q1
\v 13 Bir baba çocuklarına nasıl acırsa,  
\q2 Yahve kendisinden korkanlara öyle acır.   
\q1
\v 14 Çünkü yaratılışımızı bilir.  
\q2 Toprak olduğumuzu hatırlar.   
\q1
\v 15 İnsana gelince, günleri ota benzer.  
\q2 Kır çiçeği gibi gelişir.   
\q1
\v 16 Üzerine rüzgâr esince gelip geçer.  
\q2 Bulunduğu yer artık onu hatırlamaz.   
\q1
\v 17 Ama Yahve’nin sevgi dolu iyiliği  
\q2 kendisinden korkanlara karşı sonsuzdur,  
\q2 doğruluğu çocuklarının çocuklarınadır,   
\q1
\v 18 kurallarına uyanlara,  
\q2 O’nun buyruklarına uymayı hatırlayanlaradır.   
\q1
\v 19 Yahve tahtını göklerde kurdu.  
\q2 O’nun krallığı her şeye hükmediyor.   
\q1
\v 20 Yahve’yi övün, ey O’nun melekleri,  
\q2 güçte büyük olup  
\q2 sözünün sesine itaat eden  
\q2 ve sözünü yerine getiren ey sizler.   
\q1
\v 21 Yahve’yi övün, O’nun bütün orduları,  
\q2 isteğini yerine getiren hizmetkârları.   
\q1
\v 22 Hakimiyetinin her yerindeki bütün işleri  
\q2 Yahve’yi övün,  
\q2 Yahve’yi öv, ey canım!   
\c 104  
\q1
\v 1 Ey canım, Yahve’yi öv,  
\q2 ey Yahve, Tanrım, çok büyüksün.  
\q2 Saygınlık ve heybetle giyinmişsin.   
\q1
\v 2 O’dur bir giysi gibi kendini ışıkla örten.  
\q2 Gökleri bir perde gibi geren.   
\q1
\v 3 O’dur odalarının en üstünü sular üzerine kuran,  
\q2 bulutları kendine araba eden,  
\q2 rüzgârın kanatları üzerinde yürüyen.   
\q1
\v 4 O’dur habercilerini\f + \fr 104:4 \ft veya melekler\f* rüzgârlar,  
\q2 hizmetkârlarını ateş alevleri yapan.   
\q1
\v 5 Yeryüzünün temellerini attın,  
\q2 sonsuza dek sarsılmasın diye.   
\q1
\v 6 Bir kaftan gibi onu derinlikle kapladın.  
\q2 Sular dağların üzerinde durdu.   
\q1
\v 7 Senin azarlamandan sular kaçtı,  
\q2 gürleyişinin sesiyle hemen çekildiler.   
\q1
\v 8 Dağlar yükseldi,  
\q2 vadiler battı,  
\q2 onlar için belirlediğin yere doğru.   
\q1
\v 9 Üstünden geçmesinler diye bir sınır çektin,  
\q2 ta ki, yeryüzünü kaplamak için bir daha dönmesinler.   
\q1
\v 10 Vadilerde çıkarttığın pınarlar,  
\q2 dağların arasında akarlar.   
\q1
\v 11 Kırdaki bütün hayvanlara içecek verir.  
\q2 Yaban eşekleri susuzluklarını giderirler.   
\q1
\v 12 Gökteki kuşlar onların yanında yuva yapar.  
\q2 Dalların arasında öterler.   
\q1
\v 13 Dağları odalarından sular.  
\q2 Yeryüzü işlerinin ürünüyle doldu.   
\q1
\v 14 Hayvanlar için ot,  
\q2 insanın ekip biçmesi için bitkiler yetiştirirsin,  
\q2 öyle ki, topraktan yiyecek çıkarsınlar.   
\q1
\v 15 İnsanın yüreğini sevindiren şarabı,  
\q2 yüzünü aydınlatan yağı,  
\q2 yüreğini güçlendiren ekmeği sen verirsin.   
\q1
\v 16 Yahve’nin ağaçları,  
\q2 kendi diktiği Lübnan sedirleri iyi sulanır.   
\q1
\v 17 Kuşlar orada yuva yaparlar.  
\q2 Leylek ise evini selvi ağaçlarına yapar.   
\q1
\v 18 Yüksek dağlar yaban keçileri içindir.  
\q2 Kayalar, kaya porsuklarının sığınağıdır.   
\q1
\v 19 Ayı mevsimler için belirledi.  
\q2 Güneş batacağı zamanı bilir.   
\q1
\v 20 Karartırsın, gece olur,  
\q2 o zaman tüm orman hayvanları çıkar.   
\q1
\v 21 Genç aslanlar avlarının peşinden kükrer,  
\q2 Tanrı’dan yiyeceklerini isterler.   
\q1
\v 22 Güneş doğar, çekilirler,  
\q2 inlerinde yatarlar.   
\q1
\v 23 İnsan işine gider,  
\q2 akşama kadar çalışır.   
\q1
\v 24 Ey Yahve, işlerin ne çoktur!  
\q2 Hepsini bilgeliğinle yaptın.  
\q2 Yeryüzü zenginliklerinle dolu.   
\q1
\v 25 Deniz var, büyük ve geniş,  
\q2 içinde sayısız küçük büyük hayvanlar,  
\q2 canlı şeyler bulunur.   
\q1
\v 26 Oraya gemiler gider,  
\q2 içinde oynasın diye yarattığın Livyatan oradadır.   
\q1
\v 27 Hepsi seni bekliyor,  
\q2 ta ki, onlara yiyeceklerini vaktinde veresin.   
\q1
\v 28 Onlara verirsin ve toplarlar.  
\q2 Elini açarsın, iyilikle doyarlar.   
\q1
\v 29 Yüzünü gizleyince sıkıntıya düşerler.  
\q2 Soluklarını kesince ölüp toza dönerler.   
\q1
\v 30 Ruhunu gönderirsin, yaratılırlar.  
\q2 Yerin yüzünü yenilersin.   
\q1
\v 31 Yahve’nin yüceliği sonsuza dek sürsün.  
\q2 Yahve işleriyle sevinsin.   
\q1
\v 32 O yeryüzüne bakar, yer titrer.  
\q2 Dağlara dokunur ve onlar tüter.   
\q1
\v 33 Yaşadığım sürece Yahve’ye ezgiler söyleyeceğim.  
\q2 Var oldukça Tanrım’ı ezgilerle öveceğim.   
\q1
\v 34 Düşüncem O’na hoş görünsün.  
\q2 Ben Yahve ile sevineceğim.   
\q1
\v 35 Günahkârlar yeryüzünde tükensin.  
\q2 Artık kötüler olmasın.  
\q2 Ey canım, Yahve’yi öv.  
\q2 Yah’ı öv!   
\c 105  
\q1
\v 1 Yahve’ye şükredin, adını çağırın!  
\q2 Yaptıklarını halklar arasında bildirin.   
\q1
\v 2 O’na ezgilerle, ilahiler söyleyin!  
\q2 O’nun tüm şaşılası işlerini anlatın.   
\q1
\v 3 Kutsal adıyla övünün.  
\q2 Yahve’yi arayanların yüreği sevinsin.   
\q1
\v 4 Yahve’yi ve O’nun gücünü arayın.  
\q2 Yüzünü daima arayın.   
\q1
\v 5 Yaptığı şaşılası işleri,  
\q2 harikalarını ve ağzının hükümlerini hatırlayın:   
\q1
\v 6 Ey sizler, hizmetkârı Avraham’ın soyu,  
\q2 Yakov’un çocukları, O’nun seçilmişleri.   
\q1
\v 7 Tanrımız Yahve O’dur.  
\q2 O’nun hükümleri tüm yeryüzündedir.   
\q1
\v 8 O, antlaşmasını,  
\q2 bin kuşağa buyurduğu sözü,   
\q1
\v 9 Avraham’la yaptığı antlaşmayı,  
\q2 İshak'a olan andını sonsuza dek hatırlar,   
\q1
\v 10 bunu Yakov için bir kural,  
\q2 İsrael'e sonsuz bir antlaşma olarak onayladı:   
\q1
\v 11 “Mirasının payı olmak üzere,  
\q2 Kenan ülkesini sana vereceğim.”   
\q1
\v 12 O zaman için sayıca birkaç kişiydiler,  
\q2 çok azdılar ve orada yabancıydılar.   
\q1
\v 13 Ulustan ulusa,  
\q2 bir krallıktan öteki halka dolaşıp durdular.   
\q1
\v 14 Kimsenin onlara kötülük etmesine izin vermedi.  
\q2 Kralları bile onların uğruna azarladı:   
\q1
\v 15 “Meshettiklerime dokunmayın!  
\q2 Peygamberlerime zarar vermeyin!” dedi.   
\q1
\v 16 Ülkeye kıtlığı çağırdı.  
\q2 Yiyecek kaynaklarını yok etti.   
\q1
\v 17 Önlerinden bir adam gönderdi.  
\q2 Yosef köle olmak üzere satıldı.   
\q1
\v 18 Ayaklarına pranga vurdular.  
\q2 Boynunu demir halkayla bağladılar.   
\q1
\v 19 Sözü gerçekleşene dek,  
\q2 Yahve’nin sözü onu sınadı.   
\q1
\v 20 Kral gönderip onu özgür kıldı.  
\q2 Halklara hükmeden onu salıverdi.   
\q1
\v 21 Onu evinin efendisi,  
\q2 tüm malının yöneticisi yaptı,   
\q1
\v 22 Beylerini istediği gibi eğitsin,  
\q2 ihtiyarlarına bilgelik öğretsin diye.   
\q1
\v 23 İsrael de Mısır'a geldi.  
\q2 Yakov Ham ülkesinde yaşadı.   
\q1
\v 24 Halkını çok artırdı,  
\q2 onları düşmanlarından daha güçlü yaptı.   
\q1
\v 25 Hizmetkârlarına karşı düzen kursunlar diye,  
\q2 onların yüreklerini halkından nefret etmeye yöneltti,   
\q1
\v 26 Hizmetkârı Moşe'yi,  
\q2 seçmiş olduğu Aron’u gönderdi.   
\q1
\v 27 Aralarında mucizeler,  
\q2 Ham diyarında harikalar gerçekleştirdiler.   
\q1
\v 28 Karanlık gönderip ortalığı kararttı.  
\q2 Sözlerine karşı gelmediler.   
\q1
\v 29 Sularını kana çevirdi,  
\q2 balıklarını öldürdü.   
\q1
\v 30 Ülkeleri kurbağalarla dolup taştı,  
\q2 krallarının odalarında bile.   
\q1
\v 31 O söyleyince sinek sürüleri,  
\q2 tüm sınırları içine bitler geldi.   
\q1
\v 32 Onlara yağmur yerine dolu,  
\q2 ülkelerine yıldırım verdi.   
\q1
\v 33 Bağlarını, incir ağaçlarını vurdu,  
\q2 ülkelerinin ağaçlarını parçaladı.   
\q1
\v 34 O söyleyince, çekirgeler,  
\q2 sayısız çekirgeler geldi.   
\q1
\v 35 Ülkelerinin bütün bitkilerini,  
\q2 topraklarının ürününü yediler.   
\q1
\v 36 Ülkelerinin ilk doğanlarının hepsini,  
\q2 güçlerinin ilk ürünlerini vurdu.   
\q1
\v 37 Onları altın ve gümüşle çıkardı.  
\q2 Oymaklarının içinde tek bir zayıf insan bile yoktu.   
\q1
\v 38 Onlar gidince Mısır sevindi,  
\q2 çünkü onların korkusu üzerlerine çökmüştü.   
\q1
\v 39 Örtü olarak bulutu,  
\q2 geceyi aydınlatmak için ateşi serdi.   
\q1
\v 40 İstediler, O da bıldırcın getirdi,  
\q2 onları gökyüzünün ekmeğiyle doyurdu.   
\q1
\v 41 Kayayı yardı ve sular fışkırdı.  
\q2 Kurak yerlerde ırmak gibi aktı.   
\q1
\v 42 Çünkü kutsal sözünü,  
\q2 hizmetkârı Avraham’ı hatırladı.   
\q1
\v 43 Halkını sevinçle,  
\q2 seçmiş olduklarını ezgiyle dışarı çıkardı.   
\q1
\v 44 Ulusların topraklarını onlara verdi.  
\q2 Halkların emeğini miras aldılar,   
\q1
\v 45 ta ki O’nun kurallarını tutsunlar,  
\q2 yasasını yerine getirsinler.  
\q2 Yah’ı övün!   
\c 106  
\q1
\v 1 Yahve’ye övgüler olsun!  
\q2 Yahve’ye şükredin, çünkü O iyidir,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 2 Yahve’nin büyük işlerini kim dile getirebilir?  
\q2 Ya da tüm övgülerini tam olarak kim ilan edebilir?   
\q1
\v 3 Ne mutlu adaleti tutanlara.  
\q2 Ne mutlu, her zaman doğru olanı yapan insana.   
\q1
\v 4 Halkına gösterdiğin lütufla beni hatırla, ey Yahve.  
\q2 Kurtarışınla beni ziyaret et,   
\q1
\v 5 öyle ki, seçtiklerinin başarısını göreyim,  
\q2 ulusunun sevinciyle coşayım,  
\q2 Mirasınla birlikte övüneyim.   
\q1
\v 6 Atalarımızla birlikte günah işledik.  
\q2 Suç işledik.  
\q2 Kötülük yaptık.   
\q1
\v 7 Atalarımız Mısır'daki harikalarını anlamadılar.  
\q2 Sevgi dolu iyiliklerinin çokluğunu hatırlamadılar,  
\q2 denizde, Kızıldeniz'de isyan ettiler.   
\q1
\v 8 Kudretli gücünü bildirsin diye,  
\q2 yine de kendi adı uğruna onları kurtardı,   
\q1
\v 9 Kızıldeniz'i de azarladı ve deniz kurudu,  
\q2 çölden geçermiş gibi onları derinliklerden geçirdi.   
\q1
\v 10 Onları kendilerinden nefret edenin elinden kurtardı,  
\q2 onları düşmanın elinden kurtardı.   
\q1
\v 11 Sular düşmanlarını örttü.  
\q2 Geride onlardan biri bile kalmadı.   
\q1
\v 12 O zaman sözlerine inandılar.  
\q2 O’na ezgilerle övgülerini sundular.   
\q1
\v 13 O’nun işlerini hemen unuttular.  
\q2 O’nun öğüdünü beklemediler,   
\q1
\v 14 ama çölde iştahlarına yenik düştüler,  
\q2 ıssız yerde Tanrı'yı denediler.   
\q1
\v 15 Onlara istediklerini verdi,  
\q2 ama canlarına zayıflık gönderdi.   
\q1
\v 16 Ordugâhta da Moşe’yi,  
\q2 Yahve'nin kutsalı Aron’u kıskandılar.   
\q1
\v 17 Yer yarıldı ve Datan'ı yuttu,  
\q2 Aviram'ın yandaşlarını örttü.   
\q1
\v 18 Onların arasında ateş tutuştu,  
\q2 alevi kötüleri yaktı.   
\q1
\v 19 Horev'de bir buzağı yaptılar,  
\q2 dökme bir surete taptılar.   
\q1
\v 20 Böylece ot yiyen bir öküzün sureti için  
\q2 kendi yüceliklerini değiştiler.   
\q1
\v 21 Kurtarıcılarını,  
\q2 Mısır'da büyük şeyler,   
\q1
\v 22 Ham diyarında harika işler,  
\q2 Kızıldeniz'de korkunç şeyler yapmış olan  
\q2 Tanrı'yı unuttular.   
\q1
\v 23 Bu nedenle onları yok edeceğini söyledi,  
\q2 seçtiği Moşe, yok etmesin diye,  
\q2 gazabını döndürmek için  
\q2 O’nun önünde gedikte durmasaydı,  
\q2 onları yok edecekti.   
\q1
\v 24 Evet, güzel ülkeyi küçümsediler.  
\q2 Sözüne inanmadılar,   
\q1
\v 25 ama çadırlarında söylendiler,  
\q2 Yahve’nin sesini dinlemediler.   
\q1
\v 26 Bu nedenle onları  
\q2 çölde devirmeye,   
\q1
\v 27 Soylarını uluslar arasında düşürmeye,  
\q2 onları ülkelere dağıtmaya onlara ant içti.   
\q1
\v 28 Baal Peor'a da bağlandılar.  
\q2 Ölülerin kurbanlarını yediler.   
\q1
\v 29 Böylece işleriyle O'nu öfkelendirdiler.  
\q2 Üstlerine veba geldi.   
\q1
\v 30 Bunun üzerine Pinehas ayağa kalktı ve yargıyı gerçekleştirdi.  
\q2 Böylece veba durduruldu.   
\q1
\v 31 Bu ona doğruluk sayıldı,  
\q2 gelecek tüm kuşaklar için.   
\q1
\v 32 Meriva sularında da O'nu öfkelendirdiler;  
\q2 Moşe onlardan ötürü sıkıntıya düştü;   
\q1
\v 33 O'nun ruhuna karşı isyan ettikleri için  
\q2 düşünmeden dudaklarıyla konuştu.   
\q1
\v 34 Yahve’nin onlara buyurduğu gibi,  
\q2 halkları yok etmediler.   
\q1
\v 35 Ama uluslara karıştılar,  
\q2 onların işlerini öğrendiler.   
\q1
\v 36 Putlarına hizmet ettiler,  
\q2 bu onlara tuzak oldu.   
\q1
\v 37 Evet, oğullarını ve kızlarını iblislere kurban ettiler.   
\q1
\v 38 Suçsuz kanı döktüler,  
\q2 oğullarının ve kızlarının kanlarını bile,  
\q2 Kenan putlarına kurban olarak sundular.  
\q2 Toprak kanla kirlendi.   
\q1
\v 39 Böylece işleriyle kirlendiler,  
\q2 kendi eylemlerinde fahişelik ettiler.   
\q1
\v 40 Bu yüzden Yahve’nin öfkesi halkına karşı tutuştu.  
\q2 Mirasından nefret etti.   
\q1
\v 41 Onları ulusların eline verdi.  
\q2 Onlardan nefret edenler onlara hükmetti.   
\q1
\v 42 Düşmanları da onlara zulmetti.  
\q2 Onların eli altında boyun eğdirildiler.   
\q1
\v 43 Onları defalarca kurtardı,  
\q2 ama kendi öğütlerinde isyankârdılar,  
\q2 kötülükleri yüzünden alçaltıldılar.   
\q1
\v 44 Yine de onların sıkıntısını gördü,  
\q2 onların yakarışlarını duyduğunda.   
\q1
\v 45 Onlar için antlaşmasını hatırladı,  
\q2 sevgi dolu iyiliğinin çokluğuna göre  
\q2 düşüncesinden vazgeçti.   
\q1
\v 46 Onları tutsak alanların  
\q2 onlara acımasını sağladı.   
\q1
\v 47 Kurtar bizi, ey Tanrımız Yahve,  
\q2 kutsal adına şükretmek,  
\q2 övgünle zafer kazanmak için,  
\q2 bizi ulusların arasından topla!   
\q1
\v 48 İsrael'in Tanrısı Yahve’ye,  
\q2 sonsuzluklar boyunca övgüler olsun!  
\q2 Bütün halk “Amin” desin.  
\q2 Yah’a övgüler olsun!  
\d 5. KİTAP   
\c 107  
\q1
\v 1 Yahve’ye\f + \fr 107:1 \ft “Yahve” Tanrı’nın asıl ismidir, diğer çevirilerde bazen “RAB=EFENDİ” (tamamı büyük harflerle) olarak çevrilir.\f* şükredin, çünkü O iyidir,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 2 Yahve’nin kurtardıkları böyle desinler,  
\q2 düşmanın elinden kurtardıkları,   
\q1
\v 3 onları, doğudan ve batıdan,  
\q2 kuzeyden ve güneyden,  
\q2 ülkelerden topladı.   
\q1
\v 4 Çölde ıssız bir yolda dolaştılar.  
\q2 Yaşanacak bir kent bulamadılar.   
\q1
\v 5 Aç ve susuz,  
\q2 içlerindeki canları bitkin düştü.   
\q1
\v 6 O zaman sıkıntı içinde Yahve’ye yakardılar,  
\q2 onları sıkıntılarından kurtardı,   
\q1
\v 7 yaşamak için bir kente gidebilsinler diye,  
\q2 onlara doğru yolda öncülük etti.   
\q1
\v 8 Yahve’ye sevgi dolu iyiliği için,  
\q2 insanoğullarına olan harika işleri için,  
\q2 övsünler!   
\q1
\v 9 Çünkü özlemle dolu canı doyurur.  
\q2 Aç canı iyilikle doldurur.   
\q1
\v 10 Bazıları karanlıkta, ölümün gölgesinde,  
\q2 ıstırap ve demirle bağlı oturmuştu.   
\q1
\v 11 Çünkü Tanrı'nın\f + \fr 107:11 \ft “Tanrı” olarak tercüme edilen İbranice kelime “אֱלֹהִ֑ים” (Elohim)’dir.\f* sözlerine isyan ettiler,  
\q2 Yüceler Yücesi'ni küçümsediler.   
\q1
\v 12 Bu nedenle onların yüreğini emekle alçalttı.  
\q2 Düştüler, yardım edecek kimse yoktu.   
\q1
\v 13 O zaman sıkıntı içinde Yahve’ye yakardılar,  
\q2 onları sıkıntılarından kurtardı.   
\q1
\v 14 Onları karanlıktan ve ölümün gölgesinden çıkardı,  
\q2 zincirlerini kırdı.   
\q1
\v 15 Yahve’ye sevgi dolu iyiliği için,  
\q2 insanoğullarına olan harika işleri için,  
\q2 övsünler!   
\q1
\v 16 Çünkü tunç kapıları kırdı,  
\q2 demir sürgüleri parçaladı.   
\q1
\v 17 Akılsızlar itaatsizliklerinden  
\q2 ve kötülükleri yüzünden sıkıntı çekerler.   
\q1
\v 18 Canları her türlü yiyecekten tiksinir.  
\q2 Ölüm kapılarına yaklaşırlar.   
\q1
\v 19 O zaman sıkıntı içinde Yahve’ye feryat ederler,  
\q2 onları sıkıntılarından kurtarır.   
\q1
\v 20 Sözünü gönderip onları iyileştirir,  
\q2 onları mezarlarından kurtarır.   
\q1
\v 21 Yahve’ye sevgi dolu iyiliği için,  
\q2 insanoğullarına olan harika işleri için,  
\q2 övsünler!   
\q1
\v 22 Şükran kurbanları sunsunlar,  
\q2 işlerini ezgilerle ilan etsinler.   
\q1
\v 23 Gemilerle denize inenler,  
\q2 büyük sularda iş yapanlar,   
\q1
\v 24 onlar Yahve’nin işlerini,  
\q2 derinlerdeki harikalarını görürler.   
\q1
\v 25 Çünkü O buyruk verir, fırtına rüzgârını kaldırır,  
\q2 denizin dalgalarını yükseltir.   
\q1
\v 26 Gökyüzüne yükselirler, yeniden derinlere inerler.  
\q2 Sıkıntıdan ötürü canları erir.   
\q1
\v 27 Sarhoş biri gibi ileri geri sallanıp, sendelerler,  
\q2 akılları başlarından gider.   
\q1
\v 28 O zaman sıkıntı içinde Yahve’ye feryat ederler,  
\q2 onları sıkıntılarından kurtarır.   
\q1
\v 29 Fırtınayı yatıştırır,  
\q2 dalgalar sakinleşir.   
\q1
\v 30 O zaman ortalık sakinleştiği için sevinirler,  
\q2 onları diledikleri limana götürür.   
\q1
\v 31 Yahve’ye sevgi dolu iyiliği için,  
\q2 insanoğullarına olan harika işleri için,  
\q2 övsünler!   
\q1
\v 32 Halk topluluğunda O'nu yüceltsinler,  
\q2 ihtiyarlar meclisinde O’nu övsünler.   
\q1
\v 33 Irmakları çöle,  
\q2 pınarları kuru toprağa,   
\q1
\v 34 verimli toprağı orada oturanların kötülüğü yüzünden  
\q2 çorak alana döndürür.   
\q1
\v 35 Çölü su göletine,  
\q2 kurak yeri su pınarlarına çevirir.   
\q1
\v 36 Yaşanacak bir kent hazırlasınlar diye  
\q2 orada açları yaşatır.   
\q1
\v 37 Tarlalar ekerler, bağlar dikerler,  
\q2 çoğalan ürünü toplarlar.   
\q1
\v 38 Onları da kutsar, böylece fazlasıyla çoğalırlar.  
\q2 Hayvanlarının eksilmesine izin vermez.   
\q1
\v 39 Baskı, sıkıntı ve keder yüzünden  
\q2 yine azalırlar ve alçalırlar.   
\q1
\v 40 Beylere hakaret yağdırır,  
\q2 yolsuz çorak bir yerde onları dolaştırır.   
\q1
\v 41 Yine de yoksulları sıkıntılarından kurtarır,  
\q2 ailelerini sürü gibi çoğaltır.   
\q1
\v 42 Doğrular bunu görecek ve sevinecek.  
\q2 Bütün kötüler ağzını kapayacak.   
\q1
\v 43 Bilge olan bunlara dikkat etsin.  
\q2 Yahve’nin sevgi dolu iyiliklerini düşünsün.   
\c 108  
\d Ezgi - David’in mezmuru  
\q1
\v 1 Yüreğim kararlıdır, ey Tanrı.  
\q2 Ezgi söyleyecek, canımla müzik yapacağım.   
\q1
\v 2 Uyan, ey arp ve lir!  
\q2 Şafağı ben uyandırayım.   
\q1
\v 3 Uluslar arasında sana şükürler sunayım, ey Yahve.  
\q2 Halkların arasında seni ilahilerle öveyim.   
\q1
\v 4 Çünkü sevgi dolu iyiliğin göklerin üstünde büyüktür.  
\q2 Sadakatin gökyüzüne ulaşır.   
\q1
\v 5 Ey Tanrı, göklerin üstünde yücel!  
\q2 Görkemin tüm yeryüzünü kaplasın.   
\q1
\v 6 Sevdiklerin kurtulsun diye,  
\q2 sağ elinle kurtar ve yanıt ver bize.   
\q1
\v 7 Tanrı kutsal yerinden şöyle konuştu:  
\q2 “Zafer kazanacağım.  
\q2 Şekem'i böleceğim,  
\q2 Sukkot Vadisi’ni ölçeceğim.   
\q1
\v 8 Gilad benimdir, Manaşşe de benim.  
\q2 Efraim de başımın siperi,  
\q2 Yahuda asamdır.   
\q1
\v 9 Moav yıkanma leğenimdir.  
\q2 Edom'un üzerine çarığımı atacağım.  
\q2 Filist üzerine zaferle haykıracağım.”   
\q1
\v 10 Kim beni surlu kente götürecek?  
\q2 Bana kim Edom'a kadar yol gösterecek?   
\q1
\v 11 Ey Tanrı, sen bizi reddetmedin mi?  
\q2 Ordularımızla yola çıkmıyorsun, ey Tanrı.   
\q1
\v 12 Düşmana karşı bize yardım et,  
\q2 çünkü insanın yardımı boştur.   
\q1
\v 13 Tanrı’yla yiğitlik ederiz,  
\q2 çünkü düşmanlarımızı ezecek olan O’dur.   
\c 109  
\d Müzik şefi için - David’in mezmuru 
\v 1 Ey övgülerimin Tanrısı, sessiz kalma,   
\q1
\v 2 Çünkü kötünün ağzını, hilekâr ağzını bana karşı açtılar.  
\q2 Benimle yalancı bir dille konuştular.   
\q1
\v 3 Nefret dolu sözlerle çevremi sarıp,  
\q2 nedensiz yere bana karşı savaştılar.   
\q1
\v 4 Sevgime karşılık bana düşmandırlar,  
\q2 bense dua etmekteyim.   
\q1
\v 5 İyiliğe kötülükle,  
\q2 sevgime nefretle karşılık verdiler.   
\q1
\v 6 Başına kötü bir adam koy.  
\q2 Sağ yanında bir düşman dursun.   
\q1
\v 7 Yargılandığı zaman suçlu çıksın.  
\q2 Duası günaha dönsün.   
\q1
\v 8 Günleri az olsun.  
\q2 Makamını bir başkası alsın.   
\q1
\v 9 Çocukları yetim,  
\q2 karısı dul kalsın.   
\q1
\v 10 Çocukları başıboş gezen dilenciler olsun.  
\q2 Yıkık yerlerinden çıkıp aransınlar.   
\q1
\v 11 Tefeci tüm malını kapsın.  
\q2 Emeğinin ürününü yabancılar yağmalasın.   
\q1
\v 12 Ona iyilik eden kimse olmasın,  
\q2 yetimlerine acıyacak kimse olmasın.   
\q1
\v 13 Soyu kesilsin.  
\q2 Gelecek kuşakta adları silinsin.   
\q1
\v 14 Atalarının suçları Yahve tarafından hatırlansın.  
\q2 Annesinin günahı silinmesin.   
\q1
\v 15 Sürekli Yahve’nin önünde bulunsunlar,  
\q2 öyle ki, anılarını yeryüzünden kesip atsın.   
\q1
\v 16 İyilik etmeyi hatırlamadı,  
\q2 ama yoksulu ve muhtacı,  
\q2 yüreği kırık olanı öldürmek için zulmetti.   
\q1
\v 17 Laneti sevdi ve kendi başına geldi.  
\q2 Kutsamaktan hoşlanmadı ve bu ondan uzak kaldı.   
\q1
\v 18 Laneti giysisi gibi kuşandı.  
\q2 Su gibi iç kısımlarına,  
\q2 yağ gibi kemiklerine girdi.   
\q1
\v 19 Kendisini örteceği giysi gibi olsun ona,  
\q2 hep kuşandığı bir kemer gibi olsun.   
\q1
\v 20 Düşmanlarıma, canım için kötülük söyleyenlere  
\q2 Yahve’nin verdiği karşılık budur.   
\q1
\v 21 Ama sen, ey Efendim\f + \fr 109:21 \ft “Efendi” olarak tercüme edilen sözcük “Adonay”dır.\f* Yahve,  
\q2 adın uğruna benimle ilgilen,  
\q2 çünkü sevgi dolu şefkatin iyidir, kurtar beni.   
\q1
\v 22 Çünkü ben yoksul ve muhtacım.  
\q2 Yüreğim içimde yaralı.   
\q1
\v 23 Akşam gölgesi gibi kayboluyorum.  
\q2 Çekirge gibi silkelenip atıldım.   
\q1
\v 24 Dizlerim oruçtan zayıfladı.  
\q2 Bedenim ince ve yağsız kaldı.   
\q1
\v 25 Ben de onlara yüzkarası oldum.  
\q2 Beni gördüklerinde başlarını sallıyorlar.   
\q1
\v 26 Yardım et bana, ey Yahve Tanrım.  
\q2 Sevgi dolu iyiliğin uyarınca beni kurtar;   
\q1
\v 27 bilsinler ki bu senin elindir,  
\q2 bunu yapan sensin ey Yahve.   
\q1
\v 28 Onlar lanet edebilir, ama sen kutsa.  
\q2 Ayağa kalktıklarında utanacaklar,  
\q2 ama senin hizmetkârın sevinecek.   
\q1
\v 29 Düşmanlarım rezilliği giyinsin.  
\q2 Bir elbise gibi kendilerini kendi utançlarıyla örtsünler.   
\q1
\v 30 Yahve’ye ağzımla çok şükürler sunacağım.  
\q2 Kalabalığın arasında O’nu öveceğim.   
\q1
\v 31 Çünkü O, yoksulun canını yargılayanlardan  
\q2 onu kurtarmak için sağında durur.   
\c 110  
\d David’in mezmuru  
\q1
\v 1 Yahve Efendim’e:  
\q2 “Ben düşmanlarını ayakların için tabure edene dek,  
\q2 sağımda otur” dedi.   
\q1
\v 2 Yahve senin kuvvet asanı Siyon'dan gönderecek.  
\q2 Düşmanlarının arasında hüküm sür.   
\q1
\v 3 Halkın, gücünün gününde kutsal düzen içinde  
\q2 kendilerini gönüllü olarak sunarlar.  
\q2 Gençlerin sabahın rahminden doğan çiğ gibidir.   
\q1
\v 4 Yahve ant içti, düşüncesini değiştirmez:  
\q2 “Melkisedek düzeninde sen sonsuza dek kâhinsin.”   
\q1
\v 5 Efendi senin sağındadır.  
\q2 Gazabının gününde kralları ezecek.   
\q1
\v 6 Uluslar arasında hüküm verecek.  
\q2 Cesetleri yığacak.  
\q2 Bütün dünyanın hükümdarını ezecek.   
\q1
\v 7 Yolda dereden içecek;  
\q2 bu nedenle başını dik tutacak.   
\c 111  
\q1
\v 1 Yah’ı övün!\f + \fr 111:1 \ft Mezmurlar 111, her bir dizesinde “Yah’a şükürler olsun!” ifadesinin yer aldığı bir akrostiş şiirdir; alfabedeki bir harfle başlar (Alef’ten Tav’a doğru sıralanmıştır).\f*  
\q2 Doğruların meclisinde ve topluluk içinde  
\q2 bütün yüreğimle Yahve’ye şükürler sunacağım,   
\q1
\v 2 Yahve’nin işleri büyüktür,  
\q2 onlardan zevk alanların hepsi onları düşünür.   
\q1
\v 3 O’nun işi saygınlık ve heybettir.  
\q2 Doğruluğu sonsuza dek sürer.   
\q1
\v 4 Harika işlerinin hatırlanmasını sağladı.  
\q2 Yahve lütufkâr ve merhametlidir.   
\q1
\v 5 Kendisinden korkanlara yiyecek verir.  
\q2 O her zaman antlaşmasını hatırlar.   
\q1
\v 6 Ulusların mirasını onlara vermekle  
\q2 halkına işlerinin gücünü gösterdi,   
\q1
\v 7 ellerinin işleri gerçek ve adalettir.  
\q2 O’nun bütün kuralları kesindir.   
\q1
\v 8 Onlar sonsuzluklar boyunca sabittir.  
\q2 Gerçek ve doğrulukla yapılır.   
\q1
\v 9 Halkına kurtuluş gönderdi.  
\q2 Antlaşmasını sonsuza dek atamıştır.  
\q2 O’nun adı kutsal ve muhteşemdir!   
\q1
\v 10 Yahve korkusu bilgeliğin başlangıcıdır.  
\q2 O’nun işini yapanların hepsi iyi bir anlayışa sahiptir.  
\q2 O’nun övgüsü sonsuza dek sürer!   
\c 112  
\q1
\v 1 Yah’ı övün!\f + \fr 112:1 \ft Mezmurlar 112, her bir dizesinde “Yah’a şükürler olsun!” ifadesinin yer aldığı bir akrostiş şiirdir ve her beyit alfabedeki bir harfle başlar (Alef’ten Tav’a doğru sıralanmıştır).\f*  
\q2 Ne mutlu Yahve'den korkan insana,  
\q2 O’nun buyruklarından büyük zevk alana.   
\q1
\v 2 Onun soyu ülkede kudretli olacak.  
\q2 Doğruların kuşağı kutsanacak.   
\q1
\v 3 Bolluk ve zenginlik onun evindedir.  
\q2 Onun doğruluğu sonsuza dek sürer.   
\q1
\v 4 Doğrular için karanlıkta ışık doğar,  
\q2 lütufkâr, merhametli ve adildir onlar.   
\q1
\v 5 Lütfedenin ve ödünç verenin durumu iyidir.  
\q2 Yargıda davasını sürdürür.   
\q1
\v 6 Çünkü o asla sarsılmaz.  
\q2 Doğrular daima hatırlanır.   
\q1
\v 7 Kötü haberden korkmaz.  
\q2 Yüreği kararlıdır, Yahve’ye güvenir.   
\q1
\v 8 Yüreği sağlamdır.  
\q2 Sonunda düşmanlarını gördüğünde korkmaz.   
\q1
\v 9 O dağıttı, yoksullara verdi.  
\q2 Doğruluğu sonsuza dek durur.  
\q2 Boynuzu saygınlıkla yükselir.   
\q1
\v 10 Kötü kişi bunu görüp dertlenir.  
\q2 Dişlerini gıcırdatır, eriyip gider.  
\q2 Kötülerin dileği yok olur.   
\c 113  
\q1
\v 1 Yah’ı övün!  
\q2 Ey Yahve’nin hizmetkârları övün,  
\q2 Yahve’nin adını övün.   
\q1
\v 2 Şimdiden sonsuza dek,  
\q2 Yahve’nin adına övgüler olsun.   
\q1
\v 3 Güneşin doğuşundan batışına dek,  
\q2 Yahve’nin adı övülmelidir.   
\q1
\v 4 Yahve bütün ulusların üstünde yücedir,  
\q2 O’nun görkemi göklerin üzerindedir.   
\q1
\v 5 Kim var Tanrımız Yahve gibi,  
\q2 yücelerde oturan,   
\q1
\v 6 Gökte ve yeryüzünde olanlara  
\q2 bakmak için eğilen?   
\q1
\v 7 Yoksulu topraktan kaldırır.  
\q2 Muhtacı kül yığınından yükseltir,   
\q1
\v 8 beylerle,  
\q2 halkının beyleriyle oturtsun diye.   
\q1
\v 9 Kısır kadını sevinçli bir çocuklar annesi eder  
\q2 evinde oturtur.  
\q2 Yah’ı övün!   
\c 114  
\q1
\v 1 İsrael Mısır’dan,  
\q2 Yakov'un evi yabancı dilli halktan  
\q2 ayrıldığında,   
\q1
\v 2 Yahuda kutsal yeri,  
\q2 İsrael O’nun krallığı oldu.   
\q1
\v 3 Deniz bunu gördü ve kaçtı.  
\q2 Yarden tersine döndü.   
\q1
\v 4 Dağlar koçlar gibi,  
\q2 küçük tepeler kuzular gibi sıçradı.   
\q1
\v 5 Ey deniz, ne oldu da kaçtın?  
\q2 Ey Yarden, neden ters döndün?   
\q1
\v 6 Ey dağlar, neden koçlar gibi,  
\q2 ey küçük tepeler, neden kuzular gibi sıçradınız?   
\q1
\v 7 Titreyin, ey yeryüzü, Efendi’nin önünde,  
\q2 Yakov'un Tanrısı'nın huzurunda,   
\q1
\v 8 O’dur kayayı su havuzuna,  
\q2 çakmaktaşını su pınarına çeviren.   
\c 115  
\q1
\v 1 Bize değil, ey Yahve, bize değil.  
\q2 Ama sevgi dolu iyiliğin ve gerçeğin uğruna,  
\q2 kendi adına yücelik ver.   
\q1
\v 2 Neden uluslar:  
\q2 “Şimdi, onların Tanrısı nerede?” desin.   
\q1
\v 3 Ama Tanrımız göklerdedir.  
\q2 Ne isterse onu yapar.   
\q1
\v 4 Onların putları gümüş ve altındır,  
\q2 insan ellerinin işi.   
\q1
\v 5 Ağızları var ama konuşmazlar.  
\q2 Gözleri var ama görmezler.   
\q1
\v 6 Kulakları var ama duymazlar.  
\q2 Burunları var ama koku almazlar.   
\q1
\v 7 Elleri var ama hissetmezler.  
\q2 Ayakları var ama yürümezler,  
\q2 boğazlarıyla da konuşmazlar.   
\q1
\v 8 Onları yapanlar ve onlara güvenen herkes,  
\q2 onlar gibi olacak.   
\q1
\v 9 Ey İsrael, Yahve’ye güven!  
\q2 O’dur onların yardımcısı ve kalkanı.   
\q1
\v 10 Ey Aron Evi, Yahve’ye güvenin!  
\q2 O’dur onların yardımcısı ve kalkanı.   
\q1
\v 11 Ey sizler Yahve’den korkanlar, Yahve’ye güvenin!  
\q2 O’dur onların yardımcısı ve kalkanı.   
\q1
\v 12 Yahve bizi hatırlar. O bizi kutsayacak.  
\q2 İsrael'in evini kutsayacak.  
\q2 Aron'un evini kutsayacak.   
\q1
\v 13 Yahve'den korkanları,  
\q2 küçüğü de büyüğü de kutsayacak.   
\q1
\v 14 Yahve sizi,  
\q2 sizi ve çocuklarınızı fazlasıyla artırsın.   
\q1
\v 15 Göğü ve yeri yaratan Yahve  
\q2 sizi kutsasın.   
\q1
\v 16 Gökler Yahve’nin gökleridir,  
\q2 ama yeryüzünü insanoğullarına verdi.   
\q1
\v 17 Ölüler, sessizliğin içine inenler,  
\q2 Yah'ı övmezler.   
\q1
\v 18 Ama biz şimdiden sonsuza dek,  
\q2 Yah’ı öveceğiz,  
\q2 Yah’ı övün!   
\c 116  
\q1
\v 1 Yahve'yi seviyorum,  
\q2 çünkü sesimi, feryadımı merhametiyle duyar.   
\q1
\v 2 Kulağını bana döndürdüğü için,  
\q2 yaşadığım sürece O’nu çağıracağım.   
\q1
\v 3 Ölüm ipleri çevremi sarmıştı,  
\q2 Şeol'ün\f + \fr 116:3 \ft Şeol ölüler diyarıdır.\f* acıları beni ele geçirmişti.  
\q2 Sıkıntı ve keder buldum.   
\q1
\v 4 O zaman Yahve’nin adını çağırdım:  
\q2 “Ey Yahve, sana yalvarıyorum, canımı kurtar.”   
\q1
\v 5 Yahve lütufkâr ve doğrudur.  
\q2 Merhametlidir Tanrımız.   
\q1
\v 6 Yahve saf insanı korur.  
\q2 Alçaltılmıştım ve O beni kurtardı.   
\q1
\v 7 Ey canım, rahatına dön,  
\q2 çünkü Yahve sana cömertçe davrandı.   
\q1
\v 8 Çünkü canımı ölümden,  
\q2 gözlerimi gözyaşından,  
\q2 ayaklarımı düşmekten kurtardın.   
\q1
\v 9 Yaşayanlar diyarında  
\q2 Yahve’nin önünde yürüyeceğim.   
\q1
\v 10 İman ettim, bu nedenle şöyle dedim:  
\q2 “Çok acı çektim.”   
\q1
\v 11 Telaşla şöyle dedim:  
\q2 “Bütün insanlar yalancıdır.”   
\q1
\v 12 Bana yönelik tüm iyiliklerine karşılık  
\q2 Yahve’ye ne vereyim?   
\q1
\v 13 Kurtuluş kâsesini alıp  
\q2 Yahve’nin adını çağıracağım.   
\q1
\v 14 Bütün halkının önünde,  
\q2 Yahve’ye adaklarımı yerine getireceğim.   
\q1
\v 15 Yahve’nin gözünde  
\q2 kutsallarının ölümü değerlidir.   
\q1
\v 16 Ey Yahve, gerçekten ben senin hizmetkârınım.  
\q2 Hizmetkârın, hizmetçi kızın oğluyum.  
\q2 Zincirlerimden beni sen serbest bıraktın.   
\q1
\v 17 Sana şükran kurbanını sunacağım,  
\q2 Yahve’nin adını çağıracağım.   
\q1
\v 18 Yahve’ye adaklarımı yerine getireceğim,  
\q2 bütün halkının önünde,   
\q1
\v 19 Yahve'nin evinin avlularında,  
\q2 senin ortanda, ey Yeruşalem.  
\q2 Yah’ı övün!   
\c 117  
\q1
\v 1 Ey bütün uluslar, Yahve’yi övün!  
\q2 O’nu övün, ey bütün halklar!   
\q1
\v 2 Çünkü bize olan sevgi dolu iyiliği büyüktür.  
\q2 Yahve’nin sadakati sonsuza dek sürer.  
\q2 Yah’ı övün!   
\c 118  
\q1
\v 1 Yahve’ye şükredin, çünkü O iyidir,  
\q2 sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 2 Şimdi İsrael,  
\q2 “Sevgi dolu iyiliği sonsuza dek sürer” desin.   
\q1
\v 3 Şimdi Aron'un evi,  
\q2 “Sevgi dolu iyiliği sonsuza dek sürer” desin.   
\q1
\v 4 Şimdi Yahve’den korkanlar,  
\q2 “Sevgi dolu iyiliği sonsuza dek sürer” desin.   
\q1
\v 5 Sıkıntı içinde Yah’a seslendim.  
\q2 Yah özgürlükle bana yanıt verdi.   
\q1
\v 6 Yahve benden yanadır. Korkmam.  
\q2 İnsan bana ne yapabilir?   
\q1
\v 7 Bana yardım edenlerin arasında  
\q2 Yahve benden yanadır.  
\q2 Bu nedenle benden nefret edenlere zaferle bakacağım.   
\q1
\v 8 Yahve’ye sığınmak,  
\q2 insana güvenmekten iyidir.   
\q1
\v 9 Yahve’ye sığınmak,  
\q2 beylere güvenmekten iyidir.   
\q1
\v 10 Bütün uluslar çevremi sardı,  
\q2 ama Yahve’nin adıyla kopardım onları.   
\q1
\v 11 Çevremi sardılar, evet çevremi sardılar.  
\q2 Yahve’nin adıyla gerçekten kopardım onları.   
\q1
\v 12 Arılar gibi çevremi sardılar.  
\q2 Diken ateşi gibi söndüler.  
\q2 Yahve’nin adıyla kopardım onları.   
\q1
\v 13 Düşeyim diye beni şiddetle geri ittin,  
\q2 ama Yahve bana yardım etti.   
\q1
\v 14 Yah benim gücüm ve ezgimdir.  
\q2 O benim kurtuluşum oldu.   
\q1
\v 15 Sevinç ve kurtuluş sesi doğruların çadırlarındadır.  
\q2 “Yahve’nin sağ eli yiğitlik eder.   
\q1
\v 16 Yahve’nin sağ eli yücedir!  
\q2 Yahve’nin sağ eli yiğitlik eder!”   
\q1
\v 17 Ölmeyeceğim, yaşayacağım,  
\q2 Yah'ın işlerini ilan edeceğim.   
\q1
\v 18 Yah beni ciddi bir şekilde cezalandırdı,  
\q2 ama beni ölüme teslim etmedi.   
\q1
\v 19 Bana doğruluğun kapılarını aç.  
\q2 Onların içine gireyim.  
\q2 Yah’a şükürler sunayım.   
\q1
\v 20 Yahve’nin kapısı işte budur;  
\q2 doğrular oraya girer.   
\q1
\v 21 Sana şükrederim, çünkü bana yanıt verdin,  
\q2 benim kurtuluşum oldun.   
\q1
\v 22 Yapıcıların reddettiği taş  
\q2 köşe taşı\f + \fr 118:22 \ft Kelimenin tam anlamıyla köşenin başı\f* oldu.   
\q1
\v 23 Bu Yahve’nin işidir.  
\q2 Gözümüzde şaşılacak bir iş.   
\q1
\v 24 Yahve’nin yarattığı gün bu gündür.  
\q2 İçinde sevinip coşalım!   
\q1
\v 25 Bizi şimdi kurtar, ey Yahve, sana yalvarırız!  
\q2 Sana yalvarırız, ey Yahve, şimdi bolluk gönder.   
\q1
\v 26 Kutsansın Yahve’nin adıyla gelen!  
\q2 Yahve’nin evinden seni kutsarız.   
\q1
\v 27 Yahve Tanrı'dır ve bize ışık verdi.  
\q2 Kurbanınızı sunağın boynuzlarına kadar iplerle bağlayın.   
\q1
\v 28 Sen benim Tanrım’sın, sana şükrederim.  
\q2 Sen benim Tanrım’sın, seni yüceltirim.   
\q1
\v 29 Yahve’ye şükredin, çünkü O iyidir,  
\q2 sevgi dolu iyiliği sonsuza dek sürer.   
\c 119  
\d א ALEF  
\q1
\v 1 Ne mutlu yolları kusursuz olanlara,  
\q2 Yahve’nin yasasına göre yürüyenlere.   
\q1
\v 2 Ne mutlu O'nun kurallarına uyanlara,  
\q2 O’nu tüm yüreğiyle arayanlara.   
\q1
\v 3 Evet, onlar hiç haksızlık etmezler.  
\q2 O’nun yolunda yürürler.   
\q1
\v 4 Onlara tamamen uyalım diye,  
\q2 ilkelerini buyurdun.   
\q1
\v 5 Keşke yollarım sağlam olsaydı  
\q2 yasalarına itaat etmek için!   
\q1
\v 6 O zaman hayal kırıklığına uğramazdım,  
\q2 bütün buyruklarını göz önünde bulundurdukça.   
\q1
\v 7 Sana dürüst bir yürekle şükredeceğim,  
\q2 doğru hükümlerini öğrendikçe.   
\q1
\v 8 Kurallarına uyacağım.  
\q2 Beni bütünüyle terk etme.  
\d ב BEYT   
\q1
\v 9 Genç insan yolunu nasıl temiz tutabilir?  
\q2 Sözüne göre yaşamakla.   
\q1
\v 10 Bütün yüreğimle seni aradım.  
\q2 Buyruklarından sapmama izin verme.   
\q1
\v 11 Sözünü yüreğimde sakladım,  
\q2 sana karşı günah işlememek için.   
\q1
\v 12 Övgüler olsun sana, ey Yahve.  
\q2 Bana kurallarını öğret.   
\q1
\v 13 Dudaklarımla,  
\q2 ağzından çıkan bütün hükümlerini ilan ederim.   
\q1
\v 14 Senin tanıklıkların yolunda,  
\q2 tüm zenginlikler benimmiş gibi sevindim.   
\q1
\v 15 Senin ilkelerin üzerinde  
\q2 derin derin düşüneceğim,  
\q2 yollarını göz önünde bulunduracağım.   
\q1
\v 16 Senin kurallarından zevk alırım.  
\q2 Sözünü unutmam.  
\d ג GİMEL   
\q1
\v 17 Hizmetkârına iyilik et de yaşayayım,  
\q2 sözüne uyayım.   
\q1
\v 18 Gözlerimi aç da  
\q2 yasandaki şaşılası şeyleri göreyim.   
\q1
\v 19 Ben yeryüzünde bir yabancıyım.  
\q2 Buyruklarını benden saklama.   
\q1
\v 20 Canım her zaman senin hükümlerinin özlemiyle  
\q2 yanıp tutuşuyor.   
\q1
\v 21 Senin buyruklarından sapan  
\q2 lanetli küstahları azarladın.   
\q1
\v 22 Utancı ve hakareti benden uzaklaştır,  
\q2 çünkü senin hükümlerini tuttum.   
\q1
\v 23 Beyler oturup bana iftira etse bile,  
\q2 hizmetkârın senin ilkelerinin üzerinde  
\q2 derin derin düşünecek.   
\q1
\v 24 Gerçekten de senin ilkelerin benim zevkimdir,  
\q2 danışmanlarımdır.  
\d ד DALET   
\q1
\v 25 Canım toprağa serildi.  
\q2 Sözün uyarınca dirilt beni!   
\q1
\v 26 Yollarımı açıkladım, bana yanıt verdin.  
\q2 Bana kurallarını öğret.   
\q1
\v 27 İlkelerindeki öğretiyi anlamamı sağla!  
\q2 O zaman senin şaşılası işlerinin  
\q2 üzerinde derin derin düşünürüm.   
\q1
\v 28 Canım kederden bitkin,  
\q2 sözün uyarınca güçlendir beni.   
\q1
\v 29 Beni yalan yolundan uzak tut.  
\q2 Yasanı bana lütufla bağışla!   
\q1
\v 30 Ben gerçeğin yolunu seçtim.  
\q2 Hükümlerini önüme koydum.   
\q1
\v 31 Senin kurallarına sarıldım, ey Yahve.  
\q2 Hayal kırıklığına uğratma beni.   
\q1
\v 32 Buyruklarının yolunda koşuyorum,  
\q2 çünkü yüreğimi özgür kıldın.  
\d ה HE   
\q1
\v 33 Ey Yahve, bana yasalarının yolunu öğret.  
\q2 Onları sonuna dek tutayım.   
\q1
\v 34 Bana anlayış ver, yasana uyayım.  
\q2 Evet, ona tüm yüreğimle itaat edeyim.   
\q1
\v 35 Buyruklarının yolunda bana yol göster,  
\q2 çünkü onlardan zevk alırım.   
\q1
\v 36 Yüreğimi bencil kazanca değil,  
\q2 senin kurallarına yönelt.   
\q1
\v 37 Gözlerimi değersiz şeylere bakmaktan çevir.  
\q2 Beni kendi yollarınla canlandır.   
\q1
\v 38 Hizmetkârına verdiğin sözü yerine getir ki,  
\q2 senden korkulsun.   
\q1
\v 39 Korktuğum hakareti benden uzaklaştır,  
\q2 çünkü senin hükümlerin iyidir.   
\q1
\v 40 İşte, senin ilkelerini özlüyorum!  
\q2 Beni doğruluğunun içinde dirilt.  
\d ו VAV   
\q1
\v 41 Sözün uyarınca, ey Yahve,  
\q2 sevgi dolu iyiliğin, kurtarışın da bana gelsin.   
\q1
\v 42 Böylece bana hakaret edene bir yanıtım olsun,  
\q2 çünkü senin sözüne güveniyorum.   
\q1
\v 43 Gerçeğin sözünü ağzımdan düşürme,  
\q2 çünkü senin hükümlerine umut bağladım ben.   
\q1
\v 44 Bu yüzden yasana sürekli,  
\q2 sonsuza dek uyacağım.   
\q1
\v 45 Özgürce yürüyeceğim,  
\q2 çünkü senin ilkelerini aradım.   
\q1
\v 46 Kralların önünde de senin kuralların hakkında konuşacak,  
\q2 hayal kırıklığına uğramayacağım.   
\q1
\v 47 Buyruklarından zevk alırım,  
\q2 çünkü onları severim.   
\q1
\v 48 Sevdiğim buyruklarına ellerimi kaldırırım.  
\q2 Senin kurallarının üzerinde derin derin düşüneyim.  
\d ז ZAYİN   
\q1
\v 49 Hizmetkârına verdiğin sözü hatırla,  
\q2 çünkü bana umut verdin.   
\q1
\v 50 Sıkıntımda tesellim budur,  
\q2 çünkü senin sözün beni diriltti.   
\q1
\v 51 Küstahlar benimle çok alay ettiler,  
\q2 ama senin yasandan sapmadım.   
\q1
\v 52 Eski hükümlerini hatırlarım, ey Yahve,  
\q2 kendimi teselli ettim.   
\q1
\v 53 Öfke beni ele geçirdi,  
\q2 yasanı terk eden kötüler yüzünden.   
\q1
\v 54 Senin kuralların yaşadığım evde  
\q2 benim ezgilerim oldu.   
\q1
\v 55 Gece adını hatırladım, ey Yahve,  
\q2 yasana uyarım.   
\q1
\v 56 Benim yolum budur;  
\q2 senin ilkelerini tutmak.  
\d ח HET   
\q1
\v 57 Benim payım Yahve’dir.  
\q2 Sözlerine uyacağıma söz verdim.   
\q1
\v 58 Bütün yüreğimle lütfunu aradım.  
\q2 Sözün uyarınca bana merhamet et.   
\q1
\v 59 Yollarımı düşündüm,  
\q2 adımlarımı senin hükümlerine yönelttim.   
\q1
\v 60 Senin buyruklarını tutmak için  
\q2 acele ettim, geç kalmadım.   
\q1
\v 61 Kötülerin ipleri beni bağladı,  
\q2 ama yasanı unutmadım.   
\q1
\v 62 Doğru hükümlerin için  
\q2 gece yarısı kalkıp sana şükrederim.   
\q1
\v 63 Senden korkan, ilkelerine uyan herkesin,  
\q2 dostuyum ben.   
\q1
\v 64 Yeryüzü sevgi dolu iyiliğinle dolu, ey Yahve.  
\q2 Bana kurallarını öğret.  
\d ט TET   
\q1
\v 65 Sözün uyarınca  
\q2 hizmetkârına iyilik ettin, ey Yahve.   
\q1
\v 66 Bana sağduyu ve bilgi öğret,  
\q2 çünkü senin buyruklarına inanıyorum.   
\q1
\v 67 Acı çekmeden önce yoldan sapmıştım,  
\q2 ama şimdi sözüne uyuyorum.   
\q1
\v 68 Sen iyisin ve iyilik edersin.  
\q2 Bana kurallarını öğret.   
\q1
\v 69 Küstahlar yalanla bana kara çaldılar.  
\q2 Ben bütün yüreğimle ilkelerini tutarım.   
\q1
\v 70 Onların yürekleri yağ gibi katılaştı,  
\q2 bense yasandan zevk alırım.   
\q1
\v 71 Acı çekmem benim için iyi oldu,  
\q2 ta ki, kurallarını öğreneyim.   
\q1
\v 72 Senin ağzının yasası  
\q2 benim için binlerce altın ve gümüşten daha iyidir.  
\d י YOD   
\q1
\v 73 Senin ellerin beni yarattı ve biçim verdi.  
\q2 Bana anlayış ver ki, buyruklarını öğrenebileyim.   
\q1
\v 74 Senden korkanlar beni görecek ve sevinecek,  
\q2 çünkü ben umudumu senin sözüne bağladım.   
\q1
\v 75 Ey Yahve, yargılarının doğru olduğunu bilirim,  
\q2 sadakatinde bana acı verdin.   
\q1
\v 76 Hizmetkârına olan sözün uyarınca,  
\q2 lütfen sevgi dolu iyiliğin bana teselli olsun.   
\q1
\v 77 Senin şefkatli merhametlerin bana gelsin, yaşayayım,  
\q2 çünkü yasan benim zevkimdir.   
\q1
\v 78 Küstahlar hayal kırıklığına uğrasın,  
\q2 çünkü haksız yere beni düşürdüler.  
\q2 Ben senin ilkelerinin üzerinde  
\q2 derin derin düşüneceğim.   
\q1
\v 79 Senden korkanlar bana dönsünler.  
\q2 Yasalarını bilecekler.   
\q1
\v 80 Yüreğim senin hükümlerine karşı suçsuz olsun ki,  
\q2 hayal kırıklığına uğramayayım.  
\d כ KAF   
\q1
\v 81 Canım senin kurtarışın için bitkin durumda.  
\q2 Senin sözüne umut bağladım.   
\q1
\v 82 Gözlerim senin sözün için sönüyor.  
\q2 “Beni ne zaman teselli edeceksin?” diyorum.   
\q1
\v 83 Çünkü dumanda kalmış şarap tulumu gibi oldum.  
\q2 Senin kurallarını unutmuyorum.   
\q1
\v 84 Hizmetkârının günleri ne kadardır?  
\q2 Bana zulmedenleri ne zaman yargılayacaksın?   
\q1
\v 85 Yasana aykırı olarak  
\q2 küstahlar benim için çukur kazdılar.   
\q1
\v 86 Buyruklarının tümü sadakattir.  
\q2 Bana haksız yere zulmediyorlar.  
\q2 Yardım et bana!   
\q1
\v 87 Neredeyse beni yeryüzünden sileceklerdi,  
\q2 ama ben senin ilkelerini bırakmadım.   
\q1
\v 88 Sevgi dolu iyiliğin uyarınca koru canımı,  
\q2 böylece ağzının kurallarını tutayım.  
\d ל LAMED   
\q1
\v 89 Ey Yahve, sözün  
\q2 Göklerde sonsuza dek kalıcıdır.   
\q1
\v 90 Sadakatin tüm kuşakları kapsar.  
\q2 Yeryüzünü kurdun ve o duruyor.   
\q1
\v 91 Yasaların bugüne dek duruyor,  
\q2 çünkü her şey sana hizmet eder.   
\q1
\v 92 Eğer yasan benim zevkim olmasaydı,  
\q2 acım yüzünden yok olurdum.   
\q1
\v 93 İlkelerini asla unutmayacağım,  
\q2 çünkü onlarla beni dirilttin.   
\q1
\v 94 Ben seninim.  
\q2 Kurtar beni, çünkü senin ilkelerini aradım.   
\q1
\v 95 Kötüler beni yok etmek için beklediler.  
\q2 Ben senin kurallarını dikkate alıyorum.   
\q1
\v 96 Her kusursuzluğun bir sınırını gördüm,  
\q2 ama senin buyrukların sınırsızdır.  
\d מ MEM   
\q1
\v 97 Yasanı ne kadar severim!  
\q2 Bütün gün düşüncem odur.   
\q1
\v 98 Buyrukların beni düşmanlarımdan daha bilge kılar,  
\q2 çünkü buyrukların her zaman benimledir.   
\q1
\v 99 Bütün öğretmenlerimden daha anlayışlıyım,  
\q2 çünkü tanıklıkların benim düşüncemdir.   
\q1
\v 100 Yaşlılardan daha iyi anlarım,  
\q2 çünkü senin ilkelerine uydum.   
\q1
\v 101 Ayaklarımı her kötü yoldan uzak tuttum,  
\q2 senin sözüne uymak için.   
\q1
\v 102 Senin hükümlerinden ayrılmadım,  
\q2 çünkü bana sen öğrettin.   
\q1
\v 103 Vaatlerin damağıma ne tatlıdır,  
\q2 ağzım için baldan tatlıdır!   
\q1
\v 104 İlkelerin sayesinde anlayış kazanıyorum,  
\q2 bunun için her yanlış yoldan nefret ediyorum.  
\d נ NUN   
\q1
\v 105 Sözün ayaklarım için bir fener,  
\q2 yolum için bir ışıktır.   
\q1
\v 106 Senin doğru hükümlerini yerine getireyim diye  
\q2 ant içtim, andımı pekiştirdim.   
\q1
\v 107 Çok acı çekiyorum.  
\q2 Sözün uyarınca beni dirilt, ey Yahve.   
\q1
\v 108 Yalvarırım sana, ağzımın gönüllü sunularını kabul et.  
\q2 Ey Yahve, bana hükümlerini öğret.   
\q1
\v 109 Canım sürekli elimdedir,  
\q2 yine de yasanı unutmam.   
\q1
\v 110 Kötüler bana tuzak kurdu,  
\q2 yine de senin ilkelerinden sapmadım.   
\q1
\v 111 Senin tanıklıklarını sonsuza dek miras olarak aldım,  
\q2 çünkü onlar yüreğimin sevincidir.   
\q1
\v 112 Kurallarını uygulamaya yüreğimi koydum,  
\q2 ta sonuna, sonsuza dek.  
\d ם SAMEH   
\q1
\v 113 Çift fikirli insanlardan nefret ederim  
\q2 ama senin yasanı severim.   
\q1
\v 114 Saklanacak yerim ve kalkanım sensin.  
\q2 Senin sözüne umut bağlarım.   
\q1
\v 115 Uzak durun benden,  
\q2 ey siz kötülük edenler.  
\q2 Ta ki, Tanrım’ın buyruklarını tutabileyim.   
\q1
\v 116 Sözün uyarınca bana destek ol ki, yaşayayım.  
\q2 Umudumdan utanmayayım.   
\q1
\v 117 Beni tutup kaldır, güvende olurum,  
\q2 senin kurallarına daima saygı duyarım.   
\q1
\v 118 Kurallarından sapan herkesi reddedersin,  
\q2 çünkü onların hilesi boşunadır.   
\q1
\v 119 Yeryüzünün bütün kötülerini  
\q2 süprüntü gibi bir kenara attın.  
\q2 Bunun için tanıklıklarını severim.   
\q1
\v 120 Senin korkundan bedenim titrer.  
\q2 Yargılarından korkarım.  
\d ע AYİN   
\q1
\v 121 Adil ve doğru olanı yaptım.  
\q2 Beni zalimlerin eline bırakma.   
\q1
\v 122 Hizmetkârının mutluluğunu güven altına al.  
\q2 Küstahların beni ezmesine izin verme.   
\q1
\v 123 Gözlerim senin kurtarışını ve doğru sözünü,  
\q2 aramayı bırakıyor.   
\q1
\v 124 Hizmetkârına sevgi dolu iyiliğine göre davran.  
\q2 Bana kurallarını öğret.   
\q1
\v 125 Ben senin hizmetkârınım. Bana anlayış ver de  
\q2 senin tanıklıklarını bileyim.   
\q1
\v 126 Harekete geçme zamanıdır, ey Yahve,  
\q2 çünkü yasanı çiğniyorlar.   
\q1
\v 127 Bunun için senin buyruklarını,  
\q2 altından, saf altından daha çok severim.   
\q1
\v 128 Bu nedenle tüm ilkelerini doğru sayarım.  
\q2 Her yanlış yoldan nefret ediyorum.  
\d פ PE   
\q1
\v 129 Tanıklıkların harikadır,  
\q2 bunun için canım onlara uyuyor.   
\q1
\v 130 Sözlerinin açılışı ışık verir,  
\q2 saf insana anlayış.   
\q1
\v 131 Ağzımı genişçe açtım ve hasret kaldım.  
\q2 Çünkü buyruklarını özlüyorum.   
\q1
\v 132 Bana yönel ve bana merhamet et,  
\q2 adını sevenlere her zaman yaptığın gibi.   
\q1
\v 133 Adımlarımı sözünde pekiştir.  
\q2 Hiçbir kötülük bana hakim olmasın.   
\q1
\v 134 Beni insanların baskısından kurtar da  
\q2 ilkelerine uyayım.   
\q1
\v 135 Yüzünü hizmetkârının üzerinde parlat.  
\q2 Bana kurallarını öğret.   
\q1
\v 136 Gözlerimden oluk oluk yaşlar akıyor,  
\q2 çünkü yasana uymuyorlar.  
\d צ TSADE   
\q1
\v 137 Sen doğrusun, ey Yahve.  
\q2 Yargıların dosdoğrudur.   
\q1
\v 138 Kurallarını doğrulukla buyurdun.  
\q2 Onlar tamamen güvenilirdir.   
\q1
\v 139 Gayretim beni tüketti,  
\q2 çünkü düşmanlarım  
\q2 senin sözlerini görmezden geliyor.   
\q1
\v 140 Vaatlerin tümüyle sınandı,  
\q2 hizmetkârın onları sever.   
\q1
\v 141 Ben küçük ve hor görülen biriyim.  
\q2 Senin ilkelerini unutmuyorum.   
\q1
\v 142 Senin doğruluğun sonsuz bir doğruluktur.  
\q2 Yasan gerçektir.   
\q1
\v 143 Sıkıntı ve ıstırap beni ele geçirdi.  
\q2 Buyrukların benim zevkimdir.   
\q1
\v 144 Tanıklıkların daima doğrudur.  
\q2 Bana anlayış ver ki, yaşayayım.  
\d ק KOF   
\q1
\v 145 Tüm yüreğimle çağırdım.  
\q2 Yanıt ver bana, ey Yahve!  
\q2 Senin kurallarını tutacağım.   
\q1
\v 146 Seni çağırdım. Kurtar beni!  
\q2 Senin kurallarına uyacağım.   
\q1
\v 147 Şafaktan önce kalkıyorum  
\q2 ve yardım için yakarıyorum.  
\q2 Umudumu senin sözlerine bağladım.   
\q1
\v 148 Gece nöbetleri boyunca gözlerim açık kalıyor,  
\q2 senin sözünü düşüneyim diye.   
\q1
\v 149 Sevgi dolu iyiliğine göre sesimi duy.  
\q2 Hükümlerin uyarınca beni dirilt, ey Yahve.   
\q1
\v 150 Kötülüğün ardına düşenler yaklaşıyor.  
\q2 Onlar senin yasandan uzaklar.   
\q1
\v 151 Sen yakınsın, ey Yahve.  
\q2 Buyruklarının tümü gerçektir.   
\q1
\v 152 Eskiden beri tanıklıklarından bilirim ki,  
\q2 sen onları sonsuza dek kurdun.  
\d ר REŞ   
\q1
\v 153 Çektiğim sıkıntıyı gör ve kurtar beni,  
\q2 çünkü senin yasanı unutmuyorum.   
\q1
\v 154 Davamı savun ve kurtar beni!  
\q2 Sözün uyarınca beni dirilt.   
\q1
\v 155 Kurtuluş kötülerden uzaktır,  
\q2 çünkü senin hükümlerini aramıyorlar.   
\q1
\v 156 Senin sevecen merhametlerin ne büyüktür, ey Yahve.  
\q2 Beni hükümlerine göre dirilt.   
\q1
\v 157 Bana zulmedenler ve düşmanlarım çoktur.  
\q2 Ben senin tanıklıklarından sapmadım.   
\q1
\v 158 Hainlere nefretle bakarım,  
\q2 çünkü onlar senin sözünü tutmuyorlar.   
\q1
\v 159 İlkelerini ne kadar sevdiğimi gör.  
\q2 Sevgi dolu iyiliğine göre beni dirilt, ey Yahve.   
\q1
\v 160 Bütün sözlerin doğrudur.  
\q2 Her doğru hükmün sonsuza dek durur.  
\d ש SİN ve ŞİN   
\q1
\v 161 Beyler yok yere bana zulmettiler,  
\q2 ama yüreğim sözlerine hayran kalır.   
\q1
\v 162 Büyük ganimet bulan biri gibi,  
\q2 ben senin sözünde sevinirim.   
\q1
\v 163 Yalandan nefret ederim ve tiksinirim.  
\q2 Yasanı severim.   
\q1
\v 164 Doğru hükümlerin için,  
\q2 günde yedi kez seni överim.   
\q1
\v 165 Yasanı sevenler büyük esenliğe sahip olurlar.  
\q2 Hiçbir şey onları tökezletemez.   
\q1
\v 166 Kurtarışına umut bağladım, ey Yahve.  
\q2 Buyruklarını yerine getirdim.   
\q1
\v 167 Canım senin tanıklıklarını tuttu.  
\q2 Onları fazlasıyla severim.   
\q1
\v 168 İlkelerine ve tanıklıklarına uydum,  
\q2 çünkü bütün yollarım senin önündedir.  
\d ת TAV   
\q1
\v 169 Feryadım önüne gelsin, ey Yahve.  
\q2 Sözün uyarınca bana anlayış ver.   
\q1
\v 170 Yalvarışım senin önüne gelsin.  
\q2 Sözün uyarınca kurtar beni.   
\q1
\v 171 Dudaklarım övsün,  
\q2 çünkü bana kurallarını öğretiyorsun.   
\q1
\v 172 Dilim senin sözünü ezgiye çevirsin,  
\q2 çünkü bütün buyrukların doğruluktur.   
\q1
\v 173 Elin bana yardım etmeye hazır olsun,  
\q2 çünkü ben senin ilkelerini seçtim.   
\q1
\v 174 Senin kurtarışını özledim, ey Yahve.  
\q2 Yasan benim zevkimdir.   
\q1
\v 175 Canımı yaşat ki, seni öveyim.  
\q2 Senin hükümlerin bana yardım etsin.   
\q1
\v 176 Kaybolmuş bir koyun gibi yoldan saptım.  
\q2 Hizmetkârını ara,  
\q2 çünkü ben senin buyruklarını unutmam.   
\c 120  
\q1
\v 1 Sıkıntı içinde Yahve’yi çağırdım.  
\q2 Bana yanıt verdi.   
\q1
\v 2 Ey Yahve, canımı yalancı dudaklardan,  
\q2 aldatıcı dilden kurtar.   
\q1
\v 3 Ey aldatıcı dil,  
\q2 sana ne verilecek,  
\q2 senin için daha çok ne yapılacak?   
\q1
\v 4 Güçlünün sivri oklarıyla,  
\q2 ardıç kömürü.   
\q1
\v 5 Vay halime, Meşek'te yaşadığım,  
\q2 Kedar'ın çadırları arasında oturduğum için!   
\q1
\v 6 Canım uzun zamandır  
\q2 esenlikten nefret edenle mesken tutuyor.   
\q1
\v 7 Ben esenlikten yanayım,  
\q2 ama ben konuşunca, onlar savaştan yana.   
\c 121  
\d Hagga ilahisi  
\q1
\v 1 Gözlerimi tepelere kaldırıyorum.  
\q2 Yardımım nereden gelecek?   
\q1
\v 2 Yardımım yeri ve göğü yaratan  
\q2 Yahve'den gelecek.   
\q1
\v 3 O ayaklarının sarsılmasına izin vermez.  
\q2 Seni koruyan uyuklamaz.   
\q1
\v 4 İşte İsrael'i koruyan  
\q2 ne uyur, ne de uyuklar.   
\q1
\v 5 Senin koruyucun Yahve’dir.  
\q2 Sağ yanında Yahve sana gölgedir.   
\q1
\v 6 Gündüz güneş,  
\q2 gece ay sana zarar vermez.   
\q1
\v 7 Yahve seni her kötülükten korur.  
\q2 O senin canını korur.   
\q1
\v 8 Şimdiden sonsuza dek,  
\q2 Yahve senin gidişini gelişini koruyacak.   
\c 122  
\d David’in hagga ilahisi  
\q1
\v 1 Bana, “Hadi Yahve'nin evine gidelim!”  
\q2 dediklerinde sevindim.   
\q1
\v 2 Ayaklarımız senin kapılarında duruyor,  
\q2 ey Yeruşalem,   
\q2
\v 3 bitişik kurulmuş bir kenttir Yeruşalem,   
\q1
\v 4 oymaklar, Yah’ın oymakları,  
\q2 İsrael için olan kural uyarınca,  
\q2 Yahve’nin adına şükretmek için oraya çıkarlar.   
\q1
\v 5 Çünkü yargı için kurulmuş tahtlar,  
\q2 David'in evinin tahtları vardır.   
\q1
\v 6 Yeruşalem'in esenliği için dua edin.  
\q2 Seni sevenler bolluğa kavuşur.   
\q1
\v 7 Surlarının içinde esenlik,  
\q2 saraylarında bolluk olsun.   
\q1
\v 8 Kardeşlerim ve dostlarım için,  
\q2 şimdi “Sende esenlik olsun” derim.   
\q1
\v 9 Tanrımız Yahve’nin evi için,  
\q2 senin iyiliğini ararım.   
\c 123  
\d Hagga ilahisi  
\q1
\v 1 Ey göklerde oturan,  
\q2 gözlerimi sana kaldırıyorum   
\q1
\v 2 Hizmetkârların gözleri efendilerinin eline,  
\q2 hizmetçinin gözleri hanımının eline baktığı gibi,  
\q2 işte, bizim gözlerimiz de Tanrımız Yahve’ye öyle bakar,  
\q2 O bize merhamet edene kadar.   
\q1
\v 3 Bize merhamet et, ey Yahve, bize merhamet et,  
\q2 çünkü fazlasıyla aşağılanmaya katlandık.   
\q1
\v 4 Canımız rahat olanların alaylarına,  
\q2 küstahların küçümsemesine,  
\q2 fazlasıyla doydu.   
\c 124  
\d David’in hagga ilahisi  
\q1
\v 1 Yahve bizim tarafımızda olmasaydı,  
\q2 desin şimdi İsrael:   
\q1
\v 2 Yahve bizim tarafımızda olmasaydı,  
\q2 insanlar bize karşı çıktığında,   
\q1
\v 3 öfkeleri bize karşı alevlendiğinde,  
\q2 o vakit bizi diri diri yutarlardı.   
\q1
\v 4 O vakit sular bizi boğardı,  
\q2 sel canımızı aşardı,   
\q1
\v 5 O vakit gururlu sular canımızı aşardı.   
\q1
\v 6 Övgüler olsun,  
\q2 bizi onların dişlerine yem etmeyen Yahve’ye.   
\q1
\v 7 Canımız kuş avcısının tuzağından  
\q2 bir kuş gibi kurtuldu.  
\q2 Tuzak kırıldı, biz kurtulduk.   
\q1
\v 8 Yeri göğü yaratan  
\q2 Yahve’nin adı yardımcımızdır.   
\c 125  
\d Hagga ilahisi  
\q1
\v 1 Yahve'ye güvenenler Siyon Dağı gibidir,  
\q2 sarsılmaz, sonsuza dek kalır.   
\q1
\v 2 Dağlar Yeruşalem'i nasıl sarmışsa,  
\q2 Yahve de halkını  
\q2 Şimdiden sonsuza dek öyle sarmıştır.   
\q1
\v 3 Çünkü kötülüğün asası  
\q2 doğruların payında kalmayacak,  
\q2 öyle ki, doğrular ellerini  
\q2 kötülük yapmak için kullanmasınlar.   
\q1
\v 4 İyilere, yüreği dürüst olanlara,  
\q2 iyilik et, ey Yahve.   
\q1
\v 5 Ama kendi eğri yollarına sapanlara gelince,  
\q2 Yahve onları kötülüğün işçileriyle birlikte uzaklaştıracak.  
\q2 Esenlik İsrael’in üzerinde olsun.   
\c 126  
\d Hagga ilahisi  
\q1
\v 1 Yahve Siyon'a dönenleri geri getirdiğinde,  
\q2 düş görenler gibiydik.   
\q1
\v 2 O zaman ağzımız kahkahalarla,  
\q2 dilimiz ezgiyle doldu.  
\q2 O zaman uluslar arasında şöyle dediler:  
\q2 “Yahve onlar için büyük şeyler yaptı.”   
\q1
\v 3 Yahve bizim için büyük şeyler yaptı,  
\q2 bunun için sevinçliyiz.   
\q1
\v 4 Eski bolluk günlerimize geri döndür, ey Yahve,  
\q2 Negev'deki dereler gibi.   
\q1
\v 5 Gözyaşları içinde ekenler,  
\q2 sevinçle biçecekler.   
\q1
\v 6 Ağlayarak ekilecek tohumu taşıyıp dışarı çıkan,  
\q2 elbette sevinçle demetleri taşıyarak geri gelecektir.   
\c 127  
\d Solomon’un hagga ilahisi  
\q1
\v 1 Evi Yahve yapmazsa,  
\q2 yapıcılar boşuna çalışır.  
\q1 Kente Yahve göz kulak olmazsa,  
\q2 bekçi boşuna nöbet tutar.   
\q1
\v 2 Boşunadır sizin için erken kalkıp geç yatmanız,  
\q2 ey zahmet ekmeği yiyenler.  
\q2 Çünkü O sevdiklerine uyku verir.   
\q1
\v 3 İşte çocuklar Yahve’nin mirasıdır.  
\q2 Rahmin ürünü, onun ödülüdür.   
\q1
\v 4 Yiğidin elindeki oklar gibi,  
\q2 gençlik çocukları da böyledir.   
\q1
\v 5 Ok kılıfı onlarla dolu olan adama ne mutlu.  
\q2 Düşmanlarıyla kapıda konuşurken, hayal kırıklığına uğramazlar.   
\c 128  
\d Hagga ilahisi  
\q1
\v 1 Ne mutlu Yahve’den korkan,  
\q2 O’nun yolunda yürüyen herkese.   
\q1
\v 2 Çünkü ellerinin emeğini yiyeceksin.  
\q2 Mutlu olacaksın ve senin için iyi olacak.   
\q1
\v 3 Eşin evinin içinde verimli bir asma gibi olacak,  
\q2 çocukların sofranın etrafındaki zeytin filizleri gibi.   
\q1
\v 4 İşte, Yahve’den korkan adam böyle kutsanır.   
\q1
\v 5 Yahve seni Siyon'dan kutsasın,  
\q2 yaşamının bütün günlerinde  
\q2 Yeruşalem'in iyiliğini göresin.   
\q1
\v 6 Evet, çocuklarının çocuklarını göresin.  
\q2 Esenlik İsrael’in üzerinde olsun.   
\c 129  
\d Hagga ilahisi  
\q1
\v 1 Gençliğimden beri bana çok kez eziyet ettiler.  
\q2 Şimdi İsrael desin:   
\q1
\v 2 Gençliğimden beri bana çok kez eziyet ettiler,  
\q2 yine de bana karşı galip gelemediler.   
\q1
\v 3 Çiftçiler sırtımda saban sürdüler.  
\q2 Saban izlerini uzun bıraktılar.   
\q1
\v 4 Yahve doğrudur.  
\q2 Kötülerin bağlarını kopardı.   
\q1
\v 5 Hayal kırıklığına uğrayıp geri dönsünler,  
\q2 Siyon'dan nefret edenlerin hepsi.   
\q1
\v 6 Büyümeden önce kuruyan,  
\q2 damlardaki ot gibi olsunlar.   
\q1
\v 7 Onunla orakçı elini,  
\q2 demetçi kucağını doldurmaz.   
\q1
\v 8 Oradan geçenler de,  
\q2 “Yahve’nin kutsaması üzerinize olsun.  
\q2 Sizi Yahve'nin adıyla kutsuyoruz” demezler.   
\c 130  
\d Hagga ilahisi  
\q1
\v 1 Derinliklerden seni çağırdım, ey Yahve.   
\q1
\v 2 Ey Efendim, sesimi duy.  
\q2 Dikkatli olsun kulakların  
\q2 dileklerimin sesine.   
\q1
\v 3 Ey Yah, sen eğer günahların kaydını tutarsan,  
\q2 kim ayakta durabilir, ey Efendim?   
\q1
\v 4 Ama sende bağışlanma var,  
\q2 bunun için senden korkulsun.   
\q1
\v 5 Yahve'yi bekliyorum.  
\q2 Canım bekliyor.  
\q2 O’nun sözüne umut bağlıyorum.   
\q1
\v 6 Bekçilerin sabahı özlemesinden daha çok,  
\q2 sabah bekçilerinden daha çok,  
\q2 canım Efendi’yi özlüyor.   
\q1
\v 7 Ey İsrael, Yahve’ye umut bağla,  
\q2 çünkü Yahve’nin sevgi dolu iyiliği vardır.  
\q2 O’nda bol kurtuluş vardır.   
\q1
\v 8 İsrael'i bütün günahlarından O kurtaracaktır.   
\c 131  
\d David’in hagga ilahisi  
\q1
\v 1 Ey Yahve, yüreğim gururlu,  
\q2 gözlerim yükseklerde değil,  
\q2 ne büyük meselelerle,  
\q2 ne de benim için fazlasıyla harika olan  
\q2 şeylerle ilgilenmiyorum.   
\q1
\v 2 Ana kucağında sütten kesilmiş bir çocuk gibi  
\q2 gerçekten canımı sakinleştirip susturdum,  
\q2 canım sütten kesilmiş bir çocuk gibi.   
\q1
\v 3 Ey İsrael, Yahve’ye umut bağla,  
\q2 şimdiden sonsuza dek.   
\c 132  
\d Hagga ilahisi  
\q1
\v 1 Ey Yahve, David’i ve bütün sıkıntılarını hatırla,   
\q1
\v 2 Yahve’ye nasıl ant içtiğini,  
\q2 Yakov'un Güçlüsü’ne olan adağını:   
\q1
\v 3 “Gerçekten evimin içine girmeyeceğim,  
\q2 yatağıma çıkmayacağım,   
\q1
\v 4 Gözlerime uyku,  
\q2 göz kapaklarıma uyuklama vermeyeceğim;   
\q1
\v 5 Yahve’ye bir yer,  
\q2 Yakov'un Güçlüsü'ne bir mesken bulana dek.”   
\q1
\v 6 İşte onun Efrata'da olduğunu duyduk.  
\q2 Onu Yaar kırında bulduk:   
\q1
\v 7 “O’nun meskenine gidelim.  
\q2 O’nun ayağının taburesinde tapınalım.   
\q1
\v 8 Sen ve gücünün sandığı, ey Yahve,  
\q2 kendi dinlenme yerine çık,   
\q1
\v 9 kâhinleriniz doğrulukla giyinsin.  
\q2 Kutsallarınız sevinçle haykırsın!”   
\q1
\v 10 Hizmetkârın David'in hatırı için,  
\q2 meshetmiş olduğuna yüz çevirme.   
\q1
\v 11 Yahve David'e gerçekle ant içti.  
\q2 Ondan geri dönmez:  
\q2 “Senin bedeninin ürününü tahtına oturtacağım.   
\q1
\v 12 Eğer çocukların antlaşmamı,  
\q2 onlara öğreteceğim tanıklığımı tutarsa,  
\q2 onların çocukları da daima  
\q2 senin tahtında oturacaklar.”   
\q1
\v 13 Çünkü Yahve Siyon'u seçti.  
\q2 Kendine mesken olarak onu arzu etti.   
\q1
\v 14 “Burası benim sonsuza dek dinlenme yerimdir.  
\q2 Burada yaşayacağım çünkü bunu ben arzuladım.   
\q1
\v 15 Onun erzağını bol bol bereketleyeceğim.  
\q2 Yoksulunu ekmekle doyuracağım.   
\q1
\v 16 Kâhinlerine de kurtuluş giydireceğim.  
\q2 Kutsalları sevinç içinde yüksek sesle haykıracaklar.   
\q1
\v 17 Orada David'in boynuzunu yeşerteceğim.  
\q2 Meshedilmişim için bir kandil atadım.   
\q1
\v 18 Düşmanlarını utançla örteceğim  
\q2 ama kendi üzerindeki tacı parlayacak.”   
\c 133  
\d David’in hagga ilahisi  
\q1
\v 1 Bakın, ne iyi, ne hoştur  
\q2 kardeşlerin beraberce birlik içinde yaşaması!   
\q1
\v 2 Baştaki değerli yağ gibi,  
\q2 sakaldan, Aron’un sakalından akan,  
\q2 kaftanlarının yakasına dek inen yağ gibi.   
\q1
\v 3 Siyon tepelerine inen,  
\q2 Hermon’un çiyi gibidir,  
\q2 çünkü Yahve orada bereketi,  
\q2 sonsuz yaşamı verdi.   
\c 134  
\d Hagga ilahisi  
\q1
\v 1 Bakın! Ey sizler Yahve’nin bütün hizmetkârları,  
\q2 geceyi Yahve'nin evinde geçirenler,  
\q2 Yahve’yi övün!   
\q2
\v 2 Kutsal yerde ellerinizi kaldırın.  
\q2 Yahve’yi övün!   
\q1
\v 3 Göğü ve yeri yapan Yahve  
\q2 sizi Siyon'dan kutsasın.   
\c 135  
\q1
\v 1 Yah’ı övün!  
\q2 Yahve’nin adını övün!  
\q2 Ey Yahve'nin hizmetkârları, O'nu övün,   
\q1
\v 2 ey sizler Yahve’nin evinde,  
\q2 Tanrımız’ın evinin avlularında duranlar.   
\q1
\v 3 Yahve’yi övün, çünkü Yahve iyidir.  
\q2 Adını ezgilerle övün, çünkü bu hoştur.   
\q1
\v 4 Çünkü Yahve kendisi için Yakov'u,  
\q2 kendi mülkü olarak İsrael’i seçti.   
\q1
\v 5 Çünkü bilirim ki Yahve büyüktür,  
\q2 Efendimiz bütün ilâhlardan üstündür.   
\q1
\v 6 Yahve ne dilediyse onu yaptı,  
\q2 gökte, yeryüzünde, denizlerde ve tüm derinliklerde.   
\q1
\v 7 Yeryüzünün uçlarından bulutları yükseltir.  
\q2 Yağmurla birlikte şimşekler yapar.  
\q2 Rüzgârı hazinelerinden çıkarır.   
\q1
\v 8 Hem insanı hem hayvanı,  
\q2 Mısır’ın ilk doğanlarını vurdu,   
\q1
\v 9 senin orta yerinde, ey Mısır,  
\q2 Firavun'nun ve onun bütün hizmetkârlarının üzerine,  
\q2 belirtiler ve harikalar gönderdi.   
\q1
\v 10 Birçok ulusu vurdu,  
\q2 güçlü kralları öldürdü,   
\q1
\v 11 Amorlular'ın kralı Sihon’u,  
\q2 Başan Kralı Og’u,  
\q2 Kenan'ın bütün krallıklarını.   
\q1
\v 12 Onların topraklarını mülk olarak,  
\q2 kendi halkı İsrael'e miras olarak verdi.   
\q1
\v 13 Adın, ey Yahve, sonsuza dek durur,  
\q2 ünün, ey Yahve, tüm kuşaklar boyuncadır.   
\q1
\v 14 Çünkü Yahve halkını yargılar,  
\q2 hizmetkârlarına merhamet gösterir.   
\q1
\v 15 Ulusların putları gümüş ve altındır,  
\q2 insan ellerinin işi.   
\q1
\v 16 Ağızları var ama konuşmazlar.  
\q2 Gözleri var ama görmezler.   
\q1
\v 17 Kulakları var ama duymazlar.  
\q2 Ağızlarında hiç soluk bulunmaz.   
\q1
\v 18 Onları yapanlar ve onlara güvenen herkes,  
\q2 onlar gibi olacak.   
\q1
\v 19 Ey İsrael evi, Yahve’yi övün!  
\q2 Ey Aron evi, Yahve’yi övün!   
\q1
\v 20 Ey Levi evi, Yahve’yi övün!  
\q2 Ey Yahve'den korkanlar,  
\q2 Yahve’yi övün!   
\q1
\v 21 Yeruşalem’de oturan Yahve  
\q2 Siyon'dan övülsün.  
\q1 Yah’ı övün!   
\c 136  
\q1
\v 1 Yahve’ye şükredin, çünkü O iyidir,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 2 Tanrılar Tanrısı'na şükredin,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 3 Efendilerin Efendisi’ne şükredin,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 4 Büyük harikalar yapan tek varlığa,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 5 Gökleri anlayışla yapana,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 6 Yeryüzünü suların üzerine yayana,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 7 Büyük ışıklar yapana,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 8 Gündüze hükmetsin diye güneşi,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 9 Geceye hükmetmek için ayı ve yıldızları,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 10 Mısır’ın ilk doğanını vurana,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 11 İsrael'i aralarından çıkarana,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 12 Güçlü eli ve uzanmış koluyla;  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 13 Kızıldeniz'i ikiye bölene;  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 14 İsrael'i ortasından geçirene,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 15 Firavun'la ordusunu  
\q2 Kızıldeniz'de bozguna uğratana,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 16 Halkına çölde öncülük edene,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 17 Büyük kralları vurana,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 18 Güçlü kralları öldürene,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 19 Amorluları'ın kralı Sihon’u,  
\q2 çünkü sevgi dolu iyiliği Sonsuza dek sürer.   
\q1
\v 20 Başan Kralı Og’u,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 21 Topraklarını mülk olarak,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 22 Hizmetkârı İsrael'e miras olarak verene,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 23 Düşkünlüğümüzde bizi hatırlayana,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 24 Bizi düşmanlarımızdan kurtarana,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 25 Her yaratığa yiyecek verene,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\q1
\v 26 Göklerin Tanrısı’na şükredin,  
\q2 çünkü sevgi dolu iyiliği sonsuza dek sürer.   
\c 137  
\q1
\v 1 Babil ırmakları kıyısında,  
\q2 orada oturduk.  
\q2 Siyon'u hatırladığımızda, evet ağladık.   
\q1
\v 2 O diyardaki söğütlere,  
\q2 arplarımızı astık.   
\q1
\v 3 Çünkü orada bizi tutsak edenler  
\q2 bizden ezgiler.  
\q2 Bize eziyet edenler  
\q2 sevinç ezgileri istediler:  
\q2 “Bize Siyon ezgilerinden birini söyleyin!” dediler.   
\q1
\v 4 Yahve'nin ezgisini  
\q2 yabancı bir diyarda nasıl söyleriz?   
\q1
\v 5 Eğer seni unutursam, ey Yeruşalem,  
\q2 sağ elim becerisini unutsun.   
\q1
\v 6 Eğer seni hatırlamazsam  
\q2 eğer Yeruşalem’i baş sevincimden üstün tutmazsam,  
\q2 dilim damağıma yapışsın,   
\q1
\v 7 Yeruşalem gününde,  
\q2 “Yıkın! Onu temeline kadar yıkın!” diyen  
\q2 Edom'un çocuklarına karşı,  
\q2 hatırla, ey Yahve.   
\q1
\v 8 Ey sen, yıkıma mahkûmsun ey Babil kızı,  
\q2 bize yaptığının karşılığını,  
\q2 sana ödetecek olana ne mutlu.   
\q1
\v 9 Senin yavrularını alıp  
\q2 kayaya çarpacak olana ne mutlu!   
\c 138  
\d David’in mezmuru  
\q1
\v 1 Bütün yüreğimle sana şükrederim.  
\q2 İlahlar\f + \fr 138:1 \ft Burada kullanılan elohim kelimesi genellikle “Tanrı” anlamına gelir ama aynı zamanda “ilâhlar”, “beyler” veya “melekler” anlamına da gelebilir.\f* önünde seni ilahilerle överim.   
\q1
\v 2 Kutsal tapınağına doğru eğilirim,  
\q2 sevgi dolu iyiliğin ve gerçeğin için  
\q2 adına şükrederim;  
\q2 çünkü Adını ve Sözü'nü her şeyin üstünde yücelttin.   
\q1
\v 3 Çağırdığım gün bana yanıt verdin.  
\q2 Canımdaki güçle beni cesaretlendirdin.   
\q1
\v 4 Yeryüzünün bütün kralları sana şükredecek, ey Yahve,  
\q2 çünkü ağzının sözlerini işittiler.   
\q1
\v 5 Yahve’nin yollarını, evet, ezgilere dökecekler,  
\q2 çünkü Yahve'nin yüceliği büyüktür!   
\q1
\v 6 Çünkü Yahve yükseklerde ise de,  
\q2 alçakgönüllülerle ilgilenir,  
\q2 ama kibirliyi uzaktan tanır.   
\q1
\v 7 Sıkıntının ortasında yürüsem bile,  
\q2 sen beni canlandırırsın.  
\q2 Düşmanlarımın gazabına karşı elini uzatırsın.  
\q2 Sağ elin beni kurtaracak.   
\q1
\v 8 Yahve beni endişelendiren şeyi tamam eder.  
\q2 Sevgi dolu iyiliğin sonsuza dek sürer, ey Yahve.  
\q2 Kendi ellerinin işlerini bırakma.   
\c 139  
\d Müzik şefi için - David’in mezmuru  
\q1
\v 1 Yahve, sen beni yokladın ve tanıdın.   
\q1
\v 2 Oturuşumu ve kalkışımı bilirsin.  
\q2 Düşüncelerimi uzaktan sezersin.   
\q1
\v 3 Yolumu ve yatışımı araştırırsın,  
\q2 bütün yollarımı bilirsin.   
\q1
\v 4 Çünkü dilimde tek söz yokken,  
\q2 işte, ey Yahve, sen bunun hepsini bilirsin.   
\q1
\v 5 Beni arkadan ve önden kuşattın.  
\q2 Elini üzerime koydun.   
\q1
\v 6 Bu bilgi beni aşıyor, yüce, ona erişemem.   
\q1
\v 7 Senin Ruhun’dan nereye gidebilirim?  
\q2 Ya da senin varlığından nereye kaçabilirim?   
\q1
\v 8 Göğe çıksam oradasın.  
\q2 Yatağımı Şeol'e\f + \fr 139:8 \ft Şeol ölüler diyarıdır.\f* sersem, işte oradasın!   
\q1
\v 9 Şafağın kanatlarını alsam,  
\q2 denizin en uzak uçlarına konsam,   
\q1
\v 10 orada bile elin bana yol gösterir,  
\q2 sağ elin beni tutar.   
\q1
\v 11 Desem ki, “Karanlık beni mutlaka örter,  
\q2 çevremdeki ışık gece olsun.”   
\q1
\v 12 Karanlık bile senden gizlenemez,  
\q2 gece gündüz gibi parlar.  
\q2 Karanlık senin için ışık gibidir.   
\q1
\v 13 Çünkü benim iç varlığımı sen biçimlendirdin.  
\q2 Annemin rahminde beni sen ördün.   
\q1
\v 14 Sana şükürler sunarım,  
\q2 çünkü saygın ve harika yapılmışım.  
\q2 Senin işlerin harikadır.  
\q2 Canım bunu çok iyi bilir.   
\q1
\v 15 Gizlide yapıldığımda,  
\q2 yeryüzünün derinliklerinde örüldüğümde,  
\q2 bedenim senden gizli değildi.   
\q1
\v 16 Gözlerin bedenimi gördü.  
\q2 Benim için tayin edilen günlerin,  
\q2 henüz hiçbiri yokken,  
\q2 hepsi senin kitabında yazılmıştı.   
\q1
\v 17 Düşüncelerin benim için ne değerlidir, ey Tanrı!  
\q2 Onların hesabı uçsuz bucaksızdır!   
\q1
\v 18 Onları saysam, sayıları kumdan çoktur.  
\q2 Uyandığımda yine seninleyim.   
\q1
\v 19 Keşke sen, ey Tanrı, kötüleri öldürsen.  
\q2 Uzak durun benden, siz kana susamış insanlar!   
\q1
\v 20 Çünkü onlar sana karşı kötü konuşuyorlar.  
\q2 Düşmanların adını boş yere anıyorlar.   
\q1
\v 21 Ey Yahve, senden nefret edenlerden nefret etmez miyim?  
\q2 Sana karşı ayaklananlara kederlenmez miyim?   
\q1
\v 22 Onlardan katıksızca nefret ederim.  
\q2 Onlar benim düşmanım oldular.   
\q1
\v 23 Beni yokla, ey Tanrı, yüreğimi bil.  
\q2 Beni dene ve düşüncelerimi öğren.   
\q1
\v 24 Bak, içimde kötü bir yol var mı,  
\q2 sonsuzluk yolunda bana öncülük et.   
\c 140  
\d Müzik şefi için - David’in mezmuru  
\q1
\v 1 Ey Yahve, kurtar beni kötü insanlardan.  
\q2 Koru beni zalimden.   
\q1
\v 2 Onlar, yüreklerinde kötülük tasarlar,  
\q2 sürekli savaş için toplanırlar.   
\q1
\v 3 Dillerini yılan gibi keskinleştirdiler.  
\q2 Engerek zehri dudaklarının altındadır. Selah.   
\q1
\v 4 Ey Yahve, koru beni kötülerin elinden.  
\q2 Ayaklarıma çelme takmaya kararlı  
\q2 zalim insanlardan koru beni.   
\q1
\v 5 Küstahlar bana tuzak kurdular,  
\q2 yol kenarına ağ gerdiler.  
\q2 Benim için kapan yerleştirdiler. Selah.   
\q1
\v 6 Yahve’ye, “Sen benim Tanrım’sın” dedim.  
\q2 Dileklerimin feryadını dinle, ey Yahve.   
\q1
\v 7 Kurtuluşumun gücü, ey Efendi Yahve,  
\q2 savaş gününde başımı örttün.   
\q1
\v 8 Ey Yahve, kötülerin dileklerini verme.  
\q2 Kötü planları başarıya ulaşmasın,  
\q2 yoksa gurura kapılırlar. Selah.   
\q1
\v 9 Beni kuşatanların başına gelince,  
\q2 kendi dudaklarının kötülüğü onları kaplasın.   
\q1
\v 10 Üzerlerine kızgın korlar yağsın.  
\q2 Ateşe atılsınlar,  
\q2 asla çıkamayacakları  
\q2 çamurlu çukurlara.   
\q1
\v 11 Kötülük konuşan yeryüzünde tutunamasın.  
\q2 Kötülük, zalimi yıkmak için onu avlasın.   
\q1
\v 12 Bilirim ki, Yahve dertlinin davasına bakar,  
\q2 muhtacı haklı çıkarır.   
\q1
\v 13 Gerçekten doğrular senin adına şükredecekler.  
\q2 Doğrular senin huzurunda oturur.   
\c 141  
\d David’in mezmuru  
\q1
\v 1 Ey Yahve, seni çağırdım.  
\q2 Bana tez gel!  
\q2 Seni çağırdığımda sesimi dinle.   
\q1
\v 2 Duam buhur gibi,  
\q2 el kaldırışım akşam kurbanı gibi  
\q2 senin önünde dursun.   
\q1
\v 3 Ey Yahve, ağzıma bekçi koy.  
\q2 Dudaklarımın kapısını koru.   
\q1
\v 4 Yüreğimi kötülüğe meyletme,  
\q2 kötülük yapan adamlarla fesat işlemeyeyim.  
\q2 Onların lezzetlerinden yemeyeyim.   
\q1
\v 5 Doğru bana vursun, iyiliktir bu,  
\q2 azarlasın beni, başa sürülen yağ gibidir,  
\q2 başım onu reddetmesin,  
\q2 ama benim duam hep kötü işlere karşıdır.   
\q1
\v 6 Onların yargıçları kayanın yanına atıldı.  
\q2 Sözlerimi duyacaklar,  
\q2 çünkü yerinde söylenmiştir.   
\q1
\v 7 “Nasıl biri toprağı sürüp yararsa,  
\q2 kemiklerimiz de Şeol'ün\f + \fr 141:7 \ft Şeol ölüler diyarıdır.\f* ağzında  
\q2 öyle dağılmış durumda.”   
\q1
\v 8 Çünkü gözlerim senin üzerinde,  
\q2 ey Efendimiz Yahve.  
\q2 Sana sığınıyorum.  
\q2 Canımı yoksul bırakma.   
\q1
\v 9 Bana kurdukları tuzaktan,  
\q2 kötülük işçilerinin kapanlarından koru beni.   
\q1
\v 10 Ben geçip giderken,  
\q2 kötüler hep birlikte kendi ağlarına düşsünler.   
\c 142  
\d David’in Maskili - Mağaradayken ettiği dua  
\q1
\v 1 Sesimle Yahve'ye yakarıyorum.  
\q2 Sesimle Yahve'den merhamet diliyorum.   
\q1
\v 2 Yakınmamı O’nun önünde döküyorum.  
\q2 O’na dertlerimi anlatıyorum.   
\q1
\v 3 Ruhum içimde bunaldığında,  
\q2 sen yolumu bilirsin.  
\q2 Yürüdüğüm yolda,  
\q2 bana tuzak kurdular.   
\q1
\v 4 Sağıma bak da gör,  
\q2 çünkü beni düşünen kimse yok.  
\q2 Sığınacak yer benden kaçtı.  
\q2 Kimse canımı umursamıyor.   
\q1
\v 5 Sana feryat ettim, ey Yahve.  
\q2 “Sen benim sığınağımsın” dedim.  
\q2 “Yaşayanlar diyarından benim payımsın.”   
\q1
\v 6 Feryadımı dinle,  
\q2 çünkü çok çaresizim.  
\q2 Kurtar beni bana zulmedenlerden,  
\q2 çünkü onlar benden güçlüdür.   
\q1
\v 7 Canımı zindandan çıkar da,  
\q2 adına şükredeyim.  
\q2 Doğrular çevremi saracak,  
\q2 çünkü bana iyilik edeceksin.   
\c 143  
\d David’in mezmuru  
\q1
\v 1 Duamı duy, ey Yahve.  
\q2 Dileklerimi dinle.  
\q2 Sadakatin ve doğruluğunla beni rahatlat.   
\q1
\v 2 Hizmetkârınla yargıya girme,  
\q2 çünkü senin önünde  
\q2 yaşayanlardan hiçbiri doğru değildir.   
\q1
\v 3 Çünkü düşman canımın peşinde.  
\q2 Hayatımı yerle bir etti.  
\q2 Çoktan ölmüş olanlar gibi  
\q2 beni karanlık yerlerde yaşattı.   
\q1
\v 4 Bunun için ruhum içimde bunalmış durumda.  
\q2 İçimde yüreğim kimsesiz.   
\q1
\v 5 Eski günleri hatırlıyorum.  
\q2 Yaptıklarının tümü üzerinde derin derin düşünüyorum.  
\q2 Ellerinin işi üzerinde düşünceye dalıyorum.   
\q1
\v 6 Ellerimi sana açıyorum.  
\q2 Kurak toprak gibi canım sana susamış. Selah.   
\q1
\v 7 Bana tez yanıt ver, ey Yahve.  
\q2 Ruhum tükeniyor.  
\q2 Yüzünü benden gizleme,  
\q2 yoksa çukura inenler gibi olurum.   
\q1
\v 8 Sabahleyin sevgi dolu iyiliğini duyur,  
\q2 çünkü sana güveniyorum.  
\q2 Yürümem gereken yolu bana bildir,  
\q2 çünkü canımı sana kaldırıyorum.   
\q1
\v 9 Ey Yahve, kurtar beni düşmanlarımdan.  
\q2 Beni saklaman için sana kaçıyorum.   
\q1
\v 10 İsteğini yapmayı bana öğret,  
\q2 çünkü sen benim Tanrım’sın.  
\q2 Senin Ruh’un iyidir.  
\q2 Doğruluk diyarında bana öncülük et.   
\q1
\v 11 Ey Yahve, adın uğruna beni dirilt.  
\q2 Doğruluğunla canımı sıkıntıdan kurtar.   
\q1
\v 12 Sevgi dolu iyiliğinle düşmanlarımı yok et,  
\q2 canıma eziyet eden herkesi yok et,  
\q2 çünkü ben senin hizmetkârınım.   
\c 144  
\d David’in mezmuru  
\q1
\v 1 Ellerime savaşmayı,  
\q2 parmaklarıma mücadeleyi öğreten  
\q2 kayam Yahve’ye övgüler olsun.   
\q1
\v 2 O’dur sevgi dolu iyiliğim, kalem,  
\q2 yüksek kulem, kurtarıcım,  
\q2 kalkanım ve kendisine sığındığım;  
\q2 halkımı bana boyun eğdiren.   
\q1
\v 3 Ey Yahve, insan nedir ki, ona değer veresin?  
\q2 Ya da insanoğlu nedir ki, onu düşünesin?   
\q1
\v 4 İnsan soluğa benzer.  
\q2 Günleri, geçip giden gölge gibidir.   
\q1
\v 5 Ey Yahve, gökleri yar ve aşağı in.  
\q2 Dağlara dokun da tütsünler.   
\q1
\v 6 Şimşek çaktır, onları dağıt.  
\q2 Oklarını gönder de onları bozguna uğrat.   
\q1
\v 7 Yukarıdan elini uzat,  
\q2 kurtar beni.  
\q2 beni büyük sulardan,  
\q2 yabancıların elinden özgür kıl.   
\q1
\v 8 Ağızları hile söyler,  
\q2 onların sağ eli yalanın sağ elidir.   
\q1
\v 9 Sana yeni bir ezgi söyleyeyim, ey Tanrı.  
\q2 On telli lirle sana ezgiler söyleyeyim.   
\q1
\v 10 Krallara kurtuluş veren,  
\q2 hizmetkârı David'i  
\q2 ölümcül kılıçtan kurtaran sensin.   
\q1
\v 11 Beni kurtar, yabancıların elinden özgür kıl,  
\q2 onların ağızları yalan söyler,  
\q2 onların sağ eli yalanın sağ elidir.   
\q1
\v 12 O zaman oğullarımız iyi yetişmiş fidanlar gibi,  
\q2 kızlarımız sarayın oymalı sütunları gibi olacak.   
\q1
\v 13 Ambarlarımız her türlü erzakla dolu.  
\q2 otlaklarımızda koyunlarımız binlerce,  
\q2 on binlerce yavru verecek.   
\q1
\v 14 Öküzlerimiz bol yük çekecek.  
\q2 Saldırı ve sürgün,  
\q2 sokaklarımızda çığlık olmayacak.   
\q1
\v 15 Ne mutlu bu durumda olan halka.  
\q2 Ne mutlu Tanrısı Yahve olan halka.   
\c 145  
\d David’in övgü mezmuru\f + \fr 145:0 \ft Bu, her dizesi (13. dizenin ikinci yarısı da dahil) İbranice alfabesinin ardışık bir harfiyle başlayan bir akrostiş mezmurdur.\f*  
\q1
\v 1 Seni yücelteceğim, ey Tanrım, ey Kral.  
\q2 Adını daima öveceğim.   
\q1
\v 2 Her gün seni öveceğim.  
\q2 Adını daima yücelteceğim.   
\q1
\v 3 Yahve büyüktür, övgüye çok layıktır!  
\q2 O’nun büyüklüğü keşfedilemez.   
\q1
\v 4 Senin işlerini bir kuşak öbür kuşağa methedecek,  
\q2 kudretli işlerini bildirecek.   
\q1
\v 5 Saygınlığının yüce heybeti,  
\q2 şaşılası işlerinin üzerinde  
\q2 derin derin düşüneceğim.   
\q1
\v 6 İnsanlar müthiş işlerinin gücünden söz edecekler.  
\q2 Senin büyüklüğünü ilan edeceğim.   
\q1
\v 7 Senin büyük iyiliğinin anısını dile getirecekler,  
\q2 doğruluğunu ezgiyle söyleyecekler.   
\q1
\v 8 Yahve lütufkârdır, merhametlidir,  
\q2 yavaş öfkelenir, sevgi dolu iyiliği büyüktür.   
\q1
\v 9 Yahve herkese iyidir.  
\q2 O’nun sevecen merhametleri  
\q2 bütün işlerinin üzerindedir.   
\q1
\v 10 Bütün işlerin sana şükreder, ey Yahve.  
\q2 Kutsalların seni yüceltir.   
\q1
\v 11 Krallığının görkeminden söz eder,  
\q2 gücün hakkında konuşur,   
\q1
\v 12 insanoğlu O’nun güçlü işlerini,  
\q2 krallığının yüce heybetini bilsin diye.   
\q1
\v 13 Senin krallığın sonsuz bir krallıktır.  
\q2 Hakimiyetin tüm kuşaklar boyunca sürer.  
\q2 Yahve bütün sözlerinde sadıktır,  
\q2 tüm işlerinde sevgi doludur.\f + \fr 145:13 \ft Bazı yazmalarda bu son iki satır atlanmıştır.\f*   
\q1
\v 14 Yahve düşen herkese destek olur,  
\q2 eğilenlerin hepsini doğrultur.   
\q1
\v 15 Hepsinin gözleri seni bekler.  
\q2 Onlara yiyeceklerini mevsiminde verirsin.   
\q1
\v 16 Elini açarsın,  
\q2 her canlıyı dilediğince doyurursun.   
\q1
\v 17 Yahve bütün yollarında doğrudur,  
\q2 tüm işlerinde lütufkârdır.   
\q1
\v 18 Yahve kendisini çağıranların hepsine,  
\q2 kendisini içtenlikle çağıran herkese yakındır.   
\q1
\v 19 Kendisinden korkanların dileklerini yerine getirir.  
\q2 Onların feryadını işitir ve onları kurtarır.   
\q1
\v 20 Yahve kendisini seven herkesi korur,  
\q2 ama kötülerin hepsini yok eder.   
\q1
\v 21 Ağzım Yahve’yi över.  
\q2 Bütün canlılar O’nun kutsal adını,  
\q2 daima övsün.   
\c 146  
\q1
\v 1 Yah’ı övün!  
\q2 Ey canım, Yahve’yi öv.   
\q1
\v 2 Yaşadıkça Yahve’yi öveceğim.  
\q2 Var oldukça Tanrım’a ezgiler söyleyeceğim.   
\q1
\v 3 Beylere,  
\q2 kendisinde yardım olmayan  
\q2 insanoğluna güvenmeyin.   
\q1
\v 4 Ruhu ayrılır, kendisi toprağa döner.  
\q2 O gün fikirleri yok olur.   
\q1
\v 5 Ne mutlu yardımcısı Yakov'un Tanrısı olana,  
\q2 umudu Tanrısı Yahve olana:   
\q1
\v 6 O’dur göğü ve yeri,  
\q2 denizi ve içindeki her şeyi yaratan,  
\q2 gerçeği sonsuza dek koruyan,   
\q1
\v 7 Ezilenlere adalet sağlayan,  
\q2 açlara yemek veren.  
\q2 Yahve tutsakları özgür kılar.   
\q1
\v 8 Yahve körlerin gözlerini açar.  
\q2 Yahve eğilmiş olanları doğrultur.  
\q2 Yahve doğruları sever.   
\q1
\v 9 Yahve yabancıları korur.  
\q2 Yetime ve dul kadına destek olur,  
\q2 kötülerin yolunuysa altüst eder.   
\q1
\v 10 Yahve sonsuza dek,  
\q2 ey Siyon, senin Tanrın tüm kuşaklar boyunca  
\q2 hüküm sürecektir.  
\q2 Yah’ı övün!   
\c 147  
\q1
\v 1 Yah’ı övün,  
\q2 çünkü Tanrımız’a ilahiler söylemek iyidir;  
\q2 çünkü O’nu övmek hoş ve yerindedir.   
\q1
\v 2 Yahve Yeruşalem'i bina ediyor.  
\q2 İsrael'in sürgünlerini bir araya topluyor.   
\q1
\v 3 O, kırık yürekleri iyileştirir,  
\q2 yaralarını sarar.   
\q1
\v 4 Yıldızların sayısını sayar.  
\q2 Hepsini adlarıyla çağırır.   
\q1
\v 5 Efendimiz büyüktür, güçte muazzamdır.  
\q2 Anlayışı sonsuzdur.   
\q1
\v 6 Yahve alçakgönüllülere destek olur.  
\q2 Kötüleri yere çalar.   
\q1
\v 7 Yahve’ye şükranla ilahi söyleyin.  
\q2 Arpla, Tanrımız’a ezgiler söyleyin,   
\q1
\v 8 O’dur gökyüzünü bulutlarla kaplayan,  
\q2 yeryüzü için yağmuru hazırlayan,  
\q2 dağlarda ot bitiren.   
\q1
\v 9 O, hayvanlara yiyecek sağlar,  
\q2 bağrışan kuzgun yavrularına.   
\q1
\v 10 Atın gücünden zevk almaz.  
\q2 İnsanın bacaklarından memnun olmaz.   
\q1
\v 11 Yahve kendisinden korkanlardan,  
\q2 sevgi dolu iyiliğine umut bağlayanlardan hoşlanır.   
\q1
\v 12 Ey Yeruşalem, Yahve’yi öv!  
\q2 Ey Siyon, Tanrın’ı yücelt!   
\q1
\v 13 Çünkü kapılarınızın sürgülerini güçlendirdi.  
\q2 İçindeki çocuklarını kutsadı.   
\q1
\v 14 Sınırlarında esenlik sağlar.  
\q2 Seni buğdayın en iyisiyle doyurur.   
\q1
\v 15 Buyruğunu yeryüzüne gönderir.  
\q2 Sözü çok hızlı gider.   
\q1
\v 16 Yapağı gibi kar verir,  
\q2 kırağıyı kül gibi saçar.   
\q1
\v 17 Doluyu çakıl taşları gibi yağdırır.  
\q2 Kim O'nun soğuğuna dayanabilir?   
\q1
\v 18 Sözünü gönderir ve onları eritir.  
\q2 Rüzgârını estirir, sular akar.   
\q1
\v 19 Sözünü Yakov'a,  
\q2 kurallarını ve hükümlerini İsrael'e gösterir.   
\q1
\v 20 Bunu hiçbir ulus için yapmadı.  
\q2 Onlar O’nun hükümlerini bilmezler.  
\q2 Yah’ı övün!   
\c 148  
\q1
\v 1 Yah’ı övün!  
\q2 Yahve'yi göklerden övün!  
\q2 O’nu yücelerde övün!   
\q1
\v 2 O'nu, övün, ey bütün melekleri!  
\q2 O’nu övün, ey bütün ordusu!   
\q1
\v 3 O'nu övün, ey güneş ve ay!  
\q2 O’nu övün, ey bütün parlayan yıldızlar!   
\q1
\v 4 O'nu övün, ey göklerin gökleri,  
\q2 göklerin üstündeki sular.   
\q1
\v 5 Yahve’nin adını övsünler,  
\q2 çünkü O buyurdu ve yaratıldılar.   
\q1
\v 6 Onları sonsuza dek yerleştirdi.  
\q2 Bozulmayacak bir hüküm koydu.   
\q1
\v 7 Yeryüzünden Yahve’yi övün,  
\q2 ey büyük deniz yaratıkları ve tüm derinlikler,   
\q1
\v 8 şimşek ve dolu, kar ve bulutlar,  
\q2 O’nun sözünü yerine getiren kasırga,   
\q1
\v 9 dağlar ve bütün tepeler;  
\q2 meyve ağaçları ve bütün sedirler,   
\q1
\v 10 yabanıl ve evcil bütün hayvanlar,  
\q2 küçük yaratıklar ve uçan kuşlar,   
\q1
\v 11 yeryüzünün kralları ve bütün halklar,  
\q2 beyler ve bütün dünya hakimleri,   
\q1
\v 12 delikanlılar ve genç kızlar,  
\q2 yaşlılar ve çocuklar,   
\q1
\v 13 Yahve’nin adını övsünler,  
\q2 çünkü yalnızca O’nun adı yücedir.  
\q2 O’nun görkemi yeryüzünün ve göklerin üstündedir.   
\q1
\v 14 Halkının boynuzunu yükseltti,  
\q2 tüm kutsallarını,  
\q2 kendisine yakın olan halkı,  
\q2 İsrael’in çocuklarını methettirdi.  
\q2 Yah’ı övün!   
\c 149  
\q1
\v 1 Yahve’yi övün!  
\q2 Yahve'ye yeni bir ezgi söyleyin,  
\q2 kutsallar topluluğunda övgüsünü sunun.   
\q1
\v 2 İsrael kendisini yapanla sevinsin.  
\q2 Siyon çocukları Kralları’yla coşsun.   
\q1
\v 3 Dans ederek O'nun adını övsünler!  
\q2 Tef ve arp çalarak O'nu ilahilerle yüceltsinler!   
\q1
\v 4 Çünkü Yahve halkından hoşlanır.  
\q2 Alçakgönüllüleri kurtuluşla taçlandırır.   
\q1
\v 5 Kutsallar onur içinde sevinsinler.  
\q2 Yataklarında sevinçle ezgi söylesinler.   
\q1
\v 6 Ağızlarında Tanrı'ya yüce övgüler,  
\q2 ellerinde iki ağızlı kılıçla,   
\q1
\v 7 uluslardan öç alsınlar,  
\q2 halkları cezalandırsınlar,   
\q1
\v 8 krallarını zincirlerle,  
\q2 soylularını demir prangalarla bağlasınlar,   
\q1
\v 9 ta ki, yazılı hükmü  
\q2 onlara karşı yerine getirsinler.  
\q2 O'nun bütün kutsalları bu onuru taşır.  
\q1 Yah’ı övün!   
\c 150  
\q1
\v 1 Yah’ı övün!  
\q2 Kutsal yerinde Tanrı’yı övün!  
\q2 Güçlü işleri için O’nu göklerde övün!   
\q1
\v 2 Güçlü işlerinden ötürü O’nu övün!  
\q2 Harika büyüklüğüne yaraşır biçimde  
\q2 O’nu övün!   
\q1
\v 3 Boru çalarak O’nu övün!  
\q2 Arp ve lirle O’nu övün!   
\q1
\v 4 Tefle, dansla O’nu övün!  
\q2 Yaylı çalgılar ve flütle O’nu övün!   
\q1
\v 5 Yüksek ses çıkaran zillerle O'nu övün!  
\q2 Çınlayan zillerle O’nu övün!   
\q1
\v 6 Nefesi olan her şey Yah'ı övsün!  
\q2 Yah’ı övün!   
\m  