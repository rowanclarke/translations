\id JAS
\h يَاعْقُوبْ 
\toc1 يَاعْقُوبْ 
\toc2 يَاعْقُوبْ 
\toc3 يَاع. 
\mt1 يَاعْقُوبْ  
\c 1
\s1 ثَاقدْجبْثْ ن لْ-إِيمَانْ  
\m
\v 1 يَاعْقُوبْ، أَمْسخَّارْ ن أَربِّي ؤُ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، إِ ثنْعَاشْ ن ثْقبَّاڒْ ثِينِّي إِتّْوَازدْجْعنْ جَارْ ڒڭْنُوسْ: ڒهْنَا \add خَاومْ\add*! \x ◘ \xo 1:‏1 \xt ڒخ. 8‏:‏1؛ 1 بُط. 1‏:‏1. \x*   
\b  
\m
\v 2 \add أَ\add* أَيْثْمَا، مَاڒَا أَذْ خَاومْ كّنْ عْڒَامْ كُوڒْ إِجَارِّيبنْ، حسْبمْ مَانْ أَيَا مَارَّا ذ ڒفْرَاحثْ، \x ◘ \xo 1:‏2 \xt مت. 5‏:‏11؛ رُوم. 5‏:‏3؛ 1 بُط. 1‏:‏6. \x*  
\v 3 مَاغَارْ كنِّيوْ ثسّْنمْ بلِّي ثَاقدْجبْثْ ن لْ-إِيمَانْ، أَذْ د-ثجّْ صّْبَارْ نْومْ. \x ◘ \xo 1:‏3 \xt رُوم. 5‏:‏3؛ 1 بُط. 1‏:‏7. \x*  
\v 4 مَاشَا إِتّْخصَّا صّْبَارْ أَذْ إِتّْوَاكمّڒْ، حِيمَا أَذْ ثَاوْضمْ ؤُ أَذْ ثْكمّْڒمْ، ؤُشَا وَارْ كنِّيوْ إِتّْخصِّي وَالُو.   
\m
\v 5 مَاڒَا شَا ن إِجّنْ زَّايْومْ ثقِّيمْ أَسْ عَاذْ ثِيغِيثْ، أَذْ ت إِتَّارْ زِي أَربِّي ونِّي إِتِّيشنْ س ثشْرِيمثْ إِ مَارَّا بْڒَا أَزَاوَارْ، ؤُشَا أَذْ أَسْ ثمّوْشْ. \x ◘ \xo 1:‏5 \xt أَوڒن. 2‏:‏3؛ إِرْم. 29‏:‏12؛ مت. 7‏:‏7؛ 21‏:‏22؛ مك. 11‏:‏24؛ يُوح. 16‏:‏24؛ 1 يُوح. 3‏:‏22؛ 5‏:‏14. \x*  
\v 6 مَاشَا أجّْ إِ-ث أَذْ إِتَّارْ س لْ-إِيمَانْ، بْڒَا أَشكِّي، مِينْزِي ونِّي إِتّْشكَّانْ أَقَا نتَّا أَمْ ڒمْوَاجْ ن ڒبْحَارْ نِّي إِتّْوَاعَارّْننْ زڭْ ؤُسمِّيضْ.  
\v 7 وَارْ تّجِّي أَذْ أَسْ إِتّْغِيڒْ إِ بْنَاذمْ نِّي أَذْ إِكْسِي شَا زِي سِيذِي،  
\v 8 \add مَاغَارْ نتَّا\add* س ثْنَاينْ إِزدْجِيفنْ، وَارْ يَارْسِي ذِي مَارَّا إِبْرِيذنْ نّسْ.   
\b  
\m
\v 9 أجّْ ؤُمَاثْومْ إِوَاضْعنْ أَذْ إِسّمْغَارْ ذِي ڒُوعْڒَا نّسْ،  
\v 10 ؤُ بُو-وَاڭْڒَا ذڭْ ؤُوَاضعْ نّسْ، مِينْزِي أَمْ ثْوَارْذشْثْ ذِي أَرْبِيعْ أَذْ إِفْنَا نتَّا.  
\v 11 مَاغَارْ أَذْ ثنْقَارْ ثْفُوشْثْ س ڒحْمُو نّسْ، أَذْ ثسّشْمضْ أَرْبِيعْ ؤُشَا ثَاوَارْذشْثْ أَذْ ثِيسْڒَاوْ ؤُشَا أَذْ أَسْ إِرَاحْ وَاژْرِي ن وُوذمْ نّسْ. أَمُّو إِ غَا إِفْنَا عَاوذْ بُو-وَاڭْڒَا ذِي \add مَارَّا\add* إِبْرِيذنْ نّسْ. \x ◘ \xo 1:‏11 \xt إِشا. 40‏:‏6، 7؛ 1 كُور. 7‏:‏31؛ يَاع. 4‏:‏14؛ 1 بُط. 1‏:‏24؛ 1 يُوح. 2‏:‏17. \x*   
\m
\v 12 سّعْذْ ن ورْيَازْ نِّي إِ غَا إِحمْڒنْ أَجَارّبْ، مِينْزِي مَاڒَا إِذْوڒْ ذ أَمْقدْجبْ، أَذْ إِطّفْ تَّاجْ ن ثُوذَارْثْ نِّي ثُوغَا إِوَاعْذْ زَّايسْ أَربِّي إِ يِينِّي ث إِتّخْسنْ. \x ◘ \xo 1:‏12 \xt أَيُوبْ 5‏:‏17؛ مت. 10‏:‏22؛ 19‏:‏28، 29؛ 2 تِيم. 4‏:‏8؛ 1 بُط. 5‏:‏4؛ أَسَا. 2‏:‏10. \x*  
\v 13 وَارْ تّجِّي حذْ مَاڒَا إِتّْوَاجَّاربْ، أَذْ يِينِي: ”أَربِّي إِ ذ أَيِي إِتّْجَارَّابنْ!“ أَقَا أَربِّي وَارْ إِزمَّارْ أَذْ إِتّْوَاجَارّبْ زِي ڒْغَارْ ؤُشَا نتَّا س يِيخفْ نّسْ وَارْ إِتّْجَّارِّيبْ ؤُڒَا ذ إِجّْ.  
\v 14 مَاشَا كُوڒْ إِجّْ أَذْ إِتّْوَاغْوَا زِي نّشْوثْ نّسْ ؤُشَا \add نّشْوثْ\add* أَذْ ث ثطّفْ ؤُشَا أَذْ زَّايسْ إِتّْوَاغْوَا.  
\v 15 مَاڒَا نّشْوثْ ثكْسِي س ؤُعذِّيسْ، أَذْ د-ثَارُووْ دّنْبْ، ؤُشَا خْمِي غَا إِمْغَارْ دّنْبْ، أَذْ د-يَاوِي ڒْموْثْ.  
\v 16 \add أَ\add* أَيْثْمَا إِعِيزّنْ، وَارْ تّْودَّارمْ!  
\v 17 كُوڒْ ثَاوْهِيبْثْ ثَاصبْحَانْثْ ذ إِكمّْڒنْ ثْهكّْوَا-د زِي سنّجْ، زِي بَابَاثْسنْثْ ن ثْفَاوِينْ إِ وَارْ غَارْ إِدْجِي ؤُبدّڒْ نِيغْ ثِيڒِي ن دّوْڒَانْ. \x ◘ \xo 1:‏17 \xt أَوڒن. 2‏:‏6؛ إِشا. 14‏:‏27؛ 46‏:‏10؛ مـَال. 3‏:‏6؛ رُوم. 11‏:‏29؛ 1 كُور. 4‏:‏7. \x*  
\v 18 يُوسَا-د أَسْ خْ ڒْخَاضَارْ، مَاحنْذْ أَذْ أَنغْ د-يجّْ س وَاوَاڒْ ن ثِيذتّْ، حِيمَا أَذْ نِيڒِي ذ \add صَّابثْ\add* ثَامزْوَارُوثْ زِي \add مَارَّا\add* مِينْ زَّايسْ د-إِخڒْقنْ. \x ◘ \xo 1:‏18 \xt 1 كُور. 4‏:‏15؛ ڭال. 4‏:‏19؛ 1 بُط. 1‏:‏23. \x*   
\b  
\m  
\s1 أَسْحدْجِي ذ طَّاعثْ إِ وَاوَاڒْ ن أَربِّي  
\m
\v 19 سْنمْ أَيَا، \add أَ\add* أَيْثْمَا إِعِيزّنْ، أجّْ كُوڒْ بْنَاذمْ أَذْ إِقدْجقْ حِيمَا أَذْ إِسڒْ، وَارْ ثْقدْجِيقمْ شَا غَارْ وَاوَاڒْ نِيغْ غَارْ ثفْقحْثْ. \x ◘ \xo 1:‏19 \xt أَوڒن. 17‏:‏27؛ أَمب. 5‏:‏1. \x*  
\v 20 مِينْزِي ثَافْقحْثْ ن ورْيَازْ وَارْ د-ثتِّيوِي شَا ثَاسڭْذَا زَّاثْ إِ أَربِّي.  
\v 21 س ؤُينِّي سّْبعّْذمْ خَاومْ قَاعْ ثَاخْمُوجِي ذ وَاطَّاسْ ن ثُوعفّْنَا، ؤُشَا قبْڒمْ س ثمْهِينْثْ أَوَاڒْ إِ إِتّْوَاژُّونْ ذِي طّْبِيعثْ نّغْ، \add أَوَاڒْ\add* إِ إِزمَّارنْ أَذْ إِسّنْجمْ ڒعْمُورْ نْومْ. \x ◘ \xo 1:‏21 \xt رُوم. 13‏:‏12؛ كُول. 3‏:‏8. \x*   
\m
\v 22 إِڒِيمْ ذ إِنِّي إِتّڭّنْ أَوَاڒْ، وَارْ إِدْجِي ذ إِنِّي إِتّسْڒَانْ وَاهَا، وَارْ شمْثمْ إِخفْ نْومْ! \x ◘ \xo 1:‏22 \xt مت. 7‏:‏21؛ لك. 11‏:‏28؛ رُوم. 2‏:‏13؛ 1 يُوح. 3‏:‏7. \x*  
\v 23 مِينْزِي مَاڒَا إِسْڒَا حذْ إِ وَاوَاڒْ، \add مَاشَا\add* وَارْ زَّايسْ إِڭِّي، أَقَا نتَّا أَمْ يِيجّْ ن ورْيَازْ إِ إِخزَّارنْ ذِي ثِيسِيثْ ذڭْ ؤُغمْبُوبْ نّسْ. \x ◘ \xo 1:‏23 \xt لك. 6‏:‏47.\x*  
\v 24 مِينْزِي إِتّْوَاڒَا إِخفْ نّسْ، إِرُوحْ، ؤُشَا ڒخْذنِّي أَذْ إِتُّو مَامّشْ ثُوغَا إِدْجَا.  
\v 25 مَاشَا ونِّي إِ غَا إِخْزَارنْ ذِي شَّارِيعَا إِكمّْڒنْ ن ثِيڒلِّي ؤُشَا إِقِّيمْ إِخزَّارْ ذَايسْ، وَارْ إِدْجِي أَمْ يِيجّنْ إِتّسْڒَا ڒخْذنِّي إِتّتُّو \add ذغْيَا\add*، مَاشَا أَمْ يِيجّنْ ونِّي ت إِتّڭّنْ س ثِيذتّْ، أَقَا وَانِيثَا ذ أَمِيمُونْ ذِي مِينْ إِتّڭّْ. \x ◘ \xo 1:‏25 \xt مت. 5‏:‏19. \x*   
\m
\v 26 مَاڒَا ذِينْ ونِّي ؤُمِي إِتّْغِيڒْ أَقَا نتَّا إِتّْسخَّارْ إِ أَربِّي أَمْ وَارْ إِحطِّي إِڒسْ نّسْ، مَاشَا إِخدّعْ ؤُڒْ نّسْ، \add خنِّي\add* أَقَا ثَاسخَّارْثْ نّسْ بَاطڒْ. \x ◘ \xo 1:‏26 \xt إِزهد. 34‏:‏14؛ يَاع. 3‏:‏6؛ 1 بُط. 3‏:‏10. \x*  
\v 27 مَاغَارْ ثَاسخَّارْثْ ثَامزْذَاڭْثْ ذ إِقدّْسنْ قِيبَاتْشْ إِ أَربِّي، بَابَاثْنغْ، أَقَا-ث ذ ثَا: أَثْهِيلِي ذڭْ إِيُوجِيڒنْ ذ ثِيجَّاڒْ ذِي ڒْمحْنثْ نْسنْثْ، ؤُ مَاحنْذْ بْنَاذمْ أَذْ إِحيّذْ إِخفْ نّسْ زِي دُّونشْثْ بْڒَا ڒْغشّْ.   
\b  
\b  
\m  
\c 2
\s1 ثَايْرِي بْڒَا إِ غَا نڭّْ س وُوذْمَاونْ  
\m
\v 1 \add أَ\add* أَيْثْمَا، وَارْ تّڭّمْ س وُوذْمَاونْ ذِي لْ-إِيمَانْ إِعُودْجنْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 2:‏1 \xt لَاوِي 19‏:‏15؛ أَعَوذ. 16‏:‏19؛ أَوڒن. 24‏:‏23؛ مت. 22‏:‏16. \x*  
\v 2 مِينْزِي مَاڒَا يُوذفْ-د غَارْ ثْمسْمُونْثْ نْومْ إِجّْ ن ورْيَازْ س ثْخَاذنْثْ ن وُورغْ ؤُ س وَارُّوضْ إِشْنَانْ، \add أَمْ\add* د-يُوذفْ عَاوذْ إِجّْ ن ؤُمزْڒُوضْ س وَارُّوضْ إِخمْجنْ،  
\v 3 \add مَاشَا\add* أَذْ ثوْشمْ ثَايْنِيثْ إِ ونِّي غَارْ إِدْجَا وَارُّوضْ إِشْنَانْ، أَذْ أَسْ ثِينِيمْ: ”أَقَا ذَا إِجّْ ن ومْشَانْ إِصبْحنْ!“، مَاشَا إِ ؤُمزْڒُوضْ أَذْ أَسْ ثِينِيمْ: ”شكْ بدّْ ذِيهَا!“ نِيغْ: ”قِّيمْ زَّاثْ إِ ثْنبْذَاثْ ن إِضَارنْ نّغْ!“،  
\v 4 مَا وَارْ تّمْصُورُّوفمْ \add خنِّي\add* جَارْ أَومْ س إِغمْبَابْ ؤُشَا ثْذوْڒمْ ذ ڒْحُوكَّامْ س إِخَارِّيصنْ إِعفَّاننْ؟   
\m
\v 5 سْڒمْ، \add أَ\add* أَيْثْمَا إِعِيزّنْ، مَا وَارْ دْجِينْ إِمزْڒَاضْ ن دُّونشْثْ-أَ ذ بُو-وَاڭْڒَا ذِي لْ-إِيمَانْ؟ أَقَا إِخْضَارْ-إِ-ثنْ أَربِّي، حِيمَا أَذْ إِڒِينْ ذ إِوْرِيثنْ ن ثْڭلْذِيثْ إِ زَّايسْ إِوَاعْذْ أَربِّي إِ يِينِّي ث إِتّخْسنْ. \x ◘ \xo 2:‏5 \xt ؤُف. 20‏:‏6؛ 1 صم. 2‏:‏30؛ أَوڒن. 8‏:‏17؛ مت. 5‏:‏3؛ يُوح. 7‏:‏48؛ 1 كُور. 1‏:‏26‏-‏29. \x*  
\v 6 مَاشَا كنِّيوْ ثْغطّْرمْ زڭْ إِمزْڒَاضْ! خْزَارْ، مَا وَارْ دْجِينْ ذ إِنِّي س وَاڭْڒَا ذ إِنِّي خَاومْ إِحكّْمنْ ؤُ ذ إِنِّي كنِّيوْ إِندّْهنْ غَارْ ڒْفُوسِينَا؟  
\v 7 خْزَارْ، مَا وَارْ دْجِينْ ذ نِيثْنِي إِنِّي إِتّْشقَّافنْ ذڭْ يِيسمْ إِصبْحنْ ونِّي خَاومْ إِتّْوَاڒَاغَانْ؟  
\v 8 \add مَاشَا\add* مَاڒَا ثْكمّْڒمْ شَّارِيعَا ن أَربِّي ذِي مَانْ أَيَا أَمْ مَامّشْ ثُورَا: ”أَذْ ثخْسذْ جَّارْ نّشْ أَمْ يِيخفْ نّشْ!“، أَقَا ثتّڭّمْ مْلِيحْ، \x ◘ \xo 2:‏8 \xt لَاوِي 19‏:‏18؛ مت. 22‏:‏39؛ مك. 12‏:‏31؛ رُوم. 13‏:‏9؛ ڭال. 5‏:‏14؛ أَفا. 5‏:‏2؛ 1 تس. 4‏:‏9. \x*  
\v 9 مَاشَا مَاڒَا ثڭِّيمْ س وُوذْمَاونْ، أَقَا ثتّڭّمْ دّْنُوبْ ؤُشَا أَذْ ثتّْوَاحكْممْ س شَّارِيعَا أَمْ يِينِّي إِخْضَانْ أَكْ-ذ شَّارِيعَا.   
\m
\v 10 مِينْزِي ونِّي إِضْفَارنْ مَارَّا شَّارِيعَا، مَاشَا يَارْژَا إِشْثْ ن ثوْصيّثْ، أَقَا نتَّا ذ بُو-ؤُمَارْوَاسْ زِي شَّارِيعَا مَارَّا. \x ◘ \xo 2:‏10 \xt أَعَوذ. 27‏:‏26؛ مت. 5‏:‏19؛ ڭال. 3‏:‏10. \x*  
\v 11 مِينْزِي ونِّي إِنَّانْ: ”وَارْ زنِّي!“، إِنَّا عَاوذْ: ”وَارْ نقّْ!“ مَاڒَا وَارْ ثزْنِيذْ، مَاشَا ثنْغِيذْ، أَقَا شكْ ذ أَخطَّايْ ن شَّارِيعَا. \x ◘ \xo 2:‏11 \xt ؤُف. 20‏:‏13، 14؛ أَعَوذ. 5‏:‏17، 18؛ مت. 5‏:‏27. \x*  
\v 12 سِيوْڒمْ ؤُشَا ڭّمْ أَمْ يِينِّي إِ غَا إِتّْوَاحكْمنْ س ثبْرِيذْثْ ن شَّارِيعَا ن ثِيڒلِّي.  
\v 13 مِينْزِي ڒْحُوكْمْ وَارْ يَارحّمْ شَا خْ ونِّي ثُوغَا وَارْ يَارحّْمنْ، مَاشَا س أَرّحْمثْ أَذْ ثِيڒِيمْ ثتّْوَاسُّوعْڒَامْ خْ ڒْحُوكْمْ. \x ◘ \xo 2:‏13 \xt مت. 6‏:‏15؛ 18‏:‏35؛ مك. 11‏:‏25؛ لك. 16‏:‏25. \x*   
\b  
\m  
\s1 لْ‘إِمَانْ ذ ڒخْذَايمْ  
\m
\v 14 \add أَ\add* أَيْثْمَا، مَانْ ڒفْضڒْ مَاڒَا إِجّنْ إِقَّارْ: ”نشّْ أَقَا أَيِي غَارِي لْ-إِيمَانْ!“، \add مَاشَا\add* نتَّا وَارْ غَارسْ بُو ڒخْذَايمْ؟ مَا إِزمَّارْ لْ-إِيمَانْ نّسْ أَذْ ث إِسّنْجمْ؟ \x ◘ \xo 2:‏14 \xt مت. 7‏:‏26؛ يَاع. 1‏:‏23. \x*  
\v 15 مَاڒَا إِتّْخصَّا أَسْ إِ يِيجّْ ن ثوْمَاثْ نِيغْ إِ يِيشْثْ ن ثْوتْشْمَاثْ مِينْ غَا يَارْضنْ نِيغْ مِينْ غَا شّنْ كُوڒْ أَسّْ، \x ◘ \xo 2:‏15 \xt لك. 3‏:‏11؛ 1 يُوح. 3‏:‏17. \x*  
\v 16 ؤُشَا إِجّنْ زَّايْومْ أَذْ أَسنْ يِينِي: ”ؤُيُورمْ ذِي ڒهْنَا، أَرْضمْ مِينْ إِسّحْمَانْ، جِّيوْنمْ مَاشَّا!“، مَاشَا وَارْ ذ أَسنْ إِوْشِي وَالُو مِينْ إِتّْخصَّانْ إِ أَرِّيمثْ، مَانْ نّْفَاعْ؟  
\v 17 أَقَا أَمُّو ؤُڒَا ذ لْ-إِيمَانْ بْڒَا ڒخْذَايمْ، أَقَا إِمُّوثْ س إِخفْ نّسْ.   
\m
\v 18 مَاڒَا أَذْ أَشْ إِنَّا إِجّنْ: ”شكْ غَاركْ لْ-إِيمَانْ، نشّْ غَارِي ڒخْذَايمْ!“ سْشنْ أَيِي لْ-إِيمَانْ نّشْ بْڒَا ڒخْذَايمْ ؤُشَا نشّْ أَذْ أَشْ سّشْنغْ لْ-إِيمَانْ إِنُو زِي ڒخْذَايمْ إِنُو!  
\v 19 مَا شكْ ثُومْنذْ بلِّي أَربِّي ذ إِجّنْ؟ أَقَا ثڭِّيذْ مْلِيحْ. ؤُڒَا ذ شّْوَاطنْ ؤُمْننْ ذِي مَانْ أَيَا ؤُشَا تَّارْجِيجنْ.  
\v 20 مَا ثخْسذْ أَذْ ثسّْنذْ، \add أَ\add* بْنَاذمْ إِضعْفنْ، بلِّي لْ-إِيمَانْ بْڒَا ڒخْذَايمْ إِمُّوثْ؟  
\v 21 مَا وَارْ إِتّْوَاسڭّذْ جذِّيثْنغْ إِبْرَاهِيمْ زِي ڒخْذَايمْ ؤُمِي إِكَّارْ أَذْ إِغَارْصْ إِ مِّيسْ إِسْحَاقْ خْ ؤُعَالْطَارْ؟ \x ◘ \xo 2:‏21 \xt أَمز. 22‏:‏10. \x*  
\v 22 أَقَا ثژْرِيمْ بلِّي لْ-إِيمَانْ نّسْ ثُوغَا إِخْذمْ أَكْ-ذ ڒخْذَايمْ نّسْ، ؤُشَا لْ-إِيمَانْ إِتّْوَاكمّڒْ س ڒخْذَايمْ.  
\v 23 أَمُّو إِتّْوَاكمّڒْ \add وَاوَاڒْ ن\add* ثِيرَا \add إِقدّْسنْ\add* إِ إِقَّارنْ: ”إِبْرَاهِيمْ يُومنْ ذِي أَربِّي ؤُشَا إِتّْوَاحْسبْ أَسْ-ث-إِ-د ذ ثَاسڭْذَا!“، ؤُشَا ڒَاغَانْ أَسْ ’أَمدُّوكَّاڒْ ن أَربِّي‘. \x ◘ \xo 2:‏23 \xt أَمز. 15‏:‏6؛ رُوم. 4‏:‏3؛ ڭال. 3‏:‏6. \x*   
\m
\v 24 ثتّْوَاڒَامْ \add خنِّي\add*، بلِّي بْنَاذمْ إِتّْوَاسڭّذْ زِي ڒخْذَايمْ، وَارْ إِدْجِي زِي لْ-إِيمَانْ وَاهَا.   
\m
\v 25 مَا وَارْ ثُوغِي رَاحَابْ، ثَامْغَارْثْ ن فَارْقْ-شّْغڒْ، ثتّْوَاسڭّذْ أَمُّو زِي ڒخْذَايمْ ؤُمِي ثَارحّبْ زڭْ إِبرْڭَاڭنْ، ثسُّوفّغْ إِ-ثنْ زڭْ وبْرِيذْ نّغْنِي؟ \x ◘ \xo 2:‏25 \xt ياش. 2‏:‏1؛ 6‏:‏23؛ عبر. 11‏:‏31. \x*  
\v 26 \add س ؤُيَا،\add* أَمْ أَرِّيمثْ بْڒَا بُوحْبڒْ ثمُّوثْ، أَمُّو ؤُڒَا ذ لْ-إِيمَانْ بْڒَا ڒخْذَايمْ إِمُّوثْ.   
\b  
\b  
\m  
\c 3
\s1 إِڒسْ ن بْنَاذمْ  
\m
\v 1 وَارْ تّجِّيمْ أَطَّاسْ زَّايْومْ أَذْ ذوْڒنْ ذ إِمسْغَارنْ، \add أَ\add* أَيْثْمَا، أَقَا كنِّيوْ ثسّْنمْ بلِّي أَذْ نكْسِي ڒْحُوكْمْ أَمقّْرَانْ. \x ◘ \xo 3:‏1 \xt مت. 7‏:‏1؛ 23‏:‏8؛ لك. 6‏:‏37. \x*  
\v 2 مِينْزِي مَارَّا نشِّينْ ننّذْرفْ ذڭْ وَاطَّاسْ. \add مَاڒَا\add* شَا ن يِيجّنْ وَارْ إِتّْنذْرَافْ ذڭْ وَاوَاڒْ، أَقَا نتَّا ذ بْنَاذمْ إِكْمڒْ، إِزمَّارْ أَذْ إِقمّعْ مَارَّا أَرِّيمثْ \add نّسْ\add*. \x ◘ \xo 3:‏2 \xt إِزهد. 34‏:‏14؛ يَاع. 1‏:‏26. \x*  
\v 3 خْزَارْ، نتّڭّْ سْڒِيمَاثْ ذڭْ إِقمُّومنْ ن إِيْسَانْ حِيمَا أَذْ أَنغْ مَّارْسنْ، أَقَا نْزمَّارْ أَذْ \add زَّايْسنْثْ\add* نسُّويُورْ أَرِّيمثْ نْسنْ ثْمُونْ.   
\m
\v 4 \add ؤُڒَا ذ\add* إِغَارُّوبَا إِمقّْرَاننْ إِنِّي إِتّْوَاعَارّْننْ زڭْ ؤُسمِّيضْ إِجهْذنْ، تّْوَاندّْهنْ س يِيجّْ ن ڒْڭِيذُونْ أَمژْيَانْ، مَانِي مَا إِخْسْ ڒْخَاضَارْ ن ڒْقبْطَانْ \add أَذْ إِنْذهْ\add*.  
\v 5 أَمُّو ؤُڒَا ذ إِڒسْ، أَقَا-ث ذ إِجّْ ن إِخفْ أَمژْيَانْ، \add وَاخَّا أَمنِّي\add* إِسّْڭعّذْ إِخفْ نّسْ. خْزَارْ، مَامّشْ ثِيمسِّي ثَامژْيَانْثْ أَذْ ثسّشْمضْ ڒْغَابثْ ثَامقّْرَانْثْ. \x ◘ \xo 3:‏5 \xt أَوڒن. 12‏:‏18؛ 15‏:‏2. \x*  
\v 6 إِڒسْ ذ إِشْثْ ن ثْمسِّي ؤُ دُّونشْثْ ن دّنْبْ أَمْ يِيشْثْ ن وزْغَارْ. إِڒسْ-أَ جَارْ إِغزْذِيسنْ نّغْ أَمْ يِيشْثْ ن ڒْحَاجّثْ ثسّخْمجْ أَرِّيمثْ مَارَّا، إِسَّارْغْ جِّيڒَاثْ إِ إِضفَّارنْ إِجّْ إِ ونّغْنِي، إِنِّي إِقْنُونِّيينْ أَمْ ثْجَارَّارِينْ. ؤُشَا \add ؤُڒَا ذ يِيڒسْ س يِيخفْ نّسْ\add* أَقَا إِتّْوَاسَّارغْ س ثْمسِّي.  
\v 7 مِينْزِي مَارَّا دَّارْبْ ن ڒْمَاڒْ، ن إِجْضَاضْ ؤُ ن إِمُودَّارنْ إِنِّي إِتّْبُوعنْ ذِي ڒبْحَارْ ؤُ خْ ثمُّورْثْ، تّْوَامَارْسنْ إِ طّْبِيعثْ ن بْنَاذمْ. \f ◼ \fr 3:‏7 \ft \+bd ’إِمُودَّارنْ‘\+bd* - نِيغْ ’لْحَايَاوَانَاثْ‘.\f*  
\v 8 مَاشَا إِڒسْ وَارْ إِزمَّارْ أَذْ ث إِسّْقمّعْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ. أَقَا-ث ذ إِجّْ ن ڒْغَارْ إِ وَارْ إِتّْوَاسّْقمّْعنْ، أَقَا إِشُّورْ س سّمْ إِنقّنْ.  
\v 9 زَّايسْ إِ نْبَاركْ سِيذِي ذ بَابَاثْنغْ ؤُشَا زَّايسْ ننعّڒْ خْ إِوْذَانْ إِنِّي إِتّْوَاڭّنْ ذِي صِّيفثْ ن أَربِّي.  
\v 10 أَقَا زڭْ إِجّْ ن ؤُقمُّومْ ثتّفّغْ-د لْبَارَاكَا ذ نّعْڒثْ. \add أَ\add* أَيْثْمَا، مَانْ أَيَا وَارْ إِعدّڒْ أَذْ يِيڒِي أَمُّو!  
\v 11 مَا إِزمَّارْ أَذْ د-فّْغنْ زڭْ إِجّْ ن ڒْعُونْصَارْ \add وَامَانْ\add* إِمِيژِيذنْ ذ \add وَامَانْ\add* إِمرْزَاڭنْ؟  
\v 12 \add أَ\add* أَيْثْمَا، مَا إِزمَّارْ وَارْثُو أَذْ إِوْشْ زِّيثُونْ نِيغْ ثْزَايَارْثْ ڒْبَاشُورْ؟ أَمُّو ؤُڒَا ذ أَمَانْ إِمدْجَاحنْ وَارْ زمَّارنْ أَذْ ثنْ أَرّنْ ذ إِمِيژِيذنْ.   
\b  
\m  
\s1 ثِيغِيثْ زِي سنّجْ ذ ثِيغِيثْ زِي ثمُّورْثْ  
\m
\v 13 وِي زَّايْومْ إِدْجَانْ ذ أَمِيغِيسْ ؤُ س ڒعْقڒْ؟ أَذْ إِسّْشنْ وَانِيثَا ڒخْذَايمْ نّسْ زِي ثِيشْڒِي نّسْ إِصبْحنْ س ثِيغِيثْ أَكْ-ذ ثمْهِينْثْ. \x ◘ \xo 3:‏13 \xt أَفا. 5‏:‏8. \x*  
\v 14 مَاشَا مَاڒَا ذِينْ ڒحْسذْ أَمرْزَاڭْ ذ ؤُمْشُوبّشْ ذڭْ وُوڒَاونْ نْومْ، وَارْ سْڭِيعِّيذْ إِخفْ نّشْ خْ ثِيذتّْ ؤُ وَارْ سْخَارِّيقْ شَا! \x ◘ \xo 3:‏14 \xt رُوم. 13‏:‏13. \x*  
\v 15 ثَانِيثَا وَارْ ثدْجِي ذ ثِيغِيثْ إِ د-إِهْوَانْ زِي سنّجْ، أَقَا-ت زِي ثمُّورْثْ، زڭْ إِخَارِّيصنْ ن بُوحْبڒْ ن بْنَاذمْ ؤُ زِي شّْوَاطنْ. \x ◘ \xo 3:‏15 \xt 1 كُور. 2‏:‏6، 7. \x*  
\v 16 مِينْزِي مَانِي إِدْجَا ڒحْسذْ ذ ؤُمْشُوبّشْ، أَقَا ذِينْ إِخَارْوِيضنْ ذ \add عْڒَامْ\add* كُوڒْ ثُوعفّْنَا. \x ◘ \xo 3:‏16 \xt 1 كُور. 3‏:‏3؛ ڭال. 5‏:‏20. \x*  
\v 17 مَاشَا ثِيغِيثْ زِي سنّجْ ثزْذڭْ، خنِّي ذَايسْ ڒهْنَا ذ ڒضْرَافثْ، ثتّڭّْ أَرَّايْ، ثشُّورْ س أَرّحْمثْ ذ ڒْغِيدْجثْ إِصبْحنْ، وَارْ تّڭّْ شَا س ڒحْزَابْ نِيغْ س وُوذْمَاونْ.  
\v 18 \add مَاشَا\add* ڒْغِيدْجثْ ن ثْسڭْذَا ثتّْوَازَارّعْ ذِي ڒْهُوذْنثْ زڭْ يِينِّي إِتّڭّنْ ڒهْنَا.   
\b  
\b  
\m  
\c 4
\s1 أَوَاضعْ زَّاثْ إِ أَربِّي  
\m
\v 1 مَانِيسْ د-إِكَّا ؤُمنْغِي ذ إِمْشُوبّشنْ جَارْ أَومْ؟ مَا زعْمَا زڭْ شّهْوَاثْ إِ إِمّنْغنْ ذڭْ إِغزْذِيسنْ نْومْ؟ \x ◘ \xo 4:‏1 \xt رُوم. 7‏:‏23؛ 1 بُط. 2‏:‏11. \x*  
\v 2 كنِّيوْ ثمّژْرمْ \add مَاشَا\add* كنِّيوْ وَارْ غَارْومْ وَالُو. كنِّيوْ ثْنقّمْ ؤُ ثتَّاسْممْ ؤُشَا قَاعْ أَمنِّي وَارْ د أَومْ إِتِّيكّْوِيضْ وَالُو. كنِّيوْ ثتّمْشُوبُّوشمْ ؤُ ثتّْمنْغَامْ، مَاشَا وَارْ غَارْومْ وَالُو، مِينْزِي كنِّيوْ وَارْ ثتّتَّارَامْ.  
\v 3 \add نِيغْ\add* كنِّيوْ ثتّتَّارَامْ، مَاشَا وَارْ ثكْسِيمْ شَا، مِينْزِي ثتّتَّارمْ مِينْ وَارْ إِحْڒِينْ، حِيمَا أَذْ ثڭّمْ غَارْ شّهْوَاثْ نْومْ. \x ◘ \xo 4:‏3 \xt مت. 20‏:‏22؛ رُوم. 8‏:‏26. \x*  
\v 4 \add أَ كنِّيوْ\add* إِنِّي إِزنَّانْ! مَا وَارْ ثسِّينمْ شَا بلِّي ثَامخْسِيوْثْ ن دُّونشْثْ أَقَا-ت ذ ڒعْذَاوثْ خْ أَربِّي؟ أَحقَّا ونِّي إِتّخْسنْ أَذْ يِيڒِي ذ أَمدُّوكّڒْ ن دُّونشْثْ، أَذْ يِيڒِي ذ ڒعْذُو ن أَربِّي. \x ◘ \xo 4:‏4 \xt يُوح. 15‏:‏9؛ ڭال. 1‏:‏10؛ 1 يُوح. 2‏:‏15. \x*  
\v 5 نِيغْ إِتّْغِيڒْ أَومْ بلِّي ثِيرَا \add إِقدّْسنْ\add* وَارْ غَارْسنْثْ لْمعْنَا:  
\b  
\m \qt ”أَرُّوحْ إِ ذَايْنغْ إِزدّْغنْ\qt*  
\m \qt إِتَّاسمْ س ثُوسْمِي!“؟\qt* \x ◘ \xo 4:‏5 \xt ڒخْڒ. 11‏:‏29. \x*   
\b  
\m
\v 6 مَاشَا سِيذِيثْنغْ إِتِّيشْ أَنغْ أَرْضَا كْثَارْ، مَاغَارْ إِنَّا:  
\b  
\m \qt ”أَربِّي إِسّْوَاضّعْ إِمْعفَّارنْ،\qt*  
\m \qt مَاشَا إِ إِمْوَاضْعنْ إِتِّيشْ أَسنْ أَرْضَا.“\qt* \x ◘ \xo 4:‏6 \xt أَوڒن. 3‏:‏34؛ 1 بُط. 5‏:‏5. \x*   
\b  
\m
\v 7 س ؤُيَا مَارْسمْ إِخفْ نْومْ زَّاثْ إِ أَربِّي، مْعَاڒَامْ أَكْ-ذ شِّيطَانْ ؤُشَا نتَّا أَذْ زَّايْومْ يَارْوڒْ. \x ◘ \xo 4:‏7 \xt أَفا. 4‏:‏27؛ 1 بُط. 5‏:‏9. \x*  
\v 8 أَذْسمْ أَربِّي ؤُشَا نتَّا أَذْ كنِّيوْ د-يَاذسْ. سِيرْذمْ إِفَاسّنْ نْومْ، \add أَ\add* إِمذْنَابْ، قدّْسمْ ؤُڒَاونْ نْومْ، \add أَ كنِّيوْ\add*، إِنِّي غَارْ إِدْجَا ثْنَاينْ ن إِزدْجِيفنْ.  
\v 9 مَارْسمْ إِخفْ نْومْ، شضْنمْ! جّمْ ثَاضحَّاشْثْ نْومْ أَذْ ثذْوڒْ ذ أَشْضَانْ ؤُ ڒفْرَاحثْ نْومْ أَذْ ثذْوڒْ ذ ڒحْزنْ. \x ◘ \xo 4:‏9 \xt مت. 5‏:‏4. \x*  
\v 10 مَارْسمْ إِخفْ نْومْ زَّاثْ إِ سِيذِي ؤُشَا نتَّا أَذْ كنِّيوْ إِسّْعُودْجْ. \x ◘ \xo 4:‏10 \xt أَيُوبْ 22‏:‏29؛ أَوڒن. 29‏:‏23؛ مت. 23‏:‏12؛ لك. 14‏:‏11؛ 18‏:‏14؛ 1 بُط. 5‏:‏6. \x*   
\m
\v 11 \add أَ\add* أَيْثْمَا، وَارْ تّْشقَّافمْ شَا ذڭْ وَايَاوْيَا! ونِّي إِشقَّافنْ ذڭْ ؤُمَاسْ نِيغْ إِحكّمْ خْ ؤُمَاسْ، أَقَا وَا إِتّْشقَّافْ ذِي شَّارِيعَا ؤُشَا إِحكّمْ خْ شَّارِيعَا. ؤُشَا مَاڒَا ثْحكْمذْ خْ شَّارِيعَا، أَقَا وَارْ ثدْجِيذْ شَا ذ ونِّي إِتّڭّنْ شَّارِيعَا، مَاشَا \add ثَارِّيذْ إِخفْ نّشْ\add* ذ ڒْقَاضِي \add ن شَّارِيعَا\add*.  
\v 12 إِجّنْ وَاهَا إِ إِدْجَانْ ذ بَابْ ن شَّارِيعَا، نتَّا ذ ونِّي غَارْ ثدْجَا ثْزمَّارْ، حِيمَا أَذْ إِوْشْ ثُوذَارْثْ نِيغْ أَذْ ت يَاريّبْ. مَاشَا مِينْ ثعْنِيذْ شكْ ؤُمِي ثْحكّْمذْ خْ جَّارْ نْومْ؟   
\m
\v 13 مَا خنِّي إِ غَا نِينِي خْ يِينِّي إِقَّارنْ: ”أَسّْ-أَ نِيغْ ثِيوشَّا أَذْ نْرَاحْ غَارْ ثنْذِينْثْ-أَ غَارْ ثنْذِينْثْ-إِنْ، أَذْ ذِينْ نڭّْ ثَاسبَّابْثْ ڒْمِيجَاڒْ ن إِجّْ ن ؤُسڭّْوَاسْ، أَذْ نْسغْ أَذْ نزّنْزْ أَذْ نَارْبحْ!“؟ \x ◘ \xo 4:‏13 \xt لك. 12‏:‏18. \x*  
\v 14 نِيثْنِي وَارْ سِّيننْ مَامّشْ غَا ثِيڒِي ثِيوشَّا. مِينْ ثعْنَا ثُوذَارْثْ نّغْ؟ أَقَا-ت مْغِيرْ ذ إِجّْ ن ڒفْوَارْ إِ غَا د-إِضْهَارْ، أَذْ إِذُورّقْ، أَذْ ثفْسِي ڒخْذنِّي. \x ◘ \xo 4:‏14 \xt إِشا. 40‏:‏6؛ 1 كُور. 7‏:‏31؛ يَاع. 1‏:‏10؛ 1 بُط. 1‏:‏24؛ 1 يُوح. 2‏:‏17. \x*  
\v 15 س ؤُيَا إِتّْخصَّا أَذْ إِنِينْ: ”مَاڒَا إِخْسْ سِيذِي، أَذْ ندَّارْ، أَذْ نڭّْ ثَا ذ ثِينْ.“ \x ◘ \xo 4:‏15 \xt ڒخ. 18‏:‏21؛ 1 كُور. 4‏:‏19؛ عبر. 6‏:‏3. \x*  
\v 16 إِوَا نِيثْنِي تّْفيّْشنْ ذڭْ ؤُعفَّارْ نْسنْ، مَاشَا قَاعْ أَفيّشْ-أَ ذ أَعفَّانْ.  
\v 17 ونِّي إِسّْننْ مَامّشْ إِ غَا إِڭّْ ڒْخَارْ ؤُشَا وَارْ ث إِتّڭّْ، أَذْ أَسْ د-إِتّْوَاحْسبْ ذ دّنْبْ. \x ◘ \xo 4:‏17 \xt لك. 12‏:‏47. \x*   
\b  
\b  
\m  
\c 5
\s1 أَعْڒَامْ غَارْ أَيْثْبَابْ ن وَاڭْڒَا  
\m
\v 1 إِوَا كنِّيوْ، \add أَ\add* أَيْثْبَابْ ن وَاڭْڒَا، سْحِيسّْفمْ، رُومْ إِ لْمُوصِيبَاثْ إِ كنِّيوْ إِتّْرَاجَانْ. \x ◘ \xo 5:‏1 \xt أَوڒن. 11‏:‏28؛ عَام. 6‏:‏1؛ لك. 6‏:‏24؛ 1 تِيم. 6‏:‏9. \x*  
\v 2 مِينْزِي أَڭْڒَا نْومْ أَقَا إِغُومّْ، يَارْصُوضْ، ؤُشَا أَرُّوضْ نْومْ شِّينْ ث ثْشِينْذَا،  
\v 3 ؤُرغْ نْومْ ذ نُّوقَارْثْ نْومْ أَقَا أَرْشَانْ ؤُشَا أَرشِّي نْسنْ أَذْ خَاومْ ثشْهذْ، أَذْ إِشّْ دَّاثْ نْومْ أَمْ ثْمسِّي. أَقَا كنِّيوْ ثيْرُومْ ثِيمسِّي إِ يِيخفْ نْومْ إِ وُوسَّانْ إِنڭُّورَا. \x ◘ \xo 5:‏3 \xt مت. 6‏:‏19؛ رُوم. 2‏:‏5. \x*  
\v 4 خْزَارْ، ڒْمُونثْ ن إِشوَّاڒنْ نِّي ثسّْعِيزّمْ خْ ينِّي إِمْجَارنْ إِيَّارنْ نْومْ ثسْغُويُّو، ؤُشَا ثْغُويِّيثْ ن يِينِّي إِمْجَارنْ ثِيوضْ أَسْ-د أَڒْ إِمزُّوغنْ ن سِيذِي ن ڒْعسْكَارَاثْ. \x ◘ \xo 5:‏4 \xt لَاوِي 19‏:‏13؛ أَعَوذ. 24‏:‏14. \x*  
\v 5 أَقَا كنِّيوْ ثْفيّْشمْ خْ ثمُّورْثْ، ثضْفَارمْ مژْرِي نْومْ. أَقَا ثسّْجِيوْنمْ أَرِّيمَاثْ نْومْ أَمْ ذڭْ وَاسّْ ن ثْغَارْصِيثْ. \x ◘ \xo 5:‏5 \xt أَيُوبْ 21‏:‏13؛ لك. 16‏:‏19، 25. \x*  
\v 6 أَقَا كنِّيوْ ثْحكْممْ خْ ؤُمْسڭَّاذْ س ڒْموْثْ، \add أَمْ\add* نتَّا وَارْ خَاومْ إِمّْعَاڒَا شَا.   
\b  
\m  
\s1 ضّْبَارْ ذِي ثَامَارَا ؤُ ذڭْ ؤُودّبْ  
\m
\v 7 مَاشَا كنِّيوْ، \add أَ\add* أَيْثْمَا، صْبَارمْ أَڒْ د غَا يَاسْ سِيذِي، أَمْ مَامّشْ إِتّْرَاجَا ؤُفدْجَاحْ غَارْ ڒْغِيدْجثْ إِغْڒَانْ \add ن ثمُّورْثْ\add*، إِصْبَارْ س ڒْخَاضَارْ أَڒْ خَاسْ إِوّثْ ونْژَارْ ن زِيشْ ذ ؤُنڭَّارْ.  
\v 8 ؤُڒَا ذ كنِّيوْ، صْبَارمْ، سْمحّْذمْ ؤُڒَاونْ نْومْ، أَقَا ثَاوَاسِيثْ ن سِيذِيثْنغْ ثُوذسْ-د.  
\v 9 \add أَ\add* أَيْثْمَا، وَارْ ثْسُوضمْ خْ وَايَاوْيَا، حِيمَا وَارْ غَارْومْ د-إِتِّيكّْوِيضْ ڒْحُوكْمْ. مَاغَارْ خْزَارْ، ڒْقَاضِي إِبدّْ غَارْ ثوَّارْثْ.  
\v 10 \add أَ\add* أَيْثْمَا، مْقُودَّامْ أَكْ-ذ إِنَابِييّنْ إِنِّي ثُوغَا إِسِّيوْڒنْ س يِيسمْ ن سِيذِي مَاحنْذْ أَذْ ثصْبَارمْ ذِي ڒحْصَارَاثْ نْومْ.  
\v 11 خْزَارمْ، أَذْ نْبَاركْ إِنِّي إِتّْصبَّارنْ. أَقَا كنِّيوْ ثسْڒَامْ خْ صّْبَارْ ن أَيُوبْ ؤُشَا ثْوَاڒَامْ ڒْغِيدْجثْ ثنِّي ذ أَسْ إِڭَّا سِيذِي، مَاغَارْ سِيذِي ذ أَرْحِيمْ ذ أَحْنِينْ. \x ◘ \xo 5:‏11 \xt ڒخْڒ. 14‏:‏18؛ أَيُوبْ 1‏:‏21، 22؛ إِزهد. 103‏:‏8؛ مت. 5‏:‏11. \x*   
\b  
\m  
\s1 طِيوصَّا ثِينڭُّورَا  
\m
\v 12 أَمزْوَارُو ن مَارَّا، \add أَ\add* أَيْثْمَا، وَارْ تّْجَادْجَامْ شَا، ڒَا غَارْ ؤُجنَّا ڒَا غَارْ ثمُّورْثْ ؤُشَا ؤُڒَا ذ إِشْثْ ن ثْجَادْجِيثْ نّغْنِي. أَذْ غَارْومْ يِيڒِي ’وَاهْ!‘ نْومْ ذ ’وَاهْ!‘، ذ ’لَّ!‘ نْومْ ذ ’لَّ!‘، نِيغْ أَقَا أَذْ ثِيڒِيمْ سَاذُو ڒْحُوكْمْ. \x ◘ \xo 5:‏12 \xt مت. 5‏:‏34؛ 2 كُور. 1‏:‏17، 18. \x*   
\m
\v 13 مَا أَقَا \add ذِينْ\add* شَا ن إِجّنْ جَارْ أَومْ إِودّبْ؟ أجّْ إِ-ث أَذْ إِتَّارْ. مَا أَقَا \add ذِينْ\add* شَا ن إِجّنْ إِفَارْحْ؟ أجّْ إِ-ث أَذْ إِغنّجْ س إِزْڒَانْ ن ؤُصبّحْ. \x ◘ \xo 5:‏13 \xt أَفا. 5‏:‏19؛ كُول. 3‏:‏16. \x*  
\v 14 مَا ذِينْ جَارْ أَومْ حذْ إِهْڒشْ؟ أجّْ إِ-ث أَذْ د-إِڒَاغَا خْ إِمْغَارنْ ن ثْمسْمُونْثْ \add غَارسْ\add*، حِيمَا أَذْ أَسْ كْسِينْ س ڒْمعْرُوفْ، أَذْ ث رثْفنْ س زّشْثْ ن وذْهَانْ س يِيسمْ ن سِيذِيثْنغْ. \x ◘ \xo 5:‏14 \xt لَاوِي 14‏:‏17، 18؛ مك. 6‏:‏13.\x*  
\v 15 ؤُشَا ثَاژَادْجِيثْ ن لْ-إِيمَانْ أَذْ ثسّْڭنْفَا أَمهْڒُوشْ ؤُشَا سِيذِيثْنغْ أَذْ ث إِسّْنكَّارْ. ؤُشَا مَاڒَا ثُوغَا إِتّڭّْ دّْنُوبْ، أَذْ أَسْ تّْوَاغْفَارنْ.  
\v 16 نعْممْ إِجّْ إِ ونّغْنِي س إِعذِييّنْ نْومْ ؤُ ژَتدْجمْ إِ وَايَاوْيَا، حِيمَا أَذْ ثتّْوَاسّْڭنْفَامْ، مَاغَارْ جّهْذْ ن ثْژَادْجِيثْ ن ؤُمْسڭَّاذْ أَقَا-ث ذ أَمقّْرَانْ.   
\m
\v 17 إِلِييَا ثُوغَا ذ بْنَاذمْ إِتَّاشَا أَمْ نشِّينْ. إِژُّودْجْ حِيمَا وَارْ إِشِّيثْ ونْژَارْ خْ ثمُّورْثْ. \add خنِّي أَنْژَارْ\add* وَارْ إِوْثِي شَا خْ ثمُّورْثْ ثْڒَاثَا ن إِسڭّْوُوسَا ذ ستَّا ن إِيُورنْ. \x ◘ \xo 5:‏17 \xt 1 إِج. 17‏:‏1؛ لك. 4‏:‏25. \x*  
\v 18 ؤُشَا ثُوغَا إِژُّودْجْ عَاوذْ، ڒخْذنِّي أَجنَّا إِوْثَا أَنْژَارْ ؤُشَا ثَامُّورْثْ ثوْشَا صَّابثْ نّسْ. \x ◘ \xo 5:‏18 \xt 1 إِج. 18‏:‏45. \x*   
\m
\v 19 \add أَ\add* أَيْثْمَا، مَاڒَا ذِينْ حذْ جَارْ أَومْ إِفّغْ خْ وبْرِيذْ ن ثِيذتّْ ؤُشَا شَا ن يِيجّنْ يَارّْ إِ-ث-إِ-د أَذْ د-إِذْوڒْ زڭْ ؤُودَّارْ نّسْ، \x ◘ \xo 5:‏19 \xt مت. 18‏:‏15. \x*  
\v 20 أجّْ إِ-ث أَذْ إِسّنْ، أَقَا ونِّي د غَا يَارّنْ أَمذْنُوبْ زڭْ ؤُودَّارْ نّسْ، أَذْ إِسّنْجمْ ڒعْمَارْ زِي ڒْموْثْ ؤُشَا أَذْ إِسّْذُورِييْ أَطَّاسْ ن دّْنُوبْ. \x ◘ \xo 5:‏20 \xt أَوڒن. 10‏:‏12؛ 1 بُط. 4‏:‏8. \x*   