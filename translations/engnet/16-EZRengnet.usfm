\v 12  \w But|strong="H3861"\w* \w after|strong="H4481"\w* \w our|strong="H4481"\w* ancestors \w angered|strong="H7265"\w* \w the|strong="H4481"\w* God \w of|strong="H4481"\w* \w heaven|strong="H8065"\w*, \w he|strong="H1768"\w* \w delivered|strong="H3052"\w* \w them|strong="H1994"\w* \w into|strong="H1541"\w* \w the|strong="H4481"\w* \w hands|strong="H3028"\w* \w of|strong="H4481"\w* \w King|strong="H4430"\w* \w Nebuchadnezzar|strong="H5020"\w* \w of|strong="H4481"\w* Babylon, \w the|strong="H4481"\w* \w Chaldean|strong="H3679"\w*, \w who|strong="H1768"\w* \w destroyed|strong="H5642"\w* \w this|strong="H1836"\w* \w temple|strong="H1005"\w* \w and|strong="H4430"\w* exiled \w the|strong="H4481"\w* \w people|strong="H5972"\w* \w to|strong="H1994"\w* Babylon.  
