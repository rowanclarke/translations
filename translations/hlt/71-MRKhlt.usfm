\p
\v 39 A \w haeng|strong="G1326"\w* \w vaengah|strong="G2532"\w* \w khohli|strong="G0417"\w* \w te|strong="G3588"\w* a \w ho|strong="G2008"\w* \w tih|strong="G2532"\w* \w tuili|strong="G2281"\w* \w te|strong="G3588"\w*, \wj “ \+w Paa|strong="G4623"\+w* lamtah \+w duem|strong="G5392"\+w* laeh,” \wj* a \w ti|strong="G2036"\w* nah.  
\p Te \w dongah|strong="G2532"\w* \w khohli|strong="G0417"\w* \w te|strong="G3588"\w* \w paa|strong="G2869"\w* \w tih|strong="G2532"\w* \w suepduem|strong="G1055"\w* la \w boeih|strong="G3173"\w* \w om|strong="G1096"\w*.  
\v 40 Te \w phoeiah|strong="G2532"\w* \w amih|strong="G0846"\w* te, \wj “ \+w Balae|strong="G5101"\+w* tih \+w rhalyawp|strong="G1169"\+w* la na \+w om|strong="G2075"\+w* uh? \+w Tangnah|strong="G4102"\+w* na \+w khueh|strong="G2192"\+w* uh \+w hlan|strong="G3768"\+w*a?\wj*” a \w ti|strong="G2036"\w* nah.   
\p
