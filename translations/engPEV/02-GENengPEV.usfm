\v 12 \w Jacob|strong="H3290"\w* said \w to|strong="H1121"\w* \w Rachel|strong="H7354"\w*, “\w I|strong="H3588"\w* am \w your|strong="H3588"\w* \w father|strong="H1121"\w*’s relative. \w My|strong="H5046"\w* mother’s name \w is|strong="H1931"\w* \w Rebekah|strong="H7259"\w*, \w and|strong="H1121"\w* \w she|strong="H1931"\w* \w is|strong="H1931"\w* \w your|strong="H3588"\w* \w father|strong="H1121"\w*’s sister.”  
\p \w Then|strong="H3588"\w* \w Rachel|strong="H7354"\w* \w ran|strong="H7323"\w* home \w and|strong="H1121"\w* \w told|strong="H5046"\w* \w her|strong="H5046"\w* \w father|strong="H1121"\w* Laban \w what|strong="H3588"\w* happened.   
\p
\v 13 \w As|strong="H1697"\w* soon \w as|strong="H1697"\w* \w Laban|strong="H3837"\w* \w heard|strong="H8085"\w* \w that|strong="H3605"\w* \w his|strong="H3605"\w* sister’s \w son|strong="H1121"\w* \w Jacob|strong="H3290"\w* \w came|strong="H1961"\w* \w to|strong="H1961"\w* Haran, \w he|strong="H3605"\w* \w ran|strong="H7323"\w* \w to|strong="H1961"\w* \w meet|strong="H7125"\w* \w Jacob|strong="H3290"\w*. \w Then|strong="H1961"\w* \w Laban|strong="H3837"\w* hugged \w Jacob|strong="H3290"\w* \w and|strong="H1121"\w* \w kissed|strong="H5401"\w* \w him|strong="H3605"\w* \w on|strong="H1961"\w* \w the|strong="H3605"\w* cheek, \w and|strong="H1121"\w* \w he|strong="H3605"\w* \w took|strong="H1961"\w* \w Jacob|strong="H3290"\w* \w to|strong="H1961"\w* \w his|strong="H3605"\w* \w house|strong="H1004"\w*. \w And|strong="H1121"\w* \w Jacob|strong="H3290"\w* \w told|strong="H5608"\w* \w Laban|strong="H3837"\w* \w about|strong="H1961"\w* \w the|strong="H3605"\w* \w things|strong="H1697"\w* \w that|strong="H3605"\w* \w happened|strong="H1961"\w* \w to|strong="H1961"\w* \w him|strong="H3605"\w*.  
\v 14 \w Then|strong="H3117"\w* \w Laban|strong="H3837"\w* talked \w to|strong="H3117"\w* Jacob, \w and|strong="H3117"\w* \w he|strong="H3117"\w* said, “\w You|strong="H3117"\w* \w and|strong="H3117"\w* \w me|strong="H5973"\w*, \w we|strong="H3068"\w* \w are|strong="H3117"\w* both \w from|strong="H3117"\w* \w the|strong="H3117"\w* \w same|strong="H6106"\w* family.” \w After|strong="H3117"\w* \w that|strong="H3117"\w*, Jacob \w stayed|strong="H3427"\w* \w at|strong="H3427"\w* \w Laban|strong="H3837"\w*’s house \w for|strong="H3427"\w* \w one|strong="H1320"\w* \w month|strong="H2320"\w*, \w and|strong="H3117"\w* \w he|strong="H3117"\w* worked \w for|strong="H3427"\w* \w Laban|strong="H3837"\w*.   
\s1 Jacob married Leah and Rachel  
\p
\v 15-18 Jacob’s uncle Laban had 2 daughters. His older daughter was called Leah, and his younger daughter was called Rachel. Leah had pretty eyes, but Rachel was really beautiful. So Jacob loved Rachel, and he wanted to marry her.  
\p After one month, Laban talked to Jacob. Laban said, “You are working for me, but I am not paying you anything, because you are my relative. Is that fair? No way. I want to start paying you for the work that you do for me. Tell me, how much do you want me to pay you?”  
\p Jacob said, “You don’t have to pay me anything. I just want to marry Rachel, your younger daughter. If I work for you for 7 years, will you give her to me to marry?”   
\p
\v 19 \w Then|strong="H5414"\w* \w Laban|strong="H3837"\w* said, “\w All|strong="H5414"\w* \w right|strong="H2896"\w*. \w You|strong="H5414"\w* \w are|strong="H2896"\w* \w our|strong="H5414"\w* relative, \w so|strong="H5414"\w* \w it|strong="H5414"\w*’s \w best|strong="H2896"\w* \w for|strong="H3427"\w* Rachel \w to|strong="H5414"\w* \w marry|strong="H5414"\w* \w you|strong="H5414"\w*, \w not|strong="H5414"\w* another \w man|strong="H2896"\w*. \w Stay|strong="H3427"\w* here \w and|strong="H2896"\w* \w work|strong="H5414"\w* \w for|strong="H3427"\w* \w me|strong="H5414"\w* \w for|strong="H3427"\w* 7 years, \w and|strong="H2896"\w* \w then|strong="H5414"\w* \w I|strong="H5414"\w* \w will|strong="H5414"\w* \w give|strong="H5414"\w* \w her|strong="H5414"\w* \w to|strong="H5414"\w* \w you|strong="H5414"\w* \w to|strong="H5414"\w* \w marry|strong="H5414"\w*.”   
\p
\v 20 \w So|strong="H1961"\w* \w Jacob|strong="H3290"\w* \w worked|strong="H5647"\w* \w for|strong="H3117"\w* \w Laban|strong="H7651"\w* \w for|strong="H3117"\w* 7 \w years|strong="H8141"\w*, \w so|strong="H1961"\w* \w that|strong="H3117"\w* \w he|strong="H3117"\w* could \w marry|strong="H1961"\w* \w Rachel|strong="H7354"\w*. \w Jacob|strong="H3290"\w* really loved \w Rachel|strong="H7354"\w*, \w and|strong="H3117"\w* \w he|strong="H3117"\w* felt really happy \w that|strong="H3117"\w* \w he|strong="H3117"\w* \w was|strong="H1961"\w* going \w to|strong="H1961"\w* \w marry|strong="H1961"\w* \w her|strong="H3290"\w*. \w He|strong="H3117"\w* \w was|strong="H1961"\w* \w so|strong="H1961"\w* happy \w that|strong="H3117"\w* \w those|strong="H1961"\w* 7 \w years|strong="H8141"\w* only felt \w like|strong="H1961"\w* \w a|strong="H3068"\w* few \w days|strong="H3117"\w*.   
\p
\v 21 \w At|strong="H3117"\w* \w the|strong="H3588"\w* \w end|strong="H4390"\w* \w of|strong="H3117"\w* \w those|strong="H3588"\w* 7 \w years|strong="H3117"\w*, \w Jacob|strong="H3290"\w* said \w to|strong="H3117"\w* \w Laban|strong="H3837"\w*, “\w I|strong="H3588"\w* worked \w for|strong="H3588"\w* \w you|strong="H3588"\w* \w for|strong="H3588"\w* 7 \w years|strong="H3117"\w*, just \w like|strong="H4390"\w* \w you|strong="H3588"\w* said. \w So|strong="H3588"\w* \w now|strong="H3117"\w*, let \w me|strong="H3051"\w* marry \w your|strong="H3588"\w* daughter Rachel.”   
\p
\v 22 \w Then|strong="H6213"\w* \w Laban|strong="H3837"\w* \w made|strong="H6213"\w* \w a|strong="H3068"\w* wedding party. \w He|strong="H6213"\w* got \w all|strong="H3605"\w* \w the|strong="H3605"\w* people \w that|strong="H3605"\w* lived \w in|strong="H6213"\w* \w that|strong="H3605"\w* \w place|strong="H4725"\w* \w to|strong="H6213"\w* come \w to|strong="H6213"\w* \w that|strong="H3605"\w* wedding party, \w and|strong="H6213"\w* \w he|strong="H6213"\w* \w gave|strong="H6213"\w* \w them|strong="H6213"\w* lots \w of|strong="H4725"\w* good food.   
\p
\v 23 \w But|strong="H1961"\w* \w then|strong="H1961"\w*, \w that|strong="H1961"\w* \w night|strong="H6153"\w*, Laban tricked Jacob. Laban \w took|strong="H3947"\w* \w his|strong="H3947"\w* \w daughter|strong="H1323"\w* \w Leah|strong="H3812"\w* \w to|strong="H1961"\w* Jacob’s room, \w instead|strong="H3947"\w* \w of|strong="H1323"\w* \w his|strong="H3947"\w* \w daughter|strong="H1323"\w* Rachel. \w Then|strong="H1961"\w* Jacob slept \w with|strong="H3947"\w* \w Leah|strong="H3812"\w*, \w like|strong="H1961"\w* \w a|strong="H3068"\w* man sleeps \w with|strong="H3947"\w* \w his|strong="H3947"\w* wife. \w But|strong="H1961"\w* Jacob didn’t know \w that|strong="H1961"\w* \w he|strong="H6153"\w* slept \w with|strong="H3947"\w* \w Leah|strong="H3812"\w*. \w He|strong="H6153"\w* thought \w that|strong="H1961"\w* \w he|strong="H6153"\w* slept \w with|strong="H3947"\w* Rachel.   
\p
\v 24-30 The next morning, Jacob saw that Leah was in his room, instead of Rachel. So Jacob was angry, and he went and talked to Laban. Jacob said, “You told me that I have to work for you for 7 years, and then I can marry Rachel. So I worked those 7 years, just like you said, but then you tricked me. You gave me Leah to be my wife, instead of Rachel. Why did you do that bad thing to me?”  
\p Laban said, “Leah is my older daughter, and Rachel is my younger daughter. In our culture, the older daughter always gets married first. That’s the reason why I gave you Leah to be your wife, instead of Rachel.”  
\p Then Laban said, “Listen, your wedding party will finish in one week. So spend this week with Leah, and after that, I will give you Rachel to marry as well. But after you marry Rachel, you have to work for me for 7 more years.”  
\p Jacob agreed to do what Laban said. After one week, Jacob and Leah’s wedding party finished. Then Laban gave his daughter Rachel to Jacob, and Jacob married Rachel as well. And Jacob slept with Rachel, like \w a|strong="H3068"\w* man sleeps with his wife. So then Jacob had 2 wives, but he loved Rachel more than Leah.  
\p Laban had some women that worked for him. And Laban gave one of those women to his daughter Leah, to work for her, and he gave another of those women to his daughter Rachel, to work for her. The woman that worked for Leah was called Zilpah, and the woman that worked for Rachel was called Bilhah.  
\p Then Jacob worked for Laban for 7 more years.   
\s1 Leah had 4 sons  
\p
\v 31 Jacob didn’t love \w his|strong="H3068"\w* wife \w Leah|strong="H3812"\w*. \w He|strong="H3588"\w* \w only|strong="H3588"\w* loved \w his|strong="H3068"\w* wife \w Rachel|strong="H7354"\w*. \w And|strong="H3068"\w* \w God|strong="H3068"\w* \w saw|strong="H7200"\w* \w that|strong="H3588"\w* Jacob didn’t love \w Leah|strong="H3812"\w*. \w So|strong="H3588"\w* \w God|strong="H3068"\w* felt sorry \w for|strong="H3588"\w* \w Leah|strong="H3812"\w*, \w and|strong="H3068"\w* \w he|strong="H3588"\w* let \w her|strong="H7200"\w* \w have|strong="H3068"\w* kids. \w But|strong="H3588"\w* \w Rachel|strong="H7354"\w* couldn’t \w have|strong="H3068"\w* \w any|strong="H7200"\w* kids.   
\p
\v 32 \w This|strong="H7200"\w* \w is|strong="H3068"\w* \w the|strong="H7200"\w* story \w about|strong="H8034"\w* \w Leah|strong="H3812"\w* \w and|strong="H1121"\w* \w her|strong="H7200"\w* \w kids|strong="H1121"\w*.  
\p \w A|strong="H3068"\w* \w baby|strong="H1121"\w* started \w to|strong="H3068"\w* grow \w inside|strong="H3068"\w* \w Leah|strong="H3812"\w*, \w and|strong="H1121"\w* \w she|strong="H3588"\w* \w had|strong="H3068"\w* \w a|strong="H3068"\w* \w baby|strong="H1121"\w* boy. \w Leah|strong="H3812"\w* \w named|strong="H7121"\w* \w that|strong="H3588"\w* \w baby|strong="H1121"\w* \em Reuben\em*. \w That|strong="H3588"\w* \w name|strong="H8034"\w* means \em this is my son\em*. \w And|strong="H1121"\w* \w Leah|strong="H3812"\w* \w said|strong="H7121"\w*, “\w God|strong="H3068"\w* \w saw|strong="H7200"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w was|strong="H3068"\w* sad, \w so|strong="H7121"\w* \w he|strong="H3588"\w* \w gave|strong="H3205"\w* \w me|strong="H7200"\w* \w a|strong="H3068"\w* \w son|strong="H1121"\w*. \w Now|strong="H6258"\w* \w I|strong="H3588"\w* reckon \w my|strong="H3068"\w* husband \w will|strong="H3068"\w* love \w me|strong="H7200"\w*.”   
\p
\v 33 Later \w on|strong="H3068"\w*, Leah \w had|strong="H3068"\w* \w another|strong="H2088"\w* \w baby|strong="H1121"\w* boy. \w And|strong="H1121"\w* Leah \w said|strong="H7121"\w*, “\w God|strong="H3068"\w* \w heard|strong="H8085"\w* \w that|strong="H3588"\w* \w my|strong="H8085"\w* husband doesn’t love \w me|strong="H5414"\w*, \w so|strong="H7121"\w* \w he|strong="H3588"\w* \w gave|strong="H5414"\w* \w me|strong="H5414"\w* \w another|strong="H2088"\w* \w son|strong="H1121"\w*.” \w And|strong="H1121"\w* Leah \w named|strong="H7121"\w* \w that|strong="H3588"\w* \w baby|strong="H1121"\w* \em Simeon\em*. \w That|strong="H3588"\w* \w name|strong="H8034"\w* means \em he heard\em*.   
\p
\v 34 Later \w on|strong="H5921"\w*, Leah \w had|strong="H3205"\w* \w another|strong="H5750"\w* \w baby|strong="H1121"\w* boy. \w And|strong="H1121"\w* Leah \w said|strong="H7121"\w*, “\w Now|strong="H6258"\w* \w I|strong="H3588"\w* reckon \w my|strong="H5921"\w* husband \w will|strong="H1121"\w* love \w me|strong="H5921"\w* \w and|strong="H1121"\w* stay close \w to|strong="H5921"\w* \w me|strong="H5921"\w*, \w because|strong="H3588"\w* \w I|strong="H3588"\w* \w gave|strong="H3205"\w* \w him|strong="H3205"\w* 3 \w sons|strong="H1121"\w*.” \w And|strong="H1121"\w* Leah \w named|strong="H7121"\w* \w that|strong="H3588"\w* \w baby|strong="H1121"\w* \em Levi\em*. \w That|strong="H3588"\w* \w name|strong="H8034"\w* \w means|strong="H3651"\w* \em stay close\em*.   
