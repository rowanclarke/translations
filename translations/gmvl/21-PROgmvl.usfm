\id PRO - Gamo Full Bible final version 
\h Leemiso Maxaafa 
\toc1 Leemiso Maxaafa 
\toc2 Leemiso Maxaafa 
\toc3 Leemi 
\mt1 Leemiso Maxaafa 
\imt1 Giddo Qofa 
\ip Leemiso Maxaafay tosseninne Leemiso haasayan giigida oosonne ammano timirte. Izappe dariza baggay asaa de7on hach hach gayttiza hanota gishshas yootees. Koyroppe doommishe, «Aadho erateththas koyroy Xoossas yashshateth» giza qofa hassa7isson doommees. Izikka tamaarsizayssi ammano wogan asi ooththanayssa xalla gidontta, asi baas hach hach de7on hananaas bessiza lo7o kandonne ooththanaas bessiza lo7o ooso gujjidi tamaarssees. Ha maxaafa giddon ashketeththa gishshas, dandaya gishshas, asas qadheteththa gishshassinne ammaneteththa gishshas daro timirtey leemison imettides. 
\iot Ha Maxaafay Oykkida Kumeththa Qofa 
\io1 Leemisota wostti go7ettanaakko bessiza oge \ior 1:1-7\ior* 
\io1 Aadho erateth koyana mala imettida zore \ior 1:8—7:27\ior* 
\io1 Erateth sabbanaas yexettida mazamure \ior 8:1—9:18\ior* 
\io1 Solomoone leemisota \ior 10:1—29:27\ior* 
\io1 Agurey haasayda yo7ota \ior 30:1-33\ior* 
\io1 Limu7eele aaya ba naaza tamaarsida timirte \ior 31:1-31\ior* 
\c 1  
\s1 Leemisota Wostti Go7ettanaakko Bessiza Oge 
\q1  
\v 1 Hayti Isra7eele Kawo Dawite naa 
\q2 Solomoone leemisota.\x - \xo 1:1 \xt 1Kawo 4:32\x* 
\q1  
\v 2 Leemisoti asay aadho erateththa, 
\q2 seeranne erateththa haasaya 
\q2 akeekanaas maaddeettes. 
\q1  
\v 3 Isttika de7ana de7on 
\q2 aadho erateth, 
\q2 xilloteth, suure pirdanne 
\q2 suure hano tamaarsizayta. 
\q1  
\v 4 Erateththi paccidaytas akeeka, 
\q2 naateththatas erateththinne 
\q2 wozinamateth immizayta. 
\q1  
\v 5 Aadho eranchchati 
\q2 ha leemisota siyidi 
\q2 erateth gujjeettes; 
\q2 akeekanchcha asatikka 
\q2 lo7o zoreta ekkeettes. 
\q1  
\v 6 Hessa malan leemisotanne 
\q2 istta birsheththata, 
\q2 aadho eranchchata haasayanne 
\q2 istta maaleththo 
\q2 akeekanaas dandayeettes. 
\b  
\q1  
\v 7 Aadho erateththas koyroy 
\q2 GODAAS yashshateththa; 
\q2 eeyati gidikko 
\q2 aadho erateththinne 
\q2 seera kadheettes.\x - \xo 1:7 \xt Iyo 28:28; Maza 111:10; Leemi 9:10\x* 
\b  
\s1 Yelaga Naytas Imettida Zore 
\q1  
\v 8 Ta naazoo! 
\q2 Ne aawa zore ezga; 
\q2 ne aaya tamaarsizayssaka aggofa. 
\q1  
\v 9 Hessi ne hu7es 
\q2 bonchcho kallachcha; 
\q2 nees qoodhen aaththiza 
\q2 alleqo mala gidana. 
\b  
\q1  
\v 10 Ta naazoo! 
\q2 Nena nagaranchchati 
\q2 baleththiko eeno gooppa. 
\q1  
\v 11 Istti nena, «Ane haa ya; 
\q2 issife biidi 
\q2 suuth gussanaas zuggoos; 
\q2 xillotakka wodhanaas 
\q2 qotetti uttoos. 
\q1  
\v 12 Duufoy mittiza mala 
\q2 nunikka ane istta 
\q2 paxa dishin mittoos; 
\q2 nuni istta ciimma ollan 
\q2 olettiza asa mala 
\q2 ane ooththoos. 
\q1  
\v 13 Nuni al7o miish 
\q2 ubbaa demmana; 
\q2 histtidi nu keeththa 
\q2 bonqqi ekkida 
\q2 miishshan kunththana. 
\q1  
\v 14 Nunara zuppeta; 
\q2 demmidaaz issife 
\q2 go7ettana» gaana. 
\q1  
\v 15 Ta naazoo! 
\q2 Isttara issife 
\q2 oge hemettofa; 
\q2 istti biza oge baana gaada 
\q2 ne toho denththofa. 
\q1  
\v 16 Gaasoykka istti iita miish 
\q2 ooththanaas woxxeettes; 
\q2 asaa suuth gussanaaskka 
\q2 jaameettes. 
\q1  
\v 17 Kafoy xeellishin 
\q2 iza oykkanaas 
\q2 yarde woththiko 
\q2 aykkoka maaddenna. 
\q1  
\v 18 Hayti ha asati bantta 
\q2 suuth gussanaas zuggeettes; 
\q2 bantta shemppo wodhanaas 
\q2 qotetti utteettes. 
\q1  
\v 19 Bessontta ogera go7a demmanaas 
\q2 woxxiza ubbata wurseththay 
\q2 hayssa mala; 
\q2 istti shiishshida aqotay 
\q2 istta shemppo ekki baana. 
\s1 Aadho Erateth Kadhizaytas Imettida Seera 
\q1  
\v 20 Aadho erateththaya 
\q2 oge bolla de7ashe xeygawus; 
\q2 dubbushan ba qaala 
\q2 dhoqqu histtada waassawus. 
\q1  
\v 21 Aadho erateththaya cora asi 
\q2 shiiqizason waassawus; 
\q2 katama geliza pengen eqqada,\x - \xo 1:20-21 \xt Leemi 8:1-3\x* 
\b  
\q1  
\v 22 «Intteno wozina pacetoo! 
\q2 Intte awude gakkanaas 
\q2 eeyateththa oge kaallanee? 
\q2 Qilccizaytoo! Intte qilccizayssan 
\q2 awude gakkanaas ufayetteetii? 
\q2 Eeyatoo! Erateththa 
\q2 awude gakkanaas ixxanee? 
\q1  
\v 23 Ta seeran intte simmidaakko, 
\q2 tani ta qofa 
\q2 inttes qonccisanakkoshin; 
\q2 ta qaalakka 
\q2 inttena tamaarsanakkoshin. 
\q1  
\v 24 Tani xeygida wode 
\q2 intte koyontta ixxideta; 
\q2 tani ta kusheza micciin 
\q2 oonikka wudu gibeenna. 
\q1  
\v 25 Ta zore ubbaa kadhideta; 
\q2 ta seerakka ekkibeekketa. 
\q1  
\v 26 Hessa gishshas 
\q2 inttena metoy gakkiza wode 
\q2 tani intte bolla miiccana; 
\q2 bashshi intte bolla gakkiza wode 
\q2 tani intte bolla qilccana. 
\q1  
\v 27 Bashshi abba dambala mala 
\q2 inttena qaaththiza wode, 
\q2 metoy gote carko mala 
\q2 inttena denththiza wode, 
\q2 tuggaynne waayey 
\q2 inttena mittiza wode 
\q2 tani inttena qilccana. 
\b  
\q1  
\v 28 «He wode istti tana xeygana; 
\q2 ta gidikko isttas koykke; 
\q2 istti tana minththi koyana; 
\q2 gido attiin tana demmettenna. 
\q1  
\v 29 Istti erateth ixxida; 
\q2 GODAAS yashshateth 
\q2 dooribeettenna. 
\q1  
\v 30 Ta zore ekkanaas koyibeettenna; 
\q2 ta seera ubbaa kadhida. 
\q1  
\v 31 Hessa gishshas 
\q2 istti bantti ooththida 
\q2 ooso ayfeza maana; 
\q2 bantti qoppida 
\q2 qofa ayfekka kallana. 
\q1  
\v 32 Wozinay paccidayta 
\q2 aadho erateththafe 
\q2 haakoy istta wodhana; 
\q2 balata wuda dhayoy 
\q2 istta dhayssana. 
\q1  
\v 33 Gido attiin tana siyizayti 
\q2 ubbay saron daana; 
\q2 aykko hirgay baynda 
\q2 woppan daana» gawus. 
\c 2  
\s1 Aadho Erateththafe Beettiza Anjjo 
\q1  
\v 1 Ta naazoo! Neni ta qaala siyikko, 
\q2 ta azazokka 
\q2 neni ne wozinan woththiko, 
\q2  
\v 2 ne hayth aadho erateththaako 
\q2 zaarikko, 
\q2 ne wozina akeekakko 
\q2 ne zaarikko, 
\q1  
\v 3 shaakki erisiza erateth 
\q2 ne koykko, 
\q2 ne qaala dhoqqu histtada 
\q2 akeeka xeygikko, 
\q1  
\v 4 izokka bira koyza mala 
\q2 ne koykko, 
\q2 qotan diza aqota mala 
\q2 ne izo minththa koykko, 
\q2  
\v 5 he wode neni 
\q2 GODAAS yashshateth akeekana; 
\q2 Xoossaaka lo7eththada erana. 
\q1  
\v 6 GODAY aadho erateth 
\q2 immiza gishshas 
\q2 izappe erateththinne 
\q2 akeekay beettes. 
\q1  
\v 7 Izi suuretas xoono minjjees; 
\q2 istta bolla wosoy bayndaytas 
\q2 gondalle gidees. 
\q1  
\v 8 Suure pirda oge naagees; 
\q2 baas ammanettizayta 
\q2 hemeth minththees. 
\q1  
\v 9 He wode neni xilloteth, 
\q2 suure pirda, 
\q2 geellay baynda pirdanne 
\q2 lo7o oge ubbaa shaakka erana. 
\q1  
\v 10 Gaasoykka aadho erateththi 
\q2 ne wozinan gelana; 
\q2 erateththayka 
\q2 ne shemppo ufayssana. 
\q1  
\v 11 Shaakki eroy nees gondalle gidana; 
\q2 akeekaykka nena naagana. 
\q1  
\v 12 Aadho erateththi nena 
\q2 iita asata ogeppe ashshana; 
\q2 geella haasayzaytappeka 
\q2 nena naagana. 
\q1  
\v 13 Istti dhuma ogen baanaas 
\q2 suure oge aggizayta; 
\q2  
\v 14 Istti iita ooson ufayettizayta; 
\q2 geella ogen hombocizayta. 
\q1  
\v 15 Istta ogey geella; 
\q2 istta hemetay mirqqeththa. 
\b  
\q1  
\v 16 Aadho erateththi 
\q2 layma maccassafe naagana; 
\q2 ba inxarsan cimmizaarippe 
\q2 nena ashshana. 
\q1  
\v 17 Iza ba yelagateththa 
\q2 azina aggidaaro; 
\q2 Xoossa sinththan gelida 
\q2 caaqo qaala kadhidaaro. 
\q1  
\v 18 Izi soo beeththi hayqos gaththees; 
\q2 izi ogetikka 
\q2 moytilleta duulatan gaththeettes. 
\q1  
\v 19 Izikko gelida 
\q2 oonikka guye simmenna; 
\q2 de7o ogekka demmenna. 
\b  
\q1  
\v 20 Hessa gishshas neni 
\q2 lo7o asata leemiso kaalla; 
\q2 xillota ogen hemetta. 
\q1  
\v 21 Suure asati biitta bolla gam7ana; 
\q2 wosoy baynda asatikka 
\q2 izi bolla minni daana. 
\q1  
\v 22 Gido attiin iitati biittafe dhayana; 
\q2 ammanettonttaytikka dhoqallettana. 
\c 3  
\s1 Godaan Ammaneteth 
\q1  
\v 1 Ta naazoo! 
\q2 Tani nena tamaarsizayssa 
\q2 dogoppa; 
\q2 ta azazotakka 
\q2 ne wozinan woththa. 
\q1  
\v 2 Istti ne layth adussana; 
\q2 ishalo de7onne 
\q2 saroteth nees gujjana. 
\q1  
\v 3 Siiqoynne tumateththi 
\q2 neeppe haakkofetto; 
\q2 istta ne qoodhen qachcha; 
\q2 ne wozinankka xaafa. 
\q1  
\v 4 Histtiko neni Xoossa sinththaninne 
\q2 asaa sinththan sabettananne 
\q2 lo7o sunth demmana.\x - \xo 3:4 \xt Luqa 2:52\x* 
\b  
\q1  
\v 5 Neni polo wozinan 
\q2 GODAAN ammanetta; 
\q2 neni ne akeekan zemppofa. 
\q1  
\v 6 Neni biza oge ubbaan 
\q2 iza sinththasa; 
\q2 izikka ne biza oge suurisana. 
\q1  
\v 7 Nerkka nena 
\q2 aadho eranchcha gooppa; 
\q2 GODAAS yayya; 
\q2 iitappeka haakka.\x - \xo 3:7 \xt Oro 12:16\x* 
\q1  
\v 8 Hessi ne bollaa payya woththana; 
\q2 ne meqeththatakka xalisana. 
\b  
\q1  
\v 9 GODAA ne aqotan bonchcha; 
\q2 biittay nees immiza ayfe ubbaafe 
\q2 xeeraa izas imon bonchcha. 
\q1  
\v 10 Ne hessaththo ooththiko 
\q2 ne gootarati kumi palahana; 
\q2 neni woyne ushshu agizasoti 
\q2 cippi gi kumana. 
\q1  
\v 11 Ta naazoo! 
\q2 GODAA seera kadhoppa; 
\q2 izi nena hanqiza 
\q2 wodekka lanccofa.\x - \xo 3:11 \xt Iyo 5:17\x* 
\q1  
\v 12 Aaway ba siiqiza naa 
\q2 seerizayssaththo 
\q2 GODAYKKA ba dosiza 
\q2 naa seerees.\x - \xo 3:11-12 \xt Ib 12:5-6\x*\x - \xo 3:12 \xt Ajju 3:19\x* 
\q1  
\v 13 Aadho erateth demmanaas 
\q2 woxxiza asi, 
\q2 akeekakka baas miishshe 
\q2 ooththiza asi anjjettidaade. 
\q1  
\v 14 Gaasoykka izippe demmiza go7ay 
\q2 birappe demmiza 
\q2 go7appe aadhdhees; 
\q2 izippe beettiza go7ay 
\q2 worqqafe beettiza 
\q2 go7appe aadhdhees. 
\q1  
\v 15 Aadho erateththi zo7o inqqufe 
\q2 keehi al7o; 
\q2 neni demmanaas amottiza ubbay 
\q2 izira ginattenna. 
\q1  
\v 16 Iza ushachcha kushen adussa layth, 
\q2 hadirsa kushen aqotanne 
\q2 bonchcho oykkadus. 
\q1  
\v 17 Izi ogeti ufayssiza ogeta; 
\q2 iza hemettiza oge ubbayka saro. 
\q1  
\v 18 Iza bana idimmizaytas 
\q2 de7o miththa; 
\q2 izo oykkizaytikka anjjettana. 
\b  
\q1  
\v 19 GODAY ba aadho erateththan 
\q2 sa7a medhdhides; 
\q2 ba akeekankka salota 
\q2 istti dizason minththides. 
\q1  
\v 20 Shaafati iza erateththan goggeettes; 
\q2 shaarati ira immeettes. 
\q1  
\v 21 Ta naazoo! Suure pirdanne 
\q2 shaakki ero naaga; 
\q2 istti ne sinththafe haakkofetto. 
\q1  
\v 22 Istti nees de7o gidana; 
\q2 ne qoodheskka aleqo gidana. 
\q1  
\v 23 He wode neni ogen 
\q2 hirgay baynda hemettana; 
\q2 ne tohoykka dhuphettenna. 
\q1  
\v 24 Neni ichchida wode babbaka; 
\q2 ichchadakka 
\q2 mal7o dhisko dhiskana. 
\q1  
\v 25 Akeekontta gakkiza metonne 
\q2 iitata bolla gakkiza 
\q2 dhayssas babbaka. 
\q1  
\v 26 Ays giikko GODAY nees 
\q2 ammanettizaade gidana; 
\q2 ne tohoy 
\q2 woximaden oykettontta mala 
\q2 izi nena naagana. 
\b  
\q1  
\v 27 Nees maaddana wolqqay dishin 
\q2 maado bessizaytas 
\q2 lo7o ooso aggofa. 
\q1  
\v 28 Ha7i nees dishin ne shoorozas, 
\q2 «Simmada ya; 
\q2 tani nees wonto immana» gooppa. 
\q1  
\v 29 Nenan ammanettidi ne matan dishin 
\q2 ne shooroza bolla 
\q2 iita miish ooththanaas halchchofa. 
\q1  
\v 30 Nena qohontta as 
\q2 gaasoy baynda coo mootoppa. 
\b  
\q1  
\v 31 Gene ooththiza asata qullofa; 
\q2 istta iita ogekka kaallofa. 
\q1  
\v 32 Gaasoykka GODAY 
\q2 iita ooththizayta ixxees; 
\q2 gido attiin suuretas izi 
\q2 ba wozina qofa qonccisees. 
\b  
\q1  
\v 33 GODAA qanggeththi 
\q2 iita ooththizayta keeththanna; 
\q2 gido attiin 
\q2 iza anjjoy xillotasonna. 
\q1  
\v 34 Otoreteththan qilccizayta bolla 
\q2 GODAYKKA qilccees; 
\q2 gido attiin banttana 
\q2 kawushshizayta bonchchees.\x - \xo 3:34 \xt Yaaqo 4:6; 1Phex 5:5\x* 
\q1  
\v 35 Aadho eranchchati 
\q2 bonchcho laattana; 
\q2 eeyati gidikko kawushshateththas 
\q2 aadhdhi imettana. 
\c 4  
\s1 Aadho Erateththa Go7a 
\q1  
\v 1 Ta naytoo! Intte aawa zore siyite; 
\q2 wozinan woththi ezgite; 
\q2 akeekakka inttes miish histtite. 
\q1  
\v 2 Tani inttes lo7o timirte 
\q2 immiza gishshas 
\q2 ta timirte aggofte. 
\q1  
\v 3 Tani ta hu7enkka 
\q2 ta aawaas yelaga naa; 
\q2 ta aayeyska mexi issi naa. 
\q1  
\v 4 Ta aaway tana tamaarsishe, 
\q2 «Ta qaala kumeththa 
\q2 wozinan oykka; 
\q2 ta azazotakka naaga; 
\q2 ne histtiko paxa de7ana. 
\q1  
\v 5 Aadho erateththinne akeeka oykka; 
\q2 ta qaala dogoppa; 
\q2 izippeka kare kezoppa. 
\q1  
\v 6 Aadho erateth aggofa; 
\q2 iza nees gondalle gidana; 
\q2 izo siiqa; 
\q2 izakka nena naagana. 
\q1  
\v 7 Aadho erateththi bayra; 
\q2 hessa gishshas izo demma. 
\q2 Akeekay ne aqoza ubbaa 
\q2 ekkizaa gidikkoka iza demma. 
\q1  
\v 8 Neni aadho erateth bonchcha; 
\q2 iza nena 
\q2 dhoqqu dhoqqu ooththana; 
\q2 neni izo idimma; 
\q2 iza nena bonchchana. 
\q1  
\v 9 Iza ne hu7en 
\q2 saba akilile woththana; 
\q2 bonchcho kallachchaka 
\q2 immana» gees. 
\q1  
\v 10 Ta naazoo! Ta gizayssa ezga; 
\q2 ta qaalaakka 
\q2 ne wozinan woththa; 
\q2 ne layththi aduqqana. 
\q1  
\v 11 Tani nena aadho erateththa 
\q2 oge kaaleththana; 
\q2 suure ogekka bessana. 
\q1  
\v 12 Ne hemettashe dhuphettaka; 
\q2 woxxikokka kundaka. 
\q1  
\v 13 Ta timirte lo7eththa oykka; 
\q2 izo yeddofa; 
\q2 iza nees de7o gidida gishshas 
\q2 izo naaga. 
\q1  
\v 14 Nagaranchchata oge yedhdhofa; 
\q2 iita asata ogenkka hemettofa. 
\q1  
\v 15 Izippe haakka; izin hemettofa; 
\q2 izippe guye simma; 
\q2 histtada ne ogeyra ba. 
\q1  
\v 16 Istti iita ooththontta dishe 
\q2 dhiski erettenna; 
\q2 as dhupheththontta dishin 
\q2 dhiskoy istta ayfen yeenna. 
\q1  
\v 17 Istti iitateth kaththa mala meettes; 
\q2 genekka ushsha mala uyeettes. 
\b  
\q1  
\v 18 Xillota ogey seeta gallas gakkanaas 
\q2 poo7i poo7i biza 
\q2 mallado xalqqe mala. 
\q1  
\v 19 Gido attiin nagaranchchata ogey 
\q2 sakkanna dhuma mala; 
\q2 istti aazan dhuphettanaakkoka 
\q2 erettenna. 
\q1  
\v 20 Ta naazoo! Ta gizayssa akeeka; 
\q2 ta qaalaakka lo7eththa ezga. 
\q1  
\v 21 Ne ayfe sinththafe haassofa; 
\q2 ne wozinan woththa. 
\q1  
\v 22 Gaasoykka istti demmiza asas 
\q2 de7o immeettes; 
\q2 istti asateththaska 
\q2 payyateth immeettes. 
\q1  
\v 23 Ubbaafekka bollara 
\q2 neni ne wozina 
\q2 minththada naaga; 
\q2 ays giikko de7oy izappe pulttees. 
\q1  
\v 24 Ne doonappe gene haasaya digga; 
\q2 iita haasaya 
\q2 ne metershafe haassa. 
\q1  
\v 25 Ne ayfeti sitti giidi 
\q2 sinth xeelletto; 
\q2 tishshi histtada 
\q2 ne sinththan dizayssa xeella. 
\q1  
\v 26 Ne tohos oge giigsa; 
\q2 suure oge xalla hemetta.\x - \xo 4:26 \xt Ib 12:13\x* 
\q1  
\v 27 Ushach hadirsi gooppa; 
\q2 ne toho iitappe naaga. 
\c 5  
\s1 Laymateththafe Naageteth 
\q1  
\v 1 Ta naazoo! Ta aadho erateththaa 
\q2 ne wozinan woththa; 
\q2 tani akeekan yootiza qaala 
\q2 lo7eththa ezga. 
\q1  
\v 2 Hessika wozinamateththi 
\q2 nees miish gidana malanne 
\q2 ne metershati 
\q2 erateth naagana malassa. 
\q1  
\v 3 Layma maccassa inxarsafe 
\q2 eessa ililoy xokkees; 
\q2 izi haasayay oyssafekka 
\q2 aadhdhi shuggees. 
\q1  
\v 4 Gido attiin iza wurseththan 
\q2 godare uuththa mala cammawus; 
\q2 nam7u baggara qanxxiza 
\q2 qara mashsha mala. 
\q1  
\v 5 Izi tohoti duge hayqoso beettes; 
\q2 izi tanggoy sitti histti 
\q2 duge duufon kaaleththees. 
\q1  
\v 6 Iza de7o oges wudu guukku; 
\q2 izi ogeti geella; 
\q2 gido attiin geella gididayssaka 
\q2 iza erukku. 
\b  
\q1  
\v 7 Ta naytoo! Tana ezgite; 
\q2 ta yootiza qaalaappe ke7opite. 
\q1  
\v 8 Intte oge izippe haassite; 
\q2 izi pengerakka aadhdhofte. 
\q1  
\v 9 Hessika intte intte 
\q2 goobateththa haratas, 
\q2 intte layththaaka menxe iitatas 
\q2 intte immontta malassa. 
\q1  
\v 10 Allagati intte aqotan 
\q2 kaa7ontta malanne 
\q2 intte daaburankka hara asasoy 
\q2 duretontta malassa. 
\q1  
\v 11 Intte ashoy wuriin, 
\q2 intte meqeththi gilqiin 
\q2 wurseththa layththan 
\q2 intte goottarana. 
\q1  
\v 12 Qasseka neni, 
\q2 «Tani ays seera ixxadinaa! 
\q2 Ta wozinaykka zore 
\q2 ays kadhidee! 
\q1  
\v 13 Tana tamaarsizayti 
\q2 yootidayssa ekkabeekke; 
\q2 tana zorizayta 
\q2 zorezakka ezgabeekke. 
\q1  
\v 14 Hessa gishshas tani 
\q2 shiiqida duulata sinththafe 
\q2 dhayana matadis» gaana. 
\b  
\q1  
\v 15 Neni eelissida ne pultto haaththafe 
\q2 uyada aliza mala 
\q2 ne machcheys ammanettada 
\q2 izi siiqon ala. 
\q1  
\v 16 Beetta beetta maccassi 
\q2 uyiza pultto haath gidoppa. 
\q1  
\v 17 Nenateththaa ne machcheys naaga; 
\q2 hara maccassara zin7ofa. 
\q1  
\v 18 Ne machcheya nees 
\q2 anjjettida pultto gidu; 
\q2 yelagateththan neni ekkida 
\q2 ne machcheyra ufayetta. 
\q1  
\v 19 Lo7iza gaara malanne 
\q2 ufayssiza genessa mala, 
\q2 izi dhanththati ubba wode 
\q2 nena aletto; 
\q2 izi siiqoy nena ubbato oykko. 
\q1  
\v 20 Ta naazoo! 
\q2 Layma maccassay siiqon 
\q2 ays maththottay? 
\q2 Hara asa machchira 
\q2 ays qoomettay? 
\b  
\q1  
\v 21 Gaasoykka asi ooththiza ubbaa 
\q2 GODAY beyees; 
\q2 izi hemettiza hemetaa ubbaa 
\q2 pilggi xeellees. 
\q1  
\v 22 Nagaranchcha izi ooththida 
\q2 nagaray zaari oykkees. 
\q2 Iza nagara gitey iza qachchees. 
\q1  
\v 23 Izi ba eeyateththa daron 
\q2 oge balana; 
\q2 bana haarana dandayontta 
\q2 aggida gishshas 
\q2 izi hayqqana. 
\c 6  
\s1 Hachchas Hachchas Bessiza Zore 
\q1  
\v 1 Ta naazoo! Neni ne shoorozas 
\q2 waase gelidaa gidikko, 
\q2 hara asa gishshas neni 
\q2 kushe baqqa caaqqidaa gidikko, 
\q2  
\v 2 neni gelida qaalan 
\q2 oykettidaa gidikko, 
\q2 ne doonappe ke7ida qaalan 
\q2 ne oykettidaa gidikko, 
\q2  
\v 3 ta naazoo! Neni ne shooroza 
\q2 kushen kundida gishshas 
\q2 nena ashshanaas baada 
\q2 iza sinththan kunda; 
\q2 ne shoorozakko baada shoobba. 
\q1  
\v 4 Hessaththo ooththontta 
\q2 dashe dhiskofa; 
\q2 ne siphinththati liphopetto. 
\q1  
\v 5 Shankkanchchatappe genessi 
\q2 kessi ekki attiza mala, 
\q2 yarden oykettontta attida 
\q2 kafo mala nena ashsha. 
\b  
\q1  
\v 6 Nenoo azallazoo! 
\q2 Cunccalletaakko ba; 
\q2 histtada isttafe tamaarada 
\q2 aadho eranchcha gida. 
\q1  
\v 7 Cunccalletas azazizay deenna; 
\q2 istta haarizay deenna. 
\q1  
\v 8 Gido attiin banttas maana miish 
\q2 bone shiishsheettes; 
\q2 kath shiishshiza wode 
\q2 banttas kath shiishsheettes. 
\b  
\q1  
\v 9 Nenoo azallazoo! 
\q2 Neni awude gakkanaas 
\q2 dhiskanee? 
\q2 Dhiskofekka 
\q2 ne awude beegganee? 
\q1  
\v 10 «Tani guuththara dhiska ekkana; 
\q2 guuththara liipha dendana; 
\q2 ta kushe borkotada 
\q2 guuththara shempa ekkana» 
\q2 ne gishin, 
\q2  
\v 11 he wode manqoteththi 
\q2 panga mala, 
\q2 pacey ola miishsha 
\q2 oykkida asa mala 
\q2 ne bolla puttu gaana.\x - \xo 6:10-11 \xt Leemi 24:33-34\x* 
\b  
\q1  
\v 12 Womaleynne menxe iita asi 
\q2 yuuyi yuuyidi 
\q2 iita qaala haasayzay, 
\q2  
\v 13 ba ayfera qim7otizay, 
\q2 ba tohon bessizay, 
\q2 ba biradhdhetankka malatizay, 
\q2  
\v 14 ba wozinan iita miish 
\q2 woththi denththi qoppizay 
\q2 ay wodekka oosh denththees. 
\q1  
\v 15 Hessa gaason bashshi akeekontta 
\q2 iza bolla yaana; 
\q2 izi hassa7ay baynda meqqana; 
\q2 meqqidikka paxenna. 
\b  
\q1  
\v 16 GODAY ixxiza usuppun 
\q2 yo7oti deettes; 
\q2 laappunththaza 
\q2 keehi harasettees. 
\q1  
\v 17 Otoreteththan xeelliza ayfe, 
\q2 wordotiza inxars, 
\q2 xillo asata wodhiza kushe, 
\q2  
\v 18 iita miish qoppiza wozina, 
\q2 iitaso eesotiza tohota, 
\q2  
\v 19 wordo bolla wordo gujji gujjidi 
\q2 yootiza wordo markka, 
\q2 ishantta giddon 
\q2 oosh medhdhiza asa. 
\s1 Laymappe Haako 
\q1  
\v 20 Ta naazoo! Ne aawa azazo pola; 
\q2 ne aaya tamaarsidayssaka aggofa. 
\q1  
\v 21 Istta ubbato ne wozinan oykka; 
\q2 ne qoodhenkka qachcha. 
\q1  
\v 22 Neni hemettiza wode 
\q2 istti nena kaaleththana; 
\q2 neni ichchiza wode 
\q2 istti nena naagana; 
\q2 neni beegottiza wodekka 
\q2 istti nena zorana. 
\q1  
\v 23 Ays giikko ha azazoti nees xomppe; 
\q2 timirtetikka poo7o; 
\q2 qasse seeraykka 
\q2 de7okko efiza oge. 
\q1  
\v 24 Ha azazoti iita maccassafe 
\q2 nena naagana; 
\q2 doonan cimmiza hawusha 
\q2 maccassafekka naagana. 
\q1  
\v 25 Izi lo7eteththa 
\q2 ne wozinan amottofa; 
\q2 izi qim7oteththan oykettofa. 
\q1  
\v 26 Issi addey 
\q2 bana bayza diza maccassayo 
\q2 guuththa miishshan 
\q2 demmanaas dandayees; 
\q2 asa machchi geedo kaaloy 
\q2 nees shemppo dhayssana. 
\q1  
\v 27 Issi asi tama idimmiin 
\q2 iza may7oy 
\q2 meetettontta attanaas dandayzee? 
\q1  
\v 28 Issi asi bonqo tama yedhdhi bishin 
\q2 iza tohoy 
\q2 xuugettontta attana dandayzee? 
\q1  
\v 29 Asa machcho laggeththiza asi 
\q2 hessa mala; 
\q2 izo bochchiza ubbay 
\q2 qaxxayettontta attenna. 
\b  
\q1  
\v 30 Kaysoy gafa attanaas kaysikko 
\q2 asay iza kadhenna. 
\q1  
\v 31 Gido attiin izas diza aqota 
\q2 ubbaa oychchikokka 
\q2 izi oykettidaa gidikko 
\q2 laappun kushe qanxxana bessees. 
\q1  
\v 32 Layma laymatiza asas 
\q2 wozinay pace; 
\q2 hessaadey barkka 
\q2 ba shemppo dhayssees. 
\q1  
\v 33 Bukaynne kawushshateththi 
\q2 izas qaada; 
\q2 yeellateththi izappe 
\q2 mulekka qucettenna. 
\q1  
\v 34 Qanaatey azina hanqettana mala denththeththees; 
\q2 izi halo kessiza wode 
\q2 izas qadhettenna. 
\q1  
\v 35 Izi ay edakka ekkenna; 
\q2 ay keena imotaykka 
\q2 iza hanqo doshisenna. 
\c 7  
\s1 Laymappe Naagettana Mala Imettida Seera 
\q1  
\v 1 Ta naazoo! Ta qaala naaga; 
\q2 ta azazokka ne wozinan 
\q2 qum7a oykka. 
\q1  
\v 2 Ne paxa de7ana mala 
\q2 ta azazota naaga; 
\q2 ta timirtezakka 
\q2 ne ayfe ciro mala naaga. 
\q1  
\v 3 Hayta ne biradhdhetan qachcha; 
\q2 ne wozinankka xaafa. 
\q1  
\v 4 Aadho erateth ne taas michcho ga; 
\q2 akeekakka ne taas dabbo ga. 
\q1  
\v 5 Istti nena layma maccassafenne 
\q2 ba qaalan baleththiza 
\q2 hawusha maccassafe naagana. 
\q1  
\v 6 Issi gallas tani 
\q2 ta keeththa maskootezara 
\q2 kare xeelladis. 
\q1  
\v 7 Akeekay paccida yelagata be7adis. 
\q2 Istta giddofe issoy keehi eeya. 
\q1  
\v 8 He wodallay izi soo efiza 
\q2 oge baggara oykki bishe 
\q2 izi keeththa achchara 
\q2 aadhdhi bishin, 
\q1  
\v 9 he wode sa7ay qammanaas 
\q2 lankilankishin, 
\q2 dhumay ayfe oykkishin, 
\b  
\q2  
\v 10 issi maccassaya 
\q2 iza demmanaas kezadus; 
\q2 layma maccassa may7o may7ada 
\q2 baleththanaas murtta kezadus. 
\q1  
\v 11 Iza xalanne 
\q2 yeellay baynda maccassa; 
\q2 sohon woppu gaada uttuku. 
\q1  
\v 12 Iza issito ogen, issito gulan, 
\q2 issito dubbushan eqqada naagawus. 
\q1  
\v 13 Iza he naaza 
\q2 shiishsha oykkada yeerawus; 
\q2 yeellay baynda iza ayfe 
\q2 tishshi histta xeellashe, 
\b  
\q2  
\v 14 «Tani tason issifeteththa yarsho 
\q2 yarshanaas bessees; 
\q2 tani ta adina hach poladis. 
\q1  
\v 15 Histtada nena xeellanawu ke7adis; 
\q2 nena keeha koyadis; 
\q2 ha7i beya nena demmadis. 
\q1  
\v 16 Tani Gibxeppe yida 
\q2 alleqissiza ansolakka 
\q2 ta hiixan yeggadis. 
\q1  
\v 17 Tani karbbe, almmuniyemenne 
\q2 qarafa geetettiza 
\q2 sawotappe oosettida 
\q2 shitto ta hiixan cacafadis. 
\q1  
\v 18 Haa ya; ane wonttana gakkanaas 
\q2 siiqo aloos; 
\q2 qoomettidikka ufayettoos. 
\q1  
\v 19 Ta keeththaaway soon deenna; 
\q2 haako dere bides. 
\q1  
\v 20 Miish karaxiite kunththi 
\q2 ekki bida gishshas 
\q2 aginay dors daganththontta 
\q2 simmenna» gadus. 
\b  
\q1  
\v 21 Histtada ba mal7o haasayan 
\q2 iza baleththadus; 
\q2 ba liiqo inxarsankka cimmadus. 
\q1  
\v 22 Shukas laagetti biza boora mala, 
\q2 woximaden oykettana 
\q2 biza cofosho mala 
\q2 heerakka aamusontta 
\q2 izo kaallidi bides. 
\q1  
\v 23 Wondafe yiishshi 
\q2 iza tire caddana gakkanaas, 
\q2 iza shemppo dhayssanayssa 
\q2 erontta dishe piradhdhidi yarden 
\q2 geliza kafo mala gidides. 
\b  
\q1  
\v 24 Ta naazoo! Ane ha7i siya; 
\q2 ta doonappe keziza 
\q2 qaalaakka ezga. 
\q1  
\v 25 Ne wozinay izikko booppo; 
\q2 iza biza bala ogen geloppa. 
\q1  
\v 26 Iza kawushshada olidayti undenna; 
\q2 iza wodhidayta qooday 
\q2 keehi daro. 
\q1  
\v 27 Izi soy duufon efiza oge; 
\q2 he ogey duge hayqoso gaththees. 
\c 8  
\s1 Aadho Erateththa Saba 
\q1  
\v 1 Siyite! Aadho erateththaya ba qaala 
\q2 doqqu histta xeygekkee? 
\q2 Akeekaykka ba cenggurssaa 
\q2 dhoqqu histta sissekee? 
\q1  
\v 2 Oge doonan de7iza 
\q2 zumbullata bollanne 
\q2 daggala ogetan eqqawus. 
\q1  
\v 3 Gimbeza lanqen katamata 
\q2 geliza pengen eqqada 
\q2 ba qaala dhoqqu histtada,\x - \xo 8:1-3 \xt Leemi 1:20-21\x* 
\q2  
\v 4 hayto asatoo! Tani inttena xeygays; 
\q2 tani asa zereth ubbaa xeygays. 
\q1  
\v 5 Intteno akeekay paccidaytoo! 
\q2 wozinama gidite; 
\q2 intteno eeyatoo akeeka demmite. 
\q1  
\v 6 Tani go7iza miish 
\q2 yootiza gishshas ezgite; 
\q2 ta doonappe suure yo7oy kezees. 
\q1  
\v 7 Ta doonay tuma haasayees; 
\q2 ta metershatikka 
\q2 iita miish ixxeettes. 
\q1  
\v 8 Ta doonappe keziza qaalati 
\q2 ubbay tuma; 
\q2 geella woykko bokka gidettenna. 
\q1  
\v 9 Akeekay diza asas 
\q2 ta haasayay likke; 
\q2 erateththi dizaytas 
\q2 ta haasayan wordoy deenna. 
\q1  
\v 10 Birappe aaththidi ta zore ekkite; 
\q2 muuruta worqqafe aaththidi 
\q2 erateth doorite. 
\b  
\q1  
\v 11 Ays giikko, «Tani aadho erateththi 
\q2 zo7o inqqufekka keeha al7ays; 
\q2 neni amottiza miish ubbayka 
\q2 tanara ginattanaas dandayenna. 
\q1  
\v 12 Tani aadho erateththi 
\q2 akeekara days; 
\q2 erateththinne wozinamateththi 
\q2 ta miishshata. 
\q1  
\v 13 Godaas yashshateththi iita ixo; 
\q2 tani otoronne hallaca, 
\q2 menxe iitateththinne 
\q2 geella haasaya ixxays. 
\q1  
\v 14 Zoreynne lo7o pirday tayta; 
\q2 taas akeekaynne wolqqay dees. 
\q1  
\v 15 Kawoti tanan kawoteettes; 
\q2 dere ayssizayti 
\q2 suure woga kesseettes. 
\q1  
\v 16 Daannati tani maaddiin 
\q2 deraa aysseettes; 
\q2 deraa haariza gita asati 
\q2 ubbay haareettes. 
\q1  
\v 17 Tana siiqizayta tani siiqays; 
\q2 minni koyzayti tana demmana. 
\q1  
\v 18 Dureteththinne bonchchoy 
\q2 ta matan deettes; 
\q2 wurontta aqotaynne 
\q2 injjey ta matanna. 
\q1  
\v 19 Intte taappe demmiza go7ay 
\q2 muuruta worqqafe aadhdhees; 
\q2 ta imotaykka 
\q2 seerisi kessida birappe darees. 
\q1  
\v 20 Tani xilloteththa ogen hemettays; 
\q2 suure pirda kaallays. 
\q1  
\v 21 Tana siiqizaytas 
\q2 tani dureteth immana; 
\q2 istta minjja keeththaaka 
\q2 tani kunththana. 
\b  
\q1  
\v 22 «GODAY tana ba ooso ubbaafe 
\q2 koyro medhdhides; 
\q2 benippeka iza oosaas 
\q2 koyroy tana.\x - \xo 8:22 \xt Ajju 3:14\x* 
\q1  
\v 23 Saloynne sa7ay 
\q2 medhettanaappe kase 
\q2 Beni mernaasofe 
\q2 tani shuumettadis. 
\q1  
\v 24 Wogga gita abbati baynda wode, 
\q2 haaththa pulttoti 
\q2 dhuuqqanaappe kase 
\q2 tani yelettadis. 
\q1  
\v 25 Zumatinne zumbullati 
\q2 medhettanaappe 
\q2 kase tani yelettadis. 
\q1  
\v 26 GODAY sa7anne 
\q2 sa7a bolla diza dembata 
\q2 woykko alame bolla diza gudullata 
\q2 medhdhanaappe kase tani yelettadis. 
\q1  
\v 27 GODAY salota miccida wodenne 
\q2 gita abbatappe bollara 
\q2 salo gufanththo giigsida wode 
\q2 tani heen de7ays. 
\q1  
\v 28 GODAY shaarata bollan 
\q2 woththida wode, 
\q2 gita abbaa pulttota 
\q2 dhuussida wode, 
\q2  
\v 29 abbaa haaththati 
\q2 banttas imettida zawappe 
\q2 pinnidi aadhdhontta mala 
\q2 zawa woththida wode, 
\q2 sa7as yoch yeggida wode, 
\q2  
\v 30 he wode tani iza matan 
\q2 waanna oosanchcha; 
\q2 ubbaa gallas tani 
\q2 ufayssan kumays; 
\q2 tanikka iza sinththan ufayettays. 
\q1  
\v 31 Izas gidida alame ubbaan 
\q2 ta ufayettays; 
\q2 asaa naytankka ta ufayettays. 
\b  
\q1  
\v 32 «Ha7ikka ta naytoo! 
\q2 Tani gizayssa ezgite; 
\q2 ta oge naagizayti anjjettidayta. 
\q1  
\v 33 Ta timirte siyite; 
\q2 aadho eranchchata gidite; 
\q2 wuda dhayopite. 
\q1  
\v 34 Tani yootizayssa siyiza asi, 
\q2 hach hach ta pengen beettiza asi, 
\q2 taso gelizasonkka 
\q2 naagiza asi anjjettidaade. 
\q1  
\v 35 Tana demmiday de7o demmees; 
\q2 GODAAPPE izi saba demmees. 
\q1  
\v 36 Gido attiin tana 
\q2 demmontta aggida asi 
\q2 bana qohees; 
\q2 tana ixxiza ubbati 
\q2 hayqo siiqeettes» gadus. 
\c 9  
\s1 Aadho Erateththinne Eeyateth 
\q1  
\v 1 Aadho erateththaya 
\q1 baas keeth keexxadus; 
\q2 keeththas laappun 
\q2 tuussata essadus. 
\q1  
\v 2 Iza modhdho mehe shukkadus; 
\q2 woyne ushshu aggadus; 
\q2 maaddaka giigsadus. 
\q1  
\v 3 Histtada asaa xeyganaas 
\q2 ba macca aylleta kiittadus. 
\q2 Iza katamayppe dhoqqa soon 
\q2 eqqada xeygadus; 
\q1  
\v 4 «Inttenoo! Eray paccidayto 
\q2 haa gelite!» gadus. 
\q2 Eeyatakka iza, 
\q1  
\v 5 «Haa yiidi ta qumaa miite; 
\q2 tani aggida 
\q2 woyne ushshaaka uyite! 
\q1  
\v 6 Intte eeyateththa ogeza aggite; 
\q2 intte shemppora paxa de7ana; 
\q2 akeeka ogen hemettite» gadus. 
\q1  
\v 7 Qilcciza as seeriza asi ubbay 
\q2 baas cashshe kallana; 
\q2 iita as zorizaadeyka 
\q2 baas kawuyana. 
\q1  
\v 8 Qilcciza as zoroppa; 
\q2 ne iza zorikko izi nena ixxana. 
\q2 Aadho eranchcha as seera; 
\q2 ne iza seerikko izi nena dosana. 
\q1  
\v 9 Aadho eranchcha as tamaarsa; 
\q2 histtiko izi kaseyssafekka 
\q2 aadho eranchcha gidana. 
\q2 Xillo as tamaarsa; 
\q2 histtiko izi erateth gujjana. 
\b  
\q1  
\v 10 Aadho erateththas koyroy 
\q2 GODAAS yashshateththa; 
\q2 Geeshshaza eroykka akeeka.\x - \xo 9:10 \xt Iyo 28:28; Maza 111:10; Leemi 1:7\x* 
\q1  
\v 11 Ta gaason nees barey aduqqana; 
\q2 nees de7o layththayka gujettana. 
\q1  
\v 12 Neni aadho eranchcha gidikko 
\q2 go7ettana; 
\q2 ne qilccizaade gidikko qohettana. 
\b  
\q1  
\v 13 Eeya maccassi wocama darawus; 
\q2 iza bana haarukku; 
\q2 iza aykkoka erukku. 
\q1  
\v 14 Iza ba karen utta pe7awus; 
\q2 katama giddon dhoqqaso 
\q2 keza uttawus. 
\q1  
\v 15 Heera aadhdhi 
\q2 ba oge bizayta xeygawus. 
\q1  
\v 16 Izakka wozina pacetas, 
\q2 «Inttenoo! akeekay paccidayto 
\q2 taakko haa yiite. 
\q1  
\v 17 Kaysi uyiza haaththi mal7ees; 
\q2 geeman miza qumaykka 
\q2 suukesees» gawus. 
\q1  
\v 18 Gido attiin hayqqida asay 
\q2 heen de7izayssa, 
\q2 izi imaththatikka duufo giddon 
\q2 dizayssa istti erettenna. 
\c 10  
\s1 Solomoone Leemisota 
\q1  
\v 1 Hayti Solomoone leemisota. 
\q2 Aadho erateththi diza nay 
\q2 ba aawa ufayssees; 
\q2 gido attiin eeya nay 
\q2 ba aayo ceecisees. 
\q1  
\v 2 Bessontta ogera yida 
\q2 aqotay go7enna; 
\q2 gido attiin xilloteththi 
\q2 hayqoppe ashshees. 
\q1  
\v 3 GODAY xillota gafisenna; 
\q2 gido attiin nagaranchchata 
\q2 amo calqamissana. 
\q1  
\v 4 Azallateththi manqisees; 
\q2 minni oosoy gidikko duresees. 
\q1  
\v 5 Aadho eranchchay 
\q2 kath wodera shiishshees; 
\q2 kath shiishshiza wode dhiskiza 
\q2 asi gidikko kawuyees. 
\q1  
\v 6 Xillo asi anjjettees; 
\q2 iita asa doona 
\q2 makkallateththi gordees. 
\q1  
\v 7 Xillota sunththay 
\q2 anjjon xeygettishe daana; 
\q2 iitata sunththi gidikko dogettana. 
\q1  
