\id 1JN
\h 1 يُوحَانَّا
\toc1 1 يُوحَانَّا
\toc2 1 يُوحَانَّا
\toc3 1 يُوح.
\mt1 1 يُوحَانَّا
\c 1
\s1 أَوَاڒْ ن ثُوذَارْثْ
\m 
\v 1 ونِّي ثُوغَا ذِينْ زڭْ ؤُمزْوَارُو، ذ نتَّا إِ ذ أَومْ نتّْبَارّحْ: ونِّي نسْڒَا ذ ونِّي نژْرَا س ثِيطَّاوِينْ نّغْ، ذ ونِّي نثْوَاڒَا ؤُ نْحَاذَا ث س إِفَاسّنْ نّغْ ذ ونِّي إِدْجَانْ ذ أَوَاڒْ إِدَّارنْ. \x ◘ \xo 1:‏1 \xt لك. 24‏:‏39؛ يُوح. 20‏:‏27؛ يُوح. 1‏:‏1، 14؛ ڒخ. 13‏:‏26؛ 2 بُط. 1‏:‏16. \x*
\v 2 أَقَا ثُوذَارْثْ ثضْهَارْ-د، نشِّينْ نژْرَا إِ-ت، ؤُشَا نْشهّذْ ؤُ نتّْبَارّحْ أَومْ ثُوذَارْثْ إِتّْذُومَانْ، ثنِّي ثُوغَا أَكْ-ذ بَابَاثْنغْ ؤُشَا ثتّْوَاسَّارْڭبْ-د إِ نشِّينْ.
\v 3 مِينْ نژْرَا ذ مِينْ نسْڒَا، أَذْ أَومْ ث-إِ-د-نسّْشنْ، حِيمَا عَاوذْ كنِّيوْ أَذْ ثِيڒِيمْ ذڭْ ؤُمُونِي أَكِيذْنغْ، ؤُشَا أَمُونِي نّغْ أَكْ-ذ بَابَاثْنغْ ؤُ أَكْ-ذ مِّيسْ يَاسُوع لْمَاسِيحْ.
\v 4 أَقَا نتَّارِي مَانْ أَيَا إِ كنِّيوْ، حِيمَا ڒفْرَاحثْ نّغْ أَذْ ثِيڒِي ثكْمڒْ.
\b
\s1 أَربِّي ذ ثَافَاوْثْ
\m 
\v 5 ذ وَا ذ ڒخْبَارْ أَصبْحَانْ إِ زَّايسْ نسْڒَا ؤُشَا أَذْ أَومْ نْبَارّحْ: أَربِّي ذ ثَافَاوْثْ، نتَّا وَارْ ذَايسْ بُو جُّورّثْ ن ثَادْجسْثْ. \x ◘ \xo 1:‏5 \xt يُوح. 1‏:‏9؛ 8‏:‏12؛ 9‏:‏5؛ 12‏:‏35، 36. \x*
\v 6 مَاڒَا نقَّارْ، أَقَا غَارْنغْ أَمُونِي أَكِيذسْ، ؤُشَا نڭُّورْ ذِي ثَادْجسْثْ، أَقَا نسّْخَارِّيقْ، وَارْ نْضفَّارْ شَا ثِيذتّْ.
\v 7 مَاشَا مَاڒَا نُويُورْ ذِي ثْفَاوْثْ، أَمْ نتَّا ذِي ثْفَاوْثْ، غَارْنغْ أَمُونِي أَكْ-ذ وَايَاوْيَا، ؤُشَا أَذْ ثَافْ إِذَامّنْ ن يَاسُوع، مِّيسْ، أَذْ أَنغْ سِّيزْذڭنْ زِي مَارَّا دّْنُوبْ نّغْ. \x ◘ \xo 1:‏7 \xt عبر. 9‏:‏14؛ 1 بُط. 1‏:‏19؛ أَسَا. 1‏:‏5. \x*
\m 
\v 8 مَاڒَا نقَّارْ، وَارْ ذَايْنغْ بُو دّْنُوبْ، أَقَا نسّْخَارِّيقْ خْ يِيخفْ نّغْ ؤُشَا ثِيذتّْ وَارْ ذَايْنغْ ثدْجِي. \x ◘ \xo 1:‏8 \xt 1 إِج. 8‏:‏46؛ 2 إِم. 6‏:‏36؛ أَيُوبْ 9‏:‏2؛ إِزهد. 143‏:‏2؛ أَوڒن. 20‏:‏9؛ أَمب. 7‏:‏20. \x*
\v 9 مَاشَا مَاڒَا ننْعمْ س دّْنُوبْ نّغْ، أَقَا نتَّا ذ أَمْثِيقِّي ذ أَمْسڭَّاذْ حِيمَا أَذْ أَنغْ إِغْفَارْ دّْنُوبْ نّغْ ؤُشَا أَذْ أَنغْ إِسِّيزْذڭْ زِي مَارَّا مِينْ وَارْ إِسڭّْذنْ. \x ◘ \xo 1:‏9 \xt إِزهد. 32‏:‏5؛ أَوڒن. 28‏:‏13. \x*
\v 10 مَاڒَا نقَّارْ: ’نشِّينْ وَارْ ذَايْنغْ بُو دّْنُوبْ!‘، نتَّارَّا إِ-ث ذ بُو-إِخَارِّيقنْ ؤُشَا أَوَاڒْ نّسْ وَارْ ذَايْنغْ إِدْجِي.
\b
\b
\c 2
\s1 ؤُيُورمْ ذِي ثْفَاوْثْ
\m 
\v 1 \bd \bdit أَ\bdit* إِحنْجِيرنْ إِنُو\bd*، ؤُرِيغْ أَيَا إِ كنِّيوْ، حِيمَا وَارْ ثْخطِّيمْ شَا. ؤُشَا مَاڒَا إِخْضَا شَا ن إِجّنْ، أَقَا غَارْنغْ ؤُمْسصْڒَاحْ، ذ ونِّي إِدْجَانْ غَارْ بَابَاثْنغْ، يَاسُوع لْمَاسِيحْ، أَمْسڭَّاذْ. \x ◘ \xo 2:‏1 \xt 1 تِيم. 2‏:‏5؛ عبر. 7‏:‏25. \x*
\v 2 مَاغَارْ نتَّا ذ أَصْڒَاحْ إِ دّْنُوبْ نّغْ، وَارْ إِدْجِي خْ دّْنُوبْ نّغْ وَاهَا، مَاشَا عَاوذْ إِ يِينِّي ن دُّونشْثْ مَارَّا. \x ◘ \xo 2:‏2 \xt يُوح. 4‏:‏42؛ رُوم. 3‏:‏25؛ 2 كُور. 5‏:‏18؛ كُول. 1‏:‏20؛ 1 يُوح. 4‏:‏10، 14. \x*
\m 
\v 3 س مَانْ أَيَا إِ نتّْوَاڒَا بلِّي أَقَا نسّنْ إِ-ث، مَاڒَا نطّفْ ذِي ثْوصَّا نّسْ.
\v 4 ونِّي إِقَّارنْ: ”نشّْ سّْنغْ ث!“، مَاشَا وَارْ إِطِّيفْ شَا ذِي ثْوصَّا نّسْ، نتَّا ذ بُو-إِخَارِّيقنْ ؤُشَا ثِيذتّْ وَارْ ذَايسْ ثدْجِي. \x ◘ \xo 2:‏4 \xt 1 يُوح. 4‏:‏20. \x*
\v 5 مَاشَا ونِّي إِتّطّْفنْ ذڭْ وَاوَاڒْ نّسْ، أَذْ ذَايسْ ثْكمّڒْ ثَايْرِي ن أَربِّي س ثِيذتّْ. س مَانْ أَيَا نسّنْ، بلِّي أَقَا نشِّينْ ذَايسْ. \x ◘ \xo 2:‏5 \xt يُوح. 13‏:‏35. \x*
\v 6 ونِّي إِقَّارنْ: ’نشّْ ذَايسْ!‘، إِتّْخصَّا أَذْ يُويُورْ أَمْ مَامّشْ ثُوغَا إِڭُّورْ نتَّا. \x ◘ \xo 2:‏6 \xt يُوح. 13‏:‏15؛ 1 بُط. 2‏:‏21. \x*
\m 
\v 7 \bd \bdit أَ\bdit* إِمْعِيزّنْ إِنُو\bd*، وَارْ ذ أَومْ تَّارِيغْ شَا ثَاوْصيّثْ ن جْذِيذْ، مَاشَا ثَاوْصيّثْ ثَاقْذِيمْثْ إِ ثُوغَا غَارْومْ زڭْ ؤُمزْوَارُو. ثَاوْصيّثْ-أَ ثَاقْذِيمْثْ ذ أَوَاڒْ إِ ثُوغَا ثسْڒِيمْ. \x ◘ \xo 2:‏7 \xt 1 يُوح. 3‏:‏23؛ 2 يُوح. 5. \x*
\v 8 وَاخَّا أَمنِّي أَذْ أَومْ د-أَرِيغْ ثَاوْصيّثْ ن جْذِيذْ، ثنِّي إِدْجَانْ ذ ثِيذتّْ ذَايسْ ؤُ ذَايْومْ، مِينْزِي ثَادْجسْثْ ثعْذُو ؤُشَا ثَافَاوْثْ ن ثِيذتّْ أَقَا ثتّضْهَارْ-د ڒخُّو. \x ◘ \xo 2:‏8 \xt يُوح. 13‏:‏34؛ 15‏:‏12. \x*
\m 
\v 9 ونِّي إِقَّارنْ بلِّي أَقَا-ث ذِي ثْفَاوْثْ، \add مَاشَا\add* إِشَارّهْ ؤُمَاسْ، نتَّا أَقَا-ث ذِي ثَادْجسْثْ أَڒْ إِضَا.
\v 10 ونِّي إِتّخْسنْ ؤُمَاسْ، أَذْ إِقِّيمْ ذِي ثْفَاوْثْ ؤُشَا وَارْ ذَايسْ بُو ڒفْضِيحثْ إِ زِي غَا إِنْقَارْذْ \add ؤُمَاسْ\add*. \x ◘ \xo 2:‏10 \xt يُوح. 12‏:‏35؛ 1 يُوح. 3‏:‏14. \x*
\v 11 مَاشَا ونِّي إِشَارّْهنْ ؤُمَاسْ، أَقَا-ث ذِي ثَادْجسْثْ ؤُشَا إِڭُّورْ ذِي ثَادْجسْثْ، وَارْ إِسِّينْ مَانِي غَا إِرَاحْ، مِينْزِي ثَادْجسْثْ ثسّْذَارْغڒْ ثِيطَّاوِينْ نّسْ.
\b
\s1 ثَايْرِي ن أَربِّي، بَابَاثْنغْ
\m 
\v 12 أَذْ أَومْ د-أَرِيغْ، \bd \bdit أَ\bdit* إِحنْجِيرنْ\bd*، مِينْزِي دّْنُوبْ نْومْ تّْوَاغْفَارنْ أَومْ ذِي طّْوعْ ن يِيسمْ نّسْ. \x ◘ \xo 2:‏12 \xt لك. 24‏:‏47؛ ڒخ. 4‏:‏12؛ 13‏:‏38. \x*
\m 
\v 13 أَذْ أَومْ د-أَرِيغْ، \bd \bdit أَ\bdit* إِبَابَاثنْ\bd*، مِينْزِي أَقَا ثسّْنمْ ونِّي إِدْجَانْ زڭْ ؤُمزْوَارُو.
\m أَذْ أَومْ د-أَرِيغْ، \bd \bdit أَ\bdit* إِبْڒِيغنْ\bd*، مِينْزِي أَقَا ثْغلّْبمْ خْ ؤُمْعفَّانْ.
\b
\m أَقَا ؤُرِيغْ أَومْ-د، \bd \bdit أَ\bdit* إِحُوذْرِييّنْ\bd*، مِينْزِي ثسّْنمْ بَابَاثْنغْ.
\m 
\v 14 أَقَا ؤُرِيغْ أَومْ-د، \bd \bdit أَ\bdit* إِبَابَاثنْ\bd*، مِينْزِي ثسّْنمْ ونِّي إِدْجَانْ زڭْ ؤُمزْوَارُو.
\m أَقَا ؤُرِيغْ أَومْ-د، \bd \bdit أَ\bdit* إِبْڒِيغنْ\bd*، مِينْزِي أَقَا كنِّيوْ ثْجهْذمْ ؤُشَا أَوَاڒْ ن أَربِّي إِزدّغْ ذَايْومْ ؤُشَا ثْغلّْبمْ خْ ؤُمْعفَّانْ.
\b
\m 
\v 15 وَارْ تّخْسمْ شَا دُّونشْثْ ؤُڒَا ذ مِينْ إِدْجَانْ ذِي دُّونشْثْ، مِينْزِي مَاڒَا شَا ن إِجّنْ إِتّخْسْ دُّونشْثْ، ثَايْرِي ن بَابَاثْنغْ وَارْ ذَايسْ ثدْجِي. \x ◘ \xo 2:‏15 \xt ڭال. 1‏:‏10؛ يَاع. 4‏:‏4. \x*
\v 16 مِينْزِي مَارَّا مِينْ إِدْجَانْ ذِي دُّونشْثْ - أَقَا-ث ذ نّشْوثْ ن دَّاثْ ذ نّشْوثْ ن ثِيطَّاوِينْ ذ ثُوفّثْ ن دُّونشْثْ\add -أَ\add* - وَارْ د-إِتِّيسْ شَا زِي بَابَاثْنغْ، مَاشَا زِي دُّونشْثْ.
\v 17 ؤُشَا دُّونشْثْ ثْعدُّو ؤُڒَا ذ نّشْوَاثْ نّسْ، مَاشَا ونِّي إِتّڭّنْ مِينْ إِخْسْ أَربِّي، أَذْ إِقِّيمْ إِ ڒبْذَا. \x ◘ \xo 2:‏17 \xt إِزهد. 90‏:‏10؛ إِشا. 40‏:‏6؛ 1 كُور. 7‏:‏31؛ يَاع. 1‏:‏10؛ 4‏:‏14؛ 1 بُط. 1‏:‏24. \x*
\b
\s1 لْمَاسِيحْ إِسّْخَارِّيقنْ
\m 
\v 18 \bd \bdit أَ\bdit* إِحنْجِيرنْ إِنُو\bd*، أَقَا ڒْوقْثْ ثَانڭَّارُوثْ ثِيوضْ-د، ؤُشَا أَمْ ثسْڒِيمْ بلِّي أَذْ د-يَاسْ لْمَاسِيحْ أَفَالْسُو، أَمنِّي ڒخُّو ضْهَارنْ-د أَطَّاسْ ن إِمَاسِيحنْ إِفَالْسُوثنْ. س ؤُينِّي نسّنْ بلِّي ڒْوقْثْ ثَانڭَّارُوثْ أَقَا ثِيوضْ-د. \f ◼ \fr 2:‏18 \ft \bd ’لْمَاسِيحْ أَفَالْسُو‘\bd* - خْزَارْ 1 يُوحْ. 2:18، 22؛ 4:3. أَقَا ذِينْ أَطَّاسْ ن إِوْذَانْ إِنِّي إِقَّارنْ: ’لْمَاسِيحْ وَارْ إِدْجِي ذ أَربِّي! نتَّا ذ أَنَابِي!‘ مَانْ أَيَا إِخْسْ أَذْ يِينِي بلِّي نِيثْنِي وَارْ سّْثعْثَارِيفنْ ؤُ وَارْ نعّْمنْ شَا، أَقَا أَربِّي يُوسَا-د ذِي أَرِّيمثْ ن يَاسُوع لْمَاسِيحْ أَمْ مَامّشْ إِ ذ أَنغْ إِسّڒْمذْ وذْلِيسْ إِقدّْسنْ. س ؤُينِّي تّڭّنْ نِيثْنِي أَمْ مَامّشْ إِتّڭّْ لْمَاسِيحْ أَفَالْسُو، وَارْ شهّْذنْ شَا أَقَا يَاسُوع لْمَاسِيحْ يُوسَا-د ذِي أَرِّيمثْ. س ؤُينِّي ضفَّارنْ ث ذڭْ إِخَارِّيقنْ نّسْ، نِيثْنِي ذ إِحنْجِيرنْ ن دّجَّاڒْ.\f*  \x ◘ \xo 2:‏18 \xt مت. 24‏:‏5؛ 2 تس. 2‏:‏3. \x*
\v 19 فّْغنْ-د زَّايْنغْ، مَاشَا وَارْ ثنْ ثُوغِي زَّايْنغْ. معْلِيكْ نِيثْنِي ثُوغَا زَّايْنغْ، أَذْ إِڒِي قِّيمنْ أَكِيذْنغْ. مَاشَا نِيثْنِي فّْغنْ-د زَّايْنغْ، حِيمَا أَذْ إِبَانْ بلِّي نِيثْنِي مَارَّا وَارْ دْجِينْ شَا زَّايْنغْ. \x ◘ \xo 2:‏19 \xt إِزهد. 41‏:‏10؛ ڒخ. 20‏:‏30؛ 1 كُور. 11‏:‏19. \x*
\v 20 أَقَا غَارْومْ أَذْهَانْ ن ؤُمْقدَّاسْ ؤُشَا ثسّْنمْ أَذْ ثْفَارْزمْ كُوڒْ إِجّْ ن بْنَاذمْ. \x ◘ \xo 2:‏20 \xt إِزهد. 45‏:‏8؛ 133‏:‏2؛ 2 كُور. 1‏:‏21؛ عبر. 1‏:‏9. \x*
\v 21 وَارْ ذ أَومْ ؤُرِيغْ مِينْزِي وَارْ ثسِّينمْ شَا ثِيذتّْ، مَاشَا مِينْزِي أَقَا ثتّسّْنمْ ت، ؤُ ثسّْنمْ \add عَاوذْ\add* ؤُڒَا ذ إِجّْ ن ؤُخَارِّيقْ وَارْ د-إِتّفّغْ شَا زِي ثِيذتّْ.
\v 22 وِي إِدْجَانْ ذ بُو-إِخَارِّيقنْ مْغِيرْ ونِّي إِنْكَارنْ بلِّي يَاسُوع ذ لْمَاسِيحْ! ذ وَا ذ لْمَاسِيحْ أَفَالْسُو، ونِّي إِنْكَارنْ بَابَاسْ ذ مِّيسْ. \f ◼ \fr 2:‏22 \ft \bd ’لْمَاسِيحْ أَفَالْسُو‘\bd* - خْزَارْ 1 يُوحْ. 2:18 ذ 1 يُوحْ. 4:3.\f*
\v 23 مَارَّا ونِّي إِنْكَارنْ مِّيسْ وَارْ يُومِينْ عَاوذْ ذِي بَابَاسْ. ونِّي إِشهّْذنْ إِ مِّيسْ، إِشهّذْ عَاوذْ إِ بَابَاسْ. \x ◘ \xo 2:‏23 \xt لك. 12‏:‏9؛ 2 تِيم. 2‏:‏12. \x*
\v 24 أجّْ أَذْ ذَايْومْ إِقِّيمْ مِينْ ثسْڒِيمْ زڭْ ؤُمزْوَارُو. مَاڒَا إِقِّيمْ ذَايْومْ مِينْ ثسْڒِيمْ زڭْ ؤُمزْوَارُو، أَذْ ثقِّيممْ كنِّيوْ عَاوذْ ذِي بَابَاسْ ؤُ ذِي مِّيسْ.
\v 25 ثَا ذ ثِيكّسْثْ ن وَاوَاڒْ إِ ذ أَنغْ إِوْشَا: ثُوذَارْثْ إِتّْذُومَانْ.
\m 
\v 26 مَانْ أَيَا ؤُرِيغْ أَومْ-ث-إِ-د خْ يِينِّي كنِّيوْ إِخدّْعنْ.
\v 27 مَاڒَا أَذْهَانْ إِ زَّايسْ ثطّْفمْ أَذْ إِقِّيمْ ذَايْومْ، وَارْ ثحْذَاجمْ أَذْ كنِّيوْ إِسّڒْمذْ حذْ. مِينْزِي أَذْهَانْ ن أَربِّي، أَذْ كنِّيوْ إِسّڒْمَاذْ ذِي مَارَّا، ؤُشَا نتَّا ذ ثِيذتّْ وَارْ ذَايسْ دْجِينْ إِخَارِّيقنْ. خنِّي قِّيممْ ذَايسْ، \add ذِي لْمَاسِيحْ\add*، أَمْ مَامّشْ إِ ذ أَومْ إِسّڒْمذْ نتَّا. \x ◘ \xo 2:‏27 \xt إِرْم. 31‏:‏34؛ عبر. 8‏:‏11. \x*
\b
\m 
\v 28 خنِّي ڒخُّو، \bd \bdit أَ\bdit* إِحنْجِيرنْ إِنُو\bd*، قِّيممْ ذَايسْ، حِيمَا وَارْ نتّْسضْحِي شَا قِيبَاتْشْ نّسْ خْ مِينِّي د غَا إِضْهَارْ، مَاشَا أَذْ غَارْنغْ ثِيڒِي تِّيقّثْ غَارْ ثْوَاسِيثْ نّسْ. \x ◘ \xo 2:‏28 \xt مك. 8‏:‏38؛ 1 يُوح. 3‏:‏2. \x*
\v 29 مَاڒَا ثسّْنمْ، بلِّي نتَّا ذ أَمْسڭَّاذْ، سْنمْ عَاوذْ بلِّي مَارَّا وِي إِتّڭّنْ ثَاسڭْذَا، أَقَا \add إِتّْوَاخْڒقْ-د\add* زَّايسْ.
\b
\b
\c 3
\s1 ثَارْوَا ن أَربِّي
\m 
\v 1 خْزَارْ، مشْحَاڒْ ثمْغَارْ ثَايْرِي إِ زِي ذ أَنغْ إِتّخْسْ بَابَاثْنغْ، أَڒَامِي إِڒَاغَا ؤُ إِڭَّا أَنغْ ثَارْوَا. س ؤُينِّي دُّونشْثْ وَارْ ذ أَنغْ ثسِّينْ شَا، مِينْزِي وَارْ ث ثسِّينْ شَا. \x ◘ \xo 3:‏1 \xt يُوح. 1‏:‏12. \x*
\v 2 \bd \bdit أَ\bdit* إِمْعِيزّنْ إِنُو\bd*، ڒخُّو نشِّينْ ذ ثَارْوَا ن أَربِّي إِ ندْجْ، وَارْ د-إِضْهَارْ عَاذْ مِينْ غَا نِيڒِي. أَقَا نسّنْ خْمِي د غَا إِبَانْ نتَّا، أَذْ نِيڒِي ذِي صِّيفثْ نّسْ، مِينْزِي أَذْ ث نْژَارْ أَمْ مَامّشْ إِدْجَا نتَّا. \x ◘ \xo 3:‏2 \xt إِشا. 56‏:‏5؛ مت. 5‏:‏12؛ يُوح. 1‏:‏12؛ رُوم. 8‏:‏15، 18؛ 2 كُور. 4‏:‏17؛ ڭال. 3‏:‏26؛ 4‏:‏6؛ فِيل. 3‏:‏21؛ كُول. 3‏:‏4. \x*
\v 3 مَارَّا ونِّي غَارْ إِدْجَا ؤُسِيثمْ-أَ ذَايسْ \add ذڭْ وُوڒْ نّسْ\add*، أَذْ إِسِّيزْذڭْ إِخفْ نّسْ، أَمْ مَامّشْ إِدْجَا نتَّا ذ أَمزْذَاڭْ.
\v 4 مَارَّا ونِّي إِتّڭّنْ دّْنُوبْ، إِتّڭّْ ڒْمُوعْصِييّثْ، مِينْزِي مَارَّا دّنْبْ ذ ڒْمُوعْصِييّثْ. \x ◘ \xo 3:‏4 \xt 1 يُوح. 5‏:‏17. \x*
\v 5 ثسّْنمْ بلِّي نتَّا إِبَانْ-د، حِيمَا أَذْ إِكّسْ دّْنُوبْ نّغْ: نتَّا وَارْ ذَايسْ بُو دّْنُوبْ. \x ◘ \xo 3:‏5 \xt إِشا. 53‏:‏9، 12؛ 2 كُور. 5‏:‏21؛ 1 بُط. 2‏:‏22؛ 1 تِيم. 1‏:‏15. \x*
\v 6 مَارَّا وِي ذَايسْ إِ غَا إِقِّيمنْ، وَارْ إِتّڭّْ شَا دّْنُوبْ. مَارَّا وِي إِتّڭّنْ دّْنُوبْ، وَارْ ث إِژْرِي، وَارْ ث إِسِّينْ.
\v 7 \bd \bdit أَ\bdit* إِحنْجِيرنْ إِنُو\bd*، وَارْ تّجِّيمْ أَذْ كنِّيوْ إِخَارْوضْ حذْ. ونِّي إِتّڭّنْ ثَاسڭْذَا ذ نتَّا ذ أَمْسڭَّاذْ أَمْ مَامّشْ عَاوذْ لْمَاسِيحْ ذ أَمْسڭَّاذْ. \x ◘ \xo 3:‏7 \xt 1 يُوح. 2‏:‏29. \x*
\m 
\v 8 ونِّي إِتّڭّنْ دّْنُوبْ ذ نتَّا زِي شِّيطَانْ، مِينْزِي شِّيطَانْ ثُوغَا ذ أَمذْنُوبْ زڭْ ؤُمزْوَارُو. إِ مَانْ أَيَا إِ د-إِضْهَارْ مِّيسْ ن أَربِّي: حِيمَا أَذْ إِسّخْسَارْ ڒخْذَايمْ ن شِّيطَانْ.
\m 
\v 9 مَارَّا ونِّي د-إِتّْوَاخڒْقنْ زِي أَربِّي، وَارْ إِتّڭّْ شَا دّْنُوبْ، مِينْزِي زَّارِيعثْ نّسْ أَقَا-ت ذَايسْ ؤُشَا وَارْ إِزمَّارْ أَذْ إِخْضَا، مِينْزِي إِتّْوَاخْڒقْ-د زِي أَربِّي. \x ◘ \xo 3:‏9 \xt 1 بُط. 1‏:‏23؛ 1 يُوح. 5‏:‏18. \x*
\v 10 ذِي مَانْ أَيَا أَذْ د-ضْهَارنْ ثَارْوَا ن أَربِّي ذ ثَارْوَا ن شِّيطَانْ: مَارَّا ونِّي وَارْ إِتّڭّنْ ثَاسڭْذَا ؤُ وَارْ إِتّخْسنْ ؤُمَاسْ، وَارْ إِدْجِي شَا زِي أَربِّي.
\v 11 مَاغَارْ ثَا ذ ثَاوْصِييّثْ إِ ثُوغَا ثسْڒِيمْ زڭْ ؤُمزْوَارُو بلِّي أَذْ ثخْسمْ إِجّنْ ونّغْنِي!‘ \x ◘ \xo 3:‏11 \xt يُوح. 13‏:‏34؛ 15‏:‏12؛ 1 يُوح. 3‏:‏23. \x*
\v 12 وَارْ إِدْجِي أَمْ قَايِينْ ونِّي إِدْجَانْ زڭْ ؤُمْعفَّانْ ؤُشَا إِنْغَا ؤُمَاسْ. مَايمِّي إِنْغَا ؤُمَاسْ؟ س مِينْزِي ڒخْذَايمْ نّسْ ثُوغَا أَثنْثْعفّْننْثْ ؤُشَا ثِينِّي ن ؤُمَاسْ سڭّْذنْثْ. \x ◘ \xo 3:‏12 \xt أَمز. 4‏:‏8؛ 27‏:‏41؛ عبر. 11‏:‏4. \x*
\v 13 وَارْ ثذْهِيشمْ شَا، \add أَ\add* أَيْثْمَا، مَاڒَا دُّونشْثْ ثْشَارْهْ إِ كنِّيوْ. \x ◘ \xo 3:‏13 \xt يُوح. 15‏:‏18. \x*
\v 14 نشِّينْ نسّنْ، أَقَا نژْوَا زِي ڒْموْثْ غَارْ ثُوذَارْثْ، مِينْزِي نخْسْ أَوْمَاثنْ نّغْ. ونِّي وَارْ إِتّخْسنْ ؤُمَاسْ، أَذْ إِقِّيمْ ذِي ڒْموْثْ. \x ◘ \xo 3:‏14 \xt 1 يُوح. 2‏:‏10. \x*
\v 15 مَارَّا وِي إِشَارّْهنْ ؤُمَاسْ ذ أَقتَّاڒْ، ؤُشَا كنِّيوْ ثسّْنمْ بلِّي ثُوذَارْثْ إِتّْذُومَانْ وَارْ ثْزمَّارْ أَذْ ثقِّيمْ ذڭْ إِجّْ ن ؤُقتَّاڒْ. \x ◘ \xo 3:‏15 \xt مت. 5‏:‏21؛ ڭال. 5‏:‏21. \x*
\v 16 زِي مَانْ أَيَا نسّنْ ثَايْرِي نّسْ إِ نشِّينْ، أَقَا نتَّا إِسَّارْسْ ثُوذَارْثْ نّسْ ذڭْ ومْشَانْ نّغْ. عَاوذْ إِتّْخصَّا أَنغْ نِيشَانْ أَذْ نسَّارْسْ ثُوذَارْثْ نّغْ خْ أَيْثْمَاثْنغْ. \x ◘ \xo 3:‏16 \xt يُوح. 15‏:‏13؛ أَفا. 5‏:‏2. \x*
\v 17 ونِّي غَارْ إِدْجَا أَڭْڒَا ن دُّونشْثْ ؤُشَا إِتّْوَاڒَا ؤُمَاسْ إِزْڒضْ، خنِّي إِقّنْ خَاسْ ؤُڒْ نّسْ، مَامّشْ إِ غَا ثزْذغْ ثَايْرِي ن أَربِّي ذَايسْ؟ \x ◘ \xo 3:‏17 \xt أَعَوذ. 15‏:‏7؛ لك. 3‏:‏11؛ يَاع. 2‏:‏15. \x*
\m 
\v 18 \bd \bdit أَ\bdit* إِحنْجِيرنْ إِنُو\bd*، أجّْ أَنغْ وَارْ نتّخْسْ إِجّنْ ونّغْنِي س وَاوَاڒْ نِيغْ س إِڒسْ، مَاشَا س ڒخْذَايمْ ؤُ ذِي ثِيذتّْ.
\v 19 س مَانْ أَيَا نسّنْ أَقَا نشِّينْ زِي ثِيذتّْ ؤُشَا أَذْ نسّقْنعْ ؤُڒَاونْ نّغْ قْبڒْ إِ د غَا يَاسْ.
\v 20 مِينْزِي مَاڒَا إِحْكمْ وُوڒْ نّغْ خَانغْ، مشْحَاڒْ ذ أَمقّْرَانْ أَربِّي خْ وُوڒْ نّغْ! أَقَا نتَّا إِسّنْ مَارَّا.
\v 21 \bd \bdit أَ\bdit* إِمْعِيزّنْ إِنُو\bd*، مَاڒَا ؤُڒْ نّغْ وَارْ خَانغْ إِحْكمْ، أَقَا غَارْنغْ تِّيقّثْ زَّاثْ إِ أَربِّي،
\v 22 ؤُشَا مَانْ ڒْحَاجّثْ إِ غَا نتَّارْ، أَذْ ت نكْسِي زَّايسْ، مِينْزِي نشِّينْ نْحطَّا ثِيوصَّا نّسْ ؤُشَا أَذْ نڭّْ مِينْ غَا يَارْضَانْ قِيبَاتْشْ نتَّا. \x ◘ \xo 3:‏22 \xt إِرْم. 29‏:‏12؛ مت. 7‏:‏8؛ 21‏:‏22؛ مك. 11‏:‏24؛ لك. 11‏:‏9؛ يُوح. 14‏:‏13؛ 16‏:‏24؛ يَاع. 1‏:‏5؛ 1 يُوح. 5‏:‏14. \x*
\v 23 ذ ثَا ذ ثَاوْصيّثْ نّسْ بلِّي أَذْ نَامنْ ذڭْ يِيسمْ ن مِّيسْ يَاسُوع لْمَاسِيحْ ؤُشَا أَذْ نخْسْ إِجّْ ونّغْنِي أَمْ مَامّشْ إِ ذ أَنغْ يُومُورْ. \x ◘ \xo 3:‏23 \xt لَاوِي 19‏:‏18؛ مت. 22‏:‏39؛ يُوح. 6‏:‏29؛ 13‏:‏34، 35؛ 15‏:‏12؛ 17‏:‏3؛ أَفا. 5‏:‏2؛ 1 تس. 4‏:‏9؛ 1 بُط. 4‏:‏8؛ 1 يُوح. 4‏:‏21. \x*
\v 24 ونِّي إِحطَّانْ ثِيوصَّا نّسْ، أَذْ زَّايسْ إِتّْوَاحْضَا ؤُ نتَّا إِزدّغْ ذَايسْ. س مَانْ أَيَا نسّنْ بلِّي نتَّا إِتّْغِيمَا ذَايْنغْ، زِي أَرُّوحْ نّسْ إِ ذ أَنغْ إِوْشَا. \x ◘ \xo 3:‏24 \xt يُوح. 14‏:‏23؛ 15‏:‏10؛ 1 يُوح. 4‏:‏12. \x*
\b
\b
\c 4
\s1 قدْجْبمْ أَرُّوحَاثْ
\m 
\v 1 \bd \bdit أَ\bdit* إِمْعِيزّنْ إِنُو\bd*، وَارْ تِّيقّمْ شَا ذِي مَارَّا أَرُّوحَاثْ، مَاشَا قدْجْبمْ أَرُّوحَاثْ، مَا زِي أَربِّي إِ إِدْجَانْ، مِينْزِي أَطَّاسْ ن إِنَابِييّنْ إِسّْخَارِّيقنْ أَقَا فّْغنْ-د غَارْ دُّونشْثْ. \x ◘ \xo 4:‏1 \xt إِرْم. 29‏:‏8؛ مت. 7‏:‏15، 16؛ 24‏:‏4، 5، 24؛ 1 كُور. 14‏:‏29؛ أَفا. 5‏:‏6؛ كُول. 2‏:‏18؛ 2 بُط. 2‏:‏1؛ 2 يُوح. 7. \x*
\v 2 س مَانْ أَيَا أَذْ ثسّْنمْ أَرُّوحْ ن أَربِّي: مَارَّا أَرُّوحْ ونِّي إِشهّْذنْ بلِّي يَاسُوع لْمَاسِيحْ يُوسَا-د ذِي دَّاثْ أَقَا نتَّا زِي أَربِّي.
\v 3 مَارَّا أَرُّوحْ ونِّي وَارْ إِشهّْذنْ بلِّي يَاسُوع يُوسَا-د ذِي دَّاثْ، وَارْ إِدْجِي شَا زِي أَربِّي، مَاشَا زِي أَرُّوحْ ن لْمَاسِيحْ أَفَالْسُو ونِّي إِ خفْ ثسْڒَامْ أَذْ د-يَاسْ، أَقَا نتَّا ذَا ڒخُّو ذِي دُّونشْثْ. \f ◼ \fr 4:‏3 \ft \bd ’لْمَاسِيحْ أَفَالْسُو‘\bd* - خْزَارْ 1 يُوحْ. 2:18، 22؛ 4:3. أَقَا ذِينْ أَطَّاسْ ن إِوْذَانْ إِنِّي إِقَّارنْ: ’لْمَاسِيحْ وَارْ إِدْجِي ذ أَربِّي! نتَّا ذ أَنَابِي!‘ مَانْ أَيَا إِخْسْ أَذْ يِينِي بلِّي نِيثْنِي وَارْ سّْثعْثَارِيفنْ ؤُ وَارْ نعّْمنْ شَا، أَقَا أَربِّي يُوسَا-د ذِي أَرِّيمثْ ن يَاسُوع لْمَاسِيحْ أَمْ مَامّشْ إِ ذ أَنغْ إِسّڒْمذْ وذْلِيسْ إِقدّْسنْ. س ؤُينِّي تّڭّنْ نِيثْنِي أَمْ مَامّشْ إِتّڭّْ لْمَاسِيحْ أَفَالْسُو، وَارْ شهّْذنْ شَا أَقَا يَاسُوع لْمَاسِيحْ يُوسَا-د ذِي أَرِّيمثْ. س ؤُينِّي ضفَّارنْ ث ذڭْ إِخَارِّيقنْ نّسْ، نِيثْنِي ذ إِحنْجِيرنْ ن دّجَّاڒْ.\f*  \x ◘ \xo 4:‏3 \xt 2 تس. 2‏:‏7؛ 1 يُوح. 2‏:‏18، 22. \x*
\v 4 مَاشَا كنِّيوْ ذ ثَارْوَا ن أَربِّي إِ ثدْجَامْ، أَقَا ثْغلّْبمْ خَاسنْ، مِينْزِي ذ ونِّي إِدْجَانْ ذَايْومْ ذ أَمقّْرَانْ خْ ونِّي إِدْجَانْ ذِي دُّونشْثْ. \x ◘ \xo 4:‏4 \xt 2 إِج. 6‏:‏16؛ 2 إِم. 32‏:‏7؛ يُوح. 16‏:‏33\x*
\v 5 نِيثْنِي زِي دُّونشْثْ، س ؤُينِّي سَّاوَاڒنْ زِي دُّونشْثْ ؤُشَا دُّونشْثْ ثتّسْڒَا أَسنْ-د.
\v 6 أَقَا أَنغْ زِي أَربِّي. ونِّي إِسّْننْ أَربِّي، إِتّسْڒَا أَنغْ. ونِّي وَارْ إِدْجِينْ زِي أَربِّي وَارْ ذ أَنغْ إِتّسْڒِي شَا. س مَانْ أَيَا إِ غَا نسّنْ أَرُّوحْ ن ثِيذتّْ ذ أَرُّوحْ ن ؤُودَّارْ. \x ◘ \xo 4:‏6 \xt يُوح. 8‏:‏47؛ 10‏:‏27. \x*
\b
\s1 أَربِّي ذ ثَايْرِي
\m 
\v 7 \bd \bdit أَ\bdit* إِمْعِيزّنْ إِنُو\bd*، أجّْ أَنغْ أَذْ نخْسْ أَيَاوْيَا، مِينْزِي ثَايْرِي زِي أَربِّي، ؤُ مَارَّا ونِّي إِتّخْسنْ، ذ نتَّا إِتّْوَاخْڒقْ-د زِي أَربِّي ؤُشَا إِسّنْ أَربِّي.
\v 8 مِينْزِي أَربِّي ذ ثَايْرِي، ؤُ ونِّي وَارْ إِتّخْسنْ، وَارْ إِسِّينْ شَا أَربِّي.
\v 9 س مَانْ أَيَا ثضْهَارْ أَنغْ-د ثَايْرِي ن أَربِّي، بلِّي أَربِّي أَقَا إِسّكّْ-د أَينِّي ن مِّيسْ إِ غَارسْ غَارْ دُّونشْثْ، حِيمَا أَذْ زَّايسْ ندَّارْ. \x ◘ \xo 4:‏9 \xt يُوح. 3‏:‏16؛ رُوم. 5‏:‏8. \x*
\v 10 ذِي مَانْ أَيَا إِ ثدْجَا ثَايْرِي، وَارْ إِدْجِي بلِّي نشِّينْ نتّخْسْ أَربِّي، مَاشَا بلِّي نتَّا إِتّخْسْ أَنغْ ؤُشَا إِسّكّْ-د مِّيسْ ذ أَصْڒَاحْ خْ دّْنُوبْ نّغْ. \x ◘ \xo 4:‏10 \xt رُوم. 3‏:‏24، 25؛ 2 كُور. 5‏:‏19؛ كُول. 1‏:‏19؛ 1 يُوح. 2‏:‏2. \x*
\m 
\v 11 \bd \bdit أَ\bdit* إِمْعِيزّنْ إِنُو\bd*، مَاڒَا ثُوغَا أَربِّي إِتّخْسْ أَنغْ أَمُّو، إِتّْخصَّا أَنغْ عَاوذْ أَذْ نخْسْ إِجّْ ونّغْنِي.
\v 12 ؤُڒَا ذ إِجّنْ مَا إِژْرَا أَربِّي. مَاشَا مَاڒَا نتّخْسْ أَيَاوْيَا، أَربِّي أَذْ ذَايْنغْ إِقِّيمْ، ؤُشَا ثَايْرِي نّسْ أَقَا ثذْوڒْ ثكْمڒْ ذَايْنغْ. \x ◘ \xo 4:‏12 \xt ؤُف. 33‏:‏20؛ أَعَوذ. 4‏:‏12؛ يُوح. 1‏:‏18؛ 1 تِيم. 1‏:‏17؛ 6‏:‏16؛ 1 يُوح. 3‏:‏24. \x*
\m 
\v 13 زِي مَانْ أَيَا نسّنْ بلِّي نتّْغِيمَا ذَايسْ ؤُ نتَّا ذَايْنغْ، مِينْزِي نتَّا إِوْشَا أَنغْ زِي أَرُّوحْ نّسْ.
\v 14 أَقَا نژْرَا ؤُ نْشهّذْ بلِّي بَابَاسْ إِسّكّْ-د مِّيسْ ذ أَمْسنْجمْ ن دُّونشْثْ.
\v 15 مَارَّا ونِّي إِشهّْذنْ بلِّي يَاسُوع ذ مِّيسْ ن أَربِّي، أَربِّي أَذْ ذَايسْ إِزْذغْ ؤُ نتَّا أَذْ إِزْذغْ ذِي أَربِّي.
\v 16 أَقَا نشِّينْ نُومنْ ؤُ نسّنْ ثَايْرِي ثنِّي إِدْجَانْ غَارْ أَربِّي إِ نشِّينْ. أَربِّي ذ ثَايْرِي ؤُ ونِّي إِ غَا إِقِّيمنْ ذِي ثَايْرِي، أَذْ إِقِّيمْ ذِي أَربِّي.
\m 
\v 17 ذِي مَانْ أَيَا ثتّْوَاكمّڒْ ثَايْرِي نّسْ ذَايْنغْ، أَڒَامِي أَذْ غَارْنغْ ثِيڒِي تِّيقّثْ ذڭْ وَاسّْ ن لْحِيسَابْ، مِينْزِي أَمْ مَامّشْ إِدْجَا نتَّا، أَذْ نِيڒِي نشِّينْ عَاوذْ ذِي دُّونشْثْ-أَ.
\v 18 ذِي ثَايْرِي وَارْ ثتِّيڒِي ثِيڭّْوُوذِي، مَاشَا ثَايْرِي نِيشَانْ ثسُّوفُّوغْ ثِيڭّْوُوذِي، مِينْزِي ثِيڭّْوُوذِي ثتَّاسْ-د أَكْ-ذ ؤُنخْڒِيعْ. ونِّي إِتّڭّْوذنْ، وَارْ إِتِّيڒِي إِكْمڒْ ذِي ثَايْرِي.
\v 19 خْ ؤُيَا أَذْ نخْسْ أَربِّي، مِينْزِي نتَّا ثُوغَا إِتّخْسْ أَنغْ ذ أَمزْوَارُو.
\v 20 مَاڒَا شَا ن إِجّنْ إِقَّارْ: ”نشّْ تّخْسغْ أَربِّي!“، أَمْ إِشَارّهْ ؤُمَاسْ، أَقَا نتَّا ذ بُو-إِخَارِّيقنْ. مِينْزِي ونِّي وَارْ إِتّخْسنْ ؤُمَاسْ ونِّي إِتّْوَاڒَا، خنِّي مَامّشْ غَا يڭّْ أَذْ إِخْسْ أَربِّي ونِّي وَارْ إِتّْوِيڒِي. \x ◘ \xo 4:‏20 \xt 1 يُوح. 2‏:‏4. \x*
\v 21 أَقَا ثَاوْصيّثْ-أَ نطّفْ إِ-ت زَّايسْ، بلِّي كُوڒْ إِجّنْ إِ إِتّخْسنْ أَربِّي، أَذْ إِخْسْ ؤُڒَا ذ ؤُمَاسْ. \x ◘ \xo 4:‏21 \xt لَاوِي 19‏:‏18؛ مت. 22‏:‏39؛ يُوح. 13‏:‏34؛ 15‏:‏12؛ أَفا. 5‏:‏2؛ 1 تس. 4‏:‏9؛ 1 بُط. 4‏:‏8؛ 1 يُوح. 3‏:‏23. \x*
\b
\b
\c 5
\s1 لْ‘إِمَانْ ذِي مِّيسْ ن أَربِّي
\m 
\v 1 مَارَّا ونِّي يُومْننْ بلِّي يَاسُوع ذ لْمَاسِيحْ، أَقَا نتَّا إِتّْوَاخْڒقْ-د زِي أَربِّي، ؤُشَا مَارَّا ونِّي إِتّخْسنْ ونِّي ث-إِ-د يجِّينْ، أَذْ إِخْسْ عَاوذْ ونِّي زَّايسْ د-إِتّْوَاخڒْقنْ. \x ◘ \xo 5:‏1 \xt يُوح. 1‏:‏12. \x*
\v 2 زِي مَانْ أَيَا نسّنْ بلِّي نتّخْسْ ثَارْوَا ن أَربِّي، خْمِي نتّخْسْ أَربِّي ؤُ نتّڭّْ ثِيوصَّا نّسْ.
\v 3 مِينْزِي ثَا ذ ثَايْرِي ن أَربِّي، أَذْ نحْضَا ثِيوصَّا نّسْ، ؤُشَا ثِيوصَّا نّسْ وَارْ وْعَارنْثْ شَا. \x ◘ \xo 5:‏3 \xt مت. 11‏:‏29، 30؛ يُوح. 14‏:‏15؛ 15‏:‏10. \x*
\v 4 مَاغَارْ مْكُوڒْ إِجّنْ إِ د-إِتّْوَاخڒْقنْ زِي أَربِّي أَذْ إِغلّبْ خْ دُّونشْثْ. ذ وَا ذ أَغْڒَابْ إِ إِتّْغلَّابنْ خْ دُّونشْثْ، أَقَا-ث ذ لْ-إِيمَانْ نّغْ. \x ◘ \xo 5:‏4 \xt يُوح. 16‏:‏33. \x*
\v 5 مَانْ ونْ إِ غَا إِغلّْبنْ خْ دُّونشْثْ، مْغِيرْ ونِّي يُومْننْ بلِّي يَاسُوع ذ مِّيسْ ن أَربِّي! \x ◘ \xo 5:‏5 \xt 1 كُور. 15‏:‏57؛ 1 يُوح. 4‏:‏15. \x*
\v 6 ذ وَا إِ د-إِكِّينْ زڭْ وَامَانْ ذ إِذَامّنْ، يَاسُوع لْمَاسِيحْ. وَارْ د-يكِّي زڭْ وَامَانْ وَاهَا، مَاشَا زڭْ وَامَانْ ذ إِذَامّنْ.
\v 7 أَرُّوحْ ذ ونِّي إِشهّْذنْ، مِينْزِي أَرُّوحْ ذ ثِيذتّْ.
\v 8 أَقَا ذِينْ ثْڒَاثَا ن يِينِّي إِشهّْذنْ: أَرُّوحْ ذ وَامَانْ ذ إِذَامّنْ، ؤُشَا نِيثْنِي س ثْڒَاثَا ذڭْ إِجّنْ.
\m 
\v 9 مَاڒَا نقْبڒْ شّْهَاذثْ ن إِوْذَانْ، مشْحَاڒْ ذ ثَامقّْرَانْثْ شّْهَاذثْ ن أَربِّي. ثَا ذ شّْهَاذثْ ن أَربِّي ثنِّي إِشْهذْ خْ مِّيسْ.
\v 10 ونِّي يُومْننْ ذِي مِّيسْ ن أَربِّي، غَارسْ شّْهَاذثْ-أَ ذڭْ إِخفْ نّسْ. ونِّي وَارْ يُومِيننْ شَا ذِي أَربِّي، أَقَا إِڭَّا إِ-ث ذ بُو-إِخَارِّيقنْ، مِينْزِي نتَّا وَارْ يُومِينْ شَا ذِي شّْهَاذثْ ثنِّي إِوْشَا أَربِّي خْ مِّيسْ. \x ◘ \xo 5:‏10 \xt يُوح. 3‏:‏36؛ رُوم. 8‏:‏16؛ ڭال. 4‏:‏6. \x*
\v 11 ؤُشَا ثَا ذ شّْهَاذثْ: أَربِّي إِوْشَا أَنغْ ثُوذَارْثْ إِتّْذُومَانْ ؤُشَا ثُوذَارْثْ نِّي أَقَا-ت ذِي مِّيسْ. \x ◘ \xo 5:‏11 \xt يُوح. 1‏:‏4. \x*
\v 12 ونِّي غَارْ إِدْجَا مِّيسْ، غَارسْ ثُوذَارْثْ. ونِّي وَارْ غَارْ إِدْجِي مِّيسْ ن أَربِّي، وَارْ غَارسْ بُو ثُوذَارْثْ.
\b
\s1 أَوَاڒْ ذ ؤُسدْجمْ غَارْ ؤُنڭَّارُو
\m 
\v 13 ؤُرِيغْ أَومْ-د مَانْ أَيَا، حِيمَا أَذْ ثسّْنمْ بلِّي غَارْومْ ثُوذَارْثْ إِتّْذُومَانْ، كنِّيوْ إِنِّي إِتَّامْننْ ذڭْ يِيسمْ ن مِّيسْ ن أَربِّي. \x ◘ \xo 5:‏13 \xt يُوح. 20‏:‏31. \x*
\m 
\v 14 ذ ثَا ذ تِّيقّثْ ثنِّي غَارْنغْ ذَايسْ، مَاڒَا نتَّارْ زَّايسْ شَا ن ڒْحَاجّثْ عْلَاحْسَابْ مِينْ إِخْسْ نتَّا، نتَّا أَذْ غَارْنغْ إِسڒْ. \x ◘ \xo 5:‏14 \xt إِرْم. 29‏:‏12؛ مت. 7‏:‏8؛ 21‏:‏22؛ مك. 11‏:‏24؛ لك. 11‏:‏9؛ يُوح. 14‏:‏13؛ 15‏:‏7؛ 16‏:‏24؛ يَاع. 1‏:‏5؛ 1 يُوح. 3‏:‏2. \x*
\v 15 مَاڒَا نتّْوَاسّقْنعْ نِيشَانْ أَقَا أَذْ أَنغْ إِسڒْ مِينْ مَا ذ أَسْ نتَّارْ، خنِّي نتِّيقّْ بلِّي أَقَا يُوسَا-د أَنغْ مِينْ ذ أَسْ نتَّارْ.
\m 
\v 16 مَاڒَا حذْ إِژْرَا ؤُمَاسْ إِخطَّا، إِجّْ ن ؤُخطُّو وَارْ إِهْذِيجنْ شَا ڒْموْثْ، أجّْ إِ-ث أَذْ إِژَّادْجْ \add ذِي طّْوعْ نّسْ\add*، ؤُشَا أَذْ أَسْ ثمّوْشْ ثُوذَارْثْ، إِ ونِّي وَارْ إِخطِّينْ شَا أَڒْ ڒْموْثْ. أَقَا ذِينْ أَخطُّو أَڒْ ڒْموْثْ، وَارْ قَّارغْ شَا أَقَا إِتّْخصَّا أَذْ إِژَّادْجْ إِ مَانْ أَيَا. \x ◘ \xo 5:‏16 \xt ڒخْڒ. 15‏:‏30؛ 1 صم. 2‏:‏25؛ مت. 12‏:‏31؛ مك. 3‏:‏29؛ لك. 12‏:‏10؛ عبر. 6‏:‏4؛ 10‏:‏26؛ 2 بُط. 2‏:‏2. \x*
\v 17 مَارَّا ڒْمُوعْصِييّثْ، أَقَا-ت ذ دّنْبْ ؤُشَا أَقَا ذِينْ دّنْبْ إِ وَارْ إِدْجِينْ شَا أَڒْ ڒْموْثْ. \x ◘ \xo 5:‏17 \xt 1 يُوح. 3‏:‏4. \x*
\m 
\v 18 نسّنْ بلِّي كُوڒْ إِجّنْ ونِّي د-إِتّْوَاخڒْقنْ زِي أَربِّي، وَارْ إِخطِّي شَا، مِينْزِي ونِّي د-إِتّْوَاخڒْقنْ زِي أَربِّي أَذْ إِحْضَا إِخفْ نّسْ ؤُ أَمْعفَّانْ وَارْ ث إِتّْحِيذِي.\x ◘ \xo 5:‏18 \xt 1 يُوح. 3‏:‏9. \x*
\v 19 نسّنْ، أَقَا أَنغْ زِي أَربِّي ؤُشَا دُّونشْثْ مَارَّا أَقَا-ت ذڭْ \add إِفَاسّنْ ن\add* ؤُمْعفَّانْ.
\v 20 نسّنْ بلِّي مِّيسْ ن أَربِّي أَقَا يُوسَا-د ؤُشَا إِوْشَا أَنغْ-د ڒفْهَامثْ حِيمَا أَذْ نسّنْ ونِّي إِدْجَانْ ذ ثِيذتّْ ؤُ حِيمَا أَذْ نِيڒِي ذڭْ ونِّي ذ ثِيذتّْ، ذِي مِّيسْ يَاسُوع لْمَاسِيحْ. ذ وَا ذ أَربِّي س ثِيذتّْ ذ ثُوذَارْثْ إِتّْذُومَانْ. \x ◘ \xo 5:‏20 \xt إِشا. 9‏:‏5؛ 44‏:‏6؛ 53‏:‏11؛ 54‏:‏5؛ لك. 24‏:‏45؛ يُوح. 20‏:‏28؛ رُوم. 9‏:‏5؛ 1 تِيم. 3‏:‏16. \x*
\b
\m 
\v 21 \bd \bdit أَ\bdit* إِحنْجِيرنْ إِنُو\bd*، حْضَامْ إِخفْ نْومْ زڭْ وعْبذْ ن لْ-أَصْنَامْ! 
