\id 2CO
\h 2 הקורינתיאנים 
\toc1 אִגֶּרֶת פּוֹלוֹס הָשֵּׁנִית אֶל־הַקּוֹרִנְתִּיִים 
\toc2 אִגֶּרֶת פּוֹלוֹס הָשֵּׁנִית אֶל־הַקּוֹרִנְתִּיִים 
\toc3 2 הקורינתיאנים 
\mt1 אִגֶּרֶת פּוֹלוֹס הָשֵּׁנִית אֶל־הַקּוֹרִנְתִּיִים  
\c 1
\cp  א
\cl פרק א 
\p
\v 1 \vp א\vp* פּוֹלוֹס שְׁלִיחַ יֵשׁוּעַ הַמָּשִׁיחַ בִּרְצוֹן אֱלֹהִים אֲנִי וְטִימוֹתִיּוֹס אָחִינוּ אֶל־עֲדַת אֱלֹהִים בְּקֹרִנְתּוֹס וְאֶל־כָּל־הַקְּדוֹשִׁים אֲשֶׁר בְּאֶרֶץ אֲכַיָּא׃  
\v 2 \vp ב\vp* חֶסֶד וְשָׁלוֹם יִתֵּן לָכֶם אֱלֹהִים אָבִינוּ וַאֲדֹנֵינוּ יֵשׁוּעַ הַמָּשִׁיחַ׃  
\v 3 \vp ג\vp* בָּרוּךְ הוּא הָאֱלֹהִים אֲבִי אֲדֹנֵינוּ יֵשׁוּעַ הַמָּשִׁיחַ אֲבִי הָרַחֲמִים וֵאלֹהֵי כָל־נֶחָמָה׃  
\v 4 \vp ד\vp* הַמְנַחֵם אֹתָנוּ בְּכָל־צָרָה וְהַנֹּתֵן לָנוּ כֹּחַ לְנַחֵם אֲחֵרִים בְּכָל־צָרָתָם בַּתַּנְחוּמִים אֲשֶׁר נֻחַמְנוּ מֵאֵת אֱלֹהִים׃  
\v 5 \vp ה\vp* כִּי כַּאֲשֶׁר עָצְמוּ מַכְאֹבֵינוּ בַּעֲבוּר הַמָּשִׁיחַ כֵּן עַל־יְדֵי הַמָּשִׁיחַ יַעַצְמוּ הַנִּחֻמִים לָנוּ׃  
\v 6 \vp ו\vp* אִם־אָפְפוּ עָלֵינוּ רָעוֹת נֹחַם וְיֶשַׁע יֵצְאוּ לָכֵם מֵהֶן וְאִם־נִמְצָא נֹחַם אַתֶּם הֵם הַמְנֻחָמִים כִּי־יִגְדַּל כֹּחֲכֶם מִסִּבְלוֹת הַצָּרוֹת הָאֵלֶּה אֲשֶׁר נִסְבֹּל גַּם־אֲנָחְנוּ׃  
\v 7 \vp ז\vp* וְיֶשׁ־לָנוּ תִּקְוָה נֶאֱמָנָה בְּדַעְתֵּנוּ כִּי כַּאֲשֶׁר חֵלֶק לָכֶם בַּצָּרָה כֵּן יִהְיֶה לָכֶם חֵלֶק גַּם־בַּנֶּחָמָה׃  
\v 8 \vp ח\vp* כִּי אֵין־נַפְשֵׁנוּ לְהַעְלִים מִכֶּם אַחֵינוּ אֶת־הַצָּרוֹת אֲשֶׁר עָבְרוּ עָלֵינוּ בְּאַסְיָא כִּי כָבְדוּ מִמֶּנּוּ עַד־מְאֹד וְכִי־כָשַׁל כֹּחַ הַסַּבָּל עַד כִּי־גַם לְחַיֵּינוּ אָמַרְנוּ נוֹאָשׁ׃  
\v 9 \vp ט\vp* וַאֲנַחְנוּ דִבַּרְנוּ עִם־לִבֵּנוּ לֵאמֹר מִשְׁפַּט־מָוֶת נִגְזַר עָלֵינוּ לְבִלְתִּי נִבְטַח עוֹד בְּנַפְשֵׁנוּ כִּי אִם־בֵּאלֹהִים הַמְחַיֶּה אֶת־הַמֵּתִים׃  
\v 10 \vp י\vp* אֲשֶׁר הִצִּילָנוּ מִן־הַמָּוֶת הַקָּשֶׁה הַזֶּה כִּי מַצִּיל הוּא וְלוֹ הוֹחַלְנוּ כִּי יַצִּילֵנוּ עוֹד׃  
\v 11 \vp יא\vp* כִּי גַּם־אַתֶּם תָּחוּשׁוּ לַעֲזָר־לָנוּ בִּתְפִלַּתְכֶם וּבָזֹאת רַבִּים יוֹדוּ לֵאלֹהִים עַל־מַתְּנַת הַחֶסֶד אֲשֶׁר נָתַן לָנוּ בִּתְפִילַת רַבִּים׃  
\v 12 \vp יב\vp* וְזֹאת הִיא תְהִלָּתֵנוּ אֲשֶׁר לִבֵּנוּ לְעֵדוּת לָנוּ כִּי בְנִקְיוֹן כַּפַּיִם וּבְנֶפֶשׁ זַכָּה כְּלֵב אֱלֹהִים הִתְהַלַּכְנוּ בְּקֶרֶב הָאָרֶץ וְאַף כִּי־בְקֶרֶב מַחֲנֵיכֶם וְלֹא בְחָכְמַת בָּשָׂר וָדָם כִּי אִם־בְּחֶסֶד אֱלֹהִים׃  
\v 13 \vp יג\vp* כִּי לֹא־כָתַבְנוּ אֲלֵיכֶם דָּבָר זוּלָתִי אֵת אֲשֶׁר אַתֶּם קֹרִאים וּמְקַיְּמִים וְגַם הוֹחַלְתִּי כִּי־תָקִימוּ דְבָרַי עַד־הַקֵּץ׃  
\v 14 \vp יד\vp* וְכַאֲשֶׁר הָיִינוּ לִתְהִלָּה לַאֲנָשִׁים מִכֶּם הַמַּכִּירִים אֹתָנוּ כֵּן אַתֶּם לִתְהִלָה לָנוּ בְּיוֹם יֵשׁוּעַ אֲדֹנֵינוּ׃  
\v 15 \vp טו\vp* וּבַבִּטָחוֹן הַזֶּה הָיָה אֶת־לְבָבִי לָבוֹא אֲלֵיכֶם אָז לָתֵת לָכֶם לִוְיַת־חֵן שֵׁנִית׃  
\v 16 \vp טז\vp* וְלַעֲבֹר דֶּרֶךְ עֲלֵיכֶם אֶל־מַקְדּוֹנְיָא וּמִמַּקְדּוֹנְיָא לָשׁוּב אֲלֵיכֶם וְאַתֶּם תְּשַׁלְּחוּנִי אָז אֶל־אֶרֶץ יְהוּדָה׃  
\v 17 \vp יז\vp* וְכַאֲשֶׁר הָיָה כֵן אֶת־לְבָבִי הֲכִי בָזֹאת נִמְהַר לֵב הָיִיתִי אוֹ הֲכִי הָיְתָה מַחֲשַׁבְתִּי כְּמַחֲשֶׁבֶת בָּשָׂר וָדָם וַיְהִי בְּפִי הֵן וְלֹא לֹא וָהֵן כָּאֶחָד׃  
\v 18 \vp יח\vp* עַל־אֱמוּנַת אֱלֹהִים כִּי־דְבָרֵנוּ אֲלֵיכֶם לֹא הָיָה הֵן וָלֹא׃  
\v 19 \vp יט\vp* כִּי בֶן־הָאֱלֹהִים יֵשׁוּעַ הַמָּשִׁיחַ אֲשֶׁר אֲנִי וְסִלְוָנוֹס וְטִימוֹתִיּוֹס קָרָאנוּ אֹתוֹ בֵינֵיכֶם הוּא לֹא הָיָה הֵן וָלֹא כִּי רַק־אֱמֶת בּוֹ׃  
\v 20 \vp כ\vp* וּבוֹ כָל־הַבְטָחוֹת אֱלֹהִים אֱמֶת וְאָמֵן עַל־יָדֵינוּ לִכְבוֹד אֱלֹהִים׃  
\v 21 \vp כא\vp* כִּי־אֱלֹהִים הוּא אֲשֶׁר הֲקִימָנוּ בַמָּשִׁיחַ עִמָּכֶם וַיִּמְשְׁחֵנוּ בְּמִשְׁחַת קַדְשׁוֹ׃  
\v 22 \vp כב\vp* וְגַם־הָיָה לָנוּ לְמַחְסֶה עֹז וְאֶת־רוּחוֹ נָתַן בְּלִבֵּנוּ לְעֵרָבוֹן לָנוּ׃  
\v 23 \vp כג\vp* וַאֲנִי לֵאלֹהִים אֶקְרָא לְעֵדוּת לִי כִּי מֵחֶמְלָתִי עֲלֵיכֶם לֹא־בָאתִי אֶל־קֹרִנְתּוֹס עַד־עָתָּה׃  
\v 24 \vp כד\vp* כִּי לֹא לְהִשְׂתָּרֵר עַל־אֱמוּנַתְכֶם הִנֵּנוּ כִּי אִם־רַק כַּחֲבַרִים לְהַגְדִּיל טוּבְכֶם אֲשֶׁר בֶּאֱמוּנָה אַתֶּם חַיִּים׃   
\c 2
\cp  ב
\cl פרק ב 
\p
\v 1 \vp א\vp* וַאֲנִי שַׂמְתִּי עַל־לִבִּי לְבִלְתִּי שׁוּב אֲלֵיכֶם עוֹד בְּעִצָּבוֹן׃  
\v 2 \vp ב\vp* כִּי אִם־אֲנִי אַעֲצִיבְכֶם בְּעָצְבִּי מִי אֵפוֹא יְשַׂמְּחֵנִי עוֹד הֲכִי הוּא יְשַׂמְּחֵנִי אֲשֶׁר נֶעְצַב עַל־יָדִי׃  
\v 3 \vp ג\vp* וְכָזֹאת הִנֵּה כָתַבְתִּי פֶּן־אֶתְעַצֵּב אֶל־לִבִּי בְּבֹאִי בְּקִרְבְּכֶם תַּחַת אֲשֶׁר הוֹחַלְתִּי לִשְׂמֹחַ בָּכֶם וָאֶבְטַח בְּכֻלְּכֶם כִּי שִׂמְחָתִי הִיא שִׂמְחַת כֻּלְּכֶם׃  
\v 4 \vp ד\vp* וַאֲנִי מֵרֹב יָגוֹן וּמְצוּקַת לֵב כָּתַבְתִּי כָזֹאת וּבְשֶׁטֶף דְּמָעוֹת וְלֹא לְמַעַן תֵּעָצֵבוּ כִּי אִם־רַק לְמַעַן תֵּדְעוּ אֶת־הָאַהֲבָה הָעַזָּה אֲשֶׁר אָהַבְתִּי אֶתְכֶם׃  
\v 5 \vp ה\vp* וְאִם־אִישׁ מִכֶּם נָתַן עֲצָבֶת לֹא רַק אֹתִי לְבַדִּי הֶעֱצִיב כִּי אִם־מִבְּלִי אַכְבִּיר מִלִּים כִּמְעַט אֶתְכֶם כֻּלְּכֶם הֶעֱצִיב׃  
\v 6 \vp ו\vp* אַךְ דַּי לָאִישׁ הַהוּא הַזַּעַם אֲשֶׁר זְעָמוּהוּ רַבִּים׃  
\v 7 \vp ז\vp* עַל־כֵּן אֵפוֹא שׁוּבוּ תְּנוּ חֲנִינָה לָאִישׁ הַהוּא וְדַבְּרוּ עַל־לִבּוֹ פֶּן־יְבֻלַּע בִּיגוֹנוֹ כִּי רַב הוּא׃  
\v 8 \vp ח\vp* וְלָזֹאת אֲנִי שֹׁאֵל מֵאִתְּכֶם פִּקְדוּ־נָא אֹתוֹ בְּאַהֲבַתְכֶם׃  
\v 9 \vp ט\vp* וְגַם־לְבַעֲבוּר זֹאת כָּתַבְתִּי כִּי־מְנַסֶּה אֲנִי לָדַעַת הֲיִשְׁכֶם שֹׁמְעִים אֶל־כָּל־מִצְוֹתָי׃  
\v 10 \vp י\vp* וְאִישׁ אֲשֶׁר אַתֶּם תִּסְלְחוּ־לוֹ אֶסְלַח־לוֹ גַּם־אָנִי כִּי אֲנִי אִם־סָלַחְתִּי מְאוּמָה סָלַחְתִּי אֶת־אֲשֶׁר סָלַחְתִּי לְמַעַנְכֶם לִפְנֵי הַמָּשִׁיחַ׃  
\v 11 \vp יא\vp* פֶּן־יַעְקְבֵנוּ הַשָּׂטָן כִּי לֹא־נֶעֶלְמוּ מִמֶנּוּ מְזִמּוֹתָיו׃  
\v 12 \vp יב\vp* וְכַאֲשֶׁר בָּאתִי אֶל־טְרוֹאַס עַל־דְּבַר בְּשׁרַת הַמָּשִׁיחַ אֲשֶׁר נִפְתַּח־לִי שָׁם שַׁעַר בַּאֲדֹנֵינוּ׃  
\v 13 \vp יג\vp* לֹא־נָחָה רוּחִי בְקִרְבִּי כִּי לֹא־מָצָאתִי שָׁם אֶת־טִיטוֹס אָחִי וָאֵפֶן וָאֵלֵךְ מֵאִתָּם אֶל־מַקְדּוֹנְיָא׃  
\v 14 \vp יד\vp* אַךְ בָּרוּךְ הוּא הָאֱלֹהִים הַנּוֹתֵן לָנוּ תְשׁוּעָה בִמְשִׁיחֵנוּ תָּמִיד וְרֵיחַ דַּעְתּוֹ יַזִּיל עַל־יָדֵינוּ בְּכָל־מָקוֹם׃  
\v 15 \vp טו\vp* כִּי אֲנַחְנוּ רֵיחַ הַנִּיחֹחַ הָעֹלֶה מֵאֵת הַמָּשִׁיחַ לֵאלֹהִים בֵּין בְּתוֹךְ הַנּשָׁעִים וּבֵין בְּתוֹךְ הָאֹבְדִים׃  
\v 16 \vp טז\vp* לָאֵלֶּה רֵיחַ הַמָּוֶת לַמָּוֶת וְלָאֵלֶּה רֵיחַ הַחַיִּים לַחַיִּים וּמִי־הוּא נָכוֹן לִכְהֻנָּה כָזֹאת׃  
\v 17 \vp יז\vp* כִּי אֲנַחְנוּ לֹא כְרַבִּים הַהֹפְכִים דִּבְרֵי אֱלֹהִים כִּי אִם־בְּיִשְׁרַת לֵבָב לִפְנֵי אֱלֹהִים וּבֵאלֹהִים אֲנַחְנוּ מְדַבְּרִים בַּמָּשִׁיחַ׃   
\c 3
\cp  ג
\cl פרק ג 
\p
\v 1 \vp א\vp* הֲנָחֵל עוֹד הַפַּעַם לְחַוֹּתְכֶם מִי־אָנוּ הֲחֵפֶץ לָנוּ כַּאֲנָשִׁים אֲחֵרִים בְּכִתְבֵי מְלִיצָה אֲלֵיכֶם אוֹ מִכֶּם׃  
\v 2 \vp ב\vp* אַתֶּם אִגַּרְתֵּנוּ חֲרוּתָה עַל־לִבֵּנוּ אֲשֶׁר כָּל־אָדָם מֵבִין וְקֹרֵא בָהּ׃  
\v 3 \vp ג\vp* כַּאֲשֶׁר מוּדַעַת זֹאת כִּי אַתֶּם אִגֶּרֶת הַמָּשִׁיחַ עֲרוּכָה עַל־יָדֵינוּ וּכְתוּבָה לֹא בִדְיוֹ כִּי אִם־בְּרוּחַ אֱלֹהִים חַיִּים לֹא עַל־לֻחוֹת אֲבָנִים כִּי אִם־עַל־לֻחוֹת לֵב בָּשָׂר׃  
\v 4 \vp ד\vp* וּבִטָּחוֹן רַב כַּזֶה יֶשׁ־לָנוּ בֵּאלֹהִים עַל־יְדֵי מְשִׁיחֵנוּ׃  
\v 5 \vp ה\vp* לֹא כִי כֹּחַ לָנוּ לְקַיֵּם כָּל־דָּבָר כְּפִי הָעֹלֶה עַל־רוּחֵנוּ כִּי אִם־כֹּחֵנוּ מֵאֵת הָאֱלֹהִים׃  
\v 6 \vp ו\vp* אֲשֶׁר גַּם־כֹּחַ נָתַן לָנוּ לִהְיוֹת כֹּהֲנֵי בְרִית הַחֲדָשָׁה לֹא לְפִי הָאֹתִיּוֹת כִּי אִם־לְפִי הָרוּחַ כִּי־הָאוֹת מֵמִית וְהָרוּחַ מְחַיֶּה׃  
\v 7 \vp ז\vp* וְאִם־הַכְּהֻנָּה אֲשֶׁר מָוֶת בָּהּ וַאֲשֶׁר חֲרוּתָה בְּאֹתִיּוֹת עַל־הָאֲבָנִים מָלְאָה כָבוֹד עַד־כִּי לֹא יָכְלוּ בְנֵי יִשְׂרָאֵל לְהַבִּיט אֶל־פְּנֵי משֶׁה מִפְּנֵי אוֹר פָּנָיו אֲשֶׁר לֹא יַעֲמֹד לָנֶצַח׃  
\v 8 \vp ח\vp* אַף כִּי יָאֲתָה כָבוֹד לִכְהֻנָּה אֲשֶׁר בָּהּ חַיֵּי רוּחַ׃  
\v 9 \vp ט\vp* וְאִם־תִּכָּבֵד הַכְּהֻנָּה אֲשֶׁר תוֹרָתָהּ דִּין הֲלֹא תִכָּבֵד הַכְּהֻנָּה אֲשֶׁר צָדְקָה תוֹרָתָהּ בְּכָבוֹד מִשְׁנֶה׃  
\v 10 \vp י\vp* כִּי בַמֶּה נֶחְשָׁב כְּבוֹד הַכְּהֻנָּה הָרִאשֹׁנָה נֶגֶד עֵרֶךְ הַכְּהֻנָּה אֲשֶׁר־לָהּ יֶתֶר שְׂאֵת׃  
\v 11 \vp יא\vp* וְאִם־בַּת־חֲלוֹף כְּבוּדָה הִיא אַף כִּי־זֹאת הָעֹמֶדֶת לָנֶצַח׃  
\v 12 \vp יב\vp* עַל־כֵּן בִּהְיוֹת לָנוּ תִּקְוָה כָזֹאת פִּינוּ יַבִּיעַ עָתָק׃  
\v 13 \vp יג\vp* וְלֹא כְּמשֶׁה אֲשֶׁר נָתַן מַסְוֶה עַל־פָּנָיו וּבְנֵי יִשְׂרָאֵל לֹא יָכְלוּ לְהִתְבּוֹנֵן אֶל־תַּכְלִית תּוֹרָתוֹ הַבָּאָה עַד־קִצָּהּ׃  
\v 14 \vp יד\vp* כִּי כָּבֵד לִבָּם וְעַד־הַיּוֹם הַזֶּה כַּאֲשֶׁר יִקְרְאוּן דִּבְרֵי הַבְּרִית הַיְשָׁנָה עוֹד הַמַּסְוֶה הַהוּא לְנֶגֶד עֵינֵיהֶם כִּי לֹא יָסוּר בִּלְתִּי בַמָּשִׁיחַ׃  
\v 15 \vp טו\vp* הֵם יֶהְגּוּן בְּתוֹרַת משֶׁה וְהַמַּסְוֶה כְּמִכְסֶה עַל־לִבָּם עַד־הַיּוֹם הַזֶּה׃  
\v 16 \vp טז\vp* אַךְ כַּאֲשֶׁר יָשׁוּב יִשְׂרָאֵל אֶל־הָאָדוֹן אָז הַמַּסְוֶה יוּסָר׃  
\v 17 \vp יז\vp* וַאֲדֹנֵינוּ הוּא הָרוּחַ וּמִי אֲשֶׁר־בּוֹ רוּחַ אֲדֹנֵינוּ חָפְשִׁי הוּא׃  
\v 18 \vp יח\vp* וַאֲנַחְנוּ כֻלָּנוּ בְּלִי מִכְסֶה עַל־פָּנֵינוּ רֹאִים כְּבוֹד אֲדֹנֵינוּ כְּמוֹ בִרְאִי מוּצָק וְצַלְמֵנוּ יְשֻׁנֶּה יִדְמֶה לַצֶּלֶם הַהוּא וְיַעֲלֶה מִכָּבוֹד אֶל־כָּבוֹד מִלִּפְנֵי אֲדוֹן הָרוּחַ׃   
\c 4
\cp  ד
\cl פרק ד 
\p
\v 1 \vp א\vp* עַל־כֵּן בִּהְיוֹת לָנוּ כְּהֻנָּה כָזֹאת בְּחֶסֶד אֵל לֹא נֵחַת מִפְּנֵי־כֹל׃  
\v 2 \vp ב\vp* מִנִּסְתָּרוֹת הַמְּבִישׁוֹת פְּנֵי בַעֲלֵיהֶן נִרְחָק בְּעִקְּבוֹת עָקְבָה לֹא נֵלֵךְ וְעַל־דְּבַר הָאֱלֹהִים לֹא נִטְפֹּל שֶׁקֶר כִּי אִם־לְגַלּוֹת אֶת־הָאֱמֶת בָּאנוּ וּבְזֹאת נָפִיק רָצוֹן מִלֵּב כָּל־בְּנֵי אָדָם לִפְנֵי אֱלֹהִים׃  
\v 3 \vp ג\vp* וְאִם גַּם־בְּשׁרָתֵנוּ מַסְוֶה עַל־פָּנֶיהָ הַמַּסְוֶה הוּא רַק לְעֵינֵי הָאֹבְדִים׃  
\v 4 \vp ד\vp* אֲשֶׁר עִוֵּר אֱלֹהֵי הָעוֹלָם הַזֶּה עֵינֵי אֵלֶּה אֲשֶׁר לֹא אֵמֻן בָּם לְבִלְתִּי יִגַּהּ עֲלֵיהֶם אוֹר כְּבוֹד בְּשׁרַת הַמָּשִׁיחַ אֲשֶׁר הוּא צֶלֶם הָאֱלֹהִים׃  
\v 5 \vp ה\vp* כִּי לֹא עָלֵינוּ כִּי אִם־עַל־יֵשׁוּעַ הַמָּשִׁיחַ נֹאמַר כִּי הוּא הָאָדוֹן וּלְמַעֲנוֹ אֲנַחְנוּ עַבְדֵיכֶם׃  
\v 6 \vp ו\vp* כִּי הָאֱלֹהִים אֲשֶׁר אָמַר וַיּוֹפַע אוֹר מֵאֹפֶל הוּא הִדְלִיק נֵרוֹ בְּחַדְרֵי לִבֵּנוּ לְהָפִיץ אוֹר דַּעַת כְּבוֹדוֹ בִּפְנֵי יֵשׁוּעַ הַמָּשִׁיחַ׃  
\v 7 \vp ז\vp* וְהָאוֹצָר הַזֶּה לָנוּ בִּכְלִי חָרֶשׂ לְמַעַן תֵּת יֶתֶר עֹז לֵאלֹהִים וְלֹא לָנוּ׃  
\v 8 \vp ח\vp* נִלְחָצִים אֲנַחְנוּ מִכָּל־עֵבֶר אַךְ לֹא רְצוּצִים נְבֻכִים וְלֹא נוֹאָשִׁים׃  
\v 9 \vp ט\vp* נִרְדָּפִים וְלֹא נֶעֱזָבִים נִדָּחִים וְלֹא אֹבְדִים׃  
\v 10 \vp י\vp* וְאֶת־מוֹת הָאָדוֹן יֵשׁוּעַ נֹשְׂאִים אֲנַחְנוּ תָּמִיד בְּנַפְשֵׁנוּ לְמַעַן יִגָּלוּ בְנַפְשֵׁנוּ גַּם־חַיָּיו׃  
\v 11 \vp יא\vp* כִּי נְתוּנִים אֲנַחְנוּ לַמָּוֶת כָּל־יְמֵי חַיֵּינוּ בַּעֲבוּר יֵשׁוּעַ לְמַעַן יִגָּלוּ גַם־חַיֵּי יֵשׁוּעַ בִּבְשָׂרֵנוּ בָּשָׂר כָּלֶה׃  
\v 12 \vp יב\vp* וּבְכֵן כַּאֲשֶׁר עָלֵינוּ גָּדַל כֹּחַ הַמָּוֶת כֵּן עֲלֵיכֶם כֹּחַ הַחַיִּים׃  
\v 13 \vp יג\vp* אַךְ בִּהְיוֹת בָּנוּ רוּחַ הָאֱמוּנָה הַהוּא כַּדָּבָר הַכָּתוּב הֶאֱמַנְתִּי כִּי־אֲדַבֵּר לָכֵן מַאֲמִינִים אֲנַחְנוּ וְגַם־נְדַבֵּרָה׃  
\v 14 \vp יד\vp* אַחֲרֵי אֲשֶׁר יָדַעְנוּ כִּי הַמֵּקִים אֶת־הָאָדוֹן יֵשׁוּעַ הוּא גַּם־יָקִים אֹתָנוּ עִם־יֵשׁוּעַ וְגַם־יַעֲמִידֵנוּ עִמָּכֶם לְפָנָיו׃  
\v 15 \vp טו\vp* וְכָל־אֵלֶּה בַּעֲבוּרְכֶם לְמַעַן יוֹסִיפוּ רַבִּים לְהוֹדוֹת לִכְבוֹד הָאֱלֹהִים רֹב חַסְדּוֹ׃  
\v 16 \vp טז\vp* וְעַל־כֵּן אֵפוֹא לֹא נֵחַת מִפְּנֵי־כֹל אַף אִם־הָאָדָם הַחִיצוֹן נָמַק בָּנוּ הִנֵּה הָאָדָם הַפְּנִימִי יַחֲלִיף כֹּחַ יוֹם יוֹם׃  
\v 17 \vp יז\vp* כִּי עָנְיֵנוּ אֲשֶׁר קַל הוּא וְעֹבֵר כְּרָגַע עֹז נֶצַח יִתֶּן־לָנוּ כָּבוֹד מְאֹד נַעֲלָה׃  
\v 18 \vp יח\vp* כִּי לֹא לִדְבָרִים הַנִּרְאִים אָנוּ מְצַפִּים כִּי אִם־לַאֲשֶׁר אֵינָם נִרְאִים כִּי הַנִּרְאִים לְיָמִים חֲרוּצִים וַאֲשֶׁר אֵינָם נִרְאִים עַד־עוֹלְמֵי עַד׃   
\c 5
\cp  ה
\cl פרק ה 
\p
\v 1 \vp א\vp* כִּי יָדַעְנוּ אִם יֵהָרֵס בֵּית חֹמֶר אֹהֶל נַפְשֵׁנוּ יֻתַּן לָנוּ בַּיִת מֵאֵת הָאֱלֹהִים אֲשֶׁר אֵינֶנּוּ בָנוּי בְּיָדַיִם כִּי בֵּית עוֹלָם הוּא בַּמָּרוֹם׃  
\v 2 \vp ב\vp* כִּי פֹה בְּבָתֵּי הַנֶּפֶשׁ נֶאֱנָחִים אֲנָחְנוּ וְשֹׁאֲפִים לְהִתְלוֹנֵן בְּצֵל הַמָּעוֹן הָעֶלְיוֹן׃  
\v 3 \vp ג\vp* וְאִם נִתְלוֹנֵן שָׁם לֹא נִהְיֶה עוֹד כְּעֵירֻמִּם מִבְּלִי מַחְסֶה׃  
\v 4 \vp ד\vp* כִּי כָל־עוֹד נִתְגּוֹרֵר פֹּה בְּבָתֵּי הַנֶּפֶשׁ אֲנַחְנוּ מְסֻבָּלִים וְנֶאֱנָקִים וְלֹא לַחֲלִיפַת חֲלִיצָתֵנוּ אֲנַחְנוּ מִתְאַוִּים כִּי אִם־לִהְיוֹת מְלֻבָּשִׁים לְבַעֲבוּר יְבֻלַּע הַמָּוֶת בְּמוֹ־הַחַיִּים׃  
\v 5 \vp ה\vp* וְהָאֱלֹהִים הוּא אֲשֶׁר הֲכִינָנוּ לְכָל־זֹאת וְאֶת־רוּחוֹ נָתַן לְעֵרָבוֹן לָנוּ׃  
\v 6 \vp ו\vp* וּבְזֹאת אֲנַחְנוּ סְמוּכִים תָּמִיד וְגַם־יֹדְעִים כִּי כָל־עוֹד אֲשֶׁר נִשְׁכֹּן בַּגְּוִיָּה נִשְׁכֹּן כְּמוֹ גֹלִים מֵעַל פְּנֵי הָאָדוֹן׃  
\v 7 \vp ז\vp* כִּי בָאֱמוּנָה אָנוּ הֹלְכִים וְלֹא לְמַרְאֵה עֵינָיִם׃  
\v 8 \vp ח\vp* וְיֶשׁ־לָנוּ עַל־מִי לְהִסָּמֵךְ וְתַאֲוַת לִבֵּנוּ גְדֹלָה לְהַרְחִיק נְדֹד מִן־הַגְּוִיָּה וּלְהִתְלוֹנֵן בְּצֵל הָאָדוֹן׃  
\v 9 \vp ט\vp* עַל־כֵּן נִתְאַמֵּץ אִם־מִקָּרוֹב אוֹ־מֵרָחוֹק לִהְיוֹת לוֹ לְרָצוֹן׃  
\v 10 \vp י\vp* כִּי כֻלָּנוּ מִתְעַתְּדִים לַעֲמֹד לִפְנֵי כִסֵּא מִשְׁפַּט הַמָּשִׁיחַ לָקַחַת אִישׁ אִישׁ כְּמַעֲשֵׂהוּ אֲשֶׁר עָשָׂה בְּעוֹדוֹ בִּבְשָׂרוֹ אִם־טוֹב וְאִם־רָע׃  
\v 11 \vp יא\vp* וְאַחֲרֵי אֲשֶׁר יִרְאַת יְהוָֹה לְנֶגֶד עֵינֵינוּ נְפַתֶּה אֶת־בְּנֵי הָאָדָם לְיִרְאָה אֹתוֹ וּבְיִשְׁרַת לְבָבֵנוּ יְדֻעִים אֲנַחְנוּ לֵאלֹהִים אוֹחִילָה כִי כֵן יְדֻעִים אֲנַחְנוּ גַּם־לָכֶם׃  
\v 12 \vp יב\vp* וְלֹא בָאנוּ בְזֹאת לְרוֹמֵם נַפְשֵׁנוּ לִפְנֵיכֶם עוֹד הַפָּעַם כִּי אִם־לָשִׂים לָכֶם יָדַיִם לְהִתְפָּאֵר בָּנוּ וְלָתֵת לָכֶם פִּתְחוֹן פֶּה נֶגֶד הַמִּתְפָּאֲרִים לָעֵינַיִם וְלַלֵּבָב אֵין מְאוּמָה׃  
\v 13 \vp יג\vp* וְאַף אִם־נֶחְשַׁבְנוּ כְמִשְׁתּוֹלְלִים כֵּן הָיִינוּ לֵאלֹהִים וְאִם כִּמְחֻכָּמִים כֵּן הָיִינוּ לָכֶם׃  
\v 14 \vp יד\vp* כִּי־אַהֲבַת הַמָּשִׁיחַ חָזְקָה עָלֵינוּ לְהוֹצִיא מִשְׁפָּט כָּזֶה אִם־אֶחָד מֵת בְּעַד כֻּלָּם אָז כֻּלָּם כְּמֵתִים נֶחְשָׁבוּ׃  
\v 15 \vp טו\vp* וְהוּא מֵת בְּעַד כֻּלָּם לְמַעַן יִחְיוּ כֻלָּמוֹ לֹא לְנַפְשָׁם כִּי אִם־לוֹ אֲשֶׁר מֵת וְקָם בַּעֲדָם׃  
\v 16 \vp טז\vp* עַל־כֵּן מֵעַתָּה לֹא־נֵדַע עוֹד אִישׁ לְפִי בְשָׂרוֹ וְאַף הַמָּשִׁיחַ אִם־יְדַעֲנֻהוּ לְפִי בְּשָׂרוֹ לֹא־נֵדָעֵהוּ עוֹד עָתָּה׃  
\v 17 \vp יז\vp* כִּי מִי לַמָּשִׁיחַ בְּרִיאָה חֲדָשָׁה הוּא קַדְמֹנִיּוֹת חָלְפוּ וְהִנֵּה הַכֹּל חָדָשׁ הוּא׃  
\v 18 \vp יח\vp* וכָל־זֹאת מִיַּד אֱלֹהִים אֲשֶׁר נְתָנָנוּ לְהִתְרַצּוֹת אֵלָיו בַּמָּשִׁיחַ וַעֲבֹדַת הַסְּלִיחָה הַזֹּאת שָׂם עָלֵינוּ׃  
\v 19 \vp יט\vp* כִּי הֵן אֱלֹהִים הָיָה בְּיֵשׁוּעַ הַמָּשִׁיחַ לִסְלֹחַ לִבְנֵי הָעוֹלָם וְלֹא־לִזְכֹּר לָהֶם אֶת־חַטֹּאתֵיהֶם וְתוֹרַת הַסְּלִיחָה הַזֹּאת הִפְקִיד בְּיָדֵינוּ׃  
\v 20 \vp כ\vp* וְאִם כֵּן אֵפוֹא מְלִיצֵי הַמָּשִׁיחַ אֲנָחְנוּ כְּמוֹ אִם־אֱלֹהִים מִתְחַנֵּן אֲלֵיכֶם עַל־פִּינוּ אֲנַחְנוּ מְחַלִּים אֶת־פְּנֵיכֶם בְּשֵׁם הַמָּשִׁיחַ הִתְרַצּוּ־נָא אֶל־הָאֱלֹהִים׃  
\v 21 \vp כא\vp* הוּא אֲשֶׁר לֹא־יָדַע חַטָּאת אֹתוֹ עָשָׂה לְחַטָּאת בַּעֲדֵנוּ לְמַעַן נִהְיֶה אֲנַחְנוּ בוֹ לְצִדְקַת אֱלֹהִים׃   
\c 6
\cp  ו
\cl פרק ו 
\p
\v 1 \vp א\vp* וַאֲנַחְנוּ כְּעֹשִׂים עִמּוֹ בִּמְלַאכְתּוֹ מְבַקְשִׁים מִכֶּם אַל־נָא תִשְׂאוּ חֶסֶד־אֵל לָרִיק׃  
\v 2 \vp ב\vp* כִּי הוּא אֹמֵר בְּעֵת רָצוֹן עֲנִיתִיךָ וּבְיוֹם יְשׁוּעָה עֲזַרְתִּיךָ הִנֵה עַתָּה עֵת רָצוֹן הִנֵּה עַתָּה יוֹם יְשׁוּעָה׃  
\v 3 \vp ג\vp* וְלֹא נִתֵּן מִכְשֹׁל לִפְנֵי־כֹל פֶּן־תֵּחָשֵׁב עֲבֹדָתֵנוּ לְשִׁמְצָה׃  
\v 4 \vp ד\vp* אוּלָם בְּכָל־מַעֲמָד נַעֲמֹד לְעֵינֵי הָרֹאִים כִּמְשָׁרְתֵי־אֵל בְּרֹב עֹצֶר רוּחַ בְּלַחַץ בְּמָצוֹק וּבְחֹסֶר כֹּל׃  
\v 5 \vp ה\vp* בְּמַהֲלֻמּוֹת בְּבָתֵּי כְלָאִים בִּמְהוּמוֹת בִּתְלָאוֹת בִּבְלִי־שֵׁנָה בַּלַּיְלָה וּבְהִתְעַנּוֹת בַּיּוֹם׃  
\v 6 \vp ו\vp* בְּבֹר לֵב בְּאוֹר הַדַּעַת וּבְאֹרֶךְ רוּחַ בַּחֲנִינָה בְּרוּחַ הַקֹּדֶשׁ וּבְאַהֲבָה בְּלֹא לֵב וָלֵב׃  
\v 7 \vp ז\vp* בְּדִברֵי אֱמֶת בִּגְבוּרַת אֱלֹהִים וּבִכְלִי נֵשֶׁק הַצְּדָקָה מִיָּמִין וּמִשְּׂמֹאל׃  
\v 8 \vp ח\vp* בְּכָבוֹד וּבְקָלוֹן בְּדִבָּה רָעָה וּבְשֵׁמַע תְּהִלָּה כְּמַתְעִים וְנֶאֱמָנִים׃  
\v 9 \vp ט\vp* כִּבְנֵי בְלִי־שֵׁם וְאַנְשֵׁי שֵׁם כְּמֵתִים וְהִנֵּה אֲנַחְנוּ חַיִּים כְּמֻכִּים וְלֹא מוּמָתִים׃  
\v 10 \vp י\vp* כְּנֶעֱצָבִים וּשְׂמֵחִים תָּמִיד כְּרָשִׁים וּמַעֲשִׁירֵי רַבִּים כְּאֵין לָהֶם מְאוּמָה וְיֵשׁ לָהֶם כֹּל׃  
\v 11 \vp יא\vp* וְאַתֶּם יוֹשְׁבֵי קֹרִנְתּוֹס פִּינוּ פָתַחְנוּ לָכֶם אַף לִבֵּנוּ רָחָב׃  
\v 12 \vp יב\vp* לֹא־צַר הוּא מֵהָכִיל אֶתְכֶם אַךְ מֵעֵיכֶם וְרַחֲמֵיכֶם צָרוּ מֵהָכִיל אֹתָנוּ׃  
\v 13 \vp יג\vp* וַאֲנִי כְּמוֹ אֶל־בָּנִים אֲנִי מְדַבֵּר הָשִׁיבוּ גְמוּל וְהַרְחִיבוּ לִבְּכֶם גַּם־אַתֶּם׃  
\v 14 \vp יד\vp* אַל־תִּצָּמְדוּ לִמְהָרְסֵי אֱמוּנָה לִמְשֹׁךְ עִמָּם בְּעֹל אֶחָד כִּי מַה אַחֲוָה בֵּין צֶדֶק לָרֶשַׁע וּמַה בְּרִית בֵּין אוֹר לַחֹשֶׁךְ׃  
\v 15 \vp טו\vp* בַּמֶּה יִשְׁוֶה הַמָּשִׁיחַ לִבְלִיָּעַל אוֹ מֶה חֵלֶק לְשֹׁמֵר אֱמוּנָה עִם־מְהָרֵס אֱמוּנָה׃  
\v 16 \vp טז\vp* מַה־קֶּשֶׁר לְהֵיכַל אֱלֹהִים עִם־אֱלִילִים כִּי־אֲנַחְנוּ הֵיכַל אֱלֹהִים חַיִּים כַּאֲשֶׁר אָמַר הָאֱלֹהִים וְשָׁכַנְתִּי בְתוֹכָם וְהִתְהַלַּכְתִּי בְתוֹכָם וְהָיִיתִי לָהֶם לֵאלֹהִים וְהֵם יִהְיוּ־לִי לְעָם׃  
\v 17 \vp יז\vp* עַל־כֵּן צְאוּ מִתּוֹכָם וְהִבָּרוּ נְאֻם־יְהוָֹה וְטָמֵא אַל־תִּגָּעוּ וַאֲנִי אֲקַבֵּל אֶתְכֶם׃  
\v 18 \vp יח\vp* וְהָיִיתִי לָכֶם לְאָב וְאַתֶּם תִּהְיוּ־לִי לְבָנִים וּלְבָנוֹת נְאֻם־יְהוָֹה צְבָאוֹת׃   
\c 7
\cp  ז
\cl פרק ז 
\p
\v 1 \vp א\vp* לָכֵן יְדִידִים בִּהְיוֹת לָנוּ הַבְטָחוֹת אֵלֶּה נְטַהֵר נַפְשֵׁנוּ מִכָּל־טֻמְאַת בָּשָׂר וָרוּחַ וְנַעֲלֶה בַקֹּדֶשׁ בְּיִרְאַת אֱלֹהִים׃  
\v 2 \vp ב\vp* שָׂאוּנוּ־נָא לֹא עָשַׁקְנוּ לֹא חִבַּלְנוּ וְלֹא עָקַבְנוּ אִישׁ׃  
\v 3 \vp ג\vp* וְלֹא לְהַאֲשִׁימְכֶם אֲנִי מְדַבֵּר כִּי הֲלֹא קִדַּמְתִּי לֵאמֹר כִּי שְׁמוּרִים אַתֶּם בְּלִבֵּנוּ גַּם־בַּמָּוֶת גַּם־בַּחַיִּים׃  
\v 4 \vp ד\vp* אֲרֶשֶׁת שְׂפָתַי נִמְרְצָה אֲלֵיכֶם וְאֶתְפָּאֵר בָּכֶם עַד־מְאֹד וּבְכָל־צָרָתֵנוּ מָלֵאתִי נֹחַם וְדֵי שְׂמָחוֹת שָׂבָעְתִּי׃  
\v 5 \vp ה\vp* כִּי בְּבֹאֵנוּ מַקְדּוֹנְיָא לֹא־הָיָה שָׁלוֹם בִּבְשָׂרֵנוּ כִּי אִם־צָרָה מִכָּל־עֵבֶר מִחוּץ חֶרֶב וּמֵחֲדָרִים אֵימָה׃  
\v 6 \vp ו\vp* אַךְ זֹקֵף כְּפוּפִים אֱלֹהִים אֲשֶׁר סָמַךְ לָנוּ בְּיַד טִיטוֹס בְּבֹאוֹ׃  
\v 7 \vp ז\vp* וְלֹא בְּבֹאוֹ בִּלְבָד כִּי אִם־גַּם בְּתַנְחוּמִים אֲשֶׁר מָצָא בֵינֵיכֶם בְּהַגִּידוֹ לָנוּ אֶת־חֵשֶׁק לִבְּכֶם אֶת־יְגוֹנְכֶם וְאֶת־קִנְאַתְכֶם לִי אֲשֶׁר עַל־כֵּן הוֹסִיף שִׂמְחָה בְּלִבִּי׃  
\v 8 \vp ח\vp* וְאִם גַּם־הֶעֱצַבְתִּי אֶתְכֶם בְּאִגַּרְתִּי לֹא אֶנָּחֵם עַתָּה אַף כִּי־נִחַמְתִּי אָז בִּרְאֹתִי כִּי־הָאִגֶּרֶת הַהִיא הֶעֱצִיבָה אֶתְכֶם לִזְמָן מָה׃  
\v 9 \vp ט\vp* וְעַתָּה אֲנִי שָׂמֵחַ לֹא עַל־עָצְבְּכֶם כִּי אִם־עַל־עָצְבְּכֶם לִתְשׁוּבָה אַחֲרֵי אֲשֶׁר נֶעֱצַבְתֶּם לְפִי רְצוֹן אֱלֹהִים לִבְלִי הֱיוֹת לָכֶם כָּל־נֶזֶק עַל־יָדֵנוּ׃  
\v 10 \vp י\vp* כִּי הָעֹצֶב לְפִי רְצוֹן אֱלֹהִים מוֹלִיךְ לִתְשׁוּבָה וְלִתְשׁוּעָה אֲשֶׁר עַל־זֹאת לֹא יִנָּחֵם אִישׁ אַךְ עֹצֶב לְפִי־דֶרֶךְ הָעוֹלָם יוֹלִיךְ לַמָּוֶת׃  
\v 11 \vp יא\vp* הֲלֹא תִרְאוּ פְרִי עָצְבְּכֶם אֲשֶׁר כִּרְצוֹן אֱלֹהִים כִּי עוֹרֵר אֶתְכֶם לִשְׁקֹד עַל־דְּבָרֵינוּ אַף לְהִצְטַדֵּק וְאַף לְהִתְקַצֵּף אַף לְיִרְאָה וְאַף לְאַהֲבָה אַף לְקִנְאָה וְאַף לִנְקָמָה הוֹכַחְתֶּם כִּי־נְקִיִּים הֱיִיתֶם מִכֹּל וָכֹל בָּעִנְיָן הַהוּא׃  
\v 12 \vp יב\vp* וְעַל־כֵּן כַּאֲשֶׁר כָּתַבְתִּי אֲלֵיכֶם לֹא כָתַבְתִּי בַּעֲבוּר זֶה אֲשֶׁר עָשָׂה אֶת־הָרָעָה וְלֹא בַּעֲבוּר זֶה אֲשֶׁר סָבַל אֶת־הָרָעָה כִּי אִם־בַּעֲבוּר הַרְאֹתְכֶם כַּמָּה אַתֶּם חֲרֵדִים עָלֵינוּ לִפְנֵי הָאֱלֹהִים׃  
\v 13 \vp יג\vp* וּבַעֲבוּר־זֹאת תַּנְחוּמִים יְשַׁעַשְׁעוּ נַפְשֵׁנוּ בְּתַנְחוּמֹתֵיכֶם וְרֹב שְׂמָחוֹת שָׂבַעְנוּ בְּשִׂמְחַת טִיטוֹס אֲשֶׁר כֻּלְּכֶם יַחְדָּו הֵנַּחְתֶּם אֶת־רוּחוֹ׃  
\v 14 \vp יד\vp* וַאֲנִי לֹא אֵבוֹשׁ מֵאֲשֶׁר הִלַּלְתִּיכֶם לְפָנָיו כִּי כַּאֲשֶׁר כָּל־דְּבָרֵינוּ אֲלֵיכֶם דִּבְרֵי אֱמֶת הֵם כֵּן הוּקַם דְּבַר הַתְּהִלָּה אֲשֶׁר הִלַּלְתִּיכֶם לִפְנֵי טִיטוֹס׃  
\v 15 \vp טו\vp* וְגַם־הוּא נִכְמְרוּ רַחֲמָיו אֲלֵיכֶם יֶתֶר מְאֹד וַיִּזְכֹּר כִּי כֻלְּכֶם יַחְדָּו הִקְשַׁבְתֶּם לְקוֹלוֹ וְכִי קִבַּלְתֶּם אֹתוֹ בְּיִרְאָה וּבַחֲרָדָה׃  
\v 16 \vp טז\vp* וַאֲנִי שָׂמֵחַ כִּי בְכָל־דָּבָר לִבִּי בָכֶם בָּטוּחַ׃   
\c 8
\cp  ח
\cl פרק ח 
\p
\v 1 \vp א\vp* וְהִנְנוּ מוֹדִיעִים אֶתְכֶם אַחִים כִּי גָבַר חֶסֶד אֵל עַל־קְהִלוֹת מַקְדּוֹנְיָא׃  
\v 2 \vp ב\vp* כִּי כַּאֲשֶׁר הִגְדִּיל כּוּר צָרָתָם כֵּן גָּדְלָה שִׂמְחָתָם וְרֹב עָנְיָם הִרְבָּה שִׁפְעַת נִדְבָתָם׃  
\v 3 \vp ג\vp* וַאֲנִי עֵד הִנֵּנִי כִּי לְפִי־עֵרֶךְ כֹּחָם אוֹ גַם־יֶתֶר מִדֵּי־כֹחָם כִּנְדִיבֵי לֵב׃  
\v 4 \vp ד\vp* בִּקְשׁוּ מִמֶּנּוּ בְּתַחֲנוּנִים רַבִּים עַל־דְּבַר נִדְבָתָם זֶה חַסְדָּם וְחֵלֶק עֲבֹדָתָם לַקְּדוֹשִׁים׃  
\v 5 \vp ה\vp* וְגַם־עָשׂוּ יֶתֶר מֵאֲשֶׁר קִוִּינוּ כִּי בַתְּחִלָּה הִקְדִּישׁוּ נַפְשָׁם לַאֲדֹנֵינוּ וְלָנוּ בִּרְצוֹן הָאֱלֹהִים׃  
\v 6 \vp ו\vp* וּלְפִי־זֹאת בִּקַּשְׁנוּ מֵאֵת טִיטוֹס כַּאֲשֶׁר הֵחֵל מֵאָז כֵּן יְכַלֶּה מַעֲשֵׂה הַחֶסֶד הַזֶּה בָּכֶם׃  
\v 7 \vp ז\vp* וְהִנֵּה כַּאֲשֶׁר חֵלֶק רַב לָכֶם בַּכֹּל בֶּאֱמוּנָה בְּתוֹרָה וּבְדַעַת בְּכָל־מַאֲמַצֵּי כֹחַ וּבְאַהֲבָה אֲשֶׁר תֶּאֱהָבֻנוּ כֵּן תַּרְבּוּ חֶלְקְכֶם גַּם־בַּחֶסֶד הַזֶּה׃  
\v 8 \vp ח\vp* וְלֹא כִדְבַר מִצְוָה אֲנִי אֹמֵר כִּי אִם־לְנַסֹּתְכֶם בְּמַאֲמַצֵּי כֹחַ אֲחֵרִים לִרְאוֹת אִם־אַהֲבַתְכֶם זַכָּה׃  
\v 9 \vp ט\vp* כִּי־יְדַעְתֶּם אֶת־חֶסֶד יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ כִּי עָשִׁיר הָיָה וַיְהִי לְרָשׁ לְמַעַנְכֶם אֲשֶׁר עֵקֶב רִישׁוֹ תַּעֲשִׁירוּ׃  
\v 10 \vp י\vp* וַאֲנִי מְחַוֶּה דַעְתִּי בַדָּבָר הַזֶּל לְהוֹעִיל לָכֶם אַחֲרֵי אֲשֶׁר הַחִלֹּתֶם זֶה שָׁנָה לֹא רַק לַעֲשׂוֹת חֶסֶד כִּי אִם־גַּם לַעֲשׁתוֹ בְּחֵפֶץ לֵב׃  
\v 11 \vp יא\vp* וְעַתָּה הַשְׁלִימוּ אֶת־הַמַּעֲשֶׂה וְכַלּוּ אֶת־הַמְלָאכָה לְפִי רוּחֲכֶם הַנְּדִיבָה כַּאֲשֶׁר תִּמְצָא יֶדְכֶם׃  
\v 12 \vp יב\vp* כִּי אִישׁ אֲשֶׁר רוּחוֹ נְדִיבָה יִהְיֶה לְרָצוֹן כְּפִי אֲשֶׁר יֶשׁ־לְאֵל יָדוֹ וְלֹא־כְפִי אֲשֶׁר אֵין־לְאֵל יָדוֹ׃  
\v 13 \vp יג\vp* כִּי לֹא לִרְוָחָה לַאֲחֵרִים וּלְמַעֲמָסָה עֲלֵיכֶם דְּבָרָי׃  
\v 14 \vp יד\vp* כִּי אִם־בְּקַו הַשָּׁוֶה הַיּוֹם יִתְרָה לָכֶם לְמַלֵּא מַחְסֹרָם וּלְעֵת אַחֶרֶת יִתְרָתָם תִּהְיֶה לְמַלֵּא מַחְסֹרְכֶם לְמַעַן יִהְיֶה קַו שָׁוֶה׃  
\v 15 \vp טו\vp* כַּכָּתוּב וְלֹא הֶעְדִּיף הַמַּרְבֶּה וְהַמַּמְעִיט לֹא הֶחְסִיר׃  
\v 16 \vp טז\vp* וַאֲנִי אוֹדֶה אֶת־אֱלֹהִים אֲשֶׁר נָתַן בְּלֵב טִיטוֹס לָחוּשׁ לָכֶם כָּזֹאת׃  
\v 17 \vp יז\vp* כִּי לֹא רַק אֶת־פְּקֻדָּתֵנוּ שָׁמָר כִּי אִם־רַב פְּעָלִים הַזֶּה הָלַךְ אֲלֵיכֶם מֵרְצוֹן נַפְשׁוֹ׃  
\v 18 \vp יח\vp* וַנִּשְׁלַח עִמּוֹ אֶת־אָחִינוּ אֲשֶׁר נוֹדַע לִתְהִלָּה בַּבְּשׁרָה בְּכָל־הַקְּהִלּוֹת׃  
\v 19 \vp יט\vp* וּמִלְּבַד זֹאת נִבְחַר גַּם־הוּא מֵאַנְשֵׁי הַקְּהִלּוֹת לָלֶכֶת עִמָּנוּ בַּעֲבֹדָתֵנוּ לֶאֱסֹף הַנְּדָבוֹת לִכְבוֹד אֲדֹנֵינוּ וְלַעֲזָר־לָנוּ׃  
\v 20 \vp כ\vp* וְאַף גַּם־לְהַרְחִיק מֵעָלֵינוּ דִּבָּה רָעָה עַל־דְּבַר הַכֶּסֶף הָרָב אֲשֶׁר אָסַפְנוּ בַּעֲבֹדָתֵנוּ׃  
\v 21 \vp כא\vp* כִּי־חַשְׁנוּ לְהַשְׁגִּיחַ מַה־טּוֹב גַּם־בְּעֵינֵי הָאָדוֹן וְגַם־בְּעֵינֵי בְנֵי־אָדָם׃  
\v 22 \vp כב\vp* וַנִּשְׁלַח עִמָּהֶם אֶת־אָחִינוּ אִישׁ אַמִּיץ כֹּחַ אֲשֶׁר בָּחַנּוּ אֹתוֹ פְּעָמִים רַבּוֹת בִּדְרָכִים שֹׁנִים וְעַתָּה הוֹסִיף אֹמֶץ לִבּוֹ בְּבִטְחוֹנוֹ בָכֶם כִּי רַב הוּא׃  
\v 23 \vp כג\vp* וְהִנֵּה עַל־דְּבַר טִיטוֹס חָבֵר הוּא לִי וְתֹמֵךְ יָדִי בַּעֲבֹדָתִי בְּקִרְבְּכֶם וְכֵן עַל־דְּבַר אַחֵינוּ הֲלֹא הֵם שְׁלוּחֵי הַקְּהִלּוֹת לִכְבוֹד מְשִׁיחֵנוּ׃  
\v 24 \vp כד\vp* עַל־כֵּן תְּחַוּוּ עֵדוּת אַהֲבַתְכֶם לָהֶם וַאֲשֶׁר גַּם־נִתְפָּאֵר בָּכֶם נֶגֶד פְּנֵי הַקְּהִלּוֹת׃   
\c 9
\cp  ט
\cl פרק ט 
\p
\v 1 \vp א\vp* אָמְנָם עַל־דְּבַר מִשְׁמַרְתֵּנוּ לְכַלְכֵּל אֶת־הַקְּדוֹשִׁים אַךְ־לְמוֹתָר לִי לִכְתֹּב אֲלֵיכֶם׃  
\v 2 \vp ב\vp* כִּי יָדַעְתִּי נִדְבַת לִבְּכֶם אֲשֶׁר הָיְתָה לִתְהִלָּה בְּפִי מֵאָז לִפְנֵי קְהַל מַקְדּוֹנְיָא לֵאמֹר כִּי זֶה שָׁנָה אֲשֶׁר אֲכַיָּא נָכוֹן לִבָּהּ לְהִתְנַדֵּב וְכִי גַּם־קִנְאַתְכֶם עוֹרְרָה לֵב רַבִּים׃  
\v 3 \vp ג\vp* אֲבָל שָׁלַחְתִּי אֲלֵיכֶם אֶת־הָאַחִים לְמַעַן לֹא תִהְיֶה תְהִלַּתְכֶם בְּפִי בַּדָּבָר הַזֶּה לָרִיק וּלְמַעַן תִּהְיוּ נְכֹנִים כַּאֲשֶׁר אָמָרְתִּי׃  
\v 4 \vp ד\vp* כִּי אִם־יָבוֹאוּ אַנְשֵׁי מַקְדּוֹנְיָא עִמִּי וְיִמְצְאוּ כִּי אֵינְכֶם נְכֹנִים אֵינֶנִּי אֹמֵר כִּי אַתֶּם תֵּבשׁוּ אַךְ אֲנַחְנוּ הֲלֹא נֵבוֹשׁ מִמִּבְטָחֵנוּ׃  
\v 5 \vp ה\vp* עַל־כֵּן חָשַׁבְתִּי כִּי עָלַי הַדָּבָר לְהָעִיר אֶת־הָאַחִים לְקַדֵּם לָבוֹא אֲלֵיכֶם לְהָכִין מִסַּת נִדְבַת יֶדְכֶם כִּמְדֻבָּר מֵאָז לִהְיוֹת עֲרוּכָה כְּמִסַּת יַד נָדִיב וְלֹא כְיַד כִּילַי׃  
\v 6 \vp ו\vp* כִּי הִנֵּה הַזֹּרֵעַ זֶרַע רָזֶה יִקְצֹר רָזוֹן וְהַזֹּרֵעַ בְּיַד נְדִיבָה יִקְצֹר נְדִיבוֹת׃  
\v 7 \vp ז\vp* כָּל־אִישׁ יִתֵּן כַּאֲשֶׁר יִדְּבֶנּוּ לִבּוֹ לֹא בְעַיִן רָעָה וְלֹא בְאֹנֶס כִּי הַנֹּתֵן בְּלֵב טוֹב יֶאֱהַב אֹתוֹ אֱלֹהִים׃  
\v 8 \vp ח\vp* וְיַד אֱלֹהִים מַשֶּׂגֶת לִשְׁפֹּת לָכֶם כָּל־חָסֶד לְמַלֵּא דֵי מַחְסֹרְכֶם כָּל־הַיָּמִים וְלָתֵת לָכֶם חַיִל לַעֲשׂוֹת כָּל־טוֹב׃  
\v 9 \vp ט\vp* כַּכָּתוּב פִּזַּר נָתַן לָאֶבְיוֹנִים צִדְקָתוֹ עֹמֶדֶת לָעַד׃  
\v 10 \vp י\vp* וְהַנֹּתֵן זֶרַע לַזֹּרֵעַ וְלֶחֶם לָאֹכֵל כֹּה יִתֵּן וְכֹה יוֹסִף לָכֶם אֶת־זַרְעֲכֶם וְאֶת־פְּרִי צִדְקַתְכֶם יַרְבֶּה׃  
\v 11 \vp יא\vp* כִּי תִתְבָּרֲכוּ בַכֹּל בְּכָל־מַעֲשֵׂה נְדִיבוֹת לְהַשְׁמִיעַ תְּהִלַּת אֱלֹהִים עַל־יָדֵינוּ׃  
\v 12 \vp יב\vp* כִּי־עֲבֹדַת הַצְּדָקָה הַזֹּאת לֹא לְבַד מַחְסוֹר הַקְּדוֹשִׁים תְּמַלֵּא כִּי אִם־גַּם־תִּפְתַּח פִּי רַבִּים לְהוֹדוֹת לַאלֹהִים׃  
\v 13 \vp יג\vp* וּבְמַעֲשֶׂה הַצְּדָקָה הַזֹּאת יִתְּנוּ לֵאלֹהִים כָּבוֹד עַל־אֲשֶׁר נִכְנַע לִבְּכֶם לְקַבֵּל עֲלֵיכֶם בְּשׁרַת הַמָּשִׁיחַ וְעַל־נִדְבַת יֶדְכֶם לְאוֹת אַחֲוָה לָהֶם וּלְכָל־אֶבְיוֹנֵי אָדָם׃  
\v 14 \vp יד\vp* וְהֵם יִתְפַּלְלוּ בַעַדְכֶם כִּי נַפְשָׁם דָּבְקָה בְנַפְשְׁכֶם בַּעֲבוּר חֶסֶד אֵל אֲשֶׁר גָּבַר עֲלֵיכֶם׃  
\v 15 \vp טו\vp* בָּרוּךְ הוּא אֱלֹהִים הַנֹּתֵן לָנוּ מַתָּן עָצוּם מִסַּפֵּר׃   
\c 10
\cp  י
\cl פרק י 
\p
\v 1 \vp א\vp* וַאֲנִי פוֹלוֹס בְּנֹעַם מְשִׁיחֵנוּ וּבְעַנְוָתוֹ הִנְנִי דֹרֵשׁ מִכֶּם לַאֲשֶׁר פָּנִים בְּפָנִים שָׁפֵל הָיִיתִי לִפְנֵיכֶם וּמֵרָחוֹק יָצָא עָתָק מִפִּי׃  
\v 2 \vp ב\vp* וְלָזֹאת אֲנִי דֹרֵשׁ מִכֶּם אַל־תִּתְּנוּ לִי תֹאֲנָה בְּבוֹאִי לְהוֹצִיא עָתָק מִפִּי בֶּעֱזוּז לִבִּי כַּאֲשֶׁר מִתְעַתֵּד אֲנִי לִקְרַאת אֵלֶּה הָאֹמְרִים כִּי חַיֵּי בְשָׂרִים חַיֵּינוּ׃  
\v 3 \vp ג\vp* כִּי בְחַיֵּי בְשָׂרֵנוּ לֹא כְדֶרֶךְ בָּשָׂר וְדָם נֵצֵא לִקְרַאת נָשֶׁק׃  
\v 4 \vp ד\vp* כִּי גַם־כְּלֵי נִשְׁקֵנוּ אֵינָם כְּלֵי בָשָׂר כִּי אִם־חֲזָקִים לֵאלֹהִים לַהֲרֹס מִבְצָרִים׃  
\v 5 \vp ה\vp* לְהָפֵר מַחְשְׁבוֹת עֲרוּמִים לְהַשְׁפִּיל כָּל־גֵּאֶא אֲשֶׁר יִגְאֶה עַל־דַּעַת אֱלֹהִים וּלְהֹלִיךְ כָּל־לֵב בַּשְּׁבִי לְהַכְנִיעוֹ לִפְנֵי הַמָּשִׁיחַ׃  
\v 6 \vp ו\vp* וּנְכֹנִים אֲנַחְנוּ לָבֹא בְמִשְׁפָּט עִם כָּל־הַמֵּאֲנִים לִשְׁמֹעַ אִם רַק־אַתֶּם תָּשִׂימוּ שְׁכֶם אֶחָד׃  
\v 7 \vp ז\vp* הֲתִשְׁפְּטוּ לְמַרְאֵה עָיִן מִי הוּא אֲשֶׁר סָמוּךְ לִבּוֹ כִּי לַמָּשִׁיחַ הוּא יָשׁוּב יִתְבּוֹנֵן בְּנַפְשׁוֹ כִּי־כַאֲשֶׁר הוּא לַמָּשִׁיחַ כֵּן גַּם־אֲנָחְנוּ לַמָּשִׁיחַ׃  
\v 8 \vp ח\vp* וְגַם לֹא אֵבוֹשׁ אִם אוֹסִיף עוֹד לְהִתְהַלֵּל בַּשִּׁלְטוֹן אֲשֶׁר נָתַן־לָנוּ אֲדֹנֵינוּ לִבְנוֹת אֶתְכֶם וְלֹא לִפְרוֹץ בָּכֶם׃  
\v 9 \vp ט\vp* אַךְ לֹא יַחְשְׁבֵנִי אִישׁ כְּמַחֲרִיד אֶתְכֶם בְּאִגְּרוֹת׃  
\v 10 \vp י\vp* בַּעֲבוּר הָאֹמְרִים עָלַי הִנֵּה אִגְּרוֹתָיו נִכְבָּדוֹת וְקָשׁוֹת וּמַרְאֵה פָנָיו רַע וְנִיבוֹ נִבְזֶה׃  
\v 11 \vp יא\vp* כִּי הַחשֵׁב כָּזֹאת הֲלֹא יֵדַע כִּי־כִלְשׁוֹן אִגַּרְתֵּנוּ מֵרָחוֹק כֵּן נִשְׁמֹר לַעֲשׂוֹת כַּאֲשֶׁר נָבוֹא פָּנִים בְּפָנִים׃  
\v 12 \vp יב\vp* כִּי לֹא נָעֹז לְהִתְחַשֵּׁב וּלְהִתְמַשֵּׁל כַּאֲנָשִׁים הַמִּתְהַלְּלִים בְּמוֹ־פִיהֶם הֵן הֵמָּה חַסְרֵי לֵב הַמֹּדְדִים נַפְשָׁם בְּמִדַּת נַפְשָׁם וְעֹרְכֵי עֶרְכָּם בְּעֶרְכָּם׃  
\v 13 \vp יג\vp* וַאֲנַחְנוּ לֹא נִתְהַלֵּל לִבְלִי־חֹק כִּי אִם־לְפִי קַו הַמִּדָּה אֲשֶׁר חָלַק־לָנוּ אֱלֹהִים בַּמִּדָּה זוּ אֲשֶׁר תִּתְּנֵנוּ לָגֶשֶׁת אֲלֵיכֶם׃  
\v 14 \vp יד\vp* כִּי לֹא עָבַרְנוּ חֹק כְּאִלּוּ אֵין לָנוּ לָגֶשֶׁת אֲלֵיכֶם כִּי הֲלֹא בִבְשׁרַת הַמָּשִׁיחַ כְּבָר קִדַּמְנוּ לְהַגִּיעַ עָדֵיכֶם׃  
\v 15 \vp טו\vp* וְלֹא נִתְהַלֵּל לִבְלִי־חֹק לִנְגֹּעַ בְּנַחֲלַת יְגִיעַת אֲחֵרִים אֲבָל יֶשׁ־לָנוּ תִקְוָה כִּי־תִרְבֶּה אֱמוּנַתְכֶם וְכֵן יִגְדַּל כְּבוֹדֵנוּ בָכֶם לְפִי קַו הַמִּדָּה כֻלָּהּ עַד־לְמַעְלָה רֹאשׁ׃  
\v 16 \vp טז\vp* וְגַם־נְבַשֵּׂר אֶת־הַבְּשׁרָה מִכֶּם וָהָלְאָה כִּי לֹא נָבוֹא לְהִתְהַלֵּל בַּחֲבָלִים נָפְלוּ לַאֲחֵרִים׃  
\v 17 \vp יז\vp* אַךְ הַמִּתְהַלֵּל יִתְהַלֵּל בַּיהוָֹה׃  
\v 18 \vp יח\vp* כִּי לֹא זֶה הוּא אֲשֶׁר פִּיו יְשַׁבְּחֶנּוּ נֶאֱמָן הוּא כִּי אִם־זֶה אֲשֶׁר יְשַׁבְּחֶנּוּ פִּי יְהוָֹה׃   
\c 11
\cp  יא
\cl פרק יא 
\p
\v 1 \vp א\vp* אַחֲלַי שָׂאוּנִי־נָא מְעַט בְּאִוַּלְתִּי אַךְ יָדַעְתִּי כִּי נָשׁא תִּשָּׁאֻנִי׃  
\v 2 \vp ב\vp* כִּי קִנֵּאתִי לָכֶם קִנְאַת אֱלֹהִים וְיִעַדְתִּי אֶתְכֶם לָאִישׁ הוּא הַמָּשִׁיחַ אֲשֶׁר לְפָנָיו הִנְנִי לְהַעֲמִידְכֶם כִּבְתוּלָה תַּמָּה׃  
\v 3 \vp ג\vp* אַךְ יָרֵאתִי כִּי כַאֲשֶׁר הִשִּׁיא הַנָּחָשׁ אֶת־חַוָּה בְּעָרְמָתוֹ כֵּן גַּם־אַתֶּם פֶּן־תָּסִירוּ אֶת־לִבְּכֶם וְאֶת־תֻּמַּתְכֶם מֵאַחֲרֵי הַמָּשִׁיחַ׃  
\v 4 \vp ד\vp* לוּ אִישׁ הַבָּא אֲלֵיכֶם יַגִּיד לָכֶם יֵשׁוּעַ אַחֵר אֲשֶׁר לֹא הִגַּדְנוּ אוֹ כִי תִקְחוּ רוּחַ אַחֶרֶת אֲשֶׁר לֹא־לְקַחְתֶּם אוֹ בְשׁרָה אַחֶרֶת אֲשֶׁר לֹא־קִבַּלְתֶּם אָז תּוּכְלוּ לְהָכִיל דְּבָרָיו׃  
\v 5 \vp ה\vp* אֲבָל חָשַׁבְתִּי כִּי לֹא נֹפֵל אֲנִי מֵרָאשֵׁי הַשְּׁלִיחִים אַף לֹא בְּדָבָר אֶחָד׃  
\v 6 \vp ו\vp* אִם כַּעֲרַל שְׂפָתַיִם אֲנִי בְּמִדְבָּרִי לֹא־כֵן אֲנִי בַּדָּעַת כִּי כָל־אֲשֶׁר בִּלְבָבִי הֲלֹא נוֹדַע לָכֶם בִּפְנֵי כָל־אָדָם׃  
\v 7 \vp ז\vp* הַחֵטְא חָטָאתִי כִּי הִשְׁפַּלְתִּי נַפְשִׁי לְמַעַן אַתֶּם תָּרִימוּ רֹאשׁ כִּי הֵבֵאתִי לָכֶם בְּשׁרַת אֱלֹהִים בְּלֹא־כָסֶף׃  
\v 8 \vp ח\vp* שַׁלּוֹתִי קְהִלּוֹת אֲחֵרוֹת כִּי לָקַחְתִּי מֵהֶן שְׂכַר פְּעֻלָּתִי לַעֲבֹד אֶתְכֶם חִנָּם׃  
\v 9 \vp ט\vp* וּבִהְיוֹתִי עִמָּכֶם וָאֶחְסַר לֹא הֶלְאֵיתִי אִישׁ כִּי דֵי מַחְסֹרִי מִלְאוּ הָאַחִים אֲשֶׁר בָּאוּ מִמַּקְדּוֹנְיָא וָאֶשְׁתַּמֵּר מְאֹד מִהְיוֹת עֲלֵיכֶם לְמַשָּׂא וְכֵן אוֹסִיף לְהִשְׁתַּמֵּר׃  
\v 10 \vp י\vp* כַּאֲשֶׁר הַמָּשִׁיחַ וַאֲמִתּוֹ לִי הוּא כֵּן לֹא תֵעָצֵר מִמֶּנִּי תְּהִלָּתִי זוּ בִּגְלִילוֹת אֲכַיָּא׃  
\v 11 \vp יא\vp* וְעַל־מַה־זֶּה אֶשְׁתַּמָּר הַעַל אֲשֶׁר לֹא אָהַבְתִּי אֶתְכֶם הָאֱלֹהִים הוּא יוֹדֵעַ׃  
\v 12 \vp יב\vp* אַךְ כַּאֲשֶׁר עָשִׂיתִי כֵּן אוֹסִיף לַעֲשׂוֹת לְהַעֲבִיר תֹּאֲנָה מִן־הַמְבַקְשִׁים תֹּאֲנָה לְמַעַן יוּכְלוּ לְהִתְחַשֵּׁב בִּתְהִלָּתָם כָּמֹנוּ׃  
\v 13 \vp יג\vp* כִּי אֲנָשִׁים כָּאֵלֶּה שְׁלִיחֵי שֶׁקֶר הֵם עֹשֵׂי רְמִיָּה הַמִּתְחַפְּשִׂים לִשְׁלִיחֵי הַמָּשִׁיחַ׃  
\v 14 \vp יד\vp* וְאֵין זֶה פֶּלֶא אַחֲרֵי אֲשֶׁר גַּם־הַשָּׂטָן מִתְחַפֵּשׂ לְמַלְאַךְ אוֹר׃  
\v 15 \vp טו\vp* עַל־כֵּן לֹא דָבָר גָּדוֹל הוּא אִם יִתְחַפְּשׂוּ גַם־מְשָׁרְתָיו לִמְשָׁרְתֵי צֶדֶק אֲשֶׁר בְּאַחֲרִיתָם מִפְּרִי מַעַלְלֵיהֶם יֹאכֵלוּ׃  
\v 16 \vp טז\vp* וְעוֹד אֲנִי אֹמֵר אַל־יַחְשְׁבֵנִי אִישׁ לֶאֱוִיל כִּי אִם־כֵּן אַף כֶּאֱוִיל שְׂאוּ פָנַי וְאֶתְהַלֵּל מְעַט גַּם־אָנִי׃  
\v 17 \vp יז\vp* אֵת אֲשֶׁר אֲנִי דֹבֵר לֹא מִפִּי הָאָדוֹן הוּא כִּי אִם־דְּבָרַי כְּאֹחֵז בְּסִכְלוּת לַאֲשֶׁר סָמוּךְ לִבִּי בִּתְהִלָּתִי׃  
\v 18 \vp יח\vp* אַחֲרֵי אֲשֶׁר רַבִּים מִתְהַלְּלִים כְּדֶרֶךְ בָּשָׂר וָדָם אֶתְהַלֵּל גַּם־אָנִי׃  
\v 19 \vp יט\vp* כִּי תִשְׂאוּ אֶת־הָאֱוִילִים בְּחֵפֶץ לֵב יַעַן חֲכָמִים אַתֶּם׃  
\v 20 \vp כ\vp* כִּי הֲלֹא תִשְׂאוּ אִם־יַעֲבִיד אֶתְכֶם אִישׁ אִם־יְבַלַּע אֶתְכֶם אִישׁ אִם־יַעֲשֹׁק אֶתְכֶם אִם־יִתְנַשֵּׂא עֲלֵיכֶם אוֹ יַכֶּה אֶתְכֶם עַל־הַלֶּחִי׃  
\v 21 \vp כא\vp* לְבָשְׁתֵּנוּ אֲנִי דֹבֵר כְּמוֹ אִם רְפֵי יָדַיִם הָיִינוּ לַעֲשׂוֹת כָּאֵלֶּה אֲבָל בַּאֲשֶׁר יָעִיז אִישׁ אֶת־פָּנָיו הִנֵּה כְּאֹחֵז בְּסִכְלוּת אֲנִי אֹמֵר אָעִיז פָּנַי גַּם־אָנִי׃  
\v 22 \vp כב\vp* אִם הֵם עִבְרִים כֵּן גַּם־אָנִי אִם הֵם יִשְׂרְאֵלִים כֵּן גַּם־אָנִי אִם הֵם זֶרַע אַבְרָהָם כֵּן גַּם־אָנִי׃  
\v 23 \vp כג\vp* אִם הֵם מְשָׁרְתֵי הַמָּשִׁיחַ כְּסָר טַעַם אֲנִי דֹבֵר אֲנִי עֹלֶה עֲלֵיהֶם בְּרֹב עָמָל בְּבָתֵּי כְלָאִים פְּעָמִים רַבּוֹת בְּמַהֲלֻמּוֹת לְאֵין סְפֹרוֹת וּפַעַם אַחֲרֵי פַעַם בְּשַׁעֲרֵי מָוֶת׃  
\v 24 \vp כד\vp* חָמֵשׁ פְּעָמִים הֻכֵּיתִי מִידֵי הַיְּהוּדִים אַרְבָּעִים חֲסֵרָה אֶחָת׃  
\v 25 \vp כה\vp* שָׁלשׁ פְּעָמִים הֻכֵּיתִי בַשּׁוֹטִים פַּעַם אַחַת סֻקַּלְתִּי בָאֲבָנִים שָׁלשׁ פְּעָמִים נִשְׁבְּרָה אֳנִיָּתִי וּכְיוֹם תָּמִים הָיִיתִי בִּמִצֻלוֹת יָם׃  
\v 26 \vp כו\vp* בְּמַסָּעוֹת רַבִּים וּמָגוֹר מִסָּבִיב מִשֶּׁטֶף מַיִם מָגוֹר מִפְּנֵי שֹׁדְדִים מָגוֹר מִפְּנֵי בְנֵי עַמִּי מָגוֹר מִפְּנֵי גוֹיִם מָגוֹר בָּעִיר מָגוֹר בַּמִּדְבָּר מָגוֹר בַּיָּם וּמָגוֹר בְּקֶרֶב אֲחֵי שָׁקֶר׃  
\v 27 \vp כז\vp* בְּעָמָל וּבִתְלָאָה וּבִבְלִי־שֵׁנָה פְּעָמִים הַרְבֵּה בִּבְלִי־לֶחֶם וּבִבְלִי־מָיִם וְגַם־רַבּוֹת עִנֵּיתִי בַצּוֹם נַפְשִׁי וּבִבְלִי שִׂמְלָה לְעוֹרִי בַּקָּרָה׃  
\v 28 \vp כח\vp* מִלְּבַד הֲמוֹן צְרָכַי יוֹם יוֹם וְדַאֲגַת כָּל־הַקְּהִלּוֹת אֲשֶׁר עָלַי הָיוּ כֻּלָּנָה׃  
\v 29 \vp כט\vp* מִי חָלָה וְלֹא חֻלֵּיתִי מִי נִכְשַׁל וְלֹא בָעֲרָה אֵשׁ בַּהֲגִיגִי׃  
\v 30 \vp ל\vp* אִם־עָלַי לְהִתְהַלֵּל אֶתְהַלֵּל בְּתַחֲלוּאָי׃  
\v 31 \vp לא\vp* הִנֵּה הָאֱלֹהִים הָאָב לְיֵשׁוּעַ הַמָּשִׁיחַ אֲדוֹנֵינוּ בָּרוּךְ הוּא לְעוֹלָם וָעֶד הוּא יֹדֵעַ כִּי לֹא אֲשַׁקֵּר׃  
\v 32 \vp לב\vp* וּבְדַמֶּשֶׂק הַנְּצִיב אֲשֶׁר לַאֲרֵטַס הַמֶּלֶךְ שָׁמַר שָׁם אֶל־הָעִיר הַהִיא לְלָכְדֵנִי׃  
\v 33 \vp לג\vp* וּבְסַל בְּעַד הַחַלּוֹן הוֹרִידוּ אֹתִי מֵעַל הַחוֹמָה וְנִמְלַטְתִּי מִיָּדוֹ׃   
\c 12
\cp  יב
\cl פרק יב 
\p
\v 1 \vp א\vp* אָמְנָם לֹא לְהוֹעִיל לִי לְהִתְהַלֵּל אַךְ בָּאתִי לְסַפֵּר מַרְאוֹת וְחֶזְיֹנוֹת מֵאֵת הָאָדוֹן׃  
\v 2 \vp ב\vp* זֶה אַרְבַּע־עֶשְׂרֵה שָׁנָה יָדַעְתִּי אִישׁ בַּמָּשִׁיחַ וְלֹא יָכֹלְתִּי לָדַעַת אִם־בַּגּוּף הֱיוֹתוֹ אוֹ־מִחוּץ לַגּוּף כִּי פְּלִיאָה דַעַת מִמֶּנִּי אֱלֹהִים הוּא יֹדֵעַ וְהָאִישׁ הַהוּא עָלָה לָרָקִיעַ הַשְּׁלִישִׁי׃  
\v 3 \vp ג\vp* אֶת־הָאִישׁ הַהוּא יָדָעְתִּי אִם־בַּגּוּף הֱיוֹתוֹ אוֹ־מִחוּץ לַגּוּף לֹא יָכֹלְתִּי לָדַעַת אֱלֹהִים הוּא יֹדֵעַ׃  
\v 4 \vp ד\vp* וְאֶל־תּוֹךְ הַפַּרְדֵּס עָלָה וַיִּשְׁמַע אֲשֶׁר עָצְמוּ מִסַּפֵּר וְאֵין כֹּחַ בִּלְשׁוֹן אָדָם לְמַלֲלָם׃  
\v 5 \vp ה\vp* בָּאִישׁ הַהוּא אֶתְהַלֵּל וּבְנַפְשִׁי לֹא אֶתְהַלֵּל זוּלָתִי בְּתַחֲלוּאָי׃  
\v 6 \vp ו\vp* וְאַף לוּ־חָפַצְתִּי לְהִתְהַלֵּל לֹא־הָיִיתִי כִכְסִיל אַחֲרֵי אֲשֶׁר אֱמֶת אֲנִי מְדַבֵּר אַךְ אֶעֱצֹר בְּמִלִּין פֶּן־יַחֲשֹׁב אִישׁ עֶרְכִּי לְמַעְלָה מֵאֲשֶׁר יִרְאֶה־בִּי אוֹ מֵאֲשֶׁר יִשְׁמַע מִמֶּנִּי׃  
\v 7 \vp ז\vp* וּלְבִלְתִּי אֶתְנַשֵּׂא בְּתַעֲצֻמּוֹת הַחֶזְיֹנוֹת יֶתֶר מִדַּי נִתַּן־לִי קוֹץ מַכְאִיב בִּבְשָׂרִי וְהוּא מַלְאַךְ הַשָּׂטָן לְהַכֹּתֵנִי בְאֶגְרֹף פֶּן־אֶתְנַשֵּׂא יֶתֶר מִדָּי׃  
\v 8 \vp ח\vp* וְעַל־זֹאת הִתְחַנַּנְתִּי אֶל־הָאָדוֹן זֶה שָׁלֹשׁ פְּעָמִים לַהֲסִירֵהוּ מִמֶּנִּי׃  
\v 9 \vp ט\vp* וַיֹּאמֶר אֵלַי חַסְדִּי רַב־לְךָ כִּי לְאֵין אוֹנִים אַשְׁלִים גְּבוּרָתִי עַל־כֵּן מִטּוּב לֵב אֶתְהַלֵּל בְּתַחֲלוּאָי לְמַעַן תִּמָּצֵא בִי גְּבוּרַת הַמָּשִׁיחַ׃  
\v 10 \vp י\vp* וְעַל־כֵּן רָצְתָה נַפְשִׁי בְתַחֲלוּאִים וּבְגִדּוּפִים וְלִהְיוֹת נִרְדָּף וְלָשֶׁבֶת בְּמָצוֹק וּבְחֹסֶר כֹּל לְמַעַן הַמָּשִׁיחַ כִּי אִם־נְפוּגֹתִי אָז גִּבּוֹר אָנִי׃  
\v 11 \vp יא\vp* הָיִיתִי לִכְסִיל בְּהִתְהַלֲלִי אַךְ אַתֶּם אִלְצְתּוּנִי כִּי עֲלֵיכֶם הָיָה לְהַלֲלֵנִי יַעַן לֹא־נֹפֵל אֲנִי מֵרָאשֵׁי הַשְּׁלִיחִים אַף כִּי־כְאַיִן אָנִי׃  
\v 12 \vp יב\vp* אָמְנָם הָאֹתוֹת כִּי אֲנִי הוּא הַשָּׁלִיחַ נַעֲשׂוּ בְקִרְבְּכֶם בְּכָל־אֶרֶךְ רוּחַ בְּמוֹפְתִים וּבְנִפְלָאוֹת וּבַעֲלִילוֹת נִשְׂגָּבוֹת׃  
\v 13 \vp יג\vp* כִּי־בַמֶּה נֹפְלִים אַתֶּם מִיֶּתֶר הַקְּהִלּוֹת אִם־לֹא בַּאֲשֶׁר לֹא הוֹגַעְתִּי אֶתְכֶם סִלְחוּ־לִי לְעַוָּתָתִי זֹאת׃  
\v 14 \vp יד\vp* הִנְנִי נָכוֹן לָבוֹא אֲלֵיכֶם פַּעַם שְׁלִישִׁית וּלְמַשָּׂא לֹא אֶהְיֶה עֲלֵיכֶם כִּי לֹא הוֹנְכֶם אֲנִי מְבַקֵּשׁ כִּי אִם־אֵת לִבְּכֶם כִּי לֹא מִשְׁפַּט הַבָּנִים לֶאֱצֹר אוֹצָרוֹת לַאֲבוֹתָם כִּי אִם־הָאָבוֹת לִבְנֵיהֶם׃  
\v 15 \vp טו\vp* וַאֲנִי הִנְנִי נֹתֵן לָכֶם אֶת־אֲשֶׁר לִי בְּחֵפֶץ לְבָבִי וְגַם אֶת־נַפְשִׁי אֶתֵּנָה אַף כִּי־כַאֲשֶׁר אוֹסִיף לְאַהֲבָה אֶת־נַפְשְׁכֶם כֵּן תַּמְעִיטוּ לְאַהֲבָה אֶת־נַפְשִׁי׃  
\v 16 \vp טז\vp* אֲבָל לוּ יְהִי־כֵן אָנֹכִי לֹא הָיִיתִי לָכֶם לְמַעֲמָסָה רַק בִּהְיוֹתִי עָרוּם לָכַדְתִּי אֶתְכֵם בְּעָרְמָה׃  
\v 17 \vp יז\vp* הַאִם הוֹנֵיתִי אֶתְכֶם עַל־יְדֵי אָח מֵאַחַד מֵאֵלֶּה אֲשֶׁר שָׁלַחְתִּי אֲלֵיכֶם׃  
\v 18 \vp יח\vp* הִפְצַרְתִּי בְטִיטוֹס לָלֶכֶת וְגַם־אַחַד הָאַחִים שָׁלַחְתִּי אִתּוֹ הַאִם־הוֹנָה אֶתְכֵם טִיטוֹס הֲלֹא בְרוּחַ אַחַת וּבְאֹרַח אֶחָד צְעָדֵינוּ כּוֹנָנוּ׃  
\v 19 \vp יט\vp* אוּלַי עוֹדְכֶם חשְׁבִים כִּי הִנְנוּ מִצְטַדְּקִים לִפְנֵיכֶם אֲבָל דְּבָרֵינוּ נֶגֶד פְּנֵי הָאֱלֹהִים וּמְשִׁיחוֹ כִּי כָל־אֵלֶּה רַק בִּגְלַלְכֶם יְדִידִים לְהִבָּנוֹת מִמֶּנּוּ׃  
\v 20 \vp כ\vp* כִּי יָרֵא אָנֹכִי בְּבֹאִי פֶּן־אֶמְצָאֲכֵם לֹא כִלְבָבִי וְאַתֶּם תִּמְצָאוּנִי לֹא כִלְבַבְכֶם פֶּן־אֶמְצָא בָכֶם מְרִיבָה וְקִנְאָה עֶבְרָה וּמָדוֹן הוֹלְכֵי רָכִיל וּמוֹצִיאֵי דִבָּה גְּאוֹן זֵדִים וּמְהוּמָה רַבָּה׃  
\v 21 \vp כא\vp* פֶּן־בְּבֹאִי עוֹד יַשְׁפִּילֵנִי אֱלֹהַי לִפְנֵיכֶם וְהִתְעַצַּבְתִּי אֶל־לִבִּי עַל־רַבִּים מֵהֶם אֲשֶׁר־חָטְאוּ כְבָר וְלֹא שָׁבוּ מִן־הַתּוֹעֵבָה וּמִן־הַזְּנוּת וּמִן־הַנְּבָלָה אֲשֶׁר עָשׂוּ׃   
\c 13
\cp  יג
\cl פרק יג 
\p
\v 1 \vp א\vp* הִנְנִי בָא אֲלֵיכֶם פַּעַם שְׁלִישִׁית עַל־פִּי שְׁנַיִם עֵדִים אוֹ עַל־פִּי שְׁלשָׁה עֵדִים יָקוּם כָּל־דָּבָר׃  
\v 2 \vp ב\vp* הֵן אָמַרְתִּי מֵאָז וּכְמוֹ מִקָּרוֹב כַּאֲשֶׁר הָיִיתִי עִמָּכֶם בַּפַּעַם הַשֵּׁנִית כֵּן גַּם־עַתָּה מֵרָחוֹק טֶרֶם בֹּאִי הִנְנִי מַגִּיד וְכֹתֵב לְכָל־אֲשֶׁר חָטְאוּ כְבָר וּלְכָל־יֶתֶר אַנְשֵׁי קְהִלַּתְכֶם כִּי לֹא־אוֹסִיף לָחוּס בְּשׁוּבִי אֲלֵיכֶם׃  
\v 3 \vp ג\vp* יַעַן לִבְחֹן אַתֶּם מְבַקְשִׁים אִם־הַמָּשִׁיחַ דִּבֶּר בִּי אֲשֶׁר לֹא קָצְרָה יָדוֹ לָכֶם כִּי כְגִבּוֹר הוּא בְּקִרְבְּכֶם׃  
\v 4 \vp ד\vp* כִּי אַף־אִם־נִצְלַב כֶּאֱנוֹשׁ אָנוּשׁ חַי הוּא בִּגְבוּרַת אֱלֹהִים וְכֵן בּוֹ גַּם־אֲנַחְנוּ קִצְרֵי־יָד הִנֵּנוּ אַךְ חַיִּים עִמּוֹ בִּגְבוּרַת אֱלֹהִים לְטוֹב לָכֶם׃  
\v 5 \vp ה\vp* נַסּוּ אֶת־נַפְשְׁכֶם אִם־בֶּאֱמוּנָה אַתֶּם עֹמְדִים וְהִבָּחֵנוּ אוֹ הֲטֶרֶם תֵּדְעוּ מִנַּפְשְׁכֶם כִּי יֵשׁוּעַ הַמָּשִׁיחַ בְּקִרְבְּכֶם אִם־לֹא סִיגִים אַתֶּם׃  
\v 6 \vp ו\vp* וַאֲנִי הוֹחַלְתִּי כִּי תַשְׂכִּילוּ אֲשֶׁר לֹא כֶסֶף נִמְאָס אֲנָחְנוּ׃  
\v 7 \vp ז\vp* וְאֶל־הָאֱלֹהִים נִתְפַּלֵּל לְבִלְתִּי תַעֲשׂוּן כָּל־רָע לֹא לְמַעַן הִוָּדַע כִּי אֲנַחְנוּ מְזֻקָּקִים כִּי אִם־לְמַעַן תַּעֲשׂוּן אַתֶּם אֶת־הַטּוֹב אַף כִּי־אֲנַחְנוּ כְּסִיגִים נֵחָשֵׁב׃  
\v 8 \vp ח\vp* כִּי לֹא נוּכַל עֲשׂוֹת דָּבָר לְנֶגֶד הָאֱמֶת כִּי אִם־בְּעַד הָאֱמֶת׃  
\v 9 \vp ט\vp* כִּי גַם־נָגִילָה אִם גִּבֹּרֵי כֹחַ אַתֶּם אַף כִּי אֲנַחְנוּ כְּדַלֵּי כֹחַ נֵחָשֵׁב כִּי אֶל־הַדָּבָר הַזֶּה אָנוּ מִתְפַּלְלִים לִהְיוֹתְכֶם שְׁלֵמִים׃  
\v 10 \vp י\vp* וְעַל־כֵּן כָּתַבְתִּי אֶת־הַדְּבָרִים הָאֵלֶּה בְּעוֹדֶנִּי רָחוֹק מִכֶּם לְמַעַן בְּבֹאִי לֹא יִהְיֶה־לִּי מָקוֹם לְדַבֵּר אִתְּכֶם קָשׁוֹת לְפִי הַכֹּחַ אֲשֶׁר נָתַן לִי הָאָדוֹן לִבְנוֹת אֶתְכֶם וְלֹא לִפְרוֹץ בָּכֶם׃  
\v 11 \vp יא\vp* וְעַתָּה שִׂישׂוּ אַחַי הֱיוּ תְמִימִים וְהִתְחַזָּקוּ יַחֲדוּ אֶת־לִבְּכֶם וְאֶת־הַשָּׁלוֹם אֶהֱבוּ וֵאלֹהֵי הָאַהֲבָה וְהַשָּׁלוֹם יִהְיֶה עִמָּכֶם׃  
\v 12 \vp יב\vp* שַׁאֲלוּ לְשָׁלוֹם אִישׁ אֶת־אָחִיו בִּנְשִׁיקַת הַקֹּדֶשׁ׃  
\v 13 \vp יג\vp* הַקְּדוֹשִׁים כֻּלָּם שֹׁאֲלִים לְשָׁלוֹם לָכֶם׃  
\v 14 \vp יד\vp* חֶסֶד אֲדֹנֵינוּ יֵשׁוּעַ הַמָּשִׁיחַ וְאַהֲבַת הָאֱלֹהִים וְלִוְיַת רוּחַ הַקֹּדֶשׁ עִם־כֻּלְּכֶם אָמֵן׃   