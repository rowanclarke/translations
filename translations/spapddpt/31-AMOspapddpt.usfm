\v 4 \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w Por|strong="H5921"\+w* \+w tres|strong="H7969"\+w* \+w pecados|strong="H6588"\+w* \+w de|strong="H5921"\+w* \+w Judá|strong="H3063"\+w*, \+w y|strong="H5921"\+w* \+w por|strong="H5921"\+w* \+w el|strong="H5921"\+w* cuarto, \+w no|strong="H3808"\+w* \+w le|strong="H5921"\+w* revocaré su castigo: \+w Porque|strong="H5921"\+w* despreciaron \+w la|strong="H5921"\+w* \+w Ley|strong="H8451"\+w* \+w de|strong="H5921"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w y|strong="H5921"\+w* \+w no|strong="H3808"\+w* \+w guardaron|strong="H8104"\+w* sus \+w Ordenanzas|strong="H2706"\+w*, \+w y|strong="H5921"\+w* \+w los|strong="H5921"\+w* extraviaron sus \+w mentiras|strong="H3577"\+w*, tras \+w las|strong="H5921"\+w* cuales \+w anduvieron|strong="H1980"\+w* sus antepasados.\wj*  
\v 5 \wj Encenderé fuego en \+w Judá|strong="H3063"\+w*, que devorará los palacios de Jerusalén.\wj*   
\p
\v 6 \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w Por|strong="H5921"\+w* \+w tres|strong="H7969"\+w* \+w pecados|strong="H6588"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w*, \+w y|strong="H5921"\+w* \+w por|strong="H5921"\+w* \+w el|strong="H5921"\+w* cuarto, \+w no|strong="H3808"\+w* revocaré su castigo: \+w Porque|strong="H5921"\+w* venden \+w al|strong="H5921"\+w* \+w justo|strong="H6662"\+w* \+w por|strong="H5921"\+w* \+w dinero|strong="H3701"\+w*, \+w y|strong="H5921"\+w* \+w al|strong="H5921"\+w* necesitado \+w por|strong="H5921"\+w* un par \+w de|strong="H5921"\+w* sandalias.\wj*  
\v 7 \wj Codician \+w hasta|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w polvo|strong="H6083"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w tierra|strong="H6083"\+w* \+w que|strong="H5921"\+w* \+w está|strong="H5921"\+w* \+w sobre|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w cabeza|strong="H7218"\+w* \+w del|strong="H5921"\+w* \+w pobre|strong="H1800"\+w*, \+w y|strong="H5921"\+w* pervierten \+w la|strong="H5921"\+w* senda \+w del|strong="H5921"\+w* humilde. Un hombre \+w y|strong="H5921"\+w* su padre \+w se|strong="H5921"\+w* unen \+w con|strong="H5921"\+w* \+w la|strong="H5921"\+w* misma joven, \+w a|strong="H3068"\+w* fin \+w de|strong="H5921"\+w* profanar \+w mi|strong="H5921"\+w* \+w santo|strong="H6944"\+w* \+w Nombre|strong="H8034"\+w*.\wj*  
\v 8 \wj \+w Se|strong="H5921"\+w* acuestan \+w sobre|strong="H5921"\+w* ropas retenidas \+w en|strong="H5921"\+w* prenda \+w junto|strong="H5921"\+w* \+w a|strong="H3068"\+w* \+w cualquier|strong="H3605"\+w* \+w altar|strong="H4196"\+w* \+w y|strong="H5921"\+w* \+w beben|strong="H8354"\+w* \+w el|strong="H5921"\+w* \+w vino|strong="H3196"\+w* \+w de|strong="H5921"\+w* \+w los|strong="H5921"\+w* multados \+w en|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w casa|strong="H1004"\+w* \+w de|strong="H5921"\+w* su \+tl ʼelohim\+tl*.\wj*   
\p
\v 9 \wj Yo \+w destruí|strong="H8045"\+w* \+w al|strong="H8478"\+w* amorreo \+w ante|strong="H6440"\+w* \+w ellos|strong="H1931"\+w*, \+w cuya|strong="H1931"\+w* estatura \+w era|strong="H1931"\+w* \+w como|strong="H8478"\+w* \+w la|strong="H1931"\+w* \+w altura|strong="H1363"\+w* \+w de|strong="H8478"\+w* \+w los|strong="H1931"\+w* cedros y fuertes \+w como|strong="H8478"\+w* \+w los|strong="H1931"\+w* robles. Sin embargo Yo \+w destruí|strong="H8045"\+w* \+w su|strong="H1931"\+w* \+w fruto|strong="H6529"\+w* \+w arriba|strong="H4605"\+w* y \+w sus|strong="H1931"\+w* \+w raíces|strong="H8328"\+w* \+w abajo|strong="H8478"\+w*,\wj*  
\v 10 \wj Yo, Quien los \+w saqué|strong="H5927"\+w* de la tierra de \+w Egipto|strong="H4714"\+w* y los conduje por el \+w desierto|strong="H4057"\+w* durante 40 \+w años|strong="H8141"\+w* para que poseyeran la tierra del amorreo.\wj*  
\v 11 \wj Entonces levanté \+w a|strong="H3068"\+w* algunos \+w de|strong="H1121"\+w* sus \+w hijos|strong="H1121"\+w* para \+w que|strong="H1121"\+w* fueran \+w profetas|strong="H5030"\+w* y \+w a|strong="H3068"\+w* algunos \+w de|strong="H1121"\+w* sus jóvenes para \+w que|strong="H1121"\+w* fueran nazareos. ¿No \+w es|strong="H2063"\+w* \+w así|strong="H2063"\+w*, \+w oh|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*? \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 12 \wj Pero ustedes dieron \+w a|strong="H3068"\+w* \+w beber|strong="H8248"\+w* \+w vino|strong="H3196"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H5921"\+w* nazareos \+w y|strong="H5921"\+w* \+w mandaron|strong="H6680"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H5921"\+w* \+w profetas|strong="H5030"\+w*: \+w No|strong="H3808"\+w* profeticen.\wj*  
\v 13 \wj \+w Ciertamente|strong="H2009"\+w*, ustedes me presionaron, \+w como|strong="H8478"\+w* una carreta es presionada cuando está cargada \+w de|strong="H8478"\+w* gavillas.\wj*  
\v 14 \wj \+w No|strong="H3808"\+w* hay \+w escape|strong="H4422"\+w* para el ágil, \+w ni|strong="H3808"\+w* el \+w fuerte|strong="H2389"\+w* saca su \+w fuerza|strong="H3581"\+w*, \+w ni|strong="H3808"\+w* el \+w valiente|strong="H1368"\+w* salva su \+w vida|strong="H5315"\+w*.\wj*  
\v 15 \wj El \+w que|strong="H3808"\+w* empuña el \+w arco|strong="H7198"\+w* \+w no|strong="H3808"\+w* \+w resistirá|strong="H5975"\+w*, el ligero de \+w pies|strong="H7272"\+w* \+w no|strong="H3808"\+w* \+w escapará|strong="H4422"\+w*, \+w ni|strong="H3808"\+w* el jinete \+w salvará|strong="H4422"\+w* su \+w vida|strong="H5315"\+w*.\wj*  
\v 16 \wj Aun \+w el|strong="H1931"\+w* más bravo entre \+w los|strong="H1931"\+w* guerreros \+w huirá|strong="H5127"\+w* \+w desnudo|strong="H6174"\+w* en \+w aquel|strong="H1931"\+w* \+w día|strong="H3117"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\c 3  
\s1 Gloria y tragedia de Israel  
\p
\v 1 \w Oh|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w escuchen|strong="H8085"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w que|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w habla|strong="H1696"\w* \w contra|strong="H5921"\w* ustedes, \w contra|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w familia|strong="H4940"\w* \w que|strong="H5921"\w* \w saqué|strong="H5927"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*:  
\v 2 \wj \+w Entre|strong="H5921"\+w* \+w todas|strong="H3605"\+w* \+w las|strong="H5921"\+w* \+w familias|strong="H4940"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra, \+w solo|strong="H7535"\+w* \+w los|strong="H5921"\+w* \+w conocí|strong="H3045"\+w* \+w a|strong="H3068"\+w* ustedes. \+w Por|strong="H5921"\+w* \+w tanto|strong="H3651"\+w*, \+w los|strong="H5921"\+w* castigaré \+w por|strong="H5921"\+w* \+w todas|strong="H3605"\+w* sus \+w iniquidades|strong="H5771"\+w*.\wj*   
\p
\v 3 ¿\w Andarán|strong="H3212"\w* \w dos|strong="H8147"\w* \w juntos|strong="H3162"\w* si \w no|strong="H1115"\w* están de acuerdo?  
\v 4 ¿\w Rugirá|strong="H7580"\w* el león en el \w bosque|strong="H3293"\w* si \w no|strong="H1115"\w* tiene presa? ¿\w Rugirá|strong="H7580"\w* el \w leoncillo|strong="H3715"\w* en su guarida si \w no|strong="H1115"\w* apresó?  
\v 5 ¿\w Caerá|strong="H5307"\w* \w el|strong="H5921"\w* \w pájaro|strong="H6833"\w* \w al|strong="H5921"\w* suelo \w si|strong="H3808"\w* \w no|strong="H3808"\w* hay trampa? ¿Saltará \w la|strong="H5921"\w* trampa \w del|strong="H4480"\w* suelo \w sin|strong="H3808"\w* \w no|strong="H3808"\w* atrapó?  
\v 6 ¿\w Se|strong="H1961"\w* \w tocará|strong="H8628"\w* la \w trompeta|strong="H7782"\w* en la \w ciudad|strong="H5892"\w* \w sin|strong="H3808"\w* alborotar al \w pueblo|strong="H5971"\w*? ¿\w Sucederá|strong="H1961"\w* alguna calamidad en la \w ciudad|strong="H5892"\w* \w si|strong="H3808"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w no|strong="H3808"\w* la envía?  
\v 7 \w Ciertamente|strong="H3588"\w* \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd* \w nada|strong="H3808"\w* \w hace|strong="H6213"\w* \w sin|strong="H3808"\w* revelar \w su|strong="H3588"\w* secreto \w a|strong="H3068"\w* sus esclavos \w profetas|strong="H5030"\w*.  
\v 8 \w Si|strong="H3808"\w* \w el|strong="H4310"\w* león ruge, ¿\w quién|strong="H4310"\w* \w no|strong="H3808"\w* \w temerá|strong="H3372"\w*? \w Si|strong="H3808"\w* \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd* \w habla|strong="H1696"\w*, ¿\w quién|strong="H4310"\w* \w no|strong="H3808"\w* \w profetizará|strong="H5012"\w*?   
\p
