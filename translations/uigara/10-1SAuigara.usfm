\id 1SA
\h سامۇئىل «1»
\toc1 سامۇئىل «1»
\toc2 سامۇئىل «1»
\toc3 1سام.
\mt1 سامۇئىل «1»
\c 1
\s1 دەرد-ئەلەمدىن بولغان تىلەك
\m 
\v 1 ئەفرائىم تاغلىقىدىكى راماتائىم-زوفىمدا ئەلكاناھ ئىسىملىك بىر كىشى بار ئىدى. ئۇ ئەفرائىملىق بولۇپ، يەروھامنىڭ ئوغلى، يەروھام ئېلىخۇنىڭ ئوغلى، ئېلىخۇ توخۇنىڭ ئوغلى، توخۇ زۇفنىڭ ئوغلى ئىدى. \x ◘ \xo 1:1 \xt 1تار. 6‏:11، 12\x*
\v 2 ئۇنىڭ ئىككى ئايالى بار ئىدى. بىرسىنىڭ ئىسمى ھانناھ، يەنە بىرسىنىڭ ئىسمى پەنىنناھ ئىدى. پەنىنناھنىڭ بالىلىرى بار ئىدى، لېكىن ھانناھنىڭ بالىسى يوق ئىدى.
\v 3 بۇ ئادەم ھەر يىلى ئۆز شەھىرىدىن ساماۋى قوشۇنلارنىڭ سەردارى بولغان پەرۋەردىگارغا سەجدە قىلىپ قۇربانلىق سۇنغىلى شىلوھغا باراتتى. ئۇ يەردە ئەلىنىڭ خوفنىي ۋە فىنىھاس دېگەن ئىككى ئوغلى پەرۋەردىگارنىڭ كاھىنلىرى بولۇپ ئىشلەيتتى. \x ◘ \xo 1:3 \xt مىس. 23‏:14؛ قان. 16‏:16. \x*
\v 4 ھەر قېتىم ئەلكاناھ قۇربانلىق قىلغان كۈنىدە ئۇ \add قۇربانلىقتىن\add* ئايالى پەنىنناھ ۋە ئۇنىڭ ھەربىر ئوغۇل-قىزلىرىغا ئۆز ئۈلۈشىنى بېرەتتى.
\v 5 ئەمما ھانناھغا بولسا ئۇ ئىككى ھەسسىلىك ئۈلۈش بېرەتتى؛ چۈنكى ئۇ ھانناھنى تولىمۇ سۆيەتتى. لېكىن پەرۋەردىگار ئۇنى تۇغماس قىلغانىدى. \f ◼ \fr 1:5 \ft \bd «لېكىن پەرۋەردىگار ئۇنى تۇغماس قىلغانىدى»\bd* ــ ئىبرانىي تىلىدا: «لېكىن پەرۋەردىگار ئۇنىڭ بالىياتقۇسىنى ئېتىۋەتكەنىدى».\f*
\v 6 پەرۋەردىگارنىڭ ئۇنى تۇغماس قىلغانلىقىدىن ئۇنىڭ كۈندەش رەقىبى \add پەنىنناھ ھانناھنى\add* ئازابلاش ئۈچۈن ئۇنىڭ بىلەن قاتتىق قېرىشاتتى.
\v 7 ۋە ھەر يىلى، ھانناھ ھەر قېتىم پەرۋەردىگارنىڭ ئۆيىگە چىققاندا، \add پەنىنناھ\add* ئۇنىڭغا ئازار بېرەتتى. پەنىنناھ شۇنداق قىلغاچقا، ئۇ يىغلاپ ھېچ نېمە يېمەيتتى. \f ◼ \fr 1:7 \ft \bd «ۋە ھەر يىلى، ھانناھ ھەر قېتىم پەرۋەردىگارنىڭ ئۆيىگە چىققاندا، پەنىنناھ ئۇنىڭغا ئازار بېرەتتى»\bd* ــ نېمىشقا ئۇلار ھەر قېتىم «پەرۋەردىگارنىڭ ئۆيىگە چىققاندا» شۇنداق بولىدۇ؟ ــ بىزنىڭچە ھەر قېتىم بىر ئىبرانىي ئائىلە خۇدانىڭ ئالدىغا شۇنداق كەلگەندە، ئۇلار بارلىق بالىلىرى ئۈچۈن ئالاھىدە تەشەككۈر ئېيتىشى مۇمكىم. شۇ چاغلاردا پەنىنناھ ھانناھقا «سەن بىر تۇغماس!» دەپ ئەسلىتەتتى.\fp بەزى تەرجىمىلەردە مۇشۇ جۈملىنىڭ بېشىدا: «ئۇ (ئەلكاناھ) ھەر يىلى پەرۋەردىگارنىڭ ئۆيىگە چىققاندا، ھانناھ ئۇنىڭغا ھەمراھ بولۇپ بارغاندا...» دېيىلىدۇ.\f*
\v 8 ئاخىرى ئۇنىڭ ئېرى ئەلكاناھ ئۇنىڭغا: ــ ئى ھانناھ، نېمىشقا يىغلايسەن؟ نېمىشقا بىرنەرسە يېمەيسەن؟ نېمىشقا كۆڭلۈڭ ئازار يەيدۇ؟ مەن ئۆزۈم ساڭا ئون ئوغۇلدىن ئەۋزەل ئەمەسمۇ؟! ــ دېدى. \x ◘ \xo 1:8 \xt رۇت 4‏:15. \x*
\m 
\v 9 ئۇلار شىلوھدا يەپ-ئىچكەندىن كېيىن (ئەلى دېگەن كاھىن شۇ چاغدا پەرۋەردىگارنىڭ ئىبادەتخانىسىنىڭ ئىشىكى يېنىدىكى ئورۇندۇقتا ئولتۇراتتى) ھانناھ داستىخاندىن تۇردى؛
\v 10 ئۇ قاتتىق ئازاب ئىچىدە پەرۋەردىگارغا دۇئا قىلىپ زار-زار يىغلايتتى.
\v 11 ئۇ قەسەم ئىچىپ: ــ ئى ساماۋى قوشۇنلارنىڭ سەردارى بولغان پەرۋەردىگار، ئەگەر دېدىكىڭنىڭ دەردىگە يېتىپ، مېنى ياد ئېتىپ دېدىكىڭنى ئۇنتۇماي، بەلكى دېدىكىڭگە بىر ئوغۇل بالا ئاتا قىلساڭ، ئۇنى پۈتۈن ئۆمرىنىڭ كۈنلىرىدە سەن پەرۋەردىگارغا بېغىشلايمەن؛ ئۇنىڭ بېشىغا ئۇستىرا ھېچقاچان سېلىنمايدۇ، دېدى. \f ◼ \fr 1:11 \ft \bd «ئۇنىڭ بېشىغا ئۇستىرا ھېچقاچان سېلىنمايدۇ»\bd* ــ تەۋرات دەۋرىدە بەزى كىشىلەر ئۆزلىرىنى خۇدانىڭ ئىبادىتىگە بېغىشلاش مەقسىتىدە ئۆزلىرىنى «نازارىي» دەپ ئاتايتتى؛ «نازارىي»لار (نازارىي بولۇشقا قەسەم ئىچىپ بېكىتىلگەن مۆھلەتتە) ھاراق ئىچمەيتتى، چاچلىرىنى ھېچ چۈشۈرمەيتتى. «چۆل.» 1:6-22نى كۆرۈڭ.\f*  \x ◘ \xo 1:11 \xt ھاك. 13‏:5. \x*
\m 
\v 12 ئۇ پەرۋەردىگارنىڭ ئالدىدا دۇئاسىنى داۋام قىلىۋاتقاندا، ئەلى ئۇنىڭ ئاغزىغا قاراپ تۇردى؛
\v 13 چۈنكى ھانناھ دۇئانى ئىچىدە قىلغاچقا لەۋلىرى مىدىرلاۋاتقىنى بىلەن ئاۋازى ئاڭلانمايتتى. شۇڭا ئەلى ئۇنى مەست بولۇپ قاپتۇ، دەپ ئويلىدى.
\v 14 ئەلى ئۇنىڭغا: ــ قاچانغىچە مەست يۈرىسەن؟ شارابىڭنى ئۆزۈڭدىن نېرى قىل، دېدى.
\m 
\v 15 لېكىن ھانناھ جاۋابەن: ــ ئۇنداق ئەمەس، ئى غوجام! كۆڭلى سۇنۇق بىر مەزلۇممەن. مەن شارابمۇ، ھاراقمۇ ئىچمىدىم، بەلكى جېنىم دەردىنى پەرۋەردىگارنىڭ ئالدىدا تۆكتۈم؛ \x ◘ \xo 1:15 \xt زەب. 62‏:8؛ 142‏:2\x*
\v 16 دېدەكلىرىنى يامان خوتۇن دەپ بىلمىگەيلا. چۈنكى مېنىڭ زور دەردىم ۋە ئازابلىرىمدىن بۇ كۈنگىچە شۇنداق نىدا قىلىۋاتىمەن، دېدى. \f ◼ \fr 1:16 \ft \bd «دېدەكلىرىنى يامان خوتۇن دەپ بىلمىگەيلا...»\bd* ــ ئىبرانىي تىلىدا «دېدەكلىرىنى «بېلىئالنىڭ قىزى» دەپ بىلمىگەيلا» دېيىلىدۇ. «بېلىئال»نىڭ مەنىسى «ئەرزىمەس» دېگەنلىك بولۇپ، بەلكىم ئىبلىسنى كۆرسىتىدۇ.\f*
\m 
\v 17 ئەلى ئۇنىڭغا جاۋاب بېرىپ: ــ تىنچ-ئامان قايتقىن؛ ئىسرائىلنىڭ خۇداسى ئۆزىدىن تىلىگەن ئىلتىجايىڭنى ئىجابەت قىلغاي، دېدى.
\m 
\v 18 ھانناھ: ــ دېدەكلىرى كۆز ئالدىلىرىدا ئىلتىپات تاپقاي، دېدى. ئۇ شۇلارنى دەپ چىقىپ، غىزا يېدى ۋە شۇنىڭدىن كېيىن چىرايىدا ئىلگىرىكىدەك غەمكىنلىك كۆرۈنمىدى.
\m 
\v 19 ئۇلار ئەتىسى تاڭ سەھەردە ئورنىدىن تۇرۇپ پەرۋەردىگارنىڭ ھۇزۇرىدا سەجدە قىلىپ بولۇپ، راماھدىكى ئۆيىگە يېنىپ كەلدى. ئەلكاناھ ئايالى ھانناھغا يېقىنچىلىق قىلدى؛ پەرۋەردىگار ئۇنى ئەسلىگەنىدى.
\v 20 ھانناھ ھامىلىدار بولۇپ، ۋاقتى-سائىتى توشۇپ، بىر ئوغۇل تۇغدى. ئۇ: «مەن ئۇنى پەرۋەردىگاردىن تىلەپ ئالدىم» دەپ، ئىسمىنى سامۇئىل قويدى. \f ◼ \fr 1:20 \ft \bd ««مەن ئۇنى پەرۋەردىگاردىن تىلەپ ئالدىم» دەپ، ئىسمىنى سامۇئىل قويدى»\bd* ــ ئىبرانىي تىلىدا «سامۇئىل» دېگەننىڭ مەنىسى «خۇدا ئاڭلىدى» ياكى «خۇدادىن تىلىگەن» دېگەنگە يېقىن كېلىدۇ.\f*
\b
\s1 ھانناھ سامۇئىلنى پەرۋەردىگارغا ئاتايدۇ
\m 
\v 21 ئۇنىڭ ئېرى ئەلكاناھ ئۆيىدىكى ھەممىسى بىلەن پەرۋەردىگارغا ئاتىدىغان ھەر يىللىق قۇربانلىقنى قىلغىلى ۋە قىلغان قەسىمىنى ئادا قىلىش ئۈچۈن شىلوھغا چىقتى.
\v 22 لېكىن ھانناھ بىللە بارماي ئېرىگە: ــ بالا ئەمچەكتىن ئايرىلغاندىلا ئاندىن مەن ئۇنىڭ پەرۋەردىگارنىڭ ئالدىدا ھازىر بولۇشى ئۈچۈن ئۇنى ئېلىپ بارىمەن؛ شۇنىڭ بىلەن ئۇ ئۇ يەردە مەڭگۈ تۇرىدۇ، دېدى.
\v 23 ئېرى ئەلكاناھ ئۇنىڭغا: ــ ئۆزۈڭگە نېمە ياخشى كۆرۈنسە، شۇنى قىلغىن. ئۇنى ئەمچەكتىن ئايرىغۇچە تۇرۇپ تۇرغىن. پەرۋەردىگار ئۆز سۆز-كالامىغا ئەمەل قىلغاي، دېدى. ئايالى ئۆيدە قېلىپ بالىسى ئەمچەكتىن ئايرىلغۇچە ئېمىتتى.
\v 24 بالىسى ئەمچەكتىن ئايرىلغاندىن كېيىن ئۇ ئۇنى ئېلىپ، شۇنداقلا ئۈچ بۇقا، بىر ئەفاھ ئۇن ۋە بىر تۇلۇم شارابنى ئېلىپ پەرۋەردىگارنىڭ شىلوھدىكى ئۆيىگە ئاپاردى. بالا بولسا تېخى كىچىك ئىدى. \f ◼ \fr 1:24 \ft \bd «بىر ئەفاھ ئۇن»\bd* ــ «ئەفاھ» ئاشلىق-دانلارنىڭ ئۆلچەم بىرلىكى ئىدى، تەخمىنەن 27 لىتر. بۇقا قۇربانلىق قىلىنغاندا، ئۇنىڭغا قوشۇپ ئۇندىن «قوشۇمچە ئاشلىق ھەدىيەسى» قىلىنىشىمۇ كېرەك ئىدى.\f*  \x ◘ \xo 1:24 \xt لۇقا 2‏:41. \x*
\v 25 ئۇلار بىر بۇقىنى سويۇپ بالىنى ئەلىنىڭ قېشىغا ئېلىپ كەلدى. \f ◼ \fr 1:25 \ft \bd «ئۇلار بىر بۇقىنى سويۇپ بالىنى ئەلىنىڭ قېشىغا ئېلىپ كەلدى»\bd* ــ قالغان ئىككى بۇقا بەلكىم ئېلىغا سامۇئىلنى بېقىش ئۈچۈن بەرگەن «بېقىش ھەققى» بولۇشى مۇمكىن. باشقا بىر ئېھتىماللىق باركى، 24-ئايەتنىڭ مەنىسى: «...ئۈچ بۇقا» ئەمەس، بەلكى «....ئۈچ ياشلىق بىر بۇقا» بولۇشى مۇمكىن. بىراق بۇ ئايەتنى شۇنداق چۈشەنگەن ئالىملار ئاز.\f*
\v 26 شۇنىڭ بىلەن ھانناھ \add ئۇنىڭغا\add*: ــ ئى غوجام، ئۆزلىرىدە ھايات راست بولغىنىدەك، بۇ يەردە سىلىنىڭ قاشلىرىدا تۇرۇپ پەرۋەردىگارغا نىدا قىلغان مەزلۇم مەن بولىمەن، دېدى.
\v 27 مەن مۇشۇ ئوغۇل بالا ئۈچۈن دۇئا قىلدىم ۋە مانا، پەرۋەردىگار مېنىڭ تىلىگەن ئىلتىجايىمنى ئىجابەت قىلدى.
\v 28 ئەمدى ھازىر مەن ئۇنى پەرۋەردىگارغا تاپشۇرۇپ بەردىم. ئۆمرىنىڭ ھەممە كۈنلىرىدە ئۇ پەرۋەردىگارغا بېغىشلانغان بولىدۇ، دېدى. شۇنىڭ بىلەن ئۇلار ئۇ يەردە پەرۋەردىگارغا سەجدە قىلدى. \f ◼ \fr 1:28 \ft \bd «...ئۇلار ئۇ يەردە پەرۋەردىگارغا سەجدە قىلدى»\bd* ــ \bd «ئۇلار»\bd* بەزى كونا كۆچۈرمىلەردە «ئۇ ئۇ يەردە پەرۋەردىگارغا سەجدە قىلدى» دېيىلىدۇ (دېمەك، سامۇئىلنى كۆرسىتىدۇ).\f*
\b
\b
\c 2
\s1 ھانناھ تەنتەنە بىلەن پەرۋەردىگارنى مەدھىيىلەيدۇ
\m 
\v 1 ھانناھ دۇئا قىلىپ مۇنداق دېدى: ــ
\m «مېنىڭ قەلبىم پەرۋەردىگار بىلەن يايرايدۇ،
\m مېنىڭ مۈڭگۈزۈم پەرۋەردىگار بىلەن ئېگىز كۆتۈرۈلدى؛
\m ئاغزىم دۈشمەنلىرىمنىڭ ئالدىدا تەنتەنىلىكتە ئېچىلدى؛
\m چۈنكى سېنىڭ نىجاتىڭدىن شادلىنىمەن. \f ◼ \fr 2:1 \ft \bd «مېنىڭ مۈڭگۈزۈم پەرۋەردىگار بىلەن ئېگىز كۆتۈرۈلدى»\bd* ــ تەۋراتتا، «مۈڭگۈز»لەر كۆپ ھاللاردا ئادەملەرنىڭ ئابرۇي-شۆھرىتىنى ياكى كۈچىنى بىلدۈرىدۇ. مۇشۇ يەردە قۇتقۇزغۇچى-مەسىھنى كۆرسىتىشى مۇمكىن. «زەب.»، 17:132نى كۆرۈڭ. بۇ مۈڭگۈزلەر ئادەمنىڭ بېشىدا ئۆسكەن ئەمەس، ئەلۋەتتە!\f*  \x ◘ \xo 2:1 \xt لۇقا 1‏:46. \x*
\m 
\v 2 پەرۋەردىگاردەك مۇقەددەس بولغۇچى يوقتۇر؛
\m چۈنكى سەندىن باشقا ھېچ كىم يوق،
\m خۇدايىمىزدەك ھېچ ئۇيۇلتاش يوقتۇر. \x ◘ \xo 2:2 \xt قان. 3‏:24؛ زەب. 86‏:8. \x*
\m 
\v 3 ئى ئىنسانلار، كىبىرلىك سۆزلىرىڭلارنى كۆپەيتىۋەرمەڭلار،
\m يوغان گەپلەرنى ئاغزىڭلاردىن چىقارماڭلار؛
\m چۈنكى پەرۋەردىگار بىلىم-ھىدايەتكە ئىگە خۇدادۇر.
\m ئىنسانلارنىڭ ئەمەللىرى ئۇنىڭ تەرىپىدىن تارازىدا تارتىلىدۇ.
\m 
\v 4 پالۋانلارنىڭ ئوق-يالىرى سۇندۇرىلدى؛
\m لېكىن پۇتلىشىپ يىقىلغانلارنىڭ بېلى بولسا قۇدرەت بىلەن باغلاندى.
\m 
\v 5 قورسىقى توق بولغانلار نان تېپىش ئۈچۈن ئۆزىنى ياللانمىلىققا بەردى؛
\m لېكىن ئاچ قالغانلار ھازىر ئاچ قالمىدى؛
\m ھەتتا تۇغماس ئايال يەتتىنى تۇغىدۇ؛
\m لېكىن كۆپ بالىلىق بولغان سولىشىپ كېتىدۇ. \x ◘ \xo 2:5 \xt زەب. 34‏:9-10؛ يىغ. 5‏:6؛ لۇقا 1‏:53. \x*
\m 
\v 6 پەرۋەردىگار ھەم ئۆلتۈرىدۇ، ھەم ھايات بېرىدۇ؛
\m ئۇ ئادەمنى تەھتىساراغا چۈشۈرىدۇ، ئۇ يەردىن يەنە تۇرغۇزىدۇ؛ \f ◼ \fr 2:6 \ft \bd «تەھتىسارا»\bd* ــ ئۆلگەنلەرنىڭ روھى بارىدىغان جاي.\f*  \x ◘ \xo 2:6 \xt قان. 32‏:39؛ ئ‍ەز. 37‏:11-14\x*
\m 
\v 7 پەرۋەردىگار ئادەمنى ھەم نامرات قىلىۋېتىدۇ، ھەم باي قىلىدۇ؛
\m ئۇ كىشىنى ھەم پەس قىلىدۇ، ھەم ئېگىز كۆتۈرىدۇ.
\m 
\v 8 ئۇ ئۆزى مىسكىننى توپىدىن قوپۇرىدۇ،
\m قىغلىقتىن يوقسۇلنى كۆتۈرىدۇ؛
\m ئۇلارنى ئېسىلزادىلەر ئارىسىدا تەڭ ئولتۇرغۇزىدۇ؛
\m ئۇلارنى شان-شەرەپلىك تەختىگە مىراس قىلدۇرىدۇ؛
\m چۈنكى يەرنىڭ تۈۋرۈكلىرى پەرۋەردىگارنىڭكىدۇر؛
\m ئۇ ئۆزى دۇنيانى ئۇلارنىڭ ئۈستىگە سالغانىدى. \x ◘ \xo 2:8 \xt ئايۇپ 36‏:15؛ زەب. 113‏:7، 8؛ لۇقا 1‏:52؛ زەب. 24‏:1-2؛ 102‏:25؛ 104‏:5 \x*
\m 
\v 9 ئۆز مۇقەددەس بەندىلىرىنىڭ پۇتلىرىنى ئۇ مەزمۇت قىلىدۇ؛
\m ئەمما رەزىللەر بولسا، قاراڭغۇدا شۈك قىلىنىدۇ؛
\m چۈنكى ھېچكىم ئۆز قۇدرىتى بىلەن نۇسرەت تاپمايدۇ.
\m 
\v 10 پەرۋەردىگار بىلەن قارشىلاشقانلار پارە-پارە قىلىۋېتىلىدۇ؛
\m ئۇ ئۆزى ئاسمانلاردىن ئۇلارغا قارشى گۈلدۈرلەيدۇ.
\m پەرۋەردىگار يەر يۈزىنىڭ چەتلىرىگىچە ھۆكۈم چىقىرىدۇ؛
\m ئۇ ئۆزى تىكلىگەن پادىشاھقا قۇدرەت بېرىدۇ،
\m ئۇ ئۆزى مەسىھلىگىنىنىڭ مۈڭگۈزىنى ئېگىز كۆتۈرىدۇ!». \f ◼ \fr 2:10 \ft \bd «ئۇ ئۆزى مەسىھلىگىنىنىڭ مۈڭگۈزىنى ئېگىز كۆتۈرىدۇ!»\bd* ــ «مەسىھلىمەك» ياكى «مەسىھ قىلىش»: خۇدانىڭ يوليورۇقى بىلەن ئىسرائىلغا يېڭى بىر پادىشاھ بېكىتىش ئۈچۈن ئۇنىڭ بېشىغا زەيتۇن مېيى سۈرۈلۈشى كېرەك ئىدى. مۇشۇ مۇراسىم «مەسىھ قىلىنىش» ياكى «مەسىھلىنىش» دەپ ئاتىلاتتى ۋە شۇنداقلا شۇ چاغدىن باشلاپ شۇ پادىشاھ «خۇدانىڭ مەسىھلىگىنى» دەپ ئاتىلاتتى. كاھىنلار ۋە بەزى ۋاقتىدا پەيغەمبەرلەرمۇ «مەسىھ قىلىناتتى». ئىسرائىلدا شۇ چاغدا پادىشاھ بولمىغاچقا، ھانناھنىڭ بۇ سۆزى دەرۋەقە كەلگۈسى ئىشلارنى ئالدىنئالا كۆرسەتكەن بېشارەت ئىدى.\f*  \x ◘ \xo 2:10 \xt 1سام. 7‏:10؛ زەب. 2‏:6؛ 21‏:8؛ 89‏:24\x*
\b
\m 
\v 11 ئەلكاناھ بولسا راماھدىكى ئۆز ئۆيىگە يېنىپ باردى. بالا بولسا ئەلىنىڭ قېشىدا پەرۋەردىگارغا خىزمەت قىلىپ قالدى.
\b
\s1 ئەلىنىڭ ئوغۇللىرىنىڭ كاھىنلىق مەنسىپىدىن رەزىللىك بىلەن پايدىلىنىشلىرى
\m 
\v 12 ئەمما ئەلىنىڭ ئوغۇللىرى ئىنتايىن يامان كىشىلەردىن بولۇپ، پەرۋەردىگارنى تونۇمايتتى. \f ◼ \fr 2:12 \ft \bd «...ئىنتايىن يامان كىشىلەردىن بولۇپ»\bd* ــ ئىبرانىي تىلىدا: «بېلىئالنىڭ (ئىبلىسنىڭ) ئوغۇللىرىدىن بولۇپ» دېيىلىدۇ. «بېلىئال»نىڭ مەنىسى «ئەرزىمەس»، بەلكىم شەيتاننى كۆرسىتىدۇ.\f*
\v 13 كاھىنلارنىڭ خەلقلەرگە مۇنداق ئادىتى بولغان: ــ بىرسى قۇربانلىق قىلىپ، گۆش قايناپ پىشىۋاتقاندا كاھىننىڭ خىزمەتكارى كېلىپ ئۈچ تىللىق چاڭگاكنى قولىدا تۇتۇپ
\v 14 داش، قازان، داڭقان ياكى كورىنىڭ ئىچىگە سانجىپ، چاڭگاكقا نېمە ئېلىنغان بولسا كاھىن شۇنى ئۆزىگە ئالاتتى. ئۇلارنىڭ شىلوھغا \add قۇربانلىق قىلغىلى\add* كەلگەن ھەممە ئىسرائىللارغا شۇنداق ئادىتى بولغان. \f ◼ \fr 2:14 \ft \bd «ئۇلارنىڭ شىلوھغا قۇربانلىق قىلغىلى كەلگەن ھەممە ئىسرائىللارغا شۇنداق ئادىتى بولغان»\bd* ــ مۇشۇ خىل قۇربانلىقلار، شۈبھىسىزكى، «تەشەككۈر قۇربانلىقلىرى» ياكى «ئىناقلىق قۇربانلىقلىرى» ئىدى. كاھىنلارنىڭ مۇشۇ ئادىتى مۇسا پەيغەمبەرگە چۈشۈرۈلگەن قانۇننىڭ بەلگىلىمىلىرىگە ئاساسلانغان ئەمەس. كاھىنلارنىڭ «ھوقۇق ئۈلۈشى» بولسا «لاۋ.» 11:7-18، 28-34-ئايەتلەردە كۆرسىتىلىدۇ. ئەمما ئەلىنىڭ ئوغۇللىرى ئاچكۆزلۈكىدىن بۇ ئادەتنى تولىمۇ ھەددىدىن ئاشۇرۇۋەتكەنىدى. كېيىنكى ئايەتلەرنى كۆرۈڭ.\f*
\v 15 شۇنداقلا ھەتتا ياغنى كۆيدۈرمەستە كاھىننىڭ خىزمەتكارى كېلىپ قۇربانلىق قىلىۋاتقان ئادەمگە: ــ كاھىنغا كاۋاپ ئۈچۈن گۆش بەرگىن، چۈنكى ئۇ سەندىن قايناپ پىشقان گۆش قوبۇل قىلمايدۇ، بەلكى خام گۆش لازىم، دەيتتى.
\v 16 ئەگەر قۇربانلىق قىلغۇچى ئۇنىڭغا: ــ ئاۋۋال يېغى كۆيدۈرۈلۈپ بولسۇن، ئاندىن نېمىنى خالىساڭ شۇنى ئالغىن، دېسە، ئۇ: ــ بولمايدۇ، ماڭا دەرھال بەر! بولمىسا مەجبۇرىي ئالىمەن، دەيتتى؛ \f ◼ \fr 2:16 \ft \bd «ئاۋۋال يېغى كۆيدۈرۈلۈپ بولسۇن، ئاندىن نېمىنى خالىساڭ شۇنى ئالغىن»\bd* ــ مۇسا پەيغەمبەرگە چۈشۈرۈلگەن قانۇن بويىچە قۇربانلىقلاردىكى بارلىق ياغلار پەرۋەردىگارغا ئاتاپ كۆيدۈرۈلەتتى. ئادەمنىڭ ئۇنى يېيىشى مەنئى قىلىناتتى.\f*
\v 17 شۇنداق قىلىپ بۇ ئىككى ياشنىڭ گۇناھى پەرۋەردىگارنىڭ ئالدىدا تولىمۇ ئېغىر بولغانىدى؛ چۈنكى ئۇنىڭ سەۋەبىدىن خەق پەرۋەردىگارغا ئاتىغان قۇربانلىقلار كۆزگە ئىلىنمايۋاتاتتى.
\m 
\v 18 ئەمما سامۇئىل نارەسىدە بالا بولۇپ كاناپتىن توقۇلغان بىر ئەفودنى كىيىپ پەرۋەردىگارنىڭ ئالدىدا خىزمەت قىلاتتى. \f ◼ \fr 2:18 \ft \bd «سامۇئىل نارەسىدە بالا بولۇپ كاناپتىن توقۇلغان بىر ئەفودنى كىيىپ پەرۋەردىگارنىڭ ئالدىدا خىزمەت قىلاتتى»\bd* ــ «ئەفود» دېگەن نېمە؟ خۇدا مۇسا پەيغەمبەرگە چۈشۈرگەن قانۇن بويىچە، باش كاھىن كىيدىغان بىر ئالاھىدە كالتە چاپان بولۇپ، ئۇنىڭ ئىچىدىكى ئىككى خىل تاش ئارقىلىق خۇدادىن يول سورىغىلى بولاتتى. سامۇئىل لاۋىي قەبىلىسىدىن بولمىسىمۇ، بۇ ئايەتكە قارىغاندا «كاھىنلىق كىيىم» كىيىپ، كاھىنلىق خىزمىتىنى قىلىۋاتاتتى.\f*
\v 19 بۇنىڭدىن باشقا ئۇنىڭ ئانىسى ھەر يىلدا ئۇنىڭغا بىر كىچىك تون تىكىپ، ھەر يىللىق قۇربانلىقنى قىلغىلى ئېرى بىلەن بارغاندا ئالغاچ كېلەتتى.
\v 20 ئەلى ئەلكاناھ ۋە ئايالىغا بەخت تىلەپ دۇئا قىلىپ: ــ «ئايالىڭنىڭ پەرۋەردىگارغا بېغىشلىغىنىنىڭ ئورنىغا ساڭا ئۇنىڭدىن باشقا نەسىل بەرگەي، دېدى. ئاندىن بۇ ئىككىسى ئۆز ئۆيىگە ياندى.
\v 21 شۇنىڭ بىلەن پەرۋەردىگار ھانناھنى يوقلاپ بەرىكەتلەپ، ئۇ ھامىلىدار بولۇپ جەمئىي ئۈچ ئوغۇل ۋە ئىككى قىز تۇغدى. كىچىك سامۇئىل بولسا پەرۋەردىگارنىڭ ئالدىدا تۇرۇپ ئۆسۈۋاتاتتى. \f ◼ \fr 2:21 \ft \bd «...يوقلاپ بەرىكەتلەپ»\bd* ــ ئىبرانىي تىلىدا پەقەت «يوقلاپ» دېيىلىدۇ. خۇدانىڭ «يوقلىشى» توغرۇلۇق «تەبىرلەر»نىمۇ كۆرۈڭ.\f*
\m 
\v 22 ئەلى بەك قېرىپ كەتكەنىدى. ئۇ ئوغۇللىرىنىڭ پۈتكۈل ئىسرائىلغا ھەممە قىلغانلىرىنى ئاڭلىدى ھەم جامائەت چېدىرىنىڭ ئىشىكىدە خىزمەت قىلىدىغان ئاياللار بىلەن ياتقىنىنىمۇ ئاڭلىدى. \f ◼ \fr 2:22 \ft \bd «جامائەت چېدىرى»\bd* ــ يەنى «ئىبادەت چېدىرى» ياكى «مۇقەددەس چېدىر».\f*
\v 23 ئۇ ئۇلارغا: ــ سىلەر نېمە ئۈچۈن شۇنداق ئىشلارنى قىلىسىلەر؟ چۈنكى بۇ خەلقنىڭ ھەممىسىدىن سىلەرنىڭ يامانلىقىڭلارنى ئاڭلاۋاتىمەن، دېدى.
\v 24 بولمايدۇ، ئى ئوغۇللىرىم! مەن ئاڭلىغان بۇ خەۋەر ياخشى ئەمەس، پەرۋەردىگارنىڭ خەلقىنى ئازدۇرۇپسىلەر. \f ◼ \fr 2:24 \ft \bd «پەرۋەردىگارنىڭ خەلقىنى ئازدۇرۇپسىلەر»\bd* ــ باشقا بىرخىل تەرجىمىسى: «پەرۋەردىگارنىڭ خەلقى ئارىسىدا تارقالغان خەۋەر ياخشى ئەمەس».\f*
\v 25 ئەگەر بىر ئادەم يەنە بىر ئادەمگە گۇناھ قىلسا، باشقا بىرسى ئۇنىڭ ئۈچۈن خۇدادىن رەھىم سورىسا بولىدۇ؛ لېكىن ئەگەر بىرسى پەرۋەردىگارغا گۇناھ قىلسا، كىم ئۇنىڭ گۇناھىنى تىلىيەلەيدۇ؟ ــ دېدى. لېكىن ئۇلار ئاتىسىنىڭ سۆزىگە قۇلاق سالمىدى؛ چۈنكى پەرۋەردىگار ئۇلارنى ئۆلتۈرۈشنى نىيەت قىلغانىدى.
\v 26 ئەمما سامۇئىل دېگەن بالا ئۆسۈۋاتاتتى، پەرۋەردىگار ھەم ئادەملەرنىڭ ئالدىدا ئىلتىپات تاپقانىدى. \x ◘ \xo 2:26 \xt لۇقا 2‏:52. \x*
\m 
\v 27 خۇدانىڭ بىر ئادىمى ئەلىنىڭ يېنىغا كېلىپ مۇنداق دېدى: ــ پەرۋەردىگار شۇنداق دەيدۇ: «مىسىردا، پىرەۋننىڭكىدە تۇرغاندا ئۆزۈمنى ئاتاڭنىڭ جەمەتىگە ئوچۇق ئايان قىلمىدىممۇ؟ \x ◘ \xo 2:27 \xt روس. 7‏:25. \x*
\v 28 مەن ئۇنى كاھىنىم بولۇش، ئۆز قۇربانگاھىمدا قۇربانلىق قىلىش، خۇشبۇي يېقىش ۋە مېنىڭ ئالدىمدا ئەفود تونىنى كېيىپ خىزمەت قىلىشقا ئىسرائىلنىڭ ھەممە قەبىلىلىرىدىن تاللىمىغانىدىممۇ؟ شۇنىڭدەك مەن ئىسرائىلنىڭ ئوتتا كۆيدۈرىدىغان ھەممە قۇربانلىقلىرىنى ئاتاڭغا تاپشۇرۇپ تەقدىم قىلغان ئەمەسمۇ؟ \f ◼ \fr 2:28 \ft \bd «... مەن ئىسرائىلنىڭ ئوتتا كۆيدۈرىدىغان ھەممە قۇربانلىقلىرىنى ئاتاڭغا تاپشۇرۇپ تەقدىم قىلغان ئەمەسمۇ؟»\bd* ــ تەۋراتقا ئاساسەن، كاھىنلارنىڭ ھەرقانداق قۇربانلىقلاردىن ئۆزىگە خاس بىر ئۈلۈشنى ئېلىش ھوقۇقى بار ئىدى.\f*  \x ◘ \xo 2:28 \xt لاۋ. 10‏:14. \x*
\v 29 نېمىشقا مەن بۇيرۇغان، تۇرالغۇ جايىمدىكى قۇربانلىقىم بىلەن ئاشلىق ھەدىيەلىرىنى دەپسەندە قىلىسىلەر؟ نېمىشقا خەلقىم ئىسرائىللار كەلتۈرگەن ھەممە ھەدىيەلەرنىڭ ئېسىلىدىن ئۆزلىرىڭلارنى سەمرىتىپ، ئۆز ئوغۇللىرىڭلارنىڭ ھۆرمىتىنى مېنىڭكىدىن ئۈستۈن قىلىسەن؟» \x ◘ \xo 2:29 \xt قان. 32‏:15. \x*
\v 30 ئۇنىڭ ئۈچۈن ئىسرائىلنىڭ خۇداسى پەرۋەردىگار مۇنداق دەيدۇ: «مەن دەرھەقىقەت سېنىڭ ۋە ئاتاڭنىڭ جەمەتىدىكىلەر مېنىڭ ئالدىمدا خىزمىتىمدە مەڭگۈ ماڭىدۇ، دەپ ئېيتقانىدىم؛ لېكىن ئەمدى مەن پەرۋەردىگار شۇنى دەيمەنكى، بۇ ئىش ھازىر مەندىن نېرى بولسۇن! مېنى ھۆرمەت قىلغانلارنى مەن ھۆرمەت قىلىمەن، لېكىن مېنى كەمسىتكەنلەر پەس قارىلىدۇ. \x ◘ \xo 2:30 \xt مىس. 28‏:43؛ 29‏:9. \x*
\v 31 مانا شۇنداق كۈنلەر كېلىدۇكى، سېنىڭ بىلىكىڭنى ۋە ئاتاڭنىڭ جەمەتىنىڭ بىلىكىنى تەڭ كېسىۋېتىمەن؛ شۇنىڭ بىلەن جەمەتىڭدە بىرمۇ قېرىغان ئادەم تېپىلمايدۇ! \f ◼ \fr 2:31 \ft \bd «... سېنىڭ بىلىكىڭنى ۋە ئاتاڭنىڭ جەمەتىنىڭ بىلىكىنى تەڭ كېسىۋېتىمەن»\bd* ــ «ئادەمنىڭ بىلىكى» ئۇنىڭ كۈچى، قابىلىيىتى ۋە ھوقۇقىنى بىلدۈرەتتى.\f*
\v 32 سەن تۇرالغۇ جايىمدا دەرد-قايغۇ كۆرىسەن؛ ئىسرائىللار ھەرقانداق ھۇزۇر-بەختنى كۆرگىنى بىلەن، سېنىڭ جەمەتىڭدە ئەبەدگىچە بىرمۇ قېرىغان ئادەم تېپىلمايدۇ. \f ◼ \fr 2:32 \ft \bd «سەن تۇرالغۇ جايىمدا دەرد-قايغۇ كۆرىسەن»\bd* ــ ياكى «سەن تۇرالغۇ جايىمدا دۈشمەن كۆرىسەن». \bd «سېنىڭ جەمەتىڭدە ئەبەدگىچە بىرمۇ قېرىغان ئادەم تېپىلمايدۇ»\bd* ــ بۇ بېشارەت تۆۋەندىكى بابلاردا ئېچىلىدۇ. ئەلى ئۆزى پەرۋەردىگارنىڭ ئەھدە ساندۇقىنىڭ بۇلاپ كېتىلگەنلىكىنى كۆرىدۇ؛ بىراق كېيىنكى كۈنلەردە، يەنى داۋۇت پادىشاھنىڭ كۈنلىرىدىكى بەخت-بەرىكەتنى ئۇ كۆرمەيدۇ (ئەلىنىڭ جەمەتىنىڭ كېيىنكى تارىخى 22-باب، 1-22، «1پاد.» 26:2-27دە كۆرۈلىدۇ).\f*
\v 33 ۋە مەن قۇربانگاھىمنىڭ خىزمىتىدىن ئۈزۈپ تاشلىمىغان ئادىمىڭ بار بولسا، ئۇ كۆزلىرىڭنىڭ خىرەلىشىشى بىلەن جېنىڭنىڭ ئازابلىنىشىغا سەۋەب بولىدۇ. جەمەتىڭدە تۇغۇلغانلارنىڭ ھەممىسى بالاغەتتىن ئۆتمەي ئۆلىدۇ. \f ◼ \fr 2:33 \ft \bd «كۆزلىرىڭنىڭ خىرەلىشىشى»\bd* ــ بۇ ئىبارە ئادەتتە كۆز ياشلىرىنىڭ كۆپ تۆكۈلگەنلىكىدىن ياكى زور غەمكىنلىكتىن بولغان ھالەتنى كۆرسىتىدۇ.\f*
\v 34 ساڭا بۇ ئىشلارنى ئىسپاتلاشقا، ئىككى ئوغلۇڭ خوفنىي بىلەن فىنىھاسنىڭ بېشىغا چۈشىدىغان مۇنداق بىر ئالامەت بېشارەت بولىدۇ: ــ ئۇلارنىڭ ئىككىلىسى بىر كۈندە ئۆلىدۇ.
\v 35 ئەمما ئۆزۈمگە روھىم ۋە دىلىمدىكى نىيىتىم بويىچە ئىش كۆرىدىغان سادىق بىر كاھىننى تىكلەيمەن؛ مەن ئۇنىڭغا مەزمۇت بىر جەمەت قۇرىمەن؛ ئۇ مېنىڭ مەسىھ قىلغىنىمنىڭ ئالدىدا مەڭگۈ مېڭىپ خىزمەت قىلىدۇ. \f ◼ \fr 2:35 \ft \bd «...مېنىڭ مەسىھ قىلغىنىمنىڭ ئالدىدا»\bd* ــ مېنىڭ پادىشاھىمنىڭ ئالدىدا، دېمەكچى. بىزنىڭچە بۇ بېشارەت ئاۋۋال سامۇئىلنىڭ ئۆزىدە ئاندىن كاھىن زادوكنىڭ جەمەتىدە ئەمەلگە ئاشۇرۇلدى. \bd «مەڭگۈ مېڭىپ خىزمەت قىلىدۇ»\bd* ــ ئىبرانىي تىلىدا «بارلىق كۈنلەردە مېڭىپ خىزمەت قىلىدۇ».\f*
\v 36 شۇنداق بولىدۇكى، سېنىڭ جەمەتىڭدىكىلەردىن ھەربىر تىرىك قالغانلار بىر سەر كۈمۈش ۋە بىر چىشلەم نان تىلەشكە ئۇنىڭ ئالدىغا كېلىپ ئۇنىڭغا تەزىم قىلىپ: «كاھىنلىق خىزمەتلىرىدىن ماڭا بىر ئورۇن بەرسىلە، يېگىلى بىر چىشلەم نان تاپاي دەپ ئېيتىدىغان بولىدۇ» دەيدۇ.
\b
\b
\c 3
\s1 پەرۋەردىگار سامۇئىلنى چاقىرىدۇ
\m 
\v 1 سامۇئىل دېگەن بالا بولسا ئەلىنىڭ ئالدىدا پەرۋەردىگارنىڭ خىزمىتىدە بولاتتى. ئەمدى پەرۋەردىگارنىڭ سۆزى ئۇ كۈنلەردە كەم ئىدى؛ ۋەھىيلىك كۆرۈنۈشلەرمۇ كۆپ ئەمەس ئىدى.
\v 2 ۋە شۇنداق بولدىكى، بىر كۈنى ئەلى ئورنىدا ياتقانىدى (ئۇنىڭ كۆزلىرى تورلىشىپ كۆرمەس بولۇپ قالاي دېگەنىدى) \x ◘ \xo 3:2 \xt 1سام. 4‏:15. \x*
\v 3 خۇدانىڭ چىرىغى تېخى ئۆچمىگەن بولۇپ، سامۇئىل پەرۋەردىگارنىڭ ئىبادەتخانىسىدا، خۇدانىڭ ئەھدە ساندۇقىغا يېقىنلا يەردە ياتاتتى.
\v 4 پەرۋەردىگار سامۇئىلنى چاقىردى. ئۇ: ــ مانا مەن بۇ يەردە، دېدى.
\v 5 ئۇ ئەلىنىڭ قېشىغا يۈگۈرۈپ بېرىپ: ــ مانا مەن، مېنى چاقىردىڭغۇ، دېدى. لېكىن ئۇ جاۋاب بېرىپ: ــ مەن چاقىرمىدىم؛ قايتىپ بېرىپ ياتقىن، دېدى. شۇنىڭ بىلەن ئۇ بېرىپ ياتتى.
\v 6 پەرۋەردىگار يەنە: «سامۇئىل!» دەپ چاقىردى. سامۇئىل قوپۇپ ئەلىنىڭ قېشىغا بېرىپ: مانا مەن، مېنى چاقىردىڭغۇ، دېدى. لېكىن ئۇ جاۋاب بېرىپ: ــ مەن چاقىرمىدىم ئى ئوغلۇم، يەنە بېرىپ ياتقىن، دېدى.
\m 
\v 7 سامۇئىل پەرۋەردىگارنى تېخى تونۇمىغانىدى؛ پەرۋەردىگارنىڭ سۆزى ئۇنىڭغا تېخى ئايان قىلىنمىغانىدى.
\v 8 لېكىن پەرۋەردىگار يەنە ئۈچىنچى قېتىم: «سامۇئىل!» دەپ چاقىردى؛ ئۇ قوپۇپ ئەلىنىڭ قېشىغا بېرىپ: ــ مانا مەن؛ سەن مېنى چاقىردىڭ، دېدى. ئۇ ۋاقىتتا ئەلى پەرۋەردىگار بالىنى چاقىرىپتۇ، دەپ بىلىپ يەتتى.
\v 9 شۇنىڭ بىلەن ئەلى سامۇئىلغا: ــ بېرىپ ياتقىن. ئۇ ئەگەر سېنى چاقىرسا، سەن: ــ ئى پەرۋەردىگار، سۆز قىلغىن، چۈنكى قۇلۇڭ ئاڭلايدۇ، دەپ ئېيتقىن، دېۋىدى، سامۇئىل بېرىپ ئورنىدا ياتتى.
\v 10 ۋە پەرۋەردىگار كېلىپ يېقىن تۇرۇپ ئىلگىرىكىدەك: ــ «سامۇئىل، سامۇئىل!» دەپ چاقىردى. سامۇئىل: ــ سۆز قىلغىن، چۈنكى قۇلۇڭ ئاڭلايدۇ، دەپ جاۋاب بەردى. \f ◼ \fr 3:10 \ft \bd «سامۇئىل، سامۇئىل!»\bd* ــ تەۋرات-ئىنجىلدا خۇدا بىر كىشىنىڭ ئىسمىنى قايتىلاپ چاقىرغان بولسا، ئۇ ئادەمنىڭ ئۆزىگە ئىنتايىن سۆيۈملۈك ئىكەنلىكىنى كۆرسىتىدۇ.\f*
\m 
\v 11 پەرۋەردىگار سامۇئىلغا: ــ مانا مەن ئاڭلىغانلارنىڭ ئىككى قۇلىقىنى زىڭىلداتقۇدەك بىر ئىشنى ئىسرائىلنىڭ ئارىسىدا قىلماقچىمەن. \x ◘ \xo 3:11 \xt 2پاد. 21‏:12؛ يەر. 19‏:3. \x*
\v 12 شۇ كۈنىدە مەن بۇرۇن ئەلىنىڭ جەمەتىدىكىلەر توغرىسىدا ئېيتقىنىمنىڭ ھەممىسىنى ئۇنىڭ ئۈستىگە چۈشۈرىمەن؛ باشتىن ئاخىرغىچە ئادا قىلىمەن! \x ◘ \xo 3:12 \xt 1سام. 2‏:31. \x*
\v 13 چۈنكى ئۆزىگە ئايان بولغان قەبىھلىك تۈپەيلىدىن مەن ئۇنىڭغا، سېنىڭ جەمەتىڭدىن مەڭگۈلۈك ھۆكۈم چىقارماقچىمەن، دەپ ئېيتقانمەن؛ چۈنكى ئۇ ئوغۇللىرىنىڭ ئىپلاسلىقىنى بىلىپ تۇرۇپ ئۇلارنى توسمىدى. \f ◼ \fr 3:13 \ft \bd «مەن ئۇنىڭغا، سېنىڭ جەمەتىڭدىن مەڭگۈلۈك ھۆكۈم چىقارماقچىمەن، دەپ ئېيتقانمەن»\bd* ــ ياكى «مەن ئۇنىڭغا، سېنىڭ جەمەتىڭدىن مەڭگۈلۈك ھۆكۈم چىقارماقچىمەن، دەپ ئېيتقىن». \bd «چۈنكى ئۇ ئوغۇللىرىنىڭ ئىپلاسلىقىنى بىلىپ تۇرۇپ ئۇلارنى توسمىدى»\bd* ــ ياكى «چۈنكى ئۇ ئوغۇللىرىنىڭ خۇدانى قارغىغانلىقىنى بىلىپ تۇرۇپ ئۇلارنى توسمىدى».\f*
\v 14 ئۇنىڭ ئۈچۈن ئەلىنىڭ جەمەتىدىكىلەرگە قەسەم قىلغانمەنكى، ئەلىنىڭ جەمەتىدىكىلەرنىڭ قەبىھلىكى مەيلى قۇربانلىق بىلەن بولسۇن، مەيلى ھەدىيە بىلەن بولسۇن كەفارەت قىلىنماي، ئەبەدگىچە كەچۈرۈم قىلىنمايدۇ، دېدى.
\m 
\v 15 سامۇئىل ئەتىسى تاڭ ئاتقۇچە يېتىپ، ئاندىن پەرۋەردىگارنىڭ ئۆيىنىڭ ئىشىكلىرىنى ئاچتى. ئەمما سامۇئىل ۋەھىيلىك كۆرۈنۈشنى ئەلىگە ئېيتىشتىن قورقتى.
\v 16 لېكىن ئەلى سامۇئىلنى چاقىرىپ: ــ ئى سامۇئىل ئوغلۇم، دېدى. ئۇ: ــ مانا مەن، دەپ جاۋاب بەردى.
\v 17 ئۇ: ــ ئۇ ساڭا نېمە سۆز قىلدى؟ سەندىن ئۆتۈنەي، ئۇنى مەندىن يوشۇرمىغىن. ئەگەر ئۇنىڭ ساڭا ئېيتقانلىرىنىڭ بىرىنى ماڭا ئېيتماي قويساڭ، خۇدا دېگىنىنى سېنىڭ بېشىڭغا چۈشۈرسۇن ۋە ئۇنىڭدىن ئارتۇق چۈشۈرسۇن! ــ دېدى.
\v 18 شۇنىڭ بىلەن سامۇئىل ئۇنىڭغا ھېچنېمىنى قالدۇرماي ھەممىنى دەپ بەردى. ئەلى: ــ مانا، ئۇ پەرۋەردىگاردۇر؛ ئۇ نېمىنى لايىق تاپسا، شۇنى قىلسۇن، دېدى.
\m 
\v 19 سامۇئىل ئۆسۈپ چوڭ بولۇۋاتاتتى ۋە پەرۋەردىگار ئۇنىڭ بىلەن بىللە بولۇپ، ئۇنىڭ ئېيتقان بېشارەتلىك سۆزلىرىدىن ھېچقايسىسىنى يەردە قالدۇرمايتتى.
\v 20 شۇنىڭ بىلەن پۈتكۈل ئىسرائىل داندىن تارتىپ بەئەر-شېباغىچە سامۇئىلنىڭ پەرۋەردىگارنىڭ پەيغەمبىرى قىلىپ تىكلەنگەنلىكىنى بىلىپ يەتتى. \f ◼ \fr 3:20 \ft \bd «داندىن تارتىپ بەئەر-شېباغىچە»\bd* ــ «دان» ئىسرائىلنىڭ شىمالىي چېتىدە، «بەئەر-شېبا» ئۇنىڭ جەنۇبىي چېتىدە ئىدى.\f*
\v 21 شۇ ۋاقىتتا پەرۋەردىگار شىلوھدا ئۆزىنى يەنە ئايان قىلدى. چۈنكى پەرۋەردىگار شىلوھدا ئۆز سۆز-كالامى ئارقىلىق سامۇئىلغا ئۆزىنى ئايان قىلدى؛ ۋە سامۇئىل ئۇنىڭ سۆزىنى پۈتكۈل ئىسرائىلغا يەتكۈزدى. \f ◼ \fr 3:21 \ft \bd «سامۇئىل ئۇنىڭ سۆزىنى پۈتكۈل ئىسرائىلغا يەتكۈزدى»\bd* ــ ياكى «سامۇئىل ئېيتقان بۇ سۆز پۈتكۈل ئىسرائىلدا يۈز بەردى». \bd «پەرۋەردىگار شىلوھدا ئۆز سۆز-كالامى ئارقىلىق سامۇئىلغا ئۆزىنى ئايان قىلدى»\bd* ــ ئىبرانىي تىلىدا: «پەرۋەردىگار شىلوھدا پەرۋەردىگارنىڭ سۆز-كالامى ئارقىلىق سامۇئىلغا ئۆزىنى ئايان قىلدى»\f*
\b
\b
\c 4
\s1 پەرۋەردىگارنىڭ ئەھدە ساندۇقى فىلىستىيلەرنىڭ قولىغا چۈشىدۇ
\m 
\v 1 ئۇ ۋاقىتتا ئىسرائىل فىلىستىيلەر بىلەن جەڭ قىلغىلى چىقىپ ئەبەن-ئېزەرگە يېقىن جايدا بارگاھ-چېدىرلارنى تىكتى. فىلىستىيلەر بولسا ئافەك دېگەن جايدا بارگاھ-چېدىرلارنى تىكتى.
\v 2 فىلىستىيلەر ئىسرائىللار بىلەن سوقۇشقىلى سەپ تىزىپ تۇردى. جەڭ كېڭەيگەندە ئىسرائىل فىلىستىيلەر ئالدىدا تارمار بولدى؛ فىلىستىيلەر ئۇلارنىڭ جەڭ سەپلىرىدىن تۆت مىڭچە ئادەمنى ئۆلتۈردى.
\v 3 خالايىق بارگاھقا يېنىپ كەلگەندە، ئىسرائىلنىڭ ئاقساقاللىرى: ــ نېمىشقا پەرۋەردىگار بۈگۈن بىزنى فىلىستىيلەر تەرىپىدىن تارمار قىلدۇردى؟ بىز شىلوھدىن پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى قېشىمىزغا ئېلىپ كېلەيلى؛ ئۇ ئارىمىزدا بولسا، بىزنى دۈشمىنىمىزنىڭ قولىدىن قۇتقۇزىدۇ، دېدى.
\m 
\v 4 شۇ گەپتىن كېيىن خالايىق شىلوھغا ئادەم ماڭدۇرۇپ، شۇ يەردىن كېرۇبلارنىڭ ئوتتۇرىسىدا ئولتۇرغان ساماۋى قوشۇنلارنىڭ سەردارى پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى ئېلىپ كۆتۈرۈپ كەلدى. شۇنىڭدەك ئەلىنىڭ ئىككى ئوغلى خوفنىي بىلەن فىنىھاسمۇ خۇدانىڭ ئەھدە ساندۇقى بىلەن بىللە كەلدى. \f ◼ \fr 4:4 \ft \bd «...كېرۇبلارنىڭ ئوتتۇرىسىدا ئولتۇرغان ساماۋى قوشۇنلارنىڭ سەردارى پەرۋەردىگار»\bd* ــ «كېرۇبلار» پەرىشتىلەرنىڭ شەكلىدە بولۇپ، ئەھدە ساندۇقىنىڭ ئىككى تەرىپىدە تۇراتتى. «مىس.» 17:25-22نى كۆرۈڭ. خۇدا «كېرۇبلارنىڭ ئوتتۇرىسىدا، ئەھدە ساندۇقىنىڭ ئۈستىدە ھۇزۇرۇمنى ئولتۇرغۇزىمەن، دەپ ۋەدە قىلغانىدى.\f*  \x ◘ \xo 4:4 \xt 2سام. 6‏:2؛ زەب. 80‏:1؛ 99‏:1\x*
\v 5 ۋە شۇنداق بولدىكى، پەرۋەردىگارنىڭ ئەھدە ساندۇقى لەشكەرگاھقا ئېلىپ كېلىنگەندە پۈتكۈل ئىسرائىل يەرنى تەۋرەتكۈدەك كۈچلۈك بىر چۇقان كۆتۈرۈشتى.
\m 
\v 6 فىلىستىيلەر كۈچلۈك تەنتەنە ئاۋازىنى ئاڭلاپ: ــ ئىبرانىيلارنىڭ لەشكەرگاھىدىن ئاڭلانغان بۇ كۈچلۈك چۇقان نېمە ۋەجىدىن چىققاندۇ، دەپ ئېيتىشتى. ئارقىدىنلا ئۇلار پەرۋەردىگارنىڭ ئەھدە ساندۇقىنىڭ ئۇلارنىڭ لەشكەرگاھىغا كەلتۈرۈلگىنىنى بىلىپ يەتتى.
\v 7 شۇنىڭ بىلەن فىلىستىيلەر قورقۇپ: ــ ئىلاھلار ئۇلارنىڭ لەشكەرگاھىغا كەپتۇ، ھالىمىزغا ۋاي! مۇنداق ئىش بۇ ۋاقىتقىچە ھېچ بولغان ئەمەس، دېيىشتى.
\v 8 ھالىمىزغا ۋاي! بىزنى بۇ قۇدرەتلىك ئىلاھلارنىڭ قولىدىن كىم قۇتقۇزىدۇ؟ مانا باياۋاندا مىسىرلىقلارنى تۈرلۈك بالا-ۋابالار بىلەن ئۇرغان ئىلاھلار دەل شۇلاردۇر!
\v 9 ئى فىلىستىيلەر، ئۆزلىرىڭلارنى جەسۇر كۆرسىتىپ ئەركەكتەك تۇرۇڭلار. بولمىسا، ئىبرانىيلار بىزگە قۇل بولغاندەك بىز ئۇلارغا قۇل بولىمىز؛ ئەركەكتەك بولۇپ جەڭ قىلىڭلار! ــ دېدى. \x ◘ \xo 4:9 \xt ھاك. 13‏:1. \x*
\m 
\v 10 شۇنىڭ بىلەن فىلىستىيلەر ئىسرائىللار بىلەن جەڭ قىلدى. ئىسرائىل تارمار قىلىنىپ، ھەربىرى تەرەپ-تەرەپكە ئۆز چېدىرىگە بەدەر قاچتى. جەڭدە قاتتىق قىرغىنچىلىق بولۇپ، ئىسرائىلدىن ئوتتۇز مىڭ پىيادە ئەسكەر ئۆلتۈرۈلدى.
\v 11 پەرۋەردىگارنىڭ ئەھدە ساندۇقى ئولجا بولۇپ كەتتى ۋە ئەلىنىڭ ئىككى ئوغلى خوفنىي بىلەن فىنىھاسمۇ ئۆلتۈرۈلدى. \x ◘ \xo 4:11 \xt 1سام. 2‏:34؛ زەب. 78‏:59-61\x*
\b
\m 
\v 12 شۇ كۈنى بىر بىنيامىنلىق جەڭ مەيدانىدىن قېچىپ كىيىم-كېچەكلىرى يىرتىق، ئۈستىبېشى توپا-چاڭ ھالدا شىلوھغا يۈگۈرۈپ كەلدى. \x ◘ \xo 4:12 \xt يە. 7‏:6. \x*
\v 13 ئۇ يېتىپ كەلگەندە، مانا ئەلى يولنىڭ چېتىدە ئۆز ئورۇندۇقىدا ئولتۇرۇپ تاقىتى-تاق بولۇپ كۈتۈۋاتاتتى؛ ئۇنىڭ كۆڭلى پەرۋەردىگارنىڭ ئەھدە ساندۇقىنىڭ غېمىدە پەرىشان ئىدى. ئۇ كىشى خەۋەرنى يەتكۈزگىلى شەھەرگە كىرگەندە، پۈتكۈل شەھەر پەرياد-چۇقان كۆتۈردى.
\v 14 ئەلى پەرياد ساداسىنى ئاڭلاپ: ــ بۇ زادى نېمە ۋاراڭ-چۇرۇڭ؟ دەپ سورىدى. ئۇ كىشى ئالدىراپ كېلىپ ئەلىگە خەۋەر بەردى
\v 15 (ئەلى توقسان سەككىز ياشقا كىرگەن، كۆزلىرى قېتىپ قالغان بولۇپ، كۆرمەيتتى). \x ◘ \xo 4:15 \xt 1سام. 3‏:2\x*
\v 16 ئۇ كىشى ئەلىگە: ــ مەن جەڭدىن قايتىپ كەلگەن كىشىمەن، بۈگۈن جەڭ مەيدانىدىن قېچىپ كەلدىم، دېدى. ئەلى: ــ ئى ئوغلۇم، نېمە ئىش يۈز بەردى؟ ــ دەپ سورىدى.
\v 17 خەۋەرچى جاۋاب بېرىپ: ــ ئىسرائىل فىلىستىيلەرنىڭ ئالدىدىن بەدەر قاچتى. خەلق ئارىسىدا قاتتىق قىرغىنچىلىق بولدى! سېنىڭ ئىككى ئوغلۇڭ، خوفنىي بىلەن فىنىھاسمۇ ئۆلدى ھەمدە خۇدانىڭ ئەھدە ساندۇقىمۇ ئولجا بولۇپ كەتتى، دېدى.
\v 18 ۋە شۇنداق بولدىكى، خەۋەرچى خۇدانىڭ ئەھدە ساندۇقىنى تىلغا ئالغاندا، ئەلى دەرۋازىنىڭ يېنىدىكى ئورۇندۇقتىن كەينىگە يىقىلىپ چۈشۈپ، بوينى سۇنۇپ ئۆلدى؛ چۈنكى ئۇ قېرىپ، بەدىنىمۇ ئېغىرلىشىپ كەتكەنىدى. ئۇ قىرىق يىل ئىسرائىلنىڭ ھاكىمى بولغانىدى. \f ◼ \fr 4:18 \ft \bd «ئۇ قىرىق يىل ئىسرائىلنىڭ ھاكىمى بولغانىدى»\bd* ــ «ھاكىم»لارنىڭ يېتەكچى ھەم سوراقچى رولىنى چۈشىنىش ئۈچۈن تەۋراتتىكى «باتۇر ھاكىملار»نى كۆرۈڭ.\f*
\m 
\v 19 ئۇنىڭ كېلىنى، يەنى فىنىھاسنىڭ ئايالى ھامىلىدار بولۇپ تۇغۇشقا ئاز قالغانىدى. ئۇ خۇدانىڭ ئەھدە ساندۇقىنىڭ ئولجا بولۇپ كەتكەنلىكى ۋە قىيىنئاتىسى بىلەن ئېرىنىڭمۇ ئۆلگەنلىك خەۋىرىنى ئاڭلىغاندا، بىردىنلا قاتتىق تولغاق تۇتۇپ، پۈكۈلۈپ بالىنى تۇغدى.
\v 20 ئۇ ئۆلەي دەپ قالغاندا، چۆرىسىدە تۇرغان ئاياللار: ــ قورقمىغىن، سەن ئوغۇل بالا تۇغدۇڭ، دېدى. لېكىن ئۇ بۇنىڭغا جاۋابمۇ بەرمىدى ھەم كۆڭۈل بۆلمىدى.
\v 21 ئۇ: «شان-شەرەپ ئىسرائىلدىن كەتتى» دەپ بالىغا «ئىخابود» دەپ ئىسىم قويدى؛ چۈنكى خۇدانىڭ ئەھدە ساندۇقى ئولجا بولۇپ كەتكەن ھەم قېيىنئاتىسى بىلەن ئېرىمۇ ئۆلگەنىدى. \f ◼ \fr 4:21 \ft \bd «ئۇ: «شان-شەرەپ ئىسرائىلدىن كەتتى» دەپ بالىغا «ئىخابود» دەپ ئىسىم قويدى»\bd* ــ «ئىخابود» بەلكىم «شان-شەرەپ قېنى؟» ياكى «شان-شەرەپ كەتتى» دېگەننى بىلدۈرىدۇ.\f*
\v 22 ئۇ يەنە: ــ شان-شەرەپ ئىسرائىلدىن كەتتى؛ چۈنكى خۇدانىڭ ئەھدە ساندۇقى ئولجا بولۇپ كەتتى! ــ دېدى.
\b
\b
\c 5
\m 
\v 1 فىلىستىيلەر خۇدانىڭ ئەھدە ساندۇقىنى ئولجا ئېلىپ، ئۇنى ئەبەن-ئېزەردىن ئېلىپ ئاشدودقا باردى.
\v 2 ئۇ يەردە فىلىستىيلەر خۇدانىڭ ئەھدە ساندۇقىنى ئېلىپ داگون بۇتخانىسىغا ئەكىرىپ، داگون دېگەن بۇتنىڭ يېنىغا قويدى.
\v 3 ئاشدوددتكىلەر ئەتىسى سەھەر قوپۇپ كەلسە، مانا داگون بۇتى پەرۋەردىگارنىڭ ئەھدە ساندۇقىنىڭ ئالدىدا يىقىلغىنىچە دۈم ياتاتتى. شۇڭا ئۇلار داگون بۇتنى ئېلىپ يەنە ئۆز ئورنىدا تۇرغۇزۇپ قويدى.
\v 4 لېكىن ئەتىسى سەھەر قوپۇپ كەلسە، مانا، داگون پەرۋەردىگارنىڭ ئەھدە ساندۇقىنىڭ ئالدىدا يىقىلغىنىچە دۈم ياتاتتى؛ داگوننىڭ بېشى ھەم قوللىرى بوسۇغىدا چېقىلغانىدى؛ داگوننىڭ پەقەت بېلىقسىمان تېنى قالغانىدى. \f ◼ \fr 5:4 \ft \bd «داگون پەرۋەردىگارنىڭ ئەھدە ساندۇقىنىڭ ئالدىدا يىقىلغىنىچە دۈم ياتاتتى»\bd* ــ «داگون» دېگەن بۇتتا ئادەمنىڭ بېشى ۋە بېلىقنىڭ تېنى بار ئىدى.\f*
\v 5 شۇڭا بۈگۈنگە قەدەر ئاشدودتا يا داگوننىڭ كاھىنلىرى بولسۇن يا داگوننىڭ بۇتخانىسىغا كىرگۈچىلەر بولسۇن، داگوننىڭ بوسۇغىسىغا دەسسىمەيدۇ.
\m 
\v 6 ئاندىن پەرۋەردىگارنىڭ قولى ئاشدودتىكىلەرنىڭ ئۈستىگە قاتتىق چۈشۈپ، ئۇلارنى ۋەيران قىلىپ، ئاشدود بىلەن ئەتراپىدىكىلەرنى ھۈررەك كېسىلى بىلەن ئۇردى. \f ◼ \fr 5:6 \ft \bd «ھۈررەك كېسىلى»\bd* ــ ياكى «ئۆسمىلەر» ياكى «بوۋاسىر كېسىلى».\f*  \x ◘ \xo 5:6 \xt زەب. 78‏:60-66. \x*
\v 7 ئاشدودتىكىلەر بۇلارنى كۆرۈپ: ــ ئىسرائىلنىڭ خۇداسىنىڭ ئەھدە ساندۇقى بىزلەردە تۇرمىسۇن! چۈنكى ئۇنىڭ قولى بىزنى ۋە ئىلاھىمىز داگوننى قاتتىق بېسىۋالدى، دېيىشتى.
\v 8 شۇنىڭ بىلەن ئۇلار ئادەم ماڭدۇرۇپ فىلىستىيلەرنىڭ ھەممە غوجىلىرىنى چاقىرتىپ جەم قىلىپ ئۇلاردىن: ــ ئىسرائىلنىڭ خۇداسىنىڭ ئەھدە ساندۇقىنى قانداق بىر تەرەپ قىلىمىز؟ دەپ سورىدى. ئۇلار: ــ ئىسرائىلنىڭ خۇداسىنىڭ ئەھدە ساندۇقى گاتقا چەت يول بىلەن يۆتكەلسۇن، دەپ جاۋاب بېرىشتى. شۇنىڭ بىلەن ئۇلار ئىسرائىلنىڭ خۇداسىنىڭ ئەھدە ساندۇقىنى ئۇ يەرگە چەت يول بىلەن يۆتكىدى. \f ◼ \fr 5:8 \ft \bd «گاتقا چەت يول بىلەن يۆتكەلسۇن»\bd* ــ بەلكىم باشقا شەھەر-كەنتلەردىن ئۆتكۈزمەسلىك ئۈچۈن.\f*
\v 9 ۋە شۇنداق بولدىكى، ئۇلار ئۇنى چەت يول بىلەن يۆتكىگەندىن كېيىن پەرۋەردىگارنىڭ قولى ئۇ شەھەرگە چۈشۈپ كىشىلەرنى قاتتىق ساراسىمىگە چۈشۈردى. ئۇ كىچىكلەردىن تارتىپ چوڭلارغىچە شەھەردىكىلەرنى ئۇردى، ئۇلار ھۈررەك كېسىلىگە گىرىپتار بولدى.
\v 10 شۇنىڭ بىلەن ئۇلار خۇدانىڭ ئەھدە ساندۇقىنى ئەكرونغا ئەۋەتتى. لېكىن خۇدانىڭ ئەھدە ساندۇقى ئەكرونغا يېتىپ كەلگەندە، ئەكروندىكىلەر پەرياد قىلىپ: ــ بىز بىلەن خەلقىمىزنى ئۆلتۈرۈش ئۈچۈن ئۇلار ئىسرائىلنىڭ خۇداسىنىڭ ئەھدە ساندۇقىنى بىزگە يۆتكىدى! ــ دېدى.
\v 11 ئۇلار ئادەم ماڭدۇرۇپ فىلىستىيلەرنىڭ غوجىلىرىنى قىچقارتىپ جەم قىلىپ ئۇلارغا: ــ بىز بىلەن خەلقىمىزنى ئۆلتۈرمەسلىكى ئۈچۈن ئىسرائىلنىڭ خۇداسىنىڭ ئەھدە ساندۇقىنى بۇ يەردىن ئۆز جايىغا كەتكۈزۈڭلار، دېدى؛ چۈنكى قاتتىق ۋەھىمە شەھەرنى باسقانىدى؛ خۇدانىڭ قولى ئۇلارنىڭ ئۈستىگە تولىمۇ ئېغىر چۈشكەنىدى.
\v 12 ئۆلمىگەن ئادەملەر بولسا ھۈررەك كېسىلى بىلەن ئۇرۇلۇپ، شەھەرنىڭ پەريادى ئاسمانغا كۆتۈرۈلدى.
\b
\b
\c 6
\s1 فىلىستىيلەر ئەھدە ساندۇقىنى قايتۇرۇپ ئەۋەتىدۇ
\m 
\v 1 پەرۋەردىگارنىڭ ئەھدە ساندۇقى فىلىستىيلەرنىڭ يۇرتىدا يەتتە ئاي تۇردى.
\v 2 فىلىستىيلەر كاھىنلار بىلەن پالچىلارنى چاقىرىپ ئۇلارغا: ــ پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى قانداق قىلىمىز؟ ئۇنى قانداق قىلىپ ئۆز جايىغا ئەۋەتەلەيمىز؟ يول كۆرسىتىڭلار، دېدى.
\v 3 ئۇلار: ــ ئەگەر ئىسرائىلنىڭ خۇداسىنىڭ ئەھدە ساندۇقىنى قايتۇرۇپ ئەۋەتسەڭلار، قۇرۇق ئەۋەتمەڭلار، ھېچ بولمىغاندا ئۇنىڭ بىلەن بىر «ئىتائەتسىزلىك قۇربانلىقى»نى بىرگە ئەۋەتىشىڭلار زۆرۈردۇر، دېدى. شۇنداق قىلغاندا شىپا تاپىسىلەر، شۇنداقلا ئۇنىڭ قولىنىڭ نېمە ئۈچۈن سىلەردىن ئايرىلمىغانلىقىنى بىلىسىلەر، دېدى.
\v 4 ئۇلار: ــ بىز نېمىنى ئىتائەتسىزلىك قۇربانلىقى قىلىپ ئەۋەتىمىز؟ ــ دەپ سورىدى.
\m ئۇلار: ــ فىلىستىيلەرنىڭ غوجىلىرىنىڭ سانى بەش؛ شۇڭا بەش ئالتۇن ھۈررەك ۋە بەش ئالتۇن چاشقان ياساپ ئەۋەتىڭلار؛ چۈنكى سىلەرگە ۋە غوجاڭلارغا ئوخشاشلا بالا-قازا چۈشتى.
\v 5 ھۈررەكلىرىڭلارنىڭ شەكلىنى ۋە زېمىنىڭلارنى ۋەيران قىلىدىغان چاشقانلارنىڭ شەكلىنى نەقىش قىلىپ ياساپ، ئىسرائىلنىڭ خۇداسىغا شان-شەرەپ كەلتۈرۈڭلار. شۇنىڭ بىلەن ئۇ بەلكىم سىلەرنىڭ، ئىلاھلىرىمىزنىڭ ۋە زېمىنىڭلارنىڭ ئۈستىنى باسقان قولىنى يېنىكلىتەرمىكىن: ــ
\v 6 مىسىرلىقلار بىلەن پىرەۋن ئۆز كۆڭۈللىرىنى قاتتىق قىلغاندەك سىلەرمۇ نېمىشقا ئۆز كۆڭلۈڭلارنى قاتتىق قىلىسىلەر؟ ئۇ مىسىرلىقلارغا زور قاتتىق قوللۇق كۆرسەتكەندىن كېيىن، ئۇلار ئىسرائىللارنى قويۇپ بەرمىدىمۇ، ئۇلار شۇنىڭ بىلەن قايتىپ كەلمىدىمۇ؟ \x ◘ \xo 6:6 \xt مىس. 12‏:31. \x*
\v 7 ئەمدى يېڭى بىر ھارۋا ياساپ، تېخى بويۇنتۇرۇققا كۆندۈرۈلمىگەن موزايلىق ئىككى ئىنەكنى ھارۋىغا قوشۇڭلار؛ ئۇلاردىن موزايلىرىنى ئايرىپ، ئۆيدە ئېلىپ قېلىڭلار؛
\v 8 ئاندىن پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى كۆتۈرۈپ ھارۋىغا سېلىڭلار؛ ۋە ئۇنىڭغا ئەۋەتىدىغان ئىتائەتسىزلىك قۇربانلىقى قىلىدىغان ئالتۇن بۇيۇملارنى بىر قاپقا سېلىپ ساندۇققا يانداپ قويۇڭلار ۋە ساندۇقنى شۇ پېتى ماڭدۇرۇڭلار؛
\v 9 ئاندىن قاراپ تۇرۇڭلار. ئەگەر ھارۋا ئىسرائىل چېگرىسىدىكى يول بىلەن بەيت-شەمەشكە ماڭسا، بىزگە كەلگەن شۇ چوڭ بالا-قازانى چۈشۈرگۈچىنىڭ ئۆزى پەرۋەردىگار بولىدۇ. ئۇنداق بولمىسا، بىزنى ئۇرغان ئۇنىڭ قولى ئەمەس، بەلكى بىزگە چۈشكەن تاسادىپىيلىق بولىدۇ، خالاس، دېيىشتى.
\m 
\v 10 شۇنىڭ بىلەن فىلىستىيلەر شۇنداق قىلدى. ئۇلار موزايلىق ئىككى ئىنەكنى ھارۋىغا قوشۇپ، موزايلىرىنى ئۆيدە سولاپ قويۇپ،
\v 11 پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى ھارۋىغا سېلىپ، ئالتۇن چاشقان ۋە قۇيما ھۈررەكلەر قاچىلانغان قاپنى ئۇنىڭغا يانداپ قويدى.
\v 12 ئىنەكلەر بەيت-شەمەشكە بارىدىغان يول بىلەن ئۇدۇل يۈرۈپ كەتتى. ئۇلار كۆتۈرۈلگەن يول بىلەن ماڭغاچ مۆرەيتتى، يا ئوڭ تەرەپكە يا سول تەرەپكە قېيىپ كەتمىدى. فىلىستىيلەرنىڭ غوجىلىرى ئۇلارنىڭ ئارقىسىدىن بەيت-شەمەشنىڭ چېگرىسىغىچە باردى.
\v 13 بەيت-شەمەشتىكىلەر جىلغىدا بۇغداي ئورۇۋاتاتتى، ئۇلار باشلىرىنى كۆتۈرۈپ ئەھدە ساندۇقىنى كۆرۈپ خۇش بولۇشتى.
\v 14 ھارۋا بەيت-شەمەشلىك يەشۇئانىڭ ئېتىزلىقىغا كېلىپ، ئۇ يەردىكى بىر چوڭ تاشنىڭ يېنىدا توختاپ قالدى. ئۇلار ھارۋىنى چېقىپ، ئىككى ئىنەكنى پەرۋەردىگارغا ئاتاپ كۆيدۈرمە قۇربانلىق قىلدى. \f ◼ \fr 6:14 \ft \bd «ھارۋا بەيت-شەمەشلىك يەشۇئانىڭ ئېتىزلىقىغا كېلىپ، ئۇ يەردىكى بىر چوڭ تاشنىڭ يېنىدا توختاپ قالدى»\bd* ــ دېمىسەكمۇ، بەيت-شەمەشتىكىلەر ئىسرائىللار ئىدى، بەيت-شەمەش ئىسرائىل بىلەن فىلىستىيە ئوتتۇرىسىدىكى چېگرا ئىدى.\f*
\v 15 لاۋىيلار پەرۋەردىگارنىڭ ئەھدە ساندۇقى بىلەن ئالتۇن بۇيۇملار بار قاپنى چۈشۈرۈپ چوڭ تاشنىڭ ئۈستىگە قويدى. شۇ كۈنى بەيت-شەمەشتىكىلەر پەرۋەردىگارغا كۆيدۈرمە قۇربانلىقلار ۋە باشقا قۇربانلىقلارنى قىلدى. \f ◼ \fr 6:15 \ft \bd «بەيت-شەمەشتىكىلەر پەرۋەردىگارغا كۆيدۈرمە قۇربانلىقلار ۋە باشقا قۇربانلىقلارنى قىلدى»\bd* ــ «باشقا قۇربانلىقلار» بەلكىم «تەشەككۈر قۇربانلىقلىرى»نى كۆرسىتىدۇ. ئۇنداق قۇربانلىقلارنى يېيىشكە بولىدۇ.\f*
\v 16 فىلىستىيلەرنىڭ بەش غوجىسى بۇلارنى كۆرۈپ شۇ كۈنى ئەكرونغا قايتىپ كەتتى.
\v 17 فىلىستىيلەرنىڭ پەرۋەردىگارغا ئىتائەتسىزلىك قۇربانلىقى قىلىپ بەرگەن ئالتۇن ھۈررىكى: ــ ئاشدود ئۈچۈن بىر، گازا ئۈچۈن بىر، ئاشكېلون ئۈچۈن بىر، گات ئۈچۈن بىر ۋە ئەكرون ئۈچۈن بىر ئىدى.
\v 18 ئالتۇن چاشقانلارنىڭ سانى بولسا فىلىستىيلەرنىڭ بەش غوجىسىغا تەۋە بارلىق شەھەرنىڭ سانى بىلەن باراۋەر ئىدى. بۇ شەھەرلەر سېپىللىق شەھەرلەر ۋە ئۇلارغا قاراشلىق سەھرا-كەنتلەرنى، شۇنداقلا ئۇلار پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى قويغان چوڭ چىمەنزارغىچە ھەممە جاينى ئۆز ئىچىگە ئالاتتى. بۇ چىمەنزار ھازىرمۇ بەيت-شەمەشلىك يەشۇئانىڭ ئېتىزلىقىدا بار. \f ◼ \fr 6:18 \ft \bd «بۇ شەھەرلەر سېپىللىق شەھەرلەر ۋە ئۇلارغا قاراشلىق سەھرا-كەنتلەرنى، شۇنداقلا ئۇلار پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى قويغان چوڭ چىمەنزارغىچە ھەممە جاينى ئۆز ئىچىگە ئالاتتى. بۇ چىمەنزار ھازىرمۇ بەيت-شەمەشلىك يەشۇئانىڭ ئېتىزلىقىدا بار»\bd* ــ باشقا بىرخىل تەرجىمىسى: «(بۇ شەھەرلەر سېپىللىق شەھەرلەرنى ۋە ئۇنىڭغا قاراشلىق سەھرا-كەنتلەرنى، شۇنداقلا ئۇلار پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى قويغان چوڭ تاشقىچە ھەممىنى ئۆز ئىچىگە ئالغانىدى) بۇ چوڭ تاش بۈگۈنگىچە بەيت-شەمەشلىك يەشۇئانىڭ ئېتىزلىقىدا تۇرماقتا». يەنە باشقا تەرجىمىلىرى ئۇچرىشى مۇمكىن.\f*
\m 
\v 19 ئەمما بەيت-شەمەشتىكىلەر ئۆز مەيلىچە ئەھدە ساندۇقىنىڭ ئىچىگە قارىغىنى ئۈچۈن پەرۋەردىگار ئۇلاردىن يەتمىش ئادەمنى، جۈملىدىن چوڭلاردىن ئەللىكنى ئۇردى. پەرۋەردىگار خەلقنى مۇنداق قاتتىق ئۇرغانلىقى ئۈچۈن پۈتۈن خەلق ماتەم تۇتتى. \f ◼ \fr 6:19 \ft \bd «...يەتمىش ئادەمنى، جۈملىدىن چوڭلاردىن ئەللىكنى ئۇردى»\bd* ــ بۇنىڭ باشقا بىرخىل تەرجىمىسى: «...بەش تۈمەن يەتمىش ئادەمنى ئۇردى». ئاز بىر قىسىم كونا كۆچۈرمىلەردىمۇ پەقەت «يەتمىش ئادەم» دەپ خاتىرىلەنگەن.\f*
\v 20 بەيت-شەمەشتىكىلەر: ــ بۇ مۇقەددەس خۇدا پەرۋەردىگارنىڭ ئالدىدا كىم ئۆرە تۇرالايدۇ؟ ئەھدە ساندۇقى بىزنىڭ بۇ يەردىن كىمنىڭ قېشىغا ئاپىرىلىشى كېرەك؟ ــ دېدى.
\v 21 ئاندىن ئۇلار كىرىئات-يېئارىمدىكىلەرگە ئەلچىلەرنى ئەۋىتىپ: ــ فىلىستىيلەر پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى قايتۇرۇپ بەردى. بۇ يەرگە كېلىپ ئۇنى ئۆزۈڭلارغا ئېلىپ كېتىڭلار، دېدى.
\b
\b
\c 7
\s1 ئىسرائىللار فىلىستىيلەر بىلەن يەنە سوقۇشىدۇ
\m 
\v 1 شۇنىڭ بىلەن كىرىئات-يېئارىمدىكى ئادەملەر كېلىپ پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى ئېلىپ چىقىپ، دۆڭنىڭ ئۈستىدىكى ئابىنادابنىڭ ئۆيىدە قويدى ۋە ئۇنىڭ ئوغلى ئەلىئازارنى ئەھدە ساندۇقىغا قاراشقا پەرۋەردىگارغا ئاتاپ بېكىتتى. \x ◘ \xo 7:1 \xt 2سام. 6‏:4. \x*
\v 2 ئەھدە ساندۇقى كىرىئات-يېئارىمدا قويۇلغاندىن تارتىپ ئۇزۇن ۋاقىت، يەنى يىگىرمە يىل ئۆتتى. ئىسرائىلنىڭ پۈتكۈل جەمەتى پەرۋەردىگارنى سېغىندى.
\m 
\v 3 ۋە سامۇئىل ئىسرائىلنىڭ پۈتكۈل جەمەتىگە: ــ ئەگەر پۈتۈن قەلبىڭلار بىلەن پەرۋەردىگارنىڭ يېنىغا قايتىپ، ياتلارنىڭ ئىلاھلىرى بىلەن ئاشتاروتلارنى ئۆز ئاراڭلاردىن يوقىتىپ، كۆڭلۈڭلارنى پەرۋەردىگارغا باغلاپ، خاس ئۇنىڭ ئىبادىتىدىلا بولساڭلار ئۇ سىلەرنى فىلىستىيلەرنىڭ قولىدىن قۇتقۇزىدۇ، دېدى. \f ◼ \fr 7:3 \ft \bd «ئاشتاروتلار»\bd* ــ ياكى «ئاشەراھلار» ــ ئالاھىدە دەرەخلەر بىلەن مۇناسىۋەتلىك ئايال بۇتلارنى كۆرسىتىدۇ؛ دەرەخلەر بەلكىم ئايال بۇت شەكلىدە ئويۇلغان ياكى نەقىشلەنگەن بولۇشى مۇمكىن ئىدى.\f*  \x ◘ \xo 7:3 \xt قان. 6‏:13؛ 10‏:20؛ مات. 4‏:10؛ لۇقا 4‏:8\x*
\v 4 شۇنىڭ بىلەن ئىسرائىل بائاللار بىلەن ئاشتاروتلارنى تاشلاپ خاس پەرۋەردىگارنىڭ ئىبادىتىدىلا بولدى.
\m 
\v 5 ئاندىن سامۇئىل: ــ پۈتكۈل ئىسرائىلنى مىزپاھ شەھىرىگە جەم قىلساڭلار، مەن سىلەر ئۈچۈن پەرۋەردىگارنىڭ ئالدىدا دۇئا قىلاي، دېدى.
\v 6 ئەمدى ئۇلار مىزپاھقا جەم بولۇپ، ئۇ يەردە سۇ تارتىپ ئۇنى پەرۋەردىگار ئالدىغا قۇيدى ۋە ئۇ كۈنى روزا تۇتۇپ: ــ بىز پەرۋەردىگارنىڭ ئالدىدا گۇناھ سادىر قىلدۇق، دېدى. شۇنىڭ بىلەن سامۇئىل مىزپاھتا ئىسرائىللارنىڭ ئەرز-دەۋالىرى ئۈستىدىن ھۆكۈم چىقاردى. \f ◼ \fr 7:6 \ft \bd «...سامۇئىل ... ئىسرائىل خەلقىنىڭ ئەرز-دەۋالىرىنىڭ ئۈستىدىن ھۆكۈم چىقاردى»\bd* ــ سامۇئىل پەيغەمبەر ئىسرائىل ئۈستىگە ھۆكۈم سۈرگەن «باتۇر ھاكىملار» ياكى «قۇتقۇزغۇچى باتۇرلار»نىڭ ئەڭ ئاخىرقىسى ئىدى.\f*
\m 
\v 7 فىلىستىيلەر ئىسرائىللارنىڭ مىزپاھدا جەم بولغىنىنى ئاڭلىدى؛ فىلىستىيلەرنىڭ غوجىلىرى ئىسرائىل بىلەن جەڭ قىلغىلى چىقتى. ئىسرائىللار بۇنى ئاڭلاپ فىلىستىيلەردىن قورقتى.
\v 8 ئىسرائىللار سامۇئىلغا: ــ بىز ئۈچۈن پەرۋەردىگار خۇدايىمىز بىزنى فىلىستىيلەرنىڭ قولىدىن قۇتقۇزۇشى ئۈچۈن ئۇنىڭغا نىدا قىلىشتىن توختىمىغىن، دېدى.
\v 9 سامۇئىل ئانىسىنى ئېمىۋاتقان بىر قوزىنى ئېلىپ تولۇق بىر كۆيدۈرمە قۇربانلىق قىلىپ پەرۋەردىگارغا سۇندى؛ سامۇئىل ئىسرائىلنىڭ ھەققىدە پەرۋەردىگارغا پەرياد كۆتۈردى؛ پەرۋەردىگار دۇئاسىنى ئاڭلىدى.
\v 10 سامۇئىل كۆيدۈرمە قۇربانلىق قىلىۋاتقاندا فىلىستىيلەر ئىسرائىل بىلەن سوقۇشقىلى يېقىنلاپ كەلدى. لېكىن پەرۋەردىگار شۇ كۈنى فىلىستىيلەرنىڭ ئۈستىگە قاتتىق گۈلدۈرماما گۈلدۈرلىتىپ ئۇلارنى ئالاقزادە قىلىۋەتتى؛ شۇنىڭ بىلەن ئۇلار ئىسرائىل ئالدىدا تارمار بولدى. \x ◘ \xo 7:10 \xt يە. 10‏:10. \x*
\v 11 ئىسرائىللار مىزپاھتىن چىقىپ ئۇلارنى بەيت-كارنىڭ تۈۋىگىچە قوغلاپ قىردى.
\m 
\v 12 ئۇ ۋاقىتتا سامۇئىل بىر تاشنى ئېلىپ، ئۇنى مىزپاھ بىلەن شەننىڭ ئوتتۇرىسىدا تىكلەپ: ــ «پەرۋەردىگار بىزگە ھازىرغىچە ياردەم بېرىۋاتىدۇ» ــ دەپ ئۇنى ئەبەن-ئېزەر دەپ ئاتىدى. \f ◼ \fr 7:12 \ft \bd «سامۇئىل بىر تاشنى ئېلىپ.... پەرۋەردىگار بىزگە ھازىرغىچە ياردەم بېرىۋاتىدۇ» ــ دەپ ئۇنى ئەبەن-ئېزەر دەپ ئاتىدى»\bd* ــ «ئەبەن-ئېزەر» دېگەننىڭ مەنىسى: «ياردەم تېشى».\f*  \x ◘ \xo 7:12 \xt 1سام. 4‏:1. \x*
\m 
\v 13 شۇنىڭ بىلەن فىلىستىيلەر بېسىقىپ ئىسرائىلنىڭ زېمىنىغا يەنە تاجاۋۇز قىلمىدى؛ سامۇئىل \add ھاكىم\add* بولغان بارلىق كۈنلەردە پەرۋەردىگارنىڭ قولى فىلىستىيلەرنىڭ ئۈستىگە قارشى بولدى؛
\v 14 شۇنداق قىلىپ ئەكروندىن تارتىپ گاتقىچە فىلىستىيلەر ئىسرائىلدىن ئېلىۋالغان شەھەرلەرنىڭ ھەممىسى ئىسرائىلغا ياندۇرۇلدى؛ شەھەرلەرگە تەۋە زېمىنلارنىمۇ ئىسرائىل فىلىستىيلەرنىڭ قولىدىن ياندۇرۇپ ئالدى. بۇنىڭدىن باشقا ئىسرائىل بىلەن ئامورىيلار ئوتتۇرىسىدا تىنچلىق بولدى.
\m 
\v 15 سامۇئىل بولسا پۈتۈن ئۆمرىدە ئىسرائىلنى سورىدى.
\v 16 ھەر يىلى ئۇ بەيت-ئەل، گىلگال ۋە مىزپاھلارنى ئايلىنىپ، مۇشۇ يەرلەردە ئىسرائىل ئۈستىدىن ھۆكۈم يۈرگۈزەتتى.
\v 17 ئاندىن ئۇ راماھقا يېنىپ باراتتى؛ چۈنكى ئۇنىڭ ئۆيى شۇ يەردە ئىدى ھەم ئۇ ئۇ يەردىمۇ ئىسرائىل ئۈستىدىن ھۆكۈم يۈرگۈزەتتى. ئۇ ئۇ يەردىمۇ پەرۋەردىگارغا بىر قۇربانگاھ ياسىغانىدى. \x ◘ \xo 7:17 \xt 1سام. 8‏:4. \x*
\b
\b
\c 8
\m 
\v 1 شۇنداق بولدىكى، سامۇئىل قېرىغاندا ئوغۇللىرىنى ئىسرائىلغا ھاكىم قىلىپ قويدى.
\v 2 ئۇنىڭ تۇنجىسىنىڭ ئىسمى يوئېل بولۇپ، ئىككىنچىسىنىڭ ئىسمى ئابىياھ ئىدى. بۇلار بەئەر-شېبادا ھاكىملىق قىلدى.
\v 3 لېكىن ئوغۇللىرى ئۇنىڭ يوللىرىدا يۈرمەيتتى، بەلكى مەنپەئەتنى كۆزلەپ ئېزىپ، پارىلارنى يەپ، ھەق-ناھەقنى ئاستىن-ئۈستۈن قىلدى. \x ◘ \xo 8:3 \xt مىس. 18‏:21؛ قان. 16‏:19. \x*
\m 
\v 4 ئۇ ۋاقىتتا ئىسرائىلنىڭ ھەممە ئاقساقاللىرى راماھدا جەم بولۇپ سامۇئىلنىڭ قېشىغا كېلىپ
\v 5 ئۇنىڭغا: ــ مانا سەن قېرىدىڭ، ئوغۇللىرىڭ بولسا سېنىڭ يوللىرىڭدا يۈرمەيدۇ. بارلىق ئەللەردە بولغاندەك ئۈستىمىزگە ھۆكۈم سۈرىدىغان بىر پادىشاھ بېكىتكىن، دېدى. \x ◘ \xo 8:5 \xt ھوش. 13‏:10؛ روس. 13‏:21. \x*
\m 
\v 6 ئۇلارنىڭ «ئۈستىمىزگە ھۆكۈم سۈرىدىغان بىر پادىشاھ بېكىتكىن» دېگىنى سامۇئىلنىڭ كۆڭلىگە ئېغىر كەلدى. سامۇئىل پەرۋەردىگارغا دۇئا قىلىۋىدى، \x ◘ \xo 8:6 \xt 1سام. 12‏:17. \x*
\v 7 پەرۋەردىگار سامۇئىلغا جاۋابەن: ــ خەلق ساڭا ھەرنېمە ئېيتسا ئۇلارغا قۇلاق سالغىن؛ چۈنكى ئۇلار سېنى ئەمەس، بەلكى «ئۈستىمىزگە پادىشاھ بولمىسۇن» دەپ مېنى تاشلىدى.
\v 8 مەن ئۇلارنى مىسىردىن چىقارغان كۈندىن تارتىپ بۈگۈنكى كۈنگىچە ئۇلار شۇنداق ئىشلارنى قىلىپ، مېنى تاشلاپ باشقا ئىلاھلارغا ئىبادەت قىلىپ كەلگەن. ئەمدى ئۇلار ساڭا ھەم شۇنداق قىلىدۇ.
\v 9 شۇنىڭ ئۈچۈن ئۇلارنىڭ سۆزىگە ئۇنىغىن. لېكىن ئۇلارنى قاتتىق ئاگاھلاندۇرۇپ كەلگۈسىدە ئۇلارنىڭ ئۈستىدە سەلتەنەت قىلىدىغان پادىشاھنىڭ ئۇلارنى قانداق باشقۇرىدىغانلىقىنى بىلدۈرگىن، دېدى.
\m 
\v 10 سامۇئىل ئۆزىدىن بىر پادىشاھ سورىغان خەلققە، پەرۋەردىگارنىڭ ئېيتقىنىنىڭ ھەممىسىنى دەپ بەردى.
\m 
\v 11 ئۇ: ــ ئۈستۈڭلاردا سەلتەنەت قىلىدىغان پادىشاھنىڭ تۇتىدىغان يولى مۇنداق بولىدۇ: ــ ئۇ ئوغۇللىرىڭلارنى ئۆز ئىشىغا قويۇپ، جەڭ ھارۋىلىرىنى ھەيدەشكە، ئاتلىق ئەسكەرلىرى بولۇشقا سالىدۇ؛ ئۇلار ئۇنىڭ ھارۋىلىرىنىڭ ئالدىدا يۈگۈرىدۇ؛
\v 12 ئۇلارنى ئۆزى ئۈچۈن مىڭ بېشى ۋە ئەللىك بېشى بولۇشقا، يېرىنى ھەيدەشكە، ھوسۇلىنى ئورۇشقا، جەڭ قوراللىرى بىلەن ھارۋا ئەسۋابلىرىنى ياساشقا سالىدۇ.
\v 13 قىزلىرىڭلارنى ئەتىر ياساشقا، تاماق ئېتىشكە ۋە نان يېقىشقا سالىدۇ.
\v 14 ئەڭ ئېسىل زېمىنلىرىڭلار، ئۈزۈمزارلىرىڭلار بىلەن زەيتۇنلۇقلىرىڭلارنى تارتىۋېلىپ ئۆز خىزمەتكارلىرىغا بېرىدۇ.
\v 15 ئۇ ئۇرۇقۇڭلاردىن، ئۈزۈمزارلىرىڭلارنىڭ ھوسۇلىدىن ئوندىن بىر ئۈلۈشىنى ئۆزىنىڭ غوجىدارلىرى ۋە خىزمەتكارلىرىغا بۆلۈپ بېرىدۇ. \f ◼ \fr 8:15 \ft \bd «ئۇرۇقۇڭلار»\bd* ــ بەلكىم ئاشلىقنىڭ ئۆزىنى كۆرسىتىشى مۇمكىن. \bd «ئۆزىنىڭ غوجىدارلىرى ۋە خىزمەتكارلىرىغا ...»\bd* ــ ياكى «ئۆزىنىڭ ئاغۋاتلىرى ۋە خىزمەتكارلىرىغا ...».\f*
\v 16 ئۇ قۇللىرىڭلار، دېدەكلىرىڭلار، ئەڭ كېلىشكەن يىگىتلىرىڭلارنى ۋە ئېشەكلىرىڭلارنى ئۆز ئىشىغا سالىدۇ.
\v 17 ئۇ قويلىرىڭلاردىن ئوندىن بىر ئۈلۈشىنى ئالىدۇ؛ سىلەر ئۇنىڭ قۇل-خىزمەتكارلىرى بولىسىلەر.
\v 18 سىلەر ئۇ كۈندە ئۆزۈڭلارغا تاللىغان پادىشاھ تۈپەيلىدىن پەرياد كۆتۈرىسىلەر؛ لېكىن پەرۋەردىگار ئۇ كۈنىدە سىلەرگە قۇلاق سالمايدۇ، دېدى.
\m 
\v 19 خەلق بولسا سامۇئىلنىڭ سۆزىگە قۇلاق سالماي: ــ ياق، بەلكى ئۈستىمىزگە سەلتەنەت قىلىدىغان بىر پادىشاھ بولسۇن، دېدى.
\v 20 ــ شۇنداق قىلىپ بىز باشقا ھەربىر ئەللەرگە ئوخشاش بولىمىز؛ بىزنىڭ پادىشاھىمىز ئۈستىمىزدىن ھۆكۈم چىقىرىپ، بىزنى باشلايدۇ ۋە بىز ئۈچۈن جەڭ قىلىدۇ، دېدى.
\m 
\v 21 سامۇئىل خەلقنىڭ ھەممە سۆزلىرىنى ئاڭلاپ، ئۇلارنى پەرۋەردىگارغا يەتكۈزدى. \f ◼ \fr 8:21 \ft \bd «سامۇئىل ... سۆزلىرىنى ئاڭلاپ، ئۇلارنى پەرۋەردىگارغا يەتكۈزدى»\bd* ــ ئىبرانىي تىلىدا «سامۇئىل ... سۆزلىرىنى ئاڭلاپ، ئۇلارنى پەرۋەردىگارنىڭ قۇلىقىغا قايتىلاپ بەردى».\f*
\v 22 پەرۋەردىگار ئەمدى سامۇئىلغا: ــ سەن ئۇلارنىڭ سۆزىگە قۇلاق سېلىپ، ئۇلارغا بىر پادىشاھ بېكىتكىن، دېدى. سامۇئىل ئىسرائىللارغا: ــ ھەربىرىڭلار ئۆز شەھىرىڭلارغا قايتىڭلار، دېدى.
\b
\b
\c 9
\s1 سائۇل سامۇئىلنىڭ قېشىغا كېلىدۇ
\m 
\v 1 بىنيامىن قەبىلىسىدىن كىش ئاتلىق بىر كىشى بار ئىدى. ئۇ ئابىئەلنىڭ ئوغلى، ئابىئەل زېرورنىڭ ئوغلى، زېرور بىكوراتنىڭ ئوغلى، بىكورات ئافىيانىڭ ئوغلى ئىدى؛ ئافىيا بولسا بىنيامىنلىق ئىدى. ئۇ ئۆزى باتۇر ۋە دۆلەتمەن كىشى ئىدى. \x ◘ \xo 9:1 \xt 1سام. 14‏:51. \x*
\v 2 كىشنىڭ سائۇل ئىسىملىك، ئېسىل ۋە خۇشخۇي بىر ئوغلى بار ئىدى. ئىسرائىللار ئارىسىدا ئۇنىڭدىن چىرايلىق ئادەم يوق ئىدى؛ ئۇ شۇنداق ئېگىز بويلۇق ئەر ئىدىكى، خەلقنىڭ ھەرقاندىقى ئۇنىڭ مۈرىسىگىمۇ كەلمەيتتى.
\m 
\v 3 سائۇلنىڭ ئاتىسى كىشنىڭ ئېشەكلىرى يىتىپ كەتكەنىدى. بۇنىڭ بىلەن كىش ئوغلى سائۇلغا: ــ سەن خىزمەتكارلاردىن بىرىنى ئۆزۈڭ بىلەن بىللە ئېلىپ، ئېشەكلەرنى تېپىپ كەلگىن، دېدى.
\v 4 ئۇلار بېرىپ ئەفرائىم ئېدىرلىقىدىن ئۆتۈپ، شالىشاھ زېمىنىنى كېزىپ، ئۇلارنى ئىزدەپ تاپالمىدى؛ ئۇلار شائالىم زېمىنىدىنمۇ ئۆتتى، ئېشەكلەر ئۇ يەردىمۇ يوق ئىدى. ئاندىن بىنيامىن زېمىنىنى كېزىپ ئۆتتى، ئۇلارنى يەنە تاپالمىدى.
\v 5 ئۇلار زۇف زېمىنىغا يەتكەندە سائۇل ئۆزى بىلەن كەلگەن خىزمەتكارىغا: ــ بولە، ئۆيگە يانايلى؛ بولمىسا ئاتام ئېشەكلەردىن ئەنسىرمەي، ئەكسىچە بىزنىڭ غېمىمىزنى يەپ كېتەرمىكى، دېدى.
\m 
\v 6 لېكىن ئۇ ئۇنىڭغا: ــ مانا، بۇ شەھەردە خۇدانىڭ بىر ئادىمى بار. ئۇ مۆھتەرەم بىر ئادەم، ھەر نېمە دېسە ئەمەلگە ئاشماي قالمايدۇ. ئەمدى ئۇ يەرگە بارايلى؛ ئۇ بىزگە بارىدىغان يولىمىزنى كۆرسىتىپ قويارمىكىن، دېدى.
\m 
\v 7 شۇڭا سائۇل خىزمەتكارىغا: ــ لېكىن ئۇنىڭ يېنىغا بارساق ئۇ كىشىگە نېمە بېرىمىز؟ چۈنكى خۇرجۇنلىرىمىزدا نان تۈگەپ قالدى، قولىمىزدا خۇدانىڭ ئادىمىگە بەرگۈدەك سوۋغىتىمىز يوق. يېنىمىزدا يەنە نېمە بار؟ ــ دېدى.
\m 
\v 8 خىزمەتكار سائۇلغا جاۋاب بېرىپ: ــ مانا قولۇمدا چارەك شەكەل كۈمۈش بار. ماڭىدىغان يولىمىزنى دەپ بەرسۇن، خۇدانىڭ ئادىمىگە شۇنى بېرەي، دېدى \f ◼ \fr 9:8 \ft \bd «مانا قولۇمدا چارەك شەكەل كۈمۈش بار»\bd* ــ «شەكەل» ئېغىرلىق مىقدارى، كۈمۈش بەلكىم 11.4 گرام ئىدى.\f*
\v 9 (بۇرۇن ئىسرائىلدا بىر ئادەم خۇدادىن يول سورىماقچى بولسا: ــ كېلىڭلار، ئالدىن كۆرگۈچىنىڭ قېشىغا بارايلى، دەيتتى. ھازىر «پەيغەمبەر» دېگەننى ئۆتكەن زاماندا «ئالدىن كۆرگۈچى» دەيتتى). \x ◘ \xo 9:9 \xt يار. 25‏:22. \x*
\m 
\v 10 سائۇل خىزمەتكارىغا: ــ مەسلىھەتىڭ ياخشى بولدى. بىز ماڭايلى، دېدى. شۇنىڭ بىلەن ئۇلار خۇدانىڭ ئادىمى تۇرغان شەھەرگە باردى.
\v 11 ئۇلار شەھەرگە چىقىدىغان يولدا كېتىۋاتقاندا، سۇ تارتقىلى چىققان بىرنەچچە قىزغا ئۇچرىدى ۋە ئۇلاردىن: ــ ئالدىن كۆرگۈچى مۇشۇ يەردىمۇ؟ ــ دەپ سورىدى.
\m 
\v 12 ئۇلار جاۋاب بېرىپ: ــ شۇنداق. مانا ئۇ ئالدىڭلاردا تۇرىدۇ؛ تېز بېرىڭلار، چۈنكى خالايىق بۈگۈن \add شەھەرنىڭ\add* يۇقىرى جايىدا قۇربانلىق قىلماقچى، شۇڭا ئۇ بۈگۈن شەھەرگە كىردى.
\v 13 ئۇ \add قۇربانلىقتىن\add* يېيىشكە تېخى يۇقىرى جايغا چىقماي تۇرۇپلا، سىلەر ئۇنىڭ بىلەن شەھەردە ئۇچرىشىسىلەر. خەلق ئۇ كەلمىگۈچە تائام يېمەيدۇ، چۈنكى ئۇ ئاۋۋال قۇربانلىقنى بەرىكەتلەيدۇ؛ ئاندىن چاقىرىلغان مېھمانلار تائامغا ئېغىز تېگىدۇ. ھازىر چىقىڭلار، چۈنكى بۇ دەل ئۇنى تاپقىلى بولىدىغان ۋاقىت، دېدى. \f ◼ \fr 9:13 \ft \bd «...ئۇ ئاۋۋال قۇربانلىقنى بەرىكەتلەيدۇ»\bd* ــ «قۇربانلىقنى بەرىكەتلەش» مۇشۇ يەردە (1) تەشەككۈر ئېيتىش؛ (2) قۇربانلىق قوبۇل قىلىنغاي دەپ تىلەشنى بىلدۈرىدۇ.\f*
\m 
\v 14 ئۇلار شەھەرگە چىقىپ شەھەر مەركىزىگە كەلگەندە، مانا سامۇئىل يۇقىرى جايغا چىقىشقا ئۇلارغا قاراپ كېلىۋاتاتتى.
\m 
\v 15 پەرۋەردىگار سائۇل كېلىشتىن بىر كۈن ئىلگىرى سامۇئىلغا: \x ◘ \xo 9:15 \xt 1سام. 15‏:1. \x*
\m 
\v 16 ــ ئەتە مۇشۇ ۋاقىتلاردا مەن يېنىڭغا بىنيامىن زېمىنىدىن بىر ئادەمنى ئەۋەتىمەن. سەن ئۇنى مېنىڭ خەلقىم ئىسرائىلنىڭ ئۈستىگە ئەمىر بولۇشقا مەسىھ قىلغىن. ئۇ مېنىڭ خەلقىمنى فىلىستىيلەرنىڭ قولىدىن قۇتقۇزىدۇ. چۈنكى مېنىڭ خەلقىمنىڭ پەريادى ماڭا يەتكىنى ئۈچۈن ئۇلارغا ئىلتىپات بىلەن قارىدىم، ــ دېدى.
\m 
\v 17 سامۇئىل سائۇلنى كۆرگەندە پەرۋەردىگار ئۇنىڭغا: ــ مانا، مەن ساڭا سۆز قىلغان ئادەم مۇشۇدۇر. بۇ ئادەم مېنىڭ خەلقىمنىڭ ئۈستىدە سەلتەنەت قىلىدۇ، دەپ ئىزھار قىلدى.
\m 
\v 18 سائۇل دەرۋازىدا تۇرغان سامۇئىلنىڭ قېشىغا بېرىپ: سىلىدىن سوراي، ئالدىن كۆرگۈچىنىڭ ئۆيى نەدە، دەپ سورىدى.
\m 
\v 19 سامۇئىل سائۇلغا: ــ ئالدىن كۆرگۈچى مەن ئۆزۈم شۇ. مەندىن ئاۋۋال يۇقىرى جايغا چىققىن. بۈگۈن سىلەر مەن بىلەن تائام يەيسىلەر؛ ئەتە سېنى ئۇزۇتۇپ چىققاندا، كۆڭلۈڭدىكى ھەربىر ئىشلارنى ساڭا دەپ بېرەي، ــ دەپ جاۋاب بەردى.
\v 20 ئەمما ئۈچ كۈن بۇرۇن يىتىپ كەتكەن ئېشەكلەردىن بولسا، ئەندىشە قىلمىغىن؛ ئۇلار تېپىلدى. ئەمدى ئىسرائىلنىڭ ھەممە ئارزۇسى كىمگە مايىل؟ ساڭا ۋە ئاتاڭنىڭ پۈتكۈل جەمەتىگە ئەمەسمۇ؟ ــ دېدى.
\m 
\v 21 سائۇل جاۋاب بېرىپ: ــ مەن ئىسرائىل قەبىلىلىرى ئىچىدىكى ئەڭ كىچىك قەبىلە بولغان بىنيامىندىن، جەمەتىممۇ بىنيامىن قەبىلىسى ئىچىدىكى ئەڭ كىچىكى تۇرسا؟ نېمە ئۈچۈن بۇ سۆزلەرنى ماڭا دەيلا؟ ــ دېدى.
\m 
\v 22 سامۇئىل بولسا سائۇلنى ۋە خىزمەتكارىنى باشلاپ، مېھمانخانا ئۆيىگە كىردى ۋە ئۇلارنى چاقىرىلغانلارنىڭ ئارىسىدا تۆردە ئولتۇرغۇزدى. ئۇلار ئوتتۇزچە ئادەم ئىدى.
\v 23 سامۇئىل ئاشپەزگە: ــ مەن ساقلاپ قويغىن دەپ، ساڭا تاپشۇرغان ھېلىقى تائامنى ئېلىپ كەلگىن، دېدى.
\m 
\v 24 شۇنىڭ بىلەن ئاشپەز ساقلاپ قويغان چوڭ ئاجرىتىلغان قولنى ئېلىپ سائۇلنىڭ ئالدىغا قويدى. سامۇئىل: ــ مانا، \add ساڭا\add* ساقلاپ قويۇلغىنى شۇدۇر! ئۇنى ئالدىڭغا ئېلىپ يېگىن؛ چۈنكى ئۇ مەن خەلقنى چاقىرغان چېغىمدا ئاتايىن ساڭا ئاتاپ ئېلىپ قويغاندىن تارتىپ بۇ بېكىتىلگەن ۋاقىتقىچە ساقلاندى، دېدى. شۇنىڭ بىلەن ئۇ كۈنى سائۇل بىلەن سامۇئىل تاماقتا بىللە بولدى.
\v 25 ئۇلار يۇقىرى جايدىن چۈشۈپ شەھەرگە كىردى، \add سامۇئىل\add* ئۆگزىدە سائۇل بىلەن سۆزلەشتى.
\v 26 ئەتىسى تاڭ شەھەردە ئورۇندىن تۇرغاندا سامۇئىل سائۇلنى ئۆگزىدىن چاقىرىپ: ــ ئورنۇڭدىن تۇر، مەن سېنى ئۇزۇتۇپ قوياي، دېدى. سائۇل ئورۇندىن تۇردى ۋە ئىككىسى بىللە چىقتى، ــ ھەم ئۇ سامۇئىل بىلەن بىللە كوچىغا چىقتى.
\v 27 ئۇلار شەھەرنىڭ ئايىغىغا كېتىۋاتقاندا، سامۇئىل سائۇلغا: خىزمەتكارغا ئالدىمىزدا ماڭغاچ تۇرغىن، دەپ بۇيرۇغىن، دېدى. ئۇ شۇنداق قىلدى. ئاندىن سامۇئىل: ــ سەن تۇرۇپ تۇر، پەرۋەردىگارنىڭ سۆز-كالامىنى ساڭا يەتكۈزەي، دېدى.
\b
\b
\c 10
\s1 سامۇئىل سائۇلنى مەسىھ قىلىدۇ
\m 
\v 1 سامۇئىل بىر ماي كومزىكىنى ئېلىپ ئۇنىڭ بېشىغا تۆكۈپ ئۇنى سۆيۈپ مۇنداق دېدى: ــ «مانا بۇ، پەرەۋردىگارنىڭ سېنى ئۆز مىراسىغا ئەمىر بولۇشقا مەسىھ قىلغىنى ئەمەسمۇ؟ \f ◼ \fr 10:1 \ft \bd «مانا بۇ، پەرەۋردىگارنىڭ سېنى ئۆز مىراسىغا ئەمىر بولۇشقا مەسىھ قىلغىنى ئەمەسمۇ؟»\bd* ــ بەزى كونا كۆچۈرمىلەردە سامۇئىلنىڭ سۆزلىرى: «پەرۋەردىگار سېنى ئۆز خەلقى ئىسرائىل ئۈستىگە ھۆكۈمران قىلدى. سەن پەرۋەردىگارنىڭ خەلقى ئۈستىگە سەلتەنەت قىلىسەن ۋە ئۇلارنى ئەتراپىدىكى دۈشمەنلەرنىڭ قولىدىن قۇتقۇزىسەن. مانا، شۇ ئىش پەرەۋردىگار سېنى ئۆز مىراسىغا باش بولغىلى مەسىھ قىلغان ئەمەسمۇ؟» بۇنىڭغا قوشۇپ دېيىلىدۇ.\f*  \x ◘ \xo 10:1 \xt روس. 13‏:21. \x*
\m 
\v 2 سەن بۈگۈن مەندىن ئايرىلغاندىن كېيىن بىنيامىن زېمىنىنىڭ چېگرىسىدىكى زەلزاھغا يېتىپ بارغىنىڭدا راھىلەنىڭ قەبرىسىنىڭ يېنىدا ساڭا ئىككى كىشى ئۇچرايدۇ؛ ئۇلار ساڭا: «سەن ئىزدەپ بارغان ئېشەكلەر تېپىلدى، ۋە مانا، ئاتاڭ ئېشەكلەردىن غەم قىلماي، بەلكى سىلەر ئۈچۈن: ئوغلۇمنى قانداق قىلىپ تاپارمەن، دەپ ئەنسىرىمەكتە» دەپ ئېيتىدۇ.
\v 3 سەن ئۇ يەردىن مېڭىپ، تابوردىكى دۇب دەرىخىگە يەتكەندە پەرۋەردىگارنىڭ ئالدىغا بېرىش ئۈچۈن بەيت-ئەلگە چىقىپ كېتىۋاتقان ئۈچ كىشىگە ئۇچرايسەن. ئۇلاردىن بىرى ئۈچ ئوغلاق، بىرى ئۈچ نان ۋە يەنە بىرى بىر تۇلۇم شارابنى كۆتۈرۈپ كېلىدۇ.
\m 
\v 4 ــ ئۇلار ساڭا سالام قىلىپ ئىككى ناننى سۇنىدۇ؛ سەن بەرگىنىنى قوللىرىدىن ئالغىن. \x ◘ \xo 10:4 \xt ھاك. 18‏:15. \x*
\v 5 ئاندىن سەن «خۇداغا \add ئاتالغان\add* گىبېئاھ شەھەرىگە بارىسەن (ئۇ يەردە فىلىستىيلەرنىڭ بىر لەشكەرگاھى بار)؛ سەن شۇ شەھەرگە كەلسەڭ چىلتار، تەمبۇر، نەي ۋە لىرىلارنى كۆتۈرۈپ يۇقىرى جايىدىن چۈشكەن بىر بۆلەك پەيغەمبەرلەر ساڭا ئۇچرايدۇ. ئۇلار بېشارەتلىك سۆزلەرنى قىلىدۇ. \f ◼ \fr 10:5 \ft \bd «خۇداغا ئاتالغان گىبېئاھ شەھەرىگە بارىسەن»\bd* ــ باشقا بىر خىل تەرجىمىسى: «خۇدانىڭ دۆڭىگە بارىسەن». ئىبرانىي تىلىدا: «خۇدانىڭ گىبېئاھى» (گىبېئاھ بىر شەھەر، مەنىسى «دۆڭ»، «ئېدىر»). \bd «لىرىلارنى كۆتۈرۈپ يۇقىرى جايىدىن چۈشكەن بىر بۆلەك پەيغەمبەرلەر»\bd* ــ ياكى «لىرىلارنى كۆتۈرۈپ يۇقىرى جايىدىن چۈشىدىغان بىر بۆلەك پەيغەمبەرلەر».\f*  \x ◘ \xo 10:5 \xt 1تار. 16‏:39؛ چۆل. 11‏:25\x*
\v 6 شۇنىڭ بىلەن پەرۋەردىگارنىڭ روھى سېنىڭ ۋۇجۇدۇڭغا چۈشىدۇ، سەن ئۇلار بىلەن بىرلىكتە بېشارەتلىك سۆزلەرنى قىلىسەن ۋە يېڭى بىر ئادەم بولىسەن.
\v 7 مۇشۇ ئالامەتلەر ساڭا كەلگەندە، قولۇڭدىن نېمە كەلسە شۇنى قىلغىن. چۈنكى خۇدا سەن بىلەن بىللىدۇر.
\v 8 ئاندىن مەندىن ئىلگىرى گىلگالغا چۈشۈپ بارىسەن. مانا، مەن ھەم يېنىڭغا چۈشۈپ كۆيدۈرمە قۇربانلىقلار سۇنۇش ۋە ئىناقلىق قۇربانلىقلىرى قىلىش ئۈچۈن كېلىمەن. مەن يېنىڭغا بېرىپ، نېمە قىلىشىڭ كېرەكلىكىنى ئۇقتۇرمىغۇچە، مېنى يەتتە كۈن ساقلاپ تۇرغىن». \x ◘ \xo 10:8 \xt 1سام. 13‏:8. \x*
\m 
\v 9 ۋە شۇنداق بولدىكى، ئۇ بۇرۇلۇپ سامۇئىلدىن ئايرىلغاندا خۇدا ئۇنىڭغا يېڭى بىر قەلب ئاتا قىلدى؛ ۋە بۇ ئالامەتلەرنىڭ ھەممىسى ئاشۇ كۈنى ئەمەلدە كۆرسىتىلدى.
\m 
\v 10 ئۇلار گىبېئاھغا يېتىپ كەلگەندە مانا، بىر بۆلەك پەيغەمبەرلەر ئۇنىڭغا ئۇچرىدى؛ خۇدانىڭ روھى ئۇنىڭ ۋۇجۇدىغا چۈشتى، بۇنىڭ بىلەن ئۇ ئۇلارنىڭ ئارىسىدا بېشارەت قىلىشقا باشلىدى. \x ◘ \xo 10:10 \xt 1سام. 19‏:19. \x*
\v 11 ئۇنى ئىلگىرى تونۇيدىغانلارنىڭ ھەممىسى ئۇنىڭ پەيغەمبەرلەرنىڭ ئارىسىدا بېشارەت قىلغىنىنى كۆرگەندە ئۇلار بىر-بىرىگە: ــ كىشنىڭ ئوغلىغا نېمە بوپتۇ؟ سائۇلمۇ پەيغەمبەرلەردىن بىرى بولدىمۇ نېمە؟ ــ دېيىشتى.
\v 12 ئەمما يەرلىك بىر ئادەم: ــ بۇلارنىڭ ئاتىلىرى كىملەر؟ ــ دېدى. شۇنىڭ بىلەن: «سائۇلمۇ پەيغەمبەرلەرنىڭ بىرىمىدۇ؟» دەيدىغان گەپ پەيدا بولدى. \f ◼ \fr 10:12 \ft \bd «بۇلارنىڭ \bdit ، يەنى پەيغەمبەرلەرنىڭ\bdit* ئاتىلىرى كىملەر؟»\bd* ــ مۇشۇ سوئال بەلكىم پەيغەمبەر بولۇش ئۈچۈن ئالىيجاناب ياكى ئېسىلزادە ئائىلىسىدە تۇغۇلۇش شەرت ئەمەس، دېگەننى كۆرسىتىدۇ. \bd «سائۇلمۇ پەيغەمبەرلەرنىڭ بىرىمىدۇ؟»\bd* ــ مۇشۇ گەپ بەلكىم (1) مەلۇم بىرسىنىڭ ئۇلۇغ بىر ئىش قىلالايدىغانلىقىغا بولغان گۇماننى بىلدۈرىدۇ؛ (2) ئۇنىڭ ئەكسىچە، سائۇل ئەسلى «ئۇلۇغ ئەرباب» بولمىسىمۇ، ئاددىي ئادەم نېمىشقا ئۇلۇغ ئىشنى قىلالمايدىكەن، دېگەن پىكىرنى بىلدۈرىدۇ. 12-ئايەتتىكى «يەرلىك ئادەم»نىڭ سوئالىغا قارىغاندا، بىز ئىككىنچى پىكىرگە مايىلمىز.\f*  \x ◘ \xo 10:12 \xt گال. 1‏:24؛ 1سام. 19‏:25\x*
\m 
\v 13 ئەمدى سائۇل بېشارەتلىك سۆزلەرنى قىلىپ بولۇپ، يۇقىرى جايغا چىقىپ كەتتى.
\v 14 سائۇلنىڭ تاغىسى ئۇنىڭدىن ۋە ئۇنىڭ خىزمەتكارىدىن: ــ نەگە بېرىپ كەلدىڭلار؟ دەپ سورىدى. ئۇ: ــ ئېشەكلەرنى ئىزدىگىلى چىقتۇق؛ لېكىن ئۇلارنى تاپالماي سامۇئىلنىڭ قېشىغا باردۇق، دېدى.
\m 
\v 15 سائۇلنىڭ تاغىسى: ــ سامۇئىلنىڭ سىلەرگە نېمە دېگىنىنى ماڭا ئېيتىپ بەرگىنە، دېدى.
\m 
\v 16 سائۇل تاغىسىغا: ــ ئۇ جەزم بىلەن بىزگە ئېشەكلەر تېپىلدى، دەپ خەۋەر بەردى، دېدى. لېكىن سامۇئىلنىڭ پادىشاھلىق ئىشى توغرۇلۇق ئېيتقان سۆزىنى ئۇنىڭغا دەپ بەرمىدى.
\b
\s1 سامۇئىل خەلقنى ئاگاھلاندۇرىدۇ
\m 
\v 17 سامۇئىل ئەمدى خەلقنى پەرۋەردىگارنىڭ ئالدىغا جەم بولۇڭلار دەپ، مىزپاھقا چاقىردى.
\v 18 ئۇ ئىسرائىلغا: ــ ئىسرائىلنىڭ خۇداسى پەرۋەردىگار مۇنداق دەيدۇ: ــ «مەن سىلەر ئىسرائىلنى مىسىردىن چىقىرىپ مىسىرلىقلارنىڭ قولىدىن ئازاد قىلىپ، سىلەرگە زۇلۇم قىلغان ھەممە پادىشاھلىقلارنىڭ قولىدىن قۇتقۇزدۇم.
\v 19 لېكىن بۈگۈنكى كۈندە سىلەرنى بېشىڭلارغا چۈشكەن بارلىق بالايىئاپەتلەردىن ۋە بارلىق مۇشەققەتلەردىن قۇتقۇزغۇچى خۇدايىڭلاردىن ۋاز كېچىپ ئۇنىڭغا: «ياق! ئۈستىمىزگە بىر پادىشاھ بېكىتىپ بەرگەيسەن» ــ دېدىڭلار. ئەمدى ئۆزۈڭلارنى قەبىلەڭلار بويىچە، جەمەتىڭلار بويىچە پەرۋەردىگارنىڭ ئالدىغا ھازىر قىلىڭلار» ــ دېدى. \x ◘ \xo 10:19 \xt 1سام. 8‏:7؛ 1سام. 8‏:19؛ 12‏:12. \x*
\m 
\v 20 شۇنىڭ بىلەن سامۇئىل ئىسرائىلنىڭ ھەممە قەبىلىلىرىنى ئالدىغا جەم قىلىپ، چەك تاشلىۋىدى، چەك بىنيامىن قەبىلىسىگە چىقتى. \x ◘ \xo 10:20 \xt يە. 7‏:14\x*
\v 21 ئۇ بىنيامىن قەبىلىسىنى جەمەت-جەمەتلىرى بويىچە ئۆز ئالدىغا كەلتۈرۈپ چەك تاشلىۋىدى، چەك ماترىنىڭ جەمەتىگە چىقتى. ئاندىن كېيىن يەنە چەك تاشلىۋىدى، كىشنىڭ ئوغلى سائۇلغا چىقتى. ئۇلار ئۇنى ئىزدىۋىدى، ئەمما ئۇنى تاپالمىدى.
\m 
\v 22 شۇڭا ئۇلار پەرۋەردىگاردىن يەنە: ــ ئۇ كىشى بۇ يەرگە كېلەمدۇ؟ ــ دەپ سورىدى.
\m پەرۋەردىگار جاۋابەن: ــ مانا، ئۇ يۈك-تاقلارنىڭ ئارىسىغا يوشۇرۇنۇۋالدى، دېدى.
\v 23 شۇڭا ئۇلار يۈگۈرۈپ بېرىپ ئۇنى شۇ يەردىن ئېلىپ كەلدى. ئۇ خەلقنىڭ ئوتتۇرىسىدا تۇرغاندا خالايىقنىڭ بويى ئۇنىڭ مۈرىسىگىمۇ كەلمىدى. \x ◘ \xo 10:23 \xt 1سام. 9‏:2\x*
\m 
\v 24 سامۇئىل بارلىق خەلققە: ــ ئەمدى پەرۋەردىگار تاللىغان كىشىگە قاراڭلار! دەرۋەقە بارلىق خەلقنىڭ ئىچىدە ئۇنىڭغا يېتىدىغان بىرسى يوقتۇر، دېدى. ۋە خەلقنىڭ ھەممىسى: ــ پادىشاھ ياشىسۇن! ــ دەپ توۋلاشتى.
\m 
\v 25 سامۇئىل خەلققە پادىشاھلىق ھوقۇق-قانۇنلىرىنى ئۇقتۇردى ۋە ئۇنى ئورام يازما قىلىپ يېزىپ چىقىپ، پەرۋەردىگارنىڭ ئالدىغا قويدى. ئاندىن سامۇئىل ھەممە خەلقنى، ھەرقايسىسىنى ئۆز ئۆيلىرىگە قايتۇردى.
\v 26 سائۇلمۇ ھەم گىبېئاھدىكى ئۆيىگە قايتتى؛ كۆڭۈللىرى خۇدا تەرىپىدىن تەسىرلەندۈرۈلگەن بىر تۈركۈم باتۇر كىشى ئۇنىڭ بىلەن بىللە باردى. \x ◘ \xo 10:26 \xt 1سام. 13‏:2. \x*
\v 27 لېكىن بىرنەچچە رەزىل كىشى: ــ بۇ كىشى قانداقمۇ بىزنى قۇتقۇزالىسۇن؟ ــ دەپ ئۇنى كەمسىتىپ ئۇنىڭغا ھېچ سوۋغات بەرمىدى؛ ئەمما ئۇ ئاڭلىماسلىققا سالدى. \f ◼ \fr 10:27 \ft \bd «بىرنەچچە رەزىل كىشى»\bd* ــ ئىبرانىي تىلىدا: «بېلىئالنىڭ (شەيتاننىڭ) بىرنەچچە بالىلىرى».\f*  \x ◘ \xo 10:27 \xt 1سام. 11‏:12؛ 2تار. 17‏:5. \x*
\b
\b
\c 11
\s1 سائۇل يابەشتىكىلەرگە ياردەمگە بارىدۇ
\m 
\v 1 شۇ ۋاقىتتا ئاممونىي ناھاش چىقىپ يابەش-گىلېئادنى مۇھاسىرىگە ئالدى. يابەشنىڭ ھەممە ئادەملىرى ناھاشقا: ــ ئەگەر بىز بىلەن ئەھدە تۈزسەڭ، ساڭا بويسۇنىمىز، دېدى. \f ◼ \fr 11:1 \ft \bd «يابەش-گىلېئاد»\bd* ــ دېمەك، گىلېئاد (رايونى)دىكى يابەش.\f*
\m 
\v 2 لېكىن ئاممونىي ناھاش ئۇلارغا: ــ پۈتكۈل ئىسرائىلغا دەشنەم قىلىش ئۈچۈن ھەر بىرىڭلارنىڭ ئوڭ كۆزىنى ئويۇپ ئاندىن سىلەر بىلەن ئەھدە قىلاي، دېدى.
\m 
\v 3 يابەشنىڭ ئاقساقاللىرى ئۇنىڭغا: ــ بىزگە يەتتە كۈن مۆھلەت بەرگىن؛ بىز ئىسرائىلنىڭ پۈتكۈل يۇرتىغا ئەلچىلەرنى ماڭدۇرۇپ ئاندىن كېيىن بىزنى قۇتقۇزىدىغان ئادەم چىقمىسا، ئۆزىمىز چىقىپ ساڭا تەسلىم بولىمىز، دېدى.
\m 
\v 4 ئەمدى ئەلچىلەر سائۇلنىڭ شەھىرى گىبېئاھغا كېلىپ مۇشۇ سۆزلەرنى خەلقنىڭ قۇلىقىغا يەتكۈزدى؛ ھەممە خەلق پەرياد كۆتۈرۈپ يىغلىدى.
\v 5 ۋە مانا، سائۇل ئېتىزلىقىدىن چىقىپ كالىلارنى ھەيدەپ كېلىۋاتاتتى، ئۇ: ــ خەلق نېمە دەپ يىغلايدۇ، دەپ سورىدى. ئۇلار يابەشتىن كەلگەن كىشىلەرنىڭ سۆزلىرىنى ئۇنىڭغا دەپ بەردى.
\v 6 سائۇل بۇ سۆزلەرنى ئاڭلىغاندا خۇدانىڭ روھى ئۇنىڭ ئۈستىگە كېلىپ، ئۇنىڭ غەزىپى قاتتىق قوزغالدى.
\v 7 ئۇ بىر جۈپ ئۇينى چېپىپ پارچىلاپ، پارچىلىرىنى ئەلچىلەرنىڭ قولى ئارقىلىق پۈتكۈل ئىسرائىل زېمىنىغا تارقىتىپ: ــ ھەر كىم كېلىپ سائۇل بىلەن سامۇئىلغا ئەگەشمىسە، ئۇلارنىڭ ئۇيلىرىمۇ مۇشۇنىڭغا ئوخشاش قىلىنىدۇ، دېدى.
\m شۇنىڭ بىلەن پەرۋەردىگارنىڭ قورقۇنچى خەلقنىڭ ئۈستىگە چۈشتى؛ شۇنداق بولدىكى، ئۇلار ئىتتىپاقلىشىپ بىر ئادەمدەك جەڭگە چىقتى. \x ◘ \xo 11:7 \xt ھاك. 20‏:1. \x*
\v 8 سائۇل ئۇلارنى بېزەك \add دېگەن جايدا\add* سانىغاندا ئىسرائىللار ئۈچ يۈز مىڭ، يەھۇدانىڭ ئادەملىرى بولسا ئوتتۇز مىڭ چىقتى.
\v 9 ئۇلار كەلگەن ئەلچىلەرگە: ــ گىلېئادتىكى يابەشنىڭ ئادەملىرىگە شۇنداق ئېيتىڭلاركى، ئەتە كۈن چۈش بولغاندا نىجات سىلەرگە كېلىدۇ، دېدى.
\m ئەلچىلەر بېرىپ شۇنى گىلېئادتىكى يابەشلىقلارغا يەتكۈزدى؛ ئۇلار ئىنتايىن خۇشال بولۇشتى.
\m 
\v 10 شۇنىڭ بىلەن يابەشتىكىلەر: ــ ئەتە بىز قېشىڭلارغا چىقىپ \add تەسلىم بولىمىز\add*، سىلەر بىزنى قانداق قىلىشقا لايىق كۆرسەڭلار، شۇنداق قىلىڭلار، دېدى.
\m 
\v 11 ئەتىسى شۇنداق بولدىكى، سائۇل خەلقنى ئۈچ بۆلەك قىلدى؛ ئۇلار كېچە تۆتىنچى جېسەكتە لەشكەرگاھغا كىرىپ ئاممونىيلارنى كۈن چۈش بولغۇچە ئۇرۇپ قىردى. تىرىك قالغانلار بولسا شۇنداق پاراكەندە بولدىكى، ئۇلاردىن ئىككى ئادەممۇ بىر يەرگە كېلەلمىدى.
\b
\s1 سائۇل پادىشاھ قىلىنىدۇ
\m 
\v 12 خەلق ئەمدى سامۇئىلغا: ــ بىزنىڭ ئۈستىمىزگە سائۇل پادىشاھ بولمىسۇن دەپ ئېيتقانلار كىملەر؟ بۇ كىشىلەرنى كەلتۈرۈپ، ئۇلارنى ئۆلتۈرەيلى، دېدى. \x ◘ \xo 11:12 \xt 1سام. 10‏:27. \x*
\m 
\v 13 لېكىن سائۇل: ــ بۈگۈن ھېچكىم ئۆلتۈرۈلمىسۇن. چۈنكى بۈگۈن پەرۋەردىگار ئىسرائىلغا نۇسرەت بەردى، دېدى.
\m 
\v 14 سامۇئىل خەلققە: ــ قېنى، گىلېئادقا بېرىپ ئۇ يەردە پادىشاھلىقنى يېڭىباشتىن تىكلەيلى، دەپ ئېيتتى.
\m 
\v 15 شۇنى دېۋىدى، ھەممە خەلق گىلېئادقا بېرىپ گىلېئادتا پەرۋەردىگارنىڭ ئالدىدا سائۇلنى پادىشاھ قىلدى؛ ئۇلار ئۇ يەردە پەرۋەردىگارنىڭ ئالدىدا ئىناقلىق قۇربانلىقلىرىنى كەلتۈردى. سائۇل ھەم شۇنىڭدەك بارلىق ئىسرائىل شۇ يەردە زور خۇشاللىققا چۆمدى.
\b
\b
\c 12
\m 
\v 1 سامۇئىل پۈتكۈل ئىسرائىلغا: ــ مانا، مەن سىلەرنىڭ بارلىق ئېيتقان سۆزلىرىڭلارنى ئاڭلاپ ئۈستۈڭلارغا بىر پادىشاھ قويدۇم؛ \f ◼ \fr 12:1 \ft \bd «مەن سىلەرنىڭ بارلىق ئېيتقان سۆزلىرىڭلارنى ئاڭلاپ ئۈستۈڭلارغا بىر پادىشاھ قويدۇم»\bd* ــ ئىبرانىي تىلىدا: «مەن سىلەرنىڭ ئېيتقان سۆزلىرىڭلارنىڭ ھەممىسىدە ئاۋازىڭلارغا قۇلاق سېلىپ بىر پادىشاھ قويدۇم» دېيىلىدۇ.\f*
\v 2 مانا ئەمدى پادىشاھ سىلەرنىڭ ئالدىڭلاردا يۈرمەكتە، مەن بولسام قېرىپ بېشىم ئاقاردى؛ مانا، مېنىڭ ئوغۇللىرىممۇ ئاراڭلاردا تۇرىدۇ. ياشلىقىمدىن تارتىپ بۇ كۈنگىچە سىلەرنىڭ ئالدىڭلاردا مېڭىپ كەلدىم. \f ◼ \fr 12:2 \ft \bd «مانا، مېنىڭ ئوغۇللىرىممۇ ئاراڭلاردا تۇرىدۇ»\bd* ــ سامۇئىلنىڭ دېگىنىنىڭ مەنىسى، شۈبھىسىزكى: «ئۆزۈم قېرى؛ مېنىڭ ئوغۇللىرىم ئۆز گۇناھلىرىغا ئۆزلىرى مەسئۇل ــ سىلەر ئۇلارنى قانداق بىر تەرەپ قىلساڭلار ئۆز ئىختىيارىڭلار. مەن ئۆزۈم سىلەرنىڭ ئالدىڭلاردا گۇناھكار ئەمەسمەن» دېگەندەك.\f*
\m 
\v 3 مانا بۇ يەردە تۇرۇپتىمەن. پەرۋەردىگارنىڭ ئالدىدا ۋە ئۇنىڭ مەسىھ قىلىنغىنىنىڭ ئالدىدا ماڭا ئەرزىڭلار بولسا دەۋېرىڭلار؛ كىمنىڭ ئۇيىنى تارتىۋالدىم؟ كىمنىڭ ئېشىكىنى تارتىۋالدىم؟ كىمنىڭ ھەققىنى يېدىم؟ كىمگە زۇلۇم قىلدىم؟ ياكى مەن كۆزۈمنى كور قىلىش ئۈچۈن كىمدىن پارا ئالدىم؟ شۇنداق بولسا دەڭلار، ۋە مەن ئۇنى سىلەرگە تۆلەپ بېرىمەن، دېدى.
\m 
\v 4 ئۇلار جاۋاب بېرىپ: ــ سەن بىزنىڭ ھەققىمىزنى يېمىدىڭ، ھېچكىمگە زۇلۇم قىلمىدىڭ ۋە ھېچ كىشىنىڭ قولىدىن بىرەر نەرسىنىمۇ ئېلىۋالمىدىڭ، دېدى.
\m 
\v 5 ئۇ ئۇلارغا: ــ مەندە ھېچ ھەققىڭلار قالمىغانلىقىغا پەرۋەردىگار سىلەرگە گۇۋاھ بولۇپ ۋە ئۇنىڭ مەسىھ قىلغىنى ھەم بۈگۈن گۇۋاھچى بولسۇن، دېۋىدى، ئۇلار: ــ ئۇ گۇۋاھتۇر، دېدى.
\m 
\v 6 سامۇئىل خەلققە مۇنداق دېدى: «\add گۇۋاهچى بولسا\add* دەرۋەقە مۇسا بىلەن ھارۇننى تىكلەپ ئاتا-بوۋىلىرىڭلارنى مىسىر زېمىنىدىن چىقارغۇچى پەرۋەردىگاردۇر!
\v 7 ئەمدى ئورنۇڭلاردىن تۇرۇڭلار، مەن پەرۋەردىگارنىڭ ئالدىدا پەرۋەردىگارنىڭ سىلەرگە ۋە ئاتا-بوۋىلىرىڭلارغا يۈرگۈزگەن ھەققانىي ئەمەللىرىنى سىلەرنىڭ ئالدىڭلارغا قويۇشقا سۆز قىلاي.
\m 
\v 8 ياقۇپ مىسىرغا كىرگەندىن كېيىن ئاتا-بوۋىلىرىڭلار پەرۋەردىگارغا پەرياد قىلغاندا، پەرۋەردىگار مۇسا بىلەن ھارۇننى ئەۋەتتى. ئۇلار ئاتا-بوۋىلىرىڭلارنى مىسىردىن چىقىرىپ بۇ يەردە ئولتۇراقلاشتۇردى. \f ◼ \fr 12:8 \ft \bd «ياقۇپ مىسىرغا كىرگەندىن كېيىن...»\bd* ــ «ياقۇپ» مۇشۇ يەردە ياقۇپنىڭ ئەۋلادلىرى، يەنى ئىسرائىلنى كۆرسىتىدۇ.\f*  \x ◘ \xo 12:8 \xt يار. 46‏:5؛ مىس. 2‏:23؛ مىس. 3‏:10. \x*
\v 9 ئەمما ئۇلار ئۆز خۇداسى پەرۋەردىگارنى ئۇنتۇدى؛ شۇڭا ئۇ ئۇلارنى ھازورنىڭ قوشۇنىدىكى سەردار سىسېرانىڭ قولىغا، فىلىستىيلەرنىڭ قولىغا ھەم موئابنىڭ پادىشاھىنىڭ قولىغا تاپشۇرۇپ بەردى؛ بۇلار ئۇلار بىلەن جەڭ قىلىشتى. \x ◘ \xo 12:9 \xt ھاك. 4‏:2؛ ھاك. 10‏:7؛ ھاك. 3‏:12. \x*
\v 10 شۇنىڭ بىلەن ئۇلار پەرۋەردىگارغا پەرياد قىلىپ: «بىز گۇناھ قىلىپ پەرۋەردىگارنى تاشلاپ بائاللار ۋە ئاشتاروتلارنىڭ ئىبادىتىدە بولدۇق؛ ئەمما ئەمدى بىزنى دۈشمەنلىرىمىزنىڭ قولىدىن قۇتقۇزغىن، بىز ساڭا ئىبادەت قىلىمىز» دېدى. \f ◼ \fr 12:10 \ft \bd «پەرۋەردىگارنى تاشلاپ بائاللار ۋە ئاشتاروتلارنىڭ ئىبادىتىدە بولدۇق»\bd* ــ «بائاللار» ۋە «ئاشتاروتلار» ئىككى خىل بۇتلارنى كۆرسىتىدۇ.\f*
\v 11 ۋە پەرۋەردىگار يەرۇببائال، بېدان، يەفتاھ ۋە سامۇئىلنى ئەۋەتىپ، ئەتراپىڭلاردىكى دۈشمەنلىرىڭلارنىڭ قولىدىن سىلەرنى قۇتقۇزدى، شۇنىڭ بىلەن تىنچ-ئامان تۇرۇۋاتقانىدىڭلار. \f ◼ \fr 12:11 \ft \bd «پەرۋەردىگار يەرۇببائال، بېدان، يەفتاھ ۋە سامۇئىلنى ئەۋەتىپ...»\bd* ــ «بېدان» بەلكىم باراكنى كۆرسىتىدۇ («ھاك.» 4-بابنى كۆرۈڭ).\f*  \x ◘ \xo 12:11 \xt ھاك. 6‏:14؛ 10‏:3؛ 11‏:15. \x*
\m 
\v 12 لېكىن خۇدايىڭلار پەرۋەردىگار ئۆزى پادىشاھىڭلار بولسىمۇ، ئامموننىڭ پادىشاھى ناھاشنىڭ سىلەرگە قارشى قوپقىنىنى كۆرگىنىڭلاردا سىلەر: ياق! بىر پادىشاھ ئۈستىمىزگە سەلتەنەت قىلسۇن دەپ ماڭا ئېيتتىڭلار. \x ◘ \xo 12:12 \xt 1سام. 8‏:5، 19. \x*
\v 13 ئەمدى سىلەر خالاپ تاللىغان، سىلەر تىلىگەن پادىشاھقا قاراڭلار؛ مانا، پەرۋەردىگار سىلەرنىڭ ئۈستۈڭلارغا بىر پادىشاھ قويدى. \x ◘ \xo 12:13 \xt 1سام. 10‏:19\x*
\m 
\v 14 ئەگەر سىلەر پەرۋەردىگاردىن قورقۇپ، ئۇنىڭ قۇللۇقىدا بولۇپ، ئۇنىڭ ئاۋازىغا قۇلاقلىرىڭلارنى سېلىپ، ئۇنىڭ ئەمرىگە ئاسىيلىق قىلمىساڭلار، سىلەر ھەم ئۈستۈڭلاردا سەلتەنەت قىلغان پادىشاھ خۇدايىڭلار پەرۋەردىگارغا ئەگەشسەڭلار، ئەمدى سىلەرگە ياخشى بولىدۇ. \x ◘ \xo 12:14 \xt قان. 1‏:26. \x*
\v 15 لېكىن پەرۋەردىگارنىڭ سۆزىگە قۇلاق سالماي، بەلكى پەرۋەردىگارنىڭ ئەمرىگە ئاسىيلىق قىلساڭلار، پەرۋەردىگارنىڭ قولى ئاتا-بوۋىلىرىڭلارغا قارشى بولغاندەك سىلەرگىمۇ قارشى بولىدۇ.
\m 
\v 16 ئەمدى تۇرۇڭلار، پەرۋەردىگار كۆزلىرىڭلارنىڭ ئالدىدا قىلىدىغان ئۇلۇغ كارامەتنى كۆرۈڭلار!
\v 17 بۈگۈن بۇغداي ئورىدىغان ۋاقىت ئەمەسمۇ؟ مەن پەرۋەردىگارغا نىدا قىلاي، ئۇ گۈلدۈرماما بىلەن يامغۇر ياغدۇرىدۇ. شۇنىڭ بىلەن سىلەرنىڭ بىر پادىشاھ تىلىگىنىڭلارنىڭ پەرۋەردىگارنىڭ نەزىرىدە زور رەزىللىك ئىكەنلىكىنى كۆرۈپ يېتىسىلەر».
\m 
\v 18 ئاندىن سامۇئىل پەرۋەردىگارغا نىدا قىلدى؛ شۇنىڭ بىلەن پەرۋەردىگار شۇ كۈنى گۈلدۈرماما بىلەن يامغۇر ياغدۇردى. خەلق پەرۋەردىگاردىن ۋە سامۇئىلدىن بەك قورقتى.
\v 19 خەلقنىڭ ھەممىسى سامۇئىلغا: ــ خۇدايىڭ پەرۋەردىگارغا بىزنى ئۆلمىسۇن دەپ كەمىنىلىرىڭ ئۈچۈن دۇئا قىلغىن؛ چۈنكى ھەممە گۇناھلىرىمىزنىڭ ئۈستىگە يەنە يامانلىق ئاشۇرۇپ ئۆزىمىزگە بىر پادىشاھ تىلىدۇق، دېدى.
\m 
\v 20 سامۇئىل خەلققە مۇنداق دېدى: ــ قورقماڭلار؛ سىلەر دەرۋەقە بۇ ھەممە رەزىللىكنى قىلغانسىلەر، لېكىن ئەمدى پەرۋەردىگارغا ئەگىشىشتىن چەتنىمەي، پۈتكۈل كۆڭۈللىرىڭلار بىلەن پەرۋەردىگارنىڭ ئىبادىتىدە بولۇڭلار؛
\v 21 ئادەمگە پايدا يەتكۈزمەيدىغان ياكى ئادەمنى قۇتقۇزالمايدىغان بىھۇدە ئىشلارنى ئىزدەپ، يولدىن ئېزىپ كەتمەڭلار؛ چۈنكى ئۇلارنىڭ تايىنى يوقتۇر.
\v 22 چۈنكى پەرۋەردىگار ئۆز ئۇلۇغ نامى ئۈچۈن ئۆز خەلقىنى تاشلىمايدۇ؛ چۈنكى پەرۋەردىگار سىلەرنى ئۆز خەلقى قىلىشنى لايىق كۆرگەندۇر.
\m 
\v 23 ماڭا نىسبەتەن، سىلەر ئۈچۈن دۇئا قىلىشتىن توختاش بىلەن پەرۋەردىگارغا گۇناھ قىلىش مەندىن نېرى بولسۇن؛ بەلكى مەن سىلەرگە ياخشى ۋە دۇرۇس يولنى ئۆگىتىمەن.
\v 24 پەقەت سىلەر پەرۋەردىگاردىن قورقۇپ پۈتكۈل كۆڭۈللىرىڭلار ۋە ھەقىقەت بىلەن ئۇنىڭ ئىبادىتىدە بولۇڭلار؛ چۈنكى سىلەر ئۈچۈن قىلغان ئۇلۇغ كارامەتلەرگە قاراڭلار!
\m 
\v 25 لېكىن يامانلىق قىلساڭلار، ھەم ئۆزۈڭلار ھەم پادىشاھىڭلار ھالاك قىلىنىسىلەر».
\b
\b
\c 13
\s1 سائۇل پەرۋەردىگارنىڭ سۆزلىرىدىن چىقىپ كېتىدۇ
\m 
\v 1 سائۇل \add ئوتتۇز\add* ياشتا پادىشاھ بولۇپ ئىسرائىلنىڭ ئۈستىدە ئىككى يىل سەلتەنەت قىلغاندىن كېيىن \f ◼ \fr 13:1 \ft \bd «سائۇل ئوتتۇز ياشتا پادىشاھ بولۇپ ئىسرائىلنىڭ ئۈستىدە ئىككى يىل سەلتەنەت قىلغاندىن كېيىن...»\bd* ــ قەدىمكى كۆچۈرمىلەردە بۇ ئايەت باشقا شەكىللەردە كۆرۈلىدۇ. «سائۇل \bd ئوتتۇز\bd* ياشتا...» دېگەن سۆز تەۋراتنىڭ گرېكچە تەرجىمىسى (LXX)دە كۆرۈلىدۇ. سائۇل جەمئىي قىرىق يىل سەلتەنەت قىلدى («روس.» 21:13).\f*
\v 2 ئۆزىگە ئىسرائىلدىن ئۈچ مىڭ ئادەمنى ئىلغاپ ئالدى. ئىككى مىڭى مىكماشتا ۋە بەيت-ئەل تاغلىرىدا سائۇلنىڭ قېشىدا، بىر مىڭى بىنيامىن زېمىنىدىكى گىبېئاھدا يوناتاننىڭ قېشىدا ئىدى. ئەمما ئۇ قالغان خەلقنىڭ ھەربىرىنى ئۆز ئۆيلىرىگە كەتكۈزۈۋەتتى.
\m 
\v 3 يوناتان بولسا فىلىستىيلەرنىڭ گېبادىكى لەشكەرگاھىغا ھۇجۇم قىلدى، فىلىستىيلەر بۇنىڭدىن خەۋەر تاپتى. سائۇل بولسا: ــ پۈتكۈل زېمىندىكى ئىبرانىيلار ئاڭلاپ ئويغانسۇن دەپ، كاناي چالدۇردى.
\v 4 پۈتكۈل ئىسرائىل سائۇلنىڭ فىلىستىيلەرنىڭ لەشكەرگاھىغا ھۇجۇم قىلغانلىقىدىن ھەمدە ئىسرائىلنىڭ فىلىستىيلەرگە نەپرەتلىنىدىغانلىكىدىن خەۋەر تاپتى. خەلق سائۇلنىڭ كەينىدىن گىلگالغا بېرىپ يىغىلدى.
\m 
\v 5 فىلىستىيلەردىن ئىسرائىل بىلەن جەڭ قىلغىلى ئۈچ مىڭ جەڭ ھارۋىسى، ئالتە مىڭ ئاتلىق لەشكەر ۋە دېڭىز ساھىلىدىكى قۇمدەك كۆپ پىيادە لەشكەر يىغىلدى. ئۇلار كېلىپ بەيت-ئاۋەننىڭ شەرق تەرىپىدىكى مىكماشتا بارگاھ تىكتى. \f ◼ \fr 13:5 \ft \bd «فىلىستىيلەردىن ئىسرائىل بىلەن جەڭ قىلغىلى ئۈچ مىڭ جەڭ ھارۋىسى، ... يىغىلدى»\bd* ــ كۆپ كونا كۆچۈرۈلمىلەردە: «فىلىستىيلەردىن ئىسرائىل بىلەن جەڭ قىلغىلى ئوتتۇز مىڭ جەڭ ھارۋىسى... يىغىلدى» دېيىلىدۇ. لېكىن بۇنداق كۆپ بولۇشى مۇمكىن ئەمەس. ھېچ بولمىغاندا مۇشۇ «جەڭ ھارۋىلىرى» ئىچىدە يۈك-تاقلارنى ئېلىپ ماڭغان ھارۋىلارمۇ بار ئىدى. \bd «بەيت-ئاۋەن»\bd* ــ يەنى «بەيت-ئەل».\f*
\m 
\v 6 ئىسرائىلنىڭ ئادەملىرى ئۆزلىرىنىڭ قاتتىق خىيىم-خەتەردە قالغانلىقىنى كۆرۈپ غارلارغا، چاتقاللىقلارغا، قىيا تاشلىقلارغا، يۇقىرى جايلارغا ۋە ئازگاللارغا يوشۇرۇنۇۋېلىشتى؛ \f ◼ \fr 13:6 \ft \bd «ئىسرائىلنىڭ ئادەملىرى ئۆزلىرىنىڭ قاتتىق خىيىم-خەتەردە قالغانلىقى»\bd* ــ «ئۆزلىرىنىڭ قاتتىق خىيىم-خەتەردە قالغانلىقى» بەلكىم قوشۇنىنىڭ ئەھۋالىنى كۆرسىتىشى مۇمكىن.\f*
\v 7 \add بەزى\add* ئىبرانىيلار ئىئوردان دەرياسىدىن ئۆتۈپ، گاد ۋە گىلېئادنىڭ زېمىنىغا قېچىپ باردى. لېكىن سائۇل گىلگالدا قالدى، ئادەملىرىنىڭ ھەممىسى ئۇنىڭغا تىترىگەن ھالدا ئەگەشتى.
\m 
\v 8 ئەمدى سائۇل سامۇئىل ئۇنىڭغا بېكىتكەن ۋاقىتقىچە يەتتە كۈن كۈتۈپ تۇردى؛ لېكىن سامۇئىل گىلگالغا كەلمىدى، خەلق ئۇنىڭدىن تارىلىپ كەتكىلى تۇردى.
\v 9 سائۇل: ــ كۆيدۈرمە قۇربانلىق بىلەن ئىناقلىق قۇربانلىقلىرىنى بۇ يەرگە ــ يېنىمغا ئېلىپ كېلىڭلار، دېدى. ئاندىن ئۇ ئۆزى كۆيدۈرمە قۇربانلىق ئۆتكۈزدى.
\v 10 ۋە شۇنداق بولدىكى، ئۇ كۆيدۈرمە قۇربانلىقنى تۈگىتىشى بىلەنلا، مانا سامۇئىل كەلدى. سائۇل ئۇنىڭغا سالام قىلغىلى ئالدىغا چىقتى.
\m 
\v 11 لېكىن سامۇئىل: ــ نېمە ئىشلارنى قىلدىڭ؟! ــ دەپ سورىدى. سائۇل: ــ خەلق مەندىن تارىلىپ كەتكەنلىكىنى، سىلىنىڭ بېكىتكەن ۋاقىتتا كەلمىگەنلىكلىرىنى، فىلىستىيلەرنىڭ مىكماشتا يىغىلغىنىنى كۆردۇم،
\v 12 مەن ئىچىمدە: ئەمدى فىلىستىيلەر گىلگالغا چۈشۈپ ماڭا ھۇجۇم قىلماقچى، مەن بولسام تېخى پەرۋەردىگارغا ئىلتىجا قىلمىدىم، دېدىم. شۇڭا كۆيدۈرمە قۇربانلىق قىلىشقا ئۆزۈمنى مەجبۇرلىدىم، دېدى.
\m 
\v 13 سامۇئىل سائۇلغا: ــ سەن ئەخمەقلىق قىلدىڭ؛ سەن خۇدايىڭ پەرۋەردىگار ساڭا بۇيرۇغان ئەمرنى تۇتمىدىڭ؛ شۇنداق قىلغان بولساڭ پەرۋەردىگار ئىسرائىلنىڭ ئۈستىدىكى سەلتەنىتىڭنى مەڭگۈ مۇستەھكەم قىلاتتى، دېدى.
\v 14 لېكىن ئەمدى سەلتەنىتىڭ مۇستەھكەم تۇرمايدۇ. پەرۋەردىگار ئۆز كۆڭلىدىكىدەك مۇۋاپىق بىر ئادەمنى ئىزدەپ تاپتى. پەرۋەردىگار ئۇنى ئۆز خەلقىنىڭ باشلامچىسى قىلدى، چۈنكى سەن پەرۋەردىگار ساڭا بۇيرۇغاننى تۇتمىدىڭ، دېدى.
\m 
\v 15 ئاندىن سامۇئىل ئورنىدىن تۇرۇپ گىلگالدىن كېتىپ بىنيامىن زېمىنىدىكى گىبېئاھغا باردى. سائۇل بولسا ئۆز يېنىدىكى ئادەملەرنى سانىدى؛ ئۇلار ئالتە يۈزچە چىقتى.
\v 16 سائۇل بىلەن ئوغلى يوناتان ۋە ئۇلارنىڭ قېشىدا قالغان خەلق بىنيامىن زېمىنىدىكى گېبادا قېلىپ قالدى، فىلىستىيلەر بولسا مىكماشتا بارگاھ تىككەنىدى.
\m 
\v 17 قاراقچىلار دائىم فىلىستىيلەرنىڭ بارگاھىدىن چىقىپ ئۈچ بۆلەككە بۆلۈنەتتى. بىر بۆلەك شۇئال زېمىنىدىكى ئوفراھغا بارىدىغان يولغا ئاتلىناتتى،
\v 18 بىر بۆلەك بەيت-ھورونغا بارىدىغان يول بىلەن ماڭاتتى، يەنە بىر بۆلەك چۆلنىڭ چېتىدىكى زەبوئىم جىلغىسىغا قارايدىغان زېمىندىكى يولغا ماڭاتتى.
\m 
\v 19 ئەمما پۈتكۈل ئىسرائىل زېمىنىدا ھېچبىر تۆمۈرچى تېپىلمايتتى؛ چۈنكى فىلىستىيلەر: ــ ئىبرانىيلار ئۆزلىرىگە قىلىچ ياكى نەيزە ياسىيالمىسۇن، دەپ ئويلايتتى. \x ◘ \xo 13:19 \xt ھاك. 5‏:8. \x*
\v 20 بۇ سەۋەبتىن ئىسرائىللار ھەممىسى ساپان چىشلىرى، كەتمەنلىرىنى، پالتىلىرىنى ۋە ئورغاقلىرىنى بىسلاش ئۈچۈن فىلىستىيلەرنىڭ قېشىغا باراتتى.
\v 21 ئۇلار ساپان چىشلىرى ۋە كەتمەنلەر ئۈچۈن ئۈچتىن ئىككى شەكەل، جوتۇ، پالتا ۋە زىخلارنى بىسلاش ئۈچۈن ئۈچتىن بىر شەكەلنى تۆلەيتتى.
\v 22 شۇڭا ئۇرۇش بولغاندا سائۇل ۋە يوناتاننىڭ قېشىدىكى خەلقنىڭ ھېچبىرىدە قىلىچ يا نەيزە يوق ئىدى؛ پەقەت سائۇل بىلەن ئوغلى يوناتاندىلا بار ئىدى.
\b
\s1 يوناتان يالغۇز جەڭگە چىقىدۇ
\m 
\v 23 ئۇ ۋاقىتتا فىلىستىيلەرنىڭ بىر قاراۋۇللار ئەترىتى مىكماشتىكى داۋانغا چىققانىدى.
\b
\b
\c 14
\m 
\v 1 بىر كۈنى سائۇلنىڭ ئوغلى يوناتان ياراغ كۆتۈرگۈچىسىگە: ــ كەلگىن، ئۇدۇلىمىزدىكى فىلىستىيلەرنىڭ قاراۋۇللار ئەترىتىنىڭ يېنىغا چىقايلى، دېدى. ئەمما ئۇ ئاتىسىغا ھېچنېمە دېمىدى. \f ◼ \fr 14:1 \ft \bd «ياراغ كۆتۈرگۈچى»\bd* ــ بۇ ئىبارىنىڭ باشقا بىرخىل تەرجىمىسى «ساۋۇت-قالقان كۆتۈرگۈچى».\f*
\v 2 سائۇل بولسا گىبېئاھنىڭ چېتىدىكى مىگروندىكى ئانار دەرىخىنىڭ تېگىدە قالدى. ئۇنىڭ قېشىدىكى خەلق ئالتە يۈزچە ئىدى \x ◘ \xo 14:2 \xt 1سام. 13‏:15\x*
\v 3 (ئۇ ۋاقىتتا ئەفودنى ئاخىتۇبنىڭ ئوغلى، ئىخابودنىڭ ئاكىسى ئاخىياھ كىيەتتى؛ ئۇ شىلوھدا تۇرۇۋاتقان، پەرۋەردىگارنىڭ كاھىنى ئىدى. ئاخىتۇب فىنىھاسنىڭ ئوغلى، فىنىھاس ئەلىنىڭ ئوغلى ئىدى). خەلق بولسا يوناتاننىڭ كەتكىنلىكىنى بىلمىگەنىدى. \f ◼ \fr 14:3 \ft \bd «ئۇ ۋاقىتتا ئەفودنى ئاخىتۇبنىڭ ئوغلى، ئىخابودنىڭ ئاكىسى ئاخىياھ كىيەتتى»\bd* ــ «ئەفود»نىڭ نېمە ئىكەنلىكىنى چۈشىنىش ئۈچۈن «مىس.» 28-بابنى ۋە ئىزاھاتلىرىنى كۆرۈڭ. بەزى ۋاقىتلاردا ئۇنىڭ ئارقىلىق پەرۋەردىگارنىڭ ئىرادىسىنى ياكى ھۆكۈملىرىنى پەرق ئەتكىلى بولاتتى. ئادەتتە پەقەت «باش كاھىن» ئەفودنى كىيەتتى.\f*
\m 
\v 4 يوناتان فىلىستىيلەرنىڭ قاراۋۇللار ئەترىتى تەرەپكە ئۆتمەكچى بولغان داۋاننىڭ ئىككى تەرىپىدە تۈۋرۈكتەك تىك قىيا تاشلار بار ئىدى. بىرىنىڭ نامى بوزەز، يەنە بىرىنىڭ نامى سەنەھ ئىدى.
\v 5 بىر قىيا تاش شىمالىي تەرىپىدە بولۇپ، مىخماش بىلەن قارىشىپ تۇراتتى، يەنە بىرى جەبۇب تەرىپىدە گېبانىڭ ئۇدۇلىدا ئىدى.
\v 6 يوناتان ياراغ كۆتۈرگۈچىسىگە: ــ كەل، بۇ خەتنىسىزلەرنىڭ قاراۋۇللار ئەترىتىگە چىقايلى؛ پەرۋەردىگار بىز ئۈچۈن بىر ئىش قىلسا ئەجەب ئەمەس، چۈنكى پەرۋەردىگارنىڭ قۇتقۇزۇشى ئۈچۈن ئادەملەرنىڭ كۆپ ياكى ئاز بولۇشى ھېچ توسالغۇ بولمايدۇ، دېدى.
\m 
\v 7 ئۇنىڭ ياراغ كۆتۈرگۈچىسى ئۇنىڭغا: ــ كۆڭلۈڭدە ھەر نېمە بولسا شۇنى قىلغىن؛ بارغىن، مانا، كۆڭلۈڭ نېمىنى خالىسا مەن سەن بىلەن بىللىمەن، دېدى.
\m 
\v 8 يوناتان: ــ مانا، بىز ئۇ ئادەملەر تەرەپكە چىقىپ ئۆزىمىزنى ئۇلارغا كۆرسىتەيلى؛
\v 9 ئەگەر ئۇلار بىزگە: ــ بىز سىلەرنىڭ قېشىڭلارغا بارغۇچە تۇرۇپ تۇرۇڭلار، دېسە ئۇلارنىڭ قېشىغا چىقماي ئۆز جايىمىزدا تۇرۇپ تۇرايلى؛
\v 10 لېكىن ئۇلار: ــ بىزنىڭ قېشىمىزغا چىقىڭلار، دېسە، چىقايلى. چۈنكى شۇنداق بولسا پەرۋەردىگار ئۇلارنى قولىمىزغا بېرىپتۇ، دەپ بىلىمىز؛ مۇشۇنداق ئىش بىزگە بىر بېشارەت بولىدۇ، دېدى.
\m 
\v 11 ئىككىيلەن ئۆزىنى فىلىستىيلەرنىڭ قاراۋۇللار ئەترىتىگە كۆرسەتتى. فىلىستىيلەر: ــ مانا، ئىبرانىيلار ئۆزىنى يوشۇرغان ئازگاللاردىن چىقىۋاتىدۇ، دېدى.
\v 12 ئەترەتتىكىلەر يوناتان بىلەن ياراغ كۆتۈرگۈچىسىگە: ــ بىزگە چىقىڭلار، بىز سىلەرگە بىر نەرسىنى كۆرسىتىپ قويىمىز، دېدى. يوناتان ياراغ كۆتۈرگۈچىسىگە: ــ ماڭا ئەگىشىپ چىققىن؛ چۈنكى پەرۋەردىگار ئۇلارنى ئىسرائىلنىڭ قولىغا بەردى، دېدى.
\v 13 يوناتان قول-پۇتلىرى بىلەن ئۆمىلەپ چىقتى، ياراغ كۆتۈرگۈچىسى كەينىدىن ئۇنىڭغا ئەگەشتى. فىلىستىيلەر يوناتاننىڭ ئالدىدا يىقىلىشتى؛ ياراغ كۆتۈرگۈچىسى كەينىدىن كېلىپ ئۇلارنى قەتل قىلدى.
\m 
\v 14 شۇ تۇنجى ھۇجۇمدا يوناتان بىلەن ياراغ كۆتۈرگۈچىسى تەخمىنەن يېرىم قوشلۇق يەردە ئۆلتۈرگەنلەر يىگىرمىدەك ئادەم ئىدى. \f ◼ \fr 14:14 \ft \bd «يېرىم قوشلۇق يەر»\bd* ــ «بىر قوشلۇق يەر» كالا بىلەن بىر كۈن ئىچىدە ھەيدەپ بولغىلى بولىدىغان يەر.\f*
\v 15 ئاندىن لەشكەرگاھدىكىكەرنى، دالادا تۇرۇۋاتقانلارنى، بارلىق ئەترەتلەردىكىلەرنى ۋە بۇلاڭ-تالاڭ قىلغۇچىلارنى تىترەك باستى. ئۇلار ھەم تىترەپ قورقتى، يەرمۇ تەۋرىنىپ كەتتى؛ چۈنكى بۇ چوڭ قورقۇنچ خۇدا تەرىپىدىن كەلگەنىدى.
\m 
\v 16 ئەمدى بىنيامىن زېمىنىدىكى گىبېئاھدا تۇرۇۋاتقان پايلاقچىلار كۆردىكى، مانا، لەشكەر توپلىرى تارمار بولۇپ ئۇيان-بۇيان يۈگۈرۈشۈپ كەتتى.
\v 17 سائۇل قېشىدىكى خەلققە: ئادەملىرىمىزنى ساناپ كىمنىڭ بۇ يەردىن كەتكەنلىكىنى ئېنىقلاڭلار، دېدى. ئۇلار سانىۋىدى، مانا، يوناتان بىلەن ياراغ كۆتۈرگۈچىسى يوق چىقتى.
\v 18 سائۇل ئاخىياھقا: ــ خۇدانىڭ ئەھدە ساندۇقىنى ئېلىپ كەلگىن، دېدى. چۈنكى ئۇ ۋاقىتتا خۇدانىڭ ئەھدە ساندۇقى ئىسرائىلنىڭ ئارىسىدا ئىدى. \f ◼ \fr 14:18 \ft \bd «خۇدانىڭ ئەھدە ساندۇقىنى ئېلىپ كەلگىن»\bd* ــ بەزى كونا كۆچۈرمىلەردە: «ئەفودنى ئېلىپ كەلگىن» دېيىلىدۇ.\f*
\m 
\v 19 سائۇل كاھىنغا سۆز قىلىۋاتقاندا فىلىستىيلەرنىڭ لەشكەرگاھىدا بولغان غەلۋە بارغانسېرى كۈچىيىپ كەتتى. سائۇل كاھىنغا: ــ قولۇڭنى يىغقىن، دېدى. \f ◼ \fr 14:19 \ft \bd «سائۇل كاھىنغا: ــ قولۇڭنى يىغقىن، دېدى»\bd* ــ شۈبھىسىزكى، سائۇل كاھىندىن ئەفودتىكى «ئۇرىم ۋە تۇممىم» («مىس.» 30:28، «لاۋ.» 8:8، «چۆل.» 21:27) ئارقىلىق خۇدادىن يوليورۇق سورىماقچى ئىدى. لېكىن كېيىنكى خەۋەرگە قارىغاندا، سائۇل نېمە يوليورۇقن كۈتمەي دەرھال دۈشمەنلەرنى خوعلىغىلى تۇردىى.\f*
\v 20 ئاندىن سائۇل ۋە ئۇنىڭ بىلەن بولغان ھەممە خەلق يىغىلىپ جەڭگە چىقتى؛ ۋە مانا، فىلىستىيلەرنىڭ ھەربىرى ئۆز سەپدىشىغا قارشى قىلىچ كۆتۈرۈپ زور پاراكەندىلىك بولدى. \f ◼ \fr 14:20 \ft \bd «يىغىلىپ جەڭگە چىقتى»\bd* ــ ياكى «جار سېلىشىپ جەڭگە چىقتى».\f*
\m 
\v 21 ئۇ ۋاقىتتىن ئىلگىرى فىلىستىيلەرنىڭ ئارىسىدا بولغان، ئۇلار بىلەن بىللە لەشكەرگاھنىڭ ئەتراپىغا چىققان ئىبرانىيلار بار ئىدى؛ ئۇلارمۇ سائۇل ۋە يوناتان بىلەن بىللە بولغان ئىسرائىللارغا قوشۇلدى.
\v 22 شۇنىڭدەك ئەفرائىم تاغلىرىدا ئۆزىنى يوشۇرغان ئىسرائىللار فىلىستىيلەرنىڭ قاچقىنىنى ئاڭلىغاندا سوقۇشقا چىقىپ ئۇلارنى قوغلىدى.
\v 23 شۇنىڭ بىلەن پەرۋەردىگار ئۇ كۈنى ئىسرائىلغا نۇسرەت بەردى. سوقۇش بەيت-ئاۋەننىڭ ئۇ تەرىپىگە ئۆتتى.
\m 
\v 24 لېكىن ئىسرائىلنىڭ ئادەملىرى ئۇ كۈنى زور بېسىم ئاستىدا قالدى. چۈنكى سائۇل ئۇلارغا قەسەم ئىچكۈزۈپ: ــ مەن دۈشمەنلىرىمدىن ئىنتىقام ئالمىغۇچە كەچ بولۇشتىن ئىلگىرى تائام يېگەن كىشىگە لەنەت بولسۇن، دەپ ئېيتقانىدى. شۇنىڭ ئۈچۈن خەلقتىن ھېچكىم تائام يېمىدى.
\v 25 ئەمما بارلىق زېمىندىكى قوشۇن بىر ئورمانلىققا كىرگەندە يەر يۈزىدە ھەسەل بار ئىدى.
\v 26 خەلق ئورمانلىققا كىرگەندە، مانا بۇ ھەسەل ئېقىپ تۇراتتى؛ لېكىن ھېچكىم قولىنى ئاغزىغا كۆتۈرمىدى، چۈنكى خەلق قەسەمدىن قورقاتتى.
\m 
\v 27 لېكىن يوناتان ئاتىسىنىڭ خەلققە قەسەم ئىچكۈزگەنلىكىنى ئاڭلىمىغانىدى. شۇڭا ئۇ قولىدىكى ھاسىنى سۇنۇپ ئۇچىنى ھەسەل كۆنىكىگە تىقىپ قولى بىلەن ئاغزىغا سالدى. شۇنداق قىلىپ كۆزلىرى نۇرلاندى.
\v 28 ئەمما خەلقتىن بىرى: سېنىڭ ئاتاڭ خەلققە چىڭ قەسەم ئىچكۈزۈپ: ــ بۈگۈن تائام يېگەن كىشىگە لەنەت بولسۇن! دەپ ئېيتقانىدى. شۇنىڭ ئۈچۈن خەلق ھالسىزلىنىپ كەتتى، دېدى.
\m 
\v 29 يوناتان: ــ مېنىڭ ئاتام زېمىنغا ئازار بەردى؛ قاراڭلار، بۇ ھەسەلدىن كىچىككىنە تېتىشىم بىلەنلا كۆزلىرىمنىڭ شۇنچە نۇرلانغىنىنى كۆرمىدىڭلارمۇ؟
\v 30 خەلق بۈگۈن دۈشمەنلەردىن تارتىۋالغان ئولجىدىن خالىغىنىنى يېگەن بولسا فىلىستىيلەرنىڭ ئارىسىدىكى قىرغىنچىلىق تېخىمۇ زور بولماسمىدى؟ ــ دېدى.
\m 
\v 31 ئاشۇ كۈنى ئۇلار مىكماشتىن تارتىپ فىلىستىيلەرنى قوغلاپ ئايجالونغىچە ئۇرۇپ قىرىشتى؛ خەلق تولا ھېرىپ كەتكەنىدى.
\v 32 شۇنىڭ بىلەن خەلق ئولجا ئۈستىگە ئېتىلىپ بېرىپ، قوي، كالا ۋە موزايلارنى تۇتۇپ شۇ يەردىلا سويدى. ئاندىن خەلق گۆشنى قاننى ئادالىۋەتمەيلا يېدى. \f ◼ \fr 14:32 \ft \bd «شۇنىڭ بىلەن خەلق ئولجا ئۈستىگە ئېتىلىپ بېرىپ، قوي، كالا ۋە موزايلارنى تۇتۇپ شۇ يەردىلا سويدى. ئاندىن خەلق گۆشنى قاننى ئادالىۋەتمەيلا يېدى»\bd* ــ مۇسا پەيغەمبەرگە چۈشۈرۈلگەن قانۇن بويىچە، قاننى ئاۋۋال ئادالىۋەتمەي گۆشنى يېيىش گۇناھ بولاتتى.\f*
\m 
\v 33 سائۇلغا خەۋەر كېلىپ: مانا، خەلق قاننى ئادالىۋەتمەيلا گۆشنى يەپ پەرۋەردىگارغا گۇناھ قىلىۋاتىدۇ، دەپ ئېيتىلدى. ئۇ: سىلەر پەرۋەردىگارغا ئاسىيلىق قىلدىڭلار! ئەمدى بۇ يەرگە يېنىمغا چوڭ بىر تاشنى دومىلىتىپ كېلىڭلار، دېدى.
\v 34 سائۇل يەنە: سىلەر خەلقنىڭ ئارىسىغا چىقىپ ئۇلارغا: ھەربىرى ئۆز كالىسىنى، ئۆز قويىنى قېشىمغا ئېلىپ كېلىپ بۇ يەردە سويۇپ يېسۇن؛ لېكىن گۆشنى قاننى ئادالىۋەتمەي يەپ، پەرۋەردىگارغا گۇناھ قىلماڭلار، دەڭلار، دېدى. بۇ كېچە خەلقنىڭ ھەممىسى ھەربىرى ئۆز كالىسىنى ئېلىپ كېلىپ ئۇ يەردە سويدى.
\v 35 سائۇل بولسا پەرۋەردىگارغا بىر قۇربانگاھ ياسىدى. بۇ ئۇنىڭ پەرۋەردىگارغا ياسىغان تۇنجى قۇربانگاھى ئىدى.
\m 
\v 36 سائۇل: ــ بۇ كېچىدە فىلىستىيلەرنىڭ پېيىگە چۈشۈپ، ئەتە تاڭ ئاتقۇچە ئۇلارنى تالاپ ھېچ بىرىنى تىرىك قويمايلى، دېدى. خەلق: ــ نېمە ساڭا ياخشى كۆرۈنسە شۇنى قىلغىن، دەپ جاۋاب بەردى. لېكىن كاھىن سۆز قىلىپ: ــ پەرۋەردىگارنىڭ يېنىغا كىرىپ \add يوليورۇق سوراپ\add* چىقايلى، دېدى.
\v 37 سائۇل خۇدادىن: ــ يا فىلىستىيلەرنىڭ كەينىدىن چۈشەيمۇ؟ سەن ئۇلارنى ئىسرائىلنىڭ قولىغا تاپشۇرامسەن؟ ــ دەپ سورىدى. لېكىن ئۇ كۈنى ئۇ ئۇنىڭغا ھېچ جاۋاب بەرمىدى.
\v 38 سائۇل: ــ ئى خەلقنىڭ ھەممە چوڭلىرى، بۇ يەرگە چىقىڭلار. بۈگۈن كىم گۇناھ قىلغانلىقىنى ئېنىقلاپ بېقىڭلار. \f ◼ \fr 14:38 \ft \bd «سائۇل: ــ ئى خەلقنىڭ ھەممە چوڭلىرى، بۇ يەرگە چىقىڭلار. بۈگۈن كىم گۇناھ قىلغانلىقىنى ئېنىقلاپ بېقىڭلار»\bd* ــ خۇدا ئۆزىگە جاۋاب بەرمىگەچكە، سائۇل ئارىمىزدا گۇناھ بار، دەپ بىلدى.\f*  \x ◘ \xo 14:38 \xt ھاك. 20‏:2\x*
\v 39 چۈنكى ئىسرائىلغا نۇسرەت بەرگەن پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، بۇ گۇناھ ھەتتا ئوغلۇم يوناتاندا تېپىلسىمۇ ئۇ جەزمەن ئۆلتۈرۈلسۇن، دېدى. لېكىن پۈتكۈل خەلقتىن ھېچكىم ئۇنىڭغا جاۋاب بەرمىدى.
\m 
\v 40 ئاندىن ئۇ پۈتكۈل ئىسرائىلغا: ــ سىلەر بىر تەرەپتە تۇرۇڭلار، مەن ئوغلۇم يوناتان يەنە بىر تەرەپتە تۇرايلى، دېدى. خەلق ئۇنىڭغا: ــ نېمە ساڭا ياخشى كۆرۈنسە، شۇنى قىلغىن، دېدى.
\m 
\v 41 سائۇل ئىسرائىلنىڭ خۇداسى پەرۋەردىگارغا: ــ بۇ چەك بىلەن ئەينى ئەھۋالنى ئاشكارا قىلغايسەن، دېدى. چەك بولسا سائۇل بىلەن يوناتاننى كۆرسەتتى، خەلق قۇتۇلدى. \f ◼ \fr 14:41 \ft \bd «بۇ چەك بىلەن ئەينى ئەھۋالنى ئاشكارا قىلغايسەن»\bd* ــ گرېك تىلىدىكى LXX تەرجىمىسىدە «نېمىشقا بۈگۈن قۇلۇڭغا جاۋاب بەرمەيسەن؟ ئەيىب بەندە ياكى ئوغلۇم يوناتاندا بولسا، «ئۇرىم» چىقسۇن؛ ئىسرائىللاردا بولسا «تۇممىم» چىقسۇن» ديىلىدۇ.\f*
\m 
\v 42 سائۇل: ــ مېنىڭ بىلەن ئوغلۇم يوناتاننىڭ ئوتتۇرىسىغا چەك تاشلاڭلار، دېدى. شۇنداق قىلىۋىدى، چەك يوناتانغا چىقتى.
\v 43 سائۇل يوناتانغا: ــ قىلغىنىڭنى ماڭا ئېيتقىن، دېدى. يوناتان ئۇنىڭغا: ــ قولۇمدىكى ھاسا بىلەن كىچىككىنە ھەسەل ئېلىپ تېتىپ باقتىم ۋە مانا، شۇنىڭ ئۈچۈن مەن ئۆلۈمگە مەھكۇم بولدۇم! ــ دەپ جاۋاب بەردى.
\m 
\v 44 سائۇل: ــ سەن چوقۇم ئۆلۈشۈڭ كېرەك، ئى يوناتان؛ ئۇنداق قىلمىسام، خۇدا ماڭا سېنىڭ بېشىڭغا چۈشكەندىنمۇ ئارتۇق چۈشۈرسۇن! ــ دېدى.
\m 
\v 45 لېكىن خەلق سائۇلغا: ــ ئىسرائىلدا بۇ ئۇلۇغ نۇسرەتنى قازانغان يوناتان ئۆلتۈرۈلەمدۇ؟ بۇنداق ئىش بىزدىن نېرى بولغاي! پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمىزكى، ئۇنىڭ بېشىدىن بىر تال چاچ يەرگە چۈشمەيدۇ؛ چۈنكى بۈگۈنكى ئىشنى ئۇ خۇدانىڭ ياردىمى بىلەن ئەمەلگە ئاشۇردى، دېدى. شۇنداق قىلىپ خەلق يوناتاننى ئۆلۈمدىن خالاس قىلدى.
\v 46 ئاندىن سائۇل فىلىستىيلەرنى قوغلاشتىن توختىدى؛ فىلىستىيلەرمۇ ئۆز جايىغا قايتىپ كەتتى.
\m 
\v 47 شۇنداق قىلىپ سائۇل ئىسرائىلنىڭ سەلتەنىتىنى ئۆزىنىڭ قىلدى؛ ئاندىن ئۇ چۆرىسىدىكى دۈشمەنلىرىگە، يەنى موئابلار، ئاممونىيلار، ئېدومىيلار، زوباھدىكى پادىشاھلار ۋە فىلىستىيلەرگە ھۇجۇم قىلدى. ئۇ قايسى تەرەپكە يۈزلەنسە غالىپ كېلەتتى. \f ◼ \fr 14:47 \ft \bd «ئۇ قايسى تەرەپكە يۈزلەنسە غالىپ كېلەتتى»\bd* ــ ياكى «ئۇ قايسى تەرەپكە يۈزلەنسە ئۇلارنى ۋەيران قىلاتتى».\f*
\v 48 ئۇ زور جاسارەت كۆرسىتىپ ئامالەكلەرنى ئۇرۇپ ئىسرائىلنى بۇلاڭ-تالاڭ قىلغۇچىلاردىن قۇتقۇزدى.
\b
\s1 سائۇلنىڭ جەمەتى
\m 
\v 49 سائۇلنىڭ ئوغۇللىرى يوناتان، يىشۋى ۋە مالقى-شۇئا ئىدى؛ ئۇنىڭ ئىككى قىزىنىڭ ئىسمى بولسا ــ چوڭىنىڭ مېراب، كىچىكىنىڭ مىقال ئىدى.
\v 50 سائۇلنىڭ ئايالىنىڭ ئىسمى ئاھىنوئام بولۇپ، ئۇ ئاخىمائازنىڭ قىزى ئىدى. سائۇلنىڭ قوشۇنىنىڭ سەردارى ئابنەر ئىدى؛ ئۇ سائۇلنىڭ تاغىسى نەرنىڭ ئوغلى ئىدى.
\v 51 سائۇلنىڭ ئاتىسى كىش ۋە ئابنەرنىڭ ئاتىسى نەر بولسا، ئىككىسى ئابىئەلنىڭ ئوغۇللىرى ئىدى.
\v 52 سائۇل پۈتكۈل ئۆمرىدە فىلىستىيلەر بىلەن قاتتىق جەڭدە بولۇپ تۇردى. سائۇل ئۆزى ھەرقاچان باتۇر يا پالۋانلارنى كۆرسە، ئۇنى ئۆز خىزمىتىگە سالاتتى.
\b
\b
\c 15
\s1 سائۇلنىڭ پادىشاھلىق ھوقۇقىدىن مەھرۇم قىلىنىشى
\m 
\v 1 ئەمدى سامۇئىل سائۇلغا: ــ پەرۋەردىگار سېنى ئۆز خەلقى ئىسرائىل ئۈستىگە پادىشاھ بولۇش ئۈچۈن مەسىھ قىلغىلى مېنى ئەۋەتكەنىدى؛ ئەمدى پەرۋەردىگارنىڭ سۆزىنى ئاڭلىغىن.
\v 2 ساماۋى قوشۇنلارنىڭ سەردارى بولغان پەرۋەردىگار مۇنداق دەيدۇ: ــ مەن ئامالەكلەرنىڭ ئىسرائىلغا قىلغان مۇئامىلىسىنى، يەنى ئىسرائىل مىسىردىن چىققاندا ئۇلارنىڭ يولدا ئۇلارغا قانداق قارشىلىق كۆرسەتكەنلىكىنى كۆڭلۈمگە پۈككەنمەن. \x ◘ \xo 15:2 \xt مىس. 17‏:8، 14؛ قان. 25‏:17\x*
\v 3 ئەمدى بېرىپ ئامالەكلەرنى ئۇرۇپ ئۇلارنىڭ ھەممىسىنى ۋەيران قىلىپ ئۇلارنى ھېچ ئايىمايلا، ئەر بولسۇن، ئايال بولسۇن، ئۆسمۈر بولسۇن، بوۋاق بولسۇن، كالا-قوي، تۆگە ۋە ئىشەك ھەممىسىنى يوقاتقىن، دېدى.
\v 4 سائۇل خەلقنى جەم قىلىپ ئۇلارنى تەلائىم شەھىرىدە سانىۋىدى، ئىككى يۈز مىڭ پىيادە ئەسكەر، يەھۇدا قەبىلىسىدىن ئون مىڭ ئادەم چىقتى.
\v 5 سائۇل ئامالەكلەرنىڭ شەھىرىگە كەلگەندە شۇ يەردىكى ۋادىدا بۆكتۈرمە قويدى. \f ◼ \fr 15:5 \ft \bd «ئامالەكلەرنىڭ شەھىرىگە»\bd* ــ ياكى «ئامالەكلەرنىڭ شەھەرلىرىگە».\f*
\m 
\v 6 ئاندىن سائۇل كېنىيلەرگە: ــ چىقىپ كېتىڭلار، سىلەرنى ئۇلار بىلەن قوشۇپ يوقاتماسلىقىم ئۈچۈن ئامالەكلەرنىڭ ئارىسىدىن چىقىپ كېتىڭلار؛ چۈنكى ئىسرائىل مىسىردىن چىققاندا سىلەر ئۇلارنىڭ ھەممىسىگە مېھرىبانلىق كۆرسەتكەنسىلەر، دېدى. شۇنىڭ بىلەن كېنىيلەر ئامالەكلەردىن چىقىپ كەتتى. \x ◘ \xo 15:6 \xt مىس. 18‏:10، 19؛ چۆل. 10‏:29؛ ھاك. 1‏:16\x*
\v 7 ئەمدى سائۇل ئامالەكلەرنى ھاۋىلاھدىن تارتىپ مىسىرنىڭ ئۇدۇلىدىكى شۇرغىچە قوغلاپ ئۇردى.
\v 8 ئۇ ئامالەكلەرنىڭ پادىشاھى ئاگاگنى تىرىك تۇتتى، ئەمما بارلىق خەلقنى قىلىچ بىسى بىلەن پۈتۈنلەي يوقاتتى. \x ◘ \xo 15:8 \xt چۆل. 24‏:7\x*
\m 
\v 9 لېكىن سائۇل بىلەن خەلق ئاگاگنى ئايىدى ۋە قوي-كالا، بوردالغان مال ۋە قوزىلاردىن ئەڭ ئېسىللەرنىڭ ھەممىسىنى، جۈملىدىن نېمە ياخشى بولسا شۇنى ئاياپ ئۇلارنى ھالاك قىلىشقا قولى بارمىدى؛ لېكىن نېمە يارىماس ۋە زەئىپ بولسا شۇلارنىڭ ھەممىسىنى ئۇلار يوقاتتى. \f ◼ \fr 15:9 \ft \bd «سائۇل بىلەن خەلق ... قوي-كالا، بوردالغان مال ۋە قوزىلاردىن ئەڭ ئېسىللەرنىڭ ھەممىسىنى ...ھالاك قىلىشقا قولى بارمىدى»\bd* ــ «بوردالغان مال» دېگەننىڭ باشقا خىل تەرجىمىسى: «ئىككىنچى تۇغۇلغان مال».\f*
\m 
\v 10 شۇنىڭ بىلەن پەرۋەردىگارنىڭ سۆزى سامۇئىلغا كېلىپ مۇنداق دېگەندە: ــ \f ◼ \fr 15:10 \ft \bd «پەرۋەردىگارنىڭ سۆزى سامۇئىلغا كېلىپ مۇنداق دېگەندە...»\bd* ــ ياكى «پەرۋەردىگارنىڭ سۆزى سامۇئىلغا كېلىپ مۇنداق دېدى» دەپ ئىپادىلىنىدۇ. تاۋراتتا بىر يۈزدىن ئارتۇق قېتىممۇ «پەرۋەردىگارنىڭ سۆزى پالانچى ئادەمگە كېلىپ مۇنداق دېدى» دېگەن ئىبارە تېپىلىدۇ. ئنىققى، «پەرۋەردىگارنىڭ سۆزى» بىر شەخسگە ئوخشايدۇ.«يار.» 8:3 «ئۇلار پەرۋەردىگار خۇدانىڭ ئاۋازىنىڭ باغدا ماڭغانلىقىنى ئاڭلاپ كېلىپ....» دېگەنلىكتىمۇ «پەرۋەردىگار خۇدانىڭ ئاۋازى» بىر شەخسنى كۆرسىتىدۇ. شۈبھىسىزكى بۇ شەخس «ئۈچتە بىر»دىكى ئىككىنچى شەخنسدۇر.\f*
\v 11 «سائۇلنى پادىشاھ قىلغىنىمغا پۇشايمان قىلدىم، چۈنكى ئۇ ماڭا ئەگىشىشتىن يېنىپ مېنىڭ سۆزۈمگە ئەمەل قىلمىدى».
\m سامۇئىل ئازار چېكىپ پۈتكۈل بىر كېچە پەرۋەردىگارغا پەرياد كۆتۈردى.
\m 
\v 12 ئەتىسى سامۇئىل سائۇلنىڭ ئالدىغا چىقىش ئۈچۈن تاڭ سەھەردىلا ئورنىدىن تۇردى. سامۇئىلغا: ــ سائۇل كارمەلگە باردى ۋە مانا، ئۇ ئۆزىگە بىر ئابىدە تۇرغۇزۇپ ئاندىن يېنىپ گىلگالغا چۈشۈپتۇ، دېگەن خەۋەر بېرىلدى.
\m 
\v 13 سامۇئىل سائۇلنىڭ قېشىغا كەلگەندە سائۇل ئۇنىڭغا: ــ پەرۋەردىگار سېنى مۇبارەكلىگەي! پەرۋەردىگارنىڭ سۆزلىرىگە ئەمەل قىلدىم، دېدى.
\m 
\v 14 لېكىن سامۇئىل: ــ ئۇنداق بولسا قۇلىقىمغا ئاڭلانغان قوينىڭ مەرىشى بىلەن مەن ئاڭلاۋاتقان كالىنىڭ مۆرىشى زادى نەدىن كەلدى؟ ــ دېدى.
\m 
\v 15 سائۇل جاۋاب بېرىپ: ــ ئۇلار ئامالەكلەردىن ئېلىپ كېلىندى؛ چۈنكى خەلق خۇدايىڭ پەرۋەردىگارغا قۇربانلىق قىلىش ئۈچۈن قوي-كالىنىڭ ئېسىللىرىنى ئاياپ قالدۇرۇپ قويدى؛ قالغىنىنى بولسا پۈتۈنلەي يوقاتتۇق، دېدى.
\m 
\v 16 سامۇئىل سائۇلغا: ــ قوي، بۇ گېپىڭنى! مەن پەرۋەردىگارنىڭ بۇ كېچە ماڭا نېمە دېگىنىنى ساڭا ئېيتىپ بېرەي، دېدى. ئۇ ئۇنىڭغا: ــ ئېيتقىن، دېدى.
\m 
\v 17 سامۇئىل مۇنداق دېدى: ــ ئۆز نەزىرىڭدە كىچىك ھېسابلانغان ۋاقتىڭدىلا پەرۋەردىگار سېنى ئىسرائىلنىڭ ئۈستىگە پادىشاھ بولسۇن دەپ، مەسىھ قىلىشى بىلەن سەن ئىسرائىل قەبىلىلىرىنىڭ بېشى بولغان ئەمەسمىدىڭ؟
\v 18 ئاندىن پەرۋەردىگار سېنى: ــ سەن بېرىپ گۇناھكار ئامالەكلەرنى ھالاك قىلغىن؛ ئۇلارنى يوقاتقۇچە ئۇلار بىلەن سوقۇشقىن، دەپ ئەۋەتكەنىدى.
\v 19 ئەمدى نېمىشقا پەرۋەردىگارنىڭ سۆزىگە قۇلاق سالماي، بەلكى ئولجا ئۈستىگە دۈم چۈشۈپ، پەرۋەردىگارنىڭ نەزىرىدە يامان بولغاننى قىلدىڭ؟
\m 
\v 20 سائۇل سامۇئىلغا: ــ مەن ھەقىقەتەن پەرۋەردىگارنىڭ سۆزىگە قۇلاق سالدىمغۇ! پەرۋەردىگار مېنى ئەۋەتكەن يول بىلەن ماڭدىم ۋە ئامالەكلەرنىڭ پادىشاھى ئاگاگنى ئېلىپ كېلىپ ئامالەكلەرنىڭ ئۆزىنى پۈتۈنلەي يوقاتتىم.
\v 21 ئەمما خەلق بولسا ئولجىدىن قوي بىلەن كالا، يەنى يوقىتىشقا بېكىتىلگەن نەرسىلەردىن ئەڭ ئېسىلىنى ئېلىپ خۇدايىڭ پەرۋەردىگارغا گىلگالدا قۇربانلىق قىلىش ئۈچۈن ئېلىپ كەلدى، دېدى.
\m 
\v 22 سامۇئىل: ــ پەرۋەردىگار كۆيدۈرمە قۇربانلىقلار بىلەن تەشەككۈر قۇربانلىقلىرىنى كەلتۈرۈشتىن سۆيۈنەمدۇ، يا پەرۋەردىگارنىڭ سۆزىگە ئىتائەت قىلىشتىن سۆيۈنەمدۇ؟ مانا ئىتائەت قىلماقلىق قۇربانلىق قىلماقلىقتىن ئەۋزەل، كۆڭۈل قويۇش قوچقار يېغىنى سۇنۇشتىن ئەۋزەلدۇر. \x ◘ \xo 15:22 \xt توپ. 4‏:17؛ ھوش. 6‏:6؛ مات. 9‏:13؛ 12‏:7\x*
\m 
\v 23 چۈنكى ئاسىيلىق بولسا جادۇگەرلىك گۇناھى بىلەن ئوخشاشتۇر،
\m باشباشتاقلىق قەبىھلىك ۋە بۇتپەرەسلىككە باراۋەردۇر.
\m سەن پەرۋەردىگارنىڭ سۆزىنى تاشلىغىنىڭ ئۈچۈن،
\m پەرۋەردىگار سېنى تاشلاپ پادىشاھلىقتىن مەھرۇم قىلدى، ــ دېدى.
\m 
\v 24 سائۇل سامۇئىلغا: ــ مەن گۇناھ سادىر قىلدىم، چۈنكى مەن پەرۋەردىگارنىڭ ئەمرىدىن ۋە سېنىڭ سۆزۈڭدىنمۇ چىقتىم؛ چۈنكى مەن خەلقتىن قورقۇپ ئۇلارنىڭ سۆزىگە كىردىم.
\v 25 ئەمدى گۇناھىمنى ئەپۇ قىلغىن؛ مېنىڭ پەرۋەردىگارغا سەجدە قىلىشىم ئۈچۈن مېنىڭ بىلەن قايتىپ بارغىن، دېدى.
\m 
\v 26 سامۇئىل سائۇلغا: ــ مەن سېنىڭ بىلەن قايتىپ بارمايمەن؛ چۈنكى سەن پەرۋەردىگارنىڭ سۆزىنى تاشلىغانسەن، ۋە پەرۋەردىگار سېنى تاشلاپ پادىشاھلىقتىن مەھرۇم قىلدى، دېدى.
\m 
\v 27 سامۇئىل كېتىشكە بۇرۇلغىنىدا سائۇل ئۇنىڭ تونىنىڭ پېشىنى تۇتۇۋالدى، ئۇ يىرتىلىپ كەتتى.
\v 28 سامۇئىل ئۇنىڭغا: ــ پەرۋەردىگار بۈگۈن ئىسرائىلنىڭ پادىشاھلىقىنى سەندىن يىرتىپ ئېلىپ سەندىن ئەۋزەل بولغان بىر يېقىنىڭغا تاپشۇردى.
\v 29 ئىسرائىلنىڭ جانابىي ئالىيىسى بولغۇچى يالغان سۆزلىمەيدۇ ياكى نىيىتىدىن يانمايدۇ؛ چۈنكى ئۇ ئادەم بالىسىدەك نىيىتىدىن يانغۇچى ئەمەستۇر، دېدى. \f ◼ \fr 15:29 \ft \bd «ئىسرائىلنىڭ جانابىي ئالىيىسى بولغۇچى»\bd* ــ خۇدانى كۆرسىتىدۇ، ئەلۋەتتە.\f*  \x ◘ \xo 15:29 \xt چۆل. 23‏:19؛ ياق. 1‏:17\x*
\m 
\v 30 سائۇل: ــ مەن گۇناھ سادىر قىلدىم. لېكىن خەلقىمنىڭ ئاقساقاللىرىنىڭ ۋە ئىسرائىلنىڭ ئالدىدا ماڭا ئىززەت قىلىپ مېنىڭ بىلەن يېنىپ بارغىن؛ شۇنىڭ بىلەن خۇدايىڭ پەرۋەردىگارغا سەجدە قىلالايمەن، دېدى.
\m 
\v 31 شۇنىڭ بىلەن سامۇئىل سائۇل بىلەن يېنىپ باردى ۋە سائۇل پەرۋەردىگارغا سەجدە قىلدى.
\m 
\v 32 ئاندىن سامۇئىل: ــ ئامالەكلەرنىڭ پادىشاھى ئاگاگنى مېنىڭ ئالدىمغا ئېلىپ كېلىڭلار، دېدى. ئاگاگ بولسا خۇشلۇق بىلەن ئۇنىڭ قېشىغا باردى. ئاگاگ كۆڭلىدە: ــ شۈبھىسىزكى، ئۆلۈم دەھشىتى ئۆتۈپ كەتتى، دېدى. \f ◼ \fr 15:32 \ft \bd «... ئاگاگ بولسا خۇشلۇق بىلەن ئۇنىڭ قېشىغا باردى. ئاگاگ كۆڭلىدە: ــ شۈبھىسىزكى، ئۆلۈم دەھشىتى ئۆتۈپ كەتتى، دېدى»\bd* ــ بۇ ئايەتنى ئىبرانىي تىلىدا چۈشىنىش تەس. باشقا بىر تەرجىمىسى: «... ئاگاگ بولسا تىترىگەن ھالدا ئۇنىڭ قېشىغا باردى. ئاگاگ: ــ دەرۋەقە ئۆلۈمنىڭ ئاچچىقى قورقۇنچلۇقتۇر! ــ دېدى».\f*
\m 
\v 33 ئەمما سامۇئىل: ــ سېنىڭ قىلىچىڭ خوتۇنلارنى بالىسىز قىلغاندەك سېنىڭ ئاناڭمۇ خوتۇنلارنىڭ ئارىسىدا بالىسىز بولىدۇ، دېۋىدى، سامۇئىل ئاگاگنى گىلگالدا پەرۋەردىگارنىڭ ئالدىدا چاناپ پارە-پارە قىلدى.
\m 
\v 34 ئاندىن سامۇئىل راماھقا باردى. سائۇل بولسا «سائۇلنىڭ يۇرتى گىبېئاھ» دېگەن جايدىكى ئۆيىگە چىقىپ كەتتى.
\v 35 سامۇئىل ئۆلگەن كۈنىگىچە سائۇل بىلەن قايتا كۆرۈشمىدى. ئەمما سامۇئىل سائۇل ئۈچۈن قايغۇردى. پەرۋەردىگار سائۇلنى ئىسرائىلنىڭ ئۈستىگە پادىشاھ قىلغانلىقىدىن ئەپسۇسلاندى.
\b
\b
\c 16
\s1 سامۇئىل داۋۇتنىڭ پادىشاھ بولۇشى ئۈچۈن ئۇنى مەسىھ قىلىدۇ
\m 
\v 1 پەرۋەردىگار سامۇئىلغا: ــ سەن قاچانغىچە سائۇل ئۈچۈن قايغۇرۇپ يۈرىسەن؟ مەن ئۇنى ئىسرائىلغا سەلتەنەت قىلىشتىن مەھرۇم قىلىپ تاشلىغان ئەمەسمۇ؟ مۈڭگۈزۈڭنى زەيتۇن مېيى بىلەن تولدۇرۇپ بارغىن. مەن سېنى بەيت-لەھەملىك يەسسەنىڭ قېشىغا ئەۋەتىمەن. ئۇنىڭ ئوغۇللىرىدىن پادىشاھ بولۇشقا ئۆزۈمگە بىرنى بېكىتتىم، دېدى.
\m 
\v 2 سامۇئىل بولسا: ــ مەن قانداق بارىمەن؟ سائۇل بۇ ئىشنى ئاڭلىسا مېنى ئۆلتۈرۈۋېتىدۇ! ــ دېدى. پەرۋەردىگار: ــ ئۆزۈڭ بىلەن بىر ئىنەكنى ئالغاچ بېرىپ پەرۋەردىگارغا قۇربانلىق قىلىش ئۈچۈن كەلدىم، دېگىن.
\v 3 يەسسەنى قۇربانلىققا چاقىرغىن، ئاندىن مەن ساڭا قىلىدىغىنىڭنى ئايان قىلىمەن؛ ۋە مەن ساڭا دېگەن بىرسىنى ئۆزۈم ئۈچۈن مەسىھ قىلغىن، دېدى.
\m 
\v 4 سامۇئىل پەرۋەردىگارنىڭ دېگىنىنى ئادا قىلىپ بەيت-لەھەمگە باردى. يېتىپ كەلگەندە شەھەرنىڭ ئاقساقاللىرى تىترىگەن ھالدا چىقىپ: ــ بىزگە تىنچ-ئامانلىق ئېلىپ كەلدىڭمۇ؟ ــ دەپ سورىدى.
\m 
\v 5 ئۇ: ــ تىنچ-ئامانلىق ئېلىپ كەلدىم؛ پەرۋەردىگارغا قۇربانلىق سۇنۇشقا كەلدىم. سىلەر ئۆزۈڭلارنى ھارامدىن پاكلاپ مەن بىلەن بىللە قۇربانلىققا كېلىڭلار، دېدى. شۇنىڭ بىلەن ئۇ يەسسە بىلەن ئوغۇللىرىنى ھالال قىلىپ قۇربانلىققا چاقىردى.
\v 6 ئۇلار كەلگەندە سامۇئىل ئېلىئابنى كۆرۈپ ئىچىدە: ــ پەرۋەردىگارنىڭ مەسىھ قىلىدىغىنى شۈبھىسىزكى ئۆزىنىڭ ئالدىدا تۇرىدۇ، دېدى.
\m 
\v 7 لېكىن پەرۋەردىگار سامۇئىلغا: ــ ئۇنىڭ تەقى-تۇرقىغا ياكى بويىغا قارىمىغىن. مەن ئۇنى شاللىۋەتتىم، چۈنكى خۇدا ئىنسان كۆرگەندەك كۆرمەيدۇ؛ ئىنسان بولسا سىرتقى قىياپىتىگە قارايدۇ، لېكىن پەرۋەردىگار قەلبگە قارايدۇ، دېدى. \x ◘ \xo 16:7 \xt 1تار. 28‏:9؛ زەب. 7‏:9؛ 147‏:10-11؛ يەر. 11‏:20؛ 17‏:10؛ 20‏:12\x*
\m 
\v 8 ئاندىن يەسسە ئابىنادابنى چاقىرىپ سامۇئىلنىڭ ئالدىدىن ئۆتكۈزدى. ئەمما سامۇئىل: ــ پەرۋەردىگار بۇنى ھەم تاللىمىدى، دېدى.
\m 
\v 9 ئاندىن يەسسە شامماھنى ئۇنىڭ ئالدىدىن ئۆتكۈزدى. ئەمما سامۇئىل: ــ پەرۋەردىگار بۇنى ھەم تاللىمىدى، دېدى.
\m 
\v 10 شۇنىڭغا ئوخشاش يەسسە ئوغۇللىرىنىڭ يەتتىسىنى سامۇئىلنىڭ ئالدىدىن ئۆتكۈزدى. لېكىن سامۇئىل يەسسەگە: ــ پەرۋەردىگار بۇلارنى ھەم تاللىمىدى، دېدى.
\m 
\v 11 سامۇئىل يەسسەدىن: ــ بارلىق يىگىتلەر مۇشۇلارمۇ؟ دەپ سورىدى. ئۇ: ــ ھەممىدىن كىچىكى قالدى. لېكىن مانا، ئۇ قوي بېقىۋاتىدۇ، دېدى. سامۇئىل يەسسەگە: ــ ئۇنى چاقىرتىپ ئېلىپ كەلگىن، چۈنكى ئۇ كەلمىگۈچە داستىخاندا ئولتۇرمايمىز، دېدى. \x ◘ \xo 16:11 \xt 2سام. 7‏:8؛ زەب. 78‏:70-71\x*
\m 
\v 12 \add يەسسە\add* ئادەم ماڭدۇرۇپ ئۇنى كەلتۈردى. ئۇ چىرايىدا قان يۈگۈرۈپ تۇرىدىغان، كۆزلىرى چىرايلىق ۋە كېلىشكەن يىگىت ئىدى. پەرۋەردىگار: ــ قوپۇپ ئۇنى مەسىھ قىلغىن، چۈنكى \add مېنىڭ تاللىغىنىم\add* شۇدۇر! دېدى.
\v 13 سامۇئىل ماي مۈڭگۈزىنى ئېلىپ ئۇنى قېرىنداشلىرىنىڭ ئارىسىدا مەسىھ قىلدى. ئۇ كۈندىن تارتىپ پەرۋەردىگارنىڭ روھى داۋۇتنىڭ ۋۇجۇدىغا چۈشتى. سامۇئىل بولسا قوپۇپ راماھغا كەتتى. \x ◘ \xo 16:13 \xt زەب. 89‏:20-21؛ روس. 7‏:46؛ 13‏:22\x*
\b
\s1 داۋۇت سائۇلنىڭ ئالدىغا كېلىدۇ
\m 
\v 14 ئەمدى پەرۋەردىگارنىڭ روھى سائۇلدىن كەتكەنىدى، ۋە پەرۋەردىگار تەرىپىدىن بىر يامان روھ ئۇنى پەرىشان قىلدى.
\v 15 سائۇلنىڭ خىزمەتكارلىرى ئۇنىڭغا: ــ مانا خۇدا تەرىپىدىن بىر يامان روھ سېنى پەرىشان قىلىدۇ.
\v 16 ئەمدى غوجىمىز ئۆزلىرى ئالدىلىرىدىكى خىزمەتكارلىرىنى دەرھال بۇيرۇغايلىكى، ئۇلار چىلتار چېلىشقا ئۇستا ئادەمنى تاپسۇن؛ ۋە شۇنداق بولىدۇكى، خۇدا تەرىپىدىن يامان روھ ئۈستلىرىگە كەلسە ئۇ چىلتار چالسۇن، ئۇنىڭ بىلەن ھاللىرى ئوبدان بولىدۇ، دېدى.
\m 
\v 17 سائۇل خىزمەتكارلىرىغا: ــ مېنىڭ ئۈچۈن چىلتار چېلىشقا ئۇستا بىر ئادەمنى تېپىپ قېشىمغا ئېلىپ كېلىڭلار، دېدى.
\m 
\v 18 غۇلاملاردىن بىرى ئۇنىڭغا: ــ مانا بەيت-لەھەملىك يەسسەنىڭ چىلتارغا ئۇستا بىر ئوغلىنى كۆردۈم. ئۇ ئۆزى باتۇر بىر جەڭچى، گەپتە ھوشيار ۋە كېلىشكەن ئادەم ئىكەن، شۇنداقلا پەرۋەردىگار ئۇنىڭ بىلەن بىللە ئىكەن، دېدى.
\m 
\v 19 شۇنىڭ بىلەن سائۇل يەسسەگە ئەلچىلەرنى ماڭدۇرۇپ: ــ قوي باقىدىغان ئوغلۇڭ داۋۇتنى ماڭا ئەۋەتكىن، دەپ ئېيتتى.
\m 
\v 20 يەسسە بىر ئېشەكنى تەييارلاپ ئۇنىڭغا نان بىلەن بىر تۇلۇم شاراب ۋە بىر ئوغلاقنى ئارتىپ، بۇلارنى ئوغلى داۋۇتنىڭ قولى بىلەن سائۇلغا ئەۋەتتى.
\v 21 شۇنىڭ بىلەن داۋۇت سائۇلنىڭ قېشىغا كېلىپ ئۇنىڭ ئالدىدا تۇردى. سائۇل ئۇنىڭغا تولىمۇ ئامراق ئىدى؛ ئۇ سائۇلنىڭ ياراغ كۆتۈرگۈچىسى بولدى.
\v 22 ئاندىن سائۇل يەسسەگە خەۋەر ئەۋەتىپ: ــ داۋۇت مېنىڭ ئالدىمدا تۇرسۇن؛ چۈنكى ئۇ نەزىرىمگە ياقتى، دەپ ئېيتتى.
\m 
\v 23 ئەمدى شۇنداق بولىدۇكى، ئۇ \add يامان\add* روھ خۇدا تەرىپىدىن سائۇلنىڭ ئۈستىگە كەلگەندە داۋۇت چىلتارنى ئېلىپ قولى بىلەن چالدى. بۇنىڭ بىلەن سائۇل ئارام تېپىپ ھالى ئوبدان بولۇپ يامان روھ ئۇنىڭدىن چىقىپ كەتتى.
\b
\b
\c 17
\s1 داۋۇت بىلەن گولىئات
\m 
\v 1 ئەمما فىلىستىيلەر جەڭ قىلىش ئۈچۈن قوشۇنلىرىنى يىغدى. ئۇلار يەھۇداغا تەۋە سوكوھدا جەم بولۇپ، سوكوھ بىلەن ئازىكاھ ئوتتۇرىسىدىكى ئەفەس-داممىمدا چېدىرلارنى تىكتى.
\v 2 سائۇل بىلەن ئىسرائىللارمۇ جەم بولۇپ ئېلاھ جىلغىسىدا چېدىرلىرىنى تىكىپ فىلىستىيلەر بىلەن جەڭ قىلغىلى سەپ تۈزدى. \f ◼ \fr 17:2 \ft \bd «ئېلاھ جىلغىسىدا»\bd* ــ ياكى «دۇبلار جىلغىسىدا».\f*
\v 3 فىلىستىيلەر بىر تەرەپتىكى تاغدا، ئىسرائىللار يەنە بىر تەرەپتىكى تاغدا تۇراتتى؛ ئوتتۇرىسىدا جىلغا بار ئىدى.
\m 
\v 4 شۇ ۋاقىتتا فىلىستىيلەرنىڭ لەشكەرگاھىدىن گاتلىق گولىئات ئىسىملىك بىر چېمپىيون پالۋان چىقىپ كەلدى. ئۇنىڭ ئېگىزلىكى ئالتە گەز بىر غېرىچ ئىدى. \f ◼ \fr 17:4 \ft \bd «ئۇنىڭ ئېگىزلىكى ئالتە گەز بىر غېرىچ ئىدى»\bd* ــ تەۋراتتىكى «گەز» بىر جەينەككە باراۋەر بولۇپ، يەنى 45 سانتىمېتر ئىدى. دېمەك گولىئاتنىڭ ئېگىزلىكى 2.8 مېتر ئىدى.\f*
\v 5 بېشىغا مىس دۇبۇلغا، ئۇچىسىغا قاسىراقلىق ساۋۇت كىيگەنىدى. ئۇنىڭ بۇ مىس ساۋۇتى بولسا بەش مىڭ شەكەل كېلەتتى. \f ◼ \fr 17:5 \ft \bd «ئۇنىڭ بۇ مىس ساۋۇتى بولسا بەش مىڭ شەكەل كېلەتتى»\bd* ــ «بەش مىڭ شەكەل» بەلكىم 60-100 كىلوگرام بولۇشى مۇمكىن.\f*
\v 6 پاچاقلىرىغا مىستىن تىزلىق باغلىغان، ئۆشنىسىگە مىس ئاتما نەيزە قىستۇرۇۋالغانىدى.
\v 7 ئۇنىڭ نەيزىسىنىڭ سېپى بولسا باپكارنىڭ خادىسىدەك ئىدى؛ نەيزىسىنىڭ بېشى ئالتە يۈز شەكەل كېلەتتى؛ قالقان كۆتۈرگۈچىسى ئۇنىڭ ئالدىدا ماڭاتتى.
\m 
\v 8 ئۇ ئورنىدا تۇرۇپ ئىسرائىلنىڭ قوشۇنلىرىغا مۇنداق توۋلايتتى: ــ «سىلەر نېمىشقا جەڭ قىلىش ئۈچۈن سەپ تۈزگەنسىلەر؟ مەن فىلىستىي ئەمەسمۇ؟ سىلەر بولساڭلار سائۇلنىڭ قۇللىرىغۇ؟ ئاراڭلاردىن بىر ئادەمنى تاللاپ چىقىڭلار، ئۇ مەن بىلەن ئېلىشىشقا چۈشسۇن!
\v 9 ئۇ مەن بىلەن ئېلىشىپ مېنى ئۇرۇپ ئۆلتۈرەلسە، بىز سىلەرنىڭ قۇللىرىڭلار بولىمىز. لېكىن مەن ئۇنى مەغلۇپ قىلىپ ئۆلتۈرسەم، سىلەر بىزنىڭ قۇللىرىمىز بولۇپ بىزنىڭ خىزمىتىمىزدە بولۇسىلەر».
\v 10 شۇ فىلىستىي يەنە سۆز قىلىپ: ــ مەن بۈگۈن ئىسرائىلنىڭ قوشۇنىغا ھاقارەت قىلدىمغۇ؟ سىلەر بىر ئادەمنى چىقىرىڭلار، بىز ئېلىشايلى! ــ دېدى.
\m 
\v 11 سائۇل بىلەن ھەممە ئىسرائىل بۇ فىلىستىينىڭ سۆزلىرىنى ئاڭلاپ، ئالاقزادە بولۇپ بەك قورقتى.
\m 
\v 12 داۋۇت يەھۇدا يۇرتىدىكى بەيت-لەھەمدە ئولتۇرۇقلۇق يەسسە دېگەن ئەفراتلىق ئادەمنىڭ ئوغلى ئىدى. يەسسەنىڭ سەككىز ئوغلى بار ئىدى. سائۇلنىڭ كۈنلىرىدە ئۇ خېلى ياشىنىپ قالغانىدى.
\v 13 يەسسەنىڭ ئۈچ چوڭ ئوغلى سائۇل بىلەن جەڭگە چىققانىدى. جەڭگە چىققان ئۈچ ئوغۇلنىڭ تۇنجىسىنىڭ ئىسمى ئېلىئاب، ئىككىنچىسىنىڭ ئىسمى ئابىناداب ۋە ئۈچىنچىسىنىڭ شامماھ ئىدى.
\v 14 داۋۇت ھەممىدىن كىچىكى ئىدى. ئۈچ چوڭ ئوغلى سائۇلغا ئەگىشىپ چىققانىدى.
\v 15 بەزىدە داۋۇت سائۇلنىڭ قېشىدىن ئۆز ئاتىسىنىڭ قويلىرىنى بېقىش ئۈچۈن قايتىپ كېلەتتى. \x ◘ \xo 17:15 \xt 1سام. 16‏:19\x*
\m 
\v 16 ئاشۇ فىلىستىي بولسا قىرىق كۈنگىچىلىك ھەر ئەتىگەن ۋە كەچتە چىقىپ تۇردى.
\m 
\v 17 يەسسە ئوغلى داۋۇتقا: ــ بۇ ئەفاھ قوماچنى ۋە بۇ ئون ناننى ئېلىپ لەشكەرگاھغا تېز بېرىپ ئاكىلىرىڭغا بەرگىن، \f ◼ \fr 17:17 \ft \bd «بۇ ئەفاھ قوماچ»\bd* ــ بىر «ئەفاھ» 27-30 لىتر بولۇشى مۇمكىن.\f*
\v 18 بۇ ئون پارچە قۇرۇتنى ئۇلارنىڭ مىڭبېشىغا بېرىپ ئاكىلىرىڭنىڭ ئەھۋالىنى سوراپ ئۇلارنىڭ كېپىل خېتىنى ئېلىپ كەلگىن، دېدى. \f ◼ \fr 17:18 \ft \bd «ئاكىلىرىڭنىڭ ئەھۋالىنى سوراپ ئۇلارنىڭ كېپىل خېتىنى ئېلىپ كەلگىن»\bd* ــ مۇشۇ «كېپىل خېتى» بەلكىم ئۇلار داۋۇت ئاپارغان نەرسىلەرنى قوبۇل قىلغانلىقىنىڭ ئىسپاتى بولۇشى مۇمكىن.\f*
\m 
\v 19 سائۇل، شۇ \add ئۈچ ئوغۇل\add* ۋە ئىسرائىلنىڭ ھەممە ئادەملىرى ئېلاھ جىلغىسىدا تۇرۇپ فىلىستىيلەرگە قارشى جەڭ قىلاتتى.
\m 
\v 20 داۋۇت بولسا ئەتىسى سەھەر قوپۇپ قويلارنى بىر باققۇچىنىڭ قولىغا تاپشۇرۇپ، ئاشلىق-تۈلۈكنى ئېلىپ يەسسە ئۇنىڭغا تاپىلىغاندەك، قوشۇن ئىستىھكامىغا يەتكەندە، جەڭگە چىقىدىغان لەشكەرلەر سۆرەن كۆتۈرۈۋاتقانىدى. \x ◘ \xo 17:20 \xt 1سام. 26‏:5\x*
\v 21 ئىسرائىل ۋە فىلىستىيلەر بىر-بىرىگە ئۇدۇلمۇئۇدۇل تۇرۇپ سوقۇشقا سەپ تۈزدى.
\v 22 داۋۇت بولسا ئېلىپ كەلگەن نەرسىلەرنى يۈك-تاقلارغا قارىغۇچىنىڭ قولىغا تاپشۇرۇپ سەپ ئارىسىغا يۈگۈرۈپ بېرىپ ئاكىلىرىدىن تىنچلىق سورىدى.
\v 23 ئۇ ئۇلار بىلەن سۆزلىشىپ تۇرغاندا، فىلىستىيلەردىن بولغان گولىئات دېگەن چېمپىئون پالۋان فىلىستىيلەرنىڭ سېپىدىن چىقىپ يەنە ھېلىقى گەپنى قىلدى؛ داۋۇت ئۇنى ئاڭلىدى.
\v 24 ئىسرائىلنىڭ ھەممە ئادەملىرى بۇ ئادەمنى كۆرگەندە قېچىپ كېتىشتى ۋە بەك قورقتى.
\m 
\v 25 ئىسرائىلنىڭ ئادەملىرى بىر-بىرىگە: ــ چىقىۋاتقان بۇ ئادەمنى كۆردۈڭلارمۇ؟ ئۇ ئىسرائىلغا ھاقارەت قىلىش ئۈچۈن چىقىدۇ. شۇنداق بولىدۇكى، ئۇنى ئۆلتۈرگەن ئادەمگە پادىشاھ كۆپ مال-مۈلۈك ئىنئام قىلىدۇ، ئۆز قىزىنى ئۇنىڭغا خوتۇنلۇققا بېرىدۇ ھەم ئاتىسىنىڭ جەمەتىنى ئىسرائىل تەۋەسىدە باج-ئالۋاندىن خالاس قىلىدۇ، دېدى.
\m 
\v 26 داۋۇت ئۆز يېنىدا تۇرغان ئادەملەردىن: ــ بۇ فىلىستىينى ئۆلتۈرۈپ ئىسرائىلغا قىلىنغان شۇ ھاقارەتنى يوقاتقان كىشىگە نېمە قىلىنىدۇ؟ چۈنكى بۇ خەتنىسىز فىلىستىي زادى كىم؟ ئۇ قانداقسىگە مەڭگۈ ھايات بولغۇچى خۇدانىڭ قوشۇنلىرىغا ھاقارەت قىلىشقا پېتىنىدۇ؟ ــ دېدى.
\m 
\v 27 خالايىق ئۇنىڭغا ئالدىنقىلارنىڭ دېگەن سۆزى بويىچە جاۋاب بېرىپ: ــ ئۇنى ئۆلتۈرگەن كىشىگە مۇنداق-مۇنداق قىلىنىدۇ، دېدى.
\m 
\v 28 لېكىن ئۇنىڭ چوڭ ئاكىسى ئېلىئاب ئۇنىڭ ئۇ ئادەملەر بىلەن سۆزلەشكىنىنى ئاڭلاپ قالدى؛ ئېلىئابنىڭ داۋۇتقا ئاچچىقى كېلىپ: ــ نېمىشقا بۇ يەرگە كەلدىڭ؟ چۆلدىكى ئۇ ئازغىنە قوينى كىمگە تاشلاپ قويدۇڭ؟ مەن كىبىرلىكىڭنى ۋە كۆڭلۈڭنىڭ يامانلىقىنى بىلىمەن. سەن ئالايىتەن جەڭنى كۆرگىلى كەلدىڭ، دېدى.
\m 
\v 29 داۋۇت: ــ مەن نېمە قىلدىم؟ پەقەت بىر سۆز قىلسام بولمامدىكەن؟ ــ دېدى.
\m 
\v 30 داۋۇت بۇرۇلۇپ باشقىسىدىن ئالدىنقىدەك سورىدى، خەلق ئالدىدا ئېيتقاندەك ئۇنىڭغا جاۋاب بەردى.
\m 
\v 31 ئەمما بىرسى داۋۇتنىڭ ئېيتقان سۆزلىرىنى ئاڭلاپ قېلىپ سائۇلغا يەتكۈزدى؛ ئۇ داۋۇتنى چاقىرتىپ كەلدى.
\v 32 داۋۇت سائۇلغا: ــ بۇ كىشىنىڭ سەۋەبىدىن ھېچكىمنىڭ يۈرىكى سۇ بولمىسۇن. سىلىنىڭ قۇللىرى بۇ فىلىستىي بىلەن سوقۇشقىلى چىقىدۇ، دېدى.
\m 
\v 33 سائۇل داۋۇتقا: ــ سەن بۇ فىلىستىي بىلەن سوقۇشقىلى بارساڭ بولمايدۇ! سەن تېخى ياش، ئەمما ئۇ ياشلىقىدىن تارتىپلا جەڭچى ئىدى، دېدى.
\m 
\v 34 داۋۇت سائۇلغا: ــ قۇللىرى ئۆز ئاتىسىنىڭ قويلىرىنى بېقىپ كەلدىم. بىر شىر ياكى ئېيىق كېلىپ پادىدىن بىر قوزىنى ئېلىپ كەتسە،
\v 35 مەن ئۇنىڭ كەينىدىن قوغلاپ ئۇنى ئۇرۇپ قوزىنى ئاغزىدىن قۇتقۇزۇپ ئالاتتىم. ئەگەر قوپۇپ ماڭا ھۇجۇم قىلسا مەن ئۇنى يايلىدىن تۇتۇۋېلىپ ئۇرۇپ ئۆلتۈرەتتىم.
\v 36 قۇللىرى ھەم شىر ھەم ئېيىقنى ئۆلتۈرگەن؛ بۇ خەتنىسىز فىلىستىيمۇ ئۇلارغا ئوخشاش بولىدۇ. چۈنكى ئۇ مەڭگۈ ھايات بولغۇچى خۇدانىڭ قوشۇنىغا ھاقارەت كەلتۈردى ــ دېدى.
\v 37 داۋۇت سۆزىنى داۋام قىلىپ: ــ مېنى شىرنىڭ چاڭگىلىدىن ۋە ئېيىقنىڭ چاڭگىلىدىن قۇتقۇزغان پەرۋەردىگار ئوخشاشلا بۇ فىلىستىينىڭ قولىدىن قۇتقۇزىدۇ، دېدى. سائۇل داۋۇتقا: ــ بارغىن، پەرۋەردىگار سېنىڭ بىلەن بىللە بولغاي، دېدى.
\m 
\v 38 ئاندىن سائۇل داۋۇتقا ئۆز جەڭ كىيىملىرىنى كىيگۈزۈپ، بېشىغا مىس دۇبۇلغىنى تاقاپ ۋە ئۇنىڭغا بىر جەڭ ساۋۇتىنى كىيگۈزدى.
\v 39 داۋۇت بولسا سائۇلنىڭ قىلىچىنى كىيىمنىڭ ئۈستىگە ئېسىپ، مېڭىپ باقتى؛ چۈنكى ئۇ بۇلارنى كىيىپ باقمىغانىدى. شۇنىڭ بىلەن داۋۇت سائۇلغا: ــ مەن بۇلارنى كىيىپ ماڭالمايدىكەنمەن؛ چۈنكى بۇرۇن كىيىپ باقمىغان، دەپ ئۇلارنى سېلىۋەتتى.
\v 40 ئۇ قولىغا ھاسىسىنى ئېلىپ، ئېرىقتىن بەش سىلىق تاش ئىلغاپ پادىچى خالتىسىنىڭ يانچۇقىغا سالدى؛ ئۇ سالغۇسىنى قولىغا ئېلىپ فىلىستىيگە يېقىن باردى.
\v 41 فىلىستىي بولسا چىقىپ داۋۇتقا يېقىنلاشتى، قالقان كۆتۈرگۈچىسىمۇ ئۇنىڭ ئالدىدا ماڭدى.
\m 
\v 42 فىلىستىي داۋۇتقا بىرقۇر سەپسېلىپ قاراپ مەسخىرە قىلدى. چۈنكى ئۇ تېخى ياش، بۇغداي ئۆڭلۈك ۋە كېلىشكەن يىگىت ئىدى.
\v 43 فىلىستىي داۋۇتقا: ــ سەن ھاسا كۆتۈرۈپ ئالدىمغا كەپسەن؟ سەن مېنى ئىت دەپ ئويلاپ قالدىڭمۇ؟ ــ دەپ ئۆز بۇتلىرىنىڭ ناملىرىنى تىلغا ئېلىپ داۋۇتنى قارغىدى.
\v 44 فىلىستىي داۋۇتقا يەنە: ــ بۇ ياققا كەل، مەن گۆشۈڭنى ئاسماندىكى ئۇچار-قاناتلارغا ۋە دالالاردىكى يىرتقۇچلارغا يەم قىلىمەن، دېدى.
\m 
\v 45 داۋۇت فىلىستىيكە: ــ سەن قىلىچ، نەيزە ۋە ئاتما نەيزىنى كۆتۈرۈپ ماڭا ھۇجۇم قىلغىلى كەلدىڭ؛ لېكىن مەن سەن ھاقارەت قىلغان، ئىسرائىلنىڭ قوشۇنلىرىنىڭ خۇداسى بولغان پەرۋەردىگارنىڭ نامى بىلەن ئالدىڭغا ھۇجۇمغا چىقتىم ــ دېدى.
\m 
\v 46 «دەل بۈگۈن پەرۋەردىگار سېنى مېنىڭ قولۇمغا تاپشۇرىدۇ. مەن سېنى ئۆلتۈرۈپ بېشىڭنى كېسىپ ئالىمەن؛ مەن لەشكەرگاھدىكى فىلىستىيلەرنىڭ جەسەتلىرىنىمۇ ئاسماندىكى ئۇچار-قاناتلارغا ۋە دالالاردىكى يىرتقۇچلىرىغا يەم قىلىمەن. بۇنىڭ بىلەن پۈتكۈل جاھان ئىسرائىلدا بىر خۇدانىڭ بار ئىكەنلىكىنى بىلىدۇ
\v 47 ۋە بۇ پۈتكۈل جامائەت پەرۋەردىگارنىڭ نۇسرەت بېرىشىنىڭ قىلىچ، نەيزە بىلەن ئەمەس ئىكەنلىكىنى بىلىدۇ؛ چۈنكى بۇ جەڭ بولسا پەرۋەردىگارنىڭكىدۇر، ئۇ سېنى قولىمىزغا تاپشۇرىدۇ».
\m 
\v 48 فىلىستىي داۋۇتقا ھۇجۇم قىلغىلى قوپۇپ يېقىن كەلگەندە داۋۇت ئۇنىڭغا ھۇجۇم قىلغىلى فىلىستىي قوشۇنىنىڭ سېپىگە قاراپ يۈگۈردى.
\v 49 داۋۇت قولىنى خالتىسىغا تىقىپ بىر تاشنى چىقىرىپ سالغۇغا سېلىپ فىلىستىيگە قارىتىپ ئاتتى؛ تاش فىلىستىينىڭ پېشانىسىگە تەگدى. تاش ئۇنىڭ پېشانىسىگە پېتىپ كەتتى، ئۇ دۈم چۈشۈپ يەرگە يىقىلدى.
\m 
\v 50 شۇنداق قىلىپ داۋۇت فىلىستىينى سالغۇ ۋە تاش بىلەن مەغلۇپ قىلىپ ئۇنى ئۇرۇپ ئۆلتۈردى؛ داۋۇتنىڭ قولىدا ھېچ قىلىچ يوق ئىدى.
\v 51 داۋۇت يۈگۈرۈپ بېرىپ، فىلىستىينىڭ ئۈستىدە تۇرۇپ، قىلىچىنى قىنىدىن تارتىپ ئېلىپ ئۇنى ئۆلتۈرۈپ، ئۇنىڭ بېشىنى ئالدى. فىلىستىيلەر ئۆز باتۇرىنىڭ ئۆلگىنىنى كۆرۈپلا، بەدەر قاچتى.
\v 52 ئىسرائىللار بىلەن يەھۇدالار بولسا ئورنىدىن قوپۇپ سۆرەن سېلىشىپ فىلىستىيلەرنى جىلغىغىچە ۋە ئەكرون دەرۋازىلىرىغىچە كەينىدىن قوغلاپ كەلدى؛ ئۆلتۈرۈلگەن فىلىستىيلەر شائارائىمغا بارىدىغان يولدا گات ۋە ئەكرونغىچە يېتىپ كەتكەنىدى.
\v 53 ئىسرائىل فىلىستىيلەرنى قوغلاشتىن يېنىپ كېلىپ ئۇلارنىڭ لەشكەرگاھىنى بۇلاڭ-تالاڭ قىلدى.
\v 54 داۋۇت فىلىستىينىڭ بېشىنى يېرۇسالېمغا ئېلىپ باردى؛ ئۇنىڭ يارىغىنى بولسا ئۆز چېدىرىغا قويدى.
\m 
\v 55 سائۇل داۋۇتنىڭ فىلىستىينىڭ ئالدىغا چىققىنىنى كۆرگەندە قوشۇننىڭ سەردارى ئابنەردىن: ــ ئى ئابنەر، بۇ يىگىت كىمنىڭ ئوغلى؟ ــ دەپ سورىدى. ئابنەر: ــ ئى پادىشاھ، ھاياتىڭ بىلەن قەسەم قىلىمەنكى، بىلمەيمەن، دېدى.
\m 
\v 56 پادىشاھ: ــ بۇ يىگىت كىمنىڭ ئوغلى ئىكەن دەپ سوراپ باققىن، دېدى.
\m 
\v 57 داۋۇت فىلىستىينى قىرىپ قايتىپ كەلگەندە ئابنەر ئۇنى پادىشاھنىڭ قېشىغا ئېلىپ باردى؛ فىلىستىينىڭ بېشى تېخىچە ئۇنىڭ قولىدا تۇراتتى.
\m 
\v 58 سائۇل ئۇنىڭدىن: ــ ئى يىگىت، كىمنىڭ ئوغلىسەن؟ دەپ سورىدى. داۋۇت: ــ مەن سىلىنىڭ قۇللىرى بەيت-لەھەملىك يەسسەنىڭ ئوغلىمەن، دەپ جاۋاب بەردى.
\b
\b
\c 18
\s1 سائۇلنىڭ داۋۇتتىن ھەسەت قىلىشى
\m 
\v 1 داۋۇت بىلەن سائۇلنىڭ سۆھبىتى ئاياغلاشقاندا، يوناتاننىڭ كۆڭلى داۋۇتنىڭ كۆڭلىگە شۇنداق باغلاندىكى، ئۇنى ئۆز جېنىدەك سۆيدى.
\v 2 سائۇل بولسا ئۇ كۈنى ئۇنى ئۆز يېنىدا ئېلىپ قېلىپ، ئۇنى ئاتىسىنىڭ ئۆيىگە قايتقىلى قويمىدى.
\m 
\v 3 يوناتان داۋۇت بىلەن ئەھدە قىلىشتى؛ چۈنكى ئۇ ئۇنى ئۆز جېنىدەك سۆيەتتى.
\v 4 يوناتان ئۇچىسىدىكى توننى سېلىپ داۋۇتقا بەردى، يەنە جەڭ كىيىملىرىنى، جۈملىدىن ھەتتا قىلىچى، ئوقياسى ۋە كەمىرىنىمۇ ئۇنىڭغا بەردى.
\v 5 سائۇل داۋۇتنى نەگىلا ئەۋەتسە ئۇ شۇ يەرگە باراتتى، شۇنداقلا ئىشلارنى جايىدا قىلاتتى. شۇنىڭ ئۈچۈن سائۇل ئۇنى لەشكەرلەرنىڭ ئۈستىگە قويدى. بۇ ئىش بارلىق خەلققە ۋە ھەم سائۇلنىڭ خىزمەتكارلىرىغىمۇ ياقتى.
\m 
\v 6 داۋۇت فىلىستىينى ئۆلتۈرۈپ كۆپچىلىك بىلەن يانغاندا ئىسرائىلنىڭ ھەممە شەھەرلىرىدىكى قىز-ئاياللار سائۇلنى ناخشا ئېيتىپ ئۇسسۇل ئويناپ قارشى ئالغىلى چىقتى؛ ئۇلار خۇشلۇق ئىچىدە داپ ۋە ئۈچتار بىلەن نەغمە چېلىشتى.
\v 7 قىز-ئاياللار نەغمە چالغاندا: ــ سائۇل مىڭلاپ ئۆلتۈردى، ۋە داۋۇت ئون مىڭلاپ ئۆلتۈردى، دەپ ئوقۇشاتتى. \x ◘ \xo 18:7 \xt مىس. 15‏:21؛ 1سام. 21‏:11؛ 29‏:5\x*
\m 
\v 8 بۇنى ئاڭلاپ سائۇل ناھايىتى خاپا بولدى؛ بۇ سۆز ئۇنىڭ كۆڭلىگە تەگدى. ئۇ: ــ داۋۇتقا ئون مىڭلاپ ھېسابلاندى، ئەمما ماڭا پەقەت مىڭلاپ ھېسابلاندى؛ ئەمدى پادىشاھلىقتىن باشقا ئۇنىڭغا ھېچنەرسە كەم ئەمەس، دېدى.
\v 9 شۇ كۈندىن تارتىپ سائۇل داۋۇتنى كۆزلەپ يۈردى.
\m 
\v 10 ئەتىسى خۇدا تەرىپىدىن قاباھەتلىك بىر روھ سائۇلنىڭ ئۈستىگە چۈشتى ۋە ئۇ ئۆيىدە قالايمىقان جۆيلىگىلى تۇردى. ئەمدى داۋۇت باشقا ۋاقىتتىكىدەك قولى بىلەن چىلتار چالدى؛ سائۇلنىڭ قولىدا نەيزە بار ئىدى. \f ◼ \fr 18:10 \ft \bd «ئەتىسى خۇدا تەرىپىدىن قاباھەتلىك بىر روھ سائۇلنىڭ ئۈستىگە چۈشتى ۋە ئۇ ئۆيىدە قالايمىقان جۆيلىگىلى تۇردى»\bd* ــ ئىبرانىي تىلىدا مۇشۇ ئايەتتىكى «جۆيلۈش» «ئۇرغۇپ چىقىش» دېگەن سۆز بىلەن ئىپادىلىنىدۇ. باشقا ئەھۋالدا بۇ سۆز «بېشارەت بېرىش»نى كۆرسىتىدۇ.\f*
\v 11 سائۇل: ــ داۋۇتنى تامغا نەيزە بىلەن قادىۋېتىمەن دەپ، نەيزىنى ئاتتى؛ لېكىن داۋۇت ئىككى قېتىم ئۆزىنى دالدىغا ئالدى.
\m 
\v 12 پەرۋەردىگارنىڭ داۋۇت بىلەنلا بولۇپ، ئۆزىدىن يىراقلاپ كەتكىنى ئۈچۈن سائۇل داۋۇتتىن قورقاتتى.
\v 13 شۇنىڭ ئۈچۈن سائۇل داۋۇتنى ئۆز يېنىدىن ئايرىپ، ئۇنى لەشكەرلەرگە مىڭبېشى قىلىپ قويدى؛ ئۇ لەشكەرلەرنى ئېلىپ جەڭگە چىقىپ تۇراتتى. \f ◼ \fr 18:13 \ft \bd «ئۇ لەشكەرلەرنى ئېلىپ جەڭگە چىقىپ تۇراتتى»\bd* ــ ئىبرانىي تىلىدا «ئۇ لەشكەرلەر (خەلق) ئالدىدا چىقىپ كىرەتتى» دېگەن سۆز بىلەن ئىپادىلىنىدۇ.\f*
\m 
\v 14 داۋۇت بولسا ھەممە ئىشلارنى پەم بىلەن قىلاتتى؛ چۈنكى پەرۋەردىگار ئۇنىڭ بىلەن بىللە ئىدى.
\v 15 سائۇل ئۇنىڭ پەملىك ئىكەنلىكىنى كۆرۈپ ئۇنىڭدىن بەك قورقاتتى.
\m 
\v 16 ئەمما پۈتكۈل ئىسرائىل بىلەن يەھۇدا خەلقى داۋۇتنى سۆيەتتى؛ چۈنكى ئۇ ئۇلارنى يېتەكلەپ جەڭگە چىقاتتى. \f ◼ \fr 18:16 \ft \bd «چۈنكى ئۇ ئۇلارنى يېتەكلەپ جەڭگە چىقاتتى»\bd* ــ ئىبرانىي تىلىدا «چۈنكى ئۇ ئۇلار ئالدىدا چىقىپ كىرەتتى».\f*
\v 17 سائۇل داۋۇتقا: ــ مانا، چوڭ قىزىم مېراب ــ مەن ئۇنى ساڭا خوتۇنلۇققا بەرگۈم بار. سەن پەقەت خىزمىتىمگە جان-پىدا بولۇپ، پەرۋەردىگارنىڭ جەڭلىرىدە كۈرەش قىلغىن، دېدى. چۈنكى سائۇل ئىچىدە: ــ ئۇ مېنىڭ قولۇم بىلەن ئەمەس، بەلكى فىلىستىيلەرنىڭ قولى بىلەن يوقىتىلسۇن، دەپ خىيال قىلغانىدى.
\m 
\v 18 ئەمما داۋۇت سائۇلغا: ــ مەن كىم ئىدىم، مېنىڭ ئاتامنىڭ جەمەتى ئىسرائىل ئارىسىدا نېمە ئىدى، مەن قانداقمۇ پادىشاھنىڭ كۈيئوغلى بولاي؟ ــ دېدى.
\m 
\v 19 لېكىن سائۇلنىڭ قىزى مېراب داۋۇتقا بېرىلىدىغان ۋاقىتتا، ئۇ مەھولاتلىق ئادرىئەلگە خوتۇنلۇققا بېرىلدى.
\v 20 ئەمما سائۇلنىڭ قىزى مىقالنىڭ كۆڭلى داۋۇتقا چۈشكەنىدى. باشقىلار بۇنى سائۇلغا ئېيتتى، بۇ ئىشتىن سائۇل خۇش بولدى.
\v 21 سائۇل: ــ قىزىمنى داۋۇتقا بېرەي، ئۇ ئۇنىڭغا بىر سىرتماق بولۇپ، فىلىستىيلەرنىڭ قولىدا يوقىتىلسۇن، دەپ ئويلىدى. شۇنىڭ بىلەن سائۇل داۋۇتقا: ــ بۈگۈن ئىككىنچى قېتىم كۈيئوغلۇم بولىسەن، دېدى. \f ◼ \fr 18:21 \ft \bd «بۈگۈن ئىككىنچى قېتىم كۈيئوغلۇم بولىسەن»\bd* ــ ياكى «بۈگۈن ئىككىدىن بىرىدە (دېمەك، ئىككى قىزىمدىن بىرىدە) كۈيئوغلۇم بولىسەن».\f*
\m 
\v 22 سائۇل ئۆز غۇلاملىرىغا: ــ داۋۇتقا ئاستىرتىن: ــ مانا، پادىشاھ سەندىن سۆيۈنىدۇ، ۋە ھەممە غۇلاملىرى ساڭا ئامراق. شۇنىڭ ئۈچۈن پادىشاھنىڭ كۈيئوغلى بولغىن، دەپ ئېيتىڭلار، دەپ تاپىلىدى.
\v 23 سائۇلنىڭ غۇلاملىرى بۇ سۆزلەرنى داۋۇتنىڭ قۇلىقىغا يەتكۈزدى. لېكىن داۋۇت: ــ نەزىرىڭلاردا پادىشاھنىڭ كۈيئوغلى بولۇش كىچىك ئىشمۇ؟ مەن بولسام بىر كەمبەغەل ۋە ئەتىۋارسىز ئادەممەن ــ دېدى.
\m 
\v 24 سائۇلنىڭ غۇلاملىرى سائۇلغا داۋۇتنىڭ دېگەنلىرىنى ئۆز ئەينى يەتكۈزدى.
\m 
\v 25 سائۇل: ــ سىلەر داۋۇتقا: ــ پادىشاھ ساڭا باشقا تويلۇق ئالغۇزمايدۇ، پەقەت پادىشاھ دۈشمەنلىرىدىن ئىنتىقام ئېلىش ئۈچۈن يۈز فىلىستىينىڭ خەتنىلىكىنىلا ئالىدۇ، دەپ ئېيتىڭلار، دېدى (سائۇلنىڭ مەقسىتى بولسا داۋۇتنى فىلىستىيلەرنىڭ قولىدا يوقىتىش ئىدى).
\m 
\v 26 غۇلاملار بۇ سۆزلەرنى داۋۇتقا يەتكۈزدى؛ پادىشاھنىڭ كۈيئوغلى بولۇش داۋۇتقا يېقىپ قالدى. ئەمدى بېكىتىلگەن مۆھلەت توشمايلا،
\v 27 داۋۇت تۇرۇپ ئۆز ئادەملىرى بىلەن چىقىپ ئىككى يۈز فىلىستىينى ئۆلتۈردى. داۋۇت ئۇلارنىڭ خەتنىلىكىنى كېسىپ ئېلىپ پادىشاھنىڭ كۈيئوغلى بولۇش ئۈچۈن بۇلارنىڭ ھەممىسىنى پادىشاھقا تاپشۇردى. سائۇل قىزى مىقالنى ئۇنىڭغا خوتۇنلۇققا بەردى. \x ◘ \xo 18:27 \xt 2سام. 3‏:14\x*
\m 
\v 28 سائۇل پەرۋەردىگارنىڭ داۋۇت بىلەن بىللە ئىكەنلىكىنى ۋە ئۆز قىزى مىقالنىڭ ئۇنى سۆيىدىغانلىقىنى كۆرۈپ
\v 29 داۋۇتتىن تېخىمۇ قورقتى. شۇنىڭ بىلەن سائۇل ئۈزلۈكسىز داۋۇتقا دۈشمەن بولدى.
\m 
\v 30 فىلىستىيلەرنىڭ ئەمىرلىرى دائىم سوقۇشقا چىقاتتى؛ ئەمما ھەر قېتىم چىقسىلا داۋۇتنىڭ ئىشلىرى سائۇلنىڭ ھەممە خىزمەتكارلىرىنىڭكىدىن مۇۋەپپەقىيەتلىك بولاتتى؛ شۇنىڭ بىلەن ئۇنىڭ نامى \add خالايىق\add* تەرىپىدىن تولىمۇ ھۆرمەتكە سازاۋەر بولاتتى.
\b
\b
\c 19
\s1 سائۇل داۋۇتنى ئۆلتۈرۈشكە ئىنتىلىدۇ
\m 
\v 1 سائۇل ئۆز ئوغلى يوناتان ۋە ھەممە خىزمەتكارلىرىغا داۋۇتنى ئۆلتۈرۈشكە بۇيرۇق قىلدى. لېكىن سائۇلنىڭ ئوغلى يوناتان داۋۇتقا بەك ئامراق ئىدى.
\v 2 يوناتان داۋۇتقا: ــ ئاتام سائۇل سېنى ئۆلتۈرمەكچى؛ ئەمدى ئەتە ئەتىگەن قاتتىق ئېھتىيات قىلغىن، بىر مەخپىي جاينى تېپىپ ئۆزۈڭنى يوشۇرغىن؛
\v 3 مەن ئۆزۈم چىقىپ سەن يوشۇرۇنغان ئېتىزلىققا بېرىپ ئاتامنىڭ يېنىدا تۇرۇپ ئاتام بىلەن سېنىڭ توغراڭدا سۆزلىشىپ باقاي؛ ئەھۋالنى ئېنىق بىلگەندىن كېيىن ساڭا خەۋەر قىلاي، دېدى.
\m 
\v 4 يوناتان ئاتىسى سائۇلغا داۋۇتنىڭ ياخشى گېپىنى قىلىپ: ــ پادىشاھ ئۆز خىزمەتكارىغا، يەنى داۋۇتقا يامانلىق قىلمىغاي! چۈنكى ئۇ ساڭا گۇناھ قىلمىغان؛ بەلكى ئۇنىڭ ئەمەللىرى ئۆزۈڭگە كۆپ ياخشىلىقلارنى ئېلىپ كەلگەن: ــ
\v 5 ئۇ ئۆز جېنىنى ئالقىنىغا ئېلىپ قوپۇپ ھېلىقى فىلىستىينى ئۆلتۈردى ۋە شۇنىڭ بىلەن پەرۋەردىگار پۈتكۈل ئىسرائىل ئۈچۈن چوڭ نۇسرەت بەردى. شۇ چاغدا سەن ئۆزۈڭ كۆرۈپ خۇش بولغان ئەمەسمۇ؟ ئەمدىلىكتە نېمىشقا داۋۇتنى سەۋەبسىز ئۆلتۈرۈپ ناھەق قان تۆكۈپ گۇناھكار بولماقچى بولىسەن؟ ــ دېدى.
\m 
\v 6 سائۇل يوناتاننىڭ سۆزىگە كىردى. ئۇ: ــ پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، ئۇ ئۆلۈمگە مەھكۇم قىلىنمايدۇ، دېدى.
\v 7 ئاندىن يوناتان داۋۇتنى چاقىرىپ، داۋۇتقا بولغان ئىشلارنىڭ ھەممىسىنى دەپ بەردى. ئاندىن كېيىن يوناتان داۋۇتنى سائۇلنىڭ قېشىغا ئېلىپ كەلدى ۋە ئۇ ئىلگىرىكىدەك ئۇنىڭ خىزمىتىدە بولدى.
\m 
\v 8 ئەمما يەنە جەڭ بولدى؛ داۋۇت چىقىپ فىلىستىيلەر بىلەن جەڭ قىلىپ، ئۇلارنى قاتتىق قىرىپ مەغلۇپ قىلدى؛ ئۇلار ئۇنىڭ ئالدىدىن بەدەر قېچىستى.
\m 
\v 9 ئەمدى پەرۋەردىگار تەرىپىدىن قاباھەتلىك بىر روھ يەنە سائۇلنى باستى. ئۇ ئۆز ئۆيىدە قولىدا نەيزىسىنى تۇتۇپ ئولتۇراتتى؛ داۋۇت بولسا قولى بىلەن ساز چېلىپ تۇراتتى. \x ◘ \xo 19:9 \xt 1سام. 16‏:14؛ 18‏:10\x*
\v 10 سائۇل نەيزە بىلەن داۋۇتنى سانجىپ تامغا قاداپ قويماقچى بولىۋىدى، لېكىن داۋۇت ئۆزىنى قاچۇرۇۋالدى، نەيزە تامغا قادىلىپ قالدى. داۋۇت شۇ كېچىسى قېچىپ قۇتۇلدى.
\m 
\v 11 سائۇل بىرنەچچە چاپارمەنلەرنى داۋۇتنىڭ ئۆيىگە ئەۋەتىپ ئۇنى پايلاپ تۇرۇپ ئەتىسى تاڭ يورۇغاندا ئۇنى ئۆلتۈرۈشكە ماڭدۇردى. ئەمما داۋۇتنىڭ ئايالى مىقال ئۇنىڭغا: ــ ئەگەر بۇ كېچە جېنىڭنى ئېلىپ قاچمىساڭ، ئەتە ئۆلتۈرۈلىسەن، دېدى.
\v 12 شۇڭا مىقال داۋۇتنى پەنجىردىن چۈشۈرۈپ قويدى. شۇنداق قىلىپ ئۇ قېچىپ قۇتۇلدى.
\v 13 ئاندىن مىقال بىر «تەرافىم» بۇتنى ئېلىپ كارىۋاتقا ياتقۇزۇپ، بېشىغا ئۆچكە يۇڭىدىن قىلىنغان بىر ياستۇقنى قويۇپ، ئەدىيال بىلەن يېپىپ قويدى. \f ◼ \fr 19:13 \ft \bd «تەرافىم»\bd* ــ بىرخىل بۇت. مىقالنىڭ يېنىدا بۇنداق بۇتنىڭ بولۇشى تەۋراتقا خىلاپ، ئەلۋەتتە.\f*
\m 
\v 14 سائۇل داۋۇتنى تۇتۇش ئۈچۈن چاپارمەنلەرنى ئەۋەتكەندە مىقال: ــ ئۇ ئاغرىپ قالدى، دېدى.
\v 15 سائۇل چاپارمەنلەرنى \add قايتىدىن\add* ئەۋەتىپ: ــ ئۇنى كارىۋات بىلەن قوشۇپ ئېلىپ كېلىڭلار، ئۇنى ئۆلتۈرىمەن، دەپ بۇيرۇدى.
\m 
\v 16 چاپارمەنلەر كىرگەندە، مانا كارىۋاتتا بۇ بۇت ياتاتتى، بېشىغا ئۆچكە يۇڭىدىن قىلىنغان ياستۇق قويۇلغانىدى.
\v 17 سائۇل مىقالغا: ــ نېمىشقا مېنى بۇنداق ئالداپ، دۈشمىنىمنى قاچۇرۇۋېتىسەن؟ ــ دېدى. مىقال سائۇلغا جاۋاب بېرىپ: ــ ئۇ: «مېنى قويۇۋەتكىن؛ بولمىسا سېنى ئۆلتۈرۈۋېتىمەن» دېدى، دەپ جاۋاب بەردى. \f ◼ \fr 19:17 \ft \bd «ئۇ: «مېنى قويۇۋەتكىن؛ بولمىسا سېنى ئۆلتۈرۈۋېتىمەن» دېدى»\bd* ــ ئىبرانىي تىلىدا: «ئۇ: «مېنى قويۇۋەتكىن؛ سېنى ئۆلتۈرۈشۈمنىڭ نېمە ھاجىتى؟» دېدى».\f*
\m 
\v 18 داۋۇت قېچىپ قۇتۇلۇپ، راماھقا سامۇئىلنىڭ قېشىغا بېرىپ، سائۇلنىڭ ئۇنىڭغا قىلغانلىرىنىڭ ھەممىسىنى دەپ بەردى. ئاندىن ئۇ سامۇئىل بىلەن نايوتقا بېرىپ ئولتۇراقلاشتى.
\m 
\v 19 بىرسى سائۇلغا: ــ داۋۇت راماھدىكى نايوتتا بار ئىكەن، دەپ خەۋەر بەردى.
\v 20 سائۇل داۋۇتنى تۇتۇپ كېلىشكە چاپارمەنلەرنى ماڭدۇردى. ئەمما ئۇلار يېتىپ بارغاندا پەيغەمبەرلەرنىڭ بىر جامائىتى بېشارەت بېرىۋاتقانلىقىنى ۋە سامۇئىلنىڭمۇ ئۇلارنىڭ ئارىسىدا تۇرۇپ ئۇلارغا نازارەتچىلىك قىلىۋاتقانلىقىنى كۆردى؛ شۇنداق بولدىكى، خۇدانىڭ روھى سائۇلنىڭ چاپارمەنلىرىنىڭ ۋۇجۇدىغىمۇ چۈشۈپ، ئۇلارمۇ ھەم بېشارەت بېرىشكە باشلىدى.
\m 
\v 21 بۇ خەۋەر سائۇلغا ئېيتىلدى؛ ئۇ يەنە باشقا چاپارمەنلەرنى ئەۋەتتى، لېكىن ئۇلارمۇ بېشارەت بېرىشكە چۈشتى. ئاندىن سائۇل ئۈچىنچى قېتىم يەنە چاپارمەنلەرنى ماڭدۇردى. ئۇلارمۇ ھەم بېشارەت بېرىشكە چۈشتى.
\v 22 ئاندىن سائۇل ئۆزى راماھقا بېرىپ، سەقۇدىكى چوڭ قۇدۇققا يېتىپ كەلگەندە، «سامۇئىل بىلەن داۋۇت نەدە؟» ــ دەپ سورىدى. بىرسى: ــ ئۇلار راماھدىكى نايوتتا بار ئىكەن، دەپ جاۋاب بەردى.
\m 
\v 23 شۇڭا ئۇ راماھدىكى نايوتقا يېتىپ كەلدى؛ خۇدانىڭ روھى ئۇنىڭ ۋۇجۇدىغىمۇ چۈشتى؛ شۇنىڭ بىلەن ئۇمۇ پىيادە مېڭىپ راماھدىكى نايوتقا بارغۇچە بېشارەت بېرىپ ماڭدى.
\v 24 ئۇ ھەتتا كىيىملىرىنى سېلىۋېتىپ سامۇئىلنىڭ ئالدىدا بېشارەت بەردى؛ پۈتۈن بىر كېچە ۋە پۈتۈن بىر كۈندۈز ئۇ يەردە يالىڭاچ ياتتى. بۇنىڭ بىلەن: ــ «سائۇلمۇ پەيغەمبەرلەردىنمۇ؟» دەيدىغان گەپ پەيدا بولدى. \f ◼ \fr 19:24 \ft \bd «بۇنىڭ بىلەن: ــ «سائۇلمۇ پەيغەمبەرلەردىنمۇ؟» دەيدىغان گەپ پەيدا بولدى»\bd* ــ 10-باب، 12-ئايەت ۋە ئۇنىڭدىكى ئىزاھاتنى كۆرۈڭ.\f*
\b
\b
\c 20
\s1 يوناتان داۋۇتنى قوغدىماقچى
\m 
\v 1 داۋۇت راماھدىكى نايوتتىن قېچىپ يوناتاننىڭ قېشىغا بېرىپ ئۇنىڭغا: ــ مەن نېمە قىلىپتىمەن؟ نېمە قەبىھلىك قىلىپتىمەن؟ ئاتاڭ ئالدىدا نېمە گۇناھ قىلىپتىمەن، ئۇ مېنىڭ جېنىمنى ئالماقچى بولۇۋاتىدۇ؟ ــ دېدى.
\m 
\v 2 ئۇ ئۇنىڭغا: ــ يوقسۇ، بۇنداق ئىش نېرى بولسۇن! سەن ئۆلمەيسەن. چوڭ ئىش بولسۇن، كىچىك ئىش بولسۇن ئاتام ماڭا دېمەي قويمايدۇ. نېمىشقا ئاتام بۇ ئىشنى مەندىن يوشۇرىدىكىنە؟ ھەرگىز ئۇنداق بولمايدۇ، دېدى.
\m 
\v 3 لېكىن داۋۇت يەنە قەسەم قىلىپ: ــ ئاتاڭ سېنىڭ نەزىرىڭدە ئىلتىپات تاپقىنىمنى جەزمەن بىلىدۇ. شۇڭا ئۇ كۆڭلىدە: ــ يوناتان بۇنى بىلىپ قالمىسۇن؛ بولمىسا ئۇنىڭغا ئازار بولىدۇ، دېگەندۇ. لېكىن پەرۋەردىگارنىڭ ھاياتى بىلەن، جېنىڭ ۋە ھاياتىڭ بىلەن ئالدىڭدا قەسەم قىلىمەنكى، ماڭا ئۆلۈمنىڭ ئارىلىقى بىر قەدەملا قالدى، دېدى.
\m 
\v 4 يوناتان داۋۇتقا: ــ كۆڭلۈڭ نېمىنى خالىسا شۇنى قىلاي، دېدى.
\m 
\v 5 داۋۇت يوناتانغا مۇنداق دېدى: ــ مانا ئەتە «يېڭى ئاي» بولىدۇ؛ مەن ئادەتتىكىدەك پادىشاھ بىلەن ھەمداستىخان بولمىسام بولمايدۇ. لېكىن مېنى قويۇپ بەرگىن، مەن ئۈچىنچى كۈنى ئاخشىمىغىچە دالادا مۆكۈنۈۋالاي.
\v 6 ئاتاڭ مېنىڭ سورۇندا يوقلۇقىمنى كۆرۈپ سورىسا، سەن ئۇنىڭغا: «داۋۇت مەندىن ئۆز شەھىرى بەيت-لەھەمگە تېزراق بېرىپ كېلىشكە جىددىي رۇخسەت سورىدى، چۈنكى ئۇ يەردە پۈتكۈل ئائىلىسى ئۈچۈن بىر يىللىق قۇربانلىق ئۆتكۈزىدىكەن»، دېگىن، دېدى.
\v 7 ئەگەر ئۇ: ــ ئوبدان بوپتۇ، دېسە، قۇلۇڭ تىنچ-ئامان بولىدۇ: ــ لېكىن ئۇ ئاچچىقلانسا، ئۇنىڭ ماڭا يامانلىق قىلىشنى نىيەت قىلغانلىقىدىن گۇمان قىلمىغىن.
\v 8 سەن قۇلۇڭغا ئىلتىپات كۆرسەتكىن؛ چۈنكى سەن ئۆزۈڭ بىلەن پەرۋەردىگارنىڭ ئالدىدا قۇلۇڭنى ئەھدىلەشتۈرگەنسەن. لېكىن ئەگەر مەندە بىر يامانلىق بولسا سەن ئۆزۈڭلا مېنى ئۆلتۈرگىن؛ مېنى ئېلىپ بېرىپ ئاتاڭغا تاپشۇرۇشنىڭ نېمە ھاجىتى؟ ــ دېدى. \x ◘ \xo 20:8 \xt 1سام. 18‏:3\x*
\m 
\v 9 يوناتان: ــ ئۇنداق خىيال سەندىن نېرى بولسۇن! ئەگەر ئاتامنىڭ ساڭا يامانلىق قىلىدىغان نىيىتى بارلىقىنى بىلىپ قالسام، ساڭا دەيتتىم ئەمەسمۇ؟ ــ دېدى.
\m 
\v 10 داۋۇت يوناتانغا: ــ ئەگەر ئاتاڭ ساڭا قاتتىق گەپ بىلەن جاۋاب بەرسە، كىم ماڭا خەۋەر بېرىدۇ؟ ــ دېدى.
\m 
\v 11 يوناتان داۋۇتقا: ــ كەلگىن، دالاغا چىقايلى، دېدى. شۇنىڭ بىلەن ئىككىسى دالاغا چىقتى.
\v 12 يوناتان داۋۇتقا مۇنداق دېدى: ــ ئىسرائىلنىڭ خۇداسى پەرۋەردىگار ماڭا \add گۇۋاھكى\add*، مەن ئەتە ياكى ئۆگۈنلۈككە مۇشۇ ۋاقىتتا ئاتامنىڭ نىيىتىنى بىلىپ، ساڭا ئىلتىپاتلىق بولسا، مەن ئادەم ماڭدۇرۇپ ساڭا مەلۇم قىلمامدىم؟
\v 13 ئەگەر ئاتام ساڭا يامانلىق قىلماقچى بولسا، مەن سېنى تىنچ-ئامان يولغا سېلىش ئۈچۈن ساڭا ئادەم ئەۋەتىپ خەۋەر بەرمىسەم، پەرۋەردىگار ماڭا سېنىڭ بېشىڭغا چۈشكەندىنمۇ ئارتۇق چۈشۈرسۇن؛ ئەمدى پەرۋەردىگار ئاتام بىلەن بىللە بولغاندەك سېنىڭ بىلەن بىللە بولسۇن.
\m 
\v 14 ھاياتلا بولسام مېنى ئۆلمىسۇن دەپ پەرۋەردىگارنىڭ مېھرىبانلىقىنى ماڭا كۆرسەتكەيسەن.
\v 15 مەن ئۆلۈپ كەتكەن تەقدىردىمۇ، ئۆيدىكىلىرىمدىن ھەم ھېچ ۋاقىت مېھرىبانلىقىڭنى ئۈزمىگەيسەن؛ پەرۋەردىگار سەن داۋۇتنىڭ ھەممە دۈشمەنلىرىنى يەر يۈزىدىن يوقاتقاندىن كېيىنمۇ شۇنداق قىلغايسەن».
\m 
\v 16 شۇنىڭ بىلەن يوناتان داۋۇتنىڭ جەمەتى بىلەن ئەھدە قىلىشىپ: ــ پەرۋەردىگار داۋۇتنىڭ دۈشمەنلىرىدىن ھېساب ئالسۇن، دېدى.
\v 17 ئاندىن يوناتان يەنە ئۆزىنىڭ داۋۇتقا بولغان مۇھەببىتى بىلەن ئۇنىڭغا قەسەم قىلدۇردى؛ چۈنكى ئۇ ئۇنى ئۆز جېنىدەك سۆيەتتى.
\m 
\v 18 يوناتان داۋۇتقا مۇنداق دېدى: ــ ئەتە يېڭى ئاي بولىدۇ. مانا سېنىڭ ئورنۇڭ بوش قالىدۇ، كىشىلەر سېنىڭ يوقلۇقۇڭغا دىققەت قىلىدۇ.
\v 19 ئۈچىنچى كۈنى سەن چۈشۈپ ئالدىنقى قېتىم بۇ ئىشقا يولۇققىنىڭدا ئۆزۈڭنى يوشۇرغان جايغا بېرىپ «ئېزەل» دېگەن تاشنىڭ يېنىدا تۇرۇپ تۇرغىن.
\v 20 مەن تاشنىڭ يېنىدىكى بىر جايغا خۇددى نىشاننى قارالىغاندەك ئۈچ پاي يا ئوقى ئاتاي.
\m 
\v 21 ئاندىن غۇلامنى ماڭدۇرۇپ: ــ «يا ئوقلىرىنى تېپىپ كەلگىن» ــ دەيمەن. ئەگەر مەن غۇلامغا: ــ ئەنە، ئوقلار ئارقا تەرەپتە تۇرىدۇ، ئۇلارنى ئېلىپ كەل، دېسەم، سەن چىقىپ يېنىمغا كەلگىن؛ شۇنداق بولغاندا، پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، سەن ئۈچۈن تىنچ-ئامانلىق بولىدۇ، ھېچ ئىش بولمايدۇ.
\v 22 لېكىن غۇلامغا: ــ ئەنە، ئوقلار ئالدىڭدا تۇرىدۇ، دېسەم، سەن كەتكىن، چۈنكى ئۇنداق بولسا، پەرۋەردىگار سېنى كەتكۈزۈۋەتكەن بولىدۇ.
\v 23 ئەمدىلىكتە مەن بىلەن سەن سۆزلەشكەن ئىش توغرۇلۇق، پەرۋەردىگار سەن بىلەن مېنىڭ ئوتتۇرىمدا گۇۋاھچىدۇر.
\m 
\v 24 شۇنىڭ بىلەن داۋۇت دالادا مۆكۈنۈۋالدى. يېڭى ئاي كەلگەندە، پادىشاھ تائام يېگىلى داستىخاندا ئولتۇردى.
\v 25 پادىشاھ بولسا بۇرۇنقىدەكلا ئۆز ئورنىدا تامنىڭ يېنىدىكى تۆردە ئولتۇردى. يوناتان ئورنىدىن تۇردى، ئابنەر سائۇلنىڭ يېنىدا ئولتۇردى. لېكىن داۋۇتنىڭ ئورنى بوش قالدى. \f ◼ \fr 20:25 \ft \bd «پادىشاھ بولسا بۇرۇنقىدەكلا ئۆز ئورنىدا تامنىڭ يېنىدىكى تۆردە ئولتۇردى. يوناتان ئورنىدىن تۇردى، ئابنەر سائۇلنىڭ يېنىدا ئولتۇردى»\bd* ــ يوناتاننىڭ «ئورنىدىن تۇرۇشى» بەلكىم تاغىسى ئابنەرنىڭ ھۆرمىتى ئۈچۈن ئۇنىڭغا سائۇلنىڭ يېنىدىكى ئورۇننى بوشىتىش ئۈچۈن.\fp باشقا خىل تەرجىمىسى: «يوناتان ئۇنىڭ (سائۇلنىڭ) ئۇدۇلىدا ئىدى»\f*
\v 26 ئەمما سائۇل ئۇ كۈنى ھېچنېمە دېمىدى. چۈنكى ئۇ: ــ داۋۇتقا بىر ئىش بولدى، ئۇ ناپاك بولۇپ قالدى. ئۇ جەزمەن ناپاك بولۇپ قاپتۇ، دەپ ئويلىدى. \f ◼ \fr 20:26 \ft \bd «داۋۇتقا بىر ئىش بولدى، ئۇ ناپاك بولۇپ قالدىن»\bd* ــ «ناپاك بولۇش»: مۇسا پەيغەمبەرگە چۈشۈرۈلگەن قانۇن بويىچە، بىرسى مەسىلەن بىر ئۆلۈككە تەگكەن بولسا بىر مەزگىل «ناپاك» بولاتتى ــ شۇنداق بولسا ئۇنىڭ ھېچ قۇربانلىق (مەسىلەن، يېڭى ئايدىكى قۇربانلىقلار)دىن يېيىشىگە بولمايتتى.\f*
\v 27 لېكىن داۋۇتنىڭ ئورنى يېڭى ئاينىڭ ئەتىسىمۇ، يەنى ئاينىڭ ئىككىنچى كۈنىمۇ بوش ئىدى. سائۇل ئوغلى يوناتاندىن: ــ نېمىشقا يەسسەنىڭ ئوغلى ياكى تۈنۈگۈن ياكى بۈگۈن تاماققا كەلمەيدۇ، دەپ سورىدى.
\m 
\v 28 يوناتان سائۇلغا جاۋاب بېرىپ: ــ داۋۇت بەيت-لەھەمگە بارغىلى مەندىن جىددىي رۇخسەت سوراپ: ــ
\v 29 مېنىڭ بېرىشىمغا رۇخسەت قىلغىن، ئائىلىمىزنىڭ شەھەردە بىر قۇربانلىق ئىشى بولغاچ ئاكام مېنىڭ بېرىشىمنى ئېيتىپتۇ؛ ئەگەر سېنىڭ نەزىرىڭدە ئىلتىپات تاپقان بولسام قېرىنداشلىرىم بىلەن كۆرۈشۈپ كېلىشكە رۇخسەت بەرگىن، دېدى. شۇڭا ئۇ پادىشاھنىڭ داستىخىنىغا كەلمىدى، دېدى.
\m 
\v 30 سائۇلنىڭ يوناتانغا قاتتىق غەزىپى كېلىپ: ــ ئى بۇزۇق، كاج خوتۇننىڭ ئوغلى، نېمىشقا يەسسەنىڭ ئوغلىنى ئۆزۈڭگە تاللاپ، ئۆزۈڭنى شەرمەندە قىلىپ ۋە ئاناڭنى نومۇسقا قويغىنىڭنى بىلمەمدىمەن؟
\v 31 ئەگەر يەسسەنىڭ ئوغلى يەر يۈزىدە تىرىك بولسىلا، سەن ھەم سېنىڭ پادىشاھلىقىڭ مۇستەھكەم بولمايدۇ. شۇڭا ئەمدى ئادەم ئەۋەتىپ ئۇنى مېنىڭ قېشىمغا ئېلىپ كەلگىن، چۈنكى ئۇ ئۆلۈمگە مەھكۇمدۇر! ــ دېدى.
\m 
\v 32 يوناتان ئاتىسى سائۇلغا جاۋاب بېرىپ: ــ ئۇ نېمىشقا ئۆلۈمگە مەھكۇم قىلىنىشى كېرەك؟ ئۇ نېمە قىپتۇ؟ ــ دېدى.
\m 
\v 33 ئاندىن سائۇل يوناتانغا سانجىش ئۈچۈن ئۇنىڭغا نەيزىنى ئاتتى؛ بۇنىڭ بىلەن يوناتان ئاتىسىنىڭ داۋۇتنى ئۆلتۈرمەكچى بولغانلىقىنى ئېنىق بىلىپ يەتتى.
\v 34 يوناتان بولسا قاتتىق ئاچچىقلاپ داستىخاندىن قوپۇپ كەتتى ۋە يېڭى ئاينىڭ ئىككىنچى كۈنى ھېچ تائام يېمىدى. چۈنكى ئاتىسىنىڭ داۋۇتنى شۇنداق ھاقارەتلىشى ئۇنىڭغا قاتتىق ئازار بولغانىدى.
\m 
\v 35 ئەتىسى يوناتان دالاغا چىقىپ داۋۇت بىلەن كېلىشكەن جايغا باردى. ئۇنىڭ بىلەن بىر كىچىك غۇلام بىللە باردى.
\m 
\v 36 ئۇ غۇلامغا: ــ سەن يۈگۈر، مەن ئاتقان يا ئوقلىرىنى تېپىپ كەلگىن، دېدى. غۇلام يۈگۈردى، ئۇ بىر ئوقنى ئۇنىڭ ئالدى تەرىپىگە ئاتتى.
\v 37 غۇلام يوناتان ئاتقان ئوق چۈشكەن جايغا كەلگەندە يوناتان غۇلامنى چاقىرىپ: ــ ئوق سېنىڭ ئالدى تەرىپىڭدە تۇرمامدۇ؟ ــ دېدى.
\v 38 ئاندىن يوناتان غۇلامنى يەنە چاقىرىپ: ــ بول، ئىتتىك بول، ھايال بولمىغىن! ــ دېدى. يوناتاننىڭ غۇلامى يا ئوقىنى يىغىپ غوجىسىغا ئېلىپ كەلدى.
\v 39 لېكىن غۇلامنىڭ بولغان ئىشتىن خەۋىرى يوق ئىدى. بۇنى يالغۇز يوناتان بىلەن داۋۇتلا بىلەتتى.
\m 
\v 40 ئاندىن يوناتان غۇلامىغا ياراغلىرىنى بېرىپ ئۇنىڭغا: ــ ئۇلارنى شەھەرگە ئېلىپ كەتكىن، دېدى.
\m 
\v 41 غۇلام كەتكەندىن كېيىن داۋۇت \add تاشنىڭ\add* جەنۇب تەرىپىدىن چىقىپ يەرگە يىقىلىپ ئۈچ قېتىم تەزىم قىلدى. ئۇلار بىر-بىرىنى سۆيۈشتى، بىر-بىرىگە ئېسىلىشىپ يىغلاشتى، بولۇپمۇ داۋۇت قاتتىق يىغلىدى.
\m 
\v 42 يوناتان داۋۇتقا: ــ سەپىرىڭ تىنچ-ئامان بولسۇن؛ چۈنكى بىز ئىككىمىز: ــ پەرۋەردىگار مېنىڭ بىلەن سېنىڭ ئوتتۇرۇڭدا ۋە مېنىڭ نەسلىم بىلەن سېنىڭ نەسلىڭ ئوتتۇرىسىدا مەڭگۈگە گۇۋاھ بولسۇن، دەپ پەرۋەردىگارنىڭ نامى بىلەن قەسەم ئىچىشكەن، دېدى. داۋۇت ئورنىدىن قوپۇپ ماڭدى، يوناتانمۇ شەھەرگە كىرىپ كەتتى.
\b
\b
\c 21
\s1 داۋۇت نوب شەھىرىگە بارىدۇ
\m 
\v 1 داۋۇت ئەمدى نوبقا كېلىپ ئاخىمەلەك كاھىننىڭ قېشىغا باردى.
\v 2 لېكىن ئاخىمەلەك داۋۇتنى كۆرگەندە تىترەپ قورقۇپ ئۇنىڭغا: ــ نېمىشقا بىرىمۇ سەن بىلەن كەلمەي يالغۇز كەلدىڭ؟ ــ دېدى.
\m 
\v 3 داۋۇت ئاخىمەلەك كاھىنغا: ــ پادىشاھ ماڭا مەلۇم بىر ئىشنى بۇيرۇپ: ــ مەن ساڭا بۇيرۇغان ئىش ياكى ساڭا تاپىلغان يوليورۇق توغرىسىدىن ھېچكىم بىرنېمە بىلمىسۇن، دېگەنىدى. ئۆز غۇلاملىرىمنى بولسا مەلۇم بىر جايغا بېرىشقا بېكىتىپ قويدۇم.
\v 4 ئەمدى قولۇڭدا نېمە بار؟ بەش نان، ياكى نېمە بولسا، شۇنى ماڭا بەرگىن، دېدى.
\m 
\v 5 كاھىن داۋۇتقا جاۋاب بېرىپ: ــ قولۇمدا ئادەتتىكى نان يوق، پەقەت مۇقەددەس نان بار. ئەگەر غۇلاملار ئاياللارغا يېقىنلاشمىغان بولسا يېسە راۋا بولىدۇ، دېدى.
\m 
\v 6 داۋۇت كاھىنغا جاۋاب بېرىپ: ــ بەرھەق، مەن باشقا ۋاقىتلاردا چىققىنىمغا ئوخشاش، ئاياللار بىزدىن يىراق بولغىلى ئۈچ كۈن بولدى. مەن \add ھەرقېتىم\add* چىققاندا، گەرچە ئادەتتىكى سەپەر بولسىمۇ، غۇلاملارنىڭ قاچىلىرى پاك بولىدىغان يەردە، بۈگۈن ئۇلار ۋە قاچىلىرى تېخىمۇ پاك بولمامدۇ، دېدى. \f ◼ \fr 21:6 \ft \bd «...گەرچە ئادەتتىكى سەپەر بولسىمۇ، غۇلاملارنىڭ قاچىلىرى پاك بولىدىغان يەردە، بۈگۈن ئۇلار ۋە قاچىلىرى تېخىمۇ پاك بولمامدۇ»\bd* ــ باشقا نەچچە تەرجىمىسى ئۇچرىشى مۇمكىن.\f*
\m 
\v 7 شۇنىڭ بىلەن كاھىن ئۇنىڭغا مۇقەددەس ناندىن بەردى، چۈنكى بۇ يەردە «تەقدىم نان»دىن باشقا ھېچقانداق نان يوق ئىدى. بۇ نان پەرۋەردىگارنىڭ ھۇزۇرىغا يېڭى ئىسسىق نان قويۇلغان كۈنى ئالماشتۇرۇلغان نانلار ئىدى \f ◼ \fr 21:7 \ft \bd «چۈنكى بۇ يەردە «تەقدىم نان»دىن باشقا ھېچقانداق نان يوق ئىدى»\bd* ــ «تەقدىم نان»: ــ ياكى «(خۇدانىڭ) ھۇزۇرى نېنى»، ياكى «تىزىلغان نان». «مىس.» 25- ۋە 35-بابنى كۆرۈڭ.\f*  \x ◘ \xo 21:7 \xt مات. 12‏:3؛ مار. 2‏:25؛ لۇقا 6‏:3\x*
\v 8 (لېكىن ئۇ كۈنى سائۇلنىڭ خىزمەتكارلىرىدىن مەلۇم بىرسى ئۇ يەردە پەرۋەردىگارنىڭ ھۇزۇرىدا قالدۇرۇلغانىدى. ئۇنىڭ ئىسمى دوئەگ بولۇپ سائۇلنىڭ پادىچىلىرىنىڭ چوڭى ئىدى).
\m 
\v 9 داۋۇت ئاخىمەلەككە: ــ قولۇڭدا نەيزە ياكى قىلىچ يوقمۇ؟ پادىشاھ تاپشۇرغان ئىش جىددىي بولغاچ ياكى قىلىچ ياكى باشقا ياراغلىرىمنى ئېلىپ كېلەلمىدىم، دېدى.
\m 
\v 10 كاھىن: ــ سەن ئېلاھ جىلغىسىدا ئۆلتۈرگەن فىلىستىي گولىئاتنىڭ قىلىچى بۇ يەردە بار، ئۇ ئەفودنىڭ كەينىدە، بىر پارچە رەختكە ئوراقلىق ھالدا تۇرىدۇ. خالىساڭ ئالغىن، ئۇنىڭدىن باشقىسى يوق، دېدى. داۋۇت: ــ بۇ تەڭدىشى يوق قىلىچتۇر، شۇنى ماڭا بەرگىن، دېدى.
\m 
\v 11 داۋۇت ئۇ كۈنى قوپۇپ سائۇلدىن قېچىپ گاتنىڭ پادىشاھى ئاقىشنىڭ قېشىغا باردى.
\m 
\v 12 لېكىن ئاقىشنىڭ خىزمەتكارلىرى ئۇنىڭغا: ــ بۇ زېمىننىڭ پادىشاھى داۋۇت ئەمەسمۇ؟ ئۇنىڭ توغرىسىدا قىز-ئاياللار بىر-بىرىگە: ــ
\m سائۇل مىڭلاپ ئۆلتۈردى،
\m ۋە داۋۇت ئون مىڭلاپ ئۆلتۈردى،
\m ــ دەپ ناخشا-غەزەل ئوقۇشۇپ ئۇسسۇل ئوينىغان ئەمەسمۇ، دېدى. \x ◘ \xo 21:12 \xt 1سام. 18‏:7\x*
\m 
\v 13 داۋۇت بۇ سۆزلەرنى كۆڭلىگە پۈكۈپ گاتنىڭ پادىشاھى ئاقىشتىن بەك قورقتى.
\v 14 شۇنىڭ ئۈچۈن ئۇلارنىڭ كۆز ئالدىدا ئۆزىنىڭ يۈرۈش-تۇرۇشلىرىنى ئۆزگەرتىپ، ئۇلارنىڭ قولىدا تۇرغان ۋاقتىدا ئۆزىنى ساراڭدەك كۆرسەتتى؛ ئۇ دەرۋازىلارنىڭ ئىشىكلىرىگە جىجىپ، تۈكۈرۈكىنى ساقىلىغا ئاقتۇراتتى.
\m 
\v 15 ئاقىش خىزمەتكارلىرىغا: ــ مانا بۇ ئادەمنىڭ ساراڭلىقىنى كۆرمەمسىلەر؟ ئۇنى نېمىشقا مېنىڭ ئالدىمغا ئېلىپ كەلدىڭلار؟
\v 16 مەندە ساراڭلار كەمچىلمىدى؟ سىلەر بۇ كىشىنى ئالدىمغا ساراڭلىق قىلغىلى ئېلىپ كەلدىڭلارمۇ؟ بۇ ئادەم مېنىڭ ئۆيۈمگە كىرىشى كېرەكمۇ؟ ــ دېدى.
\b
\b
\c 22
\s1 داۋۇت مىزپاھ ۋە ئادۇللامغا بارىدۇ
\m 
\v 1 داۋۇت ئۇ يەردىن كېتىپ ئادۇللامدىكى غارغا قاچتى. ئۇنىڭ قېرىنداشلىرى بىلەن ئاتىسىنىڭ پۈتكۈل جەمەتى بۇنى ئاڭلاپ ئۇنىڭ قېشىغا باردى.
\v 2 ئېزىلگەن، قەرزدار بولغان ۋە دەردمەنلەرنىڭ ھەممىسى يىغىلىپ ئۇنىڭ يېنىغا كەلدى ۋە ئۇ ئۇلارنىڭ سەردارى بولدى. ئۇنىڭغا قوشۇلغان ئادەملەر بولسا تۆت يۈزچە ئىدى.
\m 
\v 3 داۋۇت ئۇ يەردىن چىقىپ موئابدىكى مىزپاھقا بېرىپ موئابنىڭ پادىشاھىدىن: ــ خۇدانىڭ مېنى نېمە قىلىدىغىنىنى بىلگۈچە، ئاتا-ئانامنىڭ بۇ يەرگە كېلىپ ئاراڭلاردا تۇرۇشىغا يول قويغايلا، دەپ تەلەپ قىلدى. \f ◼ \fr 22:3 \ft \bd «موئابدىكى مىزپاھ»\bd* ــ ياكى «موئابدىكى مىزپەھ».\f*
\v 4 داۋۇت ئاتىسى ۋە ئانىسىنى موئابنىڭ پادىشاھىنىڭ قېشىغا ئېلىپ كەلدى. داۋۇت قورغاندا تۇرغان پۈتكۈل كۈنلەردە ئاتا-ئانىسى ئۇنىڭ بىلەن بىللە تۇردى.
\m 
\v 5 ئەمما گاد پەيغەمبەر داۋۇتقا: ــ قورغاندا تۇرماي، بۇ يەردىن چىقىپ، يەھۇدا زېمىنىغا بارغىن، دېدى. شۇنىڭ بىلەن داۋۇت ئۇ يەردىن ئايرىلىپ، ھەرەت ئورمانلىقىغا باردى.
\b
\s1 سائۇل نوبدىكى كاھىنلارنى ئۆلتۈرىدۇ
\m 
\v 6 سائۇل داۋۇتنىڭ نەدە تۇرۇۋاتقانلىقىدىن خەۋەر تاپتى. سائۇل بۇ ۋاقىتتا راماھدىكى گىبېئاھدا ئېگىز بىر جايدا يۇلغۇن دەرىخىنىڭ تۈۋىدە ئولتۇراتتى. ئۇنىڭ قولىدا نەيزىسى بار ئىدى، بارلىق خىزمەتكارلىرى چۆرىسىدە تۇراتتى.
\v 7 سائۇل چۆرىسىدە تۇرغان خىزمەتكارلىرىغا: ــ ئى بىنيامىنلىقلار، قۇلاق سېلىڭلار! يەسسەنىڭ ئوغلى ھەر بىرىڭلارغا ئېتىزلار بىلەن ئۈزۈمزارلارنى تەقسىم قىلىپ بېرەمدۇ؟ ھەممىڭلارنى مىڭ بېشى ۋە يۈز بېشى قىلامدۇ؟
\v 8 سىلەر ھەممىڭلار ماڭا قەست قىلدىڭلار، ئۆز ئوغلۇمنىڭ يەسسەنىڭ ئوغلى بىلەن ئەھدە قىلىشقىنىنى ھېچكىم ماڭا ئۇقتۇرمىدى. ھېچ قايسىڭلار ماڭا ئىچ ئاغرىتمىدىڭلار ياكى ئۆز ئوغلۇمنىڭ مېنىڭ خىزمەتكارىمنى ماڭا يوشۇرۇن ھۇجۇم قىلىشقا قۇتراتقىنىدىن ماڭا خەۋەر بەرمىدىڭلار، دېدى.
\m 
\v 9 ئاندىن سائۇلنىڭ خىزمەتكارلىرىنىڭ ئىچىگە كىرىۋالغان دوئەگ: ــ «مەن يەسسەنىڭ ئوغلىنىڭ نوبقا ئاخىتۇبنىڭ ئوغلى ئاخىمەلەكنىڭ قېشىغا كەلگىنىنى كۆردۈم،
\v 10 ــ ئاخىمەلەك ئۇنىڭ ئۈچۈن پەرۋەردىگاردىن يول سورىدى ۋە ئۇنىڭغا ئوزۇق-تۈلۈك بىلەن فىلىستىي گولىئاتنىڭ قىلىچىنى بەردى» ــ دېدى.
\m 
\v 11 پادىشاھ ئادەم ئەۋەتىپ ئاخىتۇبنىڭ ئوغلى كاھىن ئاخىمەلەكنى، شۇنداقلا ئۇنىڭ ئاتىسىنىڭ پۈتكۈل جەمەتىنى، يەنى نوبدىكى كاھىنلارنىمۇ چاقىرتىپ كەلدى. ئۇلارنىڭ ھەممىسى پادىشاھنىڭ قېشىغا كەلدى.
\m 
\v 12 سائۇل: ــ ئى ئاخىتۇبنىڭ ئوغلى ئاڭلىغىن، دېدى. ئۇ: ــ ئى غوجام، مانا مەن، دېدى.
\m 
\v 13 سائۇل ئۇنىڭغا: ــ نېمىشقا سىلەر، سەن بىلەن يەسسەنىڭ ئوغلى، ماڭا قەست قىلىسىلەر؟ سەن ئۇنىڭغا نان ۋە قىلىچ بېرىپ، ئۇنىڭ ئۈچۈن خۇدادىن يول سورىدىڭغۇ؟ مانا ئەمدى ئۇ بۈگۈنكىدەك ماڭا ھۇجۇم قىلماقچى بولۇپ پايلاپ يۈرمەكتە! ــ دېدى.
\m 
\v 14 ئاخىمەلەك پادىشاھقا جاۋاب بېرىپ: ــ سىلىنىڭ بارلىق خىزمەتكارلىرىنىڭ ئارىسىدا داۋۇتتەك سادىق كىم بار؟ ئۇ پادىشاھنىڭ كۈيئوغلى، سىلىنىڭ مەخپىي مەسلىھەتلىرىگە ئىشتىراك قىلغۇچى ۋە ئوردىلىرى ئىچىدە ئىززەتلىك ئەمەسمىدى؟
\v 15 مەن پەقەت ئۇنىڭ ئۈچۈن خۇدادىن يول سوراشنى بۈگۈنلا باشلىدىممۇ؟ \add ئاسىيلىق\add* قىلىش مەندىن نېرى بولسۇن! پادىشاھ ئۆز قۇلىنى ۋە ئاتامنىڭ پۈتكۈل جەمەتىنى ئەيىبكە بۇيرۇمىغايلا، چۈنكى قۇللىرىنىڭ بۇ ئىشتىن قىلچە خەۋىرى يوق، دېدى. \f ◼ \fr 22:15 \ft \bd «چۈنكى قۇللىرىنىڭ بۇ ئىشتىن قىلچە خەۋىرى يوق»\bd* ــ ئىبرانىي تىلىدا «چۈنكى قۇللىرىنىڭ بۇ ئىشتىن ئازمۇ، جىقمۇ خەۋىرى يوق».\f*
\m 
\v 16 لېكىن پادىشاھ: ــ ئى ئاخىمەلەك، سەن ئۆلىسەن، سەن ۋە ئاتاڭنىڭ پۈتكۈل جەمەتى چوقۇم ئۆلىسىلەر، دېدى.
\v 17 پادىشاھ ئۆز چۆرىسىدىكى چاپارمەنلىرىگە: ــ ماڭ، پەرۋەردىگارنىڭ كاھىنلىرىنى ئۆلتۈرۈڭلار! چۈنكى ئۇلار ھەم داۋۇتقا ھەمدەم بولدى ھەم ئۇنىڭ قاچقىنىنى بىلىپ تۇرۇپ ماڭا خەۋەر بەرمىدى، دېدى. لېكىن پادىشاھنىڭ قول ئاستىدىكىلىرى پەرۋەردىگارنىڭ كاھىنلىرىنى ئۆلتۈرۈشكە قول كۆتۈرگىلى ئۇنىمىدى.
\m 
\v 18 ئەمدى پادىشاھ دوئەگكە: ــ سەن بېرىپ كاھىنلارنى ئۆلتۈرۈۋەتكىن، دېدى. ئېدوملۇق دوئەگ بېرىپ كاھىنلارنى ئۆلتۈردى؛ بۇ كۈنى ئۇ كاناپتىن توقۇلغان ئەفود كىيگەن سەكسەن بەش ئادەمنى ئۆلتۈردى.
\m 
\v 19 ئاندىن ئۇ كاھىنلارنىڭ شەھىرى نوبدا ئولتۇرغۇچىلارنى قىردى، يەنى ئەر ۋە ئاياللار، بالىلار ۋە بوۋاقلار، كالا، ئېشەك، قويلار ــ ھەممىسىنى قىلىچلىدى.
\v 20 ئەمما ئاخىتۇبنىڭ ئوغلى ئاخىمەلەكنىڭ ئابىياتار دېگەن بىر ئوغلى قۇتۇلۇپ داۋۇتنىڭ قېشىغا قېچىپ كەلدى.
\v 21 ئابىياتار داۋۇتقا سائۇل پەرۋەردىگارنىڭ كاھىنلىرىنى ئۆلتۈردى، دەپ خەۋەر بەردى.
\m 
\v 22 داۋۇت ئابىياتارغا: ــ ئۇ كۈنى دوئەگنىڭ ئۇ يەردە ئىكەنلىكىنى كۆرۈپ، ئۇنىڭ جەزمەن سائۇلغا خەۋەر بېرىدىغىنىنى بىلگەنىدىم. مەن ئاتاڭنىڭ پۈتكۈل جەمەتىنىڭ ئۆلتۈرۈلۈشىگە زامىن بولدۇم، دېدى.
\v 23 مەن بىلەن بىللە تۇرغىن، ھېچ قورقمىغىن. چۈنكى مېنىڭ جېنىمنى ئالماقچى بولغانلار سېنىڭ جېنىڭنىمۇ ھەم ئالماقچى. مېنىڭ قېشىمدا بىخەتەر تۇرىسەن، دېدى.
\b
\b
\c 23
\s1 داۋۇت كېئىلاھ شەھىرىنى قۇتقۇزىدۇ
\m 
\v 1 بىرسى داۋۇتقا خەۋەر بېرىپ: ــ مانا فىلىستىيلەر كېئىلاھغا ھۇجۇم قىلىپ خامانلارنى بۇلاپ-تالىماقتا، دېدى.
\m 
\v 2 داۋۇت پەرۋەردىگاردىن: ــ مەن بېرىپ بۇ فىلىستىيلەرگە زەربە بېرىمەنمۇ؟ ــ دەپ سورىدى. پەرۋەردىگار داۋۇتقا: ــ بېرىپ فىلىستىيلەرگە زەربە بېرىپ كېئىلاھنى ئازاد قىلغىن، دېدى.
\m 
\v 3 لېكىن داۋۇتنىڭ ئادەملىرى ئۇنىڭغا: ــ مانا بىز يەھۇدا زېمىنىدا تۇرۇپمۇ قورقۇۋاتقان يەردە، كېئىلاھغا بېرىپ فىلىستىيلەرنىڭ قوشۇنلىرىغا ھۇجۇم قىلساق قانداق بولار؟ ــ دېدى.
\m 
\v 4 شۇڭا داۋۇت يەنە بىر قېتىم پەرۋەردىگاردىن سورىۋىدى، پەرۋەردىگار ئۇنىڭغا جاۋاب بېرىپ: ــ سەن ئورنۇڭدىن تۇرۇپ كېئىلاھغا بارغىن؛ چۈنكى مەن فىلىستىيلەرنى قولۇڭغا تاپشۇرىمەن، دېدى.
\v 5 بۇنىڭ بىلەن داۋۇت ئۆز ئادەملىرى بىلەن كېئىلاھغا بېرىپ فىلىستىيلەر بىلەن سوقۇشۇپ، ماللىرىنى ئولجا قىلىپ، ئۇلارنى قاتتىق قىردى. داۋۇت شۇنداق قىلىپ كېئىلاھدا تۇرۇۋاتقانلارنى قۇتقۇزدى.
\b
\s1 داۋۇت سائۇلنىڭ چاڭگىلىدىن يەنە قۇتۇلىدۇ
\m 
\v 6 ئەمدى ئاخىمەلەكنىڭ ئوغلى ئابىياتار كېئىلاھغا قېچىپ كېلىپ داۋۇتنىڭ قېشىغا كەلگەندە، ئۇنىڭ قولىدا ئەفود بار ئىدى. \x ◘ \xo 23:6 \xt 1سام. 22‏:20\x*
\m 
\v 7 بىرسى سائۇلغا، داۋۇت كېئىلاھغا كەپتۇ، دەپ خەۋەر بەردى. سائۇل: ــ ئەمدى خۇدا ئۇنى مېنىڭ قولۇمغا تاشلاپ تاپشۇردى. چۈنكى ئۇ دەرۋازىلىرى ۋە تاقاقلىرى بار شەھەرگە كىرگەچكە سولىنىپ قالدى، دېدى.
\v 8 ئەمدى سائۇل داۋۇت بىلەن ئادەملىرىنى مۇھاسىرىگە ئېلىش ئۈچۈن ھەممە خەلقنى كېئىلاھغا بېرىپ جەڭ قىلىشقا چاقىردى.
\m 
\v 9 داۋۇت سائۇلنىڭ ئۆزىنى قەستلەيدىغانلىقىنى بىلىپ، ئابىياتار كاھىنغا: ــ ئەفودنى ئېلىپ كەلگىن، دېدى. \f ◼ \fr 23:9 \ft \bd «داۋۇت سائۇلنىڭ ئۆزىنى قەستلەيدىغانلىقىنى بىلىپ، ئابىياتار كاھىنغا: ــ ئەفودنى ئېلىپ كەلگىن، دېدى»\bd* ــ كۆرۈنىدۇكى، 10-12-ئايەتتىكى سوئاللارنى داۋۇت ئەفود ۋاسىتىسى بىلەن پەرۋەردىگاردىن سورايدۇ.\f*
\v 10 ئاندىن داۋۇت: ــ ئى ئىسرائىلنىڭ خۇداسى پەرۋەردىگار، مەنكى سېنىڭ قۇلۇڭ سائۇلنىڭ بۇ شەھەرنى مېنىڭ سەۋەبىمدىن خاراب قىلىش ئۈچۈن كېئىلاھغا كېلىشكە قەستلەۋاتقانلىقىنى ئېنىق ئاڭلىدى.
\v 11 كېئىلاھدىكىلەر مېنى ئۇنىڭ قولىغا تۇتۇپ بېرەرمۇ؟ سائۇل ئۆز بەندەڭ ئاڭلىغاندەك بۇ يەرگە كېلەرمۇ؟ ئى ئىسرائىلنىڭ خۇداسى پەرۋەردىگار، سەندىن ئۆتۈنىمەنكى، ئۆز بەندەڭگە بىلدۈرگەيسەن، دېدى. پەرۋەردىگار: ــ ئۇ بۇ يەرگە كېلىدۇ، دېدى. \f ◼ \fr 23:11 \ft \bd «..كېلەرمۇ؟... كېلىدۇ»\bd* ــ ئىبرانىي تىلىدا «... چۈشەرمۇ؟...چۈشىدۇ» دېيىلىدۇ.\f*
\v 12 داۋۇت يەنە: ــ كېئىلاھتىكىلەر مېنى ۋە ئادەملىرىمنى سائۇلنىڭ قولىغا تۇتۇپ بېرەرمۇ، دېدى. پەرۋەردىگار: ــ ئۇلار سىلەرنى تۇتۇپ بېرىدۇ، دېدى.
\m 
\v 13 ئەمدى داۋۇت ئادەملىرى بىلەن (تەخمىنەن ئالتە يۈزچە) ئورنىدىن تۇرۇپ كېئىلاھدىن چىقىپ، ئۆزلىرى بارالايدىغان تەرەپكە قاراپ كەتتى. سائۇلغا، داۋۇت كېئىلاھتىن قېچىپتۇ دەپ خەۋەر بېرىلگەندە ئۇ ئۇنى قوغلاشقا چىقمىدى.
\m 
\v 14 داۋۇت بولسا چۆلدىكى قورغان-قىيالاردا ھەمدە زىف چۆلىنىڭ تاغلىرىدا تۇردى. سائۇل ئۇنى ھەر كۈنى ئىزدەيتتى؛ لېكىن خۇدا ئۇنى ئۇنىڭ قولىغا تاپشۇرمىدى.
\m 
\v 15 ئەمدى داۋۇت سائۇلنىڭ ئۆزىنى ئۆلتۈرگىلى چىقىدىغانلىقىنى بايقاپ قالدى. شۇ چاغدا ئۇ زىف چۆلىدىكى بىر ئورمانلىقتا تۇراتتى. \f ◼ \fr 23:15 \ft \bd «زىف چۆلىدىكى بىر ئورمانلىقتا..»\bd* ــ ياكى «زىف چۆلىدىكى خورەش شەھىرىدە...».\f*
\v 16 سائۇلنىڭ ئوغلى يوناتان بولسا ئورمانلىققا چىقىپ داۋۇتنىڭ قېشىغا بېرىپ، ئۇنى خۇدا ئارقىلىق رىغبەتلەندۈرۈپ ئۇنىڭغا: ــ \f ◼ \fr 23:16 \ft \bd «يوناتان... \bdit داۋۇتنى\bdit* .... رىغبەتلەندۈردى»\bd* ــ ئىبرانىي تىلىدا: «يوناتان ... ئۇنىڭ (داۋۇتنىڭ) قولىنى كۈچلەندۈردى» دېيىلىدۇ.\f*
\v 17 قورقمىغىن؛ چۈنكى ئاتام سائۇلنىڭ قولى سېنى تاپالمايدۇ. سەن بەلكى ئىسرائىلنىڭ ئۈستىدە پادىشاھ بولىسەن، مەن بولسام سېنىڭ ۋەزىرىڭ بولىمەن، بۇنى ئاتام سائۇلمۇ بىلىدۇ، دېدى.
\m 
\v 18 ئاندىن ئۇلار ئىككىيلەن پەرۋەردىگارنىڭ ئالدىدا ئەھدە قىلىشتى؛ داۋۇت بولسا، ئورمانلىقتا تۇرۇپ قالدى، يوناتان ئۆز ئۆيىگە يېنىپ كەتتى.
\m 
\v 19 شۇنىڭدىن كېيىن زىفتىكىلەر گىبېئاھتا تۇرۇۋاتقان سائۇلنىڭ قېشىغا كېلىپ: ــ مانا، داۋۇت خاقىلاھنىڭ ئېگىزلىكىدىكى يەشىموننىڭ جەنۇبى تەرىپىگە جايلاشقان ئورمانلىقتىكى قورغانلاردا يوشۇرۇنۇۋالدى، بىلمەمدىلا؟
\v 20 شۇڭا، ئى پادىشاھ، قاچان كۆڭۈللىرى تارتسا شۇ چاغدا كەلسىلە؛ بىزنىڭ بۇرچىمىز ئۇنى پادىشاھنىڭ قولىغا تۇتۇپ بېرىشتۇر، دېدى.
\m 
\v 21 سائۇل: ماڭا ئىچ ئاغرىتقىنىڭلار ئۈچۈن پەرۋەردىگار سىلەرگە بەخت ئاتا قىلغاي.
\v 22 ئەمدى سىلەردىن ئۆتۈنىمەنكى، بېرىپ زادى قايسى يەردە تۇرىدىغىنىنى جەزملەشتۈرۈڭلار، ئۇنىڭ ئىز-دېرىكىنى ئېنىقلاپ، ۋە كىمنىڭ ئۇنى كۆرگەنلىكىنى بىلىپ كېلىڭلار؛ چۈنكى كىشىلەر ئېيتىشىچە ئۇ ئىنتايىن ھىيلىگەر ئىكەن، دېدى.
\m 
\v 23 شۇڭا بېرىپ، ئۇنىڭ يوشۇرۇنغان بارلىق مەخپىي جايلىرىنى ئېنىق كۆرۈپ كېلىڭلار، يېنىمغا يېنىپ كېلىپ ماڭا ئەينىنى ئېيتىڭلار. ئاندىن مەن سىلەر بىلەن بىللە بارىمەن؛ ۋە شۇنداق بولىدۇكى، ئەگەر ئۇ زېمىندا بولسىلا، مەن يەھۇدىيلارنىڭ مىڭلىغانلارنىڭ ئارىسىدىن ئۇنى ئىزدەپ تاپىمەن، دېدى.
\m 
\v 24 ئۇلار قوپۇپ سائۇلدىن ئىلگىرى زىفقا باردى؛ لېكىن داۋۇت ئۆز ئادەملىرى بىلەن مائون چۆللۈكىدىكى يەشىموننىڭ جەنۇب تەرىپىدىكى ئاراباھ تۈزلەڭلىكىدە تۇرۇۋاتاتتى.
\v 25 سائۇل ئادەملىرى بىلەن داۋۇتنى ئىزدەپ باردى. كىشىلەر بۇ خەۋەرنى داۋۇتقا ئېيتتى؛ شۇنىڭ بىلەن ئۇ چۈشۈپ، قىياغا بېرىپ مائون چۆلىدە تۇردى. سائۇل بۇنى ئاڭلاپ داۋۇتنىڭ كەينىدىن قوغلاپ مائوننىڭ چۆلىگە چىقتى.
\v 26 سائۇل تاغنىڭ بۇ تەرىپىدە ماڭدى، ئەمما داۋۇت ئادەملىرى بىلەن تاغنىڭ ئۇ تەرىپىدە ماڭدى. داۋۇت سائۇلدىن قېچىش ئۈچۈن ئالدىرىۋاتقانىدى؛ لېكىن سائۇل ئادەملىرى بىلەن داۋۇت ۋە ئۇنىڭ ئادەملىرىنى تۇتىمىز دەپ ئۇلارنى قورشىغىلى تۇردى.
\v 27 ئەمما بىر خەۋەرچى سائۇلنىڭ قېشىغا كېلىپ ئۇنىڭغا: ــ فىلىستىيلەر زېمىنىمىزنىڭ جەنۇب تەرىپىگە كىرىپ بۇلاڭ-تالاڭ قىلىۋاتىدۇ، تېزدىن قايتسىلا، دېدى.
\m 
\v 28 شۇنىڭ بىلەن سائۇل يېنىپ داۋۇتنى قوغلاشتىن توختاپ فىلىستىيلەر بىلەن سوقۇشقىلى چىقتى. شۇڭا ئۇ يەر سېلا-خامماھلېكوت دەپ ئاتالدى. \f ◼ \fr 23:28 \ft \bd «سېلا-ھامماھلېكوت»\bd* ــ مەنىسى بەلكىم «ئايرىغۇچى قورام تاش».\f*
\v 29 داۋۇت بولسا ئۇ يەردىن چىقىپ ئەن-گەدىنىڭ تاغ-قورغانلىقىدا تۇردى.
\b
\b
\c 24
\s1 داۋۇت سائۇلنى ئايايدۇ
\m 
\v 1 سائۇل فىلىستىيلەرنى قوغلاپ چىقىرىپ يانغاندا ئۇنىڭغا: ــ مانا، داۋۇت ئەن-گەدىدىكى چۆلدە تۇرۇۋېتىپتۇ، دېگەن خەۋەر بېرىلدى.
\v 2 سائۇل ئەمدى پۈتكۈل ئىسرائىلدىن خىللانغان ئۈچ مىڭ ئادەمنى ئېلىپ داۋۇت بىلەن ئادەملىرىنى ئىزدىگىلى «ياۋا تېكىلەر» قورام تاشلىقىغا چىقتى.
\v 3 ئۇ يولنىڭ يېنىدىكى قوي قوتانلىرىغا كەلگەندە، شۇ يەردە بىر غار بار ئىدى. ئۇ تەرەت قىلىش ئۈچۈن غارغا كىردى؛ داۋۇت بىلەن ئادەملىرى غارنىڭ ئىچكىرىسىدە ئولتۇراتتى.
\m 
\v 4 داۋۇتنىڭ ئادەملىرى ئۇنىڭغا: ــ مانا پەرۋەردىگارنىڭ ساڭا: ــ ئۆز دۈشمىنىڭنى سېنىڭ قولۇڭغا بېرىمەن، نېمە ساڭا لايىق كۆرۈنسە شۇنى قىلغىن، دېگەن كۈنى دەل مۇشۇ كۈن ئىكەن، دېدى. داۋۇت قوپۇپ سائۇلنىڭ تونىنىڭ پېشىنى تۇيدۇرماي كېسىۋالدى.
\v 5 لېكىن سائۇلنىڭ تونىنىڭ پېشىنى كەسكىنى ئۈچۈن داۋۇت كۆڭلىدە قاتتىق ئەپسۇسلاندى.
\v 6 ئۇ ئۆز ئادەملىرىگە: ــ پەرۋەردىگار مېنى پەرۋەردىگار ئۆزى مەسىھ قىلغان غوجامغا بۇنداق قولۇمنى ئۇزارتىشتىن ساقلىسۇن، چۈنكى ئۇ پەرۋەردىگارنىڭ مەسىھلىگىنىدۇر، دېدى.
\m 
\v 7 شۇ سۆز بىلەن داۋۇت ئۆز ئادەملىرىنى توسۇپ سائۇلغا چېقىلغىلى قويمىدى. سائۇل بولسا قوپۇپ غاردىن چىقىپ ئۆز يولىغا كەتتى.
\v 8 ئاندىن داۋۇتمۇ تۇرۇپ غاردىن چىقىپ سائۇلنىڭ كەينىدىن: ــ ئى غوجام پادىشاھ! ــ دەپ چاقىردى. سائۇل كەينىگە قاراۋىدى، داۋۇت ئېگىلىپ يۈزىنى يەرگە ياققان ھالدا تەزىم قىلدى.
\v 9 داۋۇت سائۇلغا مۇنداق دېدى: ــ «مانا، داۋۇت سېنى قەستلەشكە پۇرسەت ئىزدەۋاتىدۇ، دەيدىغان كىشىلەرنىڭ سۆزىگە نېمىشقا قۇلاق سالىلا؟
\v 10 مانا بۈگۈن ئۆز كۆزلىرى بىلەن كۆردىلىكى، پەرۋەردىگار بۈگۈن غاردا سىلىنى ئۆز قولۇمغا بەرگەنىدى. بەزىلەر ماڭا ئۇنى ئۆلتۈرۈۋەتكىن، دېدى؛ لېكىن مەن سىلىنى ئاياپ: ــ غوجامغا قولۇمنى ئۇزارتمايمەن، چۈنكى ئۇ پەرۋەردىگارنىڭ مەسىھلىگىنىدۇر، دېدىم.
\v 11 قارىسىلا، ئى ئاتا، قولۇمدىكى تونلىرىنىڭ پېشىگە. سىلىنى ئۆلتۈرمەي تونلىرىنىڭ پېشىنى كەسكەنلىكىمدىن شۇنى بىلسىلەكى، كۆڭلۈمدە سىلىگە يا يامانلىق يا ئاسىيلىق يوق، سىلىگە گۇناھ قىلغىنىم يوق، لېكىن سىلى جېنىمنى ئالغىلى پايلىماقتىلا. \f ◼ \fr 24:11 \ft \bd «كۆڭلۈمدە سىلىگە يا يامانلىق يا ئاسىيلىق يوق»\bd* ــ ئىبرانىي تىلىدا «قولۇمدا سىلىگە يا يامانلىق يا ئاسىيلىق يوق».\f*
\v 12 پەرۋەردىگار مەن بىلەن سىلىنىڭ ئوتتۇرىمىزدا ھۆكۈم قىلسۇن، مېنىڭ ھېسابىمنى سىلىدىن پەرۋەردىگار ئالسۇن؛ لېكىن مېنىڭ قولۇم سىلىگە كۆتۈرۈلمەيدۇ.
\v 13 كونىلار: ــ «رەزىللىك رەزىللەردىن چىقىدۇ» دەپ ئېيتقانىكەن، لېكىن ئۆز قولۇم سىلىگە كۆتۈرۈلمەيدۇ.
\v 14 ئىسرائىلنىڭ پادىشاھى كىمنى تۇتقىلى چىقتى؟ كىمنى قوغلاپ يۈرىدۇ؟ بىر ئۆلۈك ئىتنى، خالاس! يالغۇز بىر بۈرگىنى، خالاس!
\v 15 پەرۋەردىگار سوراقچى بولۇپ مەن بىلەن سىلىنىڭ ئوتتۇرىمىزدا ھۆكۈم چىقارسۇن! ئۇ ھەق-ناھەقنى ئايرىپ، دەۋايىمنى سوراپ مېنى سىلىنىڭ قوللىرىدىن خالاس قىلىپ، ئادالەت يۈرگۈرگەي!» ــ دېدى.
\m 
\v 16 داۋۇت سائۇلغا بۇ سۆزلەرنى ئېيتقاندا سائۇل: ــ بۇ سېنىڭ ئاۋازىڭمۇ، ئى ئوغلۇم داۋۇت؟ ــ دېدى. ئاندىن سائۇل يۇقىرى ئاۋاز بىلەن يىغلاپ كەتتى.
\v 17 ئۇ داۋۇتقا: ــ «سەن مەندىن ئادىلسەن، چۈنكى سەن ماڭا ياخشىلىق قايتۇردۇڭ، لېكىن مەن ساڭا يامانلىق قايتۇردۇم.
\v 18 سەن بۈگۈن ماڭا ياخشىلىق قىلغانلىقىڭنى ئوبدان كۆرسىتىپ بەردىڭ؛ پەرۋەردىگار مېنى قولۇڭغا تاپشۇرغان بولسىمۇ، سەن مېنى ئۆلتۈرمىدىڭ.
\v 19 بىرسى ئۆز دۈشمىنىنى تاپسا، ئۇنى ئامان-ئېسەن كەتكىلى قويامدۇ؟ پەرۋەردىگار سېنىڭ ماڭا بۈگۈن قىلغان ياخشىلىقىڭ ئۈچۈن ساڭا ياخشىلىق ياندۇرغاي.
\v 20 ئەمدى مانا، شۇنى بىلدىمكى، سەن جەزمەن پادىشاھ بولىسەن، ئىسرائىلنىڭ پادىشاھلىقى سېنىڭ قولۇڭدا تىكلىنىدۇ.
\v 21 لېكىن ھازىر پەرۋەردىگار بىلەن ماڭا قەسەم قىلغىنكى، مەندىن كېيىن مېنىڭ نەسلىمنى يوقاتماي، نامىمنى ئاتامنىڭ جەمەتىدىن ئۆچۈرمىگەيسەن»، دېدى.
\m 
\v 22 شۇنىڭ بىلەن داۋۇت سائۇلغا قەسەم قىلدى. سائۇل ئۆز ئۆيىگە يېنىپ كەتتى؛ داۋۇت ئادەملىرى بىلەن قورغان-قىياغا چىقىپ شۇ يەردە تۇردى.
\b
\b
\c 25
\s1 سامۇئىل ئۆلىدۇ
\m 
\v 1 سامۇئىل ئۆلدى. پۈتكۈل ئىسرائىل يىغىلىپ ئۇنىڭ ئۈچۈن ماتەم تۇتتى؛ ئۇلار ئۇنى ئۇنىڭ راماھدىكى ئۆيىدە دەپنە قىلدى. داۋۇت بولسا قوپۇپ پاران چۆلىگە باردى. \x ◘ \xo 25:1 \xt 1سام. 28‏:3\x*
\b
\s1 داۋۇت، نابال، ئابىگائىل
\m 
\v 2 ئەمدى تىرىكچىلىكى كارمەلدە بولغان، مائوندا ئولتۇرۇقلۇق بىر ئادەم بار ئىدى. بۇ كىشى بەك باي بولۇپ ئۈچ مىڭ قوي، بىر مىڭ ئۆچكىسى بار ئىدى. ئۇ ئۆز قويلىرىنى كارمەلدە قىرقىۋاتاتتى.
\v 3 ئۇ ئادەمنىڭ ئىسمى نابال بولۇپ، ئايالىنىڭ ئىسمى ئابىگائىل ئىدى؛ ئايالى ھەم پەم-پاراسەتلىك ھەم ئەپت-تۇرقى چىرايلىق، لېكىن ئېرى قاتتىق قول ۋە رەزىل ئىدى؛ ئۇ كالەبنىڭ ئەۋلادىدىن ئىدى. \f ◼ \fr 25:3 \ft \bd «ئۇ ئادەمنىڭ ئىسمى نابال بولۇپ...»\bd* ــ «نابال»نىڭ مەنىسى «ئەخمەق، قوپال».\f*
\m 
\v 4 داۋۇت چۆلدە تۇرۇپ نابالنىڭ ئۆز قويلىرىنى قىرقىيدىغانلىقىنى ئاڭلاپ
\v 5 ئون ياش يىگىتنى ئۇ يەرگە ماڭدۇرۇپ ئۇلارغا: ــ سىلەر كارمەلگە چىقىپ نابالنىڭ قېشىغا بېرىپ، مەندىن ئۇنىڭغا سالام ئېيتىڭلار.
\v 6 ئۇنىڭغا: ــ «ياشىغايسەن؛ سىزگە تىنچ-ئامانلىق بولغاي، ئۆيىڭىزگە تىنچ-ئامانلىق بولغاي، ھەممە بارلىقىڭىزغا تىنچ-ئامانلىق بولغاي!
\v 7 مەن قىرقىغۇچىلارنىڭ سىزدە ئىش باشلىغانلىقىنى ئاڭلىدىم. سىزنىڭ پادىچىلىرىڭىز بىز تەرەپلەردە تۇرغاندا ئۇلارغا ھېچ زەخمە يەتكۈزمىدۇق؛ بىز كارمەلدە تۇرغان ۋاقىتتا ئۇلارنىڭ ھېچ نەرسىسى يىتىپ كەتمىدى.
\v 8 ئۆز يىگىتلىرىڭىزدىن سورىسىڭىز ئۇلار سىزگە دەپ بېرىدۇ. شۇڭا بىز قۇتلۇق بىر كۈنىدە كەلدۇق، شۇڭا يىگىتلىرىمىز نەزىرىڭىزدە ئىلتىپات تاپسۇن؛ ئۆز قولىڭىزغا نېمە چىقسا شۇنى كەمىنىلىرىڭىزگە ۋە ئوغلىڭىز داۋۇتقا نېمە چىقسا شۇنى بەرگەيسىز»، دەڭلار، ــ دېدى.
\m 
\v 9 داۋۇتنىڭ يىگىتلىرى ئۇ يەرگە بېرىپ بۇ گەپلەرنىڭ ھەممىسىنى داۋۇتنىڭ نامىدا ئۇنىڭغا ئېيتىپ ئاندىن جىم تۇرۇپ ساقلىدى.
\m 
\v 10 نابال داۋۇتنىڭ خىزمەتكارلىرىغا جاۋاب بېرىپ: ــ داۋۇت دېگەن كىم؟ يەسسەنىڭ ئوغلى دېگەن كىم؟ بۇ كۈنلەردە ئۆز غوجىلىرىنى تاشلاپ كېتىۋاتقان خىزمەتكارلار تولا.
\v 11 مەن ئۆزۈمنىڭ يېمەك-ئىچمەكلىرىمنى ۋە يۇڭ قىرقۇغۇچىلىرىمغا سويغان گۆشنى كەلگەن جايى نامەلۇم بولغان كىشىلەرگە بېرەمدىم؟ ــ دېدى. \f ◼ \fr 25:11 \ft \bd «يېمەك-ئىچمىكىم»\bd* ــ ئىبرانىي تىلىدا «نېنىم ۋە سۈيۈم».\f*
\m 
\v 12 داۋۇتنىڭ يىگىتلىرى كەلگەن يولىغا يېنىپ كەتتى. يېنىپ كېلىپ ئۇلار داۋۇتقا ھەممە گەپنى دەپ بەردى.
\v 13 داۋۇت ئۆز ئادەملىرىگە: ــ ھەر بىرىڭلار ئۆز قىلىچىڭلارنى ئېسىڭلار، دېدى. شۇنىڭ بىلەن ھەربىرى ئۆز قىلىچىنى \add تاسمىسىغا\add* ئاستى، داۋۇتمۇ ئۆز قىلىچىنى ئاستى. ئاندىن تۆت يۈزچە ئادەم داۋۇت بىلەن چىقتى، ۋە ئىككى يۈز كىشى جابدۇقلار بىلەن قالدى.
\v 14 ئەمما نابالنىڭ خىزمەتكارلىرىدىن بىرى ئۇنىڭ ئايالى ئابىگائىلغا: ــ داۋۇت ئەلچىلەرنى چۆلدىن غوجىمىزغا سالام بېرىشكە ئەۋەتكەنىكەن؛ لېكىن ئۇ ئۇلارنى تىللاپ كايىپ كەتتى.
\v 15 بۇ ئادەملەر بولسا، بىزگە كۆپ ياخشىلىق قىلغان. بىز دالادا ئۇلارنىڭ يېنىدا يۈرگەن ۋاقىتلىرىمىزدا بىزگە ھېچ يامانلىق كەلمىدى، بىزنىڭ ھېچ نەرسىمىزمۇ يىتىپ كەتمىگەنىدى.
\v 16 بىز ئۇلارغا يېقىن جايدا قوي باققان ۋاقىتتا ئۇلار كېچە-كۈندۈز بىزگە سېپىلدەك بولغانىدى.
\v 17 ئەمدى بۇ ئىشتىن خەۋەردار بولدىلا، قانداق قىلىش كېرەكلىكىنى ئويلىشىپ باققايلا. بولمىسا، غوجىمىزغا ۋە پۈتكۈل ئۆيدىكىلىرىگە بىر بالا-قازا كەلمەي قالمايدۇ. ئۇ شۇنچە كاج بىر ئادەمكى، ھېچكىم ئۇنىڭغا سۆز قىلىشقا پېتىنالمايدۇ، دېدى. \f ◼ \fr 25:17 \ft \bd «ئۇ شۇنچە كاج بىر ئادەمكى...»\bd* ــ ئىبرانىي تىلىدا «ئۇ بېلىئالنىڭ (شەيتاننىڭ) شۇنداق بىر ئوغلىكى...».\f*
\m 
\v 18 ئابىگائىل دەرھال ئىككى يۈز نان، ئىككى تۇلۇم شاراب، بەش پىشۇرۇلغان قوي، بەش سېئاھ قوماچ، بىر يۈز كىشمىش پوشكىلى، ئىككى يۈز ئەنجۈر پوشكىلى ئېلىپ ئېشەكلەرگە ئارتىپ \f ◼ \fr 25:18 \ft \bd «بەش سېئاھ قوماچ»\bd* ــ «سېئاھ» ئۈچتىن بىر ئەفاھ، يەنى ئاشلىق-دانلارنىڭ ئۆلچەم بىرلىكى ئىدى، تەخمىنەن 9 لىتر.\f*
\v 19 ئۆز يىگىتلىرىگە: ــ مېنىڭ ئالدىمدا بېرىڭلار؛ مانا، مەن كەينىڭلاردىن باراي، دېدى. لېكىن ئۇ ئۆز ئېرى نابالغا بۇ ئىشنى دېمىدى.
\v 20 ئۇ ئۆز ئېشىكىگە مىنىپ تاغنىڭ ئېتىكىدىن چۈشكەندە، مانا داۋۇت ئادەملىرى بىلەن ئۇنىڭ ئۇدۇلىغا چۈشۈپ ئۇنىڭ بىلەن ئۇچراشتى.
\m 
\v 21 داۋۇت ئەسلىدە: ــ مەن بۇ كىشىنىڭ مېلىنى چۆلدە بىكاردىن بىكار قوغداپ، ئۇنىڭ بارلىقىدىن ھېچنېمىنى يىتتۈرگۈزمىگەنىدىم؛ لېكىن ئۇ ياخشىلىقنىڭ ئورنىدا ماڭا يامانلىق قىلدى.
\v 22 ئۇنىڭ ئادەملىرىدىن ئەتىگىچە بىرەر ئەركەكنى قالدۇرۇپ قويسام، خۇدا مەن داۋۇتنى ئۇنىڭدىنمۇ ئارتۇق جازالىغاي، دېگەنىدى. \f ◼ \fr 25:22 \ft \bd «ئۇنىڭ ئادەملىرىدىن ئەتىگىچە بىرەر ئەركەكنى قالدۇرۇپ قويسام...»\bd* ــ مۇشۇ يەردە «بىرەر ئەركەك» ئىبرانىي تىلىدا «تامغا قاراپ بىرەر سىيگۈچى» بىلەن ئىپادىلىنىدۇ. \bd «خۇدا مەن داۋۇتنى ئۇنىڭدىنمۇ ئارتۇق جازالىغاي»\bd* ــ ياكى «خۇدا داۋۇتنىڭ دۈشمەنلىرىگە ئۇنىڭدىنمۇ ئارتۇق قىلغاي» (بەزى كونا كۆچۈرمىلەردە شۇنداق يېزىلىدۇ).\f*
\v 23 ئابىگائىل داۋۇتنى كۆرۈپ، ئالدىراپ ئېشەكتىن چۈشۈپ، داۋۇتنىڭ ئالدىدا يىقىلىپ يۈزىنى يەرگە يېقىپ تەزىم قىلدى؛
\v 24 ئۇنىڭ پۇتلىرىغا ئېسىلىپ مۇنداق دېدى: ــ «ئى غوجام، بۇ قەبىھلىك ماڭا ھېسابلانسۇن؛ ئەمدى شۇنى ئۆتۈنىمەنكى، دېدەكلىرىنىڭ سىلىگە سۆز قىلىشىغا ئىجازەت قىلىپ، دېدىكلىرىنىڭ سۆزىگە قۇلاق سالغايلا: ــ
\v 25 ئۆتۈنىمەنكى، غوجام بۇ رەزىل ئادەم نابالغا پىسەنت قىلمىغايلا؛ چۈنكى ئۇنىڭ مىجەزى خۇددى ئىسمىغا ئوخشاشتۇر؛ ئۇنىڭ ئىسمى «كاج»، دەرۋەقە ئۇنىڭدا كاجلىق تولىمۇ ئېغىردۇر. لېكىن مەن دېدەكلىرى بولسا غوجام ئەۋەتكەن يىگىتلەرنى كۆرمىدىم. \f ◼ \fr 25:25 \ft \bd «غوجام بۇ رەزىل ئادەم نابال»\bd* ــ ئىبرانىي تىلىدا «غوجام بېلىئالنىڭ (شەيتاننىڭ) بۇ ئوغلى نابال» دېيىلىدۇ. \bd «ئۇنىڭ ئىسمى «كاج»، دەرۋەقە ئۇنىڭدا كاجلىق تولىمۇ ئېغىردۇر»\bd* ــ ئىبرانىي تىلىدا «نابال» دېگەننىڭ مەنىسى «كاج».\f*
\v 26 ئەمدى ئى غوجام، پەرۋەردىگارنىڭ ھاياتى بىلەن ۋە سېنىڭ جېنىڭ بىلەن قەسەم ئىچىمەنكى، پەرۋەردىگار سىلىنى ئۆز قوللىرى بىلەن قان تۆكۈپ ئىنتىقام ئېلىشتىن ساقلىدى. ئەمدى دۈشمەنلىرىمۇ، سىلى غوجامغا يامانلىق قىلماقچى بولغانلارمۇ نابالغا ئوخشاش بولسۇن.
\v 27 ئەمدى دېدەكلىرى غوجامغا ئېلىپ كەلگەن بۇ سوۋغات بولسا غوجامغا ئەگەشكەن يىگىتلەرگە تەقسىم قىلىنسۇن.
\m 
\v 28 سىلىدىن ئۆتۈنىمەنكى، دېدەكلىرىنىڭ سەۋەنلىكىنى كەچۈرگەيلا؛ چۈنكى سىلى، ئى غوجام پەرۋەردىگارنىڭ جەڭلىرىنى قىلىپ كەلگەنلىرى ئۈچۈن، بارلىق كۈنلىرىدە سىلىدە يامانلىق تېپىلمىغىنى ئۈچۈن پەرۋەردىگار جەزمەن جەمەتلىرىنى مەزمۇت قىلىدۇ.
\v 29 بىرسى قوپۇپ سىلىنى قوغلاپ جانلىرىنى ئىزدىسە، سىلى غوجامنىڭ جېنى پەرۋەردىگار خۇدالىرىنىڭ قېشىدىكى تىرىكلەر خالتىسى ئىچىدە ئورىلىپ ساقلىنىدۇ، لېكىن دۈشمەنلىرىنىڭ جانلىرىنى بولسا، ئۇ سالغۇغا سېلىپ چۆرۈپ تاشلايدۇ.
\m 
\v 30 ئەمدى پەرۋەردىگار سىلى غوجام توغرىسىدا ئېيتقان بارلىق ياخشى ۋەدىلىرىگە ئەمەل قىلىپ، سىلىنى ئىسرائىلغا باش قىلغاندا شۇنداق بولىدۇكى،
\v 31 سىلى غوجامنىڭ ناھەق قان تۆكمىگەنلىكلىرى ياكى ئۆز ئىنتىقاملىرىنى ئالمىغانلىقلىرى ئۈچۈن كۆڭۈللىرىگە پۇتلىكاشاڭ ياكى دەرد بولمايدۇ. ۋە پەرۋەردىگار غوجامغا نۇسرەت بەرگىنىدە سىلى ئۆز دېدەكلىرىنى ياد قىلغايلا».
\m 
\v 32 داۋۇت ئابىگائىلغا: ــ سېنى بۈگۈن مېنىڭ بىلەن ئۇچرىشىشقا ئەۋەتكەن ئىسرائىلنىڭ خۇداسى پەرۋەردىگارغا تەشەككۈر-مەدھىيە قايتۇرۇلغاي!
\v 33 ئەمدى ئەقىل-پاراسىتىڭگە بارىكاللا، ساڭىمۇ بارىكاللا! چۈنكى سەن بۈگۈن مېنى ئۆز قولۇم بىلەن قان تۆكۈپ ئىنتىقام ئېلىشتىن توستۇڭ.
\m 
\v 34 لېكىن مېنى ساڭا زىيان-زەخمەت يەتكۈزۈشتىن ساقلىغان ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، سەن مېنىڭ ئالدىمغا تېزلىنىپ كەلمىگەن بولساڭ، نابالنىڭ ئادەملىرىدىن ھېچ ئەركەك ئەتىگىچە تىرىك قالماس ئىدى، دېدى. \f ◼ \fr 25:34 \ft \bd «نابالنىڭ ئادەملىرىدىن ھېچ ئەركەك ئەتىگىچە تىرىك قالماس ئىدى»\bd* ــ مۇشۇ يەردە «ئەركەك» ئىبرانىي تىلىدا «تامغا قاراپ سىيگۈچى» بىلەن ئىپادىلىنىدۇ.\f*
\m 
\v 35 ئاندىن داۋۇت ئۇنىڭ ئۆزىگە كەلتۈرگەن نەرسىلىرىنى قولىدىن تاپشۇرۇپ ئېلىپ ئۇنىڭغا: ــ تىنچ-ئامان ئۆيۈڭگە بارغىن، مانا سۆزلىرىڭگە قۇلاق سېلىپ، كۆڭلۈڭنى قوبۇل قىلدىم، دېدى.
\m 
\v 36 ئابىگائىل نابالنىڭ قېشىغا كەلدى؛ مانا، ئۇ ئۆيىدە شاھانە زىياپەتتەك بىر زىياپەت ئۆتكۈزۈۋاتاتتى. نابال كۆڭلىدە خۇشال ئىدى ۋە ئىنتايىن مەست بولۇپ كەتكەنىدى. شۇڭا ئابىگائىل ئەتىسى تاڭ ئاتقۇچە ئۇنىڭغا ھېچ نېمە دېمىدى.
\v 37 لېكىن ئەتىسى نابال مەستلىكتىن يېشىلگەندە ئايالى ئۇنىڭغا بولغان ۋەقەلەرنى دەپ بېرىۋىدى، ئۇنىڭ يۈرىكى ئۆلگەندەك بولۇپ، ئۆزى تاشتەك بولۇپ قالدى.
\v 38 ۋە شۇنداق بولدىكى، تەخمىنەن ئون كۈندىن كېيىن نابالنى پەرۋەردىگار ئۇردى ۋە ئۇ ئۆلدى.
\m 
\v 39 داۋۇت نابالنىڭ ئۆلگىنىنى ئاڭلاپ: ــ پەرۋەردىگار مۇبارەكتۇر. چۈنكى ئۇ مەن نابالدىن تارتقان ھاقارەت ئۈچۈن دەۋايىمنى سوراپ ئۆز قۇلىنى يامانلىقتىن ساقلىدى؛ ئەكسىچە پەرۋەردىگار نابالنىڭ يامانلىقىنى ئۆز بېشىغا ياندۇردى، دېدى. ئاندىن ئابىگائىلنى ئۆز ئەمرىمگە ئالاي دەپ، ئۇنىڭغا سۆز قىلغىلى ئەلچى ماڭدۇردى.
\v 40 داۋۇتنىڭ خىزمەتكارلىرى كارمەلگە ئابىگائىلنىڭ قېشىغا كېلىپ ئۇنىڭغا: ــ سېنى ئەمرىمگە ئالاي دەپ داۋۇت ساڭا سۆز قىلغىلى بىزنى ئەۋەتتى، دېدى.
\m 
\v 41 ئابىگائىل بولسا قوپۇپ يۈزىنى يەرگە تەگكۈدەك تەزىم قىلىپ: ــ مانا، دېدىكىڭ غوجامنىڭ خىزمەتكارلىرىنىڭ پۇتلىرىنى يۇيۇشقا قۇل بولسۇن، دېدى. \f ◼ \fr 25:41 \ft \bd «مانا، دېدىكىڭ غوجامنىڭ خىزمەتكارلىرىنىڭ پۇتلىرىنى يۇيۇشقا قۇل بولسۇن»\bd* ــ ئىسرائىلدا ۋە ئوتتۇرا شەرقتە شۇنداق ئادەت باركى، ئۆيگە مېھمان كەلسە، ساھىبخان ياكى خىزمەتكارلىرى ئۇلارنىڭ پۇتلىرىنى يۇيىدۇ.\f*
\v 42 ئاندىن ئابىگائىل شۇ ھامان ئۆزىگە ھەمراھ بولغان بەش چۆرىسى بىلەن ئېشەككە مىنىپ داۋۇتنىڭ ئەلچىلىرىنىڭ كەينىدىن بېرىپ، ئۇنىڭ ئايالى بولدى.
\m 
\v 43 داۋۇت يىزرەئەللىك ئاھىنوئامنى ھەم خوتۇنلۇققا ئالغانىدى. شۇنىڭ بىلەن بۇ ئىككىسى ئۇنىڭغا خوتۇن بولدى.
\m 
\v 44 لېكىن سائۇل داۋۇتقا خوتۇن قىلىپ بەرگەن قىزى مىقالنى گاللىمدىكى لائىشنىڭ ئوغلى فالتىغا خوتۇنلۇققا بەرگەنىدى. \x ◘ \xo 25:44 \xt 2سام. 3‏:15\x*
\b
\b
\c 26
\s1 داۋۇت سائۇلنى يەنە رەھىم قىلىپ ئايايدۇ
\m 
\v 1 ئەمدى زىفلىقلار گىبېئاھغا سائۇلنىڭ قېشىغا كېلىپ: ــ داۋۇت يەشىمونغا يېقىن ھاقىلاھ ئېگىزلىكىگە يوشۇرۇنۇۋاپتۇ ئەمەسمۇ؟ ــ دېدى.
\m 
\v 2 سائۇل قوپۇپ ئىسرائىلدىن خىللانغان ئۈچ مىڭ ئادەمنى ئېلىپ، زىف چۆلىدە داۋۇتنى ئىزدىگىلى ئۇ يەرگە باردى.
\v 3 سائۇل بولسا يول بويىدا، يەشىمونغا يېقىن ھاقىلاھ ئېگىزلىكىدە چېدىر تىكتى. داۋۇت چۆلدە تۇرۇۋاتاتتى؛ ئۇ سائۇلنىڭ چۆلگە ئۆز كەينىدىن چىققىنىدىن خەۋەر تاپقاندا
\v 4 داۋۇت پايلاقچىلارنى ماڭدۇرۇپ سائۇلنىڭ راستلا كەلگەنلىكىنى بىلدى.
\v 5 داۋۇت قوپۇپ سائۇل چېدىر تىككەن جايغا باردى؛ ئۇ سائۇل بىلەن قوشۇن سەردارى، نەرنىڭ ئوغلى ئابنەر ياتقان يەرنى كۆردى. سائۇل بولسا قوشۇن ئىستىھكامى ئىچىدە ئۇخلاپ ياتقانىدى، ئادەملىرى چېدىرلىرىنى ئۇنىڭ ئەتراپىغا تىككەنىدى.
\m 
\v 6 داۋۇت ئەمدى ھىتتىيلاردىن بولغان ئاخىمەلەك ۋە يوئابنىڭ ئىنىسى زەرۇئىيانىڭ ئوغلى ئابىشايغا: ــ كىم مەن بىلەن لەشكەرگاھغا چۈشۈپ، سائۇلنىڭ يېنىغا بارىدۇ؟ ــ دەپ سورىدى. ئابىشاي: ــ مەن سېنىڭ بىلەن باراي، دېدى.
\m 
\v 7 شۇنىڭ بىلەن داۋۇت ۋە ئابىشاي كېچىدە قوشۇن بار يەرگە بېرىۋىدى، مانا سائۇل قوشۇن ئىستىھكامى ئىچىدە ئۇخلاپ ياتقانىدى؛ ئۇنىڭ نەيزىسى تەكىيىسىنىڭ يېنىدا يەرگە قاداقلىق تۇراتتى؛ ئابنەر بىلەن ئادەملىرى ئۇنىڭ ئەتراپىدا ياتاتتى.
\v 8 ئابىشاي داۋۇتقا: ــ خۇدا بۈگۈن دۈشمىنىڭنى قولۇڭغا تاپشۇردى. سەندىن ئۆتۈنىمەنكى، ماڭا نەيزە بىلەن بىرلا سانجىپ ئۇنى يەرگە قاداپ قويۇشقا ئىجازەت بەرگەيسەن! ئىككى قېتىم سانجىشىمنىڭ لازىمى يوقتۇر، دېدى.
\m 
\v 9 داۋۇت ئابىشايغا: ــ ئۇنى يوقاتمىغىن. كىم پەرۋەردىگارنىڭ مەسىھ قىلغىنىغا قول ئۇزىتىپ گۇناھغا تارتىلمىغان؟ ــ دېدى.
\m 
\v 10 داۋۇت يەنە: ــ پەرۋەردىگارنىڭ ھاياتى بىلەن \add قەسەم قىلىمەنكى\add*، پەرۋەردىگار جەزمەن ئۇنى ئۇرىدۇ؛ يا ئۇنىڭ ئۆلىدىغان كۈنى كېلىدۇ يا ئۇ جەڭگە چۈشۈپ ھالاك بولىدۇ.
\v 11 پەرۋەردىگار مېنى پەرۋەردىگارنىڭ مەسىھلىگىنىگە قول ئۇزىتىشىدىن ساقلىغاي! ئەمما ئۇنىڭ بېشىدىكى نەيزە بىلەن سۇ ئىدىشىنى ئالغىن، ئاندىن كېتەيلى، دېدى.
\v 12 شۇنىڭ بىلەن داۋۇت نەيزە بىلەن ئىدىشنى سائۇلنىڭ بېشىنىڭ يېنىدىن ئېلىپ، ئىككىسى چىقىپ كەتتى. ئەمما ھېچكىم كۆرمىدى، تۇيۇپمۇ قالمىدى ھەم ئويغىنىپ كەتمىدى، بەلكى ھەممىسى ئۇخلاۋەردى؛ چۈنكى پەرۋەردىگار بىر قاتتىق ئۇيقۇنى ئۇلارنىڭ ئۈستىگە چۈشۈرگەنىدى.
\m 
\v 13 داۋۇت ئۇدۇلدىكى تەرەپكە ئۆتۈپ يىراقراق بىر دۆڭنىڭ تۆپىسىدە تۇردى؛ ئۇلارنىڭ ئارىلىقى يىراق ئىدى.
\v 14 داۋۇت قوشۇن بىلەن نەرنىڭ ئوغلى ئابنەرگە توۋلاپ: ــ جاۋاب بەرمەمسەن، ئى ئابنەر! ــ دېدى. ئابنەر: ــ پادىشاھقا توۋلىغۇچى كىم سەن؟ ــ دېدى.
\m 
\v 15 داۋۇت ئابنەرگە: ــ سەن باتۇر ئەمەسمۇ؟ ئىسرائىلدا ساڭا كىم تەڭ كېلەلەيدۇ؟ نېمىشقا غوجاڭ پادىشاھنى قوغدىمىدىڭ؟ چۈنكى خەلقتىن بىر كىشى غوجاڭ پادىشاھنى ھالاك قىلغىلى كىرىپتۇ.
\v 16 سېنىڭ بۇنداق قىلغىنىڭ ياخشى ئەمەس! پەرۋەردىگارنىڭ ھاياتى بىلەن \add قەسەم قىلىمەنكى\add*، پەرۋەردىگار مەسىھ قىلغان غوجاڭلارنى قوغدىمىغانلىقىڭلار ئۈچۈن ئۆلۈمگە لايىق بولدۇڭلار. ئەمدى پادىشاھنىڭ نەيزىسى ۋە بېشىنىڭ يېنىدىكى سۇ ئىدىشىنىڭ قەيەردىلىكىگە قاراپ بېقىڭلار، دېدى.
\m 
\v 17 سائۇل داۋۇتنىڭ ئاۋازىنى تونۇپ: ــ بۇ سېنىڭ ئاۋازىڭمۇ، ئى ئوغلۇم داۋۇت! ــ دېدى. داۋۇت: ــ ئى غوجام پادىشاھ، بۇ مېنىڭ ئاۋازىمدۇر، دېدى.
\v 18 ئۇ يەنە: ــ نېمىشقا غوجام ئۆز قۇلىنى مۇنداق قوغلايدۇ؟ مەن نېمە قىلىپتىمەن؟ قولۇمدا نېمە يامانلىق بار؟
\v 19 ئەمدى غوجام پادىشاھ ئۆز قۇلىنىڭ سۆزىگە قۇلاق سالغاي. پەرۋەردىگار سىلىنى ماڭا قارشى قوزغاتقان بولسا بىر ھەدىيە-قۇربانلىق ئۇنىڭ كۆڭلىنى رازى قىلغاي؛ لېكىن ئىنسان بالىلىرى بولسا، ئۇلار پەرۋەردىگارنىڭ ئالدىدا لەنەتكە قالسۇن، چۈنكى ئۇلارنىڭ ئەمدى مېنى پەرۋەردىگارنىڭ مىراسىدىن بەھرىمەن بولۇشتىن مەھرۇم قىلىپ، مېنى باشقا ئىلاھلارغا ئىبادەت قىل، دېگىنى بولىدۇ. \f ◼ \fr 26:19 \ft \bd «... پەرۋەردىگار سىلىنى ماڭا قارشى قوزغاتقان بولسا بىر ھەدىيە-قۇربانلىق ئۇنىڭ كۆڭلىنى رازى قىلغاي...»\bd* ــ مەنىسى: (1) داۋۇت مەلۇم يامانلىق قىلغان بولسا، پەرۋەردىگار ئۇنى قۇربانلىق ئارقىلىق كەچۈرۈم قىلىدۇ؛ (2) پەرۋەردىگار سائۇلنى جازالاش ئۈچۈن ئۇنى داۋۇتقا قارشى چىقىشقا قوزغىغان بولسا، شۈبھىسىزكى، ئۇ قۇربانلىق ئارقىلىق سائۇلنى كەچۈرۈم قىلىدۇ. \bd «چۈنكى ئۇلارنىڭ ئەمدى مېنى پەرۋەردىگارنىڭ مىراسىدىن بەھرىمەن بولۇشتىن مەھرۇم \bdit قىلماقچى\bdit*...»\bd* ــ مۇشۇ يەردە «پەرۋەردىگارنىڭ مىراسى»: (1) خۇدا ئىسرائىلغا ۋەدە قىلغان قانائان زېمىنىنى؛ (2) خۇدانىڭ ئىبادەت چېدىرىدىكى تۈزۈمى ئارقىلىق بولغان كۆپ ئىمتىيازلاردىن، جۈملىدىن كاھىن-لاۋىيلار ئارقىلىق خۇدانىڭ تەلىم-كالامىنى ئاڭلاشتىن بەھرىمەن بولۇشنى ئۆز ئىچىگە ئالىدۇ. \bd «\bdit ئۇلارنىڭ\bdit* مېنى باشقا ئىلاھلارغا ئىبادەت قىل، دېگىنى بولىدۇ»\bd* ــ داۋۇت ئۆزى ئىسرائىلنىڭ زېمىنىدا تۇرمىغان بولغاچقا، خۇدانىڭ ئىبادەت چېدىرىغا بارالمايدۇ.\f*
\v 20 ئەمدى مېنىڭ قېنىم پەرۋەردىگارنىڭ ھۇزۇرىدىن يىراق يەرگە تۆكۈلمىسۇن؛ چۈنكى تاغلاردا بىر كەكلىكنى ئوۋلىغاندەك ئىسرائىلنىڭ پادىشاھى بىر يالغۇز بۈرگىنى ئىزدىگىلى چىقىپتۇ، دېدى. \x ◘ \xo 26:20 \xt 1سام. 24‏:15\x*
\m 
\v 21 سائۇل: ــ مەن گۇناھ قىلدىم؛ يېنىپ كەلگىن ئى ئوغلۇم داۋۇت؛ مېنىڭ جېنىم بۈگۈن كۆزلىرىڭدە ئەزىز سانالغىنى ئۈچۈن مەن ساڭا بۇندىن كېيىن ھېچ زىيان-زەخمەت يەتكۈزمەيمەن؛ مانا، ئەخمەقلىق قىلدىم، بەك ئېزىپتىمەن، دېدى.
\m 
\v 22 داۋۇت جاۋاب بېرىپ: ــ مانا پادىشاھنىڭ نەيزىسى، غۇلاملاردىن بىرى كېلىپ ئۇنى ياندۇرۇپ ئالسۇن.
\v 23 پەرۋەردىگار ھەر ئادەمنىڭ ھەققانىيلىقى بىلەن سادىقلىقىغا قاراپ ياندۇرغاي. چۈنكى بۈگۈن پەرۋەردىگار سىلىنى مېنىڭ قولۇمغا تاپشۇردى، لېكىن مەن پەرۋەردىگارنىڭ مەسىھلىگىنىگە قول ئۇزىتىشنى خالىمىدىم.
\v 24 مانا، بۈگۈن سىلىنىڭ جانلىرى مېنىڭ كۆزلىرىمدە ئەزىز بولغاندەك مېنىڭ جېنىم پەرۋەردىگارنىڭ كۆزىدە ئەزىز بولغاي، ئۇ مېنى ھەممە ئاۋارىچىلىكتىن قۇتقۇزغاي، دېدى.
\m 
\v 25 سائۇل داۋۇتقا: ــ ئەي ئوغلۇم داۋۇت، بەرىكەتلەنگەيسەن. سەن جەزمەن ئۇلۇغ ئىشلارنى قىلىسەن، ئىشلىرىڭ جەزمەن راۋاجلىق بولىدۇ، دېدى. ئاندىن داۋۇت ئۆز يولىغا كەتتى، سائۇلمۇ ئۆز جايىغا يېنىپ باردى.
\b
\b
\c 27
\s1 داۋۇت فىلىستىيلەرگە قوشۇلىدۇ
\m 
\v 1 داۋۇت كۆڭلىدە: ــ ھامان بىر كۈنى سائۇلنىڭ قولىدا ھالاك بولىدىغان ئوخشايمەن. شۇڭا فىلىستىيلەرنىڭ زېمىنىغا تېزدىن قېچىپ كېتىشىمدىن باشقا ئامال يوق. شۇنداق قىلسام سائۇل ئىسرائىل زېمىنى ئىچىدە مېنى تېپىشتىن ئۈمىدسىزلىنىپ، ئىزدەشتىن قول ئۈزىدۇ، ۋە مەن ئۇنىڭ قولىدىن قۇتۇلىمەن، دەپ ئويلىدى.
\v 2 شۇنىڭ بىلەن داۋۇت قوپۇپ ئۇنىڭغا ئەگەشكەن ئالتە يۈز ئادەمنى ئېلىپ گاتنىڭ پادىشاھى مائوقنىڭ ئوغلى ئاقىشنىڭ قېشىغا باردى.
\v 3 ئەمدى داۋۇت ۋە ئادەملىرى، يەنى ھەربىرى ئۆز ئائىلىسىدىكىلەر بىلەن بىللە گاتتا ئاقىش بىلەن تۇردى. داۋۇت ئىككى ئايالى، يەنى يىزرەئەللىك ئاھىنوئام ۋە نابالنىڭ تۇل خوتۇنى كارمەللىك ئابىگائىل بىلەن بىللە شۇ يەردە تۇردى.
\m 
\v 4 سائۇل: ــ داۋۇت گاتقا قېچىپتۇ، دېگەن خەۋەرنى ئاڭلىغاندا، ئۇنى يەنە ئىزدەپ يۈرمىدى.
\m 
\v 5 داۋۇت ئاقىشقا: ــ ئەگەر كۆزلىرىنىڭ ئالدىدا ئىلتىپات تاپقان بولسام، ئولتۇرۇشۇم ئۈچۈن سەھرادىكى بىر شەھەردىن بىزگە بىر جاي بەرگەيلا؛ قۇلۇڭ قانداقمۇ شاھانە شەھەردە سىلىنىڭ قاشلىرىدا تۇرسۇن، دېدى.
\m 
\v 6 ئۇ كۈنى ئاقىش ئۇنىڭغا زىكلاگ شەھىرىنى بەردى. شۇنىڭ ئۈچۈن زىكلاگ بۈگۈنكى كۈنگىچە يەھۇدا پادىشاھلىرىغا تەۋە بولۇپ كەلمەكتە.
\v 7 داۋۇت فىلىستىيلەرنىڭ زېمىنىدا تۇرغان ۋاقىت بىر يىل تۆت ئاي بولدى.
\m 
\v 8 داۋۇت بولسا ئۆز ئادەملىرى بىلەن چىقىپ گەشۇرىيلارغا، گەزرىيلەرگە ۋە ئامالەكلەرگە ھۇجۇم قىلىپ، ئۇلارنى بۇلاڭ-تالاڭ قىلىپ تۇراتتى (چۈنكى ئۇلار قەدىمدىن تارتىپ شۇرىغا كىرىش يولىدىن تارتىپ مىسىر زېمىنىغىچە بولغان شۇ يۇرتتا تۇراتتى).
\v 9 داۋۇت \add ھەرقېتىم\add* زېمىندىكىلەرنى قىرىپ ئەر ياكى ئايال بولسۇن، بىرنىمۇ تىرىك قالدۇرمايتتى ۋە قوي، كالا، ئېشەك، تۆگە ۋە كىيىم-كېچەكلەرنى ئېلىپ ئاقىشنىڭ يېنىغا يېنىپ كېلەتتى.
\m 
\v 10 ئاقىش: ــ بۈگۈن قايسى جايلارنى بۇلاڭ-تالاڭ قىلدىڭلار، دەپ سورايتتى؛ داۋۇت: ــ يەھۇدا زېمىنىنىڭ جەنۇب تەرىپىنى، يەراھمىيەللىكلەرنىڭ جەنۇب تەرىپىنى ۋە كېنىيلەرنىڭ جەنۇب تەرىپىنى بۇلاڭ-تالاڭ قىلدۇق، دەيتتى.
\m 
\v 11 داۋۇت ئەر ياكى ئاياللارنىڭ بىرىنىمۇ گاتقا تىرىك ئېلىپ كەلمەيتتى؛ چۈنكى ئۇ: ــ ئۇلار بىزنىڭ توغرىمىزدىن، «داۋۇت ئۇنداق-مۇنداق قىلدى» دەپ گەپ قىلىشى مۇمكىن، دەيتتى. داۋۇت فىلىستىيلەرنىڭ زېمىنىدا تۇرغان ۋاقتىدا ئۇ دائىم شۇنداق قىلاتتى.
\m 
\v 12 شۇڭا ئاقىش داۋۇتقا ئىشەندى: ــ «ئەمدى ئۇ خەلقى ئىسرائىلنى ئۆزىدىن سەسكەندۈرۈۋەتتى؛ مېنىڭ خىزمىتىمدە مەڭگۈ قۇل بولىدۇ»، دەپ ئويلىدى.
\b
\b
\c 28
\s1 ئەن-دوردىكى جادۇگەر ئايال
\m 
\v 1 ئۇ كۈنلەردە فىلىستىيلەر ئىسرائىلغا قارشى جەڭ قىلىش ئۈچۈن ئۆز قوشۇنلىرىنى يىغدى. ئاقىش داۋۇتقا: ــ بىلىشىڭ كېرەككى، ئادەملىرىڭنى ئېلىپ مېنىڭ بىلەن جەزمەن جەڭگە چىقىشىڭ لازىم، دېدى.
\m 
\v 2 داۋۇت ئاقىشقا: ــ ئۇنداقتا سىلى قۇللىرىنىڭ نېمە قىلالايدىغانلىقىنى بىلىپ قالىلا ــ دېدى. ئاقىش داۋۇتقا: ــ مانا، سېنى ئۆزۈمگە مەڭگۈلۈك پاسىبان قىلاي، دېدى.
\m 
\v 3 (سامۇئىل ئۆلگەنىدى ۋە پۈتكۈل ئىسرائىل ئۇنىڭ ئۈچۈن ماتەم تۇتۇپ ئۇنى ئۆز شەھىرى بولغان راماھدا دەپنە قىلغانىدى. سائۇل بولسا جىنكەشلەر بىلەن پالچىلارنى زېمىندىن قوغلاپ چىقاردى). \f ◼ \fr 28:3 \ft \bd «سائۇل بولسا جىنكەشلەر بىلەن پالچىلارنى زېمىندىن قوغلاپ چىقاردى»\bd* ــ مۇشۇ يەردە «جىنكەشلەر» ئۆلگەنلەرنىڭ روھلىرىنى چاقىرغۇچىلارنى كۆرسىتىدۇ. مۇشۇنداق ھەرىكەتلەر تەۋراتتا قاتتىق مەنئى قىلىنغان؛ ئەمەلىيەتتە، ئۇنداق قىلغان كىشىلەر دائىم دېگۈدەك جىنلار تەرىپىدىن ئالدىنىپ كېتىدۇ.\f*  \x ◘ \xo 28:3 \xt 1سام. 25‏:1\x*
\v 4 فىلىستىيلەر توپلىشىپ چىقىپ شۇنەمدە چېدىر تىكتى. سائۇلمۇ ھەم پۈتكۈل ئىسرائىلنى يىغىپ، گىلبوئاھدا چېدىر تىكتى.
\v 5 سائۇل ئەمدى فىلىستىيلەرنىڭ قوشۇن بارگاھىنى كۆرگەندە قورقۇپ، يۈرىكى سۇ بولۇپ كەتتى.
\m 
\v 6 سائۇل پەرۋەردىگاردىن يول سورىدى؛ لېكىن پەرۋەردىگار يا چۈش بىلەن يا «ئۇرىم» بىلەن يا پەيغەمبەرلەر ئارقىلىق ئۇنىڭغا جاۋاب بەرمىدى. \f ◼ \fr 28:6 \ft \bd «پەرۋەردىگار يا چۈش بىلەن يا «ئۇرىم» بىلەن ... ئۇنىڭغا جاۋاب بەرمىدى»\bd* ــ «ئۇرىم» بىرخىل تاش. ئۇ كاھىن كىيگەن «ئەفود»نىڭ يانچۇقىدا تۇرىدۇ. بۇ تاشلار ئارقىلىق ئىسرائىل خەلقى خۇدادىن يول سورىسا بولاتتى. «مىس.» 28:28-30نى كۆرۈڭ.\f*
\m 
\v 7 شۇنىڭ بىلەن سائۇل خىزمەتكارلىرىغا: ــ ماڭا پالچى جىنكەش بىر خوتۇننى تېپىپ بېرىڭلار، مەن بېرىپ ئۇنىڭدىن يول سوراي، دېدى. خىزمەتكارلىرى ئۇنىڭغا: ــ ئەن-دوردا جىنكەش بىر خوتۇن بار ئىكەن، دېدى. \f ◼ \fr 28:7 \ft \bd «ماڭا پالچى جىنكەش بىر خوتۇننى تېپىپ بېرىڭلار»\bd* ــ «پالچى جىنكەش خوتۇن» ئىبرانىي تىلىدا: «پالچى جىنى بار خوتۇن» ياكى «پالچى جىننى چاقىرغۇچى خوتۇن» دېگەن سۆز بىلەن ئىپادىلىنىدۇ. مۇشۇ سۆزلەر ئۇنىڭغا چاپلاشاقان جىن خېلى كۈچلۈك ئىكەن، دېگەننى پۇرىتىدۇ.\f*
\v 8 سائۇل نىقابلىنىپ، باشقا كىيىملەرنى كىيىپ ئىككى ئادەمنى ھەمراھ قىلىپ باردى. ئۇلار كېچىسى بېرىپ خوتۇننىڭ قېشىغا كەلدى. ئۇ خوتۇنغا: ــ ماڭا جىن چاقىرىپ پال ئېچىپ، مەن دېگەن بىرسىنى قېشىمغا كەلتۈرگىن، دېدى.
\m 
\v 9 خوتۇن ئۇنىڭغا: ــ مانا، سائۇلنىڭ قىلغانلىرىنى، يەنى زېمىندىن جىنكەشلەرنى ۋە پالچىلارنى يوقاتقانلىقىنى ئۆزۈڭ بىلىسەن؛ نېمىشقا مېنى ئۆلتۈرۈشكە جېنىمغا تۇزاق قويىسەن، دېدى.
\m 
\v 10 سائۇل ئۇنىڭغا پەرۋەردىگار بىلەن قەسەم قىلىپ: ــ پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، بۇ ئىش ئۈچۈن ساڭا جازا بولمايدۇ، دېدى.
\m 
\v 11 خوتۇن: ــ ساڭا كىمنى چىقىرىمەن؟ ــ دەپ سورىدى. ئۇ: ــ ماڭا سامۇئىلنى چىقارغىن، دېدى.
\m 
\v 12 خوتۇن سامۇئىلنى كۆرگەندە قاتتىق ئاۋاز بىلەن چىرقىرىدى، ئاندىن سائۇلغا: ــ نېمىشقا مېنى گوللايسەن؟ سەن ئۆزۈڭ سائۇلغۇ! ــ دېدى.
\m 
\v 13 پادىشاھ ئۇنىڭغا: ــ قورقمىغىن! نېمىنى كۆردۈڭ؟ ــ دېدى. ئۇ سائۇلغا: ــ مەن بىر ئىلاھنىڭ يەردىن چىققىنىنى كۆردۈم، دېدى.
\m 
\v 14 ئۇ: ــ ئۇنىڭ قىياپىتى قانداق ئىكەن؟ دېدى. خوتۇن: ــ قېرى بىر بوۋاي چىقىۋاتىدۇ؛ ئۇ يېپىنچا كىيگەنىكەن، دېدى. سائۇل: ــ ئۇ سامۇئىل ئىكەن، دەپ بىلىپ، يۈزىنى يەرگە يېقىپ تەزىم قىلدى.
\m 
\v 15 سامۇئىل سائۇلغا: ــ نېمىشقا مېنى ئاۋارە قىلىپ چىقاردىڭ؟ ــ دېدى. سائۇل: ــ مەن تولىمۇ پەرىشان بولدۇم؛ چۈنكى فىلىستىيلەر ماڭا قارشى جەڭ قىلىۋاتىدۇ، ۋە خۇدا مەندىن يىراقلاپ، ماڭا ياكى پەيغەمبەرلەر ئارقىلىق ياكى چۈشلەر ئارقىلىق ھېچ جاۋاب بەرمەيۋاتىدۇ. شۇڭا مېنىڭ نېمە قىلىشىم كېرەكلىكىنى ماڭا بىلدۈرگەيسەن دەپ، سېنى چاقىردىم، دېدى.
\m 
\v 16 سامۇئىل: ــ پەرۋەردىگار سەندىن يىراقلاپ، دۈشمىنىڭ بولغاندىن كېيىن نېمىشقا مەندىن مەسلىھەت سورايسەن؟ ــ دېدى.
\m 
\v 17 ــ پەرۋەردىگار ئۆزى ئۈچۈن مەن ئارقىلىق ئېيتقىنىنى قىلدى؛ پەرۋەردىگار پادىشاھلىقنى قولۇڭدىن يىرتىپ ئېلىپ، قوشناڭغا، يەنى داۋۇتقا بەردى. \f ◼ \fr 28:17 \ft \bd «پەرۋەردىگار ئۆزى ئۈچۈن مەن ئارقىلىق ئېيتقىنىنى قىلدى؛ پەرۋەردىگار پادىشاھلىقنى ... قوشناڭغا، يەنى داۋۇتقا بەردى»\bd* ــ ئوقۇرمەنلەرنىڭ ئېسىدە باركى، سامۇئىل ئەسلىدە سائۇلغا: «پەرۋەردىگار بۈگۈن ئىسرائىلنىڭ پادىشاھلىقىنى سەندىن يىرتىپ ئېلىپ سەندىن ئەۋزەل بولغان بىر يېقىنىڭغا تاپشۇردى» دەپ خۇدانىڭ جازاسىنى ئۇقتۇرغانىدى (28:15).\f*
\v 18 سەن پەرۋەردىگارنىڭ سۆزىگە قۇلاق سالماي، ئۇنىڭ ئامالەكلەرگە قاراتقان قاتتىق غەزىپىنى يۈرگۈزمىگىنىڭ ئۈچۈن پەرۋەردىگار بۈگۈن ساڭا شۇ ئىشنى قىلدى.
\v 19 پەرۋەردىگار ئۆزۈڭ بىلەن ئىسرائىلنىمۇ فىلىستىيلەرنىڭ قولىغا تاپشۇرىدۇ؛ ئەتە سەن ۋە ئوغۇللىرىڭ مېنىڭ بىلەن بىللە بولىسىلەر؛ ۋە پەرۋەردىگار ئىسرائىلنىڭ قوشۇنىنىمۇ فىلىستىيلەرنىڭ قولىغا تاپشۇرىدۇ، دېدى.
\m 
\v 20 سائۇل شۇئان يەرگە دۈم يىقىلدى، سامۇئىلنىڭ سۆزلىرىدىن قاتتىق قورقۇپ كەتتى؛ بىر كېچە-كۈندۈز تاماقمۇ يېمىگەچكە، ماغدۇرىمۇ قالمىدى.
\m 
\v 21 ئايال ئەمدى سائۇلنىڭ قېشىغا بېرىپ ئۇنىڭ تولىمۇ پەرىشان بولغىنىنى كۆرۈپ، ئۇنىڭغا: ــ مانا، دېدەكلىرى جېنىنى ئالقىنىغا ئېلىپ قويۇپ تاپىلىغانلىرىغا بىنائەن قىلدىم.
\v 22 ئەمدى سىلىدىن ئۆتۈنىمەن، دېدىكلىرىنىڭ سۆزىگە كىرگەيلا؛ مېنى سىلىنىڭ ئالدىلىرىغا بىر چىشلەم نان كەلتۈرۈشكە ئۇنىغايلا؛ شۇنىڭ بىلەن سىلى يەپ قۇۋۋەت تېپىپ ئاندىن ئۆز يوللىرىغا كېتەلەيلا، دېدى.
\m 
\v 23 لېكىن ئۇ رەت قىلىپ: ــ يېمەيمەن، دەپ ئۇنىمىدى. ئۇنىڭ خىزمەتكارلىرى ھەم ئايالمۇ يېيىشنى ئۇنىڭغا دەۋەت قىلىشتى؛ ئۇ يەردىن قوپۇپ كارىۋاتتا ئولتۇردى.
\v 24 ئايالنىڭ ئۆيىدە بىر بورداق موزاي بار ئىدى. ئۇ دەرھال ئۇنى سويدى؛ ھەم خېمىر يۇغۇرۇپ پېتىر نان پىشۈرۈپ بەردى.
\v 25 ئۇ ئۇنى سائۇل بىلەن خىزمەتكارلىرىنىڭ ئالدىغا قويدى. ئۇلار يەپ بولۇپ، شۇ كېچىسى كەتتى.
\b
\b
\c 29
\s1 فىلىستىي ئەمىرلەر داۋۇتنى ئۆز سېپىدىن چىقىرىۋېتىدۇ
\m 
\v 1 فىلىستىيلەر ھەممە قوشۇنلىرىنى يىغىپ ئافەكتە جەم قىلدى؛ ئىسرائىللار يىزرەئەلدىكى بۇلاقنىڭ يېنىدا چېدىر تىكتى.
\v 2 فىلىستىيلەرنىڭ سەردارلىرى يۈز ياكى مىڭدىن ئەسكەرنى باشلاپ، سەپ تىزىپ كەلدى؛ ئۇلارنىڭ كەينىدىن داۋۇت ئۆز ئادەملىرىنى باشلاپ ئاقىش بىلەن چىقىپ سەپ تۈزدى.
\m 
\v 3 فىلىستىيلەرنىڭ ئەمىرلىرى: ــ بۇ ئىبرانىيلار بۇ يەردە نېمە ئىش قىلىدۇ؟ ــ دېدى. ئاقىش فىلىستىيلەرنىڭ ئەمىرلىرىگە: ــ بۇ ئىسرائىلنىڭ پادىشاھى سائۇلنىڭ خىزمەتكارى داۋۇت ئەمەسمۇ؟ ئۇ بۇ يەردە بىرنەچچە كۈن، بىرنەچچە يىللاردىن بېرى مەن بىلەن تۇرغان ئەمەسمۇ؟ ئۇ ماڭا كەلگەن كۈندىن تارتىپ بۇ كۈنگىچە ئۇنىڭدىن ھېچ ئەيىب بايقىمىدىم، دېدى.
\m 
\v 4 ئەمما فىلىستىيلەرنىڭ ئەمىرلىرى ئۇنىڭغا ئاچچىقلاندى. فىلىستىيلەرنىڭ ئەمىرلىرى ئۇنىڭغا: ــ ئۇنى قايتۇرۇۋەت! بۇ كىشى سەن ئۆزۈڭ ئۇنىڭغا ئورۇنلاشتۇرغان جايغا كەتسۇن؛ بىز بىلەن بىللە سوقۇشقا چۈشمىسۇن، بولمىسا، ئۇ سوقۇشتا بىزگە رەقىب بولۇپ قېلىشى مۇمكىن. بۇ ئادەم ئۆز غوجىسى بىلەن نېمىسى ئارقىلىق يارىشىدۇ؟ بۇ ئادەملەرنىڭ باشلىرىنى ئېلىش بىلەن بولمامدۇ؟ \x ◘ \xo 29:4 \xt 1تار. 12‏:20\x*
\v 5 بۇ قىز-ئاياللار بۇرۇن ئۇنىڭ توغرىسىدا ئۇسسۇل ئويناپ قوشاق قېتىپ: ــ سائۇل مىڭلاپ ئۆلتۈردى، ۋە داۋۇت ئون مىڭلاپ ئۆلتۈردى، دېگەن داۋۇت ئەمەسمۇ؟ ــ دېدى. \x ◘ \xo 29:5 \xt 1سام. 18‏:7\x*
\m 
\v 6 ئاقىش داۋۇتنى چاقىرىپ ئۇنىڭغا: ــ پەرۋەردىگارنىڭ ھاياتى بىلەن \add قەسەم قىلىپ ئېيتىمەنكى\add*، سەن دۇرۇس ئادەمسەن، سېنىڭ مېنىڭ بىلەن لەشكەرگاھتا خىزمەتتە بولۇشۇڭ كۆزلىرىمدە ياخشى ئىشتۇر؛ چۈنكى ماڭا كەلگەن كۈنىدىن تارتىپ بۇ كۈنگىچە سەندىن ھېچ يامانلىق بايقىمىدىم. لېكىن سەن ئەمىرلەرگە ياقماپسەن. \f ◼ \fr 29:6 \ft \bd «سېنىڭ مېنىڭ بىلەن لەشكەرگاھتا خىزمەتتە بولۇشۇڭ...»\bd* ــ ئىبرانىي تىلىدا «سېنىڭ مېنىڭ بىلەن لەشكەرگاھغا كىرىپ-چىقىشىڭ».\f*
\v 7 شۇڭا تىنچ-ئامان يېنىپ كەتكىن، بولمىسا فىلىستىيلەرنىڭ ئەمىرلىرىنى نارازى قىلىپ قويىسەن، دېدى.
\m 
\v 8 داۋۇت ئاقىشقا: ــ مەن نېمە قىلدىم؟ سىلىنىڭ قاشلىرىغا كەلگەن كۈندىن تارتىپ بۇ كۈنگىچە قىلغان قايسى \add يامانلىقىم\add* ئۈچۈن مېنى غوجام پادىشاھنىڭ دۈشمەنلىرى بىلەن سوقۇشقىلى بارغۇزمايلا؟ ــ دېدى.
\m 
\v 9 ئاقىش داۋۇتقا جاۋاب بېرىپ: ــ كۆزلىرىمدە خۇدانىڭ بىر پەرىشتىسىدەك ماڭا ياخشى ئىكەنلىكىڭنى بىلىمەن. لېكىن فىلىستىيلەرنىڭ ئەمىرلىرى سېنى بىز بىلەن بىللە جەڭگە چىقمىسۇن دەۋاتىدۇ، دېدى.
\m 
\v 10 شۇڭا ئەتە سەھەردە قوپۇڭلار، ئۆزۈڭ ۋە بىللە كەلگەنلەر، يەنى مەن خوجاڭنىڭ خىزمەتكارلىرى؛ سەھەردە قوپۇڭلار، تاڭ يورۇشى بىلەنلا چىقىپ كېتىڭلار، دېدى.
\m 
\v 11 شۇڭا داۋۇت ئۆز ئادەملىرى بىلەن سەھەردە تۇرۇپ فىلىستىيلەرنىڭ زېمىنىغا ماڭدى. فىلىستىيلەر بولسا يىزرەئەلگە چىقتى.
\b
\b
\c 30
\s1 داۋۇت ئامالەكلەردىن بالا-چاقىلىرىنى قۇتقۇزىدۇ
\m 
\v 1 شۇنداق بولدىكى، داۋۇت ۋە ئادەملىرى ئۈچىنچى كۈنى زىكلاگقا يېتىپ كەلدى؛ مانا، ئامالەكلەر جەنۇب تەرەپكە ۋە زىكلاگقا ھۇجۇم قىلىپ، زىكلاگنى ۋەيران قىلىپ ئوت قويۇپ كۆيدۈرگەنىدى.
\v 2 ئۇلار شەھەردىكى قىز-ئاياللارنى، چوڭ بولسۇن، كىچىك بولسۇن، ئۇلارنىڭ ھەممىسىنى ئەسىرگە ئالدى. ئۇلاردىن ھېچكىمنى ئۆلتۈرمەي، ھەممىسىنى ئېلىپ، يولىغا چىققانىدى.
\m 
\v 3 داۋۇت ئۆز ئادەملىرى بىلەن شەھەرگە كەلگەندە، مانا، شەھەر ئاللىقاچان كۆيۈپ تۈگىگەنىدى؛ ئۇلارنىڭ ئاياللىرى ۋە ئوغۇل-قىزلىرى ئەسىرگە ئېلىنغانىدى.
\v 4 ئەمدى داۋۇت ۋە ئۇنىڭ بىلەن بىللە بولغان خەلق قاتتىق يىغا-زار كۆتۈرۈشتى، تاكى ماغدۇرى قالمىغۇچە يىغلاشتى.
\v 5 داۋۇتنىڭ ئىككى ئايالى، يىزرەئەللىك ئاھىنوئام بىلەن كارمەللىك نابالدىن تۇل قالغان ئابىگائىلمۇ ئەسىرگە ئېلىنغانىدى.
\v 6 داۋۇت قاتتىق ئازابلاندى؛ چۈنكى بارلىق خالايىق، ھەربىرى ئۆز ئوغۇل-قىزلىرى ئۈچۈن قايغۇرۇپ غەزەپلىنىپ ئۇنى چالما-كېسەك قىلىپ ئۆلتۈرەيلى، دېيىشىۋاتاتتى. ئەمما داۋۇت ئۆزىنى خۇداسى پەرۋەردىگاردىن كۈچ-قۇۋۋەتلەندۈردى.
\m 
\v 7 داۋۇت ئاخىمەلەكنىڭ ئوغلى كاھىن ئابىياتارغا: ــ ئەفودنى يېنىمغا ئېلىپ كەلگىن، دېدى. \f ◼ \fr 30:7 \ft \bd «ئەفودنى يېنىمغا ئېلىپ كەلگىن»\bd* ــ «ئەفود» توغرۇلۇق 18:2دىكى ئىزاھاتنى كۆرۈڭ.\f*
\m 
\v 8 داۋۇت پەرۋەردىگاردىن: ــ بۇ قوشۇننى قوغلايمۇ؟ ئۇلارغا يېتىشەلەرمەنمۇ؟ ــ دەپ سورىدى. ئۇ: ــ قوغلا؛ سەن جەزمەن ئۇلارغا يېتىشىۋالىسەن ھەم ھەممىسىنى قايتۇرۇپ كېلەلەيسەن، دېدى.
\m 
\v 9 داۋۇت ۋە ئۇنىڭ بىلەن بىللە بولغان ئالتە يۈز ئادەم بېرىپ بېسور ۋادىسىغا يېتىپ كەلگەندە، كەينىدە سۆرۈلۈپ قالغانلار شۇ يەردە قالدى.
\v 10 داۋۇت ئۆزى تۆت يۈز ئادەم بىلەن داۋاملىق قوغلاپ ماڭدى؛ ئىككى يۈز ئادەم ھالسىراپ كەتكەچكە، بېسور ۋادىسىدىن ئۆتەلمەي كەينىدە قالغانىدى.
\m 
\v 11 ئۇلار دالادا مىسىرلىق بىر ئادەمنى ئۇچراتتى. ئۇلار ئۇنى داۋۇتنىڭ قېشىغا ئېلىپ كېلىپ، ئۇنىڭغا نان بېرىپ يېگۈزدى، سۇ ئىچكۈزدى؛
\v 12 ئۇنىڭغا بىر پارچە ئەنجۈر پوشكىلى بىلەن ئىككى كىشمىش پوشكىلىنىمۇ بەردى. ئۇ بۇلارنى يەپ، ئۇنىڭغا قايتىدىن جان كىردى؛ چۈنكى ئۇ ئۈچ كېچە-كۈندۈز نان يېمىگەن، سۇمۇ ئىچمىگەنىدى.
\v 13 داۋۇت ئۇنىڭدىن: ــ سەن كىمگە تەۋە؟ سەن قەيەرلىكسەن؟ ــ دەپ سورىدى. ئۇ: ــ مەن مىسىرلىق يىگىت بولۇپ، بىر ئامالەكنىڭ قۇلىمەن. لېكىن مەن ئۈچ كۈن ئىلگىرى كېسەل بولۇپ قالغاچقا، غوجام مېنى تاشلىۋەتتى.
\v 14 بىز ئەسلى كەرەتىيلەرنىڭ يۇرتىنىڭ جەنۇب تەرىپىگە ۋە يەھۇدا زېمىنىغا ۋە كالەبنىڭ زېمىنىنىڭ جەنۇب تەرىپىگە ھۇجۇم قىلىپ بۇلاڭ-تالاڭ قىلدۇق؛ شۇنداقلا زىكلاگنى كۆيدۇرۈۋەتكەنىدۇق، دېدى.
\m 
\v 15 داۋۇت ئۇنىڭدىن: ــ بىزنى ئۇ \add دۈشمەن\add* قوشۇنى تەرەپكە باشلاپ بارالامسەن، دېدى. ئۇ: ــ خۇدانىڭ نامى بىلەن مەن سېنى ئۆلتۈرمەيمەن، سېنى غوجاڭنىڭ قولىغىمۇ تۇتۇپ بەرمەيمەن دەپ قەسەم قىلسىلا، سىلىنى ئۇ قوشۇننىڭ قېشىغا باشلاپ باراي، دېدى.
\m 
\v 16 ئۇنى ئۇ يەرگە باشلاپ بارغاندا، مانا ئۇلار پۈتكۈل يەرگە يېيىلىپ، يەپ-ئىچىپ فىلىستىيلەرنىڭ زېمىنىدىن ھەم يەھۇدا زېمىنىدىن ئالغان چوڭ ئولجىلىرىدىن خۇش بولۇپ ئۇسسۇل ئوينىشىۋاتاتتى.
\m 
\v 17 ئەمما داۋۇت شۇ كۈنى گۇگۇمدىن تارتىپ ئىككىنچى كۈنى كەچكىچە ئۇلارنى ئۇرۇپ قىردى. تۆگىگە مىنىپ بەدەر قاچقان تۆت يۈز يىگىتتىن باشقا ھېچبىر ئادەم قېچىپ قۇتۇلمىدى؛
\v 18 ۋە داۋۇت ئامالەكلەر بۇلىۋالغان ھەممە نەرسىنى ياندۇرۇپ ئالدى؛ ئۆزىنىڭ ئىككى ئايالىنىمۇ قۇتقۇزۇۋالدى.
\v 19 ئامالەكلەر ئېلىپ كەتكەن ئوغۇل-قىز، مال-مۈلۈكلەر ۋە باشقا ھەممە نەرسىنى داۋۇت ئۇلاردىن قايتۇرۇۋالدى. ھېچنېمە، چوڭ بولسۇن كىچىك بولسۇن چۈشۈپ قالمىغانىدى.
\m 
\v 20 \add داۋۇتنىڭ ئادەملىرى\add* قايتۇرۇۋالغان ماللىرىنىڭ ئالدىغا \add ئولجا ئالغان\add* باشقا قوي ۋە كالا پادىلارنى سېلىپ ھەيدەپ كېتىۋاتاتتى. \add ئۇنىڭ ئادەملىرى\add* كېتىۋېتىپ: ــ بۇلار داۋۇتنىڭ ئولجىسى، دېيىشتى؛ داۋۇت ئۇلارنىڭ ھەممىسىنى ئۆزىگە ئالدى. \f ◼ \fr 30:20 \ft \bd «داۋۇتنىڭ ئادەملىدى قايتۇرۇۋالغان ماللىرىنىڭ ئالدىغا ... باشقا قوي ۋە كالا پادىلارنى سېلىپ ھەيدەپ كېتىۋاتاتتى»\bd* ــ بەلكىم ئامالەكلەر ئىلگىرى داۋۇت ۋە ئادەملىرىدىن بۇلىۋالغان مال ئەمەس، بەلكى ئامالەكلەرنىڭ ئۆزلىرىنىڭ باشقا ماللىرى بولۇشى مۇمكىن.\f*
\m 
\v 21 داۋۇت ھالسىزلىنىپ ئۆزى بىلەن بىللە بارالمىغان بېسور ۋادىسىنىڭ بويىدا قالدۇرۇپ كەتكەن ئىككى يۈز ئادەمنىڭ قېشىغا يېتىپ كەلدى؛ ئۇلار داۋۇت ۋە ئۇنىڭ بىلەن كەلگەن ئادەملەرنىڭ ئالدىغا چىقتى، داۋۇت خەلقنىڭ قېشىغا بېرىپ ئۇلارغا سالام قىلدى.
\m 
\v 22 لېكىن داۋۇت بىلەن بارغانلارنىڭ ئارىسىدىكى رەزىل ئادەملەر ۋە ئەرزىمەسلەرنىڭ ھەممىسى قوپۇپ: ــ بۇلار بىز بىلەن بارمىغاندىن كېيىن بىز ياندۇرۇپ ئالغان ئولجىدىن ئۇلارغا ھېچ نېمە بەرمەيلى. ئۇلار پەقەت ھەربىرى ئۆز خوتۇن-بالىلىرىنى ئېلىپ كەتسۇن، دېدى. \f ◼ \fr 30:22 \ft \bd «رەزىل ئادەملەر ۋە ئەرزىمەسلەر...»\bd* ــ ئىبرانىي تىلىدا: «رەزىل ئادەملەر ۋە بېلىئالنىڭ (ئىبلىسنىڭ) ئوغۇللىرى...».\f*
\v 23 ئەمما داۋۇت: ــ ياق، ئى بۇرادەرلىرىم؛ پەرۋەردىگار بىزگە تەقسىم قىلغاننى \add ئۇلارغىمۇ تەقسىم\add* قىلمىساق بولمايدۇ. چۈنكى ئۇ بىزنى قوغداپ بىزنىڭكىگە تاجاۋۇز قىلغانلارنى قولىمىزغا تاپشۇردى.
\v 24 بۇ ئىشتا كىم سىلەرگە ماقۇل دەيدۇ؟ چۈنكى سوقۇشقا چۈشكەننىڭ ئۈلۈشى قانداق بولسا يۈك-تاقلارغا قارىغۇچىلارنىڭمۇ ئۈلۈشى شۇنداق بولىدۇ؛ ھەممە ئادەم تەڭ بۆلۈشسۇن ــ دېدى.
\v 25 شۇ كۈندىن تارتىپ بۇ ئىسرائىل ئۈچۈن ھۆكۈم-بەلگىلىمە قىلىپ بېكىتىلدى. بۈگۈنگىچە ھەم شۇنداق.
\v 26 داۋۇت زىكلاگقا يېتىپ كەلگەندە، ئولجىدىن دوستلىرى بولغان يەھۇدا ئاقساقاللىرىغا ئەۋەتىپ: ــ مانا، پەرۋەردىگارنىڭ دۈشمەنلىرىدىن ئالغان ئولجا سىلەرگە بىر سوۋغات بولسۇن، دېدى.
\m 
\v 27 ئۇ ئولجىدىن ھەم بەيت-ئەلدىكىلەرگە، جەنۇبىي راموتتىكىلەرگە، ياتتىردىكىلەرگە،
\v 28 ئاروئەردىكىلەرگە، سىفموتتىكىلەرگە، ئەشتەموئادىكىلەرگە،
\v 29 راقالدىكىلەرگە، يەراھمىيەللىكلەرنىڭ شەھەرلىرىدىكىلەرگە ۋە كېنىيلەرنىڭ شەھەرلىرىدىكىلەرگە،
\v 30 خورماھتىكىلەرگە، قوراشاندىكىلەرگە، ئاتاقتىكىلەرگە، \f ◼ \fr 30:30 \ft \bd «قوراشاندىكىلەرگە...»\bd* ــ ياكى «بوراشاندىكىلەرگە...».\f*
\v 31 ھېبروندىكىلەرگە ۋە داۋۇت ۋە ئادەملىرى بىللە يۈرگەن ھەممە يەردىكىلەرگە سوۋغات ئەۋەتتى.
\b
\b
\c 31
\s1 سائۇل قازا قىلىدۇ، ئىسرائىل مەغلۇپ بولىدۇ
\r 1تار. 10‏:1-12
\m 
\v 1 ئەمدى فىلىستىيلەر ئىسرائىل بىلەن جەڭ قىلدى. ئىسرائىلنىڭ ئادەملىرى فىلىستىيلەرنىڭ ئالدىدىن قېچىپ، گىلبوئا تېغىدا قىرىپ يىقىتىلدى.
\v 2 فىلىستىيلەر سائۇل ۋە ئۇنىڭ ئوغۇللىرىنى تاپ بېسىپ قوغلاۋاتاتتى. فىلىستىيلەر بولسا سائۇلنىڭ ئوغۇللىرى يوناتان، ئابىناداب، مەلكىشۇئانى ئۇرۇپ ئۆلتۈردى.
\v 3 سائۇلنىڭ ئەتراپىنى ئۇرۇش قاپلىدى؛ ئوقياچىلار سائۇلغا يېتىشتى؛ ئۇ يا ئوقى بىلەن ئېغىر يارىلاندۇرۇلدى.
\m 
\v 4 ئاندىن سائۇل ياراغ كۆتۈرگۈچىسىگە: ــ قىلىچىڭنى سۇغۇرۇپ مېنى سانجىپ ئۆلتۈرۈۋەتكىن؛ بولمىسا بۇ خەتنىسىزلەر كېلىپ مېنى سانجىپ، مېنى خورلۇققا قويۇشى مۇمكىن، دېدى. لېكىن ياراغ كۆتۈرگۈچىسى ئىنتايىن قورقۇپ كېتىپ، ئۇنىمىدى. شۇنىڭ بىلەن سائۇل قىلىچنى ئېلىپ ئۈستىگە ئۆزىنى تاشلىدى.
\v 5 ياراغ كۆتۈرگۈچىسى سائۇلنىڭ ئۆلگىنىنى كۆرۈپ، ئۇمۇ ئوخشاشلا ئۆزىنى قىلىچنىڭ ئۈستىگە تاشلاپ ئۇنىڭ بىلەن تەڭ ئۆلدى.
\v 6 شۇنىڭ بىلەن سائۇل، ئۈچ ئوغلى، ياراغ كۆتۈرگۈچىسى ۋە ئۇنىڭ ھەممە ئادەملىرى شۇ كۈندە بىراقلا ئۆلدى.
\m 
\v 7 ئەمدى ۋادىنىڭ ئۇ تەرىپىدىكى ھەمدە ئىئوردان دەرياسىنىڭ بۇ يېقىدىكى ئىسرائىللار ئەسكەرلىرىنىڭ قاچقانلىقىنى ۋە سائۇل بىلەن ئوغۇللىرىنىڭ ئۆلگىنىنى كۆرگىنىدە، شەھەرلەرنى تاشلاپ قاچتى، فىلىستىيلەر كېلىپ ئۇ جايلاردا ئورۇنلاشتى. \f ◼ \fr 31:7 \ft \bd «ئىئوردان دەرياسىنىڭ بۇ يېقى...»\bd* ــ بەلكىم ئىئوردان دەرياسىنىڭ غەربىي تەرىپىنى كۆرسىتىدۇ.\f*
\m 
\v 8 ئەمدى شۇنداق بولدىكى، ئەتىسى فىلىستىيلەر ئۆلتۈرۈلگەنلەرنىڭ كىيىم-كېچەكلىرىنى سالدۇرۇۋالغىلى كەلگەندە گىلبوئا تېغىدا سائۇل بىلەن ئوغۇللىرىنىڭ ئۆلۈك ياتقانلىقىنى كۆردى.
\v 9 ئۇلار ئۇنىڭ بېشىنى كېسىپ ساۋۇت-ياراغلىرىنى سالدۇرۇپ بۇلارنى فىلىستىيلەرنىڭ زېمىنىنىڭ ھەممە يەرلىرىگە ئاپىرىپ بۇتخانىلىرىدا ۋە خەلقنىڭ ئارىسىدا بۇ خۇش خەۋەرنى تارقاتتى. \f ◼ \fr 31:9 \ft \bd «ئۇلار ... ساۋۇت-ياراغلىرىنى سالدۇرۇپ بۇلارنى فىلىستىيلەرنىڭ زېمىنىنىڭ ھەممە يەرلىرىگە ئاپىرىپ بۇتخانىلىرىدا ...خۇش خەۋەرنى تارقاتتى»\bd* ــ ياكى «ئۇلار ... ساۋۇت-ياراغلىرىنى سالدۇرۇپ، ئېلانچىلارنى فىلىستىيلەرنىڭ زېمىنىنىڭ ھەممە يەرلىرىگە ئەۋەتىپ بۇتخانىلىرىدا ...خۇش خەۋەرنى تارقاتتى».\f*  \x ◘ \xo 31:9 \xt 1تار. 10‏:9\x*
\v 10 ئۇلار ئۇنىڭ ساۋۇت-ياراغلىرىنى ئاشتاروت بۇتخانىسىدا قويۇپ ئۆلۈكىنى بەيت-شان شەھىرىدىكى سېپىلغا ئېسىپ قويدى.
\m 
\v 11 ئەمدى يابەش-گىلېئادتا ئولتۇرغۇچىلار فىلىستىيلەرنىڭ سائۇلغا نېمە قىلغىنىنى ئاڭلىغاندا
\v 12 ئۇلارنىڭ ئىچىدىكى ھەممە باتۇرلار ئاتلىنىپ كېچىچە مېڭىپ، سائۇل بىلەن ئوغۇللىرىنىڭ ئۆلۈكلىرىنى بەيت-شاندىكى سېپىلدىن چۈشۈرۈپ، ئۇلارنى يابەشكە ئېلىپ بېرىپ ئۇ يەردە كۆيدۈردى.
\v 13 ئاندىن ئۇلارنىڭ سۆڭەكلىرىنى يابەشتىكى يۇلغۇننىڭ تۈۋىگە دەپنە قىلىپ يەتتە كۈن روزا تۇتتى. 
