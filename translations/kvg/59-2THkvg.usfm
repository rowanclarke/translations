\id 2TH - NT0243 Kuni/Boazi [kvg] (Kuni Dialect) - Fumey Dec/2015
\ide UTF-8
\h 2 Tesalonika
\toc1 2 Tesalonika
\toc2 2 Thessalonians
\toc3 2 Tes
\mt1 2 Tesalonika
\mt2 Pol-qa pepa qambo-menas, Klisten bawan ezoqam-te, ndigu Tesalonika taon-te giyagam
\is1 Megeat Manqat-qase
\ip Pol nqanek pepa nøme, Tesalonika taon Klisten bawan ezoqam-te gepeawam, ta khøuwa-te ndøgo, ndego Kolin taon-té gegoám.
\ip Bugukhokhof khøuwa, Pol Tesalonika taon-te, mø̀ndøgoám, Mbumbukiam-qa Manqat vø̄e-zømesimam. Yaq ezoqa kopoáv, teqa manqat gè-unimanqatiním. Geté Zu ezoqa nøme, ta zapaya ndøgo, ova ndø-einím, Pol vø̄ngeatømem (Kel 17:1-10).
\ip Yaq ndakin Pol manqat āv gene-ewág nqǽgo: Tesalonika Klisten ezoqa nøme, ndigu gèqavotumít, av nqægo, Yesu nqawa tendoqavan. Ndigu āv gini-mataváp nqǽgo: Yesu nqawa màndoqaván. Yaq ndigu sège-qovezám neka sasae gonemáv. Nqanek pepa mokho-te, Pol ndigu nqawá gene-zømesím, Yesu-qa qavane-qa yaq-te. Yaq ndego nøme āv gezømbe-peawám nqǽgo: Ndigu tiqa yage, bè-enénd, neka matev eqeieqei-té geabeyagé. Sasae yà begó.
\c 1
\p 
\v 1 Nqanek pepa no Pol neka Sailes neka Timoti, ni nipeaomít. Zo-té qeitø-peaomít, zo Klisten bawan ezoqam, Tesalonika taon-te ndozoyage, zo Mbumbukiam, nigi Tat, neka Evezøza, Yesu Keliso, tiqa mokho-te ndozotu꞉gu.
\p 
\v 2 \x - \xo 1:2 \xt Lom 1:7\x*Mbumbukiam, nigi Tat, neka Yesu Keliso, nigi Evezøza, tiqa kuku matev neka sambi matev ndø̀goát, zo-te.
\s1 Yesu-qa qavøne khøuwa neka unimanqatin-te bazaføgakh-us waniap-qa yaq-te
\p 
\v 3 Nǿfuap! Ni Mbumbukiam ike manqat oskia bambu-manqaté, zo zapaya. Matev av nqægo eqeieqeí. Zapa ndǿgo, zoqa unimanqatin kandambá qazømbe-khouwevtét, neka zoqa kuku matev, zo ate ndøzøte꞉go yaqyaq-a nandøzøgo, nāndø̄zø̄-khōūwēvtēt.
\v 4 \x - \xo 1:4 \xt 2 Ko 7:4; 1 Tes 2:19\x*Yaq nakémbá, ni zo nìti-khambuvupatún, Mbumbukiam-gi Klisten bawabawan nøme mokho-te. Zapa ndǿgo, zo ambá gini-ngenøzoát neka zo matev føgøføgakh ambá qazøte-upøgím, geté zo sekembá sozo-apét, zoqa unimanqatin-te neka bazaføgakh-us ndōzōwānī.
\p 
\v 5 Ta matev ate ndægo, zo-te ndøfakhanumit, Mbumbukiam, ni āv gininømánd nqǽgo: Teqa manqa ovøyam matev, ndaføyamba-qapé. Zo ndakin Mbumbukiam-qa Megeat Matev zapaya, ngenøgim matev ndozo-ndape, ndego zo eqeieqei mé꞉zǽb. Yaq zo kopømbaqapé, teqa Megeat Matev-te ndøgo, ndòzomø-óz.
\v 6 \x - \xo 1:6 \xt Lom 12:19\x*Mbumbukiam-qa matev eqeieqeí. Ndego yaq-fia ndǿtá, ti-te ndigu, zo ndingenøzoat.
\v 7 \x - \xo 1:7 \xt 1 Tes 3:13\x*Geté zo ndakin ndingiæzoat, Mbumbukiam pusup zǿ-etoám, ni namba. Ta khøuwa-te ndǿgo tenǿgó, Evezøza Yesu tendoveao, ndego tegi enzol ezoqam bazaføgakh-us namba, yan-te tendovis, gøina wageap-us.
\v 8 \x - \xo 1:8 \xt Isa 66:15\x*Yaq ndego yaq-fia ndǿtá, ti-te ndigu, Mbumbukiam ndisanqawe neka ndigu Manqat Mbomambaqape, nigi Evezøza Yesu-qa yaq-te, manqa o-mba ndapeav ndigu.
\v 9 \x - \xo 1:9 \xt Isa 2:10\x*Yaq-fia teta, nqánek: Ndigu soqaqape-té gígoát. Miavmiáv. Neka ndigu Evezøza-te neka teqa waev bazaføgakh-us-te, géqatáz.
\v 10 \x - \xo 1:10 \xt Kol 3:4\x*Nqanek matev ta khøuwa-te ndǿgo tønéfakhán, ndego tendoqavan, neka iz kandambaqape vǿndāp, ta zapaya ndøgo, ndego ekeza ezoqam gezømbe-matanam. Neka gekha ezoqām ndigu, ndi-unimanqatinat, khanakhanakh mbá ginígoát te-te. Até zo-á, zo søzøtumú-goát, ti namba. Zapa ndǿgo, manqat ndøgo, ni zo qeizø-manqatam, zo mòzo-unimanqatiním.
\v 11 \x - \xo 1:11 \xt Kol 1:9; 1 Tes 1:2-3\x*Yaq nakémbá, ni oskia niguligulimatún, zoqa yaq-te. Ni Mbumbukiam-te, āv qati-vi꞉matún nqǽgo: Ndego nigi Mbumbukiam, zo gezǿtøkeé. Yaq zo āv tøzøté-yagát, av ndego gezømbe-akha, zo tozoyagat. Yaq zo ambá av nqǣgo, matev eqeieqei gone-qa mba zógōt. Geté zoqa unimanqatin matev mokho-te neka Mbumbukiam-qa bazaføgakh-te, zo matev eqeieqei uni zøtégoát.
\v 12 Yaq nigi Evezøza Yesu Keliso-qa iz, gé-eqatát, zo zapaya, yaq te mokho-te, até zoqá íz-a, vǿ-eqatāt. Nqanek matev ate ndægo, nigi Mbumbukiam neka Evezøza Yesu Keliso, tiqa kuku matev mokho-té qando-fakhaté.
\c 2
\s1 Matev vinivinimba ndø̀khæ-fakhanám, yaq váev, Keliso tendoqavan
\p 
\v 1 Nǿfuap! Nigi Evezøza Yesu Keliso-qa qavøne-qa yaq-te neka ni te namba tizipindam, taqa yaq-te, ni āv qazimbi-pouwé nqǽgo:
\v 2 Zo matavap nakhamas-te, bezø-enø̀vøe᷄m neka ndøfofogìme᷄m, ezoqa nøme tezø-ein, av nqægo, Yesu-qa qavøne khøuwa mø̀ndø-fakhān. Oskiá ndøgo, ezoqa Nqova Mbomambaqape-qa iz-te, manqat av nqægo tezø-ein, o te-ein av nqægo, nqanek manqat ni-tē qandowāv o nī nitøndu-peaomēm, zo ndø-unimanqatìni᷄m.
\v 3 \x - \xo 2:3 \xt 1 Tim 4:1; 1 Zion 2:18; 4:3\x*Zo ezoqa betùba᷄m. Yesu naqanøká géfakhanák. Bugukhokhof ezoqa kopoáv, Mbumbukiam zitá giní-wuowém. Neka ndego ezoqam bètøndokhæ-veáo, ndego Mbumbukiam-qa manqat ndemøkuiam, yaq ndego Mbumbukiam vaev-te vǿngiū.
\v 4 \x - \xo 2:4 \xt Dan 11:36; Ezek 28:2\x*Ndego ezoqa soqaqape, Mbumbukiam-gé qaqa ezoqam ndǿgoát. Neka ndego ekeza kha, āv genévewát nqǽgo: Mbumbuk ate ndi꞉gu, unimé꞉-løvubám, neka gekha gigiap nømē ndøgo, ezoqa ndimbovizap, vǿløvuām. Yaq ndego Mbumbukiam-qá khoev-té gemǿqóm. Neka ezoqa āv gezømbé-manqatát nqǽgo, “No Mbumbukiām.”
\p 
\v 5 Zo tozombó-matavap? No taqa yaq-te mø̀ezømbe-manqatám, no zo-te qægoam.
\v 6 Zo mø̀zøte-zøtéz, ndego ezoqa soqaqape, gekha ndø̄geiwat, atema ta khøuwa-te ndøgo, ma Mbumbukiam gembøezav, tendoveao.
\v 7 Khonoam-te ndøgo, Mbumbukiam-qa Manqat møkuiam matev, mø̀ndøngáz. Geté ndakin ezoqa kopo nqanek matev gò꞉toké, atema ta khøuwa-te ndøgo, tewav.
\v 8 \x - \xo 2:8 \xt Isa 11:4; Veve 19:15\x*Taqa zita-te, ndego ezoqa soqaqape gendóveáo. Geté vaev-te, Evezøza Yesu tendowav, ndego gélaváo. Segé-khambáo, vǿsoqoēv. Teqa bugug waev-us, géngiú.
\v 9 \x - \xo 2:9 \xt Veve 13:11-13\x*Ndego ezoqa soqaqape, Saitan-qá bazaføgakh-té genǿgeáv, neka umingiap matev vinivinimba vǿmatønumāt. Ndego andé Mbumbukiam-qá matev me mé꞉goát. Geté ndøgo khavozam matév.
\v 10 Gekha matev soqøsoqā ndøgo, ndego sugumúgút, neka ezoqa vǿtubām, ndigu Mbumbukiam vaev-te tengiæzo. Mbumbukiam ndigu ta zapaya ndǿgo tené-ngiæzó: Ndigu poeveáv, unimanqatin manqat tindapem, yaq vǿe-khandī꞉z.
\v 11 Ndigu unimanqatin manqat ndapeav tigoat, yaq Mbumbukiam tiqa matavap nøme mba zømbó-enegím. Yaq ndigu khavozam manqat vǿ-unimanqatinīm.
\v 12 Yaq ndigu yaq-fia géndapém, ndigu unimanqatin manqat unimanqatinteav qagoam neka matev soqøsoqa vøzø̄-goupam.
\s1 Ni føgøføgakh bizi-waniáp, ni Mbumbukiam gevevendam
\p 
\v 13 \x - \xo 2:13 \xt 2 Tes 1:3; Ef 1:4\x*Nǿfuap! Ni Mbumbukiam ike manqat oskia bambu-manqaté, zo zapaya, ma Evezøza kuku ndømbøego. Mbumbukiam zo é-møndo꞉-vevesám, zo gēkhandī꞉z, zo Nqova Mbomambaqape-qa mokho-te, ndaføyamba ndozoyage neka unimanqatin manqat ndōzō-ūnīmānqātīnāt.
\v 14 Mbumbukiam zo Manqat Mbomambaqape mokho-te, ni qati-zømesimam, ndǿgo tezømbe-akhá: Zo nigi Evezøza Yesu Keliso-qá waev-té neka bazaføgakh-qape-té qazógoát.
\v 15 Nǿfuap! Yaq nakémbá, zo føgøføgakh ndøwaniáp neka nømendim manqat oskia ndøkhatiwí, ndøgo niqa manqat neka pepa mokho-te qati-zømesimam.
\p 
\v 16 Yesu Keliso, nigi Evezøza, neka Mbumbukiam, nigi Tat, ndego kuku ndømbogo ni-te, neka teqa tanakh matev mokho-te, ni miavmiav zita ndini-tøpøzu neka vintønat matev mbomambaqape gini-etoam,
\v 17 ndigu zo zita bezøtøpøzú, neka zo bezø̄tøkee. Yaq zo kopømbaqapé, gekha matev eqeieqeī ndøgo, sozógoát neka manqat eqeieqei vozó-manqatāt.
\c 3
\s1 Pol Klisten ezoqam gezøviam, tiqa yaq-te tiguligulimat
\p 
\v 1 Nǿfuap! Manqat nøme nqánek: Zo niqa yaq-te, āv qane-guligulím: Evezøza-qa nømendim matev, nakhamas-té qabenø-vøndá. Neka ezoqa bèndapém. Vizap-ús. Ate av-té, zo qazøte-ndapem.
\v 2 Neka nøme āv qane-guligulím: Mbumbukiam ni ezoqa soqøsoqa-te, tèabinimbi-khakhazám, ndigu ni ngiænoat-qa ndigu. Zapa ndǿgo, ezoqa nøme, ndigu unimanqatinteáv, Mbumbukiam-qa Manqat.
\v 3 Geté ndego Evezøza, unimanqatín. Ndego zo bazaføgakh zǿ-etoám neka nqova soqaqape-te gezømbó-khakhazumát.
\v 4 \x - \xo 3:4 \xt 2 Ko 7:16; Gal 5:10\x*Ni Evezøza-te āv qati-vintønat nqǽgo: Manqat ndøgo, ni zo nqazimbi-løvuat, zo matev mòzogoatún. Yaq zo sozó-apét, ta matev-te nqanek.
\v 5 Ni Evezøza-te āv qati-guligulím nqǽgo: Ndego zo tèabezømbe-tøkeé, yaq zo Mbumbukiam-qa kuku matev nøme mba zøtézøtéz, neka føgøføgakh vozó-waniapāt, ate av-té, Keliso føgøføgakh ge꞉yam.
\s1 Klisten ezoqam, sasae yà begó
\p 
\v 6 \x - \xo 3:6 \xt Lom 16:17\x*Nǿfuap! Nigi Evezøza Yesu Keliso-qa iz-te, ni nqeizǿ-pouwe: Klisten ezoqa nøme, ndigu sasae ndøzømbo-qasi꞉vap neka ndigu yageav ndøgo, av ni zo qati-zømesimam, zo ti namba me꞉khokhòmba᷄p.
\v 7 \x - \xo 3:7 \xt Filip 3:17\x*Zo zøkeza mø̀zøte-zøtéz, zo niqa yage matev gèmbopáev. Zapa ndǿgo, ni zo-te qeiyagam, ni ambá av nqǣgo, niwaui꞉ntām.
\v 8 \x - \xo 3:8 \xt 1 Tes 2:9\x*Ni lou logemáv, ndøgo ni fia gonemav qagoam. Geté pavpave nekā lovølova, ni sasae bazaføgakh-us nigoám. Zapa ndǿgo, ni poeveáv, ni zo ezoqa nøme-te teito-tambat.
\v 9 \x - \xo 3:9 \xt 1 Ko 9:4; 1 Tes 1:6\x*Ni amba tøni-poeɨn, ni ambá kopømbá, zo-te lou-qa yaq-te teito-tambɨn. Geté ni nikeza zendá qati-sasaetám. Ni tøti-matønumám ndǿgo: Zo niqa matev, tø̀mbøe-paevém.
\v 10 Ni zo-te qeigoam, ni mø̀izø-manqatám, av nqægo: Gekha ezoqām ndego, sasae tømbøe-qasi꞉vat, ndego lou belòge᷄.
\p 
\v 11 \x - \xo 3:11 \xt 1 Tim 5:13\x*Ni āv qatiyogé nqǽgo: Zo ezoqa nøme khokhó sozoyagé. Sasae gonemáv. Ndigu kesov ezoqam-qá matev-té ginø-sokhosumatún.
\v 12 \x - \xo 3:12 \xt 1 Tes 4:11\x*Ezoqam av nandi꞉gu, ni Evezøza Yesu Keliso-qa iz-te, nqeizǿ-pouwe, neka ni ndigu āv qati-guguzá nqǽgo: Ndigu matev eqeieqei-té giabenø-yagé neka bèsasaeát, ekeza lou-qa.
\p 
\v 13 \x - \xo 3:13 \xt Gal 6:9\x*Nǿfuap! Zo matev eqeieqei matanam-te bezø-èwe᷄z.
\v 14 Klisten ezoqa nøme, manqat ndapeav tegoat, ni nqanek pepa-te qeipeaomem, gè-ometé, neka zo te namba me꞉khokhòmba᷄p. Yaq ndego mivi bendáp.
\v 15 \x - \xo 3:15 \xt 1 Tes 5:14\x*Geté zo ezoqam av nge꞉go, qaqa ezoqam mèvewe᷄. Geté zóguguím. Zo gèmbo-mataváp. Ndego zogé Klisten zøfú.
\s1 Pol-qa vaev manqat
\p 
\v 16 Ni āv qati-guligulím nqǽgo: Gekha matēv ndøgo, zo tøzø-fakhanumat, Evezøza, ndego sambi zapa, zo sambi oskia zǿ-etoumát.
\p Evezøza ndø̀goát, zo namba, zo ate ndøzøte꞉go.
\p 
\v 17 Nqanek khaiya mboma manqat-qase nqanek, no Pol, nøkeza zendá qate-peaomít. Noqa pepa-te ate ndægo, no āv tøte-peaumatún. Yaq ezoqa segézøtéz, ta pepa ndøgo, no-té qandowáv.
\p 
\v 18 Nigi Evezøza Yesu Keliso-qa kuku matev, ndø̀goát, zo-te, zo ate ndøzøte꞉go. 
