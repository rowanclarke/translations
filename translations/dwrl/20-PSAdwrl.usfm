\q2 taani daroppe Aa siik'ay. 
\q1  
\v 168 Taani ne wogawunne 
\q2 neeni odeeddawoo azazettana; 
\q2 ayaw gooppe, ta ogiyaa ubbaa neeni be'aasa. 
\qa Taw 
\q1  
\v 169 Abeet Med'inaa Godaw, ta waasuu, 
\q2 ne sintsa gakko; 
\q2 neeni geedda k'aalaadan taw akeekaa imma. 
\q1  
\v 170 Ta watiwatuu ne sintsa gakko; 
\q2 neeni geedda k'aalaadan taana ashsha. 
\q1  
\v 171 Neeni ne awaayuwaa 
\q2 taana tamaarissiyaa diraw, 
\q2 ta doonaappe galatay pulttana. 
\q1  
\v 172 Ne azazotuu ubbay s'illo gidiyaa diraw, 
\q2 ta ins's'arssay ne k'aalaabaa yes's'ana. 
\q1  
\v 173 Taani ne wogaa dooreedda diraw, 
\q2 ne kushii taana maaddanaw giigeeddawaa gido. 
\q1  
\v 174 Abeet Med'inaa Godaw, neeni 
\q2 taana ashshana mala laamotay; 
\q2 ne higgiikka taana nashechchee. 
\q1  
\v 175 Taani neena galatana mala, 
\q2 taana pas'a wotsa; 
\q2 ne pirddaykka taana maaddo. 
\q1  
\v 176 Taani bayeedda dorssaadan bichchaaray; 
\q2 taana ne k'oomaa koya; 
\q2 ayaw gooppe, taani ne azazuwaa dogabeykke. 
\c 120  
\s1 C'imiyaawanttuppenne Worddotuwaappe  // Attanaw Shiik'o Woosaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa 
\q1  
\v 1 Ta waayiyaa wode taani Med'inaa Godaa s'eesaad; 
\q2 I taw koyeedda. 
\q1  
\v 2 Abeet Med'inaa Godaw, worddotiyaa doonatuwaappenne, 
\q2 c'immiyaa ins's'arssatuwaappe taana ashsha. 
\b  
\q1  
\v 3 Hinttenoo worddanchchatoo, 
\q2 S'oossay hinttena waatanddeeshsha? 
\q1 Simmi harabaa ayaa gujjanddeeshsha? 
\q1  
\v 4 Tooranchchatuwaa pootsaa k'aran I hinttena c'addanawaa; 
\q2 tamaa bonk'k'uwaan I hinttena s'uuggana. 
\b  
\q1  
\v 5 Aayye taanoo! Hinttenana de'iyaawe Mesheka 
\q2 woy K'eedaare asaana de'iyaawaa mala iita. 
\q1  
\v 6 Sarotetsaa is's'iyaa asatuwaana 
\q2 taani daro wodiyaa de'aaddi. 
\q1  
\v 7 Taani saro asaa; 
\q2 shin taani sarotetsaabaa haasayiyaa wode, 
\q2 unttunttu olaawaa haasayiino! 
\c 121  
\s1 S'oossay Nuuna Naagiyaawaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa 
\q1  
\v 1 Taani d'ok'k'u gaade wogga deretuwaa s'eellay; 
\q2 taw maaduu hak'appe yanddeeshsha? 
\q1  
\v 2 Taw maaduu 
\q2 saluwaanne sa'aa med'd'eedda Med'inaa Godaappe yee. 
\b  
\q1  
\v 3 I ne gediyaa halis'issenna; 
\q2 neena naagiyaawe gem"ishenna. 
\q1  
\v 4 Israa'eeliyaa naagiyaawe, 
\q2 ubbakka gisennanne gem"ishenna. 
\q1  
\v 5 Med'inaa Goday neena naagiyaawaa. 
\q2 Med'inaa Goday new ushechcha baggana gidiide, 
\q2 neena kuwayiyaawaa. 
\q1  
\v 6 Gallassi neena away meenna; 
\q2 k'ammakka aginay neena k'ohenna. 
\b  
\q1  
\v 7 Med'inaa Goday k'ohiyaawaa ubbaappe neena naagana; 
\q2 I ne shemppuwaa naagana. 
\q1  
\v 8 Med'inaa Goday ne buussaa, ne yuussaa, 
\q2 hachcheppe med'inaa gakkanaw naagana. 
\c 122  
\s1 Yerusaalamiw Shiik'eedda Sabaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa, Daawite s'aafeeddawaa 
\q1  
\v 1 Unttunttu taana, «Ane Med'inaa Godaa golliyaa boytte» yaagina, 
\q2 taani nashetaad. 
\q1  
\v 2 Neenoo Yerusaalame katamatee, 
\q2 nuuni ne penggetuwaanna geliide ek'k'eeddo! 
\b  
\q1  
\v 3 Yerusaalame katamay, 
\q2 dantsetiide minni kees'etteedda katamaa. 
\q1  
\v 4 Med'inaa Godaa awaayuwaadan, 
\q2 Israa'eeliyaa zaratuu, 
\q1 Med'inaa Godaa galatanaw yiyaa katamay hawaa. 
\q1  
\v 5 Daawita zeretsaappe kaateteeddawanttu 
\q2 barenttu asaw pirddanaw yaan utteeddino. 
\b  
\q1  
\v 6 Yerusaalame sarotetsaw 
\q2 hawaadan yaagiide woossite; 
\q1 «Neena siik'iyaawanttoo 
\q2 unttunttu ootsiyaawe ubbay suuro! 
\q1  
\v 7 Ne gimbbetuwaa giddon saruu de'o! 
\q2 Ne geesatuwaakka bochchiyaabay d'ayo!» yaagiide woossite. 
\q1  
\v 8 Ta ishatuwaanne ta dabbotuwaa diraw gaade, 
\q2 «Ne giddon saruu de'o!» yaagay. 
\q1  
\v 9 Med'inaa Godaa nu S'oossaa golliyaa diraw gaade, 
\q2 taani Yerusaalame durettanaw woosana. 
\c 123  
\s1 Maarotaa Demanaw Shiishsho Woosaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa 
\q1  
\v 1 Neenoo, kawutetsaa araatan saluwaan utteeddawoo, 
\q2 taani pude neekko s'eellay. 
\q1  
\v 2 K'oomay bare godaa kushiyaa s'eelliyaawaadaaninne 
\q2 k'oomata bare godatti kushiyaa s'eelliyaawaadan, 
\q2 hewaadankka I nuuna maarana gakkanaw, 
\q2 nu ayifii Med'inaa Godaakko, nu S'oossaakko, s'eellee. 
\b  
\q1  
\v 3 Nuuna maara; abeet Med'inaa Godaw, nuuna maara. 
\q2 Ayaw gooppe, nuw kad'ii dareedda. 
\q1  
\v 4 Nuuni ishaluwaan de'iyaawanttu shek'aanne 
\q2 otoranchchatuwaa kad'iyaa kalleeddo. 
\c 124  
\s1 S'oossay Israa'eeliyaa Ashiyaawaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa, Daawite s'aafeeddawaa 
\q1  
\v 1 Med'inaa Goday nu bagga gidennentto, nuuni waananeeshsha? 
\q2 Israa'eeliyaa asatuu zaaruwaa hawaadan yaagiide zaariino; 
\q1  
\v 2 «Med'inaa Goday nu bagga gidennentto, 
\q2 nu bollan Asay denddeedda wode, 
\q1  
\v 3 unttunttu nu bollan hank'k'uwaa suulliide, 
\q2 nuuna pas'a mittana shin. 
\q1  
\v 4 Di'uu nuuna meec'c'iide; 
\q2 shaafaa haatsay nuuna muukkana shin; 
\q1  
\v 5 kuntso haatsay nuuna maana shin» yaagino. 
\b  
\q2  
\v 6 Nuuna nu morkkatuwaa matan, 
\q2 s'oonissibeenna Med'inaa Goday galatetto. 
\q1  
\v 7 Nuuni shankkanchchatuwaa p'iriyaappe, 
\q2 kafuu kessi akkiyaawaadan kessi akkeeddo. 
\q1 P'irii me"eedda, nuunikka kessi akki atteedo! 
\q1  
\v 8 Nu maaduu 
\q2 saluwaanne sa'aa med'd'eedda Med'inaa Godaa suntsaappe yee. 
\c 125  
\s1 S'oossay Bare Asaw Waase 
\d Pudetsaa kesiidde yes's'eedda yetsaa 
\q1  
\v 1 Med'inaa Godaan ammanettiyaawanttu k'aas's'anaw danddayenna, 
\q2 med'inaw de'iyaa S'iyoone deriyaa mala. 
\q1  
\v 2 Deretuu 
\q2 Yerusaalame katamaa yuushshuwaan de'iyaawaadan, 
\q2 hachcheppe med'inaa gakkanaw, 
\q2 Med'inaa Goday bare asaa yuushshuwaan de'ee. 
\b  
\q1  
\v 3 S'illotuu barenttu kushshiyaa iitatetsaw dentsenna mala, 
\q2 iitatuwaa ayissuwaa s'am"ay, 
\q2 s'illotoo imetteedda biittaa bollan gam"enna. 
\q1  
\v 4 Abeet Med'inaa Godaw, keeka asatoonne, 
\q2 wozanaa suure asatoo keekkabaa ootsa. 
\q1  
\v 5 Barenttu geella ogiyaa simmiyaawantta, 
\q2 Med'inaa Goday iitaa ootsiyaawanttuna ittippe mura. 
\q1 Israa'eeliyaw saruu gido! 
\c 126  
\s1 Omooduwaappe Simmeeddawanttu Mazimuriyaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa 
\q1  
\v 1 Med'inaa Goday nuuna omoodetteeddawantta zaariide, 
\q2 S'iyoone aheedda wode, nuw akumuwaa malateedda. 
\q1  
\v 2 He wode nuuni daro nashetti, miic'c'iide, 
\q2 nashshechchaa yetsaa yes's'eeddo. 
\q1 Yaatina, hara kawutetsatuu barenttu giddon, 
\q2 «Hawanttoo Med'inaa Goday wolk'k'aamabaa ootseedda» yaageeddino. 
\q1  
\v 3 Tumukka Med'inaa Goday nuw wolk'k'aamabaa ootseedda; 
\q2 nuunikka loytsi nashetteeddo. 
\b  
\q1  
\v 4 Abeet Med'inaa Godaw, Neegeeba Bazzuwaan iraa bukissaade, 
\q2 shaafaa haatsaa zaara kuntsiyaawaadan, 
\q2 nuwukka nu kaac'aa ooratsa. 
\q1  
\v 5 Yeekkiide zereeddawanttu, 
\q2 nashshechchan yes's'iidde c'akkana. 
\q1  
\v 6 Zeretsaa tookkiide, yeekkiidde beeddawanttu, 
\q2 nashshechchaa yetsaa yes's'iidde, 
\q2 mirk'k'iyaa tookkiide simmana. 
\c 127  
\s1 S'oossaan Ammanetanaaddan Imetteedda Zoriyaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa, Solomon s'aafeeddawaa 
\q1  
\v 1 Med'inaa Goday golliyaa kees's'ana d'ayooppe, 
\q2 kees's'iyaawanttu c'oo mela daaburiino. 
\q1 Med'inaa Goday katamaa naagana d'ayooppe, 
\q2 naagiyaawanttu c'oo mela naagiino. 
\q1  
\v 2 Neeni wontta guuran denddiyaawe, 
\q2 omarssi k'amissaade gisiyaawe, 
\q2 k'umaw hirggaade tuggatiyaawe c'oo mela; 
\q2 ayaw gooppe, S'oossay bare siik'iyaawanttoo shemppuwaa immee. 
\q1  
\v 3 Naanay Med'inaa Godaappe imettiyaa imotaa; 
\q2 yelotuu tumuwaappe woytuwaa. 
\q1  
\v 4 Itti uray bare yalagatetsan yeleedda attuma naanatuu, 
\q2 olanchchaa kushiyan de'iyaa tooratuwaa mala. 
\q1  
\v 5 He k'arc'c'iitan de'iyaa wonddaafiyaa tooratuwaadan, 
\q2 daro naanatuu de'iyaa Asay anjjetteeddawaa. 
\q1 Ayaw gooppe, I bare morkkatuwaanna, 
\q2 katamaa penggiyaan mootettiyaa wode, ubbakka s'oonettenna. 
\c 128  
\s1 S'oossaw Azazetussaan Beetiyaa Anjjuwaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa 
\q1  
\v 1 Med'inaa Godaw yayyiyaawanttunne, 
\q2 Aa ogiyaan hamettiyaawanttu ubbay anjjetteedawantta. 
\b  
\q1  
\v 2 Neeni ne daaburaa ayifiyaa maana; 
\q2 neeni nashettananne new lo"o gidana. 
\q1  
\v 3 Ne machata ne son ayifiyaa dorkkokkeedda, 
\q2 woyniyaa turaa mala gidana. 
\q1 Ne naanatuukka ne gaytaa yuushshuwaan, 
\q2 wogaraa puutiyaa mala gidana. 
\q1  
\v 4 Med'inaa Godaw yayyiyaa asay 
\q2 tumuwaappe hewaadan anjjettana. 
\b  
\q1  
\v 5 Med'inaa Goday neena S'iyooneppe anjjo! 
\q2 Neeni de'eedda laytsaa ubbaan 
\q1 Yerusaalame lo"otetsaa neena besso. 
\q1  
\v 6 Ne naanatuwaa naanatuwaa be'a! 
\b  
\q2 Israa'eeliyaw saruu gido! 
\c 129  
\s1 Israa'eelii Morkkiyaappe Attanaw Shiishsho Woosaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa 
\q1  
\v 1 Israa'eeliyaa Asay hawaadan yaago; 
\q2 «Unttunttu ta yalagatetsaadeppe doommiide, 
\q2 taana uk'k'inneeddino. 
\q1  
\v 2 Ee, unttunttu ta yalagatetsaadeppe doommiide, 
\q2 taana uk'k'inneeddino; 
\q2 shin unttunttu taana d'ayissibeykkino. 
\q1  
\v 3 Ta zokkiyaa k'ays's'eeriyaan shoc'i shoc'iide, 
\q2 gosheedda shoyk'aa malatisseeddino» yaago. 
\q1  
\v 4 Shin Med'inaa Goday s'illo gideeddawe 
\q2 iitatuwaa k'ashuwaappe taana billi yeddeedda. 
\b  
\q1  
\v 5 S'iyoone is's'iyaa ubbay, 
\q2 yeellatiide guyye simmo. 
\q1  
\v 6 Golliyaa huup'iyaan mokkiide, 
\q2 dic'c'anaappe kasetiide meliyaa maataa mala gido. 
\q1  
\v 7 He maataa buuc'c'anaw kushiyaan dankkiyaawe, 
\q2 woy mirk'k'iyaa k'achchiyaawe ooninne baawa. 
\q1  
\v 8 He ogiyaanna aad'd'iyaawanttu, 
\q2 «Med'inaa Goday wolk'k'aa immo» giina, c'akkiyaawanttu, 
\q1 «Med'inaa Goday anjjo» giyaawe de'enna. 
\c 130  
\s1 Maaduwaa demanaw Shiik'eedda Woosaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa 
\q1  
\v 1 Abeet Med'inaa Godaw, taani metuwaa c'iimman de'aadde, 
\q2 neekko waassay. 
\q1  
\v 2 Abeet Godaw, ta kooshshaa sisa; 
\q2 taani watiwatiyaa watiwatuwaa ne haytsay hayzzo. 
\q1  
\v 3 Abeet Med'inaa Godaw, neeni, 
\q2 nu nagaraa mazggobiyaan s'aafeeddentto, 
\q2 abeet Godaw, won ooni pirddaappe attanaw danddayii? 
\q1  
\v 4 Shin nuuni neena bonchchiidde azazettana mala, 
\q2 nuw atto yaagaasa. 
\b  
\q1  
\v 5 Taani Med'inaa Godaa naagay; 
\q2 ee, taani Aa laamotaan naagay; 
\q1 Aa k'aalankka hidootaa ootsay. 
\q1  
\v 6 Sa'ay awude wonttanddeeshsha 
\q2 giide naagiyaa k'amma zabaynyatuwaappe aad'd'aade, 
\q2 taani unttunttuppekka aatsaade, 
\q2 Godaa laamotaan naagay. 
\b  
\q1  
\v 7 Israa'eeliyaa asaw, Med'inaa Godaan hidootaa ootsite; 
\q2 ayaw gooppe, aggena siik'uu Med'inaa Godaana; 
\q2 k'ay I ubbaa gede asaa ashshanaw koyee. 
\q1  
\v 8 Israa'eeliyaa asaa 
\q2 unttunttu nagaraa ubbaappe ashshanawe Aa.\x - \xo 130:8 \xt Mat. 1:21; Tit. 2:14\x* 
\c 131  
\s1 S'oossaan Ammanettussaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa, Daawite s'aafeeddawaa 
\q1  
\v 1 Abeet Med'inaa Godaw, taani wozanaan ayyiyaawaa aggaad; 
\q2 ta ayfiyaan otoruwaan s'eelabeykke. 
\q1 Wolk'k'aamabaw woy eranaw danddayenna 
\q2 malalissiyaabaw taani hirggikke. 
\q1  
\v 2 Hewaa aggade d'antsaa duus's'eedda na'ay 
\q2 bare aatti matan c'o"u giyaawaadan, 
\q2 taani c'o"u gaad. 
\q2 Ee, woppu geedda na'aadan taani woppu gaad. 
\q1  
\v 3 Israa'eeliyaa asaw, hachcheppe 
\q2 med'inaa gakkanaw Med'inaa Godaan hidootaa ootsite. 
\c 132  
\s1 Geeshsha Golliyaa Sabbanaw Shiik'o Mazimuriyaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa 
\q1  
\v 1 Abeet Med'inaa Godaw, 
\q2 Daawitanne I danddayeedda metuwaa k'oppa. 
\q1  
\v 2 Med'inaa Godaw I c'aak'k'eeddawaa, 
\q2 Yaak'ooba s'oossaw, Wolk'k'aamaw 
\q1 I hawaadan yaagiide geppeeddawaa hassaya; 
\q1  
\v 3 «Hawaappe guyiyaan taani ta golle gelikke, 
\q2 woy ta hiis'an gisikke. 
\q1  
\v 4 Taani ta ayifiyaa c'iilimmikke, 
\q2 woy gem"ishikke. 
\q1  
\v 5 Hewenne, taani Med'inaa Godaw sa'aa, 
\q2 Yaak'ooba S'oossaw, Wolk'k'aamaw 
\q2 de'iyaasaa giigissana gakkanaassa» yaageedda. 
\b  
\q1  
\v 6 Hekko, nuuni Taabootaabaa, 
\q2 Efiraatan siseeddo;\x - \xo 132:6 \xt 2 Od. 6:41-42\x* 
\q1 Yi'aariima giyaa biittaan Aa nuuni demmeeddo. 
\q1  
\v 7 Nuuni, «Ane I de'iyaasaa boytte; 
\q2 Aa gedii yed'd'iyaasaan guufanniide, 
\q2 aw goyinneetto» yaageeddo. 
\b  
\q1  
\v 8 Abeet Med'inaa Godaw, dendda! 
\q2 Ne minotetsaw mallaa gidiyaa ne Taabootaanna, 
\q2 ne Geeshsha Golliyaa gelaade de'a. 
\q1  
\v 9 Ne k'eesatuu s'illotetsaa mayno; 
\q2 ne asatuu nashshechchaw yes's'ino. 
\q1  
\v 10 Ne k'oomaa Daawita diraw, 
\q2 neeni okkeedda kaatiyaa aggoppa. 
\b  
\q1  
\v 11 Med'inaa Goday Daawitaw laamettena c'aak'uwaa 
\q2 hawaadan yaagiide c'aak'k'eedda;\x - \xo 132:11 \xt 2 Sam. 7:12-16; 1 Od. 17:11-14; Maz. 89:3-4; Kit. 2:30\x* 
\q1 «Ne gulbbataappe yeletteedda ne naanatuwaappe ittuwaa 
\q2 taani kawutsana. 
\q1  
\v 12 Ne naanatuu ta c'aak'uwaanne 
\q2 taani tamaarissiyaa timirttiyaa naagooppe, 
\q2 unttunttu naanatuukka ne kawutetsaa araatan med'inaw uttana» yaageedda. 
\q1  
\v 13 Med'inaa Goday S'iyoone dooreedda; 
\q2 barew de'iyaasaa ootsanawukka amottiide, 
\q2 hawaadan yaageedda; 
\q1  
\v 14 «Hawe taw med'inaw de'iyaa sa'aa; 
\q2 taani amotteedda diraw, hawaan uttana. 
\q1  
\v 15 Taani daro katsaa immaade S'iyoono anjjana; 
\q2 izin de'iyaa hiyyeesatuwaakka k'umaa kalissana. 
\q1  
\v 16 Izin de'iyaa k'eesetuwaakka 
\q2 taani atotetsaa mayzzana; 
\q2 izin S'oossaa asatuukka nashshechchaw yes's'ana. 
\b  
\q1  
\v 17 «Ha sa'aan, 
\q2 Daawita zeretsaappe ittuwaa kawutsana;\x - \xo 132:17 \xt 1 Kat. 11:36\x* 
\q2 taani okkeedda kaatiyaa kawutetsaa gam"etsana. 
\q1  
\v 18 Taani Aa morkkatuwaa yeellaa mayzzana; 
\q2 shin Aa huup'iyaan de'iyaa kawutetsaa kallachchay p'oolana» yaageedda. 
\c 133  
\s1 Ishatuwaa Siik'oo Shiik'eedda Sabaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa, Daawite s'aafeeddawaa 
\q1  
\v 1 Ishatuu ittippetetsan de'iyaawe ayiba lo"obeenne nashechchiyaabee! 
\q1  
\v 2 Hewe huup'iyaa okkina, buuchchaanna goggiyaa, 
\q2 Aaroona buuchchaanna goggiide 
\q1 Aa mayuwaa morggiyaa gakkiyaa al"o zayitiyaa mala. 
\q1  
\v 3 Hewe Hermmoone deriyaa ketterssay, 
\q2 S'iyoone Deretuwaa gakkiyaawaa mala. 
\q1 Med'inaa Goday hewan anjjuwaa, med'inaa de'uwaa immeedda. 
\c 134  
\s1 S'oossaa Galatussaa 
\d Pudetsaa kesiidde yes's'eedda yetsaa 
\q1  
\v 1 Hinttenoo Med'inaa Godaa k'oomatoo, 
\q2 Med'inaa Godaa golliyaan k'amma ootsiyaawanttoo, 
\q2 ubbaykka haa yiide, Med'inaa Godaa galatite. 
\q1  
\v 2 Geeshsha Golliyaan hintte kushiyaa mic'c'iide, 
\q2 Med'inaa Godaa galatite. 
\b  
\q1  
\v 3 Saluwaanne sa'aa med'd'eedda Med'inaa Goday, 
\q2 hinttena S'iyooneppe anjjo. 
\c 135  
\s1 Galataa Mazimuriyaa 
\q1  
\v 1 Med'inaa Godaa galatite! 
\b  
\q1 Hinttenoo Med'inaa Godaa k'oomatoo, 
\q2 Med'inaa Godaa suntsaa galatite! 
\q1  
\v 2 Hinttenoo Med'inaa Godaa golliyaa giddon, 
\q2 nu S'oossaa golliyaa dabaaban ek'k'eeddawanttoo, 
\q1 S'oossaa galatite! 
\q1  
\v 3 Med'inaa Goday keeka gidiyaa diraw, 
\q2 Med'inaa Godaa galatite! 
\q1 I lo"a gidiyaa diraw, 
\q2 Aa suntsaa sabbite! 
\q1  
\v 4 Med'inaa Goday Yaak'ooba bare huup'ew, 
\q2 Israa'eeliyaa asaakka barew buzo ootsiide dooreedda. 
\b  
\q1  
\v 5 Med'inaa Goday wolk'k'aama gidiyaawaanne 
\q2 nu Goday s'oossatuwaa ubbaappe d'ok'k'iyaawaa, 
\q2 taani eray. 
\q1  
\v 6 Saluwankka saankka, 
\q2 abbatuwaaninne unttunttu c'iimmotuwaa ubbaa giddonkka, 
\q1 Med'inaa Goday bare doseeddawaa ubbaa ootsee. 
\q1  
\v 7 Iraa tooko shaariyaa sa'aa gas'aappe I dentsee; 
\q2 I iraanna walk'k'antsaa kiittee; 
\q2 bare minjjiyaa sa'aappe c'arkkuwaa kessee. 
\b  
\q1  
\v 8 Gibs'e biittan asaa naanatuwaappenne, 
\q2 mehiyaa maraappe, 
\q2 bayira yeletteeddawantta wod'eedda. 
\q1  
\v 9 Neenoo Gibs'ee, Par"oonanne Aa k'oomatuwaa muranaw, 
\q2 hinttenttu gidon ooratsabaanne malalissiyaabaa yeddeedda. 
\q1  
\v 10 I daro kawutetsatuwaa bayzzeedda; 
\q2 wolk'k'aama kaatetuwaakka wod'eedda. 
\q1  
\v 11 Amooretuwaa kaatiyaa Sihoona, 
\q2 Baasaane kaatiyaa Ooganne, 
\q2 Kanaane kaatetuwaa ubbaa wod'eedda. 
\q1  
\v 12 Unttunttu biittaa bare asatuwaa, 
\q2 Israa'eelatuwaa laatisseedda. 
\q1  
\v 13 Abeet Med'inaa Godaw, ne suntsay med'inaw de'ana; 
\q2 yeletaappe yeletaa gakkanaw Med'inaa Goday hassayettana. 
\q1  
\v 14 Med'inaa Goday bare asaw pirddana; 
\q2 I bare k'oomatoo k'arettana. 
\q1  
\v 15 Gadiyaa asatuwaa eek'atuu asaa kushii 
\q2 biraappenne work'k'aappe med'd'eeddawantta.\x - \xo 135:15 \xt Maz. 115:4-8; Sas'. 9:20\x* 
\q1  
\v 16 Unttunttoo doonay de'ee, shin haasayikkino; 
\q2 ayifii de'ee, shin s'eellikkino. 
\q1  
\v 17 Haytsay de'ee, shin sissikkino; 
\q2 unttunttu doonaan shemppuu baawa. 
\q1  
\v 18 Unttuntta med'd'eeddawanttunne, 
\q2 unttunttun ammanettiyaawanttu, 
\q2 ubbay unttunttudan hanino. 
\q1  
\v 19 Israa'eeliyaa golliyaa asatoo, 
\q2 Med'inaa Godaa galatite; 
\q1 Aaroona golliyaa asatoo, 
\q2 Med'inaa Godaa galatite; 
\q1  
\v 20 Leewiyaa golliyaa asatoo, 
\q2 Med'inaa Godaa galatite; 
\q1 Med'inaa Godaw yayyiyaawanttoo, 
\q2 ubbay Med'inaa Godaa galatite. 
\q1  
\v 21 Yerusaalamen de'iyaa Med'inaa Goday 
\q2 S'iyoonen galatetto! 
\b  
\q1 Med'inaa Godaa galatite! 
\c 136  
\s1 Galataa Mazimuriyaa 
\q1  
\v 1 Med'inaa Godaa galatite! Ayaw gooppe, I keeka;\x - \xo 136:1 \xt 1 Od. 16:34; 2 Od. 5:13; 7:3; Izr. 3:11; Maz. 100:5; 106:1; 107:1; 118:1; Erm. 33:11\x* 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 2 S'oossatuwaa S'oossaa galatite! 
\q2 Aggena Aa siik'uu med'inaawaa. 
\q1  
\v 3 Godatuwaa Godaa galatite! 
\q2 Aggena Aa siik'uu med'inaawaa. 
\b  
\q1  
\v 4 Aa s'alalay wolk'k'aama malalissiyaabaa ootsee; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 5 Bare aad'd'eeda eran I salotuwaa med'd'eedda;\x - \xo 136:5 \xt Dom. 1:1\x* 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 6 Biittaa haatsaa bollan mic'c'eedda;\x - \xo 136:6 \xt Dom. 1:2\x* 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 7 Wolk'k'aama poo'otuwaa med'd'eedda;\x - \xo 136:7 \xt Dom. 1:16\x* 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 8 Away gallassi mooddanaadan ootseedda; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 9 Aginayinne s'oolinttetuu 
\q2 k'amma mooddanaadan ootseedda; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 10 I Gibs'e biittan bayiratuwaa wod'eedda;\x - \xo 136:10 \xt Kes. 12:29\x* 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 11 Israa'eeliyaa asaa, 
\q2 Gibs'eppe kaaletsiide kesseedda;\x - \xo 136:11 \xt Kes. 12:51\x* 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 12 Bare mino kushiyan, 
\q2 bare wolk'k'aama k'esiyaan hawaa ootseedda; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 13 Zo'o Abbaa shaakki yegeedda;\x - \xo 136:13 \xt Kes. 14:21-29\x* 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 14 Israa'eeliyaa asaa, 
\q2 he abbaa gidduwaana pintseedda; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 15 Gibs'e kaatiyaanne Aa olanchchatuwaa 
\q2 Zo'o Abban muukisseedda; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 16 I bare asaa kaaletsiide, 
\q2 bazzuwaana aatseedda; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 17 Wolk'k'aama kaatetuwaa shoc'eedda; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 18 Eretteedda kaatetuwaa wod'eedda; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 19 Amooretuwaa kaatiyaa Sihoona wod'eedda;\x - \xo 136:19 \xt Pay. 21:21-30\x* 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 20 K'ay Baasaane kaatiyaa Ooga wod'eedda;\x - \xo 136:20 \xt Pay. 21:31-35\x* 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 21 Yaatiide unttunttu biittaa bare asaa laatisseedda; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 22 Bare k'oomaa Israa'eeliyaa laatisseedda; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 23 I nuuni kawusheedda wodekka nuuna k'oppeedda; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 24 Nuuna nu morkkatuwaappe ashsheeda; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 25 Med'etaa ubbaw k'umaa immee; 
\q2 aggena Aa siik'uu med'inaawaa. 
\q1  
\v 26 Saluwaa S'oossaa galatite! 
\q2 Aggena Aa siik'uu med'inaawaa. 
\c 137  
\s1 Omooduwaan De'iyaa Israa'eeliyaa Yeekuwaa 
\q1  
\v 1 Baabloone shaafatuwaa matan uttiide, 
\q2 nuuni S'iyoone k'oppeedda wode yeekkeeddo. 
\q1  
\v 2 He sa'aan nuuni, 
\q2 nu diitsaa haatsaa matan dic'c'iyaa mitsaa bolla kak'k'eeddo. 
\q1  
\v 3 Nuuna omoodeedda asatuu, 
\q2 nuuni yes's'iide, unttuntta nashshechchana mala, 
\q1 «S'iyoone yetsaappe ittuwaa ane nuw yes's'ite» yaageeddino. 
\b  
\q1  
\v 4 Med'inaa Godaa yetsaa, nuuni, 
\q2 allaga biittan wooti yes's'anee? 
\q1  
\v 5 Yerusaalame katamatee, taani neena dogooppe, 
\q2 ta ushechcha kushii bare oosuwaa dogo. 
\q1  
\v 6 Taani neena hassayennan aggooppenne 
\q2 ta nashshechchaa ubbaappe aatsaade Yerusaalame dosennan aggooppe, 
\q2 ta ins's'arssay kookkiyaana oyk'k'etto. 
\b  
\q1  
\v 7 Abeet Med'inaa Godaw, Yerusaalame omoodettiyaa gallassi, 
\q2 Eedooma asatuu ootseeddawaa hassaya; 
\q2 unttunttu, «kolite! kolite! 
\q2 Hirkki s'ap'uwaa gakkanaw laalite!» yaageeddawaa dogoppa. 
\b  
\q1  
\v 8 Baabloone biittaw, neenikka bayana!\x - \xo 137:8 \xt Sas'. 18:6\x* 
\q2 Neeni nu bollan ootseedda iita oosuwaa, 
\q2 ne bolla ootsiyaawe anjjetteedawaa. 
\q1  
\v 9 Ne guutsa naanatuwaa oyk'k'iide, 
\q2 zaallaa bolla shoc'iyaawe anjjetteedawaa. 
\c 138  
\s1 Galataa Woosaa 
\d Daawite S'aafeeddawaa 
\q1  
\v 1 Abeet Med'inaa Godaw, taani ta kumentsaa wozanaappe neena galatana; 
\q2 s'oossatuwaa sintsan neena sabbana. 
\q1  
\v 2 Ne Geeshsha Golliyaakko simmaade, 
\q2 new goynaade, aggena ne siik'uwaanne ne tumatetsaa diraw, 
\q2 taani ne suntsaa galatay; 
\q2 ayaw gooppe, neeni ne suntsaanne ne k'aalaa, 
\q2 ubbaappe aatsaade d'ok'k'u ootsaadda. 
\q1  
\v 3 Taani s'eeseedda gallassi taw koyaadda; 
\q2 ne minotetsan taana minisaadda. 
\b  
\q1  
\v 4 Abeet Med'inaa Godaw, sa'aan de'iyaa kaatetuu ubbay, 
\q2 neena galatino; 
\q2 ayaw gooppe, unttunttu ne doonaappe keseedda k'aalaa siseeddino. 
\q1  
\v 5 Med'inaa Godaa bonchchuu wolk'k'aama gidiyaa diraw, 
\q2 unttunttu Med'inaa Godaa ogiyaawaa yes's'ana. 
\q1  
\v 6 Med'inaa Goday bolla d'ok'k'an de'ooppekka, 
\q2 hiyyeesatuwaa keeka ayifiyaan s'eellee. 
\q1 Shin otoranchchatuwaa I haakuwaan eree. 
\b  
\q1  
\v 7 Taani metuwaa gidduwaana hamettooppekka, 
\q2 neeni taana de'uwaan naagaasa. 
\q1 Ta morkkatuwaa hank'k'uwaa bolla ne kushiyaa mic'c'aasa; 
\q2 ne ushechchan taana ashshaasa. 
\q1  
\v 8 Med'inaa Goday taw giide k'oppeeddawaa polana; 
\q2 abeet Med'inaa Godaw, aggena ne siik'uu med'inaawaa. 
\q1 Ne kushiyaa oosuwaa agga aggoppa. 
\c 139  
\s1 Ubbaa Eriyaa S'oossaa 
\d Zammaaretuwaa Kaappoo Yes'etteedda, Daawite s'aafeedda mazamuriyaa 
\q1  
\v 1 Abeet Med'inaa Godaw, neeni taana biddaade eraadda. 
\q1  
\v 2 Taani awude uttinttonne 
\q2 awude ek'k'intto, neeni eraasa; 
\q2 neeni ta k'ofaa ubbaa haakuwaan eraasa. 
\q1  
\v 3 Taani biyaasaanne, 
\q2 shemppiyaa sa'aa s'omoosaasa; 
\q2 ta ogetuwaa ubbaa neeni eraasa. 
\q1  
\v 4 Abeet Med'inaa Godaw, taani ta ins's'arssan 
\q2 itti k'aalaa haasayanaappe kasetaade, 
\q2 neeni ta k'ofaa ubbaa eraasa. 
\q1  
\v 5 Neeni ta yuushshuwaan de'aassa; 
\q2 ne kushiyan taana naagaasa. 
\q1  
\v 6 Ne eray taana loytsi malalissee; 
\q2 taani akeekanaw danddayiyaasaappe d'ok'k'a. 
\b  
\q1  
\v 7 Taani ne Ayaanappe hak'a baanaw danddayayitaa? 
\q2 Woy ne sintsaappe hak'a bak'atanaw danddayayitaa? 
\q1  
\v 8 Pude saluwaa kesooppe, 
\q2 neeni yaan de'aassa! 
\q1 Duge Si'ooliyaa wod'd'inttokka, 
\q2 neeni yaan de'aassa. 
\q1  
\v 9 Away mokkiyaasaa bagga paallaade booppe, 
\q2 woy away wulliyaasaa baggan haakkaade de'ooppe, 
\q1  
\v 10 he saankka ne kushii taana kaaletsee; 
\q2 ne ushechcha kushii taana zemppissee. 
\q1  
\v 11 Taani, «D'umaw, taana gentsaa; 
\q2 poo'uwaa, k'ammaw laametta» yaaginttokka, 
\q1  
\v 12 d'umaa daruu new d'umenna; 
\q2 k'ammay gallassaadan poo'ee; 
\q2 ayaw gooppe, new d'umay poo'uwaa mala. 
\q1  
\v 13 Neeni ta giddo asatetsaa ubbaa med'd'aadda; 
\q2 ta aatti uluwaan taana neeni waas'a med'aadda. 
\q1  
\v 14 Neeni taana malalissiyaabaanne ooratsabaa ootsaade med'd'eedda diraw, 
\q2 taani neena galatay. 
\q1 Ne oosotuu malalissiyaawantta! 
\q2 Taani k'ay hewaa wurssaade eray. 
\q1  
\v 15 Taani geema sa'aan med'ettiyaa wode, 
\q2 ta mek'etsatuu neeppe geemmibeyikkino. 
\q1 Ta bollay ta aatti uluwaa c'iimmaa giddon 
\q2 hiillan alleek'k'ettiide oosettiyaa wode, 
\q1  
\v 16 yelettibeenna ta asatetsaa ne ayifii be'eedda. 
\q2 Biro ittuunne doomettennan de'ishshin, 
\q2 taw neeni giigiseedda gallassatuu ubbatuu 
\q2 ne mazggobiyaan s'aafetteeddino. 
\q1  
\v 17 Abeet S'oossaw, 
\q2 ne k'ofatuu ayaa c'oratteeddinoo! 
\q1 Unttuntta eranawe ayaa waayissii! 
\q1  
\v 18 Taani unttuntta paydintto, 
\q2 unttunttu shafiyaappe darana shin. 
\q1 Taani beegottiyaa wode, 
\q2 ha"ikka neenana de'ay. 
\q1  
\v 19 Abeet S'oossaw, neeni iitatuwaa wod'aaddintto ayee de'ii! 
\q2 Suutsaa gussiyaa asatuu taappe haakkino! 
\q1  
\v 20 Unttunttu ne bolla iitabaa haasayiino; 
\q2 ne morkketuu ne suntsaa bayzziino. 
\q1  
\v 21 Abeet Med'inaa Godaw, neena is's'iyaawantta 
\q2 taani is's'ikkitaa? 
\q1 Ne bolla denddiyaawantta 
\q2 taani shenetikkitaa? 
\q1  
\v 22 Taani unttuntta ubbaa is's'ay; 
\q2 unttuntta taani ta morkkatuwaadan payday. 
\q1  
\v 23 Abeet S'oossaw, 
\q2 taana biddaade, ta wozanaa era; 
\q2 taana paac'c'aade, ta un"etiyaa k'ofaa era. 
\q1  
\v 24 Ane taanan iitabay de'ooppe s'eella; 
\q2 med'inaa ogiyaan taana kaaletsa. 
\c 140  
\s1 Iitatuwaa Bolla Shiik'eedda Woosaa 
\d Zammaaretuwaa Kaappoo Yes'etteedda, Daawite s'aafeedda mazamuriyaa 
\q1  
\v 1 Abeet Med'inaa Godaw, iita asatuwaappe taana ashsha; 
\q2 makkalanchcha asatuwaappe taana naaga. 
\q1  
\v 2 Unttunttu ubbaa wode, 
\q2 iitabaa ootsanaw mak'ettiino; 
\q2 ubbaa gallassikka, 
\q2 walassaa dentsetsanaw k'oppiino. 
\q1  
\v 3 Unttunttu barenttu ins's'arssaa shooshshaawaadan k'arayiino;\x - \xo 140:3 \xt Rom. 3:13\x* 
\q2 unttunttu doonaappe asaa wod'iyaa hasuwaa shooshshaa yishshaa mala haasayay kesee. 
\b  
\q1  
\v 4 Abeet Med'inaa Godaw, iita asatuwaa kushiyaappe, 
\q2 taana ashsha; 
\q2 ta gediyaa k'as's'anaw k'oppiyaa makkalanchcha asatuwaappe taana naaga. 
\q1  
\v 5 Otoranchcha asatuu taw diizzaa giigisseeddino; 
\q2 gitiyaa hiis's'eeddino; 
\q2 taana oyk'k'anaw p'iriyaa ogiyaan wotseeddino. 
\b  
\q1  
\v 6 Taani Med'inaa Godaa, «Neeni ta S'oossaa» yaagay. 
\q2 Abeet Med'inaa Godaw, taani watiwatiyaa watiwatuwaa sisa. 
\q1  
\v 7 Abeet Ubbaa Mooddiyaa Med'inaa Godaw, 
\q2 taana ashshiyaa minoo, 
\q2 olaa gallassi taw gonddale gidaadda. 
\q1  
\v 8 Abeet Med'inaa Godaw, 
\q2 iitatoo unttunttu amuwaa immoppa; 
\q2 unttunttu iita mak'k'uwaa polissoppa. 
\b  
\q1  
\v 9 Ta morkkatuwaan taana s'oonissoppa; 
\q2 unttunttu doonaappe kesiyaa iitabay unttunttoo simmo. 
\q1  
\v 10 Unttunttu bolla s'uuggiyaa bonk'k'uu k'oletto; 
\q2 unttunttu taman olettino; 
\q2 hewaappe laa"entso denddenna olan oletino. 
\q1  
\v 11 Zigiriyaawantta biittay tookkoppo; 
\q2 makkalanchcha asatuwaa iitabay shankkatiide oyk'k'o. 
\q1  
\v 12 Med'inaa Goday hiyyeesatoo pirddiyaawaanne, 
\q2 metootanchchatuwaa maataa naagisiyaawaa eray. 
\q1  
\v 13 Tumuppe s'illotuu ne suntsaa galatana; 
\q2 suure asatuu ne sintsan de'ana. 
\c 141  
\s1 Omarssa Woosaa 
\d Daawite s'aafeedda mazamuriyaa 
\q1  
\v 1 Abeet Med'inaa Godaw, taani neena s'eesay; 
\q2 taana maaddanaw elleella. 
\q1 Taani neekko waassiyaa wode, ta kooshshaa sisa! 
\q1  
\v 2 Ta woosay is'aanaa c'uwaadan, 
\q2 ne sintsa shiik'o;\x - \xo 141:2 \xt Sas'. 5:8\x* 
\q2 taani ta kushiyaa mic'c'iyaawe, 
\q2 new omarssa yarshshuwaa mala gido. 
\b  
\q1  
\v 3 Abeet Med'inaa Godaw, ta doonaa naagiyaawaa wotsa; 
\q2 ta mettershshatuwaa penggiyaan zabayinyaa essa. 
\q1  
\v 4 Bayzzuwaa ootsiyaa asatuwaanna, 
\q2 iita oosuwaa ootsenna mala, 
\q2 ta wozanaa iitabaakko zaaroppa. 
\q2 Unttunttu gibiraakka taana muzoppa. 
\b  
\q1  
\v 5 S'illo Asay taana aggena siik'uwaan 
\q2 seeranawunne muranaw danddayee; 
\q2 unttunttu taana bak'k'ooppe hewe ta huup'iyaan zayitiyaa okkiyaawaa mala; 
\q2 ayaw gooppe, taani ubbaa gedekka 
\q2 iitatuwaa oosuwaa bolla woossay. 
\q1  
\v 6 Unttunttu daannatuu zaallaa aafuwaana, 
\q2 duge olettiyaa wode, 
\q2 ta k'aalay tuma gidiyaawaa unttunttu Asay erana. 
\q1  
\v 7 Biittay goshetiyaawaadaaninne 
\q2 guullu me"eretiyaawaadan 
\q2 unttunttu mek'etsaykka duufuwaa doonaan laalettana. 
\b  
\q1  
\v 8 Abeet Ubbaa Mooddiyaa Med'inaa Godaw, 
\q2 ta ayifii neena s'eellee; 
\q2 taani neekko bak'ataade attay; 
\q2 taana hayk'oo aatsaade immoppa. 
\q1  
\v 9 Unttunttu taw wotseedda gitiyaappenne, 
\q2 iitaa ootsiyaawanttu p'iriyaappe taana naaga. 
\q1  
\v 10 Taan saro aad'd'iyaa wode, 
\q2 iitatuu barenttu wotseedda gitiyaan oyk'k'ettino. 
\c 142  
\s1 S'oossaa Maaduwaa Demanaw Shiik'eedda Woosaa 
\d Akeekan S'aafetteedda Daawita Timirttiyaa, Gonggolo giddon de'iyaa wode Aa woosaa 
\q1  
\v 1 Ta k'aalaa d'ok'k'u ootsaade, Med'inaa Godaw waassay. 
\q2 Ta k'aalaa d'ok'k'u ootsaade, 
\q2 Med'inaa Godaw watiwatay. 
\q1  
\v 2 Ta k'ohuwaa ubbaa aw magannay; 
\q2 ta metuwaa ubbaa aw oday. 
\q1  
\v 3 Taani hidoota k'ans's'ana matiyaa wode, neeni ta ogiyaa eraasa. 
\q2 Taani hamettiyaa ogiyaan taw gitiyaa k'osi wotseeddino. 
\q1  
\v 4 Taani ta yuushshuwaa s'eelliyaa wode, 
\q2 taana maaddiyaawe ittuunne baawa; 
\q2 taani k'osetta attiyaa sa'ay baawa; 
\q2 taana naagiyaawekka baawa. 
\b  
\q1  
\v 5 Abeet Med'inaa Godaw, taani, 
\q2 new hawaadan gaade waassay; 
\q1 «Neeni taani bak'ataade attiyaa sa'aa; 
\q2 taani pas'a de'ishshin, taana gakkeedda saamay neena» yaagay. 
\q1  
\v 6 Taani loytsa metootiyaa diraw, 
\q2 ta waasuwaa hayzza. 
\q1 Taana yederssiyaawanttu, 
\q2 taw loytsi wolk'k'aameedda diraw, 
\q2 taana unttunttuppe ashsha. 
\q1  
\v 7 Taani ne suntsaa galatana mala, 
\q2 taana k'ashuwaappe billa. 
\q1 Neeni taw keekiyaa diraw, 
\q2 s'illotuu ta yuushshuwaan shiik'ana. 
\c 143  
\s1 S'oossaa Maaduwaa Demanaw Shiik'eedda Woosaa 
\d Daawite s'aafeedda mazamuriyaa 
\q1  
\v 1 Abeet Med'inaa Godaw, ta woosaa sisa; ta watiwatuwaa hayzza. 
\q2 Neeni s'illuwaanne ammanettiyaawaa gidiyaa diraw, 
\q2 taw zaaruwaa imma. 
\q1  
\v 2 Ne sintsan s'illo gidana Asay baawa;\x - \xo 143:2 \xt Rom. 3:20; Gal. 2:16\x* 
\q2 hewaa diraw, taana ne k'oomaa pirddaw shiishshoppa. 
\b  
\q1  
\v 3 Taana ta morkkii yederssiide, 
\q2 biittaana gatsi kinchchereetseedda; 
\q2 beni hayk'k'eedda asatuwaadan taana d'uman wotseedda. 
\q1  
\v 4 Hewaa diraw, taani hidootaa k'ans's'aad; 
\q2 ta wozanaykka yibbaateedda. 
\b  
\q1  
\v 5 Taani beni wodetuwaa hassayay; 
\q2 neeni ootseedda oosuwaa ubbaa zaara zaaraadde k'oppaynne 
\q2 ne kushii ootseeddawaa akeekay. 
\q1  
\v 6 Taani ta kushiyaa neekko mic'c'aad; 
\q2 mela biittay haatsaa koyiyaawaadan, 
\q2 ta shemppuu neena saamettee. 
\b  
\q1  
\v 7 Abeet Med'inaa Godaw, taw zaaruwaa immanaw elleella! 
\q2 Taani hidootaa k'ans's'aad. 
\q1 Taani duge duufuwaan geliyaa asatuwaa mala gidennaadan, 
\q2 ne som"uwaa taappe gentsoppa. 
\q1  
\v 8 Taani neena ammanettiyaa diraw, 
\q2 wontta wontta aggena ne siik'uwaa taana bessa. 
\q1 Taani ta shemppuwaappe neena woossiyaa diraw, 
\q2 taani baanaw bessiyaa ogiyaa taana tamaarissa. 
\b  
\q1  
\v 9 Abeet Med'inaa Godaw, taani neekko bak'ateedda diraw, 
\q2 taana ta morkkatuwaappe ashsha. 
\q1  
\v 10 Neeni ta S'oossaa gidiyaa diraw, 
\q2 taani ne sheniyaa ootsana mala, taana tamaarissa; 
\q2 lo"o Ayyaanan taana suure ogiyaa kaaletsa. 
\q1  
\v 11 Abeet Med'inaa Godaw, ne suntsaa diraw, taana ashsha; 
\q2 ne s'illotetsan taana metuwaappe kessa. 
\q1  
\v 12 Aggena ne siik'uwaan ta morkkatuwaa wod'a; 
\q2 ta baaligaaratuwaa ubbaa d'ayissa; 
\q2 ayaw gooppe, taani ne k'oomaa. 
\c 144  
\s1 S'oonuwaa Mazimuriyaa 
\d Daawite s'aafeeddawaa 
\q1  
\v 1 Med'inaa Goday, ta zaallay galatetto! I ta kushiyaa olaw, 
\q2 ta birad'd'etuwaakka tooraw loohissee. 
\q1  
\v 2 I taana siik'iyaa S'oossaanne ta geessuwaa; 
\q2 I ta miis'aanne taana ashshiyaawaa. 
\q1 I ta gonddalliyaanne taani bak'ataade attiyaa sa'aa. 
\q2 Kawutetsatuwaa I taw moodissiyaawaa. 
\b  
\q1  
\v 3 Abeet Med'inaa Godaw, 
\q2 neeni aw k'oppiyaa Asay I ayee?\x - \xo 144:3 \xt Yob. 7:17-18; Maz. 8:4\x* 
\q1 Neeni naagetiyaa asaa na'ay ayee? 
\q1  
\v 4 Asay itti gede c'arkkiyaa c'arkkuwaa mala; 
\q2 Aa gallassatukka aad'd'iyaa kuwaa mala. 
\b  
\q1  
\v 5 Abeet Med'inaa Godaw, ne saluwaa daakaade duge wod'd'a! 
\q2 Wogga deretuwaa bochcha; unttunttukka c'uwattino! 
\q1  
\v 6 Walk'k'antsaa yeddaade ne morkkatuwaa laala! 
\q2 Ne wonddaafiyaa pootsaa yeddaade unttuntta yederssa! 
\q1  
\v 7 Bollaanna ne kushiyaa duge yeddaade, 
\q2 taana c'iimmo haatsatuwaappe goochchaade kessa; 
\q2 allaga asatuwaa kushiyaappe taana wotsa akka. 
\q1  
\v 8 Unttunttu tumuwaa haasayikkino, 
\q2 C'aak'k'iiddekka wordduwaa haasayiino. 
\b  
\q1  
\v 9 Abeet S'oossaw, taani 
\q2 new ooratsa yetsaa yes's'ana; 
\q2 tammu bak'etsaan waas'etteedda diitsaan new diis's'ana. 
\q1  
\v 10 Kaatetoo s'oonuwaa immaasa; 
\q2 ne k'oomaa Daawita ashshaasa. 
\q1  
\v 11 Taana iitaa mashshaappe ashshaasa; 
\q2 allaga asatuwaa kushiyaappe taana wotsa akka. 
\q1 Unttunttu tumuwaa haasayana giide c'aak'k'iiddekka, 
\q2 wordduwaa haasayiino. 
\q1  
\v 12 Nu attuma naanatuu, 
\q2 barenttu yalagatetsan dolk'k'idolk'k'iide, 
\q2 dic'c'iyaa mitsaa mala gidino. 
\q2 Nu mac'c'a naanatuukka kaatiyaa golliyaa zooziyaan, 
\q2 alleek'k'oo esseedda tuuk'iyaa mala gidino. 
\q1  
\v 13 Nu diyyetuu, 
\q2 daro dumma dumma k'ommo katsaan kumino; 
\q2 nu dembbatuwaan de'iyaa dorssatuu sha"aa, 
\q2 tammu sha"aa yelino. 
\q1  
\v 14 Nu miizzatuu birassino; 
\q2 unttunttu sal"eesenan yelettiide c'orattino. 
\q1 Nu ogetuwaan dagama waasuu sisettoppo. 
\q1  
\v 15 Ha yewuu tumu haniyaa asatuu, 
\q2 anjjetteeddawantta. 
\q1 Unttunttu S'oossay Med'inaa Godaa gidiyaa asatuu 
\q2 anjjetteeddawantta. 
\c 145  
\s1 Galataa S'oossaw 
\d Daawite s'aafeedda galataa sabaa 
\q1  
\v 1 Abeet ta S'oossaw, ta kaatiyaw, taani neena gitayananne, 
\q2 ne suntsaa med'i med'inaw galatana. 
\q1  
\v 2 Taani neena ubbaa gallassi sabbana; 
\q2 ne suntsaakka med'i med'inaw galatana. 
\q1  
\v 3 Med'inaa Goday wolk'k'aama; d'ok'k'a galatay aw bessee. 
\q2 Aa gitatetsay asaa k'ofaappe aad'd'ee. 
\q1  
\v 4 Itti yeletay hara yeletaw 
\q2 neeni ootseeddawaa odana; 
\q2 ne malalissiyaa oosotuwaakka awaayana. 
\q1  
\v 5 Unttunttu ne bonchchuwaanne 
\q2 ne anggaa gitatetsaabaa haasayana; 
\q2 taanikka ne malalissiyaa oosuwaa 
\q2 zaara zaaraadde k'oppana. 
\q1  
\v 6 Asay, «Hoola!» giissiyaa ne oosuwaa wolk'k'aabaa haasayana; 
\q2 taanikka ne gitatetsaa awaayana. 
\q1  
\v 7 Unttunttu ne keekkatetsaa daruwaa odana; 
\q2 ne s'illotetsaabaakka yes's'ana. 
\b  
\q1  
\v 8 Med'inaa Goday k'arettiyaawaanne maariyaawaa; 
\q2 I hank'k'ettanaw elleellennawaanne; 
\q2 danddayanchchanne aggena siik'uu dariyaawaa. 
\q1  
\v 9 Med'inaa Goday ubbaw keeka; 
\q2 I bare med'd'eedda ubbaw k'arettiyaawaa. 
\q1  
\v 10 Abeet Med'inaa Godaw, 
\q2 ne med'etaa ubbay neena galatana; 
\q2 ne asatuu ubbaykka neena sabbana. 
\q1  
\v 11 Unttunttu ne kawutetsaa bonchchuwaabaa haasayana; 
\q2 ne wolk'k'aabaa odana. 
\q1  
\v 12 Hewenne, ne wolk'k'aama oosuwaabaanne 
\q2 ne kawutetsaa bonchchuwaa anggaabaa 
\q2 asaa erissana. 
\q1  
\v 13 Ne kawutetsay med'inaa kawutetsaa; 
\q2 ne maatay yeletaa ubbaa gakkanaassa. 
\b  
\q1 Med'inaa Goday bare geedda k'aalaw ubbaw ammanettiyaawaa; 
\q2 I bare oosuwaa ubbaan k'arettiyaawaa. 
\q1  
\v 14 Med'inaa Goday hokkeeddawantta ubbaa zemppissee; 
\q2 kunddeeddawantta ubbaa dentsee. 
\q1  
\v 15 Ubbaa ayifii neekko s'eellee; 
\q2 unttuntta koshshiyaa wodiyaan neeni unttunttoo k'umaa immaasa. 
\q1  
\v 16 Neeni ne kushiyaappe imma; 
\q2 pas'a de'iyaawantta ubbaa amuwaa alaa. 
\q1  
\v 17 Med'inaa Goday bare ogiyaan ubbaan s'illuwaa; 
\q2 I bare oosuwaa ubbaan k'arettiyaawaa. 
\q1  
\v 18 Med'inaa Goday barena s'eesiyaa ubbaw, 
\q2 tumuwaan barena s'eesiyaa ubbaw matan de'ee. 
\q1  
\v 19 I barew yayyiyaawanttu ubbaw, 
\q2 amuwaa kuntsee. 
\q1 K'ay I unttunttu waasuwaa sisiide, 
\q2 unttuntta ashshee. 
\q1  
\v 20 Med'inaa Goday barena siik'iyaawantta ubbaa naagee; 
\q2 shin iitatuwaa ubbaa d'ayissana. 
\q1  
\v 21 Taani ta doonaan Med'inaa Godaa galatana. 
\q2 Med'etaa ubbay Aa geeshsha suntsaa 
\q2 med'i med'inaw galato! 
\c 146  
\s1 Maadda S'oossaw Galataa 
\q1  
\v 1 Med'inaa Godaa galatite! 
\b  
\q2 Ta shemppattee Med'inaa Godaa galataa! 
\q1  
\v 2 Ta de'uwaa laytsaa ubbaan, 
\q2 taani Med'inaa Godaa galatana; 
\q2 taani de'eedda keenan ubbaan 
\q2 ta S'oossaa sabbana. 
\b  
\q1  
\v 3 Asay ashshanaw danddayenna diraw, 
\q2 asaa kaappatuwaan ammanettoppite. 
\q1  
\v 4 Unttunttu shemppuu kesiyaa wode, 
\q2 unttunttu biittaw simmiino; 
\q2 unttunttu halchchuu ubbay 
\q2 he gallassikka atti aggee. 
\b  
\q1  
\v 5 Yaak'ooba S'oossay maaddiyaa uraynne 
\q2 Med'inaa Godaa bare S'oossaa barew hidootaa ootsiyaa uray, 
\q2 anjjetteeddawaa. 
\q1  
\v 6 Med'inaa Goday saluwaanne sa'aa, 
\q2 wolk'k'aama abbaanne Aa giddon de'iyaawaa ubbaa, 
\q2 med'd'eeddawaa;\x - \xo 146:6 \xt Kit. 4:24; 14:15\x* 
\q2 I med'inawukka ammanettiyaawaa. 
\q1  
\v 7 I naak'etteeddawanttoo pirddiyaawaa; 
\q2 koshateeddawanttoo k'umaa immiyaawaa. 
\b  
\q1 Med'inaa Goday k'ashetteeddawantta billee; 
\q1  
\v 8 Med'inaa Goday k'ook'etuwaa s'eelissee. 
\q2 Med'inaa Goday kunddeeddawantta dentsee; 
\q1 Med'inaa Goday s'illotuwaa siik'ee. 
\q1  
\v 9 Med'inaa Goday betetuwaa naagee. 
\q2 Am"etuwaanne aawuu bayinna naanatuwaa maaddee; 
\q2 shin iitatuwaa ogiyaa baletsee. 
\q1  
\v 10 Med'inaa Goday med'inaw kaatetee. 
\q2 S'iyoonee, ne S'oossay, 
\q2 yeletaappe yeletaa gakkanaw kaatetana. 
\b  
\q2 Med'inaa Godaa galatite! 
\c 147  
\s1 Ubbaa Danddayiyaa S'oossaw Shiik'iyaa Galataa 
\q1  
\v 1 Med'inaa Godaa galatite! Nu S'oossaa sabbiyaawe lo"a; 
\q2 Aa sabbiyaawe nashechchiyaabaanne bessiyaawaa. 
\b  
\q1  
\v 2 Med'inaa Goday Yerusaalame ooratsana; 
\q2 Israa'eeliyaa asatuwaappe beteeddawanttakka shiishshana. 
\q1  
\v 3 Wozanay me"eeddawantta I patsee; 
\q2 unttunttu madutsaakka I k'achchee. 
\q1  
\v 4 I s'oolinttetuwaa 
\q2 unttunttu payduwaan eree; 
\q2 unttuntta ubbaakka unttunttu suntsan suntsan s'eesee. 
\q1  
\v 5 Nu Goday wolk'k'aama; Aa wolk'k'ay dara; 
\q2 Aa akeekay likkiyaappe aad'd'iyaawaa. 
\q1  
\v 6 Med'inaa Goday naak'etteeddawantta zemppissee; 
\q2 shin iitatuwaa biittan duge olee. 
\b  
\q1  
\v 7 Med'inaa Godaw galataa yetsaa yes's'ite; 
\q2 nu S'oossaw diitsaa diis's'ite. 
\q1  
\v 8 I saluwaa shaariyaa kamee; 
\q2 sa'aw iraa bukissee; 
\q2 k'eeri deretuwaa bolla maataa mokissee. 
\q1  
\v 9 Mehetoonne waassiyaa k'uuruwaa maratoo, 
\q2 miyaawaa I immee. 
\q1  
\v 10 I nashettiyaawe paratuwaa wolk'k'aaninne, 
\q2 tooranchchatu minotetsan gidenna. 
\q1  
\v 11 Med'inaa Goday barew yayyiyaawanttuninne 
\q2 aggena Aa siik'uwaan, 
\q2 barenttu hidootaa wotseeddawanttun nashettee. 
\q1  
\v 12 Yerusaalame katamatee, Med'inaa Godaa galataa! 
\q2 S'iyoonee, ne S'oossaa galataa! 
\q1  
\v 13 Ayaw gooppe, I, 
\q2 ne penggiyaa kulbbatuwaa minisee; 
\q2 ne giddon de'iyaa ne asaakka anjjee. 
\q1  
\v 14 I ne zawaa sarotetsaan naagee; 
\q2 neena loytsi lo"iyaa zarggaa kalissee. 
\q1  
\v 15 I bare kiitaa sa'aw kiittee; 
\q2 Aa k'aalaykka elle gakkee. 
\q1  
\v 16 I shachchaa bullukkuwaadan mic'c'ee; 
\q2 ketterssaa bidintsaadan laalee. 
\q1  
\v 17 I bare wolk'k'aama shachchaa 
\q2 shuchchaadan duge olee. 
\q1 He meeguwaan ek'k'anaw ooninne danddayenna. 
\q1  
\v 18 I bare k'aalaa kiittiide, 
\q2 shachchaa muushissee. 
\q1 I c'arkkuwaa c'arkkissina, haatsay goggee. 
\q1  
\v 19 I bare k'aalaa Yaak'ooba zeretsaw, 
\q2 bare awaayuwaanne pirddaa 
\q1 Israa'eeliyaa asaw awaayee. 
\q1  
\v 20 I hara kawutetsaa asaw, 
\q2 hawaa ootsibeenna; 
\q2 unttunttu Aa pirddaa erikkino. 
\b  
\q2 Med'inaa Godaa galatite! 
\c 148  
\s1 Med'etay Ubbay S'oossaa Galato 
\q1  
\v 1 Med'inaa Godaa galatite! 
\b  
\q2 Salotuwaan de'iyaawanttoo, Med'inaa Godaa galatite; 
\q2 bolla d'ok'k'an de'iyaawanttoo, Aa galatite. 
\q1  
\v 2 Hinttenoo, Aa kiitanchchatoo, 
\q2 ubbatuu Aa galatite. 
\q1 Saluwaan de'iyaa Aa olanchchatoo, 
\q2 ubbatuu Aa galatite. 
\q1  
\v 3 Awaw, aginaw, Aa galatite; 
\q2 poo'iyaa s'oolinttetoo, ubbatoo Aa galatite. 
\q1  
\v 4 Hinttenoo, ubbaappe bolla d'ok'k'an de'iyaa salotoo, 
\q2 Aa galatite. 
\q1 Saluwaappe bollaanna de'iyaa haatsatoo, 
\q2 Aa galatite. 
\q1  
\v 5 Unttunttu ubbatuu Med'inaa Godaa suntsaa galatino; 
\q2 ayaw gooppe, I azazina, 
\q1 Unttunttu ubbaykka med'etteeddino. 
\q1  
\v 6 I unttuntta med'i med'inaw 
\q2 unttunttu sa'aan sa'aan wotseedda. 
\q1 Unttunttu ubbakka is's'anaw danddayenna azazuwaa I unttunttoo immeedda. 
\b  
\q1  
\v 7 Sa'aan de'iyaawanttoo, Med'inaa Godaa galatite! 
\q2 Abban de'iyaa med'etatoo, wolk'k'aama abbaa c'iimmatoo, 
\q2 ubbatuukka Aa galatite. 
\q1  
\v 8 Hinttenoo, walk'k'antsaw, 
\q2 shachchaw, shaariyaw, c'aaganaw, 
\q1 Aa azazuwaa poliyaa gotiyaw, 
\q2 Ubbatuukka Aa galatite. 
\q1  
\v 9 Hinttenoo, deretoo, zoozetoo, 
\q2 Miyaa ayifiyaa ayifiyaa mitsatoo, zigatoo, 
\q2 ubbatuukka Aa galatite. 
\q1  
\v 10 Mehetoo, do'atoo, 
\q2 sa'aanna gooshettiyaa med'etatoo, 
\q2 paalliyaa kafotoo, 
\q2 Ubbatuukka Aa galatite. 
\q1  
\v 11 Sa'aa kaatetoo, kawutetsaa asatoo, 
\q2 kaappatoo, asaa mooddiyaawanttoo, 
\q1 Ubbatuukka Aa galatite. 
\q1  
\v 12 Wodallatoo, wodoratoo, 
\q2 c'imatoo, naanaatoo, 
\q1 Ubbatuukka Aa galatite! 
\q1  
\v 13 Unttunttu ubbatuu Med'inaa Godaa suntsaa galatino; 
\q2 Ayaw gooppe, Aa suntsay ubbaappe bollaanna de'iyaawaa; 
\q1 Aa bonchchuu salotuwaappekka sa'aappekka bollaanna d'ok'k'an de'ee. 
\q1  
\v 14 Aa bagga gidiyaa, aw matattiyaa Israa'eeliyaa asatuu, 
\q2 Aa galatana mala, I unttuntta minisee. 
\b  
\q1 Med'inaa Godaa galatite! 
\c 149  
\s1 S'oonuwaa Mazimuriyaa 
\q1  
\v 1 Med'inaa Godaa galatite! Med'inaa Godaw ooratsa yetsaa yes's'ite! 
\q2 Ammaniyaawanttu shiik'uwaan Aa sabbite! 
\b  
\q1  
\v 2 Israa'eeliyaa asatuu 
\q2 barentta med'd'eeddawaan nashetino. 
\q1 S'iyoone asatuu barenttu kaatiyaan loytsi nashetino. 
\q1  
\v 3 Duriidde, karabuwaa bak'k'iiddenne, 
\q2 diitsaa diis's'iidde, Aa suntsaa sabbino. 
\q1  
\v 4 Ayaw gooppe, S'oossay bare asan nashettee; 
\q2 Naak'etteeddawanttoo s'oonuwaa immiide, 
\q1 I unttuntta bonchchee. 
\b  
\q1  
\v 5 Asatuu barenttu s'oonuwaan nashetino; 
\q2 k'amman ubbaan nashshechchaw yes's'ino. 
\q1  
\v 6 Unttunttu doonaan S'oossaa galatay, 
\q2 unttunttu kushiyankka laa"u bagga kuussa mashshay de'o. 
\q1  
\v 7 Hewekka, unttunttu kawutetsatoo, 
\q2 haluwaa kessanaassanne asatuwaa muranaassa. 
\q1  
\v 8 Unttunttu kaatetuwaa sanssalatan, 
\q2 unttunttu olaa gadaawatuwaakka birataan k'achchanaassanne, 
\q1  
\v 9 unttunttu bolla s'aafetteedda pirddaa polanaassa. 
\q2 Hewe S'oossaa asatuwaa ubbaw s'oonuwaa. 
\b  
\q1 Med'inaa Godaa galatite! 
\c 150  
\s1 S'oossaa Galatite 
\q1  
\v 1 Med'inaa Godaa galatite! 
\b  
\q2 Aa geeshsha sa'aan S'oossaa galatite; 
\q2 Aa wolk'k'aama saluwaan Aa galatite. 
\q1  
\v 2 Aa wolk'k'aama oosatuwaa diraw, Aa galatite; 
\q2 ubbaappe aad'd'iyaa Aa gitatetsaadan Aa galatite. 
\b  
\q1  
\v 3 Malakataa punniidde, Aa galatite; 
\q2 Diitsaanne maasink'k'uwaa diis's'iidde, 
\q1 Aa galatite. 
\q1  
\v 4 Darbbiyaa bak'k'iiddenne duriide, 
\q2 Aa galatite; 
\q1 Diitsaa diis's'iiddinne lookkuwaa punniidde, Aa galatite. 
\q1  
\v 5 Dawalaa k'aatsiidde, Aa galatite; 
\q2 dawalaa shoc'iide, Aa galatite. 
\b  
\q1  
\v 6 Pas'a shemppatuu ubbatuu, 
\q2 Med'inaa Godaa galatino! 
\b  
\q1 Med'inaa Godaa galatite!