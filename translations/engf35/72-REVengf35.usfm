\p
\v 4 \w And|strong="G2532"\w* \w I|strong="G2532"\w* \w saw|strong="G3708"\w* \w thrones|strong="G2362"\w*, \w and|strong="G2532"\w* \w they|strong="G2532"\w* \w sat|strong="G2523"\w* \w on|strong="G1909"\w* \w them|strong="G3588"\w*, \w and|strong="G2532"\w* \w judgment|strong="G2917"\w* \w was|strong="G3588"\w* committed \w to|strong="G2532"\w* \w them|strong="G3588"\w*; \w also|strong="G2532"\w*, \it I saw\it* \w the|strong="G2532"\w* \w souls|strong="G5590"\w* \w of|strong="G3056"\w* \w those|strong="G3588"\w* \w who|strong="G3588"\w* \w had|strong="G2424"\w* \w been|strong="G2532"\w* \w beheaded|strong="G3990"\w*\f + \fr 20:4 \ft What cultures in our day practice beheading?\f* \w on|strong="G1909"\w* \w account|strong="G3056"\w* \w of|strong="G3056"\w* \w the|strong="G2532"\w* \w testimony|strong="G3141"\w* \w of|strong="G3056"\w* \w Jesus|strong="G2424"\w* \w and|strong="G2532"\w* \w on|strong="G1909"\w* \w account|strong="G3056"\w* \w of|strong="G3056"\w* \w the|strong="G2532"\w* \w Word|strong="G3056"\w* \w of|strong="G3056"\w* \w God|strong="G2316"\w*, \w even|strong="G2532"\w* \w those|strong="G3588"\w* \w who|strong="G3588"\w* \w had|strong="G2424"\w* \w not|strong="G3756"\w* \w worshiped|strong="G4352"\w* \w the|strong="G2532"\w* \w Beast|strong="G2342"\w* \w or|strong="G2532"\w* \w his|strong="G1438"\w* \w image|strong="G1504"\w* \w and|strong="G2532"\w* \w had|strong="G2424"\w* \w not|strong="G3756"\w* \w received|strong="G2983"\w* \w the|strong="G2532"\w* \w mark|strong="G5480"\w* \w on|strong="G1909"\w* \w their|strong="G1438"\w* \w forehead|strong="G3359"\w* \w and|strong="G2532"\w* \w on|strong="G1909"\w* \w their|strong="G1438"\w* \w hand|strong="G5495"\w*. \w And|strong="G2532"\w* \w they|strong="G2532"\w* \w lived|strong="G2198"\w* \w and|strong="G2532"\w* reigned \w with|strong="G3326"\w* \w the|strong="G2532"\w* \w Christ|strong="G5547"\w* \w for|strong="G1223"\w* \w a|strong="G2532"\w* \w thousand|strong="G5507"\w* \w years|strong="G2094"\w*.  
\v 5 (\w Now|strong="G3062"\w* \w the|strong="G3588"\w* \w rest|strong="G3062"\w* \w of|strong="G3588"\w* \w the|strong="G3588"\w* \w dead|strong="G3498"\w* \w did|strong="G3588"\w* \w not|strong="G3756"\w* \w come|strong="G3756"\w* \w to|strong="G3756"\w* \w life|strong="G2198"\w* until \w the|strong="G3588"\w* \w thousand|strong="G5507"\w* \w years|strong="G2094"\w* \w were|strong="G3588"\w* \w finished|strong="G5055"\w*.)\f + \fr 20:5 \ft Verse six makes clear that this part of verse 5 is parenthetical. It is participants in the first resurrection who will reign the thousand years; so that first resurrection must happen at the beginning of the thousand years, not the end; so “the rest of the dead” are the lost who will participate in the resurrection unto condemnation (call it the second resurrection), after the Millennium. Superficial readings of this passage have given rise to all sorts of confusion.\f* \w This|strong="G3778"\w* \w is|strong="G3588"\w* \w the|strong="G3588"\w* \w first|strong="G4413"\w* resurrection.  
