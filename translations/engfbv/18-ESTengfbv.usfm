\p 
\v 9 \w The|strong="H3605"\w* \w king|strong="H4428"\w*'s secretaries \w were|strong="H5971"\w* \w summoned|strong="H7121"\w*, \w and|strong="H3967"\w* \w on|strong="H7121"\w* \w the|strong="H3605"\w* \w twenty-third|strong="H6242"\w* \w day|strong="H2320"\w* \w of|strong="H4428"\w* \w the|strong="H3605"\w* \w third|strong="H7992"\w* \w month|strong="H2320"\w*, \w the|strong="H3605"\w* \w month|strong="H2320"\w* \w of|strong="H4428"\w* \w Sivan|strong="H5510"\w*, \w they|strong="H5704"\w* \w wrote|strong="H3789"\w* \w a|strong="H3068"\w* \w decree|strong="H6680"\w* \w of|strong="H4428"\w* \w all|strong="H3605"\w* \w of|strong="H4428"\w* \w Mordecai|strong="H4782"\w*'s \w orders|strong="H6680"\w* \w to|strong="H5704"\w* \w the|strong="H3605"\w* \w Jews|strong="H3064"\w* \w and|strong="H3967"\w* \w to|strong="H5704"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*'s \w chief|strong="H8269"\w* \w officers|strong="H8269"\w*, \w the|strong="H3605"\w* \w governors|strong="H6346"\w*, \w and|strong="H3967"\w* \w the|strong="H3605"\w* nobles \w of|strong="H4428"\w* \w the|strong="H3605"\w* 127 \w provinces|strong="H4082"\w* \w from|strong="H5704"\w* \w India|strong="H1912"\w* \w to|strong="H5704"\w* \w Ethiopia|strong="H3568"\w*. \w They|strong="H5704"\w* \w wrote|strong="H3789"\w* \w to|strong="H5704"\w* \w every|strong="H3605"\w* \w province|strong="H4082"\w* \w in|strong="H4428"\w* \w its|strong="H3605"\w* \w own|strong="H5971"\w* script, \w to|strong="H5704"\w* \w every|strong="H3605"\w* \w people|strong="H5971"\w* \w in|strong="H4428"\w* \w their|strong="H3605"\w* \w own|strong="H5971"\w* \w language|strong="H3956"\w*, \w and|strong="H3967"\w* \w to|strong="H5704"\w* \w the|strong="H3605"\w* \w Jews|strong="H3064"\w* \w in|strong="H4428"\w* \w their|strong="H3605"\w* \w own|strong="H5971"\w* script \w and|strong="H3967"\w* \w language|strong="H3956"\w*.
