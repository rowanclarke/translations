\p 
\v 35 Each morning \w when|strong="H1961"\w* \w the|strong="H6440"\w* men \w who|strong="H3068"\w* \w were|strong="H1961"\w* carrying \w the|strong="H6440"\w* sacred chest \w started|strong="H1961"\w* \w to|strong="H3068"\w* walk, \w Moses|strong="H4872"\w*/\w I|strong="H3068"\w* said,
\q1 “\w Yahweh|strong="H3068"\w*, \w arise|strong="H6965"\w*!
\q2 \w Scatter|strong="H6327"\w* \w your|strong="H3068"\w* \w enemies|strong="H8130"\w*!
\q2 \w Cause|strong="H1961"\w* \w those|strong="H1961"\w* \w who|strong="H3068"\w* \w hate|strong="H8130"\w* \w you|strong="H6440"\w* \w to|strong="H3068"\w* \w run|strong="H5127"\w* \w away|strong="H5127"\w* \w from|strong="H5265"\w* \w you|strong="H6440"\w*!”
\p 
\v 36 \w And|strong="H3478"\w* each \w time|strong="H3478"\w* \w the|strong="H3068"\w* \w men|strong="H3478"\w* \add stopped to\add* \w set|strong="H5117"\w* \w down|strong="H5117"\w* \w the|strong="H3068"\w* sacred chest, Moses/\w I|strong="H3068"\w* said,
