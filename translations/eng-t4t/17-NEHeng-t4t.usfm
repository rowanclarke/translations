\c 12  
\s1 A list of the priests and Levites who returned  
\p
\v 1  \add Many\add* \w priests|strong="H3548"\w* \w and|strong="H1121"\w* \add other\add* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Levi|strong="H3881"\w* \w returned|strong="H5927"\w* ◄\w from|strong="H5927"\w* Babylonia/\w to|strong="H5927"\w* Jerusalem► \w with|strong="H5973"\w* \w Zerubbabel|strong="H2216"\w* \w and|strong="H1121"\w* \w Jeshua|strong="H3442"\w*. \w They|strong="H3548"\w* \w included|strong="H5927"\w*  
\li1 Seraiah, Jeremiah, Ezra,   
\li1
\v 2 Amariah, Malluch, Hattush,   
\li1
\v 3 Shecaniah, Rehum, Meremoth,   
\li1
\v 4 Iddo, Ginnethon, Abijah,   
\li1
\v 5 Mijamin, Moadiah, Bilgah,   
\li1
\v 6 Shemaiah, Joiarib, Jedaiah,   
\li1
\v 7 Sallu, Amok, Hilkiah, and Jedaiah.  
\m \w All|strong="H3117"\w* those \w men|strong="H7218"\w* \w were|strong="H3117"\w* \w leaders|strong="H7218"\w* \w of|strong="H3117"\w* \w the|strong="H3117"\w* \w priests|strong="H3548"\w* \w during|strong="H3117"\w* \w the|strong="H3117"\w* \w time|strong="H3117"\w* \w that|strong="H3117"\w* \w Jeshua|strong="H3442"\w* \add was the Supreme Priest\add*.   
\p
\v 8  \add Some of the other\add* descendants \w of|strong="H5921"\w* \w Levi|strong="H3881"\w* \w who|strong="H1931"\w* returned \w were|strong="H3881"\w* \w Jeshua|strong="H3442"\w*, \w Binnui|strong="H1131"\w*, \w Kadmiel|strong="H6934"\w*, \w Sherebiah|strong="H8274"\w*, \w Judah|strong="H3063"\w*, \w and|strong="H3063"\w* \w Mattaniah|strong="H4983"\w*. \w They|strong="H5921"\w* \w were|strong="H3881"\w* \w in|strong="H5921"\w* \w charge|strong="H5921"\w* \w of|strong="H5921"\w* singing \w songs|strong="H1960"\w* \w to|strong="H5921"\w* thank \add God\add*.  
\v 9 \w Bakbukiah|strong="H1229"\w*, \w Unni|strong="H6042"\w*, \w and|strong="H1229"\w* \w other|strong="H5048"\w* descendants \w of|strong="H5048"\w* Levi formed \w a|strong="H3068"\w* choir that stood \w opposite|strong="H5048"\w* \w the|strong="H5048"\w* \w other|strong="H5048"\w* group \add and sang in reply to them\add*.   
\s1 A list of descendants of Jeshua the Supreme Priest  
\p
\v 10 \w Jeshua|strong="H3442"\w* \add who was the Supreme Priest\add* \w was|strong="H3205"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* \w Joiakim|strong="H3113"\w*, \w who|strong="H3205"\w* \w was|strong="H3205"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* Eliashib, \w who|strong="H3205"\w* \w was|strong="H3205"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* \w Joiada|strong="H3111"\w*,  
\v 11 \w who|strong="H3205"\w* \w was|strong="H3205"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* \w Jonathan|strong="H3129"\w*, \w who|strong="H3205"\w* \w was|strong="H3205"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* \w Jaddua|strong="H3037"\w*.   
\s1 Leaders of the clans of priests  
\p
\v 12 \w When|strong="H1961"\w* \w Joiakim|strong="H3113"\w* \w was|strong="H1961"\w* \w the|strong="H3117"\w* Supreme \w Priest|strong="H3548"\w*, \w these|strong="H3117"\w* \w were|strong="H1961"\w* \w the|strong="H3117"\w* \w leaders|strong="H7218"\w* \w of|strong="H3117"\w* \w the|strong="H3117"\w* clans \w of|strong="H3117"\w* \w priests|strong="H3548"\w*:  
\li1 Meraiah, from \add the clan of\add* Seraiah;  
\li1 Hananiah, from \add the clan of\add* Jeremiah;   
\li1
\v 13 Meshullam, from \add the clan of\add* Ezra;  
\li1 Jehohanan, from \add the clan of\add* Amariah;   
\li1
\v 14 Jonathan, from \add the clan of\add* Malluch;  
\li1 Joseph, from \add the clan of\add* Shecaniah;   
\li1
\v 15 Adna, from \add the clan of\add* Harim;  
\li1 Helkai, from \add the clan of\add* Meremoth/Maraioth;   
\li1
\v 16 Zechariah, from \add the clan of\add* Iddo;  
\li1 Meshullam, from \add the clan of\add* Ginnethon;   
\li1
\v 17 Zicri, from \add the clan of\add* Abijah.  
\li1 There was also a leader from \add the clan of\add* Miniamin;  
