\id MAT - Southern Carrier -Canada 2012 (DBL -2013) 
\h Matthew 
\toc1 Yak'usda Bughunek Unzoo, 'I Matthew Yuk'uné'uzguz 
\toc2 Matthew 
\toc3 Mt 
\mt1 Yak'usda Bughunek Unzoo, 'I Matthew Yuk'uné'uzguz 
\c 1  
\s1 Sizi Gri ndunnah hube dínzut 
\p  
\v 1 Ndi dustl'us 'uk'e'eduguz 'et ndutni, 'i be Sizi Gri 'en hube dínzut 'en 'uhínt'ah, 'i Sizi 'en David yuts'uh hainzut 'int'ah. David 'en Abraham yuts'uh hainzut 'int'ah.  
\v 2 Abraham 'en Isaac bu'abá 'int'ah. 
\q1 Isaac 'en Jacob bu'abá 'int'ah. 
\q1 Jacob 'en Judah 'ink'ez bulhutsinkah bu'abá 'int'ah. 
\q1  
\v 3 Judah 'en ndun ts'eke Tamar 'en be Perez 'ink'ez Zerah bu'abá 'int'ah. 
\q1 Perez 'en Hezron bu'abá, 
\q1 'ink'ez Hezron 'en Ram bu'abá 'int'ah. 
\q1  
\v 4 Ram 'en Amminadab bu'abá. 
\q1 Amminadab 'en Nashon bu'abá, 
\q1 'ink'ez Nashon 'en Salmon bu'abá 'int'ah. 
\q1  
\v 5 Salmon bu'at Rahab 'en be Boaz bu'abá. 
\q1 Boaz 'en Ruth 'en be Obed bu'abá. 
\q1 'Ink'ez Obed 'en Jesse bu'abá 'int'ah. 
\q1  
\v 6 Jesse hubudayi cho David bu'abá. 
\m 'Et hubudayi cho David, ndun Uriah bu'at inle, 'en be Solomon bu'abá 'int'ah. 
\q1  
\v 7 Solomon 'en Rehoboam bu'abá. 
\q1 Rehoboam 'en Abijah bu'abá, 
\q1 'ink'ez Abijah 'en Asa bu'abá 'int'ah. 
\q1  
\v 8 Asa 'en Jehoshaphat bu'abá. 
\q1 Jehoshaphat 'en Joram bu'abá, 
\q1 'ink'ez Joram 'en Uzziah bu'abá 'int'ah. 
\q1  
\v 9 Uzziah 'en Jotham bu'abá. 
\q1 Jotham 'en Ahaz bu'abá, 
\q1 'ink'ez Ahaz 'en Hezekiah bu'abá 'int'ah. 
\q1  
\v 10 Hezekiah 'en Manasseh bu'abá. 
\q1 Manasseh 'en Amon bu'abá, 
\q1 'ink'ez Amon 'en Josiah bu'abá 'int'ah. 
\q1  
\v 11 Hoh da wheghah whudezulh, ts'iyannah dune keyah whuti Babylon ts'ih wheoobuhanla, 'et Josiah 'en Jeconiah 'ink'ez bulhutsinkah 'en bu'abá 'int'ah. 
\p  
\v 12 Keyah whuti Babylon whuz whebuhanla hukw'elh'az 'et Jeconiah 'en Shealtiel bu'abá 'int'ah. 
\q1 Shealtiel 'en Zurubbabel bu'abá 'int'ah. 
\q1  
\v 13 Zerubbabel 'en Abiud bu'abá. 
\q1 Abiud 'en Eliakim bu'abá, 
\q1 'ink'ez Eliakim 'en Azor bu'abá 'int'ah. 
\q1  
\v 14 Azor 'en Zadok bu'abá. 
\q1 Zadok 'en Achim bu'abá, 
\q1 'ink'ez Achim 'en Eliud bu'abá 'int'ah. 
\q1  
\v 15 Eliud 'en Eleazor bu'abá. 
\q1 Eleazor 'en Matthan bu'abá, 
\q1 'ink'ez Matthan 'en Jacob bu'abá 'int'ah. 
\q1  
\v 16 Jacob 'en Joseph bu'abá 'int'ah. 'En Mary buki 'ink'ez Mary 'en be Sizi whuzdli. 'En Christ hiyulhni. 
\p  
\v 17 'Et Abraham 'en David whuts'un, 'en ts'iyawh lanezi 'o 'at dit (14) bubé hudinde 'uhint'ah. 'Ink'ez David hoh da whudezulh hoh ts'iyannah keyah whut'en Babylon ts'ih whebuhanla whuts'un, 'en ts'iyawh lanezi 'o 'at dit (14) bubé hudinde hinli. 'Ink'ez hoh da whudezulh hoh ts'iyannah keyah Babylon ts'ih whebuhanla 'et hukw'elh'uz dich'oh bukeyah yun k'ut Judah, whuz whenáhedel, Christ 'et whuts'un, 'en ts'iyawh lanezi 'o 'at dit (14) bubé hudinde hinli ho' hint'ah. 
\s1 Sizi Gri whuzdli 
\p  
\v 18 'Aw 'et Sizi Gri whuzdli, ndez na'a 'uhooja. 'Ama Mary 'en Joseph 'en yughu tedalh ka lhahódinla, 'ink'ez yughu tedalh whutsuh hoh 'et nahoo'ai 'uda 'uski bulh 'int'ah. Ndoni, 'i be 'uja.  
\v 19 'Et ndun Joseph 'en ts'ah'un dune unli, 'et huwa lhgho hutedukelh ts'iyannah tah yooya yoolhtselh whuch'a bubeni lhaidinla. 'Ink'ez whu'iz yuch'a natedalh hukwa' ninzun.  
\v 20 'Et howu nuni nuzut hoh 'et huwu nusúti hoh neMoodihti bulizas 'en 'uyulhni, “Joseph nyun David buts'u hainzut inli ho' 'int'ah. Wheniljut ilah Mary n'at wule. Ndun 'uski Ndoni be chainya ho' 'int'ah.  
\v 21 'Aw 'et 'en duneyaz tele. Nyunch'oh boozi bugha ídon'alh. Sizi dóni. 'En 'utenilh ts'iyannah lubeshi ch'a hubutelhyih.”  
\v 22 'Et ndez na'a 'uhooja, neMoodihti ndun nus whunilh'en, 'en be daja ni, 'et nduhoolcho hoh túne' whust'en. 'Et ndun nus whunilh'en ndez na'a njan ndutni,  
\v 23 “Soo zulhts'ai ndun ts'eke 'aw dune t'enizun 'et whunts'ih khunyaz 'uski ba 'uja, 'ink'ez buyaz dune tele, boozi Emmanuel hiduténilh, Yak'usda nelh 'int'ah, ni ho' utni.” 
\p  
\v 24 'Et Joseph ts'enanzut hoh neMoodihti bulizas daja yulhni, hoh tune' 'ust'en 'ink'ez 'aw 'et Mary yilhchoot bu'at tele ka.  
\v 25 'Udechoo buyaz whutele t'eoonanzin 'et whuts'un 'aw yut'áchaghesnak. 'Aw 'et buye' whuzdli, 'et k'an zeh soo yughusda. 'Et boozi yugha íden'ai Sizi yulhni. 
\c 2  
\s1 Dune whunih, Maji hubuhútni, 'en 'et Jerusalem ts'ih hunindel 
\p  
\v 1 'Aw 'et yun k'ut Judea, keyah Bethlehem whuz'ai, 'et Sizi whuzdli. Hoh da whuz na'a Herod hubudayi cho unli hoh 'et 'uhooja. 'Aw 'et whuzdli hukw'elh'az khunyaz nda whut'en keyah Jerusalem ts'ih hunindel. 'En whunih Maji hubuhútni, 'en 'uhint'ah.  
\v 2 'Ink'ez dune hoodulhkut, “Lizwif hubudayi cho k'an whuzdli, 'en nts'e whuzdli? 'Et ndi sum cho ts'a'en, 'i bugha lhuts'úzdel. 'Et huwa ndaz de ndun 'uski 'en buts'un teni' ts'untelhdzilh ka whusats'ándel.”  
\v 3 'Et whunts'ih hubudayi cho Herod whulh 'udúzts'ai hoh buba dzuh 'uhutni. Jerusalem whut'en, 'en chah whuz na'a zeh huba dzuh 'uhutni.  
\v 4 'Ink'ez ts'iyannah ba náwhulnuk hubumoodih 'ink'ez Moses be' dustl'us 'uk'ununa'úsduguz chah, 'en ts'iyawh Herod 'anih hubudani. 'Et 'en hubuts'un nahooté'alh Christ ndet whutele.  
\v 5 'Ink'ez 'uhiyulhni, “Yun k'ut Judea, keyah Bethlehem whuz'ai, 'et whutele. Nus whunilh'en 'et 'uk'e'edúguz, 'et ndutni, 
\q1  
\v 6 ‘Yun k'ut Judea ts'ih keyah Bethlehem whut'en, 
\q2 'et nuhkeyah hoontsolyaz hoonli, 
\q2 'et whunts'ih tube whudezti tele. 
\p Nuhkeyah 'et whuts'un 'ilhunuh moodih ncha, 'en whusateyalh. 'Ink'ez sudune, 
\q2 Israel hits'uh hainde, 
\q2 'en sheep ghunli k'una'a bughu tele.’ ” 
\p  
\v 7 'Et Herod whu'iz hoh dune whunih 'en 'anih hubudáni. 'En hubuts'un naooté'alh ka ndet dzin nts'oh whudezulh ndi sum be hóoduteltsilh.  
\v 8 'Et hukw'elh'az keyah Bethlehem ts'ih whebalh'a 'ink'ez ndo búlhni, “Ahdulh 'ink'ez soo cho hoh 'uski naoolhteh. 'Et nawhah'ai t'eh, nts'e 'int'ah 'et sts'ótl'a khunek wah'alh. Si chah whuz tesyalh buts'un teni' ntelhzilh ka.”  
\v 9 'Et hubudayi cho ndo búlhni hoh whehándel. Hedulh hoh khunyaz ndi sum ndaz de ts'un hitelh'en 'ink'ez hubutsuh 'ults'ulh. 'Et nts'e 'uski usda 'et bugha nduk, 'et lhghá dilts'ut.  
\v 10 'Et ndet sum hinalh'en da tube huhóont'i.  
\v 11 'Et 'ink'ez koo dahuníndel hoh 'uski hitelh'en, 'ama Mary 'en bulh. Hibut nachánelya 'ink'ez hits'un teni' nalhdzin. Huye 'úzdla, 'i hidah lhch'az hiyílhchoot hoh 'i hiyé ha'anla 'ink'ez hits'u hítelhdel. Gold, yoo sooltsun, 'i frankencense hiyulhni, 'ink'ez yoo Myrrh hiyulhni chah, 'i ts'iyawh hits'u hítelhdel.  
\v 12 'Ink'ez Yak'usda bubul be bugha dáni, 'aw Herod buk'unaoohdelh gunih hubudáni. 'Et huwa 'uts'un ts'un hubukeyah ts'ih whenáhedel. 
\s1 Joseph, Mary teh, 'ink'ez Sizi bulh yun k'ut Egypt ts'uwhútni, whuz whehándel. 
\p  
\v 13 'Aw 'et whenáhedel hukw'elh'az neMoodihti bulizas Joseph nute hoh beghah hódiltsai. 'Et ndi yúlhni, “Didinyaih, ndun 'uski 'ama bulh hubilhchoot 'ink'ez yun k'ut Egypt 'a ts'ih whuz hubalhtelh! 'Et nuhwhudutésnilh 'et whuts'un 'et doolhúts'i! 'Et 'áho Herod 'uski yuka it'é'ilh yutuzelhghelh ka!”  
\v 14 'Et 'ulh'ek dinadeja 'ink'ez 'uski 'ama bulh hubilhchoot 'ink'ez yun k'ut Egypt whuz whehandel.  
\v 15 'Et Herod datetsah whuts'un 'et hudutélts'ilh. 'Et ndúhut'en hoh neMoodihti ndun nus whunilh'en, 'en be daja ni 'et ndoneltsuk tune' whust'en hoh njan ndutni, “Suye' 'anih dáni yun k'ut Egypt whuch'a naooja ka.” 
\s1 Hubudayi cho Herod nehughan 'en ndo búlhni, “Keyah Bethlehem ts'ih duneyaz nat naoodezulh be suli, 'en ts'iyawh huboohghan.” 
\p  
\v 16 'Aw 'et Herod t'eoonanzin ndunnah whunih, Maji hiyulhni, nahina'a, 'et huwa tube hunilch'e. 'Et nts'oh huwa whezulh Maji hidáni hoh bulunah nehughan keyah Bethlehem ts'ih whebalh'a. 'Et ndo búlhni, 'et keyah whut'en ts'iyawh 'ink'ez whunat whut'en chah ndunnah duneyaz nat naoodezulh be suli 'ink'ez whuts'un whudelhdzulh chah, 'en ts'iyawh huboohghan.  
\v 17 'Et whuz na'a ndun nus whunilh'en Jeremiah hiyulhni, daja ni 'et ts'iyawh nduhóolhcho tune' whust'en hoh njan ndutni, 
\q1  
\v 18 “'Et keyah Ramah hódants'o hoh tso yahalhtuk 
\q2 'ink'ez hubuzkeh k'ehúnentai. 
\q1 Rachel buzkehyaz hubuk'etso yahalhtuk. 
\q2 'Aw budzi nduk na'ootneh ghaít'ah, 
\q1 bubuzkehkah hoolah huzdli 'et huwa.” 
\s1 Joseph, Mary, Sizi chah, keyah Nazareth huwhútni hudutélts'ilh 
\p  
\v 19 'Aw 'et Herod dazsai hoh Egypt ts'ih neMoodihti bulizas Joseph huwunute hoh beghah níwhults'ut.  
\v 20 'Et ndi yulhni, “Didinyih! 'Uski bu'ama bulh naoobilchoot. Israel yun k'ut whuz nahdulh. 'Et whutsuh da ndunnah 'uski híkuneztai hituzelhghelh ka, 'en ts'iyawh yahadla.”  
\v 21 'Et dudinya. 'Uski bu'ama bulh nabílchoot 'ink'ez Israel yun k'ut ts'ih whenáhedel.  
\v 22 'Et whunts'ih Joseph whulh uduzts'ai Herod buye' Archelaus hiyulhni, 'en bu'abá k'edanya 'ink'ez k'an Judea yun k'ut hubudayi cho unli. 'Et whuz teyalh whénuljut hoh howu nusúti 'et Yak'usda yugha dáni. 'Et huwa Galilee yun k'ut ts'ih whuz whehándel.  
\v 23 Whuz hunindel keyah Nazareth huwhútni, 'et hudutélts'ilh. 'Et whuz na'a nus whunilh'en daja hutni, hoh túne' whust'en njan nduhútni, “'En Nazareth whut'en hiduténilh.” 
\c 3  
\s1 John dune too be 'ulh'en ts'iyannah ndo búlhni, “Ndun Yak'uz k'une' whul'en, 'aw 'et nilhdukw netah 'utet'ilh.” 
\p  
\v 1 'Et whezulh hoh John dune too be 'ulh'en 'en Judea yun k'ut dune chahóot'ih ts'ih, whuz whinya 'ink'ez dune bulh yalhtuk.  
\v 2 'Et ndo búlhni, “Nuhwhulubeshi ch'a nuhwhubeni náhandunoohlelh. 'Aw 'et nilhdukw suli hoh ndun yak'uz k'une' whul'en, 'en nuhwhutah 'utet'ilh.”  
\v 3 Ndun 'en nus whunilh'en Isaiah yughu yalhtuk hoh njan ndutni, 
\q1 “Dune chahóot'ih ts'ih dune yiz dusduts'ai soo 'ultus hahuyih hoh njan ndutni, 
\q1 ‘NeMoodihti buti lhaoodahleh! 
\q2 Buti soo lhts'odez'a buba whulhtsi.’ ” 
\p  
\v 4 'Ink'ez John dich'oh khunai bugha, camel hiyulhni, 'i ye dune unli 'ink'ez 'ukulh se be sudelhú'oo. Tulk'us cho 'ink'ez honey, 'i ya'alh.  
\v 5 'Et hoh da dune ts'iyawh ndunnah Jerusalem whut'en, Judea yun k'ut whut'en, 'ink'ez dune 'et took'oh Jordan whut'en, 'en ts'iyawh John highu nindel.  
\v 6 'Ink'ez bulubeshi hubugha hunahuwhélnuk hoh 'et nyo 'et took'oh Jordan, John 'en too be' balh'en.  
\v 7 'Et whunts'ih lhanah Pharisee 'ink'ez Sadducee chah, 'en too be' hutelnilh ka highu nindel. 'Et hubunilh'en hoh ndo búlhni, “Nuhwheni poison tl'ughus buzkehkah lí'aht'ah! Ndan 'ún whulhni Yak'usda huntelch'oh whuch'a lhúwus?  
\v 8 Lubeshi ch'a nuhwheni nahandunihla t'eh, ndaht'en ts'iyannah t'ehonóozin ndaht'ah.  
\v 9 'Ink'ez khun teh na'dudoohtni gunih, nuwheni Abraham buts'u hats'ánde 'uts'int'ah. Ts'ah'un na'a 'ún whudusni Yak'usda soo 'ultus ho' 'int'ah, tse be 'i whunts'ih Abraham buts'u hahánde hubutelhtsilh.  
\v 10 Nuhwheni duchun lí'aht'ah. 'Aw 'et tsetsilh lhadínt'ah. Duchun bumai hoolah, bughih tubulh tsuhídantsel 'ink'ez hidutélhk'un.  
\v 11 Nuhwheni nahunduníhla 'et huwa too zai be too be' nuhwhúsdla. 'Et whunts'ih sk'elh'az ndun whusatéyalh, 'en sughanus dezti ho' 'int'ah. 'Aw bukegwun buba nutésdle huba soo cha'lhúdzooh. Ndun Ndoni 'ink'ez kwun bulh 'i be too be' nuhwhutelh'ilh.  
\v 12 Be tl'onuldzeh 'i tl'o mai be tahawhúlhts'ih, 'i niyútun. 'Ink'ez ndi tl'o mai yutahawhúlhts'ih, 'i 'ink'ez yuk'ut 'ut'en, 'i chah yuk'ut lhadút'ih t'eh, 'ink'ez yuna'ulhdoh. 'Ink'ez ndi mai ndai lhaduja, 'i deínudzih 'ink'ez mai koo ts'ih wheyúlih. Ndi kwun 'aw nachanusne, be but'ooz, duték'un,” ndo búlhni. 
\s1 John, Sizi too be 'uyínla 
\p  
\v 13 'Et Sizi Galilee yun k'ut ts'ih hainya. Jordan took'oh ninya John too be' yutelilh ka.  
\v 14 'Et whunts'ih John dah yúlhni. “Nyun too be' sonleh huba' hoont'ah. 'Ink'ez di ka si suts'ú tenya too be' nyoosdleh ka?”  
\v 15 'Et whunts'ih Sizi ndi yúlhni, “Whute ndoh hot'e, be ts'ah'un 'uhoont'ah, 'i 'et ts'iyawh lhaoodutenilh ho' hoont'ah.” 'Aw 'et whute 'et ndúyinla.  
\v 16 Sizi too be' yinla hoh tooz hanája ibulh 'et 'ahoh yak'uz whuda'dutézkez 'ink'ez Yak'usda buyégha yunilh'en hoh ndus de dut'ai, 'i dove hiyúlhni, 'i k'una'a Sizi buk'édinde.  
\v 17 Khunyaz ndus de 'uwhutni, “Ndun 'en suYe' buk'esi' 'en 'int'ah, 'ink'ez tube 'en bulh hoonúst'i,” ni. 
\c 4  
\s1 Netsudule Sizi tink'us yunóolht'uk hukwa' yulh'en 
\p  
\v 1 Sizi dune chahóot'ih ts'ih Ndoni Sizi whuz wheyálh'a netsudule yootélhdzih ka.  
\v 2 Dit lanezi dzin (40) sahá'delya, 'et hukw'elh'az buye'élts'ul.  
\v 3 'Et ndun yootélhdzih ka, 'en yughu ninya 'ink'ez ndi yúlhni, “'Alha Yak'usda buYe' ninli t'eh, ndi tse lhes wule dini.”  
\v 4 'Et Sizi 'uyúlhni, “Yak'usda bughunek k'ut 'uk'une'úsduguz, ‘'Aw lhes zeh ilah dune yugha khuna, 'et Yak'usda bughunek ts'iyawh, 'i be chah higha khuna.’ ”  
\v 5 'Et netsudule keyah whudezti ts'ih yulh whin'az, 'ink'ez luglez whucho degha ndoh hukw'ut, 'et hukw'abah ninilhya.  
\v 6 'Ink'ez ndi yúlhni, “'Alha Yak'usda buYe' ninli t'eh, njan whegha' dudintneh! 'Alha 'uk'e'edúguz hoh njan ndutni, 
\q1 ‘Yak'usda bulizas butl'aho'ai hoh 'en nyun nka huwuhinli, 
\q2 'ink'ez hubula be nyoohóotetun, 
\q1 'et 'aw nke tse t'aoonalh ghaít'ah.’ ” 
\p  
\v 7 'Et Sizi nduyulhni, “Doo chah zeh njan 'uk'e'éduguz hoh ndutni, ‘Khun teh Moodihti nYak'usda 'en nantan'ah hukwa ólhdzih gunih!’ ”  
\v 8 'Et doo chah zeh netsudule ndi dzulh yédoh hadet'ai ts'ih whuz yulh whin'az. 'Et ndi yun k'ut ndulhcho hoh whenulhtun hubudayi cho bube 'ut'en k'ah 'ink'ez huyé dezti, 'i chah.  
\v 9 'Ink'ez ndi yúlhni, “Ngwutsi be nininyih 'ink'ez suts'u téni' nilhdzun t'eh, 'et sih ts'iyawh, nye'ildzun wule!”  
\v 10 'Ink'ez Sizi ndi yúlhni, “Satan naindalh! 'Et 'uk'e'éduguz hoh njan ndutni, ‘Moodihti nYak'usda, 'aw 'en zeh bubut negwutsi be nits'uyih, 'ink'ez buts'u téni' uznilhdzun, 'ink'ez 'en zeh buba né'ts'oot'en huba' hoont'ah.’ ”  
\v 11 'Et netsudule whenaja 'ink'ez lizas whusahándel 'ink'ez hiba ne'ut'en. 
\s1 Sizi dune hubulh yawhénilhtuk 
\p  
\v 12 John tsak'ehiyan'a Sizi whulh údants'o hoh Galilee yun k'ut ts'ih whinya.  
\v 13 Nazareth whuch'a séya 'ink'ez keyah Capernaum whuz ninya 'et tedalh ka. Keyah 'et taba whuz'ai. Yun k'ut Zebulun 'ink'ez Naphtali lhodin'ai.  
\v 14 Isaiah nus ho'en, 'et howu yailhtuk lhaóodotneh hoh njan ndutni, 
\q1  
\v 15 “Yun k'ut Zebulun 'ink'ez yun k'ut Naphtali, 
\q2 bun k'uz wheti 'et whuz'ai. 
\q2 Galilee 'i 'udun yun k'ut whut'en, 
\q2 huwhut'i. 
\q1  
\v 16 Tsahólhgus yuh hudelhts'i, 
\q2 'en be whét'en cho 'i hitelh'en. 
\q1 Hoh huwhut'en dahutetsah tsagwusts'it huba li'hoont'ah, ndunnah 'en huba hoolh'en.” 
\p  
\v 17 'Et whuts'un Sizi dune hubulh yawhénilhtuk hoh ndo búlhni, “Nuhwhulubeshi ch'a nuhwhubeni náhandunoohleh! Yak'uz k'une' whul'en 'aw 'et nilhdukw suli.” 
\s1 Dinah lhook ka 'uhut'en Sizi, “'Anih,” hubúlhni. 
\p  
\v 18 'Aw 'et bun k'ut Galilee taba Sizi hoh wheghah uyalh 'et nanah dune lhulhutsinkah hubutelh'en. 'Ilhunuh 'en Simon hiyulhni, Peter chah hiyulhni, 'et 'ilhunuh bulhutsin 'en Andrew hiyulhni. 'En lhoombilh tahíyalhdel lhook ka 'uhut'en hinli.  
\v 19 'Ink'ez ndo búlhni, “Suneh'us. Dune ka 'ut'en nuhwhutelhsilh.”  
\v 20 'Ahoh hubuloombil hiladetnik 'ink'ez hik'ah ts'ih 'uhoot'en ka hiyuntez'az.  
\v 21 'Et 'o 'un hedulh nanah dune hubutelh'en. 'En chah lhulhutsinkah Zebedee buye'kah. 'Ilhunuh James 'ink'ez 'ilhunuh 'en John hiyulhni. Bu'abá bulh ts'i cho be húdelhts'i 'ink'ez hubuloombil nahuyutl'oo. 'Et Sizi hubukahunih.  
\v 22 'Et 'ahoh bu'abá highu dehaín'az 'aw 'et ye usda hoh 'ink'ez Sizi hik'ah ts'ih 'uhoot'en ka hiyuntez'az. 
\s1 Sizi lhanah dune hunduda soo ná'ubalh'en 
\p  
\v 23 Galilee yun k'ut Sizi ndulhcho nuya. Lizwif hubuluglez dune hubulh yálhtuk. Yak'uz k'une' whul'en, 'en hubugha khunek unzoo, 'i be hubulh yálhtuk. Ndan nduda 'ink'ez buyust'e tel'en, 'en ts'iyawh soo na'bulh'en.  
\v 24 'Et Syria huwhut'en, ts'iyawh hiyulh údits'o. Ndunnah lhenyoo dada bé hunduda, 'ink'ez ndan 'o nus bulh 'últs'ulh chah, ndan ntsi' nudúde buyudínda chah, 'ink'ez hubukaootuzuk 'ink'ez nuchahúsyah chah, 'en Sizi ts'un lhgha budinla hoh ts'iyawh soo ná'binla.  
\v 25 Galilee, 'ink'ez Decapolis yun k'ut whut'en chah, 'ink'ez Jerusalem whut'en, Judea whut'en, 'ink'ez Jordan took'oh 'onghoh whughah whut'en chah, 'et 'ahuneltsuk 'ilhunahuwésdel 'en ts'iyawh hiyuntezdel. 
\c 5  
\s1 Sizi ndo búlhni, “Dawhuldzoo 'et hubughá whults'ut” 
\p  
\v 1 'Ilhunahuwésdel Sizi hubunilh'en. Dzulh yenun ts'ih whenya, 'ink'ez 'et nátl'adeda hoh yugha hódul'eh, 'en highu nindel.  
\v 2 'Et wheoobudunilh'i, 'et njan ndo búlhni, 
\q1  
\v 3 “Lubeshi 'ulh'en, 'en budzi tel'en unli, 
\q2 'en yak'uz k'une' whul'en bube'ildzun huzdli, 
\q2 'et huwa degha nus hoonzoo hubugha whults'ut. 
\q1  
\v 4 Hubulubeshi ghu ni hinli, 'en degha nus k'enánet'a hutele. 
\q2 'En 'uhuja degha nus hoonzoo hubugha whults'ut. 
\q1  
\v 5 Yuh údudildzun, 
\q2 'en ndi yun k'ut bube'ildzun whutele, 'et huwa degha nus hoonzoo hubugha whults'ut. 
\q1  
\v 6 Ndan ye be ts'ah'un 'uhoont'ah, 'i tube hukwa buye'élts'ul 'ink'ez ta'oosde lí'hint'ah, 'et hubugha óotelts'ulh. 
\q2 'En degha nus hoonzoo hubughá whults'ut. 
\q1  
\v 7 Bugha te'huninzun, Yak'usda chah hubugha te'untezilh, 
\q2 'et t'eh degha nus hoonzoo hubughá whults'ut. 
\q1  
\v 8 Hubudzi dutsun chailah, 
\q2 'en k'at le Yak'usda hute'ilh 'et huwa 'en degha nus hoonzoo hubughá whults'ut. 
\q1  
\v 9 Ndan ts'ah'un na'a lhulh 'uhint'ah hubulhtsi, 'en Yak'usda buzkeh ubahudaténilh. 
\q1 'Et huwa degha nus hoonzoo hubughá whults'ut. 
\q1  
\v 10 Ndunnah ye be ts'ah'un 'uhoont'ah gha dzuh nobuhulhdeh, 'en yak'uz k'une' whul'en, 'et bube'ildzun hinli. 
\q1 'Et huwa degha nus hoonzoo hubughá whults'ut. 
\q1  
\v 11 Dune nuhwheni ch'a yahutelhtuk 'ink'ez dzuh nunohotelhdzut, 'ink'ez ts'iyaitsuk whuts'it khunek dutsun, 'i be nuhwheni ch'a 'uts'un na'a yahutelhtuk, 'et si sugha whuz na'a dune dzuh nunwhahulhdzut t'eh, 'et degha nus hoonzoo hubughá whults'ut. 
\p  
\v 12 Whunélhnik 'ink'ez degha nus hoonáht'i! Yak'uz hooncha hoh nuhwhuba k'elha whutele. Nuhtsuh nus whunilh'en inle, 'en chah whuz na'a zeh bube huzula inle. 
\s1 Huba 'alha 'uhoont'ah 'en lusel 'ink'ez be whét'en lí'hint'ah 
\p  
\v 13 Lubeshi 'uhulh'en huba lusel liaht'ah. 'Et whunts'ih lusel 'aw buzachahóolkih suli t'eh, nts'e na'a simba doo chah lusel buzahóolki naoodle? 'Aw hoonli ba chaízooh ho' 'int'ah. 'I 'ants'ih dune ti híyulhkuk 'ink'ez hik'unúdelh.  
\v 14 Ndi yun k'ut dune huba be whét'en, 'i li'aht'ah. Keyah whuti dzulh k'ut whuz'ai t'eh, 'aw whuntool'ih ghaít'ah.  
\v 15 Dune too dezk'un naidulhk'an 'ink'ez 'aw k'its'ai yut'ah niyóo'alh ghaít'ah. K'us kw'uzdai k'eíte'alh 'ink'ez kwun 'i bugha ts'iyannah huwhuntelh'ilh.  
\v 16 Dune ba be whét'en ahli. 'I be nuhwhe'ut'en unzoo, 'i dune yuntelh'ilh 'ink'ez nuhwhe'aBá yak'uz usda, 'en degha nus hidutélhti.” 
\s1 Sizi ndo búlhni, “Moses be' dustl'us 'ink'ez nus whunilh'en bube dustl'us ts'iyawh lhadutésdlih” 
\p  
\v 17 “Moses be' dustl'us 'ink'ez nus whunilh'en bube' dustl'us 'i hoolah natelhtsilh ka whusaíya noohzin gunih. 'I ts'iyawh lhaoodutesdlih 'et wheni whusaíya.  
\v 18 'Alha' dusni ndun whudusni, Moses be' dustl'us Hebrew bughunek k'una'a hoonsolyaz hoh 'uk'e'edúguz 'ink'ez hoonsolyaz 'uk'e'edúsgus, ndet 'uwhulhni, 'et ts'iyawh 'et ndúhooja t'eh, 'et whuts'un 'aw ndi yun 'ink'ez yat'ah chah 'ustl'e' 'uhóneh ghaít'ah.  
\v 19 Ndai khunek neghalts'ut, hoontsolyaz whunts'ih dune k'uhinínyuz t'eh, 'ink'ez 'uyoon whuz na'a zeh wheoobodutelh'eh t'eh, 'et sih yak'uz k'úne' whul'en, 'en 'aw hoonli chailah hiduténilh. 'Et ndi khunek netl'adélts'ut, 'i dune ts'iyawh hik'une' 'ut'en t'eh, 'ink'ez 'uyoon chah whuz na'a 'az whebodutelh'eh, yak'uz k'úne' whul'en be ncha 'int'ah hiduténilh.  
\v 20 Ndun whudusni ndunnah Moses be' dustl'us 'uk'ununa'úsduguz 'ink'ez Pharisee chah, 'en hiye be ts'ah'un 'uhoont'ah, 'ink'ez nuhwheni ye be ts'ah'un 'uhoont'ah, 'i be huba nus hoonzoo t'eh, 'aw 'et zeh nts'e yak'uz k'une' whul'en ts'ih téhdulh. 
\s1 Nyulh dune hoonliyaz hoh nch'a detni t'ewhunínzun t'eh, bughu ninya 'ink'ez nyulh dune naooltsilh 
\p  
\v 21 “Whulh udahts'o netsuhda hubuhutni, ‘Dune solhghelh gunih,’ 'ink'ez ndan dune selhghi t'eh, 'et hukw'una'a huba nahuteyeh ho' hoont'ah.  
\v 22 Ndun whuhdúsni, ndunnah 'ants'ih dulh dune bulh hunilch'e t'eh, 'en huba nahutedeh. 'Et ndan dudulh dune ‘Raca’ 'ulhni t'eh, khunek dakelh k'una'a ‘Ntsi'’ ni hoh 'utni, 'i bugha naheyelh hububut huteyin. 'Ink'ez chah zeh ndun dune, ‘Whuzinik dune inli ho' 'int'ah!’ yulhni t'eh, 'en tube whewhúnujut kwuncho yuh ts'ih buhutenoh.  
\v 23 'Et huwa hoonliyaz Yak'usda bukw'uzdai k'ut howa' té'alh, 'ink'ez nyulh dune hoonli nch'a hudetni whunailnih t'eh,  
\v 24 'et whutsuh nyulh dune bulh lhk'enahoodutseh. Hukw'elh'az k'an zeh Yak'usda bukw'uzdai k'ut huwa' tan'alh, 'et huwa níoon'alh.  
\v 25 'Et khun dune hoonli nch'a hudetni t'eh, 'ahoh buts'un ts'ah'un na'hotneh. 'Et naheyelh but nínyutelhtelh whutsuh ndóneh. 'Aw ndúchainel t'eh, nch'a hudetni, 'en naheyelh but nínyutelhtelh. Naheyelh, 'en nélhghel tl'anyutelhtelh 'ink'ez nch'a dána'dute'alh.  
\v 26 Ts'ah'un 'un whudúsni, ts'iyaitsuk buk'elha whutelhtsilh whuts'un, nts'e na'a simba whuch'a naoohja?” 
\s1 Ndun ts'eke yunilh'en 'ink'ez budzi yuh hoh duninzun, “Bulh tínta' test'ilh hukwa' nuszun,” 'et 'uda yulh tinta' 'ant'en ho' 'int'ah 
\p  
\v 27 “Whulh udahts'o netsuhda hubuhutni, ‘'Uyoon ts'eke bulh tinta' ont'en gunih.’  
\v 28 Sich'oh 'un whudúsni, dune ts'eke yunilh'en 'ink'ez budzi yuh hoh duninzun t'eh, ‘Bulh tínta' test'ilh hukwa' nuszun,’ 'uda budzi yuh bulh tinta' ant'en ho' 'int'ah.  
\v 29 'Et nalhnih ts'ih nyuna be lubeshi inla t'eh, hanón'alh 'ink'ez 'un ntolh'is. 'Et ndáhja t'eh nuhyust'e ndulhcho chadutésk'un hoh whanus soo' hoont'ah.  
\v 30 'Ink'ez nalhnih ts'ih nla be tínta' nint'en t'eh, k'ont'as 'ink'ez 'un tolh'is. Nuhyust'e ndulhcho 'aw kwuncho yuh ts'ih chadutésk'un, 'et 'o nus soo' hoont'ah.” 
\s1 Dune ts'eke bulh lhgho delhts'i, 'ilhuz wheni 'uhoont'ah 
\p  
\v 31 “'O 'un chah nduhútni ‘Ndun bu'at 'ustl'e' 'utelilh, ye' dustl'us 'istl'e' itelilh, 'i yutl'ayóolhchoos huba' hoont'ah.’  
\v 32 'Et whunts'ih 'un whudúsni, bu'at 'uyoon dune bulh tinta' 'ant'en 'et huwa zeh dustl'us ye' 'ustl'e' itelilh, 'i yutl'ayóolhchoos. Ndúchainel hoh bu'at 'ustl'e' 'uyínla t'eh, dich'oh bu'at tinta' 'ant'en yulhtsi. 'Ink'ez ndun ts'eke 'uyoon dune ghu nasda t'eh, dune 'en chah tinta' 'ut'ih unli ho' 'int'ah.” 
\s1 Khun nyunch'oh nghunek k'ónyis gunih 
\p  
\v 33 “'Et doo chah niz de whudezulh da ts'iyawh t'eoonáhzun 'uda dune daja hutni hoh njan duhutni, ‘Khun nyunch'oh nghunek k'ónyis gunih. 'Et neMoodihti buts'u nahizínya 'et nduhoolcho hukw'una'a 'ont'en huba' hoont'ah.’  
\v 34 'Et whunts'ih sich'oh 'un whudúsni, khun whuz na'a teh ndudóohtni gunih. Khun ‘Yak'uz whunalh 'udusni,’ doohtni gunih. 'Alha yak'uz ts'ih Yak'usda bukw'usda cho dezti, 'i 'et su'ai.  
\v 35 'Ink'ez, ‘Ndi yun k'ut whunalh 'udusni,’ doohtni gunih. Yak'usda duke yuk'udelhú'ez, 'i 'int'ah 'et huwa. 'Ink'ez khun teh, ‘Keyah Jerusalem whunalh 'udusni,’ doohtni gunih. Hubudayi cho k'us dezti bukeyah whucho 'uhoont'ah 'et huwa.  
\v 36 'Ink'ez khun teh, ‘Sutsi be 'alha' dusni,’ doni gunih. 'Aw ntsigha 'ilhuk'i whuntsi dulyul k'us dulhgus 'ólhtsilh hoolah.  
\v 37 'Et ndez na'a njan dúdoohtni, 'Aw 'et ‘A,’ dahtni, ‘A,’ 'int'ah. 'Ink'ez ‘'Awundooh,’ dahtni t'eh chah, ‘'Awundooh,’ 'uhoont'ah. 'Et 'uts'un na'a 'udutéhnilh t'eh, 'et sih ntsi' ts'ih hadutédoh ho' 'int'ah.” 
\s1 Dune ntsi', 'en buch'a nónt'uk 
\p  
\v 38 “'Et whutsuh da whulh udahts'o nts'e na'a dune daja hutni inle njan duhutni, ‘Dune buna chawhés'en silhtsi t'eh, nyunch'oh nyúna be chawhés'en tanle. 'I be kw'elha whutelhtsilh. 'Et bughoo habe'alhchus t'eh, nyunch'oh nghoo be k'elha whutelhtsilh,’ hutni inle.  
\v 39 'Et whunts'ih 'un whuhdúsni, dune ntsi' k'ól'en gunih. 'Et k'us ndan nalhnih ts'ih nuhnezkuk t'eh, 'et 'intl'as ts'ih buts'un nándunont'ah.  
\v 40 Khun ndan nts'oozt'an naheyelh but nts'u yuka 'utni t'eh, ndzoot 'i chah bughá yólhchoos.  
\v 41 Dune 'et nduhóolhdzah sulh ti ínyalh nyulhni t'eh, nat 'uwhuldzah ts'ih bulh neóonya.  
\v 42 Ndan hoonli nts'un hukwa 'utni t'eh, hubugha yó'alh. Hoonli bughu sinla yulhni t'eh, buch'a naool'ah gunih.” 
\s1 Nuhch'az detni, 'en buk'eoohtsi' 
\p  
\v 43 “'Et whulh údahts'o hubuhútni, ‘Nyeghah whut'i buk'eoontsi' 'ink'ez nch'a hudetni, 'en buts'u dontnik.’  
\v 44 Ndun whúdusni, nuhch'a hudetni, 'en buk'eoohtsi'. Ndunnah denwhútdule, 'en khunek unzoo, 'i be hubulh yaóolhtuk. Ndunnah nuhts'u dutnik, 'en buts'un wahzoo. 'Et ndunnah hoontsi' nuhts'un ne'hut'en 'ink'ez dzuh nunwhahulhdzut, 'en chah buba tenadoohdli.  
\v 45 'Et ndez na'a nuh'aBá yak'uz usda, buzkeh wahle. Yak'usda ndunnah hintsi' 'ink'ez hinzoo 'en ndi sa lhulhúgha buk'eidindi. Ts'ah'un 'uhint'ah 'ink'ez ts'ah'un cha'hít'ah, en chah lhulhúgha buk'ut nawhúlhtih.  
\v 46 Ndunnah nuhk'entsi', 'en zeh hubuk'ehtsi' t'eh, di simba nuhgha óokat? Sooneya nalhdzooh chah whuz na'a zeh nduhút'en.  
\v 47 Nuhwhulhutsinkah zeh dahooja hubudahni t'eh, 'uyoon degha nus ahzoo na'dunáhzun ih? Hoolah! Sooneya nalhdzooh, 'en chah whuz na'a zeh nduhút'en.  
\v 48 Nuh'aBá yak'uz usda dant'ah hoh ts'ah'un 'int'ah, nuhwheni chah whuz na'a zeh ndóht'e huba' hoont'ah.” 
\c 6  
\s1 'Ut'en unzoo, 'i 'ulh'en t'eh, khun ts'iyannah nalh tube cho whe 'ududoolhúti gunih 
\p  
\v 1 “Huwahli! Khun tel'en gha' teh'alh t'eh, ts'et whucho ndóht'en gunih. 'Et whuz na'a ndaht'en t'eh, nuhwhe'aBá yak'uz usda, 'en 'aw nuhwhuba k'elha holhtselh ghaít'ah.  
\v 2 'Et huwa tel'en gha' teh'alh t'eh, khun ts'iyannah nalh tube cho 'ududoolhúti gunih. Ndunnah duba nahudzoo, 'en 'et whuz na'a 'et duhút'en. Lizwif hubuluglez k'us ti whulheguz 'et ts'iyannah hubunoolh'en ka, 'et nduhút'en. 'Alha' dusni, ndunnah ba 'uk'elha whutele, 'uda huba 'uk'elha whuzdli ho' hoont'ah.  
\v 3 'Et whunts'ih tel'en gha' teh'alh t'eh, nyula 'intl'as ts'ih 'aw t'ewhunozin nyula nalhnih ts'ih dat'en 'et.  
\v 4 'Et whuz na'a 'uyoon t'ehoníszun 'et ndaht'en hoh tel'en bugha 'áh'aih. 'Ink'ez nuhwhe'aBá yak'uz usda, 'en dahoont'ah huwa 'et ndaht'en, 'et ts'iyawh nuhwhunílh'en ho' 'int'ah. 'Et huwa dich'oh ts'iyannah but hoonzoo hoh nuhwhuba k'elha whutelhtsilh.” 
\s1 Ndez na'a tenadoohdli huba' hoont'ah 
\p  
\v 5 “'Et tenadahdli t'eh, khun ndunnah duba nahudzoo k'ah ts'ih tenadoohdli gunih. Ndunnah Lizwif hubuluglez nahudelhúya, k'us ti wheguz chah, 'ants'ih ts'iyannah hubunoolh'en ka tenahududli. Ndun whudúsni 'uda huba k'elha whuzdli ho' hint'ah.  
\v 6 'Et nuhwheni tenadutehdli t'eh, nuhwhenich'oh whaht'i, dati dána'dehtan 'ink'ez tenadoohdli. Nuhwhe'aBá, 'aw be chaoodést'en, 'en ts'iyannah nalh nuhwhuba k'elha whutelhtsilh.  
\v 7 'Et tenadahdli t'eh, lhat cho lhtanahoohdeh gunih. Whuz na'a ndunnah 'aw Yak'usda t'echahunízun tenahududli. Lhai khunek be tenahududli t'eh, 'et sih Yak'usda hubudutéts'o huninzun.  
\v 8 'En hubuk'una'a 'udoohni gunih. Nuhwhe'aBá dant'i be ndunahdzit 'uda t'ewhunínzun ho' 'int'ah.  
\v 9 'Et ndez na'a tenadoohdli, 
\q1 ‘Ne'aBá yak'uz sinda. 
\q1 Nyoozi dóoti. 
\q1  
\v 10 Hoh hubudayi cho inli, 
\q2 whusahóolts'it. 
\q1 Hukwa' ninzun t'eh, ndoh honeh, 
\q1 ndi yun k'ut 'ink'ez yak'uz chah. 
\q1  
\v 11 K'an dzin uzte'alh, 
\q2 'i negha iní'ai. 
\q1  
\v 12 'Uyoon bulh tink'us ts'uwhulh'ai t'eh, buba whunats'odoolnah. 
\q2 'Et whuz na'a zeh tink'us 'uts'ut'ih 'et neba whunaoodolnah. 
\q1  
\v 13 Nts'e tink'us ts'unint'uk, whuch'a neghinli. 
\q1 'Ink'ez ndun ntsi', 'en chah buch'a neghinli. 
\q1 'Et yak'uz k'une' 'int'en 'int'ah, 'ink'ez be ilhtus, 
\q2 be dénti, 'i chah, 'i 'ilhuz wheni, 'i ts'iyawh nye'ildzun 'int'ah. 
\q2 'Et ndoh honeh.’ 
\p  
\v 14 Dune nuhwhudulhyah né'hut'en t'eh, buba whunaoodelhúnah t'eh, nuhwhe'aBá yak'uz usda, 'en chah nuhwhuba whunaoodutelnah.  
\v 15 'Et whunts'i dune nuhwhudulhyah né'hut'en t'eh, 'ink'ez buba whuchanaooduzulhunah t'eh, nuhwhe'aBá yak'uz usda, 'en chah nuhwhuba whunaoodoolnah ghaít'ah.” 
\s1 Sahá'delhuya t'eh, 'onghunnah hubuch'a nonoolh'i 
\p  
\v 16 “Ndet sahá'delhuya t'eh, ndan duba nahudzoo, 'en hubuk'una'a 'ooht'e gunih. 'En hubudzi yuh 'uhilhdzun na'hududil'i ho' hint'ah. Dunen 'uts'un 'oonint'en hiyúlhtsih, whuz na'a te'hududil'en 'ink'ez dzuh nuhuzut na'hududil'i, 'uyoon húbonoolh'en ka. 'Alha ndun whudusni, ndan nduhút'en, 'uda huba k'elha whuzdli ho' hint'ah.  
\v 17 'Et nuhwheni sahá'delhúya t'eh, soo cho nuhwhunen chah na'óolhdeh 'ink'ez nuhtsigha chah naoolhlho.  
\v 18 'Et whuz na'a sahá'delhúya t'eh, 'et 'onghunnah hubuch'a nonah'i. 'Et whunts'ih nuhwhe'aBá cha'whést'en ts'ih whunts'ih whunilh'en, ts'iyannah nalh nuhwhuba k'elha whutelhtsilh.” 
\s1 Yak'uz be hoonzoo 'uhoont'ah, 'i be yak'uz ts'ih whuz 'ilho neóohlelh 
\p  
\v 19 “Ndi yun k'ut hoonáht'i, 'i 'ilho 'oohleh gunih. Ndulh'en t'eh, 'ants'ih k'enadidutsih 'ink'ez muszoombaiyaz chah hoolah yutelhtsilh. 'Undunut'ih, nuhghu dá'duteyus 'ink'ez hiduntet'ih.  
\v 20 'Et yak'uz be hoonzoo 'uhoont'ah, 'i whuz 'ilho wéhla. 'Aw buk'ena'doodutsih ghaít'ah. 'Ink'ez muszoombaiyaz chah 'aw hoolah yoolhtselh ghaít'ah. 'Aw nuhghu da'hooyis 'ink'ez nuhghe' hudunoot'ih ghaít'ah.  
\v 21 'Et ndet be hoonzoo 'uhoont'ah, ndet sáhla, nuhdzi chah 'et duté'alh.” 
\s1 Dune buna too dezk'un li'int'ah 
\p  
\v 22 “Nena neyust'e ba too dezk'un li'int'ah. Nuhna soo 'int'ah t'eh, nuhyust'e be whét'en, 'i dezbun.  
\v 23 'Et whunts'ih dune buna tink'us 'ut'en be untsi' t'eh, 'et buyust'e ndulhcho tsahólhgus be dutébun. 'Et huwa be whét'en nohwhulh 'int'ah tsahólhgus k'una'a be hoodet'en t'eh, dáhoolcho, 'i be simba tsahólhgus wule?” 
\s1 Yak'usda k'une' 'int'en t'eh, sooneya chah k'une' 'ont'en ghaít'ah 
\p  
\v 24 “'Ilhunuh dune nanah moodih ba 'oot'en ghaít'ah. 'Ilhunuh 'en yuts'u dutetnik 'ink'ez 'ilhunuh yuk'etetsi'. K'us 'ilhunuh yuk'úne' tet'en 'ink'ez 'ilhunuh yuch'a dutetni. 'Aw Yak'usda k'une' 'int'en 'ink'ez sooneya chah k'une' 'ont'en ghaít'ah.” 
\s1 Yinkak delhúts'i huwu ni wahle gunih 
\p  
\v 25 “'Et huwa njan ndun whudusni, yinkak delhúts'i huwu ni wahle gunih. Teh'alh, 'i 'ink'ez tehnilh, 'i chah, 'ink'ez nuhyust'e be soo nadutehnilh, 'i chah, 'i ts'iyawh khun bugha ni wahle gunih. Teh'alh, 'i be kháhna, 'i degha nus dezti nahzun ih? K'us naih 'i nuhuyust'e degha nus dezti nahzun ih?  
\v 26 Nduk dut'ai núdelh, 'i nulh'en! 'Aw hacha'nusdle 'ink'ez 'aw khi huba ilhucha'wesdle ilah. 'Et whunts'ih nuhwhe'aBá yak'uz usda, 'en bugha 'á'aih. Nuhwheni 'en ilah 'o nus huba déhti.  
\v 27 Nuhtah ndan dalcho tele howu ni unli? 'Aw 'et huwa 'o nus 'ulyez wule ghaít'ah!  
\v 28 Di ka be dune tehleh wuni ahli? 'Indakyaz nts'e na'a haniyeh, 'et howu nuni nahzut. 'Aw cha'hust'en 'ink'ez 'aw naih chah cha'hulh'en hiye dune tele ka.  
\v 29 Ndun whudusni Solomon 'en whunts'ih soo nadut'ih teh, 'aw 'indakyaz yuch'a degha nus cha'ildzooh.  
\v 30 Yak'usda tl'o unzoo, 'i yilh'i. 'I k'an dzin tl'o k'ut haniyeh 'ink'ez bunt'ah 'i tsehidutelhkulh 'ink'ez duték'un. 'Et dáhoolcho 'i be nuhwheni 'o nus soo nanohdutele? Nuhwheni 'aw soo cho nuhwhuba 'alha' cha'hoot'ah ho' 'aht'ah!  
\v 31 'Et huwa di simba ts'oo'alh, k'us di simba ts'ootnai, k'us di simba be dune ts'oole, noohzin gunih.  
\v 32 'Alha 'udun yun k'ut whut'en 'et zeh hukwa hités'en. 'Ink'ez 'alha 'i be nuhwhe'aBá yak'uz usda, ndai hoonliyaz be ts'udunudli, 'i ts'iyawh t'eooninzun.  
\v 33 Ndet Yak'usda nuhwhuba hubudayi cho tele 'ink'ez ye ts'ah'un na'a 'uhoont'ah, 'i nuhbe'ildzun tele, 'et zeh hukwa' nahzun t'eh, 'o 'un, 'i chah ts'iyawh nuhgha tékulh ho' hoont'ah.  
\v 34 'Et huwa bunt'ah dawhútenilh, 'et howu ni wahle gunih. Bunt'ah dawhuténilh, 'et ndo honeh. Dzin totsuk soo' hoolcho howun ni hoonli 'et huwa.” 
\c 7  
\s1 'Uyoon ba nahoohyeh gunih 
\p  
\v 1 “'Uyoon ba nahoohyeh gunih. Doo ka sih nuhwhuba nahoodeh.  
\v 2 Nts'e na'a 'uyoon ba nahahyeh, 'et whuz na'a nuhwhuba nahutedeh. 'Ink'ez nts'e na'a 'uyoon ghu nuni nahdzut, whuz na'a zeh nuhghu nuní huntezut.  
\v 3 'Et di ka nyulhutsin lhusyaz buna k'et deztan, 'i nilh'en, nyunch'oh duchun cho nyuna k'et deztan 'ink'ez?  
\v 4 Nts'e na'a nyulhutsin 'uduténilh, ‘Nyuna k'elts'ut, 'i nyuna k'ehanaóos'alh,’ 'ink'ez nyunch'oh lhi'ílcho, 'i nyuna k'et su'ai, 'i 'aw chanílh'en?  
\v 5 Buba naindzoo! 'Udechoo lhe'ílcho, 'i nyuna k'élts'ut, 'i choo nyuna k'éhanain'aih. 'Et sih soo whunilh'en hoh buna k'élts'ut, 'i buna k'ehanáyo'alh.  
\v 6 Yak'usda bughunek lubeshi bughuh hoolah, 'i khun teh lhikah ndult'ah hubugha yóoh'alh gunih. K'us Yak'usda ye whúneodulh'eh, 'i kw'usul dezti, 'i pearl hiyulhni, 'et dult'ah, 'i khun teh goso dult'ah butayóolhdelh gunih. 'Et ndahja t'eh, ndulhcho hik'unutélh'us 'ink'ez 'ahoh nuhts'un nahulhúya 'ink'ez yanohodutélhch'ulh.” 
\s1 Yak'usda nuhts'o hukwa' ninzun, 'et Yak'usda hukwa 'oodolhkut 'ink'ez nuhgha whúte'alh 
\p  
\v 7 “Yak'usda bukayoodulhkut, 'i nuhgha íte'alh. Bukunáhta 'ink'ez nahootéh'alh. Ndati whudúlhghalh 'ink'ez nuhwhuba da'dutékwus.  
\v 8 Ndan 'oodulhkut, Yak'usda hubugha whúte'alh. Hoonliyaz hukunúta, 'en nahahooté'alh. 'Ink'ez ndati hodulhghalh 'en Yak'usda huba dá'dutet'ilh.  
\v 9 Ndunnah nuhbákah nuhtah, buye' lhes yuts'u ka 'utni t'eh, tse yughá ndunóo'alh ghaít'ah.  
\v 10 K'us lhook yuts'u ka 'utni t'eh, hoh tl'ughus yugha óolelh ghaít'ah.  
\v 11 Nuhwheni lubeshi 'ulh'en ahli, 'et whunts'ih t'eoonahzun nts'e na'a unzoo, 'i nohwuzkeh hubugha itéh'alh. Dáwhulcho, 'i be 'o nus nduk yak'uz nuhwhe'aBá, ndunnah yoodulhkut, unzoo, 'i hubugha ité'alh.  
\v 12 'Et huwa nts'e na'a hukwa' nahzun dune danoh hotelh'ilh, 'et whuz na'a zeh nuhwheni 'et ndúboolh'en. 'Alha Moses be' dustl'us, 'ink'ez nus whunilh'en bube' dustl'us chah, 'et nawhult'ah 'et nduwhútni.” 
\s1 Ndi hukwuti hoondot 
\p  
\v 13 “Njan hukwuti hoondot 'et hukohdelh huba' hoont'ah. 'Et hukwuti hoontel, 'et hoontsi' ts'un whuz’ai, whuz whéti 'uhoont'ah 'ink'ez lhanah whuz whehúdelh.  
\v 14 Njan 'et huwa 'et nduhút'en, njan hukwuti hoondot, 'i 'ilhuz be ts'ukhuna 'uhoont'ah 'ink'ez howa whulna ho' hoont'ah. 'Aw lhanah ilah nahuhóo'aih.” 
\s1 Dune dahút'en, 'et 'i be dahint'ah t'eoobuntehzeh 
\p  
\v 15 “Ndunnah whuts'it be nus whunilh'en na'dudil'i, 'en buka huwahli! Sheep zuz be soo dint'ah, 'en buyuh ts'ih yus soo degha nus ntsi' 'en lí'hint'ah.  
\v 16 'Et huwa dahút'en, 'et 'i be t'eoobuntehzeh. 'Et mai cho whus chuntah ih oonahye? K'us ndi mai, figs hiyulhni, chuntah whuduts'ul whutah oonahye ih? 'Awundooh!  
\v 17 'Et whuz na'a zeh duchun unzoo, 'i mai unzoo, 'i bugha haniyeh.  
\v 18 'Ink'ez duchun dalhjut, 'i 'aw mai unzoo, 'i bugha hanóoyeh ghaít'ah.  
\v 19 Ts'iyai, 'i duchun 'aw mai unzoo, 'i bugha hanooyeh ghaít'ah, 'i nánuhidutselh 'ink'ez hidelhk'un.  
\v 20 'Et huwa dune chah whuz na'a ndúhint'ah. 'Et huwa t'eoobunoohzin.” 
\s1 Yak'usda k'únucha'ust'en, 'en Sizi Gri bube'ildzun chahilah 
\p  
\v 21 “'Aw ts'iyannah, ‘SMoodihti, sMoodihti,’ sulhni, 'aw nts'e yak'uz k'une' ts'uwhul'en whuz hutooya ghaít'ah. Ndan se'aBá buts'o hukwa' ninzun tune' 'ut'en, 'aw 'en zeh yak'uz ts'un hutedulh.  
\v 22 'Et ndunnah njan dzin whusawhélts'ut t'eh, ‘SMoodihti sMoodihti, 'alha nyoozi be nus ts'úhoo'en. 'Ink'ez nyoozi be ntsi' nududeh, 'i 'uyoon bughu whe náts'inanyoot! 'Ink'ez nyoozi 'i be huwa 'ét'en tune' ts'ut'en,’ hutni.  
\v 23 'Et ndunt'ah dune ts'iyawh hubudutésnilh, ‘'Aw t'enwhunuzúszun. Such'a nasahdel! Nuhwheni 'aw suk'unucha'aht'il aht'ah!’ ” 
\s1 Sizi Gri bughunek soo cho whulh ts'ooyin 
\p  
\v 24 “'Et huwa ndunnah sughunek yoozilhts'ai, 'ink'ez daja dusni hukw'une' hut'en, ndun dune whunih bukoo tse k'ut niooni'ai, 'en k'una'a 'uhint'ah.  
\v 25 'Aw 'et nawheóonilhtan 'ink'ez too 'aw 'et ulhtus suli, 'i njan bukoo whut'agheznai. Nilhtsi ulhtus, 'i chah whudelhts'ut. 'Et whunts'ih njan bukoo 'aw dachahóonil. Njan bukoo tse k'ut whuz'ai 'et huwa.  
\v 26 'Et whunts'ih ndan sughunek hudits'o 'ink'ez 'aw hik'unucha'ust'en t'eh, ndun dune whusnik, 'en bukoo 'ants'ih sai k'ut niooni'ai, 'en duhúlt'ah.  
\v 27 'Aw 'et nawhéoonilhtan 'ink'ez too 'aw 'et ulhtus suli, 'i njan bukoo whut'agheznai. Nilhtsi ulhtus, 'i chah whudilhts'uk. 'Ink'ez njan bukoo nawhélts'ut. 'Ink'ez wheóonujut hoh nahwélts'ut.”  
\v 28 'Et Sizi ndi khunek ye hubulh yailhtuk, 'i lhaduja hoh 'ilhunahuwésdel tube huba hooncha.  
\v 29 Khunek be butl'awhélts'ut hoh wheoobudalh'i. Ndunnah Moses be' dustl'us k'ut 'uk'ununa'úsduguz, 'aw whuz na'a hubuchaoodílh'il. 
\c 8  
\s1 Dune hubukak whulhjut 'en Sizi soo na'binla 
\p  
\v 1 'Aw 'et Sizi ndus de dzulhyaz k'uz hanaja hoh lhanah dune hinantesdel.  
\v 2 'Et hoh dune bukak whulhjut, 'i leprosy hiyúlhni, 'en yududezya, yubut nachaniti 'ink'ez ndi yúlhni, “SMoodihti nyun hukwa' ninzun t'eh, ndi ndai be ilhtus, 'i 'int'i, 'i be suna'ilhdeh.”  
\v 3 'Et Sizi bula be yut'aghéznai 'ink'ez, “A, hukwa' nuszun. Nyuna'alhde!” yúlhni. 'Et bukak whulhjut, 'et 'ahoh soo na'uja.  
\v 4 'Et Sizi ndi yúlhni, “Khun teh 'uyoon doni gunih! 'Et náwhulnuk buts'inyalh 'ink'ez ts'ah'un na'a díni nyust'e nts'e na'a hoh soo na'uja 'ink'ez nyunoolh'en. 'Et Moses be' dustl'us yuk'uyaoolhtuk. 'I bugha ndai huwa ta'alh, 'i nyudóoni. 'Et whuz na'a ts'iyannah whubuntalhtun dainja hoh soo na'inja.” 
\s1 'Ilhunuh Rome whut'en nehughan bumoodih, 'en buye' Sizi soo na'yinla 
\p  
\v 5 'Aw 'et Sizi keyah Capernaum ts'ih huwhutni ninya hoh 'ilhunuh Rome whut'en nehughan bumoodih, 'en yududezya hoh yuts'u tedudlih,  
\v 6 “SMoodihti se'ustlenyaz, 'en njan koo yun sulhti 'aw dechadusnik hoh tube dzuh nuzut.”  
\v 7 'Et Sizi 'uyulhni, “Buts'u tesyalh 'ink'ez soo na'tesdlilh.”  
\v 8 'Et whunts'ih ndun nehughan bumoodih 'uyulhni, “SMoodihti sukoo ts'ih tanyalh huba 'aw soo cha'lhúdzooh. 'Ants'ih nghunek be 'et ndudénja t'eh, 'et whunts'ih se'ustlenyaz soo na'ootnelh sih.  
\v 9 'Alha si chah 'onghunnah sugha ndoh 'uhint'ah hoh hukwa' huninzun tune' suhulh'en. 'Et si chah whuz na'a zeh nehughan huba ndoh 'ust'ah. 'Et 'ilhunuh, ‘Inyalh!’ dusni t'eh, 'et 'aho wheyih. 'Et 'uyoon ‘'Anih,’ dúsni t'eh, 'et 'ahoh sughu yih. 'Et se'ulhna, ‘Njan dineh!’ dúsni t'eh, 'et 'ahoh 'et ndút'ih.”  
\v 10 Sizi ndun dune ndet 'uwhúlhni whulhúdants'o hoh tube ba hooncha. 'Et huwa ndunnah yunedulh ndo búlhni, “Israel whuyun k'ut ndulhcho hoh, 'aw ndun dune whuz na'a buba 'alha 'uhoont'ah nachalhtel.  
\v 11 'Et ndun whudusni ndaz de 'ink'ez nus de lhanah whusatedulh hoh yak'uz k'une' whul'en ts'ih 'et Abraham, 'ink'ez Isaac, 'ink'ez Jacob chah, 'en 'ilho lhula na'hutet'alh.  
\v 12 'Et whunts'ih ndunnah yak'uz k'une' hool'en huba 'int'ah inle, 'en 'az tsahólhgus ts'ih hubotelhdulh. 'Et ts'iyawh hutso 'ink'ez hubughoo lhehídutelhk'us.”  
\v 13 'Et Sizi ndun nehughan bumoodih 'en ndi yúlhni, “'Aw 'et inyalh! 'Et nts'e whula mba 'alha 'ust'ah, whuz na'a zeh mba' whuténilh.” 'Et soo 'et 'uhunet'oh hoh be 'ustl'enyaz soo na'uja. 
\s1 Peter bubez, 'en chah Sizi soo na'yinla 
\p  
\v 14 'Et Sizi, 'en Peter bukoo daninya hoh bubez yunilh'en. 'Et kw'usti k'ut sulhti dada nézul be nduda.  
\v 15 Yuzih ninínya 'ink'ez yula t'agheznai. 'Et 'ahoh ndi nézul nduda buts'uh hanaidede. 'Et 'ahoh dinadija 'ink'ez bugha ná'unt'ai. 
\s1 Lhanah ntsi' nududeh hubuyidélhts'i, Sizi bughunek be buts'ah haóobunanyoot 
\p  
\v 16 'Aw 'et sa yuk tez'ai hoh lhanah ntsi' nududeh hubuyidélhts'i, 'en Sizi highu bunínla. Bughunek be ntsi' nududeh, 'i hubuyáh hanaínanyoot. 'Et ts'iyawh ndan nduda, 'en ts'iyawh soo na'ubinla.  
\v 17 'Et whuz na'a Isaiah nus ho'en hoh ndutni, 'et ts'iyawh 'et ndúhooja. 'Et huwa njan ndutni, 
\q1 “Ndai lait'ah neilh'i, 'i ts'iyawh neghu yílhchoot. 
\q2 'Ink'ez nedada chah 'i nets'u hanáhonla.” 
\s1 Ndun Sizi Gri ba ne'tét'en hukwa' ninzun t'eh, 'et t'eh ndai ndi yun k'ut hukw'entsi', 'et ts'iyawh whuladootni huba' hoont'ah 
\p  
\v 18 'Et 'ilhunahuwésdel ts'iyawh hinasdúguz. 'Et Sizi whunalh'en hoh 'et ndunnah yulh 'ut'en, 'en ts'iyawh ndo búlhni, “Nyan uztooke.”  
\v 19 'Et 'ilhunuh Moses be' dustl'us 'uk'ununa'usdúguz, 'en yughu ninya hoh ndi yúlhni, “Nehodulh'eh nts'oh tula nutányalh, 'et ndulhcho nyun tesyalh hukwa' nuszun.”  
\v 20 'Et Sizi ndi yúlhni, “Soo cho howu nuní ninzut! Nanguz 'en chah 'an whut'i ho' 'int'ah 'ink'ez dut'aiyaz chah ut'o ut'i. 'Et whunts'ih yinkak dune ye', 'aw hukw'ut tsin tel'alh 'et whunts'ih chahóot'ih.”  
\v 21 'Et 'uyoon yugha hoodul'eh, 'en ndi yúlhni, “SMoodihti subailh'i. 'Se'abá wheyutelhtelh choo.”  
\v 22 'Et whunts'ih Sizi ndi yúlhni, “Sunanyalh! Dudulh yaidla dich'oh wheyunalhuhoolyelh.” 
\s1 Nilhtsi 'ink'ez tatsi bulh 'i whunts'ih Sizi hik'une' 'ut'en 
\p  
\v 23 'Aw 'et ts'i beinya 'ink'ez yugha hoodul'eh, 'en ts'iyawh hiyulh 'úja.  
\v 24 Ni huzki ibulh hubulh taoodelts'ut 'ink'ez 'aw 'et ts'i be tawhenduniteh, 'et whunts'ih Sizi 'en nanisti.  
\v 25 'Ink'ez yugha hoodul'eh, 'en hits'u whendel ts'enahiyulhdzit. “NeMoodihti netalhyis! 'Aw 'et too ts'uteghan!”  
\v 26 'Et ndo búlhni, “Di ka whénlhujut? 'Aw bé 'alha' whut'en, 'i soo 'últus, 'i chaht'ih ho' dahni.” Didinya hoh khunekti be hukwa' yudáni too 'ink'ez nilhtsi bulh yatelhtuk, 'ink'ez 'aw 'et dinghel.  
\v 27 'Et ndunnah dune huba hooncha hoh 'ulhódutni, “Ndun dant'ah dune simba 'int'ah? Nilhtsi 'ink'ez tatsi bulh 'i whunts'ih hik'une' 'ut'en.” 
\s1 Nanah dune ntsi' nududeh, 'i hubuyudínda, 'en Sizi ntsi' nududeh, 'i buts'ah hanaóobunanyoot 
\p  
\v 28 'Aw 'et nyan nisúki ndunnah Gergese hubuyun k'ut huwhutni, whuz lhghuhudindel. 'Et nanah dune highu nin'az. 'En ntsi' nududeh, 'i buyudínda. Ndet neyust'e 'ahule, 'et whuz de hahá'az. Soo cha'hunízun k'et 'aw dune buyust'e ghah lhoya ghaít'ah.  
\v 29 'Et khunyaz tube cho 'uhutni, “Sizi nyun Yak'usda buYe' inli ho' 'int'ah! Ndai nets'u hukwa' ninzun? Nket'ah neba whusaóotelts'ulh whutsuh, dzuh nunetalhdzut ka 'inja whusainya?”  
\v 30 'Et njan howu nilhdza, 'et goso lhai hoh ahú'alh.  
\v 31 'Et ntsi' nududeh, 'en hits'u tedudlih hoh hiyulhni, “Whusanáneuntanyulh t'eh, 'et nyooz goso yúzdoodeh netl'ahó'alh.”  
\v 32 'Et “Ahdulh!” ndo búlhni. 'Aw 'et ntsi' nududeh, 'i ndunnah dune hubuts'uh haídande hoh goso yídande. 'Aw 'i bulh goso wheghah helghaz 'ink'ez too hubanghan.  
\v 33 'Et ndunnah goso ghuhinli, ts'iyawh 'ahoh keyah ts'ih whehélghaz. 'Ink'ez keyah whut'en ts'iyawh ndo badáni dahooja 'et. Ndunnah nanah ntsi' nududeh, 'i hubuyidande inle, 'et dahúja nduhóolcho ndo badáni.  
\v 34 'Aw 'et keyah whut'en, ts'iyawh 'az whehélghaz 'ink'ez Sizi hidudezdel. Hitelh'en ibulh njan buyun k'ut whuch'a naóoja, 'et hukwa hits'u tedudlih. 
\c 9  
\s1 Sizi ndun dune 'et ndi yulhni, “Nlubeshi ts'iyawh mba hoolah suli.” 
\p  
\v 1 Sizi 'aw 'et ts'i benya 'ink'ez nyan whehánki dich'oh dukeyah ts'ih.  
\v 2 'Aw 'et ndun dechadusnik, 'en kwusuti be whusahíyankai. Sizi hubunilh'en 'ink'ez t'eooninzun huba 'alha' hoont'ah. 'Et dechadusnik 'uyúlhni, “Dahooja 'uski, nduk 'un dunilt'uk! Nyulubeshi ts'iyawh mba hoolah suli!”  
\v 3 'Et 'ahoh bulunah Moses be' dustl'us 'uk'ununa'úsduguz 'ulhódutni, “Ndun dune Yak'usda ch'a yalhtuk ho' 'utni!”  
\v 4 'Et daja huninzun Sizi 'et ts'iyawh t'eooninzun. 'Et ndo búlhni, “Di ka nuhdzi yuh ntsi' ghu nuni nahzut?  
\v 5 Nts'e na'a simba huwa chahoolnah k'una'a uzdooni? ‘Lubeshi mba hoolah suli,’ k'us, ‘Didinyih 'ink'ez inyalh’?  
\v 6 'Et njan t'eoonóhzin yinkak dune ye', 'en ndi yun k'ut huba' hoont'ah ho' 'int'ah lubeshi 'un toolhdelh ka huba' hoont'ah ho' 'int'ah,” hubúlhni. 'Ink'ez ndun dechadusnik, “Didinyih 'ink'ez kw'usinti, 'i nailchoot 'ink'ez nkoo ts'ih naindalh!” yulhni.  
\v 7 'Et 'ahoh dinadija 'ink'ez bukoo ts'ih whenája.  
\v 8 'Et 'ilhunahuwésdel ts'iyawh huba hooncha 'ink'ez Yak'usda hidálhti, dune, 'en chah butl'aho'ai hoh huba' hót'e ka. 
\s1 Matthew 'en sooneya nalhdzooh 
\p  
\v 9 'Et hukw'elh'az Sizi wheghah lhuseya hoh ndet sooneya nalhdzooh, 'et 'ilhunuh dune Matthew hiyulhni, 'et usda yunilh'en. “Sunanyalh,” yulhni. 'Et didinya 'ink'ez yuk'ah ts'ih oot'en ka yuntezya.  
\v 10 Sizi yukoo ts'ih daninya 'ink'ez buzih usda bula na'utet'alh. Sooneya 'ilhunanowez'aih 'ink'ez lubeshi 'ulh'en, 'en chah koo dahuníndel 'ink'ez Sizi 'ink'ez yugha hoodul'eh hubulh hubulana'hut'alh.  
\v 11 'Ink'ez ndunnah Pharisee hinilh'en hoh yugha hoodul'eh hubuhoodulhkut, “Nuhodulh'eh, 'et di ka sooneya 'ilhunanowez'aih 'ink'ez lubeshi 'ulh'en chah hubulh na'ut'alh?”  
\v 12 'Et Sizi bubulh údants'o daja hiyulhni 'et ndo búlhni, “Ndunnah soo 'ínt'ah 'aw yoo be duyun ka cha'hunízun. Nduda, 'en zeh yoo be duyun ka' huninzun.  
\v 13 'Et huwa ahdulh 'ink'ez ndet 'uk'e'whe'edúguz hoh 'et hodoolhú'eh, ‘'Uyoon hubugha te'ntehzilh 'et nuhts'uh hukwa' nuszun. Ndai Yak'usda bukw'uzdai k'ut hidutelhk'un, 'i buka' cha'núszun,’ ni. Si chah whuz na'a, 'aw dune ts'ah'un 'uhint'ah, 'aw hubuka ilah whusáya. 'Et lubeshi 'uhulh'en, 'en bulubeshi ch'a bubeni naháhundunooleh ka, 'et huba whusáya.” 
\s1 John yugha hoodul'eh, 'en sahá'delya 'et Sizi hukwa hiyoodulhkut 
\p  
\v 14 'Aw 'et John yugha hoodul'eh, 'en Sizi ts'un hunindel hoh hiyoodulhkut, “Dáhoont'ah huwa wheni chah 'ink'ez Pharisee, 'en chah lhat hoh sahá'delya. 'Ink'ez nyun ngha hoodulh'eh, 'en 'aw sahá'chahudulhuye?”  
\v 15 'Et Sizi ndo búlhni, “Ndun bu'at whutele, 'en bulh dunekah 'awhuz hiyulh 'int'ah, 'en chah ih soo sahá'hudutelyih? 'Awundooh! 'Et whunts'ih dubulh dunekah buch'a nahítelhtelh, 'et t'eh zeh sahá'hudutelyelh.  
\v 16 'Ink'ez chah, 'aw 'uda, 'i dzoot 'aw k'andit, 'i naih be naoolhkut ghaít'ah. 'Et nyoo k'andit, 'i naih naootéltsulh 'ink'ez buts'u hanaitech'ulh, 'et 'o nus hootétsi'.  
\v 17 'Et doo chah, 'aw k'an mai too, 'i 'aw 'ujut, 'i 'uzus be yóolhdzeh ghaít'ah. 'Et nduyínla t'eh, 'et sih bukóltalh. 'Et nyoo k'an, 'i mai too ts'iyawh nadutejulh, 'ink'ez ndi 'uzus 'i chah tinta' tet'ilh. 'Et k'an mai too, k'an 'uzus 'i be híyalhdze t'eh, 'aw tinta' 'oot'en ghait'ah.” 
\s1 Sizi 'uski yula ilhchoot hoh dinadija 'ink'ez 'ilhunuh ts'eke soo na'yinla 
\p  
\v 18 'Et njan dahooja 'awhuz howu yalhtuk khunyaz 'ilhunuh moodih yughu ninya 'ink'ez yubut nachániti. 'Et ndi yulhni, “Sutse' k'an 'ahoh dazsai. 'Et whunts'ih soo tulih sukoo ts'ih tónya, 'ink'ez nla be buk'édolnih, 'et sih nakhóotna!”  
\v 19 'Et Sizi didinya 'ink'ez yuntezya. Yugha hoodul'eh, 'en chah ts'iyawh hiyulh 'ut'en.  
\v 20 'Et wheghah hedulh hoh khunyaz 'ilhunuh ts'eke, 'en lanezi 'o 'at nat (12) naooduzuk inle hoh 'uskai 'uyulh'en. Ndun ts'eke Sizi yut'ak ts'ih yugha ninya 'ink'ez nayits'uz, 'i yus ts'ih yut'agheznai.  
\v 21 'Et ndutenilh whuts'uh dich'oh nduna'dudútni, “'Ants'ih bunaih but'aghénai t'eh, 'et sih soo na'oosneh.”  
\v 22 Sizi yuts'u nálha'a 'ink'ez yunilh'en 'ink'ez ndi yúlhni, “Stse', nduk 'undunilt'uk! Be 'alha' hoont'ah, 'i mba 'alha' 'int'ah 'et huwa soo na'inja.” 'Et whuts'un soo na'uja.  
\v 23 'Aw 'et Sizi ndun moodih bukoo ts'ih daninya hoh ndi be ts'ujun, 'i flute hiyulhni, 'i hiye ujun hoh hubunilh'en. 'Et 'onghunnah tube tahúdetnik hoh tso yahalhtuk, 'ink'ez ndo búlhni,  
\v 24 “'Az náhdulh! Ndun ts'ekeyaz 'aw dáchaitsal, 'ants'ih nanisti ho' 'int'ah.” 'Et highudloh.  
\v 25 'Et dune ts'iyawh 'az whenaóobahalh'a. Sizi bukoo ts'ih daninya hoh 'uski yula ilhchoot ibulh dinadija.  
\v 26 'Et dahooja, 'et yun k'ut ndulhcho 'et hukw'u nahuwhulnuk. 
\s1 Nanah dune chawhés'en, 'en Sizi soo na'binla 
\p  
\v 27 'Aw 'et Sizi natesja hoh nanah dune chawhés'en hiyuntez'az 'ink'ez hikazulh, “NeMoodihti David buts'u hainzut negha te'nenzeh!”  
\v 28 'Et Sizi koo ts'ih daninya hoh ndunnah chawhés'en highudani'az. 'Et Sizi ndo búlhni, “Nuhwhuba 'alha' hoont'ah ih njan 'et dutésnilh huba?” 'Et 'uhiyulhni, “A, neMoodihti!”  
\v 29 Buna yut'agheznai 'ink'ez ndo búlhni, “Nts'e na'a nuhwhuba 'alha' hoont'ah, whuz na'a 'uhóneh.”  
\v 30 'Et 'ahoh nahitát'en 'ink'ez honilh'en. Sizi khunek ulhtus, 'i be ndo búlhni, “Khun 'uyoon dóohni gunih!”  
\v 31 'Et whunts'ih tináhunt'az 'ink'ez ndi keyah ndulhcho ts'iyannah ndo badáni. 
\s1 Huba 'alha' cha'hoot'ah, 'en 'uhutni, “Sizi 'en netsudule ye ulhtus, 'i be 'ut'en” 
\p  
\v 32 'Et tinahúndel 'ilhunuh dune 'aw yachalhtuk, ntsi' nududeh, 'i buyidínda 'et huwa. 'En Sizi highu hínilhti.  
\v 33 'Et ndun ntsi' nududeh, 'i ye yáhanainanyoot. Ndun dune 'aw 'et yawhénilhtuk. 'Et 'ilhunahuwésdel 'ulhódutni, “Israel yun k'ut nduhoolhcho hoh 'aw ndez na'a cha'whúsne, 'et k'an ts'iyai 'et 'udechoo ndúhooja!”  
\v 34 'Et ndunnah Pharisee nduhútni, “'Ants'ih ntsi' nududeh, 'en bumoodih ye ulhtus, 'i bugha ndi nududeh ntsi' yuts'u hanaínanyoot!” 
\s1 Sizi 'en dune hubugha te'ninzun 
\p  
\v 35 'Aw 'et Sizi njan keyah whuti 'ink'ez keyah whuyaz chah nduhóolhcho nusiya. 'Ink'ez Lizwif hubuluglez ndi khunek unzoo, 'i be yak'uz k'úne' whul'en, 'en hubugha wheboodulh'eh. 'Et dune ndunnah buyust'e nduda, 'en ts'iyawh soo na'bulh'en.  
\v 36 'Ink'ez 'ilhunahuwésdel hubunilh'en. 'En ts'iyawh nihunentsai k'ah hanul'en, 'aw 'uhooneh ghaít'ah. 'Ink'ez ts'iyaintsuk ladetnik li'hut'en. 'Ants'ih sheepyaz lhanah 'aw hubughunli hoolah li'hint'ah.  
\v 37 'Ink'ez yugha hoodul'eh, 'en ndo búlhni, “'Alha 'aw 'et ha' nukat newhúninzut 'ink'ez tl'o mai lhai suli, 'et whunts'ih ndunnah 'uhut'en, 'en 'aw soo cha'huniltsuk.  
\v 38 'Et huwa Yak'usda ha' nukat whumoodih, 'en 'uyoon 'uhut'en chah whusáboolh'a, 'et huba tenadoohdli,” hubúlhni. 
\c 10  
\s1 Lanezi 'o 'at nanah (12) whel'a huboozi yuk'e'tegus 
\p  
\v 1 'Et lanezi 'o 'at nanah (12) Sizi yugha hoodul'eh, 'en 'ilho 'anih hubudáni. Ntsi' nududeh, 'i 'en ts'iyawh ndet whehílhtus chah, 'ink'ez k'une' bool'en ka, 'et chah, 'ink'ez ndet hukw'e húndudá chah, 'et ts'iyawh 'et whuch'a soo na'botelilh, 'et chah ts'iyawh butl'ahó'ai.  
\v 2 Njan 'et lanezi 'o 'at nanah whel'a huboozi yuk'e'tegus; 'udechoo Simon, 'en Peter chah hiyulhni; 'en bulhutsin 'en Andrew hiyulhni; 'et doo chah James chah Zebedee buye', 'ink'ez John 'en chah 'en bulhutsin 'int'ah;  
\v 3 Philip 'ink'ez Bartholomew; Thomas 'ink'ez sooneya nalhdzooh Matthew hiyulhni; James 'en chah Alphaeus buye' 'int'ah, 'ink'ez Lebbaeus 'en buboozi 'udek'elh'az Thaddaeus hiyulhni;  
\v 4 'et Simon chah, 'en Canaan yun k'ut whut'en 'int'ah, 'ink'ez Judas Iscariot 'en 'uja Sizi be 'onket 'int'ah. 
\s1 Ndunnah lanezi 'o 'at nanah, 'en Sizi hubutelh'alh 
\p  
\v 5 'Aw 'et ndunnah lanezi 'o 'at nanah, 'en nts'e 'uhutet'ilh, Sizi whuz hubutelh'alh. 'Et khunek ulhtus, 'i hubutl'aida'ai hoh ndo búlhni, “Khun 'udun yun k'ut whut'en hubuti ts'ih teh toohdelh gunih. 'Ink'ez Samaria hubukeyah ts'uti whuz teh toohdelh gunih.  
\v 6 'Et Israel buts'u hainde, 'en 'ants'ih sheep tinta nilh'az, 'i lí'hint'ah, 'en zeh hubuts'un toohdelh.  
\v 7 'Aw 'et ahdulh hoh hubutah lhohdelh, njan 'et hubudutéhnilh, ‘Nts'e na'a yak'uz dune k'úne' whul'en, 'aw 'et nilhdukw suli.’  
\v 8 Nduda 'ink'ez buka whulhjut, leprosy hiyúlhni, 'en chah ts'iyawh soo na'boolh'en. Yaidla chah dinábudóohlelh. Ntsi' nududeh, dune hubuts'ah hanábunoohyukw. Ndai 'ants'ih nuhgha nkat, 'i chah 'ants'ih huwaóohle.  
\v 9 Khun teh sooneya nuhsooneya zus be óohdzaih gunih!  
\v 10 Khun téhdulh t'eh hoonliyaz toohla gunih. 'Ezdla 'ink'ez kesgwut, 'i chah 'ink'ez nankoh ts'oozt'an 'ink'ez nuhtuz. 'Alha ndan 'ut'en, 'en nts'e na'a ne'ut'en, 'en huba soo 'úlzoo dant'i hiye ndunidzit 'i hubutl'ahó'alh huba' hoont'ah.  
\v 11 Ndet keyah ts'ih téhdulh 'et keyah whuyaz k'us keyah whuti, 'et ndunnah keyah whut'en, 'en hukwa boodolhkut k'us ndan simba dune budzi unzoo, 'en bukoo doolhúts'i.  
\v 12 'Et hubugha danáhdel t'eh, ndunnah bukoo hudelhts'i 'i ts'iyawh hoonzoo nuhghá holts'it, nuhwhuba hukwa' nídudzun, 'et whuz na'a 'et ndubudóohni.  
\v 13 'Et ndunnah bukoo 'et hudelhts'i, 'en huhóont'i hubughu danáhdel t'eh, 'et nuhdzi dant'ah, ts'iyawh hubuts'un be óolhnih. 'Aw 'et nduchahit'ah t'eh, daja hubudáhni, 'aw nuhwhula'hooneh ghaít'ah.  
\v 14 'Et ndunnah 'aw nuhghun nuchahiyal 'ink'ez chanohuhoozilhts'ai t'eh, 'et bukoo tinaoohdelh 'et nyoh keyah whuti 'et chah whuch'a naoohdelh. 'Ink'ez nuhke ts'iyawh lhez ch'a naoohghat.  
\v 15 'Alha ndun whudusni ndet dzin dune ba nahutedeh whusawhélts'ut t'eh, ndunnah Sodom whut'en 'ink'ez Gomorrah whut'en chah, njan keyah whut'en ndunnah nuhghu núchayal, 'en 'o nus 'uwhultsi' hubugha óotelts'ulh. 
\s1 Sizi 'utni, “Si soozi bugha ts'iyannah nuhts'u dutetnih” 
\p  
\v 16 “Njan whunulh'en, 'ants'ih sheep yus yugha wélh'az li'hoont'ah ts'ih whuz nuhwhutelh'a. 'Et huwa tl'ughus k'una'a whunih wáhle, 'ink'ez dut'aiyas, dove hiyulhni, 'i k'una'a 'aw dune ndóolhdah gunih.  
\v 17 Bulunah dune buch'a kháhdli. 'En Lizwif naheyelh, 'en hububut nenóhotelelh. 'Ink'ez Lizwif luglez húbez ts'ih 'et nuhohóotelhtsus.  
\v 18 'Et 'ants'ih yun k'ut whumoodih 'ink'ez hubudayi cho chah si sugha 'en hububut nenóhotelelh. 'Ink'ez si sugha wheoobuntelhtun. 'Udun yun k'ut whut'en, 'en chah si sugha wheoobuntelhtun.  
\v 19 'Aw 'et whutl'anohuhanla t'eh, nts'e na'a daja dutehnilh, 'et huwu ni wahle gunih. Nts'oh howa whudezulh whe ndai be yátelhtuk, 'i 'et t'ewhunoohzeh.  
\v 20 'Alha 'aw nuhwhenich'oh ilah yatelhtuk. Nuhwhe'aBá buyégha 'i 'uduténilh.  
\v 21 'Et dune dulhutsin datétsah ka whutl'aítelhtelh. Bu'abá 'en buzkeh chah whuz hubutelilh. Bubuzkeh budusnekah chah hubuch'a nehúdutedulh 'et dahutetsah huwá botelelh.  
\v 22 'Ink'ez si soozi bugha ts'iyannah nuhts'u dutetnik. 'Et whunts'ih ndunnah 'udek'elh'az whuts'un 'et whechahítsaz, 'aw 'en zeh hudutejih.  
\v 23 'Et whunts'ih njan keyah 'en dzuh nanóhahulhdzut t'eh, 'et 'udun keyah ts'ih hubuch'a tóohdelh. 'Et keyah whuti 'et chah dzuh nunohohulhdeh t'eh, doo chah 'o 'un keyah hubuch'a tóohdelh. 'Alha' dusni 'et yinkak dune ye' whusateyalh whutsuh, 'aw njan Israel hits'uh hainde, 'en hubukeyah ts'iyawh whutah lhóhdelh ghaít'ah.  
\v 24 Dune yugha hoodul'eh, 'en 'aw yuba dune hoodulh'eh hubugha ndoh cha'it'ah. 'Ink'ez be 'ulhna, 'en chah 'aw dumoodih bugha ndoh cha'it'ah.  
\v 25 Dune yugha hoodul'eh, whuyodulh'eh k'una'a 'oot'e huba' hoont'ah, 'ink'ez be 'ulhna, 'en dumoodih k'una'a 'oot'e huba' hoont'ah. 'Et si Beelzebul\f + \fr 10:25 \ft Ndunnah buboozi, Beelzebul, 'en ntsi' hubumoodihti 'int'ah, ni hoh 'utni.\f* suhútni t'eh, 'et nuhwheni sugha hoodul'eh, nuhwheni chah whuz na'a zeh 'et ndunohoduténilh!  
\v 26 'Et huwa 'en bube noolhújut gunih! Ts'iyaitsuk lubeshi whu'iz 'int'ah 'ink'ez ntelh'i, 'i ts'iyawh ts'et haóotekulh 'ink'ez ts'iyannah 'et t'ehontezeh. 
\s1 Yak'usda 'en zeh be noolhújut 
\p  
\v 27 “Njan daja nuhwhudusni tsahólhgus ts'et whucho howu yaoolhtuk. Ndet whu'iz whudahts'o, 'et bun k'ut whuts'un khunekti be howu yaoolhtuk.  
\v 28 Ndun neyust'e hughan 'et 'aw nezul 'i hizoolhghelh ghaít'ah, 'et ndunt'ah, 'en bube noolhújut gunih. 'Et whunts'ih Yak'usda ndun nuhzul nuhyust'e bulh kwuncho yuh ts'ih nuhtenoh, 'en zeh be noolhújut.  
\v 29 'Alha ih ndi nankoh 'uschas, 'i 'ilho sooneya chadíti, 'i 'et 'ultsuk 'i be oohket? A, 'alha 'uhoont'ah. 'Et whunts'ih ne'aBá 'aw hukwa cha'nizun t'eh, 'aw 'ilhunuh ndi yun k'ut naoolts'it ghaít'ah.  
\v 30 'Ink'ez nuhtsigha, 'i ts'iyawh 'ilhuk'i hoh t'eininzun.  
\v 31 'Et huwa khun whenoolhujut gunih. Nuhwheni 'uschas buch'a degha nus déhti hoh aht'ah. 
\s1 Dune nalh Sizi 'en zeh neulhyis 'int'ah uzdooni 
\p  
\v 32 “'Et huwa ndun dune nalh 'et ndutni, Sizi, 'en zeh si sulhyis 'int'ah, ndun 'et ndutni, se'aBá yak'uz usda, 'en dutesnilh, ndun 'en se'ildzun 'int'ah.  
\v 33 'Et whunts'ih ndunnah dune nalh si hubulhyis ilah hutni t'eh, si chah se'aBá yak'uz usda ndunnah, 'en 'aw se'ildzun chahilah dóosni. 
\s1 Ndan si sugha dich'oh ye khuna, 'i whuladetnik, 'en ndai ye khuna, 'i nayité'alh 
\p  
\v 34 “Ts'iyannah lhts'un ts'ah'un 'uhoot'e, 'et hukwa ndi yun k'ut whusáya noohzin gunih! 'Aw lhts'un ts'ah'un 'uhoot'e hubugha ootés'alh hukwa ilah whusáya. 'Et soh cho li'int'ah, 'i hubugha ités'alh 'et huba whusáya. 
\q1  
\v 35 Dune bu'abá ch'a nidúteyalh 'ink'ez butse' 'en be'ama ch'a nidúteyalh. 
\q2 'Ink'ez 'en buyas'at 'en dubez ch'a nidúteyalh, 'et hukwa whusáya. 
\q1  
\v 36 Ndunnah dune bukoo huwhut'i, 
\q2 'en chah hich'a nidutédulh. 
\p  
\v 37 Ndan bu'abá k'us bu'ama, si sughanus hubuk'entsi' t'eh, ndunt'ah, 'en 'aw suba soo cha'hildzooh! 'Ink'ez ndan buye' 'ink'ez butse' bulh, si sughanus hubuk'entsi' t'eh, 'en 'aw suba soo cha'ildzooh.  
\v 38 'Ink'ez chah ndunnah bulhdulalhgus chadestil, 'ink'ez suchahunesdulh t'eh, 'en ts'iyawh suba soo cha'hildzooh.  
\v 39 Ndan dich'oh ye khuna, 'et hoolhyih hukwa 'ut'en, 'en ye khuna ts'iyawh tinta ooté'alh ho' hoont'ah. 'Et whunts'ih ndan si sugha dich'oh ye khuna, 'i tinta ooní'ai, 'en ye khuna, 'i nayité'alh. 
\s1 Ndan hoont'i hoh danyunilhti, 'en si chah hoont'i hoh dasunílhti ho' 'int'ah 
\p  
\v 40 “Ndan hoont'i hoh danyunilhti, 'en si chah hoont'i hoh dasunílhti li'hoont'ah. Ndan whesalh'a, 'en chah hoont'i hoh daínilhti ho' hoont'ah.  
\v 41 Ndan nus whunilh'en, 'en 'et huwa dune hoont'i hoh dainílhti. 'Et nts'e na'a buba k'elha whutele, 'et ndan chah whuz na'a zeh buba k'elha whutele. 'Et whuz na'a zeh ndan ts'ah'un dune, 'en 'et huwa dune hoont'i hoh dainílhti, 'en ndet buba k'elha whutele, 'et whuz na'a zeh ndunnah chah ba k'elha whutele.  
\v 42 'Ink'ez ndunnah si sugha hoodul'eh, 'ink'ez ndun hubutah k'us hukw'elh'ih 'int'ah, 'en sugha hoodul'eh 'int'ah 'et huwa dune too nezk'uz yubainkai t'eh, 'alha 'ún whudusni, 'en whunts'ih buba k'elha whutale ho' hoont'ah.” 
\c 11  
\s1 Nanah John yugha hoodul'eh, 'en John Sizi ts'un whebalh'a John dune too be 'ulhen, 'en nanah yugha hoodul'eh, 'en Sizi ts'un wheóobalh'a 
\p  
\v 1 'Aw 'et Sizi lanezi 'o 'at nanah yugha hoodul'eh, 'en ts'iyaintsuk ndo budáni 'ustl'e' 'udeja, 'et bughu whénya. 'Uts'un keyah ts'un whenya dune hodutelh'eh 'ink'ez hubulh yatelhtuk wheni.  
\v 2 'Aw 'et John ndalts'ut 'et Christ be 'ut'en k'ah whulh uduzts'ai. 'Et huwa nanah yugha hoodul'eh, 'en John Sizi ts'un wheóobalh'a.  
\v 3 'Et hiyoodulhkut, “Nyun ih whusatéyalh inli, k'us 'uyoon tulih ka ts'itóo'en?”  
\v 4 'Et Sizi njan ndo búlhni, “John bugha nanaht'az t'eh, ndet whunélh'en 'ink'ez ndet whudáhts'o, 'et ts'iyawh ndudóohni.  
\v 5 'Et chawhés'en chah 'et honilh'en nasdli. Dzuh nuhudelh, 'en soo nahudelh nahúsdli. Hubuka whulhjut chah leprosy hiyúlhni, butsun hoolah nasdli, 'ink'ez cha'hudusts'uk chah 'ahudits'o nasdli. Yaidla chah dináhudidel 'ink'ez tel'en chah khunek unzoo, 'i be hubulh yaintuk ho' hint'ah.  
\v 6 'Et ndunnah si sugha 'aw buba dzuh chailel t'eh, 'en degha nus hoonzoo bughá whults'ut.”  
\v 7 'Et ndunnah nanah whehá'az, Sizi ndunnah 'ilhunahuwésdel, 'en njan John bugha hubulh yawhenilhtuk hoh ndo búlhni, “Di teh'ilh ka dune chahóot'ih ts'ih whéhdel? Tl'o ghazilh nonulhts'i, 'i tulih teh'ilh nahzun ih?  
\v 8 Ndet simba hukwa tsi hoohli whuteh'ilh? Dune naih duchut, 'i be soo naduja, 'en tulih teh'ilh nahzun ih? Sih soo zelhts'ai, ndunnah naih duchut, 'i be dune unli, 'aw 'en zeh hubudayi cho bukoo hudelhts'i.  
\v 9 'Et ndet whuteh'ilh hukwa tsi hóohli? Nus whunilh'en tulih? A, 'alha' hoont'ah. 'Et 'unhwhudúsni, nus whunilh'en degha nus hoonzoo whunalh'en!  
\v 10 Ndun 'en bugha 'uk'une'úsduguz, 'i 'et ndutni, 
\q1 ‘Sih soo zelhts'ai 'uyoon khunek suba na'a, 'en ntsuh telh'alh. 
\q2 Nts'oh lhutéyalh mba lhaoodutelilh ka.’ 
\p  
\v 11 Ts'ah'un na'a 'ún whudusni, ts'iyannah whuzdli, 'aw John dune too be 'ulh'en degha nus dezti hoolah. 'Et whunts'ih nts'e yak'uz k'úne' whul'en, ndan degha nus dezti chailah, 'en degha nus uncha ho' 'int'ah.  
\v 12 'Et hoh da John dune too be 'ulh'en be whe' whudit'en, 'et k'an dzin whuts'un, yak'uz nts'e k'úne' whul'en, 'et yak'uz huhoolhdel, 'ink'ez huhoolhdel, 'en ts'iyawh yak'uz da'hudutóoyis hukwa' hut'en.  
\v 13 John whusateyalh whuts'un, nus whunilh'en hube' dustl'us, 'ink'ez Moses be' dustl'us chah, ndet daóotenilh hubudani, 'et 'uwhulhni.  
\v 14 'Et daja nuhwhudúsni, soo nuhwhuba 'alha' whutet'ilh t'eh, ndun nus whunilh'en Elijah whusateyalh, John 'en 'int'ah, 'et huwa.  
\v 15 Ndan budzo hooni, 'en 'ahoozólhts'a huba' hoont'ah.  
\v 16 'Et yuk'edíndeh nts'e na'a simba nuhwhuba lhuzih neooboosdlelh? Ndez na'a njan duhínt'ah hoh 'uskehyaz nduhúlt'ah 'ink'ez nts'e ts'uyi, 'i be 'ooket 'et hudelhts'i. 'en dudulh dunekah buts'u hahuyih hoh ndó buhútni, 
\q1  
\v 17 ‘Be ts'ujun, 'i nuhwhuba be ts'ujun, 
\q2 'et whunts'ih neba chanuzahdak. 
\q1 'Ink'ez nuhwheni nuhwhuba tso ts'inli, 
\q2 'et whunts'ih 'aw wáhtso ghaít'ah!’ 
\p  
\v 18 'Et John dune taninya hoh 'aw cha'us'al 'ink'ez 'aw tachasnai. 'Et highu yalhtuk ho' hutni, ‘Nududeh, 'i ntsi' buyudínda,’ dahni.  
\v 19 'Et yinkak dune ye', 'en dune hubutaninya hoh hubula whé'ni'al 'ink'ez hubula tawhénitnai, 'et 'uhutni, ‘Ndun 'en bucha hooncha 'ink'ez mai too chah 'utnai. Sooneya nalhdzooh 'ink'ez lubeshi 'ulh'en, 'en hubulh dunekah 'int'ah,’ dáhni. 'Et whunts'ih ndunnah Yak'usda bugha whunih suli, 'en ts'iyawh ndi hiye whunih, 'i be ts'ah'un 'uhint'ah suli.” 
\s1 Ndunnah hubeni lht'anahádunoolelh hukwa cha'hunízun, 'en dawhultsi' hubugha óotelts'ulh 
\p  
\v 20 'Et hukw'elh'az nts'e keyah whuti totsuk 'ut'en ncha, 'i ba' yílya, 'i ndut'en hukwa' budáni. 'Aw hubeni lht'anahádunoolelh hukwa cha'hunízun.  
\v 21 'Et huwa 'utni, “Nuhwheni Chorazin whut'en, 'ink'ez nuhwheni Bethsaida whut'en chah, dawhultsi' 'et nuhts'u whélts'ulh! Soo cho soozélhts'ai 'uda ndet nduhóolcho hoolhtus nuhnat ne'whust'en, ndunnah Tyre 'ink'ez Sidon whut'en, 'en chah bunat 'et ndúhooja t'eh, 'uda da hubeni lht'anahádunoolelh, 'ink'ez doso naih be húdelhts'i 'ink'ez lhez tsi la hidudzih wule da.  
\v 22 'Et whunts'ih ndun whudusni, ndet dzin nuhwhuba whusawhutelts'ulh nts'e na'a nuhwhuba nahutedeh ka, 'et ndunnah hubulh dawhutenilh, 'et nuhwheni 'o nus 'uwhultsi' 'et nuhts'u whelts'ulh.  
\v 23 'Ink'ez nuhwheni Capernaum whut'en nduk yak'uz huba soo áht'ah nahzun ih? 'Awundooh! 'Et kwuncho yuh ts'ih nuhotelhdulh! 'Alha 'uda ndet hoolhtus nuhnat ne'whust'en, ndunnah Sodom whut'en, 'en chah bunat 'et ndúhooja t'eh, 'awhuz da bukeyah 'et whuz'ai wule da.  
\v 24 'Et whunts'ih ts'ah'un 'un whudúsni, dahoont'ah nuhwhuba whusawhutelts'ulh, nts'e na'a nuhwhuba nahutedeh ka, 'et ndunnah Sodom whut'en hubulh dawhutenilh, 'et nuhwheni 'o nus 'uwhultsi' 'et nuhts'u whélts'ulh.” 
\s1 Sizi ndo búlhni, “Nuhwheni ts'iyawh dez ahdulh 'ink'ez natelhuyis nuhgha óotes'alh” 
\p  
\v 25 Sizi 'awhuz hubulh yalhtuk 'et ndutni, “'ABá nyun nyudélhti. Yak'uz 'ink'ez yun k'ut huMoodihti inli. Whunih 'ink'ez hoodul'eh, 'en ndi 'i ts'iyawh buch'a whunte'i. 'Et whunts'ih 'uskiyaz li'int'ah, 'en bunalhts'et hahó'ai.  
\v 26 'Et whunts'ih 'aBá ndet 'uhóonla hoonínt'i. Ndoh honeh.  
\v 27 Se'aBá ts'iyawh stl'ahónla, 'ink'ez 'en buYe' ndan unli ts'iyannah t'ehonízun. Ba'aBá 'aw 'en zeh t'eininzun. 'Ink'ez ndan be'aBá unli, buYe' 'aw 'en zeh t'eininzun. 'Ink'ez ndan buYe' 'onghun ts'iyawh wheoobuntelhtun hukwa' ninzun t'eh, 'en zeh huba' hoont'ah.  
\v 28 Nuhwheni ts'iyawh ndan 'ut'en ulhtus, 'i 'ulh'en 'ink'ez ndan ndaz, 'i nuhle li'aht'ah, nuhwheni ts'iyawh dez ahdulh 'ink'ez nats'ulyis nuhgha óotes'alh.  
\v 29 Ndai se' 'ut'en, 'i ulhchoot 'ink'ez nedúht'aih li'ahleh 'ink'ez si sugha hoodulhú'eh. 'Aw dune ch'a nucha'zust'en 'ink'ez ts'iyannah tah te'dudulhú'en 'et huwa. 'Et whuz na'a nuhzul nátelyis huba nahóh'alh.  
\v 30 Ndi úlhchoot, 'i 'aw nuhwhuba hubugha chahóolnah tele, 'ink'ez se'ut'en k'ah chah hoondzak tele.” 
\c 12  
\s1 Sizi 'en nats'ulyis dzin whunts'ih huMoodihti ho' 'int'ah 
\p  
\v 1 'Aw 'et 'ilhut dzin 'et Lizwif huba nalyis dzin huhoolh'i. Hoh da Sizi tl'o k'ut íyalh, 'ink'ez yugha hoodul'eh, 'en chah hiyulh hudulh hoh buye'élts'ul. 'Et tl'o mai huyoonuye 'ink'ez hiya'alh.  
\v 2 'Et ndunnah Pharisee hiya'en ibulh, Sizi hiyoodulhkut, “Ngha hoodul'eh dahút'en hubunilh'en ih? K'an dzin nats'ulyis dzin 'uhoont'ah. 'Aw 'et nduhóot'en huba cha'hoot'ah!”  
\v 3 'Et Sizi ndo búlhni, “'Et hubudayi cho David daja 'aw ih hukw'e yachasulhtuk? 'Et hoh da David 'ink'ez hiyulh 'ut'en hubuye'élts'ul?  
\v 4 'Aw 'et Yak'usda bukoo daninya ndi lhes ndai Yak'usda hubugha it'aih, 'i yu'alh 'ink'ez hiyulh 'ut'en, 'en chah hiyan'al. Nawhulnuk 'aw 'en zeh huyoo'alh huba' hoont'ah, 'et whunts'ih David 'ink'ez hiyulh 'ut'en 'en chah nduhuja.  
\v 5 'Ink'ez Moses be' dustl'us chah, 'aw buk'eyáchasulhtuk hoh ih dahni? Ndez na'a njan ndutni, náwhulnuk nats'ulyis dzin luglez whucho dahuníndel 'ink'ez 'et 'uhut'en. Nts'e na'a 'uhuhoolhdzun, 'et k'uhoninyuz, 'et whunts'ih 'aw buk'echahoolts'ulh.  
\v 6 Whuz na'a ndun whudusni, njan nuhwhutah, 'et 'ilhunuh 'en njan luglez whucho whuch'a degha nus 'ilcho 'int'ah.  
\v 7 'Et 'uk'e'whusdúguz 'et ndutni, ‘'Uyoon bugha te'untezilh, 'et nuhts'uh hukwa' nuszun. Ndai Yak'usda bukw'uzdai k'ut hidutelhk'un, 'i buka cha'nuszun,’ ni. 'Et ndi njan ndutni, 'et t'eoonahzun t'eh, 'et sih ndan buk'echáwhulhts'it, 'en 'aw buk'ehoh'alh hukwa aht'en ilah!  
\v 8 'Et huwa yinkak dune ye' nats'ulyis dzin 'et whunts'ih 'en huMoodihti ho' 'int'ah.” 
\s1 Nats'ulyis dzin 'ut'en unzoo, 'i 'uts'oolh'en 
\p  
\v 9 'Aw 'et hukw'elh'az bughuh whinya hoh ndunnah Lizwif hubuluglez ts'ih daninya.  
\v 10 'Ilhunuh dune 'en 'et usda 'ink'ez 'aw bula 'aw ye nucha'ust'en. 'Et Sizi hiyoodulhkut, “'Et nats'ulyis dzin soo na'uztetnilh huba' hoont'ah ih?” 'Et hoonliyaz highu nahooté'alh hukwa' hut'en.  
\v 11 'Et ndo búlhni, “Ndan nuhtah 'utenilh sheepyaz tsak'et 'álts'ut hoh hanaítelhtelh nats'ulyis dzin 'et whunts'ih?  
\v 12 'Et dawhulcho, 'i be dune sheep degha nus dezti ho' 'int'ah? 'Et huwa netl'awhélts'ut nats'ulyis dzin 'ut'en unzoo, 'i 'uts'ulh'en whuba.”  
\v 13 'Et ndun dune nduyúlhni, “Nyla lhk'unadíntsih!” 'Aw 'et lhk'unaidezsi hoh ílhk'uz ts'ih k'una'a sóo na'uja.  
\v 14 'Et Pharisee 'az whuhandel 'ink'ez huwu yahalhtuk nts'e na'a hituzelhghelh hukwa. 
\s1 Sizi ndan unli, 'aw whebuntelhtun hukwa cha'nínzun 
\p  
\v 15 'Et Sizi hituzelhghelh huwu yahalhtuk, 'et t'ewhunanzin ibulh bughuh whenaja. Lhanah nduda hiyuntezdel, 'en ts'iyawh soo naóo'balh'en.  
\v 16 Khunek ulhtus, 'i be ndo búlhni, “'Uyoon ts'un sughu yaoolhtuk gunih.”  
\v 17 'Et nus whunilh'en Isaiah, daja ni, hoh tuné'whust'en. Ndi khunek njan ndutni, 
\q1  
\v 18 “Ndun suYe' se'ustlen, 
\q2 'en 'utahaílhti 'int'ah. 
\q1 'En buk'esi'. 
\q1 'En bugha suzul tube yé hoont'i. 
\q2 Suyéghah buk'eidutelhdoh. 
\q1 'Et nts'e na'a dahoont'ah dune ba nahesyelh, 
\q2 suYe' whuz na'a zeh 'udun 
\q2 yun k'ut whut'en ndo buduténilh. 
\q1  
\v 19 'Aw dune budulhyah 'udooni ghaít'ah. 
\q2 'Aw hububúlh 'aooldzul ghaít'ah. 
\q2 Ti nuya t'eh, 'aw hubulh dóoltul ghaít'ah. 
\q1  
\v 20 'Aw tl'oghazilh lhbe né'dujut, 'i whunts'ih k'udóojis ghaít'ah. 
\q2 'Aw too dezk'un 'aw 'et nanutneh, 'i whunts'ih, 'aw nainoolhneh ghaít'ah. 
\q1 'Aw 'et Yak'usda lubeshi ba naheyeh 'et whuch'a nilhde t'eh, whuz na'a zeh suYe' 'utet'ilh. 
\q1  
\v 21 'Ink'ez 'udun yun k'ut whut'en ndun suYe' se'ustlen, 
\q2 'en boozi, 'i be 'et whut'anihíntetan.” 
\s1 Ndunnah lhch'a nihudendel, 'en chah hoolah hutele 
\p  
\v 22 Njan 'ilhudzin 'et 'ilhunuh ntsi' nududeh buyudínda, 'en chawhés'en 'ink'ez yaoolhtuk chah ghaít'ah. 'En Sizi buts'un lhgha hidílhti hoh soo ná'yinla. 'En 'ahoh yutá'en 'ink'ez yawhenilhtuk.  
\v 23 'Et 'ilhunahuwésdel ts'iyawh tube huba hooncha 'ink'ez dich'oh lhulh yáhaltuk, “'En 'alha David buts'u hainzut tulih 'int'ah.”  
\v 24 'Et Pharisee whulhódants'o hoh 'et 'uhiyulhni, “Ndun Sizi, 'en Beelzebul, ntsi' nududeh bumoodih 'int'ah, 'en be zeh ntsi' nududeh, 'i dune ts'uh hanahinuyukw,” hutni.  
\v 25 Daja huninzun Sizi t'eooninzun 'et ndo búlhni, “Yun k'ut k'une' huwhul'en, 'en lhch'a nehúdindel t'eh, 'en ts'iyawh hoolah hutele. 'Ink'ez keyah whuti whudune k'us bukoo hudelhts'i chah, ts'iyawh lhch'a nehúdindel t'eh, 'en chah huhoolah hutele.  
\v 26 Whuz na'a Satan dich'oh dune ts'uh hanainuyukw t'eh, 'et 'alha dich'oh lhch'a detni ho' 'int'ah. 'Ink'ez nts'e na'a hubudayi cho unli, 'ilhuz whutet'ilh?  
\v 27 'Et si Beelzebul 'en be 'ust'en t'eh, 'et t'eh sudahni nuhwheni nuhye'kah, k'us ndan simba ntsi' nududeh, 'i dune ts'uh hanaóobunooyukw? 'Et huwa 'en hubugha t'ewhuntehzeh tink'us údahni!  
\v 28 'Et whunts'ih Yak'usda buyégha be ntsi' nududeh dune ts'uh hanánusyukw t'eh, 'et 'alha' hoont'ah, nts'e Yak'usda hubudayi cho unli, 'aw 'et nuhghu whults'ut ho' hoont'ah.  
\v 29 'Et nts'e na'a 'utenilh 'ilhunuh dune 'et dune ulhtus bukoo daninya 'ink'ez hoonliyaz yegho telhchulh? 'Aw 'ooneh ghaít'ah. Ndun dune 'udechoo yulhghel t'eh, 'et t'eh zeh ts'iyaitsuk yegho telhchulh.  
\v 30 Ndunnah sulh cha'it'ah, 'en sch'a hudetni ho' hint'ah. 'Ink'ez ndunnah 'aw dune sula 'ilhuchahowesdle 'en ts'iyawh 'ants'ih yahutedúkulh li'hutenilh. 
\s1 Ndunnah Ndoni ch'a detni be yalhtuk, 'aw buba whunaoodootnah ghaít'ah 
\p  
\v 31 “'Et huwa 'un whuhdúsni, lubeshi ts'iyawh 'ink'ez Yak'usda ch'a yalhtuk, 'et ts'iyawh nuhwhuba whunaoodutelnah. 'Et whunts'ih Ndoni ch'a detni be yalhtuk, 'aw buba whunaoodootnah ghaít'ah.  
\v 32 'Ink'ez ndunnah yinkak dune ye' ch'a yalhtuk, daja hutni, soo buba 'un whutelhdulh. 'Et whunts'ih ndunnah Ndoni ch'a yahalhtuk, 'aw buba 'un whutoolhdelh ghaít'ah. K'an dzin k'us nus de whunts'ih 'aw 'uhoneh ghaít'ah. 
\s1 Duchun bumai gha dant'i duchun 'i t'enahzun 
\p  
\v 33 “Mai chun unzoo, 'i hanúlhyeh t'eh, bumai unzoo tele. 'Et mai chun untsi', 'i hanálhyeh t'eh, bumai ntsi' tele. 'Et bumai whuzdli t'eh, dant'i duchun 'int'ah, 'i bumai bugha t'entedzeh.  
\v 34 Nuhwheni ts'iyawh poison tl'ughus buzkeh li'aht'ah! Nts'e na'a ahtsi' 'ink'ez khunek unzoo, 'i be yalhtuk? Nuhdzi ndai be dezbun, 'i be zeh yalhtuk.  
\v 35 Dune unzoo 'en ndai unzoo, 'i budzi tuz 'ilhunayoole, 'aw 'i zeh buts'uh haídukat. 'Et dune untsi', 'en ndai untsi', 'i budzi tuz 'ilhunayoole, 'aw 'i zeh buts'uh haídukat.  
\v 36 'Et ndun whudusni ndunnah 'aw khunek cha'it'ah, 'i be yalhtuk, dune ba nahedelh dzin whusawhélts'ut t'eh, nts'e na'a khunek 'i be yalhtuk, whuz na'a buba nahutedeh.  
\v 37 'Et huwa nuhghunek bugha Yak'usda nalh ts'ah'un dune tehle, k'us nuhghunek bugha kwuncho yuh ts'ih téhdulh k'una'a, whuz na'a nuhwhuba nahutedeh.” 
\s1 Sizi buba 'alha' cha'ít'ah, 'en hoonliyaz hooncha tune' whut'en, 'et zeh huhó'en hukwa' huninzun 
\p  
\v 38 'Aw 'et bulunah Moses be' dustl'us 'uk'ununa'úsduguz, 'ink'ez Pharisee, 'en chah 'uhiyulhni, “Dune hoodulh'eh neba huwa 'et'en tune' tant'en nts'uh hukwa' uzninzun.”  
\v 39 'Et ndo búlhni, “K'an ndoh whudezulh dune hintsi', 'ink'ez 'ahoolhyez dune ts'eke bulh tinta' hut'ih. Hoonliyaz hooncha tune' whut'en, 'et zeh hukwa hités'en. 'I bugha t'ehonózin. 'Et whunts'ih honilh'en bughá holts'it ghaít'ah. Nts'e na'a nus whunilh'en Jonah bulh dahooja, 'et zeh hote'ilh.  
\v 40 Njan dúhooja, tat dzin 'ink'ez tat 'ulh'ek Jonah lhook cho chadánda. 'Et whuz na'a zeh yinkak dune ye' 'en tat dzin 'ink'ez tat 'ulh'ek yun yuh ts'ih tédalh.  
\v 41 'Ink'ez wheghah whezulh dzin dune ba nahutedeh t'eh, Nineveh whut'en, nuhwheni k'andoh whudezulh, 'en nuhwhutah di hudutédulh 'ink'ez nuhwhuba nahoteyeh. Soo cho whunulh'en, hoh da Jonah hubulh yailhtuk da, ts'iyawh hububeni lht'anahádunezdla. 'Aw 'et soo zélhts'ai, 'ilhunuh 'en Jonah degha nus 'int'ah k'an nuhtah siyin.  
\v 42 'Et wheghah whezulh dzin dune ba nahutedeh t'eh, 'et nyaz de hubudayi cho ts'eke 'en nuhtah didutéyalh, 'et nuhk'ehóotelts'ulh. Ndi yun k'ut nilhdza hainya, Solomon ye whunih, 'i yudutéts'o ka 'et huwa. 'Et whunts'ih 'ilhunuh Solomon degha nus whunih k'an nuhtah siyin.” 
\s1 Dahooja hoh ntsi' nududeh, 'i doo chah zeh dune buyunaídede t'eh 
\p  
\v 43 'Ink'ez ndo búlhni, “'Et ntsi' nududeh dune ts'uh hanádide hoh yun whudezgih, 'et whuz nududeh natelyis hukwu núta. 'Et 'aw nduhóont'ah nachahóo'al.  
\v 44 'Et dich'oh na'dudútni, ‘'Et ndun buyudúsda, 'en buts'un zeh natóosja,’ ni. 'Et whuz lhghu nadija hoh 'aw hoonli hoolah. 'Et ndun dune budzi yuh chadítsun nawhulhtsi 'ink'ez ts'ah'un na'a 'uja, 'et nahoo'ai.  
\v 45 'Ink'ez 'et 'uts'un whedande 'ink'ez skwunlai 'o 'at nanah ntsi' nududeh, 'i 'en degha nus 'ultsi', 'en 'et dune hiyaíndel 'ink'ez 'et nihunina. 'Et ndun dune ndun hiyudalts'i', 'en 'et whutsuh da 'o nus 'ultsi' suli. Nuhwheni k'an ndoh nuhwheghah whudezulh, nuhwheni dune tube untsi' aht'ah, 'et whuz na'a zeh nuhwhuba 'uwhuténilh!” 
\s1 Sizi be'ama 'ink'ez bulhutsinkah teh hiyulh yatelhtuk hukwa' huninzun 
\p  
\v 46 Sizi 'awhuz 'ilhunahuwésdel hubulh yalhtuk hoh be'ama 'ink'ez bulhutsinkah teh, 'az nahudelhúya. 'Et hiyulh yatelhtuk hukwa' huninzun.  
\v 47 'Et 'ilhunuh dune 'uyulhni, “Nilh'en! Nyu'ama 'ink'ez nyulhutsin 'az nahudelhúya nyulh yahutelhtuk hukwa' huninzun!”  
\v 48 'Et Sizi ndi yúlhni, “Ndan su'ama, 'ink'ez ndan sulhutsinkah?”  
\v 49 'Et Sizi ndunnah yugha hoodul'eh, 'en butune'úlhge, “Nilh'en ndunnah, 'en su'ama 'ink'ez sulhutsinkah 'uhint'ah.  
\v 50 Se'aBá 'en yak'uz usda, k'us ndan hik'une' 'ut'en, 'en sulhutsin, sulhtus, 'ink'ez su'ama teh 'uhint'ah!” 
\c 13  
\s1 Khunek be whuts'odul'eh, 'i 'a'nule bugha 
\p  
\v 1 'Et dzin Sizi koo tininya, 'ink'ez bun taba natl'adeda.  
\v 2 'Aw 'et dune lhanah higha wézdel 'et ts'i beinya, 'ink'ez ts'i bet natl'adeda. 'Et ts'iyawh taba 'et nahudelhúya.  
\v 3 Ndai khunek be whuts'odul'eh, 'i 'et lhelhdun huwa hubulh yalhtuk hoh ndo búlhni, “Sih soo zélhts'ai, 'ilhunuh 'a'nule, 'en 'a'ntelelh ts'ih whinya.  
\v 4 'Et 'a'nule bulah ti nanánkat. 'I dut'aiyaz whusahándel 'ink'ez ts'iyawh hineldel.  
\v 5 'Et bulah tse tah nanánkat, 'et huwa 'i 'ahoh hanusdúki, 'ankw'us yun hoolah huwa.  
\v 6 Bughih hoolah 'et huwa hasain'ai hoh ts'iyawh yanúdezgi 'ink'ez hoolah suli.  
\v 7 'Et bulah chah whus tah nanánkat. 'I chah whus cho whutah bulh tanenyi 'ink'ez bulh lhéwhuntlah.  
\v 8 'Et 'onghoh, 'i yun unzoo, 'i k'ut nanánkat hoh soo hananyi. Bumai buluh lanezi lanezi (100) bumai suli, buluh lhk'utat lanezi (60) bumai suli, 'ink'ez buluh tat lanezi (30) bumai suli.  
\v 9 Ndan budzo hoonli, 'en soo cho hiyoozólhts'a huba' hoont'ah.” 
\s1 Khunek be whuts'odul'eh, 'i be zeh Sizi hubulh yalhtuk 
\p  
\v 10 'Aw 'et yugha hoodul'eh highu nindel, 'et hiyoodulhkut, 'ink'ez 'uhiyúlhni, “Di ka ndi khunek be whuts'odul'eh, 'i be zeh hubulh yaílhtuk?”  
\v 11 'Et ndo búlhni, “Yak'uz be k'úne' whul'en 'aw be whe' hoont'ah hooyah, 'i daja ni, nuhwheni zeh nuhghá whunt'ai. 'Et 'onghun 'aw hubugha chahóolts'ulh. 'Et huwa whuz na'a zeh hubulh yalhtuk.  
\v 12 'Et huwa njan duhoont'ah, ndunnah hoontsoolyaz t'ehonínzun, 'en 'o nus lhat t'ehonínzun, 'et hubugha whútelts'ulh. 'Et ndunnah hoonli t'ehonízun, hoontsoolyaz, hodits'o ndai 'aw 'i hiyit'i, 'i whunts'ih bughu nayitélchulh.  
\v 13 'Et huwa ndi khunek be whuts'odul'eh, 'i be zeh hubulh yalhtuk. 
\q1 'Et doo ka honalh'en 'et whunts'ih 'aw chahonilh'en. 
\q2 'Ink'ez hidits'o 'et whunts'ih 'aw chahodústs'o, 'aw t'ehonoozeh chah ghaít'ah.  
\v 14 'Et Isaiah nus ho'en daja ni 'en bugha ts'iyawh lhaóodulya. Njan ndutni, 
\q1 ‘'Ahoolhyez whudahts'o 'et whunts'ih 'aw t'echanuzéhze. 
\q2 'Ahoolhyez whunulh'en 'et whunts'ih 'aw ts'ah'un nechaóozah'ai. 
\q1  
\v 15 Ndunnah dune budzi 'ants'ih buba' hoont'ah suli 'et huwa, 
\q2 'ink'ez 'aw hoonli hodóts'o hoolah, 
\q2 'ink'ez ndai be 'alha' hoont'ah, 
\q2 'i 'aw hinoolh'en hukwa cha'hunízun. 
\q1 'Et huwa chawhés'en lí'hint'ah. 
\q1 'Et huwa 'aw honóolh'en ghaít'ah, 
\q2 'ink'ez budzo be 'aw hodóts'o ghaít'ah. 
\q1 'Ink'ez budzi be 'aw t'ehonoozeh hoolah. 
\q1 'Et whuz na'a nducháhit'ah t'eh, 
\q2 'uda da hubulubeshi ch'a nahulhya wule da, 
\q2 'ink'ez da Yak'usda huboolhyih,’ ni Isaiah. 
\p  
\v 16 'Et whunts'ih nuhwheni ndai nuhna be whunulh'en, ts'ah'un na'a whunulh'en. 'Ink'ez nuhdzeh hoh soo whúdahts'o, 'et huwa degha nus hoonzoo nuhghá whults'ut.  
\v 17 Ts'ah'un 'un whúdusni, hoh da lhanah nus whunilh'en 'ink'ez ndunnah ts'ah'un 'uhint'ah, ndai nulh'en, 'i hiyuntelh'ilh hukwa' huninzun, 'et whunts'ih 'aw chahiyí'il! Ndet whudahts'o, 'et soo ts'ah'un hodutéts'o hukwa' huninzun, 'et whunts'ih 'aw chahodíts'il. 
\s1 Khunek be whuts'odul'eh, 'i be 'a'nule, 'en bugha njan ndutni hoh 'utni 
\p  
\v 18 “'Et huwa ndi khunek be whuts'odul'eh, 'i be 'a'nulih, 'en bugha, njan ndutni,  
\v 19 ndunnah yak'uz nts'e na'a 'uhuhoolhdzun whulh 'úhudits'o ndi khunek daja ni hoh 'utni 'et whunts'ih bubeni be 'aw t'ehonuszun. Ndai dune budzi tuz 'ahinanla, 'i ndun ntsi' whusayih 'ink'ez budzi be hanaída'aih! Ndi 'i 'int'ah, ti 'anélya, 'i 'int'ah.  
\v 20 Ndi ndai da tse tah 'anilya, 'i ndunnah 'i k'una'a 'uhint'ah. Ndi khunek hidits'o t'eh, 'ink'ez soo 'ahoh huhóont'i hoh hiyilhchukw.  
\v 21 'Et whunts'ih dich'oh 'aw bughih hoolah li'hint'ah. 'Et huwa 'astl'iyaz zeh huba 'alha' hoont'ah. 'Ink'ez ndi khunek 'i bugha dzuh nuhudeh 'ink'ez 'onghunnah buch'a hudetni. 'Et huwa 'ahoh whulahudutnih.  
\v 22 Ndai whus tah 'anankat, 'i li'int'ah, 'en ndez na'a 'uhint'ah. 'En khunek hidits'o, 'et whunts'ih ndi yun k'ut huwu ni ts'inli, ndi yun k'ut soo uzde'a 'uhoont'ah, 'et 'i ts'iyawh whus cho 'i be bulh lheyúllhuk ndult'ah. 'Et huwa 'aw lhahúdulya hoole ghaít'ah.  
\v 23 'Et whunts'ih ndet yun unzoo, 'i k'éninkat, 'i li'ínt'ah, 'en ndez na'a njan ndúhint'ah. Ndi Yak'usda bughunek hidits'o, 'i t'ehinuzih teh daja ni hoh 'utni. 'Et huwa bumai lhai lhih li'hint'ah. Bulah lanezi lanezi (100) suli. 'Et doo chah bulah lhk'utat lanezi (60) suli. 'Et doo chah bulah tat lanezi (30) suli.” 
\s1 'Uyoo khunek be whuts'odutel'eh, 'i nts'e na'a yak'uz hubudayi cho 'uhuhoolhdzun 
\p  
\v 24 Doo chah 'uyoo khunek be nawhutnuk, 'i be whuts'odul'eh, 'i be hubulh yalhtuk 'et njan ndo búlhni, “Nts'e na'a yak'uz hubudayi cho 'uhuhoolhdzun, 'et dez na'a njan nduhoont'ah. Dune ndi yun buk'ut 'a'nukat. Unzoo, 'i 'anukat, 'i 'ainanla.  
\v 25 'Awhuz huztez hoh dune yuch'a detni whusainya. 'Et ndi 'ainanla, 'i unzoo, 'i tah, ndi 'anukat, 'i 'ut'antsi' ts'utni, 'i yutah 'ainanla, 'ink'ez whenaja.  
\v 26 'Et ts'iyawh hanányi hoh ndi 'ut'antsi', 'i chah bulh hainanyi.  
\v 27 'Et bukoo whumoodih be 'ulhna highu nindel 'ink'ez 'uhiyulhni, ‘Dahooja nemoodih, di hoh inla ndi unzoo, 'i hanuyeh butah 'anánla? Di ho' 'int'ah ndi 'ut'antsi' ndult'ah?’  
\v 28 'Et ndo búlhni, ‘Sch'a detni 'uja.’ 'Et be 'ulhna hiyulhni, ‘Ndi 'ut'an untsi', 'i butah hananyi, 'i hats'úntelelh hukwa' ninzun ih?’  
\v 29 'Et ndo búlhni, ‘'Awundooh! Whute 'int'ah doo ka sih ndi unzoo, 'i chah bulh 'óohneh.  
\v 30 Whute ndulhdzun ha' untekulh whuts'un. 'Aw 'et ha' nukat neooninzut t'eh, ha' untelelh, 'en si budóosni, 'udechoo 'ut'antsi' hanáhle 'ink'ez ulhghel duték'un huba. 'Ink'ez ndai unzoo, 'i ts'iyawh hanáhle 'ink'ez haníyeh, 'i ba bukoo whuz danáhle.’ ” 
\s1 Nts'e na'a yak'uz hubudayi cho 'uhuhoolhdzun, ndi mai, mustard hiyulhni, 'i k'una'a 'uhoont'ah 
\p  
\v 31 Doo chah 'uyoo khunek be nawhutnuk, 'i be whuts'odul'eh, 'i be hubulh yalhtuk 'et njan ndo búlhni, “Nts'e na'a yak'uz hubudayi cho 'uhuhoolhdzun, 'et ndez na'a njan nduhoont'ah. Ndi mai, mustard hiyulhni, 'i k'una'a 'int'ah. 'I dune yílhchoot 'ink'ez ha'nulhyeh k'et wheyínanla.  
\v 32 Ndi mai soo degha nus ninsol, 'i hanányi 'ink'ez buchun degha nus dincha suli. Ndi mustard hiyulhni buchun, 'i ndai mai chun ts'iyawh 'ut'an hanúlhyeh bugha ndoh suli. 'Et 'i dut'aiyaz buyooschun tah 'ut'o ninínla.” 
\s1 Nts'e na'a yak'uz hubudayi cho 'uhuhoolhdzun, 'et lhes ntuldoh, 'i ndult'ah 
\p  
\v 33 Doo chah 'uyoo khunek be nawhutnuk, 'i be whuts'odul'eh, 'i be hubulh yalhtuk 'et njan ndo búlhni, “Nts'e na'a yak'uz hubudayi cho 'uhuhoolhdzun, 'et ndez na'a njan nduhoont'ah, lhes ntuldoh, 'i ndult'ah. Ts'eke yílhchoot 'ink'ez lhes nudzaih, 'i tat tests'ai be lhtayudzih, 'i dezbun. 'Et yunélhus, 'ink'ez 'udun ninínkai hoh untéldoh.” 
\s1 Khunek be nawhulnuk, 'i be whuts'odul'eh, 'i 'et whuz na'a zeh Sizi 'ilhunahuwúdulh hubulh yailhtuk 
\p  
\v 34 Ndi ts'iyai, 'i khunek be nawhutnuk, 'i be whuts'odul'eh, 'i 'et whuz na'a zeh Sizi 'ilhunahuwúdulh hubulh yailhtuk. 'Aw 'uts'un na'a cha'budínil. 'Et ndez na'a zeh hubudáni.  
\v 35 'Et whuz na'a ndun nus whunilh'en daja dani, 'et ts'iyawh lhaóoduja hoh njan ndutni, 
\q1 “Khunek be nawhutnuk, 'i be whuts'odul'eh, 'i be hubulh yatelhtuk. 
\q2 Nts'oh huwa whudezulh hoh ndi yun 'uyínla 'et whuts'un, 
\q2 ndai buch'a yuntez'i, 'i bugha hubudutésnilh.” 
\s1 Ndi haniyeh, 'i tah 'ut'an ntsi' hanányi, 'i wheoobuntelhtun daja ni 
\p  
\v 36 'Et Sizi 'ilhohuwezdel, 'en ts'iyawh whenábalh'a 'ink'ez koo danínya. 'Et yugha hoodul'eh highu nindel 'ink'ez 'uhiyúlhni, “Ndi khunek be nawhutnuk, 'i be whuts'odul'eh, 'i ts'ah'un na'a nedini ndi haniyeh, 'i unzoo, 'i tah 'ut'an ntsi' hananyi, 'i 'et daja ni hoh 'utni?”  
\v 37 'Et ndo búlhni, “Ndai unzoo, 'i hanányi bumai 'i, ndun 'ainanla, 'en yinkak dune ye' 'en 'int'ah.  
\v 38 Haniyeh k'et, 'et ndi yun k'ut nduwhúlt'ah ho' hoont'ah. Ndi mai unzoo, 'i yak'uz hubudayi cho buzkeh, 'en nduhúlt'ah. 'Et whunts'ih ndi 'ut'an ntsi', 'i ntsi' buzkeh nduhúlt'ah.  
\v 39 'Ink'ez ndun yuch'a detni, ndi 'ut'an ntsi' 'ainanla, 'en netsudule. Njan ha'nukat 'et ndóh yun k'ut ts'udelhts'i whulatah 'et 'uhóont'ah. Ndunnah ha' úntelelh, 'en lizas nduhult'ah.  
\v 40 'Et huwa nts'e na'a ndi 'ut'an ntsi' nahidulhdzooh 'ink'ez hidelhk'un, whuz na'a zeh njan k'an ndoh whudezulh whulatah t'eh chah, nduwhutenilh.  
\v 41 'Ink'ez yinkak dune ye', 'en bulizas nduhóolcho ts'ih whutl'abutelelh. Nts'e hubudayi cho unli, ndunnah hukwaya hoonli tune' 'úst'en, 'en 'ink'ez yuk'unucha'ust'en, 'en ts'iyawh 'ilhunaoobotélelh.  
\v 42 Nts'e kwun dezk'un huba' hoont'ah, 'et whuz hubatelhdulh. 'Ink'ez tso yahutelhtuk 'ink'ez hubughoo lhuhidutek'us.  
\v 43 'Et dzin nts'e na'a sa hadánat, ndunnah ts'ah'un na'a 'int'ah, nts'e be'aBá hubudayi cho unli, 'en chah whuz na'a zeh sa k'una'a buts'u haíteduz ho' hoont'ah. Ndunnah budzo hoonli, 'en soo cho hiyoozólhts'a huba' hoont'ah. 
\s1 Yak'uz k'une' whul'en, daóodelti, 'et ndez na'a njan ndúhoont'ah 
\p  
\v 44 “Doo chah zeh 'ún whudusni, yak'uz k'úne' whul'en, daóodelti, 'et ndez na'a njan ndúhoont'ah. Ndun dune njan yun k'ut hoonzoo, 'et nunúta hoonliyaz dezti, i nayí'ai. 'Ink'ez 'onghoh nayuntelh'i. 'Et hoont'i k'et ndun dune ndai hoonli yit'i, 'i ts'iyawh ye 'ónket 'ink'ez ndi yun yuk'ut nayi'ai, 'i yun ndulhcho whe yonket. 
\s1 Doo chah zeh yak'uz k'úne' whul'en daoodelti, 'et ndez na'a njan nduhoont'ah 
\p  
\v 45 “Doo chah zeh 'ún whudusni, yak'uz k'úne' whul'en, daoodelti, 'et ndez na'a njan nduhoont'ah. 'Et doo chah 'uyoon dune, 'en hoonliyaz 'i ts'iyawh yooket. 'Et 'o 'un doo chah ye ná'oonket. 'En kw'usul k'us dunezti, 'i hikunuta.  
\v 46 'En 'ilho kw'usul k'us dunezti, 'i naini'ai. Ndun dune ndai hoonli yit'i, 'i ts'iyawh ye 'ónket hoh ndi kw'usul k'us dunezti, 'i yoonanket. 
\s1 Yak'uz k'une' whul'en, 'et lhoombilh tahíyalhdel, 'et whuz na'a njan nduhoont'ah 
\p  
\v 47 “'Et doo chah zeh 'ún whudusni, yak'uz k'úne' whul'en, 'et ndez na'a njan ndúhoont'ah. Ndez na'a 'uhut'en, lhoombilh tahíyalhdel 'ink'ez yanáhiyigus lhawh dédowh 'i hiyuzdlooh.  
\v 48 'Et yahíyuzguz ts'iyawh lhtahahíyule. Ndai lhook untsi', 'i ts'iyawh 'un whehíyulhdelh. 'Ink'ez ndai unzoo, 'i ts'iyawh nts'e 'uhitelh'ilh ts'ú whehiyulhdelh.  
\v 49 'Aw 'et nts'oh whúdezulh hoh huba neóoni'ai, 'et huba whusawhélts'ut t'eh, 'et hukw'un'a zeh 'uwhuténilh. Lizas whusahutedulh, 'en ts'iyawh dune hinzoo 'ink'ez dune hintsi' lhtahábotelelh.  
\v 50 Ndunnah hintsi', 'en nts'e kwun dezk'un huba' hoont'ah, 'et whuz hubotelhdulh. 'Ink'ez tso yahutelhtuk 'ink'ez hubughoo lhuhidutek'us.”  
\v 51 'Aw 'et Sizi ndo búlhni, “Njan ndun whudusni, 'et ts'iyawh ih t'eoonáhzun?” 'Et 'uhiyúlhni, “A, neMoodihti, ts'iyawh t'ets'oninzun.”  
\v 52 'Et ndo búlhni, “'Et huwa ndan Yak'usda bughunek 'uk'e'eduguz, 'i 'ink'ez yak'uz k'une' whul'en 'et hubugha wheyodalh'i, ndun dune 'en bukoo whumoodih, 'en ndult'ah. 'Ink'ez ndai yit'i, 'i tah ts'iyawh ts'et hayúle, k'an, 'i 'ink'ez 'uda, 'i chah. 'Et whuz na'a dune hoodulh'eh.” 
\s1 Keyah Nazareth ts'ih ndunnah Sizi buba 'alha' cha'hoot'ah, 'en ts'iyawh hits'u desnih 
\p  
\v 53 'Et ndi khunek be nawhutnuk, 'i be whuts'odul'eh, 'i 'aw 'et Sizi ts'iyaintsuk lhaoodinla hoh njan usda 'et whuch'a nanja.  
\v 54 'Ink'ez dich'oh bukeyah ts'ih whénaja hoh Lizwif hubuluglez 'et wheóobudunilh'i. Et ts'iyannah huba hooncha suli, 'ink'ez 'ulhódutni, “Ndun dune nts'ez de hahó'ai ndi khunek whunih, 'i be yalhtuk? 'Ink'ez hooncha tune' 'ut'en nts'e na'a dat'en hoh 'ut'en?  
\v 55 'Alha ilah bukoo 'uwhulh'en, 'en buye' 'int'ah? 'Ink'ez 'en ilah be'ama Mary? K'us bulhutsinkah 'en James, Joses, Simon, 'ink'ez Judas?  
\v 56 'Et bulhtuskah 'aw ts'iyawh nelh cha'hit'ah? 'Et ndun dune ndi ts'iyawh nts'ez de hahónla hoh 'utni?”  
\v 57 'Et huwa ts'iyawh hits'u desnih. 'Et Sizi ndo búlhni, “Ndun nus whunilh'en unli, 'en ts'iyannah yudelhti. 'Et whunts'ih dich'oh bukeyah whut'en 'ink'ez dich'oh bukoo, 'en chah 'aw chahidílhti.”  
\v 58 'Et Sizi 'en 'aw buba 'alha' cha'yít'ah. 'Et huwa dich'oh bukeyah 'aw lhat hooncha tunucha'ít'il. 
\c 14  
\s1 John dune too be 'ulh'en, 'en hizelhghi 
\p  
\v 1 'Et hoh da wheghah whudezulh hoh hubudayi cho Herod 'en Sizi yulh údants'o.  
\v 2 'Et Herod bube 'ustl'en ndo búlhni, “Ndun John dune too be 'ulh'en, 'en 'int'ah. Yaidla tah nakhitna. 'Et huwa 'ut'en hoolhtus tune'út'en.”  
\v 3 Ndez na'a 'uhooja hoh da Herod John hiyílhchoot, hiyulhghel 'ink'ez tsak'e híya'ai. Bulhutsin Philip hiyulhni, 'en bu'at Herodias hiyulhni, 'en bula gha ts'ih 'uhiyínla.  
\v 4 'Et John 'en Herod ndi yulhni, “'Aw nyun mba ts'ah'un na'a cha'hoot'ah hoh 'uyoon bu'at buzih sinda.”  
\v 5 'Et Herod yutuzelhghelh hukwa' ninzun. 'Et whunts'ih ts'iyannah dune John 'en nus whunilh'en 'int'ah huninzun, 'et huwa Herod whenelhújoot.  
\v 6 'Et 'ilhudzin 'et Herod whuzdli dzin 'uhoont'ah hoh Herodia butse' 'en hububut nunúdaih. Herod tube buba hoonzoo.  
\v 7 'Et 'ahoh hits'u náhezya hoh ndi yúlhni, “Ndet sts'o hukwa' ninzun sts'o hukwa' dini.”  
\v 8 'Et ndun ts'eke be'ama, 'en, “Herod oodílhkut John dune too be 'ulh'en butsi lusyet be stl'ainkaih dóni,” yulhni.  
\v 9 'Et hubugha hubudayi cho budzi únduda suli. 'Et ts'iyannah ndunnah yuzih hudelhts'i, 'en ts'iyawh hidánts'o, 'et ts'ekeyaz bughunek yutl'aida'ai. 'Et huwa whuz na'a 'uhiyooleh huba' hoont'ah.  
\v 10 'Aw 'et nts'e tsak'esda ts'ih whuz wheyálh'a, 'ink'ez tsak'esda ghuhinli, 'en John hitsi k'unéntsel.  
\v 11 'Ink'ez lusyet be whusahíyankai, 'ink'ez ndun ts'ekeyaz tl'ahíyankai. 'Ink'ez be'ama yughah níninkai.  
\v 12 Yugha hoodul'eh, 'en whusahandel. Hiyust'e hiyilhchoot 'ink'ez whuyihiyalhti. 'Et hukw'elh'az Sizi ts'un whehandel 'ink'ez nduhídani. 
\s1 5,000 dune Sizi híte'alh, 'i hubugha iní'ai 
\p  
\v 13 'Et Sizi whulh uduzts'ai hoh buch'a nanja 'ink'ez ts'i be inya 'ink'ez nts'e dune nuchasyah ts'ih whuz whénki. 'Et whunts'ih lhanah dune t'ehonanzin ibulh nts'e whénki ts'ih, whuz lhelhdun keyah whut'en whehínandel.  
\v 14 'Et Sizi ts'i bé hainya hoh dune soo ts'ah'un hulai 'aw 'uzdooni ghaít'ah, 'en bunilh'en. 'Et 'ahoh hubugha té'nanzin 'ink'ez nduda chah ts'iyawh soo na'binla.  
\v 15 K'an 'aw 'et hulhgha 'uhoont'ah 'et huwa yugha hoodul'eh, 'en highu nindel 'ink'ez 'uhiyúlhni, “Njan dune nuchasyah 'uhoont'ah. 'Aw 'et ye 'un whezulh. Ndunnah ts'iyawh 'uts'un keyah ts'ih naoobélh'alh, 'et whuz hite'alh, 'i hiyoket.”  
\v 16 'Et whunts'ih Sizi ndo búlhni, “'Aw nahutoodelh huba cha'hóot'ah. Nuhwhenich'oh hubugha ná'nuht'aih.”  
\v 17 'Et 'uhiyúlhni, “'Aw hoonliyaz chats'it'ih. Lhes skwunlai 'ink'ez lhook nankoh, 'aw 'i zeh ts'it'i.”  
\v 18 'Et ndo búlhni, “De' sugháh ninahle!”  
\v 19 'Et ndunnah 'ilhunahuwésdel, 'en ts'iyawh tl'oyaz k'ut natl'ahudoolts'ilh hubúlhni. 'Et ndi skwunlai lhes 'ink'ez nankoh lhook chah, 'i hitl'ahíyanla, nduk yetá'en hoh suchanailya ni tenadedli. Lhes taidalhkut 'ink'ez lhook 'i chah ndíyinla 'ink'ez yugha hoodul'eh butl'ayánla, 'ilhohuwezdel hubugha híyoo'alh ka.  
\v 20 'Et ts'iyawh 'uhan'al 'ink'ez 'uhunesdai. Ndai ts'ih tezkat 'i ts'iyawh 'ilhunahiwezdla hoh lanezi 'o 'at nankoh (12) ts'its'ai dezbun.  
\v 21 'Et ndunnah dune, 'en 'ankw'us 5000 'uha'al. 'Et 'uskeh 'ink'ez ts'ekoo 'en chah 'uha'al. 
\s1 Sizi too k'ut nuya 
\p  
\v 22 'Aw 'et Sizi yugha hoodul'eh ts'i tuz whenaóobalh'a hoh, “Sutsuh nyan ahkelh,” hubúlhni. 'Ink'ez 'ilhunahuwésdel, 'en chah dukeyah ts'ih whenaóobalh'a.  
\v 23 'Aw 'et ndunnah ts'iyawh whenaóobalh'a hoh dich'oh ndoh dzulh k'uz whinya tenadutedli ka. Dich'oh únli hoh bé nadalhghel.  
\v 24 'Aw 'et ts'i bun k'ut taniz hoh wheghah tatsi cho be nilhts'i be hubududezts'i. 'I be ts'i hoh nudúlduz.  
\v 25 'Aw 'et bundada haootélh'en hoh Sizi too k'ut buts'u tezya.  
\v 26 'Et khunyaz yugha hoodul'eh hitelh'en hoh whehunelhújoot, “Dune tsen 'ut'en!” hutni ibulh tsoya whehúnilhtuk.  
\v 27 'Et 'ahoh Sizi hubulh yatelhtuk, “Nuhdzi ulhtus úlhtsi! Si 'ust'en! Whenulhujut ílah!”  
\v 28 Peter ndez na'a yoodulhkut, “SMoodihti 'alha nyun 'int'en t'eh, too k'ut nts'u toosya stl'ahóo'aih.”  
\v 29 'Et 'ahoh ndi yúlhni, “'Anih!” 'Aw 'et Peter ts'i be hainya 'ink'ez Sizi too k'ut yuts'u teyalh ka.  
\v 30 'Et nyo whunilh'en hoh nilhtsi tube ulhtus 'ink'ez whenelhújoot 'ink'ez yuk tezdlat hoh, “SMoodihti, sula 'ineh!” yulhni.  
\v 31 'Et 'ahoh Sizi yula dughélchoot hoh ndi yulhni, “'Aw soo 'ultsuk, 'i be 'alha' hoont'ah, 'i chaint'ih. 'Et dahoont'ah huwa mba nawh 'uhoont'ah?”  
\v 32 'Et ts'i be nahét'az hoh 'ahoh nilhts'i k'ah na'ja.  
\v 33 'Et ndunnah ts'i be hudelhts'i, ts'iyawh hibut nachánilya 'ink'ez 'uhiyulhni, “'Alha nyun Yak'usda buYe' 'unínt'ah!” 
\s1 Gennesaret whut'en nduda Sizi soo na'bulh'en 
\p  
\v 34 'Aw 'et nyan Gennesaret ts'ih yahuzki hoh,  
\v 35 'et keyah whut'en Sizi hitelh'en ibulh, nahiyoolhúts'it hoh lhtunahunek hust'ai. 'Ink'ez ts'iyawh nduda, 'en hits'ún lhgha hobodinla.  
\v 36 Hits'utédudlih, “Ndai nyunaih naints'uz, 'i 'ants'ih yus ts'ih but'áts'ughoonalh,” hiyulhni. Ts'iyawh ndan hit'aghéznai, 'en ts'iyawh ts'ah'un na'a soo ná'huja. 
\c 15  
\s1 Ndai nedzi be yats'ulhtuk, 'i bugha ts'intsi' 'ulhih 
\p  
\v 1 'Aw 'et Jerusalem keyah whuts'un ndunnah Moses be' dustl'us 'uk'ununa'úsduguz 'ink'ez Pharisee, 'en chah ts'iyawh Sizi highu nindel 'ink'ez 'uhutni,  
\v 2 “'Et di ka ngha hoodul'eh, netsuh whudelhdzulh 'uda ne'whust'en hukw'u na'a 'aw hukw'unucha'hust'en? Whunilh'en, ndunnah ngha hoodul'eh, 'aw lanacha'hulhúde 'uhute'alh whutsuh!”  
\v 3 'Et ndo búlhni, “'Et di ka nuhwhenich'oh nuhk'ah ts'ih huwa Yak'usda bughunek buk'unucha'zaht'en?  
\v 4 Whunulh'en, nuhwheni nts'e na'a ndaht'en! Yak'usda bughunek nuhtl'aida'ai hoh njan ndutni, ‘Nyu'abá 'ink'ez nyu'ama bulh hubudóolhti.’ 'Et doo chah 'udun 'et njan ndutni, ‘Ndan be'ama 'ink'ez be'abá bulh dzuh ts'ih bughu yatelhtuk, 'en daootsah huba' hoont'ah.’  
\v 5 'Et whunts'ih nuhwheni ndez na'a 'udahni, ‘Ndan be'abá k'us be'ama njan ndo búlhni, ndai 'ust'i, 'i be da nuhla 'oost'en wule, 'et whunts'ih 'i ts'iyawh Yak'usda bugha iníla.’  
\v 6 'Et whuz na'a nuhwhe'ut'en k'ah be 'aw be'ama 'ink'ez be'abá bulh chabudílhti. 'I be Yak'usda bughunek nuhtl'aida'ai, 'i 'aw hoonliyaz chailah sulhtsi!  
\v 7 Nuhwheni duba náhdzoo ahli! Ndun nus whunilh'en Isaiah, 'en 'uda ho'en 'ink'ez ts'ah'un na'a 'utni nuhwheni nuhwhugha. Njan 'et njan ndutni, 
\q1  
\v 8 ‘Ndunnah dune bughunek be buzek be sudélhti. 
\q2 'Et whunts'ih budzi sughun nilhdza 'int'ah. 
\q1  
\v 9 Ndunnah doo ka 'ants'i 'et suts'un teni 'uhunoolhzin. 
\q2 'Ink'ez ndet dune bube 'ut'en k'ah, 
\q2 'i Yak'usda bughunek netl'aida'ai, 'i k'una'a 'uyoon hubuhoodoolh'eh ka' 'uhut'en.’ ” 
\p  
\v 10 'Et Sizi 'ilhunahuwésdel ndo búlhni, “'Anih! Ndez áhdulh!” 'Et ndo búlhni, “Soo zélhts'ai 'ink'ez soo cho nt'eoonahzeh!  
\v 11 Ndai dune buzai yúkat, 'i 'aw 'et ílah hintsi' hulhih. 'Et whunts'ih ndai khunek 'aw chaizooh, 'i dune ye yalhtuk, 'i be dune hintsi' 'ulhih.”  
\v 12 'Et yugha hoodul'eh highun nindel hoh 'uhiyúlhni, “T'eoonínzun ih ndunnah Pharisee nyudánts'o daja dini, 'et nduhóolcho huba dzuh 'údenja?”  
\v 13 'Et Sizi ndo búlhni, “'ABá yak'uz usda, ndai 'aw whuyuchaínilel, 'i bughih tubulh hahítelhch'ulh.  
\v 14 Whute! Ndunnah 'aw buts'áhachaoozah'aih! 'En moodih chawhés'en li'hint'ah. 'Et ndez na'a njan nduhoont'ah, 'ilhunuh chawhés'en 'ink'ez 'ilhunuh chawhés'en ghunli t'eh, nahúlt'ah tsa k'et hutelts'ulh.”  
\v 15 'Et Peter yoodulhkut, “Ndi be nawhutnuk 'i be whuts'odul'eh, 'i nts'e na'a daja ni, 'et ts'iyawh whenénilhtun.”  
\v 16 'Et ndi yúlhni, “'Aw ih nuhwheni tachaoodulhts'it hoh ih dahni?  
\v 17 'Awhuz ih ts'ah'un nechaóozah'ak? Dune ndai buzai yúkat, 'i ts'iyawh bubut zeh be yukat. 'Ink'ez buyust'e ts'ih hanádukat.  
\v 18 'Et ndai dune khunek be yailhtuk, 'i budzi ts'ih hayúkat 'i 'int'ah, 'ink'ez 'i dune dilhtsi'.  
\v 19 Soo cho whunulh'en, ndi 'et ndunt'ah, 'i dune budzi tuz hayúkat, be ne-eni untsi', 'i dune hutuzelhghelh, 'uyoon dune bu'at k'us 'uyoon ts'eke buki bulh tinta' ant'en, 'ink'ez 'aw lhughudelhúts'i whunts'ih whuz na'a zeh ne'hut'en. 'Uhudunut'ih, 'uyoon ba huwhuts'it, 'ink'ez Yak'usda ch'a yahulhtuk chah.  
\v 20 'Et njan 'et ndúhoont'ah, nduhoolhchoh dune hintsi' hulhih. 'Et 'aw lanacha'zulhude hoh 'ah'alh, 'aw 'et huwa ilah hintsi' 'ulhih.” 
\s1 Ndun ts'eke, 'udun yun k'ut whut'en, 'en buba 'alha' hoont'ah hooncha ho' hoont'ah 
\p  
\v 21 'Aw 'et Sizi njan usda whuch'a nanja hoh Tyre keyah 'ink'ez Sidon keyah wheghah nánja.  
\v 22 'Et whuts'un 'ilhunuh ts'eke, 'en Canaan whut'en 'int'ah, 'en yughu ninya. Tso bulh yalhtuk ho 'uyulhni, “SMoodihti sugha te'ninzeh, t'enyunúszun David buts'u hainzut 'unint'ah! Sutse', 'en ntsi' nududeh, 'i buyídinda!”  
\v 23 'Et 'aw daja chaidínil. 'Et yugha hoodul'eh highu nindel 'ink'ez 'uhiyúlhni, “'Un nailh'alh, 'et tso bulh yalhtuk 'ustl'e' 'udóoneh sih.”  
\v 24 'Et Sizi, 'en ndun ts'eke 'uyúlhni, “Ndunnah Israel bukoo whut'i, 'en 'ants'ih sheep tinta nílh'az, 'i li'int'ah, 'en zeh buts'un whests'alh'a.”  
\v 25 Ndun ts'eke 'en yughu ninya hoh yubut nachaneti 'ink'ez, “SMoodihti, sula 'ineh!” yulhni.  
\v 26 'Et Sizi 'uyúlhni, “'Uskehkah lhes híyu'alh, 'i lhiyazkah hubugha ts'iya'aih t'eh 'aw chahóozooh.”  
\v 27 'Et ts'eke ndi yúlhni, “SMoodihti 'alha' dini. 'Et whunts'ih ndai moodihti bukw'uzdai k'ut tukat, 'i lhiyazkah hiyeldel.”  
\v 28 'Et Sizi ndi yúlhni, “O ts'eke ndi mba be 'alha' hoont'ah, 'et hooncha ho' hoont'ah. 'Et huwa hukwa' ninzun k'una'a 'uhoneh.” 'Et soo ndoh wheghah whezulh, buts'e' soo na'uja. 
\s1 Lhanah hunduda, 'en Sizi usda highu nindel 'ink'ez ts'iyawh soo ná'balh'en 
\p  
\v 29 'Aw 'et Sizi bughu natesja Galilee bun ghah lhunásja hoh, ndoh dzulh k'uz whenya, 'et natl'adeda.  
\v 30 'Et khunyaz lhanah dune, 'en highu nindel. Ndunnah nuchahúsdel, chawhés'en, yachahulhtuk, buyust'e hubodi'ai, 'ink'ez 'uyoon chah, 'en ts'iyawh hits'un hubuninla. Hibut nebaninla 'ink'ez ts'iyawh soo ná'hubínla.  
\v 31 Yachahulhtuk chah yawhehunilhtuk, buyust'e hubodi'ai, 'en chah soo na'huja. Nucháhsdel chah nahúdelh nahusdli, chahuwhés'en chah honilh'en nahusdli. Ts'iyannah bunalh'en hoh tube huba hooncha 'ink'ez Israel budune, 'en buYak'usda 'en 'o nus hidálhti. 
\s1 Sizi 4,000 dune ghá' ní'ai 
\p  
\v 32 Sizi yugha hoodul'eh, 'en 'anih hubúlhni 'ink'ez ndo búlhni, “Ts'iyawh ndunnah dune hubugha té'nuszun. Tat dzin whuts'un njan suzih hudelhts'i 'ink'ez 'aw huya'alh, 'i chahít'ih. 'Et 'aw cha'hus'al hoh bukeyah ts'ih nabutoolh'a ghaít'ah. 'Et ndúbusdla t'eh, nahedulh hoh sih bukaootoozit.”  
\v 33 Yugha hoodul'eh hiyulhni, “Njan keyah 'aw dune hoolah 'uhoont'ah. Nts'ez de simba soo 'últsuk, 'i tet'alh, 'i nats'óolelh dune lhe'huneltsuk lah?”  
\v 34 'Et Sizi ndo búlhni, “Daltsuk lhes sut'e aht'i?” ‘Skwunlai 'o at nankoh 'i lhes sut'e 'ink'ez lhook nsolyaz bulh,” hiyulhni.  
\v 35 'Et 'ilhuhowezdel, 'en natl'adulhúts'ih hubúlhni.  
\v 36 'Et ndi lhes skwunlai 'o at nankoh (7) lhook bulh yílhchoot 'ink'ez suchanailya ni hoh tenadidli. Taidalhkut 'ink'ez yugha hoodul'eh butl'ayánkai. 'I ts'iyawh natl'ahudelts'i, 'en butahíninik.  
\v 37 Ts'iyawh na'het'al 'ink'ez 'uhunesdai. 'Et yugha hoodul'eh skwunlai 'o at nankoh k'its'ai dezbun 'i highá' wez'al, 'i 'ilhunahiwezdla.  
\v 38 4,000 dune bat'en 'uha'al. 'Uskiyaz 'ink'ez ts'ekoo 'en chah 'uha'al.  
\v 39 'Aw 'et Sizi 'ilhunahuwésdel bukeyah ts'ih whuz whenaóobalh'a, 'et ts'i be naja 'ink'ez yun Magdala huwhutni ts'ih whuz whehánki. 
\c 16  
\s1 Pharisee 'ink'ez Sadducee chah, 'en huwa 'ét'en huba' hooleh hukwa hiyoodulhkut 
\p  
\v 1 'Aw 'et ndunnah Pharisee 'ink'ez Sadducee chah, 'en highu nindel 'ink'ez hiyóolhdzih hoh hiyoodulhkut, “'Aw ih yak'uz whuts'un hooncha tune' whut'en, whunénolhtun ghaít'ah?”  
\v 2 'Et ndo búlhni, “'Et hulhgha ts'ih nduk whunulh'en. 'Et whudulk'un t'eh, 'et dzin hoonzoo tele dahni.  
\v 3 'Et bundada kw'us bulh dulk'un suli whunulh'en t'eh, 'aw 'et zeh whudutetsi' dahni. Nuhwheni duba nahdzoo ahli! 'Et nduk dawhut'en, 'et t'eoonáhzun. 'Et whunts'ih ndoh whugha whudezulh dawhut'en, 'et ndet 'uwhulhni, 'aw t'eoonuzáhzun!  
\v 4 Njan k'an ndoh whudezulh, 'en lubeshi ts'un ne'hut'en 'uhint'ah. 'Ink'ez 'ahoolhyez dune ts'eke bulh tinta' hutet'ilh, 'et zeh whuts'un hunint'uk. 'Ink'ez hooncha huwa 'ét'en whuntelh'ilh hukwa' nahzun. 'Et whunts'ih 'aw hooh'en nuhghu hólts'it ghaít'ah. 'Et nts'e na'a Jonah bulh dáhooja inle, 'et zeh whuteh'ilh ho' hoont'ah!” hubúlhni, 'ink'ez bughu whenája. 
\s1 Pharisee 'ink'ez Herod bules untuldoh, 'i ch'a hughohle hubúlhni 
\p  
\v 5 'Aw 'et nyan yahuzki hoh yugha hoodul'eh lhes nahodelhúnah.  
\v 6 'Et Sizi ndo búlhni, “'Ahoolhyez wheni khahdli ndunnah Pharisee 'ink'ez Sadducee chah, 'en bules untuldoh, 'i ch'a.”  
\v 7 'Et 'ahoh lhulh yawhehunilhtuk, “'Et 'aw lhes chats'ít'ih 'et huwa 'utni.”  
\v 8 'Et Sizi t'eoonanzin, 'et ndo búlhni, “Nuhwheni be 'alha' hoont'ah, 'i unsol! 'Et huwa 'udahni. 'Aw lhes whusachah'al, 'et huwa ih 'et howu yalhtuk?  
\v 9 'Awhuz ih 'aw ts'ah'un t'eoonuzahzun? 'Aw whunachazulhunik hoh ih skwulai lhes 'i be 5,000 hubugha náh'ai, 'ink'ez daltsuk k'its'ai ts'utezkat, 'i 'ilhunawehla?  
\v 10 'Et doo chah skwunlai 'o at nankoh lhes 'i be 4,000 hubugha ináh'ai, 'et daneltsuk k'its'ai ts'uhtézkat, 'i 'ilhunawehla?  
\v 11 'Et nts'e na'a aht'ah t'eoonuzahzun, 'aw lhes hubugha nohwhulh yachasulhtuk? 'Uda ndun whudúsni, ndunnah Pharisee 'ink'ez Sadducee chah, 'en bules untuldoh, 'i bughohle, 'i bughi yálhtuk ho' dusni.”  
\v 12 'Et 'ahoh t'ehoninzun ndunnah Pharisee 'ink'ez Sadducee chah, dune huhodulh'eh, 'et whuch'a buch'a huwahli, 'et 'uwhulhni. Ndi lhes bulh untuldoh, 'i ch'a huwahli ni ilah hoh 'utni. 
\s1 Sizi 'en Christ 'int'ah 'et Peter howu yalhtuk 
\p  
\v 13 'Et Sizi Caesarea Philippi buyun k'uz whinya hoh yugha hoodul'eh, 'en huboodulhkut, “Si yinkak dune ye' 'ust'ah. 'Et whunts'ih n'awh dune, ndan hoh 'ust'ah hutni?”  
\v 14 'Et 'uhiyúlhni, “Bulunah, 'en nyun John dune too be 'ulh'en 'int'ah hutni. 'Et bulunah chah, nyun Elijah 'int'ah hutni. 'Et 'onghunnah chah, nyun Jeremiah 'int'ah hutni. 'Ink'ez bulunah nyun nus whunilh'en 'ilhunuh 'int'ah hutni.”  
\v 15 'Et ndo búlhni, “Nuhwheni do, ndan 'ust'ah dahni?”  
\v 16 'Et Simon Peter yatelhtuk hoh ndi yúlhni, “Nyun ndun Christ, Yak'usda khuna, 'en buYe' 'unint'ah.”  
\v 17 'Et Sizi ndi yúlhni, “Simon Jonah buye', degha nus hoonzoo nghá whults'ut! Ndet sudini, 'et 'aw ndi yun k'ut dune, 'en ilah nyunalhts'et hahó'ai. Se'aBá yak'uz usda, 'en nyunalhts'et haho'ai.  
\v 18 'Ink'ez nyun Peter 'int'ah. 'Et ndi tse 'i k'ut suluglez neootes'alh. Njan ndun kwuncho ulhtus, 'i yuh ts'ih haindel, 'en whunts'ih 'aw whuch'a' hoolhdeh ghaít'ah.  
\v 19 Nts'e yak'uz hubudayi cho usda, whuz be da'dutut'aih, 'i ntl'ates'alh. 'Et ndi yun k'ut ndai whedinguz, 'i 'et 'uda yak'uz chah whuz na'a zeh whedint'uk. 'Et ndai ndi yun k'ut k'unada'uk, 'i 'et yak'uz chah 'uda whuz na'a zeh k'una'tet'uk.”  
\v 20 'Et yugha hoodul'eh khunekti be ndo búlhni, “Khun teh 'uyoon dóohni gunih, si Sizi ndun Christ, 'en 'ust'ah.” 
\s1 Dzuh nutezut 'ink'ez datétsah, 'et Sizi huwu yalhtuk 
\p  
\v 21 'Et wheghah whezulh whuts'un Sizi yugha hoodul'eh, 'en wheóobunulhtun nus daootenilh 'et. Nts'e na'a Jerusalem ts'ih teyalh. 'Et keyah ndunnah dune netsuh whudelhdzulh, 'ink'ez náwhulnuk bumoodih, 'ink'ez Moses be' dustl'us 'uk'ununa'úsduguz chah, 'en bube lhat hoh dzuh nuhítelhdzut, 'ink'ez hituzelhghelh. 'Et whulh tat dzin, 'et dinadutédalh.  
\v 22 'Et Peter, 'en Sizi yílhchoot, 'udun neínilhti 'ink'ez hukwa' yudáni, “SMoodihti nyun Yak'usda ngha te'untezeh! 'Aw nyulh 'et ndúhoneh ghaít'ah!”  
\v 23 Peter yuts'un nalhú'a 'ink'ez ndi yúlhni, “Satan sut'ak ninínyih! Nyun yooya suzilhts'i! Yak'usda nts'e na'a dat'en, 'et 'aw howu nuni chanuzinzut. Ndi yun k'ut dune nts'oh tuné'hut'en, 'et hukw'una'a zeh nuni ninzut!” 
\s1 Ndan Sizi Gri yuntooya hukwa' ninzun, 'en ye dulhdulalhgus yóolhchoot 'ink'ez yuntooya 
\p  
\v 24 'Et Sizi yugha hoodul'eh ndo búlhni, “Ndan dune se'ut'en k'ah oot'en ka sunteyalh hukwa' ninzun t'eh, ndi yun k'ut dats'ínt'ah, 'et ts'iyawh whula dootnih, 'ink'ez dulhdulalhgus yóolhchoot 'ink'ez suntooya.  
\v 25 'Et huwa ndan ye khuna hotelhyih hukwa' ninzun t'eh, 'en tinta hóte'alh. 'Et whunts'ih ndan ye khuna si sugha tinta ooní'ai t'eh, 'en ye khuna 'i nahíte'alh.  
\v 26 'Et huwa dune ndi yun 'i ndulhcho bube'ildzun yúzdli t'eh, 'ink'ez duzul 'i tinta iní'ai t'eh, ndet buba whutézoo? 'Ink'ez dich'oh duzul nayitélcholh hukwa' ninzun t'eh, di k'elha simba duzul nahíyoket?  
\v 27 'Et huwa yinkak dune ye' whusateyalh, ndai be'aBá ye dezti, 'i 'ink'ez bulizas, 'en hubulh, 'et whusainya t'eh, nts'e na'a ts'iyannah dahét'en, whuz na'a 'ilhunah hoh buba k'elha whutele.  
\v 28 Soo ts'ah'un na'a ndun whudusni, bulunah njan nuhudelhúya, 'en dahutetsah whutsuh 'et whuts'un yinkak dune ye' nts'e na'a hubudayi cho tele, 'en whuz de úyalh huyuntelh'ilh.” 
\c 17  
\s1 Sizi 'uts'un onent'en suli 
\p  
\v 1 'Aw 'et whulh lhk'utat dzin inle hoh Sizi 'en Peter, James, 'ink'ez dulhutsin John chah, 'en ndoh dzulh k'uz dulh hobélya.  
\v 2 Khunyaz hubunalh 'uts'un oonent'en suli. Bunen 'ants'ih sa k'una'a buts'u ha'ánduz, 'ink'ez bunaih 'i chah khunyaz lhiyul suli, 'ink'ez 'i chah buts'u ha 'ánduz.  
\v 3 'Et khunyaz Moses 'ink'ez Elijah hubunalh hube whédilts'ai 'ink'ez Sizi hubulh yawhénilhtuk.  
\v 4 Peter, 'en Sizi 'uyulhni, “NeMoodihti njan uzdelhts'i hoonzoo. Hukwa' ninzun t'eh, tat whut'ah 'uts'otelilh. 'Ilhunuh nyun mba, 'et 'ilhunuh Moses ba, 'ilhunuh chah Elijah ba.”  
\v 5 Peter yalhtuk hoh khunyaz kw'us be tídet'en hoh buk'eyínde. Kw'us tah ts'ih khunyaz 'uwhutni, “Ndun suYe' degha nus buk'esi' 'int'ah. 'En bulh hóonust'i. 'En zeh 'oozélhts'ai!”  
\v 6 Yugha hoodul'eh hídants'o hoh hibut nacháneldel, 'ink'ez tube whehunelhújoot.  
\v 7 Sizi bughu ninya 'ink'ez but'agheznai hoh ndo búlhni, “Dinadahdelh 'ink'ez whenlhújut ilah!”  
\v 8 'Et nduk nahítat'en, 'aw 'uyoon hoolah. Sizi dich'oh zeh hiya'en.  
\v 9 Ndet dzulh k'ut whenahedidel, 'et yuk nahidulh, Sizi khunek ulhtus, 'i be hubulh yalhtuk 'et ndo búlhni, “Yinkak dune ye' yaidla tah dinadutédalh whuts'un ndet whunelh'en, 'et khun 'uyoon ndudóohtni gunih!”  
\v 10 'Et yugha hoodul'eh, 'en hiyoodulhkut, “Ndunnah Moses be' dustl'us 'uk'ununa'úsduguz, 'et di ka' hutni, Elijah 'en choo whusateyalh huba' hoont'ah hutni?”  
\v 11 'Et Sizi ndo búlhni, “'Et 'alha Elijah 'en choo whusateyalh 'ink'ez ndai hoonliyaz ts'iyawh lhanaidutedlilh.  
\v 12 'Et whunts'ih ndun whudusni, Elijah 'uda whusainya ho' 'int'ah. 'Ink'ez 'en 'aw t'ehinízun. 'Et hukwa' huninzun k'una'a 'uhiyinla. 'Et whuz na'a zeh 'en hubula be yinkak dune ye' dzuh nutezut.”  
\v 13 'Et yugha hoodul'eh, 'en ts'iyawh John dune too be 'ulh'en, 'en yughu yalhtuk t'ehonanzin. 
\s1 'Uski, 'en ntsi' nudúdeh, 'i buyudínda, 'en Sizi soo ná'yinla 
\p  
\v 14 'Aw 'et 'ilhohuwezdel 'en butanahundel hoh 'ilhunuh dune yughu ninya 'ink'ez yubut dugwútsi be nenínya. 'Ink'ez 'utni,  
\v 15 “SMoodihti suye' 'en bugha te'nonzeh! Bukaootuzuk 'ink'ez tube dzuh nuzut. Lhat tsudúlts'uk 'ink'ez talts'uk chah 'ut'i.  
\v 16 'Et ngha hoodul'eh bughi nílhti 'et whunts'ih 'aw soo na'hiyooleh ghaít'ah.”  
\v 17 'Et Sizi ndo búlhni, “Nuhwheni k'an ndoh whudezulh, nuhwheni 'aw be 'alha' hoont'ah, 'i chaht'ih, 'ink'ez tink'us zeh 'eht'ilh. 'Et dawhuldzah nuhwhutah tesdalh? 'Ink'ez dawhuldzah nuhwhuba 'et ndutest'ilh? De', nye' 'en sugha nínilhtih!”  
\v 18 'Et ntsi' nududeh, 'i buyudínda, Sizi 'en ts'un khunek ulhtus, 'i be hukwa' yudáni. 'Et whulh hulhgha zeh yuts'u hanája 'ink'ez ndun 'uski soo na'uja.  
\v 19 'Et Sizi yugha hoodul'eh, 'en dune hoolah ts'ih highu nindel hoh 'uhiyulhni, “'Et dahoont'ah huwa ndun 'uski, 'en ntsi' nududeh, 'i 'aw buts'u hanáts'inooyoot ghaít'ah?”  
\v 20 'Et Sizi ndo búlhni, “'Aw nuhwhuba 'alha' cha'hoot'ah 'et huwa 'aw 'oohleh ghaít'ah. 'Alha 'ún whudusni ndi 'anukat, 'i lhe'niltsol, 'i mustard hiyulhni, 'i k'una'a be nuhwhuba 'alha' hoont'ah, 'i 'et 'ulcho t'eh, 'et ndez 'una'a da 'udoohni. Ndi dzulh njan whuts'un, 'et nguz nailts'ut dahni t'eh, 'ahoh 'et ndutenilh. 'Et whuz na'a ts'iyaitsuk whuz na'a 'udahni t'eh, 'et ndutét'ilh.  
\v 21 'Et whunts'ih ndi ntsi' nududeh, 'i netenadudli, 'i 'ink'ez sahá'delya, 'et t'eh zeh dune buts'u hanáts'iyunteyolh ho' hoont'ah.” 
\s1 Sizi datetsah, 'et doo chah huwu yalhtuk 
\p  
\v 22 'Aw 'et Sizi 'ink'ez yugha hoodul'eh, 'en Galilee yun k'ut hudelhts'i 'et ndo búlhni, “'Aw 'et nilhdukw yinkak dune ye', 'en 'uyoon dune tl'ahítelhtelh.  
\v 23 Hituzelhghelh 'ink'ez whulh tat dzin inle t'eh, dinadutédalh.” 'Et hodánts'o hoh ts'iyawh tube tso huzdli. 
\s1 Sizi 'en chah luglez whucho whuzooneya yuk'elha hoolh'i 
\p  
\v 24 'Aw 'et keyah Capernaum whuz hunindel hoh 'ilhunuh sooneya 'ilhunanowes'aih, 'en Peter yughu ninya 'ink'ez yoodulhkut, “Nuhwheni whunohodulh'eh 'en chah ilah luglez whucho whuzooneya yuk'elha hoolh'i?”  
\v 25 'Et, “A,” ni. 'Et Peter koo danínya. 'Et Sizi 'ahoh yulh yatélhtuk 'ink'ez ndi yulhni, “Simon, daja ninzun? Ndi ndai sooneya dune buba k'elha yutele, 'i ndi yun k'ut hubudayi cho 'en ndi sooneya 'ilhunanowes'aih? Dich'oh buzkehkah tulih k'us n'awh whut'en tulih?”  
\v 26 'Et Peter ndi yulhni, “'Aw n'awh whut'en, 'aw 'en zeh.” Sizi ndi yúlhni, “'Et 'alha' dini. Hubudayi cho dich'oh bubuzkehkah 'en 'aw huba k'elha hole ghaít'ah.  
\v 27 'Et whunts'ih ndunnah Capernaum whut'en, 'en nelh hánilch'e hukw'u na'a hubuts'oolh'en ghaít'ah. 'Et huwa ndi luglez whucho whuzooneya, 'i huba k'elha ts'iyoolhtsilh. 'Aw 'et, bun k'uz ts'inyalh 'ink'ez oolhjas. Soo 'udechoo lhook silhjus, 'i buzek lhch'a 'uhoonleh. 'Et sooneya naité'alh. 'I ilhchoot 'ink'ez si 'ink'ez nyun bulh neba bugha íyo'alh.” 
\c 18  
\s1 Yak'uz hubudayi cho dilhts'i ndan simba degha nus dezti? 
\p  
\v 1 'Et hoh da zeh Sizi yugha hoodul'eh, 'en highu nindel 'ink'ez hiyoodulhkut, “Yak'uz hubudayi cho delhts'i ndan simba k'us dezti?”  
\v 2 'Et Sizi ndun 'uskiyaz 'anih yulhni, 'ink'ez hubutah neínilhti.  
\v 3 'Ink'ez ndo búlhni, “'Et soo ts'ah'un na'a 'un whudúsni, 'aw 'uts'un na'a nahcha'ahnil, 'ink'ez 'uskehyaz k'ah ts'ih sahli t'eh, 'aw 'et zeh huwa, nts'e yak'uz hubudayi cho unli whuz toohdelh ghait'ah.  
\v 4 'Et huwa ndun 'uskiyaz, ndan yuk'ah ts'ih 'int'ah, whuz na'a dich'oh te'dudil'en, 'et ndunt'ah, 'en nts'e yak'uz k'une' whul'en, 'en hubutah k'us hidelhti tele ho' 'int'ah.  
\v 5 'Ink'ez ndun dune 'uskiyaz, ndan yuk'ah ts'ih 'int'ah huhóont'i, 'i bulh highu nuseya, si chah whuz na'a zeh 'usuhinla.” 
\s1 Dune 'en bugha 'uyoon lubeshi yutélhcholh t'eh, ndun dune nduja, 'et dahóolts'i' 'et whute'ilh 
\p  
\v 6 “'Et ndunnah 'uskehyaz huba 'alha' 'ust'ah, 'uskehyaz hoontsi' ts'ih hubonilht'uk, ndun dune 'et ndúja, 'en tse cho buts'ilchun yehudinguz 'ink'ez k'us takhulh 'et tábuhano t'eh, 'et 'o nus whútezoo.  
\v 7 Ndi yun k'ut hudelhts'i, 'en ndunnah hukwaya hoonli tune' 'uhut'en, 'en dawhultsi', 'et buts'u whélts'ulh ho' hint'ah. 'Alha njan hukwaya hoonli tune' hutet'en ho' hoont'ah. 'Et whunts'ih ndan bugha 'et 'úhooja, 'en dawhultsi', 'et hote'ilh ho' hoont'ah!  
\v 8 'Et nla k'us nke 'i be hukwaya hoonli tune' 'ínt'en t'eh, k'unint'as 'ink'ez 'un tilh'is! 'Et dzuh ninya k'us nyust'e bodin'ai, 'et whuz na'a 'ilhuz be ts'ukhuna, 'i nghalts'ut t'eh, 'et whuz na'a degha nus mba whútezoo. 'Et whunts'ih nke 'anelht'et 'ink'ez nla 'anelht'et chah bulh 'ínt'ah hoh kwun nachanusne, 'i tanyaníno t'eh, degha nus mba whutétsi'.  
\v 9 'Ink'ez nyuna be hukwaya hoonli tune' whut'en whunilh'en t'eh, nyuna hanó'alh 'ink'ez 'un ntolh'is! 'Et nyuna 'ilho bulh zeh, 'et whuz na'a 'ilhuz be ts'ukhuna, 'i ngha nínzut t'eh, degha nus mba whútezoo. 'Et whunts'ih nyuna 'anelht'et bulh kwun nachanusne, 'i tanyaníno t'eh, degha nus mba whutétsi'. 
\s1 Ndunnah tinta huninkat, 'en Sizi hubutelhyih ka, 'et huba whusainya 
\p  
\v 10 “'Et ndunnah 'uskehka khun buka cha'nuzoohzin gunih! 'Alha lizas yak'uz hudelhts'i, 'en bughu hinli 'ink'ez se'aBá yak'uz usda, bulizas 'en 'ahoolhyez hinalh ne'ut'en.  
\v 11 'Et huwa ndunnah tinta huninkat, 'en yinkak dune ye' hubutelhyih ka, 'et huba whusainya.  
\v 12 Nts'e na'a daja nahzun? 'Et dune 'en lanezi lanezi (100) sheep 'ut'i hoh 'en hubutah 'ilhunuh tinta nínya 'et bulah 'et nébuninla 'ink'ez ndai lhuk'i tinta nínya, 'en dzulh k'uz yukawhenántai.  
\v 13 'Et nayilhti t'eh, ts'ah'un na'a 'un whudusni, ndunnah bulah 'et nébuninla, 'en bugha whunelhnik. 'Et whunts'ih ndai lhuk'i tinta nínya, nayilhti t'eh, 'en bugha dahoolcho 'i be simba 'o nus whuntélhnik!  
\v 14 'Et whuz na'a zeh ndunnah 'uskehkah 'et 'ilhunuh whunts'ih kwuncho yuh ts'ih teyalh t'eh, nuhwhe'aBá yak'uz usda, 'en 'aw hukwa cha'nizun. 
\s1 Nyulhutsin lubeshi be dulya 'uja t'eh, datánlilh? 
\p  
\v 15 “'Et nyulhutsin lubeshi be nch'ani t'eh, 'et buzih nininya 'ink'ez di ka sch'adini, 'et dóni. 'Et nyun 'ink'ez nyulhutsin bulh nuhwhenich'oh lhanaóodoohle. 'Et nghunek yílhchoot t'eh, nyulhutsin whuch'a nanilde ho' hoont'ah.  
\v 16 'Et 'aw chanyoozílhts'ai t'eh, 'ilhunuh k'us nanah teh ilhchoot 'ink'ez 'et bukoo ts'ih natoohdelh. Nanah k'us tanah teh mba lhgha 'úhudeja t'eh, 'et whuz na'a 'uhót'e. 'Et 'i be daja hutni, ts'iyai 'i khunek ts'ah'un na'a 'uhoneh.  
\v 17 'Et whunts'ih 'et chah 'aw chanhozílhts'ai t'eh, 'et Yak'usda ba 'ilhunahuwésdel, 'en chah budóohni. 'Et 'en chah 'aw chaboozílhts'ai t'eh, 'et ndan 'aw huba 'alha' cha'hoot'ah k'us ndan sooneya 'ilhunanowes'aih, 'et ndun lubeshi be nch'ani, 'et 'en buk'una'a noolh'en.  
\v 18 'Alha' dusni ho' dusni, nuhwheni ndai ndi yun k'ut whuladehtnik t'eh, 'et nduk yak'uz chah bulaoodutetnih. 'Et ndi yun k'ut ndai lhgha 'úhudeja t'eh, 'et ndoh yak'uz chah lhgha 'úwhutenilh.  
\v 19 Doo chah 'ún whudusni, ndai buka yoodutelhkut, 'i 'ink'ez nanah k'us tanah ndi yun k'ut lhgha nuhwhuba soo' hoont'ah t'eh, 'et se'aBá yak'uz usda, 'en nuhwhuba 'uwhutelilh.  
\v 20 'Et huwa nts'e soozi bugha nanah k'us tanah 'ilhunahuwésdel t'eh, 'et sih si chah nuhtah 'ust'ah ho' hoont'ah.” 
\s1 Lhba whunats'odoolnah 
\p  
\v 21 'Et Peter yughu ninya 'ink'ez yoodulhkut, “SMoodihti ndun sulhutsin 'en lubeshi be sch'a 'uja. Dawhultsuk whe lubeshi be sch'a 'utet'ilh 'ink'ez buba whunaoodutelhúnah? Skwunlai 'o 'at nankoh (7) tulih 'et 'uwhuneltsuk?”  
\v 22 'Et Sizi ndi yulhni, “'Aw skwunlai 'o 'at nankoh (7) 'i chaduzúsnih. 'Et skwunlai 'o 'at nankoh lanezi (70) k'us 'o 'un tulih 'et 'uwhuneltsuk dusni ho' dusni.  
\v 23 'Et yak'uz k'úne' whul'en, 'et ndez na'a njan duhoont'ah. Ilhunuh hubudayi cho unli da, 'et be 'ulhna, 'en daneltsuk be buts'ú whulh'ai, 'i ts'iyawh ye bubúlh lhanaoodutélilh, 'et hukwa' ninzun.  
\v 24 'Et ho' whunilh'en 'ilhunuh be 'ulhna dahinilhti. Ndai ye yuts'ú whulh'ai, 'i 10,000 sooneya dezti, 'i 'et 'uneltsuk.  
\v 25 Hoolah! Yuk'elha yoolhtsilh, 'i hoolah. 'Et ndun hubudayi cho bughunek be 'et ndi yulhni, 'et ndun dune, bu'at, bubuzkeh, 'ink'ez ndai yit'i, 'i chah, 'i ts'iyawh ye 'óket. 'Et t'eh soo suba k'elha whutelhtsilh.  
\v 26 'Et huwa ndun be 'ulhna yubut nacháneti 'ink'ez yuts'un tedudlih hoh ndi yúlhni, ‘Sumoodih k'at, suba ilh'i! Ts'iyawh mba k'elha whutelhsilh!’  
\v 27 Bumoodih tube yugha te'nanzin. 'Et ndai ye yuts'u whulh'ai, 'i ts'iyawh yuba whunaoodelhunah, 'ink'ez whenayalh'a.  
\v 28 'En 'ulhna zeh 'az whinya hoh doo chah 'ilhunuh dudulh 'ulhna, 'en nayilhti. 'En lanezi lanezi (100) sooneya ch'adíti, 'i 'et 'uneltsuk yuts'u whulh'ai. Yuzool ílhchoot hoh ndi yúlhni, ‘Daneltsuk ngunelh'ai, 'i suba buk'elha hoolhtsi!’  
\v 29 Ndun yubut dugwútsi be nininya 'ink'ez yuts'u tedudlih hoh ndi yúlhni, ‘K'at, suba ilh'i. Ts'iyawh mba k'elha whutelhsilh!’  
\v 30 'Et whunts'ih 'aw chayoozilhts'ai. 'Et whunts'i 'ayan'ai ndai yughi nelh'ai, 'i ts'iyawh yuba k'elha whutelhtsilh 'et whuts'un.  
\v 31 'Et 'onghoh 'ulhna, 'en ts'iyawh honalh'en 'et dahooja. 'Et ts'iyawh howu ni huzdli. 'Et huwa hubumoodih ts'un whehandel 'ink'ez ts'iyawh nduhidani.  
\v 32 'Et ndun 'et ndúja, 'en bumoodih 'anih yudani 'ink'ez 'et ndo búlhni, ‘Nyun 'ulhna k'us ntsi' zeh 'int'ah! Suts'un tedindlih ka 'et huwa ndai be sts'o zilh'ai, 'i ts'iyawh mba whunaoodelhúnah!  
\v 33 Nts'e na'a ngha te'nazin, 'et whuz na'a 'oneh mba' hoont'ah, nyulh 'ulhna ts'un!’ yulhni.  
\v 34 'Et bumoodih yulh hunilch'e. 'Et ndunnah dune dzuh nuhulhdeh, 'en butl'ayálhti. 'Et ndai yughi nelh'ai, 'i ts'iyawh yuba k'elha whutelhtsilh whuts'un.  
\v 35 'Et nuhwheni chah nuhwhulhutsinka tinta' hant'en, 'ink'ez nuhdzi ndulhcho, 'i be 'aw buba whunachaooduzulhúhnah t'eh, 'et sih se'aBá yak'uz usda, 'en chah whuz na'a zeh 'aw nuhwhuba whunaoodoolnah ghaít'ah.” 
\c 19  
\s1 Dune lhghu delhts'i lhch'á nahusdel, 'et huwa Sizi hubodulh'eh 
\p  
\v 1 'Aw 'et Sizi hubulh yalhtuk 'ustl'e' 'udeja hoh njan Galilee yun k'ut whuch'a nanja. 'Et Judea yun k'ut Jordan koh whuch'az whuz ninya.  
\v 2 Lhanah dune 'et whuz hahínandel. 'Et soo na'balh'en.  
\v 3 'Et ndunnah Pharisee, 'en chah highu nindel hiyootélhdzih ka. 'Et hiyoodulhkut, “'Et ndet huwa ne'atkah 'ants'ih hoh hubugha buch'a naztedalh t'eh, 'et Moses khunek netl'aida'ai, 'i buk'una'a ih 'uhoont'ah?”  
\v 4 Sizi ndo búlhni, “'Et ndi dustl'us k'ut 'uk'e'eduguz, 'i 'aw ih buk'eyáchasulhtuk? Njan 'et ndutni, 'udechoo ho' whewhudit'en da ndun dune inla, 'en dune 'ink'ez ts'eke bulh 'obínla da.  
\v 5 'Ink'ez 'et ndutni, ‘Njan huwa dune be'abá 'ink'ez be'ama bulh buch'a ooya huba' hoont'ah, 'ink'ez bu'at bulh lhulh zeh 'uhoot'e huba' hoont'ah. 'Et whuz na'a nahúlt'oh 'ilho hutele.’  
\v 6 'Et whuz na'a 'aw 'o 'un nanah chahilah, 'ilho zeh hinli suli. 'Et huwa ndun Yak'usda lhgha hubunilhti, 'aw dune lhch'a nabóolhtelh huba cha'hoot'ah.”  
\v 7 'Et hiyulhni, “'Et di ka Moses hoh da whuz na'a netl'ahó'ai 'ink'ez dustl'us chah neba inla inle hoh dune, 'en bu'at tl'ayóolhchoos 'ink'ez naitoolh'a.”  
\v 8 'Et ndo búlhni, “Nuhwhenich'oh nuhdzi dulhts'un, 'et huwa Moses nuh'at whuch'a naoohja nuhtl'ahó'ai. 'Et whunts'ih whe'whudit'en whuts'un, 'aw 'et duchahoot'ah.  
\v 9 'Et 'un whudúsni, dune bu'at 'en 'uyoon dune bulh tinta' 'ant'en t'eoonanzin t'eh, 'et sih zeh ndi dustl'us ndai ye 'ustl'e' itelilh, 'i bu'at tl'ayóolhchoos. 'En bu'at 'aw tinta cha'it'il t'eh 'et whunts'ih ndi dustl'us yutl'ayálhchooz, 'ink'ez 'uyoon ts'eke yughu nasda t'eh, 'et sih dune ts'eke bulh tinta' 'ant'en suli. 'Ink'ez ndun dune bu'at 'ustl'e' 'uyínla 'ink'ez 'uyoon dune yughu nasda t'eh, ndun dune 'en chah dune ts'eke bulh tinta' 'ant'en tele.”  
\v 10 'Et Sizi yugha hoodul'eh, 'en 'uhiyulhni, “'Et dune bu'at bulh whuz na'a 'uhutet'ilh t'eh, 'aw lhghu chahíkah t'eh, 'et 'o nus soo' hoont'ah.”  
\v 11 'Et ndo búlhni, “Ndi khunek, 'i 'aw ts'iyannah ba cha'it'ah. Ndan bughá whunt'ai, 'aw 'en zeh buba' hoont'ah.  
\v 12 'Et bulunah dune 'aw bughez hoolah hoh huwhuzdli. 'Et 'onghunnah 'et whuz na'a dune 'ubinla. 'Ink'ez nts'e yak'uz hubudayi cho, bulunah 'en ba whuz na'a soo whulh 'utet'ilh, 'en whuz na'a whulh 'úhoot'e.” 
\s1 Sizi 'uskehyaz bula be hubuk'edalnik 
\p  
\v 13 'Aw 'et 'uskehyaz highu bunínla. Khun teh buk'édolnih 'ink'ez buba tenadoodli ka. 'Et whunts'ih yugha hoodul'eh, 'en dah hubuhútni.  
\v 14 'Et Sizi ndo búlhni, “Whute 'uskehyaz sts'un hutoodelh. Khun teh dah budóohni gunih! Ndunnah Yak'usda hubudayi cho unli whuz delhts'i, 'en ndunnah 'uskehyaz hubunduhúlt'ah ho' hint'ah.”  
\v 15 Bula be hubuk'edilnik, 'ink'ez buch'a nanja. 
\s1 Dune soode'a 'int'ah 
\p  
\v 16 'Aw 'et 'ilhunuh dune Sizi yughu ninya 'ink'ez yoodulhkut, “Dune hoodulh'eh unzoo, nts'e na'a hoonzoo k'una'a 'utest'ilh 'ilhuz khutenalh whuch'a ootélhdoh?”  
\v 17 'Et Sizi ndi yulhni, “'Et di ka nuszoo sudini? 'Aw 'ilhunuh unzoo hoolah. Yak'usda 'aw 'en zeh unzoo ho' 'int'ah. 'Et whunts'ih 'ilhuz be hukhutenalh hukwa' ninzun t'eh, ndai Yak'usda khunek dune tl'aida'ai, 'i buk'une' 'int'en da.”  
\v 18 'Et ndi yúlhni, “'Et k'us ndai ho' dini?” 'Ink'ez Sizi ndi yúlhni, “Dune sóolhghelh gunih! Ts'ekoo bulh tinta' 'ont'en gunih! 'Undunont'ih gunih! 'Uyoon ba honts'it gunih!  
\v 19 Nye'abá 'ink'ez nye'ama bulh hubudólhti! Nts'e na'a nyunch'oh k'enaindutsi', whuz na'a zeh nyulh dune buk'eontsi'!”  
\v 20 'Et ndun chilh ndi yulhni, “Nusol da whuts'un, ndi ts'iyawh buk'une' zust'en. Nts'e na'a 'o 'un datést'ilh?”  
\v 21 Sizi ndi yulhni, “Lhadulya 'utant'ilh hukwa' ninzun t'eh, ndai 'int'i, 'i ts'iyawh be 'ónket, 'ink'ez tel'en butaininle. 'Et sih nduk yak'uz ndai 'ilhuwenla, 'i 'et mba telalh. 'Ink'ez 'anih se'ut'en k'ah tune' ónt'en ka sunanyalh.”  
\v 22 'Et ndun chilh ndi khunek yudánts'o hoh tube budzi nduda hoh yuch'a nanja. Tube soode'a 'int'ah 'et huwa. 
\s1 Dune 'uhuhooleh ghaít'ah, 'et whunts'ih Yakusda ba huwa chahoolnah ho' hoont'ah 
\p  
\v 23 'Et Sizi yugha hoodul'eh ndo búlhni, “Ndi 'i be soo ts'ah'un na'a 'ún whudusni, yak'uz ts'ih, nts'e hubudayi cho unli, tube howa whulna hoh dune soode'a 'et whuz teyalh.  
\v 24 Doo chah zeh 'un whudúsni, ndi khunai ncha, 'i camel hiyulhni, 'i buba howa whulna hoh ughabatsoh bula tah bukoni'a hukwa téyalh. 'Et whunts'ih 'o nus howa whulna hoh dune soo de'a, 'en Yak'usda hubudayi cho unli whuz dateyalh.”  
\v 25 'Et yugha hoodul'eh, 'en hidants'o hoh buba hooncha 'ink'ez 'et nduhutni, “Ndan zeh dutejih ho' 'udini?”  
\v 26 Sizi hubunilh'en 'ink'ez ndo búlhni, “Dune, 'aw ndet 'uhuhooleh ghaít'ah, 'et whunts'ih Yak'usda ba huwa chahoolnah ho' hoont'ah.”  
\v 27 'Et Peter yatelhtuk hoh Sizi njan ndi yulhni, “Whunilh'en, ndai ts'ut'i, 'i ts'iyawh bulazdetnik, 'ink'ez nye 'ut'en k'ah ts'ih ts'oot'en ka nyuts'un ts'utezdel. 'Et huwa ndai negha nínkat?”  
\v 28 'Et Sizi ndo búlhni, “Ts'ah'un na'a 'ún whudusni, nts'oh whuye whudezulh ts'iyaintsuk k'an, 'i natedleh, 'et wheghah whudezulh hoh yinkak dune ye', yuk'usda cho dezti, 'i yuk'etl'adutedalh. 'Et nuhwheni suntehdel inle, nuhwheni chah lanezi 'o 'at nankoh kw'uts'uzda, 'i dune huba nahuteyeh ka, 'et dutelhúts'ilh. 'Et Israel buts'u hainde, 'en lanezi 'o 'at nanah (12) lhendoh dédowh, 'en huba nahutehyeh.  
\v 29 'Ink'ez ndan bukoo huwu tezya, k'us dulhutsinkah, k'us dulhtuskah, k'us bu'abá 'ink'ez be'ama, k'us bu'at, k'us buzkehkah, k'us dukeyah chah, njan si soozi bugha huwu tezya t'eh, 'en lanezi lanezi (100) 'et 'uwhuneltsuk butl'anaootedúkulh. 'Ink'ez 'ilhuz be ts'ukhuna, 'et chah hubugha óotelts'ulh.  
\v 30 'Et whunts'ih lhanah 'udechoo 'uhint'ah, 'en 'udek'elh'az nahutedleh. 'Ink'ez lhanah 'udek'elh'az hinli, 'en 'udetsah nahutedleh.” 
\c 20  
\s1 Khunek be nawhutnuk, 'i be whuts'odul'eh, Yak'usda nts'e na'a be nek'une' whul'en 
\p  
\v 1 “Yak'uz ts'e Yak'usda hubudayi cho, 'en ts'iyawh k'une' whul'en, 'et ndez na'a njan nduhoont'ah, 'ilhunuh dune 'en ndi yun k'ut yun ut'i. 'Et mai too chun haniyeh k'et, 'et huba 'utet'ilh ka' ninzun. Bundada 'uda 'et dune telh'alh ka whuz whinya.  
\v 2 'Et ndunnah hubalh'a 'ilhuk'i sooneya chaditi 'i dzin nduhóolyez hoh hik'elha utet'ilh, huhóost'et. 'Et huwa mai too chun haniyeh k'ez whebalh'a.  
\v 3 'Et hukw'elh'az 9:00 bat'en, ts'uyi be 'óoket daninya dune bunilh'en, 'ants'ih hoh nahudelhúya.  
\v 4 'Et njan ndo búlhni, ‘Nuhwheni chah whuz mai too chun haniyeh ts'ih ahdulh. 'Ink'ez nts'e na'a sooneya ts'ah'un 'int'ah, 'i nuhwhuba k'elha telhsilh.’ 'Ink'ez whuz whehándel.  
\v 5 'Et doo chah hukw'elh'az dzetniz bat'en k'us 3:00 bat'en chah whuz whinya. 'Et whuz na'a zeh 'uja.  
\v 6 Doo chah hulhgha ts'ih bat'en whuz whinya 'ink'ez 'uyoon chah 'ants'ih hoh nadelhúya hubunilh'en. 'En chah ndo búlhni, ‘'Et di ka dzin nduwhulyez 'ants'ih hoh nudelhúya?’  
\v 7 ‘'Et 'aw dune nechalh'ah, 'et huwa 'uts'int'ah,’ hiyulhni. 'Et ndo búlhni, ‘Nuhwheni chah whuz mai too chun haniyeh ts'ih ahdulh. 'Ink'ez nts'e na'a sooneya ts'ah'un 'int'ah, 'i nuhwhuba k'elha télhsilh.’  
\v 8 'Aw 'et hulhgha ts'ih dune 'ustl'e' hut'ih ndun mai too chun 'ut'i, 'en bughunli 'anih yudani 'ink'ez ndi yúlhni, ‘'Uhut'en ts'iyawh whusábinle, 'ink'ez huba k'elha hoolhtsi. 'Et ndun 'udek'elh'az whe'dit'en, 'en choo huba k'elha holhtsi.’  
\v 9 Ndunnah hulhgha ts'ih bat'en ul'a whusahandel 'ilhunah hinli 'ilhuk'i sooneya chaditi, 'i buba k'elha yulhtsi.  
\v 10 'Et ndunnah 'udechoo ul'a, 'en chah whusahandel. 'O nus lhai duba k'elha tele huninzun. 'Et whunts'ih whuz na'a zeh 'ilhunah hinli 'ilhuk'i sooneya chaditi, 'i buba k'elha yulhtsi.  
\v 11 'En ts'iyawh buba 'uk'elha whuzdli hukw'elh'az, 'et ndun yun ut'i hich'a yawhenilhtuk.  
\v 12 'Et 'uhiyúlhni, ‘Ndunnah 'udek'ah wheóobalh'a, 'en 'ilhoh sadzi hukw'e' hoonist'ah zeh 'uhet'en. 'Ink'ez wheni dzin ndúhoolyez hoh sa ulhtus, 'i niz 'uts'et'en. 'Et whunts'ih 'en nelhulhúgha zeh buba 'uk'elha whuzílhtsi.’  
\v 13 'Et ndun yun ut'i 'et ndo búlhni, ‘Sulh dunekah 'aw hoonliyaz tink'us na'a cha'unwhúslil. 'Et ts'iyawh nuhwhuba soo' hoont'ah 'ilhuk'i sooneya chaditi, 'i mba k'elha silhsi.  
\v 14 'Aw 'et ndai nuhwhe'ildzun ulhchoot 'ink'ez nahdulh. 'Et ndunnah 'udek'elh'az hubalh'a, 'en nuhwheni nuhk'una'a zeh 'et 'uneltsuk 'i zeh buba k'elha tesilh 'et hukwa' nuszun.  
\v 15 'Alha ilah ih ndai ust'i, 'i nts'e na'a hukwa' nuszun tune' 'úlh'en? Nuszoo 'et huwa ih sugha 'aoonilh ahli?’ hubúlhni.”  
\v 16 'Et 'awhuz Sizi njan howu yalhtuk ndo búlhni, “Ndunnah 'udek'ah hinli, 'en 'udechoo nahutedleh. 'Ink'ez ndunnah 'udechoo hinli, 'en 'udek'ah nahutedleh. 'Et huwa Yak'usda lhanah 'anih dáni, 'et whunts'ih ntsoolyaz zeh 'utahaóobanla.” 
\s1 Sizi datetsah 'ink'ez dinadutedalh 'et whulh tat huwi yatelhtuk 
\p  
\v 17 'Aw 'et Sizi Jerusalem ts'ih tezya. 'Ink'ez ndunnah lanezi 'o 'at nanah ndunnah yugha hoodul'eh, 'en 'udun nibuninla 'ink'ez ndo búlhni,  
\v 18 “Soo zúlhts'ai, Jerusalem ts'iztedulh 'ink'ez yinkak dune ye', 'en ndunnah náwhulnuk moodih, 'ink'ez Moses be' dustl'us 'uk'ununa'úsduguz chah, 'aw 'et butl'ahitelhtelh, datetsah ka hiba nahuteyeh.  
\v 19 'Ink'ez 'udun yun k'ut whut'en butl'ahitelhtelh. 'En highu tedloh, hiyootelhtsus, 'ink'ez 'et lhdulalhgus k'ehítelhtelh. 'Ink'ez hukw'elh'az whulh tat dzin dinadutédalh.” 
\s1 James 'ink'ez John hube'ama, 'en hoonli hukwa Sizi yoodulhkut 
\p  
\v 20 'Aw 'et Zebedee buzkeh hube'ama, 'et Sizi hits'un tezdel hiyoodutelhkut ka. Hube'ama yubut nachaniti.  
\v 21 'Et Sizi ndi yulhni, “Ndet sts'o hukwa' ninzun?” 'Et ts'eke 'utni, “Nts'e hubudayi cho inli, ndunnah nanah suzkeh, 'en 'ilhunuh nalhnih ts'ih tedalh 'ink'ez 'ilhunuh intl'as ts'ih tedalh, sugha óoni'ai.”  
\v 22 'Et Sizi njan ndutni, “Ndet hukwa' hoodulhkut 'aw t'eoonuzahzun. Ndi lubot 'aw 'et be' tesnilh, 'i nuhwheni chah be' tehnilh nahzun ih? 'Ink'ez ndai dune be too be 'ul'en, 'i be 'usotelilh. Nuhwheni chah whuz na'a zeh ih too be' tehnilh?” 'Et ndi híyulhni, “A, 'et sih nduts'óoneh!”  
\v 23 'Et ndo búlhni, “'Alha sulubot be' tehnilh, 'ink'ez be too be' lhúya, 'i too be' tehnilh. 'Et 'aw doosni ghaít'ah ndan nalhnih ts'ih sts'un tedalh 'ink'ez ndan intl'as ts'ih sts'un tedalh. Ndunnah se'aBá huba lhaóodinla, 'aw 'en zeh buba' hoont'ah.”  
\v 24 'Et 'onghunnah lanezi hidants'o hoh, 'aw 'et ndunnah nanah lhulhutsinkah huba dzuh 'uhudeja.  
\v 25 'Et Sizi ndunnah ts'iyawh 'anih hubudani 'ink'ez ndo búlhni, “Nuhwheni t'eoonahzun ndunnah 'udun yun k'ut whut'en bumoodih, 'en dune k'une' buhul'en. 'Ink'ez ndunnah ncha, 'en ndunnah bumoodih huba hubugha ndoh 'uhint'ah. 'Et whuz na'a hube 'ut'en k'ah hooni.  
\v 26 'Et whunts'ih nuhwheni nuhtah whuz na'a 'uteht'ilh nóohzin gunih. 'Et ndan nuhtah ncha tele hukwa' ninzun, 'en nuhwhuba ne'út'en wule.  
\v 27 'Et ndan nuhtah 'udechoo tele hukwa' ninzun, 'en nuhwhe'ulhna wule.  
\v 28 Whuz na'a yinkak dune ye', 'aw ba ne'whutet'en hukwa whusáchaiyal. 'Et dune buba ne'ut'en tele 'ink'ez buba datetsah, 'et whuz na'a lhanah naootekulh, 'et hukwa whusainya.” 
\s1 Nanah chawhés'en, 'en honilh'en nasdli 
\p  
\v 29 'Aw 'et hukw'elh'az Jericho keyah whuch'a náhusdel hoh lhanah dune hiyuntezdel.  
\v 30 Nanah chawhés'en ti whuzih huzke. 'Et Sizi wheghah uyalh hoh hiduzts'ai. Soo tube cho hits'uh hahuyih, “Moodihti, David buts'u haínzut, negha te'nonzeh!”  
\v 31 'Et 'ilhunahuwésdel, 'en “T'eduzahnih!” hubuhútni. 'Et whunts'ih 'o nus 'uhutni, “Moodihti, David buts'u haínzut, negha te'nonzeh!”  
\v 32 'Et Sizi bughah nininya 'ink'ez ndo búlhni, “Dez áh'us. Ndet nuhwhuba 'uwhutesdlilh hukwa' nahzun?”  
\v 33 “NeMoodihti nena be ts'onolh'en hukwa' uzninzun,” hiyúlhni.  
\v 34 'Ink'ez Sizi hubugha te'nanzin hoh bula be hubuna yut'agheznai. 'Et 'ahoh honilh'en suli. 'Aw 'et hiyuntez'az. 
\c 21  
\s1 Lhanah huhoost'et hoh Sizi keyah Jerusalem ninya 
\p  
\v 1 'Aw 'et Jerusalem wheghah hedulh keyah whuyaz Bethphage huwhutni, 'et whuz hunindel. 'I dzulh yenun, Olive huwhutni. 'Et Sizi nanah yugha hoodul'eh, 'en dutsuh whébalh'a,  
\v 2 'et ndo búlhni, “Njan keyah whuyaz nuhgha nch'az whuz ah'us. 'Et whuz lhgha dah'az t'eh, 'et 'ahoh yeztliyaz, donkey hiyulhni, buyaz bulh whehudint'uk, 'et whunoolh'en. Sk'unaoobudooh'uk 'ink'ez dez sts'un naoobutoohlooh.  
\v 3 'Et dune nuhoodulhkut, ‘Di ka 'ulh'en?’ nuhuwhútni t'eh, ‘NeMoodihti yuka' ninzun,’ dóohtni. 'Et 'ahoh sts'un bula dóohtnih.”  
\v 4 'Et whuz na'a ndi ts'iyawh tune' whust'en, 'i be nus hon'en daja ni, 'et ndulhcho 'et dúhooja. 'Et njan ndutni, 
\q1  
\v 5 “Zion bukeyah whuti whut'en, 
\q2 whunulh'en! Nuhhubudayi cho te'dudil'en hoh nuhts'u teyalh. 
\q1 Donkey buyaz, 'en yuk'usda. 
\q2 'En be nuhts'u teyalh.” 
\p  
\v 6 'Et ndez na'a njan dúhooja, Sizi yugha hoodul'eh whuz wheha'az, 'ink'ez Sizi daja hubúlhni, hoh tune'hust'en.  
\v 7 'Et whuz na'a Donkey buyaz bulh hits'u hinilhti. Dunaih hik'ehíyinla 'ink'ez 'on dus de Sizi hik'etl'ahidilhda.  
\v 8 Lhanah dune dunaih ti hiba néhiyuzbus nts'oh lhuteyalh. 'Ink'ez 'onghunnah, 'en chah 'ul nanehidutselh 'ink'ez ti hiba nehídenla.  
\v 9 'Aw 'et 'ilhunahuwésdel bulunah butsuh 'ink'ez bulunah buk'ah ts'ih hedulh 'ink'ez tube cho hahuyih ho' hutni, 
\q1 “David buts'u haínzut ba ts'odélhti! 
\q1 NeMoodihti boozi be whuz de úyalh. 
\q1 'En degha nus hoonzoo bugha whults'ut. 
\q1 'Et soo deghan doh hidélhti!” hutni. 
\p  
\v 10 'Aw 'et Sizi keyah Jerusalem whuz ninya, 'et keyah whut'en khunahuntesdel hoh 'ulhódutni, “Ndan dune ho' 'int'ah?”  
\v 11 'Et 'ilhunahuwésdel hubuhútni, “Ndun 'en Sizi nus whunilh'en, 'en 'int'ah. Keyah Nazareth yun k'ut Galilee whuz'ai, whuz de hainya 'int'ah.” 
\s1 Ndunnah luglez whucho 'ooket 'ink'ez 'e'ooket, 'en ts'iyawh Sizi tinaoobunenyoot 
\p  
\v 12 'Aw 'et Jerusalem hubuluglez whucho whuna'neztl'oo daninya 'et ndunnah 'ooket 'ink'ez 'e'óoket, 'en ts'iyawh tenabunenyoot. Sooneya lhk'enaduleh bukw'uzdai 'i chah ts'iyawh buch'a yuntez'ai. Ndunnah dut'aiyaz, dove hiyulhni, be 'óoket, 'en bukw'usuda 'i chah buch'a yuntez'ai.  
\v 13 'Et ndo búlhni, “'Uk'e'eduguz hoh njan ndutni, ‘Njan sukoo tenadudli ba koo dahni,’ 'et whunts'ih 'et chah njan ndutni, ‘'Undunut'ih, 'en bukoo whuzúlhtsi.’ ”  
\v 14 'Et luglez whucho 'et chawhés'en 'ink'ez bukechun nduda, 'en highu nindel, 'et soo na'balh'en.  
\v 15 Ndunnah náwhulnuk bumoodih 'ink'ez Moses be' dustl'us 'uk'ununa'úsduguz, 'en njan huwa 'ét'en tune' 'ust'en hinalh'en. 'Ink'ez 'uskeh 'en chah luglez whucho sulyahalhtuk 'et njan nduhutni, “David buts'u haínzut buba ts'odélhti!” 'Et njan ts'iyawh honalh'en hoh hukwa hanílch'e.  
\v 16 'Ink'ez Sizi 'et ndi hiyulhni, “Ndi daja hutni huboozélhts'ai ih?” 'Et ndo búlhni, “A, 'ink'ez dahúja 'aw hukw'uyachasulhtuk hoh ih dahni? Ndez na'a 'uk'e'wheduguz 'et njan ndutni, 
\q1 ‘'Uskeh 'ink'ez 'uskehyaz chah, 
\q2 'en bughunek 'i be' hutni, ts'ah'un na'a suba hodilhti hubulhtsi.’ ” 
\p  
\v 17 'Et ndunnah 'aw 'et buch'a nanja 'ink'ez keyah whuti huwu whenája. 'Ink'ez keyah whuyaz Bethany ts'un ninya 'et usda. 
\s1 Ndi duchun mai buts'u haníyeh, 'i Sizi yek'éhanya 
\p  
\v 18 'Et 'om bun 'uda 'et keyah whuti whuts'u hédulh hoh khunyaz buye'élts'ul.  
\v 19 'Et ti whuzih khunyaz ndi mai chun, fig hiyulhni, yutelh'en. 'Et 'i yuts'un lhgha dinya hoh 'et 'aw bumai bughoh hoolah. 'Ut'an zeh bugha hoonli hoh ndi yúlhni, “'Et 'aw 'ilhuz nyumai hootélah.” Ni ibulh ndi duchun 'uyulhni, 'i dezgi. 
\s1 Ndi duchun, fig hiyulhni, 'i be whuts'odutel'eh 
\p  
\v 20 Ndunnah yugha hoodul'eh hiya'en hoh tube huba hooncha. 'Et 'uhutni, “Nyoo mai chun, fig hiyulhni, daja hoh 'uja khunyaz dezgi?”  
\v 21 'Et Sizi ndo búlhni, “'Alha 'un whudusi, bé 'alha' hoont'ah, 'i aht'i, 'ink'ez 'aw nuhwhuba nawh cha'whutést'il t'eh, 'et ndi mai chun khunsih doogi. 'Aw 'et zeh ilah, njan dzulhyaz, ‘Didílhts'i 'ink'ez bun k'ut whucho ts'ih tailhts'i,’ 'i dáhtni t'eh, 'et whuz na'a 'et ndoh whútenilh.  
\v 22 'Et ndai buka' dahni tenadudli be, nuhwhuba 'alha' hoont'ah t'eh, 'i ts'iyawh nuhgha tékulh.” 
\s1 Sizi ndan bugha dune gha ndoh 'int'ah, 'et hukwa hiyoodulhkut 
\p  
\v 23 'Aw 'et luglez whucho daninya 'et hudélhts'i wheoobudunilh'i. 'Et nawhulnuk degha nus dézti 'ink'ez dune netsuh whudelhdzulh chah, 'en highu nindel 'ink'ez 'uhiyúlhni, “Nedini ndan bugha dune gha ndoh 'unint'ah njan dint'en. K'us ndan ntl'ahó'ai dune gha ndoh 'unínt'ah?”  
\v 24 'Et Sizi ndo búlhni, “Si chah 'ilhun hukwa nuhoodutelhkut. 'Et ndusudáhni t'eh, 'et nuhwhudutesnilh ndan bugha dune gha ndoh 'ust'ah.  
\v 25 Nts'e na'a John dune too be 'úlh'en? Ndan yutl'aho'ai dune too be telilh huba? Yak'uz ts'ih tulih hawhélts'ut, k'us dune tulih ts'ih hawhélts'ut?” Dich'oh lhtah howu yahalhtuk 'ink'ez 'uhutni, “'Et yak'uz ts'ih hawhélts'ut ts'utni t'eh, 'et neundúdoni, ‘'Et di ka John nuhwhuba 'alha' cha'dusnih?’  
\v 26 'Et whunts'ih, ‘Dune ts'ih hawhélts'ut whutéla 'uhoont'ah,’ ts'utni t'eh, 'aw uzdooni ghaít'ah, dune hububéznuljut, ts'iyanah John 'en nus whunilh'en 'int'ah huninzun 'et huwa.”  
\v 27 'Et Sizi ndi hiyulhni, “'Aw nts'ez de hawhélts'ut nt'ets'onízun.” 'Ink'ez Sizi ndo búlhni, “Ndan be dune bugha ndoh 'ust'ah ndi njan nduwhúlh'en, 'et si chah 'aw ndun whudóosni ghaít'ah.” 
\s1 Ndunnah nanah ndet be'abá huba hukwa' ninzun, k'us nts'oh tune'hut'en 
\p  
\v 28 “Njan hubugha daja nahzun? 'Ilhunuh dune nanah buye'. 'En 'udechoo yughu ninya 'ink'ez ndi yulhni, ‘Suye' mai too chun haniyeh ts'ih whuz inyalh 'ink'ez suba 'int'en.’  
\v 29 'Et yuch'a tsí'desnih. 'Et whunts'ih hukw'elh'az ndunát'e 'ink'ez whuz whinya.  
\v 30 'Et bulh nat buye', 'en chah yughu ninya 'ink'ez ndi yulhni. ‘A, whuz toosya 'ink'ez 'oost'en!’ ni. 'Et whunts'ih 'aw whuz chatíyal.”  
\v 31 'Et Sizi 'utni, “Ndunnah nanah k'us ndan ndet be'abá huba hukwa' ninzun hoh teh hukw'une' hust'en?” “'Et 'udechoo, 'en zeh,” hutni. 'Et Sizi ndo búlhni, “Ts'ah'un 'ún whudusni, ndunnah sooneya nalhdzooh 'ink'ez ts'ekoo 'ul'en chah, nts'e Yak'usda hubudayi cho unli, whuz nuhtsuh hutedulh.  
\v 32 Soo whunulh'en, be ts'ah'un 'uhoont'ah, 'i be John dune too be 'ulh'en nuhts'uh whusainya, 'ink'ez 'aw nuhwhuba 'alha' cha'hoot'ah. 'Et whunts'ih sooneya nalhdzooh 'ink'ez ts'ekoo 'ul'en, 'en ts'iyawh huba 'alha' hoont'ah. 'Et nuhwheni whunulh'en 'et whunts'ih 'aw nuwheni k'ah nácha'ahlil, 'ink'ez 'aw nuhwhuba 'alha' cha'hoot'ah.” 
\s1 Mai haníyeh k'et whulh'ai, 'en bugha whúts'odul'eh 
\p  
\v 33 “Njan 'uyoo be nawhutnuk, 'i be nuhwhudutésnilh. Sih soozólhts'a! 'Ilhunuh bukoo whumoodih, 'en haniyeh k'et 'uhoonla, 'ink'ez mai too mai too chun 'ananla. 'Ink'ez whuna'neztl'oo. 'Et tsak'et hahónkai mai too 'utahahúlhtsus, 'et chah neóoni'ai. 'Ink'ez buk'ut yutest'en, 'i chah wheni 'uhinla. 'En njan haniyeh k'et ndunnah ha' nulhyeh butl'ahó'ai, 'ink'ez nilhdza keyah ts'ih whinya.  
\v 34 'Aw 'et 'oonuje neooninzut hoh bukoo whumoodih 'en 'ulhna, 'en whuz whebalh'a 'ink'ez ndun 'uhut'en, 'en buts'un mai hitelhchulh ka.  
\v 35 'Et ndunnah ha' nulhyeh, 'en bukoo whumoodih 'en 'ulhna hubílhchoot. 'Ink'ez 'ilhunuh soo yayalhchus. 'Ilhunuh chah hizelhghi. 'Ilhunuh chah tse be yahiyalh'uz.  
\v 36 'Et doo chah zeh 'onghunnah 'ulhna 'o nus 'uhuneltsuk whuz whebalh'a. 'En chah whuz na'a zeh 'et ndo buhínla.  
\v 37 'Et 'udek'elh'az bukoo whumoodih buye' whuz buts'ú wheyálh'a. ‘'En tulih hidóolhti,’ ni.  
\v 38 'Et whunts'ih ndunnah bughu whulh'ai hitelh'en hoh 'et 'ulhódutni, ‘Ndun 'en nyoo haníyeh k'et bube'ildzun, 'en buye' 'ut'en. Ts'uzoolhghelh! 'Et t'eh ndet buts'i telts'ulh, ts'iyawh 'et nduhóolcho ts'ohólhchoot!’  
\v 39 'Et hiyílhchoot 'ink'ez njan haníyeh k'et tínahinino 'ink'ez hizelhghi.  
\v 40 'Et huwa 'et njan mai too chun haniyeh, 'en bube'ildzun, 'en whusateyalh. Whusainya t'eh, 'et dabóoleh simba?”  
\v 41 'Et ndi híyulhni, “'Et ndunnah untsi', 'en hooncha hukw'un'a hoolah hubutelhtsilh 'ink'ez njan haniyeh k'et 'uyoon ha' untelhyeh bugho télh'alh. 'Et whuz na'a niwhúzuk totsuk ndi mai higha' hítelelh.”  
\v 42 'Et Sizi ndo búlhni, “'Aw ih hukw'e yachazulhtuk Yak'usda bughunek daja ni inle da? 'Et ndez k'e'eduguz, 
\q1 ‘Ndunnah 'en ndi tse be koo 'uwhulh'en 'i 'ún hidutelh'us, 
\q2 'i ba koo buk'uwhuz'ai huba soo degha nus tse 'int'ah, 'i suli. 
\q1 'Et Moodihti whuz na'a 'uhoonla. 
\q2 'Ink'ez nuwheni tube neba hooncha ho' hoont'ah,’ ni. 
\p  
\v 43 'Et huwa nuhwhudúsni, nts'e Yak'usda hubudayi cho unli, 'et ts'iyawh nuhghu nahootélchulh 'ink'ez 'uyoon hudedowh butl'aóote'alh. 'En 'ut'en unzoo, 'i buts'u haóokat.  
\v 44 'Ink'ez ndunnah ndi tse hik'elts'ut, 'en ts'iyawh yahidutélhkulh. 'Ink'ez ndunnah ndi tse buk'édilts'ut, 'en ts'iyawh hoolah hutele.”  
\v 45 'Et ndunnah Lizwif náwhulnuk bumoodih 'ink'ez Pharisee chah, 'en ndi khunek be nawhutnuk, 'i whulh 'úhudants'o hoh t'ehonanzin Sizi 'en didut bughu yalhtuk.  
\v 46 Nts'e na'a simba Sizi hitelhchulh 'et hukwa' hut'en. 'Et whunts'ih dune yé hunuljut. 'En Sizi 'en nus whunilh'en 'int'ah huninzun 'et huwa. 
\c 22  
\s1 Yak'uz k'une' whul'en, 'et hubudayi cho buye' bu'at whutele, 'et ndult'ah 
\p  
\v 1 'Et doo chah zeh Sizi be nawhutnuk, 'i be whuts'odul'eh, 'i be hubulh yalhtuk 'et ndo búlhni,  
\v 2 “'Et yak'uz k'úne' whul'en, ndez na'a njan dóohoont'ah, 'ilhunuh hubudayi cho buye' bu'at whutele, 'en huba lhadútenilh.  
\v 3 'Ink'ez ndunnah bughu núseya, de'ulhna buts'u whebaoolh'a, 'anih hubadooni ka, 'et whunts'ih buch'a tséhudesnih.  
\v 4 'Et doo chah zeh 'uyoon chah de'ulhna whuz wheóolh'a. Ndunnah bughu nusja suba budoohni, ‘'Aw 'et ts'uyi, 'i lhadínt'ah. Njan musdus ts'iyawh ndai nilhúk'a, 'i ts'iyawh suba nahiyanghan dune yute'alh whuba. Ts'iyai 'i lhadínt'ah. 'Aw 'et ndunnah lhghusdúke hubulh na'uztet'alh. Soo 'a dezáhdulh! suba hubudóohni.’  
\v 5 'Et whunts'ih ndunnah bughu nusja huba 'ants'ih 'uhoont'ah. Ts'iyawh lhents'un whehándel. Bulunah chah há' hunulhyeh ts'ih whenáhedel. 'Et bulunah chah hube 'ut'en k'ah whuz'ai ts'ih whenáhedel.  
\v 6 Bulunah hubudayi cho be 'ulhna hubihílhchoot 'ink'ez dzuh ne'buhalh'en 'ink'ez hubuhanghan.  
\v 7 'Et hubudayi cho whulh údants'o hoh tube hunílch'e. Ndunnah nehughan hubít'i ts'iyawh whuz whebalh'a. Ndunnah be 'ulhna inghan, 'en ts'iyawh hoolah hubulhtsi 'ink'ez bukeyah ts'iyawh hodálhk'un.  
\v 8 'Et hukw'elh'az 'uyoon chah be 'ulhna, 'en ndo búlhni, ‘'Aw 'et na'tet'alh lhaoodint'ah, 'et whunts'ih bughu nusja, 'aw huba soo cha'hildzooh.’  
\v 9 'Et huwa 'aw 'et ti ts'íh ahdulh. 'Ants'ih lhanah cho nahla t'eh, 'en ts'iyawh bughu nóhdelh.  
\v 10 'Et ndun be 'ulhna ti ts'ih whehandel. Ndan nabuhinla, ntsi' 'ink'ez unzoo tubulh 'ilho ts'iyawh whusábahanla. 'Aw 'et na'hutet'alh bukoo whudezbun.  
\v 11 'Aw 'et hubudayi cho buts'un danínya bughu nusja hubuntelh'ilh ka. 'Et 'ilhunuh dune 'en 'aw naih dune lhghu delhts'i whunaih be dune chailah hoh yutelh'en.  
\v 12 'Et ndi yúlhni, ‘Sulh dune 'aw dune lhghu delhts'i whunaih be dune chainlah. 'Ink'ez nts'e na'a danínya?’ 'Et ndun dune 'aw whé 'uyoodoni hoolel.  
\v 13 'Et hubudayi cho duba ne'ut'en ndo búlhni, ‘Ndun dune ulhchoot 'ink'ez ulhghel. 'Ink'ez 'az tsahólhgus yuh ts'ih táhneh! 'Et whuz tetso 'ink'ez dughoo lheidútelhk'us.’  
\v 14 Njan 'et ndutni hoh 'utni, lhanah ghu nusja 'et whunts'ih bulunah zeh 'utahálya.” 
\s1 Yun k'elha huhoolh'i hukwa' hoodulhkut 
\p  
\v 15 'Aw 'et ndunnah Pharisee 'udun nehúnindel 'ink'ez howu yahalhtuk, nts'e na'a Sizi ye yalhtuk, 'i be hitelhzah hukwa' hut'en.  
\v 16 'Et Pharisee hubugha hoodul'eh 'ink'ez Herod dédowh chah, 'en Sizi ts'un wheoobuhalh'a. 'Et ndi hiyúlhni, “Dune hoodulh'eh t'ets'oninzun nyun ts'ah'un dune 'int'ah 'ink'ez khunek 'alha' 'int'ah, 'i be Yak'usda k'una'a dune hodilh'eh. Ts'iyannah mba lhgha 'int'ah. Nts'e na'a dune dahút'en 'et whunts'ih mba 'ants'ih 'uhoont'ah.  
\v 17 'Et huwa nedini, ndi yun hik'elha hiyilh'i, 'i 'et ts'ah'un tulih 'uhoont'ah hoh hubudayi cho Caeser 'en tulih buba k'elha ts'uyoolhtselh, k'us 'awundooh tulih? Daja ninzun?”  
\v 18 'Et Sizi t'eooninzun nts'e na'a hoontsi' k'ah ts'ih 'uhoont'ah, 'et huwa ndo búlhni, “'Et di kah sóolhdzih? Nuhwheni ts'iyawh duba nahdúdzoo aht'ah!  
\v 19 De' nyoo sooneya sunalh ts'et nah'a!” 'Ilhuk'i sooneya chaditi, 'i hitl'ahína'ai.  
\v 20 'Et ndo búlhni, “Ndan bunen 'ink'ez boozi chah buk'e'edúguz?”  
\v 21 “Hubudayi cho Caesar,” hiyulhni. 'Et ndo búlhni, “'Et huwa ndai hubudayi cho Caeser bube'ildzun, 'i butl'anáyahle. 'Ink'ez ndai Yak'usda bube'ildzun, 'i Yak'usda butl'anáyahle.”  
\v 22 'Et hidants'o hoh ts'iyawh huba hooncha 'ink'ez hich'a nandel. 
\s1 Nat ts'ukhítnaih hukwa Sizi hiyoodulhkut 
\p  
\v 23 'Et dzin zeh ndunnah Sadducee, 'en highu nindel. 'En 'uhutni dats'úzsai 'ink'ez 'aw nats'ukhóotnah ghaít'ah.  
\v 24 'Et ndi híyulhni, “Dune hoodulh'eh Moses ndez na'a njan ndutni, 'et dune 'aw buzkeh hoolah hoh dazsai 'ink'ez bu'at zeh khuna t'eh, 'et bulhutsin 'en yughu naooda huba' hoont'ah. 'Et ndun bulhutsin 'en dughe yughu nasda t'eh, 'en ts'un dulhutsin ba buzkeh whutele.  
\v 25 'Et netah skwunlai 'o 'at nanah lhulhutsinka, 'en 'udetsah whudelhdzulh, 'en 'at ut'i. 'Ink'ez 'aw buzkeh hoolah hoh dazsai. 'En bu'at dulhutsin ba nayoosdzi.  
\v 26 Whúlh nanah whuz na'a zeh dazsai. 'Et whulh tat, 'en chah whuz na'a zeh 'uja. 'Et nduwhúlyez hoh skwunlai 'o 'at nanah ts'iyawh yahadla.  
\v 27 'Et 'udek'elh'az ndun ts'eke 'en chah dazsai.  
\v 28 'Et huwa nedini 'ilhudzin whusawhutelts'ulh hoh ts'iyannah dinadutédulh, 'et t'eh ndun ts'eke ndan bu'at tele? 'Et whunulh'en skwunlai 'o 'at nanah ts'iyawh hubughinda.”  
\v 29 'Et Sizi ndo búlhni, “Nuhwhenich'oh na'dunáht'ah! 'Aw Yak'usda bughunek nt'enuzahzun. Ye ulhtus, 'i chah 'aw nt'enuzahzun.  
\v 30 'Et ndet dzin dune dinadidel t'eh, 'aw lhghu chahudutelhts'il 'et huwa. Dune dinadidel, 'en Yak'usda bulizas k'una'a 'uhutet'ilh ho' hoont'ah.  
\v 31 'Et daja sudahni yaidla tah dinadutédalh hubugha, Yak'usda daja ni, 'aw ih hukw'u yachazulhtuk? Njan ndutni,  
\v 32 ‘Si Abraham, Isaac, 'ink'ez Jacob, hubuYak'usda 'ust'ah.’ 'Aw yaidla hubuYak'usda ilah 'int'ah. Hukhuna 'en hubuYak'usda nusli unli 'et huwa.”  
\v 33 'Et 'ilhunahuwésdel 'en dahoont'ah hubugha hubudani tube huba hooncha. 
\s1 'Ilhuk'i khunek degha nus dezti, 'i netl'aída'ai 
\p  
\v 34 'Et Pharisee whulh 'úhudants'o nts'e na'a Sizi ndunnah Sadducee hubudani, 'et hukwa Sadducee 'aw yahutoolhdih ghaít'ah hoh hinat 'ilhunahuwésdel.  
\v 35 'Aw 'et 'ilhunuh hubutah, Moses be' dustl'us k'ut, daja ni hoh beni hoonli be yalhtuk unli, 'en Sizi yóolhdzih hoh yoodulhkut,  
\v 36 “Dune hoodilh'eh k'us undai khunek neba yutulhúhezya, 'i k'us degha nus dezti?”  
\v 37 'Et Sizi ndi yulhni, “ ‘Yak'usda nyuMoodihti ndzi ndulhcho 'i be, nzul ndulhcho 'i be, nyunut'uk ts'iyawh 'i be, 'ink'ez nyeni ts'iyawh 'i be chah, 'et whuz na'a 'en buk'eoontsi'.’  
\v 38 Ndi ndai nuhwhuba yutulhuhezya, 'i 'udechoo 'ink'ez degha nus dezti, 'i 'int'ah.  
\v 39 'Et bulh nankoh, 'i 'udechoo, 'i k'una'a 'int'ah, ndez na'a njan ndutni, ‘'Et dahoont'ah hukw'una'a nyunch'oh k'enaindutsi', 'et whuz na'a zeh 'onghunnah chah buk'eoontsi'.’  
\v 40 Ndi nankoh khunek nuhtl'adélts'ut, 'i be Moses be' dustl'us, 'ink'ez nus whunilh'en hube dustl'us chah, 'i ts'iyawh 'ants'ih koo buk'ut whuz'ai, 'i li'int'ah.” 
\s1 Christ ndan unli 'int'ah? 
\p  
\v 41 'Et 'awhuz ndunnah Pharisee 'ilhunahuwésdel hoh Sizi huboodulhkut,  
\v 42 “Christ ndan unli 'int'ah nahzun? K'us ndan yuts'u hainzut simba 'int'ah?” “'En David yuts'u hainzut 'int'ah,” hiyulhni.  
\v 43 'Et ndo búlhni, “Nts'e na'a 'int'ah David Ndoni be nyun sMoodihti 'int'ah nyudúsni ni 'et ndez na'a njan ndutni, 
\q1  
\v 44 ‘Moodihti 'en sMoodihti ndi yúlhni, 
\q2 nalhnih ts'ih sinda t'eh nch'a detni, 'en buk'ut nke naóolyis mba hólhsilh.’ 
\p  
\v 45 'Et whuz na'a David, ‘SMoodihti,’ 'uyulhni. Nts'e na'a simba 'en yuts'u hainzut wule?”  
\v 46 'Aw dune yuts'u yatoolhdih hoolah. 'Et ts'iyannah whehunuljut 'aw 'o 'un hiyoodolhkut ghaít'ah. 
\c 23  
\s1 Moses be' dustl'us 'uk'ununa'úsduguz 'ink'ez Pharisee chah, 'en dawhultsi' 'et buts'u whélts'ulh 
\p  
\v 1 'Aw 'et Sizi ndunnah 'ilhunahuwésdel 'en 'ink'ez yugha hoodul'eh chah hubulh yawhenilhtuk hoh ndutni,  
\v 2 “Ndun Moses be' dustl'us 'uk'ununa'úsduguz 'ink'ez Pharisee, 'en chah 'en dune hodutelh'eh 'et wheni Moses yuk'usda, 'i k'ut natl'ahudelts'i.  
\v 3 'Et ndai khunek hiye nohwhulh yalhtuk, 'i 'et ts'iyawh wúlhchoot 'ink'ez buk'úne' 'ooht'en. 'Et whunts'ih khun hubuk'una'a ne'óoht'en gunih. 'Et 'alha daja hutni, hoh tunuchá'hust'en.  
\v 4 'Et ndez na'a né'hut'en, lhai cho lhughel tube howa whulna dune neyúghe huba. Dune buwus k'ehiyíle. 'Et hedich'oh hubulasgek lhuk'i whunts'ih nuhighoolhnah ghaít'ah.  
\v 5 Ndai 'uhiyulh'en, 'i 'uyoon yunoolh'en huba 'uhiyulh'en. 'Ink'ez ndi Yak'usda bughunek zus, Phylacteries hiyulhni, 'o nus ncha hiyilh'i ts'iyannah hinoolh'en ka. 'Ink'ez ndi nayidúts'uz 'i tenahududli teh nahuyits'uz, 'i chah butsuh 'o nus 'udelyez nahiyulhtsih.  
\v 6 'Et 'uhuté'alh 'ink'ez luglez chah soo k'us hoonzoo 'et zeh hudutélts'ilh hukwa' huninzun.  
\v 7 'Ink'ez ndet ts'uyi, 'i be 'óoket, 'et ts'iyannah hubodélhti hoh dahooja hubuhútni, 'et huhóont'i. 'Ink'ez ts'iyawh 'ihunah hinli hoh, ‘Rabbi! Nehodulh'eh!’ huba hudóoni hukwa' huninzun.  
\v 8 'Et whunts'ih khun teh 'uyoon ‘Rabbi,’ nuhodóoni gunih! 'Aw 'ilhunuh zeh whenohodulh'eh hoonli 'et huwa, Christ 'en 'int'ah. 'Et nuhwheni ts'iyawh lhulhutsinkah ahli.  
\v 9 'Et ndi yun k'ut 'ants'ih ndan, ‘'Abá,’ hubudóohni gunih. 'Aw 'ilhunuh zeh nuh'aBá unli 'et huwa, Yak'uz usda, 'en 'int'ah.  
\v 10 'Ink'ez khun teh 'uyoon ‘Nemoodihti,’ nuhwhudóoni gunih. 'Aw 'ilhunuh zeh nuhMoodihti hoonli 'et huwa, Christ 'en 'int'ah.  
\v 11 Ndunnah nuhtah hincha, 'en nuhwhuba ne'hút'en wule.  
\v 12 'Ink'ez ndan dich'oh ncha nadudil'i, 'en deghanyuk tel'en tele. 'Et ndan deghanyuk 'ududildzun, 'en degha ndoh ncha tele.”  
\v 13 'Et nuhwheni Moses be' dustl'us 'uk'ununa'úsduguz nuhwheni Pharisee chah, nuhwheni duba nahdúdzoo aht'ah! Dawhultsi' 'et nuhts'u whélts'ulh. Ndez na'a njan ndaht'en, nts'e hubudayi cho yak'uz usda, 'et whudáti dune ch'a dána'dehtan. Nuhwhenich'oh whunts'ih daóohya ghaít'ah. 'Ink'ez ndunnah whuz hedulh, 'en chah 'aw dabóohlelh ghaít'ah.  
\v 14 Nuhwheni Moses be' dustl'us 'uk'ununa'úsduguz, nuhwheni Pharisee chah, nuhwheni duba nadúhdzoo aht'ah! Dawhultsi' 'et nuhts'u whélts'ulh! Tsandelh hubukoo hubugha haoondunaht'ah. 'Et ndi tenadudli 'i be whuz na'a zeh 'aoonilhka sa cho tenadahdli. 'Et huwa 'o nus 'uwhulcho nuhwhuba nahutedeh.  
\v 15 Nuhwheni Moses be' dustl'us 'uk'ununa'úsduguz, nuhwheni Pharisee chah, nuhwheni duba nadúhdzoo aht'ah! Dawhultsi' 'et nuhts'u whélts'ulh! Ndi yun k'ut ndulhcho hoh náhdelh 'ink'ez too k'ut ndulhcho hoh nahke, 'ilhunuh tulih nuhwhenich'oh nuhk'una'a 'int'ah wulhtsilh. 'Et whuch'a nulhde t'eh, 'et sih ndan nat 'uwhultsi' hoh nuhghanus kwuncho yuh whuye' tele.  
\v 16 Nuhwheni chawhés'en li'aht'ah, dawhultsi' nuhts'u whélts'ulh. Lhe'aht'ah whuzeh'en 'et whunts'ih dune ti wheoobuntelhtun hukwa' aht'en. 'Et ndez na'a dune whubodulh'eh, njan luglez whucho boozi be dune nahuhezya t'eh, 'et 'ants'ih 'uhoont'ah. 'Et whunts'ih luglez whucho 'et gold 'ink'ez silver bulh 'uhoolya, 'et 'i be whuz na'a nahuhezya t'eh, 'et whuz na'a 'uhuhooleh huba' hoont'ah, dáhni.  
\v 17 Nuhwheni whuzáhnik 'ink'ez chaoozéh'en ahli! K'us ndet degha nus whudezti? Luglez whucho k'us gold bulh 'úhoolya, 'et 'i tulih? 'Et luglez whucho 'et degha nus whudezti. 'Et gold bulh 'uhoolya, 'i 'ants'ih Yak'usda ba 'udun nenínkat, 'i 'int'ah.  
\v 18 Ndi 'i chah dune whubodulh'eh, ndan Yak'usda bukw'uzdai 'i be hoonliyaz yuts'u nahezya, 'et 'ants'ih 'uhoont'ah. 'Et whunts'ih ndai 'ants'ih huwa t'aih, 'i Yak'usda bukw'uzdai k'eyin'ai, 'et 'i be dune yuts'u nahezya t'eh, 'et nduyóoleh huba' hoont'ah. 'Et whuz na'a dune whubodulh'eh.  
\v 19 Nuhwheni whuzahnik 'ink'ez chaoozéh'en ahli. K'us ndet degha nus whudezti? 'Ants'ih huwa t'aih, 'i tulih k'us Yak'usda bukw'uzdai tulih? Ndi Yak'usda bukw'uzdai 'i degha nus dezti! Ndi 'ants'et huwa t'aih, 'i Yak'usda bukw'uzdai 'i bugha Yak'usda bube'ildzun suli 'et huwa.  
\v 20 'Et huwa ndan Yak'usda bukw'uzdai 'i be hoonliyaz yuts'u nahezya, ndi Yak'usda bukw'uzdai 'ink'ez buk'uyuzdla, 'i ts'iyawh 'i be yuts'u nahezya.  
\v 21 'Ink'ez ndan luglez whucho yuts'u nahezya, luglez whucho 'ink'ez Yak'usda usda, 'et ts'iyawh yuts'u nahezya.  
\v 22 'Ink'ez ndan yak'uz yuts'u nahezya, Yak'usda yuk'usda cho dezti, 'i 'ink'ez ndan yuk'usda, 'en be yuts'u nahezya.  
\v 23 Nuhwheni Moses be' dustl'us 'uk'ununa'úsduguz, nuhwheni Pharisee chah, nuhwheni duba nahdzoo aht'ah! Dawhultsi' 'et nuhts'u whélts'ulh! Ndez na'a njan daht'en, ndai haníyeh, 'i 'ut'an sooltsun, 'i chah, anise hiyulhni, 'i chah, 'ink'ez cummin hiyulhni, 'i chah, 'i bulah zeh, 10%, 'i Yak'usda ghah'aih. 'Et whunts'ih Moses be' dustl'us k'ut degha nus whudezti, 'et ts'iyawh whuladehtnik. Ndez na'a ts'ah'un 'uhoont'ah. Njan ndet ts'ah'un na'a ne'áht'en, ye negha te'untezeh, 'i chah, 'ink'ez be néba 'alha' hoont'ah, 'i chah, njan 'et ts'iyawh whuladehtnik, 'et whunts'ih whuz na'a ndóht'en huba' hoont'ah, 'ink'ez 'onghun, 'i chah 'aw lhachaduzahle bula doohtnih gunih.  
\v 24 Lhe'aht'ah whuzeh'en 'et whunts'ih, dune ti whúbuntelhtun hukwa' aht'en. Lhe'aht'en, ndai ahnai, 'i sts'uz yé tat'o t'eh, 'i ahguz 'et whunts'ih nuhwheni ndi khunai cho, camel hiyulhni, 'i telhnoh li'hoont'ah!  
\v 25 Nuhwheni Moses be' dustl'us 'uk'ununa'úsduguz, nuhwheni Pharisee chah, nuhwheni duba nahdzoo aht'ah. Dawhultsi' 'et nuhts'u whélts'ulh! Lusyet 'ink'ez lubot chah yoo 'az ts'ih toonáhgus. 'Et whunts'ih bet ts'ih 'et ndai 'uyoon be, bé whulhts'it, 'i 'ink'ez nts'e na'a hukwa' nahzun tune' aht'en 'et 'i be nuhlusyet 'ink'ez nuhlubot teh dezbun.  
\v 26 Nuhwheni Pharisee chawhés'en ahli! Ndi lusyet 'ink'ez lubot bulh 'udechoo bet ts'ih tóonawhahgus 'et t'eh yoo 'az chah 'aw chaditsun wule.  
\v 27 Nuhwheni Moses be' dustl'us 'uk'ununa'úsduguz, Pharisee nuhwheni chah, duba nahdzoo aht'ah! Dawhultsi' 'et nuhts'u whélts'ulh! 'Ants'ih ts'un k'ut whuduchun dustl'us 'i lí'aht'ah. yoo 'az ts'ih tube soo 'awhut'en, 'ink'ez bet ts'ih whudutsun 'ink'ez dune ts'un be whudezbun.  
\v 28 'Et whuz na'a zeh dune nalh nuhyust'e yoo 'az ts'ih ts'ah'un dune hinli ndoonéht'en. 'Et whunts'ih nuhyuh ts'ih ts'ah'un cha'aht'ah. Ndai duba nahdzoo 'ink'ez 'uk'únucha'ust'en, 'i chah, 'i be whudezbun.  
\v 29 Nuhwheni Moses be' dustl'us 'uk'ununa'úsduguz, Pharisee nuhwheni chah, duba nahdzoo aht'ah! Dawhultsi' 'et nuhts'u whélts'ulh! Nuhwheni nus whunilh'en, 'en buba tse bet 'ahudutelhtelh 'uwhulh'en. 'Ink'ez ts'ah'un 'int'ah, 'en buts'un k'ut hoonzoo whulhtsi.  
\v 30 'Ink'ez ndez na'a njan ndudáhtni, ‘Hoh da netsuh whudelhdzulh hubulh ts'ukhuna inle ndúcha. Hoh da ts'ukhuna t'eh, 'et nus whunilh'en hubuhughan da, 'aw bulah ts'oot'en ghaít'ah inle.’  
\v 31 'Et ndi njan ndudáhtni, 'i be nuhwhenich'oh ch'a déhtni. Ts'iyannah hobunulhtun 'aw 'uyoon ndunnah nus whunilh'en hubahanghan, nuhwheni 'en buts'uh háde ahli!  
\v 32 'Aw 'et ndai 'ut'en untsi', 'i nuhwhubákah whe'hidilh'en, 'et ts'iyawh lhaóodahla.  
\v 33 Tl'ughus poison buzkehkah lí'aht'ah! Njan kwuncho yuh wheni nuhwhuba nahutedeh, nts'e na'a 'utehnilh wheghoo tehdulh? 'Aw 'uhóneh ghait'ah!  
\v 34 'Et hukwa soo cho soo zélhts'ai, 'et nus whunilh'en, 'ink'ez dune huwhunih, 'ink'ez Yak'usda bughunek hodulh'eh chah, 'en ts'iyawh nuhts'ún butelh'alh. 'En bulunah butehghan. 'Et whuz na'a lhdulalhgus hubunduntélht'ah. Bulunah nuhluglez bez ts'ih 'et hubootelhtsus. 'Ink'ez lhelhdun keyah totsuk zah nohbutelhzut.  
\v 35 'Ink'ez 'et huwa 'et ndez na'a nuhk'eóotelts'ulh. Ndunnah ts'ah'un 'int'ah buzkai yun k'ut nájul, 'en bughá 'utehnilh nuhk'eóotelts'ulh. Hoh da Abel 'en 'uja buzkai yun k'ut nájul. 'Et njan Zechariah buzkai yun k'ut nájul 'et whuts'un. 'En 'int'ah Berechiah buye'. Ndun 'en njan luglez whucho 'et Yak'usda bukw'uzdai ye guz 'et nuhtsuh whudelhdzulh, 'en hizelhghi inle.  
\v 36 Ts'ah'un na'a be 'ún whudusni k'an whudelhdzulh, 'et nuhwheni hukw'elha whutelhtsilh ho' aht'ah. 
\s1 Jerusalem whut'en, 'en hubugha Sizi budzi nduda suli 
\p  
\v 37 “Nuhwheni Jerusalem whut'en, dáwhultsi' nuhts'u whélts'ulh! Nuhwheni aht'en nus whunilh'en ahghan. 'Ink'ez ndunnah nuhts'u télh'a, 'en chah tse be hubahghan. Dant'ah ligok duduzkeh dints'un be huboontun, whuz na'a nuhwheni chah lhat hoh 'ilhunanohwutésdlelh hukwa' nuszun, 'et whunts'ih 'aw hukwa cha'nahzun.  
\v 38 Soo cho whunulh'en, 'aw 'et nuhwheni Jerusalem whut'en nuhkeyah 'aw hoonli hoolah suli hoh nuhwhuba 'et nenáwhults'ut, 'et whuz na'a Yak'usda nuhladutetnih.  
\v 39 'Et 'un whudusni, 'aw 'o 'un chasutuzeh'il. 'Et ndet dzin whusaootélts'ulh, 'et ndudútehnilh, ‘Ndun Yak'usda boozi be whusatéyalh, 'en degha nus hoonzoo buts'ó telts'ulh,’ 'et k'an zeh suteh'ilh!” 
\c 24  
\s1 Njan Lizwif hubuluglez whucho hoolah whutéleh, 'et Sizi huwu yalhtuk 
\p  
\v 1 'Aw 'et njan luglez whucho Sizi 'az whenaja hoh yugha hoodul'eh highu nindel. Njan luglez whucho nts'e na'a 'uhóolya 'et whuhínulhtun.  
\v 2 'Et Sizi ndo búlhni, “Njan ts'iyawh 'aw chaoonuzulh'en 'ih? Ts'ah'un na'a 'ún whudusni, 'aw lhuk'i tse lhk'uchadutésdla, ts'iyawh nadúntejulh ho' hoont'ah.” 
\s1 Ndet hoh wheóoduteltsilh, 'et huwa nt'ets'onoozeh 
\p  
\v 3 'Aw 'et haoodet'aiyaz dzulh Olive hiyulhni, 'et usda. 'Et ndunnah yugha hoodul'eh ts'iyawh highu nindel, 'ink'ez whu'izyaz hiyoodulhkut, “Njan nket'ah 'uwhuténilh? Nts'oh whudezulh hoh whusanátandalh, 'ink'ez nts'oh huwa whudezulh hoh whulatah whutele? Ndet hoh wheóoduteltsilh, 'et huwa nt'ets'onoozeh? 'Et nendudíni!”  
\v 4 'Aw 'et Sizi ndo búlhni, “Soo cho howahli. Khun teh dune nanohwhunoo'ah gunih.  
\v 5 'Alha lhanah soozi bugha whusahutedulh 'ink'ez 'uhudutenilh, ndun Christ unli, si 'ust'ah, nduhutni hoh lhanah nahunte'ah.  
\v 6 Dune nehughan whulh 'udutéhts'o. 'Ink'ez dune lhutegan chah howu yahutelhtuk. 'Et chah whudutéhts'o. Khun teh whénoolhujut gunih. Njan dawhutenilh, 'et ts'iyawh nduwhutenilh, 'et whunts'ih 'awhuz whulatah ilah 'uhoont'ah.  
\v 7 'Et huwa lhelhdowh dédowh lhch'az nehúdutadulh. 'Ink'ez yinkak ndulhcho hubudayi cho be 'ustl'ennah, 'en chah lhehútedulh. 'Et dai whúteleh, 'ink'ez dada chah whutéleh. 'Et lhelhdun yun nutughetnah.  
\v 8 Ndi ts'iyawh be dzuh nuts'udeh, 'i k'an be whewhudít'en.  
\v 9 'Et neooninzut t'eh, 'et dzuh nunohotilhdeh ka whutl'anohotelelh. Bulunah nuhoteghan. 'Ink'ez si soozi bugha 'udun yun k'ut whut'en nuhts'o dutetnik.  
\v 10 'Et hukw'elh'az 'et lhanah huba dzuh tele, 'ink'ez nuhwhenich'oh nuhtah lhgha hawhútelhyih 'ink'ez lhts'udutehtnih.  
\v 11 Lhanah whuts'it be nus whunilh'en hinli, 'en lhanah dune nahunte'ah.  
\v 12 'Ink'ez ndunnah 'uk'unucha'ust'en, 'en 'o nus 'uhultsi' tele. Dune ye lhk'etsi', 'i chah k'ah 'utenilh.  
\v 13 'Et whunts'ih ndunnah soo whulatah whuts'un whechahítsaz, 'aw 'en zeh hudutejih.  
\v 14 'Et nts'e na'a Yak'usda yak'uz ts'un dune k'une' whul'en, 'en bugha khunek unzoo, 'i yun k'ut ndulcho hoh be yatetuk. 'I be 'udun yun k'ut whut'en, 'en huba whubuntelhtun tele. 'Et zeh 'aw 'et whulatah whusawhételts'ulh.” 
\s1 Degha nus whewhunujut 
\p  
\v 15 “'Et huwa ndi degha nus be whunujut, 'en hoolah yutelhtsilh, 'en degha nus whudezti ts'ih siyin hoh nulh'en t'eh, ndun Daniel nus whunilh'en hoh da howu yalhtuk inle. (Soo zélhts'ai, ndi ndan yuk'eyalhtuk, 'en soo cho bubeni taóodoolts'it).  
\v 16 'Et ndan Judea yun k'ut hudelhts'i, dzulhyaz k'uz tsihutoolhdelh.  
\v 17 Ndan bukoo hukw'usda khun teh nanaóoja 'ink'ez bukoo ts'ih na'óolhchoot gunih.  
\v 18 Ndan haníyeh k'et 'ut'en, 'en khun bukoo ts'ih dunaih kunaóoda gunih.  
\v 19 'Et hoh t'eh, ndan ts'ekoo helchan, 'ink'ez ndan buzkeh ye'úlht'ukw, 'en huba tube 'o nus whutetsi'.  
\v 20 Nket'ah whuch'a tsiz telhdulh, khi k'us nats'ulyis dzin, 'et teh 'uhoneh gunih, 'et huba tenadahdli.  
\v 21 'Et 'alha whusawhélts'ut t'eh, hooncha dune dzuh nuhutedeh. 'Et ndi yun k'ut whe'whudit'en da, 'ink'ez k'an dzin whuts'un, 'aw whuz na'a doo chah zeh ndó honeh ghaít'ah, 'ilhuh zeh 'uwhutenilh.  
\v 22 Hoh t'eh nts'oh whugha whudezulh hoondukw nachahwháhdlel t'eh, 'aw dune hudoojih hoolah. 'Et whunts'ih 'utahálya, 'en hubugha hoondukw whutelhtsilh.  
\v 23 'Et ndun Christ njan usda k'us nwun usda, 'et ndun nuhwhuhútni t'eh, khun nuhwhuba 'alha hudooni gunih.  
\v 24 'Alha lhanah whuts'it be Christ la'dadil'i 'ink'ez whuts'it be nus whunilh'en, 'en lhanah nuhtah whutele. 'Ink'ez nuhtah tube hooncha tune'hutet'en. 'Ink'ez huwa 'et'en chah nuhtah ne'hutet'en. 'Et ndi njan ndótet'ilh, khun teh 'utahálya nabonoo'ah huninzun, 'et hukwa' hutet'ilh.  
\v 25 'Et sih soo zulhts'ai, whutsuh whudelhdzulh 'uda nuhwhudáni.  
\v 26 'Et huwa dune ndun whulhni t'eh, ‘Nulh'en nda 'et dune chahóot'ih 'et usda!’ hutni t'eh, khun whuz toohdelh gunih. K'us, ‘'Et bukoo bez ts'ih usda,’ hutni t'eh, khun nuhwhuba 'alha hudooni gunih.  
\v 27 Ndez na'a njan nduwhútenilh, 'et ditnik kwun ndaz de hadánat 'ink'ez nuk ts'un whedanat. 'Et ts'iyannah dune yunoolh'en ka, 'et whuz na'a yinkak dune ye' whusanatedalh.  
\v 28 'Et huwa nts'e neyust'e súlht'i, 'et sbalyan 'ilhuwezdel. 
\s1 Yinkak dune ye' whusanátedalh 
\p  
\v 29 “'Et dune dzuh nuhutedeh, 
\q1 'et ndúhooja t'eh, hukw'elh'az 'ahoh sa dulhgus tele. 
\q2 'Ulh'ek ooza chah 'aw be chahoodest'en tele. 
\q1 Sum chah ts'iyawh ndus de hantejulh. 
\q2 'Ink'ez ndai yak'uz whelhtus ndulhcho hoh notughetnah. 
\p  
\v 30 'Et njan nduhóoja t'e, ts'iyannah dune yunoolh'en ka yinkak dune ye' yak'uz ts'ih be hóoduteltsilh. 'Et hoh wheghah whezulh t'eh, 'et dune ndi yun k'ut ndulhcho tso yahutelhtuk. 'Et yinkak dune ye' whuz de úyalh hiyuntelh'ilh. Kw'us k'ut yak'uz ts'ih hatéyalh. Ye dezti, 'i 'ink'ez ye ulhtus, 'i be' tenilh.  
\v 31 Be ts'ujih, 'i tube cho be' duts'o hoh bulizas whuz haóobutelh'alh. 'Utahálya, 'en ts'iyawh 'ilhunaooboohootélelh. Diwh hukw'un'a hutedulh 'ink'ez yaz ndulhcho notedulh. 'Et ndulhcho hoh 'ilhunaooboohootélelh. 
\s1 Mai, fig hiyulhni, buduchun, 'i be nawhutnuk be whuts'odul'eh 
\p  
\v 32 “Ndi mai, fig hiyulhni, buduchun, 'i be nawhutnuk be whuts'odul'eh. Ndi 'i 'int'ah, buzooschum 'ulghih teh, 'Aw 'et but'an whulhlhih, 'i bugha t'ewhunáhzun 'aw 'et dain nilhdukw suli.  
\v 33 Nuhwheni chah whuz na'a zeh ndi ts'iyawh nuhwhudusni. 'Et hoh nket'ah nulh'en 'aw 'et t'ewhunóhzin, 'en nuhwheghah. 'Ants'ih ndati siyin li'hoont'ah.  
\v 34 'Alha ts'ah'un na'a 'ún whudusni, k'an ndoh whudezulh 'aw yachahútesdla, 'et ndi ndó tenilh ts'iyawh 'et lhawhúdutenilh, 'et whuts'un.  
\v 35 Yaz 'ink'ez ndi yun k'ut 'i chah hoolah whutele. 'Et whunts'ih ndi sughunek 'aw hoolah chatesdle.  
\v 36 Ndet dzin 'ink'ez nts'oh whugha whudezulh 'uwhutenilh, 'aw dune nt'echaoonízun. Lizas yak'uz hudelhts'i, 'en whunts'ih 'aw nt'ehonízun. Se'aBá yak'uz usda, 'aw 'en zeh nt'eooninzun.  
\v 37 'Et hoh da Noah khuna da, dune dahant'e, 'et whuz na'a zeh 'uwhutét'ilh hoh yinkak dune ye' whusanátedalh.  
\v 38 Soo cho whunulh'en, yinkak too be' whutenilh da, whutsuh da, ts'iyannah 'a'alh 'ink'ez 'uhutnai. Dune 'ink'ez ts'ekoo bulh lhgho delhts'i, Noah ts'i cho be teyalh 'et whuts'un.  
\v 39 Dune 'aw t'ehonízun nket'ah too hadutébilh. 'Aw 'et hadámbun hoh ts'iyawh too hubanghan. 'Et whuz na'a zeh yinkak dune ye' whusanátedalh t'eh, 'et ndó tenilh.  
\v 40 'Et dzin nanah, 'en haniyeh k'et 'uhut'en. 'Ilhunuh, 'en hitélhcholh 'ink'ez 'ilhunuh 'aw 'et tedalh.  
\v 41 Nanah hite'ulh, 'i hidunulhduz. 'Ilhunuh hitélhcholh 'ink'ez 'ilhunuh 'aw 'et tedalh.  
\v 42 'Et huwa soo cho huwahli! Nts'oh huwa whezulh hoh nuhMoodihti whusateyalh 'aw nt'eoonuzahzun.  
\v 43 'Et ndi nuwheni taoonahle, ndun bukoo moodih, nts'oh huwa whudezulh undunut'ih whusateyalh, 'et t'ewhuninzun t'eh, 'et soo ts'ah'un da huwole, 'ink'ez 'aw hikoo da'óoyis ghaít'ah.  
\v 44 'Et huwa nuhwheni chah lhadóoht'e. 'Alha nts'oh huwa whudezulh, 'et buka tsih chawhahlih, 'et yinkak dune ye', 'et whusanátedalh.” 
\s1 'Ulhna ts'ah'un 'int'ah 
\p  
\v 45 “K'us ndan 'ulhna, 'en ts'ah'un 'int'ah 'ink'ez whunih 'int'ah? 'en 'int'ah, bumoodih dich'oh 'en 'onghunnah 'ulhna bukoo humoodih yutelhtsilh. 'Et soo hoh hite'alh, 'i hubugha ite'alh.  
\v 46 'Et bumoodih whusanaja teh 'ink'ez 'ulhna whuz na'a nduja, 'en degha nus hoonzoo buts'uh whélts'ulh.  
\v 47 'Alha 'ún whudusni, ndai yit'i, 'i chah ts'iyawh k'une' yul'en yutelhtsilh.  
\v 48 'Et whunts'ih ndun be 'ulhna ntsi' dich'oh budzi yuh 'et nduninzun, ‘SMoodih sa sla whusanádaih.’  
\v 49 'Et khunyaz 'onghunnah dudulh 'ulhna hububeyih, 'ink'ez tatnai chah hubula whe'ni'al 'ink'ez hubula tawhénitnai.  
\v 50 Ndet dzin ndun bumoodih whusanátedalh 'ink'ez nts'o huwa 'uhunit'oh utenilh 'aw t'ewhunízun, 'et wheghah 'uhunet'oh whusanátedalh.  
\v 51 'Et lhulcho lhk'ube' yutelht'oh 'ink'ez ndunnah duba nahudzoo 'en hubuts'itekulh, 'i bulah buts'itekulh. 'Et whuz na'a tso bulh dughoo lhidutelhk'us.” 
\c 25  
\s1 Ndi be nawhutnuk 'i be whuts'odul'eh, 'i lanezinah t'etdukah 'en dune t'ehunízun, skwunlanah, 'en huwhunih 'ink'ez skwunlanah, 'en huwhusnik 'et hubugha 
\p  
\v 1 “Yak'uz nts'e hubudayi cho usda ndi yun k'ut whusawhélts'ut teh, 'et ndez na'a ndó tenilh, lanezi t'etdukah 'en dune t'ehunízun, ndi kwun be whét'en, 'i hiyilhchoot 'ink'ez ndun dune 'at tet'ilh 'az 'et hibalh'i.  
\v 2 Skwunlanah, 'en huwhunih 'ink'ez skwunlanah, 'en huwhusnik.  
\v 3 Ndunnah huwhusnik ndi too dezk'un hit'i 'et whunts'ih ndi too dezk'un hiye náhitelhdzoh, 'i hi'et 'uja.  
\v 4 'Et huwhunih 'en too dezk'un denáhitelhdzoh, 'i chah hitez'ai.  
\v 5 'Et 'at tet'ilh sa sla whusayih. 'Et ts'iyawh nehunentsai 'ink'ez ts'iyawh bulh buk'eóodilts'ut hoh nahunéstez.  
\v 6 Tuzniz bat'en 'ilhunuh hahuyih, ‘'Aw 'et 'at tet'ilh 'az de íyalh. Dinadahdelh 'ink'ez bududéhdelh!’  
\v 7 'Et ndunnah t'etdukah ts'iyawh dihudíndel 'ink'ez too dezk'un, 'i ts'iyawh nahídulhk'an.  
\v 8 Huwhusnik, 'en ndunnah huwhunih hubuhutni, ‘Too dezk'un negha núlhdzeh, netoo dezk'un 'aw 'et bé haooduk'aih!’  
\v 9 'Et ndunnah huwhunih, ‘'Awundooh!’ hutni ‘Nuhgha nidulze t'eh, nuhwheni 'ink'ez nuwheni chah 'aw neba soo cha'iltsuk.’ 'Et hubuhutni, ‘'E'óoket ts'ih whuz ahdulh, 'ink'ez nuhwhenich'oh 'óohket.’  
\v 10 'Et whuz whehandel, 'at tet'ilh buk'elh'at whusaínya. 'Ink'ez ndunnah yuba lhadint'ah, 'en na'hutet'alh ts'ih hiyúlh danindel, 'ink'ez ndati daná'hudentan, 'ink'ez dána'hude'ai.  
\v 11 'Et hukw'elh'az ndunnah t'etdukah huwhusnik whusánahedel hoh, ‘Nemoodih, nemoodih, neba dana'dutintih!’ hiyulhni.  
\v 12 'Et ndo búlhni, ‘'Alha 'aw nt'enwhunuzúszun!’  
\v 13 'Et whuz na'a nuhwheni chah soo cho huwahli! 'Alha ndet dzin 'ink'ez nts'oh whugha whezulh hoh yinkak dune ye' whusanatedalh, 'aw dune t'eoonízun hoolah.” 
\s1 Dune dude 'ulhna, ndai yít'i, 'i butl'ayánla, 'et yak'uz hubudayi cho usda ndult'ah be nawhutnuk 
\p  
\v 14 “Yak'uz ndet hubudayi cho usda, ndi yun k'ut whusawhélts'ut teh, 'et whuz na'a ndó tenilh, ndun dune dukeyah huwu teyalh. 'Et teyalh whutsuh dude 'ulhna 'anih hubudani. Ndai yit'i, 'i hubutl'ayánla.  
\v 15 'Ilhunuh skwunlai sooneya dezti, 'i yutl'aina'ai. 'Et 'ilhunuh chah nankoh sooneya dezti, 'i yutl'ainanzai. 'Et doo chah 'ilhunuh 'en 'ilho zeh yutl'ainanzai. 'Ilhunuh hinli hoh nts'e na'a soo hoonzoo hukw'un'a hiye' whutelilh, 'et wheni butl'ainanzai.  
\v 16 'Et hukw'elh'az 'aw 'et whinya. 'Et 'ilhunuh skwunlai yutl'ainanzai, 'en 'o 'un skwunlai uneltsuk, 'i ye na'yínla.  
\v 17 'Et whuz na'a zeh 'ilhunuh 'en nankoh yutl'ainanzai hoh nankoh ye yúba na'yínla.  
\v 18 'Et whunts'ih 'ilhunuh lhuk'i zeh yutl'aina'ai, 'en yun hahónkai 'ink'ez whuz dumoodih buzooneya yuntelh'i.  
\v 19 'Et hukw'elh'az sa inle hoh ndunnah 'ulhna hubumoodih whusanája. 'Et nahooté'alh hukwa' ninzun nts'e na'a dahiyínla.  
\v 20 'Et ndun skwunlai yutl'ainanzai, 'en skwunlai be 'o 'un 'uneltsuk, 'i yuba whusanáinanzai. 'Et ndi yulhni, ‘Sumoodih skwunlai sooneya dezti, 'i stl'ananzai. Nah! Nilh'en skwunlai be 'o nus mba na'usdla.’  
\v 21 'Et bumoodih ndi yulhni, ‘Tube soo 'inja! Nyun tube inzoo. Nduhóolhcho k'une' nyutelh'en. Nyun tube 'ulhna unzoo inli. 'Et hoontsoolyaz k'une' nyutelh'en inle. 'Et k'an n'un hoh lhai ghu tanleh. 'Anih! Ndai nyumoodih ye hoont'i, 'i nyun chah be hóotant'i.’  
\v 22 'Et 'ilhunuh nankoh sooneya dezti, 'i yutl'ainanzai, 'en chah whusainya. 'Et ndi yulhni, ‘Sumoodih nankoh sooneya dezti, 'i stl'ananzai. Nah! Nilh'en nankoh be 'o nus mba na'usdla.’  
\v 23 'Et bumoodih ndi yulhni, ‘Tube soo 'inja! Nyun chah tube inzoo. Nduhóolhcho k'une' nyutelh'en. Nyun chah tube 'ulhna unzoo inli. 'Et nyun chah hoontsolyaz k'une' nyutelh'en inle. 'Et k'an nyun chah n'un hoh lhai ghu tanlelh. 'Et nyun chah 'anih! Ndai nyumoodih ye hoont'i, 'i nyun chah be hootant'i.’  
\v 24 'Et doo chah 'ilhunuh 'ilhuk'i sooneya dezti yutl'ainánzai, 'en chah whusainya 'ink'ez ndi yúlhni, ‘Sumoodih t'eoonuszun nyun 'aw t'echa'nínzun 'unint'ah. Nts'e 'acha'ninlel 'et whunts'ih 'et ha'ninle. Nts'e haneyeh whuyúchaninlel 'et whunts'ih 'et chah ha'nínle.  
\v 25 Tube whenlhujut 'et huwa ndi sooneya dezti yun yuh ts'ih ntélh'i. Nah! Nilh'en ndi stl'ana'ai, 'i ntl'ananús'aih.’  
\v 26 'Et bumoodih 'uyúlhni, ‘Nyun níntsi' 'ink'ez tsi'dintnik 'ulhna 'int'ah. 'Alha t'eooninzun nts'e 'acha'nuzusdlah, 'et whunts'ih 'et chah ha' nusdle. 'Ink'ez nts'e haníyeh whucha'núsdlel, 'et whunts'ih 'et chah ha' nusdle.  
\v 27 'Et huwa hoh da ndez na'a njan ndónleh huba' hoont'ah. Ndi uszooneya ntl'anadzai, 'i sooneya lhk'enadunudzih, 'en butl'achainuzínzai. 'Et t'eh da uszooneya 'o nus 'uneltsuk, 'i be na'óotneh wule da.’  
\v 28 'Et huwa ndo búlhni, ‘Ndunnah ndi uszooneya dezti, 'i bugha nailhúchoot. Ndun lanezi sooneya dezti, 'i yit'i, 'en bugha inéhzaih.  
\v 29 'Et ndan yulah zeh ut'i, 'en 'o nus lhai bugha itélts'ulh. 'Et whuz na'a lhai tet'ilh. 'Et whunts'ih ndan ntsoolyaz ut'i, 'i whunts'ih bughu nayutélchulh.  
\v 30 'Aw 'et ndun 'ulhna ntsi', ulhchoot 'ink'ez 'az tsahólhgus yuh ts'ih téhnoh.’ 'Et whuz tso bulh dughoo lhudoolhk'us sih.” 
\s1 Yinkak dune ye' whusanátedalh teh, 'et t'eh yinkak dune, 'en ts'iyawh huba nahuteyeh 
\p  
\v 31 “'Aw 'et yinkak dune ye' nket'ah buts'u ha 'ánduz hoh whusanátedalh teh, 'et ndunnah lizas lubeshi bughoh hoolah, 'en hiyulh whusanátedulh. 'Et 'ink'ez yuk'usda cho dezti, 'i k'ut nanátl'adutedalh.  
\v 32 'Et 'ink'ez yinkak dune, 'en ts'iyawh hibut 'ilhunaoobuhootélelh. 'Et sheep ghunli k'una'a sheep, 'i sbai tahanaítelelh.  
\v 33 Sheepyaz 'en nalhnih ts'un ts'ih nebutelelh. 'Ink'ez sbai 'en 'íntl'as ts'un ts'ih nebutelelh.  
\v 34 'Et hubudayi cho 'et ndunnah nalhnih ts'un ts'ih 'int'ah 'et whuz na'a ndubudutenilh, ‘Nuhwheni se'aBá degha nus hoonzoo nuhghá whults'ut ahli. 'Et huwa 'anih! Ndi yun 'utelnilh whutsuh, ndet hubudayi cho yak'uz úsda, 'et ndet nuhwhuba lhaoodinla, 'et k'an zeh nuhtl'aootelts'ulh.  
\v 35 Soo cho whunulh'en, suye'élts'ul hoh 'ates'alh, 'i sugha náh'ai. Ta'oosde hoh ndai tesnilh, 'i sugha náhkai. 'Uts'un whút'en usdli 'et whunts'ih nuhwhukoo ts'ih dásunulhti.  
\v 36 'Aw naih chaúst'i hoh 'enásalhti. Ndusda hoh sts'un nusahdel. Stsak'esida hoh suts'un nusahdel.’  
\v 37 'Ink'ez ndunnah ts'ah'un 'int'ah hiyoodutélhkut, ‘NeMoodihti nkeda nye'élts'ul hoh nts'a'en 'ink'ez tá'alh, 'i ngházni'ai? 'Ink'ez ta'óonde hoh tantnilh, 'i nghaznínkai?  
\v 38 'Et nkeda 'uts'un whút'en inli hoh dánts'unilhti inle? K'us naih chaint'ih hoh naih ngházninla inle?  
\v 39 Nkeda ndinda hoh nts'unálh'en k'us tsak'esinda hoh nts'un nuts'uzdel inle?’  
\v 40 'Et hubudayi cho njan ndoh dúbudutenilh, ‘'Alha, 'i be 'ún whudusni, ndunnah sulhutsinkah, ndunnah 'aw ncha chailah, 'en 'ilhunuh whunts'ih whuz na'a 'et ndóbahla t'eh, 'et si 'usáhla ho' hoont'ah.’  
\v 41 'Aw 'et ndunnah 'intl'as ts'ih 'int'ah, ndez na'a ndo ba duténilh, ‘Ndai Yak'usda ye hunilch'e, 'i nuwhulh 'int'ah sahli! Sch'a nanahdelh! 'Aw 'et ndi kwun 'aw nachanusne, 'i netsudule bulizas huba 'uhóolya, 'et nuhwheni chah whuz tehdulh!  
\v 42 Suye'élts'ul inle 'et whunts'ih 'aw tes'alh, 'i sugha chah'al. Ta'óosde 'et whunts'ih 'aw tesnilh, 'i sugha chahkal.  
\v 43 'Uts'un whut'en usdli, 'aw 'et dachasúlhtel. Hoh da 'aw naih chast'ih 'et whunts'ih 'aw be oosda, 'i hoolah naih sugha chahlel. Hoh da ndusda hoh 'ink'ez tsak'esida, 'aw suts'un nuchahdulh.’  
\v 44 'Et dez na'a 'uhidutenilh, ‘NeMoodihti nkeda da nts'a'en ho' dini? Nkeda nye'ilts'ul 'ink'ez ta'onde? K'us 'uts'un whut'en inle, k'us be dune onle, 'i chaínt'ih? K'us ndinda 'ink'ez tsak'esinda? 'Et whuz na'a nts'a'en 'et whunts'ih 'aw hoonliyaz hoh nlacha'ts'ínil dini?’  
\v 45 'Et ndoh budutenilh, ‘'Alha 'i be 'un whudusni, ndunnah sulhutsinkah 'aw ncha chahílah, 'et 'aw 'ilhunuh whunts'ih whuz na'a nuchaoobahlil. 'Et huwa si chah 'aw nduchásahlil li'hoont'ah.’  
\v 46 'Et nduhint'ah, 'en 'ilhuz wheni dzuh nahutedoh ts'ih hutedulh. 'Et whunts'ih ndunnah ts'ah'un 'int'ah, 'en 'ilhuz hoh ts'ukhuna hubugha ootékulh.” 
\c 26  
\s1 Sizi whu'ízyaz hikunúta hituzelhghelh ka 
\p  
\v 1 'Aw 'et Sizi ts'iyaintsuk lhadúja yugha hoodul'eh 'et ndo búlhni,  
\v 2 “'Et t'eoonahzun 'aw 'et nat dzin whuz'ai butus lhuseya 'et whunahutelnih. 'Et 'ink'ez yinkak dune ye' 'aw 'et butl'ahitelhtelh 'ink'ez lhdulalhgus k'ehiyutelhtelh.”  
\v 3 'Et soo wheghah whezulh hoh, 'et nahuwhulnuk degha ndoh, 'ink'ez Moses be' dustl'us 'uk'ununa'úsduguz, 'ink'ez dune netsuh whudelhdzulh chah, 'en ts'iyawh náwhulnuk degha nus dezti, 'en Caiaphas hiyulhni, bukoo soo' whulcho 'et 'ilhunahuwutédulh.  
\v 4 'Et 'ilho yahalhtuk 'ink'ez huwhuts'it hoh hoonli hiba' hoonla hoh Sizi hitélhcholh 'ink'ez hituzelhghelh.  
\v 5 “'Et whunts'ih 'et njan butus lhuseya 'et whutah 'uts'inla t'eh, 'et hukwa dune lhtahahót'alh.” hutni. 
\s1 Datetsah whutsuh ts'eke Sizi k'unuts'újul, 'i yutsi k'eyilhdze 
\p  
\v 6 'Aw 'et keyah whuyaz Bethany huwhútni, 'et Simon buka whulhjut ínle, leprosy hiyúlhni, bukoo 'et Sizi yuzih usda.  
\v 7 'Et 'ilhunuh ts'eke bughu daninya hoh 'en ndi tse dezti, 'i Alabaster hiyúlhni, 'i be ndi luboodai 'ulya, 'i ye'alh. Ndi k'unutsutjul sooltsun, 'i tube dezti ho' 'int'ah. 'Et kw'uzdai k'ut na'ut'alh hoh yutsi k'eyilhdze.  
\v 8 'Et ndunnah yugha hoodul'eh hinilh'en hukwa cha'hunízun. 'Ink'ez 'en ndúlhodutni, “'Et di ka ndi 'ants'ih tinta' yulh'ih?  
\v 9 Ndi yoo dezti, 'i bé' ts'onket 'ink'ez, 'i ts'iyawh tehel'en, 'en hubugha íts'oodzaih wule da!”  
\v 10 'Et Sizi t'eoonanzin 'et ndo búlhni, “Ndun ts'eke 'aw buts'áhachaoozah'ak. 'Ut'en unzoo, 'i suba 'uyínla ho' 'int'ah.  
\v 11 'Ahoolhyez tehel'en hubulh áht'ah, 'et whunts'ih si 'ahoolhyez 'aw nohwhulh cha'tuzest'il.  
\v 12 'Alha ndi k'unutsutjul sooltsun, 'i 'adutestelh huba suyust'e yuk'eyílhdze hoh 'ut'en. 'Et whuz na'a lhasúdinla.  
\v 13 'Alha 'un whudusni ndi yun k'ut ndulhcho ndi khunek unzoo, 'i nudutékat, ndun ts'eke ndet 'uhoonla, 'et hukw'u naootitnuk 'et hoh dune yunatelnih.” 
\s1 Judas 'en Sizi be 'óotekulh hukwa' ninzun 
\p  
\v 14 'Aw 'et ndunnah lanezi 'o 'at nanah, 'en hubutah 'ilhunuh Judas Iscariot hiyulhni, 'en náwhulnuk bumoodih buts'uh whinya.  
\v 15 'Et ndo búlhni, “Daltsuk sugha ntéh'alh ndun dune nuhwhutl'aílhti t'eh?” “'Et tat lanezi sooneya, silver,” hiyulhni, 'et 'uneltsuk hiba hiyoodalhto.  
\v 16 'Et whuts'un nts'e na'a butl'aitelhtelh 'et hukwunúta. 
\s1 Sizi 'en yugha hoodul'eh butus lhuséya hubulh na'ut'alh 
\p  
\v 17 'Et k'an 'aw 'et ndi lhes chantíldoh dzin whusawhélts'ut hoh ndunnah Sizi yugha hoodul'eh, 'en highu nindel 'ink'ez huyoodulhkut, “Njan Hubutus Lhuseya 'ute'alh, nts'e mba lhats'odutelilh hukwa' nínzun?”  
\v 18 'Et ndo búlhni, “Nyooz keyah whuti whuz ahdulh. 'Ilhunuh dune suba ndudóohtni, ‘Nehodulh'eh njan ndutni, 'aw 'et suba nilhdukw whezulh. Nkoo ts'ih ndunnah sugha hoodul'eh njan butus lhuseya, 'et 'ilho hubulh whunatelnih.’ ”  
\v 19 'Ink'ez yugha hoodul'eh Sizi daja hubudani, 'et whuz na'a nduhuja. 'Ink'ez njan Hubutus Lhuseya 'et wheni lhaháduja.  
\v 20 'Aw 'et hulhgha whusahonzut lanezi 'o 'at nanah yugha hoodul'eh, 'en hubulh natl'adeda hubula na'tet'alh ka.  
\v 21 'Et 'uha'alh hubutah ndo búlhni, “'Alha 'ún whudusni njan nuhtah 'ilhunuh whutl'asutelhtelh.”  
\v 22 'Et ts'iyawh ni huzdli, 'ink'ez 'ilhunah hinli hoh hiyoodulhkut, “SMoodihti si tulih sudini?”  
\v 23 'Et ndo búlhni, “Ndan dules sulh toonayuz'ai, 'en 'utenilh whutl'asútelhtelh.  
\v 24 'Alha yinkak dune ye' nts'e na'a ba 'uk'e'eduguz, whuz na'a 'utenilh datetsah. 'Et dune ndan whutl'ayálhti, 'en dune degha nus hoontsi' bugha ootélts'ulh. Ndun dune 'aw cha'hóolel t'eh, 'et sih 'o nus buba hózoo wule da.”  
\v 25 'Et Judas, ndun whutl'aitelhtelh, 'en Sizi yoodulhkut, “Rabbi si ih sudíni?” 'Et ndi yúlhni, “Nyunch'oh 'udini.” 
\s1 Sizi 'udek'elh'az na'ut'alh 
\p  
\v 26 'Aw 'et 'uhan'al hoh Sizi lhes yilhchoot. Suchanailya ni hoh tenadedli. Taidalhkut 'ink'ez yugha hoodul'eh hubutaininik. 'Et ndo búlhni, “Úlhchoot 'ink'ez ah'alh. Ndi suyust'e 'int'ah.”  
\v 27 'Et lubot 'i chah yilhchoot 'ink'ez suchanailya ni hoh tenadedli. 'Et ndo búlhni, “Nuhwheni ts'iyawh ndi wahnai.  
\v 28 Ndi k'andit khunek 'i suzkai be nuhts'u nahuzíya. Lhanah ba nadútelt'ih. 'Et 'i be bulubeshi huba hoolah natedleh.  
\v 29 Njan 'et 'un whudusni, ndi mai too, doo chah zeh 'aw chatuzésnil. 'Et whunts'ih ndi mai too k'an, 'i nuwhulh tesnilh. Nts'e se'aBá hubudayi cho unli, 'et whuz lhgha dahdel, 'et dzin nuhwhubulh tesnilh.”  
\v 30 'Et Yak'usda buyun be héjun 'ink'ez ndoh dzulhyaz k'uz Olive hiyulhni, whuz whehandel.  
\v 31 'Aw 'et Sizi ndo búlhni, “K'an 'ulh'ek nuhwheni ts'iyawh skahóoyatehle. Ndez na'a 'uk'e'edúguz hoh ndutni, 
\q1 ‘Sheep ghunli, tuzelghelh huba whutl'aitelhtelh. 
\q2 'Ink'ez 'et sheep ts'iyawh lhtatelh'us.’ 
\p  
\v 32 'Et dinadusja hukw'elh'az t'eh, 'et yun k'ut Galilee ts'ih nuhwhutsah tesyalh.” 
\s1 Sizi, 'en Peter ndi yúlhni, “T'echasunuzinzun dutanilh” 
\p  
\v 33 'Et Peter ndi yúlhni, “'Et ts'iyawh nyun nkayahutele, 'et whunts'ih si 'aw nkayáchatuzésdle.”  
\v 34 'Et Sizi njan ndi yulhni, “'Alha, 'i be 'un nyudúsni, 'et k'an 'ulh'ek ligok dune 'uduténilh whutsuh, 'et tat t'echasunuzínzun dutanilh.”  
\v 35 'Et Peter 'utni, “Nyúlh datesah t'eh, 'et whunts'ih 'aw t'echanyunuzúszun doosni ghaít'ah.” 'Et 'onghun yugha hoodul'eh, 'en chah whuz na'a zeh 'uhutni. 
\s1 Sizi Gethsemane 'et tenadedli 
\p  
\v 36 'Et 'ilhunuh haniyeh k'et Gethsemane huwhútni ts'ih whuz hunindel hoh Sizi yugha hoodul'eh ndo búlhni, “Nuhwheni njan delhúts'i. 'Et si ye'at tenadutesdli.”  
\v 37 Peter 'ink'ez Zebedee buzkeh, nanah, 'en hubilhchoot 'ink'ez dulh whebeldel. 'Aw 'et tso cho buk'édilts'ut 'ink'ez budzi tube yuk 'uja.  
\v 38 'Ink'ez ndo búlhni, “Suzul tube tso suli k'et 'aw 'et datesah li'ust'ah. Njan delhúts'i 'ink'ez sula huwahli.”  
\v 39 'O 'unyaz whinya hoh 'et nachaneti 'ink'ez tenawhéndunidli 'ink'ez njan ndutni, “'ABá ndi lubot be dzuh nuteszut, 'i whuz na'a 'int'ah t'eh, 'et whute senghólts'it. 'Et whunts'ih 'aw si hukwa' nuszun k'una'a ilah. Nyun hukwa' ninzun hukw'un'a 'et 'uhóneh.”  
\v 40 'Et ndunnah yugha hoodul'eh nahunistez hoh bughu nanja. 'Et Peter ndi yulhni, “'Aw ih lhuk'i hukw'e'uhunint'o whuts'un sula ghónle ghaít'ah?  
\v 41 Tink'us nínt'uk whuch'a howinli 'ink'ez tenadinli! 'Alha dune yéghah whuz na'a hukwa' ninzun, 'et whunts'ih buyust'e laít'ah.”  
\v 42 'Et doo chah zeh whulh nat bugho whenaja tenadutedli ka. 'Et njan ndutni, “'ABá ndi lubot ts'iyawh usnai t'eh, 'et k'an zeh sughu natalcholh. 'Et whuz na'a zeh hukwa' ninzun t'eh, 'et ndó hot'e.”  
\v 43 'Et doo chah zeh nahuneztez hoh bughu nanja. Bulh huba yilhtus k'et 'aw hitóo'en ghaít'ah.  
\v 44 'Aw 'et bugho whenaja 'ink'ez whulh tat, 'i khunek 'i be zeh tenadedli.  
\v 45 'Aw 'et yugha hoodul'eh bughu nanja 'ink'ez ndo búlhni, “'Awhuz nalhúyis 'ink'ez sahtez hó ih aht'ah? Soo zélhts'ai 'aw 'et suba whusawhélts'ut. Yinkak dune ye' 'en ndunnah lubeshi 'uhulh'en, 'en butl'asátelhtelh.  
\v 46 Soo 'a dinadahdelh! 'Aw 'et uztoodelh sih! Whunulh'en ndun butl'asútelhtelh, 'aw 'et seghah uyalh!” 
\s1 Sizi 'aw 'et hiyílhchoot 
\p  
\v 47 'Awhuz yalhtuk hoh 'et khunyaz Judas, 'en whusainya, 'en ndunnah lanezi 'o 'at nanah whuhél'a, 'en ndun 'ilhunuh 'int'ah. 'En bulh lhanah dune yulh whusaindel. Bulunah soh cho nuhule, 'ink'ez bulunah be netunuzdult'o nadule. Náwhulnuk bumoodih 'ink'ez dune netsuh whudelhdzulh, 'en whusaoohábahalh'a.  
\v 48 'Aw 'et ndun Sizi hubutl'aitelhtelh, 'en 'ilhunahuwésdel ndo búlhni, “Ndan nandunests'ooz, 'en 'udúsni. 'En 'ahoh olhchoot!”  
\v 49 'Et 'ahoh Sizi yughu ninya hoh “Dahooja Rabbi,” yulhni 'ink'ez 'en naindunants'ooz.  
\v 50 'Et Sizi ndutni, “Sulh dune di ka whusainya?” 'Aw 'et whusahandel 'ink'ez Sizi 'aw 'et hiyilhchoot.  
\v 51 'Et khunyaz 'ilhunuh Sizi yulh 'int'ah ndi soh cho hayálhtsus 'ink'ez náwhulnuk degha nus dezti be 'ulhna, 'en yudzo yuts'ah habé' yalht'o.  
\v 52 'Et Sizi ndi yulhni, “Nyoo soh cho t'unádintih! 'Alha ndunnah 'et nduhút'en, 'en 'et hukw'e dahutetsah.  
\v 53 'Et si hukwa' nuszun t'eh, se'aBá oodalhkut t'eh 'ink'ez k'an 'ahoh 70,000 lizas 'o 'un 'uhuneltsuk, 'en da sts'o tl'aboolelh wule da sula hutenilh ka. 'Et 'aw t'eoonuzínzun hoh 'int'en.  
\v 54 'Et zeh ndust'en t'eh, nts'e na'a Yak'usda bughunek lhadútenilh? Nts'e na'a sts'un dawhut'ih, 'et whuz na'a 'uhóneh huba' hoont'ah.”  
\v 55 'Aw 'et wheghah 'uhunet'oh hoh Sizi 'ilhunahuwésdel ndo búlhni, “'Et di ka soh cho 'ink'ez be netunuzdult'o chah nudáhle 'ink'ez 'undunaht'ih hukw'u n'a'a skaootéhdel? Dzin totsuk luglez whucho 'et nuhwhutah sída 'ink'ez whunohodulh'eh. 'Et whunts'ih 'aw chasúlhchulh.  
\v 56 'Et huwa, nus whunilh'en bube' dustl'us hukw'e'edúguz, 'et ts'iyawh lhawhúdutenilh.” 'Aw 'et higha hoodul'eh, 'en whulahúdetnik 'ink'ez highut sitélhdel. 
\s1 Sizi naheyelh hububut ninínya 
\p  
\v 57 'Aw 'et ndunnah Sizi hiyilhchoot, 'en náwhulnuk degha nus dezti, Caiaphas hiyulhni, ghu hinílhti. Moses be' dustl'us 'uk'ununa'úsduguz, 'ink'ez dune tsuh whudelhdzulh chah, whuz 'ilhunahuwésdel.  
\v 58 'Et Peter 'o niz de hubuneyalh hoh náwhulnuk degha nus dezti bukoo whuna'nezdútl'oo whuz níbunenya. Whuz hubughu daninya hoh nélhghel buzih natl'adeda 'ink'ez na'dunildzilh, daootenilh whuntelh'ilh 'et hukwa.  
\v 59 'Et náwhulnuk bumoodih, 'ink'ez dune netsuh whudelhdzulh chah, 'ink'ez nahuheyelh chah, 'en ts'iyawh hoonliyaz whuts'it hubugha highu nahó'alh hukwa' hut'en hituzelhghelh ka.  
\v 60 'Et whunts'ih 'aw hiyulh náho'alh hoolah. Lhanah dune whusahándel 'ink'ez huwhuts'it be highu yalhtuk. 'Et whunts'ih 'awhuz hoonli hiyulh nachawhus'ai. 'Et khunyaz nanah dune huwhuts'it whuz haha'az  
\v 61 hoh nduhútni, “'Et ndun dune 'utni Yak'usda hubuluglez whucho hoolah whutelhtsilh 'ink'ez tat dzin whutah 'udun na'whutelilh ni,” hutni.  
\v 62 'Aw 'et náwhulnuk degha nus dezti didinya 'ink'ez Sizi yoodulhkut, “'Aw ih daja chadáhnil? Daja hutni 'et hubugha daja ninzun?”  
\v 63 'Et Sizi 'aw nt'edusnih. 'Et náwhulnuk degha nus dezti, 'en 'uyulhni, “Ndun Yak'usda khuna, 'en be nyudusni yatalhtuk huba' hoont'ah. 'I be mba nahutedeh. Nedini Christ Yak'usda buYe', 'en ih 'unint'ah?”  
\v 64 'Et Sizi ndi yulhni, “Nyunch'oh 'et 'udíni. 'Et njan hubugha nohwhulh yalhtuk, nk'atlih t'eh yinkak dune ye', 'en ndun be hóolhtus, 'en nalhnih ts'ih yughu usda, 'et whuteh'ilh. 'Ink'ez kw'us k'ut ndus de hatéyalh, 'et chah whuteh'ilh.”  
\v 65 'Et náwhulnuk degha nus dezti ye usda, 'i bubut gha lhts'e yalhch'ul 'ink'ez 'utni, “Yak'usda ch'a detni hoh yalhtuk. 'Aw 'uyoon nedóni hukwa cha'uznízun. K'an whunulh'en Yak'usda ch'a detni ts'iyawh nuhwheni nuhnalh 'utni.  
\v 66 Daja nahzun?” 'Et 'uhutni, “Daóotsah huba 'uhoont'ah!”  
\v 67 Hinen ts'ih huyoodunuzewh. Huyoolhchis 'ink'ez bulunah hiyoonukat.  
\v 68 'Et whuz na'a nduhíyulhni, “Neba nus whutan'ilh. Nyun 'int'ah Christ inli t'eh, ndan 'unyinla nyunézkuk?” hiyúlhni. 
\s1 Peter 'utni, “Sizi 'aw t'echanuzúszun” 
\p  
\v 69 'Et Peter n'az whuna'nesdútl'oo whez ts'ih usda hoh ts'ekeyaz yughu ninya. 'Ink'ez ndi yulhni, “Ndun Sizi Galilee whut'en, nyun chah bulh 'int'en inle!”  
\v 70 'Et ts'iyawh hububut whuts'oodedlai hoh ndutni, “Daja dini 'aw nt'echaoonuzúszun.”  
\v 71 'Et 'az tínanja. 'Uyoon ts'eke chah yunilh'en, 'ink'ez hoh nahudelhúya, 'en ndo búlhni, “Ndun 'en chah Sizi Nazareth whut'en bulh 'int'ah inle.”  
\v 72 'Et doo chah zeh neghan ndoh nalh whuts'oodésdlat hoh ndutni, “Ndun dune 'aw nt'echanuzúszun!”  
\v 73 Hukw'elh'az ndunnah yuzih nuhudelhúya, 'en highu nindel hoh 'uhiyúlhni, “'Alha ndunnah yulh 'uhant'e, 'en nyun chah 'ilhunuh 'int'ah. Nts'e na'a yailhtuk, 'et huwa t'ents'unínzun.”  
\v 74 'Et Peter ndutni, “Yak'usda sts'e'telhtsus 'aw ts'ah'un cha'duzusnih t'eh, ndun dune 'udáhni, 'aw t'echanuzúszun.” 'Et 'ahoh ligok dune 'udéja.  
\v 75 'Et Sizi daja ni 'et Peter whunalnik hoh njan ndutni, “'Et ligok dune 'uduténilh whutsuh, tat 'aw t'echasunuzinzun dutenilh.” 'Et 'az whenaja 'ink'ez tube cho howintse. 
\c 27  
\s1 Sizi, 'en Pilate but ninínya 
\p  
\v 1 'Et 'om bun bundada 'uda náwhulnuk bumoodih, 'en ts'iyawh, dune netsuh whudelhdzulh, 'en chah, 'en Sizi hich'a detni hoh howu yahalhtuk hituzelhghelh hukwa.  
\v 2 'Et Sizi hiyulhghel 'ink'ez yun k'ut whumoodih, 'en Pontius Pilate hiyulhni, hits'un hinilhti. 
\s1 Judas tsená'usduguz 
\p  
\v 3 'Et ndun whutl'ayálhti, 'en Judas hiyúlhni, 'aw 'et Sizi datetsah huba ba nahisda hoh, 'et nt'eoonanzin hoh tube budzi nduda suli. 'Et ndi tat lanezi sooneya silver hiyulhni, ndunnah náwhulnuk bumoodih 'ink'ez dune netsuh whudelhdzulh chah, buba whusanáyandzai.  
\v 4 'Et ndo búlhni, “Njan ndusja hoh tinta' nust'en. Ndun dune nuhts'un whutl'aílhti, 'en 'aw tinta cha'ít'il.” 'Et 'uhiyúlhni, “Nuwheni neba cha'hóot'ah. Nyunch'oh zeh mba' hoont'ah!”  
\v 5 'Et ndi tat lanezi silver ts'utni, 'i sooneya luglez whucho yun hububut nayántsut. 'Et 'ink'ez 'az whenaja 'ink'ez tsená'usduguz.  
\v 6 'Et ndunnah náwhulnuk bumoodih ndi sooneya silver ts'utni, 'i hiyilhchoot 'ink'ez 'uhutni, “Dune buzkai suli, 'i 'int'ah. 'Et huwa 'aw Yak'usda ba be 'úzdla, 'i be náts'oodzaih ghaít'ah.”  
\v 7 'Et dich'oh dutah howu yahalhtuk. 'Ink'ez ndan lhez 'oosa' 'ulh'en, ndi sooneya 'i be yun hiyónket. 'I k'ut 'uts'un whut'en wheyóbahule 'et wheni.  
\v 8 'Et huwa soo k'an njan dzin 'et whuts'un ndi yun boozi 'i 'uskai yun hiyulhni.  
\v 9 'Et whuz na'a hoh da ndun nus whunilh'en Jeremiah, daja ni 'et nduhóolcho túne' whust'en 'et lhaóodija njan ndutni, “Ndi sooneya silver ts'utni, 'et tat lanezi 'et 'uneltsuk ulhchoot. 'Et 'uneltsuk hiyoodolhto, ndun Israel hits'uh hainde, 'en huba k'elha hiyoolhtsilh.  
\v 10 'Ink'ez lhez 'oosa' 'ulh'en, 'en buyun hiyónket. 'Et whuz na'a Moodihti sudani.” 
\s1 Sizi, 'en Pilate yubut siyin 
\p  
\v 11 'Aw 'et Sizi ndun yun moodih 'en yubut siyin. 'En yun moodih yoodulhkut, “Nyun ih 'int'ah Lizwif hubudayi cho inli?” 'Et Sizi ndi yúlhni, “A, 'alha dini.”  
\v 12 'Ink'ez ndunnah Lizwif bumoodih 'ink'ez dune netsuh whudelhdzulh chah, 'en hik'eho'alh hukwa' hut'en. 'Et whunts'ih 'aw hoonliyaz cha'dínil.  
\v 13 'Et Pilate yoodulhkut, “'Aw ih cha'duzínts'uk, 'aw daooneltsuk hoh nch'a yahálhtuk?”  
\v 14 'Et 'aw lhuk'i khunek be whunts'ih daja chadinil. 'Et hoh yun k'ut whumoodih tube buba hooncha. 
\s1 Pilate, 'en Barabbas buba yulanadetnik 
\p  
\v 15 'Et nawhudezulh totsuk Lizwif butus lhuseya 'et whunahulnih, 'et whutah yun moodih ndan tsak'esda 'ilhunuh hika' ninzun, 'en ts'iyannah buts'un lanadutetnih. 'Et whuz na'a buk'ah ts'ih 'uhoont'ah.  
\v 16 'Ilhunuh tsak'esda, 'en Barabbas hiyulhni, ts'iyannah t'ehinínzun.  
\v 17 'Et ts'iyawh 'ilhunahuwésdel hoh Pilate huboodulhkut, “Ndan nuhwhuba bulanadutesnih hukwa' nahzun, Barabbas k'us Sizi, 'en Christ hiyulhni?”  
\v 18 T'eooninzun 'oolnih bugha butl'ahíyalhti.  
\v 19 'Et Pilate dune ba nahedilh, 'i kw'usuda k'usda hoh bu'at 'en khunek yuts'ó tl'aida'ai, 'et ndi yulhni, “Ndun dune 'en ts'ah'un 'int'ah. Hoonliyaz onleh gunih! 'Alha k'an dzin 'en bugha huwu nusíti 'et hoh dzuh nusízut.”  
\v 20 'Et ndunnah náwhulnuk bumoodih 'ink'ez dune netsuh whudelhdzulh chah, 'en 'ilhunahuwésdel ba hubahoont'i 'et whuz na'a 'uhóoneh ka, 'en Pilate, Barabbas yulanadootnih 'ink'ez Sizi hoolah hiyoolhtsilh.  
\v 21 'Aw 'et yun moodih 'en huboodulhkut, “Ndunnah nanah, 'en k'us ndan nuhwhuba bulanadutesnih hukwa' nahzun?” 'Ink'ez 'et 'uhiyúlhni, “Barabbas.”  
\v 22 'Et Pilate ndo búlhni, “'Et ndun do, Sizi ndun Christ hiyúlhni, 'en nts'e na'a chah daóosdleh ka?” 'Et 'ilhunahuwésdel nduhíyulhni, “Lhdulalhgus kélhtih!”  
\v 23 'Et yun moodih 'et ndutni, “Di ka? Ndet hoh tinta' 'ant'en?” 'Et whunts'ih sulyehúdelya, “Lhdulalhgus kélhtih!” hutni.  
\v 24 'Et Pilate t'ewhunínzun 'aw hoonliyaz 'uhooleh ghaít'ah. Ndunnah 'ilhunahuwésdel 'aw 'et lhtahotét'alh li'hoont'ah. 'Ink'ez 'ilhohuwezdel hububut too be lana'elde 'ink'ez ndo búlhni, “Ndun ts'ah'un dune buzkai but'aghóosnalh hukwa cha'nuzúszun. Nuhwhenich'oh zeh nuhwhuba 'uhoont'ah.”  
\v 25 Ts'iyannah dune 'et nduhútni, “Nuwheni ts'iyawh neuzkeh tubulh buzkai whuteleh, 'et nek'éholts'it!”  
\v 26 'Aw 'et Barabbas buba yulanadetnik 'ink'ez Sizi hiyolhtsus. 'Et hukw'elh'az butl'ayálhti lhdulalhgus k'ehíyoolhtelh ka. 
\s1 Nehughan Sizi highu nolhéya 
\p  
\v 27 'Aw 'et yun moodih 'en nehughan huwhut'i, 'en Sizi hiyílhchoot 'ink'ez bukoo ts'ih whehíyalhti, 'et Praetorium huwhútni. 'Et ts'iyawh ndunnah nehughan Sizi higha' wezguz.  
\v 28 'Et hinaih hits'u húnuhuyulhch'ul hoh nalhti dulk'un, 'i be híyalhti.  
\v 29 Whus cho nahinelhbaz, 'i hitsi nihída'ai. 'Ink'ez tl'oghazilh nalhnih ts'ih hila k'ehídantan. Hubudayi cho k'una'a oot'e ka hitl'ahídantan. Hibut nachánuldulh cha' hiyulh'en. 'Et whuz na'a highudloh. 'Ink'ez “Lizwif hubudayi cho sa cho khona!” hiyúlhni.  
\v 30 Highá dizoh, 'ink'ez tl'oghazilh be hitsi oonulht'ah.  
\v 31 'Et highudloh 'ustl'e' 'uhudeja hoh ndi nalhti highun náhuyílchoot 'ink'ez dich'oh bunaih be nahíyalhti. 'Aw 'et lhdulalhgus k'ehítelhtelh ts'ih hítelhti.  
\v 32 'Aw 'et Sizi tehínilhti hoh 'ilhunuh dune Cyrene whut'en 'int'ah, 'en Simon hiyúlhni, 'en hidudezdel hoh ndi Sizi bulhdulalhgus buba idantilh hiyúlhni.  
\v 33 'Aw 'et njan Golgotha ts'uwhútni whuz lhgha hudindel. 'Et ndi khunek ‘'Utsints'un nez'ai,’ ni hoh 'utni.  
\v 34 'Et mai too dunink'ooz, 'i 'ink'ez yoo, gall ts'utni, hitaidenla. 'I yulh yootnai hukwa' huyinla. 'Et yálhka 'ink'ez 'aw yootnai hukwa cha'nízun.  
\v 35 'Et lhdulalhgus yehídunilht'o hukw'elh'az hinaih higha 'áinlih. Dahúja 'et hoh da nus whunilh'en nts'e na'a 'udani, 'et ts'iyawh hukw'u na'a 'uhooja. Ndez na'a njan dudani, 
\q1 “Ndi sunaih dich'oh lhtahiyulya. 
\q1 'Ink'ez bulah higha 'ainli cha' hiyínla.” 
\p  
\v 36 'Aw 'et nátl'ahudelts'i 'ink'ez highunli.  
\v 37 Butsi huwa ndoh ts'ih lhustelyaz whehindunilht'o. 'Ink'ez ndet hik'ehoo'ai 'et 'uk'e'hanguz. 'Et ndutni, 
\qc ndun Sizi 'en 'int'ah Lizwif hubudayi cho. 
\p  
\v 38 Nanah 'uhundunut'ih, 'en chah hiyulh lhdulalhgus k'ebuhilhti. 'Ilhunuh nalhnih ts'ih, 'ink'ez 'ilhunuh 'intl'as ts'ih.  
\v 39 Ndunnah wheghah whehúdelh nodunul'us 'ink'ez hich'a detni hoh yahalhtuk.  
\v 40 'Et 'uhiyúlhni, “Nyun 'int'ah luglez whucho nanaóodutanlelh 'ink'ez tat dzin zeh na'whutanlelh dini! Nyunch'oh 'ududílyih! Yak'usda buYe' inli t'eh, ndi lhdulalhgus k'ut buk'ut nanaíndaih!”  
\v 41 'Et ndunnah náwhulnuk bumoodih, 'en chah whuz na'a zeh highudloh. Moses be' dustl'us 'uk'ununa'úsduguz, 'en chah 'ink'ez dune netsuh whudelhdzulh chah, ts'iyawh whuz na'a zeh 'uhutni hoh ndez na'a njan duhutni,  
\v 42 “'Uyoon ulhyis 'et whunts'ih dich'oh 'aw 'ududoolyih ghaít'ah. Israel buts'u hahánde, 'en ba hubudayi cho unli t'eh, 'et t'eh ndi lhdulalhgus yuk'ut nanaóoja wule da. 'Et t'eh da neba 'alha 'oot'e.  
\v 43 'En Yak'usda t'anínentan. 'Et huwa Yak'usda yuka' ninzun t'eh, k'an 'ahoh da yoolhyih. 'En 'utni si Yak'usda buYe' 'ust'ah.”  
\v 44 Ndunnah 'uhundunut'ih yuzih lhdulalhgus k'usulhti, 'en chah whuz na'a zeh 'et nduhíyulhni. 
\s1 Sizi ye khuna, 'i yuladetnik 
\p  
\v 45 Dzetniz hukw'elh'az 3:00 bat'en 'ink'ez hulhgha 6:00 bat'en 'et whuts'un ndi yun k'ut ndúwhulcho tsahólhgus suli.  
\v 46 'Et 6:00 bat'en Sizi tube cho ka' deduja hoh, “Eli, Eli, lama sabachthani?” Ndi khunek, “SuYak'usda, SuYak'usda di ka sula dantnik,” ni ho' 'utni.  
\v 47 Bulunah dune 'et nuhúdelhuya hidánts'o 'ink'ez 'uhutni, “'Ah! Elijah hahayih hoh 'utni!”  
\v 48 'Et 'ahoh 'ilhunuh whusalgai, 'ink'ez duchun bula'dul'oo, 'i mai too dunink'ooz, 'i ye toonayuztan 'ink'ez nduk Sizi yuzek be naóonulhtsul.  
\v 49 'Onghunnah 'uhutni, “Bukaza'ez! Khunsih, Elijah yughu ninya 'ink'ez tulih yoolhyih.”  
\v 50 Doo chah Sizi tube cho 'udéja 'ink'ez duyéghah yula detnik.  
\v 51 Khunyaz luglez whucho bez ts'ih hukwadelhchooz 'i lhulcho lhk'énch'ul. 'Et yun chah nughésnai, 'ink'ez tse cho chah lhts'edankat.  
\v 52 Ts'un k'ut dune 'adinla 'et cha da' dutezkat. 'Ink'ez lhanah dune Yak'usda bube'ildzun, 'en nahunestez inle, 'en dináhudidel.  
\v 53 'Aw 'et tse be tsa k'et ts'ih hanáhedel, 'ink'ez keyah Jerusalem ts'ih whehandel. 'Et lhanah nalhts'et hube hóodiltsai, 'et whébunelhtan. Sizi nakhitna hukw'elh'az ndulhcho 'et ndúhooja.  
\v 54 'Aw 'et ndun nehughan bumoodih 'en, 'ink'ez yulh 'uhut'en, 'en ndunnah Sizi yughunli, yun nughéznai 'ink'ez nts'oh tuné'whust'en, 'et honalh'en, 'et hoh tube whehunelhújoot 'ink'ez 'et 'uhutni, “'Alha ndun dune, 'en Yak'usda buYe' 'int'ah.”  
\v 55 Lanah ts'ekoo chah 'et nahudelhúya ye 'az de whuts'un honilh'en. 'En Galilee ts'ih hahándel 'uhut'en. 'En Sizi whusahínandel 'ink'ez hiba ne'úst'en 'uhint'ah.  
\v 56 'En hubutah Mary, Magdala whut'en, 'en chah 'ut'en, 'ink'ez Mary, James 'ink'ez Joses bulh 'en hube'ama, 'en chah 'ut'en, 'et Zebedee buyekah 'en be'ama chah, 'ut'en. 
\s1 Joseph, Sizi whuyiyalhti 
\p  
\v 57 'Aw 'et hulhgha wheghah whezulh hoh 'ilhunuh Arimathea whut'en, dune soode'a 'int'ah, 'en Joseph 'uhiyulhni. 'En chah Sizi yugha hoodul'eh 'ilhunuh suli.  
\v 58 'En Pilate ts'ih whinya, 'ink'ez Sizi buyust'e yuts'un ka na'dutni dutl'ayóolhtelh ka. 'Et Pilate ndo búlhni, “Sizi buyust'e ndunnah butl'ayúlhtih.”  
\v 59 'Et Joseph Sizi buyust'e ndus de hanáyalhti 'ink'ez naih dezti, 'i 'aw chaditsun, 'i yugha iwézduz.  
\v 60 'Et dich'oh butse be tsa k'et k'an 'uhoonla, 'et bez ts'ih 'et neínilhti. 'Et tse cho be whudanaindunelhmul 'ink'ez whenája.  
\v 61 Mary Magdala whut'en, 'en chah 'et usda. Njan tsa k'et huwanch'az, 'et 'uyoon Mary chah 'et usda. 
\s1 Sizi nts'e whuhíyalhti, ndi tse k'ut whuduná'hudelhdze 
\p  
\v 62 'Et njan dzenis whuti 'et wheni lhazdutneh dzin 'uhoont'ah. 'Et 'om bun dzin ndunnah náwhulnuk bumoodih 'ink'ez Pharisee chah, 'en ts'iyawh Pilate ts'un whehandel.  
\v 63 'Et ndi híyulhni, “Nemoodih ndun nena'a 'awhuz khuna hoh daja neúlhni, 'et whunats'ulnih hoh ‘Tat dzin inle t'eh dinádutésdalh,’ ni.  
\v 64 'Et hoh nghunek be budóoni njan tsa k'et da'dute'a whulh tat dzin 'et whuts'un. 'Et 'aw ndúchainel t'eh ndunnah yugha hoodul'eh 'ulh'ek whusahándel 'ink'ez hiyust'e hindutet'ih tulih. 'Ink'ez ts'iyannah ndoh budóoni ndunnah yaidla hubutah dinadeja ho' 'int'ah. 'Et whuz na'a 'udek'elh'az whuts'it, 'i 'udechoo, 'i degha nus 'ultsi' whutéleh,” hiyulhni.  
\v 65 'Et Pilate ndo búlhni, “Nuhwheni chah nohhowunli aht'i hoh aht'ah. 'Aw 'et nahdulh 'ink'ez nuhwhenich'oh soo duts'o cho hoh dána'deh'aih!”  
\v 66 'Et whehándel 'ink'ez ndi tse k'ut whuduná'hudelhdze. 'I be duts'o cho whuzdli. 'Et 'ink'ez howu hinli 'en 'et nibanínla. 
\c 28  
\s1 Sizi dinadija 
\p  
\v 1 Nats'ulyis dzin hukw'elh'az hukw'enilhghel, 'et 'udechoo dzin, soo haootelh'en, 'et Mary Magdala whut'en 'ink'ez 'uyoon Mary bulh ts'un k'uz huni'az 'ink'ez honilh'en.  
\v 2 Khunyaz 'ilhunuh neMoodihti bulizas yak'uz hainya. 'Et huwa yun chah nughesnai. Whusainya 'ink'ez ndi tse whudahaidunalhmul, 'ink'ez yuk'étl'adida.  
\v 3 Bunen 'ants'ih ditnik kwun nduwhút'en. Bunaih tsil k'una'a lhiyul.  
\v 4 'Et huwa ndunnah howuhinli nujut k'et hudulduz, 'ink'ez 'ants'ih dune dahuzsai li'huja.  
\v 5 Lizas ndunnah ts'ekoo ndo búlhni, “Nulhújut ilah. T'eoonuszun Sizi ndun lhdulalhgus k'ut dazsai, 'en bukunáhta hó 'aht'en.  
\v 6 'Aw njan hoolah! Dinadeja ho' 'int'ah. Nts'e na'a datenilh ni, whuz na'a dinadija hó 'int'ah. 'Anih, njan whunulh'en, ndet neMoodihti ilhte!  
\v 7 'Et 'a cho whuz ah'us 'ink'ez ndunnah yugha hoodul'eh hubudáhni yaidla tah dinadija hó 'int'ah. Soo zelhts'ai nuhtsuh Galilee ts'ih iyalh. 'Et teh'ilh. Soo cho soo zelhts'ai 'uda ndun whudáni.”  
\v 8 'A tsih tse be tsa k'et whuch'a nahúnt'az. Whehunelhujoot 'et whunts'ih 'o nus huhóont'i cha' hint'ah. 'Ink'ez ndunnah yugha hoodul'eh 'en buts'un whuhelgai ndoh buduténilh ka. 
\s1 Sizi hits'u teni' nilhdzun 
\p  
\v 9 'Et ndunnah yugha hoodul'eh ts'ih he'us hoh khunyaz Sizi bududezya 'ink'ez ndo búlhni, “Whunélhnik.” Hizih neni'az 'ink'ez hike óontun 'ink'ez hits'u téni' nalhdzin.  
\v 10 'Et Sizi ndo búlhni, “'Aw whénulhujut ilah. sulhutsinkah buts'un naht'us 'ink'ez sba dobudóohni, nuhwheni ts'iyawh Galilee ts'ih toohdelh. 'Et si suhunoolh'en.” 
\s1 Lhuhúdughan 'en sooneya hubugha hinendzai 
\p  
\v 11 'Aw 'et hutezdel hoh 'et howuhinli bulunah Jerusalem ts'ih hunindel. 'Et whuz hunindel hoh 'et ndunnah náwhulnuk bumoodih, 'en 'et nduhóolcho hubudáni njan ndet dahooja 'et.  
\v 12 'Aw 'et náwhulnuk bumoodih 'ink'ez dune netsuh whudelhdzulh, 'en ts'iyawh 'ilhunahuwésdel 'ink'ez howu yahalhtuk. 'Ink'ez lhai sooneya 'i lhahudughan hubugha hinendzai.  
\v 13 'Et ndo buhútni, “'Et nuhwheni ndez na'a 'udutéhnilh, ‘'Et 'ulh'ek 'awhuz ts'uztez hoh ndunnah yugha hoodul'eh whusahanel'i 'ink'ez buyust'e neghu hitelhti.’  
\v 14 'Et yun moodih whulh 'údants'o t'eh, soo kháznent'a hoh bulh yats'oolhtuk sih. 'Et t'eh whuz na'a 'aw hoonliyaz nuhts'u cha'hosne.”  
\v 15 'Et huwa ndunnah lhahudughan ndi sooneya hiyoolhchoot, 'ink'ez nts'e na'a ndo badáni, 'et whuz na'a zeh 'o 'unnah chah hubudáni. 'Et soo k'an dzin 'et whuts'un, 'et whuz na'a Lizwif dich'oh dutah howu yahalhtuk. 
\s1 Sizi yak'uz whenaja whutsuh khunek netl'aída'ai khunek buk'une' ts'oot'en ka 
\p  
\v 16 'Aw 'et ndunnah lanezi 'o 'at 'ilhunuh 'en yugha hoodul'eh, 'en Galilee ts'ih whehandel. Ndi dzulh k'uz Sizi hubudani, whuz whehandel.  
\v 17 Hiyan'en hoh hits'un teni' nalhdzin. 'Et whunts'ih bulunah huba cha'hoot'ah.  
\v 18 Sizi hubuts'un whusainya hoh hubulh yalhtuk 'ink'ez njan ndo búlhni, “Yak'uz 'ink'ez ndi yun k'ut 'i ts'iyawh huwandoh 'ust'ah, 'et sutl'awhélts'ut.  
\v 19 'Et huwa lhelhts'un keyah whut'en, 'en ts'iyawh buts'un nahdulh 'ink'ez si sugha hoodul'eh hubulhtsi. Se'aBá 'ink'ez 'uYe' 'ink'ez Ndoni, ndi boozi be 'i be too be' butelh'ilh.  
\v 20 Ndai khunek nuhtl'adá'ai, 'i ts'iyawh hik'une' 'oot'en hubodoolh'eh. 'Ink'ez sih soo zelhts'ai, 'et dzin whulatah lhaoodija t'eh, 'et whuts'un 'ahoolhyez nohwhulh 'útest'ilh ho' hoont'ah.” 'Et ndoh honeh.