\v 9 \add Il dit cela,\add* \w afin|strong="G2443"\w* \w que|strong="G3754"\w* \w fût|strong="G3739"\w* \w accomplie|strong="G4137"\w* \w la|strong="G1537"\w* \w parole|strong="G3056"\w* \w qu|strong="G3754"\w*’\w il|strong="G3739"\w* \w avait|strong="G3739"\w* \w dite|strong="G3004"\w* : « \w Je|strong="G1473"\w* \w n|strong="G3756"\w*’\w ai|strong="G3739"\w* \w perdu|strong="G3588"\w* \w aucun|strong="G3762"\w* \w de|strong="G1537"\w* \w ceux|strong="G3588"\w* \w que|strong="G3754"\w* \w vous|strong="G3754"\w* \w m|strong="G1473"\w*’\w avez|strong="G3748"\w* \w donnés|strong="G1325"\w*. »
\v 10 \w Alors|strong="G2532"\w* Simon-Pierre, \w qui|strong="G3588"\w* \w avait|strong="G2192"\w* \w une|strong="G2532"\w* \w épée|strong="G3162"\w*, \w la|strong="G2532"\w* \w tira|strong="G1670"\w*, \w et|strong="G2532"\w* frappant \w le|strong="G2532"\w* \w serviteur|strong="G1401"\w* \w du|strong="G2532"\w* \w grand|strong="G2532"\w* prêtre, \w il|strong="G2532"\w* \w lui|strong="G2532"\w* coupa \w l|strong="G1161"\w*’\w oreille|strong="G5621"\w* \w droite|strong="G1188"\w* : \w ce|strong="G1161"\w* \w serviteur|strong="G1401"\w* \w s|strong="G1438"\w*’\w appelait|strong="G3686"\w* \w Malchus|strong="G3124"\w*.
\v 11 \w Mais|strong="G3767"\w* \w Jésus|strong="G2424"\w* \w dit|strong="G3004"\w* \w à|strong="G1519"\w* \w Pierre|strong="G4074"\w* : « Remets \w ton|strong="G3361"\w* \w épée|strong="G3162"\w* \w dans|strong="G1519"\w* \w le|strong="G1519"\w* \w fourreau|strong="G2336"\w*. \w Ne|strong="G3756"\w* \w boirai-je|strong="G3756"\w* \w donc|strong="G3767"\w* \w pas|strong="G3756"\w* \w le|strong="G1519"\w* calice\f + \fr 18:11 \ft 11. Ce \fq calice\ft , symbole des souffrances de la Passion (comp. Is. 51, 16 ; Jér. 49, 12 ; 51, 7). rappelle celui de l’agonie au jardin des Oliviers (Matth. 26, 52 sv.).\f* \w que|strong="G3739"\w* \w mon|strong="G1519"\w* \w Père|strong="G3962"\w* \w m|strong="G1473"\w*’\w a|strong="G1519"\w* \w donné|strong="G1325"\w* ? »
\p 
