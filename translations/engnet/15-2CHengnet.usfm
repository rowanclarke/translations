\s1 Solomon’s Wealth
\p 
\v 14 \w Solomon|strong="H8010"\w* accumulated \w chariots|strong="H7393"\w* \w and|strong="H3967"\w* \w horses|strong="H6571"\w*. \w He|strong="H8147"\w* \w had|strong="H1961"\w* 1,400 \w chariots|strong="H7393"\w* \w and|strong="H3967"\w* 12,000 \w horses|strong="H6571"\w*. \w He|strong="H8147"\w* \w kept|strong="H1961"\w* \w them|strong="H8147"\w* \w in|strong="H4428"\w* \w assigned|strong="H1961"\w* \w cities|strong="H5892"\w* \w and|strong="H3967"\w* \w in|strong="H4428"\w* \w Jerusalem|strong="H3389"\w*.
\v 15 \w The|strong="H5414"\w* \w king|strong="H4428"\w* \w made|strong="H5414"\w* \w silver|strong="H3701"\w* \w and|strong="H3701"\w* \w gold|strong="H2091"\w* \w as|strong="H7230"\w* \w plentiful|strong="H7230"\w* \w in|strong="H4428"\w* \w Jerusalem|strong="H3389"\w* \w as|strong="H7230"\w* stones; cedar \w was|strong="H4428"\w* \w as|strong="H7230"\w* \w plentiful|strong="H7230"\w* \w as|strong="H7230"\w* \w sycamore|strong="H8256"\w* fig \w trees|strong="H8256"\w* \w are|strong="H4428"\w* \w in|strong="H4428"\w* \w the|strong="H5414"\w* lowlands.
