\id 3JN  
\h 3 Juan 
\toc1 Carta na jnda̱ ndyee na seiljeii Juan 
\toc2 3 Juan 
\toc3 3 Jn. 
\mt1 Carta na jnda̱ ndyee na seiljeii Juan 
\c 1  
\s1 Ñꞌoom na seicwanom Juan na mꞌaaⁿ Gayo 
\p  
\v 1 Ja na cwiluiitquiendyo̱, matseiljeiya cartawaa na wjaanaꞌ na mꞌaaⁿꞌ Gayo na mayuuꞌcheⁿ jeeⁿ wiꞌ tsꞌo̱o̱ⁿya ꞌu. 
\p  
\v 2 ꞌU re nnꞌaⁿya na jeeⁿ jnda ntyjiiya macaⁿꞌa nnom Tyꞌo̱o̱tsꞌom na chaꞌtso cantyja ꞌnaⁿꞌ ya wjaꞌmꞌaaⁿꞌ, ndoꞌ ya ncꞌoomꞌ na tiwiꞌ chaꞌxjeⁿ ya wjaaquiendyuꞌ na mꞌaaⁿꞌ nacje ꞌnaaⁿꞌ Espíritu.  
\v 3 Ee tquiecañom ntꞌom nnꞌaaⁿya na cwilaꞌyuꞌ na mꞌaaⁿya, ndoꞌ tquiaanaꞌ na jeeⁿ neiⁿya na jluena no̱o̱ⁿ na jeeⁿ xcweeꞌ tsꞌomꞌ cantyja ꞌnaaⁿꞌ ñꞌoom na mayuuꞌ ndoꞌ cantyja na wjaamꞌaaⁿꞌ, macheꞌ na juu ñꞌoom naya maqueⁿnaꞌ xjeⁿ ꞌnaaⁿꞌnaꞌ ꞌu.  
\v 4 Ee tjaaꞌnaⁿ cwiicheⁿ nnom ñꞌoom na mañequiaatinaꞌ na neiⁿya chaꞌxjeⁿ quia na mandiiya na joo nnꞌaⁿ na cwiluiindye ntseindaaya tyeⁿ cwiljooꞌndyena naquiiꞌ ñꞌoom na mayuuꞌ. 
\s1 Juan matseitꞌmaaⁿꞌñê Gayo 
\p  
\v 5 ꞌU re nnꞌaⁿya na jeeⁿ jnda ntyjiiya, jeeⁿ xcwe macheꞌ na mateixeꞌ nnꞌaaⁿya na cweꞌ cwiquieya na mꞌaaⁿꞌ, meiiⁿ joona nnꞌaⁿ na ticwajnaⁿꞌ.  
\v 6 Jo nda̱a̱ nnꞌaⁿ na cwilaꞌyuꞌ ljooñe, jluena na jeeⁿ wiꞌ tsꞌomꞌ joona. Cwii nayaꞌñeeⁿ cateijndeiꞌ joona ꞌnaⁿ na macaⁿnaꞌ cha nnda̱a̱ ncꞌootina tsꞌiaaⁿ ꞌnaaⁿꞌ Tyꞌo̱o̱tsꞌom, ee jeeⁿ cjaweeꞌ ntyjeeⁿ na macheꞌ naljoꞌ.  
\v 7 Ee joona macwiꞌooñꞌomna ñꞌoom naya ꞌnaaⁿꞌ Jesucristo jo nda̱a̱ nnꞌaⁿ, ndoꞌ tîcatoꞌñoomna sꞌom nda̱a̱ nnꞌaⁿ na tyoolayuꞌ.  
\v 8 Ncꞌe na ljoꞌ, jaa nnꞌaⁿ na cwilayuuꞌa laꞌxmaaⁿya na cateixꞌa̱a̱ya joona na nnteijndeiiya na cwiꞌoonquiana ñꞌoom na mayuuꞌ. 
\s1 Tixcwe sꞌaa Diótrefes 
\p  
\v 9 Seiljeiya cwii carta cwentaaꞌ tmaaⁿꞌ nnꞌaⁿ na macwjiꞌ Tyꞌo̱o̱tsꞌom cwentaaⁿꞌaⁿ yuu na mꞌaⁿꞌyoꞌ sa̱a̱ juu Diótrefes ticwancueⁿꞌeⁿ na ja nntsa̱ꞌntjo̱ⁿ ee ñecuaa xjeⁿ ꞌnaaⁿꞌaⁿ.  
\v 10 Ncꞌe na luaaꞌ, quia na nncua̱caño̱o̱ⁿya ꞌo, quia joꞌ ncwaⁿya jom na machꞌeeⁿ na luaaꞌ na matseineiiⁿ ñꞌoom cantu nacjooyâ. Ndoꞌ nchii macanda̱ nmeiⁿꞌ machꞌeeⁿ, mati nnꞌaⁿ na cwiꞌoonquia ñꞌoomꞌ Tyꞌo̱o̱tsꞌom, tiñeꞌcoñoom joona, ndoꞌ nnꞌaⁿ na ñeꞌcalaꞌljo naⁿꞌñeeⁿ, macwjeeⁿꞌeⁿ joona quiiꞌ tmaaⁿꞌ nnꞌaⁿ na macwjiꞌ Tyꞌo̱o̱tsꞌom cwentaaⁿꞌaⁿ. 
\p  
\v 11 ꞌU re nnꞌaⁿya na jeeⁿ jnda ntyjiiya, tintseijomndyuꞌ ñequio tsꞌiaaⁿ natia, ꞌu catseijomndyuꞌ tsꞌiaaⁿ na ya. Ee tsꞌaⁿ na matseijomñe tsꞌiaaⁿ na ya tseixmaaⁿ cwentaaꞌ Tyꞌo̱o̱tsꞌom, sa̱a̱ tsꞌaⁿ na wjaantyjo̱ ñequio natia, ticꞌoomñe cwentaaⁿꞌaⁿ. 
\s1 Ya machꞌee Demetrio 
\p  
\v 12 Chaꞌtsondye nnꞌaⁿ ya ñꞌoom nquiuna cantyja ꞌnaaⁿꞌ nnꞌaaⁿya Demetrio, ndoꞌ manquiiti ñꞌoom na mayuuꞌ macwjiꞌyuuꞌñenaꞌ cantyja ꞌnaaⁿꞌaⁿ. Mati jâ cwitjeiꞌyuuꞌndyô̱ na ljoꞌ ndoꞌ ꞌo manquiuꞌyoꞌ na cwilana̱a̱ⁿyâ ñꞌoom na mayuuꞌ. 
\s1 Ñꞌoom na macanda̱ na seiljeii Juan 
\p  
\v 13 Jndye ñꞌoom niom na ñeꞌcatseiljeiya cwentaꞌ sa̱a̱ tiñeꞌcatsꞌaa naljoꞌ ñequio tsom ñequio ndaantom,  
\v 14 ee ntyjaaꞌya tsꞌo̱o̱ⁿ na tyuaaꞌ nntyꞌiaya ꞌu quialjoꞌcheⁿ nlana̱a̱ⁿ ntyja̱a̱ nda̱a̱ya. 
\p  
\v 15 Quiaa Tyꞌo̱o̱tsꞌom na tjaañomtiuu cꞌoomꞌ. Nnꞌaⁿ na mꞌaⁿ ñjaaⁿ na ya ñꞌoom ñequiondyuꞌ cwilaꞌcwanomna na xmaⁿndyuꞌ, ndoꞌ ꞌu jeꞌ, quiaaꞌ na xmaⁿñe cwii cwii tsꞌaⁿ na matseiyuꞌ yuu na mꞌaaⁿꞌ.