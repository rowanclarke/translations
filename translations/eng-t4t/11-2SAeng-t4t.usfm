\p 
\v 18 Abishai, \w Joab|strong="H3097"\w*’s \add younger\add* brother, \w was|strong="H8034"\w* \w the|strong="H5921"\w* \w leader|strong="H7218"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* 30 \add greatest warriors\add*. \add One day\add* \w he|strong="H1931"\w* fought \w against|strong="H5921"\w* 300 \w men|strong="H1121"\w* \w and|strong="H3967"\w* \w killed|strong="H2491"\w* \w them|strong="H5921"\w* \w all|strong="H5921"\w* \w with|strong="H5921"\w* \w his|strong="H5921"\w* \w spear|strong="H2595"\w*. \w As|strong="H1121"\w* \w a|strong="H3068"\w* result, \w he|strong="H1931"\w* \w also|strong="H8034"\w* became \w famous|strong="H8034"\w*.
