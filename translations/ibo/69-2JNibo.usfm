\id 2JN - Biblica® Open Igbo Contemporary Bible 2020
\h 2 Jọn
\toc1 2 Jọn
\toc2 2 Jọn
\toc3 2Jọn
\mt1 2 Jọn
\c 1
\p 
\v 1 Ọ bụ okenye ahụ,
\b
\p Na-edegara nwanyị ahụ onye Chineke họpụtara, na ụmụ ya akwụkwọ a, bụ ndị m hụrụ nʼanya nʼime eziokwu. Ọ bụghị naanị m kama ndị niile maara eziokwu ahụ.
\v 2 Nʼihi eziokwu ahụ nke dị nʼime anyị, nke ga-adịgidekwa nʼime anyị ruo mgbe ebighị ebi:
\b
\p 
\v 3 Amara, na ebere, na udo nke sitere na Chineke Nna na Jisọs Kraịst, bụ Ọkpara Nna ahụ dịnyere anyị nʼeziokwu nʼịhụnanya.
\b
\s1 Eziokwu na ịhụnanya
\p 
\v 4 Apụghị m ịkọ ụdị aṅụrị m nwere mgbe m hụrụ na ụfọdụ ụmụ gị na-ebi ndụ ịgbaso eziokwu dịka ihe Nna nyere anyị nʼiwu.
\v 5 Ma ugbu a, ezi nwanyị, ọ bụghị iwu ọhụrụ ka m na-edere gị kama nke ahụ e nyere anyị site na mmalite. Ana m arịọ ka anyị hụrịta ibe anyị nʼanya.
\v 6 Nke a bụ ịhụnanya ahụ: ka anyị na-ejegharị nʼirube isi nʼiwu ya niile. Dịka unu si nụ ya site na mmalite, unu ahapụkwala ijegharị nʼime ya.
\s1 Ndị ozizi ụgha
\p 
\v 7 Nʼihi na ọtụtụ ndị nduhie apụọla baa nʼụwa, bụ ndị na-adịghị ekwenye na Jisọs Kraịst bịara nʼoyiyi mmadụ. Onye ọbụla dị otu a bụ onye nduhie bụrụkwa onye na-emegide Kraịst.
\v 8 Lezienụ anya, ka unu ghara itufu ụgwọ ọrụ nke anyị dọgburu onwe anyị nʼọrụ maka ya, kama ka unu nata ụgwọ ọrụ unu nʼuju.
\v 9 Onye ọbụla na-adịghị anọgide nʼozizi Kraịst, nke na-esite na ya na ewezuga onwe ya, enweghị Chineke. Ma onye ọbụla na-anọgide nʼozizi ahụ nwere Nna na Ọkpara ya.
\v 10 Ọ bụrụ na onye ọbụla abịa izi unu ihe ọzọ dị iche site nʼozizi a, unu akpọbatala ya nʼụlọ unu, maọbụ nabatakwa ya.
\v 11 Nʼihi na onye nabatara ya ga-eso onye dị otu a keta oke nʼajọ omume ya.
\b
\b
\p 
\v 12 Ọ bụ ezie na enwere m ọtụtụ ihe m chọrọ idere unu, ma achọghị m iji akwụkwọ na inki dee ha. Kama, ana m ele anya ịbịa leta unu ka mụ na unu kwukọrịta okwu ihu nʼihu, ka e sikwa otu a mee ka ọṅụ anyị zuo oke.
\b
\p 
\v 13 Ụmụ nwanne gị nwanyị, bụ onye a họpụtara, na-ekele unu.
