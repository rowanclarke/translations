\id PHM Mazatec of Jalapa de Diaz
\h Xu̱ju̱n xi kin'ekjíhi̱ Filemon
\toc1 Xu̱ju̱n xi kits'ínkjihi̱ nda̱ postru̱ Pablo̱ Filemon
\toc2 Xu̱ju̱n xi kin'ekjíhi̱ Filemon
\toc3 Flm.
\mt1 Xu̱ju̱n xi kits'ínkjihi̱ nda̱ postru̱ Pablo̱ Filemon
\c 1
\s1 B'i̱ ts'ín kikjaniñaha̱ Pablo̱ Filemon
\p 
\v 1 An Pablo̱ kjíi̱ya'yán nga̱t'aha̱ Cristo̱ Jesu. An ko̱ nda̱ nts'eé Timoteo̱ tísuniñai̱hi̱ nda̱ Filemon. Tjo ṉkjúnna ji. Ji xi ta̱ tín'exát'aihi̱ Cristo̱.
\v 2 Tísuniña yai̱hi̱ nichjaá Api̱a̱, ko̱ nda̱ nts'eé Arkipo̱ xi ta̱ títs'ín nga'yún nga̱t'aha̱ Cristo̱, ko̱ xu̱ta̱ ni̱nku̱ xi ma ñjakú ni'yahi̱.
\p 
\v 3 Kas'enu̱u kju̱a̱nda ko̱ kju̱a̱jyu xi tsjáná Nti̱a̱ Na̱'miná ko̱ Nda̱ Nti̱a̱ná Jesucristo̱.
\s1 B'i̱ ts'ín kitsúya Pablo̱ xi nkú ts'ín nchja̱ntjai Filemon
\p 
\v 4 F'áítsjenna ji nk'ie nga nchjaka̱ Nti̱a̱ná. Tehe̱nte tsja máb'a̱chjíhi̱
\v 5 nga tí'miyana xi nkú ts'ín tjohi ngayjee̱ xu̱ta̱ xi Nti̱a̱ná kits'ín ts'e̱ ko̱ xi nkú ts'ín n'e s'ejin Nda̱ Nti̱a̱ná Jesu.
\p 
\v 6 Bankihi̱ Nti̱a̱ná nga xi nkú ts'ín n'e s'ejin ni xi ngujihín n'e s'ejián, kui xi kats'ínxájin kju̱a̱nkjintak'uhi̱n tu̱ xi b'a̱ ts'ín ka̱mankjihin ri ngayjee̱ ni nda xi tjínná nga̱t'aha̱ Cristo̱ Jesu.
\v 7 Tsjo ṉkjún tjínna ko̱ sakúna nga'yún nga̱t'aha̱ xi nkú ts'ín tjohi xu̱ta̱ ni̱nku̱. A̱t'aha̱ nga̱t'ahi̱, nda̱ nts'é, kisakú nga'yúhu̱n ani̱ma̱ha̱ xu̱ta̱ xi ts'e̱ Nti̱a̱ná.
\s1 B'i̱ ts'ín nchja̱ntjai Pablo̱ Onesi̱mo̱
\p 
\v 8 Kui b'a̱ maha, ndaha tsa ngajoho̱ Cristo̱ ka̱ma kuinchjako̱ masen masehen ni xi tjíhin nga n'e̱i,
\v 9 tu̱nga tu̱ sa ní tíbankihi ni xi xíhin a̱t'aha̱ tjoná xinki̱á. An Pablo̱ xi ja kama chá ko̱ kjíi̱ya'yán nd'a̱i̱ tu̱ nga̱t'aha̱ Cristo̱ Jesu
\v 10 tíbankihi nku kju̱a̱nda nga̱t'a ts'e̱ Onesi̱mo̱. Kui xi ja tsichu ma xi nkú joyaha tsa ntína̱ e̱i̱ a̱ya nu̱ba̱yóo̱.
\v 11 Kui xi najmi kamachjéhin ni̱stjin nk'ie tu̱nga nd'a̱i̱ ji ko̱ an machénná ndo̱.
\p 
\v 12 Títs'inkjíse ngáhara. N'e̱kjáíhi̱n xi nkúhu tsa an niu̱.
\v 13 Mjena nga k'úéjñako̱ sana e̱i̱ tsakai tu̱ xi ngajohi̱ ts'i̱ínxát'ahana e̱i̱ má nga kjíi̱ya'yán tu̱ nga̱t'aha̱ én nda tsuhu̱ Nda̱ Nti̱a̱ná.
\v 14 Tu̱nga ndahá nku ni najmi mjena chu̱ba̱ ts'ian tsa najmi tjínkuhu̱ tak'uin, tu̱ xi ani̱ma̱hi̱ ni̱baha̱ ra̱ kju̱a̱nda xi n'e̱ní ko̱ najmi an ts'in kju̱a̱'yúhunra.
\p 
\v 15 Kutsa kuihí kju̱a̱ha ngji t'axíhin ri Onesi̱mo̱ chuba ni̱stjin, tu̱ xi n'e̱kjáín sín ngáha̱ ri̱ nd'a̱i̱.
\v 16 Tu̱nga najmi ta̱ xi nkúhú ni tsa nku nda̱ musu̱ xi kich'atsei cha̱se̱hi̱. Tu̱ sa ní cha̱se̱hi̱ xi nkúhu nku nda̱ xi 'yún chjí saha̱ ra̱ nga nku nda̱ musu̱. Nga̱t'a ts'a̱n nda̱ts'é ja tsichu ma ndo̱ ko̱ tjona. Nga̱t'a ts'i̱ 'yún chjí saha̱ ra̱ ndo̱, a̱t'aha̱ ta̱ ts'i̱ínxát'a ngáha ri ko̱ ta̱ s'ejihi̱n Nda̱ Nti̱a̱ná xi nkúhu ji.
\p 
\v 17 Kui b'a̱ maha, xihi̱ yaní nga nkuhú tinchajián ni xi ngujihín s'ejinná, n'e̱kjáín ngáha̱ ri̱ Onesi̱mo̱ xi nkúhu tsa an niu̱.
\v 18 Tsa tjín má najmi nda kits'ínko̱hi ko̱ tsa tjín ni xi tje̱he̱n ts'i̱, kuenta̱na̱ t'et'ai niu̱.
\v 19 An k'uechjá ni xi tje̱he̱n. An Pablo̱ ntuna̱ tíb'et'áhana xu̱ju̱i̱n nga b'a̱ ts'ian, ndaha tsa ka̱ma ts'inkj'áítsjehen ni xi tje̱hin ts'a̱n. Nga̱t'ana̱ tinchihinni.
\v 20 Ji nda̱ nts'e, a̱t'aha̱ tjohi̱ Nda̱ Nti̱a̱ná, kasakújinna ji nku kju̱a̱nda. Tjen nga'yíhi̱n ani̱ma̱na̱ tu̱ nga̱t'aha̱ nga nkuhú kich'aá Cristo̱.
\p 
\v 21 B'a̱ ts'ín tíb'et'áha a̱t'aha̱ behe̱ k'an nga ku̱i̱nú'yá'énní. Be nga 'yún n'e̱tjusun sai ni xi tíbankihi.
\v 22 Ko̱ ta̱ tíbankihi kj'a̱í sa ni. T'endaní nku a̱nte ni'yahi̱, a̱t'aha̱ tíbinchihu̱u Nti̱a̱ná nga ka̱ma kfínsenu̱u. Tu̱ tíkuyáhá ra̱ nga b'a̱ ka̱ma.
\s1 B'i̱ ts'ín kits'ínkje Pablo̱ xu̱ju̱i̱n
\p 
\v 23 Títs'ínkjihi kju̱a̱suniña nda̱ Epa̱fra̱. E̱i̱ ta̱ kjiya'yúnko̱na nga̱t'aha̱ Cristo̱ Jesu.
\v 24 Ko̱ ta̱ títs'ínkjihi kju̱a̱suniña nda̱ Marko̱, nda̱ Aristarko̱, nda̱ Dema̱ ko̱ nda̱ Luko̱. Kui jái̱ ta̱ y'anjiko̱na xá xi títs'ian.
\p 
\v 25 Kju̱a̱ndaha̱ Nda̱ Nti̱a̱ná Jesucristo̱ kas'eyaha̱ ani̱ma̱nu̱u.
