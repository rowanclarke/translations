\id MAT  
\h Mataio 
\toc1 Mataio 
\toc2 Mataio 
\toc3 Mataio 
\mt1 Mataio  
\c 1  
\s1 KA EUANELIO I KAKAUIA'I  
\q1
\v 1 O KE kuauhau na ka hanauna o Iesu Kristo, ka mamo a Davida, ka mamo a Aberahama.   
\b  
\q1
\v 2 Na Aberahama o Isaaka; na Isaaka o Iakoba; na Iakoba o Iuda a me kona poe hoahanau;   
\q1
\v 3 Na Iuda laua me Tamara o Paresa a me Zara; na Paresa o Hezerona; na Hezerona o Arama;   
\q1
\v 4 Na Arama o Aminadaba; na Aminadaba o Naasona; na Naasona o Salemona;   
\q1
\v 5 Na Salemona laua me Rahaba o Boaza; na Boaza laua me Ruta o Obeda; na Obeda o Iese;   
\q1
\v 6 Na Iese o Davida ke alii; na Davida na ke alii laua me ka wahine a Uria o Solomona;   
\q1
\v 7 Na Solomona o Rehoboama; na Rehoboama o Abia; na Abia o Asa;   
\q1
\v 8 Na Asa o Iosapata; na Iosapata o Iorama; na Iorama o Ozia;   
\q1
\v 9 Na Ozia o Iotama, na Iotama o Ahaza; na Ahaza o Hezekia;   
\q1
\v 10 Na Hezekia o Manase; na Manase o Amona; na Amona o Iosia;   
\q1
\v 11 Na Iosia o Iekonia a me kona poe hoahanau, i ka manawa o ka lawe ana i Babulona:   
\b  
\q1
\v 12 A mahope mai o ka lawe ana i Babulona, na Iekonia o Saletiela; na Saletiela o Zerubabela;   
\q1
\v 13 Na Zerubabela o Abiuda; na Abiuda o Eliakima; na Eliakima o Azora;   
\q1
\v 14 Na Azora o Sadoka; na Sadoka o Akima; na Akima o Eliuda;   
\q1
\v 15 Na Eliuda o Eleazara; na Eleazara o Mahetana; na Mahetana o Iakoba;   
\q1
\v 16 Na Iakoba o Iosepa ke kane a Maria nana i hanau o Iesu, i kapaia o Kristo.   
\b  
\q1
\v 17 O na banauna a pau mai ia Aberahama mai a hiki ia Davida, he umi ia hanauna a me kumamaha; a mai ia Davida mai a hiki i ka lawe ana i Babulona, he umi ia hanauna a me kumamaha; a mai ka lawe ana aku i Babulona mai, a hiki ia Kristo he umi ia hanauna a me kumamaha.   
\b  
\q1
\v 18 Penei hoi ka hanau ana o Iesu Kristo: I hoopalau e ia kona makuwahine o Maria na Iosepa, aole nae laua i pili, a ikea oia, ua hapai na ka Uhane Hemolele.   
\q1
\v 19 Aka, he kanaka pono kana kane o Iosepa, aole ia i makemake e hoino ia ia ma ke akea; manao iho la ia e kipaku malu ia ia.   
\q1
\v 20 A i kona noonoo ana ma ia mau mea, aia hoi, ikeia'ku ka anela a ka Haku e ia ma ka moe, i mai la, E Iosepa, e ka mamo a Davida, mai makau oe ke lawe ia Maria i wahine nau; no ka mea, ua hapai oia na ka Uhane Hemolele.   
\q1
\v 21 A e hanau mai oia i keikikane, a e kapa aku oe i kona inoa o IESU; no ka mea, e hoola ia i kona poe kanaka mai ko lakou hewa.   
\q1
\v 22 Ma ia mau mea i ko ai ka mea a ka Haku i olelo mai ai ma ke kaula, i ka i ana mai,   
\q1
\v 23 Aia hoi, e hapai ana kekahi wahine puupaa, a e hanau mai ia i keikikane, a e kapaia kona inoa o Emanuela; o ke ano keia, o ke Akua me kakou.   
\q1
\v 24 A ala ae la o Iosepa mai ka hiamoe ana, hana aku la ia e like me ka ka anela a ka Haku i kauoha mai ai ia ia, a lawe mai la ia i kana wahine;   
\q1
\v 25 Aole nae i moe aku ia ia, a hiki i ka wa i hanau ai oia i kana makahiapo kane, a kapa aku la ia i kona inoa o IESU.   
\c 2  
\b  
\q1
\v 1 A HANAUIA o Iesu ma Betelehema i Iudea, i ke kau ia Herode ke alii, aia hoi, kele mai la na magoi mai ka aina hikina mai a Ierusalema,   
\q1
\v 2 I ka i ana mai, Ai la ihea ka mea i hanau iho nei i aliii no ka poe Iudaio? No ka mea, ua ike makou ma ka aina hikina i kona hoku, a ua hele mai nei makou e kukuli hoomaikai ia ia.   
\q1
\v 3 A lohe ae la o Herode ke alii, apoapo ae la kona oili, oia a me ko Ierusalema a pau.   
\q1
\v 4 Alaila, houluulu ae la ia i ka poe kahuna nui a me ka poe kakauolelo a na kanaka, ninau mai la oia ia lakou, Ai la ihea kahi e hanau ai o ka Mesia?   
\q1
\v 5 Hai aku la lakou ia ia, Aia i Betelehema i Indea nei; no ka mea, ua palapalaia e ke kaula penei,   
\q1
\v 6 O oe, e Betelehema, i ka aina o Iuda, aole no oe ka mea uuku loa iwaena o ko Iuda poe alii; no ka mea, mailoko mai ou e hele mai ana kekahi alii, nana e hoomalu i ko'u poe kanaka o ka Iseraela.   
\b  
\q1
\v 7 Alaila, kii malu aku la o Herode i ua mau magoi la, ninau pono aku la ia lakou i maopopo ai ka manawa i ikea aku ai ua hoku la.   
\q1
\v 8 Hoouna aku la oia ia lakou i Betelehema, i aku la, Ou haele oukou, e imi pono aku i ua keiki la; a loaa hoi, alaila e hai mai ia'u, i hele aku hoi au e kukuli hoomaikai ia ia.   
\q1
\v 9 A lohe ae la i ka ke alii, haele aku la lakou; aia hoi, ka hoku a lakou i ike ai ma ka aina hikina, lele e aku la ia imua o lakou, a hele aku la, a kau iho la maluna pono o kahi e noho ana o ua keiki la,   
\q1
\v 10 A ike aku lakou i ua hoku la, hauoli nui loa ae la lakou.   
\b  
\q1
\v 11 Komo lakou iloko o ka hale, a ike aku la i ua keiki la a me kona makuwahine o Maria, a moe iho la lakou, hoomaikai aku la ia ia; a wehe ae la lakou i ko lakou waihona waiwai, haawi aku la lakou nana i ke gula, a me ka libano, a me ka mura.   
\q1
\v 12 A ma ka moeuhane, papaia mai lakou, aole e hoi bou aku io Herode la, a ma kekahi alanui e ae i hoi aku ai lakou i ko lakou aina.   
\b  
\q1
\v 13 A hala aku la lakou, aia hoi, ikea aku la ka anela a ka Haku e Iosepa i ka moeuhane, i mai la, E ala, e lawe i ke keiki a me kona makuwahine, a holo aku i Aigupita; malaila e noho ai, a olelo hon aku au ia oe; no ka mea, e imi mai ana o Herode i ke keiki, e pepehi ia ia.   
\q1
\v 14 Ala ae la ia, lawe ae la i ke keiki a me kona makuwahine i ka po, a holo aku la i Aigupita;   
\q1
\v 15 Malaila ia i noho ai a make o Herode. Nolaila, ko ae la ka olelo a ka Haku ma ke kaula, i ka i ana mai, Ua kahea aku au i ka'u keiki mai Aigupita mai.   
\b  
\q1
\v 16 Alaila, ike ae la o Herode, ua hoohokaia oia e ka poe magoi, ukiuki loa iho la ia, kena aku la ia, a luku aku la i na keikikane a pau o Betelehema, a o na wahi a puni e kokoke ana, i ka poe elua makahiki a hala ilalo, i ka manawa i ninau pono aku ai ia i ka poe magoi.   
\q1
\v 17 Alaila, ko ae la ka olelo a ke kaula a Ieretnia, i i mai ai,   
\q1
\v 18 Ua lohea ka leo ma Rama, he pihe, he uwe ana, a me ke kanikau nui; e uwe ana o Rahela no kana mau keiki, aole loa ia e na, no ka mea, aole ae nei lakou.   
\b  
\q1
\v 19 A make o Herode, alaila ikea aku la kekahi anela a ka Haku e Iosepa ma ka moeuhane i Aigupita;   
\q1
\v 20 I mai la, E ala oe e lawe i ke keiki a me kona makuwahine, a e hoi aku i ka aina o ka Iseraela; no ka mea, ua make ka poe i imi mai e pepehi i ua keiki nei.   
\q1
\v 21 Ala'e la ia, lawe ae la i ua keiki la, a me kona makuwahine, a hele aku la i ka aina o ka Iseraela.   
\q1
\v 22 Aka, lohe ae la ia, o Arekelau ke alii ma ludea i pani no ka hakahaka o kona makuakane o Herode, makau iho la ia i ka hele aku malaila: a aoia mai ai ma ka moeuhane, hoi aku ia i ka moku o Galilaia.   
\q1
\v 23 A hiki aku la ia i kekahi kulanakauhale o Nazareta ka inoa, noho iho la ia ilaila: pela i ko ai ka olelo a ka poe kaula, E kapaia oia he Nazarene.   
\c 3  
\b  
\q1
\v 1 I A mau la la i hele mai ai o Ioane Bapetite, e ao ana ma ka waonahele i Iudea, i ka i ana ae,   
\q1
\v 2 E mihi oukou, no ka mea, ua kokoke mai nei ke aupuni o ka lani.   
\q1
\v 3 Oia no ka mea i oleloia mai e ke kaula e Isaia, i ka i ana mai, Ka leo o ka mea e kala ana ma ka waonahele, E hoomakaukau oukou i alanui no Iehova, e hana i kona mau kuamoo i pololei.   
\q1
\v 4 Ua aahu iho la o ua Ioane la i ke kapa hulu kamelo, a he kaei ili ma kona puhaka; a he uhini kaua ai, a me ka meli o ka nahelehele.   
\q1
\v 5 Alaila, hele aku la ko Ierusalema a me ko Iudea a pau io na la, a me ko na wahi a pau e kokoke ana ma Ioredane.   
\q1
\v 6 A bapetizoia iho la lakou e ia iloko o Ioredane, me ka hai ana mai i ko lakou hewa.   
\b  
\q1
\v 7 A ike aku la ia, he nui na Parisaio a me na Sadukaio i hele mai e bapetizoia'i e ia, i aku la oia ia lakou, E ka hanauna moonihoawa, nawai oukou i ao aku e holo i pakele ai i ka iuaina e kau mai ana?   
\q1
\v 8 E hua ae oukou i ka hua e ku i ka mihi.   
\q1
\v 9 Mai manao oukou e ohumu iloko o oukou iho, o Aberahama ko kakou kupuna; no ka mea, ke i aku nei au ia oukou, e hiki no i ke Akua ke hoala ae mai keia mau pohaku mai i poe mamo na Aberahama.   
\q1
\v 10 Ano hoi, ke waiho nei ke koi lipi ma ke kumu o na laau, a o kela laau o keia laau e hua ole mai ana i ka hua maikai, e kua ia ilalo a e kiolaia'ku ia i ke ahi.   
\q1
\v 11 Owau no ke bapetizo aku nei ia oukou i ka wai, no ka mihi; aka, o ka mea e hele mai ana mahope o'u, he nui aku kona mana i ko'u, aole au e pono ke lawe i kona mau kamaa; nana oukou e bapetizo aku i ka Uhane Hemolele a me ke ahi.   
\q1
\v 12 Aia no ma kona lima kana peahi, a e hoomaemae pono ana ia i kana huaai; a e hoiliili hoi ia i kana palaoa iloko o ka hale papaa, a e hoopau aku i ka opala i ke ahi pio ole.   
\b  
\q1
\v 13 Alaila, hele mai la o Iesu, mai Galilaia mai i Ioredaue io Ioane la, e bapetizoia'i e ia.   
\q1
\v 14 Hoole aku la o Ioane ia ia, i aku ia, Owau kau e bapetizo mai e pono ai; a ke hele mai nei anei oe io'u nei?   
\q1
\v 15 Olelo mai la o Iesu, i mai la ia ia, E ae mai oe ano, no ka mea, pela kaua e pono ai ke malama i ka pono a pau: alaila, ae aku la kela ia ia.   
\q1
\v 16 A bapetizoia o Iesu, alaila, pii koke mai la ia mai ka wai mai; aia hoi, hamama ae la ka lani nona, a ikea aku la ka Uhane o ke Akua e iho mai ana me ho mainu nunu la, a kau iho la maluna iho ona.   
\q1
\v 17 Aia hoi, he leo mai ka lani mai, e i mai ana, O ka'u Keiki punahele keia, ka mea a'u i olioli loa ai.   
\c 4  
\b  
\q1
\v 1 A LAILA, alakaiia'ku la o Iesu e ka Uhane i ka waonahele, e hoowalewaleia'ku ai e ka diabolo.   
\q1
\v 2 Hookeai iho la ia i hookahi kanaha la, a me na po he kanaha, a mahope iho, pololi iho la ia.   
\q1
\v 3 A hiki aku ka mea hoowalewale io na la, i aku la ia, Ina o ke Keiki oe a ke Akua, e i mai oe i keia mau pohaku i lilo i berena.   
\q1
\v 4 Aka, olelo mai la o Iesu, i mai la, Ua palapalaia, Aole e ola ke kanaka i ka berena wale no, aka, ma na mea a pau mai ka waha mai o ke Akua.   
\q1
\v 5 Alaila, lawe aku la ka diabolo ia ia i ke kulanakauhale hoano; a hookau aku la ia ia maluna iho o kahi oioi o ka luakini;   
\q1
\v 6 I aku la ia ia, Ina o oe ke Keiki a ke Akua, e lele iho oe ilalo; no ka mea, ua palapalaia, E kauoha mai no ia i kona poe anela nou, e kaikai lakou ia oe ma ko lakou mau lima, o kuia kou wawae i ka pohaku.   
\q1
\v 7 I mai la o Iesu, Ua palapalaia no hoi, Mai hoao aku oe i ka Haku i kou Akua.   
\q1
\v 8 Lawe hou aku la ka diabolo ia ia i kahi mauna kiekie loa, a hoike aku la ia ia i na aupuni a pau o ka honua, a me ko lakou nani;   
\q1
\v 9 I aku la hoi ia ia, O keia mau mea a pau ka'u e haawi aka ai ia oe, ke kukuli iho oe, a hoomana mai ia'u.   
\q1
\v 10 Alaila, olelo mai la Iesu ia ia, E hele pela oe, e Satana; no ka mea, ua palapalaia, E hoomana aku oe i ka Haku i kou Akua, a e malama aku oe ia ia wale no.   
\q1
\v 11 Alaila, haalele aku la ka diabolo ia ia; aia hoi, hele mai la na anela, a lawelawe nana.   
\b  
\q1
\v 12 Lohe ae la o Iesu, ua hooleiia o Ioane iloko o ka halepaahao, hele aku la ia i Galilaia.   
\q1
\v 13 Haalele ae la oia ia Nazareta, hele aku la a noho ma Kaperenauma ma ke kahaloko, ma ka mokuna o Zabulona o me Napetali.   
\q1
\v 14 Pela i ko ai ka mea i oleloia e ke kaula e Isaia, i ka i ana mai,   
\q1
\v 15 O ka aina o Zabulona, a o ka aina o Napetali ma ke ala o ka loko ma kela aoao o Ioredane, o Galilaia no na kanaka e;   
\q1
\v 16 O ka poe kanaka e noho ana ma ka pouli, ike ae la lakou i ka malamalama nui; amaluna o ka poe e noho ana ma ka malu o ka make, ua puka mai ka malamalama.   
\b  
\q1
\v 17 Mai ia manawa mai, hoomaka o Iesu e hai mai a e olelo mai, E mihi oukou, no ka mea, ua kokoke mai nei ke aupuni o ka lani.   
\b  
\q1
\v 18 Hele aku la o Iesu ma ke kae o ka loko o Galilaia, ike mai la ia i na hoabanau elua, o Simona i kapaia o Petero, a me kona kaikaina o Anederea, e kuu ana i ka upena i ka loko, no ka mea, he mau lawaia laua.   
\q1
\v 19 I mai la oia ia laua, E hahai mai olua ia'u, a e hoolilo au ia olua i mau lawaia kanaka.   
\q1
\v 20 Haalele koke iho la laua i na upena, a hahai aku la ia ia.   
\q1
\v 21 A hele aku la ia malaila aku, ike mai la ia i na hoahanau e ae elua, o Iakobo ke keiki a Zebedaio, a me kona kaikaina o Ioane, maluna no o ka moku me ko laua makuakane o Zebedaio, e hono ana i ka lakou mau upena, a kahea mai la oia ia laua.   
\q1
\v 22 Haalele koke aku la laua i ka moku, a me ka laua makuakane, a hahai aku la ia ia.   
\b  
\q1
\v 23 Kaahele ae la o Iesu ma Galilaia a puni, e ao mai ana iloko o ko lakou mau halehalawai, a e hai mai ana i ka euanelio no ke aupuni, a e hoola ana hoi i ka mai a me ka nawaliwali a pau o na kanaka.   
\q1
\v 24 Kui aku la kona kaulana i Suria a puni, halihali mai la lakou io na la i ko lakou poe mai a pau, i loohia e kela mai keia mai, a me na eha, o ka poe i ulubia e na daimonio, a me ka poe hebena, a me ka poe lolo; a hoola mai la oia ia lakou.   
\q1
\v 25 He nui loa ka poe kanaka i hahai mai ia ia no Galilaia mai, no Dekapoli mai, a no Ierusalema mai, no Iudea mai, a no kela kapa mai o Ioredane.   
\c 5  
\b  
\q1
\v 1 I KE ae la o Iesu i ka nui o na kanaka, pii aku la ia i kekahi mauna; a noho iho la ia, hele aku la kana mau haumana io na la.   
\q1
\v 2 Oaka ae la kona waha, ao mai la oia ia lakou, i mai la,   
\b  
\q1
\v 3 Pomaikai ka poe i haahaa ka naau; no ka mea, no lakou ke aupuni o ka lani.   
\b  
\q1
\v 4 Pomaikai ka poe e u ana; no ka mea, e hooluoluia'ku lakou.   
\b  
\q1
\v 5 Pomaikai ka poe akahai; no ka mea, e lilo ka honua ia lakou.   
\b  
\q1
\v 6 Pomaikai ka poe pololi, a makewai no ka pono; no ka mea, e hoomaonaia lakou.   
\b  
\q1
\v 7 Pomaikai ka poe i aloha aku; no ka mea, e alohaia mai lakou.   
\b  
\q1
\v 8 Pomaikai ka poe i maemae ma ka uaau; no ka mea, e ike lakou i ke Akua.   
\b  
\q1
\v 9 Pomaikai ka poe uwao; no ka mea, e iia lakou he poe keiki na ke Akua.   
\b  
\q1
\v 10 Pomaikai ka poe i hoomaauia mai no ka pono; no ka mea, no lakou ke aupuni o ka lani.   
\q1
\v 11 E pomaikai ana no oukou, ke hoino mai kanaka ia oukou, ke hoomaau mai no hoi; a no'u nei, e olelo wahahee mai ai ia oukou i na mea ino a pau.   
\q1
\v 12 E hauoli oukou, e olioli nui hoi; no ka mea, he nui ka uku no oukou ma ka lani: pela lakou i hoomaau aku ai i ka poe kaula mamua o oukou.   
\b  
\q1
\v 13 O oukou no ka paakai o ka honua: aka, ina pau ka liu o ka paakai, pehea la ia e liu hou ai? Aohe ona mea e pono ai ma ia hope, e kiola wale ia i waho e hehiia'i e na kanaka.   
\q1
\v 14 O oukou no ka malamalama o ke ao nei: o ke kulanakauhale i ku ma kahi kiekie, aole ia e nalowale.   
\q1
\v 15 Aole i hoaia ke kukui i mea e waihoia'i malalo iho o ke poi, aka, ma kahi o kau ai o ke kukui, i malamalama no ka poe a pau iloko o ka hale.   
\q1
\v 16 Pola oukou o hoakaka aku ai i ko oukou malamalama imua o na kanaka, i ike mai ai lakou i ka oukou hana maikai ana, a i hoonani aku hoi lakou i ko oukou Makua i ka lani,   
\b  
\q1
\v 17 Mai manao oukou i hele mai nei au e hoole i ke kanawai a me ka poe kaula. O ka hooiaio ka'u i hele mai nei, aole ka hoole.   
\q1
\v 18 No ka mea, he oiaio ka'u e olelo aku nei ia oukou, e lilo e ka lani a me ka honua, aole e lilo kahi huna, aole hoi kahi lihi iki o ke kanawai, a pau loa ae la ia i ka hookoia.   
\q1
\v 19 Nolaila, o ka mea e uhai aku i kekahi hua iki o keia mau kanawai, a e ao aku hoi i kanaka pela; oia ke oleloia he mea uuku loa iloko o ke aupuni o ka lani; aka, o ka mea e malama ia mau kanawai, a e ao aku i kanaka pela, oia ke oleloia he mea nui iloko o ke aupuni o ka lani.   
\q1
\v 20 No ka mea, ke i aku nei au ia oukou, A i oi ole aku ko oukou pono i ko ka poe kakauolelo a me ko ka poe Parisaio, aole loa oukou e komo iloko o ke aupuni o ka lani.   
\b  
\q1
\v 21 Ua lohe no oukou i ka mea i oleloia mai i ka poe kahiko, Mai pepehi kanaka oe; a o ka mea e pepehi i ke kanaka, e lilo ana ia i ka hoohewaia:   
\q1
\v 22 Eia hoi ka'u e olelo aku nei ia oukou, O ka mea e huhu hala ole aku i kona hoahanau, e lilo ana ia i mea no ka hoohewaia; a o ka mea e hailiili aku i kona hoahanau, E, pupuka! e lilo ia i mea no ka aha hookolokolo; a o ka mea e hailiili aku, E, lapuwale? e lilo ia i mea no ke ahi i Gehena.   
\q1
\v 23 No ia mea, a i lawe mai oe i kau mohai i ke kuahu, a malaila oe i manao ai, he mea kau e hewa ai i kou hoahanau;   
\q1
\v 24 E waiho malaila oe i kau mohai imua o ke kuahu, e hele aku oe e hoolaulea e mamua i kou hoahanau, alaila e hoi mai e kaumaha aku i kau mohai.   
\q1
\v 25 E hoolaulea koke aku oe i kou mea i lawehala ai, oiai oe me ia ma ke alanui, o haawi aku kela ia oe i ka lunakanawai, a na ka lunakanawai oe e haawi aku i ka ilamuku, a e hooleiia'ku oe iloko o ka halepaahao.   
\q1
\v 26 He oiaio ka'u e olelo aku nei ia oe; aole loa oe e puka e mai iwaho olaila, a pau loa ae la ka aie i ka ukuia e oe.   
\b  
\q1
\v 27 Ua lohe oukou i ka olelo ana mai i ka poe kahiko, Mai moe kolohe oe:   
\q1
\v 28 Eia hoi ka'u e olelo aku nei ia oukou, O ka mea e nana wale aku i ka wahine i mea e kuko he wa aku ai ia ia, ua moe kolohe no oia me ia ma kona naau.   
\q1
\v 29 No ia hoi, a i hoohihia mai kou maka akau ia oe, e poalo ae ia mea, a e hoolei aku, mai ou aku; e aho nou e lilo kekahi lala ou, i ole e hooleiia'ku ai kou kino okoa iloko o Gehena.   
\q1
\v 30 Ina hoi e hoohihia mai kou lima akau ia oe, e oki ia mea, a e hoolei aku mai ou aku; e aho nou e lilo kekahi lala ou, i ole e hooleiia'ku ai kou kino okoa iloko o Gehena.   
\q1
\v 31 Ua oleloia mai no, O ka mea hoohemo i kana wahine, e haawi aku ia nana i ka palapala no ka hemo ana:   
\q1
\v 32 Eia hoi ka'u e olelo aku nei ia oukou, O ka mea hoohemo wale i kana wahine, ke ole ia no ka moe kolohe, nana no ia e hoomoe kolohe aku; a o ka mea e mare i ua wahine hemo la, ua moe kolohe no ia.   
\b  
\q1
\v 33 Ua lohe no hoi oukou i ka olelo ana mai i ka poe kahiko, Mai hoohiki wahahee oe; aka, e hooko aku oe no ka Haku i kau mea i hoohiki ai:   
\q1
\v 34 Eia hoi ka'u e olelo aku nei ia oukou, Mai hoohiki ino iki; aole i ka lani, no ka mea, o ko ke Akua nohoalii ia:   
\q1
\v 35 Aole hoi i ka honua, no ka mea, o kona keehana wawae in: aole hoi i Ierusalema, no ka mea, o ko ke Alii nui kulanakauhale ia.   
\q1
\v 36 Aole hoi oe e hoohiki ino i kou poo iho, no ka mea, aole e hiki ia oe ke hoolilo i kekahi oho i keokeo, aole hoi i eleele.   
\q1
\v 37 Penei oukou e olelo aku ai, o ka ae, he ae ia; o ka ole, he hoole ia: a o ka mea oi aku i keia, no ka ino mai ia.   
\b  
\q1
\v 38 Ua lohe oukou i ka olele ana mai, He maka no ka maka, a he niho no ka niho:   
\q1
\v 39 Eia hoi ka'u e olelo aku nei ia oukou, Mai hoopai aku i ka ino; a o ka mea nana e papai mai i kou papalina akau, e haliu aku oe ia ia i kekahi.   
\q1
\v 40 A o ka mea nana oe e kahihi wale aku ma ke kanawai, a e lawe i kou kapa komo, ho hou aku no hoi ia ia i kou aahu.   
\q1
\v 41 O ka mea e koi mai ia oe e hele i hookahi mile, e hele pu me ia i elua.   
\q1
\v 42 O ka mea e noi mai ia oe, e haawi aku nana, a o ka mea e noi mai e lawe lilo ole i kau mea, mai kaii ae oe.   
\b  
\q1
\v 43 Ua lohe no oukou i ka olelo ana mai, E aloha aku oe i kou hoalauna, a e inaina aku hoi i kou enemi:   
\q1
\v 44 Eia hoi ka'u e olelo aku nei ia oukou, E aloha aku i ko oukou poe enemi, e hoomaikai aku hoi i ka poe hoino mai ia oukou; e hana lokomaikai aku hoi i ka poe inaina mai ia oukou; e pule aku hoi no ka poe hoohewa wale mai ia oukou, a hana ino mai hoi ia oukou;   
\q1
\v 45 I lilo ai oukou i poe keiki na ko oukou Makua i ka lani, nana no i hoopuka mai i kona ia maluna o ka poe ino a me ka poe maikai, nana hoi i hooua mai maluna o ka poe pono a me ka poe pono ole.   
\q1
\v 46 A i aloha aku oukou i ka poe i aloha mai ia oukou, heaha la auanei ka uku e loaa mai ai ia oukou? Aole anei pela e hana nei ka poe lunaauhau?   
\q1
\v 47 Ina e uwe aku oukou i ko oukou poe hoahanau wale no, heaha la ko oukou mea e oi aku ai? Aole anei pela e hana nei ka poe lunaauhau?   
\q1
\v 48 E hemolele oukou, e like me ka hemolele o ko oukou Makua iloko o ka lani.   
\c 6  
\b  
\q1
\v 1 E MALAMA ia oukou, aole a hana wale aku i ko oukou manawalea imua o na kanaka, no ka ikeia mai e lakou; o loaa ole ia oukou ka ukuia mai e ko oukou Makua i ka lani.   
\b  
\q1
\v 2 A i kou manawalea ana aku, mai hookani i ka pu imua ou e like me ka hana ana a ka poe hookamani iloko o na halehalawai a ma na alanui, i hoomaikaiia mai ai e na kanaka: he oiaio ka'u e olelo aku nei ia oukou, Ua loaa ia lakou ko lakou uku.   
\q1
\v 3 Aka o oe, i kou manawalea ana aku, mai hoike i kou lima hema i ka mea a kou lima akau e hana'i.   
\q1
\v 4 I nalo hoi kou manawalea ana; a o kou Makua e nana mai ana i kahi nalo, oia ke uku mai ia oe ma ke akea.   
\b  
\q1
\v 5 A i pule aku oe, ea, mai hoohalike me ka poo hookamani; makemake lakou e pule ku ana ma na halehalawai a me na huina alanui, i ikeia mai ai lakou e kanaka; he oiaio ka'u e olelo aku nei ia oukou, Ua loaa ia lakou ko lakou uku.   
\q1
\v 6 Aka, i kau pule ana, e komo ae oe i kou keena mehameha, a papani oe i kou puka, e pule aku i kou Makua ina no ma kahi nalo, a o kou Makua e ike ana iloko o kahi nalo, oia ke uku mai ia oe ma ke akea,   
\q1
\v 7 A i ka pule ana, mai kuawili wale aku oukou i ka olelo, e like me ka poe kanaka e; ke manao nei lakou, no ka nui o ka lakou olelo ana, e hooloheia mai ai lakou.   
\q1
\v 8 Mai hoohaliko me lakou; no ka mea, ua ike no ko oukou Makua i na mea e pono ai oukou, mamua o ka oukou noi ana aku ia ia.   
\q1
\v 9 Penei oukou e pule aku ai; E ko makou Makua iloko o ka lani, e hoanoia kou iuoa.   
\q1
\v 10 E hiki mai kou aupuni; e malamaia kou makemake ma ka honua nei, e like me ia i malamaia ma ka lani la;   
\q1
\v 11 E haawi mai ia makou i keia la i ai na makou no neia la;   
\q1
\v 12 E kala mai hoi ia makou i ka makou lawehala ana, me makou e kala nei i ka poe i lawehala i ka makou.   
\q1
\v 13 Mai hookuu oe ia makou i ka hoowalewaleia mai; e hoopakele no nae ia makou i ka ino; no ka mea, nou ke aupuni, a me ka mana, a me ka hoonaniia, a mau loa aku. Amene.   
\q1
\v 14 Ina paha oukou e kala aku i na hala o kanaka, e kala mai no hoi ko oukou Makua o ka lani i ko oukou.   
\q1
\v 15 Aka, i ole oukou e kala aku i na hala o kanaka, aole no hoi e kala mai ko oukou Makua i ko oukou hala.   
\b  
\q1
\v 16 A i hookeai oukou, mai hoinoino maka oukou e like me ka poe hookamani; no ka mea, ua hoinoino lakou i ko lakou maka i ikeia mai e na kanaka ka lakou hookeai ana: he oiaio ka'u e olelo aku nei ia oukou, Ua loaa ia lakou ko lakou uku.   
\q1
\v 17 Aka, i hookeai oe, e poni i kou poo, a e holoi i kou maka;   
\q1
\v 18 I ike ole ia kau hookeai ana e na kanaka, aka, i ikea ia e kou Makua ina no i kahi nalo, a o kou Makua ke ike i kahi nalo, oia ke uku mai ia oe ma ko akea.   
\b  
\q1
\v 19 Mai hoahu oukou i waiwai no oukou ma ka honua, kahi e pau ai i ka mu a me ka popo, kahi e wawahi mai ai na aihue e aihue ai.   
\q1
\v 20 Aka, e hoahu ae oukou i waiwai no oukou ma ka lani, kahi e pau ole ai i ka mu a me ka popo, kahi e wawahi ole mai ai na aihue e aihue ai.   
\q1
\v 21 No ka mea, ma kahi e waiho ai ko oukou waiwai, malaila pu no hoi ko oukou naau.   
\q1
\v 22 O ka maka ko ke kino kukui no ia. Ina he maikai kou maka, e malamalama ana kou kino a pau.   
\q1
\v 23 Aka, i ino kou maka, e paapu ana kou kino i ka pouli. Ina e lilo ka malamalama iloko on i pouli, aohe io hoi o ka nui o ua pouli la!   
\b  
\q1
\v 24 Aole no e hiki i ke kanaka ke malama i na haku elua; no ka mea, e hoowahawaha ia i kekahi, a e aloha aku hoi i kekahi; a i ole ia, e hoopili aku ia i kekahi me ka haalele i kekahi. Aole e hiki ia oukou ke malama pu i ke Akua a me ka mamona.   
\q1
\v 25 No ia mea, ke olelo aku nei au ia oukou, Mai manao nui ma ko oukou ola ana, i ka oukou mea e ai ai, a i ka oukou mea e inu ai; aole hoi ma ko oukou kino, i ko oukou mea e aahu ai. Aole anei e oi aku ke ola i ka ai, a me kino i ke kapa?   
\q1
\v 26 E nana aku i na manu o ka lewa; aole lakou e lulu hua, aole hoi e oki ai, aole no hoi e hoahu ae iloko o na halepapaa; a ua hanai ko oukou Makua o ka lani ia lakou. Aole anei e oi aku ko oukou maikai i ko lakou?   
\q1
\v 27 Owai la ka mea o oukou o hiki ma ka manao nui ana ke hooloihi aku i kona kiekie i hookahi hailima?   
\q1
\v 28 Heaha hoi ka oukou e manao nui ai i ke kapa? E nana i na lilia o ke kula, i ko lakou ulu ana; aole nae lakou e hana, aole hoi e milo:   
\q1
\v 29 Ke olelo aku nei hoi au ia oukou, O Solomona i kona nani a pau, aole ia i kahiko like ia me kekahi o ia mau mea.   
\q1
\v 30 Ina pela ke Akua e hoonani mai ai i ka nahelehele, ina no ma ke kula i keia la, a i ka la apopo e hooleiia'i iloko o ka umu; aole anei he oiaio kona hoaahu ana mai ia oukou, e ka poe paulele kapekepeke?   
\q1
\v 31 Nolaila hoi, mai ninau aku oukou me ka manao nui, Heaha ka kakou mea e ai ai? Heaha hoi ka kakou mea e inu ai? Heaha hoi ko kakou mea e aahu ai?   
\q1
\v 32 No ka mea, ke hoopapau nei na kanaka e ma keia mau mea a pau. Ua ike no hoi ko oukou Makua o ka lani, he pono ke loaa ia oukou ia mau mea a pau.   
\q1
\v 33 Aka, e imi e oukou mamua i ke aupuni o ke Akua a me kana pono, a e pau ua mau mea la i ka haawiia mai ia oukou.   
\q1
\v 34 Nolaila, mai manao nui aku oukou i ka mea o ka la apopo: no ka mea, na ka la apopo e manao iho i na mea nona iho. O ka ino o kekahi la ua nui ia nona iho.   
\c 7  
\b  
\q1
\v 1 MAI manao ino aku, o manao ino ia mai oukou.   
\q1
\v 2 No ka mea, me ka manao ino a oukou e manao ino aku ai, pela hoi e manao ino ia mai ai oukou. Me ke ana a oukou e ana aku ai, pela no hoi e anaia mai ai no oukou.   
\q1
\v 3 Heaha kau e nana aku ai i ka pula iki iloko o ka maka o kou hoahanau, aole hoi oe i ike i ke kaola iloko o kou maka iho?   
\q1
\v 4 Pehea la hoi oe e olelo aku ai i kou hoahanau, E ae mai na'u e unuhi ka pula iki noloko mai o kou maka, a he kaola no ka hoi iloko o kou maka iho?   
\q1
\v 5 E ka hookamani, e unuhi mua oe i ke kaola mailoko ae o kou maka iho, alaila oe e ike pono ai ke unuhi ae i ka pula iki maloko o ka maka a kou hoahanau.   
\b  
\q1
\v 6 Mai haawi aku i ka mea hoano na na ilio, aole hoi e hoolei i ka oukou mau momi imua o na puaa, o hehiia ilalo e ko lakou mau wawae, a e kepa mai hoi lakou e moku oukou.   
\b  
\q1
\v 7 E noi, a e haawiia na oukou; e imi, a e loaa hoi ia oukou: e kikeke, a e weheia no oukou.   
\q1
\v 8 No ka mea, o ka mea noi, ua haawiia nana; o ka mea imi, ua loaa no ia ia; a o ka mea kikeke, ua weheia nona.   
\q1
\v 9 Owai la ke kanaka o oukou e haawi aku i ka pohaku na kana keiki, ke noi mai ia i berena?   
\q1
\v 10 A i noi mai ia i ia, e haawi aku anei oia i nahesa nana?   
\q1
\v 11 Ina paha oukou he poe hewa i ike i ka haawi aku i na mea maikai na ka oukou mau keiki, he oi nui aku ko oukou Makua i ka lani ma kona haawi ana mai i na mea maikai na ka poe e noi aku ia ia.   
\q1
\v 12 O na mea a pau a oukou e makemake ai e hanaia mai ia oukou e na kanaka, oia ka oukou e hana aku ai ia lakou; no ka mea, pela no ka ke kanawai a me ka ka poe kaula.   
\b  
\q1
\v 13 E komo ae oukou ma ka puka pilikia; no ka mea, he akea ka puka, he palahalaha hoi ke alanui e hiki aku ai i ka make; a nui wale hoi ka poe komo ilaila.   
\q1
\v 14 Aka, he pilikia ka puka, he ololi hoi ke ala e hiki aku ai i ke ola, a kakaikahi wale ka poe loaa ia.   
\b  
\q1
\v 15 E malama hoi ia oukou no ka poe kaula hoopunipuni ke hele mai io oukou nei me ka aahu hipa; aka, maloko, he poe ilio hihiu hae lakou.   
\q1
\v 16 Ma ko lakou hua e ike aku ai oukou ia lakou. E ohiia anei ka huawaina noluna mai o ke kakalaioa, a o na fiku hoi noluna mai o ka puakala?   
\q1
\v 17 Oia hoi, o na laau maikai a pau, ua hua mai no lakou i na hua maikai; aka, o ka laau ino, ua hua mai no hoi ia i na hua ino.   
\q1
\v 18 Aole e hiki i ka laau maikai ke hua mai i ka hua ino; aole hoi e hiki i ka laau ino ke hua mai i ka hua maikai.   
\q1
\v 19 O kela laau a o keia laau ke hua ole mai ia i ka hua maikai, ua kuaia oia ilalo, a ua kiolaia'ku hoi ia iloko a ke ahi.   
\q1
\v 20 Nolaila hoi, ma ko lakou hua, e ike aku ai oukou ia lakou.   
\b  
\q1
\v 21 O ka poe e olelo mai ia'u, E ka Haku, E ka Haku, aole e pau lakou i ke komo mai iloko o ke aupuni o ka lani; aka, o ka mea e malama i ka makemake o ko'u Makua iloko o ka lani.   
\q1
\v 22 He nui ka poe e olelo mai ana ia'u ia la, E ka Haku, E ka Haku, aole anei makou i ao aku ma kou inoa? i mahiki aku hoi i na uhane ino ma kou inoa? a i hana aku i na hana mana he nui ma kou inoa?   
\q1
\v 23 Alaila, e hai aku au ia lakou, Aole au i ike ia oukou; e haele oukou pela mai o'u aku nei, e ka poe hana ino.   
\b  
\q1
\v 24 Nolaila hoi, o ka mea lohe i keia mau olelo a'u, a malama hoi ia, e hoohalike au ia ia me ke kanaka naauao, nana i kukulu kona hale maluna o ka pohaku.   
\q1
\v 25 A haule mai la ka ua, kahe mai la ka wai, nou mai la ka makani, a pa ma ua hale la, aole nae ia i hiolo; no ka mea, ua hookumuia oia maluna o ka pohaku.   
\q1
\v 26 A o ka mea lohe ia mau olelo a'u, a malama ole hoi ia, e hoohalikeia hoi ia me ke kanaka naaupo, nana i kukulu kona hale maluna o ke one.   
\q1
\v 27 A haule mai la ka ua, kahe mai la ka wai, nou mai la ka makani, a pa ma ua hale nei, a hiolo iho la ia; nani wale hoi kona hiolo ana.   
\b  
\q1
\v 28 A hooki ae la Iesu ia mau olelo, kahaha iho la na kanaka i kana ao ana.   
\q1
\v 29 No ka mea, ao aku la ia ia lakou me he mea mana la, aole e like me ka poe kakanolelo.   
\c 8  
\b  
\q1
\v 1 A IHO mai la ia mai ka mauna mai, he nui loa ka poe i ukali ia ia.   
\q1
\v 2 Aia hoi kekahi lepero i hele mai io na la, moe iho la imua oua, i mai la, E ka Haku, a i makemake oe, e hiki no ia oe ke huikala mai ia'u.   
\q1
\v 3 O aku la Iesu i kona lima, hoopa iho la ia ia, i aku la, Ke makemake nei au, e huikalaia hoi oe. Ola koke iho la kona mai lepera.   
\q1
\v 4 I aku la o Iesu ia ia, E ao oe, mai hai aku ia hai. Aka, e hele oe e hoike aku ia oe iho i ke kahuna, e haawi i ka mohai a Mose i kauoha mai ai, i mea e'ike ai lakou.   
\b  
\q1
\v 5 A hiki aku la o Iesu i Kaperenauma, hele mai la kekahi lunahaneri io na la, noi mai la ia ia.   
\q1
\v 6 I mai la, E ka Haku, ke moe iho la no kuu kauwa ma ka hale i ka mai lolo, ua ehaeha loa.   
\q1
\v 7 I aku la o Iesu ia ia, E hele aku no au e hoola ia ia.   
\q1
\v 8 Olelo mai la ka lunahaneri, i mai la, E ka Haku, aole o'u pono e komo ae oe iloko o ko'u hale; e olelo wale mai no oe, a e ola no kuu kauwa.   
\q1
\v 9 No ka mea, he kanaka aku wau malalo o ke alii, he poe koa malalo iho o'u; a olelo aku no au i kekahi, E hele aku, a hele aku no ia, a i kekahi hoi, E hele mai, a hele mai no ia; a i kuu kauwa, E hana ia mea, a hana no ia.   
\q1
\v 10 A lohe ae la o Iesu, mahalo ae la ia, i mai la i ka poe e ukali aku ana, He oiaio ka'u e olelo aku nei ia oukou, aole au i ike i ka manaoio nui e like me keia iloko o ka Iseraela.   
\q1
\v 11 Ke i aku nei au ia oukou, he nui ka poe e hele mai, mai ka hikina a me ke komohana mai, a e noho pu lakou me Aberahama, a me Isaaka, a me Iakoba iloko o ke aupuni o ka lani.   
\q1
\v 12 A o na keiki o ke aupuni, e kipakuia'ku lakou iloko o ka pouli iwaho, malaila e uwe ai, a e uwi ai na niho.   
\q1
\v 13 Olelo aku la o Iesu i ka lunahaneri, O hoi oe; a e like me kau i manaoio mai ai, pela hoi e hanaia 'ku ai nou. Ola iho la no kana kauwa ia hora.   
\b  
\q1
\v 14 Komo ae la o Iesu iloko o ka hale o Petero, ike iho la ia i kona makuahonoaiwahine e moe ana i ka mai kuni.   
\q1
\v 15 Hoopa aku la ia i kona lima, haalele iho la ke kuni ia ia, ala ae la ia, a lawelawe na lakou.   
\b  
\q1
\v 16 A ahiahi ae la, halihaliia mai io na la na mea he nui wale i uluhia e na daimonio; mahiki aku la ia i na uhane ma ka olelo, a hoola iho la i ka poe mai a pau:   
\q1
\v 17 Pela i ko ai ka olelo a ke kaula a Isaia, i i mai ai, Nana no i lawe ko kakou nawaliwali, nana hoi i halihali ko kakou mai.   
\b  
\q1
\v 18 A ike ae la o Iesu, ua puni ia i ka poe kanaka he nui wale, kena mai la ia e holo ma kela kapa.   
\q1
\v 19 Hele mai la kekahi kakauolelo, i aku la ia ia, E ke Kumu, e hahai aku no au ia oe i na wahi a pau au e hele ai.   
\q1
\v 20 I mai la Iesu ia ia, He mau lua ko na alopeke, he mau punana ko na manu o ka lewa; aka, o ke Keiki a ke kanaka, aohe ona wahi e hoomoe ai i kona poo.   
\q1
\v 21 Olelo aku la ia ia kekahi haumana ana, E ka Haku, e ae mai oe ia'u e hele mua au e kanu i kuu makuakane.   
\q1
\v 22 Olelo mai la Iesu ia ia, E hahai mai oe ia'u, na ka poe make no e kanu i ko lakou poe make.   
\b  
\q1
\v 23 Ee aku la ia maluna o ka moku, a hahai aku la kana mau haumana ia ia.   
\q1
\v 24 Aia hoi, he ino nui ma ka moanawai, a popoiia'e la ka moku e na ale: aka, ua hiamoe oia.   
\q1
\v 25 A hele aku la na haumana ana e hoala ia ia, i aku la, E ka Haku, e hoola mai ia makou, o make makou.   
\q1
\v 26 I mai la oia ia lakou, Heaha ka oukou e makau ai, e ka poe paulele kapekepeke? Ku ae la ia iluna, papa aku la ia i ka makani a me ka loko, a malie loa iho la.   
\q1
\v 27 Mahalo aku la ua poe kanaka la, i aku la, Heaha ke ano o ia nei, i hoolohe mai ai ka makani a me ka moanawai ia ia?   
\b  
\q1
\v 28 A hiki aku la ia i kela kapa, i ka aina o ko Gadara, halawai mai la me ia elua kanaka i uluhia e na daimonio, i hoea mai, mai na halekupapau mai, ua nui loa ko ku o ka hau, aohe kanaka i aa aku e maalo ma ia wahi.   
\q1
\v 29 Aia hoi, kahea mai la laua, i mai la, Heaha kau ia makou nei, e Iesu ke Keiki a ke Akua? Ua hiki e mai nei anei oe e hana eha mai ia makou mamua o ka manawa?   
\q1
\v 30 A i kahi mamao aku, he kumupuaa e ai ana.   
\q1
\v 31 Noi mai la ia mau daimonio ia ia, i mai la, A i mahiki aku oe ia makou, e ae mai oe e haele makou e komo aku iloko o ke kumupuaa.   
\q1
\v 32 I aku la ia ia lakou, ou haele. A hemo lakou iwaho, komo aku la lakou iloko o ua kumupuaa la: aia hoi, naholo kiki aku la ua kumupuaa la a pau ilalo ma ka pali i ka moanawai, a pau lakou i ka make maloko o ka wai.   
\q1
\v 33 Auhee aku la ka poe kahupuaa, a hiki aku la i ke kulanakauhale, hai aku la lakou ia mau mea a pau, a me ka mea o ua mau kanaka la i uluhia e na daimonio.   
\q1
\v 34 Aia hoi, holo nui mai la ko ke kulanakauhale iwaho, e halawai me Iesu, a ike mai la ia ia, nonoi nui mai la lakou ia ia e hele aku ia mai ko lakou aina aku.   
\c 9  
\b  
\q1
\v 1 E E ae la ia maluna o ka moku, holo aku la ia, a hiki aku la i kona kulanakauhale.   
\q1
\v 2 Aia hoi, hali mai la lakou io na la i kekahi mai lolo, e moe ana iluna o kahi moe, A ike aku la o Iesu i ko lakou manaoio, i aku la ia i ka mai lolo, E kuu keiki, e hoolana i kou manao, ua kalaia kon hewa.   
\q1
\v 3 Alaila, ohumu iho la kekahi poe kakauolelo iloko o lakou iho, He olelo hoino ka ia nei.   
\q1
\v 4 Ike iho la Iesu i ko lakou manao, ninau aku la, No ke aha la oukou e manao ino ai iloko o ko oukou naau?   
\q1
\v 5 Mahea ka hiki pono ke olelo, Ua kalaia kou hewa, a ke olelo paha, E ala'e a e hele?   
\q1
\v 6 I ike hoi oukou, he mana no ko ke Keiki a ke kanaka e kala aku ai i na hewa ma ka honua nei, E ku ae, (wahi ana i ka mai lolo,) e lawe oe i kou wahi moe, a e hoi i kou hale.   
\q1
\v 7 A ku ae la ia, a hoi aku la i kona hale.   
\q1
\v 8 A ike aku la na kanaka, mahalo aku la, a hoonani aku la lakou i ke Akua, nana i haawi mai ia mana no na kanaka.   
\b  
\q1
\v 9 A hele aku la o Iesu mai ia wahi aku, ike mai la ia i kekahi kanaka e noho ana ma kahi hookupu, o Mataio kona inoa; i mai la oia ia ia, E hahai mai oe ia'u. Ku ae la ia a hahai aku la ia ia.   
\b  
\q1
\v 10 A i ko Iesu noho ana i ka ahaaina iloko o ka hale, aia hoi, he nui na lunaauhau a me na lawehala i hele mai, a noho pu me ia a me kana poe haumana.   
\q1
\v 11 A ike aku la ka poe Parisaio, i mai la lakou i kana poe haumana, No ke aha la e ai pu ai ka oukou humu me na lunaauhau a me na lawehala?   
\q1
\v 12 Lohe ae la o Iesu, i aku la oia ia lakou, Aole no ka poe ola ke kahuna lapaau, no ka poe mai no ia.   
\q1
\v 13 E hele hoi oukou e ao i ke ano o keia, o ke aloha ko'u makemake, aole ka mohai: ua hele mai nei au e ao aku i ka poe hewa e mihi, aole i ka poe pono.   
\b  
\q1
\v 14 Alaila, hele mai la na haumana a Ioane io na la, i mai la, Ke hookeai pinepine nei makou a me ka poe Parisaio, heaha hoi ka mea e hookeai ole ai kau poe haumana?   
\q1
\v 15 I aku la Iesu ia lakou, E hiki anei i na keiki o ke kanemare ke kaniuhu, i ka wa e noho pu ai ia me lakou? E hiki mai ana ka manawa e laweia'ku ai ke kanemare mai o lakou aku, ilaila lakou e hookeai ai.   
\q1
\v 16 Aole no kekahi e pinai i ka apana lole hou maluna o ka lole kahiko, o moku ka mea kahiko i ka mea hou, a nui aku ka nahae.   
\q1
\v 17 Aole hoi e ukuhi na kanaka i ka waina hou maloko o na hue ili kahiko, o nahae na hue, a kahe aku ka waina, a pau na hue: aka, ukuhi no lakou i ka waina hou iloko o na hue hou, a koe pu ia mau mea i ka malamaia.   
\b  
\q1
\v 18 I kana olelo ana ia mau mea ia lakou, aia hoi, hele mai kekahi luna, moe iho ia ia, i mai la ia ia, Ua make iho nei ka'u kaikamahine, aka, e hele mai oe, a kau i kou lima maluna ona, a e ola ia.   
\q1
\v 19 Ku ae la o Iesu iluna, hahai aku la ia ia me kana poe haumana.   
\b  
\q1
\v 20 Aia hoi, he wahine hee koko i na makahiki he umikumamalua, hele aku la ia mahope iho ona, a hoopa aku la i ka lepa o kona aahu:   
\q1
\v 21 No ka mea, i iho la ia iloko ona, A i hoopa wale aku au i kona aahu, e ola au.   
\q1
\v 22 Haliu ae la o Iesu, ike ae la ia ia, i aku la, E ke kaikamahine, e hoolana i kou manao: ua hoola mai kou manaoio ia oe. A ola koke iho la ua wahine la ia hora.   
\q1
\v 23 A hiki aku la o Iesu i ka hale o ua luna la, ike ae la ia i ka poe hookiokio, a me na kanaka e kumakena ana,   
\q1
\v 24 I aku la oia ia lakou, Ou hoi oukou, aole i make ke kaikamahine, ua hiamoe no. A hoowahawaha mai la lakou ia ia.   
\q1
\v 25 A pau ae la ka poe kanaka i ka hookukeia iwaho, komo aku la ia iloko, lalau iho la i kona lima, a ala ae la ua kaikamahine nei.   
\q1
\v 26 A kaulana aku la ia mea ma ia aina a pau.   
\b  
\q1
\v 27 A hele aku la o Iesu mai ia wahi aku, elua kanaka makapo i hahai ia ia, kahea mai la laua, i mai la, E ka mamo a Davida, e aloha mai oe ia maua.   
\q1
\v 28 Komo ae la ia iloko o ka hale, a hele mai ua mau makapo la io na la, ninau aku la Iesu ia laua, Ke manaoio nei anei olua, e hiki no ia'u ke hana i keia mea? I aku la laua ia ia, Ae, e ka Haku.   
\q1
\v 29 Alaila, hoopa aku la ia i ko laua mau maka, i aku la, E like me ko olua manaoio ana mai, pela e hanaia aku ai no olua.   
\q1
\v 30 Kaakaa ae la ko laua mau maka. Papa aku la Iesu ia laua, i aku la, E malama olua o ikea ia e hai.   
\q1
\v 31 Aka, hele aku la laua, a hookaulaua aku la ia ia ma ia aina a puni.   
\b  
\q1
\v 32 A hele aku la lakou iwaho, aia hoi, haliia mai io na la he kanaka aa, ua uluhia e ka daimonio.   
\q1
\v 33 A mahikiia aku ka daimonio, olelo mai la ua aa la, a mahalo ae la ka poe kanaka, i ae la, Aole i ikea ka mea like me neia iwaena o ka Iseraela.   
\q1
\v 34 Aka, olelo aku la ka poe Parisaio, Ke mahiki aku nei oia nei i na daimonio ma ke alii o na daimonio.   
\b  
\q1
\v 35 Kaahele ae la o Iesu ma na kulanakauhale a pau, a me na kauhale, e ao ana iloko o na halehalawai o lakou, a e hai mai ana i ka euanelio no ke aupuni, me ka hoola i na mai a pau, a me na nawaliwali a pau o na kanaka.   
\b  
\q1
\v 36 A ike mai la ia i ka ahakanaka, hu ae la kona aloha ia lakou; no ka mea, ua maluhiluhi lakou, ua auwana hoi e like me na hipa kahu ole.   
\q1
\v 37 Alaila, i mai la ia i kana poe haumana, He nui ke kihapai ai, ua hapa no nae ka poe lawehana.   
\q1
\v 38 No ia mea, e noi oukou i ka Haku nana ke kihapai ai, e hoouna oia i na lawehana iloko o kana kihapai.   
\c 10  
\b  
\q1
\v 1 A HEA ae la ia i kana poe haumana he umikumamalua, alaila haawi mai la i ka mana no lakou e mahiki aku ai i na uhane ino, a e hoola aku i na mai a pau a me na nawaliwali a pau.   
\b  
\q1
\v 2 Eia hoi na inoa o ka poe lunaolelo he umikumamalua. O ka mua, o Simona i kapaia o Petero, me kona kaikaina o Anederea; o Iakobo na Zebedaio, a me kona kaikaina o Ioane;   
\q1
\v 3 O Pilipo a me Baretolomaio; o Toma a me Mataio ka lunaauhau; o Iakobo na Alepaio, a me Lebaio i kapaia o Tadaio.   
\q1
\v 4 O Simon a no Kanaana a me Iuda Isekariota, nana ia i kumakaia aku.   
\b  
\q1
\v 5 O keia poe umikumamalua ka Iesu i hoouna ae ai, kauoha mai la ia lakou, i mai la. Mai hele oukou ma ke kuamoo o ko na aina e, aole hoi e komo i kekahi kulanakauhale o ko Samaria:   
\q1
\v 6 Aka, e hele oukou i ka poe hipa auwana o ka ohana o Iseraela,   
\q1
\v 7 I ko oukou hele ana, e ao aku, me ka i ana, Ua kokoke mai nei ke aupuni o ka lani.   
\q1
\v 8 E hoola i na mai, e huikala i na lepero, e hoala i na mea make, e mahiki aku i na daimonio; ua haawi wale ia mai ia oukou, e haawi wale aku oukou.   
\q1
\v 9 Mai hahao oukou i gula, aole hoi i kala, aole hoi i keleawe iloko o ko oukou mau hipuu;   
\q1
\v 10 Aole hoi he aa no ko oukou hele ana, aole hoi elua aahu, aole hoi kamaa, aole no hoi he kookoo; no ka mea, he pono ke loaa i ka mea hana ka ai nana.   
\q1
\v 11 A o ke kulanakauhale, a o ke kauhale paha, a oukou e komo aku ai, e ninau aku i ko laila poe pono; malaila no e noho ai a hiki i ka manawa e hele aku ai malaila aku.   
\q1
\v 12 Aia komo aku oukou iloko o ka hale, e uwe aku i ko laila.   
\q1
\v 13 A i pono ko ka hale, e kau ko oukou aloha maluna ona; aka, i pono ole, e hoi hou mai no ko oukou aloha io oukou la.   
\q1
\v 14 A o ka mea hookipa ole ia oukou, aole hoi e hoolohe i ka oukou olelo, a hele aku oukou iwaho o kela hale, a o kela kulanakauhale paha, e lulu iho i ka lepo o ko oukou wawae.   
\q1
\v 15 He oiaio ka'u o olelo aku nei ia oukou, E aho no ka hewa ana o ko Sodoma a me ko Gomora i ko ia kulanakauhale i ka la e hookolokolo ai.   
\b  
\q1
\v 16 Eia hoi, ko hoouna aku nei au ia oukou e like me na hipa mawaena o na ilio hihiu hae; no ia mea, e maalea oukou e like me na nahesa, e noho malie hoi e like me na manu nunu.   
\q1
\v 17 E malama hoi ia oukou i na kanaka? no ka mea, e haawi aku lakou ia oukou i ka aha hookolokolo, e hahau hoi lakou ia oukou iloko o ko lakou mau halehalawai;   
\q1
\v 18 A no'u nei e alakaiia'ku ai oukou imua o na kiaaina a me na alii, i mea o ike ai no lakou, a no ko na aina e.   
\q1
\v 19 Aia haawiia'ku oukou, mai manao nui i ka oukou e olelo aku ai; no ka mea, e haawiia aku ia oukou i kela manawa ka oukou mea e olelo aku ai.   
\q1
\v 20 No ka mea, aole na oukou e olelo aku, na ka Uhane no o ko oukou Makua e olelo ana ma o oukou la.   
\q1
\v 21 E haawi ana ka hoahanau i ka hoahanau e make, a o ka makuakane i ke keiki; a e ku e na keiki i na makua, e hoolilo ia lakou i ka make.   
\q1
\v 22 No ko'u inoa e inainaia mai ai oukou e na kanaka a pau: aka, o ka mea hoomau aku a hiki i ka hopeua, e ola ia.   
\q1
\v 23 Aia hana ino mai lakou ia oukou iloko o kekahi kulanakauhale, e holo aku oukou i kekahi; he oiaio ka'u e olelo aku nei ia oukou, Aole e pau e na kulanakauhale o ka Iseraela i ke kaaheleia e oukou, a hihi mai no ke Keiki a ke kanaka.   
\b  
\q1
\v 24 Aole he kiekie ka haumana maluna o ke kumu, aole hoi ke kauwa maluna o kona haku.   
\q1
\v 25 He aho no ka haumana ke like ia me kana kumu, a o ke kauwa ke like ia me kona haku. Ina o kapa mai lakou i ka mea nona ka hale, o Belezebuba, e nui auanei ko lakou kapa ana i ko ka hale pela.   
\q1
\v 26 Mai makau hoi ia lakou; no ka mea, aohe mea i uhiia e ole e hoakakaia'na, aohe mea i hunaia e ole e hoikeia'na.   
\q1
\v 27 O ka'u e olelo aku nei ia oukou ma ka pouli nei, oia ka oukou e hai aku ai ma ka malamalama; a o ka mea a oukou e lohe nei ma ka pepeiao, oia ka oukou e kala aku ai maluna o na hale.   
\q1
\v 28 Mai makau aku hoi oukou i ka poe nana e pepehi mai ke kino, aole nae e hiki ia lakou ke pepehi i ka uhane; aka, e makau aku i ka mea nona ka mana e make ai ka uhane a me ke kino iloko o Gehena.   
\q1
\v 29 Aole anei i kuaiia na manu liilii elua i kekahi asario? aole hoi e haule wale kekahi o laua ma ka lepo, ke ole ko oukou Makua.   
\q1
\v 30 Ua pau loa no hoi na lauoho o ko oukou mau poo i ka heluia.   
\q1
\v 31 Nolaila, mai makau oukou, ua oi loa aku oukou mamua o na manu liilii he nui loa.   
\q1
\v 32 Nolaila, o ka mea nana au e hooia aku imua o na kanaka, na'u hoi ia e hooia aku imua o ko'u Makua iloko o ka lani.   
\q1
\v 33 A o ka mea nana au o hoole aku imua o na kanaka, na'u hoi ia e hoole aku imua o ko'u Makua iloko o ka lani.   
\b  
\q1
\v 34 Mai manao oukou i hele mai nei au e lawe mai i ke kuikahi ma ka honua; o ka pahikaua ka'u i hele mai nei e lawe mai, aole ke kuikahi.   
\q1
\v 35 No ka mea, i hele mai nei au e hookuee i ke kanaka i kona makuakane, a i ke kaikamahine i kona makuwahine, a i ka hunonawahine i kona makuahunoaiwahine.   
\q1
\v 36 O na enemi a ke kanaka, no kona hale iho no lakou.   
\q1
\v 37 O ka mea hookela aku i ke aloha i kona makuakane a i kona makuwahine, aole no ia'u, aole ia e pono no'u: a o ka mea hookela aku i ke aloha i kana keikikane a i ke kaikamahine, aole ia'u, aole hoi ia e pono no'u.   
\q1
\v 38 A o ka mea kaikai ole i kona kea, a e hahai mai mamuli o'u, aole ia e pono ia'u.   
\q1
\v 39 O ka mea malama i kona ola, e lilo no kona ola; aka, o ka mea haalele i kona ola no'u nei, e loaa ia ia ke ola.   
\b  
\q1
\v 40 O ka mea hookipa mai ia oukou, oia ke hookipa mai ia'u; a o ka mea, hookipa mai ia'u, oia ke hookipa mai i ka mea nana au i hoouna mai.   
\q1
\v 41 O ka mea hookipa mai i ke kaula, no ka mea, he kaula ia, e loaa ia ia ka uku no ke kaula; a o ka mea hookipa mai i ke kanaka pono, no ka mea, he kanaka pono ia, e loaa ia ia ka uku no ke kanaka pono.   
\q1
\v 42 O ka mea nana e haawi mai i ko kiaha wai huihui e inu, no kekahi o keia mau mea uuku, no ka mea, he haumana ia, he oiaio ka'u e olelo aku nei ia oukou, Aole ia e nele i kona uku.   
\c 11  
\b  
\q1
\v 1 A OKI ae la ka Iesu ao ana aku i kana poe haumana he umikumamalua, hele aku la ia malaila aku, e ao a e olelo aku iloko o ko lakou mau kulanakauhale.   
\b  
\q1
\v 2 Lohe ae la o Ioane iloko o ka halepaahao i na hana a Kristo, hoouna mai la ia i na haumana ana elua.   
\q1
\v 3 Ninau aku la ia ia, O oe io no anei ka mea e hele mai ana; e kali anei makou i kekahi mea e ae?   
\q1
\v 4 Olelo mai la Iesu, i mai la ia laua, Ou hoi olua, e hai aku ia Ioane i na mea a olua i lohe, a i ike iho nei.   
\q1
\v 5 Ua ike na makapo, ua hele na oopa, ua huikalaia na lepero, ua lohe na kuli, ua hoalaia ua make, a ua haiia'ku ka euanelio i ka poe ilihune.   
\q1
\v 6 Pomaikai hoi ka mea i hoohihia ole ia no'u.   
\b  
\q1
\v 7 A hala aku la laua, hoomaka aku la Iesu e olelo i ka poe kanaka no Ioane, i aku la, I hele la oukou i ka waonahele e ike i ke aha? I ka ohe anei i luli i ka makani?   
\q1
\v 8 I hele hoi oukou e ike i ke aha? He kanaka anei i kahikoia i ke kapa pahee? Aia no ka poe i kahikoia i ke kapa pahee iloko o na hale o na'lii.   
\q1
\v 9 I hele hoi oukou e ike i ke aha? He kaula anei? Oia, ke hai aku nei au ia oukou, o ka mea hoi e oi aku i ke kaula.   
\q1
\v 10 Oia no ka mea i palapalaia nona, Aia hoi, ke hoouna aku nei au i ka'u elele mamua ou, nana e hoomakaukau i kou alanui mamua ou.   
\q1
\v 11 He oiaio ka'u e olelo aku nei ia oukou, O na mea a na wahine i hanau ai, aole kekahi o lakou i oi aku imua o Ioane Bapetite: aka, o ka mea liilii loa iloko o ke aupuni o ka lani, ua oi aku ia imua ona.   
\q1
\v 12 Mai ka wa ia Ioane Bapetite mai a hiki ia nei, ua imi ikaika ia ke aupuni o ka lani, a ua laweia e ka poe ikaika no lakou.   
\q1
\v 13 Ua wanana mai ka poe kaula a pau a me ke kanawai, a hiki mai ai o Ioane.   
\q1
\v 14 Ina e hiki ia oukou ke hoomaopopo, oia nei no ua Elia la, ka mea e hele mai ana.   
\q1
\v 15 O ka mea pepeiao lohe la, e hoolohe ia.   
\b  
\q1
\v 16 Me ke aha la au e hoohalike ai i keia hanauna? Ua like no ia me na kamalii e noho ana i kahi kuai, a e kahea aku ana i ko lakou mau hoa,   
\q1
\v 17 I ka i ana aku, E, ua hookiokio aku makou ia oukou, aole oukou i haa mai; ua makena aku makou ia oukou, aole hoi oukou i uwe mai.   
\q1
\v 18 No ka mea, i hele mai nei o Ioane me ka ai ole a me ka inu ole, a ke olelo nei lakou, He daimonio kona.   
\q1
\v 19 I hele mai nei ke Keiki a ke kanaka me ka ai ana a me ka inu ana, a ke olelo nei lakou, Aia hoi, he kanaka pakela ai, pakela inu waina, a he hoalauna no na lunaauhau a me na lawehala. Aka, ua hoaponoia ka naauao e kana poe keiki.   
\b  
\q1
\v 20 Ilaila kana hoomaka ana e hoohewa aku i na kulanakauhale, kahi i hanaia'i ka nui loa o kana mau hana mana; no ka mea, aole lakou i mihi.   
\q1
\v 21 Auwe oe, e Korazina! Auwe oe, e Betesaida! no ka mea, ina i hanaia ma Turo a me Sidona na hana mana i hanaia'ku ai io olua la, ina ua mihi e lakou, iloko o ke kapa ino a me ka lehu ahi.   
\q1
\v 22 Ke olelo aku nei au ia oukou, E aho no ka hewa ana o Turo a me Sidona i ko olua, i ka la e hookolokolo ai.   
\q1
\v 23 O oe hoi, e Kaperenauma, ka i hookiekieia'e i ka lani, e kiolaia oe ilalo i ka po; no ka mea, ina i hanaia ma Sodoma na hana mana i hanaia'ku ai iloko ou, ina ua koe ia a hiki i neia manawa.   
\q1
\v 24 Aka hoi, ke olelo aku nei au ia oukou, E aho no ka hewa ana o Sodoma i kou i ka la e hookolokolo ai.   
\b  
\q1
\v 25 Ia wa la, olelo aku la o Iesu, i aku la, Ke aloha aku nei au ia oe, e ka Makua, ka Haku o ka lani a me ka honua; no ka mea, na huna oe i keia mau mea i ka poe akamai a me ka poe maalea, a ua hoike mai oe ia mau mea i na keiki uuku.   
\q1
\v 26 Oia no, e ka Makua, no ka mea, o ka pono no ia ia oe.   
\q1
\v 27 Ua haawiia mai ia'u na mea a pau o ko'u Makua; aohe kanaka i ike i ke Keiki, o ka Makua wale no; aole hoi he kanaka i ike i ka Makua, o ke Keiki wale no, a me ka mea ia ia e hoike aku ai ke Keiki.   
\b  
\q1
\v 28 E hele mai oukou a pau loa io'u nei, e ka poe luhi a me ka poe kaumaha, na'u oukou e hoomaha aku.   
\q1
\v 29 E amo oukou i ka'u auamo maluna iho o oukou, a e aoia oukou e au: no ka mea, ua akahai au, na haahaa kuu naau, a e loaa ia oukou ka maha no ko oukou mau uhane.   
\q1
\v 30 No ka mea, he oluolu ka'u auamo, he mama hoi ka'u ukana.   
\c 12  
\b  
\q1
\v 1 I A wa la, hele aku la o Iesu i ka la Sabati mawaena o na mahina ai, pololi iho la na haumana ana, a hoomaka aku la lakou e lalau i na huhui palaoa, a ai iho la.   
\q1
\v 2 Ike aku la ka poe Parisaio, i aku la lakou ia ia, Aia ke hana nei kau poe haumana i ka mea ku ole i ke kanawai ke hana i ka la Sabati.   
\q1
\v 3 I mai la oia ia lakou, Aole anei oukou i heluhelu i ka mea a Davida i hana'i, a me ka poe me ia, i ka wa i pololi ai lakou?   
\q1
\v 4 Ia ia i komo aku ai iloko o ka hale o ke Akua, a ai iho la i ka berena hoike, ka mea ku pono ole ia ia ke ai, aole hoi i ka poe me ia, na ka poe kahuna wale no.   
\q1
\v 5 Aole anei oukou i heluhelu ma ke kanawai, o ka poe kahuna iloko o ka luakini i na la Sabati, ua hana lakou i ka la Sahati, aole hoi a lakou hala?   
\q1
\v 6 Ke olelo aku nei au ia oukou, Eia maanei kekahi, ua oi aku ia mamua o ka luakini.   
\q1
\v 7 Ina paha i ike oukou i ke ano o keia, O ke aloha ko'u makemake. aole ka mohai, ina ua hoohewa ole mai oukou i ka poe hala ole.   
\q1
\v 8 No ka mea, o ko Keiki a ke kanaka, oia ka Haku no ka la Sabati.   
\b  
\q1
\v 9 Holo aku la ia mai ia wahi aku, a komo aku la iloko o ko lakou halehalawai.   
\b  
\q1
\v 10 Aia ilaila he kanaka, ua maloo kona lima: ninau mai la lakou ia ia, i mea e hoopii aku ai lakou ia ia, i mai la, He mea pono anei ke hoola aku i ka la Sabati?   
\q1
\v 11 I aku la oia ia lakou, Owai la ke kanaka o oukou hookahi hipa kana, a i haule iho i ka lua i ka la Sabati, aole anei ia e lalau aku ia ia, a e huki mai iluna?   
\q1
\v 12 Aole anei e oi aku ke kanaka mamua o ka hipa? He mea pono no ke hana maikai i ka la Sabati.   
\q1
\v 13 Alaila, olelo aku la ia i ua kanaka la, E o mai kou lima: o mai la ia, a ola ae la ia e like me kela lima.   
\b  
\q1
\v 14 Hele aku la ka poe Parisaio iwaho, kukakuka ae la lakou i mea e make ai oia ia lakou.   
\b  
\q1
\v 15 A ike iho la o Iesu ia mea, hele aku la ia mai ia wahi aku; a he nui ka poe kanaka i hahai aku ia ia, hoola iho la oia ia lakou a pau.   
\q1
\v 16 Papa mai la oia ia lakou, aole lakou e hai hoike aku ia ia:   
\q1
\v 17 I ko ai ka olelo a ke kaula a Isaia, i i mai ai,   
\q1
\v 18 Aia hoi kuu kauwa a'u i koho ai, kuu mea aloha, ia ia ka olioli o kuu naau; e kau aku ana au i kuu Uhane maluna iho ona, a e hai aku ia i ke kanawai i na lahuikanaka.   
\q1
\v 19 Aole ia e hakaka, aole hoi e walaau aku, aole hoi e lohea kona leo ma na alanui.   
\q1
\v 20 Aole e hai ia ia ka ohe pepe, aole hoi ia e kinai i ka uiki e hoopipi ana, a kui aku ia i ke kanawai a lanakila.   
\q1
\v 21 A e paulele hoi na lahuikanaka ma kona inoa.   
\b  
\q1
\v 22 Alaila, haliia mai io na la kekahi kanaka i uluhia e ka daimonio, ua makapo, ua paa hoi ka leo; a hoola iho la kela ia ia, a olelo ae la ka leopaa, a ike ae hi ka makapo.   
\q1
\v 23 Kahaha iho la na kanaka a pau, i ae la, O ka Mamo anei keia a Davida?   
\q1
\v 24 A lohe ae la ka poe Parisaio, i ae la lakou, Ma o Belezebuba la wale no, ke alii o na daimonio, kana mahiki ana aku i na daimonio.   
\q1
\v 25 Ike ae la o Iesu i ko lakou manao ana, i aku la ia lakou, O ke aupuni i mokuahana ia ia iho, e pau ia, a o ke kulanakauhale a o ka poe ohana i mokuahana ia ia iho, aole ia e mau.   
\q1
\v 26 Ina paha o Satana e mahiki aku ia Satana, ua mokuahana oia ia ia iho, a pehea la hoi e mau ai kona aupuni?   
\q1
\v 27 Ina paha owau e mahiki aku i na daimonio ma o Belezebuba la, ma owai la hoi e mahiki aku ai na keiki a oukou ia lakou? Nolaila, e lilo lakou i poe hooponopono ia oukou.   
\q1
\v 28 Ina paha owau e mahiki aku i na daimonio ma ka Uhane o ke Akua, ina ua kokoke mai ke aupuni o ke Akua io oukou nei.   
\q1
\v 29 Pehea la e hikiai i kekahi ke komo iloko o ka hale o ke kanaka ikaika, a hao i kona waiwai? Aia nakinaki ia mamua i ke kanaka ikaika a paa, alaila e hao ia i na mea o kona hale.   
\q1
\v 30 O ka mea aole me au nei, o ko'u enemi no ia; a o ka mea hoiliili pu ole me au, ua hooleilei wale aku no ia.   
\b  
\q1
\v 31 Ke olelo aku nei hoi au ia oukou, O na hala a pau, a me na olelo hoino e kalaia'na no na kanaka: aka, o ka olelo hoino aku i ka Uhane Hemolele, aole ia e kalaia no na kanaka.   
\q1
\v 32 O ka mea olelo hoino mai i ke Keiki a ke kanaka, e kalaia'na oia; aka, o ka mea olelo hoino i ka Uhane Hemolele, aole loa e kalaia'na oia i keia ao, aole hoi i kela ao aku.   
\q1
\v 33 Ina e hoomaikai aku oukou i ka laau, e hoomaikai pu no hoi i ko na hua; aka i ole, alaila e hoino aku i ka laau me ka hoino pu i kona hua; no ka mea, ua ikea ka laau ma kona hua.   
\q1
\v 34 E ka hanauna moonihoawa! pehea la e hiki ai ia oukou ka poe ino ke olelo i na mea maikai? No ka mea, no ka piha o ka naau e olelo ai ka waha.   
\q1
\v 35 O ke kanaka maikai, ua lawe mai ia i na mea maikai mailoko ae o ka waiwai maikai o ka naau: a o ke kanaka ino, ua lawe mai ia i na mea ino mailoko ae o ka waiwai ino.   
\q1
\v 36 Ke olelo aku nei au ia oukou, O na huaolelo ino a pau a na kanaka e olelo ai, e hookolokoloia'na lakou ia mea, i ka la e hookolokolo ai.   
\q1
\v 37 No ka mea, ma kau mau olelo e hoaponoia'i oe, a ma kau mau olelo e hoahewaia'i oe.   
\b  
\q1
\v 38 Alaila, olelo mai la kekahi poe kakauolelo a me na Parisaio, i mai la, E ke Kumu, ke ake nei makou e ike aku i hoailona nou.   
\q1
\v 39 Olelo aku la ia, i aku la ia lakou, Ke imi nei ka hanauna hewa, moe kolohe, i hoailona: aole loa e haawiia ka hoailona ia lakou, o ka hoailona a ke kaula a Iona wale no.   
\q1
\v 40 E like me Iona ekolu la ekolu po iloko o ka opu o ka ia nui, pela auanei ke Keiki a ke kanaka, ekolu la ekolu po iloko o ka opu o ka honua.   
\q1
\v 41 E ku e mai auanei na kanaka o Nineva i keia hanauna i ka la hookolokolo, a e hoohewa mai ia lakou nei; no ka mea, mihi iho la lakou i ka olelo ana a Iona: eia hoi, maanei kekahi i oi aku mamua o Iona.   
\q1
\v 42 I ka la hookolokolo e ku e mai auanei ke aliiwahine o ke kukuluhema i keia hanauna, a e hoohewa mai ia lakou nei; no ka mea, i hele mai ia mai na palena o ka honua e hoolohe i ka olelo naauao a Solomona; eia hoi, maanei kekahi i oi aku mamua o Solomona.   
\b  
\q1
\v 43 A puka mai ka uhane ino mailoko mai o kekahi kanaka, hele aku no ia ma na wahi panoa, e imi ana i kahi e maha ai, a loaa ole.   
\q1
\v 44 Alaila, olelo iho no ia, E hoi ana au i ko'u hale, kahi a'u i puka mai ai. A hiki mai, ike iho la ia, ua kaawale ia, ua kahiliia, a ua hoolakolakoia.   
\q1
\v 45 Alaila, hele aku no ia, a lawe pu mai me ia i na uhane e ae i ehiku, ua oi aku ko lakou ino i kona iho; komo lakou iloko, a noho ilaila: a hewa loa aku ka hope o ua kanaka la i kona noho ana mamua. Pela auanei no hoi keia hanauna hewa.   
\b  
\q1
\v 46 Ia ia i olelo ai i na kanaka, aia ku mai la iwaho kona makuwahine, a me kona poe hoahanau, e ake e olelo pu me ia.   
\q1
\v 47 I aku la kekahi ia ia, Aia, ke ku mai la iwaho kou makuwahine a me ou mau hoahanau, e ake e olelo pu me oe.   
\q1
\v 48 Olelo mai la ia, i mai la i ka mea nana i hai aku ia ia, Owai la ko'u makuwahine a me o'u mau hoahanau?   
\q1
\v 49 O mai la ia i kona lima i na haumana ana, i aku la ia, Aia hoi, ko'u makuwahine a me o'u mau hoahanau.   
\q1
\v 50 O ka mea i hana i ka makemake o ko'u Makua i ka lani, oia ko'u kaikaina a me ko'u kaikuwahine, a me ko'u makuwahine.   
\c 13  
\b  
\q1
\v 1 I A la la, hele aku la o Ieau iwaho o ka hale, a noho iho la ia ma kapa o ka loko.   
\q1
\v 2 He nui loa ka poe kanaka i akoakoa mai io na la, ee aku la ia maluna o kekahi moku, noho iho la; a ku nui mai la ua poe kanaka la mauka.   
\q1
\v 3 Ao mai la oia ia lakou i kela mea keia mea ma na olelonane, i ka i ana mai, Aia hoi, hele aku la kekahi kanaka lulu hua e lulu.   
\q1
\v 4 A i kana lulu ana, helelei iho la kekahi ma kapa alanui, lele mai la na manu, a pau ae la ia i ke kikoa.   
\q1
\v 5 Aka helelei iho la kekahi ma kahi hapapa, aohe nui o ka lepo; kupu wawe ae la ia no ka papau o ka lepo.   
\q1
\v 6 A puka mai ka la, mae iho la ia, maloo aku la no ke aa ole.   
\q1
\v 7 Aka helelei iho la kakahi ma kahi kakalaioa, kupu ae la ke kakalaioa a kahihi aku la ia mea.   
\q1
\v 8 Aka helelei iho la hoi kekahi ma ka lepo maikai, a hua mai la i ka hua, he pahaneri ka kekahi, he pakanaono ka kekahi, a he pakanakolu ka kekahi.   
\q1
\v 9 O ka mea pepeiao lohe la, e hoolohe ia.   
\b  
\q1
\v 10 Hele mai la kana poe haumana, ninau aku la ia ia, No ke aha la oe e olelo mai ai ia lakou ma na olelonane?   
\q1
\v 11 Olelo mai la oia ia lakou, i mai la, No ka mea, ua haawiia aku ia oukou e ike i na mea pohihihi o ke aupuni o ka lani, aole nae i haawiia'ku ia lakou.   
\q1
\v 12 O ka mea ua loaa, e haawi hou ia'ku nana a mahuahua; aka, o ka mea ua loaa ole, e laweia'ku kana mai ona aku la.   
\q1
\v 13 Nolaila ka'u e olelo aku nei ia lakou ma na olelonane; no ka mea, i ka nana ana, aole lakou i ike; a i ka lohe ana, aole lakou i hoolohe, aole hoi i hoomaopopo.   
\q1
\v 14 A i ko ai ka wanana a Isaia ia lakou, i ka i ana, I ka lohe ana, e lohe auanei oukou, aole nae e hoomaopopo; a i ka nana ana, e nana auanei oukou, aole nae e ike.   
\q1
\v 15 No ka mea, ua palaka ka naau o keia poe kanaka, ua hookuli lakou i ko lakou mau pepeiao, ua hoopaa hoi i ko lakou mau maka; o ike auanei ko lakou mau maka, o lohe hoi ko lakou mau pepeiao, o manao hoi ko lakou naau, o huli mai lakou, a hoola aku au ia lakou.   
\q1
\v 16 Pomaikai ko oukou mau maka, no ka mea, ua ike: a me ko oukou mau pepeiao, ua lohe.   
\q1
\v 17 He oiaio ka'u e olelo aku nei ia oukou, He nui na kaula a me na kanaka pono i ake e ike i na mea a oukou e ike nei, aole nae lakou i ike; a e lohe hoi i na mea a oukou e lohe nei, aole nae i lohe.   
\b  
\q1
\v 18 E hoolohe oukou i ke ano o ka olelonane no ke kanaka luluhua.   
\q1
\v 19 O kela mea keia mea lohe i ka olelo no ke aupnui me ka hoomaopopo ole: alaila, hele mai no ka mea ino, a kaili aku ia i ka mea i luluia iloko o kona naau. Oia ka mea i luluia ma kapa alanui.   
\q1
\v 20 O ka mea i luluia ma kahi hapapa, oia ka mea i lohe i ka olelo, a hopu koke iho la ia me ka olioli.   
\q1
\v 21 Aole nae he aa iloko ona, nolaila ua pokole kona kupaa ana; a hiki mai ka pilikia a me ka hoino no ka olelo, alaila haule koke iho la ia.   
\q1
\v 22 O ka mea i luluia ma kahi kakalaioa, oia ka mea i lohe i ka olelo; a na ka manao ana i na mea o keia ao, a me ka hoopunipuni ana o ka waiwai e kinai iho ka olelo, a lilo ia i mea hua ole.   
\q1
\v 23 A o ka mea i luluia ma kahi lepo maikai, oia ka mea i lohe i ka olelo me ka hoomaopopo; a hua mai i ka hua he pahaneri ka kekahi, he pakanaono ka kekahi, a he pakanakolu ka kekahi   
\b  
\q1
\v 24 Hai mai la oia i kekahi olelonane hou ia lakou, i mai la, Ua hoohalikeia ke aupuni o ka lani me kekahi kanaka nana i lulu iho i ka hua maikai ma kana mahinaai.   
\q1
\v 25 A i ka wa i hiamoe ai na kanaka, hele mai la kona enemi, a lulu iho la i ka zizania iloko pu me ka palaoa, a hoi aku la.   
\q1
\v 26 A kupu mai ke kino, a opuu ae la, alaila ikea iho la ka zizania.   
\q1
\v 27 Hele mai la na kauwa a ua mea hale la, i mai la ia ia, E ka haku, aole anei oe i lulu iho i ka hua maikai ma kau mahinaai? No hea mai la hoi ka zizania?   
\q1
\v 28 I aku la oia ia lakou, Na ke kanaka enemi ia i hana. Ninau mai la ka poe kauwa ia ia, E kii anei makou e uhuki ia mea?   
\q1
\v 29 I aku la ia, Aole, o uhuki pu oukou i ka palaoa i ko oukou waele ana i ka zizania.   
\q1
\v 30 E waiho no pela, e ulu pu laua a hiki i ka ohi ana: a i ka wa e ohi ai, na'u e olelo aku i ka poe okioki, E houluulu mua oukou i ka zizania, e pua a paa i mea e puhi ai i ke ahi; a o ka palaoa la, e hoiliili ia iloko o ko'u halepapaa.   
\b  
\q1
\v 31 Hai aku la oia ia lakou i kekahi olelonane hou, i aku la, Ua like ke aupuni o ka lani mo kekahi hua makeke a ke kanaka i lawe a kanu iho i kana mahinaai.   
\q1
\v 32 He makalii keia hua i na hua a pau, a kupu ae ia, ua oi kona kino i na laalaau a pau, a lilo ae la ia i laau, a lele mai na manu o ka lewa, a kau iho iluna o kona mau lala.   
\b  
\q1
\v 33 Olelo mai la hoi oia ia lakou i kekahi olelonane hou. Ua like ke aupuni o ka lani me ka mea hu a kekahi wahine i lawe ai, a hui pu me na sato palaoa ekolu, a pau ae la ia i ka hu.   
\b  
\q1
\v 34 Oia mau mea a pau ka Iesu i olelo aku ai i na kanaka ma na olelonane; a ma na oleloane wale no kana olelo ana aku ia lakou:   
\q1
\v 35 I ko ai ka mea i oleloia e ke kaula, i ka i ana mai, E pane aku kuu waha i na olelonane, e hai aku hoi au i na mea i hai ole ia, mai ke kumu mai o ke ao nei.   
\b  
\q1
\v 36 Alaila, haalele aku la Iesu i ka poe kanaka, a hele mai la iloko o ka hale. Hele aku la na haumana io na la, i aku la, E hoakaka mai oe ia makou i ka olelonane no ka zizania ma ka mahinaai.   
\q1
\v 37 Olelo mai la ia, i mai la ia lakou, O ka mea nana i lulu i ka hua maikai, oia ke Keiki a ke kanaka.   
\q1
\v 38 O ka mahinaai, oia ke ao nei: o ka hua maikai, oia na keiki no ke aupuni; a o ka zizania, oia na keiki o ka mea ino.   
\q1
\v 39 O ka enemi nana i lulu ia mea, oia ka diabolo; o ka wa e ohi ai, o ka hopena ia o keia ao; ao ka poe nana e okioki, o ka poe anela ia.   
\q1
\v 40 Me ka zizania i hoiliiliia'i a puhiia'i i ke ahi, pela no hoi i ka hopena o keia ao.   
\q1
\v 41 Na ke Keiki a ke kanaka e hoouna i kona poe anela, a e houluulu mai lakou i na mea hoohihia wale, a me na mea hana ino a pau mailoko mai o kona aupuni;   
\q1
\v 42 A e hoolei aku ia lakou iloko o ka lua ahi; ilaila ka uwe ana a me ka nwi ana o na niho.   
\q1
\v 43 Alaila e lilelile ae ka poe pono e like me ka la iloko o ke aupuni o ka lakou Makua. O ka mea pepeiao lohe la, e hoolohe ia.   
\b  
\q1
\v 44 Eia hou, Ua like ke aupuni o ka lani me ka waiwai i hunaia iloko o kahi kihapai: a loaa ia i ke kanaka, huna hou iho no ia, a hele aku me ka olioli, a kuai lilo aku no i kana mau mea a pau, a kuai lilo mai ia kihapai nona.   
\b  
\q1
\v 45 Eia hou, Ua like ke aupuni o ka lani me ke kanaka kuai, e imi ana i na momi maikai.   
\q1
\v 46 A ike aku ia i kekahi momi maikai loa, hele aku no ia, a kuai lilo aku i kana mau mea a pau, a kuai lilo mai ia momi nona.   
\b  
\q1
\v 47 Eia hou, Ua like ke aupuni o ka lani me ka upena i kuu i ke kai, a puni ae la na ia he nui wale ke ano.   
\q1
\v 48 A piha ia, huki ae lakou iuka, noho iho, a hahao iho i na mea maikai iloko o na ipu, aka, hoolei aku no i na mea ino.   
\q1
\v 49 Pela no i ka hopena o keia ao; e kii mai auanei ka poe anela, a e hookaawale lakou i ka poo hewa maiwaena ae o ka poe pono;   
\q1
\v 50 A e hoolei aku ia lakou iloko o ka lua ahi; ilaila e uwe ai a e uwi ai na niho.   
\b  
\q1
\v 51 Ninau mai la o Iesu ia lakou, Ua ike pono anei oukou i neia mau mea a pau? I aku la lakou ia ia, Ae, e ka Haku.   
\q1
\v 52 Olelo mai la kela ia lakou, No ia mea, kela kakauolelo keia kakauolelo i aoia i na mea o ke aupuni o ka lani, ua like no ia me ke kanaka mea hale, nana i lawe mai na mea hou a me na mea kahiko mailoko mai o kona waihona waiwai.   
\b  
\q1
\v 53 A oki ae la ka Iesu olelo ana mai i keia mau olelonane, helo aku la ia mai ia wahi aku.   
\q1
\v 54 A hiki aku la ia i kona aina, ao aku la ia i na kanaka iloko o ko lakou halehalawai; a kahaha iho la lakou, i ae la, Nohea la ka naauao a me ka hana mana a na kanaka la?   
\q1
\v 55 Aole anei keia ke keiki a ke kamana? Aole anei o Maria ka inoa o kona makuwahine? a o na hoahanau ona, o Iakobo, o Iose, o Simona, a o Iuda?   
\q1
\v 56 A o na kaikuwahine ona, aole anei lakou a pau me kakon? Nohea mai la ia ia keia mau mea a pau?   
\q1
\v 57 A ukiuki iho la lakou ia ia. I aku la Iesu ia lakou, Aole he kaula i hoowahawahaia ma kahi e, aia no ma kona aina a ma kona hale iho no.   
\q1
\v 58 Aohe nui na hana mana ana i hana'i ilaila, no ko lakou hoomaloka.   
\c 14  
\b  
\q1
\v 1 I A wa la, lohe ae la o Herode ke alii kiaaina i ke kaulana o Iesu,   
\q1
\v 2 I aku la ia i kaua poe kauwa, O Ioane Bapetite keia; ua ala mai ia mai ka make mai; nolaila i hanaia'i na hana mana e ia.   
\b  
\q1
\v 3 No ka mea, hopu aku la o Herode ia Ioane a paa, a hahao aku la ia ia iloko o ka halepaahao, no Herodia ka wahine a Pilipo a kona hoahanau.   
\q1
\v 4 No ka mea, i olelo aku o Ioane ia Herode, Aole ou pono ke lawe ia ia nau.   
\q1
\v 5 Manao iho la ia e pepehi ia ia, a makau ae la ia i na kanaka; no ka mea, manao iho la lakou, he kaula ia.   
\q1
\v 6 Aia malamaia'i ka la hanau o Herode, haa mai la ke kaikamahine a Herodia iwaena o lakou, a lealea iho la o Herode.   
\q1
\v 7 Nolaila, hoohiki mai la ia, e haawi mai ia ia i kana mea e noi aku ai.   
\q1
\v 8 A hoeueuia mai oia e kona makuwahine, i aku la ia, O ke poo o Ioane Bapetite kau e haawi mai ai ia'u maluna o ke pa.   
\q1
\v 9 Miuamina iho la ke alii; aka, no kona hoohiki ana, a no ka poe hoaai e noho pu ana me ia, kena aku la ia e haawiia mai.   
\q1
\v 10 Hoouna aku la ia, a oki iho la i ke poo o Ioane iloko o ka halepaahao.   
\q1
\v 11 A laweia mai la kona poo maluna o ke pa, a haawiia mai ia i ua kaikamahino la, a nana ia i lawe aku i kona makuwahine.   
\q1
\v 12 Kii aku la kana poe haumana i ke kino, a kanu iho la; a hele mai la lakou a hai mai la ia Iesu.   
\b  
\q1
\v 13 A lohe ae la o Iesu, holo kaawale aku la ia ma ka moku i kahi nehelehele, a lohe ae la na kanaka, hahai wawae aku la lakou ia ia, mailoko mai o na kulanakauhale.   
\b  
\q1
\v 14 A pae aku la Iesu, ike aku la ia i na Kanaka he nui loa, haehae ke aloha ia lakou, a hoola iho la ia i ko lakou poe mai.   
\b  
\q1
\v 15 A ahiahi ae la, hele mai la kana poe haumana io na la, i aku la, He wahi waonahele keia, a ua hala ae nei ka hora; e hoihoi aku oe i ua poe kanaka nei, i hele lakou i na kauhale, e kuai i ai na lakou.   
\q1
\v 16 I mai la o Iesu ia lakou, Aole e pono no lakou ke hele aku, na oukou e haawi aku i ai na lakou.   
\q1
\v 17 I aku la lakou ia ia, Elima wale no popo berena a makou, a me na ia elua.   
\q1
\v 18 I mai la o Iesu, E lawe mai oukou ia mau mea i o'u nei.   
\q1
\v 19 Kauoha aku la ia i na kanaka e noho iho ilalo ma ka weuweu, lalau aku la ia i na popo berena elima, a me na ia elua, nana ae la ia i ka lani, hoomaikai aku la, wawahi iho la; haawi aku la i ka berena i na haumana, na na haumana hoi i haawi aku ia mau mea i ka poe kanaka.   
\q1
\v 20 Ai iho la lakou a pau, a maona; a hoiliili mai la lakou i na hakina i koe a piha ae la na hinai he umikumamalua.   
\q1
\v 21 O ka poe i ai, elima paha tausani kanaka lakou, he okoa na wahine a me na kamalii.   
\b  
\q1
\v 22 A koi koke aku la Iesu i kana mau haumana e ee iluna o ka moku, a e holo e mamua ma kela kapa, ia ia e hoihoi aku ai i ka poe kanaka.   
\q1
\v 23 A pau ka poe kanaka i ka hoihoiia'ku e ia, pii aku la ia, oia wale no, i kekahi mauna e pule ai: a hiki mai ke ahiahi, oia wale no malaila.   
\q1
\v 24 A o ua moku la, mawaena ia o ka loko e luliia'na e na ale, no ka mea, mamua mai ka makani.   
\q1
\v 25 I ka ha o ka wati o ka po, hele mai la Iesu io lakou la, e hele ana maluna o ka loko.   
\q1
\v 26 Ike aku la na haumana ia ia e hele ana maluna o ka loko, hopohopo iho la lakou, i ae la, He uhane ia! a hooho aku la lakou i ka makau.   
\q1
\v 27 Olelo koke mai la o Iesu ia lakou, E hoolana oukou, owau no keia, mai makau.   
\q1
\v 28 Olelo aku la o Petero ia ia, E ka Haku, a o oe no ia, e olelo mai oe ia'u e hele aku iou la maluna o ka wai.   
\q1
\v 29 I mai la kela, E hele mai. Iho iho la o Petero mai luna o ka moku, a hele aku la ia maluna o ka wai e halawai me Iesu.   
\q1
\v 30 A ike aku la ia i ka makani ikaika, makau iho la ia; a i ka hoomaka ana e poho iho, kahea aku la ia, i aku la, E ka Haku, e hoola mai ia'u.   
\q1
\v 31 Kikoo koke mai la Iesu i kona lima, paa mai la ia ia, i mai la, E ka mea paulele kapekepeke, heaha kau mea i kanalua ai?   
\q1
\v 32 A ee mai la laua maluna o ka moku, malie iho la ka makani.   
\q1
\v 33 Hele mai la ka poe maluna o ka moku, moe iho la lakou imua ona, i aku la, He oiaio o oe no ke Keiki a ke Akua.   
\b  
\q1
\v 34 Holo aku la lakou, a hiki aku la i ka aina o Genesareta.   
\q1
\v 35 A ike mai la ia ia na kanaka o ia wahi, kii aku la lakou ma ia aina a puni, a lawe mai la i ka poe mai a pau io na la;   
\q1
\v 36 Nonoi mai la lakou ia ia e hoopa wale mai i ka lepa o kona aahu; a o ka poe a pau i hoopa mai, ua ola lakou.   
\c 15  
\b  
\q1
\v 1 A LAILA hele mai la io Iesu la na kakauolelo a me na Parisaio no Ierusalema mai, ninau mai la,   
\q1
\v 2 No ke aha la e pale nei kau poe haumana i ka mooolelo a ka poe lunakahiko? No ka mea, aole lakou e holoi i na lima o lakou i ka lakou ai ana.   
\q1
\v 3 Olelo aku la oia ia lakou, i aku la, No ke aha la hoi oukou e pale nei i ke kanawai o ke Akua ma ka oukou mooolelo?   
\q1
\v 4 Ua kauoha mai ke Akua, i ka i ana mai, E malama oe i ka makuakane a me ka makuwahine; a o ka mea olelo hoino aku i ka makuakane a i ka maku wahine paha, e make ia.   
\q1
\v 5 A ke olelo nei oukou, O ka mea e olelo aku i ka makuakane a i ka makuwahine paha, Ua laa, o ka'u mea e pono ai oe;   
\q1
\v 6 Aole ia e malama hou aku i kona makuakane, a me kona makuwahine. Pela oukou i hoole ai i ke kanawai o ke Akua ma ka oukou mooolelo.   
\q1
\v 7 E ka poe hookamani, pono io ka Isaia i olelo mai ai no oukou, i ka i ana,   
\q1
\v 8 O keia poe kanaka, ke hookokoke mai nei lakou ia'u me ko lakou waha, a ke hoomaikai mai nei ia'u me na lehelehe; aka, o ko lakou naau la, he mamao loa ia ia'u.   
\q1
\v 9 Make hewa ko lakou malama ana mai ia'u, i ka lakou ao ana aku i na kauoha a na kanaka i kumu e malamaia'i.   
\b  
\q1
\v 10 Kahea aku la ia i ka poe kanaka, i aku la, E hoolohe mai oukou, a o hoomaopopo hoi.   
\q1
\v 11 Aole e haumia ke kanaka i ka mea i komo ma ka waha; aka, o ka mea i puka ae mailoko mai o ka waha, oia ka mea e haumia ai ke kanaka.   
\q1
\v 12 Alaila, hele aku la kana poe haumana, i aku la ia ia, Ke ike nei anei oe, ua huhu ka poe Parisaio i ko lakou lohe ana i keia olelo?   
\q1
\v 13 Olelo mai la ia, i mai la, O na mea kanu a pau aole i kanuia e ko'u Makua i ka lani, e pau ia i ka uhukiia.   
\q1
\v 14 E waiho pela ia lakou; he poe alakai makapo lakou no na makapo: ina he makapo e alakai i ka makapo, e haule pu laua iloko o ka lua.   
\q1
\v 15 Olelo aku la o Petero ia ia, i aku la, E hoakaka mai oe i keia olelonane.   
\q1
\v 16 I mai la o Iesu, Oukou anei kekahi i hoomaopopo ole?   
\q1
\v 17 Aole anei oukou i ike, o ka mea komo ma ka waha, ua hele iho no ia maloko o ka opu, a ua hooleiia'ku ia ma ke kiona?   
\q1
\v 18 Aka, o ka mea e puka ana mailoko mai o ka waha, mailoko mai ia o ka naau; oia ka mea e haumia ai ke kanaka.   
\q1
\v 19 No ka mea, mailoko mai o ka naau ke puka mai nei na manao ino, ka pepehi kanaka ana, ka moe kolohe ana, ka hookamakama ana, ka aihue ana, ka hoopunipuni ana, a me na olelo ino.   
\q1
\v 20 Oia na mea e hanmia ai ke kanaka: aka, o ka ai ana me na lima holoi ole ia, aole e haumia ke kanaka ia mea.   
\b  
\q1
\v 21 Hele aku la o Iesu mai ia wahi aku, a hiki aku la ma na mokuna o Turo a me Sidona.   
\q1
\v 22 Aia ilaila kekahi wahine Kanaana no ia aina i hele mai ai, kahea mai la ia ia, i mai la, E ka Haku, ka mamo a Davida, e aloha mai oe ia'u, ua uluhia loa kuu kaikamahine e ka daimonio.   
\q1
\v 23 Aole ia i olelo iki aku ia ia. Hele aku la kana mau haumana, a noi aku la ia ia, E hoihoi aku oe ia ia; no ka mea, ke walaau mai nei ia mahope o kakou.   
\q1
\v 24 Olelo mai la ia, i mai la, Ua hoounaia mai nei au i ka ohana hipa auwana o ka Iseraela wale no.   
\q1
\v 25 Hele mai la ua wahine la, moe iho la ia imua ona, i mai la, E ka Haku, e kokua mai oe ia'u.   
\q1
\v 26 Olelo aku la o Iesu, i aku la, Aole e pono ke lawe i ka ai a na kamalii, a hoolei aku na na ilio.   
\q1
\v 27 I mai la kela, He oiaio, e ka Haku; ua ai no nae na ilio i na hunahuna i helelei iho malalo o ka papaaina a ko lakou haku.   
\q1
\v 28 Alaila, olelo aku la o Iesu ia ia, i aku la, E ka wahine, nui kou manaoio; me kau makemake, pela e hanaia'ku ai nou. A ola iho la kana kaikamahine ia hora.   
\b  
\q1
\v 29 Hele aku la o Iesu ma ia wahi aku, a hiki aku la ma ke kae loko i Galilaia: pii aku la ia iluna i kekahi mauna, a noho iho la ilaila.   
\q1
\v 30 He nui ka poe kanaka i hele mai io na la, e halihali pu mai ana i na oopa, i na makapo, i na aa, i na mumuku, a me na mea e ae he nui wale, a waiho iho la ia lakou ma na wawae o Iesu; a hoola iho la oia ia lakou.   
\q1
\v 31 Mahalo aku la ua poe kanaka la i ko lakou ike ana ae i na aa e olelo ana, i na mumuku e ola ana, i na oopa e hele ana, a i na makapo e ike ana; a hoonani aku la lakou i ke Akua o ka Iseraela.   
\b  
\q1
\v 32 Kahea mai la o Iesu i kana poe haumana, i mai la, Ke aloha aku nei ko'u naau i keia poe kanaka, no ka mea, eia ke kolu o ka la i noho ai lakou me au, aole hoi a lakou mea e ai ai; aole au makemake e hoihoi aku ia lakou me ka pololi, o maule auanei lakou ma ke ala.   
\q1
\v 33 I aku la kana poe haumana ia ia, Nohea la e loaa'i ia kakou ka berena ma keia wahi waonahele, i maona ai ka poe nui me neia?   
\q1
\v 34 Ninau mai la o Iesu ia lakou, Ehia na popo berena a oukou? I aku la lakou, Ehiku, a he mau wahi ia liilii.   
\q1
\v 35 Olelo aku la ia i ua poe kanaka la, e noho ilalo ma ka honua.   
\q1
\v 36 Lalau aku la ia i na popo berena ehiku, a me na ia, hooalohaloha aku la, wawahi iho la, haawi aku la i na haumana ana, a haawi aku la hoi na haumana i ka poe kanaka.   
\q1
\v 37 Ai iho la lakou a pau a maona: hoiliili iho la lakou i na hakina i koe, ehiku hinai i piha.   
\q1
\v 38 O ka poe i ai, eha tausani kanaka, he okoa na wahine a me na kamalii.   
\q1
\v 39 A hoihoi aku la ia i ua poe la, ee aku la ia maluna o ka moku, a holo aku la ma kekahi kae o Magedala.   
\c 16  
\b  
\q1
\v 1 HELE mai la na Parisaio a me na Sadukaio; hoao mai la lakou ia ia, nonoi mai la, e hoike aku ia lakou i hoailona mai ka lani mai.   
\q1
\v 2 Olelo aku la oia ia lakou, i aku la, I ke ahiahi, olelo no oukou, E malie auanei, no ka mea, ke ulaula mai la ke ao.   
\q1
\v 3 I ke kakahiaka hoi, He la ino keia, no ka mea, ua ulaula mai ke ao, ua hakumakuma. E ka poe hookamani, ke ike nei oukou i ke kilo i na ouli o ke ao; aole anei oukou i ike i na hoailona o neia manawa?   
\q1
\v 4 Ke makemake nei kekahi hanauna ino moe kolohe i hoailona; aole hoi e haawiia ka hoailona ia lakou, o ka hoailona a Iona a ke kaula wale no. A haalele aku la oia ia lakou a hele aku la.   
\b  
\q1
\v 5 I ka holo ana o kana poe haumana ma kola aoao, poina iho la ia lakou ke lawe pu mai i ka berena.   
\b  
\q1
\v 6 I mai la o Iesu ia lakou, E ao ia oukou iho e makaala i ka mea hu a ka poe Parisaio a me ka poe Sadukaio.   
\q1
\v 7 Wa iho la lakou ia lakou iho, i ae la, No ko kakou lawe ole mai i ka berena keia mea.   
\q1
\v 8 Ike mai o Iesu, i mai la ia lakou, Heaha ka oukou e wa iho nei ia oukou iho, e ka poe paulele kapekepeke, no ko oukou lawe ole mai i ka berena?   
\q1
\v 9 Aole anei oukou i ike, aole hoi oukou hoomanao i na popo berena elima, na ka poe elima tausani, ehia na hinai piha a oukou i hoiliili ai?   
\q1
\v 10 Aole hoi i na popo berena ehiku na ka poe aha tansani, ehia na hinai piha a oukou i hoiliili ai?   
\q1
\v 11 Heaha hoi ka oukou i hoomaopopo ole ai, aole no ka berena ka'u i olelo aku ai ia oukou, e makaala ia oukou iho i ka mea hu a ka poe Parisaio a me ka poe Sadukaio?   
\q1
\v 12 Alaila, ike maopopo iho la lakou, aole ia i olelo mai e makaala i ka mea hu berena; aka, i ke ao ana a ka poe Parisaio a me ka poe Sadukaio.   
\b  
\q1
\v 13 I ka hele ana aku o Iesu i ka aina o Kaisareia Pilipi, ninau mai la ia i kana poe haumana, i mai la, Owai la wau, ke Keiki a ke kanaka, i ka na kanaka olelo?   
\q1
\v 14 I aku la lakou, O Ioane Bapetite i ka kekahi, o Elia i ka kekahi, o Ieremia i ka kekahi, a i ole ia, o kekahi no o ka poe kaula.   
\q1
\v 15 Ninau mai la oia ia lakou, Owai hoi wau i ka oukou nei olelo?   
\q1
\v 16 Olelo aku la o Simona Petero, i aku la, O oe no ka Mesia, ke Keiki a ke Akua ola.   
\q1
\v 17 Olelo mai la o Iesu, i mai la ia ia, Pomaikai oe, e Simona ke keiki a Iona; no ka mea, aole na ke kanaka ia i hoike mai ia oe; aka na ko'u Makua no iloko o ka lani.   
\q1
\v 18 Ke olelo aku nei hoi au ia oe, O oe no o Petero, a maluna o keia pohaku e kukulu ana au i ko'u ekalesia, aole hoi e lanakila mai na ipuka o ka po maluna ona.   
\q1
\v 19 E haawi aku hoi au ia oe i na ki o ke aupuni o ka lani; a o ka mea e hoopaaia e oe ma ka honua nei, e hoopaaia hoi oia ma ka lani; a o ka mea e kuuia e oe ma ka honua nei, e kuuia hoi oia ma ka lani.   
\q1
\v 20 Alaila, papa mai la ia i kana poe haumana, aole lakou e hai aku i kekahi, oia ka Mesia.   
\b  
\q1
\v 21 Mai ia wa mai i hoomaka ai o Iesu e hoike mai i kana poe haumana, he pono nona ke hele aku i Ierusalema, a e hoomainoino nui ia e ka poe lunakahiko, a me ka poe kahuna nui, a me ka poe kakauolelo, e pepehiia hoi ia a make, a po akolu ae e ala hou mai ai.   
\q1
\v 22 Lalau aku la o Petero ia ia, hoomaka e ao aku la ia ia, i aku la, E alohaia mai oe, e ka Haku; aole loa oe e hanaia pela.   
\q1
\v 23 Haliu ae la kela, i mai la ia Petero, E hele oe pela mahope o'u, e Satana: He mea hihia oe no'u; no ka mea, aole oe e manao nei e like me ka ke Akua, o ka ke kanaka kau e manao nei.   
\b  
\q1
\v 24 Alaila, i mai la o Iesu i kana poe haumana, O ka mea makemake e hele mamuli o'u, e hoole kela ia ia iho, e hapai hoi ia i kona kea, a e hahai mai ia'u.   
\q1
\v 25 No ka mea, o ka mea e manao ana e malama i kona ola, e lilo ana ia mea: aka, o ka mea e haalele i kona ola no'u, e loaa ia ia ke ola.   
\q1
\v 26 Heaha ka pomaikai no ke kanaka ke loaa ia ia keia ao a pau, a lilo aku kona uhane? Heaha hoi ka ke kanaka e haawi aku ai i uku no kona uhane?   
\q1
\v 27 E hele mai no ke Keiki a ke kanaka iloko o ka nani o kona Makua me kona poe anela; alaila e uku aku ia i kela kanaka i keia kanaka e like me kana hana ana.   
\q1
\v 28 He oiaio ka'u e olelo aku nei ia oukou, O kekahi poe e ku mai nei, aole lakou e hoao e i ka make, a ike lakou i ke Keiki a ke kanaka e hele mai ana i kona aupuni.   
\c 17  
\b  
\q1
\v 1 A HALA ae la na la eono, kono ae la o Iesu ia Petero me Iakobo a me Ioane kona kaikaina, a kai aku la ia lakou ma kahi mehameha ma ka mauna kiekie.   
\q1
\v 2 Hoopahaohaoia iho la ia imua o lakou; alohi mai la kona helehelena e like me ka la, a keokeo mai la kona aahu e like me ka malamalama.   
\q1
\v 3 Aia hoi, ikea ae la e lakou o Mose a me Elia e kamailio pu ana me ia.   
\q1
\v 4 Olelo aku la o Petero ia Iesu, i aku la, E ka Haku, he pono no kakou ke noho maanei; ina oe e makemake, e kukulu makou i mau halelewa i ekolu, nou kekahi, no Mose kekahi, a no Elia kekahi.   
\q1
\v 5 Ia ia i olelo aku ai, aia hoi, he ao alohilohi i uhi mai ia lakou; a he leo mailoko mai o ke ao i pae mai la, O ka'u Keiki punahele keia, ka mea a'u i olioli loa ai; e hoolohe oukou ia ia.   
\q1
\v 6 A lohe ae la na haumana, moe iho la lakou ilalo ke alo, makau loa ae la.   
\q1
\v 7 Hele mai la o Iesu, hoopa iho la ia lakou, i mai la, E ala'e, mai makau oukou.   
\q1
\v 8 Alawa ae la ko lakou maka iluna, aole lakou i ike i ke kanaka e ae, ia Iesu wale no.   
\b  
\q1
\v 9 A iho mai la lakou mai ka mauna mai, papa mai la o Iesu ia lakou, i mai la, Mai hai aku oukou i ka oukou mea i ike iho nei, a ala mai ke Keiki a ke kanaka mai ka make mai.   
\q1
\v 10 Ninau aku la na haumana ana ia ia, i aku la, No ke aha la e olelo mai nei ka poe kakauolelo, o Elia ke hele e mai mamua e pono ai?   
\q1
\v 11 Olelo mai la o Iesu ia lakou, i mai la, O Elia no ke hele e mai mamua e pono ai, a e hooponopono i na mea a pau.   
\q1
\v 12 Ke olelo aku nei no hoi au ia oukou, Ua hiki e mai no o Elia, aole nae lakou i ike ia ia; aka, ua hana aku lakou ia ia i ka mea a lakou i makemake ai. Pela no hoi ke Keiki a ke kanaka e hana eha ia'i e lakou.   
\q1
\v 13 Alaila ike iho la na haumana, o Ioane Bapetite kana i olelo mai ai ia lakou.   
\b  
\q1
\v 14 A hiki ae la lakou i ka poe kanaka, hele mai la kekahi kanaka io na la, kukuli iho la imua ona, i mai la,   
\q1
\v 15 E ka Haku, e aloha mai oe i ka'u keiki; no ka mea, ua loohia ia e ka mai hina, ua eha loa, ua hina pinepine ia iloko o ke ahi, a iloko o ka wai.   
\q1
\v 16 A lawe mai la au ia ia i kau poe haumana, aole hoi i hiki ia lakou ke hoola ia ia.   
\q1
\v 17 Olelo mai la o Iesu, i mai la, E ka hanauna manaoio ole a me ka hewa! Pehea hoi ka loihi o ko'u noho pu ana me oukou? Pehea hoi ka loihi o ko'u hoomanawanui ana'ku ia oukou? E lawe mai ia ia io'u nei.   
\q1
\v 18 Papa aku la o Iesu ia ia, a puka aku la ka daimonio iwaho ona; a ola iho la ua keiki la mai ia hora mai.   
\b  
\q1
\v 19 Alaila, hele malu aku la na haumana io Iesu la, ninau aku la, No ke aha la i hiki ole ai ia makou ke mahiki aku ia ia?   
\q1
\v 20 I mai la o Iesu ia lakou, No ko oukou manaoio ole. He oiaio ka'u e olelo aku nei ia oukou, ina he like ko oukou manaoio me kekahi hua makeke, a olelo aku paha oukou i keia mauna, E nee aku oe i o, a e nee aku no ia; aole mea hiki ole ia oukou.   
\q1
\v 21 Aka, aole e puka wale aku ka mea me neia, aia ma ka pule a me ka hookeai wale no.   
\b  
\q1
\v 22 I ko lakou noho ana ma Galilaia, i mai la o Iesu ia lakou, E kumakaia'ku ke Keiki a ke kanaka iloko o na lima o kanaka:   
\q1
\v 23 Na lakou ia e pepehi a make, a po akolu ae e hoalaia mai ai ia. A kaumaha loa iho la lakou.   
\b  
\q1
\v 24 A hiki aku la lakou i Kaperenauma, hele mai la ka poe auhau hapaha io Petero la, i mai la, Aole anei e hookupu mai ka oukou kumu i ka hapaha?   
\q1
\v 25 I aku la ia, Ae. A komo aku la ia iloko o ka hale, olelo mua mai la o Iesu ia ia, i mai la, Heaha kou manao, e Simona, owai ka poe hookupu aku i ka mea auhau a me ka uku i na alii o keia ao? o ka lakou poe keiki anei, a o na kanaka e paha?   
\q1
\v 26 I aku la Petero ia ia, O kanaka e. I mai la Iesu ia ia, Alaila, ua kaawale na keiki.   
\q1
\v 27 Aka, o hoonaukiuki kakou ia lakou, e hele aku oe i ka moanawai, e hoolei aku i ka makau, a e huki mai i ka ia mua e lou mai ana; a i ka wehe ana i kona waha, e loaa ia oe kekahi hapalua: oia kau e lawe ai, a e haawi aku ia lakou no kaua.   
\c 18  
\b  
\q1
\v 1 I A manawa, hele aku la ka poe haumana io Iesu la, i aku la, Owai la ka mea nui loa iloko o ke aupuni o ka lani?   
\q1
\v 2 Kahea aku la o Iesu i wahi keiki uuku, hooku ae la ia ia iwaenakonu o lakou,   
\q1
\v 3 I mai la, He oiaio ka'u e olelo aku nei ia oukou, ina aole oukou i hoohuliia'e, a e like hoi me na keiki uuku, aole loa oukou e komo iloko o ke aupuni o ka lani.   
\q1
\v 4 O ka mea hoohaahaa ia ia iho e like me keia keiki, oia ka nui loa iloko o ke aupuni o ka lani.   
\q1
\v 5 O ka mea launa aku i kekahi keiki e like me keia no ko'u inoa, oia ke launa mai ia'u.   
\q1
\v 6 Aka, o ka mea hoohihia aku i kekahi o keia poe mea uuku o ka poe manaoio mai ia'u, e aho nona ke nakinakiia ka pohaku wili palaoa ma kona a-i, a e hoopaholoia oia i kahi hohonu o ke kai.   
\b  
\q1
\v 7 Auwe ko ke ao nei no na hoohihia ana! E hiki io mai no na hihia; aka, auwe ke kanaka nana e hoohihia mai!   
\q1
\v 8 Ina e hoohibia mai kou lima a o kou wawae paha ia oe, e oki iho ia mea, a e hoolei aku; e aho nou e komo oopa oe, a mumuku paha iloko o ke ola, i ole e hoolei pu ia'ku oe me kou mau lima elua, a me na wawae elua iloko o ke ahi mau loa.   
\q1
\v 9 Ina paha e hoohihia mai kou maka ia oe, e poalo ae, a hoolei aku; e aho nou e komo makahi oe iloko o ke ola, i ole e hooleiia oe me na maka elua iloko o ke ahi o Gehena.   
\q1
\v 10 E ao oukou, mai hoowahawaha mai i kekahi o keia poe mea uuku: no ka mea, ke olelo aku nei au ia oukou, e nana mau ana ko lakou poe anela i ka lani i ka helehelena o ko'u Makua i ka lani.   
\q1
\v 11 A ua hele mai nei ke Keiki a ke kanaka e hoola i ka mea i auwana.   
\q1
\v 12 Heaha ko oukou manao? Ina paha hookahi haneri hipa a kekahi kanaka, a ua auwana kekahi o lakou, aole anei ia e waiho i ka poe kanaiwakumamaiwa, a hele aku ma na mauna e imi i ka mea i nalowale?   
\q1
\v 13 Ina paha e loaa oia ia ia, he oiaio ka'u e olelo aku nei ia oukou, ua oi aku kona olioli no ua hipa la, i ka olioli no na hipa he kanaiwakumamaiwa aole i auwana.   
\q1
\v 14 Pela hoi, aole e makemake ko oukou Makua i ka lani e lilo aku kekahi o keia poe mea uuku.   
\b  
\q1
\v 15 Ina e hana hewa mai kou hoahanau ia oe, e hele oe e ao aku ia ia olua wale no. A i hoolohe mai oia ia oe, ua loaa ia oe kou hoahanau.   
\q1
\v 16 A i hoolohe ole mai oia ia oe, e kono aku me oe i hookahi i elua paha, i maopopo ai kela olelo keia olelo ma ka waha o na mea ike maka elua a ekolu paha.   
\q1
\v 17 Ina paha e hoolohe ole kela ia laua, alaila, e hai aku ia mea i ka ekalesia; a ina paha e hoolohe ole ia i ka ekalesia no hoi, e hoohalike oe ia ia me ke kanaka e, a me ka lunaauhau.   
\q1
\v 18 He oiaio ka'u e olelo aku nei ia oukou, O na mea a oukou e hoopaa ai ma ka honua nei, e hoopaaia hoi lakou ma ka lani; a o na mea a oukou e kala ai ma ka honua nei, e kalaia no hoi lakou ma ka lani.   
\b  
\q1
\v 19 Eia hou, Ke olelo aku nei hoi au ia oukou, ina paha elua o oukou ma ka honua nei e manao like i kekahi mea a laua e noi ai, e haawiia'ku hoi ia na laua e ko'u Makua i ka lani.   
\q1
\v 20 No ka mea, ma kahi e halawai ai na mea elua a ekolu paha ma ko'u inoa, malaila hoi au iwaena pu me lakou.   
\b  
\q1
\v 21 Alaila, hele aku la o Petero io na la, i aku la, E ka Haku, ehia na hana hewa ana mai a ko'u hoahanau ia'u, a kala aku au ia ia? ehiku anei?   
\q1
\v 22 Olelo mai la o Iesu ia ia, Ke i aku nei au ia oe, Aole ehiku wale no; aka, he kanahiku hiku.   
\b  
\q1
\v 23 No ia mea, ua like ke aupuni o ka lani me kekahi alii, ka i manao iho e olelo hoakaka me kana poe kauwa no ka lakou aie ana.   
\q1
\v 24 I ka hoomaka ana e hoakaka ai, ua kaiia mai kekahi mea aie io na la, he umi tausani na talena kana i aie ai.   
\q1
\v 25 Aole hoi ana mea e uku aku ai; kauoha aku la kona haku e kuai lilo ia'ku oia me kana wahine, a me kana mau keiki, a me kana mea a pau loa, i loaa'i ka uku.   
\q1
\v 26 Moe iho la ua kauwa la, hoomaikai aku la ia ia, i aku la, E ka haku, e ahonui mai oe ia'u, a e uku aku au ia oe ia mea a pau loa.   
\q1
\v 27 Aloha mai la ka haku i ua kauwa la, kuu mai la ia ia, a kala mai la i kana aie.   
\q1
\v 28 Hele aku la ua kauwa la iwaho, a halawai me kekahi hoakauwa ona, i aie mai i kana i hookahi haneri denari, lalau aku la ia ia, a umi iho la i kona a-i, i aku la, E uku mai oe ia'u i kau mea i aie.   
\q1
\v 29 Moe iho la kona hoakauwa ma kona wawae, noi mai la ia ia, i mai la, E ahonui mai oe ia'u, a e uku aku au ia oe ia mea a pau loa.   
\q1
\v 30 Aole ia i ae aku; aka, hele aku la ia, a hoolei aku la ia ia iloko o ka halepaahao, a pau loa ka aie i ka ukuia.   
\q1
\v 31 A ike ae la kona mau hoakauwa i ka mea ana i hana'i, minamina loa iho la lakou; a hele lakou, hai aku la i ko lakou haku i na mea a pau i hanaia.   
\q1
\v 32 Alaila, kahea aku la kona haku ia ia, i aku la, E ke kauwa ino, ua kala aku no au i kau aie a pau, i kou noi ana mai ia'u;   
\q1
\v 33 Aole anei i pono nou ke aloha aku i kou hoakauwa, me a'u i aloha aku ai ia oe?   
\q1
\v 34 Huhu aku la kona haku, a haawi aku la ia ia i ka poe kiai halepaahao, a pau loa ae la kana aie i ka ukuia.   
\q1
\v 35 Pela hoi i ko'u Makua i ka lani e hana aku ai ia oukou, ina aole oukou a pau e kala aku me ko oukou naau i na hala o ko oukou poe hoahanau.   
\c 19  
\b  
\q1
\v 1 A PAU ae la ia olelo ana a Iesu, hele aku la ia mai Galilaia aku, a hiki aku la ma ka mokuna o Iudea ma kela aoao o Ioredane.   
\q1
\v 2 A he nui ka poe kanaka i hahai aku ia ia, a hoola iho la ia i ko lakou poe mai.   
\b  
\q1
\v 3 Hele mai la kekahi poe Parisaio io na la, e hoao aku ia ia, i mai la, He mea pono anei ke hooki ke kane i kana wahine i kela hala i keia hala.   
\q1
\v 4 Olelo aku la ia, i aku la ia lakou, Aole anei oukou i heluhelu, O ka mea nana laua i hana i kinohou, hana iho la ia, he kane, he wahine?   
\q1
\v 5 I iho la ia, No keia mea, e haalele ke kanaka i kona makuakane a me kona makuwahine, a e pili aku ia me kana wahine, a e lilo laua elua i io hookahi.   
\q1
\v 6 Nolaila, aole e lilo hou laua i elua, hookahi o laua io. No ia hoi, o ka mea a ke Akua i hoopili pu iho ai, mai noho a hookaawale ae ke kanaka.   
\q1
\v 7 I mai la lakou ia ia, No ke aha hoi o Mose i kauoha mai ai, e haawi aku na ka wahine i palapala hoohemo, a e hooki aku ia ia?   
\q1
\v 8 I aku la oia ia lakou, No ka paakiki o ko oukou naau i ae mai ai o Mose ia oukou e hooki i na wahine a oukou; aole pela ia mai kinohi mai.   
\q1
\v 9 Ke olelo aku nei au ia oukou, o ka mea nana e hooki i kana wahine, ke moe kolohe ole ia, a e mare i ka wahine hou, ua moe kolohe ia kane; a o ka mea nana e mare ua wahine hemo la, ua moe kolohe hoi ia.   
\b  
\q1
\v 10 I aku la kana poe haumana ia ia, Ina paha pela ke kane me kana wahine, e aho no ke mare ole.   
\q1
\v 11 I mai la kela ia lakou, Aole e hiki i na kanaka a pau ke hoomanawanui pela; aia i ka poe nana keia pono i haawiia mai.   
\q1
\v 12 No ka mea, he poe eunuha kekahi mai ko lakou hanau ana mai, a he poe eunuha kekahi i hoeunuhaia e kanaka, a he poe eunuha kekahi i hoeunuhaia e lakou iho no ke aupuni o ka lani. O ka mea e hiki ia ia ia mea, e pono no ia pela.   
\b  
\q1
\v 13 Alaila, laweia mai io na la na kamalii, e kau aku ai ia i na lima maluna o lakou, a e pule aku; a papa aku la ka poe haumana ia lakou.   
\q1
\v 14 I mai la Iesu, E kuu mai oukou i na kamalii, me ka papa ole ia lakou i ka hele mai io'u nei; no ka mea, no ka poe e like me lakou nei ke aupuni o ka lani.   
\q1
\v 15 A kau iho la ia i na lima maluna o lakou, a hele aku la.   
\b  
\q1
\v 16 Aia hoi, hele mai la kekahi kanaka, i mai la ia ia, E ke kumu maikai, heaha ka mea maikai a'u e hana'i, i loaa ia'u ke ola mau loa?   
\q1
\v 17 I aku la oia ia ia, No ke aha la oe e kapa mai nei ia'u he maikai? Aohe mea maikai e ae, hookahi wale no, o ke Akua. Ina e makemake oe e komo iloko o ke ola, e malama oe i na kanawai.   
\q1
\v 18 I mai la kela, O na kanawai hea? I aku la Iesu, O neia, Mai pepehi kauaka oe, Mai moe kolohe oe, Mai aihue oe, Mai hoike wahahee oe.   
\q1
\v 19 E hoomaikai i kou makuakane a me kou makuwahine; a, E aloha oe i kou hoalauna me oe ia oe iho.   
\q1
\v 20 I mai la ua kanaka opiopio la ia ia, Ua malama au ia mau mea a pau mai kuu wa kamalii mai; heaha ko'u hemahema?   
\q1
\v 21 I aku la Iesu ia ia, A i makemake oe e hemolele, ea, e hele oe, e kuai lilo aku i kou waiwai a pau, a e haawi aku na ka poe ilihune, a e loaa ia oe ka waiwai iloko o ka lani; a e hele mai oe e hahai mai ia'u.   
\q1
\v 22 Lohe ae la ua kanaka opiopio la ia olelo, hele aku la ia me ka minamina; no ka mea, he nui loa kona waiwai.   
\b  
\q1
\v 23 Olelo mai la o Iesu i kana poe haumana, He oiaio ka'u e olelo aku nei ia oukou, e komo apuepue ke kanaka waiwai iloko o ke aupuni o ka lani.   
\q1
\v 24 Eia hou ke olelo aku nei au ia oukou, E hiki e ke kamelo ke komo ma ka puka o ke kuikele mamua o ke komo ana o ke kanaka waiwai iloko o ke aupuni o ka lani.   
\q1
\v 25 Lohe ae la na haumana ana, kahaha nui iho la lakou, i ae la, Owai la auanei ke ola?   
\q1
\v 26 Nana mai la o Iesu ia lakou, i mai la, He mea hiki ole ia i kanaka; aka, e hiki io no na mea a pau i ke Akua.   
\b  
\q1
\v 27 Alaila, olelo aku la o Petero ia ia, i aku la, Eia hoi, ua haalele makou i na mea a pau, a ua hahai aku makou ia oe; heaha la uanei ka makou e loaa'i?   
\q1
\v 28 I mai la o Iesu ia lakou, He oiaio ka'u e olelo aku nei ia oukou, i ke ola hou ana, i ka wa e noho ai ke Keiki a ke kanaka maluna o kona nohoalii nani; oukou hoi ka poe i hahai mai ia'u, e noho no oukou maluna o na nohoalii he umikumamalua, i poe lunakanawai no na ohana o Iseraela he umikumamalua.   
\q1
\v 29 O ka mea haalele i na hale, i na hoahanaukane, i na hoahanauwahine, i ka makuakane, i ka makuwahine, i ka wahine, i na keiki, i na aina hoi, no ko'u inoa, e loaa mai ia ia he pahaneri, a e lilo mai ia ia ke ola mau loa.   
\q1
\v 30 A he nui na mea mua e lilo ana i hope, a o na mea hope e lilo ana i mua.   
\c 20  
\b  
\q1
\v 1 NO ka mea, ua like ke aupuni o ka lani me kekahi kanaka mea hale, i hele aku la i kakahiaka nui e hoolimalima i ka poe paaua no kona pawaina.   
\q1
\v 2 Hoolimalima oia i kekahi poe paaua i ka denari hookahi no ka la hookahi; hoouna aku la oia ia lakou ma kona pawaina.   
\q1
\v 3 Hele hou aku la ia iwaho i ke kolu o ka hora, ike aku la ia i kekahi poe kanaka e ku hana ole ana ma kahi kuai.   
\q1
\v 4 I aku la oia ia lakou, E haele hoi oukou i ka pawaina, a o ka mea pono, na'u ia e uku aku ia oukou. A hele aku la lakou.   
\q1
\v 5 Hele hou aku la ia iwaho, i ke ono a i ka iwa o ka hora, a hana iho la e like mamua.   
\q1
\v 6 A i ka hora umikumamakahi, hele aku la ia iwaho, ike aku la i kekahi poe e ku hana ole ana, i aku la oia ia lakou, Heaha ka oukou e ku hana ole nei a pau ka la?   
\q1
\v 7 I mai la lakou ia ia, No ka mea, aohe mea nana makou i hoolimalima. I aku la oia ia lakou, E haele hoi oukou i ka pawaina, a o ka mea pono, e loaa hoi ia ia oukou.   
\q1
\v 8 A ahiahi ae la, i aku la ka haku nona ka pawaina i kona puuku, E kahea aku oe i ka poe paaua, a e haawi aku ia lakou i ka uku, mai ka poe hope mai a hiki aku i ka poe mua.   
\q1
\v 9 A hele mai la ka poe i hoolimalimaia i ka hora umikumamakahi, loaa pakahi ia lakou ka denari.   
\q1
\v 10 A hele mai la ka poe i hoolimalimaia mamua, manao iho la lakou e loaa mai ka pakela uku, a loaa pakahi ia lakou ka denari.   
\q1
\v 11 A loaa iho la, ohumu iho la lakou i ka mea hale,   
\q1
\v 12 I ae la, o keia poe hope, hookahi wale no hora o ka lakou hana ana, a ua hoohalike mai oe ia lakou me makou, ka poe hooikaika i ka wa luhi a me ka wela o ka la.   
\q1
\v 13 Olelo aku la ia, i aku la i kekahi o lakou, E ka hoalauna, aole au i hana ino aku ia oe, aole anei oe i ae mai ia'u no ka denari hookahi?   
\q1
\v 14 E lawe oe i kau, a e hele. O ko'u makemake no e haawi aku na keia poe mahope e like me kau.   
\q1
\v 15 Aole anei au e pono ke hana aku me ka'u mamuli o ko'u makemake? Ua hewa anei kou maka i ko'u lokomaikai?   
\q1
\v 16 Pela hoi ka poe hope e lilo i mua, a o ka poe mua i hope: no ka mea, he nui na mea i heaia, aka he uuku ka poe i waeia.   
\b  
\q1
\v 17 I ko Iesu hele ana i Ierusalema, kai aku la ia i ka poe haumana he umikumamalua i kahi kaawale ma ke alanui, i mai la ia lakou,   
\q1
\v 18 Eia ke pii nei kakou i Ierusalema, a e kumakaiaia'ku ke Keiki a ke kanaka i ka poe kahuna nui a me ka poe kakauolelo; a e hoohewa lakou ia ia e make;   
\q1
\v 19 A e haawi aku hoi lakou ia ia i ko na aina e e hoomaewaewaia mai ai, a e hahauia mai ai, a e kaulia'i ma ke kea; a po akolu ae, e ala hou mai ia.   
\b  
\q1
\v 20 Alaila, punee mai io na la ka makuwahine o na keiki a Zebedaio, oia me na keiki ana; moe iho la ia imua ona, a noi aku la ia ia i kekahi mea.   
\q1
\v 21 Ninau mai la o Iesu ia ia, i Heaha kou makemake? I aku la kela, E kauoha oe e noho keia mau keiki a'u elua, o kekahi ma kou lima akau, a o kekahi ma kou lima hema iloko o kou aupuni.   
\q1
\v 22 Olelo mai la o Iesu, i mai la, Aole oukou i ike i ka oukou mea e noi mai nei. E hiki no anei ia olua ke inu i ko ke kiaha a'u e inu ai; a e bapetizoia i ka bapetizo ana a'u e bapetizoia mai ai? I aku la laua ia ia, E hiki no ia maua.   
\q1
\v 23 Olelo mai la o Iesu ia laua, E inu no auanei olua i ko ke kiaha o'u, a e bapetizoia hoi i ka bapetizo ana a'u e bapetizoia'i; aka, o ka noho ma ko'u lima akau, a ma ko'u lima hema, aole ka'u ia e haawi aku; aia no ia no ka poe nona i hoomakaukauia'i ia mea e ko'u Makua.   
\q1
\v 24 A lohe ae la ka umi, ukiuki aku la lakou i ua mau hoahanau la elua.   
\q1
\v 25 Kahea mai la o Iesu ia lakou, i mai la, Ua ike oukou, o na alii o na lahuikanaka, ua hookiekie maluna o lakou, a o na luna hoi, ua hoounauna ia lakou.   
\q1
\v 26 Aole pela ia oukou; a i manao kekahi o oukou i nui, e pono no e lilo ia i mea lawelawe na oukou.   
\q1
\v 27 A i manao kekahi e lilo i pookela iwaena o oukou, e pono no e lilo ia i kauwa na oukou.   
\q1
\v 28 Pela hoi, aole i hele mai ke Keiki a ke kanaka no ka lawelaweia mai, aka, no ka lawelawe aku, a me ka haawi aku i kona ola i kumuhoola no na mea he nui loa.   
\b  
\q1
\v 29 I ko lakou hele ana ae mai Ieriko aku, he nui ka poe kanaka i hahai ia ia.   
\b  
\q1
\v 30 Aia hoi, elua makapo e noho ana ma kapa alanui; lohe ae la laua, o Iesu ke maalo ae, kahea mai la laua, i mai la, E aloha mai oe ia maua, e ka Haku, e ka mamo a Davida.   
\q1
\v 31 Papa aku la ka poe kanaka ia laua, e hamau: a nui loa ae la ka laua kahea ana, E aloha mai oe ia maua, e ka Haku, e ka mamo a Davida.   
\q1
\v 32 Ku malie iho la o Iesu, hea aku la ia laua, i aku la, Heaha ko olua makemake e hana aku ai au ia olua?   
\q1
\v 33 I mai la laua ia ia, E ka Haku, e hookaakaaia mai ko maua mau maka.   
\q1
\v 34 Aloha aku la o Iesu, hoopa aku la i ko laua mau maka; ike koke ae la ko laua mau maka, a hahai aku la laua ia ia.   
\c 21  
\b  
\q1
\v 1 A KOKOKE aku la lakou i Ierusalema, ua hiki aku la i Betepage ma ka mauna Oliveta, alaila, hoouna aku la o Iesu i na haumana elua;   
\q1
\v 2 I aku la ia laua, E hele aku olua i ke kauhale e kupono mai ana ia olua, a e loaa koke ia olua ka hoki ua nakikiia, a me ke keiki me ia: e wehe ae olua, a e kai mai io'u nei.   
\q1
\v 3 Ina paha e olelo mai kekahi ia olua, e i aku, Na ka Haku ia mau mea e pono ai: alaila e kuu koke mai no ia i na hoki.   
\q1
\v 4 Ua pau ia mau mea i ka hanaia, i ko ai ka mea i oleloia mai e ke kaula, i ka i ana,   
\q1
\v 5 E hai aku oukou i ke kaikamahine a Ziona, Aia hoi, ke hele akahai mai nei kou Alii iou la, e noho ana maluna o ka hoki, o ke keiki hoi a ka hoki.   
\q1
\v 6 Hele aku la ua mau hanmana la, a hana aku la e like me ka Iesu i kauoha mai ai ia laua.   
\q1
\v 7 Kai mai la laua i ua hoki la, a me ke keiki, hohola ae la lakou i na kapa o lakou maluna o laua, a hoee aku la ia Iesu maluna iho.   
\q1
\v 8 Hohola iho la ka nui o ka poe kanaka i ko lakou kapa ma ke alanui, a okioki ae la kekahi poe i na lalalaau, a haliilii iho la ma ke alanui.   
\q1
\v 9 Hookani ae la ka poe hele mamua, a me ka poe hahai mahope, i aku la, Hosana i ka Mamo a Davida! E hoouaniia ka Mea e hele mai nei ma ka inoa o ka Haku; Hosana i ke lani kiekie loa!   
\q1
\v 10 A hiki aku la ia i Ierusalema, pihoihoi ae la ko ke kulanakauhale a pau, ninau mai la lakou, Owai keia?   
\q1
\v 11 I aku la ka poe kanaka, O Iesu keia, ke Kaula no Nazareta i Galilaia.   
\b  
\q1
\v 12 Komo aku la Iesu iloko o ka luakini o ke Akua, a hookuke aku la iwaho i ka poe kuai lilo aku, a me ka poe kuai lilo mai a pau iloko o ka luakini: hookahuli ae la ia i na papa o ka poe kuai moni, a me na noho o ka poe kuai manu nunu.   
\q1
\v 13 I aku la oia ia lakou, Ua palapalaia, E kapaia ko'u hale, he hale pule; a ua hoolilo iho nei oukou ia ia i ana no na powa.   
\q1
\v 14 Hele mai la ka poe makapo a me ka poe oopa io na la ma ka luakini, a hoola aku la oia ia lakou.   
\q1
\v 15 Ike mai la ka poe kahuna nui a me ka poe kakauolelo i na mea kupanaha ana i hana'i, a me na kamalii e hookani ana iloko o ka luakini, Hosana i ka Mamo a Davida; ukiuki mai la lakou,   
\q1
\v 16 I mai la ia ia, Ke lohe nei anei oe i ka lakou nei olelo? I aku la o Iesu ia lakou, Ae, aole anei oukou i heluhelu, Ua hoomakaukau oe i ka hoolea mailoko mai o na waha kamalii a me na keiki waiu?   
\b  
\q1
\v 17 Haalele aku la oia ia lakou, a hele aku la iwaho o ke kulanakauhele i Betania, malaila i noho ai a ao ka po.   
\b  
\q1
\v 18 A kakahiaka ae, i kona hoi ana i ke kulanakauhale, pololi iho la ia.   
\q1
\v 19 Ike ae la ia i kekahi laau fiku ma kapa alanui, hele aku la ia ilaila, a o na lau wale no i loaa ia ia maluna ona; i aku ia i ua laau la, Mai noho a ulu ka hua maluna ou ma ia hope a mau loa aku. Maloo koke iho la ua laau fiku la.   
\q1
\v 20 A ike ae la ka poo haumana, kahaha iho la lakou, i ae la, Emo ole ka maloo ana o ka laau fiku!   
\q1
\v 21 Olelo mai la o Iesu, i mai la ia lakou, He oiaio ka'u e olelo aku nei ia oukou, Ina he manaoio ko oukou, aole oukou kanalua, e hana no oukou aole i keia wale no o ka laau fiku; aka, ina e olelo aku oukou i keia mauna, E kaikaiia'e oe, a e hooleiia'ku iloko o ka moana; e hanaia no ia.   
\q1
\v 22 Oia hoi, o na mea a pau a oukou e nonoi ai ma ka pule me ka manaoio, e loaa no ia ia oukou.   
\b  
\q1
\v 23 Ia ia i komo aku ai iloko o ka luakini, a ao mai la ilaila, hele mai la io na la ka poe kahuna nui, a me ka poe lunakahiko o na kanaka, i mai la, Nawai mai kau mana e hana aku ai i keia mau mea? Nawai hoi i haawi mai keia mana ia oe?   
\q1
\v 24 Olelo aku la o Iesu ia lakou, i aku la, Owau kekahi e ninau aku ia oukou, a i hai mai oukou ia, e hai aku no hoi au ia oukou i ka mea nana i haawi mai ia'u e hana keia mau mea.   
\q1
\v 25 O ka bapetizo ana a Ioane, no hea ia? No ka lani mai anei? no kanaka anei? Kuka iho la lakou ia lakou iho, i ae la, Ina e hai aku kakou, No ka lani mai; alaila, e ninau mai kela ia kakou, No ke aha la oukou i manaoio ole ai ia ia?   
\q1
\v 26 A i hai aku kakou, No kanaka, ke makau aku nei kakou i na kanaka; no ka mea, ke manao nei lakou a pau, he kaula no o Ioane.   
\q1
\v 27 Olelo mai la lakou ia Iesu, i mai la, Aole makou i ike. I aku la hoi oia ia lakou, Aole hoi au e hai aku ia oukou i ka mea nana i haawi mai ia'u e hana i keia mau mea.   
\b  
\q1
\v 28 Aka, heaha ka oukou manao? He wahi kanaka ia ia na keikikane elua; a hele aku la ia i ka mua, i aku la, E kuu keiki, e hele aku oe e hana i keia la ma kuu pawaina.   
\q1
\v 29 Hoole mai la kela, i mai la, Aole au e hiki. A mahope mihi iho la ia, a hele aku la.   
\q1
\v 30 Hele aku la hoi oia i kana keiki muli, a olelo aku la pela ia ia. Ae mai la ia, i mai la, E hele no wau, e kuu haku; aole nae ia i hele.   
\q1
\v 31 Owai ko laua mea nana i hana ka makemake o ka makua? I mai la lakou ia ia, O ka mua. I aku la Iesu ia lakou, He oiaio ka'u e olelo aku nei ia oukou, e komo e ka poe lunaauhau a me na wahine hookamakama mamua o oukou iloko o ke aupuni o ke Akua.   
\q1
\v 32 No ka mea, i hele mai nei o Ioane io oukou nei ma ka aoao o ka pono, aole nae oukou i manaoio ia ia; aka, manaoio ka poe lunaauhau a me na wahine hookamakama ia ia; a ia oukou i ike ia ia, aole oukou i mihi mahope me ka manaoio ia ia.   
\b  
\q1
\v 33 E hoolohe mai oukou i kekahi olelonane hou: Kanu iho la kekahi mea hale i ka malawaina, hana iho la ia i pa a puni, eli iho la i wahi kaomi waina iloko olaila, kukulu iho la i hale kiai, haawi aku la ia wahi i na hoaaina, a hele aku la ia i ka aina e.   
\q1
\v 34 A i ka wa i kokoke e oo ai ka hua, hoouna mai la ia i kana mau kauwa i ka poe hoaaina i loaa mai ai ka hua nona.   
\q1
\v 35 A hopu aku la na hoaaina i kana mau kauwa, hahau iho la lakou i kekahi, pepehi iho la i kekahi a make, a hailuku aku la i kekahi me ka pohaku.   
\q1
\v 36 Hoouna hou mai la ia i na kauwa e ae, he nui aku i ka poe mamua, a hana hou pela na hoaaina ia lakou.   
\q1
\v 37 A mahope iho, hoouna mai la ia i kana Keiki io lakou la, i iho la, E hoomaikai mai paha lakou i ka'u keiki.   
\q1
\v 38 Ike aku la ka poe hoaaina i ua keiki la, olelo ae la kekahi i kekahi, Eia ae ka hooilina, ina kakou, e pepehi ia ia, a lilo mai kona aina no kakou.   
\q1
\v 39 Hopu aku la lakou ia ia, hookuke aku la ia ia iwaho o ka pawaina, pepehi iho la ia ia a make.   
\q1
\v 40 Aia hiki mai ka haku nona ka pawaina, heaha kana e hana mai ai i ua poe hoaaina nei?   
\q1
\v 41 I mai la lakou ia ia, E pepehi hoomainoino ia i kela poe ino, a e haawi aku ia i ka pawaina, no kekahi poe hoaaina e ae, nana e hookupu mai nona na hua i ka wa e oo ai.   
\q1
\v 42 Olelo aku la o Iesu ia lakou, Aole anei oukou i heluhelu iloko o ka palapala hemolele, O ka pohaku a ka poe hana hale i haalele ai, ua lilo ia i pohaku kumu kihi? O ka ka Haku hana keia, a he mea mahalo hoi ia i ko kakou mau maka.   
\q1
\v 43 Nolaila, ke olelo aku nei au ia oukou, E laweia'na ke aupuni o ke Akua mai o oukou mai, a e haawiia'ku ia i ka lahuikanaka nana e hua mai kona hua.   
\q1
\v 44 A o ka mea e haule iho maluna o keia pohaku, e haihaiia oia; aka, o ka mea i hauleia iho e ua pohaku la maluna, e pepe loa ia.   
\b  
\q1
\v 45 Lohe ae la ka poe kahuna nui a me ka poe Parisaio i kana mau olelonane, ike iho la lakou, no lakou iho kana i olelo ai.   
\q1
\v 46 Makemake iho la lakou e lalau mai ia ia, a makau aku la lakou i ka poe kanaka; no ka mea, manao iho la lakou he kaula ia.   
\c 22  
\b  
\q1
\v 1 OLELO hou aku la o Iesu ia lakou i na olelonane, i aku la,   
\q1
\v 2 Ua like ke aupuni o ka lani me kekahi alii nana i hoomakaukau ka ahaaina no kana keiki.   
\q1
\v 3 Hoouna aku la ia i kana poe kauwa e kii i ka poe i oleloia e hele mai i ka ahaaina; aka, aole lakou i makemake e hele mai.   
\q1
\v 4 Hoouna hou aku la ia i na kauwa e ae, i aku la, E i aku oukou i ka poe i oleloia, Eia hoi, ua hoomakaukau no wau i ka'u ahaaina, ua kaluaia ka'u mau bipi a me na mea i kupaluia, ua makaukau hoi na mea a pau; e hele mai oukou i ka ahaaina.   
\q1
\v 5 Hoowahawaha mai la lakou, hele aku la; o kekahi ma kona aina, a o kekahi ma kana kuai ana.   
\q1
\v 6 A o ka poe i koe, lalau mai la lakou i kana mau kauwa, hoomainoino mai la ia lakou, pepehi iho la a make.   
\q1
\v 7 A lohe ae la ke alii, huhu iho la ia, hoouna aku la ia i kona poe kana, luku aku la ia poe pepehi kanaka, a puhi aku la i ko lakou kulanakauhale.   
\q1
\v 8 Alaila, olelo aku la ia i kana poe kauwa, Ua makaukau nae ka abaaina; aole hoi i pono kela poe i oleloia.   
\q1
\v 9 Nolaila, e hele aku oukou ma na huina alanui, a e koi aku i na mea a pau i loaa ia oukou, e hele mai i ka ahaaina.   
\q1
\v 10 Hele aku la ua poe kauwa la iwaho ma ke alanui, a houluulu mai la i na mea a pau i loaa ia lakou, o ka poe ino a me ka poe maikai; a nui iho la na hoaai ma ua ahaaina la.   
\b  
\q1
\v 11 Komo aku la ke alii iloko e nana i ka poe hoaai, ike aku la ia ilaila i kekahi kanaka aole i kahikoia i ke kapa alumina.   
\q1
\v 12 I aku la kela ia ia, E ka hoalauna, pehea la oe i hele mai nei, aole i kahikoia i ke kapa ahaaina? Mumule loa iho la ia.   
\q1
\v 13 Alaila, i aku la ua alii la i ka poe lawelawe, E nakiki iho ia ia a paa ma na wawae e me na lima, e lawe aku ia ia, a e hoolei aku iloko o ka pouli mawaho; ilaila e uwe ai a e uwi ai na niho.   
\q1
\v 14 No ka mea, he nui ka poe i kaheaia, he uuku hoi ka poe i waeia,   
\b  
\q1
\v 15 Alaila hele aku la ka poe Parisaio, kukakuka ae la i ka mea e hoohihia ia ia i kana olelo ana.   
\q1
\v 16 Hoouna mai la lakou io na la i na haumana a lakou me kekahi poe Herodiano, i mai la, E ke Kumu, ke ike nei makou, he oiaio kau, a ke ao mai nei oe i ka aoao o ke Akua me ka oiaio, aole oe i paewaewa ma ka kekahi, aole hoi i manao i ko waho o ke kanaka.   
\q1
\v 17 E hai mai hoi oe, heaha kou manao? He mea pono anei ke hookupu waiwai ia Kaisara? aole anei?   
\q1
\v 18 Ike ae la o Iesu i ko lakou manao ino ana, i aku la, E ka poe hookamani, no ke aha la oukou e hoao mai nei ia'u?   
\q1
\v 19 E hoike mai ia'u i kekahi moni hookupu. A lawe mai la lakou io na la i kekahi denari.   
\q1
\v 20 Ninau aku la oia ia lakou, Nowai keia kii a me ka palapala?   
\q1
\v 21 I mai la lakou ia ia, No Kaisara. Alaila, i aku la oia ia lakou, E haawi aku i ka Kaisara ia Kaisara, a i ka ke Akua hoi i ke Akua.   
\q1
\v 22 A lohe ae la lakou, kahaha iho la, haalele mai la lakou ia ia a hele aku la.   
\b  
\q1
\v 23 Ia la hoi, hele mai la io na la ka poe Sadukaio, ka poe i olelo, Aole alahouana; ninau mai la lakou ia ia.   
\q1
\v 24 I mai la, E ke Kumu, i olelo mai o Mose, Ina e make kekahi kanaka aohe ana keiki, e mare no kona kaikaina i kana wahine e hoala mai i hua na kona kaikuaana.   
\q1
\v 25 Ehiku mau hoahanau me makou: mare iho la ka makahiapo i wahine, a make iho la, aohe ana keiki; a lilo aku la kana wahine na kona kaikaina.   
\q1
\v 26 Pela aku hoi ka lua a me ke kolu a hiki aku la i ka hiku o lakou.   
\q1
\v 27 Mahope iho o lakou a pau, make iho la hoi ua wahine la.   
\q1
\v 28 Nolaila, i ke alahouana, na ka mea hea o lakou a ehiku ua wahine la? no ka mea, he wahine ia na lakou a pau mamua.   
\q1
\v 29 Olelo aku la o Iesu ia lakou, i aku la, Ua lalau oukou, i ka ike ole i ka palapala hemolele, a me ka mana o ke Akua.   
\q1
\v 30 No ka mea, i ke alahouana, aole lakou e mare, aole hoi e hoopalau; aka, ua like lakou me na anela o ke Akua i ka lani.   
\q1
\v 31 A, no ke alahouana o ka poe i make, aole anei oukou i heluhelu i ka ke Akua olelo ia oukou, e i mai ana,   
\q1
\v 32 Owau no ke Akua o Aberahama, ke Akua o Isaaka, ke Akua o Iakoba? O ke Akua, aole ia he Akua no ka poe i make, no ka poe ola no.   
\q1
\v 33 A lohe ae la ka poe kanaka, kahaha iho la lakou i kana ao ana.   
\b  
\q1
\v 34 Lohe ae la ka poe Parisaio, ua paa ia ia ka waha o ka poe Sadukaio, akoakoa mai la lakou io na la:   
\q1
\v 35 A ninau mai la kekahi o lakou, ho kakaolelo, hoao mai la ia ia, i mai la,   
\q1
\v 36 E ke Kumu, heaha ke kauoha nui iloko o ke kanawai?   
\q1
\v 37 I aku la o Iesu ia ia, E aloha aku oe ia Iehova i kou Akua me kou naau a pau, a me kou uhane a pau, a me kou manao a pau.   
\q1
\v 38 O ka mua keia a me ke kauoha nui.   
\q1
\v 39 Ua like hoi ka lua me ia, E aloha aku oe i kou hoalauna me oe ia oe iho.   
\q1
\v 40 Maluna o keia mau kauoha elua, ke kau nei ke kanawai a pau a me na kaula.   
\b  
\q1
\v 41 A akoakoa mai ka poe Parisaio, ninau aku la Iesu ia lakou,   
\q1
\v 42 I aku la, Heaha ko oukou manao no ka Mesia. He mamo ia nawai? I mai la lakou, Na Davida.   
\q1
\v 43 I aku la oia ia lakou, Pehea la hoi o Davida i kapa ai ia ia ma ka Uhane, he Haku? i ka i ana,   
\q1
\v 44 Olelo aku la ka Haku i kuu Haku, E noho mai oe ma kuu lima akau, a hoolilo iho ai au i kou poe enemi i keehana wawae nou.   
\q1
\v 45 Ina hoi o Davida i kapa aku ia ia he Haku, pehea la ia e mamo ai nana?   
\q1
\v 46 Aole i hiki i kekahi ke ekemu iki mai ia ia, aole hoi kekahi i aa e ninau hou mai ia ia mai ia wa iho.   
\c 23  
\b  
\q1
\v 1 A LAILA, olelo mai la o Iesu i ka poe kanaka a me kana poe haumana.   
\q1
\v 2 I mai la, Ke noho nei ka poe kakauolelo a me ka poe Parisaio ma ka noho o Mose.   
\q1
\v 3 Nolaila, o na mea a pau a lakou e kauoha mai ai e malama, e malama oukou ia a e hana aku pela; aka, mai hana oukou e like me ka lakou hana ana: no ka mea, ke olelo nei lakou, aole nae e hana.   
\q1
\v 4 Ke nakinaki nei lakou i na ukana kaumaha, a he luhi hoi ke hali, a ke kau nei iluna o na hokua o na kanaka; aole nae lakou e hoopa iki aku ia mau mea me kekahi manamanalima o lakou.   
\q1
\v 5 Ke hana nei lakou i ka lakou mau hana a pau, i ikea mai ai e na kanaka. Ke hoopalahalaha nei lakou i ua apana kanawai o lakou; a ke hoonui nei hoi lakou i na lepa o ka lakou aahu.   
\q1
\v 6 Ke makemake nei lakou i na wahi maikai ma na ahaaina, a me na noho kiekie ma na halehalawai;   
\q1
\v 7 A me ka uwe alohaia'ku ma na aha kanaka, a me ke kapaia e na kanaka, E Rabi, e Rabi.   
\q1
\v 8 Aka, o oukou, mai kapaia oukou he Rabi, no ka mea, hookahi a oukou Kumu, o ka Mesia, a he poe hoahanau oukou a pau.   
\q1
\v 9 Aole hoi e hoomakua aku oukou i kekahi kanaka ma ka honua nei; hookahi o oukou Makua, aia i ka lani.   
\q1
\v 10 Aole hoi oukou e kapaia mai na Haku, hookahi o oukou Haku, o ka Mesia.   
\q1
\v 11 O ka mea nui iwaena o oukou, he pono e lilo ia i kauwa na oukou.   
\q1
\v 12 O ka mea hookiekie ae ia ia iho, e hoohaahaaia iho no ia; a o ka mea hoohaahaa ia ia iho, e hookiekieia'e oia.   
\b  
\q1
\v 13 Auwe oukou, e ka poe kakauolelo a me ka poe Parisaio, na bookamani! no ka mea, ke papani nei oukou i ke aupuni o ka lani imua o na kanaka; no ka mea, aole oukou e komo ae, aole hoi oukou e ae aku e komo iloko ka poe e komo ana.   
\q1
\v 14 Auwe oukou, e ka poe kakauolelo a me na Parisaio, na hookamani! no ka mea, ua pau ia oukou na hale o na wahinekanemake; a ke hooloihi nei oukou i na pule i mea e ikea ai. No ia hoi, e loaa uanei ia oukou ka make nui loa.   
\b  
\q1
\v 15 Auwe oukou, e ka poe kakauolelo a me ka poe Parisaio, na hookamani! no ka mea, ke poaihaele nei oukou i ke kai a me ka aina, i kaana mai ai na oukou kekahi haumana; a loaa, ua hana oukou ia ia, a oi papalua kona keiki ana no Gehena mamua o ko oukou.   
\b  
\q1
\v 16 Auwe oukou, e na alakai makapo, ka i olelo, O ka hoohiki aku ma ka luakini he mea ole ia; aka, o ka mea hoohiki aku ma ke gula o ka luakini, he aie kana!   
\q1
\v 17 He poe naaupo a me ka makapo: heaha ka mea oi, o ke gula anei, a o ka luakini anei, ka mea e laa ai ke gula?   
\q1
\v 18 A, o ka mea hoohiki aku ma ke kuahu, he mea ole ia; aka, o ka mea hoohiki aku ma ka mohai iluna iho, he aie kana.   
\q1
\v 19 He poe naaupo a me ka makapo: heaha ka mea oi, o ka mohai anei, a o ke kuahu anei, ka mea e laa ai ka mohai?   
\q1
\v 20 O ka mea hoohiki ma ke kuahu, oia no ka hoohiki ma ia mea a me na mea a pau maluna iho.   
\q1
\v 21 A o ka mea hoohiki aka ma ka luakini, oia no ke hoohiki aku ma ia mea, a me ka mea e noho ana iloko.   
\q1
\v 22 A o ka mea hoohiki ma ka lani, oia ke hoohiki ma ka nohoalii o ke Akua, a me ka mea e noho ana iluna iho.   
\b  
\q1
\v 23 Auwe oukou, e ka poe kakauolelo a me ka poe Parisaio, na hookamani! no ka mea, ke hookupu nei oukou i ka hapaumi o ka mineta me ka aneto a me ke kumino; a ke haalele nei i na mea nui o ke kanawai, i ka hoopono, i ke aloha a me ka hooiaio: o ka oukou mau mea keia e pono ai ke hana, aole hoi e haalele i kela.   
\q1
\v 24 E na alakai makapo, ke kanana nei i ka naonao, me ke ale wale iho i ke kamelo.   
\b  
\q1
\v 25 Auwe oukou, e ka poe kakauolelo a me ka poe Parisaio, na hookamani! no ka mea, ke holoi nei oukou ia waho o ke kiaha a me ke pa; aka, ua piha o loko i ka mea i kaili wale ia a me ka liki ole i ka hoomanawanui.   
\q1
\v 26 E ka Parisaio makapo: e holoi mua oe ia loko o ke kiaha a me ke pa, i maemae pu ia me ko waho.   
\b  
\q1
\v 27 Auwe oukou, e ka poe kakauolelo a me ka poe Parisaio, na hookamani! no ka mea, ua like oukou me na halekupapau keokeo; ua ikea nae ko waho he maikai; aka, ua piha o loko i na iwikupapau a me ka pelapela.   
\q1
\v 28 Pela hoi oukou, ua ikea e na kanaka, he maikai mawaho; aka, ua piha o loko i ka hoopunipuni a me ka pono ole.   
\b  
\q1
\v 29 Auwe oukou, e ka poe kakauolelo a me ka poe Parisaio, na hookamani! no ka mea, ke hana nei oukou i na halekupapau no ka poe kaula, a ke hoonaui nei hoi i na halekupapau no ka poe haipule;   
\q1
\v 30 A ke olelo nei oukou, Ina makou i ola pu i ka wa o ka makou poe kupuna, aole makou i hookahe pu me lakou i ke koko o ka poe kaula.   
\q1
\v 31 Pela oukou e hoike mai nei ia oukou iho, he mamo oukou na ka poe pepehi kaula.   
\q1
\v 32 E hoopiha ae hoi oukou i ke ana o ko oukou poe kupuna.   
\q1
\v 33 E ka poe nahesa, ka ohana moonihoawa, pehea la auanei oukou e pakele ai i ka make ma gehena?   
\b  
\q1
\v 34 Nolaila hoi, ke hoouna aku nei au ia oukou la i na kaula a me na kanaka naauao, a me na kakaoolelo: a na oukou e pepehi a e kau ma ke kea i kekahi poe o lakou; a e hahau hoi i kekahi poe o lakou ma na halehalawai; a e alualu hoi ia lakou mai keia kulanakauhale a kela kulanakauhale.   
\q1
\v 35 I hookauia maluna iho o oukou ke koko hala ole a pau i hookaheia maluna o ka honua, mai ke koko o Abela o ke kanaka pono mai, a hiki i ke koko o Zakaria ke keiki a Barakia, a oukou i pepehi ai mawaena o ka luakini a me ke kuahu.   
\q1
\v 36 He oiaio ka'u e olelo aku nei ia oukou, E kau mai ana keia mau mea a pau maluna o keia hanauna.   
\b  
\q1
\v 37 E Ierusalema, e Iersualema! ka mea nana i pepehi i na kaula, a i hailuku hoi i ka poe i hoounaia mai iou nei; nani kuu makemake e houluulu mai i kau poe keiki, e like me ka houluulu ana a ka mea i kana ohana keiki malalo iho o kona mau eheu; aole nae oukou i makemake mai.   
\q1
\v 38 Aia hoi, ua waiho neoneo ia no oukou ko oukou hale o noho ai.   
\q1
\v 39 No ka mea, ke olelo aku nei au ia oukou, Aole oukou e ike hou mai ia, u, a hiki i ka wa e olelo mai ai oukou, e hoomaikaiia ka mea e hele mai ana ma ka iuoa o ka Haku.   
\c 24  
\b  
\q1
\v 1 I KO Iesu hele ana aku iwaho, haalele aku la ia i ka luakini, a hele mai la kaua poe haumana e kuhikuhi ia ia i na hale o ka luakini.   
\q1
\v 2 I mai la o Iesu ia lakou, Ke ike nei anei oukou i keia mau mea a pau? He oiaio ka'u e olelo aku nei ia oukou, e pau ia mau mea i ka hoohioloia; aole e koe kekahi pohaku maluna o kekahi pohaku.   
\b  
\q1
\v 3 I kona noho ana maluna o ka mauna Oliveta, hele malu aku la ka poe haumana io na la, i aku la, E hai mai oe ia makou, i ka manawa hea e hiki mai ai ia mau mea? Heaha hoi ka hoailona no kou hiki ana mai, a me ka hope o keia ao?   
\q1
\v 4 Olelo mai la o Iesu ia lakou i aka la, E malama ia oukou, o hoopunipuni mai hekahi ia oukou.   
\q1
\v 5 No ka mea, he nui na mea e holo mai ma ko'u inoa, me ka i ana mai, Owau no ka Mesia, a he nui no ka poe e hoopunipuniia e lakou.   
\q1
\v 6 E lohe auanei oukou i na kaua, a me na lono no na kaua; e ao ia oukou iho, mai hopohopo; no ka mea, e hiki io mai ia mau mea a pau, aole nae ia ka hopena.   
\q1
\v 7 E ku e ana kekahi lahuikanaka i kekahi lahuikanaka; a o kekahi aupuni i kekahi aupuni: a e hiki mai no na wi, a me na ahulau, a me na olai i kela wahi a i keia wahi.   
\q1
\v 8 O keia mau mea ka hoomaka ana o na popilikia.   
\q1
\v 9 la manawa, e haawi lakou ia oukou e hoomainoinoia mai ai, a e pepehi mai lakou ia oukou a make; a e inainaia mai hoi oukou e na lahuikanaka a pau no ko'u inoa.   
\q1
\v 10 Alaila hoi, he nui na mea e hihia ana; a e kumakaia aku kekahi i kekahi, e inaiua aku hoi kekahi i kekahi.   
\q1
\v 11 E ku mai no hoi na kaula wahahee he nui loa, a e hoopunipuni aku hoi lakou i na kanaka he nui loa.   
\q1
\v 12 No ka nui ana mai o ka hewa, e malili no ke aloha o ka lehulehu.   
\q1
\v 13 Aka, o ka mea hoomanawanui aku a hiki i ka hopena, e ola ia.   
\q1
\v 14 A e haiia'ku no keia euanelio o ke aupuni ma na wahi aukauaka a pau, i mea e ike ai na lahuikanaka a pau: alaila iho e hiki mai ka hopena.   
\b  
\q1
\v 15 Aia ike oukou i ka mea ino e hooneoneo ai e ku ana ma kahi hoano, ka mea i oleloia mai e ke kaula e Daniela; (o ka mea heluhelu, e pono e hoomaopopo iho oia,)   
\q1
\v 16 Alaila, o ka poe e noho ana ma Iudea, e holo lakou ma na kuahiwi.   
\q1
\v 17 O ka mea maluna o ka hale, mai iho iho ia e lawe i na mea oloko o kona hale.   
\q1
\v 18 A o ka mea ma ka waena, mai hoi hou ia i hope e kii i kona kapa aahu.   
\q1
\v 19 Auwe ka poe wahine hapai, a me ka poe hanai waiu ia mau la!   
\q1
\v 20 E pule hoi oukou, i holo ole ai oukou i ka wa hooilo, aole hoi i ka la Sabati.   
\q1
\v 21 Alaila, e nui loa mai no ka popilikia, aohe popilikia me neia mai ke kumu mai o ka honua, aole hoi ma ia hope aku.   
\q1
\v 22 Ina e hoopokole ole ia ua mau la la, ina aole loa e ola kekahi kanaka: aka, no ka poe i waeia, e hoopokoleia ua mau la la.   
\q1
\v 23 Ina e olelo mai kekahi ia oukou ia manawa, E, eia maanei ka Media; a, aia ma o, mai manao oukou he oiaio.   
\q1
\v 24 No ka mea, e ku ae no na Mesia wahahee, a me na kaula wahahee, a e hoike aku lakou i na hoailona nui, a me na mea kupanaha; a ina he mea hiki, ina e hoopunipuni hoi lakou i ka poe i waeia.   
\q1
\v 25 Aia hoi, ua hai e au mamua ia oukou.   
\q1
\v 26 Nolaila, a i olelo mai lakou ia oukou, Aia la, ma ka waonahele oia, mai hele aku oukou ilaila: Aia hoi ia ma ke keena mehameha; mai manao oukou he oiaio.   
\q1
\v 27 No ka mea, e like me ka uila i anapu mai ai, mai ka hikina mai, a hoomalamalama aku i ke komohana; pela no hoi ka hiki ana mai o ke Keiki a ke kanaka.   
\q1
\v 28 No ka mea, i kahi e waiho ai ka heana, ilaila no e akoakoa ai na aeto.   
\b  
\q1
\v 29 Mahope iho o ia mau la popilikia, e poeleele ana ka la, aole hoi e malamalama mai ka mahina, e haule iho hoi na hoku mai ka lani mai, a e hoonaueia na mea mana o ka lani.   
\q1
\v 30 Alaila, e ikea mai ai ka hoailona no ke Keiki a ke kanaka ma ka lani; a e uwe na lahuikanaka a pau o ka honua, aia ike lakou i ke keiki a ke kanaka e hele mai ana maluna o na ao o ka lani, me ka mana a me ka nani nui.   
\q1
\v 31 A e hoouna aku ia i kana poe anela me ka pu kani nui, a e hoakoakoa mai lakou i kona poe i waeia, mai na makani eha, a mai kela aoao o ka lani a mai keia aoao hoi   
\b  
\q1
\v 32 E ao oukou i ka olelonane no ka laau fiku; Aia opiopio na lala, a ulu ae na lau, na ike oukou, ke kokoke mai nei ke kau.   
\q1
\v 33 Pela hoi, a ike oukou i keia mau mea a pau, alaila e ike oukou, na kokoke mai ia, aia ma ka puka.   
\q1
\v 34 Ho oiaio ka'u e olelo aku nei ia oukou, Aole e hala aku keia hanauna, a hiki e mai ua mau mea la a pau.   
\q1
\v 35 E lilo ana ka lani a me ka honua; aka, aole loa e lilo ka'u mau olelo.   
\b  
\q1
\v 36 Aole i ike kekahi kanaka ia la a me ia hora, aole hoi na anela o ka lani; o ko'u Makua wale no.   
\q1
\v 37 Me na la o Noa, pela hoi ka hiki ana mai o ke Keiki a ke kanaka.   
\q1
\v 38 No ka mea, i na la mamua o ke kaiakahinalii, ai lakou a inu hoi, mare lakou a hoopalau no ka mare ana, a hiki i ka la i komo ai o Noa iloko o ka halelana;   
\q1
\v 39 Aole lakou i ike, a hiki mai ke kaiakahinalii, a pau loa ae la lakou i ka make: pela no hoi ka hiki ana mai o ke Keiki a ke kanaka.   
\q1
\v 40 Alaila, elua kanaka ma ka waena, e laweia kekahi, a e koe no kekahi.   
\q1
\v 41 Elua wahine e wili palaoa ana, a laweia kekahi, a e koe no kekahi.   
\b  
\q1
\v 42 Nolaila, e kiai oukou; no ka mea, aole oukou ike i ka hora e hiki mai ai ko oukou Haku.   
\q1
\v 43 Ua ike oukou i keia, ina paha i ike ka mea hale i ka wati e hiki mai ai ka aihue, ina ua kiai ia, i wawahi ole ia'i kona hale.   
\q1
\v 44 Pela hoi oukou e noho ai me ka makaukau; no ka mea, i ka hora e manao ole ia'i e oukou, o hiki mai no ke Keiki a ke kanaka.   
\b  
\q1
\v 45 Owai la ke kanwa malama pono, naanao, i hoonohoia'e e kona haku i luna no kona mau ohua e haawi aku i ai na lakou i ka manawa pono.   
\q1
\v 46 E pomaikai ana ua kauwa la, ke ike mai kona haku ia ia e hana ana pela i kona hoi ana mai.   
\q1
\v 47 He oiaio ka'u e olelo aku nei ia oukou, e hoonoho kela ia ia maluna o kona waiwai a pau.   
\q1
\v 48 Aka, o ke kauwa ino la, i olelo iho iloko o kona naau, Ke hoohakalia nei kuu haku i kona hoi ana mai;   
\q1
\v 49 A ke hoomaka ia e pepehi i na hoa kauwa ona, a e ai pu a e inu pu me ka poe ona:   
\q1
\v 50 E hoi hon mai no ka haku o ua kanwa la, i ka la i kiai ole ai ia, a me ka hora i manao ole ai ia;   
\q1
\v 51 A e hookaawale aku kela ia ia, a e haawi aku i kana kuleana me ka poe hookamani; ilaila ka uwe ana a me ka uwi ana o na niho.   
\c 25  
\b  
\q1
\v 1 A LAILA, e hoohalikeia ke aupuni o ka lani me na wahine puupaa he umi, na lakou i lawe i ko lakou mau kukui, a hele aku la i waho e halawai me ke kane mare.   
\q1
\v 2 Elima o lakou i naauao, elima hoi i naaupo.   
\q1
\v 3 Lawe aku la ua poe naaupo la i ko lakou mau kukui, aole nae i lawe pu i ka aila.   
\q1
\v 4 Aka, lawe pu aku la ua poe naauao la i ka aila iloko o ko lakou mau ipu me na kukui o lakou.   
\q1
\v 5 I ka hookaulua ana o ke kane mare, luluhi ae la na maka o lakou, a hiamoe iho la lakou a pau.   
\q1
\v 6 I ke aumoe he kahea ana, Eia ae, ke hele mai la ke kanemare; e holo aku oukou e halawai me ia.   
\q1
\v 7 Alaila, ala ae la ua poe wahine puupaa la a pau, a koli iho la i ko lakou mau kukui.   
\q1
\v 8 I aku la ka poe naaupo i ka poe naauao, E haawi mai no makou i kauwahi aila o oukou; no ka mea, ua pio ko makou mau kukui.   
\q1
\v 9 Olelo ae la ka poe naauao, i ae la, Aole paha e lawa ka aila no kakou a pau; e hele ae oukou i ka poe kuai, a kuai i aila no oukou.   
\q1
\v 10 A hala aku la lakou e kuai, hiki mai la ke kanemare; a o ka poe i makaukau, komo pu aku la lakou me ia i ka mare ana, a papaniia'e la ka puka.   
\q1
\v 11 Mahope iho, hele mai na poe wahine puupaa la i koe, i mai la, E ka Haku, e ka Haku e, e wehe ae oe ia makou.   
\q1
\v 12 Olelo aku la ia, i aku la, He oiaio ka'u e olelo aku nei ia oukou, aole au ike ia oukou.   
\q1
\v 13 No ia hoi, e kiai oukou, no ka mea, aole oukou ike i ka la, aole hoi i ka hora e hiki mai ai ke Keiki a ke kanaka.   
\b  
\q1
\v 14 Ua like hoi ia me ke kanaka e hele ana, houluulu ae la ia i kana poe kauwa, a haawi aku la ia lakou i na kumukuai nona.   
\q1
\v 15 Haawi aku la ia i na talena elima no kekahi, i elua hoi no kekahi, a i hookahi hoi no kekahi; i kela mea i keia mea e like me kona akamai; alaila, holo koke aku la ia.   
\q1
\v 16 A o ka mea ia ia na talena elima, hele aku la ia, a kuai aku me ia kumu, a loaa mai ia ia na talena hou elima.   
\q1
\v 17 Pela hoi ka mea ia ia na talena elua; loaa mai no hoi ia ia na talena hou elua.   
\q1
\v 18 Aka, o ka mea ia ia ke talena hookahi, hele aku la ia, eli iho la ma ka lepo, a huna iho la i ka moni a kona haku.   
\q1
\v 19 A liuliu aku la, hoi mai la ka haku o ua mau kauwa la, a olelo hoakaka pu iho la me lakou.   
\q1
\v 20 Hele mai la ka mea ia ia na talena elima, a lawe pu mai la me ia i na talena hou elima, i mai la, E ka Haku, ua haawi mai oe ia'u i na talena elima; eia hoi ia me na talena hou elima a'u i loaa ai.   
\q1
\v 21 I aku la kona haku ia ia, Pono, e ke kauwa maikai, malama pono; he pono kou malama ana i na mea he uuku, e hoonoho no au ia oe maluna o na mea he nui loa. E komo ae oe iloko o ka olioli o kou haku.   
\q1
\v 22 Hele mai la hoi ka mea ia ia na talena elua, i mai la, E ka Haku, ua haawi mai oe ia'u i na talena elua; eia hoi ia me na talena hou elua a'u i loaa'i.   
\q1
\v 23 I aku la kona haku ia ia, Pono, e ke kauwa maikai, malama pono; he pono kou malama ana i na mea he uuku, e hoonoho no au ia oe maluna o na mea he nui loa. E komo ae oe iloko o ka olioli o kou haku.   
\q1
\v 24 Holo mai la hoi ka mea ia ia ke talena hookahi, i mai la, E ka Haku, ua ike no au ia oe he kanaka oolea, e oki ana ma kahi au i lulu ole aku ai, a e ohi ana ma kahi au i kanana ole aku ai:   
\q1
\v 25 Makau iho la au, a hele aku la, huna iho la au i kau talena ma ka lepo; eia mai no kau.   
\q1
\v 26 Olelo aku la kona haku ia ia, i aku la, E ke kauwa lokoino, hana ole, ua ike anei oe e oki ana au ma kahi a'u i lulu ole aku ai; a e ohi ana au ma kahi a'u i kanana ole ia?   
\q1
\v 27 Ilaila kau pono e waiho aku i ka'u moni me ka poe kuai moni, a i ko'u hoi ana mai, alaila loaa mai ia'u ka'u me ka uku hoopanee.   
\q1
\v 28 E lawe ae i ke talena mai ona aku, a e haawi aku na ka mea ia ia na talena he umi.   
\q1
\v 29 O ka mea ua loaa ia ia, e haawi hou ia nana a nui loa; aka, o ka mea ua loaa ole ia ia, e laweia ae ka mea ia ia.   
\q1
\v 30 A e hoolei aku i ua kauwa pono ole nei iwaho i kahi pouli; ilaila e uwe ai a e uwi ai na niho.   
\b  
\q1
\v 31 Aia hiki mai ke Keiki a ke kanaka me kona nani, a o na anela a pau pu me ia; alaila, e noho iho ia maluna o kona nohoalii nani:   
\q1
\v 32 A e hoakoakoaia mai na lahuikanaka a pau loa imua o kona alo; a e hookaawale ae oia ia lakou i kekahi poe mai kekahi poe ae, e like me ke kahuhipa i hookaawale aku i na hipa a me na kao.   
\q1
\v 33 A e hooku aku oia i ka poe hipa ma kona lima akau, a i ka poe kao ma kona lima hema.   
\q1
\v 34 Alaila, e olelo aku ke alii i ka poe ma kona lima akau, E hehe mai oukou, e ka poe i hoomaikaiia e ko'u Makua, e komo oukou i ke aupuni i hoomakaukauia no oukou mai ka hookumu ana mai o ka honua.   
\q1
\v 35 No ka mea, pololi iho la an, a haawi mai la oukou i ai na'u; makewai au, a hoinu mai la oukou ia'u; he malihini au, a hookipa oukou ia'u;   
\q1
\v 36 He kapa ole ko'u, a hoaahu mai la oukou ia'u; mai iho la au, a ike mai la oukou ia'u; maloko hoi o ka halepaahao, a hele mai la oukou ia'u.   
\q1
\v 37 Alaila, e olelo mai ka poe pono ia ia, e i mai, E ka Haku, inahea i ike ai makou ia oe ua pololi, a haawi aku i ai nau? a ua makewai, a hoinu makou ia oe?   
\q1
\v 38 Inahea hoi i ike ai makou ia oe he malihini, a hookipa makou ia oe? a me ke kapa ole, a hoaahu makou ia oe?   
\q1
\v 39 Inahea hoi i ike ai makou ia oe, he mai, a iloko o ka halepaahao, a hele aku makou iou la?   
\q1
\v 40 A e olelo aku ke alii ia lakou, me ka i aku, He oiaio ka'u e olelo aku nei ia oukou, i ka oukou hana ana pela i kekahi mea liilii loa o keia poe hoahanau o'u, ua hana mai oukou pela ia'u.   
\q1
\v 41 Alaila, e olelo ae ia i ka poe ma ka lima hema, E ka poe i ahewaia, haele oukou pela mai o'u aku nei iloko o ke ahi mau loa, i hoomakaukauia no ka diabolo a me hona poe anela.   
\q1
\v 42 No ka mea, a pololi au, aole no oukou i haawi mai i ai na'u; a makewai au, aole hoi oukou i hoinu mai ia'u;   
\q1
\v 43 He malihini au, aole no oukou i hookipa ia'u; he kapa ole ko'u, aole hoi oukou i hoaahu mai ia'u; he mai ko'u, a iloko hoi o ka halepaahao, aole hoi oukou i ike mai ia'u.   
\q1
\v 44 Alaila, e olelo mai lakou, me ka i mai, E ka Haku, inahea i ike ai makou ia oe, ua pololi, a ua makewai, a he malihini, a ke kapa ole, a he mai, a iloko o ka halepaahao paha, a malama ole makou ia oe?   
\q1
\v 45 Alaila e olelo aku oia ia lakou, me ka i aku, He oiaio ka'u e olelo aku nei ia oukou, i ka oukou hana ole ana peha i kekahi mea liilii loa o keia poe, ua hana ole mai hoi oukou pela ia'u.   
\q1
\v 46 A o keia poe la, e hele aku lakou i kahi make mau loa; aka, o ka poe maikai iloko o ke ola mau loa.   
\c 26  
\b  
\q1
\v 1 A PAU ae la keia mau olelo a pau a Iesu, i mai la ia i kana poe haumana;   
\q1
\v 2 Ua ike oukou, elua la i koe, a hiki mai ka ahaaina moliaola; a e kumakaiaia ke Keiki a ke kanaka e kaulia'i ma ke kea.   
\b  
\q1
\v 3 Alaila, hoakoakoa ae la ka poe kahuna nui a me ka poe kakauolelo, a me ka poe lunakahiko o na kanaka, ma ka hale o ke kahuna nui, o Kaiapa kona inoa,   
\q1
\v 4 Kukakuka ae la lakou, e lalau aku ia Iesu me ka hoopunipuni, a e pepehi ia ia a make.   
\q1
\v 5 Olelo ae la lakou, aole i ka wa ahaaina, o haunaele na kanaka.   
\b  
\q1
\v 6 Aia ma Betania o Iesu ma ka hale o Simona ka lepero;   
\q1
\v 7 Hele mai la kekahi wahine io na la, me ka ipu alabatero, ua piha i ka mea poni makamae, a ninini iho la ia maluua o kona poo i kona noho ana e ai.   
\q1
\v 8 Ike ae la kana poe haumana, ukiuki iho la lakou, i aku la, No ke aha la keia hoomaunauna?   
\q1
\v 9 E hiki no ke kuai lilo aku i keia mea poni i kumu nui, a e haawiia'ku ia na ka poe ilihune.   
\b  
\q1
\v 10 A ike iho la o Iesu, i mai la oia ia lakou, No ke aha la oukou e hoopilikia mai ai i ka wahine? He mea maikai kana i hana mai ai ia'u.   
\q1
\v 11 Ua mau loa ka poe ilihune me oukou, aole au e mau loa ana me oukou.   
\q1
\v 12 No ka mea, ua ninini mai kela i keia mea poni maluna iho o ko'u kino, e hoomakaukau ia'u no ke kanu ana.   
\q1
\v 13 He oiaio ka'u e olelo aku nei ia oukou, Ma na wahi a pau loa o ke ao nei, e haiia'ku ai keia euanelio, ilaila e haiia'ku ai ka ia nei hana ana, i mea e kaulana ai oia.   
\b  
\q1
\v 14 Alaila, hele aku la kekahi o ka poe umikumamalua, o Iuda Isekariota kona inea, i ka poe kahuna nui, i aku la,   
\q1
\v 15 Heaha ka oukou e haawi mai ai ia'u a na'u ia e kumakaia aka ia oakou? A kaupaona mai la lakou nana i na wahi moni he kanakolu.   
\q1
\v 16 Ma ia hope iho, imi iho la ia i ka wa pono e kumakaia aku ai ia ia.   
\b  
\q1
\v 17 I ka la mua o ka ahaaina berena hu ole, hele aku la ka poe haumana io Iesu la, i aku la ia ia, Mahea la kahi au e makemake ai e hoomakaukau makou nau e ai i ka moliaola?   
\q1
\v 18 I mai la kela, E haele aku iloko o ke kulanakauhale i kekahi kanaka, e olelo aku ia ia, Ke i mai nei ke Kumu, Ua kokoke mai nei kuu manawa; he pono e malama au me ka'u mau haumana i ka moliaola ma kou hale.   
\q1
\v 19 Hana aku la ka poe haumana e like me ka Iesu kauoha ana mai ia lakou, a hoomakaukau iho la i ka moliaola.   
\b  
\q1
\v 20 Ahiahi ae la, noho iho la ia e ai me ka umikumamalua.   
\q1
\v 21 A i ka ai ana a lakou, i mai la kela, He oiaio ka'u e olelo aku nei ia oukou, e kumakaia auanei kekahi o oukou nei ia'u.   
\q1
\v 22 A kaumaha loa iho la lakou, ninau pakahi aku la lakou ia ia, E ka Haku, owau anei?   
\q1
\v 23 Olelo mai la ia, i mai la, O ka mea e lalau pu ana me au i ka lima ma ke pa, oia ke kumakaia ia'u.   
\q1
\v 24 E hele aku ana ke Keiki a ke kanaka, e like me ka mea i palapalaia nona; auwe hoi ke kanaka nana e kumakaia ke Keiki a ke kanaka! pomaikai ua kanaka la, ina aole i hauauia mai ia.   
\q1
\v 25 Alaila, olelo aku la o Iuda nana ia i kumakaia ku, i aku la, E Rabi, owau anei ia? I mai la kela ia ia, Oia kau i olelo mai.   
\b  
\q1
\v 26 I ka lakou ai ana, lalau iho la o Iesu i ka berena, hooalohaloha aku la ia, wawahi iho la, a haawi mai la na ka poe haumana, mai la, E lawe oukou, e ai; o ko'u kino keia.   
\q1
\v 27 Lalau iho la hoi oia i ke kiaha, hooalohaloha aku la, haawi mai la ia lakou, i mai la, E inu oukou a pau i keia;   
\q1
\v 28 No ka mea, o ko'u koko keia no ke kauoha hou, i hookaheia no na mea he nui loa, i mea e kalaia'i na hala.   
\q1
\v 29 Ke olelo aku nei au ia oukou, aole au e inu hou i ko ka huawaina, a hiki aku i ka la e inu pu ai au me oukou he waina hou iloko o ke aupuni o ko'u Makua.   
\b  
\q1
\v 30 Himeni ae la lakou, alaila hele aku la lakou ma ka mauna Oliveta.   
\b  
\q1
\v 31 Alaila, olelo mai la o Iesu ia lakou, i keia po, e hihia auanei oukou a pau no'u; no ka mea, ua palapalaia, E hahau ana au i ke Lahuhipa, a e pau hoi ka ohana hipa i ka puehu.   
\q1
\v 32 Aka, mahope iho o kuu ala hou ana, e hele aku no au mamua o oukou i Galilaia.   
\q1
\v 33 Olelo aku la o Petero ia ia, i aku la, Ina e hihia lakou nei a pau nou, aole loa au g hihia,   
\q1
\v 34 I mai la o Iesu ia ia, He oiaio ka'u e olelo aku nei ia oe, i keia po, mamua mai o ke ooo ana o ka mea, e pakolu kau hoole ana mai ia'u.   
\q1
\v 35 I aku la o Petero, Ina e make pu au me oe, aole loa au e hoole aku ia oe. Pela hoi i olelo aku ai na haumana a pau.   
\b  
\q1
\v 36 Alaila, hele aku la o Iesu me lakou ma kekahi wahi o Gelesemane ka inoa; i mai la ia i ka poe haumana, E noho iho oukou maauei, a hele aku au e pule ma o.   
\q1
\v 37 Lawe aku la oia ia Petero a me na keiki elua a Zebedaio, hoomaka iho la ia e luuluu iho, a me ke kaumaha.   
\q1
\v 38 Alaili, i mai la oia ia lakou, Ua kaumaha loa kuu uhane e like me ka make; e noho iho oukou maanei, a e kiai pu me au.   
\q1
\v 39 Hele iki aku la ia, moe iho la kona alo ilalo, pule aku la ia, i aku la, E ko'u Makua e, ina paha he mea hiki ia, e lawe aku oe i keia kiaha mai o'u aku nei; aka hoi, aia i kou makemake, aole i ko'u.   
\q1
\v 40 Hoi mai la ia i ua mau haumana la, a loaa iho la lakou e hiamoe ana; i mai ia ia Petero, Pela no anei, aole e hiki ia oukou ke kiai pu me au i hookahi hora?   
\q1
\v 41 E kiai oukou, e pule hoi, o lilo oukou i ka hoowalewaleia mai; ua oluolu nae ka naau, aka o ke kino, ua nawaliwali ia.   
\q1
\v 42 Hele hou aku la ia, ka lua ia o ka hele ana; pule aka la ia, i aku la, E ko'u Makua, ina paha aole ia he mea hiki ke laweia'ku keia kiaha mai o'u aku nei, i inu ole au, ina no e hanaia kou makemake.   
\q1
\v 43 Hoi hou mai la ia, a loaa hou iho la lakou e hiamoe ana; no ka mea, ua luluhi iho ko lakou mau maka.   
\q1
\v 44 Waiho mai la ia ia lakou, hele hou aku la, o ke kolu keia o ka pule ana, ma kela olelo hookahi no.   
\q1
\v 45 Alaila, hele mai la ia i kana poe haumana, i mai la ia lakou, E hiamoe nai aku oukou, a e hoomaha iho: aia hoi, ke kokoke mai nei ka hora, a e kamakaiaia'na ke Keiki a ke kanaka a lilo i na lima o ka poe hewa.   
\q1
\v 46 E ala mai, e haele kakou; eia ae ua kokoke mai nei ka mea nana au i kumakaia.   
\b  
\q1
\v 47 A i kana olelo ana, aia hoi, hele mai la o Iuda, kekahi o ka poe umikumamalua, me ia pa ka poe kanaka he nui, me na pahikaua a me na newa, i hoounaia mai o na kahana nui a me na lunakahiko   
\q1
\v 48 O ka mea nana ia i kumakaia, haawi aku la ia i hoailona ia lakou, i aku la, O ka mea a'u e honi aku ai, oia no ia, e hoopaa oukou ia ia.   
\q1
\v 49 A hele pololei aku la ia io Iesu la, i aku la, Aloha oe, e Rabi, a honi aku la ia ia.   
\q1
\v 50 I mai la o Iesu ia ia, E ka hoalauna, heaha kau i hele mai nei? Alaila hele aku la lakou, a kau aku la i na lima malana o Iesu, a hoopaa iho la ia ia.   
\q1
\v 51 Aia hoi, o kekahi o ka poe me Iesu, lalau iho la kona lima i kana pahikana, unuhi ae la, a hahau aku la i ke kauwa a ke kaluna nui, a old aku la i kona pepeiao.   
\q1
\v 52 Alaila i mai la o Iesu ia ia, E hoihoi oe i ka pahikaua i kona wahi: no ka mea, o ka poe lalau i ka pahikaua, o make no lakou i ka pahikaua.   
\q1
\v 53 Ke manao nei anei oe, e hiki ole ia'u ano ke kahea aku i ko'a Makua, a e hoouna mai no ia io'u nei i na legeona anela he umikumamalua a keu aku?   
\q1
\v 54 Aka, pehea la hoi e hookoia'I ka Palapala, e i mai ana, e hanaia keia mau mea?   
\q1
\v 55 Ia hora no, olelo aka la Iesu i ka poe kanaka, Ke hele mai nei anei oukou iwaho nei me na pahikaua a me na newa e lalau mai ia'u, e like me ka lalau ana i ka powa? Ua noho pu au me oukou i kela la i keia la e ao ana iloko o ka luakini aole nae oukou i lalau mai ia'u.   
\q1
\v 56 Ua hanaia keia mau mea a pau i ko ai na palapala a ka poe kaula. Alaila, haalele iho la na haumana a pau ia ia, a holo aku la.   
\b  
\q1
\v 57 A o ka poe nana Iesu i lalau aku, alakai aku la lakou ia ia io Kaiapa la ke kahana nui, kahi i hoakoakoaia'i ka poe kakauolelo a me na lunakahiko.   
\q1
\v 58 Ukali mamao aku la o Petero ia ia, a hiki i ka pahale o ke kahuna nui: a komo aku la ia iloko, noho pu iho la me ka poe ilamuku e ike i ka hope.   
\q1
\v 59 Imi aku la ka poe kahuna nui me na lunakahiko, a me ka ahalonakanawai a pau i mea hoike wahahee no Iesu i make ai oia;   
\q1
\v 60 Aole nae i loaa. He nui no hoi na mea hoike wahahee i hele mai, aole hoi i loaa, Mahope iho hele mai la elua mau mea hoike wahahee,   
\q1
\v 61 I mai la, Ua olelo mai oia nei, E hiki no ia'u ke wawahi iho i ka luakini o ke Akua, a e hana hou au ia a paa i na la ekolu.   
\q1
\v 62 Ku ae la ke kahuna nui, i mai la ia ia, Aole anei oe e olelo iki mai? Heaha ka laua nei i hoike mai ai nou?   
\q1
\v 63 Aole o Iesu i ekemu ae. Olelo mai la ke kahuna nui ia ia, i mai la, Ke ninau pono aku nei au ia oe ma ke Akua ola, e hai mai oe ia makou, o oe anei ka Mesia, ke Keiki a ke Akua?   
\q1
\v 64 Olelo aku la o Iesu, Oia kau i olelo mai. A ke olelo aku nei hoi au ia oukou, mahope aku nei, e ike no oukou i ke keiki a ke kanaka e noho ana ma ka lima akau o ka Mea mana, a e hele mai ana maluna o na ao o ka lani.   
\q1
\v 65 Alaila haehae iho la ke kahuna nui i kona aahu, i ne la, Ke olelo hoino wale nei oia nei; pahea la e pono ai kakou i na mea ikemaka hou? Aia hoi, ua loho iho nei oukou i kana olelo hoino aaa.   
\q1
\v 66 Heaha ko oukou manao? I mai la lakou, Ua hewa ia e make.   
\q1
\v 67 Alaila, kuha aku la lakou i kona maka, a kui aku la ia ia, a papai aku la kekahi poe ia ia me ka poho lima,   
\q1
\v 68 I aku la, E ka Mesia, e koho mai oe ia makou, nawai oe i papai aku?   
\b  
\q1
\v 69 Noho iho la o Petero iwaho ma ka pahale; a hele mai la kekahi kaikamahine io na la, i mai la, O oe no hoi kekahi mo Iesu no Galilaia.   
\q1
\v 70 Hoole aku la ia imua o lakou a pau, i aku la, Aole au ike i kau mea e olelo mai nei.   
\q1
\v 71 Hele aku la ia iwaho ma ka ipuka, ike mai la kekahi kaikamahine e ae ia ia, a hai aku la ia lakou ilaila, Oia nei no hoi kekahi me Iesu no Nazareta.   
\q1
\v 72 Hoole hou aku la ia me ka hoohiki ino, Aole au ike i ua kanaka la.   
\q1
\v 73 Mahope iho, hele mai la ka poe e ku ana ilaila, i mai la ia Petero, Oiaio no, o oe kekahi o lakou, no ka mea, ke hoike mai nei kau olelo ia oe iho.   
\q1
\v 74 Alaila, hoomaka iho la ia e hailiili a me ka hoohiki ino, i aku la, Aole au i ike ia kanaka. A ooo koke iho la ka mea.   
\q1
\v 75 A hoomanao iho la o Petero i ka mea a Iesu i olelo mai ai ia ia, Mamua mai o ke ooo ana o ka mea, e pakolu no kau hoole ana mai ia'u. Hele aku la ia iwaho, a uwe walania iho la ia.   
\c 27  
\b  
\q1
\v 1 A KAKAHIAKA ae la, kukakuka iho la ka poe kahuna nui a pau, a me ka poe lunakahiko o na kanaka, i ka mea o make ai o Iesu.   
\q1
\v 2 Hikiikii iho la lakou ia ia, kai aku la ia ia, a haawi aku la ia Ponetio Pilato ke kiaaina.   
\b  
\q1
\v 3 Alaila, ike ae la o Iuda nana ia i kumakaia aku, ua hoohewaia o Iesu e make, mihi iho la ia, hoihoi aku la ia i na moni he kanakolu i ka poe kahuna nui a me na lunakahiko,   
\q1
\v 4 I aku la, Ua hewa wau i kuu kumakaia ana aku i ke koko hala ole. I mai la lakou, Heaha ia ia makou? Ia oe aku no ia mea.   
\q1
\v 5 Hoolei iho la ia i na moni ilalo, maloko o ka luakini, haalele aku la a hele, a kaawe iho la ia ia iho.   
\q1
\v 6 Lawe ae la ka poe kahuna nui i ua mau moni la, i ae la, Aole pono ke waiho aku ia mea me na moni laa; no ka mea, o ke kumu keia i kuai ai i ke koko.   
\q1
\v 7 Kukakuka iho la lakou, a kuai aku la me ia mau mea i ka aina o ka potera, i wahi e kanu ai i na malihini.   
\q1
\v 8 No ia mea, ua kapaia ua aina la, ka aina koko, a hiki i neia manawa.   
\q1
\v 9 Ilaila i ko ai ka olelo a ke kaula a Ieremia, i i mai ai, Ua lawe aku lakou i na moni he kanakolu, ke kumukuai no ka mea i kuaiia, ka mea a ka poe mamo a Iseraela i kuai ai;   
\q1
\v 10 A haawi aku la lakou ia mau mea no ka aina o ka potera, e like me ka ka Haku i kauona mai ai ia'u.   
\b  
\q1
\v 11 Ku ae la o Iesu imua o ke kiaaina, ninau mai la ke kiaaina ia ia, i mai la. O oe no anei ke alii o ka poe Iudaio? I aku la Iesu ia ia, Oia no kau i olelo mai la.   
\q1
\v 12 Ia ia i ahewaia'i e ua kahuna nui a me na lunakahiko, aole ia i olelo iki aku.   
\q1
\v 13 Alaila, i mai la o Pilato ia ia, Aole anei oe e lohe ia mau mea he nui wale a lakou e hoike mai nei nou?   
\q1
\v 14 Aole hoi oia i olelo iki aku ia ia, a kahaha nui iho la ke kiaaina.   
\q1
\v 15 Ia ahaaina he mea mau no i ke kiaaina ke kuu aku i kekahi paahao no na kanaka, i ka mea a lakou i makemake ai.   
\q1
\v 16 He paahao kaulana ia lakou ia manawa, o Baraba ka inoa.   
\q1
\v 17 A akoakoa mai la lakou, ninau aku la o Pilato ia lakou, Owai ka oukou e makemake nei e kala aku au no oukou, o Baraba anei, a o Iesu anei i kapaia ka Mesia?   
\q1
\v 18 No ka mea, ua ike iho la ia, no ka huahua i hoopea aku ai lakou ia ia.   
\b  
\q1
\v 19 A i kona noho ana ma ka noho hookolokolo, hoouna mai la kana wahine io na la, i mai la, Mai mea iki aku oe i ua kanaka hala ole la; no ka mea, ua kaumaha loa wau nona i keia la ma ka moeuhane.   
\q1
\v 20 Aka, hookonokono aku la ka poe kahuna nui a me ka poe lunakahiko i na kanaka, e noi mai ia Baraba, a e pepehi ia Iesu.   
\q1
\v 21 Olelo aka la ke kiaaina, i aku la ia lakou, Owai ko oukou mea makemake o laua nei, e kuu aku ai au no oukou? I mai la lakou, O Baraba.   
\q1
\v 22 Ninau aku la o Pilato ia lakou, Heaha hoi ka'u e hana aku ai ia Iesu, i kapaia ka Mesia? I mai la lakou a pau ia ia, E kaulia ia ma ke kea.   
\q1
\v 23 Ninau aku la ke kiaaina, No ke aha? Heaha ka hewa ana i hana'i? A nui loa ae la ka lakou uwa ana mai, i mai, E kaulia ma ke kea.   
\b  
\q1
\v 24 Ike ae la o Pilato, aole e hiki kana, aka, he nui loa ka haunaele ana mai, lalau aka la ia i ka wai, a holoi iho la i kona mau lima imus o ka poe kanaka, i aku la, Aohe o'u hala i ke koko o keia kanaka pono: ia oukou aku no ia.   
\q1
\v 25 Olelo mai la ka poe kanaka a pau, Iluna iho o makou kona koko, iluna hoi o ka makou kamalii.   
\b  
\q1
\v 26 Alaila, kuu ae la ia ia Baraba no lakou: aka, hahau aku la oia ia Iesu, a haawi aku la ia ia e kaulia'i ma ke kea.   
\b  
\q1
\v 27 Alaila, kai aku la ka poe koa o ke kiaaina ia Iesu iloko o kahi hookolokolo, a hoaluulu mai la lakou i ka poe koa a pau io na la.   
\q1
\v 28 Wehe ae la lakou i kona kapa, a kahiko iho la ia ia i ka aahu ulaula.   
\b  
\q1
\v 29 Ulana iho la lakou i leialii kakalaioa, a kau aku la ia maluna o kona poo, a me ka ohe ma kona lima akau; kukali iho la imua ona, hoomaewaewa aku la lakou ia ia, i aku la, Aloha oe, e ke Alii o ka poe Iudaio!   
\q1
\v 30 A kuhaaku la lakou ia ia, lalau aku hoi i ka ohe, a hahau aku la hoi i kona poo.   
\q1
\v 31 A pau ko lakou hoomaewaewa ana ia ia, wehe ae la lakou i ua aahu la, a hoaahu ae la ia ia i kona aahu, a kai aku la ia ia e kaulia'i ma ke kea.   
\b  
\q1
\v 32 I ko lakou hele ana iwaho, loaa iho la ia lakou kekahi kanaka no Kurene, o Simona kona iona; koi aku la lakou ia ia e amo i kona kea.   
\b  
\q1
\v 33 A hiki aku la lakou i kahi i kapaia o Gologota, oia hoi keia i hoikeia, he wahi iwipoo,   
\b  
\q1
\v 34 Haawi aku la lakou i ka vinega i kawili pu ia me ka laau awaawa, e inu; a i ka hoao ana iho, aole ia i makemake e inu.   
\q1
\v 35 Kau aku la lakou ia ia ma ke kea, a puunaue aku la i kona mau kapa, a puu iho la hoi; i ko ai ka mea i oleloia e ke kaula, Ua puunaue ae lakou i kuu mau kapa aahu no lakou, a no ko'u kapakomo ua puu no lakou.   
\q1
\v 36 Noho iho la lakou ilaila, a kiai aku la ia ia.   
\q1
\v 37 Kau aka la lakou maluna ae o kona poo i ka palapala o kona ahewa ana, O IESU KEIA, KE ALII O KA POE IUDAIO.   
\q1
\v 38 Elua hoi kanaka powa i kaulia pu me ia ma ke koa, ma ka lima akau kekahi, ma ka lima hema hoi kekahi.   
\b  
\q1
\v 39 O ka poe maalo ae, kuamuamu aku la lakou ia ia, e hooluliluli ana i ko lakou poo,   
\q1
\v 40 Me ka i ana, O oe ka mea nana e wawahi i ka luakini, a hooku hou ae i na la ekolu, e hoola oe ia oe iho. A o ke Keiki oe a ke Akua, e iho mai oe ilalo mailuna mai o ke kea.   
\q1
\v 41 Hoomaewaewa aku la no hoi ka poe kahuna nui, me ka poe kakauolelo, a me ka poe lunakahiko, i aku la,   
\q1
\v 42 Ua hoola kela ia hai, aole ka e hiki ia ia ke hoola ia ia iho. A o ke alii ia no ka Iseraela, e iho iho ia ilalo mai ke kea mai, a o manaoio aku makou ia ia.   
\q1
\v 43 Ua paulele aku no ia i ke Akua, a ina makemake mai ke Akua ia ia, e hoola mai kela ia ia ano; no ka mea, ua olelo mai no ia, Owau no ke Keiki a ke Akua.   
\q1
\v 44 Pela mai no hoi na powa e kau pu ana me ia, hoine mai la ia ia.   
\b  
\q1
\v 45 Mai ka hora aono a hiki i ka hora aiwa, ua pouli ka honua a pau.   
\q1
\v 46 A i ka iwa o ka hora, kahea aku la o Iesu me ka leo nui, i aku la, Eli, Eli, lama sabaketani? oia hoi keia, E kuu Akua, e kuu Akua: no ke aha la oe i haalele mai ai ia'u?   
\q1
\v 47 A lohe ae la kekahi poe o lakou e ku ana malaila, i mai la lakou, Ke kahea aku nei oia ia Elia.   
\q1
\v 48 Holo koke aku la kekahi o lakou, lalau ae la i ka huahuakai, hoou iho la i ka vinega, kau aku la ia ma ka ohe, a haawi aku la ia ia e inu.   
\q1
\v 49 I mai la kekahi poe, Alia, a ike kakou, e hele mai paha o Elia e hoola ia ia.   
\b  
\q1
\v 50 Kahea hou aku la o Iesu me ka leo nui, alaila kuu aku la ia i ka uhane.   
\q1
\v 51 Aia hoi, nahae iho la ka paku o ka luakini iwaena, mailuna a hala ilalo: naueue ae la ka honua, naba'e la hoi na pobaku.   
\q1
\v 52 Hamama ae la na halekupapau, a he nui na haipule e hiamoe ana i ala hou mai,   
\q1
\v 53 A hele mai la iwaho o na halekupapau mahope iho o kona ala hou ana mai, a komo aku la iloko o ke kulanakauhale hoano, a ua ikea e na mea he nui loa.   
\q1
\v 54 A ike ae la ka lunahaneri, a o na mea me ia e kiai ana ia Iesu i ke olai, a me na mea i hanaia, makau loa iho la lakou, i ae la, He oiaio no, o ke Keiki no keia a ke Akua!   
\q1
\v 55 He nui no hoi ka poe wahine ma kahi mamao aku, e makaikai mai ana; na lakou i ukali ia Iesu mai Galilaia mai e lawelawe ana nana.   
\q1
\v 56 Me lakou pu o Maria no Magedala, a o Maria ka makuwahine o Iakoba laua o Iose, a me ka makuwahine o na keiki a Zebedaio.   
\b  
\q1
\v 57 A ahiahi ae la, hele mai la kekahi kanaka waiwai no Arimataia, o Iosepa kona inoa, he haumana hoi ia na Iesu.   
\q1
\v 58 Hele aku la ia io Pilato la, a noi aku la i ke kino o Iesu. Alaila kauoha aku la o Pilato, e haawiia mai ke kino.   
\q1
\v 59 Lawe ae la o Iosepa i ke kino, a wahi iho la ia ia iloko o ka lole olona maemae;   
\q1
\v 60 A waiho iho la ia ia ma kona halekupapau hou i kalaiia iloko o ka pohaku: a olokaa aku la ia i pohaku nui ma ka puka o ua halekupapau la, a hoi aku la.   
\q1
\v 61 Malaila no o Maria no Magedala, a me kekahi Maria, e noho ana ma kahi ku pono i ua halekupapau la.   
\b  
\q1
\v 62 I ka la mahope iho o ka la hoomalolo, hele akoakoa aku la ka poe kahuna nui a me ka poe Parisaio io Pilato la,   
\q1
\v 63 I aku la, E ka haku, ke hoomanao nei makou, i olelo mai ua kanaka hoopunipuni la i kona wa e ola ana, A po akolu ae, e ala hou mai ana au.   
\q1
\v 64 Nolaila, e kauoha aku oe i kiai pono ia'i ka halekupapau a hiki i ka poakolu, o hele mai ka poe haumana ana, a aihue malu ia ia, a e olelo aku i na kanaka, Ua ala mai ia mai ka make mai; a e nui loa aku ka hewa o keia hoopunipuni hope i kola mamua.   
\q1
\v 65 I mai la o Pilato ia lakou, Aia ia oukou ho poe kiai; e haele oukou, e hoopaa loa i ka hale kupapau.   
\q1
\v 66 Hele aku la lakou, hoopaa iho la i ka halekupapau, hoailona iho la i ka pohaku, a hoonoho iho la i poe kini.   
\c 28  
\b  
\q1
\v 1 A NO A ae la ka Sabati, a wehe ae la ke alaula o ka la mua o ka hebedoma, hele aku la o Maria no Magedala, a me kekahi Maria e nana i ka halekupapau.   
\q1
\v 2 Aia hoi, he olai nui: no ka mea, ua iho mai ka anela a ka Haku mai ka lani mai, a olokaa ae la i ka pobaku mai ka puka ae, a noho iho la iluna o ia mea.   
\q1
\v 3 Ua like kona helehelena me ka uila, a ua huali kona kapa e like me ka hau;   
\q1
\v 4 Haalulu iho la ka poe kiai i ka makau ia ia, a ua like lakou me na kanaka make.   
\q1
\v 5 Olelo mai la ka anela i ua mau wahine la, Mai makau olua, no ka mea, ua ike au e imi ana olua ia Iesu i ka mea i kaulia ma ke kea.   
\q1
\v 6 Aole ia maanei, no ka mea, ua ala ae ia e like me kana olelo ana; e haele mai olua e nana i kahi i waiho ai o ka Haku.   
\q1
\v 7 E haele koke olua e hai aku i kana poe haumana, ua ala ae ia mai ka make mai; aia hoi, e hele aku ana ia mamua o oukou i Galilaia, malaila oukou e ike aku ai ia ia. Eia hoi, ua hai aku no wau ia olua.   
\q1
\v 8 Hoi koke aku la laua iwaho o ka halekupapau me ka makau a me ka olioli nui; a holo aku la laua e hai aku i na baumana ana.   
\b  
\q1
\v 9 I ko laua hele ana aku o hai i na haumana, aia hoi, halawai mai la o Iesu me laua, i mai la, Aloha olua! Hele aku la laua, apo ae la ma kona wawae, a hoomana aku la ia ia.   
\q1
\v 10 Alaila, i mai la o Iesu ia laua, Mai makau olua, ou hele o i aku i ko'u poe hoahanau, o haele aku lakou i Galilaia, malaila lakou e ike ai ia'u.   
\b  
\q1
\v 11 A hala aku la laua, alaila, hele aku la kekahi mau mea o ka poo kiai iloko o ke kulanakauhale, a hai aku la i ka poe kahuna nui i na mea a pau i hanaia.   
\q1
\v 12 A akoakoa ae la lakou me ka poo lunakahiko, kukakuka iho la lakou a haawi aku la i na moni he nui i ka poe koa,   
\q1
\v 13 I aku la, E olelo aku oukou, Na kana poe haumaua no i kii mai i ka po, a lawe malu aku la ia ia i ko makou wa e hiamoe ana.   
\q1
\v 14 Ina e hiki aku keia i na pepeiao o ke kiaaina, na makou ia e hoolealea aku, a e hoopakele ia oukou.   
\q1
\v 15 Lawe ae la lakou i ua moni la, a hana aku la e like me ka lakou i kauoha mai ai. A ua kui aku la ia olelo ana iwaena o ka poe Iudaio a hiki i neia manawa.,   
\b  
\q1
\v 16 Hele aku la ka poe haumana he umikumamakahi i Galilaia, i ka manua a Iesu i hoike mai ai ia lakou,   
\q1
\v 17 A ike aku la lakou ia ia, hoomana aku la ia ia; aka, ua kanalua kekahi poe.   
\q1
\v 18 Hele mai la o Iesu olelo mai la ia lakou, i mai la, Ua haawiia mai ia'u ka mana a pau ma ka lani a ma ka honua nei.   
\b  
\q1
\v 19 E hele ae oukou e hoohanmana aku i na lahuikanaka a pau, e bapetizo ana ia lakou iloko o ka inoa o ka Makua, a o ke Keiki, a o ka Uhane Hemolele:   
\q1
\v 20 E ao aku ana ia lakou e malama i na mea a pau a'u i kauoha aku ai ia oukou, Aia hoi, owau no me oukou i na manawa a pau, a hiki i ka hopena o keia ao. Amene.   