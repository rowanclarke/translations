\q1
\v 4 \w Their|strong="H3559"\w* \w chariots|strong="H7393"\w* \w will|strong="H3117"\w* dash through \w the|strong="H3117"\w* streets \add of Nineveh\add*  
\q2 \w and|strong="H3117"\w* rush furiously through \w the|strong="H3117"\w* plazas.  
\q1 Going \w as|strong="H3117"\w* quick \w as|strong="H3117"\w* lightning,  
\q2 \w they|strong="H3117"\w* \w will|strong="H3117"\w* resemble flaming \w torches|strong="H6393"\w*.   
\b  
\q1
\v 5  \add Meanwhile\add*, \w your|strong="H1984"\w* king will summon \w his|strong="H1984"\w* officers  
\q2 \w who|strong="H7323"\w* will stumble \w as|strong="H2351"\w* \w they|strong="H7323"\w* \add try to\add* come \add quickly\add*.  
\q1 \w They|strong="H7323"\w* will \w dash|strong="H7323"\w* \w to|strong="H7323"\w* \w the|strong="H1984"\w* \add city\add* wall,  
\q2 holding \w their|strong="H1984"\w* shields \w to|strong="H7323"\w* protect themselves.   
\q1
\v 6 But, \w the|strong="H2142"\w* gates \add of the dams\add* \w on|strong="H3559"\w* \w the|strong="H2142"\w* rivers \w will|strong="H2346"\w* \w be|strong="H4116"\w* thrown open \add by enemy soldiers\add*,  
\q2 \w and|strong="H4116"\w* \add the flood will cause\add* \w the|strong="H2142"\w* palace \w to|strong="H3559"\w* collapse.   
\q1
\v 7 \w The|strong="H6605"\w* queen \w will|strong="H1964"\w* \w have|strong="H5104"\w* \w her|strong="H6605"\w* clothes stripped \w off|strong="H6605"\w* \w her|strong="H6605"\w* \add by enemy soldiers\add*,  
