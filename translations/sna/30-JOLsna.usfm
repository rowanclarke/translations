\id JOL - Biblica® Open Shona Contemporary Bible 2017 
\h JOERE 
\toc1 Joere 
\toc2 Joere 
\toc3 Joe 
\mt1 JOERE 
\c 1  
\p  
\v 1 Shoko raJehovha rakasvika kuna Joere mwanakomana waPetueri. 
\s1 Dambudziko reMhashu 
\q1  
\v 2 Inzwai izvi, imi vakuru; 
\q2 teererai imi mose vagere munyika. 
\q1 Ko, zvakadai zvakamboitika here pamazuva enyu, 
\q2 kana pamazuva amadzitateguru enyu? 
\q1  
\v 3 Zvinhu izvi zviudzei vana venyu, 
\q2 uye vana venyu ngavaudzewo vana vavo, 
\q2 vana vavowo vaudze chizvarwa chinotevera. 
\q1  
\v 4 Zvakasiyiwa nefararira remhashu 
\q2 zvakadyiwa nemhashu dzemagutaguta; 
\q1 zvakasiyiwa nemhashu dzemagutaguta 
\q2 zvakadyiwa negwatagwata; 
\q2 zvakasiyiwa negwatagwata zvakadyiwa nedzimwewo mhashu. 
\q1  
\v 5 Mukai imi zvidhakwa, chemai! 
\q2 Ungudzai imi vanwi vewaini; 
\q1 ungudzai nokuda kwewaini itsva, 
\q2 nokuti yabvutwa pamiromo yenyu. 
\q1  
\v 6 Rudzi rwarwisa nyika yangu, 
\q2 rune simba uye haruverengeki; 
\q2 rune meno eshumba nameno makuru eshumbakadzi. 
\q1  
\v 7 Rwakaparadza mizambiringa yangu yose, 
\q2 rukaparadza mionde yangu yose. 
\q1 Rwakasvuura makwati ose emiti, 
\q2 rukaarasira kure, 
\q2 ndokusiya mapazi awo achena kuti mbe-e. 
\b  
\q1  
\v 8 Chemai semhandara yakapfeka masaga 
\q2 inochema murume wouduku hwayo. 
\q1  
\v 9 Zvipiriso zvezviyo nezvipiriso zvokunwa 
\q2 hazvichawanikwi muimba yaJehovha. 
\q2 Vaprista vari kuungudza, vaya vanoshumira pamberi paJehovha. 
\q1  
\v 10 Minda yaparadzwa, 
\q2 pasi paoma; 
\q1 zviyo zvaparadzwa, 
\q2 waini itsva yapera, 
\q2 mafuta hakuchina. 
\q1  
\v 11 Pererwai nezano, imi varimi, 
\q2 ungudzai, imi varimi vemizambiringa, 
\q1 chemerai gorosi nebhari, 
\q2 nokuti mukohwo weminda waparadzwa. 
\q1  
\v 12 Muzambiringa waoma, 
\q2 uye muonde wasvava; 
\q1 mutamba, muchindwi nomuti womuapuro, 
\q2 miti yose yesango, yaoma. 
\q1 Zvirokwazvo, mufaro wavanhu 
\q2 wasvava. 
\s1 Vanhu vanonzi vatendeuke 
\q1  
\v 13 Pfekai masaga mucheme, imi vaprista; 
\q2 ungudzai, imi munoshanda paaritari. 
\q1 Uyai muvate usiku hwose makapfeka masaga, 
\q2 imi munoshumira pamberi paMwari wangu; 
\q1 nokuti zvipiriso zvezviyo nezvokunwa 
\q2 zvadziviswa muimba yaMwari wenyu. 
\q1  
\v 14 Tsaurai nguva yokutsanya kutsvene; 
\q2 danai vanhu kuungano tsvene. 
\q1 Kokai vakuru 
\q2 navose vanogara munyika 
\q1 kuimba yaJehovha Mwari wedu, 
\q2 mugodana kuna Jehovha. 
\b  
\q1  
\v 15 Rinotyisa sei zuva iro! 
\q2 Nokuti zuva raJehovha rava pedyo; 
\q2 richauya sokuparadza kunobva kuna Wamasimba Ose. 
\b  
\q1  
\v 16 Ko, zvokudya hazvina kubviswa here 
\q2 pamberi pedu chaipo, 
\q1 mufaro nokufarisisa 
\q2 kubva mumba maMwari wedu? 
\q1  
\v 17 Mbeu dzinopetana 
\q2 dzisati dzamera pasi pevhu, 
\q1 matura aparara, 
\q2 tsapi dzaputswa 
\q2 nokuti hapachina zviyo. 
\q1  
\v 18 Mombe dzinogomera sei! 
\q2 Matanga emombe odzungaira 
\q1 nokuda kwokushayiwa mafuro. 
\q2 Kunyange mapoka amakwai ari kutambudzika. 
\b  
\q1  
\v 19 Haiwa Jehovha, ndinodana kwamuri, 
\q2 nokuti moto wapisa mafuro, 
\q2 uye mirazvo yemoto yapisa miti yose musango. 
\q1  
\v 20 Kunyange mhuka dzesango dzinochema kwamuri; 
\q2 nokuti hova dzesango dzapwa 
\q2 uye moto waparadza mafuro ose. 
\c 2  
\s1 Hondo yeMhashu 
\q1  
\v 1 Ridzai hwamanda muZioni; 
\q2 ridzai hwamanda yokuyambira vanhu muri pagomo rangu dzvene. 
\q1 Vanhu vose vagere munyika ngavadedere 
\q2 nokuti zuva raJehovha riri kuuya. 
\q1 Rava pedyo, 
\q2  
\v 2 zuva rerima nokusuwa, 
\q2 zuva ramakore nokusviba. 
\q1 Samambakwedza anoonekwa pamusoro pamakomo, 
\q2 hondo huru ine simba guru iri kuuya; 
\q1 zvakadai hazvina kutombovapo munguva yakare, 
\q2 uye hazvichazoonekwizve munguva ichatevera. 
\q1  
\v 3 Moto unoparadza pamberi padzo, 
\q2 marimi omoto ari kupisa shure kwadzo. 
\q1 Pamberi padzo, nyika yakafanana nebindu reEdheni, 
\q2 shure kwadzo kwangova gwenga risina basa, 
\q2 hapana chinopunyuka. 
\q1  
\v 4 Pakuonekwa kwadzo dzakaita samabhiza; 
\q2 dzinomhanya samabhiza ehondo. 
\q1  
\v 5 Nokutinhira sokwengoro 
\q2 dzinokwakuka pamusoro pamakomo 
\q1 dzichidya mashanga semoto unopisa uswa hwakaoma, 
\q2 sehondo ine simba yabuda kundorwa. 
\b  
\q1  
\v 6 Pakungodziona chete, ndudzi dzose dzinotya; 
\q2 vose vanocheneruka kumeso. 
\q1  
\v 7 Dzinorwisa samauto; 
\q2 dzinokwira madziro savarwi. 
\q1 Dzinofamba dzakateverana 
\q2 dzisingatsauki padzakananga napo. 
\q1  
\v 8 Hadzikwikwidzani pakufamba, 
\q2 imwe neimwe inofamba yakananga mberi. 
\q1 Dzinopwanya nzvimbo dzakadzivirirwa sei, 
\q2 pasina chinodzikanganisa pakurongana kwadzo. 
\q1  
\v 9 Dzinobhururuka dzakananga muguta; 
\q2 dzinomhanya pamusoro porusvingo. 
\q1 Dzinokwira dzichipinda mudzimba; 
\q2 dzinopinda napamawindo sembavha. 
\b  
\q1  
\v 10 Pamberi padzo, pasi panozunguzika, 
\q2 denga rinodedera, 
\q1 zuva nomwedzi zvinosviba 
\q2 uye nyeredzi dzinodzima. 
\q1  
\v 11 Jehovha anoomba, 
\q2 ari pamberi pehondo yake; 
\q1 mauto ake haaverengeki, 
\q2 uye vane simba ndivo vanoteerera kurayira kwake. 
\q1 Zuva raJehovha iguru; 
\q2 rinotyisa kwazvo. 
\q2 Ndiani angamira musi waro? 
\s1 Bvarurai Mwoyo Yenyu 
\q1  
\v 12 Jehovha anoti, “Kunyange zvino, 
\q2 tendeukirai kwandiri nemwoyo yenyu yose 
\q2 muchitsanya, muchichema uye muchiungudza.” 
\b  
\q1  
\v 13 Bvarurai mwoyo yenyu, 
\q2 kwete nguo dzenyu. 
\q1 Dzokerai kuna Jehovha Mwari wenyu, 
\q2 iye ane nyasha uye ane tsitsi, 
\q1 anononoka kutsamwa 
\q2 uye ane rudo rukuru; 
\q2 anozvidzora pakutumira vanhu njodzi. 
\q1  
\v 14 Ndiani anoziva? Anogona kupinduka agonzwa tsitsi, 
\q2 uye agokusiyirai mukomborero 
\q1 wezvipiriso zvezviyo nezvipiriso zvokunwa 
\q2 zvinoitirwa Jehovha Mwari wenyu. 
\b  
\q1  
\v 15 Ridzai hwamanda muZioni. 
\q2 Sarudzai zuva rokutsanya kutsvene, 
\q2 danai vanhu kuungano tsvene. 
\q1  
\v 16 Unganidzai vanhu, 
\q2 munatse ungano iyi, 
\q1 unganidzai pamwe chete vakuru, 
\q2 unganidzai vana, 
\q2 vachiri kuyamwa. 
\q1 Vachangowanana, murume ngaabude muimba yake 
\q2 nomwenga muimba yake. 
\q1  
\v 17 Vaprista vanoshumira pamberi paJehovha 
\q2 ngavacheme vari pakati pebiravira retemberi nearitari. 
\q1 Ngavati, “Musaparadza vanhu venyu, imi Jehovha. 
\q2 Musaita kuti nhaka yenyu ive chinhu chinosekwa, 
\q2 chirevo pakati pendudzi. 
\q1 Vachataurirei pakati pamarudzi vachiti, 
\q2 ‘Mwari wavo aripiko?’ ” 
\s1 Mhinduro yaJehovha 
\q1  
\v 18 Ipapo Jehovha achava negodo pamusoro penyika yake, 
\q2 uye achanzwira vanhu vake tsitsi. 
\p  
\v 19 Jehovha achavapindura achiti, 
\q2 “Ndava kukutumirai zviyo, waini itsva namafuta, 
\q1 zvakawanda zvokuti muchaguta kwazvo, 
\q2 handichazokuitai zvakare chiseko chendudzi. 
\b  
\q1  
\v 20 “Ndichadzingira kure nemi hondo yokumusoro, 
\q2 ndichaidzingira kunyika yakaoma isina chibereko, 
\q1 dziya dziri mberi dzichawira mugungwa rokumabvazuva, 
\q2 uye dziya dziri shure dzichawira mugungwa rokumadokero. 
\q1 Uye kunhuhwa kwadzo kuchakwira; 
\q2 kunhuhwa kwadzo kukuru kuchakwira.” 
\b  
\q1 Zvirokwazvo akaita zvinhu zvikuru. 
\q2  
\v 21 Usatya iwe nyika; 
\q2 fara zvako upembere. 
\q1 Zvirokwazvo Jehovha aita zvinhu zvikuru. 
\q2  
\v 22 Musatya, imi mhuka dzesango, 
\q2 nokuti mafuro ava kusvibira. 
\q1 Miti yava kubereka michero yayo; mionde nemizambiringa zvichabereka kwazvo. 
\q1  
\v 23 Farai imi vanhu veZioni, 
\q2 farai muna Jehovha Mwari wenyu, 
\q1 nokuti akakupai mvura yokupedzisira mukururama. 
\q2 Anokupai mvura yakawanda, 
\q2 yokupedzisira neyebumharutsva sakare. 
\q1  
\v 24 Mapuriro enyu achazara nezviyo, 
\q2 uye zvisviniro zvenyu zvichazara newaini itsva namafuta. 
\b  
\q1  
\v 25 “Ndichakuripirai makore ose amakadyirwa nemhashu: 
\q2 mhashu dzemagutaguta nedzegwatakwata, 
\q2 dzimwe mhashu nefararira remhashu; 
\q1 hondo yangu huru yandinotuma pakati penyu. 
\q1  
\v 26 Muchava nezvokudya zvakawanda kusvikira maguta, 
\q2 ipapo mucharumbidza zita raJehovha Mwari wenyu, 
\q2 uyo akakuitirai zvishamiso; 
\q1 vanhu vangu havachazonyadziswi zvakare. 
\q1  
\v 27 Ipapo muchazoziva kuti ndirimo muIsraeri, 
\q2 uye kuti ndini Jehovha Mwari wenyu, 
\q2 uyewo kuti hakuna mumwe; 
\q1 vanhu vangu havachazonyadziswi zvakare. 
\s1 Zuva raJehovha 
\q1  
\v 28 “Uye mushure maizvozvo, 
\q2 ndichadururira Mweya wangu pamusoro pavanhu vose. 
\q1 Vanakomana navanasikana venyu vachaprofita, 
\q2 vatana venyu vacharota hope, 
\q2 majaya enyu achaona zviratidzo. 
\q1  
\v 29 Kunyange pamusoro pavaranda vangu, zvose varume navakadzi, 
\q2 ndichadururira Mweya wangu mumazuva iwayo. 
\q1  
\v 30 Ndicharatidza zvishamiso kudenga 
\q2 napanyika, 
\q2 ropa nomoto neshongwe dzoutsi. 
\q1  
\v 31 Zuva richashanduka rigova rima, 
\q2 uye mwedzi uchava ropa, 
\q2 zuva guru raJehovha rinotyisa risati rasvika. 
\q1  
\v 32 Uye ani naani anodana 
\q2 kuzita raJehovha achaponeswa; 
\q1 nokuti paGomo reZioni nomuJerusarema 
\q2 muchava noruponeso, 
\q2 sezvakataurwa naJehovha, 
\q1 pakati pavanopunyuka, 
\q2 avo vachadanwa naJehovha. 
\c 3  
\s1 Kutongwa kweNdudzi 
\q1  
\v 1 “Mumazuva iwayo, napanguva iyoyo, 
\q2 kana ndichinge ndadzosa pfuma yeJudha neyeJerusarema, 
\q1  
\v 2 ndichaunganidza ndudzi dzose 
\q2 ndigoenda nadzo kuMupata waJehoshafati. 
\q1 Ipapo ndichavatonga 
\q2 nokuda kwenhaka yangu, vanhu vangu vaIsraeri, 
\q1 nokuti vakaparadzira vanhu vangu pakati pendudzi, 
\q2 uye vakagovana nyika yangu. 
\q1  
\v 3 Vakakanda mijenya pamusoro pavanhu vangu, 
\q2 vakatsinhanisa vakomana nezvifeve; 
\q1 vakatengesa vanasikana kuti vagotenga waini 
\q2 yokuti vanwe. 
\p  
\v 4 “Zvino ndakakutadzirai chiiko, imi Tire neSidhoni, nemi matunhu ose eFiristia? Muri kundiripira chimwe chinhu chandakaita here? Zvino kana muchindiripira, ini ndichadzosera zvamakaita pamisoro yenyu chaiyo nokukurumidza chaizvo.  
\v 5 Nokuti makatora sirivha negoridhe rangu, mukatakurawo midziyo yangu yakanakisisa mukandoiisa kutemberi dzenyu.  
\v 6 Makatengesa vanhu veJudha neveJerusarema kuvaGiriki kuti muvaendese kure. 
\p  
\v 7 “Tarirai, ini ndichavamutsa kubva kunzvimbo dzamakavatengesera, uye ndichadzosera pamisoro yenyu chaiyo zvamakaita.  
\v 8 Ndichatengesa vanakomana navanasikana venyu kuvanhu veJudha, uye vachavatengesa kuvaShebha, rudzi rwuri kure.” Jehovha ataura. 
\q1  
\v 9 Paridzirai izvi kundudzi dzose: 
\q2 Gadzirirai hondo! 
\q1 Mutsai varwi! 
\q2 Varwi vose ngavaswedere pedyo varwise. 
\q1  
\v 10 Pfurai mapadza enyu muaite minondo, 
\q2 uye mapanga okuchekerera miti muaite mapfumo. 
\q1 Asina simba ngaati, “Ndine simba!” 
\q1  
\v 11 Uyai nokukurumidza, imi ndudzi dzose, kubva kumativi ose 
\q2 mugoungana ipapo. 
\b  
\q1 Haiwa Jehovha, burutsai varwi venyu. 
\b  
\q1  
\v 12 “Ndudzi dzose ngadzimutswe; 
\q2 ngadziende kuMupata waJehoshafati, 
\q1 nokuti ipapo ndipo pandichagara pasi 
\q2 kuti nditonge ndudzi dzose kumativi ose enyika. 
\q1  
\v 13 Shandisai jeko, 
\q2 nokuti gohwo raibva. 
\q1 Uyai musvine mazambiringa netsoka dzenyu, 
\q2 nokuti chisviniro chazara, 
\q2 uye zvirongo zvopfachukira, 
\q1 uku ndiko kukura kwakaita kuipa kwavo.” 
\b  
\q1  
\v 14 Vazhinji zhinji, vazhinji zhinji, 
\q2 vari mumupata wokutonga. 
\q1 Nokuti zuva raJehovha rava pedyo 
\q2 mumupata wokutonga. 
\q1  
\v 15 Zuva nomwedzi zvichasviba 
\q2 uye nyeredzi dzichadzima. 
\q1  
\v 16 Jehovha achaomba paZioni, 
\q2 uye achatinhira ari muJerusarema; 
\q2 denga nenyika zvichadedera. 
\q1 Asi Jehovha achava utiziro hwavanhu vake, 
\q2 nhare yavanhu veIsraeri. 
\s1 Maropafadzo aVanhu vaMwari 
\q1  
\v 17 “Ipapo muchaziva kuti ini Jehovha Mwari wenyu, 
\q2 ndinogara muZioni, gomo rangu dzvene. 
\q1 Jerusarema richava dzvene; 
\q2 vatorwa havachazorirwisazve. 
\b  
\q1  
\v 18 “Pazuva iroro makomo achachururuka waini itsva, 
\q2 uye zvikomo zvichaerera mukaka; 
\q2 hova dzose dzomuJudha dzichaerera mvura. 
\q1 Chitubu chichaerera chichibva muimba yaJehovha, 
\q2 uye chichadiridzira mupata wemiti yemiunga. 
\q1  
\v 19 Asi Ijipiti ichava dongo, 
\q2 Edhomu ichava gwenga risina basa, 
\q1 nokuda kwokurwiswa kwakaitwa vanhu veJudha, 
\q2 vakateura ropa risina mhosva munyika yavo. 
\q1  
\v 20 MuJudha muchagara vanhu nokusingaperi, 
\q2 uye nomuJerusarema kusvikira kuzvizvarwa zvose. 
\q1  
\v 21 Mhosva yavo yeropa yandisina kuregerera, 
\q2 ndichairegerera, 
\qc nokuti Jehovha anogara muZioni.”