\id OBA - Biblica® Open Kurdi Sorani Standard Version 
\h عۆبەدیا 
\toc1 عۆبەدیا 
\toc2 عۆبەدیا 
\toc3 عۆبەدیا 
\mt1 عۆبەدیا 
\c 1  
\s1 بینینەکەی عۆبەدیا 
\p  
\v 1 بینینەکەی عۆبەدیا. 
\b  
\p یەزدانی باڵادەست سەبارەت بە ئەدۆم ئەمە دەفەرموێت، 
\q1 هەواڵێکمان لەلایەن یەزدانەوە بیست، 
\q2 نێردراوێک بۆ نەتەوەکان نێردراوە تاکو پێیان بڵێت: 
\q1 «هەستن! هەستن بۆ جەنگ.» 
\b  
\q1  
\v 2 «ئێستا لەنێو گەلاندا بچووکت دەکەمەوە، 
\q2 تۆ زۆر ڕیسوا دەبیت. 
\q1  
\v 3 فیزی دڵت هەڵیخەڵەتاندی، 
\q2 ئەی نیشتەجێی نێو کەلێنی تاشەبەرد\f + \fr 1:3 \ft پایتەختی ئەدۆم ناوی سەلەع بوو، کە هەمان وشەی عیبرییە بۆ تاشەبەرد.‏\f*، 
\q2 ئەوەی نشینگەکەت لە بەرزاییدایە، 
\q1 ئەوەی لە دڵی خۆتدا دەڵێیت: 
\q2 ”کێ دامدەگرێتە سەر زەوی؟“ 
\q1  
\v 4 ئەگەر وەک هەڵۆ بەرز بیتەوە و 
\q2 ئەگەر هێلانەت لەناو ئەستێرەکان دابنێیت، 
\q2 لەوێوە دەتهێنمە خوارەوە.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\q1  
\v 5 «ئەگەر دز یان چەتەی شەوانت بۆ بێت، 
\q1 ئایا تەنها ئەوەی پێویستیان بێت نایدزن؟ 
\q2 ئەگەر ڕەزبڕت\f + \fr 1:5 \ft ڕەزبڕ: ئەوەی بەرهەمی ڕەزی دەبڕێتەوە.‏\f* بۆ بێت 
\q1 ئایا هەندێک ترێ بەجێناهێڵن؟ 
\q2 ئای چۆن بە تەواوی بڕایتەوە! 
\q1  
\v 6 ئای عیسۆ چۆن دەپشکێنرێت! 
\q2 گەنجینە شاردراوەکانی تاڵان دەکرێن! 
\q1  
\v 7 هەموو هاوپەیمانەکانت هەتا سنوور ڕاویان نای، 
\q2 هەڵیانخەڵەتاندی و بەسەرتدا زاڵبوون، 
\q1 ئەوانەی نمەکی تۆیان کردبوو داوت بۆ دەنێنەوە، 
\q2 بەڵام تۆ تێناگەیت.» 
\b  
\q1  
\v 8 یەزدان دەفەرموێت: 
\q2 «ئایا لەو ڕۆژەدا، 
\q1 دانایان لە ئەدۆم لەناو نابەم، 
\q2 تێگەیشتووانیش لە چیای عیسۆ؟ 
\q1  
\v 9 ئەی تێمان، پاڵەوانەکانت دەتۆقن، 
\q2 هەموو ئەوانەی لە چیای عیسۆن 
\q2 بە کوشتن لەناودەچن. 
\q1  
\v 10 لەبەر ستەمی تۆ لە یاقوبی برات، 
\q2 ڕیسوایی داتدەپۆشێت، 
\q2 بۆ هەتاهەتایە لەناودەچیت. 
\q1  
\v 11 ئەو ڕۆژەی تەماشات دەکرد 
\q2 کاتێک بیانییەکان سامانەکەیان داگیر کرد و 
\q1 نامۆکان هاتنە ناو دەروازەکانی و 
\q2 لەسەر ئۆرشەلیم تیروپشکیان کرد، 
\q2 هەروەها تۆش وەک یەکێک بووی لەوان. 
\q1  
\v 12 بەڵام نابێت بە ڕۆژی کارەساتی براکەت دڵخۆش بیت، 
\q2 یان لە ڕۆژی لەناوچوونی نەوەی یەهودا شادمان بیت، 
\q1 یان لە ڕۆژی تەنگانەیاندا شانازی بکەیت. 
\q1  
\v 13 نابێت بچیتە ناو دەروازەی گەلەکەم 
\q2 لە ڕۆژی کارەساتیان، 
\q1 یان بە ناخۆشییەکەیان دڵخۆش بیت 
\q2 لە ڕۆژی کارەساتیان، 
\q1 یان دەستت بۆ سامانەکەیان درێژ بکەیت 
\q2 لە ڕۆژی کارەساتیان. 
\q1  
\v 14 نابێت لەسەر دووڕیانەکان بوەستیت 
\q2 بۆ کوشتنی دەربازبووەکانیان، 
\q1 نابێت هەڵاتووەکانیان ڕادەست بکەیت 
\q2 لە ڕۆژی تەنگانەیاندا. 
\b  
\q1  
\v 15 «ڕۆژی یەزدان\f + \fr 1:15 \ft ڕۆژی سزادانی گوناهباران و ڕزگارکردنی گەلی خودا.‏\f* بۆ هەموو گەلان نزیکە. 
\q2 هەروەک ئەوەی کردت ئاوات پێ دەکرێتەوە، 
\q2 کردەوەکانت بەسەر خۆت دێتەوە. 
\q1  
\v 16 هەروەک لەسەر کێوی پیرۆزم خواردتانەوە، 
\q1 هەموو گەلان بەردەوام جامی سزا دەخۆنەوە؛ 
\q1 دەخۆنەوە و دەخۆنەوە و 
\q1 وەک ئەوەیان لێدێت کە هەرگیز نەبووبن. 
\q1  
\v 17 بەڵام دەربازبوون لەسەر کێوی سییۆن دەبێت، 
\q2 پیرۆز دەبێت، 
\q2 بنەماڵەی یاقوبیش بەشە میراتی خۆیان وەردەگرن. 
\q1  
\v 18 بنەماڵەی یاقوب دەبێتە ئاگر و 
\q2 بنەماڵەی یوسف دەبێتە گڕ؛ 
\q1 بنەماڵەی عیسۆش دەبێتە پووش، 
\q2 جا گڕیان تێبەردەدەن و دەیانخۆن. 
\q2 بنەماڵەی عیسۆ کەسیان لێ دەرباز نابێت.» 
\q4 ئەمە فەرمایشتی یەزدانە. 
\b  
\q1  
\v 19 خەڵکی نەقەب 
\q2 چیای عیسۆ داگیر دەکەن، 
\q1 خەڵکی زوورگەکانیش 
\q2 خاکی فەلەستییەکان. 
\q1 دەبنە خاوەنی کێڵگەکانی ئەفرایم و سامیرە، 
\q2 بنیامینیش دەبێتە خاوەنی گلعاد. 
\q1  
\v 20 ئەو کۆمەڵەی ڕاپێچکراوانی ئیسرائیل کە لە کەنعانن 
\q2 هەتا سەرەفەند دەست بەسەر خاکەکەدا دەگرن؛ 
\q1 ڕاپێچکراوانی ئۆرشەلیمیش کە لە سفارەدن 
\q2 دەست بەسەر شارۆچکەکانی نەقەبدا دەگرن. 
\q1  
\v 21 ڕزگارکەرانی خاکەکەش سەردەکەونە سەر کێوی سییۆن 
\q2 بۆ فەرمانڕەوایەتی لەسەر چیای عیسۆ. 
\q2 پاشایەتیش بۆ یەزدان دەبێت.