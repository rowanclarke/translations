\v 55 \w and|strong="H1004"\w* \w the|strong="H3427"\w* \w families|strong="H4940"\w* \w of|strong="H1004"\w* \w scribes|strong="H5608"\w* \w who|strong="H3427"\w* \w lived|strong="H3427"\w* \w at|strong="H3427"\w* \w Jabez|strong="H3258"\w*: \w the|strong="H3427"\w* \w Tirathites|strong="H8654"\w*, \w Shimeathites|strong="H8101"\w*, \w and|strong="H1004"\w* \w Sucathites|strong="H7756"\w*. \w These|strong="H1992"\w* \w are|strong="H1992"\w* \w the|strong="H3427"\w* \w Kenites|strong="H7017"\w* \w who|strong="H3427"\w* descended \w from|strong="H1004"\w* \w Hammath|strong="H2575"\w*, \w the|strong="H3427"\w* father \w of|strong="H1004"\w* \w the|strong="H3427"\w* \w house|strong="H1004"\w* \w of|strong="H1004"\w* \w Recab|strong="H7394"\w*.
\b
\c 3
\p 
\v 1 \w These|strong="H1732"\w* \w were|strong="H1961"\w* \w the|strong="H3205"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w David|strong="H1732"\w* \w born|strong="H3205"\w* \w to|strong="H1961"\w* \w him|strong="H3205"\w* \w in|strong="H1121"\w* \w Hebron|strong="H2275"\w*: \w The|strong="H3205"\w* \w firstborn|strong="H1060"\w* \w was|strong="H1961"\w* Amnon, \w whose|strong="H1121"\w* mother \w was|strong="H1961"\w* Ahinoam \w of|strong="H1121"\w* Jezreel. \w The|strong="H3205"\w* \w second|strong="H8145"\w* \w was|strong="H1961"\w* \w Daniel|strong="H1840"\w*, \w whose|strong="H1121"\w* mother \w was|strong="H1961"\w* Abigail \w of|strong="H1121"\w* Carmel.
\v 2 \w The|strong="H1121"\w* \w third|strong="H7992"\w* \w was|strong="H4428"\w* Absalom, \w whose|strong="H1121"\w* mother \w was|strong="H4428"\w* \w Maacah|strong="H4601"\w*, \w the|strong="H1121"\w* \w daughter|strong="H1323"\w* \w of|strong="H1121"\w* \w Talmai|strong="H8526"\w*, \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Geshur|strong="H1650"\w*. \w The|strong="H1121"\w* \w fourth|strong="H7243"\w* \w was|strong="H4428"\w* Adonijah, \w whose|strong="H1121"\w* mother \w was|strong="H4428"\w* \w Haggith|strong="H2294"\w*.
\v 3 \w The|strong="H8203"\w* \w fifth|strong="H2549"\w* was \w Shephatiah|strong="H8203"\w*, whose mother was Abital. \w The|strong="H8203"\w* \w sixth|strong="H8345"\w* was \w Ithream|strong="H3507"\w*, whose mother was \w his|strong="H5698"\w* wife \w Eglah|strong="H5698"\w*.
\p 
\v 4 These \w were|strong="H3205"\w* \w the|strong="H3205"\w* \w six|strong="H8337"\w* \w sons|strong="H3205"\w* \w born|strong="H3205"\w* \w to|strong="H3389"\w* David \w in|strong="H8141"\w* \w Hebron|strong="H2275"\w*, \w where|strong="H8033"\w* \w he|strong="H8033"\w* \w reigned|strong="H4427"\w* \w seven|strong="H7651"\w* \w years|strong="H8141"\w* \w and|strong="H7970"\w* \w six|strong="H8337"\w* \w months|strong="H2320"\w*. David \w reigned|strong="H4427"\w* \w in|strong="H8141"\w* \w Jerusalem|strong="H3389"\w* \w thirty-three|strong="H7970"\w* \w more|strong="H3205"\w* \w years|strong="H8141"\w*,
\v 5 \w and|strong="H3389"\w* these \w were|strong="H1323"\w* \w the|strong="H3205"\w* \w children|strong="H3205"\w* \w born|strong="H3205"\w* \w to|strong="H3389"\w* \w him|strong="H3205"\w* there:
\p Shammua,\f + \fr 3:5 \ft Actually Shimea, a different spelling of Shammu.\f* \w Shobab|strong="H7727"\w*, \w Nathan|strong="H5416"\w*, \w and|strong="H3389"\w* \w Solomon|strong="H8010"\w*. Their mother \w was|strong="H3389"\w* Bathsheba,\f + \fr 3:5 \ft Actually Bathshua, a different spelling of Bathsheba.\f* \w daughter|strong="H1323"\w* \w of|strong="H1323"\w* \w Ammiel|strong="H5988"\w*.
\v 6 In addition there were also \w Ibhar|strong="H2984"\w*, Elishua,\f + \fr 3:6 \ft Actually Elishama, a different spelling of Elishua.\f* Eliphelet,
\v 7 \w Nogah|strong="H5052"\w*, \w Nepheg|strong="H5298"\w*, \w Japhia|strong="H3309"\w*,
\v 8 Elishama, Eliada, \w and|strong="H8672"\w* Eliphelet, \w a|strong="H3068"\w* total \w of|strong="H8672"\w* \w nine|strong="H8672"\w*.
\v 9 \w These|strong="H3605"\w* \w were|strong="H1121"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w David|strong="H1732"\w*, apart \w from|strong="H1121"\w* \w his|strong="H3605"\w* \w sons|strong="H1121"\w* \w by|strong="H3605"\w* \w his|strong="H3605"\w* \w concubines|strong="H6370"\w*. \w Their|strong="H3605"\w* sister \w was|strong="H1732"\w* \w Tamar|strong="H8559"\w*.
\p 
