\v 36 Algunas clases \w de|strong="H4480"\w* \w levitas|strong="H3881"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w* estaban \w en|strong="H4480"\w* \w Benjamín|strong="H1144"\w*.
\c 12
\s1 Nuevo recuento de sacerdotes y levitas
\p 
\v 1 Estos son \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* y \w levitas|strong="H3881"\w* \w que|strong="H1121"\w* \w subieron|strong="H5927"\w* \w con|strong="H5973"\w* \w Zorobabel|strong="H2216"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Salatiel, y \w Jesuá|strong="H3442"\w*: \w Seraías|strong="H8304"\w*, \w Jeremías|strong="H3414"\w*, \w Esdras|strong="H5830"\w*,
\v 2 Amarías, Maluc, \w Hartús|strong="H2407"\w*,
\v 3 Secanías, \w Rehum|strong="H7348"\w*, Meremot,
\v 4 \w Iddo|strong="H5714"\w*, Gineto, Abías,
\v 5 Mijamín, \w Maadías|strong="H4573"\w*, \w Bilga|strong="H1083"\w*,
\v 6 \w Semaías|strong="H8098"\w*, Joyarib, \w Jedaías|strong="H3048"\w*,
\v 7 \w Salú|strong="H5543"\w*, \w Amoc|strong="H5987"\w*, \w Hilcías|strong="H2518"\w* y \w Jedaías|strong="H3048"\w*. Esos fueron los \w jefes|strong="H7218"\w* de los \w sacerdotes|strong="H3548"\w* y sus hermanos en \w días|strong="H3117"\w* de \w Jesuá|strong="H3442"\w*.
\p 
\v 8 \w Los|strong="H5921"\w* \w levitas|strong="H3881"\w* eran \w Jesuá|strong="H3442"\w*, Binúi, \w Cadmiel|strong="H6934"\w*, \w Serebías|strong="H8274"\w*, \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* Matanías, \w quien|strong="H1931"\w*, \w con|strong="H5921"\w* \w sus|strong="H1931"\w* hermanos, dirigía \w los|strong="H5921"\w* cánticos \w de|strong="H5921"\w* alabanza.
\v 9 Bacbuquías y Uni, sus hermanos, estaban \w frente|strong="H5048"\w* \w a|strong="H3068"\w* ellos en el servicio.
\p 
\v 10 \w Jesuá|strong="H3442"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Joyaquim, quien \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Eliasib. Éste \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Joiada,
\v 11 quien \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Jonatán, y él \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Jadúa|strong="H3037"\w*.
\p 
\v 12 En \w los|strong="H1961"\w* \w días|strong="H3117"\w* de Joyaquim, \w los|strong="H1961"\w* \w sacerdotes|strong="H3548"\w* \w jefes|strong="H7218"\w* de casas paternas \w eran|strong="H1961"\w*: de \w Seraías|strong="H8304"\w*, \w Meraías|strong="H4811"\w*; de \w Jeremías|strong="H3414"\w*, \w Hananías|strong="H2608"\w*;
\v 13 de \w Esdras|strong="H5830"\w*, Mesulam; de Amarías, \w Johanán|strong="H3076"\w*;
\v 14 de Melicú, Jonatán; de \w Sebanías|strong="H7645"\w*, \w José|strong="H3130"\w*;
\v 15 de \w Harim|strong="H2766"\w*, \w Adna|strong="H5733"\w*; de Meraiot, Helcay;
\v 16 de \w Iddo|strong="H5714"\w*, \w Zacarías|strong="H2148"\w*; de Ginetón, Mesulam;
\v 17 de Abías, Zicri; de \w Miniamín|strong="H4509"\w*, de Moadías, Piltay;
\v 18 de \w Bilga|strong="H1083"\w*, \w Samúa|strong="H8051"\w*; de \w Semaías|strong="H8098"\w*, Jonatán;
\v 19 de Joyarib, Matenay; de \w Jedaías|strong="H3048"\w*, Uzi;
\v 20 de Salay, Calay; de \w Amoc|strong="H5987"\w*, \w Eber|strong="H5677"\w*;
\v 21 de \w Hilcías|strong="H2518"\w*, \w Hasabías|strong="H2811"\w*; de \w Jedaías|strong="H3048"\w*, Natanael.
\p 
\v 22 \w En|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* Eliasib, Joiada, \w Johanán|strong="H3110"\w* \w y|strong="H5921"\w* \w Jadúa|strong="H3037"\w*, \w los|strong="H5921"\w* \w levitas|strong="H3881"\w* fueron contados \w por|strong="H5921"\w* sus casas paternas, así \w como|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w*, \w hasta|strong="H5921"\w* \w el|strong="H5921"\w* \w reinado|strong="H4438"\w* \w de|strong="H5921"\w* \w Darío|strong="H1867"\w* \w el|strong="H5921"\w* persa.
\v 23 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Leví|strong="H3878"\w*, \w jefes|strong="H7218"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* casas paternas, fueron anotados \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H5921"\w* Crónicas \w hasta|strong="H5704"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w Johanán|strong="H3110"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Eliasib.
\v 24 \w Los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H5048"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*: \w Hasabías|strong="H2811"\w*, \w Serebías|strong="H8274"\w* y \w Jesuá|strong="H3442"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* \w Cadmiel|strong="H6934"\w*, con sus hermanos al \w frente|strong="H5048"\w* \w de|strong="H5048"\w* ellos, \w fueron|strong="H1732"\w* designados \w por|strong="H3881"\w* turnos alternos para \w alabar|strong="H1984"\w* y tributar acciones \w de|strong="H5048"\w* gracias, conforme al mandato \w de|strong="H5048"\w* \w David|strong="H1732"\w*, varón \w de|strong="H5048"\w* \nd ʼElohim\nd*.
\p 
\v 25 Matanías, Bacbuquías, \w Obadías|strong="H5662"\w*, Mesulam, \w Talmón|strong="H2929"\w*, Acub, \w porteros|strong="H7778"\w*, montaban guardia en los almacenes junto \w a|strong="H3068"\w* las \w puertas|strong="H8179"\w*.
\v 26 Estos estaban en \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H1121"\w* Joyaquim, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jesuá|strong="H3442"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Josadac, y en \w los|strong="H1121"\w* \w días|strong="H3117"\w* del \w gobernador|strong="H6346"\w* \w Nehemías|strong="H5166"\w* y del \w sacerdote|strong="H3548"\w* y \w escriba|strong="H5608"\w* \w Esdras|strong="H5830"\w*.
\s1 Dedicación del muro
\p 
\v 27 Para \w la|strong="H3605"\w* dedicación del \w muro|strong="H2346"\w* \w de|strong="H5035"\w* Jerusalén \w buscaron|strong="H1245"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* \w de|strong="H5035"\w* \w todas|strong="H3605"\w* partes para llevarlos \w a|strong="H3068"\w* Jerusalén, \w a|strong="H3068"\w* fin \w de|strong="H5035"\w* \w celebrar|strong="H6213"\w* \w la|strong="H3605"\w* dedicación y \w la|strong="H3605"\w* fiesta con cánticos y acciones \w de|strong="H5035"\w* gracias, con \w címbalos|strong="H4700"\w*, \w salterios|strong="H5035"\w* y \w arpas|strong="H3658"\w*.
\v 28 Así fueron reunidos \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w cantores|strong="H7891"\w*, tanto \w del|strong="H4480"\w* valle \w que|strong="H4480"\w* circunda \w a|strong="H3068"\w* Jerusalén como \w de|strong="H4480"\w* las \w aldeas|strong="H2691"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w de|strong="H4480"\w* Netofa,
\v 29 \w y|strong="H3588"\w* Bet-gilgal \w y|strong="H3588"\w* \w los|strong="H1992"\w* \w campos|strong="H7704"\w* \w de|strong="H3588"\w* Geba \w y|strong="H3588"\w* Azmavet, \w porque|strong="H3588"\w* \w los|strong="H1992"\w* \w cantores|strong="H7891"\w* \w se|strong="H1992"\w* \w edificaron|strong="H1129"\w* \w aldeas|strong="H2691"\w* \w alrededor|strong="H5439"\w* \w de|strong="H3588"\w* Jerusalén.
\v 30 \w Se|strong="H5971"\w* purificaron los \w sacerdotes|strong="H3548"\w* y los \w levitas|strong="H3881"\w*. También purificaron al \w pueblo|strong="H5971"\w*, las \w puertas|strong="H8179"\w* y el \w muro|strong="H2346"\w*.
\p 
\v 31 Entonces ordené \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w que|strong="H5921"\w* subieran \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w*. Establecí \w dos|strong="H8147"\w* \w grandes|strong="H1419"\w* \w coros|strong="H8426"\w* \w que|strong="H5921"\w* elevaban \w alabanzas|strong="H8426"\w* \w y|strong="H5921"\w* acciones \w de|strong="H5921"\w* gracias. \w El|strong="H5921"\w* primero marchaba \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w* \w del|strong="H5921"\w* \w muro|strong="H2346"\w*, \w hacia|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w del|strong="H5921"\w* Muladar,
\v 32 y tras ellos \w iba|strong="H3212"\w* Osaías, la mitad \w de|strong="H8269"\w* los \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* \w Judá|strong="H3063"\w*,
\v 33 \w Azarías|strong="H5838"\w*, \w Esdras|strong="H5830"\w*, Mesulam,
\v 34 \w Judá|strong="H3063"\w*, \w Benjamín|strong="H1144"\w*, \w Semaías|strong="H8098"\w* y \w Jeremías|strong="H3414"\w*.
\p 
\v 35 Algunos \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* marchaban con \w trompetas|strong="H2689"\w*: \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jonatán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Semaías|strong="H8098"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Matanías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Micaías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Zacur, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Asaf,
\v 36 y sus hermanos \w Semaías|strong="H8098"\w*, Azarael, Milalay, Gilalay, Maay, Natanael, \w Judá|strong="H3063"\w*, \w Hanani|strong="H2607"\w*, con los \w instrumentos|strong="H3627"\w* musicales \w de|strong="H6440"\w* \w David|strong="H1732"\w*, varón \w de|strong="H6440"\w* \nd ʼElohim\nd*.
\p El \w escriba|strong="H5608"\w* \w Esdras|strong="H5830"\w* marchaba al frente \w de|strong="H6440"\w* ellos.
\p 
\v 37 \w Las|strong="H5921"\w* \w gradas|strong="H4609"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w subieron|strong="H5927"\w* directamente \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Fuente|strong="H5869"\w*, \w por|strong="H5921"\w* \w la|strong="H5921"\w* subida \w al|strong="H5921"\w* \w muro|strong="H2346"\w* \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*, \w hacia|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w del|strong="H5921"\w* \w Agua|strong="H4325"\w*, \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w oriente|strong="H4217"\w*.
\p 
\v 38 \w El|strong="H5921"\w* \w segundo|strong="H8145"\w* \w coro|strong="H8426"\w* \w que|strong="H5921"\w* elevaba \w alabanzas|strong="H8426"\w* \w y|strong="H5921"\w* acciones \w de|strong="H5921"\w* gracias marchaba \w en|strong="H5921"\w* sentido contrario. Yo \w iba|strong="H1980"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* mitad \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w* \w desde|strong="H5704"\w* \w la|strong="H5921"\w* \w torre|strong="H4026"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* Hornos \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w* \w ancho|strong="H7342"\w*,
\v 39 \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w de|strong="H5921"\w* Efraín, \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* Antigua, \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w del|strong="H5921"\w* \w Pescado|strong="H1709"\w*, \w la|strong="H5921"\w* \w torre|strong="H4026"\w* \w de|strong="H5921"\w* Hananel \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w torre|strong="H4026"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* Cien \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w Ovejas|strong="H6629"\w* \w y|strong="H5921"\w* \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* Guardia.
\p 
\v 40 Entonces \w los|strong="H5973"\w* \w dos|strong="H8147"\w* \w coros|strong="H8426"\w* que elevaban \w alabanzas|strong="H8426"\w* y acciones \w de|strong="H5973"\w* gracias se detuvieron \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w Templo|strong="H1004"\w* \w de|strong="H5973"\w* \nd ʼElohim\nd*, también yo y la mitad \w de|strong="H5973"\w* \w los|strong="H5973"\w* dirigentes \w conmigo|strong="H5973"\w*.
\v 41 Los \w sacerdotes|strong="H3548"\w* Elyaquim, \w Maaseías|strong="H4641"\w*, \w Miniamín|strong="H4509"\w*, Micaías, Elioenay, \w Zacarías|strong="H2148"\w* y \w Hananías|strong="H2608"\w* tenían las \w trompetas|strong="H2689"\w*,
\v 42 y \w Maasías|strong="H4641"\w*, \w Semaías|strong="H8098"\w*, Eliazar, Uzi, \w Johanán|strong="H3076"\w*, Malquías, \w Elam|strong="H5867"\w* \w Ezer|strong="H5829"\w* y los \w cantores|strong="H7891"\w* \w cantaban|strong="H7891"\w* \w a|strong="H3068"\w* viva voz dirigidos por Izrahías.
\p 
\v 43 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* inmolaron \w grandes|strong="H1419"\w* \w sacrificios|strong="H2077"\w* \w y|strong="H1571"\w* \w se|strong="H1931"\w* alegraron \w porque|strong="H3588"\w* \nd ʼElohim\nd* \w los|strong="H1931"\w* deleitó \w con|strong="H3588"\w* \w gran|strong="H1419"\w* regocijo, del \w que|strong="H3588"\w* participaban \w también|strong="H1571"\w* las mujeres \w y|strong="H1571"\w* \w los|strong="H1931"\w* \w niños|strong="H3206"\w*. \w La|strong="H1931"\w* \w alegría|strong="H8057"\w* \w de|strong="H3588"\w* Jerusalén \w se|strong="H1931"\w* \w oía|strong="H8085"\w* desde \w lejos|strong="H7350"\w*.
\s1 Reorganización del servicio
\p 
\v 44 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* algunos fueron designados \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w se|strong="H1931"\w* encargaran \w de|strong="H5921"\w* \w los|strong="H5921"\w* almacenes \w para|strong="H5921"\w* \w las|strong="H5921"\w* \w ofrendas|strong="H8641"\w*, \w las|strong="H5921"\w* \w primicias|strong="H7225"\w* \w y|strong="H3588"\w* \w los|strong="H5921"\w* diezmos, \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* recoger \w en|strong="H5921"\w* \w ellos|strong="H1931"\w* \w los|strong="H5921"\w* productos \w del|strong="H5921"\w* \w campo|strong="H7704"\w* \w y|strong="H3588"\w* \w las|strong="H5921"\w* porciones legales \w que|strong="H3588"\w* correspondían \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H3588"\w* \w levitas|strong="H3881"\w*. \w Judá|strong="H3063"\w* \w se|strong="H1931"\w* alegraba \w de|strong="H5921"\w* contemplar \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H3588"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w* \w en|strong="H5921"\w* \w su|strong="H1931"\w* servicio.
\p 
\v 45 Éstos \w guardaban|strong="H8104"\w* \w el|strong="H1121"\w* precepto \w de|strong="H1121"\w* su \nd ʼElohim\nd* y observaban las purificaciones. También \w los|strong="H1121"\w* \w cantores|strong="H7891"\w* y \w porteros|strong="H7778"\w* cumplían lo establecido para ellos según \w los|strong="H1121"\w* mandatos \w de|strong="H1121"\w* \w David|strong="H1732"\w* y su \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w*,
\v 46 \w porque|strong="H3588"\w* desde \w los|strong="H3588"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* \w David|strong="H1732"\w* \w y|strong="H3588"\w* Asaf, desde \w tiempo|strong="H3117"\w* \w antiguo|strong="H6924"\w*, \w había|strong="H3588"\w* directores \w para|strong="H3588"\w* \w los|strong="H3588"\w* \w cantores|strong="H7891"\w*, \w los|strong="H3588"\w* cánticos \w de|strong="H3588"\w* \w alabanza|strong="H8416"\w* \w y|strong="H3588"\w* acción \w de|strong="H3588"\w* gracias \w a|strong="H3068"\w* \nd ʼElohim\nd*.
\p 
\v 47 En \w días|strong="H3117"\w* \w de|strong="H1121"\w* \w Zorobabel|strong="H2216"\w* y \w Nehemías|strong="H5166"\w*, \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w daba|strong="H5414"\w* porciones \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w cantores|strong="H7891"\w* y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w porteros|strong="H7778"\w*, como \w era|strong="H1121"\w* requerido \w día|strong="H3117"\w* \w a|strong="H3068"\w* \w día|strong="H3117"\w*. Quedó consagrado \w lo|strong="H1697"\w* prescrito \w para|strong="H5414"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*, así como \w para|strong="H5414"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón.
\c 13
\s1 Exclusión de extranjeros
\p 
\v 1 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w se|strong="H1931"\w* \w leyó|strong="H7121"\w* \w en|strong="H5704"\w* \w el|strong="H1931"\w* rollo \w de|strong="H5704"\w* \w Moisés|strong="H4872"\w* \w a|strong="H3068"\w* oídos del \w pueblo|strong="H5971"\w*. \w Se|strong="H1931"\w* encontró \w escrito|strong="H3789"\w* \w en|strong="H5704"\w* \w él|strong="H1931"\w* \w que|strong="H1931"\w* \w los|strong="H1931"\w* amonitas \w y|strong="H5704"\w* moabitas \w no|strong="H3808"\w* debían entrar \w jamás|strong="H5769"\w* \w en|strong="H5704"\w* \w la|strong="H1931"\w* \w congregación|strong="H6951"\w* \w de|strong="H5704"\w* \nd ʼElohim\nd*,
\v 2 \w porque|strong="H3588"\w* \w no|strong="H3808"\w* salieron \w a|strong="H3068"\w* recibir \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w con|strong="H5921"\w* \w pan|strong="H3899"\w* \w y|strong="H3588"\w* \w agua|strong="H4325"\w*, \w sino|strong="H3588"\w* alquilaron \w a|strong="H3068"\w* \w Balaam|strong="H1109"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w los|strong="H1121"\w* maldijera. \w Pero|strong="H3588"\w* nuestro \nd ʼElohim\nd* convirtió \w la|strong="H5921"\w* \w maldición|strong="H7045"\w* \w en|strong="H5921"\w* \w bendición|strong="H1293"\w*.
\v 3 Por tanto, al \w escuchar|strong="H8085"\w* \w la|strong="H3605"\w* \w Ley|strong="H8451"\w*, excluyeron de \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* extranjero.
\p 
\v 4 \w Antes|strong="H6440"\w* \w de|strong="H6440"\w* \w esto|strong="H2088"\w*, el \w sacerdote|strong="H3548"\w* Eliasib, encargado \w de|strong="H6440"\w* la \w cámara|strong="H3957"\w* del \w Templo|strong="H1004"\w* \w de|strong="H6440"\w* nuestro \nd ʼElohim\nd*, quien emparentó con \w Tobías|strong="H2900"\w*,
\v 5 le preparó una \w gran|strong="H1419"\w* \w cámara|strong="H3957"\w* \w donde|strong="H8033"\w* anteriormente \w se|strong="H1961"\w* depositaban las \w ofrendas|strong="H8641"\w* vegetales, \w el|strong="H6213"\w* \w incienso|strong="H3828"\w*, \w los|strong="H1961"\w* \w vasos|strong="H3627"\w*, \w los|strong="H1961"\w* diezmos del \w grano|strong="H1715"\w*, \w vino|strong="H1961"\w* nuevo y \w aceite|strong="H3323"\w* asignado \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w levitas|strong="H3881"\w*, \w cantores|strong="H7891"\w* y \w porteros|strong="H7778"\w*, y la \w ofrenda|strong="H4503"\w* \w para|strong="H5414"\w* \w los|strong="H1961"\w* \w sacerdotes|strong="H3548"\w*.
\s1 Segundo viaje de Nehemías
\p 
\v 6 \w Pero|strong="H3588"\w* durante \w todo|strong="H3605"\w* \w esto|strong="H2088"\w* \w yo|strong="H4480"\w* \w no|strong="H3808"\w* \w estaba|strong="H1961"\w* \w en|strong="H4480"\w* Jerusalén. \w El|strong="H3588"\w* \w año|strong="H8141"\w* 32 \w de|strong="H4480"\w* Artajerjes, \w rey|strong="H4428"\w* \w de|strong="H4480"\w* Babilonia, \w fui|strong="H1961"\w* ante \w el|strong="H3588"\w* \w rey|strong="H4428"\w*. \w Después|strong="H1961"\w* \w de|strong="H4480"\w* un \w tiempo|strong="H3117"\w* \w pedí|strong="H7592"\w* permiso \w al|strong="H4480"\w* \w rey|strong="H4428"\w*
\v 7 y regresé \w a|strong="H3068"\w* Jerusalén. Me percaté del \w mal|strong="H7451"\w* \w que|strong="H2691"\w* Eliasib \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* favor \w de|strong="H7451"\w* \w Tobías|strong="H2900"\w*, al prepararle una cámara en los \w patios|strong="H2691"\w* del \w Templo|strong="H1004"\w* \w de|strong="H7451"\w* \nd ʼElohim\nd*.
\v 8 \w Por|strong="H4480"\w* eso \w me|strong="H4480"\w* airé muchísimo. \w Eché|strong="H7993"\w* \w todas|strong="H3605"\w* las pertenencias \w de|strong="H4480"\w* \w Tobías|strong="H2900"\w* \w fuera|strong="H2351"\w* \w de|strong="H4480"\w* \w la|strong="H3605"\w* \w cámara|strong="H3957"\w*.
\v 9 Ordené que limpiaran las \w cámaras|strong="H3957"\w* y dispuse que restituyeran \w allí|strong="H8033"\w* los utensilios sagrados del \w Templo|strong="H1004"\w* de \nd ʼElohim\nd*, con las ofrendas vegetales y el \w incienso|strong="H3828"\w*.
\p 
\v 10 También \w supe|strong="H3045"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w levitas|strong="H3881"\w* \w no|strong="H3808"\w* les fueron \w dadas|strong="H5414"\w* sus porciones, \w de|strong="H3588"\w* manera \w que|strong="H3588"\w* \w los|strong="H3588"\w* \w levitas|strong="H3881"\w* \w y|strong="H3588"\w* \w los|strong="H3588"\w* \w cantores|strong="H7891"\w*, \w en|strong="H3588"\w* vez \w de|strong="H3588"\w* cumplir sus tareas, cada uno \w se|strong="H3045"\w* \w fue|strong="H3808"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w campo|strong="H7704"\w*.
\v 11 Entonces reprendí \w a|strong="H3068"\w* \w los|strong="H5921"\w* dirigentes: ¿\w Por|strong="H5921"\w* \w qué|strong="H5921"\w* \w está|strong="H5975"\w* abandonado \w el|strong="H5921"\w* \w Templo|strong="H1004"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd*? \w Los|strong="H5921"\w* reuní \w y|strong="H5921"\w* \w los|strong="H5921"\w* restablecí \w en|strong="H5921"\w* su puesto.
\p 
\v 12 \w Todo|strong="H3605"\w* \w Judá|strong="H3063"\w* llevó \w el|strong="H3605"\w* diezmo del \w grano|strong="H1715"\w*, del \w vino|strong="H8492"\w* nuevo y del \w aceite|strong="H3323"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* depósitos.
\v 13 Designé \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w* Selemías, \w al|strong="H5921"\w* \w escriba|strong="H5608"\w* \w Sadoc|strong="H6659"\w* \w y|strong="H3588"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w a|strong="H3068"\w* Pedaías \w como|strong="H3588"\w* encargado \w de|strong="H4480"\w* \w los|strong="H1121"\w* depósitos. \w Junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ellos|strong="H3027"\w* estaba \w Hanán|strong="H2605"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Zacur, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Matanías, \w porque|strong="H3588"\w* eran considerados fieles, \w y|strong="H3588"\w* \w les|strong="H5921"\w* correspondió repartir \w entre|strong="H5921"\w* sus hermanos.
\p 
\v 14 ¡\w Acuérdate|strong="H2142"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w por|strong="H5921"\w* \w esto|strong="H2063"\w*, oh \nd ʼElohim\nd* \w mío|strong="H5921"\w*, \w y|strong="H5921"\w* \w no|strong="H6213"\w* \w borres|strong="H4229"\w* mis obras leales \w que|strong="H5921"\w* \w hice|strong="H6213"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w Templo|strong="H1004"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \nd ʼElohim\nd* \w y|strong="H5921"\w* su servicio!
\p 
\v 15 \w En|strong="H5921"\w* esos \w días|strong="H3117"\w* \w vi|strong="H7200"\w* \w en|strong="H5921"\w* \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* \w unos|strong="H1992"\w* \w que|strong="H5921"\w* pisaban lagares \w en|strong="H5921"\w* \w sábado|strong="H7676"\w*, llevaban gavillas cargadas \w sobre|strong="H5921"\w* \w asnos|strong="H2543"\w*, \w y|strong="H5921"\w* también \w traían|strong="H5921"\w* \w a|strong="H3068"\w* Jerusalén \w vino|strong="H3196"\w*, \w uvas|strong="H6025"\w*, \w higos|strong="H8384"\w* \w y|strong="H5921"\w* \w toda|strong="H3605"\w* clase \w de|strong="H5921"\w* \w carga|strong="H4853"\w* \w en|strong="H5921"\w* \w sábado|strong="H7676"\w*. \w Protesté|strong="H5749"\w* \w a|strong="H3068"\w* causa \w del|strong="H5921"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* vendían \w las|strong="H1992"\w* provisiones.
\p 
\v 16 \w Vivían|strong="H3427"\w* también en \w la|strong="H3605"\w* ciudad \w hombres|strong="H1121"\w* \w de|strong="H1121"\w* Tiro, quienes importaban \w pescado|strong="H1709"\w* y \w toda|strong="H3605"\w* clase \w de|strong="H1121"\w* mercancías \w que|strong="H1121"\w* vendían en \w sábado|strong="H7676"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, aun en Jerusalén.
\p 
\v 17 \w Entonces|strong="H3117"\w* reprendí \w a|strong="H3068"\w* los jefes \w de|strong="H1697"\w* \w Judá|strong="H3063"\w*: ¿\w Qué|strong="H4100"\w* significa \w esta|strong="H2088"\w* \w mala|strong="H7451"\w* acción \w que|strong="H4100"\w* \w hacen|strong="H6213"\w*, y profanan \w así|strong="H2088"\w* \w el|strong="H6213"\w* \w sábado|strong="H7676"\w*?
\v 18 ¿\w No|strong="H3808"\w* \w hicieron|strong="H6213"\w* \w así|strong="H3541"\w* sus antepasados, \w y|strong="H5921"\w* nuestro \nd ʼElohim\nd* trajo \w toda|strong="H3605"\w* \w esta|strong="H2063"\w* desgracia \w sobre|strong="H5921"\w* \w nosotros|strong="H3605"\w* \w y|strong="H5921"\w* \w esta|strong="H2063"\w* \w ciudad|strong="H5892"\w*? ¡Ustedes aumentan \w la|strong="H5921"\w* \w ira|strong="H2740"\w* divina \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w* \w al|strong="H5921"\w* profanar \w el|strong="H5921"\w* \w sábado|strong="H7676"\w*!
\p 
\v 19 \w Aconteció|strong="H1961"\w* \w que|strong="H3808"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* víspera \w del|strong="H5921"\w* \w sábado|strong="H7676"\w*, \w cuando|strong="H3117"\w* llegaba \w la|strong="H5921"\w* noche \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w puertas|strong="H1817"\w* \w de|strong="H5921"\w* Jerusalén, ordené \w que|strong="H3808"\w* \w las|strong="H5921"\w* \w puertas|strong="H1817"\w* fueran cerradas \w hasta|strong="H5704"\w* pasar \w el|strong="H5921"\w* \w sábado|strong="H7676"\w*. Emplacé \w a|strong="H3068"\w* algunos \w de|strong="H5921"\w* mis esclavos \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w puertas|strong="H1817"\w* \w para|strong="H5704"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* entrara alguna \w carga|strong="H4853"\w* \w en|strong="H5921"\w* \w sábado|strong="H7676"\w*.
\p 
\v 20 Pero \w los|strong="H3605"\w* comerciantes y vendedores de \w toda|strong="H3605"\w* esa clase de mercancías pasaron \w la|strong="H3605"\w* noche \w fuera|strong="H2351"\w* de Jerusalén \w una|strong="H6471"\w* y \w dos|strong="H8147"\w* \w veces|strong="H6471"\w*.
\p 
\v 21 \w Entonces|strong="H6256"\w* \w yo|strong="H4480"\w* les advertí: ¿\w Por|strong="H4480"\w* \w qué|strong="H4480"\w* pernoctan \w frente|strong="H5048"\w* \w al|strong="H4480"\w* \w muro|strong="H2346"\w*? \w Si|strong="H3808"\w* \w lo|strong="H1931"\w* hacen otra \w vez|strong="H6256"\w*, les \w echaré|strong="H7971"\w* \w mano|strong="H3027"\w*. \w Desde|strong="H4480"\w* \w ese|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w no|strong="H3808"\w* volvieron \w en|strong="H4480"\w* \w sábado|strong="H7676"\w*.
\p 
\v 22 \w Por|strong="H5921"\w* otra parte, ordené \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w* \w que|strong="H5921"\w* \w se|strong="H1961"\w* purificaran \w y|strong="H1571"\w* acudieran \w a|strong="H3068"\w* vigilar \w las|strong="H5921"\w* \w puertas|strong="H8179"\w* \w para|strong="H5921"\w* santificar \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w sábado|strong="H7676"\w*. ¡\w Acuérdate|strong="H2142"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w también|strong="H1571"\w* \w por|strong="H5921"\w* \w esto|strong="H2063"\w*, oh \nd ʼElohim\nd* \w mío|strong="H5921"\w*, \w y|strong="H1571"\w* perdóname \w según|strong="H5921"\w* \w la|strong="H5921"\w* inmensidad \w de|strong="H5921"\w* tu \w misericordia|strong="H2617"\w*!
\p 
\v 23 En \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w también|strong="H1571"\w* \w vi|strong="H7200"\w* \w que|strong="H1571"\w* algunos \w judíos|strong="H3064"\w* \w se|strong="H1992"\w* casaron \w con|strong="H1571"\w* esposas de Asdod, de Amón \w y|strong="H1571"\w* Moab.
\v 24 Sus \w hijos|strong="H1121"\w* \w hablaban|strong="H1696"\w* \w a|strong="H3068"\w* medias \w el|strong="H1121"\w* lenguaje \w de|strong="H1121"\w* Asdod. Ninguno \w de|strong="H1121"\w* ellos podía \w hablar|strong="H1696"\w* la \w lengua|strong="H3956"\w* \w de|strong="H1121"\w* Judá, sino \w el|strong="H1121"\w* lenguaje \w de|strong="H1121"\w* su propio \w pueblo|strong="H5971"\w*.
\p 
\v 25 Contendí \w con|strong="H5973"\w* \w ellos|strong="H1992"\w* y \w los|strong="H1992"\w* maldije. Castigué \w a|strong="H3068"\w* algunos \w de|strong="H5973"\w* \w ellos|strong="H1992"\w* y \w les|strong="H1992"\w* arranqué \w su|strong="H1992"\w* cabello. \w Los|strong="H1992"\w* juramenté \w por|strong="H5414"\w* \nd ʼElohim\nd* \w que|strong="H1121"\w* dijeran: No \w darán|strong="H5414"\w* \w sus|strong="H1992"\w* \w hijas|strong="H1323"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w ellos|strong="H1992"\w*, \w ni|strong="H5973"\w* \w tomarán|strong="H5375"\w* \w de|strong="H5973"\w* \w las|strong="H1992"\w* \w hijas|strong="H1323"\w* \w de|strong="H5973"\w* \w ellos|strong="H1992"\w* \w para|strong="H5414"\w* \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w*, \w ni|strong="H5973"\w* \w para|strong="H5414"\w* ustedes \w mismos|strong="H1992"\w*.
\p 
\v 26 ¿\w No|strong="H3808"\w* \w pecó|strong="H2398"\w* \w Salomón|strong="H8010"\w*, \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w por|strong="H5921"\w* estas mismas \w cosas|strong="H7227"\w*? \w Aunque|strong="H1571"\w* \w entre|strong="H5921"\w* \w muchas|strong="H7227"\w* \w naciones|strong="H1471"\w* \w no|strong="H3808"\w* \w hubo|strong="H1961"\w* \w rey|strong="H4428"\w* \w como|strong="H1571"\w* \w él|strong="H5921"\w*, \w fue|strong="H1961"\w* amado \w por|strong="H5921"\w* su \nd ʼElohim\nd*, \w y|strong="H1571"\w* \nd ʼElohim\nd* \w lo|strong="H3808"\w* \w hizo|strong="H5414"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w sin|strong="H3808"\w* embargo, \w las|strong="H5921"\w* mujeres \w extranjeras|strong="H5237"\w* \w lo|strong="H3808"\w* \w hicieron|strong="H5414"\w* \w pecar|strong="H2398"\w*.
\v 27 ¿Entonces escucharemos \w de|strong="H7451"\w* ustedes \w este|strong="H2063"\w* \w gran|strong="H1419"\w* \w mal|strong="H7451"\w* al ser infieles \w contra|strong="H4603"\w* nuestro \nd ʼElohim\nd* y convivir con mujeres \w extranjeras|strong="H5237"\w*?
\p 
\v 28 Ahuyenté \w de|strong="H5921"\w* \w mi|strong="H5921"\w* lado \w a|strong="H3068"\w* uno \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Joiada, \w hijo|strong="H1121"\w* \w del|strong="H5921"\w* \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w* Eliasib, \w porque|strong="H5921"\w* \w era|strong="H1121"\w* \w yerno|strong="H2860"\w* \w de|strong="H5921"\w* Sanbalat \w horonita|strong="H2772"\w*.
\p 
\v 29 ¡\w Acuérdate|strong="H2142"\w* \w de|strong="H5921"\w* \w ellos|strong="H1992"\w*, oh \nd ʼElohim\nd* \w mío|strong="H5921"\w*, \w porque|strong="H5921"\w* profanaron \w la|strong="H5921"\w* investidura sacerdotal, \w el|strong="H5921"\w* \w pacto|strong="H1285"\w* \w del|strong="H5921"\w* \w sacerdocio|strong="H3550"\w* \w y|strong="H5921"\w* \w los|strong="H1992"\w* \w levitas|strong="H3881"\w*!
