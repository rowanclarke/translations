\p
\v 6 Te \w dongah|strong="G2532"\w* \w hlangping|strong="G3793"\w* \w te|strong="G3588"\w* \w diklai|strong="G1093"\w* \w ah|strong="G1909"\w* \w ngol|strong="G0377"\w* ham a \w uen|strong="G3853"\w*. Te \w phoeiah|strong="G2532"\w* \w vaidam|strong="G0740"\w* \w parhih|strong="G2033"\w* \w te|strong="G3588"\w* a \w loh|strong="G2983"\w* tih a \w uem|strong="G2168"\w* tih a \w aeh|strong="G2806"\w*. Te \w daengah|strong="G2532"\w* \w hlangping|strong="G3793"\w* taengah \w tael|strong="G3908"\w* \w hamla|strong="G2443"\w* \w a|strong="G0846"\w* \w hnukbang|strong="G3101"\w* rhoek \w te|strong="G3588"\w* a \w paek|strong="G1325"\w* \w tih|strong="G2532"\w* a \w tael|strong="G3908"\w* uh.  
\v 7 Te \w phoeiah|strong="G2532"\w* \w ngadik|strong="G2485"\w* a \w yool|strong="G3641"\w* a \w khueh|strong="G2192"\w* uh te \w khaw|strong="G2532"\w* a \w uem|strong="G2127"\w* tih \w amih|strong="G0846"\w* te, \wj “ \+w He|strong="G5023"\+w* \+w khaw|strong="G2532"\+w* \+w tael|strong="G3908"\+w* uh,” \wj* a \w ti|strong="G2036"\w* nah.   
\p
\v 8 A \w caak|strong="G5315"\w* uh \w tih|strong="G2532"\w* a \w hah|strong="G5526"\w* uh \w phoeiah|strong="G2532"\w* a \w nueipil|strong="G2801"\w* aka \w coih|strong="G4051"\w* te \w voh|strong="G4711"\w* \w rhih|strong="G2033"\w* \w la a\w* \w phueih|strong="G0142"\w* uh.  
\v 9 Te \w vaengah|strong="G1161"\w* \w thawngli|strong="G5070"\w* \w tluk|strong="G5613"\w* \w om|strong="G2258"\w* uh.  
\v 10 \w Amih|strong="G0848"\w* a \w hlah|strong="G0630"\w* \w phoeiah|strong="G2532"\w* tah \w lawng|strong="G4143"\w* \w khuila|strong="G1519"\w* \w tlek|strong="G2117"\w* \w kun|strong="G1684"\w* tih \w a|strong="G0846"\w* \w hnukbang|strong="G3101"\w* rhoek \w neh|strong="G3326"\w* \w Dalmanutha|strong="G1148"\w* \w paengpang|strong="G3313"\w* \w la|strong="G1519"\w* \w pawk|strong="G2064"\w*.   
\s1 Tolrhu te Rhael Lah  
\p
\v 11 \x - \xo 8.11 \xt Mat 12. 38; Luk 11. 16.\x* Te \w vaengah|strong="G2532"\w* \w Pharisee|strong="G5330"\w* rhoek \w te|strong="G3588"\w* \w cet|strong="G1831"\w* uh \w tih|strong="G2532"\w* \w Jesuh|strong="G2424"\w* te \w koe|strong="G0756"\w* a \w oelh|strong="G4802"\w* uh. \w Vaan|strong="G3772"\w* \w lamkah|strong="G0575"\w* \w miknoek|strong="G4592"\w* te \w anih|strong="G0846"\w* \w taengah|strong="G3844"\w* a \w toem|strong="G2212"\w* uh tih a \w noemcai|strong="G3985"\w* uh.  
\v 12 \x - \xo 8.12 \xt Mat 12. 39; Luk 11. 29.\x* \w Tedae|strong="G2532"\w* \w a|strong="G0846"\w* \w lungbuei|strong="G4151"\w* \w ah|strong="G3588"\w* \w huei|strong="G0389"\w* tih, \wj “ \+w Balae|strong="G5101"\+w* \+w hekah|strong="G3778"\+w* \+w cadil|strong="G1074"\+w* \+w loh|strong="G3588"\+w* \+w miknoek|strong="G4592"\+w* a \+w toem|strong="G2212"\+w*. \+w Nangmih|strong="G5213"\+w* taengah \+w rhep|strong="G0281"\+w* ka \+w thui|strong="G3004"\+w*, \+w Hekah|strong="G5026"\+w* \+w cadil|strong="G1074"\+w* he \+w miknoek|strong="G4592"\+w* \+w tueng|strong="G1325"\+w* ham \+w moenih|strong="G1487"\+w*,” \wj* a \w ti|strong="G3004"\w*.  
\v 13 Te \w dongah|strong="G2532"\w* \w amih|strong="G0848"\w* \w te a\w* \w toeng|strong="G0863"\w* phoeiah \w koep|strong="G3825"\w* \w kun|strong="G1684"\w* tih \w rhalvangan|strong="G4008"\w* \w la|strong="G1519"\w* \w kat|strong="G0565"\w*.  
\v 14 Te \w vaengah|strong="G2532"\w* \w buh|strong="G0740"\w* \w khuen|strong="G2983"\w* ham a \w hmaai|strong="G1950"\w* uh \w dongah|strong="G2532"\w* \w lawng|strong="G4143"\w* \w khuikah|strong="G1722"\w* \w amih|strong="G1438"\w* \w taengah|strong="G3326"\w* \w vaidam|strong="G0740"\w* \w pakhat|strong="G1520"\w* bueng \w pawt|strong="G3361"\w* \w atah|strong="G1487"\w* atloe \w khueh|strong="G2192"\w* uh \w pawh|strong="G3756"\w*.  
\v 15 \x - \xo 8.15 \xt Luk 12. 1.\x* Te \w vaengah|strong="G2532"\w* \w amih|strong="G0846"\w* te ol a \w paek|strong="G1291"\w* tih, \wj “ \+w Ngaithuen|strong="G3708"\+w* uh, \+w Pharisee|strong="G5330"\+w* rhoek \+w kah|strong="G3588"\+w* \+w tolrhu|strong="G2219"\+w* \+w neh|strong="G2532"\+w* \+w Herod|strong="G2264"\+w* kah \+w tolrhu|strong="G2219"\+w* \+w te|strong="G3588"\+w* \+w hmat|strong="G0991"\+w* uh,” \wj* a \w ti|strong="G3004"\w* nah.   
\p
\v 16 Te \w vaengah|strong="G2532"\w* \w vaidam|strong="G0740"\w* a \w khueh|strong="G2192"\w* uh \w pawt|strong="G3756"\w* \w te|strong="G3754"\w* \w amamih|strong="G0240"\w* \w khuiah|strong="G4314"\w* \w dawtlet|strong="G1260"\w* \w uh thae\w*.  
\v 17 \w Tedae|strong="G2532"\w* a \w ming|strong="G1097"\w* dongah \w amih|strong="G0846"\w* te, \wj “ \+w Balae|strong="G5101"\+w* tih \+w vaidam|strong="G0740"\+w* na \+w khueh|strong="G2192"\+w* uh \+w pawt|strong="G3756"\+w* \+w te|strong="G3754"\+w* na \+w thui|strong="G1260"\+w* uh. Na \+w yakming|strong="G3539"\+w* uh \+w pawt|strong="G3761"\+w* tih, na \+w hmuhming|strong="G4920"\+w* uh \+w thlan|strong="G3768"\+w* a? \+w Na|strong="G5216"\+w* \+w thinko|strong="G2588"\+w* \+w te|strong="G3588"\+w* \+w mangkhak|strong="G4456"\+w* la vawk \+w khueh|strong="G2192"\+w* uh ne\wj*.  
\v 18 \x - \xo 8.18 \xt Jer 5. 21; Eze 12. 2; Mrk 4. 12.\x* \wj \+w Mik|strong="G3788"\+w* aka \+w khueh|strong="G2192"\+w* rhoek loh na \+w hmuh|strong="G0991"\+w* uh voel \+w pawt|strong="G3756"\+w* \+w tih|strong="G2532"\+w* \+w hna|strong="G3775"\+w* aka \+w khueh|strong="G2192"\+w* rhoek loh na \+w yaak|strong="G0191"\+w* uh \+w pawt|strong="G3756"\+w* \+w dongah|strong="G2532"\+w* na \+w poek|strong="G3421"\+w* uh \+w moenih|strong="G3756"\+w*\wj*.  
\v 19 \wj \+w Thawngnga|strong="G4000"\+w* \+w ham|strong="G1519"\+w* \+w vaidam|strong="G0740"\+w* \+w panga|strong="G4002"\+w* ka \+w aeh|strong="G2806"\+w* \+w vaengah|strong="G3753"\+w* a \+w nueipil|strong="G2801"\+w* na \+w phueih|strong="G0142"\+w* uh te \+w voh|strong="G2894"\+w* \+w meyet|strong="G4214"\+w* a \+w bae|strong="G4134"\+w*?\wj*” a \w ti|strong="G3004"\w* nah hatah \w Jesuh|strong="G2424"\w* taengah, “\w Hlainit|strong="G1427"\w*,” a \w ti|strong="G3004"\w* na uh.   
\p
\v 20 \wj \+w “Thawngli|strong="G5070"\+w* \+w ham|strong="G1519"\+w* \+w parhih|strong="G2033"\+w* \+w vaengah|strong="G3753"\+w* a \+w nueipil|strong="G2801"\+w* na \+w phueih|strong="G0142"\+w* uh te \+w voh|strong="G4711"\+w* \+w meyet|strong="G4214"\+w* a \+w bae|strong="G4138"\+w*?\wj*” a ti nah \w hatah|strong="G2532"\w* \w Jesuh|strong="G2424"\w* taengah, “\w Parhih|strong="G2033"\w*,” a \w ti|strong="G3004"\w* na uh.   
\p
\v 21 Te \w phoeiah|strong="G2532"\w* \w amih|strong="G0846"\w* te, \wj “ Na \+w hmuhming|strong="G4920"\+w* uh \+w hlan|strong="G3768"\+w* a?,” \wj* a \w ti|strong="G3004"\w* nah.   
\s1 Mikdael Loh Kho a Hmuh  
\p
