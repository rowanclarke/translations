\id PHM  
\h FILEMÓN 
\toc1 Si₂ carta a₂ca₂jmo₃ San Pablo ne₄ FILEMÓN 
\toc2 FILEMÓN 
\toc3 Flm. 
\mt2 Si₂ carta a₂ca₂jmo₃ San Pablo ne₄ 
\mt1 FILEMÓN 
\c 1  
\s1 Ca₂jmo₃ Pablo si₂ ca₂chein₃ ne₄ Filemón 
\p  
\v 1 Jniá₂ Pa₄ 'eng₅₄ né'₃ 'má₃ o₄quió'₄ Cristo Jesús. Jmo₅ jniá₂ si₂ carta la₂ quiang'₅₄ rɨn'₅₄ jniog₄ Timoteo, ne'₅₄ 'ne₂ Filemón i₂'nió₄, i₂co₂dsia₅ jmo₂ ta₁,  
\v 2 ne₄ 'io₅₄ rɨn'₅₄ jniog₄ Apia, quian'₅₄ Arquipo në́₃, co₂'nió'₄ bá₄ jan₂ 'lióg₂ rɨn'₅₄ jniog₄, quian'₅₄ ne₄ guá'₅ i₂ŋɨ'₂ dsi₂néi₂ quiáng'₂.  
\v 3 Juɨ₁jme₂gu'₅₄ bá₄ Diú₄ 'nia'₂, juɨ₁tion'₄ bá₄ 'nia'₂ 'ei₅ tei₄, jmo₅ Diú₄ Jmei₂ jniog₄ quian'₅₄ Te₁gui'₅₄ Jesucristo. 
\s1 'A₂ lia'₂ jme₁'nio₃ Filemón rɨin'₅₄ ia₁ a₂'éin₂ 
\p  
\v 4 Ca₂le₃jë́₃ ráun₂ cuë́₅ jniá₂ ti₁'mag'₄ Diú₄, 'ɨ́n₅ jniá₂ 'ne₂ jë₁ma₂chi₁ca₂lein'₄ jniá₂.  
\v 5 Ia₁ ma₂ca₂rë₃guion₅₄ jág₁ a₂'nióg'₃ Te₁gui'₅₄ Jesús, 'éng'₂ bá₄ të₂le₃ quió'₅, ján₃ bá₄ le₂jaun₂ 'nióg'₃ ca₂le₃jɨ́n₃ i₂ma₂tén₅ të₂le₃ quió'₅ Diú₄.\f + \fr 1:5 \ft lit. “ca₂le₃jɨ́n₃ dsa₂ jŋió₅.” \f* 
\v 6 Mɨ₅ jniá₂ ján₃ a₂jmó'₂ dsen₅₄ 'au'₂ a₂quen'₅₄ a₂'éng'₂ jɨn₄ dsa₂ sián'₂, ia₁jaun₂ le₃cuɨ́'₅ ca₂le₃jë́₃ a₂dse₃ a₂cha₂ ja₁con₂ jniog₄ o₄quió'₄ Cristo Jesús.  
\v 7 'Ŋio₅ lɨn₃ 'io'₂ jéin₅, 'ei₅ lián'₂ dsɨ₃, ia₁ a₂'nióg'₃ jniá₂, ia₁ 'uɨg₅₄ quián'₂ 'ne₂ bá₄ rɨn'₅₄ jniog₄, ma₂qui₂le₁'ág₄ tei₄ dsɨ́₅ dsa₂ i₂'én₂.\f + \fr 1:7 \ft lit. “dsa₂ jŋió₅.” \f* 
\s1 Mɨ₅ Pa₄ ne₄ Filemón a₂jmo₃ 'éi₂ dse₃ dsɨ́₅ le₃quió'₅ Onésimo 
\p  
\v 8 Jaun₂ lë₃, o₁jŋia'₅₄ jme₁ca₂tɨ́n₂ jniá₂ le₃quió'₅ Cristo a₂jmo₅₄ 'éi'₃ ne'₅₄ 'ne₂, juɨ₁lia'₂ 'e₂ dsi₂ten₅₄ jmó'₂,  
\v 9 la₁ të₂le₃ ia₁ a₂ŋɨ́₄ lë₃ 'nió₃ bá₄ jniá₂ 'ne₂, ja₂lɨn₃ guë́₄ dse₃ chi₂len'₄ jniá₂ 'ne₂, lɨ́n₂ jniá₂. Jniá₂ Pa₄ ma₂gueng'₂ 'eng₅₄ né'₃ 'má₃ o₄quió'₄ Cristo Jesús.  
\v 10 Mɨ₅₄ jmó'₂ dse₃ 'au'₂ të₂le₃ quió'₅ Onésimo i₂ca₂lɨn₃ co₂'nió'₄ jan₂ chi'₂ quiáng₃ dsi₂néi₂ 'né₅ 'má₃ la₂. 
\p  
\v 11 Le₂jŋiá₅ në́₃ jme₁lɨ́n₄ Onésimo\f + \fr 1:11 \ft Jág₁ juɨ₁lia'₂ chen₂ Onésimo co₂'nió'₄ a₂juá'₂, Dsa₂ i₂tén₅ ta₁, quian'₅₄ jág₁ jmei₅ griego.\f* jan₂ dsa₂ i₂tsá₃ ta₁ tén₄ jme₃ti₃ ta₁ ne'₅₄. La₁ rë₂në́₃ në́₃, ma₂téin₅ bá₄ ta₁ jme₃ti₃ ta₁ ne₄ jniog₄ le₃o₃.  
\v 12 Jaun₂ dsiain'₅₄ táng₃ jniá₂ ne'₅₄, jaun₂ guein₅₄ bá₄ co₂nio₄ co₂'nió'₄ bá₄ a₂jme₁guéi'₄ jniá₂ 'ŋió₃.  
\v 13 O₁jŋia'₅₄ jme₁'ɨ́n₅ dsɨ₃ jme₁'í₂ guë́₄ ja₁lá₃ jme₃ti₃ ta₁ ne₃ co₂'nió'₄ bá₄ a₂jme₁jme₁ti'₄ 'ne₂ të₁lia'₂ 'eng₅₄ guë́₄ né'₃ 'má₃ 'uɨg₅₄ quió'₅ jág₁ dse₃,  
\v 14 la₁ tsá₃ 'e₂ 'nio₃ jmo₅₄ 'i₁caun₂ jua'₅₄ a₂tɨng₂ 'ŋió₃ jua'₅₄ a₂tsá₃ 'ei₅ caun₂ jág₁ quian'₅₄ 'ne₂. Jaun₂ tsá₃ o₁leng'₂ jua'₅₄ a₂chi₂quiong₅₄ jniá₂ jmɨg₄ a₂jmó'₂ tion₅₄; jaun₂ 'a₂ con'₂ 'ŋio₂ 'au'₂ 'ŋiag'₂ bá₄ 'ne₂.  
\v 15 'An₁ Diú₄ bá₄ ca₂cuë₃ jmɨg₄ ca₂téi₂ Onésimo co₂'na₂ quián'₂ 'ne₂, ia₁jaun₂ guéin'₄ jme₃quiong'₅₄ co₂tan₅₄,  
\v 16 on₃jua'₅₄ ma₃lɨ́in₅ ca₂ne₅₄ dsa₂ i₂lë₁jme₂ti₃ ta₁ ne'₅₄, ton'₂ të₂le₃ dse₃ guë́₄ ma₂lɨ́in₅ jan₂ rɨ́ng'₂ i₂'niog'₃ të₂le₃ quian'₅₄ jme₂dsí₂. Jniá₂ 'ŋio₅ lɨn₃ 'niói₃, la₁ 'ne₂ në́₃ 'ŋio₅ lɨn₃ guë́₄ ca₂tɨ́ng'₂ jme₁'niói'₄ jaun₂ tsá₃ ma₃jɨin'₅₄ juɨ₁lia'₂ ja₁jɨng'₄ jan₂ dsa₂ lë₁dsa₂. Jɨin₅₄ bá₄ juɨ₁lia'₂ ja₁jɨng'₄ jan₂ rɨ́ng'₂ të₂le₃ quió'₅ Te₁gui'₅₄. 
\p  
\v 17 Le₂në₅ jaun₂, chi₂jua'₂ dsón'₂ jmo'₂ 'au'₂ a₂lɨ́n₅ jniá₂ jan₂ dsa₂ i₂jmo'₂ ta₁ quiang'₅₄, jaun₂ guein₅₄ bá₄, jmo₄ 'au'₂ co₂'nió'₄ a₂guéi'₅ jniá₂ 'ŋió₃.  
\v 18 Chi₂jua'₂ 'e₂ dain₅₄ ma₂jmóg'₂, o₃ chi₂jua'₂ cha₂ a₂rɨin₂, quió₃ jniá₂ mɨ₄.  
\v 19 Jniá₂ Pa₄ jmo₂₃ si₂ la₂ 'ŋió₃ të₃dsón'₂ quian'₅₄ gu₃.\f + \fr 1:19 \ft 'Nio'₂ ja₁ton₅ 1 Corintios 16:21; Gálatas 6:11; Colosenses 4:18; 2 Tesalonicenses 3:17.\f* Jniá₂ bá₄ quɨ́₄, jŋia'₅₄ jme₁'nio₃ jniá₂ jmo₅₄ dsiog'₂ 'au'₂ a₂rɨng'₂ quiáng'₂ 'ŋiag'₂ quió₃ ján₃.  
\v 20 Jaun₂ le₂në₅ bá₄, 'ne₂ rɨn'₅₄ jniog₄, jmo₄ dse₃ 'au'₂ quian'₅₄ jniá₂ juɨ₁lia'₂ dsi₂ten₅₄ jmo₃ dsa₂ i₂'én₂ le₃quió'₅ Te₁gui'₅₄, jmo₄ juɨ₁le₂güɨg'₂ dsɨ₃ juɨ₁lia'₂ jan₂ rɨ́ng'₂ le₃quió'₅ Cristo. 
\p  
\v 21 Dsian'₄ jniá₂ si₂ la₂ ne'₅₄, ia₁ dsón'₂ bá₄ lɨ́ng₂ jme₁ti'₄ bá₄ ca₂le₃jë́₃, të₂le₃ lë́₅ guë́₄ jmó'₂ con'₂ guë́₄ a₂juá'₅.  
\v 22 Jmo₄ dse₃ 'au'₂, jmo₄ co₂jŋia₅₄ caun₂ dsi₂néi₂ ja₁i₁jŋia₁₂, ia₁ 'ɨ́n₂ dsɨ₃ jniá₂ a₂ŋág'₃ Diú₄ a₂mɨ'₂ 'nia'₂, jmo₃ bá₄ a₂dsióg₄ jniá₂ i₁jag₁₂. 
\s1 'Ág'₅ jág₁ jë₁ca₂tó'₂, cuag₂₃ Diú₄ në́₃ 
\p  
\v 23 Rɨ́ng'₃ i₂chen₂ Epafras i₂quiang'₅₄ 'eng₅₄ né'₃ 'má₃ 'uɨg₅₄ quió'₅ Cristo Jesús, dsiáin'₂ jág₁ a₂cuɨin₂₃ Diú₄ 'ne₂.  
\v 24 Ján₃ bá₄ le₂jaun₂ Marcos, Aristarco, Demas quian'₅₄ Lucas në́₃ i₂jme₂'o₅₄ jmo₅ ta₁. 
\p  
\v 25 Juɨ₁jme₂gu'₅₄ Te₁gui'₅₄ Jesucristo jme₂dsí₂ quián'₂ 'nia'₂. 
\p Co₂në₅.