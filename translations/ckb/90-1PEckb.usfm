\id 1PE - Biblica® Open Kurdi Sorani Standard Version
\h یەکەم پەترۆس
\toc1 یەکەم نامەی پەترۆس
\toc2 یەکەم پەترۆس
\toc3 یەکەم پەترۆس
\mt1 یەکەم نامەی پەترۆس
\c 1
\p 
\v 1 لە پەترۆسی نێردراوی عیسای مەسیحەوە،
\b
\p بۆ ئەوانەی خودا هەڵیبژاردوون، بێگانە پەراگەندەکان لە پۆنتۆس و گەلاتیا و کەپەدۆکیا و ئاسیا و بیسینیا\f + \fr 1:1 \ft هەموو ئەو شوێنانە دەکەونە تورکیای ئێستاوە.\f*،
\v 2 کە بەگوێرەی زانینی پێشووی خودای باوک هەڵبژێردراون، بە پیرۆزکردنی ڕۆحی خۆی بۆ گوێڕایەڵی عیسای مەسیح و پرژاندنی خوێنەکەی:
\b
\p با نیعمەت\f + \fr 1:2 \ft نیعمەت بەخشینێکی خودایە بە مرۆڤ بەبێ شایستەبوونی پێی دەبەخشێت.\f* و ئاشتیتان بۆ زیاد بێت.
\b
\s1 ستایشی خودا بۆ هیوای زیندوو
\p 
\v 3 ستایش بۆ خودا، باوکی عیسای مەسیحی پەروەردگارمان! بەهۆی بەزەییە فراوانەکەیەوە لەدایکبوونەوەی پێ بەخشین\f + \fr 1:3 \ft مەبەست لە لەدایکبوونەوەیە لە ڕۆحی پیرۆز، بڕوانە \xt یۆحەنا 3‏:3‏-8.‏\xt*\ft ‏\f* بۆ هیوایەکی زیندوو بە هەستانەوەی عیسای مەسیح لەنێو مردووان،
\v 4 بۆ میراتێک کە نافەوتێت و گڵاو نابێت و کاڵ نابێتەوە. ئەو میراتە بۆ ئێوە لە ئاسمان پارێزراوە،
\v 5 ئێوە کە بە هێزی خودا پاسەوانی کراون بە باوەڕ، بۆ ئەو ڕزگارییەی ئامادەیە لە کۆتایی زەمانە ڕابگەیەنرێ.
\v 6 ئەمانە دڵخۆشتان دەکات، هەرچەندە لەوانەیە بۆ ماوەیەکی کەم ناچار بن بە دەست تاقیکردنەوەی جۆراوجۆرەوە ئازار بچێژن،
\v 7 تاکو سەلماندنی باوەڕی ڕاستەقینەتان، کە لە زێڕی لەناوچوو بەنرخترە، هەرچەندە بە ئاگر تاقی دەکرێتەوە، کاتێک عیسای مەسیح ئاشکرا دەکرێت ستایش و شکۆ و ڕێزی بەدواوە دەبێت.
\v 8 هەرچەندە نەتانبینیوە خۆشتان دەوێ، ئێستاش نایبینن باوەڕی پێ دەهێنن و دڵخۆش دەبن بە شێوەیەک هەر باسی ناکرێت و شکۆدارە،
\v 9 چونکە ئامانجی باوەڕتان بەدەستدەهێنن، واتا ڕزگاریی دەروونتان.
\p 
\v 10 ئەو پێغەمبەرانەی کە پێشبینییان کرد لەسەر ئەو نیعمەتەی کە خودا بۆ ئێوەی ئامادە کردبوو، بە وردی لێکۆڵینەوەیان لە بابەتی ئەو ڕزگاربوونە کرد و بەدوایدا گەڕان،
\v 11 ڕۆحی مەسیح کە تێیاندابوو، ئاگاداری دەکردنەوە سەبارەت بە ئازارەکانی مەسیح و ئەو شکۆداربوونەی لەدوای ئازارەکانەوە دێت، هەوڵیان دەدا کە بزانن ڕۆحی پیرۆز ئاماژە بە چی دەکات لەبارەی کاتی ڕوودانەکەی یان بارودۆخی جیهان لە کاتی ڕوودانەکەی.
\v 12 بۆیان ئاشکرا کرا کە پەیامەکە بۆ خۆیان نەبوو، بەڵکو بۆ ئێوە بوو، واتا ڕووداوەکان لە سەردەمی ئێوە ڕوودەدەن. ئێستا پێتان ڕاگەیەنرا بەهۆی ئەوانەی مزگێنییان پێ بەخشین بە یارمەتی ڕۆحی پیرۆز، کە لە ئاسمانەوە نێردراوە. ئەمانە ئەو ڕووداوانەن کە فریشتەکانیش بە پەرۆشن لێیان ورد ببنەوە.
\s1 بانگەوازێک بۆ پیرۆزی
\p 
\v 13 بۆیە با مێشکتان ئامادە بێت بۆ چالاکی، خۆڕاگر بن، هیواتان بە تەواوی لەسەر ئەو نیعمەتە بێت کە لە ئاشکراکردنی عیسای مەسیحەوە دێت.
\v 14 وەک منداڵی گوێڕایەڵ، وەک کاتی نەزانی خۆتان لەگەڵ هەوەسە کۆنەکانتان مەگونجێنن،
\v 15 بەڵکو هەروەک ئەوەی بانگی کردوون پیرۆزە، ئێوەش لە هەموو هەڵسوکەوتێک پیرۆز بن،
\v 16 چونکە نووسراوە: ﴿پیرۆز بن، چونکە من پیرۆزم.﴾\f + \fr 1:16 \ft \xt لێڤییەکان 11‏:44‏،45 و لێڤییەکان 19‏:2 و لێڤییەکان 20‏:7.‏\xt*\ft ‏\f*
\p 
\v 17 لەبەر ئەوەی لە خودای باوک دەپاڕێنەوە، ئەوەی بێ لایەنگری هەرکەسێک بەگوێرەی کردەوەکەی حوکم دەدات، کەواتە لە کاتی نامۆییتاندا بە لەخواترسییەوە بژین.
\v 18 دەزانن بە شتی لەناوچووی وەک زێڕ و زیو نەکڕاونەتەوە، لەو ژیانە پووچەی لە باوباپیرانەوە بۆتان مابووەوە،
\v 19 بەڵکو بە خوێنێکی گرانبەها، خوێنی مەسیح، کە وەک بەرخێکی بێ لەکە و کەموکوڕییە.
\v 20 لەپێش دامەزراندنی جیهان هەڵبژێردرابوو، بەڵام لەم ڕۆژگارانەی دوایی لە پێناوی ئێوەدا دەرکەوت.
\v 21 بەهۆیەوە باوەڕتان بە خودا هەیە، ئەوەی لەنێو مردووان هەڵیستاندەوە و شکۆی پێدا، تاکو هیوا و باوەڕتان بە خودا بێت.
\p 
\v 22 بە گوێڕایەڵیتان بۆ ڕاستی خۆتان پاک کردووەتەوە بۆ خۆشەویستی برایانەی بێ دووڕوویی، لە قووڵایی دڵەوە یەکتریتان خۆشبوێ.
\v 23 ئێوەش لەدایک بوونەوە\f + \fr 1:23 \ft نوێبوونەوە بە ڕۆحی پیرۆز.‏\f*، نەک بە تۆوێکی فەوتاو بەڵکو نەفەوتاو، بە وشەی زیندووی خودا کە دەمێنێتەوە،
\v 24 چونکە نووسراوە:
\q1 ﴿هەموو مرۆڤێک وەک گژوگیا وایە و
\q2 هەموو شکۆیەکەی وەک گوڵی کێوی وایە.
\q1 گژوگیا وشک دەبێت و گوڵ هەڵدەوەرێ،
\q2 
\v 25 بەڵام فەرمایشتی یەزدان هەتاهەتایە چەسپاو دەبێت.﴾\f + \fr 1:25 \ft \xt ئیشایا 40‏:6‏-8.‏\xt*\ft ‏\f*
\m ئەمەش ئەو فەرمایشتەیە کە مزگێنیتان پێدرا.
\c 2
\s1 بەردی زیندوو
\p 
\v 1 بۆیە هەموو ڕق و هەموو فێڵ و دووڕوویی و چاوپیسی و هەموو زەمکردنێک دابکەنن.
\v 2 وەک ساوای تازە لەدایک بوو، ئارەزووتان لە شیری ڕۆحی پاک بێت، تاکو بەمە بۆ ڕزگاری گەشە بکەن،
\v 3 چونکە تامتان کردووە کە مەسیحی باڵادەست چاکە.
\p 
\v 4 ئەوەی ئێوە دێنە لای، بەردە زیندووەکەیە، لەلایەن خەڵکەوە ڕەتکراوەتەوە، بەڵام لەلایەن خوداوە هەڵبژێردراوە و گرانبەهایە،
\v 5 ئێوەش وەک بەردی زیندوو لە خانووێکی ڕۆحی بنیاد دەنرێن، بۆ کاهینیێتی پیرۆز، بۆ کردنی قوربانییە ڕۆحییە قبوڵکراوەکان بۆ خودا لە ڕێگەی عیسای مەسیحەوە،
\v 6 چونکە لە نووسراوە پیرۆزەکاندا هاتووە:
\q1 ﴿ئەوەتا بەردێک لە سییۆن دادەنێم،
\q2 گرنگترین بەردی بناغەی\f + \fr 2:6 \ft یان قولینچک.‏\f* هەڵبژێردراو و گرانبەها،
\q2 ئەوەی پشتی پێ ببەستێت شەرمەزار نابێت.﴾\f + \fr 2:6 \ft \xt ئیشایا 28‏:16.‏\xt*\ft ‏\f*
\m 
\v 7 بۆیە بۆ ئێوە کە باوەڕتان هێناوە ئەم بەردە گرانبەهایە، بەڵام بۆ بێباوەڕان،
\q1 ﴿ئەو بەردەی وەستاکان ڕەتیان کردەوە،
\q2 بوو بە گرنگترین بەردی بناغە،﴾\f + \fr 2:7 \ft \xt زەبوورەکان 118‏:22‏\xt*\ft ‏\f*
\m 
\v 8 هەروەها:
\q1 ﴿دەبێتە بەردێک بۆ کۆسپ،
\q2 تاشەبەردێکیش کە لێی بکەونە خوارەوە.﴾\f + \fr 2:8 \ft \xt ئیشایا 8‏:14.‏\xt*\ft ‏\f*
\m ئەوانە ساتمە دەکەن و دەکەون، چونکە گوێڕایەڵی وشەی خودا نین، هەر ئەمەشە چارەنووسیان.
\p 
\v 9 بەڵام ئێوە گەلێکی هەڵبژێردراون، کاهینیێتی شاهانە، نەتەوەیەکی پیرۆز، گەلی تایبەتی خودان\f + \fr 2:9 \ft بڕوانە \xt دەرچوون 19‏:5‏-6 و ئیشایا 43‏:20‏،21‏\xt*\ft ‏.‏\f*، تاکو چاکییەکانی ئەوە ڕابگەیەنن کە بانگی کردوون لە تاریکییەوە بۆ ڕووناکییە سەرسوڕهێنەرەکەی.
\v 10 پێشتر گەل نەبوون، بەڵام ئێستا گەلی خودان، پێشتر بەزەییتان وەرنەگرتبوو، بەڵام ئێستا بەزەییتان وەرگرتووە.
\p 
\v 11 خۆشەویستان، ئێوە نامۆ و بێگانەن بەم جیهانە، هەر بۆیە لێتان دەپاڕێمەوە لە هەوەسەکانی جەستە دوور بکەونەوە، کە لە دژی دەروون دەجەنگن.
\v 12 با لەنێو بێباوەڕاندا ڕەوشتتان باش بێت، تاکو کاتێک بوختانتان پێ دەکەن گوایا ئێوە بەدکارن، کردەوە چاکەکانتان ببینن و لە ڕۆژی بەسەرکردنەوەی خودا، ئەوانیش خودا شکۆدار بکەن.
\s1 ملکەچی بۆ دەسەڵاتداران
\p 
\v 13 لەبەر مەسیحی باڵادەست، ملکەچی هەموو دامودەزگایەکی مرۆڤانە بن: بۆ پاشا وەک دەسەڵاتدار،
\v 14 یان بۆ پارێزگاران وەک نێردراوی ئەو بۆ سزادانی بەدکاران و ستایشی چاکەکاران،
\v 15 چونکە خواستی خودا ئاوایە، بە چاکەکاری نەزانیی گێلەکان بێدەنگ بکەن.
\v 16 وەک مرۆڤی ئازاد بژین، بەڵام نەک ئازادی پەردەی بەدکاری بێت، بەڵکو وەک بەندەی خودا بژین.
\v 17 ڕێز لە هەمووان بگرن، هاوباوەڕانتان خۆشبوێ، لە خودا بترسن و ڕێز لە پاشا بگرن.
\s1 نموونەی ئازارەکانی مەسیح
\p 
\v 18 ئەی کۆیلەکان، بە هەموو ترسەوە ملکەچی گەورەکانتان بن، نەک تەنها بۆ چاک و دڵنەرمەکان، بەڵکو بۆ توندەکانیش،
\v 19 چونکە ئەگەر کەسێک لەبەر ویژدانی بەرامبەر خودا بەرگەی ژانی ئازاری زۆرداری بگرێت، ئەمە جێی ستایشە.
\v 20 بەڵام ئەگەر هەڵەتان کرد و لێتان درا و بەرگەتان گرت، ئەمە چ شانازییەکە؟ بۆیە ئەگەر چاکە بکەن و لە ئازاردا بەرگەتان گرت، ئەمە جێی ستایشە لەلای خودا.
\v 21 بۆ ئەمە بانگکراون، لەبەر ئەوەی مەسیحیش لە پێناوتاندا ئازاری چێژت و نموونەی بۆ بەجێهێشتن، تاکو بە هەنگاوەکانیدا بڕۆن.
\q1 
\v 22 ﴿ئەوەی هیچ گوناهێکی نەکردبوو،
\q2 فڕوفێڵی لەسەر زار نەبوو.﴾\f + \fr 2:22 \ft \xt ئیشایا 53‏:9.‏\xt*\ft ‏\f*
\m 
\v 23 ئەوەی جنێوی پێدەدرا و جنێوی نەدەدایەوە، ئازار دەدرا و هەڕەشەی نەدەکرد، بەڵکو خۆی دەدایە دەست ئەوەی حوکمی دادپەروەرانەیە.
\v 24 ئەوەی خودی خۆی لە لەشیدا لەسەر دار گوناهەکانمانی هەڵگرت، تاکو سەبارەت بە گوناه بمرین و بۆ ڕاستودروستی بژین. بە برینەکانی ئەو چاکبوونەوە.\f + \fr 2:24 \ft بڕوانە \xt ئیشایا 53‏:5‏\xt*\ft ‏\f*
\v 25 ئێوە وەک مەڕی ونبوو وابوون، بەڵام ئێستا گەڕاونەتەوە لای شوان و چاودێری گیانتان.
\c 3
\s1 ژن و مێرد
\p 
\v 1 ئەی ژنەکان، بە هەمان شێوە ملکەچی مێردەکانتان بن، تەنانەت ئەگەر هەندێکیان گوێڕایەڵی وشەی خودا نەبوون\f + \fr 3:1 \ft مەبەستی لەو ژنانەیە لەدوای مێردکردن باوەڕیان هێناوە، مێردەکانیان هێشتا باوەڕیان نەهێناوە.‏\f*، ئەوا ژنەکان بێ وشە بە ڕەوشتیان دەیانبەنەوە،
\v 2 کاتێک لەخواترسی و ڕەوشتی پاکتان ببینن.
\v 3 با ڕازاوەییتان دەرەکی نەبێت، لە ئەگریجەی پرچ و زێڕ بەخۆوەکردن و جلی باش لەبەرکردن،
\v 4 بەڵکو لەناو دڵتاندا شاراوە و لەناونەچوو بێ، ڕازاندنەوەی ڕۆحێکی نەرم و هێمن، ئەوەی لەلای خودا گرانبەهایە،
\v 5 چونکە بەم شێوەیە ژنە پیرۆزەکان لە کۆندا، کە هیوایان بە خودا بوو، خۆیان دەڕازاندەوە، ملکەچی مێردەکانیان دەبوون،
\v 6 وەک سارا گوێڕایەڵی ئیبراهیم بوو، بە گەورە بانگی دەکرد. ئێوەش بوونەتە کچی ئەو، ئەگەر چاکە بکەن و لە هیچ شتێک نەترسن.
\p 
\v 7 بە هەمان شێوە، مێردەکان، بە هەستیارییەوە لەگەڵ ژنەکانتاندا بژین و ئەوە لەبەرچاو بگرن کە لە ئێوە ناسکترن. ڕێزیان بگرن، چونکە لەگەڵتاندا هاومیراتی نیعمەتی ژیانن، بۆ ئەوەی نوێژەکانتان کۆسپی تێنەکەوێت.
\s1 بەرگەگرتنی ئازار لە پێناوی ڕاستی
\p 
\v 8 لە کۆتاییدا، هەمووتان یەک بیروڕاتان هەبێ، هاوسۆزبن و یەکتریتان خۆشبوێت، میهرەبان و ڕۆحسووک بن.
\v 9 خراپە بە خراپە مەدەنەوە، نە جنێویش بە جنێو، بەڵکو بە پێچەوانەوە داوای بەرەکەت بکەن و بزانن ئێوە بۆ ئەمە بانگکراون، تاکو ببنە میراتگری بەرەکەت،
\v 10 چونکە
\q1 ﴿ئەوەی بیەوێت ژیانی خۆشبوێت و
\q2 ڕۆژگاری خۆش ببینێت،
\q1 با زمانی لە خراپە بپارێزێت و
\q2 لێوەکانی لە فێڵبازی.
\q1 
\v 11 با لە خراپە لابدات و چاکە بکات،
\q2 با بەدوای ئاشتیدا بگەڕێت و کۆششی بۆ بکات،
\q1 
\v 12 چونکە چاوی یەزدان لەسەر ڕاستودروستانە و
\q2 گوێی لە پاڕانەوەکانیان ڕاگرتووە.
\q1 بەڵام ڕووی یەزدان لە دژی خراپەکارانە.﴾\f + \fr 3:12 \ft \xt زەبوورەکان 34‏:12‏-16‏\xt*\ft ‏\f*
\p 
\v 13 کێ ئازارتان دەدات ئەگەر بۆ چاکە دڵگەرم بن؟
\v 14 بەڵام ئەگەر لەبەر ڕاستودروستی ئازارتان چێژت، ئەوا خۆزگە بە ئێوە. ﴿مەترسن لەوەی کە ئەوان لێی دەترسن، مەتۆقن.﴾\f + \fr 3:14 \ft \xt ئیشایا 8‏:12.‏\xt*\ft ‏\f*
\v 15 بەڵکو مەسیح وەک پەروەردگار لە دڵتاندا تەرخان بکەن، هەردەم ئامادەبن بۆ وەڵامدانەوەی پرسیاری هەر یەکێک سەبارەت بەم هیوایەی لە ئێوەدایە، بەڵام بە دڵنەرمی و ڕێزەوە.
\v 16 هەروەها ویژدانێکی باشتان هەبێت، هەتا ئەوانەی بوختان بە سەربوردە باشەکانتان دەکەن کە بەرهەمی یەکبوونتانە لەگەڵ مەسیح، لە قسەکانیان شەرمەزار بن،
\v 17 چونکە باشترە، ئەگەر خواستی خودا بێت، لەبەر چاکەکاری ئازار بدرێن، نەک خراپەکاری.
\v 18 لەبەر ئەوەی مەسیح تەنها جارێک لەبەر گوناه ئازار درا، بێتاوان لە پێناوی تاوانباران، تاکو لە خودامان نزیک بکاتەوە. خەڵک مەسیحیان کوشت بەڵام خودا بە ڕۆح زیندووی کردەوە،
\v 19 بەمەش ڕۆحی مەسیح چوو مزگێنی دا بە ڕۆحە زیندانییەکان،
\v 20 بەوانەی کە لە کۆندا یاخی بوون، کاتێک خودا لە ڕۆژانی نوحدا بە پشوودرێژییەوە چاوەڕوان بوو، کە کەشتییەکە ئامادە دەکرا. تەنها هەشت کەس لەو کەشتییەدا بوون و بە ئاو ڕزگار بوون.
\v 21 ئەمەش هێمای لەئاوهەڵکێشانە کە ئێستا ڕزگارتان دەکات، نەک سڕینەوەی پیسی جەستە، بەڵکو بەڵێنی ویژدانێکی باش بۆ خودا، بە هەستانەوەی عیسای مەسیح،
\v 22 ئەوەی بەرەو ئاسمان ڕۆیشت و لە دەستەڕاستی خودا دانیشت، فریشتە و دەسەڵاتدار و هێزەکان ملکەچن بۆی.
\c 4
\s1 ژیان لە پێناوی خودا
\p 
\v 1 وەک مەسیح بە جەستە ئازاری چێژت، ئێوەش خۆتان بەم بیروڕایە چەکدار بکەن، چونکە ئەوەی بە جەستە ئازار بچێژێ لە گوناهکردن دەوەستێ،
\v 2 تاکو ئەو کاتەی بە جەستە لە ژیاندا ماوە بۆ هەوەسی مرۆڤانە نەژی، بەڵکو بۆ خواستی خودا.
\v 3 ئیتر ئەو کاتەی لە ئەنجامدانی خواستی بێباوەڕان بەسەرتان برد بەسە، لە بەڕەڵایی، هەوەسبازی، سەرخۆشی، ڕابواردن، ئاهەنگی شەرابخواردنەوە، بتپەرستیی قێزەون.
\v 4 لەمە سەرسام دەبن کە لەگەڵیان ڕاناکەن بۆ لافاوی هەمان بەدڕەوشتی و جنێوتان پێدەدەن.
\v 5 بەڵام ئەوانە حیسابی خۆیان دەدەن بەوەی کە ئامادەیە مردووان و زیندووان حوکم بدات،
\v 6 چونکە بەم هۆیەوە مژدە درایە مردووانیش، تاکو بەگوێرەی خەڵک لە جەستەدا حوکم بدرێن، بەڵام بەگوێرەی خودا لە ڕۆحدا بژین.
\p 
\v 7 کۆتایی هەموو شتێک نزیک بووەتەوە. بۆیە ژیر و چاوکراوە بن تاکو نوێژ بکەن.
\v 8 لە سەرووی هەموو شتێکەوە خۆشەویستیتان بۆ یەکتری بەهێز بێت، چونکە خۆشەویستی گوناهی زۆر دادەپۆشێت.
\v 9 بێ بۆڵەبۆڵ میوانداریەتی یەکتری بکەن.
\v 10 هەریەکە بەگوێرەی ئەو بەهرەیەی وەریگرتووە، خزمەتی یەکتری پێ بکەن، وەک سەرکارێکی باش لەسەر نیعمەتە جۆراوجۆرەکانی خودا.
\v 11 ئەگەر کەسێک وتار دەدات، با بە جۆرێک بدوێت وەک کەسێک کە پەیامی خودا ڕابگەیەنێت. ئەگەر کەسێک خزمەت دەکات، با بەو هێزەوە بیکات کە خودا دابینی کردووە، تاکو لە ڕێگەی عیسای مەسیحەوە خودا لە هەموو شتێکدا شکۆدار بێت. هەتاهەتایە شکۆ و دەسەڵات بۆ ئەوە. ئامین.
\s1 وەک قوتابی مەسیح ئازار بچێژن
\p 
\v 12 خۆشەویستان، لەلاتان سەیر نەبێ لە تاقیکردنەوەتان بەڵای سووتێنەر تووشتان دێت، وەک بڵێی شتێکی سەیرتان بەسەرهاتووە،
\v 13 بەڵکو دڵخۆش بن وەکو ئەوەی کە بەشداریتان لە ئازارەکانی مەسیحدا کردبێت، تاکو لە ئاشکراکردنی شکۆیەکەی دڵخۆش و شادمان بن.
\v 14 ئەگەر بە ناوی مەسیح جنێوتان پێدرا، خۆزگە دەخوازرێت بە ئێوە، چونکە ڕۆحی شکۆ و خودا دێتە سەرتان.
\v 15 با کەستان وەک بکوژێک یان دزێک یان بەدکارێک یاخود یەکێک دەست لە کاروباری خەڵک وەربدات ئازار نەچێژێ،
\v 16 بەڵام ئەگەر وەک قوتابی مەسیح ئازار بدرێن، شەرم مەکەن، بەڵکو ستایشی خودا بکەن کە ناوی مەسیحتان هەڵگرتووە،
\v 17 چونکە کاتی دەستپێکردنی لێپرسینەوەیە لە گەلی خودا. ئەگەر دەستپێک لە ئێمەوە بێت، کۆتایی ئەوانە چی دەبێت کە گوێڕایەڵی پەیامی ئینجیلی خودا نابن؟
\q1 
\v 18 ﴿ئەگەر کەسی ڕاستودروست بە زەحمەت ڕزگاری ببێت،
\q2 ئەی چارەنووسی خراپەکار و گوناهبار چۆن دەبێت؟﴾\f + \fr 4:18 \ft \xt پەندەکان 11‏:31‏\xt*\ft ‏\f*
\p 
\v 19 بۆیە ئەوانەی بەگوێرەی خواستی خودا ئازار دەدرێن، با خۆیان بدەنە دەست بەدیهێنەری دڵسۆز و بەردەوام بن لە چاکەکاری.
\c 5
\s1 شوانی مێگەلی خودا
\p 
\v 1 وەک پیرێکی هاوڕێتان، داوا لەو پیرانە دەکەم کە لەنێوتاندان، شایەتی ئازارەکانی مەسیح و هاوبەشی ئەو شکۆیەی وا ڕادەگەیەنرێ:
\v 2 ئەو مێگەلەی خودا بلەوەڕێنن کە لەنێوانتاندایە، وەک چاودێر خزمەتیان بکەن، نەک بە ناچاری، بەڵکو بە ویستەوە وەک چۆن خودا دەیەوێت، نەک بۆ دەستکەوتی شەرمەزاری، بەڵکو بە چالاکییەوە،
\v 3 خۆتان بەسەر ئەوانەدا مەسەپێنن کە دراونەتە دەستتان، بەڵکو ببنە نموونە بۆ مێگەل.
\v 4 کاتێکیش سەرۆکی شوانان دەردەکەوێ، تاجی شکۆ وەردەگرن کە کاڵ نابێتەوە.
\p 
\v 5 ئەی لاوەکان، بە هەمان شێوە ملکەچی پیران بن، هەمووتان بەرامبەر بە یەکتر بێفیز بن، چونکە:
\q1 ﴿خودا بەرهەڵستی لووتبەرزەکان دەکات،
\q2 بەڵام نیعمەت دەداتە بێفیزەکان.﴾\f + \fr 5:5 \ft \xt پەندەکان 3‏:34‏\xt*\ft ‏\f*
\m 
\v 6 بۆیە لەژێر دەستی بەهێزی خودا بێفیز بن، تاکو لە کاتی خۆیدا بەرزتان بکاتەوە.
\v 7 هەموو خەمێکتان بە خودا بسپێرن، چونکە ئەو بایەختان پێدەدات.
\p 
\v 8 چاوکراوە بن و ئێشک بگرن، شەیتانی دوژمنتان وەک شێرێکی بە نەڕەنەڕ دەسووڕێتەوە، بەدوای یەکێکدا دەگەڕێ بۆ ئەوەی بیخوات.
\v 9 بەربەرەکانێی بکەن، لە باوەڕەکە بچەسپێن، بزانن خوشک و براکانیشتان لە جیهاندا هەمان ئازار دەچێژن.
\p 
\v 10 خودای هەموو نیعمەتێک، ئەوەی بە یەکبوون لەگەڵ عیسای مەسیحدا\f + \fr 5:10 \fq بە یەکبوون لەگەڵ عیسای مەسیحدا \ft لە زمانی یۆنانیدا (لە عیسای مەسیحدا) بەکارهاتووە.‏\f* بانگی کردوون بۆ شکۆیە هەتاهەتاییەکەی، کە تۆزێک ئازارتان چێژت، خۆی ڕاستە ڕێتان دەکات و واتان لێ دەکات کە بەهێز و چەسپاو و دەمەزراو بن.
\v 11 هەتاهەتایە دەسەڵات بۆ ئەوە. ئامین.
\s1 نیعمەتی ڕاستی خودا
\p 
\v 12 بەهۆی سیلا\f + \fr 5:12 \ft یۆنانی: \tl سیلوانۆس‏\tl*.‏\f*، کە بە برای دڵسۆزی دەزانم، بە کورتی بۆم نووسین، هانتان دەدەم و شایەتی دەدەم، ئەمە نیعمەتە ڕاستەقینەکەی خودایە. تێیدا بچەسپێن.
\v 13 ئەوەی لە بابل\f + \fr 5:13 \ft بابل: هێمایە بۆ ڕۆما.‏\f* وەک ئێوە هەڵبژێردراوە، سڵاوتان لێدەکات، هەروەها مەرقۆسی ڕۆڵەم.
\v 14 بە ماچی خۆشەویستی سڵاو لە یەکتری بکەن. ئاشتی بۆ هەمووتان بێت کە لەگەڵ مەسیح یەکن\f + \fr 5:14 \fq کە لەگەڵ مەسیح یەکن \ft لە زمانی یۆنانیدا (لە مەسیحدا) بەکارهاتووە.‏\f*.
