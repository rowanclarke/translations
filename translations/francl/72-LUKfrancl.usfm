\v 55 (\w Ainsi|strong="G2532"\w* \w qu|strong="G2532"\w*’\w il|strong="G2532"\w* \w l|strong="G2532"\w*’\w avait|strong="G2532"\w* promis \w à|strong="G1519"\w* \w nos|strong="G2532"\w* \w pères|strong="G3962"\w*)  
