\id JUD  
\h Judas 
\toc1 YA'A KUU CARTA JA NI CHAA SAN JUDAS APOSTOL NUU TAKA ÑAYƗVƗ KAKANDIJA 
\toc2 Judas 
\toc3 Jud. 
\mt2 LA EPISTOLA UNIVERSAL DE SAN JUDAS APOSTOL 
\mt1 YA'A KUU CARTA JA NI CHAA SAN JUDAS APOSTOL NUU TAKA ÑAYƗVƗ KAKANDIJA 
\c 1  
\p  
\v 1 Máá‑rí kúu Judas ñani̱ Jacobo, te mozo Jesucristo kúu‑ri̱. Te cháa‑ri̱ tutu̱ yá'a nuu̱ róó, ña̱yɨvɨ ní kana‑ya̱ xiní, ja̱ ní ndundoo‑ró ní sá'a Táa̱‑yo̱ Dios. Te Jesucristo, ndíto va̱'a‑ya̱ róó.  
\v 2 Tu̱'un kuaká'nu ini̱, jíín tú'un vindáa̱ vinené, jíín tú'un kúndá'ú ini̱ tá'an ná ndeá‑ga̱ nuu̱‑ro̱ sá'a‑ya̱. 
\s1 Ná kuíñi ni̱'in‑yó jíín tú'un kándíja 
\p  
\v 3 Ñáni̱ máni̱ jíná'an‑ró, xaa̱n jítú iní‑ri̱ chaa‑ri̱ tu̱'un nuu̱‑ro̱ ndasa ni̱ nama‑ya̱ yóó jíná'an‑yó. Ko ni̱ jini̱‑ri̱ ja̱ jínu ñú'ún já cháa‑ri̱ tutu̱ nuu̱‑ro̱ já má kuá'a‑ró tú'un stɨ́vɨ́‑i tu̱'un kákandíja‑yó, ja̱ ɨ́ɨn jínu‑ni ni̱ ja̱'a‑ya̱ tú'un‑ún nuu̱ ñáyɨvɨ ndóo.  
\v 4 Chi̱ yaku̱ ña̱yɨvɨ, ni̱ kɨ̱vɨ koyo sa̱'í‑i. Te tú káchiñú'ún‑i Dios. Te ni̱ ka̱nasama‑i tu̱'un luu íó ini̱ Dios máá‑yó, ni̱ ka̱nasá'a‑i tu̱'un kuáxán. Te suni tú kájatá'ú‑i máá Jíto'o̱‑yo̱ Jesucristo, ni Dios ja̱ máá ɨ́ɨn‑ni‑ya̱ tá'ú tíñu. Ko ña̱yɨvɨ yá'a, onde̱ aná'án a ni̱ kundaa̱ ja̱ tá'nu̱ ndatu̱‑i. 
\s1 Dios kúu I'a̱ sándaa̱ tiñu sɨkɨ́ cháa ñáá ii̱ 
\p  
\v 5 Te vina, va̱sa a ni̱ kajini̱ va̱'a‑ró, ko ná náxndáku‑ri̱ nuu̱‑ro̱ ndasa ni̱ sá'a máá‑yá. Chi va̱sa a ni̱ nama‑ya̱ ñáyɨvɨ iní ñuu̱ Egipto, ko kúkuéé‑ga̱, te ni̱ xnáa‑yá sava‑i ja̱ tú ní kákandíja‑i.  
\v 6 Te ndajá'a̱‑yá ja̱ ní ka̱skéndo̱o tiñu kándi̱so, te suni ni̱ ka̱skéndo̱o ve'e káxiu̱kú, ni̱ ju'ni̱‑ya̱ ndájá'a̱‑ún jíín cadena nɨ́ɨ́ káni, káxiu̱kú chíi ñu̱ñáa onde̱ kɨvɨ̱ ká'nu ja̱ cháa̱ juicio.  
\v 7 Suni ni̱ ndo'o ñuu̱ Sodoma jíín ñúu̱ Gomorra jíín sáva‑ga̱ ñuu̱ ni̱ ka'i̱in yani. Chi ña̱yɨvɨ ñúu̱‑ún, suni súan ni̱ ka̱jika téné‑i, te sɨ́ɨn ku̱ñu kuáxán ní ka̱ndúkú‑i. Te ñuu̱‑ún kúu ɨɨn ja̱ ná kóto nchaa̱‑yo̱, chi ni̱ ka̱ndo'o‑i juicio nuu̱ ñú'u̱n nɨ́ɨ́ káni.  
\v 8 Te suni modo súan kásá'a ña̱yɨvɨ yá'a, chi̱ jíín tú'un ká'a̱n ja̱ni jíín‑i, te kásáchá'án‑i yikɨ kúñu‑i, kásákátá‑i nuu̱ cháa ndíso tíñu, te káka'a̱n ndɨva̱'a‑i sɨkɨ̱ já kákuñá'nu.  
\v 9 Te Miguel, ndajá'a̱ ñá'nu‑ga̱, hora ja̱ ní státá'an‑ya̱ jíín kuí'na̱ sɨkɨ́ yíkɨ kúñu Moisés, tú ní chúndéé iní‑ya̱ náku̱xndíi‑ya̱ sɨkɨ́ kuí'na̱‑ún, ja̱ ká'a̱n ndɨva̱'a‑ya̱, chi̱ sua ni̱ ka'a̱n‑ya̱: Máá Tatá Dios, ná kána jíín‑yá nuu̱‑ro̱, áchí‑ya̱.  
\v 10 Ko ña̱yɨvɨ yá'a káka'a̱n ndɨva̱'a‑i sɨkɨ̱ táká ja̱ tú kájuku̱'un ini̱‑i. Te tu̱'un kájini̱ máá‑i ja̱ máá‑i, nátu̱'un kɨtɨ yúkú‑ni, jíín tú'un yúan te naa‑í.  
\v 11 Naka̱ ndá'ú koo máá‑i, chi̱ a kája'a̱n‑i ichi ní kandii̱ Caín. Te ni̱ katau̱‑i kája'a̱n‑i yata̱ sá'a̱n ñáá Balaam náva̱'a ni'i̱n‑í na̱jíín sɨkɨ́‑ún. Te suni kánaa‑í jíín tú'un já'a̱ ini̱ Coré.  
\v 12 Ña̱yɨvɨ yá'a, nuu̱ káyee‑í jíín‑ró, te kákuu‑i ɨɨn cha'a̱n núu̱ káyee maní‑ro̱. Te tú káyu̱'ú‑i koto va̱'a‑i máá‑i ja̱ skée‑í máá‑i. Viko̱ já tú ndíso sau̱ kákuu‑i, ja̱ ndéché‑ni sá'a tachi̱. Yunu já tú kúun nde'e̱ víko saú kákuu‑i, uu̱ jínu ni̱ kaji'i̱ ja̱ ní tu'un onde̱ yo'o.  
\v 13 Su'ma̱ mar ja̱ ndónda kákuu‑i. Te ti'iñu̱ mar kúu tu̱'un kuka nuu̱ iní‑i. Nátu̱'un tiñu̱ú xíní já kájika kuu sáni kákuu‑i, te ni̱ sátu̱'a‑ya̱ lugar ñu̱ñáa lúchi túún nuu̱ kúxiu̱kú‑i nɨ́ɨ́ káni.  
\v 14 Te Enoc, chi̱i tata̱ usia̱ Adán, ni̱ jani‑de tu̱'un sɨkɨ̱ ñáyɨvɨ yá'a: A ni̱ chaa̱ máá Tatá Dios jíín kuá'a̱ xáa̱n ñáyɨvɨ ndóo‑ya̱,  
\v 15 náva̱'a sándaa̱‑ya̱ tíñu ta̱ká ña̱yɨvɨ, te naku̱xndíi‑ya̱ sɨkɨ́ táká ña̱yɨvɨ já tú káchiñú'ún‑i‑ya̱, chi ni̱ ka̱sá'a‑i tiñu ñáá, kua̱chi ja̱ tú ní káchiñú'ún‑i‑ya̱. Te suni kua'a̱ tú'un ndɨva̱'a ni̱ kaka'a̱n‑i sɨkɨ̱‑yá, áchí‑de.  
\v 16 Ña̱yɨvɨ yá'a, kákutuku ini̱‑i, te káka'a̱n ndɨva̱'a‑i na̱ni ja̱ káta'a̱n‑i, te kásá'a‑i ndéni kaní ini̱ máá‑i. Káka'a̱n ni̱'in‑i ja̱ kánda̱a téyíí‑i, te vixi̱ káka'a̱n‑i náva̱'a ni'i̱n‑í na̱jíín.  
\v 17 Ko máá‑ró, ñáni̱ máni̱, ná nándaku ini̱‑ro̱ tú'un ni̱ kaka'a̱n cha̱a ni̱ ka̱kuu apóstol máá Jíto'o̱‑yo̱ Jesucristo.  
\v 18 Chi ni̱ kaka'a̱n‑de: Onde̱ kɨvɨ̱ ndɨ́'ɨ‑na̱ te koo ña̱yɨvɨ sákátá núu̱‑ro̱. Te ña̱yɨvɨ‑ún, kaka kuu‑i ja̱ ndúkú‑i sá'a‑i tiñu ñáá ja̱ kákani̱ ini̱ máá‑i, áchí‑de.  
\v 19 Ña̱yɨvɨ yá'a kákuu ja̱ sásɨ́ɨn ña̱yɨvɨ. Ña̱yɨvɨ yúkú kákuu‑i, chi̱ tú ncháá máá Espíritu‑ya̱ iní‑i.  
\v 20 Ko máá‑ró, ñáni̱ máni̱, ná skuá'nu‑ró máá‑ró jíín tú'un ii̱ kákandíja‑ró. Te kaka̱n ta'u̱‑ro̱ jíín Espíritu Santo.  
\v 21 Ma̱ kúxio‑ró núu̱ tú'un kúndá'ú ini̱ Dios róó, te ná ndúkú‑ró já máá Jíto'o̱‑yo̱ Jesucristo, ná kúndá'ú ini̱‑ya̱ róó ja̱ kúchaku̱‑ro̱ nɨ́ɨ́ káni sá'a‑ya̱.  
\v 22 Te kundá'ú ini̱‑ro̱ sáva‑i, va̱sa kájani sɨ̱kɨ́ ini̱‑i.  
\v 23 Te nama‑ró yakú‑ga̱‑i va̱sa yú'ú‑ro̱, te nátu̱'un stáa‑ró‑i nuu̱ ñú'u̱n. Te sava‑ga̱‑i kundá'ú ini̱‑ro̱‑í, va̱sa jíto u'u̱‑ro̱ sá'ma chá'án já ní kukini ni̱ sá'a ku̱ñu‑i.  
\v 24 Te vina íó ɨɨn‑ni I'a̱ ja̱ kúu koto róó, náva̱'a tú kanangava‑ró kuáchi, te kuu sá'a‑ya̱ já kuíñi‑ró núu̱ ndíi ncháa̱ máá‑yá, jíín já má kóo chá'án‑ró, jíín já kúsɨɨ̱ xáa̱n iní‑ro̱.  
\v 25 Te nuu̱ máá ɨ́ɨn‑ni Dios, I'a̱ náma yóó, ná nákana jaa‑yó‑yá, te ná kóo ja̱ jíñú'ún‑yó núu̱‑yá. Te ná tá'ú máá‑yá tiñu jíín fuerza ndíso‑ya̱, vina te onde̱ nɨ́ɨ́ káni nɨ́ɨ́ kuiá. Súan ná kóo. Amén.