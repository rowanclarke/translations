\id JOL Biblica® Open Lingala Contemporary Bible 2020
\h Joeli
\toc1 Joeli
\toc2 Joeli
\toc3 Jo
\mt1 Joeli
\c 1
\s1 Mampinga ya mabanki
\p 
\v 1 Tala liloba oyo Yawe alobaki na nzela ya Joeli, mwana mobali ya Petueli :
\q1 
\v 2 — Bino bakambi ya bato, boyoka liloba oyo ;
\q2 bino nyonso, bavandi ya mokili,
\q1 botia matoyi mpe boyoka !
\q2 Boni, likambo ya boye esila kosalema
\q2 na tango na bino to mpe na tango ya bakoko na bino ?
\q1 
\v 3 Boyebisa yango epai ya bana na bino,
\q2 mpe tika ete bana na bino bayebisa yango
\q1 epai ya bana na bango ;
\q2 mpe bana na bango, na milongo ya bato
\q2 oyo bakoya na sima.
\q1 
\v 4 Matiti oyo mampinga ya mabanki etiki,
\q2 mabanki minene elie yango ;
\q1 oyo mabanki minene etiki,
\q2 mabanki mike elie yango ;
\q1 oyo mabanki mike etiki,
\q2 mabanki mosusu elie yango.
\q1 
\v 5 Bino balangwi masanga, bolamuka mpe bolela ;
\q2 bolela, bino nyonso bameli vino.
\q2 Pamba te babotoli bino vino ya sika na bibebu.
\q1 
\v 6 Ekolo moko ya bapaya ebundisi mokili na Ngai,
\q2 ezali na nguya makasi mpe bakokoka te kotanga
\q1 motango ya bato na yango.
\q2 Minu na yango ezali lokola minu ya nkosi ya mobali,
\q2 mpe mbanga na yango, lokola mbanga ya nkosi ya mwasi.
\q1 
\v 7 Ekolo yango ekomisi elanga na Ngai ya vino
\q2 lokola esobe mpe ekati-kati banzete na Ngai ya figi,
\q1 elongoli banzete na Ngai nyonso baposo,
\q2 ebwaki yango mpe etiki bitape na yango pembe.
\q1 
\v 8 Bosala matanga lokola elenge mwasi oyo alati pili
\q2 mpo na kolela mobandami na ye.
\q1 
\v 9 Makabo ya bambuma mpe ya masanga
\q2 ezali kopesama lisusu te na Tempelo ya Yawe.
\q2 Banganga-Nzambe, basali ya Nkolo, bazali na matanga.
\q1 
\v 10 Bilanga ebebisami, mabele ekawuki,
\q2 mbuma ya ble ezali lisusu te,
\q2 vino esili mpe mafuta ezali lisusu te.
\q1 
\v 11 Bino basali bilanga, bozala na soni ;
\q2 bino baloni vino, bolela mpo na mbuma ya ble mpe ya orje,
\q2 pamba te milona ebebisami.
\q1 
\v 12 Bilanga ya vino ekawuki,
\q2 banzete ya figi elembi-lembi,
\q1 banzete ya grenade, ya mbila mpe ya pome,
\q2 banzete nyonso ya bilanga esili kokawuka.
\q2 Solo, esengo ya bato esili.
\s1 Kobengama mpo na kobongola motema
\q1 
\v 13 Oh bino Banganga-Nzambe,
\q2 bolata basaki mpe bolela.
\q1 Bino bato oyo bosalaka na etumbelo, bolela.
\q2 Bino basali ya Nzambe na ngai, boya,
\q1 bolata basaki butu mobimba.
\q2 Pamba te makabo ya bambuma mpe ya masanga
\q2 ezali kopesama lisusu te na Ndako ya Nzambe na bino.
\q1 
\v 14 Bopanza sango ya kokila bilei,
\q2 bobengisa bato na mayangani ya bule,
\q1 bobengisa bakambi mpe bavandi nyonso ya mokili
\q2 ete baya na Ndako ya Nzambe na bino
\q2 mpe bolela epai na Yawe.
\b
\q1 
\v 15 Mawa na mokolo wana !
\q2 Pamba te mokolo ya Yawe ekomi pene ;
\q1 ekoya lokola libebi
\q2 oyo ewuti epai na Nkolo-Na-Nguya-Nyonso.
\b
\q1 
\v 16 Boni, wuta na Ndako ya Nzambe mpe na miso na biso,
\q2 balongoli te bilei, esengo mpe kosepela ?
\q1 
\v 17 Bankona ekawuki na se ya mabele,
\q2 bibombelo etikali lisusu na eloko te,
\q1 bibombelo ya bambuma ebukani
\q2 mpo ete ble ezali lisusu te.
\q1 
\v 18 Tika ete ngombe elela !
\q2 Bibwele ekomi kotelengana,
\q1 pamba te matiti ya kolia etikali lisusu te ;
\q2 ezala bameme to bantaba ekomi na pasi.
\b
\q1 
\v 19 Oh Yawe, Yo nde nazali kobelela,
\q2 pamba te moto ezikisi matiti mpe banzete nyonso ya bilanga.
\q1 
\v 20 Ezala banyama ya zamba ezali kotalela Yo,
\q2 pamba te miluka ekawuki
\q2 mpe moto ezikisi bilanga.
\c 2
\s1 Mokolo ya Nkolo
\q1 
\v 1 Bobeta kelelo na Siona !
\q2 Bobelela na likolo ya ngomba na Ngai ya bule !
\q1 Tika ete bavandi nyonso ya mokili balenga,
\q2 pamba te mokolo ya Yawe ezali koya ;
\q2 solo, ekomi penza pene.
\q1 
\v 2 Ezali mokolo ya butu mpe ya molili makasi,
\q2 mokolo ya londende mpe ya mapata ya mwindo.
\q1 Ndenge pole ya tongo epanzanaka na bangomba,
\q2 ndenge wana mpe mampinga moko
\q1 ya basoda ebele mpe ya mpiko ezali koya.
\q2 Makambo ya boye etikala nanu kosalema te na kala
\q2 mpe ekotikala kosalema te na mikolo oyo ekoya.
\b
\q1 
\v 3 Liboso na bango, moto ezali kotumba ;
\q2 sima na bango, moto ezali kozikisa.
\q1 Liboso na bango, mokili ezali lokola elanga ya Edeni,
\q2 mpe sima na bango, lokola esobe.
\q2 Solo, ata eloko moko te ekotikala.
\q1 
\v 4 Bazali lokola bampunda ;
\q2 bapumbwaka lokola basoda
\q2 oyo batambolaka likolo ya bampunda.
\q1 
\v 5 Batambolaka likolo ya basonge ya bangomba
\q2 na makelele makasi lokola makelele ya bashar,
\q1 lokola makelele ya matiti oyo ezali kozika,
\q2 lokola mampinga moko ya basoda ya mpiko
\q2 oyo babongami mpo na kokende na bitumba.
\q1 
\v 6 Soki bamoni bango,
\q2 bato ya bikolo bakomaka na somo
\q2 mpe bilongi nyonso ekawukaka.
\q1 
\v 7 Bakimaka lokola bilombe,
\q2 bapumbwaka bamir lokola basoda ya mpiko,
\q2 batambolaka nzela moko, batengamaka te.
\q1 
\v 8 Batutanaka te bango na bango,
\q2 moko na moko alandaka kaka nzela na ye.
\q1 Badusolaka na kati-kati ya bibundeli ya banguna,
\q2 mpe eloko moko te ekangaka bango nzela.
\q1 
\v 9 Bawelelaka kokota kati na engumba,
\q2 bapotaka mbangu pene ya mir,
\q1 bakotaka na bandako
\q2 ndenge miyibi bakotaka na nzela ya maninisa.
\q1 
\v 10 Mokili eninganaka liboso na bango,
\q2 Lola elengaka,
\q1 moyi mpe sanza eyindaka,
\q2 minzoto etikaka kongenga.
\q1 
\v 11 Yawe azali koganga lokola kake
\q2 na liboso ya mampinga na Ye.
\q1 Milongo ya mampinga na Ye etonda na basoda ;
\q2 basoda oyo batosaka mitindo na Ye bazali na nguya.
\q1 Mokolo ya Yawe ezali monene,
\q2 ezali somo makasi ;
\q2 nani akoki kotelema na mokolo yango ?
\s1 Kozonga epai na Yawe
\q1 
\v 12 « Ezala sik’oyo, » elobi Yawe,
\q2 « bozonga epai na Ngai na mitema na bino mobimba,
\q2 na kokila bilei, na mpinzoli mpe na kolela. »
\b
\q1 
\v 13 Bopasola mitema na bino, kasi bilamba na bino te.
\q2 Bozonga epai na Yawe, Nzambe na bino,
\q1 pamba te atonda na ngolu mpe na mawa,
\q2 asilikaka noki te mpe atonda na bolingo,
\q2 abongolaka mokano na Ye ya kotindela bato pasi.
\q1 
\v 14 Nani ayebi soki akoki
\q2 kobongola makanisi to koyoka mawa
\q1 mpe kotika na sima na Ye lipamboli,
\q2 mpo ete bokoka lisusu kobonzela Yawe, Nzambe na bino,
\q2 makabo ya bambuma to makabo ya masanga ya vino ?
\b
\q1 
\v 15 Bobeta kelelo na Siona !
\q2 Bopanza sango ya mokolo ya bule ya kokila bilei
\q2 mpe bobengisa mayangani ya bule.
\q1 
\v 16 Bosangisa bato, bobulisa mayangani,
\q2 bosangisa bakambi mpe bana,
\q1 ezala oyo bazali nanu komela mabele.
\q2 Tika ete elenge mobali oyo abali sika
\q1 atika shambre na ye ya libala,
\q2 mpe elenge mwasi oyo abali sika
\q2 atika mpe shambre na ye ya libala.
\q1 
\v 17 Tika ete Banganga-Nzambe oyo basalelaka Yawe
\q2 balela na kati-kati ya ndako moke ya kokotela mpe etumbelo.
\q1 Tika ete baloba : « Oh Yawe, bikisa bato na Yo,
\q2 kokomisa te libula na Yo eloko ya kotiola
\q1 to eloko ya maseki kati na bikolo.
\q2 Mpo na nini bato ya bikolo mosusu baloba :
\q2 ‹ Wapi Nzambe na bango ? › »
\s1 Eyano ya Yawe
\q1 
\v 18 Yawe akotonda na zuwa mpo na mokili na Ye
\q2 mpe akoyokela bato na Ye mawa.
\q1 
\v 19 Yawe akoyanola mpe akoloba na bango :
\q2 « Nakotindela bino ble, vino ya sika mpe mafuta ;
\q1 bongo bokotonda yango.
\q2 Nakokomisa bino lisusu te
\q2 eloko ya kotiola kati na bikolo.
\q1 
\v 20 Nakotindika monguna ya nor mosika na bino,
\q2 nakomema ye na mokili ekawuka mpe ezanga eloko ;
\q1 bongo basoda na ye, oyo bazalaka na liboso
\q2 bakozinda na ebale monene ya este ;
\q1 mpe oyo bazalaka na sima, na ebale monene ya weste.
\q2 Solo na ye ya kopola ekoyokana,
\q2 kobeba na ye ekopanzana. »
\b
\q1 Solo, asali makambo minene.
\q1 
\v 21 Oh mabele, kobanga te,
\q2 zala na esengo mpe sepela,
\q2 pamba te Yawe asali makambo minene.
\q1 
\v 22 Banyama ya zamba, bobanga te,
\q2 pamba te matiti eboti lisusu na elanga,
\q1 banzete eboti lisusu bambuma ;
\q2 banzete ya figi mpe ya vino eboti bambuma ebele penza.
\q1 
\v 23 Bosepela, bino bato ya Siona,
\q2 bosepela kati na Yawe, Nzambe na bino,
\q1 pamba te apesi bino mvula mpo na kobikisa bino.
\q2 Akonokisela bino bamvula minene
\q1 na eleko ya mvula mpe na eleko ya elanga,
\q2 ndenge ezalaki liboso.
\q1 
\v 24 Etando oyo batutelaka ble ekotonda na bambuma,
\q2 banzungu ekotonda na vino mpe na mafuta.
\q1 
\v 25 Nakozongisela bino mibu
\q2 oyo mampinga minene ya mankoko, ya makelele,
\q1 ya mabanki minene mpe ya bambinzo eliaki :
\q2 mampinga minene na Ngai oyo natindaki
\q2 mpo na kobundisa bino.
\q1 
\v 26 Bokolia bilei ebele mpe bokotonda,
\q2 bongo bokokumisa Kombo ya Yawe, Nzambe na bino,
\q1 oyo asaleli bino makambo ya kokamwa :
\q2 bato na Ngai bakotikala koyoka lisusu soni te.
\q1 
\v 27 Boye bokoyeba solo ete Ngai, nazali kati na Isalaele,
\q2 ete nazali Yawe, Nzambe na bino,
\q1 mpe ete Nzambe mosusu azali te.
\q2 Bato na Ngai bakotikala koyoka lisusu soni te.
\c 3
\s1 Tango Yawe akosopa Molimo na Ye
\q1 
\v 1 Sima na makambo oyo,
\q2 nakosopa Molimo na Ngai kati na bato nyonso.
\q1 Bana na bino ya mibali mpe ya basi bakosakola,
\q2 mibange na bino bakolota bandoto,
\q2 bilenge na bino bakozwa bimoniseli.
\q1 
\v 2 Ata mpe kati na basali na Ngai ya mibali mpe ya basi,
\q2 nakosopa Molimo na Ngai, na mikolo wana.
\q1 
\v 3 Nakolakisa bino bilembo ya kokamwa,
\q2 na likolo mpe na mokili :
\q2 makila, moto mpe makonzi ya milinga.
\q1 
\v 4 Moyi ekobongwana molili,
\q2 mpe sanza ekobongwana makila,
\q2 liboso ete mokolo ya Yawe ekoma,
\q2 mokolo oyo ya monene mpe ya somo.
\q1 
\v 5 Bongo moto nyonso oyo akobelela Kombo ya Yawe akobikisama ;
\q2 pamba te na ngomba Siona mpe na Yelusalemi,
\q1 ekozala na bato oyo bakobika,
\q2 kolanda ndenge Yawe alobaki,
\q1 mpe bato oyo Yawe akobenga
\q2 bakozala kati na bato oyo bakobika.
\c 4
\s1 Nzambe akosambisa bikolo
\q1 
\v 1 « Na mikolo mpe na tango wana,
\q2 tango nakozongisa bakangami ya Yuda mpe ya Yelusalemi,
\q1 
\v 2 nakosangisa bato ya bikolo nyonso
\q2 mpe nakokitisa bango na lubwaku ya Jozafati.
\q1 Nakosambisa bango kuna
\q2 na tina na libula na Ngai, Isalaele, bato na Ngai ;
\q1 pamba te bapanzi bato na Ngai kati na bikolo
\q2 mpe bakaboli mokili na Ngai.
\q1 
\v 3 Babeti zeke mpo na kokabola bato na Ngai,
\q2 bapesi bilenge mibali basi ya ndumba,
\q1 bateki bilenge basi mpo na kozwa kaka vino,
\q2 mpe balangwe yango.
\q1 
\v 4 Eh bongo bino, Tiri mpe Sidoni,
\q2 bituka ya bato ya Filisitia,
\q1 likambo nini lisusu kati na Ngai mpe bino ?
\q2 Bolingi kozongisela Ngai mabe to kotombokela Ngai ?
\q1 Soki yango nde ezali makanisi na bino,
\q2 Ngai nde nasengeli kozongisela bino mabe na lombangu.
\q1 
\v 5 Pamba te bozwaki palata mpe wolo na Ngai,
\q2 bomengo na Ngai ya motuya makasi
\q2 mpe bomemaki yango na batempelo na bino.
\q1 
\v 6 Botekaki bato ya Yuda mpe ya Yelusalemi epai ya Bagreki
\q2 mpo na komema bango mosika ya mokili na bango.
\q1 
\v 7 Ngai moko nakopesa bango makasi
\q2 mpo ete babima na bisika nyonso
\q2 epai wapi botekaki bango.
\q1 
\v 8 Nakoteka bana na bino ya mibali mpe ya basi
\q2 epai ya bato ya Yuda,
\q1 mpe bango bakoteka bango epai ya bato ya Sabe,
\q2 ekolo ya mosika penza, »
\q2 elobi Yawe.
\s1 Etumbu mpe kosambisama
\q1 
\v 9 « Bosakola likambo oyo kati na bikolo :
\q2 Bobulisa mampinga mpo na bitumba !
\q1 Bolamusa bilombe !
\q2 Tika ete bilombe nyonso ya bitumba bapusana mpe baya !
\q1 
\v 10 Bosala mipanga, na nzela ya bakongo na bino ;
\q2 mpe makonga, na nzela ya bipasola na bino !
\q1 Tika ete moto na bolembu aloba :
\q2 ‹ Nazali makasi. ›
\q1 
\v 11 Bino bikolo nyonso ya zingazinga,
\q2 boya na lombangu mpe bosangana !
\b
\q1 Oh Yawe, kitisa bilombe na Yo !
\b
\q1 
\v 12 Tika ete bikolo nyonso elamuka mpe emata
\q2 kino na lubwaku ya Jozafati !
\q1 Pamba te kuna nde nakovanda mpo na kosambisa
\q2 bikolo nyonso ya zingazinga.
\q1 
\v 13 Bosimba bambeli, pamba te bambuma eteli.
\q2 Boya, bokamola bambuma ya vino,
\q1 pamba te ekamolelo etondi,
\q2 banzungu etondi,
\q2 mabe na bango eleki ndelo.
\q1 
\v 14 Bato bazali ebele, ebele penza,
\q2 na lubwaku ya kosambisama.
\q1 Mokolo ya Yawe ekomi pene,
\q2 na lubwaku ya kosambisama.
\q1 
\v 15 Sanza mpe moyi ekoyinda,
\q2 minzoto ekongenga lisusu te.
\q1 
\v 16 Wuta na Siona, Yawe akoloba makasi ;
\q2 wuta na Yelusalemi, akoloba na mongongo makasi lokola kake ;
\q1 Lola mpe mabele ekoningana.
\q2 Kasi Yawe akozala ekimelo mpo na bato na Ye,
\q2 engumba batonga makasi mpo na bana ya Isalaele.
\s1 Yawe apamboli bato na Ye
\q1 
\v 17 Boye, bokoyeba solo ete Ngai nazali Yawe, Nzambe na bino ;
\q2 navandaka na Siona, ngomba na Ngai ya bule.
\q1 Yelusalemi ekozala engumba ya bule,
\q2 bapaya bakolekela lisusu wana te.
\q1 
\v 18 Na mokolo wana, bangomba ekotangisa vino ya sika,
\q2 mpe miliki ekotanga na bangomba mikuse.
\q1 Miluka nyonso ya Yuda ekotonda na mayi,
\q2 etima moko ya mayi ekobima wuta na Tempelo ya Yawe
\q2 mpe ekosopela lubwaku ya banzete ya akasia mayi.
\q1 
\v 19 Kasi mokili ya Ejipito ekobebisama,
\q2 mokili ya Edomi ekokoma esobe
\q1 mpo na makambo mabe oyo basalaki epai ya bato ya Yuda,
\q2 pamba te basopaki makila ya bato ya Yuda
\q2 na mabele na bango, atako basalaki mabe te.
\q1 
\v 20 Bato bakokoma kovanda na mokili ya Yuda mpo na libela,
\q2 mpe na engumba Yelusalemi, libela na libela.
\q1 
\v 21 Nakopetola bino mpo na ngambo ya makila,
\q2 mpo ete nanu napetola bino te. »
\qc Yawe akovanda na Siona.
