\p
\v 15 \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* sus antepasados, \w les|strong="H5921"\w* \w envió|strong="H7971"\w* sus \w mensajeros|strong="H4397"\w*, \w porque|strong="H3588"\w* \w Él|strong="H5921"\w* \w se|strong="H5921"\w* compadecía \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* vivienda.  
\v 16 Pero ellos \w se|strong="H1961"\w* burlaron \w de|strong="H5704"\w* \w los|strong="H1961"\w* \w mensajeros|strong="H4397"\w* \w de|strong="H5704"\w* \nd ʼElohim\nd* \w y|strong="H5704"\w* despreciaron la \w Palabra|strong="H1697"\w* \w de|strong="H5704"\w* \w Él|strong="H5030"\w*. \w Se|strong="H1961"\w* burlaban \w de|strong="H5704"\w* sus \w profetas|strong="H5030"\w* \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* la \w ira|strong="H2534"\w* \w de|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w se|strong="H1961"\w* encendió \w contra|strong="H1961"\w* su \w pueblo|strong="H5971"\w* \w y|strong="H5704"\w* \w no|strong="H1961"\w* \w hubo|strong="H1961"\w* \w remedio|strong="H4832"\w*.  
\v 17 Entonces \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w caldeos|strong="H3778"\w* \w subió|strong="H5927"\w* \w contra|strong="H5921"\w* \w ellos|strong="H3027"\w* \w y|strong="H5921"\w* \w mató|strong="H2026"\w* \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* sus jóvenes \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* su \w Santuario|strong="H4720"\w*. \w No|strong="H3808"\w* tuvo compasión \w del|strong="H5921"\w* joven, \w la|strong="H5921"\w* doncella, \w el|strong="H5921"\w* \w anciano|strong="H2205"\w* \w ni|strong="H3808"\w* \w el|strong="H5921"\w* débil. \w A|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w entregó|strong="H5414"\w* \w en|strong="H5921"\w* su \w mano|strong="H3027"\w*.  
\v 18 Llevó \w a|strong="H3068"\w* Babilonia \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios \w de|strong="H8269"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H8269"\w* \nd ʼElohim\nd*, \w grandes|strong="H1419"\w* y \w pequeños|strong="H6996"\w*, y \w los|strong="H3605"\w* tesoros \w de|strong="H8269"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H8269"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* y \w los|strong="H3605"\w* del \w rey|strong="H4428"\w* y \w de|strong="H8269"\w* sus \w jefes|strong="H8269"\w*.  
\v 19 Quemaron \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd ʼElohim\nd* y \w destruyeron|strong="H7843"\w* \w el|strong="H3605"\w* \w muro|strong="H2346"\w* de Jerusalén. Incendiaron \w todos|strong="H3605"\w* \w los|strong="H3605"\w* edificios fortificados y \w destruyeron|strong="H7843"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* objetos valiosos \w que|strong="H3605"\w* había en \w ella|strong="H3605"\w*.   
\p
\v 20 \w A|strong="H3068"\w* \w los|strong="H1121"\w* \w que|strong="H4480"\w* escaparon \w de|strong="H4480"\w* la \w espada|strong="H2719"\w* \w los|strong="H1121"\w* llevó \w cautivos|strong="H1540"\w* \w a|strong="H3068"\w* Babilonia, \w y|strong="H5704"\w* \w fueron|strong="H1961"\w* esclavos \w de|strong="H4480"\w* \w él|strong="H1121"\w* \w y|strong="H5704"\w* sus \w hijos|strong="H1121"\w* \w hasta|strong="H5704"\w* \w cuando|strong="H5704"\w* \w se|strong="H1961"\w* impuso \w el|strong="H1121"\w* \w reino|strong="H4427"\w* \w de|strong="H4480"\w* \w Persia|strong="H6539"\w*,  
\v 21 \w para|strong="H5704"\w* \w que|strong="H5704"\w* se cumpliera \w la|strong="H3605"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w por|strong="H1697"\w* \w boca|strong="H6310"\w* \w de|strong="H5704"\w* \w Jeremías|strong="H3414"\w*, \w hasta|strong="H5704"\w* \w cuando|strong="H3117"\w* \w la|strong="H3605"\w* tierra disfrutó sus \w sábados|strong="H7676"\w*. Guardó \w sábado|strong="H7676"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w tiempo|strong="H3117"\w* \w de|strong="H5704"\w* \w la|strong="H3605"\w* desolación \w hasta|strong="H5704"\w* cumplirse 70 \w años|strong="H8141"\w*.   
\p
\v 22 En \w el|strong="H3605"\w* primer \w año|strong="H8141"\w* \w de|strong="H1697"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Persia|strong="H6539"\w*, para \w que|strong="H1571"\w* se cumpliera \w la|strong="H1571"\w* \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* pronunciada \w por|strong="H1697"\w* \w boca|strong="H6310"\w* \w de|strong="H1697"\w* \w Jeremías|strong="H3414"\w*, \nd \+w Yavé|strong="H3068"\+w*\nd* \w despertó|strong="H5782"\w* \w el|strong="H3605"\w* \w espíritu|strong="H7307"\w* \w de|strong="H1697"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Persia|strong="H6539"\w*, \w quien|strong="H3605"\w* hizo \w pregonar|strong="H5674"\w* \w por|strong="H1697"\w* escrito en \w todo|strong="H3605"\w* su \w reino|strong="H4438"\w*:   
\p
\v 23 \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*, dice: \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H1931"\w* \nd ʼElohim\nd* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w me|strong="H5921"\w* \w dio|strong="H5414"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* tierra \w y|strong="H5921"\w* \w me|strong="H5921"\w* designó \w para|strong="H5921"\w* \w que|strong="H4310"\w* \w le|strong="H1931"\w* construya una \w Casa|strong="H1004"\w* \w en|strong="H5921"\w* Jerusalén, \w que|strong="H4310"\w* \w está|strong="H1931"\w* \w en|strong="H5921"\w* \w Judá|strong="H3063"\w*. \w El|strong="H1931"\w* \w que|strong="H4310"\w* \w de|strong="H5921"\w* ustedes sea \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*, \w que|strong="H4310"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w su|strong="H1931"\w* \nd ʼElohim\nd* sea \w con|strong="H5973"\w* \w él|strong="H1931"\w*, \w y|strong="H5921"\w* \w suba|strong="H5927"\w*.   