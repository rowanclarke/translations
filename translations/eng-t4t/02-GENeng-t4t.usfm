\v 22 \w Then|strong="H1961"\w* \w Yahweh|strong="H3068"\w* said, “\w Look|strong="H2005"\w*! \w Those|strong="H4480"\w* \w two|strong="H3947"\w* \w have|strong="H1961"\w* \w become|strong="H1961"\w* \w like|strong="H1961"\w* \w us|strong="H3045"\w* \w because|strong="H4480"\w* \w they|strong="H3068"\w* \w know|strong="H3045"\w* \w what|strong="H2896"\w* \w is|strong="H3068"\w* \w good|strong="H2896"\w* \add to do\add* \w and|strong="H3068"\w* \w what|strong="H2896"\w* \w is|strong="H3068"\w* \w evil|strong="H7451"\w* \add to do\add*. \w So|strong="H4480"\w* \w now|strong="H6258"\w*, \w it|strong="H3045"\w* \w will|strong="H3068"\w* \w not|strong="H3045"\w* \w be|strong="H1961"\w* \w good|strong="H2896"\w* \w if|strong="H2005"\w* \w they|strong="H3068"\w* \w reach|strong="H1961"\w* \w out|strong="H7971"\w* \w and|strong="H3068"\w* \w pick|strong="H3947"\w* \w and|strong="H3068"\w* eat \add some of the fruit from\add* \w the|strong="H3947"\w* \w tree|strong="H6086"\w* \add which enables people who eat it\add* \w to|strong="H3068"\w* \w live|strong="H2416"\w* \add forever\add*!”
