\v 11 ЖЃeЙ“ayi mavofodaiti undЙ”zita puufele maazu saК‹agЙ” (623),
\li2 
\v 12 Azagade mavofodaiti waagila unfele puufele maazu felegЙ” (1.222),
\li2 
\v 13 Adonikame mavofodaiti undЙ”zita puulЙ”zita maazu lЙ”zita (666),
\li2 
\v 14 ЖЃigivayi mavofodaiti waafelegЙ” puulЙ”Й”lugЙ” maazu lЙ”zita (2.056),
\li2 
\v 15 Adin mavofodaiti unnaani puulЙ”Й”lu maazu naanigЙ” (454),
\li2 
\v 16 AtЙ›Й›l mavofodaiti, Ezekiase naМЃ-pЙ›lЙ›yeЙ ei wu puutaaК‹uu maazu lЙ”saК‹a (98),
\li2 
\v 17 ЖЃesayi mavofodaiti unsaК‹agЙ” puufele maazu saК‹agЙ” (323),
\li2 
\v 18 Yola mavofodaiti ungila puugЙ” maazu felegЙ” (112),
\li2 
\v 19 Ж“asume mavofodaiti unfelegЙ” puufele maazu saК‹agЙ” (223),
\li2 
\v 20 GiЙ“aal mavofodaiti puutaaК‹uugЙ” maazu lЙ”Й”lugЙ” (95),
\li2 
\v 21 ЖЃЙ›teleyЙ›me nuiti ungila puufele maazu saК‹agЙ” (123),
\li2 
\v 22 Netofa nuiti puulЙ”Й”lu maazu lЙ”zita (56),
\v 23 AnatЙ”te nuiti ungila puufele maazu lЙ”saК‹a (128),
\li2 
\v 24 AzamavЙ›te nuiti puunaani maazu felegЙ” (42),
\li2 
\v 25 Kiliyate-Yeyalime nuiti, ta Kefila nuiti, naa К‹Й›Й› ЖЃeyelЙ”te nuiti ba, undЙ”fela puunaani maazu saК‹agЙ” (743),
\li2 
\v 26 Lama nuiti ta GeЙ“a nuiti undЙ”zita puufele maazu Й ila (621),
\li2 
\v 27 Mikemase nuiti ungila puufele maazu felegЙ” (122),
\li2 
\v 28 ЖЃetЙ›le nuiti ta Ayi nuiti unfelegЙ” puufele maazu saК‹agЙ” (223),
\li2 
\v 29 NeЙ“o nuiti puulЙ”Й”lu maazu felegЙ” (52),
\li2 
\v 30 MagaЙ“ise mavofodaiti ungila puulЙ”Й”lu maazu lЙ”zita (156),
\li2 
\v 31 Elame zЙ”i mavofodaiti waagila unfele puulЙ”Й”lu maazu naanigЙ” (1.254),
\li2 
\v 32 Ж“alime mavofodaiti unsaК‹agЙ” puufele (320),
\li2 
\v 33 Lode, ta Ж“adide, naa К‹Й›Й› Wono nuiti ba undЙ”fela puufele maazu lЙ”Й”lugЙ” (725),
\li2 
\v 34 Zeliko nuiti unsaК‹agЙ” puunaani maazu lЙ”Й”lugЙ” (345),
\li2 
\v 35 Senaa nuiti waasaК‹agЙ” undЙ”zita puusaК‹agЙ” (3.630).
\b
\li1 
\v 36 ZalaЙ a Й ula nuiti tetegi:
\li2 Yedaya naМЃ-doun zunuiti, Zozuwe naМЃ-pЙ›lЙ›yeЙ ei wu untaaК‹uugЙ” puulЙ”fela maazu saК‹agЙ” (973),
\li2 
\v 37 ImЙ›Й›l mavofodaiti waagila puulЙ”Й”lu maazu felegЙ” (1.052),
\li2 
\v 38 Pasuul mavofodaiti waagila unfele puunaani maazu lЙ”fela (1.247),
\li2 
\v 39 Ж“alime mavofodaiti waagila puugЙ” maazu lЙ”fela (1.017).
\b
\li1 
\v 40 Levi nuiti tetegi zu:
\li2 Zozuwe ta KadimiyЙ›le, ta ЖЃinuwi naa К‹Й›Й› Wodavia К‹a, ti-mavofodaiti puulЙ”fela maazu naanigЙ” (74).
\b
\li1 
\v 41 Guye loo nuiti:
\li2 Azafe mavofodaiti ungila puufele maazu lЙ”saК‹a (128).
\b
\li1 
\v 42 SiЙ ida makЙ› nuiti:
\li2 Salume, ta AtЙ›Й›l, TalamЙ”n, ta AkuЙ“e, Ж“atita, ta SoЙ“ai ti-mavofodaiti ungila puusaК‹agЙ” maazu taaК‹uugЙ” (139).
\b
\li1 
\v 43 GALA sei К‹Й›lЙ›i wu wotiЙ Й› nuiti ti Й Й›ni ga niiti ti-laaseigiti ti К‹aazu, ti-mavofodaiti:
\li2 SiЙ a, Ж“asufa, TaЙ“ayЙ”te,
\v 44 KelЙ”se, SiaЙ a, PadЙ”n,
\v 45 LeЙ“ana, Ж“agaЙ“a, AkuЙ“e,
\v 46 Ж“agaЙ“e, Samelai, Ж“anan,
\v 47 GidЙ›le, GaЙ aal, Leaya,
\v 48 Lesin, Nekoda, Gazame,
\v 49 Uza, Paseya, ЖЃesayi,
\v 50 Asena, MeЙ unime, Nefusime,
\v 51 ЖЃakeЙ“uke, Ж“akufa, Ж“aaleЙ uul,
\v 52 ЖЃasalute, Meyida, Ж“aalesa,
\v 53 ЖЃaalekЙ”se, Sisela, Tama,
\v 54 Nesiya, Ж“atifa.
\b
\li1 
\v 55 SalomЙ”n naМЃ-botiЙ Й› nuiti ti-mavofodaiti ti Й Й›ni ga niiti ti-laaseigiti ti К‹aazu, naati ti-mavofodaiti:
\li2 Sotayi, SofelЙ›te, Peluda,
\v 56 Yaala, Daalakon, GidЙ›le,
\v 57 Sefatia, Ж“atile, PokЙ›lЙ›te-Ж“asebayime, Ami.
\b
\li2 
\v 58 GALA sei К‹Й›lЙ›i wu wotiЙ Й› nuiti, ta SalomЙ”n naМЃ-botiЙ Й› nuiti ti-mavofodaiti pЙ› kpЙ”ga Й Й›ni ga nu unsaК‹agЙ” puutaaК‹uu maazu felegЙ” (392).
\b
\li1 
\v 59 Tanigaa ti zeЙ eni taai niiti su ti К‹a: TЙ›le-Mela, TЙ›le-Yaalesa, KeluЙ“e-Adan, ImЙ›Й›l, kЙ›lЙ› ti la Й Й›ni zooni ti К‹a ta-wolodaiti dЙ”lЙ” ta ti-mЙ›mЙ›wolani nii eМЃ dЙ›Й›zu ga ta ga IzilayЙ›le nu, ti laaseigiti kaa:
\li2 
\v 60 Delaya, ta ToЙ“iya, ta Nekoda ti-mavofodaiti undЙ”zita puulЙ”Й”lu maazu felegЙ” (652).
\li1 
\v 61 ZalaЙ a Й ula nuiti Й“alaa saama, tanigaa ti Й Й›ni naama Й Й›К‹elei zu, naati daaseigiti kaa:
\li2 Ж“aЙ“aya ta AkЙ”se naa К‹Й›Й› ЖЃaalazilayi К‹a, ti-mavofodaiti, gaaЙ“elagi naa Galaade nui ЖЃaalazilayi laaseigi zeЙ eni mazЙ”lЙ”Й” eМЃ naa naМЃ-doun anzanui vuluni.
\p 
\v 62 SЙ›К‹Й›i nii ti-mЙ›mЙ›wolani daaseigi su, ti gaiziЙ›ni, kЙ›lЙ› ti la kaani. Naa maaК‹ele ma ti ti К‹Й›tЙ›ni ga ti la ЙІadeni, ti la Й Й›ni vaani bu, naati ti К‹a boti nЙ”pЙ› kЙ› zalaЙ a Й ulazuК‹Й›.
\v 63 Zou zЙ›К‹Й› Й undiЙ ii Й“Й”Й Й”goi ti leveni ga ti mina daamianigi naa ta mi, niiti ti veai GALA bЙ›, eyЙ›su zalaЙ a Й ula nui gila ge GALA gaazaЙ a ta-vaa zu ga wuulimegi ta tumimegi.
\b
\p 
\v 64 BЙ›bЙ›i pЙ› kpЙ”ga Й Й›ni ga nu waaК‹uunaanigЙ” maazu felegЙ” unsaК‹agЙ” puulЙ”zita (42.360).
\v 65 Ta-wotiЙ Й› nuiti, zinaa ta anzaa, ti Й Й›ni ga nu waadЙ”fela unsaК‹agЙ” puusaК‹a maazu lЙ”fela (7.337). Guye loo nuiti, zinaa ta anzaa, naati ti Й Й› ga unfelegЙ” (200).
\v 66 Sooi Й Й›ni ti ya ga undЙ”fela puusaК‹agЙ” maazu lЙ”zita (736), soovale fuului Й Й› ti ya ga unfelegЙ” puunaani maazu lЙ”Й”lugЙ” (245).
\v 67 ЖќЙ”mЙ›i Й Й›ni ga unnaanigЙ” puusaК‹agЙ” maazu lЙ”Й”lugЙ” (435), soovalegi Й Й› ga waadЙ”zita undЙ”fela puufele (6.720).
\b
\p 
\v 68 Ti zeeliai ma ZeluzalЙ›me, Ж“Й”oЙ Й” GALAGI zei К‹Й›lЙ›i naМЃ-taazuК‹Й›, pЙ›lЙ›yeЙ e Й undiЙ ii ma mЙ”inmЙ”in ti vebЙ›aniiti feeni, niiti ti daai Й isu, GALA sei К‹Й›lЙ›i lo fai zu, tosu wЙ”lЙ”mai.
\v 69 Ti ti zooda vai Й Й›Й›ni ga naavoloi pЙ›lЙ›i lo fai zu. Nii ti kulani, naa liini ga zanu kae waaК‹uulЙ”zita maazu Й ila (61.000), ta wali kilo waafelegЙ” undЙ”Й”lu (2.500). Ti tookЙ”ba ungila (100) feeni Й“alaa ga zalaЙ a Й ula nuiti ta-zeЙ eiti.
\p 
\v 70 ZalaЙ a Й ula nuiti, ta Levi nuiti, ta nuЙ“usЙ›i tanigaa, ta guye loo nuiti, ta siЙ ida makЙ› nuiti, naa К‹Й›Й› GALA sei К‹Й›lЙ›i wu wotiЙ Й› nuiti ba, ti zeini taai naati su, К‹Й›ti ti naМЃti feeni ti ya. NuЙ“usЙ›i mЙ”taiti ti zeini ta-laa wЙ”lЙ”maiti su.
\c 3
\s1 ZalaЙ a Й ulazuК‹Й› lo fai К‹olu, // GALA dЙ›bi vai lЙ”Й”zei К‹olu
\p 
\v 1 Konagi ma alugi lЙ”felasiЙ›i zeeliai ma, IzilayЙ›le nuiti kpein ti Й Й›nina zeini ta-laazuК‹Й›ti, ti pЙ› ti Й aalЙ›Й›ni ba ZeluzalЙ›me eЙ Й› nu Й ila nЙ”.
\v 2 Yosadake naМЃ-doun zunui Zozuwe, ta bЙ”Й”la zalaЙ a Й ula nuiti, naa К‹Й›Й› SeyalitiyЙ›le naМЃ-doun zunui ZoloЙ“aЙ“Й›le К‹a, ta naМЃ-bolodamaiti, ti botii lЙ”Й”zeini, ti Й—a GALA naМЃ-zalaЙ a Й ulazuК‹Й› lo К‹olu, nii a kЙ› ti Й—a gala zalaЙ aiti kula naМЃ, К‹elei sЙ›К‹Й›ai la Moize naМЃ-tЙ” sЙ›К‹Й›i zu, GALA naМЃ-nui.
\v 3 AnЙ›Й› ni ti Й Й›ni luazu nui naati ba ti К‹aani, ti zei zooi zu, ti Й Й›ai ma duЙ”lai zu, ti zalaЙ a Й ulazuК‹Й› loni tosu wЙ”lЙ”mai nЙ”, ti Й—a gala zalaЙ aiti kula Ж“Й”oЙ Й” GALAGI К‹Й›, sobui ta kpЙ”kЙ”i.
\v 4 Ti kota vЙ›tii Й ulani, eЙ Й›К‹elei sЙ›К‹Й›ai la, ti Й—a gala zalaЙ ai Й ula folo-o-folo, eМЃ zoloo zalaЙ ai liegi ma nii sЙ›К‹Й›ai folo Й ilagilagi vaa ma.
\v 5 Naa К‹oluma, ti gala zalaЙ ai Й ulani folo-o-folo, ta alu toga niinЙ›i ma vЙ›ti geleiti, ta yeeЙ Й›Й alai zЙ”iti pЙ› su geleiti ti ga Ж“Й”oЙ Й” GALAGI nЙ”nЙ”, naa К‹Й›Й› niiti kpein ba ti Й Й›Й›ni vebЙ›aniiti feezu Ж“Й”oЙ Й” GALAGI К‹Й›.
\v 6 Alugi lЙ”felasiЙ›i ma volo mЙ”ungi, ti tЙ”Й”zeini ga ti Й—a gala zalaЙ aiti kula Ж“Й”oЙ Й” GALAGI К‹Й›, anЙ›Й› ni ti la Й Й›ni dЙ› GALA sei К‹Й›lЙ›i ma Й Й”tu mЙ”ungiti daani.
\v 7 Ti walii veeni kЙ”tu zaЙ a nuiti zea, ta pЙ›lЙ› maalЙ›Й› nuiti, ti daamianigiti ta kpЙ”leЙ“Й”le ganigiti ta gulЙ”i ve SidЙ”n ta Tiil nuiti zea, nii a kЙ› ti sЙ›dele gului zeЙ e LiЙ“an, ti da kpoloЙ—Й›i Й a, ti К‹aa la Zafa. Nii pЙ› ge Й Й›Й›ni ga zobogi maaК‹ele, nii PЙ›Й›lese masagi Siluse feeni.
\p 
\v 8 Ti zeeliai ma ZeluzalЙ›me, Ж“Й”oЙ Й” GALAGI zei К‹Й›lЙ›i ma laazuК‹Й›, ta-Й onagi velesiЙ›i ta alugi velesiЙ›i ma, SeyalitiyЙ›le naМЃ-doun zunui ZoloЙ“aЙ“Й›le, Yosadake naМЃ-doun zunui Zozuwe ta bЙ”Й”la zalaЙ a Й ula nuiti, ta Levi nuiti, eМЃ К‹Й›Й› niiti kpein ba ti zeЙ eni duЙ”la К‹elei zu, ti К‹a, ti tЙ”Й”zeini ga botii Й Й›a. Ti yeeloni Levi nuЙ“usЙ›iti ba, eМЃ zo kona К‹uufelegЙ” (20) ma, eМЃ lЙ› zeemaazu, ga ti lo Ж“Й”oЙ Й” GALAGI zei К‹Й›lЙ›i lo fai luЙ Й”.
\v 9 Levi nui Zozuwe ta naМЃ-doun zunuiti, ta kЙ›Й›Й Й›lointi, naa К‹Й›Й› KadimiyЙ›le К‹a, ta naМЃ-doun zunuiti, ta kЙ›Й›Й Й›lointi, Wodavia naМЃ-bolodamaiti su, ta Levi nui niiti ti ga Ж“enadade naМЃ-bolodamaiti, ti pЙ› ti loni GALA sei К‹Й›lЙ›i ma wotiЙ Й› nuiti tuЙ Й”.
\p 
\v 10 PЙ›lЙ› lo nuiti ti Й Й›ai ma GALA sei К‹Й›lЙ›i ma zeЙ“asemai laazu, zalaЙ a Й ula nuiti ti К‹aani К‹elelaК‹Й›, ti maaЙ iliai ga ta-zalaЙ a Й ula zeЙ eiti, puК‹ugi ti ya, Levi nui Azafe mavofodaiti ti К‹a ga kЙ”tЙ›giti, Ж“Й”oЙ Й” GALAGI lЙ›bi vai ma, eЙ Й›К‹elei sЙ›К‹Й›ai la Davide К‹Й›, IzilayЙ›le masagi.
\v 11 Ti Й Й›ni Ж“Й”oЙ Й” GALAGI lЙ›bizu, ti Й—a maamusЙ› ga pilima wuyei, ti Й—a Й Й› ma: В«Ж“Й”oЙ Й” GALAGI К‹agЙ›, mazЙ”lЙ”Й” naМЃ-wooЙ Й›Й iladai Й a yЙ›su naМЃ Й Й” IzilayЙ›le К‹Й›!В» NuЙ“usЙ›iti Й“alaa ti Й Й›ni Ж“Й”oЙ Й” GALAGI lЙ›bizu ga koozunЙ› woo wolaiti, tЙ”Й”zei Ж“Й”oЙ Й” GALAGI zei К‹Й›lЙ›i ma zeЙ“asemai laa vai К‹a.
\v 12 Nu mЙ”inmЙ”in ge Й Й›ni naМЃ, niiti ti Й Й›ni ga kЙ›wolaiti zalaЙ a Й ula nuiti, ta Levi nuiti, ta pЙ›lЙ›yeЙ e Й undiЙ iiti saama, ti GALA sei К‹Й›lЙ› mЙ”ungi Й aani, naati ti Й Й›ni wЙ”lЙ”zu ga gola, siЙ›gi zu GALA sei К‹Й›lЙ› niinЙ›i ma zeЙ“asemai Й Й›ni laazu la ti Й aazu. KЙ›lЙ› nu mЙ”inmЙ”in kiligaa ti Й Й›ni ta-Й oozunЙ›Й›i Й ulazu kЙ›lЙ›ma ga kpee woo wolaiti.
\v 13 TЙ” Й a eМЃ ba nu la Й Й›ni zooga eМЂ К‹a nuiti goo yЙ”Й Й”zuЙ ula, niiti ti wЙ”lЙ”zu, ta niiti ti wooЙ ulazu ga koozunЙ›Й›i, mazЙ”lЙ”Й” Й›sЙ› pЙ› ge Й Й›ni kpee wolai loozu, nu Й—a ti woomЙ›ni Й oozama.
\c 4
\s1 GALA sei К‹Й›lЙ›i lo fai // Й“ela fai pele zu
\p 
\v 1 Nui niiti ti Й Й›ni zooi zu, ti ga Zuda ta ЖЃЙ›nzamЙ›n ti zili nuiti, ti mЙ›nini ga naati ti Й ulani kpein duЙ”lai zu, ta ga GALA sei К‹Й›lЙ›i lo Ж“Й”oЙ Й” GALAGI К‹Й›, IzilayЙ›le naМЃ-GALAGI.
\v 2 Ti К‹aani ZoloЙ“aЙ“Й›le К‹Й” bЙ› ta pЙ›lЙ›yeЙ e Й undiЙ iiti, ti Й Й› ti ma: В«GaМЃ pЙ” gi Й“Й” wo К‹a, ade GALA sei К‹Й›lЙ›i nii lo. MazЙ”lЙ”Й” GALA gilagi naa nЙ” Й a gaМЃ Й—a dЙ›bi, gi Й—a zalaЙ aiti kula bЙ›, eМЃ zo yee nuu ma Asiili masagi Ezaal-Ж“adon К‹aani la ga giye К‹Й›.В»
\v 3 KЙ›lЙ› ZoloЙ“aЙ“Й›le ta Zozuwe, naa К‹Й›Й› pЙ›lЙ›yeЙ e Й undiЙ iiti ba, ti ti wooЙ aaК‹oteni ga: В«EМЃ la zolooni ga wo Й“Й” gi К‹a, ade GALA sei К‹Й›lЙ›i lo gaМЃ-Ж“ALAGI К‹Й›. GaМЃ Й ila nЙ” Й a gi kЙ›Й›zu, mazЙ”lЙ”Й” toЙ a Й Й›Й›zu ga Ж“Й”oЙ Й” GALAGI zei К‹Й›lЙ›i, IzilayЙ›le naМЃ-GALAGI. PЙ›Й›lese Masagi Siluse Й“Й”Й Й”i Й a eМЃ deveni Й ani.В»
\p 
\v 4 Zooi zu nui naati ti tЙ”Й”zeini ga Zuda nuЙ“usЙ›iti iЙІЙ”teК‹ea, ta ti Й—a naati maalua, nii a kЙ› ti looЙ o GALA sei К‹Й›lЙ›i lo fai К‹a.
\v 5 Ti Й Й›ni walii veezu masagi naМЃ-botiЙ Й› nuiti zea ga ti Zuda nuiti ta-wotii zuЙ oloЙ olo, naa Й a ti yЙ›ni daawu PЙ›Й›lese masagi Siluse naМЃ-masa fai ma ziЙ›gi pЙ› su, eyЙ›su eМЃ zeeli Daliyuse nЙ”nЙ”i ma.
\s1 Zuifuiti maalЙ”Й” vai // masagi AaletazЙ›Й›lesЙ›se ma
\p 
\v 6 ZЙ›Й›lesЙ›se\f + \fr 4:6 \fk ZЙ›Й›lesЙ›se\ft : EМЃ Й Й›ni ga PЙ›Й›lese masagi niima Й onagiti su: 486-464 aisa Yesu Kilista zЙ”lЙ”Й”.\f* naМЃ-masa fai lЙ”Й”zei ziЙ›gi zu, ti sЙ›К‹Й›i Й Й›Й›ni, ti teК‹e ma, ti ZeluzalЙ›me zei wo nuiti ta Zuda you zЙ›К‹Й›i ma nuiti maalЙ”Й” su.
\p 
\v 7 SiЙ›gi zu AaletazЙ›Й›lesЙ›se\f + \fr 4:7 \fk AaletazЙ›Й›lesЙ›se\ft : EМЃ Й Й›ni ga PЙ›Й›lese masagi niima Й onagiti su: 464-424 aisa Yesu Kilista zЙ”lЙ”Й”.\f* Й Й›ni la ga PЙ›Й›lese masagi, ЖЃisilame, ta Miteledate, naa К‹Й›Й› TaЙ“eyЙ›le К‹a, ta ti-wЙ”Й”laiti ti sЙ›К‹Й›i Й Й›Й›ni masagi ma, ti kЙ›Й›ni ga Alame zЙ›К‹Й›i ta Alame wooi zu.
\v 8 Zou zЙ›К‹Й› Й undiЙ ii Lewume ta sЙ›К‹Й› Й Й› nui Simesai ti sЙ›К‹Й›i Й Й›Й›ni tiya Й“alaa masagi AaletazЙ›Й›lesЙ›se ma, eМЃ К‹ilЙ› ZeluzalЙ›me К‹a, sЙ›К‹Й›i lЙ”Й”zeini Й ani:
\p 
\v 9 Zou zЙ›К‹Й› Й undiЙ ii Lewume, ta sЙ›К‹Й› Й Й› nui Simesai, ta ti-wЙ”Й”lai mЙ”taiti niiti ti ga Din nuiti, ta Afalasatake nuiti, TaalepЙ›le nuiti, Afalase nuiti, Ж“eelЙ›ke nuiti, ЖЃaЙ“ilЙ”ne ta Suze nuiti, naa К‹Й›Й› DeЙ a ta Elame nuiti ba.
\v 10 NuЙ“usЙ›i mЙ”tai pЙ› daaseigi zu, niiti lЙ”Й Й”Й ula nu wolai Wosenapaal К‹aani ga tiye, eМЃ ti zei Samali laa wolaiti su, ta ziЙ› wolai Efelate folo liizu К‹elei, ta mЙ”taiti.
\v 11 SЙ›К‹Й›i zu wooi Й Й›ni ga nii:
\p В«SЙ›К‹Й›i nii Й a liizu masagi AaletazЙ›Й›lesЙ›se ma, eМЃ Й ula naМЃ-botiЙ Й› nuiti zea, ti ziЙ› wolai Efelate folo liizu К‹elei, ta mЙ”taiti.
\v 12 Masagi, gaМЃ bosu eМЂ ma ga Zuifui niiti ti zeЙ eai eМЂ К‹Й” bЙ›, ti К‹a gi zaama ZeluzalЙ›me, ta ga taa ЙІЙ”i eМЃ ga gaazulЙ›Й› laai lo К‹olu, ti Й“ega К‹oluma ga seЙ“asemaiti da, ta ga ma ziЙ igiti buzeЙ e.
\v 13 Tama kЙ›ni masagi eМЂ kwЙ›Й› ga ni taai tЙ›i ka lona К‹olu, ma ziЙ igiti ti wuzeЙ e К‹olu, ti la mЙ” zou zalai ta maazoloo ganii Й ula, ta zou maaleК‹e salai, naama zeeК‹o ka yЙ› masagi naМЃ-naavolo vaiti ba.
\v 14 GЙ›i gi undaanЙ› zЙ”lЙ”Й”gai ga gi botii Й Й› eМЂ К‹Й›, gi la zooga gi К‹a yЙ› wЙ›lЙ›zu, ti К‹a Й—a eМЂ К‹Й›lЙ›lala, gi deveК‹Й› ga gi eМЂ loo Й isu ga niima vaiti.
\v 15 WЙ›lЙ› masa pЙ”lЙ”maiti ta-zЙ›К‹Й› wЙ”lЙ”maiti su, niiti ti Й Й›a eМЂ luЙ Й”. ЖЉa pЙ›tЙ› ga gaamazu kaite taai nii Й a ga gaazulЙ›Й› laai, ta eМЃ la looЙ oni ga zou masagiti ta zou zЙ›К‹Й› Й undiЙ iiti kpЙ”lЙ”a, ta kaite taai nii zu Й a nЙ” wuulee ga kpaka faiti. Naa nЙ” Й a eМЃ kЙ›ai Й“alaa ma taai Й oloЙ ologai.
\v 16 GaМЃ pЙ” gi eМЂ loo Й isu, masagi, ga ni taai nii a lona К‹olu, ma ziЙ igiti ti wuzeЙ e К‹olu, eМЂ leve la mЙ” Й Й›a ziЙ› wolai Efelate folo liizu К‹elei ma.В»
\s1 Masagi naМЃ-gooЙ aaК‹otegi
\p 
\v 17 Masagi gooЙ aaК‹otegi Й Й›ni ga nii eМЃ teК‹eni: В«ЖЉЙ›i eМЂ ga zou zЙ›К‹Й› Й undiЙ ii Lewume, ta sЙ›К‹Й› Й Й› nui Simesai, naa К‹Й›Й› ti zeini Samali ta wЙ”i wo ziЙ› wolai Efelate folo liizu К‹elei ma yooi mЙ”tai pЙ› su, naМЂ wo luК‹Й”su.
\v 18 SЙ›К‹Й›i nii wo teК‹egai, ti kalagЙ› gaМЂazu.
\v 19 GeМЂ devei veeК‹Й› ga ti wЙ›lЙ› sЙ›К‹Й›iti su, tama ti kaaК‹Й› ga gaamazu kaite, ZeluzalЙ›me Й a ga taai nii eМЃ ga gaazulЙ›Й› laai masagiti daalЙ”Й Й”ma, ta kaite gaazulЙ›Й›i ta kpaka faiti ta naМЃ.
\v 20 Masagaa ti Й Й›a ZeluzalЙ›me, ti-zЙ›bЙ›i wЙ”Й”lЙ”ai, niiti ti zeini ziЙ› wolai Efelate folo liizu К‹elei yooiti kpein unga, naati ti Й—a zou zalai ta maazoloo ganii ve ti ya, ta zou maaleК‹e salai.
\v 21 TЙ” Й a eМЃ ba aМЂ bo ti ma ti botii Й“ela pele zu, ti mina taai naa lo, ni geМЂ la deve veeni.
\v 22 AМЂ mina naama vai la Й oba, faa ЙІЙ”i К‹a wЙ”Й”lЙ”, zeeК‹o ge К‹a yЙ› masagiti ba.В»
\p 
\v 23 TЙ›i feya ti masagi AaletazЙ›Й›lesЙ›se naМЃ-sЙ›К‹Й›i zu wooi mЙ›nini, Lewume ta sЙ›К‹Й› Й Й› nui Simesai ta ti-wЙ”Й”laiti ti liini ga gaazuvilЙ› Zuifuiti pЙ” bЙ› ZeluzalЙ›me, ti naati ta-wotii Й“ela pele zu ga toomai ta maaЙ“aai.
\p 
\v 24 ЖІele Й ana GALA sei К‹Й›lЙ›i lo fai Й“elani la pele zu ZeluzalЙ›me, eyЙ›su PЙ›Й›lese masagi Daliyuse naМЃ-masadai ma Й onagi velesiЙ›i ma.
\c 5
\s1 GALA sei К‹Й›lЙ›i lo fai // lЙ”Й”zei vai К‹olu
\p 
\v 1 GALA goo wo nuiti AzeМЃ\f + \fr 5:1 \ft WЙ›lЙ› К‹Й›: \xt AzeМЃ 1:1\xt*\ft .\f* ta Zakali\f + \fr 5:1 \ft WЙ›lЙ› К‹Й›: \xt Zkl 1:1\xt*\ft .\f*, Ido naМЃ-doun zunui, ti Й“Й”Й›ni Zuifuiti pЙ” Zuda yooi zu ta ZeluzalЙ›me ga GALA daawooi, IzilayЙ›le naМЃ-GALAGI.
\v 2 ZoloЙ“aЙ“Й›le, SeyalitiyЙ›le naМЃ-doun zunui, ta Zozuwe, Yosadake naМЃ-doun zunui, ti wuzeЙ e К‹ele Й ana, ti GALA sei К‹Й›lЙ›i lo fai lЙ”Й”zei ZeluzalЙ›me, GALA goo wo nuiti ti Й—a Й“Й” ti К‹a.
\p 
\v 3 Gaamago nЙ”, Tatenayi nii eМЃ Й Й›ni ga zou zЙ›К‹Й› Й undiЙ ii ziЙ› wolai Efelate folo liizu К‹elei pЙ› unda, ta Setaal-ЖЃozinayi, eМЃ К‹Й›Й› ti-wЙ”Й”laiti pЙ› ba, ti liini ti К‹Й” bЙ›, ti Й Й› ti ma: В«ЖЃЙ› Й a eМЃ niima levei vea wo ya ga wo GALA sei К‹Й›lЙ›i nii lo К‹olu, wo ma ziЙ igiti niinЙ›?
\v 4 Nuiti kpein ti niima К‹Й›lЙ›i losu, aМЂ ti pЙ› daaseigiti fe gi ya.В»
\v 5 KЙ›lЙ› GALA ge Й“aani Zuifuiti ta-Й undiЙ iiti maazu. Nu la ta-wotii loni pele zu, eyЙ›su sЙ›К‹Й› zeeli Daliyuse ma, ta eМЃ naМЃ-gooЙ aaК‹otegi ve eМЃ К‹ilЙ› niima vai К‹a.
\s1 Ti Zuifuiti maalЙ” vai // masagi Daliyuse ma
\p 
\v 6 WЙ›lЙ› sЙ›К‹Й›i zu wooi К‹a, nii eМЃ leК‹eni masagi Daliyuse ma, eМЃ Й ula Tatenayi ya, nii eМЃ Й Й›ni ga zou zЙ›К‹Й› Й undiЙ ii ziЙ› wolai Efelate folo liizu К‹elei pЙ› unda, ta Setaal-ЖЃozinayi, eМЃ К‹Й›Й› ti-wЙ”Й”laiti pЙ› ba.
\v 7 ЖІele Й aa ti Й“Й”Й›ni la ta-zЙ›К‹Й›i zu:
\p В«Masagi Daliyuse, ziilЙ›i daazeeliai Й Й› eМЂ К‹Й›.
\v 8 Masagi, gaМЃ bosu eМЂ ma ga gi liiК‹Й› Zuda you zЙ›К‹Й›i ma, gi zeeli GALA golai zei К‹Й›lЙ›i К‹Й” bЙ›. Nuiti ta ga pЙ›lЙ›i naa lo ga kЙ”tu zaЙ aai, ti Й—a guluiti dЙ” ma ziЙ igiti su, ti zЙ›bЙ›zeЙ eК‹Й› botii zu, eМЃ Й—a zoloo ti ya.
\v 9 Gi kundiЙ iiti gaazaЙ agЙ›, gi Й Й› ti ma: вЂ№ЖЃЙ› Й a eМЃ niima levei vea wo ya ga wo GALA sei К‹Й›lЙ›i nii lo К‹olu, wo ma ziЙ igiti niinЙ›?вЂє
\v 10 Gi Й Й›Й›К‹Й› ti ma Й“alaa, niiti kpein ti unda, ti naati kpein daaseigiti sЙ›К‹Й›, ti fe gi ya.
\v 11 Ti gi wooЙ aaК‹otegЙ› ga: вЂ№GALAGI nii eМЃ geeЙ Й”lЙ”gi ta zooi Й“Й›tЙ›a, naa naМЃ-botiЙ Й› nuiti ka ga giye, gaМЃ sei К‹Й›lЙ›i nii losu К‹olu, nii IzilayЙ›le masa golai gila ge toni kaite, eМЃ gaaЙ“ela.
\v 12 KЙ›lЙ› gi-mЙ›mЙ›wolani ti geeЙ Й”lЙ”gi Й“Й›tЙ› Ж“ALAGI yiiЙ aawanaai ma, naa ti Й wЙ›Й›ni NeЙ“ukadenЙ›zaal ma, ЖЃaЙ“ilЙ”ne masagi, KaledeМЃ nui, tЙ” Й a eМЃ GALA sei К‹Й›lЙ›i nii Й oloni, eМЃ li ga tiye duЙ”lai zu ЖЃaЙ“ilЙ”ne.
\v 13 KЙ›lЙ› anЙ›Й› naa К‹e, ЖЃaЙ“ilЙ”ne masagi Siluse naМЃ-kona mЙ”ungi ma, eМЃ devei veeni ga GALA sei К‹Й›lЙ›i nii lo К‹olu.
\v 14 Masagi Siluse Й“Й”Й Й”i devei veeni ga sЙ”Й”lai niiti kpein ti Й“Й›tЙ›ai ga zanugi ta walii, niiti NeЙ“ukadenЙ›zaal ti Й ulani GALA sei К‹Й›lЙ›i wu ZeluzalЙ›me, eМЃ li ga tiye, eМЃ ti la naМЃ-galagi naМЃ-pЙ›lЙ›i wu ЖЃaЙ“ilЙ”ne, ti sЙ”Й”lai naati feeni SЙ›sЙ›Й“asaal ya, nii tЙ” Й“Й”Й Й”i eМЃ kЙ›Й›ni ga Zuda you zЙ›К‹Й› Й undiЙ ii.
\v 15 EМЃ valini ma ga: Li ga sЙ”Й”lai niiti. SiЙ›gi zu GALA sei К‹Й›lЙ›i Й“esu la ga lo tosu wЙ”lЙ”mai ZeluzalЙ›me, wo ti la bu.
\v 16 NaМЃzu Й a SЙ›sЙ›Й“asaal К‹aa la К‹Й› ZeluzalЙ›me, eМЃ GALA sei К‹Й›lЙ› niinЙ›i ma zeЙ“asemai la. EМЃ zo naazu ma botii Й a ba, eМЃ Й—a Й Й›, kЙ›lЙ› gaa la dЙ› Й“elani.вЂє
\v 17 Niizu niina, masagi, ni Й—a kaana ga faa К‹agЙ”, bo, ti wЙ›lЙ› ЖЃaЙ“ilЙ”ne masagiti ta-zЙ›К‹Й› wЙ”lЙ”maiti su, eМЃ Й wЙ›Й› ni masagi Siluse deve veeni ga Й ite vaa GALA sei К‹Й›lЙ›i nii lo fai zu ZeluzalЙ›me, naa К‹oluma Й—a Й—a-levei lЙ› ga giye niina niima vai zu.В»
\c 6
\s1 Daliyuse naМЃ-gooЙ aaК‹otegi eМЃ feeni
\p 
\v 1 Naazu masagi Daliyuse devei veeni ga ti gaiziЙ›i wo ЖЃaЙ“ilЙ”ne zЙ›К‹Й›iti ta ani Й“ii makЙ› К‹Й›lЙ›i wu.
\v 2 ЖђkЙ›Й“atane taazuК‹Й›, MЙ›de Й oК‹ii laa wolai nii siЙ igi ma, minaМЃ Й a ti sЙ›К‹Й› Й“iligi gila kaani naМЃ, nii sЙ›К‹Й›i К‹Й”nЙ›ni ma Й ani:
\p 
\v 3 В«Siluse naМЃ-kona mЙ”ungi masa fai zu, eМЃ niima levei woni, GALA sei К‹Й›lЙ›i maanЙ›Й›К‹Й› eМЃ lo К‹olu ZeluzalЙ›me, naa Й Й› ga К‹Й› zalaЙ aiti ta Й Й› Й ulazu naМЃ, toЙ a losu tosu wЙ”lЙ”mai nЙ”, gaa Й aaЙ oozazu ga mЙ›tЙ›lЙ› К‹uusaК‹agЙ” (30), kogi Й Й› ga mЙ›tЙ›lЙ› К‹uusaК‹agЙ” (30),
\v 4 kЙ”tu zaЙ aai ma ЙІЙ›kpЙ› saК‹agЙ”, gulu niinЙ›i ma ЙІЙ›kpЙ› Й ila. Naama walii kpein ka Й ulazu masagi naМЃ-naavolo makЙ›suК‹Й›.
\v 5 Naa К‹oluma zanu sЙ”Й”laiti ta wali zЙ”Й”laiti kpein NeЙ“ukadenЙ›zaal ti Й ulani GALA sei К‹Й›lЙ›i wu ZeluzalЙ›me, eМЃ К‹a ga tiye ЖЃaЙ“ilЙ”ne, ti pЙ› maanЙ›Й›К‹Й› ti Й ale ma, К‹Й› ti zeЙ eai naМЃ, ti la GALA sei К‹Й›lЙ›i wu ZeluzalЙ›me.В»
\p 
\v 6 Naa maaК‹ele ma, Daliyuse niima zЙ›К‹Й›i leК‹eni ziЙ› wolai Efelate folo liizu К‹elei you zЙ›К‹Й› Й undiЙ ii Tatenayi ma, ta Setaal-ЖЃozinayi, ta ti-wЙ”Й”laiti kpein: В«AМЂ yeeЙ ula fai naa zu.
\v 7 AМЂ Zuifuiti zЙ›na dЙ”in, ti GALA sei К‹Й›lЙ›i lo, Zuifuiti ta-you zЙ›К‹Й› Й undiЙ ii ta ta-Й Й›wolaiti ka ti tosu, tosu wЙ”lЙ”mai.
\v 8 NЙ”МЂnЙ” ma levei Й a geМЂ bosu, К‹elei wa ziЙ› la Zuifuiti ta-Й undiЙ iiti tetemazu, GALA sei К‹Й›lЙ›i lo fai zu. AМЂ Й aaЙ“a, pЙ›lЙ›i lo walii kpein ge Й—a ve ti ya falafala, eМЃ Й ula masagi naМЃ-naavolo makЙ›suК‹Й›, nii eМЃ zЙ”lЙ”Й”su maazoloo ganii zu eМЃ Й ulazu ziЙ› wolai Efelate folo liizu К‹elei ma yooi zu, naa Й a a kЙ› botii mina lo pele zu.
\v 9 KЙ›ni wo kЙ› К‹ele-o-К‹ele, wo Й—a naa ve zalaЙ a Й ula nuiti zea folo-o-folo, nii ta Й“Й›dЙ› ma, ti dЙ›Й› ga woye, eМЃ Й Й›ni ga: nikЙ› zinЙ› Й“okpagiti, baala sinЙ›iti, baala ziК‹oiti, gala zalaЙ aiti faa zu eМЃ veezu GALAGI К‹Й› eМЃ geeЙ Й”lЙ”gi zu. ЖІele nЙ” Й ana wa kЙ›Й› la Й“alaa eМЃ К‹ilЙ› moloi, kpoloi, dЙ”Й”i ta gulЙ”iti ba.
\v 10 Ta zoo naazu ti Й—a geeЙ Й”lЙ”gi zu Ж“ALAGI yiima zalaЙ aiti kula, ti Й—a GALA fali masagi yЙ›nvui, ta naМЃ-dointi zЙ›nvuiti ta-vaa zu.
\v 11 Devei taЙ ili ka mЙ”nЙ” geМЂ feezu: Nu nЙ”pЙ› eМЃ devei nii Й oloЙ olosu, ta kpЙ›dЙ› gila kula naМЃ-pЙ›lЙ›i wu, ti sЙ›lЙ› ba, naМЃ-pЙ›lЙ›i Й a valibo ga kaК‹a ziЙ igi.
\v 12 GALAGI nii eМЃ zeini ZeluzalЙ›me, naa masagi Й“aa zooi naa Й oloЙ olo, nii eМЃ yeewuzeЙ ezu eМЃ devei nii zeЙ e ma, ga eМЃ GALA sei К‹Й›lЙ›i nii Й olo eМЃ ZeluzalЙ›me. NaМЂ Й“Й”Й Й”i Daliyuse, naМЂ Й a geМЂ devei nii vea, kЙ›ni eМЃ ziЙ› ga pagЙ”.В»
\s1 GALA sei К‹Й›lЙ› wotii Й aaЙ“ela fai
\p 
\v 13 Naa К‹oluma ziЙ› wolai Efelate folo liizu К‹elei you zЙ›К‹Й› Й undiЙ ii Tatenayi, ta Setaal-ЖЃozinayi, ta ti-wЙ”Й”laiti kpein, ti ziЙ›ni ga masagi Daliyuse naМЃ-devei nЙ”.
\v 14 Zuifuiti ta-Й undiЙ iiti ti iЙІЙ”dЙ”Й”i zЙ”lЙ”Й”ni GALA goo wo nuiti AzeМЃ ta Ido naМЃ-doun zunui Zakali ta-lЙ›nЙ› gooiti su, ti Й—a li luЙ Й”ma pЙ›lЙ› logi zu, eyЙ›su ti gaaЙ“ela, eЙ Й›К‹elei Ж“Й”oЙ Й” GALAGI deveni la, ta eЙ Й›К‹elei PЙ›Й›lese masagiti Siluse, ta Daliyuse, eМЃ К‹Й›Й› AaletazЙ›Й›lesЙ›se К‹a ti deveni la.
\v 15 GALA sei К‹Й›lЙ›i Й“eni alugi daa ga Adaal, naa naМЃ-folo saК‹agЙ”i ma, masagi Daliyuse naМЃ-kona dЙ”zitasiЙ›i ma masa fai zu.
\p 
\v 16 IzilayЙ›le nuiti, ta zalaЙ a Й ula nuiti, ta Levi nuiti, naa К‹Й›Й› nuЙ“usЙ›i mЙ”tai pЙ› ba ti Й ulaai duЙ”lai zu, ti К‹a, ti GALA sei К‹Й›lЙ›i laalaoni ga koozunЙ›Й›i.
\v 17 GALA sei К‹Й›lЙ›i naa laalao fai zu, ti zalaЙ aiti kulani: nikЙ› zinЙ› ungila (100), baala sinЙ› unfelegЙ” (200), baala ziК‹o unnaanigЙ” (400), ta boli zinЙ› puugЙ” maazu fele (12) koto gba vai zu IzilayЙ›le nuiti pЙ› bЙ›, eМЃ zoloo ta-woloda puugЙ” maazu felegЙ”iti (12) ma.
\v 18 Ti zalaЙ a Й ula nuiti seini su К‹elei ta-zeikpasui la, Levi nuiti Й“alaa К‹elei ta-Й aaЙ wЙ›sui la, GALA naМЃ-botiЙ Й› vai zu ZeluzalЙ›me, К‹elei sЙ›К‹Й›ai la Moize naМЃ-sЙ›К‹Й›i zu.
\p 
\v 19 Niiti kpein ti Й ulani duЙ”lai zu, ti К‹a, naati ti Pake fЙ›tii Й ulani alu mЙ”ungi ma volo puugЙ” maazu naanigЙ”i (14) ma.
\v 20 ZalaЙ a Й ula nuiti ta Levi nuiti ti Й“Й”Й Й” ЙІadeni К‹Й”Й”ma, ti pЙ› ti ЙІadeni. Levi nuiti ti Pake suaiti kЙ”daaleК‹eni naazu nuЙ“usЙ›i pЙ› bЙ›, ti Й ulaai duЙ”lai zu, ta ti-Й Й›Й›lointi bЙ› zalaЙ a Й ula nuiti, ta tiya Й“Й”Й Й”i К‹Й›.
\v 21 IzilayЙ›le nui niiti kpein ti Й ulaai duЙ”lai zu, ti К‹a, ti Pake daamii woni К‹Й”Й”ma, ta niiti kpein ti Й“Й”Й Й” ЙІadeni, ti yeeЙ“e zii Й iligiti ta-Й Й”zЙ”ba vaiti pЙ› ba, ta ti К‹ilЙ› ti К‹olu Ж“Й”oЙ Й” GALAGI yiima vai Й Й›Й› vai zu, IzilayЙ›le naМЃ-GALAGI.
\v 22 Folo lЙ”fela laawu fЙ›tii Й ulani, nii ta Й—a Й“ului mi su, nii lЙ›К‹Й› la su, ti kЙ›Й›ni ga koozunЙ› wolai, mazЙ”lЙ”Й” Ж“Й”oЙ Й” GALAGI Asiili masagi\f + \fr 6:22 \fq Asiili masagi\ft : Daliyuse, nii eМЃ Й Й›ni ga PЙ›Й›lese masagi.\f* yii latini ti ma ga pagЙ”, eМЃ Й“Й” ti К‹a GALA sei К‹Й›lЙ›i lo fai zu, IzilayЙ›le naМЃ-GALAGI.
\c 7
\s1 Жђsedalase lii vai ZeluzalЙ›me
\p 
\v 1 Niima vaiti kpein poluma, PЙ›Й›lese masagi AaletazЙ›Й›lesЙ›se naМЃ-siЙ›gi zu, zunui ta Й Й›ni naМЃ, daa ga Жђsedalase, Selaya naМЃ-doun zunui, mЙ›mЙ›wolani daaseigiti ta ti zЙ”lЙ”Й” peleiti kaa: Azalia, Yilikiya,
\v 2 Salume, SadЙ”ke, AyituЙ“e,
\v 3 Amalia, Azalia, MelayЙ”te,
\v 4 Zelayia, Uzi, ЖЃuki,
\v 5 AЙ“isua, Fineyase, Eleazaal, zalaЙ a Й ula Й undiЙ i wolai AalЙ”n naМЃ-doun zunui.
\v 6 Жђsedalase naa zeЙ eni ЖЃaЙ“ilЙ”ne. EМЃ Й Й›ni ga sЙ›К‹Й› Й Й› nui, kalagai Moize naМЃ-tЙ”gi zu, tЙ”gi nii IzilayЙ›le naМЃ-GALAGI, Ж“Й”oЙ Й” GALAGI feeni Moize ya. Masagi Й Й›ni naa kpein feezu Жђsedalase ya, nii eМЃ Й Й›ni falizu ma, mazЙ”lЙ”Й” naМЃ-GALAGI, Ж“Й”oЙ Й” GALAGI Й Й›ni ba.
\v 7 Masagi AaletazЙ›Й›lesЙ›se naМЃ-masadai ma Й onagi lЙ”felasiЙ›i ma, IzilayЙ›le nui tanigaa ti Й aleni ma, ti li ZeluzalЙ›me: zalaЙ a Й ula nuiti, Levi nuiti, gЙ›ingЙ›in gani gЙ›in nuiti, siЙ ida makЙ› nuiti, ta GALA sei К‹Й›lЙ›i wu wotiЙ Й› nuiti.
\p 
\v 8 Жђsedalase yЙ›ni ti К‹olu, ti li ZeluzalЙ›me, masagi AaletazЙ›Й›lesЙ›se naМЃ-masadai ma Й onagi lЙ”felasiЙ›i ma alugi lЙ”Й”lusiЙ›i ma.
\v 9 EМЃ deveni ga eМЃ zeЙ e ЖЃaЙ“ilЙ”ne alu mЙ”ungi ma volo mЙ”ungi ma, eМЃ zeeli ZeluzalЙ›me alugi lЙ”Й”lusiЙ›i ma volo mЙ”ungi ma, naМЃ-GALAGI zaalai zu, nii eМЃ Й Й›ni tЙ”un makЙ›su.
\v 10 MazЙ”lЙ”Й” Жђsedalase Й Й›ni Й aaЙ“aazu, eМЃ Й—a Ж“Й”oЙ Й” GALAGI naМЃ-tЙ”gi Й ala, ta eМЃ Й—a so ga yii pЙ›, eМЃ Й—a IzilayЙ›le nuiti kala ga tЙ”giti ta deveiti.
\s1 TosuК‹Й› niiti AaletazЙ›Й›lesЙ›se ti Й alivaani // Жђsedalase ma
\p 
\v 11 SЙ›К‹Й›i zu wooi К‹Й›tЙ›, nii PЙ›Й›lese masagi AaletazЙ›Й›lesЙ›se feeni zalaЙ a Й ula nui Жђsedalase ya, tЙ”giti ta deveiti ma Й alamЙ”in, niiti Ж“Й”oЙ Й” GALAGI ti veeni IzilayЙ›le nuiti zea:
\p 
\v 12 В«AaletazЙ›Й›lesЙ›se, masagiti ta-masagi, niima zЙ›К‹Й›i Й a liizu zalaЙ a Й ula nui Жђsedalase ma, GALAGI nii eМЃ geeЙ Й”lЙ”gi zu, naa naМЃ-tЙ”giti ma Й alamЙ”in.
\v 13 GeМЂ devei vea ga nu nЙ”pЙ› IzilayЙ›le nuiti saama, ti naМЂ-masa zooi zu, eМЃ Й Й›ni ga zalaЙ a Й ula nu, Й“aa Levi nu, eМЃ pЙ” ga eМЃ li ZeluzalЙ›me, ti Й“e ti pЙ› ba, wo li К‹Й”Й”ma wa tiye.
\v 14 NЙ”МЂun naМЂ, masagi, gaМЃ naМЂ-tЙ›nЙ›bo nu lЙ”felaiti ka gi eМЂ leК‹esu ZeluzalЙ›me ta Zuda, eМЂ ka К‹elei Й—a-Ж“ALAGI naМЃ-tЙ”gi zosu la naМЃ, nii eМЃ eМЂ ya.
\v 15 SiЙ› Й ilagi naa nЙ” zu Й—a liizu ga walii ta zanugi, nii gaМЃ naМЂ-tЙ›nЙ›bo nuiti gi daai Й isu ga gi fe IzilayЙ›le naМЃ-GALAGI К‹Й›, eМЃ zeini ZeluzalЙ›me.
\v 16 ЖЉa liizu Й“alaa ga waliiti ta zanugiti, niiti ti Й ulaai nuiti zea ti ЖЃaЙ“ilЙ”ne you zЙ›К‹Й›i zu, ta niiti nuЙ“usЙ›iti ta zalaЙ a Й ula nuiti ti daai Й isu ga vebЙ›anii ta-Ж“ALAGI zei К‹Й›lЙ›i vaa zu, eМЃ ZeluzalЙ›me.
\v 17 Naama walii Й a eМЂ nikЙ› zinЙ›iti ta baala sinЙ›iti ta baala ziК‹oiti geyazu la naМЃ, naa К‹Й›Й› vebЙ› zalaЙ aiti ba ta puya zalaЙ aiti, eМЂ ti pЙ› kula ga zalaЙ ai wa-Ж“ALAGI zei К‹Й›lЙ›i ma zalaЙ a Й ulazuК‹Й› ZeluzalЙ›me.
\v 18 Wa eМЂ-wЙ”Й”la zalaЙ a Й ula nuiti, nii nЙ”pЙ› wa ka ga soloogЙ› ga wo kЙ› ga wali ta zanu mЙ”tai, aМЂ kЙ›Й› la, eЙ Й›К‹elei soloogai la wa-Ж“ALAGI yiimai ma.
\v 19 GALA sei К‹Й›lЙ›i wu wotiЙ Й› zЙ”Й”lai niiti ti veai eМЂ ya, li, eМЂ ti la Й—a-Ж“ALAGI zei К‹Й›lЙ›i wu ZeluzalЙ›me.
\v 20 Ni ani Й ili geya vaa a lona eМЂ К‹a Й—a-Ж“ALAGI zei К‹Й›lЙ›i naa ma vaa zu, naama walii Й a Й ula masagi naМЃ-naavolo makЙ›suК‹Й›.
\p 
\v 21 В«NЙ”МЂun naМЂ, masagi AaletazЙ›Й›lesЙ›se, geМЂ devei vea naavolo makЙ› nuiti kpein zea, ti ziЙ› wolai Efelate folo liizu К‹elei, ga ti naa kpein kЙ› ga pagЙ”, nii zalaЙ a Й ula nui Жђsedalase bosu ti ma, geeЙ Й”lЙ”gi zu Ж“ALAGI naМЃ-tЙ”giti ma Й alamЙ”in.
\v 22 Ti maanЙ›Й›К‹Й› ti kilo waasaК‹agЙ” (3.000) Й Й›Й ala ve zea ga walii, moloi kilo waaК‹uusaК‹agЙ” (30.000) Й Й›Й ala, dЙ”Й”i litЙ›lЙ› waanaanigЙ” (4.000) Й Й›Й ala, gulЙ”i litЙ›lЙ› waanaanigЙ” (4.000) Й Й›Й ala, ti kpoloi ve zea, К‹elei nЙ›ai la ti К‹Й›.
\v 23 Devei kpein geeЙ Й”lЙ”gi Й“Й›tЙ› Ж“ALAGI feezu, sei К‹Й›lЙ›i ma vaa zu, ti pЙ› ge Й Й› ga kЙ›Й›К‹elei, nii a kЙ› GALAGI naa mina К‹a yiiЙ aawanazu masa zooi ma, Й“aa naМЂ Й“Й”Й Й”i ma gaМЃ maМЂvofodaiti.
\v 24 GaМЃ bosu Й“alaa naavolo makЙ› nuiti kpein ma ga nu mina zou zalai, Й“aa maazoloo ganii, Й“aa zou maaleК‹e salai Й ula zalaЙ a Й ula nuiti zea, ta Levi nuiti, ta guye loo nuiti, eМЃ К‹Й›Й› siЙ ida makЙ› nuiti ba, ta GALA sei К‹Й›lЙ›i wu wotiЙ Й› nuiti, naa К‹Й›Й› nuiti kpein ba ti botii Й Й›Й›zu GALA sei К‹Й›lЙ›i wu.
\p 
\v 25 В«Жђsedalase, Й—a ma, К‹elei Й—a-Ж“ALAGI Й igi veai la eМЂ ya, faawo bo nuiti ta tukpЙ”Й aaleК‹e nuiti sei ziЙ› wolai Efelate folo liizu К‹elei nuЙ“usЙ›iti saama, ti Й—a tukpЙ”Й aaleК‹e naati bЙ›, ti Й—a-Ж“ALAGI naМЃ-tЙ”giti kwЙ›Й›. Wa ti lЙ›Й› ga naati Й“alaa, niiti ti la ti Й wЙ›Й›.
\v 26 ZЙ”i nЙ”pЙ› eМЃ la kЙ›Й›ni eМЃ К‹a Й—a-Ж“ALAGI naМЃ-tЙ”giti ta masagi naМЃ-tЙ”giti so ga pagЙ”, naama nui maanЙ›Й›К‹Й› ga eМЃ za, Й“aa ti kula zooi К‹a, Й“aa kЙ”ligiti ti Й ula zea, Й“aa eМЃ К‹ili kasoi Й a.В»
\s1 MaamusЙ›i
\p 
\v 27 Mamagi Й a Ж“Й”oЙ Й” GALAGI К‹Й›, ade-mЙ›mЙ›wolani ta-Ж“ALAGI, nii eМЃ puai masagi yiima ga eМЃ nii Й Й›Й ala lЙ›biyai ve Ж“Й”oЙ Й” GALAGI zei К‹Й›lЙ›i К‹Й› ZeluzalЙ›me.
\v 28 TЙ” Й a eМЃ wooЙ Й›Й iladai Й Й›a bЙ›МЂ, eМЃ Й aazu unfe fe bЙ›МЂ gi yЙ”Й Й”zu gaМЃ masagi, ta naМЃ-tЙ›nЙ›bo nuiti, naa К‹Й›Й› naМЃ-tosuba nu wolaiti kpein ba. TЙ›i geМЂ kwЙ›Й›ni ga toЙ a baМЂ, naa iМЂЙІЙ”dЙ”Й”ni, geМЂ zoo geМЂ IzilayЙ›le Й undiЙ iiti gaalЙ› ba, ga gi lЙ› К‹Й”Й”ma ZeluzalЙ›me.
\c 8
\s1 Жђsedalase ziЙ›ЙІЙ”Й Й”iti daaseigiti
\p 
\v 1 PЙ›lЙ›yeЙ e Й undiЙ iiti daaseigiti kaa, niiti gi lЙ›Й›ni К‹Й”Й”ma ga tiye, gi zeЙ e ЖЃaЙ“ilЙ”ne, gi li ZeluzalЙ›me, masagi AaletazЙ›Й›lesЙ›se naМЃ-siЙ›gi zu.
\li1 
\v 2 Fineyase mavofodaiti: GЙ›Й›lЙ›some.
\li1 Itamaal mavofodaiti: DaniyЙ›le.
\li1 Davide mavofodaiti: Ж“atuse.
\li1 
\v 3 Sekania ta PaleyЙ”se ti-mavofodaiti: Zakali, nii eМЃ Й Й›ni nu ungila nu К‹uulЙ”Й”lu (150) unda.
\li1 
\v 4 PaЙ ate-MoaЙ“e mavofodaiti: EliyЙ”yenayi, Zelayia naМЃ-doun zunui, nii eМЃ Й Й›ni nu unfelegЙ” (200) unda.
\li1 
\v 5 Zatu mavofodaiti: Sekania, YaЙ aziyЙ›le naМЃ-doun zunui, nii eМЃ Й Й›ni nu unsaК‹agЙ” (300) unda.
\li1 
\v 6 Adin mavofodaiti: EЙ“Й›de, Zonatan naМЃ-doun zunui, nii eМЃ Й Й›ni nu К‹uulЙ”Й”lugЙ” (50) unda.
\li1 
\v 7 Elame mavofodaiti: Ezayi, Atalia naМЃ-doun zunui, nii eМЃ Й Й›ni nu К‹uulЙ”fela (70) unda.
\li1 
\v 8 Sefatia mavofodaiti: ZeЙ“adia, MikayЙ›le naМЃ-doun zunui, nii eМЃ Й Й›ni nu К‹uulЙ”saК‹a (80) unda.
\li1 
\v 9 ZoaЙ“e mavofodaiti: AЙ“ediyase, YeЙ iyЙ›le naМЃ-doun zunui, nii eМЃ Й Й›ni nu unfelegЙ” nu puugЙ” maazu lЙ”saК‹a (218) unda.
\li1 
\v 10 Selomite mavofodaiti: Yosifiya naМЃ-doun zunui, nii eМЃ Й Й›ni nu ungila nu К‹uulЙ”zita (160) unda.
\li1 
\v 11 ЖЃeЙ“ayi mavofodaiti: Zakali, ЖЃeЙ“ayi naМЃ-doun zunui, nii eМЃ Й Й›ni nu К‹uufelegЙ” maazu lЙ”saК‹a (28) unda.
\li1 
\v 12 Azagade mavofodaiti: YoЙ anan, Ж“akatan naМЃ-doun zunui, nii eМЃ Й Й›ni nu ungila nu puugЙ” (110) unda.
\li1 
\v 13 Adonikame mavofodaiti: gaaЙ“elagiti niiti ti-laaseigiti ti Й Й›ni ga ElifelЙ›te, YeiyЙ›le, ta Semaya, naati ti Й Й›ni nu К‹uulЙ”zita (60) unda.
\li1 
\v 14 ЖЃigivayi mavofodaiti: Utayi ta Zakuul, niiti ti Й Й›ni nu К‹uulЙ”fela (70) unda.
\s1 ZeluzalЙ›me ziЙ›i Й Й›К‹ele Й“Й›tЙ› vai
\p 
\v 15 GeМЂ niima nuiti kpein gaalЙ›Й›ni ba ziЙ› wolai Й obaК‹Й›, nii eМЃ yeizu ga AЙ ava К‹ele, gi yЙ›ni minaМЃ folo saК‹agЙ” laawu. GeМЂ wЙ›lЙ›ni nuЙ“usЙ›iti saama ta zalaЙ a Й ula nuiti, geМЂ la Levi nu nЙ”pЙ› kaani ti zu.
\v 16 NaМЃzu Й a geМЂ kundiЙ ii niiti tolini la: EliyezЙ›Й›l, AliyЙ›le, Semaya, ЖђlЙ›natan, YaliЙ“e, Natan, Zakali, ta Mesulame, naa К‹Й›Й› tЙ” kalamЙ”n felegЙ”iti ba YoyaliЙ“e ta ЖђlЙ›natan.
\v 17 GeМЂ valini ti ma ga ti li Kasifia Й undiЙ ii Ido К‹Й” bЙ›, geМЂ wooi К‹u ti-la, nii ta bo Ido ma, ta kЙ›Й›Й Й›lointi pЙ›, GALA sei К‹Й›lЙ›i wu wotiЙ Й› nuiti niiti ti Kasifia, ga ti kpЙ”ba nuiti teК‹e gi ma, gaМЃ-Ж“ALAGI zei К‹Й›lЙ›i vai zu.
\v 18 TЙ›i gaМЃ-Ж“ALAGI ma ge Й Й›ni gi К‹a, eМЃ Й—a gi Й aazumaawЙ”inЙ a, ti SeleЙ“ia leК‹eni gi ma, nu Й Й›ni de Й igi ma, Maali naМЃ-bolodai zu, Levi mavofodai zu, IzilayЙ›le naМЃ-doun zunui, ti nu puugЙ” maazu lЙ”saК‹a (18) К‹Й›Й›ni ba kЙ›Й›Й Й›lointi saama, ta naМЃ-doun zunuiti,
\v 19 eМЃ К‹Й›Й› Ж“asaЙ“iya ta Ezayi К‹a, ti Й Й› Melali mavofodaiti, ta kЙ›Й›Й Й›lointi, eМЃ К‹Й›Й› ti-loun zunuiti ba, ti pЙ› kpЙ”ga Й Й›ni ga nu К‹uufelegЙ” (20).
\v 20 Ti К‹aani Й“alaa ga nu unfelegЙ” nu К‹uufelegЙ” (220), niiti Davide ta pЙ›lЙ›yeЙ e Й undiЙ iiti ti yeeloni ti pЙ› ba ga ti-laaseigiti, ti ti ve Levi nuiti zea, ga ti Й—a botii Й Й› GALA sei К‹Й›lЙ›i wu.
\p 
\v 21 Gi yЙ›ni minaМЃ ziЙ› wolai Й obaК‹Й›, nii eМЃ yeizu ga AЙ ava К‹ele, geМЂ deve ga gi zugi zo, naa Й Й› ga gaМЃ-Й“Й”Й Й”maayeii ma К‹oogi gaМЃ-Ж“ALAGI К‹Й›, nii a kЙ› gi siЙ› К‹agЙ” wo ziilЙ›igi zu, gaМЃ gaМЃ-К‹Й›lЙ›yeЙ eiti, ta gi-Й Й”ligiti.
\v 22 NaМЂ la Й Й›Й›na masagi ma, eМЃ salaК‹usuiti ta soo Й“izЙ› zalaК‹usuiti fe, ti gi makЙ› gi zili nuiti daalЙ”Й Й”ma, naa Й Й›ni Й Й›Й›zu ga unfe faa zeМЂa, tЙ”Й”zei gi dЙ›Й›ni la ga, gaМЃ-Ж“ALAGI Й a Й—a naati makЙ›, niiti ti bЙ› ga wooЙ Й›Й ila nuiti, kЙ›lЙ› toЙ a Й—a yiiЙ aawana gola naati ma, ti Й Й›lЙ›zu tЙ”un ba.
\v 23 Naa maaК‹ele ma, gi zugi zoni, gi gaМЃ-Ж“ALAGI maanЙ›Й›nЙ›ni ga eМЃ Й“aa gi maazu, tama eМЃ gi wooЙ aaК‹oteni.
\p 
\v 24 Naa К‹oluma geМЂ zalaЙ a Й ula Й undiЙ i puugЙ” maazu felegЙ” (12) lolini, ta SeleЙ“ia, naa К‹Й›Й› Ж“asaЙ“iya К‹a, ta ti-Й Й›Й›loun puugЙ”.
\v 25 GeМЂ walii ta zanugi Й Й”Й Й”ni, geМЂ pЙ›Й› sЙ”Й”la Й“iigiti kpein ba niiti masagi ta naМЃ-tЙ›nЙ›bo nuiti, naa К‹Й›Й› naМЃ-botiЙ Й› nu wolaiti ba, ta IzilayЙ›le nuiti ti naМЃ-zooi zu, ti kpЙ”ni ba gaМЃ-Ж“ALAGI zei К‹Й›lЙ›i vai zu, geМЂ fe ti ya.
\v 26 GeМЂ kilo waaК‹uufelegЙ” (20.000) veeni ti ya ga walii, geМЂ kilo waasaК‹agЙ” (3.000) ve ti ya ga ani Й“iigiti ti Й“Й›tЙ›ai ga walii, geМЂ kilo waasaК‹agЙ” (3.000) ve ti ya ga zanugi,
\v 27 geМЂ zanu Й—aawЙ” К‹uufelegЙ” (20) ve ti ya, nii a la zeeli zanu kae waagila (1.000) su, ta kЙ”lu Й“Й”i aniЙІaka К‹apa felegЙ”, ti К‹agai ga zanugi Й Й›К‹ele.
\v 28 GeМЂ Й Й›ni ti ma: В«ЖІelei wo veai la Ж“Й”oЙ Й” GALAGI К‹Й›, К‹ele Й ana niima zЙ”Й”laiti feai la. Walii ta zanugi ta ga vebЙ›aniiti, niiti ti ve Ж“Й”oЙ Й” GALAGI К‹Й›, wo-mЙ›mЙ›wolani ta-Ж“ALAGI.
\v 29 AМЂ Й“aa ti maazu ga pagЙ”, eyЙ›su wo zeeli ZeluzalЙ›me, naМЃzu wa ti pЙ› gaalu niina, wo ti ve zalaЙ a Й ula Й undiЙ i wolaiti zea, ta Levi nuiti, eМЃ К‹Й›Й› pЙ›lЙ›yeЙ e Й undiЙ iiti ba, wo ti К‹u Ж“Й”oЙ Й” GALAGI zei К‹Й›lЙ›i ma К‹Й›Й›bagoiti bu.В»
\v 30 ZalaЙ a Й ula nuiti ta Levi nuiti ti walii ta zanugiti seЙ eni, eМЃ К‹Й›Й› sЙ”Й”lai zЙ”iti ba, ti li ga tiye ZeluzalЙ›me, gaМЃ-Ж“ALAGI zei К‹Й›lЙ›i wu.
\s1 SiЙ›i wo pelei, // ta ti zeeli К‹elei ZeluzalЙ›me
\p 
\v 31 Alu mЙ”ungi ma volo puugЙ” maazu felegЙ”i (12) ma, gi zeЙ eni ziЙ› wolai Й obaК‹Й›, nii eМЃ yeizu ga AЙ ava К‹ele, gi li ZeluzalЙ›me. EyЙ›su gi zeeli, gaМЃ-Ж“ALAGI yeeyЙ›ni gi К‹a, eМЃ Й—a Й“aa gi maazu gi zili nuiti ta toosu nuiti daalЙ”Й Й”ma, niiti ti Й Й›ni gi maaluazu.
\v 32 Gi zeeliai ma ZeluzalЙ›me, gi looЙ oni folo saК‹agЙ” laawu.
\v 33 Foloi naanisiЙ›i, gi walii, ta zanugi, ta sЙ”Й”la Й“iigiti gaaluni gaМЃ-Ж“ALAGI zei К‹Й›lЙ›i wu, gi ti ve zalaЙ a Й ula nui MelemЙ”te ya, Ilii naМЃ-doun zunui, ta Fineyase naМЃ-doun zunui Eleazaal. Levi nui niiti ti Й Й›ni ti Й oba, ti-laaseigiti kaa: Zozuwe naМЃ-doun zunui YozaЙ“ade, ta ЖЃinuwi naМЃ-doun zunui Noadia.
\v 34 Ti gaaluni, eМЃ Й Й”Й Й”, buЙІЙ›gi Й“Й”gai pЙ› ge zЙ›К‹Й›ni sЙ›К‹Й›i zu.
\p 
\v 35 Niiti kpein ti duЙ”lai Й Й›Й›ni, ti Й ale ma, naati ti zalaЙ aiti kulani IzilayЙ›le naМЃ-GALAGI К‹Й› ga: nikЙ› zinЙ› puugЙ” maazu felegЙ” (12), IzilayЙ›le nuiti kpein bЙ›. Ti baala sinЙ› К‹uutaaК‹uugЙ” maazu lЙ”zita (96), ta baala ziК‹o К‹uulЙ”fela maazu lЙ”fela (77) Й ulani gala zalaЙ aiti faa zu, ta boli zinЙ› puugЙ” maazu felegЙ” (12) ga koto gba zalaЙ ai. Togani naati kpein ti Й alani Ж“Й”oЙ Й” GALAGI К‹Й›.
\v 36 Naa К‹oluma ti masagi naМЃ-sЙ›К‹Й›i zu wooi laazeelini naМЃ-nu wolaiti ma, ta zou zЙ›К‹Й› Й undiЙ iiti ma, ti zeini ziЙ› wolai Efelate folo liizu К‹elei. Naati ti tЙ”nЙ” ma Й“Й”bai Й Й›Й›ni IzilayЙ›le nuiti bЙ›, GALA sei К‹Й›lЙ›i lo fai zu.
\c 9
\s1 WЙ›Й›n anzanuiti fulu vai // IzilayЙ›le nui ma mЙ”inmЙ”in bЙ›
\p 
\v 1 Niima vaiti poluma, kundiЙ ii tanigaa ti maaЙ“uЙ ani baМЂ, ti Й Й› maМЂ: В«IzilayЙ›le nuЙ“usЙ›iti, ta zalaЙ a Й ula nuiti, naa К‹Й›Й› Levi nuiti ba, ti la maaЙ oozani zooi nii zu nuЙ“usЙ›iti ba, ti la kЙ›Й›ni ti К‹a zeЙ e zii niiti ta-Й Й”zЙ”ba vaiti polu: Kanaan nuiti, Ж“Й›te nuiti, FelЙ›ze nuiti, YeЙ“use nuiti, AmЙ”n nuiti, MoaЙ“e nuiti, Ezipete nuiti, ta Amool nuiti.
\v 2 MazЙ”lЙ”Й” ti naati ti-loun anzanuiti fuluК‹Й› Й“Й”Й Й” К‹Й›, ta ti-loun zunuiti bЙ›, ti zii ЙІadegai zupua ga zooi nii zu nuЙ“usЙ›iti. Zou zЙ›К‹Й› Й undiЙ iiti ta kundiЙ iiti ka ti Й Й›a ga nu mЙ”ungiti ti siЙ› К‹ele ЙІЙ”i Й Й›.В»
\p 
\v 3 GeМЂ naa mЙ›nigai ma, geМЂ naМЂ-seЙ eiti ta naМЂ-seЙ e maazu zeЙ ei К‹alini ga, geМЂ Й—a nЙ”МЂundeЙ aiti ta kpЙ›МЂlЙ›i volofolo ma kidaaК‹iligi maaК‹ele ma, geМЂ zei gaazuЙ ilii zu.
\v 4 GeМЂ yЙ›ni zeini naМЃ eyЙ›su kpЙ”kЙ” zalaЙ a Й ula ziЙ›gi zeeli. Niiti kpein ti Й Й›ni luazu IzilayЙ›le naМЃ-GALAGI naМЃ-tukpЙ”i К‹a, naama nuiti ta-Й Й›Й›woti ЙІЙ”iti daalЙ”Й Й”ma, ti Й ulaai duЙ”lai zu, naati ti К‹aani, ti zei koМЂba.
\v 5 KpЙ”kЙ” zalaЙ a Й ula ziЙ›gi zu, geМЂ wuzeЙ eni, geМЂ Й ula naМЂ-gaazuЙ ilii zu, naМЂ-seЙ eiti ta naМЂ-seЙ e maazu zeЙ ei К‹aliai ga, geМЂ К‹ilЙ›ni ЙІiМЂibiЙ a, geМЂ yeemaale naМЂ-GALAGI, Ж“Й”oЙ Й” GALAGI ma,
\v 6 geМЂ maanЙ›Й›nЙ› Й ani: В«NaМЂ-GALAGI, niima unfe kaa le! Ee, naМЂ-GALAGI, naМЂ unfesu vЙ”lЙ” ga geМЂ К‹a Й aazuwuzeЙ e, geМЂ wЙ›lЙ› eМЂ К‹a. MazЙ”lЙ”Й” gaМЃ-vaaЙ aaza golaiti ti wola mЙ”inЙ—a, ti gi maaЙ“Й”lea, gi-zЙ”giti ti Й aaЙ ooza, ti zei geeЙ Й”lЙ”gi К‹a.
\v 7 EМЃ zo gi-Й Й›Й›ni ta-voloiti ma, eМЃ zeeli za ma, gaМЃ ga sЙ”ba nuiti nЙ”, gaМЃ-vaaЙ aaza golaiti maaК‹ele Й a eМЃ kЙ›a, gaМЃ-o, gaМЃ-masagiti-yo, gaМЃ-zalaЙ a Й ula nuiti, eМЂ gi lЙ”a la zii Й iligiti ta-masagiti zea, eМЂ gi ve boЙ a zЙ”kpЙ”i ta duЙ”lai ya, gi Й Й› toomai ta unfegi laawu, eЙ Й›К‹elei eМЃ la za.
\v 8 KЙ›lЙ› niima ziЙ›gi zu, Ж“Й”oЙ Й” GALAGI, gaМЃ-Ж“ALAGI, eМЂ undaanЙ› Й Й›a gi К‹Й› yeeЙ Й›Й ala go laawu, ga nui tanigaa ti yЙ› vulua gi zaama, ti Й ale ma, ti К‹a, ti zei Й—a-you ЙІadegai zu, eМЂ gi-Й aazuК‹Й›ti seЙ ea ma, ti volo, eМЂ zЙ›nvu go ve gi К‹Й› ga luЙ”lai zaama.
\v 9 Gi Й Й›a duЙ”lai zu, kЙ›lЙ› eМЂ la Й Й›lЙ›ni gi К‹a. EМЂ PЙ›Й›lese masagiti gaazu К‹agЙ” logЙ› gi К‹a, ti vaaК‹Й› bu ga ti gi-yЙ›nvui yЙ› gi ya, nii a kЙ› gi gaМЃ-Ж“ALAGI zei К‹Й›lЙ›i lo К‹olu, ta gi koloЙ olosuК‹Й›ti buzeЙ e К‹olu, ta gi lЙ”Й”Й uzu К‹agЙ” zЙ”lЙ”Й” Zuda ta ZeluzalЙ›me.
\p 
\v 10 В«KЙ›lЙ› lee Й a gaМЃ bo niina naa pЙ› poluma, ee, gaМЃ-Ж“ALAGI! MazЙ”lЙ”Й” gi Й Й›lЙ›a Й—a-lЙ”giti ba,
\v 11 niiti eМЂ ti veai gi ya ga Й—a-wotiЙ Й› nuiti maaК‹ele, GALA goo wo nuiti, eМЂ Й Й›ni gi ma: вЂ№Zooi nii wo К‹aazu sЙ”lЙ”Й”su, kЙ”zЙ”К‹Й›, tЙ”Й”zei zii niiti ti zeini su ti Й Й”zЙ”К‹Й›, tama ti sulaavegЙ› ga ta-Й Й”zЙ”ba vaiti eyЙ›su eМЃ zeeli kwЙ›gi pЙ› ma.
\v 12 Naa Й a eМЃ ba, aМЂ mina wo-loun anzanuiti fe ti-loun zunuiti bЙ› ga anza, aМЂ mina ti-loun anzanuiti fulu wo-loun zunuiti bЙ› ga anza, aМЂ mina yiizoolЙ› ga ta-yiilЙ›igi ta ta-undaanЙ›Й›i ma vaa, naazu wa zЙ›bЙ›i zЙ”lЙ”Й”, wo Й—a zooi К‹aalЙ”nЙ” pagЙ”iti mi, wo ma zooi yЙ› wo-lointi zea ga poganii eyЙ›su Й Й”.вЂє
\v 13 Nii kpein seeliai gi ma, naa Й ulaК‹Й› gaМЃ-Й otoiti ta gi-zЙ” ЙІЙ”u wolaiti su, kЙ›lЙ› anЙ›Й› naa К‹e, eМЂ la gi zoni ga К‹elei soloogai la gaМЃ-vaaЙ aaza golaiti ma, eМЂ vaaК‹Й› bu ga eМЂ gi-mЙ”ta goi yЙ› naМЃ.
\v 14 Leeni vaa zu gaМЃ li Й—a-lЙ”giti koloЙ olosu К‹olu, ga gi Й—a vului Й Й› yЙ”Й Й”zu gaМЃ zii niiti ti kЙ”zЙ”ba vaiti kЙ›Й›zu? EМЂ la yiiЙ aawana gi ma naazu Й“aa, eМЃ К‹a gi pЙ› suwuЙ aaleК‹e, kulaba la ba?
\v 15 IzilayЙ›le naМЃ-GALAGI, Ж“Й”oЙ Й” GALAGI, eМЂ lelebogЙ›, naa Й a eМЃ kЙ›a, eМЂ gi mЙ”ta goi gi yЙ› ga vulua za, wЙ›lЙ› gi К‹a eМЂ Й akala ga gaМЃ-Й otoiti, tama niima Й Й›К‹elei nii zu, gi la zooga losu kpaan eМЂ Й akala.В»
\c 10
\s1 IzilayЙ›le Й undiЙ iiti ti minazeЙ e vai ga // ti Й olo GALA bЙ›
\p 
\v 1 SiЙ›gi zu Жђsedalase laaК‹Й›a Й Й›ni de zooi ma, eМЃ Й—a wЙ”lЙ”, GALA sei К‹Й›lЙ›i laaК‹Й›, eМЃ Й—a niima Ж“ALA falii ta tosЙ”gai nii Й Й›, IzilayЙ›le nuЙ“usЙ›i ma mЙ”inmЙ”in ge Й aalЙ›Й›ni ba koba, zunuiti ta anzanuiti ta doungoiti, ti Й—a wЙ”lЙ” ga gola.
\v 2 Naazu YeЙ iyЙ›le naМЃ-doun zunui Sekania, eМЃ ga Elame mavofodai ta, naa Й Й›ni Жђsedalase ma: В«Gi Й Й›a ga wooК‹alada nuiti gaМЃ-Ж“ALAGI К‹Й›, ga gi lii vai gi wЙ›Й›n anzanuiti fulu zii Й iligiti saama, niiti ti zooi nii zu. KЙ›lЙ› kito ko Й a dЙ› IzilayЙ›le К‹Й› niima vai zu.
\v 3 Ade minazeЙ e niina ada-Ж“ALAGI К‹Й› ga ada wЙ›Й›n anzanui niiti kpЙ›Й› ta ti-lointi, eЙ Й›К‹elei maМЂliЙ ii Жђsedalase naМЃ-tЙ›nЙ›gi la, ta niiti kpein ti ada-Ж“ALAGI naМЃ-deveiti sosu. Ade naМЃ-tЙ”giti so kpaan.
\v 4 WuzeЙ e, tЙ”Й”zei Й—a Й a Й—a niima vai Й aaЙ ula ba. KЙ›lЙ› gaМЃ yЙ›su eМЂ К‹a, zЙ›bЙ›zeЙ e, eМЂ kЙ›!В»
\p 
\v 5 Жђsedalase wuzeЙ eni, eМЃ kpЙ›Й›lagi la zalaЙ a Й ula nuiti ta-Й undiЙ iiti bu, ta Levi geleiti, ta IzilayЙ›le nuiti pЙ›, ga ti Й ona ga ta naa Й Й›, nii ti bogai. Ti pЙ› ti Й onani.
\v 6 Naa К‹oluma Жђsedalase zeЙ eni GALA sei К‹Й›lЙ›i ma Й oizuК‹Й›, eМЃ li EliasiЙ“e naМЃ-doun zunui YoЙ anan laazuК‹Й›, eМЃ ЙІi naМЃ, kЙ›lЙ› eМЃ Й Й›lЙ›ni daamianigi pЙ› ba ta kpЙ”le aniiti pЙ›, mazЙ”lЙ”Й” eМЃ Й Й›ni wЙ”lЙ”zu IzilayЙ›le luЙ” wЙ”lЙ”maiti ta-Й oto wolaiti faa zu.
\s1 DuЙ” wЙ”lЙ”maiti ta-Й aalЙ›ba vai ZeluzalЙ›me
\p 
\v 7 Ti sЙ›К‹Й›i leК‹eni naМЃzu Zuda yooi zu naМЃ pЙ› ta ZeluzalЙ›me, ga niiti kpein ti Й Й›a duЙ”lai zu, ti Й alegai ma, ti Й aalЙ› ba ZeluzalЙ›me.
\v 8 KundiЙ iiti ta totuЙ Й”iti ti deveni ga zЙ”i nЙ”pЙ› eМЃ la К‹aani folo saК‹agЙ” laawu, kЙ”ligiti ta ve Ж“Й”oЙ Й” GALAGI К‹Й›, tЙ” Й“Й”Й Й”i Й a Й ula naati saama, ti Й ulaai duЙ”lai zu.
\p 
\v 9 Zuda ta ЖЃЙ›nzamЙ›n zunuiti kpein ti Й aalЙ›Й›ni ba ZeluzalЙ›me folo saК‹agЙ” laawu. Naa Й Й›Й›ni alugi laaК‹uusiЙ›i ma volo К‹uufelegЙ”i (20) ma. NuЙ“usЙ›iti pЙ› ti Й Й›ni zeini GALA sei К‹Й›lЙ›i ma Й oizuК‹Й›, ti Й—a Й“ali, tЙ”Й”zei naama vai К‹a ti Й Й›ni su, ta tonai eМЃ Й Й›ni К‹uuzu ga sabalagi.
\v 10 ZalaЙ a Й ula nui Жђsedalase wuzeЙ eni, eМЃ Й Й› ti ma: В«WooК‹aladai Й a wo kЙ›ai ga wo wЙ›Й›n anzanuiti fulu vai, wo ta Й“Й”ga IzilayЙ›le nuЙ“usЙ›iti ta-Й oto Й asЙ”i К‹a.
\v 11 AМЂ laa zЙ” ga niina Ж“Й”oЙ Й” GALAGI К‹Й›, wo-Й Й›Й›ni ta-Ж“ALAGI, wo ziima vai Й Й›, aМЂ bali ma wa zooi nii zu nuЙ“usЙ›iti, ta wЙ›Й›n anzanuiti.В»
\p 
\v 12 NuЙ“usЙ›iti pЙ› ti gooЙ aaК‹oteni ga woo wola, ti Й Й› ma: В«Gi-yee Й a bu! GaМЃ naa Й Й›, nii eМЂ bogai!
\v 13 KЙ›lЙ› nuЙ“usЙ›i mЙ”inК‹Й›, tonai Й aa eМЃ К‹uuzu, nu la zooga yЙ›su eteaК‹Й›, niima vai mu ge la vЙ”lЙ” ga folo Й ila Й“aa folo felegЙ” vaa nЙ”, mazЙ”lЙ”Й” gi ma mЙ”inmЙ”in, gi tЙ” koloЙ ologi Й Й›Й›К‹Й› niima vai zu.
\v 14 GaМЃ pЙ” ga gaМЃ-Й undiЙ iiti ti yЙ› nuЙ“usЙ›i yeema, zЙ”iti kpein ti wЙ›Й›n anzanuiti fuluai, naati ti Й—a К‹a ti К‹Й” ta ta-laa Й undiЙ iiti, naa К‹Й›Й› tukpЙ”Й aaleК‹e nuiti ba, kui naa ma, nii togai ti К‹Й›, ga niima vai Й aaЙ ulazu ba ga pagЙ” eyЙ›su gaМЃ-Ж“ALAGI naМЃ-ziiЙ aawana wolai zeЙ e gi maala.В»
\v 15 AzayЙ›le naМЃ-doun zunui Zonatan, ta Tikava naМЃ-doun zunui Yaziya, naa К‹Й›Й› Mesulame К‹a ta Levi nui SaЙ“etayi, naati gila kpe nЙ” Й a ti Й Й›lЙ›ni naa ma levei К‹a.
\p 
\v 16 IzilayЙ›le nuiti niiti ti Й ulani duЙ”lai zu, naati pЙ› ti vaani bu. ZalaЙ a Й ula nui Жђsedalase yiimazeЙ eni pЙ›lЙ›yeЙ e Й undiЙ iiti pЙ›lЙ›yeЙ eiti kpein saama, eМЃ yeeloni ti Й ilagilagi kpein ba. Ti ta-zei lЙ”Й”zeini alugi К‹uusiЙ›i ma volo mЙ”ungi ma nii a kЙ› ti niima vai wuuК‹Й›tЙ›.
\v 17 Alu mЙ”ungi ma volo mЙ”ungi, ti Й“eni ga zunuiti kpein ta-vaiti gaaЙ ula ba, niiti ti wЙ›Й›n anzanuiti fuluni.
\s1 SЙ”ba nuiti daaseigiti
\li1 
\v 18 ZalaЙ a Й ula nuiti ti-mavofodaiti saama, tanigaa ti wЙ›Й›n anzanuiti fuluni, naama nuiti daaseigiti ka ga nii:
\li1 Yosadake naМЃ-doun zunui Zozuwe mavofodaiti saama, ta kЙ›Й›Й Й›lointi: Maaseya, EliyezЙ›Й›l, YaliЙ“e, ta Gedalia.
\v 19 Ti minazeЙ eni, ti Й ona ga ta ti-anzaiti kpЙ›Й›zu, naa К‹olu ti baala sinЙ› Й ilagila kula ga faazuЙ“Й›tЙ› zalaЙ ai ta-Й otoi ma zuvaayЙ› fai zu.
\li1 
\v 20 Niiti ti Й Й›ni ImЙ›Й›l mavofodaiti saama, ti Й Й›ni ga:
\li2 Ж“anani ta ZeЙ“adia.
\li1 
\v 21 Niiti ti Й Й›ni Ж“alime mavofodaiti saama, ti Й Й›ni ga:
\li2 Maaseya, Eli, Semaya, YeЙ iyЙ›le ta Woziase.
\li1 
\v 22 Niiti ti Й Й›ni Pasuul mavofodaiti saama, ti Й Й›ni ga:
\li2 EliyЙ”yenayi, Maaseya, IsemayЙ›le, NetaneyЙ›le, YozaЙ“ade ta Eleyasa.
\b
\li1 
\v 23 Niiti ti Й Й›ni Levi nuiti saama, ti Й Й›ni ga:
\li2 YozaЙ“ade, Simeyi, Kelaya eМЃ lolisu Й“alaa ga Kelita, Petayia, Zuda ta EliyezЙ›Й›l.
\b
\li1 
\v 24 Nii eМЃ Й Й›ni gЙ›ingЙ›in gani nuiti saama, naa Й Й›ni ga:
\li2 EliasiЙ“e.
\b
\li1 Niiti ti Й Й›ni siЙ ida makЙ› nuiti saama, ti Й Й›ni ga:
\li2 Salume, TelЙ›me ta Uli.
\b
\li1 
\v 25 Niiti ti Й Й›ni IzilayЙ›le nui mЙ”taiti saama, ti Й Й›ni ga:
\li1 PaleyЙ”se mavofodai zu geleiti ti Й Й›ni ga:
\li2 Lamia, Yiziya, Malikiya, Miyamine, Eleazaal, Malikiya ta ЖЃenaya.
\li1 
\v 26 Elame mavofodai zu geleiti ti Й Й›ni ga:
\li2 Matania, Zakali, YeЙ iyЙ›le, AЙ“idi, YelemЙ”te ta Eli.
\li1 
\v 27 Zatu mavofodai zu geleiti ti Й Й›ni ga:
\li2 EliyЙ”yenayi, EliasiЙ“e, Matania, YelemЙ”te, ZaЙ“ade ta Aziza.
\li1 
\v 28 ЖЃeЙ“ayi mavofodai zu geleiti ti Й Й›ni ga:
\li2 YoЙ anan, Ж“anania, ZaЙ“ayi ta Atalayi.
\li1 
\v 29 ЖЃani mavofodai zu geleiti ti Й Й›ni ga:
\li2 Mesulame, Maluke, Adaya, YasuЙ“e, Seyale ta LamЙ”te.
\li1 
\v 30 PaЙ ate-MoaЙ“e mavofodai zu geleiti ti Й Й›ni ga:
\li2 Adana, Kelale, ЖЃenaya, Maaseya, Matania, ЖЃЙ›saleyЙ›le, ЖЃinuwi ta ManaseМЃ.
\li1 
\v 31 Ж“alime mavofodai zu geleiti ti Й Й›ni ga:
\li2 EliyezЙ›Й›l, Yisiya, Malikiya, Semaya, SimiyЙ”n,
\v 32 ЖЃЙ›nzamЙ›n, Maluke ta Semalia.
\li1 
\v 33 Ж“asume mavofodai zu geleiti ti Й Й›ni ga:
\li2 Matenayi, Matata, ZaЙ“ade, ElifelЙ›te, Yelemayi, ManaseМЃ ta Simeyi.
\li1 
\v 34 ЖЃani mavofodai zu geleiti ti Й Й›ni ga:
\li2 Maadayi, Amalame, UwЙ›le
\v 35 ЖЃenaya, ЖЃedia, KeluЙ u,
\v 36 Vania, MelemЙ”te, EliasiЙ“e,
\v 37 Matania, Matenayi, Yaasayi,
\v 38 ЖЃani, ЖЃinuwi, Simeyi,
\v 39 Selemiya, Natan, Adaya,
\v 40 Makenadebayi, Sasayi, Salayi,
\v 41 AzalЙ›le, Selemiya, Semalia,
\v 42 Salume, Amalia ta ZozЙ›fe.
\li1 
\v 43 NeЙ“o mavofodai zu geleiti ti Й Й›ni ga:
\li2 YeiyЙ›le, Matitia, ZaЙ“ade, ZeЙ“ina, Yadayi, ZowЙ›le ta ЖЃenaya.
\b
\p 
\v 44 Zunui niiti pЙ› ti wЙ›Й›n anzanuiti fuluni, ma mЙ”inmЙ”ingaa ti doun zЙ”lЙ”Й” ti К‹a.
