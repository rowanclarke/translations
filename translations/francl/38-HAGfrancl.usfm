\p
\v 20 \w La|strong="H03068"\w* \w parole|strong="H01697"\w* \w de|strong="H01697"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w fut|strong="H03068"\w* \w adressée|strong="H01697"\w* \w une|strong="H03068"\w* \w seconde|strong="H08145"\w* \w fois|strong="H08145"\w* \w à|strong="H03068"\w* \w Aggée|strong="H02292"\w* \w le|strong="H03068"\w* \w vingt-quatrième|strong="H03068"\w* \w jour|strong="H02320"\w* \w du|strong="H01697"\w* \w mois|strong="H02320"\w* \w en|strong="H03068"\w* \w ces|strong="H01697"\w* \w termes|strong="H00559"\w* :  
