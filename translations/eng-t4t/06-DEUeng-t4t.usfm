\v 14 \w The|strong="H8085"\w* people-groups \w that|strong="H3588"\w* \w you|strong="H5414"\w* \w are|strong="H1471"\w* \w about|strong="H8085"\w* \w to|strong="H3068"\w* \w expel|strong="H3423"\w* \add from the land that you will occupy\add* ◄consult/\w seek|strong="H3808"\w* advice \w from|strong="H8085"\w*► \w soothsayers|strong="H6049"\w* \w and|strong="H3068"\w* \w those|strong="H8085"\w* \w who|strong="H3068"\w* \w practice|strong="H6049"\w* \w divination|strong="H7080"\w*. \w But|strong="H3588"\w* \w as|strong="H3068"\w* \w for|strong="H3588"\w* \w you|strong="H5414"\w*, \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w does|strong="H3808"\w* \w not|strong="H3808"\w* \w allow|strong="H5414"\w* \w you|strong="H5414"\w* \w to|strong="H3068"\w* \w do|strong="H3068"\w* \w that|strong="H3588"\w*.  
\v 15  \add Some day\add* \w he|strong="H3068"\w* \w will|strong="H3068"\w* send \w from|strong="H8085"\w* \w among|strong="H7130"\w* \w you|strong="H3644"\w* \w a|strong="H3068"\w* \w prophet|strong="H5030"\w* \w like|strong="H3644"\w* \w me|strong="H3644"\w*. \add He is the one who will tell you what will happen in the future\add*, \w and|strong="H6965"\w* \w he|strong="H3068"\w* \w is|strong="H3068"\w* \w the|strong="H8085"\w* \w one|strong="H3068"\w* whom \w you|strong="H3644"\w* must \w heed|strong="H8085"\w*.  
\v 16 \w On|strong="H3117"\w* \w the|strong="H3605"\w* \w day|strong="H3117"\w* \w that|strong="H7200"\w* \w your|strong="H3068"\w* ancestors \w were|strong="H3117"\w* \w gathered|strong="H8085"\w* \w at|strong="H3068"\w* \w the|strong="H3605"\w* bottom \w of|strong="H3068"\w* Sinai Mountain, \w they|strong="H3117"\w* pleaded \w with|strong="H5973"\w* \w me|strong="H7200"\w* \w saying|strong="H6963"\w*, ‘\w We|strong="H3117"\w* \w do|strong="H3068"\w* \w not|strong="H3808"\w* \w want|strong="H3808"\w* \w Yahweh|strong="H3068"\w* \w to|strong="H4191"\w* speak [MTY] \w to|strong="H4191"\w* \w us|strong="H7200"\w* \w again|strong="H5750"\w*, \w and|strong="H3068"\w* \w we|strong="H3068"\w* \w do|strong="H3068"\w* \w not|strong="H3808"\w* \w want|strong="H3808"\w* \w to|strong="H4191"\w* \w see|strong="H7200"\w* \w this|strong="H2063"\w* huge fire \add that is burning on the mountain\add*!’ \add Your ancestors said that because they were afraid\add* \w that|strong="H7200"\w* \w they|strong="H3117"\w* \w would|strong="H3068"\w* \w die|strong="H4191"\w* \add if Yahweh spoke to them again\add*.   
\p
\v 17 \w Then|strong="H1696"\w* \w Yahweh|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w me|strong="H1696"\w*, ‘\w What|strong="H1696"\w* \w they|strong="H3068"\w* \w have|strong="H3068"\w* \w said|strong="H1696"\w* \w is|strong="H3068"\w* \w true|strong="H3068"\w*/wise.  
\v 18 \w So|strong="H5414"\w* \w I|strong="H5414"\w* \w will|strong="H1697"\w* \w send|strong="H5414"\w* \w from|strong="H6965"\w* \w among|strong="H7130"\w* \w them|strong="H5414"\w* \w a|strong="H3068"\w* \w prophet|strong="H5030"\w* \w who|strong="H3605"\w* \w will|strong="H1697"\w* \w be|strong="H1697"\w* \w like|strong="H3644"\w* \w you|strong="H5414"\w*. \w I|strong="H5414"\w* \w will|strong="H1697"\w* \w tell|strong="H1696"\w* \w him|strong="H5414"\w* \w what|strong="H1697"\w* \w to|strong="H1696"\w* \w say|strong="H1696"\w*, \w and|strong="H6965"\w* \w then|strong="H6965"\w* \w he|strong="H3605"\w* \w will|strong="H1697"\w* \w tell|strong="H1696"\w* \w people|strong="H1696"\w* \w everything|strong="H3605"\w* \w that|strong="H3605"\w* \w I|strong="H5414"\w* \w tell|strong="H1696"\w* \w him|strong="H5414"\w* \w to|strong="H1696"\w* \w say|strong="H1696"\w*.  
\v 19 \w He|strong="H3808"\w* \w will|strong="H1961"\w* \w speak|strong="H1696"\w* \w for|strong="H8034"\w* \w me|strong="H5973"\w*. \w And|strong="H8085"\w* \w I|strong="H1697"\w* \w will|strong="H1961"\w* punish anyone \w who|strong="H3808"\w* \w does|strong="H3808"\w* \w not|strong="H3808"\w* \w heed|strong="H8085"\w* \w what|strong="H1697"\w* \w he|strong="H3808"\w* \w says|strong="H1696"\w*.  
\v 20 \w But|strong="H3808"\w* \w if|strong="H1931"\w* \w any|strong="H1697"\w* other \add person says that he is a\add* \w prophet|strong="H5030"\w* \add and\add* dares \w to|strong="H1696"\w* \w speak|strong="H1696"\w* \w a|strong="H3068"\w* \w message|strong="H1697"\w* \w which|strong="H1931"\w* \w he|strong="H1931"\w* falsely \w says|strong="H1696"\w* comes \w from|strong="H1697"\w* \w me|strong="H1696"\w* \w but|strong="H3808"\w* \w which|strong="H1931"\w* \w I|strong="H1697"\w* \w did|strong="H3808"\w* \w not|strong="H3808"\w* \w tell|strong="H1696"\w* \w him|strong="H6680"\w* \w to|strong="H1696"\w* \w speak|strong="H1696"\w*, \w or|strong="H3808"\w* \w if|strong="H1931"\w* \w anyone|strong="H1931"\w* \w who|strong="H1931"\w* \w speaks|strong="H1696"\w* \w a|strong="H3068"\w* \w message|strong="H1697"\w* \w that|strong="H1931"\w* \w he|strong="H1931"\w* \w says|strong="H1696"\w* other gods [MTY] \w have|strong="H5030"\w* revealed \w to|strong="H1696"\w* \w him|strong="H6680"\w*, \w he|strong="H1931"\w* \w must|strong="H4191"\w* \w be|strong="H4191"\w* \w executed|strong="H4191"\w* \add for doing that\add*.’   
\p
\v 21 \w But|strong="H3588"\w* \w if|strong="H3588"\w* \w you|strong="H3588"\w* \w say|strong="H1696"\w* \w to|strong="H1696"\w* \w yourself|strong="H3824"\w*, ‘\w How|strong="H3588"\w* \w can|strong="H3045"\w* \w we|strong="H3068"\w* \w know|strong="H3045"\w* \w if|strong="H3588"\w* \w a|strong="H3068"\w* \w message|strong="H1697"\w* \add that someone tells us\add* \w does|strong="H3808"\w* \w not|strong="H3808"\w* \w come|strong="H3045"\w* \w from|strong="H3068"\w* \w Yahweh|strong="H3068"\w*?’  
\v 22  \add The answer is that\add* \w when|strong="H1961"\w* someone \w speaks|strong="H1696"\w* \w a|strong="H3068"\w* \w message|strong="H1697"\w* \add about what will happen in the future\add*, \w a|strong="H3068"\w* \w message|strong="H1697"\w* \w that|strong="H1931"\w* \w he|strong="H1931"\w* \w says|strong="H1696"\w* \w was|strong="H3068"\w* revealed \w by|strong="H3068"\w* \w Yahweh|strong="H3068"\w*, \w if|strong="H1961"\w* \w what|strong="H1697"\w* \w he|strong="H1931"\w* \w says|strong="H1696"\w* \w does|strong="H3808"\w* \w not|strong="H3808"\w* \w happen|strong="H1961"\w*, \add you will know that\add* \w the|strong="H3068"\w* \w message|strong="H1697"\w* \w did|strong="H3068"\w* \w not|strong="H3808"\w* \w come|strong="H1961"\w* \w from|strong="H4480"\w* \w Yahweh|strong="H3068"\w*. \w That|strong="H1931"\w* \w person|strong="H1696"\w* \w has|strong="H3068"\w* wrongly claimed \w that|strong="H1931"\w* \w it|strong="H1931"\w* \w was|strong="H3068"\w* revealed \w to|strong="H1696"\w* \w him|strong="H1931"\w* \w by|strong="H3068"\w* \w Yahweh|strong="H3068"\w*. \w So|strong="H4480"\w* \w you|strong="H3808"\w* \w do|strong="H3068"\w* \w not|strong="H3808"\w* \w need|strong="H1697"\w* \w to|strong="H1696"\w* \w be|strong="H1961"\w* \w afraid|strong="H1481"\w* \w of|strong="H3068"\w* \add anything that\add* \w he|strong="H1931"\w* \add says\add*.”   
\c 19  
\s1 The cities of refuge  
\p
\v 1 \w After|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w has|strong="H3068"\w* \w gotten|strong="H5414"\w* rid \w of|strong="H1004"\w* \w the|strong="H3588"\w* people-groups \w from|strong="H3772"\w* \w the|strong="H3588"\w* land \w that|strong="H3588"\w* \w he|strong="H3588"\w* \w is|strong="H3068"\w* \w giving|strong="H5414"\w* \w to|strong="H3068"\w* \w you|strong="H3588"\w*, \w and|strong="H3068"\w* \w after|strong="H3588"\w* \w you|strong="H3588"\w* \w have|strong="H3068"\w* \w expelled|strong="H3423"\w* \w them|strong="H5414"\w* \w from|strong="H3772"\w* \w their|strong="H3068"\w* \w cities|strong="H5892"\w* \w and|strong="H3068"\w* \w you|strong="H3588"\w* start \w to|strong="H3068"\w* \w live|strong="H3427"\w* \w in|strong="H3427"\w* \w their|strong="H3068"\w* \w houses|strong="H1004"\w*,  
\v 2-3 you must divide into three parts the land that he is giving to you. Then choose \w a|strong="H3068"\w* city in each part. You must make good roads \add in order that people can get to those cities easily\add*. Someone who kills another person can escape to one of those cities \add to be safe/protected\add*.   
\p
\v 4 “\w This|strong="H2088"\w* \w is|strong="H2088"\w* \w the|strong="H5221"\w* \w rule|strong="H1697"\w* \w about|strong="H1697"\w* someone \w who|strong="H1931"\w* \w has|strong="H2088"\w* \w killed|strong="H5221"\w* \w another|strong="H7453"\w* person. \w If|strong="H1931"\w* someone ◄\w accidentally|strong="H1847"\w*/\w without|strong="H3808"\w* planning \w to|strong="H1697"\w*► \w kills|strong="H5221"\w* \w another|strong="H7453"\w* person \w who|strong="H1931"\w* \w was|strong="H1931"\w* \w not|strong="H3808"\w* \w his|strong="H5221"\w* \w enemy|strong="H8130"\w*, \w he|strong="H1931"\w* \w may|strong="H7523"\w* \w escape|strong="H5127"\w* \w to|strong="H1697"\w* \w one|strong="H2088"\w* \w of|strong="H1697"\w* \w those|strong="H1931"\w* cities \w and|strong="H8033"\w* \w be|strong="H3808"\w* safe/protected \w there|strong="H8033"\w*.  
\v 5 \w For|strong="H3027"\w* example, \w if|strong="H1931"\w* \w two|strong="H4480"\w* \w men|strong="H3772"\w* go \w into|strong="H3027"\w* \w the|strong="H4480"\w* \w forest|strong="H3293"\w* \w to|strong="H4191"\w* \w cut|strong="H3772"\w* \w some|strong="H4480"\w* \w wood|strong="H6086"\w*, \w if|strong="H1931"\w* \w the|strong="H4480"\w* \w axe|strong="H1631"\w* \w head|strong="H1270"\w* \w comes|strong="H4672"\w* \w off|strong="H3772"\w* \w the|strong="H4480"\w* \w handle|strong="H6086"\w* \w while|strong="H1931"\w* \w one|strong="H4480"\w* \w of|strong="H3027"\w* \w them|strong="H3027"\w* \w is|strong="H1931"\w* \w chopping|strong="H2404"\w* \w down|strong="H3772"\w* \w a|strong="H3068"\w* \w tree|strong="H6086"\w* \w and|strong="H3027"\w* \w the|strong="H4480"\w* \w axe|strong="H1631"\w* \w head|strong="H1270"\w* \w strikes|strong="H4672"\w* \w and|strong="H3027"\w* \w kills|strong="H4191"\w* \w the|strong="H4480"\w* \w other|strong="H7453"\w* \w man|strong="H4191"\w*, \w the|strong="H4480"\w* \w man|strong="H4191"\w* \add who was using the axe\add* \w will|strong="H5892"\w* \w be|strong="H4191"\w* allowed \w to|strong="H4191"\w* \w run|strong="H5127"\w* \w to|strong="H4191"\w* \w one|strong="H4480"\w* \w of|strong="H3027"\w* \w those|strong="H4480"\w* \w cities|strong="H5892"\w* \w and|strong="H3027"\w* \w be|strong="H4191"\w* safe \w there|strong="H4672"\w*, \add because the people of that city will protect him\add*.  
\v 6 \w Because|strong="H3588"\w* \w he|strong="H1931"\w* accidentally \w killed|strong="H5221"\w* \w someone|strong="H5315"\w*, \w and|strong="H4941"\w* \w because|strong="H3588"\w* \w the|strong="H3588"\w* \w man|strong="H5315"\w* \w was|strong="H1931"\w* \w not|strong="H3808"\w* \w his|strong="H5221"\w* \w enemy|strong="H8130"\w*, \w he|strong="H1931"\w* \w can|strong="H4194"\w* try \w to|strong="H1870"\w* \w run|strong="H7291"\w* \w to|strong="H1870"\w* \w one|strong="H3808"\w* \w of|strong="H1870"\w* \w those|strong="H1931"\w* cities. \w If|strong="H3588"\w* there \w were|strong="H5315"\w* \w only|strong="H3588"\w* \w one|strong="H3808"\w* \w city|strong="H1931"\w*, \w it|strong="H1931"\w* \w may|strong="H5315"\w* \w be|strong="H3808"\w* \w a|strong="H3068"\w* \w long|strong="H7235"\w* \w distance|strong="H1870"\w* \w to|strong="H1870"\w* \w that|strong="H3588"\w* \w city|strong="H1931"\w*. \w Then|strong="H3588"\w* \w if|strong="H3588"\w* \w the|strong="H3588"\w* \w relative|strong="H1350"\w* \w of|strong="H1870"\w* \w the|strong="H3588"\w* \w man|strong="H5315"\w* \w who|strong="H1931"\w* \w was|strong="H1931"\w* \w killed|strong="H5221"\w* [MTY], \w the|strong="H3588"\w* \w man|strong="H5315"\w* \w who|strong="H1931"\w* \w is|strong="H1931"\w* supposed/expected \w to|strong="H1870"\w* \w get|strong="H5381"\w* revenge, \w is|strong="H1931"\w* \w very|strong="H7235"\w* angry, \w he|strong="H1931"\w* \w may|strong="H5315"\w* \w be|strong="H3808"\w* \w able|strong="H5381"\w* \w to|strong="H1870"\w* \w catch|strong="H5381"\w* \w the|strong="H3588"\w* other \w person|strong="H5315"\w* \w before|strong="H3808"\w* \w he|strong="H1931"\w* arrives \w at|strong="H3808"\w* \w that|strong="H3588"\w* \w city|strong="H1931"\w*.  
\v 7  \add To prevent that from happening\add*, \w you|strong="H6680"\w* must choose \w three|strong="H7969"\w* \w cities|strong="H5892"\w*, \w not|strong="H5892"\w* only \w one|strong="H3651"\w*, \add in order that someone can get to one of those cities quickly\add*.   
\p
\v 8-9 “If you do everything that I am today commanding you to do, and if you love \w Yahweh|strong="H3068"\w* our God, and if you conduct your lives as he wants you to do, \w Yahweh|strong="H3068"\w* our God will give you much more land than you will have when you first occupy it, which is what he promised to do. He will give you all the land which he promised your ancestors that he would give to you. When he gives you that land, you must select three more cities \add to which people may escape\add*.  
\v 10 \w Do|strong="H3068"\w* \w this|strong="H5414"\w* \w in|strong="H5921"\w* order \w that|strong="H3068"\w* \w people|strong="H3808"\w* \w who|strong="H3068"\w* ◄\w are|strong="H3068"\w* \w innocent|strong="H5355"\w*/\w have|strong="H1961"\w* killed \w someone|strong="H5414"\w* \w else|strong="H3808"\w* \w without|strong="H3808"\w* planning \w to|strong="H3068"\w*► \w will|strong="H3068"\w* \w not|strong="H3808"\w* die, \w and|strong="H3068"\w* \w you|strong="H5414"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w be|strong="H1961"\w* guilty \w for|strong="H5921"\w* \add allowing\add* \w them|strong="H5414"\w* \w to|strong="H3068"\w* \w be|strong="H1961"\w* executed, \w in|strong="H5921"\w* \w the|strong="H5921"\w* \w land|strong="H7130"\w* \w that|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w is|strong="H3068"\w* \w giving|strong="H5414"\w* \w to|strong="H3068"\w* \w you|strong="H5414"\w*.   
\p
\v 11 “\w But|strong="H3588"\w* \w suppose|strong="H3588"\w* \w someone|strong="H5315"\w* \w hates|strong="H8130"\w* \w his|strong="H5921"\w* \w enemy|strong="H8130"\w* \w and|strong="H6965"\w* hides \w and|strong="H6965"\w* waits \w for|strong="H3588"\w* \w that|strong="H3588"\w* \w person|strong="H5315"\w* \add to come along the road\add*. \w Then|strong="H1961"\w* \add when he passes by, suddenly\add* \w he|strong="H3588"\w* \w attacks|strong="H5221"\w* \w him|strong="H5921"\w* \w and|strong="H6965"\w* murders \w him|strong="H5921"\w*. \w If|strong="H3588"\w* \w the|strong="H5921"\w* attacker \w flees|strong="H5127"\w* \w to|strong="H4191"\w* \w one|strong="H3588"\w* \w of|strong="H5892"\w* \w those|strong="H5921"\w* \w cities|strong="H5892"\w* \add to be protected there\add*,  
\v 12 \w the|strong="H5414"\w* \w elders|strong="H2205"\w* \w of|strong="H3027"\w* \w the|strong="H5414"\w* \w city|strong="H5892"\w* \add where the murdered man lived must not protect the attacker. They\add*. \w must|strong="H4191"\w* \w send|strong="H7971"\w* \w someone|strong="H5414"\w* \w to|strong="H4191"\w* \w the|strong="H5414"\w* \w city|strong="H5892"\w* \w to|strong="H4191"\w* \w which|strong="H8033"\w* \w the|strong="H5414"\w* other \w man|strong="H2205"\w* escaped, \w and|strong="H7971"\w* \w bring|strong="H3947"\w* \w him|strong="H5414"\w* \w to|strong="H4191"\w* [MTY] \w the|strong="H5414"\w* \w relative|strong="H1350"\w* who \w is|strong="H3027"\w* supposed/expected \w to|strong="H4191"\w* \w get|strong="H3947"\w* revenge, \w so|strong="H3947"\w* \w that|strong="H5414"\w* \w he|strong="H8033"\w* \w may|strong="H5414"\w* \w execute|strong="H4191"\w* \w that|strong="H5414"\w* \w man|strong="H2205"\w*.  
\v 13 \w You|strong="H5921"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w pity|strong="H2347"\w* \w those|strong="H5921"\w* \w who|strong="H3478"\w* murder other \w people|strong="H3808"\w*! \w Instead|strong="H3808"\w*, \w you|strong="H5921"\w* \w must|strong="H3808"\w* execute \w them|strong="H5921"\w*, \w in|strong="H5921"\w* order \w that|strong="H3478"\w* \w the|strong="H5921"\w* \w people|strong="H3808"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* land \w of|strong="H5869"\w* \w Israel|strong="H3478"\w* \w will|strong="H3478"\w* \w not|strong="H3808"\w* murder [MTY] \w innocent|strong="H5355"\w* \w people|strong="H3808"\w*, \w and|strong="H3478"\w* \w in|strong="H5921"\w* order \w that|strong="H3478"\w* \w things|strong="H2896"\w* \w will|strong="H3478"\w* \w go|strong="H3478"\w* \w well|strong="H2896"\w* \w for|strong="H5921"\w* \w you|strong="H5921"\w*.”   
\s1 Warning against moving boundaries  
\p
\v 14 “\add When you are living\add* \w in|strong="H3068"\w* \w the|strong="H5414"\w* \w land|strong="H5159"\w* \w that|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w is|strong="H3068"\w* \w giving|strong="H5414"\w* \w to|strong="H3068"\w* \w you|strong="H5414"\w*, \w do|strong="H3068"\w* \w not|strong="H3808"\w* \w move|strong="H5253"\w* \w the|strong="H5414"\w* markers \w of|strong="H3068"\w* \w your|strong="H3068"\w* \w neighbors|strong="H7453"\w*’ \w property|strong="H5159"\w* boundaries \w which|strong="H3068"\w* \w were|strong="H7223"\w* \w placed|strong="H5414"\w* \w there|strong="H3068"\w* long ago.”   
\s1 Warnings about witnesses  
\p
