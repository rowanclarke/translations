\v 13 \w Then|strong="H1768"\w* \w they|strong="H1768"\w* told \w the|strong="H3606"\w* \w king|strong="H4430"\w*, “Daniel, one \w of|strong="H4481"\w* \w the|strong="H3606"\w* exiles \w from|strong="H4481"\w* Judah, shows \w no|strong="H3809"\w* regard \w for|strong="H5922"\w* \w you|strong="H1768"\w*, \w O|strong="H3068"\w* \w king|strong="H4430"\w*, \w or|strong="H3809"\w* \w for|strong="H5922"\w* \w the|strong="H3606"\w* \w decree|strong="H1882"\w* \w that|strong="H1768"\w* \w you|strong="H1768"\w* \w have|strong="H1768"\w* \w signed|strong="H7560"\w*. \w He|strong="H1768"\w* still \w makes|strong="H1156"\w* \w his|strong="H5922"\w* \w petition|strong="H1156"\w* three times \w a|strong="H3068"\w* \w day|strong="H3118"\w*.”
\b
\m 
\v 14 \w As|strong="H1768"\w* \w soon|strong="H4481"\w* \w as|strong="H1768"\w* \w the|strong="H5922"\w* \w king|strong="H4430"\w* heard \w this|strong="H5922"\w*, \w he|strong="H1768"\w* \w was|strong="H4430"\w* deeply distressed \w and|strong="H6032"\w* \w set|strong="H7761"\w* \w his|strong="H5922"\w* mind \w on|strong="H5922"\w* delivering \w Daniel|strong="H1841"\w*, \w and|strong="H6032"\w* \w he|strong="H1768"\w* labored until sundown \w to|strong="H5922"\w* rescue \w him|strong="H5922"\w*.
\b
\m 
\v 15 \w Then|strong="H1768"\w* \w the|strong="H5922"\w* men approached \w the|strong="H5922"\w* \w king|strong="H4430"\w* together \w and|strong="H4430"\w* said \w to|strong="H5922"\w* \w him|strong="H5922"\w*, “Remember, \w O|strong="H3068"\w* \w king|strong="H4430"\w*, \w that|strong="H1768"\w* \w by|strong="H7761"\w* \w the|strong="H5922"\w* law \w of|strong="H4430"\w* \w the|strong="H5922"\w* Medes \w and|strong="H4430"\w* Persians no decree \w or|strong="H4430"\w* ordinance established \w by|strong="H7761"\w* \w the|strong="H5922"\w* \w king|strong="H4430"\w* \w can|strong="H1768"\w* \w be|strong="H1934"\w* changed.”
