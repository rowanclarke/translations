\id 2JN Wanca Quechua NT 
\h 2 San Juan 
\toc1 Juan Ishcay Cartacuśhan 
\toc2 2 San Juan 
\toc3 2Jn 
\mt1 Juan Ishcay Cartacuśhan 
\ip Chalapacü cay sasa-sasa caśhan timpućhümi cayta Juan isquirbila. Chaymi cay cartacta ćhasquïcunäta cuydayninwan malcaćhu chalapacücunäta “aclacuśha walmi” nila. Quiquin chalapacücunätañatac “wawincuna” nila. Chaynütacmi quiquinpis “yaśha” nicun, śhutinta mana camalachicullal. 
\ip Cay cartaćhüpis Salbacü Jesus ya'anchicnu nunaman muyuśha śhamuśhanta mana awnïcunäpi cuydaculcänanpämi, chaynütac quiquin-pula cuyacunanpämi niycun. 
\c 1  
\p  
\v 1 Ya'a yaśham rasun cuyacuywan limaycälic, aclacuśhá walmicta llapan wawintinta. Manamari ya'allachu sinu'a rasuncäta lluy lisïcunäpis cuyapäcuśhunquim.  
\v 2 Caynu cuyapäcuc rasunca cananpis wiña-wiñaypäpis ya'anchicwan cayaptinñamá. 
\p  
\v 3 Quiquin Tayta Diosninchicwan, chulin Jesusninchic llaquipayninpïta jawca cawsayninta rasun sumä cuyacuywan ya'anchicman uycamäśhun.\f + \fr 1:3 \fk ya'anchicman uycamäśhun: \ft Waquin unay isquirbishacunaćhu'a “…amcunawan caycuchun” niyanmi.\f* 
\p  
\v 4 Aw-ari, waquinnin wawiquicunacta Tayta Diosninchic nimäśhanchicmannuy rasuncämannuy sumäpa cawsayalcäśhanta talïlulmi sumä cushicülú.  
\v 5 Canan cuyaśhá walmi, amcunacta niycälic quiquinchic-pula cuyanacunapämi. Cay manamá muśhü camachicuychu, sinu'a allaycuycäpi ćhasquishallanchicmi.  
\v 6 Rasun cuyaśhanchicta camalachinchic Tayta Diosninchicpa nimäśhanchicta cäsucul cawsaśhanchicpam. Chay nimäśhanchicñatacmi puntapi uyalipäcuśhayquinüpis cuyanacunanchic. 
\p  
\v 7 Canan, má, uyalipämay-ari: “Salbacü Jesus ya'anchicnu nunaman muyulcul śhamuśhanta” mana awnïcuna cay pachäćhu achca-achcam timpuyalcan. Chaycuna Jesuspa cuntran śhalcü ingañacücunamá.  
\v 8 Caycunapïta sumätam cuydaculcanqui, lluy lulayniquicuna yan'alpä mana cananpä, aśhwanpa tincüninman lluy cabalta ćhasquiycälinayquipä. 
\p  
\v 9 Ñatac mayanpis Jesuspa yaćhachicuyninpi masyalcul yaćhachïcá, manamá Tayta Diosninchicwanchu. Pay yaćhachimäśhallanchicćhu tacyaycücämi ichá Dioswanpis, chulin Jesuswanpis cayan.  
\v 10 Sïchuśh mayanpis amcunaman śhamul, juc willacuyta apamuptin'a ama yaycaycachiychu nï ćhasquiycuypischu.  
\v 11 Ćhasquiycücá mana allin lulä-masinñam licalïlun. 
\p  
\v 12 Ñatac achca niycälinac cayaptinpis cay cartap manamá niycälishayquichu. Aśhwanpa quiquïmi śhamuyta pinsayá cära-cära limaycunanchicpä jinal sumä cushicunanchicpä. 
\p  
\v 13 Aclacuśhan ñañayquip wawincunam limaycälimuśhunqui. Chaynu cachun. Jamallá. 