\c 3  
\s1 Jonah kah Olthui  
\p
\v 1 \w BOEIPA|strong="H3068"\w* \w ol|strong="H1697"\w* he \w Jonah|strong="H3124"\w* \w taengah|strong="H0413"\w* a \w pabae|strong="H8145"\w* la \w cet|strong="H1961"\w* tih,  
\v 2 “\w Thoo|strong="H6965"\w*, \w Nineveh|strong="H5210"\w* \w khopuei|strong="H5892"\w* \w len|strong="H1419"\w* \w la|strong="H0413"\w* \w cet|strong="H1980"\w* \w lamtah|strong="H9999"\w* \w nang|strong="H9905"\w* \w taengah|strong="H0413"\w* \w olthang|strong="H7150"\w* \w ka|strong="H0595"\w* \w thui|strong="H1696"\w* \w te|strong="H0834"\w* \w a|strong="H9907"\w* \w taengah|strong="H0413"\w* \w hoe|strong="H7121"\w* pah,” a \w ti|strong="H0559"\w* nah.   
