\q1 tlen eliyaya icone Simeón, 
\q1 tlen eliyaya icone Judá, 
\q1 tlen eliyaya icone José, 
\q1 tlen eliyaya icone Jonán, 
\q1 tlen eliyaya icone Eliaquim, 
\q1  
