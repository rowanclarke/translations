\v 45 ‘Anyone \w who|strong="H2931"\w* \w has|strong="H1961"\w* \w a|strong="H3068"\w* contagious skin disease must \w wear|strong="H1961"\w* \w torn|strong="H6533"\w* clothes \w and|strong="H7218"\w* \w not|strong="H1961"\w* comb \w his|strong="H7121"\w* \w hair|strong="H7218"\w*. \add When he is near other people\add*, \w he|strong="H5921"\w* must \w cover|strong="H5844"\w* \w the|strong="H5921"\w* lower \w part|strong="H7218"\w* \w to|strong="H1961"\w* \w his|strong="H7121"\w* face \w and|strong="H7218"\w* \w call|strong="H7121"\w* \w out|strong="H5921"\w*, “Do \w not|strong="H1961"\w* \w come|strong="H1961"\w* \w near|strong="H5921"\w* \w me|strong="H5921"\w*! \w I|strong="H5921"\w* \w have|strong="H1961"\w* \w a|strong="H3068"\w* contagious skin disease!”
\v 46 \w He|strong="H1931"\w* \w is|strong="H1931"\w* not allowed \w to|strong="H3117"\w* \w be|strong="H3117"\w* \w with|strong="H3427"\w* \w other|strong="H3605"\w* \w people|strong="H3427"\w* \w as|strong="H3117"\w* \w long|strong="H3117"\w* \w as|strong="H3117"\w* \w he|strong="H1931"\w* \w has|strong="H5061"\w* \w the|strong="H3605"\w* disease. \w He|strong="H1931"\w* \w must|strong="H2351"\w* \w live|strong="H3427"\w* \w alone|strong="H1931"\w*, \w outside|strong="H2351"\w* \w the|strong="H3605"\w* \w camp|strong="H4264"\w*.’”
\s1 Regulations concerning mildew
\p 
\v 47-48 “Sometimes \w a|strong="H3068"\w* person’s clothing gets mildew on it. It may be clothing that is woven from wool or made from linen or from leather.
\v 49 \w If|strong="H7200"\w* \w the|strong="H3605"\w* contaminated/mildewed \w part|strong="H1931"\w* \w is|strong="H1931"\w* \w greenish|strong="H3422"\w* \w or|strong="H7200"\w* reddish, \w it|strong="H1931"\w* \w is|strong="H1931"\w* \w a|strong="H3068"\w* spreading mildew, \w and|strong="H3548"\w* \w it|strong="H1931"\w* must \w be|strong="H1961"\w* \w shown|strong="H7200"\w* \w to|strong="H1961"\w* \w the|strong="H3605"\w* \w priest|strong="H3548"\w*.
\v 50 \w The|strong="H7200"\w* \w priest|strong="H3548"\w* \w will|strong="H3117"\w* examine \w it|strong="H7200"\w*, \w and|strong="H3117"\w* \w then|strong="H7200"\w* put \w it|strong="H7200"\w* \w in|strong="H3117"\w* \w a|strong="H3068"\w* separate place \w by|strong="H3117"\w* itself \w for|strong="H3117"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*.
\v 51 \w On|strong="H3117"\w* \w the|strong="H3605"\w* \w seventh|strong="H7637"\w* \w day|strong="H3117"\w* \w he|strong="H1931"\w* must examine \w it|strong="H1931"\w* again. \w If|strong="H3588"\w* \w the|strong="H3605"\w* mildew \w has|strong="H5061"\w* \w spread|strong="H6581"\w*, \w it|strong="H1931"\w* \w is|strong="H1931"\w* \w clear|strong="H3605"\w* \w that|strong="H3588"\w* \w it|strong="H1931"\w* \w is|strong="H1931"\w* \w a|strong="H3068"\w* type \w of|strong="H3117"\w* mildew \w that|strong="H3588"\w* destroys clothing, \w and|strong="H3117"\w* \w that|strong="H3588"\w* clothing must \w not|strong="H6213"\w* \w be|strong="H3117"\w* worn again.
\v 52 \w The|strong="H3605"\w* owner must \w burn|strong="H8313"\w* \w completely|strong="H3605"\w* \w the|strong="H3605"\w* item \w that|strong="H3588"\w* \w has|strong="H1961"\w* \w the|strong="H3605"\w* mildew \w in|strong="H1961"\w* \w it|strong="H1931"\w*, \w whatever|strong="H3605"\w* kind \w of|strong="H3627"\w* item \w it|strong="H1931"\w* \w is|strong="H1931"\w*.
\p 
\v 53 \w But|strong="H3808"\w* \w when|strong="H7200"\w* \w the|strong="H3605"\w* \w priest|strong="H3548"\w* \w examines|strong="H7200"\w* \w it|strong="H7200"\w*, \w if|strong="H2009"\w* \w the|strong="H3605"\w* mildew \w has|strong="H5061"\w* \w not|strong="H3808"\w* \w spread|strong="H6581"\w*,
\v 54 \w he|strong="H3117"\w* \w will|strong="H3117"\w* tell \w the|strong="H3117"\w* person \add who owns it\add* \w to|strong="H3117"\w* \w wash|strong="H3526"\w* \w it|strong="H6680"\w*. \w Then|strong="H6680"\w* \w he|strong="H3117"\w* must \w put|strong="H6680"\w* \w it|strong="H6680"\w* \w in|strong="H3117"\w* \w a|strong="H3068"\w* separate place \w for|strong="H3117"\w* \w another|strong="H8145"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*.
\v 55 \w Then|strong="H2009"\w* \w the|strong="H7200"\w* \w priest|strong="H3548"\w* \w will|strong="H5869"\w* examine \w it|strong="H1931"\w* \w again|strong="H2015"\w*. \w If|strong="H2009"\w* \w the|strong="H7200"\w* color \w of|strong="H5869"\w* \w the|strong="H7200"\w* mildew \w has|strong="H5061"\w* \w not|strong="H3808"\w* \w changed|strong="H2015"\w*, \w even|strong="H3808"\w* \w though|strong="H1931"\w* \w it|strong="H1931"\w* \w has|strong="H5061"\w* \w not|strong="H3808"\w* \w spread|strong="H6581"\w*, \w that|strong="H7200"\w* item \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w be|strong="H3808"\w* worn \w again|strong="H2015"\w*. \w It|strong="H1931"\w* \w does|strong="H3808"\w* \w not|strong="H3808"\w* matter \w if|strong="H2009"\w* \w the|strong="H7200"\w* mildew \w is|strong="H1931"\w* \w on|strong="H7200"\w* \w the|strong="H7200"\w* inside \w of|strong="H5869"\w* \w the|strong="H7200"\w* clothing \w or|strong="H3808"\w* \w on|strong="H7200"\w* \w the|strong="H7200"\w* outside; \w it|strong="H1931"\w* \w must|strong="H3808"\w* \w be|strong="H3808"\w* \w burned|strong="H8313"\w*.
\v 56 \w But|strong="H7200"\w* \w when|strong="H7200"\w* \w the|strong="H7200"\w* \w priest|strong="H3548"\w* \w examines|strong="H7200"\w* \w it|strong="H7200"\w* \add after it has been washed\add*, \w if|strong="H2009"\w* \w the|strong="H7200"\w* mildew \w has|strong="H5061"\w* \w faded|strong="H3544"\w*, \w he|strong="H4480"\w* must \w tear|strong="H7167"\w* \w out|strong="H4480"\w* \w that|strong="H7200"\w* \w part|strong="H4480"\w* \w that|strong="H7200"\w* \w had|strong="H3548"\w* \w the|strong="H7200"\w* mildew \w in|strong="H7200"\w* \w it|strong="H7200"\w*.
\v 57 \w But|strong="H7200"\w* \w if|strong="H7200"\w* \w the|strong="H3605"\w* mildew reappears \w in|strong="H5750"\w* \w that|strong="H7200"\w* item, \w it|strong="H1931"\w* \w is|strong="H1931"\w* \w clear|strong="H3605"\w* \w that|strong="H7200"\w* \w it|strong="H1931"\w* \w is|strong="H1931"\w* \w spreading|strong="H6524"\w*, \w and|strong="H7200"\w* \w the|strong="H3605"\w* \w whole|strong="H3605"\w* item must \w be|strong="H5750"\w* \w burned|strong="H8313"\w*.
\v 58 \w But|strong="H1992"\w* \w after|strong="H1992"\w* \w the|strong="H3605"\w* \w clothing|strong="H3627"\w* \w is|strong="H3605"\w* \w washed|strong="H3526"\w* \w and|strong="H3627"\w* \w the|strong="H3605"\w* mildew \w disappears|strong="H5493"\w*, \w it|strong="H3605"\w* must \w be|strong="H5061"\w* \w washed|strong="H3526"\w* \w again|strong="H8145"\w*, \w and|strong="H3627"\w* \w then|strong="H3605"\w* \w it|strong="H3605"\w* can \w be|strong="H5061"\w* worn \w again|strong="H8145"\w*.
\p 
\v 59 \w Those|strong="H3605"\w* \w are|strong="H3627"\w* \w the|strong="H3605"\w* regulations \w concerning|strong="H3605"\w* mildew \w on|strong="H3627"\w* \w things|strong="H3605"\w* \w made|strong="H2930"\w* \w of|strong="H3627"\w* \w wool|strong="H6785"\w* \w or|strong="H5061"\w* \w linen|strong="H6593"\w* \w or|strong="H5061"\w* \w leather|strong="H5785"\w*, \w for|strong="H3605"\w* deciding whether \w those|strong="H3605"\w* \w things|strong="H3605"\w* can continue \w to|strong="H3627"\w* \w be|strong="H5061"\w* worn \w or|strong="H5061"\w* not.”
\c 14
\s1 Rituals for those healed of contagious skin diseases
\p 
\v 1 \w Yahweh|strong="H3068"\w* \w also|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*,
\v 2 “\w These|strong="H2063"\w* \w are|strong="H3117"\w* \w the|strong="H3117"\w* regulations \w for|strong="H3117"\w* anyone \w who|strong="H3548"\w* \w has|strong="H1961"\w* \w been|strong="H1961"\w* healed \w of|strong="H3117"\w* \w a|strong="H3068"\w* contagious skin disease.
\v 3 \w The|strong="H7200"\w* \w person|strong="H7200"\w* \w must|strong="H2351"\w* \w be|strong="H5061"\w* \w brought|strong="H3318"\w* \w to|strong="H3318"\w* \w a|strong="H3068"\w* \w priest|strong="H3548"\w*. \w The|strong="H7200"\w* \w priest|strong="H3548"\w* will \w take|strong="H3318"\w* \w him|strong="H7200"\w* \w outside|strong="H2351"\w* \w the|strong="H7200"\w* \w camp|strong="H4264"\w* \add to where that person has been staying\add*, \w and|strong="H3548"\w* examine \w him|strong="H7200"\w*. \w If|strong="H2009"\w* \w the|strong="H7200"\w* skin \w disease|strong="H6883"\w* \w has|strong="H5061"\w* been \w healed|strong="H7495"\w*,
\v 4 \w the|strong="H3947"\w* \w priest|strong="H3548"\w* \w will|strong="H2416"\w* say \w that|strong="H3548"\w* someone \w must|strong="H3947"\w* \w bring|strong="H3947"\w* \w two|strong="H8147"\w* \w living|strong="H2416"\w* \w birds|strong="H6833"\w* \w that|strong="H3548"\w* \w are|strong="H3548"\w* acceptable \w to|strong="H6680"\w* \w Yahweh|strong="H3068"\w*, along \w with|strong="H3548"\w* some cedar \w wood|strong="H6086"\w*, some \w scarlet|strong="H8144"\w*/\w red|strong="H8144"\w* \w yarn|strong="H8144"\w*, \w and|strong="H6086"\w* some sprigs \w of|strong="H6086"\w* ◄hyssop/\w a|strong="H3068"\w* very leafy plant►.
\v 5 \w Then|strong="H6680"\w* \w the|strong="H5921"\w* \w priest|strong="H3548"\w* \w will|strong="H4325"\w* \w command|strong="H6680"\w* \w that|strong="H3548"\w* \w one|strong="H2416"\w* \w of|strong="H3627"\w* \w the|strong="H5921"\w* \w birds|strong="H6833"\w* \w be|strong="H3548"\w* \w killed|strong="H7819"\w* \w while|strong="H5921"\w* \add it is being held\add* \w over|strong="H5921"\w* \w a|strong="H3068"\w* \w clay|strong="H2789"\w* \w pot|strong="H3627"\w* containing \w water|strong="H4325"\w* \w from|strong="H5921"\w* \w a|strong="H3068"\w* \w spring|strong="H4325"\w*.
\v 6 \w Then|strong="H3947"\w* \w the|strong="H5921"\w* priest \w will|strong="H4325"\w* \w dip|strong="H2881"\w* \w the|strong="H5921"\w* other \w bird|strong="H6833"\w*, \w along|strong="H5921"\w* \w with|strong="H5921"\w* \w the|strong="H5921"\w* cedar \w wood|strong="H6086"\w*, \w the|strong="H5921"\w* \w scarlet|strong="H8144"\w*/\w red|strong="H8144"\w* \w yarn|strong="H8144"\w* \w and|strong="H6086"\w* \w the|strong="H5921"\w* hyssop, \w into|strong="H5921"\w* \w the|strong="H5921"\w* \w blood|strong="H1818"\w* \w of|strong="H4325"\w* \w the|strong="H5921"\w* \w bird|strong="H6833"\w* \w that|strong="H4325"\w* \w was|strong="H4325"\w* \w killed|strong="H7819"\w*.
\v 7 \w Then|strong="H7971"\w* \w he|strong="H4480"\w* must \w sprinkle|strong="H5137"\w* \w some|strong="H4480"\w* \w of|strong="H6440"\w* \w the|strong="H6440"\w* blood \w on|strong="H5921"\w* \w the|strong="H6440"\w* \w person|strong="H6440"\w* \w who|strong="H2416"\w* \w was|strong="H6440"\w* healed; \w he|strong="H4480"\w* must \w sprinkle|strong="H5137"\w* \w it|strong="H5921"\w* \w on|strong="H5921"\w* \w him|strong="H6440"\w* \w seven|strong="H7651"\w* \w times|strong="H6471"\w*. \w Then|strong="H7971"\w* \w he|strong="H4480"\w* \w will|strong="H7704"\w* declare \w that|strong="H4480"\w* \w the|strong="H6440"\w* \w person|strong="H6440"\w* \w is|strong="H6440"\w* permitted \w to|strong="H7971"\w* \w be|strong="H6440"\w* \w with|strong="H5921"\w* \w other|strong="H6471"\w* people \w again|strong="H7971"\w*. \w And|strong="H7971"\w* \w the|strong="H6440"\w* priest \w will|strong="H7704"\w* \w release|strong="H7971"\w* \w the|strong="H6440"\w* \w other|strong="H6471"\w* \w bird|strong="H6833"\w* \w and|strong="H7971"\w* allow \w it|strong="H5921"\w* \w to|strong="H7971"\w* fly \w away|strong="H7971"\w*.
\p 
\v 8 “\w Then|strong="H3605"\w* \w the|strong="H3605"\w* person \w who|strong="H3605"\w* \w was|strong="H3117"\w* healed \w must|strong="H2351"\w* \w wash|strong="H3526"\w* \w his|strong="H3605"\w* clothes, \w shave|strong="H1548"\w* \w off|strong="H1548"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* \w hair|strong="H8181"\w*, \w and|strong="H3117"\w* \w bathe|strong="H7364"\w*. \w Then|strong="H3605"\w* \w he|strong="H3117"\w* \w is|strong="H3117"\w* allowed \w to|strong="H3117"\w* return \w to|strong="H3117"\w* \w the|strong="H3605"\w* \w camp|strong="H4264"\w*, \w but|strong="H3605"\w* \w he|strong="H3117"\w* \w must|strong="H2351"\w* \w stay|strong="H3427"\w* \w outside|strong="H2351"\w* \w his|strong="H3605"\w* tent \w for|strong="H3427"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*.
\v 9 \w On|strong="H3117"\w* \w the|strong="H3605"\w* \w seventh|strong="H7637"\w* \w day|strong="H3117"\w*, \w he|strong="H3117"\w* must \w again|strong="H1961"\w* \w shave|strong="H1548"\w* \w off|strong="H1548"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* \w hair|strong="H8181"\w*, \w including|strong="H3605"\w* \w his|strong="H3605"\w* \w beard|strong="H2206"\w* \w and|strong="H3117"\w* \w his|strong="H3605"\w* \w eyebrows|strong="H5869"\w*. \w Then|strong="H1961"\w* \w he|strong="H3117"\w* must \w again|strong="H1961"\w* \w wash|strong="H3526"\w* \w his|strong="H3605"\w* clothes \w and|strong="H3117"\w* \w bathe|strong="H7364"\w*, \w and|strong="H3117"\w* \w then|strong="H1961"\w* \w he|strong="H3117"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* allowed \w to|strong="H1961"\w* \w be|strong="H1961"\w* \w with|strong="H3117"\w* \w other|strong="H3605"\w* \w people|strong="H1320"\w* \w again|strong="H1961"\w*.
\p 
\v 10 “\w The|strong="H3947"\w* next \w day|strong="H3117"\w* \w that|strong="H3117"\w* person \w must|strong="H3947"\w* \w bring|strong="H3947"\w* \w two|strong="H8147"\w* \w male|strong="H3532"\w* \w lambs|strong="H3532"\w* \w and|strong="H3117"\w* \w one|strong="H3532"\w* \w female|strong="H1323"\w* \w lamb|strong="H3532"\w* \w that|strong="H3117"\w* \w is|strong="H3117"\w* \w one|strong="H3532"\w* \w year|strong="H8141"\w* \w old|strong="H1323"\w*, \w all|strong="H3117"\w* \w of|strong="H3117"\w* \w them|strong="H3947"\w* \w with|strong="H1101"\w* \w no|strong="H3947"\w* defects. \w He|strong="H3117"\w* \w must|strong="H3947"\w* \w also|strong="H3117"\w* \w bring|strong="H3947"\w* \w six|strong="H7969"\w* quarts/liters \w of|strong="H3117"\w* \w fine|strong="H5560"\w* \w flour|strong="H5560"\w*, \w mixed|strong="H1101"\w* \w with|strong="H1101"\w* \w olive|strong="H8081"\w* \w oil|strong="H8081"\w*, \w to|strong="H3117"\w* \w be|strong="H3117"\w* \w an|strong="H3947"\w* \w offering|strong="H4503"\w*, \w and|strong="H3117"\w* ◄0.6 pint/0.3 liter► \w of|strong="H3117"\w* \w olive|strong="H8081"\w* \w oil|strong="H8081"\w*.
\v 11 \w The|strong="H6440"\w* \w priest|strong="H3548"\w* \w who|strong="H3068"\w* declares \w that|strong="H3068"\w* \w the|strong="H6440"\w* \w person|strong="H6440"\w*’s skin disease \w is|strong="H3068"\w* ended must bring \w that|strong="H3068"\w* \w person|strong="H6440"\w*, \w and|strong="H3068"\w* \w his|strong="H3068"\w* \w offerings|strong="H3068"\w*, \w to|strong="H3068"\w* \w me|strong="H6440"\w*, \w Yahweh|strong="H3068"\w*, \w at|strong="H3068"\w* \w the|strong="H6440"\w* \w entrance|strong="H6607"\w* \w of|strong="H3068"\w* \w the|strong="H6440"\w* Sacred Tent.
\p 
\v 12 “\w Then|strong="H3947"\w* \w the|strong="H6440"\w* \w priest|strong="H3548"\w* \w must|strong="H3947"\w* \w take|strong="H3947"\w* \w one|strong="H3532"\w* \w of|strong="H3068"\w* \w the|strong="H6440"\w* \w male|strong="H3532"\w* \w lambs|strong="H3532"\w* \w and|strong="H3068"\w* \w lift|strong="H3068"\w* \w it|strong="H7126"\w* \w up|strong="H5130"\w*, \w along|strong="H6440"\w* \w with|strong="H3068"\w* \w the|strong="H6440"\w* \w olive|strong="H8081"\w* \w oil|strong="H8081"\w*, \w in|strong="H3068"\w* \w front|strong="H6440"\w* \w of|strong="H3068"\w* \w me|strong="H6440"\w*, \w to|strong="H3068"\w* \w be|strong="H3068"\w* \w a|strong="H3068"\w* guilt \w offering|strong="H8573"\w*—\add an offering for his being guilty for not giving to me the things that he was required to give me\add*.
