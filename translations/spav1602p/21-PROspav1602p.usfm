\v 16 \w Porque|strong="H3588"\w* \w siete|strong="H7651"\w* \w veces|strong="H7651"\w* \w cae|strong="H5307"\w* \w el|strong="H3588"\w* \w justo|strong="H6662"\w*, \w y|strong="H3588"\w* se torna \w a|strong="H3068"\w* \w levantar|strong="H6965"\w*; \w mas|strong="H3588"\w* \w los|strong="H3588"\w* \w impíos|strong="H7563"\w* \w caerán|strong="H5307"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w mal|strong="H7451"\w*.   
