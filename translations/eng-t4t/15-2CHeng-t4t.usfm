\v 12 \w The|strong="H7121"\w* \w messenger|strong="H4397"\w* \w who|strong="H5030"\w* \w went|strong="H1980"\w* \w to|strong="H1696"\w* \w summon|strong="H7121"\w* \w Micaiah|strong="H4321"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w him|strong="H7121"\w*, “\w Listen|strong="H2009"\w* \w to|strong="H1696"\w* \w me|strong="H4994"\w*! \w All|strong="H1697"\w* \w the|strong="H7121"\w* \w other|strong="H7121"\w* \w prophets|strong="H5030"\w* \w are|strong="H1992"\w* unitedly predicting \w that|strong="H1697"\w* \w the|strong="H7121"\w* \w king|strong="H4428"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* successful \add in the battle\add*. \w So|strong="H1980"\w* \w be|strong="H1961"\w* sure \w to|strong="H1696"\w* agree \w with|strong="H1980"\w* \w them|strong="H1992"\w* \w and|strong="H1980"\w* \w say|strong="H1696"\w* \w that|strong="H1697"\w* \w the|strong="H7121"\w* \w king|strong="H4428"\w*’s army \w will|strong="H1961"\w* \w be|strong="H1961"\w* successful!”   
\p
\v 13 \w But|strong="H3588"\w* \w Micaiah|strong="H4321"\w* \w said|strong="H1696"\w*, “\w As|strong="H3068"\w* \w surely|strong="H3588"\w* \w as|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w lives|strong="H2416"\w*, \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w tell|strong="H1696"\w* \w the|strong="H3588"\w* king \w only|strong="H3588"\w* \w what|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w tells|strong="H1696"\w* \w me|strong="H1696"\w* \w to|strong="H1696"\w* \w say|strong="H1696"\w*.”   
