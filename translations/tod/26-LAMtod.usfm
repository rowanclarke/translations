\id LAM - Toma Bible
\h Gɔlɔ Wooiti
\toc1 Zelemi Ná-Gɔlɔ Wooiti
\toc2 Gɔlɔ Wooiti
\toc3 Gɔl
\mt2 Zelemi
\mt1 Ná-Gɔlɔ Wooiti
\imt1 Sɛʋɛi lɔɔzeizuʋɛ ma woo mɔungiti
\ip Gɔlɔ Woo Zɛʋɛi ɠa ga kidafaawu zɛʋɛi é Zeluzalɛme taa wolai ɠoloɠolo fai zuɠulazu. Nui nii é Gɔlɔ Woo Zɛʋɛi ɠɛai, tɔ ɓɔɠɔi é la ɓɔɠɔ lɛɛni, kɛlɛ Zuifu zɛʋɛ ɠɛ nui tanigaa ta keletiɛn zɛʋɛ ɠɛ nui tanigaa laaʋɛ da ga Zelemi ɠa é sɛʋɛai. Tɛi sɛʋɛi nii ɓɔɛzu é lo Zeluzalɛme ɠoloɠolo fai ʋa, kɛɛʋɛ eɠɛ sɛʋɛi nii zɛʋɛʋɛ kona undɔɔlugɔ puulɔsaʋa maazu lɔzitai (586) ʋoluma, Zeluzalɛme ɠoloɠolo siɛgi zu, aisa Yesu Kilista ʋa zɔlɔɔ, kɛlɛ kɛɛʋɛ aisa kona undɔɔlugɔ kona puugɔ maazu lɔzitai (516) yeeluɠɔ, aisa Yesu Kilista ʋa zɔlɔɔ, siɛgi zu Zeluzalɛme loga la ʋolu, ta GALA sei ʋɛlɛi laalao siɛgi zu. Kɛɛʋɛ eɠɛ nui nii é sɛʋɛi nii ɠɛai, é ɠɛni vulua Zeluzalɛme ɠoloɠolo siɛgi zu, kona undɔɔlugɔ kona ʋuulɔsaʋa maazu lɔzitai (586) ma, aisa Yesu Kilista ʋa zɔlɔɔ.
\ip Gɔlɔ Woo Zɛʋɛi zu ná pɛ soolɛi ɠa é dɛɛzu Zeluzalɛme ná-faa zu. Anɛɛ ni Ɓaɓilɔne ɠɔɔ ɓɔgi ɠa é lɔɔni Zeluzalɛme, é ná ɠoloɠolo, Gɔlɔ Woo Zɛʋɛi zɛʋɛ nui ɠɛ naama vai ɠɛɛʋɛ, tɔɔzei GALA ná-tukpɔɠaaleʋei ɠa é Zuda yooi ma (\xt 1:12\xt*). GALA ge Zuda loɠani ga Ɓaɓilɔne nuiti dɔɔ vai zooi zu. Kɛlɛ naa pɛ su, Gɔlɔ Woo Zɛʋɛi zɛʋɛ nui ɠi ge looni GALA ná-wooɠɛɠiladai zu. Ná-ziiɓɔlɔi zaama, é ɠɛni ma: «Ɠɔoɠɔ GALAGI zu la ɓɔlɔa ga ná-wooɠɛɠiladai, kwɛ ge la ná-maawɔinɠai ʋa» (\xt 3:22\xt*). Naa ʋoluma sɛʋɛ ɠaaɓelagɛ ga GALA falii nii a kɛ GALA ge Zuda zei ʋolu ga pagɔ.
\iot Unsosuʋɛ
\io1 1. Soolɛi tɔɔzei GALA ná-tukpɔɠaaleʋei é ná-nuɓusɛiti daalɔɠɔma, ta Zeluzalɛme ɠoloɠolo fai (\xt 1:1—2:22\xt*).
\io1 2. Sɛʋɛi ɠɛɛ nui ɠi ge looni GALA ná-wooɠɛɠiladai zu, ta é naa ná-kpɔbai valini (\xt 3:1-66\xt*).
\io1 3. Zuda nuɓusɛiti ta-maanɔɠɔ wolai ma zoolɛi (\xt 4:1-22\xt*).
\io1 4. GALA falii Zuda yooi zei vai zu ʋolu ga pagɔ (\xt 5:1-22\xt*).
\c 1
\s1 Zeluzalɛme, eɠɛ poanzai ti ɠɛlɛai ba
\q1 
\v 1 Ee! Wɛlɛ tɔ ɠila ba gaalɛiɗai,
\q1 taa wolai nii nuɓusɛi mɔinni su!
\q1 Tɔɠɔɠulani ziiti saama,
\q1 wɛlɛ, é ɠɛa eɠɛ poanzai.
\q1 Mɔungi, é ɠɛni ga masa anzanui zou zɛʋɛiti unda,
\q1 tɔ ɠa niina é duɔla wotiiti kpein kɛɛzu.
\q1 
\v 2 Toɠa ɲiizu gɔlɔi ɠa piin,
\q1 gaazuɗɛiti ta yeizu komagaʋɛti.
\q1 Niiti kpein ti ɠɛni ga ná-wɛɛinti,
\q1 ti taɠila kpalaa ge la gaanɛɛnɛzu.
\q1 Bɔɔlaiti pɛ ti woyani,
\q1 ti pɛ ti ɠɛ niina ga sili nuiti.
\b
\q1 
\v 3 Zuda nuiti ti lia zou ɠili su,
\q1 ti ɓɔlɔa ʋoluma ga nimizai ta duɔlai.
\q1 Wɛlɛ ba, é zeini zii ɠiligiti saama,
\q1 é la ziilɛi sɔlɔɔsu.
\q1 Kpɛɛ nuiti ti yeezeelia ma
\q1 kidaaʋiligiti saama.
\q1 
\v 4 Siyɔn ʋeleiti ti lɔa gɔlɔi zu,
\q1 mazɔlɔɔ nu la mɔ ʋaazu ná, fɛtiiti su.
\q1 Ná-pɛlɛla ɓogiti pɛ ti ɠoloɠologa,
\q1 ná-zalaɠa ɠula nuiti ta kpalagi wosu,
\q1 ná-anzalopoiti gaazuɠiliʋɛ,
\q1 naa pɛ ka ga ziiɓɔlɔi Siyɔn ʋɛ.
\q1 
\v 5 Sili nuiti ti vɔniga ma,
\q1 sakpeɲɔɠɔiti ziilɛiɗa.
\q1 Mazɔlɔɔ Ɠɔoɠɔ GALAGI ziizoolɛa
\q1 ná-tɔ koloɠologiti mɔin vai zu.
\q1 Ná-doungoiti ti lia,
\q1 sili nuiti ti ti lɔ duɔlai zu.
\q1 
\v 6 Siyɔn nuɓusɛiti ti ʋalaga
\q1 ta-lɛbiyaiti pɛ ma.
\q1 Ta-ɠundiɠi wolaiti kɛɛʋɛ eɠɛ dopaiti,
\q1 ti la mɔ ani nɔpɛ sɔlɔɔni, ta mi,
\q1 ti ɗa li ga ɓizaa, zɛbɛ la mɔ ti ya,
\q1 ti ʋa ɠula dosoi ya.
\b
\q1 
\v 7 Ná-maanɔɠɔ voloiti su, voloi é ɠɛni leʋeteʋesu da,
\q1 Zeluzalɛme ɠi ge loa
\q1 nii kpein su
\q1 é ɠɛ ga zeaɠɔli pagɔiti mɔungi.
\q1 Siɛgi zu ná-nuɓusɛiti ti lɔɔni la sili nuiti zeezu,
\q1 nu la ná a ɓɔ ti ʋa,
\q1 sili nuiti ti ɠɛni ɲɛɛɠulazu su,
\q1 tɔɔzei é ɠoloɠologa.
\q1 
\v 8 Zeluzalɛme ná-kotoi wola zeizeiɗa ɠoozu,
\q1 naa ɠa é kɛa é ɠɔzɔa.
\q1 Niiti kpein ti ɠɛni maamusɛzu,
\q1 naati ta niina suvɛzu, ta ɠɛna kabei ɠaa.
\q1 Tɔ ɓɔɠɔi, toɠa kpalagi wosu,
\q1 é ɗa ɠula ʋolu.
\q1 
\v 9 Ná-alu kaa ɲamai ma ɠɔzɔi ʋogiti ta ná-seɠeiti su,
\q1 é la ɠigaiziɛni gaaɓelazuʋɛ zu,
\q1 ná-tooi ɠulaʋɛ filiba,
\q1 nu la koba, é ʋa tɛnɛ.
\q1 É ɠɛ ma: «Ɠɔoɠɔ GALAGI, wɛlɛ nà-nimizai ʋa,
\q1 wɛlɛ ʋelei sìli nui pilɛ sɔlɔɔsu la.»
\q1 
\v 10 Sili nuiti ti yeeʋɛa
\q1 ná-naavoloiti ma mɛɛ.
\q1 Tɔ ɓɔɠɔi zii ɠiligiti kaani,
\q1 ti lɔ ná-seizu ɲadegai zu.
\q1 Kɛlɛ tɔun, Maliɠii, è tɔ seini ma,
\q1 ga ti mina ɠɛ ɗa-ɠaalɛbai zu.
\q1 
\v 11 Ná-nuɓusɛi pɛ ka ɓalasu,
\q1 ti ɗa daamianigi ɠaiziɛ,
\q1 ti ti-yeaɠɔli pagɔi pɛ fea daamiani fai zu,
\q1 nii a kɛ ti yiila.
\q1 «Pɛtɛ, Ɠɔoɠɔ GALAGI, wɛlɛ,
\q1 ʋelei wɔ̀inzeɠeai la!»
\s1 Zeluzalɛme ná-gɔlɔ wooi
\q1 
\v 12 «Wɔiti pɛ wo leʋesu ʋɛ ʋelei, niima maanɔɠɔi la zeelini wo ma.
\q1 À wɛlɛ, wo ɠida bu,
\q1 nu nɔpɛ ná-taɓa la dɛ zeelini nii zu,
\q1 nii gè sɔlɔɔsu,
\q1 nii Ɠɔoɠɔ GALAGI daa mà,
\q1 ná-ziiɠaawana wolai ma voloi.
\q1 
\v 13 É abui yeiɗa, é zeɠe geezuʋɛ,
\q1 é ʋa, é lɔ kpùsɛi zu.
\q1 É baliiti tɛa tùɠɔ,
\q1 é tòkaga ga pòluʋelei.
\q1 É ɓeteʋea bà mɛtu,
\q1 ma zeeɓɛi ɠa bà yeenɔpɛ.
\q1 
\v 14 Zeei nà-tɔ koloɠologiti gilia ba,
\q1 ti laani ɓɔɠɔ maazu eɠɛ galui,
\q1 ti lɛ, ti zei kɔ̀bu.
\q1 Maliɠii sɛ̀bɛi zuzaa,
\q1 é dɔ̀a sili nuiti zeezu,
\q1 niiti gè la zooga faa nɔpɛ kɛɛzu ga tiye.
\q1 
\v 15 Maliɠii nà-salaʋusu ɠɛzɛiti kpɛa,
\q1 niiti ti ɠɛa nɔ̀un ba.
\q1 É salaʋusuiti toliga dàalɔɠɔma,
\q1 nii a kɛ é nà-nu niinɛiti suɠoloɠolo.
\q1 É sùɠoloɠologa, nɛ̀i gè ga Zuda ná-Siyɔin,
\q1 eɠɛ nu a leezɛn ʋu kɔɠɛi zu.
\q1 
\v 16 Naati pɛ faa ɠa gè wɔlɔzu su,
\q1 gàazuɗɛi pɛ ge ʋua,
\q1 mazɔlɔɔ gaanɛɛnɛ nui maaɠooza bà,
\q1 toɠa a la zìilaa.
\q1 Dòinti pɛ ti ɠaalɛiɗa gola,
\q1 tɔɔzei sìli nui zobo zɔlɔɔga.»
\b
\q1 
\v 17 Siyɔn yeelɛɛni geezu,
\q1 nu nɔpɛ ge la gaanɛɛnɛni.
\q1 Ɠɔoɠɔ GALAGI ná-devei ɠa
\q1 é Izilayɛle zeiɲɔɠɔiti kɛa ga sili nuiti.
\q1 Zeluzalɛme ɠɛa
\q1 ti ɠaazu ga kɔzɔba anii.
\b
\q1 
\v 18 «Ɠɔoɠɔ GALAGI zɔlegɛ, é naa ɠɛ,
\q1 mazɔlɔɔ gè la ɠoloni ná-deveiti bɛ.
\q1 À woilo, nuɓusɛiti pɛ,
\q1 à nà-kpɔlɔiti pɛtɛ!
\q1 Dòun ɓeaiti ta dòun lakpagiti
\q1 ti lia duɔlai zu.
\q1 
\v 19 Gè wooɠulani nɛ̀ɛɲɔɠɔiti ma,
\q1 kɛlɛ ti yàavani.
\q1 Nà-zalaɠa ɠula nuiti ta nà-kɛwolaiti
\q1 ti zaani taazuʋɛ,
\q1 ti yɛ daamiani gaiziɛ vai ma,
\q1 ti ʋa zɛbɛ zɔlɔɔ ʋolu.
\q1 
\v 20 Ɠɔoɠɔ GALAGI, nà-kpɔlɔi ʋɛtɛ!
\q1 Kòozuʋɛ ɠɛa nɔ yupuyapa,
\q1 zìiɓɔlɔa kòozu,
\q1 mazɔlɔɔ gè kololalai ɠɛɛni gola.
\q1 Boɠa zɔkpɔi ɠa bàlasu dòinti ma etea ʋelei,
\q1 pɛlɛwu ʋelei, eɠɛ nɔ nà ɠɛ saai ɓɔɠɔi ɠoba.
\q1 
\v 21 Ta kpàla gooiti mɛnisu,
\q1 nu nɔpɛ ge la gàanɛɛnɛzu.
\q1 Sìli nuiti pɛ ti nà-maanɔɠɔ vai zuɠwɛɛga,
\q1 é nɛɛni ti ʋɛ gola ga è naa zei mà.
\q1 Foloi è ma vaa woni, è ʋaa la,
\q1 nii é zeini mà, ti naa ɠɛɠalai zɔlɔɔ!
\q1 
\v 22 Wɛlɛ fɔɔn ta-zuɲɔuyai ʋa,
\q1 è ti zo da
\q1 eɠɛʋelei è sòni da
\q1 nà-tɔ koloɠologiti faa zu!
\q1 Wɛlɛ, nà ɓalasu nɔ ɠɔ,
\q1 zìi ɠana wana.»
\c 2
\s1 Zeluzalɛme taai // ta GALA sei ʋɛlɛi ti ɠoloɠolo fai
\q1 
\v 1 Ee, Maliɠii ná-ziiɠaawanai zu,
\q1 é Zeluzalɛme maalɔɔɠua ga tonaɓiingi!
\q1 É Izilayɛle ná-lɛbiyai ɠulaa geezuʋɛ,
\q1 é pili ya zooi ma!
\q1 Siɛgi zu é yiiɠaawanani la Siyɔn laalɔɠɔma,
\q1 é yeemani ga ná-kɔɠɔloma anii nɔ ʋe.
\q1 
\v 2 Maliɠii la maawɔinɠaa ɠɛɛni,
\q1 é Zakɔɓe ná-pɛlɛyeɠeiti pɛ kpɔleni.
\q1 É yɛni ná-ziiɠaawanai zu,
\q1 é Zuda laa wolaiti pɛ koloɠolo, siɠigi ti ma,
\q1 é masadai ta ma ɠundiɠiiti puuni ya zooi ma,
\q1 é ɓaaɠula ti ma.
\q1 
\v 3 Ná-ziiɠaawana wolai zu,
\q1 é Izilayɛle ná-zobogi pɛ koloɠoloni.
\q1 É ɓɔɠɔ zoni, é la ti maaloboni
\q1 siɛgi zu ti zili nuiti ti ʋaani la.
\q1 É abui ɠaazoga ná-nuɓusɛiti pɔ bɛ,
\q1 naa ti-maaɠoolii pɛ galani.
\q1 
\v 4 É ná-mɛɛin zumɛɛnga eɠɛ nu zili nui,
\q1 é zeezai ʋɛɛ ma ga é ʋa pili.
\q1 É ɓɔɠɔ lɛ ga gi zili nui ʋe,
\q1 é naa kpein paa, nii nu ɠaazu ɠɛa ɠulazu ba.
\q1 É ná-ziiɠaawanai ʋua eɠɛ abui
\q1 Siyɔn GALA sei ʋɛlɛi ma.
\q1 
\v 5 Maliɠii gi zoni eɠɛ gi zili nui,
\q1 é Izilayɛle ɓɔleni
\q1 ta ná-pɛlɛ ʋapagiti pɛ,
\q1 é ná-siɠigiti golowolo,
\q1 é ziizoolɛi ta kidaaʋiligi lɔ
\q1 Zuda nuɓusɛiti su adaʋɛ pɛ.
\q1 
\v 6 É ná-kpelei ma zasai ɠatani,
\q1 ná-gaalɛba wosuʋɛ ná ga sei ʋɛlɛi, é miná ɠoloɠoloni.
\q1 Siyɔn, Ɠɔoɠɔ GALAGI zeemai woni
\q1 fɛti voloiti ma ta dooɠo foloiti.
\q1 Ná-ziimaleʋei ma yiiɠaawanai zu,
\q1 é ɓaaɠulani masagiti ma ta zalaɠa ɠula nuiti.
\q1 
\v 7 Maliɠii la mɔ ná-zalaɠa ɠulazuʋɛ ʋɔ,
\q1 é ɠɛlɛa sei ʋɛlɛ ɲadegai ʋa,
\q1 é zɛni ná, é loo sili nuiti zeezaama,
\q1 Siyɔn ʋɛlɛ ʋapagiti ma ziɠigiti.
\q1 Ti-wooi ɠa ɠulazu Ɠɔoɠɔ GALAGI zei ʋɛlɛi wu
\q1 eɠɛ fɛti voloi.
\q1 
\v 8 Ɠɔoɠɔ GALAGI deveni
\q1 ga é Siyɔn ziɠigiti golo.
\q1 É galui laani ma, gaa ʋa ɠɛ sɔli,
\q1 é la inɛinɛni ga golo vai.
\q1 É siɠi felegɔi pɛ doɠani,
\q1 tama ti felegɔ pɛ ti ɠoloni.
\b
\q1 
\v 9 Taai laaʋɛ ma ɓogiti ti ʋua ya,
\q1 é ma zɔɠɔgiti suɓulukpuluni.
\q1 Ná-masagi ta ná-kundiɠiiti ta zii ɠiligiti zeezu,
\q1 tɔ ge la mɔ ná.
\q1 Anɛɛ ná-GALA goo wo nuiti
\q1 ti la mɔ kulakɛlɛma zɔlɔɔsu Ɠɔoɠɔ GALAGI ya.
\q1 
\v 10 Siyɔn nuɓusɛiti ta-ɠɛwolaiti
\q1 ta zeini zooi ma, ti maaɠɛ kpɔ,
\q1 ti fufiligi ʋu tɔungi ma,
\q1 ti saa wɔlɔ wo seɠeiti too ɠɔba.
\q1 Zeluzalɛme anzalopoiti
\q1 ti unpilɛga zooi ma.
\b
\q1 
\v 11 Gàazuɠɛzɛiti ti ɓɔlɔa ga gɔlɔi,
\q1 sàsu ɠana ɓali,
\q1 kito nɔpɛ ge la mɔ bɛ̀,
\q1 é lo maanɔɠɔi ʋa é zeelizu nà-nuɓusɛiti ma,
\q1 tɔɔzei ɲiimiɓɔlegiti ta doungo ʋɛlɛʋɛlɛgiti ta zaazu ga kpɔɔle wɔin
\q1 taazuʋɛ peleiti su.
\q1 
\v 12 Doungoiti ti ɗa ɠɛ ti-leeni ma:
\q1 «Mini ɠa ani ná nu mi ɓaa nu kpɔle?»
\q1 Naazu ti ɗa ɠɛ yɔɔɠɛ, eɠɛ nuiti ti maawanaai
\q1 taa zaamaʋɛ peleiti su,
\q1 ti-yii loozu niina
\q1 ti-lee yeelokoiti su.
\b
\q1 
\v 13 Zeluzalɛme, gè la kwɛɛ nii nà bo è ma,
\q1 è ɠɛʋelei la ɠulani ga taɠili nɔpɛ nɔnɔ!
\q1 Ɓɛ ná-faa ɠa nà bo è ma, gè è ɠaanɛɛnɛ la,
\q1 Siyɔn nuɓusɛiti?
\q1 Mazɔlɔɔ ɗa-nimizai zuwɔɔlɔʋɛ eɠɛ kpoloɗɛi,
\q1 ɓɛ ɠa deɠɛmu a zoo é è ɠɛdɛ?
\q1 
\v 14 Ɗa-ƓALA goo wo nuiti ti ɠɛni è ʋɛ
\q1 ga zɛɛ wo nuiti nɔ.
\q1 Ti la ɠɛni ɗa-vaaɠaaza golai ɠulani kɛlɛma è ʋɛ,
\q1 nii a kɛ è mina li duɔlai zu.
\q1 Ti ɠɛni kulakɛlɛmaiti kaazu è ʋɛ,
\q1 ti ga zɛɛ ɓɔɛiti, ta yaava vaiti nɔ.
\q1 
\v 15 Zɔiti pɛ ti leʋesu náʋɛ
\q1 ta yealoɠazu ma tɔɔzei è ɠoloɠologa,
\q1 ti ɗa foei vɛ, ti ɗa tɔungiti ɲiikpi
\q1 ga ti ɲɛɛɠula è zu, Zeluzalɛme:
\q1 «Taa wolai ɠa nɛi, ti ɠɛni tolisu ga
\q1 pagi daazeeliai, eteai pɛ ná-koozunɛɛi?»
\q1 
\v 16 È zili nuiti pɛ
\q1 ta laalaosu è laalɔɠɔma,
\q1 ti ɗa foei vɛ, ti ɗa ɲiigaiti siɛ ga,
\q1 ti ɗa ɠɛ ma: «Gi kpɔlea!
\q1 Zaa voloi ɠa gi ɠɛa maaɓɔunsu,
\q1 gi yeezeelia ma, gá ga ka.»
\q1 
\v 17 Nii Ɠɔoɠɔ GALAGI a bo, naa ɠa a ɗa kɛ,
\q1 toɠa ɗa daawooi ʋilɛ su
\q1 nii é boni kaite wɔlɔwɔlɔ,
\q1 é goloni, maawɔinɠaa la su.
\q1 Ɗa-nimiza vai ɠɛa ga è zili nuiti ta-ɠoozunɛɛi,
\q1 é è-zakpeɲɔɠɔiti ta-wasogi wɔɔlɔa.
\b
\q1 
\v 18 Nuɓusɛi ɓain gooi ɠa lɛɛzu Maliɠii ʋɔ pelei.
\q1 Siyɔn ziɠigi,
\q1 ɓe è-ɠaazuɗɛ ɓoigi ʋa,
\q1 é ʋu folo ʋɛɛ kpidi ʋa.
\q1 Mina lago pa dooɠo,
\q1 maaleʋe mina ɠɛ ɗa-wɔlɔi ʋa.
\q1 
\v 19 Wuzeɠe, è maanɛɛnɛi wo kpidii,
\q1 lɛlɛi ɠilagilagi pɛ tɔɔzeizuʋɛ!
\q1 Kula yiimaʋɛ
\q1 Maliɠii ɠaazu.
\q1 Yeezei bɛ ga maanɛɛnɛi
\q1 è-lointi zɛnvui vaa zu,
\q1 ti zaazu niina ga pului
\q1 koi yɔɠɔzu ʋelei pɛ su.
\b
\q1 
\v 20 Wɛlɛ, Ɠɔoɠɔ GALAGI, pɛtɛ
\q1 niiti è ti zosu ɠana!
\q1 Anzanuiti ta zoo nɛi ti ti-lointi mi,
\q1 niiti ti ti zogai ɠoozu, ti nɛai ti ʋɛ?
\q1 Nu ɠa zoo nɛi é ɗa-zalaɠa ɠula nuiti ta GALA goo wo nuiti paa,
\q1 Maliɠii è zei ʋɛlɛ ɲadegai wu?
\q1 
\v 21 Doungoiti ta nu wɔlɔiti
\q1 ta ʋuuni zooi ma taazuʋɛ ná pɛ.
\q1 Doun anzanuiti ta doun zunuiti ta laani
\q1 boɠa zɔkpɔi laaʋogi ti ʋa.
\q1 È ti ʋaani ɗa-yiiɠaawana voloi,
\q1 è ti ɠɔdaaleʋeni, maawɔinɠaa la su.
\q1 
\v 22 È dùaba nuɓusɛiti toliga mà,
\q1 eɠɛ fɛti volo.
\q1 Ɠɔoɠɔ GALAGI, ɗa-yiiɠaawana voloi,
\q1 fulu nu la ɠulani, ɓaa pela gele.
\q1 Dointi gè ti nɛɛni ʋɛ gola, gè ti ɠula su,
\q1 sìli nui ti pɛ undaaʋiliga.
\c 3
\s1 Kidaaʋili golai, ta kito kitei ma ungi
\q1 
\v 1 Nà ga zunui nii unfegi zeeliai ma
\q1 Maliɠii ná-ziiɠaawana ɓakɔi ya.
\q1 
\v 2 É liini ga ze, gè siɛi wo
\q1 kpidii zu, wozakala su la de.
\q1 
\v 3 Nà nɔ yeenɔpɛ nɔ
\q1 é yeei ʋɛɛzu bà.
\q1 
\v 4 É mà zuai vɔɔni su ta kɔ̀lɔgi,
\q1 é mà ɠaeiti galeɠale.
\q1 
\v 5 É koozuʋiligi ta kpɔlɔi
\q1 latini mà eɠɛ siɠigi.
\q1 
\v 6 É dɔ̀ɔni kpidii zu
\q1 eɠɛ nuiti ti zaani kaite.
\b
\q1 
\v 7 É màalatini ga gè mina ɠula,
\q1 é màavelevele ga yɔlɔɠɔiti, ti ɗa kàta.
\q1 
\v 8 Gè ɓɔlɔa ga kpeei loa, gè kpɔbai ɠaiziɛ,
\q1 é pele leʋeni nà-maanɛɛnɛ wooiti pɛ tuɠɔ.
\q1 
\v 9 É pelei laaɠuluga tùɠɔ ga kɔtu ziɠigiti,
\q1 é nà-peleiti seɠeni ma.
\q1 
\v 10 É ɠɛni bɛ̀ ga filɛ zuai, é zei tùɠɔ,
\q1 ɓaa zalai é ɓɔɠɔ maalɔɔɠuai.
\q1 
\v 11 É sèɠea pelei ʋa, é bàliʋali,
\q1 é fàlibo, é kɛ̀ ga zou vɔɔi.
\q1 
\v 12 É ná-mɛɛin zumɛɛnga,
\q1 é tete mà, ga é pili mà.
\q1 
\v 13 É sàamaʋɛ zuvoloni ga
\q1 ná-mɛɛinti pɛ.
\q1 
\v 14 Nuɓusɛiti pɛ ta ɲɛɛɠulazu sù,
\q1 ti ɗa dàalɔɔ guyei zu yeenɔpɛ.
\q1 
\v 15 É kògi zulaave ga ani wanaiti,
\q1 é ani wanai ɠɛɛni ga nà-kpɔɔle ɗɛi.
\q1 
\v 16 É ɲìigaiti gaaɠaleni ga ɲaɠae numagai,
\q1 é zuʋui ziɛ mà ɲɛgɛlɛin.
\q1 
\v 17 É ziilɛigi ɠulaa zèa,
\q1 gè yeema undaanɛɛi ma.
\q1 
\v 18 Gè ɠɛni ma: «Kito ge la bɛ̀,
\q1 kì ge la mɔ loni Ɠɔoɠɔ GALAGI ʋa!»
\b
\q1 
\v 19 Ee! Ɠizɛ nà-nimizai zu ta nà-kpɔlɔi,
\q1 toɠa ga anivebɛi ta ani wanai gè ɓɔɔlezu la.
\q1 
\v 20 Kì ka su, gè la yeema ma ɠɔ,
\q1 toɠa lɔɔzu ga ze.
\q1 
\v 21 Kɛlɛ wɛlɛ nii gè pɔ gè ɗa ɠisiɛ su zìimaʋɛ,
\q1 wɛlɛ nà-kitogi ma ungi ʋa:
\q1 
\v 22 Ɠɔoɠɔ GALAGI zu la ɓɔlɔa ga ná-wooɠɛɠiladai,
\q1 kwɛ ge la ná-maawɔinɠai ʋa.
\q1 
\v 23 Toɠa ɗa ti niinɛ sobu-o-sobu.
\q1 Ee, Ɠɔoɠɔ GALAGI, ɗa-wooɠɛɠiladai wola wɔɔlɔʋɛ!
\q1 
\v 24 Nà bosu, gè ɠɛ ma: «Ɠɔoɠɔ GALAGI ɠa ga nà-naavoloi,
\q1 naa ɠa é kɛɛzu kìgi logai ba.»
\b
\q1 
\v 25 Ɠɔoɠɔ GALAGI laavegɛ ga nuɓɔɠɔlai naama nui ʋɛ nii é ɠitosu ba,
\q1 ta zɔi é gaaʋotesu ma.
\q1 
\v 26 Pagɛ nu maaɠɛ kpɔ,
\q1 è Ɠɔoɠɔ GALAGI ná-unmɔɔ fai maaɓɔun.
\q1 
\v 27 Pagɛ nui ma è yeezei faaɓaagiti bu
\q1 è ma nu niinɛlai zu.
\q1 
\v 28 È zei yɛ, è ɠaalɛi,
\q1 mazɔlɔɔ naa ɠa deveai è ma.
\q1 
\v 29 È maayei, è laa lɔ fufiligi zu,
\q1 kito ka naa zu tanisu!
\q1 
\v 30 È ɠomagi ve è woizuloɠa nui ya,
\q1 è ɓɔɠɔ yɛ ná, ɓaaɠula è ma.
\b
\q1 
\v 31 Mazɔlɔɔ Maliɠii la ɗa ga nu ʋiliga ya
\q1 é ʋa yɛsu ɠɔ.
\q1 
\v 32 Kɛlɛ ni a nu ɠaazuɠili vai ɠɛɛna,
\q1 toɠa maawɔinɠai ɠɛ,
\q1 é zoloo ná-wooɠɛɠilada wolai ma.
\q1 
\v 33 Mazɔlɔɔ ziima la de ga é ʋa nuɓusɛiti unfe,
\q1 é ʋa ti ɓɔlɔ.
\b
\q1 
\v 34 Siɛgi zu ti ɠɔɠɔlosu da
\q1 zooi zu ɠasoa nuiti pɛ ma,
\q1 
\v 35 siɛgi zu ti lɛɠɛzu la GALA su, nii é Anii-Pɛ-Unda,
\q1 ti kakama vai ɠɛ ga nuiti,
\q1 
\v 36 siɛgi zu ti nui ta ná-tukpɔi maaʋesu da,
\q1 Maliɠii la ɗa ga naa ɠaa ɓaa?
\b
\q1 
\v 37 Ɓɛ ɠa a wooi wona, su vaiti ta ɗa ɠɛ?
\q1 Maliɠii laade é ʋa ɠɛ devei wosu ɓaa?
\q1 
\v 38 GALA nii é Anii-Pɛ-Unda, naa laawooi laade
\q1 fai pɛ ge ɠulazu su, maanɔɠɔi ta undaanɛɛi?
\q1 
\v 39 Leeni vaa zu nuɓusɛi a kpee loo, tama é vulua?
\q1 Ɛsɛ ge kpee loo ga ná-kotoiti faa.
\b
\q1 
\v 40 De ɠida de-ziɛ ʋeleiti bu,
\q1 de ɠale ma, de ʋa Ɠɔoɠɔ GALAGI ʋɔ.
\q1 
\v 41 Ade GALA fali ga yii pɛ, de yeeiti tɛ
\q1 GALA pɔ pelei é geeɠɔlɔgi zu.
\q1 
\v 42 Gi ɗa-lɔgiti koloɠoloni, gi ɓakani!
\q1 Ɗa ma, è la ɠɛni gi zuvaayɛni!
\q1 
\v 43 È ɓɔɠɔ maaɠilini ɗa-yiiɠaawanai zu,
\q1 è ʋilɛni gi ʋolu,
\q1 è gi ʋaa, è la gi maawɔinɠaani.
\q1 
\v 44 È ɓɔɠɔ maalɔɔɠuni ga tonaɓiingi,
\q1 gá-ƓALA fali wooiti ti ʋa zeeli è ma.
\q1 
\v 45 È gi ɠɛɛni ga kaʋai,
\q1 kaʋa luulaai nuɓusɛi zɔiti saama.
\b
\q1 
\v 46 Gi zili nuiti ta laalaosu
\q1 gi laalɔɠɔma.
\q1 
\v 47 Gɔnɔi yɛga duai ma ta gaazulatigi,
\q1 ta faa zuɠoloɠologi, ta faaɓalakalagi.
\q1 
\v 48 Gàazuɗɛiti ta ʋuuzu eɠɛ kɔtuɗɛiti
\q1 nà-nuɓusɛiti ta-vaaɓalakalagi maaʋele ma.
\b
\q1 
\v 49 Gɔlɔɗɛi ɠa gàazuʋɛti, maaleʋe la ba,
\q1 ti la looɠosu ɠɔ,
\q1 
\v 50 eyɛsu Ɠɔoɠɔ GALAGI yɛ geezuʋɛ,
\q1 é maayei, é wɛlɛ, é ka.
\q1 
\v 51 Nii é zeelizu nà-taazu anzalopoiti ma,
\q1 naa ʋɛtɛ fai ɠa kpɔ̀lɔzu gola.
\b
\q1 
\v 52 Ta pòlu, ti ɗa kpɛ̀ eɠɛ wɔni,
\q1 ti ga sìli nuiti, un ge la ba.
\q1 
\v 53 Ti mà vului lɔɔɠua zeɠezaɠai zu,
\q1 ti kɔtu wolai la màazu.
\q1 
\v 54 Ziɛi lɛɛni, é ɓudɛ nɔ̀ungi maazu,
\q1 gè ɠɛni ɠɛɛzu: «Ùndaaʋiliga!»
\b
\q1 
\v 55 Ee, Ɠɔoɠɔ GALAGI, gè yɛni zeɠe ɓomaʋɛ,
\q1 gè wooɠula è ma.
\q1 
\v 56 È nà-kpee wooi mɛnini:
\q1 «Mina woi zeɠe kpàla gooiti ma, ta nà-kidaaʋili kpeeiti!»
\q1 
\v 57 Voloi gè wooɠulani la è ma, è maaɓuɠani bà,
\q1 è ɠɛni mà: «Mina lua!»
\b
\q1 
\v 58 Maliɠii, è màavaawoga,
\q1 è zɛ̀nvui unmɔɔga.
\q1 
\v 59 Ɠɔoɠɔ GALAGI, è kakama vai ɠaa ti kɛai ga ze,
\q1 nà-tukpɔi lo bɛ̀.
\q1 
\v 60 È pɛtɛga ʋelei ti potokulai ɠɛɛzu la ze,
\q1 ta ta-yaava vaiti pɛ dàalɔɠɔma.
\q1 
\v 61 Ɠɔoɠɔ GALAGI, è ta-ʋoomu gooiti pɛ mɛnini,
\q1 ta ta-yaava vaiti pɛ dàalɔɠɔma.
\q1 
\v 62 Sìli nuiti ta-ɓɔɛzuɠulaiti ta ta-ɠisiɛiti,
\q1 naa pɛ ka ɠɛɛzu dàalɔɠɔma foloi laawu ɲɛgɛlɛin.
\q1 
\v 63 Ti ɠɛni zeini, ti ɠɛni loni,
\q1 wɛlɛ, nà ɠa ti dàalɔɔzu ta-wuyeiti su.
\b
\q1 
\v 64 Ee, Ɠɔoɠɔ GALAGI, ti zo
\q1 eɠɛʋelei ti kɛɛni la ga ze.
\q1 
\v 65 Ɗa ti-yii zasa ti ɠoozu,
\q1 naa ɠa a ɠɛ ga ɗa-voovooi ti ʋa.
\q1 
\v 66 Ɗa ɗa-yiiɠaawanai ʋilɛ ti ʋolu,
\q1 è ti-ma zuwu ɠaaleʋe eteai zu, ee, Ɠɔoɠɔ GALAGI!
\c 4
\s1 Zeluzalɛme ɠoloɠologa
\q1 
\v 1 Leeni ʋe deɠɛmu! Zanugi ɠɔikɔiga!
\q1 Zanu kitei la mɔ volozu!
\q1 Kɔtu ɲadegaiti ti vazaga
\q1 taazuʋɛ peleiti su.
\q1 
\v 2 Leeni ʋe mu, Siyɔn lointi ti vizɔgai,
\q1 ti-zuɲɛgi vizɔni zanugi ʋa,
\q1 ta zoo ti ɠaalu ga pɔlɔ liɠii zɔngɔi nɔ,
\q1 diɠi lo nui kpɛtɛai?
\q1 
\v 3 Anɛɛ koʋeiti ta ɗa ɲiimi lɔ
\q1 ti-lointi da.
\q1 Kɛlɛ nà-nuɓusɛiti kɛɛʋɛ eɠɛ maawɔinɠaalala loun deei,
\q1 eɠɛ saa wɔnigi é teʋebai zu.
\q1 
\v 4 Kpɔɔle wɔin doun ɲɛgiti nɛgiti kataga
\q1 ti-laaɠoozuʋɛti ba.
\q1 Doungoiti ta daamianigi ɠaiziɛzu,
\q1 nu la ná, é ʋa ɠɛ dɔ daalaa ɠila kpalaa veezu ti ya.
\q1 
\v 5 Niiti ti ɠɛni daamii nɛɛnɛ golai wosu,
\q1 naati ta loozu ga fikɛʋalasui taazuʋɛ peleiti su.
\q1 Niiti ti kulasui woni ani ʋagɔiti pɛ saama,
\q1 naati ta kpoɠagiti suvelɛsu.
\q1 
\v 6 Nà-nuɓusɛiti ta-ɠakagiti suwɔɔlɔʋɛ gola
\q1 é leʋe Sɔdɔme nuiti ta-vaaɠaazagiti ba,
\q1 nii é ɓezeɠeleni gaazulooma laa ɠila daawu,
\q1 nu la yeevɔɔɠuni ba.
\q1 
\v 7 Siyɔn ɠundiɠiiti ti ɲadeni, é leʋe kobe kolegi ʋa,
\q1 ti-ɠɔlɔgi ɠole é leʋe nɔnɔi ʋa.
\q1 Ti-ɓusɛi ʋa é leʋe kpɔzɔi ʋa.
\q1 Ti-ɠaazuʋɛ ɗa volo é leʋe kɔtu zɔngɔ ɓaagi ʋa daa ga safiilegi.
\q1 
\v 8 Ti maaʋɛ lɛiɗa é leʋe kpakpaliɠii ʋa,
\q1 nu la mɔ ɠwɛɛsu ɠaazu ti ʋa taazuʋɛ.
\q1 Ti-ɠɔlɔgi ɠataga ti-ɠaeiti ba,
\q1 ti-ɠɔlɔgi vɔa ti ma eɠɛ gulu vɔɔi.
\q1 
\v 9 Niiti ti zaazu ga boɠa zɔkpɔi, naati undaanɛɛʋɛ
\q1 é leʋe naati ba, niiti ti zaazu ga pului,
\q1 ti vɔɔzu, ti ɠaɲa,
\q1 mazɔlɔɔ ti ʋalagɛ kpala ga aniiti ma.
\q1 
\v 10 Doun deeiti ti ga maawɔinɠaa nuiti,
\q1 ti ɗa ti-lointi gili diɠii zu,
\q1 ti ɠɛ ti ʋɛ ga daamianigi
\q1 kidaaʋiligi zu é zeelini nà-nuɓusɛiti ma.
\b
\q1 
\v 11 Ɠɔoɠɔ GALAGI zeelia ná-ziiɠaawanai ɠwɛ ma,
\q1 é ná-ziiɠaawana wolai laaɓadɔa,
\q1 é abui ɠaazoni Siyɔn,
\q1 naa ma wuulaagiti pɛ galani.
\q1 
\v 12 Eteai zu masagiti ta nu nɔpɛ
\q1 ge la ɓena zoo é ʋa la da,
\q1 ga yeeta, pilɛ sɔlɔɔ nui, nii é ga gi zili nui
\q1 a la lɛ Zeluzalɛme ga pɛlɛla ʋeleiti.
\q1 
\v 13 Naa ɠɛɛʋɛ ná-GALA goo wo nuiti ta-ɠotoi ma vaa zu,
\q1 ta ná-zalaɠa ɠula nuiti ta-vaaɠaaza golaiti,
\q1 niiti ti telebo nuiti
\q1 ma ɲamai ʋuuni náʋɛ.
\q1 
\v 14 Kɛlɛ niizu ta leʋesu taazuʋɛ
\q1 eɠɛ gaazuɠole nua,
\q1 ti ɠɔzɔai ga ɲamai
\q1 eyɛsu nu la zooga é ʋa vɔɔɠu ta-zeɠei ʋa.
\q1 
\v 15 Ta ɓainsu ti ma ga: «À lɔu li, kɔzɔba nuiti!
\q1 À lɔu li, à lɔu li, à mina vɔɔɠu gi ʋa!»
\q1 Siɛgi zu ti ʋelazu la ɠana, ti ɗa leʋeteʋe ziiti saama,
\q1 ta ɠɛɛzu ti ma: «À mina zei ʋɛ!»
\q1 
\v 16 Ɠɔoɠɔ GALAGI ɓɔɠɔi ɠa é ti zuvazani,
\q1 é la pɔ é ʋa ti ɠaa mɔnɔ.
\q1 Ti la ɠɛni unfema veeni zalaɠa ɠula nuiti bɛ,
\q1 ɓaa ti ʋa kɛwola wɔlɔiti bɛlɛzei.
\b
\q1 
\v 17 Gi-ɠaazuʋɛ yɛni nɔ ɓɔlɔzu dɛ,
\q1 gi ɗa kpɔbai maaɓɔun fuun.
\q1 Gi ɠɛni gá-ɠɔɔɓɔgi zeizuʋɛ, gi ɗa wɛlɛ zii ta luɠɔ,
\q1 é la ʋaani é ʋa gi ɠizo.
\q1 
\v 18 Gi zili nuiti ti ɠɛni gi-ɠɔɠɔ ʋo gaiziɛzu,
\q1 gi la mɔ ɠɛni ziɛziɛsu taazuʋɛ.
\q1 Gá-eteai ɠana ɓe, gá-voloiti daazeelia,
\q1 gi-ɠaaɓelagi zeelia.
\q1 
\v 19 Gi ɓɛɛ nuiti gola zuvilɛni,
\q1 é leʋe koɠɛi ʋa geezuʋɛ.
\q1 Ti ɠɛni gi ɓɛɛzu gizeiti ma,
\q1 ti ɠɛni seikpɛgi ʋɛɛzu gi ɠaiziɛ vai zu teʋebaiti su.
\q1 
\v 20 Gá-masagi, nii Ɠɔoɠɔ GALAGI gulɔi ziɛni ma, nii gá-eteai ɠɛni zea,
\q1 ti naa zoni ga ta-ʋaliiti,
\q1 tama naa ɠa gi ɠɛni ɠɛɛzu ma:
\q1 «Gá yɛ ná-niinigi wu, gi gá-eteai ziɛ zii ɠiligiti saama.»
\b
\q1 
\v 21 Wa zoo wo ɠoozunɛ, Edɔme nuɓusɛiti,
\q1 wɔiti wo zeini Use yooi zu!
\q1 Kɛlɛ tukpɔɠaaleʋe ɗaawɔi ɠa zeelizu ɓalaa wo ma,
\q1 ma lɔɔi ɠa wo zo, wo maaɲakai ɠula!
\q1 
\v 22 Siyɔn nuɓusɛiti, wo-zalai laazeelia,
\q1 nu la mɔ lia ga ɗe duɔla zu pɛ.
\q1 Kɛlɛ ɗɔun ɗa, Edɔme, Maliɠii ɠa ɗa-vaaɠaaza golaiti salazu,
\q1 toɠa ɗa-ɠotoiti kula kɛlɛma.
\c 5
\s1 Nuɓusɛiti ti ɓɔlɔai ta-maanɛɛnɛ wooi
\q1 
\v 1 Ɠɔoɠɔ GALAGI, ɠizɛ naa zu, nii seeliai gi ma.
\q1 Wɛlɛ, è gá-ɓaaɠulamai ʋɛtɛ.
\q1 
\v 2 Gá-yooi vea taɠiligaani zea,
\q1 gá-ʋɛlɛiti ti ve wɛɛinti zea.
\q1 
\v 3 Gi ɠɛa ga podointi, kɛɛɠɛ la gi ʋɛ,
\q1 gi-leeni ti ɠɛ eɠɛ poanzaiti.
\q1 
\v 4 Gá ɠɛɛna gá-ɗɛi ɓɔlea, kɛni gi geya ga walii,
\q1 kɛni gi gá-ɠoʋi vɔɔi ɠeya pɛ, gi ʋa sɔlɔɔ.
\q1 
\v 5 Gi nimiza nuiti ta gi ʋolu,
\q1 gi ɓɔlɔa, dooɠo ge la gi ʋɛ.
\q1 
\v 6 Gi yeezeini Ezipete yooi ʋɛ,
\q1 ta Asiili ʋele, gi ʋa daami wo gá-ʋului zu.
\q1 
\v 7 Gi-ɠɛɛni ti kotoi ɠɛɛni, kɛlɛ ti la mɔ ná,
\q1 gá ɠa niina gi ta-vaaɠaaza golai ma ɠasɔi zeɠezu.
\q1 
\v 8 Duɔiti ta zeini gi unda,
\q1 kɛlɛ nu nɔpɛ ge la gi ɠulazu ti ya.
\q1 
\v 9 Nii a kɛ gi daamianigi zɔlɔɔ, gi-un ka ɠɛɛzu é yɛ su,
\q1 gá ɠomisu nu ɓulugi ma teʋebai zu, boɠa zɔkpɔi ti ya.
\q1 
\v 10 Gi-ɠɔlɔgi ɗa ɠala eɠɛ gá ɠɛ fuulu zu,
\q1 pului ná-kpɔidai ʋɛ.
\q1 
\v 11 Ti anzanuiti koloɠoloni Siyɔn,
\q1 ta anza ɓeaiti Zuda laa wolaiti su.
\q1 
\v 12 Ti kundiɠiiti kpadɔni gului ma ga ti-yeeiti,
\q1 ti la ɠɛni unfeni kɛwola wɔlɔiti ma ga tago ɓalaa.
\q1 
\v 13 Nu niinɛiti ti ɠɛni ani ziɠa ɠɔtui zeɠezu,
\q1 zunu loungoiti ti ɠɛni loozu gulu ɠasɔiti bu.
\q1 
\v 14 Kɛwolaiti ti looɠoga unpilɛ faiti ba,
\q1 nu niinɛiti ti looɠoga ta-wuye loo vaiti ba.
\q1 
\v 15 Koozunɛ la mɔ gi-yiimaʋɛ.
\q1 Gi ɠɛni kuai wosu ga koozunɛɛi, naa valiboga ga gaazuɠilii.
\q1 
\v 16 Lɛbiya wɔɔlɔgi ɠulaa gi unba.
\q1 Gi maanɔɠɔa, mazɔlɔɔ gi kotoi ɠɛa!
\q1 
\v 17 Ungo, ni gi-yii ɠa ɓɔlɔzu,
\q1 ni gi-ɠaazuʋɛti ti ʋɛɛʋɛ ma,
\q1 
\v 18 naa lɔɔzeiʋɛ Siyɔn ɠoloɠolo fai ʋa,
\q1 miná ɠa niina koʋeiti ti ziɛziɛsu ná.
\b
\q1 
\v 19 Kɛlɛ ɗɔun ɗa, Ɠɔoɠɔ GALAGI, ɗa masadai ɠɛɛzu eyɛsu ɠɔ,
\q1 ɗa-masa kpɔkpɔgi ɠa ná siɛnɔpɛ su.
\q1 
\v 20 Leeni vaa zu ɗa yeema gi ma eyɛsu ɠɔ?
\q1 Leeni vaa zu ɗa ɠɛlɛ gi ʋa eyɛsu suɠooza?
\q1 
\v 21 Ɠɔoɠɔ GALAGI, gi ɠaaɠale ma è ʋɔ pelei, gá ɠale ma!
\q1 Gá-voloiti niinɛ, eɠɛʋelei é ɠɛni la mɔungi!
\q1 
\v 22 Ɗa gi ʋili ya nɛi gaamazu ga ɠite ɓaa?
\q1 Ɗa yiiɠaawana nɛi gi ma, da ge leʋe ɓaa?
