\v 32 \w Y|strong="H3068"\w* enterraron \w en|strong="H6912"\w* Siquem \w los|strong="H1121"\w* \w huesos|strong="H6106"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w* \w que|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w habían|strong="H1961"\w* traído \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*, \w en|strong="H6912"\w* la \w parte|strong="H2513"\w* del \w campo|strong="H7704"\w* \w que|strong="H1121"\w* \w Jacob|strong="H3290"\w* \w compró|strong="H7069"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Hemor padre \w de|strong="H1121"\w* Siquem, \w por|strong="H7069"\w* \w cien|strong="H3967"\w* piezas \w de|strong="H1121"\w* plata; y \w fue|strong="H1961"\w* \w en|strong="H6912"\w* \w posesión|strong="H5159"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*.   
