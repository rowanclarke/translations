\v 5 \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* atendieron \w a|strong="H3068"\w* las \w obras|strong="H4639"\w* del \w SEÑOR|strong="H3068"\w*, \w ni|strong="H3808"\w* al \w hecho|strong="H4639"\w* \w de|strong="H3588"\w* sus \w manos|strong="H3027"\w*, \w derribarálos|strong="H2040"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H3588"\w* \w edificará|strong="H1129"\w*.
\m 
\v 6 \w Bendito|strong="H1288"\w* \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w*, \w que|strong="H3588"\w* \w oyó|strong="H8085"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* mis \w ruegos|strong="H8469"\w*.
\m 
\v 7 El \w SEÑOR|strong="H3068"\w* es mi \w fortaleza|strong="H5797"\w* \w y|strong="H5797"\w* mi \w escudo|strong="H4043"\w*: en él esperó mi \w corazón|strong="H3820"\w*, \w y|strong="H5797"\w* fui ayudado; por lo que se gozó mi \w corazón|strong="H3820"\w*, \w y|strong="H5797"\w* con mi \w canción|strong="H7892"\w* le \w alabaré|strong="H3034"\w*.
\m 
\v 8 \w El|strong="H1931"\w* \w SEÑOR|strong="H3068"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* fuerza, \w y|strong="H5797"\w* \w la|strong="H1931"\w* \w fortaleza|strong="H5797"\w* de las \w saludes|strong="H3444"\w* de \w su|strong="H1931"\w* \w ungido|strong="H4899"\w*.
\m 
\v 9 \w Salva|strong="H3467"\w* \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w*, \w y|strong="H5704"\w* \w bendice|strong="H1288"\w* \w a|strong="H3068"\w* tu \w heredad|strong="H5159"\w*; \w y|strong="H5704"\w* pastoréalos \w y|strong="H5704"\w* ensál­zalos \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.
\c 29
\d Salmo de David.
\m 
\v 1 \w DAD|strong="H3051"\w* al \w SEÑOR|strong="H3068"\w*, \w oh|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w fuertes|strong="H5797"\w*, \w dad|strong="H3051"\w* al \w SEÑOR|strong="H3068"\w* la \w gloria|strong="H3519"\w* \w y|strong="H3519"\w* la \w fortaleza|strong="H5797"\w*.
\m 
\v 2 \w Dad|strong="H3051"\w* al \w SEÑOR|strong="H3068"\w* la \w gloria|strong="H3519"\w* debida \w a|strong="H3068"\w* su \w nombre|strong="H8034"\w*: Adorad al \w SEÑOR|strong="H3068"\w* en la hermosura \w de|strong="H1927"\w* la \w santidad|strong="H6944"\w*.
\m 
\v 3 \w Voz|strong="H6963"\w* \w del|strong="H5921"\w* \w SEÑOR|strong="H3068"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w aguas|strong="H4325"\w*: hizo tronar \w el|strong="H5921"\w* \w Dios|strong="H3068"\w* \w de|strong="H5921"\w* glo­ria: \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*.
\m 
\v 4 \w Voz|strong="H6963"\w* del \w SEÑOR|strong="H3068"\w* con \w potencia|strong="H3581"\w*; \w voz|strong="H6963"\w* del \w SEÑOR|strong="H3068"\w* con \w gloria|strong="H1926"\w*.
\m 
\v 5 \w Voz|strong="H6963"\w* del \w SEÑOR|strong="H3068"\w* que \w quebranta|strong="H7665"\w* los cedros; y \w quebrantó|strong="H7665"\w* el \w SEÑOR|strong="H3068"\w* los cedros del \w Líbano|strong="H3844"\w*.
\m 
\v 6 \w E|strong="H3068"\w* hízolos saltar \w como|strong="H3644"\w* \w becerros|strong="H5695"\w*; al \w Líbano|strong="H3844"\w* y al \w Sirión|strong="H8303"\w* \w como|strong="H3644"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w unicornios|strong="H7214"\w*.
\m 
\v 7 \w Voz|strong="H6963"\w* del \w SEÑOR|strong="H3068"\w* que derrama \w llamas|strong="H3852"\w* de fuego.
\m 
\v 8 \w Voz|strong="H6963"\w* del \w SEÑOR|strong="H3068"\w* que hará temblar el \w desierto|strong="H4057"\w*; hará temblar el \w SEÑOR|strong="H3068"\w* el \w desierto|strong="H4057"\w* de \w Cades|strong="H6946"\w*.
\m 
\v 9 \w Voz|strong="H6963"\w* del \w SEÑOR|strong="H3068"\w* \w que|strong="H3605"\w* hará estar de parto \w a|strong="H3068"\w* las ciervas, \w y|strong="H3519"\w* desnuda­rá las breñas: \w y|strong="H3519"\w* en su \w templo|strong="H1964"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* suyos le dicen \w gloria|strong="H3519"\w*.
\m 
\v 10 \w El|strong="H3427"\w* \w SEÑOR|strong="H3068"\w* \w preside|strong="H3427"\w* en \w el|strong="H3427"\w* dilu­vio, y \w asentóse|strong="H3427"\w* \w el|strong="H3427"\w* \w SEÑOR|strong="H3068"\w* \w por|strong="H5769"\w* \w rey|strong="H4428"\w* para \w siempre|strong="H5769"\w*.
\m 
\v 11 El \w SEÑOR|strong="H3068"\w* \w dará|strong="H5414"\w* \w fortaleza|strong="H5797"\w* \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*: el \w SEÑOR|strong="H3068"\w* \w bendecirá|strong="H1288"\w* \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w* en \w paz|strong="H7965"\w*.
\c 30
\d Salmo cantado en la dedicación de la Casa: Salmo de David.
\m 
\v 1 GLORIFICARTE he, oh SEÑOR; \w porque|strong="H1732"\w* me has ensalzado, y no hiciste \w a|strong="H3068"\w* mis enemigos alegrarse de mí.
\m 
\v 2 Oh \w SEÑOR|strong="H3068"\w* \w Dios|strong="H3068"\w* mío, \w a|strong="H3068"\w* ti clamé, \w y|strong="H3588"\w* \w me|strong="H3588"\w* sanaste.
\m 
\v 3 Oh \w SEÑOR|strong="H3068"\w*, hiciste subir mi alma del sepulcro, dísteme vida, para que no descendiese \w a|strong="H3068"\w* la sepultura.
\m 
\v 4 Cantad \w al|strong="H4480"\w* \w SEÑOR|strong="H3068"\w*, vosotros sus santos, y dadle gracias \w a|strong="H3068"\w* la memoria \w de|strong="H4480"\w* su santidad.
\m 
\v 5 Porque un momento será su furor; mas en su voluntad está \add la\add* vida: por la noche durará el lloro, mas \w a|strong="H3068"\w* la mañana \add vendrá\add* la ale­gría.
\m 
\v 6 \w Y|strong="H3068"\w* dije \w yo|strong="H3588"\w* \w en|strong="H3588"\w* mi prosperidad: \w No|strong="H3588"\w* seré jamás conmovido;
\m 
\v 7 Porque tú, SEÑOR, \w por|strong="H5769"\w* tu benevolencia has asentado mi monte con fortaleza. Escondiste tu rostro, fui conturbado.
\m 
\v 8 \w A|strong="H3068"\w* ti, oh \w SEÑOR|strong="H3068"\w*, clamaré; \w y|strong="H5797"\w* al \w SEÑOR|strong="H3068"\w* suplicaré.
\m 
\v 9 ¿Qué provecho hay en mi san­gre, cuando yo descienda al hoyo? ¿te alabará el polvo? ¿anunciará tu verdad?
\m 
\v 10 Oye, \w oh|strong="H4100"\w* SEÑOR, y ten mise­ricordia \w de|strong="H1818"\w* mí: SEÑOR, \w sé|strong="H4100"\w* tú mi ayudador.
\m 
\v 11 Has tornado \w mi|strong="H1961"\w* endecha en baile; desataste \w mi|strong="H1961"\w* cilicio, y ceñís­teme de alegría.
\m 
\v 12 Por tanto \w a|strong="H3068"\w* ti cantaré alaban­zas, gloria \add mía\add*, y no estaré callado. Oh SEÑOR Dios mío, te daré gracias para siempre.
\c 31
\d Al Músico principal: Salmo de David.
\m 
\v 1 EN ti, oh SEÑOR, he esperado; no sea yo confundido para siempre: líbrame en tu justicia.
\m 
\v 2 Inclina \w a|strong="H3068"\w* mí tu oído, \w líbrame|strong="H6403"\w* presto; séme \w por|strong="H5769"\w* roca de fortale­za, \w por|strong="H5769"\w* casa fuerte para salvarme.
\m 
\v 3 Porque tú \w eres|strong="H1961"\w* \w mi|strong="H1961"\w* \w roca|strong="H6697"\w* y \w mi|strong="H1961"\w* for­taleza; y por tu nombre me guia­rás, y me encaminarás.
\m 
\v 4 \w Me|strong="H3588"\w* sacarás \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w red|strong="H4686"\w* \w que|strong="H3588"\w* han escondido \w para|strong="H4616"\w* mí; \w porque|strong="H3588"\w* tú eres mi fortaleza.
\m 
\v 5 \w En|strong="H3588"\w* tu mano encomiendo mi espíritu: tú \w me|strong="H3588"\w* has redimido, oh SEÑOR, Dios \w de|strong="H3588"\w* verdad.
\m 
\v 6 Aborrecí \w a|strong="H3068"\w* los \w que|strong="H3027"\w* esperan en vanidades ilusorias; \w mas|strong="H6485"\w* yo en el \w SEÑOR|strong="H3068"\w* he esperado.
\m 
\v 7 Me gozaré y alegraré en tu misericordia; \w porque|strong="H8130"\w* has visto mi aflicción; has conocido mi alma en las angustias:
\m 
\v 8 \w Y|strong="H3068"\w* no me encerraste en mano del enemigo; hiciste estar mis pies en anchura.
\m 
\v 9 Ten misericordia de mí, oh SEÑOR, \w que|strong="H3808"\w* \w estoy|strong="H5975"\w* \w en|strong="H5975"\w* angustia: hanse consumido de pesar mis ojos, mi alma, y mis entrañas.
\m 
\v 10 \w Porque|strong="H3588"\w* \w mi|strong="H5315"\w* \w vida|strong="H5315"\w* se \w va|strong="H3068"\w* gastan­do \w de|strong="H3588"\w* dolor, \w y|strong="H3588"\w* mis años \w de|strong="H3588"\w* suspi­rar: hase enflaquecido \w mi|strong="H5315"\w* fuerza \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w mi|strong="H5315"\w* iniquidad, \w y|strong="H3588"\w* mis huesos se han consumido.
\m 
\v 11 \w De|strong="H3588"\w* \w todos|strong="H8141"\w* mis enemigos he sido oprobio, \w y|strong="H3588"\w* \w de|strong="H3588"\w* mis vecinos \w en|strong="H3588"\w* gran manera, \w y|strong="H3588"\w* horror \w a|strong="H3068"\w* mis conocidos: \w los|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* veían fuera, huían \w de|strong="H3588"\w* \w mí|strong="H3015"\w*.
\m 
\v 12 He \w sido|strong="H1961"\w* olvidado \w de|strong="H4480"\w* \add su\add* cora­zón \w como|strong="H1961"\w* un muerto: \w soy|strong="H1961"\w* \w como|strong="H1961"\w* un vaso quebrado.
\m 
\v 13 Porque he oído afrenta \w de|strong="H7911"\w* muchos; miedo por todas partes, \w cuando|strong="H1961"\w* consultaban juntos con­tra \w mí|strong="H1961"\w*, \w e|strong="H3068"\w* ideaban quitarme la vida.
\m 
\v 14 \w Mas|strong="H3588"\w* \w yo|strong="H3588"\w* \w en|strong="H5921"\w* \w ti|strong="H5921"\w* confié, oh SEÑOR: \w yo|strong="H3588"\w* dije: Dios \w mío|strong="H5921"\w* eres tú.
\m 
\v 15 \w En|strong="H5921"\w* tu mano están mis tiem­pos: líbrame \w de|strong="H5921"\w* \w la|strong="H5921"\w* mano \w de|strong="H5921"\w* mis enemigos, \w y|strong="H5921"\w* \w de|strong="H5921"\w* mis perseguido­res.
\m 
\v 16 Haz resplandecer tu rostro sobre tu siervo: sálvame \w por|strong="H3027"\w* tu misericordia.
\m 
\v 17 \w No|strong="H5921"\w* sea yo confundido, oh SEÑOR, ya \w que|strong="H5921"\w* \w te|strong="H5921"\w* he invocado; sean corridos \w los|strong="H5921"\w* impíos, estén mudos \w en|strong="H5921"\w* \w el|strong="H5921"\w* sepulcro.
\m 
\v 18 \w Enmudezcan|strong="H1826"\w* \w los|strong="H3588"\w* labios mentirosos, \w que|strong="H3588"\w* hablan contra \w el|strong="H3588"\w* \w justo|strong="H7563"\w* cosas duras, \w con|strong="H3588"\w* soberbia \w y|strong="H3588"\w* menosprecio.
\m 
\v 19 ¡Cuán grande es tu bien, \w que|strong="H5921"\w* has guardado \w para|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w te|strong="H5921"\w* temen, \w que|strong="H5921"\w* has obrado \w para|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* esperan \w en|strong="H5921"\w* \w ti|strong="H5921"\w*, \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* hijos \w de|strong="H5921"\w* \w los|strong="H5921"\w* hombres!
\m 
\v 20 \w Los|strong="H1121"\w* esconderás en \w el|strong="H1121"\w* \w secreto|strong="H6845"\w* \w de|strong="H5048"\w* tu rostro \w de|strong="H5048"\w* las arrogancias del \w hombre|strong="H1121"\w*: \w los|strong="H1121"\w* pondrás en un taber­náculo \w a|strong="H3068"\w* cubierto \w de|strong="H5048"\w* contención \w de|strong="H5048"\w* lenguas.
\m 
\v 21 Bendito el SEÑOR, \w porque|strong="H6440"\w* ha hecho maravillosa su miseri­cordia para conmigo en ciudad fuerte.
\m 
\v 22 \w Y|strong="H3068"\w* decía \w yo|strong="H3588"\w* \w en|strong="H3588"\w* mi premura: Cortado soy \w de|strong="H3588"\w* delante \w de|strong="H3588"\w* tus ojos: sin embargo tú oíste \w la|strong="H3588"\w* voz \w de|strong="H3588"\w* mis ruegos, \w cuando|strong="H3588"\w* \w a|strong="H3068"\w* ti clamaba.
\m 
\v 23 Amad al SEÑOR todos voso­tros sus santos: \w a|strong="H3068"\w* los fieles guar­da el SEÑOR, y paga abundante­mente al que obra con soberbia.
\m 
\v 24 Esforzaos \w todos|strong="H3605"\w* vosotros \w los|strong="H5921"\w* \w que|strong="H5921"\w* esperáis \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*, \w y|strong="H5921"\w* tome vuestro corazón aliento.
\c 32
\d Salmo de David: Masquil.
\m 
\v 1 BIENAVENTURADO aquel cuyas transgresiones \add son\add* perdonadas, \add cuyos\add* \w pecados|strong="H6588"\w* son \w cubiertos|strong="H3680"\w*.
\m 
\v 2 Bienaventurado el hombre \w a|strong="H3068"\w* quien \w no|strong="H3808"\w* imputa el \w SEÑOR|strong="H3068"\w* la \w iniquidad|strong="H5771"\w*, y en cuyo \w espíritu|strong="H7307"\w* \w no|strong="H3808"\w* hay superchería.
\m 
\v 3 \w Mientras|strong="H3605"\w* \w callé|strong="H2790"\w*, \w envejeciéronse|strong="H1086"\w* mis \w huesos|strong="H6106"\w* \w en|strong="H3588"\w* mi gemir \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w*.
\m 
\v 4 \w Porque|strong="H3588"\w* \w de|strong="H5921"\w* \w día|strong="H3119"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w* \w se|strong="H5921"\w* \w agravó|strong="H3513"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w* tu \w mano|strong="H3027"\w*; \w volvió|strong="H2015"\w*­\w se|strong="H5921"\w* \w mi|strong="H5921"\w* verdor \w en|strong="H5921"\w* sequedades \w de|strong="H5921"\w* estío. \w Selah|strong="H5542"\w*.
\m 
\v 5 \w Mi|strong="H5921"\w* \w pecado|strong="H2403"\w* \w te|strong="H5921"\w* \w declaré|strong="H3045"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w encubrí|strong="H3680"\w* \w mi|strong="H5921"\w* \w iniquidad|strong="H5771"\w*. \w Confesaré|strong="H3034"\w*, dije, \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w mis|strong="H5375"\w* \w rebeliones|strong="H6588"\w* \w al|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*; \w y|strong="H5921"\w* tú \w perdonaste|strong="H5375"\w* \w la|strong="H5921"\w* mal­dad \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pecado|strong="H2403"\w*. \w Selah|strong="H5542"\w*.
\m 
\v 6 \w Por|strong="H5921"\w* \w esto|strong="H2063"\w* \w orará|strong="H6419"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w todo|strong="H3605"\w* \w santo|strong="H2623"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w tiempo|strong="H6256"\w* \w de|strong="H5921"\w* poder hallarte: cier­tamente \w en|strong="H5921"\w* \w la|strong="H5921"\w* inundación \w de|strong="H5921"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w* \w no|strong="H3808"\w* \w llegarán|strong="H5060"\w* \w éstas|strong="H2063"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*.
\m 
\v 7 Tú eres mi refugio; me preserva­rás de \w angustia|strong="H6862"\w*; con cánticos de liberación me rodearás. \w Selah|strong="H5542"\w*.
\m 
\v 8 \w Te|strong="H5869"\w* haré \w entender|strong="H7919"\w*, \w y|strong="H5921"\w* \w te|strong="H5869"\w* enseñaré \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w en|strong="H5921"\w* \w que|strong="H2098"\w* debes \w andar|strong="H3212"\w*: \w te|strong="H5869"\w* guiaré \w con|strong="H5921"\w* mis \w ojos|strong="H5869"\w*.
\m 
\v 9 \w No|strong="H1077"\w* \w seáis|strong="H1961"\w* \w como|strong="H1961"\w* el \w caballo|strong="H5483"\w*, \w o|strong="H3068"\w* \w como|strong="H1961"\w* el mulo, sin entendimien­to: con cabestro y con freno su boca ha de ser reprimida, \w para|strong="H1961"\w* \w que|strong="H1961"\w* \w no|strong="H1077"\w* lleguen \w a|strong="H3068"\w* ti.
\m 
\v 10 \w Muchos|strong="H7227"\w* \w dolores|strong="H4341"\w* para el \w impío|strong="H7563"\w*; \w mas|strong="H7227"\w* el que espera en el \w SEÑOR|strong="H3068"\w*, lo cercará \w misericordia|strong="H2617"\w*.
\m 
\v 11 \w Alegraos|strong="H8055"\w* en \w el|strong="H3605"\w* \w SEÑOR|strong="H3068"\w*, y gozaos, \w justos|strong="H6662"\w*: y \w cantad|strong="H7442"\w* \w todos|strong="H3605"\w* vosotros \w los|strong="H3605"\w* \w rectos|strong="H3477"\w* \w de|strong="H6662"\w* \w corazón|strong="H3820"\w*.
\c 33
\m 
\v 1 \w ALEGRAOS|strong="H7442"\w*, \w justos|strong="H6662"\w*, en el \w SEÑOR|strong="H3068"\w*: \w a|strong="H3068"\w* los \w rectos|strong="H3477"\w* es \w hermosa|strong="H5000"\w* la \w alabanza|strong="H8416"\w*.
\m 
\v 2 \w Celebrad|strong="H3034"\w* al \w SEÑOR|strong="H3068"\w* con \w arpa|strong="H3658"\w*: \w cantadle|strong="H2167"\w* con \w salterio|strong="H5035"\w* y decacor­dio.
\m 
\v 3 \w Cantadle|strong="H7891"\w* \w canción|strong="H7892"\w* \w nueva|strong="H2319"\w*: ha­cedlo \w bien|strong="H3190"\w* \w tañendo|strong="H5059"\w* con \w júbilo|strong="H8643"\w*.
\m 
\v 4 \w Porque|strong="H3588"\w* \w recta|strong="H3477"\w* \w es|strong="H3588"\w* \w la|strong="H3605"\w* \w palabra|strong="H1697"\w* del \w SEÑOR|strong="H3068"\w*, \w y|strong="H3588"\w* \w toda|strong="H3605"\w* \w su|strong="H3588"\w* \w obra|strong="H4639"\w* \w con|strong="H3588"\w* ver­dad \add hecha\add*.
\m 
\v 5 Él ama \w justicia|strong="H6666"\w* y \w juicio|strong="H4941"\w*: de la \w misericordia|strong="H2617"\w* del \w SEÑOR|strong="H3068"\w* está \w llena|strong="H4390"\w* la tierra.
\m 
