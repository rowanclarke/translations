\id JAS - Biblica® Open Kurdi Sorani Standard Version
\h یاقوب
\toc1 نامەی یاقوب
\toc2 یاقوب
\toc3 یاقوب
\mt1 نامەی یاقوب
\c 1
\p 
\v 1 لە یاقوبی بەندەی خودا و عیسای مەسیحی خاوەن شکۆوە،
\b
\p بۆ دوازدە هۆزەکە\f + \fr 1:1 \ft مەبەست لە دوازدە هۆزەکەی نەوەی ئیسرائیلە.‏\f* کە لەنێو نەتەوەکاندا پەرشوبڵاو بوونەتەوە:
\b
\p سڵاو.
\b
\s1 تاقیکردنەوە لە دەرەوە
\p 
\v 2 خوشکان و برایانم، بەوپەڕی خۆشیی دابنێن، کاتێک دەکەونە نێو جۆرەها تاقیکردنەوە و ناخۆشییەوە،
\v 3 چونکە دەزانن تاقیکردنەوەی باوەڕتان دانبەخۆداگرتن دروستدەکات.
\v 4 با دانبەخۆداگرتن کاری خۆی تەواو بکات، بۆ ئەوەی تەواو و پێگەیشتوو بن و کەموکوڕیتان لە هیچ شتێکدا نەبێت.
\v 5 ئەگەر یەکێکتان لە دانایی کەموکوڕی هەیە، با داوا لە خودا بکات، کە بە دڵفراوانی بە هەمووان دەبەخشێت و گلەییش ناکات، پێشی دەبەخشرێت.
\v 6 بەڵام با بە باوەڕەوە داوا بکات و گومان نەکات، چونکە ئەوەی گومان دەکات وەک شەپۆلی دەریا وایە، با دەیهێنێت و دەیبات.
\v 7 ئەو مرۆڤە با بیرنەکاتەوە کە شتێک لە مەسیحی باڵادەستەوە وەردەگرێت،
\v 8 چونکە مرۆڤی ڕاڕا، لە هیچ یەک لە ڕێگاکانی چەسپاو نییە.
\p 
\v 9 با برای پایەنزم شانازی بە بەرزییەکەیەوە بکات،
\v 10 دەوڵەمەندیش بە نزمییەکەی، چونکە وەک گوڵی گژوگیا لەناودەچێت.
\v 11 لەبەر ئەوەی ڕۆژ بە گەرمییە سووتێنەرەکەی هەڵدێت، گژوگیا وشک دەبێت و گوڵەکەی هەڵدەوەرێت و دیمەنی جوانی نامێنێت. بە هەمان شێوە، دەوڵەمەندیش کاتێک سەرقاڵە بە کارەکانییەوە لەناودەچێت.
\s1 تاقیکردنەوە
\p 
\v 12 خۆزگە دەخوازرێت بەوەی بەرگەی تاقیکردنەوە دەگرێت، چونکە کە سەلمێنرا تاجی ژیان وەردەگرێت، ئەوەی خودا بەڵێنی داوە بیدات بەوانەی خۆشیان دەوێت.
\p 
\v 13 کاتێک کەسێک تاقی دەکرێتەوە، با نەڵێت: «لەلایەن خوداوە تاقی دەکرێمەوە،» چونکە خودا لە کاری خراپەدا تاقی ناکرێتەوە، ئەویش کەس بەو شێوەیە تاقی ناکاتەوە.
\v 14 بەڵام هەرکەسێک بەو ئارەزووە خراپەی کە هەیەتی تاقی دەکرێتەوە، ئەگەر پێی ڕاکێشرا و هەڵخەڵەتا.
\v 15 کە ئارەزووی خراپ سک بکات گوناهی لێ دەبێت، گوناهیش کە گەشەی کرد مردن بەرهەم دێنێت.
\p 
\v 16 خوشک و برایانی خۆشەویستم، هەڵمەخەڵەتێن.
\v 17 هەموو بەخشینێکی چاک و بەهرەیەکی تەواو لەلایەن سەرەوەیە، لەلای باوکی ڕووناکییەکانەوە دێتە خوارەوە، ئەوەی ناگۆڕێت و سێبەری خولانەوەی نییە.
\v 18 خواستی لەسەر بوو کە بە وشەی ڕاستی لەدایک ببین\f + \fr 1:18 \ft بڕوانە \xt یۆحەنا 1‏:12‏-13.‏\xt*\ft ‏\f*، تاکو ببینە نۆبەرەی بەدیهێنراوانی.
\s1 گوێ بگرن و کاری پێ بکەن
\p 
\v 19 خوشک و برا خۆشەویستەکانم، ئەمەتان بیر نەچێت: با هەر مرۆڤێک لە گوێگرتندا خێرا بێت، لە قسەکردندا لەسەرخۆ بێت، لە تووڕەبووندا خاو بێت،
\v 20 چونکە تووڕەیی مرۆڤ ڕاستودروستی خودا ناهێنێتە کایەوە.
\v 21 کەواتە هەموو گڵاوی و گەشەکردنێکی بەدکاری دابکەنن، ئەو وشەیەی کە لە ئێوەدا چانراوە بە دڵنەرمییەوە وەریبگرن، ئەوەی دەتوانێت گیانتان ڕزگار بکات.
\p 
\v 22 تەنها گوێگری وشەی خودا مەبن، بەڵکو کاری پێ بکەن، ئەگینا خۆتان هەڵدەخەڵەتێنن،
\v 23 چونکە ئەگەر یەکێک گوێگری وشەی خودا بێت و کاری پێ نەکات، وەک یەکێک وایە لە ئاوێنەدا سەیری ڕوخساری خۆی بکات،
\v 24 ئینجا دوای ئەوەی سەیری خۆی دەکات و دەڕوات، یەکسەر لەبیری دەچێت چۆن بووە.
\v 25 بەڵام هەرکەسێک بە وردی سەرنجی ئەو شەریعەتە تەواوە بدات کە ئازادی دەبەخشێت، هەروەها بەردەوام کاری پێ بکات و ئەوەی دەبیستێت لەیادی نەکات بەڵکو کاری پێ بکات، ئەوا ئەمە لە کرداریدا بەرەکەتدارە.
\p 
\v 26 ئەوەی خۆی بە دیندار دابنێت و زمانی خۆی نەپارێزێت، ئەوا خۆی هەڵدەخەڵەتێنێت و دیندارییەکەی پووچە.
\v 27 ئایینی پاک و بێگەرد\f + \fr 1:27 \ft ئەم ڕێبازەی خودا دایناوە تاکو مرۆڤ لەڕێیەوە پەیوەندی پێوە بکات.‏\f* لەلای خودای باوک ئەمەیە: بەسەرکردنەوەی هەتیوان و بێوەژنان لە تەنگانەیاندا، هەروەها خۆی لە گڵاویی جیهان بپارێزێت.
\c 2
\s1 بە جیاوازی هەڵسوکەوت مەکەن
\p 
\v 1 ئەی خوشکان و برایانم، ئێمەی باوەڕداران بە عیسای مەسیحی خاوەن شکۆمان، نابێت جیاکاری لەنێوان خەڵکی بکەین.
\v 2 ئەگەر پیاوێک هاتە ناو کۆڕەکەتان، ئەنگوستیلەی زێڕی لە پەنجە بوو و بەرگی نایاب بوو، هەروەها هەژارێکیش بە بەرگی پیس،
\v 3 تەماشای بەرگە نایابەکەتان کرد و گوتتان: «لێرە دانیشە باشە،» بە هەژارەکەش بڵێن: «لەوێ ڕابوەستە» یان «لەبەرپێم دانیشە،»
\v 4 ئایا لەنێوان خۆتاندا جیاکاری ناکەن و بە بیری خراپ حوکم بەسەر یەکدا نادەن؟
\p 
\v 5 خوشک و برا خۆشەویستەکانم، گوێ بگرن: ئایا خودا هەژارانی ئەم جیهانەی هەڵنەبژاردووە تاکو لە باوەڕ دەوڵەمەند بن و میراتگری شانشین بن، کە بەڵێنی داوە بیدات بەوانەی خۆشیان دەوێت؟
\v 6 بەڵام ئێوە سووکایەتیتان بە هەژارەکە کرد. ئایا دەوڵەمەندەکان نین خۆیان بەسەرتاندا دەسەپێنن و ڕاپێچی دادگاکانتان دەکەن؟
\v 7 ئایا ئەوان نین کفر بەو ناوە چاکە دەکەن کە پێی بانگکراون؟
\p 
\v 8 ئەگەر بەڕاستی شەریعەتی شاهانەتان هێناوەتە دی کە بەگوێرەی نووسراوە پیرۆزەکە دەڵێ: ﴿نزیکەکەت وەک خۆت خۆشبوێت،﴾\f + \fr 2:8 \ft \xt لێڤییەکان 19‏:18‏\xt*\ft ‏\f* چاک دەکەن.
\v 9 بەڵام ئەگەر جیاکاری بکەن، ئەوا گوناه دەکەن و وەک سەرپێچیکار لەلایەن شەریعەتەوە سەرزەنشت دەکرێن،
\v 10 چونکە ئەوەی هەموو شەریعەت بەجێبهێنێت، بەڵام تەنها بەندێکی بشکێنێت، ئەوا لە هەمووی تاوانبارە.
\v 11 ئەوەی فەرموویەتی: ﴿داوێنپیسی مەکە،﴾\f + \fr 2:11 \ft \xt دەرچوون 20‏:14 و دواوتار 5‏:18‏\xt*\ft ‏\f* هەروەها فەرمووشیەتی: ﴿مەکوژە.﴾\f + \fr 2:11 \ft \xt دەرچوون 20‏:13 و دواوتار 5‏:17‏\xt*\ft ‏\f* ئەگەر داوێنپیسیت نەکرد بەڵام یەکێکت کوشت، ئەوا سەرپێچی شەریعەتت کردووە.
\p 
\v 12 ئاوا بدوێن و ئاوا کار بکەن، وەک ئەوەی بە شەریعەتی ئازادی حوکم بدرێن،
\v 13 چونکە حوکمدان بێ بەزەییانەیە بۆ ئەو کەسەی کە بێ بەزەیی بووە، بەڵام بەزەیی بەسەر حوکمداندا سەردەکەوێت.
\s1 باوەڕ و کردار
\p 
\v 14 خوشکان و برایانم، چ سوودێکی هەیە ئەگەر یەکێک بڵێت باوەڕم هەیە، بەڵام کرداری نەبێت؟ ئایا ئەم جۆرە باوەڕە دەتوانێت ڕزگاری بکات؟
\v 15 ئەگەر خوشک یان برایەک پێویستی بە جلوبەرگ و خواردنی ڕۆژانە هەبوو،
\v 16 یەکێکتان پێتان گوتن: «بەخێر بچن، جلی گەرم لەبەر بکەن، تێر بخۆن،» و پێداویستییەکانی ژیانیان نەدەنێ، چ سوودێکی هەیە؟
\v 17 بەم شێوەیەش، باوەڕ ئەگەر کرداری نەبێت، لە خۆیدا مردووە.
\p 
\v 18 لەوانەیە کەسێک بڵێ: «تۆ باوەڕت هەیە و من ‏کردار.»
\p نیشانم بدە باوەڕت چۆن بێ کردار دەبێت، ئەوسا منیش بە کردارەکانم نیشانت دەدەم باوەڕم چۆنە‏.
\v 19 تۆ باوەڕت هەیە کە یەک خودا هەیە، چاک دەکەیت. تەنانەت ڕۆحە پیسەکانیش باوەڕ دەکەن و دەلەرزن.
\p 
\v 20 ئەی مرۆڤی گێل، دەتەوێت بزانیت کە باوەڕ بێ کردار نەزۆکە؟
\v 21 ئایا ئیبراهیمی باوکمان بە کردار بێتاوان نەکرا، کاتێک لەسەر قوربانگا ئیسحاقی کوڕی پێشکەش کرد؟
\v 22 دەبینیت باوەڕ بە کردارەکەی لە کاردا بوو، باوەڕەکەش بە کردار تەواو بوو.
\v 23 نووسراوە پیرۆزەکەش هاتە دی کە دەفەرموێ: ﴿ئیبراهیم باوەڕی بە خودا هێنا و ئەمەشی بە ڕاستودروستی بۆ دانرا،﴾\f + \fr 2:23 \ft \xt پەیدابوون 15‏:6‏\xt*\ft ‏\f* هەروەها ناوی لێنرا دۆستی خودا.
\v 24 دەبینن کە مرۆڤ بە کردار بێتاوان دەبێت نەک تەنها بە باوەڕ.
\p 
\v 25 بەم شێوەیە ڕاحابی لەشفرۆش، ئایا بە کردار بێتاوان نەبوو، کە پێشوازی لە سیخوڕەکان\f + \fr 2:25 \ft یۆنانی: نێردراوەکان.‏\f* کرد و بە ڕێگایەکی دیکەدا بەڕێی کردن؟\f + \fr 2:25 \ft بڕوانە \xt یەشوع 2‏:4‏-15.‏\xt*\ft ‏\f*
\v 26 هەروەک چۆن جەستە بێ ڕۆح مردووە، باوەڕیش بێ کردار مردووە.
\c 3
\s1 خراپیی زمان
\p 
\v 1 خوشکان و برایانم، زۆرتان مەبنە فێرکار، بزانن لێپرسینەوەی قورسترمان لەگەڵ دەکرێت.
\v 2 هەموومان لە زۆر شت هەڵە دەکەین. ئەگەر یەکێک هەیە لە قسەکردندا هەڵە ناکات، ئەوە مرۆڤێکی تەواوە و دەتوانێت جڵەوی هەموو جەستەی بگرێتە دەست.
\p 
\v 3 ئێمە لغاو دەکەینە دەمی ئەسپ تاکو گوێڕایەڵمان بێت و هەموو لەشی ئاراستە بکەین.
\v 4 سەیری کەشتی بکەن، هەرچەندە گەورەیە و بای بەهێز دەیبات، کەچی بە سەوڵێکی بچووک بۆ هەر لایەک کەشتیوان بیەوێت ئاراستەی دەکات.
\v 5 بە هەمان شێوە زمانیش ئەندامێکی بچووکە، بەڵام شانازی بە لەخۆباییبوونەوە دەکات. ئاگرێکی بچووک چ دارستانێکی گەورە دەسووتێنێ.
\v 6 زمان ئاگرە، جیهانێکە لە خراپە لەنێو ئەندامانی لەشمان. زمان هەموو لەش گڵاو دەکات، ئاگر لە ژیان بەردەدات و خۆی بە گڕی دۆزەخ دادەگیرسێت.
\p 
\v 7 مرۆڤ دەتوانێت هەموو جۆرە ئاژەڵێکی کێوی و باڵندە و خشۆک و بوونەوەرێکی ئاوی دەستەمۆ بکات و کردووشیەتی،
\v 8 بەڵام کەس ناتوانێت زمان دەستەمۆ بکات. خراپەیەکە ناگیرێت، پڕە لە ژەهری کوشندە.
\p 
\v 9 بە زمان ستایشی یەزدان و خودای باوک دەکەین، هەر بە هەمان زمانیش نەفرەت لەو خەڵکە دەکەین کە لە شێوەی خودا دروستکراون.
\v 10 ستایش و نەفرەت لە هەمان دەم دێتە دەرەوە. خوشکان و برایانم، ئەمە پەسەند نییە.
\v 11 ئایا لە یەک کانیدا ئاوی سازگار و ئاوی سوێر هەڵدەقوڵێت؟
\v 12 خوشکان و برایانم، ئایا دار هەنجیر زەیتوون دەگرێت، یان مێو هەنجیر؟ بەم شێوەیەش کانی سوێر ئاوی سازگار نادات.
\s1 دانایی خودایی
\p 
\v 13 کێ لەنێوتاندا دانا و تێگەیشتووە؟ با بە ڕەوشتی باشی نیشانی بدات، هەروەها بەو کارانەی کە بە بێفیزییەوە ئەنجامی دەدات و لە داناییەوە سەرچاوە دەگرێت.
\v 14 بەڵام ئەگەر چاوپیسی تاڵ و خۆپەرستیتان لە دڵدا بوو، شانازی مەکەن یان نکۆڵی لە ڕاستی مەکەن.
\v 15 ئەم داناییە لە ئاسمانەوە دانەبەزیوە، بەڵکو دنیایی و مرۆڤانە و شەیتانییە،
\v 16 چونکە چاوپیسی و خۆپەرستی لەکوێ بێت، گێرەشێوێنی و هەموو کارێکی خراپ لەوێیە.
\p 
\v 17 بەڵام ئەو داناییەی لە ئاسمانەوەیە، لەپێش هەموو شتێک پاکە، دواتر ئاشتیخوازە، خۆنەویستە، گوێڕایەڵە، پڕ لە بەزەییە و بەروبوومی چاکە، لایەنگر و دووڕوو نییە.
\v 18 ئاشتیسازان تۆوی ئاشتی دەچێنن و بەرهەمەکەی ڕاستودروستی دەبێت.
\c 4
\s1 ملکەچی خودا بن
\p 
\v 1 هۆکاری سەرهەڵدانی ئەم شەڕ و ناکۆکییەی نێوانتان چییە؟ ئایا بەهۆی ئارەزووە خراپەکانتانەوە نییە کە لە ئەندامەکانی لەشتاندا دەجەنگن.
\v 2 ئارەزوو دەکەن و نیتانە، هەر بۆیە دەکوژن. ئیرەیی دەبەن و ناتوانن دەستتان بکەوێت، هەر بۆیە ناکۆکی دەکەن و شەڕ دەکەن. نیتانە، چونکە لە خودا داوا ناکەن.
\v 3 کاتێک داوا دەکەن وەریناگرن، چونکە بە پاڵنەری خراپ داوا دەکەن، تاکو ئارەزووەکانتانی پێ تێر بکەن.
\p 
\v 4 ئەی داوێنپیسان، نازانن دۆستایەتی جیهان دوژمنایەتی خودایە؟ بۆیە ئەوەی بیەوێت ببێتە دۆستی جیهان، ئەوا بووەتە دوژمنی خودا.
\v 5 یاخود وا دەزانن نووسراوە پیرۆزەکە لەخۆڕا دەفەرموێ، خودا بە دڵگەرمی پەرۆشە بەو ڕۆحەی کە تیاماندا نیشتەجێی کردووە؟
\v 6 بەڵام نیعمەتی\f + \fr 4:6 \ft نیعمەت بەخشینێکی خودایە بە مرۆڤ بەبێ شایستەبوونی پێی دەبەخشێت.\f* زیاتر دەدات، بۆیە نووسراوە پیرۆزەکە دەفەرموێت:
\q1 ﴿خودا بەرهەڵستی لووتبەرزەکان دەکات،
\q2 بەڵام نیعمەت دەداتە بێفیزەکان.﴾\f + \fr 4:6 \ft \xt پەندەکان 3‏:34‏\xt*\ft ‏\f*
\p 
\v 7 بۆیە ملکەچی خودا بن. بەرهەڵستی شەیتان بکەن، لێتان هەڵدێت.
\v 8 لە خودا نزیک بنەوە، لێتان نزیک دەبێتەوە. دەستتان خاوێن بکەنەوە ئەی گوناهباران، دڵتان پاک بکەنەوە ئەی ڕاڕایەکان.
\v 9 خەفەت بخۆن و بگریێن و شیوەن بکەن. پێکەنینتان بگۆڕن بۆ گریان و خۆشی بۆ خەفەت.
\v 10 لەبەردەم پەروەردگاردا بێفیز بن، ئەویش بەرزتان دەکاتەوە.
\p 
\v 11 خوشکان، برایان، بە خراپە باسی یەکتری مەکەن. ئەوەی بە خراپە باسی خوشک یان براکەی بکات یاخود حوکمیان بدات، ئەوا بە خراپە باسی تەورات دەکات و تەورات حوکم دەدات. ئەگەر تەورات حوکم بدەیت، ئەوا تۆ کار بە تەورات ناکەیت، بەڵکو خۆت دەکەیت بە دادوەر بەسەرییەوە.
\v 12 تەنها یەک شەریعەتدانەر و دادوەر هەیە، ئەو دەتوانێت ڕزگار بکات و لەناوببات. بەڵام تۆ کێی تاکو نزیکەکەت حوکم بدەیت؟
\s1 پشتبەستن بە خودا
\p 
\v 13 وەرن ئەوانەی دەڵێن: «ئەمڕۆ یان بەیانی دەڕۆین بۆ فڵان شار، ساڵێک لەوێ دەبین و کاسبی دەکەین و قازانج دەکەین.»
\v 14 ئێوە کە نازانن بەیانی چی دەبێت، ژیانتان چییە؟ چونکە هەڵمێکە، ماوەیەک دەردەکەوێت، دواتر نامێنێت.
\v 15 لە جیاتی ئەوە بڵێن: «ئەگەر مەسیحی باڵادەست خواستی لەسەر بوو و ژیاین، ئەمە و ئەوە دەکەین.»
\v 16 بەڵام ئێوە شانازی بە لووتبەرزیتانەوە دەکەن، هەموو شانازییەکی ئاواش خراپە.
\v 17 بۆیە ئەوەی بزانێت چاکە بکات و نەیکات، گوناه دەکات.
\c 5
\s1 ئاگادارکردنەوەی دەوڵەمەندەکان
\p 
\v 1 وەرن ئەی دەوڵەمەندەکان، بگریێن و شیوەن بکەن بۆ ئەو دەردەسەرییەی بەسەرتان دێت.
\v 2 سامانتان بۆگەن بووە و بەرگتان مۆرانە لێیداوە،
\v 3 زێڕ و زیوتان دادەخورێت، داخورانەکەشیان شایەتیتان لەسەر دەدات و وەک ئاگر جەستەتان دەخوات. لە ڕۆژانی کۆتایی گەنجینەتان بۆ خۆتان کۆکردەوە.
\v 4 ئەوەتا ئەو کرێیەی کە نەتانداوە بەو کرێکارانەی کە لە کێڵگەکانی ئێوە کاریان کردووە، لە دژی ئێوە هاوار دەکات. هاواری سەپانەکانیش گەیشتە گوێی یەزدانی سوپاسالار.
\v 5 لەسەر زەوی خۆشتان ڕابواردووە و بە شوێن ئارەزووەکانی جەستەتان کەوتوون، دڵی خۆتان وەک دابەستە بۆ ڕۆژی سەربڕین ڕاگرتووە.
\v 6 بێتاوانەکەتان حوکم دا و کوشتتان، کە بەرهەڵستی ئێوەی نەدەکرد.
\s1 دانبەخۆداگرتن لە ئازار
\p 
\v 7 بۆیە خوشکان و برایانم، هەتا هاتنەوەی مەسیحی خاوەن شکۆ ئارام بگرن. تەماشا بکەن چۆن جوتیار چاوەڕێی بەرهەمە بەهادارەکەی زەوی دەکات، بۆ بارانی پاییز و بەهار ئارام دەگرێت.
\v 8 ئێوەش ئارام بگرن و ورەتان بەرز بێت، چونکە هاتنەوەی مەسیحی خاوەن شکۆ نزیک بووەتەوە.
\v 9 خوشکان، برایان، بۆڵەبۆڵ لەسەر یەکتری مەکەن، نەوەک حوکم بدرێن. ئەوەتا دادوەر لە بەردەرگا ڕاوەستاوە.
\p 
\v 10 خوشکان، برایان، نموونە وەربگرن لە بەرگەی ئازار و ئارامگرتنی ئەو پێغەمبەرانەی کە بە ناوی یەزدانەوە قسەیان کرد.
\v 11 وا ئێمە ئەوانە بە بەختەوەر دەزانین کە دانیان بەخۆیاندا گرتووە. دانبەخۆداگرتنی ئەیوبتان بیستووە کە لە ئەنجامدا یەزدان چۆن بەرەکەتداری کرد،\f + \fr 5:11 \ft بڕوانە \xt ئەیوب 42‏:10‏-17.‏\xt*\ft ‏\f* چونکە یەزدان بەزەیی زۆرە و میهرەبانە.
\p 
\v 12 خوشکان و برایانم، پێش هەموو شتێک، سوێند مەخۆن، نە بە ئاسمان و نە بە زەوی و نە بە شتی دیکە. بەڵکو با قسەتان «بەڵێ» بۆ «بەڵێ» و «نەخێر» بۆ «نەخێر» بێت، نەوەک تاوانبار بکرێن.
\s1 نوێژ بە باوەڕەوە
\p 
\v 13 کامەتان ناخۆشی هەیە؟ با نوێژ بکات. کەس دڵخۆشە؟ با بە گۆرانی ستایش بکات.
\v 14 کامەتان نەخۆشە؟ با پیرانی کڵێسا بانگ بکات بۆ ئەوەی نوێژی لەسەر بکەن و بە ناوی عیسای خاوەن شکۆوە چەوری بکەن\f + \fr 5:14 \ft بڕوانە \xt مەرقۆس 6‏:13‏\xt*\ft ‏\f*.
\v 15 ئەو نوێژەی بە باوەڕ دەکرێت نەخۆش چاک دەکاتەوە و عیسای خاوەن شکۆ هەڵیدەستێنێتەوە. ئەگەر گوناهێکیشی کردبێت دەبەخشرێت.
\v 16 بۆیە بۆ یەکتری دان بە گوناهەکانتاندا بنێن، نوێژ بۆ یەکتری بکەن تاکو چاکببنەوە. نوێژی کەسی ڕاستودروست زۆر بەهێز و کاریگەرە.
\p 
\v 17 ئەلیاس مرۆڤێک بوو وەک ئێمە لە هەمان سروشت، بە گەرمی نوێژی کرد تاکو باران نەبارێت، ئیتر سێ ساڵ و نیو لەسەر خاکەکەیان باران نەباری.
\v 18 نوێژی کردەوە، ئاسمان بارانی دا و زەویش بەرهەمی دا.
\p 
\v 19 خوشکان و برایانم، ئەگەر یەکێکتان لە ڕاستی چەواشە کرا و یەکێک گەڕاندییەوە،
\v 20 با بزانێت ئەوەی گوناهبارێک لە ڕێگای گومڕایی بگەڕێنێتەوە، دەروونێک لە مردن ڕزگار دەکات و زۆر گوناهیش دادەپۆشێت.
