\id LAM - Biblica® Open Igbo Contemporary Bible 2020
\h Abụ Akwa
\toc1 Abụ Akwa
\toc2 Abụ Akwa
\toc3 Akw
\mt1 Abụ Akwa
\c 1
\q1 
\v 1 Lee ka obodo ahụ nke ndị ya dị ọtụtụ
\q2 si bụrụ ebe tọgbọrọ nʼefu!
\q1 Lee ka o si ghọọ nwanyị di ya nwụrụ,
\q2 bụ obodo ahụ a maara aha ya nʼetiti mba niile.
\q1 Lee ka onye naara abụ eze nwanyị nʼetiti ala niile a na-achị achị
\q2 si ghọọ ohu.
\b
\q1 
\v 2 Ọ na-akwasị akwa ike nʼabalị,
\q2 anya mmiri na-asọdakwa na nti ya,
\q1 nʼetiti ndị ahụ niile hụrụ ya nʼanya,
\q2 ọ dịghị onye na-akasị ya obi.
\q1 Ndị enyi ya niile aghọgbuola ya;
\q2 ha niile aghọọla ndị iro ya.
\b
\q1 
\v 3 Juda ejeela biri nʼala ọzọ,
\q2 mgbe o siri nʼọnọdụ mweda nʼala na ndọgbu nʼọrụ pụta.
\q1 Ọ na-ebi nʼetiti mba dị iche iche,
\q2 ma ọ chọtaghị ebe izuike ọbụla.
\q1 Nʼetiti nhụju anya ya
\q2 ndị niile na-achụ ya ọsọ achụkwutela ya.
\b
\q1 
\v 4 Okporoụzọ niile e si eje Zayọn na-eru ụjụ,
\q2 nʼihi na ọ dịghị onye na-abịakwa na mmemme ndị ahụ a kara aka.
\q1 Ọnụ ụzọ ama ya niile atọgbọrọla nʼefu,
\q2 ndị nchụaja ya na-asụ ude,
\q1 ụmụ agbọghọ nọ nʼọnọdụ mwute,
\q2 ya onwe ya nọkwa nʼọnọdụ dị ilu.
\b
\q1 
\v 5 Ndị iro ya aghọọla ndị na-achị ya;
\q2 ndị iro ya nọ nʼahụ udo.
\q1 Nʼihi na \nd Onyenwe anyị\nd* emekpaala ya ahụ,
\q2 nʼihi ịba ụba nke njehie ya niile.
\q1 E burula ụmụntakịrị ya bulaa mba ọzọ,
\q2 dịka ndị a dọtara nʼagha.
\b
\q1 
\v 6 Ịma mma niile
\q2 esitela nʼahụ ada Zayọn pụọ.
\q1 Ụmụ eze ya dị ka ele
\q2 nke na-enweghị ike ịchọta ebe ịta nri.
\q1 Nʼihi adịghị ike ha,
\q2 ha esitela nʼihu ndị na-achụ ha ọsọ gbalaga.
\b
\q1 
\v 7 Nʼụbọchị ndị ahụ niile e wedara ya nʼala,
\q2 Jerusalem echetala akụ ndị ahụ niile bụ nke ya na mgbe ochie.
\q2 Jerusalem echetala ha nʼụbọchị ndị ahụ niile ọ na-awagharị.
\q1 Mgbe ndị ya dabara nʼaka ndị iro ya,
\q2 o nweghị onye inyeaka ha hụrụ.
\q1 Nʼoge ahụ, ndị iro ya hụrụ ọnọdụ
\q2 ya, chịa ya ọchị.
\b
\q1 
\v 8 Jerusalem emehiela nke ukwu,
\q2 nʼezie, ọ ghọọla ihe rụrụ arụ.
\q1 Ndị ahụ niile na-asọpụrụ ya na mbụ elelịala ya anya,
\q2 nʼihi na ha ahụla ọtọ ya.
\q1 Ya onwe ya kwa na-asụ ude,
\q2 ma chigharịakwa azụ.
\b
\q1 
\v 9 Ịrụ arụ ya pụtara ihe, ọ bụladị nʼuwe ya.
\q2 Ọ dịkwaghị mgbe o chere echiche banyere ihe dị na-eche ya nʼoge dị nʼihu.
\q1 Lee ka o si daa, dasie ike,
\q2 ma ọ dịghị onye bịara kasịe ya obi.
\q1 “\nd Onyenwe anyị\nd*, lee nsogbu m niile.
\q2 Lee ka ndị iro si merie m.”
\b
\q1 
\v 10 Onye iro agbasaala aka ya
\q2 chịkọtaa akụ ya niile.
\q1 O ji anya ya hụ ka mba ndị ọzọ dị iche iche
\q2 si bata ebe nsọ ya.
\q1 Ndị ahụ na-ekwesighị ịbata
\q2 bụ ndị batara nʼebe nzukọ gị.
\b
\q1 
\v 11 Ndị ya niile na-asụ ude
\q2 mgbe ha na-achọ ihe ha ga-eri.
\q1 Ha na-ewere ihe ha nwere nye nʼihi oriri,
\q2 ime ka ha nwee ike dịrị ndụ.
\q1 “\nd Onyenwe anyị\nd*, lee, ma tuleekwa ihe ndị a niile,
\q2 nʼihi na abụrụla m onye a na-elelị.”
\b
\q1 
\v 12 “Ọ bụ na ọ dịghị emetụ unu nʼobi, unu ndị niile na-esi ebe a na-agafe?
\q2 Legharịanụ anya unu ka unu hụrụ.
\q1 O nwere ahụhụ dịka ahụhụ m,
\q2 nke e mere ka ọ bịakwasị m,
\q1 bụ nke \nd Onyenwe anyị\nd* mere ka ọ bịakwasị m,
\q2 nʼụbọchị ọ na-ewe iwe ya dị ọkụ?
\b
\q1 
\v 13 “O si nʼelu zite ọkụ,
\q2 e, o zitere ọkụ nke na-ere nʼime ọkpụkpụ m.
\q1 Ọ gbasara ụgbụ nʼebe ụkwụ m ga-esi gafee,
\q2 meekwa ka m laghachi azụ.
\q1 O mere ka m bụrụ ihe tọgbọrọ nʼefu,
\q2 onye na-ada mba ogologo ụbọchị niile.
\b
\q1 
\v 14 “Ọ na-eleru anya na mmehie m niile;\f + \fr 1:14 \ft Maọbụ, \fqa ọ kpaala mmehie m niile dịka agbụ yoku\f*
\q2 jiri aka ya na-akpa ha dịka ụdọ.
\q1 A nyakwasịla ya nʼolu m.
\q2 Onyenwe anyị emeela ka ike gwụsịa m.
\q1 O werela m nyefee nʼaka ndị ahụ
\q2 m na-apụghị iguzogide.
\b
\q1 
\v 15 “Onyenwe anyị ajụla
\q2 ndị niile bụ dike nʼagha nọ nʼetiti m.
\q1 Ọ kpọkuola usuu ndị agha ka ha bịa buo agha megide m,
\q2 ka ha bịa gwepịa ụmụ okorobịa m niile.
\q1 Nʼebe ịzọcha mkpụrụ vaịnị ya
\q2 ka Onyenwe anyị zọchara ada Juda na-amaghị nwoke.
\b
\q1 
\v 16 “Ọ bụ nke a mere m ji akwa akwa.
\q2 Ọ bụ ya mekwara anya mmiri ji ju m anya.
\q1 O nweghị onye nkasiobi ọbụla nọ m nso;
\q2 o nwekwaghị onye ga-akpọghachi mkpụrụobi m.
\q1 Ụmụ m atọgbọla nʼefu,
\q2 nʼihi na onye iro emeriela.”
\b
\q1 
\v 17 Lee ka Zayọn si gbasapụ aka ya
\q2 ma o nweghị onye nkasiobi o nwere.
\q1 \nd Onyenwe anyị\nd* enyela iwu banyere Jekọb
\q2 na ndị agbataobi ya ga-aghọ ndị iro ya.
\q1 Jerusalem aghọkwaala
\q2 ihe rụrụ arụ nʼetiti ha.
\b
\q1 
\v 18 “Ma \nd Onyenwe anyị\nd* bụ onye ezi omume.
\q2 Ọ bụ mụ onwe m nupuru isi nʼiwu ya.
\q1 Geenụ ntị unu ndị niile,
\q2 leenụ anya nʼụdị ahụhụ dakwasịrị m.
\q1 A dọtala ụmụ okorobịa na ụmụ agbọghọbịa m niile nʼagha
\q2 buru ha jee mba ọzọ.
\b
\q1 
\v 19 “Akpọkuru m ndị mụ na ha dị na mma,
\q2 ma ha ghọgburu m.
\q1 Ndị nchụaja m na ndị okenye m
\q2 nwụrụ nʼime obodo
\q1 mgbe ha nọ na-achọta nri
\q2 ha ga-eji debe onwe ha ndụ.
\b
\q1 
\v 20 “Lee, \nd Onyenwe anyị\nd*, ka m si bụrụ onye ahụhụ dị ukwuu dakwasịrị.
\q2 Ime anụ ahụ m na-anụ ọkụ,
\q1 obi m kwa enweghị izuike nʼime m
\q2 nʼihi na onye nnupu isi dị ukwuu ka m bụ.
\q1 Nʼezi, ọ bụ mma agha ka a ga-eji mee ka mmadụ gbara aka nwa.
\q2 Ma nʼime ụlọ, ọ bụ naanị ọnwụ dị ya.
\b
\q1 
\v 21 “Ndị mmadụ anụla olu ịsụ ude m,
\q2 ma o nweghị onye bịara ịkasị m obi.
\q1 Ndị iro m niile anụla akụkọ ihe ọjọọ dakwasịrị m,
\q2 ma ha na-aṅụrịkwa ọṅụ nʼihi ihe i mere ka ọ bịakwasị m.
\q1 Mee ka ụbọchị ahụ i kara aka bịa,
\q2 nke ga-eme ka ha dịrị ka m dị.
\b
\q1 
\v 22 “Kwere ka ihe ọjọọ niile ha na-eme bịa nʼihu gị.
\q2 Mesokwa ha mmeso
\q1 dịka i si mesoo m
\q2 nʼihi mmehie niile nke m.
\q1 Nʼihi na ịsụ ude m dị ọtụtụ,
\q2 ana m adakwa mba nʼobi m.”
\b
\b
\c 2
\q1 
\v 1 Lee ka Onyenwe anyị si jiri igwe ojii nke iwe ya
\q2 kpuchie ada Zayọn!
\q1 O sitela nʼeluigwe
\q2 tụda ịma mma Izrel nʼala,
\q1 o chetakwaghị ebe mgbakwasị ụkwụ ya,
\q2 nʼụbọchị iwe ya.
\b
\q1 
\v 2 Onyenwe anyị elodala ebe obibi niile nke Jekọb;
\q2 na-enweghịkwa ọmịiko nʼebe ọ nọ.
\q1 O sitela nʼoke iwe ya
\q2 dọdasịa ebe niile e wusiri ike nke ada Juda.
\q1 Ọ wedala alaeze ya na ndị ụmụ eze ya nʼala,
\q2 mee ka ha gharakwa ị nwee nsọpụrụ.
\b
\q1 
\v 3 O sitela nʼoke iwe ya
\q2 bipụ ike niile Izrel nwere.
\q1 O seghachiri aka nri ya,
\q2 mgbe ndị iro ha na-abịa nso.
\q1 O nwukwara dịka ọkụ na-enwusi ike nʼetiti Jekọb;
\q2 si otu a rechapụ ihe niile dị gburugburu ya.
\b
\q1 
\v 4 O kweela ụta ya, jide ya nʼaka nri ya,
\q2 dịka onye iro.
\q1 Dịka onye iro kwa
\q2 o gbuola ndị ahụ niile mara mma ile anya;
\q1 ọ wụpụla iwe ya, dịka ọ bụ ọkụ,
\q2 nʼelu ụlọ ada Zayọn.
\b
\q1 
\v 5 Onyenwe anyị dị ka onye iro,
\q2 o lomichaala Izrel.
\q1 O lomichaala ụlọeze ya niile,
\q2 bibiekwa ebe ya niile e wusiri ike.
\q1 O meela ka iru ụjụ na ịkwa akwa
\q2 mụbaara ada Juda.
\b
\q1 
\v 6 O meela ka ebe obibi ya tọgbọrọ nʼefu, dịka ubi a gbara ogige;
\q2 o bibiela ebe nzukọ ya niile.
\q1 \nd Onyenwe anyị\nd* emeela ka Zayọn chezọọ
\q2 ime mmemme ya a kara aka, na idebe ụbọchị izuike ọbụla nsọ.
\q1 Site nʼoke iwe ya,
\q2 ọ jụla eze na onye nchụaja.
\b
\q1 
\v 7 Onyenwe anyị ajụla ebe ịchụ aja ya
\q2 gbakụta ebe nsọ ya azụ.
\q1 O werela mgbidi niile nke ụlọeze ya
\q2 nyefee nʼaka onye iro;
\q1 ha emeela ka olu ha daa ụda nʼime ụlọ \nd Onyenwe anyị\nd*
\q2 dịka nʼụbọchị mmemme a kara aka.
\b
\q1 
\v 8 \nd Onyenwe anyị\nd* ekpebiela ibibi
\q2 mgbidi gbara ada Zayọn gburugburu.
\q1 O setịpụrụ ihe ọtụtụ;
\q2 o sepụkwaghị aka ya na ibibi ya.
\q1 O mere ka mkputamkpu aja na mgbidi ruo ụjụ,
\q2 meekwa ka ha richapụsịa.
\b
\q1 
\v 9 Ọnụ ụzọ ama ya niile emikpuola nʼala;
\q2 ọ gbajiela mkpọrọ niile e ji akpọchi ha, laakwa ha nʼiyi.
\q1 A dọtala eze ya na ụmụ eze ya nʼagha, buru ha jee mba ọzọ.
\q2 Iwu adịghịkwa,
\q1 otu a, ndị amụma ya enwekwaghị ike ịhụ ọhụ
\q2 site nʼebe \nd Onyenwe anyị\nd* nọ.
\b
\q1 
\v 10 Ndị okenye ada Zayọn
\q2 nọ ọdụ nʼala, dere duu.
\q1 Ha ekpokwasịla aja nʼisi ha;
\q2 ha eyikwasịkwala onwe ha uwe mkpe.
\q1 Ụmụ agbọghọ Jerusalem na-amaghị nwoke
\q2 ehulatala isi ha nʼala.
\b
\q1 
\v 11 Ike agwụla anya m nʼihi ịkwa akwa,
\q2 ime ime ahụ m na-anụ ọkụ.
\q1 Obi m dị ka ihe a wụpụrụ nʼala,
\q2 nʼihi na e bibiela ndị m,
\q1 nʼihi na ụmụntakịrị na ụmụ a mụrụ ọhụrụ na-ada mba
\q2 nʼokporoụzọ nke obodo.
\b
\q1 
\v 12 Ha na-ebere nne ha akwa na-asị,
\q2 “Olee ebe ọka na mmanya dị?”\f + \fr 2:12 \ft Achịcha na ihe ọṅụṅụ dị\f*
\q1 Mgbe ha na-ada mba dịka ndị e merụrụ ahụ
\q2 nʼokporoụzọ obodo,
\q1 mgbe ọnwụ ji nwayọọ na-eripịasị ndụ ha
\q2 nʼaka nne ha ku ha.
\b
\q1 
\v 13 Gịnị ka m nwere ike ikwu banyere gị?
\q2 Gịnị ka m ga-eji tụnyere gị,
\q2 gị ada Jerusalem?
\q1 Gịnị ka m ga-asị na i yiri,
\q2 nke ga-enyere m aka ịmata otu m ga-esi kasịe gị obi,
\q2 gị ada Zayọn na-amaghị nwoke?
\q1 Ọnya dị gị nʼahụ miri emi, dịka ịdị omimi nke osimiri.
\q2 Onye pụrụ ịgwọ gị?
\b
\q1 
\v 14 Ọhụ niile ndị amụma gị hụrụ
\q2 bụ ọhụ ụgha na ọhụ na-enweghị isi.
\q1 Ha ekpugheghị mmehie gị,
\q2 igbochi ndọta nʼagha nke a dọtara gị.
\q1 Kama ihe ha hụtaara gị
\q2 bụ ihe ụgha na nduhie.
\b
\q1 
\v 15 Ndị niile si nʼebe ị nọ
\q2 na-agafe na-akụrụ gị aka ha;
\q1 ha na-efufe isi ha,
\q2 jirikwa ada Jerusalem na-eme ihe ọchị.
\q1 Ha na-ajụ ajụjụ na-asị, “Nke a ọ bụ obodo ahụ
\q2 a na-akpọ ebe mabigara mma oke,
\q2 ọṅụ nke ụwa niile?”
\b
\q1 
\v 16 Ndị iro gị niile na-emeghepụ ọnụ ha
\q2 megide gị;
\q1 ha na-achị gị ọchị, na-atara gị ikekere eze.
\q2 Ha na-ekwu na-asị, “Anyị eloola ya.
\q1 Nke a bụ ụbọchị ahụ anyị na-ele anya ya.
\q2 Anyị adịrịla ndụ hụ ya.”
\b
\q1 
\v 17 \nd Onyenwe anyị\nd* emeela ihe o zubere ime.
\q2 O mezuola ihe o kwuru na ọ ghaghị ime
\q2 site nʼoge gara aga.
\q1 Ọ kwatuola gị, na-enweghị ọmịiko ọbụla.
\q2 O meela ka ndị iro gị ṅụrịa ọṅụ nʼahụ gị;
\q2 o meekwala ka e bulie ike nke ndị iro gị.
\b
\q1 
\v 18 Obi ndị mmadụ
\q2 na-etiku Onyenwe anyị.
\q1 Gị, mgbidi niile nke ada Zayọn,
\q2 ka anya mmiri gị na-asọpụta dịka osimiri
\q2 ehihie na abalị niile,
\q1 enyekwala onwe gị izuike,
\q2 enyekwala anya gị izuike.
\b
\q1 
\v 19 Bilie, kwaa akwa nʼabalị,
\q2 nʼoge mmalite nche abalị.
\q1 Wụpụta ihe dị gị nʼobi nʼihu Onyenwe anyị
\q2 dịka ọ bụ mmiri.
\q1 Welie aka unu elu nye Onyenwe anyị
\q2 nʼihi ụmụntakịrị ndị a,
\q1 ndị na-ada nʼihi agụụ
\q2 nʼisi okporoụzọ niile.
\b
\q1 
\v 20 “Lee anya, \nd Onyenwe anyị\nd*, ma tụgharịa uche gị.
\q2 Onye ka i sirila otu a mesoo mmeso?
\q1 O kwesiri ka ndị bụ nne rie ụmụ ha,
\q2 bụ ụmụ nke ha mụrụ?
\q1 O kwesiri ka e gbuo onye nchụaja na onye amụma
\q2 nʼime ebe dị nsọ nke Onyenwe anyị?
\b
\q1 
\v 21 “Ụmụ okorobịa na ndị okenye dinakọrọ nʼotu ebe,
\q2 nʼuzuzu nke okporoụzọ.
\q1 E jirila mma agha gbuo
\q2 ụmụ okorobịa m na ụmụ agbọghọ m.
\q1 I gbuola ha nʼụbọchị iwe gị;
\q2 i gburu ha jụ inwe ọmịiko nʼahụ ha.
\b
\q1 
\v 22 “Dịka i si akpọ oku ka a bịa nʼụbọchị oriri,
\q2 otu a ka i si kpọkọta ihe egwu niile ka ha bịakwasị m nʼakụkụ niile.
\q1 Nʼụbọchị nke iwe \nd Onyenwe anyị\nd*
\q2 ọ dịghị onye gbapụrụ ọsọ, ọ dịkwaghị onye fọdụrụ ndụ;
\q1 ndị m lekọtara, zụlitekwa
\q2 ka ndị iro m lara nʼiyi.”
\b
\b
\c 3
\q1 
\v 1 Abụ m onye hụrụla ahụhụ site
\q2 na mkpara igwe nke nrubiga oke nke iwe \nd Onyenwe anyị.\nd*
\q1 
\v 2 O sitela nʼihu ya chụpụ m, mee ka m jegharịa
\q2 nʼọchịchịrị kama nʼìhè.
\q1 
\v 3 Nʼezie, ọ tụgharịala aka ya megide m,
\q2 mgbe mgbe, ogologo ụbọchị niile.
\b
\q1 
\v 4 O meela ka akpụkpọ ahụ na anụ ahụ m fịkpọọ,
\q2 ọ nyajisiela ọkpụkpụ di m nʼahụ.
\q1 
\v 5 O busola m agha,
\q2 jiri ihe ilu na oke mkpagbu gbaa m gburugburu.
\q1 
\v 6 O meela ka m biri nʼọchịchịrị
\q2 dịka ndị nwụrụ anwụ kemgbe oge gara aga.
\b
\q1 
\v 7 Ọ gbachibidola m ogige, ime ka m ghara ịgbapụ;
\q2 o jirila ụdọ igwe dị arọ mee ka m ghara ijegharị.
\q1 
\v 8 Ọ na-eme ka ekpere m hapụ irute ya,
\q2 ọ bụladị mgbe m kpọkuru ya ka o nyere m aka.
\q1 
\v 9 O jirila nkume a wara awa gbachie ụzọ m niile,
\q2 o meela ka okporoụzọ m gbagọọ agbagọ.
\b
\q1 
\v 10 Dịka anụ ọhịa bịa nke makpu na-eche nche,
\q2 na dịka ọdụm nke na-ezo onwe ya,
\q1 
\v 11 o sitela nʼokporoụzọ dọkpụrụ m dọbisie m ahụ,
\q2 hapụ m na-enweghị onye inyeaka.
\q1 
\v 12 Ọ dọọla ụta ya
\q2 mee m ka m bụrụ onye àkụ ya ga-agbata.
\b
\q1 
\v 13 O ji àkụ nke si nʼakpa àkụ ya
\q2 gbapuo m obi.
\q1 
\v 14 Aghọrọ m ihe ọchị nye ndị m niile;
\q2 ha ji abụ na-akwa m emo ogologo ụbọchị niile.
\q1 
\v 15 O meela ka ihe niile na-elu ilu ju m afọ,
\q2 meekwa ka m ṅụjuo oluilu afọ.
\b
\q1 
\v 16 O meela ka m jiri okwute tajisie eze m,
\q2 o kponyekwala m ntụ nʼọnụ m.
\q1 
\v 17 Enweghị m udo,
\q2 echezọkwaala m ihe ọganihu bụ.
\q1 
\v 18 Nʼihi ya, ana m ekwu, “Ịma mma m ọbụla adịghịkwa.
\q2 Agaghị m enwetakwa ihe ndị ahụ m lere anya na m ga-esi nʼaka \nd Onyenwe anyị\nd* nweta.”
\b
\q1 
\v 19 Ana m echeta ahụhụ m, na mwagharị m,
\q2 ya na ihe ilu na oluilu.
\q1 
\v 20 Mgbe m na-echeta ya,
\q2 obi m na-ada mba nʼime m.
\q1 
\v 21 Ma ọ dị ihe m na-echeta nʼobi m
\q2 nke na-eme ka m nwee olileanya.
\b
\q1 
\v 22 Ọ bụ nʼihi ịhụnanya dị ukwuu nke \nd Onyenwe anyị\nd* na-emeghị ka anyị gwụsịa,
\q2 nʼihi na obi ebere ya adịghị agwụ agwụ.
\q1 
\v 23 Ha na-adị ọhụrụ ụtụtụ niile;
\q2 ikwesi ntụkwasị obi gị bụ ihe kwudosiri ike.
\q1 
\v 24 Mkpụrụobi m na-ekwu, “\nd Onyenwe anyị\nd* bụ oke m,
\q2 nʼihi ya, aga m enwe nchekwube na ya.”
\b
\q1 
\v 25 \nd Onyenwe anyị\nd* dị mma nʼebe ndị olileanya ha dị nʼime ya,
\q2 e, nʼebe obi ahụ dị, nke na-achọsi ya ike.
\q1 
\v 26 Ọ bụ ihe dị mma iji nwayọọ
\q2 chere nzọpụta nke \nd Onyenwe anyị\nd*.
\q1 
\v 27 Ọ bụ ihe dị mma ka mmadụ buru ibu arọ dịrị ya
\q2 mgbe ọ bụ okorobịa.
\b
\q1 
\v 28 Ya nọrọkwa duu naanị ya,
\q2 nʼihi na ọ bụ \nd Onyenwe anyị\nd* bokwasịrị ya ibu ahụ.
\q1 
\v 29 Ya tinye ihu ya nʼaja,
\q2 nʼihi na olileanya nwere ike dịrị.
\q1 
\v 30 Ya cheziere onye ahụ chọrọ iti ya ihe ntị ya,
\q2 ya kwerekwa ka ihe ihere ju ya afọ.
\b
\q1 
\v 31 Nʼihi na Onyenwe anyị adịghị ajụ onye ọbụla ruo
\q2 mgbe ebighị ebi.
\q1 
\v 32 Ọ bụ ezie na ọ na-eme ka mmekpa ahụ bịa, ma ọ na-emesịakwa gosi obi ebere ya,
\q2 nʼihi na ịhụnanya ya, nke na-adịghị agwụ agwụ, dị ukwuu.
\q1 
\v 33 Nʼihi na ọ naghị elezi anya eweta ahụhụ,
\q2 maọbụ mee ka ụmụ mmadụ nọọ na mmekpa ahụ.
\b
\q1 
\v 34 Iji ụkwụ zọgbuo
\q2 ndị mkpọrọ nọ nʼala ahụ
\q1 
\v 35 ime ka ihe ruru mmadụ hapụ iru ya aka
\q2 nʼihu Onye kachasị ihe niile elu,
\q1 
\v 36 ime ka ikpe ziri ezi ghara irute mmadụ.
\q2 Ọ bụ na Onyenwe anyị agaghị ahụ ihe ndị a?
\b
\q1 
\v 37 Onye pụrụ ikwu okwu mekwa ka ọ dị ire
\q2 ma ọ bụrụ na Onyenwe anyị enyeghị iwu ka ọ dị otu ahụ?
\q1 
\v 38 Ọ bụghị site nʼọnụ Onye kachasị ihe niile elu
\q2 ka ihe ọma na ihe ọjọọ si abịa?
\q1 
\v 39 Gịnị mere mmadụ dị ndụ ga-eji tamuo ntamu
\q2 mgbe ọ na-ahụ ahụhụ nʼihi mmehie ya?
\b
\q1 
\v 40 Ka anyị nyochaanụ ụzọ anyị nwapụta ya.
\q2 Ka anyị lọghachikwutenụ \nd Onyenwe anyị\nd*.
\q1 
\v 41 Ka anyị welie aka anyị abụọ na obi anyị elu nye
\q2 Chineke nọ nʼeluigwe, sị:
\q1 
\v 42 “Anyị emehiela, nupu isi,
\q2 ma ị gbagharabeghị.
\b
\q1 
\v 43 “I jirila iwe kpuchie onwe gị, si otu a chụọ anyị ọsọ.
\q2 I gbuola anyị, jụ imere anyị ebere.
\q1 
\v 44 I jiri igwe ojii kpuchie onwe gị
\q2 ka ekpere anyị ghara irute gị.
\q1 
\v 45 I meela ka anyị ghọọ unyi na ihe a zachapụrụ azachapụ
\q2 nʼetiti mba niile.
\b
\q1 
\v 46 “Ndị iro anyị niile asaghepụla ọnụ ha
\q2 megide anyị.
\q1 
\v 47 Anyị ahụọla ahụhụ site nʼoke ihe egwu na ihe ndaba dị iche iche,
\q2 na mbibi na ịla nʼiyi.”
\q1 
\v 48 Anya mmiri nke dịka iyi na-asọ asọ si nʼanya m na-asọpụta
\q2 nʼihi ndị m a lara nʼiyi.
\b
\q1 
\v 49 Anya mmiri si m nʼanya ga-anọgide na-asọpụta
\q2 na-akwụsịghị akwụsị,
\q1 
\v 50 tutu ruo mgbe \nd Onyenwe anyị\nd* ga-esite nʼeluigwe
\q2 ledata anya ma hụ.
\q1 
\v 51 Ihe anya m na-ahụ na-ewetara mkpụrụobi m ihe mgbu,
\q2 nʼihi ọnọdụ nke ndị inyom niile nọ nʼime obodo m.
\b
\q1 
\v 52 Ndị ahụ mere onwe ha ndị iro m, ndị m na-emeghị ihe ọjọọ ọbụla,
\q2 na-achụ m ọsọ dịka m bụ nnụnụ.
\q1 
\v 53 Ha gbalịrị ime ka m nwụọ nʼime olulu
\q2 site nʼịtụ m nkume.
\q1 
\v 54 Mmiri kpuchiri m isi,
\q2 echere m na-efuola m.
\b
\q1 
\v 55 Esitere m na nsọtụ olulu ahụ kpọkuo aha gị,
\q2 gị \nd Onyenwe anyị\nd*.
\q1 
\v 56 Ị nụrụ arịrịọ m rịọrọ gị, “Biko, emechila ntị gị.
\q2 Nụrụ arịrịọ inyeaka nke m na-arịọ gị.”
\q1 
\v 57 Ị bịara nso mgbe m kpọkuru gị.
\q2 Ị sịrị, “Atụla egwu.”
\b
\q1 
\v 58 Gị onwe gị, Onyenwe anyị, kpechitere ọnụ m,
\q2 gị gbapụtara ndụ m.
\q1 
\v 59 \nd Onyenwe anyị\nd*, ị hụla ihe ọjọọ ha mere m.
\q2 Kpechitere m ọnụ m.
\q1 
\v 60 Ị hụla ịbọ ọbọ ha niile
\q2 na nzube niile ha na-ezube megide m.
\b
\q1 
\v 61 \nd Onyenwe anyị\nd*, ị nụla nkọcha niile ha na-akọcha m
\q2 na nzube niile ha na-ezube megide m.
\q1 
\v 62 Ị na-anụ izu na ntamu nke ndị iro m
\q2 megide m ogologo ụbọchị niile.
\q1 
\v 63 Lee ha! Ha na-akọcha m mgbe ha guzoro ọtọ, na-akọcha m mgbe ha nọdụrụ ala.
\q2 Ha ji abụ na-akọcha m.
\b
\q1 
\v 64 \nd Onyenwe anyị\nd*, biko, kwụghachi ha ihe ruuru ha,
\q2 nʼihi ihe niile aka ha rụpụtara.
\q1 
\v 65 Jiri ihe mkpudo kpuchie obi ha.
\q2 Meekwa ka ịbụ ọnụ gị dịkwasị ha.
\q1 
\v 66 Site nʼiwe gị chụọ ha ọsọ. Laakwa ha nʼiyi nʼiwe gị,
\q2 ka ha ghara ịdịkwa nʼokpuru eluigwe nke \nd Onyenwe anyị\nd* ọzọ.
\b
\b
\c 4
\q1 
\v 1 Lee ka ọlaedo si chuo echu.
\q2 Lee ka ọlaedo makarịsịrị mma si gbanwee ghọọ ihe na-amakwaghị mma.
\q1 Nkume niile dị oke ọnụahịa nke ebe nsọ bụ
\q2 ndị a ghasara nʼisi okporoụzọ niile.
\b
\q1 
\v 2 Lee ka ụmụ ndị ikom Zayọn dị oke ọnụahịa,
\q2 ndị dị oke ọnụahịa na mbụ dịka ọlaedo a nụchara anụcha,
\q1 si dịrị ugbu a dịka ite aja
\q2 nke ọkpụ ite kpụrụ.
\b
\q1 
\v 3 Ọ bụladị ụmụ nkịta ọhịa na-eji ara ha
\q2 azụ ụmụ ha,
\q1 ma ndị a aghọọla ndị na-enweghị obi ebere;
\q2 ha aghọọla enyi nnụnụ nke na-ebi nʼọzara.
\b
\q1 
\v 4 Lee na ire nwa ọhụrụ na-arapara nʼakpo ọnụ ya
\q2 nʼihi akpịrị ịkpọ nkụ.
\q1 Ụmụntakịrị na-arịọkwa ka e nye ha nri,
\q2 ma o nweghị onye na-enye ha nri ahụ.
\b
\q1 
\v 5 Ndị ahụ naara eri ihe ụtọ dị iche iche
\q2 tọgbọrọ nʼefu ugbu a nʼokporoụzọ.
\q1 Ndị ahụ a zụrụ iyi uwe uhie uhie
\q2 nọ ugbu a na-edina nʼebe a na-ekpofu ahịhịa.
\b
\q1 
\v 6 Ahụhụ dịịrị ndị m dị ukwuu
\q2 karịa ahụhụ nke bịakwasịrị Sọdọm.
\q1 Nʼihi na ọ bụ nʼotu ntabi anya ka a kwatụrụ ya.
\q2 Ọ dịkwaghị onye bịara nyere ya aka.
\b
\q1 
\v 7 Ụmụ ndị eze ha na-egbuke karịa akụmmiri igwe,
\q2 ha na-acha ọcha chakarịa mmiri ara ehi.
\q1 Anụ ahụ ha na-akwọ mụrụmụrụ dịka nkume rubi dị oke ọnụahịa;
\q2 ha makwara mma ile anya dịka nkume safaia, bụ nkume dị oke ọnụahịa.
\b
\q1 
\v 8 Ma ugbu a, ha na-eji nji karịa unyi.
\q2 A naghị amatakwa ha ma a hụ ha nʼezi.
\q1 Anụ ahụ ha araparala nʼọkpụkpụ ha;
\q2 ọ kpọnwụọla dịka a ga-asị na ọ bụ osisi kpọrọ nkụ.
\b
\q1 
\v 9 Ọnọdụ ndị e ji mma agha gbuo ka mma
\q2 karịa ọnọdụ ndị nwụrụ site nʼụnwụ,
\q1 ndị agụụ gụgburu, ndị ji nwayọọ nwayọọ nwụọ
\q2 nʼihi nri nke na-adịghị nʼubi.
\b
\q1 
\v 10 Aka ha ka ndị inyom ndị ahụ nwere obi ebere
\q2 ji gbuo ụmụ ha, sie ha.
\q1 Ụmụ ha ghọọrọ ha nri
\q2 nʼoge ahụ a lara ndị m nʼiyi.
\b
\q1 
\v 11 \nd Onyenwe anyị\nd* emeela ka nrubiga oke nke iwe ya pụta ìhè;
\q2 ọ wụpụla iwe ya dị ọkụ.
\q1 O sunyela ọkụ na Zayọn,
\q2 nke rechapụrụ ntọala ya niile.
\b
\q1 
\v 12 Ndị eze nke ụwa ekwetaghị;
\q2 otu a kwa, ndị ụwa niile ekwetakwaghị
\q1 na ndị iro nwere ike
\q2 si nʼọnụ ụzọ ama banye nʼime Jerusalem.
\b
\q1 
\v 13 Ma ihe ndị a mere nʼihi mmehie ndị amụma ya,
\q2 na nʼihi ajọ omume nke ndị nchụaja ya,
\q1 ndị wụsiri ọbara
\q2 ndị ezi omume nọ nʼetiti ya.
\b
\q1 
\v 14 Ugbu a, ha na-asọ isi nʼokporoụzọ niile,
\q2 dịka ndị kpuru ìsì.
\q1 Ha ejirila ọbara merụọ onwe ha.
\q2 O nwekwaghị onye na-agbalị ịbịaru ha nso ịmetụ uwe ha aka.
\b
\q1 
\v 15 Ndị mmadụ na-eti mkpu na-asị ha, “Sitenụ nʼebe anyị nọ wezuga onwe unu! Unu rụrụ arụ!
\q2 Wezuganụ onwe unu, unu emetụkwala anyị aka!”
\q1 Mgbe ha gbapụrụ ọsọ bido na-awagharị,
\q2 ndị nọ na mba dị iche iche na-asị ha,
\q2 “O kwesighị ka ha nọrọkwa nʼebe a.”
\b
\q1 
\v 16 \nd Onyenwe anyị\nd* nʼonwe ya achụsaala ha.
\q2 Ọ gaghị agụnyekwa ha.
\q1 Ọ dịkwaghị ndị na-asọpụrụ onye nchụaja,
\q2 ọ dịkwaghị ndị na-emere ndị okenye amara.
\b
\q1 
\v 17 Nke ka nke, anya agbaala anyị ọchịchịrị,
\q2 ebe anyị nọ na-elepụ anya nʼefu maka enyemaka.
\q1 Ọ bụ site nʼụlọ elu nche ka anyị nọ na-elepụ anya, na-ele anya
\q2 maka ọbịbịa mba ahụ na-enweghị ike bịa zọpụta anyị.
\b
\q1 
\v 18 Ndị mmadụ na-esogharị anyị ebe niile anyị jere,
\q2 nʼihi ya anyị enweghị ike jegharịakwa nʼokporoụzọ anyị.
\q1 Ọgwụgwụ anyị adịla nso, a pụkwara ịgụta ụbọchị ole fọdụụrụ anyị,
\q2 tupu ọgwụgwụ anyị eruo.
\b
\q1 
\v 19 Ndị na-achụ anyị ọsọ na-agbasi ọsọ ike
\q2 karịa ugo na-efe na mbara eluigwe.
\q1 Ha chụgharịrị anyị nʼelu ugwu niile,
\q2 nọrọkwa nʼọzara zoo onwe ha na-eche anyị.
\b
\q1 
\v 20 Ume ndụ anyị, nke \nd Onyenwe anyị\nd* tere mmanụ,
\q2 ka ha jidere nʼọnya ha.
\q1 Anyị naara eche na anyị ga-ebi nʼokpuru ndo ya,
\q2 nʼetiti mba dị iche iche.
\b
\q1 
\v 21 Ṅụrịa ọṅụ, ka obi tọkwaa gị ụtọ, gị ada Edọm,
\q2 onye nke bi nʼala Uz.
\q1 Ma a ga-emesịakwa nye gị iko ahụ.
\q2 Ị ga-esitekwa na ya ṅụọ ihe ọṅụṅụ ṅụjụbiga afọ oke. A ga-agbakwa gị ọtọ.
\b
\q1 
\v 22 Gị ada Zayọn, ahụhụ gị agwụsịala;
\q2 Ọ gaghị emekwa ka i jee biri ogologo oge na mba ọzọ.
\q1 Kama, ọ ga-ata gị ahụhụ nʼihi mmehie gị, gị, ada Edọm,
\q2 kpugheekwa ajọ omume gị niile.
\b
\b
\c 5
\q1 
\v 1 \nd Onyenwe anyị\nd*, biko, cheta ihe niile dakwasịrị anyị;
\q2 leekwa anya ka ị hụrụ ọnọdụ ihere anyị.
\q1 
\v 2 E werela ihe nketa anyị nyefee ndị ọbịa nʼaka,
\q2 werekwa ebe obibi anyị nyefee nʼaka ndị mba ọzọ.
\q1 
\v 3 Anyị aghọọla ụmụ mgbei, na ndị na-enweghị nna.
\q2 Nne anyị ha dị ka ndị inyom di ha nwụrụ.
\q1 
\v 4 Anyị na-akwụ ụgwọ nʼihi mmiri anyị na-aṅụ.
\q2 Ọ bụkwa ego ka anyị ji azụ nkụ.
\q1 
\v 5 Agbanyeghị na anyị nya yoku nʼolu, anyị bụ ndị a na-adọgbu nʼọrụ,
\q2 ike agwụla anyị, enyeghị anyị izuike.
\q1 
\v 6 Anyị weere onwe anyị nyefee ndị Ijipt na ndị Asịrịa nʼaka
\q2 nʼihi inweta nri ga-ezuru anyị.
\q1 
\v 7 Nna anyị ha mehiere, ma ha anwụọla.
\q2 Ma ọ bụ anyị na-anata ntaramahụhụ kwesiri ịbụ nke ha.
\q1 
\v 8 Ndị bụ ohu na-achị anyị.
\q2 Ọ dịghị onye anyị nwere nke ga-anapụta anyị site nʼaka ha.
\q1 
\v 9 Anyị ji ndụ anyị nʼaka mgbe anyị na-achọ inweta ihe anyị ga-eri,
\q2 nʼihi mma agha nke dị nʼọzara.
\q1 
\v 10 Anụ ahụ anyị dị ọkụ dịka ite ọkụ,\f + \fr 5:10 \ft Ite ọkụ a, bụ nke eji eghe ihe dịka achịcha maọbụ amịkpọ anụ na ihe ndị ọzọ\f*
\q2 na-amakwa jijiji nʼihi agụụ.
\q1 
\v 11 Emerụọla ndị inyom dị na Zayọn,
\q2 ha na ụmụ agbọghọ na-amaghị nwoke niile dị nʼobodo dị iche iche nke Juda.
\q1 
\v 12 Akwụgbuola ụmụ eze site nʼikegide aka ha nʼelu;
\q2 a dịghị enyekwa ndị okenye nsọpụrụ.
\q1 
\v 13 Ụmụ okorobịa na-adọgbu onwe ha nʼọrụ na nkume ịkwọ nri,
\q2 ụmụntakịrị ndị nwoke na-asụkwa ngọngọ nʼokpuru ọtụtụ nkụ.
\q1 
\v 14 Ndị okenye adịghịkwa anọ nʼọnụ ụzọ ama,
\q2 ụmụ okorobịa akwụsịkwala ịkpọ ụbọ akwara ha.
\q1 
\v 15 Ọṅụ adịghịkwa nʼobi anyị;
\q2 ite egwu anyị aghọọlara anyị ịnọ ọnọdụ iru ụjụ.
\q1 
\v 16 Okpueze esitela nʼisi anyị dapụ.
\q2 Ahụhụ dịrị anyị nʼihi na anyị emehiela.
\q1 
\v 17 Nʼihi nke a, obi anyị na-ada mba,
\q2 nʼihi ihe ndị a ka anya anyị na-agba ọchịchịrị.
\q1 
\v 18 Nʼihi ugwu Zayọn nke tọgbọrọ nʼefu,
\q2 nke ghọrọ ebe nkịta ọhịa na-akpagharị.
\b
\q1 
\v 19 Gị, \nd Onyenwe anyị\nd*, na-abụ eze ruo mgbe ebighị ebi.
\q2 Ocheeze gị na-adịgide site nʼọgbọ ruo nʼọgbọ.
\q1 
\v 20 Gịnị mere i ji na-echezọ anyị kpamkpam?
\q2 Gịnị mere i ji gbakụta anyị azụ ogologo ụbọchị ndị a niile?
\q1 
\v 21 Mee ka anyị lọghachikwute gị, \nd Onyenwe anyị\nd*, ka anyị si otu a lọtakwa;
\q2 gbanwee ụbọchị anyị ka ọ dị ọhụrụ dịka na mgbe ochie,
\q1 
\v 22 ma ọ bụghị na ị jụla anyị kpamkpam
\q2 na-eweso anyị iwe nke ukwu.
