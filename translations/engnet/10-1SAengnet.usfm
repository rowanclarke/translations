\s1 Saul Executes the Priests  
\p
\v 6  \w But|strong="H3588"\w* \w Saul|strong="H7586"\w* \w found|strong="H3045"\w* \w out|strong="H5921"\w* \w the|strong="H3605"\w* whereabouts \w of|strong="H3027"\w* \w David|strong="H1732"\w* \w and|strong="H3027"\w* \w the|strong="H3605"\w* \w men|strong="H5650"\w* \w who|strong="H3605"\w* \w were|strong="H3027"\w* \w with|strong="H5921"\w* \w him|strong="H5921"\w*. \w Now|strong="H3588"\w* \w Saul|strong="H7586"\w* \w was|strong="H1732"\w* \w sitting|strong="H3427"\w* \w at|strong="H3427"\w* \w Gibeah|strong="H1390"\w* \w under|strong="H8478"\w* \w the|strong="H3605"\w* tamarisk tree \w at|strong="H3427"\w* \w an|strong="H3588"\w* elevated location \w with|strong="H5921"\w* \w his|strong="H3605"\w* \w spear|strong="H2595"\w* \w in|strong="H3427"\w* \w hand|strong="H3027"\w* \w and|strong="H3027"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* \w servants|strong="H5650"\w* \w stationed|strong="H5324"\w* \w around|strong="H5921"\w* \w him|strong="H5921"\w*.  
