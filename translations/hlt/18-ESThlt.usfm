\v 16 “\w Cet|strong="H1980"\w* laeh, \w Shushan|strong="H7800"\w* \w ah|strong="H9996"\w* aka \w phoe|strong="H4672"\w* \w Judah|strong="H3064"\w* \w pum|strong="H3605"\w* \w te|strong="H0853"\w* \w calui|strong="H3664"\w* \w lamtah|strong="H9999"\w* \w kai|strong="H9901"\w* \w hamla|strong="H5921"\w* \w yaeh|strong="H6684"\w* uh laeh. \w Khoyin|strong="H3915"\w* \w khothaih|strong="H3117"\w* \w hnin|strong="H3117"\w* \w thum|strong="H7969"\w* khuiah caak \w ca|strong="H0398"\w* uh \w boeh|strong="H0408"\w*, tui khaw \w o|strong="H8354"\w* uh \w boeh|strong="H0408"\w*. \w Kai|strong="H0589"\w* \w neh|strong="H9999"\w* \w ka|strong="H9901"\w* \w tanu|strong="H5291"\w* rhoek khaw \w te|strong="H3651"\w* tlam te ka \w yaeh|strong="H6684"\w* uh eh. \w Te|strong="H3651"\w* \w phoeiah|strong="H9996"\w* tah \w olkhan|strong="H1881"\w* \w bangla|strong="H9995"\w* a om \w pawt|strong="H3808"\w* \w akhaw|strong="H0834"\w* \w manghai|strong="H4428"\w* \w taengla|strong="H0413"\w* ka \w cet|strong="H0935"\w* \w vetih|strong="H9999"\w* a \w milh|strong="H0006"\w* khaw ka \w milh|strong="H0006"\w* \w mai|strong="H9995"\w* bitni,” a \w ti|strong="H0559"\w* nah.   
\p
