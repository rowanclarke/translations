\v 4 \w De|strong="H5921"\w* éstos, 24.000 debían supervisar \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w y|strong="H5921"\w* 6.000 debían ser funcionarios \w y|strong="H5921"\w* \w jueces|strong="H8199"\w*.  
\v 5 4.000 eran \w porteros|strong="H7778"\w* y 4.000 alababan \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* con los \w instrumentos|strong="H3627"\w* que \w yo|strong="H6213"\w* \w hice|strong="H6213"\w* para tributar alabanzas, dijo David.   
\p
\v 6 \w Los|strong="H1121"\w* \w repartió|strong="H2505"\w* \w David|strong="H1732"\w* en grupos según \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w*: Gersón, Coat y \w Merari|strong="H4847"\w*.   
\p
\v 7 Los hijos de \w Gersón|strong="H1649"\w*: \w Laadán|strong="H3936"\w* y Simei.  
\v 8 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Laadán|strong="H3936"\w*, \w tres|strong="H7969"\w*: \w Jehiel|strong="H3171"\w* \w el|strong="H1121"\w* primero, después Zetam y \w Joel|strong="H3100"\w*.  
\v 9 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Simei, \w tres|strong="H7969"\w*: Selomit, \w Haziel|strong="H2381"\w* y \w Harán|strong="H2039"\w*. Éstos fueron \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* las casas paternas \w de|strong="H1121"\w* \w Laadán|strong="H3936"\w*.  
\v 10 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Simei: Jahat, Zina, \w Jeús|strong="H3266"\w* y \w Bería|strong="H1283"\w*. Estos cuatro fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Simei.  
\v 11 Jahat \w era|strong="H1961"\w* \w el|strong="H1121"\w* primero, y Zina \w el|strong="H1121"\w* \w segundo|strong="H8145"\w*. Pero \w Jeús|strong="H3266"\w* y \w Bería|strong="H1283"\w* \w no|strong="H3808"\w* \w tuvieron|strong="H1961"\w* \w muchos|strong="H7235"\w* \w hijos|strong="H1121"\w*, por \w lo|strong="H3808"\w* cual \w fueron|strong="H1961"\w* contados \w como|strong="H1961"\w* una sola \w familia|strong="H1004"\w*.   
\p
\v 12 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Coat: \w Amram|strong="H6019"\w*, Izhar, \w Hebrón|strong="H2275"\w* y Uziel, ellos cuatro.  
\v 13 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Amram|strong="H6019"\w*: Aarón \w y|strong="H5704"\w* \w Moisés|strong="H4872"\w*. Aarón \w fue|strong="H1931"\w* apartado \w para|strong="H5704"\w* \w que|strong="H1931"\w* \w se|strong="H1931"\w* dedicara \w con|strong="H5704"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* las cosas \w más|strong="H5704"\w* \w sagradas|strong="H6944"\w*, quemaran incienso \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w ministraran|strong="H8334"\w* \w y|strong="H5704"\w* bendijeran \w en|strong="H5704"\w* \w su|strong="H1931"\w* \w Nombre|strong="H8034"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.  
\v 14 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w*, varón \w de|strong="H5921"\w* \nd ʼElohim,\nd* fueron contados \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w tribu|strong="H7626"\w* \w de|strong="H5921"\w* \w Leví|strong="H3878"\w*.  
\v 15 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*: Gersón y Eliezer.  
\v 16 \w Sebuel|strong="H7619"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Gersón, fue \w el|strong="H1121"\w* \w jefe|strong="H7218"\w*.  
\v 17 Rehabías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Eliezer, \w fue|strong="H1961"\w* \w el|strong="H1121"\w* \w jefe|strong="H7218"\w*. Eliezer \w no|strong="H3808"\w* \w tuvo|strong="H1961"\w* otros \w hijos|strong="H1121"\w*, pero \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Rehabías \w se|strong="H1961"\w* \w multiplicaron|strong="H7235"\w* grandemente.  
\v 18 \w El|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Izhar fue Selomit, \w el|strong="H1121"\w* \w jefe|strong="H7218"\w*.  
\v 19 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hebrón|strong="H2275"\w*: \w Jerías|strong="H3404"\w* \w el|strong="H1121"\w* primero, Amarías \w el|strong="H1121"\w* \w segundo|strong="H8145"\w*, \w Jahaziel|strong="H3166"\w* \w el|strong="H1121"\w* \w tercero|strong="H7992"\w*, y \w Jecamán|strong="H3360"\w* \w el|strong="H1121"\w* \w cuarto|strong="H7243"\w*.  
\v 20 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Uziel: Micaía \w el|strong="H1121"\w* primero, \w e|strong="H3068"\w* \w Isías|strong="H3449"\w* \w el|strong="H1121"\w* \w segundo|strong="H8145"\w*.   
\p
\v 21 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Merari|strong="H4847"\w*: Mahli y Musi. \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Mahli: Eleazar y \w Cis|strong="H7027"\w*.  
\v 22 Eleazar \w murió|strong="H4191"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w tuvo|strong="H1961"\w* \w hijos|strong="H1121"\w*, \w sino|strong="H3588"\w* solo \w hijas|strong="H1323"\w*, \w de|strong="H3588"\w* modo \w que|strong="H3588"\w* sus parientes, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Cis|strong="H7027"\w*, las \w tomaron|strong="H5375"\w* \w como|strong="H3588"\w* esposas.  
\v 23 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Musi fueron \w tres|strong="H7969"\w*: Mahli, Edar y Jeremot.   
\p
\v 24 Éstos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Leví|strong="H3878"\w* según sus \w casas|strong="H1004"\w* paternas, \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* \w casas|strong="H1004"\w* paternas según \w el|strong="H1121"\w* censo \w de|strong="H1121"\w* ellos, \w contados|strong="H4557"\w* por sus \w nombres|strong="H8034"\w*, individualmente, \w de|strong="H1121"\w* 20 \w años|strong="H8141"\w* \w arriba|strong="H4605"\w*, \w los|strong="H1121"\w* cuales \w trabajaban|strong="H6213"\w* en \w el|strong="H1121"\w* \w ministerio|strong="H5656"\w* \w de|strong="H1121"\w* la \w Casa|strong="H1004"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 25 \w Porque|strong="H3588"\w* \w David|strong="H1732"\w* dijo: \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* dio paz \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*. \w Él|strong="H3588"\w* \w morará|strong="H7931"\w* \w en|strong="H5704"\w* Jerusalén \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.  
\v 26 \w Además|strong="H1571"\w* \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* \w ya|strong="H1571"\w* no tendrán \w que|strong="H1571"\w* cargar \w el|strong="H3605"\w* \w Tabernáculo|strong="H4908"\w* \w y|strong="H1571"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios para su \w ministerio|strong="H5656"\w*.  
\v 27 \w Así|strong="H3588"\w* \w que|strong="H3588"\w*, conforme \w a|strong="H3068"\w* \w las|strong="H1992"\w* últimas \w palabras|strong="H1697"\w* \w de|strong="H3588"\w* \w David|strong="H1732"\w*, \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Leví|strong="H3881"\w* \w fueron|strong="H1732"\w* \w contados|strong="H4557"\w* \w de|strong="H3588"\w* 20 \w años|strong="H8141"\w* \w arriba|strong="H4605"\w*.   
\p
\v 28 \w Estaban|strong="H4612"\w* bajo \w las|strong="H5921"\w* órdenes \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Aarón \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* \w que|strong="H3588"\w* ministraran \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w patios|strong="H2691"\w* \w y|strong="H3588"\w* \w las|strong="H5921"\w* \w cámaras|strong="H3957"\w*: \w para|strong="H5921"\w* \w la|strong="H5921"\w* purificación \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w cosa|strong="H3605"\w* \w consagrada|strong="H6944"\w*, \w la|strong="H5921"\w* \w obra|strong="H4639"\w* \w del|strong="H5921"\w* \w ministerio|strong="H5656"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd*  
\v 29 y \w los|strong="H3605"\w* \w Panes|strong="H3899"\w* de \w la|strong="H3605"\w* Presencia, mantener \w la|strong="H3605"\w* flor de harina destinada al sacrificio, \w a|strong="H3068"\w* las hojuelas sin levadura, \w a|strong="H3068"\w* \w lo|strong="H3605"\w* preparado en \w sartén|strong="H4227"\w*, \w a|strong="H3068"\w* \w lo|strong="H3605"\w* tostado y \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w medida|strong="H4060"\w* y cuenta,  
\v 30 asistir cada \w mañana|strong="H1242"\w* todos los días \w a|strong="H3068"\w* dar gracias y tributar alabanzas \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, y \w asimismo|strong="H3651"\w* al llegar la noche,  
\v 31 ofrecer \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w holocaustos|strong="H5930"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w sábados|strong="H7676"\w*, \w las|strong="H5921"\w* lunas \w nuevas|strong="H2320"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w solemnidades|strong="H4150"\w* señaladas \w continuamente|strong="H8548"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w según|strong="H5921"\w* \w el|strong="H5921"\w* \w número|strong="H4557"\w* fijado \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w ordenanza|strong="H4941"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* prescribe,  
\v 32 y para \w que|strong="H1121"\w* tuvieran \w la|strong="H8104"\w* custodia del Tabernáculo \w de|strong="H1121"\w* Reunión y del \w Santuario|strong="H6944"\w*, bajo las órdenes \w de|strong="H1121"\w* sus hermanos \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón en \w el|strong="H1121"\w* \w ministerio|strong="H5656"\w* \w de|strong="H1121"\w* \w la|strong="H8104"\w* \w Casa|strong="H1004"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\c 24  
\s1 Organización de los sacerdotes  
\p
\v 1 Ahora, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón fueron distribuidos en grupos.  
\p \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón fueron \w Nadab|strong="H5070"\w*, Abiú, Eleazar \w e|strong="H3068"\w* Itamar.  
\v 2 Pero \w como|strong="H1961"\w* \w Nadab|strong="H5070"\w* y Abiú \w murieron|strong="H4191"\w* \w antes|strong="H6440"\w* \w que|strong="H3808"\w* \w su|strong="H1992"\w* padre, y \w no|strong="H3808"\w* \w tuvieron|strong="H1961"\w* \w hijos|strong="H1121"\w*, Eleazar \w e|strong="H3068"\w* Itamar ejercieron \w el|strong="H1121"\w* \w sacerdocio|strong="H3547"\w*.   
\p
\v 3 \w David|strong="H1732"\w* y \w Sadoc|strong="H6659"\w* repartieron \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Eleazar, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Ahimelec y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Itamar \w por|strong="H4480"\w* turnos \w en|strong="H4480"\w* \w el|strong="H1121"\w* \w ministerio|strong="H5656"\w*.  
\v 4 Pero como \w había|strong="H4672"\w* \w más|strong="H4480"\w* \w varones|strong="H1397"\w* \w jefes|strong="H7218"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Eleazar \w que|strong="H4480"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Itamar, \w los|strong="H1121"\w* repartieron así: \w De|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Eleazar, 16 \w jefes|strong="H7218"\w* \w de|strong="H4480"\w* \w casas|strong="H1004"\w* paternas, y \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Itamar \w ocho|strong="H8083"\w* \w jefes|strong="H7218"\w* \w de|strong="H4480"\w* \w casas|strong="H1004"\w* paternas.  
\v 5 \w De|strong="H3588"\w* \w esta|strong="H1961"\w* manera \w fueron|strong="H1961"\w* repartidos \w por|strong="H3588"\w* sorteo \w los|strong="H1121"\w* unos \w y|strong="H3588"\w* \w los|strong="H1121"\w* otros, \w porque|strong="H3588"\w* tanto \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Eleazar \w como|strong="H3588"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Itamar \w hubo|strong="H1961"\w* funcionarios \w del|strong="H5973"\w* \w Santuario|strong="H6944"\w* \w y|strong="H3588"\w* funcionarios \w de|strong="H3588"\w* \nd ʼElohim\nd*.   
\p
\v 6 \w El|strong="H1121"\w* \w escriba|strong="H5608"\w* \w Semaías|strong="H8098"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Natanael, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*, \w escribió|strong="H3789"\w* sus nombres \w en|strong="H4480"\w* \w presencia|strong="H6440"\w* \w del|strong="H4480"\w* \w rey|strong="H4428"\w* y \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w*, \w delante|strong="H6440"\w* \w de|strong="H4480"\w* \w Sadoc|strong="H6659"\w* \w el|strong="H1121"\w* \w sacerdote|strong="H3548"\w*, \w de|strong="H4480"\w* Ahimelec, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Abiatar, y \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H4480"\w* las \w casas|strong="H1004"\w* paternas \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* y \w levitas|strong="H3881"\w*. Designaron \w por|strong="H4480"\w* sorteo una \w casa|strong="H1004"\w* paterna \w para|strong="H4480"\w* Eleazar y otra \w para|strong="H4480"\w* Itamar.   
\p
\v 7 La \w primera|strong="H7223"\w* \w suerte|strong="H1486"\w* tocó \w a|strong="H3068"\w* \w Joiarib|strong="H3080"\w*, la \w segunda|strong="H8145"\w* \w a|strong="H3068"\w* \w Jedaías|strong="H3048"\w*,  
\v 8 la \w tercera|strong="H7992"\w* \w a|strong="H3068"\w* \w Harim|strong="H2766"\w*, la cuarta \w a|strong="H3068"\w* Seorim,  
\v 9 la quinta \w a|strong="H3068"\w* Malquías, la sexta \w a|strong="H3068"\w* Mijamín,  
\v 10 la séptima \w a|strong="H3068"\w* \w Cos|strong="H6976"\w*, la octava \w a|strong="H3068"\w* Abías,  
\v 11 la novena \w a|strong="H3068"\w* \w Jesúa|strong="H3442"\w*, la décima \w a|strong="H3068"\w* Secanías,  
\v 12 la undécima \w a|strong="H3068"\w* Eliasib, la duodécimma \w a|strong="H3068"\w* Jaquim,  
\v 13 la decimotercera \w a|strong="H3068"\w* Hupa, la decimocuarta \w a|strong="H3068"\w* Jesebeab,  
\v 14 la decimoquinta \w a|strong="H3068"\w* \w Bilga|strong="H1083"\w*, la decimosexta \w a|strong="H3068"\w* Imer,  
\v 15 la decimoséptima \w a|strong="H3068"\w* \w Hezir|strong="H2387"\w*, la decimoctava \w a|strong="H3068"\w* Afses,  
\v 16 la decimonovena \w a|strong="H3068"\w* Petaías, la vigésima \w a|strong="H3068"\w* Hezequiel,  
\v 17 la vigesimoprimera \w a|strong="H3068"\w* Jaquín, la vigesimosegunda \w a|strong="H3068"\w* Gamul,  
\v 18 la vigesimotercera \w a|strong="H3068"\w* Delaía, la vigesimocuarta \w a|strong="H3068"\w* \w Maazías|strong="H4590"\w*.   
\p
\v 19 Éstos fueron distribuidos para su \w ministerio|strong="H5656"\w*, para \w que|strong="H3027"\w* entraran en la \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*, según \w les|strong="H6680"\w* fue \w ordenado|strong="H6680"\w* \w por|strong="H3027"\w* su padre Aarón, de la manera como \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* de \w Israel|strong="H3478"\w* le \w mandó|strong="H6680"\w*.   
\p
