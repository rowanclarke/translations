\mt1 Aycháya  
\mt4 (Isaiah)  
\c 9  
\s1 Wangarr An-nika An-walkurpa Nipa An-nelangga  
\q1
\v 6 An-delipa a-bambungguna arrburrwa.  
\q1 Wangarr an-gata ay-ninyarrapa ay-workiya an-nigipa walkurpa ana-jerrmarra arrburrwa.  
\q1 An-ngayburrpa bunggawa a-ni barra an-molamola.  
\q1 An-nelangga abu-ngurrja barra aburr-workiya  
\q2 An-gugunggaja An-molamola,  
\q2 Wangarr Burr-barlmarrk Jama A-jirra,  
\q2 An-ngayburrpa Nyanyapa Arrburrwa A-jirrapa A-workiya,  
\q2 An-ngayburrpa Mu-ngoyurra A-jirra arrburrwa,  
\q3 Mari An-nyagara Arr-jalkakaja A-workiya.   