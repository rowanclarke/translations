\v 23 \w Then|strong="H1961"\w* \w there|strong="H1961"\w* \w was|strong="H1961"\w* another \w evening|strong="H6153"\w* \w that|strong="H3117"\w* \w was|strong="H1961"\w* \w followed|strong="H1961"\w* \w by|strong="H3117"\w* another \w morning|strong="H1242"\w*. \w He|strong="H3117"\w* called \w that|strong="H3117"\w* \w period|strong="H3117"\w* \w of|strong="H3117"\w* \w time|strong="H3117"\w* ‘\w the|strong="H3117"\w* \w fifth|strong="H2549"\w* \w day|strong="H3117"\w*’.
\v 24 \w Then|strong="H1961"\w* God \w said|strong="H3651"\w*, “\w I|strong="H3651"\w* \w want|strong="H5315"\w* various \w kinds|strong="H4327"\w* \w of|strong="H3318"\w* \w creatures|strong="H2416"\w* \w to|strong="H3318"\w* appear \w on|strong="H1961"\w* \w the|strong="H3318"\w* earth. \w There|strong="H1961"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* many \w kinds|strong="H4327"\w* \w of|strong="H3318"\w* ◄livestock/domestic \w animals|strong="H2416"\w*►, \w creatures|strong="H2416"\w* \w that|strong="H5315"\w* scurry across \w the|strong="H3318"\w* ground, \w and|strong="H3318"\w* large wild \w animals|strong="H2416"\w*.” \w And|strong="H3318"\w* \w that|strong="H5315"\w* \w is|strong="H5315"\w* \w what|strong="H3651"\w* \w happened|strong="H1961"\w*.
