\id SNG  
\h Mele a Solomona 
\toc1 Mele a Solomona 
\toc2 Mele a Solomona 
\toc3 Mele a Solomona 
\mt1 Mele a Solomona  
\c 1  
\s1 KE MELE  
\q1
\v 1 KE Mele o na mele, na Solomona no ia,   
\b  
\q1
\v 2 E honi mai ia'u i na honi o kona waha; No ka mea, ua oi aku kou aloha i ka waina.   
\q1
\v 3 No ke ala o kou mea poni maikai, Ua like kou inoa me ka aila ala i nininiia; No ia mea, ua aloha mai na kaikamahine ia oe.   
\q1
\v 4 E ume mai ia'u, e hahai makou mamuli ou. Ua hookomo mai ke alii ia'u iloko o kona keena; E hauoli makou, a e olioli hoi ia oe; E hoomanao makou i kou aloha mamua o ka waina; Ua aloha aku ka poe pono ia oe.   
\b  
\q1
\v 5 Ua eleele au, ua maikai no nae, E na kaikamahine o Ierusalema; E like me na halelewa o Kedara, E like hoi me na paku lole o Solomona.   
\q1
\v 6 Mai nana mai oukou ia'u, no ka mea, ua eleele au, No ka nana ana mai o ka la ia'u. Ua huhu mai ia'u na keiki a ko'u makuwahine, Ua hoolilo mai lakou ia'u i mea kiai i na malawaina; Aka hoi, o ka'u malawaina, aole au i malama.   
\b  
\q1
\v 7 E hai mai ia'u, e ka mea a ko'u uhane i aloha'i, Aila ihea oe i hanai mai. Mahea la oe i hoomaha ai i ke awakea? No ke aha la wau i lilo ai, Me ho wahine la i uhiia, Ma na poe hipa a kou mau hoanoho?   
\b  
\q1
\v 8 Ina, aole oe i ike, E ka mea maikai mawaena o na wahine, E hele oe ma na kapuwai o ka poe hipa, E hanai i kau poe kao keiki, Ma kahi kokoke i na halelewa o ka poe kahuhipa.   
\b  
\q1
\v 9 Ua hoohalike au ia oe, e ka'u mea i aloha'i, Me he lio wahine la iloko o na kaa o Parao.   
\q1
\v 10 Ua hoonaniia kou papalina i na kaula momi, A o kou a-i i na lei maikai.   
\b  
\q1
\v 11 E hana makou nou i na kaula gula, A me na kaula hoi i paukuia i ke kala.   
\b  
\q1
\v 12 I ka noho pu ana o ke alii me kona poe, Ua moani aku la ko'u mea ala.   
\q1
\v 13 O ka'u mea i aloha'i, he pua mura no ia na'u, E moe iho la ia mawaena o ko'u poli.   
\q1
\v 14 O ka'u mea i aloha'i, he lala kupero ia na'u, No ka malawaina mai o Enegedi.   
\b  
\q1
\v 15 Aia hoi, he nani kou, e ka'u mea i aloha'i, He nani kou, he mau maka manu nunu kou.   
\b  
\q1
\v 16 Aia hoi, he nani kou, e ka'u mea i aloha'i, he maikai hoi; Ua omaomao no hoi ko kaua wahi moe.   
\q1
\v 17 Na kaola o ko kaua hale, he laau kedera ia, A me ko kaua mau oa, he laau fira.   
\c 2  
\b  
\q1
\v 1 O WAU no ka rose o Sarona, A me ka lilia o na awawa.   
\b  
\q1
\v 2 E like me ka lilia mawaena o na kakalaioa, Pela no ka'u mea i aloha'i mawaena o na kaikamahine.   
\b  
\q1
\v 3 E like me ka laau ohia mawaena o na laau o ka nahelehele, Pela ka'u mea i aloha'i mawaena o na keiki kane; Ua noho iho au malalo o kona malu me ka oluolu, A ua ono kona hua i kuu ai ana.   
\q1
\v 4 Ua hookomo mai oia ia'u iloko o ka halo ahainu, A o kona hae maluna iho o'u, he aloha no ia.   
\q1
\v 5 E hooluolu mai ia'u i ka pai huawaina, E hanai mai hoi ia'u i ka hua ohia; No ka mea, ua mai au i ke aloha.   
\q1
\v 6 Aia kona lima hema malalo iho o ko'u poo, O kona lima akau hoi, ua apo mai ia'u.   
\b  
\q1
\v 7 Ke kauoha aku nei au ia oukou, e na kaikamahine o Ierusalema, Ma na anetelope a me na dia o ke kula, E hooluliluli ole aku oukou, a e hoala ole aku i ka'u mea i aloha'i, a ala wale mai ia.   
\b  
\q1
\v 8 He leo ka, no ka'u mea i aloha'i Aia hoi, e hiki mai ana ia, E lele ana maluna o na mauna, E lehai ana hoi maluna o na puu.   
\q1
\v 9 Ua like ka'u mea i aloha'i, me ka anetelope, A me ka dia keiki hoi; Aia ka, ku iho la oia mahope o ko makou pa, E nana ana ma na puka makani, E makaikai ana ma na puka olepelepe.   
\b  
\q1
\v 10 Olelo mai la ka'u mea i aloha'i, i mai ia'u, E ka'u mea i aloha'i, e ko'u mea nani, e ku ae, a e hele mai oe:   
\q1
\v 11 No ka mea, aia hoi, ua hala ka hooilo, Ua pau ka ua, a ua malie;   
\q1
\v 12 Ua ikeia mai na pua ma ka honua; Ua hiki mai ka wa e oki ai, Ua loheia hoi ka leo o ke kuhukuku ma ko makou aina;   
\q1
\v 13 O ka laau fiku ua hua mai ia i kona hua opiopio, Ua aala mai ka pua o ka waina. E ka'u mea i aloha'i, e ko'u mea maikai, e ala, a e hele mai oe.   
\b  
\q1
\v 14 E ko'u nunu, ma na wahi malu o ka pohaku, a me na wahi hunaia o ka pali, E ae mai e ike au i kou helehelena. A e lohe hoi i kou leo; No ka mea, ua oluolu kou leo, a o kou helehelena, ua maikai no ia.   
\b  
\q1
\v 15 E hopu aku no makou i na alopeke, I na alopeke liilii, na mea i ino ai na malawaina; No ka mea, ua pua mai ko kakou malawaina.   
\b  
\q1
\v 16 No'u no ka'u mea i aloha'i, A nona hoi au; E ai ana oia mawaena o na lilia.   
\q1
\v 17 A i ka wa oluolu o ka la, a auhee na aka, E huli oe, e ka'u mea i aloha'i. A lilo oe i anetelope, A i dia keiki paha maluna o na mauna palipali.   
\c 3  
\b  
\q1
\v 1 MALUNA o ko'u wahi moe, i ka po, Ua imi au i ka'u mea i aloha'i; Imi au ia ia, aole nae i loaa.   
\q1
\v 2 E ku au iluna, ano, e hele a puni ke kulanakauhale, Ma na alanui, a me na wahi akea, E imi i ka mea a ko'u uhane i aloha'i; Ua imi au ia ia, aole nae i loaa.   
\q1
\v 3 Ua loaa au i ka poe kiai, Ka poe hele a puni ke kulanakauhale; I aku la au, Ua ike anei oukou i ka'u mea i aloha'i?   
\q1
\v 4 Aole liuliu ko'u hele ana mai o lakou aku, A loaa mai ia'u ka mea a ko'u uhane i aloha'i; Ua lalau au ia ia, aole nae e hookuu aku; A hookomo au ia ia iloko o ka hale o ko'u makuwahine, A iloko o ke keena o ka mea nana au i hanau mai.   
\b  
\q1
\v 5 Ke kauoha aku nei au ia oukou, e na kaikamahine o Ierusalema, Ma na anetelope a me na dia o ke kula, E hooluliluli ole aku oukou, a e hoala ole i ka'u mea i aloha'i, a ala wale mai ia.   
\b  
\q1
\v 6 Owai keia e hoea mai ana mai ka waonahele mai, E like me na punohu uwahi? Ua moani mai kona mura, a me koua libano, A me na mea ala a pau a ka mea kalepa.   
\q1
\v 7 Aia hoi, o kona wahi e moe ai, no Solomona ia, He kanaono kanaka koa [e ku ana] a puni ia, He poe ikaika o ka Iseraela.   
\q1
\v 8 Ua lalau lakou a pau i na pahikaua, He poe akamai lakou i ke kaua; Aia no ka pahi a kela mea keia mea ma kona uha, No ka makau i ka po.   
\q1
\v 9 Hana iho la ke alii o Solomona i hale auamo nona, I ka laau o Lebanona.   
\q1
\v 10 Hana iho la oia i na kia he kala; A o ke kino, hana iho la i ke gula; O ka noho ona, he mea ulaula ia; Ua kipapaia kona walua i ke aloha, No na kaikamahine mai o Ierusalema.   
\q1
\v 11 E puka iwaho, e na kaikamahine o Ziona, a e ike i ke alii ia Solomona, Me kona papale alii, ka mea a kona makuwahine i kau maluna ona, I kona la i mareia'i, i ka la i olioli ai kona naau.   
\c 4  
\b  
\q1
\v 1 A IA hoi, he nani kou, e ka'u mea i aloha'i, aia hoi, he nani kou; O kou mau maka, ua like me na maka manu nunu, Iloko o kou pale; Ua like kou lauoho me ko ka poe kao, I ko lakou noho ana ma ka mauna o Giliada.   
\q1
\v 2 Ua like kou mau niho me ka poe hipa i akoia, E hele mai ana, mai ka auau ana mai; Ua hanau palua lakou a pau, Aohe mea pa mawaena o lakou a pau.   
\q1
\v 3 Ua like kou mau lehelehe me ke kaula ulaula, A ua maikai kau olelo ana; E like me ka apana pomeraite, pela kou mau maka, Iloko o kou pale.   
\q1
\v 4 O kou a-i, ua like ia me ka halekiai o Davida, I kukuluia'i i hale kahiko kaua. Ua kau lakou malaila i hookahi tausani palekaua; He mau palekana lakou a pau no ka poe koa.   
\q1
\v 5 O ko'u mau waiu, ua like ia me na anetelope i hanau palua ia, E ai ana mawaena o na lilia.   
\q1
\v 6 A i ka wa oluolu o ka la, a auhee na aka, E hele au i ka mauna mura, a i ka puu libano.   
\b  
\q1
\v 7 He nani loa kou a pau, e ka'u mea i aloha'i, Aole ou wahi kina iki.   
\b  
\q1
\v 8 E hele pu me au, mai Lebanona mai, e ka'u wahine, Me au pu, mai Lebanona mai, E nana mai ka piko mai o Amana, Mai ka piko mai o Sinera, a me Heremona, Mai ka lua mai o na liona, A mai ka mauna mai o na leopadi.   
\q1
\v 9 Ua hooeha mai oe i ko'u naau, e ko'u kaikuwahine, e ka'u wahine; Ua hooeha mai oe i ko'u naau me kekahi o kou mau maka, Me kekahi lei hoi o kou a-i.   
\q1
\v 10 Nani kou aloha, e ko'u kaikuwahine, e ka'u wahine! Maikai kou aloha mamua o ka waina, A me ke ala o kou mea kahinu, Mamua o na mea ala a pau loa.   
\q1
\v 11 O kou lehelehe, e ka'u wahine, ua haule ka meli malaila iho; Aia malalo iho o kou elelo, ka meli a me ka waiu; A o ke ala o kou kapa, Ua like ia me ke ala o Lebanona.   
\q1
\v 12 O ko'u kaikuwahine, o ka'u wahine, he kihapai ia i paa i ka pa, He kiowai i uhiia, he punawai hoi i kapiliia.   
\q1
\v 13 O kou mau kawowo, o ke kihapai pomeraite no ia me na hua ono, O ke kupero me ka naredo:   
\q1
\v 14 O ka na naredo, a me ke keroko, a me ke kalamo, a me ke kinemona, Me na laau ala a pau, o ka mura a me ka aloe, Me na mea ala maikai a pau.   
\q1
\v 15 O ka punawai o na kihapai, o ka luawai o ka wai ola, A me na wai kahe mai Lebanona mai.   
\b  
\q1
\v 16 E ala mai, e ka makani kukulu akau, E ka makani kukulu hema, e hele mai; E pa mai i ko'u kihapai i moani aku kona mea ala. E komo mai, o ka'u mea i aloha'i iloko o kona kihapai, E ai ia i ka hua o kona kihapai.   
\c 5  
\b  
\q1
\v 1 U A komo au iloko o ko'u kihapai, e ko'u kaikuwahine, e ka'u wahine; Ua ohi au i ko'u mura mea ala; Ua ai au i ko'u waihona meli me ko'u meli; Ua inu au i ko'u waina me ko'u waiu; E ai, e ko'u poe makamaka, E inu, oia hoi, e inu nui, e ka'u poe i aloha'i.   
\b  
\q1
\v 2 Ua hiamoe au. ua ala no nae ko'u naau: He leo ka! o ka'u mea i aloha'i e kikeke ana, [me ka i mai,] E wehe ae no'u, e ko'u kaikuwahine, e ka'u mea i aloha'i, e ka'u manu nunu, e ko'u mea maemae; No ka mea, ua paapu ko'u poo i ka hau, A me ko'u wili lauoho i na paka ua o ka po.   
\q1
\v 3 Ua wehe au i ko'u kapa komo; Pehea la wau e komo hou aku ai ia? Ua holoi au i ko'u mau wawae; Pehea la wau e hoopaumaelo hou aku ai?   
\q1
\v 4 Ua hookomo mai ka'u mea i aloha'i i kona lima ma kahi hakahaka, A haehae ko'u opu nona.   
\q1
\v 5 Ua ku au iluna e wehe ae no ka'u mea i aloha'i, A kulu ka mura mai ko'u mau lima aku, A kahe hoi ka mura maemae loa mai ko'u mau manamana lima, Maluna o ka mea e paa ai ka puka.   
\q1
\v 6 Ua wehe ae au no ka'u mea i aloha'i; Aka, o ka'u mea i aloha'i, ua huli ae ia, a hele aku la; Ua lele ko'u oili i kana olelo ana mai; Ua imi au ia ia, aole nae i loaa, Ua kahea aku au ia ia, aole nae i ekemu mai.   
\q1
\v 7 Ua loaa au i ka poe kiai i ko lakou hele ana a puni ke kulanakauhale, Ua pepehi mai lakou ia'u a eha au; O ka poe kiai maluna o ka pa, ua kaili ae lakou i ko'u aahu.   
\q1
\v 8 Ua kauoha aku au ia oukou, e na kaikamahine o Ierusalema, Ina e loaa ia oukou ka'u mea i aloha'i, E hai aku oukou ia ia, ua mai au i ke aloha.   
\b  
\q1
\v 9 Heaha kau mea i aloha'i, mamua o kekahi mea i aloha'i, E ka mea maikai mawaena o na wahine; Heaha kau mea i aloha'i mamua o kekahi mea i aloha'i, I kauoha mai ai oe ia makou pela?   
\b  
\q1
\v 10 O ka'u mea i aloha'i, ua keokeo ia a me ka ulaula hoi, Ua oi nui aku ia mamua o na tausani he umi.   
\q1
\v 11 O kona poo, he gula maemae ia, O kona wili lauoho, na loloa ia, A eleele hoi me he manu koraka la.   
\q1
\v 12 O kona mau maka, ua like ia me ko ka manu nunu ma na kahawai, I holoiia i ka waiu, E noho ana me ka maikai.   
\q1
\v 13 O kona mau papalina, ua like ia me ka mala o na mea ala, A me ka ulaula ala hoi; O kona lehelehe, ua like ia me na lilia e kahe mai ana he mura maemae loa.   
\q1
\v 14 O kona mau lima, ua like ia me na komo lima gula, I paapu i ka topaza. O kona opu, ua like ia me ka niho elepani, I uhiia hoi i ka sapeira.   
\q1
\v 15 O kona uha, ua like ia me na kia pohaku keokeo, Ua kukuluia maluna iho o na kumu gula maemae: O kona helehelena, ua like ia me Lebanona, Maikai hoi e like me na laau kedera.   
\q1
\v 16 O kona waha, he mea ono no ia; Oiaio, he mea makemake nui loa ia oia. Oia ka'u mea i aloha'i, oia ko'u makamaka, E na kaikamahine o Ierusalema.   
\c 6  
\b  
\q1
\v 1 A ILA ihea i hele ai ka'u mea i aloha'i, E ka mea maikai mawaena o na wahine? Mahea la i huli aku ai kau mea i aloha'i, I imi pu hoi kakou ia ia?   
\b  
\q1
\v 2 Ua iho ka'u mea i aloha'i ilalo o kona kihapai, I ka mala o na mea ala, E ai ana iloko o ke kihapai, A e ohi hoi i na lilia.   
\q1
\v 3 No ka'u mea i aloha'i owau, A o ka'u mea i aloha'i, no'u ia: E ai ana ia mawaena o na lilia.   
\b  
\q1
\v 4 Ua maikai oe, e ka'u mea i aloha'i, e like me Tireza, Ua nani hoi e like me Ierusalema; A he mea e makau ai e like me ka poe e amo ana i na hae.   
\q1
\v 5 E huli aku oe i kou mau maka mai o'u aku nei, No ka mea, ua lanakila laua maluna o'u. O kou lauoho, ua like ia me ka poe kao, E noho ana maluna o Giliada.   
\q1
\v 6 O kou mau niho, ua like ia me ka poe hipa, E pii mai ana mai ka auau ana mai; Ua hanau palua lakou a pau, Aohe mea pa mawaena o lakou a pau.   
\q1
\v 7 Me ka apana pomeraite, pela kou mau maka, Iloko o kou pale.   
\q1
\v 8 Aia na wahine alii he kanaono, Elua kanaha haiawahine, A o ka poe puupaa hoi, aole lakou e pau i ka heluia.   
\q1
\v 9 O ka'u manu nunu, ko'u mea maemae, hookahi no ia, He kamakahi ia na kona makuwahine, Oia wale no ka mea i alohaia e ka mea nana ia i hanau mai. Ua ike na kaikamahine ia ia, a hoomaikai aku la lakou; O na alii wahine a me na haiawahine hoi, Ua hoonani pu lakou ia ia.   
\b  
\q1
\v 10 Owai keia e nana mai ana e like me ka wehe ana o ke alaula? Ua konale ia e like me ka mahina, Ua maikai hoi ia e like me ka la, A he mea e makau ai e like me ka poe e amo ana i na hae.   
\q1
\v 11 Ua iho au ilalo o ke kihapai agoza, E nana i na mea uliuli o ke awawa, E ike hoi i ka ulu ana o ka waina, A me ka pua ana o ka pomeraite:   
\q1
\v 12 A emo ole, ua lilo aka ko'u uhane, E like me na kaa o Aminadiba.   
\b  
\q1
\v 13 E hoi, e hoi mai, e Sulamite, E hoi, e hoi mai i ike makou ia oe. Heaha ka oukou mea e ike ai ia Sulamite? E like me ko na poe kaua elua.   
\c 7  
\b  
\q1
\v 1 NANI wale kou mau wawae iloko o na kamaa, e ke kaikamahine alii! O ke apo o kou mau uha, ua like ia me ka lei o ka a-i, Ka mea a na lima o ka poe akamai i hana'i.   
\q1
\v 2 O kou piko me he kiaha poepoe la ia, Aole nele i ka waina ala. O kou opu me he pua palaoa la, Ua nakinakiia i na lilia.   
\q1
\v 3 O kou mau waiu, ua like me na anetelope elua, He mau mahoe anetelope laua.   
\q1
\v 4 O koa a-i, ua like ia me ka halekiai niho elepani; O kou mau maka, me na punawai o Hesebona, Aia ma ka ipuka o Beterabima; O kou ihu ua like ia me ka halekiai o Lebanona, Aia kona alo i Damaseko.   
\q1
\v 5 O kou poo maluna ou, ua like ia me Karemela, O kou lauoho maluna o kou poo, me he mea ulaula la; Ua paa ke alii iloko o na keena maluna.   
\b  
\q1
\v 6 Manomano kou nani, a me kou maikai, E ka'u mea i aloha'i, no ka olioli!   
\q1
\v 7 O kou kiekie, ua like ia me ka laau pama, A o kou mau waiu me he mau huhui waina la.   
\q1
\v 8 I iho la au, E pii au iluna o ka laau pama, A paa aku au i kona mau lala. Ano, e lilo mai kou mau waiu me he mau huhui waina la; A o ke ala o kou ihu e like me na ohia.   
\q1
\v 9 A o ke aluna o kou waha me ka waina maikai no ka'u mea i aloha'i, e kahe oluolu ana, A olelo ae la na leheleho o ka poe hiamoe.   
\b  
\q1
\v 10 No ka'u mea i aloha'i owau, A o kona makemake, eia no ia'u.   
\q1
\v 11 Ina kaua, e ka'u mea i aloha'i, e hele kaua i ke kula, E noho kaua ma na kauhale.   
\q1
\v 12 E ala ae i ke kakahiaka ma ka malawaina, e ike i ka ulu ana o ka waina, E nana i ka pua ana o ka waina, A me ke kupu ana o ka pomeraite; Malaila au e haawi aiiaoei kou aloha.   
\q1
\v 13 Ua ala mai na dudima, A ma ko makou mau ipuka, aia na hua ono a pau, He mea kahiko, a me ka mea hou, O na mea au i waiho ai nou, e ka'u mea i aloha'i.   
\c 8  
\b  
\q1
\v 1 I NA paha oe i like me ko'u kaikunane, Ka mea i omo i ka waiu o ko'u makuwahine! A i loaa oe ia'u mawaho, e honi no au ia oe, Aole hoi au e hoowahawahaia.   
\q1
\v 2 A e alakai no hoi au ia oe, a e hookomo ia oe Iloko o ka hale o ko'u makuwahine, ka mea nana au i ao mai. E hoohainu au ia oe i ka waina ala, No ka waina hou o ko'u pomeraite.   
\q1
\v 3 Aia malalo iho o ko'u poo kona lima hema, A o kona lima akau, ua apo mai ia'u.   
\b  
\q1
\v 4 Ke kauoha aku nei au ia oukou, e na kaikamahine o Ierusalema, E hooluliluli ole aku oukou, a e hoala ole aku i ka'u mea i aloha'i, A ala wale mai ia.   
\b  
\q1
\v 5 Owai keia e pii mai nei mai ka waoakua mai, E hilinai ana maluna o kana mea i aloha'i? Ua hoala aku au ia oe, malalo iho o ka laau ohia; Malaila, ua hanau mai kou makuwahine ia oe, Malaila, ua hanau mai ia oe ka mea nana oe i hanau mai.   
\b  
\q1
\v 6 E kau mai ia'u i hoailona maluna o kou naau, I hoailona hoi maluna o kou lima; No ka mea, o ke aloha, ua ikaika ia e like me ka make; O ka lili, ua paa loa ia e like me ka luakupapau; O kona lapalapa ana, o ka lapalapa ana no ia o ke ahi wela loa.   
\q1
\v 7 Aole pio ke aloha i na wai he nui loa, Aole ia e mokuhia e na wai kahe; Ina e haawi aku ke kanaka i ka waiwai a pau o kona hale i lilo mai ke aloha, E hoowahawaha loa ia ia mau mea.   
\b  
\q1
\v 8 Ke kaiku wahine uuku o makou, aole ona waiu, Heaha ka mea a makou e hana'i no ko makou kaikuwahine, I ka la i hoopalauia'i oia?   
\q1
\v 9 Ina he pa oia, e kukulu makou maluna ona he halepakui kala; Ina he puka oia, e uhi makou ia ia i na laau kedera.   
\b  
\q1
\v 10 He pa no wau, A o ko'u mau waiu e like ia me ka halekiai: Alaila, ua like au i kona mau maka, me he mea la i alohaia mai.   
\q1
\v 11 He malawaina na Solomona ma Baalahamona; Ua hoolimalima aku oia i kana malawaina i ka poe nana i malama; Ua lawe mai kela kanaka, keia kanaka i hookahi tausani apana kala i uku no ka hua waina.   
\q1
\v 12 O ka'u malawaina, ia'u no ia, eia no imua o'u, He tausani kau, e Solomona, A elua haneri na ka poe malama i ka hua.   
\b  
\q1
\v 13 E ka mea e noho ana ma na kihapai, Ua lohe ka poe hoanoho i kou leo; E ae mai oe i lohe au.   
\b  
\q1
\v 14 E wikiwiki oe, e ka'u mea i aloha'i, E hoohalike ia oe iho me ka anetelope, a me ka dia keiki, Maluna o na mauna ala.   