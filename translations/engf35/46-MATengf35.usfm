\q2 \w who|strong="G3588"\w* \w will|strong="G1510"\w* \w shepherd|strong="G4165"\w* \w my|strong="G1722"\w* \w people|strong="G2992"\w* \w Israel|strong="G2474"\w*.’ ”\f + \fr 2:6 \ft See Micah 5:2.\f*   
\m
\v 7 \w Then|strong="G5119"\w* \w Herod|strong="G2264"\w*, \w calling|strong="G2564"\w* \w the|strong="G3588"\w* wise \w men|strong="G3097"\w* \w secretly|strong="G2977"\w*, determined \w from|strong="G3844"\w* \w them|strong="G3588"\w* \w the|strong="G3588"\w* \w time|strong="G5550"\w* \w when|strong="G5119"\w* \w the|strong="G3588"\w* star \w appeared|strong="G5316"\w*.  
\v 8 \w And|strong="G2532"\w* directing \w them|strong="G3588"\w* \w to|strong="G1519"\w* Bethlehem \w he|strong="G2532"\w* \w said|strong="G3004"\w*, “\w When|strong="G1161"\w* \w you|strong="G3004"\w* \w get|strong="G2147"\w* \w there|strong="G2532"\w*, \w search|strong="G1833"\w* carefully \w for|strong="G1519"\w* \w the|strong="G2532"\w* young \w child|strong="G3813"\w*; \w and|strong="G2532"\w* \w should|strong="G3588"\w* \w you|strong="G3004"\w* \w find|strong="G2147"\w* \w him|strong="G3588"\w*, \w bring|strong="G2532"\w* \w back|strong="G1519"\w* \w word|strong="G3588"\w* \w to|strong="G1519"\w* \w me|strong="G1473"\w*, \w so|strong="G2532"\w* \w that|strong="G3588"\w* \w I|strong="G1473"\w* \w also|strong="G2532"\w* \w may|strong="G2532"\w* \w go|strong="G4198"\w* \w and|strong="G2532"\w* \w worship|strong="G4352"\w* \w him|strong="G3588"\w*.”\f + \fr 2:8 \ft Presumably Herod was a good actor, so if they hadn't been warned in a dream, they would probably have reported back.\f*   
\s1 The Star!  
\p
\v 9 \w So|strong="G2532"\w* \w having|strong="G2532"\w* heard \w the|strong="G1722"\w* \w king|strong="G3588"\w* \w they|strong="G2532"\w* \w departed|strong="G4198"\w*, \w and|strong="G2532"\w* \w there|strong="G2532"\w* \w was|strong="G1510"\w* \w the|strong="G1722"\w* star \w that|strong="G3739"\w* \w they|strong="G2532"\w* \w had|strong="G2532"\w* \w seen|strong="G3708"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* East! \w It|strong="G2532"\w* \w went|strong="G4198"\w* \w before|strong="G4254"\w* \w them|strong="G3588"\w* \w until|strong="G2193"\w* \w it|strong="G2532"\w* \w arrived|strong="G2064"\w* \w and|strong="G2532"\w* \w stopped|strong="G2476"\w* \w above|strong="G1883"\w* \w where|strong="G3757"\w* \w the|strong="G1722"\w* \w young|strong="G3739"\w* \w Child|strong="G3813"\w* \w was|strong="G1510"\w*.  
\v 10 \w Now|strong="G1161"\w* \w when|strong="G1161"\w* \w they|strong="G1161"\w* \w saw|strong="G3708"\w* \w the|strong="G1161"\w* star \w they|strong="G1161"\w* \w rejoiced|strong="G5463"\w* \w with|strong="G3588"\w* \w exceedingly|strong="G4970"\w* \w great|strong="G3173"\w* \w joy|strong="G5479"\w*!\f + \fr 2:10 \ft It reappeared after two years. They had undertaken an expensive and dangerous journey in the dark, as it were. Now God confirms that they are on the right track. They are beside themselves with joy! It guided them to the very house.\f*  
\v 11 \w And|strong="G2532"\w* \w coming|strong="G2064"\w* \w into|strong="G1519"\w* \w the|strong="G2532"\w* \w house|strong="G3614"\w*\f + \fr 2:11 \ft Joseph probably used the stable (Luke 2:7) for only one night; the next day he would look for more adequate quarters. That Jesus was born at night is clear from Luke 2:8-12. The angels appeared at night (verse 8) and said “this day” (verse 11)—the shepherds were Jews, and the Jewish day began at 6:00 p.m. Since the shepherds broadcasted the message delivered by the angel, any people in the town who loved God would want to help Joseph. The Text says ‘young child’, not ‘baby’—the visit to Jerusalem (Luke 2:22-38) is now well behind them.\f* \w they|strong="G2532"\w* \w saw|strong="G3708"\w* \w the|strong="G2532"\w* \w young|strong="G4374"\w* \w Child|strong="G3813"\w* \w with|strong="G3326"\w* \w Mary|strong="G3137"\w* \w His|strong="G1519"\w* \w mother|strong="G3384"\w*,\f + \fr 2:11 \ft They may have arrived at night. All the events recorded in verses 1-8 presumably happened the same day. It is only some ten miles from Jerusalem to Bethlehem, but it may have been already dark when they started out. The Text says that they saw Jesus and Mary; Joseph is not mentioned. Perhaps he was sleeping in another room. If the magi took off immediately, as I suppose, then the angel roused Joseph as soon as they were out the door.\f* \w and|strong="G2532"\w* \w falling|strong="G4098"\w* \w down|strong="G4098"\w* \w they|strong="G2532"\w* \w worshiped|strong="G4352"\w* \w Him|strong="G3588"\w*; \w and|strong="G2532"\w* opening \w their|strong="G2532"\w* \w treasures|strong="G2344"\w* \w they|strong="G2532"\w* \w presented|strong="G4374"\w* \w gifts|strong="G1435"\w* \w to|strong="G1519"\w* \w Him|strong="G3588"\w*: \w gold|strong="G5557"\w*, \w frankincense|strong="G3030"\w* \w and|strong="G2532"\w* \w myrrh|strong="G4666"\w*.\f + \fr 2:11 \ft Because the gifts were three, some have assumed that the magi were three, but nowhere does the Text specify the number. Now, as then, those who are wise still seek Him. The gifts were providential to meet their financial needs in Egypt and beyond, quite apart from any symbolism.\f*  
\v 12 \w Then|strong="G2532"\w*, \w having|strong="G2532"\w* \w been|strong="G2532"\w* \w warned|strong="G5537"\w* \w in|strong="G1519"\w* \w a|strong="G2532"\w* \w dream|strong="G3677"\w* \w not|strong="G3361"\w* \w to|strong="G1519"\w* return \w to|strong="G1519"\w* \w Herod|strong="G2264"\w*, \w they|strong="G2532"\w* departed \w for|strong="G1519"\w* \w their|strong="G2532"\w* \it own\it* \w country|strong="G5561"\w* \w by|strong="G1223"\w* \w a|strong="G2532"\w* different \w road|strong="G3598"\w*.   
\s1 The flight to Egypt  
\p
\v 13 \w Now|strong="G1161"\w* \w when|strong="G1161"\w* \w they|strong="G2532"\w* \w had|strong="G2532"\w* departed, \w again|strong="G1453"\w*, \w an|strong="G2532"\w* angel \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w Lord|strong="G2962"\w* \w appeared|strong="G3708"\w* \w to|strong="G1519"\w* \w Joseph|strong="G2501"\w* \w in|strong="G1519"\w* \w a|strong="G2532"\w* \w dream|strong="G3677"\w* \w saying|strong="G3004"\w*: “\w Get|strong="G1453"\w* \w up|strong="G1453"\w*, \w take|strong="G3880"\w* \w the|strong="G2532"\w* young \w Child|strong="G3813"\w* \w and|strong="G2532"\w* \w His|strong="G1519"\w* \w mother|strong="G3384"\w*, \w flee|strong="G5343"\w* \w to|strong="G1519"\w* Egypt \w and|strong="G2532"\w* stay \w there|strong="G1563"\w* \w until|strong="G2193"\w* \w I|strong="G2532"\w* \w tell|strong="G3004"\w* \w you|strong="G4771"\w*; \w because|strong="G1063"\w* \w Herod|strong="G2264"\w* \w is|strong="G1510"\w* \w about|strong="G3195"\w* \w to|strong="G1519"\w* \w seek|strong="G2212"\w* \w the|strong="G2532"\w* young \w Child|strong="G3813"\w* \w to|strong="G1519"\w* destroy \w Him|strong="G3588"\w*!”  
\v 14 \w So|strong="G2532"\w* \w he|strong="G2532"\w* \w got|strong="G1453"\w* \w up|strong="G1453"\w* \w and|strong="G2532"\w* \w took|strong="G3880"\w* \w the|strong="G2532"\w* young \w Child|strong="G3813"\w* \w and|strong="G2532"\w* \w His|strong="G1519"\w* \w mother|strong="G3384"\w* \w by|strong="G2532"\w* \w night|strong="G3571"\w*\f + \fr 2:14 \ft That same night, immediately. A suspicious man like Herod doubtless sent a spy to keep an eye on the magi. When they took off in the opposite direction Herod would have been informed within a few hours. If Joseph had waited until morning it would probably have been too late.\f* \w and|strong="G2532"\w* departed \w for|strong="G1519"\w* Egypt.  
\v 15 \w And|strong="G2532"\w* \w he|strong="G2532"\w* \w was|strong="G1510"\w* \w there|strong="G1563"\w* \w until|strong="G2193"\w* \w the|strong="G2532"\w* \w death|strong="G5054"\w* \w of|strong="G1537"\w* \w Herod|strong="G2264"\w*, \w so|strong="G2443"\w* \w that|strong="G2443"\w* \w what|strong="G3588"\w* \w was|strong="G1510"\w* \w spoken|strong="G3004"\w* \w by|strong="G1223"\w* \w the|strong="G2532"\w* \w Lord|strong="G2962"\w* \w through|strong="G1223"\w* \w the|strong="G2532"\w* \w prophet|strong="G4396"\w* \w should|strong="G3588"\w* \w be|strong="G1510"\w* \w fulfilled|strong="G4137"\w*, namely: “\w Out|strong="G1537"\w* \w of|strong="G1537"\w* Egypt \w I|strong="G1473"\w* \w called|strong="G2564"\w* \w my|strong="G1473"\w* \w Son|strong="G5207"\w*.”\f + \fr 2:15 \ft The time spent in Egypt was possibly only a month or two. The quote is from Hosea 11:1, which in that context refers to Israel, but Jesus was/is literally God's Son—OT prophecies often have a dual reference/application.\f*   
\s1 The massacre  
\p
\v 16 \w Then|strong="G2532"\w* \w Herod|strong="G2264"\w*, \w when|strong="G2532"\w* \w he|strong="G2532"\w* \w saw|strong="G3708"\w* \w that|strong="G3754"\w* \w he|strong="G2532"\w* \w had|strong="G2532"\w* \w been|strong="G2532"\w* deceived \w by|strong="G1722"\w* \w the|strong="G1722"\w* wise \w men|strong="G3956"\w*, \w became|strong="G3588"\w* \w very|strong="G3029"\w* angry, \w and|strong="G2532"\w* \w he|strong="G2532"\w* \w sent|strong="G2532"\w* \w out|strong="G2532"\w* \w and|strong="G2532"\w* killed \w all|strong="G3956"\w* \w the|strong="G1722"\w* boys \w who|strong="G3739"\w* \w were|strong="G3588"\w* \w in|strong="G1722"\w* Bethlehem \w and|strong="G2532"\w* \w in|strong="G1722"\w* \w all|strong="G3956"\w* \w its|strong="G3956"\w* districts, \w from|strong="G3844"\w* \w two|strong="G1332"\w* \w years|strong="G1332"\w* \w old|strong="G1332"\w* \w and|strong="G2532"\w* \w under|strong="G5259"\w*, \w according|strong="G2596"\w* \w to|strong="G2532"\w* \w the|strong="G1722"\w* \w time|strong="G5550"\w* \w which|strong="G3739"\w* \w he|strong="G2532"\w* \w had|strong="G2532"\w* determined \w from|strong="G3844"\w* \w the|strong="G1722"\w* wise \w men|strong="G3956"\w*.\f + \fr 2:16 \ft Obviously it had been his intention to kill Jesus.\f*  
\v 17 \w Then|strong="G5119"\w* \w what|strong="G3588"\w* \w was|strong="G3588"\w* \w spoken|strong="G3004"\w* \w by|strong="G1223"\w* \w Jeremiah|strong="G2408"\w* \w the|strong="G1223"\w* \w prophet|strong="G4396"\w* \w was|strong="G3588"\w* \w fulfilled|strong="G4137"\w*, namely:   
\q1
\v 18 “\w A|strong="G2532"\w* \w voice|strong="G5456"\w* \w was|strong="G1510"\w* heard \w in|strong="G1722"\w* \w Ramah|strong="G4471"\w*,  
\q2 lamentation, \w weeping|strong="G2799"\w* \w and|strong="G2532"\w* \w great|strong="G4183"\w* \w mourning|strong="G3602"\w*;  
\q1 \w Rachel|strong="G4478"\w* \w weeping|strong="G2799"\w* \w for|strong="G3754"\w* \w her|strong="G3754"\w* \w children|strong="G5043"\w*  
\q2 \w and|strong="G2532"\w* \w not|strong="G3756"\w* \w wanting|strong="G2309"\w* \w to|strong="G2532"\w* \w be|strong="G1510"\w* \w comforted|strong="G3870"\w*,  
\q2 \w because|strong="G3754"\w* \w they|strong="G2532"\w* \w are|strong="G1510"\w* \w no|strong="G3756"\w* \w more|strong="G4183"\w*.”\f + \fr 2:18 \ft Ramah was a district of Bethlehem. The quote is from Jeremiah 31:15. The birth of the Savior resulted in the massacre of many infants; being the fulfillment of prophecy means it was part of the Plan. God's ways seem strange to us at times, but He is under no obligation to explain His actions. (However, based on Jeremiah 31:16 I wonder if God did not compensate the parents somehow.)\f*   
\s1 The return to Natsareth  
\p
\v 19 \w Now|strong="G1161"\w* \w Herod|strong="G2264"\w* having \w died|strong="G5053"\w*, \w there|strong="G1161"\w*, \w an|strong="G1722"\w* angel \w of|strong="G2962"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w* \w appeared|strong="G3708"\w* \w in|strong="G1722"\w* \w a|strong="G1722"\w* \w dream|strong="G3677"\w* \w to|strong="G2596"\w* \w Joseph|strong="G2501"\w* \w in|strong="G1722"\w* Egypt  
\v 20 \w saying|strong="G3004"\w*: “\w Get|strong="G1453"\w* \w up|strong="G1453"\w*, \w take|strong="G3880"\w* \w the|strong="G2532"\w* young \w Child|strong="G3813"\w* \w and|strong="G2532"\w* \w His|strong="G1519"\w* \w mother|strong="G3384"\w* \w and|strong="G2532"\w* \w go|strong="G4198"\w* \w into|strong="G1519"\w* \w the|strong="G2532"\w* \w land|strong="G1093"\w* \w of|strong="G2532"\w* \w Israel|strong="G2474"\w*, \w for|strong="G1063"\w* \w those|strong="G3588"\w*\f + \fr 2:20 \ft The Text is plainly plural here, so who else besides Herod had died? That massacre would not be a nice thing to have on the record, and it may be that Herod had ordered the execution of others who were involved.\f* \w seeking|strong="G2212"\w* \w the|strong="G2532"\w* \w life|strong="G5590"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* young \w Child|strong="G3813"\w* \w have|strong="G2532"\w* \w died|strong="G2348"\w*.”  
\v 21 \w So|strong="G2532"\w* \w he|strong="G2532"\w* \w got|strong="G1453"\w* \w up|strong="G1453"\w* \w and|strong="G2532"\w* \w took|strong="G3880"\w* \w the|strong="G2532"\w* young \w Child|strong="G3813"\w* \w and|strong="G2532"\w* \w His|strong="G1519"\w* \w mother|strong="G3384"\w* \w and|strong="G2532"\w* \w went|strong="G1525"\w* \w into|strong="G1519"\w* \w the|strong="G2532"\w* \w land|strong="G1093"\w* \w of|strong="G2532"\w* \w Israel|strong="G2474"\w*.  
\v 22 \w But|strong="G1161"\w* hearing \w that|strong="G3754"\w* Archelaus \w was|strong="G3588"\w* reigning \w over|strong="G2596"\w* \w Judea|strong="G2449"\w* \w instead|strong="G1161"\w* \w of|strong="G3962"\w* \w his|strong="G1519"\w* \w father|strong="G3962"\w* \w Herod|strong="G2264"\w*, \w he|strong="G1161"\w* \w was|strong="G3588"\w* \w afraid|strong="G5399"\w* \w to|strong="G1519"\w* \w go|strong="G1519"\w* \w there|strong="G1563"\w*. \w And|strong="G1161"\w* \w being|strong="G1161"\w* \w warned|strong="G5537"\w* \w in|strong="G1519"\w* \w a|strong="G1519"\w* \w dream|strong="G3677"\w* \w he|strong="G1161"\w* proceeded \w into|strong="G1519"\w* \w the|strong="G1519"\w* region \w of|strong="G3962"\w* \w Galilee|strong="G1056"\w*.  
\v 23 \w And|strong="G2532"\w* \w upon|strong="G1519"\w* \w arriving|strong="G2064"\w* \w he|strong="G2532"\w* \w settled|strong="G2730"\w* \w in|strong="G1519"\w* \w a|strong="G2532"\w* \w city|strong="G4172"\w* \w called|strong="G2564"\w* Natsareth [Branch-town],\f + \fr 2:23 \ft We know from Luke that Natsareth was Joseph's home—his house and business were waiting for him (although he had been gone for quite a while). The name of the town in Hebrew is based on the consonants נצר (\+it resh, tsadde, nun\+it*), but since Hebrew is read from right to left, for us the order is reversed = n, ts, r. This word root means ‘branch’. Greek has the equivalent for ‘ps’ and ‘ks’, but not for ‘ts’, so the transliteration used a ζ (\+it zeta\+it*) ‘dz’, which is the voiced counterpart of ‘ts’. But when the Greek was transliterated into English it came out as ‘z’! But Hebrew has a ‘z’, ז (\+it zayin\+it*), so in transliterating back into Hebrew people assumed the consonants נזר, replacing the correct \+it tsadde\+it* with \+it zayin\+it*. This technical information is necessary as background for the next footnote.\f* \w so|strong="G2532"\w* \w that|strong="G3754"\w* \w what|strong="G3588"\w* \w was|strong="G3588"\w* \w spoken|strong="G3004"\w* \w through|strong="G1223"\w* \w the|strong="G2532"\w* \w prophets|strong="G4396"\w* \w should|strong="G3588"\w* \w be|strong="G2532"\w* \w fulfilled|strong="G4137"\w*, \w that|strong="G3754"\w* \w He|strong="G2532"\w* \w would|strong="G2532"\w* \w be|strong="G2532"\w* \w called|strong="G2564"\w* \w a|strong="G2532"\w* Natsorean [Branch-man].\f + \fr 2:23 \ft Neither ‘Nazareth’ nor ‘Nazarene’, spelled with a \+it zayin\+it*, is to be found in the Old Testament, but there is a prophetic reference to Messiah as the Branch, \+it netser\+it*—Isaiah 11:1—and several to the related word, \+it tsemach\+it*—Isaiah 4:2; Jeremiah 23:5; 33:15; Zechariah 3:8; 6:12. So Matthew is quite right—the prophets (plural, being at least three) referred to Christ as the Branch. Since Jesus was a man, He would be the ‘Branch-man’, from ‘Branch-town’. Which brings us to the word ‘Natsorean’. The familiar ‘Nazarene’ (Ναζαρηνος) [Natsarene] occurs in Mark 1:24; 14:67; 16:6 and Luke 4:34, but here in Matthew 2:23 and in fourteen other places, including Acts 22:8 where the glorified Jesus calls \+nd Himself\+nd* that, the word is ‘Natsorean’ (Ναζωραιος), which is quite different. (Actually, in Acts 22:8 Jesus introduced Himself to Saul as ‘\+nd the\+nd* Natsorean’, which Saul would understand as a reference to the Messiah.) To my surprise, Pilate put “the Natsorean” in the accusation above the cross—John 19:19. I have been given to understand that the Nazareth of Jesus' day had been founded some 100 years before by a Branch family who called it Branch town; they were very much aware of the prophecies about the Branch and fully expected the Messiah to be born from among them—they called themselves Branch-people (Natsoreans). Of course everyone else thought it was a big joke and tended to look down on them. “Can anything good…?”\f*   
\c 3  
\ms1 Ministry of John the Baptizer—26 AD  
\m
\v 1 \w Now|strong="G1161"\w* \w in|strong="G1722"\w* \w those|strong="G3588"\w* \w days|strong="G2250"\w* \w John|strong="G2491"\w* \w the|strong="G1722"\w* Baptizer \w began|strong="G1161"\w* \w preaching|strong="G2784"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w wilderness|strong="G2048"\w* \w of|strong="G2250"\w* \w Judea|strong="G2449"\w*  
\v 2 \w and|strong="G2532"\w* \w saying|strong="G3004"\w*, “\w Repent|strong="G3340"\w*, \w for|strong="G1063"\w* \w the|strong="G2532"\w* kingdom \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w heavens|strong="G3772"\w* \w has|strong="G2532"\w* \w come|strong="G2532"\w* \w near|strong="G1448"\w*!”  
\v 3 \w For|strong="G1063"\w* \w this|strong="G3778"\w* \w is|strong="G1510"\w* \w he|strong="G3778"\w* \w who|strong="G3588"\w* \w was|strong="G1510"\w* \w referred|strong="G3004"\w* \w to|strong="G3004"\w* \w by|strong="G1223"\w* \w the|strong="G1722"\w* \w prophet|strong="G4396"\w* \w Isaiah|strong="G2268"\w*, \w saying|strong="G3004"\w*:  
\q1 “\w A|strong="G1722"\w* \w voice|strong="G5456"\w* crying-out,  
\q2 ‘\w Prepare|strong="G2090"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w wilderness|strong="G2048"\w* \w the|strong="G1722"\w* \w way|strong="G3598"\w* \w of|strong="G1223"\w* \w the|strong="G1722"\w* \sc \+w Lord|strong="G2962"\+w*\sc*,  
\q2 \w make|strong="G4160"\w* \w His|strong="G1223"\w* \w paths|strong="G5147"\w* \w straight|strong="G2117"\w*.’ ”\f + \fr 3:3 \ft The reference is to Isaiah 40:3. Hebrew poetry, and prose, makes heavy use of parallel or synonymous statements. From the context in Isaiah it seems clear that “in the wilderness” goes with the verb ‘make straight’, not ‘call out’. But why a straight road in the wilderness? Any road facilitates the movement of people and goods, but a straight road through accidented terrain is a major asset. (Actually, Isaiah 40:3-4 describes the construction of a modern superhighway.) John was the voice, but it was the people who had to make the road. So how about us? Are we supposed to be making such a road, and if so, how? At the very least we should be proclaiming biblical values to the world by every available means.\f*   
\p
\v 4 \w Now|strong="G1161"\w* \w John|strong="G2491"\w* \w actually|strong="G2532"\w* used \w clothes|strong="G1742"\w* \it made\it* \w from|strong="G2532"\w* \w camel|strong="G2574"\w*'\w s|strong="G2192"\w* \w hair|strong="G2359"\w* \w and|strong="G2532"\w* \w a|strong="G2192"\w* \w leather|strong="G1193"\w* \w belt|strong="G2223"\w* \w around|strong="G4012"\w* \w his|strong="G4012"\w* \w waist|strong="G3751"\w*; \w while|strong="G1161"\w* \w his|strong="G4012"\w* \w food|strong="G5160"\w* \w was|strong="G1510"\w* locusts \w and|strong="G2532"\w* \w wild|strong="G2532"\w* \w honey|strong="G3192"\w*.  
\v 5 \w Then|strong="G2532"\w* \w Jerusalem|strong="G2414"\w*, \w all|strong="G3956"\w* \w Judea|strong="G2449"\w* \w and|strong="G2532"\w* \w all|strong="G3956"\w* \w the|strong="G2532"\w* \w region|strong="G4066"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w Jordan|strong="G2446"\w* \w went|strong="G2532"\w* \w out|strong="G1607"\w* \w to|strong="G4314"\w* \w him|strong="G3588"\w*,  
\v 6 \w and|strong="G2532"\w* \w were|strong="G3588"\w* \w being|strong="G2532"\w* baptized \w by|strong="G1722"\w* \w him|strong="G3588"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w Jordan|strong="G2446"\w*, \w confessing|strong="G1843"\w* \w their|strong="G2532"\w* sins.   
\s1 A bunch of snakes  
\p
\v 7 \w But|strong="G1161"\w* \w seeing|strong="G3708"\w* \w many|strong="G4183"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w Pharisees|strong="G5330"\w* \w and|strong="G2532"\w* \w Sadducees|strong="G4523"\w* \w coming|strong="G2064"\w* \w to|strong="G2532"\w* \w his|strong="G1909"\w* baptism, \w he|strong="G2532"\w* \w said|strong="G3004"\w* \w to|strong="G2532"\w* \w them|strong="G3588"\w*: “\w Brood|strong="G1081"\w* \w of|strong="G2532"\w* \w vipers|strong="G2191"\w*! \w Who|strong="G5101"\w* tipped \w you|strong="G5210"\w* off \w to|strong="G2532"\w* \w flee|strong="G5343"\w* \w from|strong="G2064"\w* \w the|strong="G2532"\w* \w coming|strong="G2064"\w* \w wrath|strong="G3709"\w*?  
\v 8 \w Therefore|strong="G3767"\w* \w produce|strong="G4160"\w* \w fruit|strong="G2590"\w* worthy \w of|strong="G3588"\w* \w repentance|strong="G3341"\w*,  
\v 9 \w and|strong="G2532"\w* don'\w t|strong="G3588"\w* \it even\it* \w think|strong="G1380"\w* \w to|strong="G2532"\w* \w say|strong="G3004"\w* \w within|strong="G1722"\w* \w yourselves|strong="G1438"\w*, ‘\w We|strong="G3754"\w* \w have|strong="G2192"\w* Abraham \w as|strong="G1722"\w* \w father|strong="G3962"\w*,’\f + \fr 3:9 \ft They had notions of spiritual privilege based on birth, but as someone has said, God has no grandchildren. Later on Jesus will make clear that they did in fact reject John's message—they were not baptized.\f* \w for|strong="G1063"\w* \w I|strong="G2532"\w* \w say|strong="G3004"\w* \w to|strong="G2532"\w* \w you|strong="G5210"\w* \w that|strong="G3754"\w* \w God|strong="G2316"\w* \w is|strong="G3588"\w* \w able|strong="G1410"\w* \w to|strong="G2532"\w* \w raise|strong="G1453"\w* \w up|strong="G1453"\w* \w children|strong="G5043"\w* \w to|strong="G2532"\w* Abraham \w from|strong="G1537"\w* \w these|strong="G3778"\w* \w stones|strong="G3037"\w*.  
\v 10 \w Indeed|strong="G2532"\w*, \w already|strong="G2235"\w* \w the|strong="G2532"\w* ax \w is|strong="G3588"\w* \w being|strong="G2532"\w* \w laid|strong="G2749"\w* \w to|strong="G1519"\w* \w the|strong="G2532"\w* \w root|strong="G4491"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w trees|strong="G1186"\w*.\f + \fr 3:10 \ft The Messiah was already present, and He would condemn the Pharisees and Sadducees.\f* \w So|strong="G3767"\w* \w every|strong="G3956"\w* \w tree|strong="G1186"\w* \w not|strong="G3361"\w* \w producing|strong="G4160"\w* \w good|strong="G2570"\w* \w fruit|strong="G2590"\w* \w is|strong="G3588"\w* \w cut|strong="G1581"\w* \w down|strong="G1581"\w* \w and|strong="G2532"\w* thrown \w into|strong="G1519"\w* \w the|strong="G2532"\w* \w fire|strong="G4442"\w*.   
\p
\v 11 “\w I|strong="G1473"\w* baptize \w you|strong="G5210"\w* \w with|strong="G1722"\w* \w water|strong="G5204"\w* \w unto|strong="G1519"\w* \w repentance|strong="G3341"\w*, \w but|strong="G1161"\w* \w the|strong="G1722"\w* \w One|strong="G3739"\w* \w coming|strong="G2064"\w* \w after|strong="G3694"\w* \w me|strong="G1473"\w* \w is|strong="G1510"\w* \w mightier|strong="G2478"\w* \w than|strong="G2478"\w* \w I|strong="G1473"\w*, \w whose|strong="G3739"\w* \w sandals|strong="G5266"\w* \w I|strong="G1473"\w* \w am|strong="G1510"\w* \w not|strong="G3756"\w* \w worthy|strong="G2425"\w* \w to|strong="G1519"\w* carry. \nd \+w He|strong="G2532"\+w*\nd* \w will|strong="G1510"\w* baptize \w you|strong="G5210"\w* \w with|strong="G1722"\w* \w Holy|strong="G4151"\w* \w Spirit|strong="G4151"\w*.\f + \fr 3:11 \ft There is no article with ‘Holy Spirit’, so I take the phrase as a proper name. The ‘and fire’ we are used to is read by only 20% of the Greek manuscripts. The 80% includes the best line of transmission. However, Luke 3:16 has the ‘and fire’.\f*  
\v 12 \w His|strong="G1519"\w* \w winnowing|strong="G4425"\w* shovel \w is|strong="G3588"\w* \w in|strong="G1722"\w* \w His|strong="G1519"\w* \w hand|strong="G5495"\w*, \w and|strong="G2532"\w* \w He|strong="G2532"\w* \w will|strong="G2532"\w* \w thoroughly|strong="G1245"\w* clean \w out|strong="G2532"\w* \w His|strong="G1519"\w* threshing floor \w and|strong="G2532"\w* \w gather|strong="G4863"\w* \w His|strong="G1519"\w* \w wheat|strong="G4621"\w* \w into|strong="G1519"\w* \w the|strong="G1722"\w* barn; \w but|strong="G1161"\w* \w He|strong="G2532"\w* \w will|strong="G2532"\w* \w burn|strong="G2618"\w* \w up|strong="G1519"\w* \w the|strong="G1722"\w* chaff \w with|strong="G1722"\w* unquenchable \w fire|strong="G4442"\w*.”\f + \fr 3:12 \ft Can you have wheat without chaff? Isn't the chaff part of the wheat plant? What might the implications of this analogy be for the Church? What percentage of the plant is edible wheat? Wherever Christianity is the state or majority religion, or part of the prevailing culture, a large majority of the ‘Christians’ will be chaff. Where Christians are persecuted a high percentage will be wheat. Since Judaism was part of the prevailing culture, presumably most of John's hearers were chaff. The ‘unquenchable’ fire is presumably a reference to the Lake.\f*   
\ms1 Baptism of Jesus  
\p
\v 13 \w Then|strong="G5119"\w* \w Jesus|strong="G2424"\w* \w came|strong="G3854"\w* \w from|strong="G5259"\w* \w Galilee|strong="G1056"\w* \w to|strong="G4314"\w* \w John|strong="G2491"\w* \w at|strong="G1909"\w* \w the|strong="G1909"\w* \w Jordan|strong="G2446"\w* \w to|strong="G4314"\w* \w be|strong="G3588"\w* baptized \w by|strong="G5259"\w* \w him|strong="G3588"\w*.  
\v 14 \w But|strong="G1161"\w* \w John|strong="G2491"\w* tried \w to|strong="G4314"\w* dissuade \w Him|strong="G3588"\w* \w saying|strong="G3004"\w*, “\w I|strong="G1473"\w* \w have|strong="G2192"\w* \w need|strong="G5532"\w* \w to|strong="G4314"\w* \w be|strong="G2532"\w* baptized \w by|strong="G5259"\w* \w You|strong="G4771"\w*, \w and|strong="G2532"\w* \w You|strong="G4771"\w* \w are|strong="G3588"\w* \w coming|strong="G2064"\w* \w to|strong="G4314"\w* \w me|strong="G1473"\w*?”\f + \fr 3:14 \ft John knew that Jesus was the Messiah.\f*  
\v 15 \w But|strong="G1161"\w* \w in|strong="G3956"\w* answer \w Jesus|strong="G2424"\w* \w said|strong="G3004"\w* \w to|strong="G4314"\w* \w him|strong="G3588"\w*, “Permit \w it|strong="G1161"\w* \w now|strong="G1161"\w*, \w because|strong="G1063"\w* \w thus|strong="G3779"\w* \w it|strong="G1161"\w* \w is|strong="G1510"\w* appropriate \w to|strong="G4314"\w* \w us|strong="G3004"\w* \w to|strong="G4314"\w* \w fulfill|strong="G4137"\w* \w all|strong="G3956"\w* \w righteousness|strong="G1343"\w*.”\f + \fr 3:15 \ft Our Lord's statement here seems difficult to us. Since Mark 1:4 and Luke 3:3 state that it was “a baptism of repentance for forgiveness of sins” but Jesus had no sins to repent of, in what sense was He “fulfilling all righteousness”? Perhaps as Messiah and Great High Priest He needed to identify Himself with those of His people who were truly repentant.\f* \w Then|strong="G5119"\w* \w he|strong="G1161"\w* permitted \w Him|strong="G3588"\w*.  
\v 16 \w And|strong="G2532"\w* \w having|strong="G2532"\w* \w been|strong="G2532"\w* baptized \w Jesus|strong="G2424"\w* \w came|strong="G2064"\w* \w up|strong="G2532"\w* directly \w from|strong="G2064"\w* \w the|strong="G2532"\w* \w water|strong="G5204"\w*, \w when|strong="G1161"\w* \nd wow\nd*, \w the|strong="G2532"\w* \w heavens|strong="G3772"\w* \w were|strong="G3588"\w* opened \w to|strong="G2532"\w* \w Him|strong="G3588"\w*, \w and|strong="G2532"\w* \w he|strong="G2532"\w* \w saw|strong="G3708"\w* \w the|strong="G2532"\w* \w Spirit|strong="G4151"\w* \w of|strong="G4151"\w* \w God|strong="G2316"\w* \w coming|strong="G2064"\w* \w down|strong="G2597"\w* \w like|strong="G5616"\w* \w a|strong="G2532"\w* \w dove|strong="G4058"\w* \w and|strong="G2532"\w* alighting \w upon|strong="G1909"\w* \w Him|strong="G3588"\w*.\f + \fr 3:16 \ft The episode is presented from John's perspective, while in Mark 1:11 and Luke 3:22 it is presented from Jesus' perspective. Just as at Pentecost the Holy Spirit translated into the ears of the foreigners, I take it that here Jesus heard one thing and John another.\f*  
\v 17 \w And|strong="G2532"\w* wow, \w a|strong="G2532"\w* \w Voice|strong="G5456"\w* \w from|strong="G1537"\w* \w the|strong="G1722"\w* \w heavens|strong="G3772"\w* \w saying|strong="G3004"\w*, “\w This|strong="G3778"\w* \w is|strong="G1510"\w* \w my|strong="G3708"\w* \w Son|strong="G5207"\w*, \w the|strong="G1722"\w* beloved, \w in|strong="G1722"\w* \w whom|strong="G3739"\w* \w I|strong="G1473"\w* \w am|strong="G1510"\w* \it always\it* \w well|strong="G2532"\w* \w pleased|strong="G2106"\w*!”\f + \fr 3:17 \ft The Trinity is clearly manifested: voice = Father, Jesus = Son, dove = Holy Spirit. This was an important confirmation for Jesus.\f*   
\c 4  
\ms1 Jesus tested by Satan  
\m
\v 1 \w Then|strong="G5119"\w* \w Jesus|strong="G2424"\w* \w was|strong="G3588"\w* \w led|strong="G2424"\w* \w up|strong="G1519"\w* \w by|strong="G5259"\w* \w the|strong="G1519"\w* \w Spirit|strong="G4151"\w* \w into|strong="G1519"\w* \w the|strong="G1519"\w* \w wilderness|strong="G2048"\w* \w to|strong="G1519"\w* \w be|strong="G1519"\w* \w tested|strong="G3985"\w* \w by|strong="G5259"\w* \w the|strong="G1519"\w* \w devil|strong="G1228"\w*.  
\v 2 \w And|strong="G2532"\w* \w having|strong="G2532"\w* \w fasted|strong="G3522"\w* \w forty|strong="G5062"\w* \w days|strong="G2250"\w* \w and|strong="G2532"\w* \w forty|strong="G5062"\w* \w nights|strong="G3571"\w*, \w afterward|strong="G5305"\w* \w He|strong="G2532"\w* \w was|strong="G2532"\w* \w hungry|strong="G3983"\w*.\f + \fr 4:2 \ft This episode was ordained by the Holy Spirit. Jesus had to confront Satan when He was physically the weakest He would ever be (40 days without food!). When Satan failed to defeat this weakened Jesus he was probably filled with despair—he now knew that he could never defeat Him. (But he would still try to kill Him.)\f*  
\v 3 \w And|strong="G2532"\w* \w coming|strong="G4334"\w* \w to|strong="G2443"\w* \w Him|strong="G3588"\w* \w the|strong="G2532"\w* \w tempter|strong="G3985"\w* \w said|strong="G3004"\w*, “\w Since|strong="G1096"\w* \w you|strong="G1487"\w* \w are|strong="G1510"\w* \w the|strong="G2532"\w* \w Son|strong="G5207"\w* \w of|strong="G5207"\w* \w God|strong="G2316"\w*, \w command|strong="G3004"\w* \w that|strong="G2443"\w* \w these|strong="G3778"\w* \w stones|strong="G3037"\w* \w become|strong="G1096"\w* loaves \w of|strong="G5207"\w* bread.”\f + \fr 4:3 \ft Satan was not so foolish as to question Jesus' identity, “if”; he was more subtle, “since”.\f*  
\v 4 \w But|strong="G1161"\w* \w in|strong="G1909"\w* answer \w He|strong="G1161"\w* \w said|strong="G3004"\w*, “\w It|strong="G1161"\w* \w is|strong="G3588"\w* \w written|strong="G1125"\w*: ‘\w Man|strong="G3956"\w* \w shall|strong="G2316"\w* \w not|strong="G3756"\w* \w live|strong="G2198"\w* \w on|strong="G1909"\w* bread \w alone|strong="G3441"\w*, \w but|strong="G1161"\w* \w by|strong="G1223"\w* \w every|strong="G3956"\w* \w word|strong="G4487"\w* \w coming|strong="G2316"\w* \w out|strong="G1607"\w* \w of|strong="G1223"\w* \w God|strong="G2316"\w*'s \w mouth|strong="G4750"\w*.’ ”\f + \fr 4:4 \ft See Deuteronomy 8:3.\f*  
\v 5 \w Then|strong="G2532"\w* \w the|strong="G2532"\w* \w devil|strong="G1228"\w* \w takes|strong="G3880"\w* \w Him|strong="G3588"\w* \w into|strong="G1519"\w* \w the|strong="G2532"\w* \w holy|strong="G2413"\w* \w city|strong="G4172"\w*\f + \fr 4:5 \ft ‘The holy city’ was evidently Jerusalem. One is tempted to ask, what was ‘holy’ about it?\f* \w and|strong="G2532"\w* sets \w Him|strong="G3588"\w* \w upon|strong="G1909"\w* \w the|strong="G2532"\w* \w pinnacle|strong="G4419"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w temple|strong="G2413"\w*,\f + \fr 4:5 \ft This is literal; Satan has the power to transport things. Matthew has the correct sequence, whereas Luke inverts the order of tests 2 and 3 (Matthew uses adverbs of sequence, but Luke does not).\f*  
\v 6 \w and|strong="G2532"\w* \w says|strong="G3004"\w* \w to|strong="G4314"\w* \w Him|strong="G3588"\w*, “\w Since|strong="G3754"\w* \w you|strong="G4771"\w* \w are|strong="G1510"\w* \w the|strong="G2532"\w* \w Son|strong="G5207"\w* \w of|strong="G5207"\w* \w God|strong="G2316"\w*, throw \w yourself|strong="G4572"\w* \w down|strong="G2736"\w*; \w for|strong="G1063"\w* \w it|strong="G2532"\w* \w is|strong="G1510"\w* \w written|strong="G1125"\w*:  
\q1 ‘\w He|strong="G2532"\w* \w will|strong="G2316"\w* \w give|strong="G3004"\w* \w orders|strong="G1781"\w* \w to|strong="G4314"\w* \w His|strong="G4012"\w* angels \w about|strong="G4012"\w* \w you|strong="G4771"\w*,  
\q2 \w and|strong="G2532"\w* \w they|strong="G2532"\w* \w will|strong="G2316"\w* lift \w you|strong="G4771"\w* \w up|strong="G2532"\w* \w on|strong="G1909"\w* \w their|strong="G2532"\w* \w hands|strong="G5495"\w*,  
\q1 \w lest|strong="G3379"\w* \w you|strong="G4771"\w* \w strike|strong="G4350"\w* \w your|strong="G2532"\w* \w foot|strong="G4228"\w* \w against|strong="G1909"\w* \w a|strong="G2532"\w* \w stone|strong="G3037"\w*.’ ”\f + \fr 4:6 \ft See Psalm 91:11-12. Satan knows the Bible, and how to twist it.\f*   
\p
\v 7 \w Jesus|strong="G2424"\w* \w said|strong="G5346"\w* \w to|strong="G3756"\w* \w him|strong="G3588"\w*, “\w It|strong="G3825"\w* \w is|strong="G3588"\w* \nd \+w also|strong="G2316"\+w*\nd* \w written|strong="G1125"\w*: ‘\w You|strong="G4771"\w* \w shall|strong="G2316"\w* \w not|strong="G3756"\w* \w test|strong="G1598"\w* \w the|strong="G3588"\w* \sc \+w Lord|strong="G2962"\+w*\sc* \w your|strong="G2962"\w* \w God|strong="G2316"\w*!’ ”\f + \fr 4:7 \ft See Deuteronomy 6:16. The point is to not put God to the test, to not deliberately do something irresponsible with the intention of obliging God to work a miracle to save you.\f*  
\v 8 \w Again|strong="G3825"\w* \w the|strong="G2532"\w* \w devil|strong="G1228"\w* \w takes|strong="G3880"\w* \w Him|strong="G3588"\w* \w to|strong="G1519"\w* \w a|strong="G2532"\w* \nd \+w very|strong="G3029"\+w*\nd* \w high|strong="G5308"\w* \w mountain|strong="G3735"\w* \w and|strong="G2532"\w* \w shows|strong="G1166"\w* \w Him|strong="G3588"\w* \w all|strong="G3956"\w* \w the|strong="G2532"\w* kingdoms \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w world|strong="G2889"\w* \w and|strong="G2532"\w* \w their|strong="G2532"\w* \w glory|strong="G1391"\w*.\f + \fr 4:8 \ft This also is literal and obviously supernatural (since the world is a sphere, even from a satellite one can only see half of it). We have here a master stroke of Satan—Jehovah the Son took on human form in order to recover what the first Adam had lost, and Satan offers it to Him on a silver platter, with just one ‘small’ condition…\f*  
\v 9 \w And|strong="G2532"\w* \w he|strong="G2532"\w* \w says|strong="G3004"\w* \w to|strong="G2532"\w* \w Him|strong="G1325"\w*, “\w All|strong="G3956"\w* \w these|strong="G3778"\w* \w things|strong="G3956"\w* \w I|strong="G1473"\w* \w will|strong="G2532"\w* \w give|strong="G1325"\w* \w to|strong="G2532"\w* \w you|strong="G4771"\w*, \w if|strong="G1437"\w* \w You|strong="G4771"\w* \w will|strong="G2532"\w* \w fall|strong="G4098"\w* \w down|strong="G4098"\w* \w and|strong="G2532"\w* \w worship|strong="G4352"\w* \w me|strong="G1325"\w*.”  
\v 10 \w Then|strong="G2532"\w* \w Jesus|strong="G2424"\w* \w says|strong="G3004"\w* \w to|strong="G2532"\w* \w him|strong="G3588"\w*: “\w Get|strong="G5217"\w* behind \w me|strong="G3004"\w*, \w Satan|strong="G4567"\w*!\f + \fr 4:10 \ft 88% of the Greek manuscripts have “Get behind me…”; in Luke 4:8 at least 97% have “Get behind me…”.\f* \w For|strong="G1063"\w* \w it|strong="G2532"\w* \w is|strong="G3588"\w* \w written|strong="G1125"\w*: ‘\w You|strong="G4771"\w* \w shall|strong="G2532"\w* \w worship|strong="G4352"\w* \w the|strong="G2532"\w* \sc \+w Lord|strong="G2962"\+w*\sc* \w your|strong="G2962"\w* \w God|strong="G2316"\w*, \w and|strong="G2532"\w* \w Him|strong="G3588"\w* \w only|strong="G3441"\w* \w shall|strong="G2532"\w* \w you|strong="G4771"\w* \w serve|strong="G3000"\w*.’ ”\f + \fr 4:10 \ft See Deuteronomy 6:13. Note that Jesus did not deny his right to make the offer.\f*  
\v 11 \w Then|strong="G2532"\w* \w the|strong="G2532"\w* \w devil|strong="G1228"\w* leaves \w Him|strong="G3588"\w*, \w and|strong="G2532"\w* \nd \+w then|strong="G2532"\+w*\nd*, angels \w came|strong="G4334"\w* \w and|strong="G2532"\w* \w began|strong="G5119"\w* \w ministering|strong="G1247"\w* \w to|strong="G2532"\w* \w Him|strong="G3588"\w*.\f + \fr 4:11 \ft The impression one gets is that the angels were not allowed to help Jesus during His direct confrontation with Satan.\f*   
\ms1 Jesus chooses Capernaum as His base of operations—27 AD  
\p
\v 12 \w Now|strong="G1161"\w* hearing \w that|strong="G3754"\w* \w John|strong="G2491"\w* \w had|strong="G3588"\w* been \w put|strong="G1519"\w* \w in|strong="G1519"\w* \w prison|strong="G3860"\w*, Jesus departed \w into|strong="G1519"\w* \w Galilee|strong="G1056"\w*.\f + \fr 4:12 \ft The early Judean ministry, as recorded in John 1, 2 and 3, ends here.\f*  
\v 13 \w And|strong="G2532"\w* \w leaving|strong="G2641"\w* Natsareth \w behind|strong="G2641"\w*,\f + \fr 4:13 \ft See Luke 4:16-30. Presumably Jesus moved His belongings out of Natsareth at this time.\f* \w He|strong="G2532"\w* \w went|strong="G2064"\w* \w and|strong="G2532"\w* \w took|strong="G2532"\w* \w up|strong="G1519"\w* residence \w in|strong="G1722"\w* \w Capernaum|strong="G2584"\w* \w by|strong="G1722"\w* \w the|strong="G1722"\w* \w sea|strong="G3864"\w*, \w in|strong="G1722"\w* \w the|strong="G1722"\w* regions \w of|strong="G2532"\w* \w Zebulun|strong="G2194"\w* \w and|strong="G2532"\w* \w Naphtali|strong="G3508"\w*;  
\v 14 \w so|strong="G2443"\w* \w that|strong="G2443"\w* \w what|strong="G3588"\w* \w was|strong="G3588"\w* \w spoken|strong="G3004"\w* \w through|strong="G1223"\w* \w Isaiah|strong="G2268"\w* \w the|strong="G1223"\w* \w prophet|strong="G4396"\w* \w should|strong="G3588"\w* \w be|strong="G2443"\w* \w fulfilled|strong="G4137"\w*, namely:   
\q1
\v 15 “\w Land|strong="G1093"\w* \w of|strong="G2532"\w* \w Zebulun|strong="G2194"\w* \w and|strong="G2532"\w* \w land|strong="G1093"\w* \w of|strong="G2532"\w* \w Naphtali|strong="G3508"\w*,  
\q2 \w way|strong="G3598"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w sea|strong="G2281"\w*, \w beyond|strong="G4008"\w* \w the|strong="G2532"\w* \w Jordan|strong="G2446"\w*, \w Galilee|strong="G1056"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w nations|strong="G1484"\w*!   
\q1
\v 16 \w The|strong="G1722"\w* \w people|strong="G2992"\w* \w sitting|strong="G2521"\w* \w in|strong="G1722"\w* \w darkness|strong="G4655"\w* \w saw|strong="G3708"\w* \w a|strong="G2532"\w* \w great|strong="G3173"\w* \w light|strong="G5457"\w*,  
\q2 \w and|strong="G2532"\w* \w upon|strong="G1722"\w* \w those|strong="G3588"\w* \w sitting|strong="G2521"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w place|strong="G1722"\w* \w and|strong="G2532"\w* \w shadow|strong="G4639"\w* \w of|strong="G2532"\w* \w death|strong="G2288"\w*  
\q2 \w light|strong="G5457"\w* \w has|strong="G3708"\w* dawned.”\f + \fr 4:16 \ft See Isaiah 9:1-2.\f*   
\s1 Jesus calls four fishermen  
\p
\v 17 \w From|strong="G2532"\w* \w then|strong="G2532"\w* \w on|strong="G3004"\w* \w Jesus|strong="G2424"\w* \w began|strong="G5119"\w* \w to|strong="G2532"\w* \w preach|strong="G2784"\w* \w and|strong="G2532"\w* \w to|strong="G2532"\w* \w say|strong="G3004"\w*, “\w Repent|strong="G3340"\w*, \w for|strong="G1063"\w* \w the|strong="G2532"\w* kingdom \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w heavens|strong="G3772"\w* \w has|strong="G2532"\w* \w come|strong="G2532"\w* \w near|strong="G1448"\w*.”\f + \fr 4:17 \ft Right! The King was walking among them. “Kingdom of the heavens” and “kingdom of God” are synonyms, as can be seen by comparing parallel passages in Mark and Luke. Jesus continues with John's message, since the herald is now out of action.\f*  
\v 18 \w And|strong="G2532"\w* \w walking|strong="G4043"\w* \w by|strong="G3844"\w* \w the|strong="G2532"\w* \w Sea|strong="G2281"\w* \w of|strong="G2532"\w* \w Galilee|strong="G1056"\w* \w He|strong="G2532"\w* \w saw|strong="G3708"\w* \w two|strong="G1417"\w* brothers, \w Simon|strong="G4613"\w* (\w the|strong="G2532"\w* \w one|strong="G3588"\w* \w called|strong="G3004"\w* \w Peter|strong="G4074"\w*) \w and|strong="G2532"\w* Andrew \w his|strong="G1519"\w* brother, casting \w a|strong="G2532"\w* circular net \w into|strong="G1519"\w* \w the|strong="G2532"\w* \w sea|strong="G2281"\w* (\w for|strong="G1063"\w* \w they|strong="G2532"\w* \w were|strong="G1510"\w* fishermen).  
