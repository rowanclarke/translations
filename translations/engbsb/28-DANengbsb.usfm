\m 
\v 21 \w Then|strong="H1768"\w* \w Daniel|strong="H1841"\w* \w replied|strong="H6032"\w*, “\w O|strong="H3068"\w* \w king|strong="H4430"\w*, \w may|strong="H2417"\w* \w you|strong="H1768"\w* live forever!
