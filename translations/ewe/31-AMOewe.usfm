\id AMO - Biblica® Open Ewe Contemporary Scriptures 2020
\h Amos
\toc1 Amos ƒe agbalẽ
\toc2 Amos
\toc3 Amo
\mt1 Amos
\mt2 ƒe agbalẽ
\c 1
\p 
\v 1 Esiawoe nye Amos, lãkplɔla siwo tso Tekoa la dometɔ ɖeka ƒe nyawo. Ekpɔ ŋutega tso Israel ŋuti ƒe eve do ŋgɔ na anyigba ƒe ʋuʋu, esime Uzia nɔ fia ɖum le Yuda, eye Yoas ƒe vi, Yeroboam, nɔ fia ɖum le Israel.
\b
\b
\p 
\v 2 Egblɔ be,
\q1 “Yehowa ɖe gbe abe dzata ene tso Zion,
\q2 eye eƒe gbe ɖi tso Yerusalem.
\q1 Enumake lãnyiƒewo ƒu kplakplakpla,
\q2 eye Karmel to la tame yrɔ.”
\s1 Ʋɔnudɔdrɔ̃ dukɔ siwo ƒo xlã Israel
\p 
\v 3 Ale Yehowa gblɔe nye esi:
\q1 “Le Damasko ƒe nu vɔ̃ gbogbo
\q2 siwo wòwɔ edziedzi ta la,
\q1 nyematsɔ wo akee o,
\q2 elabena edugu Gilead kple galuƒomɔ
\q2 abe ale si wotsɔa galuƒomɔ dugua lu ene.
\q1 
\v 4 Eya ta matɔ dzo Fia Hazael ƒe fiasã,
\q2 eye magbã Ben Hadad ƒe mɔ sesẽwo.
\q1 
\v 5 Maŋe gameti sesẽ siwo wotsɔ do Damasko ƒe agbowoe,
\q2 eye mawu fia si le Aven ƒe Balime,
\q1 kple ame si le fia ɖum le Bet Eden,
\q2 eye woaɖe aboyo Siriatɔwo ayi ɖe Kir.”
\q2 Yehowae gblɔe.
\p 
\v 6 Ale Yehowa gblɔe nye esi,
\q1 “Le Gaza ƒe nu vɔ̃ gbogboawo ta la,
\q2 nyematsɔ wo akee o,
\q1 elabena eɖe aboyo nye ameha gã aɖe,
\q2 eye wòdzra wo kluviwoe na Edom.
\q1 
\v 7 Eya ta matɔ dzo Gaza ƒe gliwo,
\q2 eye dzo afia eƒe mɔ sesẽwo.
\q1 
\v 8 Matsrɔ̃ Asdod nɔlawo katã, mawu Askelontɔwo ƒe fia,
\q2 eye magbã Ekron va se ɖe esime Filistitɔ mamlɛawo atsrɔ̃.”
\q2 Aƒetɔ Mawue gblɔe.
\p 
\v 9 Ale Yehowa gblɔe nye esi,
\q1 “Le Tiro ƒe nu vɔ̃ gbogboawo ta la,
\q2 nyematsɔ wo akee o,
\q1 elabena eda le nubabla si le eya
\q2 kple Israel dome la dzi, eye wòdze edzi,
\q1 wɔ aʋa kplii hekplɔe yi ɖe kluvinyenye me le Edom.
\q1 
\v 10 Le esia ta matɔ dzo Tiro ƒe gliwo,
\q2 eye eƒe mɔ sesẽwo abi azu afi.”
\p 
\v 11 Ale Yehowa gblɔe nye esi:
\q1 “Le Edom ƒe nu vɔ̃ gbogboawo ta la,
\q2 nyematsɔ wo akee o, elabena eɖe
\q1 Israel ɖe nu kple yi, eye wòlé dziku ɖe dɔ me ɖikaa,
\q2 hegbe be yemakpɔ nublanui nɛ o.
\q1 
\v 12 Eya ta matɔ dzo Teman,
\q2 eye wòabi Bozra ƒe mɔ sesẽwo.”
\p 
\v 13 Ale Yehowa gblɔe nye esi:
\q1 “Le Amon ƒe nu vɔ̃ gbogboawo ta la,
\q2 nyematsɔ wo akee o,
\q1 elabena le woƒe aʋa si wowɔ le Gilead be
\q2 yewoakeke yewoƒe liƒowo ɖe edzi me la,
\q2 wotsɔ yi dze ƒodo na Gilead ƒe funɔwo.
\q1 
\v 14 Eya ta matɔ dzo Raba ƒe gli sesẽwo,
\q2 eye wòabi eƒe mɔwo le aʋaɣli ƒe ɖiɖi me le aʋakpegbe
\q2 kple yaƒoƒo sesẽ le ahomtugbe.
\q1 
\v 15 Woƒe fiawo kple amegãwo katã ayi aboyome.”
\q2 Yehowae gblɔe.
\c 2
\p 
\v 1 Ale Yehowa gblɔe nye esi:
\q1 “Le Moab ƒe nu vɔ̃ gbogboawo ta la,
\q2 nyematsɔ wo akee o,
\q1 elabena etsɔ Edom fia ƒe ƒuwo me akaloe.
\q1 
\v 2 Eya ta mana dzo nava fia Moab,
\q2 eye wòabi mɔ sesẽ siwo le Keriyɔt.
\q1 Moab fia ŋutɔ atsrɔ̃ le ʋunyaʋunya me le aʋaɣli
\q2 kple kpẽwo ƒe ɖiɖi me,
\q1 
\v 3 eye mawu eƒe fia
\q2 kple eŋutimewo katã.”
\q2 Yehowae gblɔe.
\p 
\v 4 Ale Yehowa gblɔe nye esi:
\q1 “Le Yuda ƒe nu vɔ̃ gbogboawo ta la,
\q2 nyematsɔ wo akee o,
\q1 elabena egbe nu le Yehowa ƒe seawo gbɔ,
\q2 eye wògbe eƒe ɖoɖowo dzi wɔwɔ,
\q1 ke boŋ ena eƒe alakpalegba siwo yome
\q2 wo fofowo dze la kplɔe trae,
\q1 
\v 5 eya ta mana dzo nava fia Yuda,
\q2 eye wòafia Yerusalem ƒe mɔ sesẽwo.”
\s1 Ʋɔnudɔdrɔ̃ Israel
\p 
\v 6 “Le Israel ƒe nu vɔ̃ gbogboawo ta la,
\q1 “Nyematsɔ wo akee o,
\q2 elabena etsɔ ame dzɔdzɔe dzra ɖe klosalo ta,
\q1 eye wòtsɔ ame dahe dzra
\q2 ɖe atokota dodo ɖeka pɛ ta.
\q1 
\v 7 Wotea ame dahewo ɖe to,
\q2 eye wotrɔa gbo nya dzɔdzɔewo
\q2 na ame gblɔe siwo wote ɖe to.
\q1 Vɔ̃ɖitɔe nye be,
\q2 ŋutsu kple via dea ɖetugbi ɖeka gbɔ
\q2 heƒoa ɖi nye ŋkɔ kɔkɔe la.
\q1 
\v 8 Woɖoa atsyɔ̃ kple avɔ siwo
\q2 woxɔ le fenyilawo si le vɔsamlekpuiwo katã gbɔ,
\q1 eye wonoa nyadrɔ̃ha siwo woxɔ le
\q2 woƒe mawuwo ƒe aƒe me.
\b
\q1 
\v 9 “Metsrɔ̃ Amoritɔwo le wo ŋgɔ,
\q2 togbɔ be wodzɔ atsu abe sedati,
\q1 eye wosẽ abe sesewu ene hã la, meho wo kple ke.
\q1 
\v 10 Mekplɔ wò do goe tso Egipte,
\q2 eye mekplɔ wò le gbedzi ƒe blaene sɔŋ,
\q1 be woava xɔ Amoritɔwo ƒe anyigba.
\q1 
\v 11 Meɖo mia viŋutsuwo nyagblɔɖilawo
\q2 kple míaƒe ɖekakpuiwo Mawu ƒe kluwo na Israel;
\q1 ɖe nàte ŋu agblɔ be esiawo katã mele eme oa?
\q2 Yehowae gblɔe.
\q1 
\v 12 Gake miena wain Mawu ƒe kluwo wono.
\q2 Gawu la, miegbe na nyagblɔɖilawo be womagblɔ nya ɖi o.
\b
\q1 
\v 13 “Eya ta mate mi ɖe to abe ale si keke si
\q2 wodo bligba na fũu la yia toe ene.
\q1 
\v 14 Miaƒe aʋawɔla ɖeablawo mate ŋu asi, akpɔ sitsoƒe o,
\q2 ame sesẽwo mate ŋu azã woƒe ŋusẽ o,
\q2 eye kalẽtɔ mate ŋu aɖe eƒe agbe o.
\q1 
\v 15 Aŋutrɔdala manɔ te adae o,
\q2 asrafo zazɛ̃wo mate ŋu asi o,
\q2 eye sɔdola nyuitɔ mate ŋu ado sɔ asi le tsɔtsrɔ̃ la nu o.
\q1 
\v 16 Dzideƒotɔ siwo le kalẽtɔwo dome
\q2 hã asi amamae gbe ma gbe.”
\q2 Yehowae gblɔe.
\c 3
\s1 Ɖasefowo yɔyɔ ɖe Israel ŋu
\p 
\v 1 O Israel, se nya si Yehowa gblɔ tso mi ƒome blibo si wòkplɔ tso Egipte la ŋu ɖa.
\q1 
\v 2 “Le amegbetɔƒome siwo katã le anyigba dzi dome la,
\q2 miawo ko metia,
\q1 eya ta wòle be mahe to
\q2 na mi vevie ɖe miaƒe nu vɔ̃wo ta ɖo,
\q1 
\v 3 elabena aleke ame eve ate ŋu
\q2 azɔ ɖekae ne womeɖo gbe ɖi o?”
\b
\q1 
\v 4 Ɖe dzata ɖea gbe le ave me
\q2 ne melé nu oa?
\q1 Ɖe dzata tea gbe le eƒe do me
\q2 ne mekpɔ lé nu haɖe oa?
\q1 
\v 5 Ɖe xevi dzona ɖe mɔ dzi le anyigba,
\q2 ne wometre mɔ nɛ oa?
\q1 Alo ɖe mɔ fena, ne naneke meɖo eme oa?
\q1 
\v 6 Ne kpẽ ɖi le du me la,
\q2 ɖe dua me tɔwo mevɔ̃na oa?
\q1 Ne dzɔgbevɔ̃e va du aɖe dzi la,
\q2 ɖe menye Yehowae ɖe mɔ oa?
\b
\q1 
\v 7 Eya ta Yehowa Ŋusẽkatãtɔ,
\q2 mewɔa naneke ne meɖe eƒe ɖoɖo fia
\q2 eƒe dɔla nyagblɔɖilawo hafi o.
\b
\q1 
\v 8 Dzata ɖe gbe, ame kae mavɔ̃ o.
\q2 Yehowa Mawu ƒo nu, ame kae agbe be
\q2 yemagblɔ nya ɖi o.
\b
\q1 
\v 9 Miɖe gbeƒã le Asdod
\q2 kple Egipte fiasãwo me be,
\q1 “Miƒo ƒu mia ɖokuiwo ɖe Samaria towo dzi,
\q2 ne miakpɔ ʋunyaʋunya gã
\q1 kple teteɖeanyi siwo le edzi yim le dukɔ la dome.”
\b
\q1 
\v 10 Yehowa be, “Nye dukɔ ŋlɔ nu nyui wɔwɔ be,
\q2 woƒe aƒe nyuiwo me yɔ kple nu siwo wofi
\q2 kple nu siwo woda adzoe.”
\p 
\v 11 Yehowa Mawu be,
\q1 “Eya ta futɔ aɖe ava nye avuzi le miaƒe anyigba dzi,
\q2 agbã miaƒe mɔ sesẽwo,
\q2 eye wòaha miaƒe fiasãwo.”
\p 
\v 12 Ale Yehowa gblɔe nye si,
\q1 “Abe ale si Alẽkplɔla ɖea lã ƒe ata eve
\q2 kple to kakɛ aɖe ko le dzata ƒe nu me la,
\q1 nenema kee wòanɔ na Israelvi siwo nɔ Samaria
\q2 le aba ƒe dzogoe dzi
\q2 kple ame siwo nɔ aba ƒe kundru dzi.”
\p 
\v 13 Aƒetɔ Yehowa, Dziƒoʋakɔwo ƒe Mawu la gblɔ be,
\q1 “Misee, eye miagblɔe na Yakob ƒe aƒe la be:
\q1 
\v 14 Gbe si gbe mahe to na Israel ɖe eƒe nu vɔ̃wo ta la,
\q2 gbe ma gbe kee matsrɔ̃ legba siwo katã le Betel.
\q1 Woaŋe vɔ̃samlekpui la ƒe dzowo woage ɖe anyigba.
\q1 
\v 15 Magbã kesinɔtɔwo ƒe aƒe nyuiwo,
\q2 akaka woƒe vuvɔŋɔlixɔ dranyiwo
\q2 kple woƒe dzomeŋɔlixɔwo.
\q1 Matsrɔ̃ woƒe nyiɖuxɔwo, eye magbã woƒe sãwo,”
\q2 Yehowae gblɔe.
\c 4
\s1 Israel metrɔ va Mawu gbɔ o
\q1 
\v 1 “Miɖo tom, mi Basan nyinɔ dami siwo le Samaria towo dzi,
\q2 mi nyɔnu siwo baa hiãtɔwo,
\q1 eye mietea ame dahewo ɖe to hegblɔna
\q2 na mia srɔ̃wo be, midi aha vɛ míano!
\q1 
\v 2 Yehowa Ŋusẽkatãtɔ la ta eƒe kɔkɔenyenye,
\q2 be ɣeyiɣi li gbɔna esime yeaɖe mi
\q2 kple miaƒe dzidzimeviwo kple ƒu.
\q1 
\v 3 Woakplɔ mi ato gliwo ƒe gbagbãƒee,
\q2 miakpɔ ŋgɔ tẽe, eye woatsɔ mi aƒu gbe ɖo ɖe Harmon.”
\q2 Yehowae gblɔe.
\q1 
\v 4 “Miva Betel ne miawɔ nu vɔ̃.
\q2 Miyi Gilgal ne miadzi miaƒe nu vɔ̃wo ɖe edzi,
\q1 mitsɔ vɔsawo vɛ ŋdi sia ŋdi;
\q2 mitsɔ nu ewoliawo vɛ
\q2 ŋkeke etɔ̃ sia ŋkeke etɔ̃.
\q1 
\v 5 Mitsɔ amɔʋaʋãbolo wɔ akpedavɔsae.
\q2 Miɖe gbeƒã lɔlɔ̃nununana.
\q1 Migblɔe dadatɔe, elabena nenema mielɔ̃a wɔwɔ.
\q2 O, Israel!”
\q2 Yehowa Ŋusẽkatãtɔ lae gblɔe.
\b
\q1 
\v 6 “Medɔ dɔwuame ɖe miaƒe duwo me,
\q2 gake mewɔ naneke le mia ŋuti o,
\q2 eye miegbe be yewomatrɔ ɖe ŋutinye o.”
\q2 Yehowae gblɔe.
\b
\q1 
\v 7 “Ɣleti etɔ̃ hafi miadze miaƒe nukuwo ŋeŋe gɔme la,
\q2 mena tsidzadza tɔ kplo zi ɖeka,
\q2 eye miaƒe nukuwo gblẽ.
\q1 Medɔa tsi wòdzana ɖe du ɖeka dzi,
\q2 medzana ɖe bubuwo dzi o.
\q1 Ale ne tsi le dzadzam ɖe agble aɖe dzi la,
\q2 bubuawo me ƒuna kplakplakpla,
\q2 eye woƒe nukuawo fiana.
\q1 
\v 8 Amewo tsoa du siwo me ku le ɖiɖim le,
\q2 eye wozɔa mɔ didi yia tsidiƒe
\q1 le du bubu me afi si tsi le dzadzam le,
\q2 gake womekpɔnɛ kuna o.
\q1 Ele alea, gake miegbe be yewomatrɔ ɖe ŋutinye o.”
\q2 Yehowae gblɔe.
\b
\q1 
\v 9 “Mena miaƒe bliwo dze heteku, eye wohlɔ̃;
\q2 mena ʋetsuviwo ɖu miaƒe wainkawo kple amitiwo,
\q1 gake miegbe be yewomatrɔ ɖe ŋutinye o.”
\q2 Yehowae gblɔe.
\b
\q1 
\v 10 “Mena dɔvɔ̃wo va dze mia dzi
\q2 abe esiwo mehe va Egiptetɔwo dzi le blema ene.
\q1 Mena mia viwo tsi aʋa,
\q2 eye menya miaƒe sɔwo de gbe.
\q1 Ame kukuwo na miaƒe asaɖa me le ʋeʋẽm kũu,
\q2 gake miegbe, mietrɔ ɖe ŋutinye o.”
\q2 Yehowae gblɔe.
\b
\q1 
\v 11 “Metsrɔ̃ miaƒe du aɖewo
\q2 abe ale si metsrɔ̃ Sodom kple Gomorae ene;
\q1 ame siwo susɔ la le abe atikpo si
\q2 woɖe tso dzo me la ene,
\q1 gake miegbe, mietrɔ ɖe ŋutinye o.”
\q2 Yehowae gblɔe.
\b
\q1 
\v 12 “Eya ta ale mawɔ na wò, O Israel!
\q2 Esi wònye aleae mawɔ na wò ta la,
\q1 dzra ɖo nàdo go wò Mawu, O Israel!”
\b
\q1 
\v 13 Ame si wɔ towo kple ya,
\q2 eye wòɖea eƒe susuwo fiaa amegbetɔ,
\q1 eyae trɔa ŋdi wòzua viviti,
\q2 eye wògbãa towo ɖe eƒe afɔ te gudugudu.
\q2 Eŋkɔe nye Yehowa, Dziƒoʋakɔwo ƒe Mawu la.
\c 5
\s1 Konyifafa kple yɔyɔ na dzimetɔtrɔ
\p 
\v 1 “O! Israel ƒe aƒe, metsɔ blanuiléle dzi konyifaha sia na wò:
\q1 
\v 2 “Ɖetugbi Israel dze anyi, eye magafɔ akpɔ o.
\q2 Wogbe nu le egbɔ le eya ŋutɔ ƒe anyigba dzi,
\q1 eye ame aɖeke meli alé eƒe alɔnu afɔe ɖe tsitre o,
\q1 
\v 3 elabena Aƒetɔ Yehowa gblɔ na Israel be,
\q2 ‘Ne du aɖe ɖo ame akpe ɖeka ɖe aʋa la,
\q1 ame alafa ɖeka koe agbɔ,
\q2 eye du si ɖo ame alafa ɖeka ɖa la
\q2 ame ewo koe agbɔ.’ ”
\p 
\v 4 Yehowa gblɔ na Israel ƒe aƒe la be,
\q1 “Midim, ne mianɔ agbe.
\q2 
\v 5 Migati legba siwo le Betel,
\q1 Gilgal alo Beerseba yome o,
\q2 elabena maɖe aboyo Gilgatɔwo,
\q2 eye Betel atsrɔ̃.”
\q1 
\v 6 Midi Yehowa ne mianɔ agbe,
\q2 ne menye nenema o la;
\q1 miabi abe dzo ene ato Yosef ƒe aƒe dzi,
\q2 afia Betel, eye ame aɖeke mate ŋu atsii o.
\b
\q1 
\v 7 O, mi ame siwo trɔ afia nyui tsotso wòzu vevesese,
\q2 eye mietsɔ dzɔdzɔenyenye ƒu gbe ɖe anyigba!
\b
\q1 
\v 8 Midi ame si wɔ ɣletiviwo ƒe ha siwo woyɔna be atifieŋui,
\q2 avu kple avutɔ, ame si trɔa viviti tsiɖitsiɖi wòzua kekeli,
\q2 eye wòtrɔa ŋkeke wòzua zã.
\q1 Eyae yɔa tsi tso atsiaƒu me be
\q2 wòaho ayi dzi ahadza ɖe anyigba dzi.
\q1 Aƒetɔ Yehowae nye eƒe ŋkɔ.
\q1 
\v 9 Le aɖabaƒoƒo ɖeka me la,
\q2 enana gbegblẽ vaa ame sesẽ dzi,
\q2 eye wògbãa eƒe gli sesẽwo.
\b
\q1 
\v 10 Mielé fu ame siwo toa nyateƒe le ʋɔnu,
\q2 eye miele fu nyateƒetola.
\q1 
\v 11 Esi miefanya ame dahewo kple afɔ,
\q2 eye mieba wo le blidzɔxɔxɔ me ta la,
\q1 mianɔ kpexɔ nyui siwo tum miele la me
\q2 alo ano wain tso waingble siwo dem miele la me o.
\b
\q1 
\v 12 Elabena wò nu vɔ̃wo sɔ gbɔ hetri akɔ.
\q2 Menya wo katã nyuie.
\q1 Èsẽa ŋuta le ame dzɔdzɔe ŋu,
\q2 eye nèxɔa zãnu hetrɔa gbo ame dahe ƒe nya dzɔdzɔe,
\q1 
\v 13 eya ta ame siwo nye nunyalawo la,
\q2 azi ɖoɖoe le ɣeyiɣi mawo me,
\q2 elabena ɣeyiɣi vɔ̃e wònye.
\b
\q1 
\v 14 Midi nyui, miasi le vɔ̃ nu ne mianɔ agbe!
\q2 Ekema Yehowa,
\q1 Mawu Dziƒoʋakɔwo ƒe Aƒetɔ la,
\q2 anye kpeɖeŋutɔ vavã na mi abe ale si
\q2 miawo ŋutɔ miegblɔ la ene.
\q1 
\v 15 Mitsri nu vɔ̃ eye mialɔ̃ nyui.
\q2 Mitrɔ miaƒe ʋɔnudrɔ̃ƒewo woazu afia nyui tsoƒewo.
\q1 Ɖewohĩ Yehowa, Dziƒoʋakɔwo ƒe Mawu la,
\q1 akpɔ nublanui na Yosef ƒe aƒe ƒe ame mamlɛawo.
\p 
\v 16 Ale Yehowa, Mawu Dziƒoʋakɔwo ƒe Aƒetɔ la gblɔe nye esi:
\q1 “Avifafa anɔ kpɔdomewo, eye asiƒonu anɔ mɔ dodowo dzi.
\q2 Míyɔ agbledelawo hã be woafa avi kpli mi;
\q2 miyɔ konyifalawo hã vɛ be woafa avi kpli mi.
\q1 
\v 17 Avifafa anɔ waingble ɖe sia ɖe me,
\q2 elabena mava to afi ma akaka agbleawo.”
\q2 Yehowae gblɔe.
\s1 Aƒetɔ la ƒe ŋkeke
\q1 
\v 18 Baba na mi, ame siwo tsi dzi
\q2 ɖe Yehowa ƒe ŋkeke la ƒe vava ŋuti.
\q1 Nu ka ta mietsi dzi ɖe
\q2 Yehowa ƒe ŋkeke la ƒe vava ŋuti ɖo?
\q1 Ŋkeke ma anye viviti,
\q2 manye kekeli o.
\q1 
\v 19 Le ŋkeke ma dzi la,
\q2 mianɔ abe ame si
\q1 si le dzata nu ɖake ɖe sisiblisi ŋuti la ene,
\q2 eye esi wòƒu du ɖo aƒe me heziɔ ɖe gli ŋuti la, da ɖui.
\q1 
\v 20 Ɖe Yehowa ƒe ŋkeke la menye viviti,
\q2 eye menye kekeli oa?
\q1 Ɖe menye blukɔe wònye,
\q2 eye keklẽ mele eme oa?
\b
\q1 
\v 21 “Melé fu miaƒe ŋkekenyuiwo, eye metsri wo.
\q2 Nyemaʋẽ miaƒe takpekpewo
\q2 kple ŋkekenyuiwo ase o.
\q1 
\v 22 Ne miewɔ numevɔsa kple nuɖuvɔsawo nam hã la,
\q2 nyemaxɔ wo o.
\q1 Ne mietsɔ miaƒe lã damiwo sa vɔe nam hã la,
\q2 nyemanye kɔ akpɔ wo o.
\q1 
\v 23 Te wò hawo ƒe ɖiɖi ɖe megbe tso gbɔnye,
\q2 wò saŋkuƒoƒowo hã le to me vem nam!
\q1 
\v 24 Nya dzɔdzɔe nesi abe tsi ene,
\q2 eye dzɔdzɔenyenye abe tɔʋu si memiena o ene!
\b
\q1 
\v 25 “O, Israelviwo, nyee mietsɔ lã wuwuwo kple numemewo sa vɔ na
\q2 esi mienɔ gbedzi ƒe blaene sɔŋ?
\q1 
\v 26 Miekɔ miaƒe fia, Sakut kple Kaiwan, miaƒe ɣletivimawu
\q2 siwo ƒe nɔnɔme miewɔ na mia ɖokuiwo la ɖe dzi,
\q1 
\v 27 eya ta maɖo mi ɖe aboyo me le Damasko godo.”
\q2 Yehowa, ame si ŋkɔe nye Dziƒoʋakɔwo ƒe Mawu lae gblɔe.
\c 6
\s1 Baba na ame siwo susuna be yewode le yewo ɖokuiwo me
\q1 
\v 1 Baba na mi, ame siwo ɖe dzi ɖi bɔkɔɔ le Zion
\q2 kple ame siwo susu be yewosu te le Samaria towo dzi,
\q1 mi ame siwo nye ame veviwo
\q2 kple ame ŋkutawo le Israel,
\q2 ame siwo gbɔ dukɔ la xɔa aɖaŋu le.
\q1 
\v 2 Miyi ɖe Kalne ne miakpɔ nu si dzɔ le afi ma la ɖa;
\q2 eye miayi ɖe du gã Hamat me, ahaɖiɖi ɖe Gat,
\q1 Filistitɔwo ƒe anyigba dzi, akpɔ nu si dzɔ la ɖa.
\q2 Ɖe mienyo wu fiaɖuƒe siawo
\q2 alo ɖe miaƒe anyigba lolo wu wo tɔa?
\q1 
\v 3 Mieɖe susu ɖa le ŋkeke vɔ̃ la ŋuti,
\q2 gake miaƒe nu tovowo wɔwɔ wɔe be
\q2 Ʋɔnudrɔ̃gbe la le mia lalam.
\q1 
\v 4 Miemlɔa nyiɖubawo dzi,
\q2 eye miedrana ɖe zikpui bɔbɔewo dzi heɖina ɖe eme;
\q1 alẽvi kple nyivi damitɔwoe woɖana na mi.
\q1 
\v 5 Midzia ha vlowo hevuna ɖe kasaŋku ŋu ƒona
\q2 abe David ye le ha kpam ene.
\q1 
\v 6 Miekua wain ɖe tre gãwo me wòyɔna banaa mienona,
\q2 eye miesia ami ʋeʋĩwo,
\q1 gake Yosef ƒe aƒe la ƒe gbegblẽ ya meka mi o,
\q1 
\v 7 eya ta miawoe anye ame gbãtɔ siwo
\q2 woaɖe aboyoe, eye miaƒe agbe vivi ɖuɖu la nu atso.
\s1 Yehowa tsi tsitre ɖe Israel ƒe dada ŋu
\p 
\v 8 Aƒetɔ Yehowa ta eƒe agbe. Dziƒoʋakɔwo ƒe Mawu la gblɔ be,
\q1 “Yakob ƒe dada ƒuƒlu la le ŋu nyɔm nam,
\q2 eye melé fu eƒe mɔ sesẽwo.
\q1 Matsɔ du gã sia
\q2 kple emenu nyuiwo ade asi na eƒe futɔwo.”
\p 
\v 9 Ne ŋutsu ewo susɔ ɖe aƒe ɖeka me hã, wo katã woaku.
\v 10 Ne ƒometɔ aɖe si atɔ dzo ame kukuawo va aƒea me la, abia ame si ɣla ɖe aƒea me la be, “Ame aɖewo gatsi agbe kpe ɖe ŋuwòa?” Ame la aɖo eŋu nɛ be, “Ao!” Ekema ame si va la, agblɔ be, “Mia nu. Mele be míayɔ Yehowa ƒe ŋkɔ le afi sia o.”
\q1 
\v 11 Elabena kpɔ ɖa, Yehowa de se be,
\q2 woagbã aƒe suewo kple gãwo siaa.
\b
\q1 
\v 12 Sɔwo ate ŋu aƒu du le agakpewo dzia?
\q2 Ɖe nyitsu siwo wotsɔna ŋlɔa agblee la
\q2 ate ŋu aŋlɔ atsiaƒu dzia?
\q1 Ke mietrɔ afia nyui tsotso wòzu aɖi,
\q2 eye miedo ŋunyɔ nu sia nu
\q2 si nye nu dzɔdzɔe la wòzu atsa.
\q1 
\v 13 Mi ame siwo kpɔ dzidzɔ esi wogbã Lodeba
\q2 eye miegblɔ be,
\q1 “Ɖe menye míawo ŋutɔ ƒe ŋusẽe míetsɔ xɔ Karnaim oa?”
\b
\q1 
\v 14 Yehowa, Dziƒoʋakɔwo ƒe Mawu la gblɔ be,
\q2 “O Israel ƒe aƒe, mana dukɔ aɖe natso ɖe ŋuwò.
\q1 Ate wò ɖe to vevie tso Lebo Hamat
\q2 va se ɖe Wadi Araba tɔʋu la to.”
\c 7
\s1 Ʋetsuviwo, dzo kple dzidzeka
\p 
\v 1 Esiae nye nu si Aƒetɔ Yehowa ɖe fiam le ŋutega me: Yehowa le ʋetsuviwo ƒe ha gã drinya aɖe dɔm ɖa be woava aɖu kelemenukuwo. Esia ava eme ne woxe nuku gbãtɔwo ƒe adzɔ na fia la vɔ megbe.
\v 2 Esi ʋetsuviawo ɖu nukuawo keŋkeŋ vɔ la, medo ɣli be, “O Aƒetɔ Mawu, meɖe kuku, tsɔe ke dzro. Aleke Yakob ate ŋu anɔ te, elabena enye dukɔ sue aɖe ko?”
\p 
\v 3 Ale Yehowa ɖe asi le susu si wòɖo la ŋuti.
\p Eye Yehowa gblɔ be, “Esia mava eme o.”
\p 
\v 4 Esiae nye nu si Aƒetɔ Yehowa ɖe fiam: Aƒetɔ Mawu yɔ dzo be wòadza, eye dzo la bi tɔsisi goglowo, eye wòfia anyigba la katã.
\v 5 Ale megblɔ nɛ be, “O Aƒetɔ Mawu, meɖe kuku mègawɔe o, elabena dukɔ sue aɖe ko wònye!” Aleke Yakob ate ŋu anɔ tee?
\p 
\v 6 Ale Aƒetɔ Yehowa ɖe asi le susu sia hã ŋuti,
\p Eye wògblɔ nam be, “Esia mava eme o.”
\b
\p 
\v 7 Emegbe la, egaɖe nu sia fiam: Aƒetɔ la le tsi tsitre ɖe gli si woɖo, wòdzɔ kã la xa, eye glidzidzenu le esi.
\v 8 Aƒetɔ la biam be, “Amos, nu ka nèkpɔ?”
\p Meɖo eŋuti be, “Glidzidzenu.”
\p Yehowa gayi dzi be, “Kpɔ ɖa, metsɔ glidzidzenu ɖo nye dukɔ, Israel titina. Nyemagatsɔe ake wo azɔ o.
\q1 
\v 9 “Woagbã Isak ƒe nuxeƒewo,
\q2 Israel ƒe Kɔkɔeƒewo azu aƒedo,
\q2 eye matso ɖe Yeroboam ƒe aƒe la ŋu kple yi.”
\s1 Amos kple Amazia
\p 
\v 10 Ke esi Amazia, nunɔla si le Betel se nya siwo gblɔm Amos le la, eɖo du ɖe Israel fia Yeroboam kaba be, “Amos le nugbe ɖom ɖe ŋutiwò le Israel dukɔ la titina. Amewo mate ŋu atsɔ nya siwo katã gblɔm wòle la o.
\v 11 Amos le gbɔgblɔm be,
\q1 “ ‘Yeroboam atsi yi nu
\q2 eye woaɖe aboyo Israel,
\q2 akplɔe tso eƒe denyigba dzi.’ ”
\p 
\v 12 Amazia ɖo ame dɔdɔwo ɖe Amos be, “Wò, nyagblɔɖila, do go le afi sia! Si nàyi ɖe Yudanyigba dzi, eye nàgblɔ nya ɖi le afi ma be nàkpɔ abolo aɖu.
\v 13 Mègava ɖe fu na mí kple wò ŋutegakpɔkpɔ ƒe nyawo le Betel, míaƒe toxɔdu, afi si fiaɖuƒe la ƒe gbedoxɔ le o!”
\p 
\v 14 Amos ɖo eŋu ɖo ɖe Amazia be, “Menye nyagblɔɖilawo dometɔ ɖekae menye o. Nyemetso nyagblɔɖilawo ƒe ƒome me o. Nye la, lãnyila kple atikutsetsewo fɔla ko menye,
\v 15 gake Yehowa yɔm tso lãnyilawo dome gblɔ nam be, ‘Yi nàgblɔ nya ɖi na nye dukɔ Israel.’
\v 16 Azɔ ɖo to nàse gbedeasi sia, si tso Yehowa gbɔ na wò. Ègblɔ be,
\q1 “ ‘Mègagblɔ nya ɖi ɖe Israel ŋuti o,
\q2 eye mègagblɔ Mawu ƒe nya tsi tsitre ɖe Isak ƒe aƒe ŋu o.’
\p 
\v 17 “Aleae nye Yehowa ƒe ŋuɖoɖo na wò,
\q1 “ ‘Esime nètsi tsitre ɖe nyagblɔɖiawo ŋuti ta la,
\q2 srɔ̃wò azu gbolo le du sia me,
\q2 woawu viwò ŋutsuwo kple nyɔnuwo kple yi;
\q1 woatsɔ dzidzeka ama wò anyigbae.
\q2 Wò ŋutɔ ya, àku ɖe dzronyigba dzi,
\q1 eye Israelviwo azu kluviwo le aboyo me
\q2 le anyigba aɖe si le didiƒe ke la dzi.’ ”
\c 8
\s1 Kutsetse ɖiɖiwo ƒe kusi la
\p 
\v 1 Aƒetɔ Yehowa ɖe kusi aɖe si yɔ fũu kple kutsetse ɖiɖiwo la fiam le ŋutega me.
\v 2 Ebiam be, “Amos, nu ka kpɔm nèle?”
\p Meɖo eŋu nɛ be, “Kusi si yɔ kple atikutsetse ɖiɖiwo.”
\p Yehowa gblɔ nam be, “Israel ƒe ɣeyiɣi de, eya ta nyemagahe woƒe tohehe ɖe megbe azɔ o.”
\p 
\v 3 Egagblɔ be, “Hadzidzi siwo ɖina le gbedoxɔ me la azu avifafa gbe ma gbe. Ame kukuwo akaka ɖe afi sia afi, eye ɖoɖoe azi klẽnee.”
\q1 
\v 4 Misee ɖa, mi ame siwo baa ame dahewo,
\q2 heɖoa afɔ hiãtɔwo dzi.
\p 
\v 5 Mi ame siwo le gbɔgblɔm be,
\q1 “Gbe ka gbe dzinu yeye nu le yiyi ge
\q2 ne míadzra bli,
\q1 eye Dzudzɔgbe nu le yiyi ge
\q2 ne míaʋu avawo nu?”
\q1 Míatsɔ nudanu suewo kple nudzidzenu miamiawo
\q2 anɔ ame bamii.
\q1 
\v 6 Mi ame siwo doa kluvi
\q2 ame dahewo ɖe klosaloga ɖeka ta,
\q1 eye miedzraa hiãtɔwo ɖe afɔkpa dodo ɖeka pɛ ta
\q2 alo dzraa bli gbegblẽ na wo.
\p 
\v 7 Yehowa ta nu ɖe Yakob ƒe dada ŋu be, “Nyemaŋlɔ miaƒe nu vɔ̃wo be o!
\q1 
\v 8 “Le esia ta anyigba adzo nyanyanya,
\q2 ame sia ame afa konyi,
\q2 eye woakɔ ayi dzi abe Nil tɔsisi ene.
\q1 Woadze agbo, agadze anyi abe Egipte tɔsisi la ene.”
\p 
\v 9 Aƒetɔ Yehowa be, “Gbe ma gbe la,
\q2 mana ɣe naɖo to le ŋdɔkutsu,
\q1 eye viviti nado ɖe anyigba dzi le ŋkeke me.
\q1 
\v 10 Matrɔ miaƒe ŋkekenyuiwo woazu konyifafa,
\q2 eye miaƒe dzidzɔhawo azu avihawo.
\q1 Mianɔ funyivɔ me,
\q2 alũ ta kolikoli abe mia viŋutsu ɖeka hɔ̃ɔ si
\q2 le mia si lae ku ene.
\q1 Nyateƒe, ŋkeke ma ave le miaƒe nu me ŋutɔ.”
\b
\q1 
\v 11 Aƒetɔ Yehowa be:
\q1 “Ŋkeke li gbɔna esi dzi maɖo dɔwuame ɖe anyigba dzi,
\q1 menye nuɖuɖu kple tsi ƒe dɔwuame o,
\q2 ke boŋ Yehowa ƒe nyasese ƒe dɔwuame wòanye.
\q1 
\v 12 Woatsa tso afii ayi afi mɛ,
\q2 tso anyiehe ayi ɣedzeƒe,
\q1 anɔ Yehowa ƒe nya dim be yewoase,
\q2 gake womakpɔe o.
\p 
\v 13 “Gbe ma gbe la,
\q1 “ɖeɖi ate ɖetugbi dzetugbewo
\q2 kple ɖekakpui sesẽwo ŋu,
\q1 eye nu ati kɔ na wo le mawunya ƒe tsikɔ si
\q2 le wo wum la ta.
\q1 
\v 14 Ame siwo ta legba si le Samaria,
\q2 eye wogblɔ be, ‘O Dan,
\q1 meta wò mawu ƒe agbe
\q2 alo meta Beerseba ƒe mɔ la adze anyi,
\q2 eye womagafɔ akpɔ gbeɖe o.’ ”
\c 9
\s1 Woatsrɔ̃ Israel
\p 
\v 1 Mekpɔ Aƒetɔ la wòle tsitre ɖe vɔsamlekpui la gbɔ, eye wògblɔ nam be,
\q1 “Xlã nu ɖe sɔtiawo tame ne xɔa ƒe agunu naʋuʋu.
\q2 Mu sɔtiawo woadze ameawo ƒe ta dzi,
\q1 eye ame siwo susɔ la, mawu wo kple yi.
\q2 Ame ɖeka pɛ mato le eme o, eye ɖeke hã masi o.
\q1 
\v 2 Ne woƒu du yi keke tsiẽƒe hã la,
\q2 mava afi ma ahe wo ado goe;
\q1 eye ne wolia nu yi dziƒo hã la,
\q2 mayi afi ma ahe wo vɛ.
\q1 
\v 3 Togbɔ be woasi aɖabe ɖe agakpe siwo
\q2 le Karmel to tame hã la,
\q1 madi wo, ake ɖe wo ŋu,
\q2 ahe wo ado goe le afi ma.
\q1 Ne wosi ɖabe ɖe atsiaƒu ƒe gogloƒe ke hã la,
\q2 madɔ ƒumedawo ɖa be woaɖu wo, woaku.
\q1 
\v 4 Togbɔ be woƒe futɔwo akplɔ wo ayi aboyo me hã la,
\q2 afi ma hã maɖe gbe be woawu wo kple yi.
\b
\q1 “Nye ŋkuwo anɔ wo ŋu na vɔ̃,
\q2 ke menye na nyui o.”
\b
\q1 
\v 5 Aƒetɔ Yehowa, Dziƒoʋakɔwo ƒe Mawu,
\q2 ame si ka asi anyigba ŋuti wòlolõ,
\q1 eye edzinɔlawo katã fa konyi,
\q2 ame si na anyigba kɔ dzi abe Nil ene,
\q2 eye wòna wòdze eme abe Egipte tɔsisi ene.
\q1 
\v 6 Ame si tu nɔƒe kɔkɔwo ɖe dziƒonutowo me,
\q2 eye wòɖo woƒe agunu ɖe anyigba dzi,
\q1 ame si lɔ atsiaƒutsi, eye wòtrɔe ɖe anyigba katã dzi.
\q2 Yehowae nye eƒe ŋkɔ.
\b
\q1 
\v 7 Yehowa be, “O Israelviwo,
\q2 ɖe miele nam abe Kustɔwo ene oa?
\q1 Ɖe menye nyee kplɔ Israel tso Egiptenyigba dzi,
\q2 Filistitɔwo tso Kaftor kple Siriatɔwo tso Kir oa?”
\b
\q1 
\v 8 “Aƒetɔ Yehowa ƒe ŋkuwo le fiaɖuƒe sẽto la ŋuti.
\q2 Matsrɔ̃ wo ɖa le anyigba dzi,
\q1 negbe Yakob ƒe aƒe la ko nyematsrɔ̃ keŋkeŋ o,”
\q2 Yehowae gblɔe.
\q1 
\v 9 “Elabena meɖe gbe, eye matsra Israel ƒe aƒe la
\q2 le dukɔwo dome abe ale si wotsraa bli kple tsranui ene,
\q2 ke ku ɖeka gɔ̃ hã mage ɖe anyigba o.
\q1 
\v 10 Nu vɔ̃ wɔla siwo le nye dukɔ me la
\q2 atsi yi nu kpe ɖe ame siwo gblɔ be,
\q2 ‘Vɔ̃ aɖeke madzɔ ɖe mía dzi o,’ la ŋu.”
\s1 Woagbugbɔ Israel aɖo te
\p 
\v 11 “Ekema le ɣe ma ɣi me la,
\q1 “Magbugbɔ David ƒe agbadɔ atu,
\q2 maɖɔ eƒe fiasã gbagbãwo ɖo,
\q2 magaɖo eƒe aƒedowo te,
\q2 eye magbugbɔ atui abe ale si wònɔ tsã ene,
\q1 
\v 12 ale be woaxɔ Edom ƒe ame mamlɛawo
\q2 kple dukɔ siwo katã ŋuti woyɔ nye ŋkɔ ɖo.”
\q2 Nye Yehowa ame si awɔ esiawo katã lae gblɔe.
\p 
\v 13 Yehowa be, “Ŋkekewo li gbɔna,”
\q1 “esime nukuxala maxa nuku vɔ
\q2 hafi agbleŋlɔla nagadze agbleŋɔŋlɔ gɔme o,
\q1 eye wainfiala mafia wain vɔ hafi
\q2 woagadze waintiwo dodo gɔme o.
\q1 Aha yeye atsyɔ le towo dzi,
\q2 eye wòatsa le togbɛwo tame.
\b
\q1 
\v 14 “Makplɔ Israel agbɔe tso aboyo me,
\q2 woagbugbɔ woƒe du siwo zu aƒedo la atso, ahanɔ wo me,
\q1 woade waingblewo,
\q2 eye woafia aha ano le wo me.
\q1 Woade agblewo eye woaɖu wo me kutsetsewo.
\q1 
\v 15 Maɖo Israel ɖe eya ŋutɔ ƒe anyigba dzi,
\q2 eye womagaho wo kple ke tso anyigba si metsɔ
\q2 na wo la dzi akpɔ gbeɖe o.”
\m Yehowa, miaƒe Mawu lae gblɔe.
