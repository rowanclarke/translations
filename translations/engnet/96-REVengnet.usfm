\p
\v 1 “\w To|strong="G3004"\w* \w the|strong="G1722"\w* angel \w of|strong="G1577"\w* \w the|strong="G1722"\w* \w church|strong="G1577"\w* \w in|strong="G1722"\w* \w Ephesus|strong="G2181"\w*, \w write|strong="G1125"\w* \w the|strong="G1722"\w* \w following|strong="G1722"\w*:  
\p “\w This|strong="G3588"\w* \w is|strong="G3588"\w* \w the|strong="G1722"\w* solemn pronouncement \w of|strong="G1577"\w* \w the|strong="G1722"\w* \w one|strong="G3588"\w* \w who|strong="G3588"\w* \w has|strong="G1125"\w* \w a|strong="G1722"\w* firm grasp \w on|strong="G1722"\w* \w the|strong="G1722"\w* \w seven|strong="G2033"\w* stars \w in|strong="G1722"\w* \w his|strong="G1722"\w* \w right|strong="G1188"\w* \w hand|strong="G1188"\w* – \w the|strong="G1722"\w* \w one|strong="G3588"\w* \w who|strong="G3588"\w* \w walks|strong="G4043"\w* \w among|strong="G1722"\w* \w the|strong="G1722"\w* \w seven|strong="G2033"\w* \w golden|strong="G5552"\w* \w lampstands|strong="G3087"\w*:  
\v 2 ‘\w I|strong="G2532"\w* \w know|strong="G1492"\w* \w your|strong="G2532"\w* \w works|strong="G2041"\w* \w as|strong="G2532"\w* \w well|strong="G2532"\w* \w as|strong="G2532"\w* \w your|strong="G2532"\w* \w labor|strong="G2873"\w* \w and|strong="G2532"\w* steadfast \w endurance|strong="G5281"\w*, \w and|strong="G2532"\w* \w that|strong="G3754"\w* \w you|strong="G4771"\w* \w cannot|strong="G1410"\w* tolerate \w evil|strong="G2556"\w*. \w You|strong="G4771"\w* \w have|strong="G2532"\w* \w even|strong="G2532"\w* \w put|strong="G3985"\w* \w to|strong="G2532"\w* \w the|strong="G2532"\w* \w test|strong="G3985"\w* \w those|strong="G3588"\w* \w who|strong="G3588"\w* refer \w to|strong="G2532"\w* \w themselves|strong="G1438"\w* \w as|strong="G2532"\w* apostles (\w but|strong="G2532"\w* \w are|strong="G1510"\w* \w not|strong="G3756"\w*), \w and|strong="G2532"\w* \w have|strong="G2532"\w* discovered \w that|strong="G3754"\w* \w they|strong="G2532"\w* \w are|strong="G1510"\w* \w false|strong="G5571"\w*.  
