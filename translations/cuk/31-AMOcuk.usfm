\id AMO - Kuna, San Blas - Bible -Panama 2014 (DBL -2014)
\h Amós
\toc1 Amós-Garda
\toc2 Amós
\toc3 Am
\mt1 AMÓS-GARDA
\mt2 AMÓS
\imt2 GEBE-SOGLENAID
\imt1 Garda-nug
\ip \it Amós-Garda.\it* Amós, Judá-yarginedid, Tecoaʼgi e-neggweburad. Amósʼde sibad-wawaad-akwedid, sapur-dulebalid. \it Ibmar-berbegedye,\it* Amós-nug obarileged.
\is1 Amós-Gardagi weyob sunmaklenaid
\ip Bab-Dummad Israel-yargi e-gayaburbagi-sunmakega Amósʼse gochad.
\ip A-ibagangine, Israel-yar bela-bela nasgumai gusad. Degi-inigwele, isgued, degi, igar-innikigwad-imaklesulid nai gusbalid. Dule-mani-ibegan bur bule mani-nikudmalad, dule-wileganadi, bur bule wiled gusmalad. Dule-Bab-akudakmalad-e-bab-dummaganse-gormalayobi, Israel-dulemar Babse gotemarmogad.
\ip Amós sogatar negburgan-daksadi, sognaid, Bab-Dummad bela we-napnegga igar itogoed. We-garda-bergunaidgi, Bab-Dummad gannar Israel-yar-nudakoedgi sunmaknaid.
\ip We-gardagine, weyob ilemakar sunmaklenaid:
\io1 1. Bab-Jehová, Israel-yar-dikarba-yarmar-nanaid sabsur-odurdakoed (1:1–2:5).
\io1 2. Bab-Jehová, Israel-yar-naid sabsur-odurdakoed (2:6-16).
\io1 3. Bab-Jehová, Israel-dulemargi sabsur-sunmaknaid (3:1–6:14).
\io1 4. Amós sogatar negburgan daksad (7:1–9:10).
\io1 5. Israel-dulemar-gannar-ambikuoed-ibagan (9:11-15).
\ip Be itogua.
\c 1
\ms1 1. BAB-JEHOVÁ, ISRAEL-YAR-DIKARBA-YARMAR-NANAID SABSUR-ODURDAKOED
\mr (1:1–2:5)
\s1 Bab-Jehová nue-urwed
\p 
\v 1 We, Amós-e-gayaburbado. Amósʼde Tecoa-neggweburginedid, sibad-wawaad-akwed-duled. Amós, Israel-yargi birgabose negabandur-noed-iduar, negburgan daksad. Deunni, Uzías, Judá-e-reyga-maid, degi, Joás-machi-Jeroboam, Israel-e-reyga maidginmogad.
\v 2 Amós sogded:
\q1 “Sión-yala-akale, Bab-Jehová uludagoed,
\q2 Jerusalén-akale, mar-goledyob e-gayaburba gordagoed.
\q1 Sibad-wawaad-nikamalad-e-nainugi gagan-ara-ara-nanaid bela bergudoed.
\q2 Carmelo-yar-birigi-gagan-nanaid dingudoed.”
\s1 Bab-Jehová Damasco-yar-naid sabsur-odurdakoed
\p 
\v 3 Bab-Jehová weyob soged:
\q1 “Damasco-dorgan-e-isgued nue-wilub-obicha naid.
\q2 Sabsur-e-odurdaklegoedi, an ega osulogosulid.
\q1 Ar ade, Damasco-dorgan undar-beedse Galaad-dulemar-wiosad.
\q2 Esgoro-nugar-nikadgi-ibmar-durwilegeyobi Galaad-imaksamalad.
\q1 
\v 4 Ani an Rey-Hazael-e-neg, soogi ogumakoed,
\q2 Ben-Adad-e-neg-gandikmalad bela gummakoed.
\q1 
\v 5 Damasco-neggwebur-yawagak-esgoromar an bibisgoed,
\q2 Avén-nebagi dule-bukwad an obelogoed.
\q1 Bet-Edénʼgi dummaganga-mamaid an osulogoed.
\q2 Siria-dulemar yogasaar-gales Kirʼye-yar-nugadse barmiledmaloed.
\q2 Ani an Bab-Jehová-guedi we-ibmar soged.”
\s1 Bab-Jehová Gaza-yar-naid sabsur-odurdakoed
\p 
\v 6 Bab-Jehová weyob soged:
\q1 “Gaza-dorgan-e-isgued nue-wilub-obicha naid.
\q2 Sabsur-e-odurdaklegoedi, an ega osulogosulid.
\q1 Ar ade, Gaza-dorgan, bela neggweburmargi-dulemar-bukwad galesa sesmalad,
\q2 geb Edom-dorganga maiga manigi uksamalad.
\q1 
\v 7 Ani an Gaza-neggwebur-e-galu-matusulid, soogi ogumakoed.
\q2 E-neg-gandikmalad-bukwad bela gummakoed.
\q1 
\v 8 Asdod-dorgan-bukwamalad an osulogoed.
\q2 Ascalón-neggweburgi dummagan-mamaid an obelogoed.
\q1 Ecrón-neggweburgi gannar an-ganguedba an gwichigudoed,
\q2 Filistea-dule-napi-ambikumaloed bela an obelomogoed.
\q2 Ani an Bab-Jehová Bela-Gangued-Nikadi we-ibmar soged.”
\s1 Bab-Jehová Tiro-yar-naid sabsur-odurdakoed
\p 
\v 9 Bab-Jehová weyob soged:
\q1 “Tiro-dorgan-e-isgued nue-wilub-obicha naid.
\q2 Sabsur-e-odurdaklegoedi, an ega osulogosulid.
\q1 Ar ade, Tiro-dorgan, bela dulemar-gasa-sesmaladi, Edom-dorganga maiga manigi uksamalad.
\q2 Na gwenatigwar-gued-igar-ebo-mesismalad iesmalad.
\q1 
\v 10 Ani an Tiro-galu-matusurmalad, soogi ogumakoed.
\q2 E-neg-gandikmalad-bukwad bela gummakoed.”
\s1 Bab-Jehová Edom-yar-naid sabsur-odurdakoed
\p 
\v 11 Bab-Jehová weyob soged:
\q1 “Edom-dorgan-e-isgued nue-wilub-obicha-naid.
\q2 Sabsur-e-odurdaklegoedi, an ega osulogosulid.
\q1 Ar ade, Edom-dorgan, e-gwenadgan-wile-daksasulid.
\q2 Es-suidyalaba balegicha gusmalad.
\q1 Ar na saed-itoged ulubgi bargadsurmalad,
\q2 e-urwed gwen iessurmalad.
\q1 
\v 12 Ani an Temán-neggwebur, soogi ogumakoed,
\q2 Bosra-neggwebur-e-neg-gandikmalad bela gummakoed.”
\s1 Bab-Jehová Amón-yar-naid sabsur-odurdakoed
\p 
\v 13 Bab-Jehová weyob soged:
\q1 “Amón-dorgan-e-isgued nue-wilub-obicha naid.
\q2 Sabsur-e-odurdaklegoedi, an ega osulogosulid.
\q1 Ar Amón-dorgan, na e-yarmar-abingunanaid onasogega,
\q2 Galaad-omegan-gurgin-nikamalad-ibe saban-maris nanaed.
\q1 
\v 14 Ani an Rabá-neggwebur-e-galu-matusurmalad soogi ogumakoed,
\q2 e-neg-gandikmalad bela gummakoed.
\q1 Bila-onolenaidgi oimaknanaidaeyob, sabsur-oimaknanai gumaloed.
\q2 Burwa-dummad-uurmakmaiyob, neg-oimaknai guoed.
\q1 
\v 15 Amón-dorgan-e-rey gales seledoed,
\q2 bela e-dummagan eba gales seledmogoed.
\q2 Ani an Bab-Jehová-guedi we-ibmar soged.”
\c 2
\s1 Bab-Jehová Moab-yar-naid sabsur-odurdakoed
\p 
\v 1 Bab-Jehová weyob soged:
\q1 “Moab-dorgan-e-isgued nue-wilub-obicha-naid.
\q2 Sabsur-e-odurdaklegoedi, an ega osulogosulid.
\q1 Ar Moab-dulemar, Edom-e-rey-garmar ogumaksad,
\q2 burubi-guedse imaksad.
\q1 
\v 2 Ani an Moab-yala, soogi ogumakoed,
\q2 Queriot-neg-gandikmalad bela gummakoed.
\q1 Moab-dulemar bilagi-oimaknanaid-abalagi berguoed,
\q2 gar-trompeta-gornaid-abalagi burgoed.
\q1 
\v 3 E-dummad-negsemaid, e-dulemar-wagab an osulogoed.
\q2 E-dummagan belagwable an eba obelogoed.
\q2 Ani an Bab-Jehová-guedi we-ibmar soged.”
\s1 Bab-Jehová Judá-yar-naid sabsur-odurdakoed
\p 
\v 4 Bab-Jehová weyob soged:
\q1 “Judá-dorgan-e-isgued nue-wilub-obicha naid.
\q2 Sabsur-e-odurdaklegoedi, an ega osulogosulid.
\q1 Ar Judá-dorgan, e-gakansamaladba Bab-Jehová-Igar-Maidgi aibatemalad,
\q2 Bab-Jehová-Igar-Sogmaidba nanassurmalad.
\q1 Bab-dummadyob-imaklemaladba nanasmalad,
\q2 e-dadgan-nanasadba nanasmarmogad.
\q1 
\v 5 A-ulale, ani an Judá-yargi soo barmidoed,
\q2 Jerusalén-e-neg-gandikmalad bela gummakoed.”
\ms1 2. BAB-JEHOVÁ, ISRAEL-YAR-NAID SABSUR-ODURDAKOED
\mr (2:6-16)
\p 
\v 6 Bab-Jehová weyob soged:
\q1 “Israel-dorgan-e-isgued nue-wilub-obicha naid.
\q2 Sabsur-e-odurdaklegoedi, an ega osulogosulid.
\q1 Ar Israel-dorgan, dule-nued manigi uksamalad,
\q2 Israel-dorgan, dule-wilese-gudimalad sapat-gwagwen-muchub uksamarbalid.
\q1 
\v 7 Dule-wilegana sabsur-ise-wilegar imaksamalad,
\q2 mesagwale imaksamalad.
\q1 Wileganaga igar-maidba igar nabossurmalad.
\q2 Baba, galagwensuli ome-wargwengi nanadidaed,
\q2 a-omegi, e-machi galagwensuli nanadidamogad.
\q1 Weyob an-nug-isligwaled oichosmalad.
\q2 
\v 8 Amarde, yogasaaledgi bab-dummaganga-ibmar-ukleged-ailamar-dikarba, mor-manigi-siid, na megega ebudamalad.
\q2 Dule-mani-ganikid-ibe-vino-sulesadi, e-bab-dummaganse-goled-neggi gobdamalad.
\b
\q1 
\v 9 ”We-dulemar-wagab, Amorreo-dulemar an obelosad,
\q2 amar-ibe e-ibmar-nikumaid an osulosad,
\q2 e-gandik-bukwad an ei osulosad.
\q1 Ar Amorreo-dulemar urwaryobi sugu-inigwele,
\q2 encina-sapimaryob dutusur-inigwele, an obelosad.
\b
\q1 
\v 10 ”Egipto-yargi-noega an bemar-imaksamalad.
\q2 Nega-dulesulidganba birga-dulabo (40) an bemar-idudii gusad,
\q2 adi, Amorreo-dulemar-bukwamalad-e-yala bemarga ukegar.
\q1 
\v 11 Deginbali, be-mimmigan-imbagi, an-gayaburba-barsogmalad an nugsasad.
\q2 Be-sapingan-imbagi, dulemar-anga-nugsalesad an susbalid.
\q2 A-dulemarde, Nazareo-duleye bilesmalad.
\q1 Israel-dulemar, ¿weyob ibmar-gusadi napirasursi? Deyobdo.
\q2 Ani an Bab-Jehová-guedi we-ibmar soged.
\q1 
\v 12 Degi-inigwele, dule-anga-nugsalesad Nazareoʼye-bileged, vino-gobega be imaksamalad.
\q2 An-gayaburba-barsogedga be sogsamalad:
\q2 ‘Mer Bab-Jehová-gayaburbagi sunmakoye.’
\b
\q1 
\v 13 ”Israel-dorgan, a-ulale, an sabsur-apor bemar-imakoed,
\q2 igi ur-dummad-napagined orosgwaggi-dakleged ena-danikir, ibmar-birgi-nasar ibmar gullu-gullu imake,
\q2 deyob an bemar-imakoed.
\q1 
\v 14 Dule-gwae-gwae-abarmaked, angi wakinnosurguoed.
\q2 Dule-dutusulid, dukin e-garganguedba bendaklegosulid.
\q1 Dule-gandikidbela, dukin na e-san bendakosurmogad.
\q2 
\v 15 Dule-sigumied, an-abin gwisguosurguoed.
\q1 Dule-gwae-gwae-nanaed, angi wakinnosurguoed,
\q2 dule moligi-sii-wakinmaile, na san-onogosulid.
\q1 
\v 16 A-ibagi, sorda-bila-onomalad-bur-gandikmaladi, uka-swili wakinmai guoed.
\q2 Ani an Bab-Jehová-guedi we-ibmar soged.”
\c 3
\ms1 3. BAB-JEHOVÁ, ISRAEL-DULEMARGI SABSUR-SUNMAKNAID
\mr (3:1–6:14)
\s1 Amós Israel-dulemarga ibmar-sognaid
\p 
\v 1 ¡Israel-dulemar, we-gayaburba be nue itomalo! Bab-Jehová bemar-annik, degi, bela Egipto-yargi dulemar-noargusmalad-annik weyob soged:
\q1 
\v 2 “Bela-dulemar-napneggi-bukwad-abargi
\q1 unnila bemarbi an be-susad.
\q2 Degi-inigwele, bela-bemar-ibmar-isgana-imaksadbali, an sabsur-bemar-odurdakoed.”
\b
\q1 
\v 3 ¿Dule na ebo igar-amisulile,
\q2 sunna ebo-nued-gudiguo be ebinsae? Suli.
\q1 
\v 4 ¿Achumigur san ganisulile, uurmako be ebinsae? Suli.
\q2 ¿Achumigur-sapingwa, e-gubya-yaba san ganisuli-maile, uurmako be ebinsae? Suli.
\q1 
\v 5 ¿Nuu-galu-yaba mas-sisulir, nuu galego be ebinsae? Suli.
\q2 ¿Nuu-galu walagwengi ibmar-galesuli atido be ebinsae? Suli.
\q1 
\v 6 ¿Neggweburgi gar-trompeta gollalile,
\q2 dulemar dobedba oimakardasur be ebinsae? Eye.
\q1 ¿Neggweburgi boni-dummadgan-noedi,
\q2 Bab-Jehová imaksur be ebinsae? Eye.
\b
\q1 
\v 7 Ar napiragwad, Bab-Jehová-Bur-Gandik-Maidi,
\q2 e-gayaburba-barsogmaladga ibmar-sogsasuli geg ibmar imaked.
\b
\q1 
\v 8 Ar achumigur uurmakalile, ¿doa dobguosur be ebinsae?
\q2 Bab-Jehová-Bur-Gandik-Maid sunmakele, ¿doa e-gayaburba barsogosur be ebinsamoga?
\s1 Israel-yala sabsur-odurdaklegoed
\q1 
\v 9 Asdod-e-neggandikmaladgi binnasur be sogmalo,
\q2 Egipto-yar-neg-gandikmaladgi binnasur be sogmarbalo.
\q1 Weyob be sogmalo: “Samaria-yar-birse be ambikudamar,
\q2 agi dobed-dummad-naid be dakdamar,
\q2 agi sabsur-wilenanaid be dakdamar.”
\p 
\v 10 Bab-Jehová soged:
\q1 “Bemar, igar-innikigwadba geg nanamalad:
\q2 Ar bemar sabsur-urwedgi-ibmar-sumaladid,
\q2 reyneggi a-ibmar sabomaladid.”
\p 
\v 11 A-ulale, Bab-Jehová-Bur-Gandik-Maid weyob soged:
\q1 “Be-isdarmalad-wargwen gandikidgi be-yar sunonikoed.
\q2 Be-neggandikmaladi bela bei earmaloed.
\q2 Be-reynegmargi-ibmar-nuegan-bukwad bela bei sumaloed.”
\p 
\v 12 Bab-Jehová weyob soged:
\q1 “Igi-sibad-wawaad-edarbedi, e-sibad-wawaad achumigurse-galealile, aisaar na bendaknaidae,
\q2 degi-inigwele, unnila e-malibi, e-uayadukubidibe na gadapdae,
\q1 deyobi, wis Israel-dorgan-Samariaʼgi-bukwadi san-onogoed.
\q2 Deyobi, wis Israel-dorgan-Damasco-neggweburgi gan-mua-muadgi-sigmaladi, san-onogoed.”
\p 
\v 13 Bab-Dummad-Jehová-Bela-Gangued-Nika-Maid weyob soged:
\q1 “Nuekwa be an-itomalo.
\q2 Jacob-dulemarga iduakwaa be ibmar sogmarmogo.
\b
\q1 
\v 14 ”Israel-dorgan e-ibmar-isgana-imaksad-ulale,
\q2 an sabsur-odurdakoed-ibagine, Betelʼgi e-ibmar-ogumakar-ukleged-ailamar an obelogoed.
\q1 Ibmar-ogumakar-ukleged-ailagi moli-bebegiid-bukwad an bibisgoed,
\q2 bela napagi an mioed.
\q1 
\v 15 Dii-wied-ibagi-obunnoged-negmar bela an bibisgoed,
\q2 yorgi-obunnoged-negmar bela an eyaroed.
\q1 Akwa-marfilʼye-nugadgi negmar-sobarmalad bela an osulogoed.
\q2 Bukidar nega-dummagan-bubukwadi an eyaroed.
\q2 Ani an Bab-Jehová-guedi we-ibmar soged.”
\c 4
\s1 Omegan-Samariaʼginmalad mani-ibegan
\q1 
\v 1 Bemar, omegan-Samariaʼginmalad, an bega ibmar-sogoed be itomar:
\q2 Bemar, Basán-yalagi moli-bebe-nikad-ome-wardummaganyob gumalad.
\q1 Bemar, dule-wilegana sabsur-wiobukmalad,
\q2 ise-mesagwale, be dule-wilegana imakbukmalad.
\q1 Be-suimargarbela be sogbukwadamalad:
\q2 “Vino anga sedaye.”
\p 
\v 2 Bab-Jehová-Bur-Gandik-Maidi, e-san-isligwaledba ise-sogar soged:
\q1 “Bemargi ibagan-dani, bemar belagwable akegi ebipilemai gumaloed,
\q2 achwer-nugar-dummagangi-gales be ebipilemai gumaloed.
\q1 
\v 3 Bemar neggwebur-galu-matusulid-ayaroedbali ilekwaa ainimai gumaloed.
\q2 Geb Hermón-yarse be-metemaloed.
\q2 Ani an Bab-Jehová-guedi weyob soged.”
\s1 Israel-dulemar sabsur-odurdakleged amba itosurmalad
\q1 
\v 4 “Betel-neggweburse be namar,
\q2 ase be isgunamar.
\q1 Gilgal-neggweburse be namar,
\q2 bur bule ase isgudii be sanamar.
\q1 Bane-bane wakudaryalaba ibmar-ukleged be uknamar.
\q2 Ibapaagi ibmar-ambegi-gwensak-ukleged (10%) be uknamar.
\q1 
\v 5 Dog-nuedye-sogega, madu-ina-nikad be ogumaknamar.
\q2 Bela dule be owisomala,
\q1 na ibmar-ukleged e-itoleged-ukbiedba ibmar sedamaloye.
\q2 Ar Israel-dulemar, weyob abemalad.
\q2 Ani an Bab-Jehová-guedi weyob soged.”
\s1 Israel-dulemar Bab-Dummadba yapa ibsaed
\q1 
\v 6 “Ani an bela be-neggweburmargi ukud-dummad nasiksad,
\q2 bela be-dulemar-bukwadga masgulleged an osulosad.
\q1 Degite, bemar deyob-gusmar-inigwele, gwen gannar anse aibilissurmalad.
\q2 Ani an Bab-Jehová-guedi weyob soged.
\b
\q1 
\v 7 ”Nii-warbaase ibmar-gwag-welegoed-iduale, dii bar an owissulid.
\q2 Unnila neggwebur-gwagwengi dii an owisad.
\q2 Neggwebur-baidgindi dii an owissulid.
\q1 Nainu-gwensakgi dii-winai gusad.
\q2 Baid-nainugindi dii wissulid,
\q2 abali, nainu dingude gusad.
\q1 
\v 8 Degisoggu, dulemar neggwebur-baid-baidse dii-amidii gusmalad.
\q2 Wis-gobsamar-inigwele, amba uku-uku-itogedi surgussurmalad.
\q1 Degite, bemar deyob-gusmar-inigwele, gwen gannar anse aibilissurmalad.
\q2 Ani an Bab-Jehová-guedi weyob soged.
\b
\q1 
\v 9 ”Be-ibmar-digarmalad bonigangi an obelosad,
\q2 neg-uedikidba an dinare imaksad.
\q1 Sesmar be-nainugan obelosad,
\q2 sesmar be-uva-digar-nanaid oburgwisad.
\q1 Sesmar be-higuera-sapimar obelosad,
\q2 degi, be-olivo-sapimar obelosbalid.
\q1 Degite, bemar-ibe deyob-ibmar-gus-inigwele, bemar gwen gannar anse aibilissurmalad.
\q2 Ani an Bab-Jehová-guedi weyob soged.
\b
\q1 
\v 10 ”Egipto-dulemargi bonigan an barmisgusayobi, an bemargi barmisgusad.
\q2 Es-suidgi be-sapingan an oburgwisad,
\q1 e-molimar-galesmalad an ogilosbalid.
\q2 Dule-burgwismalad-e-mui-yapanned neg-gagasa an nasiksad.
\q1 Degite, bemar deyob-gusmar-inigwele, gwen gannar anse aibilissurmalad.
\q2 Ani an Bab-Jehová-guedi weyob soged.
\b
\q1 
\v 11 ”An Sodoma-neggwebur-wiosayobi, degi, Gomorra-neggwebur-wiosayobi, an bemar-wiosmogad.
\q2 Bemar suar soose-negabar-gummaksayobi gusmalad.
\q1 Degite, bemar deyob-gusmar-inigwele, gwen gannar anse aibilissurmalad.
\q2 Ani an Bab-Jehová-guedi weyob soged.
\b
\q1 
\v 12 ”Israel-dulemar, be anse aibilissurmalad-ulale, an begi gwichigumogoed.
\q2 Israel-dulemar, begi an gwisguosoggu, an-iduar guakwa be gudimalo.
\q2 Ar bemar we-ibmar-guoedi igar-gaosurmalad.”
\b
\q1 
\v 13 Dule-yarmar-nasiksadi, burwamar-obinnisadi, dulemarga-ibmar-guoed-sogedi, Bab-Jehováʼye nugad.
\q2 Neg-meegwad, negsichidga obinyedi, yarmar-birgi-nanaedi, Bab-Jehováʼye nugad,
\q2 Bab-Dummad-Bela-Gangued-Nikadid.
\c 5
\s1 Israel-dulemar gannar-Bab-Jehováʼba-nanaegala unalesad
\q1 
\v 1 Israel-dulemar, nue itomalo,
\q2 gayaburba-wile-itoged-namaklegedgi, an bega namaksokalid.
\b
\q1 
\v 2 “Israel-dulemar yagwa-swilidik-yeerdaklegedyobid, be sabsur-omukulesmalad.
\q2 Bar be gannar gwisguosulid.
\q1 Napagi meremai be guoed,
\q2 dule-be-ogwised sate guoed.”
\p 
\v 3 Bab-Jehová-Bur-Gandik-Maid, Israel-dulemarga weyob soged:
\q1 “Neggwebur-gwensak sorda-miligwen (1,000) bila-onogedse-naele,
\q2 unnila dulatar (100) durgumaloed.
\q1 Ar neggwebur-gwensak dulatar (100) bila-onogedse-naele,
\q2 unnila e-ambe (10) durgumaloed.”
\p 
\v 4 Bab-Jehová Israel-dulemarga weyob soged:
\q1 “Be an-amimalale, be dula-gudii gumaloed.
\q2 
\v 5 Melle be Betel-neggweburse bar namala.
\q1 Gilgal-neggweburse melle be bar namala,
\q2 degi, Beerseba-neggweburse melle be bar namarbali,
\q1 ar ade, Gilgal-dulemar galesa seledmaloed,
\q2 degi, Betel-neggweburdi bela berguoed.”
\b
\q1 
\v 6 Bab-Jehová be amimala, adi, be dula-gudii gumaloed.
\q2 Degisulile, Bab-Jehová José-wagangi sooyobi aidenonikoed,
\q1 We-soo, bela Betel-neggwebur ogumakoed.
\q2 Dule we-soo-oginnega sate guoed.
\q1 
\v 7 Igar-innikigwadi, igar-isganaga be imakmalad.
\q2 Bur Igar-napiragwadi obanagwar be imakmalad.
\b
\q1 
\v 8 Bab-Dummad niisgwa-danaled Pléyadesʼye-bileged obinnisad,
\q2 degi, niisgwa-baigan Oriónʼye-bileged obinnisbalid.
\q1 Bab-Dummad neg-sipusulidi, neg-meegwadga imaked,
\q2 degi, neg-meegwad, negsichidga imakbalid.
\q1 Bab-Dummad demar-bukibse goled. Geb napneggi dii-owiega imaked.
\q2 ¡E-nuga, Bab-Jehováʼye nugad!
\q1 
\v 9 Bab-Jehová neggandikmalad osuloged,
\q2 dule-ambikued-neggandikmalad osulobalid.
\b
\q1 
\v 10 Bemar, igar-nudaked-neggi dule-igar-nudakega-arbamaladi, isdar dakmalad,
\q2 degi, dule-napira-ibmar-soged, isdar be dakmarbalid.
\q1 
\v 11 Ar bemar, dule-wilegana ibigwensuli imakmarsoggu,
\q2 degi, orosgi-dakleged-trigoʼgi, mani-galeged-bennuked ega be igar-mesismarsoggu,
\q1 a-ulale, be-akwa-neg-sobsamaladgi, be megosurmalad.
\q2 Degine, nainugi be-uva-naid-e-vino gwen be gobosurmalad.
\q1 
\v 12 Bemar-ibmar-isgana-yaisur-imaksad an wisid,
\q2 be-isgumalad-yaisulid an wisid.
\b
\q1 Bemar, dule-innikigwad ibgwensur imaked,
\q2 igar-nabolemaladgi emarse be manigi baklemalad.
\q2 Degine, igar-nabolegedgi dule-wileganagi be gwisgumalad.
\q1 
\v 13 Agala, weyob neg-gunaidgine, dule-binsaed-nikadaedi bogi gudidaed.
\q2 Ar ade, we-ibagande nuedsulid.
\b
\q1 
\v 14 Melle igar-isgana be amimala, bur igar-nued be amimala,
\q2 adi, be dula-gudii gumaloed.
\q1 Degidbali, Bab-Dummad-Jehová-Bela-Gangued-Nikadi,
\q2 bemarba gudii guoed.
\b
\q1 
\v 15 Igar-isgana be obane, igar-nuedbina be soge,
\q2 igar-nabiroleged-neggi, igar-innikigwadba igar be nabomala.
\q1 Abakale, Bab-Dummad-Jehová-Bela-Gangued-Nika-Maid,
\q2 José-wagan-besmalad wile dakalile.
\p 
\v 16 Agala, Bab-Dummad-Jehová-Bela-Gangued-Nika-Maid weyob soged:
\q1 “Bela-dule-ambikumaladgi, dulemar-ise-boale itolegoed,
\q2 degi, bela galimbaba wile-itolegedba binnasur-gornanai itolegoed.
\q1 Bomalaga sapur-dorganse gorlegoed,
\q2 degi, bomalaga dulemar-manigi-bomaladse gorlegoed.
\q1 
\v 17 An sabsur-bemar-wiodanikile,
\q2 bela uva-digarmaladba dule-boe itolegoed.
\q2 Ani an Bab-Jehová-guedi weyob soged.”
\s1 Bab-Jehová-e-iba
\q1 
\v 18 Dule, Bab-Jehová-sabsur-odurdaked-iba-abitogele, ¡duledar-wilesmar!
\q2 ¿Ar ibiga we-ibade edarbesunna?
\q1 Ar we-iba negasichidbi naguoed,
\q2 neg-meegwad naguosulid.
\q1 
\v 19 Dule aisaar achumigur-idu-wakinmaiyob guoenad,
\q2 degi-inigwele, wiob-abingudagoed.
\q2 Deyobiyobi, a-iba ega guoed.
\q1 Dule e-negyaba-dogmaile, galugi akadapiyob guoed,
\q2 galugi-akadapidba naibegi-warmaksayobi guoed.
\q2 Deyobiyobi, a-iba ega guoed.
\q1 
\v 20 Bab-Jehová-sabsur-odurdaked-ibade negasichidbi-nai guoed, neg-meegwad-nai guosulid.
\q2 Bela neg-gubyagwaledbi-nai guoed, neg dale-dalesaar daklegosulid.
\p 
\v 21 Bab-Jehová sogdebalid:
\q1 “Ibamar be anga onogedi, an isdar-daked.
\q2 Bemar bulakwaa an-nug-odummogega itoakwaa-anse-gormaladi, yeer-ito an-imaksulid.
\q1 
\v 22 Ar bemar anga be-ibmar-ogumakar-ukleged ukele, an abingaosulid.
\q2 Ibmar-gwagmar anga be ukele, an abingaosurbalid.
\q1 Amba gwenatigwar-guega moli-bebe-nikad-senigana-wardummagan-ukleged,
\q2 an be-ibe abingaosurbalid.
\q1 
\v 23 Be-namaked-oimaksiid an itobisulid.
\q2 Be-gar-cítara-goled, an itobisulid.
\q1 
\v 24 Bur, dii-aryomaiyobi, igar-naboleged galesuli selemai abeleged,
\q2 degi, diwar-suurmakmaiyobi, igar-innikimalad selemai abeleged.
\b
\q1 
\v 25 ”Israel-dulemar, bemar birga-dulabo (40) nega-dulesulidganba gudigusmargua,
\q1 ¿anga be napiragwadgi ibmar-ogumakar-ukleged uksamarsi?
\q2 ¿Anga be napiragwadgi ibmar-ukleged uksamarsi? Suli.
\q1 
\v 26 Emide, bemarde nuchu-Moloc-e-neg-sobaled be semamaid.
\q2 Degi, nuchu-Quiún be semamaid.
\q1 Wemarde niisgwa-e-nuchumar-nanaed,
\q2 bemar we-ibmarmar-sobsamaladi, gwen Bab-Dummadsulid.
\q1 
\v 27 Degisoggu, dikasuli Damasco-neggwebur-dakasik an be-balimetemaloed.”
\p Bab-Jehová deyob soged. E-nuga, Bab-Dummad-Bela-Gangued-Nikadye nugad.
\c 6
\s1 Bab-Dummad Israel-dulemar-sabsur-imakoed
\p 
\v 1 Amós sogdebalid:
\q1 “Dule-Sión-neggweburgi-baisuli-itodimalad, ¡duledar-wilesmar!
\q2 Samaria-yargi-dobsulidba-gudidimalad, ¡duledar-wilesmar!
\q1 Dule-nug-nikamalad neggwebur-dummagangi-mamaid, ¡duledar-wilesmar!
\q2 A-dulemarse Israel-dulemar bendakleged egisnaddamalad.
\q1 
\v 2 Calne-neggweburse be namar, nue be dakmalo.
\q2 Agi bukwa, Hamat-neggwebur-dummadse be namarbalo.
\q1 Geb sorba Filistea-neggwebur-Gatʼye-nugadse be namarbalo.
\q2 ¿Ar bemarde we-neggweburmargi bur obinmarde?
\q2 ¿Bemar-yarde bur we-yarmarba dummadye sogde?
\q1 
\v 3 Bemar iba-isgana obangumarye be bimalad,
\q2 aka, be neg-nue-gagaled-iba warmakega imakmalad.
\q1 
\v 4 Be-gabed-megmaladgi elefante-nugar-goamar nanaid, a-megedgi na be megdimalad,
\q2 degi, be-gan-siged-mua-muad-dummadgi be bilikwaa sigdimalad.
\q1 A-gangi-sii, bemar sibad-wawaad-mimmigan-e-galugi-sulearmalad gundimalad,
\q2 degi, moli-bebe-nikad-senigana-wardummagan be gundimarbalid.
\q1 
\v 5 Bemar, David-namakeyob namakye be sogmalanad,
\q2 yogasaar be namakmalad.
\q1 Gar-cítaraʼba be namakdedamalad.
\q2 Be-itoleged, gar-gormalad be obinyedamalad.
\q1 
\v 6 Bemar nog-dummagangi vino be gobdimalad.
\q2 Degi, ina-wawadikid-nuegan be ebudimarbalid.
\q1 Ar José-e-wagan-e-neg-bibichisadba
\q2 nunmaked-dummad, eba nunmak be itosurmalad.
\q1 
\v 7 A-ulale, emidi bemar-inse dulemar-galesa-seledmaloed-iduar seledmaloed,
\q2 deyobi, dulemar-galagwensur-iba-onomalad berguoed.”
\s1 Israel-dulemar-san-dummarba-itoged-ular, Bab-Jehová sae-itoged
\p 
\v 8 Bab-Dummad-Jehová na dukin ise-sogar imaksad. Bab-Dummad-Jehová-Bela-Gangued-Nikad weyob soged:
\q1 “Jacob-wagan san-dummarba-imaked an isdar-daked.
\q2 E-neg-gandikmalad an sae-daked.
\q1 Agala, e-neggwebur e-isdarmaladga an urmakoed,
\q2 degi, bela e-ibmar-nikadi an e-isdarmaladga urmakoed.”
\p 
\v 9 Weyob neg gudoed: Dule neg-gwagwengi e-ambe (10) dula besale, bela burgwemaloed.
\v 10 Geb e-gwenad-gwensak muimar-ogumakega, a-negse muimar-sudanikile, dule-neggi-gudiidga weyob sogdoed: “¿Dule-baid amba be-walik gudii?”
\p Geb dule weyob abin sogdoed: “Suli.” Geb degidgine, ega sogdoed: “¡Boogwa! Anmar geg Bab-Jehová-nug obared.”
\q1 
\v 11 Ar Bab-Jehová igar-ukdoed:
\q2 Neg-dummagan bibisgeye,
\q2 degi, neg-burwigana ubigwar imakye.
\b
\q1 
\v 12 ¿Ar molimar akwa-dummagan-imbaba abarmaksi?
\q2 ¿Ar akwa-dummagangi nabir moli-bebe-nikad napa imusi?
\q1 Ar bemardi, igar-innikigwad, ibmar-isganaga obinnismalad.
\q2 Igar-innikigwad-selemaid, boniga be obinnismalad.
\q1 
\v 13 Bemar ibmar-gwen-imaksasulidgi be wergudimalad.
\q2 Be sogmalad: “Anmar-ganguedgi anmarde gargangued nikusmarye.”
\b
\q1 
\v 14 Degisoggu, Israel-dulemar, Bab-Jehová-Bela-Gangued-Nikadi soged:
\q2 “Bemargi neggwebur-soggwen gwichiguega an imakoed.
\q1 A-neggwebur ise-mesagwale bemar-imakoed.
\q2 Hamatʼse-doglemaid-akale, Arabá-diwar-maidse, bemar ese odurdaklegoed.”
\c 7
\ms1 4. AMÓS SOGATAR NEGBURGAN DAKSAD
\mr (7:1–9:10)
\s1 Negburgan-sogapaa-daklesad
\p 
\v 1 Bab-Jehová-Bur-Gandik-Maid, we-negburgan anga oyosad:
\p Reyga ibmar-gwag-orosgi-dakleged-ukleged-welesad-sorba, a-gwag gannar ainiali an dakalid. Agi Bab-Jehová sesmar-bukidar urbenai an dakarbalid.
\v 2 Degi, sesmar napaneggi gaganse-bakale, bela obelosgua, binnasuli an goted:
\p —An-Bab-Jehová-Bur-Gandik-Maidye, an bese wilesakwaa egisye, Jacob-waganga isgued be eliye. ¿Ar igi Jacob-wagande bar bukuosunna? Unnila ichee gumalad.
\p 
\v 3 Degidgine, Bab-Jehová wiledakde, sogded:
\p —Degir nabir, an deyob neg imakosulid.
\p 
\v 4 Geb degi, Bab-Jehová-Bur-Gandik-Maid, negburgan-baid anse oyosbalid: An daked, Bab-Jehová dule-sabsur-odurdakega soose gote. Degi, soo napa-urba demar-wilasailad dinnaa imaksad. Degine, nainugan bela swanga imaksad.
\p 
\v 5 Deyob an daksagu, binnasuli an goted:
\p —Bab-Dummad-Jehováʼye, bese wilesakwaa an egisye, soo be oginye. Degisulile, ¿ar igi Jacob-wagande bar bukuosunna? Unnila iche gumalad.
\p 
\v 6 Degidgine, Bab-Jehová wiledakde, sogded:
\p —Degir nabir, an deyob neg imakosulid.
\p 
\v 7 Bab-Jehová, anga negburgan-baid oyosbalid: An daked, Bab-Jehová galu-matusulid-nuekwa-sobaled-nagaba gwichi. Degi, neg-wilubsaed-dubgi-gingwa-naid e-argangi-gani, an dakalid.
\v 8 Degi, Bab-Jehová anse egichialid:
\p —Amós, ¿wede ibu be dake?
\p An abin-sogded:
\p —Dubgi gingwa-nai an daked.
\p Degidgine, Bab-Jehová anga sogded:
\p —Dubgi-gingwa-naidi, an-Israel-dulemar-abargi an obatoed, adi, wilubdakega, bule inniki-gudimardibeye. Inniki-gudisulile, bar an ega e-isgued eliosulid.\fig Dule, neg-wilubsaed-dubgi-gingwa-naidgi galu wilubsanaid. (Amós 7:7-8) |src="LB00125B.TIF" size="col" ref="Amós 7:8"\fig*
\q1 
\v 9 Isaac-wagan-e-bab-dummaganse-goled-ailamar bela osulolegoed,
\q2 degi, Israel-e-bab-dummaganse-goled-negmar bela bibisgoed.
\q1 Jeroboam-e-gwenadgan es-suidgi an oberguoed.
\s1 Amasías, Amósʼgi gwichigusad
\p 
\v 10 Degidgine, Betel-neggweburgined-dule-irwa-Babse-goled-Amasías, Israel-rey-Jeroboamʼga gayaburba barmisad: “Amós, Israel-sordamar-abargi begi gwisgudiid. Ar Amós-sunmakedba Israel-dulemar binsaed-galediid.
\v 11 Ar ade, Amós sogdiid:
\q1 ‘Rey-Jeroboam es-suidgi burgoye.
\q2 Israel-dulemardi e-yargi gales seledmarmogoye.’ ”
\p 
\v 12 Geb degi, Amasías, Amósʼga sogded:
\p —¡Dule-negburgan-daked, be wegi-gudiid be nae! Ar be mas-gunbiele, Judá-yarse be nae. Agi, Bab-Jehová-igargi be sunmaknae.
\v 13 Melle bar Betel-neggweburgi, Bab-Jehová-igargi be sunmaknoniko, ar Betelʼde, rey-e-neg-islidikidid, rey-e-bab-dummadse-goled-negad.
\p 
\v 14 Amós, Amasías-abin sogded:
\p —An Bab-Dummad-gayaburba-barsoged-dulesulid, an a-machisurbalid. Unnila, an sibad-wawaad-edarbed-dule gued, higuera-sapigi an arbaed-dulebalid.
\v 15 Degi-inigwele, Bab-Jehová sibad-edarbedgi an-onosad. Anga sogsad: ‘An-gayaburbagi be an-Israel-dulemarga be sunmaknaye.’
\v 16 Degisoggu, Amasías, Bab-Jehová-gayaburba be itoge:
\p ”Bede soged:
\q1 ‘Mer Bab-Jehová-ibmar-imakoedgi Israel-dulemarga gandikidgi sunmakoye.
\q2 Mer Bab-Jehová-gayaburbagi Isaac-waganga gandikidgi sunmakbaloye.’
\p 
\v 17 ”Agala, Bab-Jehová weyob bega soged:
\q1 ‘Be-ome neggweburgi ibmarbina na san-urmakdii guoed.
\q2 Be-masmala, degi, be-bunamala es-suidgi oburgwilegoed.
\q1 Be-napamar wilubsaar mimilegoed.
\q2 Degi, bedi, be-yargi burgosulid.
\q1 Israel-dulemardi e-yargi dikasuli gales seledmaloed.’ ”
\c 8
\s1 Amós sapi-san-gorogana garbagi-bukwa daksad
\p 
\v 1 Bab-Jehová-Bur-Gandik-Maid, negburgan anga oyosbalid: Garbagi sapi-san-gorogwad-bukwa an daksad.
\v 2 Degi, anse egichided:
\p —Amós, we, ¿ibu be dake?
\p Degi, an abin-sogde:
\p —Garbagi sapi-san-gorogana-bukwa an daked.
\p Degidgine, Bab-Jehová anga sogded:
\p —Israel-dulemar-e-bergued-ibagan warmaknonikid. Ibmar-san-gorogwayobi berguoed. Israel-dulemarga e-isgued bar an eliosulid.
\p 
\v 3 Bab-Jehová-Bur-Gandik-Maid sogded:
\p —A-ibagangi, reyneggi-namaklemalad, boedga guoed. Dulemar-bukidar yogasaar burgwar-burgwar omilede gumaloed. Degi, bogidikidgi muimar yogasaar metemaloed.
\q1 
\v 4 Nue be an itomalo,
\q2 bemar, dulemar-wilegana sabsur-imakmalad,
\q2 bemar, dule-wilegana obelodimarbalid.
\b
\q1 
\v 5 ”Bemar sogmalad:
\q1 ‘Anmar ibmar-gwagmar manigi ukega, ¿sana we nii-gebe-gwisgusad-e-iba berguoe?
\q2 Anmar ibmar-gwag-orosgi-dakleged-trigo manigi ukega,
\q2 ¿sana we itoged-iba berguoe?’
\b
\q1 ”Bemar ibmar-nibirgi-uked bur ichee-gued abediid.
\q2 E-manidi odummoged abediid.
\q2 Emar-yardakega nibir-nuedsulid ebudamalad.
\q1 
\v 6 Orosgwaggi-dakleged-e-solamar bemar manigi ukdamalad.
\q2 Bemar dule-wilegana manigi bakdamarbalid,
\q2 degi, dule-ibmar-abedimalad nag-uka-gwagwengi unnir bakdamarbalid.”
\p 
\v 7 Bab-Jehová, Jacob-dulemar-e-san-dummarba-imakedgi, ise-sogar sogded: “Ibmar be imaksamaladi, an gwen iegosulid.
\q1 
\v 8 Deyob bela neg-guoed-ulale, ¿napade giglimakosuli?
\q2 ¿Bela e-dulamar boosurmala?
\q1 Bela napa, Nilo-diwar-engumaiyobi megoed, dogdoed.
\q2 Agi Egipto-diwar-ilideyobi, ilidoed.”
\p 
\v 9 Bab-Jehová-Bur-Gandik-Maid sogdebalid:
\q1 “A-ibagi, yorukudba dad-galegega an imakoed,
\q2 degi, napneggi ibginedba negsichid an nasikoed.
\q1 
\v 10 Be-iba-onomalad ise-bukib-binsaleged-ibaga an imakoed.
\q2 Degi, be-namakmalad,
\q1 namakmalad-ise-bukib-binsaedga an imakbaloed.
\q2 Bukib-binsaleged-e-mor-yoega an bemar-imakbaloed.
\q1 Degi, be-nono swanga-imakega an be-imakbaloed.
\q2 Machi-wargwennagwad-burgwisar, ega bonanaidaeyob ise-boar bemar bomaloed,
\q2 degi, ibagan nunmaked-dummad-nai bergudoed.”
\p 
\v 11 Bab-Jehová-Bur-Gandik-Maid sogdebalid:
\q1 “Ibagan-danikid, napneggi an ukud-dummad nasikoed.
\q2 We-ukudde, masgulleged an obarsulid,
\q1 degi, uku-uku-itogedgi-dii-gobleged an obarsurbalid.
\q2 An obaredi, dulemar an-gayaburba-itobiedba uku-uku-gudiguoed, an obared.
\q1 
\v 12 Degisoggu, dulemar, Bab-Jehová-Gayaburba-amiega, igarsuli demar-mataganba namaloed.
\q2 Igarsuli dad-nakwed-argan-sapiledsik, degi, dad-nakwedsik gudii gumaloed.
\q2 Degi-inigwele, Bab-Jehová-gayaburba gwen amiosurmalad.
\b
\q1 
\v 13 ”A-ibagine, yagana-yeerdaklemalad, sapingana-gandikmalad, uku-uku-itogedba negoedmaloed.
\q2 
\v 14 Dulemar Samaria-dorgan-e-isgudiidga ise-sogar sogdamaladi bergumaloed, bar-durguosurmalad
\q1 Amarde sogmalad: ‘Dan-neggwebur-e-bab-dummad-dula-gudiidba ise-sogar an bega sogye.’
\q2 Degi, sogdamarbalid: ‘Beerseba-neggwebur-e-bab-dummad-dula-gudiidba ise-sogar an bega sogye.’ ”
\c 9
\s1 Amós, Babse-goled-neg-bibichilesad-negburgan daksad
\p 
\v 1 Dule-Dummad ibmar-ogumakar-ukleged-aila-dikarba-gwichi an daksad, degi, anga sogded:
\q1 “Buarmar-e-bargamalad be omukue,
\q2 adi, buarmar giglimakega, dulemar-e-nonogi babatidoed.
\q1 Dulemar-burgosurmaladdi es-suidgi an osulogoed.
\q2 Dulemar-wargwensaar wakinnosulid,
\q2 wargwensaagwar durguosulid.
\q1 
\v 2 Israel-dulemar neg-uan-napa-uluba dukuye-sogele, amba an onogoed.
\q2 Ar amba nibanegse nakweye-sogele, amba an amar-odegoed.
\q1 
\v 3 Amba Carmelo-yar-birba dukuye-sogele,
\q2 ase an aminaoed, degi, an gaoed.
\q1 Demar-mata-wilasorse angi dukuye-sogele,
\q2 amba naibe-demargined egi-warmakega an barmidoed.
\q1 
\v 4 Israel-dulemar, e-isdarmaladse-galesa selenadapidgine, an igar-ukoed,
\q2 es-suidgi amar-oburgwegar.
\q1 Israel-dulemargi nue an nakulegoed.
\q2 An egi-nakulegoedi, ibmar-nued ega imakegarsulid.
\q2 Ibmar-isganaga imakegalad.”
\b
\q1 
\v 5 Bab-Jehová-Bur-Gandik-Maid, Bela-Gangued-Nikad-Maid napa ebugele, napa maludoed.
\q2 Napa mullumakmai megoed,
\q1 Egipto-diwar-Nilo-maiyob megoed,
\q2 degi, bela dule-bukwamalad ise-boar gumaloed.
\q1 
\v 6 Bab-Dummad nibaneggi na e-neg nasiksad,
\q2 degi, napaneggi e-neg-sailagan nasiksabalid.
\q1 Dii napaneggi-owiegala, demar-mata-obupurmakega imaked.
\q2 E-nuga, Bab-Jehováʼye nugad.
\b
\q1 
\v 7 Israel-wagan, Bab-Jehová soged:
\q2 “¿Ar bemarde anga Etiopía-dulemaryob-gusursi?
\q1 ¿Ar ande Egiptoʼgi Israel-dulemar-onissursi?
\q2 ¿Caftor-yargi Filistea-dulemar an onisbarsursi?
\q2 Degi, ¿Kir-yargi Arameo-dulemar an onisbarsursi?
\b
\q1 
\v 8 ”Ani an Bab-Jehová-Bur-Gandik-Maidi,
\q2 we-yar-isgus-naidgi nakulemaid.
\q1 Jacob-wagan napneg-naidgi an obelogoed,
\q2 degi-inigwele, an bela obelogosulid.”
\p Bab-Dummad-Jehová soged.
\q1 
\v 9 “Igi ukub bugbugi egwalealile, napagi akwa-gwagwensaar argwansuli,
\q2 deyobi, Israel-dulemar neggwebur-baigan-abargi, an egwaoed.”
\p 
\v 10 Bab-Jehová sogdebalid:
\q1 “Bela an-dulamar-isgudimalad, es-suidgi burgwemaloed.
\q2 Bela sogdimaladi: Bonigan anmarse gwen nonikosurye.
\q1 Anmar-oakalogosurye.
\q2 Dule-deyob-sogdimaladi, bela burgwemaloed.”
\ms1 5. ISRAEL-DULEMAR-GANNAR-AMBIKUOED-IBAGAN
\mr (9:11-15)
\p 
\v 11 Bab-Jehová sogdebalid:
\q1 “A-ibagi, David-meged-neg-ayarisadi, an soboed.
\q2 Neg-yaa-ollogan-ambikusadi, an edioed,
\q1 degi, e-neg-bibichismalad iduar-sobaledyob,
\q2 gannar an sobbaloed.
\q1 
\v 12 Adi, Israel-dulemar, degi, bela dulemar an-nug-odummodimaladi,
\q2 Edom-neggwebur, degi, bela neggwebur-bamalad suegar.”
\p 
\v 13 Bab-Jehová sogdebalid:
\q1 “Ibmar-san-bukidar-welegoed-ibagan danikid,
\q2 ibmar-gwag-digleged-ibagan-naidgi, amba oros-gwaggiid-dakleged, welenai guoed.
\q1 Uva-digleged-ibagan-naidgi, amba uva-egurlenai guoed.
\q2 Yar-dummaganba vino-binid aryomamai guoed,
\q2 bela yala-senigana-imbaganba suurmakmai guoed.
\q1 
\v 14 An-Israel-dulemar-galesmalad an gannar e-yarse sedagoed.
\q2 Neggweburmar-bergusad gannar na sobmarbaloed,
\q2 agi na ambikumaloed.
\q1 Uva-dubmar digmaloed, degi, e-vino gobdii gumaloed.
\q2 Ibmar-digedgi arbamaloed,
\q2 a-ibmar-sanmakoedi, gundii gumaloed.”
\p 
\v 15 Be-Bab-Dummad-Jehová soged:
\q1 “Israel-dulemar e-yargi an urboed,
\q2 adi, mer yar-an-ega-uksadgi, bar onilegegar.”
