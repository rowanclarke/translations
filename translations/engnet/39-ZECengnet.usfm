\s1 Introduction
\p 
\v 1 \w In|strong="H8141"\w* \w the|strong="H3068"\w* \w eighth|strong="H8066"\w* \w month|strong="H2320"\w* \w of|strong="H1121"\w* \w Darius|strong="H1867"\w*’ \w second|strong="H8147"\w* \w year|strong="H8141"\w*, \w the|strong="H3068"\w* \w word|strong="H1697"\w* \w of|strong="H1121"\w* \w the|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd* \w came|strong="H1961"\w* \w to|strong="H3068"\w* \w the|strong="H3068"\w* \w prophet|strong="H5030"\w* \w Zechariah|strong="H2148"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Berechiah|strong="H1296"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Iddo|strong="H5714"\w*, \w as|strong="H1697"\w* follows:
\p 
\v 2 \w The|strong="H5921"\w* \nd \w Lord|strong="H3068"\w*\nd* \w was|strong="H3068"\w* \w very|strong="H7107"\w* \w angry|strong="H7107"\w* \w with|strong="H3068"\w* \w your|strong="H3068"\w* ancestors.
\v 3 \w Therefore|strong="H3068"\w* \w say|strong="H7725"\w* \w to|strong="H7725"\w* \w the|strong="H5002"\w* people: \w The|strong="H5002"\w* \nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3068"\w* \w all|strong="H7725"\w* \w says|strong="H5002"\w*, “\w Turn|strong="H7725"\w* \w to|strong="H7725"\w* \w me|strong="H7725"\w*,” \w says|strong="H5002"\w* \w the|strong="H5002"\w* \nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3068"\w* \w all|strong="H7725"\w*, “\w and|strong="H3068"\w* \w I|strong="H3541"\w* \w will|strong="H3068"\w* \w turn|strong="H7725"\w* \w to|strong="H7725"\w* \w you|strong="H7725"\w*,” \w says|strong="H5002"\w* \w the|strong="H5002"\w* \nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3068"\w* \w all|strong="H7725"\w*.
\v 4 “\w Do|strong="H3068"\w* \w not|strong="H3808"\w* \w be|strong="H1961"\w* \w like|strong="H1961"\w* \w your|strong="H3068"\w* \w ancestors|strong="H7223"\w*, \w to|strong="H7725"\w* \w whom|strong="H7121"\w* \w the|strong="H5002"\w* \w former|strong="H7223"\w* \w prophets|strong="H5030"\w* \w called|strong="H7121"\w* \w out|strong="H7725"\w*, saying, ‘\w The|strong="H5002"\w* \nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3068"\w* \w all|strong="H7725"\w* \w says|strong="H5002"\w*, “\w Turn|strong="H7725"\w* \w now|strong="H4994"\w* \w from|strong="H7725"\w* \w your|strong="H3068"\w* \w evil|strong="H7451"\w* \w wickedness|strong="H7451"\w*,”’ \w but|strong="H3808"\w* \w they|strong="H3068"\w* \w would|strong="H3068"\w* \w by|strong="H3068"\w* \w no|strong="H3808"\w* \w means|strong="H7181"\w* \w obey|strong="H8085"\w* \w me|strong="H4994"\w*,” \w says|strong="H5002"\w* \w the|strong="H5002"\w* \nd \w Lord|strong="H3068"\w*\nd*.
\v 5 “\w As|strong="H1992"\w* \w for|strong="H2421"\w* \w your|strong="H5769"\w* ancestors, \w where|strong="H1992"\w* \w are|strong="H1992"\w* \w they|strong="H1992"\w*? \w And|strong="H5769"\w* \w did|strong="H5030"\w* \w the|strong="H2421"\w* \w prophets|strong="H5030"\w* \w live|strong="H2421"\w* \w forever|strong="H5769"\w*?
\v 6 \w But|strong="H3808"\w* \w have|strong="H3068"\w* \w my|strong="H3068"\w* \w words|strong="H1697"\w* \w and|strong="H3068"\w* \w statutes|strong="H2706"\w*, \w which|strong="H3068"\w* \w I|strong="H1697"\w* \w commanded|strong="H6680"\w* \w my|strong="H3068"\w* \w servants|strong="H5650"\w* \w the|strong="H6213"\w* \w prophets|strong="H5030"\w*, \w not|strong="H3808"\w* \w outlived|strong="H5381"\w* \w your|strong="H3068"\w* fathers? \w Then|strong="H3651"\w* \w they|strong="H3651"\w* \w paid|strong="H7725"\w* \w attention|strong="H1870"\w* \w and|strong="H3068"\w* confessed, ‘\w The|strong="H6213"\w* \nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H3068"\w* \w rules|strong="H2706"\w* \w over|strong="H3068"\w* \w all|strong="H6213"\w* \w has|strong="H3068"\w* \w indeed|strong="H7725"\w* \w done|strong="H6213"\w* \w what|strong="H1697"\w* \w he|strong="H6213"\w* \w said|strong="H1697"\w* \w he|strong="H6213"\w* \w would|strong="H3068"\w* \w do|strong="H6213"\w* \w to|strong="H7725"\w* \w us|strong="H7725"\w*, \w because|strong="H3651"\w* \w of|strong="H3068"\w* \w our|strong="H3068"\w* sinful \w ways|strong="H1870"\w*.’”
\s1 The Introduction to the Visions
\p 
\v 7 \w On|strong="H3117"\w* \w the|strong="H3068"\w* \w twenty-fourth|strong="H6242"\w* \w day|strong="H3117"\w* \w of|strong="H1121"\w* \w the|strong="H3068"\w* \w eleventh|strong="H6249"\w* \w month|strong="H2320"\w*, \w the|strong="H3068"\w* \w month|strong="H2320"\w* \it Shebat\it*, \w in|strong="H8141"\w* \w Darius|strong="H1867"\w*’ \w second|strong="H8147"\w* \w year|strong="H8141"\w*, \w the|strong="H3068"\w* \w word|strong="H1697"\w* \w of|strong="H1121"\w* \w the|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd* \w came|strong="H1961"\w* \w to|strong="H3068"\w* \w the|strong="H3068"\w* \w prophet|strong="H5030"\w* \w Zechariah|strong="H2148"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Berechiah|strong="H1296"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Iddo|strong="H5714"\w*, \w as|strong="H1697"\w* follows:
\s1 The Content of the First Vision
\p 
\v 8 \w I|strong="H2009"\w* \w was|strong="H1931"\w* attentive \w that|strong="H7200"\w* \w night|strong="H3915"\w* \w and|strong="H3915"\w* \w saw|strong="H7200"\w* \w a|strong="H3068"\w* \w man|strong="H7200"\w* \w seated|strong="H5921"\w* \w on|strong="H5921"\w* \w a|strong="H3068"\w* red \w horse|strong="H5483"\w* \w that|strong="H7200"\w* \w stood|strong="H5975"\w* \w among|strong="H5921"\w* \w some|strong="H2009"\w* \w myrtle|strong="H1918"\w* \w trees|strong="H1918"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* \w ravine|strong="H4699"\w*. \w Behind|strong="H5975"\w* \w him|strong="H5921"\w* \w were|strong="H5483"\w* red, \w sorrel|strong="H8320"\w*, \w and|strong="H3915"\w* \w white|strong="H3836"\w* \w horses|strong="H5483"\w*.
\s1 The Interpretation of the First Vision
\p 
\v 9 \w Then|strong="H1696"\w* \w I|strong="H7200"\w* \w asked|strong="H4100"\w* \w one|strong="H7200"\w* nearby, “\w What|strong="H4100"\w* \w are|strong="H1992"\w* \w these|strong="H1992"\w*, sir?” \w The|strong="H7200"\w* \w angelic|strong="H4397"\w* \w messenger|strong="H4397"\w* \w who|strong="H1992"\w* \w replied|strong="H1696"\w* \w to|strong="H1696"\w* \w me|strong="H7200"\w* \w said|strong="H1696"\w*, “\w I|strong="H7200"\w* \w will|strong="H4100"\w* \w show|strong="H7200"\w* \w you|strong="H4100"\w* \w what|strong="H4100"\w* \w these|strong="H1992"\w* \w are|strong="H1992"\w*.”
\v 10 \w Then|strong="H6030"\w* \w the|strong="H3068"\w* \w man|strong="H6030"\w* \w standing|strong="H5975"\w* among \w the|strong="H3068"\w* \w myrtle|strong="H1918"\w* \w trees|strong="H1918"\w* \w spoke|strong="H6030"\w* \w up|strong="H5975"\w* \w and|strong="H1980"\w* \w said|strong="H6030"\w*, “\w These|strong="H7971"\w* \w are|strong="H3068"\w* \w the|strong="H3068"\w* \w ones|strong="H5975"\w* whom \w the|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd* \w has|strong="H3068"\w* \w sent|strong="H7971"\w* \w to|strong="H1980"\w* \w walk|strong="H1980"\w* \w about|strong="H1980"\w* \w on|strong="H1980"\w* \w the|strong="H3068"\w* earth.”
\v 11 \w The|strong="H3605"\w* riders \w then|strong="H6030"\w* \w agreed|strong="H5975"\w* \w with|strong="H1980"\w* \w the|strong="H3605"\w* \w angel|strong="H4397"\w* \w of|strong="H3068"\w* \w the|strong="H3605"\w* \nd \w Lord|strong="H3068"\w*\nd*, \w who|strong="H3605"\w* \w was|strong="H3068"\w* \w standing|strong="H5975"\w* \w among|strong="H3427"\w* \w the|strong="H3605"\w* \w myrtle|strong="H1918"\w* \w trees|strong="H1918"\w*, “\w We|strong="H1980"\w* \w have|strong="H3068"\w* \w been|strong="H8252"\w* \w walking|strong="H1980"\w* \w about|strong="H1980"\w* \w on|strong="H1980"\w* \w the|strong="H3605"\w* earth, \w and|strong="H1980"\w* \w now|strong="H2009"\w* \w everything|strong="H3605"\w* \w is|strong="H3068"\w* \w at|strong="H3427"\w* \w rest|strong="H8252"\w* \w and|strong="H1980"\w* \w quiet|strong="H8252"\w*.”
\v 12 \w The|strong="H3068"\w* \w angel|strong="H4397"\w* \w of|strong="H3068"\w* \w the|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd* \w then|strong="H6030"\w* asked, “\nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H8141"\w* \w all|strong="H5704"\w*, \w how|strong="H4970"\w* \w long|strong="H5704"\w* \w before|strong="H5704"\w* \w you|strong="H5704"\w* \w have|strong="H7355"\w* \w compassion|strong="H7355"\w* \w on|strong="H3068"\w* \w Jerusalem|strong="H3389"\w* \w and|strong="H3063"\w* \w the|strong="H3068"\w* \w other|strong="H2088"\w* \w cities|strong="H5892"\w* \w of|strong="H3068"\w* \w Judah|strong="H3063"\w* \w which|strong="H3068"\w* \w you|strong="H5704"\w* \w have|strong="H7355"\w* \w been|strong="H3068"\w* \w so|strong="H3808"\w* \w angry|strong="H2194"\w* \w with|strong="H3068"\w* \w for|strong="H5704"\w* \w these|strong="H2088"\w* \w seventy|strong="H7657"\w* \w years|strong="H8141"\w*?”
\v 13 \w The|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd* \w then|strong="H6030"\w* addressed \w good|strong="H2896"\w*, \w comforting|strong="H5150"\w* \w words|strong="H1697"\w* \w to|strong="H1696"\w* \w the|strong="H3068"\w* \w angelic|strong="H4397"\w* \w messenger|strong="H4397"\w* \w who|strong="H3068"\w* \w was|strong="H3068"\w* \w speaking|strong="H1696"\w* \w to|strong="H1696"\w* \w me|strong="H6030"\w*.
\v 14 Turning \w to|strong="H1696"\w* \w me|strong="H7121"\w*, \w the|strong="H3541"\w* \w messenger|strong="H4397"\w* \w then|strong="H1696"\w* \w said|strong="H1696"\w*, “\w Cry|strong="H7121"\w* \w out|strong="H1696"\w* \w that|strong="H3068"\w* \w the|strong="H3541"\w* \nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3068"\w* \w all|strong="H1419"\w* \w says|strong="H3541"\w*, ‘\w I|strong="H3541"\w* \w am|strong="H3068"\w* \w very|strong="H7065"\w* \w much|strong="H1419"\w* \w moved|strong="H3389"\w* \w for|strong="H7121"\w* \w Jerusalem|strong="H3389"\w* \w and|strong="H3068"\w* \w for|strong="H7121"\w* \w Zion|strong="H6726"\w*.
\v 15 \w But|strong="H1992"\w* \w I|strong="H5921"\w* am \w greatly|strong="H1419"\w* \w displeased|strong="H7107"\w* \w with|strong="H5921"\w* \w the|strong="H5921"\w* \w nations|strong="H1471"\w* \w that|strong="H1471"\w* take \w my|strong="H5921"\w* grace \w for|strong="H5921"\w* \w granted|strong="H5826"\w*. \w I|strong="H5921"\w* \w was|strong="H7451"\w* \w a|strong="H3068"\w* \w little|strong="H4592"\w* \w displeased|strong="H7107"\w* \w with|strong="H5921"\w* \w them|strong="H1992"\w*, \w but|strong="H1992"\w* \w they|strong="H1992"\w* \w have|strong="H1471"\w* only made \w things|strong="H1419"\w* \w worse|strong="H7451"\w* \w for|strong="H5921"\w* \w themselves|strong="H1992"\w*.
\s1 The Oracle of Response
\p 
\v 16 “‘\w Therefore|strong="H3651"\w*,’ \w says|strong="H5002"\w* \w the|strong="H5002"\w* \nd \w Lord|strong="H3068"\w*\nd*, ‘\w I|strong="H3541"\w* \w have|strong="H3068"\w* \w become|strong="H7725"\w* \w compassionate|strong="H7725"\w* \w toward|strong="H5921"\w* \w Jerusalem|strong="H3389"\w* \w and|strong="H3068"\w* \w will|strong="H3068"\w* \w rebuild|strong="H1129"\w* \w my|strong="H3068"\w* \w temple|strong="H1004"\w* \w in|strong="H5921"\w* \w it|strong="H5921"\w*,’ \w says|strong="H5002"\w* \w the|strong="H5002"\w* \nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H5921"\w* \w all|strong="H5921"\w*. ‘\w Once|strong="H7725"\w* \w more|strong="H3651"\w* \w a|strong="H3068"\w* surveyor’s measuring line \w will|strong="H3068"\w* \w be|strong="H3068"\w* \w stretched|strong="H5186"\w* \w out|strong="H5186"\w* \w over|strong="H5921"\w* \w Jerusalem|strong="H3389"\w*.’
\v 17 Speak up \w again|strong="H5750"\w* \w with|strong="H3068"\w* \w the|strong="H3541"\w* \w message|strong="H3068"\w* \w of|strong="H3068"\w* \w the|strong="H3541"\w* \nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3068"\w* \w all|strong="H5750"\w*: ‘\w My|strong="H3068"\w* \w cities|strong="H5892"\w* \w will|strong="H3068"\w* \w once|strong="H5750"\w* \w more|strong="H5750"\w* \w overflow|strong="H6327"\w* \w with|strong="H3068"\w* \w prosperity|strong="H2896"\w*, \w and|strong="H3068"\w* \w once|strong="H5750"\w* \w more|strong="H5750"\w* \w the|strong="H3541"\w* \nd \w Lord|strong="H3068"\w*\nd* \w will|strong="H3068"\w* \w comfort|strong="H5162"\w* \w Zion|strong="H6726"\w* \w and|strong="H3068"\w* validate \w his|strong="H3068"\w* \w choice|strong="H2896"\w* \w of|strong="H3068"\w* \w Jerusalem|strong="H3389"\w*.’”
\s1 Vision Two: The Four Horns
\p 
\v 18 Once again I looked and this time I saw four horns.
\v 19 So I asked the angelic messenger who spoke with me, “What are these?” He replied, “These are the horns that have scattered Judah, Israel, and Jerusalem.”
\v 20 Next the \nd Lord\nd* showed me four blacksmiths.
\v 21 I asked, “What are these going to do?” He answered, “These horns are the ones that have scattered Judah so that there is no one to be seen. But the blacksmiths have come to terrify Judah’s enemies and cut off the horns of the nations that have thrust themselves against the land of Judah in order to scatter its people.”
\c 2
\p 
\v 1 \w I|strong="H2009"\w* \w looked|strong="H7200"\w* again, \w and|strong="H5869"\w* \w there|strong="H2009"\w* \w was|strong="H7161"\w* \w a|strong="H3068"\w* \w man|strong="H5375"\w* \w with|strong="H5869"\w* \w a|strong="H3068"\w* measuring line \w in|strong="H7200"\w* \w his|strong="H5375"\w* hand.
\v 2 \w I|strong="H4100"\w* \w asked|strong="H4100"\w*, “\w Where|strong="H4100"\w* \w are|strong="H3478"\w* \w you|strong="H4100"\w* going?” \w He|strong="H3389"\w* \w replied|strong="H1696"\w*, “\w To|strong="H1696"\w* measure \w Jerusalem|strong="H3389"\w* \w in|strong="H3478"\w* order \w to|strong="H1696"\w* determine \w its|strong="H7161"\w* width \w and|strong="H3063"\w* \w its|strong="H7161"\w* length.”
\v 3 \w At|strong="H3068"\w* \w this|strong="H7200"\w* point \w the|strong="H7200"\w* angelic messenger \w who|strong="H3068"\w* spoke \w to|strong="H3068"\w* \w me|strong="H7200"\w* \w went|strong="H3068"\w* \w out|strong="H7200"\w*, \w and|strong="H3068"\w* \w another|strong="H7200"\w* messenger \w came|strong="H3068"\w* \w to|strong="H3068"\w* \w meet|strong="H7200"\w* \w him|strong="H7200"\w*
\v 4 \w and|strong="H3063"\w* \w said|strong="H6310"\w* \w to|strong="H6213"\w* \w him|strong="H6213"\w*, “Hurry, \w speak|strong="H6310"\w* \w to|strong="H6213"\w* \w this|strong="H6213"\w* young \w man|strong="H5375"\w* \w as|strong="H6213"\w* follows: ‘Jerusalem \w will|strong="H1471"\w* \w no|strong="H3808"\w* \w longer|strong="H3808"\w* \w be|strong="H3808"\w* enclosed \w by|strong="H6213"\w* walls because \w of|strong="H7218"\w* \w the|strong="H5375"\w* multitude \w of|strong="H7218"\w* \w people|strong="H1471"\w* \w and|strong="H3063"\w* animals there.
\v 5 \w But|strong="H7200"\w* \w I|strong="H2009"\w* (\w the|strong="H7200"\w* \nd Lord\nd* says) \w will|strong="H5869"\w* \w be|strong="H3027"\w* \w a|strong="H3068"\w* wall \w of|strong="H3027"\w* fire surrounding Jerusalem \w and|strong="H3027"\w* \w the|strong="H7200"\w* source \w of|strong="H3027"\w* glory \w in|strong="H3027"\w* \w her|strong="H5375"\w* midst.’”
\p 
\v 6 “\w You|strong="H7200"\w* \w there|strong="H7200"\w*! Flee \w from|strong="H1980"\w* \w the|strong="H7200"\w* northland!” says \w the|strong="H7200"\w* \nd Lord\nd*, “\w for|strong="H3389"\w* \w like|strong="H1980"\w* \w the|strong="H7200"\w* four winds \w of|strong="H7341"\w* heaven \w I|strong="H7200"\w* \w have|strong="H7200"\w* scattered \w you|strong="H7200"\w*,” says \w the|strong="H7200"\w* \nd Lord\nd*.
\v 7 “\w Escape|strong="H3318"\w*, Zion, \w you|strong="H1696"\w* \w who|strong="H4397"\w* live among \w the|strong="H3318"\w* Babylonians!”
\v 8 \w For|strong="H3427"\w* \w the|strong="H8432"\w* \nd Lord\nd* \w who|strong="H3427"\w* rules \w over|strong="H3427"\w* \w all|strong="H7230"\w* \w says|strong="H1696"\w* \w to|strong="H1696"\w* \w me|strong="H1696"\w* \w that|strong="H5288"\w* \w for|strong="H3427"\w* \w his|strong="H8432"\w* own glory \w he|strong="H3389"\w* \w has|strong="H1696"\w* sent \w me|strong="H1696"\w* \w to|strong="H1696"\w* \w the|strong="H8432"\w* nations \w that|strong="H5288"\w* plundered \w you|strong="H8432"\w* – \w for|strong="H3427"\w* anyone \w who|strong="H3427"\w* touches \w you|strong="H8432"\w* touches \w the|strong="H8432"\w* pupil \w of|strong="H3427"\w* \w his|strong="H8432"\w* eye.
\v 9 “\w I|strong="H3068"\w* \w am|strong="H1961"\w* \w about|strong="H5439"\w* \w to|strong="H3068"\w* punish \w them|strong="H5439"\w* \w in|strong="H3068"\w* \w such|strong="H1961"\w* \w a|strong="H3068"\w* way,” \w he|strong="H3068"\w* \w says|strong="H5002"\w*, “\w that|strong="H3068"\w* \w they|strong="H3068"\w* \w will|strong="H3068"\w* \w be|strong="H1961"\w* looted \w by|strong="H3068"\w* \w their|strong="H3068"\w* \w own|strong="H1961"\w* slaves.” \w Then|strong="H1961"\w* \w you|strong="H8432"\w* \w will|strong="H3068"\w* know \w that|strong="H3068"\w* \w the|strong="H5002"\w* \nd \w Lord|strong="H3068"\w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3068"\w* \w all|strong="H5439"\w* \w has|strong="H3068"\w* \w sent|strong="H3068"\w* \w me|strong="H1961"\w*.
\p 
\v 10 “Sing \w out|strong="H6566"\w* \w and|strong="H3068"\w* \w be|strong="H3068"\w* happy, \w Zion|strong="H6566"\w* \w my|strong="H3068"\w* daughter! \w For|strong="H3588"\w* \w look|strong="H3068"\w*, \w I|strong="H3588"\w* \w have|strong="H3068"\w* come; \w I|strong="H3588"\w* \w will|strong="H3068"\w* settle \w in|strong="H3068"\w* \w your|strong="H3068"\w* midst,” \w says|strong="H5002"\w* \w the|strong="H5002"\w* \nd \w Lord|strong="H3068"\w*\nd*.
\v 11 “Many nations \w will|strong="H1323"\w* \w join|strong="H3427"\w* themselves \w to|strong="H1323"\w* \w the|strong="H3427"\w* \nd Lord\nd* \w on|strong="H3427"\w* \w the|strong="H3427"\w* day \w of|strong="H1323"\w* salvation, \w and|strong="H3427"\w* they \w will|strong="H1323"\w* also \w be|strong="H6726"\w* \w my|strong="H4422"\w* \w people|strong="H3427"\w*. Indeed, I \w will|strong="H1323"\w* \w settle|strong="H3427"\w* \w in|strong="H3427"\w* \w the|strong="H3427"\w* midst \w of|strong="H1323"\w* \w you|strong="H6726"\w* \w all|strong="H3427"\w*.” Then \w you|strong="H6726"\w* \w will|strong="H1323"\w* know \w that|strong="H4422"\w* \w the|strong="H3427"\w* \nd Lord\nd* \w who|strong="H3427"\w* rules \w over|strong="H3427"\w* \w all|strong="H3427"\w* \w has|strong="H6726"\w* sent me \w to|strong="H1323"\w* \w you|strong="H6726"\w*.
