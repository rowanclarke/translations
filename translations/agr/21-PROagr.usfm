\id PRO - Aguaruna
\h Proverbios
\toc1 Pujutan wakannumiajai pachis jintiamu
\toc2 (Proverbios)
\toc3 Pr.
\mt2 Pujutan wakannumiajai pachis jintiamu
\mt1 Proverbios
\c 1
\ms1 Yama nagkamchaku agagbau
\mr (1.1-7)
\s1 Chicham pegkeg yachametai jintinkagtamu
\p 
\v 1 Juju ainawai apu Salomón, Davita uchiji, Israel aents aidaun apuji aajakua nunú tibau.
\m 
\v 2 Juna tiuwa nunak:
\b
\q1 Niina aentsji Israel wegantu aidau
\q1 yacha shiig anentaimkau atinme,
\q1 nuninak dekas chicham pegkeg aina
\q1 nuna dekau atinme.
\q1 
\v 3 Nuninak jintiamu antuka jutan,
\q1 wainak chichashtan, shiig takatan,
\q1 imagnisa emetmamja pujutan,
\q1 
\v 4 tuja datsauch imanis jintiag
\q1 anentaimchau aidaun
\q1 jintintua wajiu aneaku emak,
\q1 shiig anentaimsa eseja pujutan unuinagtatus agajui.
\q1 
\v 5 Aents yacha shiig anentaimkauwa duka
\q1 juju jintiamua nunak shiig antawai,
\q1 nunik nuni kuashat unuimatan
\q1 shiig anentaimtajai juwawai.
\q1 
\v 6 Wagki niig aents yacha
\q1 shiig anentaimkau aidau
\q1 tuja dita apachji augmattsamu,
\q1 etsegbaun, tuja adivinanza
\q1 jintiamu aidaun aatus
\q1 antuka unuimagtag tau asa.
\q1 
\v 7 Yachameta duka Tuke Pujuu
\q1 eme anentsa umigbauwa nuwi nagkamnawai.
\q1 Tuja aents pegkegchau aidauk
\q1 unuimat pegkeg jintiamua nunak dakitawai.
\s1 Datsa aidau chichagbau
\q1 
\v 8 Uchuchih,
\q1 amina apa chichame antugkata,
\q1 tuja amina duku jintinjabaush
\q1 kajimatki idaisaipa.
\q1 
\v 9 Nii jintinjabauwa duka
\q1 amina nugkutaijum pegkeg nugkuaju,
\q1 tuja atsejutai corona atsejaku
\q1 amainaitam nujai betekai.
\q1 
\v 10 Uchuchih,
\q1 aents pegkegchau aidau
\q1 tsanupagtag tuinakuish antugkaipa.
\q1 
\v 11 Tuja dita tujamiajaintaih:
\q1 “Juwi taata nunikamin
\q1 jutijai ijunja tuke aneasa
\q1 ii wakegamu umiktasa
\q1 aents utugchatji atsugbau
\q1 nagkaebaukesh maami,
\q1 
\v 12 dutikaku aents shiig anentaimkau
\q1 aina dushakam dutiksaik maami.
\q1 Dutikawaja nugka tai initak yutua ukukiagmi.
\q1 
\v 13 Dutika waji aidau yajuaka
\q1 wiakchameawagmi.
\q1 ¡Nuniaku iina jenig
\q1 waji kasamkamu aidau
\q1 yajuaka aimkagmi!
\q1 
\v 14 Nuadui taata nunikamin
\q1 kasamkattag nunú akandaika
\q1 yajuakmi”, tujamainakuish,
\q1 
\v 15 ¡amek uchuchi ditajaig wepa!
\q1 Tuja dita pegkegchaun
\q1 takaina duka amek tupanjata.
\q1 
\v 16 Wagki ditak pegkegchaun
\q1 takastatus waugtuinawai;
\q1 ¡Aentsun maatasashkam waugtuinawai!
\b
\q1 
\v 17 Pishak achiktasa,
\q1 pan wainmain apujtusmak,
\q1 pishakak nuna wainu asa
\q1 duka nagkaemamaitsui.
\q1 
\v 18 Tujash nunú aents aidauk
\q1 dita jamainnak dekainayatak
\q1 pempeentumakiag umigmamainawai.
\q1 
\v 19 Nuadui aents magkagtin aina
\q1 duka wiakuch wetajai tukama,
\q1 dita pegkegchau takamtin
\q1 ¡ditashkam dutiksaik maam ainawai!
\s1 Unuimat Apajuínmaya jukitajum tusa ipaamamu
\q1 
\v 20 Unuimatak antugtuktinme tusa
\q1 jinta aidaunum untsumainawai.
\q1 
\v 21 Unuimata duka yaakta waitijin,
\q1 tuja tuwig ima senchi aents aidaush
\q1 tuwawa nuwi aatus untsumainak:
\b
\q1 
\v 22 “Datsauch imanis jintiag
\q1 anentaimchau aidauwah,
\q1 atumesh ¿wajutiya dushikagtutash,
\q1 kajegkagtutash idaisattagme?
\q1 Tuja unuimat dakitajum dusha
\q1 ¿wajutiya idaisattagme?
\q1 ¿Wajutiya unuimagtatjume?
\q1 
\v 23 Wi tajim nunú antuktajum,
\q1 nuniakjumin wi atumnak
\q1 mina wakanjun amastatjime,
\q1 dutikakun mina anentaimtajun
\q1 dekamtikattajime.
\q1 
\v 24 Wi atumnak untsuajime,
\q1 tuja wi ipaajime kaunatajum tusan,
\q1 tujash atumek mina antugtutak dakitagme.
\q1 
\v 25 Nuniau asajum, mina chichamjuk
\q1 kajimatkijum idaisaugme,
\q1 tuja wi atumin jintinbau
\q1 antuka unuimatchakam dakitagme.
\q1 
\v 26 ¡Nuadui wishakam
\q1 atum waitiakjuminish,
\q1 tuja sapigmakjuminish
\q1 ayatak dushittajai!
\q1 
\v 27 Tuja sapigmamu, waitut,
\q1 wake besemag pujamu,
\q1 waugkamin anentaibau aatus,
\q1 dase wainchijai betek
\q1 iyaak nugká ayaunak
\q1 ashí tsaiyama imanik minitjamkui,
\q1 
\v 28 waitiakjum untsugkugminish,
\q1 wika aikchatnaitjime.
\q1 Egatkugmesh waitkashtinaitjume,
\q1 untsugkugmesh ayam achattagme.
\q1 
\v 29 Wagki atumek unuimat
\q1 pegkeja duka dakitau asajum,
\q1 Apajuí umigtashkam dakitagme.
\q1 
\v 30 Nuniau asajum, mina chichameg
\q1 antuka jutak dakitagme,
\q1 tuja wi atumin nunikaigpajum
\q1 tusan tajim dushakam dakitagme.
\q1 
\v 31 ¡Nuadui atumek nunú umiakjum waittsattagme!
\q1 ¡Tuja atum wakegamu
\q1 taka takakuajum pimpiktatjume!
\q1 
\v 32 Aents shiig emetug
\q1 anentaimkachu aina nunak
\q1 nii dekachbaujiya duke pempeentuki maawai.
\q1 Tuja aents pegkegchau aina nunak
\q1 nii wakejus pegkegchaun taka duke
\q1 pempeentuki maawai.
\q1 
\v 33 Untsu mina chichamjun umigtauk
\q1 makichkish ishamkagtutsuk
\q1 agkan shiig pujustinai.”
\c 3
\s1 Unuimat pachisa ujaniamu
\q1 
\v 1 Uchuchih, wi jintinkagtamua nunú kajimatkipa,
\q1 tuja mina chichameg umiktin agagbauwa nunú
\q1 amina anentaimin jukita.
\q1 
\v 2 Nunú umiakum, kuashat tsawan iwaku shiig aneasam pujustinaitme.
\q1 
\v 3 Tuja anenka duka, dekaskea nujai
\q1 makichkish idaisatin aipa;
\q1 duka nugkutaijai betek nugkuaju ata.
\q1 Amina anentaimtagmin
\q1 kajimatmainchau aneaku ata.
\q1 
\v 4 Nuniakum Apajuí wait anentam atatme,
\q1 tuja aents aidaushkam wait anenjamjagtatui.
\b
\q1 
\v 5 Amina dekatjumin kajinmamsa anentaimtsuk,
\q1 ima Tuke Pujuuwaig ashí
\q1 kajinmamsam anentaimta.
\q1 
\v 6 Ashí ame takattam duka
\q1 Apajuí anentaimtusam takasta,
\q1 nuniamin nii pujut pegkegnum etamtatui.
\q1 
\v 7 Ame ima yacha jumamipa,
\q1 duka nunitsuk Tuke Pujuu umigkata,
\q1 nuniakum pegkegchau aina nunú tupanjata.
\q1 
\v 8 Nuniakum jamamtuchu,
\q1 wajiu pegkeg pujuttame.
\b
\q1 
\v 9 Amina tagkujum aidau, wajijum aidau
\q1 akanka Tuke Pujuu suwakum emematta;
\q1 dutikakum ajak ajakmamu aina
\q1 nuwiyashkam yama nagkamchaku
\q1 juukbau Tuke Pujuu susata.
\q1 
\v 10 Dutikakum yutanmash,
\q1 tuja umutnumash atsumkas pujuttame.
\b
\q1 
\v 11 Uchuchih,
\q1 Tuke Pujuu esetamatatus
\q1 suwimkan amaakuig dakitjaipa,
\q1 tuja nii chichagtamkuish kajekaipa.
\q1 
\v 12 Wagki Tuke Pujuuk
\q1 makichik múun uchijin jintintak,
\q1 suwimkan suwama numamtuk,
\q1 nii aneamu aidaun
\q1 jintintak suwimkan suwawai.
\q1 
\v 13 Datsauch unuimaju,
\q1 shiig anentaimkauwa nunak
\q1 Apajuí pegkegnum yumigkiawai.
\q1 
\v 14 ¡Nunú unuimata nunuwai oron nagkaesau,
\q1 plata nagkaesau pegkeja duka!
\q1 
\v 15 Unuimat shiig anentaimja
\q1 pujutan sukagta duka,
\q1 kaya shiig pegkejuch akik aina
\q1 nuna nagkaesauwai.
\q1 ¡Iman asa tikich waji pegkeg
\q1 wakejumain aina nujaigkish betekchauwai!
\q1 
\v 16 Aents unuimaju, yacha duka
\q1 kuashat mijan pujustinai,
\q1 nunik wiakuch wajas eme anentam atinai.
\q1 
\v 17 Apajuín chichame umiamua
\q1 nunú ima pegkejai,
\q1 tuja nii jintinkagtamu
\q1 betek umiamua nunú
\q1 agkan pujutan sukagtawai.
\q1 
\v 18 Shiig anentaimja pujutan unuimaina
\q1 nunú pujutan juwinawai.
\q1 Shiig anentaimja pujutan juidauk,
\q1 numi pujuta sukagtinjai betek ainawai.
\q1 Tuja nunú unuimatan jukiaju aidauk
\q1 shiig aneasagtinai.
\c 6
\s1 Daki aipa
\q1 
\v 6 Dakih, week wajuk takawa
\q1 nunú weme diisam unuimagta:
\q1 
\v 7 Weeka inauk atsawai,
\q1 tuja nunú dutikata tusa
\q1 tumainchakam atsawai,
\q1 
\v 8 nuniaig nii yuwatnujinak esattin
\q1 ajak juut jegamtai, juuka ijumui.
\q1 
\v 9 ¡Dakih, yamai kanaschaum jamah!
\q1 ¿Wajupa asamea nantaktatme?
\q1 
\v 10 Ame kanú tepamin,
\q1 tuja kajim mantamkui pukuga eketmin,
\q1 tuja shiig kanagtasam
\q1 pagku pagkumasa tepamin,
\q1 
\v 11 waitut, kasajai betek pachiachbau iyanjama
\q1 shiig ujuuna awajtamsattawai.
\s1 Apajuí dakitamua nunú
\q1 
\v 16 Awai seisa imajin, tuja nuigtu
\q1 makichik, nujai ijumjamak sieteya imani
\q1 Tuke Pujuu shiig dakita nunú:
\q1 
\v 17 Emebau aidaun, waitjin aidaun,
\q1 aents utugchatji atsujunak main aidaun,
\q1 
\v 18 aents anentaimtaji pegkegchau aidaun,
\q1 pegkegchau takatan wakejus wekaetaun,
\q1 
\v 19 tikichin tsanumjin,
\q1 tuja waitjin, chichama tsanumjug
\q1 niina yachijaig maanimitkau aidaun
\q1 aatus Apajuík dakitawai.
\c 7
\s1 Nuwa aishin pegkegchau takajin aidau ujaamu
\q1 
\v 1 ¡Uchuchih, mina chichameg umikta,
\q1 mina chichameg umiktin agagbauwa nunú
\q1 shiig aneaku ata!
\q1 
\v 2 Mina chichameg umiktin
\q1 agagbau aina nunú umikta;
\q1 dutikakum amina jiim kuitamainaitam imatiksam kuitamkata,
\q1 nuniakum iwaku pujuttame.
\q1 
\v 3 Amina tsajam uwegmin jigka nenau ata,
\q1 anentaimin kajimatmainchau, aneaku ata.
\q1 
\v 4 Unuimata duka amina umaimijai betek emata,
\q1 tuja yachameta nunú amina kumpajum emata.
\q1 
\v 5 Tuja nuwa aishin pegkegchaun takamjin,
\q1 pegkegchin chichagtamak,
\q1 tsanuja pegkegchaun takamtiksai tusa,
\q1 unuimata nunú ayamjutpaktatui.
\b
\q1 
\v 6 Makichik tsawantai jeganum
\q1 niimtai ujaimunum wi niimkun wajayajai.
\q1 
\v 7 Nunika niimku wajai,
\q1 uchi datsa imanik jintiag
\q1 anentaimkachu aidau yujainamunum,
\q1 nuwi makichik datsauch nuni nagkaemas
\q1 shiig esegag anentaimkachun wainkabiajai.
\q1 
\v 8 Nunú uchik jinta aintug juwaki,
\q1 jinta tuniakbaunum jeganta
\q1 nunú nuwa jeega nuni wemayi.
\q1 
\v 9 Nuniaig etsa akaemayi,
\q1 nuniak suwe wemayi.
\q1 
\v 10 Nuniai nuwa akika dutiktai iwagmamin
\q1 aina nujai betek, makichik nuwa iwagmamjau,
\q1 pegkegchaun takamin asa
\q1 nunú anentaiyai jiinkibi uchin igkugtatus.
\q1 
\v 11 Nunú nuwak setakchau datsantainkachu,
\q1 tuja emetnag jeen titu pujuchu,
\q1 
\v 12 jinta ain wekayin, tuja plazanum,
\q1 jinta tuniakunum aents nagkaebaun igkug,
\q1 pegkegchau takamtiksatatus wekayin.
\q1 
\v 13 Nunin asa nunú uchi wetatman
\q1 pagkuk saukua ajantsuk chichajak:
\q1 
\v 14 “Wi mina apajuímtaiju
\q1 emematkun kuntinun maamua
\q1 nuna nejen ajamsatjame.
\q1 Wi dutikatjai tibaugnak yamai betek umikjai.
\q1 
\v 15 Nuadui amina igkugtasan jiinkijai,
\q1 amina wainkatasan shiig senchi
\q1 egamjam nuna yamai igkugjame.
\q1 
\v 16 Mina pegakjui,
\q1 colcha egiptunmaya lino
\q1 pegkeg najanamun ainkamjai,
\q1 
\v 17 dutikan kugkuin pegkeg mirra,
\q1 áloe, canela aidauwai ukatkamjai.
\q1 
\v 18 Wayata nunikamin ii wakegamu a aniakua tuke tsawampagmi.
\q1 
\v 19 Mina aishjuk atsawai;
\q1 tikich nugkanum wemayi.
\q1 
\v 20 Kuichkin aimak juki wemayi,
\q1 nuadui wamkek tashtatui,
\q1 nantu antumai taattawai”, tau.
\b
\q1 
\v 21 Tusa pegkegchin ima
\q1 imatjakua wakemitkakmayi,
\q1 
\v 22 dutikam buey maatasa
\q1 juki ematiama numamtuk,
\q1 tuja kuntin maatasa dakamtikamunum
\q1 japa egkemkamtai,
\q1 
\v 23 flechayai anentai ijutim
\q1 jama numamtuk wajaktatus,
\q1 tuja pishak achiktasa
\q1 detua ukukbaunum awimpap
\q1 jakattaja tusa dekachu asa,
\q1 wemaina numamtuk nuwan pataetuk megkaekabi.
\b
\q1 
\v 24 Nunika megkaekatag tachakmek
\q1 uchuchih, mina chichameg antukam umikta.
\q1 
\v 25 Amek nunú nuwa duka
\q1 anentaimtusmek diisaipa.
\q1 Wagki nunú wekaetakum,
\q1 amina pujutjumin megkaekaim.
\q1 
\v 26 Nunú nuwa duka kuashat aentsun
\q1 pegkegchaun takamtikas emegkawai.
\q1 ¡Nii emegkagbau aidauk shiig kuashtai!
\q1 
\v 27 Tuja niina jeen wayamua duka
\q1 jaka megkaemaina nujai betekai.
\c 8
\s1 Unuimatan chichame
\q1 
\v 1 Unuimata duka senchi untsumui;
\q1 yachameta nunú niina chichamen
\q1 antumtikagtawai.
\q1 
\v 2 Nain aidaunum,
\q1 jinta amatkau aidaunum,
\q1 
\v 3 tuja waiti aidaunum,
\q1 yaaktanum waitainum wajas untsumak:
\q1 
\v 4 “¡Ashí aents aidautigmin juna tajime!
\q1 
\v 5 Datsauch jintiag anentaimkachu aidautigmesh
\q1 shiig anentaimkau atajum;
\q1 tuja atum shiig anentaimkachu aidautigmek,
\q1 eseja anentaimat unuimagtajum.
\q1 
\v 6 Pegkeg unuimamainun
\q1 wi titatjim nunú shiig antuka jukitajum.
\q1 
\v 7 Wi titatag duka dekaske;
\q1 minak waitjutak shiig awajtuchui.
\q1 
\v 8 Mina chichamjuk ashí pegkejai;
\q1 wika jimag weninnuchuitjai.
\q1 
\v 9 Aents shiig anentaimkauwa
\q1 nunú diismak mina chichamjuk dakitmainchau
\q1 paan antumainai.
\q1 
\v 10 Plata jumain idaikujum,
\q1 dekas wi jintiamua nunú jukitajum,
\q1 tuja oro shiig pegkeg jumain idaikujum,
\q1 dekas unuimata nunú jukitajum.
\q1 
\v 11 Unuimata duka kaya pegkejuch aina
\q1 nuna nagkaesauwai.
\q1 Tuja waji pegkeg wakemain ainakush,
\q1 makichkish unuimatjaig betekchauwai.
\q1 
\v 12 Witjai dekatnuk,
\q1 witjai chicham pegkejan sukagtinnuk,
\q1 tuja wi dutikatag takunuk
\q1 shiig anentaimsan dutikajai.
\q1 
\v 13 Tuke Pujuun umija duka
\q1 pegkegchau takat aina nunak kajejawai.
\q1 Tuja ememamu,
\q1 tikich wagagkau anentaimat, pegkegchau takat,
\q1 waitjut aina nunak wika kajejajai.
\q1 
\v 14 Chichagkagtut, pegkegnum anentaimat,
\q1 yachamet, unuimat aina duka midau ainawai.
\q1 Tuja senchia dushakam midauwai.
\q1 
\v 15 Wi nunikti tibau asag apu wenawai,
\q1 nuninak chicham umiktin
\q1 dekas pegkeg aidaun najanainawai.
\q1 
\v 16 Ashí apu nugkanum inamin aina duka,
\q1 wi nunikti tibau asag inamainawai.
\q1 
\v 17 Tuja mina anentuidaunak
\q1 wishakam dutiksanuk aneajai,
\q1 tuja mina egatuidaunashkam wantintajai.
\q1 
\v 18 Wiakchamet, eme anentam ata,
\q1 shiig pujut, waji wamak megkaejashtin
\q1 aina nunashkam wi suwajai.
\q1 
\v 19 Wi sukagtamua duka
\q1 oro pegkeja nuna nagkaesauwai,
\q1 tuja wi sukagtamua duka
\q1 plata akiken nagkaesauwai.
\q1 
\v 20 Wika tuke pegkejan takauwaitjai,
\q1 
\v 21 nuniau asan mina anentuidaunak,
\q1 kuashat wajigtin wiakuch emajai.
\b
\q1 
\v 22 “Tuke Pujuu minak najatuawai.
\q1 Nii najankamu aina nunak
\q1 eke najantsuk miná najatuawai.
\q1 
\v 23 Tuja nugkanak eke
\q1 najantsuk miná najatuawai.
\q1 
\v 24 Mina najatuawa nuaduik
\q1 nayantsak atsujakui,
\q1 tuja yumi pukuni jiinaidaush,
\q1 namak aidaush atsujakui.
\q1 
\v 25 Tuke Pujuuk muja aidaun, nain aidaun
\q1 eke najantsuk miná najatuauwai.
\q1 
\v 26 Tuja nugkanak ikam aidaunash,
\q1 nuigtu nugka yukukuntujai nugkan najankauwa
\q1 nunakesh najantsuk miná najatuauwai.
\q1 
\v 27 Apajuí nayaimpin yumi
\q1 piyajunum eneknak najanauwa
\q1 nuaduik wika pujuyajai.
\q1 
\v 28 Tuja yakí agkajunum yujagmin najana umika,
\q1 nayantsan initken yumi pukuni jiinaidaun epetug,
\q1 
\v 29 nayantsanum yumi piyag betsakai tusa emetug idayak,
\q1 tuja nugka buchitmainchau
\q1 atinun umikua nuadui nagkamsan,
\q1 
\v 30 wika Apajuí takakui,
\q1 niijai takakun pujuyajai.
\q1 Wi ayajai niina shiig anemtikin,
\q1 tuja niina emtinig shiig aneasan
\q1 wasugkamkun pujuyajai.
\q1 
\v 31 Apajuí nugka najanamun
\q1 diisan shiig aneyajai,
\q1 tuja nii aentsun najanauwa nuna
\q1 diisan shiig aneamu ajuti.
\b
\q1 
\v 32 “Nuadui uchig aidauwah,
\q1 wi tajim nunú antugtuktajum:
\q1 Wi tajim nunú umiakjumek,
\q1 Apajuí yayaam atinaitjume.
\q1 
\v 33 Wi jintinjim nunú dakittsuk
\q1 shiig unuimagtajum,
\q1 nuniakjum shiig anentaimkau atajum.
\q1 
\v 34 Aents kashi kashinig mina jegajui taa
\q1 mina chichamjun antugtauk shiig aneastinai,
\q1 wagki Apajuí yayamu asa.
\q1 
\v 35 Mina igkuntuk pujutan juwawai,
\q1 nunik Tuke Pujuu wait anentam awai.
\q1 
\v 36 Tuja mina pegkegchaun chichagtauk
\q1 jaka megkaetanum pujawai.
\q1 ¡Tuja mina kajegtuina duka
\q1 jaka megkaetan aneenak núninawai!”
\c 13
\q1 
\v 1 Uchi shiig anentaimkauwa duka
\q1 niina apaji chichamen umignai,
\q1 untsu uchi anentainkachua duka
\q1 apaji chichamenak antugtsui.
\q1 
\v 2 Maki makichik aentsuk nii pegkeg chichakbaujinian pegkejan juwawai,
\q1 untsu aents chichaman betek umichu aina duka
\q1 dita pegkegchaujin suwimkan juwinawai.
\q1 
\v 3 Shiig anentaimag chichauk
\q1 niina pujutjin kuitamak nuniawai,
\q1 untsu wainak chichá wekaguk kuashat utugchatan igkuawai.
\q1 
\v 4 Aents dakia duka
\q1 nii wakegamujin jukitag takush juwatsui,
\q1 untsu aents takauwa nudauk
\q1 kuashat waji ajawai.
\q1 
\v 5 Aents pegkegchau takatan
\q1 tupanjauk waitjutnak dakitawai.
\q1 Untsu aents pegkegchaun takauk
\q1 eme anentsa diishtai,
\q1 datsan chichajam auwai.
\b
\q1 
\v 6 Shiig anentaimsa pujamua nunú
\q1 aentsnak pegkeg emawai,
\q1 untsu aents pegkegchaun takau aina
\q1 nunak niina pegkegchaujig bakuawai.
\q1 
\v 7 Awai aents makichkish wajigtuchuitak
\q1 wiakuch atajai tusa wakegau,
\q1 tuja antsag kuashat wajigtin aidaushkam
\q1 wajigtuchuapi tujuttinme tusa uumush ainawai.
\q1 
\v 8 Aents wiakcha duka achikmak,
\q1 mantuawainum tusa ishamkagtak
\q1 niina kuichkijin ashí akikmak uwemainai,
\q1 untsu ujunauchik achigkachagtimpash
\q1 tusa anentaimkug waitiatsui.
\q1 
\v 9 Aents pegkegchau takatan
\q1 tupanjau aina duka tsaaptin pegkeg winchamtinama iman ainawai,
\q1 untsu aents pegkegchauwa duka
\q1 jii kajinkaujai betekai.
\b
\q1 
\v 10 Ememata duka ima maanitnak inimui;
\q1 untsu unuimata nunú
\q1 aents chichama antuk umin aina nuwi awai.
\q1 
\v 11 Yupichuch wiakchameamua duka
\q1 wamak amugak megkaewai;
\q1 tuja aents shiig takak,
\q1 diipas wiakchamea duka kuashat ikauwai.
\q1 
\v 12 Tuja ii wakegamu uminchakuig,
\q1 wake besemag dekapnawai.
\q1 Untsu ii atsumamu betek uminkuig,
\q1 shiig aneamu ajutkagtawai.
\q1 
\v 13 Aents chichaman umiachuk
\q1 suwimkan jukitnai;
\q1 untsu chichaman umiauk akiam atinai.
\b
\q1 
\v 14 Aents shiig anentaimkau
\q1 jintinkagtamua duka pujutan sukagtawai,
\q1 nuadui jamainun uwemtikagtawai.
\q1 
\v 15 Shiig jintinkagtauk shiig anentam auwai,
\q1 untsu shiig jintinkagtachuk
\q1 pegkegchaunum jegantinai.
\q1 
\v 16 Aents yacha shiig anentaimkauwa duka
\q1 shiig anentaimag takawai,
\q1 untsu aents anentainkachua duka
\q1 nii dekachbaujiya nuna iwaintumawai.
\b
\q1 
\v 17 Aents chichaman betek etsegchauwa
\q1 duka utugchatan apujui,
\q1 untsu chichaman shiig
\q1 betek etsegna nunú
\q1 aentsnak shiig anemtikawai.
\b
\q1 
\v 18 Aents chichagkatatama dakitauk,
\q1 waittanum, datsannum pujutnai;
\q1 untsu chichaman antuk umiauk,
\q1 eme anentam atinai.
\q1 
\v 19 Ii wakegamu uminkuig shiig aneenui;
\q1 tuja aents anentainkachu aina duka
\q1 pegkegchau takat idaitanak atsanenatsui.
\b
\q1 
\v 20 Aents yacha aidaujai tsaniauk,
\q1 niishkam yacha atinai,
\q1 untsu aents shiig anentainkachu aina nujai tsaniauk, pegkegchaunum jegatnai.
\c 15
\q1 
\v 1 Pegkegnum aimawa nunú
\q1 kajekbaunak imijiawai;
\q1 untsu kajeka aimawa duka nuni senchi kajeamun inimui.
\b
\q1 
\v 2 Aents yacha shiig anentaimkau aina
\q1 nuna chichameg unuimatan sukagtawai,
\q1 untsu aents anentainkachu aina
\q1 nuna chichameg pegkegchau ainawai.
\b
\q1 
\v 3 Tuke Pujuuk ashí yantamnum pujawai,
\q1 nuniau asa aents pegkeg aidaun pegkegchau aidaujai diyakui.
\q1 
\v 4 Pegkeg chichamua nunú aentsnak pegkegnum yayawai.
\q1 Untsu pegkegchau chichamua nunú aentsu pujutin emestawai.
\b
\q1 
\v 5 Aents anentainkachua duka
\q1 niina apaji jintinmash dakitawai,
\q1 untsu yacha shiig anentaimkauwa duka niina apaji chichamen antujui.
\b
\q1 
\v 6 Aents Apajuí umigna duka
\q1 shiig kuashat wajigtinai,
\q1 untsu aents pegkegchauwa nunak
\q1 niina wajijiya duke utugchatan itajui.
\b
\q1 
\v 7 Aents yacha shiig anentaimkauwa duka
\q1 nii dekamujin tikich aentsnash
\q1 pegkejan jintintui.
\q1 Untsu aents anentainkachu aina duka
\q1 pegkegchauwa nuna jintintui.
\b
\q1 
\v 8 Aents pegkegchau aidau
\q1 Apajuí anentag suwaji tusag,
\q1 kuntinun maa apeena duka
\q1 Tuke Pujuunak shiig awagmatsui.
\q1 Untsu aents pegkegchau takatan tupanjau aina
\q1 nunú segamak Apajuík shiig antujui.
\b
\q1 
\v 9 Tuke Pujuuk aents pegkegchau aina
\q1 nuna pujutjinak dakitawai,
\q1 untsu ya tudaun tupantug
\q1 pegkejan takak pujawa nuna aneawai.
\c 20
\q1 
\v 1 Vino nampeamua nunú
\q1 aentsun pegkegchau chichamtin emawai;
\q1 uwaja nampetai aina duka utugchatan inimui;
\q1 nuna uwag nampeauk shiig anentaimag chichatsui.
\b
\q1 
\v 2 Apu kajena duka
\q1 león kajeak shinuwama imanai;
\q1 tuja nuna apun ikajeauk nigki bakumawai.
\b
\q1 
\v 3 Aents pegkegchau takatan
\q1 tupanjauk jiyanitnak dakitawai;
\q1 untsu anentainkachua duka jiyanitan wekaetawai.
\q1 
\v 4 Aents dakia duka aja takamain esat tepeau aig,
\q1 takatsuk pujau asa,
\q1 yumi tepeamtai nii yumainjig atsugtinai.
\q1 
\v 5 Aentsu anentaimtajig
\q1 nayantsa kunajinia wainmaitsu numamtinai.
\q1 Untsu aents yacha duka
\q1 nuna takumpap tawa tusa shiig dekawai.
\b
\q1 
\v 6 Kuashat aents aidau,
\q1 amina kumpauchijum atajai tuinawai;
\q1 ¿tujash dekas aents imanush igkumainashit?
\q1 
\v 7 ¡Aents pegkegchau takatan
\q1 tupanjau aidaun uchiji aidauk,
\q1 dita apaji pegkejan takajaku aina nujai betek
\q1 pegkejan takainak,
\q1 Apajuí yayamu asag shiig aneasagtinai!
\c 22
\q1 
\v 1 Pegkegnum augmatam ata nunuwai
\q1 wiakchameutan nagkaesau.
\q1 
\v 2 Aents wiakuch akush ujunajaig betekai,
\q1 wagki mai Tuke Pujuu najanamu asag.
\q1 
\v 3 Aents yacha shiig anentaimkauwa duka
\q1 pegkegchaun wainkug wamak idaiwai;
\q1 untsu aents anentainkachua duka
\q1 ayatak akuumtawai, nuniau asa,
\q1 utugchatan igkug waitiawai.
\q1 
\v 4 Apajuí eme anentsa puyatjusa umigbauwa nunú
\q1 sukagtawai pujutan, wiakchameutan,
\q1 eme anentam atan.
\q1 
\v 5 Aents pegkegchau aina nuna
\q1 tsanumtaiji aidauk ishamain ainawai.
\q1 Untsu aents niina pujutjin
\q1 kuitama duka nunak tupantawai.
\b
\q1 
\v 6 Amina uchigmek piipichia duik shiig jintintuata,
\q1 dutikamu asa múun wajasash kajimatkishtinai.
\c 23
\q1 
\v 4 Wiakuch atajai tusam
\q1 anentaimkum waittsaipa,
\q1 duka puyatjutsuk idaisata.
\q1 
\v 5 Ame shiig anentaimsa diyakmek,
\q1 wiakuch wetak wainkaya nunú dekaattame,
\q1 wagki duka águila uchiji aidau
\q1 nanapjuk nanaak shimak megkagama
\q1 numamtuk megkaewai.
\b
\q1 
\v 19 Uchuchih, wi tajam nunú
\q1 shiig antukam unuimagta,
\q1 nuniakum shiig anentaimsam pegkeg takata duke takasta.
\q1 
\v 20 Aents nampeku aidaujai
\q1 ijunjamek wekaesaipa,
\q1 tuja ushu aina nujaishkam kumpajinawaipa.
\q1 
\v 21 Wagki nampen aidauk,
\q1 ushu aidauk, ujuuna wenawai,
\q1 tuja daki aidauk jáanch pegkegchau
\q1 ampinkau mamuku aidaun apajag nugkuinawai.
\q1 
\v 22 Apa amina akimpawa
\q1 nuna chichame antugkata;
\q1 tuja amina duku múuntuch
\q1 wajasmataish dakitjaipa.
\q1 
\v 23 Dekaskea nunú, yachameta nunú,
\q1 jintinjamamu aina nunú,
\q1 unuimata nunú aatsam sumakta.
\q1 ¡Dutikamek duka sujukaipa!
\q1 
\v 24 Uchi pegkeg, yacha,
\q1 shiig anentaimkauwa nuna apajig
\q1 shiig aneak ememas anentaimui.
\q1 
\v 25 ¡Yajauwajah, uchi yacha shiig anentaimkau aidaunmak!
\q1 Nuadui uchita atumek atumi apa dukujai
\q1 shiig anemtiksatajum.
\b
\q1 
\v 26 Uchuchih,
\q1 wi tajam nunú shiig antukta,
\q1 nuniakum wi jintintuawaitjam nunú kajimatkipa;
\q1 
\v 27 wagki nuwa akika dutiktai aina duka
\q1 waa múun suwe ishamainama imanai;
\q1 tuja nuwa aishintin tikichjai
\q1 tsanijinna dushakam waa tsejegkush,
\q1 init akagama numamtinai.
\q1 
\v 28 Nuadui kasajai betek
\q1 kuashat aishmag aidaun achiawai,
\q1 dutika aents nuna yujajin aina
\q1 nujai betek emawai.
\b
\q1 
\v 29 ¿Yaita waitiaush?
\q1 ¿Ya waitiakush ejetua?
\q1 ¿Yaita utugchatan apujus
\q1 anentaimak waitu wekagush?
\q1 ¿Yaita nigki suwimkan sumamas waitiaush?
\q1 ¿Yaita bushapajun niim wekagush?
\q1 
\v 30 Nunak vino uwaja,
\q1 nampetan makichkish idaitsuk,
\q1 tikich umutai aidaunashkam umú yujau aina nunú
\q1 nunak núninawai.
\q1 
\v 31 ¡Datsauchih, uwaja nampetai aidau
\q1 kajiak niime pegkeg wega duka
\q1 makichkish anentaimtusmek diisaipa!
\q1 ¡Nunú diyakmek wakejukam uwagtatme!
\q1 
\v 32 Tuja niimeg pegkejaitak,
\q1 dapi esajatbau tsaagke najamama imanai.
\q1 
\v 33 Iman asamtai nunú umakmek,
\q1 pegkegchau wainchatai aidau waintatme,
\q1 tuja pegkegchau anentaimkum
\q1 ima pegkegchauk chichattame.
\q1 
\v 34 Nuniakum lanchanum egkemjanus
\q1 yakí jiitkaunum ekemsan nayantsanum
\q1 wegagtai dekaptatme.
\q1 
\v 35 Nuniakum: “Awatujagmae,
\q1 tujash dekapjachmajai;
\q1 asutuinakuish dekapjachmajai;
\q1 tujash nunak puyatjatsjai,
\q1 juna sakapagnuk nantakin vino egakan,
\q1 nuni kuashat uwagtatjai”, titatme.
\c 24
\q1 
\v 3 Jegak shiig anentaimsa jegamtayai,
\q1 tuja shugkushkam
\q1 shiig anentaimsa ajitayai.
\q1 
\v 4 Waji pegkejuch wakejumain aidau
\q1 ijumaina numamtuk, unuimata nuna
\q1 niina kanutaiji aidaunum ijumui.
\q1 
\v 5 Aents yacha nunuwai tikich aents
\q1 senchigtina nuna nagkaesauk.
\q1 Unuimata nunuwai dekas
\q1 senchigtin ata nuna nagkaesauk.
\q1 
\v 6 Wagki maaniatag takuik, shiig anentaimsa
\q1 chicham umika maanitayai,
\q1 tuja depetmaktatus wakegauk
\q1 tikichi chichamenash shiig antuku amainai.
\b
\q1 
\v 17 Amina shiwaajum waituinakuish,
\q1 shiig aneakjum dushikjaigpajum,
\q1 tuja utugchatji ajakuish dushikjaigpa.
\q1 
\v 18 Wagki duka Tuke Pujuunak shiig awagmatsui,
\q1 nuniau asa amina kajegtamak suwimkan amamainai.
\q1 
\v 19 Aents pegkegchau aidau diisam kajekaipa,
\q1 tuja niina wajiji aidau
\q1 diigsamesh kajegkaipa.
\q1 
\v 20 Wagki aents pegkegchauwa duka
\q1 pegkeg pujutnakesh jukishtinai.
\q1 ¡Aents pegkegchau aina duka
\q1 lampara ikagnakbaujai betek agtinai!
\c 25
\p 
\v 21 Amina shiwajumesh yapajakuig,
\q1 yutai ajamsata;
\q1 tuja kitamakuishkam umutai susata.
\q1 
\v 22 Nunú ame dutikamin,
\q1 amina pegkegchau awajtamin asa
\q1 nii tuma datsaagtatui,
\q1 Nuadui Tuke Pujuu aminak
\q1 pegkegnum akigmaktinai.
\c 27
\q1 
\v 1 Kashin nuna imatikan takastatjai
\q1 tusamek emtikamek tumamipa,
\q1 wagki amek dekatsme
\q1 kashinish wajukatamki duka.
\q1 
\v 2 Duka amekek imatipa,
\q1 idaisata nunak tikich aidau tujamtinme,
\q1 iik eme anenmamku
\q1 imatbauk pegkegchauwai.
\b
\q1 
\v 3 Kaya, kamatak aina duka
\q1 senchi kijin ainawai,
\q1 tujash nuna nagkaesau kijinai
\q1 aents anentainkachu nii wakegamun
\q1 umiktakama kajeamujiya nunú.
\q1 
\v 4 Kajeamua duka pegkegchauwai, tutitjan itawai,
\q1 tujash nuna nagkaesau
\q1 kakajus depetmainchauwa duka,
\q1 tikich takakui diisa kajegkagtamua nunuwai.
\b
\q1 
\v 5 Aents amina anempa duka
\q1 uuka chichá wekaetsuk,
\q1 paan igkumpa tujamtatui.
\q1 
\v 6 Shiwag kajegtamiatak tsanupak kumpamjama nunú kajittsa diitsuk,
\q1 dekas iina kumpaji igkujatua tukagta nuwi
\q1 kajintsa anentaimainai.
\c 30
\q1 
\v 18 Wi puyatjusa diyamug aidauk
\q1 kampatum waji, tuja nuigtu makichik,
\q1 nujai ijumjamak ipak usumta imajin ainawai.
\q1 Tujash shiig ejeyin dekamainchau dekapeajai.
\q1 
\v 19 Duka juju ainawai:
\q1 “Águila yakí wekaga nuna jintig dekamaitsui,
\q1 tuja kaya aidaunmash dapi jintish
\q1 wajuk awaki duka shiig dekamaitsui.
\q1 Tuja lancha nayantsanum wekaga nuna jintishkam dekamaitsui;
\q1 tuja wagkag aishmagkush imatikash
\q1 nuwanash wakegawa dushakam dekamaitsui.
\q1 Juju aina nuna shiig ejeyin
\q1 dekamainchau dekapeajai.”
\c 31
\s1 Nuwa pegkeg // eme anentsa diitai
\q1 
\v 10 Nuwa shiig anentaimkauk
\q1 kakajus igkumaitsui,
\q1 ¡kaya pegkejuch akik aina
\q1 nuna nagkaesauwai!
\q1 
\v 11 Niina aishig shiig kajitus diyawai,
\q1 tuja kuichkinash atsumchagtinai.
\q1 
\v 12 Niina aishig, nuwe utugchatan apujtus
\q1 waitkachbau asa,
\q1 tuké shiig aneas pujawai.
\q1 
\v 13 Lanan ujuchjai egaka sumak,
\q1 nuna wakejus shiig aneas jáanchi apijug najanak pujawai.
\q1 
\v 14 Lancha wajiin atushtanmayan ikaunmama numamtuk,
\q1 nunú nuwa dita yuwatnujinak atushtanmayan ikaunmawai.
\q1 
\v 15 Dutika eke tsawatsaig nantaki,
\q1 yutain inajuk uchiji aidaun
\q1 inake aidaujai ayujuk,
\q1 inake aidaunak takatnum ishimui.
\q1 
\v 16 Tuja nugka pegkejan diisa,
\q1 nuna akikenak nii takasa jukimui
\q1 betek akikmak sumawai.
\q1 Dutika nuwi uvan ajakmawai.
\q1 
\v 17 Aatus kakaag senchi takau asa,
\q1 shiig aneas kashikmas nagkama taka takakua etsa akapak ukuawai.
\q1 
\v 18 Wajiji kuashat kawegti tau asa nii kuitamui,
\q1 tuja kashish takau asamtai, jii tuké keeka awai.
\q1 
\v 19 Tuja niina jáanchjinash
\q1 nigki apaja nugkuawai.
\q1 
\v 20 Tuja ujudauch aidau
\q1 atsumiagtaish, yayawai.
\q1 
\v 21 Tsetsek tepetaish,
\q1 niina uchiji aidaunak puyatjatsui,
\q1 wagki ditak jáanchin shiig nugkujag yujaidau asagmatai.
\q1 
\v 22 Colchajinash nigki najanui,
\q1 tuja niig jáanch shiig pegkeg
\q1 apagbau aidaun nugkuawai.
\q1 
\v 23 Tuja niina aishinashkam
\q1 yaaktanmaya aidauk ashí wainainawai,
\q1 wagki apu eme anentsa diitai aina nuwi niishkam
\q1 pachitkau asamtai.
\q1 
\v 24 Nunú nuwak jáanch aidaun
\q1 akachumtai aidaujai najanak,
\q1 waji sujin aidaunum sujawai.
\q1 
\v 25 Eme anentsa diitai asa,
\q1 nuna megkaekaig tusa kuitamamui.
\q1 Tuja atakea duish wajukatnukitja
\q1 tusagkesh puyatmamtsui.
\q1 
\v 26 Chichaakush shiig anentaimas chichawai,
\q1 tuja niina uchijinash shiig anentus jintintui.
\q1 
\v 27 Niina jeen utugchat ai tusa aneaku pujawai,
\q1 tuja nii takasa jukichbaujinianak yuwatsui.
\q1 
\v 28 Nuadui niina uchiji aidau
\q1 niina aishijai emematus chichajuinak:
\q1 
\v 29 “¡Nuwa pegkeg aidauk kuashat ayawai,
\q1 tujash ametme ashí tikich nuwa aina
\q1 nuna nagkaesaumek!” tuinawai.
\q1 
\v 30 Nuwa shigmaji diisa wakejamua duka wainkayai,
\q1 tuja shiig awajkagtamujia
\q1 dushakam wainkayai,
\q1 dekas nuwa Tuke Pujuun umigna
\q1 nunuwai ememattsa diyam auwa duka.
\q1 
\v 31 ¡Niina takatji pegkeja nunú anentaimtusjum,
\q1 ashí aents aidau emtin eme anentsajum
\q1 pegkegnum chichagtajum!
