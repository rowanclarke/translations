\p 
\v 1 \w La|strong="G2532"\w* \w Pâque|strong="G3957"\w* \w et|strong="G2532"\w* \w les|strong="G2532"\w* Azymes\f + \fr 14:1 \ft \it La Pâque\it* était marquée par l’immolation et la manducation de l’agneau pascal. La fête des \it Azymes\it* ou pains sans levain débutait avec la Pâque. Voir Mat 26:1-17 (notes).\f* \w devaient|strong="G2532"\w* \w avoir|strong="G2532"\w* \w lieu|strong="G3326"\w* \w deux|strong="G1417"\w* \w jours|strong="G2250"\w* \w après|strong="G3326"\w* ; \w et|strong="G2532"\w* \w les|strong="G2532"\w* \w Princes|strong="G2532"\w* \w des|strong="G2532"\w* prêtres \w et|strong="G2532"\w* \w les|strong="G2532"\w* \w Scribes|strong="G1122"\w* \w cherchaient|strong="G2212"\w* \w les|strong="G2532"\w* \w moyens|strong="G4459"\w* \w de|strong="G2532"\w* \w se|strong="G2532"\w* \w saisir|strong="G2902"\w* \w de|strong="G2532"\w* \w Jésus|strong="G2532"\w* \w par|strong="G1722"\w* \w ruse|strong="G1388"\w*, \w afin|strong="G2532"\w* \w de|strong="G2532"\w* \w le|strong="G2532"\w* \w faire|strong="G2532"\w* \w mourir|strong="G2532"\w*.\f + \fr 14:1 \ft 14, 1. Matth. 26, 1 ; Luc. 22, 1.\f*
\v 2 « \w Mais|strong="G1063"\w*, disaient-ils, \w que|strong="G3588"\w* \w ce|strong="G3588"\w* \w ne|strong="G3361"\w* \w soit|strong="G3361"\w* \w pas|strong="G3361"\w* \w pendant|strong="G1722"\w* \w la|strong="G1722"\w* \w fête|strong="G1859"\w*, \w de|strong="G1722"\w* \w peur|strong="G3379"\w* \w qu|strong="G1063"\w*’\w il|strong="G1063"\w* \w n|strong="G3361"\w*’\w y|strong="G1722"\w* ait \w du|strong="G1722"\w* \w tumulte|strong="G2351"\w* \w parmi|strong="G1722"\w* \w le|strong="G1722"\w* \w peuple|strong="G2992"\w*. »
\s2 L’onction de Béthanie
