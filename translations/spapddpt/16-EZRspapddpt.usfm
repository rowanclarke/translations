\v 11 Cantaban, alababan \w y|strong="H3588"\w* daban gracias \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*:  
\q1 \w Porque|strong="H3588"\w* \w Él|strong="H5921"\w* \w es|strong="H3588"\w* \w bueno|strong="H2896"\w*, \w porque|strong="H3588"\w* \w para|strong="H5921"\w* \w siempre|strong="H5769"\w* \w es|strong="H3588"\w* \w su|strong="H3588"\w* \w misericordia|strong="H2617"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\p \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* dio un \w gran|strong="H1419"\w* grito \w cuando|strong="H3588"\w* alabó \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w porque|strong="H3588"\w* fueron puestos \w los|strong="H5921"\w* \w cimientos|strong="H3245"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 12 Pero \w muchos|strong="H7227"\w* \w de|strong="H5869"\w* los \w sacerdotes|strong="H3548"\w*, los \w levitas|strong="H3881"\w*, los \w jefes|strong="H7218"\w* \w de|strong="H5869"\w* \w casas|strong="H1004"\w* paternas y los \w ancianos|strong="H2205"\w* \w que|strong="H2088"\w* \w vieron|strong="H7200"\w* el \w primer|strong="H7218"\w* \w Templo|strong="H1004"\w*, \w lloraban|strong="H1058"\w* en \w alta|strong="H7311"\w* \w voz|strong="H6963"\w* cuando ante sus \w ojos|strong="H5869"\w* eran puestos los \w cimientos|strong="H3245"\w* \w de|strong="H5869"\w* \w esta|strong="H2088"\w* \w Casa|strong="H1004"\w*, mientras \w muchos|strong="H7227"\w* daban \w gritos|strong="H8643"\w* \w de|strong="H5869"\w* \w gozo|strong="H8057"\w*.  
\v 13 \w No|strong="H3588"\w* \w se|strong="H5971"\w* podía distinguir \w entre|strong="H3588"\w* \w el|strong="H3588"\w* \w clamor|strong="H8643"\w* \w de|strong="H3588"\w* \w júbilo|strong="H8643"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w llanto|strong="H1065"\w* del \w pueblo|strong="H5971"\w*, \w porque|strong="H3588"\w* gritaba \w a|strong="H3068"\w* \w gran|strong="H1419"\w* \w voz|strong="H6963"\w*. \w El|strong="H3588"\w* bullicio \w se|strong="H5971"\w* \w oía|strong="H8085"\w* \w desde|strong="H5704"\w* \w lejos|strong="H7350"\w*.   
\c 4  
\s1 Interrupción del trabajo  
\p
\v 1 \w Pero|strong="H3588"\w* \w cuando|strong="H3588"\w* \w los|strong="H1121"\w* \w adversarios|strong="H6862"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w Benjamín|strong="H1144"\w* \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* pueblo del exilio construía un \w Templo|strong="H1964"\w* \w para|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*,  
\v 2 \w llegaron|strong="H5066"\w* \w a|strong="H3068"\w* \w Zorobabel|strong="H2216"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w jefes|strong="H7218"\w* \w de|strong="H3588"\w* \w las|strong="H1992"\w* casas paternas \w y|strong="H3588"\w* \w les|strong="H1992"\w* dijeron: \w Edificaremos|strong="H1129"\w* \w con|strong="H5973"\w* ustedes, \w porque|strong="H3588"\w* buscamos \w a|strong="H3068"\w* \w su|strong="H1992"\w* \nd ʼElohim\nd* \w como|strong="H3588"\w* ustedes. Sacrificamos \w a|strong="H3068"\w* \w Él|strong="H5973"\w* desde \w los|strong="H1992"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* Esar-adón, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Asiria, \w que|strong="H3588"\w* nos \w hizo|strong="H5927"\w* \w subir|strong="H5927"\w* \w aquí|strong="H6311"\w*.   
\p
\v 3 \w Pero|strong="H3588"\w* \w Zorobabel|strong="H2216"\w*, \w Jesuá|strong="H3442"\w* \w y|strong="H3588"\w* \w los|strong="H3588"\w* demás \w jefes|strong="H7218"\w* \w de|strong="H3588"\w* \w casas|strong="H1004"\w* paternas \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w les|strong="H6680"\w* respondieron: \w Nada|strong="H3808"\w* tienen ustedes \w en|strong="H3588"\w* común \w con|strong="H3588"\w* nosotros \w para|strong="H3588"\w* \w que|strong="H3588"\w* edifiquen \w Casa|strong="H1004"\w* \w a|strong="H3068"\w* nuestro \nd ʼElohim\nd*. Nosotros \w solos|strong="H3162"\w* construiremos \w para|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w como|strong="H3588"\w* \w Ciro|strong="H3566"\w*, \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Persia|strong="H6539"\w*, nos \w ordenó|strong="H6680"\w*.   
\p
\v 4 Entonces el \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* la tierra desalentaba al \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w Judá|strong="H3063"\w* y \w los|strong="H1961"\w* aterrorizaba mientras construían.  
\v 5 Contrataron \w consejeros|strong="H6098"\w* \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w* \w para|strong="H5704"\w* frustrar sus propósitos \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*, \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w reinado|strong="H4428"\w* \w de|strong="H5921"\w* \w Darío|strong="H1867"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*.   
\p
\v 6 \w Al|strong="H5921"\w* principio \w del|strong="H5921"\w* \w reinado|strong="H4438"\w* \w de|strong="H5921"\w* Asuero, \w escribieron|strong="H3789"\w* una acusación \w contra|strong="H5921"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* Jerusalén.   
\p
\v 7 \w En|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* Artajerjes, \w Bislam|strong="H1312"\w*, \w Mitrídates|strong="H4990"\w*, \w Tabeel|strong="H2870"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* resto \w de|strong="H5921"\w* sus colegas \w escribieron|strong="H3789"\w* \w a|strong="H3068"\w* Artajerjes, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*. \w La|strong="H5921"\w* carta estaba \w escrita|strong="H3789"\w* \w en|strong="H5921"\w* arameo \w y|strong="H5921"\w* fue traducida \add del\add* arameo.   
\p
\v 8 El comandante \w Rehum|strong="H7348"\w* y el \w secretario|strong="H5613"\w* Simsai \w escribieron|strong="H3790"\w* \w al|strong="H5922"\w* \w rey|strong="H4430"\w* Artajerjes una carta \w contra|strong="H5922"\w* Jerusalén:   
\p
\v 9 El comandante \w Rehum|strong="H7348"\w*, el \w secretario|strong="H5613"\w* Simsai y el resto \w de|strong="H1768"\w* sus compañeros: los jueces, los magistrados, los oficiales, los funcionarios, los \w de|strong="H1768"\w* Erec, los babilonios, los \w de|strong="H1768"\w* Susa (es decir, los elamitas),  
\v 10 y \w los|strong="H1994"\w* demás pueblos \w que|strong="H1768"\w* el grande y noble Asnapar deportó y estableció en la \w ciudad|strong="H7149"\w* \w de|strong="H1768"\w* Samaria y en otras \w de|strong="H1768"\w* la región \w de|strong="H1768"\w* Más Allá del Río Éufrates.   
\p
\v 11 \w Esta|strong="H1836"\w* es la copia \w de|strong="H5922"\w* la carta \w que|strong="H1768"\w* le \w enviaron|strong="H7972"\w*: \w Al|strong="H5922"\w* \w rey|strong="H4430"\w* Artajerjes, \w de|strong="H5922"\w* tus esclavos, habitantes \w de|strong="H5922"\w* Más Allá del Río Éufrates. Ahora  
\v 12 sepa \w el|strong="H1934"\w* \w rey|strong="H4430"\w* \w que|strong="H1768"\w* los \w judíos|strong="H3062"\w* \w que|strong="H1768"\w* \w subieron|strong="H5559"\w* \w de|strong="H4481"\w* \w ti|strong="H3890"\w*, vinieron \w a|strong="H3068"\w* nosotros \w a|strong="H3068"\w* Jerusalén y están reedificando la \w ciudad|strong="H7149"\w* \w rebelde|strong="H4779"\w* y malvada. Terminan \w sus|strong="H1934"\w* muros y reparan los cimientos.  
\v 13 Sepa \w ahora|strong="H3705"\w* \w el|strong="H1934"\w* \w rey|strong="H4430"\w* \w que|strong="H1768"\w* \w si|strong="H2006"\w* \w esta|strong="H1791"\w* \w ciudad|strong="H7149"\w* es reedificada \w y|strong="H3809"\w* los muros terminados, \w no|strong="H3809"\w* pagarán \w tributo|strong="H4061"\w*, impuesto \w ni|strong="H3809"\w* peaje. Eso perjudicará \w el|strong="H1934"\w* tesoro \w de|strong="H1768"\w* los \w reyes|strong="H4430"\w*.  
\v 14 \w Ahora|strong="H3705"\w*, puesto \w que|strong="H1768"\w* dependemos del palacio, \w y|strong="H3809"\w* \w no|strong="H3809"\w* es propio \w que|strong="H1768"\w* nosotros veamos la afrenta del \w rey|strong="H4430"\w*, \w por|strong="H5922"\w* eso enviamos \w esto|strong="H1836"\w* \w e|strong="H3068"\w* informamos \w al|strong="H5922"\w* \w rey|strong="H4430"\w*  
\v 15 \w para|strong="H5922"\w* \w que|strong="H1768"\w* se indague \w en|strong="H5922"\w* el rollo \w de|strong="H4481"\w* las Memorias \w de|strong="H4481"\w* tus antepasados. Hallarás \w en|strong="H5922"\w* el rollo \w de|strong="H4481"\w* las Memorias y sabrás \w que|strong="H1768"\w* \w esta|strong="H1836"\w* \w ciudad|strong="H7149"\w* es \w rebelde|strong="H4779"\w* y perjudicial \w para|strong="H5922"\w* los \w reyes|strong="H4430"\w* y las provincias, y \w que|strong="H1768"\w* \w ellos|strong="H4481"\w* incitaron revueltas \w en|strong="H5922"\w* su interior desde tiempos muy antiguos. \w Por|strong="H4481"\w* tanto, \w esta|strong="H1836"\w* \w ciudad|strong="H7149"\w* fue destruida.  
\v 16 Informamos al \w rey|strong="H4430"\w* \w que|strong="H1768"\w* \w si|strong="H2006"\w* \w esta|strong="H1836"\w* \w ciudad|strong="H7149"\w* es reedificada \w y|strong="H3809"\w* sus muros restaurados, \w como|strong="H6903"\w* resultado \w no|strong="H3809"\w* tendrás posesión.   
\p
\v 17 Entonces el \w rey|strong="H4430"\w* \w envió|strong="H7972"\w* una \w respuesta|strong="H6600"\w* \w al|strong="H5922"\w* comandante \w Rehum|strong="H7348"\w* y \w al|strong="H5922"\w* \w secretario|strong="H5613"\w* Simsai, \w a|strong="H3068"\w* sus demás compañeros \w que|strong="H1768"\w* habitaban \w en|strong="H5922"\w* Samaria y \w a|strong="H3068"\w* los demás \w de|strong="H5922"\w* la provincia \w de|strong="H5922"\w* Más Allá del Río Éufrates: \w Paz|strong="H8001"\w*. \w Y|strong="H3068"\w* ahora,  
\v 18 la carta \w que|strong="H1768"\w* nos \w enviaron|strong="H7972"\w* fue leída con claridad ante \w mí|strong="H6925"\w*.  
\v 19 Decreté \w que|strong="H1768"\w* se buscara, y se halló \w que|strong="H1768"\w* esa \w ciudad|strong="H7149"\w* se rebela \w contra|strong="H5922"\w* los \w reyes|strong="H4430"\w* desde \w tiempo|strong="H3118"\w* \w antiguo|strong="H5957"\w*, \w que|strong="H1768"\w* \w en|strong="H5922"\w* ella se fomentó rebelión y sedición,  
\v 20 \w que|strong="H5922"\w* \w en|strong="H5922"\w* Jerusalén \w hubo|strong="H1934"\w* \w reyes|strong="H4430"\w* \w fuertes|strong="H8624"\w* \w que|strong="H5922"\w* dominaban \w toda|strong="H3606"\w* la región \w de|strong="H5922"\w* Más Allá del Río y \w que|strong="H5922"\w* se les pagaba tributos, impuestos y peaje.  
\v 21 \w Ahora|strong="H3705"\w* pues, den órdenes para \w que|strong="H5705"\w* esos \w hombres|strong="H1400"\w* cesen su trabajo \w y|strong="H3809"\w* \w que|strong="H5705"\w* esa \w ciudad|strong="H7149"\w* \w no|strong="H3809"\w* sea reedificada \w hasta|strong="H5705"\w* \w que|strong="H5705"\w* un edicto sea promulgado \w por|strong="H4481"\w* mí.  
\v 22 Guárdense \w de|strong="H5922"\w* ser negligentes \w en|strong="H5922"\w* hacer \w esto|strong="H1836"\w*, pues, ¿\w por|strong="H5922"\w* \w qué|strong="H4101"\w* debe aumentar \w el|strong="H1934"\w* daño \w en|strong="H5922"\w* perjuicio \w de|strong="H5922"\w* los \w reyes|strong="H4430"\w*?   
\p
\v 23 Tan pronto como la copia \w de|strong="H4481"\w* la carta \w del|strong="H4481"\w* \w rey|strong="H4430"\w* Artajerjes fue leída \w delante|strong="H6925"\w* \w de|strong="H4481"\w* \w Rehum|strong="H7348"\w*, \w del|strong="H4481"\w* \w secretario|strong="H5613"\w* Simsai y \w de|strong="H4481"\w* sus compañeros, se presentaron apresuradamente \w en|strong="H5922"\w* Jerusalén ante \w los|strong="H1994"\w* \w judíos|strong="H3062"\w* y \w los|strong="H1994"\w* obligaron \w a|strong="H3068"\w* cesar la obra \w por|strong="H4481"\w* medio \w del|strong="H4481"\w* poder y la fuerza.   
\p
\v 24 Cesó la obra \w de|strong="H1768"\w* la \w Casa|strong="H1005"\w* \w de|strong="H1768"\w* \nd ʼElohim\nd* \w que|strong="H1768"\w* está \w en|strong="H5705"\w* Jerusalén. Fue interrumpida \w hasta|strong="H5705"\w* \w el|strong="H1934"\w* \w año|strong="H8140"\w* \w segundo|strong="H8648"\w* del reinado \w de|strong="H1768"\w* \w Darío|strong="H1868"\w*, \w rey|strong="H4430"\w* \w de|strong="H1768"\w* Persia.   
\c 5  
\s1 Reanudación del trabajo  
\p
\v 1 Entonces los profetas Hageo y \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1247"\w* \w de|strong="H5922"\w* \w Iddo|strong="H5714"\w*, profetizaron \w a|strong="H3068"\w* los \w judíos|strong="H3062"\w* \w que|strong="H1768"\w* estaban \w en|strong="H5922"\w* \w Judá|strong="H3061"\w* y Jerusalén \w en|strong="H5922"\w* \w Nombre|strong="H8036"\w* del \nd ʼElohim\nd* \w de|strong="H5922"\w* \w Israel|strong="H3479"\w*, Quien estaba con ellos.  
\v 2 En ese tiempo se levantaron \w Zorobabel|strong="H2217"\w*, \w hijo|strong="H1247"\w* \w de|strong="H1768"\w* Salatiel, y Jesuá, \w hijo|strong="H1247"\w* \w de|strong="H1768"\w* Josadac. Comenzaron \w a|strong="H3068"\w* reedificar la \w Casa|strong="H1005"\w* \w de|strong="H1768"\w* \nd ʼElah\nd* \w que|strong="H1768"\w* estaba en Jerusalén. Los \w profetas|strong="H5029"\w* \w de|strong="H1768"\w* \nd ʼElohim\nd* los apoyaban y estaban \w con|strong="H5974"\w* ellos.   
\p
\v 3 Pero \w al|strong="H5922"\w* mismo \w tiempo|strong="H2166"\w* \w Tatnai|strong="H8674"\w*, \w gobernador|strong="H6347"\w* \w de|strong="H5922"\w* Mas Allá del Río Éufrates, Setar-boznai y sus compañeros se presentaron ante ellos y les preguntaron: ¿\w Quién|strong="H4479"\w* les \w dio|strong="H7761"\w* \w orden|strong="H2942"\w* \w para|strong="H5922"\w* construir \w este|strong="H1836"\w* Templo y terminar \w este|strong="H1836"\w* muro?  
\v 4 También les preguntaron cuáles eran los nombres \w de|strong="H1768"\w* los \w hombres|strong="H1400"\w* \w que|strong="H1768"\w* reconstruyen \w este|strong="H1836"\w* \w edificio|strong="H1147"\w*.  
\v 5 Pero la mirada \w de|strong="H5922"\w* \nd ʼElohim\nd* estaba \w sobre|strong="H5922"\w* \w los|strong="H1994"\w* ancianos \w de|strong="H5922"\w* \w los|strong="H1994"\w* \w judíos|strong="H3062"\w*, \w y|strong="H3809"\w* \w no|strong="H3809"\w* \w los|strong="H1994"\w* obligaron \w a|strong="H3068"\w* interrumpir \w el|strong="H1934"\w* trabajo \w hasta|strong="H5705"\w* \w que|strong="H5705"\w* \w el|strong="H1934"\w* asunto fuera \w al|strong="H5922"\w* \add rey\add* \w Darío|strong="H1868"\w* \w y|strong="H3809"\w* \w éste|strong="H1836"\w* diera instrucciones \w por|strong="H5922"\w* carta.   
\p
\v 6 Entonces \w Tatnai|strong="H8674"\w*, \w gobernador|strong="H6347"\w* \w de|strong="H5922"\w* Mas Allá del Río, Setar-boznai y sus compañeros, los gobernadores \w de|strong="H5922"\w* Mas Allá del Río, \w enviaron|strong="H7972"\w* \w al|strong="H5922"\w* \w rey|strong="H4430"\w* \w Darío|strong="H1868"\w*  
\v 7 una \w carta|strong="H6600"\w* \w en|strong="H5922"\w* la cual se \w escribió|strong="H3790"\w* \w esto|strong="H1836"\w*: \w Al|strong="H5922"\w* \w rey|strong="H4430"\w* \w Darío|strong="H1868"\w* sea \w toda|strong="H3606"\w* \w paz|strong="H8001"\w*.   
\p
\v 8 Sepa \w el|strong="H1934"\w* \w rey|strong="H4430"\w* \w que|strong="H1768"\w* fuimos \w a|strong="H3068"\w* la provincia \w de|strong="H1768"\w* \w Judea|strong="H3061"\w*, \w a|strong="H3068"\w* la \w Casa|strong="H1005"\w* del gran \nd ʼElohim\nd*, \w que|strong="H1768"\w* es construida con grandes piedras y madera en las paredes. \w Esta|strong="H1791"\w* obra se ejecuta diligentemente y prospera en las manos \w de|strong="H1768"\w* ellos.   
\p
\v 9 \w Y|strong="H3068"\w* \w preguntamos|strong="H7593"\w* \w a|strong="H3068"\w* aquellos ancianos: ¿\w Quién|strong="H4479"\w* les \w dio|strong="H7761"\w* \w orden|strong="H2942"\w* de edificar \w este|strong="H1836"\w* Templo y restaurar estos muros?  
\v 10 Les \w preguntamos|strong="H7593"\w* también sus nombres para informarte los nombres \w de|strong="H1768"\w* los jefes \w de|strong="H1768"\w* ellos.   
\p
\v 11 Nos \w respondieron|strong="H8421"\w*: Nosotros somos esclavos del \nd ʼElohim\nd* \w de|strong="H1768"\w* \w los|strong="H1994"\w* cielos y \w de|strong="H1768"\w* la tierra. Reedificamos la \w Casa|strong="H1005"\w* \w que|strong="H1768"\w* fue construida hace muchos \w años|strong="H8140"\w*, la cual un gran \w rey|strong="H4430"\w* \w de|strong="H1768"\w* \w Israel|strong="H3479"\w* \w edificó|strong="H1124"\w*.  
\v 12 Pero \w después|strong="H4481"\w* \w que|strong="H1768"\w* nuestros antepasados provocaron \w al|strong="H4481"\w* \nd ʼElohim\nd* \w de|strong="H4481"\w* \w los|strong="H1994"\w* cielos, Él \w los|strong="H1994"\w* \w entregó|strong="H3052"\w* \w en|strong="H4481"\w* \w mano|strong="H3028"\w* \w de|strong="H4481"\w* \w Nabucodonosor|strong="H5020"\w*, \w rey|strong="H4430"\w* \w de|strong="H4481"\w* Babilonia, el \w caldeo|strong="H3679"\w*, quien destruyó \w este|strong="H1836"\w* Templo y deportó el \w pueblo|strong="H5972"\w* \w a|strong="H3068"\w* Babilonia.   
\p
\v 13 Pero en el primer \w año|strong="H8140"\w* \w de|strong="H1768"\w* \w Ciro|strong="H3567"\w*, \w rey|strong="H4430"\w* \w de|strong="H1768"\w* Babilonia, el mismo \w rey|strong="H4430"\w* \w Ciro|strong="H3567"\w* \w dio|strong="H7761"\w* \w orden|strong="H2942"\w* para \w que|strong="H1768"\w* \w este|strong="H1836"\w* Templo \w de|strong="H1768"\w* \nd ʼElohim\nd* fuera reconstruido.  
\v 14 El \w rey|strong="H4430"\w* \w Ciro|strong="H3567"\w* \w sacó|strong="H5312"\w* \w del|strong="H4481"\w* \w templo|strong="H1965"\w* \w de|strong="H4481"\w* Babilonia \w los|strong="H1994"\w* utensilios \w de|strong="H4481"\w* \w oro|strong="H1722"\w* y \w de|strong="H4481"\w* \w plata|strong="H3702"\w* \w del|strong="H4481"\w* \w Templo|strong="H1965"\w* \w de|strong="H4481"\w* \nd ʼElohim\nd* \w que|strong="H1768"\w* \w Nabucodonosor|strong="H5020"\w* \w sacó|strong="H5312"\w* \w del|strong="H4481"\w* \w Templo|strong="H1965"\w* \w de|strong="H4481"\w* Jerusalén y \w puso|strong="H7761"\w* \w en|strong="H4481"\w* el \w templo|strong="H1965"\w* \w de|strong="H4481"\w* Babilonia.  
\p Estos \add utensilios\add* fueron entregados \w a|strong="H3068"\w* uno llamado Sesbasar, \w a|strong="H3068"\w* quien nombró \w gobernador|strong="H6347"\w*,  
\v 15 y le dijo: \w Toma|strong="H5376"\w* estos utensilios, anda y ponlos \w en|strong="H5922"\w* el \w Templo|strong="H1965"\w* \w que|strong="H1768"\w* está \w en|strong="H5922"\w* Jerusalén, y \w que|strong="H1768"\w* la \w Casa|strong="H1005"\w* \w de|strong="H5922"\w* \nd ʼElohim\nd* sea reconstruida \w en|strong="H5922"\w* su lugar.  
\v 16 El mismo Sesbasar vino \w y|strong="H3809"\w* colocó los fundamentos \w del|strong="H4481"\w* Templo \w de|strong="H4481"\w* \nd ʼElohim\nd* \w que|strong="H1768"\w* \w está|strong="H1791"\w* \w en|strong="H5705"\w* Jerusalén. Desde entonces \w hasta|strong="H5705"\w* \w ahora|strong="H3705"\w* estaba \w en|strong="H5705"\w* construcción, aunque \w no|strong="H3809"\w* \w está|strong="H1791"\w* terminada.   
\p
\v 17 \w Y|strong="H3068"\w* \w ahora|strong="H3705"\w*, \w si|strong="H2006"\w* parece \w bien|strong="H2869"\w* \w al|strong="H5922"\w* \w rey|strong="H4430"\w*, \w que|strong="H1768"\w* se indague \w en|strong="H5922"\w* la tesorería \w real|strong="H4430"\w* \w que|strong="H1768"\w* \w está|strong="H1836"\w* \w allí|strong="H8536"\w* \w en|strong="H5922"\w* Babilonia, \w para|strong="H5922"\w* verificar \w si|strong="H2006"\w* el \w rey|strong="H4430"\w* \w Ciro|strong="H3567"\w* \w dio|strong="H7761"\w* \w orden|strong="H2942"\w* \w de|strong="H4481"\w* reconstruir \w este|strong="H1836"\w* Templo \w de|strong="H4481"\w* \nd ʼElohim\nd* \w en|strong="H5922"\w* Jerusalén. \w Que|strong="H1768"\w* se nos diga la voluntad \w del|strong="H4481"\w* \w rey|strong="H4430"\w* \w sobre|strong="H5922"\w* \w esto|strong="H1836"\w*.   
\c 6  
\s1 Edicto de Darío  
\p
\v 1 Entonces el \w rey|strong="H4430"\w* \w Darío|strong="H1868"\w* \w dio|strong="H7761"\w* \w orden|strong="H2942"\w*. Indagaron en la \w casa|strong="H1005"\w* \w de|strong="H1768"\w* los archivos, \w donde|strong="H1768"\w* \w guardaban|strong="H5182"\w* los tesoros en Babilonia.  
\v 2 En Acmeta, en el palacio \w que|strong="H1768"\w* está en la provincia \w de|strong="H1768"\w* Media, fue \w hallado|strong="H7912"\w* un rollo \w donde|strong="H1768"\w* estaba escrito.  
\p \w Memoria|strong="H1799"\w*:  
\v 3 El \w año|strong="H8140"\w* \w primero|strong="H2298"\w* del \w rey|strong="H4430"\w* \w Ciro|strong="H3567"\w*, el mismo \w rey|strong="H4430"\w* \w Ciro|strong="H3567"\w* \w dio|strong="H7761"\w* un decreto acerca del Templo \w de|strong="H1768"\w* \nd ʼElohim\nd* en Jerusalén: \w Que|strong="H1768"\w* el Templo sea reedificado en el lugar \w donde|strong="H1768"\w* se ofrecen los holocaustos, y sus cimientos sean colocados firmemente. \w Que|strong="H1768"\w* su \w altura|strong="H7314"\w* y su anchura sean \w de|strong="H1768"\w* 27 metros,  
\v 4 con \w tres|strong="H8532"\w* hileras \w de|strong="H4481"\w* piedras grandes y una hilera \w de|strong="H4481"\w* madera \w nueva|strong="H2323"\w*, y sean pagados los gastos \w por|strong="H4481"\w* el tesoro \w del|strong="H4481"\w* \w rey|strong="H4430"\w*.  
\v 5 Sean restituidos \w al|strong="H4481"\w* \w Templo|strong="H1965"\w* \w de|strong="H4481"\w* \nd ʼElohim\nd* los utensilios \w de|strong="H4481"\w* \w oro|strong="H1722"\w* y \w plata|strong="H3702"\w* \w que|strong="H1768"\w* \w Nabucodonosor|strong="H5020"\w* \w sacó|strong="H5312"\w* \w del|strong="H4481"\w* \w Templo|strong="H1965"\w* \w de|strong="H4481"\w* Jerusalén y transportó \w a|strong="H3068"\w* Babilonia; \w que|strong="H1768"\w* sean devueltos y llevados otra vez \w a|strong="H3068"\w* su lugar, \w al|strong="H4481"\w* \w Templo|strong="H1965"\w* \w de|strong="H4481"\w* Jerusalén, y sean puestos \w en|strong="H4481"\w* el \w Templo|strong="H1965"\w* \w de|strong="H4481"\w* \nd ʼElohim\nd*.   
\p
\v 6 \w Por|strong="H4481"\w* tanto: \w Tatnai|strong="H8674"\w*, \w gobernador|strong="H6347"\w* \w de|strong="H4481"\w* Mas Allá \w del|strong="H4481"\w* Río, Setar-boznai y \w sus|strong="H1934"\w* compañeros, los gobernadores \w de|strong="H4481"\w* Mas Allá \w del|strong="H4481"\w* Río, apártense \w de|strong="H4481"\w* \w allí|strong="H8536"\w*.  
\v 7 Dejen \w que|strong="H5922"\w* se haga la obra \w de|strong="H5922"\w* ese Templo \w de|strong="H5922"\w* \nd ʼElohim\nd*, y \w que|strong="H5922"\w* el \w gobernador|strong="H6347"\w* y los ancianos \w de|strong="H5922"\w* los \w judíos|strong="H3062"\w* reconstruyan ese Templo \w de|strong="H5922"\w* \nd ʼElohim\nd* \w en|strong="H5922"\w* su lugar.   
\p
\v 8 \w Por|strong="H4481"\w* mí es dada la \w orden|strong="H2942"\w* \w de|strong="H4481"\w* lo \w que|strong="H1768"\w* deben hacer \w con|strong="H5974"\w* esos ancianos \w de|strong="H4481"\w* los \w judíos|strong="H3062"\w* para la construcción \w de|strong="H4481"\w* ese Templo \w de|strong="H4481"\w* \nd ʼElohim\nd*: \w Que|strong="H1768"\w* \w del|strong="H4481"\w* tesoro \w real|strong="H4430"\w*, proveniente \w de|strong="H4481"\w* los tributos \w de|strong="H4481"\w* Mas Allá \w del|strong="H4481"\w* Río, sean pagados los gastos \w a|strong="H3068"\w* esos \w hombres|strong="H1400"\w* puntualmente \w y|strong="H3809"\w* \w sin|strong="H3809"\w* interrupción.  
\v 9 \w Y|strong="H3068"\w* lo \w que|strong="H1768"\w* \w sea|strong="H1934"\w* necesario, tanto \w becerros|strong="H1123"\w* como \w carneros|strong="H1798"\w* \w y|strong="H3809"\w* corderos para holocaustos al \nd ʼElohim\nd* del \w cielo|strong="H8065"\w*, como \w trigo|strong="H2591"\w*, \w sal|strong="H4416"\w*, \w vino|strong="H2562"\w* \w y|strong="H3809"\w* aceite, según lo \w que|strong="H1768"\w* digan los sacerdotes \w que|strong="H1768"\w* están en Jerusalén, les \w sea|strong="H1934"\w* dado cada \w día|strong="H3118"\w* \w sin|strong="H3809"\w* falta,  
\v 10 para \w que|strong="H1768"\w* puedan ofrecer sacrificios \w de|strong="H1768"\w* olor agradable al \nd ʼElohim\nd* del \w cielo|strong="H8065"\w* y oren \w por|strong="H1768"\w* la vida del \w rey|strong="H4430"\w* y \w de|strong="H1768"\w* \w sus|strong="H1934"\w* \w hijos|strong="H1123"\w*.   
\p
\v 11 También \w decreto|strong="H6600"\w* \w que|strong="H1768"\w* \w a|strong="H3068"\w* \w cualquiera|strong="H3606"\w* \w que|strong="H1768"\w* infrinja \w este|strong="H1836"\w* edicto, \w que|strong="H1768"\w* se le arranque un madero \w de|strong="H4481"\w* su \w casa|strong="H1005"\w*, se clave y sea colgado \w en|strong="H5922"\w* él, y su \w casa|strong="H1005"\w* sea convertida \w en|strong="H5922"\w* un montón \w de|strong="H4481"\w* escombros.  
\v 12 El \nd ʼElah\nd* \w que|strong="H1768"\w* determinó \w que|strong="H1768"\w* su \w Nombre|strong="H8036"\w* more \w allí|strong="H8536"\w*, \w destruya|strong="H4049"\w* \w a|strong="H3068"\w* cualquier \w rey|strong="H4430"\w* \w o|strong="H3068"\w* \w pueblo|strong="H5972"\w* \w que|strong="H1768"\w* intente modificarlo para destruir ese Templo del \nd ʼElohim\nd* \w que|strong="H1768"\w* \w está|strong="H1791"\w* en Jerusalén. Yo, \w Darío|strong="H1868"\w*, promulgo el edicto. Sea ejecutado con \w toda|strong="H3606"\w* diligencia.   
\s1 Dedicación del Templo  
\p
\v 13 Entonces \w Tatnai|strong="H8674"\w*, \w gobernador|strong="H6347"\w* \w de|strong="H1768"\w* Mas Allá del Río, Setar-boznai y sus compañeros, cumplieron puntualmente según el \w rey|strong="H4430"\w* \w Darío|strong="H1868"\w* ordenó.  
\v 14 Los ancianos \w de|strong="H4481"\w* los \w judíos|strong="H3062"\w* construyeron y prosperaron, \w en|strong="H4481"\w* conformidad con la profecía \w de|strong="H4481"\w* los \w profetas|strong="H5029"\w* Hageo y \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1247"\w* \w de|strong="H4481"\w* \w Iddo|strong="H5714"\w*. Terminaron la edificación según el mandato \w del|strong="H4481"\w* \nd ʼElohim\nd* \w de|strong="H4481"\w* \w Israel|strong="H3479"\w*, \w al|strong="H4481"\w* edicto \w de|strong="H4481"\w* \w Ciro|strong="H3567"\w*, \w al|strong="H4481"\w* \w de|strong="H4481"\w* \w Darío|strong="H1868"\w* y \w al|strong="H4481"\w* \w de|strong="H4481"\w* Artajerjes, \w rey|strong="H4430"\w* \w de|strong="H4481"\w* Persia.  
\v 15 \w El|strong="H1932"\w* Templo fue terminado \w el|strong="H1932"\w* tercer \w día|strong="H3118"\w* del mes \w de|strong="H1768"\w* Adar del \w año|strong="H8140"\w* sexto del reinado del \w rey|strong="H4430"\w* \w Darío|strong="H1868"\w*.   
\p
\v 16 Los \w hijos|strong="H1123"\w* de \w Israel|strong="H3479"\w*, los sacerdotes, los levitas y el resto de los \w hijos|strong="H1123"\w* del cautiverio dedicaron ese Templo de \nd ʼElohim\nd* con regocijo.  
\v 17 \w En|strong="H5922"\w* la dedicación \w de|strong="H5922"\w* ese Templo \w de|strong="H5922"\w* \nd ʼElohim\nd* ofrecieron 100 \w becerros|strong="H8450"\w*, 200 \w carneros|strong="H1798"\w* y 400 corderos, y 12 machos cabríos como sacrificios \w que|strong="H5922"\w* apaciguan \w por|strong="H5922"\w* \w todo|strong="H3606"\w* \w Israel|strong="H3479"\w*, según el número \w de|strong="H5922"\w* las tribus \w de|strong="H5922"\w* \w Israel|strong="H3479"\w*.  
\v 18 Establecieron \w a|strong="H3068"\w* los sacerdotes según sus clases y \w a|strong="H3068"\w* los levitas según sus órdenes \w para|strong="H5922"\w* el servicio \w de|strong="H5922"\w* \nd ʼElohim\nd* \w en|strong="H5922"\w* Jerusalén, según lo escrito \w en|strong="H5922"\w* el rollo \w de|strong="H5922"\w* Moisés.   
\s1 La Pascua  
\p
\v 19 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* la cautividad celebraron la \w Pascua|strong="H6453"\w* \w el|strong="H1121"\w* 14 del \w mes|strong="H2320"\w* \w primero|strong="H7223"\w*,  
\v 20 \w pues|strong="H3588"\w* \w los|strong="H1992"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H3588"\w* \w los|strong="H1992"\w* \w levitas|strong="H3881"\w* \w se|strong="H1992"\w* purificaron \w como|strong="H3588"\w* un solo \w hombre|strong="H1121"\w*. \w Todos|strong="H3605"\w* \w ellos|strong="H1992"\w* estaban purificados. Luego sacrificaron \w el|strong="H3588"\w* cordero pascual \w por|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* del \w cautiverio|strong="H1473"\w*, \w por|strong="H3588"\w* \w sus|strong="H1992"\w* hermanos \w sacerdotes|strong="H3548"\w* \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w ellos|strong="H1992"\w* \w mismos|strong="H1992"\w*.  
\v 21 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1121"\w* regresaron del \w cautiverio|strong="H1473"\w* comieron, y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H1121"\w* se adhirieron \w a|strong="H3068"\w* \w ellos|strong="H3605"\w* se apartaron \w de|strong="H1121"\w* \w la|strong="H3605"\w* impureza \w de|strong="H1121"\w* las \w naciones|strong="H1471"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* tierra para buscar \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H3605"\w* \nd ʼElohim\nd* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.   
\p
\v 22 Celebraron \w con|strong="H5921"\w* regocijo \w la|strong="H5921"\w* \w fiesta|strong="H2282"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* Panes sin Levadura durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w*, \w porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w los|strong="H5921"\w* alegró \w y|strong="H3588"\w* \w dispuso|strong="H6213"\w* \w en|strong="H5921"\w* \w su|strong="H3588"\w* favor \w el|strong="H5921"\w* \w corazón|strong="H3820"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Persia\f + \fr 6:22 \ft Lit. \+nd Asiria.\+nd*\f* \w para|strong="H5921"\w* fortalecer sus \w manos|strong="H3027"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w del|strong="H5921"\w* \w Templo|strong="H1004"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd*, \w el|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\c 7  
\s1 Misión de Esdras  
\p
\v 1 Después \w de|strong="H1121"\w* estas \w cosas|strong="H1697"\w*, en \w el|strong="H1121"\w* \w reinado|strong="H4428"\w* \w de|strong="H1121"\w* Artajerjes, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Persia|strong="H6539"\w*, \w Esdras|strong="H5830"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Seraías|strong="H8304"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hilcías|strong="H2518"\w*,  
\v 2 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Salum, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Sadoc|strong="H6659"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahitob,  
\v 3 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amarías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Meraiot,  
\v 4 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Zeraías|strong="H2228"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Uzi, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Buqui,  
\v 5 \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Abisúa, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Finees, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Eleazar, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Aarón, \w el|strong="H1121"\w* \w primer|strong="H7218"\w* \w sacerdote|strong="H3548"\w*:  
\v 6 \w Esdras|strong="H5830"\w* \w subió|strong="H5927"\w* \w de|strong="H5921"\w* Babilonia, \w donde|strong="H5921"\w* \w era|strong="H1931"\w* \w escriba|strong="H5608"\w* diestro \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w Ley|strong="H8451"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w dada|strong="H5414"\w* \w por|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\p \w El|strong="H1931"\w* \w rey|strong="H4428"\w* \w le|strong="H1931"\w* concedió \w toda|strong="H3605"\w* \w su|strong="H1931"\w* petición, \w porque|strong="H5921"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w su|strong="H1931"\w* \nd ʼElohim\nd* estaba \w sobre|strong="H5921"\w* \w él|strong="H1931"\w*.   
\p
\v 7 \w El|strong="H1121"\w* \w año|strong="H8141"\w* \w séptimo|strong="H7651"\w* \w del|strong="H4480"\w* \w rey|strong="H4428"\w* Artajerjes también \w subieron|strong="H5927"\w* \w a|strong="H3068"\w* Jerusalén algunos \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* y \w levitas|strong="H3881"\w*, \w los|strong="H1121"\w* \w cantores|strong="H7891"\w* y \w porteros|strong="H7778"\w* y \w los|strong="H1121"\w* sirvientes.   
\p
\v 8 \w El|strong="H1931"\w* \w mes|strong="H2320"\w* \w quinto|strong="H2549"\w* del \w año|strong="H8141"\w* \w séptimo|strong="H7637"\w* del \w rey|strong="H4428"\w*, \add Esdras\add* llegó \w a|strong="H3068"\w* Jerusalén.  
\v 9 \w Pues|strong="H3588"\w* \w el|strong="H1931"\w* \w primero|strong="H7223"\w* \w del|strong="H5921"\w* \w mes|strong="H2320"\w* \w primero|strong="H7223"\w* \w fue|strong="H1931"\w* \w el|strong="H1931"\w* inicio \w del|strong="H5921"\w* regreso \w de|strong="H5921"\w* Babilonia, \w y|strong="H3588"\w* \w el|strong="H1931"\w* \w primero|strong="H7223"\w* \w del|strong="H5921"\w* \w mes|strong="H2320"\w* \w quinto|strong="H2549"\w* llegó \w a|strong="H3068"\w* Jerusalén, \w según|strong="H5921"\w* \w la|strong="H1931"\w* bondadosa \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* \nd ʼElohim\nd* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w*.  
\v 10 \w Porque|strong="H3588"\w* \w Esdras|strong="H5830"\w* determinó \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w corazón|strong="H3824"\w* escudriñar \w la|strong="H3588"\w* \w Ley|strong="H8451"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, practicarla \w y|strong="H3588"\w* enseñar sus \w Estatutos|strong="H2706"\w* \w y|strong="H3588"\w* Preceptos \w en|strong="H3588"\w* \w Israel|strong="H3478"\w*.   
\s1 Decreto de Artajerjes  
\p
\v 11 \w Esta|strong="H2088"\w* \w es|strong="H2088"\w* \w la|strong="H5921"\w* copia \w de|strong="H5921"\w* \w la|strong="H5921"\w* carta \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* Artajerjes \w dio|strong="H5414"\w* \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w Esdras|strong="H5830"\w*, \w escriba|strong="H5608"\w* dedicado \w a|strong="H3068"\w* escribir \w los|strong="H5921"\w* \w Mandamientos|strong="H4687"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H5921"\w* sus \w Estatutos|strong="H2706"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*:   
\p
\v 12 Artajerjes, \w rey|strong="H4430"\w* \w de|strong="H1768"\w* \w reyes|strong="H4430"\w*, al \w sacerdote|strong="H3549"\w* \w Esdras|strong="H5831"\w*, \w escriba|strong="H5613"\w* erudito \w de|strong="H1768"\w* la Ley del \nd ʼElohim\nd* del \w cielo|strong="H8065"\w*. \add Paz\add* perfecta.  
\p \w Y|strong="H3068"\w* ahora:  
\v 13 \w Por|strong="H4481"\w* mí es dado decreto para \w que|strong="H1768"\w* \w todo|strong="H3606"\w* aquel \w del|strong="H4481"\w* \w pueblo|strong="H5972"\w* \w de|strong="H4481"\w* \w Israel|strong="H3479"\w*, sus sacerdotes y levitas \w que|strong="H1768"\w* quiera \w ir|strong="H1946"\w* \w contigo|strong="H5972"\w* \w a|strong="H3068"\w* Jerusalén, \w vaya|strong="H1946"\w*.  
\v 14 \w Porque|strong="H1768"\w* tú eres enviado \w de|strong="H4481"\w* \w parte|strong="H6925"\w* \w del|strong="H4481"\w* \w rey|strong="H4430"\w* y \w de|strong="H4481"\w* sus siete consejeros \w a|strong="H3068"\w* inspeccionar \w Judea|strong="H3061"\w* y Jerusalén, según la Ley \w de|strong="H4481"\w* tu \nd ʼElohim\nd* \w que|strong="H1768"\w* está \w en|strong="H5922"\w* tu \w mano|strong="H3028"\w*,  
\v 15 y \w a|strong="H3068"\w* llevar la \w plata|strong="H3702"\w* y el \w oro|strong="H1722"\w* \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* y sus consejeros ofrecieron voluntariamente al \nd ʼElohim\nd* \w de|strong="H1768"\w* \w Israel|strong="H3479"\w*, \w cuya|strong="H1768"\w* \w morada|strong="H4907"\w* está en Jerusalén,  
\v 16 junto \w con|strong="H5974"\w* \w toda|strong="H3606"\w* la \w plata|strong="H3702"\w* y el \w oro|strong="H1722"\w* \w que|strong="H1768"\w* halles en \w toda|strong="H3606"\w* la provincia \w de|strong="H1768"\w* Babilonia, \w con|strong="H5974"\w* las ofrendas voluntarias del \w pueblo|strong="H5972"\w* y \w de|strong="H1768"\w* los sacerdotes para el Templo \w de|strong="H1768"\w* su \nd ʼElohim\nd* \w que|strong="H1768"\w* está en Jerusalén.   
\p
\v 17 \w Por|strong="H5922"\w* tanto, con \w este|strong="H1836"\w* dinero \w comprarás|strong="H7066"\w* con \w toda|strong="H3606"\w* diligencia \w becerros|strong="H8450"\w*, \w carneros|strong="H1798"\w*, corderos, sus ofrendas vegetales y sus libaciones. \w Los|strong="H1994"\w* ofrecerás \w en|strong="H5922"\w* el altar del Templo \w de|strong="H5922"\w* tu \nd ʼElohim\nd* \w que|strong="H1768"\w* \w está|strong="H1836"\w* \w en|strong="H5922"\w* Jerusalén.  
\v 18 \w Con|strong="H5921"\w* \w el|strong="H5921"\w* resto \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w plata|strong="H3702"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w oro|strong="H1722"\w*, haz \w lo|strong="H5921"\w* \w que|strong="H1768"\w* parezca bien \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* tus hermanos. Pueden hacerlo \w según|strong="H5921"\w* \w la|strong="H5921"\w* voluntad \w de|strong="H5921"\w* su \nd ʼElohim\nd*.   
\p
\v 19 Restituirás al \nd ʼElohim\nd* \w de|strong="H1768"\w* Jerusalén los utensilios sagrados \w que|strong="H1768"\w* te son entregados para el servicio del Templo \w de|strong="H1768"\w* tu \nd ʼElohim\nd*.  
\v 20 Pagarás \w del|strong="H4481"\w* tesoro \w del|strong="H4481"\w* \w rey|strong="H4430"\w* el resto \w de|strong="H4481"\w* las cosas necesarias para el Templo \w de|strong="H4481"\w* tu \nd ʼElohim\nd*.   
\p
\v 21 \w Y|strong="H3068"\w* \w por|strong="H4481"\w* mí, el \w rey|strong="H4430"\w* Artajerjes, es dada \w orden|strong="H2942"\w* \w a|strong="H3068"\w* \w todos|strong="H3606"\w* los tesoreros \w de|strong="H4481"\w* Mas Allá \w del|strong="H4481"\w* Río, para \w que|strong="H1768"\w* \w todo|strong="H3606"\w* lo \w que|strong="H1768"\w* les pida el \w sacerdote|strong="H3549"\w* \w Esdras|strong="H5831"\w*, erudito \w de|strong="H4481"\w* la Ley \w del|strong="H4481"\w* \nd ʼElohim\nd* \w del|strong="H4481"\w* \w cielo|strong="H8065"\w*, sea dado con \w toda|strong="H3606"\w* diligencia:  
\v 22 \w hasta|strong="H5705"\w* 3.300 kilogramos \w de|strong="H1768"\w* \w plata|strong="H3702"\w*, 3.3 toneladas \w de|strong="H1768"\w* \w trigo|strong="H2591"\w*, 2.200 litros \w de|strong="H1768"\w* \w vino|strong="H2562"\w*, 2.200 litros \w de|strong="H1768"\w* aceite \w y|strong="H3809"\w* \w sal|strong="H4416"\w* \w sin|strong="H3809"\w* medida.   
\p
\v 23 \w Todo|strong="H3606"\w* lo \w que|strong="H1768"\w* \w sea|strong="H1934"\w* ordenado \w por|strong="H4481"\w* \w el|strong="H1934"\w* \nd ʼElohim\nd* \w del|strong="H4481"\w* \w cielo|strong="H8065"\w* \w sea|strong="H1934"\w* hecho diligentemente \w para|strong="H5922"\w* \w el|strong="H1934"\w* Templo \w del|strong="H4481"\w* \nd ʼElohim\nd* \w del|strong="H4481"\w* \w cielo|strong="H8065"\w*, \w pues|strong="H1768"\w* ¿\w por|strong="H4481"\w* \w qué|strong="H1768"\w* se encenderá \w su|strong="H1934"\w* ira \w contra|strong="H5922"\w* \w el|strong="H1934"\w* \w reino|strong="H4437"\w* \w del|strong="H4481"\w* \w rey|strong="H4430"\w* y \w de|strong="H4481"\w* \w sus|strong="H1934"\w* \w hijos|strong="H1123"\w*?  
\v 24 \w A|strong="H3068"\w* ustedes les informamos \w que|strong="H1768"\w* \w no|strong="H3809"\w* les es lícito imponer \w tributo|strong="H4061"\w*, contribución \w o|strong="H3068"\w* peaje \w a|strong="H3068"\w* alguno \w de|strong="H5922"\w* los sacerdotes, levitas, \w cantores|strong="H2171"\w*, \w porteros|strong="H8652"\w* \w o|strong="H3068"\w* servidores \w de|strong="H5922"\w* Templo \w de|strong="H5922"\w* \nd ʼElohim\nd*.   
\p
\v 25 \w Y|strong="H3068"\w* tú, \w Esdras|strong="H5831"\w*, según la \w sabiduría|strong="H2452"\w* \w que|strong="H1768"\w* te da tu \nd ʼElohim\nd*, establece magistrados \w y|strong="H3809"\w* \w jueces|strong="H8200"\w* \w que|strong="H1768"\w* juzguen \w a|strong="H3068"\w* \w todo|strong="H3606"\w* \w el|strong="H1934"\w* \w pueblo|strong="H5972"\w* \w de|strong="H1768"\w* Más Allá del Río, \w a|strong="H3068"\w* \w todos|strong="H3606"\w* los \w que|strong="H1768"\w* conocen la Leyes \w de|strong="H1768"\w* tu \nd ʼElohim\nd*. Puedes enseñarlas \w a|strong="H3068"\w* \w cualquiera|strong="H3606"\w* \w que|strong="H1768"\w* las ignore.   
\p
\v 26 \w A|strong="H3068"\w* \w todo|strong="H3606"\w* \w el|strong="H1934"\w* \w que|strong="H1768"\w* \w no|strong="H3809"\w* cumpla la Ley \w de|strong="H4481"\w* tu \nd ʼElah\nd* \w y|strong="H3809"\w* la ley \w del|strong="H4481"\w* \w rey|strong="H4430"\w*, \w que|strong="H1768"\w* le \w sea|strong="H1934"\w* ejecutado estrictamente un \w juicio|strong="H1780"\w*, \w ya|strong="H1768"\w* \w sea|strong="H1934"\w* para muerte, destierro, confiscación \w de|strong="H4481"\w* bienes \w o|strong="H3068"\w* prisión.   
\p
\v 27 ¡\w Bendito|strong="H1288"\w* sea \nd \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* \w de|strong="H5414"\w* nuestros antepasados, que \w puso|strong="H5414"\w* tales cosas en el \w corazón|strong="H3820"\w* del \w rey|strong="H4428"\w* \w para|strong="H5414"\w* honrar el \w Templo|strong="H1004"\w* \w de|strong="H5414"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* que \w está|strong="H2063"\w* en Jerusalén,  
\v 28 \w y|strong="H5921"\w* \w extendió|strong="H5186"\w* \w hacia|strong="H5921"\w* \w mí|strong="H5921"\w* su \w misericordia|strong="H2617"\w* \w ante|strong="H6440"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w*, sus \w consejeros|strong="H3289"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w poderosos|strong="H1368"\w* gobernadores \w del|strong="H5921"\w* \w rey|strong="H4428"\w*!  
\p \w Así|strong="H2388"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w mi|strong="H5921"\w* \nd ʼElohim\nd* \w me|strong="H5921"\w* fortaleció \w para|strong="H5921"\w* \w que|strong="H5921"\w* reuniera \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* \w que|strong="H5921"\w* subieran \w conmigo|strong="H5973"\w*.   
\c 8  
\s1 Compañeros de Esdras  
\p
\v 1 Éstos son \w los|strong="H5973"\w* \w jefes|strong="H7218"\w* \w de|strong="H5973"\w* las casas paternas y la genealogía \w de|strong="H5973"\w* \w los|strong="H5973"\w* que \w subieron|strong="H5927"\w* \w conmigo|strong="H5973"\w* desde Babilonia \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w reinado|strong="H4428"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w* Artajerjes:   
\p
\v 2 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Finees, Gersón; \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Itamar, \w Daniel|strong="H1840"\w*; \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, Hatús;  
\v 3 \w de|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* Secanías, \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* Paros, \w Zacarías|strong="H2148"\w*, y \w con|strong="H5973"\w* \w él|strong="H5973"\w* fueron reconocidos por genealogía 150 \w varones|strong="H2145"\w*.  
\v 4 \w De|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* Pajat-moab, Elioenai, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Zeraías|strong="H2228"\w*, y \w con|strong="H5973"\w* \w él|strong="H5973"\w* 200 \w varones|strong="H2145"\w*;  
\v 5 \w de|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* Zatu, Secanías, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Jahaziel|strong="H3166"\w*, y \w con|strong="H5973"\w* \w él|strong="H5973"\w* 300 \w varones|strong="H2145"\w*;  
\v 6 \w de|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w Adín|strong="H5720"\w*, \w Ebed|strong="H5651"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Jonatán, y \w con|strong="H5973"\w* \w él|strong="H5973"\w* 50 \w varones|strong="H2145"\w*;  
