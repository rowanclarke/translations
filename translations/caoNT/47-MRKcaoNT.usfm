\id MRK - Chácobo NT -Bolivia 2010 (DBL -2013)
\h San Marcos
\toc1 EL Santo Evangelio Según San Marcos
\toc2 Marcos
\toc3 Mr
\mt2 EL Santo Evangelio Según
\mt1 San Marcos
\c 1
\s1 Xaba xo tsi ashimati ibo Juán Dios Chani yoanina
\r Mateo 3.1-12; Lucas 3.1-9, 15-17; Juan 1.19-28
\p 
\v 1 Jesucristo Chani jia ca tsi xo naa, naa Diós raani ca Baquë yoati na.
\v 2 Jariapari tsi quiha jahuë Baquë yoati tsi Dios chaniniquë; naa Isaías yamabá quënëni cató no.
\q1 “‘Mia bëbo noho Chani bëhai ca raapariquia,
\q2 mi quinia rohahuati’ i jahuë Baquë qui Dios ni quiha.
\q1 
\v 3 Jasca xabachá racaxëhi quiha mia bëbo cahai cato.
\q2 Toa xo tsi quënaxëhi quiha.
\q1 Quënahax, ‘Mamë rohahuacana,
\q2 Ibo johai quëshpi na’ ixëhi quiha nohiria bo qui.
\q1 ‘Mato jabi mëstëhuacana, naa bahi mëstëhuahai jascaria’ ixëhi quiha”
\m nëa tsi Dios nëcani quiha Isaías yamabá quënëni cató no.
\p 
\v 4 Jabi naa Chani bëhai ca ashimati ibo Juan ini quiha. Xabachá tsi quiha ja jisiquiniquë, Dios Chani yoahi na. Jatsi,
\p —Mato jocha quima Dios quiri bësocana. Bësoxo ma ashimahacati xo. Jatsi masahacaxëhi quiha mato jocha ra —i nohiria bo qui Juan niquë.
\v 5 Jatsi quiha jodioba maí cabo, Jerusalén cabo, tihi ca nohiria bocaniquë, Juan chani nicacascani na. Nicaxo tsi quiha jato jocha ja bërohuacaniquë. Jatsi quiha Juan yamabá jato ashimaniquë ani Jordán xo na.
\p 
\v 6 Jabi camello rani tsi Juan sahuëti acacani quiha. Bichi cinturón ja chinëxëni quiha. Chapo bo, nihí ca bata, tihi cabo ja pini quiha.
\v 7 Jabi Juán yoani ca chani tsi xo naa:
\p —E cho joxëhi quiha ëa oquëria cato. Jahuë yonati iti mëtsama xo ëa ra, ëa oquëria ca ja nori iqui na.
\v 8 Jënë́ tsi mato ashimaquia; jama, Espíritu Santó tsi mato ashimaxëhi quiha naa johai cato —i Juan niquë.
\s1 Jesu ashimahacanina — Jochati ja tanamahacanina
\r Mateo 3.13; 4.11; Lucas 3.21-22; 4.1-13
\p 
\v 9 Jaquirëquë toatiyá tsi Nazaret, naa Galileá ca yaca ax Jesu joniquë. Ja joquë tsi quiha ani Jordán xo tsi Juán Jesu ashimaniquë.
\v 10 Jatsi quiha jënë ax tsëquëpama tsi nai japëquëhai Jesú jisniquë. Jatsi ja qui Espíritu Santo botëniquë; boto botëhai jisiria iquiina.
\v 11 Jatsi quiha naipá ca joi chaniniquë:
\p —Noho Baquë yoi xo mia. Mi qui raniquia —iquiina.
\p 
\v 12 Jaquirëquë xaba qui Espíritu Santó Jesu raatapiniquë.
\v 13 Cuarenta bari no tsi ja ini quiha xabachá no. Toá ja no tsi quiha Satanás tanamaniquë jochamaxëna. Jasca, toá tsi yohina bo ini quiha jato ri; jama, ángel bo bëcaniquë Jesu mëbixëna.
\s1 Cuatro ca joni bo Jesú quënanina
\r Mateo 4.12-22; Lucas 4.14-15; 5.1-11
\p 
\v 14 Jabi preso qui Juan nanëhacaquë tsi quiha Galilea mai qui Jesu caniquë. Caxo tsi quiha Dios Chani jia ca ja yoaniquë.
\v 15 Yoahax,
\p —Tsëquëquë xaba-xabatiya ra. Basima tsi xo Diós otohaina ra. Mato jocha quima casocana. Casoxo Dios Chani jia ca chahahuacana —i ja niquë.
\p 
\v 16 Ia Galilea quënipama tsi quiha rabë ca joni Jesú jisniquë, naa Simón, jahuë noma Andrés. Sani bicanaibo ja icani quiha. Jabi jato nishi bo niahi ja icani quiha Jesu cahëquë no. Jatsi,
\p 
\v 17 —E bëta bëcana. Joni bo biti mato tiisimaxëquia —i jato qui Jesu niquë. \fig Pedro, Andrés, tihi cabo Jesú quënahaina|src="cn01681b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="MRK 1.17"\fig*
\p 
\v 18 Jatsi quiha jato nishi bo ja janatapicaniquë Jesu banahuaxëna.
\p 
\v 19 Ori pistia caxo tsi quiha rabë ca joni huëtsa bo ja jisniquë, naa Zebedeo baquë Jacobo, Jacobo noma Juan. Jato notí tsaho ja icani quiha, jato nishi bo shomahuacanaina.
\v 20 Jato tsayapama tsi Jesú jato quënaniquë. Jatsi quiha jato jahëpa Zebedeo, jahuë yonati bo, tihi cabo ja jisbëriatapicaniquë. Jisbëria tsi quiha Jesu ja banahuacaniquë.
\s1 Yoshi jaya ca joni
\r Lucas 4.31-37
\p 
\v 21 Jatsi Capernaum yaca qui ja cahëcaniquë, naa Jesu, jahuë rabëti bo ya. Jodioba joiti barí tsi quiha jato catiti xobo qui Jesu jiconiquë. Jicoxo tsi quiha tiisimatsijahuaniquë.
\v 22 Jabi ja tiisimani ca quinia qui nohiria bo ratëniquë. Jato yoba tiisimati maestro bo quirima ja ini quiha, chama ya jato ja tiisimani nori quëshpi na.
\p 
\v 23 Jatsi quiha yoshi jayanish ca joni jiconiquë catiti xobo qui. Pistiama ca joí tsi ja quënaniquë:
\p 
\v 24 —Noqui yosiyamahuë, Nazarét ca Jesú. Tonia noqui quëyohi mi joquë pë. Mia cahëquia. Mia ri tsi xo toa Dios Baquë jiaxëni cato ra —i ja qui yoshi niquë.
\p 
\v 25 Jatsi Jesú yoshi raahaniquë:
\p —Pasihuë. Joni quima ax natsëquëhuë —iquiina.
\p 
\v 26 Jatsi pë yoshiní joni rasëbimaniquë. Rasëbimahax ja sai-sainiquë, natsëquëhi na.
\v 27 Jatsi quiha ratëyoniquë nohiria tsayahax na. Chaninatsijacaniquë:
\p —¿Jëniria ni sa? ¿Tiisimahai ca paxa ni naa sa? Jisí. Chama jaya xo naa joni ra. Jisí. Jahuë chani qui nicahi quiha yoshi bo ri pa —iquiina.
\p 
\v 28 Jatsi Galilea maí tsi chani pacananiquë Jesú ani yoati na.
\s1 Huëstima ca nohiria Jesú jënimahuanina
\r Mateo 8.14-15; Lucas 4.38-39
\p 
\v 29 Jaquirëquë catiti xobo jisbaya tsi quiha Simón, Andrés, tihi caba xobo qui ja bocaniquë. Bocaniquë Jacobo, Juan, jato ri.
\v 30 Jabi raca Simón raisi ini quiha. Ja iquini quiha. Xobo qui Jesu cahëquë tsi,
\p —Iquihi quiha —i Jesu qui jaca niquë.
\p 
\v 31 Jatsi jisi Jesu caniquë. Caxo tsi quiha jahuë mëquë ja biniquë joimaxëna. Jatsi janacatapiniquë jahuë iquini ra. Joixo oriquiti taatsijahuaniquë pa.
\s1 Huëstima ca anomaria cabo Jesú jënimahuanina
\r Mateo 8.16-17; Lucas 4.40-41
\p 
\v 32 Bari chixabano tsi quiha iquicanaibo, anomaria cabo, yoshi jaya cabo, tihi cabo nohiria bá bëniquë Jesu qui.
\v 33 Jasca, xobo bësojó tsi yacatá ca nohiria tëquë quëtsoniquë.
\v 34 Jatsi huëstima ca anomaria cabo ja jënimahuaniquë. Yoshi bo ja natsëcaniquë. Natsëcapama tsi yoshi bo ja pasimaniquë, ja chaniyamacano iquish na. Dios Baquë ja iqui ca ja cahëcani quiha.
\s1 Galilea mai xo tsi Dios Chani Jesú yoanina
\r Lucas 4.42-44
\p 
\v 35 Huëaquë, jari mitsëmono tsi Jesu joiniquë. Xobo jisbaya tsi quiha nohiria yama ca iti qui ja caniquë jamë no. Toá tsi ja bëhoxni quiha.
\v 36 Jatsi Jesu yopaxo tsi Simón, jahuë rabëti bo, tihi cabá mërahi bocaniquë.
\v 37 Jisi tsi,
\p —Mia mëracani quiha nohiria tëquë ra —i ja qui jaca niquë.
\p 
\v 38 Jama,
\p —Nëá ca yaca huëtsa bo qui no cati xo. Jato qui Dios Chani ë yoaxëti xo ra. Ja tsi xo toa ë raahacaniquë —i jato qui Jesu niquë.
\p 
\v 39 Jatsi Galilea mai tëquë xo tsi Dios Chani ja yoabonaniquë, jato catiti xobo xo na. Yoshi bo ja natsëcaniquë jaa ri.
\s1 Leproso ca joni Jesú jënimahuanina
\r Mateo 8.1-4; Lucas 5.12-16
\p 
\v 40 Jatsi lepra jaya ca joni Jesu qui joniquë jënimahuahacaxëna. Bonohuaxëni ca joni ja ini quiha. Mënihax,
\p —Mi aapicatsai tsi ëa jënimahuati mëtsa xo mia ra —i Jesu qui ja niquë.
\p 
\v 41 Jatsi quiha Jesu cohuënaniquë tsayahax na. Noitiria ca joni ja ini quiha. Jatsi Jesú joni motsaniquë. Motsahax,
\p —Acasquia ra. Bahuëhacahuë —i ja qui Jesu niquë.
\p 
\v 42 Jatsi tapotapiniquë jahuë bono bo. Jënima ja ini quiha.
\p 
\v 43 Jatsi jahuë xobo qui raanox pari tsi Jesú yobaniquë:
\p 
\v 44 —Quiniahuë. E aca ca yoayamahuë. Jama, jaboqui arati ibo qui caaparita, mia ja tsayano iquish na. Jatsi Moisés yobani ca ja qui ahuë tëpas-hacati, nohiria bo qui mi jënimahuahacaha jismaxëna —i ja qui Jesu niquë.
\p 
\v 45 Jama, caquí tsi quiha Jesú ja bax aca ca ja yoabonaniquë pë. Jatsi quiha chani pacanatapiniquë Jesu yoati na. Jaha tsi pë bëro tsi yaca qui jiconoma Jesu ini quiha, naa tihiria ca quëtsohai ca nohiria iqui na. Jaha tsi quiha yaca basi, naa xobo yama cató tsi quiha ja chitëniquë.
\c 2
\s1 Mohitimaxëni ca joni Jesú jënimahuanina
\r Mateo 9.1-8; Lucas 5.17-26
\p 
\v 1 Ichariama ca bari tsi quiha Jesu chitëniquë xobo yama cató no. Jaquirëquë Capernaum qui jahari ja joniquë jahuë xobo qui. Jatsi quiha jahari ja johai ca nohiria bá nicaniquë.
\v 2 Jaha tsi quiha jahuë xobo qui huëstima ca nohiria quëtsoniquë. Jahuë xobo ja rëamëcani quiha. Jasca, caiti cacha xëa yama ini quiha niiti. Jatsi quiha jato qui Jesu chaniniquë, Dios Chani yoahi na.
\v 3 Yoajahuano tsi quiha nohiria maxo xobo qui cahëniquë, mohitimaxëni ca joni bëhaina. Cuatro ca joni bá bëni quiha.
\v 4 Xobo qui cahëhax Jesu qui basimanoma ja icaniquë rë, naa huëstima ca nohiria iqui na. Jaha tsi quiha xobo mapasti tsëcatsijahuacaniquë. Quinihuaxo tsi quiha noitiria ca joni ja botëmacaniquë, jahuë oxatí no.
\v 5 Jabi Jesu qui ja chitimiriacani quiha toa joni ja jënimahuano. Jabi ja chitimicanai ca jisi tsi mohitimaxëni ca joni qui Jesu chaniniquë:
\p —Masahacaquë mi jocha, noho baquë́ —iquiina.
\p 
\v 6 Jabi toá tsi jodioba yoba tiisimacanaibo tsaho ini quiha. Jesú yoaha ca ja nicacaniquë. Nicahax,
\p 
\v 7 —¿Jënihax tsi toca tsi chanihi ni naa joni sa? Dios pasomaha chanihi quiha pë. Yama tsi xo jocha masati mëtsa cato ra; jaroha tsi xo Dios —i jamë jaca niquë.
\p 
\v 8 Jabi ja shinacanai ca Jesú cahëtapiniquë. Japi jato qui ja chaniniquë.
\p —¿Jëniriahax toca tsi shinacanai rë, ëa yoati na?
\v 9 ¿Jëni ca ni toa bëroria ca yoati, naa mohitimaxëni ca qui? “Masahacaquë mi jocha” ¿iti ni? “Niina. Cohuë” ¿iti ni?
\v 10 Jabi jocha masati chama Nohiria Baquë jaya ca ma cahëno ra. Tsayacahuë —i jato qui Jesu niquë.
\p Jatsi mohitimaxëni ca joni qui Jesu chaniniquë: \fig Mohitimaxëni ca Jesú jënimahuahaina|src="cn01687b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="MRK 2.10"\fig*
\p 
\v 11 —Joihuë. Mi oxati topihuë. Mi xobo qui cata —iquiina.
\p 
\v 12 Jatsi joitapiniquë joni ra. Joixo tsi quiha jahuë oxati ja topiniquë. Jatsi quiha xobo ja huajaniquë jato bësojó no. Jaha tsi quiha ja ratëyocaniquë tsayahax na. Tsayaxo tsi Dios ocahuatsijahuacaniquë:
\p —Anomaria tsi xo naa no tsayahana ra —iquiina.
\s1 Mateo Jesú quënanina
\r Mateo 9.9-13; Lucas 5.27-32
\p 
\v 13 Jatsi Galilea qui jahari Jesu catëquëniquë. Caxo tsi quiha ja qui quëtsohai ca nohiria tiisimatsijahuaniquë.
\v 14 Ia quënipama tsi quiha gobierno bax nohiria quima parata biti ibo-iboria ca joni Jesú jisniquë, naa Alfeo baquë Mateo. Jahuë oficina xara tsaho ja ini quiha. Jatsi,
\p —Ea banahuahuë —i ja qui Jesu niquë.
\p Jatsi quiha Mateo joiniquë. Joixo tsi Jesu ja banahuaniquë.
\v 15 Jaquirëquë Mateo xobo qui Jesu caniquë oriquixëna. Jabi impuesto biti ibo-iboria bo, jochahuaxëni cabo, tihi cabo qui joi Mateó amani quiha Jesu ya oriquiti. Jabi Jesu ja banahuacascani quiha jato ri.
\v 16 Jatsi quiha yosananiquë jodioba chama bo, naa jodioba yoba tiisimacanaibo, jochahuaxëni cabo ya Jesu oriquihai tsayahax na. Jatsi jahuë rabëti bo qui ja chanicaniquë:
\p —¿Jënixo tsi impuesto biti ibo bo, jochahuaxëni cabo, tihi cabo ya oriquihi ni Jesu pë? —iquiina.
\p 
\v 17 Jatsi quiha Jesú jato quëbiniquë nicaxo na:
\p —Doctor qui cayamahi quiha jënima cabo. Jama, doctor ó quëëhai ca tsi xo naa anoma cabo. Jasca, shinajiaxëni cabo quënahi ë joyamaniquë, jato jocha quima bësomati jochacanaibo quënati nori —nëa tsi jato qui Jesu nëcaniquë.
\s1 Samati jabi
\r Mateo 9.14-17; Lucas 5.33-39
\p 
\v 18 Toatiyá tsi quiha ashimati ibo Juan banahuacanaibo, fariseobo banahuacanaibo, tihi cabo samahi iniquë. Japi huësti huësti ca nohiria Jesu qui bëcaniquë nicaxëna. Johax,
\p —¿Jënihax tsi samahi ni Juan banahuacanaibo, fariseobo banahuacanaibo? Mi rabëti bo tsi xo toa samayamacanaina pa —i ja qui jaca niquë.
\p 
\v 19 Jatsi Jesú quëbiniquë:
\p —¿Joní ahui yano tsi samahi ni ahui bichish cato rabëti bo pa? Iyamacani quiha ra. Cohuëti xaba ma xo ra. Jabi ahui bichish ca jato bëtano tsi oriquicani quiha ra.
\v 20 Jama, tobixëhi quiha bari huëtsa, naa ahui bichish ca mëbihacaxëhai ca bari. Toa barí tsi quiha samacaxëcani quiha jahuë rabëti bo cohuëhi na. (Jabi tocaxëhi quiha noho rabëti bo ri ë caquë no) —nëa tsi Jesu nëcaniquë.
\s1 Arati quinia siri jatihaina
\r Mateo 9.16-17; Lucas 5.36-39
\p 
\v 21 Jatsi quiha Jesu chaniniquë nohiria bo qui jahuë arati quinia paxa ca yoati na.
\p —Quësi paxá tsi quiha raiti siri pishpayamahi quiha nohiria. Anoma quiha. Jabi quësi paxá tsi ja pishpapicano tsi përësixëhi quiha raiti siri. Përësixëhi quiha quësi paxa ri, jaha bëquiyamahai iqui na. (Jascaria, mato arati quinia siri jaha bëquiyamahi quiha noho tiisi paxa cato. Jamëri xo.)
\v 22 Jasca, jënë bichi ca sota sirixëni qui jëësihai ca jënë paxa ca rëhuiyamahi quiha nohiria. Rëhuipijahuacano tsi poshixëhi quiha jënë bichi ca sota ra. Jatsi japaquëxëhi quiha jënë. Yoshihuahacaxëhi quiha sota ra. Jama, jënë bichi ca sota paxa ca qui jënëria paxa ca rëhuihacati xo. (Jascaria, anoma tsi xo toa arati quinia sirí tsi noho tiisi paxa ca tiisimahaina ra. Arati quinia huëtsá tsi ja tiisimahacaxëti xo. Mato arati jabi siri jaha bëquiyamahi quiha noho tiisi paxa cato) —nëa tsi nohiria bo qui Jesu nëcaniquë.
\s1 Joiti barí tsi Jesu rabëti bá trigo bimi risanina
\r Mateo 12.1-8; Lucas 6.1-5
\p 
\v 23 Joiti barí tsi quiha harina trigo huai bo nacohi Jesu iniquë jahuë rabëti bo ya. Bohopama tsi quiha jahuë rabëti bá trigo bimi risaniquë piti.
\v 24 Jatsi quiha ja qui jodioba chama bo chaniniquë tsayahax na.
\p —Tsayapa. Anoma ca acani quiha mi rabëti bo ra. Anoma tsi xo toa joiti barí tsi yonocohaina ra —i ja qui jaca niquë.
\p 
\v 25 Jatsi Jesú quëbiniquë:
\p —¿Quënëhacanish cabo ó tsi noba David yamabá ani ca ma tsayayamayamani, naa jahuë joni bo ya ja paxnaniquë no?
\v 26 Dios xobo qui ja jiconi quiha jahuë joni bo ya, arati ibo ba mapari bixëna. Jabi toatiyá tsi quiha arati ibo bo chama Abiatar i-ipaoni quiha. Jicoxo tsi quiha Dios qui aquëquëmani ca mapari David yamabá bini quiha, pixëna; naa pinoma ca mapari quiha. Jatsi quiha ja bëta inish ca joni bo qui toa roa ca mapari ja ani quiha piti —nëa tsi Jesu nëcaniquë jato qui.
\p 
\v 27 Jatsi,
\p —Joiti bari Diós ani quiha joni mëbixëna ra. Joni acacayamani quiha joiti bari bax na.
\v 28 Jatsi jënima tsi xo toa noho rabëti bá acaina, joiti bari Ibo-iboria ca ë nori iqui na —i jato qui Jesu niquë.
\c 3
\s1 Mëquë choni jaya cato
\r Mateo 12.9-14; Lucas 6.6-11
\p 
\v 1 Catiti xobo qui Jesu jicotëquëniquë. Toá tsi mëquë choni jayanish ca joni ini quiha.
\v 2 Jatsi quiha nohiria bá Jesu tsaya-tsayamisniquë ja qui quësocasquí na. Joiti barí tsi joni ja jënimahuaxëti ó ja pasocani quiha.
\v 3 Jatsi mëquë choni jayanish ca joni qui Jesu chaniniquë:
\p —Niihuë. Nëri johuë —iquiina.
\p 
\v 4 Jatsi nohiria bo Jesú nicaniquë:
\p —¿Yoi ni, jia ni joiti barí tsi jia ca acaina? ¿Naa joni mëbixëhi ni noa? ¿Mëbiyamaxëhi ni noa? ¿Xabahamaxëhi ni noa; quëyoxëhi ni noa? —i jato qui ja niquë.
\p Quëbiyamaniquë nohiria pë. Ja pasicaniquë.
\v 5 Jatsi caxaxo tsi quiha Jesú jato bëisniquë. Cahëtimaxëni ca nohiria ra. Jato shina yoi iqui tsi Jesu cohuënaniquë. Jatsi noitiria ca joni qui Jesu chaniniquë:
\p —Mi mëquë yoi mëtahuë —iquiina.
\p Jatsi quiha joní jahuë mëquë mëtaniquë. Jënimahuahacani quiha jahuë mëquënë.
\v 6 Jatsi bamaxoma tsi jodioba chama bá jisbayaniquë. Jisbaya tsi maxo huëtsa ya, naa Herodes yonati bo ya ja caticaniquë chaninaxëna, Jesu acascani na.
\s1 Ia quëmapó ca nohiria misco bo
\p 
\v 7 Jatsi ia qui Jesu caniquë jahuë rabëti bo ya. Ja caquë tsi quiha banahuacaniquë Galileá ca nohiria misco ra.
\v 8 Jisti bo Jesú acai ca nicahax bëcani quiha jodioba maí ca nohiria. Jasca, Jerusalén, Idumea, ani Jordán rabëquëxë, Tiro, Sidón mai, tihi cabo ax ja bëcani quiha Jesu jisxëna.
\v 9 Jatsi quiha quëtsohai ca nohiria iqui tsi jahuë rabëti bo ja yobaniquë ja bax noti rohahuati. Nohiria quima paxati quiha.
\v 10 Jabi huëstima ca ja jënimahuaniquë toa barí no. Ja tsi xo toa ja qui nohiria quëtsoni quiha Jesu motsaxëna.
\v 11 Jasca, ja bësojó tsi yoshi jaya ca nohiria mëni-mëniniquë, Jesu tsayahax na. Mënihax yoshi bá quënaniquë:
\p —Dios Baquë xo mia ra —iquiina.
\p 
\v 12 Jama, jato ja yobarianiquë tsohuë ja iqui ca yoayamati.
\s1 Doce ca rabëti bo Jesú binina
\r Mateo 10.1-4; Lucas 6.12-16
\p 
\v 13 Nohiria bo jënimahuahax tsi tëmachi Jesu tëmahinaniquë. Tëmahinaxo tsi quiha ja bicasni ca joni bo ja quënaniquë ja bëtati. Jatsi ja qui ja bëcaniquë.
\v 14 Doce ca joni bo ja bini quiha ja bëtati, raahacati, Dios Chani yoati.
\v 15 Jasca, chama jato qui ja aniquë yoshi bo tsëcati.
\v 16 Jabi doce ca ja bini ca tsi xo naa:
\q1 Simón, naa Pedro ja janëni cato,
\q1 
\v 17 Jacobo, naa Zebedeo baquë,
\q1 Jacobo noma Juan, (Boanerges ja quënahacacani quiha, “Tërëhai cato baquë bo” iquiina.)
\q1 
\v 18 Andrés,
\q1 Felipe,
\q1 Bartolomé,
\q1 Mateo,
\q1 Tomás,
\q1 Alfeo baquë Jacobo,
\q1 Tadeo,
\q1 gobierno pasomaha ca Simón,
\q1 
\v 19 Judas Iscariote, naa jodioba chama bo qui Jesu mëanish cato.
\q1 Tihi cabo Jesú biniquë ja bëtati.
\s1 Yoshi bëboti chama Jesú jayahaina
\r Mateo 12.22-32; Lucas 11.14-23; 12.10
\p Jaquirëquë xobo qui Jesu jiconiquë jahuë rabëti bo ya.
\v 20 Ja qui nohiria misco quëtsotëquëniquë pa. Jabi nohiria iqui tsi pinoma quiha ja icaniquë rë.
\v 21 Jatsi quiha Jesú nohiria jënimahuahai ca jahuë noma bo, jahuë jahëhua, tihi cabá nicaniquë. Nicaxo tsi quiha Jesu bichi ja bocaniquë, yoyo jayahai ca quëscajahuahi na.
\p 
\v 22 Jasca, jahuë xobo qui cahëniquë Jerusalén ca maestro bo, naa Dios yoba cahëxëni cabo. Cahëhax tsi quiha ja nëcacaniquë:
\p —Jahuë ibo tsi xo Satanás ra. Yoshi bo ibo-iboria tsi xo toa Jesu mëbihai cato. Ja tsi xo toa yoshi tsëcati chama jaya xo ra —i jaca niquë pë, ja yoati na.
\p 
\v 23 Jatsi nohiria Jesú quënaniquë chani bo jato qui yoaxëna. Ja nëcani quiha:
\p —¿Jënahuariaxo raca Satanás Satanás natsëcana?
\v 24 Jabi iquinapihi tsi quëyohacaxëhi quiha país ca nohiria ra. Chama yama xo toca ca gobierno ra.
\v 25 Jasca, quëyohacaxëhi quiha xobó ca nohiria ra, ja iquinacaquë no. Yonocobëquitimaxëni ca xo rë.
\v 26 Japi jamë pasomaha iquinapihi tsi quëyohacaxëhi quiha Satanás chama. Tocapijano tsi basima xo jahuë rëso ra. Jabi tocayamahi quiha Satanás ra.
\p 
\v 27 ‘¿Jënahuariahax raca joni chamaxëni cato xobo qui joni jicona, jahuë jahuë bo yomaxëna? ¿Jariapari tsi quiha chamaxëni ca joni nëxayamayamaxëhi ni? Nëxaxo tsi jahuë jahuë bo yomahi quiha.
\p 
\v 28 ‘Mato parayamaquia. Nohiria jocha tëquë masaxëhi quiha Dios ra. Masahacaxëhi quiha ëa pasomaha ca chani ri.
\v 29 Jama, Espíritu Santo pi nohiriá ocahuano tsi jahuë jocha shina-bënoyamaxëhi quiha Dios. Quësohacapaoxëhi quiha toa nohiria ra —i Jesu niquë nohiria bo qui chanihi na.
\p 
\v 30 Jabi toca tsi quiha Jesu chaniniquë:
\p —Yoshi jaya —i jaca ni quëshpi na.
\s1 Jesu jahëhua, jahuë noma bo
\r Mateo 12.46-50; Lucas 8.19-21
\p 
\v 31 Jatsi xobo qui jahuë jahëhua, jahuë noma bo, tihi cabo bëcaniquë. Xobo cacha nii ja icani quiha. Jatsi chani ja qui ja raacaniquë, cacha ja jono iquish na.
\p 
\v 32 Jatsi,
\p —Cacha tsi xo mi ihua, mi noma bo. Mia mëracani quiha —i Jesu tëamë ca nohiria niquë.
\p 
\v 33 Jatsi Jesú jato nicaniquë:
\p —¿Tsohuë ni toa noho jahëhua yoi ra? ¿Tsohuë ni toa ëbë xatë yoi bo? —iquiina.
\p 
\v 34 Jatsi ja tëamë ca tsaho ca nohiria qui tsayahax,
\p —Nëá xo noho jahëhua yoi. Nëá xo ëbë xatë yoi bo.
\v 35 Ebë xatë, noho yoxa cato, noho jahëhua tihi ca tsi xo toa Dios shina acai cato iquia —iquiina.
\c 4
\s1 Bëro sayanish cato
\r Mateo 13.1-9; Lucas 8.4-8
\p 
\v 1 Ia Galilea quëmapo xo tsi quiha nohiria bo tiisimati Jesú chitahëhuaniquë. Anomaria nohiria iniquë ra, naa ja qui quëtsocanaibo. Nohiria misco quiha. Ja tsi xo toa ianë́ ca noti qui Jesu jiconiquë nohiria quima paxaxëna. Jicohax tsi quiha ja tsahoniquë. Quëmapó tsi quiha nohiria tëquë mani ini quiha.
\v 2 Jatsi quiha huëstima ca jahuë bo jato ja yoaniquë chaniquí na. Bëroria ca jahuë chani ini quiha. Ja nëcaniquë:
\p 
\v 3 —Bëro sayahi quiha huësti ca joni caniquë.
\v 4 Jahuë huai sayajahuano tsi quiha huësti huësti ca bëro bahi tapaí xapaquëniquë. Toá ca bëro isa bá piniquë joxo na.
\v 5 Jasca, bëro huëtsa quiha maxax mai qui xapaquëniquë, naa iriama ca mai cató no. Toá tsi quiha bëro shinahatapiniquë, oti yama pi mai ini iqui na.
\v 6 Bari tsëquëquë tsi quiha ja mëshahacaniquë. Tapo mishni quiha. Ja iqui tsi ja chonicaniquë rë.
\v 7 Jatsi huësti huësti ca bëro masa xërëquë tsi xapaquëniquë rë. Bëro ya tsi shinahabëquiniquë masara pë. Banaha ca ja mapani quiha.
\v 8 Jama, bëro huëtsa mai jiaxëni ca qui xapaquëniquë. Jocohax jia tsi quiha ja shinahaniquë. Huëstima ca bimi ja saihuacaniquë. Cien ca bëro huësti ca maxó saihuani quiha. Maxo huëtsa tsi quiha setenta. Maxo huëtsa ri treinta —nëa tsi quiha Jesu nëcaniquë.
\p 
\v 9 Jatsi,
\p —Ea nicaxëti xo jatiroha cabo ra —i Jesu niquë nohiria bo qui.
\s1 Jonë ca chani yoati na
\r Mateo 13.10-17; Lucas 8.9-10
\p 
\v 10 Jamë pistia ja no tsi quiha jahuë rabëti bo, toá ca banahuacanaibo huëtsa bo, tihi cabá nicaniquë ja yoaha ca chani yoati na. Jato qui bëronoma ini quiha ja yoahana.
\v 11 Jatsi jato ja quëbiniquë:
\p —Mato qui tiisi acacaniquë, Diós otohai ca yoati tsi jonë ca jahuë bo cahëti. Jama, naa jonë ca jahuë bo cahëyamahi quiha ëa pasomaha cabo. Nëca ca chaní tsi, naa ejemplo bá tsi nohiria qui chaniquia, nicaxo ja cahëyamacano iquish na.
\v 12 Dios quiri ja bësoyamacano, jato jocha masahacayamano iquish na.
\s1 Bëro sayanish ca ejemplo Jesú bërohuanina
\r Mateo 13.18-23; Lucas 8.11-15
\p 
\v 13 Jatsi Jesú jato nicaniquë:
\p —¿E yoaha ca chani ma cahëyamaha pa? Cahëyamapiquí tsi ¿jënahuariaxo raca ë yoaxëhai ca ejemplo huëtsa bo ma cahëna?
\v 14 Bëro sayahai ca tsi xo toa Dios Chani yoahai cato.
\v 15 Huësti huësti ca nohiria tsi xo toa bahi tapaí ca bëro jascaria. Dios Chani nicacani quiha. Ja nicacano tsi johi quiha Satanás, jato shina ó ca sayaha ca chani tsëcaxëna.
\v 16 Nohiria huëtsa tsi xo toa maxax mai qui sayaha ca bëro jascaria. Ranixo tsi Dios Chani biriacani quiha nicaxo na.
\v 17 Jama, jato shina ó tsi tapoyamahi quiha Dios Chani rë. Naamayamahi quiha ja chahahuacanaina rë. Dios Chani iqui tsi nohiria bá jato yosino tsi ja tënëmapihacacano tsi Dios quinia quima casotapicani quiha.
\v 18 Jatsi nohiria huëtsa tsi xo toa masa xërëquë sayaha ca bëro jascaria. Dios Chani nicacani quiha jato ri;
\v 19 jama, Dios quima jato ninihi quiha maí ca jahuë bo, naa jaha ja quëëcanaina. Maí ca jahuë bo shinacani quiha pë. Jatsi Dios Chani, naa sayaha ca bëro tsiihaqui quiha parata ó ja quëëcanaina ra. Tsiihaqui quiha toa jato ranihuahai ca jahuë bo rë. Ja quëshpi tsi jato shina ó tsi anitimaxëni tsi xo Dios Chani ra.
\v 20 Jama, tobi quiha Dios Chani bicanaibo, nicaxo na. Mai jiaxëni cato ó ca sayaha ca bëro jascaria ca xo. Dios bax saihuacani quiha. Huësti ca maxo tsi xo cien ca saihuahaina. Maxo huëtsa tsi xo setenta ca saihuahaina. Maxo huëtsa tsi xo treinta ra —nëa tsi Jesu nëcaniquë, jahuë chani bërohuahi na.
\s1 Lamparina ejemplo
\r Lucas 8.16-18
\p 
\v 21 Jatsi quiha jahuë chani Jesú rëtsaniquë:
\p —¿Paiti nama, oxati nama, tihi cabo nama jahuë lamparina janahi ni ibo pa, tsamaxo na? Tocayamahi quiha ibo ra. Jahuë ití tsi janahi quiha.
\v 22 Jabi bërohuahacaxëhi quiha jaboqui jonë ca tëquë.
\v 23 Ea nicati xo jatiroha cabo ra —i Jesu niquë.
\p 
\v 24 Jaquirëquë ja nëcaniquë:
\p —Nicaquí tsi chahahuacana. Jia pi ma nicano tsi Dios Chani pi ma jabino tsi mato tiisi anihuaxëhi quiha Dios.
\v 25 Oquë ca tiisi bixëhi quiha tiisi jaya cabo; jama, jahuë tiisi pistia roha bënoxëhi quiha nicacasyamacanaibo ra —i Jesu niquë.
\s1 Shinahacai ca bëro ejemplo
\p 
\v 26 Jaquirëquë Jesu nëcaniquë:
\p —Chani mato qui yoaquia Diós otohai ca mato cahëmaxëna. Tobi quiha huai ibo. Jahuë bëro sayahi cahi quiha.
\v 27 Sayaxo jisbayahi quiha. Jatsi huinocahi quiha bari bo. Ibo yamano tsi jocohi quiha toa ja sayahana. Jia tsi shinahahi quiha; jamë no.
\v 28 Jabi mai tsi xo toa bëro jocomahaina. Jariapari tsi xo jahuë joco. Jaquirëquë jahuë pëhi. Jarohari tsi xo jahuë bimi shini cato.
\v 29 Jahuë bëro shiniquë tsi tësaqui ibo ra. Tsëquëquë tësatiya —i Jesu niquë tiisimahi na.
\s1 Mostaza bëro ejemplo
\r Mateo 13.31-32; Lucas 13.18-19
\p 
\v 30 Jaquirëquë chani huëtsa Jesú yoaniquë:
\p —¿Jënahuariaxo Diós otohai ca mato cahëmaxëhi ni ëa sa? ¿Jëni ca ejemplo yoaxëhi ni ëa sa, mato cahëmati?
\v 31 Jabi mostaza bëro chani mato yoaxëquia ra. Toca xo Diós otohaina ra. Jabi mishni-mishniria tsi xo toa banaha ca mostaza bëro.
\v 32 Jama, shinahacax pistiama quiha. Tëtëcaria tsi xo jahuë mëshi bo. Planta huëtsa bo oquë quiha. Jasca, mëshi naxërëquë xo tsi jato naha acani quiha isa bo, tëbaquishí racaxëna —i jato qui Jesu niquë, tiisimahi na.
\s1 Ejempío bá tsi Jesu chaninina
\r Mateo 13.34-35
\p 
\v 33 Nëca tsi quiha huëstima ca ejemplo bo Jesú yoaniquë, Dios Chani nohiria bo tiisimaquí na. Cahëti mëtsa pi ja icano tsi ja tocani quiha.
\v 34 Jabi ejemplo bo ja yoarohaniquë tiisimaquí na. Jahuë jabi quiha. Jama, jahuë rabëti bo roha yaquí tsi quiha jahuë chani bo ja bërohuapaoniquë.
\s1 Yoshini, choca, tihi cabo Jesú janacamanina
\r Mateo 8.23-27; Lucas 8.22-25
\p 
\v 35 Yata, bari caquë tsi quiha jahuë rabëti bo Jesú yobaniquë:
\p —¿Ia rabëquëx ca qui canomani? —iquiina.
\p 
\v 36 Jatsi Jesu tsaho ca noti qui jahuë rabëti bo jiconiquë. Jicoxo tsi quiha nohiria bo ja jisbayacaniquë. Jisbaya tsi quiha ia ja shitacaniquë. Jatsi jato noti ya noti huëtsa bo shitaniquë jato ri.
\v 37 Jatsi iané tsi cosporiatsi yoshi niquë rë. Rëamëtsi quiha jato noti niquë choca iqui na. Jëtëquëpaimaria ja icani quiha.
\v 38 Jama, noti chipojó Jesu iniquë. Oxa quiha. Tëpasamëti raca. Jatsi jahuë rabëti bá Jesu bësomaniquë.
\p —Noqui shinahuë, Maestró. Rësopaima xo noa rë —i ja qui jaca niquë.
\p 
\v 39 Jatsi Jesu niiniquë. Niixo tsi quiha yoshi, choca, tihi cabo ja raahaniquë:
\p —Pasihuë. Janacahuë ra —iquiina.
\p Jatsi yoshi xotohai ca janacaniquë. Pasi roha ja ini quiha ra.
\v 40 Jatsi jahuë rabëti bo qui Jesu chaniniquë:
\p —¿Jëniriahax raquëcanai ra? ¿Jëniriahax ë qui ma chitimiyamaha? —iquiina.
\p 
\v 41 Raquëhax,
\p —¿Tsohuë cara ni naa sa? Ja qui nicahi quiha yoshini, choca, tihi cabo ra —i jaca niquë.
\c 5
\s1 Yoshi jayanish ca jënimahuahacanina
\r Mateo 8.28-34; Lucas 8.26-39
\p 
\v 1 Ia Galilea shitahax tsi quiha Gadara mai qui ja rërëcaniquë.
\v 2 Rërëhax noti ax Jesu botëniquë. Jatsi maihuati quini bo, naa cementerio icanai ca ax joni joniquë,
\v 3 naa yoshi jaya cato. Toá tsi quiha ja racaniquë, rësonish caba maí no. Anomaria jahuë yoyo ini quiha. Nëxanoma quiha. Jasca, mëchichó nëxanoma ja ini quiha.
\v 4 Jasca, huëstima tsi jahuë mëquënë, jahuë tahë, tihi cabo nëxahacaniquë; mahitsa. Mëchichó toa joni ja nëxacaquë tsi quiha mëri tsi ja tësaniquë. Jasca, jahuë tahë achati manë bo ja choshapaoniquë.
\v 5 Jasca, barihani, baquicha, rësonish caba maí tsi quiha ja cocohi iniquë. Maca bo nacopama tsi ja sai-saini quiha. Quënoxëni ca maxa bá tsi quiha jamë ja quëësani quiha.
\v 6 Jabi basi xo tsi Jesu jisi tsi quiha ja qui ja jabaniquë. Jabahax ja bësojó tsi quiha ja mëniniquë.
\v 7 Jatsi joi pistiamá tsi quiha ja quënaniquë:
\p —Ea huënahuayamahuë Jesú, mana ca Dios Baquë́. Dios janë́ tsi ëa shinahuë. Ea tënëmayamahuë ra iquia —iquiina.
\p 
\v 8 Jabi toca tsi quiha ja chaniniquë Jesú yoaha iqui na,
\p —Naa joni quima natsëquëhuë ra —i ja qui ja ni quëshpi na.
\p 
\v 9 Jatsi,
\p —¿Jahuë ni mi janë ra? —i quiha Jesu niquë.
\p —Seis Mil xo ëa —i ja niquë huëstima ca yoshi bo ja jayani quëshpi na.
\p 
\v 10 Jatsi Jesu ja bënarianiquë, toa mai quima jato ja raayamano iquish na.
\v 11 Jabi toá tsi, basima quiha, huëstima ca yahua jinaya iniquë. Macana xo tsi pihi ja icani quiha.
\v 12 Jatsi yoshi bá bënaniquë:
\p —Toa yahua jinaya qui noqui raahuë. Jato qui no jicono ra —iquiina.
\p 
\v 13 Jatsi,
\p —Bocata —i jato qui Jesu niquë.
\p Jatsi joni quima ax yoshi bo natsëquëniquë. Natsëquëhax tsi quiha yahua jinaya qui ja jicocaniquë. Jatsi jabatsi yahua tirixëni niquë. Dos mil ca yahua quiha. Maca ax rënichihax ia qui ja jabayocaniquë. Ja nëachiyocaniquë ianë́ no.
\p 
\v 14 Jatsi yahua jinaya obëso cabo jabayocaniquë, ratëhi na. Yacatá ca nohiria, xabachá ca nohiria, tihi cabo yoahi ja bocani quiha. Jatsi nohiria bo bëcaniquë oca pi ja ni ca jisi na.
\v 15 Jesu ini ca qui cahëxo yoshi jayapaonish ca joni ja jiscaniquë. Jaboqui tsaho ja ini quiha. Raiti sahuë quiha. Yoyo yama, jënima ja ini quiha. Tsayahax ja raquëcaniquë.
\v 16 Jabi yoyoxëni ca joni jënimahuahacani ca quinia jisnish cabá yoaniquë bëcanish cabo qui.
\v 17 Jatsi Jesu bënatsi jahuacaniquë jato mai jisbayati.
\p 
\v 18 Jatsi jahuë noti qui Jesu jiconiquë jisbayaxëna. Jicojano tsi quiha,
\p —Mi bëta cacasquia ra —i yoshi jayapaonish ca niquë.
\p 
\v 19 Jama, noti qui Jesú jicomayamaniquë. Jicomayamaxo tsi quiha ja qui ja chaniniquë:
\p —Jahari mi xobo, mi nabo, tihi cabo qui catá. Mi bax Ibobá acana, mia ja shomahuahana, tihi cabo jato mi yoano ra —iquiina.
\p 
\v 20 Jatsi pë joni jisbayaniquë. Jisbaya tsi quiha Decápolis icanai ca yaca bo xo tsi Jesú ja bax ani ca ja yoabonaniquë. Ratëniquë jahuë chani nicanish cabo tëquë.
\s1 Jairo jahini, jimihai ca yoxa jënimahuahacanina
\r Mateo 9.18-26; Lucas 8.40-56
\p 
\v 21 Jahari ia rabëquëx ca qui Jesu cahëquë tsi toá tsi quiha nohiria misco mani iniquë. Quëmapó nii ja icani quiha.
\v 22 Jatsi quiha ja qui joni joniquë, naa Jairo icanai cato. Jodioba catiti xobo chama quiha. Jesu jisi tsi quiha Jesu tahë tsi Jairo mëniniquë.
\v 23 Mënihax ja bënarianiquë:
\p —Anoma xo noho jahini rë. Noho xobo qui johuë. Noho jahi mi motsano ra, ja jënimanano iquish na, ja rësoyamano —iquiina.
\p 
\v 24 Jatsi Jairo ya Jesu caniquë. Banahuaniquë nohiria misco ri, ja qui quëtsocanaina.
\v 25 Jabi nohiria xërëquë tsi quiha noitiria ca jimi acai ca yoxa ini quiha. Doce ca año no tsi quiha jimi ja ani quiha.
\v 26 Jasca, huëstima ca doctor bo qui ja cani quiha jënimahuahacaxëna. Quëyohacani quiha jahuë parata; jama, jari jasca pi ja ini quiha rë. Oquënahi ja jimi acai ini quiha.
\v 27 Jesu yoati tsi nicahi tsi nohiria xërëquë tsi Jesu cho ja basimaniquë. Basimaxo tsi quiha Jesu sahuëti ja motsaniquë.
\v 28 Jabi jamë ja nëcani quiha: “Jahuë sahuëti roha pi motsahi tsi jënimaxëquia ra” iquiina.
\v 29 Jatsi tocapijaniquë. Bismatapiniquë ja jimihaina ra.
\v 30 Jarohari tsi quiha jahuë chama natsëquëha ca Jesú cahëtapiniquë. Nohiria naxërëquë bopinaxo tsi quiha ja nicaniquë:
\p —¿Tsohuë noho sahuëti motsaha? —iquiina.
\p 
\v 31 Jatsi jahuë rabëti bá quëbiniquë:
\p —Tsayahuë. Anomaria tsi xo toa nohiriá mia tijihacanaina. ¿Jëniriahax raca, “¿Tsohuë ëa motsaha?” i mi a pa? —iquiina.
\p 
\v 32 Jama, motsahax ca jari Jesú mëraniquë, nohiria tsayaquí na.
\v 33 Jatsi raquëtsi yoxa niquë. Ja jënimahuahacaha ca ja cahëni quiha. Japi mëmë tsi Jesu qui ja joniquë. Johax Jesu tahë tsi quiha ja mëniniquë. Ja jënimahuahacaha ca ja yoaniquë, parayamaquí na.
\v 34 Jatsi Jesu ja qui chaniniquë:
\p —Mi jënimahuahacaquë cai, mi chitimihai ca iqui na. Bëpasi tsi cata. Jaboqui jënima xo mia —iquiina.
\p 
\v 35 Jari Jesu ja qui chanino tsi quiha huësti huësti ca nohiria bëcaniquë Jairo xobo ax na, naa jodioba catiti xobo chama. Cahëhax,
\p —Rësoquë mi jahini rë. Maestro jari huënahuayamahuë. Iquë rë —i jahini jahëpa qui jaca niquë.
\p 
\v 36 Ja yoacana ca chahahuayamahi tsi jodioba catiti xobo chama qui Jesu chaniniquë:
\p —Raquëyamatsina. E qui roha mi chitimino ra —iquiina.
\p 
\v 37 Jatsi jahari nohiria bo Jesú raaniquë, jamë cacatsina. Pedro, Jacobo, Juan, Jacobo noma, tihi ca roha ja boniquë.
\v 38 Jairo xobo qui cahëxo tsi quiha pacots-huahai ca nohiria, naa araconacanaibo, huini-huinicanaibo, tihi cabo ja jisniquë.
\v 39 Xobo qui jicopama tsi quiha,
\p —¿Jënahuariahax raca nëca tsi araconacanai? Anomaria xo ma pacots-huahaina ra. Rësoyamahi quiha naa baquë. Oxa roha —i nohiria bo qui Jesu niquë.
\p 
\v 40 Jatsi ja osacaniquë. Jatsi xobo cacha nohiria tëquë ja raaniquë. Raaxo tsi quiha jahëpa, jahëhua, ja bëta bëcanish cabo, tihi roha ca ja bëniquë jahi ini ca qui.
\v 41 Jatsi jahini mëquë Jesú biniquë. Bichi tsi,
\p —Talita, cumi, naa joihuë caí, iquia —i jahi pistia qui Jesu niquë. \fig Jairo jahi jënimahuahacahaina|src="cn01713b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="MRK 5.41"\fig*
\p 
\v 42 Jatsi joitapiniquë jahini. Tapiti mëtsa ja ini quiha ra. Jabi doce ca año ja jayani quiha naa xotaco. Jatsi ratëniquë nohiria tëquë tsayahax na.
\v 43 Jama, nohiria bo Jesú yobaniquë, ja aca ca ja yoayamacano Jasca, jato ja yobaniquë jahi pistia pimati.
\c 6
\s1 Nazaret qui Jesu shishonina
\r Mateo 13.53-58; Lucas 4.16-30
\p 
\v 1 Jaquirëquë toa mai Jesú jisbayaniquë. Jisbaya tsi quiha jahari jahanahax ja coni yacata, naa Nazaret icanai ca qui ja bacaniquë jahuë rabëti bo ya.
\v 2 Joiti barí tsi quiha ja cahëcaniquë. Cahëxo tsi quiha jodioba catiti xobo xo tsi tiisimatsi quiha Jesú huaniquë. Jabi toá tsi quiha huëstima ca nohiria iniquë araxëna. Jesu chani nicahi tsi quiha ja ratëyocaniquë.
\p —¿Jahuënia ca naa tiisi ja bini sa? ¿Jënahuariaxo raca naa jisti bo aqui ni pa?
\v 3 ¿Carpintero roha tsi xo naa ra? Maria baquë yoi tsi xo naa pë. Jahuë noma bo tsi xo Jacobo, José, Judás, Simón ra. ¿Nëá tsi racayamayamahi ni jahuë yoxa cabo ri? ¿Jënahuariahax raca noqui ja oquëna? —nëa tsi nohiria bo nëcaniquë Jesu yoati na.
\p Ja iqui tsi pë jahuë chani ja nicacasyama-caniquë rë.
\v 4 Jatsi Jesú jato yoaniquë:
\p —Jabi Dios Chani yoati ibo qui nicahi quiha jatiroha ca nohiria ra. Jama, nicacasyamacanaibo tsi xo toa jahuë yacatá ca nohiria, jahuë jimi bo, jahuë xobó cabo pë. Tihi cabo tsi xo toa jahuë chani nicacasyamacanaibo —i jato qui ja niquë.
\p 
\v 5 Jatsi toa xo tsi jisti bo ati mëtsama Jesu iniquë, ja qui ja chitimiyamacani iqui na. Huësti huësti ca iquicanaibo roha ja jënimahuani quiha, jato ó tsi jahuë mëquë tsi janaquí na.
\v 6 Ratëni quiha Jesu, ja qui ja chitimicasyamacani iqui na. Jaquirëquë yaca huëtsa bo qui ja caniquë Dios Chani tiisimahi na.
\s1 Jahuë doce ca rabëti bo Jesú raanina Dios Chani yoati
\r Mateo 10.5-15; Lucas 9.1-6
\p 
\v 7 Jaquirëquë jahuë doce ca rabëti bo ja qui Jesú catianiquë. Catiaxo tsi quiha rabë rabë tsi jato raatsijahuaniquë Dios Chani yoati. Jasca, chama jato qui ja aniquë yoshi bo tsëcati.
\v 8 Jatsi jato ja yobaniquë:
\p —Mëquëya bocana. Coti jihui roha bocana. Sota, mapari, parata, tihi cabo boyamacana.
\v 9 Jënima tsi xo chinela sahuëhaina; jama, rabë ca camisa bo ma sahuëyamano —nëa tsi Jesu nëcaniquë, jato yobahi na.
\p 
\v 10 Nëca tsi ja rëtsaniquë:
\p —Yaca qui cahëhax mato qui joi amahai ca nohiria xobó tsi chitëcana. Shishohi tsi xobo huëtsa rarinayamacana.
\v 11 Yacatá ca nohiriá pi mato joihuayamano tsi mato chani pi ja nicacasyamacano tsi jato bëta chitëyamacana. Jisbaya tsi mato tahë ca cospo toj-tojhacahuë jato jocha jismaxëna. Toca tsi jato qui Dios caxa ma jismati xo —i jahuë rabëti bo qui ja niquë.
\p 
\v 12 Jatsi ja bocaniquë. Dios Chani ja yoabonacaniquë:
\p —Dios quiri mato quinia yoi ca quima bësocana ra —iquiina.
\p 
\v 13 Jasca, yoshi huëstima ca ja tsëcacaniquë. Iquicanaibo ó tsi xëni ja japacaniquë, jato ja jënimahuaquë no. Tihi tsi ja acaniquë, Dios Chani yoaquí na.
\s1 Juan yamabo yoati Herodés nicanina
\r Mateo 14.1-12; Lucas 9.7-9
\p 
\v 14 Jabi Jesu yoati tsi chama Herodés nicaniquë, nëama Jesú ani ca chani pacanani quëshpi na. Nicahax tsi quiha,
\p —Tonia bësotëquë xo Juan yamabo ra. Ja tsi xo toa jisti ati chama jaya xo ra —i Herodes niquë Jesu yoati na.
\p 
\v 15 Jasca,
\p —Dios Chani yoanish ca Elías yamabo tsi xo naa tonia —i nohiria huëtsa bo niquë.
\p Jama,
\p —Dios Chani yoati ibo-iboria tsi xo naa, naa noba Dios Chani yoanish cabo jascaria —i huëtsa bo niquë.
\p 
\v 16 Nohiria bá yoahai ca nicahax tsi quiha chama Herodes nëcaniquë:
\p —Juan yamabo xo ra. Jahuë mapo ë tëquëësaniquë rë; jama, jaboqui bëso ja nori —iquiina.
\p 
\v 17 Jabi siri tsi soldado bo chama Herodés raani quiha Juan qui tsamiti. Juan nëxati ibo chama Herodes ini quiha. Jabi ja bichi ca ahui Herodías iqui tsi quiha preso qui Juan nanëhacani quiha rë. Jabi jahuë noma Felipe ahui chama Herodés bini quiha rë, naa Herodías icanai cato.
\v 18 Jabi jahuë noma ahui ja biquë tsi,
\p —Binoma tsi xo mi noma ahuini ra. Anoma quiha —i ja qui Juan i-ipaoni quiha.
\p 
\v 19 Ja tsi xo toa Juan qui jahuë ahui paxa ca Herodías caxa iniquë. Juan ja acasni quiha pë; jama, ati mëtsama ja ini quiha jahuë bënë Herodes iqui na.
\v 20 Shina jiaxëni ca mëstë ca joni Juan iqui ca chama Herodés cahëni quiha. Ja tsi xo toa Juan ja acasyamani quiha, raquëquí na. Japi Juan ó ja bësoniquë. Jasca, ja qui jia quiha Juan chanini ca ini quiha. Nicahax ja shina-huëjënapaoni quiha.
\v 21 Jama, jahuë ahui qui tsëquëni quiha Juan namëti xabaca, naa jahuë bënë Herodes coni bari no. Toa barí tsi quiha jahuë nohiria chama bo, jahuë capitán bo, Galileá ca yosibo, tihi cabo qui joi Herodés amaniquë, jahuë fiesta qui ja bëcano.
\v 22 Ja oriquicano tsi quiha Herodías jahi jiconiquë jato bax pabëxëna. Jabi ja pabëhai ca qui raniniquë Herodes, ja bëta oriquicanaibo. Ranihax xotaco qui Herodes chaniniquë:
\p —¿Jahuë ó quëëhai? Ea nicamahuë. Jaha mi quëëhai ca mi qui axëquia ra —i ja qui ja niquë.
\p 
\v 23 Jatsi ja jurar-aniquë:
\p —Mia parayamaquia ra. Jahuëcara mi bënahai ca mi qui axëquia ra, naa ë yonahai ca bëquëx tana —iquiina.
\p 
\v 24 Jatsi xotaco caniquë jahuë jahëhua nicaxëna.
\p —¿Jahuë bënaxëhi ni ëa sa? —i jahuë jahëhua qui ja niquë.
\p Jatsi,
\p —Ashimati ibo Juan mapo bita —i ja qui ja niquë.
\p 
\v 25 Bamahaxma tsi chama Herodes qui jahari ja joniquë. Johax,
\p —Ashimati ibo Juan mapo ë qui ahuë, ratá no —i chama qui ja niquë rë.
\p 
\v 26 Jatsi Herodes cohuëniquë nicahax na. Jama, nohiria bësojó tsi “Mia parayamaquia” i ja ni iqui tsi jaha ja quëëhai ca xotaco qui ja aniquë.
\v 27 Jatsi soldado ja raaniquë Juan mapo biti.
\v 28 Jatsi preso qui soldado caniquë. Caxo jahuë mapo ja tëquëësaha ca tsi jahari ja bëniquë ratá no. Joxo xotaco qui ja aniquë. Jatsi jahëhua qui jahuë mapo ja aniquë.
\p 
\v 29 Jabi Herodés ani ca nicahax Juan banahuacanaibo bëcaniquë jahuë yora bixëna. Bixo tsi quiha ja maihuajahuacaniquë.
\s1 Cinco mil ca nohiria Jesú pimanina
\r Mateo 14.13-21; Lucas 9.10-17; Juan 6.1-14
\p 
\v 30 Jatsi Jesu rabëti bo bacaniquë, naa Dios Chani yoatí raahacanish cabo. Jesu ya catixo tsi quiha jatiroha ca ja acanina, ja tiisimacanina, tihi cabo tsi quiha Jesu ja yoacaniquë.
\p 
\v 31 Jatsi Jesu cacasniquë.
\p —¿Nohiria yama ca qui nomë canomani? Naa nohiria misco no jisbayano, no joiparino iquish na —i jahuë rabëti bo qui Jesu niquë.
\p Jabi huëstima ca nohiria ini quiha ja qui bëcanaina, bocanaina. Nohiria iqui tsi quiha piti xaba ja nariscaniquë. Jatsi ja yosanacani quiha.
\v 32 Ja quëshpi tsi iti huëtsa qui ja bocaniquë notí no, jamëjacano iquish na.
\v 33 Jama ja bocanai ca huëstima cabá jisniquë. Tsohuë cara ja icani ca ja cahëcana ca tsi rëquë ja jabacaniquë ja rërëcanai ca qui. Ja quënibonacani quiha. Quënihax Jesu bëbo ja cahëcani quiha. Jasca basima ca yaca bo ax ja jabacani quiha.
\v 34 Jatsi tëmahinapama tsi quiha naa nohiria misco Jesú jisniquë. Jato ja noini quiha, jaha bësohamaca oveja jascaria ja icani quëshpi na. Japi huëstima ca jahuë bo jato tiisimatsi quiha Jesú huaniquë.
\v 35 Yata tsi quiha ja qui jahuë rabëti bo bëcaniquë yobaxëna.
\p —Caquë bari tia —i Jesu qui jaca niquë—.
\v 36 Basima ca yaca bo, huai bo, tihi cabo qui nohiria raatsana. Toa xo tsi jahuëcara ca ja copicano piti. Yama tsi xo piti nëá no —i jaca niquë.
\p 
\v 37 Jatsi Jesú nëca tsi jato quëbiniquë:
\p —¿Mato tsani? Jato pimacana —iquiina. Jatsi ja chanicaniquë:
\p —¿Jënahuariaxo raca tihiria ca mapari no copina, naa nohiria tëquë pimaxëna? Copixëniria quiha —iquiina.
\p 
\v 38 Jatsi Jesú jato yoaniquë:
\p —¿Jahuë tihi ca mapari jayahi ni nohiria bo ra? Tsayata —iquiina.
\p Cahëhax,
\p —Cinco ca mapari, dos ca sanino, tihi cabo jayacani quiha —i Jesu qui jaca niquë.
\p 
\v 39 Jatsi nohiria bo Jesú tsahomaniquë huasí no.
\v 40 Maxo cincuenta, maxo cien, toca tsi jato ja tsahomani quiha.
\v 41 Tsahomaxo tsi quiha cinco ca mapari, dos ca sanino, tihi cabo Jesú biniquë. Bichi tsi quiha mana nai qui tsayahax tsi “Gracias” i Dios qui ja niquë piti quëshpi na. Jatsi mapari bo ja tëxënamaniquë. Tëxënamaxo jahuë rabëti bo qui ja aniquë nohiria bo taati. Jaquirëquë sani ja tëxënamaniquë nohiria bo taaxëna.
\v 42 Piniquë nohiria tëquëta. Ja sëyayocaniquë.
\v 43 Jaquirëquë mapari quësi bo, sanino, naa pihama ca quëësi bo jahuë rabëti bá catianiquë. Doce ca caca rëahacaniquë ra.
\v 44 Jabi toá tsi cinco mil ca mapari picanai ca joni bo ini quiha ra.
\s1 Jënë cacha Jesu conina
\r Mateo 14.22-27; Juan 6.16-21
\p 
\v 45 Nohiria bo pimaxo tsi noti qui jahuë rabëti bo Jesú jicomaniquë, jabëbo Betsaida qui ja shitacano iquish na. Jasca, nohiria tëquë jahari jato xobo qui ja raaniquë.
\v 46 Jahuë rabëti bo raahax maca bo qui ja caniquë bëhox-xëna.
\v 47 Bari caquë tsi quiha ia nëpax tsi jari noti ini quiha; jamë pistia maí tsi Jesu iquiina.
\v 48 Jatsi noiyamaria tsi ja huasha-huashacanai ca ja jisniquë, yoshi xotohai ca bëcha ja icanai quëshpi na. Jatsi patiari quëonox pari no tsi quiha jato qui Jesu caniquë, jënë cacha cohi na. Copama tsi jato ja tarabicasni quiha.
\v 49 Jatsi jënë́ tsi Jesu cohai ja jiscaniquë. Bërocamaqui ja iqui ja quëscahuajahuacaniquë. Jatsi ja sai i-icaniquë raquëhi na.
\v 50 Jabi ja jiscaniquë jato tëquëta. Jisi tsi ja ratëyocaniquë. Jatsi Jesu jato qui chanitapiniquë:
\p —Chamacana. Ea yoi xo naa. Raquëyamacana —iquiina.
\p 
\v 51 Jatsi noti qui Jesu jicoquë tsi quiha pasiniquë yoshi xotohaina ra. Jatsi ratëyoniquë jahuë rabëti bo. Shinati ja cahëyamacani quiha.
\v 52 Quëstoria ini quiha jato shinana. Jasca, mapari ja tëxënamaquë tsi quiha tsohuë yoi ja iqui ca ja cahëyamayoicani quiha.
\s1 Genesarét ca iquicanaibo Jesú jënimahuanina
\r Mateo 14.34-36
\p 
\v 53 Jatsi ia ja shitacaniquë. Shitaxo tsi quiha Genesaret mai qui ja rërëcaniquë. Toá tsi jato noti ja nëxacaniquë.
\v 54 Ja tëmahinacaquë tsi quiha nohiria bá Jesu cahëtapiniquë.
\v 55 Jatsi toa maí tsi pacanayocaniquë nohiria, iquicanaibo ja iqui ca qui bëxëna. Jato oxatí tsi anoma cabo ja qui ja bëcani quiha jënimahuahacati.
\v 56 Jasca, jatiroha ca Jesu cani ca qui, naa yaca bo, jihuëta bo, tihi cabo xo tsi jato anoma cabo ja janacaniquë bahí no. Jatsi Jesu ja bënariacaniquë jënimahuahacati, jahuë sahuëti quëpë roha motsacatsi na. Jabi jënimahuahacani quiha jahuë sahuëti motsanish cabo tëquëta ra.
\c 7
\s1 Nohiria jochamahai cato
\r Mateo 15.1-20
\p 
\v 1 Jatsi jodioba chama bo, jato yoba tiisimacanaibo, tihi cabo cahëniquë Jerusalén ax na, Jesu tsayacascani na.
\v 2 Jabi jahuë rabëti bo tsayapama tsi quiha chocohama ca mëquënë tsi ja picanai ca ja jiscaniquë. Jodioba jabi, jato yoba, tihi cabo pasomaha ini quiha ja acanaina. Ja quëshpi tsi jodioba chama bo ranimisniquë.
\v 3 Jabi jodioba yoba, naa jato naboyamaba yoba siri bo ja aria-ariacani quiha. Pinox pari tsi quiha ja mëchococani quiha. Jato jabi quiha.
\v 4 Jasca, jato yoba iqui tsi mercadó ca copini ca jahuë bo ja chocohacani quiha pinox pari. Jato jabi quiha. Jasca, jato canico bo, jato olla bo, jato rato bo, tihi cabo ja chocohacani quiha. Jato naboyamabá ani ca yoba quiha.
\v 5 Jatsi bëcanish ca jodioba chama bá Jesu nicaniquë:
\p —¿Jënixo tsi noba naboyamabá noqui ani ca yoba ayamahi ni mi rabëti bo? Mëchocoxoma tsi picani quiha pë. Anoma quiha —iquiina.
\p 
\v 6 Jatsi Jesú jato quëbiniquë:
\p —Quiaxëni xo mato ra. Parayamaniquë Isaías yamabo, mato yoati tsi ja quënëquë no:
\q1 “Jato janá tsi jia tsi ëa ocahuacani quiha naa nohiria;
\q1 jama, ëa basi jato shina nori.
\q1 
\v 7 Mahitsa ë qui aracani quiha.
\q2 ‘Dios yoba tsi xo naa’ icani quiha,
\q2 jato mahitsa ca yoba nori”
\m nëa tsi quiha Isaías yamabo nëcani quiha Quënëhacanish cabo ó no.
\v 8 Tsayacahuë. Dios yoba niaqui mato pë, mato joni bá tiisimahai ca yoba banahuaxëna —nëa tsi Jesu nëcaniquë jodioba chama bo qui.
\p 
\v 9 Jatsi Jesú rëtsaniquë, chanihi na:
\p —Mato jabi bo, mato yoba bo, tihi cabo banahuaquí tsi Dios yoba-yobaria niaqui mato pë.
\v 10 Jabi Dios yoba Moisés yamabá mato qui aniquë: “Mato jahëpa, mato jahëhua noicana” iquiina. Jasca, “Namëhacati xo tsohuëcara ca jahuë jahëpa, jahuë jahëhua, tihi cabo ocahuahai cato” i ja ni quiha.
\v 11 Jama, mato qui jënima tsi xo mato noitiria ca nabo nicayamahaina rë. “Jishopë. Mato mëbitimaxëni xo ëa rë, Dios qui noho parata ë aquitaha quëshpi na” iqui mato pë, jato mëbicasyamahi na.
\v 12 Jatsi mato nabo mëbiyamaqui mato rë. Mato qui jënima xo toca ca chanihaina pë. Jabi toca tsi Dios yoba niaqui mato ri, ma ani ca yoba ó bësocatsi na.
\v 13 Jabi tobi huëstima ca toca ca mahitsa ca jabi bo ma acaina rë —nëa tsi Jesu nëcaniquë bëcanish ca jodioba chama bo qui.
\s1 Nohiria jochamahai ca jahuë bo
\r Mateo 15.10-20
\p 
\v 14 Jatsi nohiria bo quënatëquëhax tsi quiha Jesu chaniniquë:
\p —Ea nicayocana. Ma cahëno ra.
\v 15 Nohiria jochamayamahi quiha toa ja qui jicohaina. Jama, nohiria jochamahai ca tsi xo toa yoi ca ja shinahai ca ja chanihaina ra.
\v 16 Jabi naa chani nicaxëti xo jatiroha cabo —i Jesu niquë.
\p 
\v 17 Jatsi nohiria bo jisbëria tsi quiha xobo qui Jesu jiconiquë. Toa xo tsi jahuë rabëti bá nicaniquë ja yoaha ca chani yoati na. Jatsi Jesu chaniniquë:
\p 
\v 18 —¿E yoaha ca cahëyamahi ni mato ri ra? ¿Jënahuariaxo raca ma pihai cató mato shina yoshihuana?
\v 19 Shina qui cayamahi quiha piti ra, jahuë poco qui nori. Cahax jahuë poco ax huajahi quiha —nëa tsi Jesu nëcaniquë.
\p Jabi ja yoaha cató tsi jatiroha ca piti jënima iqui ca Jesú jismani quiha.
\v 20 Jatsi ja nëcaniquë:
\p —Nohiria jochamahai ca tsi xo toa ja shinahaina ra.
\v 21 Ja xara, naa jahuë shina quima ax johi quiha ja shinahai ca yoi cato. Yoi ca shinaquí tsi anoma ca jahuë bo aqui quiha rë. Jahuë shina yoi iqui tsi yomahi quiha nohiria ra. Ja quëshpi tsi tobi toa joni acaina, joni huëtsa ahui bichiina,
\v 22 yoi ca ó quëëmis-haina. Jasca, jato yoi ca shinahai iqui tsi tobi quiha yoi ca acaina, paramis-haina, ranomis-haina, ranimis-haina, jamë shinamis-haina, yoyohaina.
\v 23 Jabi joni xara, naa jahuë shina quima ax johi quiha naa yoi ca tëquëta. Ja tsi xo toa nohiria bo jochamahai cato, ja picanai ca nomari —nëa tsi Jesu nëcaniquë.
\s1 Carayana ca yoxa Jesu qui canina
\r Mateo 15.21-28
\p 
\v 24 Toa ax riquicaya tsi quiha mai huëtsa, naa yaca Tiro y Sidón basima ca qui Jesu caniquë. Xobo qui jicoxo tsi quiha ja racahi iqui ca Jesú cahëmacasyamaniquë. Jama, mëri tsi quiha jahuë iti nohiria bá cahëniquë. Jonënoma ja ini quiha.
\v 25 Toatiyá tsi ja racani ca huësti ca yoxá nicaniquë, naa yoshi jaya ca jahi jayanish cato. Nicahax ja qui ja joniquë. Jatsi Jesu bësojó tsi quiha ja mënitapiniquë.
\v 26 Jabi carayana naa yoxa ini quiha, naa Sirofenicia maí conish cato. Mënixo tsi quiha Jesu ja bënarianiquë jahuë jahi ó ca yoshi natsëcati.
\v 27 Jatsi quiha Jesu ja qui chaniniquë:
\p —¿Jënahuariaxo mia ë mëbina? Jodiobo qui roha ë raahacani quiha shomahuati. Jato ë mëbipariti xo ra. Noba jabi pasomaha tsi xo toa carayanabo mëbihaina. Noba xocoba mapari ini bo qui niahai jascaria xo —i ja qui Jesu niquë.
\p 
\v 28 Jatsi yoxá quëbiniquë:
\p —Jabija, Taitá. Yoiria ca carayana roha ca ëa xo naa ra; jama, ¿jato chama quima ax paquëhax ca quëxë mishni bo piyamayamahi ni ina bo ra? Shomahuahacaqui ina bo ri ra —iquiina.
\p 
\v 29 Jatsi Jesu yoxa qui chanitëquëniquë:
\p —Jia tsi xo toa mi quëbihana. Ja iqui tsi mi jahi ë jënimahuaquë ra. Cata. Natsëquëquë mi jahi ó ca yoshini ra —iquiina.
\p 
\v 30 Jatsi jahari jahuë xobo qui yoxa caniquë. Jënima, oxati raca ja ini quiha, xobo qui ja cahëquë no. Yama jahuë yoshi ini quiha.
\s1 Jaro ca joni Jesú jënimahuanina
\p 
\v 31 Tiro mai riquicaya tsi quiha Sidón mai Jesu naconiquë Ia Galilea qui caxëna. Decápolis icanai ca yaca bo ja tarabiniquë caquí na.
\v 32 Toa xo tsi quiha patoxi ca jaro ca joni nohiria bá bëniquë ja qui. Bëxo tsi quiha Jesu ja bënariacaniquë, jahuë mëquë jaha ja janano.
\v 33 Japi nohiria misco quima Jesú joni boniquë, jamë pistia ja bëtati. Jatsi joni pahoqui quiní tsi jahuë mëtsis Jesú pahostaniquë. Pahostaxo tsi quiha coshoxo tsi jahuë jana ja motsaniquë.
\v 34 Jaquirëquë nai qui tsayapama tsi quiha ja ëësiniquë. Jatsi,
\p —Papëquëhuë ra —i ja qui Jesu niquë.
\p 
\v 35 Jatsi nicatapiniquë joni. Bëro tsi quiha ja chaniniquë ra. Jënima quiha jahuë pahoqui, jahuë jana, tihi cabo iniquë.
\v 36 Jatsi nohiria bo qui Jesu chaniniquë:
\p —E aca ca yoayamatsacana —iquiina.
\p Jato ja pasimacasni quiha; mahitsa. Jato ja pasima-pasimaquë tsi quiha oquë tsi ja ani ca ja pacanamacaniquë rë.
\v 37 Jatsi ratëyoniquë nohiria tëquë, ja ani ca nicahax na.
\p —Anomaria tsi xo toa ja acaina ra. Patoxi cabo pasomahi quiha ra. Jaro cabo chanimahi quiha pa —nëa tsi nohiria bo nëcaniquë Jesu yoati na.
\c 8
\s1 Cuatro mil ca nohiria Jesú pimanina
\r Mateo 15.32-39
\p 
\v 1 Jaquirëquë toatiyá tsi quiha nohiria misco catitëquëniquë, Jesu jiscatsi na. Jatsi jato piti ja quëyocaquë tsi quiha jahuë rabëti bo Jesú quënaniquë:
\p 
\v 2 —Noitiria tsi xo naa nohiria. Tres ca bari no tsi ë bëta ja icaquë. Jaboqui yama tsi xo ja picanaina rë.
\v 3 Paxnacanai ca jato xobo qui jato ë raapino tsi bahí tsi rësocanacaxëcani quiha tonia. Basi-basiria tsi xo toa huësti huësti ca bëcanana —i jahuë rabëti bo qui Jesu niquë.
\p 
\v 4 Jatsi jahuë rabëti bá quëbiniquë:
\p —¿Jënahuariaxo raca jato bax mapari bo no bina rë? Xobo yama ca iti tsi xo naa ra —iquiina.
\p 
\v 5 Jatsi Jesú nicaniquë:
\p —¿Jahuë tihi ca mapari yani mato? —iquiina.
\p —Siete ca mapari roha —i jaca niquë.
\p 
\v 6 Jatsi nohiria misco ca ja tsahomaniquë maí no. Mapari bichi tsi quiha “Gracias” i Dios qui ja niquë. Jatsi mapari ja tëxënamaniquë. Tëxënamaxo tsi quiha jahuë rabëti bo ja mëaniquë nohiria misco bo taati. Jatsi mapari nohiria bo qui ja mëacaniquë.
\v 7 Jasca, huësti huësti ca sani mishni ja jayacaniquë. Naa sani bixo tsi quiha “Gracias” i Dios qui Jesu niquë. Jatsi jahuë rabëti bo qui sani ja mëaniquë nohiria bo taati.
\v 8 Piniquë nohiria tëquëta. Ja sëyayocaniquë. Jabi tobi cuatro mil ca nohiria ini quiha picanaina.
\v 9 Ja picaquë tsi quiha pihama ca quësi mishni bo ja topicaniquë. Jaquirëquë jato xobo qui nohiria bo ja raaniquë.
\v 10 Raahax noti qui ja jiconiquë jahuë rabëti bo ya. Jicoxo ia ja shitacaniquë.
\s1 Jisti jodioba chama bá jiscasnina
\r Mateo 16.1-4
\p 
\v 11 Jatsi jodioba chama bo Jesu qui bëcaniquë ja qui joi mëraxëna. Jesu tanamacasquí tsi quiha Jesu ja nicacaniquë:
\p —Mana ca jisti mi ano ra. Jisti pi mi ano tsi mia chahahuaxëqui noa ra —iquiina.
\p Jabi ja tocacaniquë ja qui quësocastsi na pë.
\v 12 Jato qui yosanahi tsi quiha jato qui Jesu nëcaniquë:
\p —Jistí-naxëni xo mato pë. Mato bax ayamaxëquia ra —iquiina.
\p 
\v 13 Jato jisbaya tsi quiha noti qui ja jiconiquë. Jatsi ia ja shitaniquë rabëquëx ca qui.
\s1 Jodioba chama bo, chama Herodes, tihi cabo ó jahuë rabëti bo Jesú quiniamanina
\r Mateo 16.5-12
\p 
\v 14 Ia shitapama tsi quiha,
\p —Jishopë. Mapari piti no shina-bënoquë rë —i Jesu qui jaca niquë.
\p Jabi huësti ca mapari roha ja jayacani quiha notí no.
\p 
\v 15 Jatsi Jesú jato yobaniquë:
\p —Jodioba chama bo, Herodes, tihi cabo ó tsi quiniacaxëcahuë, mapari levadura jascaria jaca nori iqui na. Mëri tsi pacanahi quiha jato yoi cato ra —iquiina.
\p 
\v 16 Jatsi jato xërëquë tsi chaninatsijacaniquë.
\p —¿Jënijaha sa? Toca tsi chanihi quiha pë, mapari no shina-bënoha iqui na, tonia —i jaca niquë.
\p 
\v 17 Jabi mapari yoati tsi ja chaninacanai ca Jesú cahëni quiha. Cahëhi tsi,
\p —¿Jënihax tsi joi i-icanai rë, naa ma shina-bënoha ca mapari yoati na? —i jato qui Jesu niquë—. Ma shina-bënoha ca mapari shinayamaquia ra. ¿Jari cahëyamacanai? Quëstoria xo mato mapo rë.
\v 18 ¿Bëro yama ni mato sa? Jatsi tsayacahuë. ¿Pahoqui jaya ni mato? Jatsi nicacahuë.
\v 19 ¿Cinco mil ca nohiria jaboqui ë pimayamaha? Jasca, ¿cinco ca maparí roha tsi jato tëquë ë pimayamaha? Jaquirëquë ¿jahuë tihi ca caca ma rëaha, naa mapari pihama cató no? —i jato qui Jesu niquë.
\p Jatsi,
\p —Doce ca cacano —i jaca niquë.
\p 
\v 20 Jatsi,
\p —Jasca, siete ca maparí tsi cuatro mil ca nohiria ë pimahitaquë ra. Toatiyá tsi ¿jahuë tihi ca caca ma rëahitaha, pihama ca maparí no? —i Jesu niquë.
\p Jatsi jahuë rabëti bá quëbiniquë:
\p —Siete ca caca no rëahitaquë —iquiina.
\p 
\v 21 Jatsi,
\p —¿Jari tsohuë ë nori ca cahëyamacanai? ¿Jari ma pihai ca mapari shinahi ni mato ra? —iquiina.
\s1 Betsaidá ca bëco ca joni Jesú jënimahuanina
\p 
\v 22 Betsaida yaca qui ja cahëcaquë tsi quiha bëco ca joni Jesu qui nohiriá bëcaniquë. Bëxo tsi quiha Jesu ja bënariacaniquë, joni jënimahuati.
\v 23 Jatsi yaca cacha Jesú joni mëpiniquë. Mëpixo tsi quiha jahuë bëro qui Jesu coshohaniquë. Jatsi jahuë mëquë jahá janaxo Jesú nicaniquë:
\p —¿Jahuë tsayahai? —iquiina.
\p 
\v 24 Jatsi taisniquë joni. Tais-hax tsi quiha,
\p —Nohiria bo jisquia. Jama, ë qui bohohai ca jihui bo jisiria ca xo rë —i Jesu qui joni niquë.
\p 
\v 25 Jatsi joni bëro Jesú motsatëquëniquë. Ja bëpëquëquë tsi quiha jënima jahuë bëro iniquë. Bëroria quiha jatiroha ca ini quiha.
\v 26 Jatsi Jesú joni raaniquë jahuë xobo qui. Raahax,
\p —Yaca qui mi jicotëquëyamano. Mi bax ë aca ca nohiria bo mi yoayamano ra —i joni qui Jesu niquë.
\s1 —Xabahamati Ibo xo mia —i Pedro nina
\r Mateo 16.13-20; Lucas 9.18-21
\p 
\v 27 Jaquirëquë jahuë rabëti bo ya Jesu caniquë Cesareá ca Filipo mai ó ca yaca bo qui. Bahí copama tsi quiha jahuë rabëti bo Jesú nicaniquë:
\p —¿Tsohuë ni ëa? ¿Jënihi ni nohiria bo ëa yoati na? —iquiina.
\p 
\v 28 Jatsi jahuë rabëti bá quëbiniquë:
\p —“Ashimanish ca Juan yamabo përë xo mia” ii quiha huësti huësti ca nohiria. “Elías yamabo xo mia” ii quiha nohiria huëtsa bo. “Tonia Dios Chani yoanish ca xo mia” ii quiha tëxë bo —i Jesu qui jaca niquë.
\p 
\v 29 Jatsi Jesú jato nicaniquë:
\p —¿Jënihi ni mato ëa yoati na? ¿Tsohuë ni ëa yoi? —iquiina.
\p Jatsi,
\p —Dios raahacanish ca Xabahamati Ibo xo mia ra —i ja qui Pedro niquë.
\p 
\v 30 Jatsi Jesú jato yobaniquë, Cristo, naa Xabahamati Ibo ja iqui ca yoayamati.
\s1 Ja rësoxëhai yoati tsi Jesu chaninina
\r Mateo 16.21-28; Lucas 9.22-27
\p 
\v 31 Jatsi ja rësoxëhai yoati tsi chanitsi Jesu niquë:
\p —Tënë-tënëxëquia ra, naa Nohiria Baquë ë nori cato. Ea niacaxëcani quiha jodioba yosibo, jato arati ibo ba chama bo, jato yoba tiisimacanaibo rë. Ea namëcaxëcani quiha ra; jama, tres ca bari huinocaquë tsi bësotëquëxëquia ra —nëa tsi jahuë rabëti bo qui Jesu nëcaniquë.
\p 
\v 32 Jabi bëro tsi ja rësoxëhai yoati tsi Jesu chaniniquë. Jatsi ori tsi Jesu Pedró boniquë jamë tsi ja qui chanixëna.
\p —Anoma tsi xo toca tsi mi chanihaina ra —i Jesu qui ja niquë, raahahi na.
\p 
\v 33 Jama, Jesu bopinaniquë. Bopinaxo tsi quiha Pedro ja raahaniquë, jahuë rabëti bo tsayaquí na.
\p —Ea basihuë, Satanás. Dios shinahai ca jasca ma xo toa mi shinahaina, nohiria bá shinahai jascaria nori —i Pedro qui ja niquë.
\p 
\v 34 Jatsi jahuë rabëti bo, nohiria misco, tihi cabo Jesú quënaniquë yobati.
\p —Ea pi banahuacasquí tsi ma acatsai ca ma shinayamati xo. Jaquirëquë mato cruz iacana. Iaxo ëa banahuacahuë.
\v 35 Jabi xabahamahacayamaxëhi quiha jahuë noma jabi ó quëëmisxëni cato. Jama, xabahamahacaxëhi quiha jahuë noma jabi chihohuahai cato, ëa, noho chani, tihi cabo quëshpi na.
\v 36 Jabi jatiroha ca maí ca jahuë bo nohiriá bëbomitsa; jama, tënëtiya qui caapiquí tsi ¿jahuë raca ja bëbona?
\v 37 Jabi jahuë shina pi bënoquí tsi ¿jahuë raca Dios qui nohiriá ana ra, jahuë shina bitëquëxëna?
\v 38 Jabi anoma ca jochahuaxëni tsi xo naa jaboqui bësocanaibo iquia. Jabi ëa, noho chani, tihi cabo qui naa nohiria bo rabino tsi jato qui rabixëquia ëa ri, xaba huëtsá tsi ë joxëquë no. Toa barí tsi ángel bo ya tsi joxëquia ra, noho Jahëpa chamá no ra, naa Nohiria Baquë ë nori cato —nëa tsi nohiria bo qui Jesu nëcaniquë.
\c 9
\p 
\v 1 Jatsi jahuë chani Jesú rëtsaniquë:
\p —Mato parayamaquia. Chamá tsi joxëhi quiha Diós otohaina ra. Jasca, ja johai ca jisxëqui mato huësti huësti cabo ra, ma rësonox pari —i jato qui ja niquë.
\s1 Jesu jabitinina
\r Mateo 17.1-13; Lucas 9.28-36
\p 
\v 2 Jatsi seis bari quirëquë, Pedro, Jacobo, Juan, tihi cabo maca qui Jesú boniquë jato bëtarohaxëna. Toá tsi quiha jahuë jaria jabitiniquë jato bësojó no.
\v 3 Joxonariani quiha jahuë sahuëti; huëa jascaria quiha. ¿Tsohuë raca toca tsi raiti joxohuana?
\v 4 Jatsi Elías yamabo, Moisés yamabo, tihi cabo jisiquiniquë. Jesu ya chanihi ja icani quiha.
\v 5 Jatsi Jesu qui Pedro chaniniquë:
\p —Noqui jia tsi xo nëá no iquiina. Nëa xo tsi tres ca tapas axëqui noa ra; huësti mi-na, huësti Moisés-na, huësti Elías yamabá-na —nëa tsi Pedro nëcaniquë.
\p 
\v 6 Jabi jahuëcara chaniti Pedró cahëyamani quiha raquëquí na.
\v 7 Jatsi tsëmo joniquë. Joxo tsi quiha jato ja mapaniquë. Jatsi tsëmó ca joi chaniniquë:
\p —Noho Baquë yoi tsi xo naa ra. Noiquia. E qui jia tsi xo toa ja acaina ra. Ja qui nicacana —i joi niquë.
\p 
\v 8 Jatsi nëjo nëjo taistapipama tsi quiha yama ca ja jiscaniquë. Jesu roha jato bëta ini quiha.
\p 
\v 9 Jatsi maca ax botëjacano tsi quiha jato Jesú yobaniquë:
\p —Ma jisi ca nohiria bo jari yoayamacana. Jariapari tsi rësohax bësotëquëxëquia ra, naa Nohiria Baquë ë nori cato. Jaquirëquë jënima tsi xo nohiria bo ma yoahaina ra —iquiina.
\p 
\v 10 Jatsi ja bëpacaniquë. Jama, ja yoaha ca ja cahëyamacani quiha. Jaha tsi,
\p —¿Jënihax tsi “Bësotëquëxëquia” i ja a sa? —i jaca niquë chaninahi na.
\p 
\v 11 Cahëcasquí tsi quiha Jesu ja nicacaniquë:
\p —“Xabahamati Ibo jonox pari no tsi joxëhi quiha Elías chama jaya ca pari” ii quiha noba yoba tiisimacanaibo. ¿Jabija ni toa ja yoacanaina? —i Jesu qui jaca niquë.
\p 
\v 12 Jatsi Jesú jato quëbiniquë:
\p —Jariapari joxëhi quiha Elías, naa Dios chama jaya cato. Joxo tsi jatiroha ca paxahuaxëhi quiha. Jabija tsi xo toa ja yoacanaina. Jama, “Tënëxëhi quiha Nohiria Baquë ri. Niaxëhi quiha nohiria bo rë” ¿i Dios Chani yoanish cabo yamayamani?
\v 13 Jabi joniquë Elías ra, naa Dios chama jaya cato. Ja joquë tsi ja qui nohiria bá yosiniquë rë, mato Quënëhacanish cabá yoani ca jascaria —nëa tsi jahuë rabëti bo qui Jesu nëcaniquë.
\s1 Yoyo jaya ca baquë Jesú jënimahuanina
\r Mateo 17.14-21; Lucas 9.37-43
\p 
\v 14 Jatsi maca ax botëxo tsi quiha nohiria misco ja jiscaniquë. Jesu rabëti bo yaxo joi mërahi jodioba chama ini quiha. Jato tëamë tsi nohiria misco mani ini quiha.
\v 15 Jatsi Jesu jisi tsi nohiria bo shina-risiquiniquë. Ja qui ja jabayocaniquë joihuaxëna.
\v 16 Jatsi Jesú jahuë rabëti bo nicaniquë:
\p —¿Jënixo tsi joi mëracanai? —iquiina.
\p 
\v 17 Jatsi toá ca nohiria xërëquë ca joní quëbiniquë:
\p —Mi qui noho baquë ë bëquë ra, jënimahuahacati. Yoshi jaya xo rë. Jaro quiha.
\v 18 Noho baquë qui tsamiquí tsi mai qui niahi quiha rë. Jatsi jabacoxhi quiha noho baquë. Xëta mayëquërëhi quiha. Jatsi huishta-huishtahi quiha ra. Anoma quiha. Jabi, “Noho baquë ó ca yoshi tsëcacahuë” i mi rabëti bo qui ë quë. Tsëcatimaxënicana rë —nëa tsi Jesu qui joni nëcaniquë.
\p 
\v 19 Jatsi Jesú quëbiniquë:
\p —Chitimitimaxëni ca yosaxëni ca nohiria xo mato pë. ¿Jahuë tihi tsi mato tënëxëhi ni ëa ra? Mi baquë nëri bëhuë —nëa tsi joni qui Jesu nëcaniquë.
\p 
\v 20 Jatsi Jesu qui jahuë baquë ja bëcaniquë. Jatsi pë Jesu jisi tsi quiha yoshiní baquë caxo amaniquë. Paquëniquë baquë. Maí tsi ja robi-robiniquë, ja bacoxhaina.
\v 21 Jatsi pë Jesú jahuë jahëpa nicaniquë:
\p —¿Jahuë tihi tsi nëca tsi ja ini?
\m —iquiina.
\p Jatsi jahuë jahëpa chaniniquë:
\p —Baquë pistia ax rohari.
\v 22 Huëstima tsi chihi, jënë, tihi cabo qui yoshiní noho baquë niani quiha axëna. Japi noqui shinahuë ra. Noqui mëbihuë ra. Mia roha tsi xo toa ati chama jaya cato ra —i jahëpa niquë.
\p 
\v 23 Jatsi,
\p —“Ati chama jaya xo mia” ¿i mi a pa? Acacati xo jatiroha cato, Dios qui chitimihai ca bax na iquia —i jahëpa qui Jesu niquë.
\p 
\v 24 Jatsi quiha jahëpá quëbitapiniquë:
\p —Dios qui chitimiquia ra. Jama, ëa chamahuahuë ra, oquë tsi ë chitimino iquish na —iquiina.
\p 
\v 25 Jatsi ja qui quëtsohai ca nohiria misco anihai ca jisi tsi quiha baquë ó ca yoshi Jesú raahaniquë:
\p —Natsëquëhuë ra, yoshi jaro patoxi cató. Baquë qui jicotëquëpistiayamariaxëhuë iquia —nëa tsi quiha Jesu nëcaniquë yoshi qui.
\p 
\v 26 Jatsi yoshiní jahuë baquë sai i-imaniquë. Caxo amahax tsi quiha ja natsëquëniquë ra. Jabi toa tsi pë chaparoha baquë ini quiha maí no. Ja rësoni nohiria bá quëscahuaniquë. Jaha tsi quiha,
\p —Naquë baquë ra —i jaca niquë.
\p 
\v 27 Jatsi pë Jesú jahuë mëquë achaniquë. Achaxo tsi quiha baquë ja joimaniquë. Niiniquë baquë ra. Jënima quiha ja iniquë ra.
\p 
\v 28 Jaquirëquë, xobo qui Jesu jicoquë tsi,
\p —¿Jënixo tsi jahuë yoshi tsëcanoma no iqui? —i Jesu qui jahuë rabëti bo niquë.
\p 
\v 29 Jatsi Jesú jato yoaniquë:
\p —Bëronoma tsi xo nëca ca yoshi natsëcahaina ra. No bëhoxhai cató tsi ja natsëcahacaxëti xo ra. Yama xo quinia huëtsa —i quiha jato qui Jesu niquë.
\s1 Ja nahai yoati tsi Jesu chanitëquënina
\r Mateo 17.22-23; Lucas 9.43b–5
\p 
\v 30-31 Toa mai ax riquibaya tsi quiha Galilea mai ja nacocaniquë. Nohiria bo basi Jesu chitëniquë jahuë rabëti bo tiisimacatsi na. Chanihi tsi,
\p —Nohiria bo qui ë mëahacaxëti xo. Jatsi ëa acaxëcani quiha. Jama, tres bari quirëquë bësotëquëxëquia ra —i jato qui Jesu niquë.
\p 
\v 32 Jabi Jesú yoaha ca jahuë rabëti bá cahëyamaniquë. Jama,
\p —¿Jënihi ni mi yoahaina? No joma —iyama jaca ni quiha raquëhi na.
\s1 ¿Tsohuë ni toa oquë cato?
\r Mateo 18.1-5; Lucas 9.46-48
\p 
\v 33 Jatsi Capernaum yaca qui ja cahëcaniquë. Xobo qui jicoxo tsi quiha Jesú jahuë rabëti bo nicaniquë:
\p —Bahí bohopama tsi ¿jahuë yoati tsi joi mëranahi ma iqui? —iquiina.
\p 
\v 34 Jatsi ja bëpacaniquë, yoacasyamaquí na. Ja bërabicani quiha jato xërëquë ca oquë ca iqui ca yoati tsi chaninahi ja icani quëshpi na.
\v 35 Jatsi Jesu tsahoniquë. Tsahoxo tsi quiha jahuë doce ca rabëti bo ja quënaniquë. Chanihi tsi,
\p —Ja cho ixëti quiha tsohuëcara ca rëquë icatsai cato. Jatiroha cabo ja mëbixëti xo —i jato qui Jesu niquë.
\p 
\v 36 Jatsi baquë pistia jato nëpax tsi Jesú jananiquë. Baquë icohax ja rëtsaniquë. Chanihi tsi,
\p 
\v 37 —Jabi ëa joihuahi quiha tsohuëcara ca noho janë́ tsi nëca ca baquë joihuahai cato. Jasca, ëa raanish ca ri joihuahi quiha ëa joihuahai cato ra —i jahuë rabëti bo qui Jesu niquë.
\s1 Jesu rabëti yoi bo
\r Lucas 9.49-50
\p 
\v 38 Jatsi Juan chaniniquë:
\p —Mi janë́ tsi yoshi natsëcahai ca joni no jisitaquë ra. “Ayamahuë ra” i ja qui no itaquë; noba maxo quirima ja iqui iqui na —iquiina.
\p 
\v 39 Jatsi,
\p —Toa jënëyamacana —i ja qui Jesu niquë—. Ea ocahuatimaxëni tsi xo toa noho janë́ tsi jisti acai cato ra.
\v 40 Noba rabëti tsi xo toa noqui pasomahama cato iquia.
\v 41 Mato parayamaquia. Copihacaxëhi quiha chahahuacanaibo mëbihai cato ra, ëa iqui tsi jënëpaxa roha jato qui ja aquë no.
\s1 Jochati tanamahacahaina
\r Mateo 18.6-9; Lucas 17.1-2
\p 
\v 42 ‘Jabi jia tsi ë qui chitimicani quiha naa xocobo mishni bo. Japi noitiriaxëhi quiha nëca ca chahahuabëna cabo ë quima bësomahai cato ra. Anomariaxëhi quiha jahuë copi ra. Ja acai quëshpi tsi tërotamë ca rënëti maxax ya nëmi ca ia qui ja niahacati xo iquia. Jama, oquëria ca copi bixëhi quiha ra, ja aca ca yoi ca quëshpi na.
\v 43 Mato mëquënë́ pi mato jochamacasno tsi mërëësicahuë. Oquë tsi xo toa mërëxto tsi nai qui cahaina. Noitiria tsi xo toa tënëtiya qui niahacahaina mëquë ya.
\v 44 Nocatimaxëni tsi xo toa tënëtiya chihi ra.
\v 45 Jasca, yoi ca qui mato tahë́ pi mato bono tsi jorëësicahuë. Oquë tsi xo toa jorëxto tsi nai qui cahaina. Noitiria tsi xo toa tënëtiya qui cahaina tahë ya.
\v 46 Nocatimaxëni tsi xo toa tënëtiya chihi ra.
\v 47 Jocha quiri pi mato bëró mato bësomano tsi bëtsëquëcahuë. Oquë tsi xo Diós otohai ca qui huësti ca bëro ya roha jicohaina. Noitiria tsi xo toa rabë ca bëro ya tënëtiya qui niahacahaina ra.
\v 48 Nocatimaxëni tsi xo toa tënëtiya chihi ra.
\p 
\v 49 ‘Tënëhai cató tsi rohahuahacaxëti xo jatiroha cabo.
\v 50 Chopara jia ca jascariacana. Jia tsi xo chopará tëëhuahaina. Jama, jahuë tëë bënopiquí tsi ¿jënahuariaxo ja tëëhuana? —nëa tsi Jesu nëcaniquë nohiria bo tiisimahi na.
\c 10
\s1 Ahui niahai yoati tsi Jesú tiisimanina
\r Mateo 19.1-12; Lucas 16.18
\p 
\v 1 Jatsi toa ax riquiquiria tsi, jodioba mai qui Jesu caniquë, naa Jordán rabëquëx cato. Ani Jordan ja shitaquë tsi quiha ja qui nohiria misco quëtsotëquëniquë. Jatsi tiisimatsi Jesú huaniquë. Jahuë jabi quiha.
\p 
\v 2 Jatsi ja qui huësti huësti ca jodioba chama bo bëcaniquë tanamaxëna. Ja qui joi mëratsijahuacani quiha. Jatsi,
\p —¿Anoma ni joní jahuë ahui niahaina? —i Jesu qui jaca niquë, ja qui quësocascani na.
\p 
\v 3 Quëbihi tsi,
\p —¿Jëni Moisés ni? ¿Jahuë yoba mato qui ja ani? —i jato qui ja niquë.
\p 
\v 4 Jatsi jodioba chama bá quëbiniquë:
\p —Moisés qui jënima ja ini quiha. Jariapari tsi quiha ahui niati papi joni ja huishamani quiha ahui mëati. Ahui qui toa papi mëajahuaquë tsi quiha jënima Moisés qui ini quiha toa jahuë ahui joní niahaina ra —i Jesu qui jaca niquë.
\p 
\v 5 Jatsi,
\p —Majia —i Jesu niquë—. Mato jochahuaxëni ca quëstoria ca shina iqui tsi toa yoba mato qui Moisés yamabá ani quiha ra.
\v 6 Dios quinia ma xo toa ahui niahaina ra. Jariapari tsi quiha joni, yoxa, tihi cabo Diós nëhohuaniquë racanabëquiti.
\v 7 Ja tsi xo toa jahuë jahëpa, jahuë jahëhua, tihi cabo jisbayahi quiha joni, jahuë ahui qui riiti. (Jasca, jahuë nabo jisbayahi quiha yoxa ri, jahuë bënë qui riiti.) Jatsi racanabëquicani quiha.
\v 8 Toca tsi huëstinacani quiha dos cabo, naa ahui bënë tëquëta.
\v 9 Jabi Diós racanabëquimaha ca nohiria bá bëquëxyamano ra —nëa tsi jodioba chama bo qui Jesu nëcaniquë.
\p 
\v 10 Jatsi xobo qui jicoxo tsi quiha jahuë rabëti bá Jesu nicatëquëniquë, naa joní ahui niahai ca yoati na.
\v 11 Quëbihi tsi,
\p —Jahuë ahui pi niaquí tsi ahui pasomaha jochahi quiha joni, ahui paxa ca ja biquë no.
\v 12 Jascaria jahuë bënë pi niaquí tsi ja pasomaha jochahi quiha yoxa ri, bënë paxa ca ja biquë no —i jato qui Jesu niquë.
\s1 Xocobo mishni bo Jesú shomahuanina
\r Mateo 19.13-15; Lucas 18.15-17
\p 
\v 13 Huësti huësti ca nohiria bá jato xocobo Jesu qui bëniquë, jato ja shomahuano iquish na. Jama, jato nabo raahatsi jahuë rabëti bá huaniquë pë.
\v 14 Jatsi jato ja raahacahai ca jisi tsi quiha jahuë rabëti bo qui Jesu caxaniquë. Chanihi tsi,
\p —Nëri ë qui xocobo bëcano ra. Jato chitiayamacana. Nëca cabo otocatsi quiha Dios. Ja qui jia quiha.
\v 15 Mato parayamaquia. Bëroria tsi Diós jato otohai ca bichi quiha xocobo ra. Jabi xocobo jascaria pi Diós otohai ca biyamahi tsi Diós otohai ca qui jicoyamaxëhi quiha mato ra —i nohiria bo qui Jesu niquë.
\p 
\v 16 Jatsi xocobo icoxo tsi jato ja shomahuaniquë. Jahuë mëquë jato ó tsi ja janani quiha.
\s1 Rico ca ya Jesu chaninina
\r Mateo 19.16-30; Lucas 18.18-30
\p 
\v 17 Bahí tsi Jesu cano tsi quiha ja qui joni jabaniquë. Ja bësojó tsi ja mëniniquë. Mënihax ja chaniniquë:
\p —¿Jënahuaxëhi ni ëa ra, Maestro jiaxëni cató, bëso-bësopaoxëti? —iquiina.
\p 
\v 18 Jatsi Jesu ja qui chaniniquë:
\p —¿“Jiaxëni cato” ëa mi quënaha pa? Yama tsi xo jiaxëni cato ra. Ja huësti ca tsi xo Dios.
\v 19 Jabi Moisés yoba bo cahëqui mia tonia. “Nohiria ayamahuë” ii quiha. Jasca, “Joni huëtsa ahui biyamahuë; yomayamahuë; quiayamahuë; parayamahuë; mi ipa, mi ihua, tihi cabo noihuë,” tihi ca tsi ii quiha jahuë yoba —nëa tsi Jesu nëcaniquë joni qui.
\p 
\v 20 Jatsi,
\p —Toa yoba bo tëquë ë nicaquë xocobo xo rohari, Maestró —i Jesu qui joni niquë.
\p 
\v 21 Jatsi noixo joni Jesú bëisniquë. Chanihi tsi,
\p —Huësti roha tsi xo toa mi naris-haina ati. Cata. Mi jahuëmishni bo tëquë iniahuë. Iniaxo toa parata noitiria cabo qui ahuë. Toca pi mi no tsi mana ca rico ca jahuë bo jayaxëqui mia naipá no. Jaquirëquë johuë. Ea mi banahuano ra —i joni qui Jesu niquë.
\p 
\v 22 Jatsi joni cohuënaniquë Jesú yoaha ca nicahax na. Cohuë tsi quiha ja bacaniquë, rico-ricoria ja iqui iqui na.
\p 
\v 23 Jatsi nëjo nëjo tsi quiha jahuë rabëti bo Jesú tsaya-tsayaniquë. Chanihi tsi,
\p —Bëronoma tsi xo toa rico ca joni Diós otohai ca qui jicohaina ra —i jato qui ja niquë.
\p 
\v 24 Jatsi ratëniquë Jesu rabëti bo, ja yoani ca nicahax na. Jama, jari jasca pi Jesu chaniniquë:
\p —Bëroma tsi xo Diós otohai ca qui jicohaina ra, noho xocobá.
\v 25 Jahuë chama yoí tsi bëronoma tsi xo Diós otohai ca qui rico ca jicohaina iquia, naa sopiri quini camelló nacohai jascaria nori —nëa tsi jahuë rabëti bo qui Jesu nëcaniquë.
\p 
\v 26 Jatsi ratëyorianiquë jahuë rabëti bo ja yoani ca nicahax na. Chaninahi tsi,
\p —¿Yama tsi xo toa xabahamahacati mëtsa cato rë? —i jaca niquë.
\p 
\v 27 Jatsi Jesú jato yoaniquë:
\p —Jabija. Jamë xabahamatimaxëni tsi xo nohiria. Dios roha tsi xo toa nohiria xabahamahaina. Jatiroha ca ati mëtsa xo ra —iquiina.
\p 
\v 28 Jatsi Pedró quëbiniquë,
\p —Tsayahuë. Jatiroha ca no jisbërianiquë mia banahuaxëna —iquiina.
\p 
\v 29 Jatsi,
\p —Mato parayamaquia —i Jesu niquë—. Copihacaxëhi quiha ëa banahuahai cato ra. Ea, xabahamati chani, tihi cabo iqui tsi jahuë xobo, jahuë xatë bo, jahuë jahëpa, jahuë jahëhua, jahuë ahuini, jahuë xocobo, jahuë mai, tihi cabo pi jisbëriaquí tsi
\v 30 cien ca veces huino bixëqui ëa banahuahai cato, jaboqui bësohi na. Xobo bo, xatë bo, jahëhua bo, xocobo, mai bo, tihi cabo bixëhi quiha tënëpiquí na. Jasca, mana ca copi bixëhi quiha bësoti paxa ca tsëquëxëquë no. Jatsi bëso-bësopaoxëqui toa.
\v 31 Jishopë. Toa barí tsi jachoxëhi quiha huëstima ca jaboqui rëquë cabo. Jasca, rëquëxëhi quiha huëstima ca jaboqui jacho cabo.
\s1 Jesu chaninina ja nahai yoati na
\r Mateo 20.17-19; Lucas 18.31-34
\p 
\v 32 Jerusalén qui jahuë rabëti bo ya capama tsi quiha jato bëbo Jesu cohi iniquë. Shina-huëjë jahuë rabëti bo ini quiha. Jasca, shina-huëjëni quiha bacahai ca nohiria bo ri. Capama tsi quiha jahuë rabëti bo ya roha Jesu chanicananiquë ja rësoxëhai ca yoati na. Chanihi tsi,
\p 
\v 33 —Nicapa. Jerusalén qui caqui noa rë. Toa xo tsi arati iboba chama bo, yoba tiisimacanaibo, tihi cabo qui mëahacaxëquia rë. Jatsi ë qui quësocaxëcani quiha, “Namëhacati xo” iquiina. Jaquirëquë ë qui quësoxo tsi carayanabo qui ëa mëacaxëcani quiha acacati.
\v 34 Jatsi ëa mahuacaxëcani quiha naa carayanabo. Rispichí tsi ëa rashacaxëcani quiha. Rashaxo tsi ëa namëcaxëcani quiha. Jama, tres bari quirëquë bësotëquëxëquia ra —i jahuë rabëti bo qui Jesu niquë.
\s1 Jacobo, Juan, tihi cabá bënanina
\r Mateo 20.20-28
\p 
\v 35 Jatsi Jesu qui Juan, Jacobo, tihi cabo bëcaniquë, naa Zebedeo baquë bo.
\p —Tobi jahuëcara ca no bax mi ano ra, Taitá —i Jesu qui jaca niquë.
\p 
\v 36 Jatsi,
\p —¿Jahuë mato bax axëhi ni ëa? —i Jesu niquë.
\p 
\v 37 Jatsi Jesu ja quëbicaniquë:
\p —Mana xo tsi mi yonano tsi mia tapaí tsi tsahocasqui noa, huësti ca mi mënëcayá no, huëtsa mi mëxojó no —iquiina.
\p 
\v 38 Jatsi Jesú quëbiniquë:
\p —Ma bënahai ca cahëyamaqui mato ra. ¿Tënëti mëtsa ni mato ra, naa ë tënëmahacapaimaria ca jascaria? Anomariaxëhi quiha noho cohuë. Jasca, anomariaxëhi quiha ë tënëhaina ra —i jato qui Jesu niquë.
\p 
\v 39 Jatsi,
\p —Jaahuë. Mia jascaria tsi tënëti mëtsa xo noa ra —i Jesu qui jaca niquë.
\p Jatsi,
\p —Tënë-tënëxëqui mato ra, naa ë tënëmahaca-xëhai jascaria.
\v 40 Jama, noho mënëcayá ca tsahoti, noho mëxojó ca tsahoti, tihi cabo mato qui ati mëtsama xo ëa ra. Dios tsi xo toa tsahoti bo acai cato. Ja shomahuaha cabo qui axëhi quiha ra —i jato qui Jesu niquë.
\p 
\v 41 Jabi jaha ja quëëcana ca nicahax Jacobo, Juan, tihi cabo qui jahuë rabëti bo tëxëbo caxaniquë.
\v 42 Japi Jesú jato catianiquë jato qui chanixëna.
\p —¿Jato nohiria yonamisyamayamacahi ni país ca chama bo rë? Chama jayaca xo jato nohiria yonariati ra.
\v 43 Anoma tsi xo toa ja yonamiscanaina; jama, ma tocayamaxëti xo ra. Mato yonati pari ixëti quiha mato ó ca chama manëcatsai cato ra.
\v 44 Yonati manëxëti xo toa nohiria bo rëquëninicatsai cato. Jatiroha cabo ja mëbixëti xo iquia.
\v 45 Jabi mai qui ë joyamaniquë mëbihacati; jama, nohiria bo mëbiti nori. Jabi ëmë aquia nohiria bo bax nati, jocha quima huëstima ca nohiria paquëmaxëna —nëa tsi Jesu nëcaniquë.
\s1 Bëco ca inish ca Bartimeo Jesú jënimahuanina
\r Mateo 20.29-34; Lucas 18.35-43
\p 
\v 46 Jatsi Jericó icanai ca yaca qui ja cahëcaniquë. Ja riquicano tsi quiha nohiria misco banahuahi iniquë. Jabi toá tsi naa bahi tapaí quiha Bartimeo, naa Timoteo baquë tsaho iniquë. Bëco ja ini quiha. Toa xo tsi parata bënahi ja iniquë.
\v 47 Jesu tarabihai ca nicaquí tsi quiha quënatsijahuaniquë. Joi pistiamá tsi quiha,
\p —Ea shinahuë, David yamaba Baquë Jesú —i ja niquë.
\p 
\v 48 Jatsi raahatsi nohiria bá huaniquë;
\p —Pasihuë, pasihuë —iquiina.
\p Jatsi oquë tsi ja quëna-quënaniquë:
\p —Ea shinahuë ra, David yamaba Baquë́ —iquiina.
\p 
\v 49 Jatsi Jesu niiniquë. Niihax,
\p —“Nëri johuë” i ja qui cana —i Jesu niquë.
\p Japi bëco ca ja quënacaniquë.
\p —Chamahuë. Joihuë. Mia quënahi quiha —i ja qui jaca niquë.
\p 
\v 50 Jatsi jahuë capa, naa pocho jasca ca niahax ja niiniquë. Niihax Jesu qui ja joniquë.
\p 
\v 51 Jatsi,
\p —¿Jënahuaxëhi ni ëa mi bax na? —i ja qui Jesu niquë.
\p —Taistëquëcasquia ra —i bëco ca niquë.
\p 
\v 52 Jatsi,
\p —Cata. E qui mi chitimihai iqui tsi taisqui mia iquia —i ja qui Jesu niquë.
\p Jatsi taistapiniquë joni. Bahí tsi Jesu ja banahuaniquë jaa ri.
\c 11
\s1 Jerusalén qui Jesu jiconina
\r Mateo 21.1-11; Lucas 19.28-40; Juan 12.12-19
\p 
\v 1 Jabi yaca Betfagé, yaca Betania, naa Maca Olivo Ya quiri bëso ca yaca qui cahëpama tsi quiha rëquë dos ca rabëti bo Jesú raaniquë. Jerusalén basima ja icani quiha.
\v 2 Jato raanox pari tsi quiha jato ja yobaniquë:
\p —Mato bëbo ca yaca qui jicocana. Jicoxo tsi nëxë ca burro jisxëqui mato, naa masohuahama ca burro quiha. Mëriscana. Mërisxo tsi nëri bëcahuë.
\v 3 Jabi, “¿Jënixo tsi burro mëriscanai?” i tsohuëcara pi no tsi “Bicatsi quiha Ibo. Tanaxo tsi jahari raaxëhi quiha” i jato qui cana —nëa tsi Jesu nëcaniquë jato raanox pari.
\p 
\v 4 Jatsi ja bocaniquë. Bahí ca burro baquë ja tsayacaniquë. Nëxë ja ini quiha.
\v 5 Mërisjahuacano tsi quiha,
\p —¿Jënahuariaqui burro baquë mëriscanai ra? —i jato qui toá ca nii ca joni bo niquë.
\p 
\v 6 Jatsi joni bo ja quëbicaniquë, naa Jesú yoaha ca jato yoahahi na. Jatsi,
\p —Bicahuë —i jaca niquë.
\p 
\v 7 Jatsi Jesu qui burro baquë ja bëcaniquë. Bëxo tsi quiha jato sahuëti bo ja capohuëcaniquë. Jatsi burro cacha Jesu tsahoniquë.
\v 8 Jatsi rëquë huëstima ca nohiria bá jato sahuëti bo poohabonaniquë bahí no. Jasca, mëshi bo nohiria huëtsa bá quëësacaniquë bahí tsi poohaxëna. \fig Jerusalén qui Jesu jicohaina|src="cn01784b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="MRK 11.8"\fig*
\p 
\v 9 Jatsi quënatsi rëquë bocanaibo, ja cho bocanaibo, tihi cabá huaniquë.
\q1 —Joihuacana ra.
\q1 Shomahuahaca ca tsi xo naa Iboba janë́ tsi johai cato ra.
\q1 
\v 10 Shomahuaha ca tsi xo noba chama David yamaba chamá tsi johai cato.
\q1 Jia tsi ja yonano ra.
\q1 Naipá cabá ocahuano ra —nëa tsi nohiria bo nëcaniquë.
\p 
\v 11 Toca tsi Jerusalén qui Jesu jiconiquë. Jicohax templo qui Jesu caniquë, naa jodioba arati xobo-xoboria. Jicohax ja nëjo nëjo taisniquë, jatiroha ca tsayahi na. Tsayahax Betania qui ja caniquë, jahuë rabëti bo ya. Caniquë bari ra.
\s1 Bimiyamahai ca higuera jihui Jesú yoshihuanina
\r Mateo 21.18-19
\p 
\v 12 Huëaquë Betania ax riquiquiria tsi quiha paxnahi Jesu iniquë.
\v 13 Bacapama tsi quiha ori pistia ca higuera bimi jihui ja jisniquë. Japi jihui qui ja caniquë bimi mëraxëna. Yama quiha, jahuë pëhi roha. Jari bimitiya ma quiha.
\v 14 Jatsi higuera jihui qui ja chaniniquë pa:
\p —Mi bimi pitëquëpistiayamariaxëhi quiha nohiria ra —i jihui quiina.
\p Jabi ja yoaha ca jahuë rabëti bá nicaniquë.
\s1 Templó ca iniacanaibo Jesú jabamanina
\r Mateo 21.12-17; Lucas 19.45-48; Juan 2.13-22
\p 
\v 15 Jerusalén qui cahëhax templo, naa jodioba arati xobo-xoboria qui Jesu jiconiquë. Jicoxo tsi quiha cacha toá ca iniacanaibo raatsijahuaniquë. Raaquí tsi quiha parata rarinamacanaiba mesa bo ja narabaniquë. Boto iniacanaibo tsahoti bo ja pacanamaniquë.
\v 16 Jasca, nohiria, naa jato jahuëmishni bo iniacascanaibo ja quëtianiquë, templo qui ja nacoyamacano iquish na. Tihi tsi ja ani quiha ra.
\v 17 Jaquirëquë jato ja tiisimaniquë. Tiisimahi tsi,
\p —“Bëhoxti xobo quënahacati xo noho xobo” ¿iyamayamahi ni Quënëhacanish cabo? “Nëá tsi bëhoxti quiha jatiroha ca país ca nohiria” ii quiha. Jama, yomacanaiba iti Dios xobo manëmaqui mato pë —i jato qui Jesu niquë.
\p 
\v 18 Jatsi Jesú aca ca nicaxo tsi quiha jodioba chama bo Jesu qui tsamicasniquë, naa arati iboba chama bo, jato yoba yoacanaibo. Ja qui caxa ja icani quiha. Japi Jesu ati quinia mëratsijahuacaniquë. Jama, jari ja qui ja tsamiyamacani quiha nohiria misco iqui na. Jari nohiria qui jia Jesú tiisimahai ca ini quiha.
\p 
\v 19 Jatsi quiha yata yaca Jesú jisbayaniquë jahuë rabëti bo ya.
\s1 Janonish ca higuera jihui
\r Mateo 21.20-22
\p 
\v 20 Huëaquë tsi bahí tsi bohopama tsi quiha higuera jihui ja jiscaniquë. Jano tëquë ja ini quiha; bëso yama.
\v 21 Jatsi Jesú yoahitaha ca Pedró shinaniquë. Shinahax,
\p —Tsayapa, Maestró. Naquë mi yoshihuahitaha ca jihui ra —i Jesu qui Pedro niquë.
\p 
\v 22 Jatsi quiha Jesú jato quëbiniquë:
\p —Dios qui chitimicana.
\v 23 Mato parayamaquia. Dios qui chitimiyoipihi tsi “Tsëquëhuë. Ia qui mimë niahacahuë” iti mëtsaxëqui mato naa maca qui. Chitimiyoipimano tsi mato qui nicaxëhi quiha macana ra. Ocapixëhi quiha mi yoahana iquia.
\v 24 Ja tsi xo toa “Chitimiyoicana” mato qui iquia, ma bëhoxquë no. Chitimiquí tsi ma bënahai ca bixëqui mato.
\v 25-26 Jasca, Dios qui bëhoxquí tsi mia ocahuahai cató aca ca shina-bënocana. Jato qui caxayamacana. Tocapimano tsi mato jocha shina-bënoxëqui Dios ri. Mato qui caxayamaxëqui —nëa tsi quiha jahuë rabëti bo qui Jesu nëcaniquë.
\s1 Jesu qui jodioba chama bo caxanina
\r Mateo 21.23-37; Lucas 20.1-8
\p 
\v 27 Jatsi Jerusalén qui Jesu bacaniquë jahuë rabëti bo ya. Templo, naa jodioba arati xobo-xoboriá tsi ja cono tsi quiha ja qui jodioba chama bo bëcaniquë. Bëcani quiha arati iboba chama bo, jato yoba tiisimacanaibo, jodioba yosibo.
\v 28 Bëxo tsi quiha Jesu ja nicacaniquë:
\p —¿Tsohuë mi qui chama aquitaha, templo quima iniacanaibo cacha niati pë? —i ja qui jaca niquë.
\p 
\v 29 Jatsi Jesú jato quëbiniquë:
\p —Mato nicapariquia ëa ri. Ea pi ma quëbino tsi ë qui toca ca ati chama anish ca mato yoaxëquia.
\v 30 Jatsi, ¿tsohuë Juan yamabo qui chama ani, jahuë yonoco ati? ¿Dios ni? ¿Joni ni? Toa nicaquia ra —i jato qui ja niquë.
\p 
\v 31 Jatsi joi i-ibëquitsijacaniquë:
\p —¿Jënihi ni noa rë? “Dios” ipinono tsi jatsi “¿jënixo tsi Juan yamabo ma chahahuayamani?” i noqui xëhi quiha pë.
\v 32 Jasca, ¿jëniriahax raca “Joni” i nona rë? —nëa tsi quiha ja nëcacaniquë chaninahi na.
\p Nohiria bo qui ja raquëcani quiha, “Dios Chani yoati ibo Juan yamabo iniquë nori” i nohiria bo ni quëshpi na.
\v 33 Ja quëshpi tsi,
\p —Cahëyamaqui noa —i jaca niquë quëbihi na.
\p Jatsi,
\p —E qui toca ca ati chama anish ca mato yoayamaxëquia ëa ri —i jato qui Jesu niquë.
\c 12
\s1 Dios Baquë jodiobá niahaina
\r Mateo 21.33-46; Lucas 20.9-19
\p 
\v 1 Jatsi chani huëtsa Jesú yoaniquë nohiria bo tiisimaquí na. Jahuë jabi quiha. Ja nëcaniquë:
\p —Huai joní ani quiha. Axo tsi quiha toa xo uva icanai ca bimi ja bananiquë. Jaquirëquë tëamë ca panë ja aniquë. Jatsi maxaxá ca trapichi ja aniquë jënëria ati. Axo tsi quiha jaha bësoti xobo ja aniquë, naa torre icanai cato.
\p ‘Jaquirëquë joni huëtsa bo qui jahuë huai ja aquëniquë bimi xatë quëshpi na. Aquëhax jahari xobo qui ja cani quiha.
\v 2 Jatsi tësatiya tsëquëquë tsi quiha jahuë huaí ca yonococanaibo qui jahuë yonati ja raaniquë, jahuë bimi xatë biti.
\v 3 Jama, ja cahëquë tsi quiha jahuë yonati qui ja tsamicaniquë pë. Tsamixo jahuë yonati ja sëtiacani quiha. Sëtiahax tsi quiha mëquëya jahari jahuë yonati ja raacani quiha.
\v 4 Jatsi quiha yonati huëtsa ibobá raaniquë. Ja macoaishacani quiha. Bërabihuajahuacani quiha.
\v 5 Jatsi yonati huëtsa ibobá raaniquë. Toa yonati ja acaniquë. Huëtsa bo ja raaquë tsi quiha ja jascapijahua-caniquë. Huësti huësti ca ja sëtiacani quiha. Huëtsa bo ja tëpascani quiha.
\p 
\v 6 ‘Jama, tobi ini quiha huësti ca raahama cato ra; naa jahuë baquë yoi quiha. Jabi jahuë baquë ja noini quiha. Jarohari tsi jahuë baquë yoi ja raaniquë, “Noho baquë yoi roha chahahuacaxëcani quiha tonia” iquiina.
\v 7 Jama, jahuë baquë jisi tsi, “Iboba baquë tsi xo naa johaina ra. ¿Ai canomani? Axo jahuë huai ibohuaxëqui noa ra” i jaca ni quiha.
\v 8 Jatsi baquë qui tsamixo tsi quiha ja acaniquë. Axo tsi quiha jahuë huai cacha jahuë yora ja niacaniquë.
\p 
\v 9 Jatsi toa cabo Jesú nicaniquë:
\p —¿Jënahuaxëhi ni huai ibo, joxo na? Joxo tsi ¿toa joni bo ayamayamaxëhi ni? Axo tsi joni huëtsa bo qui jahuë huai aquëxëhi quiha ra.
\v 10 Jasca, ¿Quënëhacanish cabo ó ca ma jisyamani naa yoati na?
\q1 “Oquënaxëhi quiha yosibá niaha ca Maxaxa ra” ii quiha.
\q2 “Oquë-oquëria ca tsi manëxëhi quiha ra.
\q1 
\v 11 Diós aca ca tsi xo naa ra.
\q2 Noqui jia tsi xo toa ja acana” ii quiha.
\p 
\v 12 Jatsi jodioba chama bo Jesu qui tsamicasniquë, jato yoati tsi ja chaniha ca ja cahëcani quëshpi na. Jama, ja qui tsami-yamajacani quiha nohiria bo qui raquëhi na. Japi jisbaya tsi quiha ja bocaniquë.
\s1 Impuesto bo gobierno qui acaina
\r Mateo 22.15-22; Lucas 20.20-26
\p 
\v 13 Jatsi jodioba chama bo, Herodes yonati bo, tihi cabo Jesu qui raahacaniquë tanamati. Yoi ca chani ja amacasjahuacani quiha ja qui tsamixëna.
\v 14 Jatsi Jesu qui ja bëcaniquë. Chanipama tsi,
\p —Shina jiaxëni ca parayamahai ca joni tsi xo mia ra, maestró. Nohiria shinahai ca chahahuayamaqui mia. Mi qui jaharisi tsi xo nohiria tëquëta. Dios quiniá roha tsi tiisimaqui mia. Japi mia nicacasqui noa: ¿Romanoba chama-chamaria qui impuesto bo no ati ni, naa noqui jodiobo? ¿Mi qui jia ni? ¿Jato qui axëhi ni noa ra? —i Jesu qui jaca niquë.
\p 
\v 15 Jama, ja paracascanai ca Jesú jisniquë. Ja tsi xo toa,
\p —¿Jënixo tsi ëa tanamacascanai ra? Parata nëri bëcahuë. Jiscasquia —i jato qui Jesu niquë.
\p 
\v 16 Jatsi parata ja qui ja bëcaniquë. Jatsi,
\p —¿Tsohuë bëmana jaya ni naa parata ra? ¿Tsohuë ni naa janë ibo? —i jato qui Jesu niquë.
\p Jatsi,
\p —Romanoba chama-chamaria bá-na —i jaca niquë.
\p 
\v 17 Jatsi,
\p —Romanoba chama-chamaria quiha jahuë jahuë bo tëquë acana. Jasca, Dios qui jahuë jahuë yoi bo acahuë —nëa tsi jato qui Jesu nëcaniquë.
\p Jatsi ja ratëcaniquë ja yoahaha ca qui.
\s1 Bësotëquëxëhi ni nohiria
\r Mateo 22.23-33; Lucas 20.27-40
\p 
\v 18 Jatsi Jesu jisi bocaniquë maxo huëtsa, naa saduceobo icanai cabo. “Yama tsi xo nohiria bësotëquëhaina” inish ca maxo tsi xo naa. Jesu ja nicacaniquë jato ri tanamaxëna.
\p 
\v 19 —“Baquë bo yama pi joni rësono tsi jahuë ahui bixëti xo jahuë noma. Bixo tsi jahuë rëquëmë bax xocobo ja saihuati xo” i Moisés yamabo ni quiha, Maestró.
\v 20 Jabi seis ca noma bo jayapaoni quiha joni. Jatsi ahui naa joní bini quiha. Jatsi xocobo yama tsi ja rësoniquë.
\v 21 Ja rësoquë tsi quiha jahuë xachacató jahuë ahui biniquë, ja bax xocobo saihuaxëna. Xocobo saihuahaxma tsi quiha ja rësoniquë jaa ri. Jaquirëquë jahuë nomá jahuë ahui biniquë. Xocobo saihuahaxma tsi quiha ja rësoniquë jaa ri. Toca tsi jahuë noma bo tëquëtá toa jasca ca yoxa bini quiha ahui iti.
\v 22 Xocobo ja saihuapistia-yamariacani quiha. Jarohari tsi quiha rësoniquë yoxa ri.
\v 23 Jabi nohiria bo bësotëquëno tsi ¿tsohuë ahui ixëhi ni naa yoxa sa? Siete ca bënë ja jayani quiha bësoquí na —nëa tsi quiha Jesu qui ja nëcacaniquë tanamaxëna.
\p 
\v 24 Jatsi Jesú jato quëbiniquë:
\p —Janyama xo mato ra, Quënëhacanish cabo, Dios chama, tihi cabo ma cahëyamahai iqui na.
\v 25 Jabi Diós nohiria bësotëquëmano tsi naipá ca ángel bo jascaria icaxëcani quiha ra. Ahui bo, bënë bo biyamacaxëcani quiha.
\v 26 Jabi, “Bësotëquëxëhi quiha nohiria” ¿ii ni mato sa? ¿Tonia Moisés yamabá quënëni ca ma jisyama-yamani, naa mëshohai ca pëtoro ó ca Dios chanini ca ja quënëni cató no? Toca tsi Moisés qui Diós yoani ca quënëhacani quiha. “Abraham, Isaac, Jacob, tihi cabá-na Dios ca ëa xo naa ra” i Moisés qui Dios ni quiha. Jabi “Abraham yamabo, Isaac yamabo, Jacob yamabo,” iyama ja ni quiha ra, bëso jaca nori iqui na.
\v 27 Bësoyama caba Dios ma xo Dios ra; jama, bësocanaibá-na nori. Japi janyama xo mato ra —nëa tsi Jesu nëcaniquë jato qui, naa “Bësotëquëyamaxëhi quiha nohiria” inish cabo qui.
\s1 Oquë-oquëria ca yoba
\r Mateo 22.34-40
\p 
\v 28 Jabi toá tsi nii quiha maestro iniquë, naa jodioba yoba tiisimahai cato. Saduceobo ya Jesu chaninahai ca ja nicani quiha. Jasca, jia tsi quiha Jesú jato quëbini ca ja jisni quiha. Jisi tsi Jesu qui ja joniquë jaa ri nicaxëna.
\p —¿Jëni ca yoba ni toa oquë-oquëria cato sa? —i Jesu qui ja niquë.
\p 
\v 29 Jatsi quiha Jesú quëbiniquë:
\p —Oquëria ca yoba tsi xo naa, Israel cabá. Nicacahuë. Huësti roha tsi xo nohiria ba Ibo ra. Noba Ibo Dios qui no arahai ca tsi xo naa ra.
\v 30 Jatsi mato joiti tëquëta, mato shina tëquëta, mato coshi tëquëta, tihi cabá tsi mato Ibo Dios yoi ma noiti xo iquia.
\v 31 Jaquirëquë tobi yoba huëtsa. Oquëria ca yoba tsi xo toa ri. Mabë xatë yoi bo ri ma noixëti xo, mamë ma noihai jascaria. Jabi yama tsi xo toa naa dos ca yoba bo oquë cato ra —nëa tsi Jesu nëcaniquë naa maestro qui.
\p 
\v 32 Jatsi jodioba yoba tiisimahai ca joní quëbiniquë:
\p —Jia tsi xo toa mi yoahana, Maestró. Jabija tsi xo. Yama tsi xo Dios huëtsa. Ja huësti ca tsi xo Ibo Dios ra.
\v 33 Jabija ra. Jasca, noba joiti tëquëta, noba shina tëquëta, noba coshi tëquëta, tihi cabá tsi Dios no noixëti xo. Jasca, nobë xatë yoi bo no noixëti xo ra. Yama tsi xo toa dos ca yoba oquë cato ra. Dios qui altar ó ca yohina no mëshahaina, jahuëcara huëtsa Dios qui no acaina, tihi cabo no acai ca oquë-oquëria tsi xo toa dos ca yoba no nicahaina ra —nëa tsi quiha Jesu qui joni nëcaniquë.
\p 
\v 34 Jabi jia tsi toa joní quëbini quiha. Nicahax,
\p —Diós otohai ca qui basima xo mia ra —i ja qui Jesu niquë.
\p Jaquirëquë nohiria bá Jesu nicacasyamani quiha ja qui raquëquí na.
\s1 David yamaba Ibo Cristo inina
\r Mateo 22.41-46; Lucas 20.41-44
\p 
\v 35 Arati xobo-xoboria xo tsi tiisimapama tsi quiha Jesú nohiria bo nicaniquë:
\p —“David yamaba chahitaxocobo ixëti xo Cristo, naa nohiria bo Xabahamati Ibo” ¿iyamayamacahi ni mato yoba tiisimacanaibo? ¿Jënihax tocacahi ni?
\v 36 Espíritu Santo rëamëhax tsi ¿David yamabo nëcayamayamani?
\q1 “‘Mia oquëhuanox pari tsi,
\q2 jariapari mia pasomaha cabo bëboxëquia,
\q1 jato mi yonano’ i noho Ibo qui Dios ni quiha”
\m i David yamabo niquë pa.
\v 37 “Noho Ibo” ¿i David yamayamani, Cristo yoati tsi chanihi na? Jatsi, ¿jënahuahax jari jahuë chahitaxocobo ii ni ra? —nëa tsi Jesu nëcaniquë, jato nicahi na.
\s1 Yoba tiisimacanaibo pasomaha Jesú chaninina
\r Mateo 23.1-36; Lucas 20.45-47
\p Jabi tobi quiha huëstima ca nohiria mani iniquë. Ja rani-ranicaniquë jahuë chani nicahax na.
\v 38 Jatsi jato tiisimatsi quiha Jesú huaniquë:
\p —Yoba tiisimacanaibo qui quiniacaxëcahuë. Jato sahuëti tëtëcaria bá tsi bohocani quiha pë. Nohiria bá jato joihua-joihuahai ca ó pasocani quiha ra nicaxëna.
\v 39 Jasca, nohiria bo oriquibëquinapino tsi oquë-oquëria ca tsahoti bicascani quiha pë. Jasca, catiti xobo qui jicoxo tsi oquë ca tsahoti bo ó quëëcani quiha tsahoti.
\v 40 Jabi naa joni bo tsi xo toa imanish ca yoxa ba jahuë bo yomacanaibo ra. Yomapama tsi quiha nohiria bo bësojó tsi bëhox-bëhoxcani quiha pa. Anomariaxëhi quiha Diós jato copixëhaina iquia —nëa tsi quiha Jesu nëcaniquë.
\s1 Imanish cató Dios qui ofrenda anina
\r Lucas 21.1-4
\p 
\v 41 Arati xobo tahë tsi tsahopama tsi quiha nohiria bá jato parata caja qui nanëhai ca Jesú tsaya-tsayaniquë. Bëcaniquë huëstima ca rico cabo jato parata axëna. Huëstima ca parata ja acani quiha.
\v 42 Jatsi, noitiria ca bënë imanish ca yoxa joniquë. Joxo tsi quiha dos ca parata roha ja nanëniquë. Copiriama ca parata quiha.
\v 43 Tsayaxo tsi quiha jahuë rabëti bo Jesú quënaniquë.
\p —Anomaria tsi xo toa bënë imanish ca yoxá Dios qui acana ra. Jatiroha ca nohiria huëtsa bá aca ca oquë tsi xo toa ja acana iquia.
\v 44 Jari huëstima ca parata jayacaxo tëxë bo ra. Narisyamacani quiha. Pistia roha tsi xo toa ja acanana ra. Jama xo naa yoxa iquia. Jatiroha ca ja aquë ra; naa jahuë oriquiti copiti parata quiha —i jahuë rabëti bo qui Jesu niquë.
\c 13
\s1 “Quëyohacaxëhi quiha jodioba arati xobo” i Jesu nina
\r Mateo 24.1-2; Lucas 21.5-6
\p 
\v 1 Arati xobo Jesú jisbayano tsi quiha ja qui chaniniquë jahuë rabëti huësti cato.
\p —Tsayapa, Maestró. Anomaria tsi xo naa xobo ra. Tio bo ria ca jahuë maxax bo ra —i Jesu qui ja niquë.
\p 
\v 2 Jatsi quiha Jesú quëbiniquë:
\p —Jabija. Naa xobo tsayacahuë. Jaboqui nii xo. Jama, potas-hacaxëhi quiha naa arati xobo tëquë iquia. Matsami matsami niiyamaxëhi quiha huësti ca maxaxa ra —i Jesu niquë.
\s1 Xaba rëso jisti bo
\r Mateo 24.3-14; Lucas 21.7-19
\p 
\v 3 Jabi arati xobo bëbo, naa Maca Olivo Ya tsi tsaho quiha Jesu iniquë. Tsahojano tsi quiha Pedro, Jacobo, Juan, Andrés, tihi cabo ja qui bëcaniquë nicaxëna. Yama nohiria huëtsa jato bëta ini quiha. Jatsi,
\p 
\v 4 —¿Jënixo tsi ocapixëhi ni naa mi yoahana rë? ¿Jahuë jisti jisxëhi ni noa ra naa mi yoaha ca jatiyoxëquë no? —i Jesu qui jaca niquë.
\p Jatsi Jesu nëcaniquë:
\p 
\v 5 —Quiniacaxëcahuë, ma parahacayamano.
\v 6 Jariapari tsi noho janë́ tsi bëcaxëcani quiha huëstima ca mahitsa ca joni bo. “Ea ti tsi xo nohiria bo Xabahamati Ibo-iboria” i nohiria bo qui xëhi quiha. Toca tsi huëstima ca nohiria bo paracaxëcani quiha.
\p 
\v 7 ‘Jatsi país ca nianahaina, nohiria huëtsa iquinacatsai ca chani, tihi cabo nicaxëqui mato. Nicahi tsi raquëyamacana. Ocapixëhi quiha ra. Jama, jari tobi jahuë rëso.
\v 8 Jariapari huësti ca país pasomaha nianaxëhi quiha país huëtsa. Jasca, chama huëtsa pasomaha iquinaxëhi quiha chama huëtsa. Jasca, toatiyá tsi biniacaxëcani quiha huëstima ca nohiria. Jasca, huëstima ití tsi yajoriaxëhi quiha mai. Jariapari ca nohiria bá tënëhai ca chitahë roha tsi xo naa ra, naa yoxá jahuë baquë comahai ca pahë jascaria.
\p 
\v 9 ‘Quiniacaxëcahuë. Mato qui tsamicaxëcani quiha. Tsamixo tsi policía bo qui mato bocaxëcani quiha quësoxëna. Jasca, catiti xobo xo tsi mato rashacaxëcani quiha. Jasca, chama bo, presidente bo, tihi cabo bësojó tsi niixëqui mato ëa iqui na. Jatsi jato qui Dios Chani ma yoaxëti xo.
\v 10 Jasca, jatiroha ca nohiria qui yoahacaxëti xo Dios Chani.
\v 11 Jabi mato qui ja tsamipicano tsi policía bo qui mato ja bocano tsi jato qui ma chanixëti ca yoati shina-huëjënayamacana. Toa xaba tsëquëno tsi mato qui acacaxëhi quiha ma yoaxëti cato. Toatiyá tsi ma chanino tsi ma yoaxëti ca mato jismaxëhi quiha Espíritu Santo. Chaniyamayoixëqui mato, Espíritu Santo nori.
\v 12 Toatiyá tsi jahuë xatë yoi mëaxëhi quiha huëtsa, namëhacati. Jasca, jahuë baquë pasomaha ixëhi quiha jahëpa ri. Jasca, jato nabo qui caxacaxëcani quiha xocobo ri. Caxaquí tsi chama bo qui jato nabo mëacaxëcani quiha namëhacati.
\v 13 Ea tahëhax tsi mato qui caxayocaxëcani quiha nohiria tëquëta. Jama, xabahamahacaxëhi quiha jahuë rëso qui tënëyocanaibo, naa bamayamacanaibo.
\s1 Quëras ca joni jisiquixëhaina
\r Mateo 24.15-28; Lucas 21.20-24
\p 
\v 14 ‘Toatiyá tsi “Quëyomisxëniria ca Yoixëni ca” jisxëqui mato ra. Raquëria ixëhi quiha. Jahuë iti ma tsi niixëhi quiha ra. Jabi naa quënëni ca tsayahai cató cahëno ra. Jatsi naa quëyomisxëniria ca yoixëni ca jisi tsi maca bo qui jabaxëti xo jodioba maí cabo.
\v 15 Toatiyá tsi jato xobo qui jicoyamaxëti xo cacha ca nohiria, jato jahuë bo bixëna. Ja bamayamacano.
\v 16 Jasca, jahuë sahuëti biti bacayamaxëti xo huaí ca yonocohai cato. Ja bamayamano.
\v 17 Toatiyá tsi noitixëhi quiha tohoya ca yoxa bo, baquë pistia jaya cabo ri.
\v 18 Dios qui bëhoxcana, matsitiyá tsi ja ocapiyamano iquish na.
\v 19 Toatiyá tsi anomariaxëhi quiha nohiria bá tënëhaina. Mai nëhohuahacaquë rohari tsi nëca tsi tënëpistia-yamariani quiha nohiria bo ra. Toatiyá tsi oquë-oquëriaxëhi quiha naa nohiria bá tënë-tënëhaina.
\v 20 Jama, toa tënëti xaba Diós chitiayamarohapino tsi yama ca nohiria xabahamahacaquë aquë ra. Ja bini ca nohiria bo bax toa xaba chitiaxëhi quiha.
\p 
\v 21 ‘Jatsi, “Nëá xo noqui Xabahamati Ibo; toá xo ra” i tsohuëcara pi no tsi jato chahahuayamacahuë.
\v 22 Toatiyá tsi jisiquixëhi quiha mahitsa ca xabahamati ibo bo. Jasca, jisiquixëhi quiha naa mahitsa ca Dios Chani yoacanaibo ri. Jisiquixo tsi jisti bo acaxëcani quiha pë, Diós bini ca nohiria bo paraxëna tonia.
\v 23 Jatsi quiniacaxëcahuë. Mato yobapariquia ja tocapinox pari.
\s1 Nohiria Baquë johaina
\r Mateo 24.29-31; Lucas 21.25-28
\p 
\v 24 ‘Toatiyá tsi anomariaxëhi quiha toa tënëtiya ra.
\q1 Jaquirëquë tsëmonaxëhi quiha bari.
\q2 Jasca, huahuayamaxëhi quiha oxë.
\q1 
\v 25 Nai ax paquëxëhi quiha naipá ca huishti bo.
\q2 Yajohacaxëhi quiha mai.
\v 26 Jatsi naipá tsi jisiquixëquia, naa Nohiria Baquë ë nori cato. Jatsi araxëhi quiha maí ca nohiria bo tëquëta.
\v 27 Jatsi jatiroha ca quinia, naa norte, sur, este, oeste, tihi cabo qui noho ángel bo raaxëquia. Toca tsi noho nohiria bo, naa ë bini cabo catiacaxëcani quiha.
\s1 Higuera jihui jisti
\r Mateo 24.32-35; Lucas 21.29-33
\p 
\v 28 ‘Jabi higuera jihui jisti tsayano. Ja botoxno tsi basima xo oitiya; toa cahëqui mato.
\v 29 Jascaria, ë yoaha ca jahuë bo ocapiti chitahëno tsi basima tsi xo toa ë johaina. Joti basima xo ëa.
\v 30 Mato parayamaquia. Jabi naatiyá ca bësocanaibo rësonox pari no tsi ocapixëhi quiha ë yoahana.
\v 31 Huinocaxëhi quiha naipa, mai, tihi cabo; jama, huinoca-pistiayamariaxëhi quiha noho Chani ra.
\s1 Jesu johai ca hora
\r Mateo 24.36-44
\p 
\v 32 ‘Jabi yama tsi xo toa ë joxëhai ca bari hora cahëhaina. Cahëyamahi quiha naipá ca ángel bo. Cahëyamaquia ëa ri, naa Dios Baquë ë nori cato. Toa bari cahëhi quiha Jahëpa Dios roha.
\v 33 Jatsi quiniacaxëcahuë. Jaha bësocahuë, mato ibo johai ca bari ma cahëyamahai quëshpi na.
\v 34 Jabi joni jahuë xobo qui bacahai ca jascaria tsi xo toa ë joxëhaina. Canox pari tsi ¿jahuë xobo ó jahuë yonati bo bësomayamaxëhi ni ibo? Jato yonoco yoi jaya xo jahuë yonati bo tëquëta. Jasca, “Caiti ó bësohuë” i quiha jahuë caiti obëso ca qui.
\v 35 Jatsi jaha ma bësocano mato ri. Ibo johai ca hora cahëyamaqui mato ra. ¿Jënino cara ca tia? ¿Yata ma ni? ¿Baquichá ma ni? ¿Huëatisca ma ni? ¿Baquishmari ma ni?
\v 36 Mëri joquí tsi ma oxahai ca ja jisyamano ra.
\v 37 Ja tsi xo toa jaha bësocahuë. Bacaxëquia ra. “Jaha bësocahuë” iquia jatiroha cabo qui —nëa tsi Jesu nëcaniquë.
\c 14
\s1 Jesu qui ja tsamicascanina
\r Mateo 26.1-5; Lucas 22.1-2; Juan 11.45-53
\p 
\v 1 Jabi tsëquëpaimaria tsi quiha jodioba pascua fiesta iniquë. Dos ca bari roha quiha. Toatiyá tsi levadura yama ca mapari ja pi-pipaocani quiha.
\v 2 Jasca, toatiyá tsi jodioba chama bo, naa arati ibo bo, yoba tiisimacanaibo, tihi cabo Jesu qui tsamicasniquë. Tsamicasquí tsi quinia mërahi quiha ja icaniquë Jesu ati.
\p —Fiesta no tsi achanoma quiha. Caxanaxëhi quiha yacatá ca nohiria rë —i quiha jaca niquë.
\s1 Perojomé tsi Jesu tahë ashimahacanina
\r Mateo 26.6-13; Juan 12.1-8
\p 
\v 3 Jabi yaca Betaniá tsi quiha Jesu iniquë, naa bonohuaxëni ca Simón xobó no. Oriquijano tsi quiha ja qui yoxa joniquë. Alabastro icanai ca botella ja jayani quiha. Copixëniria ca perojome rëamë ca botella quiha. Joxo tsi quiha ja tërëjëhaniquë. Tërëjëhaxo tsi quiha Jesu mapo qui ja japaniquë.
\v 4 Jatsi caxanatsi toá ca nohiria huësti huësti ca niquë tsayahax na.
\p —Jishopë.
\v 5 Iniarohapixo tsi huëstima ca parata, naa huësti ca año sueldo no jayaquë aquë rë. Toa parata noitiria cabo qui ati no iquë aquë rë —i jaca niquë.
\p Jatsi yoxa ja raahacaniquë.
\p 
\v 6 Jatsi,
\p —Iquë. Iquë. ¿Jëniriaxo tsi raahacanai? Jiaria tsi xo toa ë bax ja acana ra.
\v 7 Mato bëtarohaxëhi quiha noitiria cabo. Xaba huëstima ca jayaxo mato jato mëbiti. Jama, ëa ti tsi xo toa mato bëta naamayamahai cato.
\v 8 Ati mëtsa iqui ca naa yoxá aquë ra. Jiaria quiha. Noho mapo qui perojome ja japaquë ra, maihuahacati noho yora shomahuaxëna.
\v 9 Mato parayamaquia. Ja aca ca nicacaxëcani quiha maí ca nohiria bo tëquëta, naa Dios Chani yoahacahai cato xo na. Jatsi naa yoxa shinaxëhi quiha nohiria bo, nicaxo na —nëa tsi quiha Jesu nëcaniquë.
\s1 Chama bo qui Jesu Judás mëacasnina
\r Mateo 26.14-16; Lucas 22.3-6
\p 
\v 10 Jatsi arati iboba chama bo qui Judas Iscariote, naa Jesu rabëti bo ó ca huësti ca caniquë jato qui mëacatsi na.
\v 11 Jahuë chani nicahax ranitsi quiha jodioba chama bo ni quiha. Jatsi,
\p —Jesu quëshpi tsi parata mi qui axëqui noa —i jaca niquë ja qui.
\p Japi jato qui Jesu mëati xaba jia ca mëratsi quiha Judás huaniquë.
\s1 Pascua fiesta
\r Mateo 26.17-29; Lucas 22.7-23; Juan 13.21-30; 1 Corintios 11.23-26
\p 
\v 12 Jabi pascua fiesta chitahë ca barí tsi quiha oveja bo tëpas-hacani quiha nohiria ba jocha quëshpi na. Jatsi,
\p —¿Jahuënia tsi caxëhi ni noa sa, mi bax pascua oriquiti shomahuaxëna piti? —i quiha Jesu qui jahuë rabëti bo niquë.
\p 
\v 13 Jatsi jahuë rabëti bo dos ca ja raaniquë. Raahax,
\p —Yaca qui bocata. Toá xo joni, naa chomó ca jënë bëhai cato. Toa xo tsi bëchaxëqui mato. Toa joni banahuacana.
\v 14 Banahuahax jahuënia cara ca qui ja jicohai ca xobo ibo qui chanicana. “Noqui raaquë Maestro ra, naa shomahuahaca ca naquëtë jisti. ¿Jahuënia tsi pascua oriquiti pixëhi ni?” i ja qui cana.
\v 15 Jatsi pistiama ca naquëtë mato jismaxëhi quiha xobo ibo, naa mesa, tsahoti bo, tihi cabo jaya cato. Toa xo tsi pascua oriquiti shomahuacana no bax na —i quiha jato qui Jesu niquë.
\p 
\v 16 Jatsi quiha dos ca rabëti bo bocaniquë yaca qui. Ocapiriajani quiha Jesú yoani jascaria. Xobo qui cahëxo tsi quiha oriquiti ja shomahuacaniquë.
\p 
\v 17 Jatsi quiha yata, bari caquë tsi quiha xobo qui Jesu cahëniquë jahuë rabëti bo ya.
\v 18 Jatsi ja oriquicano tsi quiha Jesu chaniniquë:
\p —Mato parayamaquia ra. Jodioba chama bo qui ëa mëaxëhi quiha mato ó ca huësti cato rë, naa ë bëta oriquihai cato —i Jesu niquë.
\p 
\v 19 Jatsi quiha ja cohuënacaniquë:
\p —¿Tsohuë cara ni toa sa? Ea ma xo toa ra —i jaca niquë huësti huësti.
\p 
\v 20 Jatsi quiha Jesú quëbiniquë:
\p —E bëtaxo tsi pitëxti ca jahuë mapari nacomabëquihai ca tsi xo toa ëa mëaxëhai cato rë.
\v 21 Rësoxëquia Quënëhacanish cabá yoani jascaria, naa Nohiria Baquë ë nori cato. Jama, noiti-noitixëhi quiha toa jodioba chama bo qui ëa mëahai ca joni ra. Ja coyamarohapino tsi shoma ja iquë aquë rë —i Jesu niquë. \fig Jaroha ca shiati Jesú nëtohaina|src="cn01803b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="MRK 14.21"\fig*
\s1 Jaroha ca shiati Jesú nëtohaina
\p 
\v 22 Jatsi oriquipama tsi quiha mapari Jesú biniquë. Bixo tsi quiha “Gracias” i Dios qui ja niquë ja quëshpi na. Bëquëx-xo tsi quiha jato qui mapari ja aniquë piti. Jatsi,
\p —Bicahuë. Picahuë. Noho yora tsi xo naa —i jato qui ja niquë.
\p 
\v 23 Jatsi quiha copá ca jënë ja biniquë. Bichi tsi “Gracias” i ja niquë. Jatsi jënë jato qui ja aniquë. Ja ayocaniquë.
\p 
\v 24 Jatsi shiati acax Jesu nëcaniquë:
\p —Noho jimi tsi xo naa. Dios xabahamati quinia jisti quiha. Huëstima cabo bax japahacaxëhi quiha, jocha masati.
\v 25 Mato parayamaquia. Naa uva bimi jënë mato bëta xo atëquëpistiayamariaxëquia nëa mai xo na, Diós yonahai cato xo tsi ë atëquëxëquë rohari mana xo na, quinia paxá no —i quiha jato qui Jesu niquë.
\s1 “Jochati tanamahacaxëqui mato” i Jesu nina
\r Mateo 26.30-35; Lucas 22.31-34; Juan 13.36-38
\p 
\v 26 Jatsi quiha ja quëquëcaniquë. Quëquëhax jisbaya tsi Maca Olivo Ya qui ja bocaniquë.
\v 27 Jatsi quiha jato qui Jesu chaniniquë:
\p —Naa baquichá tsi ë quima casoxëqui mato rë, “Oveja obëso ca tëpasmaxëquia. Pacanamahacaxëhi quiha jahuë oveja” i Quënëhacanish cabo ó tsi Dios ni quëshpi na.
\v 28 Jama, bësotëquëhax mato bëbo Galilea qui caxëquia —i quiha jahuë rabëti bo qui Jesu niquë.
\p 
\v 29 Jatsi Pedró quëbiniquë:
\p —Mi qui tëxë bo casomitsa. Jama, mi quima casopistiayamariahai ca ëa xo naa ra —iquiina.
\p 
\v 30 Jatsi Pedro qui Jesu chaniniquë:
\p —Mia parayamaquia. Naa baquichá tsi patiari bënë quëonox pari no tsi tres tsi “Jesu cahëyamaquia” ixëqui mia rë —iquiina.
\p 
\v 31 Jatsi quiha Pedro yosananiquë:
\p —Mi bëta rësorohapihi tsi mi quima casopistiayamariaxëquia ra —i Pedro niquë.
\p Jatsi toca tsi chaniniquë Jesu rabëti bo tëquëta.
\s1 Getsemaní tsi Jesu bëhoxnina
\r Mateo 26.36-46; Lucas 22.39-46
\p 
\v 32 Jatsi Getsemaní icanai ca qui Jesu caniquë jahuë rabëti bo ya. Cahax,
\p —Nëá tsahocana. Bëhoxpariquia ra —i quiha jato qui ja niquë.
\p 
\v 33 Jatsi Pedro, Jacobo, Juan, tihi cabo ja boniquë ja bëtati. Jatsi Jesu cohuënaniquë. Raquëtsijani quiha. Jatsi,
\p 
\v 34 —Cohuëria ca ëa xo naa ra. Rësoti basima xo ëa rë. E bëta bësocana ra —i quiha jato qui ja niquë.
\p 
\v 35 Jatsi ori pistia cahax Jesu mëniniquë. Mënihax bëhoxtsijaniquë. Jatsi jahëpa ja nica-nicaniquë tënëtiya ja nacomahacayamano iquish na.
\p 
\v 36 —Ea shinahuë, noho jahëpa-jahëpariá. Mi qui jia pi no tsi naa johai ca tënëtiya mëbihuë ra, ë tënëyamano. Jama, jaha ë quëëhai ca mi ayamano; jama, mi shina roha mi ano ra —i quiha Jesu niquë bëhoxhi na.
\p 
\v 37 Bëhohax tsi quiha jahuë rabëti bo qui ja bacaniquë. Bacaxo tsi ja oxacanai ca ja jisniquë.
\p —¿Huësti ca hora roha ë bëta bësoti mëtsa ma ni mato rë?
\v 38 Bësocana. Bëhoxcana, jochati ma tanamahacayamano ra. Jabija, mato shina tsi xo toa bëhoxcatsaina; jama, mato yora tsi xo chamayama rë —i quiha Pedro qui Jesu niquë.
\p 
\v 39 Jatsi Jesu catëquëniquë bëhox-xëna. Jasca ca ja bëhoxtëquëniquë.
\v 40 Bëhoxhax ja bacatëquëniquë. Oxahi ja icani ca ja jisniquë. Coshiria ini quiha jato bëro. Bërabiquí tsi quëbiti ja cahëyamacani quiha.
\v 41 Tres tsi quiha toca tsi Jesu bacani quiha. Jarohari tsi,
\p —¿Jari oxacanai? ¿Jari joi-joicanai? Iquë ra. Tsëquëquë hora ra. Jochahuaxëni cabo qui mëahacapaimaria xo ëa, naa Nohiria Baquë ë nori cato.
\v 42 Joicana. ¿Canomani? Tsayacapa. Nëbi johi quiha ëa mëacatsai ca joni rë —i quiha Jesu niquë.
\s1 Jesu qui soldado bo tsaminina
\r Mateo 26.47-56; Lucas 22.47-53; Juan 18.2-11
\p 
\v 43 Jabi jari ja chanino tsi quiha Judas jotapiniquë rë, naa doce ó ca huësti cato. Ja bëta bëcaniquë nohiria misco. Saipi bo, jihui bo, tihi cabo ja jayacani quiha. Jabi arati ibo bo, nohiria yosibo, tihi cabo ini quiha toa jato raati ibo bo ra. Jabi ja raahacacani quiha Jesu qui tsamiti.
\v 44 Jatsi quiha nohiria misco qui jisti Judás aniquë:
\p —Ma bicatsai ca joni tatsoxëquia ra. Toa joni qui tsamicaxëcahuë. Bicahuë. Jia tsi jaha bësocahuë —i jato qui Judas ni quiha.
\p 
\v 45 Jatsi jato iti qui cahëhax Jesu qui Judas catapiniquë. Cahax,
\p —“Maestró” i Jesu qui ja niquë joihuahi na.
\p Joihuaxo tsi quiha Jesu ja tatsoniquë.
\v 46 Jatsi Jesu qui joni bo tsaminiquë. Tsamixo tsi quiha achajahuacaniquë.
\v 47 Jatsi quiha Jesu tapaí ca nii cató jahuë saipi tsëcaniquë. Tsëcaxo tsi quiha arati ibo-iboria yonati ja paxtianiquë, Jesu paxamacatsi na.
\v 48 Jatsi quiha jato qui Jesu chaniniquë:
\p —¿Saipi bo, tëpasti jihui bo, tihi cabo jaya ni mato pa? ¿Yomaxëni ca bichii jascaria ëa bichi bëcanai pa?
\v 49 Jatiroha ca bari mato bëta ë i-ipaoyamëquë ra arati xobó no. Toa xo tsi ë tiisimano tsi ¿jënihax tsi ë qui ma tsamiyamayamëta sa? Jama, jatihuahacaxëti xo Quënëhacanish cabo ra —nëa tsi quiha jato qui Jesu nëcaniquë.
\p 
\v 50 Jatsi jahuë rabëti bo jabayoniquë raquëhi na.
\v 51 Jama, huësti ca shinapayó Jesu banahuaniquë. Sabana rabanaca ja ini quiha. Jatsi toa joni qui soldado bo tsamicasniquë jaa ri.
\v 52 Ja tsamicaquë tsi quiha toa joni paxaniquë. Jahuë sabana niabëria tsi ja jabaniquë ra. Tsoboco ja ini quiha rë.
\s1 Jodioba chama bo bësojó Jesu niinina
\r Mateo 26.57-68; Lucas 22.54-55, 63-71; Juan 18.12-14, 19-24
\p 
\v 53 Jesu qui tsamixo tsi quiha jato arati ibo ba chama-chamaria qui Jesu ja bocaniquë. Toá tsi quiha mani iniquë jodioba yoba cahëxëni cabo.
\v 54 Jabi basi quiha Pedró banahuaniquë. Banahuahax chama xobo huënë qui ja jiconiquë. Jicohax tsi quiha toá ca jaha bësohai ca soldado bo ya ja tsahoniquë, chihí tsi yohohi na.
\p 
\v 55 Jatsi quiha arati ibo bo, nohiria yosibo, tihi cabá Jesu namëcasniquë pë. Ja tsi xo toa ja pasomaha ca joi ja mëracaniquë. Yama a ra.
\v 56 Jama, tobi huëstima ca quiahuacanaibo iniquë, ja qui quësocatsi na. Jamëri jamëri ini quiha ja quiacanaina. Jaharisi iyamani quiha ja quësocanaina ra.
\v 57 Jarohapa tsi quiha dos ca joni niiniquë, mahitsa ja qui quësoxëna. Quiaxëni ca joni bo ja icani quiha.
\p 
\v 58 —“Dios arati xobo potasti mëtsa xo ëa ra” i ja ni quiha. Jatsi, “Jaquirëquë tres barí tsi naa xobo nimatëquëxëquia” i ja ni quiha pë —i yosibo qui toa joni bo niquë, Jesu qui quësohi na.
\p 
\v 59 Jama, jamëri jamëri naa dos ca joni bo quësohai iniquë ra. Jaharisi ma quiha ra.
\p 
\v 60 Jatsi quiha jato arati ibo ba chama-chamaria joiniquë naxërëquë no. Niixo tsi quiha Jesu ja nicaniquë:
\p —¿Jënihai naa jahuë bo yoati na? Mia pasomaha chanicani quiha ra. ¿Jato quëbicasyamahai? —i Jesu qui ja niquë.
\p 
\v 61 Pasi quiha Jesu iniquë. Ja quëbiyamaniquë. Jatsi quiha arati ibo ba chama-chamaria nicatëquëniquë:
\p —¿Dios Baquë, naa johai ca Xabahamati Ibo ni mia ra? —i ja niquë.
\p 
\v 62 Jatsi,
\p —Jaahuë. Ja tsi xo ëa ra —i Jesu niquë—. Jasca, chamaxëni ca Dios mënëcayá ca Nohiria Baquë tsaho ca jisxëqui mia ra. Naipá ca tsëmo bá tsi ja joxëhai ca jisxëqui mia ra —i ja qui Jesu niquë.
\p 
\v 63 Jatsi arati ibo ba chamá jahuë sahuëti jaraxaniquë caxaquí na. Jatsi,
\p —¿Jëniriaxo tsi ja qui quësocanaibo huëtsa bo no nicacasna?
\v 64 Dios ja ocahuaha ca ma nicaquë ra. ¿Jabija ma ni? —i jato qui ja niquë.
\p Jatsi Jesu qui ja quësocaniquë, “Ja nati xo” iquiina.
\p 
\v 65 Jatsi quiha Jesu bëmana qui coshotsijacaniquë. Jatsi ja bëmapacaniquë raití no. Bëmapaxo tsi ja bëtoxacaniquë. Tocahi tsi,
\p —¿Tsohuë mia aca? —i ja qui jaca niquë pë.
\p Jatsi toá ca soldado bá sëtianiquë jato ri, bixo na.
\s1 Jesu quima Pedro bësonina
\r Mateo 26.69-75; Lucas 22.56-62; Juan 18.15-18, 25-29
\p 
\v 66 Xobo huënënë́ tsi Pedro niino tsi arati ibo chama yonati jiconiquë. Xotaco ja ini quiha.
\v 67 Jicoxo tsi quiha toá ca chihi tapaí ca Pedro yohohai ca ja jisniquë. Bëis-hax tsi quiha,
\p —Naa Nazarét ca Jesu ya mi iquë mia ri —i Pedro qui ja niquë.
\p 
\v 68 Jatsi,
\p —Jesu cahëyamahai ca ëa xo naa ra. E joma toa mi yoahana ra —i Pedro niquë quiahi na.
\p 
\v 69 Quiahax tsi quiha Pedro huajaniquë caiti qui. Jatsi quiha xotacó Pedro tsayatëquëniquë, cacha ja niiquë no. Tsayahax,
\p —Jesu rabëti tsi xo toa ra —i ja niquë toá ca mani cabo qui.
\p 
\v 70 Jatsi,
\p —Jahuë rabëti ma xo ëa ra —i Pedro tëquëniquë.
\p Jaquirëquë,
\p —Jabija. Jahuë rabëti xo mia. Galileá ca joni xo mia ra. Jamëri tsi xo mi joi, mi chanihaina ra —i Pedro qui toá ca manicanaibo niquë.
\p 
\v 71 Jatsi ocahuatsi Pedró huaniquë rë.
\p —Jabija ca pi ë chaniyamarohano tsi Diós ëa copino ra. Parayamahai ca ëa xo naa. ¿Tsohuë cara ni naa Jesu imahaina ra? Toa joni cahëyamaquia —nëa tsi Pedro nëcaniquë rë.
\p 
\v 72 Tocajaquë tsi quiha ja qui Jesú yoaha ca ja shinaniquë, naa “Dos tsi patiari quëonox pari no tsi tres tsi ‘Jesu cahëyamaquia’ ixëqui mia” i ja qui Jesu nina. Shinahax aratsijaniquë.
\c 15
\s1 Pilato qui Jesu ja bocanina
\r Mateo 27.1-2, 11-14; Lucas 23.1-5; Juan 18.28-38
\p 
\v 1 Huëatiscano tsi quiha arati ibo ba chama bo, nohiria yosibo, tihi cabo chaninaniquë Jesu namëti yoati na. Jesu ja namëcasni quiha pë. Jatsi quiha Jesu ja nëxacaniquë. Nëxaxo tsi quiha Pilato qui ja mëpijahuacaniquë. Mëpixo tsi quiha ja qui ja mëacaniquë namëhacati.
\p 
\v 2 Jatsi,
\p —¿Jodioba rey, naa chama-chamaria ni mia ra? —i quiha ja qui Pilato niquë nicahi na.
\p Jatsi quiha,
\p —Jaahuë —i Jesu niquë.
\p 
\v 3 Jabi anomaria ini quiha toa ja qui arati ibo ba chama bo quësohaina ra. Mahitsa quiha.
\v 4 Jatsi quiha Pilató nicatëquëniquë.
\p —¿Tsayahai? Huëstima tsi xo toa mi qui ja quësocanaina rë. ¿Jato quëbiyamahai pa? —iquiina.
\p 
\v 5 Quëbicasyamaniquë Jesu ra. Jatsi quiha Pilato ratëniquë.
\s1 Nati Jesu copihacanina
\r Mateo 27.15-31; Lucas 23.13-25; Juan 18.38; 19.16
\p 
\v 6 Jabi jatiroha ca jodioba fiesta no tsi quiha huësti ca presó ca joni Pilató paquëmapaoni quiha nohiria bo qui. Jahuë jabi quiha.
\v 7 Toatiyá tsi cárcel xara gobierno pasomaha ca joni ini quiha, naa Barrabás icanai cato. Iquinaquí tsi nohiria naa joní ani quiha.
\v 8 Jatsi quiha nohiria bëcaniquë Pilato nicaxëna, huësti ca ja paquëmano iquish na, naa ja a-apaoni jascaria.
\v 9 Jatsi quiha,
\p —¿Mato jodioba rey paquëmaxëhi ni ëa ra? —i quiha jato qui ja niquë.
\p 
\v 10 Jabi Jesu qui yosaria arati ibo bo iqui ca Pilató cahëniquë. Ja iqui tsi ja qui Jesu mëahacani quiha acacati.
\v 11 Jato qui yoi ini quiha toa Jesu ja paquëmacatsaina. Jatsi quiha arati ibo bá nohiria bo raji-rajimaniquë, Barrabás Pilató paquëmano iquish na.
\v 12 Jatsi quiha Pilató nicatëquëniquë:
\p —¿Jënahuaxëhi ni ëa ra Jesu qui, naa jodioba chama-chamaria ma quënahana? —iquiina.
\p 
\v 13 Jatsi quiha nohiria bá quënarianiquë:
\p —Cruzó tsi tooxahuë —iquiina.
\p 
\v 14 —¿Jëni ni ra? ¿Jahuë yoi ca ja aca? —i quiha jato qui Pilato niquë.
\p Jama, jato joi ja choshacaniquë quëbihi na:
\p —Cruzó tsi ja tooxahacati xo ra —iquiina.
\p 
\v 15 Jatsi quiha Pilató Barrabás paquëmaniquë nohiria bo ranihuacatsi na. Paquëmanox pari tsi quiha soldado bo qui pari Jesu ja mëaniquë rispichí tsi rashahacati. Jaquirëquë jodioba chama bo qui Jesu ja mëaniquë cruzó tsi tooxahacati.
\p 
\v 16 Jatsi quiha palació ca huënë qui soldado bá Jesu boniquë. Boxo tsi quiha soldado bo tëquë ja quënacaniquë catiti.
\v 17 Jatsi quiha sahuëti shini, naa chama-chamaria sahuëti ja sahuëmacaniquë. Jasca, nishi moxá tsi quiha chaha ja quëcocaniquë ja bax na. Quëcoxo tsi quiha ja mahuajahuacaniquë pë.
\v 18 Jaquirëquë joihuatsijahuacaniquë:
\p —¡Viva, viva, jodioba chama-chamariá! —iquiina.
\p 
\v 19 Jatsi quiha ja bësojó tsi ja mënicaniquë ja qui araxëna. Mahitsa quiha.
\v 20 Mahuaxo tsi quiha sahuëti shini ja tsobocaniquë. Jatsi jahuë sahuëti yoi sahuëmaxo tsi quiha Jesu ja bocaniquë tori, cruzó tsi tooxaxëna.
\s1 Cruzó tsi Jesu tooxahacanina
\r Mateo 27.32-44; Lucas 23.26-43; Juan 19.17-27
\p 
\v 21 Riquipama tsi quiha tarabihai ca joni, naa Cirene mai ax jonish ca ja bicaniquë Jesu cruz papiti. Simón jahuë janë ini quiha, naa Alejandro, Rufo, tihi caba jahëpa.
\v 22 Jatsi quiha Gólgota, naa Mapo Xao Ya icanai ca qui Jesu ja bocaniquë.
\v 23 Toa xo tsi vino, naa tiahui ya roihacanish ca jënë Jesu qui ja amacaniquë ati. Ayamajahuaniquë.
\v 24 Jaquirëquë quiha cruzó tsi Jesu ja tooxacaniquë. Tooxaxo tsi quiha jahuë sahuëti bo ja oquëxnacaniquë i-ihaicató no. Toca tsi jahuë jahuëcara ca biti ja cahëcani quiha.
\p 
\v 25 Baquishmari mënata barí tsi quiha Jesu tooxahacaniquë cruzó no.
\v 26 Jasca, papi ó tsi ja qui ja quësocani ca quënëhacaniquë; naa “Jodioba chama-chamaria” iquiina.
\v 27 Jasca, ja bëta dos ca yomaxëni ca joni bo tooxahacaniquë jato ri; naa huësti ca jahuë mënëcayá no, huëtsa ja mëxojó no.
\v 28 Nëca tsi quiha Quënëhacanish cabo jatihuahacani quiha, naa “Yoixëni cabo ya ja tocahacanina” ini cato.
\p 
\v 29-30 Jatsi Jesu mahuatsi quiha tarabinish cabá huaniquë. Bëquë-bëquëhi tsi quiha ja nëcacaniquë.
\p —Jë, jë. Mimë xabahamahuë arati xobo potascatsai cató. ¿Tres barí tsi toa xobo nimati mëtsa ni mia pa? Cruz ax botëhuë iqui noa —nëa tsi ja nëcacaniquë pë.
\p 
\v 31 Jascaria tsi quiha arati ibo ba chama bo, yoba tiisimacanaibo, tihi cabá Jesu mahuaniquë jato ri:
\p —Huëtsa bo ja xabahamaquë; jama, jamë xabahamati mëtsama xo ra.
\v 32 ¿Noba Israél ca rey, naa noba chama-chamaria ni naa joni pa? Jaboqui cruz ax ja botëno ra. Jatsi chahahuaxëqui noa ra noqui ri —i quiha jaca niquë jato ri chaninahi na.
\p Jasca, toá ca ja bëta tooxahacanish cabá Jesu ocahuaniquë jato ri. Anoma jato chani ini quiha.
\s1 Jesu nanina
\r Mateo 27.45-56; Lucas 23.44-49; Juan 19.28-30
\p 
\v 33 Matoroco barí tsi quiha tsëmonaniquë toa mai. Naama ini quiha ja tsëmonina. Tres hora bo quiha.
\v 34 Jarohapa tsi a las tres quiha joi pistiamá tsi Jesú quënaniquë:
\p —Eloi, Eloi, ¿lama sabactani?, naa “¿Jënixo tsi ëa mi jisbëriaha rë, noho Diós, noho Diós?” —i ja niquë.
\p 
\v 35 Toca tsi ja quënaquë tsi quiha,
\p —Elías, naa Dios Chani yoanish ca quënahi quiha tonia —i jaca niquë toá ca niicanaibo.
\p 
\v 36 Jatsi quiha huësti ca joni jabaniquë jahuë chani nicahax na, tatë bixëna. Bixo tsi quiha vinagre, naa jënë nopi ca qui ja moosaniquë. Moosaxo tsi rëbiquirihaxo tsi Jesu ja amaniquë. Amapama tsi,
\p —No manaparino ra. No tsayano. Elías jomitsa botëmaxëna —i quiha ja niquë.
\p 
\v 37 Jatsi quiha Jesú quënatëquëniquë. Quënahax ja naniquë.
\v 38 Ja naquë tsi quiha arati xobó ca rotamë ca quëbëti raiti jaxcahacaniquë. Mana ax napata quiri ja jaxcahacani quiha.
\v 39 Jasca, Jesu bësojó ca nii ca soldado ratëniquë ja nahai ca jisi na. Ratëhax,
\p —Jabija xo ra. Dios Baquë yoi naa joni iquë rë —i ja niquë.
\p 
\v 40 Jasca, basima xo tsi Jesu nahai ca yoxa bá tsayaniquë. Toá tsi quiha mani iniquë María Magdalena; Jacobo, José, tihi caba jahëhua María; Salomé.
\v 41 Jabi naa yoxa bá Jesu banahuapaoni quiha mëbicasquí na, naa Galilea maí tsi ja iniquë no. Jasca, toá tsi quiha mani iniquë yoxa huëtsa bo ri, naa Jerusalén qui ja bëta bëcanish cabo.
\s1 Jesu maihuahacanina
\r Mateo 27.57-61; Lucas 23.50-56; Juan 19.38-42
\p 
\v 42 Capaima quiha bari iniquë. Chitahë-paimaria ini quiha jato joiti bari.
\v 43 Ja tsi xo toa mëri tsi José, naa Arimateá ca racanish ca Pilato qui caniquë Jesu yora baaxëna, maihuacatsi na. Cahi tsi ja raquëniquë. Jabi jodiobá chama shinajiaxëni ca naa joni ini quiha. Jasca, Diós nohiria bo otoxëhai ca ó pasohai ca ja ini quiha jaa ri.
\v 44 Jatsi quiha jahuë yora José baaquë tsi quiha Pilato ratëniquë ja rësoha quëscahua-yamahi na. Jatsi capitán quiha ja quënaniquë.
\p —¿Japa Jesu; ja rësoha? —i quiha ja qui ja niquë.
\p 
\v 45 Ja rësoha ca nicaxo tsi quiha José qui jahuë yora ja mëaniquë maihuahacati.
\v 46 Jatsi quiha sabana jiaxëni ca José copiniquë. Jahuë yora botëmaxo tsi quiha ja yaboniquë sabana paxá no. Yaboxo tsi quiha maiquini ó tsi jahuë yora ja jananiquë. Huëyohaca ca quini paxa ca quiha. Janaxo tsi quiha maxax chahitaxëni caiti qui ja taraniquë japaxëna.
\v 47 Jabi ja bëta iniquë María Magdalena, José jahëhua María, tihi cabo. Tihi cabá Jesu maihuahaca ca iti jisni quiha.
\c 16
\s1 Jesu bësotëquënina
\r Mateo 28.1-10; Lucas 24.1-12; Juan 20.1-10
\p 
\v 1 Jodioba bari huinocaquë tsi quiha María Magdalena, Jacobo jahëhua María, Salomé, tihi cabá perojome copiniquë, Jesu yora chëxaxëna.
\v 2 Copihax tsi quiha domingo baquishmarí tsi quiha Jesu mai jisi ja bocaniquë.
\v 3 Capama tsi,
\p —Jishopë. ¿Tsohuë ni toa no bax caití ca maxax bahama tarahaina rë? —i jaca niquë chaninahi na.
\p Pistiama ca maxax ja ini quiha.
\v 4 Jama, taisquí tsi nii ca maxax ja jiscaniquë ra. Bahama ja tarahacani quiha. \fig Jesu yora ja yopacanaina|src="cn01850b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="MRK 16.4"\fig*
\v 5 Jatsi quiha maiquini qui ja jicocaniquë. Jicoxo tsi quiha jato mënëcayá ca joni shinapayo ja jiscaniquë. Sahuëti joxo sahuë tsaho ja ini quiha. Jatsi, ja raquëcaniquë tsayahax na.
\v 6 Jatsi quiha yoxa bo qui ángel chaniniquë.
\p —Raquëyamacana. Jesu, naa tooxahacahitahax ca ma mërahai cahëquia. Yama xo ra. Ja bësotëquëquë ra, ja yoani jascaria. Nëri bëcahuë. Ja janahacahitaha ca ma tsayaparino.
\v 7 Jatsi bocahuë. Pedro, jahuë rabëti bo, tihi cabo yoata. “Mato bëbo Galilea qui cahi quiha. Toa xo tsi Jesu jisxëqui mato, mato ja yoani jascaria” icana jato qui —nëa tsi quiha yoxa bo qui ángel nëcaniquë.
\p 
\v 8 Jatsi jisbaya tsi quiha ja jabariacaniquë raquëhi na. Ja mëmë-mëmëcanacaniquë. Raquëhi tsi huëtsa bo qui ja chaniyamacani quiha.
\s1 María Magdalena qui Jesu jisiquinina
\r Juan 20.11-18
\p 
\v 9 Semana jariapari ca barí tsi quiha Jesu bësotëquëniquë. Bësotëquëhax tsi María Magdalena, naa siete ca yoshi jayapaonish ca qui ja jisiquiniquë. Jahá ca yoshi bo ja niani quiha.
\v 10 Jatsi quiha María jisbayaniquë Jesu rabëti bo yoaxëna. Arahi jahuë rabëti bo ini quiha, cohuëhi na.
\v 11 Ja yoaha ca nicaxo tsi ja chahahuayamacaniquë pë. Jatsi,
\p —Bëso xo Jesu ra. Jisquë ëa ra —i jato qui ja niquë.
\s1 Dos ca banahuacanaibo qui Jesu jisiquinina
\r Lucas 24.13-35
\p 
\v 12 Jaquirëquë quiha jamëri ca quiniá tsi dos ca xabachá ca cocohai ca joni bo qui Jesu jisiquiniquë. Jato xobo qui cahi ja icani quiha.
\v 13 Jato xobo qui cahëxo tsi quiha Jesu ja jiscana ca ja yoacaniquë huëtsa bo qui. Jama, ja yoacana ca ja chahahuayamacaniquë pë.
\s1 Jahuë rabëti bo qui Jesu jisiquinina
\r Mateo 28.16-20; Lucas 24.36-49; Juan 20.19-23
\p 
\v 14 Jarohari tsi quiha jahuë rabëti yoi bo oriquino tsi jato qui Jesu jisiquiniquë. Jisiquixo tsi quiha jato ja raahaniquë. Quëstoria ca chahahuatimaxëni ja icani quiha. Jabi bëso Jesu iqui ca jisnish cabo ja chahahuayamacani quiha pë jato chani nicaxo na.
\v 15 Jatsi quiha,
\p —Jatiroha ca mai qui bocana, jatiroha ca nohiria qui chani jia ca yoati —i jato qui ja niquë—.
\v 16 Xabahamahacaxëti xo tsohuëcara ca ë qui chitimihai ca ashimahacahax cato. Jama, quësohacaxëti xo tsohuëcara ca ë qui chitimiyamahai cato ra.
\v 17 Jasca, jisti bo ati mëtsaxëhi quiha ë qui chitimicanaibo. Jariapari tsi yoshi bo natsëcacaxëcani quiha noho janë́ no. Jatsi joi jamëri bo chanicaxëcani quiha.
\v 18 Jasca, jato mëquënë́ tsi quiha rono bo topiti mëtsacaxëcani quiha. Jasca, veneno pi ahi tsi rësoyamacaxëcani quiha. Jasca, iquicanaibo jënimahuacaxëcani quiha jato ó tsi mëquë ja janacanai cató no. Tihi ca ati mëtsaxëhi quiha ë qui chitimicanaibo ra —nëa tsi quiha jato qui Jesu nëcaniquë.
\s1 Nai qui Jesu tërohacanina
\r Lucas 24.50-53
\p 
\v 19 Jaquirëquë jahuë rabëti bo qui chanixo tsi quiha nai qui Jesu tërohacaniquë. Jatsi quiha jahuë iti Jesú bini quiha Dios mënëcayá no.
\v 20 Jatsi quiha jahuë rabëti bá jisbayaniquë, jatiroha cato xo tsi Dios Chani jia ca yoaxëna. Jato bëta xo tsi Ibo Dios yonocobëquini quiha. Dios Chani ja yoacaquë tsi quiha anomaria ca jisti bo acacaniquë. Toca tsi jahuë Chani Diós oquëhuani quiha ra.
