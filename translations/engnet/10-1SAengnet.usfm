\p
\v 32  \w Then|strong="H4428"\w* \w Samuel|strong="H8050"\w* said, “\w Bring|strong="H5066"\w* \w me|strong="H5066"\w* \w King|strong="H4428"\w* Agag \w of|strong="H4428"\w* \w the|strong="H5493"\w* \w Amalekites|strong="H6002"\w*.” \w So|strong="H5066"\w* Agag \w came|strong="H5066"\w* \w to|strong="H3212"\w* \w him|strong="H4428"\w* trembling, thinking \w to|strong="H3212"\w* himself, “Surely \w death|strong="H4194"\w* \w is|strong="H4428"\w* \w bitter|strong="H4751"\w*!”  
