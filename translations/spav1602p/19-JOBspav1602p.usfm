\v 15 \w O|strong="H3068"\w* \w con|strong="H5973"\w* \w los|strong="H1992"\w* \w príncipes|strong="H8269"\w* \w que|strong="H1992"\w* poseían \w el|strong="H5973"\w* \w oro|strong="H2091"\w*, \w que|strong="H1992"\w* \w henchían|strong="H4390"\w* \w sus|strong="H1992"\w* \w casas|strong="H1004"\w* \w de|strong="H5973"\w* \w plata|strong="H3701"\w*.
