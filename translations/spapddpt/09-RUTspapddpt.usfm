\mt1 Rut  
\c 1  
\s1 La familia de Elimelec en Moab  
\p
\v 1 \w Aconteció|strong="H1961"\w* \w en|strong="H3212"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w cuando|strong="H3117"\w* gobernaban \w los|strong="H1121"\w* \w jueces|strong="H8199"\w*, \w que|strong="H1931"\w* \w hubo|strong="H1961"\w* una hambruna \w en|strong="H3212"\w* \w la|strong="H1931"\w* tierra. Un \w hombre|strong="H1121"\w* \w de|strong="H1121"\w* Belén \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* \w fue|strong="H1961"\w* \w a|strong="H3068"\w* vivir temporalmente \w en|strong="H3212"\w* \w los|strong="H1121"\w* \w campos|strong="H7704"\w* \w de|strong="H1121"\w* \w Moab|strong="H4124"\w* con \w su|strong="H1931"\w* esposa y \w sus|strong="H1931"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*.  
\v 2 \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* aquel varón \w era|strong="H1961"\w* Elimelec, \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* su esposa, \w Noemí|strong="H5281"\w*, y \w los|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* sus \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w* Mahlón y Quelión, efrateos \w de|strong="H1121"\w* Belén \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*. Así \w que|strong="H1121"\w* llegaron \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w campos|strong="H7704"\w* \w de|strong="H1121"\w* \w Moab|strong="H4124"\w* y permanecieron \w allí|strong="H8033"\w*.   
\p
\v 3 Elimelec, esposo \w de|strong="H1121"\w* \w Noemí|strong="H5281"\w*, \w murió|strong="H4191"\w*. \w Y|strong="H3068"\w* \add Noemí\add* \w quedó|strong="H7604"\w* sola con \w sus|strong="H1931"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*,  
\v 4 \w los|strong="H3427"\w* cuales \w tomaron|strong="H5375"\w* esposas moabitas, cuyos \w nombres|strong="H8034"\w* eran Orfa y Rut. Vivieron \w allí|strong="H8033"\w* como \w diez|strong="H6235"\w* \w años|strong="H8141"\w*.  
\v 5 Después \w murieron|strong="H4191"\w* \w también|strong="H1571"\w* Mahlón \w y|strong="H1571"\w* Quelión. \add Noemí\add* \w quedó|strong="H7604"\w* sin sus \w dos|strong="H8147"\w* \w hijos|strong="H3206"\w* \w y|strong="H1571"\w* sin su esposo.   
\p
\v 6 \w Entonces|strong="H3588"\w* \w ella|strong="H1931"\w* \w se|strong="H1931"\w* \w levantó|strong="H6965"\w* \w con|strong="H3588"\w* \w sus|strong="H1931"\w* \w nueras|strong="H3618"\w* \w para|strong="H3588"\w* regresar \w de|strong="H3588"\w* \w los|strong="H1931"\w* \w campos|strong="H7704"\w* \w de|strong="H3588"\w* \w Moab|strong="H4124"\w*, \w porque|strong="H3588"\w* \w oyó|strong="H8085"\w* \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w había|strong="H3588"\w* visitado \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w para|strong="H3588"\w* darles \w pan|strong="H3899"\w*.  
\v 7 \w Así|strong="H5973"\w* \w que|strong="H4480"\w* \w ella|strong="H8033"\w* \w salió|strong="H3318"\w* \w del|strong="H4480"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* \w estaba|strong="H1961"\w*, y \w con|strong="H5973"\w* sus \w dos|strong="H8147"\w* \w nueras|strong="H3618"\w* tomaron \w camino|strong="H1870"\w* \w para|strong="H4480"\w* regresar \w a|strong="H3068"\w* la tierra \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*.   
\p
\v 8 \w Noemí|strong="H5281"\w* dijo \w a|strong="H3068"\w* sus \w dos|strong="H8147"\w* \w nueras|strong="H3618"\w*: \w Anden|strong="H3212"\w*, regresen, cada una \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H5973"\w* su madre. ¡Tenga \nd \+w Yavé|strong="H3068"\+w*\nd* \w misericordia|strong="H2617"\w* \w de|strong="H5973"\w* ustedes \w como|strong="H5973"\w* ustedes la tuvieron \w con|strong="H5973"\w* \w los|strong="H5973"\w* difuntos y \w conmigo|strong="H5973"\w*!  
\v 9 \nd \+w Yavé|strong="H3068"\+w*\nd* les conceda \w a|strong="H3068"\w* cada \w una|strong="H4672"\w* que \w hallen|strong="H4672"\w* \w descanso|strong="H4496"\w* en la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* su esposo.  
\p Luego las \w besó|strong="H5401"\w*. Ellas \w alzaron|strong="H5375"\w* sus \w voces|strong="H6963"\w*, \w lloraron|strong="H1058"\w*  
\v 10 \w y|strong="H3588"\w* le decían: Nosotras \w volveremos|strong="H7725"\w* \w contigo|strong="H5971"\w* \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w*.   
\p
\v 11 Pero \w Noemí|strong="H5281"\w* dijo: Regresen, \w hijas|strong="H1323"\w* mías. ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* deben \w ir|strong="H3212"\w* \w conmigo|strong="H5973"\w*? ¿Tengo yo \w aún|strong="H5750"\w* \w hijos|strong="H1121"\w* \w en|strong="H5973"\w* mis \w entrañas|strong="H4578"\w* \w para|strong="H1961"\w* \w que|strong="H4100"\w* \w sean|strong="H1961"\w* sus esposos?  
\v 12 Regresen, \w hijas|strong="H1323"\w* mías, \w vayan|strong="H3212"\w*. \w Pues|strong="H3588"\w* envejecí \w como|strong="H3588"\w* \w para|strong="H3588"\w* \w tener|strong="H1961"\w* esposo, \w y|strong="H1571"\w* \w aunque|strong="H3588"\w* dijera: \w Tengo|strong="H3426"\w* \w esperanza|strong="H8615"\w*, \w y|strong="H1571"\w* \w esta|strong="H1961"\w* \w noche|strong="H3915"\w* \w estuviera|strong="H3426"\w* \w con|strong="H3588"\w* \w mi|strong="H1961"\w* esposo, \w e|strong="H3068"\w* incluso diera \w a|strong="H3068"\w* luz \w hijos|strong="H1121"\w*,  
\v 13 ¿\w los|strong="H1961"\w* esperarían \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* crezcan? ¿\w Se|strong="H1961"\w* retraerían \w por|strong="H3588"\w* \w ellos|strong="H3027"\w* sin tomar esposo? \w No|strong="H3588"\w*, \w hijas|strong="H1323"\w* mías. Tengo \w mayor|strong="H3588"\w* \w amargura|strong="H4843"\w* \w que|strong="H3588"\w* ustedes, \w pues|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w se|strong="H1961"\w* levantó \w contra|strong="H4480"\w* \w mí|strong="H1431"\w*.   
\p
\v 14 Entonces ellas \w alzaron|strong="H5375"\w* su \w voz|strong="H6963"\w* y \w lloraron|strong="H1058"\w* \w otra|strong="H5750"\w* vez. Orfa \w besó|strong="H5401"\w* \w a|strong="H3068"\w* su \w suegra|strong="H2545"\w*, pero Rut siguió \w apegada|strong="H1692"\w* \w a|strong="H3068"\w* ella.   
\p
\v 15 Noemí dijo: \w Mira|strong="H2009"\w*, tu cuñada regresó \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w* y \w a|strong="H3068"\w* sus \tl ʼelohim\tl*. Regresa detrás \w de|strong="H5971"\w* tu cuñada.   
\p
\v 16 Rut \w respondió|strong="H7725"\w*: \w No|strong="H3588"\w* \w me|strong="H3588"\w* ruegues \w que|strong="H3588"\w* \w te|strong="H3588"\w* \w deje|strong="H5800"\w* \w y|strong="H3588"\w* \w me|strong="H3588"\w* aparte \w de|strong="H3588"\w* ti. \w Porque|strong="H3588"\w* adondequiera \w que|strong="H3588"\w* tú \w vayas|strong="H3212"\w*, \w yo|strong="H3588"\w* \w iré|strong="H3212"\w*, \w y|strong="H3588"\w* dondequiera \w que|strong="H3588"\w* vivas, \w viviré|strong="H3885"\w*. Tu \w pueblo|strong="H5971"\w* será mi \w pueblo|strong="H5971"\w*, \w y|strong="H3588"\w* tu \nd ʼElohim\nd* mi \nd ʼElohim\nd*.  
\v 17 \w Donde|strong="H8033"\w* \w tú|strong="H6213"\w* mueras, \w yo|strong="H3588"\w* \w moriré|strong="H4191"\w*, \w y|strong="H3588"\w* \w allí|strong="H8033"\w* seré \w sepultada|strong="H6912"\w*. \w Así|strong="H3541"\w* \w me|strong="H3588"\w* \w haga|strong="H6213"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w y|strong="H3588"\w* \w aun|strong="H3254"\w* \w me|strong="H3588"\w* \w añada|strong="H3254"\w*, \w que|strong="H3588"\w* solo \w la|strong="H3588"\w* \w muerte|strong="H4194"\w* \w hará|strong="H6213"\w* separación \w entre|strong="H3588"\w* nosotras dos.  
\v 18 \w Y|strong="H3068"\w* al \w ver|strong="H7200"\w* \w que|strong="H3588"\w* estaba resuelta \w a|strong="H3068"\w* irse \w con|strong="H3588"\w* \w ella|strong="H1931"\w*, desistió \w de|strong="H3588"\w* decirle \w más|strong="H3588"\w*.   
\p
\v 19 \w Caminaron|strong="H3212"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w hasta|strong="H5704"\w* \w que|strong="H5921"\w* llegaron \w a|strong="H3068"\w* Belén. \w Sucedió|strong="H1961"\w* \w que|strong="H5921"\w* \w al|strong="H5921"\w* entrar \w en|strong="H5921"\w* Belén, \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w se|strong="H1961"\w* alborotó \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w ellas|strong="H5921"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w mujeres|strong="H5704"\w* decían: ¿\w No|strong="H1961"\w* \w es|strong="H1961"\w* \w ésta|strong="H2063"\w* \w Noemí|strong="H5281"\w*?   
\p
\v 20 \w Y|strong="H3068"\w* ella les decía: \w No|strong="H3588"\w* \w me|strong="H3588"\w* llamen \w Noemí|strong="H5281"\w*. Llámenme \w Mara|strong="H4755"\w*, \w porque|strong="H3588"\w* \nd ʼEL-Shadday\nd* \w me|strong="H3588"\w* trató \w muy|strong="H3966"\w* amargamente.   
\p
\v 21 Yo salí \w llena|strong="H4392"\w*, pero \nd \+w Yavé|strong="H3068"\+w*\nd* dispuso \w que|strong="H4100"\w* regresara \w vacía|strong="H7387"\w*. ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* me \w llaman|strong="H7121"\w* \w Noemí|strong="H5281"\w*, puesto \w que|strong="H4100"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w dio|strong="H7725"\w* testimonio contra \w mí|strong="H6030"\w*, y \nd ʼEL-Shadday\nd* me afligió?   
\p
\v 22 \w Así|strong="H1992"\w* regresó \w Noemí|strong="H5281"\w* \w con|strong="H5973"\w* \w su|strong="H1992"\w* \w nuera|strong="H3618"\w*, Rut la \w moabita|strong="H4125"\w*, cuando \w volvió|strong="H7725"\w* \w de|strong="H5973"\w* la tierra \w de|strong="H5973"\w* \w Moab|strong="H4124"\w*. Llegaron \w a|strong="H3068"\w* Belén al principio \w de|strong="H5973"\w* la cosecha \w de|strong="H5973"\w* la \w cebada|strong="H8184"\w*.   
\c 2  
\s1 La casa del pan  
\p
\v 1 \w Noemí|strong="H5281"\w* tenía un pariente de su esposo, \w hombre|strong="H1368"\w* muy rico \w llamado|strong="H8034"\w* \w Booz|strong="H1162"\w*, de la \w familia|strong="H4940"\w* de Elimelec.   
\p
\v 2 Rut la \w moabita|strong="H4125"\w* dijo \w a|strong="H3068"\w* \w Noemí|strong="H5281"\w*: \w Te|strong="H5869"\w* \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* me permitas \w ir|strong="H3212"\w* al \w campo|strong="H7704"\w*, y rebuscaré \w espigas|strong="H7641"\w* detrás \w de|strong="H5869"\w* aquel ante el cual \w halle|strong="H4672"\w* \w gracia|strong="H2580"\w*.  
\p \w Y|strong="H3068"\w* ella \w le|strong="H5869"\w* respondió: \w Vé|strong="H3212"\w*, \w hija|strong="H1323"\w* mía.  
\v 3 \w Fue|strong="H3212"\w* y \w espigó|strong="H3950"\w* \w en|strong="H3212"\w* el \w campo|strong="H7704"\w* detrás de los cosechadores. Ocurrió que aquella \w parte|strong="H2513"\w* del \w campo|strong="H7704"\w* era de \w Booz|strong="H1162"\w*, quien era de la \w familia|strong="H4940"\w* de Elimelec.   
\p
\v 4 \w Ciertamente|strong="H2009"\w* \w Booz|strong="H1162"\w* llegó \w de|strong="H5973"\w* Belén y dijo \w a|strong="H3068"\w* \w los|strong="H5973"\w* cosechadores: ¡\nd \+w Yavé|strong="H3068"\+w*\nd* sea \w con|strong="H5973"\w* ustedes!  
\p \w Y|strong="H3068"\w* ellos respondieron: ¡\nd \+w Yavé|strong="H3068"\+w*\nd* \w te|strong="H5973"\w* \w bendiga|strong="H1288"\w*!   
\p
\v 5 \w Booz|strong="H1162"\w* preguntó \w a|strong="H3068"\w* su esclavo, \w al|strong="H5921"\w* \w que|strong="H4310"\w* tenía \w a|strong="H3068"\w* su cargo \w los|strong="H5921"\w* cosechadores: ¿\w De|strong="H5921"\w* \w quién|strong="H4310"\w* \w es|strong="H2063"\w* esa joven?   
\p
\v 6 \w El|strong="H1931"\w* esclavo \w que|strong="H1931"\w* \w estaba|strong="H5324"\w* encargado \w de|strong="H5921"\w* \w los|strong="H5921"\w* cosechadores \w respondió|strong="H6030"\w*: \w Es|strong="H1931"\w* \w la|strong="H1931"\w* joven \w moabita|strong="H4125"\w* \w que|strong="H1931"\w* regresó \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w campos|strong="H7704"\w* \w de|strong="H5921"\w* \w Moab|strong="H4124"\w* \w con|strong="H5973"\w* \w Noemí|strong="H5281"\w*,  
\v 7 \w y|strong="H5704"\w* \add ella\add* dijo: Permíteme \w que|strong="H6258"\w* rebusque \w y|strong="H5704"\w* recoja entre \w los|strong="H3427"\w* manojos, detrás \w de|strong="H5704"\w* \w los|strong="H3427"\w* cosechadores. \w Así|strong="H2088"\w* \w que|strong="H6258"\w* entró \w y|strong="H5704"\w* \w está|strong="H2088"\w* \w desde|strong="H5704"\w* la \w mañana|strong="H1242"\w* \w hasta|strong="H5704"\w* \w ahora|strong="H6258"\w*, \w aunque|strong="H5704"\w* reposó un \w poco|strong="H4592"\w* \w en|strong="H5704"\w* la \w casa|strong="H1004"\w*.   
\p
\v 8 \w Entonces|strong="H1571"\w* \w Booz|strong="H1162"\w* dijo \w a|strong="H3068"\w* Rut: \w Escucha|strong="H8085"\w*, \w hija|strong="H1323"\w* mía. \w No|strong="H3808"\w* \w vayas|strong="H3212"\w* \w a|strong="H3068"\w* espigar \w a|strong="H3068"\w* \w otro|strong="H2088"\w* \w campo|strong="H7704"\w*, \w ni|strong="H3808"\w* \w pases|strong="H5674"\w* \w de|strong="H5973"\w* \w aquí|strong="H2088"\w*, \w sino|strong="H3808"\w* quédate \w aquí|strong="H2088"\w* \w con|strong="H5973"\w* mis esclavas.  
\v 9 Fíjate en el \w campo|strong="H7704"\w* donde cosechen y síguelas. \w Ciertamente|strong="H8354"\w* \w ordené|strong="H6680"\w* \w a|strong="H3068"\w* los esclavos \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w te|strong="H5869"\w* \w toquen|strong="H5060"\w*. Cuando tengas \w sed|strong="H6770"\w*, \w vé|strong="H3068"\w* \w a|strong="H3068"\w* los cántaros \w de|strong="H5869"\w* agua y \w bebe|strong="H8354"\w* \w de|strong="H5869"\w* la \w que|strong="H3808"\w* sacan los esclavos.   
\p
\v 10 Entonces \w ella|strong="H5921"\w* \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* su \w rostro|strong="H6440"\w*, \w se|strong="H5921"\w* inclinó \w hasta|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w y|strong="H5921"\w* \w le|strong="H5921"\w* preguntó: ¿\w Por|strong="H5921"\w* \w qué|strong="H5921"\w* \w hallé|strong="H4672"\w* \w gracia|strong="H2580"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w te|strong="H5869"\w* fijes \w en|strong="H5921"\w* \w mí|strong="H5921"\w*, aunque soy \w una|strong="H4672"\w* extranjera?   
\p
\v 11 \w Booz|strong="H1162"\w* le \w respondió|strong="H6030"\w*: \w Supe|strong="H3045"\w* \w en|strong="H3212"\w* detalle \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w hiciste|strong="H6213"\w* con \w tu|strong="H6213"\w* \w suegra|strong="H2545"\w* después \w de|strong="H5971"\w* \w la|strong="H3605"\w* \w muerte|strong="H4194"\w* \w de|strong="H5971"\w* \w tu|strong="H6213"\w* esposo, y cómo abandonaste \w a|strong="H3068"\w* \w tu|strong="H6213"\w* padre y \w a|strong="H3068"\w* \w tu|strong="H6213"\w* madre, \w la|strong="H3605"\w* tierra \w de|strong="H5971"\w* \w tu|strong="H6213"\w* \w nacimiento|strong="H4138"\w*, y viniste \w a|strong="H3068"\w* un \w pueblo|strong="H5971"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w conocías|strong="H3045"\w*.  
\v 12 \nd \+w Yavé|strong="H3068"\+w*\nd* recompense tu \w obra|strong="H6467"\w*. Tu remuneración \w sea|strong="H1961"\w* completa \w de|strong="H8478"\w* parte \w de|strong="H8478"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H5973"\w* \nd ʼElohim\nd* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w*, \w bajo|strong="H8478"\w* cuyas \w alas|strong="H3671"\w* viniste \w a|strong="H3068"\w* refugiarte.   
\p
\v 13 \w Y|strong="H3068"\w* \w ella|strong="H5921"\w* \w dijo|strong="H1696"\w*: ¡\w Halle|strong="H4672"\w* \w yo|strong="H3588"\w* \w gracia|strong="H2580"\w* ante \w ti|strong="H5921"\w*, \tl ʼadón\tl* \w mío|strong="H5921"\w*! \w Porque|strong="H3588"\w* \w me|strong="H5921"\w* consolaste \w y|strong="H3588"\w* \w hablaste|strong="H1696"\w* \w al|strong="H5921"\w* \w corazón|strong="H3820"\w* \w de|strong="H5921"\w* tu esclava, \w aunque|strong="H3588"\w* \w no|strong="H3808"\w* \w soy|strong="H1961"\w* \w ni|strong="H3808"\w* \w como|strong="H3588"\w* \w una|strong="H4672"\w* \w de|strong="H5921"\w* tus esclavas.   
\p
\v 14 \w A|strong="H3068"\w* \w la|strong="H7646"\w* \w hora|strong="H6256"\w* \w de|strong="H4480"\w* comer \w Booz|strong="H1162"\w* le dijo: Ven \w acá|strong="H1988"\w*, come \w pan|strong="H3899"\w* y moja tu bocado \w en|strong="H4480"\w* \w el|strong="H3427"\w* \w vinagre|strong="H2558"\w*.  
\p Así \w que|strong="H4480"\w* \w ella|strong="H4480"\w* \w se|strong="H4480"\w* sentó junto \w a|strong="H3068"\w* \w los|strong="H3427"\w* cosechadores, y \w él|strong="H3427"\w* le sirvió grano \w tostado|strong="H7039"\w*. \w Ella|strong="H4480"\w* comió y \w se|strong="H4480"\w* sació, y le sobró.  
\v 15 Luego \w se|strong="H3808"\w* \w levantó|strong="H6965"\w* \w a|strong="H3068"\w* espigar. \w Booz|strong="H1162"\w* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* sus \w criados|strong="H5288"\w*: Hasta en medio de los manojos \w podrá|strong="H3808"\w* espigar, \w y|strong="H1571"\w* \w no|strong="H3808"\w* \w la|strong="H1571"\w* avergüencen.  
\v 16 Incluso dejarán caer \w para|strong="H4480"\w* \w ella|strong="H4480"\w* algo \w de|strong="H4480"\w* los manojos \w y|strong="H1571"\w* \w lo|strong="H3808"\w* abandonarán \w para|strong="H4480"\w* \w que|strong="H4480"\w* \w ella|strong="H4480"\w* \w lo|strong="H3808"\w* espigue. \w No|strong="H3808"\w* \w la|strong="H1571"\w* reprendan.   
