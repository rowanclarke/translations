\v 10 \w My|strong="H1980"\w* \w love|strong="H1730"\w* \w is|strong="H2896"\w* mine, \w and|strong="H1980"\w* \w I|strong="H1980"\w* \w am|strong="H1980"\w* \w the|strong="H1980"\w* \w one|strong="H2896"\w* \w he|strong="H1980"\w* \w desires|strong="H1980"\w*!
\v 11 Come, \w my|strong="H5921"\w* \w love|strong="H1730"\w*, let's go \w out|strong="H5921"\w* \w into|strong="H5921"\w* \w the|strong="H5921"\w* countryside, \w and|strong="H1730"\w* spend \w the|strong="H5921"\w* night \w among|strong="H5921"\w* \w the|strong="H5921"\w* henna flowers.\f + \fr 7:11 \ft “Henna flowers”: or “villages.” The same word “henna” is used in \xt 1:14\xt*\ft and \xt 4:13\xt*\ft . It seems unlikely that they would wish to go to the villages if they wished to have privacy.\f*
\v 12 \w Let|strong="H3212"\w*'s \w go|strong="H3212"\w* early \w to|strong="H3318"\w* \w the|strong="H3318"\w* vineyards \w and|strong="H3212"\w* see if \w the|strong="H3318"\w* vines have budded \w and|strong="H3212"\w* are \w in|strong="H3212"\w* flower, \w and|strong="H3212"\w* if \w the|strong="H3318"\w* pomegranates are blossoming. \w There|strong="H3885"\w* \w I|strong="H3212"\w* \w will|strong="H7704"\w* \w give|strong="H7704"\w* \w my|strong="H3318"\w* \w love|strong="H1730"\w* \w to|strong="H3318"\w* \w you|strong="H3212"\w*.
\v 13 \w The|strong="H7200"\w* mandrakes\f + \fr 7:13 \ft A plant thought to be an aphrodisiac and associated with fertility. See for example \xt Genesis 30:14-16\xt*\ft .\f* \w give|strong="H5414"\w* \w off|strong="H6605"\w* \w their|strong="H5414"\w* fragrant scent; \w we|strong="H3068"\w* \w are|strong="H8033"\w* surrounded\f + \fr 7:13 \ft “We are surrounded”: literally, “over our doorways.”\f* \w by|strong="H5414"\w* \w all|strong="H7200"\w* kinds \w of|strong="H3754"\w* delights, new \w as|strong="H8033"\w* well \w as|strong="H8033"\w* old, \w which|strong="H8033"\w* \w I|strong="H5414"\w* \w have|strong="H7200"\w* saved \w up|strong="H5414"\w* \w for|strong="H5414"\w* \w you|strong="H5414"\w*, \w my|strong="H5414"\w* \w love|strong="H1730"\w*.
\b
\c 8
\sp Woman:
\p 
\v 1 \w How|strong="H4310"\w* \w I|strong="H5414"\w* \w wish|strong="H4310"\w* \w you|strong="H5414"\w* \w were|strong="H5414"\w* \w like|strong="H3808"\w* \w a|strong="H3068"\w* brother \w to|strong="H5414"\w* \w me|strong="H5414"\w*, \w one|strong="H3808"\w* \w who|strong="H4310"\w* \w nursed|strong="H3243"\w* \w at|strong="H3808"\w* \w my|strong="H5414"\w* mother's \w breasts|strong="H7699"\w*! \w Then|strong="H5414"\w* if \w I|strong="H5414"\w* \w met|strong="H4672"\w* \w you|strong="H5414"\w* \w on|strong="H5414"\w* \w the|strong="H5414"\w* \w street|strong="H2351"\w* \w I|strong="H5414"\w* \w could|strong="H4310"\w* \w kiss|strong="H5401"\w* \w you|strong="H5414"\w* \w and|strong="H1571"\w* \w no|strong="H3808"\w* \w one|strong="H3808"\w* \w would|strong="H4310"\w* tell \w me|strong="H5414"\w* \w off|strong="H5414"\w*.
\v 2 Then \w I|strong="H1004"\w* could take \w you|strong="H3925"\w* \w home|strong="H1004"\w* \w to|strong="H1004"\w* \w my|strong="H3925"\w* mother's \w house|strong="H1004"\w*, \w where|strong="H1004"\w* \w she|strong="H8248"\w* used \w to|strong="H1004"\w* \w teach|strong="H3925"\w* \w me|strong="H8248"\w*.\f + \fr 8:2 \ft Or “To the room of the one who bore me,” paralleling \xt 3:4\xt*\ft .\f* \w I|strong="H1004"\w* would \w give|strong="H8248"\w* \w you|strong="H3925"\w* \w spiced|strong="H7544"\w* \w wine|strong="H3196"\w* \w to|strong="H1004"\w* \w drink|strong="H8248"\w* \w from|strong="H1004"\w* \w the|strong="H8248"\w* \w juice|strong="H6071"\w* \w of|strong="H1004"\w* \w my|strong="H3925"\w* \w pomegranate|strong="H7416"\w*.
\v 3 \w He|strong="H8478"\w* supports \w my|strong="H8478"\w* \w head|strong="H7218"\w* \w with|strong="H7218"\w* \w his|strong="H8478"\w* \w left|strong="H8040"\w* \w hand|strong="H3225"\w*, \w and|strong="H7218"\w* holds \w me|strong="H8478"\w* close \w with|strong="H7218"\w* \w his|strong="H8478"\w* \w right|strong="H3225"\w*.
\v 4 \w Women|strong="H1323"\w* \w of|strong="H1323"\w* \w Jerusalem|strong="H3389"\w*, \w swear|strong="H7650"\w* \w to|strong="H5704"\w* \w me|strong="H4100"\w* \w that|strong="H5704"\w* \w you|strong="H5704"\w* won't disturb our \w love|strong="H5782"\w* \w until|strong="H5704"\w* \w the|strong="H5704"\w* right \w time|strong="H5704"\w*.
\sp Women of Jerusalem:
\p 
\v 5 \w Who|strong="H4310"\w* \w is|strong="H4310"\w* \w this|strong="H2063"\w* \w coming|strong="H5927"\w* \w in|strong="H5921"\w* \w from|strong="H4480"\w* \w the|strong="H5921"\w* \w wilderness|strong="H4057"\w* holding \w her|strong="H5921"\w* \w love|strong="H1730"\w* \w close|strong="H4480"\w* \w to|strong="H5927"\w* \w her|strong="H5921"\w*?
\sp Woman:
\p \w I|strong="H5921"\w* woke \w you|strong="H5921"\w* \w up|strong="H5927"\w* \w under|strong="H8478"\w* \w the|strong="H5921"\w* \w apple|strong="H8598"\w* \w tree|strong="H8598"\w* \w where|strong="H8033"\w* \w your|strong="H5921"\w* mother \w conceived|strong="H2254"\w* \w you|strong="H5921"\w*, \w and|strong="H8033"\w* \w where|strong="H8033"\w* \w she|strong="H2063"\w* \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H5927"\w* \w you|strong="H5921"\w*.\f + \fr 8:5 \ft What this means is unclear.\f*
\v 6 Stamp \w my|strong="H7760"\w* name \w as|strong="H3588"\w* \w a|strong="H3068"\w* \w seal|strong="H2368"\w* \w on|strong="H5921"\w* \w your|strong="H5921"\w* \w heart|strong="H3820"\w*, \w like|strong="H3820"\w* \w a|strong="H3068"\w* \w seal|strong="H2368"\w* \w on|strong="H5921"\w* \w your|strong="H5921"\w* \w arm|strong="H2220"\w*,\f + \fr 8:6 \ft As an indication of ownership.\f* \w for|strong="H3588"\w* love \w is|strong="H3820"\w* \w strong|strong="H5794"\w* \w as|strong="H3588"\w* \w death|strong="H4194"\w*, \w passion|strong="H7068"\w* \w as|strong="H3588"\w* unyielding \w as|strong="H3588"\w* \w the|strong="H5921"\w* \w grave|strong="H7585"\w*—\w its|strong="H5921"\w* \w arrows|strong="H7565"\w* flash \w like|strong="H3820"\w* \w fire|strong="H7957"\w*, \w a|strong="H3068"\w* blazing \w flame|strong="H7957"\w* \w of|strong="H5921"\w* \w the|strong="H5921"\w* Lord.
\v 7 \w Floods|strong="H5104"\w* \w of|strong="H1004"\w* \w water|strong="H4325"\w* \w cannot|strong="H3808"\w* \w extinguish|strong="H3518"\w* love; \w rivers|strong="H5104"\w* \w cannot|strong="H3808"\w* submerge \w it|strong="H5414"\w*. If \w a|strong="H3068"\w* \w man|strong="H3605"\w* \w offered|strong="H5414"\w* \w everything|strong="H3605"\w* \w he|strong="H3605"\w* owned \w in|strong="H1004"\w* order \w to|strong="H3201"\w* buy love \w he|strong="H3605"\w* \w would|strong="H7227"\w* \w be|strong="H3808"\w* \w completely|strong="H3605"\w* rejected.
\sp Woman's brothers:
\p 
\v 8 \w We|strong="H3117"\w* \w have|strong="H3117"\w* \w a|strong="H3068"\w* \w younger|strong="H6996"\w* sister whose \w breasts|strong="H7699"\w* \w are|strong="H3117"\w* still \w small|strong="H6996"\w*. \w What|strong="H4100"\w* \w shall|strong="H3117"\w* \w we|strong="H3068"\w* \w do|strong="H6213"\w* \w for|strong="H6213"\w* \w our|strong="H6213"\w* sister \w when|strong="H3117"\w* someone asks \w to|strong="H1696"\w* marry \w her|strong="H6213"\w*?
\v 9 \w If|strong="H1931"\w* \w she|strong="H1931"\w* \w is|strong="H1931"\w* \w a|strong="H3068"\w* \w wall|strong="H2346"\w*, \w we|strong="H3068"\w* \w will|strong="H1931"\w* \w build|strong="H1129"\w* \w a|strong="H3068"\w* \w silver|strong="H3701"\w* tower \w on|strong="H5921"\w* \w it|strong="H1931"\w*. \w But|strong="H1931"\w* \w if|strong="H1931"\w* \w she|strong="H1931"\w* \w is|strong="H1931"\w* \w a|strong="H3068"\w* \w door|strong="H1817"\w*, \w we|strong="H3068"\w* \w will|strong="H1931"\w* bar \w the|strong="H5921"\w* \w way|strong="H5921"\w* \w with|strong="H5921"\w* cedar \w planks|strong="H3871"\w*.\f + \fr 8:9 \ft Some take the image of the wall as representing virginity, and the door as someone who is promiscuous. In any case, the woman identifies herself as a wall in the following verse, indicating faithfulness in any case.\f*
\sp Woman:
\p 
\v 10 \w I|strong="H4672"\w* \w am|strong="H1961"\w* \w a|strong="H3068"\w* \w wall|strong="H2346"\w*, \w and|strong="H5869"\w* \w my|strong="H1961"\w* \w breasts|strong="H7699"\w* \w are|strong="H5869"\w* \w like|strong="H1961"\w* \w towers|strong="H4026"\w*. \w So|strong="H1961"\w* \w when|strong="H1961"\w* he \w looks|strong="H5869"\w* \w at|strong="H1961"\w* \w me|strong="H4672"\w* he's happy!\f + \fr 8:10 \ft Literally, “Then in his eyes I am as one who brings peace.” The woman is contradicting her brothers and is saying she is mature.\f*
\sp Woman:\f + \fr 8:11 \ft Some believe the man is speaking the following verses.\f*
\p 
\v 11 \w Solomon|strong="H8010"\w* \w had|strong="H1961"\w* \w a|strong="H3068"\w* \w vineyard|strong="H3754"\w* \w at|strong="H1961"\w* \w Baal-hamon|strong="H1174"\w* which \w he|strong="H5414"\w* leased \w to|strong="H1961"\w* tenant farmers. \w Each|strong="H5414"\w* \w of|strong="H3754"\w* \w them|strong="H5414"\w* \w paid|strong="H5414"\w* \w him|strong="H5414"\w* \w one|strong="H1961"\w* thousand \w silver|strong="H3701"\w* coins \w for|strong="H3701"\w* \w the|strong="H5414"\w* \w fruit|strong="H6529"\w* \w it|strong="H5414"\w* produced.
\v 12 But \w I|strong="H6440"\w* \w own|strong="H6440"\w* \w my|strong="H8010"\w* \w vineyard|strong="H3754"\w*, \w it|strong="H6440"\w* \w is|strong="H6440"\w* \w mine|strong="H6440"\w* alone. \w One|strong="H3967"\w* thousand silver coins \w are|strong="H6440"\w* \w for|strong="H6440"\w* \w you|strong="H6440"\w*, \w Solomon|strong="H8010"\w*, \w and|strong="H3967"\w* \w two|strong="H3967"\w* \w hundred|strong="H3967"\w* \w for|strong="H6440"\w* those who \w look|strong="H6440"\w* \w after|strong="H6529"\w* \w it|strong="H6440"\w*.
\sp Man:
\p 
\v 13 \w My|strong="H8085"\w* darling, \w sitting|strong="H3427"\w* \w there|strong="H3427"\w* \w in|strong="H3427"\w* \w the|strong="H8085"\w* \w gardens|strong="H1588"\w* \w with|strong="H3427"\w* \w companions|strong="H2270"\w* \w listening|strong="H8085"\w* \w to|strong="H8085"\w* \w you|strong="H6963"\w*—\w please|strong="H8085"\w* talk \w to|strong="H8085"\w* \w me|strong="H6963"\w*!
\sp Woman:
\p 
\v 14 Come quickly, \w my|strong="H5921"\w* \w love|strong="H1730"\w*! \w Be|strong="H2022"\w* \w like|strong="H1819"\w* \w a|strong="H3068"\w* \w gazelle|strong="H6643"\w* \w or|strong="H2022"\w* \w a|strong="H3068"\w* \w young|strong="H6082"\w* deer \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w mountains|strong="H2022"\w* \w of|strong="H2022"\w* \w spices|strong="H1314"\w*.
\b
