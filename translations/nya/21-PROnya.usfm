\id PRO - Biblica® Open God’s Word in Contemporary Chichewa 2016 
\h MIYAMBO 
\toc1 Miyambo 
\toc2 Miyambo 
\toc3 Miy 
\mt1 Miyambo 
\c 1  
\s1 Mawu Oyamba: Cholinga ndi Mutu 
\p  
\v 1 Iyi ndi miyambi ya Solomoni mwana wa Davide, mfumu ya Israeli: 
\q1  
\v 2 Ndi yothandiza kuti munthu adziwe nzeru ndi malangizo; 
\q2 kuti amvetse mawu a matanthauzo ozama; 
\q1  
\v 3 kuti alandire malangizo othandiza kuti achite zinthu mwanzeru, 
\q2 akhale wangwiro, wachilungamo ndiponso wosakondera. 
\q1  
\v 4 Ndi yothandiza munthu wamba kuti aphunzire nzeru za kuchenjera, 
\q2 achinyamata kudziwa zinthu bwino ndi kulingalira. 
\q1  
\v 5 Munthu wanzeru amvetse bwino miyamboyi kuti awonjezere kuphunzira kwake, 
\q2 ndi munthu womvetsa zinthu bwino apatepo luso, 
\q1  
\v 6 kuti azimvetsa miyambi ndi mafanizo, 
\q2 mawu a anthu anzeru ndi mikuluwiko. 
\b  
\q1  
\v 7 Kuopa Yehova ndiye chiyambi cha nzeru. 
\q2 Zitsiru zimanyoza nzeru ndi malangizo. 
\s1 Malangizo kuti Asunge Nzeru 
\s2 Malangizo kwa Achinyamata 
\q1  
\v 8 Mwana wanga, mvera malangizo a abambo ako 
\q2 ndipo usakane mawu okuwongolera a amayi ako. 
\q1  
\v 9 Ali ngati sangamutu yokongola ya maluwa pamutu pako 
\q2 ndiponso ali ngati mkanda mʼkhosi mwako. 
\b  
\q1  
\v 10 Mwana wanga, ngati anthu oyipa afuna kukukopa 
\q2 usamawamvere. 
\q1  
\v 11 Akadzati, “Tiye kuno; 
\q2 tikabisale kuti tiphe anthu, 
\q2 tikabisalire anthu osalakwa; 
\q1  
\v 12 tiwameze amoyo ngati manda, 
\q2 ndi athunthu ngati anthu otsikira mʼdzenje. 
\q1  
\v 13 Motero tidzapeza zinthu zosiyanasiyana zamtengowapatali 
\q2 ndi kudzaza nyumba zathu ndi zolanda; 
\q1  
\v 14 Bwera, chita nafe maere, 
\q2 ndipo tidzagawana chuma chathu tonse.” 
\q1  
\v 15 Mwana wanga, usayende nawo pamodzi, 
\q2 usatsagane nawo mʼnjira zawozo. 
\q1  
\v 16 Iwowatu amangofuna zoyipa zokhazokha, 
\q2 amathamangira kukhetsa magazi. 
\q1  
\v 17 Nʼkopanda phindu kutchera msampha 
\q2 mbalame zikuona! 
\q1  
\v 18 Koma anthu amenewa amangobisalira miyoyo yawo yomwe; 
\q2 amangodzitchera okha msampha! 
\q1  
\v 19 Awa ndiwo mathero a anthu opeza chuma mwankhanza; 
\q2 chumacho chimapha mwiniwake. 
\s2 Chenjezo Pomwe Tikana Nzeru 
\q1  
\v 20 Nzeru ikufuwula mu msewu, 
\q2 ikuyankhula mokweza mawu mʼmisika; 
\q1  
\v 21 ikufuwula pa mphambano ya misewu, 
\q2 ikuyankhula pa zipata za mzinda kuti, 
\b  
\q1  
\v 22 “Kodi inu anthu osachangamukanu, mudzakondwera ndi kusachangamuka mpaka liti? 
\q2 Nanga anthu onyogodola adzakondabe kunyogodola mpaka liti? 
\q2 Kapena opusa adzadana ndi nzeru mpaka liti? 
\q1  
\v 23 Tamverani mawu anga a chidzudzulo. 
\q2 Ine ndikukuwuzani maganizo anga 
\q2 ndi kukudziwitsani mawu anga. 
\q1  
\v 24 Popeza ndinakuyitanani koma inu munakana kumvera. 
\q2 Ndinayesa kukuthandizani koma panalibe amene anasamala. 
\q1  
\v 25 Uphungu wanga munawunyoza. 
\q2 Kudzudzula kwanga simunakusamale. 
\q1  
\v 26 Ndiye inenso ndidzakusekani mukadzakhala mʼmavuto; 
\q2 ndidzakunyogodolani chikadzakugwerani chimene mumachiopacho. 
\q1  
\v 27 Chiwonongeko chikadzakugwerani ngati namondwe, 
\q2 tsoka likadzakufikirani ngati kamvuluvulu, 
\q2 mavuto ndi masautso akadzakugwerani. 
\b  
\q1  
\v 28 “Tsono mudzandiyitana koma sindidzayankha; 
\q2 mudzandifunafuna, koma simudzandipeza. 
\q1  
\v 29 Popeza iwo anadana ndi chidziwitso 
\q2 ndipo sanasankhe kuopa Yehova, 
\q1  
\v 30 popeza iwo sanasamale malangizo anga 
\q2 ndipo ananyoza chidzudzulo changa. 
\q1  
\v 31 Tsono adzadya zipatso zoyenera mayendedwe awo 
\q2 ndi kukhuta ndi ntchito zimene anachita kwa ena. 
\q1  
\v 32 Pakuti anthu osachangamuka amaphedwa chifukwa cha kusochera kwawo, 
\q2 ndipo zitsiru zimadziwononga zokha chifukwa cha mphwayi zawo. 
\q1  
\v 33 Koma aliyense wondimvera adzakhala mwa bata; 
\q2 adzakhala mosatekeseka posaopa chilichonse.” 
\c 2  
\s2 Ubwino Wanzeru 
\q1  
\v 1 Mwana wanga, ngati ulandira mawu anga 
\q2 ndi kusunga malamulo anga mu mtima mwako, 
\q1  
\v 2 ndiponso kutchera khutu lako ku nzeru 
\q2 ndi kuyikapo mtima pa kumvetsa zinthu; 
\q1  
\v 3 ngati upempha kuti uzindikire zinthu 
\q2 inde kupempha ndi mtima wonse kuti ukhale womvetsa zinthu, 
\q1  
\v 4 ngati ufunafuna nzeruyo ngati siliva 
\q2 ndi kuyisakasaka ngati chuma chobisika, 
\q1  
\v 5 ndiye udzamvetsa bwino tanthauzo la kuopa Yehova; 
\q2 ndipo udzapezanso tanthauzo la kumudziwa Yehova. 
\q1  
\v 6 Pakuti Yehova ndiye amapereka nzeru, 
\q2 ndipo mʼkamwa mwake mumachokera chidziwitso ndi kumvetsa zinthu. 
\q1  
\v 7 Anthu olungama zinthu zimawayendera bwino chifukwa Yehova amakhala nawo. 
\q2 Paja Yehova ndiye chishango cha amene amayenda mwangwiro, 
\q1  
\v 8 pakuti ndiye mlonda wa njira zolungama. 
\q2 Iye amasamala mayendedwe a anthu ake okhulupirika. 
\b  
\q1  
\v 9 Choncho udzamvetsa tanthauzo la ungwiro, chilungamo, 
\q2 kusakondera ndi njira iliyonse yabwino. 
\q1  
\v 10 Pakuti nzeru idzalowa mu mtima mwako, 
\q2 kudziwa zinthu kudzakusangalatsa. 
\q1  
\v 11 Kuganizira bwino za mʼtsogolo kudzakusunga; 
\q2 kumvetsa zinthu bwino kudzakuteteza. 
\b  
\q1  
\v 12 Nzeru idzakupulumutsa ku mayendedwe oyipa, 
\q2 kwa anthu amabodza, 
\q1  
\v 13 amene amasiya njira zolungama 
\q2 namayenda mʼnjira zamdima, 
\q1  
\v 14 amene amakondwera pochita zoyipa 
\q2 namasangalala ndi kuyipa kwa ntchito zawo zonyansa. 
\q1  
\v 15 Amenewa ndi anthu a njira zawo zokhotakhota, 
\q2 ndipo makhalidwe awo ndi achinyengo. 
\b  
\q1  
\v 16 Nzeruyo idzakupulumutsanso kwa mkazi wachigololo; 
\q2 kwa mkazi wachilendo woyankhula moshashalika, 
\q1  
\v 17 amene wasiya mwamuna wa chitsikana wake 
\q2 ndi kuyiwala pangano limene anachita pamaso pa Mulungu wake. 
\q1  
\v 18 Pakuti nyumba yake imatsetserekera ku imfa; 
\q2 njira zake zimamufikitsa ku manda. 
\q1  
\v 19 Opita kwa iye palibe ndi mmodzi yemwe amabwerera 
\q2 kapena kupezanso njira zamoyo. 
\b  
\q1  
\v 20 Choncho iwe uziyenda mʼnjira za anthu abwino, 
\q2 uzitsata njira za anthu ochita chilungamo. 
\q1  
\v 21 Pakuti anthu olungama ndiwo ati adzakhale mʼdziko 
\q2 ndipo anthu angwiro ndiwo ati adzakhazikike mʼmenemo; 
\q1  
\v 22 Koma anthu oyipa adzachotsedwa mʼdzikomo, 
\q2 ndipo anthu onyenga adzachotsedwamo. 
\c 3  
\s2 Phindu Lina la Nzeru 
\q1  
\v 1 Mwana wanga, usayiwale malangizo anga, 
\q2 mtima wako usunge malamulo anga. 
\q1  
\v 2 Ukatero zaka za moyo wako zidzachuluka 
\q2 ndipo udzakhala pa mtendere. 
\b  
\q1  
\v 3 Makhalidwe ochitira ena chifundo ndi owonetsa kukhulupirika asakuchokere. 
\q2 Uwamangirire mʼkhosi mwako ngati mkanda 
\q2 ndi kuwalemba pa mtima pako. 
\q1  
\v 4 Ukatero udzapeza kuyanja ndi mbiri yabwino 
\q2 pamaso pa Mulungu ndi anthu. 
\b  
\q1  
\v 5 Uzikhulupirira Yehova ndi mtima wako wonse 
\q2 ndipo usadalire nzeru zako za kumvetsa zinthu. 
\q1  
\v 6 Pa zochita zako zonse uvomereze kuti Mulungu alipo, 
\q2 ndipo Iye adzawongola njira zako. 
\b  
\q1  
\v 7 Usamadzione ngati wa nzeru. 
\q2 Uziopa Yehova ndi kupewa zoyipa. 
\q1  
\v 8 Ukatero thupi lako lidzakhala la moyo wabwino 
\q2 ndi mafupa ako adzakhala olimba. 
\b  
\q1  
\v 9 Uzilemekeza Yehova ndi chuma chako chonse; 
\q2 zokolola zonse zoyamba kucha uzilemekeza nazonso Yehova. 
\q1  
\v 10 Ukatero nkhokwe zako zidzadzaza ndi zinthu zambiri, 
\q2 ndiponso mitsuko yako idzadzaza ndi vinyo. 
\b  
\q1  
\v 11 Mwana wanga usanyoze malangizo a Yehova, 
\q2 ndipo usayipidwe ndi chidzudzulo chake. 
\q1  
\v 12 Paja Yehova amadzudzula amene amamukonda, 
\q2 monga abambo achitira mwana amene amakondwera naye. 
\b  
\q1  
\v 13 Wodala munthu amene wapeza nzeru, 
\q2 munthu amene walandira nzeru zomvetsa zinthu, 
\q1  
\v 14 pakuti phindu la nzeru ndi labwino kuposa la siliva, 
\q2 phindu lakelo ndi labwino kuposanso golide. 
\q1  
\v 15 Nzeru ndi yoposa miyala yamtengowapatali; 
\q2 ndipo zonse zimene umazikhumba sizingafanane ndi nzeru. 
\q1  
\v 16 Mʼdzanja lake lamanja muli moyo wautali; 
\q2 mʼdzanja lake lamanzere muli chuma ndi ulemu. 
\q1  
\v 17 Njira zake ndi njira zosangalatsa, 
\q2 ndipo mu njira zake zonse muli mtendere. 
\q1  
\v 18 Nzeru ili ngati mtengo wopatsa moyo kwa oyigwiritsitsa; 
\q2 wodala munthu amene amayigwiritsa kwambiri. 
\b  
\q1  
\v 19 Yehova anakhazikitsa dziko lapansi pogwiritsa ntchito nzeru. 
\q2 Anagwiritsanso ntchito nzeru zakudziwa bwino zinthu pamene ankakhazikitsa zakumwamba. 
\q1  
\v 20 Mwa nzeru zake Yehova anatumphutsa madzi kuchokera mʼnthaka 
\q2 ndiponso mitambo inagwetsa mvula. 
\b  
\q1  
\v 21 Mwana wanga usunge nzeru yeniyeni ndi khalidwe lomalingarira zinthu bwino. 
\q2 Zimenezi zisakuchokere. 
\q1  
\v 22 Zimenezi zidzakupatsa moyo, 
\q2 moyo wake wosangalatsa ndi wabwino ngati mkanda wa mʼkhosi. 
\q1  
\v 23 Choncho udzayenda pa njira yako mosaopa kanthu, 
\q2 ndipo phazi lako silidzapunthwa; 
\q1  
\v 24 pamene ugona pansi, sudzachita mantha; 
\q2 ukadzagona pansi tulo tako tidzakhala tokoma. 
\q1  
\v 25 Usaope tsoka lobwera mwadzidzidzi 
\q2 kapena chiwonongeko chimene chidzagwera anthu oyipa, 
\q1  
\v 26 pakuti Yehova adzakulimbitsa mtima 
\q2 ndipo adzasunga phazi lako kuti lisakodwe mu msampha. 
\b  
\q1  
\v 27 Usaleke kuchitira zabwino amene ayenera kulandira zabwino, 
\q2 pamene uli nazo mphamvu zochitira zimenezi. 
\q1  
\v 28 Usanene kwa mnansi wako kuti, 
\q2 “Pita, uchite kubweranso. Ndidzakupatsa mawa” 
\q2 pamene uli nazo tsopano. 
\b  
\q1  
\v 29 Usamukonzere chiwembu mnansi wako, 
\q2 amene anakhala nawe pafupi mokudalira. 
\q1  
\v 30 Usakangane ndi munthu wopanda chifukwa 
\q2 pamene iye sanakuchitire zoyipa. 
\b  
\q1  
\v 31 Usachite naye nsanje munthu wachiwawa 
\q2 kapena kutsanzira khalidwe lake lililonse. 
\q1  
\v 32 Pakuti Yehova amanyansidwa ndi munthu woyipa 
\q2 koma amayanjana nawo anthu olungama. 
\b  
\q1  
\v 33 Yehova amatemberera nyumba ya munthu woyipa, 
\q2 koma amadalitsa nyumba ya anthu olungama. 
\q1  
\v 34 Anthu onyoza, Iye amawanyoza, 
\q2 koma amakomera mtima anthu odzichepetsa. 
\q1  
\v 35 Anthu anzeru adzalandira ulemu, 
\q2 koma zitsiru adzazichititsa manyazi. 
\c 4  
\s2 Nzeru Iposa Zonse 
\q1  
\v 1 Ananu, mverani malangizo a abambo anu; 
\q2 tcherani khutu kuti mupeze nzeru zodziwira zinthu. 
\q1  
\v 2 Zimene ndikukuphunzitsani ndi zabwino. 
\q2 Choncho musasiye malangizo anga. 
\q1  
\v 3 Paja ndinalinso mwana mʼnyumba mwa abambo anga; 
\q2 mwana mmodzi yekha wapamtima pa amayi anga. 
\q1  
\v 4 Ndipo abambo anandiphunzitsa ndi mawu akuti, 
\q2 “Ugwiritse mawu anga pa mtima pako, 
\q2 usunge malamulo anga kuti ukhale ndi moyo. 
\q1  
\v 5 Upeze nzeru, upeze nzeru zomvetsa zinthu; 
\q2 usayiwale mawu anga kapena kutayana nawo. 
\q1  
\v 6 Usasiye nzeru ndipo idzakusunga. 
\q2 Uziyikonda ndipo idzakuteteza. 
\q1  
\v 7 Fundo yayikulu pa za nzeru ndi iyi: upeze nzeru. 
\q2 Kaya pali china chilichonse chimene ungapeze, koma upeze nzeru yomvetsa bwino zinthu. 
\q1  
\v 8 Uyilemekeze nzeruyo ndipo idzakukweza; 
\q2 ikumbatire nzeruyo ndipo idzakupatsa ulemu. 
\q1  
\v 9 Idzayika sangamutu yokongola yamaluwa pamutu pako; 
\q2 idzakupatsa chipewa chaufumu chaulemu.” 
\b  
\q1  
\v 10 Mwana wanga, umvere ndi kuvomereza zimene ndikunena, 
\q2 ndipo zaka za moyo wako zidzakhala zochuluka. 
\q1  
\v 11 Ndakuphunzitsa njira yake ya nzeru. 
\q2 Ndakutsogolera mʼnjira zolungama. 
\q1  
\v 12 Pamene ukuyenda, mapazi ako sadzawombana; 
\q2 ukamadzathamanga, sudzapunthwa. 
\q1  
\v 13 Ugwiritse zimene ndikukuphunzitsazi osazitaya ayi. 
\q2 Uwasamale bwino pakuti moyo wako wagona pamenepa. 
\q1  
\v 14 Usayende mʼnjira za anthu oyipa 
\q2 kapena kuyenda mʼnjira ya anthu ochimwa. 
\q1  
\v 15 Pewa njira zawo, usayende mʼmenemo; 
\q2 uzilambalala nʼkumangopita. 
\q1  
\v 16 Pakuti iwo sagona mpaka atachita zoyipa; 
\q2 tulo salipeza mpaka atapunthwitsa munthu wina. 
\q1  
\v 17 Paja chakudya chawo ndicho kuchita zoyipa basi 
\q2 ndipo chakumwa chawo ndi chiwawa. 
\b  
\q1  
\v 18 Koma njira ya anthu olungama ili ngati kuwala kwa mʼbandakucha 
\q2 kumene kumanka kuwalirawalira mpaka dzuwa litafika pa mutu. 
\q1  
\v 19 Koma njira ya anthu oyipa ili ngati mdima wandiweyani; 
\q2 iwo sadziwa chomwe chimawapunthwitsa. 
\b  
\q1  
\v 20 Mwana wanga, mvetsetsa zimene ndikunena; 
\q2 tchera khutu ku mawu anga. 
\q1  
\v 21 Usayiwale malangizo angawa, 
\q2 koma uwasunge mu mtima mwako. 
\q1  
\v 22 Pakuti amapatsa moyo kwa aliyense amene awapeza 
\q2 ndipo amachiritsa thupi lake lonse. 
\q1  
\v 23 Ndipotu mtima wako uziwuyangʼanira bwino ndithu 
\q2 pakuti ndiwo magwero a moyo. 
\q1  
\v 24 Usiyiretu kuyankhula zokhotakhota; 
\q2 ndipo ulekeretu kuyankhula zinthu zonyansa. 
\q1  
\v 25 Maso ako ayangʼane patsogolo; 
\q2 uziyangʼana kutsogolo molunjika. 
\q1  
\v 26 Uzilingalira bwino kumene kupita mapazi ako 
\q2 ndipo njira zako zonse zidzakhala zosakayikitsa. 
\q1  
\v 27 Usapatukire kumanja kapena kumanzere; 
\q2 usapite kumene kuli zoyipa. 
\c 5  
\s2 Chenjezo kwa Mkazi Wachigololo 
\q1  
\v 1 Mwana wanga, mvetsera bwino za nzeru zimene ndikukuwuzazi, 
\q2 tchera khutu ku mawu odziwitsa bwino zinthu ndikukupatsa, 
\q1  
\v 2 kuti uthe kuchita zinthu mochenjera ndi mwanzeru 
\q2 ndiponso kuti utetezedwe ku mayankhulidwe a mkazi wachilendo. 
\q1  
\v 3 Pakuti mkazi wachigololo ali ndi mawu okoma ngati uchi. 
\q2 Zoyankhula zake ndi zosalala ngati mafuta, 
\q1  
\v 4 koma kotsirizira kwake ngowawa ngati ndulu; 
\q2 ngakuthwa ngati lupanga lakuthwa konsekonse. 
\q1  
\v 5 Mapazi ake amatsikira ku imfa; 
\q2 akamayenda ndiye kuti akupita ku manda. 
\q1  
\v 6 Iye saganizirapo za njira ya moyo; 
\q2 njira zake ndi zokhotakhota koma iye sadziwa izi. 
\b  
\q1  
\v 7 Tsopano ana inu, mundimvere; 
\q2 musawasiye mawu anga. 
\q1  
\v 8 Uziyenda kutali ndi mkazi wotereyo, 
\q2 usayandikire khomo la nyumba yake, 
\q1  
\v 9 kuopa kuti ungadzalanditse ulemerero wako kwa anthu ena; 
\q2 ndi zaka zako kwa anthu ankhanza, 
\q1  
\v 10 kapenanso alendo angadyerere chuma chako 
\q2 ndi phindu la ntchito yako kulemeretsa anthu ena. 
\q1  
\v 11 Potsiriza pa moyo wako udzabuwula, 
\q2 thupi lako lonse litatheratu. 
\q1  
\v 12 Ndipo udzati, “Mayo ine, ndinkadana ndi kusunga mwambo! 
\q2 Mtima wanga unkanyoza chidzudzulo! 
\q1  
\v 13 Sindinamvere aphunzitsi anga 
\q2 kapena alangizi anga. 
\q1  
\v 14 Ine ndatsala pangʼono kuti ndiwonongeke 
\q2 pakati pa msonkhano wonse.” 
\b  
\q1  
\v 15 Imwa madzi a mʼchitsime chakochako, 
\q2 madzi abwino ochokera mʼchitsime chako. 
\q1  
\v 16 Kodi akasupe ako azingosefukira mʼmisewu? 
\q2 Kodi mitsinje yako izingoyendayenda mʼzipata za mzinda? 
\q1  
\v 17 Mitsinjeyo ikhale ya iwe wekha, 
\q2 osati uyigawireko alendo. 
\q1  
\v 18 Yehova adalitse kasupe wako, 
\q2 ndipo usangalale ndi mkazi wa unyamata wako. 
\q1  
\v 19 Iye uja ali ngati mbalale yayikazi yokongola ndiponso ngati gwape wa maonekedwe abwino. 
\q2 Ukhutitsidwe ndi mawere ake nthawi zonse, 
\q2 ndipo utengeke ndi chikondi chake nthawi zonse. 
\q1  
\v 20 Mwana wanga, nʼchifukwa chiyani ukukopeka ndi mkazi wachigololo? 
\q2 Bwanji ukukumbatira mkazi wachilendo? 
\b  
\q1  
\v 21 Pakuti mayendedwe onse a munthu Yehova amawaona, 
\q2 ndipo Iye amapenyetsetsa njira zake zonse. 
\q1  
\v 22 Ntchito zoyipa za munthu woyipa zimamukola yekha; 
\q2 zingwe za tchimo lake zimamumanga yekha. 
\q1  
\v 23 Iye adzafa chifukwa chosowa mwambo, 
\q2 adzasocheretsedwa chifukwa cha uchitsiru wake waukulu. 
\c 6  
\s2 Za Moyo wa Uchitsiru 
\q1  
\v 1 Mwana wanga, ngati wamuperekera mnansi wako chikole, 
\q2 ngati walonjeza kumulipirira mlendo, 
\q1  
\v 2 ngati wagwidwa ndi zimene iwe unanena, 
\q2 wakodwa ndi mawu a mʼkamwa mwako. 
\q1  
\v 3 Tsono popeza iwe mwana wanga 
\q2 wadziponya mʼmanja mwa mnansi wako, chita izi kuti udzipulumutse: 
\q1 pita msanga ukamupemphe mnansi wako; 
\q2 kuti akumasule! 
\q1  
\v 4 Usagone tulo, 
\q2 usawodzere. 
\q1  
\v 5 Dzipulumutse monga imachitira mphoyo mʼdzanja la mlenje, 
\q2 ndi monga imachitira mbalame mu msampha wa munthu wosaka. 
\b  
\q1  
\v 6 Pita kwa nyerere, mlesi iwe; 
\q2 kaonetsetse njira zake kuti uphunzirepo kanthu! 
\q1  
\v 7 Zilibe mfumu, 
\q2 zilibe woyangʼanira kapena wolamulira, 
\q1  
\v 8 komabe zimasungiratu chakudya chake nthawi ya chilimwe 
\q2 ndipo zimatuta chakudyacho nthawi yokolola. 
\b  
\q1  
\v 9 Kodi uzingogonabe pamenepo mpaka liti mlesi iwe? 
\q2 Kodi tulo tako tidzatha liti? 
\q1  
\v 10 Ukati ndingogona pangʼono, ndingowodzera pangʼono 
\q2 ndingopinda manjawa pangʼono kuti ndipumule, 
\q1  
\v 11 umphawi udzakugwira ngati mbala 
\q2 ndipo usiwa udzafika ngati munthu wachifwamba. 
\b  
\q1  
\v 12 Munthu wachabechabe, munthu woyipa, 
\q2 amangoyendayenda ndi kumayankhula zoyipa, 
\q2  
\v 13 amatsinzinira maso ake, 
\q2 namakwakwaza mapazi ake 
\q2 ndi kulozaloza ndi zala zake, 
\q2  
\v 14 amalingalira zoyipa ndi mtima wake wachinyengo 
\q2 ndipo nthawi zonse amangokhalira kuyambitsa mikangano pakati pa anthu. 
\q1  
\v 15 Nʼchifukwa chake tsoka lidzamugwera modzidzimutsa; 
\q2 adzawonongeka msangamsanga popanda chomupulumutsa. 
\b  
\q1  
\v 16 Pali zinthu zisanu ndi chimodzi zimene Yehova amadana nazo, 
\q2 zinthu zisanu ndi ziwiri zimene zimamunyansa: 
\q3  
\v 17 maso onyada, 
\q3 pakamwa pabodza, 
\q3 manja akupha munthu wosalakwa, 
\q3  
\v 18 mtima wokonzekera kuchita zoyipa, 
\q3 mapazi othamangira msanga ku zoyipa, 
\q3  
\v 19 mboni yonama yoyankhula mabodza 
\q3 komanso munthu amene amayambitsa mikangano pakati pa abale. 
\s2 Chenjezo pa za Chigololo 
\q1  
\v 20 Mwana wanga, usunge malamulo a abambo ako; 
\q2 ndipo usataye zimene anakuphunzitsa amayi ako. 
\q1  
\v 21 Zimenezi uzimatirire pa mtima pako masiku onse, 
\q2 uzimangirire mʼkhosi mwako. 
\q1  
\v 22 Ukamayenda, zidzakulozera njira; 
\q2 ukugona, zidzakulondera; 
\q2 ukudzuka, zidzakuyankhula. 
\q1  
\v 23 Paja malamulo awa ali ngati nyale, 
\q2 malangizowa ali ngati kuwunika, 
\q1 ndipo chidzudzulo cha mwambo ndiwo 
\q2 moyo weniweni, 
\q1  
\v 24 kukupulumutsa kwa mkazi wadama, 
\q2 zimenezi zidzakutchinjiriza kwa mkazi wadama, ndi kukuthandiza kuti usamvere mawu oshashalika a mkazi wachiwerewere. 
\q1  
\v 25 Mu mtima wako usakhumbire kukongola kwake, 
\q2 asakukope ndi zikope zake, 
\q1  
\v 26 paja mkazi wadama amakusandutsa kukhala ngati nyenyeswa za buledi 
\q2 ndipo mkazi wa mwini wake amasokonezeratu moyo wako wonse. 
\q1  
\v 27 Kodi munthu angathe kutenga moto 
\q2 zovala zake osapsa? 
\q1  
\v 28 Kodi munthu angathe kuyenda pa makala amoto 
\q2 mapazi ake osapserera? 
\q1  
\v 29 Ndizo zimachitikira munthu amene amagonana ndi mkazi wa munthu wina. 
\q2 Aliyense wokhudza mkazi wotere adzalangidwa. 
\b  
\q1  
\v 30 Paja anthu sayinyoza mbala ikaba 
\q2 chifukwa chakuti ili ndi njala. 
\q1  
\v 31 Komabe ngati mbalayo igwidwa iyenera kulipira kasanu nʼkawiri, 
\q2 ngakhale kulandidwa katundu wa mʼnyumba mwake. 
\q1  
\v 32 Munthu wochita chigololo ndi wopanda nzeru. 
\q2 Wochita zimenezi amangodziwononga yekha. 
\q1  
\v 33 Adzalandira mabala ndi mʼnyozo, 
\q2 ndipo manyazi ake sadzamuchokera. 
\q1  
\v 34 Paja nsanje imachititsa mwini mkaziyo kukalipa, 
\q2 ndipo sadzachita chifundo pobwezera. 
\q1  
\v 35 Iye savomera dipo lililonse; 
\q2 sangapepeseke ngakhale umupatse mphatso zochuluka motani. 
\c 7  
\s2 Za Mkazi Wachigololo 
\q1  
\v 1 Mwana wanga, mvera mawu anga; 
\q2 usunge bwino malamulo angawa. 
\q1  
\v 2 Utsate malamulo anga ndipo udzakhala ndi moyo; 
\q2 samala malangizo angawa monga uchitira ndi maso ako. 
\q1  
\v 3 Uchite ngati wawamangirira pa zala zako, 
\q2 ndiponso ngati kuti wawalemba pa mtima pako. 
\q1  
\v 4 Nzeru uyiwuze kuti, “Iwe ndiwe mlongo wanga,” 
\q2 ndipo khalidwe lomvetsa bwino zinthu ulitchule kuti, “Bwenzi langa lapamtima.” 
\q1  
\v 5 Zidzakuteteza kwa mkazi wachigololo 
\q2 ndiponso zidzakuthandiza kusamvera mawu oshashalika a mkazi wachilendo. 
\b  
\q1  
\v 6 Tsiku lina pa zenera la nyumba yanga 
\q2 ndinasuzumira pa zenera. 
\q1  
\v 7 Ndinaona pakati pa anthu opusa, 
\q2 pakati pa anyamata, 
\q2 mnyamata wina wopanda nzeru. 
\q1  
\v 8 Iye ankayenda njira yodutsa pafupi ndi nyumba ya mkaziyo, 
\q2 kuyenda molunjika nyumba ya mkaziyo. 
\q1  
\v 9 Inali nthawi yachisisira madzulo, 
\q2 nthawi ya usiku, kuli mdima. 
\b  
\q1  
\v 10 Ndipo mkaziyo anadzakumana naye, 
\q2 atavala ngati munthu wachiwerewere wa mtima wonyenga. 
\q1  
\v 11 (Mkaziyo ndi wolongolola ndiponso nkhutukumve, 
\q2 iye ndi wosakhazikika pa khomo. 
\q1  
\v 12 Mwina umupeza pa msewu, mwina umupeza pa msika, 
\q2 ndipo amadikirira munthu pa mphambano iliyonse). 
\q1  
\v 13 Tsono amagwira mnyamatayo ndi kupsompsona 
\q2 ndi nkhope yake yopanda manyazi amamuwuza kuti, 
\b  
\q1  
\v 14 “Ndinayenera kupereka nsembe zachiyanjano. 
\q2 Lero ndakwaniritsa malumbiro anga. 
\q1  
\v 15 Choncho ndinabwera kudzakumana nawe; 
\q2 ndinkakufunafuna ndipo ndakupeza! 
\q1  
\v 16 Pa bedi panga ndayalapo 
\q2 nsalu zosalala zokongola zochokera ku Igupto. 
\q1  
\v 17 Pa bedi panga ndawazapo zonunkhira 
\q2 za mure, mafuta onunkhira a aloe ndi sinamoni. 
\q1  
\v 18 Bwera, tiye tikhale malo amodzi kukondwerera chikondi mpaka mmawa; 
\q2 tiye tisangalatsane mwachikondi! 
\q1  
\v 19 Mwamuna wanga kulibe ku nyumbako; 
\q2 wapita ulendo wautali: 
\q1  
\v 20 Anatenga thumba la ndalama 
\q2 ndipo adzabwera ku nyumba mwezi ukakhwima.” 
\b  
\q1  
\v 21 Ndi mawu ake onyengerera amamukakamiza mnyamatayo; 
\q2 amukopa ndi mawu ake oshashalika. 
\q1  
\v 22 Nthawi yomweyo chitsiru chimamutsatira mkaziyo 
\q2 ngati ngʼombe yopita kukaphedwa, 
\q1 monga momwe mbawala ikodwera mu msampha, 
\q2  
\v 23 mpaka muvi utalasa chiwindi chake, 
\q1 chimakhala ngati mbalame yothamangira mʼkhwekhwe, 
\q2 osadziwa kuti moyo wake uwonongeka. 
\b  
\q1  
\v 24 Tsono ana inu, ndimvereni; 
\q2 mvetsetsani zimene ndikunena. 
\q1  
\v 25 Musatengeke mtima ndi njira za mkazi ameneyu; 
\q2 musasochere potsata njira zake. 
\q1  
\v 26 Paja iye anagwetsa anthu ambiri; 
\q2 wapha gulu lalikulu la anthu. 
\q1  
\v 27 Nyumba yake ndi njira yopita ku manda, 
\q2 yotsikira ku malo a anthu akufa. 
\c 8  
\s2 Nzeru Ikuyitana 
\q1  
\v 1 Kodi nzeru sikuyitana? 
\q2 Kodi nzeru yomvetsa zinthu sinakweze mawu ake? 
\q1  
\v 2 Nzeru imayima pa zitunda mʼmbali mwa njira, 
\q2 imayima pa mphambano ya misewu. 
\q1  
\v 3 Imafuwula pafupi ndi zipata zolowera mu mzinda, 
\q2 pa makomo olowera imafuwula kuti, 
\q1  
\v 4 Inu anthu, ndikuyitana inu; 
\q2 ndikuyitanatu anthu onse. 
\q1  
\v 5 Inu amene simudziwa kanthunu khalani ochenjera; 
\q2 inu amene ndi opusa, khalani ndi mtima womvetsa zinthu. 
\q1  
\v 6 Mverani, pakuti ndikukuwuzani zinthu zofunika kwambiri; 
\q2 ndatsekula pakamwa panga ndipo payankhula zolungama. 
\q1  
\v 7 Pakamwa panga pamayankhula zoona 
\q2 ndimanyansidwa ndi kuyankhula zoyipa. 
\q1  
\v 8 Mawu onse a pakamwa panga ndi olungama; 
\q2 mʼmawu angawo mulibe zokhotakhota kapena zopotoka. 
\q1  
\v 9 Kwa anthu ozindikira, mawu anga onse ndi woona; 
\q2 kwa anthu amene ali ndi nzeru zomvetsa zinthu, mawu angawo ndi okhoza. 
\q1  
\v 10 Landirani malangizo anga mʼmalo mwa siliva, 
\q2 nzeru zomvetsa zinthu mʼmalo mwa golide wabwino. 
\q1  
\v 11 Paja nzeru ndi yabwino kwambiri kuposa miyala yamtengowapatali, 
\q2 ndipo zonse zimene ungazifune sizingafanane ndi nzeru. 
\b  
\q1  
\v 12 Ine nzeru, ndimakhala pamodzi ndi kuchenjera. 
\q2 Ine ndimadziwa zinthu ndiponso ndimalingalira zinthu bwino. 
\q1  
\v 13 Kuopa Yehova ndiko kudana ndi zoyipa. 
\q2 Ine ndimadana ndi kunyada, kudzitama, 
\q2 kuchita zoyipa, ndiponso kuyankhula zonyenga. 
\q1  
\v 14 Ndine mwini uphungu ndi maganizo abwino; 
\q2 ndili ndi nzeru yomvetsa zinthu ndiponso mphamvu. 
\q1  
\v 15 Ndine amene ndimathandiza mafumu kulamulira. 
\q2 Ndimawathandiza olamulira kukhazikitsa malamulo olungama. 
\q1  
\v 16 Ndine amene ndimathandiza akalonga polamula. 
\q2 Ndinenso amene ndimathandiza akuluakulu onse kulamulira bwino dziko. 
\q1  
\v 17 Ndimakonda amene amandikonda, 
\q2 ndipo amene amandifunafuna amandipeza. 
\q1  
\v 18 Ine ndili ndi chuma ndi ulemu, 
\q2 chuma ndi kupindula pa ntchito kokhazikika. 
\q1  
\v 19 Chipatso changa ndi chabwino kuposa golide, ngakhale golide wosalala; 
\q2 zimene ine ndimabereka zimaposa siliva wabwino kwambiri. 
\q1  
\v 20 Ndimachita zinthu zolungama. 
\q2 Ine sindipatuka mʼnjira za chilungamo. 
\q1  
\v 21 Ndimapereka chuma kwa amene amandikonda 
\q2 ndi kudzaza nyumba zawo zosungiramo chuma. 
\b  
\q1  
\v 22 “Yehova anandilenga ine nzeru monga ntchito yake yoyamba. 
\q2 Mwa ntchito zake zakalekale yoyamba ndinali ine. 
\q1  
\v 23 Ndinapangidwa kalekalelo, 
\q2 pachiyambi penipeni dziko lapansi lisanalengedwe. 
\q1  
\v 24 Nyanja, akasupe odzaza ndi madzi, 
\q2 zonsezi kulibe pamene ine ndinkabadwa. 
\q1  
\v 25 Mapiri asanakhazikitsidwe pa malo awo, 
\q2 mapiri angʼonoangʼono asanakhalepo, ine ndinali nditabadwa kale, 
\q1  
\v 26 lisanalengedwe dziko lapansi ndi minda yake; 
\q2 lisanalengedwe dothi loyamba la dziko lapansi. 
\q1  
\v 27 Ine ndinalipo pamene Yehova ankakhazikitsa mlengalenga, 
\q2 pamene ankalemba malire a nyanja yozama, 
\q1  
\v 28 pamene anakhazikitsa mitambo ya mlengalenga 
\q2 ndi kukhazikitsa akasupe a madzi ozama, 
\q1  
\v 29 pamene anayikira nyanja malire 
\q2 kuti madzi asadutse malirewo, 
\q1 ndiponso pamene ankayika malire a dziko lapansi. 
\q2  
\v 30 Tsono ine ndinali pambali pake ngati mmisiri; 
\q1 ndikumukondweretsa tsiku ndi tsiku, 
\q2 kusangalala nthawi zonse pamaso pake. 
\q1  
\v 31 Ndinkasangalala ndi dziko lake lonse 
\q2 ndiponso kumakondwera nawo anthu onse.” 
\b  
\q1  
\v 32 “Ndiye tsono ana inu, ndimvereni; 
\q2 odala anthu amene amasunga njira zanga. 
\q1  
\v 33 Mverani malangizo anga kuti mukhale ndi nzeru; 
\q2 musanyozere mawu anga. 
\q1  
\v 34 Wodala munthu amene amandimvera, 
\q2 amene amakhala pa khomo panga tsiku ndi tsiku, 
\q2 kudikirira pa chitseko changa. 
\q1  
\v 35 Paja aliyense amene apeza ine wapeza moyo 
\q2 ndipo Yehova amamukomera mtima. 
\q1  
\v 36 Koma amene alephera kundipeza, amadzipweteka yekha; 
\q2 onse amene amandida amakonda imfa.” 
\c 9  
\s2 Za Nzeru ndi Uchitsiru 
\q1  
\v 1 Nzeru inamanga nyumba yake; 
\q2 inayimika nsanamira zake zisanu ndi ziwiri. 
\q1  
\v 2 Inapha ziweto zake ndipo yasakaniza vinyo wake; 
\q2 inasakaniza vinyo wake ndi kuyala tebulo lake. 
\q1  
\v 3 Nzeruyo inatuma adzakazi ake, 
\q2 kuti akakhale pamwamba penipeni pa mzinda ndi kukalengeza kuti, 
\q1  
\v 4 “Aliyense amene ali munthu wamba, abwere kuno!” 
\q2 Kwa onse opanda nzeru inkanena kuti, 
\q1  
\v 5 “Bwerani, dzadyeni chakudya changa 
\q2 ndipo dzamweni vinyo amene ndakonza. 
\q1  
\v 6 Lekani zopusa zanu kuti mukhale ndi moyo; 
\q2 yendani njira ya nzeru yomvetsa zinthu.” 
\b  
\q1  
\v 7 Aliyense amene amayesa kukonza munthu wonyoza amadziputira minyozo; 
\q2 aliyense amene amadzudzula munthu woyipa amadetsa mbiri yake. 
\q1  
\v 8 Usadzudzule munthu wonyoza kuti angadzadane nawe; 
\q2 dzudzula munthu wanzeru ndipo adzakukonda. 
\q1  
\v 9 Ukalangiza munthu wanzeru ndiye adzapitirira kukhala wanzeru; 
\q2 ukaphunzitsa munthu wolungama ndiye adzawonjezera kuphunzira kwake. 
\b  
\q1  
\v 10 Kuopa Yehova ndiye chiyambi cha nzeru; 
\q2 kudziwa Woyerayo ndiko kukhala womvetsa bwino zinthu. 
\q1  
\v 11 Chifukwa cha ine nzeru, masiku ako adzachuluka, 
\q2 ndipo zaka za moyo wako zidzawonjezeredwa. 
\q1  
\v 12 Ngati ndiwe wanzeru, nzeru yakoyo idzakupindulitsa; 
\q2 ngati ndiwe wonyoza ena, udzavutika wekha. 
\b  
\q1  
\v 13 Uchitsiru ndi mkazi waphokoso, 
\q2 wopulikira ndiponso wosadziwa zinthu. 
\q1  
\v 14 Iye amakhala pa mpando, pa khomo la nyumba yake, 
\q2 pamalo aatali a mu mzinda, 
\q1  
\v 15 kuti aziyitana anthu ongodutsa, 
\q2 amene akunka nayenda njira zawo. 
\q1  
\v 16 Amati, “Onse amene ndi anthu wamba abwere kuno,” 
\q2 ndipo kwa wopanda nzeru amati, 
\q1  
\v 17 “Madzi akuba ndiye amatsekemera; 
\q2 chakudya chodya mobisa ndi chokoma!” 
\q1  
\v 18 Koma amunawo sadziwa kuti akufa ali kale komweko, 
\q2 ndi kuti alendo ake alowa kale mʼmanda akuya. 
\c 10  
\s1 Miyambo ya Solomoni 
\p  
\v 1 Miyambo ya Solomoni: 
\q1 Mwana wanzeru amakondweretsa abambo ake, 
\q2 koma mwana wopusa amamvetsa amayi ake chisoni. 
\b  
\q1  
\v 2 Chuma chochipeza mwachinyengo sichipindulitsa, 
\q2 koma chilungamo chimapulumutsa ku imfa. 
\b  
\q1  
\v 3 Yehova salola kuti munthu wolungama azikhala ndi njala; 
\q2 koma amalepheretsa zokhumba za anthu oyipa. 
\b  
\q1  
\v 4 Wochita zinthu mwaulesi amasauka, 
\q2 koma wogwira ntchito mwakhama amalemera. 
\b  
\q1  
\v 5 Amene amakolola nthawi yachilimwe ndi mwana wanzeru, 
\q2 koma amene amangogona nthawi yokolola ndi mwana wochititsa manyazi. 
\b  
\q1  
\v 6 Madalitso amakhala pa mutu wa munthu wolungama, 
\q2 koma pakamwa pa munthu woyipa pamaphimba chiwawa. 
\b  
\q1  
\v 7 Munthu wolungama anzake adzamukumbukira ngati mdalitso, 
\q2 koma dzina la munthu woyipa lidzayiwalika. 
\b  
\q1  
\v 8 Munthu wa mtima wanzeru amasamala malamulo, 
\q2 koma chitsiru chomangolongolola chidzawonongeka. 
\b  
\q1  
\v 9 Munthu woyenda mwangwiro amayenda mosatekeseka; 
\q2 koma amene amayenda njira yokhotakhota adzadziwika. 
\b  
\q1  
\v 10 Aliyense wotsinzinira maso mwachinyengo amabweretsa mavuto, 
\q2 koma wodzudzula chitsiru molimba mtima amabweretsa mtendere. 
\b  
\q1  
\v 11 Pakamwa pa munthu wolungama ndi kasupe wamoyo, 
\q2 koma pakamwa pa munthu woyipa pamabisa chiwawa. 
\b  
\q1  
\v 12 Udani umawutsa mikangano, 
\q2 koma chikondi chimaphimba zolakwa zonse. 
\b  
\q1  
\v 13 Nzeru imapezeka pa milomo ya munthu wozindikira zinthu, 
\q2 koma pa msana pa munthu wopanda nzeru sipachoka chikwapu. 
\b  
\q1  
\v 14 Anzeru amasunga chidziwitso 
\q2 koma pakamwa pa chitsiru pamatulutsa zowononga. 
\b  
\q1  
\v 15 Chuma cha munthu wolemera 
\q2 ndiye chitetezo chake; koma umphawi ndiye chiwonongeko cha osauka. 
\b  
\q1  
\v 16 Moyo ndiye malipiro a munthu wolungama, 
\q2 koma phindu la anthu oyipa ndi uchimo ndi imfa. 
\b  
\q1  
\v 17 Wosamalira malangizo amayenda mʼnjira ya moyo, 
\q2 koma wonyoza chidzudzulo amasochera. 
\b  
\q1  
\v 18 Amene amabisa chidani chake ndi munthu wonama, 
\q2 ndipo amene amafalitsa miseche ndi chitsiru. 
\b  
\q1  
\v 19 Mawu akachuluka zolakwa sizisowa, 
\q2 koma amene amasunga pakamwa pake ndi wanzeru. 
\b  
\q1  
\v 20 Mawu a munthu wolungama ali ngati siliva wabwino kwambiri, 
\q2 koma mtima wa munthu woyipa ndi wopanda phindu. 
\b  
\q1  
\v 21 Milomo ya anthu olungama imalimbikitsa ambiri; 
\q2 koma chitsiru chimafa chifukwa chosowa nzeru. 
\b  
\q1  
\v 22 Mdalitso wa Yehova ndiwo umabweretsa chuma, 
\q2 ntchito za munthu siziwonjezerapo kanthu. 
\b  
\q1  
\v 23 Kwa chitsiru kuchita zinthu zoyipa ndiye chinthu chomusangalatsa, 
\q2 koma kwa munthu womvetsa bwino zinthu nzeru ndiyo imamusangalatsa. 
\b  
\q1  
\v 24 Chimene munthu woyipa amachiopa chidzamuchitikira; 
\q2 chimene munthu wolungama amachilakalaka adzachipeza. 
\b  
\q1  
\v 25 Pamene namondwe wawomba, anthu oyipa amachotsedwa, 
\q2 koma anthu olungama amakhazikika mpaka muyaya. 
\b  
\q1  
\v 26 Momwe amakhalira vinyo wosasa mʼkamwa ndi momwe umakhalira utsi mʼmaso, 
\q2 ndi momwenso amakhalira munthu waulesi kwa amene amutuma. 
\b  
\q1  
\v 27 Kuopa Yehova kumatalikitsa moyo; 
\q2 koma zaka za anthu oyipa zidzafupikitsidwa. 
\b  
\q1  
\v 28 Chiyembekezo cha olungama chimapatsa chimwemwe, 
\q2 koma chiyembekezo cha anthu ochimwa chidzafera mʼmazira. 
\b  
\q1  
\v 29 Njira za Yehova ndi linga loteteza anthu ochita zabwino, 
\q2 koma wochita zoyipa adzawonongeka. 
\b  
\q1  
\v 30 Munthu wolungama sadzachotsedwa, pamalo pake 
\q2 koma oyipa sadzakhazikika pa dziko. 
\b  
\q1  
\v 31 Pakamwa pa munthu wolungama pamatulutsa za nzeru, 
\q2 koma lilime lokhota lidzadulidwa. 
\b  
\q1  
\v 32 Milomo ya anthu olungama imadziwa zoyenera kuyankhula, 
\q2 koma pakamwa pa anthu ochimwa pamatulutsa zokhota zokhazokha. 
\c 11  
\q1  
\v 1 Muyeso wachinyengo Yehova umamunyansa, 
\q2 koma amakondwera ndi muyeso woyenera. 
\b  
\q1  
\v 2 Kunyada kukalowa, pamafikanso manyazi, 
\q2 koma pamene pali kudzichepetsa pameneponso pali nzeru. 
\b  
\q1  
\v 3 Ungwiro wa anthu olungama umawatsogolera, 
\q2 koma anthu osakhulupirika amawonongeka ndi chinyengo chawo. 
\b  
\q1  
\v 4 Chuma sichithandiza pa tsiku lawukali wa Mulungu, 
\q2 koma chilungamo chimapulumutsa ku imfa. 
\b  
\q1  
\v 5 Chilungamo cha anthu angwiro chimawongolera moyo wawo, 
\q2 koma ntchito zoyipa zimagwetsa mwini wake yemweyo. 
\b  
\q1  
\v 6 Chilungamo cha anthu oyera mtima chimawapulumutsa, 
\q2 koma anthu onyenga adzagwidwa ndi zilakolako zawo zomwe. 
\b  
\q1  
\v 7 Pamene munthu woyipa wafa, chiyembekezo chake chimathanso. 
\q2 Chiyembekezo cha munthu wosalungama chimawonongeka. 
\b  
\q1  
\v 8 Munthu wolungama amapulumutsidwa ku mavuto, 
\q2 koma mʼmalo mwake amagwa mʼmavutomo ndi anthu oyipa. 
\b  
\q1  
\v 9 Munthu wosapembedza amawononga mnansi wake ndi pakamwa pake, 
\q2 koma munthu wolungama amapulumuka chifukwa cha kudziwa zinthu. 
\b  
\q1  
\v 10 Anthu olungama zinthu zikamawayendera bwino, mzinda wonse umakondwera, 
\q2 ndipo oyipa akamawonongeka anthu amafuwula mwachimwemwe. 
\b  
\q1  
\v 11 Mzinda umakwezeka chifukwa cha madalitso a anthu oyera mtima, 
\q2 koma umawonongedwa chifukwa cha pakamwa pa anthu oyipa. 
\b  
\q1  
\v 12 Munthu wonyoza mnzake ndi wopanda nzeru, 
\q2 koma munthu wanzeru zomvetsa zinthu amakhala chete. 
\b  
\q1  
\v 13 Amene amanka nachita ukazitape amawulula zinsinsi; 
\q2 koma munthu wokhulupirika amasunga pakamwa pake. 
\b  
\q1  
\v 14 Pakasoweka uphungu mtundu wa anthu umagwa; 
\q2 koma pakakhala aphungu ambiri pamakhalanso chipulumutso. 
\b  
\q1  
\v 15 Woperekera mlendo chikole adzapeza mavuto, 
\q2 koma wodana ndi za chikole amakhala pa mtendere. 
\b  
\q1  
\v 16 Mkazi wodekha amalandira ulemu, 
\q2 koma amuna ankhanza amangopata chuma. 
\b  
\q1  
\v 17 Munthu wachifundo amadzipindulira zabwino 
\q2 koma munthu wankhanza amadzibweretsera mavuto. 
\b  
\q1  
\v 18 Munthu woyipa amalandira malipiro wopanda phindu, 
\q2 koma wochita chilungamo amakolola mphotho yeniyeni. 
\b  
\q1  
\v 19 Munthu wochita za chilungamo amapeza moyo, 
\q2 koma wothamangira zoyipa adzafa. 
\b  
\q1  
\v 20 Yehova amanyansidwa ndi anthu a mtima wokhotakhota 
\q2 koma amakondwera ndi anthu a makhalidwe angwiro. 
\b  
\q1  
\v 21 Zoonadi, anthu oyipa adzalangidwa, 
\q2 koma anthu olungama adzapulumuka. 
\b  
\q1  
\v 22 Monga imaonekera mphete yagolide ikakhala pa mphuno ya nkhumba, 
\q2 ndi momwenso amaonekera mkazi wokongola wamʼkamwa. 
\b  
\q1  
\v 23 Zokhumba za anthu olungama zimathera pa zabwino zokhazokha, 
\q2 koma chiyembekezo cha anthu oyipa chimathera mu ukali wa Mulungu. 
\b  
\q1  
\v 24 Munthu wina amapatsako anzake zinthu mwaufulu nʼkumangolemererabe; 
\q2 wina amamana chomwe akanatha kupereka, koma kumanka nasawukabe. 
\b  
\q1  
\v 25 Munthu wopereka mowolowamanja adzalemera; 
\q2 iye amene amathandiza ena iyenso adzathandizidwa. 
\b  
\q1  
\v 26 Anthu amatemberera womana anzake chakudya, 
\q2 koma madalitso amakhala pamutu pa munthu amene amagulitsa chakudyacho. 
\b  
\q1  
\v 27 Iye amene amafunafuna zabwino mwakhama amapeza zabwinozo, 
\q2 koma wofunafuna zoyipa zidzamupeza. 
\b  
\q1  
\v 28 Aliyense amene amadalira chuma chake adzafota, 
\q2 koma wolungama adzaphukira ngati tsamba lobiriwira. 
\b  
\q1  
\v 29 Wovutitsa a mʼnyumba mwake adzalowa mʼmavuto, 
\q2 ndipo chitsiru chidzakhala kapolo wa munthu wa nzeru. 
\b  
\q1  
\v 30 Chipatso cha ntchito zabwino ndi moyo, 
\q2 ndipo kusatsata malamulo kumawonongetsa moyo. 
\b  
\q1  
\v 31 Ngati anthu olungama amalandira mphotho zawo pa dziko lapansi, 
\q2 kuli bwanji anthu osapembedza ndi ochimwa! 
\c 12  
\q1  
\v 1 Munthu amene amakonda mwambo amakonda kudziwa zinthu, 
\q2 koma amene amadana ndi chidzudzulo ndi wopusa. 
\b  
\q1  
\v 2 Munthu wabwino amapeza kuyanja pamaso pa Yehova, 
\q2 koma Yehova amatsutsa munthu wochita chinyengo. 
\b  
\q1  
\v 3 Munthu sangakhazikike bwino pochita zoyipa, 
\q2 koma maziko a anthu olungama sadzatekeseka. 
\b  
\q1  
\v 4 Mkazi wakhalidwe labwino ali ngati chipewa chaufumu kwa mwamuna wake, 
\q2 koma mkazi wochititsa manyazi ali ngati chilonda cha mafinya kwa mwamuna wake. 
\b  
\q1  
\v 5 Maganizo a anthu olungama ndi owongoka, 
\q2 koma malangizo a anthu oyipa ndi achinyengo. 
\b  
\q1  
\v 6 Mawu a anthu oyipa ndi ophetsa, 
\q2 koma mawu a anthu olungama amapulumutsa. 
\b  
\q1  
\v 7 Anthu oyipa amagonjetsedwa ndipo amayiwalika, 
\q2 koma nyumba ya anthu olungama idzakhalabe. 
\b  
\q1  
\v 8 Munthu amatamandidwa malinga ndi nzeru zake, 
\q2 koma anthu amitima yokhota amanyozedwa. 
\b  
\q1  
\v 9 Nʼkwabwino kukhala munthu wonyozeka koma wodzigwirira ntchito nʼkukhala ndi zonse zofunika, 
\q2 kuposa kukhala wodzikuza koma ulibe ndi chakudya chomwe. 
\b  
\q1  
\v 10 Munthu wolungama amasamalira moyo wa ziweto zake, 
\q2 koma chifundo cha munthu woyipa ndi chakhanza. 
\b  
\q1  
\v 11 Wolima mʼmunda mwake mwakhama adzakhala ndi chakudya chochuluka, 
\q2 koma wotsata zopanda pake alibe nzeru. 
\b  
\q1  
\v 12 Munthu woyipa amalakalaka zofunkha za anthu oyipa, 
\q2 koma mizu ya anthu olungama imabereka zipatso. 
\b  
\q1  
\v 13 Munthu woyipa amakodwa mu msampha wa mayankhulidwe ake oyipa; 
\q2 koma munthu wolungama amatuluka mʼmavuto. 
\b  
\q1  
\v 14 Munthu amakhala ndi zabwino zambiri chifukwa cha mawu ake 
\q2 ndipo ntchito zimene munthu agwira ndi manja ake zimamupindulira. 
\b  
\q1  
\v 15 Zochita za chitsiru mwini wakeyo amaziona ngati zabwino, 
\q2 koma munthu wanzeru amamvera malangizo. 
\b  
\q1  
\v 16 Mkwiyo wa chitsiru umadziwika nthawi yomweyo, 
\q2 koma munthu wanzeru sasamala kunyozedwa. 
\b  
\q1  
\v 17 Woyankhula zoona amapereka umboni woona, 
\q2 koma mboni yabodza imafotokoza zonama. 
\b  
\q1  
\v 18 Munthu woyankhula mosasamala mawu ake amalasa ngati lupanga, 
\q2 koma mawu a munthu wanzeru amachiritsa. 
\b  
\q1  
\v 19 Mawu woona amakhala mpaka muyaya 
\q2 koma mawu abodza sakhalitsa. 
\b  
\q1  
\v 20 Mʼmitima ya anthu amene amakonza zoyipa muli chinyengo; 
\q2 koma anthu olimbikitsa za mtendere amakhala ndi chimwemwe. 
\b  
\q1  
\v 21 Palibe choyipa chimene chimagwera munthu wolungama, 
\q2 koma munthu woyipa mavuto samuthera. 
\b  
\q1  
\v 22 Pakamwa pa bodza pamamunyansa Yehova, 
\q2 koma amakondwera ndi anthu oyankhula zoona. 
\b  
\q1  
\v 23 Munthu wochenjera amabisa nzeru zake, 
\q2 koma munthu wopusa amaonetsa uchitsiru wake poyera. 
\b  
\q1  
\v 24 Ogwira ntchito mwakhama adzalamulira, 
\q2 koma aulesi adzakhala ngati kapolo. 
\b  
\q1  
\v 25 Nkhawa imakhala ngati katundu wolemera mu mtima mwa munthu, 
\q2 koma mawu abwino amamusangalatsa. 
\b  
\q1  
\v 26 Munthu wolungama amatsogolera mnansi wake, 
\q2 koma ntchito za anthu oyipa zimawasocheretsa. 
\b  
\q1  
\v 27 Munthu waulesi sapeza chimene akufuna, 
\q2 koma munthu wakhama amapeza chuma chamtengo wapatali. 
\b  
\q1  
\v 28 Mʼnjira yachilungamo muli moyo; 
\q2 koma njira ya munthu woyipa imafikitsa ku imfa. 
\c 13  
\q1  
\v 1 Mwana wanzeru amamvera malangizo a abambo ake, 
\q2 koma mwana wonyoza samamvetsera chidzudzulo. 
\b  
\q1  
\v 2 Munthu amapeza zinthu zabwino chifukwa cha mawu ake, 
\q2 koma anthu osakhulupirika amalakalaka zachiwawa basi. 
\b  
\q1  
\v 3 Iye amene amagwira pakamwa pake amateteza moyo wake, 
\q2 koma amene amayankhula zopanda pake adzawonongeka. 
\b  
\q1  
\v 4 Munthu waulesi amakhumbira zinthu koma sapeza kanthu, 
\q2 koma munthu wakhama adzalemera. 
\b  
\q1  
\v 5 Munthu wolungama amadana ndi zabodza, 
\q2 koma zochita za munthu woyipa zimanyansa ndiponso zimachititsa manyazi. 
\b  
\q1  
\v 6 Chilungamo chimateteza munthu wangwiro, 
\q2 koma tchimo limagwetsa munthu wochimwa. 
\b  
\q1  
\v 7 Wina amadziyesa kuti ndi wolemera chonsecho alibe kanthu kalikonse; 
\q2 munthu wina amaoneka ngati wosauka chonsecho ali ndi chuma chambiri. 
\b  
\q1  
\v 8 Chuma cha munthu wolemera chitha kuwombola moyo wake, 
\q2 koma munthu wosauka amamva chidzudzulo. 
\b  
\q1  
\v 9 Nyale ya munthu wolungama ndi yokondweretsa, 
\q2 koma nyale ya munthu woyipa imazimitsidwa. 
\b  
\q1  
\v 10 Chipongwe chosamalabadirako za anthu ena chimadzetsa mikangano, 
\q2 koma womva malangizo a anzawo ndiwo ali ndi nzeru. 
\b  
\q1  
\v 11 Chuma chochipeza mofulumira chidzatha pangʼonopangʼono 
\q2 koma chuma chosonkhanitsidwa pangʼonopangʼono chidzachulukirachulukira. 
\b  
\q1  
\v 12 Chinthu chochiyembekezera chikalephereka chimalefula mtima, 
\q2 koma chinthu chochilakalaka chikachitikadi chimakhala ngati mtengo wamoyo. 
\b  
\q1  
\v 13 Amene amanyoza malangizo adzawonongeka, 
\q2 koma amene amasamala lamulo amalandira mphotho. 
\b  
\q1  
\v 14 Malangizo a munthu wanzeru ali ngati kasupe wamoyo; 
\q2 amathandiza munthu kuti asakondwe mu msampha wa imfa. 
\b  
\q1  
\v 15 Munthu wa nzeru zabwino amapeza kuyanja pakati pa anthu, 
\q2 koma munthu wosakhulupirika adzawonongeka. 
\b  
\q1  
\v 16 Munthu wochenjera amachita zinthu mwanzeru, 
\q2 koma chitsiru chimaonetsa poyera uchitsiru wake. 
\b  
\q1  
\v 17 Wamthenga woyipa amagwetsa anthu mʼmavuto, 
\q2 koma nthumwi yodalirika imabweretsa mtendere. 
\b  
\q1  
\v 18 Wokana mwambo adzasauka ndi kunyozedwa, 
\q2 koma wosamala chidzudzulo adzalemekezedwa. 
\b  
\q1  
\v 19 Chinthu chochilakalaka chikachitika chimasangalatsa mtima, 
\q2 koma zitsiru zimadana ndi kuleka zoyipa. 
\b  
\q1  
\v 20 Woyenda ndi anthu anzeru nayenso adzakhala wanzeru; 
\q2 koma woyenda ndi zitsiru adzapwetekeka. 
\b  
\q1  
\v 21 Choyipa chitsata mwini, 
\q2 koma wochita zolungama adzalandira mphotho yabwino. 
\b  
\q1  
\v 22 Munthu wabwino amasiyira zidzukulu zake cholowa, 
\q2 koma chuma cha munthu wochimwa amachilandira ndi olungama. 
\b  
\q1  
\v 23 Tsala la munthu wosauka limalola chakudya chambiri, 
\q2 koma anthu opanda chilungamo amachilanda. 
\b  
\q1  
\v 24 Amene sakwapula mwana wake, ndiye kuti amamuda, 
\q2 koma wokonda mwana wake sazengereza kumulanga. 
\b  
\q1  
\v 25 Munthu wolungama amakhala ndi zakudya zoti adye nʼkukhuta, 
\q2 koma mʼmimba mwa munthu woyipa mumakhala pululu ndi njala. 
\c 14  
\q1  
\v 1 Mkazi wanzeru amamanga banja lake, 
\q2 koma mkazi wopusa amalimasula ndi manja ake omwe. 
\b  
\q1  
\v 2 Amene amayenda molungama amaopa Yehova, 
\q2 koma amene njira zake ndi zoyipa amanyoza Yehova. 
\b  
\q1  
\v 3 Kuyankhula kwa chitsiru kumamuyitanira ndodo pa msana, 
\q2 koma milomo ya munthu wanzeru imamuteteza. 
\b  
\q1  
\v 4 Pakasowa ngʼombe zolima gome limakhala lopanda chakudya, 
\q2 koma pakakhala ngʼombe zamphamvu zakudya zimachulukanso. 
\b  
\q1  
\v 5 Mboni yokhulupirika sinama, 
\q2 koma mboni yonyenga imayankhula zabodza. 
\b  
\q1  
\v 6 Wonyoza anzake amafunafuna nzeru koma osayipeza, 
\q2 koma munthu womvetsa bwino amadziwa zinthu msanga. 
\b  
\q1  
\v 7 Khala kutali ndi munthu wopusa 
\q2 chifukwa sudzapeza mawu a nzeru. 
\b  
\q1  
\v 8 Nzeru za munthu wochenjera zagona pakuzindikira njira zake. 
\q2 Koma uchitsiru wa zitsiru umapusitsidwa ndi chinyengo chawo chomwe. 
\b  
\q1  
\v 9 Zitsiru zimanyoza za kulapa machimo, awo, 
\q2 koma kufuna kwabwino kumapezeka mwa anthu olungama. 
\b  
\q1  
\v 10 Mtima uliwonse umadziwa wokha zowawa zake, 
\q2 ndipo palibe wina aliyense angadziwe kukondwa kwake. 
\b  
\q1  
\v 11 Nyumba ya munthu woyipa idzapasuka, 
\q2 koma tenti ya munthu wowongoka mtima idzakhazikika. 
\b  
\q1  
\v 12 Pali njira ina yooneka ngati yabwino kwa munthu, 
\q2 koma kumatsiriziro kwake ndi ku imfa. 
\b  
\q1  
\v 13 Ngakhale poseka mtima utha kumva kuwawa, 
\q2 ndipo mathero achimwemwe akhoza kukhala chisoni. 
\b  
\q1  
\v 14 Munthu wosakhulupirika adzalandira zogwirizana ndi ntchito yake, 
\q2 koma munthu wabwino adzalandira mphotho ya ntchito yake. 
\b  
\q1  
\v 15 Munthu wopusa amakhulupirira chilichonse, 
\q2 koma munthu wochenjera amaganizira bwino mayendedwe ake. 
\b  
\q1  
\v 16 Munthu wanzeru amaopa Mulungu ndipo amapewa zoyipa, 
\q2 koma munthu wopusa ndi wokula mtima amakhala wosasamala. 
\b  
\q1  
\v 17 Munthu wopsa mtima msanga amachita zinthu za uchitsiru, 
\q2 ndipo anthu amadana ndi munthu wachinyengo. 
\b  
\q1  
\v 18 Anthu opusa amalandira uchitsiru, 
\q2 koma anthu ochenjera amavekedwa chipewa cha ulemerero wa kudziwa zinthu. 
\b  
\q1  
\v 19 Anthu oyipa adzagwada pamaso pa anthu abwino, 
\q2 ndipo anthu oyipa adzapempha thandizo kwa anthu olungama. 
\b  
\q1  
\v 20 Munthu wosauka ngakhale anansi ake omwe amamuda, 
\q2 koma munthu wolemera ali ndi abwenzi ambiri. 
\b  
\q1  
\v 21 Wonyoza mnansi wake ndi wochimwa 
\q2 koma ndi wodala amene amachitira chifundo anthu osowa. 
\b  
\q1  
\v 22 Kodi amene amakonzekera zoyipa sasochera? 
\q2 Koma amene amakonzekera zabwino anthu amawaonetsa chikondi ndi kukhulupirika. 
\b  
\q1  
\v 23 Ntchito iliyonse imakhala ndi phindu, 
\q2 koma kuyankhulayankhula kumabweretsa umphawi. 
\b  
\q1  
\v 24 Chipewa chaulemu cha anthu a nzeru ndi chuma chawo chomwe, 
\q2 koma malipiro a zitsiru ndi uchitsiru. 
\b  
\q1  
\v 25 Mboni yokhulupirika imapulumutsa miyoyo, 
\q2 koma mboni yabodza imaphetsa. 
\b  
\q1  
\v 26 Amene amaopa Yehova ali ndi chitetezo chokwanira 
\q2 ndipo iye adzakhala pothawira pa ana ake. 
\b  
\q1  
\v 27 Kuopa Yehova ndiye kasupe wamoyo, 
\q2 kumathandiza munthu kuti apewe msampha wa imfa. 
\b  
\q1  
\v 28 Gulu lalikulu la anthu ndiye ulemerero wa mfumu, 
\q2 koma popanda anthu kalonga amawonongeka. 
\b  
\q1  
\v 29 Munthu wosapsa mtima msanga amamvetsa zinthu kwambiri, 
\q2 koma munthu wopsa mtima msanga amaonetsa uchitsiru wake. 
\b  
\q1  
\v 30 Mtima wodekha umapatsa thupi moyo, 
\q2 koma nsanje imawoletsa mafupa. 
\b  
\q1  
\v 31 Amene amapondereza mʼmphawi amanyoza mlengi wake, 
\q2 koma wochitira chifundo munthu wosowa amalemekeza Mulungu. 
\b  
\q1  
\v 32 Anthu oyipa adzakanthidwa chifukwa cha ntchito zawo zomwe, 
\q2 koma olungama adzatetezedwa mwa imfa yawo. 
\b  
\q1  
\v 33 Nzeru zimakhala mu mtima mwa anthu omvetsa zinthu, 
\q2 koma nzeru sipezeka mu mtima mwa zitsiru. 
\b  
\q1  
\v 34 Chilungamo chimakweza mtundu wa anthu, 
\q2 koma uchimo umachititsa manyazi mtundu uliwonse. 
\b  
\q1  
\v 35 Mfumu imasangalatsidwa ndi wantchito wanzeru, 
\q2 koma imachitira ukali wantchito wochititsa manyazi. 
\c 15  
\q1  
\v 1 Kuyankha kofatsa kumathetsa mkwiyo, 
\q2 koma mawu ozaza amautsa ukali. 
\b  
\q1  
\v 2 Munthu wanzeru amayankhula zinthu za nzeru, 
\q2 koma pakamwa pa zitsiru pamatulutsa za uchitsiru. 
\b  
\q1  
\v 3 Maso a Yehova ali ponseponse, 
\q2 amayangʼana pa oyipa ndi abwino omwe. 
\b  
\q1  
\v 4 Kuyankhula kodekha kuli ngati mtengo wopatsa moyo, 
\q2 koma kuyankhula kopotoka kumapweteka mtima. 
\b  
\q1  
\v 5 Chitsiru chimanyoza mwambo wa abambo ake, 
\q2 koma wochenjera amasamala chidzudzulo. 
\b  
\q1  
\v 6 Munthu wolungama amakhala ndi chuma chambiri, 
\q2 zimene woyipa amapindula nazo zimamugwetsa mʼmavuto. 
\b  
\q1  
\v 7 Pakamwa pa anthu anzeru pamafalitsa nzeru; 
\q2 koma mitima ya zitsiru sitero. 
\b  
\q1  
\v 8 Nsembe za anthu oyipa zimamunyansa Yehova, 
\q2 koma amakondwera ndi pemphero la anthu owona mtima. 
\b  
\q1  
\v 9 Ntchito za anthu oyipa zimamunyansa Yehova 
\q2 koma amakonda amene amafunafuna chilungamo. 
\b  
\q1  
\v 10 Amene amasiya njira yabwino adzalangidwa koopsa. 
\q2 Odana ndi chidzudzulo adzafa. 
\b  
\q1  
\v 11 Manda ndi chiwonongeko ndi zosabisika pamaso pa Yehova, 
\q2 nanji mitima ya anthu! 
\b  
\q1  
\v 12 Wonyoza sakonda kudzudzulidwa; 
\q2 iye sapita kwa anthu anzeru. 
\b  
\q1  
\v 13 Mtima wokondwa umachititsa nkhope kukhala yachimwemwe, 
\q2 koma mtima wosweka umawawitsa moyo. 
\b  
\q1  
\v 14 Mtima wa munthu wozindikira zinthu umafunafuna nzeru, 
\q2 koma pakamwa pa zitsiru pamadya uchitsiru wawo. 
\b  
\q1  
\v 15 Munthu woponderezedwa masiku ake onse amakhala oyipa, 
\q2 koma mtima wachimwemwe umakhala pa chisangalalo nthawi zonse. 
\b  
\q1  
\v 16 Kuli bwino kukhala ndi zinthu pangʼono nʼkumaopa Yehova, 
\q2 kusiyana ndi kukhala ndi chuma chambiri uli pamavuto. 
\b  
\q1  
\v 17 Kuli bwino kudyera ndiwo zamasamba pamene pali chikondi, 
\q2 kusiyana ndi kudyera nyama yangʼombe yonenepa pamene pali udani. 
\b  
\q1  
\v 18 Munthu wopsa mtima msanga amayambitsa mikangano, 
\q2 koma munthu woleza mtima amathetsa ndewu. 
\b  
\q1  
\v 19 Njira ya munthu waulesi ndi yowirira ndi mtengo waminga, 
\q2 koma njira ya munthu wolungama ili ngati msewu waukulu. 
\b  
\q1  
\v 20 Mwana wanzeru amakondweretsa abambo ake, 
\q2 koma mwana wopusa amanyoza amayi ake. 
\b  
\q1  
\v 21 Uchitsiru umakondweretsa munthu wopanda nzeru, 
\q2 koma munthu womvetsa zinthu amayenda mowongoka. 
\b  
\q1  
\v 22 Popanda uphungu zolinga zako munthu zimalephereka, 
\q2 koma pakakhala aphungu ambiri zolinga zimatheka. 
\b  
\q1  
\v 23 Munthu amakondwera ndi kuyankha koyenera, 
\q2 ndipo mawu onena pa nthawi yake ndi okoma. 
\b  
\q1  
\v 24 Munthu wanzeru amatsata njira yopita ku moyo 
\q2 kuti apewe malo okhala anthu akufa. 
\b  
\q1  
\v 25 Yehova amapasula nyumba ya munthu wonyada 
\q2 koma amasamalira malo a mkazi wamasiye. 
\b  
\q1  
\v 26 Maganizo a anthu oyipa amamunyansa Yehova, 
\q2 koma mawu a anthu oyera mtima amamusangalatsa. 
\b  
\q1  
\v 27 Munthu wofuna phindu mwachinyengo amavutitsa banja lake, 
\q2 koma wodana ndi ziphuphu adzakhala ndi moyo. 
\b  
\q1  
\v 28 Munthu wolungama amaganizira za mmene ayankhire, 
\q2 koma pakamwa pa munthu woyipa pamatulutsa mawu oyipa. 
\b  
\q1  
\v 29 Yehova amakhala kutali ndi anthu oyipa, 
\q2 koma amamva pemphero la anthu olungama. 
\b  
\q1  
\v 30 Kuwala kwa maso kumasangalatsa mtima 
\q2 ndipo uthenga wabwino umalimbitsa munthu. 
\b  
\q1  
\v 31 Womvera mawu a chidzudzulo amene apatsa moyo 
\q2 adzakhala pakati pa anthu anzeru. 
\b  
\q1  
\v 32 Amene amanyoza mwambo amadzinyoza yekha, 
\q2 koma womvera mawu a chidzudzulo amapeza nzeru zomvetsa zinthu. 
\b  
\q1  
\v 33 Kuopa Yehova kumaphunzitsa munthu nzeru, 
\q2 ndipo kudzichepetsa ndi ulemu chili patsogolo ndi kudzichepetsa. 
\c 16  
\q1  
\v 1 Zolinga za mu mtima ndi za munthu, 
\q2 koma kwa Yehova ndiye kumachokera yankho. 
\b  
\q1  
\v 2 Zochita zonse za munthu zimaoneka zabwino pamaso pake, 
\q2 koma Yehova ndiye amasanthula zolinga zako. 
\b  
\q1  
\v 3 Pereka ntchito zako zonse mʼmanja mwa Yehova, 
\q2 ndipo zolinga zako zidzachitikadi. 
\b  
\q1  
\v 4 Yehova amachita zonse ndi cholinga chake, 
\q2 ngakhale anthu oyipa kuti aone tsiku latsoka. 
\b  
\q1  
\v 5 Munthu aliyense wodzikuza amamunyansa Yehova. 
\q2 Koma dziwani izi: Iwo sadzakhala osalangidwa. 
\b  
\q1  
\v 6 Chifukwa cha chikondi chosasinthika ndi kukhulupirika, munthu amakhululukidwa machimo ake; 
\q2 chifukwa cha kuopa Yehova munthu amapewa zoyipa. 
\b  
\q1  
\v 7 Pamene makhalidwe a munthu akondweretsa Yehova, 
\q2 ngakhale adani ake amakhala naye mwa mtendere. 
\b  
\q1  
\v 8 Kuli bwino kukhala ndi zinthu pangʼono zozipeza mwachilungamo, 
\q2 kusiyana ndi kukhala ndi zinthu zambiri zozipeza popanda chilungamo. 
\b  
\q1  
\v 9 Mtima wa munthu umalingalira zochita, 
\q2 koma Yehova ndiye amakhazikitsa njira zake. 
\b  
\q1  
\v 10 Mawu a mfumu ali ngati mawu ochokera kwa Mulungu; 
\q2 ndipo pakamwa pake sipalakwa poweruza mlandu. 
\b  
\q1  
\v 11 Miyeso ndi masikelo achilungamo zimachokera kwa Yehova; 
\q2 miyala yonse yoyesera ya mʼthumba anayipanga ndi Yehova. 
\b  
\q1  
\v 12 Kuchita zoyipa kumanyansa mafumu, 
\q2 pakuti chilungamo ndiye maziko a ufumu wake. 
\b  
\q1  
\v 13 Mawu owona amakondweretsa mfumu. 
\q2 Iyo imakonda munthu woyankhula choonadi. 
\b  
\q1  
\v 14 Ukali wa mfumu ndi mthenga wa imfa, 
\q2 koma munthu wanzeru amawupepesa ukaliwo. 
\b  
\q1  
\v 15 Kuwala kwa nkhope ya mfumu kumapatsa moyo; 
\q2 ndipo kukoma mtima kwake kuli ngati mitambo ya mvula nthawi ya chilimwe. 
\b  
\q1  
\v 16 Nʼkwabwino kwambiri kupeza nzeru kupambana golide. 
\q2 Kukhala womvetsa bwino zinthu nʼkwabwino kupambana ndi kukhala ndi siliva. 
\b  
\q1  
\v 17 Msewu wa munthu wowongoka mtima umapewa zoyipa; 
\q2 wopenyetsetsa kumene akupita amasunga moyo wake. 
\b  
\q1  
\v 18 Kunyada kumafikitsa ku chiwonongeko, 
\q2 ndipo munthu wodzikuza adzagwa. 
\b  
\q1  
\v 19 Nʼkwabwino kukhala ndi mtima wodzichepetsa pakati pa anthu oponderezedwa, 
\q2 kusiyana ndi kugawana zolanda ndi anthu onyada. 
\b  
\q1  
\v 20 Munthu womvera malangizo zinthu zimamuyendera bwino, 
\q2 ndipo wodala ndi amene amadalira Yehova. 
\b  
\q1  
\v 21 A mtima wanzeru amatchedwa ozindikira zinthu, 
\q2 ndipo mawu ake okoma amawonjezera nzeru. 
\b  
\q1  
\v 22 Kumvetsa zinthu ndi kasupe wa moyo kwa iwo amene ali nako, 
\q2 koma uchitsiru umabweretsa chilango kwa zitsiru. 
\b  
\q1  
\v 23 Mtima wanzeru umathandiza munthu kuyankhula mwa nzeru, 
\q2 ndipo mawu ake amawonjezera nzeru. 
\b  
\q1  
\v 24 Mawu okometsera ali ngati chisa cha njuchi, 
\q2 amakoma mu mtima ndipo amalimbitsa thupi. 
\b  
\q1  
\v 25 Pali njira ina yooneka ngati yowongoka kwa munthu 
\q2 koma kumatsiriziro kwake ndi imfa. 
\b  
\q1  
\v 26 Njala ya munthu wantchito imamuthandiza kulimbikira; 
\q2 njalayo imamukakamiza kuchitapo kanthu. 
\b  
\q1  
\v 27 Munthu wopanda pake amakonzekera kuchita zoyipa 
\q2 ndipo mawu ake ali ngati moto wopsereza. 
\b  
\q1  
\v 28 Munthu woyipa mtima amayambitsa mikangano, 
\q2 ndipo miseche imalekanitsa anthu okondana kwambiri. 
\b  
\q1  
\v 29 Munthu wandewu amakopa mnansi wake, 
\q2 ndipo amamuyendetsa njira imene si yabwino. 
\b  
\q1  
\v 30 Amene amatsinzinira maso ake amalingalira zinthu zokhota; 
\q2 amene amachita msunamo amakonzeka kuchita zoyipa. 
\b  
\q1  
\v 31 Imvi zili ngati chipewa chaufumu chaulemerero; 
\q2 munthu amazipeza akakhala moyo wolungama. 
\b  
\q1  
\v 32 Munthu wosapsa mtima msanga amaposa munthu wankhondo, 
\q2 munthu wowugwira mtima wake amaposa amene amalanda mzinda. 
\b  
\q1  
\v 33 Maere amaponyedwa pa mfunga, 
\q2 koma ndiye Yehova amene amalongosola zonse. 
\c 17  
\q1  
\v 1 Nʼkwabwino kudya mkute koma pali mtendere, 
\q2 kuposa kuchita madyerero mʼnyumba mʼmene muli mikangano. 
\b  
\q1  
\v 2 Kapolo wanzeru adzalamulira mwana wochititsa manyazi, 
\q2 ndipo kapoloyo adzagawana nawo cholowa ngati mmodzi mwa abale. 
\b  
\q1  
\v 3 Siliva amamuyesa mʼngʼanjo ndipo golide amamuyesa mʼngʼanjo, 
\q2 koma Yehova amayesa mitima. 
\b  
\q1  
\v 4 Munthu woyipa amamvera malangizo oyipa; 
\q2 munthu wabodza amatchera khutu mawu osakaza. 
\b  
\q1  
\v 5 Iye amene amalalatira mʼmphawi amanyoza mlengi wake; 
\q2 amene amakondwerera tsoka la mnzake sadzakhala osalangidwa. 
\b  
\q1  
\v 6 Zidzukulu ndiye ulemu wa anthu okalamba, 
\q2 ndipo makolo ndiye ulemerero wa ana. 
\b  
\q1  
\v 7 Kuyankhula bwino sikuyenerana ndi chitsiru, 
\q2 nanji kuyankhula bodza kungayenerane kodi ndi mfumu? 
\b  
\q1  
\v 8 Chiphuphu chili ngati mankhwala amwayi kwa wochiperekayo; 
\q2 kulikonse kumene amapita zinthu zimamuyendera. 
\b  
\q1  
\v 9 Iye amene amakhululukira zolakwa za wina, amafunitsitsa chikondi; 
\q2 wobwerezabwereza nkhani amapha chibwenzi. 
\b  
\q1  
\v 10 Munthu wanzeru amamva kamodzi kokha, 
\q2 munthu wopanda nzeru ndi samvamkunkhu. 
\b  
\q1  
\v 11 Munthu woyipa maganizo ake ali pa kuwukira basi; 
\q2 ndipo bwana adzamutumizira wamthenga wankhanza. 
\b  
\q1  
\v 12 Nʼkwabwino kukumana ndi chimbalangondo cholandidwa ana ake 
\q2 kusiyana ndi kukumana ndi chitsiru mu uchitsiru wake. 
\b  
\q1  
\v 13 Ngati munthu abwezera choyipa kusinthana ndi zabwino, 
\q2 ndiye choyipa sichidzachoka mʼnyumba mwake. 
\b  
\q1  
\v 14 Chiyambi cha mikangano chili ngati kukhamulira madzi, 
\q2 choncho uzichokapo mkangano usanayambe. 
\b  
\q1  
\v 15 Kumasula munthu wolakwa kapena kumanga munthu wosalakwa, 
\q2 zonse ziwirizi Yehova zimamunyansa. 
\b  
\q1  
\v 16 Ndalama zogulira nzeru zili ndi phindu lanji mʼmanja mwa chitsiru 
\q2 poti iyeyo mutu wake sumayenda bwino? 
\b  
\q1  
\v 17 Bwenzi lako limakukonda nthawi zonse, 
\q2 ndipo mʼbale wako anabadwa kuti azikuthandiza pamavuto. 
\b  
\q1  
\v 18 Munthu wopanda nzeru amavomereza zopereka chikole 
\q2 ndipo iyeyo amasanduka chikole cha mnansi wake. 
\b  
\q1  
\v 19 Wokonda zolakwa amakonda mkangano, 
\q2 ndipo wokonda kuyankhula zonyada amadziyitanira chiwonongeko. 
\b  
\q1  
\v 20 Munthu wamtima woyipa zinthu sizimuyendera bwino; 
\q2 ndipo woyankhula zachinyengo amagwa mʼmavuto. 
\b  
\q1  
\v 21 Mwana wopusa amamvetsa chisoni abambo ake, 
\q2 abambo a chitsiru sakhala ndi chimwemwe. 
\b  
\q1  
\v 22 Mtima wosangalala uli ngati mankhwala abwino, 
\q2 koma mtima wokhumudwa umafowoketsa mafupa. 
\b  
\q1  
\v 23 Munthu woyipa amalandira chiphuphu chamseri 
\q2 kuti apotoze chiweruzo cholungama. 
\b  
\q1  
\v 24 Munthu wozindikira zinthu, maso ake amakhala pa nzeru, 
\q2 koma chitsiru chimwazamwaza maso ake pa dziko lonse lapansi. 
\b  
\q1  
\v 25 Mwana wopusa amamvetsa chisoni abambo ake 
\q2 ndipo amapweteketsa mtima amayi ake. 
\b  
\q1  
\v 26 Sibwino kulipitsa munthu wosalakwa, 
\q2 kapena kulanga anthu osalakwa. 
\b  
\q1  
\v 27 Munthu wosunga pakamwa ndiye wodziwa zinthu, 
\q2 ndipo wodekha mtima ndiye womvetsa bwino zinthu. 
\b  
\q1  
\v 28 Ngakhale chitsiru chimakhala ngati chanzeru chikakhala chete; 
\q2 ndipo chikatseka pakamwa chimakhala ngati munthu wochenjera. 
\c 18  
\q1  
\v 1 Munthu wokonda kukhala yekha amafunafuna zomukomera yekha; 
\q2 iye amatsutsana ndi malangizo onse anzeru. 
\b  
\q1  
\v 2 Chitsiru chilibe chidwi chomvetsa zinthu, 
\q2 koma chimakondwera ndi kuyankhula maganizo ake okha. 
\b  
\q1  
\v 3 Kuyipa mtima kukabwera, manyozonso amabwera. 
\q2 Manyazi amabwera pamodzi ndi kunyozeka. 
\b  
\q1  
\v 4 Mawu a munthu ali ngati madzi akuya, 
\q2 kasupe wa nzeru ndiye mtsinje wotumphuka. 
\b  
\q1  
\v 5 Si kwabwino kukondera munthu woyipa pa milandu; 
\q2 kapena kupondereza munthu wosalakwa. 
\b  
\q1  
\v 6 Mawu a chitsiru amautsa mkangano; 
\q2 pakamwa pake pamayitana mkwapulo. 
\b  
\q1  
\v 7 Pakamwa pa chitsiru ndipo pamabweretsa chiwonongeko chake, 
\q2 ndipo milomo yake ili ngati msampha wa moyo wake. 
\b  
\q1  
\v 8 Mawu a miseche ali ngati chakudya chokoma; 
\q2 amalowa mʼmimba mwa munthu. 
\b  
\q1  
\v 9 Munthu waulesi pa ntchito yake 
\q2 ali pachibale ndi munthu amene amawononga zinthu. 
\b  
\q1  
\v 10 Dzina la Yehova lili ngati nsanja yolimba; 
\q2 wolungama amathawiramo napulumuka. 
\b  
\q1  
\v 11 Chuma cha anthu olemera chili ngati mzinda wake wolimba; 
\q2 chili ngati khoma lalitali limene amaganiza kuti limutchinjiriza. 
\b  
\q1  
\v 12 Chiwonongeko chisanafike, mtima wa munthu umakhala wonyada, 
\q2 koma ulemu umatsatira kudzichepetsa. 
\b  
\q1  
\v 13 Ukayankha usanamvetse bwino nkhani, 
\q2 umenewo ndi uchitsiru ndipo umachita manyazi. 
\b  
\q1  
\v 14 Mtima wa munthu utha kupirira pa matenda, 
\q2 koma munthu akataya mtima ndani angathe kumulimbitsanso. 
\b  
\q1  
\v 15 Munthu wanzeru amawonjezera nzeru zina; 
\q2 amafunafuna kudziwa bwino zinthu. 
\b  
\q1  
\v 16 Mphatso ya munthu imamutsekulira njira 
\q2 yomufikitsa pamaso pa anthu akuluakulu. 
\b  
\q1  
\v 17 Amene amayamba kufotokoza mlandu wake amaoneka ngati wolungama ndiye 
\q2 mpaka mnzake atabwera ndi kumufunsa bwino. 
\b  
\q1  
\v 18 Kuchita maere kumathetsa mikangano; 
\q2 amalekanitsa okangana amphamvu. 
\b  
\q1  
\v 19 Mʼbale amene wamuthandiza amakhala ngati mzinda wolimba, 
\q2 koma kukangana naye kumatsekereza thandizo. 
\b  
\q1  
\v 20 Munthu amapeza bwino malingana ndi zoyankhula zake. 
\q2 Adzakhuta ndi zipatso za pakamwa pake. 
\b  
\q1  
\v 21 Mawu ako angathe kukuphetsa kapena kukukhalitsa moyo. 
\q2 Wokonda kuyankhulayankhula adzadya zipatso zake. 
\b  
\q1  
\v 22 Wapeza mkazi wapeza chinthu chabwino 
\q2 ndipo Yehova amamukomera mtima. 
\b  
\q1  
\v 23 Munthu wosauka amapempha 
\q2 koma munthu wolemera amayankha mwaukali. 
\b  
\q1  
\v 24 Pali abwenzi amene chibwenzi chawo nʼchapamaso, 
\q2 koma pali bwenzi limene limakukangamira kuposa mʼbale wako. 
\c 19  
\q1  
\v 1 Ndi wabwino munthu wosauka amene amayenda mu ungwiro, 
\q2 aposa munthu wopusa woyankhula zokhota. 
\b  
\q1  
\v 2 Si bwino kuti munthu akhale wopanda nzeru; 
\q2 ndipo munthu woyenda mofulumira amaphonya njira. 
\b  
\q1  
\v 3 Uchitsiru wa munthu umamubweretsera zovuta, 
\q2 mtima wake umakwiyira Yehova. 
\b  
\q1  
\v 4 Chuma chimachulukitsa abwenzi; 
\q2 koma munthu wosauka bwenzi lake limamuthawa. 
\b  
\q1  
\v 5 Mboni yonama sidzalephera kulangidwa; 
\q2 ndipo iye amene amanena mabodza sadzapulumuka. 
\b  
\q1  
\v 6 Anthu ambiri amafuna munthu wopatsa kuti awakomere mtima, 
\q2 ndipo munthu amene amapereka mphatso ndi bwenzi la munthu aliyense. 
\b  
\q1  
\v 7 Ngati munthu wosauka abale ake omwe amadana naye, 
\q2 nanji abwenzi ake tsono! 
\q1 Iwo adzamuthawa kupita kutali. 
\q2 Amayesa kuwatsatira mowapembedza koma iwo samapezeka konse. 
\b  
\q1  
\v 8 Iye amene amapeza nzeru ndiye kuti amakonda moyo wake. 
\q2 Wosamalitsa kukhala wanzeru, zinthu zimamuyendera bwino. 
\b  
\q1  
\v 9 Mboni yonama sidzalephera kulangidwa, 
\q2 ndipo iye amene amanena mabodza adzawonongeka. 
\b  
\q1  
\v 10 Nʼkosayenera kuti chitsiru chizikhala ndi moyo wamanyado, 
\q2 nanjinso kuti kapolo azilamulira akalonga! 
\b  
\q1  
\v 11 Nzeru zimapangitsa munthu kukhala wosakwiya msanga; 
\q2 ulemerero wake uli posalabadira kuchitiridwa zoyipa. 
\b  
\q1  
\v 12 Mkwiyo wa mfumu uli ngati kubangula kwa mkango, 
\q2 koma kukoma mtima kwake kuli ngati mame pa udzu. 
\b  
\q1  
\v 13 Mwana wopusa ndiye tsoka la abambo ake 
\q2 ndipo mkazi wolongolola ndi wotopetsa ngati mvula yamvumbi. 
\b  
\q1  
\v 14 Nyumba ndi chuma ndiye cholowa chochokera kwa makolo; 
\q2 koma mkazi wanzeru ndi wochokera kwa Yehova. 
\b  
\q1  
\v 15 Ulesi umagonetsa tulo tofa nato 
\q2 ndipo munthu wosatakataka amakhala ndi njala. 
\b  
\q1  
\v 16 Amene amamvera malangizo amasunga moyo wake, 
\q2 koma amene sasamala malamulo a Yehova adzafa. 
\b  
\q1  
\v 17 Amene amakomera mtima osauka amachita ngati wakongoletsa Yehova, 
\q2 ndipo Yehovayo ndiye adzamubwezere. 
\b  
\q1  
\v 18 Langa mwana wako, chiyembekezo chikanalipo; 
\q2 ngati sutero udzawononga moyo wake. 
\b  
\q1  
\v 19 Munthu waukali woopsa ayenera kulandira chilango; 
\q2 pakuti akamulekelera ndiye zidzayipa kuposa kale. 
\b  
\q1  
\v 20 Mvera uphungu ndipo landira malangizo; 
\q2 pa mapeto pake udzakhala wanzeru. 
\b  
\q1  
\v 21 Munthu amakonzekera zambiri mu mtima mwake, 
\q2 koma cholinga cha Yehova ndiye chidzachitike. 
\b  
\q1  
\v 22 Chimene munthu amafuna ndi chikondi chosatha; 
\q2 nʼkwabwino kukhala wosauka kusiyana ndi kukhala wabodza. 
\b  
\q1  
\v 23 Kuopa Yehova kumabweretsa moyo; 
\q2 wotereyo amakhala mu mtendere; ndiye kuti choyipa sichidzamugwera. 
\b  
\q1  
\v 24 Munthu waulesi amapisa dzanja lake mʼmbale; 
\q2 koma sangathe kufikitsa dzanja lakelo pakamwa pake. 
\b  
\q1  
\v 25 Menya munthu wonyoza, ndipo anthu opanda nzeru adzachenjererapo; 
\q2 dzudzula munthu wozindikira zinthu, ndipo iye adzapezapo chidziwitso. 
\b  
\q1  
\v 26 Mwana wochita ndewu ndi abambo ake ndi kuthamangitsa amayi ake, 
\q2 ndi mwana wochititsa manyazi ndi wonyozetsa. 
\b  
\q1  
\v 27 Mwana wanga, ukaleka kumvera malangizo, 
\q2 udzapatukana ndi mawu opatsa nzeru. 
\b  
\q1  
\v 28 Mboni yopanda pake imanyoza cholungama, 
\q2 ndipo pakamwa pa anthu oyipa pamameza zoyipa. 
\b  
\q1  
\v 29 Chilango chakonzedwa kale kuti chigwere anthu oyipa, 
\q2 ndipo mkwapulo wakonzedwa kale kuti ukwapule misana ya anthu opusa. 
\c 20  
\q1  
\v 1 Vinyo amachititsa munthu kukhala wonyoza ndipo chakumwa choledzeretsa chimachititsa munthu kukhala wolongolola; 
\q2 aliyense wosochera nazo zimenezi alibe nzeru. 
\b  
\q1  
\v 2 Ukali wa mfumu uli ngati kubangula kwa mkango; 
\q2 amene amawuputa mkwiyowo amataya moyo wake. 
\b  
\q1  
\v 3 Nʼchaulemu kwa munthu kupewa mikangano, 
\q2 koma chitsiru chilichonse chimafulumira kulongolola. 
\b  
\q1  
\v 4 Munthu waulesi satipula mʼmunda pa nthawi yoyenera; 
\q2 kotero pa nthawi yokolola adzafunafuna zinthu koma sadzapeza kanthu kalikonse. 
\b  
\q1  
\v 5 Zolinga za mtima wa munthu zili ngati madzi akuya, 
\q2 munthu womvetsa zinthu ndiye yekha angawatunge. 
\b  
\q1  
\v 6 Anthu ambiri amayankhula za kukhulupirika kwawo, 
\q2 koma munthu wokhulupirika angamupeze ndani? 
\b  
\q1  
\v 7 Munthu wolungama amakhala ndi makhalidwe abwino; 
\q2 odala ndi ana ake amene amatsanzira moyo wake. 
\b  
\q1  
\v 8 Mfumu ikhala pa mpando wake wa chiweruzo, 
\q2 imapeta ndi maso ake anthu onse oyipa. 
\b  
\q1  
\v 9 Ndani amene anganene kuti, “Ndawuyeretsa mtima wanga; 
\q2 ndilibe tchimo lililonse?” 
\b  
\q1  
\v 10 Masikelo ndi miyeso ya zinthu imene ili yachinyengo 
\q2 zonsezi Yehova zimamunyansa. 
\b  
\q1  
\v 11 Ngakhale mwana amadziwika ndi zochita zake, 
\q2 ngati zochita zake zili zoyera ndi zoyenera. 
\b  
\q1  
\v 12 Makutu amene amamva ndi maso amene amaona, 
\q2 zonsezi anazilenga ndi Yehova. 
\b  
\q1  
\v 13 Usakonde tulo ungasauke; 
\q2 khala maso ndipo udzakhala ndi chakudya chambiri. 
\b  
\q1  
\v 14 Munthu wogula chinthu amati, “Sichabwino, sichabwino.” 
\q2 Koma akagula nʼkuchokapo amayamba kudzitama. 
\b  
\q1  
\v 15 Pali golide ndi miyala yamtengowapatali, 
\q2 koma milomo yoyankhula zanzeru ndi yamtengowapatali koposa zonsezi. 
\b  
\q1  
\v 16 Utenge chovala cha munthu amene waperekera mlendo chikole; 
\q2 kuti chikhale chikole chako chifukwa waperekera chikole munthu wachilendo. 
\b  
\q1  
\v 17 Chakudya chochipeza mwachinyengo chimukomera munthu, 
\q2 koma pa mapeto pake chimasanduka ngati mchenga mʼkamwa mwake. 
\b  
\q1  
\v 18 Zokonzekera zimapindula utafunsira uphungu; 
\q2 ndipo usanamenye nkhondo yamba wapempha malangizo oyenera. 
\b  
\q1  
\v 19 Amene amanka nanena miseche amawulula zachinsinsi. 
\q2 Choncho usamagwirizane naye munthu woyankhula zopusayo. 
\b  
\q1  
\v 20 Ngati munthu atemberera abambo ake kapena amayi ake, 
\q2 moyo wake udzazimitsidwa ngati nyale mu mdima wandiweyani. 
\b  
\q1  
\v 21 Cholowa chochipeza mofulumira poyamba, 
\q2 sichidzakhala dalitso pa mapeto pake. 
\b  
\q1  
\v 22 Usanene kuti, “Ine ndidzabwezera choyipa chimenechi!” 
\q2 Dikira Yehova, ndipo Iye adzakupulumutsa. 
\b  
\q1  
\v 23 Miyeso yosintha imamunyansa Yehova; 
\q2 ndipo masikelo onyenga si abwino. 
\b  
\q1  
\v 24 Mayendedwe a munthu amawalamulira ndi Yehova, 
\q2 tsono munthu angadziwe bwanji njira yake? 
\b  
\q1  
\v 25 Ndi msampha kwa munthu kuyankhula mofulumira kuti “Chinthu ichi nʼchopatulika kwa Yehova,” 
\q2 popeza mwina atha kusintha maganizo utalumbira kale. 
\b  
\q1  
\v 26 Mfumu ya nzeru imapeta kwathunthu 
\q2 anthu oyipa. 
\b  
\q1  
\v 27 Mpweya wa munthu uli ngati nyale ya Yehova; 
\q2 imafufuza ziwalo zake zonse zamʼkati. 
\b  
\q1  
\v 28 Kukoma mtima ndi kukhulupirika ndizo zimasunga mfumu; 
\q2 chilungamo chimalimbikitsa mpando wake waufumu. 
\b  
\q1  
\v 29 Ulemerero wa achinyamata uli mu mphamvu zawo, 
\q2 imvi ndi ulemerero wa anthu okalamba. 
\b  
\q1  
\v 30 Mikwingwirima yopweteka ndiyo imachotsa zoyipa, 
\q2 ndipo mikwapulo ndiyo imachotsa zamʼkatikati mwa munthu. 
\c 21  
\q1  
\v 1 Mtima wa mfumu uli ngati mtsinje wamadzi mʼdzanja la Yehova; 
\q2 Iye amautsongolera pa chilichonse chimene akufuna. 
\b  
\q1  
\v 2 Makhalidwe a munthu amaoneka olungama kwa mwini wakeyo, 
\q2 koma Yehova ndiye amayesa mtima wake. 
\b  
\q1  
\v 3 Za chilungamo ndi zolondola 
\q2 ndi zomwe zimakondweretsa Yehova kuposa kupereka nsembe. 
\b  
\q1  
\v 4 Maso odzikuza ndi mtima wonyada, 
\q2 zimatsogolera anthu oyipa ngati nyale nʼchifukwa chake amachimwa. 
\b  
\q1  
\v 5 Zolinga za munthu wakhama zimachulukitsa zinthu zake; 
\q2 koma aliyense wochita zinthu mofulumira amadzakhala wosauka. 
\b  
\q1  
\v 6 Chuma chochipeza ndi mawu onyenga ndi chosakhalitsa 
\q2 ndipo chimakola anthu mu msampha wa imfa. 
\b  
\q1  
\v 7 Chiwawa cha anthu oyipa chidzawawononga, 
\q2 pakuti iwo amakana kuchita zolungama. 
\b  
\q1  
\v 8 Njira ya munthu wolakwa ndi yokhotakhota, 
\q2 koma makhalidwe a munthu wosalakwa ndi olungama. 
\b  
\q1  
\v 9 Nʼkwabwino kukhala wekha pa ngodya ya denga la nyumba, 
\q2 kuposa kukhala mʼnyumba pamodzi ndi mkazi wolongolola. 
\b  
\q1  
\v 10 Munthu woyipa amalakalaka zoyipa; 
\q2 sachitira chifundo mnansi wake wovutika. 
\b  
\q1  
\v 11 Munthu wonyoza akalangidwa, anthu opusa amapeza nzeru; 
\q2 koma munthu wanzeru akalangizidwa, amapeza chidziwitso. 
\b  
\q1  
\v 12 Zolingalira za munthu woyipa nʼzosabisika pamaso pa Yehova, 
\q2 ndipo Iye adzawononga woyipayo. 
\b  
\q1  
\v 13 Amene atsekera mʼkhutu mwake wosauka akamalira, 
\q2 nayenso adzalira koma palibe adzamuyankhe. 
\b  
\q1  
\v 14 Mphatso yoperekedwa mseri imathetsa mkwiyo, 
\q2 ndipo chiphuphu choperekedwa mobisa chimathetsa mphamvu ya ukali woopsa. 
\b  
\q1  
\v 15 Chilungamo chikachitika anthu olungama amasangalala, 
\q2 koma anthu oyipa amaopsedwa nazo. 
\b  
\q1  
\v 16 Munthu amene amachoka pa njira ya anthu anzeru 
\q2 adzapezeka mʼgulu la anthu akufa. 
\b  
\q1  
\v 17 Aliyense wokonda zisangalalo adzasanduka mʼmphawi, 
\q2 ndipo wokonda vinyo ndi mafuta sadzalemera. 
\b  
\q1  
\v 18 Anthu oyipa adzakhala chowombolera cha anthu olungama 
\q2 ndipo osakhulupirika chowombolera anthu olungama mtima. 
\b  
\q1  
\v 19 Nʼkwabwino kukhala mʼchipululu 
\q2 kuposa kukhala ndi mkazi wolongolola ndi wopsa mtima msanga. 
\b  
\q1  
\v 20 Munthu wanzeru samwaza chuma chake, 
\q2 koma wopusa amachiwononga. 
\b  
\q1  
\v 21 Amene amatsata chilungamo ndi kukhulupirika, 
\q2 amapeza moyo ndi ulemerero. 
\b  
\q1  
\v 22 Munthu wanzeru amagonjetsa mzinda wa anthu amphamvu 
\q2 ndi kugwetsa linga limene iwo amalidalira. 
\b  
\q1  
\v 23 Amene amagwira pakamwa pake ndi lilime lake 
\q2 sapeza mavuto. 
\b  
\q1  
\v 24 Munthu wonyada ndi wodzikuza amamutcha, “Mnyodoli,” 
\q2 iye amachita zinthu modzitama kwambiri. 
\b  
\q1  
\v 25 Chilakolako cha munthu waulesi chidzamupha yekha 
\q2 chifukwa manja ake amangokhala goba osagwira ntchito. 
\q1  
\v 26 Tsiku lonse anthu oyipa amasirira zambiri, 
\q2 koma anthu olungama amapereka mowolowamanja. 
\b  
\q1  
\v 27 Nsembe ya anthu oyipa imamunyansa Yehova, 
\q2 nanji akayipereka ndi cholinga choyipa! 
\b  
\q1  
\v 28 Mboni yonama idzawonongeka, 
\q2 koma mawu a munthu wakumva adzakhala nthawi zonse. 
\b  
\q1  
\v 29 Munthu woyipa amafuna kudzionetsa ngati wolimba mtima, 
\q2 koma munthu wowongoka amaganizira njira zake. 
\b  
\q1  
\v 30 Palibe nzeru, palibe kumvetsa bwino, palibenso uphungu, 
\q2 zimene zingapambane Yehova. 
\b  
\q1  
\v 31 Kavalo amamukonzera tsiku la nkhondo, 
\q2 koma ndi Yehova amene amapambanitsa. 
\c 22  
\q1  
\v 1 Mbiri yabwino ndi yofunika kuposa chuma chambiri; 
\q2 kupeza kuyanja nʼkwabwino kuposa siliva kapena golide. 
\b  
\q1  
\v 2 Wolemera ndi wosauka ndi ofanana; 
\q2 onsewa anawalenga ndi Yehova. 
\b  
\q1  
\v 3 Munthu wochenjera akaona choopsa amabisala, 
\q2 koma munthu wopusa amangopitirira ndipo amadzanongʼoneza bondo. 
\b  
\q1  
\v 4 Mphotho ya munthu wodzichepetsa 
\q2 ndi woopa Yehova ndi chuma, ulemu ndi moyo. 
\b  
\q1  
\v 5 Mʼnjira za anthu oyipa muli minga ndi misampha, 
\q2 koma amene amasala moyo wake adzazipewa zonsezo. 
\b  
\q1  
\v 6 Mwana muzimuphunzitsa njira yake, 
\q2 ndipo akadzakalamba sadzachokamo. 
\b  
\q1  
\v 7 Wolemera amalamulira wosauka, 
\q2 ndipo wokongola zinthu amakhala kapolo wa womukongozayo. 
\b  
\q1  
\v 8 Amene amafesa zoyipa amakolola mavuto, 
\q2 ndipo ndodo yaukali wake idzathyoka. 
\b  
\q1  
\v 9 Amene ali ndi diso lachifundo adzadalitsika, 
\q2 pakuti iye amagawana chakudya chake ndi anthu osauka. 
\b  
\q1  
\v 10 Chotsani munthu wonyoza, ndipo kukangana kudzatha; 
\q2 mapokoso ndi zonyoza zidzaleka. 
\b  
\q1  
\v 11 Amene amakonda kukhala woyera mtima ndi kumayankhula mawu abwino, 
\q2 adzakhala bwenzi la mfumu. 
\b  
\q1  
\v 12 Maso a Yehova amakhala pa anthu odziwa bwino zinthu, 
\q2 koma Iye adzalepheretsa mawu a anthu osakhulupirika. 
\b  
\q1  
\v 13 Munthu waulesi amati, 
\q2 “Kunjaku kuli mkango. Ine ndidzaphedwa mʼmisewu!” 
\b  
\q1  
\v 14 Pakamwa pa mkazi wachigololo pali ngati dzenje lozama; 
\q2 amene Yehova wamukwiyira adzagwamo. 
\b  
\q1  
\v 15 Uchitsiru umakhala mu mtima mwa mwana, 
\q2 koma ndodo yomulangira mwanayo idzachotsa uchitsiruwo. 
\b  
\q1  
\v 16 Amene amapondereza anthu osauka kuti awonjezere chuma chake, 
\q2 ndiponso amene amapereka mphatso kwa anthu olemera onsewa adzasauka. 
\s1 Malangizo a Anthu Anzeru 
\q1  
\v 17 Utchere khutu lako ndipo umvere mawu anzeru; 
\q2 uyike mtima wako pa zimene ndikukuphunzitsa kuti udziwe. 
\q1  
\v 18 Zidzakhala zokondweretsa ngati uzisunga mu mtima mwako 
\q2 ndi wokonzeka kuziyankhula. 
\q1  
\v 19 Ndakuphunzitsa zimenezi lero 
\q2 koma makamaka uziopa Yehova. 
\q1  
\v 20 Kodi suja ndinakulembera malangizo makumi atatu 
\q2 okuchenjeza ndi okupatsa nzeru, 
\q1  
\v 21 malangizo okudziwitsa zolungama 
\q2 ndi zoona 
\q2 ndi kuti ukawayankhe zoona amene akutumawo? 
\b  
\q1  
\v 22 Mʼmphawi usamubere chifukwa ndi osauka, 
\q2 ndipo usawapondereze anthu osowa mʼbwalo la milandu, 
\q1  
\v 23 pakuti Yehova adzawateteza pa mlandu wawo 
\q2 ndipo adzalanda moyo onse amene amawalanda iwo. 
\b  
\q1  
\v 24 Usapalane naye ubwenzi munthu wosachedwa kupsa mtima 
\q2 ndipo usayanjane ndi munthu amene sachedwa kukwiya 
\q1  
\v 25 kuopa kuti iwe ungadzaphunzire njira zake 
\q2 ndi kukodwa mu msampha. 
\b  
\q1  
\v 26 Usakhale munthu wopereka chikole 
\q2 kapena kukhala mboni pa ngongole; 
\q1  
\v 27 ngati ulephera kupeza njira yolipirira 
\q2 adzakulanda ngakhale bedi lako lomwe. 
\b  
\q1  
\v 28 Usasunthe mwala wamʼmalire akalekale 
\q2 amene anayikidwa ndi makolo ako. 
\b  
\q1  
\v 29 Kodi ukumuona munthu waluso pa ntchito yake? 
\q2 Iye adzatumikira mafumu; 
\q2 sadzatumikira anthu wamba. 
\c 23  
\q1  
\v 1 Ngati ukhala pansi kuti udye pamodzi ndi wolamulira, 
\q2 uyangʼane bwino zimene zili pamaso pako, 
\q1  
\v 2 ngati ndiwe munthu wadyera 
\q2 udziletse kuti usaonetse dyera lakolo. 
\q1  
\v 3 Usasirire zakudya zake, 
\q2 pakuti zimenezo ndi zakudya zachinyengo. 
\b  
\q1  
\v 4 Usadzitopetse wekha ndi kufuna chuma, 
\q2 ukhale ndi nzeru ya kudziretsa. 
\q1  
\v 5 Ukangoti wachipeza chumacho uwona posachedwa kuti palibepo. 
\q2 Chumacho chimachita ngati chamera mapiko mwadzidzidzi 
\q2 ndi kuwuluka kunka kumwamba ngati chiwombankhanga. 
\b  
\q1  
\v 6 Usadye chakudya cha munthu waumbombo, 
\q2 usalakalake zakudya zake zokoma; 
\q1  
\v 7 paja iye ndi munthu amene 
\q2 nthawi zonse amaganizira za mtengo wake 
\q1 ngakhale amati kwa iwe, “Idya ndi kumwa,” 
\q2 koma sakondweretsedwa nawe. 
\q1  
\v 8 Udzasanza zimene wadyazo 
\q2 ndipo mawu ako woyamikira adzapita pachabe. 
\b  
\q1  
\v 9 Usayankhule munthu wopusa akumva, 
\q2 pakuti adzanyoza mawu ako anzeru. 
\b  
\q1  
\v 10 Usasunthe mwala wa mʼmalire akalekale 
\q2 kapena kulowerera mʼminda ya ana amasiye, 
\q1  
\v 11 paja Mpulumutsi wawo ndi wamphamvu; 
\q2 iye adzawateteza pa milandu yawo kutsutsana nawe. 
\b  
\q1  
\v 12 Mtima wako uzikhala pa malangizo 
\q2 ndipo makutu ako azimvetsera mawu a chidziwitso. 
\b  
\q1  
\v 13 Usaleke kumulangiza mwana; 
\q2 ngati umulanga ndi chikwapu sadzafa. 
\q1  
\v 14 Ukamukwapula ndi tsatsa 
\q2 udzapulumutsa moyo wake. 
\b  
\q1  
\v 15 Mwana wanga, ngati mtima wako ukhala wanzeru, 
\q2 inenso mtima wanga udzakondwera. 
\q1  
\v 16 Mtima wanga udzakondwera 
\q2 pamene ndidzakumva ukuyankhula zolungama. 
\b  
\q1  
\v 17 Mtima wako usachite nsanje ndi anthu ochimwa, 
\q2 koma uziopa Yehova tsiku ndi tsiku. 
\q1  
\v 18 Ndithu za mʼtsogolo zilipo 
\q2 ndipo chiyembekezo chakocho sichidzalephereka. 
\b  
\q1  
\v 19 Tamvera mwana wanga, ndipo ukhale wanzeru, 
\q2 mtima wako uwuyendetse mʼnjira yabwino. 
\q1  
\v 20 Usakhale pakati pa anthu amene amaledzera 
\q2 kapena pakati pa anthu amene amadya nyama mwadyera. 
\q1  
\v 21 Paja anthu oledzera ndi adyera amadzakhala amphawi 
\q2 ndipo aulesi adzavala sanza. 
\b  
\q1  
\v 22 Mvera abambo ako amene anakubala, 
\q2 usanyoze amayi ako pamene akalamba. 
\q1  
\v 23 Gula choonadi ndipo usachigulitse; 
\q2 ugulenso nzeru, mwambo ndiponso kumvetsa zinthu bwino. 
\q1  
\v 24 Abambo a munthu wolungama ali ndi chimwemwe chachikulu; 
\q2 Wobala mwana wanzeru adzakondwera naye. 
\q1  
\v 25 Abambo ndi amayi ako asangalale; 
\q2 amene anakubereka akondwere! 
\b  
\q1  
\v 26 Mwana wanga, undikhulupirire 
\q2 ndipo maso ako apenyetsetse njira zanga. 
\q1  
\v 27 Paja mkazi wachiwerewere ali ngati dzenje lozama; 
\q2 ndipo mkazi woyendayenda ali ngati chitsime chopapatiza. 
\q1  
\v 28 Amabisala ngati mbala yachifwamba, 
\q2 ndipo amuna amakhala osakhulupirika chifukwa cha iyeyu. 
\b  
\q1  
\v 29 Ndani ali ndi tsoka? Ndani ali ndi chisoni? 
\q2 Ndani ali pa mkangano? Ndani ali ndi madandawulo? 
\q2 Ndani ali ndi zipsera zosadziwika uko zachokera? Ndani ali ndi maso ofiira? 
\q1  
\v 30 Ndi amene amakhalitsa pa mowa, 
\q2 amene amapita nalawa vinyo osakanizidwa. 
\q1  
\v 31 Usatengeke mtima ndi kufiira kwa vinyo, 
\q2 pamene akuwira mʼchikho 
\q2 pamene akumweka bwino! 
\q1  
\v 32 Potsiriza pake amaluma ngati njoka, 
\q2 ndipo amajompha ngati mphiri. 
\q1  
\v 33 Maso ako adzaona zinthu zachilendo 
\q2 ndipo maganizo ndi mawu ako adzakhala osokonekera. 
\q1  
\v 34 Udzakhala ngati munthu amene ali gone pakati pa nyanja, 
\q2 kapena ngati munthu wogona pa msonga ya mlongoti ya ngalawa. 
\q1  
\v 35 Iwe udzanena kuti, “Anandimenya, koma sindinapwetekedwe! 
\q2 Andimenya koma sindinamve kanthu! 
\q1 Kodi ndidzuka nthawi yanji? 
\q2 Ndiye ndifunefunenso vinyo wina.” 
\c 24  
\q1  
\v 1 Usachitire nsanje anthu oyipa, 
\q2 usalakalake kuti uzikhala nawo, 
\q1  
\v 2 pakuti mitima yawo imalingalira chiwawa, 
\q2 ndipo pakamwa pawo pamayankhula zoyambitsa mavuto. 
\b  
\q1  
\v 3 Nyumba imamangidwa ndi anthu anzeru, 
\q2 ndipo imakhazikika ndi anthu odziwa zinthu; 
\q1  
\v 4 Munthu wodziwa zinthu angathe kudzaza zipinda zake 
\q2 ndi chuma chamtengowapatali ndiponso chabwino. 
\b  
\q1  
\v 5 Munthu wodziwa zinthu ali ndi mphamvu yayikulu kuposa munthu wanyonga zambiri, 
\q2 ndipo munthu wachidziwitso amaposa munthu wamphamvu. 
\q1  
\v 6 Pafunika malangizo kuti ukamenye nkhondo. 
\q2 Pakakhala aphungu ambiri kupambana kumakhalapo. 
\b  
\q1  
\v 7 Nzeru ndi chinthu chapatali kwambiri kwa chitsiru; 
\q2 chilibe choti chiyankhule pabwalo la milandu pa chipata. 
\b  
\q1  
\v 8 Amene amakonzekera kuchita zoyipa 
\q2 adzatchedwa mvundulamadzi. 
\q1  
\v 9 Kukonzekera kuchita za uchitsiru ndi tchimo, 
\q2 ndipo munthu wonyoza amanyansa anthu. 
\b  
\q1  
\v 10 Ngati utaya mtima nthawi ya mavuto ndiye kuti 
\q2 mphamvu yako ndi yochepadi! 
\b  
\q1  
\v 11 Uwapulumutse amene akutengedwa kuti akaphedwe; 
\q2 uwalanditse amene akuyenda movutika kupita kokaphedwa. 
\q1  
\v 12 Ukanena kuti, “Koma ife sitinadziwe kanthu za izi,” 
\q2 kodi Iye amene amasanthula mtima sazindikira zimenezi? 
\q1 Kodi Iye amene amateteza moyo wako sazidziwa zimenezi? 
\q2 Kodi Iye sadzalipira munthu malingana ndi ntchito zake? 
\b  
\q1  
\v 13 Mwana wanga, uzidya uchi popeza ndi wabwino; 
\q2 uchi wochokera mʼchisa cha njuchi ndi wokoma ukawulawa. 
\q1  
\v 14 Udziwe kuti nzeru ndi yoteronso pa moyo wako; 
\q2 ngati uyipeza nzeruyo, zinthu zidzakuyendera bwino mʼtsogolo, 
\q2 ndipo chiyembekezo chako sichidzapita pachabe. 
\b  
\q1  
\v 15 Usachite zachifwamba nyumba ya munthu wolungama ngati munthu woyipa. 
\q2 Usachite nayo nkhondo nyumba yake; 
\q1  
\v 16 paja munthu wolungama akagwa kasanu nʼkawiri amadzukiriranso. 
\q2 Koma woyipa adzathedwa tsoka likadzawafikira. 
\b  
\q1  
\v 17 Usamakondwera ndi kugwa kwa mdani wako. 
\q2 Mtima wako usamasangalale iye akapunthwa. 
\q1  
\v 18 Kuopa kuti Yehova ataziona zimenezi nayipidwa nazo, 
\q2 angaleke kukwiyira mdaniyo. 
\b  
\q1  
\v 19 Usavutike mtima chifukwa cha anthu ochita zoyipa 
\q2 kapena kuchitira nsanje anthu oyipa, 
\q1  
\v 20 paja munthu woyipa alibe tsogolo. 
\q2 Moyo wa anthu oyipa adzawuzimitsa ngati nyale. 
\b  
\q1  
\v 21 Mwana wanga, uziopa Yehova ndi mfumu, 
\q2 ndipo usamagwirizana ndi anthu owachitira mwano, 
\q1  
\v 22 awiri amenewa amagwetsa tsoka mwadzidzidzi. 
\q2 Ndani angadziwe mavuto amene angagwetse? 
\s1 Malangizo Enanso a Anthu Anzeru 
\p  
\v 23 Malangizo enanso a anthu anzeru ndi awa: 
\q1 Kukondera poweruza mlandu si chinthu chabwino: 
\q1  
\v 24 Aliyense amene amawuza munthu wolakwa kuti, “Iwe ndi munthu wosalakwa,” 
\q2 anthu a mitundu yonse adzamutemberera, ndi mitundu ya anthu idzayipidwa naye. 
\q1  
\v 25 Koma olanga anthu oyipa zinthu zidzawayendera bwino 
\q2 ndipo madalitso ochuluka adzakhala pa iwo. 
\b  
\q1  
\v 26 Woyankhula mawu owona 
\q2 ndiye amaonetsa chibwenzi chenicheni. 
\b  
\q1  
\v 27 Ugwiriretu ntchito zako zonse, 
\q2 makamaka za ku munda 
\q2 ndipo pambuyo pake uyambe kumanga nyumba. 
\b  
\q1  
\v 28 Usakhale mboni yotsutsa mnzako popanda chifukwa, 
\q2 kapena kugwiritsa ntchito pakamwa pako kunena zachinyengo. 
\q1  
\v 29 Usanene kuti, “Ine ndidzamuchitira iye monga momwe wandichitira ine; 
\q2 ndidzamubwezera munthu ameneyo zimene anandichitira.” 
\b  
\q1  
\v 30 Ndinkayenda mʼmbali mwa munda wa munthu waulesi 
\q2 ndinadutsa munda wamphesa wa munthu wopanda nzeru. 
\q1  
\v 31 Ndinapeza kuti paliponse mʼmundamo munali mutamera minga, 
\q2 mʼnthaka imeneyo munali mutamera khwisa, 
\q2 ndipo mpanda wake wamiyala unali utawonongeka. 
\q1  
\v 32 Tsono nditaona ndinayamba kuganizira mu mtima mwanga 
\q2 ndipo ndinatolapo phunziro ili: 
\q1  
\v 33 Ukati, “Bwanji ndigone pangʼono,” kapena “Ndiwodzereko pangʼono,” 
\q2 kapenanso “Ndipinde manja pangʼono kuti ndipumule,” 
\q1  
\v 34 umphawi udzafika pa iwe ngati mbala 
\q2 ndipo usiwa udzakupeza ngati munthu wachifwamba. 
\c 25  
\s1 Miyambo Ina ya Solomoni 
\p  
\v 1 Iyi ndi miyambo inanso ya Solomoni, imene anthu a Hezekiya mfumu ya ku Yuda analemba. 
\q1  
\v 2 Ulemerero wa Mulungu uli pa kubisa zinthu; 
\q2 ulemerero wa mafumu uli pa kufufuza zinthuzo. 
\b  
\q1  
\v 3 Monga momwe kwatalikira kumwamba ndi momwe kulili kuzama kwa dziko lapansi, 
\q2 ndi momwemonso alili maganizo a mfumu kusadziwika kwake. 
\b  
\q1  
\v 4 Chotsa zoyipa mʼsiliva 
\q2 ndipo wosula adzapanga naye ziwiya. 
\q1  
\v 5 Chotsa munthu woyipa pamaso pa mfumu; 
\q2 ndipo ufumu wake udzakhazikika mu chilungamo. 
\b  
\q1  
\v 6 Usamadzikuze ukakhala pamaso pa mfumu, 
\q2 ndipo usamakhale pamalo pa anthu apamwamba; 
\q1  
\v 7 paja ndi bwino kuti mfumu ichite kukuwuza kuti, “Bwera pamwamba pano,” 
\q2 kulekana ndi kuti ikuchititse manyazi chifukwa cha wina wokuposa. 
\b  
\q1 Chimene wachiona ndi maso ako, 
\q2  
\v 8 usafulumire kupita nacho ku bwalo la milandu 
\q1 nanga udzachita chiyani pa mapeto pake 
\q2 ngati mnansi wako adzakuchititsa manyazi? 
\b  
\q1  
\v 9 Kamba mlandu ndi mnansi wako, 
\q2 koma osawulula chinsinsi cha munthu wina 
\q1  
\v 10 kuopa kuti wina akamva mawu ako adzakuchititsa manyazi 
\q2 ndipo mbiri yako yoyipa sidzatha. 
\b  
\q1  
\v 11 Mawu amodzi woyankhulidwa moyenera 
\q2 ali ngati zokongoletsera zagolide mʼzotengera zasiliva. 
\b  
\q1  
\v 12 Kwa munthu womvetsa bwino, kudzudzula kwa munthu wanzeru kuli ngati ndolo zagolide 
\q2 kapena chodzikongoletsera china cha golide wabwino kwambiri. 
\b  
\q1  
\v 13 Wamthenga wodalirika ali ngati madzi ozizira pa nthawi yokolola 
\q2 kwa anthu amene amutuma; 
\q2 iye amaziziritsa mtima bwana wake. 
\b  
\q1  
\v 14 Munthu wonyadira mphatso imene sayipereka 
\q2 ali ngati mitambo ndi mphepo yopanda mvula. 
\b  
\q1  
\v 15 Kupirira ndiye kumagonjetsa mfumu, 
\q2 ndipo kufewa mʼkamwa kutha kumafatsitsa munthu wowuma mtima. 
\b  
\q1  
\v 16 Ngati upeza uchi, ingodya okukwanira, 
\q2 kuopa ungakoledwe nawo ndi kuyamba kusanza. 
\q1  
\v 17 Uzipita kamodzikamodzi ku nyumba ya mnzako 
\q2 ukawirikiza kupita, udzadana naye. 
\b  
\q1  
\v 18 Munthu wochitira mnzake umboni wonama, 
\q2 ali ngati chibonga kapena lupanga kapena muvi wakuthwa. 
\b  
\q1  
\v 19 Kudalira munthu wosankhulupirika pa nthawi ya mavuto, 
\q2 kuli ngati dzino lobowoka kapena phazi lolumala. 
\b  
\q1  
\v 20 Kuyimbira nyimbo munthu wachisoni 
\q2 kuli ngati kuvula zovala pa nyengo yozizira 
\q2 kapena kuthira mchere pa chilonda. 
\b  
\q1  
\v 21 Ngati mdani wako ali ndi njala, mupatse chakudya kuti adye; 
\q2 ngati ali ndi ludzu mupatse madzi kuti amwe. 
\q1  
\v 22 Pochita izi, udzamusenzetsa makala a moto pa mutu pake, 
\q2 ndipo Yehova adzakupatsa mphotho. 
\b  
\q1  
\v 23 Monga momwe mphepo yampoto imabweretsera mvula, 
\q2 chonchonso mjedu umadzetsa mkwiyo. 
\b  
\q1  
\v 24 Nʼkwabwino kukhala pa ngodya ya denga 
\q2 kuposa kukhala mʼnyumba ndi mkazi wolongolola. 
\b  
\q1  
\v 25 Mthenga wabwino wochokera ku dziko lakutali 
\q2 ali ngati madzi ozizira kwa munthu waludzu. 
\b  
\q1  
\v 26 Munthu wolungama amene amagonjera munthu woyipa 
\q2 ali ngati kasupe wodzaza ndi matope kapena chitsime cha madzi oyipa. 
\b  
\q1  
\v 27 Sibwino kudya uchi wambiri, 
\q2 sibwinonso kudzifunira wekha ulemu. 
\b  
\q1  
\v 28 Munthu amene samatha kudziretsa 
\q2 ali ngati mzinda umene adani awuthyola ndi kuwusiya wopanda malinga. 
\c 26  
\q1  
\v 1 Ngati chisanu choti mbee nthawi yachilimwe kapena mvula nthawi yokolola, 
\q2 ndi momwe zilili ndi ulemu wowulandira chitsiru. 
\b  
\q1  
\v 2 Ngati timba wokhalira kuwuluka kapena namzeze wokhalira kuzungulirazungulira, 
\q2 ndi mmenenso limachitira temberero lopanda chifukwa, silichitika. 
\b  
\q1  
\v 3 Mkwapulo ndi wokwapulira kavalo, chitsulo ndi cha mʼkamwa mwa bulu, 
\q2 choncho ndodo ndi yoyenera ku msana wa chitsiru. 
\b  
\q1  
\v 4 Usayankhe chitsiru monga mwa uchitsiru wake, 
\q2 kuopa kuti ungadzakhale ngati chitsirucho. 
\b  
\q1  
\v 5 Koma nthawi zina umuyankhe monga mwa uchitsiru wake, 
\q2 kuopa kuti angamadziyese yekha wanzeru. 
\b  
\q1  
\v 6 Kutuma chitsiru kuti akapereke uthenga 
\q2 kuli ngati kudzidula mapazi ndipo kumakuyitanira mavuto. 
\b  
\q1  
\v 7 Monga miyendo ya munthu wolumala imene ilibe mphamvu 
\q2 ndi mmene ulili mwambi mʼkamwa mwa chitsiru. 
\b  
\q1  
\v 8 Kupereka ulemu kwa chitsiru 
\q2 zili ngati kukulunga mwala mʼlegeni. 
\b  
\q1  
\v 9 Monga umachitira mtengo waminga wobaya mʼdzanja la chidakwa 
\q2 ndi mmene ulili mwambi mʼkamwa mwa chitsiru. 
\b  
\q1  
\v 10 Munthu amene amalemba ntchito chitsiru chongoyendayenda, 
\q2 ali ngati woponya mivi amene angolasa anthu chilaselase. 
\b  
\q1  
\v 11 Chitsiru chimene chimabwerezabwereza uchitsiru wake 
\q2 chili ngati galu amene amabwerera ku masanzi ake. 
\b  
\q1  
\v 12 Munthu wa uchitsiru aliko bwino popeza pali chiyembekezo 
\q2 kuposana ndi munthu amene amadziyesa yekha kuti ndi wanzeru. 
\b  
\q1  
\v 13 Munthu waulesi amati, “Mu msewu muli mkango, 
\q2 mkango woopsa ukuyendayenda mʼmisewu!” 
\b  
\q1  
\v 14 Monga chitseko chimapita uku ndi uku pa zolumikizira zake, 
\q2 momwemonso munthu waulesi amangotembenukatembenuka pa bedi lake. 
\b  
\q1  
\v 15 Munthu waulesi akapisa dzanja lake mu mʼbale; 
\q2 zimamutopetsa kuti alifikitse pakamwa pake. 
\b  
\q1  
\v 16 Munthu waulesi amadziyesa yekha wanzeru 
\q2 kuposa anthu asanu ndi awiri amene amayankha mochenjera. 
\b  
\q1  
\v 17 Munthu wongolowera mikangano imene si yake 
\q2 ali ngati munthu wogwira makutu a galu wongodziyendera. 
\b  
\q1  
\v 18 Monga munthu wamisala amene 
\q2 akuponya sakali zamoto kapena mivi yoopsa, 
\q1  
\v 19 ndi momwe alili munthu wonamiza mnzake, 
\q2 amene amati, “Ndimangoseka chabe!” 
\b  
\q1  
\v 20 Pakasowa nkhuni, moto umazima; 
\q2 chomwechonso pakasowa anthu amiseche mkangano umatha. 
\b  
\q1  
\v 21 Monga alili makala pa moto wonyeka kapena mmene zimachitira nkhuni pa moto, 
\q2 ndi mmene alili munthu wolongolola poyambitsa mikangano. 
\b  
\q1  
\v 22 Mawu a munthu wamiseche ali ngati chakudya chokoma; 
\q2 chimene chimatsikira mʼmimba mwa munthu. 
\b  
\q1  
\v 23 Monga mmene chiziro chimakutira chiwiya chadothi 
\q2 ndi mmene mawu oshashalika amabisira mtima woyipa. 
\b  
\q1  
\v 24 Munthu wachidani amayankhula zabwino 
\q2 pamene mu mtima mwake muli chinyengo. 
\q1  
\v 25 Ngakhale wotereyu mawu ake ali okoma, koma usamukhulupirire, 
\q2 pakuti mu mtima mwake mwadzaza zonyansa. 
\q1  
\v 26 Ngakhale amabisa chidani mochenjera, 
\q2 koma kuyipa kwakeko kudzaonekera poyera pa gulu la anthu. 
\b  
\q1  
\v 27 Ngati munthu akumba dzenje, adzagweramo yekha; 
\q2 ngati munthu agubuduza mwala, udzamupsinja iye mwini. 
\b  
\q1  
\v 28 Munthu wonama amadana ndi amene anawapweteka, 
\q2 ndipo pakamwa poshashalika pamabweretsa chiwonongeko. 
\c 27  
\q1  
\v 1 Usamanyadire za mawa, 
\q2 pakuti sudziwa zimene zidzachitike pa tsikulo. 
\b  
\q1  
\v 2 Munthu wina akutamande, koma osati wekha; 
\q2 mlendo akakutamanda, ndiponi koma osati ndi pakamwa pako. 
\b  
\q1  
\v 3 Mwala ndi wolemera ndipo mchenganso ndi wolemera kwambiri, 
\q2 koma makani a chitsiru ndi oposa zonsezo kulemera kwake. 
\b  
\q1  
\v 4 Mkwiyo umadzetsa nkhanza ndipo kupsa mtima kumachititsa zoopsa. 
\q2 Koma nsanje imachita zoopsa zopambana. 
\b  
\q1  
\v 5 Kudzudzula munthu poyera nʼkwabwino 
\q2 kuposa chikondi chobisika. 
\b  
\q1  
\v 6 Munthu amene amakukonda ngakhale akupweteke zili bwino, 
\q2 koma mdani wako amakupsompsona mwachinyengo. 
\b  
\q1  
\v 7 Iye amene wakhuta amayipidwa ndi chisa cha uchi, 
\q2 koma kwa munthu wanjala ngakhale chimene chili chowawa chimamukomera. 
\b  
\q1  
\v 8 Munthu amene wasochera ku nyumba kwake, 
\q2 ali monga mbalame imene yasochera pa chisa chake. 
\b  
\q1  
\v 9 Mafuta ndi zonunkhira zimasangalatsa mtima, 
\q2 ndipo kukoma mtima kwa bwenzi kwagona pa malangizo ake. 
\b  
\q1  
\v 10 Usasiye bwenzi lako ndiponso bwenzi la abambo ako, 
\q2 ndipo usapite ku nyumba ya mʼbale wako pamene wakumana ndi mavuto; 
\q2 mnzako wokhala naye pafupi amaposa mʼbale wako wokhala kutali. 
\b  
\q1  
\v 11 Mwana wanga, khala wanzeru, ndipo ukondweretse mtima wanga; 
\q2 pamenepo ine ndidzatha kuyankha aliyense amene amandinyoza. 
\b  
\q1  
\v 12 Munthu wochenjera akaona choopsa amabisala, 
\q2 koma munthu wopusa amangopitirira ndipo amakumana ndi mavuto. 
\b  
\q1  
\v 13 Utenge chovala cha munthu amene waperekera mlendo chikole; 
\q2 ngati chigwiriro chifukwa waperekera chikole mlendo wosadziwika. 
\b  
\q1  
\v 14 Ngati munthu apatsa mnzake moni mofuwula mmamawa kwambiri, 
\q2 anthu adzamuyesa kuti akutemberera. 
\b  
\q1  
\v 15 Mkazi wolongolola ali ngati 
\q2 mvula yamvumbi. 
\q1  
\v 16 Kumuletsa mkazi wotereyu zimenezi zili ngati kuletsa mphepo 
\q2 kapena kufumbata mafuta mʼdzanja. 
\b  
\q1  
\v 17 Chitsulo chimanoledwa ndi chitsulo chinzake, 
\q2 chomwechonso munthu amanoledwa ndi munthu mnzake. 
\b  
\q1  
\v 18 Amene amasamalira mtengo wamkuyu adzadya zipatso zake, 
\q2 ndipo iye amene amasamalira mbuye wake adzalandira ulemu. 
\b  
\q1  
\v 19 Monga momwe nkhope imaonekera mʼmadzi, 
\q2 chomwechonso mtima wa munthu umadziwika ndi ntchito zake. 
\b  
\q1  
\v 20 Manda sakhuta, 
\q2 nawonso maso a munthu sakhuta. 
\b  
\q1  
\v 21 Siliva amasungunulira mu uvuni ndipo golide mʼngʼanjo, 
\q2 chomwechonso munthu amadziwika ndi zomwe akudzitamandira nazo. 
\b  
\q1  
\v 22 Ngakhale utakonola chitsiru mu mtondo 
\q2 ndi musi ngati chimanga, 
\q2 uchitsiru wakewo sudzachoka. 
\b  
\q1  
\v 23 Uzidziwe bwino nkhosa zako momwe zilili. 
\q2 Kodi usamalire bwino ziweto zako? 
\q1  
\v 24 Paja chuma sichikhala mpaka muyaya, 
\q2 ndipo ufumu sukhala mpaka mibado yonse. 
\q1  
\v 25 Pamene udzu watha, msipu nʼkumera; 
\q2 ndipo atatuta udzu wa ku mapiri, 
\q1  
\v 26 ana ankhosa adzakupatsani chovala 
\q2 ndipo pogulitsa mbuzi mudzapeza ndalama yogulira munda. 
\q1  
\v 27 Mudzakhala ndi mkaka wambuzi wambiri 
\q2 kuti muzidya inuyo ndi banja lanu 
\q2 ndi kudyetsa antchito anu aakazi. 
\c 28  
\q1  
\v 1 Munthu woyipa amathawa ngakhale palibe wina womuthamangitsa, 
\q2 koma wolungama ndi wolimba mtima ngati mkango. 
\b  
\q1  
\v 2 Pamene mʼdziko muli kuwukirana, dzikolo limakhala ndi olamulira ambiri, 
\q2 koma anthu omvetsa ndi odziwa zinthu bwino ndiwo angakhazikitse bata mʼdzikolo nthawi yayitali. 
\b  
\q1  
\v 3 Munthu wosauka amene amapondereza osauka anzake 
\q2 ali ngati mvula yamkuntho imene imawononga mbewu mʼmunda. 
\b  
\q1  
\v 4 Amene amakana malamulo amatamanda anthu oyipa, 
\q2 koma amene amasunga malamulo amatsutsana nawo. 
\b  
\q1  
\v 5 Anthu oyipa samvetsa za chiweruzo cholungama, 
\q2 koma amene amafuna kuchita zimene Yehova afuna amachimvetsetsa bwino. 
\b  
\q1  
\v 6 Munthu wosauka wa makhalidwe abwino 
\q2 aposa munthu wolemera wa makhalidwe okhotakhota. 
\b  
\q1  
\v 7 Amene amasunga malamulo ndi mwana wozindikira zinthu, 
\q2 koma amene amayenda ndi anthu adyera amachititsa manyazi abambo ake. 
\b  
\q1  
\v 8 Amene amachulukitsa chuma chake polandira chiwongoladzanja chochuluka 
\q2 amakundikira chumacho anthu ena, amene adzachitira chifundo anthu osauka. 
\b  
\q1  
\v 9 Wokana kumvera malamulo 
\q2 ngakhale pemphero lake lomwe limamunyansa Yehova. 
\b  
\q1  
\v 10 Amene amatsogolera anthu olungama kuti ayende mʼnjira yoyipa 
\q2 adzagwera mu msampha wake womwe, 
\q2 koma anthu opanda cholakwa adzalandira cholowa chabwino. 
\b  
\q1  
\v 11 Munthu wolemera amadziyesa kuti ndi wanzeru, 
\q2 koma munthu wosauka amene ali ndi nzeru zodziwa zinthu amamutulukira. 
\b  
\q1  
\v 12 Pamene olungama apambana pamakhala chikondwerero chachikulu; 
\q2 koma pamene anthu oyipa apatsidwa ulamuliro, anthu amabisala. 
\b  
\q1  
\v 13 Wobisa machimo ake sadzaona mwayi, 
\q2 koma aliyense amene awulula ndi kuleka machimowo, adzalandira chifundo. 
\b  
\q1  
\v 14 Ndi wodala munthu amene amaopa Yehova nthawi zonse, 
\q2 koma amene aumitsa mtima wake adzagwa mʼmavuto. 
\b  
\q1  
\v 15 Ngati mkango wobuma kapena chimbalangondo cholusa 
\q2 ndi mmenenso amakhalira munthu woyipa akamalamulira anthu osauka. 
\b  
\q1  
\v 16 Wolamulira amene samvetsa zinthu ndiye amakhala wankhanza 
\q2 koma amene amadana ndi phindu lopeza mwachinyengo adzakhala ndi moyo wautali. 
\b  
\q1  
\v 17 Munthu amene wapalamula mlandu wopha munthu 
\q2 adzakhala wothawathawa mpaka imfa yake; 
\q2 wina aliyense asamuthandize. 
\b  
\q1  
\v 18 Amene amayenda mokhulupirika adzapulumutsidwa 
\q2 koma amene njira zake ndi zokhotakhota adzagwa mʼdzenje. 
\b  
\q1  
\v 19 Amene amalima mʼmunda mwake adzakhala ndi chakudya chochuluka, 
\q2 koma amene amangosewera adzakhala mʼmphawi. 
\b  
\q1  
\v 20 Munthu wokhulupirika adzadalitsika kwambiri, 
\q2 koma wofuna kulemera mofulumira adzalangidwa. 
\b  
\q1  
\v 21 Kukondera si kwabwino, 
\q2 ena amachita zolakwazo chifukwa cha kachidutswa ka buledi. 
\b  
\q1  
\v 22 Munthu wowumira amafunitsitsa kulemera 
\q2 koma sazindikira kuti umphawi udzamugwera. 
\b  
\q1  
\v 23 Amene amadzudzula mnzake potsiriza pake 
\q2 mnzakeyo adzamukonda kwambiri, kupambana amene amanena mawu oshashalika. 
\b  
\q1  
\v 24 Amene amabera abambo ake kapena amayi ake 
\q2 namanena kuti “kumeneko sikulakwa,” 
\q2 ndi mnzake wa munthu amene amasakaza. 
\b  
\q1  
\v 25 Munthu wadyera amayambitsa mikangano, 
\q2 koma amene amadalira Yehova adzalemera. 
\b  
\q1  
\v 26 Amene amadzidalira yekha ndi chitsiru, 
\q2 koma amene amatsata nzeru za ena adzapulumuka. 
\b  
\q1  
\v 27 Amene amapereka kwa osauka sadzasowa kanthu, 
\q2 koma amene amatsinzina maso ake adzatembereredwa kwambiri. 
\b  
\q1  
\v 28 Pamene anthu oyipa apatsidwa ulamuliro anthu amabisala, 
\q2 koma anthu oyipa akawonongeka olungama amapeza bwino. 
\c 29  
\q1  
\v 1 Munthu amene amawumitsabe khosi lake atadzudzulidwa kwambiri, 
\q2 adzawonongeka mwadzidzidzi popanda chomuchiritsa. 
\b  
\q1  
\v 2 Anthu olungama akamalamulira mʼdziko anthu amakondwa, 
\q2 koma ngati dziko lilamulidwa ndi anthu oyipa mtima anthu amadandaula. 
\b  
\q1  
\v 3 Munthu amene amakonda nzeru amasangalatsa abambo ake, 
\q2 koma woyenda ndi akazi achiwerewere amasakaza chuma chake. 
\b  
\q1  
\v 4 Mfumu imalimbitsa dziko poweruza mwachilungamo, 
\q2 koma mfumu imene imawumiriza anthu kuti ayipatse mphatso imawononga dziko. 
\b  
\q1  
\v 5 Munthu woshashalika mnzake, 
\q2 akudziyalira ukonde mapazi ake. 
\b  
\q1  
\v 6 Munthu woyipa amakodwa ndi machimo ake, 
\q2 koma wochita chilungamo amayimba lokoma. 
\b  
\q1  
\v 7 Munthu wolungama amasamalira anthu osauka, 
\q2 koma woyipa salabadira zimenezi. 
\b  
\q1  
\v 8 Anthu onyoza atha kuwutsa ziwawa mu mzinda, 
\q2 koma anthu anzeru amaletsa ukali. 
\b  
\q1  
\v 9 Ngati munthu wanzeru atsutsana ndi chitsiru, 
\q2 chitsirucho chimachita phokoso ndi kumangoseka ndipo sipakhala mtendere. 
\b  
\q1  
\v 10 Anthu okhetsa magazi amadana ndi munthu wangwiro 
\q2 koma anthu olungama amasamalira moyo wake. 
\b  
\q1  
\v 11 Munthu wopusa amaonetsa mkwiyo wake, 
\q2 koma munthu wanzeru amadzigwira. 
\b  
\q1  
\v 12 Ngati wolamulira amvera zabodza, 
\q2 akuluakulu ake onse adzakhala oyipa. 
\b  
\q1  
\v 13 Munthu wosauka ndi munthu wopondereza anzake amafanana pa kuti: 
\q2 Yehova ndiye anawapatsa maso onsewa. 
\b  
\q1  
\v 14 Ngati mfumu iweruza osauka moyenera, 
\q2 mpando wake waufumu udzakhazikika nthawi zonse. 
\b  
\q1  
\v 15 Ndodo ndi chidzudzulo zimapatsa nzeru 
\q2 koma mwana womulekerera amachititsa amayi ake manyazi. 
\b  
\q1  
\v 16 Oyipa akamalamulira zoyipa zimachuluka, 
\q2 koma anthu olungama adzaona kugwa kwa anthu oyipawo. 
\b  
\q1  
\v 17 Umulange mwana wako ndipo adzakupatsa mtendere 
\q2 ndi kusangalatsa mtima wako. 
\b  
\q1  
\v 18 Ngati uthenga wochokera kwa Yehova supezeka anthu amangochita zofuna zawo; 
\q2 koma wodala ndi amene amasunga malamulo. 
\b  
\q1  
\v 19 Munthu wantchito sangalangizidwe ndi mawu okha basi; 
\q2 ngakhale awamvetse mawuwo sadzatha kuchitapo kanthu. 
\b  
\q1  
\v 20 Ngakhale munthu wa uchitsiru nʼkuti ndiponi popeza chikhulupiriro chilipo 
\q2 kuposa munthu wodziyesa yekha kuti ndi wanzeru poyankhula. 
\b  
\q1  
\v 21 Ngati munthu asasatitsa wantchito wake kuyambira ali mwana, 
\q2 potsirizira adzapeza kuti wantchitoyo wasanduka mlowachuma wake. 
\b  
\q1  
\v 22 Munthu wamkwiyo amayambitsa mikangano, 
\q2 ndipo munthu waukali amachita zolakwa zambiri. 
\b  
\q1  
\v 23 Kunyada kwa munthu kudzamutsitsa, 
\q2 koma munthu wodzichepetsa amalandira ulemu. 
\b  
\q1  
\v 24 Woyenda ndi munthu wakuba ndi mdani wa moyo wake womwe; 
\q2 amalumbira koma osawulula kanthu. 
\b  
\q1  
\v 25 Kuopa munthu kudzakhala ngati msampha, 
\q2 koma aliyense amene amadalira Yehova adzatetezedwa. 
\b  
\q1  
\v 26 Anthu ambiri amafunitsitsa kuti wolamulira awakomere mtima, 
\q2 koma munthu amaweruzidwa mwachilungamo ndi thandizo la Yehova basi. 
\b  
\q1  
\v 27 Anthu olungama amanyansidwa ndi anthu achinyengo; 
\q2 koma anthu oyipa amanyansidwa ndi anthu a mtima wowongoka. 
\c 30  
\s1 Mawu a Aguri 
\p  
\v 1 Nawa mawu a Aguri mwana wa Yake wa ku Masa: 
\q1 Munthuyo anati kwa Itieli, “Inu Mulungu, ine ndatopa. 
\q2 Inu Mulungu, ine ndatopa. Ndalefukiratu. 
\b  
\q1  
\v 2 “Ine ndine munthu wopusa kuposa anthu onse; 
\q2 ndilibe nzeru zomvetsa zinthu zonga za munthu. 
\q1  
\v 3 Sindinaphunzire nzeru, 
\q2 ndipo Woyerayo sindimudziwa. 
\q1  
\v 4 Kodi ndani anakwera kumwamba ndi kutsikako? 
\q2 Ndani anafumbatapo mphepo mʼmanja mwake? 
\q1 Ndani anamanga madzi mʼchovala chake? 
\q2 Ndani anakhazikitsa mathero onse a dziko lapansi? 
\q1 Dzina lake ndani? Ndiwuze ngati ukudziwa! 
\q2 Ndipo mwana wake dzina lake ndani? 
\b  
\q1  
\v 5 “Mawu ali wonse a Mulungu ndi opanda cholakwika; 
\q2 Iye ndi chishango kwa amene amathawira kwa Iye. 
\q1  
\v 6 Usawonjezepo kanthu pa mawu ake, 
\q2 kuopa kuti Iye angadzakudzudzule ndi kukupeza kuti ndiwe wabodza.” 
\b  
\q1  
\v 7 “Inu Yehova, ndikukupemphani zinthu ziwiri 
\q2 musandimane zimenezo ndisanafe: 
\q1  
\v 8 Choyamba, mundichotsere kutali nane mabodza ndi chinyengo. 
\q2 Chachiwiri, ndisakhale mʼmphawi kapena munthu wachuma. 
\q2 Koma muzindidyetsa chakudya chondikwanira tsiku ndi tsiku 
\q1  
\v 9 kuopa kuti ndikakhuta kwambiri ndingayambe kukukanani, 
\q2 nʼkumanena kuti, ‘Yehova ndiye yaninso?’ 
\q1 Kuopanso kuti ndikakhala wosauka ndingayambe kuba, 
\q2 potero nʼkuyipitsa dzina la Mulungu wanga.” 
\b  
\q1  
\v 10 “Usamusinjirire wantchito kwa mbuye wake 
\q2 kuopa kuti angakutemberere ndipo iweyo nʼkupezeka wolakwa.” 
\b  
\q1  
\v 11 “Alipo ena amene amatemberera abambo awo, 
\q2 ndipo sadalitsa amayi awo. 
\q1  
\v 12 Pali ena amene amadziyesa okha oyera mtima 
\q2 komatu sanachotse zoyipa zawo. 
\q1  
\v 13 Pali ena ndi odzitukumula kwambiri, 
\q2 amene amakweza zikope modzitukumula. 
\q1  
\v 14 Pali ena amene mano awo ali ngati malupanga 
\q2 ndipo zibwano zawo zili ngati mipeni 
\q1 moti amadya amphawi ndi kuwachotsa pa dziko lapansi. 
\q2 Amachotsanso anthu osauka pakati pa anzawo.” 
\b  
\q1  
\v 15 “Msundu uli ndi ana aakazi awiri 
\q2 iwo amalira kuti, ‘Tipatseni! Tipatseni!’ ” 
\b  
\q1 “Pali zinthu zitatu zimene sizikhuta, 
\q2 zinthu zinayi zimene sizinena kuti, ‘Takhuta!’ 
\q1  
\v 16 Manda, mkazi wosabala, 
\q2 nthaka yosakhuta madzi 
\q2 ndiponso moto womangoyakirayakira!” 
\b  
\q1  
\v 17 Aliyense amene amanyoza abambo ake, 
\q2 ndi kunyozera kumvera amayi ake, 
\q1 makwangwala a ku chigwa adzamukolowola maso 
\q2 ndipo mphungu zidzadya mnofu wake. 
\b  
\q1  
\v 18 Pali zinthu zitatu zimene zimandidabwitsa, 
\q2 zinthu zinayi zimene ine sindizimvetsetsa. 
\q1  
\v 19 Ndipo ndi izi: mmene chiwulukira chiwombankhanga mlengalenga; 
\q2 mmene iyendera njoka pa thanthwe; 
\q1 mmene chiyendera chombo pa nyanja; 
\q2 ndiponso mmene mwamuna achitira akakhala ndi namwali. 
\b  
\q1  
\v 20 Umu ndi mʼmene mkazi amachitira atachita chigololo: 
\q2 Atatha kudya ndi kupukuta pakamwa pake 
\q2 iye amanena kuti “Sindinachite kalikonse kolakwa.” 
\b  
\q1  
\v 21 Pali zinthu zitatu zimene zimanjenjemeretsa dziko lapansi, 
\q2 pali zinthu zinayi zimene dziko lapansi silingathe kuzipirira: 
\q1  
\v 22 Kapolo amene wasanduka mfumu, 
\q2 chitsiru chimene chakhuta, 
\q1  
\v 23 mkazi wonyozeka akakwatiwa 
\q2 ndiponso wantchito wamkazi akalanda mwamuna wa mbuye wake. 
\b  
\q1  
\v 24 Pali zinthu zinayi zingʼonozingʼono pa dziko lapansi, 
\q2 komatu ndi zochenjera kwambiri: 
\q1  
\v 25 Nyerere zili ngati anthu opanda mphamvu, 
\q2 komatu zimasungiratu chakudya chake nthawi ya chilimwe; 
\q1  
\v 26 mbira zili ngati anthu opanda mphamvu 
\q2 komatu zimakonza pokhalapo pawo mʼmiyala; 
\q1  
\v 27 dzombe lilibe mfumu, 
\q2 komatu lonse limakhala mʼmagulumagulu poyenda. 
\q1  
\v 28 Buluzi ungathe kumugwira mʼmanja 
\q2 komatu amapezeka mʼnyumba za mafumu. 
\b  
\q1  
\v 29 “Pali zinthu zitatu zimene zimayenda chinyachinya, 
\q2 pali zinthu zinayi zimene zimayenda monyadira: 
\q1  
\v 30 Mkango umene uli wamphamvu kuposa nyama zonse, 
\q2 ndipo suthawa kanthu kalikonse. 
\q1  
\v 31 Tambala woyenda chinyachinya, mbuzi yayimuna, 
\q2 ndiponso mfumu yoyenda pakati pa anthu ake. 
\b  
\q1  
\v 32 “Ngati wakhala ukupusa ndi kumadzikweza wekha, 
\q2 kapena ngati wakhala ukukonzekera zoyipa, 
\q2 ndiye khala kaye chete, uganizire bwino! 
\q1  
\v 33 Paja pakutha mkaka mafuta amapangidwa, 
\q2 ndipo ukapsinya mphuno, magazi amatuluka, 
\q2 ndipo mikangano imakhalapo ukalimbikira kukwiya.” 
\c 31  
\s1 Mawu a Mfumu Lemueli 
\p  
\v 1 Nawa mawu a mfumu Lemueli wa ku Massa amene anamuphunzitsa amayi ake: 
\q1  
\v 2 Nʼchiyani mwana wanga? Nʼchiyani mwana wa mʼmimba mwanga? 
\q2 Nʼchiyani iwe mwana wanga amene ndinachita kupempha ndi malumbiro? 
\q1  
\v 3 Usapereke mphamvu yako kwa akazi. 
\q2 Usamayenda nawo amenewa popeza amawononga ngakhale mafumu. 
\b  
\q1  
\v 4 Iwe Lemueli si choyenera kwa mafumu, 
\q2 mafumu sayenera kumwa vinyo. 
\q2 Olamulira asamalakalake chakumwa choledzeretsa 
\q1  
\v 5 kuopa kuti akamwa adzayiwala malamulo a dziko, 
\q2 nayamba kukhotetsa zinthu zoyenera anthu osauka. 
\q1  
\v 6 Perekani chakumwa choledzeretsa kwa amene ali pafupi kufa, 
\q2 vinyo kwa amene ali pa mavuto woopsa; 
\q1  
\v 7 amwe kuti ayiwale umphawi wawo 
\q2 asakumbukirenso kuvutika kwawo. 
\b  
\q1  
\v 8 Yankhula mʼmalo mwa amene sangathe kudziyankhulira okha. 
\q2 Uwayankhulire anthu onse osiyidwa pa zonse zowayenera. 
\q1  
\v 9 Yankhula ndi kuweruza mwachilungamo. 
\q2 Uwateteze amphawi ndi osauka. 
\s1 Mathero: Mkazi Wangwiro 
\q1  
\v 10 Kodi mkazi wangwiro angathe kumupeza ndani? 
\q2 Ndi wokwera mtengo kuposa miyala yamtengowapatali. 
\q1  
\v 11 Mtima wa mwamuna wake umamukhulupirira 
\q2 ndipo mwamunayo sasowa phindu. 
\q1  
\v 12 Masiku onse a moyo wake 
\q2 mkaziyo amachitira mwamuna wake zabwino zokhazokha osati zoyipa. 
\q1  
\v 13 Iye amafunafuna ubweya ndi thonje; 
\q2 amagwira ntchito ndi manja ake mwaufulu. 
\q1  
\v 14 Iye ali ngati sitima zapamadzi za anthu amalonda, 
\q2 amakatenga chakudya chake kutali. 
\q1  
\v 15 Iye amadzuka kusanache kwenikweni; 
\q2 ndi kuyamba kukonzera a pa banja pake chakudya 
\q2 ndi kuwagawira ntchito atsikana ake antchito. 
\q1  
\v 16 Iye amalingalira za munda ndi kuwugula; 
\q2 ndi ndalama zimene wazipeza amalima munda wamphesa. 
\q1  
\v 17 Iye amavala zilimbe 
\q2 nagwira ntchito mwamphamvu ndi manja ake. 
\q1  
\v 18 Iye amaona kuti malonda ake ndi aphindu, 
\q2 choncho nyale yake sizima usiku wonse. 
\q1  
\v 19 Iye amadzilukira thonje 
\q2 ndipo yekha amagwira chowombera nsalu. 
\q1  
\v 20 Iye amachitira chifundo anthu osauka 
\q2 ndipo amapereka chithandizo kwa anthu osowa. 
\q1  
\v 21 Iye saopa kuti banja lake lifa ndi kuzizira pa nyengo yachisanu; 
\q2 pakuti onse amakhala atavala zovala zofunda. 
\q1  
\v 22 Iye amadzipangira yekha zoyala pa bedi pake; 
\q2 amavala zovala zabafuta ndi zapepo. 
\q1  
\v 23 Mwamuna wake ndi wodziwika pa chipata cha mzinda, 
\q2 ndipo amakhala pakati pa akuluakulu a mʼdzikomo. 
\q1  
\v 24 Iye amasoka nsalu zabafuta nazigulitsa; 
\q2 amaperekanso mipango kwa anthu amalonda. 
\q1  
\v 25 Mphamvu ndi ulemu zimakhala ngati chovala chake; 
\q2 ndipo amaseka osaopa zamʼtsogolo. 
\q1  
\v 26 Iye amayankhula mwanzeru, 
\q2 amaphunzitsa anthu mwachikondi. 
\q1  
\v 27 Iye amayangʼanira makhalidwe a anthu a pa banja lake 
\q2 ndipo sachita ulesi ndi pangʼono pomwe. 
\q1  
\v 28 Ana ake amamunyadira ndipo amamutcha kuti wodala; 
\q2 ndipo mwamuna wake, amamuyamikira nʼkumati, 
\q1  
\v 29 “Pali akazi ambiri amene achita zinthu zopambana 
\q2 koma iwe umawaposa onsewa.” 
\q1  
\v 30 Nkhope yachikoka ndi yonyenga, ndipo kukongola nʼkosakhalitsa; 
\q2 koma mkazi amene amaopa Yehova ayenera kutamandidwa. 
\q1  
\v 31 Mupatseni mphotho chifukwa cha zimene iye wachita 
\q2 ndipo ntchito zake zimutamande ku mabwalo.