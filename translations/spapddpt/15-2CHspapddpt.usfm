\v 9 ¿\w No|strong="H3808"\w* expulsaron ustedes \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón \w y|strong="H1241"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w*, \w y|strong="H1241"\w* designaron \w sacerdotes|strong="H3548"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* manera \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w pueblos|strong="H5971"\w* \w de|strong="H1121"\w* otras tierras, \w para|strong="H1961"\w* \w que|strong="H3808"\w* \w cualquiera|strong="H3605"\w* \w que|strong="H3808"\w* sacrifique un \w becerro|strong="H6499"\w* \w y|strong="H1241"\w* \w siete|strong="H7651"\w* carneros \w sea|strong="H1961"\w* \w sacerdote|strong="H3548"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w son|strong="H1961"\w* \nd ʼElohim\nd*?   
\p
\v 10 En cuanto \w a|strong="H3068"\w* nosotros, \nd \+w Yavé|strong="H3068"\+w*\nd* es nuestro \nd ʼElohim\nd*, y \w no|strong="H3808"\w* \w lo|strong="H3808"\w* abandonamos. \w Los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* \w que|strong="H3808"\w* \w ministran|strong="H8334"\w* delante \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w son|strong="H3808"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón, y \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* atienden su \w obra|strong="H4399"\w*.  
\v 11 \w Ellos|strong="H5921"\w* ofrecen \w holocaustos|strong="H5930"\w* \w e|strong="H3068"\w* incienso \w aromático|strong="H5561"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* cada \w mañana|strong="H1242"\w* \w y|strong="H3588"\w* \w al|strong="H5921"\w* llegar cada noche. Ponen \w los|strong="H5921"\w* \w panes|strong="H3899"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w mesa|strong="H7979"\w* \w limpia|strong="H2889"\w*. Cada noche \w encienden|strong="H1197"\w* \w el|strong="H5921"\w* candelabro \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w con|strong="H5921"\w* sus \w lámparas|strong="H5216"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* ardan, \w porque|strong="H3588"\w* \w nosotros|strong="H5921"\w* \w guardamos|strong="H8104"\w* \w el|strong="H5921"\w* mandato \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd*. \w Pero|strong="H3588"\w* ustedes \w lo|strong="H5921"\w* abandonaron.   
\p
\v 12 \w Ciertamente|strong="H3588"\w* \nd ʼElohim\nd* \w está|strong="H5921"\w* \w como|strong="H3588"\w* \w Jefe|strong="H7218"\w* \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w*, \w y|strong="H3588"\w* sus \w sacerdotes|strong="H3548"\w* \w con|strong="H5973"\w* \w las|strong="H5921"\w* \w trompetas|strong="H2689"\w* \w de|strong="H5921"\w* \w júbilo|strong="H8643"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* resuenen \w contra|strong="H5921"\w* ustedes. ¡\w Oh|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w no|strong="H3808"\w* luchen \w contra|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* sus antepasados, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* prosperarán!   
\p
\v 13 Pero \w Jeroboam|strong="H3379"\w* dispuso una emboscada \w para|strong="H1961"\w* llegar \w contra|strong="H6440"\w* ellos \w por|strong="H6440"\w* detrás. Así \w que|strong="H1961"\w* ellos \w estaban|strong="H1961"\w* frente \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*, pero \w los|strong="H1961"\w* \w de|strong="H6440"\w* la tropa emboscada \w estaban|strong="H1961"\w* \w por|strong="H6440"\w* la retaguardia.   
\p
\v 14 Cuando \w Judá|strong="H3063"\w* dio vuelta, \w ciertamente|strong="H2009"\w* eran atacados \w por|strong="H6440"\w* el frente y \w por|strong="H6440"\w* la retaguardia. Entonces \w clamaron|strong="H6817"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, los \w sacerdotes|strong="H3548"\w* \w tocaron|strong="H2690"\w* las \w trompetas|strong="H2689"\w*  
\v 15 y \w los|strong="H3605"\w* hombres \w de|strong="H6440"\w* \w Judá|strong="H3063"\w* lanzaron \w el|strong="H3605"\w* grito \w de|strong="H6440"\w* guerra. \w Sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* \w los|strong="H3605"\w* hombres \w de|strong="H6440"\w* \w Judá|strong="H3063"\w* gritaron, \nd ʼElohim\nd* \w desbarató|strong="H5062"\w* \w a|strong="H3068"\w* \w Jeroboam|strong="H3379"\w* y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Abías y \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*.   
\p
\v 16 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w huyeron|strong="H5127"\w*, \w porque|strong="H6440"\w* \nd ʼElohim\nd* \w los|strong="H1121"\w* \w entregó|strong="H5414"\w* en \w mano|strong="H3027"\w* \w de|strong="H6440"\w* \w Judá|strong="H3063"\w*.  
\v 17 Abías y su \w pueblo|strong="H5971"\w* \w hicieron|strong="H5221"\w* una \w gran|strong="H7227"\w* \w matanza|strong="H2491"\w* entre ellos. \w Cayeron|strong="H5307"\w* \w en|strong="H5221"\w* combate 500.000 hombres escogidos \w de|strong="H2568"\w* \w Israel|strong="H3478"\w*.   
\p
\v 18 \w De|strong="H5921"\w* \w esta|strong="H1931"\w* manera \w los|strong="H1121"\w* descendientes \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* fueron humillados \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w*, \w pero|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* prevalecieron \w porque|strong="H3588"\w* \w se|strong="H1931"\w* apoyaron \w en|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H1931"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w sus|strong="H1931"\w* antepasados.   
\p
\v 19 Abías \w persiguió|strong="H7291"\w* \w a|strong="H3068"\w* \w Jeroboam|strong="H3379"\w* y le \w tomó|strong="H3920"\w* algunas \w ciudades|strong="H5892"\w*, \w a|strong="H3068"\w* Bet-ʼEl, \w a|strong="H3068"\w* Jesana y \w a|strong="H3068"\w* Efraín, cada una \w con|strong="H4480"\w* sus \w aldeas|strong="H1323"\w*.  
\v 20 \w Jeroboam|strong="H3379"\w* \w no|strong="H3808"\w* recuperó su \w poder|strong="H3581"\w* \w en|strong="H5750"\w* el \w tiempo|strong="H3117"\w* \w de|strong="H5750"\w* Abías. \nd \+w Yavé|strong="H3068"\+w*\nd* \w lo|strong="H3808"\w* \w hirió|strong="H5062"\w*, y \w murió|strong="H4191"\w*.   
\p
\v 21 Abías se fortaleció. \w Tomó|strong="H5375"\w* para \w él|strong="H1121"\w* 14 esposas, y \w engendró|strong="H3205"\w* 22 \w hijos|strong="H1121"\w* y 16 \w hijas|strong="H1323"\w*.   
\p
\v 22 Los demás \w hechos|strong="H1697"\w* \w de|strong="H1697"\w* Abías, sus procedimientos y dichos, están \w escritos|strong="H3789"\w* en \w el|strong="H5030"\w* rollo del \w profeta|strong="H5030"\w* \w Iddo|strong="H5714"\w*.   
\c 14  
\s1 Reinado de Asa en Judá  
\p
\v 1 Abías descansó con sus antepasados y \w lo|strong="H6213"\w* sepultaron en la Ciudad \w de|strong="H5869"\w* David. Reinó en su lugar su hijo Asa. En su tiempo la tierra estuvo en paz durante diez años.   
\p
\v 2 Asa hizo lo bueno y lo recto ante \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd*,  
\v 3 porque quitó los altares de culto extraño y los lugares altos, quebró las piedras rituales y destruyó los símbolos de Asera.  
\v 4 Mandó \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w que|strong="H3605"\w* buscara \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H3605"\w* \nd ʼElohim\nd* \w de|strong="H6440"\w* sus antepasados, y \w que|strong="H3605"\w* practicara \w la|strong="H3605"\w* Ley y sus Mandamientos.  
\v 5 \w Además|strong="H3588"\w* quitó \w los|strong="H5973"\w* \w lugares|strong="H5892"\w* altos \w y|strong="H3588"\w* las imágenes \w de|strong="H3588"\w* todas las \w ciudades|strong="H5892"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*. \w En|strong="H5973"\w* \w su|strong="H3588"\w* reinado hubo paz.   
\p
\v 6 \w También|strong="H5750"\w* \w edificó|strong="H1129"\w* \w ciudades|strong="H5892"\w* fortificadas \w en|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w porque|strong="H3588"\w* \w había|strong="H3588"\w* paz. \w No|strong="H3588"\w* hubo guerra \w contra|strong="H6440"\w* \w él|strong="H3588"\w* \w en|strong="H3588"\w* aquellos años, \w pues|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* le dio paz.   
\p
\v 7 Así \w que|strong="H1869"\w* \add el rey Asa\add* dijo \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*: Edifiquemos estas ciudades y rodeémoslas con muros y torres, portones y barras, ya \w que|strong="H1869"\w* \w la|strong="H3605"\w* tierra aún \w es|strong="H1961"\w* nuestra, porque buscamos \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd*. \w Lo|strong="H3605"\w* buscamos, y \w Él|strong="H3605"\w* nos dio reposo por \w todas|strong="H3605"\w* partes. Así \w que|strong="H1869"\w* edificaron y prosperaron.   
\p
\v 8 Asa tuvo un \w ejército|strong="H2428"\w* \w de|strong="H5704"\w* 300.000 hombres \w de|strong="H5704"\w* Judá, quienes llevaban escudos \w y|strong="H5704"\w* lanzas, \w y|strong="H5704"\w* 280.000 \w de|strong="H5704"\w* Benjamín, quienes llevaban escudos \w y|strong="H5704"\w* tensaban arcos. Todos eran hombres \w valientes|strong="H2428"\w*.   
\p
\v 9 Zera, el etíope, \w salió|strong="H3318"\w* \w contra|strong="H6440"\w* ellos con un ejército \w de|strong="H6440"\w* 1.000.000 \w de|strong="H6440"\w* hombres y 300 carruajes, y llegó hasta \w Maresa|strong="H4762"\w*.  
\v 10 \w Entonces|strong="H3588"\w* Asa salió \w contra|strong="H5921"\w* \w él|strong="H5921"\w*. Dispusieron \w la|strong="H5921"\w* batalla \w en|strong="H5921"\w* \w el|strong="H5921"\w* valle \w de|strong="H5921"\w* Sefata, \w junto|strong="H5921"\w* \w a|strong="H3068"\w* Maresa.   
\p
\v 11 Asa invocó \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd*: ¡Oh \nd \+w Yavé|strong="H3068"\+w*\nd*, \w no|strong="H6440"\w* hay otro como Tú para ayudar, tanto al poderoso como al que \w no|strong="H6440"\w* tiene fuerza! ¡Ayúdanos, oh \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* nuestro, \w porque|strong="H6440"\w* en ti nos apoyamos, y en tu Nombre vamos \w contra|strong="H6440"\w* esta multitud! Oh \nd \+w Yavé|strong="H3068"\+w*\nd*, Tú eres nuestro \nd ʼElohim\nd*, \w no|strong="H6440"\w* prevalezca el hombre \w contra|strong="H6440"\w* Ti.   
\p
\v 12 \nd \+w Yavé|strong="H3068"\+w*\nd* derrotó \w a|strong="H3068"\w* \w los|strong="H1992"\w* etíopes \w ante|strong="H6440"\w* Asa \w y|strong="H3588"\w* Judá, \w y|strong="H3588"\w* \w los|strong="H1992"\w* etíopes huyeron.  
\v 13 Asa \w y|strong="H3588"\w* \w el|strong="H5921"\w* ejército \w que|strong="H3588"\w* \w lo|strong="H5921"\w* acompañaba \w los|strong="H5921"\w* persiguieron \w hasta|strong="H5921"\w* \w Gerar|strong="H1642"\w*. Cayeron tantos \w de|strong="H5921"\w* \w los|strong="H5921"\w* etíopes \w que|strong="H3588"\w* \w no|strong="H3588"\w* pudieron recuperarse, \w porque|strong="H3588"\w* \w fueron|strong="H1961"\w* destrozados ante \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H3588"\w* \w su|strong="H3588"\w* ejército. \w Les|strong="H5921"\w* tomaron un botín muy \w grande|strong="H7227"\w*.  
\v 14 Atacaron \w también|strong="H1571"\w* todas las ciudades alrededor de Gerar, porque \w el|strong="H1571"\w* terror de \nd \+w Yavé|strong="H3068"\+w*\nd* estaba sobre ellas. Saquearon todas las ciudades, \w pues|strong="H1571"\w* había \w en|strong="H5221"\w* ellas un gran botín.  
\v 15 También atacaron las tiendas de los que tenían ganado. Se llevaron muchas ovejas y camellos y regresaron \w a|strong="H3068"\w* Jerusalén.   
\c 15  
\s1 Reformas del rey Asa  
\p
\v 1 Entonces \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* \w vino|strong="H1961"\w* \w sobre|strong="H5921"\w* \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Oded,  
\v 2 \w quien|strong="H3605"\w* \w salió|strong="H3318"\w* al encuentro \w de|strong="H6440"\w* Asa y \w le|strong="H5973"\w* dijo: \wj Escúchenme, Asa y \+w todo|strong="H3605"\+w* \+w Judá|strong="H3063"\+w* y \+w Benjamín|strong="H1144"\+w*: \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w está|strong="H1961"\+w* \+w con|strong="H5973"\+w* ustedes, \+w si|strong="H6440"\+w* ustedes \+w están|strong="H1961"\+w* \+w con|strong="H5973"\+w* \+w Él|strong="H5973"\+w*. \+w Si|strong="H6440"\+w* \+w lo|strong="H3605"\+w* \+w buscan|strong="H1875"\+w*, \+w será|strong="H1961"\+w* \+w hallado|strong="H4672"\+w* \+w por|strong="H6440"\+w* ustedes, pero \+w si|strong="H6440"\+w* \+w lo|strong="H3605"\+w* \+w abandonan|strong="H5800"\+w*, \+w Él|strong="H5973"\+w* \+w los|strong="H3605"\+w* abandonará.\wj*  
\v 3 \wj \+w Mucho|strong="H7227"\+w* \+w tiempo|strong="H3117"\+w* estuvo \+w Israel|strong="H3478"\+w* \+w sin|strong="H3808"\+w* el \+nd ʼElohim\+nd* verdadero, \+w sin|strong="H3808"\+w* \+w sacerdote|strong="H3548"\+w* \+w que|strong="H3808"\+w* \+w enseñara|strong="H3384"\+w* y \+w sin|strong="H3808"\+w* \+w Ley|strong="H8451"\+w*.\wj*   
\p
\v 4 \wj Pero cuando \+w se|strong="H5921"\+w* \+w volvieron|strong="H7725"\+w* \+w a|strong="H3068"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w el|strong="H5921"\+w* \+nd ʼElohim\+nd* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w*, \+w en|strong="H5921"\+w* su \+w aflicción|strong="H6862"\+w* \+w y|strong="H5921"\+w* \+w lo|strong="H5921"\+w* \+w buscaron|strong="H1245"\+w*, \+w Él|strong="H5921"\+w* \+w les|strong="H5921"\+w* permitió encontrarlo.\wj*   
\p
\v 5 \wj \+w En|strong="H5921"\+w* \+w aquellos|strong="H1992"\+w* tiempos \+w no|strong="H3588"\+w* \+w había|strong="H3588"\+w* \+w paz|strong="H7965"\+w* \+w para|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w que|strong="H3588"\+w* \+w salía|strong="H3318"\+w* ni \+w para|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w que|strong="H3588"\+w* entraba, \+w sino|strong="H3588"\+w* \+w muchas|strong="H7227"\+w* \+w aflicciones|strong="H4103"\+w* \+w para|strong="H5921"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H1992"\+w* \+w habitantes|strong="H3427"\+w* \+w de|strong="H5921"\+w* \+w las|strong="H1992"\+w* tierras.\wj*  
\v 6 \wj \+w Así|strong="H3588"\+w* \+w que|strong="H3588"\+w* una \+w nación|strong="H1471"\+w* era destruida \+w por|strong="H3588"\+w* otra \+w nación|strong="H1471"\+w* \+w y|strong="H3588"\+w* una \+w ciudad|strong="H5892"\+w* \+w por|strong="H3588"\+w* otra \+w ciudad|strong="H5892"\+w*, \+w porque|strong="H3588"\+w* \+nd ʼElohim\+nd* las turbaba \+w con|strong="H3588"\+w* \+w toda|strong="H3605"\+w* clase \+w de|strong="H3588"\+w* adversidades.\wj*   
\p
\v 7 \wj \+w Pero|strong="H3588"\+w* \+w esfuércense|strong="H2388"\+w* ustedes \+w y|strong="H3588"\+w* \+w no|strong="H3588"\+w* desmayen sus \+w manos|strong="H3027"\+w*, \+w porque|strong="H3588"\+w* \+w hay|strong="H3426"\+w* \+w recompensa|strong="H6468"\+w* \+w para|strong="H3588"\+w* \+w su|strong="H3588"\+w* labor.\wj*   
\p
\v 8 Cuando Asa \w oyó|strong="H8085"\w* estas \w palabras|strong="H1697"\w* y \w la|strong="H3605"\w* profecía \w de|strong="H4480"\w* Azarías, hijo \w de|strong="H4480"\w* Oded, \w se|strong="H4480"\w* \w animó|strong="H2388"\w* y quitó \w los|strong="H3605"\w* ídolos repugnantes \w de|strong="H4480"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*, \w Benjamín|strong="H1144"\w* y las \w ciudades|strong="H5892"\w* \w que|strong="H4480"\w* \w tomó|strong="H3920"\w* \w en|strong="H4480"\w* \w la|strong="H3605"\w* región montañosa \w de|strong="H4480"\w* Efraín. Reconstruyó \w el|strong="H3605"\w* \w altar|strong="H4196"\w* \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H4480"\w* estaba \w delante|strong="H6440"\w* \w del|strong="H4480"\w* patio \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 9 \w Después|strong="H5921"\w* \w los|strong="H5921"\w* \w de|strong="H5921"\w* Efraín, \w Manasés|strong="H4519"\w* \w y|strong="H3588"\w* \w Simeón|strong="H8095"\w*, quienes vivían \w con|strong="H5973"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w Benjamín|strong="H1144"\w*, \w se|strong="H5921"\w* reunieron \w con|strong="H5973"\w* \w ellos|strong="H5921"\w*. \w Muchos|strong="H7230"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w se|strong="H5921"\w* pasaron \w al|strong="H5921"\w* \add rey Asa\add* \w porque|strong="H3588"\w* \w veían|strong="H7200"\w* \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w su|strong="H3588"\w* \nd ʼElohim\nd* estaba \w con|strong="H5973"\w* \w él|strong="H5921"\w*.   
\p
\v 10 Se reunieron en Jerusalén el \w mes|strong="H2320"\w* \w tercero|strong="H7992"\w* del \w año|strong="H8141"\w* 15 del \w reinado|strong="H4438"\w* \w de|strong="H2568"\w* Asa.  
\v 11 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w sacrificaron|strong="H2076"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* 700 becerros \w y|strong="H1241"\w* 7.000 \w ovejas|strong="H6629"\w* \w del|strong="H4480"\w* botín \w que|strong="H4480"\w* llevaron.  
\v 12 Hicieron un \w pacto|strong="H1285"\w* solemne para buscar \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* de sus antepasados, con \w todo|strong="H3605"\w* su \w corazón|strong="H3824"\w* y su \w alma|strong="H5315"\w*,  
\v 13 \w y|strong="H5704"\w* \w que|strong="H4480"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H4480"\w* \w no|strong="H3808"\w* buscara \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, muriera, \w fuera|strong="H4480"\w* \w grande|strong="H1419"\w* \w o|strong="H3068"\w* \w pequeño|strong="H6996"\w*, hombre \w o|strong="H3068"\w* mujer.  
\v 14 \w Juraron|strong="H7650"\w* delante de \nd \+w Yavé|strong="H3068"\+w*\nd* con \w gran|strong="H1419"\w* \w voz|strong="H6963"\w*, \w gritos|strong="H8643"\w* de \w júbilo|strong="H8643"\w*, \w trompetas|strong="H2689"\w* y cornetas.\f + \fr 15:14 \ft Lit. cuerno. La palabra corneta viene de cuerno. Una corneta no es una trompeta. Como se usa cuerno para el altar, para el aceite de ungir y otras funciones, usamos la palabra corneta.\f*   
\p
\v 15 \w Toda|strong="H3605"\w* \w Judá|strong="H3063"\w* \w se|strong="H5921"\w* regocijó \w a|strong="H3068"\w* causa \w del|strong="H5921"\w* \w juramento|strong="H7621"\w*, \w pues|strong="H3588"\w* \w juraron|strong="H7650"\w* \w con|strong="H5921"\w* \w todo|strong="H3605"\w* \w su|strong="H3588"\w* \w corazón|strong="H3824"\w* \w que|strong="H3588"\w* \w lo|strong="H5921"\w* buscarían \w con|strong="H5921"\w* \w toda|strong="H3605"\w* \w su|strong="H3588"\w* \w voluntad|strong="H7522"\w*. \w Y|strong="H3068"\w* \w fue|strong="H3063"\w* \w hallado|strong="H4672"\w* \w por|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w les|strong="H5921"\w* dio paz \w por|strong="H5921"\w* \w todas|strong="H3605"\w* \w partes|strong="H5439"\w*.   
\p
\v 16 \w El|strong="H6213"\w* \w rey|strong="H4428"\w* Asa \w aun|strong="H1571"\w* despojó \w a|strong="H3068"\w* su propia madre Maaca de su dignidad \w real|strong="H4428"\w*, \w porque|strong="H4428"\w* \w hizo|strong="H6213"\w* una imagen repugnante de Asera. Asa taló \w el|strong="H6213"\w* ídolo repugnante, \w lo|strong="H6213"\w* desmenuzó \w y|strong="H1571"\w* \w lo|strong="H6213"\w* \w quemó|strong="H8313"\w* junto \w al|strong="H4428"\w* \w torrente|strong="H5158"\w* Cedrón.   
\p
\v 17 \w Sin|strong="H3808"\w* embargo, \w los|strong="H3605"\w* lugares \w altos|strong="H1116"\w* \w no|strong="H3808"\w* \w fueron|strong="H1961"\w* quitados de \w Israel|strong="H3478"\w*, \w aunque|strong="H7535"\w* \w el|strong="H3605"\w* \w corazón|strong="H3824"\w* de Asa \w se|strong="H1961"\w* mantuvo \w íntegro|strong="H8003"\w* \w todo|strong="H3605"\w* su \w tiempo|strong="H3117"\w*.  
\v 18 Llevó \w plata|strong="H3701"\w*, \w oro|strong="H2091"\w* y utensilios \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* de \nd ʼElohim,\nd* lo que su padre y él mismo consagraron.   
