\id OBA
\h عُوبَاذْيَا 
\toc1 عُوبَاذْيَا 
\toc2 عُوبَاذْيَا 
\toc3 عُوب. 
\mt1 عُوبَاذْيَا  
\c 1
\m
\v 1 \bd ڒوْحِييْ ن عُوبَاذْيَا.\bd*  
\b  
\m ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، \bd خْ إِذُومْ:\bd*  
\m ‘نشِّينْ نسْڒَا إِجّْ ن ڒخْبَارْ زِي سِيذِي،  
\m ؤُ إِجّْ ن ؤُمْسكِّي إِتّْوَاسّكّْ غَارْ ڒڭْنُوسْ:  
\m كَّارْ، جّمْ أَنغْ أَذْ خَاسْ نْغوّغْ،  
\m أَذْ نمّْنغْ أَكْ-ذ \add إِذُومْ\add*!‘ \x ◘ \xo 1:‏1 \xt إِرْم. 49‏:‏14\x*   
\m
\v 2 خْزَارْ، نشّْ ڭِّيغْ شكْ ذ أَمژْيَانْ جَارْ ڒڭْنُوسْ،  
\m شكْ ثتّْوَاسّحْقَارَاذْ أَطَّاسْ. \x ◘ \xo 1:‏2 \xt إِرْم. 49‏:‏15\x*   
\m
\v 3 نّْفَاخثْ ن وُوڒْ نّشْ ثشْمثْ إِ شكْ،  
\m \add شكْ\add* ذ ونِّي ذِينْ إِزدّْغنْ ذڭْ إِمُوشَانْ ن ؤُذُورِّي جَارْ ڒجْرُوفْ،  
\m ذِي ثْزذِّيغْثْ نّشْ يُوعْڒَانْ،  
\m \add شكْ\add* ذ ونِّي إِقَّارنْ ذڭْ وُوڒْ نّشْ:  
\m ’مَانْ ونْ ذ أَيِي غَا إِغضْڒنْ غَارْ ثمُّورْثْ؟‘ \x ◘ \xo 1:‏3 \xt إِرْم. 49‏:‏16\x*   
\m
\v 4 مَاڒَا ثسّْڭعّْذذْ إِخفْ نّشْ أَمْ ؤُڭِيذرْ،  
\m نِيغْ ثڭِّيذْ ڒْعُوشّْ نّشْ جَارْ إِثْرَانْ،  
\m نشّْ أَذْ شكْ د سّنِّي سّهْوِيغْ،  
\m \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \x ◘ \xo 1:‏4 \xt ڒخْڒ. 24‏:‏21، أَيُوبْ 39‏:‏27‏-‏29، إِرْم. 49‏:‏16\x*   
\b  
\m
\v 5 ”مَاڒَا ؤُذْفنْ-د غَاركْ إِشفَّارنْ،  
\m \add نِيغْ\add* إِخوَّاننْ س دْجِيڒثْ،  
\m - \add أَ\add*، مَامّشْ إِ غَا ثتّْوَاڒدّْدْجذْ \add أَڒْ طَّارْفْ\add* -  
\m مَا وَارْ تَّاشَارنْ أَڒْ غَارْسنْ إِ غَا يِيڒِي مِينْ إِكْفَانْ؟  
\m مَاڒَا ؤُسِينْ-د غَاركْ إِنِّي إِ غَا إِڒقْضنْ أَضِيڒْ،  
\m مَا أَذْ جّنْ شَا مِينْ إِتّْوَاڒقْضنْ \add أَوَارْنِي أَسنْ\add*؟ \x ◘ \xo 1:‏5 \xt إِرْم. 49‏:‏9\x*   
\m
\v 6 \add أَ\add* مَامّشْ إِ غَا أَرْزُونْ ذِي عِيسُو،  
\m \add مَامّشْ\add* إِ غَا بقّْشنْ \add ڒكْنُوزْ\add* نّسْ نُّوفَارنْ!   
\m
\v 7 مَارَّا إِرْيَازنْ نِّي \add إِڭِّينْ\add* إِجّْ ن ڒْعَاهْذْ أَكِيذكْ،  
\m عَارْننْ شكْ غَارْ ويْمِيرْ،  
\m \add إِرْيَازنْ\add* نِّي ثُوغَا أَكِيذكْ إِدَّارنْ ذِي ڒهْنَا، شمْثنْ شكْ،  
\m نِيثْنِي زمَّارنْ خَاكْ.  
\m أَغْرُومْ زَّايكْ ڭِّينْ ث ذ ثَارحْسِيثْ سْوَادَّايْ نّشْ.  
\m ’أَقَا نتَّا وَارْ ذَايسْ بُو ڒفْهَامثْ.‘ \f ◼ \fr 1:‏7 \ft \+bd ’أَقَا نتَّا وَارْ غَارسْ بُو ڒفْهَامثْ‘\+bd* - أَوَاڒْ-أَ إِسَّاوَاڒْ خْ إِذُومْ. وَاخَّا أَطَّاسْ هجْمنْ خْ إِذُومْ مَاحنْذْ أَذْ زَّايسْ كشّْضنْ أَمْ ث شمْثنْ، وَاخَّا أَمنِّي إِذُومْ وَارْ غَارسْ بُو ڒفْهَامثْ.\f*  \x ◘ \xo 1:‏7 \xt إِزهد. 41‏:‏10، يُوح. 13‏:‏18\x*   
\m
\v 8 مَا وَارْ إِتِّيڒِي \bd ذڭْ وَاسّْ نِّي،\bd* إِقَّارْ سِيذِي،  
\m أَقَا نشّْ أَذْ أَردّْدْجغْ إِمِيغِيسنْ زِي إِذُومْ،  
\m ؤُ ڒفْهَامثْ زڭْ إِذُورَارْ ن عِيسُو؟ \x ◘ \xo 1:‏8 \xt إِشا. 29‏:‏11، 14؛ إِرْم. 49‏:‏7\x*   
\m
\v 9 أَيْثْ ن بُو-ثغْرُوضْثْ نّشْ أَذْ تّْوَاحْصَارنْ  
\m زِي ثِيڭّْوُوذِي، \add أَ\add* ثَايْمَانْ،  
\m حِيمَا كُوڒْ إِجّنْ زڭْ إِذُورَارْ ن عِيسُو  
\m أَذْ إِتّْوَاقْضعْ س ونْغَايْ.“ \x ◘ \xo 1:‏9 \xt عَام. 2‏:‏14، 16\x*   
\b  
\m
\v 10 ”زِي سِّيبّثْ ن لْعُونْفْ \add خْ\add* ؤُمَاشْ يَاعْقُوبْ،  
\m أَذْ شكْ ثْذڒْ ڒفْضِيحثْ،  
\m ؤُ أَذْ ثتّْوَاكّْسذْ إِ ڒبْذَا. \x ◘ \xo 1:‏10 \xt أَمز. 27‏:‏41؛ حِز. 35‏:‏5؛ عَام. 1‏:‏11\x*   
\m
\v 11 ذڭْ وَاسّْ إِ ذِي ثُوغَا \add خَاسْ\add* ثْبدّذْ،  
\m ذڭْ وَاسّْ إِ ذِي إِبَارَّانِييّنْ إِوْينْ-د أَڭْڒَا نّسْ  
\m ؤُ ؤُذْفنْ ڒْبَارَّانِي غَارْ ثوُّورَا نّسْ،  
\m ؤُ نْضَارنْ ثَاقدُّوحْثْ خْ ؤُرْشَالِيمْ،  
\m ثُوغَا شكْ أَمْ يِيجّنْ زَّايْسنْ. \x ◘ \xo 1:‏11 \xt إِزهد. 137‏:‏7\x*   
\m
\v 12 \add مَاشَا\add* وَارْ ذ أَشْ إِعدّڒْ أَذْ ثقِّيمذْ ثْخزَّارذْ  
\m ذڭْ وَاسّْ ن ؤُمَاشْ،  
\m ذڭْ وَاسّْ ن وشْثَابْ نّسْ أَبَارْشَانْ،  
\m وَارْ ذ أَشْ إِعدّڒْ أَذْ ثْفَارْحذْ خْ إِحنْجِيرنْ ن يَاهُوذَا،  
\m ذڭْ وَاسّْ ن وَاردّدْجْ نْسنْ  
\m ؤُ وَارْ ذ أَشْ إِعدّڒْ أَذْ ثَارزْمذْ أَقمُّومْ نّشْ أَطَّاسْ  
\m ذڭْ وَاسّْ ن ڒحْصَارثْ \add نْسنْ\add*.   
\m
\v 13 وَارْ إِعدّڒْ أَذْ ثَاذْفذْ غَارْ ثوَّارْثْ نْ ڒْڭنْسْ إِنُو  
\m ذڭْ وَاسّْ ن ؤُهلّكْ نْسنْ  
\m وَارْ ذ أَشْ إِعدّڒْ أَذْ ثقِّيمذْ ثْخزَّارذْ عَاوذْ  
\m ذڭْ وَاسّْ ن ؤُضيّعْ نْسنْ  
\m ؤُ وَارْ ذ أَشْ إِعدّڒْ أَذْ ثقِّيمذْ ثسّْوِيژّْضذْ  
\m \add إِفَاسّنْ نّشْ\add* غَارْ وَاڭْڒَا نّسْ  
\m ذڭْ وَاسّْ ن ؤُضيّعْ نّسْ،   
\m
\v 14 وَارْ ذ أَشْ إِعدّڒْ أَذْ ثْبدّذْ  
\m غَارْ مَانِي تّْمڒْقَانْ إِبْرِيذنْ،  
\m مَاحنْذْ أَذْ ثتّحِّيذْ إِنِّي إِنجْمنْ  
\m ؤُ وَارْ ذ أَشْ إِعدّڒْ  
\m أَذْ ثْسلّْمذْ إِنِّي ثُوغَا يَاروْڒنْ  
\m ذڭْ وَاسّْ ن ڒحْصَارثْ.“   
\b  
\m
\v 15 ”مَاغَارْ يُوذسْ-د أَسّْ ن سِيذِي  
\m خْ مَارَّا ڒڭْنُوسْ!  
\m أَمْ ثڭِّيذْ شكْ، أَذْ زَّايكْ إِتّْوَاڭّْ،  
\m أَخدْجصْ نّشْ أَذْ د-إِذْوڒْ خْ ؤُزدْجِيفْ نّشْ. \x ◘ \xo 1:‏15 \xt حِز. 35‏:‏15\x*   
\m
\v 16 مَاغَارْ أَمْ مَامّشْ ثسْوِيمْ كنِّيوْ  
\m خْ وذْرَارْ إِنُو إِقدّْسنْ،  
\m أَمُّو أَذْ سْونْ مَارَّا ڒڭْنُوسْ ڒبْذَا،  
\m \add وَاهْ،\add* أَذْ سْونْ أَذْ سكّْفنْ،  
\m أَذْ ذوْڒنْ أَخْمِيعمَّارْصْ وَارْ ثُوغَا دْجَانْ.   
\m
\v 17 \add مَاشَا\add* خْ وذْرَارْ ن صِيهْيُونْ  
\m أَذْ يِيڒِي مِينْ إِنّجْمنْ،  
\m ؤُ وَانِيثَا أَذْ يِيڒِي ذ أَمْقدّسْ،  
\m ؤُ \add إِنِّي ن\add* ثَادَّارْثْ ن يَاعْقُوبْ  
\m أَذْ طّْفنْ ثِيسقَّاڒْ \add نْ ڒْوَارْثْ\add* نْسنْ. \x ◘ \xo 1:‏17 \xt يُووِ. 3‏:‏5\x*   
\m
\v 18 ثَادَّارْثْ ن يَاعْقُوبْ أَذْ ثِيڒِي ذ ثِيمسِّي،  
\m ؤُ ثَادَّارْثْ ن يُوسُوفْ ذ أَشعَّاڒْ،  
\m ؤُشَا ثَادَّارْثْ ن عِيسُو أَذْ ثِيڒِي أَمْ يِيغدْجْ  
\m ؤُ نِيثْنِي أَذْ أَسنْ سّْشمْضنْ  
\m ؤُ أَذْ ثنْ شّنْ،  
\m أَڒَامِي وَارْ إِقِّيمْ  
\m ؤُڒَا ذ إِجّْ إِدَّارْ ذِي ثَادَّارْثْ ن عِيسُو،  
\m مَاغَارْ سِيذِي أَقَا إِسِّيوڒْ.“   
\b  
\m
\v 19 ”إِنِّي ن \add ثمُّورْثْ ن\add* لْجَانُوبْ  
\m أَذْ طّْفنْ إِذُورَارْ نْ عِيسُو ذ ثَاسْغَارْثْ،  
\m ؤُ يِينِّي ن ثمُّورْثْ إِوَاطَانْ  
\m أَذْ طّْفنْ \add ثَامُّورْثْ ن\add* إِفِيلِيسْطِينِييّنْ ذ ڒْوَارْثْ  
\m \add وَاهْ،\add* نِيثْنِي أَذْ طّْفنْ إِيَّارْ ن إِفْرَايِيمْ  
\m ذ ييَّارْ ن سَامَارْيَا ذ ڒْوَارْثْ،  
\m ؤُ بِينْيَامِينْ \add أَذْ إِطّفْ\add* جِيلْعَاذْ \add ذ ڒْوَارْثْ\add*،   
\m
\v 20 ؤُ إِمنْفِييّنْ زِي ڒْعسْكَارْ-أَ  
\m إِنِّي إِدْجَانْ غَارْ أَيْثْ ن إِسْرَائِيل  
\m \add أَذْ طّْفنْ ثَامُّورْثْ ن\add* أَيْثْ ن كنْعَانْ  
\m \add ذ ڒْوَارْثْ\add* أَڒْ صَارْفَاثْ،  
\m ؤُ إِمنْفِييّنْ زِي ؤُرْشَالِيمْ  
\m نِّي \add إِدْجَانْ\add* ذِي صَافَارَاذْ،  
\m أَذْ طّْفنْ ثِيندَّامْ  
\m ن \add ثمُّورْثْ ن\add* لْجَانُوبْ ذ ڒْوَارْثْ. \f ◼ \fr 1:‏20 \ft \+bd ’صَافَارَاذْ‘\+bd* - أَذْ ثَاغْ صَافَارَاذْ ذ إِجّْ ن يِيسمْ نّغْنِي إِ ثمُّورْثْ ن سّْبَانْيَا.\f*   
\m
\v 21 إِمْسلّْكنْ أَذْ ڭعّْذنْ أَذْرَارْ ن صِيهْيُونْ،  
\m حِيمَا أَذْ حَاكْمنْ أَذْرَارْ ن عِيسُو،  
\m ؤُشَا ثَاڭلْذَا أَذْ ثِيڒِي ن سِيذِي.“   