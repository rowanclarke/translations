\id HAB - Biblica® Open Igbo Contemporary Bible 2020 
\h Habakuk 
\toc1 Habakuk 
\toc2 Habakuk 
\toc3 Hab 
\mt1 Habakuk 
\c 1  
\p  
\v 1 Nke a bụ ozi Habakuk onye amụma natara. 
\s1 Mkpesa Habakuk 
\q1  
\v 2 \nd Onyenwe anyị\nd*, ruo ole mgbe ka m ga-anọgide na-eti mkpu 
\q2 ma ị dịghị ege ntị? 
\q1 Ruo ole mgbe ka m ga na-etiku gị na-asị, “Ihe ike, ihe ike!” 
\q2 ma ị dịghị azọpụta? 
\q1  
\v 3 Nʼihi gịnị ka i ji eme m ka m na-ahụ ihe ọjọọ? 
\q2 Gịnị mere i ji anagide mmegbu? 
\q1 Mbibi na ihe ike dị nʼihu m, 
\q2 na ịlụ ọgụ, na esemokwu jupụtakwara ebe niile. 
\q1  
\v 4 Nʼihi ya, iwu na-ada mba, 
\q2 ikpe ziri ezi adịghị agakwa nʼihu. 
\q1 Ndị ajọ mmadụ na-agba ndị ezi omume gburugburu, 
\q2 nke mere ka ikpe ziri ezi ghọọ ihe gbagọrọ agbagọ. 
\s1 Ọsịsa \nd Onyenwe anyị\nd* 
\q1  
\v 5 “Legide mba niile anya, ka i hụ. 
\q2 Lee, ka o ju gị anya nke ukwuu. 
\q1 Nʼihi na agaje m ime ihe nʼụbọchị ndụ unu, 
\q2 nke unu na-agaghị ekwenye, 
\q2 ọ bụladị ma akọọrọ unu ya. 
\q1  
\v 6 Nʼihi na lee, agaje m ime ka ndị Kaldịa bilie, 
\q2 bụ mba ahụ na-adịghị eme ebere, na ndị na-eme ngwangwa. 
\q1 Ha bụ ndị na-ebu agha na-ejegharị na mba niile, 
\q2 ndị na-esite nʼaka ike na-enweta ebe obibi nke na-abụghị nke ha. 
\q1  
\v 7 Ha bụ mba a na-atụ ụjọ, na ndị dịkwa egwu. 
\q2 Ha bụ iwu nye onwe ha, ihe ha tụpụtara ka ha na-eme. 
\q2 Ọ bụ onwe ha ka ha na-ebuli elu. 
\q1  
\v 8 Ịnyịnya ha nwere ụkwụ nkọ karịa agụ. 
\q2 Ha na-akpa ike karịa nkịta ọhịa nke na-ejegharị nʼanyasị. 
\q1 Ndị ịnyịnya agha ha na-awụ ọsọ, 
\q2 ndị ha na-agba ịnyịnya na-esitekwa ebe dị anya na-abịa. 
\q1 Dịka ugo nke na-efedata i buru nri ọ ga-eri. 
\q2  
\v 9 Ha niile na-abịa ime ihe ike. 
\q1 Ha ji ọsọ na-abịa dịka oke ifufe nke ọzara. 
\q2 Ha na-abịa ịchịkọta ndị a dọtara nʼagha dịka ha bụ uzuzu. 
\q1  
\v 10 Ha na-akwa ndị eze emo, 
\q2 jirikwa ndịisi ọchịchị na-eme ihe ọchị. 
\q1 Ha na-achị ebe niile e wusiri ike ọchị, 
\q2 na-ekpokọtakwa aja nʼazụ mgbidi niile ịlụta ha nʼagha. 
\q1  
\v 11 Mgbe ahụ, ha na-esi nʼebe ahụ gabiga dịka ifufe, na-agabigakwa 
\q2 ndị mehierenụ, bụrụkwa ndị ikpe mara, ndị ike ha bụ chi ha.” 
\s1 Mkpesa Habakuk nke ugboro abụọ 
\q1  
\v 12 \nd Onyenwe anyị\nd*, Ọ bụ na ị dịghị site mgbe niile ebighị ebi? 
\q2 Chineke m, na Onye Nsọ m, Ị gaghị anwụ. 
\q1 Gị, \nd Onyenwe anyị\nd*, họpụtara ha maka ikpe ikpe. 
\q2 Gị, oke nkume m, emeela ka ha bụrụ ndị ga-enweta ahụhụ. 
\q1  
\v 13 Ma anya gị dị ọcha nke ukwuu, na ọ dịghị elekwasị ajọ ihe anya; 
\q2 ị naghị anabatakwa mmegbu. 
\q1 Ma gịnị mere i ji gba ndị aghụghọ nkịtị? 
\q2 Gịnị mere i ji gba nkịtị mgbe ndị ajọ omume na-eloda 
\q2 ndị bụ ndị ezi omume karịa ha? 
\q1  
\v 14 I meela ndị mmadụ ka ha dịrị ka azụ nke osimiri, 
\q2 e, dịka anụ na-akpụ akpụ nke oke osimiri, nke na-enweghị onye na-achị ha. 
\q1  
\v 15 Onye iro nke ajọ omume juru obi, na-eji nko ya na-egbu ha. 
\q2 Ọ na-ejikwa nko ụgbụ ya na-ejide ha. 
\q1 Ọ na-achịkọta ha nʼụgbụ ya, 
\q2 si otu a na-aṅụrị ọṅụ, ma na-etegharịkwa egwu ọṅụ. 
\q1  
\v 16 Nʼihi nke a, ọ na-achụ aja 
\q2 na-esurekwa ihe nsure ọkụ na-esi isi ụtọ nye ụgbụ ya, 
\q1 nʼihi na ọ bụ ụgbụ ya na-eme ka ọ na-ebi ezi ndụ, 
\q2 na-erikwa nri kachasị mma 
\q1  
\v 17 Ọ ga-aga nʼihu mgbe niile na-awụpụ ihe o ji ụgbụ ya gbute 
\q2 na-ala mba niile nʼiyi, dịka o si masị ya, na-egosighị obi ebere ọbụla? 
\b  
\c 2  
\q1  
\v 1 Aga m arịgoro nʼelu ebe nche m, 
\q2 guzo onwe m nʼebe nchekwa ahụ. 
\q1 Aga m echerekwa ịhụ ihe ọ ga-agwa m, 
\q2 na ihe m ga-asa, banyere mkpesa ndị a. 
\s1 Ọsịsa \nd Onyenwe anyị\nd* 
\p  
\v 2 Mgbe ahụ \nd Onyenwe anyị\nd* zara m sị, 
\q1 “Dee ọhụ\f + \fr 2:2 \ft Ya bụ, ọsịsa\f* ahụ nʼelu mbadamba nkume e ji ede ihe. 
\q2 Depụta ya nke ọma, 
\q2 ka onye na-agba ọsọ nwee ike ịgụ ya. 
\q1  
\v 3 Nʼihi na e nwere ọhụ nke ga-adị ruo oge a kara aka, 
\q2 ọ na-ekwu banyere oge ọgwụgwụ, 
\q2 Ọ gaghị abụkwa ụgha. 
\q1 Ọ bụrụ na ọ dịka mmezu ya adịghị abịaru ọsịịsọ, chere mmezu ya, 
\q2 nʼihi na ọ ga-emesịa mezuo, 
\q2 ọ gaghị anọ tee aka. 
\b  
\q1  
\v 4 “Lee, onye iro na-afụli onwe ya elu; 
\q2 ọchịchọ ya ezikwaghị ezi 
\q2 ma onye ezi omume ga-esite nʼokwukwe\f + \fr 2:4 \ft Maọbụ, \fqa ikwesi ntụkwasị obi\f* ya dị ndụ. 
\q1  
\v 5 Nʼezie, mmanya\f + \fr 2:5 \ft Nʼakwụkwọ ụfọdụ ihe ị ga-ahụ bụ akụnụba.\f* na-eduhie ya ụzọ, 
\q2 onye jupụtara na nganga, na-adịghị enwe ezumike. 
\q1 Ebe ọ bụ na o nwere anya ukwu dịka ala mmụọ, 
\q2 ọ gaghị enwekwa afọ ojuju dịka ọnwụ. 
\q1 Nʼihi na ọ na-achịkọta mba niile nye onwe ya, 
\q2 ọ na-adọtakwa ọtụtụ ndị mmadụ nʼagha. 
\p  
\v 6 “Ndị a niile ha agaghị eji ịkwa emo na nkọcha sị ya, 
\q1 “ ‘Ahụhụ dịrị onye ahụ na-atụkọta ihe e zutere nʼohi, 
\q2 ruo ole mgbe ka ị ga-anọ na-eme onwe gị ọgaranya 
\q2 site nʼịnara ndị mmadụ ụgwọ nʼike?’ 
\q1  
\v 7 Ọ bụ na ndị i ji ụgwọ agaghị abịakwasị gị na mberede? 
\q2 Ọ bụ na ha agaghị eteta nʼụra, mee gị ka ị maa jijiji? 
\q2 Mgbe ahụ ka ha ga-eji gị mee ihe ha chọrọ. 
\q1  
\v 8 Nʼihi na ị kwakọtala akụ nke ọtụtụ mba dị iche iche, 
\q2 ndị ahụ fọdụrụ ga-abịakwa kwakọrọ ihe niile i nwere. 
\q1 Nʼihi na ị wụsịala ọbara ndị mmadụ, 
\q2 i bibiela ọtụtụ ala na obodo na ndị niile bi nʼime ha. 
\b  
\q1  
\v 9 “Ahụhụ na-adịrị onye ahụ na-ewu ụlọ ya site nʼuru ọjọọ, 
\q2 nke na-ewukwasị akwụ ya nʼebe dị elu, 
\q2 nʼihi ịgbanarị mbibi nke ga-abịa. 
\q1  
\v 10 I sitela nʼizuzu ọjọọ gị mee ka mbibi bịakwasị ọtụtụ mmadụ, 
\q2 sị otu a tufuo ndụ gị, ma wetakwara ezinaụlọ gị ihere. 
\q1  
\v 11 Ọ bụladị nkume ahụ e ji wuo mgbidi ga-eti mkpu megide gị. 
\q2 Osisi e ji doo elu ụlọ ga-etikwa mkpu akwa za nkume ndị ahụ. 
\b  
\q1  
\v 12 “Ahụhụ dịrị onye ahụ na-eji ọbara ewu obodo, 
\q2 nke na-ejikwa ajọ omume eme ka obodo ahụ guzosie ike. 
\q1  
\v 13 Ọ bụ na ọ bụghị uche \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, 
\q2 na ndọgbu nʼọrụ niile nke mmadụ bụ na nkịtị, ihe e ji afụnwu ọkụ, 
\q2 na oke ọrụ niile nke mba dị iche iche bụ ihe lara nʼiyi? 
\q1  
\v 14 Nʼihi na ụwa niile ga-ejupụta na ihe ọmụma nke ebube \nd Onyenwe anyị\nd*, 
\q2 dịka mmiri si ekpuchi oke osimiri. 
\b  
\q1  
\v 15 “Ahụhụ dịrị onye ahụ na-enye onye agbataobi ya mmanya, 
\q2 nke na-anọgide na-agbanyere ya mmanya tutu ruo mgbe mmanya bidoro igbu ya, 
\q2 ka o si otu a hụ ọtọ ya anya. 
\q1  
\v 16 Ihere ga-anọchi otuto na nsọpụrụ i nwere. 
\q2 Ṅụọ ka ị bụrụ onye mmanya na-egbu. 
\q1 Nʼihi na iko dị nʼaka nri \nd Onyenwe anyị\nd* na-abịakwute gị. 
\q2 Ihere ga-anọchikwa anya otuto gị. 
\q1  
\v 17 Ihe ike ahụ i mere Lebanọn ga-abịakwasịkwa gị. 
\q2 Mbibi i bibiri anụmanụ dị iche iche ga-emekwa ka egwu ju gị obi. 
\q1 Nʼihi na ị wụsịala ọbara ọtụtụ mmadụ, 
\q2 bibie ala na obodo dị iche iche, bibiekwa ndị niile bi nʼime ha. 
\b  
\q1  
\v 18 “Gịnị bụ uru arụsị bara ebe ọ bụ aka mmadụ kpụrụ ya? 
\q2 Kedụ uru igwe a kpụrụ akpụ bara, bụ nke na-ekwu okwu ụgha? 
\q1 Nʼihi na onye na-atụkwasị ha obi na-atụkwasị obi ya nʼihe ahụ aka ya rụpụtara, 
\q2 nʼihi na ọ bụ arụsị na-enweghị ike ikwu okwu ka o mere. 
\q1  
\v 19 Ahụhụ dịrị onye ahụ na-agwa osisi okwu sị, ‘Dịrị ndụ.’ 
\q2 Ma ọ bụ nkume nke na-apụghị ikwu okwu, ‘Teta nʼụra.’ 
\q1 O nwere ike izi mmadụ ihe? 
\q2 Lee, ọ bụ ihe eji ọlaọcha na ọlaedo machie, 
\q2 ma ọ dịghị nkuume ọbụla dị nʼime ya.” 
\b  
\q1  
\v 20 Ma \nd Onyenwe anyị\nd* nọ nʼime ụlọnsọ ukwu ya. 
\q2 Ya mere, ka ụwa niile dere duu nʼihu ya. 
\c 3  
\s1 Ekpere Habakuk 
\d  
\v 1 Nke a bụ ekpere Habakuk onye amụma kpere. Ọ dị nʼusoro \it Shiginot.\it* Nke a bụ ihe o kwuru. 
\q1  
\v 2 \nd Onyenwe anyị\nd* anụla m ihe niile e kwuru banyere ude gị. 
\q2 Ịdị ukwuu nke ọrụ gị niile na-emekwa ka m dere duu nʼegwu nʼihu gị, \nd Onyenwe anyị\nd*. 
\q1 Mekwaa ya ọzọ nʼoge nke anyị, 
\q2 mekwaa ka anụ akụkọ ya nʼọgbọ anyị. 
\q2 Nʼoke iwe gị chetakwa ebere. 
\b  
\q1  
\v 3 Chineke si na Teman bịa, 
\q2 Onye Nsọ ahụ sikwa nʼugwu Paran. \qs Sela\qs* 
\q1 Ebube ya na-ekpuchi eluigwe, 
\q2 otuto ya jupụtakwara nʼụwa. 
\q1  
\v 4 Ịma mma ya na-achapụta dịka ihe anyanwụ ụtụtụ, 
\q2 ihe na-enwupụta site nʼaka ya, 
\q2 ọ bụkwa nʼebe ahụ ka e zoro ike ya. 
\q1  
\v 5 Nʼihu ya ka ajọ ọrịa na-efe efe na-aga, 
\q2 oke mbibi na-esokwa ya nʼazụ. 
\q1  
\v 6 O guzoro ọtọ yọgharịa ụwa; 
\q2 o lere anya, mee ka mba niile maa jijiji. 
\q1 Ugwu ukwu ochie ahụ niile dara, 
\q2 ugwu nta ochie ndị ahụ dakwara. 
\q2 Nʼihi na ụzọ ya ga-adịgide ruo mgbe niile ebighị ebi. 
\q1  
\v 7 Ahụrụ m ụlọ ikwu nke Kushan ka ha nọ ọnọdụ ụbọchị ọjọọ, 
\q2 na ebe obibi ndị Midia ka ha nọ na oke ahụ ụfụ. 
\b  
\q1  
\v 8 Ọ bụ osimiri, ka gị bụ \nd Onyenwe anyị\nd* were iwe megide? 
\q2 Ọnụma gị, ọ dị ukwuu megide iyi niile? 
\q1 Oke iwe gị ọ bụ megide oke osimiri 
\q2 mgbe ị nọkwasịrị nʼelu ịnyịnya gị, 
\q2 nakwa nʼelu ụgbọ ịnyịnya ị wetara ndị nke gị mmeri? 
\q1  
\v 9 I kpughepụrụ ụta gị, 
\q2 kpọọ oku ka a chịtara gị ọtụtụ àkụ. \qs Sela\qs* 
\q1 I ji osimiri dị iche iche kewaa ụwa. 
\q2  
\v 10 Mgbe ugwu niile hụrụ gị ha nyagharịrị onwe ha nʼihi ihe mgbu bịakwasịrị ha. 
\q1 Oke mmiri ozuzo gabigakwara. 
\q2 Ogbu mmiri mere ka olu ya daa ụda, 
\q2 buliekwa ebili mmiri elu. 
\b  
\q1  
\v 11 Anyanwụ na ọnwa guzokwara duu na mbara eluigwe, 
\q2 mgbe ha hụrụ ihe nke àkụ gị, 
\q2 mgbe ha hụrụ amụma nke ùbe gị gburu. 
\q1  
\v 12 I sitere nʼọnụma gị zọgharịa ije nʼụwa, 
\q2 sitekwa nʼiwe gị zọchaa mba dị iche iche dịka ọka. 
\q1  
\v 13 Ị pụtara ịzọpụta ndị gị, 
\q2 ịzọpụta onye ahụ i tere mmanụ. 
\q1 Ị zọpịara isi onyendu nke ala ajọ omume ahụ, 
\q2 gbawa ya ọtọ site nʼisi ruo nʼụkwụ. 
\q1  
\v 14 Ọ bụ ùbe ya ka i ji mawaa ya isi, 
\q2 mgbe ndị dike nʼagha ya bịara dịka oke ifufe ịchụsa anyị, 
\q1 mgbe ha si nʼobi ụtọ ha chee na ha na-aga iripịa ndị ogbenye e wedara nʼala, 
\q2 bụ ndị na-ezo onwe ha. 
\q1  
\v 15 Ị chịrịla ịnyịnya gị zọọ ije nʼoke osimiri, 
\q2 kpagharịa mmiri ukwu ndị ahụ. 
\b  
\q1  
\v 16 Amara m jijiji nʼobi m mgbe m nụrụ ihe ndị a niile, 
\q2 egbugbere ọnụ m abụọ kụkọtara nʼegwu, 
\q1 ọkpụkpụ dị m nʼahụ malitere ire ure, 
\q2 mee ka ụkwụ m maa jijiji. 
\q1 Ma aga m eji ndidi chere ụbọchị ọjọọ ahụ 
\q2 nke ga-abịakwasị ndị ahụ na-abịa ibuso anyị agha. 
\q1  
\v 17 A sịkwarị na osisi fiig amaghị ifuru, 
\q2 na ọ dịghị mkpụrụ dị nʼosisi vaịnị, 
\q1 a sịkwa na mkpụrụ osisi oliv ebilata 
\q2 na ala ubi niile emepụtaghị ihe oriri, 
\q1 a sịkwa na ọ dịghị atụrụ dị nʼọgba anụ, 
\q2 na ọ dịkwaghị ehi nọ nʼụlọ anụmanụ, 
\q1  
\v 18 mụ onwe m ga-anọgide na-aṅụrị ọṅụ nʼime \nd Onyenwe anyị\nd*. 
\q2 Aga m etegharịkwa egwu ọṅụ nʼime Chineke Onye nzọpụta m. 
\b  
\q1  
\v 19 Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* bụ ike m, 
\q2 ọ na-eme ụkwụ m abụọ ka ha dịka nke ele.\f + \fr 3:19 \ft Ịdị ngwa nʼịgba ọsọ\f* 
\q2 Ọ na-emekwa ka m zọọ ije nʼebe niile dị elu. 
\d Nke a dịrị onyeisi abụ, nʼụbọ akwara m dị iche iche.