\id PSA
\toc2 Psalms
\toc1 Wuuch nangn Thepitak
\mt1 Wuuch nangn Thepitak
\c 1
\s1 Nampa 1
\q1 
\v 1 Min yomparr-r ith pam kaarp wakm kuuk pelnan pam raak warr-kak;
\q2 Iiwurr nangunp kaarp thanm kulam-thaaw pam raak warr-kokonak;
\q2 Iiiwurr niinhin kaarp ith ninh thang-kangkar-nanr.
\q1 
\v 2 Pam ith nul mang-mangal minch nangun Raak-warram nangnma Pam Porkam.
\q2 Ngul nul raak mangk minch min ngeem ngurnturnthurr miing.
\q1 
\v 3 Nul kar yuk niinanirr thaapirri kar ngok miinthin,
\q2 May yuk punth koo-yermperr raak karrtham,
\q2 Iiwurr riingkaal kaarp warramr;
\q2 Mit mong-thak nangn-man nul min yomparr-r.
\q1 
\v 4 Pam warr yorrp kaarp,
\q2 Kar may petn yarra puunuth puukr pelnan.
\q1 
\v 5 Yarr i'i pam warr nangunp kaarp than, Ith pelnan koo-thakarr ko'orr;
\q2 Iiwurr pam raak warr-kak nangunp Kaarp thaakokon thunprr pelnungun pam kuk-kunanpak;
\q2 Ngul peln kulam-n pam warr peln wonp. 
