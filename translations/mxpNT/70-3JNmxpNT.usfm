\id 3JN
\h 3 JUAN
\toc1 JA MYƗDƗGØØKPƗ NØKY MIDI JA JUAN YJA̱A̱Y
\toc2 3 JUAN
\toc3 3 Jn.
\mt1 JA MYƗDƗGØØKPƗ NØKY MIDI JA JUAN YJA̱A̱Y
\c 1
\s1 Øy tsuj ja Gayo yiknɨgajpxy
\p 
\v 1 Møja̱a̱ꞌyꞌa̱jtp øts, ɨxya̱mts øts ya̱ꞌa̱t nøky ndanɨjayɨ mets mɨguꞌuk Gayo, jaꞌagøjxp ku nɨjuunɨ ngaja̱ꞌdyɨgøy.
\p 
\v 2 Mɨguꞌuk, wa̱mp øts jøts øy yikxon xyikna̱xt møk møja̱a̱w, nayɨdeꞌen sa̱m ja Dios øy tsuj myikꞌityɨ.
\v 3 Njanchꞌøyja̱ꞌwɨpts øts, njanchuja̱ꞌwɨpts øts, jøts ku øts ja ja̱a̱ꞌy wɨna̱a̱gɨn xnɨmendøø pøn nmɨguꞌukꞌa̱jtyɨndɨp, jøts øts ja xamɨmadya̱ꞌa̱ktɨ jøts ku mets øy tsuj mja̱a̱ꞌyꞌaty sa̱m ja Dios kyajpxy wya̱ꞌa̱ñɨn.
\v 4 Midiꞌibɨ øts ɨdøꞌøn nja̱a̱ktyimyꞌøyja̱ꞌwɨp nja̱a̱ktyimchuja̱ꞌwɨp pø nmadøøpxyɨ øts jøts ku øts nmɨguꞌuk ja møj ja mutsk tpaduujnɨdɨ ja Dios kyajpxy.
\p 
\v 5 Mɨguꞌuk, øyꞌa̱jtp ku øy tsuj mja̱a̱ꞌyꞌaty ku jadeꞌen nmɨguꞌuk xpudøkɨ pøn jaty tmɨna̱xtɨp tmɨdøkɨdɨp ja Dios kyajpxy øy ja xjagaꞌijxyꞌaty.
\v 6 Tøts øøts ja wɨna̱a̱gɨn xukmadowdɨ sa̱ mets ja xtsøky sa̱ mets ja xpaꞌayøy. Ja̱a̱ktyimdyun ja mayꞌa̱jt jøts ja xja̱a̱kpudøkɨt sa̱m ja Dios tkupikyɨn, ku ja jam jadeꞌen yja̱ꞌa̱ttɨt choondɨt.
\v 7 Pø jaꞌaxɨ ja tø tnɨdsoondɨ jøts ja jadeꞌen tmɨwɨdejtɨdɨt ja Dios kyajpxy, jadeꞌents ja kaꞌap tkupøktɨ ja pudøjkɨn midi ja ja̱a̱ꞌy ja møøjyɨdɨp pøn jaty tkanɨja̱ꞌwɨdɨpnɨm ja Dios.
\v 8 Patyts adøm xpa̱a̱tꞌa̱jtyɨndɨ jøts ja ndyimbyudøjkandɨt ku ja jadeꞌen tmɨyøꞌødyɨ tmɨna̱xtɨ ja yꞌøybɨ ja tyɨɨbyɨ.
\s1 Kaꞌap yꞌøyja̱a̱ꞌyꞌaty ja mixy Diótrefes
\p 
\v 9 Tø meets ja nøky ndanɨjayɨ jøts mee ndukmadøy yøꞌøbɨ wɨnma̱a̱ꞌñ, jaꞌ ku ja mixy Diótrefes tkamøjpɨkta̱ꞌa̱ky ja nꞌayuujk ja nꞌanaꞌamɨn, jaꞌats neꞌegɨ køꞌøm nabyɨkta̱a̱jkɨp wɨndsøn jøts nɨwɨneꞌenɨn øts ja xkamɨmadøy.
\v 10 Paty ku øts wyɨnaty nnijkxy, møk øts ja ndawɨnguga̱jpxɨt ku adøm ja xwɨngajpxyɨndɨ xpagajpxyɨndɨ ku ja xnɨda̱a̱yꞌa̱jtyɨndɨ. Nayɨdeꞌents ja tkadajotkujkꞌaty, yja̱a̱ktyimyꞌaneꞌempy ja myɨguꞌuk jaꞌ, jøts ja kaꞌap tkupøktɨt pøn jaty tmɨja̱ꞌttɨp tmɨdsoꞌondɨp ja Dios kyajpxy, pønts ja jadeꞌen tjagabadunwa̱mp, jatyɨts ja tpawøpy jøts ja kaꞌ tꞌuktuktatøjkɨñɨ ma̱ ja Dios kyajpxy yikpatmadøy.
\p 
\v 11 Mɨguꞌuk Gayo, nɨjuunɨ jadeꞌen xkatuꞌunt sa̱m ja kaꞌødyumbɨ ttuñ, tum ja øybɨ mduꞌump. Pøn jadeꞌen øy ja̱a̱ꞌyꞌa̱jtp, jaꞌats ja Dios jaꞌa̱jtɨyɨp, pønts kaꞌøyꞌa̱jtp, jaꞌats ɨdøꞌøn tkaꞌejxp tkanɨja̱ꞌwɨp ja Dios.
\s1 Janch øyja̱a̱ꞌyꞌa̱jtp ja Demetrio
\p 
\v 12 Øy tsuj yiknɨmadya̱ꞌa̱ky ja Demetrio. Ña̱nkyꞌejxɨp ku ja tpaduñ ja yꞌøybɨ ja tyɨɨbyɨ. Nayɨdeꞌents øø nwa̱a̱mɨ, nyiktɨɨdyøjkɨp øøts ja nayɨdeꞌen, pø mnɨja̱ꞌwɨdɨpxɨ ku øø kaꞌ nda̱a̱yɨ.
\s1 Ja ka̱jpxpooꞌkxɨn midi ya̱ꞌa̱t nøky tyagugøjxɨp
\p 
\v 13 Maynɨm øts ja wɨnma̱a̱ꞌñ nmøødɨ midi me ndukmadoowampy, jøts kaꞌ mets ja nugo ndanɨjayɨwya̱ꞌa̱ñ;
\v 14 ndyimñɨnøjkxwampy me køꞌøm jøts ixy wɨndanɨ nnagya̱jpxɨndɨt.
\p 
\v 15 Øy yikxon xyikna̱xt. Ɨxya̱m mmɨguꞌuk mdanɨguexyɨyɨ ja ka̱jpxpooꞌkxɨn pøn jaty ya̱m tsɨnaadyɨp. Tunts ja mayꞌa̱jt jøts nayɨdeꞌen xka̱jpxpooꞌkxt pøn jaty jam nmɨguꞌukꞌa̱jtyɨndɨp.
