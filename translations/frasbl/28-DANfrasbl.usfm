\m
\v 28 PERES : Ton \w royaume|strong="H4437"\w* \w est|strong="H4437"\w* \w divisé|strong="H6537"\w*, \w et|strong="H4437"\w* il \w est|strong="H4437"\w* \w donné|strong="H3052"\w* \w aux|strong="H3052"\w* \w Mèdes|strong="H4076"\w* \w et|strong="H4437"\w* \w aux|strong="H3052"\w* \w Perses|strong="H6540"\w*. »   
\p
\v 29 Aussitôt, \w sur|strong="H5922"\w* l'ordre \w de|strong="H5922"\w* \w Belschatsar|strong="H1113"\w*, \w on|strong="H1841"\w* \w revêtit|strong="H3848"\w* \w Daniel|strong="H1841"\w* \w de|strong="H5922"\w* pourpre, \w on|strong="H1841"\w* \w lui|strong="H5922"\w* \w mit|strong="H5922"\w* \w un|strong="H1934"\w* \w collier|strong="H2002"\w* \w d|strong="H1768"\w*'\w or|strong="H1722"\w* \w au|strong="H5922"\w* \w cou|strong="H6676"\w*, \w et|strong="H1841"\w* l'\w on|strong="H1841"\w* proclama \w qu|strong="H1768"\w*'\w il|strong="H5922"\w* serait \w le|strong="H5922"\w* \w troisième|strong="H8531"\w* \w dans|strong="H5922"\w* \w le|strong="H5922"\w* \w gouvernement|strong="H7990"\w* \w du|strong="H5922"\w* \w royaume|strong="H4437"\w*.   
\p
\v 30 Cette nuit-là même, \w Belschatsar|strong="H1113"\w*, le \w roi|strong="H4430"\w* \w chaldéen|strong="H3779"\w*, \w fut|strong="H4430"\w* \w tué|strong="H6992"\w*.  
\v 31 Darius le Mède s'empara du royaume, étant âgé d'environ soixante-deux ans.   
\c 6
\p
\v 1 Il plut \w à|strong="H4437"\w* \w Darius|strong="H1868"\w* d'établir sur \w le|strong="H6902"\w* \w royaume|strong="H4437"\w* cent vingt satrapes, \w qui|strong="H4437"\w* devaient être répartis dans tout \w le|strong="H6902"\w* \w royaume|strong="H4437"\w* ;  
\v 2 \w et|strong="H6966"\w* \w à|strong="H5922"\w* \w leur|strong="H5922"\w* tête trois ministres, \w dont|strong="H1768"\w* Daniel \w faisait|strong="H1934"\w* partie, \w afin|strong="H1768"\w* \w que|strong="H1768"\w* \w ces|strong="H3606"\w* \w satrapes|strong="H3606"\w* \w leur|strong="H5922"\w* rendent \w compte|strong="H5922"\w* \w et|strong="H6966"\w* \w que|strong="H1768"\w* \w le|strong="H5922"\w* \w roi|strong="H6925"\w* \w ne|strong="H4437"\w* subisse \w aucun|strong="H3606"\w* dommage.  
\v 3 \w Ce|strong="H4481"\w* \w Daniel|strong="H1841"\w* \w se|strong="H4430"\w* distinguait \w parmi|strong="H4430"\w* \w les|strong="H4481"\w* ministres \w et|strong="H4430"\w* \w les|strong="H4481"\w* satrapes, parce \w qu|strong="H1768"\w*'\w il|strong="H4481"\w* \w y|strong="H4481"\w* \w avait|strong="H4430"\w* \w en|strong="H4430"\w* \w lui|strong="H4481"\w* \w un|strong="H1934"\w* esprit supérieur ; \w et|strong="H4430"\w* \w le|strong="H4481"\w* \w roi|strong="H4430"\w* \w pensait|strong="H4430"\w* \w à|strong="H4481"\w* l'établir \w sur|strong="H3809"\w* tout \w le|strong="H4481"\w* royaume.   
\p
\v 4 Alors \w les|strong="H3606"\w* ministres \w et|strong="H4430"\w* \w les|strong="H3606"\w* \w satrapes|strong="H3606"\w* \w cherchèrent|strong="H1934"\w* \w à|strong="H5922"\w* trouver \w un|strong="H1934"\w* motif \w d|strong="H1768"\w*'accusation \w contre|strong="H5922"\w* \w Daniel|strong="H1841"\w* \w concernant|strong="H5922"\w* \w les|strong="H3606"\w* \w affaires|strong="H3606"\w* \w du|strong="H5922"\w* \w royaume|strong="H4437"\w*. Mais \w ils|strong="H4437"\w* \w ne|strong="H4430"\w* purent trouver \w aucun|strong="H3606"\w* motif \w ni|strong="H3606"\w* \w aucune|strong="H3606"\w* faute, \w parce|strong="H6903"\w* \w qu|strong="H1768"\w*'\w il|strong="H5922"\w* \w était|strong="H4430"\w* fidèle. \w On|strong="H4430"\w* \w ne|strong="H4430"\w* trouva \w en|strong="H4430"\w* \w lui|strong="H5922"\w* \w aucune|strong="H3606"\w* négligence \w ni|strong="H3606"\w* \w aucune|strong="H3606"\w* faute.  
\v 5 \w Ces|strong="H3606"\w* \w hommes|strong="H3606"\w* dirent alors : « \w Nous|strong="H5922"\w* \w ne|strong="H3809"\w* \w trouverons|strong="H7912"\w* \w aucun|strong="H3809"\w* motif \w d|strong="H1768"\w*'accusation \w contre|strong="H5922"\w* \w ce|strong="H5922"\w* \w Daniel|strong="H1841"\w*, \w à|strong="H5922"\w* \w moins|strong="H5922"\w* \w que|strong="H1768"\w* \w nous|strong="H5922"\w* n'\w en|strong="H1934"\w* \w trouvions|strong="H7912"\w* \w un|strong="H1934"\w* \w contre|strong="H5922"\w* \w lui|strong="H5922"\w* \w concernant|strong="H5922"\w* \w la|strong="H3606"\w* \w loi|strong="H5922"\w* \w de|strong="H5922"\w* \w son|strong="H5922"\w* \w Dieu|strong="H5922"\w*. »   
\p
\v 6 \w Ces|strong="H1836"\w* ministres \w et|strong="H3809"\w* \w ces|strong="H1836"\w* \w satrapes|strong="H3606"\w* \w se|strong="H1841"\w* rassemblèrent alors \w en|strong="H1768"\w* hâte \w auprès|strong="H5922"\w* \w du|strong="H5922"\w* roi \w et|strong="H3809"\w* \w lui|strong="H5922"\w* \w parlèrent|strong="H5922"\w* \w ainsi|strong="H1836"\w* : « Roi Darius, vis \w pour|strong="H5922"\w* toujours !  
\v 7 Tous \w les|strong="H5922"\w* ministres \w du|strong="H5922"\w* royaume, \w les|strong="H5922"\w* intendants \w et|strong="H4430"\w* \w les|strong="H5922"\w* satrapes, \w les|strong="H5922"\w* conseillers \w et|strong="H4430"\w* \w les|strong="H5922"\w* gouverneurs, \w se|strong="H4430"\w* sont concertés \w pour|strong="H5922"\w* établir \w une|strong="H4430"\w* ordonnance \w royale|strong="H4430"\w* \w et|strong="H4430"\w* promulguer un \w décret|strong="H5922"\w* sévère : quiconque adressera \w une|strong="H4430"\w* requête \w à|strong="H5922"\w* un \w dieu|strong="H5922"\w* ou \w à|strong="H5922"\w* un homme \w pendant|strong="H5922"\w* trente jours, si \w ce|strong="H4430"\w* n'\w est|strong="H5922"\w* \w à|strong="H5922"\w* \w toi|strong="H5922"\w*, ô \w roi|strong="H4430"\w*, \w sera|strong="H4430"\w* \w jeté|strong="H4430"\w* \w dans|strong="H5922"\w* \w la|strong="H5922"\w* \w fosse|strong="H5922"\w* \w aux|strong="H5922"\w* lions.  
\v 8 Maintenant, ô \w roi|strong="H4430"\w*, \w confirme|strong="H6966"\w* \w le|strong="H3606"\w* \w décret|strong="H7010"\w* \w et|strong="H4430"\w* signes-en \w le|strong="H3606"\w* document, \w afin|strong="H1768"\w* \w qu|strong="H1768"\w*'\w il|strong="H4481"\w* \w ne|strong="H4430"\w* \w soit|strong="H4430"\w* pas modifié, conformément \w à|strong="H5705"\w* \w la|strong="H4481"\w* \w loi|strong="H1156"\w* \w des|strong="H4481"\w* \w Mèdes|strong="H4481"\w* \w et|strong="H4430"\w* \w des|strong="H4481"\w* Perses, \w qui|strong="H4437"\w* \w est|strong="H4437"\w* irrévocable. »  
\v 9 \w Le|strong="H1768"\w* \w roi|strong="H4430"\w* \w Darius|strong="H4430"\w* signa \w donc|strong="H3705"\w* \w le|strong="H1768"\w* document \w et|strong="H4430"\w* \w le|strong="H1768"\w* \w décret|strong="H3792"\w*.   
\p
\v 10 Lorsque Daniel apprit \w que|strong="H3606"\w* \w le|strong="H3606"\w* document \w était|strong="H4430"\w* signé, \w il|strong="H4430"\w* rentra \w dans|strong="H3606"\w* sa maison. \w Les|strong="H3606"\w* \w fenêtres|strong="H3606"\w* \w de|strong="H4430"\w* sa chambre \w à|strong="H4430"\w* l'étage étaient ouvertes \w en|strong="H4430"\w* \w direction|strong="H3606"\w* \w de|strong="H4430"\w* Jérusalem. Trois fois \w par|strong="H1868"\w* jour \w il|strong="H4430"\w* \w se|strong="H4430"\w* \w mettait|strong="H4430"\w* \w à|strong="H4430"\w* genoux, \w il|strong="H4430"\w* priait \w et|strong="H4430"\w* rendait grâce \w devant|strong="H6903"\w* son \w Dieu|strong="H3606"\w*, \w comme|strong="H6903"\w* \w il|strong="H4430"\w* \w le|strong="H3606"\w* faisait auparavant.  
\v 11 Alors \w ces|strong="H1836"\w* \w hommes|strong="H3606"\w* \w firent|strong="H5648"\w* irruption \w et|strong="H4481"\w* trouvèrent \w Daniel|strong="H1841"\w* \w en|strong="H1934"\w* train \w de|strong="H4481"\w* prier \w et|strong="H4481"\w* \w de|strong="H4481"\w* supplier \w son|strong="H5922"\w* \w Dieu|strong="H4481"\w*.  
\v 12 Puis ils s'approchèrent \w et|strong="H1841"\w* parlèrent \w au|strong="H6925"\w* \w roi|strong="H6925"\w* \w du|strong="H6925"\w* décret royal : « N'as-tu pas signé un décret stipulant \w que|strong="H7912"\w* tout \w homme|strong="H1400"\w* \w qui|strong="H1400"\w* \w adresserait|strong="H1156"\w* \w une|strong="H7912"\w* requête \w à|strong="H7912"\w* un \w dieu|strong="H6925"\w* ou \w à|strong="H7912"\w* un \w homme|strong="H1400"\w* \w dans|strong="H7912"\w* un délai \w de|strong="H1841"\w* trente jours, si ce n'est \w à|strong="H7912"\w* toi, ô \w roi|strong="H6925"\w*, serait jeté \w dans|strong="H7912"\w* \w la|strong="H1156"\w* fosse aux lions ? »  
\p \w Le|strong="H6925"\w* \w roi|strong="H6925"\w* répondit : « \w La|strong="H1156"\w* chose est certaine, conformément \w à|strong="H7912"\w* \w la|strong="H1156"\w* \w loi|strong="H1156"\w* \w des|strong="H6925"\w* \w Mèdes|strong="H6925"\w* \w et|strong="H1841"\w* \w des|strong="H6925"\w* Perses, \w qui|strong="H1400"\w* est irrévocable. »   
\p
\v 13 Alors \w ils|strong="H4430"\w* reprirent \w la|strong="H4481"\w* \w parole|strong="H6032"\w* \w devant|strong="H6925"\w* \w le|strong="H5922"\w* \w roi|strong="H4430"\w* : « \w Ce|strong="H4481"\w* Daniel, l'\w un|strong="H4481"\w* \w des|strong="H4481"\w* exilés \w de|strong="H4481"\w* Juda, \w ne|strong="H3809"\w* tient \w aucun|strong="H3809"\w* \w compte|strong="H5922"\w* \w de|strong="H4481"\w* \w toi|strong="H5922"\w*, ô \w roi|strong="H4430"\w*, \w ni|strong="H3606"\w* \w du|strong="H4481"\w* \w décret|strong="H5922"\w* \w que|strong="H1768"\w* \w tu|strong="H1768"\w* \w as|strong="H1768"\w* signé. \w Il|strong="H5922"\w* \w fait|strong="H1156"\w* \w sa|strong="H5922"\w* prière trois fois \w par|strong="H4481"\w* \w jour|strong="H3118"\w*. »  
\v 14 Lorsque \w le|strong="H5922"\w* \w roi|strong="H4430"\w* entendit \w ces|strong="H4430"\w* paroles, \w il|strong="H5922"\w* \w en|strong="H4430"\w* \w fut|strong="H4430"\w* très affligé. \w Il|strong="H5922"\w* \w prit|strong="H4430"\w* \w à|strong="H5922"\w* \w cœur|strong="H5922"\w* \w de|strong="H4481"\w* \w délivrer|strong="H4481"\w* \w Daniel|strong="H1841"\w*, \w et|strong="H4430"\w* jusqu'\w au|strong="H5922"\w* coucher \w du|strong="H4481"\w* \w soleil|strong="H4481"\w* \w il|strong="H5922"\w* s'efforça \w de|strong="H4481"\w* \w le|strong="H5922"\w* sauver.   
\p
\v 15 Alors \w ces|strong="H4430"\w* \w hommes|strong="H4430"\w* \w se|strong="H4430"\w* rassemblèrent \w de|strong="H4430"\w* nouveau \w auprès|strong="H5922"\w* \w du|strong="H5922"\w* \w roi|strong="H4430"\w* \w et|strong="H4430"\w* \w lui|strong="H5922"\w* dirent : « \w Sache|strong="H1934"\w*, ô \w roi|strong="H4430"\w*, \w que|strong="H1768"\w* \w la|strong="H5922"\w* \w loi|strong="H5922"\w* \w des|strong="H4430"\w* \w Mèdes|strong="H4430"\w* \w et|strong="H4430"\w* \w des|strong="H4430"\w* Perses exige \w qu|strong="H1768"\w*'aucun \w décret|strong="H5922"\w* ni aucune ordonnance établis \w par|strong="H1934"\w* \w le|strong="H5922"\w* \w roi|strong="H4430"\w* \w ne|strong="H4430"\w* puissent être modifiés. »   
