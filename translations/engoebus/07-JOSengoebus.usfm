\v 3 \w from|strong="H4480"\w* Shibor \w east|strong="H5921"\w* \w of|strong="H1366"\w* \w Egypt|strong="H4714"\w* \w to|strong="H5704"\w* \w the|strong="H6440"\w* \w northern|strong="H6828"\w* frontier \w of|strong="H1366"\w* \w Ekron|strong="H6138"\w* (\w which|strong="H1366"\w* \w is|strong="H6440"\w* \w counted|strong="H2803"\w* \w Canaanite|strong="H3669"\w*), \w the|strong="H6440"\w* \w five|strong="H2568"\w* \w Philistine|strong="H6430"\w* capitals, Gaza, Ashdod, Ashkelon, \w Gath|strong="H1663"\w*, \w and|strong="H4714"\w* \w Ekron|strong="H6138"\w*, \w also|strong="H6430"\w* \w the|strong="H6440"\w* \w territory|strong="H1366"\w* \w of|strong="H1366"\w* \w the|strong="H6440"\w* Avim  
\v 4 \w to|strong="H5704"\w* \w the|strong="H3605"\w* \w south|strong="H8486"\w*, \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w Canaanite|strong="H3669"\w* country \w from|strong="H5704"\w* \w Mearah|strong="H4632"\w* (\w which|strong="H3605"\w* \w is|strong="H3605"\w* Sideonian) \w as|strong="H5704"\w* \w far|strong="H5704"\w* \w as|strong="H5704"\w* Aphek \w on|strong="H3605"\w* \w the|strong="H3605"\w* Amorite frontier,  
\v 5 \w the|strong="H3605"\w* land \w of|strong="H2022"\w* \w the|strong="H3605"\w* \w Gebalites|strong="H1382"\w* \w and|strong="H2022"\w* \w all|strong="H3605"\w* \w that|strong="H3605"\w* borders \w on|strong="H8478"\w* \w the|strong="H3605"\w* \w eastern|strong="H4217"\w* \w Lebanon|strong="H3844"\w*, \w from|strong="H5704"\w* \w Baal-gad|strong="H1171"\w* \w at|strong="H2022"\w* \w the|strong="H3605"\w* \w foot|strong="H8478"\w* \w of|strong="H2022"\w* \w Mount|strong="H2022"\w* \w Hermon|strong="H2768"\w* \w to|strong="H5704"\w* \w Lebo-hamath|strong="H2574"\w*,  
