\id SNG
\h Kantik A Kantik Yo
\toc1 KANTIK A KANTIK YO
\toc2 Kantik A Kantik Yo
\toc3 Kan
\mt1 KANTIK A KANTIK YO
\c 1
\p 
\v 1 Kantik A \x + \xo 1:1 \xt I Wa 4:32\x*Kantik Yo, ki ekri pa Salomon.
\sp Jenn Fi a
\q1 
\v 2 Kite l bo m ak bo bouch li!
\q1 Paske \x + \xo 1:2 \xt Kan 1:4\x*lanmou ou bon pase diven.
\b
\q1 
\v 3 Lwil pafen ou yo santi bon.
\q1 \x + \xo 1:3 \xt Ekl 7:1\x*Non ou menm se tankou lwil kap vide;
\q1 se pou sa ke tout vyèj yo renmen ou konsa.
\q1 
\v 4 Rale m dèyè ou e annou kouri ansanm!
\q1 Wa a mennen m nan chanm li yo.
\b
\sp Lòt Yo
\q1 \x + \xo 1:4 \xt Kan 1:4\x*“Nou va rejwi nan ou e fè kè kontan;
\q1 nou va leve lanmou ou wo plis pase diven.
\sp Jenn Fi a
\q1 Ak bon rezon, yo renmen ou konsa.”
\q1 
\v 5 Mwen menm, mwen nwa; men mwen byen bèl,
\q1 O fi a Jérusalem yo, tankou tant \x + \xo 1:5 \xt És 60:7 \x*Kédar yo,
\q1 tankou rido a Salomon yo.
\q1 
\v 6 Pa gade mwen konsa akoz mwen nwa;
\q1 solèy la brile m konsa.
\q1 \x + \xo 1:6 \xt Sòm 69:8\x*Fis a manman m yo te byen fache avè m;
\q1 Yo te fè m gadyen chan rezen yo.
\q1 Men pwòp jaden pa m nan vin neglije.
\q1 
\v 7 Pale mwen, ou menm nan
\q1 ke nanm mwen tèlman renmen;
\q1 ki kote ou fè patiraj twoupo ou a?
\q1 Ki kote ou konn fè l kouche a midi?
\q1 Paske poukisa mwen ta tankou yon moun
\q1 ki vwale figi li nan kote twoupo \x + \xo 1:7 \xt Kan 8:13 \x*zanmi ou yo?
\b
\sp Salomon
\q1 
\v 8 Si ou menm, ou pa konnen,
\q1 O \x + \xo 1:8 \xt Kan 5:9\x*pi bèl pami tout fanm yo;
\q1 janbe swiv wout twoupo a,
\q1 e fè patiraj pou jenn kabrit ou yo
\q1 akote tant bèje ou yo.
\q1 
\v 9 Pou mwen, cheri mwen an,
\q1 ou tankou \x + \xo 1:9 \xt II Kwo 1:16-17\x* pi bèl poulich
\q1 pami sa kap rale cha Farawon an.
\q1 
\v 10 Bò figi ou byen bèl ak zanno,
\q1 kou ou ak \x + \xo 1:10 \xt Jen 24:53 \x*bèl kolye.
\b
\sp Lòt Yo
\q1 
\v 11 Nou va fè pou ou dekorasyon an lò
\q1 anbeli ak pwent an ajan tou won.
\sp Jenn Fi a
\q1 
\v 12 Pandan wa a te sou tab li,
\q1 \x + \xo 1:12 \xt Kan 4:14\x*pafen mwen te rive kote l ak bèl odè.
\q1 
\v 13 Sila ke m renmen an se yon pòch pafen;
\q1 \x + \xo 1:13 \xt Sòm 45:8\x*fèy bazilik ki pase tout nwit lan antre tete mwen.
\q1 
\v 14 Cheri mwen an se yon grap flè jasmen
\q1 byen plase nan chan rezen \x + \xo 1:14 \xt I Sam 23:29 \x*En-Guédi yo.
\sp Salomon
\q1 
\v 15 “Tèlman ou bèl, cheri mwen an; tèlman ou bèl!
\q1 \x + \xo 1:15 \xt Kan 4:1\x*Zye ou tankou toutrèl yo.”
\sp Jenn Fi a
\q1 
\v 16 Gade jan ou bèl e byen agreyab, \x + \xo 1:16 \xt Kan 2:3-17\x*cheri mwen an;
\q1 anverite, se zèb vèt kap fè kabann nou.
\sp Salomon
\q1 
\v 17 Pilye kay nou se \x + \xo 1:17 \xt I Wa 6:9-10\x*bwa sèd
\q1 e travès yo se bwa pen.
\c 2
\sp Jenn Fi a
\p 
\v 1 Mwen se flè Woz Saron an,
\q1 flè Lis a vale yo.
\b
\sp Salomon
\q1 
\v 2 Tankou yon flè lis pami pikan yo,
\q1 se konsa \x + \xo 2:2 \xt Kan 1:9\x*cheri mwen an ye
\q1 pami tout jenn fi yo.
\b
\sp Jenn Fi a
\q1 
\v 3 Tankou yon \x + \xo 2:3 \xt Kan 8:5\x*pye pòm pami bwa nan forè,
\q1 se konsa cheri mwen an ye pami jennonm yo.
\q1 Nan lonbraj li mwen te pran gwo plezi pou m te chita;
\q1 konsa fwi li te dous nan gou m.
\q1 
\v 4 Li te mennen m nan gwo sal bankè li,
\q1 e \x + \xo 2:4 \xt Sòm 20:5 \x*drapo li monte sou mwen an se lanmou.
\q1 
\v 5 Ban m fòs ak \x + \xo 2:5 \xt II Sam 6:19\x* gato rezen,
\q1 rafrechi m ak pòm,
\q1 akoz mwen malad ak lanmou.
\q1 
\v 6 Kite men goch li rete anba tèt mwen
\q1 ak men dwat li pou l \x + \xo 2:6 \xt Pwov 4:8\x*anbrase m.
\q1 
\v 7 M ap \x + \xo 2:7 \xt Kan 3:5\x*avèti nou, O fi a Jérusalem yo,
\q1 nan non antilòp ak bich mawon an,
\q1 pou nou pa fè lanmou m leve,
\q1 ni ouvri zye li jiskaske se plezi li.
\b
\q1 
\v 8 Koute! Men cheri mwen an!
\q1 Men l ap vini!
\q1 L ap monte \x + \xo 2:8 \xt Kan 2:17\x*sou mòn yo,
\q1 epi vòltije sou kolin yo!
\q1 
\v 9 Cheri mwen an tankou yon \x + \xo 2:9 \xt Pwov 6:5\x*antilòp,
\q1 oswa yon jenn sèf.
\q1 Gade byen, li kanpe dèyè mi kay nou an;
\q1 l ap gade nan fenèt yo, l ap gade nan jalouzi a.
\b
\q1 
\v 10 Cheri mwen an te reponn mwen
\q1 e te di m: \x + \xo 2:10 \xt Kan 2:13\x*“Leve vini cheri mwen an,
\q1 pi bèl mwen an.
\q1 
\v 11 Paske gade, sezon fredi a fin pase,
\q1 lapli fin pati nèt.
\q1 
\v 12 Flè yo deja parèt nan peyi a;
\q1 tan chante a fin rive!
\q1 Vwa \x + \xo 2:12 \xt Jen 15:9\x*toutrèl la ap koute deja nan peyi a.
\q1 
\v 13 Fwi \x + \xo 2:13 \xt Mat 24:32\x*pye fig etranje a fin mi,
\q1 e chan rezen yo bay odè pafen.
\q1 Leve vini, annou pati!”
\sp Salomon
\q1 
\v 14 O toutrèl nan \x + \xo 2:14 \xt Jr 48:28\x*fant wòch mwen an,
\q1 nan kote sekrè chemen ki monte apik,
\q1 kite mwen wè figi ou, kite mwen tande vwa ou!
\q1 Paske vwa ou dous e fòm ou bèl nèt.
\q1 
\v 15 \x + \xo 2:15 \xt Éz 13:4\x*Kenbe rena yo pou nou,
\q1 ti rena k ap detwi chan rezen yo,
\q1 paske chan nou yo ap fè flè.
\sp Jenn Fi a
\q1 
\v 16 Cheri mwen an se pa m,
\q1 e mwen se pa l.
\q1 Li fè patiraj twoupo li pami flè lis yo.
\q1 
\v 17 \x + \xo 2:17 \xt Kan 4:6\x*Jiskaske joune a vin fè fre
\q1 lè lonbraj yo kouri ale;
\q1 vire, cheri mwen an,
\q1 fè tankou antilòp la, oswa jenn sèf sou mòn Bether a.
\c 3
\sp Jenn Fi a
\p 
\v 1 Sou kabann mwen, pandan nwit lan,
\q1 mwen te chache sila \x + \xo 3:1 \xt Kan 1:7\x*ke nanm mwen renmen an.
\q1 Mwen te chache l, men m pa t jwenn li.
\q1 
\v 2 Koulye a fòk mwen leve mache toupatou nan vil la;
\q1 nan \x + \xo 3:2 \xt Jr 5:1\x*ri yo ak nan plas yo.
\q1 Fòk mwen chache sila ke nanm mwen renmen an.
\q1 Mwen te chache l, men m pa t jwenn li.
\q1 
\v 3 \x + \xo 3:3 \xt Kan 5:7\x*Gadyen ki fè tou vil la te twouve m.
\q1 Mwen te mande l: “Èske ou konn wè
\q1 sila ke nanm mwen renmen an?”
\q1 
\v 4 Lè m \x + \xo 3:4 \xt Pwov 8:17\x*fenk kite yo mwen te jwenn
\q1 sila ke nanm mwen renmen an.
\q1 Mwen te kenbe l, mwen te refize lage l
\q1 jiskaske mwen mennen l rive lakay manman m,
\q1 pou l antre nan chanm a sila ki te vin ansent mwen an.
\b
\q1 
\v 5 M ap \x + \xo 3:5 \xt Kan 2:7\x*avèti nou, O fi a Jérusalem yo,
\q1 nan non antilòp ak bich mawon an,
\q1 pou nou pa fè lanmou leve
\q1 ni ouvri zye l jiskaske se plezi li.
\b
\q1 
\v 6 Se kisa k ap monte kite dezè a
\q1 tankou pilye lafimen yo,
\q1 byen pafime ak fèy bazilik ak \x + \xo 3:6 \xt Egz 30:34 \x*lansan,
\q1 plen ak poud santi bon machann yo?
\q1 
\v 7 Gade byen, se kanape vwayaj Salomon k ap monte;
\q1 swasant òm pwisan kap antoure l,
\q1 mesye pwisan Israël yo.
\q1 
\v 8 Yo tout ki konn manyen nepe,
\q1 \x + \xo 3:8 \xt Jr 50:9\x*ki fò nan afè lagè;
\q1 chak mesye gen nepe l bò kote li,
\q1 pou fè gad kont menas lannwit yo.
\b
\q1 
\v 9 Wa Salomon te fè pou kont li
\q1 yon kanape vwayaj ak bwa Liban an.
\q1 
\v 10 Li te fè pye li ak ajan e repo pou do a ak lò.
\q1 Kote pou chita a fabrike ak twal mov,
\q1 e tout anndan li byen dekore pa \x + \xo 3:10 \xt Kan 1:5\x*fi Jérusalem yo.
\q1 
\v 11 Ale, O fi a Sion yo,
\q1 e fikse byen Wa Salomon ak kouwòn sila a
\q1 manman l te kouwone l nan \x + \xo 3:11 \xt És 62:5 \x*jou fèt maryaj li,
\q1 nan jou kè kontan li an.
\c 4
\sp Salomon
\q1 
\v 1 A la ou bèl, cheri mwen an, a la ou bèl!
\q1 \x + \xo 4:1 \xt Kan 1:15\x*Zye ou tankou toutrèl dèyè vwal ou;
\q1 cheve ou tankou yon bann kabrit
\q1 ki fin desann sòti Mòn Galaad.
\q1 
\v 2 \x + \xo 4:2 \xt Kan 6:6\x*Dan ou tankou yon bann mouton
\q1 ak lenn fenk taye ki sot benyen.
\q1 Yo tout fè pòtre jimo yo,
\q1 ni youn nan yo pa pèdi pitit li.
\q1 
\v 3 Lèv ou tankou \x + \xo 4:3 \xt Jos 2:18\x*fisèl wouj
\q1 e bouch ou tèlman bèl.
\q1 De bò figi ou tankou yon tranch grenad dèyè vwal ou.
\q1 
\v 4 \x + \xo 4:4 \xt Kan 7:4\x*Kou ou tankou fò David la,
\q1 bati ak wòch byen ranje sou sila yo mete mil boukliye yo,
\q1 tout boukliye won a mesye pwisan yo.
\q1 
\v 5 \x + \xo 4:5 \xt Kan 7:3\x*De tete ou tankou de jèn ti antilòp;
\q1 jimo manman k ap chache manje pami flè lis yo.
\b
\q1 
\v 6 \x + \xo 4:6 \xt Kan 2:17\x*Jiskaske jou a bese pou l vin fre
\q1 e lonbraj yo vin disparèt,
\q1 mwen va trase chemen mwen rive nan mòn
\q1 fèy bazilik la, ak nan kolin lansan an.
\b
\q1 
\v 7 \x + \xo 4:7 \xt Kan 1:15\x*Ou fin bèl nèt, cheri mwen an,
\q1 e nanpwen defo nan ou.
\q1 
\v 8 Vin avè m soti \x + \xo 4:8 \xt I Wa 4:33\x*Liban, fi maryaj mwen an;
\q1 m bezwen ou vini avè m sòti Liban.
\q1 Vwayaje desann soti nan wo pwent Amana,
\q1 soti nan wo pwent Mòn Senir ak Hermon;
\q1 soti nan kav lyon yo, nan mòn a leyopa yo.
\b
\q1 
\v 9 Ou fè kè m bat pi vit sè mwen, fi maryaj mwen an;
\q1 ou te fè kè m bat pi vit ak yon sèl ti kout zye tou kout,
\q1 ak yon sèl bout fisèl nan \x + \xo 4:9 \xt Jen 41:42\x*kolye ou.
\q1 
\v 10 \x + \xo 4:10 \xt Kan 7:6\x*A la bèl lanmou ou bèl, sè mwen an,
\q1 fi a maryaj mwen an!
\q1 A la pi bon lanmou ou pi bon pase diven
\q1 e bon odè a lwil ou depase tout kalite epis!
\q1 
\v 11 Lèv ou, fi a maryaj mwen an, gen gou siwo myèl;
\q1 siwo myèl ak lèt anba lang ou.
\q1 Bon odè vètman ou tankou \x + \xo 4:11 \xt Jen 27:27\x*bon odè Liban an.
\q1 
\v 12 Yon jaden fèmen ak kle se sè mwen,
\q1 fi a maryaj mwen;
\q1 yon jaden wòch ki fèmen,
\q1 yon fontèn dlo ki \x + \xo 4:12 \xt Jen 29:3\x*ansèkle.
\q1 
\v 13 Boujon ou se yon chan kiltive ak pye grenad,
\q1 ak fwi chwazi, pye jasmen ak ti bonm;
\q1 
\v 14 ti bonm ak safran, sitwonèl ak kannèl,
\q1 ak tout bwa lansan yo, \x + \xo 4:14 \xt Sòm 45:8 \x*lami ak lalwa,
\q1 ansanm ak tout meyè kalite epis yo.
\q1 
\v 15 Ou menm se yon sous jaden,
\q1 yon pwi \x + \xo 4:15 \xt Za 14:8\x*dlo fre ak ti ravin dlo k ap kouri soti Liban.
\sp Jenn Fi an
\q1 
\v 16 Leve, o van nan nò a, e vini van nan sid!
\q1 Fè jaden mwen respire ak souf bon odè;
\q1 kite epis li yo vante gaye toupatou.
\q1 Ke cheri mwen an vin nan jaden li an
\q1 pou manje tout fwi chwa li yo.
\c 5
\sp Salomon
\q1 
\v 1 Mwen te vini nan jaden mwen an, sè mwen,
\q1 fi a maryaj mwen an.
\q1 Mwen te ranmase lami mwen ak tout fèy awomatik mwen.
\q1 Mwen te manje gato myèl ak siwo myèl mwen;
\q1 mwen te bwè diven mwen ak lèt mwen.
\b
\sp Lòt Yo
\p Manje, zanmi nou yo; bwè e vin sou ak lanmou!
\b
\sp Jenn Fi a
\q1 
\v 2 Mwen t ap dòmi, men kè m t ap veye.
\q1 Yon vwa! Cheri mwen an t ap frape sou pòt la:
\q1 “Ouvri pou mwen, sè mwen, cheri mwen an,
\q1 toutrèl mwen an, ou menm ki pafè pou mwen an! Tèt mwen mouye ak lawouze,
\q1 \x + \xo 5:2 \xt Kan 5:11 \x*très cheve mwen ak imidite nwit lan.
\q1 
\v 3 Mwen te \x + \xo 5:3 \xt Luc 11:7\x*fin retire rad mwen;
\q1 kijan pou m ta remete l ankò a?
\q1 Mwen te lave pye mwen;
\q1 kijan pou m ta fè vin sal yo ankò a?
\q1 
\v 4 Cheri mwen an te lonje men l pase nan twou pòt la.
\q1 Tout \x + \xo 5:4 \xt Jr 31:20\x*santiman kè m te leve pou li.
\q1 
\v 5 Mwen te leve pou ouvri pou cheri mwen an.
\q1 Men m te \x + \xo 5:5 \xt Kan 5:13\x*degoute menm ak lami,
\q1 e dwèt mwen ak dlo lami, sou manch boulon pòt lan.
\q1 
\v 6 Mwen te ouvri a cheri mwen an,
\q1 men cheri mwen an te \x + \xo 5:6 \xt Kan 6:1\x*vire kite pou l ale!
\q1 Kè m te sòti lè l te pale a.
\q1 Mwen te chache li, men mwen pa t jwenn li.
\q1 Mwen te rele li, men li pa t reponn mwen.
\q1 
\v 7 \x + \xo 5:7 \xt Kan 3:3\x*Gadyen ki te fè tou vil la te twouve mwen.
\q1 Yo te bat mwen.
\q1 Yo te blese mwen.
\q1 Jandam sou miray la te retire gwo manto mwen an.
\b
\q1 
\v 8 “M ap \x + \xo 5:8 \xt Kan 2:5\x*avèti nou, O fi a Jérusalem yo,
\q1 si nou jwenn cheri mwen an, konsa nou va di l;
\q1 ke mwen malad ak lanmou.”
\b
\sp Lòt Yo
\q1 
\v 9 “Ki jan cheri ki cheri ou a,
\q1 sinon pi bèl pami fanm yo?
\q1 Ki jan cheri ki cheri ou a,
\q1 pi bon pase lòt,
\q1 ke ou ta nonmen non l devan nou konsa?”
\b
\sp Jenn Fi a
\q1 
\v 10 Cheri mwen an mèvèye,
\q1 yon figi wouj ranpli ak sante,
\q1 k ap \x + \xo 5:10 \xt Sòm 45:2 \x*parèt miyò pami di-mil.
\q1 
\v 11 Tèt li tankou lò, lò san tach;
\q1 \x + \xo 5:11 \xt Kan 5:2\x*très cheve li tankou grap rezen
\q1 e nwa tankou kòbo.
\q1 
\v 12 Zye li tankou toutrèl
\q1 akote dlo k ap koule,
\q1 ki benyen nan lèt,
\q1 ki monte kon bijou akote yon \x + \xo 5:12 \xt Egz 25:7 \x*basen dlo.
\q1 
\v 13 De bò figi li tankou yon kabann fèt ak fèy awomatik,
\q1 kap poze sou yon kouch zèb santi bon.
\q1 Lèv li yo se flè \x + \xo 5:13 \xt Kan 2:1 \x*lis ki degoute dlo lami.
\q1 
\v 14 Men li se wondèl fèt an lò,
\q1 anbeli ak bijou beril.
\q1 Kò li se ivwa taye ki kouvri ak pyè safi.
\q1 
\v 15 Janm li se pilye fèt an mèb blan,
\q1 plase sou yon baz lò san tach;
\q1 aparans li tankou \x + \xo 5:15 \xt Kan 7:4\x*chwa Liban an,
\q1 kon pi bèl bwa sèd li.
\q1 
\v 16 Bouch li plen ak dousè.
\q1 Li dezirab nèt.
\q1 Sa se cheri mwen an,
\q1 e sa se zanmi mwen an,
\q1 o fi Jérusalem yo.
\c 6
\sp Lòt yo
\q1 
\v 1 \x + \xo 6:1 \xt Kan 5:6\x*“Kote cheri ou a te ale, o pi bèl pami fanm yo?
\q1 Kote cheri ou a te vire, pou nou ka chache li ansanm avèk ou?”
\b
\sp Jenn Fi a
\q1 
\v 2 Cheri mwen an te desann nan jaden li an,
\q1 nan kabann ki fèt ak fèy awomatik,
\q1 pou fè patiraj twoupo li nan jaden yo,
\q1 pou ranmase flè \x + \xo 6:2 \xt Kan 2:1\x*lis.
\q1 
\v 3 Mwen pou cheri mwen an e cheri mwen pou mwen;
\q1 sila ki fè patiraj twoupo li pami flè lis yo.
\b
\sp Salomon
\q1 
\v 4 Ou bèl, cheri mwen an, tankou \x + \xo 6:4 \xt I Wa 14:17\x*Thirtsa;
\q1 bèl tankou Jérusalem,
\q1 mèvèye tankou yon lame ak drapo yo.
\q1 
\v 5 Vire zye ou! Pa gade m!
\q1 Paske zye ou fè m egare.
\q1 \x + \xo 6:5 \xt Kan 4:1\x*Cheve ou tankou yon bann kabrit k ap soti desann Galaad.
\q1 
\v 6 \x + \xo 6:6 \xt Kan 4:2\x*Dan ou tankou yon bann mouton
\q1 ki fenk monte sot benyen.
\q1 Yo tout ki pòtre marasa.
\q1 Nanpwen menm youn nan yo ki pèdi pitit.
\q1 
\v 7 \x + \xo 6:7 \xt Kan 4:3\x*De bò figi ou tankou yon tranch grenad
\q1 dèyè vwal ou.
\b
\q1 
\v 8 Genyen swasant rèn ak katre-ven konkibin,
\q1 e \x + \xo 6:8 \xt Kan 1:3\x*jèn fi menm pa kab konte;
\q1 
\v 9 Men toutrèl mwen an, parèy san parèy mwen an inik;
\q1 li se sèl fi a manman li.
\q1 Fi san tach a sila ki te pote li a.
\q1 \x + \xo 6:9 \xt Jen 30:13 \x*Jenn fi yo te wè l e te rele l beni;
\q1 ni rèn ni konkibin yo.
\q1 Yo te louwe l pou di:
\b
\q1 
\v 10 Kilès li ye ki grandi kon solèy leve a,
\q1 bèl tankou plèn lin nan,
\q1 san tach tankou \x + \xo 6:10 \xt Mat 17:2\x*solèy la,
\q1 e mèvèye tankou yon lame ak tout drapo li a?
\b
\q1 
\v 11 Mwen te desann nan chan bwa nwa yo
\q1 pou wè bwa vèt yo nan vale a;
\q1 pou wè si chan rezen fin fè boujon,
\q1 oswa \x + \xo 6:11 \xt Kan 4:13\x*grenad yo te fleri.
\q1 
\v 12 Avan mwen te menm konnen,
\q1 dezi m te plase mwen sou cha a pèp nòb mwen an.
\b
\sp Lòt Yo
\q1 
\v 13 Retounen, retounen, O Silamit lan;
\q1 \x + \xo 6:13 \xt Jij 21:21\x*retounen, retounen, pou zye nou ka gade ou!
\b
\sp Salomon
\q1 Poukisa ou ta gade Silamit lan tankou se nan dans a de twoup koral?
\c 7
\p 
\v 1 A la bèl pye ou bèl nan sandal yo, o pitit a nòb yo!
\q1 O \x + \xo 7:1 \xt Sòm 45:13\x*fi a prens lan!
\q1 Koub kwis ou tankou bijou, zèv a yon vre atis.
\q1 
\v 2 Lonbrit ou kon yon tas won ki pa janm manke diven mele;
\q1 vant ou se yon bèl pakèt ble ankadre ak flè lis;
\q1 
\v 3 \x + \xo 7:3 \xt Kan 4:5\x*De tete ou se de jenn pòtre a yon antilòp,
\q1 jimo a yon antilòp.
\q1 
\v 4 Kou ou se yon kou ivwa,
\q1 zye ou tankou sous dlo nan \x + \xo 7:4 \xt Nonb 21:26\x*Hesbon yo
\q1 akote pòtay a Bath-Rabbim nan.
\q1 Nen ou tankou tou Liban ki gade vè Damas la.
\q1 
\v 5 Tèt ou kouwone ou tankou \x + \xo 7:5 \xt És 35:2\x*Mòn Carmel
\q1 e très cheve tèt ou tankou fisèl mov.
\q1 Wa a kaptire pa très ou yo.
\q1 
\v 6 A la ou \x + \xo 7:6 \xt Kan 1:15-16\x*bèl e a la ou mèvèye,
\q1 ak tout bèlte ou yo!
\q1 
\v 7 Lè ou kanpe se tankou yon pye palmis
\q1 e tete ou se grap li yo.
\q1 
\v 8 Mwen te di: “Mwen va monte pye palmis lan,
\q1 mwen va kenbe tij fwi li yo.”
\q1 O ke tete ou yo kapab tankou grap
\q1 ki pann sou chan rezen an,
\q1 e bon odè a \x + \xo 7:8 \xt Kan 2:5\x*souf ou tankou pòm,
\q1 
\v 9 Epi \x + \xo 7:9 \xt Kan 5:16\x*bouch ou tankou meyè diven an, ki desann byen swa pou cheri mwen an,
\q1 e koule dousman nan lèv a sila
\q1 ki tonbe nan dòmi yo.
\b
\sp Jenn Fi a
\q1 
\v 10 Mwen pou cheri mwen an
\q1 e \x + \xo 7:10 \xt Sòm 45:11 \x*dezi li se pou mwen.
\q1 
\v 11 Vini, cheri mwen an!
\q1 Annou pati ale nan chan yo
\q1 e fè lojman nan ti vil yo.
\q1 
\v 12 Annou leve bonè pou rive nan chan rezen yo;
\q1 annou \x + \xo 7:12 \xt Kan 6:11\x*gade pou wè si chan rezen an
\q1 gen tan boujonnen e flè li yo fin ouvri.
\q1 Se la, m ap bay ou lanmou mwen an.
\q1 
\v 13 Mandragò yo fin bay bèl odè;
\q1 epi sou tout pòt nou yo se tout meyè fwi yo,
\q1 ni nèf ni ansyen,
\q1 ki te konsève pou ou, lanmou mwen an.
\c 8
\p 
\v 1 O ke ou te tankou frè m,
\q1 ki te souse nan tete a manman m.
\q1 Si mwen te jwenn ou deyò, mwen ta bo ou;
\q1 nonplis, pèsòn pa ta denonse m pou sa!
\q1 
\v 2 Mwen ta mennen ou e \x + \xo 8:2 \xt Kan 3:4\x*fè ou antre
\q1 lakay a manman m ki te konn enstwi mwen an.
\q1 Mwen ta bay ou diven pafime ki sòti
\q1 nan ji grenad mwen yo pou ou bwè.
\q1 
\v 3 Kite \x + \xo 8:3 \xt Kan 2:6\x*men goch li rete anba tèt mwen
\q1 e men dwat li anbrase m.
\b
\q1 
\v 4 “\x + \xo 8:4 \xt Kan 2:7\x*Mwen vle nou sèmante, o fi Jérusalem yo,
\q1 pa fè lanmou a vin leve,
\q1 ni ankouraje l jiskaske se plezi li.
\b
\sp Lòt Yo
\q1 
\v 5 Se \x + \xo 8:5 \xt Kan 3:6\x*ki fi sa a k ap monte sòti nan dezè a,
\q1 k ap apiye sou cheri li a?”
\b
\sp Jenn Fi a
\q1 Anba pye pòm nan, mwen te fè ou leve;
\q1 se la manman ou te gen doulè e te fè ou vin parèt.
\b
\q1 
\v 6 Mete mwen tankou yon so sou kè ou,
\q1 tankou yon \x + \xo 8:6 \xt És 49:16\x*so sou bra ou.
\q1 Paske lanmou gen fòs menm jan ak lanmò.
\q1 Jalouzi sevè tankou Sejou mò yo;
\q1 lè l pete se tankou dife k ap pete.
\q1 Vrèman se flanm SENYÈ a.
\q1 
\v 7 Anpil dlo p ap ka etenn lanmou,
\q1 ni rivyè p ap ka inonde l.
\q1 \x + \xo 8:7 \xt Pwov 6:35\x*Menm si yon nonm ta bay tout richès lakay li pou lanmou,
\q1 sa ta konplètman meprize.
\sp Frè Yo
\q1 
\v 8 Nou gen yon ti sè e li \x + \xo 8:8 \xt Éz 16:7\x*pa gen tete menm;
\q1 kisa n ap fè pou sè nou an nan jou ke yon moun
\q1 ta vin pale pou l ta fiyanse avè l?
\b
\q1 
\v 9 Si ti fi a se yon mi, nou va bati yon ranpa fèt an ajan pou antoure l;
\q1 men, si li se yon pòt, n ap fè yon barikad
\q1 ak \x + \xo 8:9 \xt I Wa 6:15\x*gwo planch bwa sèd.
\b
\sp Jenn Fi a
\q1 
\v 10 Mwen te yon miray e \x + \xo 8:10 \xt Éz 16:7\x*tete mwen te tankou fò yo;
\q1 konsa, mwen te devni nan zye li kon yon moun ki jwenn lapè.
\q1 
\v 11 Salomon te gen yon chan rezen nan Baal-Hamon;
\q1 Li te \x + \xo 8:11 \xt Mat 21:33 \x*bay jerans chan rezen an a gadyen yo.
\q1 Yo chak te gen pou pote mil sik ajan pou fwi li yo.
\q1 
\v 12 Pwòp chan rezen mwen an se devan m;
\q1 mil sik ajan yo se pou ou, Salomon
\q1 ak de-san pou sila ki okipe fwi li yo.
\sp Salomon
\q1 
\v 13 O ou menm, ki chita nan jaden yo,
\q1 ansanm ak zanmi mwen yo,
\q1 kite m tande vwa ou.
\b
\sp Jenn Fi a
\q1 
\v 14 Annou pati, cheri mwen an!
\q1 Fè tankou yon antilòp,
\q1 oswa yon jenn sèf sou mòn ki plen epis yo. 
