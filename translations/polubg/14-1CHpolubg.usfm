\id 1CH  
\h I Kronik 
\toc1 I Księga Kronik 
\toc2 I Kronik 
\toc3 1Krn 
\mt1 I Księga Kronik  
\c 1  
\m
\v 1 Adam, Set, Enosz;   
\m
\v 2 Kenan, Mahalaleel, Jered;   
\m
\v 3 Henoch, Matuzalem, Lamech;   
\m
\v 4 Noe, Sem, Cham i Jafet.   
\m
\v 5 Synowie Jafeta: Gomer, Magog, Madaj, Jawan, Tubal, Meszek i Tiras.   
\m
\v 6 A synowie Gomera: Aszkenaz, Rifat i Togarma.   
\m
\v 7 A synowie Jawana: Elisa i Tarszisz, Cytym i Dodanim.   
\m
\v 8 Synowie Chama: Kusz, Misraim, Put i Kanaan.   
\m
\v 9 A synowie Kusza: Seba, Chaawila, Sabta, Rama i Sabteka. A synowie Ramy: Szeba i Dedan.   
\m
\v 10 Kusz spłodził Nimroda, który zaczął być mocarzem na ziemi.   
\m
\v 11 Misraim spłodził Ludima, Ananima, Lahabima i Naftuchima;   
\m
\v 12 Oraz Patrusyma, Kasluchima, od których wywodzą się Filistyni, i Kaftoryma.   
\m
\v 13 Kanaan zaś spłodził Sidona, swego pierworodnego, i Cheta;   
\m
\v 14 Jebusytę, Amorytę i Girgaszytę;   
\m
\v 15 Chiwwitę, Arkitę i Sinitę;   
\m
\v 16 Arwadytę, Semarytę i Chamatytę.   
\m
\v 17 Synowie Sema: Elam, Assur, Arpachszad, Lud, Aram, Us, Chul, Geter i Meszek.   
\m
\v 18 Arpachszad spłodził Szelacha, a Szelach spłodził Ebera.   
\m
\v 19 Eberowi zaś urodzili się dwaj synowie: jeden \add miał\add* na imię Peleg, gdyż za jego czasów ziemia została rozdzielona, a imię brata jego – Joktan.   
\m
\v 20 Joktan spłodził Almodada, Szelefa, Chasarmaweta i Jeracha;   
\m
\v 21 Hadorama, Uzala i Diklę;   
\m
\v 22 Ebala, Abimaela i Szeba;   
\m
\v 23 Ofira, Chawila i Jobaba. Wszyscy ci byli synami Joktana.   
\m
\v 24 Sem, Arpachszad, Szelach;   
\m
\v 25 Eber, Peleg, Reu;   
\m
\v 26 Serug, Nachor, Terach;   
\m
\v 27 Abram, to jest Abraham.   
\m
\v 28 Synowie Abrahama: Izaak i Izmael.   
\m
\v 29 A oto \add są\add* ich rody: pierworodny Izmaela – Nebajot, następnie Kedar, Abdeel i Mibsam;   
\m
\v 30 Miszma, Duma, Massa, Hadad i Tema;   
\m
\v 31 Jetur, Nafisz i Kedma. \add Byli\add* oni synami Izmaela.   
\m
\v 32 A \add oto\add* synowie Ketury, nałożnicy Abrahama: urodziła ona Zimrana, Jokszana, Medana, Midiana, Jiszbaka i Szuacha. A synowie Jokszana: Szeba i Dedan.   
\m
\v 33 Synowie Midiana: Efa, Efer, Henoch, Abida i Eldaa. Oni wszyscy \add byli\add* synami Ketury.   
\m
\v 34 I Abraham spłodził Izaaka. Synowie Izaaka: Ezaw i Izrael.   
\m
\v 35 A synowie Ezawa: Elifaz, Rehuel, Jeusz, Jalam i Korach.   
\m
\v 36 Synowie Elifaza: Teman, Omar, Sefo, Gatam, Kenaz, Timna i Amalek.   
\m
\v 37 Synowie Rehuela: Nachat, Zerach, Szamma i Mizza.   
\m
\v 38 A synowie Seira: Lotan, Szobal, Sibeon, Ana, Diszon, Eser i Diszan.   
\m
\v 39 A synowie Lotana: Chori, Homam; a siostrą Lotana \add była\add* Timna.   
\m
\v 40 Synowie Szobala: Alian, Manachat, Ebal, Szefo i Onam. A synowie Sibeona: Ajja i Ana.   
\m
\v 41 Synowie Any: Diszon. Synowie Diszona: Chamran i Eszban, Jitran i Keran.   
\m
\v 42 Synowie Esera: Bilhan, Zaawan i Jaakan. Synowie Diszana: Us i Aran.   
\m
\v 43 To byli królowie, którzy panowali w ziemi Edomu, zanim zapanował król nad synami Izraela: Bela, syn Beora, a jego miasto nazywało się Dinhaba.   
\m
\v 44 A gdy Bela umarł, królował w jego miejsce Jobab, syn Zeracha z Bosry.   
\m
\v 45 A gdy Jobab umarł, królował w jego miejsce Chuszam z ziemi Temanitów.   
\m
\v 46 A gdy Chuszam umarł, królował w jego miejsce Hadad, syn Bedada, który pobił Midianitów na polu Moabu. A jego miasto nazywało się Awit.   
\m
\v 47 A gdy Hadad umarł, królował w jego miejsce Samla z Masreki.   
\m
\v 48 A gdy Samla umarł, królował w jego miejsce Szaul z Rechobot nad Rzeką.   
\m
\v 49 A gdy Szaul umarł, królował w jego miejsce Baalchanan, syn Akbora.   
\m
\v 50 A gdy Baalchanan umarł, królował w jego miejsce Hadad. Jego miasto nazywało się Pai, a jego żona miała na imię Mehetabel, \add była to\add* córka Matredy, córki Mezahaba.   
\m
\v 51 I Hadad umarł. A książętami Edomu byli: książę Timna, książę Alia, książę Jetet;   
\m
\v 52 Książę Oholibama, książę Ela, książę Pinon;   
\m
\v 53 Książę Kenaz, książę Teman, książę Mibsar;   
\m
\v 54 Książę Magdiel, książę Iram. Oni \add byli\add* książętami Edomu.   
\c 2  
\m
\v 1 Oto są synowie Izraela: Ruben, Symeon, Lewi i Juda, Issachar i Zebulon;   
\m
\v 2 Dan, Józef, Beniamin, Neftali, Gad i Aszer.   
\m
\v 3 Synowie Judy: Er, Onan i Szela. Ci trzej urodzili mu się z córki Szui, Kananejki. Ale Er, pierworodny Judy, był zły w oczach PANA, dlatego go zabił.   
\m
\v 4 Tamar zaś, jego synowa, urodziła mu Peresa i Zeracha. Wszystkich synów Judy było pięciu.   
\m
\v 5 Synowie Peresa: Chesron i Chamul.   
\m
\v 6 Synowie Zeracha: Zimri, Etan, Heman, Kalkol i Dara, wszystkich ich \add było\add* pięciu.   
\m
\v 7 Synowie Karmiego: Achar, który sprowadził nieszczęście na Izraela, gdy zgrzeszył przy rzeczach przeklętych.   
\m
\v 8 Synowie Etana: Azariasz.   
\m
\v 9 Synowie Chesrona, którzy mu się urodzili: Jerachmeel, Ram i Kelubaj.   
\m
\v 10 Ram zaś spłodził Amminadaba, a Amminadab spłodził Nachszona, księcia synów Judy.   
\m
\v 11 A Nachszon spłodził Salmę, a Salma spłodził Boaza.   
\m
\v 12 A Boaz spłodził Obeda, a Obed spłodził Jessego.   
\m
\v 13 A Jesse spłodził swego pierworodnego Eliaba, \add jako\add* drugiego – Abinadaba, trzeciego – Szimeę;   
\m
\v 14 Czwartego – Netaneela, piątego – Raddaja;   
\m
\v 15 Szóstego – Osema, siódmego – Dawida.   
\m
\v 16 A ich siostry to Seruja i Abigail. Synowie Serui: Abiszaj, Joab i Asahel – ci trzej.   
\m
\v 17 Abigail zaś urodziła Amasę, ojcem Amasy \add był\add* Jeter, Izmaelita.   
\m
\v 18 Kaleb, syn Chesrona, spłodził \add dzieci\add* z Azubą, \add swoją\add* żoną, i z Jeriotą. A jej synami byli: Jeszer, Szobab i Ardon.   
\m
\v 19 A gdy Azuba umarła, Kaleb pojął sobie za żonę Efratę, która urodziła mu Chura.   
\m
\v 20 A Chur spłodził Uriego, a Uri spłodził Besaleela.   
\m
\v 21 Potem Chesron obcował z córką Makira, ojca Gileada, i wziął ją za żonę, mając sześćdziesiąt lat, a ta urodziła mu Seguba.   
\m
\v 22 A Segub spłodził Jaira, który miał dwadzieścia trzy miasta w ziemi Gilead.   
\m
\v 23 Zabrał bowiem Geszurze i Aramowi wsie Jaira oraz Kenat i przyległe do niego miasteczka: razem sześćdziesiąt miast. Wszystkie one \add należały do\add* synów Makira, ojca Gileada.   
\m
\v 24 Po śmierci Chesrona w Kaleb-Efrata, żona Chesrona, Abija, urodziła mu Aszura, ojca Tekoa.   
\m
\v 25 Synami Jerachmeela, pierworodnego Chesrona, byli: pierworodny Ram, następnie Buna, Oren, Ozem i Achiasz.   
\m
\v 26 Jerachmeel miał także drugą żonę imieniem Atara. \add Była\add* ona matką Onama.   
\m
\v 27 Synami Rama, pierworodnego Jerachmeela, \add byli\add*: Maas, Jamin i Eker.   
\m
\v 28 Synami Onama byli Szammaj i Jada. Synami Szammaja: Nadab i Abiszur.   
\m
\v 29 Żona Abiszura miała na imię Abihail i urodziła mu Achbana i Molida.   
\m
\v 30 Synowie Nadaba: Seled i Appaim. Lecz Seled umarł bez potomstwa.   
\m
\v 31 Synowie Appaima: Jiszi. Synowie Jisziego: Szeszan, a córka Szeszana: Achlaj.   
\m
\v 32 Synowie Jady, brata Szammaja: Jeter i Jonatan. A Jeter umarł bez potomstwa.   
\m
\v 33 Synowie Jonatana: Pelet i Zaza. Byli oni synami Jerachmeela.   
\m
\v 34 Lecz Szeszan nie miał synów, tylko córki. Miał też Szeszan sługę Egipcjanina imieniem Jarcha.   
\m
\v 35 Dał więc Szeszan swemu słudze Jarsze swoją córkę za żonę, a ona urodziła mu Attaja.   
\m
\v 36 Attaj spłodził Natana, a Natan spłodził Zabada.   
\m
\v 37 Zabad spłodził Eflala, a Eflal spłodził Obeda.   
\m
\v 38 Obed spłodził Jehu, a Jehu spłodził Azariasza.   
\m
\v 39 Azariasz spłodził Chelesa, a Cheles spłodził Eleasę.   
\m
\v 40 Eleasa spłodził Sismaja, a Sismaj spłodził Szalluma.   
\m
\v 41 A Szallum spłodził Jekamiasza, a Jekamiasz spłodził Eliszamę.   
\m
\v 42 Synami Kaleba, brata Jerachmeela, \add byli\add*: jego pierworodny Mesza, który był ojcem Zifa, i synowie Mareszy – ojcem Chebrona.   
\m
\v 43 Synowie Chebrona: Korach, Tappuach, Rekem i Szema.   
\m
\v 44 Szema spłodził Rachama, syna Jorkoama, a Rekem spłodził Szammaja.   
\m
\v 45 Synem Szammaja \add był\add* Maon, a Maon \add był\add* ojcem Bet-Sura.   
\m
\v 46 Efa, nałożnica Kaleba, urodziła Charana, Mosę i Gazeza, a Charan spłodził Gazeza.   
\m
\v 47 Synowie Jahdaja: Regem, Jotam, Geszan, Pelet, Efa i Szaaf.   
\m
\v 48 Maaka, \add druga\add* nałożnica Kaleba, urodziła Szebera i Tyrchanę.   
\m
\v 49 Urodziła również Szaafa, ojca Madmanny, i Szewę, ojca Makbeny i Gibea. A córką Kaleba \add była\add* Aksa.   
\m
\v 50 Ci byli synami Kaleba, syna Chura, pierworodnego Efraty: Szobal, ojciec Kiriat-Jearima;   
\m
\v 51 Salma, ojciec Betlejema, i Charef, ojciec Bet-Gadera.   
\m
\v 52 Szobal, ojciec Kiriat-Jearima, miał synów: Haroego i połowę Manachytów.   
\m
\v 53 A rodziny Kiriat-Jearima \add to\add*: Jitryci, Putyci, Szumatyci i Mirzaici, od których wywodzą się Soreatyci i Esztaolici.   
\m
\v 54 Synowie Salmy: Betlejem, Netofatyci, Atrot, rodzina Joaba i połowa Manachytów, Soreici;   
\m
\v 55 Rodziny pisarzy mieszkających w Jabes: Tyratyci, Szimeatyci i Sukatyci. Ci są Kenitami, którzy wywodzili się od Chamata, ojca domu Rechaba.   
\c 3  
\m
\v 1 Oto synowie Dawida, którzy urodzili mu się w Hebronie: pierworodny Ammon z Achinoam, Jizreelitki, drugi Daniel z Abigail, Karmelitki;   
\m
\v 2 Trzeci Absalom, syn Maaki, córki Talmaja, króla Geszuru, czwarty Adoniasz, syn Chaggity;   
\m
\v 3 Piąty Szefatiasz z Abitali, szósty Jitream z jego żony Egli.   
\m
\v 4 Tych sześciu urodziło mu się w Hebronie, gdzie królował przez siedem lat i sześć miesięcy. A trzydzieści trzy lata królował w Jerozolimie.   
\m
\v 5 Ci zaś urodzili mu się w Jerozolimie: Szima, Szobab, Natan i Salomon – ci czterej z Batszui, córki Ammiela.   
\m
\v 6 I Ibchar, Eliszama, Elifelet;   
\m
\v 7 Nogah, Nefeg, Jafia;   
\m
\v 8 Eliszama, Eliada i Elifelet – dziewięciu.   
\m
\v 9 Ci wszyscy byli synami Dawida, nie licząc synów z nałożnic, a ich siostrą była Tamar.   
\m
\v 10 Synem Salomona \add był\add* Roboam, a jego synem Abia, jego synem Asa, jego synem Jehoszafat;   
\m
\v 11 Jego synem Joram, jego synem Achazjasz, jego synem Joasz;   
\m
\v 12 Jego synem Amazjasz, jego synem Azariasz, jego synem Jotam;   
\m
\v 13 Jego synem Achaz, jego synem Ezechiasz, jego synem Manasses;   
\m
\v 14 Jego synem Amon, jego synem Jozjasz;   
\m
\v 15 A synami Jozjasza \add byli\add*: pierworodny Jochanan, drugi Joakim, trzeci Sedekiasz, czwarty Szallum.   
\m
\v 16 Synowie Joakima: jego syn Jechoniasz i jego syn Sedekiasz.   
\m
\v 17 Synowie Jechoniasza: Assir, jego syn Szealatiel;   
\m
\v 18 Malkiram, Pedajasz, Szeneassar, Jekamiasz, Hoszama i Nedabiasz.   
\m
\v 19 Synowie Pedajasza: Zorobabel, Szimei. Synowie Zorobabela: Meszullam i Chananiasz, a ich siostra – Szelomit;   
\m
\v 20 I Chaszuba, Ohel, Berechiasz, Chasadiasz i Juszabchesed – pięciu.   
\m
\v 21 Synowie Chananiasza: Pelatiasz i Jesajasz. Synowie Refajasza, synowie Arnana, synowie Obadiasza, synowie Szekaniasza.   
\m
\v 22 Synowie Szekaniasza: Szemajasz; a synowie Szemajasza: Chattusz, Jigal, Bariach, Neariasz i Szafat – sześciu.   
\m
\v 23 Synowie Neariasza: Elioenaj, Ezechiasz i Azrikam – trzech.   
\m
\v 24 Synowie Elioenaja: Hodawiasz, Eliaszib, Pelajasz, Akkub, Jochanan, Delajasz, Anani – siedmiu.   
\c 4  
\m
\v 1 Synowie Judy: Peres, Chesron, Karmi, Chur i Szobal.   
\m
\v 2 A Reajasz, syn Szobala, spłodził Jachata, a Jachat spłodził Achumaja i Lahada. To są rody Soreatytów.   
\m
\v 3 A ci pochodzą od ojca Etama: Jizreel, Jiszma i Jidbasz, a ich siostra miała na imię Haselelponi.   
\m
\v 4 Penuel \add był\add* ojcem Gedora, a Ezer – ojcem Chuszy. To są synowie Chura, pierworodnego Efraty, ojca Betlejema.   
\m
\v 5 A Aszur, ojciec Tekoa, miał dwie żony: Chelę i Naarę.   
\m
\v 6 I Naara urodziła mu Achuzama, Chefera, Temniego i Achasztariego. Ci \add byli\add* synami Naary.   
\m
\v 7 Synowie Cheli: Seret, Jesochar i Etnan.   
\m
\v 8 A Koz spłodził Anuba, Zobeba i rody Acharchela, syna Haruma.   
\m
\v 9 A Jabes był bardziej poważany niż jego bracia. Jego matka dała mu na imię Jabes, mówiąc: Ponieważ urodziłam go w bólu.   
\m
\v 10 I Jabes wzywał Boga Izraela, mówiąc: Obyś mi naprawdę błogosławił i rozszerzył moje granice, oby twoja ręka była ze mną, obyś zachował \add mnie\add* od zła, abym nie był utrapiony. I Bóg spełnił to, o co go prosił.   
\m
\v 11 A Kelub, brat Szuchy, spłodził Mechira, który był ojcem Esztona.   
\m
\v 12 A Eszton spłodził Betrafę, Paseacha i Techinnę, ojca Irnachasza. To \add są\add* mężczyźni z Rechy.   
\m
\v 13 Synowie Kenaza: Otniel i Serajasz, a synowie Otniela: Chatat \add i Meonotaj\add*.   
\m
\v 14 Meonotaj spłodził Ofrę. Serajasz zaś spłodził Joaba, ojca Charaszimów mieszkających w dolinie – byli bowiem rzemieślnikami.   
\m
\v 15 Synowie Kaleba, syna Jefunnego: Iru, Ela i Naam. A synem Eli był Kenaz.   
\m
\v 16 Synowie Jehalleleela: Zif, Zifa, Tiria i Asareel.   
\m
\v 17 Synowie Ezry: Jeter, Mered, Efer i Jalon. \add A żona Mereda\add* urodziła Miriama, Szammaja i Iszbacha, ojca Esztemoi.   
\m
\v 18 Jego żona Jehudaja urodziła Jereda, ojca Gedora, Chebera, ojca Soko, i Jekutiela, ojca Zanoacha. To \add są\add* synowie Bitii, córki faraona, którą pojął za żonę Mered.   
\m
\v 19 Synowie jego żony Hodijji, siostry Nahama, ojca Keili: Garmity i Esztemoa, Maakatyta.   
\m
\v 20 Synowie Szimona: Amnon, Rinna, Benchanan i Tilon. A synowie Jisziego: Zochet i Benzochet.   
\m
\v 21 Synowie Szeli, syna Judy: Er, ojciec Leki, Laada, ojciec Mareszy i tych rodów, które wytwarzały bisior w domu Aszbea;   
\m
\v 22 Jokim i mężczyźni Kozeby oraz Joasz i Saraf, którzy panowali w Moabie, a także Jaszubilechem. To \add są\add* dawne wydarzenia.   
\m
\v 23 Byli oni garncarzami i mieszkali w sadach i między płotami. Mieszkali tam przy królu i pracowali dla niego.   
\m
\v 24 Synowie Symeona: Nemuel, Jamin, Jarib, Zerach i Saul.   
\m
\v 25 Jego syn Szallum, jego syn Mibsam, jego syn Miszma.   
\m
\v 26 A synowie Miszmy: jego syn Chamuel, jego syn Zakkur, jego syn Szimei.   
\m
\v 27 Szimei miał szesnastu synów i sześć córek, lecz jego bracia nie mieli wielu synów i wszystkie ich rody nie były tak liczne jak \add rody\add* synów Judy.   
\m
\v 28 Mieszkali oni w Beer-Szebie, Molada i w Chasar-Szual;   
\m
\v 29 W Bilha, Esem i Tolad;   
\m
\v 30 W Betuel, Chorma i Siklag;   
\m
\v 31 W Bet-Markabot, Chasar-Susim, Bet-Birei i Szaaraim. To były ich miasta aż do panowania Dawida.   
\m
\v 32 A ich wioskami \add były\add*: Etam, Ain, Rimmon, Token i Aszan, pięć miast;   
\m
\v 33 Oraz wszystkie ich wioski \add położone\add* dokoła tych miast aż do Baal. To były ich miejsca zamieszkania i spisy ich rodów.   
\m
\v 34 Meszobab, Jamlek i Josza, syn Amazjasza;   
\m
\v 35 Joel i Jehu, syn Joszibiasza, syna Serajasza, syna Asiela;   
\m
\v 36 I Elioenaj, Jaakoba, Jeszochajasz, Asajasz, Adiel, Jesimiel i Benajasz;   
\m
\v 37 Ziza, syn Szifiego, syna Allona, syna Jedajasza, syna Szimriego, syna Semajasza.   
\m
\v 38 Ci wymienieni imiennie byli naczelnikami w swoich rodach, a rodziny ich ojców bardzo się rozrosły.   
\m
\v 39 I dotarli aż do wejścia do Gedor, aż na wschodnią stronę doliny, szukając pastwiska dla swych trzód.   
\m
\v 40 I znaleźli obfite i dobre pastwiska oraz ziemię obszerną, spokojną i bezpieczną. Tam bowiem mieszkali przedtem Chamici.   
\m
\v 41 Zapisani \add tu\add* imiennie przyszli za czasów Ezechiasza, króla Judy, zniszczyli ich namioty i przybytki, które się tam znajdowały, doszczętnie wygubili ich i osiedlili się na ich miejscu. Tam bowiem były pastwiska dla ich trzód.   
\m
\v 42  \add Niektórzy\add* z nich, pięciuset mężczyzn spośród synów Symeona, udali się na górę Seir, a ich przywódcami byli: Pelatiasz, Neariasz, Refajasz i Uzziel, synowie Jisziego.   
\m
\v 43 I pobili resztę ocalałych Amalekitów, i zamieszkali tam do dziś.   
\c 5  
\m
\v 1 Synowie Rubena, pierworodnego Izraela. Był on pierworodnym, ale ponieważ zbezcześcił łoże swego ojca, jego pierworództwo zostało dane synom Józefa, syna Izraela. Nie spisano więc rodowodu według pierworództwa.   
\m
\v 2 Juda bowiem był najpotężniejszy wśród swoich braci i od niego pochodził władca, lecz pierworództwo \add należało\add* do Józefa.   
\m
\v 3 Synami Rubena, pierworodnego Izraela, \add byli\add*: Henoch, Pallu, Chesron i Karmi.   
\m
\v 4 Synowie Joela: jego syn Szemajasz, jego syn Gog, jego syn Szimei;   
\m
\v 5 Jego syn Micheasz, jego syn Reajasz, jego syn Baal;   
\m
\v 6 Jego syn Beera, którego Tiglat-Pileser, król Asyrii, wziął do niewoli. On był księciem Rubenitów.   
\m
\v 7 Jego braćmi według swoich rodzin, gdy spisywano rodowody ich pokoleń, \add byli\add* naczelnicy: Jejel, Zachariasz;   
\m
\v 8 I Bela, syn Azaza, syna Szemy, syna Joela, który zamieszkiwał w Aroerze aż po Nebo i Baal-Meon.   
\m
\v 9 A na wschodzie zamieszkiwał aż do wejścia na pustkowie od rzeki Eufrat. Ich stada bowiem pomnożyły się w ziemi Gilead.   
\m
\v 10 Za czasów Saula prowadzili wojnę z Hagrytami, którzy zostali przez nich pokonani. Zamieszkali więc w ich namiotach w całej wschodniej \add części\add* Gileadu.   
\m
\v 11 A synowie Gada mieszkali naprzeciw nich w ziemi Baszanu, aż \add do\add* Salka.   
\m
\v 12 Joel \add był\add* zwierzchnikiem, potem Szafam, następnie Janaj i Szafat w Baszanie.   
\m
\v 13 A ich braćmi według domów swoich ojców \add byli\add*: Mikael, Meszullam, Szeba, Joraj, Jakan, Zija i Eber – siedmiu.   
\m
\v 14 Ci są synami Abichaila, syna Churiego, syna Jaroacha, syna Gileada, syna Mikaela, syna Jesziszaja, syna Jachdo, syna Buza;   
\m
\v 15 Achi, syn Abdiela, syna Guniego – głowa domu ich ojców.   
\m
\v 16 I mieszkali w Gileadzie, w Baszanie, w jego miasteczkach i na wszystkich pastwiskach Szaronu aż po ich krańce.   
\m
\v 17 Wszyscy oni spisani zostali według rodowodów za czasów Jotama, króla Judy, i za czasów Jeroboama, króla Izraela.   
\m
\v 18 Synów Rubena i Gada oraz połowy pokolenia Manassesa, dzielnych wojowników zdolnych do noszenia tarczy i miecza i do strzelania z łuku i wyćwiczonych w boju, było czterdzieści cztery tysiące siedmiuset sześćdziesięciu wyruszających do bitwy.   
\m
\v 19 Oni prowadzili wojnę z Hagrytami, z Jeturem, z Nafiszem i Nodabem;   
\m
\v 20 I otrzymali pomoc przeciwko nim. Wydano więc w ich ręce Hagrytów wraz ze wszystkimi, którzy z nimi byli. Podczas walki bowiem wołali do Boga, a \add on\add* ich wysłuchał, bo pokładali w nim ufność.   
\m
\v 21 I zabrali z ich stad: pięćdziesiąt tysięcy wielbłądów, dwieście pięćdziesiąt tysięcy owiec, dwa tysiące osłów, a ludzi – sto tysięcy.   
\m
\v 22 Wielu bowiem poległo, gdyż wojna ta \add wyszła\add* od Boga. I mieszkali na ich miejscu aż do uprowadzenia do niewoli.   
\m
\v 23 Ale synowie połowy pokolenia Manassesa mieszkali w tej ziemi i rozmnożyli się od Baszanu aż do Baal-Chermon i Seniru, i do góry Hermon.   
\m
\v 24 A oto \add są\add* naczelnicy domów ich ojców: Efer, Jiszi, Eliel, Azriel, Jeremiasz, Hodawiasz i Jachdiel, dzielni wojownicy, ludzie sławni, naczelnicy domu swoich ojców.   
\m
\v 25 Lecz zgrzeszyli przeciw Bogu swoich ojców i cudzołożyli, idąc za bogami narodów \add tej\add* ziemi, które Bóg zniszczył przed nimi.   
\m
\v 26 Wtedy Bóg Izraela pobudził ducha Pula, króla Asyrii, i ducha Tiglat-Pilesera, króla Asyrii, i uprowadził Rubenitów i Gadytów oraz połowę pokolenia Manassesa i zaprowadził ich do Chalach, do Chabor, do Hara i do rzeki Gozan; \add są tam\add* aż do dziś.   
\c 6  
\m
\v 1 Synowie Lewiego: Gerszom, Kehat i Merari.   
\m
\v 2 A synowie Kehata: Amram, Ishar, Chebron i Uzziel.   
\m
\v 3 A dzieci Amrama: Aaron, Mojżesz i Miriam. Synowie Aarona: Nadab, Abihu, Eleazar i Itamar.   
\m
\v 4 Eleazar spłodził Pinchasa, a Pinchas spłodził Abiszuę.   
\m
\v 5 Abiszua spłodził Bukkiego, a Bukki spłodził Uzziego.   
\m
\v 6 Uzzi spłodził Zerachiasza, a Zerachiasz spłodził Merajota.   
\m
\v 7 Merajot spłodził Amariasza, a Amariasz spłodził Achituba.   
\m
\v 8 Achitub spłodził Sadoka, a Sadok spłodził Achimaasa.   
\m
\v 9 Achimaas spłodził Azariasza, a Azariasz spłodził Jochanana.   
\m
\v 10 Jochanan spłodził Azariasza. On to sprawował urząd kapłański w świątyni, którą Salomon zbudował w Jerozolimie.   
\m
\v 11 Azariasz spłodził Amariasza, a Amariasz spłodził Achituba.   
\m
\v 12 Achitub spłodził Sadoka, a Sadok spłodził Szalluma.   
\m
\v 13 Szallum spłodził Chilkiasza, a Chilkiasz spłodził Azariasza.   
\m
\v 14 Azariasz spłodził Serajasza, a Serajasz spłodził Jehocadaka.   
\m
\v 15 A Jehocadak trafił \add do niewoli\add*, gdy PAN uprowadził Judę i Jerozolimę przez Nabuchodonozora.   
\m
\v 16 Synowie Lewiego: Gerszom, Kehat i Merari.   
\m
\v 17 A to \add są\add* imiona synów Gerszoma: Libni i Szimei.   
\m
\v 18 A synowie Kehata: Amram, Ishar, Chebron i Uzziel.   
\m
\v 19 Synowie Merariego: Machli i Muszi. A to są rody Lewitów według ich ojców.   
\m
\v 20 Od Gerszoma: jego syn Libni, jego syn Jachat, jego syn Zimma;   
\m
\v 21 Jego syn Joach, jego syn Iddo, jego syn Zerach, jego syn Jeatraj.   
\m
\v 22 Synowie Kehata: jego syn Amminadab, jego syn Korach, jego syn Assir;   
\m
\v 23 Jego syn Elkana, jego syn Ebiasaf, jego syn Assir;   
\m
\v 24 Jego syn Tachat, jego syn Uriel, jego syn Uzjasz, jego syn Saul.   
\m
\v 25 Synowie Elkany: Amasaj, Achimot i Elkana.   
\m
\v 26 Synowie Elkany: jego syn Sofaj, jego syn Nachat;   
\m
\v 27 Jego syn Eliab, jego syn Jerocham, jego syn Elkana.   
\m
\v 28 Synowie Samuela: pierworodny Waszni i Abiasz.   
\m
\v 29 Synowie Merariego: Machli, jego syn Libni, jego syn Szimei, jego syn Uzza;   
\m
\v 30 Jego syn Szimea, jego syn Chaggiasz, jego syn Asajasz.   
\m
\v 31 To są ci, których Dawid ustanowił do prowadzenia śpiewu w domu PANA, odkąd spoczęła \add tam\add* arka.   
\m
\v 32 I posługiwali śpiewem przed przybytkiem, \add czyli\add* Namiotem Zgromadzenia, aż Salomon zbudował dom PANA w Jerozolimie. Stawali do swojej służby według swego porządku.   
\m
\v 33 A oto ci, którzy stawali wraz ze swoimi synami: spośród synów Kehata – śpiewak Heman, syn Joela, syna Samuela;   
\m
\v 34 Syna Elkany, syna Jerochama, syna Eliela, syna Toacha;   
\m
\v 35 Syna Sufa, syna Elkany, syna Machata, syna Amasaja;   
\m
\v 36 Syna Elkany, syna Joela, syna Azariasza, syna Sofoniasza;   
\m
\v 37 Syna Tachata, syna Assira, syna Ebiasafa, syna Koracha;   
\m
\v 38 Syna Ishara, syna Kehata, syna Lewiego, syna Izraela.   
\m
\v 39 Oraz jego brat Asaf, który stawał po jego prawicy. Asaf, syn Berechiasza, syna Szimei;   
\m
\v 40 Syna Mikaela, syna Baasejasza, syna Malkiasza;   
\m
\v 41 Syna Etniego, syna Zeracha, syna Adajasza;   
\m
\v 42 Syna Etana, syna Zimmy, syna Szimejego;   
\m
\v 43 Syna Jachata, syna Gerszoma, syna Lewiego.   
\m
\v 44 A ich bracia, synowie Merariego, \add stawali\add* po lewej stronie: Etan, syn Kisziego, syna Abdiego, syna Malluka;   
\m
\v 45 Syna Chaszabiasza, syna Amaziasza, syna Chilkiasza.   
\m
\v 46 Syna Amsjego, syna Baniego, syna Szamera;   
\m
\v 47 Syna Mochliego, syna Musziego, syna Merariego, syna Lewiego.   
\m
\v 48 A ich bracia, Lewici, \add byli\add* ustanowieni do wszelkiej posługi w przybytku domu Boga.   
\m
\v 49 Aaron zaś i jego synowie palili kadzidło na ołtarzu całopalenia i na ołtarzu kadzenia, \add byli odpowiedzialni\add* za wszelką posługę w Miejscu Najświętszym i za dokonywanie przebłagania za Izraela według wszystkiego, co nakazał Mojżesz, sługa Boży.   
\m
\v 50 A oto synowie Aarona: jego syn Eleazar, jego syn Pinchas;   
\m
\v 51 Jego syn Abiszua, jego syn Bukki, jego syn Uzzi, jego syn Zerachiasz;   
\m
\v 52 Jego syn Merajot, jego syn Amariasz, jego syn Achitub;   
\m
\v 53 Jego syn Sadok, jego syn Achimaas.   
\m
\v 54 A to są ich mieszkania według ich wieży w ich obszarze, \add to jest\add* synów Aarona, według rodu Kehatytów. Był \add to\add* bowiem ich los.   
\m
\v 55 Oddano im Hebron w ziemi Judy wraz z pastwiskami dokoła niego;   
\m
\v 56 Lecz pola miasta i jego wsie dano Kalebowi, synowi Jefunnego.   
\m
\v 57 Synom Aarona zaś dano spośród miast Judy \add miasta\add* schronienia: Hebron, Libnę z jego pastwiskami, Jattir i Esztemoę wraz z ich pastwiskami;   
\m
\v 58 I Chilen z jego pastwiskami, Debir z jego pastwiskami;   
\m
\v 59 Aszan z jego pastwiskami i Bet-Szemesz z jego pastwiskami.   
\m
\v 60 A od pokolenia Beniamina: Geba z jego pastwiskami, Alemet z jego pastwiskami i Anatot z jego pastwiskami. Wszystkich ich miast było trzynaście według ich rodzin.   
\m
\v 61 A pozostałym synom Kehata, spośród rodziny tego pokolenia, przypadło losem dziesięć miast od połowy pokolenia Manassesa.   
\m
\v 62 A synom Gerszoma według ich rodzin przypadło od pokolenia Issachara, od pokolenia Aszera, od pokolenia Neftalego i od pokolenia Manassesa w Baszanie – trzynaście miast.   
\m
\v 63 Synom Merariego według ich rodzin przypadło losem od pokolenia Rubena, od pokolenia Gada i od pokolenia Zebulona – dwanaście miast.   
\m
\v 64 Synowie Izraela dali Lewitom te miasta wraz z ich pastwiskami.   
\m
\v 65 A dali przez los od pokolenia synów Judy, od pokolenia synów Symeona i od pokolenia synów Beniamina te miasta, którym nadali ich imiona.   
\m
\v 66 A ci, którzy pochodzili z rodu synów Kehata, mieli miasta w granicach pokolenia Efraima.   
\m
\v 67 Dano im z miast schronienia: Sychem z jego pastwiskami na górze Efraim i Gezer z jego pastwiskami;   
\m
\v 68 Jokmeam z jego pastwiskami, Bet-Choron z jego pastwiskami;   
\m
\v 69 Ajjalon z jego pastwiskami i Gat-Rimmon z jego pastwiskami.   
\m
\v 70 Od połowy pokolenia Manassesa: Aner z jego pastwiskami, Bileam z jego pastwiskami. \add Dano to\add* rodzinie pozostałych synów Kehata.   
\m
\v 71 Synom Gerszoma \add dano\add* od połowy pokolenia Manassesa Golan w Baszanie z jego pastwiskami i Asztarot z jego pastwiskami;   
\m
\v 72 Od pokolenia Issachara – Kedesz z jego pastwiskami, Daberat z jego pastwiskami;   
\m
\v 73 Ramot z jego pastwiskami i Anem z jego pastwiskami.   
\m
\v 74 Od pokolenia Aszera: Maszal z jego pastwiskami, Abdon z jego pastwiskami;   
\m
\v 75 Chukok z jego pastwiskami i Rechob z jego pastwiskami.   
\m
\v 76 Od pokolenia Neftalego: Kedesz w Galilei z jego pastwiskami, Chammon z jego pastwiskami i Kiriataim z jego pastwiskami.   
\m
\v 77 Pozostałym synom Merariego \add dano\add* od pokolenia Zebulona Rimmon z jego pastwiskami i Tabor z jego pastwiskami.   
\m
\v 78 A po drugiej stronie Jordanu koło Jerycha, na wschód od Jordanu, \add dano\add* od pokolenia Rubena: Beser na pustyni z jego pastwiskami, Jahazę z jej pastwiskami;   
\m
\v 79 Kedemot z jego pastwiskami i Mefaat z jego pastwiskami.   
\m
\v 80 Od pokolenia Gada: Ramot w Gileadzie z jego pastwiskami, Machanaim z jego pastwiskami;   
\m
\v 81 Cheszbon z jego pastwiskami i Jazer z jego pastwiskami.   
\c 7  
\m
\v 1 Synami Issachara \add byli\add*: Tola, Pua, Jaszub, Szimron – czterej.   
\m
\v 2 Synowie Tolego: Uzzi, Refajasz, Jeriel, Jachmaj, Jebsam i Szemuel – naczelnicy rodów Toli. \add Byli oni\add* dzielnymi wojownikami w swoich czasach. Ich liczba za czasów Dawida \add wynosiła\add* dwadzieścia dwa tysiące sześciuset.   
\m
\v 3 Synowie Uzziego: Izrachiasz, a synowie Izrachiasza: Mikael, Obadiasz, Joel i Jeszijasz, pięciu – wszyscy naczelnicy.   
\m
\v 4 A z nimi, według rodowodów, według domów ich ojców, były oddziały zbrojne do walki w liczbie trzydziestu sześciu tysięcy. Mieli bowiem wiele żon i synów.   
\m
\v 5 Ich bracia według wszystkich rodów Issachara, dzielni wojownicy, liczyli osiemdziesiąt siedem tysięcy, wszyscy spisani \add byli\add* według rodowodów.   
\m
\v 6  \add Synowie\add* Beniamina: Bela, Beker i Jediael, trzej.   
\m
\v 7 Synowie Beli: Eszbon, Uzzi, Uzziel, Jerimot i Iri, pięciu – naczelnicy domów ojców, dzielni wojownicy; spisani według rodowodu \add liczyli\add* dwadzieścia dwa tysiące trzydziestu czterech.   
\m
\v 8 Synowie Bekera: Zemira, Joasz, Eliezer, Elioenaj, Omri, Jerimot, Abiasz, Anatot i Alamet. Ci wszyscy byli synami Bekera.   
\m
\v 9 A spisani według swoich rodowodów, naczelnicy domów swoich ojców, dzielni wojownicy, \add liczyli\add* dwadzieścia tysięcy dwustu \add mężczyzn\add*.   
\m
\v 10 Synowie Jediaela: Bilhan, a synowie Bilhana: Jehusz, Beniamin, Ehud, Kenaana, Zetan, Tarszisz i Achiszachar.   
\m
\v 11 Ci wszyscy synowie Jediaela, naczelnicy rodów, dzielni wojownicy, \add liczyli\add* siedemnaście tysięcy dwustu wyruszających na wojnę do bitwy;   
\m
\v 12 Także Szuppim i Chuppim, synowie Ira, oraz Chuszim, synowie Achera.   
\m
\v 13 Synowie Neftalego: Jachasjel, Guni, Jeser i Szallum, synowie Bilhy.   
\m
\v 14 Synowie Manassesa: Asriel, którego urodziła mu żona (a jego nałożnica Aramejka urodziła Makira, ojca Gileada;   
\m
\v 15 A Makir wziął sobie za żonę siostrę Chuppima i Szuppima, która miała na imię Maaka); drugi syn miał na imię Selofchad. Selofchad zaś miał \add tylko\add* córki.   
\m
\v 16 Maaka, żona Makira, urodziła syna i nadała mu imię Peresz. Jego brat miał na imię Szeresz, a jego synami byli Ulam i Rekiem.   
\m
\v 17 Synowie Ulama: Bedon. To są synowie Gileada, syna Makira, syna Manassesa.   
\m
\v 18 Jego siostra Hammoleket urodziła Iszhoda, Abiezera i Machlę.   
\m
\v 19 Synowie Szemidy: Achian, Szekem, Likchi i Aniam.   
\m
\v 20 Synowie Efraima: Szutelach, jego syn Bered, jego syn Tachat, jego syn Elada, jego syn Tachat;   
\m
\v 21 Jego syn Zabad, jego syn Szutelach, a także Eser i Elad, których zabili ludzie z Gat urodzeni w tej ziemi. Wtargnęli bowiem, aby zabrać ich stada.   
\m
\v 22 Ich ojciec Efraim opłakiwał \add ich\add* przez wiele dni, a jego bracia przyszli, aby go pocieszyć.   
\m
\v 23 Potem obcował ze swoją żoną, a ona poczęła i urodziła syna, i nadał mu imię Beria, ponieważ stało się nieszczęście w jego domu.   
\m
\v 24 Jego córką \add była\add* Szeera, która zbudowała Bet-Choron dolne i górne oraz Uzen-Szeera.   
\m
\v 25 I jego syn Refach, i Reszef, a jego syn Telach, jego syn Tachan;   
\m
\v 26 Jego syn Ladan, jego syn Ammihud, jego syn Eliszama;   
\m
\v 27 Jego syn Nun, jego syn Jozue.   
\m
\v 28 A ich posiadłości i miejsca zamieszkania to Betel i należące do niego miejscowości, na wschód – Naaran, a na zachód – Gezer i należące do niego miejscowości, a także Sychem i należące do niego miejscowości; aż do Gazy i należących do niej miejscowości.   
\m
\v 29 I aż do granic synów Manassesa, które stanowiły Bet-Szean i należące do niego miejscowości, Tanak i należące do niego miejscowości, Megiddo i należące do niego miejscowości oraz Dor i należące do niego miejscowości. W nich mieszkali synowie Józefa, syna Izraela.   
\m
\v 30 Synowie Aszera: Jimna, Jiszwa, Jiszwi, Beria i Sera, ich siostra.   
\m
\v 31 Synowie Berii: Cheber i Malkiel, który \add jest\add* ojcem Birzaita.   
\m
\v 32 A Cheber spłodził Jafleta, Szomera, Chotama oraz ich siostrę Szuę.   
\m
\v 33 Synowie Jafleta: Pasak, Bimhal i Aszwat. To \add są\add* synowie Jafleta.   
\m
\v 34 Synowie Szomera: Achi, Rohga, Jechubba i Aram.   
\m
\v 35 Synowie jego brata Chelema: Sofach, Jimna, Szelesz i Amal.   
\m
\v 36 Synowie Sofacha: Suach, Charnefer, Szual, Beri, Jimra;   
\m
\v 37 Beser, Hod, Szamma, Szilsza, Jitran i Beera.   
\m
\v 38 Synowie Jetera: Jefunne, Pispa i Ara.   
\m
\v 39 Synowie Ulli: Arach, Channiel i Risja.   
\m
\v 40 Ci wszyscy \add to\add* synowie Aszera, naczelnicy rodów, wyborowi i dzielni wojownicy, pierwsi wśród książąt. Ich liczba spisana według rodowodu wynosiła dwadzieścia sześć tysięcy zdolnych do walki.   
\c 8  
\m
\v 1 Beniamin spłodził Belę, swego pierworodnego, Aszbela – drugiego, Achracha – trzeciego;   
\m
\v 2 Nocha – czwartego, Rafa – piątego.   
\m
\v 3 Synami Beli \add byli\add*: Addar, Gera, Abihud;   
\m
\v 4 Abiszua, Naaman, Achoach;   
\m
\v 5 Gera, Szefufan i Huram.   
\m
\v 6 Oto synowie Ehuda – byli oni naczelnikami rodów mieszkających w Geba i zostali przesiedleni do Manachat;   
\m
\v 7 Byli to: Naaman, Achiasz i Gera. On ich przesiedlił i potem spłodził Uzzę i Ahiuda.   
\m
\v 8 A Sacharaim spłodził \add dzieci\add* w krainie Moabu po odprawieniu swoich żon Chuszimy i Baary.   
\m
\v 9 Spłodził więc ze swojej żony Chodeszy Jobaba, Sibię, Meszę, Malkoma;   
\m
\v 10 Jeusa, Sakiasza i Mirmę. Ci \add byli\add* jego synami, naczelnikami rodów.   
\m
\v 11 Z Chuszimy spłodził Abituba i Elpaala.   
\m
\v 12 Synowie Elpaala: Eber, Miszam i Szemed, który zbudował Ono i Lod oraz należące do niego miejscowości;   
\m
\v 13 A także Beria i Szema, którzy \add byli\add* naczelnikami rodów mieszkających w Ajjalonie. To oni wypędzili mieszkańców Gat.   
\m
\v 14 A Achio, Szaszak, Jeremot;   
\m
\v 15 Zebadiasz, Arad, Eder;   
\m
\v 16 Mikael, Jiszpa i Jocha – \add byli to\add* synowie Berii.   
\m
\v 17 A Zebadiasz, Meszullam, Chiszki, Cheber;   
\m
\v 18 Jiszmeraj, Jiszlia i Jobab – \add byli\add* synami Elpaala.   
\m
\v 19 A Jakim, Zikri, Zabdi;   
\m
\v 20 Elioenaj, Silletaj, Eliel;   
\m
\v 21 Adajasz, Berajasz, Szimrat – to synowie Szimejego.   
\m
\v 22 A Jiszpan, Eber, Eliel;   
\m
\v 23 Abdon, Zikri, Chanan;   
\m
\v 24 Chananiasz, Elam i Antotiasz;   
\m
\v 25 Jifdejasz i Penuel – to synowie Szaszaka.   
\m
\v 26 A Szamszeraj, Szechariasz, Ataliasz;   
\m
\v 27 Jaareszjasz, Eliasz i Zikri – to synowie Jerochama.   
\m
\v 28 Ci \add byli\add* naczelnikami rodów, przywódcami według swoich rodowodów, a zamieszkali w Jerozolimie.   
\m
\v 29 W Gibeonie mieszkał ojciec Gibeona, a jego żona miała na imię Maaka.   
\m
\v 30 Jego pierworodnym synem \add był\add* Abdon, a następni to: Sur, Kisz, Baal, Nadab;   
\m
\v 31 Gedor, Achio i Zakir.   
\m
\v 32 Miklot spłodził Szimeę. Oni także mieszkali ze swoimi braćmi w Jerozolimie, naprzeciw swoich braci.   
\m
\v 33 Ner spłodził Kisza, a Kisz spłodził Saula, Saul zaś spłodził Jonatana, Malkiszuę, Abinadaba i Eszbaala.   
\m
\v 34 Synem Jonatana \add był\add* Meribbaal, Meribbaal zaś spłodził Micheasza.   
\m
\v 35 Synowie Micheasza: Piton, Melek, Tarea i Achaz.   
\m
\v 36 Achaz spłodził Jehoaddę, a Jehoadda spłodził Alemeta, Azmaweta i Zimriego, a Zimri spłodził Mosę;   
\m
\v 37 Mosa spłodził Bineę, jego synem był Rafa, jego synem był Eleasa, jego synem był Asel.   
\m
\v 38 Asel miał sześciu synów, a oto ich imiona: Azrikam, Bokru, Izmael, Szeariasz, Obadiasz i Chanan. Ci wszyscy byli synami Asela.   
\m
\v 39 Synowie jego brata Eszeka: Ulam, jego pierworodny, Jeusz – drugi, Elifelet – trzeci;   
\m
\v 40 Synowie Ulama byli dzielnymi wojownikami, sprawnymi łucznikami, a mieli wielu synów i wnuków, razem – stu pięćdziesięciu. Ci wszyscy \add pochodzili\add* z synów Beniamina.   
\c 9  
\m
\v 1 Tak wszyscy Izraelici byli spisani w rodowodach, a oto zostały one zapisane w księdze królów Izraela i Judy, \add a\add* ci zostali uprowadzeni do Babilonu z powodu swego przestępstwa.   
\m
\v 2 Pierwszymi mieszkańcami, którzy weszli do swych posiadłości w swoich miastach, byli Izraelici, kapłani, Lewici i Netinici.   
\m
\v 3 W Jerozolimie mieszkali spośród synów Judy, Beniamina, Efraima i Manassesa:   
\m
\v 4 Utaj, syn Ammihuda, syna Omriego, syna Imriego, syna Baniego, z synów Peresa, syna Judy.   
\m
\v 5 Z Szilonitów: pierworodny Asajasz i jego synowie.   
\m
\v 6 Z synów Zeracha: Jeuel i ich braci, sześciuset dziewięćdziesięciu.   
\m
\v 7 Z synów Beniamina: Sallu, syn Meszullama, syna Hodawiasza, syna Hassenuy;   
\m
\v 8 I Jibnejasz, syn Jerochama, Ela, syn Uzziego, syna Mikriego, i Meszullam, syn Szefatiasza, syna Reuela, syna Jibniasza.   
\m
\v 9 Ich braci według rodowodów \add było\add* dziewięćset pięćdziesięciu sześciu. Ci wszyscy \add byli\add* naczelnikami rodów według domów swoich ojców.   
\m
\v 10 Z kapłanów: Jedajasz, Jehojarib, Jakin;   
\m
\v 11 I Azariasz, syn Chilkiasza, syna Meszullama, syna Sadoka, syna Merajota, syna Achituba, przełożonego domu Bożego;   
\m
\v 12 I Adajasz, syn Jerochama, syna Paszchura, syna Malkiasza, i Maasaj, syn Adiela, syna Jachzery, syna Meszullama, syna Meszillemita, syna Immera;   
\m
\v 13 Ich braci, naczelników swoich rodów, \add było\add* tysiąc siedmiuset sześćdziesięciu, ludzi zdolnych do pełnienia służby w domu Bożym.   
\m
\v 14 A z Lewitów: Szemejasz, syn Chaszuba, syna Azrikama, syna Chaszabiasza, z synów Merariego;   
\m
\v 15 I Bakbakar, Cheresz, Galal, Mattaniasz, syn Micheasza, syna Zikriego, syna Asafa;   
\m
\v 16 I Obadiasz, syn Szemajasza, syna Galala, syna Jedutuna, i Berechiasz, syn Asy, syna Elkany, który mieszkał we wsiach Netofatytów.   
\m
\v 17 A odźwierni: Szallum, Akkub, Talmon, Achiman i ich bracia. Szallum \add był ich\add* zwierzchnikiem;   
\m
\v 18  \add Który\add* aż dotąd \add stawał\add* przy bramie królewskiej od wschodu. Ci byli odźwiernymi w obozach synów Lewiego.   
\m
\v 19 Szallum, syn Korego, syna Ebiazafa, syna Koracha, i jego bracia z domu jego ojca, Korachici, pełnili służbę, \add byli\add* stróżami progów namiotu, a ich ojcowie byli stróżami wejścia do obozu PANA.   
\m
\v 20 Pinchas, syn Eleazara, był niegdyś zwierzchnikiem nad nimi, a PAN był z nim.   
\m
\v 21 Zachariasz, syn Meszelemiasza, \add był\add* odźwiernym przy wejściu do Namiotu Zgromadzenia.   
\m
\v 22 Wszystkich wybranych na odźwiernych przy bramach było dwustu dwunastu. Byli oni policzeni według ich rodowodu w swoich osiedlach, a ustanowił ich Dawid i Samuel, widzący.   
\m
\v 23 Oni więc i ich synowie \add czuwali\add* nad bramami domu PANA, w domu namiotu, jako stróże.   
\m
\v 24 Odźwierni znajdowali się z czterech stron: od wschodu, od zachodu, od północy i od południa.   
\m
\v 25 Ich bracia zaś, \add mieszkający\add* w swoich osiedlach, przychodzili co siódmy dzień, w swoich porach, aby \add być\add* z nimi.   
\m
\v 26 Czterej bowiem naczelni odźwierni pełnili stałą służbę. \add Byli\add* to Lewici \add odpowiedzialni\add* za komnaty i skarbiec domu Bożego;   
\m
\v 27 I nocowali dokoła domu Bożego, gdyż do nich należała straż i obowiązek otwierania \add go\add* każdego ranka.   
\m
\v 28  \add Niektórzy\add* z nich mieli pieczę nad naczyniami do służby, by je wnosić i wynosić w tej samej liczbie.   
\m
\v 29  \add Inni\add* spośród nich byli ustanowieni \add do opieki\add* nad naczyniami i przyborami Miejsca Najświętszego – nad mąką pszenną, winem, oliwą, kadzidłem i wonnościami.   
\m
\v 30 A niektórzy z synów kapłanów sporządzali olejki z wonności.   
\m
\v 31 Mattitiasz, spośród Lewitów, pierworodny Szalluma Korachity, był przełożonym nad tym, co przygotowane w patelniach.   
\m
\v 32  \add Niektórzy\add* ich bracia spośród synów Kehata \add byli\add* ustanowieni \add do opieki\add* nad chlebami pokładnymi, aby \add je\add* przygotowywać w każdy szabat.   
\m
\v 33 Ci \add byli\add* śpiewakami, naczelnikami rodów Lewitów, którzy mieszkają w komnatach; byli wolni od innych zajęć, gdyż we dnie i w nocy zajmowali się tą służbą.   
\m
\v 34 Byli oni naczelnikami rodów Lewitów, naczelnikami według swoich rodowodów, a mieszkali w Jerozolimie.   
\m
\v 35 W Gibeonie mieszkał Jejel, ojciec Gibeona, a jego żona miała na imię Maaka;   
\m
\v 36 A jego synem pierworodnym był Abdon, a następni to: Sur, Kisz, Baal, Neer, Nadab;   
\m
\v 37 I Gedor, Achio, Zachariasz, i Miklot.   
\m
\v 38 A Miklot spłodził Szimmeama. Tamci również mieszkali ze swoimi braćmi w Jerozolimie naprzeciw swoich braci.   
\m
\v 39 Neer spłodził Kisza, a Kisz spłodził Saula, a Saul spłodził Jonatana, Malkiszuę, Abinadaba i Eszbaala.   
\m
\v 40 Synem Jonatana \add był\add* Meribbaal, a Meribbaal spłodził Micheasza.   
\m
\v 41 Synowie zaś Micheasza to: Piton, Melek, Tarea i \add Achaz\add*.   
\m
\v 42 Achaz spłodził Jarę, a Jara spłodził Alemeta, Azmaweta i Zimriego, a Zimri spłodził Mosę.   
\m
\v 43 Mosa spłodził Bineę, a jego synem \add był\add* Rafa, jego synem \add był\add* Elasa, jego synem \add był\add* Asel.   
\m
\v 44 Asel miał sześciu synów, a oto ich imiona: Azrikam, Bokru, Izmael, Szeariasz, Obadiasz i Chanan. Ci \add byli\add* synami Asela.   
\c 10  
\m
\v 1 Gdy Filistyni walczyli z Izraelem, Izraelici uciekli przed nimi i padli zabici na górze Gilboa.   
\m
\v 2 I Filistyni ścigali Saula i jego synów, i zabili Jonatana, Abinadaba i Malkiszuę, synów Saula.   
\m
\v 3 A gdy rozgorzała bitwa przeciw Saulowi, łucznicy trafili w niego i został przez nich ciężko zraniony.   
\m
\v 4 Wtedy Saul powiedział do swego giermka: Dobądź swój miecz i przebij mnie nim, aby nie przyszli ci nieobrzezani i nie znęcali się nade mną. Ale jego giermek nie chciał \add tego zrobić\add*, ponieważ bardzo się bał. Saul więc wziął miecz i sam rzucił się na niego.   
\m
\v 5 A gdy jego giermek zobaczył, że Saul umarł, rzucił się i on na swój miecz i umarł.   
\m
\v 6 Tak umarli Saul i jego trzej synowie, a cały jego dom zginął razem z nim.   
\m
\v 7 A gdy wszyscy Izraelici, którzy \add mieszkali\add* w dolinie, zobaczyli, że \add Izraelici\add* uciekli oraz że Saul i jego synowie umarli, opuścili swoje miasta i uciekli. Przyszli więc Filistyni i mieszkali w nich.   
\m
\v 8 Kiedy nazajutrz Filistyni przyszli, aby złupić zabitych, znaleźli Saula i jego synów poległych na górze Gilboa.   
\m
\v 9 Obdarli go więc \add z szat\add*, wzięli jego głowę i zbroję i rozesłali po całej ziemi filistyńskiej, aby ogłosić radosną wieść swoim bożkom i swojemu ludowi.   
\m
\v 10 Jego zbroję położyli w domu swoich bogów, a jego głowę powiesili w świątyni Dagona.   
\m
\v 11 Kiedy wszyscy mieszkańcy Jabesz-Gilead usłyszeli o wszystkim, co Filistyni uczynili Saulowi;   
\m
\v 12 Powstali wszyscy waleczni mężczyźni, wzięli ciało Saula oraz ciała jego synów, przynieśli \add je\add* do Jabesz i pogrzebali ich kości pod dębem w Jabesz. Potem pościli przez siedem dni.   
\m
\v 13 Tak umarł Saul z powodu swojego przestępstwa, które popełnił przeciwko PANU i przeciwko słowu PANA, którego nie przestrzegał, oraz za to, że szukał rady czarownika;   
\m
\v 14 A nie radził się PANA. \add PAN\add* zabił go więc i przeniósł królestwo na Dawida, syna Jessego.   
\c 11  
\m
\v 1 Wtedy cały Izrael zebrał się przy Dawidzie w Hebronie, mówiąc: Oto jesteśmy twoją kością i twoim ciałem.   
\m
\v 2 Już przedtem, gdy jeszcze Saul był królem, wyprowadzałeś i wprowadzałeś Izraela. I PAN, twój Bóg, powiedział ci: Ty będziesz pasł mój lud Izraela i ty będziesz wodzem nad moim ludem, Izraelem.   
\m
\v 3 Przyszli więc wszyscy starsi Izraela do króla do Hebronu i Dawid zawarł z nimi przymierze w Hebronie przed PANEM. Namaścili Dawida na króla nad Izraelem zgodnie ze słowem PANA, \add które wypowiedział\add* przez Samuela.   
\m
\v 4 I Dawid wyruszył wraz z całym Izraelem do Jerozolimy, to jest Jebus; mieszkańcami tej ziemi byli Jebusyci.   
\m
\v 5 Wtedy mieszkańcy Jebus powiedzieli do Dawida: Nie wejdziesz tutaj. Dawid jednak zdobył twierdzę Syjon, to \add jest\add* miasto Dawida.   
\m
\v 6 Potem Dawid powiedział: Kto pierwszy pokona Jebusytów, będzie wodzem i naczelnikiem. Wystąpił więc jako pierwszy Joab, syn Serui, i został wodzem.   
\m
\v 7 I Dawid zamieszkał w twierdzy, dlatego nazwano ją miastem Dawida.   
\m
\v 8 Rozbudował miasto wokoło, od Millo, a Joab odbudował resztę miasta.   
\m
\v 9 A Dawid stawał się coraz potężniejszy, ponieważ PAN zastępów \add był\add* z nim.   
\m
\v 10 Oto naczelnicy spośród dzielnych wojowników, których miał Dawid i którzy dzielnie starali się z nim o jego królestwo wraz z całym Izraelem, aby uczynić go królem zgodnie ze słowem PANA o Izraelu.   
\m
\v 11 A oto spis dzielnych wojowników, których miał Dawid: Jaszobeam, syn Chakmoniego, naczelnik dowódców. On to podniósł swoją włócznię przeciw trzystu i pobił ich za jednym razem.   
\m
\v 12 Po nim Eleazar, syn Dodo, Achochita, jeden spośród trzech dzielnych.   
\m
\v 13 Był on z Dawidem w Pas-Dammim, gdzie Filistyni zebrali się do walki. Było tam pole pełne jęczmienia, a lud uciekał przed Filistynami.   
\m
\v 14 I stanęli na środku tego pola, obronili je i pobili Filistynów. Tak dokonał PAN wielkiego wybawienia.   
\m
\v 15 A trzej spośród trzydziestu dowódców zeszli po skale do Dawida, do jaskini Adullam, podczas gdy wojsko Filistynów obozowało w dolinie Rafaim.   
\m
\v 16 Dawid bowiem \add przebywał\add* w tym czasie w miejscu obronnym, a załoga Filistynów \add znajdowała się\add* wtedy w Betlejem.   
\m
\v 17 Dawid poczuł wówczas pragnienie i powiedział: Oby ktoś dał mi się napić wody ze studni w Betlejem, która jest przy bramie!   
\m
\v 18 Wtedy ci trzej przebili się przez wojsko Filistynów i zaczerpnęli wody ze studni w Betlejem, która jest przy bramie. Zabrali ją i przynieśli do Dawida. Dawid jednak nie chciał jej pić, ale wylał ją \add na ofiarę\add* dla PANA.   
\m
\v 19 I powiedział: Niech PAN mnie strzeże \add od tego\add*, abym miał to uczynić. Czy mam pić krew tych ludzi, którzy narażali swoje życie? Przynieśli bowiem \add wodę\add* z narażeniem swego życia. I nie chciał jej pić. Tych \add dzieł\add* dokonali ci trzej najdzielniejsi.   
\m
\v 20 A Abiszaj, brat Joaba, stał na czele tych trzech. On to podniósł swoją włócznię przeciw trzystu i pobił \add ich\add*, i miał sławę wśród tych trzech.   
\m
\v 21 Wśród tych trzech był on sławniejszy od pozostałych dwóch i był ich dowódcą. Nie dorównał jednak \add tamtym\add* trzem.   
\m
\v 22 Benajasz, syn Jehojady, syn walecznego męża z Kabseela, który dokonał wielu czynów, zabił dwóch wojowników z Moabu. On też zszedł do jamy i zabił lwa w śnieżnym dniu.   
\m
\v 23 Zabił również Egipcjanina, człowieka o wzroście pięciu łokci. Egipcjanin miał w ręku włócznię, \add grubą\add* jak wał tkacki. On zaś zszedł do niego z kijem, wyrwał włócznię z ręki Egipcjanina i zabił go jego własną włócznią.   
\m
\v 24 Tego dokonał Benajasz, syn Jehojady, i miał sławę wśród tych trzech dzielnych.   
\m
\v 25 Wśród trzydziestu był on sławny, ale nie dorównał tamtym trzem. I Dawid postawił go na czele swojej straży przybocznej.   
\m
\v 26 Dzielnymi wojownikami wojska \add byli\add*: Asahel, brat Joaba, Elchanan, syn Dodo z Betlejem;   
\m
\v 27 Szammot z Harodi, Cheles Pelonita;   
\m
\v 28 Ira, syn Ikkesza, Tekoitczyk, Abiezer Anatotczyk;   
\m
\v 29 Sibbekaj Chuszatyta, Ilaj Achochita;   
\m
\v 30 Maharaj Netofatyta, Cheled, syn Baany, Netofatyta;   
\m
\v 31 Itaj, syn Ribaja, z Gibea synów Beniamina, Benajasz Piratończyk;   
\m
\v 32 Churaj z potoków Gaasz, Abiel Arbatczyk;   
\m
\v 33 Azmawet Bacharumczyk, Eliachba Szaalbończyk;   
\m
\v 34 Synowie Chaszema Gisończyka, Jonatan, syn Szagiego, Hararyta;   
\m
\v 35 Achiam, syn Sakara, Hararyta, Elifal, syn Ura;   
\m
\v 36 Chefer Mekeratyta, Achiasz Pelonita;   
\m
\v 37 Chesro Karmelita, Naaraj, syn Ezbaja;   
\m
\v 38 Joel, brat Natana, Mibchar, syn Hagriego;   
\m
\v 39 Selek Ammonita, Nacharaj Berotczyk, giermek Joaba, syna Serui;   
\m
\v 40 Ira Jitryta, Gareb Jitryta;   
\m
\v 41 Uriasz Chetyta, Zabad, syn Achlaja;   
\m
\v 42 Adina, syn Szizy, Rubenita, naczelnik Rubenitów, a wraz z nim trzydziestu;   
\m
\v 43 Chanan, syn Maaki, Joszafat Mitnita;   
\m
\v 44 Uziasz Aszteratczyk, Szama i Jejel, synowie Chotamy Aroerczyka;   
\m
\v 45 Jediael, syn Szimriego, i jego brat Jocha, Tizyta;   
\m
\v 46 Eliel Machawita, Jeribaj i Joszawiasz, synowie Elnaama, Jitma Moabita;   
\m
\v 47 Eliel, Obed i Jaasiel Mezobata.   
\c 12  
\m
\v 1 Oto ci, którzy przyszli do Dawida w Siklag, gdy ukrywał się przed Saulem, synem Kisza. Należeli oni do dzielnych wojowników, którzy wspierali go w walce.   
\m
\v 2 Byli uzbrojeni w łuki i \add potrafili\add* prawą i lewą ręką \add miotać\add* kamieniami i strzelać z łuku, \add a wywodzili się\add* z braci Saula, z Beniamina.   
\m
\v 3 Naczelnikiem \add był\add* Achiezer, potem Joasz, synowie Szemajasza Gibeatczyka, Jezjel i Pelet, synowie Azmaweta, Beraka i Jehu Anatotczyk;   
\m
\v 4 I Jiszmaja Gibeonita, dzielny wojownik spośród trzydziestu i dowodzący trzydziestoma, Jeremiasz, Jachaziel, Jochanan i Jozabad Gederatyta;   
\m
\v 5 Eluzaj, Jerimot, Bealiasz, Szemariasz i Szefatiasz Charufita;   
\m
\v 6 Elkana, Jiszijasz, Azareel, Joezer i Jaszobam – Korachici;   
\m
\v 7 Joela i Zebadiasz, synowie Jerochama z Gedoru.   
\m
\v 8 Z \add pokolenia\add* Gada w warowni na pustyni do Dawida przyłączyli się dzielni wojownicy, żołnierze sprawni w boju, noszący tarczę i dzidę, ich twarze \add były\add* jak twarze lwów, a \add byli\add* zwinni jak sarny w górach;   
\m
\v 9 Ezer pierwszy, Obadiasz drugi, Eliab trzeci;   
\m
\v 10 Miszmanna czwarty, Jeremiasz piąty;   
\m
\v 11 Attaj szósty, Eliel siódmy;   
\m
\v 12 Jochanan ósmy, Elzabad dziewiąty;   
\m
\v 13 Jeremiasz dziesiąty, Makbanaj jedenasty.   
\m
\v 14  \add Wywodzili się\add* oni z synów Gada, dowódcy wojska: najmniejszy był nad stu, a największy – nad tysiącem.   
\m
\v 15 To są ci, którzy przeszli przez Jordan w pierwszym miesiącu, kiedy wylał na wszystkie brzegi, i zmusili do ucieczki wszystkich \add mieszkańców\add* dolin na wschód i na zachód.   
\m
\v 16 Do warowni do Dawida przyszli także \add niektórzy\add* z synów Beniamina i Judy.   
\m
\v 17 I Dawid wyszedł naprzeciw nich, i odpowiedział: Jeśli przyszliście do mnie w pokoju, aby mi pomóc, moje serce połączy się z wami. Lecz jeśli \add przyszliście\add*, aby mnie wydać moim wrogom, choć moje ręce są wolne od nieprawości, niech wejrzy w to Bóg naszych ojców i niech osądzi.   
\m
\v 18 Wtedy Duch ogarnął Amasaja, naczelnika dowódców, \add i powiedział\add*: Jesteśmy twoi, Dawidzie, i \add jesteśmy\add* z tobą, synu Jessego. Pokój, pokój tobie i pokój twoim pomocnikom! Gdyż tobie pomaga twój Bóg. Dawid więc przyjął ich i ustanowił dowódcami oddziałów.   
\m
\v 19  \add Z pokolenia\add* Manassesa niektórzy przyłączyli się do Dawida, gdy wyruszył z Filistynami na wojnę przeciwko Saulowi. Lecz nie pomogli im, gdyż książęta Filistynów po naradzie odesłali go, mówiąc: Ten za cenę naszych głów wróci do swego pana Saula.   
\m
\v 20 Gdy szedł do Siklag, przyłączyli się do niego z Manassesa: Adnach, Jozabad, Jediael, Mikael, Jozabad, Elihu i Silletaj, dowódcy nad tysiącami w \add pokoleniu\add* Manassesa.   
\m
\v 21 Oni to pomogli Dawidowi przeciw bandzie, bo byli wszyscy dzielnymi wojownikami i dowódcami wojska.   
\m
\v 22 W tym czasie dzień za dniem \add ludzie\add* przybywali do Dawida, aby mu pomagać, aż \add powstało\add* wielkie wojsko jak wojsko Boże.   
\m
\v 23 A oto liczba oddziałów gotowych do boju, \add które\add* przyszły do Dawida w Hebronie, aby przenieść na niego królestwo Saula zgodnie ze słowem PANA.   
\m
\v 24 Z synów Judy, noszących tarczę i włócznię, sześć tysięcy ośmiuset uzbrojonych do boju.   
\m
\v 25 Z synów Symeona, dzielnych wojowników na wojnę, siedem tysięcy stu.   
\m
\v 26 Z synów Lewiego cztery tysiące sześciuset.   
\m
\v 27  \add Także\add* Jehojada, przywódca \add synów\add* Aarona, a z nim trzy tysiące siedmiuset.   
\m
\v 28 I Sadok, młody, dzielny wojownik \add wraz z\add* domem swego ojca – dwudziestu dwóch dowódców.   
\m
\v 29 Z synów Beniamina, braci Saula, trzy tysiące. Dotąd bowiem większość z nich pozostawała w służbie domu Saula.   
\m
\v 30 Z synów Efraima dwadzieścia tysięcy ośmiuset dzielnych wojowników, ludzi sławnych w domach swych ojców.   
\m
\v 31 Z połowy pokolenia Manassesa osiemnaście tysięcy, którzy imiennie zostali wyznaczeni, aby przyjść i ustanowić Dawida królem.   
\m
\v 32 Z synów Issachara, umiejących rozpoznać czasy, tak że wiedzieli, co Izrael ma czynić – dwustu naczelników, a wszyscy ich bracia stawali na ich rozkazy.   
\m
\v 33  \add Z pokolenia\add* Zebulona \add tych\add*, którzy wychodzili na wojnę, wyćwiczonych w walce wszelką bronią wojenną – pięćdziesiąt tysięcy stających w szyku bojowym i niemających dwoistego serca.   
\m
\v 34 Z \add pokolenia\add* Neftalego – tysiąc dowódców, a z nimi trzydzieści siedem tysięcy \add uzbrojonych\add* w tarcze i włócznie.   
\m
\v 35 Z \add pokolenia\add* Dana gotowych do boju było dwadzieścia osiem tysięcy sześciuset \add mężczyzn\add*.   
\m
\v 36 Z \add pokolenia\add* Aszera tych, którzy wychodzili na wojnę, wyćwiczonych w walce – czterdzieści tysięcy.   
\m
\v 37 Z drugiej strony Jordanu z \add pokolenia\add* Rubena i Gada oraz z połowy pokolenia Manassesa w pełnym uzbrojeniu wojennym – sto dwadzieścia tysięcy \add mężczyzn\add*.   
\m
\v 38 Ci wszyscy wojownicy, którzy stawali w szyku bojowym, całym sercem przyszli do Hebronu, aby ustanowić Dawida królem nad całym Izraelem. Również i cała reszta Izraela \add była\add* jednomyślna w tym, aby ustanowić Dawida królem.   
\m
\v 39 I byli tam z Dawidem przez trzy dni, jedząc i pijąc, gdyż ich bracia przygotowali to dla nich.   
\m
\v 40 Również ci, którzy byli w ich pobliżu, aż po Issachara i Zebulona, i Neftalego, przynosili żywność na osłach, na wielbłądach, na mułach i na wołach: potrawy, mąkę, figi, rodzynki, wino, oliwę oraz woły i owce w wielkiej ilości, bo zapanowała radość w Izraelu.   
\c 13  
\m
\v 1 A Dawid odbył naradę z tysiącznikami i setnikami oraz ze wszystkimi dowódcami.   
\m
\v 2 Potem Dawid powiedział do całego zgromadzenia Izraela: \add Jeśli\add* wam się to podoba i jeśli jest to od PANA, naszego Boga, roześlijmy wiadomość wszędzie do naszych braci, którzy pozostali we wszystkich krainach Izraela, a także do kapłanów i Lewitów – po miastach i ich pastwiskach – i niech się zgromadzą u nas;   
\m
\v 3 Abyśmy sprowadzili do nas arkę naszego Boga. Nie pytaliśmy bowiem o nią za czasów Saula.   
\m
\v 4 I całe zgromadzenie powiedziało, aby tak czynić, bo ta rzecz podobała się całemu ludowi.   
\m
\v 5 Dawid więc zebrał cały Izrael od egipskiego Szichoru aż do wejścia do Chamat, aby sprowadzić arkę Boga z Kiriat-Jearim.   
\m
\v 6 Dawid wyruszył wraz z całym Izraelem do Baali, w Kiriat-Jearim, które \add znajduje się\add* w Judzie, aby sprowadzić stamtąd arkę PANA Boga zasiadającego nad cherubinami, gdzie wzywane jest jego imię.   
\m
\v 7 I wywieźli arkę Boga na nowym wozie z domu Abinadaba, a Uzza i Achio prowadzili wóz.   
\m
\v 8 Dawid zaś i cały Izrael grali przed Bogiem ze wszystkich sił, śpiewając przy dźwiękach harf, cytr, bębnów, cymbałów i trąb.   
\m
\v 9 A gdy przyszli na klepisko Kidona, Uzza wyciągnął rękę, aby przytrzymać arkę, bo woły się potknęły.   
\m
\v 10 I zapłonął gniew PANA przeciwko Uzzie i \add PAN\add* go zabił, dlatego że wyciągnął rękę do arki. I umarł tam przed Bogiem.   
\m
\v 11 I Dawid był wielce niezadowolony, że PAN tak srogo poraził Uzzę, dlatego nazwał to miejsce Peres-Uzza i tak \add jest nazywane\add* do dziś.   
\m
\v 12 I Dawid zląkł się Boga tego dnia, i powiedział: Jak mam wprowadzić do siebie arkę Boga?   
\m
\v 13 Dlatego Dawid nie wprowadził arki do siebie, do miasta Dawida, lecz wprowadził ją do domu Obed-Edoma Gittyty.   
\m
\v 14 I arka Boga pozostała z domownikami Obed-Edoma w jego domu przez trzy miesiące. A PAN błogosławił domowi Obed-Edoma i wszystkiemu, co miał.   
\c 14  
\m
\v 1 Potem Hiram, król Tyru, wysłał posłów do Dawida wraz z drewnem cedrowym, murarzami i cieślami, aby mu zbudowali dom.   
\m
\v 2 I Dawid poznał, że PAN potwierdził jego królowanie nad Izraelem, gdyż wywyższył jego królestwo ze względu na swój lud Izraela.   
\m
\v 3 Dawid pojął więcej żon w Jerozolimie i spłodził więcej synów i córek.   
\m
\v 4 A oto imiona tych, którzy mu się urodzili w Jerozolimie: Szammua, Szobab, Natan, Salomon;   
\m
\v 5 Jibchar, Eliszua, Elpalet;   
\m
\v 6 Noga, Nefeg, Jafia;   
\m
\v 7 Eliszama, Beeliada i Elifelet.   
\m
\v 8 Kiedy Filistyni usłyszeli, że Dawid został namaszczony na króla nad całym Izraelem, wszyscy Filistyni wyruszyli, aby go szukać. Gdy Dawid usłyszał o tym, wyszedł naprzeciw nich.   
\m
\v 9 Filistyni przybyli i rozciągnęli się w dolinie Refaim.   
\m
\v 10 I Dawid radził się Boga, mówiąc: Czy mam wyruszyć przeciw Filistynom i czy wydasz ich w moje ręce? PAN mu odpowiedział: Wyruszaj, a wydam ich w twoje ręce.   
\m
\v 11 A gdy przybyli do Baal-Perasim, tam Dawid ich pobił. Wtedy Dawid powiedział: Bóg rozerwał moich wrogów przez moją rękę, jak rozrywają się wody. Dlatego nazwał to miejsce Baal-Perasim.   
\m
\v 12 I porzucili tam swoje bożki, a Dawid rozkazał spalić je ogniem.   
\m
\v 13 Lecz Filistyni znowu rozciągnęli się w dolinie.   
\m
\v 14 Dawid więc ponownie radził się Boga, a Bóg mu odpowiedział: Nie ruszaj na nich, ale odwróć się od nich, abyś natarł na nich od strony drzew morwowych.   
\m
\v 15 A gdy usłyszysz odgłos kroków wśród wierzchołków drzew morwowych, wtedy wyruszysz do bitwy, gdyż Bóg wyruszył przed tobą, aby pobić wojska Filistynów.   
\m
\v 16 I Dawid uczynił tak, jak mu rozkazał Bóg, i pobili wojska Filistynów od Gibeonu aż do Gezer.   
\m
\v 17 I w ten sposób rozsławiło się imię Dawida na wszystkich ziemiach, a PAN sprawił, że bały się go wszystkie narody.   
\c 15  
\m
\v 1 A gdy \add Dawid\add* zbudował sobie domy w mieście Dawida, przygotował miejsce dla arki Boga i rozbił jej namiot.   
\m
\v 2 Wtedy Dawid powiedział: Nie \add wolno nikomu\add* nosić arki Boga oprócz Lewitów. Ich bowiem wybrał PAN, aby nosili arkę Boga i aby służyli mu na wieki.   
\m
\v 3 Dawid więc zebrał całego Izraela w Jerozolimie, aby przenieść arkę PANA na miejsce, które dla niej przygotował.   
\m
\v 4 Zgromadził też Dawid synów Aarona i Lewitów:   
\m
\v 5 Z synów Kehata: Uriela naczelnika i jego braci – stu dwudziestu;   
\m
\v 6 Z synów Merariego: Asajasza naczelnika i jego braci – dwustu dwudziestu;   
\m
\v 7 Z synów Gerszoma: Joela naczelnika i jego braci – stu trzydziestu;   
\m
\v 8 Z synów Elisafana: Szemajasza naczelnika i jego braci – dwustu;   
\m
\v 9 Z synów Chebrona: Eliela naczelnika i jego braci – osiemdziesięciu;   
\m
\v 10 Z synów Uzziela: Amminadaba naczelnika i jego braci – stu dwunastu.   
\m
\v 11 Wtedy Dawid wezwał kapłanów Sadoka i Abiatara oraz Lewitów: Uriela, Asajasza, Joela, Szemajasza, Eliela i Amminadaba;   
\m
\v 12 I powiedział do nich: Jesteście naczelnikami rodów lewickich. Poświęćcie się wy i wasi bracia, abyście mogli przenieść arkę PANA, Boga Izraela, na miejsce, które dla niej przygotowałem.   
\m
\v 13 Ponieważ za pierwszym razem tego nie uczyniliście, PAN, nasz Bóg, zesłał na nas nieszczęście, bo nie szukaliśmy go tak, jak należy.   
\m
\v 14 Poświęcili się więc kapłani i Lewici, aby przenieść arkę PANA, Boga Izraela.   
\m
\v 15 Synowie Lewitów nieśli arkę Boga, jak rozkazał Mojżesz według słowa PANA, na swoich ramionach na drążkach, które przy niej były.   
\m
\v 16 Potem Dawid rozkazał naczelnikom Lewitów, aby ustanowili swoich braci śpiewakami przy instrumentach muzycznych: cytrach, harfach i cymbałach, aby rozbrzmiewał donośny głos pełen radości.   
\m
\v 17 Lewici ustanowili Hemana, syna Joela, a z jego braci – Asafa, syna Berechiasza, a z synów Merariego, ich braci – Etana, syna Kuszajasza;   
\m
\v 18 A z nimi braci ich drugiego \add stopnia\add*: Zachariasza, Bena, Jaaziela, Szemiramota, Jechiela, Unniego, Eliaba, Benajasza, Maasejasza, Mattitiasza, Elifela, Miknejasza, Obed-Edoma i Jejela – odźwiernych.   
\m
\v 19 A śpiewacy Heman, Asaf i Etan grali głośno na cymbałach z brązu.   
\m
\v 20 Zachariasz, Jaziel, Szemiramot, Jechiel, Unni, Elijab, Maasejasz i Benajasz \add grali\add* na cytrach na Alamot.   
\m
\v 21 A Mattitiasz, Elifel, Miknejasz, Obed-Edom, Jejel i Azaziasz \add grali\add* na harfach na Seminit i prowadzili śpiew.   
\m
\v 22 A Kenaniasz, naczelnik Lewitów, odpowiadał za pieśni. Kierował śpiewaniem, bo był uzdolniony.   
\m
\v 23 Berekiasz i Elkana \add byli\add* odźwiernymi przy arce.   
\m
\v 24 A kapłani: Szebaniasz, Joszafat, Netaneel, Amasaj, Zachariasz, Benajasz i Eliezer grali na trąbach przed arką Boga, a Obed-Edom i Jechiasz \add byli\add* odźwiernymi przy arce.   
\m
\v 25 Tak więc Dawid, starsi Izraela i tysiącznicy wyruszyli, aby z radością przenieść arkę przymierza PANA z domu Obed-Edoma.   
\m
\v 26 I kiedy Bóg wspomógł Lewitów niosących arkę przymierza PANA, złożyli w ofierze siedem wołów i siedem baranów.   
\m
\v 27 A Dawid \add był\add* ubrany w szatę z bisioru, podobnie jak wszyscy Lewici, którzy nieśli arkę, śpiewacy i Kenaniasz, kierujący śpiewem. Dawid miał także na sobie lniany efod.   
\m
\v 28 I w ten sposób cały Izrael prowadził arkę przymierza PANA wśród radosnych okrzyków, przy dźwięku kornetu, trąb i cymbałów, grając na cytrach i harfach.   
\m
\v 29 I kiedy arka przymierza PANA wchodziła do miasta Dawida, Mikal, córka Saula, wyglądała przez okno i zobaczyła króla Dawida tańczącego i grającego. I wzgardziła nim w swoim sercu.   
\c 16  
\m
\v 1 A gdy przynieśli arkę Boga i umieścili ją pośrodku namiotu wzniesionego przez Dawida, złożyli całopalenia i ofiary pojednawcze przed Bogiem.   
\m
\v 2 A gdy Dawid skończył składanie całopaleń i ofiar pojednawczych, błogosławił lud w imię PANA.   
\m
\v 3 I rozdał wszystkim Izraelitom, tak mężczyźnie, jak i kobiecie, po bochenku chleba i po kawałku mięsa oraz po bukłaku \add wina\add*.   
\m
\v 4 Ustanowił też niektórych Lewitów sługami przed arką PANA, aby wspominali i chwalili \add go\add*, i dziękowali PANU, Bogu Izraela:   
\m
\v 5 Asafa, naczelnika, a po nim Zachariasza, Jejela, Szemiramota, Jechiela, Mattitiasza, Eliaba, Benajasza i Obed-Edoma: Jejela \add do gry\add* na instrumentach: cytrach i harfach, a Asafa – na cymbałach;   
\m
\v 6 A kapłanów Benajasza i Jachaziela, aby \add stali\add* nieustannie z trąbami przed arką przymierza Boga.   
\m
\v 7 Wtedy w tym dniu Dawid postanowił po raz pierwszy, aby Asaf i jego bracia chwalili PANA \add tym psalmem\add*:   
\m
\v 8 Wysławiajcie PANA, wzywajcie jego imienia, opowiadajcie między narodami sprawy jego.   
\m
\v 9 Śpiewajcie mu, śpiewajcie mu psalmy, rozmawiajcie o wszystkich jego cudach.   
\m
\v 10 Chlubcie się jego świętym imieniem, niech się raduje serce szukających PANA.   
\m
\v 11 Szukajcie PANA i jego mocy, szukajcie zawsze jego oblicza.   
\m
\v 12 Przypominajcie sobie dzieła, które czynił, jego cuda i wyroki jego ust.   
\m
\v 13 Wy, potomkowie Izraela, jego sługi; wy, synowie Jakuba, jego wybrańcy!   
\m
\v 14 On \add jest\add* PANEM, naszym Bogiem, jego sądy na całej ziemi.   
\m
\v 15 Pamiętajcie zawsze o jego przymierzu, o słowie, które nakazał po tysiąc pokoleń;   
\m
\v 16  \add O przymierzu\add*, które zawarł z Abrahamem, i o przysiędze złożonej Izaakowi.   
\m
\v 17 Ustanowił je jako prawo dla Jakuba, jako wieczne przymierze dla Izraela;   
\m
\v 18 Mówiąc: Tobie dam ziemię Kanaan jako dział waszego dziedzictwa;   
\m
\v 19 Kiedy było was niewielu, \add byliście\add* nieliczni i obcy w niej.   
\m
\v 20 I wędrowali od narodu do narodu, z jednego królestwa do innego ludu;   
\m
\v 21 Nikomu nie pozwolił ich krzywdzić, nawet karcił królów z ich powodu, \add mówiąc\add*;   
\m
\v 22 Nie dotykajcie moich pomazańców, a moim prorokom nie czyńcie \add nic\add* złego.   
\m
\v 23 Śpiewaj PANU, cała ziemio, opowiadajcie dzień po dniu o jego zbawieniu.   
\m
\v 24 Głoście wśród narodów jego chwałę, pośród wszystkich ludów – jego cudowne dzieła;   
\m
\v 25 Wielki bowiem \add jest\add* PAN i godny wszelkiej chwały, straszliwszy nad wszystkich bogów;   
\m
\v 26 Gdyż wszyscy bogowie narodów \add są\add* bożkami, a PAN uczynił niebiosa.   
\m
\v 27 Chwała i cześć przed nim, moc i radość w jego przybytku.   
\m
\v 28 Oddajcie PANU, rodziny narodów, oddajcie PANU chwałę i moc.   
\m
\v 29 Oddajcie PANU chwałę jego imienia. Przynoście dary i przychodźcie przed jego oblicze. Oddajcie PANU pokłon w ozdobie świętości.   
\m
\v 30 Zadrżyj przed nim, cała ziemio. Świat będzie utwierdzony, aby się nie poruszył.   
\m
\v 31 Niech się weselą niebiosa i niech się raduje ziemia, niech mówią wśród narodów: PAN króluje!   
\m
\v 32 Niech zaszumi morze i to, co je napełnia, niech radują się pola i wszystko, co \add jest\add* na nich.   
\m
\v 33 Wtedy radośnie wykrzykną leśne drzewa przed PANEM, bo idzie, aby sądzić ziemię.   
\m
\v 34 Wysławiajcie PANA, bo jest dobry, bo jego miłosierdzie \add trwa\add* na wieki.   
\m
\v 35 I mówcie: Zbaw nas, BOŻE naszego zbawienia, i zgromadź nas, i wybaw nas od pogan, abyśmy wielbili twoje święte imię i chlubili się twoją chwałą.   
\m
\v 36 Błogosławiony PAN, Bóg Izraela, na wieki wieków. I cały lud powiedział: Amen i chwalił PANA.   
\m
\v 37 I \add Dawid\add* zostawił tam przed arką przymierza PANA Asafa i jego braci, aby nieustannie pełnili służbę przed arką, według potrzeby każdego dnia;   
\m
\v 38 Także Obed-Edoma i ich braci, sześćdziesięciu ośmiu; a Obed-Edoma, syna Jedutuna, i Chosę \add uczynił\add* odźwiernymi.   
\m
\v 39 Kapłana Sadoka i jego braci kapłanów \add pozostawił\add* przed przybytkiem PANA na wyżynie w Gibeonie;   
\m
\v 40 Aby składali PANU nieustannie, rano i wieczorem, całopalenia na ołtarzu całopaleń, zgodnie ze wszystkim, co jest napisane w Prawie PANA, które nadał on Izraelowi;   
\m
\v 41 A z nimi \add pozostawił\add* Hemana i Jedutuna oraz resztę wybranych, imiennie wyznaczonych, aby chwalili PANA, bo jego miłosierdzie \add trwa\add* na wieki.   
\m
\v 42 I u nich, u Hemana i Jedutuna, \add pozostawił\add* trąby i cymbały dla grających na tych i na \add innych\add* instrumentach muzycznych dla Boga. Synowie zaś Jedutuna \add byli\add* odźwiernymi.   
\m
\v 43 Potem cały lud się rozszedł, każdy do swego domu. Dawid też wrócił, aby błogosławić swojemu domowi.   
\c 17  
\m
\v 1 Kiedy Dawid zamieszkał w swoim domu, powiedział do proroka Natana: Oto mieszkam w domu cedrowym, a arka przymierza PANA pod zasłonami.   
\m
\v 2 Natan powiedział do Dawida: Uczyń wszystko, co jest w twoim sercu, gdyż Bóg jest z tobą.   
\m
\v 3 Lecz tej samej nocy doszło do Natana słowo Boże, mówiące:   
\m
\v 4 Idź i powiedz mojemu słudze Dawidowi: Tak mówi PAN: Nie ty zbudujesz mi dom, w którym zamieszkam.   
\m
\v 5 Nie mieszkałem bowiem w żadnym domu od dnia, w którym wyprowadziłem synów Izraela, aż do dziś, ale przechodziłem z namiotu do namiotu i z przybytku \add do przybytku\add*.   
\m
\v 6 Wszędzie, gdziekolwiek chodziłem z całym Izraelem, czy powiedziałem do któregoś z sędziów Izraela, którym nakazałem paść mój lud: Dlaczego nie zbudowaliście mi domu cedrowego?   
\m
\v 7 Teraz więc tak powiesz mojemu słudze Dawidowi: Tak mówi PAN zastępów: Ja wziąłem ciebie z owczarni od chodzenia za trzodą, abyś był dowódcą nad moim ludem Izraelem.   
\m
\v 8 I byłem z tobą wszędzie, dokądkolwiek chodziłeś, wytraciłem przed tobą wszystkich twoich wrogów i uczyniłem twoje imię jak imię wielkich \add ludzi\add*, którzy są na ziemi.   
\m
\v 9 Ustanowię miejsce dla swego ludu Izraela i zasadzę go \add tam\add*, i będzie mieszkał na swoim miejscu, i nie poruszy się więcej ani już nie będą go gnębić synowie nieprawości jak dawniej;   
\m
\v 10 Od czasu, kiedy ustanowiłem sędziów nad swoim ludem Izraela, i ujarzmię wszystkich twoich wrogów. Oznajmiam ci też, że PAN zbuduje ci dom.   
\m
\v 11 Gdy się wypełnią twoje dni i będziesz musiał odejść do swoich ojców, wzbudzę po tobie twego potomka, który będzie spośród twoich synów, i utwierdzę jego królestwo.   
\m
\v 12 On zbuduje mi dom i utwierdzę jego tron na wieki.   
\m
\v 13 Ja będę mu ojcem, a on będzie mi synem. Nie cofnę od niego swojego miłosierdzia, jak je cofnąłem od \add tego\add*, który był przed tobą.   
\m
\v 14 Ustanowię go w moim domu i w moim królestwie na wieki, jego tron będzie utwierdzony na wieki.   
\m
\v 15 Zgodnie z tymi wszystkimi słowami i zgodnie z całym tym widzeniem, tak mówił Natan do Dawida.   
\m
\v 16 Przyszedł więc król Dawid, usiadł przed PANEM i powiedział: Kim ja jestem, PANIE Boże, i czym \add jest\add* mój dom, że doprowadziłeś mnie dotąd?   
\m
\v 17 Lecz i to było jeszcze mało w twoich oczach, Boże, gdyż złożyłeś też obietnicę o domu swego sługi na daleką przyszłość i wejrzałeś na mnie jak na człowieka wysokiego stanu, PANIE Boże.   
\m
\v 18 Co więcej \add może\add* ci \add powiedzieć\add* Dawid za taką chwałę \add okazaną\add* twemu słudze? Ty bowiem znasz swego sługę.   
\m
\v 19 PANIE, przez wzgląd na swego sługę i według swego serca uczyniłeś te wszystkie wielkie rzeczy, dając poznać te wszystkie wspaniałe sprawy.   
\m
\v 20 PANIE, nie ma nikogo podobnego do ciebie i nie ma Boga oprócz ciebie według wszystkiego, co słyszeliśmy na własne uszy.   
\m
\v 21 I czy jest taki naród na ziemi, jak twój lud Izrael, dla którego Bóg wyruszył, aby \add go\add* sobie wykupić jako swój lud, a przez to uczynić swoje imię wielkim i straszliwym, wypędzając narody przed swoim ludem, który wykupiłeś z Egiptu?   
\m
\v 22 Uczyniłeś bowiem twój lud Izraela swoim ludem na wieki i ty, PANIE, stałeś się jego Bogiem.   
\m
\v 23 Teraz więc, PANIE, niech słowo, które wypowiedziałeś o swoim słudze i o jego domu, będzie utwierdzone na wieki i uczyń, jak powiedziałeś.   
\m
\v 24 Niech stanie się tak, aby twoje imię było uwielbione na wieki, aby mówiono: PAN zastępów, Bóg Izraela, jest Bogiem nad Izraelem; niech dom Dawida, twego sługi, będzie utwierdzony przed tobą.   
\m
\v 25 Ty bowiem, mój Boże, objawiłeś swemu słudze, że zbudujesz mu dom. Dlatego twój sługa ośmielił się modlić przed tobą.   
\m
\v 26 A teraz, PANIE, ty jesteś Bogiem i obiecałeś takie dobro swemu słudze.   
\m
\v 27 Racz więc błogosławić dom swego sługi, aby trwał na wieki przed tobą. \add Co\add* bowiem ty, PANIE, błogosławisz, będzie błogosławione na wieki.   
\c 18  
\m
\v 1 Po tych wydarzeniach Dawid pobił Filistynów, ujarzmił ich i zabrał z ich rąk Gat i jego wioski.   
\m
\v 2 Pobił też Moab i Moabici stali się sługami Dawida składającymi daninę.   
\m
\v 3 Dawid pobił też Hadadezera, króla Soby w Chamat, gdy ten wyprawił się, aby rozciągnąć swoją władzę nad rzeką Eufrat.   
\m
\v 4 Dawid zabrał mu wtedy tysiąc rydwanów, siedem tysięcy jeźdźców i dwadzieścia tysięcy pieszych. I popodcinał Dawid \add ścięgna\add* wszystkich \add koniom\add* zaprzęgowym, zostawiając z nich tylko \add tyle, ile potrzeba\add* do stu rydwanów.   
\m
\v 5 Kiedy Syryjczycy z Damaszku przybyli na pomoc Hadadezerowi, królowi Soby, Dawid pobił spośród nich dwadzieścia dwa tysiące ludzi.   
\m
\v 6 Potem Dawid umieścił \add załogi\add* w Syrii damasceńskiej, a Syryjczycy stali się sługami Dawida składającymi daninę. Tak PAN zachowywał Dawida, dokądkolwiek \add ten\add* się udał.   
\m
\v 7 Dawid zabrał też złote tarcze, które mieli słudzy Hadadezera, i przyniósł je do Jerozolimy.   
\m
\v 8 Również z Tibchat i Kun, miast Hadadezera, Dawid zabrał bardzo dużo brązu, z którego Salomon wykonał morze brązowe, słupy i naczynia brązowe.   
\m
\v 9 A gdy usłyszał Tou, król Chamatu, że Dawid pobił całe wojsko Hadadezera, króla Soby;   
\m
\v 10 Posłał swego syna Hadorama do króla Dawida, aby go pozdrowił w pokoju i aby mu powinszował tego, że walczył z Hadadezerem i pokonał go – Hadadezer bowiem prowadził wojnę z Tou – i \add Hadoram\add* przyniósł ze sobą wszelkiego rodzaju naczynia złote, srebrne i brązowe.   
\m
\v 11 Również i je król Dawid poświęcił PANU wraz ze srebrem i złotem, które pobrał od wszystkich narodów: od Edomu, od Moabu, od synów Ammona, od Filistynów i od Amaleka.   
\m
\v 12 I Abiszaj, syn Serui, pobił w Dolinie Soli osiemnaście tysięcy Edomitów.   
\m
\v 13 I umieścił w Edomie załogi, a wszyscy Edomici stali się sługami Dawida. Tak PAN zachowywał Dawida, dokądkolwiek \add ten\add* się udał.   
\m
\v 14 Dawid więc królował nad całym Izraelem i sprawował sąd nad całym swym ludem, i \add wymierzał\add* mu sprawiedliwość.   
\m
\v 15 Joab, syn Serui, \add był postawiony\add* nad wojskiem, a Jehoszafat, syn Achiluda, \add był\add* kronikarzem.   
\m
\v 16 Sadok, syn Achituba, i Abimelek, syn Abiatara, \add byli\add* kapłanami, a Szawsza \add był\add* pisarzem.   
\m
\v 17 Benajasz, syn Jehojady, był \add postawiony\add* nad Keretytami i Peletytami, a synowie Dawida \add byli\add* pierwszymi przy królu.   
\c 19  
\m
\v 1 Potem umarł Nachasz, król synów Ammona, a jego syn królował w jego miejsce.   
\m
\v 2 Wtedy Dawid powiedział: Okażę życzliwość Chanunowi, synowi Nachasza, bo jego ojciec mnie okazał życzliwość. I Dawid wysłał posłańców, aby go pocieszyć po stracie jego ojca. Przyszli więc słudzy Dawida do ziemi synów Ammona, do Chanuna, aby go pocieszyć.   
\m
\v 3 Lecz książęta synów Ammona powiedzieli do Chanuna: Czy myślisz, że Dawid chce uczcić twego ojca i dlatego przysłał do ciebie pocieszycieli? Czy nie po to raczej przyszli jego słudzy do ciebie, aby przypatrzyć się tej ziemi, przeszpiegować ją i zburzyć?   
\m
\v 4 Chanun wziął więc sługi Dawida, ogolił ich, obciął ich szaty do połowy, aż do pośladków, i odesłał ich.   
\m
\v 5 Wtedy \add niektórzy\add* poszli i donieśli Dawidowi o tych ludziach. I wysłał \add posłów\add* naprzeciw nich, ponieważ ci mężczyźni byli bardzo znieważeni. Król powiedział \add im\add*: Zostańcie w Jerychu, aż wam brody odrosną, a potem wróćcie.   
\m
\v 6 Gdy synowie Ammona spostrzegli, że obrzydli Dawidowi, Chanun i synowie Ammona posłali tysiąc talentów srebra, aby sobie wynająć \add za te\add* pieniądze rydwany i jeźdźców z Mezopotamii, z Syrii-Maaka i z Soby.   
\m
\v 7 I najęli sobie za te pieniądze trzydzieści dwa tysiące rydwanów oraz króla Maaki wraz z jego ludem. Przybyli i rozbili obóz naprzeciw Medeby, a synowie Ammona zebrali się ze swoich miast i ustawili się do bitwy.   
\m
\v 8  \add A\add* gdy Dawid usłyszał o tym, wysłał Joaba z całym zastępem dzielnych wojowników.   
\m
\v 9 Ruszyli więc synowie Ammona i ustawili się w szyku bojowym przed bramą miejską. Królowie zaś, którzy przybyli \add na pomoc, stanęli\add* osobno w polu.   
\m
\v 10 Gdy Joab zobaczył, że wojsko szykuje walkę przeciwko niemu z przodu i z tyłu, wybrał \add mężczyzn\add* spośród wszystkich wyborowych \add wojowników\add* w Izraelu i ustawił ich w szyku bojowym przeciw Syryjczykom.   
\m
\v 11 A resztę ludzi oddał pod rękę swego brata Abiszaja – oni ustawili się w szyku bojowym przeciw synom Ammona.   
\m
\v 12 I powiedział: Jeśli Syryjczycy będą silniejsi ode mnie, przyjdziesz mi na pomoc, a jeśli synowie Ammona będą silniejsi od ciebie, ja przyjdę tobie na pomoc.   
\m
\v 13 Bądź odważny i walczmy mężnie za nasz lud i za miasta naszego Boga, a niech PAN uczyni to, co jest dobre w jego oczach.   
\m
\v 14 Joab więc wraz z ludem, który \add był\add* z nim, wyruszył do bitwy z Syryjczykami. A oni uciekli przed nim.   
\m
\v 15 Gdy synowie Ammona zobaczyli, że Syryjczycy uciekli, również i oni uciekli przed jego bratem Abiszajem i weszli do miasta. Wtedy Joab wrócił do Jerozolimy.   
\m
\v 16 Kiedy Syryjczycy zobaczyli, że są pobici przez Izraela, wyprawili posłańców i sprowadzili Syryjczyków, którzy \add byli\add* za rzeką. I Szofak, dowódca wojska Hadadezera, prowadził ich.   
\m
\v 17 Gdy doniesiono o tym Dawidowi, ten zebrał cały Izrael, przeprawił się przez Jordan, przybył do nich i ustawił wojsko przeciwko nim w szyku bojowym. A gdy Dawid ustawił wojsko w szyku bojowym przeciwko Syryjczykom, oni walczyli z nim.   
\m
\v 18 Lecz Syryjczycy uciekli przed Izraelem i spośród nich Dawid zabił siedem tysięcy \add ludzi walczących na\add* rydwanach oraz czterdzieści tysięcy pieszych. Zabił również Szofaka, dowódcę wojska.   
\m
\v 19 Kiedy słudzy Hadadezera zobaczyli, że zostali pokonani przez Izraela, zawarli pokój z Dawidem i zostali jego poddanymi. Potem Syryjczycy już nie chcieli udzielić pomocy synom Ammona.   
\c 20  
\m
\v 1 A na początku roku, w czasie, gdy królowie zwykli wyjeżdżać \add na wojnę\add*, Joab poprowadził potężne wojsko i spustoszył ziemię synów Ammona, potem nadciągnął i obległ Rabbę, Dawid tymczasem pozostał w Jerozolimie. I Joab zdobył Rabbę, i zburzył ją.   
\m
\v 2 Wtedy Dawid zdjął koronę jej króla z jego głowy, a okazało się, że waży ona talent złota, była też ozdobiona drogocennymi kamieniami. I włożono ją na głowę Dawida. Wywiózł też z miasta bardzo dużo łupów.   
\m
\v 3 Lud, który \add był\add* w nim, wyprowadził i przeciął piłami, bronami żelaznymi i siekierami. Tak uczynił Dawid ze wszystkimi miastami synów Ammona. Potem Dawid wrócił wraz z całym ludem do Jerozolimy.   
\m
\v 4 Następnie doszło do wojny z Filistynami w Gezer. Wtedy to Sibbekaj Chuszatyta zabił Sippaja z rodu olbrzyma i tak \add Filistyni\add* zostali pokonani.   
\m
\v 5 I znowu była wojna z Filistynami, kiedy Elchanan, syn Jaira, zabił Lachmiego, brata Goliata Gittyty, którego drzewce włóczni było jak wał tkacki.   
\m
\v 6 I była jeszcze wojna w Gat, gdzie znajdował się człowiek wysokiego wzrostu, który miał po sześć palców \add u rąk i nóg, razem\add* – dwadzieścia cztery \add palce\add*. On również pochodził z rodu tego olbrzyma.   
\m
\v 7 A gdy wyzywał Izraela, zabił go Jonatan, syn Szimei, brata Dawida.   
\m
\v 8 Ci byli synami jednego olbrzyma z Gat, a polegli z ręki Dawida i z rąk jego sług.   
\c 21  
\m
\v 1 Wtedy szatan powstał przeciwko Izraelowi i pobudził Dawida, aby policzył Izraela.   
\m
\v 2 Dawid więc powiedział do Joaba i do przełożonych nad ludem: Idźcie, policzcie Izraela od Beer-Szeby aż do Dan i donieście mi o ich liczbie, abym ją poznał.   
\m
\v 3 Lecz Joab odpowiedział: Niech PAN pomnoży swój lud sto razy tyle, ile go jest. Lecz, mój panie, królu, czy nie są oni wszyscy sługami mego pana? Czemu mój pan żąda tego? Czemu miałoby to być przyczyną grzechu dla Izraela?   
\m
\v 4 Słowo króla jednak przemogło Joaba. Wyszedł więc Joab, obszedł całego Izraela i wrócił do Jerozolimy.   
\m
\v 5 I podał Joab Dawidowi liczbę policzonych. A było wszystkich w Izraelu milion sto tysięcy mężczyzn dobywających miecz, a z Judy – czterysta siedemdziesiąt tysięcy mężczyzn dobywających miecz.   
\m
\v 6 Lecz Lewitów i Beniaminitów nie policzył razem z nimi, gdyż rozkaz króla budził odrazę w Joabie.   
\m
\v 7 Nie podobała się też Bogu ta rzecz, więc ukarał Izraela.   
\m
\v 8 Wtedy Dawid powiedział do Boga: Zgrzeszyłem bardzo, czyniąc tę rzecz. Lecz teraz, proszę, zgładź nieprawość swego sługi, gdyż bardzo głupio postąpiłem.   
\m
\v 9 I PAN powiedział do Gada, widzącego Dawida:   
\m
\v 10 Idź i powiedz Dawidowi: Tak mówi PAN: Trzy rzeczy ci przedstawiam, wybierz sobie jedną z nich, abym ci uczynił.   
\m
\v 11 Przyszedł więc Gad do Dawida i powiedział mu: Tak mówi PAN: Wybierz sobie:   
\m
\v 12 Albo trzy lata głodu, albo trzy miesiące klęsk od twoich wrogów, podczas których miecz twoich wrogów będzie cię ścigał, albo trzy dni miecza PANA i zarazy w ziemi, kiedy Anioł PANA będzie niszczył wszystkie granice Izraela. Teraz więc rozważ, co mam odpowiedzieć temu, który mnie posłał.   
\m
\v 13 Dawid odpowiedział Gadowi: Jestem w wielkiej rozterce. Niech wpadnę raczej w ręce PANA, gdyż wielkie jest jego miłosierdzie. Niech nie wpadnę w ręce człowieka.   
\m
\v 14 Zesłał więc PAN zarazę na Izraela. I poległo z Izraela siedemdziesiąt tysięcy mężczyzn.   
\m
\v 15 Posłał też Bóg Anioła do Jerozolimy, aby ją zniszczyć. A gdy ją niszczył, wejrzał PAN i użalił się nad tym nieszczęściem i powiedział do Anioła, który niszczył: Dosyć już, powstrzymaj rękę. A Anioł PANA stał obok klepiska Ornana Jebusyty.   
\m
\v 16 Gdy Dawid podniósł oczy, ujrzał Anioła PANA stojącego między ziemią a niebem, a w jego ręce dobyty miecz wyciągnięty nad Jerozolimą. Wtedy Dawid i starsi, ubrani w wory, upadli na twarze.   
\m
\v 17 I Dawid powiedział do Boga: Czy nie ja rozkazałem policzyć lud? Ja jestem tym, który zgrzeszył i bardzo źle uczynił, ale te owce, co uczyniły? PANIE, mój Boże, błagam, niech się obróci twoja ręka przeciwko mnie, domowi mego ojca. Lecz niech się nie rozprzestrzenia ta plaga przeciwko twemu ludowi.   
\m
\v 18 Wtedy Anioł PANA powiedział do Gada, aby oznajmił Dawidowi, że ma iść i zbudować PANU ołtarz na klepisku Ornana Jebusyty.   
\m
\v 19 Dawid więc poszedł według słowa Gada, który mówił w imieniu PANA.   
\m
\v 20 Wtedy Ornan obrócił się i ujrzał Anioła, a jego czterej synowie, którzy \add byli\add* z nim, ukryli się. A Ornan młócił pszenicę.   
\m
\v 21 Gdy Dawid przyszedł do Ornana, ten spojrzał i zobaczył Dawida. Wyszedł więc z klepiska i pokłonił się Dawidowi twarzą do ziemi.   
\m
\v 22 I Dawid powiedział do Ornana: Odstąp mi miejsce \add tego\add* klepiska, abym zbudował na nim ołtarz PANU. Oddaj mi je za pełną cenę, aby plaga odstąpiła od ludu.   
\m
\v 23 Ornan odpowiedział Dawidowi: Weź \add je\add* sobie i niech mój pan, król, uczyni, co uważa za słuszne. Oto oddaję też woły na całopalenia, sprzęty młocarskie na drwa i pszenicę na ofiarę z pokarmów – \add to\add* wszystko daję.   
\m
\v 24 I król Dawid powiedział do Ornana: Nie, raczej kupię \add wszystko\add* za pełną cenę. Nie wezmę bowiem dla PANA tego, co jest twoje, ani nie będę ofiarował całopaleń, które nic nie kosztują.   
\m
\v 25 Dał więc Dawid Ornanowi za \add to\add* miejsce sykle złota w wadze sześciuset.   
\m
\v 26 I Dawid zbudował tam PANU ołtarz, złożył całopalenia i ofiary pojednawcze i wzywał PANA, a on mu odpowiedział z nieba, \add spuszczając\add* ogień na ołtarz całopalenia.   
\m
\v 27 I PAN rozkazał Aniołowi, by schował swój miecz do pochwy.   
\m
\v 28 Wtedy Dawid, widząc, że PAN go wysłuchał na klepisku Ornana Jebusyty, składał tam ofiary.   
\m
\v 29 Przybytek PANA bowiem, który Mojżesz zbudował na pustyni, oraz ołtarz całopalenia \add były\add* w tym czasie na wyżynie w Gibeonie.   
\m
\v 30 Lecz Dawid nie mógł iść do niego, aby radzić się Boga, gdyż bał się miecza Anioła PANA.   
\c 22  
\m
\v 1 Wtedy Dawid powiedział: To jest dom PANA Boga i to jest ołtarz całopalenia dla Izraela.   
\m
\v 2 Dawid rozkazał zgromadzić cudzoziemców, którzy \add byli\add* w ziemi Izraela, i ustanowił \add spośród nich\add* kamieniarzy do obróbki kamieni ciosanych na budowę domu Bożego.   
\m
\v 3 Dawid przygotował też bardzo dużo żelaza na gwoździe do drzwi w bramach i na spojenie oraz niezliczoną wagę brązu;   
\m
\v 4 Także drzewa cedrowego niezliczoną ilość, bo Sydończycy i Tyryjczycy przywieźli Dawidowi bardzo wiele drewna cedrowego.   
\m
\v 5 Dawid powiedział: Salomon, mój syn, \add jest\add* młody i niedoświadczony, a dom, który ma być zbudowany dla PANA, musi być niezmiernie okazały, aby był znany i sławny we wszystkich krajach. Teraz więc poczynię przygotowania za niego. I wiele przygotował Dawid przed swoją śmiercią.   
\m
\v 6 Potem zawołał swego syna Salomona i nakazał mu zbudować dom dla PANA, Boga Izraela.   
\m
\v 7 I Dawid powiedział do Salomona: Synu mój! Pragnąłem zbudować dom dla imienia PANA, swego Boga.   
\m
\v 8 Lecz doszło do mnie słowo PANA mówiące: Rozlałeś wiele krwi i prowadziłeś wielkie wojny. Nie będziesz budował domu dla mojego imienia, ponieważ rozlałeś wiele krwi na ziemię przed moim obliczem.   
\m
\v 9 Oto urodzi ci się syn, który będzie człowiekiem pokoju, bo dam mu odpoczynek od wszystkich jego wrogów wokoło. Będzie miał na imię Salomon, ponieważ za jego dni dam Izraelowi pokój i odpoczynek.   
\m
\v 10 On zbuduje dom dla mojego imienia i on będzie mi synem, a ja \add będę\add* mu ojcem i utwierdzę tron jego królestwa nad Izraelem na wieki.   
\m
\v 11 Teraz więc, mój synu, niech PAN będzie z tobą i niech ci się powodzi, abyś zbudował dom dla PANA, swego Boga, jak zapowiedział o tobie.   
\m
\v 12 Oby tylko PAN ci dał roztropność i rozwagę i niech cię ustanowi nad Izraelem, abyś strzegł prawa PANA, swego Boga.   
\m
\v 13 Wtedy będzie ci się powodziło, jeśli będziesz strzegł i wypełniał przykazania i prawa, które PAN dał Mojżeszowi dla Izraela. Bądź silny i mężny, nie bój się ani się lękaj.   
\m
\v 14 A oto w moim trudzie przygotowałem na dom PANA sto tysięcy talentów złota i tysiąc tysięcy talentów srebra, brązu i żelaza zaś bez wagi, bo \add tego\add* jest wiele. Przygotowałem również drewno i kamień, a \add ty możesz\add* do tego dokładać.   
\m
\v 15 Masz też u siebie wielu rzemieślników, kamieniarzy, murarzy, cieśli i wszelkich biegłych w każdym rzemiośle.   
\m
\v 16 Złota, srebra, brązu i żelaza jest bez liku. Wstań więc i działaj, a PAN \add niech\add* będzie z tobą.   
\m
\v 17 Dawid też nakazał wszystkim książętom Izraela, aby pomagali jego synowi Salomonowi;   
\m
\v 18  \add Mówiąc\add*: Czy PAN, wasz Bóg, \add nie jest\add* z wami? Czy nie dał wam odpoczynku wokoło? Dał bowiem w moją rękę mieszkańców \add tej\add* ziemi, a ziemia została poddana PANU i jego ludowi.   
\m
\v 19 Teraz więc oddajcie swoje serce i swoją duszę ku szukaniu PANA, waszego Boga. Wstańcie i budujcie świątynię PANA Boga, abyście \add mogli tam\add* wnieść arkę przymierza PANA oraz święte naczynia Boga, do domu, który będzie zbudowany dla imienia PANA.   
\c 23  
\m
\v 1 Gdy więc Dawid był już stary i syty dni, ustanowił swego syna Salomona królem nad Izraelem.   
\m
\v 2 I zgromadził wszystkich książąt Izraela oraz kapłanów i Lewitów.   
\m
\v 3 Lewitów policzono od trzydziestu lat wzwyż, a ich liczba według głów wynosiła trzydzieści osiem tysięcy.   
\m
\v 4 Spośród nich dwadzieścia cztery tysiące ustanowiono na służbę w domu PANA, a urzędników i sędziów było sześć tysięcy.   
\m
\v 5 Ponadto – cztery tysiące odźwiernych i cztery tysiące chwalących PANA na instrumentach, które sporządziłem – \add powiedział Dawid\add* – ku uwielbieniu \add Boga\add*.   
\m
\v 6 Dawid podzielił ich na zmiany według synów Lewiego: Gerszona, Kehata i Merariego.   
\m
\v 7 Z Gerszona \add byli\add* Ladan i Szimei.   
\m
\v 8 Synowie Ladana: pierwszy Jechiel, potem Zetam i Joel – \add ci\add* trzej.   
\m
\v 9 Synowie Szimejego: Szelomit, Chaziel i Haran – \add ci\add* trzej \add byli\add* naczelnikami rodów Ladana.   
\m
\v 10 A synowie Szimejego: Jachat, Zina, Jeusz i Beria. Ci czterej byli synami Szimejego.   
\m
\v 11 Jachat był pierwszy, a Ziza drugi. Ale Jeusz i Beria nie mieli wielu synów i dlatego zostali policzeni jako jeden ród.   
\m
\v 12 Synowie Kehata: Amram, Ishar, Chebron i Uzziel – czterej.   
\m
\v 13 Synowie Amrama: Aaron i Mojżesz. Lecz Aaron został odłączony, aby poświęcić najświętsze rzeczy, on i jego synowie, aż na wieki – by spalać kadzidło przed PANEM, służyć mu i błogosławić w jego imieniu na wieki.   
\m
\v 14 Ale synowie Mojżesza, męża Bożego, zostali zaliczeni do pokolenia Lewiego.   
\m
\v 15 Synowie Mojżesza: Gerszon i Eliezer.   
\m
\v 16 Synowie Gerszona: pierwszy Szebuel.   
\m
\v 17 Synowie Eliezera: pierwszy Rechabiasz. Eliezer nie miał innych synów, ale synowie Rechabiasza bardzo się rozmnożyli.   
\m
\v 18 Synowie Ishara: pierwszy Szelomit.   
\m
\v 19 Synowie Chebrona: pierwszy Jeriasz, drugi Amariasz, trzeci Jachaziel, a czwarty Jekameam.   
\m
\v 20 Synowie Uzziela: pierwszy Mika i drugi Jeszijasz.   
\m
\v 21 Synowie Merariego: Machli i Muszi. Synowie Machliego: Eleazar i Kisz.   
\m
\v 22 I Eleazar umarł, nie mając synów, tylko córki. Pojęli je \add za żony\add* synowie Kisza, ich bracia.   
\m
\v 23 Synowie Musziego: Machli, Eder i Jeremot – trzej.   
\m
\v 24 To są synowie Lewiego według swych rodów, głów rodzin, policzeni według liczby imion, głowa po głowie, którzy pełnili służbę w domu PANA od lat dwudziestu wzwyż.   
\m
\v 25 Dawid bowiem powiedział: PAN, Bóg Izraela, dał odpoczynek swemu ludowi i będzie mieszkał w Jerozolimie na wieki.   
\m
\v 26 A Lewici już nie będą nosić przybytku ani wszelkich jego naczyń do jego obsługi.   
\m
\v 27 Według ostatnich postanowień Dawida Lewici zostali policzeni od lat dwudziestu wzwyż;   
\m
\v 28 Ich stanowisko bowiem polegało na posługiwaniu synom Aarona w służbie domu PANA: na dziedzińcach, w komnatach, przy oczyszczaniu wszelkich rzeczy poświęconych i przy pracy wokół służby domu Bożego;   
\m
\v 29 I przy chlebie pokładnym, przy mące na ofiarę z pokarmów, przy plackach niekwaszonych, przy tym, co pieczone, i tym, co smażone, i przy wszystkim, co ważone i mierzone.   
\m
\v 30 Mieli stawać każdego poranka, by dziękować PANU i wychwalać go, i tak samo wieczorem;   
\m
\v 31 Ponadto, mieli składać PANU wszelkie całopalenia w każdy szabat, w czasie nowiu księżyca i w uroczyste święta, według liczby \add wynikającej z\add* ustalonego porządku – ustawicznie przed PANEM.   
\m
\v 32 I mieli pełnić straż przy Namiocie Zgromadzenia, straż przy świątyni i straż przy synach Aarona, swych braci, w służbie domu PANA.   
\c 24  
\m
\v 1 A \add oto\add* podział synów Aarona. Synami Aarona \add byli\add*: Nedab, Abihu, Eleazar i Itamar;   
\m
\v 2 Ale Nadab i Abihu umarli przed swoim ojcem i nie mieli synów, dlatego Eleazar i Itamar sprawowali urząd kapłański.   
\m
\v 3 I Dawid podzielił ich, \add to jest\add* Sadoka z synów Eleazara i Achimeleka z synów Itamara, według ich urzędu w ich służbie.   
\m
\v 4 I okazało się, że spośród synów Eleazara było więcej naczelników niż spośród synów Itamara. Tak więc ich podzielono: spośród synów Eleazara \add było\add* szesnastu naczelników według rodów, a spośród synów Itamara według rodów – ośmiu.   
\m
\v 5 A zostali podzieleni przez losowanie, zarówno jedni, jak i drudzy, gdyż przełożeni świątyni i przełożeni domu Bożego byli spośród synów Eleazara, jak i spośród synów Itamara.   
\m
\v 6 A Szemajasz, syn Netaneela, pisarz z \add pokolenia\add* Lewiego, spisał ich wobec króla i książąt, kapłana Sadok, Achimeleka, syna Abiatara, oraz naczelników rodów kapłańskich i lewickich. Losowano \add na przemian\add* jeden dom z rodu Eleazara, drugi – z Itamara.   
\m
\v 7 Pierwszy los padł na Jehojariba, drugi na Jedajasza;   
\m
\v 8 Trzeci na Charima, czwarty na Seorima;   
\m
\v 9 Piąty na Malkiasza, szósty na Mijamina;   
\m
\v 10 Siódmy na Hakkosa, ósmy na Abiasza;   
\m
\v 11 Dziewiąty na Jeszuę, dziesiąty na Szekaniasza;   
\m
\v 12 Jedenasty na Eliasziba, dwunasty na Jakima;   
\m
\v 13 Trzynasty na Chuppę, czternasty na Jeszebaba;   
\m
\v 14 Piętnasty na Bilgę, szesnasty na Immera;   
\m
\v 15 Siedemnasty na Chezira, osiemnasty na Happisesa;   
\m
\v 16 Dziewiętnasty na Petachiasza, dwudziesty na Ezechiela;   
\m
\v 17 Dwudziesty pierwszy na Jachina, dwudziesty drugi na Gamula;   
\m
\v 18 Dwudziesty trzeci na Delajasza, dwudziesty czwarty na Maazjasza.   
\m
\v 19 Taka \add była\add* kolejność w służbie, aby wchodzili do domu PANA zgodnie z ustaleniem, jakie pochodziło od ich ojca Aarona, jak mu rozkazał PAN, Bóg Izraela.   
\m
\v 20 A pozostali z synów Lewiego to: z synów Amrama – Szubael; z synów Szubaela – Jechdejasz.   
\m
\v 21 Z Rechabiasza: z synów Rechabiasza pierwszym \add był\add* Jisziasz.   
\m
\v 22 Z Ishara – Szelomit; z synów Szelomita – Jachat.   
\m
\v 23 A synowie Chebrona: pierwszy Jeriasz, drugi Amariasz, trzeci Jachaziel, czwarty Jekameam.   
\m
\v 24 Synowie Uzziela: Mika; z synów Miki – Szamir.   
\m
\v 25 Brat Miki: Jisziasz; z synów Jisziasza – Zachariasz.   
\m
\v 26 Synowie Merariego: Machli i Muszi; synowie Jaazjasza: Beno.   
\m
\v 27 Synowie Merariego z Jaazjasza: Beno, Szoham, Zakkur i Ibri.   
\m
\v 28 Z Machliego: Eleazar, który nie miał synów.   
\m
\v 29 Z Kisza, synowie Kisza: Jerachmeel.   
\m
\v 30 A synowie Musziego: Machli, Eder i Jerimot. Ci \add byli\add* synami Lewitów według ich rodów.   
\m
\v 31 Oni również rzucali losy tak samo jak ich bracia, synowie Aarona, przed królem Dawidem, Sadokiem, Achimelekiem oraz naczelnikami rodów kapłańskich i lewickich – naczelnicy rodów na równi z młodszymi ich braćmi.   
\c 25  
\m
\v 1 Dawid wraz z dowódcami wojska przydzielił do służby synów Asafa, Hemana i Jedutuna, którzy mieli prorokować przy harfach, cytrach i cymbałach. A oto liczba pełniących tę służbę:   
\m
\v 2 Z synów Asafa – Zakkur, Józef, Netaniasz i Asarela. Synowie Asafa zależni od Asafa, który prorokował pod kierownictwem króla.   
\m
\v 3 Z Jedutuna – synowie Jedutuna: Gedaliasz, Seri, Jeszajasz, Chaszabiasz, Mattitiasz \add i Szimei\add*, sześciu, pod kierunkiem ich ojca Jedutuna, który prorokował przy harfie, dziękując PANU i wychwalając go.   
\m
\v 4 Z Hemana – synowie Hemana: Bukkiasz, Mattaniasz, Uzziel, Szebuel, Jerimot, Chananiasz, Chanani, Eliata, Giddalti, Romamtiezer, Joszbekasza, Malloti, Hotir i Machaziot.   
\m
\v 5 Ci wszyscy \add byli\add* synami Hemana, widzącego królewskiego w słowach Bożych, dla podnoszenia rogu. I Bóg dał Hemanowi czternastu synów i trzy córki.   
\m
\v 6 Ci wszyscy \add byli\add* pod kierownictwem swego ojca, \add przeznaczeni\add* do śpiewu w domu PANA przy cymbałach, cytrach i harfach, do służby w domu Bożym, tak jak król rozkazał Asafowi, Jedutunowi i Hemanowi.   
\m
\v 7 A liczba ich wraz z ich braćmi wyćwiczonymi w pieśniach PANA, wszystkich uzdolnionych, wynosiła dwieście osiemdziesiąt osiem.   
\m
\v 8 I rzucali losy co do swej służby, tak mały, jak i wielki, tak mistrz, jak i uczeń.   
\m
\v 9 Pierwszy los padł na Asafa i na Józefa, drugi – na Gedaliasza wraz z jego braćmi i synami, razem \add było ich\add* dwunastu.   
\m
\v 10 Trzeci – na Zakkura, na jego synów i braci, razem dwunastu.   
\m
\v 11 Czwarty – na Jisriego, na jego synów i braci, razem dwunastu.   
\m
\v 12 Piąty – na Netaniasza, na jego synów i braci, razem dwunastu.   
\m
\v 13 Szósty – na Bukkiasza, na jego synów i braci, razem dwunastu.   
\m
\v 14 Siódmy – na Jesarela, na jego synów i braci, razem dwunastu.   
\m
\v 15 Ósmy – na Jeszajasza, na jego synów i braci, razem dwunastu.   
\m
\v 16 Dziewiąty – na Mattaniasza, na jego synów i braci, razem dwunastu.   
\m
\v 17 Dziesiąty – na Szimejego, na jego synów i braci, razem dwunastu.   
\m
\v 18 Jedenasty – na Azarela, na jego synów i braci, razem dwunastu.   
\m
\v 19 Dwunasty – na Chaszabiasza, na jego synów i braci, razem dwunastu.   
\m
\v 20 Trzynasty – na Szubaela, na jego synów i braci, razem dwunastu.   
\m
\v 21 Czternasty – na Mattitiasza, na jego synów i braci, razem dwunastu.   
\m
\v 22 Piętnasty – na Jeremota, na jego synów i braci, razem dwunastu.   
\m
\v 23 Szesnasty – na Chananiasza, na jego synów i braci, razem dwunastu.   
\m
\v 24 Siedemnasty – na Joszbekasza, na jego synów i braci, razem dwunastu.   
\m
\v 25 Osiemnasty – na Chananiego, na jego synów i braci, razem dwunastu.   
\m
\v 26 Dziewiętnasty – na Mallotiego, na jego synów i braci, razem dwunastu.   
\m
\v 27 Dwudziesty – na Eliatę, na jego synów i braci, razem dwunastu.   
\m
\v 28 Dwudziesty pierwszy – na Hotira, na jego synów i braci, razem dwunastu.   
\m
\v 29 Dwudziesty drugi – na Giddaltiego, na jego synów i braci, razem dwunastu.   
\m
\v 30 Dwudziesty trzeci – na Machaziota, na jego synów i braci, razem dwunastu.   
\m
\v 31 Dwudziesty czwarty – na Romamtiezera, na jego synów i braci, razem dwunastu.   
\c 26  
\m
\v 1 Co do zmiany odźwiernych: z Korachitów był Meszelemiasz, syn Koracha, z synów Asafa.   
\m
\v 2 A z synów Meszelemiasza: pierworodny Zachariasz, drugi Jediael, trzeci Zebadiasz, czwarty Jatniel;   
\m
\v 3 Piąty Elam, szósty Jehochanan, siódmy Elioenaj.   
\m
\v 4 A z synów Obed-Edoma: pierworodny Szemajasz, drugi Jehozabad, trzeci Joach, czwarty Sakar, piąty Netaneel;   
\m
\v 5 Szósty Ammiel, siódmy Issachar, ósmy Peulletaj. Bóg bowiem mu błogosławił.   
\m
\v 6 Również jego synowi Szemajaszowi urodzili się synowie, którzy rządzili swoim rodem. \add Byli\add* bowiem bardzo dzielnymi ludźmi.   
\m
\v 7 Synowie Szemajasza: Otni, Rafael, Obed, Elzabad i ich bracia, ludzie mocni – Elihu i Semakiasz.   
\m
\v 8 Wszyscy ci byli z synów Obed-Edoma, oni, ich synowie i bracia, mężczyźni bardzo mocni i zdolni do służby, razem sześćdziesięciu dwóch z Obed-Edoma.   
\m
\v 9 I Meszelemiasz miał synów i braci, ludzi mocnych – osiemnastu.   
\m
\v 10 Również Chosa, \add który był\add* z synów Merariego, miał synów: Szimri zwierzchnik, bo chociaż nie był pierworodnym, jego ojciec ustanowił go zwierzchnikiem;   
\m
\v 11 Drugi Chilkiasz, trzeci Tebaliasz, czwarty Zachariasz. Wszystkich synów i braci Chosy \add było\add* trzynastu.   
\m
\v 12 Spośród nich wyznaczono zmiany odźwiernych, spośród naczelników, którzy \add pełnili\add* straż na przemian ze swoimi braćmi przy służbie w domu PANA.   
\m
\v 13 I rzucali losy o każdą bramę, tak mały, jak i wielki, według swoich rodów.   
\m
\v 14 Los dla Szelemiasza padł na stronę wschodnią. Potem rzucili los dla jego syna Zachariasza, mądrego doradcy, i jego los padł na stronę północną;   
\m
\v 15 Dla Obed-Edoma – na południową, a jego synom \add przypadła\add* składnica.   
\m
\v 16 Dla Szuppima i Chosy – na stronę zachodnią wraz z bramą Szalleket, przy drodze wiodącej ku górze, straż naprzeciw straży.   
\m
\v 17 Od wschodu \add było\add* sześciu Lewitów, od północy czterech na dzień, od południa czterech na dzień i przy składnicy po dwóch.   
\m
\v 18 Przy Parbar na zachodzie: czterech przy drodze, \add a\add* dwóch przy Parbar.   
\m
\v 19 Takie \add są\add* zmiany odźwiernych spośród synów Koracha i spośród synów Merariego.   
\m
\v 20 A z \add pozostałych\add* Lewitów Achiasz \add postawiony był\add* nad skarbcami domu Bożego i nad skarbcami rzeczy poświęconych.   
\m
\v 21 Synowie Ladana, \add którzy byli\add* z synów Gerszonity: z Ladana Gerszonity naczelnicy rodów, Jechiel.   
\m
\v 22 Synowie Jechiela: Zetam i jego brat Joel; \add oni byli postawieni\add* nad skarbcami domu PANA.   
\m
\v 23 Spośród Amramitów, Isharytów, Chebronitów i Uzzielitów:   
\m
\v 24 Szebuel, syn Gerszoma, syna Mojżesza, przełożony nad skarbcami.   
\m
\v 25 A jego bracia, od strony Eliezera, to: jego syn Rechabiasz, jego syn Jeszajasz, jego syn Joram, jego syn Zikri i jego syn Szelomit.   
\m
\v 26 Szelomit i jego bracia \add byli postawieni\add* nad wszystkimi skarbcami rzeczy poświęconych, które poświęcił król Dawid, naczelnicy rodów, tysiącznicy, setnicy i dowódcy wojska.   
\m
\v 27  \add To, co\add* zdobyli z wojen i łupów, poświęcali na utrzymanie domu PANA.   
\m
\v 28 I wszystko, co poświęcił Samuel, widzący, \add a także\add* Saul, syn Kisza, Abner, syn Nera, i Joab, syn Serui, oraz wszystko, co zostało poświęcone, \add było\add* pod opieką Szelomita i jego braci.   
\m
\v 29 Spośród Isharytów: Kenaniasz i jego synowie \add zajmowali się\add* sprawami zewnętrznymi Izraela jako urzędnicy i sędziowie.   
\m
\v 30 Spośród Chebronitów: Chaszabiasz i jego bracia, ludzie dzielni, \add było ich\add* tysiąc siedemset przełożonych nad Izraelem po zachodniej stronie Jordanu, odpowiadali za każdą sprawę PANA i służbę dla króla.   
\m
\v 31 Spośród Chebronitów \add pochodził\add* Jeriasz, naczelnik Chebronitów, według rodowodów jego ojców. W czterdziestym roku panowania Dawida szukano i znaleziono pośród nich bardzo dzielnych ludzi w Jazer w Gileadzie.   
\m
\v 32 A jego braci, ludzi dzielnych, \add było\add* dwa tysiące siedmiuset naczelników rodów, których król Dawid ustanowił zwierzchnikami nad Rubenitami, nad Gadytami i nad połową pokolenia Manassesa, by byli odpowiedzialni za wszystkie sprawy Boże i sprawy króla.   
\c 27  
\m
\v 1 A oto synowie Izraela według ich liczby: naczelnicy rodów, tysiącznicy, setnicy i urzędnicy, którzy służyli królowi we wszelkiej sprawie związanej z oddziałami przychodzącymi i odchodzącymi co miesiąc, przez wszystkie miesiące w roku. Każdy oddział \add liczył\add* dwadzieścia cztery tysiące.   
\m
\v 2 Nad oddziałem w miesiącu pierwszym \add stał\add* Jaszobeam, syn Zabdiela, a jego oddział \add liczył\add* dwadzieścia cztery tysiące.   
\m
\v 3 On pochodził z synów Peresa, a \add był\add* wodzem wszystkich dowódców wojska w miesiącu pierwszym.   
\m
\v 4 Nad oddziałem w miesiącu drugim \add stał\add* Dodaj, Achochita. \add Po nim\add* dowódcą był Miklot, a jego oddział \add liczył\add* dwadzieścia cztery tysiące.   
\m
\v 5 Trzecim dowódcą wojska, na miesiąc trzeci, \add był\add* Benajasz, syn Jehojady, naczelnego kapłana, a jego oddział \add liczył\add* dwadzieścia cztery tysiące.   
\m
\v 6 Ten to Benajasz \add był\add* waleczny wśród trzydziestu i dowodził trzydziestoma, a jego syn Ammizabad należał do jego oddziału.   
\m
\v 7 Czwartym dowódcą, na miesiąc czwarty, \add był\add* Asahel, brat Joaba, a po nim jego syn Zebadiasz – jego oddział \add liczył\add* dwadzieścia cztery tysiące.   
\m
\v 8 Piątym dowódcą, na piąty miesiąc, \add był\add* Szamhut Jizrachita, a jego oddział \add liczył\add* dwadzieścia cztery tysiące.   
\m
\v 9 Szóstym, na miesiąc szósty, \add był\add* Ira, syn Ikkesza Tekoitczyka, a jego oddział \add liczył\add* dwudziestu czterech.   
\m
\v 10 Siódmym, na miesiąc siódmy, \add był\add* Cheles Pelonita, z synów Efraima, a jego oddział \add liczył\add* dwadzieścia cztery tysiące.   
\m
\v 11 Ósmym, na miesiąc ósmy, \add był\add* Sibbekaj Chuszatyta, z Zerachitów, a jego oddział \add liczył\add* dwadzieścia cztery tysiące.   
\m
\v 12 Dziewiątym, na miesiąc dziewiąty, \add był\add* Abiezer Anatotczyk, z synów Beniamina, a jego oddział \add liczył\add* dwadzieścia cztery tysiące.   
\m
\v 13 Dziesiątym, na miesiąc dziesiąty, \add był\add* Maharaj Netofatyta, z Zerachitów, a jego oddział \add liczył\add* dwadzieścia cztery tysiące.   
\m
\v 14 Jedenastym, na miesiąc jedenasty, \add był\add* Benajasz Piratończyk, z synów Efraima, a jego oddział \add liczył\add* dwadzieścia cztery tysiące.   
\m
\v 15 Dwunastym, na miesiąc dwunasty, \add był\add* Cheldaj Netofatyta, z Otniela, a jego oddział \add liczył\add* dwadzieścia cztery tysiące.   
\m
\v 16 Ponadto nad pokoleniami Izraela \add postawieni byli\add*: nad Rubenitami przełożonym \add był\add* Eliezer, syn Zikriego; nad Symeonitami – Szefatiasz, syn Maaki;   
\m
\v 17 Nad Lewitami – Chaszabiasz, syn Kemuela, nad Aaronitami – Sadok;   
\m
\v 18 Nad Judą – Elihu, \add jeden\add* z braci Dawida, nad Issacharytami – Omri, syn Mikaela;   
\m
\v 19 Nad Zebulonitami – Jiszmajasz, syn Obadiasza, nad Neftalitami – Jerimot, syn Azriela;   
\m
\v 20 Nad synami Efraima – Ozeasz, syn Azazjasza, nad połową pokolenia Manassesa – Joel, syn Pedajasza;   
\m
\v 21 Nad \add drugą\add* połową \add pokolenia\add* Manassesa w Gileadzie – Iddo, syn Zachariasza, nad Beniaminatami – Jaasiel, syn Abnera.   
\m
\v 22 Nad Danitami – Azareel, syn Jerochama. Ci \add byli\add* książętami pokoleń Izraela.   
\m
\v 23 Dawid nie włączył jednak do spisu \add nikogo\add*, kto miał dwadzieścia lat lub mniej. PAN powiedział bowiem, że rozmnoży Izraela jak gwiazdy na niebie.   
\m
\v 24 Joab, syn Serui, zaczął \add ich\add* liczyć, ale nie dokończył, gdyż za to spadł gniew na Izraela. Nie włączono więc tej liczby do spisu w kronikach króla Dawida.   
\m
\v 25 Nad skarbcami króla \add postawiony był\add* Azmawet, syn Adiela; nad dochodami z pól, miast, wsi i zamków – Jonatan, syn Uzjasza;   
\m
\v 26 Nad rolnikami, \add którzy\add* uprawiali ziemię, \add stał\add* Ezri, syn Keluba.   
\m
\v 27 Nad winnicami – Szimei Ramatczyk; nad plonami winnic w piwnicach – Zabdi Szifmita.   
\m
\v 28 Nad drzewami oliwnymi i sykomorami, które \add rosły\add* na równinach, \add postawiony był\add* Baalchanan Gederczyk, a nad składami oliwy – Joasz.   
\m
\v 29 Nad bydłem pasącym się w Szaronie – Szitraj Szarończyk, nad bydłem zaś w dolinach – Szafat, syn Adlaja.   
\m
\v 30 Nad wielbłądami – Obil Izmaelita, nad oślicami – Jechdejasz Meronotyta.   
\m
\v 31 I nad owcami – Jaziz Hagryta. Ci wszyscy \add byli\add* zarządcami dobytku króla Dawida.   
\m
\v 32 Jonatan, stryj Dawida, \add był\add* doradcą, człowiekiem mądrym i uczonym. Jechiel, syn Chakmoniego, \add był\add* z synami króla.   
\m
\v 33 Achitofel też \add był\add* doradcą króla, a Chuszaj Arkita – przyjacielem króla.   
\m
\v 34 Po Achitofelu \add był\add* Jehojada, syn Benajasza, i Abiatar. Joab zaś \add był\add* dowódcą wojska króla.   
\c 28  
\m
\v 1 Potem Dawid zgromadził w Jerozolimie wszystkich książąt Izraela, książąt pokoleń i dowódców oddziałów, którzy służyli królowi, tysiączników, setników i zarządców całego dobytku i posiadłości króla i jego synów, a także urzędników, walecznych i wszystkich dzielnych wojowników.   
\m
\v 2 Wtedy król Dawid powstał i przemówił: Słuchajcie mnie, moi bracia i ludu mój! Moim pragnieniem było zbudować dom odpoczynku dla arki przymierza PANA i jako podnóżek naszego Boga i poczyniłem \add przygotowania\add* do budowy.   
\m
\v 3 Lecz Bóg powiedział do mnie: Nie zbudujesz domu dla mego imienia, ponieważ jesteś wojownikiem i rozlewałeś krew.   
\m
\v 4 Wybrał mnie jednak PAN, Bóg Izraela, spośród całego domu mego ojca, abym był królem nad Izraelem na wieki. Judę bowiem wybrał na władcę, spośród rodu Judy – dom mego ojca, a spośród synów mego ojca, mnie sobie upodobał ustanowić królem nad całym Izraelem.   
\m
\v 5 Spośród zaś wszystkich moich synów – wielu bowiem synów dał mi PAN – wybrał mego syna Salomona, aby zasiadł na tronie królestwa PANA nad Izraelem.   
\m
\v 6 I powiedział do mnie: Salomon, twój syn – to on zbuduje mój dom i moje dziedzińce. Jego bowiem wybrałem sobie za syna, a ja mu będę ojcem.   
\m
\v 7 I utwierdzę jego królestwo na wieki, jeśli podobnie jak dzisiaj będzie trwał w wypełnianiu moich przykazań i praw.   
\m
\v 8 Teraz więc na oczach całego Izraela, zgromadzenia PANA, i wobec naszego Boga \add nakazuję wam\add*: Przestrzegajcie i szukajcie wszystkich przykazań PANA, waszego Boga, abyście mogli posiadać tę dobrą ziemię i zostawić ją jako dziedzictwo swoim dzieciom po was – na wieki.   
\m
\v 9 A ty, Salomonie, mój synu, poznawaj Boga swego ojca i służ mu sercem doskonałym i dobrowolnym umysłem. PAN bowiem przenika wszystkie serca i zna wszystkie zamysły \add i\add* myśli. Jeśli będziesz go szukać, znajdziesz go, a jeśli go opuścisz, on odrzuci cię na wieki.   
\m
\v 10 Miej się teraz na baczności, gdyż PAN cię wybrał, abyś zbudował dom na świątynię; bądź mocny i wykonaj \add to\add*.   
\m
\v 11 Wtedy Dawid przekazał swojemu synowi Salomonowi wzór przedsionka \add świątyni\add*, jej domów, jej skarbców, jej komnat górnych, jej pomieszczeń wewnętrznych oraz domu dla przebłagalni.   
\m
\v 12 Do tego wzór wszystkiego, co zaplanował: dziedzińców domu PANA, wszystkich komnat dokoła oraz wszystkich skarbców domu Bożego i skarbców rzeczy poświęconych.   
\m
\v 13 Także \add wskazówki\add* co do zmian kapłańskich i lewickich, wszelkiej pracy w służbie domu PANA i co do wszelkich naczyń służby w domu PANA.   
\m
\v 14  \add Dał\add* także odpowiednią wagę złota na wszystkie naczynia złote do każdej posługi; również odpowiednią wagę srebra na wszystkie naczynia srebrne, na wszystkie naczynia do wszelkich posług;   
\m
\v 15 Mianowicie \add odpowiednią\add* wagę na świeczniki złote i ich lampy złote według wagi \add każdego\add* świecznika i jego lamp, i na świeczniki srebrne według wagi każdego świecznika i jego lamp, stosownie do użycia każdego świecznika.   
\m
\v 16 Również \add dał\add* odpowiednią wagę złota na stoły chlebów pokładnych, na każdy stół, oraz srebra – na stoły srebrne;   
\m
\v 17 I szczere złoto na widełki, miednice i kubki, na czasze złote, \add określoną\add* wagę na każdy z tych \add przedmiotów\add* i na czasze srebrne – określoną wagę na każdą z nich;   
\m
\v 18 Także na ołtarz kadzenia \add dał określoną\add* wagę szczerego złota oraz złoto na wzór wozu cherubinów, którzy swoimi rozpostartymi skrzydłami okrywali arkę przymierza PANA.   
\m
\v 19 To wszystko – \add powiedział Dawid\add* – przyszło do mnie na piśmie z ręki PANA, abym mógł zrozumieć, jak wykonać ten plan.   
\m
\v 20 Dawid powiedział do swego syna Salomona: Bądź mocny i dzielny i wykonaj to. Nie bój się ani się nie lękaj, bo PAN Bóg, mój Bóg, \add będzie\add* z tobą, nie porzuci cię ani nie opuści, dopóki nie dokończysz wszelkiej pracy wokół służby domu PANA.   
\m
\v 21 A oto zmiany kapłanów i Lewitów do każdej posługi w domu Bożym \add będą\add* z tobą w każdej pracy; każdy ochotny i zdolny do wszelkiej posługi. Także książęta i cały lud \add stawią się\add* na każdy twój rozkaz.   
\c 29  
\m
\v 1 Potem król Dawid przemówił do całego zgromadzenia: Mój syn Salomon, jedyny, którego Bóg wybrał, jest jeszcze młody i niedoświadczony, a dzieło jest wielkie. Ten pałac bowiem nie \add jest\add* dla człowieka, ale dla PANA Boga.   
\m
\v 2 Według wszystkich swoich sił przygotowałem na dom swojego Boga złoto na \add przedmioty\add* złote, srebro – na srebrne, brąz – na brązowe, żelazo – na żelazne, drewno – na drewniane, kamienie onyksowe i do osadzania, kamienia błyszczące i różnokolorowe, wszelkiego rodzaju drogie kamienie i marmur w obfitości.   
\m
\v 3 Ponadto z miłości do domu swego Boga oddaję ze swojego skarbca na dom mego Boga złota i srebra – poza tym wszystkim, co \add już\add* przygotowałem na święty dom;   
\m
\v 4  \add Mianowicie\add* trzy tysiące talentów złota, złota z Ofiru, i siedem tysięcy talentów najczystszego srebra na pokrycie ścian budynków;   
\m
\v 5 Złoto – na \add przedmioty\add* złote, a srebro – na srebrne i na wszelkie ręczne prace rzemieślników. A kto jeszcze chciałby dziś dobrowolnie złożyć PANU dar?   
\m
\v 6 Wtedy dobrowolne dary złożyli naczelnicy rodów, książęta pokoleń Izraela, tysiącznicy, setnicy oraz przełożeni nad robotami króla.   
\m
\v 7 I złożyli na służbę domu Bożego pięć tysięcy talentów złota, dziesięć tysięcy darejków, dziesięć tysięcy talentów srebra, osiemnaście tysięcy talentów brązu oraz sto tysięcy talentów żelaza.   
\m
\v 8 Ci, którzy mieli drogie kamienie, oddali \add je\add* do skarbca domu PANA na rękę Jechiela Gerszonity.   
\m
\v 9 I radował się lud \add z tego\add*, że tak dobrowolnie złożono dary, gdyż sercem doskonałym, chętnie ofiarowywano PANU. Także i król Dawid wielce się radował.   
\m
\v 10 Dawid więc błogosławił PANU przed całym zgromadzeniem i powiedział: Błogosławiony jesteś, PANIE, Boże Izraela, naszego ojca, na wieki wieków.   
\m
\v 11 Twoja, PANIE, jest wielkość, moc, chwała, zwycięstwo i majestat. Wszystko bowiem, co jest na niebie i na ziemi, jest twoje. Do ciebie należy królestwo, a ty jako głowa jesteś wyniesiony ponad wszystko.   
\m
\v 12 I bogactwo, i sława pochodzą od ciebie i ty panujesz nad wszystkimi; w twoich rękach \add jest\add* moc i siła i w twojej ręce \add jest\add* to, aby wywyższyć i umocnić wszystko.   
\m
\v 13 Teraz więc, Boże nasz, dziękujemy ci i wychwalamy chwalebne imię twoje.   
\m
\v 14 Lecz kim ja jestem i czym jest mój lud, żebyśmy zdołali ofiarować dobrowolnie te rzeczy? Od ciebie bowiem \add pochodzi\add* wszystko i daliśmy tobie to, co z twojej ręki \add otrzymaliśmy\add*.   
\m
\v 15 Jesteśmy bowiem pielgrzymami i przychodniami przed tobą, tak jak wszyscy nasi ojcowie. Nasze dni na ziemi są jak cień i nie ma czego oczekiwać.   
\m
\v 16 O PANIE, Boże nasz, cały ten dostatek, który przygotowaliśmy dla ciebie na budowę domu dla twojego świętego imienia, pochodzi z twojej ręki i twoje jest to wszystko.   
\m
\v 17 Wiem ja, mój Boże, że badasz serca i upodobałeś sobie prawość. Dlatego w prawości swego serca dobrowolnie złożyłem w ofierze to wszystko. Teraz z radością widzę, że również twój lud, który znajduje się tutaj, dobrowolnie składa ci ofiary.   
\m
\v 18 PANIE, Boże Abrahama, Izaaka i Izraela, naszych ojców, zachowaj na wieki te zamiary i myśli serca swego ludu i skłoń jego serca ku sobie.   
\m
\v 19 Salomonowi, mojemu synowi, daj serce doskonałe, aby strzegł twoich przykazań, świadectw i ustaw, aby wykonał to wszystko i aby zbudował dom, do którego poczyniłem \add przygotowania\add*.   
\m
\v 20 Potem Dawid przemówił do całego zgromadzenia: Błogosławcie teraz PANU, waszemu Bogu. I całe zgromadzenie błogosławiło PANU, Bogu swoich ojców – pochylili się i oddali pokłon PANU i królowi.   
\m
\v 21 Następnie złożyli PANU ofiary. Nazajutrz złożyli PANU całopalenia: tysiąc wołów, tysiąc baranów, tysiąc jagniąt wraz z ofiarami z płynów i mnóstwem innych ofiar, za całego Izraela.   
\m
\v 22 Jedli i pili przed PANEM tego dnia z wielką radością. I po raz drugi ustanowili królem Salomona, syna Dawida, i namaszczali \add go\add* dla PANA na władcę, a Sadoka na kapłana.   
\m
\v 23 Tak więc zasiadł Salomon na tronie PANA jako król po swoim ojcu Dawidzie i powodziło mu się, a cały Izrael był mu posłuszny.   
\m
\v 24 Również wszyscy książęta i dzielni ludzie, a także wszyscy synowie króla Dawida poddali się królowi Salomonowi.   
\m
\v 25 I PAN wielce wywyższył Salomona przed całym Izraelem i dał mu chwałę królewską, jakiej żaden król przed nim nie miał w Izraelu.   
\m
\v 26 Tak to Dawid, syn Jessego, królował nad całym Izraelem.   
\m
\v 27 A czas jego panowania nad Izraelem \add wynosił\add* czterdzieści lat: w Hebronie królował siedem lat, a w Jerozolimie królował trzydzieści trzy lata.   
\m
\v 28 I umarł w późnej starości, syty dni, bogactw i sławy. A w jego miejsce królował Salomon, jego syn.   
\m
\v 29 A dzieje króla Dawida, pierwsze i ostatnie, oto zapisane są w księdze Samuela widzącego, w księdze proroka Natana i w księdze Gada widzącego;   
\m
\v 30 Wraz z całym jego panowaniem, jego potęgą i wydarzeniami, które dotyczyły jego, Izraela i wszystkich królestw tej ziemi.   