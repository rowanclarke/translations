\c 18  
\p
\v 1  \w Some|strong="H1697"\w* \w time|strong="H3117"\w* \w later|strong="H1961"\w*, \w in|strong="H5921"\w* \w the|strong="H6440"\w* \w third|strong="H7992"\w* \w year|strong="H8141"\w* \w of|strong="H3068"\w* \w the|strong="H6440"\w* famine, \w the|strong="H6440"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w told|strong="H1697"\w* Elijah, “\w Go|strong="H3212"\w*, \w make|strong="H5414"\w* \w an|strong="H1961"\w* \w appearance|strong="H6440"\w* \w before|strong="H6440"\w* Ahab, \w so|strong="H1961"\w* \w I|strong="H3117"\w* \w may|strong="H1961"\w* \w send|strong="H5414"\w* \w rain|strong="H4306"\w* \w on|strong="H5921"\w* \w the|strong="H6440"\w* \w surface|strong="H6440"\w* \w of|strong="H3068"\w* \w the|strong="H6440"\w* \w ground|strong="H6440"\w*.”  
