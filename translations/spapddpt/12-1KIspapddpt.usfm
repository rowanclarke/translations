\p 
\v 1 Cuando la \w reina|strong="H4436"\w* de Sabá \w oyó|strong="H8085"\w* la \w fama|strong="H8034"\w* de \w Salomón|strong="H8010"\w*, que se debió al \w Nombre|strong="H8034"\w* de \nd \w Yavé|strong="H3068"\w*\nd*, vino para probarlo con preguntas difíciles.
\v 2 Llegó \w a|strong="H3068"\w* Jerusalén \w con|strong="H5973"\w* un \w gran|strong="H3966"\w* \w séquito|strong="H2428"\w*, \w camellos|strong="H1581"\w* \w cargados|strong="H5375"\w* \w de|strong="H5973"\w* \w especias|strong="H1314"\w* aromáticas, \w oro|strong="H2091"\w* \w en|strong="H5973"\w* \w gran|strong="H3966"\w* abundancia y piedras \w preciosas|strong="H3368"\w*. \w Cuando|strong="H1961"\w* llegó \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*, \w habló|strong="H1696"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w de|strong="H5973"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1961"\w* \w tenía|strong="H1961"\w* \w en|strong="H5973"\w* su \w corazón|strong="H3824"\w*.
\v 3 \w Salomón|strong="H8010"\w* respondió \w todas|strong="H3605"\w* sus preguntas, y \w no|strong="H3808"\w* \w hubo|strong="H1961"\w* \w cosa|strong="H1697"\w* difícil \w que|strong="H4480"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w no|strong="H3808"\w* le pudiera responder.
\p 
\v 4 \w La|strong="H3605"\w* \w reina|strong="H4436"\w* de Sabá, al escuchar \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w sabiduría|strong="H2451"\w* de \w Salomón|strong="H8010"\w* y \w ver|strong="H7200"\w* \w el|strong="H3605"\w* palacio \w que|strong="H3605"\w* \w edificó|strong="H1129"\w*,
\v 5 \w los|strong="H1961"\w* manjares \w de|strong="H5750"\w* su \w mesa|strong="H7979"\w*, \w los|strong="H1961"\w* asientos \w de|strong="H5750"\w* sus esclavos, la presentación y las ropas \w de|strong="H5750"\w* sus esclavos y coperos, y \w los|strong="H1961"\w* \w holocaustos|strong="H5930"\w* \w que|strong="H3808"\w* él ofrecía \w en|strong="H5750"\w* la \w Casa|strong="H1004"\w* \w de|strong="H5750"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w quedó|strong="H1961"\w* \w sin|strong="H3808"\w* aliento,
\v 6 \w y|strong="H5921"\w* dijo \w al|strong="H5921"\w* \w rey|strong="H4428"\w*: ¡\w Es|strong="H1961"\w* verdad \w lo|strong="H1697"\w* \w que|strong="H5921"\w* \w oí|strong="H8085"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* tierra \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* tus \w hechos|strong="H1697"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* tu \w sabiduría|strong="H2451"\w*!
\v 7 \w No|strong="H3808"\w* creía \w lo|strong="H1697"\w* \w que|strong="H3808"\w* me decían \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* vine \w y|strong="H5704"\w* mis \w ojos|strong="H5869"\w* \w lo|strong="H1697"\w* \w ven|strong="H7200"\w*. \w Ciertamente|strong="H2009"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* me \w dijo|strong="H5046"\w* \w ni|strong="H3808"\w* \w aun|strong="H5704"\w* \w la|strong="H2451"\w* mitad. Tú superas \w en|strong="H5704"\w* \w sabiduría|strong="H2451"\w* \w y|strong="H5704"\w* bienes \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w oí|strong="H8085"\w* \w de|strong="H5704"\w* tu \w fama|strong="H8052"\w*.
\v 8 ¡Dichosos tus hombres, dichosos estos esclavos tuyos que están \w de|strong="H6440"\w* \w continuo|strong="H8548"\w* \w delante|strong="H6440"\w* te ti y \w oyen|strong="H8085"\w* tu \w sabiduría|strong="H2451"\w*!
\p 
\v 9 ¡\w Bendito|strong="H1288"\w* \w sea|strong="H1961"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd*, \w Quien|strong="H6213"\w* \w se|strong="H1961"\w* agradó \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w para|strong="H5921"\w* establecerte \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*! \w Por|strong="H5921"\w* causa \w del|strong="H5921"\w* \w eterno|strong="H5769"\w* amor \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w tiene|strong="H1961"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w te|strong="H5921"\w* constituyó \w rey|strong="H4428"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* practiques \w la|strong="H5921"\w* equidad \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w justicia|strong="H6666"\w*.
\p 
\v 10 \w Ella|strong="H1931"\w* \add le\add* \w dio|strong="H5414"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* cuatro toneladas \w de|strong="H5750"\w* \w oro|strong="H2091"\w*, \w gran|strong="H3966"\w* cantidad \w de|strong="H5750"\w* \w especias|strong="H1314"\w* aromáticas y piedras \w preciosas|strong="H3368"\w*. \w Nunca|strong="H3808"\w* \w más|strong="H5750"\w* llegó tanta \w abundancia|strong="H7230"\w* \w de|strong="H5750"\w* \w especias|strong="H1314"\w* aromáticas \w como|strong="H1931"\w* las \w que|strong="H1931"\w* \w la|strong="H1931"\w* \w reina|strong="H4436"\w* \w de|strong="H5750"\w* Sabá llevó \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*.
\p 
\v 11 \w También|strong="H1571"\w* \w la|strong="H1571"\w* flota de \w Hiram|strong="H2438"\w* \w llevaba|strong="H5375"\w* \w oro|strong="H2091"\w* de Ofir \w y|strong="H1571"\w* transportaba \w gran|strong="H3966"\w* cantidad de \w madera|strong="H6086"\w* de sándalo\f + \fr 10:11 \ft Sándalo: árbol de madera amarillenta de excelente olor.\f* \w y|strong="H1571"\w* piedras \w preciosas|strong="H3368"\w* de Ofir.
\p 
\v 12 \w El|strong="H6213"\w* \w rey|strong="H4428"\w* \w hizo|strong="H6213"\w* columnas \w con|strong="H5704"\w* la \w madera|strong="H6086"\w* \w de|strong="H5704"\w* sándalo \w para|strong="H5704"\w* la \w Casa|strong="H1004"\w* \w de|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd*, la \w casa|strong="H1004"\w* \w real|strong="H4428"\w* \w y|strong="H5704"\w* \w arpas|strong="H3658"\w* \w y|strong="H5704"\w* liras \w para|strong="H5704"\w* los músicos. \w Tal|strong="H3651"\w* clase \w de|strong="H5704"\w* \w madera|strong="H6086"\w* \w de|strong="H5704"\w* sándalo \w no|strong="H3808"\w* \w ha|strong="H3808"\w* entrado \add más\add*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* \w ha|strong="H3808"\w* vuelto \w a|strong="H3068"\w* \w ver|strong="H7200"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.
\p 
\v 13 \w El|strong="H1931"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w reina|strong="H4436"\w* \w de|strong="H5414"\w* Sabá cuanto \w ella|strong="H1931"\w* quiso pedirle, además \w de|strong="H5414"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w Salomón|strong="H8010"\w* \w le|strong="H1931"\w* \w dio|strong="H5414"\w* según \w su|strong="H1931"\w* espléndida generosidad. Entonces \w ella|strong="H1931"\w* \w se|strong="H1931"\w* regresó \w a|strong="H3068"\w* \w su|strong="H1931"\w* tierra con \w sus|strong="H1931"\w* esclavos.
\s1 Aumento de la riqueza de Salomón
\p 
\v 14 El \w peso|strong="H4948"\w* del \w oro|strong="H2091"\w* \w que|strong="H1961"\w* le llegaba \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* \w cada|strong="H8141"\w* \w año|strong="H8141"\w* \w era|strong="H1961"\w* 22 toneladas,
\v 15 sin contar \w lo|strong="H3605"\w* de \w los|strong="H3605"\w* mercaderes, del negocio de especias, de \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de \w Arabia|strong="H6152"\w*, ni \w lo|strong="H3605"\w* de \w los|strong="H3605"\w* \w gobernadores|strong="H6346"\w* de \w la|strong="H3605"\w* tierra.
\v 16 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w hizo|strong="H6213"\w* 200 \w escudos|strong="H6793"\w* grandes \w de|strong="H5921"\w* \w oro|strong="H2091"\w* martillado \w de|strong="H5921"\w* 6,6 kilogramos \w en|strong="H5921"\w* cada \w escudo|strong="H6793"\w*.
\v 17 \w Hizo|strong="H5414"\w* \w además|strong="H5921"\w* 300 \w escudos|strong="H4043"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* martillado \w de|strong="H5921"\w* 1,65 kilogramos \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w en|strong="H5921"\w* cada \w escudo|strong="H4043"\w*, \w los|strong="H5921"\w* cuales \w el|strong="H5921"\w* \w rey|strong="H4428"\w* colocó \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w del|strong="H5921"\w* \w bosque|strong="H3293"\w* \w del|strong="H5921"\w* \w Líbano|strong="H3844"\w*.
\s1 El trono de marfil
\p 
\v 18 También \w el|strong="H6213"\w* \w rey|strong="H4428"\w* \w hizo|strong="H6213"\w* un \w gran|strong="H1419"\w* \w trono|strong="H3678"\w* de \w marfil|strong="H8127"\w* y \w lo|strong="H6213"\w* recubrió de \w oro|strong="H2091"\w* refinado.
\v 19 El \w trono|strong="H3678"\w* tenía \w seis|strong="H8337"\w* \w gradas|strong="H4609"\w* y el respaldo tenía una \w cabeza|strong="H7218"\w* de becerro. \w A|strong="H3068"\w* \w ambos|strong="H8147"\w* lados del \w asiento|strong="H3678"\w* tenía soportes para los brazos, y \w junto|strong="H3027"\w* \w a|strong="H3068"\w* los brazos \w había|strong="H5975"\w* \w dos|strong="H8147"\w* leones \w en|strong="H5975"\w* \w pie|strong="H5975"\w*.
\v 20 \w Había|strong="H5975"\w* \w igualmente|strong="H3651"\w* 12 leones \w en|strong="H5921"\w* \w pie|strong="H5975"\w*, uno \w a|strong="H3068"\w* \w cada|strong="H3605"\w* lado \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w seis|strong="H8337"\w* \w gradas|strong="H4609"\w*. \w Jamás|strong="H3808"\w* \w se|strong="H5921"\w* \w hizo|strong="H6213"\w* algo \w semejante|strong="H3651"\w* \w para|strong="H5921"\w* algún \w reino|strong="H4467"\w*.
\p 
\v 21 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w vasos|strong="H3627"\w* para beber \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w eran|strong="H3808"\w* de \w oro|strong="H2091"\w*. \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* vajilla de \w la|strong="H3605"\w* \w casa|strong="H1004"\w* del \w bosque|strong="H3293"\w* del \w Líbano|strong="H3844"\w* \w eran|strong="H3808"\w* de \w oro|strong="H2091"\w* \w puro|strong="H5462"\w*. \w Nada|strong="H3808"\w* era de \w plata|strong="H3701"\w*, pues en \w los|strong="H3605"\w* \w días|strong="H3117"\w* de \w Salomón|strong="H8010"\w* ésta \w no|strong="H3808"\w* era estimada en absoluto,
\v 22 \w porque|strong="H3588"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* tenía \w la|strong="H3588"\w* flota \w de|strong="H3588"\w* \w Tarsis|strong="H8659"\w* \w con|strong="H5973"\w* \w la|strong="H3588"\w* flota \w de|strong="H3588"\w* \w Hiram|strong="H2438"\w* \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w mar|strong="H3220"\w*.
\p Una vez \w cada|strong="H8141"\w* \w tres|strong="H7969"\w* \w años|strong="H8141"\w* llegaba \w la|strong="H3588"\w* flota \w de|strong="H3588"\w* \w Tarsis|strong="H8659"\w* \w con|strong="H5973"\w* \w oro|strong="H2091"\w*, \w plata|strong="H3701"\w*, \w marfil|strong="H8143"\w*, monos \w y|strong="H3588"\w* pavos \w reales|strong="H4428"\w*.
\p 
\v 23 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* fue \w más|strong="H2451"\w* \w grande|strong="H1431"\w* \w que|strong="H3605"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de \w la|strong="H3605"\w* tierra en \w riquezas|strong="H6239"\w* y en \w sabiduría|strong="H2451"\w*.
\v 24 \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w procuraba|strong="H1245"\w* estar en \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \w Salomón|strong="H8010"\w* \w para|strong="H5414"\w* \w oír|strong="H8085"\w* \w la|strong="H3605"\w* \w sabiduría|strong="H2451"\w* \w que|strong="H3605"\w* \nd ʼElohim\nd* \w puso|strong="H5414"\w* en su \w corazón|strong="H3820"\w*.
\v 25 \w Cada|strong="H1697"\w* \w año|strong="H8141"\w*, \w todos|strong="H8141"\w* \w ellos|strong="H1992"\w* le llevaban \w su|strong="H1992"\w* \w presente|strong="H4503"\w*: objetos \w de|strong="H1697"\w* \w plata|strong="H3701"\w* y \w de|strong="H1697"\w* \w oro|strong="H2091"\w*, ropas, \w armas|strong="H5402"\w*, perfumes, \w caballos|strong="H5483"\w* y mulas.
\p 
\v 26 \w Salomón|strong="H8010"\w* también acumuló carruajes \w de|strong="H5973"\w* guerra y \w jinetes|strong="H6571"\w*. \w Tuvo|strong="H1961"\w* 1.400 carruajes y 12.000 \w jinetes|strong="H6571"\w*, \w los|strong="H5973"\w* cuales situó \w en|strong="H5973"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5973"\w* \w los|strong="H5973"\w* carruajes y \w en|strong="H5973"\w* Jerusalén, \w cerca|strong="H5973"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w*.
\v 27 El \w rey|strong="H4428"\w* logró que la \w plata|strong="H3701"\w* en Jerusalén fuera tan \w común|strong="H7230"\w* como las piedras y que el cedro fuera tan abundante como los sicómoros \w de|strong="H5414"\w* la Sefela.
\p 
\v 28 Los \w caballos|strong="H5483"\w* de \w Salomón|strong="H8010"\w* procedían de \w Egipto|strong="H4714"\w* y Coa. Los \w mercaderes|strong="H5503"\w* del \w rey|strong="H4428"\w* los adquirían en Coa \w al|strong="H4428"\w* contado.
\v 29 \w Cada|strong="H3605"\w* carruaje \w que|strong="H3605"\w* entraba de \w Egipto|strong="H4714"\w* costaba 6,6 kilogramos de \w plata|strong="H3701"\w*, y \w cada|strong="H3605"\w* \w caballo|strong="H5483"\w* 1,65 kilogramos. \w Por|strong="H3027"\w* \w medio|strong="H3027"\w* de \add los mercaderes del rey\add* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de \w los|strong="H3605"\w* heteos y \w los|strong="H3605"\w* de Siria \w también|strong="H3651"\w* \w los|strong="H3605"\w* adquirían.
\c 11
\s1 Apostasía de Salomón
\p 
\v 1 Pero el \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*, además de la \w hija|strong="H1323"\w* de \w Faraón|strong="H6547"\w*, amó \w a|strong="H3068"\w* \w muchas|strong="H7227"\w* \w mujeres|strong="H1323"\w* \w extranjeras|strong="H5237"\w*: moabitas, amonitas, edomitas, sidonias y heteas,
\v 2 \w que|strong="H4480"\w* \w eran|strong="H3808"\w* \w de|strong="H4480"\w* \w pueblos|strong="H1471"\w* \w de|strong="H4480"\w* \w los|strong="H1992"\w* cuales \nd \w Yavé|strong="H3068"\w*\nd* dijo \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*: \wj \w No|strong="H3808"\w* \w se|strong="H4480"\w* unan \w a|strong="H3068"\w* \w ellas|strong="H1992"\w*, \w ni|strong="H3808"\w* \w ellas|strong="H1992"\w* \w se|strong="H4480"\w* unan \w a|strong="H3068"\w* ustedes, \w no|strong="H3808"\w* sea \w que|strong="H4480"\w* desvíen \w sus|strong="H1992"\w* \w corazones|strong="H3824"\w* tras \w sus|strong="H1992"\w* \tl ʼelohim\tl*.\wj* \w Salomón|strong="H8010"\w* \w se|strong="H4480"\w* apegó \w a|strong="H3068"\w* \w éstas|strong="H1992"\w* \w con|strong="H4480"\w* pasión,
\v 3 \w pues|strong="H1961"\w* \w tuvo|strong="H1961"\w* 700 \w reinas|strong="H8282"\w* y 300 \w concubinas|strong="H6370"\w*, las cuales pervirtieron su \w corazón|strong="H3820"\w*.
\v 4 \w Porque|strong="H3808"\w* \w cuando|strong="H1961"\w* \w Salomón|strong="H8010"\w* \w era|strong="H1961"\w* anciano, \w sucedió|strong="H1961"\w* \w que|strong="H3808"\w* sus mujeres hicieron desviar su \w corazón|strong="H3824"\w* hacia otros \tl ʼelohim\tl*, y ya su \w corazón|strong="H3824"\w* \w no|strong="H3808"\w* \w estuvo|strong="H1961"\w* sumiso \w a|strong="H3068"\w* la voluntad \w de|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*, \w como|strong="H5973"\w* \w el|strong="H5973"\w* \w corazón|strong="H3824"\w* \w de|strong="H5973"\w* su padre \w David|strong="H1732"\w*.
\v 5 \w Salomón|strong="H8010"\w* \w anduvo|strong="H3212"\w* tras Astarté, \tl ʼelohim\tl* de los \w sidonios|strong="H6722"\w*, y Milcom, ídolo repugnante de los amonitas.
\p 
\v 6 \w Salomón|strong="H8010"\w* \w hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* ante \nd \w Yavé|strong="H3068"\w*\nd* y \w no|strong="H3808"\w* siguió plenamente \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* como su padre \w David|strong="H1732"\w*,
\v 7 pues \w edificó|strong="H1129"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* montaña \w que|strong="H5921"\w* \w está|strong="H5921"\w* frente \w a|strong="H3068"\w* Jerusalén un lugar alto \w a|strong="H3068"\w* Quemos, ídolo repugnante \w de|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* Moloc, ídolo repugnante \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón.
\v 8 \w Hizo|strong="H6213"\w* \w esto|strong="H3651"\w* para \w todas|strong="H3605"\w* sus mujeres \w extranjeras|strong="H5237"\w*, quienes quemaban incienso y ofrecían \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* sus \tl ʼelohim\tl*.
\p 
\v 9 \nd \w Yavé|strong="H3068"\w*\nd* se airó \w contra|strong="H5973"\w* \w Salomón|strong="H8010"\w*, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w corazón|strong="H3824"\w* se desvió \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, Quien se \w le|strong="H5973"\w* \w apareció|strong="H7200"\w* \w dos|strong="H6471"\w* \w veces|strong="H6471"\w*
