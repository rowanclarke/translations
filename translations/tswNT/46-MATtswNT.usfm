\id MAT NT0001 Tsishingini (tsw) (Salka Kambari) KLP Feb. 2011
\h Matta
\toc1 Alabari a Saꞌani a Matta
\toc2 Matta
\toc3 Mat.
\mt2 Alabari a Saꞌani a
\mt1 Matta
\is1 Ucuɗuwu wa aatagada a nda
\ip Matta, vuma na ɗanai aatagada a nda, vuma ta̱ ɗa a̱tsuma̱ a ajiya e Yesu. Matta za va Israꞌila ɗa, waru u ɗana ta̱ aatagadaꞌa adama u roco a̱za̱ a̱ yi, aza a Israꞌila, a na Yesu ɗa Zamawawa na a̱ ri e indanasa ma̱ta̱wa̱ ma̱ yi.
\ip Matta reve ta̱ a na Yesu Mogono ma amayun ma ɗa, u to tsugono tsu uvaɗi suru. Waru u roco ta̱ amayun a ɗa Yesu shiton ta̱ ili i na ama̱sula̱ a Nzuwulai mu Ufaru n dammai adama a Zamawawa na a̱ ta̱wa̱ na woo oꞌwo Mogono ma Gbain. Matta rito ta̱ a na tsugono tsa̱ yi, tsugono tsu uvaɗi u nda u ɗa shi. Tsugono tsu uvaɗi u to koto, amma tsugono tsa̱ Yesu tsu ta̱ lo babu ukotu. Mogono na a ciga a ꞌyuwan u da̱na̱ za vu ucira. Yesu roco ta̱ ucira wa̱ yi ana u lyuwai aci o ukwisa̱, reve waru u ꞌyon diga a aason. Ili i nda suru oɓolo na akapi e ili suru a̱ ta̱ pe a̱tsuma̱ a aatagada a nda.
\ip Matta kamba ta̱ a̱za̱ e Itoni anaꞌan adama a na u cuɗuwai cine Yesu shitoyin ifoɓi ya̱ A̱sula̱ tsa̱ra̱ u ta̱wa̱to ama zuzu na̱ a̱yi. Ana Ada̱mu nusayin A̱sula̱, ama o oꞌwo ta̱ wukasu na̱ a̱yi. Kucci na ama a yuwusain a Nzuwulai mu Ufaru waa gura tawa addama a nda shi. Matta roco tsu ta̱ cine Yesu o oꞌwoi kucci na cayi ama ure u na a̱a̱ ta̱wa̱ zuzu na̱ A̱sula̱, waru Yesu ɗa mogono ma na maa yuwusan tsugono tsi ili suru a̱tsuma̱ o uvaɗi u nda.
\is1 Ili i na i ri pe a̱tsuma̱ a aatagada a nda
\io1 1. Nkaya na̱ limatan va̱ Yesu (1:1–2:23)
\io1 2. Ikaka ya Yahaya za vu Urumbusu (3:1-12)
\io1 3. Urumbusu wa̱ Yesu na̱ ma̱lyungwa̱ ma̱ yi (3:13–4:11)
\io1 4. Yesu a̱tsuma̱ a̱ Ga̱lili (4:12–18:35)
\io1 5. Yesu lyawa ta̱ Ga̱lili a̱ tyo Urishelima (19:1–20:34)
\io1 6. Ajuma o ukosu wa̱ Yesu: a̱tsuma̱lima̱ a̱ yi nu ukwa̱ wa̱ yi (21:1–27:66)
\io1 7. Yesu ꞌyon ta̱ a̱tsuma̱ o ukwa̱ (28:1-20)
\c 1
\s1 Nkaya ma̱ Yesu
\r (Luk. 3:23-38)
\p 
\v 1 Yesu Kristi† Zamawawa† uta̱ ta̱ o uꞌwa u Mogono Da̱wuda diga o ugundo wa Ibrahim.† Apa nda ugeru u tsukaya tsa na wu uta̱i.
\q1 
\v 2 Ibrahim ɗa matsain Ishiyaku.
\q1 Ishiyaku† ɗa matsain Yakubu.
\q1 Yakubu† ɗa matsain Yahuza na akapi a̱ muwun ma̱ a̱na̱wu ma̱ yi olobo.
\q1 
\v 3 Yahuza† ɗa matsain mpishe Farisa na̱ Zera (Tamar ɗa makuci me le).
\q1 Farisa ɗa matsain Hesuruna.
\q1 Hesuruna ɗa matsain Aram.
\q1 
\v 4 Aram ɗa matsain Aminadabu.
\q1 Aminadabu ɗa matsain Nashon.
\q1 Nashon ɗa matsain Salumuna.
\q1 
\v 5 Salumuna ɗa matsain Buwaza.
\q1 (Rahapu† ɗa makuci ma Buwaza.)
\q1 Buwaza ɗa matsain Obe.
\q1 (Rutu\f + \fr 1:5 \ft Rutu Takpaci ɗa.\f* ɗa makuci ma̱ Obe.)
\q1 Obe ɗa matsain Yese.
\q1 
\v 6 Yese† ɗa matsain Da̱wuda Mogono.
\q1 Da̱wuda† ɗa matsain Sulemanu.
\q1 (Bashaba ɗa makuci ma̱ Sulemanu, a̱yi ɗa ka na Da̱wuda\f + \fr 1:6 \ft Da̱wuda yuwan ta̱ tsipere na̱ Bashaba a̱yi o oluso Uriya, reve u yuwan ifoɓi i na vali va̱ yi Uriya a̱a̱ kuwa̱. Aalabari a nda a̱ ta̱ pe a̱tsuma̱ 2 Sam. 11:1-27.\f* usai e ekere a Uriya.)
\q1 
\v 7 Sulemanu† ɗa matsain Rihobuwa.
\q1 Rihobuwa ɗa matsain Abija.
\q1 Abija ɗa matsain Asa.
\q1 
\v 8 Asa ɗa matsain Jehoshafa.
\q1 Jehoshafa ɗa matsain Jehora.
\q1 Jehora ɗa matsain Azariya.
\q1 
\v 9 Azariya ɗa matsain Jotam.
\q1 Jotam ɗa matsain Ahazu.
\q1 Ahazu ɗa matsain Hezekiya.
\q1 
\v 10 Hezekiya ɗa matsain Manasa.
\q1 Manasa ɗa matsain Amon.
\q1 Amon ɗa matsain Josaya.
\q1 
\v 11 Josaya ɗa matsain Jekoniya na̱ muwun ma̱ a̱na̱wu ma̱ yi olobo.
\q1 (A mantsa ma ɗaɗa a̱ pura̱i ama a̱ tyo e iɗa ya Babila† tsugbashi.)
\q1 
\v 12 Ana a̱ pura̱ nle a̱ tyo Babila, a̱vu Jekoniya matsan Shayatiya.
\q1 Shayatiya ɗa matsain Zerubabe.
\q1 
\v 13 Zerubabe ɗa matsain Abihudu.
\q1 Abihudu ɗa matsain Eliyaki.
\q1 A̱vu Eliyaki matsan Azoro.
\q1 
\v 14 Azoro ɗa matsain Saduku.
\q1 Saduku ɗa matsain Akimu.
\q1 Akimu ɗa matsain Aliyadu.
\q1 
\v 15 Aliyadu ɗa matsain Eliza.
\q1 A̱vu Eliza matsan Mata.
\q1 Reve Mata matsan Yakubu.
\q1 
\v 16 Yakubu ɗa matsain Isuhu.
\q1 Isuhu ɗa vali va̱ Meri,
\q1 Meri† ɗa mma va̱ Yesu za na e ɗeyi Kristi Zamawawa.
\p 
\v 17 Ala o ugeru wa zuva e reme ta̱ tsukaya kupa na̱ a̱za̱ a̱ na̱shi diga ya Ibrahim a̱ tyo ya̱ Da̱wuda, na̱ tsukaya kupa na̱ a̱za̱ a̱ na̱shi diga a mantsa ma̱ Da̱wuda a̱ tyo mantsa ma na a̱ pura̱ nle a̱ tyo Babila, waru na̱ tsukaya kupa na̱ a̱za̱ a̱ na̱shi diga a mantsa ma na a̱ pura̱ nle a̱ tyo Babila a̱ tyo mantsa ma Zamawawa.
\s1 Limatan va̱ Yesu Kristi
\p 
\v 18 Apa nda ununa a matsain Kristi Zamawawa. Mma va̱ yi eegeɓe a vuma ro ɗa na a̱ tsu ɗe Isuhu. Babu u reve vali, a̱vu u tsura̱ a̱a̱tsuma̱ o ure wa̱ Ruhu va Akiza.†
\v 19 Isuhu gba vuma va̱ a̱ɓula̱ ɗa za na shi a yuwusan ili i na i ri mejege; agba u ciga u ca Meri wono a alanga e eteshe shi, ɗaɗa u foɓoi wu kasa na̱ a̱yi usokowu.
\p 
\v 20 A̱yi a̱tsuma̱ a majiyan mo ndolo, a̱vu malingata ma̱ A̱sulazuva ma̱ ta̱wa̱ ya̱ꞌa̱ yi a̱tsuma̱ a alavu, reve u damma, “Isuhu, mawun ma tsukaya ma̱ Da̱wuda, she vu uwwa wovon na vaa zuwa Meri wan, adama a na Ruhu va Akiza ɗa zuwa niyi u yuwain a̱a̱tsuma̱ a mawuꞌun. \fig Malingata ma̱ A̱sula̱ ma̱ ta̱wa̱i uba̱ta̱ wa̱ Isuhu|src="Matthew_1_20.tif" size="span" loc="Matthew 1:20" ref="Mat. 1:20"\fig*
\v 21 U ta matsan ulobo, a̱vu vu ca yi aala Yesu,\f + \fr 1:21 \ft Aala “Yesu” ta̱ nu urevu “A̱sulazuva za vi iwawi.”\f*† adama a na u ta wawa ama a̱ yi o unusu u le.”
\p 
\v 22 Ne ɗa nzuwulai ma̱ A̱sulazuva n shiwain, ununa Ishaya vumava̱sula̱† dammai ɗe nu ujimu,
\v 23 a na,
\q1 “Usheli u na koto u revei vali shi u ta yuwan a̱a̱tsuma̱, u ta matsan ulobo, reve a ca yi aala Imanuwe.” Urevu wa̱ yi a̱yi ɗa, “A̱sula̱ oɓolo na̱ a̱tsu.” \x ◊ \xo 1:23 \xt Isha. 7:14.\x*
\p 
\v 24 Ana Isuhu jiwain, reve u yuwan ili i na malingata ma̱ A̱sulazuva ma damma niyi u yuwan. A̱vu u tara Meri a̱ tyo o uꞌwa wo oꞌwo ka va̱ yi,
\v 25 agba e revelei shi hali u matsan uloboꞌo. Reve Isuhu ca yi aala Yesu.
\c 2
\s1 A̱za̱ o urevu a̱ ta̱wa̱i e ene Yesu
\p 
\v 1 A matsan ta̱ Yesu a̱ lyuci va Batalami e iɗa ya Yahuda, a mantsa ma na Hiridu\f + \fr 2:1 \ft A̱yi Mogono Hiridu a̱yi ɗa Hiridu Mogono ma gbain. Mawun ma̱ yi Hiridu Antiba ɗa da̱na̱i Mogono a mantsa ma na Yesu kuwa̱i.\f* da̱na̱i mogono. A mantsa mo ndolo, reve ama o ro aza a na a̱ ri nu urevu wi italyoꞌo o uta̱ asana reve a̱ ta̱wa̱ Urishelima.†
\v 2 A̱vu e ece, “Te ɗa mawun ma na a matsaiꞌin, za na ri mogono ma aza a Israꞌila?† Tse ene ta̱ talyoꞌo asana za na rocoi limatan va̱ yi ɗaɗa tsu ta̱wa̱i adama tsu yuwaan yi a̱ga̱nda̱.”
\p 
\v 3 Ana Hiridu Mogono ma uwwai ne, reve ugbozu wa̱ yi u ꞌyon, ne ɗa waru akapi a ama a̱tsuma̱ a̱ Urishelima.
\v 4 Reve u ɓoloto nan ganu a gbagbain na̱ munlu n Wila̱† suru, a̱vu we ece le, “Te ɗa aa matsan Kristi Zamawawa?”
\p 
\v 5 Reve a̱ usu, “A̱ lyuci va Batalami a̱tsuma̱ a Yahuda. Mika vumava̱sula̱ ɗana ta̱ adama a nda a Adanshi a̱ A̱sula̱:†
\q1 
\v 6 ‘A̱vu gba Batalami, vi iɗa ya Yahuda,
\q1 ili i ro i ɗa shi a̱tsuma̱ e ilyuci ya Yahuda.
\q1 Mogono ma̱ to uta̱ ya̱ꞌa̱ wu.
\q1 Za na oo oꞌwo ana za va aguɓa va aza a Israꞌila, ama a̱ va̱.’ ” \x ◊ \xo 2:6 \xt Mik. 5:2.\x*
\p 
\v 7 A̱vu Hiridu ɗe omocin a na a̱ ta̱wa̱i diga asanaꞌa usokowu, reve a damma yi mantsa ma na talyoꞌoꞌo vu uta̱i.
\v 8 Reve u damma le, “Walai i ꞌya̱wa̱ Batalami i bunga̱ mawuꞌun ulobonu. Na̱ ye ene yi, a̱vu i ta̱wa̱ i damma mu adama a̱mu fo n ꞌya̱wa̱ n yuwaan yi a̱ga̱nda̱!”
\p 
\v 9 Ana a̱za̱ o urevuꞌu a uwwai ili i na mogono ma dammai, reve a̱ ka̱ra̱. A̱vu talyoꞌo na e enei a asanaꞌa u wala elime e le, she na u rawai uba̱ta̱ꞌa̱, a̱vu wi isawan uba̱ta̱ u na mawuꞌun u ri.
\v 10 Ana e enei talyoꞌoꞌo, reve a yuwan ma̱za̱nga̱ lon!
\v 11 Ana amaꞌa a uwai o uꞌwaꞌa, a̱vu e ene mawuꞌun na̱ Meri† mma va̱ yi, a̱vu a̱ kingyo a̱ ka̱ɗa̱to a yuwaan mawuꞌun a̱ga̱nda̱. Reve o uta̱a̱ nu uneꞌe u le u zinariya, ne erepu e re a̱ ma̱guru na ri ni ikebe na a̱ tsu ɗe furenkisen† na̱ mur.†
\v 12 A̱vu A̱sula̱ o rono atsuvu a̱za̱ o urevuꞌu a̱tsuma̱ a alavu, she a̱ ka̱mba̱ ya̱ Hiridu wan, ɗaɗa a̱ ka̱mba̱i e iɗa i le nu ure u ro.
\s1 Ilaɗi a̱ tyo Masar
\p 
\v 13 Ana a̱ ka̱ra̱i, reve malingata ma̱ A̱sula̱† ma̱ ta̱wa̱ ya̱ Isuhu a̱tsuma̱ a alavu, a̱vu u damma, “ꞌYon! Jika̱ vu tara mawuꞌun na̱ mma va̱ yi a̱ tyo Masar! Vi isawan ɗe she urana u na n damma nuwu vu ka̱mba̱, adama a na Hiridu ri a zama mawuꞌun tsa̱ra̱ wu una yi.”
\v 14 Reve u ꞌyon, u tara mawuꞌun na̱ mma va̱ yi, a̱vu u reme ure na ayin a̱ tyo Masar.
\v 15 Reve a̱ da̱nu ɗe she na Hiridu kuwa̱i. A yuwan ta̱ ne adama o shiton ili i na A̱sulazuva a dammai o una̱ wa Hosiya vumava̱sula̱: “N ɗe ta̱ mawun ma̱ va̱ mo uta̱ Masar.” \x ◊ \xo 2:15 \xt Hos. 1:1.\x*
\s1 Hiridu zuwa ta̱ o una muwun mo olobo
\p 
\v 16 A mantsaꞌa ana Hiridu enei a̱za̱ o urevuꞌu a̱ ka̱nda̱ruwa̱ yi tu ucina̱, reve u yuwan upan lon. Ɗaɗa u zuwai o una muwun mo olobo suru n na n ri na aꞌwan e re a̱ cipa̱ a̱tsuma̱ a Batalami ni ilyuci i ro i na i ri lo uka̱nda̱ruwu. U reve ta̱ mantsa ma na a matsain mawuꞌun adama e ili i na a̱za̱ o urevuꞌu a dammai.
\v 17 Reve ili i na A̱sula̱ a dammai o una̱ wa Irimiya† vumava̱sula̱ wo oꞌwo amayun:
\q1 
\v 18 “Reve a uwwa uɗyo a̱tsuma̱ a Rama,
\q1 vuma ro a yisaali a adama a̱ a̱tsumola̱ngu.
\q1 Rahila† ɗa ri a yisaali adama a̱ muwun ma̱ yi,
\q1 reve u ꞌyuwan adanshi a na aa casu yi,
\q1 adama a na muwun ma̱ yi n kuwa̱i suru.” \x ◊ \xo 2:18 \xt Irm. 31:15.\x*
\s1 Uka̱mbu u le Nazara
\p 
\v 19 Ana Hiridu kuwa̱i, reve malingata ma̱ A̱sula̱ ma̱ ta̱wa̱ ya̱ Isuhu e iɗa ya Masar a̱tsuma̱ a alavu.
\v 20 A̱vu u damma yi, “ꞌYon, vu tara mawuꞌun na̱ mma va̱ yi vu ka̱mba̱ e iɗa ya Israꞌila,† adama a na aza a̱ ri e izami i na oo una mawuꞌun a̱ kuwa̱ ta̱.”
\p 
\v 21 Reve Isuhu ꞌyon, a̱vu u tara mawuꞌun na̱ mma va̱ yi, reve a̱ ka̱mba̱ e iɗa ya Israꞌila.
\v 22 Amma ana u ta̱wa̱ u revei mogono ma saꞌavu Akilayu\f + \fr 2:22 \ft Hiridu Akilayu mogono ma wuya ma ɗa ma̱ da̱na̱i ɗaɗa o uta̱a̱ niyi o tsugono. Reve Hiridu Antiba maci va̱ yi vo oꞌwo mogono.\f* mawun ma̱ Hiridu ma ɗa, reve wu uwwa wovon. Ɗaɗa a̱tsuma̱ a alavu o ro, A̱sula̱ a damma niyi u tyo e iɗa ya̱ Ga̱lili.
\v 23 Reve a̱ ka̱ra̱ a̱ ꞌya̱wa̱ a̱ da̱nu a̱ lyuci na a̱ tsu ɗe Nazara. Adama o ndolo a ɗa ili i na A̱sula̱ a dammai o una̱ wa ama̱sula̱ wo oꞌwoi amayun, a na: “E te ɗe yi za va Nazara.”
\c 3
\s1 Yahaya za vu Urumbusu foɓoi ure
\r (Mak. 1:1-8; Luk. 3:1-18; Yah. 1:19-28)
\p 
\v 1 Ana a yuwain aꞌwan o ro, reve Yahaya† za vu Urumbusu teme alajiya a̱tsuma̱ o una upasu wa Yahuda,
\v 2 adansa, “Vadalai i lyawa unusu† u ɗu i ka̱mba̱ uba̱ta̱ wa̱ A̱sula̱, adama a na tsugono tsa zuva† tsa yuwan ta̱ zuzu.”
\v 3 Ishaya† vumava̱sula̱ yuwan ta̱ ɗe adanshi a Yahaya ana u dammai:
\q1 “Nanza te ɗewu a̱tsuma̱ o una,
\q1 ‘Foɓoyi Zagbain ure,
\q1 i yuwan ure u na wa̱a̱ kuru mejege!’ ” \x ◊ \xo 3:3 \xt Isha. 40:3.\x*
\p 
\v 4 Yahaya shi ta̱ wotowu ni itana i na a ɗavai ne eleme a arakumi. Reve wu nla̱ gbakala vu ukwan. Apapari ni ishiki i ɗa i da̱na̱i ilyalya ya̱ yi.
\v 5 Ama na̱ a̱bunda̱ diga Urishelima na̱ Yahuda na̱ ba̱ta̱ na ri lo zuzu nu Uɗolu wa̱ Urdu a̱ ta̱wa̱ ta̱ adama a uwwa Yahaya.
\v 6 Ana a dammai nusu le a alanga e eteshe, a̱vu u rumbu† le o uɗoluꞌu.
\p 
\v 7 Afarishi† na aza a Sadukiya na̱ a̱bunda̱ a̱ ta̱wa̱ ta̱ uba̱ta̱ u na Yahaya shi a̱ rumbusu ama tsa̱ra̱ u rumbu le. Ana Yahaya ene nle, reve u damma, “Suru nɗu apili a ɗa! Zane ɗa damma nɗu i suma a̱tsuma̱lima̱ a na A̱sula̱ a̱ ri lo a̱ ta̱wa̱a̱?
\v 8 I yuwan ili i na yoo roco i lyawa ta̱ nusu ɗu.
\v 9 She i jiyan yoo sowo a̱tsuma̱lima̱ shi, adama a na yaa dansa Ibrahim akaya a̱ ɗu a ɗa. N ta dansaa ɗu A̱sula̱ a ta gura tara atali a nda, reve u vazatowo Ibrahim muwun n tsukaya!
\v 10 Ko gogo tsunda, aaɓau a̱ ta̱ lo ufoɓu adama wu koɗo ɗanga a aralu e le. Uɗanga u na u matsain muwun n saꞌani shi, suru o to koɗo yi reve a vari yi akina.
\p 
\v 11 “N ta̱ rumbusu ɗu na̱ mini adama u roco i vadala† ta̱, amma za na ri lo a̱ ta̱wa̱ a̱ca̱pa̱ a̱ va̱ u ta̱ rumbu ɗu na̱ Ruhu va Akiza na akina. U laꞌa mu ta̱ tsugbain lon, agba n rawa n guza̱a̱ yi atan shi.
\v 12 U tu ufoɓu na aaɗanga a faba na aakpatalutsu o uyeluwu adama u zangaɗa ishina. U ta kakasa ishina no owopo. Reve u tsun ishina i saꞌani o mopon ma̱ yi, owopo gba shi a̱vu u kula̱to le na akina a na a̱ ri n kima̱ shi.”
\s1 Yahaya rumbuyi Yesu
\p 
\v 13 A mantsa mo ndolo ma ɗa Yesu uta̱i Ga̱lili, reve u ꞌya̱wa̱ o Uɗolu wa̱ Urdu adama Yahaya rumbu yi.
\v 14 Agba a̱vu Yahaya shi ciga u ꞌyuwan a yuwan yi, a̱vu u damma, “A̱vu ɗa za na a̱a̱ rumbu mu. Cine tsa ɗa va̱a̱ ta̱wa̱ ya̱ꞌa̱ va̱?”
\p 
\v 15 Reve Yesu usu, “Ne ɗa u lobonoi wo oꞌwo gogo, adama tsu yuwan ili i na A̱sula̱ a cigai tsu yuwan.” Ɗaɗa Yahaya usuyi u rumbu yi.
\p 
\v 16 Ɗaɗa u rumbuyi† Yesu. Yesu o utushi a̱ miniꞌi, ɗaɗa zuva kpa̱tuꞌwa̱i, a̱vu we ene Ruhu va̱ A̱sula̱ e telee yi ana muɗa. \fig Urumbusu wa̱ Yesu|src="Matthew_3_13.tif" size="span" loc="Matthew 3:16" ref="Mat. 3:16"\fig*
\v 17 Ɗaɗa uɗyo diga zuva wa damma, “A̱yi nda Mawun ma̱ va̱ ma ɗa, za na n cigai, waru n ta yuwusan ma̱za̱nga̱ na̱ a̱yi lon.”
\c 4
\s1 Yesu na̱ Mekerenkesu
\r (Mak. 1:12-13; Luk. 4:1-13)
\p 
\v 1 Reve Ruhu va Akiza† tara Yesu a̱ tyo a̱tsuma̱ o una, adama Mekerenkesu† ma̱ lyungwa̱ yi.
\v 2 Agba Yesu lyuwa ili shi, hali rana na ayin amunga. Adama o ndolo, wu uwwa ta̱ ambulu lon.
\v 3 Reve Mekerenkesu ma̱ ta̱wa̱ a̱vu u damma yi, “Na̱ a̱vu Mawun ma̱ A̱sula̱ ma ɗa, ka̱mba̱to atali a nda o oꞌwo opopofu.”
\p 
\v 4 A̱vu u usu, “A ɗana ta̱ a Adanshi a̱ A̱sula̱,†
\q1 ‘Na alya e ilyalya i ɗa goon vuma a̱a̱ da̱na̱ wuma shi,
\q1 amma she ni ili i na A̱sula̱ a dammai biti.’ ” \x ◊ \xo 4:4 \xt U.Wl. 8:3.\x*
\p 
\v 5 Reve Mekerenkesu ma tara yi a̱ tyo Urishelima lyuci va akiza, reve u zuwa yi ɗe e ncilecile ma̱ A̱a̱ꞌisamapaɗa.†
\v 6 A̱vu u damma yi, “Na̱ a̱vu Mawun ma̱ A̱sula̱ ma ɗa, teteruwe e iɗa, adama a na a ɗana ta̱ a̱tsuma̱ a Adanshi a̱ A̱sula̱:
\q1 ‘A̱sula̱ a ta zuwa nlingata ma̱ yi n tiga̱ wu,
\q1 e te keɗe wu ne ekere e le,
\q1 adama vu ta̱ɗa̱tsa̱ a aatali vu uwwa usa̱n wan.’ ” \x ◊ \xo 4:6 \xt Ica 91:11-12.\x*
\p 
\v 7 Reve Yesu usu, “Amma Adanshi a̱ A̱sula̱ fo a damma ta̱, ‘She vu lyungwa̱ Zagbain A̱sula̱ a̱ wu wan.’ ” \x ◊ \xo 4:7 \xt U.Wl. 6:16.\x*
\p 
\v 8 Reve Mekerenkesu ma tara Yesu a̱ tyo zuva masasan mo ugaꞌan, a̱vu u roco yi tsugono tsu uvaɗi suru na̱ tsugbain tse ele.
\v 9 Reve u damma, “Na̱ va̱a̱ ka̱ɗa̱to vu yuwaan mu a̱ga̱nda̱, n ta ca wu ili i nda suru.”
\p 
\v 10 A̱vu Yesu usu, “Buwaa mu ure Male!† Adanshi a̱ A̱sula̱ a damma ta̱,
\q1 ‘Vu yuwaan Zagbain A̱sula̱ a̱ wu a̱ga̱nda̱, a̱yi a̱ ndeꞌen ɗa vaa yuwaan tsugbashi!’ ” \x ◊ \xo 4:10 \xt U.Wl. 6:13.\x*
\p 
\v 11 Ɗaɗa Mekerenkesu ma lyawai Yesu, a̱vu nlingata ma̱ A̱sula̱ n ta̱wa̱ n kamba yi.
\s1 Yesu temei ulinga wa̱ yi
\r (Mak. 1:14-15; Luk. 4:14-15)
\p 
\v 12 Ana Yesu uwwai a zuwa ta̱ Yahaya o uꞌwa wa ali, a̱vu u ka̱mba̱ e iɗa ya̱ Ga̱lili.
\v 13 U fara ta̱ ꞌya̱wa̱ a̱ lyuci va Nazara, a̱vu u ꞌyon u ka̱ra̱ a̱ tyo Kafarnahum na̱ nden, a̱ mɓa̱nga̱ m Mala ma̱ Ga̱lili, upasu wi iɗa ya Zebelun na̱ Nafutali.
\v 14 Ne ɗa nzuwulai ma̱ A̱sula̱ n shiwain ununa Ishaya vumava̱sula̱ dammai:
\q1 
\v 15 “A̱tsuma̱ e iɗa ya Zebelun na̱ Nafutali,
\q1 o ure a̱ tyo a mala, upasalai wu Uɗolu wa̱ Urdu,
\q1 a̱tsuma̱ a̱ Ga̱lili uba̱ta̱ u na Atakpaci† na̱ a̱bunda̱ a̱ ri nden.
\q1 
\v 16 Ama a nda a na a̱ ri nden a̱tsuma̱ e irumbu
\q1 e te ene ekan a gbain.
\q1 A̱ ta̱ nden uba̱ta̱ u na u ri ukpa̱towu na̱ lulu vu ukwa̱,
\q1 amma ekan e te ikana le.” \x ◊ \xo 4:16 \xt Isha. 9:1-2.\x*
\p 
\v 17 Diga lo ɗa Yesu temei alajiya adansa, “Vadalai a̱ nusu ɗu i ka̱mba̱ uba̱ta̱ wa̱ A̱sula̱, adama a na tsugono tsa zuva tsa yuwan ta̱ zuzu.”
\s1 Yesu ɗangulai ama a̱ na̱shi a̱za̱ e mereme ma mugula
\r (Mak. 1:16-20; Luk. 5:1-11)
\p 
\v 18 Urana u ro, Yesu a mmalu a̱ ngeꞌen m Mala ma̱ Ga̱lili, a̱vu we ene ama e re muwun ma̱ a̱na̱wu. Za ta̱ aala a̱ yi a ɗa Simo za na waru e revei na aala Bituru, za ve ire gba a̱yi ɗa Andarawu. A̱za̱ e mereme ma mugula n ɗa, a̱ shi ta̱ a varishi igolo i le a mala.
\v 19 A̱vu u damma le, “Ta̱wa̱i i kuru mu! N to roco ɗu ununa ya̱a̱ ta̱wa̱a̱ na ama o una̱ u mugula.”
\v 20 Lo ɗa a̱ ꞌyoshin a lyawai igolo i le, reve a̱ kuru yi.
\p 
\v 21 Ana u lyuwai elime, reve u cina ama e re muwun ma̱ a̱na̱wu waru, Yakubu na̱ Yahaya, olobo a̱ Za̱ba̱di. A̱ shi ta̱ a wantsun u le oɓolo na̱ dada le, o foɓuso igolo i le. A̱vu u damma le a̱ kuru yi.
\v 22 Ɗaɗa a lyawushi wantsun u le na aabara e le, reve a̱ kuru yi.
\s1 Yesu yuwan ta̱ uritosu
\p 
\v 23 Yesu ꞌya̱wa̱ ta̱ uba̱ta̱ suru a̱tsuma̱ a̱ Ga̱lili. U ritosu ta̱ a̱tsuma̱ a̱ a̱ꞌisa̱. Waru u yuwusan ta̱ alajiya a Alabari a Saꞌani† o tsugono tsa zuva. A̱vu waru u ka̱mba̱tosu a̱za̱ o ubanakun na̱ a̱za̱ a̱ mɓa̱la̱ gbaga.
\v 24 A̱vu alabari a̱ yi o uta̱ a alanga a̱tsuma̱ e iɗa ya̱ Ga̱lili, adama o ndolo a ɗa a̱za̱ o ubanakun, hali na aza a na a̱ ri e iɗa ya Suriya, a̱ ta̱wusa̱i adama a̱ ka̱mba̱to le gbaga a banakun icuꞌun icuꞌun na̱ mɓa̱la̱ n lipu. Ozo o ro e le a̱ shi ta̱ no otoni a̱ lima̱ na̱ a̱bunda̱, ozo o ro gba shi a̱ shi ta̱ a̱tsuma̱lima̱ na̱ tsudaꞌun, ozo o ro waru gba a̱kutsuma̱ a ɗa a̱ shi. A̱vu gba Yesu ka̱mba̱to le gbaga suru.
\v 25 A̱vu oɓolo a amaꞌa na̱ a̱bunda̱ a̱ kuru yi uba̱ta̱ u na u ꞌya̱wa̱i suru: ama diga Ga̱lili, na̱ Dikafoli,\f + \fr 4:25 \ft Dikafoli urevu wa̱ yi, a̱yi ɗa Mulyuci Kupa.\f* na̱ Urishelima, na̱ Yahuda suru, na̱ diga asana o Uɗolu wa̱ Urdu.
\c 5
\s1 Yesu yuwain uritosu a masasan
\p 
\v 1 Ana Yesu enei oɓoloꞌo, reve u kumba a aagaɗi a masasan a̱vu u da̱nu. A̱vu aza a na oo tono yi a rawa zuzu,
\v 2 ɗaɗa u uwai o ritosu le.
\s1 Abaꞌun a amayun
\r (Luk. 6:20-23)
\q1 
\v 3 “Aza a abaꞌun a ɗa aza a na e revei aa gura yuwan ili i ro na aciyele shi, ɗaɗa e isawain uba̱ta̱ wa̱ A̱sula̱ goon.
\q1 Tsugono tsa zuva za le ɗa!
\q1 
\v 4 Aza a abaꞌun a ɗa aza a na a̱ ri a̱ a̱tsumola̱ngu,
\q1 adama a na A̱sula̱ a̱ ta̱ ta̱na̱to okolo e le.
\q1 
\v 5 Aza a abaꞌun a ɗa aza a na a tarai aciyele ili i ro shi,
\q1 adama a na uvaɗi u to oꞌwo za le.
\q1 
\v 6 Aza a abaꞌun a ɗa aza a na a̱ ri na akuli na ambulu adama e ili i na A̱sula̱ a cigai o una̱ wi ili ya alya ni ili yo oso,
\q1 adama a na A̱sula̱ a̱ ta̱ cuwa̱ton le.
\q1 
\v 7 Aza a abaꞌun a ɗa aza a na oo rocosu ozo o ro isaꞌani,
\q1 adama a na A̱sula̱ o to roco le isaꞌani fo.
\q1 
\v 8 Aza a abaꞌun a ɗa aza a na okolo e le a̱ ri cece,
\q1 adama a na a̱ ta̱ da̱nu oɓolo na̱ A̱sula̱.
\q1 
\v 9 Aza a abaꞌun a ɗa aza a na aa yuwusan ulinga adama a̱ nden n saꞌani,
\q1 adama a na A̱sula̱ a̱ ta̱ ɗe le muwun ma̱ yi.
\q1 
\v 10 Aza a abaꞌun a ɗa aza a na o sowoi a̱tsuma̱lima̱ a̱ ma̱lyungwa̱,
\q1 adama a na aa yuwusan ili i na A̱sula̱ a cigai,
\q1 adama a na tsugono tsa zuva za le ɗa.
\p 
\v 11 “A̱sula̱ a ta zuwaa ɗu abaꞌun a mantsa ma na ama e isula nɗu. A̱sula̱ a ta zuwaa ɗu abaꞌun nna ama a̱ lyungwa̱ ɗu. A̱sula̱ a ta zuwaa ɗu abaꞌun nna ama a yuwaan ɗu cuꞌun ve epen suru adama a̱ va̱.
\v 12 Ama a̱ ta̱ lyungwa̱ ɗu cine a̱ lyungwa̱i ama̱sula̱ a na a yuwain wuma ɗe nu ujimu. I yuwan ma̱za̱nga̱, reve waru asuvu a̱ ɗu o yoꞌono, adama a na i ta̱ ni iliyinkapa ya̱ a̱bunda̱ a pura ɗu ɗe zuva.”
\s1 Akpaɗi ne ekan
\r (Mak. 9:50; Luk. 14:34-35)
\p 
\v 13 A̱vu Yesu lyuwa elime na adanshi, “A̱ɗu ɗa akpaɗi o uvaɗi. Agba ulobonu u ne u ɗa akpaɗi a̱ ri nna a buwa peme shi? I ta gura zuwa le u yoꞌoniso? O to oco le reve a dasa le na ana, cine vu revei ili ye pere.
\p 
\v 14 “A̱ɗu ɗa aza a na aa casu uvaɗi ekan. Yaa gura paꞌaton lyuci na ri usuwu a masasan shi.
\v 15 Waru a tsu kaɓato fitila reve a̱ kpa̱to yi na aasaꞌatsu shi. E eelele a ɗa a̱ tsu zuwa yi adama ekan e ikana, tsa̱ra̱ ama a na a̱ ri pe o uꞌwaꞌa suru e ene ure.
\v 16 Ne ɗa fo, yo oꞌwo ekan e ekere a ama o ro. I yuwan ili i saꞌani i na ee ene adama a ciɓala Dada ɗu na ri zuva.”
\s1 Uritosu wa̱ Yesu adama a̱ Wila̱
\p 
\v 17 Reve Yesu lyuwa elime u damma, “She i jiyan n ta̱wa̱ ta̱ adama n lungusa̱ Wila̱† wa Musa ko ili i na ama̱sula̱ o ritoi wan. N ta̱wa̱ adama n lungusa̱ le shi, amma adama n shiton uritosu u le.
\v 18 Amayun a ɗa maa dansaa ɗu, ko ili i ta̱ ya̱a̱ pusa̱n a̱tsuma̱ a̱ Wila̱ꞌa̱ shi, she ni iɗa na̱ zuva o koto. Ko ɗani a̱a̱ puwa̱n shi waru ko madaɓi me iɗani ma̱a̱ puwa̱n shi, she ni ili biti i shiwan.
\v 19 Ni i ꞌyuwan ko Wila̱ u keꞌen u na u laꞌai uka̱la̱mu wi ili i na aa yuwan, a̱vu waru i roco ozo o ro a yuwan ne, a̱ɗu ɗa yoo oꞌwo nkosoto a̱tsuma̱ o tsugono tsa zuva. Amma ni i kuru a̱vu waru i roco ozo o ro ili i na u dammai, i ta̱ tsura̱ uba̱ta̱ u saꞌani a̱tsuma̱ o tsugonoꞌo.
\p 
\v 20 “Munlu n Wila̱ na Afarishi a ta yuwusan a̱tyo a na aa yuwan adama a̱ kuru Wila̱ wa̱ A̱sula̱ mejege. I ciga i ꞌyuwan i laꞌa le a̱tsuma̱ e itoni ya̱ A̱sula̱. Ni i yuwan ne shi, n ta dansaa ɗu amayun, yaa uwa o tsugono tsa zuva shi.”
\s1 Uritosu wa̱ Yesu adama o upan
\r (Luk. 12:58-59)
\p 
\v 21 Reve Yesu lyuwa elime na adanshi u damma, “Yu uwwa ta̱ a na Wila̱ wa Musa u dammai, ‘She vu una vuma nu ucigu wa̱ wu wan.’ Waru, ‘Za na unai suru a ciga a ꞌyuwan e geꞌeto yi.’ \x ◊ \xo 5:21 \xt Mta̱. 20:13; U.Wl. 5:17.\x*
\v 22 Gogo gba n ta dansaa ɗu: na̱ vu yuwan upan na̱ za va̱ wu, a̱ ta̱ geꞌeto wu. Na̱ vu ɗe za va̱ wu, ‘A̱a̱ta̱mu,’ a ta tara wu a̱ tyo uba̱ta̱ wa Azagbain a Mbara.† Na̱ vu ɗe za va̱ wu, ‘A̱vu a̱a̱ta̱mu za na ri na̱ a̱ɓula̱ shi,’ vu ta̱ zuzu na vaa uwa a akina a na a̱ ri n kima̱ shi.
\p 
\v 23 “Adama o ndolo, na̱ vu ri mishin uba̱ta̱ u masaꞌa† a̱ A̱a̱ꞌisamapaɗa a casu uneꞌe uba̱ta̱ wa̱ A̱sula̱, reve vu cuwushin vuma ro damma ta̱ vu nusaan yi ta̱,
\v 24 vu lyawa ɗe ili i na vu ta̱wa̱yi uba̱ta̱ u masaꞌaꞌa. A̱vu vu ꞌya̱wa̱ i sa̱la̱la̱i na̱ vumaꞌa, reve ka̱mba̱ vu ca uneꞌe wa̱ wu.
\p 
\v 25 “Na̱ vuma ri na adanshi na̱ a̱vu, a̱vu u ciga u tara wu a̱ tyo uba̱ta̱ o ugeꞌetosu, i lapula adanshi a̱tsuma̱ a mantsa, kafu i rawa o ukobu wu ugeꞌetosu. Na̱ vu yuwan ne shi, na̱ vu rawa ɗe, a ta tara wu a̱ tyo uba̱ta̱ wu za vu ugeꞌetosu. Reve u zuwa wu e ekere a̱ mumaɗanga, aza a na a zuwa wu o uꞌwa wa ali.
\v 26 N ta dansaa wu amayun, voo uta̱ pe shi, she na̱ vu tsupa ili i na oo tono wu.”
\s1 Uritosu adama e tsipere
\p 
\v 27 Reve Yesu lyuwa elime, “Yu uwwa ta̱ a na Wila̱† wa Musa u dammai, ‘She vu yuwan tsipere wan.’ \x ◊ \xo 5:27 \xt Mta̱. 20:14.\x*
\v 28 A̱mu gba n ta dansaa ɗu, na̱ vu ka̱lyuwa̱ ka, reve asuvu a̱ wu a̱ ꞌya̱wa̱ ya̱ꞌa̱ yi, vu yuwan ta̱ ɗe tsipere na̱ a̱yi o okolo a̱ wu.
\v 29 Na̱ lyusu vu usaꞌani va̱ wu waa zuwusa wu vu yuwan unusu, vu foɗo yi vu vari yi. U ta laꞌaa wu vu lamba upasu u ta̱ u lipu va̱ wu, a na lipu va̱ wu suru aa uwa a akina.
\v 30 Nu ukere usaꞌani wa̱ wu waa zuwusa wu vu nusan, vu koɗo yi vu vari! U ta laꞌaa wu vu lamba upasu u ta̱ u lipu va̱ wu a na lipu va̱ wu suru aa uwa a akina.”
\s1 Uritosu adama a wukasu u lolo
\r (Mat. 19:9; Mak. 10:11-12; Luk. 16:18)
\p 
\v 31 Reve u lyuwa elime u damma, “Yu uwwa ta̱ a na Wila̱ wa Musa u dammai, ‘Vuma ta gura kakasa na̱ ka va̱ yi nu u ca yi aatagada a wukasu u lolo.’
\v 32 A̱mu gba n ta dansaa ɗu, she vuma kakasa na̱ ka va̱ yi wan, she nu u yuwan tsipere na̱ vali ro. Na̱ wu kasa na̱ a̱yi u ta zuwa yi wo oꞌwo aashakala, ununa za na tara niyi suru ri nu unusu u tsipere adama a na u zuwa niyi.”
\s1 Uritosu adama a akucunu
\p 
\v 33 Reve waru Yesu lyuwa elime na adanshi u damma, “Yu uwwa ta̱ a na Wila̱ wa Musa u dammai, ‘She vu kuɗa akucunu a̱ wu wan. Ciga ꞌyuwan vu shiton akucunu a na vu yuwayin A̱sulazuva.’ \x ◊ \xo 5:33 \xt N.Gn. 19:12; Mkc. 30:2; U.Wl. 23:21.\x*
\v 34 A̱mu gba n ta dansaa ɗu, i kucina ko ni ili i ro wan, a mantsa ma na yaa yuwusan akucunu! Zuva uba̱ta̱ u na A̱sula̱ a̱ ri na̱ nden ɗa, adama o ndolo she i yuwan akucunu na̱ zuva wan.
\v 35 Iɗa udasata wa̱ A̱sula̱ u ɗa, adama o ndolo she i kucina ni iɗa wan. Urishelima lyuci Mogono ma Gbain ma ɗa, adama o ndolo she i kucina na̱ a̱yi wan.
\v 36 She i kucina na aci a̱ ɗu wan. Yaa gura zuwa a̱nji a̱ ta̱ a̱ ɗu wo oꞌwo uꞌuri ko ulima̱ shi.
\v 37 A mantsa ma na vaa yuwusan akucunu, vu damma ‘Ee’ ko ‘Oꞌo.’ Na̱ vu damma ili i na i laꞌai ‘Ee’ ko ‘Oꞌo,’ wu uta̱ ta̱ uba̱ta̱ wu za wuya.”
\s1 A yuwan gafura
\r (Luk. 6:29-30)
\p 
\v 38 A̱vu Yesu lyuwa elime na adanshi, reve u damma, “Yu uwwa ta̱ a na Wila̱ wa Musa u dammai, ‘Nna̱ za amaton nanza a̱ lyusu ko a aanga, nu u ciga u ꞌyuwan u tsupa vumaꞌa lyusu ko aanga o ro na̱ za va̱ yi.’ \x ◊ \xo 5:38 \xt Mta̱. 21:24.\x*
\v 39 Gogo gba n ta dansaa ɗu: na̱ za ro nusaan wu, she vu tsupa wan. Nna̱ za ro ɓasa wu o ugbaguzu wu ukere usaꞌani vu lyawa yi u koso ɓasa wu o ugbaguzu wu ukere wu ugula̱.
\v 40 Na̱ wo oꞌwo za ro damma vu nusaan yi ta̱, reve u damma za vu ugeꞌetosu u zuwa wu vu ca yi utugu wa̱ wu, vu ca yi aapalutsu a̱ wu fo.
\v 41 Na̱ soja zuwa wu vu tanu itana ya̱ yi mili ta̱, tanu le a̱ tyo imili i re.
\v 42 Na̱ vuma ro pati wu ili i ro, vu ca yi. Na̱ vuma ro ece wu okopu, vu ca yi.”
\s1 Icigi yi nꞌyuwatan
\r (Luk. 6:27-28, 32-36)
\p 
\v 43 A̱vu Yesu lyuwa elime reve u damma, “Yu uwwa ta̱ a dammai, ‘Vu ciga moron ma̱ nden ma̱ wu, reve vu ꞌyuwan nꞌyuwatan ma̱ wu.’
\v 44 A̱mu gba n ta dansaa ɗu, i ciga nꞌyuwatan n ɗu, reve i yuwaan aza a na oo ɓongishi ɗu avasa.
\v 45 Ni i yuwan ne, i to oꞌwo muwun ma amayun ma Dada ɗu na ri zuva. U tsu zuwa ta̱ urana wu uta̱ uba̱ta̱ wa ama a̱ a̱ɓula̱ nu uba̱ta̱ wa ama a vama. Waru u tsu yuwan ta̱ iroꞌi uba̱ta̱ wa aza a na aa yuwusan ili i na i ri mejege nu uba̱ta̱ wa aza a na aa yuwusan ili i babu ulobonu.
\v 46 Cine A̱sula̱ aa zuwaa ɗu abaꞌun, ni i ciga aza a na a ciga nɗu goon? Ko munlu mu utafa fo a ta yuwusan ne!
\v 47 Waru nni i lobonoto aciya̱ɗu e ekere a̱ nꞌutsa̱ n ɗu goon, i laꞌa akapi a ama shi. Ko aza a na e revei A̱sula̱ shi, o tsu lobonoto ta̱ aciyele e ekere a̱ nꞌutsa̱ n le.
\v 48 Adama o ndolo, yo oꞌwo a̱za̱ a̱ a̱ɓula̱, ununa Dada ɗu za na ri zuva ri na̱ a̱ɓula̱.”
\c 6
\s1 Uritosu adama o ucasu
\p 
\v 1 A̱vu Yesu lyuwa elime o ritosu aza a na oo tono yi a̱vu u damma, “I yuwan ugbozu! A mantsa ma na yaa yuwusan ili i saꞌani, she i yuwan adama ama e ene a cuwa ɗu wan. Ni i yuwan ne, ya̱a̱ tsura̱ iliyinkapa uba̱ta̱ wa Dada ɗu za na ri zuva shi.
\p 
\v 2 “A mantsa ma na yaa casu alambi, she i ca le ununa a̱za̱ e ikpaꞌa a tsu yuwan wan. A̱ tsi ivula̱ ta̱ avana a̱tsuma̱ a̱ a̱ꞌisa̱ ne e re adama ama e ene le a cuwa le. Amayun a ɗa maa dansaa ɗu, a̱za̱ e ikpaꞌa o ndolo a̱ ushi ta̱ ɗe iliyinkapa i le.
\v 3 Adama o ndolo a mantsa ma na yaa yuwusaan alambi uneꞌe, i yuwan yi usokowu ununa ukere ugula̱ wa̱ wu wee reve ili i na ukere usaꞌani wa̱ wu waa yuwusan shi.
\v 4 I ca uneꞌe u ɗu usokowu, ne ɗa Dada ɗu na revei ili i na i ri usokowu suru, waa ca ɗu iliyinkapa.”
\s1 Uritosu adama a avasa
\r (Luk. 11:2-4)
\p 
\v 5 Reve Yesu lyuwa elime na adanshi u damma, “A mantsa ma na i ri a avasa, she yo oꞌwo ana a̱za̱ e ikpaꞌa wan! A tsu laꞌa ta̱ ciga e isawan a̱ a̱ꞌisa̱ na̱ a̱ ngeꞌen mu re a yuwusan avasa adama ama e ene le. Amayun a ɗa maa dansaa ɗu, a̱ ushi ta̱ ɗe iliyinkapa i le suru suru.
\v 6 A mantsa ma na yaa yuwan avasa, i uwa a aasula reve i ɓa̱ru una̱ntsu. Reve i yuwan avasa a̱ tyo ya Dada ɗu na ri uba̱ta̱ o usokowuꞌu. Ne ɗa Dada ɗu za na tse ene ili i na yaa yuwusan usokowu, waa ca ɗu iliyinkapa i ɗu.
\v 7 Waru a mantsa ma na i ri avasa, she yoo oꞌwo ana aza a na e revei A̱sula̱ shi wan. Adama a na a̱ tsu ka̱mbuwusa̱ ta̱ ili i na i ri na aci shi. A ta zuwusa A̱sula̱ a ta uwwa le adama a̱ a̱bunda̱ a adanshi e le.
\v 8 She yo oꞌwo ana ele wan. Adama a na Dada ɗu reve ta̱ ɗe ili i na i cigai kafu i pati yi.
\p 
\v 9 “Adama o ndolo, na̱ yaa yuwan avasa, i vasa tsunda:
\q1 ‘Dada tsu na ri zuva,†
\q1 kamba tsu tsu ca aala a̱ wu tsugbain.
\q1 
\v 10 Tsugono tsa̱ wu tsa̱ ta̱wa̱,
\q1 adama vuma biti o uvaɗi u yuwan tsutoni na̱ a̱vu,
\q1 Ununa aa yuwusan tsutoni na̱ a̱vu zuva.
\q1 
\v 11 O urana wa anaꞌan vu ca tsu ilyalya i malya.
\q1 
\v 12 Vu yuwaan tsu gafura vu nusu u tsu,
\q1 adama a na a̱tsu tsaa yuwusaan aza a na aa yuwusan tsu unusu gafura.
\q1 
\v 13 She vu lyawa tsu tsu uwa a̱ ma̱lyungwa̱ wan,
\q1 agba vu wawa tsu e ekere a za wuya.’\f + \fr 6:13 \ft Akuci a atagada a̱ da̱shi ta̱, “Tsugono na̱ tsugbain nu ucira za va̱ wu ɗa babu ukotu suru suru, ami.”\f*
\p 
\v 14 “Amayun nni i yuwaan ozo o ro gafura vu nusu le, Dada ɗu na ri zuva u ta yuwaan ɗu fo gafura vu nusu ɗu.
\v 15 Amma ni i yuwaan ozo o ro gafura shi, Dada ɗu na ri zuva waa yuwaan ɗu gafura vu unusu u ɗu shi.”
\s1 Uritosu adama a akuli
\p 
\v 16 Reve Yesu lyuwa elime na adanshi u damma, “A mantsa ma na yaa yuwusan akuli, she i lukuta̱ urewesu u ɗu ununa a̱za̱ e ikpaꞌa a yuwusan wan. A tsu vadala ta̱ o oꞌwo ili i ro koꞌo adama ama e reve a na a̱ ri a akuli. Amayun n ta dansaa ɗu, a̱za̱ e ikpaꞌa o ndolo a̱ tsura̱ ta̱ ɗe iliyinkapa i le suru suru.
\v 17 Amma a mantsa ma na i ri a akuli, i saꞌa urewesu u ɗu a̱vu yi sara a̱nji a̱ ɗu.
\v 18 Ne ɗa za ee reve a na i ri a akuli shi, she de Dada ɗu, za na ri uba̱ta̱ o usokowu suru. Waru a na u revei ili yu usokowu suru, u ta ca ɗu iliyinkapa.”
\s1 Utsuru zuva
\r (Luk. 12:33-34)
\p 
\v 19 Yesu lyuwa ta̱ elime adansa, “She i ɓolotowo aciya̱ɗu uzuwa pa o uvaɗi wan! Ikupu na̱ matsafi ma̱ ta̱ lungusa̱ le, waru evu a ta gura ɓoso a uwa pe e iva̱ le.
\v 20 Amma, i yuwan izuwa i ɗu zuva, uba̱ta̱ u na ikupu na̱ matsafi ma̱a̱ lungusa̱ le shi, waru evu aa gura ɓoso a uwa pe e iva̱ le shi.
\v 21 Okolo a̱ ɗu a̱ ta̱ da̱na̱ uba̱ta̱ u na uzuwa u ɗu u ri kuci.
\s1 Ekan a̱ lipu
\p 
\v 22 “Esu ele ɗa o oꞌwoi ana fitila lipu. Ne esu a̱ wu a̱ ri ulobonu, lipu va̱ wu suru u to oꞌwo ne ekan ma̱ɓula̱.
\v 23 Amma ne esu a̱ wu a̱ ri ulobonu shi, lipu va̱ wu ma̱ɓula̱ u ta̱ da̱na̱ a̱tsuma̱ e irumbu. Ne ekan a na a̱ ri pe ya̱ꞌa̱ wu wo oꞌwo irumbu, to, amayun vu ta̱ a̱tsuma̱ e irumbu i gbain.
\s1 A̱sula̱ nu utsuru u vuma
\r (Luk. 16:13)
\p 
\v 24 “Ko za lo aa gura yuwaan azagbain e re tsugbashi shi. Vu ta ꞌyuwan za ta̱, reve vu ciga za ta̱. Ko vu kuru za ta̱, reve vu ꞌyuwan a̱ kuru za ta̱. Vaa gura yuwaan A̱sula̱ nu utsuru a̱ga̱nda̱ shi.”
\s1 She vu dama wan
\r (Luk. 12:22-31)
\p 
\v 25 Reve Yesu lyuwa elime na adanshi, “N ta dansaa ɗu, she i dama adama e ilyalya ni ili yo oso i na i cigai adama yo oꞌwo wuma wan. She i dama adama e itana yu uꞌotosu i lipu i ɗu wan. Wuma u laꞌa ta̱ ilyalya, waru lipu laꞌa ta̱ itana i lipu.
\v 26 Ka̱lyuwa̱i nnunu! A̱ tsu cuꞌwa̱n shi, agba aa gasa shi. A tsu zuwa ilyalya o mpon shi. Agba suru na̱ ne Dada ɗu na ri zuva u ta̱ ka̱lyuwusa̱ le. Agba i reve ta̱ na i laꞌai nnunu pepere.
\v 27 Yaa gura da̱shi ko mini\f + \fr 6:27 \ft Pa nda mini u ta yuwusan adanshi a mantsa waꞌa a̱yi ɗa Agana a̱ tsu ɗe “minti” va̱ a̱gogo.\f* ma̱ ta̱ a wuma u ɗu shi ni i dama adama a̱ yi.
\p 
\v 28 “Adama a̱ nye vu damai adama e itana yu uꞌotosu? Ka̱lyuwa̱i ununa yipa̱lu yu una i tsu kungwa. A tsu yuwan ulinga adama a yuwan itana i le shi.
\v 29 Amma n ta dansaa ɗu, ko Sulemanu† nu utsuru wa̱ yi suru, wo oto itana i saꞌani reve u lobono vadamma za ta̱ le shi.
\v 30 A̱sula̱ o to foɓuso anlya o ogozo, aza a na a̱ ri wuma anaꞌan, nfaꞌan gba shi a̱ kula̱to. U lobono ta̱ i gura reve A̱sula̱ a ta ca ɗu itana yu uꞌotosu. She i da̱na̱ nu ucawu wo okolo waꞌa wan!
\v 31 She i dama wan hali i damma, ‘Nye tsaa lyuwa?’ ko ‘Nye tsoo sowo?’ ko ‘Nye tsoo oto?’
\v 32 Ama a na e revei A̱sula̱ ɗa shi goon a tsu dama adama e ili i ndolo. Dada ɗu na ri zuva reve ta̱ na i cigai ili i ndolo suru.
\v 33 Ili i na yaa laꞌa ciga a̱yi ɗa tsugono tsa̱ A̱sula̱, reve waru i yuwan ili i na A̱sula̱ a cigai. Reve a ca ɗu akapi e ili i na i cigai suru.
\v 34 Adama o ndolo, she i dama adama a nfaꞌan wan, adama a na nfaꞌan ta dama adama a aciya̱yi. Adama o ndolo she i da̱shi addama a aci a addama na urana suru wa̱a̱ ta̱wa̱a̱ wan.”
\c 7
\s1 She i geꞌeto wan
\r (Luk. 6:37-38, 41-42)
\p 
\v 1 A̱vu Yesu lyuwa elime o ritosu aza a na oo tono yi, reve u damma, “She i geꞌeto za ro wan, adama A̱sula̱ e geꞌeto ɗu wan.
\v 2 Na̱ makundatsu ma na i geꞌetoi ozo o ro, na̱ a̱yi ɗa aa yuwaan ulinga e geꞌeto ɗu.
\p 
\v 3 “Nye i zuwai va̱a̱ ka̱nla̱sa̱ macaka ma na ma̱ ri pe a̱ lyusu vu za va̱ wu, reve vi icina na̱ a̱a̱gba̱la̱ a na a̱ ri pe a̱ lyusu va̱ wu?
\v 4 Cine vaa gura damma za va̱ wu, ‘Lyawa mu uta̱a̱ macaka ma na ma̱ ri a̱ lyusu va̱ wu?’ Vu ka̱lyuwa̱ aciya̱wu! A̱vu gba vu buwa ta̱ na̱ a̱a̱gba̱la̱ o ndolo a̱ lyusu va̱ wu.
\v 5 A̱vu za vi ikpaꞌa! Uta̱a̱ neꞌen a̱a̱gba̱la̱ a na a̱ ri a̱ lyusu va̱ wu, reve ve ene ulobonu ununa voo uta̱a̱ macaka ma na ma̱ ri a̱ lyusu va̱ yi.
\p 
\v 6 “She i ca musa̱n ili i na i ri za va̱ A̱sula̱ wan. A ta vadala aa amaton wu. She i variya ngurusumu iyeɗi yi ikebe† wan. A ta dadasa le.”
\s1 Pati, zami, gugula
\r (Luk. 11:9-13)
\p 
\v 7 Reve waru Yesu dammisa, “I lyuwa elime ni ipati, a ta ca ɗu ili i na ya patishi. I zamishi, i ta̱ tsura̱. Yi gulusa a yuwusan ‘A̱zoꞌwa,’ A̱sula̱ a ta zuwa a̱ kpa̱tuꞌwa̱a̱ ɗu una̱ntsu.
\v 8 Adama a na za vi ipati suru a tsu ca yi ta̱. Waru za vi izami suru, u ta̱ tsura̱. Waru nna ama a lyuwa elime na̱ wugulusa, A̱sula̱ a̱ ta̱ kpa̱tuꞌwa̱a̱ le.
\p 
\v 9 “A̱tsuma̱ a̱ ɗu zane ɗa aa ca mawun ma̱ yi aatali, nna̱ mawuꞌun u pati yi ilyalya?
\v 10 Vu ta ca yi aagbaji, nna̱ u pati wu magula?
\v 11 A̱ɗu na i ri a̱za̱ o unusu, i reve ta̱ cine yaa ca muwun n ɗu ili i saꞌani. Dada ɗu gba na ri zuva, za na ri na̱ a̱ɓula̱, u tu ufoɓu u na waa ca aza a na a pati niyi ili i saꞌani!
\v 12 Ununa i cigai ama a yuwaan ɗu, i yuwaan le fo ne. A̱yi nda a̱yi ɗa urevu u Wila̱ wa Musa nu uritosu wa Ama̱sula̱.”
\s1 Una̱ntsu wu uɓoru
\r (Luk. 13:24)
\p 
\v 13 Reve Yesu damma, “I uwa o tsugono tsa̱ A̱sula̱ nu una̱ntsu wu uɓoru. Adama a na ure nu una̱ntsu u na wa̱a̱ ꞌya̱wa̱ o uꞌwa wa akina a̱ ta̱ washin waru a̱ ri usa̱n wu mmalu shi, waru ama na̱ a̱bunda̱ oo tono ureꞌe.
\v 14 Amma una̱ntsu u na u ri a̱ tyo uba̱ta̱ u wuma u na woo koto shi, u tu uɓoru waru ureꞌe u tu usa̱n wu mmalu, waru ama waꞌa ɗa oo tono ureꞌe.”
\s1 Uɗanga na̱ muwun ma̱ yi
\r (Luk. 6:43-44)
\p 
\v 15 A̱vu Yesu lyuwa elime na adanshi, “I da̱nu nu ugbozu adama a ama̱sula̱ e epen. A̱ ta̱ ta̱wa̱ ɗu vadamma ikyon i ɗa, agba a̱tsuma̱ e le a̱ ta̱ ni iwuya vadamma nkerenkesu.
\v 16 I te reve le e ili i na aa yuwusan, ununa vee reve uɗanga nna̱ ve ene umatsun wa̱ yi. A̱ tsu taɓa ubiri o uɗanga wa awanda shi, ko a̱ɗyumbu a ataci† shi.
\v 17 Uɗanga u saꞌani u tsu matsan ta̱ muwun n saꞌani ma̱ a̱ɓula̱, agba uɗanga u babu a̱ɓula̱ u tsu matsan muwun n saꞌani shi.
\v 18 Uɗanga u saꞌani u tsu matsan muwun m babu ulobonu shi, waru uɗanga u babu a̱ɓula̱ u tsu matsan muwun n saꞌani shi.
\v 19 Ama o tsu koɗo ta̱ uɗanga suru u na u tsu matsan muwun ma̱ a̱ɓula̱ shi, reve a̱ kula̱to yi.
\v 20 Ne ɗa fo, i te reve ama e ili i na aa yuwusan.”
\s1 “N reve ɗu shi”
\r (Luk. 13:25-27)
\p 
\v 21 Reve Yesu damma, “Za na ee ɗesu mu Zagbain Zagbain suru ɗa aa uwa o uꞌwa u tsugono tsa zuva shi. Ama a na aa uwa o tsugono tsa zuva goon, ele ɗa aza a na aa yuwusan ili i na Dada va̱ va zuva cigai.
\v 22 O urana wu ugeꞌetosu ama na̱ a̱bunda̱ e te ɗe mu Zagbain le. A ta damma, ‘Tsu yuwan ta̱ alajiya a̱tsuma̱ a aala a̱ wu, waru a̱tsuma̱ a aala a̱ wu tsu uta̱a̱ ta̱ otoni a̱ lima̱, waru tsu yuwan ta̱ linga va asalama a̱ a̱bunda̱.’
\v 23 Reve gba n damma le, ‘N reve ɗu shi. I neꞌe mu ure, a̱ɗu aza a aciyogbamu!’ ”
\s1 Asuwi e re
\r (Luk. 6:47-49)
\p 
\v 24 A̱vu Yesu damma, “Adama o ndolo, za na aa uwwusa ili i na maa dansa, reve u yuwan tsutoni ne ele, u ta̱ vadamma suwi va̱ a̱ɓula̱ na suwai uꞌwa wa̱ yi a aatali.
\v 25 Ko na̱ mini ma gbain ma̱ ta̱wa̱, ko na̱ ɗolu ta̱wa̱, waru nu upepu u keɓe yi usaaꞌa, wa̱a̱ riya̱ shi, adama a na a suwa yi ta̱ a aatali.
\p 
\v 26 “Amma za na uwwai adanshi, agba u yuwan tsutoni ne ele shi, u ta̱ vadamma ulo u vuma u na u suwai uꞌwa wa̱ yi a̱ wuyun.
\v 27 Nna̱ mini ma gbain ma̱ ta̱wa̱, ko ɗolu ta̱wa̱, waru nu upepu u keɓe yi she u ra̱mo, reve wu ɓoso suru suru.”
\s1 Ucira wa̱ Yesu
\r (Mak. 1:22; Luk. 4:32)
\p 
\v 28 Ana Yesu kotoi a yuwusan adanshi a nda, reve oɓolo a amaꞌa a uwa asalama nu cuꞌun vu uritosu wa̱ yi.
\v 29 Adama a na u da̱na̱ vadamma munlu n Wila̱ shi, agba u yuwan ta̱ uritosu tsu za vu ucira.
\c 8
\s1 Yesu ka̱mba̱to ta̱ ma̱kutu gbaga
\r (Mak. 1:40-45; Luk. 5:12-16)
\p 
\v 1 Ana Yesu cipa̱i zuva masasaꞌan, reve a̱ba̱jini o oɓolo a ama o toni yi.
\v 2 Reve ma̱kutu ma cina yi. A̱vu u ka̱ɗa̱to a̱ ma̱ka̱ka̱n ma̱ yi reve u damma, “Zagbain, na̱ vu usu vu ka̱mba̱to mu gbaga, vu ta gura ka̱mba̱to mu.”
\p 
\v 3 Reve Yesu canana ukere wa̱ yi, a̱vu u juꞌwa̱n yi a̱vu u damma, “N usu ta̱. Ka̱mba̱ gbaga!” Babu usa̱n ɗaɗa ukutuꞌu u lyawa niyi, a̱vu wo oꞌwo gbaga!
\v 4 Reve u damma yi, “She vu damma za ro ili i na i farai wan. Amma vu ꞌya̱wa̱ vu roco aciya̱wu uba̱ta̱ wa ganu,† reve vu ca kucci† cine Musa dammai aza a na a̱ ka̱mba̱i gbaga a ca. A̱yi nda u to roco ama a na vu ka̱mba̱i gbaga.”
\s1 Yesu ka̱mba̱to ta̱ aagbashi a yali ro gbaga
\r (Luk. 7:1-10)
\p 
\v 5 Reve Yesu ka̱ra̱ a̱ tyo Kafarnahum. Ana u uwai a̱tsuma̱ a̱ lyuci gbain, yali† ya̱ Roma i ro i cina yi ta̱, reve u pati yi u kamba yi.
\v 6 Reve u damma, “Zagbain, n ta̱ na aagbashi a na a̱ ri ubanakun lon. U ta̱ ɗe o uꞌwa nven, u tsu gura jinga̱ɗa̱ lipu va̱ yi shi. U ta uwwusa lipu lon.”
\p 
\v 7 Reve u damma, “N ta̱ ꞌya̱wa̱ n ka̱mba̱to yi gbaga.”
\p 
\v 8 Reve yaliꞌi u usu, “Zagbain, n rawa vu ta̱wa̱ o uꞌwa u va̱ shi. Yuwan adanshi goon, aagbashi a̱ va̱ a̱ ta̱ ka̱mba̱ gbaga.
\v 9 N ta̱ na̱ nan yali a gbagbain a na a tsu damma mu n yuwan ulinga, a̱mu fo n tsu damma ta̱ a̱soja a̱ va̱ ili i na aa yuwan. N tsu damma ta̱ soja, ‘Wala,’ reve u wala. Reve waru n damma soja ro, ‘Ta̱wa̱,’ reve u ta̱wa̱. Waru n tsu damma ta̱ aagbashi a̱ va̱, ‘Yuwan nda,’ reve u yuwan. N reve ta̱ a na adanshi a̱ wu a̱ ri nu ucira.”
\p 
\v 10 Ana wu uwwai adanshi o ndolo, u yuwan ta̱ asalama. Reve u damma aza a na oo tono yi, “Amayun a ɗa maa dansaa ɗu, ucawu wo okolo a vuma nda u laꞌa ta̱ ucawu wo okolo a na me enei a̱tsuma̱ e iɗa ya Israꞌila suru.
\v 11 Ama na̱ a̱bunda̱ a̱ to uta̱ asana na̱ a̱livu, a̱ ta̱ da̱nu, reve a lyuwa oɓolo na̱ Ibrahim, na̱ Ishiyaku, na̱ Yakubu a̱tsuma̱ o tsugono tsa zuva.
\v 12 Amma a ta vari aza a na a̱ shi a ntsayi a uwa o tsugonoꞌo a̱tsuma̱ e irumbu picim. A̱ ta̱ shon na a lumi anga adama a̱ a̱tsuma̱lima̱.”
\p 
\v 13 Reve Yesu damma yaliꞌi, “Wala a̱ tyo o uꞌwa. Aagbashi a̱ wu a̱ ta̱ ka̱mba̱ gbaga cine vu cayi okolo.” A mantsa mo ndolo ma ɗaɗa gan aagbashi a̱ yi a̱ ka̱mba̱i gbaga.
\s1 Yesu yuwaan ta̱ ama a̱ a̱bunda̱ opocino
\r (Mak. 1:29-34; Luk. 4:38-41)
\p 
\v 14 Ana a̱yi ndolo kotoi, a̱vu Yesu ꞌya̱wa̱ o uꞌwa wa̱ Bituru, reve u cina a̱na̱wa̱le Bituru nven ni ivuna̱.
\v 15 Reve u juꞌwa̱n ukere wa̱ yi, reve ivuna̱ꞌa̱ i lyawa yi, reve u ꞌyon ɗaɗa u cayi Yesu ilyalya.
\p 
\v 16 Nu ulivu u ndolo ama a̱ ta̱wa̱a̱ yi ta̱ na ama a̱ a̱bunda̱ a na a̱ ri no otoni a̱ lima̱.† Reve u ɓara otoni a̱ lima̱ꞌa̱ ɗaɗa a lyawai amaꞌa, reve u ka̱mba̱to a̱za̱ o ubanakuꞌun suru gbaga.
\v 17 U yuwan ta̱ ili i nda tsa̱ra̱ u shiton ili i na Ishaya vumava̱sula̱ dammai:
\q1 “U tara ta̱ banakun tsu,
\q1 reve waru u tawa mɓa̱la̱ n tsu.” \x ◊ \xo 8:17 \xt Isha. 53:4.\x*
\s1 Ama a ciga ta̱ o toni Yesu
\r (Luk. 9:57-62)
\p 
\v 18 Ana Yesu enei a̱ba̱jini o oɓolo a ama zuzu na̱ a̱yi, reve u damma a̱ ꞌya̱wa̱ upasalai u mala u ndeɗe.
\v 19 Reve manlu ma̱ Wila̱ mo ro ma̱ ta̱wa̱ uba̱ta̱ wa̱ yi a̱vu u damma, “Manlu, n ta̱ kuru wu uba̱ta̱ u na va̱a̱ ꞌya̱wa̱ suru.”
\p 
\v 20 Reve u damma yi, “Nranji n ta̱ na angu a̱ nden, nnunu n ta̱ ni ikinda, a̱mu agba, Mawun ma Vuma† n ri nu uba̱ta̱ u na maa gbasato shi.”
\p 
\v 21 A̱vu vuma ro za na da̱na̱i toni va̱ Yesu, damma yi, “Zagbain, lyawa mu neꞌen n ꞌya̱wa̱ n ciɗo aabara a̱ va̱.”
\p 
\v 22 Reve u damma yi, “Toni mu, a̱vu vu lyawa a̱kwa̱kwa̱ a̱ ciɗo a̱kwa̱kwa̱ e le.”
\s1 Yesu isawaton ta̱ upepu u mala
\r (Mak. 4:35-41; Luk. 8:22-25)
\p 
\v 23 A̱vu Yesu uwa a̱tsuma̱ a wantsun, tsa̱ra̱ u ꞌya̱wa̱ upasu u mala u ndeɗe oɓolo no ojoro a̱ yi.
\v 24 Reve a̱ba̱jini o upepu u mala u ꞌyon, a̱vu u jinga̱ɗa̱sa̱ wantsuꞌun, hali mini ma̱ ka̱ra̱ a uwusa yi, agba Yesu da̱na̱ ta̱ pe a nlavu.
\v 25 Reve ojoro a̱ yi a̱ ꞌya̱wa̱ uba̱ta̱ wa̱ yi, a̱vu a̱ ꞌya̱sa̱n yi na̱ yisaali, “Zagbain, wawa tsu! Tsu ciga ta̱ maliɓaa!”
\p 
\v 26 A̱vu u usu le, “Adama a̱ nye yu uwwai wovon? I ri nu ucawu wo okolo a̱bunda̱ shi.” Reve u ꞌyon a̱vu u ɓara upepuꞌu ni ikeɗu i miniꞌi, a̱vu upepuꞌu u von kwin. \fig Yesu isawaton ta̱ upepu|src="Matthew_8_23-25.tif" size="span" loc="Matthew 8:26" ref="Mat. 8:26"\fig*
\p 
\v 27 Ojoroꞌo a yuwan ta̱ asalama lon reve a damma, “Cuꞌun vuma ne ɗa tsunda? Hali upepu ni ikeɗu i mini a yuwan tsutoni na̱ a̱yi!”
\s1 Yesu yuwaan ta̱ ama e re a na a̱ ri no otoni a̱ lima̱ opocino
\r (Mak. 5:1-20; Luk. 8:26-39)
\p 
\v 28 Ana Yesu rawai upasalai wu ngeꞌen u mala zuzu na̱ lyuci va Gadara, reve ama e re a na a̱ ri no otoni a̱ lima̱ a gaꞌan na̱ a̱yi. Uba̱ta̱ wa ason a ɗa ama a nda a̱ tsu da̱na̱, waru a̱ da̱na̱ nu uyoꞌo shi, babu za na tsu gura toni lo.
\v 29 A̱vu e teme a saalasaa yi, “Cine vaa damatosun tsu, Mawun ma̱ A̱sula̱? Vu ta̱wa̱a̱ tsu ta̱ na̱ a̱tsuma̱lima̱ kafu mantsa ma na A̱sula̱ a zuwai!”
\p 
\v 30 Zuzu nu uba̱ta̱ꞌa̱, oɓolo a̱ ngurusumu a̱ da̱na̱ ta̱ lo a alyuna.
\v 31 A̱vu otoni a̱ lima̱ꞌa̱ a pati yi, “Na̱ vu uta̱a̱ tsu a̱tsuma̱ a ama a nda, vu yuwan ankuri vu ca̱co tsu a̱tsuma̱ o oɓolo a̱ ngurusumu a̱ ndeɗe.”
\p 
\v 32 Reve Yesu damma le, “Walai!” A̱vu otoni a̱ lima̱ꞌa̱ a lyawa amaꞌa, a̱vu a uwa a̱tsuma̱ a̱ ngurusumuꞌu. Reve ngurusumuꞌu suru a suma a̱ tyo za̱la̱ va agaɗi a̱ tyo a̱tsuma̱ a mala, a̱vu a̱ kuwa̱ pe.
\v 33 Reve ama a na a̱ da̱na̱i a aguɓa a̱ ngurusumuꞌu, a suma a̱ tyo a̱ lyuci, reve a damma ili i na i farai suru, hali ni ili i na i farai na ama e reꞌe.
\v 34 Reve ama suru a̱tsuma̱ a̱ lyuciꞌi o uta̱ tsa̱ra̱ e ene Yesu. Ana e ene niyi, a̱vu a pati yi u ka̱ra̱ u lyawaa le iɗa i le.
\c 9
\s1 Yesu ka̱mba̱to ta̱ osowi a̱ lipu gbaga
\r (Mak. 2:1-12; Luk. 5:17-26)
\p 
\v 1 A̱vu Yesu uwa a wantsun a̱ ka̱mba̱ a̱ tyo upasalai u mala a̱ tyo a̱ lyuci na u shi na̱ nden.\f + \fr 9:1 \ft A mantsa ma nda u shi ta̱ nden a̱ lyuci na a̱ tsu ɗe Kafarnahum (Mat. 4:13).\f*
\v 2 Ana u rawai ɗe, reve ama o ro a̱ ta̱wa̱a̱ yi na̱ vuma na ri no osowi a̱ lipu a aavalu. Ana Yesu enei ucawu wo okolo wa ama a nda, reve u damma yi, “Ulobo, she vu uwwa wovon wan. A yuwaan wu ta̱ gafura wu unusu wa̱ wu.”
\p 
\v 3 A̱vu munlu n Wila̱ n ro n dammulai va̱ni le, “Vuma nda u ta yuwusan adanshi a tarasa aciya̱yi A̱sula̱ a ɗa!”
\p 
\v 4 Ana u revei cuꞌun majiyan ma na aa yuwusan, ɗaɗa we ece nle, “Nye i zuwai yaa yuwusan majiyan me iwuya i nda?
\v 5 Zane ɗa laꞌai babu usa̱n a na a damma, ‘A yuwaan wu ta̱ gafura wu unusu wa̱ wu,’ ko ‘ꞌYon vu wala?’
\v 6 Agba a̱mu n to roco ɗu a na a̱mu, Mawun ma Vuma, n ta̱ nu ucira a̱tsuma̱ o uvaɗi u nda n yuwan gafura vu unusu.” Ɗaɗa u dammai a̱a̱kutsuma̱ꞌa̱, “ꞌYon, vu tara aavalu a̱ wu, a̱vu vu ka̱ra̱ a̱ ka̱mba̱ o uꞌwa.”
\v 7 Reve u ꞌyon u ka̱ra̱ a̱ tyo o uꞌwa.
\v 8 Ana ama e enei ili i ndolo, a yuwan ta̱ asalama, reve a yuwaan A̱sula̱ ica a na u cayi vuma cuꞌun vu ucira u nda.
\s1 Yesu ɗe ta̱ Matta
\r (Mak. 2:13-17; Luk. 5:27-32)
\p 
\v 9 Reve Yesu lyawa uba̱ta̱ u ndolo, u lyuwa elime na̱ mmalu, ɗaɗa we enei vuma ro na a̱ tsu ɗe Matta, za na shi nden uba̱ta̱ u na u tsu ushishi utafa. Ɗaɗa u damma niyi, “Toni mu.” A̱vu u ꞌyon u toni yi.
\p 
\v 10 A̱ tyo ɗe, a̱vu Yesu no ojoro a̱ yi a̱ da̱nu alya e ilyalya o uꞌwa wa Matta. A̱za̱ o uꞌushishi wu utafa na̱ a̱bunda̱ na̱ a̱za̱ o unusu o ro a̱ da̱na̱ ta̱ lo.
\v 11 Ana Afarishi enei ili i ndolo, a̱vu e ece ojoro a̱ yi, “Cine manlu ma̱ ɗu maa lyuwusa ilyalya ni icuꞌun ya ama o ndolo?”
\p 
\v 12 Yesu uwwa le ta̱ a̱vu u usu le, “Aza a na a̱ ri gbaga a ciga za va̱ a̱guma̱ shi, amma a̱za̱ o ubanakun a ciga ta̱.
\v 13 ꞌYa̱wa̱i i rito ili i nda i na Adanshi a̱ A̱sula̱ aa dansa, ‘Ana yaa yuwaan mu kucci, u laꞌaa ɗu ta̱ ye ene iliyali yo ozo o ro.’ \x ◊ \xo 9:13 \xt Hos. 6:6.\x* N ta̱wa̱ adama m banu ama a̱ a̱ɓula̱ tsa̱ra̱ o oꞌwo a̱za̱ e itoni a̱ va̱ shi. Amma n ta̱wa̱ ta̱ m banu a̱za̱ o unusu.”
\s1 A yuwan ta̱ Yesu yeci adama a akuli
\r (Mak. 2:18-22; Luk. 5:33-39)
\p 
\v 14 Urana u ro, ojoro a Yahaya za vu Urumbusu a̱ ta̱wa̱ ta̱ uba̱ta̱ wa̱ Yesu, reve a yuwan yi yeci, “Nye i zuwai a̱tsu na Afarishi tsaa yuwusan akuli, agba ojoro a̱ wu aa yuwusan shi?”
\p 
\v 15 A̱vu Yesu usu, “Ama a vali vu kasaꞌavu a tsu yuwan a̱tsumola̱ngu shi, nu u ri oɓolo ne ele. Amma mantsa ma̱ ta̱ ta̱wa̱ a na aa tara valiꞌi e memere me le, a mantsa ma ɗaɗa aa yuwan akuli.
\p 
\v 16 “Babu za na a paɗa umuna u saꞌavu u lapulaa uba̱mu wa akuci o utugu wa̱ yi. Nu u yuwan ne, umuna u saꞌavu u ta̱ vura̱nu a̱vu u kara akuci o utuguꞌu, agba apaɗi o umuna u saꞌavuꞌu waa ntsaa a akuci o utuguꞌu shi. Ne ɗa uba̱muꞌu wa̱a̱ da̱shi washin.
\v 17 Waru, a̱a̱ tsun ribina saꞌavu a akuci e itsa̱n yu kwan shi, adama a na ribinaꞌa nu u kutsa, u to ɓoso itsa̱ꞌa̱n, reve woo oco waru itsa̱ꞌa̱n a̱ la̱nga̱. Amma ama a̱ tsu tsun ta̱ ribina saꞌavu kuci e itsa̱n i saꞌavu. A̱vu suru nle a̱ da̱na̱ gbaga.”
\s1 A̱a̱kwa̱kwa̱ o usheli na̱ ka vu ubanakun
\r (Mak. 5:21-43; Luk. 8:40-56)
\p 
\v 18 Yesu a̱tsuma̱ a adanshi, a̱vu zagbain va̱ a̱a̱ꞌisa̱ ro ta̱wa̱ ya̱ꞌa̱ yi. Reve u kingyo a̱ ma̱ka̱ka̱n ma̱ yi a̱vu u damma, “Usheli u va̱ u kuwa̱ ta̱ gogo. Agba na̱ vu ta̱wa̱ vu kuruwa̱ yi ukere, u ta̱ ka̱mbisa̱ wuma.”
\v 19 Reve Yesu na aza a na oo tono yi a̱ ꞌyon a̱vu o toni zagbaiꞌin.
\p 
\v 20 A̱vu ka na da̱na̱i o ocosu mpasa hali aꞌwan kupa ne ejere ta̱wa̱ a̱ca̱pa̱ e Yesu, a̱vu u juꞌwa̱n yi ngeꞌen mu utugu.
\v 21 U da̱na̱ ta̱ a majiyan, “Na̱ n juꞌwa̱n utugu wa̱ yi goon, n ta̱ ka̱mba̱ gbaga.”
\p 
\v 22 Reve Yesu vadala ɗaɗa we ene niyi, a̱vu u damma, “Usheli, she vu uwwa wovon wan! Ucawu wo okolo a̱ wu u ka̱mba̱to wu ta̱ gbaga.” A̱vu kaꞌa wo oꞌushi gbaga.
\p 
\v 23 Reve Yesu lyuwa elime na̱ mmalu oɓolo na̱ zagbaiꞌin a̱ tyo o uꞌwa wa̱ yi, a̱vu we ene a̱za̱ e ishipa ya̱ a̱ciɗa̱ na ama a̱ a̱bunda̱ e mesun.
\v 24 A̱vu u damma, “Uta̱i suru nɗu! Usheliꞌi u kuwa̱ shi. Nlavu n ɗa waa yuwusan.” A̱vu amaꞌa a yuwaan yi izoꞌoshi yu ulamu.
\v 25 Amma ana o lo nle o uta̱ a alanga, a̱vu u ka̱ra̱ a̱ tyo uba̱ta̱ u na usheliꞌi u ri nven. Reve u reme yi ukere, ɗaɗa usheliꞌi u ꞌyoyin.
\v 26 Alabariꞌi a baza ta̱ uba̱ta̱ suru a̱tsuma̱ e iɗaꞌa.
\s1 Yesu yuwaan ta̱ nrumba̱ n re opocino
\p 
\v 27 Ana Yesu lyawai uba̱ta̱ꞌa̱, a̱yi a̱tsuma̱ a mmalu, a̱vu nrumba̱ n re n toni yi. A̱vu a saala, “Mawun ma̱ Da̱wuda, ka̱lyuwa̱ iliyali i tsu!”
\p 
\v 28 Ana Yesu uwai o uꞌwa u ro, a̱vu nrumba̱ n reꞌe n ta̱wa̱ uba̱ta̱ wa̱ yi. Reve we ece le, “I usu ta̱ n ta gura zuwa ɗu ye ene ure?”
\p A̱vu a̱ usu, “Ee, Zagbain.”
\p 
\v 29 A̱vu u juꞌwa̱n esu e le reve u damma, “Adama o ucawu wo okolo a̱ ɗu, ne ɗa woo oꞌwo.”
\v 30 Reve amaꞌa a gura ene. Agba u rono le ta̱ atsuvu lon, adansa, “She i damma vuma ro adama a nda wan.”
\v 31 Agba ana o uta̱i a̱vu a̱ ka̱ra̱ a bazasa alabariꞌi uba̱ta̱ suru a̱tsuma̱ e iɗaꞌa.
\s1 Yesu ca ta̱ vuma na tsu gura yuwan adanshi shi lafiya
\p 
\v 32 Ele a̱ ma̱ka̱ra̱a̱, a̱vu ama a̱ ta̱wa̱a̱ na̱ vuma ro uba̱ta̱ wa̱ Yesu. Otoni a̱ lima̱† a na a̱ da̱na̱i pe a̱tsuma̱ a vumaꞌa a putsaa yi ta̱ a na waa yuwan adanshi.
\v 33 Ana Yesu loyi otoni a̱ lima̱ꞌa̱, a̱yi za na shi tsu gura yuwan adanshi shi, a̱vu u fara adanshi. A̱vu oɓolo a amaꞌa a uwa asalama reve a damma, “Koto tse ene cuꞌun vi ili i nda a̱tsuma̱ a Israꞌila shi.”
\p 
\v 34 Reve Afarishi a damma, “Mogono mo otoni a̱ lima̱ ma ɗa ma ca niyi ucira u na u loyi otoni a̱ lima̱ꞌa̱.”
\s1 Yesu ene ta̱ iliyali ya ama
\r (Mak. 1:39; Luk. 4:44)
\p 
\v 35 Yesu tonishi ta̱ a burusa ilyuci na̱ mulyuci suru. U ritosu ta̱ a̱ a̱ꞌisa̱, u yuwan ta̱ alajiya a Alabari a Saꞌani adama o tsugono tsa̱ A̱sula̱, a̱vu u ca ama a na a̱ ri ubanakun na̱ mɓa̱la̱ icuꞌun icuꞌun lafiya.
\v 36 Ana we enei oɓolo a amaꞌa, reve we ene le iliyali lon, adama a na a̱ da̱na̱ ta̱ udamu waru babu ikambi, gashi ikyon i na i ri babu za va aguɓa.
\v 37 A̱vu u damma ojoro a̱ yi, “Ugasa u ta̱ a̱bunda̱, agba a̱za̱ o ugasaꞌa waꞌa ɗa a̱ ri.
\v 38 Adama o ndolo i pati za vu uɗuma̱ꞌa̱ u lyungu a̱za̱ o ulinga adama tsa̱ra̱ a yuwaan yi ulinga.”
\c 10
\s1 Yesu lyunguyi Kupanejere
\r (Mak. 3:13-19; Luk. 6:12-16)
\p 
\v 1 A̱vu Yesu ɗe ojoro† a̱ yi uba̱ta̱ u ta̱, a̱vu u ca le ucira o lo otoni a̱ lima̱, a̱vu a̱ ka̱mba̱to a̱za̱ o ubanakun na̱ mɓa̱la̱ suru gbaga.
\p 
\v 2 Aajiya† o ufaru a̱tsuma̱ a kupa ne ejereꞌe a̱yi ɗa Simo, za na a laꞌa ta̱ reve yi na aala Bituru. Mawun ma̱ a̱na̱wu ma̱ yi Andarawu aajiya ɗa fo, ne ɗa fo Yakubu na̱ Yahaya, olobo e re a̱ Za̱ba̱di.
\v 3 Filibu fo, oɓolo na̱ Batalamawu, ne ɗa fo Toma, ozo o ro waru ele ɗa Matta za vu uꞌushishi wu utafa,† na̱ Yakubu ulobo wa Alfa, na̱ Tadawu ele fo ajiya ɗa a̱ da̱na̱i.
\v 4 Akapi gba ele ɗa Simo, za na a̱ tsu ɗe Bakanani,\f + \fr 10:4 \ft A̱yi aala “Bakanani” to rocosu tsu vumaꞌa u tu nu uzuwu wa aci adama u kamba ama a̱ yi.\f* na̱ Yahuza Iskariyoti, za na winai Yesu.
\s1 Ulinga wa Kupanejereꞌe
\r (Mak. 6:7-13; Luk. 9:1-6)
\p 
\v 5 Ana Yesu lyunguyi Kupanejereꞌe,† apa ili i na u damma nle, “She i uwa uba̱ta̱ wa Atakpaci† wan, waru she i uwa a̱tsuma̱ e ilyuci ya aza a Samariya wan.
\v 6 Uba̱ta̱ wa aza a Israꞌila ɗa goon ya̱a̱ ꞌya̱wa̱, adama a na a̱ ta̱ gashi ikyon i na i puwa̱yin.
\v 7 Ni i ꞌya̱wa̱, i damma a na tsugono tsa zuva tsa̱a̱ la̱pa̱ ta̱wa̱ shi.
\v 8 A̱za̱ o ubanakun i ka̱mba̱to le gbaga, i ꞌya̱sa̱n aza a na a̱ kuwa̱i, nkutu waru i ka̱mba̱to le cece, yu uta̱a̱ otoni a̱ lima̱. Uneꞌe u ɗa i ushiyi, waru i ca pere.
\v 9 She i ɓa̱na̱ ikebe,† ko zinariya, ko azurufa, ko ikebe vu rumushili wan.
\v 10 She i tara tsa̱n ko utugu u ro ko aatan ko aaɗanga wan. Ama a na yaa kambusa, ele fo a kamba ɗu e ili i na i cigai.
\p 
\v 11 “Ni i uwa a̱ lyuci ko a̱ ma̱lyuci, i zami vuma va̱ a̱ɓula̱ i da̱nu oɓolo na̱ a̱yi hali i lyawa uba̱ta̱ꞌa̱.
\v 12 Ni i uwa o uꞌwaꞌa, i ca̱sa̱ le a̱vu i damma, ‘A̱zoꞌwa, i da̱na̱ na asuvu nden.’
\v 13 Na ama a na a̱ ri nden pe a̱ usu ɗu, i lyawa asuvu nden a̱ ɗu a̱ da̱na̱ ne ele. Agba na̱ a̱ usu ɗu shi, asuvu nden a̱ ɗu o oꞌwo ya̱ꞌa̱ ɗu.
\v 14 Waru nu uꞌwa ko lyuci a ꞌyuwan a̱ ushi ɗu ko o poloo ɗu atsuvu, i lyawa uba̱ta̱ꞌa̱, a̱vu yi ka̱ka̱la̱ ma̱buta̱ ma ana ma̱ ɗu.\f + \fr 10:14 \ft A mantsa mo ndolo, na̱ vuma za̱ka̱tsa̱ ma̱buta̱ ma̱ a̱tugu ko wu ka̱la̱ ma̱buta̱ ma ana ma̱ yi, ure u ro u ɗa u na woo roco wu kasa ta̱ aciya̱yi na ama a̱ lyuci ndolo.\f*
\v 15 Amayun a ɗa maa dansaa ɗu, o urana wu ugeꞌetosu, A̱sula̱ a ta laꞌa roco isaꞌani a̱ tyo a ama o Sodom† na̱ Gomora na ama a̱ lyuciꞌi!”
\s1 Yesu damma le ta̱ addama o ta̱ lo a̱ ta̱wa̱
\r (Mak. 13:9-13; Luk. 21:12-17)
\p 
\v 16 Reve Yesu lyuwa elime na adanshi, “N ta̱ lyungusu ɗu ana ikyon a̱tsuma̱ a̱ nkerenkesu. I da̱na̱ nu ugbozu tse iyo, agba i da̱na̱ babu iwuya tsa muɗa.
\v 17 I yuwan ugbozu, adama a na aza a na e reme ɗu a̱ ta̱ lo, a̱vu a̱ ꞌya̱wa̱to ɗu uba̱ta̱ wa̱ a̱za̱ o ugeꞌetosu, reve a zuwa a fufaba ɗu a̱tsuma̱ a̱ a̱ꞌisa̱.
\v 18 A̱ ta̱ ꞌya̱wa̱to ɗu a̱ ma̱ka̱ka̱n me igwamna na̱ ngono, adama a na yoo tono mu. U to oꞌwo ɗu ure u na yaa damma le adama a̱ va̱, waru i yuwan alajiya a̱tsuma̱ o uvaɗi.
\v 19 Mantsa ma na nanza reme nɗu, she i dama adama e ili i na yaa damma ko cine yaa damma wan. A mantsa mo ndolo, A̱sula̱ a ta ca ɗu ili i na yaa damma.
\v 20 Adanshi a na oo uta̱ o una̱ u ɗu za ɗu ɗa shi, uba̱ta̱ wa̱ Ruhu va Dada ɗu ɗa woo uta̱ a̱ tyo ya̱ꞌa̱ ɗu.
\p 
\v 21 “Ama a ta wina muwun ma̱ a̱na̱wu n le, tsa̱ra̱ o una le. Ne ɗa fo nsha̱wu maa yuwaan muwun n le. Waru muwun n ꞌya̱sa̱a̱n nsha̱wu n le aci, adama a zuwa o una le.
\v 22 Ama suru a ta ꞌyuwan ɗu adama a̱ va̱. Amma aza a na a kaɓai asuvu a̱tsuma̱ o ucawu wo okolo e le a̱ tyo o ukosu, A̱sula̱ a ta wawa le. Na ama o ɓongi ɗu a̱ lyuci ro, i lyawa yi i tyo a̱ lyuci ro.
\v 23 Amayun a ɗa maa dansaa ɗu, a̱mu Mawun ma Vuma, n ta̱ ta̱wa̱ kafu i ka̱nda̱ruwa̱ ilyuci ya Israꞌila suru.
\p 
\v 24 “Mawun ma makaranta ma laꞌa manlu ma̱ yi shi. Waru aagbashi a laꞌa zavuꞌwa va̱ yi shi.
\v 25 U lobono ta̱ mawun ma makaranta mo oꞌwo gashi manlu ma̱ yi, aagbashi waru gashi zavuꞌwa va̱ yi. Ana wo oꞌwoi a̱mu zagbain vu uꞌwa, e ɗe mu ta̱ Baꞌalzabu,† mogono mo otoni a̱ lima̱, ele a̱za̱ o uꞌwa a na a buwai e te ɗe le na ala a na a laꞌai ndolo uwuyanu!”
\s1 She yu uwwa wovon wan
\r (Luk. 12:2-7)
\p 
\v 26 A̱vu waru Yesu dammisa, “She yu uwwa wovon wa ama o ndolo wan, adama a na ili i na i ri usokowu suru gogo, a̱ ta̱ uta̱a̱ yi a alanga e eteshe.
\v 27 A̱tsuma̱ e irumbu a ɗa maa yuwusan ɗu adanshi, a̱ɗu gba i damma yi a̱tsuma̱ e ekan. Ili i na a dammai na̱ yemenu usokowu, i damma yi alanga e eteshe nu uɗyo zuva.
\p 
\v 28 “She yu uwwa wovon wa aza a na a cigai o una ɗu wan. A ta gura una lipu ɗu goon, agba aa gura una wuma u ɗu shi. Amma yu uwwa wovon wa̱ A̱sula̱, za na aa gura una lipu na̱ wuma a akina.
\v 29 Ashe a tsu wina nnunu mutali n re kobo\f + \fr 10:29 \ft Danshi na a yuwayin ulinga pa nda na̱ Tsuheleni a̱yi ɗa “asariyon.” Ka̱lyuwa̱ Ucuɗuwu wi “Ikebe.”\f* ta̱ shi? Agba ko za ta̱ le a̱a̱ kuwa̱ babu urevu wa Dada ɗu shi.
\v 30 A̱sula̱ e reve ta̱ a̱bunda̱ a̱ a̱nji a na a̱ ri a aci a̱ ɗu.
\v 31 Adama o ndolo she yu uwwa wovon wan. I laꞌa ta̱ mutali tsugbain na̱ a̱bunda̱.
\s1 I damma ama adama a̱ Kristi
\r (Luk. 12:8-9)
\p 
\v 32 “Ni i roco ozo o ro a̱ɗu a̱za̱ a̱ va̱ a ɗa, n ta damma Dada va̱ na ri zuva a̱ɗu otoni a̱ va̱ a ɗa.
\v 33 Amma ni i wasan mu, n ta damma Dada va̱ za na ri zuva a̱ɗu a̱za̱ a̱ va̱ a ɗa shi.”
\s1 Babu asuvu nden amma addama
\r (Luk. 12:51-53; Luk. 14:26-27)
\p 
\v 34 A̱vu Yesu lyuwa elime adansa, “She i yuwan majiyan n ta̱wa̱a̱ ta̱ na asuvu nden a̱tsuma̱ o uvaɗi wan. N ta̱wa̱a̱ na asuvu nden shi, agba matsun me peꞌeni.
\v 35 N ta̱wa̱ ta̱
\q1 ‘m ɓolo dada na̱ mawun ma̱ yi nla̱ngi,
\q1 usheli waru na̱ mma va̱ yi,
\q1 jene na̱ a̱na̱wa̱le.
\q1 
\v 36 Nꞌyuwatan ma̱ wu o uꞌwa wa̱ wu u ɗa oo uta̱!’ \x ◊ \xo 10:36 \xt Mik. 7:6.\x*
\p 
\v 37 “Aza a na a laꞌa cigai mbara n le, ko mukuci n le na̱ a̱mu, a rawa o toni mu shi. Aza a na a laꞌa cigai olobo ne esheli e le na̱ a̱mu a rawa o toni mu shi.
\v 38 Ni i ꞌyuwan a tara akpata a̱ a̱tsuma̱lima̱ reve i toni mu, yi ntsaa yoo oꞌwo ojoro a̱ va̱ shi.
\v 39 Za na aa yuwusan adama a wuma wa̱ yi, u ta lamba yi. Za na waru ꞌyuwain aciya̱yi adama a̱ va̱ u ta̱ tsura̱ wumaꞌa.”
\s1 A̱sula̱ a tsu ca ta̱ iliyinkapa
\r (Mak. 9:41)
\p 
\v 40 Reve Yesu dammisa, “Za na ushi nɗu, u ushi mu ta̱. Waru za na usu numu, u usu ta̱ za na lyungu numu.
\v 41 Za na ushiyi vumava̱sula̱ adama a na waa yuwusan adanshi a̱ A̱sula̱, A̱sula̱ a ta ca yi cuꞌun vi iliyinkapa i na waa ca vumava̱sula̱ꞌa̱. Waru vuma na ushiyi vuma va̱ a̱ɓula̱ adama a̱ a̱ɓula̱† a na u ri na̱ a̱yi, u ta̱ tsura̱ cuꞌun vi iliyinkapa yi za va̱ a̱ɓula̱.
\v 42 Vuma na cayi vuma ta̱ na laꞌai uka̱la̱mu a̱tsuma̱ a aza a na oo tono mu mini mo oso, adama a na vumaꞌa za na oo tono mu ɗa, amayun vuma ndolo ta̱ tsura̱ iliyinkapa.”
\c 11
\s1 Yesu na̱ Yahaya za vu Urumbusu
\r (Luk. 7:18-35)
\p 
\v 1 Ana Yesu kotoi a dansaa ojoro kupa ne ejere a̱ yi ili i ndolo suru, a̱vu u lyawa uba̱ta̱ꞌa̱, u ka̱ra̱ a̱ tyo e ilyuci ya̱ Ga̱lili adama u yuwan uritosu na alajiya.
\p 
\v 2 Yahaya za vu Urumbusu da̱na̱ ta̱ pe a̱tsuma̱ o uꞌwa wa ali, a̱vu wu uwwa ili i na Kristi Zamawawa aa yuwusan. A̱vu u lyungu ojoro o ro a̱ yi uba̱ta̱ wa̱ Yesu.
\v 3 Reve e ece yi, “A̱vu ɗaɗa za na tsoo purosuꞌu, ko tsu puro vuma ro?”
\p 
\v 4 A̱vu u usu le, “ꞌYa̱wa̱i i damma Yahaya ili i na ye enei ni ili i na yu uwwai.
\v 5 Nrumba̱ me ene ta̱, a̱kutsuma̱ waru a ta mmalu, nkutu n ka̱mba̱ ta̱ gbaga. Agulani a ta uwwusa adanshi, a̱kwa̱kwa̱ waru a̱ ka̱mba̱ ta̱ wuma, alambi fo a ta uwwusa Alabari a Saꞌani.
\v 6 A̱sula̱ a ta zuwaa aza a na a ꞌyuwan numu shi abaꞌun, adama e ili i na maa yuwusan.”
\p 
\v 7 Ana ojoro a Yahaya a̱ ka̱ra̱i, a̱vu Yesu ka̱ra̱ a adanshi a̱ yi uba̱ta̱ wo oɓolo a ama. U damma, “Cuꞌun vuma ne ɗa i ꞌya̱wa̱i ye ene a̱tsuma̱ o ogozo? U rotso ta̱ apumpu a na upepu wa̱a̱ jinga̱ɗa̱sa̱?
\v 8 Cuꞌun vuma ne ɗa yu uta̱i ye ene? Vuma na otoyi itana i saꞌani i ɗa? Icuꞌun ya ama o ndolo o ukobu u mogono u ɗa a̱ tsu da̱na̱.
\v 9 Ili i ne yu uta̱i ye ene? A̱yi vumava̱sula̱ ɗa? Amayun ne ɗaɗa, n ta dansaa ɗu u laꞌa ta̱ vumava̱sula̱.
\v 10 A̱sula̱ a yuwan ta̱ adanshi a̱ yi a̱tsuma̱ a Adanshi a̱ A̱sula̱:
\q1 ‘N ta̱ lyungu malingata ma̱ va̱ elime a̱ wu,
\q1 tsa̱ra̱ u foɓoo wu ure.’\x ◊ \xo 11:10 \xt Mal. 3:1.\x*
\p 
\v 11 “N ta dansaa ɗu, Yahaya za vu Urumbusu laꞌa ta̱ ama a na a yuwain ɗe wuma. Amma za na laꞌai uka̱la̱mu a̱tsuma̱ o tsugono tsa zuva u laꞌa yi ta̱.
\v 12 Diga a mantsa ma na Yahaya ta̱wa̱i hali a̱ tyo anaꞌan, tsugono tsa zuva tsu ta lyuwusa elime nu ucira, waru ama a ta yuwusan ukadu lon tsa̱ra̱ a uwa ɗe.\f + \fr 11:12 \ft Ure u ro u na aa gura tsura̱ urevu wi idanshi i nda na̱ Tsuheleni a̱yi ɗa, “Diga a mantsa ma na Yahaya ta̱wa̱i hali a̱ tyo anaꞌan, ama a vama a ta yuwusan uvon na̱ tsugono tsa̱ A̱sula̱ adama a̱ tsura̱ yi nu ucira.”\f*
\v 13 Ama̱sula̱ suru na̱ Wila̱ a yuwan ta̱ ɗe adanshi o tsugono tsa̱ A̱sula̱ hali a̱ tyo a mantsa ma Yahaya.
\v 14 Ni i usu adanshi e le, Yahaya a̱yi ɗaɗa Iliya, vumava̱sula̱† na yaa puraꞌa.
\v 15 Za na ri na atsuvu, wu uwwa!
\p 
\v 16 “Nye maa damma adama a ama o gogo? Nye i ɗa o rotsoi? O rotso ta̱ muwun n na n ri nden e eden, aza a na a̱ tsu ɗelei:
\q1 
\v 17 ‘Tsi ivula̱a̱ ɗu ta̱ aabulu,
\q1 agba i jeꞌen shi!
\q1 Tsu cana ta̱ ishipa yu ukwa̱,
\q1 agba i shon shi!’
\p 
\v 18 “Ana Yahaya ta̱wa̱i, u yuwan ta̱ akuli, waru u sowo ribina shi, reve a damma, ‘U ta̱ no otoni a̱ lima̱!’
\v 19 Agba Mawun ma Vuma ma̱ ka̱nda̱ruwa̱ ta̱ a lyuwusa nu u sowi, reve waru i damma, ‘Vuma nda liwi ɗa na̱ sowi! Waru a̱yi iꞌutsa̱ ya̱ a̱za̱ o uꞌushishi wu utafa na̱ a̱za̱ o unusu a ɗa.’ Na̱ ne suru a̱ tsu reve ta̱ ugbozu u ta̱ mejege a linga va̱ yi.”
\s1 Yesu ɓara ta̱ a̱za̱ a na a cayi okolo shi
\r (Luk. 10:13-15)
\p 
\v 20 A̱tsuma̱ e ilyuci i na Yesu yuwain linga va asalama va̱ a̱bunda̱ a̱ yi, ama a ꞌyuwan ta̱ a̱ ka̱mba̱ uba̱ta̱ wa̱ A̱sula̱. Wu uwwa uyoꞌo u le shi, reve u damma,
\v 21 “Woo yoꞌono ɗu shi, aza a Korasinu! Woo yoꞌono aza a Besaida fo shi! Ni ili ya asalama i na n yuwaan ɗu a̱ shi a yuwan le a̱tsuma̱ a Taya na̱ Sida, a na ama e ilyuciꞌi a̱ shi ta̱ da̱nu na akashi usukutu,\f + \fr 11:21 \ft Ama a Israꞌila a̱ tsu da̱nu ta̱ o okomo adama o roco a̱tsumola̱ngu.\f* tsa̱ra̱ o roco a lyawa ta̱ nusu le!
\v 22 N ta dansaa ɗu, o urana wu ugeꞌetosu A̱sula̱ a ta laꞌa roco ama a Taya na̱ Sida isaꞌani a na woo roco ɗu.
\v 23 Agba a̱ɗu, aza a Kafarnahum! I ciga ta̱ a̱ ꞌya̱sa̱n ɗu a̱ tyo zuva? Oꞌo! A ta vari ɗu a̱tsuma̱ a akina! Na̱ a̱ shi a yuwan ili ya asalama i na n yuwain a̱tsuma̱ a̱ ɗu a̱tsuma̱ o Sodom,† hali n gogo u shi ta̱ a̱ da̱na̱ lo!
\v 24 Agba n ta dansaa ɗu, o urana wu ugeꞌetosu, i ta laꞌa oꞌwo iliyali na ama o Sodom.”
\s1 Yesu ca ta̱ ama wivuwun
\r (Luk. 10:21-22)
\p 
\v 25 A mantsa mo ndolo Yesu damma ta̱, “Dada, A̱sulazuva a zuva† ni iɗa! N godyoo wu ta̱, adama a na vu rocoi aza a na koto e revei ili shi, ili i na vu sokoyi a̱za̱ o uguru na̱ a̱za̱ o urevu.
\v 26 Ee, Dada, ne ɗa wu ntsaa nuwu vu yuwan!
\p 
\v 27 “Dada va̱ ca mu ta̱ ili suru. Ko za reve Mawuꞌun shi, she Dada goon. Waru ko za lo revei Dadaꞌa shi, she Mawuꞌun goon, waru na aza a na Mawuꞌun u ɗangwai u damma.
\p 
\v 28 “Ta̱wa̱i ya̱ꞌa̱ va̱, suru nɗu aza a na a̱ kuna̱i ni itana yu ume, n ta ca ɗu wivuwun.
\v 29 I tara a̱a̱gba̱la̱ e inan yi iluma a̱ va̱, i rito e ekere a̱ va̱, adama a na a̱mu vuma kpaku ɗa, za na tarai aciya̱yi ili i ro shi, i ta̱ tsura̱ wivuwun o okolo a̱ ɗu.
\v 30 A̱yi a̱a̱gba̱la̱ꞌa̱ u ta̱ va̱a̱n, itana i va̱ waru a̱ ri ume shi.”
\c 12
\s1 Yesu Zagbain va Ashibi
\r (Mak. 2:23-28; Luk. 6:1-5)
\p 
\v 1 Urana wa Ashibi,† Yesu oɓolo no ojoro a̱ yi a ɓatsasa ta̱ a̱tsuma̱ a̱ a̱ɗuma̱ e ishina. Ojoroꞌo a̱ da̱na̱ ta̱ a uwwusa ambulu, reve e teme a picirasa ishina na a tami.
\v 2 Ana Afarishi† e enei ne, a̱vu a damma yi, “She ojoro a̱ wu a yuwusan cuꞌun vi ili i nda wan! Wila̱ u putsaa ta̱ a̱ da̱na̱ a kuɗusa ishina o urana wa Ashibi.”
\p 
\v 3 Reve u usu le, “I reve ili i na Da̱wuda na̱ nꞌutsa̱ ma̱ yi n yuwain, a mantsa ma na a uwwai ambulu shi?
\v 4 Ana u uwai o uꞌwa wa̱ A̱sula̱, reve a tama opopofu a̱ Wila̱, ko na wo oꞌwoi Wila̱ u putsaa le ta̱ na aa tama.† Nan ganu† ɗa goon a lyawai a tama opopofuꞌu.
\v 5 Koto i ɗenuna̱ a̱tsuma̱ a̱ Wila̱ wa Musa a na nan ganu a ɗa a lyawai a linga a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗa urana wa Ashibi shi? Agba ko za damma a nusan ta̱ a kuɗa ta̱ wila̱ wa Ashibi shi.
\v 6 Amayun a ɗa maa dansaa ɗu, za ro ta̱ pa za na laꞌai A̱a̱ꞌisamapaɗaꞌa!
\v 7 Agba i shi e geꞌeto aza a na a̱ ri nu unusu shi, ni i shi i reve ucuɗuwu wa Adanshi a̱ A̱sula̱ a nda, ‘A na yaa yuwaan mu kucci, u laꞌaa ɗu ta̱ ye ene iliyali yo ozo o ro.’ \x ◊ \xo 12:7 \xt Hos. 6:6.\x*
\v 8 Adama a na a̱mu, Mawun ma Vuma, Zagbain va Ashibi ɗa.”
\s1 Yesu ka̱mba̱to ta̱ ukere u vuma ro gbaga
\r (Mak. 3:1-6; Luk. 6:6-11)
\p 
\v 9 A̱vu Yesu ꞌyon, reve u uwa a̱tsuma̱ a̱ a̱a̱ꞌisa̱† a na a̱ ri lo zuzu.
\v 10 Ana u uwai, a̱vu u cina pe vuma no osowi o ukere. Afarishi a zuwusa ta̱ esu tsa̱ra̱ e reme Yesu nu unusu, a̱vu e ece yi, “U lobono ta̱ a yuwan ulinga wo opocino o urana wa Ashibi?”
\p 
\v 11 Reve u usu le, “Na̱ vu ri na̱ kyon, a̱vu u riya̱ a̱tsuma̱ o ookoꞌo o urana wa Ashibi, vee reme vu uta̱a̱ yi shi? Vu to uta̱a̱ yi.
\v 12 Ama a laꞌa ta̱ ikyon, adama o ndolo wu ntsaa ta̱ a yuwan ulinga u saꞌani o urana wa Ashibi.”
\p 
\v 13 Reve u damma vumaꞌa, “Canana ukere wa̱ wu.” A̱vu u canana, reve ukereꞌe u ka̱mba̱ gbaga gashi za ve ire.
\v 14 A̱vu Afarishiꞌi a̱ ka̱ra̱, reve a dammulai cine aa yuwan tsa̱ra̱ o una yi.
\s1 Yesu aagbashi a na A̱sula̱ a ɗangwai
\p 
\v 15 Yesu reve ta̱ ifoɓi i na Afarishi aa yuwusan, ɗaɗa u lyawai uba̱ta̱ꞌa̱. Ama na̱ a̱bunda̱ o toni yi ta̱, reve u ka̱mba̱to ama a na a̱ da̱na̱i na̱ banakun suru gbaga.
\v 16 Agba u rono le ta̱ atsuvu she a damma vuma ko zane ɗa u ri wan.
\v 17 U yuwan ta̱ ne tsa̱ra̱ u shiton ili i na A̱sula̱ a dammai o una̱ wa Ishaya vumava̱sula̱:
\q1 
\v 18 “Apa aagbashi a̱ va̱, za na n ɗangwai.
\q1 N ciga yi ta̱, waru u tsu yuwan ta̱ ili i na yoo yoꞌonotosu mu okolo.
\q1 N ta zuwaa yi Ruhu va̱,
\q1 waru u ta damma ama suru adama a̱ a̱ɓula̱ a̱ va̱.
\q1 
\v 19 Waa yuwan mawasan shi, waru waa yuwan adanshi ni yisaali shi,
\q1 ko u yuwan adanshi nu ucira e re shi.
\q1 
\v 20 Waa kuɗa aapumpu a na a̱ ri uka̱nzu shi,
\q1 waru wa̱a̱ kimusa̱ fitila na cigai ma̱kima̱a̱ shi.
\q1 Ne ɗa waa lyuwa elime she ni isaꞌani i lyuwa aci e iwuya.
\q1 
\v 21 Waru ama biti a ta zuwa okolo a ala a̱ yi.” \x ◊ \xo 12:21 \xt Isha. 42:1-4.\x*
\s1 Yesu na̱ Baꞌalzabu
\r (Mak. 3:20-30; Luk. 11:14-23)
\p 
\v 22 A̱vu ama o ro a̱ ta̱wa̱a̱ Yesu na̱ vuma na da̱na̱i irumba̱, waru u tsu gura yuwan adanshi shi, adama a na u ta̱ no otoni a̱ lima̱. U ka̱mba̱to ta̱ vumaꞌa gbaga, hali u gura yuwan adanshi reve waru u gura ene.
\v 23 Ama suru o oꞌwo ta̱ a asalama a̱vu a damma, “Vumaꞌa Mawun ma̱ Da̱wuda ma ɗa? A̱yi ɗaɗa Zamawawaꞌa?”
\p 
\v 24 Ana Afarishi a uwwai ne, reve a damma, “U lo ta̱ otoni a̱ lima̱ nu ucira u na Baꞌalzabu,† mogono mo otoni a̱ lima̱ ma ca niyi.”
\p 
\v 25 Yesu reve ta̱ majiyan me le, ɗaɗa u damma nle, “Iɗa i na i neꞌeshenlei aciya̱yi, reve o oꞌwo a̱ la̱ngi va̱ni le u ta̱ riya̱. Waru lyuci ko ama o uꞌwa a na e neꞌeshenlei aciyele, reve o oꞌwo a̱ la̱ngi va̱ni le a̱ ta̱ riya̱.
\v 26 Waru na̱ Male† ma ɗa moo uta̱sa̱a̱ Male, a ta dansa tsugono tsa̱ yi tse neꞌeshen ta̱ ure, waru wa̱a̱ la̱pa̱ riya̱ shi!
\v 27 I damma ta̱ a na n lo ta̱ otoni a̱ lima̱ adama a na Baꞌalzabu ca numu ucira n yuwan ne. To, zane cayi ojoro a̱ ɗu ucira o lo le? Ili i na ojoro a̱ ɗu aa yuwusan u roco ta̱ amayun a ɗa ɗu shi!
\v 28 Amma gba na̱ moo losu otoni a̱ lima̱ nu ucira u Ruhu va̱ A̱sula̱, to, tsugono tsa̱ A̱sula̱ tsa̱ ta̱ pa a̱tsuma̱ a̱ ɗu.
\p 
\v 29 “Na̱ vuma ciga u uwa a̱tsuma̱ o uꞌwa wu za vu ucira u yuwan wivu, u ciga u ꞌyuwan wu nla̱ neꞌen za vu uciraꞌa. Ne ɗa waa yuwan a̱vu u tsura̱ u yuwan wivu a̱tsuma̱ o uꞌwaꞌa.
\p 
\v 30 “Za na aa kambusa mu shi, u ta tsurala na̱ a̱mu. Za na waru aa yuwusan ulinga oɓolo na̱ a̱mu shi, amayun u ta̱ tsushuꞌun na̱ a̱mu.
\v 31 N ta dansaa ɗu, A̱sula̱ a ta yuwaan ama a na a yuwayin ama unusu gafura, hali na aza a na aa yuwusaan A̱sula̱ adanshi a vama.† Amma amayun A̱sula̱ aa yuwaan aza a na a yuwayin Ruhu va Akiza adanshi a vama gafura shi.
\v 32 Za na yuwain adanshi a vama adama a Mawun ma Vuma† a ta yuwaan yi gafura, amma za na yuwayin Ruhu va Akiza adanshi a vama, aa yuwaan yi gafura shi, ko gogo, ko a mantsa ma na ma̱a̱ ta̱wa̱.”
\s1 Uɗanga na̱ muwun ma̱ yi
\r (Luk. 6:43-45)
\p 
\v 33 A̱vu Yesu lyuwa elime na adanshi, “I ta gura damma ko cuꞌun vu uɗanga u ne u ɗa, na̱ cuꞌun muwun n na u matsain. Uɗanga u saꞌani, muwun n saꞌani n ɗa u tsu matsan kuci, uɗanga u babu ulobonu gba shi, she muwun m babu ulobonu.
\v 34 A̱ɗu apili! I ri ama a saꞌani shi, adama o ndolo cine yaa gura yuwan adanshi e ili i saꞌani? Vuma suru u tsu damma ta̱ ili i na i ri pe a̱tsuma̱ o ookolo a̱ yi.
\v 35 Vuma va̱ a̱ɓula̱ u tsu uta̱a̱ ta̱ ni ili i saꞌani i na u zuwai o ookolo, za vu ulambu wa̱ a̱ɓula̱ waru e ili yu ulambu wa̱ a̱ɓula̱ a na u zuwai o ookolo pe ɗa a̱ tsu uta̱.
\v 36 N damma ɗu, o urana wu ugeꞌetosu i ta damma idanshi i vanvama i na i dammai suru.
\v 37 Adama a na ni i damma ili i saꞌani, A̱sula̱ a ta damma i ri nu unusu shi. Amma ni i damma idanshi i vanvama, u ta damma i ta̱ nu unusu.”
\s1 Ama a pati ta̱ Yesu yuwaan le ili ya asalama
\r (Mak. 8:11-12; Luk. 11:29-32)
\p 
\v 38 Reve, munlu n Wila̱ na Afarishi a̱ ta̱wa̱ uba̱ta̱ wa̱ Yesu, reve a damma, “Manlu, tsu ciga ta̱ vu yuwan ulinga wa asalama† tse ene, tsa̱ra̱ u ca tsu iroci i na uba̱ta̱ wa̱ A̱sula̱ ɗa vu uta̱i.”
\p 
\v 39 Reve u usu le, “I ciga ta̱ iroci adama a na a̱ɗu ama e iwuya na̱ a̱za̱ o ulambu wa̱ a̱ɓula̱ a ɗa, agba yaa ca okolo shi! Amma iroci i na ya̱a̱ tsura̱ a̱yi ɗa iroci ya Yunana† vumava̱sula̱.
\v 40 Yunana da̱na̱ ta̱ a̱tsuma̱ a̱ a̱a̱tsuma̱ a magula ma gbain hali ayin a taꞌatsu. Ne ɗa fo a̱mu Mawun ma Vuma ma̱a̱ da̱na̱ a aason hali ayin a taꞌatsu.
\v 41 O urana wu ugeꞌetosu, ama a̱ Niniva† e te isawan oɓolo na̱ a̱ɗu a̱vu e geꞌeto ɗu. Ana Yunana yuwain alajiya, a vadala† ta̱ a̱ ka̱mba̱ uba̱ta̱ wa̱ A̱sula̱. Gogo vuma na laꞌai Yunana ta̱ pa.
\v 42 Waru Egbere va Sheba fo u te isawan u geꞌeto ɗu. U yuwan ta̱ mmalu ma alanga, tsa̱ra̱ wu uwwa ugbozu wa̱ Sulemanu.† Gogo gba za na laꞌai Sulemanu ta̱ pa.”
\s1 Uka̱mbu wo otoni a̱ lima̱
\r (Luk. 11:24-26)
\p 
\v 43 Yesu lyuwa ta̱ elime na adanshi, “A damma vuma ro da̱na̱ ta̱ no otoni a̱ lima̱† a̱ ta̱ goon. Reve otoni a̱ lima̱ꞌa̱ wu uta̱ a̱tsuma̱ a vumaꞌa, u tsu gara ta̱ a̱tsuma̱ e iɗa ba̱ta̱ o uꞌyewu e izami yu uba̱ta̱ u na wee ivuwan, agba wa̱a̱ tsura̱ shi.
\v 44 Otoni a̱ lima̱ꞌa̱ u ta damma, ‘N ta̱ ka̱mba̱ o uꞌwa u na n lyawai.’ Nu u ka̱mba̱, a̱vu u cina uꞌwaꞌa babu ili. A raɗa yi ta̱, reve o oꞌwoto yi cece.
\v 45 A̱vu wu uta̱ reve u ta̱wa̱to otoni a̱ lima̱ e cindere o ro aza a na a laꞌa niyi ucira, a̱vu a uwa pe a̱ da̱nu. Vumaꞌa u ta̱ da̱na̱ a̱tsuma̱ a addama a na a laꞌai cine u da̱na̱i nu ufaru. Ili i na yaa cina ama e iwuya o gogo ɗa nda.”
\s1 Mma na̱ muwun ma̱ a̱na̱wu ma̱ Yesu
\r (Mak. 3:31-35; Luk. 8:19-21)
\p 
\v 46 Yesu a yuwusaan ama adanshi, a̱vu mma va̱ yi na̱ muwun ma̱ a̱na̱wu ma̱ yi n rawa. Reve e isawan a alanga a̱vu a damma a yuwaan yi adanshi.
\v 47 Reve vuma ro yuwaan yi adanshi, “Mma va̱ wu na̱ muwun ma̱ a̱na̱wu ma̱ wu a̱ ta̱ ɗe a alanga a pura wu, a ciga ta̱ a yuwan adanshi na̱ a̱vu.”
\p 
\v 48 A̱vu u usu, “Zane ɗa mma va̱? Nan zane ɗa waru muwun ma̱ a̱na̱wu n va̱?”
\v 49 A̱vu u sapi a̱ tyo uba̱ta̱ wa aza a na oo tono yi reve u damma, “Apa nan mma va̱ na̱ muwun ma̱ a̱na̱wu n va̱.
\v 50 Aza a na a yuwain tsutoni na̱ Dada va̱ za na ri zuva, ele ɗa mma va̱ na̱ muwun ma̱ a̱na̱wu n va̱ mo olobo ne esheli.”
\c 13
\s1 Iroci yi cimbi
\r (Mak. 4:1-9; Luk. 8:4-8)
\p 
\v 1 A̱tsuma̱ o urana u ndolo, a̱vu Yesu lyawa uꞌwaꞌa, a̱vu u ka̱ra̱ a̱ tyo a̱ ngeꞌen m mala, uba̱ta̱ u na u da̱nuyi adama u yuwan uritosu.
\v 2 Oɓolo a ama a na o ɓolotoi a̱ da̱na̱ ta̱ a̱bunda̱ lon, hali u zuwa yi u uwa a wantsun, a̱vu u da̱nu pe, ama ɗe a aagaɗi.
\v 3 A̱vu u roco le ili na̱ a̱bunda̱ a̱tsuma̱ e iroci. Reve u damma, “A yuwan ta̱ cimbi ro za na ꞌya̱wa̱i mazaza me icuꞌun a̱tsuma̱ o uɗuma̱ wa̱ yi.
\v 4 A̱yi a̱tsuma̱ a mazaza, a̱vu ozo o ro o oco yi o ure, reve nnunu n ta̱wa̱ n ka̱ka̱ɗa̱ le.
\v 5 Reve ozo o ro o oco ba̱ta̱ a atali, uba̱ta̱ u na u ri na̱ ma̱bula̱ waꞌa. A̱vu o uta̱ babu usa̱n, adama a na ma̱bula̱ꞌa̱ ma̱ ri waꞌa.
\v 6 Ana urana u yuwain, reve u kpanlato le, adama a na aralu e le a̱ ri a̱ruꞌun shi, a̱vu e ꞌyewushi.
\v 7 Ozo o ro gba o oco a awanda, a̱vu awanda a̱ ꞌyon, reve a gbagbala le.
\v 8 Ozo o ro gba o oco a̱ ma̱bula̱ ma saꞌani, a̱vu a kungwa a matsan ulobonu. Cuꞌun na cimbiꞌi u cuꞌwa̱in suru, ozo o ro a matsan ta̱ mataꞌatsu mataꞌatsu, ozo o ro kupota̱li-uta̱li, ozo o ro ukpaku ukpaku.
\v 9 Za na ri na atsuvu, wu uwwa!”
\s1 Ili i na i zuwai Yesu tsu yuwan uritosu ni iroci
\r (Mak. 4:10-12; Luk. 8:9-10)
\p 
\v 10 Reve ojoro a̱ yi e ece yi, “Nye i zuwai vaa yuwusaan ama adanshi ni iroci?”
\p 
\v 11 A̱vu u usu le, “A̱ɗu ɗa a ɗangwai tsa̱ra̱ i reve ili yu usokowu i tsugono tsa zuva, agba ozo o ro e reve ili yu usokowu i nda shi.
\v 12 Za na ri ni ili, a̱yi ɗa a̱a̱ da̱shi yi lon, waru za na ri ni ili shi, waꞌa na u ri na̱ a̱yi, a̱ ta̱ ushi yi i ɗa.
\v 13 Ili i na i zuwai n tsu yuwusaan le adanshi ni iroci a̱yi ɗa:
\q1 ‘A̱ ta̱ ka̱lyuwa̱, agba ee ene shi,
\q1 a ta zuwa atsuvu, agba aa uwwa ko a̱ tsura̱ urevu shi.’
\p 
\v 14 “Adanshi a̱ A̱sula̱ a shiwan ta̱, cine Ishaya vumava̱sula̱ dammai:
\q1 ‘Ama a ta uwwa adanshi a̱ va̱,
\q1 agba ee reve ili i na maa dansa shi.
\q1 E te eneshe ili i na maa yuwusan,
\q1 agba urevu wa̱ yi u ta̱ puwa̱n le.
\q1 
\v 15 Adama a na ama a nda a gbama ta̱ okolo,
\q1 waru atsuvu e le a ula ta̱,
\q1 waru a̱ kpa̱to ta̱ esu,
\q1 adama o ndolo ee ene shi,
\q1 waru atsuvu e le aa uwwa shi,
\q1 okolo e le a̱a̱ tsura̱ urevu shi,
\q1 waru a̱a̱ ka̱mba̱ uba̱ta̱ u va̱, tsa̱ra̱ n ka̱mba̱to le gbaga shi.’ \x ◊ \xo 13:15 \xt Isha. 6:9-10.\x*
\p 
\v 16 “Amma A̱sula̱ a zuwaa ɗu ta̱ abaꞌun, adama a na esu a̱ ɗu e te ene waru atsuvu a̱ ɗu a ta uwwa!
\v 17 Ama̱sula̱ na̱ a̱bunda̱ na ama a saꞌani a̱ da̱na̱ ta̱ a maluwa tsa̱ra̱ e ene ili i na yee inda, tsa̱ra̱ waru a uwwa ili i na yaa uwwusa. Amma n damma ɗu e ene shi, waru a uwwa shi.
\s1 Yesu cuɗuwa ta̱ iroci yi icuꞌuꞌun
\r (Mak. 4:13-20; Luk. 8:11-15)
\p 
\v 18 “Zuwai atsuvu, adama i tsura̱ ucuɗuwu wi iroci yi cimbiꞌi.
\v 19 Icuꞌun i na yo ocoi a̱ ngeꞌen mu ure, ele ɗa ama a na a uwwai adanshi o tsugono tsa̱ A̱sula̱, agba a̱ tsura̱ urevu wa̱ yi shi. A̱vu za wuya ta̱wa̱, reve u usa adanshiꞌi a̱tsuma̱ o okolo e le.
\v 20 Icuꞌun i na yo ocoi ba̱ta̱ a atali, ele ɗa aza a na a̱ ushiyi adanshiꞌi na̱ ma̱za̱nga̱ babu usa̱n.
\v 21 Agba a̱ ri na aralu a̱ a̱ruꞌun shi, adama o ndolo a jima shi. Ana nden mu uvaɗi n suɗuwai, ko adanshiꞌi a zuwa nle a addama, a̱vu a̱ riya̱.
\v 22 Aza a na o ocoi a awanda, ele ɗa ama a na a uwwai adanshiꞌi, reve a uwa a̱tsuma̱ a̱tsuma̱lima̱ o uvaɗi u nda, reve waru icigi i na oo oꞌwo nu utsuru wu luma̱ le. Reve a gbagbala adanshiꞌi a putsaa le a bala.
\v 23 Aza a na o ocoi a̱ ma̱bula̱ ma saꞌani, ele ɗa ama a na a uwwai adanshiꞌi, a̱vu a̱ tsura̱ urevu wa adanshiꞌi. Cuꞌun vuma ndolo tsu matsan ta̱ ulobonu, mantsa mo ro gba shi, mataꞌatsu mataꞌatsu, mantsa mo ro gba kupota̱li-uta̱li, mantsa mo ro ukpaku ukpaku.”
\s1 Iroci ye ewenwele
\p 
\v 24 A̱vu Yesu yuwaan le iroci i ro: “Tsugono tsa zuva tsu ta̱ ne tsunda: Cimbi ro zaza ta̱ icuꞌun i saꞌani a̱tsuma̱ o uɗuma̱ wa̱ yi.
\v 25 Na ayin, mantsa ma na ama a lantsai suru, a̱vu maꞌyuwatan ma̱ yi ma̱ ꞌya̱wa̱ u cuꞌwa̱a̱n yi ewenwele a̱tsuma̱ e iwele reve u ka̱ra̱.
\v 26 Ana iweleꞌe i farai a kungusa tsa̱ra̱ a matsan, reve fo ewenweleꞌe a kungwa oɓolo ne ele.
\v 27 Reve agbashi a vumaꞌa a̱ ta̱wa̱ uba̱ta̱ wa̱ yi a̱vu a damma yi, ‘Vu cuꞌwa̱n ta̱ icuꞌun i saꞌani o uɗuma̱ wa̱ wu. Te ɗa ewenwele o uta̱i?’
\p 
\v 28 “Reve u usu, ‘Maꞌyuwatan ma ɗa ma̱ cuꞌwa̱in ewenweleꞌe.’
\p “Reve e ece yi, ‘Vu ciga tsu ta̱ tsu mula̱ ewenweleꞌe?’
\p 
\v 29 “A̱vu u usu, ‘Oꞌo, adama a na na̱ yi mula̱ ewenweleꞌe gogo, i ta̱ mula̱ iwele fo.
\v 30 Lyawai iweleꞌe a kungwa oɓolo, hali a̱ tyo a mantsa me ikani. Reve n damma aza a zamalinga: Ɓolotoi ewenweleꞌe uba̱ta̱ u ta̱ neꞌen, a̱vu yi nla̱ le tsa̱ra̱ i kula̱to le. A̱vu i ɓoloto iweleꞌe i ta̱wa̱to le o mopon ma̱ va̱.’ ”
\s1 Iroci yi icuꞌun i na i laꞌai uka̱la̱mu
\r (Mak. 4:30-32; Luk. 13:18-19)
\p 
\v 31 A̱vu Yesu dammisa le iroci i ro, u damma, “Apa cine tsugono tsa zuva tsa̱ ri: Vuma ro tara ta̱ oroci a suꞌwanꞌuri,\f + \fr 13:31 \ft A̱yi ɗa cuꞌun na a̱ tsu ɗe musta.\f* reve u cuꞌwa̱n yi a̱tsuma̱ o uɗuma̱ wa̱ yi.
\v 32 A̱yi ɗa cuꞌun na laꞌai uka̱la̱mu a̱tsuma̱ e icuꞌun, agba nu u kungwa, u tsu laꞌa ta̱ olopu biti mgbain. U tso oꞌwo ta̱ a̱ba̱jini o uɗanga, hali nnunu n ta̱wa̱ n yuwan ɗe nkinda e eten a̱ yi.”
\s1 Iroci i wolilo
\r (Luk. 13:20-21)
\p 
\v 33 A̱vu Yesu yuwusaan le iroci i ro, “Apa a nda cine tsugono tsa zuva tsa̱ ri: Ka tsu tara ta̱ wolilo† a̱vu u ja̱mba̱ra̱ yi a yira a̱tsuma̱ e meretsu, she nu u ja̱mba̱ra̱ yi suru suru, a̱vu u tsutsa.”
\s1 Yesu yuwisan ta̱ iroci
\r (Mak. 4:33-34)
\p 
\v 34 Yesu yuwusan ta̱ adanshi ni iroci adama u damma oɓolo a ama ili i nda suru. U tsu damma le ili i ro babu na u yuwain adanshi ni iroci shi.
\v 35 U yuwan ta̱ ne tsa̱ra̱ u shiton ili i na vumava̱sula̱ dammai,
\q1 “N ta yuwaan ɗu adanshi ni iroci.
\q1 N ta damma ili i na i ri usokowu diga a mantsa ma na A̱sula̱ a yuwain uvaɗi.” \x ◊ \xo 13:35 \xt Ica 78:2.\x*
\s1 Yesu cuɗuwa ta̱ iroci ye ewenwele
\p 
\v 36 Ana Yesu lyawai oɓolo a amaꞌa, a̱vu u uwa a̱tsuma̱ o uꞌwa, reve ojoro a̱ yi a̱ ta̱wa̱ uba̱ta̱ wa̱ yi a̱vu a damma, “Damma tsu urevu wi iroci ye ewenwele a̱tsuma̱ o uɗuma̱ꞌa̱.”
\p 
\v 37 Reve u usu le, “Za na zazai icuꞌun i saꞌaniꞌi a̱yi ɗa Mawun ma Vuma.
\v 38 Uɗuma̱ waru gba a̱yi ɗa uvaɗi. Ele icuꞌun i saꞌani ele ɗa ama a na a̱ ri ozo o tsugonoꞌo. Ele gba icuꞌun ye ewenwele ele ɗa aza a na o uta̱i uba̱ta̱ wu za wuya.
\v 39 Maꞌyuwatan ma na ma zaza nle a̱yi ɗa Mekerenkesu. Mantsa me ikani a̱yi ukosu wu uvaɗi. Aza a zamalinga a na oo ɓoloto le, ele ɗa nlingata ma̱ A̱sula̱.
\p 
\v 40 “O tsu ɓoloto ta̱ ewenwele a̱vu a̱ kula̱to. Ne ɗa woo oꞌwo a mantsa mo ukosu.
\v 41 A̱mu Mawun ma Vuma, n ta̱ lyungu nlingata n va̱, a ta tawa ili i na i tsu zuwa unusu suru a̱tsuma̱ o tsugono tsa̱ va, waru na aza a na aa yuwusan iwuya suru.
\v 42 A ta vari le a̱tsuma̱ a̱ a̱a̱ka̱ri a na a̱ ri tapu na akina a na a̱ ri usuɗuwu lon, uba̱ta̱ u na ama a̱ da̱na̱ a̱ shosun na a lumi anga e le na̱ mɓa̱la̱.
\v 43 Ele gba ama a̱ a̱ɓula̱ a̱ te ikana gashi urana o tsugono tsa Dada le. Za na ri na atsuvu, wu uwwa!”
\s1 Iroci yu uzuwa yu usokowu
\p 
\v 44 A̱vu Yesu lyuwa elime na adanshi, “Apa cine tsugono tsa zuva tsa̱ ri: Vuma ro tsura̱ ta̱ uzuwa u na vuma ro sokoi a̱tsuma̱ o uɗuma̱. A̱vu wu palisa yi. U yuwan ta̱ ma̱za̱nga̱ a̱vu u ꞌya̱wa̱ u wina ili i na u ri na̱ a̱yi suru, a̱vu u ka̱mba̱ u tsula uɗuma̱ꞌa̱.
\s1 Iroci yi iyeɗi yi ikebe
\p 
\v 45 “Waru, apa cine tsugono tsa zuva tsa̱ ri: Za va atsulu na awina ro te izami yi iyeɗi yi ikebe.†
\v 46 Nu u tsura̱ za na laꞌai ulobonu, reve u ꞌya̱wa̱ u wina ili i na u ri na̱ a̱yi suru tsa̱ra̱ u tsula yi.
\s1 Iroci yi igolo
\p 
\v 47 “Waru, apa cine tsugono tsa zuva tsa̱ ri: A̱za̱ e mereme ma mugula n ro a vari ta̱ igolo i le a̱tsuma̱ a mala, a̱vu e reme mugula icuꞌun icuꞌun.
\v 48 Ana igoloꞌo i shiwain, a̱vu o rono yi o uta̱ a alanga, reve a̱ da̱nu tsa̱ra̱ a kakasa mugulaꞌa. Mugula n saꞌani a̱vu a zuwa le a̱tsuma̱ a aasaꞌatsu, aza a na a̱ ri ulobonu shi gba, o oco le.
\v 49 Ne ɗa woo oꞌwo mantsa mo ukosu. Nlingata n ta̱ ta̱wa̱ a kakasa a̱za̱ e iwuya a̱tsuma̱ a ama a̱ a̱ɓula̱.
\v 50 Nlingataꞌa n ta vari a̱za̱ e iwuya a̱tsuma̱ a̱ a̱a̱ka̱ri a na a̱ ri tapu na akina a na a̱ ri usuɗuwu lon, uba̱ta̱ u na ama a̱a̱ da̱na̱ a̱ shosun na a lumi anga na̱ mɓa̱la̱.”
\s1 Akuci nu uzuwa u saꞌavu
\p 
\v 51 A̱vu Yesu ece le, “I gura ta̱ reve ili i nda suru?”
\p Reve a̱ usu, “Ee, tsu tsura̱ ta̱ urevu wa̱ yi.”
\p 
\v 52 Reve u damma le, “Manlu ma̱ wila̱ ma na suru ma̱ tsura̱i urevu u tsugono tsa zuva u rotso ta̱ vuma na oo uta̱su akuci nu uzuwa u saꞌavu a alanga a̱tsuma̱ o mopon.”
\s1 Ama a Nazara a ꞌyuwain Yesu
\r (Mak. 6:1-6; Luk. 4:16-30)
\p 
\v 53 Ana Yesu kotoi adansa iroci i nda, a̱vu u lyawa uba̱ta̱ꞌa̱.
\v 54 Reve u ka̱mba̱ Nazara, lyuci na u kungwai. Ana u yuwain uritosu ɗe a̱tsuma̱ a̱ a̱a̱ꞌisa̱,† ama suru a yuwan ta̱ asalama a̱vu a damma, “Te ɗa u tsura̱i ugbozu nu ucira u na waa yuwusan ili ya asalama i nda?
\v 55 A̱yi mawun ma za vu usheꞌen ma ɗa. Meri† ɗa mma va̱ yi, waru muwun ma̱ a̱na̱wu ma̱ yi ele ɗa, Yakubu, na̱ Isuhu, na̱ Simo na̱ Yahuza.
\v 56 Muwun ma̱ a̱na̱wu me esheli ma̱ yi suru a̱ ta̱ pa oɓolo na̱ a̱tsu. Cine tsa ɗa waa gura yuwan ulinga u nda suru?”
\v 57 Adama o ndolo ugbozu u le u da̱nu na̱ a̱yi shi, a̱vu a ꞌyuwan yi.
\p Reve gba u damma le, “Vumava̱sula̱ ri na̱ tsugbain a̱ lyuci no o uꞌwa wa̱ yi shi, she a̱ lyuci ro.”
\p 
\v 58 Adama o ndolo, u gura yuwan ili ya asalama ya̱ a̱bunda̱ a̱ lyuci va̱ yi shi, adama a na a̱ ri nu ucawu wo okolo shi.
\c 14
\s1 Ukwa̱ wa Yahaya za vu Urumbusu
\r (Mak. 6:14-29; Luk. 9:7-9)
\p 
\v 1 A mantsa mo ndolo, Hiridu Antiba, mogono ma̱ Ga̱lili, ma uwwa ta̱ adama e Yesu.
\v 2 A̱vu u damma agbashi a̱ yi, “Yesu Yahaya za vu Urumbusu ɗa, za na a̱ ꞌya̱sa̱in a̱tsuma̱ a̱ a̱kwa̱kwa̱. A̱yi ɗa i zuwai waa yuwusan cuꞌun vi ili ya asalama a nda.”
\p 
\v 3-4 Kafu mantsa ma nda, Hiridu usa ta̱ Hiridiya a̱yi ubuwu ka mawun ma̱ a̱na̱wu ma̱ yi Filibu. Yahaya† dansaa yi ta̱, “U ri ulobonu vu zuwa Hiridiya shi!” Reve u zuwa e reme Yahaya a̱ nla̱ yi, a̱vu a zuwa yi a̱tsuma̱ o uꞌwa wa ali.
\v 5 U shi ta̱ u ciga wu una yi, agba wu uwwusa ta̱ wovon wa ama, adama a na a̱ usu ta̱ Yahaya vumava̱sula̱ ɗa.
\p 
\v 6 Ana a cuwusan nu urana u na a matsain Hiridu, a̱vu usheli wa Hiridiya u jeꞌeen Hiridu oɓolo no omocin a̱ yi, a̱vu u zuwa okolo a̱ yi o yoꞌono.
\v 7 Reve u kucina na waa ca yi ili i na u cigai biti.
\v 8 A̱vu mma vu usheliꞌi u damma yi u damma, “N ciga ta̱ aaci a Yahaya za vu Urumbusu a mapara ma nda!”
\v 9 A̱vu mogonoꞌo u yuwan shinreve vi ili i na u dammai. Agba u ciga u ꞌya̱sa̱n nzuwulai n na u yuwain a̱ ma̱ka̱ka̱n mo omocin a̱ yi shi. A̱vu u damma a̱soja a̱ yi,
\v 10 a̱ ꞌya̱wa̱ o uꞌwa wa ali o koɗo aaci a Yahaya za vu Urumbusu.
\v 11 A̱vu a̱ ta̱wa̱a̱ na aaciꞌi a mapara a̱vu a ca usheliꞌi, a̱vu usheliꞌi u ꞌya̱wa̱a̱ mma va̱ yi.
\v 12 Reve ojoro a Yahaya a̱ ta̱wa̱ a tara lipu va̱ yi a̱ ciɗo. A̱vu a̱ ꞌya̱wa̱ a̱ ka̱mbuwa̱ Yesu ili i na i farai.
\s1 Yesu lyuwato ta̱ ama ukpakukupa uton
\r (Mak. 6:30-44; Luk. 9:10-17; Yah. 6:1-14)
\p 
\v 13 Ana Yesu uwwai alabari o ndolo, reve u uwa a wantsun, a̱vu u ka̱ra̱ a̱ tyo o una tsa̱ra̱ u da̱na̱ a̱yi a̱ ndeꞌen. Agba ana oɓolo a amaꞌa a uwwai ne, reve o toni yi na̱ mmalu o tono ngeꞌen m mala.
\v 14 Ana u rawai, a̱vu u cina a̱ba̱jini o oɓolo a ama a pura yi. Reve we ene le iliyali, a̱vu u ka̱mba̱to aza a na a̱ da̱na̱i ubanakun suru gbaga.
\p 
\v 15 Urana a zama ma̱riya̱a̱, a̱vu ojoro a̱ yi a̱ ta̱wa̱ uba̱ta̱ wa̱ yi a̱vu a damma, “Urana u koto ta̱, uba̱ta̱ u nda gba ogozo a ɗa. Damma amaꞌa e beteꞌwe, tsa̱ra̱ a̱ ꞌya̱wa̱ a̱ mulyuci a tsulaa aciyele ilyalya a lyuwa.”
\p 
\v 16 Reve u usu le, “Ili yi lo i na yaa zuwa le a̱ ka̱ra̱ shi. I ꞌya̱wa̱ i ca le ilyalya a lyuwa.”
\p 
\v 17 A̱vu a damma yi, “Opopofu o ton a ɗa tsu ri ne ele na̱ mugula n re goon.”
\p 
\v 18 Reve u damma le, “Ta̱wa̱a̱ numu no opopofuꞌu na̱ mugulaꞌa.”
\v 19 A̱vu u damma amaꞌa a̱ da̱nu a anlya. A̱vu u tara opopofu o toꞌon na̱ mugula n reꞌe, a̱vu u ka̱lyuwa̱ zuva, reve u godyoo A̱sula̱ adama e ilyalya. Reve u neꞌeshen opopofuꞌu, a̱vu u ca ojoro a̱ yi, reve ele a ca ama.
\v 20 Ama suru a lyuwa ta̱ hali a̱ cuwa̱n. Reve ojoroꞌo o shiton asaka kupa ne ejere na akapi e ilyalya i na i buwai.
\v 21 Ali a na a lyuwai ilyalya i ndolo a ta rawa ali ukpakukupa uton (5,000), e kece a̱ma̱ci na̱ muwun shi.
\s1 Yesu wala ta̱ a̱ mini
\r (Mak. 6:45-52; Yah. 6:15-21)
\p 
\v 22 A̱vu Yesu dammushi ojoro a̱ yi a uwa a wantsun tsa̱ra̱ a̱ ka̱ra̱ elime a̱ yi upasalai u mala. U da̱na̱ ta̱ lo tsa̱ra̱ u lyawa ama a̱ ka̱mba̱ a ꞌwa le.
\v 23 Ana u lyawa nle a̱ ka̱ra̱i a ꞌwa, reve u ka̱ra̱ a̱ ꞌya̱wa̱ a agaɗi na aciya̱yi tsa̱ra̱ u yuwan avasa. Ayin a ɗa a̱ da̱na̱i, a̱vu gba u da̱na̱ ɗe a̱yi a̱ ndeꞌen.
\p 
\v 24 A matsan mo ndolo, wantsun wo ojoro a̱ yi u da̱na̱ ta̱ e memere ma malaꞌa, waru upepu wu ucira u ꞌyon ta̱. A̱ da̱na̱ ta̱ o mpolo ni ikeɗu i mala i gbain.
\v 25 Na̱ wasasa, a̱vu u ta̱wa̱ uba̱ta̱ u le a mmalu zuva mini.
\v 26 Ana e ene niyi a mmalu zuva mini tsundolo, a uwwa ta̱ wovon. A̱vu a saala na̱ wovon, “Yimoɗi i ɗa!” \fig Yesu wala ta̱ zuva mini|src="Matthew_14_25-26.tif" size="span" loc="Matthew 14:26" ref="Mat. 14:26"\fig*
\p 
\v 27 Reve u yuwushin nle adanshi, u damma, “U rawa ta̱ ne, n ta̱ pa! She yu uwwa wovon wan.”
\p 
\v 28 A̱vu Bituru damma, “Zagbain, na̱ a̱vu ɗa mayun, damma mu n ta̱wa̱ ya̱ꞌa̱ wu zuva mini ma nda.”
\p 
\v 29 Reve u damma yi, “Ta̱wa̱.”
\p A̱vu Bituru lyawa wantsun, a̱vu u ka̱ra̱ a mmalu zuva mini a̱ tyo uba̱ta̱ wa̱ Yesu.
\v 30 Amma ana Bituru enei upepu ni ikeɗu i mala, a̱vu wu uwwa wovon ɗaɗa u temei maliɓaa. Ɗaɗa u saalai, “Zagbain, wawa mu!”
\p 
\v 31 A̱vu Yesu cananashi ukere wa̱ yi a̱vu u reme yi. A̱vu u damma yi, “Vu ta̱ nu ucawu wo okolo keꞌen. Nye i zuwai okolo a̱ wu a kuɗai?”
\p 
\v 32 Ana a uwai a̱tsuma̱ a wantsuꞌun, reve upepuꞌu u von kwin.
\v 33 Ɗaɗa aza a na a̱ da̱na̱i pe a wantsuꞌun a yuwayin Yesu a̱ga̱nda̱ adansa, “Amayun a̱vu ɗa Mawun ma̱ A̱sula̱.”
\s1 Yesu ca ta̱ ama a Janisara lafiya
\r (Mak. 6:53-56)
\p 
\v 34 A pasalai ta̱ malaꞌa a̱vu a̱ tyo e iɗa ya Janisara.
\v 35 Ana ama a na a̱ ri pe e revei Yesu ɗa, a̱vu a damma ama suru a na Yesu ta̱wa̱ ta̱. A̱vu a̱ ta̱wa̱a̱ yi na aza a na a̱ ri nu ubanakun icuꞌun icuꞌun.
\v 36 Reve a pati yi tsa̱ra̱ u lyawa aza a na a̱ ri nu ubanakun a̱ juꞌwa̱n ngeꞌen mu utugu ma̱ yi. Reve aza a na a̱ juꞌwa̱in suru a̱ ka̱mba̱ gbaga.
\c 15
\s1 I yuwan tsutoni na̱ Wila̱ wa̱ A̱sula̱
\r (Mak. 7:1-13)
\p 
\v 1 Reve Afarishi o ro na̱ munlu n Wila̱ mu uta̱ ɗe Urishelima, a̱vu a̱ ta̱wa̱ uba̱ta̱ wa̱ Yesu reve e ece yi,
\v 2 “Nye i zuwai ojoro a̱ wu oo tono ili i na nkaya n tsu n roco ntsu tsu yuwan shi? Ko ekere e le a tsu saꞌa kafu a lyuwa ilyalya o ure u na wu ntsayi shi.”
\p 
\v 3 Reve u usu le, “Nye i zuwai yoo tonishi ili i na A̱sula̱ a dammai shi, reve i uwa o tono uritosu wa aciya̱ɗu?
\v 4 A̱sula̱ a damma ta̱, ‘Vu yuwaan dada va̱ wu na̱ mma va̱ wu tsutoni,’ waru, ‘Za na isulai dada va̱ yi ko mma va̱ yi, a̱ to una yi.’ \x ◊ \xo 15:4 \xt Mta̱. 20:12; Mta̱. 21:17.\x*
\v 5 A̱ɗu gba i to ritosu a na na̱ vuma ri ni ili i na waa kambaa dada va̱ yi ko mma va̱ yi, reve u damma ‘A̱yi nda za va̱ A̱sula̱ ɗa,’
\v 6 to, a̱ ri na a ca dada le iliꞌi shi. I ꞌyuwan ta̱ ili i na A̱sula̱ a dammai adama a agadu a̱ ɗu.
\v 7 A̱ɗu a̱za̱ e ikpaꞌa! Ishaya vumava̱sula̱ yuwan ta̱ mejege ana u ɗanai A̱sula̱ a damma ta̱:
\q1 
\v 8 ‘Ama a nda a ta casu mu tsugbain a̱ na̱ le goon,
\q1 okolo e le gba alanga a ɗa a̱ ri na̱ a̱mu.
\q1 
\v 9 A̱ga̱nda̱ a na aa yuwusaan mu ili ya̱ a̱ɓula̱ i ɗa shi.
\q1 Ili i na oo ritosu ili i ro i ɗa shi, agba uritosu wa ama u ɗa.’ ” \x ◊ \xo 15:9 \xt Isha. 29:13.\x*
\s1 Ili i na i tsu lungusa̱ vuma
\r (Mak. 7:14-23)
\p 
\v 10 Reve Yesu ɗewishe oɓolo a amaꞌa, a̱vu u damma le, “I polo atsuvu yu uwwa, a̱vu i reve ili i maa dansa.
\v 11 Ili i na i tsu uwa a̱tsuma̱ a vuma, a̱yi ɗa u tsu lungusa̱ yi shi. Amma ili i na i tsu uta̱ o una̱ wa̱ yi, a̱yi ɗa u tsu lungusa̱ yi.”
\p 
\v 12 Ɗaɗa ojoro a̱ yi a̱ ta̱wa̱i uba̱ta̱ wa̱ yi, a̱vu a damma, “Vu reve ta̱ a na vi isulai Afarishi na adanshi a na vu yuwain?”
\p 
\v 13 A̱vu u usu, “Ili i na Dada va̱ va zuva cuꞌwa̱in shi, suru a̱ ta̱ mula̱ yi diga a aralu a̱ yi suru.
\v 14 I tonoo Afarishi o ndolo wan! Ele a̱ ta̱ ana nrumba̱ n na moo ronuso nrumba̱ n ro, waru suru nle a̱ ta̱ riya̱ a̱ a̱a̱ka̱ri.”
\p 
\v 15 A̱vu Bituru usu, “Nye ɗa vaa dansa ana vu yuwain adanshi adama e ili i na i tsu lungusa̱ vuma?”
\p 
\v 16 Reve Yesu usu, “Hali n gogo koto vu reve ili i maa dansa shi?
\v 17 Amayun a ɗa, suru ilyalya i na i tsu uwa o una̱, u tsu ka̱ra̱ ta̱ a̱ tyo a̱ a̱a̱tsuma̱, reve wu uta̱.
\v 18 Amma adanshi a vama a na a̱ tsu uta̱ o una̱ u tsu uta̱ ta̱ diga o okolo. Waru ele ɗaɗa ili i na i tsu lungusa̱ vuma.
\v 19 A̱tsuma̱ o okolo a ɗa majiyan me iwuya na̱ mona ma̱ tsu uta̱, pe ɗa waru tsipere ne epen a̱ tsu uta̱, na̱ wivu na adanshi a vama a aci a ama o ro.
\v 20 Ele nda ele ɗa a̱ tsu lungusa̱ za. Alya babu saꞌa ekere, u tsu lungusa̱ vuma shi.”
\s1 Yesu kambai Takpaci vu ka
\r (Mak. 7:24-30)
\p 
\v 21 A̱vu Yesu lyawa uba̱ta̱ꞌa̱ u ka̱mba̱ a̱ mɓa̱nga̱ ma Taya na̱ Sida.
\v 22 Ana u rawai, a̱vu ka ro Takpaci\f + \fr 15:22 \ft Kaꞌa za va Kaꞌana ɗa, a̱yi waru za va Israꞌila ɗa shi.\f* za na ri na̱ nden pe, u ta̱wa̱ ya̱ꞌa̱ yi, a̱vu u saala, “Zagbain, Mawun ma̱ Da̱wuda, ka̱lyuwa̱ iliyali i va̱! Usheli u va̱ u to sowuso a̱tsuma̱lima̱ no otoni a̱ lima̱.”
\p 
\v 23 Agba Yesu damma yi ili i ro shi. Ɗaɗa ojoro a̱ yi a̱ ta̱wa̱i ya̱ꞌa̱ yi, reve a pati yi, “Damma ka ndolo u ka̱ra̱. U to tono tsu na̱ yisaali.”
\p 
\v 24 Reve u usu u damma, “A̱ lyungu mu ta̱ uba̱ta̱ wa aza a Israꞌila goon! A̱ ta̱ gashi oɓolo e ikyon a na a̱ puwa̱in.”
\p 
\v 25 Reve kaꞌa u rawa uba̱ta̱ wa̱ Yesu, a̱vu u ka̱ɗa̱to u damma, “Zagbain, vu kamba mu!”
\p 
\v 26 A̱vu u usu, “U lobono a tara ilyalya i muwun, reve a ca musa̱n shi.”
\p 
\v 27 A̱vu kaꞌa u damma, “Ne ɗa, Zagbain, agba ko musa̱n n tsu lyuwa ta̱ mubishi n na ma̱a̱ riyisa̱ diga a mapara ma za na zuwa niyi.”
\p 
\v 28 Ɗaɗa Yesu usu niyi, “A̱vu ka na cayi okolo lon ɗa! N ta yuwaan wu ili i na vu patiyi.” A mantsaꞌa gan, reve usheli wa̱ yi wo oꞌwo gbaga.
\s1 Yesu ka̱mba̱to ta̱ ama a̱ a̱bunda̱ gbaga
\r (Mak. 7:31-37)
\p 
\v 29 Reve Yesu lyawa ɗe, reve u ka̱mba̱ a̱ ngeꞌen m Mala ma̱ Ga̱lili. Reve u kumba a aagaɗi u da̱nu.
\v 30 Ɗaɗa oɓolo a ama a̱ a̱bunda̱ a̱ ta̱wa̱i, a̱vu a̱ ta̱wa̱a̱ na̱ a̱kutsuma̱ na̱ nrumba̱, a̱ ta̱wa̱ ta̱ waru na aza a na a̱ ri no osowi a̱ lipu, oɓolo na aza a na a tsu gura yuwan adanshi shi, na ama a na a̱ ri na̱ banakun icuꞌun icuꞌun. A̱vu a zuwa le a̱ ma̱ka̱ka̱n ma̱ yi, reve u ka̱mba̱to le gbaga suru.
\v 31 Ama suru a yuwan ta̱ asalama ni ili i na e enei a uwai waru. Ama a na a̱ shi a tsu yuwan adanshi shi, reve a uwa adanshi gogo. Osowi a̱ lipu o oꞌwo ta̱ gbaga, a̱kutsuma̱ waru a wala, nrumba̱ waru me ene ure. Ama suru a uwa ta̱ a ciɓalasa A̱sula̱ a aza a Israꞌila.
\s1 Yesu lyuwato ta̱ ama ukpakukupa una̱shi
\r (Mak. 8:1-10)
\p 
\v 32 A̱vu Yesu ɗe ojoro a̱ yi, reve u damma le, “Me ene ta̱ iliyali ya ama a nda. O to oɓolo na̱ a̱mu hali rana taꞌatsu, agba a̱ ri ni ili i na aa lyuwa shi. Agba n ciga n zuwa a̱ ka̱ra̱ na ambulu shi. A̱ ta̱ ta̱ka̱lyuwa̱ o ure a̱ tyo o uꞌwa.”
\p 
\v 33 A̱vu ojoro a̱ yi a̱ usu, “Uba̱ta̱ u nda u rotso ta̱ ogozo. Te ɗa tsa̱a̱ tsura̱ ilyalya i na yaa rawa lyuwato cuꞌun vo oɓolo a nda?”
\p 
\v 34 A̱vu we ece le, “Opopofu a yan a ɗa i ri ne ele?”
\p A̱vu a̱ usu, “A̱za̱ e cindere, na̱ mugula meketeci.”
\p 
\v 35 A̱vu Yesu damma amaꞌa a̱ da̱nu e iɗa.
\v 36 Reve u tara opopofu e cindereꞌe na̱ mugulaꞌa a̱vu u godyoo A̱sula̱. Reve u neꞌeshen ilyalyaꞌa u ca ojoro a̱ yi, reve a ca amaꞌa.
\v 37 Amaꞌa suru a lyuwa ta̱ hali a̱ cuwa̱n. Reve ojoro a̱ yi o shiton asaka a gbagbain e cindere na akapi a na a buwai.
\v 38 Ali goon aza a na a lyuwai ilyalyaꞌa, babu na̱ a̱ma̱ci na̱ muwun, a ta rawa ama ukpakukupa una̱shi (4,000).
\v 39 Ana Yesu dammai amaꞌa a̱ ka̱ra̱, ɗaɗa u uwai a wantsun reve u pasalai malaꞌa. Reve a rawa e iɗa zuzu na̱ Magada.
\c 16
\s1 Azagbain a cigai e ene ili ya asalama
\r (Mak. 8:11-13; Luk. 12:54-56)
\p 
\v 1 A̱vu Afarishi na aza a Sadukiya a̱ ta̱wa̱ uba̱ta̱ wa̱ Yesu a̱ lyungwa̱ yi adama e reme yi nu unusu, ɗaɗa a damma niyi u yuwaan le ili ya asalama, adama u roco A̱sula̱ a̱ usu ta̱ ili i na waa yuwusan.
\p 
\v 2 Reve gba Yesu usu, “Nu urana u ri a̱ ma̱riya̱a̱, i tsu damma ta̱ ‘Alanzu o to lobono adama a na zuva ri saan.’
\v 3 Nu usana adama a na zuva ri saan na̱ wunla̱, reve i damma, ‘O to roꞌo.’ I tse ene ta̱ iroci i nda zuva, reve i reve ili i na oo rocosu. Agba ne ɗa fo, i te inda ili i na maa yuwusan gogo, waru i reve ili i na oo rocosu shi.
\v 4 Ama e iwuya na̱ a̱za̱ o ulambu wa̱ a̱ɓula̱ a zami ta̱ a yuwaan le iroci ya asalama, agba moo roco le shi, she iroci ya Yunana† vumava̱sula̱.” Reve Yesu lyawa le lo a̱vu u ka̱ra̱.
\s1 I yuwan ugbozu na̱ munlu me epen
\r (Mak. 8:14-21)
\p 
\v 5 Ana ojoro e Yesu a pasai malaꞌa a̱ tyo a̱ mɓa̱nga̱ n ndeɗe, reve e icina a na aa tara opopofu.
\v 6 Reve Yesu damma le, “I yuwan ugbozu! I da̱na̱ ufoɓu adama o wolilo wa Afarishi na aza a Sadukiya.”
\p 
\v 7 A̱vu ojoroꞌo a yuwan adanshi va̱ni le, a̱vu a damma, “U ta dansa ne adama a na tsu ta̱wa̱yi na̱ ko oopopofu shi.”
\p 
\v 8 Ana Yesu revei ili i na aa dansa, ɗaɗa we ece nle, “Nye i zuwai i ri a ndammulai adama a na i ri no opopofu shi? Ucawu wo okolo a̱ ɗu waꞌa ɗa.
\v 9 Hali n gogo koto i reve shi? I cuwan no opopofu o ton a na a lyuwatoi ali ukpakukupa utoꞌon (5,000) shi? Waru i cuwan i shiton ta̱ asaka a̱ a̱bunda̱ na akapi a na a pasai shi?
\v 10 Waru opopofu e cindere a na a lyuwatoi ali ukpakukupa una̱shi (4,000) gba? Asaka a gbagbain a yan ɗa i shitoyin?
\v 11 Adama a̱ nye i gura revei a na maa yuwusaan ɗu adanshi adama o opopofu shi? N ta dansaa ɗu i yuwan ugbozu na̱ wolilo wa Afarishi na aza a Sadukiya.”
\v 12 Ɗaɗa e revei waa yuwusaan le adanshi a̱ yuwan ugbozu na̱ wolilo† ko opopofu shi, amma adama o uritosu we epen wa Afarishi na aza a Sadukiya.
\s1 Bituru dammai Yesu Zamawawa ɗaɗa
\r (Mak. 8:27-30; Luk. 9:18-21)
\p 
\v 13 Yesu no ojoro a̱ yi a̱tsuma̱ a mmalu, ana a rawai zuzu na̱ mɓa̱nga̱ ma Kasariya Filibi, a̱vu we ece le, “Zane ɗa ama a tarasa Mawun ma Vuma?”
\p 
\v 14 A̱vu a̱ usu, “Ozo o ro a damma, a̱vu Yahaya za vu Urumbusu ɗa, ozo o ro gba a damma a̱vu Iliya ɗa, ozo o ro waru a damma a̱vu Irimiya† ɗa, ko gba shi vuma ta̱ a̱tsuma̱ a ama̱sula̱ a ɗa.”
\p 
\v 15 Reve we ece le, “A̱ɗu gba, zane ɗa yaa tarasa mu?”
\p 
\v 16 Reve Simo za na a̱ tsu ɗe Bituru usu, “A̱vu ɗa Zamawawa,† Mawun ma̱ A̱sula̱ za na tsu ca wuma.”
\p 
\v 17 Reve Yesu usu, “A̱vu za va abaꞌun ɗa, Bituru mawun ma Yahaya,\f + \fr 16:17 \ft Aala a Yahaya a̱yi ɗa Yunana na̱ Tsuyahuda.\f*† adama a na ko vuma roco wu ili i nda shi. Dada va̱ na ri zuva ɗa roco nuwu ko zane ɗa n ri.
\v 18 Adama o ndolo n ta̱ ɗe wu Bituru, za na urevu wa̱ yi u ɗa ‘Aatali.’ Waru a aatali a nda a ɗa maa suwa a̱a̱ꞌisa̱ a̱ a̱za̱ e Itoni† a̱ va̱, agba ucira wu ukwa̱ waa laꞌa ucira wa̱ yi shi.
\v 19 N ta ca wu mkpa̱tuꞌutsu n tsugono tsa zuva. Ili i na biti vu kpa̱tuꞌwa̱i pa o uvaɗi shi, A̱sula̱ fo wa̱a̱ usu u kpa̱tuꞌwa̱ le shi. Waru ili i na vu kpa̱tuꞌwa̱i pa o uvaɗi u nda, ele fo A̱sula̱ a̱ ta̱ kpa̱tuꞌwa̱ le.”
\v 20 Reve Yesu rono ojoro a̱ yi atsuvu she a damma nanza a na a̱yi ɗaɗa Zamawawaꞌa wan.
\s1 Yesu yuwan ta̱ adanshi o ukwa̱ wa̱ yi
\r (Mak. 8:31–9:1; Luk. 9:22-27)
\p 
\v 21 Diga a mantsaꞌa a̱ ꞌya̱wa̱, reve Yesu teme a dansaa ojoro a̱ yi ili i na yaa cina yi. A̱vu u damma, “Na̱ n ciga na̱ n ꞌyuwan n ꞌya̱wa̱ Urishelima uba̱ta̱ u na azagbain e iɗa, nan ganu a gbagbain na̱ munlu n Wila̱ n ri. A ta ca mu a̱tsuma̱lima̱ lon. A̱ to una mu, agba na a yuwan rana taꞌatsu, A̱sula̱ a̱ ta̱ ꞌya̱sa̱n mu.”
\p 
\v 22 Reve Bituru ɗe yi a̱ tyo a̱ ngeꞌen, a̱vu u damma yi u lyawa a dansa ne. U damma, “A̱sula̱ aa lyawa ili i ndolo i fara na̱ a̱vu shi, Zagbain!”
\p 
\v 23 Reve Yesu† vadala uba̱ta̱ wa̱ yi reve u damma yi, “Male, vu buwa mu ure! Vu ta̱ gesheshe ili i na A̱sula̱ a zuwaa numu n yuwan, adama a na majiyan ma̱ wu za vuma ɗa, agba u ri ununa A̱sula̱ aa yuwusan shi.”
\p 
\v 24 Reve u damma ojoro a̱ yi, “Za na suru cigai u kuru mu, she nu u ꞌyuwan aciya̱yi suru suru. Nu u ciga u ꞌyuwan u tara akpata a̱ a̱tsuma̱lima̱ a̱ yi reve u kuru mu.
\v 25 Adama a na za na cigai u wawa wuma wa̱ yi, u ta lamba yi, amma za na lambai wuma wa̱ yi adama a̱ va̱, u ta̱ tsura̱ yi.
\v 26 Nye i ɗa vuma aa muna nu u tsura̱ uvaɗi u nda suru, reve u lamba wuma wa̱ yi? Vuma aa gura tsupa† adama u tsurisa̱ wuma wa̱ yi shi, ko keꞌen.
\v 27 Adama a na a̱mu, Mawun ma Vuma, n ta̱ ta̱wa̱ na̱ tsugbain tsa Dada va̱ oɓolo na̱ nlingata ma̱ yi, a̱vu n geꞌeto ama suru ununa a yuwain ili biti.
\v 28 Amayun a ɗa maa dansaa ɗu, ozo o ro a̱tsuma̱ a̱ ɗu a na i ri pa nda mishin gogo, ya̱a̱ kuwa̱ shi, she na̱ ye ene mu, Mawun ma Vuma, a̱ ta̱wa̱ a̱tsuma̱ o tsugono tsa̱ va̱.”
\c 17
\s1 Lipu va̱ Yesu vadalai
\r (Mak. 9:2-13; Luk. 9:28-36)
\p 
\v 1 Ana a yuwain ayin a̱ ta̱li, reve Yesu ɗangwa Bituru na̱ Yakubu na̱ mawun ma̱ a̱na̱wu ma̱ yi Yahaya. Reve a̱ ꞌya̱wa̱ a kumba masasan mo ugaꞌan uba̱ta̱ u na a̱ da̱na̱i goon le.
\v 2 Ele a̱ ka̱nla̱, ɗaɗa oroci e Yesu a vadalai suru suru. Urewesu wa̱ yi e ikanasa ana urana, a̱tugu a̱ yi waru a̱ ka̱mba̱ uꞌuri puwu ana ekan.
\v 3 Reve Musa† na̱ Iliya o utushi, reve a uwa adanshi na̱ Yesu. \fig Lipu va̱ Yesu vadalai|src="Matthew_17_1-4.tif" size="span" loc="Matthew 17:2" ref="Mat. 17:2"\fig*
\p 
\v 4 Reve Bituru damma yi, “Zagbain, u lobono ta̱ a na tsu ri pa! Lyawa tsu yuwan ogodo a taꞌatsu pa, za ta̱ za va̱ wu, za ta̱ za va Musa, za ta̱ za va Iliya.”
\p 
\v 5 A̱yi ubuwu a adanshi, reve eleshe e ekan a̱ ta̱wa̱ u pupala le. A̱vu uɗyo wu uta̱ pe e elesheꞌe u damma, “A̱yi nda Mawun ma̱ va̱ ɗa, za na n cigai, n ta uwwusa uyoꞌo wa̱ yi lon. Yu uwwa yi!”
\p 
\v 6 Ana ojoroꞌo a uwwai uɗyoꞌo, reve a uwwa wovon lon hali a̱ riya̱ ma̱kpa̱ɓa̱.
\v 7 Ɗaɗa Yesu rawai reve u juꞌwa̱n le. A̱vu u damma, “ꞌYoyin, she yu uwwa wovon wan!”
\v 8 Ɗaɗa a̱ ꞌya̱sa̱in aci a̱ ka̱lyuwa̱i, agba e ene za ro shi, she Yesu.
\p 
\v 9 Ele a̱ ma̱cipa̱a̱ a masasaꞌan, reve u damma le, “She i damma nanza ili i na ye enei wan, she na̱ a̱ ꞌya̱sa̱n mu, a̱mu Mawun ma Vuma a̱tsuma̱ a̱ a̱kwa̱kwa̱.”
\p 
\v 10 Reve ojoroꞌo e ece yi, “O una̱ wu nye munlu n Wila̱ n dammai a na Iliya ɗa a fara ta̱wa̱ kafu Zamawawa ta̱wa̱?”
\p 
\v 11 Reve u damma le, “Amayun a ɗa Iliya ta̱ ta̱wa̱ u foɓo ili biti.
\v 12 Agba amayun, Iliya ta̱wa̱ ta̱ ɗe. Agba ama e reve a na a̱yi ɗa shi, reve a yuwaan yi ununa a cigai. Aa jima shi, ne ɗa fo aa zuwa Mawun ma Vuma mo sowo a̱tsuma̱lima̱.”
\v 13 Ɗaɗa ojoroꞌo e revei u ta yuwusaan le adanshi a Yahaya za vu Urumbusu.
\s1 Yesu ka̱mba̱toi ulobo wo otoni a̱ lima̱ gbaga
\r (Mak. 9:14-29; Luk. 9:37-43a)
\p 
\v 14 Ana Yesu no ojoro a̱ yi a̱ cipa̱i zuva masasaꞌan, oɓolo a ama a̱ a̱bunda̱ a̱ shi ta̱ lo a pura le. A̱vu vuma ro ta̱wa̱ u kingyo a̱ ma̱ka̱ka̱n ma̱ yi.
\v 15 Reve u damma, “Zagbain, ve ene iliyali i mawun ma̱ va̱! U ta̱ na̱ tsudaꞌun tsu ucira, hali u tsu riya̱ ta̱ a akina ko a̱ mini kuci.
\v 16 N ta̱wa̱ ta̱ na̱ a̱yi uba̱ta̱ wo ojoro a̱ wu, agba ko vuma ta̱ gura ka̱mba̱to yi gbaga shi.”
\p 
\v 17 Reve Yesu usu, “A̱ɗu ama o okolo o ugbamu, a̱za̱ o ulambu wu ucawu wo okolo. Hali mantsa ma ne ma ɗa ma̱a̱ da̱na̱ na̱ a̱ɗu? Waru hali mantsa ma̱ ne ma ɗa maa gura da̱nu na̱ a̱ɗu na ankuri? Ta̱wa̱i nu uloboꞌo pa nda!”
\v 18 Reve u ɓara otoni a̱ lima̱ a na a̱ ri pe o uloboꞌo, a̱vu otoni a̱ lima̱ꞌa̱ o uta̱. Diga a mantsa mo ndolo, reve u ka̱mba̱ gbaga suru suru.
\p 
\v 19 Ana alanga a jimai, a̱yi a̱ ndeꞌen, reve ojoro a̱ yi a̱ ta̱wa̱ uba̱ta̱ wa̱ yi a̱vu e ece yi, “Adama a̱ nye tsu kuɗa̱i o uta̱a̱ otoni a̱ lima̱ꞌa̱?”
\p 
\v 20 Reve u usu le, “Adama a na i ri nu ucawu wo okolo waꞌa ɗa. Amayun a ɗa maa dansaa ɗu, ni i ri nu ucawu wo okolo keꞌen cine i revei cuꞌun vu suꞌwanꞌuri, i ta damma masasan ma nda, ‘Lyawa uba̱ta̱ u nda a̱ tyo ndeɗe,’ a̱vu gba u lyawa. I ta gura yuwan ili suru.”\f + \fr 17:20 \ft Akuci a aatagada a nda a̱ da̱shi ta̱ uguzu wu 21: “Amma avasa na akuli a ɗa goon aa gura cuꞌun vi ili i nda, ili yi lo i na i laꞌai ne shi.”\f*
\s1 Yesu yuwisain adanshi o ukwa̱ wa̱ yi
\r (Mak. 9:30-32; Luk. 9:43b-45)
\p 
\v 22 Urana u ro cina a̱ ka̱mba̱ Ga̱lili, a̱vu Yesu damma le, “Za ro ta wina Mawun ma Vuma.
\v 23 A̱ to una yi, agba na a yuwan ayin a taꞌatsu a̱ ta̱ ꞌya̱sa̱n yi.” Reve a̱tsuma̱ a̱ la̱nga̱ ojoroꞌo lon.
\s1 Yesu yuwain adanshi a atsupu o utafa
\p 
\v 24 Ana Yesu no ojoro a̱ yi a rawai Kafarnahum, reve a̱za̱ o ushishi wu utafa wa̱ A̱a̱ꞌisamapaɗa e ece Bituru, “Manlu ma̱ ɗu ma tsu tsupa utafa\f + \fr 17:24 \ft Danshi na a yuwayin ulinga pa nda na̱ Tsuheleni a̱yi ɗa “utafa wa̱ A̱a̱ꞌisamapaɗa drakma re.” Ka̱lyuwa̱ Ucuɗuwu wi “Ikebe.”\f* wa̱ A̱a̱ꞌisamapaɗa shi?”
\p 
\v 25 A̱vu Bituru usu, “U tsu tsupa ta̱.”
\p Reve Bituru uwa o uꞌwaꞌa, a̱vu kafu u yuwan adanshi, ɗaɗa Yesu ece niyi, “Ngono n tsu zuwaa ta̱ ama e le utafa, ko omocin?”
\p 
\v 26 Reve u usu, “Omocin a ɗa a tsu zuwaa utafa.”
\p A̱vu Yesu usu, “To, wo oꞌwo ta̱ ama e le aa tsupa shi.
\v 27 Amma woo lobono tsu ꞌya̱sa̱n okolo a ama shi. Adama o ndolo, ꞌya̱wa̱i mavusa a mala. Magula ma na i fara remei, i kpa̱tuꞌwa̱ una̱ wa̱ yi, i ta̱ tsura̱ ikebe† i azurufa\f + \fr 17:27 \ft Danshi na a yuwayin ulinga pa nda na̱ Tsuheleni a̱yi ɗa “ikebe yi irumu i drakma i na̱shi.” Ka̱lyuwa̱ Ucuɗuwu wi “Ikebe.”\f* i na i rawai atsupu o utafa wa̱ A̱a̱ꞌisamapaɗa za va̱ na̱ za ɗu. I tara i tsupa le utafa u tsu.”
\c 18
\s1 Za na laꞌai tsugbain o tsugono tsa zuva
\r (Mak. 9:33-37; Luk. 9:46-48)
\p 
\v 1 A mantsaꞌa, reve ojoro e Yesu a̱ ta̱wa̱ uba̱ta̱ wa̱ yi, reve e ece yi, “Zane ɗa oo oꞌwo zagbain suru suru a̱tsuma̱ o tsugono tsa zuva?”
\p 
\v 2 Ɗaɗa Yesu ɗeyi mawun mo ro, reve wi isawaton yi a̱ ma̱ka̱ka̱n me le.
\v 3 A̱vu u damma, “Amayun a ɗa maa dansaa ɗu, ni i ciga i ꞌyuwan yoo oꞌwo ununa muwun n kekeꞌen n ri. Na̱ ne ɗa shi, yaa uwa o tsugono tsa zuva shi.
\v 4 Adama o ndolo za na tarai aciya̱yi ili i ro shi, ana mawun me keꞌen ma nda, a̱yi ɗa za na laꞌai tsugbain o tsugono tsa zuva.
\p 
\v 5 “Waru za na ushiyi mawun me keꞌen ma nda a aala a̱ va̱, a̱mu ɗa u ushiyi.”
\s1 Ma̱lyungwa̱ ma na ma̱ tsu ta̱wa̱ nu unusu
\r (Mak. 9:42-48; Luk. 17:1-2)
\p 
\v 6 A̱vu Yesu lyuwa elime u damma, “Woo yoꞌono aza a na aa zuwa ko vuma ta̱ a̱tsuma̱ a aza a na oo tono mu yuwan unusu shi. U ta laꞌaa le a̱ nla̱a̱ le aatali a yira a̱ yinlu a vari le a̱tsuma̱ a mala upasu u na u laꞌai a̱ruꞌun!
\p 
\v 7 “Woo yoꞌono ama shi, adama e ili i na yaa zuwusa ama ma̱riya̱ o unusu. A̱ ri ni ili i na aa yuwan shi, ili i ndolo i ta fara, agba woo yoꞌono aza a na a̱ ta̱wa̱i ne ele shi!
\v 8 Nu ukere wa̱ wu ko anana a̱ wu aa zuwusa wu mayan mo unusu, vu koɗo yi vu vari yi. U ta laꞌaa wu vu lamba upasu u lipu u ro wa̱ wu, reve vo oꞌwo na̱ wuma u na va̱a̱ kuwa̱ shi a na va̱a̱ da̱na̱ ne ekere e re na ana e re a̱vu a vari wu a akina a na a̱ ri n kima̱ shi.
\v 9 Na̱ lyusu va̱ wu aa zuwusa wu mayan mo unusu, vu foɗo yi vu vari yi. U laꞌaa wu ta̱ vu da̱na̱ na̱ lyusu ta̱ goon a̱vu vu da̱na̱ wuma, a na va̱a̱ da̱na̱ ne esu e re reve a vari wu a akina a na a̱ ri kima̱ shi.”
\s1 Iroci yi kyon na puwa̱yin
\r (Luk. 15:3-7)
\p 
\v 10 A̱vu waru Yesu damma, “I yuwan ugbozu. She i tara a̱za̱ e kekeꞌen a nda ili ye pere wan. N ta dansaa ɗu, a̱ ta̱ na̱ nlingata zuva n na n ri oɓolo na̱ Dada va̱ zuva.\f + \fr 18:10 \ft Akuci a aatagada a nda a̱ ta̱ na̱ a̱yi nda, “Amma a̱mu, Mawun ma Vuma, n ta̱wa̱ ta̱ adama n wawa aza a na a̱ puwa̱yin.”\f*
\p 
\v 12 “Na̱ za va aguɓa ri ni ikyon ukpaku, reve za ta̱ uta̱ reve u puwa̱n, nye i ɗa waa yuwan? U ta lyawa kupakucci na̱ kucci na buwai a alyuna a̱ ngeꞌen m masasan, reve u ꞌya̱wa̱ izami yi kyon ta̱ na puwa̱yiꞌin.
\v 13 Nu u tsura̱ yi, amayun a ɗa maa dansaa ɗu, u ta laꞌa yuwan ma̱za̱nga̱ a aci a̱ za ta̱ o ndolo, a na waa yuwan a aci a kupakucci na̱ kucci na buwai. \fig Kyon na puwa̱yin|src="Matthew_18_12.tif" size="span" loc="Matthew 18:13" ref="Mat. 18:13"\fig*
\v 14 Ne ɗa u ri ya Dada ɗu za na ri zuva. U ciga ko za ta̱ a̱tsuma̱ a̱ a̱za̱ e kekeꞌen a nda u puwa̱n shi, suru suru.”
\s1 Na̱ za ro nusaan wu
\r (Luk. 17:3)
\p 
\v 15 Reve Yesu lyuwa elime u damma, “Nna̱ za va̱ wu yuwaan wu unusu, ꞌya̱wa̱ ya̱ꞌa̱ yi, a̱vu vu roco yi unusu wa̱ yi. Agba vu yuwan yi usokowu, a̱vu na̱ a̱yi goon. Na̱ vumaꞌa wu uwwa wu, vu lyuwa ta̱ aci a za va̱ wu waru vu ka̱mba̱to ta̱ za va̱ wu.
\v 16 Nu u ꞌyuwan gba a uwwa wu, vu tara vuma ta̱, ko ama e re i ꞌya̱wa̱ oɓolo. Vu yuwan ne adama a na Adanshi a̱ A̱sula̱ a damma ta̱ adanshi o una̱ wa ama e re ko ama a taꞌatsu a aci a za ro u laꞌa ta̱ ume. \x ◊ \xo 18:16 \xt U.Wl. 19:15.\x*
\v 17 Nu u ꞌyuwan a uwwa le fo, vu damma a̱za̱ e Itoni. Nu u ꞌyuwan waru a uwwa a̱za̱ e Itoni, to, vu yuwan na̱ a̱yi ununa vaa yuwan na̱ za na revei A̱sula̱ shi, ko ana manlu mo uꞌushishi mo utafa.”
\s1 Ma̱nla̱ na̱ ma̱ba̱ɗa̱
\p 
\v 18 A̱vu waru Yesu damma, “Amayun a ɗa maa dansaa ɗu, Ili i na suru yi nla̱i pa o uvaɗi u nda, A̱sula̱ za na ri zuva ta̱ a̱ nla̱ yi fo. Agba ili i na suru i ba̱ɗa̱i, u ta̱ ba̱ɗa̱ yi fo.
\p 
\v 19 “Waru, n ta dansaa ɗu, na ama e re a̱tsuma̱ a̱ ɗu a yuwan a̱sa̱la̱ e ili i na a cigai, reve a vasa adama a̱ yi, Dada va̱ za na ri zuva ta yuwaan ɗu a̱yi.
\v 20 Adama a na uba̱ta̱ u na ama e re ko ama a taꞌatsu o ɓolotoi a aala a̱ va̱, n ta̱ lo oɓolo ne ele.”
\s1 Iroci ya aagbashi a na a ꞌyuwain a yuwan gafura
\p 
\v 21 Reve Bituru ta̱wa̱ ya̱ Yesu we ece, “Zagbain, na̱ za va̱ aa nususaan mu, hali uyan u ɗa maa yuwaan yi gafura? Toto ucindere?”
\p 
\v 22 A̱vu u usu, “Oꞌo, toto ucindere shi, amma kupocindere toto ucindere.
\p 
\v 23 “Nda cine tsugono tsa zuva tsa̱ ri: A yuwan ta̱ mogono mo ro za na cigai u ushi ikebe i na woo tono agbashi a̱ yi.
\v 24 A̱yi a̱tsuma̱ o uꞌushishi, reve a̱ ta̱wa̱ na̱ vuma ro za na woo tono ikebe i gbain i azurufa ukpakukupa kupa (10,000).\f + \fr 18:24 \ft Ikebe yi rumu i azurufa i gbain a̱yi ɗa a̱ tsu ɗe “talen” na̱ Tsuheleni, una̱ta̱ u ɗa talen ta̱ ri ni ikebe i na aa tsupa za zamalinga a̱tsuma̱ a aꞌwan gendu. Talen ukpakukupa kupa (10,000) laꞌa ta̱ ikebe ya atsupu yi za zamalinga vu rana ukpakukupa udoɓonuwu kupoton (50,000,000).\f*
\v 25 Aagbashiꞌi gba u shi ni ikebe i na waa gura tsupa yi shi. Ɗaɗa mogonoꞌo u zuwai a wina vumaꞌa ni ili i na u ri na̱ a̱yi suru, hali na̱ ka va̱ yi na̱ muwun ma̱ yi. Reve a tara ikebeꞌe a tsupa mogonoꞌo utan u na woo tono aagbashiꞌi.
\p 
\v 26 “Amma a̱vu aagbashiꞌi u kingyo, reve u pati u damma, ‘Vu yuwan ankuri na̱ a̱mu, n ta tsupa ili i na n kopoi suru.’
\v 27 Reve mogonoꞌo we ene yi iliyali lon, reve u lyawa yi, a̱vu u damma yi she u tsupa ikebeꞌe waru wan.
\p 
\v 28 “Aagbashiꞌi a̱ mota̱a̱, a̱vu u gaꞌan na aagbashi o ro za na woo tono ikebe i keꞌen i azurufa\f + \fr 18:28 \ft Ikebe yi rumu i azurufa i ɗa a̱tsu ɗe “dinari,” atsupu o urana u ta̱ wu za zamalinga.\f* ukpaku. Ɗaɗa u gaga niyi oogorovili. Reve u uwa a̱ cukuɗusa̱ yi nu u dansai, ‘Vu tsupa mu utan u va̱!’
\p 
\v 29 “Reve aagbashiꞌi u kingyo, reve u pati yi u damma, ‘Yuwan ankuri na̱ a̱mu, n ta tsupa wu ili i na voo tono mu suru.’
\p 
\v 30 “Agba a̱vu aagbashi o ufaruꞌu u ꞌyuwan e ene iliyali ya̱ yi. Reve u zuwa a̱ ɓa̱ru yi o uꞌwa wa ali, hali she nu u tsupa ili i na oo tono yi.
\v 31 Ana akapi a agbashi e enei ili i na u yuwain, reve a uwwa upan lon. Ɗaɗa a̱ ꞌya̱wa̱i uba̱ta̱ u mogonoꞌo, reve a damma yi ili i na i yuwain suru.
\p 
\v 32 “Ɗaɗa mogonoꞌo u ɗeyi aagbashiꞌi reve u damma, ‘A̱vu aagbashi a vama! Ana vu pati numu, n lyawaa wu ta̱ utaꞌan, reve n damma she vu tsupa ili wan.
\v 33 Vu shi ta̱ fo ee ene iliyali ya aagbashi o ndolo ununa me ene nuwu iliyali.’
\v 34 Reve mogono ma uwwa upan lon, a̱vu u zuwa a zuwa yi o uꞌwa wa ali, u sowo a̱tsuma̱lima̱ hali u tsupa ili i na oo tono yi suru.
\p 
\v 35 “Ne ɗa Dada va̱ za na ri zuva aa yuwan na̱ a̱ɗu nni i ꞌyuwan a yuwaan a̱za̱ a̱ ɗu gafura o okolo a̱ ɗu.”
\c 19
\s1 Uritosu adama a wukasu u lolo
\r (Mak. 10:1-12)
\p 
\v 1 Ana Yesu kotoi adanshi o ndolo, reve u lyawa Ga̱lili a̱vu u ka̱ra̱ a̱ tyo e iɗa ya Yahuda upasalai wu Uɗolu wa̱ Urdu.
\v 2 Reve oɓolo a ama o toni yi, a̱vu u ka̱mba̱to a̱za̱ o ubanakun gbaga.
\p 
\v 3 A̱vu Afarishi o ro a ciga a lyungwa̱ yi na̱ yeci, reve a damma, “Wila̱ u tsu u lyawa ta̱ vuma kakasa na̱ ka va̱ yi ko adama e ili i ro i na we enei suru?”
\p 
\v 4 Reve Yesu usu, “Koto i ɗenuna̱ a̱tsuma̱ a Adanshi a̱ A̱sula̱ shi? A ɗana ta̱ ana A̱sula̱ a yuwain uvaɗi, ‘U yuwan le ta̱ vali na̱ ka.
\v 5 A̱yi ɗa i zuwai vali aa lyawa dada va̱ yi na̱ mma va̱ yi reve e remulei na̱ ka va̱ yi, a̱vu ele ra o oꞌwo ili i ta̱.’ \x ◊ \xo 19:5 \xt Ufr. 1:27; Ufr. 2:24; Ufr. 5:2.\x*
\v 6 Ana wo oꞌwoi a buwa ili i re shi, agba ili i ta̱, adama o ndolo ili i na A̱sula̱ o ɓoloi she nanza kakasa wan.”
\p 
\v 7 A̱vu Afarishi e ece yi, “To, adama a̱ nye i ɗa Musa lyawai vuma ca ka va̱ yi aatagada a wukasu u lolo reve u gba̱ra̱ yi?”
\p 
\v 8 A̱vu Yesu usu, “Musa lyawa ɗu ta̱ i kakasa na̱ a̱ma̱ci a̱ ɗu, adama a na i ꞌyuwain a̱ kuru ili i na A̱sula̱ a dammai, amma ɗe o ufaru ne ɗa u shi shi.
\v 9 Waru lyawa n damma ɗu nda, za na suru lyawai ka va̱ yi reve u yuwisan lolo ro, tsipere tsa ɗa waa yuwusan, shede na̱ kaꞌa u ri e tsipere na ali o ro.”
\p 
\v 10 Reve ojoro a̱ yi a damma yi, “Na̱ ne ɗa iliꞌi i ri e ekere a vali na̱ ka va̱ yi, u laꞌa ta̱ ulobonu she vuma yuwan lolo wan.”
\p 
\v 11 A̱vu Yesu usu, “Vuma suru ɗa aa gura usu uritosu u nda shi, amma she aza a na A̱sula̱ a cayi.
\v 12 Ili i na i zuwai ozo o ro aa yuwan lolo shi a̱yi ɗa, ozo o ro a matsan le ta̱ ali agba a̱ ri gbaga shi. Ozo o ro waru ama a ɗa a̱ ka̱mba̱to nle ne. Ozo o ro waru a ꞌyuwan ta̱ lolo adama o tsugono tsa zuva. Za na aa gura tara uritosu u nda u tara.”
\s1 Yesu ushiyi muwun
\r (Mak. 10:13-16; Luk. 18:15-17)
\p 
\v 13 Reve ama o ro a̱ ta̱wa̱a̱ Yesu na̱ muwun n le, adama u juꞌwa̱n le u yuwaan le avasa. A̱vu ojoro a̱ yi a putsaa aza a na a̱ ta̱wusa̱a̱ na̱ muwuꞌun, a lyawa a damatosun yi.
\p 
\v 14 Reve gba Yesu damma le, “Lyawai muwun n kekeꞌen n ta̱wa̱ ya̱ꞌa̱ va̱, she i putsaa le wan. Icuꞌun ya ama a na a̱ ri tsa̱ muwun n nda, tsugono tsa zuva za le ɗa.”
\v 15 Ana Yesu juꞌwa̱in muwuꞌun, reve u zuwaa le abaꞌun ɗaɗa u ka̱ra̱i.
\s1 Za vu utsuru
\r (Mak. 10:17-31; Luk. 18:18-30)
\p 
\v 16 Ana a yuwain ne, reve vuma ro ta̱wa̱ ya̱ Yesu reve we ece yi, “Manlu, ili ya̱ a̱ɓula̱ i ne i ɗa maa yuwan tsa̱ra̱ n tsura̱ wuma u na woo koto shi?”
\p 
\v 17 Reve Yesu damma yi, “Adama a̱ nye vee eceshe mu ili ya̱ a̱ɓula̱? A̱sula̱ ɗa goon za va̱ a̱ɓula̱. Na̱ vu ciga vu tsura̱ wuma u babu ukotu, ciga ꞌyuwan vu kuru Wila̱ wa̱ yi.”
\p 
\v 18 A̱vu vumaꞌa we ece, “Wila̱ u ne u ɗa?”
\p Reve Yesu usu, “She vu una za nu ucigu wa̱ wu wan. She vu yuwan tsipere wan. She vu yuwan wivu wan. She vu yuwan epen a aci o ozo ro wan.
\v 19 Vu ca aabara na̱ makuci ma̱ wu tsugbain. Vu ciga ozo o ro ununa vu cigai aciya̱wu.” \x ◊ \xo 19:19 \xt Mta̱. 20.\x*
\p 
\v 20 Reve vumaꞌa\f + \fr 19:20 \ft Vumaꞌa u rawa ta̱ na waa yuwan lolo, agba koto u yuwan lolo shi.\f* u usu, “Ele nda suru n yuwan le ta̱ ɗe. Nye i buwai na maa yuwan waru?”
\p 
\v 21 A̱vu Yesu usu, “Na̱ vu ciga vu shiwan vuma, ꞌya̱wa̱ vu wina ili i na vu ri na̱ a̱yi suru, reve vu neꞌeshen alambi ikebeꞌe, vu ta̱ tsura̱ uzuwa zuva. Reve vu ta̱wa̱ vu kuru mu.”
\p 
\v 22 Ana vumaꞌa wu uwwai ne reve a̱tsuma̱ a̱ la̱nga̱ yi, adama a na u ta̱ nu utsuru lon. Reve u ka̱ra̱ ili ya̱ yi.
\p 
\v 23 Ɗaɗa Yesu dammai ojoro a̱ yi, “Amayun a ɗa maa dansaa ɗu, ili yu usa̱n i ɗa za vu utsuru uwa o tsugono tsa zuva.
\v 24 Amayun n ta dansaa ɗu, u ta laꞌa babu usa̱n aarakumi a̱ pusula̱i na̱ vunu vu bele, a na za vu utsuru aa uwa o tsugono tsa̱ A̱sula̱.”
\p 
\v 25 Ana ojoro a̱ yi a uwwai ne, reve a uwa asalama lon, reve e ece, “To, zane gba aa laꞌa?”
\p 
\v 26 A̱vu Yesu ka̱lyuwa̱ le u damma, “E ekere a vaɗilima̱ iliꞌi i ri n yuwan shi, amma uba̱ta̱ wa̱ A̱sula̱ ili biti u ta gura yuwan.”
\p 
\v 27 Ɗaɗa Bituru damma niyi, “A̱tsu ɗa nda tsu lyawai ili suru, reve tsu kuru wu. Nye ɗa gba tsa̱a̱ tsura̱ adama o ndolo?”
\p 
\v 28 Reve Yesu damma le, “Amayun a ɗa maa dansaa ɗu, a mantsa ma na a̱mu Mawun ma Vuma, ma̱a̱ da̱nu o ootogu o tsugbain a mantsa ma na ma̱a̱ ta̱wa̱, a̱ɗu aza a na oo tono mu i ta̱ da̱nu o otogu kupa ne ejere, waru i ta̱ geꞌeto gundo kupa ne ejere va Israꞌila.
\v 29 Aza a na a lyawai ili suru suru adama a̱ va̱, a lyawai ꞌwa le ko a̱ɗuma̱ e le, a̱ ta̱ tsura̱ atsupu. Ne ɗa waru na a lyawa a̱za̱ e le ali ne esheli, ko a lyawa nan dada na̱ nan mma le, ko gba a lyawa muwun, a̱ ta̱ tsura̱ atsupu hali a̱ tyo toto ukpaku, waru a̱ ta̱ tsura̱ wuma u na woo koto shi.
\v 30 Agba na̱ a̱bunda̱ aza a na a̱ ri elime gogo a̱ ta̱ ka̱mba̱ a̱ca̱pa̱, waru aza a na a̱ ri a̱ca̱pa̱ gogo a̱ ta̱ tyo elime.”
\c 20
\s1 Iroci ya aza a zamalinga
\p 
\v 1 Ana Yesu uwai o rocosu ama ununa tsugono tsa zuva tsa̱a̱ da̱na̱, a̱vu u damma, “A yuwan ta̱ vuma ro za na da̱na̱i nu uɗuma̱ wa inabi. Urana u ro, reve wu uta̱ na̱ wasasa adama u zami aza a zamalinga adama a lingaa yi uɗuma̱ wa̱ yi.
\v 2 A̱vu u damma u ta tsupa le ununa a tsu tsupa ikebe i azurufa yu ulivu irumu i ta̱ ta̱. Reve u tara le a̱ tyo o uɗuma̱ꞌa̱ a linga yi.
\p 
\v 3 “Ana alanzu a gaɗuwai, a̱yi o utula̱i e eden reve u cina ozo o ro lo a̱ mishin me pere.
\v 4 Reve u banu le fo a̱ tyo o uɗuma̱ wa̱ yi, a̱vu u damma le u ta tsupa le ili i na i lobonoi nu urana u riya̱.
\v 5 A̱vu a̱ ka̱ra̱ e reme ulinga o uɗuma̱ꞌa̱.
\p “Nu urana a aci na̱ rumu taꞌatsu vu urana reve u yuwisan ne.
\v 6 Waru ana u buwai rumu ta̱ na aa lyawa ulinga, reve wu utisa̱ a̱ lyuci, a̱vu waru u cina ama o ro mishin lo. Reve we ece le, ‘Adama a̱ nye yaa yuwusan ulinga anaꞌan shi?’
\p 
\v 7 “Reve a̱ usu, ‘Adama a na ko za tara tsu shi!’
\p “A̱vu u damma le, ‘To, ꞌya̱wa̱i i linga o uɗuma̱ u va̱.’
\p 
\v 8 “Ana urana u kotoi, reve za vu uɗuma̱ꞌa̱ u ɗe za ve elime u damma yi, ‘Ɗe aza a zamalingaꞌa vu tsupa le. Vu teme na aza a na n tarai nu ukosu, reve vu koso na aza a na n fara tarai.’
\p 
\v 9 “Reve aza a na o koso tarai a yuwan ulinga wu rumu ta̱ goon a̱ ta̱wa̱ a̱ ushi atsupu e le, za suru ushi ta̱ rumu ta̱ azurufa.
\v 10 Ana aza a na e temei ulinga ili yu usana a̱ ta̱wa̱i tsa̱ra̱ a̱ ushi atsupu e le, a ta dansa a̱ ta̱ ushi ili i na i laꞌai a̱za̱ a̱ a̱za̱ e le. A̱vu wo oꞌwo ele fo irumu i ta̱ ta̱ i azurufa i ɗa a tsupa nle.
\v 11 Ana a̱ ushiyi ikebe i le, reve a̱ ꞌya̱wa̱ na adanshawuya uba̱ta̱ wu za vu uɗuma̱ꞌa̱.
\v 12 Reve a damma, ‘Aza a na a tarai na̱ a̱ca̱pa̱ rumu ta̱ ɗa goon a lingai. A̱vu vu tsupa le una̱ta̱ na̱ a̱tsu. A̱tsu gba tsu linga ta̱ a̱tsuma̱ o usuɗuwu wu urana hali a̱ tyo ulivu!’
\p 
\v 13 “Reve za vu uɗuma̱ꞌa̱ u usu za ta̱ a̱tsuma̱ e le, ‘Iꞌutsa̱ i va̱, m paala wu shi. N tsupa wu ta̱ ili i na tsu yuwain adanshi.
\v 14 Tara ikebe ya̱ wu vu ka̱ra̱! N tara ta̱ n tsupa za na a tarai o ukosu una̱ta̱ na̱ a̱vu.
\v 15 N ta gura yuwan ununa n cigai ni ikebe i va̱. Vu ta̱ a̱ tsushuꞌun o una̱ u na n yuwayin ama a̱ ndeɗe isaꞌani?’ ”
\p 
\v 16 Ɗaɗa Yesu tsu damma, “Ne ɗa u ri. Za ve elime gogo u ta̱ ka̱mba̱ a̱ca̱pa̱, waru za va̱ a̱ca̱pa̱ ta̱ ka̱mba̱ elime.”
\s1 Yesu yuwisan ta̱ adanshi o ukwa̱ wa̱ yi wa taꞌatsu
\r (Mak. 10:32-34; Luk. 18:31-34)
\p 
\v 17 Yesu a̱tsuma̱ a mmalu a̱ tyo Urishelima, reve u ɗe ojoro a̱ yi kupa ne ejere a̱ ngeꞌen a̱vu u damma le,
\v 18 “Na̱ tsu rawa Urishelima a ta wina Mawun ma Vuma e ekere a nan ganu a gbagbain na̱ munlu n Wila̱. A ta yuwaan yi ugeꞌetosu u na oo una yi.
\v 19 Reve a zuwa yi e ekere a Atakpaci aza a na aa yuwaan yi ulamu, a fufaba yi, reve a vara yi a akpata. Agba o urana wa taꞌatsu A̱sula̱ a̱ ta̱ ꞌya̱sa̱n yi a̱tsuma̱ a̱ a̱kwa̱kwa̱.”
\s1 Ipati yi ka ro o una̱ u muwun ma̱ yi
\r (Mak. 10:35-45)
\p 
\v 20 A̱vu ka va̱ Za̱ba̱di rawa no olobo a̱ yi e re, Yakubu na̱ Yahaya. Reve u kingyo u uwa ipati ya̱ Yesu yuwaan yi ili i ro.
\p 
\v 21 A̱vu Yesu ece, “Nye i ɗa vu cigai?”
\p A̱vu u damma, “A mantsa ma na vu da̱nuyi o tsugono tsa̱ wu, vu ta lyawa muwun n va̱ n nda a̱ da̱nu uba̱ta̱ u tsugbain zuzu na̱ a̱vu, za ta̱ o ukere usaꞌani za ta̱ waru o ukere ugula̱ wa̱ wu?”
\p 
\v 22 A̱vu Yesu damma, “I reve ili i na yaa patishi shi. I ta gura sowo mokoto ma̱ a̱tsuma̱lima̱ ma na maa zama n sowo?”
\p Reve oloboꞌo a̱ usu, “Ee, tsu ta gura.”
\p 
\v 23 Reve Yesu usu, “Amayun a ɗa i to sowo a̱tsuma̱lima̱ꞌa̱! Agba maa gura ɗangwa za na a̱a̱ da̱nu o usaꞌani ko o ugula̱ u va̱ shi. Ele ba̱ta̱ ndolo uba̱ta̱ wa aza a na Dada va̱ foɓoyi ɗa.”
\p 
\v 24 Ana akapi o ojoro kupa a uwwai ne, reve a uwa upan na̱ muwun ma̱ a̱na̱wu n reꞌe.
\v 25 A̱vu Yesu ɗe aza a na oo tono yi suru reve u damma, “I reve ta̱ a̱za̱ o tsugono tsa Atakpaci a ciga ta̱ o roco tsugbain tse le e ekere a ama. Waru aza a tsugbain tse le a tsu ciga ta̱ o roco a na a̱ ri nu ucira.
\v 26 Agba e ekere a̱ ɗu, she wo oꞌwo ne wan. Za na biti cigai wo oꞌwo zagbain a̱tsuma̱ a̱ ɗu, she nu u ka̱mba̱ aagbashi a akapi a na a buwai.
\v 27 Waru za na cigai wo oꞌwo za ve elime, she nu u yuwan ulinga u tsugbashi a̱ tyo a akapi suru.
\v 28 Adama a na ko a̱mu, Mawun ma Vuma n ta̱wa̱ tsa̱ra̱ a yuwaan mu tsugbashi shi, amma n yuwaan ama, waru n ca aciya̱va̱ adama a wawa ama na̱ a̱bunda̱ a̱tsuma̱ a̱ nusu le.”
\s1 Yesu ka̱mba̱to ta̱ nrumba̱ n re gbaga
\r (Mak. 10:46-52; Luk. 18:35-43)
\p 
\v 29 Yesu no ojoro a̱ yi a lyawa ta̱ Jeriko, reve oɓolo a ama a̱ a̱bunda̱ a̱ kuru yi.
\v 30 Nrumba̱ n re n da̱na̱ ta̱ lo nden a̱ ngeꞌen mu ure. Ana a uwwai Yesu ɗa ri lo a̱ ka̱ra̱, ɗaɗa a uwai yisaali adansa, “Zagbain, Mawun ma̱ Da̱wuda! Ka̱lyuwa̱ iliyali i tsu!”
\p 
\v 31 Reve oɓolo a amaꞌa a ɓara le a̱ ɓa̱ru na̱ le, a̱vu gba a̱ da̱shi ꞌya̱sa̱n uɗyo lon, “Zagbain, Mawun ma̱ Da̱wuda! Ka̱lyuwa̱ iliyali i tsu!”
\p 
\v 32 Ana Yesu uwwa nle, reve wi isawan we ece, “Nye i cigai n yuwaan ɗu?”
\p 
\v 33 Ɗaɗa a̱ usuyi, “Zagbain, tsu ciga ta̱ tse ene!”
\p 
\v 34 A̱vu Yesu ene iliyali i le, reve u juꞌwa̱n esu e le. Ɗaɗa esu e le a̱ kpa̱tuꞌushi, reve e ene ure, ɗaɗa a̱ kuru niyi.
\c 21
\s1 Yesu uwai Urishelima
\r (Mak. 11:1-11; Luk. 19:28-40; Yah. 12:12-19)
\p 
\v 1 Yesu no ojoro a̱ yi a marawaa zuzu na̱ Urishelima, reve a rawa a̱ lyuci va Batafaji zuzu na̱ Masasan ma̱ Zetun.† A̱vu u lyungu ojoro e re elime a̱ yi.
\v 2 A̱vu u damma le, “ꞌYa̱wa̱i a̱ ma̱lyuci ma na ma̱ ri elime. Nni i rawa, i te eneshi molloli na̱ mma va̱ yi ugutsuwu. I ba̱ɗa̱ le, reve i ta̱wa̱a̱ mu ne ele. \fig Nloli n re|src="Matthew_21_2.tif" size="span" loc="Matthew 21:2" ref="Mat. 21:2"\fig*
\v 3 Na̱ za ro ece ɗu, adama a̱ nye ya̱a̱ ba̱ɗa̱sa̱ le, i damma, ‘Zagbain ciga le ta̱!’ U ta lyawaa ɗu nloliꞌi babu addama o ro.”
\p 
\v 4 Ili i nda i fara ta̱ adama o shiton ili i na Zakariya vumava̱sula̱ dammai:
\q1 
\v 5 “Dammai a̱za̱ a̱ Urishelima:
\q1 ‘Mogono ma̱ ɗu moo ta̱ lo a̱ ta̱wa̱!
\q1 U tara aciya̱yi ili i ro shi, reve u kumba mololi.
\q1 U ta̱ lo a̱ ta̱wa̱ ukumbu o molloli.’ ” \x ◊ \xo 21:5 \xt Zak. 9:9.\x*
\p 
\v 6 Reve ojoroꞌo a̱ ka̱ra̱ a yuwan ili i na Yesu damma nle a yuwan.
\v 7 A̱vu a̱ ta̱wa̱a̱ na̱ mololi na̱ molloliꞌi, reve ojoroꞌo fo o polo ɗe o nloliꞌi itana i le. Reve Yesu kumba.
\v 8 Ama na̱ a̱bunda̱ o poluso ta̱ amuna e le o ure. Ozo o ro gba shi a kuɗusa a̱vuꞌun no o poluso nle o ure.
\v 9 A̱vu ozo o ro a uwa elime e Yesu, ozo o ro gba shi a̱ da̱na̱ oo tono yi a̱ca̱pa̱. Reve a saalasa,
\q1 “Husana!† Ica a̱ tyo a Mawun ma̱ Da̱wuda!”
\q1 “A̱sula̱ a zuwaa za na a̱a̱ ta̱wa̱ a̱tsuma̱ a ala a̱ A̱sulazuva abaꞌun!”
\q1 “Ica a̱ tyo e ekere a̱ A̱sula̱!”
\p 
\v 10 Ana Yesu uwai a̱tsuma̱ a̱ Urishelima,† lyuciꞌi ma̱ɓula̱ u shiwan ta̱ na̱ a̱gidiꞌya̱. Hali ama e ece, “Vuma ne ɗa gba ndaꞌa?”
\p 
\v 11 Reve oɓolo amaꞌa a̱ usu, “Vuma nda a̱yi ɗaɗa Yesu, vumava̱sula̱ diga a̱ lyuci va Nazara va̱ Ga̱lili.”
\s1 Yesu gba̱ra̱i aza a wina a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗa
\r (Mak. 11:15-19; Luk. 19:45-48; Yah. 2:13-22)
\p 
\v 12 A̱vu Yesu uwa a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗa,† reve u lo aza a na a̱ da̱na̱i a atsulu na a wini a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗaꞌa. Reve waru wu keɓe apada a na a̱ da̱na̱i a kitaꞌusa ɗe ikebe icuꞌun icuꞌun, reve fo u kekeɓe ili yu uba̱ta̱ u na a̱ da̱na̱i a winisa nrukuku.
\v 13 Reve u damma le, “Adanshi a̱ A̱sula̱ a damma ta̱, ‘E te ɗe uꞌwa u va̱ uba̱ta̱ u mayan ma avasa.’ Amma, a̱ɗu ɗa nda i ka̱mba̱to niyi upaꞌatan we evu.”
\p 
\v 14 A̱vu nrumba̱ na̱ a̱kutsuma̱ a̱ ta̱wusa̱ uba̱ta̱ wa̱ Yesu a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗa, reve u ka̱mba̱tosu le gbaga.
\v 15 Ana nan ganu a gbagbain na̱ munlu n Wila̱ me ene niyi a yuwusan ili ya asalama, reve waru e ene muwun a cuwusa yi a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗaꞌa, waru a ta dansa, “Husana!† Ica a̱ tyo a Mawun ma̱ Da̱wuda.” Reve ili i ndolo suru i zuwa nan ganu a gbagbaiꞌin na̱ munlu n Wila̱ꞌa̱ a uwwa upan lon.
\p 
\v 16 A̱vu e ece Yesu, “Vu ta uwwusa ili i na muwun n nda maa dansa?”
\p Reve u usu le, “Ee, koto i ɗenuna̱ a̱tsuma̱ a Adanshi a̱ A̱sula̱ shi?
\q1 ‘A̱vu A̱sula̱ vu rito ta̱ muwun na̱ nreɓu a canaa wu ishipa yi ica.’ ” \x ◊ \xo 21:16 \xt Ica 8:2.\x*
\p 
\v 17 Reve Yesu lyawa le, a̱vu u ka̱ra̱ o uta̱ a̱tsuma̱ a̱ lyuciꞌi a̱ tyo Batanya, ɗe ɗa wa asai.
\s1 Yesu yuwayin uɗanga wu ubiri una̱
\r (Mak. 11:12-14, 20-24)
\p 
\v 18 Na̱ wasasa, Yesu a̱ ma̱ka̱mba̱a̱ a̱tsuma̱ a̱ lyuciꞌi, reve ambulu a̱ guza̱ yi.
\v 19 A̱vu we ene ubiri a̱ ngeꞌen mu ure, reve u ka̱ra̱ a̱ ꞌya̱wa̱ e ikyun ya̱ yi, agba u tsura̱ ɗe umatsun wa̱ yi shi, she a̱vuꞌun. Adama o ndolo reve u damma uɗangaꞌa, “Va̱a̱ da̱shi matsan shi!” Babu usa̱n reve uɗangaꞌa u ꞌyewushi.
\p 
\v 20 Ana ojoro a̱ yi e enei ili i na i farai, a yuwan ta̱ asalama lon. Reve e ece, “Cine ubiri u nda u ꞌyewushi gogogo?”
\p 
\v 21 A̱vu u usu le, “Amayun a ɗa maa dansaa ɗu, nni i ri nu ucawu wo okolo agba okolo a̱ ɗu a kuɗa shi, i ta gura yuwan ili i na n yuwain nu uɗanga u nda, hali u laꞌa. I ta gura damma masasan ma nda, ‘Ka̱ra̱, vu riya̱ a mala!’ Nni i ri nu ucawu wo okolo, ili i ndolo i ta fara.
\v 22 Ili i na i patiyi suru a̱tsuma̱ a avasa, nni i ri nu ucawu wo okolo, i ta̱ tsura̱.”
\s1 Azagbain a wasain ucira wa̱ Yesu
\r (Mak. 11:27-33; Luk. 20:1-8)
\p 
\v 23 Ana Yesu ka̱mba̱i a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗaꞌa, reve u reme uritosu. A̱vu nan ganu a gbagbain na azagbain a̱ ta̱wa̱ uba̱ta̱ wa̱ yi, reve e ece yi, “Nu ucira u ne vaa yuwusan cuꞌun vu ulinga u nda? Zane ɗa ca nuwu cuꞌun vu ucira u nda?”
\p 
\v 24 Reve u usu le, “A̱mu fo n ta̱ na̱ yeci i ta̱ i na maa yuwan ɗu. Nni i usu mu, a̱mu waru n ta damma ɗu uba̱ta̱ u na n tsura̱i ucira u na maa yuwusan linga nda.
\v 25 Zane cayi Yahaya ucira u yuwan urumbusu? A̱sula̱ a na a̱ ri zuva ɗa, ko vaɗilima̱?”
\p Reve a̱ ka̱ra̱ a ndammulai va̱ni le. “Nna̱ tsu damma, ‘Diga zuva ɗa,’ u te ece tsu, nye i zuwai tsu ushi niyi shi.
\v 26 Agba waru n tsu damma, ‘Diga uba̱ta̱ u vuma u ɗa,’ tsu ta uwwusa wovon wi ili i na ama aa yuwan na̱ a̱tsu, adama a na ama suru a̱ usu ta̱ a na Yahaya vumava̱sula̱ ɗa.”
\p 
\v 27 Adama o ndolo reve a̱ usu yi, “Tsu reve shi.”
\p Reve u usu le, “Maa damma ɗu fo za na ca numu ucira u na maa yuwan ili i na maa yuwusan shi.”
\s1 Iroci i muwun n re
\p 
\v 28 Reve Yesu damma waru nan ganu a gbagbain na azagbain, “N ta damma ɗu iroci i vuma ro na da̱na̱i na̱ muwun n re. A̱vu i damma mu ili i na i jiyain. Urana u ro, reve dadaꞌa u ꞌya̱wa̱ uba̱ta̱ a zakpara a̱vu u damma, ‘ꞌYa̱wa̱ vu yuwan ulinga o uɗuma̱ wa inabi anaꞌan!’
\p 
\v 29 “A̱vu mawuꞌun u usu, ‘Ma̱a̱ ꞌya̱wa̱ shi!’ Amma a̱ tyo ɗe, reve u vadala majiyan ma̱ yi, reve u ꞌya̱wa̱.
\p 
\v 30 “Reve waru dadaꞌa u ꞌya̱wa̱ uba̱ta̱ wu zawaꞌa a̱vu u damma, ‘ꞌYa̱wa̱ vu yuwan ulinga o uɗuma̱ u va̱ anaꞌan!’ Reve zawaꞌaꞌa u usu, ‘Ee, dada, n ta̱ ꞌya̱wa̱ n yuwan ulingaꞌa!’ Agba u ꞌya̱wa̱ shi.
\p 
\v 31 “Zane ɗa a̱tsuma̱ a̱ muwun n nda u yuwayin dadaꞌa tsutoni?”
\p Reve a̱ usu, “Mawun mo ufaru.”
\p A̱vu u damma le, “N ta dansaa ɗu amayun, a̱za̱ o uꞌushishi wu utafa na ashakala a ta uwa o tsugono tsa̱ A̱sula̱ kafu a̱ɗu.
\v 32 Yahaya za vu Urumbusu ta̱wa̱ ta̱ u roco ɗu ure u mejege u na ya̱a̱ da̱nu. Agba i usu yi shi, reve gba a̱za̱ o uꞌushishi wu utafa na ashakala a̱ usu yi. Ko na ye enei ili i nda, i ꞌyuwan ta̱ a vadala i lyawa akuci e re ɗu, reve i ꞌyuwan a̱ usu yi.”
\s1 Iroci ya aza a zamalinga a wuya
\r (Mak. 12:1-12; Luk. 20:9-19)
\p 
\v 33 Reve Yesu damma waru nan ganu a gbagbain na azagbain, “Poloi atsuvu a̱ ɗu yu uwwa iroci i nda: A yuwan ta̱ vuma ro na da̱na̱i nu uɗuma̱ wa inabi. A̱vu u suwa isula a̱ka̱nda̱ruwa̱ yi. Reve u ka̱pa̱ a̱a̱ka̱ri, tsa̱ra̱ u tsura̱ uba̱ta̱ u na wa̱a̱ da̱na̱ o sovuso masayan ma inabi,† a̱vu u suwa atsura adama a za vi ipiri. Reve u ca aza a zamalinga uɗuma̱ꞌa̱ tsa̱ra̱ a linga yi, a̱vu a̱yi u ka̱ra̱ mmalu.
\v 34 Ana mantsa mo utaꞌan wu umatsun wa inabiꞌi ma rawai, a̱vu u lyungu agbashi a̱ yi a̱ ꞌya̱wa̱ a̱ ushi akunda e ili i na o ɓolotoi.
\p 
\v 35 “Amma a̱vu aza a zamalingaꞌa e reme agbashiꞌi. Reve a lalapa za ta̱ le, a̱vu o una za ro, reve a vuvara za va taꞌatsu hali u kuwa̱.
\v 36 A̱vu za vu uɗuma̱ꞌa̱ u lyunguwisa̱ agbashi a̱ a̱bunda̱ a̱ yi a̱ ꞌya̱wa̱ a̱ ta̱wa̱a̱ yi ni inabiꞌi. Reve waru aza a zamalingaꞌa a yuwaan agbashiꞌi cine a yuwain na agbashi a na u fara lyunguyi.
\v 37 A̱ tyo o ukosu, reve za vu uɗuma̱ꞌa̱ u lyungu mawun ma̱ yi a̱ tyo uba̱ta̱ wa aza a zamalingaꞌa, a majiyan ma̱ yi a ta yuwan tsutoni na̱ a̱yi.
\p 
\v 38 “Amma ana aza a zamalingaꞌa e enei mawuꞌun a̱ ta̱wa̱, a̱vu a dammulai va̱ni le, ‘Mawun ma nda a̱yi ɗa woo oꞌwo na agadu o uɗuma̱ u nda. Nna̱ tsu una yi, tsu to oꞌwo nu uɗuma̱ꞌa̱!’
\v 39 A̱vu e reme yi, reve a tara yi o uta̱a̱ yi a̱tsuma̱ o uɗuma̱ꞌa̱ nu ucira, reve o una yi.” \fig Iroci ya aza a zamalinga|src="Matthew_21_37.tif" size="span" loc="Matthew 21:37" ref="Mat. 21:33-39"\fig*
\p 
\v 40 Reve u yuwan yeci, “Nna̱ za vu uɗuma̱ꞌa̱ u ta̱wa̱, nye i zuwai waa yuwan na aza a zamalingaꞌa?”
\p 
\v 41 A̱vu a̱ usu, “Babu ili i ro, u to una ama e iwuya o ndolo, reve u ca aza a zamalinga o ro uɗuma̱ꞌa̱, aza a na aa ca yi akunda e ili i na o ɓolotoi a mantsa ma saꞌani.”
\p 
\v 42 A̱vu u damma le, “Koto i ɗenuna̱ a̱tsuma̱ a Adanshi a̱ A̱sula̱ shi?
\q1 ‘Aatali a na asuwi a ꞌyuwain,
\q1 a̱yi ɗa wo oꞌwoi ikyun yu ucira a̱tsuma̱ o usaa.
\q1 Zagbain ɗa yuwain ili i nda,
\q1 Waru u lobono ta̱ e esu a̱ tsu!’ \x ◊ \xo 21:42 \xt Ica 118:22-23.\x*
\p 
\v 43 “Adama o ndolo n ta dansaa ɗu, a ta usa tsugono tsa̱ A̱sula̱ e ekere a̱ ɗu, reve a ca ama a na aa yuwusan ili i na A̱sula̱ a cigai o tsugono tsa̱ yi.
\v 44 Vuma na riya̱i zuva va aatali o ndolo suru u ta kukuɗa, waru za na aatali o ndolo a̱ riya̱yi, u ta̱ yukuma̱ yi.”\f + \fr 21:44 \ft Akuci a atagada va aatagada a nda a̱ ri nu uguzu wa 44 shi.\f*
\p 
\v 45 Ana nan ganu a gbagbain na Afarishi a uwwai iroci i nda, a gura ta̱ reve a na a aci e le a ɗa Yesu aa yuwusan adanshi.
\v 46 A̱vu a̱ shi a ciga e reme yi, amma reve a̱ ka̱ra̱ a uwwusa wovon wa ama, adama a na ama a ca ta̱ okolo a na Yesu vumava̱sula̱ ɗa.
\c 22
\s1 Iroci ya̱ a̱buki a gbain o lolo
\r (Luk. 14:15-24)
\p 
\v 1 Yesu yuwisan ta̱ iroci tsa̱ra̱ u rito ama. Ɗaɗa u dammai,
\v 2 “Apa cine tsugono tsa zuva tsa̱ ri: A yuwan ta̱ mogono mo ro za na foɓoi a̱ba̱jini a̱ a̱buki o lolo adama a mawun ma̱ yi.
\v 3 Mogonoꞌo u banu ta̱ ama o ro a̱ ta̱wa̱ a̱bukiꞌi. Ana urana wa̱ a̱bukiꞌi u rawai, a̱vu u lyungu agbashi a̱ yi tsa̱ra̱ e ɗe amaꞌa, reve a ꞌyuwan a̱ ta̱wa̱.
\p 
\v 4 “Reve u lyunguwisa̱ agbashi o ro, adansa, ‘Dammai aza a na m banuyi a na o koto ta̱ ifoɓi ya̱ a̱buki. M paɗa ta̱ inan i va̱ i na i laꞌai ulobonu, a̱vu n foɓo inama. O foɓo ta̱ ɗe ili suru. Ta̱wa̱i uba̱ta̱ wa̱ a̱buki o lolo.’
\p 
\v 5 “Amma aza a na a banuyiꞌi a zuwa atsuvu e le shi. Ozo o ro e le a̱ ka̱ra̱ ta̱ a̱ tyo a̱ a̱ɗuma̱ e le, ozo o ro gba a̱ ꞌya̱wa̱ ta̱ alya e eden.
\v 6 Ozo o ro gba shi e reme ta̱ agbashiꞌi, a̱vu a̱ ga̱ga̱la̱ le, hali o una le.
\v 7 Ana mogonoꞌo wu uwwai ne, u yuwan ta̱ upan lon. Ɗaɗa u lyunguyi a̱soja a̱ yi o una aza a na o unai agbashiꞌi, a̱vu a̱ kula̱to lyuci gbain le.
\p 
\v 8 “Ɗaɗa u dammai agbashi a̱ yi, ‘O koto ta̱ ifoɓi ya̱ a̱buki o lolo. M banu ta̱ ama a nda, agba a ntsaa a̱ ta̱wa̱ shi.
\v 9 Adama o ndolo, ꞌya̱wa̱i e re lyuci gbaiꞌin tsa̱ra̱ i banu vuma na i tsura̱i biti u ta̱wa̱ uba̱ta̱ wa̱ a̱buki a̱ va̱.’
\v 10 A̱vu a̱ ꞌya̱wa̱ e re, a̱vu o ɓoloto ama a na a gura tsura̱i suru, ama a̱ a̱ɓula̱ na ama o ulambu wa̱ a̱ɓula̱ suru. Ne ɗa uba̱ta̱ wa̱ a̱bukiꞌi u shiwain na ama.
\p 
\v 11 “Ana mogonoꞌo u uwai we ene omociꞌin, reve we ene pe vuma ni itana i na wu ntsayi u ta̱wa̱a̱ uba̱ta̱ u lolo shi.
\v 12 Ɗaɗa we ece niyi, ‘A̱vu, nye i zuwai vo otoi itana i na i ri ulobonu shi, reve vu ta̱wa̱ uba̱ta̱ wa̱ a̱buki?’ A̱yi gba mociꞌin u tsura̱ ili i na waa damma shi.
\p 
\v 13 “A̱vu mogonoꞌo u damma agbashi o ro, ‘Nla̱i ana ne ekere a vumaꞌa. Reve i vari yi a̱tsuma̱ e irumbu, uba̱ta̱ u na ama a̱a̱ shon na a lumi anga adama a̱ a̱tsuma̱lima̱.’
\p 
\v 14 “Amayun, a banu ta̱ ama na̱ a̱bunda̱, agba ama keꞌen ɗa a ɗangwai.”
\s1 Yeci adama a atsupu o utafa
\r (Mak. 12:13-17; Luk. 20:20-26)
\p 
\v 15 Reve Afarishi† o foɓo cine aa yuwan e reme Yesu nu unusu a̱tsuma̱ a adanshi.
\v 16 A̱vu a̱ lyunguwa̱ yi ama o ro a̱tsuma̱ o ojoro e le oɓolo no ozo o ro a na oo tono Hiridu. Reve a damma, “Manlu tsu reve ta̱ vu ta dansa amayun kuci, waru vu to rocosu ama ure wa̱ A̱sula̱ mejege. Vu tara ta̱ ama suru una̱ta̱, ko cine tsa ɗa a̱ ri.
\v 17 Damma tsu majiyan ma̱ wu, u lobono ta̱ tsu tsupa utafa a̱ tyo ya Kaisa† mogono, ko she tsu tsupa wan?”
\p 
\v 18 Yesu gba u reve ta̱ majiyan me iwuya me le, ɗaɗa u dammai, “A̱ɗu a̱za̱ e ikpaꞌa! Nye i zuwai ya̱a̱ lyungusa̱ mu?
\v 19 Roco numu ikebe\f + \fr 22:19 \ft Danshi na a yuwayin ulinga pa nda na̱ Tsuheleni a̱yi ɗa “dinari.” Ka̱lyuwa̱ Ucuɗuwu wi “Ikebe.”\f* yi rumu i na yaa tsupusaa utafaꞌa.” A̱vu amaꞌa o roco yi ikebeꞌe.
\v 20 Reve we ece le, “Ululu na aala a zane a ɗa a̱ ri ɗe uɗanu?”
\p 
\v 21 A̱vu a̱ usu, “Mogono ma gbain Kaisa.”
\p Reve u damma le, “Cayi Kaisa ili i na i ri za va̱ yi, A̱sula̱ waru i ca yi ili i na i ri za va̱ yi.”
\p 
\v 22 Ana a uwwai ne, a yuwan ta̱ asalama, ɗaɗa a lyawa niyi a̱vu a̱ ka̱ra̱.
\s1 Yeci adama o uꞌyosun wa̱ a̱kwa̱kwa̱
\r (Mak. 12:18-27; Luk. 20:27-40)
\p 
\v 23 Aza a Sadukiya† a̱ usu a na ama a̱a̱ ꞌyon a̱tsuma̱ a̱ a̱kwa̱kwa̱ shi. O urana u ndolo gan, a̱vu a̱ ta̱wa̱ uba̱ta̱ wa̱ Yesu. Reve a damma,
\v 24 “Manlu, Musa damma ta̱, ‘Na̱ vuma kuwa̱ babu mawun, a̱vu za va̱ yi sotso ma̱runa̱ꞌa̱ tsa̱ra̱ u tsura̱a̱ yi mawun.’ \x ◊ \xo 22:24 \xt U.Wl. 25:5-6.\x*
\v 25 Ɗe nu ufaru, a yuwan ta̱ ama e cindere muwun ma̱ a̱na̱wu n na n da̱na̱i pa. Za vu ufaru zuwa ta̱ ka, a̱vu u kuwa̱ babu mawun. Reve za ve ire sotso yi.
\v 26 A̱vu a̱yi fo u kuwa̱ babu mawun, reve za ro sotso yi waru, ne ɗa a yuwain hali wo olo le suru.
\v 27 A̱ tyo o ukosu, a̱vu kaꞌa fo u kuwa̱.
\v 28 Na̱ A̱sula̱ a̱ ta̱wa̱ a̱ ꞌya̱sa̱n ama o ukwisa̱, ka va zane ɗa woo oꞌwo? Adama a na wo olo ta̱ ali e cindereꞌe suru.”
\p 
\v 29 Ɗaɗa u usu nle, “I ri nu urevu shi, adama a na i reve ili i na Adanshi a̱ A̱sula̱ a dammai shi, waru i reve adama o ucira wa̱ A̱sula̱ shi.
\v 30 Na̱ a̱ ꞌya̱sa̱n ama a̱tsuma̱ a̱ a̱kwa̱kwa̱, aa yuwan lolo shi, waru aa ca lolo shi. O to oꞌwo gashi nlingata ma̱ A̱sula̱ ɗe zuva.
\v 31 Koto i ɗenuna̱ ili i na A̱sula̱ a dammai adama o uꞌyosun a̱tsuma̱ a̱ a̱kwa̱kwa̱ shi?
\v 32 A̱sula̱ a damma, ‘A̱mu ɗa A̱sula̱ a Ibrahim, na̱ A̱sula̱ a Ishiyaku, oɓolo na̱ A̱sula̱ a Yakubu.’ \x ◊ \xo 22:32 \xt Mta̱. 3:6.\x* A̱sula̱ waru A̱sula̱ a aza a wuma a ɗa, agba A̱sula̱ a̱ a̱kwa̱kwa̱ a ɗa shi.”
\v 33 Ana oɓolo a amaꞌa a uwwai tsundolo, a yuwan ta̱ asalama nu uritosu wa̱ yi.
\s1 Wila̱ u na u laꞌai mgbain
\r (Mak. 12:28-34; Luk. 10:25-28)
\p 
\v 34 Ana Afarishi a uwwai a na aza a Sadukiya a gura usu ili shi, ɗaɗa o ɓolotoi uba̱ta̱ u ta̱.
\v 35 A̱tsuma̱ e le, manlu ma̱ Wila̱ mo ro mo foɓo ta̱ cine wee reme Yesu ɗaɗa u yuwan niyi yeci:
\v 36 “Manlu, a̱tsuma̱ a̱ Wila̱ wa Musa, zane ɗa laꞌai mgbain?”
\p 
\v 37 Reve Yesu usu yi, “ ‘Vu ciga Zagbain A̱sula̱ a̱ wu no okolo a̱ wu suru, na asuvu a̱ wu suru, waru na̱ majiyan ma̱ wu suru.’ \x ◊ \xo 22:37 \xt U.Wl. 6:5.\x*
\v 38 A̱yi nda a̱yi ɗa Wila̱ u gbain wu ufaru za na laꞌai ulobonu.
\v 39 Wila̱ we ire fo u tu ulobonu, ‘Vu ciga moron ma̱ nden ma̱ wu cine vu cigai aciya̱wu.’ \x ◊ \xo 22:39 \xt N.Gn. 19:18.\x*
\v 40 Wila̱ wa Musa oɓolo na Atagada a Ama̱sula̱ suru za̱la̱ wila̱ re nda ɗa a̱ ri.”
\s1 Yeci adama a Zamawawa
\r (Mak. 12:35-37; Luk. 20:41-44)
\p 
\v 41 Afarishiꞌi lo ubuwu uɓolotowu, ɗaɗa Yesu yuwan nle yeci,
\v 42 “Nye yaa yuwusan majiyan adama a̱ Kristi Zamawawa? O ugundo wa̱ zane ɗa wu uta̱i?”
\p Reve a̱ usu, “Kristi Zamawawa Mawun ma̱ Da̱wuda ma ɗa.”
\p 
\v 43 Ɗaɗa u damma nle, “To, adama a̱ nye Da̱wuda ɗe niyi ‘Zagbain?’ Ruhu va Akiza ɗa zuwai Da̱wuda dammai,
\q1 
\v 44 ‘A̱sulazuva a damma ta̱ Zagbain va̱.
\q1 Da̱nu o ukere usaꞌani u va̱,
\q1 she na̱ n zuwa nꞌyuwatan ma̱ wu a apata a ana a̱ wu.’ \x ◊ \xo 22:44 \xt Ica 110:1.\x*
\p 
\v 45 “Ana Da̱wuda ɗe niyi Zagbain, cine woo oꞌwiso mawun ma̱ yi a mantsa ma̱ ta̱?”
\v 46 Ko za gura usu yi shi. Diga lo ko za kawan da̱shi yuwan yi yeci waru shi.
\c 23
\s1 Yesu ɓarai azagbain
\r (Mak. 12:38-39; Luk. 11:43, 46; Luk. 20:45-46)
\p 
\v 1 Reve Yesu yuwaan oɓoloꞌo no ojoro a̱ yi adanshi,
\v 2 “Munlu n Wila̱† na Afarishi a̱ ta̱ nu ucira a damma ɗu ili i na Wila̱ wa Musa waa dansa.
\v 3 I yuwan tsutoni ni ili i na o rito nɗu suru, amma she i yuwan ununa aa yuwusan wan. Adama a na a tsu damma ta̱ ili i ro, reve a yuwan ili i ro koꞌo.
\v 4 A̱ tsu nla̱a̱ ta̱ ama itana yu ume i na aa gura tanu shi, agba ele a ciga a zuwa ukere a kamba tanu le shi.
\p 
\v 5 “A ta yuwusan ili i saꞌani tsa̱ra̱ ama e ene le, za suru ta̱ nla̱sa̱ ilawo ya Adanshi a̱ A̱sula̱, amma ilawo ya Afarishi i laꞌa ta̱ mgbain. Waru alagba e elentsu a̱ a̱tugu e le a̱ ta̱ mgbain.
\v 6 A laꞌa ta ciga nda̱na̱ta̱ n saꞌani uba̱ta̱ a̱ a̱buki, waru na̱ nda̱na̱ta̱ me elime uba̱ta̱ e iɓolo.
\v 7 Na̱ a̱ ri a̱tsuma̱ e eden, a tsu laꞌa ta̱ ciga ama a̱ ca̱sa̱ le na aala a tsugbain, ‘Manlu.’
\p 
\v 8 “She i lyawa vuma ro ɗe ɗu ‘Manlu’ wan, adama a na Manlu ma̱ ta̱ ma ɗa i ri na̱ a̱yi goon, suru nɗu waru muwun ma̱ a̱na̱wu n ɗa i ri.
\v 9 A̱tsuma̱ o uvaɗi she i ɗe vuma na aala a tsugbain ‘Dada’ wan, adama a na i ta̱ na̱ Dada ta̱ goon, za na ri zuva.
\v 10 Waru she i lyawa vuma ro ɗe ɗu ‘Zagbain’ wan, adama a na Zagbain ta̱ ɗa i ri na̱ a̱yi goon, a̱yi ɗa Zamawawa.
\v 11 Za na laꞌai mgbain, wo oꞌwo aagbashi a̱ ɗu suru.
\v 12 Za na ka̱mba̱toi aciya̱yi zagbain a̱ ta̱ ka̱ɗa̱to yi, za na gba ka̱ɗa̱toi aciya̱yi a̱ ta̱ ꞌya̱sa̱n yi.
\p 
\v 13 “Woo yoꞌono ɗu shi, a̱ɗu munlu n Wila̱ na Afarishi. A̱ɗu a̱za̱ e ikpaꞌa! I ta̱ kpa̱tosu una̱ntsu u tsugono tsa zuva, agba a̱ɗu na aciya̱ɗu yaa uwa pe shi. Waru i ta putsusaa aza a na a cigai a uwa. [
\v 14 Woo yoꞌono ɗu shi a̱ɗu munlu n Wila̱ na Afarishi. A̱ɗu a̱za̱ e ikpaꞌa! I ta paalasa nruna̱ a ususa ꞌwa le, waru i ta yuwusan avasa o ugaꞌan tsa̱ra̱ ama e ene ɗu. I ta laꞌa sowo a̱tsuma̱lima̱ lon.]\f + \fr 23:14 \ft Akuci a atagada va aatagada a nda a̱ ri nu uguzu u 14 shi.\f*
\p 
\v 15 “Woo yoꞌono ɗu shi, a̱ɗu munlu n Wila̱ na Afarishi. A̱ɗu a̱za̱ e ikpaꞌa! I tsu pasa ta̱ mala, hali i tyo e iɗa ya alanga, tsa̱ra̱ i tsura̱ za vi itoni ta̱. Ni i yuwan ne, a̱vu i zuwa yi u laꞌa ɗu ntsaa na waa uwa a̱tsuma̱ a akina.
\p 
\v 16 “Woo yoꞌono ɗu shi, a̱ɗu azagbain a na ri nrumba̱! I tsu damma ta̱, ‘Na̱ vuma kucina na̱ A̱a̱ꞌisamapaɗa a mantsa ma na waa yuwusan nzuwulai, a̱yi ndolo wo oꞌwo ili shi. Agba nu u kucina na̱ zinariya na ri pe a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗaꞌa, u ciga u ꞌyuwan u shiton nzuwulai ndolo.’
\v 17 A̱ɗu olo a̱ nrumba̱! Zane ɗa laꞌai: zinariya ko A̱a̱ꞌisamapaɗa a na o oꞌwotoi zinariyaꞌa na akiza?
\v 18 A̱vu waru i damma, ‘Na̱ vuma kucina na̱ masaꞌa† a mantsa ma na waa yuwusan nzuwulai, wo oꞌwo ili i ro shi. Amma nu u kucina nu uneꞌe u na u ri a masaꞌa, u ciga u ꞌyuwan u shiton nzuwulaiꞌi.’
\v 19 A̱ɗu nrumba̱ ma ama! Zane ɗa laꞌai: a̱yi uneꞌe ko a̱yi masaꞌa ma na ma zuwai uneꞌe wo oꞌwoi na akiza?
\v 20 Na̱ ne ɗa, na̱ vuma kucina na̱ masaꞌa, u ta kucinasa na̱ a̱yi ni ili i na i ri zuva va̱ yi suru.
\v 21 Waru nu u kucina na̱ A̱a̱ꞌisamapaɗa, u ta kucinasa na̱ a̱yi oɓolo na̱ A̱sula̱, za na ri pe nden.
\v 22 Waru na̱ vuma kucina na̱ zuva, u ta kucinasa no ootogu o tsugono tsa̱ A̱sula̱ na̱ a̱yi za na ri ɗe nden.
\p 
\v 23 “Woo yoꞌono ɗu shi, a̱ɗu munlu n Wila̱ na Afarishi. A̱ɗu a̱za̱ e ikpaꞌa! I tsu ca ta̱ A̱sula̱ maɓaci ma̱ ta̱ a̱tsuma̱ a kupa e ili i na i ri ne ele suru, hali na̱ a̱vuꞌun e isuꞌwan e kekeꞌen ni icuꞌun i kekeꞌen suru. Agba i tsu yuwan tsutoni tsa̱ a̱ɓula̱ nu uritosu u Wila̱ shi, za na ele ɗa o roco ozo o ro isaꞌani na amayun na̱ a̱ɓula̱. Ele ɗa wu ntsayi i yuwan suru, agba she i vari ko ili i keꞌen i ta̱ a̱tsuma̱ e ili i na yaa yuwusan wan.
\v 24 A̱ɗu nrumba̱ n na moo ronuso ama! I ta̱ gashi vuma na tsu shere mofiyon a̱tsuma̱ a̱ mini mo oso, a̱vu u soɗu aarakumi!\f + \fr 23:24 \ft Yesu ta dansa, “I dama ta̱ adama a̱ nusu wawaꞌa amma i ta yuwusan a̱ba̱jini a̱ nusu.”\f*
\p 
\v 25 “Woo yoꞌono ɗu shi, a̱ɗu munlu n Wila̱ na Afarishi. A̱ɗu a̱za̱ e ikpaꞌa! I tsu za̱za̱ꞌwa̱ ta̱ alanga a munda na̱ ntaɗa, agba a̱tsuma̱ e le a̱ ta̱ tapu ni ili i na i usai nu ucira e ekere a ama, tsa̱ra̱ yu uwwaa aciya̱ɗu uyoꞌo.
\v 26 Afarishi, a̱ɗu nrumba̱ n ɗa! I fara ka̱mba̱to a̱tsuma̱ a munda cece, reve ucina̱ꞌa̱ fo wo oꞌwo cece!
\p 
\v 27 “Woo yoꞌono ɗu shi, a̱ɗu munlu n Wila̱ na Afarishi. A̱ɗu a̱za̱ e ikpaꞌa! I rotso ta̱ ason a na a putalai mini ma̱ uꞌuri. Alanga a ason o ndolo a̱ ta̱ gashi ulobonu, agba a̱tsuma̱, a̱ ta̱ tapu ne etele a̱ a̱kwa̱kwa̱ ni ili yi idaba icuꞌun icuꞌun.
\v 28 Ne ɗa waru, a alanga i rotso ta̱ gashi ama a̱ a̱ɓula̱ a ɗa i ri e ekere a ama, agba a̱tsuma̱ a̱ ɗu a̱ ta̱ tapu ni ikpaꞌa na̱ nusu.
\p 
\v 29 “Woo yoꞌono ɗu shi, a̱ɗu munlu n Wila̱ na Afarishi. A̱ɗu a̱za̱ e ikpaꞌa! I tsu foɓo ta̱ uba̱ta̱ wa̱ a̱ciɗa̱ ulobonu adama a ama̱sula̱, a̱vu waru i kakala ason a aza a na a yuwain wuma u saꞌani.
\v 30 A̱vu i damma, ‘Na̱ tsu shi tsu yuwan wuma u tsu a mantsa ma nkaya n tsu, tsu shi a kamba le mona ma ama̱sula̱ shi.’
\v 31 Ne ɗa i poloi aciya̱ɗu a na i paluꞌwai aciya̱ɗu adansa a̱ɗu muwun n tsukaya ma aza a na o unai ama̱sula̱ a ɗa!
\v 32 Lyuwai elime tsa̱ra̱ i koso ili i na nkaya n ɗu n farai!
\p 
\v 33 “A̱ɗu apili na̱ muwun ma apili! Cine i jiyain i laꞌa a na ee geꞌeto ɗu a̱tsuma̱ a akina a na a̱ ri n kima̱ shi?
\v 34 Adama o ndolo n ta̱ lyunguwa̱ ɗu na ama̱sula̱ na̱ a̱za̱ o urevu na̱ munlu. Ozo o ro e le i to una le, ozo o ro gba shi i ta vara le a akpata. Ozo o ro waru gba i ta ruruꞌwa̱ le a̱tsuma̱ a̱ a̱ꞌisa̱ a̱ ɗu, reve i lo le diga a̱ lyuci a̱ tyo a̱ lyuci.
\v 35 Adama o ndolo, A̱sula̱ e te ece ɗu adama a aza a na o unai babu unusu, aza a na a yuwain ɗe wuma. O ufaru a̱ɗu aza a Yahuda, yu una ta̱ Habila† vuma va̱ a̱ɓula̱, ne ɗa i lyuwai elime na̱ mona hali a̱ tyo ya Zakariya mawun ma Berekiya. A̱yi ɗa yu unai e memere mo Upasu wa Akiza na̱ masaꞌa mo ukula̱tosu a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗa.
\v 36 N ta dansaa ɗu amayun, ili i nda suru i ta cina ɗu, a̱ɗu na i ri wuma gogo.”
\s1 Yesu ciga ta̱ Urishelima
\r (Luk. 13:34-35)
\p 
\v 37 Ɗaɗa Yesu lyuwai elime na adanshi, “A̱ɗu ama a̱ Urishelima! Ama a̱ ɗu o una ta̱ ama̱sula̱ waru a vuvara ta̱ nlingata n na a̱ lyunguyi a̱ tyo ya̱ꞌa̱ ɗu. N tsu ciga ta̱ m ɓoloto ɗu uba̱ta̱ u ta̱, cine moton mo tsu va̱pa̱ muwun ma̱ yi ne evelu. Agba i lyawa mu n yuwan ne shi.
\v 38 Adama o ndolo A̱sula̱ a ta lyawa A̱a̱ꞌisamapaɗa a̱ ɗu, reve wo oꞌwo lya̱nga̱.
\v 39 N damma ɗu, ya̱a̱ da̱shi ene mu waru shi, she mantsa ma na yaa damma, ‘A̱sula̱ a zuwaa za na a̱a̱ ta̱wa̱ a̱tsuma̱ a ala a̱ A̱sulazuva abaꞌun.’ ”
\c 24
\s1 O to ɓoso A̱a̱ꞌisamapaɗa
\r (Mak. 13:1-2; Luk. 21:5-6)
\p 
\v 1 Ana Yesu uta̱i a̱ A̱a̱ꞌisamapaɗa, a̱yi a̱ ma̱ka̱ra̱a̱, a̱vu ojoro a̱ yi a̱ ta̱wa̱ uba̱ta̱ wa̱ yi, tsa̱ra̱ o roco yi saa va̱ A̱a̱ꞌisamapaɗaꞌa.
\v 2 Ɗaɗa gba u damma nle, “Ye ene ta̱ saa nda suru? Amayun a ɗa maa dansaa ɗu, ko aatali a̱ ta̱ aa lyawa zuva vu za va̱ yi shi. Suru nle o to oco le e iɗa.”
\s1 Morono ma atsuvu adama a addama
\r (Mak. 13:3-13; Luk. 21:7-19)
\p 
\v 3 Yesu ɗe nden a Masasan ma̱ Zetun, reve ojoro a̱ yi a̱ ta̱wa̱ uba̱ta̱ wa̱ yi a̱ da̱na̱ oɓolo na̱ a̱yi goon. A̱vu a damma, “Damma tsu mantsa ma na ili i ndolo yaa fara? Waru nye ya̱a̱ da̱na̱ iroci i na yoo roco tsu mantsa ma na va̱a̱ ta̱wa̱ ma rawa ta̱, waru mantsa ma na uvaɗi u nda woo koto?”
\p 
\v 4 Ɗaɗa Yesu tsu usu le, “I lyawa nanza pusa̱n ɗu ugbozu wan.
\v 5 Ama na̱ a̱bunda̱ a̱ ta̱ ta̱wa̱ na aala a̱ va̱, a ta damma, ‘A̱mu ɗa Zamawawaꞌa.’ Waru a̱ ta̱ pusa̱n ugbozu wa ama na̱ a̱bunda̱.
\v 6 I ta uwwa adama o uvon na alabari o uvon a na a̱ ri lo a̱ ta̱wa̱, amma she yu uwwa wovon wan. Ili i nda suru a ciga a ꞌyuwan a fara, kafu ukosu u ta̱wa̱.
\v 7 Iɗa i ta yuwan nla̱ngi ni iɗa, tsugono waru tsu yuwan nla̱ngi na̱ tsugono. A ta yuwan mantsa ma ambulu na̱ a̱bunda̱. A ta yuwan ura̱mosu wi iɗa ba̱ta̱ ba̱ta̱.
\v 8 Ili nda suru a̱ ta̱ gashi ufaru wu mɓa̱la̱ n limatan.
\p 
\v 9 “Ama e te reme ɗu, a zuwa ɗu a̱tsuma̱lima̱, a̱vu o una ɗu. Ama suru a ta ꞌyuwan ɗu adama a na i usu numu.
\v 10 Adama o ndolo ama na̱ a̱bunda̱ a ta lyawa itoni i va̱. A ta yuwan nla̱ngi va̱ni le, reve a ꞌyuwunlai.
\v 11 Ama̱sula̱ e epen a̱ ta̱ ta̱wa̱, reve a zuwa ama na̱ a̱bunda̱ a̱ usu epen.
\v 12 Adama o ndolo, iwuya i ta baza ba̱ta̱ suru, a̱vu icigi ya ama na̱ a̱bunda̱ i ta̱na̱ lon.
\v 13 Amma aza a na a kaɓai asuvu hali a̱ tyo o ukosu, A̱sula̱ a ta wawa le.
\v 14 She na a yuwan alajiya a Alabari a Saꞌani† adama o tsugono tsa̱ A̱sula̱ uba̱ta̱ suru a̱tsuma̱ o uvaɗi, ɗaɗa ukosu wa̱a̱ ta̱wa̱.
\s1 Ili yi idaba i na i tsu ta̱wa̱a̱ nu ulungusu
\r (Mak. 13:14-23; Luk. 21:20-24)
\p 
\v 15 “Mantsa ma̱ ta̱ ta̱wa̱ a na ye ene ili i na Daniya vumava̱sula̱ yuwain adanshi adama a̱ yi ‘Ili yi idaba i na i tsu lungusa̱ A̱a̱ꞌisamapaɗa,’ \x ◊ \xo 24:15 \xt Dan. 9:27; Dan. 11:31; Dan. 12:11.\x* mishin Upasu wa Akiza. (A̱ɗu na yee ɗesununa̱ ili i nda, i reve ili i na waa dansa.)
\v 16 A mantsa mo ndolo, ama a Yahuda a ꞌyuwan a ciga a suma a̱ tyo a nsasan tsa̱ra̱ a laꞌa.
\v 17 Za na ri a alanga, she u ka̱mbisa̱ o uꞌwa adama u tara ili i ro wan.
\v 18 Za na ri ɗe o uɗuma̱, u ka̱mba̱ o uꞌwa tsa̱ra̱ u tara aapalutsu wan.
\v 19 A mantsa mo ndolo, u ta suɗuwa a̱ma̱ci a na a̱ ri na̱ a̱tsuma̱ oɓolo na̱ a̱ma̱ci a na a̱ ri na̱ muwun n na ma apasa maani!
\p 
\v 20 “I yuwan avasa tsa̱ra̱ ilaɗi i ɗu yoo oꞌwo a̱tsuma̱ a̱ lyushi ko urana wa Ashibi wan!
\v 21 A̱yi nda u to oꞌwo a̱tsuma̱lima̱ a na koto a yuwain shi, diga na a yuwain uvaɗi u nda. Waru cuꞌun va̱ a̱tsuma̱lima̱ o ndolo a̱a̱ da̱shi fara shi.
\v 22 Amma A̱sula̱ e jebe ta̱ ɗe rana ndolo, na̱ koto u yuwan ne shi, babu vuma na aa laꞌa. Amma A̱sula̱ e te jebe le adama a aza a na u ɗangwai.
\p 
\v 23 “A mantsa mo ndolo, ozo o ro a ta damma ɗu, ‘Ka̱lyuwa̱i, ndeɗe Zamawawaꞌa!’ Ko za ro damma, ‘Apa yi’, agba she i usu wan.
\v 24 Azamawawa e epen na ama̱sula̱ e epen a̱ ta̱ ta̱wa̱ a yuwan ili ya asalama ya̱ a̱bunda̱. A ta yuwan a̱tyo a na aa yuwan tsa̱ra̱ ama o toni le, hali na ama a na A̱sula̱ a ɗangwai, na aa gura.
\v 25 Gogo n to ronuso ɗu atsuvu adama a nda, kafu ili i nda i fara.
\p 
\v 26 “Adama o ndolo, na̱ za ro damma ɗu, ‘Ka̱lyuwa̱i, Zamawawa ta̱ ɗe o ogozo,’ she i ꞌya̱wa̱ i ka̱lyuwa̱ wan. Ko a damma ɗu, ‘Apa uba̱ta̱ u na u ri upaꞌun,’ she i usu wan!
\v 27 Na̱ Mawun ma Vuma ma̱ ta̱wa̱, ama suru e te ene yi, cine i revei imaɗatsu i tsu maɗatsa zuva suru.
\v 28 Uba̱ta̱ u na a̱kwa̱kwa̱ a̱ ri, lo ɗa asala o tsu ɓoloto, adama o ndolo iroci i nda u to rocosu ukosu u rawa ta̱ zuzu.
\s1 Uta̱wu u Mawun ma Vuma
\r (Mak. 13:24-27; Luk. 21:25-28)
\p 
\v 29 “Babu usa̱n na̱ rana va̱ a̱tsuma̱lima̱ ndolo koto,
\q1 ‘Urana u ta̱ rumba̱na̱
\q1 Woto waru wa̱a̱ da̱shi ikana shi.
\q1 Italyoꞌo i ta̱ riya̱,
\q1 Waru A̱sula̱ a̱ ta̱ jinga̱ɗa̱ cira na ri zuva.’ \x ◊ \xo 24:29 \xt Isha. 13:10.\x*
\p 
\v 30 “A mantsa mo ndolo, e te ene iroci i Mawun ma Vuma ɗe zuva.† Ama o uvaɗi suru a̱ ta̱ shon adama o wovon. E te ene Mawun ma Vuma a̱ ta̱wa̱ ɗe zuva nu ucira na̱ tsugbain.
\v 31 Waru u ta̱ lyungu nlingata ma̱ yi na̱ mesun ma aavana a gbain, o to ɓoloto aza a na A̱sula̱ a ɗangwai diga o ufaru wu uvaɗi a̱ tyo o ukosu wu uvaɗi uba̱ta̱ u ta̱.
\s1 Uritosu o uɗanga wu ubiri
\r (Mak. 13:28-31; Luk. 21:29-33)
\p 
\v 32 “Gogo i rito urevu u nda e ekere o uɗanga wu ubiri: Nna̱ ye ene eten na̱ a̱vuꞌun e le a̱ lima̱na̱ da̱a̱n, waru na ayawa no ototopi, i reve mantsa ma̱ lyushi ma rawa ta̱ zuzu.
\v 33 Na̱ ye ene ili i ndolo suru a farasa, i te reve mantsa ma rawa ta̱ zuzu.
\v 34 I cuwan ili i nda suru i ta fara kafu ama a na a̱ ri nda wuma suru a̱ kuwa̱.
\v 35 Zuva ni iɗa a̱ ta̱ ka̱ra̱, agba adanshi a̱ va̱ a̱a̱ ka̱ra̱ shi ko keꞌen.
\s1 Babu za na revei mantsa ma na Yesu a̱a̱ ta̱wisa̱
\r (Mak. 13:32-37; Luk. 17:26-30, 34-36)
\p 
\v 36 “Ko za reve uranaꞌa shi, ko mantsaꞌa, hali na̱ nlingata ma̱ A̱sula̱ n na n ri ɗe zuva hali na̱ Mawun ma Vuma. She Dada ɗa goon revei.
\v 37 Na̱ Mawun ma Vuma ma̱a̱ ta̱wa̱, ili i ta̱ da̱na̱ vadamma a mantsa ma na Nuhu† yuwain wuma.
\v 38 A̱tsuma̱ a rana ndolo kafu u ulungusu u mini, ama a lyuwusa ta̱ no o sowi, na a yuwin lolo cine a tsu yuwusan hali urana u na Nuhu uwai a̱tsuma̱ a wantsun.
\v 39 Agba a gura reve ili i na i ri a mmalu shi, hali mini ma̱ ta̱wa̱ ma lyuwa le suru. Ne ɗa woo oꞌwo na̱ Mawun ma Vuma ma̱ ta̱wa̱.
\v 40 Ali e re a̱ ta̱ da̱na̱ o uɗuma̱. A ta tara vuma ta̱ reve a lyawa vuma ta̱.
\v 41 A̱ma̱ci e re a̱ ta̱ da̱na̱ a yira a aatali a yira. A ta tara ka ta̱ reve a lyawa ka ta̱.
\p 
\v 42 “Adama o ndolo, i da̱na̱ ufoɓu, i reve urana u na Zagbain ɗu ri lo a̱ ta̱wa̱ shi.
\v 43 Na̱ za vu uꞌwa reve yashi i na vivu a̱a̱ ta̱wa̱, i reve waa lantsa shi, waru waa lyawa vivu ndolo uwa o uꞌwa wa̱ yi shi.
\v 44 A̱ɗu i ꞌyuwan i ciga i da̱na̱ ufoɓu a mantsa suru. Adama a na Mawun ma Vuma ma̱ ta̱ ta̱wa̱ a mantsa ma na i zuwai shi.
\s1 Aagbashi a̱ a̱ɓula̱
\r (Luk. 12:41-48)
\p 
\v 45 “Aagbashi a̱ ne a ɗa a̱ ri na̱ a̱ɓula̱ nu ugbozu? A̱yi ɗa za na zavuꞌwa va̱ yi zuwa niyi u ka̱lyuwusa̱ akapi a̱ a̱za̱ a̱ yi a agbashi, nu u casu nle ilyalya a mantsa ma saꞌani.
\v 46 Na̱ zavuꞌwa va̱ yi ka̱mba̱, a̱vu u cina yi u yuwan ulinga u saꞌani, u ta ca yi iliyinkapa.
\v 47 Amayun a ɗa maa dansaa ɗu, zavuꞌwa ndolo ta ɗangwa aagbashi o ndolo wo oꞌwo za na a̱ da̱na̱ a̱ ka̱lyuwusa̱a̱ yi itana ya̱ yi suru.
\v 48 Agba nna aagbashiꞌi u ri na̱ a̱ɓula̱ shi, u ta damma aciya̱yi a na zavuꞌwa va̱ yi a̱a̱ ka̱mba̱ goꞌo shi.
\v 49 Reve u reme malapa ma agbashiꞌi suru. A̱vu u uwa alya nu u sowi hali wo oꞌwo usowu oɓolo na̱ a̱za̱ a̱ yi.
\v 50 Zavuꞌwaꞌa u ta̱ ka̱mba̱ a mantsa ma na u zuwai shi, ko a mantsa ma na u ri ufoɓu shi.
\v 51 Zavuꞌwa u ta ɓuɓatsa yi lipu, a̱vu u ka̱mba̱to yi wo oꞌwo na̱ a̱za̱ e ikpaꞌa, uba̱ta̱ u na ama a̱a̱ shon na lumi anga adama a̱ a̱tsuma̱lima̱.”
\c 25
\s1 Iroci ye esheli kupa
\p 
\v 1 Reve Yesu lyuwa elime na adanshi, “A mantsa mo ndolo, apa cine tsugono tsa zuva tsa̱a̱ da̱na̱: A yuwan ta̱ esheli kupa a na a tarai ifitila i le, a̱vu a̱ ka̱ra̱ a̱ ꞌya̱wa̱ a gaꞌaton vali vu kasaꞌavu.
\v 2 Ama o ton a̱tsuma̱ e le olo a ɗa, akapi a ama o ton gba a̱za̱ o ugbozu a ɗa.
\v 3 Olo o ndolo a na a̱a̱ ka̱ra̱ a tara ta̱ ifitila i le, agba a̱ guza̱ maniꞌin mo ro shi.
\v 4 A̱za̱ o ugbozu gba, a̱vu a̱ ɓa̱na̱ maniꞌin mo ro o mupondo n ro.
\v 5 Ana gba vali vu kasaꞌavu rawai goꞌo shi, a̱vu a fara mgba̱ɗa̱ hali a lantsa.
\p 
\v 6 “Na ayin uta̱nu a̱vu vuma ro saala, ‘Vali vu kasaꞌavu ta̱ lo a̱ ta̱wa̱! Ta̱wa̱i i gaꞌaton yi!’
\p 
\v 7 “A̱vu esheliꞌi suru a̱ ꞌyon a lapula ifitila i le.
\v 8 A̱vu oloꞌo a damma a̱za̱ o ugbozu, ‘Neꞌe ntsu maniꞌin ma̱ ɗu waꞌa, adama a na a̱za̱ a̱ tsu a ciga ta̱ ma̱kima̱a̱.’
\p 
\v 9 “Ɗaɗa ele gba a̱ usu nle, ‘Tsu ri na̱ maniꞌin ma na maa rawa tsu na̱ a̱ɗu shi. ꞌYa̱wa̱i uba̱ta̱ wa aza a na a winisa, tsa̱ra̱ i tsura̱ i tsulaa aciya̱ɗu.’
\p 
\v 10 “Ana olo e esheli o ndolo a̱ ꞌya̱wa̱i atsulu a maniꞌin, ɗaɗa gba vali vu kasaꞌavuꞌu u rawai. Esheli a na gba a̱ ri ufoɓu, reve a uwa o uꞌwa na̱ vali vu kasaꞌavuꞌu uba̱ta̱ wa̱ a̱buki. Ɗaɗa a̱ kpa̱toi una̱ntsu wu uꞌwaꞌa.
\p 
\v 11 “A̱ tyo ɗe, a̱vu esheli a na a buwai a rawa, ɗaɗa a uwai yisaali, ‘Zavuꞌwa! Kpa̱tuꞌwa̱a̱ tsu una̱ntsu.’
\p 
\v 12 “A̱vu gba vali vu kasaꞌavuꞌu u usu, ‘Amayun a ɗa maa dansaa ɗu, n reve ɗu shi.’ ”
\p 
\v 13 Reve Yesu damma, “Adama o ndolo i da̱na̱ ufoɓu kuci, i reve urana ko mantsa ma na ili i nda yaa fara shi.”
\s1 Iroci ya agbashi a taꞌatsu
\r (Luk. 19:11-27)
\p 
\v 14 A̱vu waru Yesu yuwisan adanshi ni iroci i nda, “A mantsa mo ndolo, apa cine tsugono tsa zuva tsa̱a̱ da̱na̱: Vuma ro shi ta̱ ciga u ꞌya̱wa̱ mmalu uba̱ta̱ u ro. Kafu u ka̱ra̱, reve u ɗe agbashi a̱ yi, a̱vu u damma le a̱ ka̱lyuwa̱ itana ya̱ yi ulobonu kafu u ta̱wa̱.
\v 15 Vumaꞌa u reve ta̱ ulinga u na za suru aa yuwan. Reve u ca za vu ufaru ikebe i gbain i azurufa\f + \fr 25:15 \ft Danshi na a yuwayin ulinga pa nda na̱ Tsuheleni a̱yi ɗa “talen.” Ka̱lyuwa̱ Ucuɗuwu wi “Ikebe.”\f* i ton. Waru u ca ta̱ za ve ire ikebe i gbain i azurufa i re. A̱vu u ca za va taꞌatsu ikebe i gbain i azurufa i ta̱. Reve u ka̱ra̱ mmalu ma̱ yi.
\v 16 Ana vumaꞌa u ka̱ra̱i, a̱vu aagbashi a na u cayi ozo o toꞌon u yuwan ulinga ne ele, u zamiyisa ozo o ton waru.
\v 17 Reve waru aagbashi a na a cayi ejere ne ɗa fo u yuwain ulinga ni ikebeꞌe, a̱vu u tsurisa̱ ejere waru.
\v 18 Amma aagbashi a na a cayi za ta̱, a̱vu u ka̱pa̱ a̱a̱ka̱ri reve u soko ikebe yi zagbain va̱ yi e iɗa.
\p 
\v 19 “Ana a jimai, a̱vu zagbaiꞌin ka̱mba̱, ɗaɗa we ecei agbashiꞌi ili i na a yuwain ni ikebeꞌe.
\v 20 A̱vu aagbashi a na a cayi ozo o toꞌon u ta̱wisa̱ yi no ozo o ton a na u tsura̱i a̱tsuma̱ e ikebeꞌe. Reve u damma, ‘Zagbain, vu ca mu ta̱ ikebe i gbain i azurufa i ton, n tsurisa̱ ta̱ ozo o ton.’
\p 
\v 21 “A̱vu u usu, ‘Vu yuwan ta̱ ulinga u saꞌani. Aagbashi a̱ a̱ɓula̱ a ɗa vu ri, waru vu tsu uwwa ta̱ adanshi. Ana vu yuwain a̱ɓula̱ ni ili i keꞌen i nda, n ta zuwa wu vu ka̱lyuwusa̱ ili i na i laꞌai mgbain. Ta̱wa̱ vu uwwa uyoꞌo oɓolo na̱ a̱mu.’
\p 
\v 22 “A̱vu za ve ire, za na a cayi ejere, ta̱wa̱ reve u damma, ‘Zagbain, vu ca mu ta̱ ikebe i gbain i azurufa i re, n tsurisa̱ ta̱ ejere.’
\p 
\v 23 “Reve u usu, ‘Vu yuwan ta̱ ulinga u saꞌani. Aagbashi a̱ a̱ɓula̱ a ɗa vu ri waru vu tsu uwwa ta̱ adanshi. Ana vu yuwain a̱ɓula̱ ni ili i keꞌen i nda, n ta zuwa wu vu ka̱lyuwusa̱ ili i n na i laꞌai mgbain. Ta̱wa̱ vu uwwa uyoꞌo oɓolo na̱ a̱mu.’
\p 
\v 24 “Ɗaɗa aagbashi a na a cayi za ta̱, u ta̱wa̱ u dammai, ‘Zagbain, n reve ta̱ vu tu usa̱n. Vu rotso ta̱ cuꞌun vuma na tsu ciga u gasa uba̱ta̱ u na u cuꞌwa̱in shi, vu ciga ta̱ ili ye pere.
\v 25 Adama o ndolo mu uwwa ta̱ wovon, ɗaɗa gba n ꞌya̱wa̱i n sokoi ikebe ya̱ wu e iɗa. Apa wu ikebe ya̱ wu.’
\p 
\v 26 “Reve u usu, ‘A̱vu aagbashi a̱ a̱ɓula̱ ɗa shi, waru orogo a ɗa vu ri! Vu damma vu reve ta̱ a na n tsu ciga n gasa uba̱ta̱ u na n cuꞌwa̱in shi.
\v 27 Vu shi ta zuwa ikebe i va̱ o uꞌwa wi ikebe e ekere a̱ a̱za̱ o uvadalasa, tsa̱ra̱ n tsura̱ pe ili i ro waꞌa a̱tsuma̱ a̱ yi.’
\p 
\v 28 “Ɗaɗa zagbaiꞌin u dammai akapi a agbashiꞌi, ‘Ushiyi ikebeꞌe e ekere a̱ yi, a̱vu i ca aagbashi a na a̱ ri ni ikebe i gbain i azurufa kupa.
\v 29 Na̱ nanza yuwan a̱ɓula̱ ni ili i na u ri na̱ a̱yi, A̱sula̱ a̱ ta̱ da̱shi ca yi ili ya̱ a̱bunda̱, waru u ta̱ tsura̱ ili hali a̱ ka̱ra̱la̱i wira̱. Za na gba ri na̱ a̱yi shi, A̱sula̱ a̱ ta̱ ushi keꞌen na u ri na̱ a̱yi.
\v 30 Gogo variyi aagbashi o ulambu wa̱ a̱ɓula̱ o ndolo a alanga, a̱tsuma̱ e irumbu i na ama a̱a̱ shon na a lumi anga e le na̱ a̱tsuma̱lima̱.’ ”
\s1 Mogono me te geꞌeto ama suru
\p 
\v 31 Reve Yesu lyuwa elime nu uritosu, “Mawun ma Vuma ma̱ ta̱ ta̱wa̱ na̱ tsugbain tsa gbain, na̱ nlingata ma̱ yi suru. U to oꞌwo Mogono, a̱vu u da̱nu o ootogu o ugeꞌetosu a gbain a̱ yi.
\v 32 Iɗa yu uvaɗi suru o to ɓoloto a̱ ma̱ka̱ka̱n ma̱ yi, waru u ta kasa le ure, cine za va aguɓa tsu kakasa ikyon na̱ mgbele.
\v 33 U ta zuwa ikyon o ukere usaꞌani, mgbele waru gba u zuwa le o ukere ugula̱ wa̱ yi.
\p 
\v 34 “A̱vu Mogonoꞌo u damma aza a na a̱ ri o ukere usaꞌani wa̱ yi, ‘Ta̱wa̱i, Dada va̱ ca ɗu ta̱ abaꞌun a̱ yi. Ushiyi tsugono tsa na A̱sula̱ o foɓoo nɗu kafu u yuwan uvaɗi.
\v 35 Ana n da̱na̱i na ambulu, i neꞌe mu ta̱ ilyalya n lyuwa. Ana n da̱na̱i na akuli, i neꞌe mu ta̱ mini n sowo. Ana n yuwain limocin i ushi mu ta̱ a ꞌwa ɗu.
\v 36 Ana n da̱na̱i ataɓu, i neꞌe mu ta̱ itana n oto. Ana n da̱na̱i ubanakun, i coꞌwo mu ta̱. Ana n da̱na̱i o uꞌwa wa ali, i ka̱lyuwa̱ mu ta̱.’
\p 
\v 37 “Reve ama a̱ a̱ɓula̱ꞌa̱ a̱ usu, ‘Zagbain, te ɗa tse ene nuwu na ambulu, a̱vu tsu neꞌe wu ilyalya? Waru te ɗe tse ene nuwu na akuli, a̱vu tsu neꞌe wu mini mo oso?
\v 38 Te ɗa tse ene nuwu a̱ ndeꞌen, waru danga na̱ ꞌwa tsu, reve tsu banu wu a ꞌwa tsu? Te ɗa tse ene nuwu ataɓu, reve tsu ca wu itana?
\v 39 Te ɗa tse ene nuwu ubanakun ko o uꞌwa wa ali, a̱vu tsu ka̱lyuwa̱ wu?’
\p 
\v 40 “Mogonoꞌo u ta̱ usu, ‘Ni i yuwaan ama a̱ va̱, ko cine a̱ ri ana ili i ro shi, a̱mu ɗa i yuwayin.’
\p 
\v 41 “Reve waru u damma aza a na a̱ ri o ukere ugula̱, ‘Lyawa numu, a̱ɗu na A̱sula̱ a yuwayin una̱. ꞌYa̱wa̱i i uwa a akina a na a̱ ri n kima̱ shi, za na o foɓoyi Mekerenkesu na̱ nlingata ma̱ yi!
\v 42 N da̱na̱ ta̱ na ambulu, agba i ca mu ilyalya n lyuwa shi. N da̱na̱ ta̱ na akuli, agba i ca mu mini n sowo shi.
\v 43 N da̱na̱ ta̱ o limocin, agba i ushi mu shi, waru n da̱na̱ ta̱ ataɓu, agba i neꞌe mu itana n oto shi. N da̱na̱ ta̱ ubanakun waru a̱tsuma̱ o uꞌwa wa ali, agba i ka̱lyuwa̱ mu shi.’
\p 
\v 44 “Ama o ndolo a̱ ta̱ usu, ‘Zagbain, urana u ne u ɗa tse ene nuwu na ambulu ko na akuli a̱vu tsu kuɗa̱ a kamba wu? Ko vu da̱na̱i o limocin a̱vu tsu kuɗa̱ a̱ ushi wu? Waru urana u ne u ɗa tse ene nuwu ataɓu reve tsu kuɗa̱ a ca wu itana? Ko gba urana u ne u ɗa vu da̱na̱i ubanakun ko vu da̱na̱i o uꞌwa wa ali reve tsu kuɗa̱ a̱ ka̱lyuwa̱ wu?’
\p 
\v 45 “Mogonoꞌo u ta damma le, ‘A mantsa ma na i ꞌyuwain a kamba ko vuma ta̱ a̱tsuma̱ a ama a̱ va̱, ko cine o rotsoi ili i ro shi, a̱mu ɗa i ꞌyuwain a yuwaan.’
\p 
\v 46 “Ama o ndolo a ta uwa a̱tsuma̱ a̱ a̱tsuma̱lima̱ a na a̱ ri n koto shi, amma ama a̱ a̱ɓula̱ a ta yuwan wuma u babu ukotu.”
\c 26
\s1 O foɓo ta̱ o una Yesu
\r (Mak. 14:1-2; Luk. 22:1-2; Yah. 11:45-53)
\p 
\v 1 Ana Yesu kotoi a yuwusan adanshi e ili i nda, ɗaɗa u dammai ojoro a̱ yi,
\v 2 “I reve ta̱, rana re ɗa buwai a fara A̱buki a Mapasa,† waru a̱mu, Mawun ma Vuma, a̱mu ɗa ee reme, a̱vu a vara mu a akpata.”†
\p 
\v 3 Reve nan ganu a gbagbain na azagbain o ɓoloto o uꞌwa wa aabara a nan ganu na a̱ tsu ɗe Kayafa.
\v 4 A̱vu a yuwan ifoɓi tsa̱ra̱ e reme Yesu usokowu, reve o una yi.
\v 5 Reve a damma, “Woo lobono tsu yuwan yi a mantsa ma̱ A̱buki a Mapasa shi, adama a na ama a̱ ta̱ ꞌya̱sa̱n nla̱ngi.”
\s1 Ka na̱ maniꞌin ma̱ ma̱guru
\r (Mak. 14:3-9; Yah. 12:1-8)
\p 
\v 6 Ele pe a̱tsuma̱ e ifoɓi i na ee reme Yesu, a̱yi gba u da̱na̱ ta̱ ɗe Batanya o uꞌwa wa̱ Simo ma̱kutu.
\v 7 A̱yi a alya e ilyalya ɗaɗa ka ro ta̱wa̱i uba̱ta̱ wa̱ yi na̱ meden ma aatali ma saꞌani. A̱tsuma̱ a̱ yi maniꞌin ma̱ ma̱guru me ikebe lon ma̱ da̱na̱ ta̱ pe. Reve u tsuwa̱n Yesu a aaci.
\p 
\v 8 Ana o ojoro a̱ yi e enei ili i ndolo, a̱vu a uwwa upan hali a damma, “Cine tsa ɗa wa̱a̱ lungususa̱ ikebe?
\v 9 Na̱ a̱ shi a wina yi, a̱ shi ta̱ tsura̱ ikebe ya̱ a̱bunda̱, reve a ca alambi.”
\p 
\v 10 Agba Yesu reve ta̱ ili i na aa dansa, ɗaɗa u damma nle, “Cine tsa ɗa yaa damatosun ka nda? U yuwaan mu ta̱ isaꞌani.
\v 11 I ta̱ na alambi a̱tsuma̱ a̱ ɗu kuci, a̱mu agba maa jima pa oɓolo na̱ a̱ɗu shi.
\v 12 U tsuwa̱n mu ta̱ maniꞌin ma nda, tsa̱ra̱ u foɓo lipu va̱ adama a̱ a̱ciɗa̱.
\v 13 Amayun a ɗa maa dansaa ɗu, uba̱ta̱ u na aa yuwan alajiya a Alabari a Saꞌani a nda a̱tsuma̱ o uvaɗi suru, a ta damma ili i na ka nda yuwain a cuwusan na̱ a̱yi.”
\s1 Yahuza usu ta̱ u wina Yesu
\r (Mak. 14:10-11; Luk. 22:3-6)
\p 
\v 14 A̱vu za ta̱ a̱tsuma̱ a Kupanejere, za na a̱ tsu ɗe Yahuza Iskariyoti, ꞌya̱wa̱ u yuwan adanshi na̱ nan ganu a gbagbain.
\v 15 Reve u damma, “Nye i ɗa yaa tsupa mu nna̱ n ca ɗu Yesu?” A̱vu a ca yi ikebe† i azurufa\f + \fr 26:15 \ft Danshi na a yuwayin ulinga pa nda na̱ Tsuheleni a̱yi ɗa “aguriyon.” Ka̱lyuwa̱ Ucuɗuwu wi “Ikebe.”\f* mataꞌatsu.
\v 16 Diga a mantsaꞌa reve u reme izami ure u na waa winaa le Yesu.
\s1 A yuwain A̱buki a Mapasa
\r (Mak. 14:12-21; Luk. 22:7-13, 21-23; Yah. 13:21-30)
\p 
\v 17 O urana wu ufaru u na aa yuwusan A̱buki o Opopofu,† a̱vu ojoro a̱ ta̱wa̱ a yuwan Yesu yeci, “Te ɗa vu cigai tsu foɓo alya e ilyalya adama A̱buki a Mapasa?”
\p 
\v 18 A̱vu u usu, “ꞌYa̱wa̱i a̱ lyuci uba̱ta̱ u vuma ro, a̱vu i damma yi, Manlu ma damma: ‘Mantsa ma na a ɗangwaa numu ma ta yuwusan. N ta yuwan A̱buki a Mapasa no ojoro a̱ va̱ o uꞌwa wa̱ wu.’ ”
\v 19 A̱vu a yuwan cine u damma nle, reve o foɓo ilyalya ya̱ A̱bukiꞌi ɗe.
\p 
\v 20 Ana urana u kotoi, reve Yesu na̱ Kupanejere† a̱ da̱nu alya.
\v 21 Ele pe a̱tsuma̱ a alya, a̱vu u damma, “N ta dansaa ɗu amayun, za ta̱ a̱tsuma̱ a̱ ɗu u ta wina mu.”
\p 
\v 22 Ojoroꞌo a uwwa uyoꞌo shi, reve a̱ ka̱ra̱ e eceshe yi a̱za̱ a̱ ta̱ ta̱, “Amayun, Zagbain, a̱mu ɗa maa wina wu shi. Ko a̱mu ɗa?”
\p 
\v 23 Reve Yesu usu, “Vuma na otoyi ukere wa̱ yi a mataɗa ma̱ ta̱ na̱ a̱mu, a̱yi ɗa za na aa wina mu.
\v 24 A̱mu Mawun ma Vuma, n ciga n ꞌyuwan n kuwa̱, cine a ɗanai adama a̱ va̱ ɗe nu ujimu. Amma woo yoꞌono vuma na wina numu shi. U shi ta laꞌaa yi nna̱ a̱ shi a matsan yi shi.”
\p 
\v 25 A̱vu Yahuza za na aa wina yi, damma, “Manlu, amayun a̱mu ɗa shi, ko a̱mu ɗa?”
\p A̱vu Yesu usu, “Ee, a̱vu ɗa.”
\s1 Alya e Ilyalya yu Ukosu
\r (Mak. 14:22-26; Luk. 22:14-20)
\p 
\v 26 Ele pe a̱tsuma̱ a alya, reve Yesu tara oopopofu. A̱vu u godyoo A̱sula̱ reve wu busa yi. Ɗaɗa waa ca ojoroꞌo a̱vu u damma, “Ushiyi oopopofu a ndaꞌa i tama yi, lipu va̱ ɗa ndaꞌa.”
\p 
\v 27 A̱vu Yesu tara mokoto a̱vu u godyoo A̱sula̱ adama a̱ yi, reve u ca ojoroꞌo a̱vu u damma, “Suru nɗu sowoi.
\v 28 Adama a na mpasa n va̱ n ɗa za na o oꞌwoi iroci ya akucunu† a na A̱sula̱ a yuwain na ama a̱ yi, adama a yuwaan le gafura vu nusu le.
\v 29 N damma ɗu nda, ma̱a̱ da̱shi sowo masayan ma inabi† shi, she na̱ n sowo yi o ure u saꞌavu o tsugono tsa Dada va̱.”
\p 
\v 30 Ana a canai ishipa, reve o uta̱ a̱ tyo a Masasan ma̱ Zetun.†
\s1 Bituru kucina ta̱ u te isawan na̱ Yesu
\r (Mak. 14:27-31; Luk. 22:31-34; Yah. 13:36-38)
\p 
\v 31 Reve Yesu damma ojoro a̱ yi, “Na ayin a nda, suru nɗu i ta suma a̱vu i lyawa mu, cine vumava̱sula̱ dammai,
\q1 ‘A̱sula̱ a̱ ta̱ ga̱la̱ za va aguɓa,
\q1 waru ikyon ya̱ yi i te beteꞌwe.’ \x ◊ \xo 26:31 \xt Zak. 13:7.\x*
\p 
\v 32 “A mantsa ma na n ꞌyoyin a̱tsuma̱ a̱ a̱kwa̱kwa̱, n ta ꞌya̱wa̱ a̱tsuma̱ a̱ Ga̱lili, n ta fara rawaa ɗu ɗe.”
\p 
\v 33 Reve Bituru damma, “Ko na akapi aa wasan wu, a̱mu maa wasan wu shi!”
\p 
\v 34 A̱vu Yesu damma, “Amayun a ɗa maa dansaa wu, na ayin a nda, kafu moton ma saala vu ta damma vu reve mu shi, toto utaꞌatsu.”
\p 
\v 35 Amma reve gba Bituru damma, “Maa damma n kuɗa̱ ta̱ e reve wu shi! N ta̱ kuwa̱ oɓolo na̱ a̱vu!” Ne ɗa fo akapi o ojoroꞌo a dammai.
\s1 Yesu yuwan ta̱ avasa e Getisemeni
\r (Mak. 14:32-42; Luk. 22:39-46)
\p 
\v 36 A̱vu Yesu ka̱ra̱ a̱ ꞌya̱wa̱ uba̱ta̱ u na a̱ tsu ɗe Getisemeni oɓolo no ojoro a̱ yi, a̱vu u damma le, “Isawain pa nda, a̱mu n ta̱ ꞌya̱wa̱ ndeɗe n yuwan avasa.”
\v 37 Reve u tara Bituru no olobo e re a̱ Za̱ba̱di, Yakubu na̱ Yahaya. U da̱na̱ ta̱ na̱ a̱tsumola̱ngu waru lon.
\v 38 Ɗaɗa u damma nle, “N ta̱ na̱ a̱tsumola̱ngu gashi u to una mu. I da̱nu pa nda, i da̱na̱ e ipiri oɓolo na̱ a̱mu.”
\p 
\v 39 A̱vu u ꞌya̱wa̱ makasu, reve u kingyo a̱vu u ka̱ɗa̱to urewesu wa̱ yi a̱ tyo e iɗa. A̱vu u yuwan avasa, “Dada va̱, nu u n ri yuwan, she vu ca mu mokoto ma̱ a̱tsuma̱lima̱ a nda wan. Amma vu yuwan ili i na n cigai wan, she ili i na vu cigai.”
\p 
\v 40 A̱vu u ka̱mba̱ uba̱ta̱ wo ojoro a taꞌatsuꞌu, reve u cina le a nlavu. A̱vu u damma Bituru, “Cine tsa ɗa mataꞌatsu ma̱ ɗu i ri a nlavu, agba i gura yuwan ipiri na̱ a̱mu hali rumu ta̱ shi?
\v 41 I da̱na̱ wuma tsa̱ra̱ i yuwan avasa i tsura̱ ucira u na yaa gura isawan mantsa ma̱ ma̱lyungwa̱. Asuvu a̱ ɗu a ciga ta̱ a yuwan ili i na i ri mejege, amma lipu ri nu ucira shi.”
\p 
\v 42 Reve waru u lyawa le tsa̱ra̱ u yuwan avasa, a̱vu u damma, “Dada va̱! Na aa tawa mokoto ma nda shi, reve wo oꞌwo she na̱ n sowo yi, n ta yuwan ili i na vu ciga numu n yuwan.”
\p 
\v 43 Ana u ka̱mbisa̱i a̱vu u cinisa le a nlavu adama a na a gura kpa̱tuꞌwa̱ esu e le shi.
\v 44 Ɗaɗa u lyawa nle a nlavu, a̱vu u ꞌya̱wa̱ u yuwan avasa wa taꞌatsu, a̱vu u vasa adansa ili i ta̱.
\p 
\v 45 Reve u ka̱mbisa̱ uba̱ta̱ wo ojoroꞌo, a̱vu u damma le, “Cine i buwai a nlavu e ivuwusan? Gogo mantsa ma yuwan ta̱. A̱mu ɗa, Mawun ma Vuma, ma na aa ca e ekere o ucira wa ama a vama.
\v 46 ꞌYoyin tsu ka̱ra̱i. Ka̱lyuwa̱i, apa vuma na aa wina mu rawai.”
\s1 E reme ta̱ Yesu
\r (Mak. 14:43-50; Luk. 22:47-53; Yah. 18:3-12)
\p 
\v 47 Yesu a̱tsuma̱ a adanshi, a̱vu Yahuza a̱tsuma̱ a Kupanejere, u rawa ugeru no oɓolo a ama. Nan ganu a gbagbain na azagbain a̱ lyungu ta̱ amaꞌa no oloko na̱ mutsun m peꞌeni adama a̱ nla̱ngi.
\v 48 Yahuza damma le ta̱ ɗe, “I te reve vuma na yee reme, na̱ n ꞌya̱wa̱ n ca̱sa̱ yi ni ikatalu.”
\v 49 A̱vu Yahuza ka̱ra̱ a̱ ꞌya̱wa̱ ya̱ Yesu mejege, reve u damma, “A̱ku, Manlu!” a̱vu u katala yi.
\p 
\v 50 Ɗaɗa u usuyi, “Iꞌutsa̱, yuwan ili i na vu ta̱wa̱i vu yuwan.” Ɗaɗa amaꞌa a̱ ta̱wa̱i a̱vu e reme yi ugbamu.
\p 
\v 51 A̱vu za ta̱ a̱tsuma̱ o ojoro e Yesu u tala matsun me peꞌeni, reve u koɗo utsuvu wa aagbashi wa aabara a nan ganu.
\v 52 A̱vu Yesu damma yi, “Ka̱mbuwa̱ matsun me peꞌeni ma̱ wu. Za na yuwain nla̱ngi na̱ matsun me peꞌeni, na̱ matsun me peꞌeni ma ɗa fo wa̱a̱ kuwa̱.
\v 53 I reve ta̱ amayun n ta gura pati Dada va̱, a̱vu u ca mu oɓolo oɓolo a nlingata ma̱ A̱sula̱ kupa ne ejere\f + \fr 26:53 \ft Oɓolo suru, a̱ ta̱ na̱ a̱soja 6,000: Reve Yesu damma u ta gura ɗe nlingata ma̱ A̱sula̱ 72,000 n ta̱wa̱ n kamba yi nnu u ciga u yuwan ne.\f* a na a laꞌai oɓolo suru adama a̱ nla̱ngi.
\v 54 Amma i ciga i ꞌyuwan wo oꞌwo tsunda, tsa̱ra̱ o shiton ili i na Adanshi a̱ A̱sula̱ a dammai.”
\p 
\v 55 Ɗaɗa Yesu dammai oɓoloꞌo, “I ta̱wa̱ ta̱ tsa̱ra̱ i reme mu no oloko na̱ mutsun m peꞌeni gashi a̱mu za vu nga̱la̱la̱i ɗa. Usana suru n da̱na̱ ta̱ o ritosu a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗa, agba i reme mu pe shi.
\v 56 Amma ili i nda i fara ta̱ suru, tsa̱ra̱ ili i na ama̱sula̱ a ɗanai i shiwan.” Ɗaɗa ojoroꞌo suru a sumai a̱vu a lyawa yi.
\s1 Azagbain a Mbara a yuwan ta̱ Yesu yeci
\r (Mak. 14:53-65; Luk. 22:54-55, 63-71; Yah. 18:13-14, 19-24)
\p 
\v 57 Aza a na e remei Yesu a tara yi ta̱ a̱ tyo o uꞌwa wa Kayafa, aabara a nan ganu, uba̱ta̱ u na munlu n Wila̱ na azagbain o ɓolotoi wira̱ u ta̱.
\v 58 A̱vu Bituru tonishi le makasu, hali a rawa a̱ a̱a̱ra̱ra̱ o uꞌwa wa aabara a nan ganu. Reve u da̱nu zuzu na̱ a̱duga̱ri a̱ A̱a̱ꞌisamapaɗa, tsa̱ra̱ we ene ili i na yaa fara na̱ Yesu.
\p 
\v 59 Nan ganu a gbagbain na Azagbain a Mbara† suru a̱ shi ta̱ a ciga o una Yesu. Reve a zamishi ama a na aa yuwan epen gayin a aci a̱ yi o ukobu wu ugeꞌetosu.
\v 60 Ama na̱ a̱bunda̱ a̱ ta̱wa̱ ta̱ a yuwan epen gayin a aci a̱ yi, amma azagbain a̱ tsura̱ ili ya amayun i na yaa zuwa o una yi shi.
\p Reve ama e re a̱ ta̱wa̱ a damma,
\v 61 “Vuma nda damma ta̱, ‘N ta̱ lungusa̱ A̱a̱ꞌisamapaɗa a nda, a̱vu n suwisa yi a̱tsuma̱ a rana taꞌatsu.’ ”
\p 
\v 62 A̱vu aabara a nan ganu a̱ ꞌyon mishin, reve we ece Yesu, “Vu ri ni ili i na vaa damma adama e ili i na ama a nda a dammai shi?”
\v 63 Agba u damma ili i ro shi.
\p A̱vu aabara a nan ganu a dammisa yi, “A̱tsuma̱ a aala a̱ A̱sula̱ a wuma n zuwa wu ta̱ vu kucina: Damma tsu na̱ a̱vu ɗa Zamawawa, Mawun ma̱ A̱sula̱.”
\p 
\v 64 Reve Yesu usu, “Ee, ne ɗaɗa cine vu dammai. Amayun a ɗa maa dansaa ɗu suru: a̱ ꞌya̱wa̱ elime i te ene Mawun ma Vuma nden o ukere usaꞌani u Mogono ma̱ A̱sulazuva, waru i te ene yi a̱ ta̱wa̱ e eleshe a zuva!”
\p 
\v 65 Ana aabara a nan ganu a uwwai ili i ndolo, a̱vu wu kara itana ya̱ yi adama a̱ a̱tsumola̱ngu, reve u damma, “Kai! Vuma nda yuwan ta̱ adanshi a vama e ekere a̱ A̱sula̱! Tsu ciga za da̱shi yuwan adanshi o ro adama a̱ yi shi. Suru nɗu yu uwwa ta̱ a na u yuwain adanshi a vama e ekere a̱ A̱sula̱.
\v 66 Nye i cigai a yuwan na̱ a̱yi?”
\p A̱vu a̱ usu, “U yuwan ta̱ unusu u na u rawai o una yi.”
\v 67 A̱vu a caraa Yesu ma̱tsa̱n o urewesu, reve a̱ kukumu ekere a̱vu a̱ cikwa̱ yi. Reve ozo o ro a ɓasa yi.
\v 68 Reve a damma, “Vu damma a̱vu ɗaɗa Zamawawaꞌa! Adama o ndolo damma tsu za na cikwa̱ nuwu!”
\s1 Bituru wasan ta̱ Yesu
\r (Mak. 14:66-72; Luk. 22:56-62; Yah. 18:15-18, 25-27)
\p 
\v 69 A mantsa mo ndolo, Bituru lo ubuwu nden a̱ a̱a̱ra̱ra̱, a̱vu aagbashi o usheli a rawa ya̱ꞌa̱ yi, reve u damma, “A̱vu fo vu to oɓolo na̱ Yesu za va̱ Ga̱lili.”
\p 
\v 70 Reve Bituru damma a̱ ma̱ka̱ka̱n ma ama, “Ne ɗa u ri shi! N reve ili i na vaa dansa shi!”
\p 
\v 71 Ana u lyawai uba̱ta̱ u na u shi, reve u ka̱mba̱ o una̱ntsu, a̱vu usheli u ro we ene yi. Reve u damma ama a na a̱ da̱na̱i lo, “Vuma nda fo u to oɓolo na̱ Yesu za va Nazara.”
\p 
\v 72 A̱vu waru Bituru wasisan u damma, “N kucina ta̱ n reve vuma nda shi!”
\p 
\v 73 A jima shi, a̱vu ama o ro a na a̱ da̱na̱i lo mishin a̱ ka̱ra̱ a̱ ꞌya̱wa̱ uba̱ta̱ wa̱ Bituru a̱vu a damma, “Amayun, a̱vu vu ta̱ pe a̱tsuma̱ a aza a na o tonishiyi Yesu. Tsu reve ta̱ ne, o una̱ u na vaa yuwusan adanshi tsa ama a̱ Ga̱lili.”
\p 
\v 74 Ɗaɗa Bituru dammai, “N kucina ta̱ amayun a ɗa maa dansa! A̱sula̱ a ca mu a̱tsuma̱lima̱ na amayun a ɗa mu shi! N reve vuma ndolo shi!”
\p Ɗaɗa moton ma saalashi.
\v 75 Ɗaɗa Bituru cuwain ni ili i na Yesu damma niyi: “Kafu moton ma saala, vu ta wasan a na vu reve numu utaꞌatsu!” A̱vu wu uta̱ u shon na̱ a̱tsumola̱ngu a̱ a̱bunda̱.\fig Bituru na̱ yisaali i moton|src="Matthew_26_75.tif" size="span" loc="Matthew 26:75" ref="Mat. 26:72-75"\fig*
\c 27
\s1 A tara ta̱ Yesu a̱ tyo ya Bilatu
\r (Mak. 15:1; Luk. 23:1-2; Yah. 18:28-32)
\p 
\v 1 Na̱ wasasa, a̱vu nan ganu a gbagbain suru na azagbain a yuwan ifoɓi i le a aci e Yesu tsa̱ra̱ o una yi.
\v 2 Reve a̱ nla̱ yi a̱vu a tara yi a̱ tyo ya Bilatu† Gwamna.
\s1 Ukwa̱ wa Yahuza
\r (Ajy. 1:18-19)
\p 
\v 3 Ana Yahuza, za na cayi Yesu e ekere a nꞌyuwatan ma̱ yi, we enei a paɗaa ta̱ Yesu ugana wu ukwa̱, reve u yuwan shinreve nu ulinga u na u yuwain. Ɗaɗa u tarai ikebe i azurufa\f + \fr 27:3 \ft Danshi na a yuwayin ulinga pa nda na̱ Tsuheleni a̱yi ɗa “aguriyon.” Ka̱lyuwa̱ Ucuɗuwu wi “Ikebe.”\f* mataꞌatsuꞌu u ka̱mbuwa̱a̱ nan ganuꞌu oɓolo na azagbaiꞌin.
\v 4 Reve u damma, “Unusu† u na n yuwain a̱yi ɗa: N ca ɗu ta̱ vuma na ri nu unusu shi tsa̱ra̱ yu una yi.”
\p A̱vu a̱ usu, “To, te imini i tsu na̱ za ndolo? Addama a̱ wu a ɗa ndoloꞌo, babu imini i tsu.”
\p 
\v 5 Ɗaɗa Yahuza ocoi ikebeꞌe pe a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗa. Reve u ꞌya̱wa̱ wu nla̱ aciya̱yi zuva hali u kuwa̱.
\p 
\v 6 A̱vu nan ganu a gbagbain a tara ikebeꞌe reve a damma, “U ushi ta̱ ikebe i nda adama a wuma u vuma. Wila̱ u damma ta̱ tsaa zuwa le oɓolo ni ikebe ya̱ A̱a̱ꞌisamapaɗa shi.”
\v 7 A̱vu a tara ikebeꞌe reve a tsula uɗuma̱ wu za na a maꞌasa mpondo, tsa̱ra̱ a̱ tsura̱ uba̱ta̱ u na a̱a̱ ciɗo omocin na̱ a̱ kuwa̱ a̱tsuma̱ a̱ Urishelima.
\v 8 A̱yi ɗa i zuwai e ɗeyi uba̱ta̱ꞌa̱, “Uɗuma̱ wu Mpasa” hali a̱ tyo a mantsa ma na a ɗanai aatagada a nda.
\v 9 Adama o ndolo a ɗa ili i na Irimiya† vumava̱sula̱ dammai i shiwain:
\q1 “A tara ta̱ ikebe i azurufa mataꞌatsu,
\q1 ikebe i na aza a Israꞌila a̱ usuyi a na aa tsupa adama a̱ yi.
\q1 
\v 10 A tsula ta̱ uɗuma̱ wu za na a maꞌasa mpondo cine A̱sulazuva a damma numu.” \x ◊ \xo 27:10 \xt Irm. 32:6-9.\x*
\s1 Bilatu yuwan ta̱ Yesu yeci
\r (Mak. 15:2-5; Luk. 23:3-5; Yah. 18:33-38)
\p 
\v 11 A mantsa mo ndolo, Yesu shi ta̱ mishin a̱ ma̱ka̱ka̱n ma Bilatu Gwamna, a̱vu Bilatu ece yi, “A̱vu mogono ma aza a Israꞌila ma ɗa?”
\p Reve Yesu usu, “Ee, cine vu dammai ne ɗa u ri.”
\p 
\v 12 Amma ana nan ganu a gbagbain na azagbain a yuwain epen a aci a̱ yi, u yuwan adanshi shi.
\v 13 Ɗaɗa Bilatu damma niyi, “Vu uwwa adanshi a na aa yuwusaan a aci a̱ wu shi?”
\v 14 Agba Yesu damma ili i ro shi, ɗaɗa gwamnaꞌa wo oꞌwoi a asalama lon.
\s1 Bilatu usu ta̱ Yesu kuwa̱
\r (Mak. 15:6-15; Luk. 23:13-25; Yah. 18:39–19:16)
\p 
\v 15 Aaꞌwan suru a mantsa ma̱ A̱buki a Mapasa, gwamna tsu lyawa ta̱ za ro na ri o uꞌwa wa ali, za na ama a ɗangwai.
\v 16 A mantsa mo ndolo, vuma na a̱ tsu ɗe Baraba da̱na̱ ta̱ pe a̱tsuma̱ o uꞌwa wa ali. Ama suru e reve ta̱ a na vuma va̱ a̱ɓula̱ ɗa shi, ko keꞌen.
\v 17 Adama o ndolo ana ama o ɓolotoi uba̱ta̱ u ta̱, ɗaɗa Bilatu ece nle, “A̱tsuma̱ aza a na a̱ ri pe a̱tsuma̱ o uꞌwa wa ali, zane ɗa i laꞌa cigai n lyawa? I ciga ta̱ n lyawa Baraba ko Yesu za na ee ɗesu Zamawawa?”
\v 18 Bilatu reve ta̱ a na azagbain a̱ ta̱wa̱i na̱ Yesu uba̱ta̱ wa̱ yi adama a̱ tsushuꞌun tsa ɗa.
\p 
\v 19 Bilatu† ubuwu lo nden o ootogu o ugeꞌetosu, ɗaɗa ka va̱ yi lyunguwa̱ niyi ikaka i nda: “She vu yuwan ili i ro na̱ vuma nda wan, adama a na ko iwuya i ta̱ u yuwan shi. Anaꞌan n yuwan ta̱ alavu a aci a̱ yi, waru u ta̱ ɓa̱li mu lon.”
\p 
\v 20 Agba nan ganu a gbagbain na azagbain a zuwa ta̱ okolo a ama o oɓoloꞌo a pati a lyawa Baraba, agba o una Yesu.
\p 
\v 21 A̱vu Bilatu ecishe oɓoloꞌo, “A̱tsuma̱ a ama e re a nda, zane ɗa i cigai n lyawaa ɗu?”
\p Reve a̱ usu, “Baraba.”
\p 
\v 22 Reve Bilatu ece le, “To, cine i cigai n yuwan na̱ Yesu, za na ee ɗesu Zamawawa?”
\p A̱vu suru nle a̱ usu, “Vara niyi a akpata.”
\p 
\v 23 Reve Bilatu ece le, “Nye i zuwai? Unusu u ne u ɗa u yuwain?”
\p A̱vu a̱ da̱shi saala lon, “Vara niyi akpata!”
\v 24 Ana Bilatu enei babu ili i na waa gura yuwan waru, waru ama a ɗa nda e temei nla̱ngi. Ɗaɗa u kenei mini a̱vu u saꞌa ekere a̱ yi a̱ ma̱ka̱ka̱n me le reve u damma, “Babu imini i va̱ na̱ mona ma vuma nda, a̱ɗu ɗa yoo una yi.”
\p 
\v 25 Reve suru nle a̱ usu, “E reme tsu nu unusu a̱tsu na̱ muwun n tsu adama a na o una niyi.”
\p 
\v 26 A̱vu Bilatu lyawaa le Baraba. Reve u damma a̱soja a fufaba Yesu na asuɗu, a̱vu a̱ ꞌya̱wa̱ a vara yi a akpata.†
\s1 A̱soja a yuwaan ta̱ Yesu ulamu
\r (Mak. 15:16-20; Yah. 19:2-3)
\p 
\v 27 A̱vu a̱soja a gwamna a tara Yesu a uwa pe o ukobu, reve a̱ ka̱nda̱ruwa̱ yi suru.
\v 28 Reve o foɗo yi itana, a̱vu o oto yi aayala a saan lon.
\v 29 A̱vu a tara awanda a̱ ka̱nda̱ruwa̱a̱ yi a aaci gashi ookokolo. Reve a zuwa aaɗanga o ukere usaꞌani wa̱ yi, a̱vu a̱ kingyo a̱ ma̱ka̱ka̱n ma̱ yi reve a yuwaan yi ulamu, “Tsu ca wu ta̱ tsugbain, mogono ma aza a Israꞌila.”
\v 30 A̱vu a tsuwa̱a̱n yi ma̱tsa̱n. A̱vu a̱ ushi aaɗanga o ukere wa̱ yiꞌi, a̱vu a fufaba yi a aaci na̱ a̱yi.
\v 31 Ana a̱ kuna̱i a yuwusaan yi ulamu a̱ tyo o ukosu, a̱vu o foɗo yi aayalaꞌa, reve otowiso yi itana ya̱ yi. A̱vu o uta̱a̱ yi tsa̱ra̱ a̱ ꞌya̱wa̱ uba̱ta̱ u na oo una yi.
\s1 A vara ta̱ Yesu a akpata
\r (Mak. 15:22-32; Luk. 23:27-43; Yah. 19:17-27)
\p 
\v 32 Ele a̱ mota̱a̱, a̱vu a gaꞌan na̱ vuma va Kurani, vuma na a̱ tsu ɗe Simo. A̱vu a̱sojaꞌa a zuwa yi u tanu akpataꞌa nu ucira.
\v 33 Reve suru nle a̱ ta̱wa̱ uba̱ta̱ u na a̱ tsu ɗe Gologota† (urevu wa̱ yi u ɗa Uba̱ta̱ wo Ookoluwo.)
\v 34 A̱vu a̱sojaꞌa a ca Yesu masayan ma na a̱ ja̱mba̱ra̱i na̱ a̱guma̱ o okono tsa̱ra̱ u sowo. U peɗe yi ta̱ reve u ꞌyuwan o sowo.
\v 35 Ana a vara niyi a akpataꞌa,† reve a̱soja a yuwan ancaꞌwa ɗaɗa e neꞌeshein itana ya̱ yi.
\v 36 Reve a̱sojaꞌa e isawan lo e ipiri ya̱ yi.
\v 37 A ɗana ta̱ ili i na i zuwai a vara niyi akpataꞌa, reve a vara yi zuva va aaci a̱ yi a akpata. Apa ili i na a ɗanai:
\pc \sc A̱yi nda, a̱yi ɗa Yesu mogono ma aza a Israꞌila.\sc*
\m 
\v 38 Waru a̱sojaꞌa a vara ta̱ evu e re a akpata, za ta̱ o ukere usaꞌani, za ta̱ gba o ukere ugula̱.
\v 39 Aza a na a̱ ka̱ra̱sa̱ lo, reve a lumgbatsasa aci e le a̱vu e isula yi.
\v 40 Reve a damma, “Vu damma ta̱ vu ta gura ɓuɓoso A̱a̱ꞌisamapaɗa, a̱vu vu suwisa yi a̱tsuma̱ a rana taꞌatsu. Adama o ndolo wawa aciya̱wu! Na̱ a̱vu Mawun ma̱ A̱sula̱ ma ɗa vu ri na amayun, cipa̱ ɗe a akpataꞌa!”
\p 
\v 41 Ne ɗa waru nan ganu a gbagbain na̱ munlu n Wila̱ n yuwaan niyi ulamu.
\v 42 Reve a damma, “U wawa ta̱ ozo o ro, agba u gura wawa aciya̱yi shi! U damma ta̱ a na a̱yi ɗa mogono ma aza a Israꞌila. To, lyawa niyi tse ene u cipa̱ e iɗa diga ɗe a akpataꞌa. Nnu u yuwan ne tsu ta̱ usu yi.
\v 43 U zuwaa ta̱ A̱sula̱ ucira, lyawa A̱sula̱ a wawa yi, nu u ciga. Hali gba u damma ta̱, ‘A̱mu ɗa Mawun ma̱ A̱sula̱.’ ”
\v 44 Evu a na a varai a akpata oɓolo na̱ a̱yi e isula yi ta̱ fo.
\s1 Ukwa̱ wa̱ Yesu
\r (Mak. 15:33-41; Luk. 23:44-49; Yah. 19:28-30)
\p 
\v 45 Ana urana u rawai aci, a̱vu irumbu i ɓa̱ru iɗa ma̱ɓula̱ a̱ tyo rumu taꞌatsu vu ulivu.
\v 46 A mantsa mo ndolo, reve Yesu saala, “Eloi, Eloi,\f + \fr 27:46 \ft A̱yi danshi “Eloi” mesun ma̱ yi ma̱ shon ta̱ una̱ta̱ na̱ mesun ma aala a Iliya. Adama o ndolo ana amaꞌa a uwwai Yesu adansa “Eloi, Eloi” a ta dansa u ta̱ ɗesu Iliya.\f* lama sabaktani,” nga, “A̱sula̱ a̱ va̱, A̱sula̱ a̱ va̱, nye i zuwai vu vari numu?”
\p 
\v 47 Ozo o ro a na a̱ da̱na̱i lo mishin uba̱ta̱ꞌa̱, ana a uwwai ne, a̱vu a damma, “Iliya ɗa wee ɗesu!”
\p 
\v 48 A̱vu za ro suma u tsupu ashiɗi a̱ mini ma alamu, reve wu nla̱ yi a aaɗanga reve u cayi tsa̱ra̱ u sowo. \fig A cayi Yesu mini ma alamu|src="Matthew_27_48.tif" size="span" loc="Matthew 27:48" ref="Mat. 27:48"\fig*
\v 49 Reve ozo o ro a damma, “Isawain, tse enei ko Iliya ta̱ ta̱wa̱ u wawa yi!”
\p 
\v 50 A̱vu Yesu saalisa, ɗaɗa u kuwa̱i.
\p 
\v 51 A mantsa mo ndolo, reve A̱sula̱ a zuwa umuna\f + \fr 27:51 \ft Umuna u nda u ɗa u neꞌeshein Upasu wa Akiza nu Upasu u na u Laꞌai Akiza a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗa. Aabara a nan ganu a ɗa goon a tsu uwa Upasu u na u Laꞌai Akiza u ta̱ a̱tsuma̱ a aaꞌwan.\f* u na u da̱na̱i Upasu wa Akiza a̱tsuma̱ a̱ A̱a̱ꞌisamapaɗa u karalai ure, diga zuva a̱ tyo e iɗa. A̱vu iɗa i ra̱mo, a̱vu atali a ɓatsa.
\v 52 Reve ason a̱ kpa̱tuꞌwa̱, a̱vu a̱ ꞌya̱sa̱n ama a̱ a̱ɓula̱ na̱ a̱bunda̱ a na a̱ kuwa̱i ɗe.
\v 53 O uta̱ ta̱ a̱tsuma̱ a ason, waru ana a̱ ꞌya̱sa̱in Yesu a̱tsuma̱ a̱ a̱kwa̱kwa̱, a uwa ta̱ a̱tsuma̱ a̱ lyuci va akiza, Urishelima, uba̱ta̱ u na ama a̱ a̱bunda̱ e ene nle.
\p 
\v 54 Ana yali na̱ a̱soja a na a̱ ri oɓolo na̱ a̱yi a̱ pirishi Yesu e enei cine iɗa i ra̱moi, oɓolo ni ili i na i farai suru, a uwwa ta̱ wovon lon. Ɗaɗa a dammai, “Mawun ma̱ A̱sula̱ ma ɗa u ri mayun!”
\p 
\v 55 A̱ma̱ci na̱ a̱bunda̱ a na o uta̱i Ga̱lili a na o toniyi Yesu tsa̱ra̱ a kamba yi, a̱ da̱na̱ ta̱ lo mishin makasu a̱ a̱ka̱nla̱.
\v 56 Meri† Magadaliya da̱na̱ ta̱ pe a̱tsuma̱ e le, na̱ Meri mma va Yakubu na̱ Isuhu, na̱ ka va Za̱ba̱di za na a̱yi ɗa mma va Yakubu na̱ Yahaya.
\s1 A̱ciɗa̱ e Yesu
\r (Mak. 15:42-47; Luk. 23:50-56; Yah. 19:38-42)
\p 
\v 57 A yuwan ta̱ vuma vi ikebe ro na a̱ tsu ɗe Isuhu, vuma lyuci va Arimatiya. Toni va̱ Yesu ɗa. Nu ulivu u ndolo a̱vu u ta̱wa̱ Urishelima.
\v 58 A̱vu u ꞌya̱wa̱ uba̱ta̱ wa Bilatu, tsa̱ra̱ u lyawa yi u tara lipu va̱ Yesu. Ɗaɗa Bilatu dammai a̱soja a̱ yi a ca yi.
\v 59 Ɗaɗa u tarai lipuꞌu, reve u katala yi no okoro.
\v 60 A̱vu u zuwa yi a̱tsuma̱ a aason a saꞌavu za na u ka̱pa̱i a̱tsuma̱ a aatali. Reve u keɓe aatali a gbain tsa̱ra̱ u ula una̱ wa aasoꞌon. Ana u yuwain ne ɗaɗa u ka̱ra̱i.
\v 61 A̱vu Meri Magadaliya na̱ Meri ro a̱ da̱nu lo zuzu na aasoꞌon.
\s1 A̱soja e ipiri ya aason
\p 
\v 62 O urana we ire, Ashibi, a̱vu nan ganu a gbagbain na Afarishi o ɓoloto uba̱ta̱ wa Bilatu.
\v 63 Reve a damma, “Zagbain, tsu cuwan ta̱ ana za ve epen o ndolo da̱na̱i wuma u damma ta̱, ‘Na a yuwan rana taꞌatsu n ta̱ ꞌyon a̱tsuma̱ a̱ a̱kwa̱kwa̱.’
\v 64 A zuwa ama a̱ piri aason o ndolo ulobonu hali rana taꞌatsu ndolo. Na̱ ne ɗa a yuwain shi, ojoro a̱ yi a̱ ta̱ ta̱wa̱ e iva̱ lipu va̱ yi, reve a damma ama a na A̱sula̱ a̱ ꞌya̱sa̱n yi ta̱ a̱tsuma̱ a̱ a̱kwa̱kwa̱. Epen o gogo a ta laꞌa za vu ufaru uwuyanu.”
\p 
\v 65 Ɗaɗa Bilatu† dammai, “Tarai a̱soja o ro tsa̱ra̱ a̱ ꞌya̱wa̱ a̱ piri aason o ndolo cine yaa gura yuwan ulobonu.”
\v 66 Reve a̱ ka̱ra̱ o foɓo aasoꞌon ulobonu lon, waru a̱vu a zuwa eerepu o urotsu† wa gwamna, reve a lyawa lo a̱soja a̱ da̱na̱ e ipiri.
\c 28
\s1 Uꞌyosun wa̱ Yesu a̱tsuma̱ o ukwa̱
\r (Mak. 16:1-10; Luk. 24:1-12; Yah. 20:1-10)
\p 
\v 1 Na̱ wasasa wa Aladi, reve Meri Magadaliya na̱ Meri ro a̱ ꞌya̱wa̱ tsa̱ra̱ a̱ ka̱lyuwa̱ aasoꞌon.
\p 
\v 2 A mantsa mo ndolo, iɗa i ra̱mo ta̱ nu ucira. Reve malingata ma̱ A̱sulazuva ma̱ cipa̱ diga zuva, a̱vu u ꞌya̱wa̱ uba̱ta̱ u na aasoꞌon a̱ ri, a̱vu u gandaluwa aatali a na a ulayi una̱ wa aasoꞌon. Reve u da̱nu zuva va̱ yi. \fig A gandaluwai aatali o una̱ wa aason|src="Matthew_28_2.tif" size="span" loc="Matthew 28:2" ref="Mat. 28:2"\fig*
\v 3 U da̱na̱ ta̱ e ikanasa tsi imaɗatsu, itana ya̱ yi i da̱na̱ ta̱ uꞌuri puwu.
\v 4 A̱soja a na a̱ da̱na̱i e ipiri ya aasoꞌon, reve wovon u reme le lon adama a malingata ma̱ A̱sula̱, a̱vu a uwa mejeꞌen ma̱ lipu, a̱vu a̱ riya̱ e iɗa gashi a̱kwa̱kwa̱.
\p 
\v 5 Reve malingataꞌa ma damma a̱ma̱ciꞌi, “She yu uwwa wovon wan. N reve ta̱ i te izami ya̱ Yesu, za na a varai a akpata.
\v 6 Wu pa shi. U ꞌyon ta̱ a̱tsuma̱ a̱ a̱kwa̱kwa̱ cine u damma nɗu waa yuwan. Ta̱wa̱i ye ene uba̱ta̱ u na lipu va̱ yi da̱na̱i.
\v 7 ꞌYa̱wa̱i i damma ojoro a̱ yi gogogo, ‘Yesu ꞌyon ta̱ a̱tsuma̱ a̱ a̱kwa̱kwa̱. U ta̱ ɗe elime a̱ ɗu a̱ ꞌya̱wa̱ Ga̱lili, i te ene yi ɗe.’ A̱yi ɗa n ta̱wa̱i n damma ɗu.”
\p 
\v 8 Ɗaɗa a̱ma̱ciꞌi a lyawushi aasoꞌon. A̱ da̱na̱ ta̱ a uwwusa wovon, waru a̱ da̱na̱ ta̱ a yuwusan ma̱za̱nga̱ lon fo. A suma ta̱ tsa̱ra̱ a damma ojoroꞌo ili i na i farai.
\v 9 Babu usa̱n reve Yesu† cina le, a̱vu u ca̱sa̱ le. Reve a rawa zuzu na̱ a̱yi e reme ana a̱ yi, a̱vu a yuwaan yi a̱ga̱nda̱.
\v 10 A̱vu u damma, “She yu uwwa wovon wan! ꞌYa̱wa̱i i damma ojoro a̱ va̱ a̱ ꞌya̱wa̱ Ga̱lili. A ta cina mu ɗe.”
\s1 A̱soja a̱ usu ta̱ a yuwaan epen
\p 
\v 11 Ana a̱ma̱ciꞌi a̱ yuwain uka̱ru u le, reve a̱soja a na a̱ da̱na̱i e ipiri ya aasoꞌon a̱ ka̱mba̱ a̱tsuma̱ a̱ lyuci, a̱vu a damma nan ganu a gbagbain ili i na i farai suru.
\v 12 Reve nan ganu a gbagbaiꞌin o ɓoloto uba̱ta̱ u ta̱ na azagbain a̱ lyuci a̱vu a yuwan a̱sa̱la̱. Reve a ca a̱sojaꞌa ikebe ya̱ a̱bunda̱,
\v 13 reve a damma le, “Dammai ama a na ojoro e Yesu a̱ ta̱wa̱ ta̱ na ayin, ɗaɗa e iva̱i lipu va̱ yi a̱ɗu pe a̱tsuma̱ a nlavu.
\v 14 Nna adanshi a nda a rawa a atsuvu a gwamna, tsu ta yuwaan yi adanshi tsa̱ra̱ tsu wawa ɗu a̱tsuma̱ a addama.”
\v 15 A̱vu a̱sojaꞌa a̱ ushi ikebeꞌe, reve a yuwan cine a damma nle a yuwan. Ne ɗa adanshiꞌi a bazai a̱tsuma̱ a Yahuda hali a̱ tyo anaꞌan.
\s1 Yesu yuwan ta̱ adanshi no ojoro a̱ yi
\r (Mak. 16:14-18; Luk. 24:36-49; Yah. 20:19-23; Ajy. 1:6-8)
\p 
\v 16 A̱vu ojoro kupa na̱ za ta̱ꞌa̱ a̱ ka̱ra̱ a̱ ꞌya̱wa̱ a masasan mo ro a̱tsuma̱ a̱ Ga̱lili uba̱ta̱ u na Yesu damma nle a̱ ꞌya̱wa̱.
\v 17 Ana a rawa e ene niyi, a̱vu a yuwaan yi a̱ga̱nda̱, agba ozo o ro e le a̱ usu shi.
\v 18 Ɗaɗa Yesu ta̱wa̱i uba̱ta̱ u le reve u damma, “A̱sula̱ a ca mu ta̱ ucira a̱tsuma̱ a zuva ni iɗa suru.
\v 19 ꞌYa̱wa̱i i tsura̱ otoni a̱tsuma̱ o uvaɗi suru. I rumbu le a̱tsuma̱ a ala† a Dada, na ala a Mawun na ala a̱ Ruhu va Akiza.†
\v 20 I rito le a yuwan ili i na n damma nɗu. N ta̱ da̱na̱ oɓolo na̱ a̱ɗu kuci, hali a̱ tyo o ukosu wu uvaɗi.”
