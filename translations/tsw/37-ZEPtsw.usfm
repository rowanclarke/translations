\id ZEP - Tsishingini (tsw) 
\h Zafaniya 
\toc3 Zaf 
\toc2 Zafaniya 
\toc1 Zafaniya 
\mt2 Aatagada a vumava̱sula̱ 
\mt1 Zafaniya 
\is1 Ucuɗuwu wa aatagada a nda 
\ip Zafaniya vumava̱sula̱ yuwan ta̱ adanshi e ikaka o ukosu wa a'wan ukpakucindere (700) kafu a matsan Yesu. U ta gura o'wo adanshi e ikaka i nda i fara ta̱ a'wan kupa kafu Mogono Josiya yuwan ulapulu wi itoni a a'wan ukpakukupa uta̱li nu ushin na̱ za ta̱ (621) kafu limatan va̱ Yesu. 
\ip Aatagada'a u ta̱ ni idanshi yi ikaka i na a̱ ri urevu ne e le, za na aa dansa, urana wu uge'etosu nu ukototosu u ta̱ lo a̱ ta̱wa̱ na A̱sulazuva aa yuwaan Yahuda adama a na wa yuwusaan musula̱ n ro a̱ga̱nda̱. Waru A̱sulazuva a̱ ta̱ ge'eto akapi a nɗa suru. 
\ip Ko na wo o'woi e ge'eto ta̱ Urishelima, acina elime a̱ ta̱ ka̱mbuwa̱i cine u da̱na̱i. Ama a na a̱a̱ da̱nu pe, o to o'wo ama a na a̱ ka̱ɗa̱toi aciyele oɓolo na̱ a̱za̱ a̱ a̱ɓula̱. A̱sulazuva na aciya̱yi u ta yuwan ma̱za̱nga̱ o una̱ wa akapi ama a̱yi na buwai. 
\io1 Ili i na i ri pe: 
\io1 Urana u na A̱sulazuva e ge'eto Yahuda ta̱ lo a̱ ta̱wa̱ 1:1-18 
\io1 Ɗewu adama o uvadalasa 2:1-3 
\io1 Uge'etosu wu nɗa ma atakpaci 2:4-15 
\io1 Uge'etosu wa̱ Urishelima ni iwawi ya̱ yi 3:1-13 
\io1 Ishipa i ma̱za̱nga̱ 3:14-20. 
\ib  
\c 1  
\p  
\v 1 A mantsa ma na Josiya ulobo wa Amon da̱na̱i o tsugono tsa Yahuda, vumava̱sula̱ Zafaniya ulobo wa Kush, ulobo wa Gedaliya, mawun ma tsukaya ma Amariya wu u'wa wa Hezekiya, damma ta̱ ili i na A̱sulazuva a damma niyi.\x - \xo 1:1 \xt 2 Ngo 22:1-23:30; 2 Alb 34:1-35:27.\x* 
\s1 Urana wu uge'etosu wa̱ A̱sulazuva 
\q1  
\v 2 Reve A̱sulazuva a damma, <<N ta̱ kototo ili biti 
\q2 a̱tsuma̱ o uvaɗi.>> 
\q1  
\v 3 <<N ta̱ kototo vaɗilima̱ 
\q2 ni inama yu uvaɗi suru, 
\q1 n ta̱ kototo nnunu 
\q2 na̱ mugula m mala, 
\q1 n ta̱ kototo a̱za̱ e iwuya, 
\q2 a̱vu n tawa vaɗilima̱ diga o uvaɗi.>> 
\q1  
\v 4 <<N ta̱ ba̱ruwa̱ ukere u va̱ n yuwan nla̱ngi na̱ Yahuda 
\q2 na aza a na a̱ ri nden a̱tsuma̱ a̱ Urishelima suru. 
\q1 Waru n to kototo akapi ama a na a yuwusaan Ba'al a̱ga̱nda̱ 
\q2 na ala a nan ganu a na a yuwusan yi ulinga. 
\q1  
\v 5 N ta̱ kototo aza a na a tsu kumba ukwa̱'a̱ 
\q2 a yuwaan urana na̱ woto na̱ italyo'o a̱ga̱nda̱. 
\q1 N ta̱ kototo aza a na a̱ ka̱ɗa̱tosu a kucinasa na̱ A̱sulazuva, 
\q2 waru a yuwusan akucunu na̱ ma̱sula̱ Mole. 
\q1  
\v 6 N ta̱ kototo aza a na a vadalai ucina a lyawai itoni ya̱ A̱sulazuva, 
\q2 na aza a na a zamiyi A̱sulazuva ko a pati niyi ikambishi shi.>> 
\q1  
\v 7 Vu rungwa̱ kpen a̱ ma̱ka̱nka̱ ma̱ A̱sulazuva! 
\q2 Adama a na urana wa̱ yi u yuwan ta̱ zuzu. 
\q1 A̱sulazuva o foɓo ta̱ na wa ca a ama a̱ yi kucci, 
\q2 waru u ɗangula ta̱ aza a yuwan ili i na u foɓoi. 
\s1 Uge'etosu a aci azagbain o mogono 
\q1  
\v 8 <<Urana u na a̱mu A̱sulazuva maa ca ama a̱ va̱ kucci, 
\q2 n ta̱ ge'eto azagbain o mogono na̱ muwun n mogono, 
\q1 na aza a na oo otosu a̱tugu a̱ga̱nda̱ 
\q2 a̱ musula̱ mi iɗa i ro. 
\q1  
\v 9 O urana u ndolo n ta̱ ge'eto za na suru 
\q2 a yuwusan a̱ga̱nda̱ tsa za na revei A̱sula̱ shi\f + \fr 1:9 \fq a yuwusan a̱ga̱nda̱ tsa za na revei A̱sula̱ shi \ft A̱yi nda agadu aza a Filistiya a ɗa. Ka̱lyuwa̱ 1 Sam 5:5.\f*, 
\q1 na aza a na o shitoyin u'wa wu zagbain le 
\q2 ni ili ya usa na̱ yipalishi.>> 
\s1 Uge'etosu a aci aza a atsulu na awina a Urishelima 
\q1  
\v 10 A̱vu A̱sulazuva a damma, <<O urana u ndolo, 
\q2 a ta uwwa mesun diga o Una̱ntsu u Magula, 
\q1 yorori diga o Upasu u ire, 
\q2 ni ilama yu ucira i ma̱riya̱ ma agaɗi. 
\q1  
\v 11 Oruwoi, a̱ɗu aza a na i ri nden upasu we eden! 
\q2 Adama a na o kototo ta̱ suru aza a atsulu na awina, 
\q1 aza a na a tsulusa azurufa suru 
\q2 o una le ta̱. 
\s1 Uge'etosu e ekere aza a na a cayi okolo shi 
\q1  
\v 12 A mantsa mo ndolo 
\q2 n ta gbangaɗa Urishelima ni ifitila, 
\q1 a̱vu n ca a̱za̱ nden n vama oforo, 
\q2 aza a na aa yuwusan majiyan, 
\q2 <A̱sulazuva a yuwan tsu isa'ani ko iwuya shi.> 
\q1  
\v 13 A̱ ta̱ pura̱ utsuru u le, 
\q2 'wa le waru o kototo le, 
\q2 a ta suwa 'wa agba a̱ da̱nu pe shi. 
\q1 A̱ ta̱ cu'wa̱n a̱ɗuma̱ a̱ ina̱bi 
\q2 agba oo sowo masayan me le shi.>> 
\s1 Urana wa̱ A̱sulazuva 
\q1  
\v 14 Urana u gbain wa̱ A̱sulazuva 
\q2 a yuwan ta̱ zuzu a̱ zura̱sa̱ ni ilaɗi. 
\q1 Uwwai! Uɗyo u mesun ma̱ A̱sulazuva ma̱ ta̱ da̱na̱ okono, 
\q2 o urana'a za a na gurai uvon u ta yuwan yisali lon. 
\q1  
\v 15 Urana u ndolo u to o'wo urana wu upan, 
\q2 urana u ɗa wa̱ a̱tsumola̱ngu na̱ a̱tsuma̱lima̱, 
\q1 urana u ɗa wa̱ a̱tsuma̱lima̱ nu ukototosu, 
\q2 urana u ɗa wi irumbu picim, 
\q1 urana u ɗa we eleshe ni irumbu da̱n. 
\q2  
\v 16 Urana u ɗa u mesun ma avana na̱ yorori yu uvon 
\q2 a aci e ilyuci i na i ri na̱ kari vu ucira 
\q2 na atsura o uga'an. 
\q1  
\v 17 <<N ta̱ ta̱wa̱a̱ ama na̱ a̱tsuma̱lima̱ 
\q2 hali e reme mmalu tsa̱ nrumba̱, 
\q1 adama a na a yuwaan ta̱ A̱sulazuva unusu. 
\q2 O to oco mpasa n le tsa̱ mini, 
\q2 inama i le waru tse everi.>> 
\q1  
\v 18 O urana wu upan wa̱ A̱sulazuva 
\q2 azurufa na̱ zinariya le 
\q2 aa gura wawa le shi. 
\q1 A̱tsuma̱ o upan wu usuɗu wa̱ yi, 
\q2 u to kototo uvaɗi ma̱ɓula̱. 
\q1 Na amayun u ta̱ kototo 
\q2 aza a na a̱ ri nden o uvaɗi suru. 
\c 2  
\s1 Ɗewu adama o uvadalusa 
\q1  
\v 1 Ɓolotoi, ɓolotoi, 
\q2 a̱ɗu iɗa yu ulambu u wono, 
\q1  
\v 2 kafu e bete'we ɗu tso owopo, 
\q2 kafu upan wu usuɗuwu wa̱ A̱sulazuva u cipa̱a̱ ɗu, 
\q1 kafu urana wu upan 
\q2 wa̱ A̱sulazuva u ta̱wa̱ aci a̱ ɗu. 
\q1  
\v 3 I zami A̱sulazuva suru nɗu, 
\q2 a̱ɗu na i tarai aciya̱ɗu ili i ro shi e iɗa'a, 
\q2 a̱ɗu na yaa yuwusan ili i na u dammai. 
\q1 I zami ya̱ a̱ɓula̱, i tara aciya̱ɗu ili i ro wan. 
\q2 U ta gura o'wo a pa'aton ɗu 
\q2 o urana wu upan wa̱ A̱sulazuva. 
\s1 Uge'etosu a aci aza a Filistiya 
\q1  
\v 4 O to kototo Gaza 
\q2 Ashikelon to o'wo okongo. 
\q1 A̱ ta̱ gba̱ra̱ Ashido nu urana a aci, 
\q2 reve fo a̱ gba̱ra̱ Ekuron.\x - \xo 2:4 \xt Isha 14:29-31; Irm 47:1-7; Izk 25:15-17; Juw 3:4-8; Emo 1:6-8; Zak 9:5-7.\x* 
\q1  
\v 5 A̱tsuma̱lima̱ a ta cina a̱ɗu, 
\q2 a̱ɗu na i ri e ikyun i mala, 
\q1 a̱ɗu aza a Keretiya, 
\q2 adanshi a̱ A̱sulazuva a̱ ta̱ a̱ nla̱ngi na̱ ɗu, 
\q1 a̱vu Ka'ana iɗa ya aza a Filistiya, 
\q2 <<N ta̱ kototo wu, 
\q2 hali na za a la'a shi.>> 
\q1  
\v 6 Iɗa i na i ri e ikyun i mala, 
\q2 uba̱ta̱ u na aza a Keretiya a̱ ri na̱ nden, 
\q1 u to o'wo uba̱ta̱ wa alyuna, 
\q2 nu uva̱la̱ta̱ wa aza a aguɓa 
\q2 nu uba̱ta̱ wa aguta e ikyon. 
\q1  
\v 7 Uba̱ta̱'a̱ u to o'wo, uba̱ta̱ wa aza a na 
\q2 a buwai wuma o u'wa wa Yahuda, 
\q2 lo ɗa a yuwan alyuna. 
\q1 Nu ulivu a̱vu o von 
\q2 a 'wa va aza a Ashikelon. 
\q1 Adama a na A̱sulazuva A̱sula̱ e le a̱ ta̱ da̱na̱ a ɗa e le, 
\q2 waru u ta̱ ka̱mbuwa̱a̱ le na aba'un e le. 
\s1 Uge'etosu aci a Mowa na̱ Amon 
\q1  
\v 8 <<Mu uwwa ta̱ ulamu u na aza Mowa a yuwusan, 
\q2 na̱ wisulusa u na aza a Amon a yuwusan, 
\q1 aza a na ee isulusa ama a̱ va̱ 
\q2 a lapusa ma̱ka̱nka̱ a dansa, 
\q2 a ta lyuwa iɗa ya ama a̱ va̱.\x - \xo 2:8 \xt Isha 15:1-16:14; 25:10-12; Irm 48:1-49:6; Izk 21:28-32; 25:1-11; Emo 1:13-15.\x* 
\q1  
\v 9 A̱vu A̱sulazuva o oɓolo a̱ a̱soja a zuva 
\q2 A̱sula̱ a Isra'ila a damma, 
\q1 n kucina ta̱ na̱ wuma u va̱, 
\q2 Mowa to o'wo tso Sodom, 
\q2 aza a Amon waru tsa Gomora 
\q2 iɗa'a u ta shiwan na awanda na̱ a̱nci a akpaɗi, 
\q2 iɗa i na i kuwa̱i hali hali. 
\q1 Ama a̱ va̱ a na a la'ai a̱ ta̱ pura̱ itana i le, 
\q2 wo o'wo agadu le.>> 
\q1  
\v 10 A̱yi nda a̱yi ɗa ili i iliyinkapa ya aciyogbamu u le, 
\q2 adama a na a tarai ama'a ili i ro shi, 
\q1 reve a yuwan tsushu'un na ama 
\q2 a̱ A̱sulazuva o oɓolo a̱ a̱soja a zuva. 
\q1  
\v 11 A̱sulazuva o to o'wo ili i wovon e ekere e le, 
\q2 na amayun u kototo musula̱ mu uvaɗi suru. 
\q1 Reve nɗa n na n ri e ikyun i mala a̱ ka̱ɗa̱to wa̱ yi, 
\q2 za suru diga e iɗa ya̱ yi. 
\s1 Uge'etosu a aci a̱za̱ a̱ Kush 
\q1  
\v 12 <<Hali na̱ a̱ɗu fo a̱za̱ a̱ Kush, 
\q2 o to o una ɗu na̱ matsun me pe'eni ma̱ va̱.>>\x - \xo 2:12 \xt Isha 18:1-7.\x* 
\s1 Uge'etosu a aci aza a Asuriya 
\q1  
\v 13 A̱sulazuva a̱ ta̱ ba̱ruwa̱ ukere wa̱ yi 
\q2 a̱ tyo wu ugana u kototo Asuriya, 
\q1 u ta̱ ka̱mba̱to Niniva okongo, 
\q2 u'yewu tsa̱ a̱tsumona.\x - \xo 2:13-15 \xt Isha 10:5-34; 14:24-27; Nah 1:1-3:19.\x* 
\q1  
\v 14 Iliyamunga o to von e memere ma̱ yi, 
\q2 na̱ cu'un vu nama biti. 
\q1 Vori na̱ papagula a̱ ta̱ da̱na̱ 
\q2 zuva va atsura a̱ lyuci'i, 
\q1 yisali i le i ta̱ da̱na̱ o uta̱sa̱ 
\q2 a angu a asula na̱ na̱ntsu, 
\q1 n'yuwatan n ta palu'wa 
\q2 ɗanga seda vu kwa̱'a̱ va̱ yi. 
\q1  
\v 15 A̱yi nda a̱yi ɗa lyuci va afalu 
\q2 na shi nden gbaga, 
\q1 za na dammai aciya̱yi, 
\q2 <<A̱mu ɗa goon, waru za ro lo shi!>> 
\q1 A̱yi ɗa nda wo o'woi okongo, 
\q2 uba̱ta̱ wu nven wi inama yu una! 
\q1 Za na ka̱ra̱i lo suru, 
\q2 u ta cira a̱vu u gbaɗatsa aaci. 
\c 3  
\s1 Uge'etosu a aci a̱ Urishelima 
\p  
\v 1 A̱tsuma̱lima̱ a ta cina lyuci va aciyogbamu, 
\q2 lyuci vi idaba ni iɓongishi! 
\q1  
\v 2 U tsu poloo za atsuvu shi, 
\q2 waru u tsu usu ulapulu shi. 
\q1 U tsu zuwaa A̱sulazuva okolo a̱ yi shi, 
\q2 waru u tsu rawa zuzu na̱ A̱sula̱ shi. 
\q1  
\v 3 Azagbain a̱ yi a̱ ta̱ tsi ikamu i ma̱gugwa̱, 
\q2 a̱za̱ o uge'etosu a̱ yi a̱ ta̱ tsa̱ nkerenkesu n na n liva̱i na ambulu, 
\q2 aza a na a tsu buwaa ili adama a nfa'an shi. 
\q1  
\v 4 Ama̱sula̱ a̱ yi ama a vama a ɗa, 
\q2 a̱za̱ e ikpa'a, 
\q1 nan ganu a̱ yi a tara ili ya akiza ili i ro shi. 
\q2 Waru a kuɗa ta̱ wila̱. 
\q1  
\v 5 A̱sulazuva a na a̱ ri a̱tsuma̱ a̱ lyuci'i za va̱ a̱ɓula̱ a ɗa, 
\q2 u tsu yuwan unusu shi. 
\q1 Usana biti u tsu roco ta̱ a̱ɓula̱ a̱ yi, 
\q2 usana wa̱ A̱sula̱ suru u tsu ka̱la̱ma̱ shi, 
\q2 suru na̱ ne za vu ulambu wa̱ a̱ɓula̱ ri na̱ wono shi. 
\q1  
\v 6 Reve A̱sulazuva a damma, <<N kototo ta̱ ɗe nɗa mu uvaɗi, 
\q2 ba̱ta̱ vu pa'atan vu ucira le la̱nga̱ ta̱. 
\q1 Waru n lungusa̱ ta̱ re le, 
\q2 babu za na a̱ kurusu le. 
\q1 O kototo ta̱ ilyuci i le suru suru 
\q2 ko za la'a shi 
\q2 waru ko za ri pe shi. 
\q1  
\v 7 Shi ta̱ n tara na amayun, a ama a̱ va̱ a ta uwwa wovon u va̱, 
\q2 waru a̱ usu tsuɓari, 
\q2 agba a̱a̱ da̱shi yuwan ulambu wu ugbozu shi, 
\q2 diga e ili i na n rono nle atsuvu. 
\q1 Amma suru na̱ ne reve a lyuwa elime nu ulambu wa̱ a̱ɓula̱ 
\q2 e ili i na aa yuwusan suru. 
\q1  
\v 8 Adama o ndolo a̱mu A̱sulazuva n damma ta̱, 
\q2 <Puroyi urana u na ma̱ 'yon n yuwan adanshi a aci a nɗa, 
\q1 adama a na n zuwa ta̱ okolo a na mo ɓoloto wu nɗa, 
\q2 no ozo o tsugono uba̱ta̱ u ta̱, 
\q1 reve n tsun wa̱ le upan u va̱, 
\q2 upan wu usuɗu u va̱ a aci e le. 
\q1 Uvaɗi ma̱ɓula̱ u ta̱ koto 
\q2 adama o upan wu usuɗuwu u va̱.> >> 
\s1 Uvadalasa wu nɗa 
\q1  
\v 9 <<Na amayun, a mantsa ma ɗaɗa 
\q2 ma̱a̱ ka̱mba̱to nɗa a̱a̱ da̱na̱ a dansa amayun, 
\q1 suru nle a̱ ta̱ ɗe Aala A̱sulazuva, 
\q2 waru a yuwayin a̱ga̱nda̱ no okolo a̱ ta̱. 
\q1  
\v 10 Diga a alanga o upasu wu uɗolu wa̱ Kush 
\q2 aza a na aa yuwusaan mu a̱ga̱nda̱, 
\q1 ama a̱ va̱ a na a̱ ri ubete'u, 
\q2 a̱ ta̱ ta̱wa̱a̱ mu na̱ kucci.>> 
\q1  
\v 11 <<O urana u ndolo yaa uwwa wono shi 
\q2 adama a̱ nusu na i yuwaan numu shi. 
\q1 Adama a na n ta̱ o uta̱a̱ aza a aciyogbamu 
\q2 no ozo o uvaɗu a̱tsuma̱ a̱ ɗu. 
\q1 Waru ya̱a̱ da̱shi yuwan aciyogbamu 
\q2 a Masasan ma Akiza ma̱ va̱ shi. 
\q1  
\v 12 Agba n ta lyawa aza a na a tarai aciyele ili i ro shi, 
\q2 na aza a na a̱ ka̱ɗa̱toi aciyele a̱tsuma̱ a̱ ɗu, 
\q2 a ta zami upa'anta uba̱ta̱ wa̱ A̱sulazuva. 
\q1  
\v 13 Aza a Isra'ila a na a buwai a̱a̱ da̱shi yuwan unusu shi, 
\q2 waru a̱a̱ da̱shi yuwan epen shi, 
\q2 agba a̱a̱ da̱shi tsura̱ epen a̱ na̱ le shi. 
\q1 A ta yuwan aguɓa, reve o von, 
\q2 agba za lo na a da'waton le shi.>>\x - \xo 3:13 \xt Wen 14:5.\x* 
\s1 Ishipa i ma̱za̱nga̱ 
\q1  
\v 14 Cana ishipa nu ucira, a̱vu Sihiyona! 
\q2 Vu 'ya̱sa̱n uɗyo, a̱vu Isra'ila! 
\q1 Vu yuwan ma̱za̱nga̱ 
\q2 waru vu yuwan mere no okolo a̱ wu suru, 
\q2 a̱vu Urishelima! 
\q1  
\v 15 A̱sulazuva a tawa ta̱ oforo a aci a̱ wu, 
\q2 waru u loso ta̱ n'yuwatan ma̱ wu. 
\q1 A̱sulazuva mogono ma Isra'ila ma̱ ta̱ oɓolo na̱ a̱vu, 
\q2 va̱a̱ da̱shi uwwa wovon u meleshe shi. 
\q1  
\v 16 O urana u ndolo a ta damma Urishelima, 
\q2 <<She vu uwwa wovon wan, a̱vu Sihiyona, 
\q2 she vu lyawa ekere a̱ wu a̱ ɗa̱mba̱ wan. 
\q1  
\v 17 A̱sulazuva A̱sula̱ a̱ wu 
\q2 a̱ ta̱ oɓolo na̱ a̱vu, 
\q2 za vu uvon ɗa, waru u tsu ulyuwu ta̱ aci. 
\q1 U ta yuwan ma̱za̱nga̱ a̱vu yuwan mere adama a̱ wu, 
\q2 u ta̱ ka̱mba̱to wu usa'avu adama e icigi ya̱ yi. 
\q2 U ta cana ishipa i ma̱za̱nga̱ nu ucira adama a̱ wu, 
\q2  
\v 18 ununa a tsu yuwan urana wa̱ a̱buki. 
\q1 N ta tawa ɗu a̱tsumola̱ngu 
\q2 waru ya̱a̱ da̱shi uwwa wono shi. 
\q1  
\v 19 Agba a mantsa'a n ta̱ ge'eto 
\q2 aza a na suru oo ɓongishi nɗu. 
\q1 N ta wawa a̱kutsuma̱ 
\q2 reve m ɓoloto aza a na e bete'wei. 
\q1 Oto o'wo ili yi ica waru a ca le tsugbain, 
\q2 a̱ ba̱ta̱ na suru a ca nle wono. 
\q1  
\v 20 A mantsa mo ndolo n to ɓoloto ɗu, 
\q2 n ka̱mba̱to ɗu o u'wa. 
\q1 N ta zuwa a ca ɗu tsugbain a̱vu i tsura̱ ica 
\q2 a̱tsuma̱ a ama o uvaɗi suru, 
\q1 a mantsa ma na n ka̱mbuwa̱a̱ nɗu 
\q2 nu utsuru u ɗu e esu a̱ ɗu. 
\q1 A̱mu A̱sulazuva a ɗa n dammai ne.>>