\id JOL - Cishingini Agwara Kambari [asg]
\toc3 Juw
\toc2 Juwelu
\toc1 Katagarda ka Juwelu
\mt1 KATAGARDA KA JUWELU
\mt1 Kuɓa̱yuwa̱
\is1 Ukuna u Katagarda ka nampa
\ip A̱ ciya̱ ili yi a̱bunda̱i a ukuna u keneki Juwelu ba. kpamu a̱ ciya̱ e yeve a makyan ma na u yongoi n wuma ba. Ama i ta̱ o cicoꞋo a ɗana ta̱ katagarda ka̱ ni ka a makyan ma̱ a̱ya̱ amangatawantawun (500) a kubana a̱ya̱ amangatawa̱na̱shi, (400) kafu a matsa Yesu (bc) a ayin a na iɗika i Fashiya yi o tsugono tsa aduniyan.
\ip Juwelu u yaꞋan ta̱ kene ka ukuna u ma̱dukpa̱ m akyun n kanbulu a uɓon u Falisadinu. A̱ ka̱tsuma̱ ki ili nampa we ene ta̱ urotu u kanna ka̱ kuta̱wa̱ ka Vuzavaguɗu, ayin a na Vuzavaguɗu u kutakacika aza a na a iwain kusheshe ka aza a usuɓi. Keneki ka ka dana ta̱ kusheshe ku Ka̱shile n kudana uma a̱ shika̱ unushi u le, n uzuwakpani u kulapulu n una̱singai adama uma a̱ ni. Ili i kindana i ɗaɗa uzuwukpani u na Ka̱shile ka yaꞋin u danai, wi ta̱ a̱ ku suku n ayinviki a ciɗa a̱ ubuta̱ u uma a̱ ni dem, ali n a̱ma̱ci olobo nu nkoshi dem derere. Ukuna u na wi punu u keci Ma̱dukpa̱ m akyun 1:1; 2:17 Uzuwukpani u kulapulusuka 2:18-27 Kanna ka Vuzavaguɗu 2:28; 3:21.
\c 1
\p 
\v 1 Vuzavaguɗu u yaꞋin kadanshi n Juwelu kolobo ka Petuwelyu.
\s1 Ma̱dukpa̱ ma akyun a iɗika
\q1 
\v 2 Panai kakuna ka nampa, a̱ɗa̱ nkoshi m gba̱ra̱-gba̱ra̱,
\q2 zuwai atsuvu a̱ ɗa̱, a̱ɗa̱ na yi punu ida̱shi a iɗika ya.
\q1 a saꞋwa ta̱ kuyaꞋan ili i tsu nampa a ayin a̱ ɗa̱?
\q2 Ko a ayin a ikaya i ɗa̱?
\q1 
\v 3 Tonukoi muku n ɗa̱ kaꞋa,
\q2 ka̱ta̱ muku n ɗa̱ feu o tonuko muku n le,
\q2 ka̱ta̱ muku ntsukaya n ɗa̱ o tonuko ntsukaya n na n kuta̱wa̱.
\q1 
\v 4 Ili i na ka̱kuma̱ ka̱ nta̱ɗa̱ma̱ci ka takumai ɗa i buwai,
\q2 akyun a gbagbaꞋin o kotso a takumai,
\q1 Ili i na akyun a gbagbaꞋin a takumai ɗa i buwai,
\q2 ka̱kuma̱ ka̱ nta̱ɗa̱ma̱ci n kenkeꞋen ko kotso ka takumai.
\q1 
\v 5 Jimgbai, a̱ɗa̱ na ma̱ra̱ ma makai, i shika̱,
\q2 lapai una̱, a̱ɗa̱ na yi osoꞋi a̱ ma̱ra̱,
\q1 lapai una̱ adama a unambi u ma̱kya̱n ma savu,
\q2 adama a na e pece ɗa̱ ta̱ n maꞋan.
\q1 
\v 6 Adama a na uma a̱ kpa̱ta̱ra̱ ta̱ iɗika i va̱,
\q2 uma a utsura a ɗa,
\q2 ka̱bunda̱i ke le ki kukece ba,
\q1 anga e le i ta̱ n alyu tsu anga a kawu,
\q1 
\v 7 A̱ la̱nga̱sa̱ ta̱ ashina a itacishi a̱ va̱,
\q2 ɗa a takumai nɗanga mu mbiri.
\q1 E sheꞋwei a̱vu e le ra̱ka̱,
\q2 a̱ ka̱sukpa̱i acaka e le wa̱ri.
\q1 
\v 8 Shika̱i tsu mekere,
\q2 ma na mi a̱ ma̱shi adama a ukpa̱ u kamana ka̱ ni.
\q1 
\v 9 Anan ganu a̱ na̱mgba̱i a̱tsuma̱,
\q2 adama a na babu kuneꞋe ki ishina n ki ili i kusoꞋo,
\q2 a kpaꞋa ku Vuzavaguɗu.
\q1 
\v 10 Ashina ra̱ka̱ okpo ta̱ a̱pula̱ka̱,
\q2 iɗika feu i ɗekpe ɗe,
\q1 Ishina i na̱mgba̱ ɗe,
\q2 ma̱kya̱n feu me ɗekpe ɗe,
\q2 babu kpamu maꞋin ma zaitu.
\q1 
\v 11 Na̱mgba̱i a̱tsuma̱ a̱ɗa̱ acimbi,
\q2 lapai una̱, a̱ɗa̱ acimbi ashina a itacishi,
\q1 na̱mgba̱i a̱tsuma̱ adama a itabi m bali,
\q2 adama a na a̱ la̱nga̱sa̱ ta̱ ili i kashina.
\q1 
\v 12 Ashina a itacishi a̱ ɗa̱ e ɗekpe ta̱ ra̱ka̱,
\q2 nɗanga mu mbiri n ɗa̱ n ɗekpe ta̱,
\q1 nɗanga n Ruman, nu nshuwa nu nɗanga n na m buwai
\q2 ra̱ka̱ n ɗekpe ta̱.
\q1 Mayun ma̱za̱nga̱ ma vuma vu lima̱ mo kotso ta̱.
\s1 Kushika̱ ku unushi n avasa
\q1 
\v 13 A̱ɗa̱ anan ganu a na yi a kuyaꞋan alyuka,
\q2 a katalikalyuka ka Vuzavaguɗu, ukai akashi a kpalu, i shika̱,
\q1 i uwa A̱Ꞌisa̱ a gbayin yi asa n akashi a kpalu a̱ ɗa̱,
\q1 adama a na babu ishina ko ma̱kya̱n,
\q2 ma na a kuyaꞋanka alyuka A̱Ꞌisa̱ a gbayin a̱ Ka̱shile ka̱ ɗa̱.
\q1 
\v 14 Salai kuyaꞋan kakuli,
\q2 yaꞋin koɓolo ka gbangam.
\q1 ɓolongi nkoshi m gba̱ra̱-gba̱ra̱ n uma a iɗika ya ra̱ka̱,
\q2 A̱Ꞌisa̱ a gbayin a Vuzavaguɗu Ka̱shile ka̱ ɗa̱,
\q1 i banka n ma̱shi ma̱ ɗa̱ u Vuzavaguɗu.
\q1 
\v 15 Ili ya atakaci ɗa a kanna ka nanlo.
\q2 Adama a na kanna ka Vuzavaguɗu ka yawa ta̱ ɗevu,
\q2 atakaci a ɗa a MalaꞋimili a̱ kuta̱wa̱.
\q1 
\v 16 A̱ a̱shi a̱ tsu ɗa a̱ la̱nga̱sa̱i tsu ilikulyaꞋa,
\q2 babu ma̱za̱nga̱ n kupana ku uyoꞋo,
\q2 a kpaꞋa ku Ka̱shile ka̱ tsu.
\q1 
\v 17 IcuꞋu i kuwa̱i adama a uɗekpu wi iɗika,
\q2 mpon n na̱mgba̱i, ɗa n fa̱da̱i.
\q1 adama a na babu ishina,
\q1 
\v 18 La̱na̱ tsu na anaka i a̱ yura̱.
\q2 Ushiga wa anaka u yangalai,
\q1 adama a na a̱ ciya̱ ijanu ba,
\q2 ushiga wu nlala feu atakaci.
\q1 
\v 19 Vuzavaguɗu, wa̱ a̱ nu u ɗa mi a̱ ma̱shi,
\q2 adama a na akina a lyaꞋa ta̱ ubuta̱ u kalina.
\q2 melentsu ma akina mo songu ta̱ nɗanga n kakamba ra̱ka̱.
\q1 
\v 20 Nnama n kakamba feu mi ta̱ a̱ ma̱shi wa̱ a̱ nu,
\q2 adama a na nyeneke n ɗekpe ta̱ ra̱ka̱.
\c 2
\s1 Ma̱dukpa̱ ma akyun tsu urotu u kanna ka Vuzavaguɗu
\q1 
\v 1 Lika̱i vugbala a Sihiyona,
\q2 i sala a kusan ku gbayin ku ciɗa ku va̱.
\q1 YaꞋan aza a na i a̱ ida̱shi a iɗika ya ra̱ka̱ e jeꞋeke ikyamba,
\q2 adama a na kanna ka Vuzavaguɗu ki ta̱ lo a̱ ku ta̱wa̱, ka yawa ta̱ ɗevu.
\q1 
\v 2 Kanna ka atakaci kaꞋa n ka̱yimbi,
\q2 kanna ke eleshu n ka̱yimbi ka kpaɓam.
\q1 tsu ka̱yimbi ke eleshu ka na ka palai nsansa,
\q2 ta ka̱bunda̱i ka akyun ka ki a̱ kuta̱wa̱ nannai,
\q1 ka na ka̱ta̱ a sawai ku ene ba,
\q2 kpamu o kudoku ku ene tsu nanlo ba,
\q2 ali ntsukaya n na n kuta̱wa̱.
\q1 
\v 3 A kutakuma vica̱Ꞌa̱ tsa akina,
\q1 E kelime ke le iɗika ya tsu kashina ka Adini,
\q2 a̱ ka̱ca̱pa̱ ke le iɗika ya tsu ka̱pula̱ka̱,
\q2 babu ili i na i kulaꞋaka ekiye e le.
\q1 
\v 4 I ta̱ n iyoci yi odoku,
\q2 a ilaɗi tsu odoku o kuvon.
\q1 
\v 5 Ci izumgbi yi ekeke odoku,
\q2 a ci ɗikpangi a gaɗi va a nsansa,
\q1 ci izumgbi i kakamba ka na ki a̱ kukula̱,
\q2 a na osoji a utsura ugeri adama o kuvon.
\q1 
\v 6 Uma ene le baci, e ci jeꞋeke ta̱ ikyamba,
\q2 a̱shi e le koli-koli.
\q1 
\v 7 A̱ tsu ta̱wa̱ ta̱ tsu ovonshi,
\q2 a kumba mashilya tsu osoji.
\q1 A tsu dasa ta̱ derere adaru-adaru,
\q2 a tsu kpatala ba.
\q1 
\v 8 Babu vuza na u tsu uwa uye u vutoku,
\q2 yaba dem o kutono kadaru ka̱ ni,
\q1 a tsu pasamgbanai ta̱ e mere ma irala,
\q2 kpamu i ku shamgbatangu ba.
\q1 
\v 9 A tsu bana ta̱ n o bonoi a̱ likuci,
\q2 a tsu suma ta̱ a gaɗi vu nshilya.
\q1 A tsu kumba ta̱ a uwa a iꞋuwa
\q2 a uwa atusu a iꞋuwa a na oboki.
\q1 
\v 10 E kelime ke le iɗika i tsu gba̱ɗa̱ ta̱,
\q2 ka̱ ta̱ gaɗi a̱da̱nga̱shile e jengeɗe,
\q1 kanna n wotoi okpoi ka̱yimbi,
\q2 azangata kpamu feu o doku e neke kutashi ba.
\q1 
\v 11 N ka̱la̱ka̱tsu ka utsura ɗa Vuzavaguɗu,
\q2 udanai osoji a̱ ni,
\q1 yiɗa̱i a ku gisangu n ka̱bunda̱i ko osoji a̱ ni,
\q2 osoji a na o tsu tono kadanshi ka̱ ni.
\q2 a laꞋa ta̱ kukece,
\q1 Kanna ka Vuzavaguɗu kagbayin kaꞋa,
\q2 kanna ko wovon ka̱u,
\q2 Yayi wa kufuɗa ku shamgba?
\s1 Uɗeki u kushika̱ unushi
\q1 
\v 12 Vuzavaguɗu u danai, <<Ko n nannai.>>
\q2 <<Bonoi wa̱ a̱ va̱ n a̱ɗu a̱ ɗa̱ ra̱ka̱,
\q1 n kakuli n ma̱shi n una̱mgbi u ka̱tsuma̱.
\q1 
\v 13 a̱ɗu a̱ ɗa̱ o yotsongu ushiki wu unushi u ɗa̱,
\q2 ba kukara ku ntogu n ɗa̱ koci ba.
\q1 I bono a̱ ubuta̱ u Vuzavaguɗu Ka̱shile ka̱ ɗa̱,
\q2 adama a na a̱yi vuza kasingai ɗa n asuvayali,
\q1 vuza na u ci yaꞋan wupa gogo ba,
\q2 kpamu vuza vu ucigi u na u tsu sabaꞋa ba,
\q2 ama u tsu ronono ta̱ a̱ ubuta̱ u kutuka̱ n ma̱dukpa̱.
\q1 
\v 14 yayi u yevei ko Vuzavaguɗu Ka̱shile ka̱ tsu,
\q2 wi ta̱ a kusabaꞋa kusheshe ku ni,
\q2 u zuwaka tsu una̱singai,
\q1 ali ci yaꞋan kuneꞋe ki ishina n ili i kusoꞋo?
\q1 
\v 15 Lika̱i vugbala a Sihiyona,
\q2 i sala kuyaꞋan kakuli.
\q1 yi erengu ka̱ci ka̱ ɗa̱,
\q2 ka̱ta̱ i yaꞋan koɓolo ka ciɗa.
\q1 
\v 16 I ɓolongu uma,
\q2 ka̱ta̱ yi erengu koɓolo ka u Vuzavaguɗu,
\q1 i ɓolongu nkoshi,
\q2 n muku nu nreɓu,
\q2 ali vali vu savu n vuka vu savu feu uta̱ a̱ kunu ku le, a̱ ta̱wa̱.
\q1 
\v 17 YaꞋan anan ganu a na i a kuyaꞋanka, Vuzavaguɗu u linga e mere ma katalikalyuka n kafalaka ka̱ A̱Ꞌisa̱ a gbayin, a̱ shika̱.
\q1 A dana, <<Vuzavaguɗu pana asuvayali a uma nu.
\q2 Ka̱ta̱ vu ka̱sukpa̱ uma a uka̱ni a̱ nu a yaꞋan wono ba,
\q2 ka̱ta̱ vu ka̱sukpa̱ uduniyan u yoku u lyaꞋaka le tsugono ba,
\q1 ali a dana,
\q2 <Teɗai Ka̱shile ka̱ ɗa̱ ki?> >>
\s1 Wushuki u Vuzavaguɗu
\q1 
\v 18 Ɗa Vuzavaguɗu u sa̱Ꞌa̱i iɗika i ni,
\q2 u panai asuvayali a uma ni.
\p 
\v 19 Vuzavaguɗu wushuki uma a̱ ni, u danai.
\q1 <<La̱na̱i, mi ta̱ a̱ kusuꞋuku ɗa̱ ishina m ma̱kya̱n n maniꞋin,
\q2 ali i yawa ɗa̱, yi o kudoku ko okpo ili i ma̱ka̱n
\q2 a̱ ubuta̱ u uma ba.
\q1 
\v 20 <<Mi ta̱ o kuloko akyun daꞋangi n a̱ɗa̱,
\q2 a na uta̱i uɓon u gaɗi a na a̱ tuka̱i ɗa̱ n kuvon,
\q2 mi ta̱ o kuloko le a kubana a kakamba ka na ki n vuza ba,
\q1 aza e kelime le a̱ yikpa̱ a Mala,
\q2 aza a na i o kutono le tamkpamu a̱ yikpa̱ a Mala me Mere.
\q1 ushami we even a ikyamba e le wi ta̱ a̱ kuɗa̱nga̱,
\q2 ushami u gbani-gbani u le wi ta̱ a̱ kuka̱ra̱Ꞌa̱ a̱ ubuta̱ dem.
\q2 adama a na mpa Vuzavaguɗu n yaꞋan ta̱ ili i mereve.
\q1 
\v 21 Ka̱ta̱ vu pana wovon ba, avu iɗika,
\q2 yaꞋan ma̱za̱nga̱ vu pana uyoꞋo,
\q1 adama a na Vuzavaguɗu ɗa u yaꞋin ili i gbayin i nanlo.
\q2 
\v 22 A̱ɗa̱ nnama n kakamba, ka̱ta̱ i pana wovon ba,
\q2 adama a na ijanu i topo ta̱.
\q1 Nɗanga kpamu feu n matsa ta̱,
\q2 nɗanga ma̱ mbiri n mi itacishi a matsa ta̱ mayin.
\q1 
\v 23 YaꞋin ma̱za̱nga̱, a̱ɗa̱ aza a Sihiyona,
\q2 i pana uyoꞋo nu mpa Vuzavaguɗu Ka̱shile ka̱ ɗa̱,
\q1 adama a na n yoꞋoko ɗa̱ ta̱ mini ma̱ ugiti,
\q2 ɗa kpamu n yoꞋoko yi ɗa̱ a makyan ma na ma untsai.
\q1 
\v 24 <<Ulanga u kulapu wi ta̱ a kushana tukpa n ishina,
\q2 Okotsu a gbagbaꞋin i ta̱ a kushana ali a ɓarakpa.
\q2 i ta̱ a kushana n ma̱kya̱n m maniꞋin ma zaitu.
\q1 
\v 25 Mi ta̱ o kubonoko ɗa̱ n ili i na akyun a takumai a̱ ka̱tsuma̱ ka̱ a̱ya̱ a nanlo,
\q2 akyun a gbagbaꞋin n e kenkeꞋen,
\q2 nu nta̱ɗa̱ma̱ci, ko ka̱kuma̱ ka akyun a na i yevei,
\q1 ɗaɗa osoji a utsura a na n suꞋuki ɗa̱.
\q1 
\v 26 <<Gogo na yi ta̱ a kulyaꞋa ilikulyaꞋa ali i cuwa̱,
\q2 ali i cikpa kula ku Vuzavaguɗu Ka̱shile ka̱ ɗa̱,
\q2 a̱yi na u yaꞋankai ɗa̱ ili i mereve,
\q1 kpamu i o kudoku kuneke uma a̱ va̱ wono ba.
\q1 
\v 27 A̱ɗa̱ uma a Isaraila talo ye kuyeve a na mpa mi ta̱ a̱ ka̱tsuma̱ ka̱ ɗa̱,
\q2 mpa ɗa Vuzavaguɗu Ka̱shile ka̱ ɗa̱,
\q2 babu vuza vu yoku, kpamu i o kudoku kuneke uma a̱ va̱ wono ba.
\s1 Kanna ka Vuzavaguɗu
\q1 
\v 28 <<Ayin a na baci ili nampa i kotsoi,
\q2 ka̱ta̱ n suꞋuku uma a̱ va̱ ra̱ka̱ n ayinviki a̱ va̱.
\q1 muku n ɗa̱ olobo nu nkere i ta̱ a kuyaꞋan kene,
\q2 nkoshi mi ta̱ a kuyaꞋan alatani,
\q2 muku mo olobo n ɗa̱ a yaꞋan kene tsa alatani.
\q1 
\v 29 Ali n agbashi a̱ ɗa̱ ali n a̱ma̱ci,
\q2 mi ta̱ a̱ kutsunku le ayinviki a̱ va̱ a kanna ka nanlo.
\q1 
\v 30 Ka̱ta̱ n yotsongu urotu wi ili i mereve, gaɗi n iɗika,
\q2 i ta̱ a̱ kutsuwa̱n mpasa n akina n ugbodoli u ka̱nga̱.
\q1 
\v 31 Kanna ki ta̱ o ko okpo ka̱yimbi,
\q2 wotoi tamkpamu wo okpo ushili tsu mpasa.
\q1 Kafu kanna ka Vuzavaguɗu ka nanlo ka̱ ta̱wa̱.
\v 32 Wi ta̱ o ko okpo vuza na baci dem u ɗekei,
\q2 kula ku Vuzavaguɗu wi ta̱ a̱ kuciya̱ wishi,
\q1 adama a na a kusan ku Sihiyona n Urushelima,
\q2 i ta̱ a kuciya̱ aza a na a kulaꞋaka,
\q2 tsu na mpa Vuzavaguɗu n danai,
\q1 a̱ ka̱tsuma̱ ka aza na a laꞋakai
\q2 i ta̱ a̱ kuciya̱ aza a na mpa Vuzavaguɗu n ɗekei.
\c 3
\s1 Vuzavaguɗu wi ta̱ a kuyaꞋanka uduniya afada
\q1 
\v 1 Vuzavaguɗu u danai, <<A ayin a nanlo,
\q2 mi ta̱ o kubonoko Yahuda n Urushelima n una̱singai u le,
\q1 
\v 2 Mi ta̱ o kuɓolongu uduniyan ra̱ka̱,
\q2 n tuka̱ le a̱ ka̱ra̱Ꞌa̱ ka Jehoshafatu.
\q1 Ta ɗe mi a kutakacika le adama a uma a̱ va̱,
\q2 adama a na a wacuwa ta̱ aza a Isaraila, ili yi uka̱ni i va̱.
\q1 ɗa kpamu e pecekushi iɗika i va̱.
\q1 
\v 3 A yaꞋain kazagba adama uma a̱ va̱,
\q2 e dengei muku mo olobo nu nkere okpoi agbashi,
\q1 adama a na a tsupaka ashakanlai n ma̱kya̱n.
\p 
\v 4 <<A̱ɗa̱ aza a Taya n aza a Sidon n uɓon Filisitiya, yiɗa̱i i cigai kuyaꞋanka mu? Yi ta̱ e kusheshe i tsupa ili i na n yaꞋankai ɗa̱? Ta baci nannai, gogo na mi ta̱ a ku kucikpa kubonoko kaꞋa a kaci ka̱ ɗa̱.
\v 5 Adama a na i pura̱ ta̱ azurufa n azanariya a na i ucanuku u singai u va̱ i bankai a̱ nva̱li ma̱ a̱ma̱li a̱ ɗa̱.
\v 6 Ɗa kpamu i pura̱i uma a̱ va̱ aza a Yahuda n aza a Urushelima, i denke yi aza e Helene, adama a na i banka le daꞋangi n iɗika i le.
\v 7 La̱na̱i, gogo na mpa mi ta̱ a kuzuwa le o bono a̱ ubuta̱ u na yi ishi i dengei le va, ka̱ta̱ n yaꞋanka ɗa̱ ili i na i yaꞋankai le.
\v 8 I ta̱ e kudenke aza a Yahuda muku n ɗa̱ olobo nu nkere, ka̱ta̱ e le tamkpamu e denke aza a Sabina, a̱ ubuta̱ wu mɓa̱ri a iɗika ya aza Arabiya, mpa Vuzavaguɗu n dansai.>>
\q1 
\v 9 Salai ukuna u nampa wa a̱ ka̱tsuma̱ ku uduniyan,
\q2 i dana, foɓusoi kuyaꞋan kuvon.
\q1 i ɗengusa̱ eyevi o kuvon,
\q2 i zuwa osoji a yawa ɗevu, a laza a kubana kuvon.
\q1 
\v 10 Lapai mba̱ri n vicimba n ɗa̱ mo okpo otokobi,
\q2 i bonoko muwun n vikyaꞋa n ɗa̱ nsara,
\q2 yaꞋan vuza babu utsura u dana,
\q1 <<Mpa vuza vu utsura ɗa.>>
\q1 
\v 11 Dakakai i ta̱wa̱, a̱ɗa̱ uduniyan u na yi uka̱ra̱Ꞌi n uma a̱ va̱,
\q2 i ɓolongu ɗe a̱ ka̱ra̱Ꞌa̱.
\q2 Vuzavaguɗu, zuwa osoji a̱ nu a gasa a̱ ubuta̱ wa.
\q1 
\v 12 <<YaꞋan uduniya u ɗa̱nga̱,
\q2 a̱ ka̱na̱ uye a kubana a̱ ka̱ra̱Ꞌa̱ ka afada ka Jehoshafatu,
\q1 adama a na ta ɗe n ku da̱sa̱ngu,
\q2 n yaꞋanka uduniyan u na wi uka̱ra̱Ꞌi n uma a̱ va̱ afada.
\q1 
\v 13 Ka gbani-gbani ke le ka yimkpa ta̱,
\q2 remei nkawun n ɗa̱ i kana le, tsu ishina i na i geꞋwei.
\q1 Ta̱wa̱i i dasa le, tsu na a tsu pisha ma̱kya̱n,
\q2 adama a na okotsu a kupisha ma̱kya̱n a shana,
\q2 ogbodo a gbagbaꞋin a shana a pasa.>>
\q1 
\v 14 Ka̱bunda̱i ka uma,
\q2 ki ta̱ punu a̱ ka̱ra̱Ꞌa̱ ka afada a̱ Ka̱shile,
\q1 adama a na kanna ka Vuzavaguɗu ka yawa ta̱ ɗevu,
\q2 a̱ ka̱ra̱Ꞌa̱ ka kukiɗa afada.
\q1 
\v 15 Kanna n wotoi i ta̱ o ko okpo ka̱yimbi,
\q2 azangata feu kpamu e kuneke kutashi ba.
\q1 
\v 16 Vuzavaguɗu wi ta̱ a kuyaꞋan yura̱ a Sihiyona,
\q2 wi ta̱ a̱ kuɗa̱ngusa̱ ka̱la̱ka̱tsu ka̱ ni a Urushelima,
\q2 gaɗi a̱da̱nga̱shile n iɗika yi ta̱ a̱ kugba̱ɗa̱.
\q1 Ama Vuzavaguɗu ɗa ubuta̱ u kusheɗeku u uma a̱ ni,
\q2 mashilya kpamu a uma a Isaraila.
\s1 Una̱singai adama a uma a̱ Ka̱shile.
\q1 
\v 17 <<Talo ye kuyeve a na mpa ɗa Vuzavaguɗu Ka̱shile ka̱ ɗa̱,
\q2 yi ta̱ e kuyeve a na mi a ida̱shi a Sihiyona,
\q2 kusan ku ciɗa ku va̱,
\q1 Urushelima wi ta̱ o okpo ciɗa,
\q2 babu kpamu irala i na i kudoku kuciya̱ ulyaꞋi wa̱ a̱ ni.
\q1 
\v 18 <<A kanna ka nanlo, nsansa mi ta̱ kushana n ma̱kya̱n,
\q2 ka̱ta̱ aginda tamkpamu a shana n mani ma anaka,
\q2 nyeneke ma aza a Yahuda ra̱ka̱ n shana n mini.
\q1 ka̱shi ka̱ mini ki ta̱ a̱ ku uta̱ ɗe a kpaꞋa ku Vuzavaguɗu,
\q2 ka̱ta̱ me neke ka̱ra̱Ꞌa̱ ka nɗanga n Akashiya kuta̱nu\f + \fr 3:18 \fq ka̱ra̱Ꞌa̱ ka nɗanga n Akashiya \ft Ka̱ra̱Ꞌa̱ ka nampa ka ɗaɗa feu e ci ɗeke Shitim. \f*.
\q1 
\v 19 <<Ama Masar wi ta̱ o ko okpo agali,
\q2 Edom tamkpamu wo okpo kakamba,
\q1 adama a ka gbani-gbani ka na a yaꞋankai aza a Yahuda,
\q2 a unai aza a babu unushi a iɗika i Yahuda.
\q1 
\v 20 Ama Yahuda wi ta̱ o ko okpo ubuta̱ wi ida̱shi i uma ayin dem
\q2 Urushelima tamkpamu a kubana a tsukaya dem
\q1 
\v 21 Mi ta̱ a kutsupa unushi u munuka ma aza a babu unushi,
\q2 mi a kucinukpa ka le u ɗa ba,
\q2 mpa Vuzavaguɗu mi ta̱ o kuyongo a Sihiyona.>>
