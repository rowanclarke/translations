\id 1TI - Fakai Translation
\h 1 Timoti
\toc1 Ran-u u̱r-Taku̱n u̱ Burus pane̱ Timoti
\toc2 1 Timoti
\toc3 1Tim
\mt2 Ran-u u̱r-Taku̱n u̱ Burus pane̱
\mt1 Timoti
\c 1
\s1 U̱s-vu̱k u̱du̱ Timoti
\p 
\v 1 Uno̱ ran-o̱ o̱o̱n du̱gu̱-du̱ ri, Burus. U-Ru̱ wu̱ u̱kre̱ in tu̱msu̱ Kiristi Ye̱so̱ ne̱ wu̱ in o̱o̱ge̱ wa-du̱ jab u̱du̱ wa, wa wa'ag me̱ u̱m shu̱'u̱t wa-to̱m-u̱ Kiristi Ye̱so̱.
\p 
\v 2 U̱m o̱ pan-du̱ uno̱ ran-o̱ m-ha u̱du̱ ró Timoti wu̱ o̱ u̱ka wa-u̱ u̱t-nip u̱ ri remu̱ u̱zu̱ tu̱msu̱ bo̱ yaag jab u̱-me̱ Kiristi. U̱m no̱ng u̱s-ko̱n u̱du̱ u-Ru̱ u-U̱so u̱ Kiristi Ye̱so̱ Wa-ko-uyan u̱ in, u̱zu̱ wa ya' bo̱ u-nya u̱ u̱r-o̱n u̱ ru̱s-du̱ jab ne̱.
\s1 U̱t-him u̱ mo̱t-tu̱ a-ko̱se̱-tu̱ u̱s-bi
\p 
\v 3 Da-u̱ u̱m o̱o̱ge̱ m-ha u̱ Makidoniya u̱m zu̱u̱g u̱zu̱ bo̱ shu̱'u̱t u̱-me̱ bo̱-u̱ Afisa remu̱ bo̱ no̱m-tu̱ to̱ko̱n ne̱t-to̱ u-har u̱ku̱n u̱zu̱ u̱n yage̱ ko̱se̱-tu̱ u̱s-bi.
\v 4 Tu̱msu̱ waru̱ u̱n u̱zu̱ u̱n yage̱ muut-u̱ jab-u̱s u̱n u̱du̱ u̱t-kwu̱r u̱ ogor-tu̱ u̱so-tu̱ u̱so-u̱t u̱n tu̱ za u̱r-ma. Go̱-du̱ rem-u̱s se̱ haatu̱n inan ko̱ o̱o̱g ba haatu̱n re̱-u̱ u-shu̱ ank-mu̱ u-Ru̱, u̱ na shu̱u̱se̱ remu̱ yadu̱ jab.
\v 5 Se̱di no̱m-u̱ u̱m u̱t-sa u̱ nak-du̱ u̱t-to̱ ri shu̱u̱s cwan-u̱t to̱, cwan-tu̱ rwu̱u̱ne̱ du̱gu̱ jab-u̱ u-he̱n tu̱msu̱ u̱ jab ne̱ u̱ nape̱ no̱m-u so̱-o̱ u̱ yo̱-o̱ ne̱ u̱ yadu̱ jab-u̱ u̱t-nip ne̱ u̱du̱ u-Ru̱.
\v 6 Se̱di e̱ke̱n ne̱t-ne̱ e̱nkte̱ du̱gu̱ no̱m-u̱t tun-to̱, tu̱msu̱ e̱ byu̱ru̱g u̱-kit u̱du̱ rem-su̱ m-zan.
\v 7 E̱ u̱t-sa e̱ shu̱'u̱t a-u̱t-ko̱se̱ tu̱ bo̱r-u̱t Mosa, se̱di e̱ nak no̱mu̱ e̱ o̱ u̱t-zu̱ ko̱ e̱ nak no̱m-u̱ e̱ o̱ u̱t-war za-u gye̱r-u̱ u̱r-be̱b ne̱ da.
\p 
\v 8 In nak u̱zu̱ bo̱r-yu̱ u-Ru̱ o̱ so̱-ya, se̱di se̱ ne̱t-tu̱ no̱ng ko̱se̱-tu̱ to̱ ho̱n-ho̱n.
\v 9 Tu̱msu̱ in nak u̱zu̱ na no̱mu̱g bo̱r-yu̱ u-Ru̱ remu̱ ne̱t-tu̱ o̱o̱ge̱ a-jabu̱ so̱-o̱ ne̱ da. Se̱di na no̱mo̱g to̱ remu̱ i pase̱ bo̱r-yu̱ u-Ru̱ tu̱msu̱ a-yu̱nsu̱ u̱s-jab ne̱, re̱mu̱ i gu̱gme̱ no̱m-du̱ no̱m-u̱ Ru̱-u̱ u̱t-sa tu̱msu̱ a-u̱t-ba'as-ne̱, remu̱ a-za u-he̱n ne̱ u̱ i yu̱te̱ u-Ru̱ m-ze̱g ne̱ da, remu̱ i ho̱ye̱ u̱so-u̱t e̱ u̱ ino-u̱t e̱ ne̱ u̱ i ho̱ye̱ u̱t-ne̱t ne̱,
\v 10 u̱ ne̱t-tu̱ i no̱me̱ m-o̱ ne̱, u̱ campa-ne̱ i rooge̱ u̱ campa-ne̱, u̱ ne̱ta-ne̱ i rooge̱ u̱ ne̱ta-ne̱, u̱ a-hyu̱-u du̱ u̱t-ne̱t ne̱, u̱ a-u̱s-bi ne̱, u̱ a pas-du̱ este̱du̱ u̱s-rem ne̱, u̱ i no̱me̱ o̱ko̱n no̱m-o̱ u̱ ko̱se̱-tu̱ u̱t-nip hose̱ u̱t-no̱m.
\v 11 Ko̱se̱-tu̱ u̱t-nip tun-to̱ eeste̱ u̱ rem-su̱ m-re̱me̱r ne̱ su̱ m-sek su̱ ware̱ mo̱t-tu̱ Ru̱-u̱ nu-u so̱-o̱. Sin-se̱ o̱o̱ge̱ remsu̱ m-re̱me̱r su̱ Ru̱-u̱ ya'u̱ me̱ no-mu̱ no̱m-du̱ bu̱t-tu̱ se̱.
\s1 Nya-u̱ Wa-ko-uyan ko̱se̱ Burus
\p 
\v 12 U̱m vam-u̱g Kiristi Ye̱so̱, Wa-ko-uyan in, wu̱ ya'u̱ me̱ u̱r-be̱b remu̱ wa kabu̱g me̱ u̱ka ne̱t wu̱ wa do̱'e̱ to̱stu̱ jab-u̱ wa u̱du̱ ri, da-u̱ wa dage̱ me̱ u̱m no̱m pama-u̱s wa.
\v 13 Ho̱to̱, u̱m o̱o̱g waru̱g no̱m-u̱t yo̱to̱ u̱ mo̱t-u̱t wu̱n ne̱. U̱m yaag ne̱t-u̱t wu̱n u̱r-ko̱b, tu̱msu̱ u̱m o̱o̱g yu̱nu̱s-du̱ u̱s-jab u̱du̱ ne̱t-u̱t wu̱n. Se̱di u̱m kwu̱mu̱g u̱r-o̱n rem u̱zu̱ u̱m no̱mo̱g u̱ ko̱b-du̱ m-nap tu̱msu̱ ko̱b-du̱ yadu̱ jab ne̱ u̱-me̱ Kiristi.
\v 14 Tu̱msu̱ Wa-ko-uyan da'u̱ste̱ nya-u wa u-tát u̱ do̱m-u̱ ri u̱ jab-u̱ so̱-o̱ ne̱ u̱ u̱t-cwan ne̱ remu̱ same̱-du̱ u̱t-hi ri u̱ Kiristi Ye̱so̱ ne̱.
\p 
\v 15 Sin-se̱ rem-se̱ nip-to̱ tu̱msu̱ yage̱ kowan kab se̱: Kiristi Ye̱so̱ haagu̱n u̱-me̱ u-dak remu̱ wa u̱ku̱rte̱ u̱t-ne̱t du̱gu̱ ba'as-u̱t e̱, tu̱msu̱ u̱-me̱ u̱n me̱ zege̱ u̱t-ba'as.
\v 16 M-ha iya ne̱, Kiristi Ye̱so̱ hog o̱n-u̱r ri, me̱ yu̱ ze̱ge̱ kowan u̱t-ba'as, u̱ remu̱ wa ko̱ste̱ u̱t-ne̱t gag-du̱ jab-u̱ wa u̱ za u̱t-ta. Wa cwan-u̱g u̱zu̱ no̱m-u̱ wa no̱me̱ remu̱ ri o̱ shu̱'u̱t m-sha u̱du̱ u̱t-ne̱t i do̱'e̱ ya-du̱ jab u̱du̱ wa, tu̱msu̱ e̱ kum fat-du̱ m-mo̱mmo̱.
\v 17 U̱ da-o̱ u̱du̱ faru̱k-u̱ za u̱r-ma, wu̱ zaare̱ m-mar da, wu̱ na hyu̱n-te̱ da, wu̱ o̱ u-Ru̱ u-gan kyak, m-ze̱g u̱ m-sek ne̱ shu̱'u̱t u̱du̱ wa m-mo̱mmo̱. U̱ shu̱'u̱t iya.
\s1 No̱m-u̱ Timoti de̱ u̱t-no̱m
\p 
\v 18 U̱m o̱ no̱mu̱ bo̱ tun-to̱ him-to̱, Timoti, wa-u̱ ri, u̱ka warru̱ no̱mu̱ do̱'e̱ u̱t-no̱m u-shu̱ su̱ na no̱me̱ u̱ mo̱t-u̱t ró ne̱ u̱r-taku̱n, u̱ remu̱ u̱zu̱ a-bo̱ do̱re̱ to̱ bo̱ u̱t-no̱m gag-m u̱ka wa m-gag so̱-wa remu̱ nip-tu̱ Rem-su̱ m-Re̱me̱r,
\v 19 bo̱ o̱ m-shu̱p u̱ yadu̱ jab-u̱ rò u̱r-zwar-ne̱, tu̱msu̱ u̱ jab ne̱ u̱ nape̱ no̱m-u so̱-o̱ u̱ yo̱-o̱ ne̱. E̱ke̱n ne̱t-ne̱ e̱ yakke̱ tun-to̱ tu̱msu̱ remu̱ iya e̱ shaktu̱sse̱ yadu̱ jab-u̱ e̱.
\v 20 Go̱-du̱ ne̱t-u̱t to̱ e̱ o̱ Himeniyus u̱ Are̱zanda. U̱m ya'aste̱ u̱n u̱ kom-tu̱ faru̱k-u̱ no̱m u̱s-te, remu̱ u̱zu̱ o̱ do̱'e̱ iis-u̱ u̱n yage̱-du̱ pyap-su̱ u-Ru̱ ne̱.
\c 2
\s1 U̱t-Him u̱ mo̱t-tu̱ u̱t-huuk
\p 
\v 1 U̱r-taku̱n, remu̱ iya, u̱m o̱ hyu̱m-du̱ no̱, no̱mo̱n u̱s-ko̱n u̱ remu̱ u̱t-ne̱t u̱t-be̱e̱t, u̱s-to̱o̱g ne̱, u̱t-vam ne̱,
\v 2 no̱mo̱n u̱s-to̱o̱g remu̱ u̱t-faru̱k u̱ i o̱ do̱m-u̱ u̱r-faru̱k ne̱ be̱e̱t. A in no̱me̱ iya in u̱t-no̱m u̱r-yu̱ m-yar tu̱msu̱ u̱ no̱m-du̱ no̱m-u̱ Ru̱-u̱ zu̱ye̱ in no̱m u-he̱n ne̱.
\v 3 Go̱-du̱ sin-se̱ to̱o̱g-se̱ otte̱ u̱r-zwar, tu̱msu̱ u-Ru̱ Wa-u-u̱ku̱r in hog zwarru̱ se̱ sok.
\v 4 Wa u̱t-sa u̱t-ne̱t u̱t-be̱e̱t u̱ kum u-u̱ku̱r du̱gu̱ ba'as-u̱t e̱ tu̱msu̱ e̱ nap rem-su̱ u̱t-nip su̱ mo̱t-tu̱ u-Ru̱.
\v 5 Remu̱ u̱zu̱ Ru̱-o̱ u-gan kyak. Tu̱msu̱ ne̱t o̱ró gan wu̱ eese̱ te̱k-u̱ u̱t-ne̱t u̱ u-Ru̱ ne̱. Ne̱t-u̱ wa na foge̱ Kiristi Ye̱so̱.
\v 6 Wa ya'aste̱ hi-u̱r wa remu̱ wa rwurut u̱t-ne̱t u̱t-be̱e̱t remu̱ e̱ kum-u̱t u-u̱ku̱r. Sin-se̱ o̱ rem-su̱ Ru̱-u̱ yase̱ u̱du̱ u-dak u-be̱e̱t ho̱n-ho̱n u̱ da-u̱ kame̱.
\v 7 O̱ wa'e̱ Ru̱-u̱ to̱mto̱n me̱ u̱ka wa-u̱t-bu̱t u̱ wa-to̱mu̱-u̱ Ye̱so̱ ne̱, u̱m no̱m ko̱se̱-tu̱ u̱t-nip su̱ rem-su̱ mo̱t-tu̱ ya-du̱ jab, u̱du̱ i za-Yahuda-ne̱. No̱m-u̱ u̱m o̱o̱ge̱ u̱t-war nip-to̱. A bise̱ u̱m o̱tte̱ da.
\p 
\v 8 Remu̱ iya, u̱m u̱t-sa campa-ne̱ be-du̱ e̱ mo̱ro̱gte̱, e̱ jaku̱s u̱t-kom tu̱ u-he̱n u̱du̱ u-Ru̱ da-u̱ e̱ o̱ u̱s-to̱o̱g, za namu̱ jab ne̱ ko̱ inan ne̱ da.
\v 9 Tu̱msu̱ iya u̱m u̱t-sa u̱ ne̱ta-ne̱ wa' cwu̱-tu̱ du̱pe̱. Ku̱mge̱ ne̱ta-ne̱ wa' cwu̱-tu̱ zaare̱ haatu̱n m-e̱' da tu̱msu̱ e̱ wa' cwu̱-tu̱ ko̱se̱ shu̱p-du̱ u̱r-hi, za u̱k-tu̱ u-ga ne̱ da, ko̱ kus-tu̱ bu̱-mu̱ u̱t-ro ko̱ ta'ar-tu̱ shik ko̱ kus-tu̱ shik sok,
\v 10 se̱di ne̱ta-ne̱ i o̱ m-gwat u̱zu̱ e̱ yaste̱ hi-u̱r e̱ u̱du̱ u-Ru̱ ku̱mge̱ e̱ muut hi-u̱t e̱ u̱ no̱m-du̱ no̱m-u̱t so̱-to̱.
\p 
\v 11 Yage̱ ne̱ta-ne̱ iis za no̱m-du̱ u̱r-shu̱t tu̱msu̱ u̱ yase̱ du̱ u̱r-hi ne̱ u-be̱e̱t.
\v 12 U̱m yaag ne̱ta u̱r-be̱b du̱ u̱t-ko̱se̱ da ko̱ e̱ no̱m u̱r-faru̱k du̱ campa-ne̱ da. Se̱di yage̱ e̱ ho̱ u̱s-ram.
\v 13 Remu̱ zu̱ Ru̱-u̱ no̱mo̱g Adamu u̱r-taku̱n kanda Hawa.
\p 
\v 14 Tu̱msu̱ Adamu wa faru̱k-u̱ no̱m u̱s-te e̱ngu̱sse̱ da. Se̱di ne̱ta wa, remu̱ u̱zu̱ wa na e̱ngu̱sse̱ wa shu̱'u̱t wa-u̱t-ba'as.
\v 15 Se̱di ne̱ta-ne̱ do̱'e̱ kwu̱m-du̱ u̱ku̱r u̱du̱ u̱r-mat du̱ yaag, abite̱ e̱ re̱e̱g u-shu̱ u̱ yadu̱ jab ne̱, u̱ u̱t-cwan ne̱, tu̱msu̱ u-he̱n ne̱, tu̱msu̱ u̱ shu̱p-du̱ u̱r-hi ne̱.
\c 3
\s1 U̱ka du̱pte̱ Yu̱-shu̱ A-dor-ne̱ Shu̱u̱t
\p 
\v 1 Rem-u̱s sin-se̱ nip-to̱ su̱ zu̱ye̱, a ne̱t-u̱ o̱ cwan-tu̱ wa shu̱'u̱t yu̱-shu̱ u̱-me̱ a-doru̱ Ye̱so̱ ne̱ wa o̱ cwan-tu̱ o̱g-u̱r so̱-de̱.
\v 2 Remu̱ iya, se̱ yu̱-shu̱ shu̱'u̱te̱ za u̱r-pyap, wa shu̱'u̱t campa ne̱ta gan, wa shu̱'u̱t u̱ shu̱p-du̱ u̱r-hi ne̱, wa shu̱'u̱t wa-u̱s-ve̱r, u̱ dim-u̱r so̱-de̱ ne̱. Tu̱msu̱ wa shu̱'u̱t wa-cwan-tu̱ u̱t-hamu̱t u̱ bu-u wa, tu̱msu̱ wa shu̱'u̱t wa kerru̱ u̱t-ko̱se̱.
\v 3 Tu̱msu̱ se̱ wa shu̱'u̱te̱ za wa swa-u̱ ke̱ u-tát da ko̱ wa cwan-tu̱ yu̱nu̱s-du̱ jab da. Se̱di se̱ wa shu̱'u̱te̱ ne̱t u̱r-ka, za wa u-har da, tu̱msu̱ za wa cwan-tu̱ shik da.
\v 4 Se̱ wa kerge̱ gargu̱ bu-u wa u̱r-zwar ne̱, tu̱msu̱ se̱ wa kerge̱ u̱t-wa yaag-u̱ wa ya' wa m-ze̱g tu̱msu̱ e̱ do̱r wa.
\v 5 Remu̱ zu̱ abite̱ ne̱t ke̱rge̱ gargu̱ bu-u wa da, re̱ne̱ o̱ wa do̱te̱ keru̱ gwat-du̱ a-doru̱ Ye̱so̱ ne̱?
\v 6 Tu̱msu̱ se̱ a wa shu̱'u̱t wa doru̱ po-wa da, remu̱ zu̱ wa kere̱ u̱t-shu̱'u̱t u̱ hu̱k-mu̱ u̱r-hi ne̱ tu̱msu̱ wa he̱ gandi kwu̱p-du̱ u̱s-rem u̱ka faru̱k-u̱ no̱m u̱s-te nomte̱.
\v 7 Yu̱-Yat-ya a-doru̱ Ye̱so̱ ne̱ se̱ tu̱msu̱ wa shu̱'u̱te̱ ne̱t wu̱ o̱tte̱ dim-u̱r so̱-de̱ u̱du̱ a-za-dor ne̱, taas wa he̱ u̱-me̱ no̱m-tu̱ m-e̱ da tu̱msu̱ u̱-me̱ re̱n-du̱ faru̱k-u̱ no̱m u̱s-te.
\p 
\v 8 Iya o̱ he̱n u̱s-diko̱n se̱ e̱ shu̱'u̱te̱ ne̱t-tu̱ ko̱re̱ ya-du̱ m-ze̱g, e̱ shu̱'u̱t ne̱t-tu̱ u̱t-nip. Tu̱msu̱ se̱ e̱ shu̱'u̱te̱ a-za swa-u̱ ke̱ ne̱ u-tát, tu̱msu̱ se̱ e̱ shu̱'u̱te̱ a-u̱t-nip-ne̱ u̱ mo̱t-tu̱ shik ne̱.
\v 9 Se̱ e̱ ship rem-su̱ u̱t-nip su̱ mo̱t-tu̱ yadu̱ jab-u̱ u̱r-zwar ne̱ tu̱msu̱ e̱ shu̱'u̱t u̱ jab ne̱ u̱ ko̱se̱ u̱zu̱ u̱n zatte̱ u̱t-ba'as da.
\v 10 Kanda na dag u̱n u̱s-diko̱n, yage̱ na re̱g u̱n sok. A-mu̱u̱ne̱ u̱zu̱ u̱n zatte̱ u̱r-pyap da, yage̱ e̱ no̱m m-ank u̱ka u̱s-diko̱n.
\p 
\v 11 Iya-o̱ he̱n tu̱msu̱ ne̱ta-u̱t u̱n se̱ e̱ shu̱'u̱te̱ ne̱t-tu̱ ko̱re̱ yadu̱ m-ze̱g, se̱di za a remsu̱ ha-mu̱ u̱r-no̱ ne̱ u̱ mo̱t-tu̱ o̱r-u̱t e̱ ne̱ da. Tu̱msu̱ e̱ shu̱'u̱t u̱ shu̱p-du̱ u̱r-hi ne̱ u̱ jab-u̱ so̱-o̱ ne̱ u̱-me̱ ko̱-uyan u̱ e̱ o̱ u̱t-no̱m.
\v 12 Se̱ diko̱n yu̱ shu̱'u̱t campa ne̱ta gan, tu̱msu̱ wa kere̱ gargu̱ ya'agu̱ wa u̱ bu-u wa ne̱ u̱r-zwar ne̱.
\v 13 Ne̱t-tu̱ o̱ u̱ no̱m-du̱ pama-u so̱-o̱ u̱ka u̱s-diko̱n e̱ do̱'e̱ kwu̱m-du̱ m-ze̱g du̱gu̱-du̱ e̱ke̱n tu̱msu̱ e̱ do̱'e̱ kwu̱m-du̱ swu̱r-mu̱ shiriktin-mu̱ jab u̱-me̱ yadu̱ jab-u̱ e̱ u̱-me̱ Kiristi Ye̱so̱.
\p 
\v 14 Ko̱ ba shu̱'u̱te̱ u̱zu̱ u̱m o̱ panu̱ no̱, u̱m cwang u̱zu̱ u̱m haan u̱m hyan no̱ za wa'as.
\v 15 Se̱di u̱m o̱ panu̱ no̱ remu̱ u̱zu̱, a-mu̱u̱ne̱ u̱zu̱ o̱ko̱n no̱m-o̱ naase̱ me̱ uda, no̱ shu̱'u̱t u̱ m-nap ne̱ u̱ka du̱pte̱ ne̱t-tu̱ dor-u̱t hi-u̱r e̱ u̱-me̱ bu-u̱ u-Ru̱. U̱m o̱ u̱s-rem u̱ mo̱t-tu̱ a-doru̱ Ye̱so̱ ne̱ u̱ Ru̱-u̱ u̱r-fat, u̱ o̱o̱ge̱ u̱r-kug tu̱msu̱ u̱r-tak du̱ u̱t-nip.
\p 
\v 16 Tu̱msu̱ in be̱e̱t in eeste̱ u̱zu̱, yu̱-u̱r so̱-de̱ in no̱m-tu̱ m-yasa to̱ tu̱-yat-to̱:
\q1 Ye̱so̱ haagu̱n u̱ war-u̱ ne̱t,
\q2 na ko̱ske̱ in u̱zu̱ wu̱na o̱ wa'u̱ u-Ru̱ u̱du̱ Yar-u̱ u-Ru̱.
\q1 A-to̱m u-Ru̱-ne̱ hyu̱n wu̱n,
\q2 a-doru̱ Ye̱so̱ no̱m do̱nse̱-u̱r wa u̱-me̱ u̱t-dak.
\q1 Ne̱t-tu̱ u-dak u-be̱e̱t e̱ yaag jab u̱ wu̱n ne̱,
\q2 Ru̱-u̱ ku̱b wu̱n u̱-do̱m u-ru̱, u̱-me̱ sek-m wa.
\c 4
\s1 Burus wargu̱ Timoti u̱ka no̱mu̱ // a-doru̱ Ye̱so̱ ne̱ u̱t-ko̱se̱
\p 
\v 1 Se̱di Yar-u̱ u-he̱n wargu̱ in u̱zu̱ u̱ ho̱-tu̱ m-vaste̱ e̱ke̱n do̱'e̱ yage̱-du̱ yadu̱ jab-u̱ u̱t-nip. E̱ do̱'e̱ do̱rru̱ ko̱se̱-tu̱ yar-tu̱ u̱t-e̱nk tu̱msu̱ u̱t-ko̱se̱ ne̱ tu̱ rwu̱ne̱ du̱gu̱ no̱m u̱s-te.
\v 2 Go̱-du̱ ko̱se̱-u̱t to̱ haan u̱du̱ ya ha-mu̱ u̱r-no̱ ne̱ u̱ u̱s-bi ne̱, i nap-mu̱ no̱m-u so̱-o̱ u̱ yo̱-o̱ ne̱ mu̱r-se̱.
\v 3 U̱n zu̱u̱g u̱zu̱ ku̱mge̱ na no̱m u̱r-gu̱ da tu̱msu̱ ana re̱ to̱ko̱n no̱m-tu̱ u̱t-re̱ to̱ da. Se̱di Ru̱-u̱ no̱ng no̱m-u̱ u̱t-re̱ remu̱ na re̱ u̱ te̱k-u̱ ya-du̱ u̱t-vam u̱du̱ i ya'e̱ jab tu̱msu̱ u̱du̱ i nape̱ u̱t-nip.
\v 4 Re̱mu̱ ko̱-uyan u̱ Ru̱-u̱ no̱me̱ u̱ so̱-o̱ o̱, tu̱msu̱ no̱m-u̱ na do̱'e̱ u̱t-gu̱gu̱m zaar da a-mu̱u̱ne̱ u̱zu̱ na kabu̱g to̱ u̱ ya-du̱ u̱t-vam ne̱.
\v 5 Re̱mu̱ zu̱ u̱du̱ to̱o̱g-u̱s in tu̱msu̱ rem-su̱ u-Ru̱ ne̱ na muute̱ to̱ u-he̱n ne̱.
\p 
\v 6 Abo̱ re̱ u-shu̱ u̱ rwu̱u̱tu̱n no̱m-u̱t to̱ m-zu̱n u̱du̱ o̱r-u̱t ró a-dor-ne̱, bo̱ do̱'e̱ shu̱'u̱t wa-warru̱ rem-u̱s Kiristi Ye̱so̱ wu̱ so̱-wa, tu̱msu̱ bo̱ u̱t-re̱ u-shu̱ u̱t-rogom ne̱ remu̱ rem-su̱ ya-du̱ jab u̱ ko̱se̱-u̱t so̱-to̱ ne̱ tu̱ bo̱ o̱o̱ge̱ u̱t-do̱r.
\v 7 Gu̱gme̱ ko̱se̱-u̱t to̱ tu̱ za tu̱ u̱t-nip da, tu̱msu̱ kwu̱r-tu̱ m-zan ne̱ tu̱ za u̱t-se̱ge̱ u̱t-ne̱t e̱ ya' u-Ru̱ m-ze̱g da. U̱ swas-mu̱ iya, iise̱ hi-u̱r ró bo̱ no̱m u̱r-yu̱ u̱ka Ru̱-u̱ o̱tte̱ u̱ssa bo̱ no̱m.
\p 
\v 8 Remu̱ iis-u̱ u-war o̱ u̱r-zwar ne̱, se̱di iis-u̱ no̱m-du̱ no̱m-u̱ Ru̱-u̱ u̱t-sa ze̱k u̱r-zwar. O̱ do̱'e̱ se̱gu̱ ne̱t u̱-me̱ dinde̱ yu̱-de̱ u̱ da-o̱ tu̱msu̱ m-mo̱mmo̱.
\p 
\v 9 No̱m-u̱ u̱m ware̱ rem-u̱s sin-se̱ nip-to̱, tu̱msu̱ se̱ ko̱rge̱ u̱t-kab u̱ u̱t-kom u̱t-yu̱r.
\v 10 O̱ wa'e̱ it o̱ no̱m-du̱ m-ank u̱s-hund ne̱ tu̱msu̱ re̱-u̱ u-shu̱ ne̱ remu̱ re̱-u̱ u̱r-ko̱rro̱ u̱ swadu̱ u̱r-ko̱b ne̱, re̱mu̱ zu̱ it wa'ag jab-u̱ it u̱du̱ u-Ru̱ u̱r-fat. Wa ko̱rge̱ u̱ku̱r du̱ u̱t-ne̱t u̱t-be̱e̱t, u̱ku̱r-u o̱ u̱t-ze̱g u̱r-zwar u̱du̱ i ya'e̱ jab u̱-me̱ wa be̱e̱t.
\p 
\v 11 Ko̱se̱ no̱m-u̱t to̱ tu̱msu̱ bo̱ waru̱ ko̱wan wa no̱m-to̱.
\v 12 A-bo̱ yage̱ waku̱n ju̱ru̱m bo̱ da remu̱ u̱zu̱ bo̱ o̱ wa'u̱ be̱b. Se̱di bo̱ shu̱'u̱t no̱m-u̱ u̱t-ko̱se̱ u̱du̱ a-dor-ne̱, u̱-me̱ rem-u̱s ró, u̱ yu̱-u̱r ró, u̱-me̱ cwan-u̱t ró, u̱-me̱ yadu̱ jab-u̱ ró tu̱msu̱ u̱-me̱ he̱n-u ró ne̱.
\v 13 Kanda u̱m haan u̱ku̱n, wa jab-u̱ karu̱nte̱ a-dor-ne̱ Ran-u̱ u-Ru̱, u̱t-bu̱t ne̱ tu̱msu̱ no̱mu̱ e̱ u̱t-ko̱se̱ ne̱.
\v 14 Taas bo̱ yage̱ nya-u̱ Yar-u̱ Ru̱-u̱ u̱ na ya'u̱ bo̱ u̱du̱ no̱m-u̱ a-warru̱ rem-su̱ u-Ru̱ ne̱ ware̱, da-u̱ ne̱nge̱n-tu̱ a-doru̱ Ye̱so̱ ne̱ do̱ru̱ bo̱ u̱t-kom.
\p 
\v 15 Wa' jab u̱-me̱ no̱m-u̱t to̱ u̱t-be̱e̱t. Yasu̱ hi-u̱r ró u̱r-be̱e̱t, u̱ remu̱ kowan do̱'e̱ hyan-du̱ re̱-u̱ u-shu̱ ró.
\v 16 Gwat hi-u̱r ró u̱r-zwar ne̱ u̱ka bo̱ o̱tte̱ u̱r-yu̱ tu̱msu̱ u̱ ko̱se̱-u̱t ró ne̱. Re̱ u-shu̱ u̱ no̱m-du̱ no̱m-u̱t to̱, remu̱ zu̱ bo̱ u̱ ne̱t-tu̱ o̱ ho̱g-du̱ bo̱ ne̱ do̱'e̱ kwu̱m-du̱ u-u̱ku̱r.
\c 5
\s1 U̱t-ko̱se̱ u̱ mo̱ttu̱ Bomos-ne̱, // u̱t-Ne̱nge̱n ne̱ tu̱msu̱ to̱k-ne̱
\p 
\v 1 A-bo̱ hagu̱sse̱ u-ne̱nge̱n da, se̱di no̱mu̱ wa u̱s-rem u̱ka u-u̱so. Gwat ya'ag-u̱ be̱b-ne̱ u̱ka o̱r-u̱t ró ne̱.
\v 2 Gwat u̱t-mang u̱ka ino-u̱t ró tu̱msu̱ ya'ag-u̱ ne̱ta-ne̱ u̱ka hu̱no-u̱t ró, u̱ jab u-he̱n ne̱.
\p 
\v 3 Gwatu̱n bomos-ne̱ i zatte̱ waku̱n wu̱ do̱'e̱ yadu̱ e̱ u̱r-se̱ge̱ da.
\v 4 Se̱di abite̱ bomos o̱tte̱ ya'ag ko̱ ya'agu̱ ya'agu̱ wa, no̱m-u̱ kame̱ e̱ no̱m u̱r-taku̱n e̱ iis u̱r-yu̱ u̱ka ya'ag u-Ru̱ u̱ bu-u̱t e̱, tu̱msu̱ e̱ to̱p i mate̱ e̱ u̱du̱ gwat-du̱ e̱. Re̱mu̱ zu̱ a e̱ no̱me̱ iya Ru̱-u̱ do̱'e̱ ho̱g-du̱ zwar-u̱r u̱n.
\p 
\v 5 Se̱di bomos wu̱ zatte̱ waku̱n wa se̱gu̱ wa da tu̱msu̱ wa o̱ war-wa, se̱ wa to̱ste̱ wadu̱ jab-u̱ wa u̱du̱ u-Ru̱. Tu̱msu̱ wa no̱m u̱s-to̱o̱g u-da u-be̱e̱t, m-gyu̱p u̱ u-ho̱ ne̱ wa o̱ u̱s-ko̱n remu̱ se̱ge̱-du̱ u-Ru̱.
\v 6 Se̱di bomos wu̱ o̱ yu̱du̱ remu̱ cwan-tu̱ ho̱g-du̱ u̱r-zwar remu̱ hi-u̱r wa, wa maru̱g u̱-me̱ u-Yar ko̱ ba wa o̱ u̱r-fat.
\v 7 Yase̱ u̱t-ne̱t bo̱r-u̱t tun-to̱, ko̱'e̱, remu̱ e̱ u̱t-shu̱'u̱t za u̱r-pyap.
\p 
\v 8 Se̱di a-mu̱u̱ne̱ u̱zu̱ waku̱n kerge̱ gwat-du̱ ko̱-u̱r wa da ko̱ ne̱t-tu̱ bu-u wa da, wa yakke̱ yadu̱ jab-u̱ wa u̱-me̱ Kiristi tu̱msu̱ go̱-du̱ ne̱t-u̱ wa ze̱k wa-za do̱r m-yo̱.
\p 
\v 9 Bomos wu̱ na pane̱ dim-u̱r wa, u̱-me̱ ran-u̱ bomos-ne̱, se̱ wa teeg u̱s-hak u̱t-shik u̱t-tu̱t, tu̱msu̱ wa o̱o̱g wa ya-du̱ jab u̱du̱ campa wa da-u̱ campa wa o̱o̱ge̱ u̱r-fat.
\v 10 Tu̱msu̱ se̱ wa o̱tte̱ dim-u̱r so̱-de̱ remu̱ no̱m-du̱ ank-m so̱mo̱, tu̱msu̱ wa no̱mgu̱ ya'agu̱ wa u̱t-him, tu̱msu̱ wa cu̱st-du̱ u̱t-hamu̱t, tu̱msu̱ wa no̱me̱-du̱ ne̱t-tu̱ u-Ru̱ u̱s-pama, tu̱msu̱ wa se̱ge̱ i o̱ swadu̱ u̱r-ko̱b, tu̱msu̱ wa ya'aste̱ hi-u̱r wa u̱ no̱m-du̱ no̱m-u̱t so̱-to̱ u̱t-go̱ u̱t-go̱ u̱t-be̱e̱t.
\p 
\v 11 Se̱di bomos-ne̱ i o̱mne̱ ya'ag, a no̱ wa dim-u̱t e̱ u̱-me̱ ran-u̱ bomos-ne̱ da. Remu̱ da-u̱ cwan-tu̱ war-u e̱ ru̱ye̱ yadu̱ hi-u̱r e̱ remu̱ Kiristi, e̱ do̱'e̱ u̱t-cwan e̱ no̱m u̱r-gu̱.
\v 12 A shu̱'u̱te̱ iya u̱n do̱'e̱ haatu̱n hi-u̱r u̱n kwu̱p-du̱ u̱s-rem remu̱ zu̱ u̱n paku̱s este̱du̱ u̱s-rem u̱n su̱ u̱r-taku̱n.
\v 13 Tu̱msu̱ a-mu̱u̱ne̱ u̱zu̱ no̱ wa'ag dim-u̱t e̱ u̱-me̱ ran-u̱ bomos-ne̱, u̱n do̱'e̱ iis-du̱ u̱r-shu̱'u̱t ro̱ggo̱ ne̱ tu̱msu̱ e̱ do̱'e̱ naasu̱ da-u e̱ u̱ cwaag u̱-me̱ u̱t-bu tu̱ u̱t-ne̱t u̱r-ba. Tu̱msu̱ u̱n zaar u̱t-shu̱'u̱t ro̱ggo̱ war-o̱ da, se̱di u̱n do̱'e̱ u̱t-shu̱'u̱t u̱ ha-mu̱ u̱r-no̱ u̱ cwaag u̱ no̱m-u̱ zaare̱ bu̱-m e̱ da tu̱msu̱ warru̱ no̱m-tu̱ kame̱ e̱ war da.
\v 14 Remu̱ iya, u̱m o̱ yadu̱ u̱s-rem u̱du̱ bomos-ne̱ i o̱mne̱ ya'agu̱ re̱k-e̱ u̱zu̱ e̱ sur m-no̱m u̱r-gu̱, e̱ mat ya'ag, tu̱msu̱ e̱ gwat bu-u̱t e̱, faru̱k-u̱ no̱m u̱s-te zaar u̱ kwu̱m-du̱ ke̱rru̱ zu̱du̱ o̱ko̱n no̱m-o̱ u̱ yo̱-o̱ u̱ u̱n ne̱ da.
\v 15 U̱m zu̱u̱g iya re̱mu̱ zu̱ e̱ke̱n bomos-ne̱ i o̱ ya'ag taag yage̱-du̱ do̱rru̱ Ye̱so̱ tu̱msu̱ e̱ o̱ do̱rru̱ faru̱k-u̱ no̱mu̱ u̱s-te u̱ da-o̱.
\p 
\v 16 Abite̱ waku̱n ne̱ta wa wu̱ o̱ wa-doru̱ Ye̱so̱ o̱tte̱ bomos-ne̱ u̱-me̱ bu-u wa, kamu̱g wa gwat e̱ tu̱msu̱ za wa sake̱ a-doru̱ Ye̱so̱ ne̱ m-no da. Se̱ a-doru̱ Ye̱so̱ ne̱ gwat bomos-ne̱ i zatte̱ waku̱n wu̱ do̱'e̱ se̱ge̱ u̱n da.
\p 
\v 17 U̱t-ne̱nge̱n i nome̱ m-ank u̱-me̱ mo̱ro̱g-du̱ a-dor-ne̱ u̱ka ku̱mte̱ e̱ ko̱rge̱ na ya' e̱ m-ze̱g, tu̱msu̱ na to̱p e̱, hadde i no̱me̱ m-ank sok u̱ same̱ u̱t-bu̱t ne̱ u̱ u̱t-ko̱se̱ ne̱.
\v 18 Remu̱ Ran-u̱ u-Ru̱ zu̱u̱g, <<A-bo̱ tage̱ nu-u go̱b-u u-na' da-u̱ wa o̱ rew-mu̱ hyu̱ da.>> Tu̱msu̱ u̱ de̱ku̱n be-de̱ o̱ zu̱u̱g, <<Ko̱wana no̱me̱ m-ank kamu̱g wa kum u-to̱p.>>
\p 
\v 19 A-bo̱ ees u̱ remsu̱ na ke̱te̱ u-ne̱nge̱n yu̱ a-doru̱ Ye̱so̱ da se̱ bo̱ kwu̱ng u̱s-ees u̱s-yu̱r ko̱ u̱s-tu̱t.
\v 20 A-mu̱u̱ne̱ ne̱nge̱n-yu̱ a-dor Ye̱so̱ no̱ng u̱t-ba'as, no̱mu̱ wa u̱t-him u̱-shu̱ a-doru̱ Ye̱so̱ ne̱, remu̱ to̱ko̱n ne̱nge̱n to̱ ho̱g gye̱r-u̱ u̱t-no̱m.
\v 21 U̱m o̱ u̱ hyu̱m-du̱ bo̱ u̱-shu̱ u-Ru̱ tu̱msu̱ u̱ Kiristi Ye̱so̱ ne̱ u̱ a-to̱m u-Ru̱ ne̱, bo̱ do̱r tunto̱ bo̱r-to̱ za ko̱se̱-du̱ m-ku̱u̱k tu̱msu̱ cwan-tu̱ u̱r-hi ne̱.
\v 22 Abo̱ no̱m ho̱r-mu̱ do̱ru̱ waku̱n u̱t-kom da, tu̱msu̱ a-bo̱ same̱ u̱t-hi u̱-me̱ ba'as-u̱t e̱ke̱n ne̱ da. Ship hi-u̱r ró u-he̱n ne̱.
\p 
\v 23 Yage̱ swadu̱ m-bu̱ u̱ war-mo̱, se̱di bo̱ swa ke̱ du̱gu̱ bu̱-mu̱ inabi cashi u̱ remu̱ re̱-mu̱ u̱t-me̱n ró tu̱msu̱ m-kwe̱t-kwe̱t-m ró ne̱.
\p 
\v 24 Bakse̱, ba'as-tu̱ to̱ko̱n ne̱t-to̱ to̱ o̱ m-zu̱n cas, tu̱msu̱ to̱ o̱ u̱ dor-tu̱ u̱n m-ha u̱du̱ kwu̱p-du̱ u̱s-rem. Se̱di e̱ke̱n o̱ro ba'as-u̱t e̱ zaar m-zu̱n da se̱ u̱ ane̱ u-shu̱.
\v 25 I ya-o̱ tu̱msu̱, ank-m so̱-mo̱ to̱ko̱n ne̱t-to̱ o̱ m-zu̱n cas. Tu̱msu̱ ank-m so̱-mo̱ tu̱ na no̱me̱ m-yasa to̱ do̱'e̱ u̱t-rwu̱u̱n de̱ku̱n ho̱-de̱ m-zu̱n.
\c 6
\p 
\v 1 To̱k-ne̱ be̱e̱t se̱ e̱ yaag u̱so-tu̱ bu-u̱t e̱ m-ze̱g. Uno̱ u̱t-hoos haatu̱n du̱ u̱s-pyap u̱ dim-du̱ u-Ru̱ u̱ ko̱se̱-tu̱ a-doru̱ Ye̱so̱ ne̱.
\v 2 Se̱di i o̱tte̱ u̱so-tu̱ u-bu i o̱ a-dor Ye̱so̱ ne̱ a e̱ ju̱ru̱m e̱ da remu̱ zu̱ e̱ o̱ a-doru̱ Ye̱so̱ ne̱. Se̱di yage̱ e̱ sur m-no̱mu̱ u̱n u̱s-pama u̱ka ku̱mte̱, remu̱ u̱zu̱ ank-m u̱n se̱gu̱ e̱ke̱n a-doru̱ Ye̱so̱ ne̱ i e̱ tone̱.
\s1 U̱t-him u̱ mo̱t-tu̱ Ko̱se̱-tu̱ u̱s-bi ne̱
\p 
\v 3 To̱ko̱n ne̱t-to̱ nom to̱ko̱n ko̱se̱-to̱ tu̱ o̱ bam du̱gu̱ ko̱se̱-tu̱ u̱m no̱mu̱ no̱ ne̱. Ko̱se̱-u̱t u̱n eeste̱ u̱ rem-su̱ u̱t-nip su̱ Wa-ko-uyan in Ye̱so̱ Kiristi da. Tu̱msu̱ u̱n ko̱ste̱ no̱m-tu̱ do̱'e̱ se̱ge̱ u̱t-ne̱t e̱ no̱m u̱r-yu̱ u̱ka Ru̱-u̱ o̱tte̱ u̱t-sa da.
\v 4 Go̱-du̱ ne̱t-u̱t to̱ o̱tte̱ hu̱k-mu̱ u̱r-hi, tu̱msu̱ u̱n nak o̱ko̱n da. Ne̱t-u̱t to̱ o̱tte̱ cwan-tu̱ inan u̱ mo̱t-tu̱ gom-tu̱ m-zan ne̱. Go̱-du̱ no̱m-u̱t to̱ haatu̱n u̱r-shu̱b, u̱ u-har ne̱, u̱s-pyap ne̱, u̱ dorog-u̱s yo̱-se̱ u̱ mo̱t-tu̱ e̱ke̱n ne̱.
\v 5 Go̱-du̱ ne̱t-u̱t to̱ haatu̱n namu̱ jab u-da u-be̱e̱t. Jab-u̱s u̱n natu̱sse̱, tu̱msu̱ u̱n yakke̱ do̱rru̱ u̱t-nip. U̱n dorog u̱zu̱ doru̱ u-Ru̱ o̱ fu̱n-yu̱ kwu̱m-du̱ shik.
\p 
\v 6 M-ha iya ne̱, do̱rru̱ u-Ru̱ u̱ ru̱s-du̱ jab-u̱ u̱ mo̱t-tu̱ no̱mu̱ bo̱ o̱tte̱ ne̱, swu̱r-mo̱ sok.
\v 7 Remu̱ zu̱ in haagu̱n u̱ o̱ko̱n ne̱ u̱ uno̱ dak-u̱ u-be̱e̱t o̱ da tu̱msu̱ iya in zaar u̱ kab-du̱ o̱ko̱n no̱m-o̱ m-rwu̱ da.
\v 8 Se̱di a in o̱tte̱ no̱m u̱t-re̱ tu̱msu̱ u̱ cwu̱-tu̱ u̱t-wa ne̱, to̱ ko̱rge̱ in.
\v 9 Se̱di ne̱t-ne̱ i u̱t-sa e̱ kum u̱t-kwu̱m, e̱ he̱ u̱-me̱ m-reg u̱ u̱r-re̱n ne̱ u̱ cwan-tu̱ no̱m-tu̱ m-rag ne̱ u-tát tu̱ u̱r-ho̱nse̱, m-te̱ m-sabre̱ tu̱msu̱ m-mar ne̱.
\v 10 Remu̱ cwan-tu̱ shik o̱ kug-du̱ go̱-du̱ no̱m-u̱t yo̱-to̱ u̱t-be̱e̱t. Tu̱msu̱ remu̱ cwan-tu̱ shik e̱ke̱n yakke̱ yadu̱ jab du̱ u̱t-nip, tu̱msu̱ e̱ naknu̱ hi-u̱r e̱ namu̱ jab u-tát.
\s1 Burus nak Timoti u̱t-to̱
\p 
\v 11 Se̱di bo̱ Timoti, bo̱ o̱ ne̱t u-Ru̱. Rem iya, so̱m m-ra du̱gu̱-du̱ no̱m-u̱t yo̱-to̱ tunto̱ u̱t-be̱e̱t. Tu̱msu̱ bo̱ do̱r fu̱n-yu̱ yu̱du̱ jab-u̱ so̱-o̱, u̱ no̱m-du̱ no̱m-tu̱ Ru̱-u̱ u̱t-sa ne̱, u̱ yadu̱ jab ne̱, u̱ u̱t-cwan ne̱ u̱ gag-du̱ jab ne̱, u jab-u̱ m-tor ne̱.
\v 12 Jumu̱n dum-m so̱-mo̱ mu̱ yadu̱ jab. Ship fat-du̱ m-mo̱mmo̱ du̱ Ru̱-u̱ fogte̱ bo̱ re̱mu̱ de̱, tu̱msu̱ rem-su̱ bo̱ ware̱ u̱-shu̱ u̱t-ne̱t u-tát.
\v 13 U̱m o̱ ko̱n-du̱ bo̱ u̱-shu̱ u-Ru̱ wu̱ yu̱'e̱ u̱r-fat u̱du̱ u̱t-no̱m u̱t-be̱e̱t tu̱msu̱ u-shu̱ Kiristi Ye̱so̱ wu̱ ware̱ u̱t-nip tu̱ mo̱t-tu̱ hi-u̱r wa ne̱ u̱-shu̱ Po̱ntus Biratus,
\v 14 u̱zu̱ bo̱ ship bo̱r-u inya u̱r-zwar ne̱, za u̱r-pyap m-te ho̱du̱ mu̱u̱n-u̱r Wa-ko-uyan in Ye̱so̱ Kiristi.
\v 15 Wa do̱'e̱ mu̱u̱n u̱ da-u̱ Ru̱-u̱ cine̱. Wu̱na o̱ wa nu-u so̱-o̱ tu̱msu̱ u-Ru̱ kyak, wu̱ ze̱ge̱ u̱t-faru̱k u̱t-be̱e̱t u̱r-be̱b tu̱msu̱ Wa-ko-uyan wu̱ zu̱ge̱ a-ko-uyan ne̱ be̱e̱t.
\v 16 Wa war-wa wa zaar m-mar da, tu̱msu̱ wa no̱m u̱r-yu̱ u-me̱ m-zu̱n mu̱ waku̱n zaar wu̱ de̱ kerru̱ te-du̱ wa da. Is-u̱ ne̱t tamu̱g hyan-du̱ wu̱n da, tu̱msu̱ wa zaar tame̱-du̱ hyan-du̱ wa da. M-ze̱g m-be̱e̱t u̱ u̱r-be̱b ne̱ u̱du̱ wa m-mo̱mmo̱! U̱ shu̱'u̱t iya.
\p 
\v 17 Nome̱ i o̱tte̱ u̱t-kwu̱m u̱ uno̱ dak-u̱ u-be̱e̱t o̱ u̱t-him a e̱ shu̱'u̱t hu̱k-mu̱ u̱r-hi da, tu̱msu̱ a e̱ wa' jab-u̱s e̱ u̱du̱ u̱t-kwu̱m tu̱ do̱'e̱ u̱t-natu̱sse̱ da. Se̱di se̱ u̱n wa'ag jab-u̱s u̱n u̱du̱ u-Ru̱, wu̱ yu̱'e̱ ko-uyan m-ho̱s remu̱ ho̱g-du̱ m-re̱me̱r in.
\v 18 Waru̱ u̱n u̱zu̱ u̱n wa' shik-u̱ u̱n u̱du̱ no̱m-du̱ no̱m-u̱t so̱-to̱. U̱n shu̱'u̱t a-u̱t-kwu̱m ne̱ u̱du̱ no̱m-du̱ ank-m so̱mo̱, tu̱msu̱ e̱ mo̱t no̱m-tu̱ e̱ o̱tte̱ m-ho̱s u̱du̱ i o̱o̱ge̱ u̱t-sa u̱r-se̱ge̱.
\v 19 A u̱n no̱me̱ iya u̱n o̱ no̱mu̱ hi-u̱r u̱n u̱r-cu̱n du̱ u̱t-kwu̱m tu̱ do̱'e̱ u̱t-shu̱'u̱t u̱r-tak du̱ u̱r-be̱b u̱ remu̱ u-shu̱, remu̱ zu̱ u̱n kum-u̱t u̱r-fat du̱ u̱t-nip.
\s1 Rem-su̱ m-vaste̱
\p 
\v 20 Timoti, ship no̱mu̱ na yase̱ bo̱ u̱r-zwar ne̱. Bir u̱-kit du̱gu̱ rem-su̱ m-zan u̱ i o̱o̱ge̱ gu̱g-mu̱ bo̱ ne̱ u̱ no̱m-u̱ e̱ o̱ u̱t-gwat u̱zu̱ nap-mo̱.
\v 21 To̱ko̱n ne̱t-to̱ hakte̱ u̱-kit du̱gu̱ yadu̱ jab e̱ tu̱msu̱ e̱ o̱ do̱rru̱ ko̱se̱-tu̱ u̱s-bi. Yage̱ nya u-Ru̱ shu̱'u̱t u̱r-ko̱t u̱ no̱ ne̱.
