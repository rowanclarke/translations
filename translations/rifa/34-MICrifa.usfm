\id MIC
\h مِيخَا 
\toc1 مِيخَا 
\toc2 مِيخَا 
\toc3 مِيخَا 
\mt1 مِيخَا  
\c 1
\s1 ڒْحُوكْمْ خْ سَامَارْيَا ذ ؤُرْشَالِيمْ  
\m
\v 1 أَوَاڒْ ن سِيذِي إِ د-يُوسِينْ غَارْ مِيخَا، أَمُورَاشْثِي، ذڭْ وُوسَّانْ ن يُوثَامْ ذ أَحَازْ ذ حِيزْقِييَا، إِجدْجِيذنْ ن يَاهُوذَا، \add أَوَاڒْ\add* إِ إِژْرَا خْ سَامَارْيَا ذ ؤُرْشَالِيمْ. \x ◘ \xo 1:‏1 \xt إِرْم. 26‏:‏18\x*   
\b  
\m
\v 2 ”سْڒمْ-د، مَارَّا كنِّيوْ، \add أَ\add* ڒڭْنُوسْ،  
\m إِڒِيمْ ثْفثْنمْ، \add أَ شمْ\add*، ثَامُّورْثْ  
\m ذ ؤُعمَّارْ نّسْ!  
\m سِيذِي إِنُو، سِيذِي،  
\m أَذْ يِيڒِي ذ أَشهَّاذْ خَاومْ،  
\m سِيذِي إِنُو زِي زَّاوشْثْ نّسْ إِقدّْسنْ. \x ◘ \xo 1:‏2 \xt أَعَوذ. 32‏:‏1؛ إِشا. 1‏:‏2\x*   
\m
\v 3 مَاغَارْ خْزَارمْ، سِيذِي إِفّغْ-د  
\m زڭْ ومْشَانْ نّسْ \add ن ثْزذِّيغْثْ\add*،  
\m ؤُ نتَّا أَذْ د-إِهْوَا  
\m ؤُ أَذْ إِصُورْفْ خْ ڒڭْعُوذِي ن ثمُّورْثْ. \x ◘ \xo 1:‏3 \xt أَعَوذ. 32‏:‏13؛ 33‏:‏29؛ إِزهد. 115‏:‏3؛ إِشا. 26‏:‏21، عَام. 4‏:‏13\x*   
\m
\v 4 إِذُورَارْ أَذْ فسْينْ سَاذُو نّسْ،  
\m ؤُ ثِيغْزُورِينْ أَذْ تّْوَابْضَانْثْ،  
\m أَمْ شّْمعْ زَّاثْ إِ وُوذمْ ن ثْمسِّي،  
\m أَمْ وَامَانْ نِّي د-إِتّْوَافَارّْغنْ  
\m زِي ثيْسَارْثْ. \x ◘ \xo 1:‏4 \xt ڒقض. 5‏:‏4؛ إِزهد. 18‏:‏8، 10؛ إِزهد. 68‏:‏3، 9؛ إِزهد. 97‏:‏5؛ عَام. 9‏:‏5\x*   
\m
\v 5 أَيَا مَارَّا \add إِتّمْسَارْ\add*  
\m زِي سِّيبّثْ ن ؤُخطُّو ن يَاعْقُوبْ،  
\m ؤُ زِي سِّيبّثْ ن دّْنُوبْ  
\m ن ثَادَّارْثْ ن إِسْرَائِيل.  
\m مِينْ إِدْجَانْ ذ خطُّو ن يَاعْقُوبْ؟  
\m مَا وَارْ \add إِدْجِي\add* ذ سَامَارْيَا؟  
\m ؤُ مِينْ دْجَانْ ذ ڒڭْعُوذِي ن يَاهُوذَا؟  
\m مَا وَارْ \add ثدْجِي\add* ذ ؤُرْشَالِيمْ؟   
\m
\v 6 نشّْ أَذْ أَرّغْ سَامَارْيَا  
\m ذ ڒْخَارْبثْ ذڭْ إِيَّارْ،  
\m ذ أَمَارْجعْ مَانِي غَا ژُّونْ ثَازَايَارْثْ،  
\m ؤُ نشّْ أَذْ نْضَارغْ إِژْرَا نّسْ ذِي ثغْزُورْثْ،  
\m ؤُ أَذْ عَارِّيغْ خْ ذْسُوسَا نّسْ.   
\m
\v 7 مَارَّا ڒخْيَاڒَاثْ نّسْ إِنقْشنْ  
\m أَذْ تّْوَاڒذْدْجنْثْ  
\m ؤُ مَارَّا ڒْمُونثْ نّسْ ن فَارْقْ-شّْغڒْ  
\m أَذْ ت سّْشمْضنْ س ثْمسِّي،  
\m ؤُ مَارَّا ڒخْيَاڒَاثْ نّسْ إِنقْشنْ  
\m أَذْ ثنْثْ أَردّْدْجغْ نشّْ،  
\m مَاغَارْ نتَّاثْ ثْيَاروْ إِ-ثنْثْ  
\m زِي ڒْمُونثْ ن فَارْقْ-شّْغڒْ،  
\m ؤُ نِيثنْثِي أَذْ د-ذوْڒنْثْ عَاوذْ  
\m ذْ ڒْمُونثْ ن فَارْقْ-شّْغڒْ.“   
\b  
\m  
\s1 أَشْضَانْ أَمقّْرَانْ ن مِيخَا  
\m
\v 8 ”خْ ؤُيَا أَذْ شضْنغْ ؤُ أَذْ وْثغْ أَڭجْذُورْ،  
\m أَذْ ؤُيُورغْ س ڒحْفَا ذ أَعَارْيَانْ،  
\m أَذْ سّْمِيعْوغْ أَمْ وُوشَّاننْ ن ڒخْڒَا،  
\m ؤُ أَذْ سْغُويغْ أَمْ يسِّيسْ ن نّْعَامثْ. \x ◘ \xo 1:‏8 \xt أَيُوبْ 30‏:‏29\x*   
\m
\v 9 مَاغَارْ إِيزِّيمنْ نّسْ نقّنْ،  
\m مَاغَارْ \add أَيَا\add* يُوسَا-د أَڒْ يَاهُوذَا،  
\m إِوسّعْ \add ڒْحُوكْمْ\add* أَڒْ ثِيوُّورَا ن ڒْڭنْسْ إِنُو،  
\m أَڒْ ؤُرْشَالِيمْ.   
\m
\v 10 وَارْ تّْبَارّْحمْ شَا مَانْ أَيَا ذِي جَاثْ،  
\m وَارْ ثتّْرُومْ، وَارْ خَاسْ نسِّيوِيڒْ.  
\m ذِي بَايْثْ-لِيئَافْرَا زُوزَّارغْ \add أَ\add*شَاڒْ  
\m خْ يِيخفْ إِنُو. \x ◘ \xo 1:‏10 \xt 2 صم. 1‏:‏20؛ إِرْم. 6‏:‏26\x*   
\m
\v 11 عْذُو، شمْ ثنِّي إِزدّْغنْ ذِي شَافِيرْ،  
\m ذ أَعَارْيَانْ ؤُ س ڒحْيَا.  
\m ثنِّي إِزدّْغنْ ذِي صَانَانْ وَارْ ثفِّيغْ شَا.  
\m ثَاغُويِّيثْ ن وشْضَانْ ن بَايْثْ-هَا-إِطْصِيلْ  
\m ثكّسْ زَّايْومْ أَبذِّي نّسْ أَكِيذْومْ. \x ◘ \xo 1:‏11 \xt إِشا. 47‏:‏3\x*   
\m
\v 12 مَاغَارْ ثنِّي إِزدّْغنْ ذِي مَارُوثْ،  
\m ثتّقْنُونُّويْ غَارْ مَارَّا ثِيغمُّورَا  
\m ذِي طّْوعْ ن ڒْخَارْ،  
\m \add مِينْزِي\add* أَقَا إِهْوَا-د ڒْغَارْ ن سِيذِي،  
\m أَڒْ ثَاوَّارْثْ ن ؤُرْشَالِيمْ. \f ◼ \fr 1:‏12 \ft \+bd ’مَارُوثْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَارْزُوڭِي‘.\f*  \x ◘ \xo 1:‏12 \xt عَام. 3‏:‏6\x*   
\m
\v 13 حزّْممْ إِيْسَانْ ن ثَازْڒَا زَّاثْ إِ ؤُكَارُّو،  
\m \add أَ شمْ\add*، ثنِّي إِزدّْغنْ ذِي لَاخِيشْ!  
\m نتَّاثْ ذ بطُّو ن دّنْبْ  
\m ن يدْجِيسْ ن صِيهْيُونْ،  
\m مَاغَارْ ذَايكْ تّْوَافنْ إِخطَّانْ ن إِسْرَائِيل.   
\m
\v 14 س ؤُيَا أوْشْ أَرِّيغَالُوثنْ ن ؤُمْسبْضِي  
\m إِ مُورَاشَاثْ-جَاثْ!  
\m ثُوذْرِينْ ن أَكْزِيبْ أَذْ ذوْڒنْثْ ذ ڒْغشّْ  
\m إِ إِجدْجِيذنْ ن إِسْرَائِيل.   
\m
\v 15 عَاوذْ نشّْ أَذْ أَمْ د-أَوْيغْ أَوْرِيثْ،  
\m \add أَ شمْ\add* ثنِّي إِزدّْغنْ ذِي مَارِيشَا!  
\m أَعُودْجِي ن إِسْرَائِيل أَذْ د-يَاسْ  
\m أَڒْ غَارْ عَاذُولَّامْ.   
\m
\v 16 أڭّْ إِخفْ نّمْ ذ ثَاقشَّارْثْ  
\m ؤُ حفّْ إِ إِخفْ نّمْ  
\m ذِي سِّيبّثْ ن إِحنْجِيرنْ نّمْ إِعِيزّنْ.  
\m أَرّْ ثَاقشَّارْثْ نّمْ ذ ثَامقّْرَانْثْ  
\m أَمشْنَاوْ أَڭِيذرْ،  
\m مِينْزِي تّْوَاوْينْ زَّايمْ  
\m غَارْ ثْمحْبَاسْثْ.“   
\b  
\b  
\m  
\c 2
\s1 إِعْڒَامنْ إِ إِسْرَائِيل ؤُ إِ ڒْحُوكَّامْ نّسْ  
\m
\v 1 ”ؤُشْثْ خْ يِينِّي إِتّْخمَّامنْ  
\m ذِي ڒْمُوعْصِييّثْ  
\m ؤُ \add خْ يِينِّي\add* إِتّْخمَّامنْ  
\m ذِي ڒْغَارْ ذِي قَامَاثْ نْسنْ.  
\m غَارْ ثُوفُّوثْ أَذْ ث ڭّنْ،  
\m مَاغَارْ أَفُوسْ نْسنْ  
\m \add ذَايسْ\add* أَطَّاسْ ن ثْزمَّارْ.   
\m
\v 2 نِيثْنِي مّژْڒنْ ذڭْ إِيَّارنْ  
\m ؤُشَا تّْكشّْضنْ ثنْ عَاوذْ،  
\m ؤُڒَا ذ ثُوذْرِينْ، ؤُشَا تّطّْفنْ ثنْثْ.  
\m أَمُّو إِ ڭِّينْ نِيثْنِي س ڒخْشُونثْ  
\m إِ ورْيَازْ ؤُ إِ ثَادَّارْثْ نّسْ،  
\m \add وَاهْ، إِ كُوڒْ\add* أَرْيَازْ ؤُ إِ ثسْغَارْثْ نّسْ.“ \x ◘ \xo 2:‏2 \xt إِشا. 5‏:‏8\x*   
\b  
\m
\v 3 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي:  
\m خْزَارْ، نشّْ ثْونِّيغْ إِجّْ ن ڒْغَارْ  
\m خْ ڒَادْجْ-أَ، إِ زِي وَارْ ثْزمَّارمْ  
\m أَذْ ثْجبْذمْ إِرَاونْ نْومْ،  
\m ؤُ \add إِ زِي\add* وَارْ ثْزمَّارنْ  
\m أَذْ ثُويُورمْ \add عَاذْ\add* س ؤُعفَّارْ،  
\m مَاغَارْ \add أَذْ ثِيڒِي\add* ذ إِشْثْ ن ڒْوقْثْ ثَاعفَّانْثْ.\x ◘ \xo 2:‏3 \xt عَام. 5‏:‏13\x*   
\m
\v 4 ذڭْ وَاسّْ نِّي أَذْ خَاومْ سّْڭعّْذنْ  
\m إِجّْ ن لْمَاثَالْ  
\m ؤُ أَذْغنّْجنْ إِجّْ ن يژْرِي ن وشْضَانْ  
\m أَمْ تّْشثْشَانْ،  
\m ؤُ أَذْ إِنِينْ: نشِّينْ نتّْوَاردّدْجْ قَاعْ!  
\m نتَّا يَارَّا ثَاسْغَارْثْ ن ڒْڭنْسْ إِنُو  
\m \add غَارْ ونّغْنِي.\add*  
\m مَامّشْ ت إِكْسِي زَّايِي؟  
\m نتَّا إِوْشَا إِيَّارنْ نّغْ  
\m إِ ونِّي د-إِفّْغنْ زڭْ وبْرِيذْ!   
\m
\v 5 س ؤُيَا وَارْ غَاركْ إِتِّيڒِي ؤُڒَا ذ إِجّنْ  
\m ونِّي إِ غَا إِنْضَارنْ أَفِيڒُو \add ن ڒقْيَاسْ\add*  
\m عْلَاحْسَابْ ثَاقدُّوحْثْ  
\m ذڭْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* ن سِيذِي.“ \x ◘ \xo 2:‏5 \xt أَعَوذ. 32‏:‏8، 9\x*   
\b  
\m
\v 6 ” ’وَارْ سُّوفُّوغمْ أَوَاڒْ  
\m \add أَمُّو\add* س ؤُكُوفُّو!‘،  
\m \add أَمُّو\add* إِ سَّاوَاڒنْ نِيثْنِي  
\m أَمْ سُّوفُّوغنْ كُوفُّو.  
\m ’خْ مَانْ أَيَا وَارْ زمَّارنْ نِيثْنِي  
\m أَذْ سُّوفّْغنْ أَوَاڒْ س ؤُكُوفُّو!‘  
\m \add أَمُّو\add* إِ غَا ثِيڒِي ڒفْضِيحثْ  
\m وَارْ ثتّْوَاكّسّْ! \x ◘ \xo 2:‏6 \xt إِشا. 30‏:‏10؛ عَام. 7‏:‏16\x*   
\m
\v 7 \add أَ كنِّيوْ،\add* ثَادَّارْثْ ن يَاعْقُوبْ،  
\m مَا إِزمَّارْ أَذْ إِتّْوَانَّا أَيَا؟  
\m ’مَا إِجَّا شَا أَرُّوحْ ن سِيذِي وَارْ ث إِڭِّي؟‘  
\m نِيغْ: ’مَا ثِينَا ذ ثِيمڭَّا نّسْ؟‘  
\m مَا وَارْ تّڭّنْ وَاوَاڒنْ إِنُو ڒْخَارْ  
\m إِ يِينِّي إِڭُّورنْ س ثْسڭْذَا؟   
\m
\v 8 \add مَاشَا عَاذْ\add* إِذنَّاضْ إِكَّارْ ڒْڭنْسْ إِنُو  
\m أَمْ يِيجّْ ن ڒعْذُو.  
\m ثْقڒْعمْ أَرُّوضْ ذ ؤُپَارْثسُّو  
\m زڭْ إِمْسبْرِيذنْ إِقفْڒنْ  
\m إِ وَارْ ت إِتّْرِيجِينْ،  
\m إِنِّي إِتّْعِيفّنْ ؤُمنْغِي.   
\m
\v 9 كنِّيوْ ثسُّوفُّوغمْ  
\m ثِيمْغَارِينْ ن ڒْڭنْسْ إِنُو  
\m زِي ثَادَّارْثْ نْسنْثْ إِعِيزّنْ.  
\m إِحنْجِيرنْ نّسْ ثكّْسمْ أَسنْ  
\m ثَالْوِيزْثْ إِنُو إِ ڒبْذَا.   
\m
\v 10 كَّارمْ ؤُ أَڭّْوجمْ،  
\m مِينْزِي وَا وَارْ إِدْجِي ذ أَمْشَانْ ن أَرَّاحثْ!  
\m مَاغَارْ أَقَا \add ثَامُّورْثْ\add* ثتّْوَاسّخْمجْ،  
\m أَذْ ثَاوِي أَردّدْجْ،  
\m \add وَاهْ\add* إِجّْ ن نّْعِي ن ؤُردّدْجْ.   
\m
\v 11 مَاڒَا شَا ن إِجّْ إِضفَّارْ أَسمِّيضْ،  
\m إِقَّارْ إِخَارِّيقنْ، \add ؤُشَا إِقَّارْ:\add*  
\m ’نشّْ أَذْ أَشْ سُّوفّْغغْ أَوَاڒنْ س ؤُكُوفُّو  
\m ذِي طّْوعْ ن بِينُو ذ شّْرَابْ!‘  
\m أَقَا نتَّا إِڭَّا  
\m \add أَخْمِي نتَّا ذ أَنَابِي\add* ن ڒْڭنْسْ  
\m نِّي إِسُّوفُّوغنْ أَوَاڒنْ س ؤُكُوفُّو.“   
\b  
\m
\v 12 ”س ثِيذتّْ، \add أَ\add* يَاعْقُوبْ،  
\m نشّْ أَذْ شكْ كْسِيغْ \add غَارِي\add* قَاعْ،  
\m نِيشَانْ نشّْ أَذْ سّْمُونغْ  
\m مِينْ إِقِّيمنْ زِي إِسْرَائِيل.  
\m أَذْ ثنْ سّْمُونغْ أَمْ وُودْجِي ن بُوصْرَا،  
\m أَمْ إِشْثْ ن ثْحِيمَارْثْ ذِي ڒْوسْطْ ن ثْركّْوَاسْثْ  
\m أَذْ ذِينْ يِيڒِي إِجّْ نْ  ؤُعُورِّيشْ ن إِوْذَانْ. \x ◘ \xo 2:‏12 \xt إِشا. 34‏:‏6؛ 63‏:‏1؛ إِرْم. 48‏:‏24؛ 49‏:‏13، 22، عَام. 1‏:‏12. \x*   
\m
\v 13 أَمْفدْجقْ أَذْ إِزْوَارْ زَّاثْ إِ وُوذمْ نْسنْ،  
\m نِيثْنِي أَذْ فدْجْقنْ ؤُ أَذْ عْذُونْ خْ ثوَّارْثْ،  
\m ؤُ أَذْ زَّايسْ د-فّْغنْ.  
\m أَجدْجِيذْ نْسنْ أَذْ إِزْوَارْ  
\m زَّاثْ إِ ؤُغمْبُوبْ نْسنْ،  
\m ؤُ سِيذِي غَارْ ؤُزدْجِيفْ نْسنْ.“   
\b  
\b  
\m  
\c 3
\s1 ڒْحُوكَّامْ ذ إِنَابِييّنْ ن إِسْرَائِيل تّْفشْڒنْ  
\m
\v 1 ”\add خنِّي\add* نِّيغْ نشّْ:  
\b  
\m ’سْڒمْ، \add أَ كنِّيوْ،\add* إِزدْجِيفنْ ن يَاعْقُوبْ،  
\m ؤُ \add كنِّيوْ\add*، ڒْحُوكَّامْ ن ثَادَّارْثْ ن إِسْرَائِيل!  
\m مَا وَارْ إِتّْخصِّي إِ كنِّيوْ  
\m أَذْ ثسّْنمْ ثَاسْغَارْثْ؟   
\m
\v 2 نِيثْنِي شَارّْهنْ مِينْ إِشْنَانْ  
\m ؤُ تّخْسنْ مِينْ إِدْجَانْ ذ أَعفَّانْ!  
\m نِيثْنِي كّْسنْ أَسنْ ثِيڒْمشْثْ  
\m ؤُڒَا ذ أَيْسُومْ خْ إِغْسَانْ نْسنْ.   
\m
\v 3 \add وَاهْ،\add* أَقَا أَثنْ ذ يِينِّي إِتّتّنْ  
\m أَيْسُومْ ن ڒْڭنْسْ إِنُو  
\m ؤُشَا كّْسنْ أَسنْ ثِيڒْمشْثْ  
\m ؤُشَا تَّارژَّانْ إِغْسَانْ نْسنْ.  
\m نِيثْنِي تّْبزَّاعنْ ثنْ أَمْ ذِي مَارْمِيثَا،  
\m أَمْ ويْسُومْ ذڭْ ؤُطنْجِيرْ.“   
\b  
\m
\v 4 ”ڒخْذنِّي أَذْ سْغُوينْ غَارْ سِيذِي،  
\m \add مَاشَا\add* وَارْ خَاسنْ د-إِتَّارِّي.  
\m أَذْ خَاسنْ إِفَّارْ ؤُذمْ نّسْ ذِي ڒْوقْثْ نِّي،  
\m زِي سِّيبّثْ ن ڒْغَارْ إِ إِڭِّينْ.“   
\b  
\m
\v 5 ”أَمُّو إِ إِقَّارْ سِيذِي إِ إِنَابِييّنْ  
\m إِنِّي إِتّْغَارَّانْ ڒْڭنْسْ إِنُو،  
\m إِنِّي ؤُمِي غَارْسنْ عَاذْ مِينْ ذِي  
\m إِ غَا إِزعْفنْ س ثغْمَاسْ نْسنْ،  
\m أَذْ ڒَاغَانْ ’ڒهْنَا!‘،  
\m \add مَاشَا\add* ضِيدّْ ن ونِّي وَارْ ذ أَسنْ إِتّڭّْ  
\m وَالُو ذڭْ ؤُقمُّومْ نْسنْ،  
\m أَذْ خَاسْ قدّْسنْ إِجّْ ن ؤُمنْغِي. \x ◘ \xo 3:‏5 \xt مِيخَا 2‏:‏11\x*   
\m
\v 6 س ؤُيَا أَذْ خَاومْ د-ثوْضَا دْجِيڒثْ،  
\m بْڒَا ڒوْحِييْ،  
\m ؤُ \add أَذْ\add* خَاومْ \add د-إِوْضَا\add* ثَادْجسْثْ  
\m بْڒَا ثَاڭزَّانْثْ.  
\m أَذْ ثغْڒِي ثْفُوشْثْ خْ إِنَابِييّنْ  
\m ؤُ أَذْ إِبَّارْشنْ وَاسّْ ثِيوَا نْسنْ. \x ◘ \xo 3:‏6 \xt إِرْم. 15‏:‏9؛ يُووِ. 2‏:‏10؛ عَام. 8‏:‏9\x*   
\m
\v 7 إِمْوَاڒَاونْ أَذْ سضْحَانْ،  
\m ؤُ إِڭزَّاننْ أَذْ ذوْڒنْ  
\m زوْغْونْ س ڒحْيَا،  
\m ؤُ نِيثْنِي مَارَّا أَذْ ڒحّْفنْ أَشْڒَاغمْ  
\m غَارْ ؤُينْشِيشْ،  
\m مِينْزِي ثْوَارِّيثْ ن أَربِّي  
\m وَارْ د-ثتِّيسْ شَا.   
\m
\v 8 مَاشَا نشّْ شُّورغْ س جّهْذْ  
\m ن أَرُّوحْ ن سِيذِي،  
\m ؤُ س ڒْحقّْ ذ ثرْيَاسْثْ،  
\m حِيمَا أَذْ بَارّْحغْ إِ يَاعْقُوبْ  
\m خْ ؤُخطُّو نّسْ  
\m ؤُ إِ إِسْرَائِيل خْ دّنْبْ نّسْ.“   
\b  
\m
\v 9 ”سْڒمْ خنِّي غَارْ مَانْ أَيَا،  
\m \add أَ\add* إِزدْجِيفنْ ن ثَادَّارْثْ ن يَاعْقُوبْ  
\m ؤُ كنِّيوْ إِمقّْرَاننْ  
\m ن ثَادَّارْثْ ن إِسْرَائِيل،  
\m إِنِّي إِشَارّْهنْ ڒْحقّْ،  
\m ؤُ سّْفَارَّاغنْ مَارَّا مِينْ إِدْجَانْ إِسڭّمْ، \x ◘ \xo 3:‏9 \xt عَام. 5‏:‏7؛ 6‏:‏12\x*   
\m
\v 10 إِنِّي إِبنَّانْ صِيهْيُونْ س إِذَامّنْ،  
\m ؤُ ؤُرْشَالِيمْ س ڒْغشّْ. \x ◘ \xo 3:‏10 \xt حِز. 22‏:‏27؛ صَاف. 3‏:‏3\x*   
\m
\v 11 إِزدْجِيفنْ نّسْ تّْضبَّارَانْ  
\m دّْعَاوِي إِ أَرّشْوثْ،  
\m إِكهَّاننْ نّسْ سّڒْمَاذنْ س ڒْمُونثْ،  
\m ؤُ إِكهَّاننْ نّسْ  
\m تّْڭزَّاننْ س ثْمنْيَاثْ.  
\m أَقَا نِيثْنِي تّْشَاڒنْ خْ سِيذِي خْمِي قَّارنْ:  
\m ’مَا وَارْ إِدْجِي سِيذِي ذِي ڒْوسْثْ نّغْ؟  
\m وَارْ ذ أَنغْ إِڒقّفْ ڒْغَارْ.‘   
\m
\v 12 س ؤُيَا، أَقَا-ت زَّايْومْ،  
\m أَقَا أَذْ شَارْزنْ صِيهْيُونْ أَمْ يِيجّْ ن ييَّارْ،  
\m أَذْ ثذْوڒْ \add ثنْذِينْثْ ن\add* ؤُرْشَالِيمْ  
\m ذ إِشْثْ نْ ڒْخَارْبثْ،  
\m ؤُ أَذْرَارْ ن ثَادَّارْثْ ذ ڒڭْعُوذِي ن وزْغَارْ.“ \f ◼ \fr 3:‏12 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  \x ◘ \xo 3:‏12 \xt مِيخَا 3‏:‏12\x*   
\b  
\b  
\m  
\c 4
\s1 ثَاڭلْذِيثْ إِ د غَا يَاسنْ زِي صِيهْيُونْ  
\m
\v 1 ”ذڭْ ؤُنڭَّارْ ن وُوسَّانْ أَذْ إِمْسَارْ،  
\m أَقَا أَذْرَارْ ن ثَادَّارْثْ ن سِيذِي  
\m أَذْ إِبدّْ إِمْثنْ  
\m خْ ثْقِيشّثْ ن إِذُورَارْ.  
\m أَذْ يِيڒِي يُوعْڒَا خْ ثوْرِيرِينْ،  
\m ؤُشَا ڒڭْنُوسْ أَذْ غَارسْ د-أَزّْڒنْ. \x ◘ \xo 4:‏1 \xt إِشا. 2‏:‏2‏-‏5\x*   
\m
\v 2 أَطَّاسْ ن ڒڭْنُوسْ أَذْ ڭعّْذنْ، أَذْ إِنِينْ:  
\m ”جّمْ أَنغْ أَذْ نْڭعّذْ  
\m غَارْ وذْرَارْ ن سِيذِي  
\m ؤُ غَارْ ثَادَّارْثْ ن أَربِّي ن يَاعْقُوبْ،  
\m حِيمَا أَذْ أَنغْ إِسّڒْمذْ  
\m زڭْ إِبْرِيذنْ نّسْ،  
\m أَذْ نُويُورْ نشِّينْ ذڭْ إِمسْرَاقْ نّسْ،  
\m مِينْزِي زِي صِيهْيُونْ أَذْ د-ثفّغْ شَّارِيعَا  
\m ؤُ أَوَاڒْ ن سِيذِي زِي ؤُرْشَالِيمْ.   
\m
\v 3 نتَّا أَذْ إِشَارّعْ جَارْ ڒڭْنُوسْ إِمْغَارنْ  
\m ؤُ أَذْ إِسڭّمْ ڒڭْنُوسْ  
\m نِّي غَارْ إِدْجَا ثِيزمَّارْ ثِيمقّْرَانِينْ،  
\m عَاذْ ؤُڒَا ذ \add ڒڭْنُوسْ\add* إِڭّْوجنْ.  
\m نِيثْنِي أَذْ ڭّنْ ڒسْيُوفْ نْسنْ ذ دُّوزَانْ  
\m ؤُ فْڒِيثْشَاثْ نْسنْ ذ ڒمْوَاسْ ن وزْبَارْ.  
\m وَارْ إِسّْڭِيعِّيذْ ؤُڒَا ذ إِجّْ ن ڒْڭنْسْ  
\m عَاذْ سِّيفْ خْ ونّغْنِي،  
\m ؤُ نِيثْنِي وَارْ ڒمّْذنْ \add عَاذْ\add* أَمنْغِي.   
\m
\v 4 نِيثْنِي أَذْ قِّيمنْ،  
\m كُوڒْ إِجّْ سَاذُو ثْزَايَارْثْ نّسْ  
\m ؤُ سَاذُو وَارْثُو ن ثَازَارْثْ نّسْ،  
\m ؤُشَا ؤُڒَا ذ إِجّنْ أَذْ \add ثنْ\add* إِسّْنخْڒعْ،  
\m مَاغَارْ أَقمُّومْ ن سِيذِي ن ڒْعسْكَارَاثْ  
\m أَقَا إِنَّا ث.“ \x ◘ \xo 4:‏4 \xt 1 إِج. 5‏:‏5، زَاك. 3‏:‏10\x*   
\b  
\m
\v 5 ”مِينْزِي مَارَّا ڒڭْنُوسْ أَذْ ؤُيُورنْ،  
\m كُوڒْ إِجّْ \add زَّايْسنْ\add* ذڭْ يِيسمْ ن أَربِّي نّسْ،  
\m مَاشَا نشِّينْ أَذْ نُويُورْ ذڭْ يِيسمْ ن سِيذِي،  
\m أَربِّي نّغْ،  
\m إِ ڒبْذَا قَاعْ.“   
\b  
\m  
\s1 سِيذِي أَذْ إِسّنْجمْ صِيهْيُونْ  
\m
\v 6 ”ذڭْ وَاسّْ نِّي، إِقَّارْ سِيذِي،  
\m نشّْ أَذْ يَارْوغْ مِينْ إِقجْذْحنْ،  
\m ؤُ أَذْ \add غَارِي\add* سّْمُونغْ مِينْ خْ ؤُزّْڒنْ،  
\m ؤُ وِي ذِي ڭِّيغْ نشّْ ڒْغَارْ. \x ◘ \xo 4:‏6 \xt أَعَوذ. 30‏:‏3، 4، 5\x*   
\m
\v 7 مِينْ إِقجْذْحنْ أَذْ ث ڭّغْ ذ ڒْبَاقِي،  
\m ؤُڒَا مِينْ إِتّْوَاعَارّْننْ غَارْ ڒَاڭّْوَاجْ،  
\m \add أَذْ ث ڭّغْ\add* ذ إِجّْ ن ڒْڭنْسْ  
\m س ثْزمَّارْ ذ ثَامقّْرَانْثْ،  
\m ؤُشَا سِيذِي أَذْ خَاسنْ يِيڒِي ذ أَجدْجِيذْ  
\m خْ وذْرَارْ ن صِيهْيُونْ،  
\m زِي ڒخُّو أَڒْ ڒبْذَا. \x ◘ \xo 4:‏7 \xt دَان. 7‏:‏14؛ صَاف. 3‏:‏19؛ لك. 1‏:‏33\x*   
\m
\v 8 إِ شمْ، مِيڭْذَالْ-عِيذْرْ،  
\m \add أَ شمْ،\add* ثَاوْرِيرْثْ ن يدْجِيسْ ن صِيهْيُونْ!  
\m أَذْ غَارمْ د-ثَاسْ،  
\m \add وَاهْ،\add* أَذْ \add غَارمْ\add* د-ثَاسْ ڒحْكَامثْ  
\m ثنِّي \add إِ ثُوغَا إِدْجَانْ\add* ذڭْ ؤُمزْوَارُو،  
\m ثَاڭلْذِيثْ ن يدْجِيسْ ن ؤُرْشَالِيمْ.“   
\b  
\m
\v 9 ”ڒخُّو \add مَاشَا\add*،  
\m مَايمِّي ثسْغُويُّوذْ \add أَمُّو\add* س جّهْذْ؟  
\m مَا وَارْ غَارمْ إِدْجِي ؤُجدْجِيذْ؟  
\m مَا إِتّْوَاهلّكْ ؤُمْشَاوَارْ نّمْ،  
\m أَقَا إِطّفْ إِ شمْ ڒحْرِيقْ  
\m أَمْ ن يِيشْثْ ن ثمْغَارْثْ إِتَّارْونْ؟ \x ◘ \xo 4:‏9 \xt إِرْم. 8‏:‏19\x*   
\m
\v 10 غْنسْ ؤُ ثْعبّْزذْ،  
\m \add أَ شمْ،\add* يدْجِيسْ ن صِيهْيُونْ،  
\m أَمْ إِشْثْ ن ثمْغَارْثْ إِتَّارْونْ.  
\m مَاغَارْ \add وَاخَّا\add* ڒخُّو  
\m أَذْ ثفّْغذْ زِي ثنْذِينْثْ،  
\m أَذْ ثْزذْغذْ ذڭْ إِيَّارْ،  
\m ؤُشَا أَذْ د-ثَاسذْ أَڒْ بَابِيلْ.  
\m \add مَاشَا\add* ذِينْ أَذْ ثْنجْمذْ،  
\m ذِينِّي أَذْ شمْ إِفكّْ سِيذِي  
\m زڭْ ؤُفُوسْ ن ڒْعذْيَانْ نّمْ.“   
\b  
\m
\v 11 ڒخُّو \add مَاشَا\add* مُوننْ خَاكْ  
\m أَطَّاسْ نْ ڒڭْنُوسْ.  
\m نِيثْنِي قَّارنْ: ’نتَّاثْ أَذْ ثتّْوَاعَارَّا!‘  
\m ثِيطَّاوِينْ نّغْ أَذْ ژَترنْثْ صِيهْيُونْ.   
\m
\v 12 نِيثْنِي وَارْ سِّيننْ إِنْوَاينْ ن سِيذِي،  
\m ؤُ وَارْ فهّْمنْ شَا شّْوَارْ نّسْ!  
\m مَاغَارْ نتَّا إِكْسِي ثنْ \add غَارسْ\add*  
\m أَمْ ثْقبِّيضِينْ ن إِمنْذِي ذڭْ ؤُنذْرَارْ.“ \x ◘ \xo 4:‏12 \xt إِرْم. 51‏:‏33\x*   
\b  
\m
\v 13 ”كَّارْ، ثسَّاروْثذْ،  
\m \add أَ شمْ،\add* يدْجِيسْ ن صِيهْيُونْ،  
\m مَاغَارْ نشّْ أَذْ أَرّغْ  
\m يِيشّْ نّمْ ذ ؤُزَّاڒْ،  
\m ؤُ أَذْ أَمْ ڭّغْ ثِيشضْيِينْ نّمْ زِي نّْحَاسْ،  
\m ؤُ شمْ أَذْ ثْڒبْزذْ أَطَّاسْ ن ڒڭْنُوسْ  
\m ؤُ نشّْ أَذْ حَارّْمغْ  
\m ثَاكشَّاضْثْ نْسنْ مَارَّا إِ سِيذِي،  
\m ؤُڒَا ذ أَڭْڒَا نْسنْ إِ سِيذِي ن مَارَّا ثَامُّورْثْ. \x ◘ \xo 4:‏13 \xt زَاك. 4‏:‏14؛ 6‏:‏5\x*   
\m
\v 14 \add خنِّي\add* ڒخُّو، ڒحْممْ  
\m إِجّنْ غَارْ ونّغْنِي،  
\m \add أَ شمْ\add* يدْجِيسْ  
\m ن إِشْثْ ن بَانْذِييَّا \add ن إِخوَّاننْ\add*!  
\m نتَّا إِحصَّارْ أَنغْ.  
\m نِيثْنِي أَذْ شَّاثنْ ڒْقَاضِي ن إِسْرَائِيل  
\m خْ ؤُقَابْسِي س إِجّْ ن وعْمُوذْ.“   
\b  
\b  
\m  
\c 5
\s1 ڒْحَاكمْ إِ د غَا يَاسنْ زِي بَايْثْ-لَاهْمْ  
\m
\v 1 ”ؤُ شكْ، بَايْثْ-لَاحْمْ إِفْرَاثَا،  
\m \add وَاخَّا\add* شكْ ذ أَمژْيَانْ  
\m أَڒَامِي \add وَارْ ثْزمَّارذْ\add*  
\m أَذْ ثِيڒِيذْ جَارْ ڒُوڒُوفْ ن يَاهُوذَا،  
\m أَقَا زَّايكْ إِ د غَا إِفّغْ نتَّا إِ نشّْ،  
\m مَاحنْذْ أَذْ يِيڒِي ذ ڒْحَاكمْ خْ إِسْرَائِيل.  
\m أَبَانِي نّسْ أَقَا-ث زِي مشْحَاڒْ ؤُيَا،  
\m زڭْ وُوسَّانْ ن ڒبْذَا. \x ◘ \xo 5:‏1 \xt مت. 2‏:‏6؛ يُوح. 7‏:‏42\x*   
\m
\v 2 س ؤُيَا نتَّا أَذْ ثنْ إِسلّمْ  
\m أَڒْ ڒْوقْثْ نِّي،  
\m أَقَا ثنِّي إِ غَا يَارْونْ، أَقَا ثُورُووْ-د.  
\m خنِّي أَذْ د-إِذْوڒْ ڒْبَاقِي ن يَايْثْمَاسْ،  
\m \add جْمِيعْ\add* أَكْ-ذ أَيْثْ ن إِسْرَائِيل.   
\m
\v 3 نتَّا أَذْ إِبدّْ \add ذِينِّي\add*  
\m ؤُشَا أَذْ يَارْوسْ ذِي جّهْذْ ن سِيذِي،  
\m ذِي ڒُوعْڒَا ن يِيسمْ ن سِيذِي، أَربِّي نّسْ.  
\m نِيثْنِي أَذْ زذْغنْ \add ذِينِّي\add*،  
\m مَاغَارْ نتَّا أَذْ يِيڒِي ذ أَمقّْرَانْ  
\m أَڒْ إِنڭُّورَا ن ثمُّورْثْ. \f ◼ \fr 5:‏3 \ft \+bd ’أَڒْ إِنڭُّورَا ن ثمُّورْثْ‘\+bd* - إِخْسْ أَذْ يِينِي ’أَڒْ إِنڭُّورَا ن دُّونشْثْ‘.\f*   
\m
\v 4 وَانِيثَا أَذْ يِيڒِي ذ ڒهْنَا.“  
\b  
\m ”خْمِي د غَا يَاسْ أَشُّورْ غَارْ ثمُّورْثْ نّغْ،  
\m ؤُ خْمِي د غَا يَاذفْ غَارْ ڒقْصُورْ نّغْ،  
\m خنِّي أَذْ أَسْ نسّڒْقَا  
\m سبْعَا ن إِمكْسَاونْ  
\m ذ ثْمنْيَا ن أَيْثْ ن جّهْذْ زِي مِيدّنْ. \x ◘ \xo 5:‏4 \xt إِشا. 9‏:‏5\x*   
\m
\v 5 نِيثْنِي أَذْ حْضَانْ  
\m خْ ثمُّورْثْ ن أَشُّورْ س سِّيفْ  
\m ؤُ ثَامُّورْثْ ن نِيمْرُوذْ ذِي ثوُّورَا نّسْ.  
\m \add أَمُّو\add* نتَّا أَذْ أَنغْ إِسّنْجمْ  
\m زڭْ \add ؤُفُوسْ\add* ن أَشُّورْ،  
\m خْمِي د غَا يَاسْ وَانِيثَا  
\m غَارْ ثمُّورْثْ نّغْ  
\m ؤُ خْمِي د غَا يَاذفْ  
\m غَارْ وُوذمْ ن ثمُّورْثْ نّغْ.“   
\b  
\m  
\s1 ڒْبَاقِي ن يَاعْقُوبْ  
\m
\v 6 ”ڒْبَاقِي ن يَاعْقُوبْ أَذْ يِيڒِي  
\m ذِي ڒْوسْطْ ن ڒڭْنُوسْ  
\m أَمشْنَاوْ نّْذَا ن سِيذِي،  
\m أَمشْنَاوْ ثِيدُّومِينْ خْ وفْسُو \add أَزِيزَا،\add*  
\m ونِّي وَارْ إِخزَّارنْ  
\m غَارْ ؤُڒَا ذ إِجّْ ن ورْيَازْ  
\m ؤُ وَارْ إِتّْرِيجِينْ ثَارْوَا ن بْنَاذمْ.   
\m
\v 7 ڒْبَاقِي ن يَاعْقُوبْ أَذْ يِيڒِي جَارْ ڒڭْنُوسْ،  
\m ذِي ڒْوسْطْ نْ ڒڭْنُوسْ،  
\m أَمشْنَاوْ أَيْرَاذْ جَارْ ڒْمَاڒْ ن يزْغَارْ،  
\m أَمشْنَاوْ أَيْرَاذْ ذ أَمژْيَانْ  
\m جَارْ ثْحِيمْرِيوِينْ ن وُودْجِي،  
\m ونِّي، خْمِي غَا إِعْذُو،  
\m إِعفّسْ ؤُ إِتّْشَارَّاڭْ  
\m ؤُشَا وَارْ ذِينْ ؤُڒَا ذ إِجّْ إِ غَا إِفكّنْ. \f ◼ \fr 5:‏7 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*   
\m
\v 8 أَفُوسْ نّشْ أَذْ يِيڒِي إِتّْوَاسّْڭعّذْ  
\m سنّجْ إِ يِينِّي إِ شكْ إِحصَّارنْ،  
\m ؤُشَا مَارَّا ڒْعذْيَانْ نّشْ  
\m أَذْ تّْوَامْحَانْ.“   
\b  
\m
\v 9 ”أَذْ إِمْسَارْ ذڭْ وَاسّْ نِّي،  
\m \add أَمُّو إِ\add* إِقَّارْ سِيذِي،  
\m أَقَا نشّْ أَذْ ثحِّيغْ إِيْسَانْ نّشْ  
\m زِي ڒْوسْطْ نّشْ  
\m ؤُ أَذْ سّْهلّْكغْ إِكَارُّوثنْ نّشْ. \x ◘ \xo 5:‏9 \xt حُوش. 14‏:‏4\x*   
\m
\v 10 أَذْ مْحِيغْ ثِيندَّامْ زِي ثمُّورْثْ نّشْ،  
\m أَذْ هذْمغْ مَارَّا لْقلْعَاثْ نّشْ.   
\m
\v 11 نشّْ أَذْ قضْعغْ ثَاسحَّارْثْ نّشْ  
\m زڭْ ؤُفُوسْ نّمْ  
\m ؤُ وَارْ غَاركْ تِّيڒِينْ عَاذْ إِبزْڭَاونْ.   
\m
\v 12 ڒخْيَاڒَاثْ نّمْ إِنقْشنْ  
\m ذ إِمَايْضُوثنْ نّشْ \add إِقدّْسنْ\add*  
\m أَذْ \add ثنْ\add* مْحِيغْ زِي ڒْوسْثْ نّشْ،  
\m حِيمَا وَارْ ثتّْبنْذَاقذْ عَاذْ  
\m إِ ڒْخذْمثْ ن إِفَاسّنْ نّشْ.   
\m
\v 13 ؤُ ثِيربِّينْ نّشْ ن شْوَارْثِي  
\m أَذْ ثنْثْ ثحِّيغْ زِي ڒْوسْطْ نّشْ.  
\b  
\m \add مَاشَا\add* أَذْ هذْمغْ ڒْعذْيَانْ نّشْ   
\m
\v 14 ؤُشَا أَذْ نْثَاقْمغْ س وغْضَابْ ؤُ س وسْعَارْ  
\m خْ ڒڭْنُوسْ نِّي وَارْ \add إِتّخْسنْ\add* أَذْ سْڒنْ.“   
\b  
\b  
\m  
\c 6
\s1 أَشثْشِي ن سِيذِي خْ ڒْڭنْسْ نّسْ ؤُ خْ ؤُرْشَالِيمْ  
\m
\v 1 ”سْڒمْ خنِّي مِينْ إِقَّارْ سِيذِي:  
\m كَّارْ، شَارّعْ زَّاثْ إِ وُوذمْ ن إِذُورَارْ،  
\m ؤُ أجّْ ثِيوْرِيرِينْ أَذْ سْڒنْثْ إِ ثْمِيجَّا نّشْ!   
\m
\v 2 سْڒمْ، \add أَ\add* إِذُورَارْ، إِ دّعْوثْ ن سِيذِي،  
\m \add ؤُڒَا ذ كنِّيوْ\add*، ذْسُوسَا إِمثْننْ ن ثمُّورْثْ،  
\m مِينْزِي سِيذِي غَارسْ إِشْثْ ن دّعْوثْ  
\m أَكْ-ذ ڒْڭنْسْ نّسْ  
\m نتَّا إِڭُّورْ غَارْ ثَادَّارْثْ ن شّْرعْ  
\m أَكْ-ذ إِسْرَائِيل.“ \x ◘ \xo 6:‏2 \xt حُوش. 4‏:‏1\x*   
\b  
\m
\v 3 ”\add أَ\add* ڒْڭنْسْ إِنُو، مِينْ ذ أَشْ ڭِّيغْ،  
\m ؤُ س مَانْثنْ إِ زِي شكْ سِّيحْڒغْ؟  
\m شهّذْ ضِيدّْ إِنُو!   
\m
\v 4 نشّْ نذْهغْ شكْ زِي ثمُّورْثْ ن مِيصْرَا،  
\m زِي ثَادَّارْثْ ن ثسْمُوغِي.  
\m نشّْ سّكّغْ-د مُوسَا  
\m ذ هَارُونْ ذ مَارْيَامْ  
\m زَّاثْ إِ ؤُغمْبُوبْ نّشْ. \x ◘ \xo 6:‏4 \xt ؤُف. 12‏:‏51؛ 14‏:‏30؛ 20‏:‏2\x*   
\m
\v 5 \add أَ\add* ڒْڭنْسْ إِنُو، فكَّارْ مْلِيحْ ذِي \add ڒْغَارْ\add*  
\m إِ \add ثُوغَا\add* إِنكّْوَا أَذْ يڭّْ بَالَاكْ،  
\m أَجدْجِيذْ ن مُوآبَ،  
\m ؤُ ذِي مِينْ خَاسْ د-يَارَّا بِيلْعَامْ،  
\m مِّيسْ ن بَاعُورْ  
\m \add ؤُ ذِي مِينْ إِمْسَارنْ\add* زِي شِيطِّيمْ أَڒْ جِيلْجَالْ،  
\m حِيمَا أَذْ ثسّْنذْ  
\m ثِيمڭَّا إِسڭّْذنْ ن سِيذِي.“ \x ◘ \xo 6:‏5 \xt ڒخْڒ. 22‏:‏5؛ 23‏:‏7؛ 25؛ ياش. 5\x*   
\b  
\m  
\s1 مِينْ إِخْسْ سِيذِي زِي ڒْڭنْسْ نّسْ؟  
\m
\v 6 ”س مِينْ زِي غَا رَاحغْ  
\m أَذْ مّڒْقِيغْ أَكْ-ذ سِيذِي،  
\m أَذْ أَضَارغْ زَّاثْ إِ أَربِّي يُوعْڒَانْ؟  
\m مَا أَذْ رَاحغْ أَذْ ث مّڒْقِيغْ  
\m س ثْغَارْصَا ن وشْمَاضْ،  
\m نِيغْ س إِعجْمِييّنْ ن إِجّْ ن ؤُسڭّْوَاسْ؟ \f ◼ \fr 6:‏6 \ft \+bd ’أَمْوَا‘\+bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*   
\m
\v 7 مَا أَذْ يَارْضَا سِيذِي  
\m س ڒُوڒُوفْ ن إِشَارِّييّنْ،  
\m سعشْرَا ن ڒُوڒُوفْ ن ثْغزْرَاثِينْ ن زّشْثْ؟  
\m مَا أَذْ وْشغْ أَمنْزُو إِنُو إِ ؤُخطُّو إِنُو،  
\m ڒْْغِيدْجثْ ن ؤُعذِّيسْ إِنُو  
\m إِ دّْنُوبْ ن ڒعْمَارْ إِنُو؟   
\m
\v 8 نتَّا إِسَّارْڭبْ إِ شكْ، \add أَ\add* بْنَاذمْ،  
\m مِينْ إِشْنَانْ،  
\m ؤُ مِينْ زَّايكْ إِتّتَّارْ سِيذِي،  
\m أَقَا أَذْ ثڭّذْ ڒْخَارْ،  
\m أَذْ ثخْسذْ ثَامخْسِيوْثْ إِشوَّارنْ،  
\m ؤُ أَذْ ثُويُورذْ أَكْ-ذ أَربِّي نّشْ  
\m س ؤُوَاضعْ!“ \x ◘ \xo 6:‏8 \xt أَعَوذ. 10‏:‏12\x*   
\b  
\m  
\s1 أَردّدْجْ ن إِعفَّاننْ  
\m
\v 9 ”ثْمِيجَّا ن سِيذِي ثتّْڒَاغَا إِ ثنْذِينْثْ.  
\m إِسمْ نّشْ إِتَّاوِي-د ؤُفكِّي.  
\m سْڒمْ إِ وعْمُوذْ  
\m ؤُ غَارْ ونِّي ث-إِ-د إِسّكّنْ!   
\m
\v 10 مَا ذِينْ عَاذْ ڒخْزِينْ شُّورنْ س ڒْغَارْ  
\m ذِي ثَادَّارْثْ ن ؤُعفَّانْ  
\m ؤُڒَا ذ إِجّْ ن نّْعِي ن \add ڒْمُوذْ ن\add* إِفَا إِنْقصْ؟   
\m
\v 11 مَا إِزمَّارْ أَذْ إِڒِيغْ ذ أَمزْذَاڭْ  
\m س ڒْمِيزَانَاثْ ن ڒْغَارْ،  
\m ؤُ س يِيشْثْ ن ثشْيَارْثْ \add ثشُّورْ\add*  
\m س ڒوْزْنَاثْ إِغشّنْ؟ \x ◘ \xo 6:‏11 \xt حُوش. 12‏:‏8\x*   
\m
\v 12 أَيْثْ بُو-وَاڭْڒَا نّسْ أَقَا شُّورنْ س لْعُونْفْ،  
\m ؤُڒَا ذ إِمزْذَاغْ نّسْ قَّارنْ إِخَارِّيقنْ  
\m ؤُ إِڒسْ نْسنْ أَقَا إِتّْغشَّا  
\m ذڭْ ؤُقمُّومْ نْسنْ.“ \x ◘ \xo 6:‏12 \xt إِرْم. 9‏:‏7\x*   
\b  
\m
\v 13 ”خنِّي نشّْ أَقَا جَارْحغْ شمْ س ثيِّيثَا،  
\m أَقَا ثتّْوَاردّْدْجذْ  
\m زِي سِّيبّثْ ن دّْنُوبْ نّمْ.   
\m
\v 14 أَذْ ثشّذْ، \add مَاشَا\add* وَارْ ثتّْجِيوِينذْ،  
\m ؤُ أَذْ ذَايمْ يِيڒِي ڒَاژْ ذِي ذَاخڒْ نّمْ.  
\m أَذْ ثفّْغذْ،  
\m \add مَاشَا\add* وَارْ ثْنجّْمذْ،  
\m ؤُ مِينْ إِنجْمنْ،  
\m أَذْ ث سّعْذُوغْ إِ سِّيفْ. \x ◘ \xo 6:‏14 \xt حُوش. 4‏:‏10\x*   
\m
\v 15 ڭُّورْ أَذْ ثْزَارْعذْ، \add مَاشَا\add* وَارْ ثْمجَّارذْ،  
\m أَذْ ثدّْزذْ أَژمُّورْ،  
\m \add مَاشَا\add* وَارْ ثْذهّْنذْ إِخفْ نّمْ س زّشْثْ  
\m \add أَذْ ثْژمّذْ\add* ؤُڒَا ذ بِينُو ن جْذِيذْ \add زڭْ ؤُضِيڒْ\add*،  
\m \add مَاشَا\add* وَارْ ثسّسّذْ بِينُو. \x ◘ \xo 6:‏15 \xt أَعَوذ. 28‏:‏38؛ Ḥag. 1‏:‏6\x*   
\m
\v 16 \add مَاغَارْ\add* ڒْڭنْسْ إِحطَّانْ ثِيوصَّا ن عُومْرِي  
\m ؤُ مَارَّا ثِيمڭَّا \add ثِيعفَّانِينْ\add*  
\m ن ثَادَّارْثْ ن أَخَابْ،  
\m ؤُ كنِّيوْ ثْضفَّارمْ ڒشْوَارْ نْسنْ،  
\m أَڒَامِي شمْ إِ غَا يَارّغْ  
\m ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ  
\m ؤُڒَا ذ إِمزْذَاغْ نّسْ إِ ؤُسمْژِي.  
\m \add أَمُّو\add* إِ غَا ثَارْبُومْ ڒْحڭْرَا ن ڒْڭنْسْ إِنُو.“ \x ◘ \xo 6:‏16 \xt 1 إِج. 16‏:‏25، 26، 30‏-‏34\x*   
\b  
\b  
\m  
\c 7
\s1 مِيخَا إِژْرَا ثُوعفّْنَا إِ إِدْجَانْ ذِي ڒْڭنْسْ  
\m
\v 1 ”ؤُشْثْ إِنُو، مَاغَارْ أَقَا أَيِي غَارِي  
\m أَمشْنَاوْ غَارْ ثْميْرَا ن ثِينِي ن ؤُنبْذُو،  
\m أَمشْنَاوْ غَارْ ثْوَاڒَا وِيسّْ ثْنَاينْ  
\m ن وڒْقَاضْ ن ؤُضِيڒْ:  
\m وَارْ ذِينْ ؤُڒَا ذ إِجّْ ن ؤُزكُّونْ ن ؤُضِيڒْ  
\m إِ مَاشَّا،  
\m وَارْ ذِينْ إِدْجِي ؤُڒَا ذ إِجّْ ن ڒْبَاشُورْ قْبڒْ ڒْوقْثْ  
\m إِ ذَايسْ مژْرِي ڒعْمَارْ إِنُو.   
\m
\v 2 أَمدُّوكَّاڒْ إِ ذَايسْ  
\m ثَامخْسِيوْثْ إِشوَّارنْ  
\m وَارْ إِقِّيمْ ذِي ثمُّورْثْ،  
\m ؤُشَا وَارْ ذِينْ ؤُڒَا ذ إِجّْ ن ؤُصبْحَانْ  
\m جَارْ إِوْذَانْ.  
\m نِيثْنِي مَارَّا تّْحَامَانْ خْ إِذَامّنْ،  
\m إِجّنْ إِيمَّارْ ونّغْنِي س ثْرَاشَّا. \x ◘ \xo 7:‏2 \xt إِزهد. 12‏:‏2؛ حُوش. 4‏:‏1\x*   
\m
\v 3 إِفَاسّنْ نْسنْ وجْذنْ س ثْنَاينْ  
\m مَاحنْذْ أَذْ ڭّنْ ڒْغَارْ.  
\m ڒْحَاكمْ إِتَّارْ ؤُ ڒْقَاضِي \add إِتّڭّْ إِ-ت\add*  
\m ذِي طّْوعْ ن ؤُخدْجصْ،  
\m ؤُ ونِّي أَمقّْرَانْ إِسَّاوَاڒْ  
\m \add عْلَاحْسَابْ\add* مژْرِي \add أَعفَّانْ\add* ن ڒعْمَارْ نّسْ  
\m ؤُ \add أَمُّو\add* إِ سّْفَارْغنْ نِيثْنِي ثَامسْڒَاشْثْ. \x ◘ \xo 7:‏3 \xt مِيخَا 2‏:‏1؛ 3‏:‏11\x*   
\m
\v 4 ونِّي زَّايْسنْ ذ أَصبْحَانْ أَطَّاسْ  
\m \add أَقَا-ث\add* أَمْ يِيجّْ ن شْبَارْقْ ن إِسنَّاننْ،  
\m ونِّي ذ أَصْذِيقْ ن وُوڒْ قَاعْ \add زَّايْسنْ\add*  
\m \add أَقَا-ث\add* مَاهُو خْ إِجّْ ن وفْرَايْ ن شْبَارْقْ  
\m أَكْ-ذ إِسنَّاننْ.  
\m أَسّْ ن إِعسَّاسنْ نّشْ،  
\m \add أَسّْ ن\add* ؤُخدْجصْ، يُوسَا-د.  
\m ڒخُّو أَذْ نْخڒْعنْ.“   
\b  
\m  
\s1 مِيخَا أَذْ إِرَاجَا أَسنْجمْ ن أَربِّي  
\m
\v 5 ”وَارْ ثُومِينذْ ذڭْ إِجّْ ن ؤُمدُّوكّڒْ،  
\m وَارْ ثتّشْڒذْ  
\m خْ ؤُمدُّوكّڒْ \add نّشْ\add* إِعِيزّنْ.  
\m حْضَا ثِيوُّورَا ن ؤُقمُّومْ نّشْ  
\m زِي ثنِّي إِدْجَانْ غَارْ وحْسِينْ نّشْ.   
\m
\v 6 مَاغَارْ مِّيسْ إِسّحْقَارَا بَابَاسْ،  
\m يدْجِيسْ ثتّْضَادَّا يمَّاسْ،  
\m ثَاسْڒِيثْ خْ لَالَّاسْ،  
\m ڒْْعذْيَانْ ن إِجّْ ن ورْيَازْ  
\m أَقَا ذ أَيْثْبَابْ ن ثَادَّارْثْ نّسْ.“ \x ◘ \xo 7:‏6 \xt حِز. 22‏:‏7؛ مت. 10‏:‏21، 35، 36؛ لك. 12‏:‏53\x*   
\b  
\m
\v 7 ”\add مَاشَا\add* نشّْ أَذْ خْزَارغْ غَارْ سِيذِي،  
\m أَذْ رَاجِيغْ أَربِّي ن ؤُسنْجمْ إِنُو.  
\m أَربِّي إِنُو أَذْ غَارِي د-إِسڒْ.“   
\b  
\m
\v 8 ”وَارْ ذ أَيِي سْفَارّحْ،  
\m \add أَ شمْ\add* ثَامْغَارْثْ نِّي ذ ڒعْذُو إِنُو!  
\m مَاغَارْ مَاڒَا وْضِيغْ، أَذْ كَّارغْ عَاوذْ،  
\m مَاڒَا قِّيمغْ ذِي ثَادْجسْثْ،  
\m أَذْ يِيڒِي سِيذِي ذ ثَافَاوْثْ إِ نشّْ.   
\m
\v 9 نشّْ أَذْ كْسِيغْ أَسْخضْ ن سِيذِي،  
\m مِينْزِي نشّْ خْضِيغْ أَكِيذسْ،  
\m أَڒْ خَافِي إِ غَا إِوّثْ نتَّا خْ دّعْوثْ إِنُو  
\m ؤُ أَذْ أَيِي يَاغْ ثَاسْغَارْثْ إِنُو.  
\m نتَّا أَذْ أَيِي إِسُّوفّغْ غَارْ ثْفَاوْثْ،  
\m نشّْ أَذْ ژَترغْ ثَاسڭْذَا نّسْ. \x ◘ \xo 7:‏9 \xt إِزهد. 9‏:‏5‏-‏6؛ إِزهد. 43‏:‏1؛ إِرْم. 50‏:‏34\x*   
\m
\v 10 ثَامْغَارْثْ ثنِّي ذ ڒعْذُو إِنُو  
\m أَذْ ثْژَارْ أَيَا.  
\m مْڒِي ذ أَسْ إِ غَا ثْذڒْ ڒحْيَا  
\m إِ ثنِّي ذ أَيِي إِقَّارنْ:  
\m ’مَانِي إِدْجَا سِيذِي، أَربِّي نّشْ؟‘  
\m ثِيطَّاوِينْ إِنُو أَذْ غَارسْ خْزَارنْثْ!  
\m ڒخُّو أَذْ ثتّْوَادّزْ نتَّاثْ،  
\m أَمْ ؤُبدْجَاعْ ذِي زّْنَاقِي.“ \x ◘ \xo 7:‏10 \xt إِزهد. 79‏:‏10؛ 115‏:‏2؛ يُووِ. 2‏:‏17\x*   
\b  
\m
\v 11 ”ذڭْ وَاسّْ إِ ذِي إِ غَا إِبْنَا نتَّا  
\m ڒحْيُوضْ نّشْ عَاوذْ،  
\m ذڭْ وَاسّْ نِّي أَذْ إِرَاحْ ڒْحقّْ  
\m غَارْ ڒَاڭّْوَاجْ أَطَّاسْ.   
\m
\v 12 ذڭْ وَاسّْ نِّي أَذْ د-أَسنْ،  
\m زِي أَشُّورْ ذ ثْندَّامْ ن مِيصْرَا،  
\m ؤُ زِي مِيصْرَا أَڒْ إِغْزَارْ \add ن لْفُورَاطْ\add*،  
\m ؤُ زِي ڒبْحَارْ أَڒْ ڒبْحَارْ  
\m ؤُ زڭْ وذْرَارْ أَڒْ وذْرَارْ \add نّغْنِي.\add*   
\m
\v 13 \add مَاشَا\add* دُّونشْثْ أَذْ ثذْوڒْ  
\m إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ،  
\m زِي سِّيبّثْ ن إِمزْذَاغْ نّسْ،  
\m زِي سِّيبّثْ ن ڒْغِيدْجثْ ن ثْمڭَّا نْسنْ.“ \x ◘ \xo 7:‏13 \xt إِرْم. 21‏:‏14\x*   
\b  
\m
\v 14 ”أَرْوسْ ڒْڭنْسْ نّشْ س ثغَّارْشْثْ نّشْ،  
\m ؤُدْجِي ن ثسْغَارْثْ نّشْ،  
\m ثنِّي إِدْجَانْ وحّْذسْ ذڭْ وزْغَارْ،  
\m ذِي ڒْوسْطْ ن كَارْمِيلْ.  
\m أجّْ إِ-ثنْثْ أَذْ أَروْسنْ ذِي بَاشَانْ ذ جِيلْعَاذْ،  
\m أَمْ ذڭْ وُوسَّانْ ن وشْحَاڒْ ؤُيَا. \x ◘ \xo 7:‏14 \xt مِيخَا 5‏:‏3\x*   
\m
\v 15 نشّْ أَذْ أَسْ سّشّْنغْ لْمُوعْجِيزَاثْ،  
\m أَمْ ذڭْ وُوسَّانْ  
\m ڒَْامِي د-ثفّْغذْ زِي ثمُّورْثْ ن مِيصْرَا. \x ◘ \xo 7:‏15 \xt يُووِ. 2‏:‏26؛ 3‏:‏3. \x*   
\m
\v 16 ڒڭْنُوسْ أَذْ ث ثْوَاڒِينْ،  
\m أَذْ سضْحَانْ زِي سِّيبّثْ  
\m ن مَارَّا ثِيزمَّارْ نْسنْ،  
\m نِيثْنِي أَذْ سَّارْسنْ أَفُوسْ خْ ؤُقمُّومْ،  
\m إِمزُّوغنْ نْسنْ أَذْ دُّوهْشَارنْ.   
\m
\v 17 نِيثْنِي أَذْ ڒسْحنْ ثَاعجَّاجْثْ أَمْ ؤُفِيغَارْ،  
\m أَذْ د-فّْغنْ زِي لْبُورْجَاثْ نْسنْ  
\m أَمْ إِمُودَّارْ ن ثمُّورْثْ إِتّْبُوعنْ.  
\m أَذْ د-أَسنْ تَّارْجِيجنْ  
\m غَارْ سِيذِي، أَربِّي نّغْ،  
\m ؤُ أَذْ زَّايكْ ڭّْوذنْ.“ \x ◘ \xo 7:‏17 \xt إِزهد. 72‏:‏9؛ إِشا. 49‏:‏32\x*   
\b  
\m  
\s1 ثَايْرِي ن أَربِّي ذ أَرّحْمثْ نّسْ  
\m
\v 18 ”مَانْ ونْ إِدْجَانْ ذ أَربِّي أَمْ شكْ،  
\m ونِّي إِغفَّارنْ ڒْمُوعْصِييّثْ،  
\m ونِّي إِعدُّونْ خْ ؤُخطُّو  
\m ن مِينْ إِقِّيمنْ زِي ثسْغَارْثْ نّسْ؟  
\m نتَّا وَارْ إِمنّعْ إِ ڒبْذَا  
\m ذڭْ وغْضَابْ نّسْ،  
\m مَاغَارْ يَارْضَا أَسْ ثَامخْسِيوْثْ إِشوَّارنْ. \x ◘ \xo 7:‏18 \xt ؤُف. 34‏:‏6، 7؛ إِزهد. 103‏:‏9\x*   
\m
\v 19 نتَّا أَذْ خَانغْ يَارْحمْ عَاوذْ،  
\m نتَّا أَذْ إِعْفسْ خْ ڒْمُوعْصِييّثْ نّغْ،  
\m \add وَاهْ\add*، شكْ أَذْ ثنْضَارذْ  
\m مَارَّا دّْنُوبْ نْسنْ  
\m ذِي ڒَادْجَاغْ ن ڒبْحَارْ.   
\m
\v 20 إِڒِي شكْ أَذْ ثسّشْنذْ ڒَامَانْ إِ يَاعْقُوبْ  
\m \add ؤُ\add* ثَامخْسِيوْثْ إِشوَّارنْ إِ إِبْرَاهِيمْ،  
\m أَمْ مَامّشْ ثجُّودْجذْ إِ ڒجْذُوذْ نّغْ  
\m زڭْ وُوسَّانْ ن مشْحَاڒْ ؤُيَا.“   