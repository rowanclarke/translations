\v 20 \w Joktan|strong="H3355"\w* \w was|strong="H3205"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* Almodad, \w Sheleph|strong="H8026"\w*, \w Hazarmaveth|strong="H2700"\w*, \w Jerah|strong="H3392"\w*,
\v 21 \w Hadoram|strong="H1913"\w*, Uzal, \w Diklah|strong="H1853"\w*,
\v 22 Obal,\f + \fr 1:22 \ft Most manuscripts have Ebal, but see \xt Genesis 10:28\xt*\ft .\f* Abimael, \w Sheba|strong="H7614"\w*,
\v 23 Ophir, \w Havilah|strong="H2341"\w*, \w and|strong="H1121"\w* \w Jobab|strong="H3103"\w*. \w These|strong="H3605"\w* \w were|strong="H1121"\w* \w all|strong="H3605"\w* \w Joktan|strong="H3355"\w*'s \w sons|strong="H1121"\w*.
\p 
\v 24 \w Shem|strong="H8035"\w*, Arphaxad,\f + \fr 1:24 \ft Some Septuagint manuscripts add “Cainan” here.\f* \w Shelah|strong="H7974"\w*,
\v 25 \w Eber|strong="H5677"\w*, \w Peleg|strong="H6389"\w*, \w Reu|strong="H7466"\w*,
\v 26 \w Serug|strong="H8286"\w*, \w Nahor|strong="H5152"\w*, \w Terah|strong="H8646"\w*,
\v 27 and Abram (\w also|strong="H1931"\w* called Abraham).
\p 
