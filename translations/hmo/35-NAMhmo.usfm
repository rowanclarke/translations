\id NAM NAHUM, Hiri Motu Bible, PNG, 6/90, 5/93 
\h NAHUMU 
\toc1 NAHUMU 
\toc2 NAHUMU 
\mt1 NAHUMU  
\c 1  
\p
\v 1 Inai hereva be Nineva hanua badana totona, Nahumu, Elekoso tauna ena mata hanai lalonai ia itaia gauna.   
\s1 Lohiabada ese Nineva hanua dekenai ia badu henia  
\q1
\v 2 Lohiabada be mai ena mama,  
\q1 ia ura lasi idau dirava ese,  
\q1 iena gabu do idia abia.  
\q1 Bona Lohiabada ese ia dekenai idia dagedage henia noho taudia,  
\q1 be ia panisidia noho.  
\q1 Mai badu danu ia ese edia davana ia henidia noho.   
\q1
\v 3 Lohiabada be ia badu haraga lasi,  
\q1 to ia be mai ena siahu bada herea.  
\q1 Lohiabada ese kerere taudia edia dika davana,  
\q1 be do ia henia momokani,  
\q1 do ia laloaboio lasi.  
\q1 Lohiabada ia raka noho gabudia dekenai,  
\q1 lai gubadia idia toreisi noho.  
\q1 Ori be Lohiabada ena aena ena kahu.   
\q1
\v 4 Lohiabada ese davara ia gwau henia noho,  
\q1 bona ia kaukau lao!  
\q1 Ia ese danu sinavai edia ranu ibounai ia haorea,  
\q1 idia kaukau lao.  
\q1 Basana bona Karamele edia uma gabudia,  
\q1 be idia dika lao noho,  
\q1 bona Lebanona ena palauapalaua idia mase noho.   
\q1
\v 5 Lohiabada ena vairana dekenai,  
\q1 ororo idia heudeheude noho,  
\q1 bona ororo maragidia idia veve ore noho.  
\q1 Iena vairanai danu tano ia mareremarere noho,  
\q1 tanobada mai ena noho taudia ibounai danu,  
\q1 be idia heudeheude noho.   
\q1
\v 6 Lohiabada ia badu neganai,  
\q1 daika do ia gini diba?  
\q1 Iena badu siahu bada dekenai,  
\q1 daika ia mauri noho diba?  
\q1 Ia ese iena badu ia bubua diho lahi bamona,  
\q1 bona nadi badadia be iena vairanai,  
\q1 idia makohia maragimaragi noho.   
\b  
\q1
\v 7 Lohiabada be ia namo.  
\q1 Ia ese iena bese taudia ia durua noho,  
\q1 edia hekwarahi bona hisihisi dinana neganai.  
\q1 Lohiabada idia abidadama henia taudia,  
\q1 be ia ese ia naridia noho.   
\q1
\v 8 Abata bada bamona,  
\q1 Lohiabada ese ia dekenai idia dagedage taudia,  
\q1 be ia hadikadia ore noho.  
\q1 Ia dekenai idia tuari henia gwauraia taudia,  
\q1 be ia ese ia alaia mase noho.   
\b  
\q1
\v 9 Umui ese Lohiabada umui hadikaia gwauraia taudia e,  
\q1 umui kamonai!  
\q1 Lohiabada ese umui do ia hadikaia ore.  
\q1 Lohiabada idia dagedage henia taudia ese,  
\q1 nega iharuana do idia karaia diba lasi.   
\q1
\v 10 Au giniginidia, kaukau gaudia,  
\q1 bona rei kakoro idia gabua bamona,  
\q1 Lohiabada ena lahi ese umui do ia gabua ore.   
\b  
\q1
\v 11 Nineva e,  
\q1 oi dekena amo tau ta ia mai vadaeni.  
\q1 Ia ese Lohiabada hadikaia dalana ia tahua noho.   
\q1
\v 12 Lohiabada ese Israela taudia ia hamaoroa noho, ia gwau,  
\q1 “Momokani Asuria taudia be mai edia goada,  
\q1 bona idia be momo herea danu,  
\q1 to haida ese do idia hadikadia ore,  
\q1 vadaeni do idia boio ore.  
\q1 Egu bese taudia e,  
\q1 lau ese umui lau hisihisi henia vadaeni,  
\q1 to umui do lau hisihisi henia lou lasi.   
\q1
\v 13 Asuria taudia edia siahu umui emui latanai,  
\q1 be harihari do lau hamakohia,  
\q1 bona umui idia guia seini,  
\q1 be do lau utua negea.”   
\b  
\q1
\v 14 Lohiabada ese Asuria taudia totona inai bamona ia hereva:  
\q1 “Edia natudia bona tubudia do idia mase.  
\q1 Vadaeni edia basileia,  
\q1 be do ia gini noho diba lasi,  
\q1 bona edia ladana be do ia ore.  
\q1 Edia dirava edia dubu edia lalonai idia noho kaivakuku,  
\q1 be do lau hadikaia ore,  
\q1 bona Asuria taudia edia guria gabudia,  
\q1 be do lau karaia hegaegae,  
\q1 badina idia be dika rohoroho momokani.”   
\b  
\q1
\v 15 Umui itaia, ororo dekena amo ia mai noho tauna ese,  
\q1 tuari ia ore hereva namona ia mailaia inai!  
\q1 Ia ese maino hereva ia gwauraia noho!  
\q1 Iuda taudia e,  
\q1 emui aria do umui karaia,  
\q1 bona Dirava dekenai umui gwauhamata gaudia do umui henia,  
\q1 badina be kara dika taudia ese,  
\q1 emui tano do idia tuari henia lou lasi.  
\q1 Unai dika taudia be haida ese,  
\q1 idia hadikadia ore momokani vadaeni.   
\c 2  
\s1 Nineva hanua badana ia moru  
\q1
\v 1 Nineva e, haida ese oi idia tuari henia noho inai!  
\q1 Oi do idia hadikaia ore taudia,  
\q1 be idia ginidae vadaeni.  
\q1 Oiemu magu do oi gimaia,  
\q1 bona emu raka vareai dala do oi naria!  
\q1 Tuari totona do oi gini hegaegae!   
\b  
\p
\v 2 Momokani, guna Asuria tuari taudia ese Israela idia hamanokaia momokani. To hari Lohiabada ese Israela dekenai goada ia henia lou vadaeni inai.   
\b  
\q1
\v 3 Nineva hanua idia tuari henia gwauraia taudia,  
\q1 edia kesi be kakakaka.  
\q1 Edia tuari dabua danu be kakakaka.  
\q1 Edia kariota edia laini idia haboua,  
\q1 bona idia gini hegaegae noho neganai,  
\q1 kariota edia auri be idia diaridiari noho, lahi bamona!  
\q1 Edia hosi idia heudeheude noho,  
\q1 tuari be kahirakahira dainai.   
\q1
\v 4 Kariota momo be hanua ariara dekenai idia noho.  
\q1 Idia heau lao, bona heau mai noho.  
\q1 Kede bamona idia diaridiari noho,  
\q1 ma edia toana bona edia haraga be kevaru bamona.   
\b  
\q1
\v 5 King ese iena tuari biagudia ia boiria hebou,  
\q1 idia heau vaira neganai,  
\q1 idia moru kava, moru kava noho.  
\q1 Tuari taudia ese hanua ena magu,  
\q1 dekenai idia heau lao,  
\q1 magu hadikaia au latadia edia vairanai,  
\q1 be kesi badana idia haginia noho.   
\q1
\v 6 Sinavai ena ranu ia koua iduara idia kehoa vadaeni,  
\q1 bona king ena ruma noho taudia,  
\q1 be idia gari bada herea noho.   
\q1
\v 7 Nineva ena kwini hahine ena dabua idia kokia,  
\q1 bona mai guia danu idia abia lao.  
\q1 Iena hesiai kekenidia be ia totona idia tai noho,  
\q1 pune manu edia tai bamona.  
\q1 Madi, mai lalohisihisi danu,  
\q1 sibodia edia kemedia idia botaia noho.   
\q1
\v 8 Ranu ia haboua gabuna ena magu ia makohia neganai,  
\q1 ranu momo ia heau lao bamona,  
\q1 Nineva taudia ese unai bamona danu,  
\q1 be edia hanua dekena amo idia heau lao noho.  
\q1 Haida idia boiboi, idia gwau,  
\q1 “Do umui gini, do umui gini!”  
\q1 To idia ta ese ia giroa lou lasi.   
\b  
\q1
\v 9 Nineva ena siliva do umui dadia!  
\q1 Ena golo danu do umui dadia!  
\q1 Ena kohu namodia be momo herea!   
\q1
\v 10 Nineva be idia hadikaia ore vadaeni,  
\q1 ia be anina lasi momokani!  
\q1 Taunimanima edia kudoudia idia manoka lao,  
\q1 gari bada dainai.  
\q1 Edia tuidia idia heudeheude noho,  
\q1 edia goada ia ore.  
\q1 Edia vairadia be idia laboralabora lao noho.   
\b  
\q1
\v 11 Guna idia gwau inai hanua,  
\q1 be laiona ena noho gabuna, ani?  
\q1 Harihari unai laiona ena guri be edeseni?  
\q1 Laiona ena natuna edia nadi kohua be edeseni?  
\q1 Laiona tau bona laiona hahine idia noho gabuna,  
\q1 bona edia natudia unuseni idia noho,  
\q1 ta ese ia hagaridia lasi gabuna be edeseni?   
\q1
\v 12 Laiona ese boroma idauidau ia alaia.  
\q1 Ia ese boroma ena hidiona ia darea maragimaragi,  
\q1 iena hahine bona natudia totona.  
\q1 Ia ese iena guri be vamu dekenai ia hahonua.   
\b  
\p
\v 13 Lohiabada, Siahu Ibounai Dirava ia gwau, “Nineva e, lau ese oi lau dagedage henia noho inai. Oiemu kariota be do lau gabua ore. Oiemu tuari taudia be tuari lalonai do idia mase. Bona oi ese idau bese taudia dekena amo oi abia kohudia be oi dekena amo do lau abia lou. Oiemu siahu ena regena bada be tanobada taudia ese do idia kamonai lou lasi.”   
\c 3  
\s1 Nineva be idia hadikaia ore  
\q1
\v 1 Taunimanima edia rarana oi bubua hanua e,  
\q1 koikoi dekenai oi honu noho.  
\q1 Oi ese dika do oi davaria momokani!  
\q1 Oi be tuari dekena amo oi abia kohu,  
\q1 dekenai oi honu noho.  
\q1 Oiemu dadia karadia idia doko lasi.   
\q1
\v 2 Kamonai! Hosi kwadia varona,  
\q1 bona kariota edia uili,  
\q1 edia regena idia daekau noho.  
\q1 Hosi bona kariota idia heau haraga noho.   
\q1
\v 3 Hosi guia taudia idia heau vaira noho.  
\q1 Edia tuari kaia bona io idia marere haraga,  
\q1 unai dainai idia diaridiari noho.  
\q1 Taunimanima momo idia mase noho.  
\q1 Mase tauanidia be idia haboua bada herea noho.  
\q1 Mase tauanidia be duahia diba lasi.  
\q1 Idia dainai taunimanima idia raka mai hekwarahi bada danu.   
\q1
\v 4 Nineva e, ariara hahine e,  
\q1 oi ese oiemu dika davana oi abia noho inai, ani?  
\q1 Oi be mai emu hairaina,  
\q1 bona mai emu meamea dikadia danu.  
\q1 Oiemu ariara karadia dekena amo,  
\q1 basileia idauidau oi koidia,  
\q1 bona oi guidia danu.   
\b  
\q1
\v 5 Siahu Ibounai Lohiabada ia gwau,  
\q1 “Lau ese oiemu dika davana do lau henia inai:  
\q1 Lau ese oiemu dabua do lau kokia ore momokani,  
\q1 vadaeni bese idauidau edia vairanai,  
\q1 oi do lau hedinaraia.  
\q1 Idia ese oiemu hemarai do idia itaia.   
\q1
\v 6 Lau ese miro be oiemu kopina,  
\q1 ena latanai do lau negea lao.  
\q1 Dika rohoroho gauna bamona,  
\q1 be oi do lau halaoa.  
\q1 Taunimanima ese mai hoa bona gari danu,  
\q1 oi do idia itaia noho.   
\q1
\v 7 Oi idia itaia taudia ibounai,  
\q1 be mai gari danu do idia raka siri.  
\q1 Do idia gwau,  
\q1 ‘Nineva be ia dika ore vadaeni!  
\q1 Daika ese ia totona do ia tai?  
\q1 Daika ia ura Nineva ena lalona do ia hagoadaia?’ ”   
\b  
\q1
\v 8 Nineva e, oiemu goada ese,  
\q1 Aigupito ena hanua badana,  
\q1 Tebe ena goada ia hereaia, a?  
\q1 Ia danu be mai ena sinavai,  
\q1 tuari dekena amo Tebe hanua ia gimaia gauna.  
\q1 Naila Sinavai ese Tebe hanua ia hagegea, magu bamona.   
\q1
\v 9 Tebe ese Etiopia bona Aigupito ia biagua,  
\q1 bona iena siahu be mai hetoana lasi.  
\q1 Putu bona Libia tanodia ese Tebe idia durua.   
\q1
\v 10 To Tebe taudia be mai guia danu,  
\q1 tuari taudia ese idia abia lao.  
\q1 Tebe ena memero maragidia,  
\q1 be ariara edia kona ibounai dekenai idia botaia mase.  
\q1 Tebe ena taunimanima namodia,  
\q1 idia matauraia taudia,  
\q1 be seini dekenai idia guia,  
\q1 bona tuari taudia ese edia huanai,  
\q1 unai lohia taudia idia haria,  
\q1 edia hesiai mai guia danu taudia,  
\q1 be do idia halaoa totona.   
\b  
\q1
\v 11 Nineva taudia e,  
\q1 umui danu do umui kekero,  
\q1 bona umui danu ese unai umui idia tuari henia taudia,  
\q1 dekena amo do umui heau,  
\q1 emui mauri do umui tahua.   
\q1
\v 12 Emui kohoro bona gabu aukadia be fig audia bamona,  
\q1 edia huahua idia mage neganai,  
\q1 badina bema au idia botaia neganai,  
\q1 huahua be ania taudia edia uduna lalonai do idia moru!   
\q1
\v 13 Nineva e, oiemu tuari taudia,  
\q1 be hahine taudia bamona,  
\q1 bona oiemu magu iduaradia be idia kehoa vadaeni,  
\q1 unai tuari taudia edia vairanai,  
\q1 badina unai iduara edia loka bona ba,  
\q1 be lahi ese ia gabua ore vadaeni.   
\b  
\q1
\v 14 Ranu do umui abia, do umui haboua,  
\q1 badina tuari taudia ese,  
\q1 Nineva do idia koua hegegea nega daudau.  
\q1 Emui magu do umui hagoadaia, do ia auka.  
\q1 Raro gabuna dekenai do umui lao,  
\q1 raro do umui kuia, do umui mikisia,  
\q1 biriki momo do umui karaia.   
\q1
\v 15 To do umui hekwarahi kava,  
\q1 badina be lahi ese umui do ia gabua,  
\q1 o tuari lalonai tuari kaia ese,  
\q1 umui do idia gwadaia mase.  
\q1 Umui be do umui boio ore haraga,  
\q1 kwadi momo ese uiti bona koni,  
\q1 idia ania ore haraga bamona.  
\q1 Momokani, guna umui be momo herea,  
\q1 biluga idia momo bamona,  
\q1 bona kwadi idia momo herea bamona.   
\q1
\v 16 Umui emui hoihoi taudia be momo herea.  
\q1 Idia ese guba ena hisiu edia momo idia hanaia.  
\q1 To harihari idia boio ore vadaeni,  
\q1 kwadi ese gau ibounai idia ania ore,  
\q1 murinai idia roho lao ore bamona.   
\q1
\v 17 Emui lohia bona opesa taudia be kwadi momo bamona,  
\q1 keru dinana neganai,  
\q1 idia be magu dekenai idia helai noho,  
\q1 to dina ia daekau neganai idia toreisi,  
\q1 idia roho lao noho,  
\q1 bona tau ta ia diba lasi idia be edeseni.   
\b  
\q1
\v 18 Asuria ena king e,  
\q1 oiemu gavana taudia idia mase vadaeni,  
\q1 bona oiemu lohia taudia be idia mahuta noho,  
\q1 ela bona hanaihanai!  
\q1 Oiemu taunimanima be ororo dekenai,  
\q1 idia heau boio vadaeni,  
\q1 bona do ia haboudia lou tauna ta be lasi.   
\q1
\v 19 Oiemu hisihisi be mai ena hanamoa dalana lasi.  
\q1 Oiemu bero be mase gauna.  
\q1 Oiemu dika ena sivarai idia kamonai noho taudia,  
\q1 ese mai moale bada danu,  
\q1 edia imadia idia patapata noho.  
\q1 Badina be oiemu dagedage karadia,  
\q1 doko diba lasi gaudia,  
\q1 be daika ese edia mamina ia abia lasi, a?   