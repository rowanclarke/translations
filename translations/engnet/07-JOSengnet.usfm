\v 15 \w until|strong="H5704"\w* \w the|strong="H5414"\w* \nd \w Lord|strong="H3068"\w*\nd* \w gives|strong="H5414"\w* \w your|strong="H3068"\w* brothers \w a|strong="H3068"\w* \w place|strong="H5414"\w* \w like|strong="H5704"\w* \w yours|strong="H5650"\w* \w to|strong="H5704"\w* \w settle|strong="H5117"\w* \w and|strong="H4872"\w* \w they|strong="H1992"\w* \w conquer|strong="H3423"\w* \w the|strong="H5414"\w* \w land|strong="H5676"\w* \w the|strong="H5414"\w* \nd \w Lord|strong="H3068"\w*\nd* \w your|strong="H3068"\w* \w God|strong="H3068"\w* \w is|strong="H3068"\w* ready \w to|strong="H5704"\w* \w hand|strong="H5414"\w* \w over|strong="H5414"\w* \w to|strong="H5704"\w* \w them|strong="H5414"\w*. \w Then|strong="H5414"\w* \w you|strong="H5414"\w* \w may|strong="H3068"\w* \w go|strong="H7725"\w* \w back|strong="H7725"\w* \w to|strong="H5704"\w* \w your|strong="H3068"\w* allotted \w land|strong="H5676"\w* \w and|strong="H4872"\w* \w occupy|strong="H3423"\w* \w the|strong="H5414"\w* \w land|strong="H5676"\w* \w Moses|strong="H4872"\w* \w the|strong="H5414"\w* \nd \w Lord|strong="H3068"\w*\nd*’s \w servant|strong="H5650"\w* \w assigned|strong="H5414"\w* \w you|strong="H5414"\w* \w east|strong="H4217"\w* \w of|strong="H3068"\w* \w the|strong="H5414"\w* \w Jordan|strong="H3383"\w*.”
\p 
\v 16 \w They|strong="H6213"\w* \w told|strong="H6680"\w* \w Joshua|strong="H3091"\w*, “\w We|strong="H6213"\w* \w will|strong="H6213"\w* \w do|strong="H6213"\w* \w everything|strong="H3605"\w* \w you|strong="H6680"\w* say. \w We|strong="H6213"\w* \w will|strong="H6213"\w* \w go|strong="H3212"\w* \w wherever|strong="H3605"\w* \w you|strong="H6680"\w* \w send|strong="H7971"\w* \w us|strong="H6213"\w*.
