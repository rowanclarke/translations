\v 11 \w This|strong="H3541"\w* \w is|strong="H3541"\w* \w what|strong="H3541"\w* \w I|strong="H3588"\w*, \w Yahweh|strong="H3068"\w* \w the|strong="H3588"\w* \w Lord|strong="H3069"\w*, say \w to|strong="H3588"\w* \w you|strong="H3588"\w* leaders: \w I|strong="H3588"\w* myself \w will|strong="H3069"\w* \w search|strong="H1875"\w* \w for|strong="H3588"\w* \w my|strong="H3588"\w* \w sheep|strong="H6629"\w* \w and|strong="H6629"\w* take \w care|strong="H1239"\w* \w of|strong="H6629"\w* \w them|strong="H3588"\w*.  
