\v 8 \w Je|strong="H07725"\w* \w camperai|strong="H02583"\w* \w autour|strong="H05439"\w* \w de|strong="H01004"\w* \w ma|strong="H07200"\w* \w maison|strong="H01004"\w* \w pour|strong="H01004"\w* \w la|strong="H07200"\w* \w défendre|strong="H05975"\w* ; \w contre|strong="H02583"\w* \w toute|strong="H05674"\w* \w armée|strong="H04675"\w*, \w tout|strong="H01004"\w* \w allant|strong="H03212"\w* \w et|strong="H07725"\w* \w venant|strong="H00935"\w* ; \w et|strong="H07725"\w* \w il|strong="H05674"\w* \w ne|strong="H05869"\w* \w passera|strong="H05674"\w* \w plus|strong="H05750"\w* \w chez|strong="H07725"\w* \w eux|strong="H01004"\w* d’\w oppresseur|strong="H05065"\w*, \w car|strong="H03588"\w* \w maintenant|strong="H06258"\w* \w j|strong="H05869"\w*’\w ai|strong="H05869"\w* \w vu|strong="H07200"\w* \w de|strong="H01004"\w* \w mes|strong="H07200"\w* \w yeux|strong="H05869"\w*.
\v 9 Tressaille d’\w une|strong="H01121"\w* \w grande|strong="H03966"\w* \w joie|strong="H07321"\w*, \w fille|strong="H01323"\w* \w de|strong="H01121"\w* \w Sion|strong="H06726"\w* ! \w Pousse|strong="H06524"\w* \w des|strong="H04428"\w* \w cris|strong="H07321"\w* d’\w allégresse|strong="H01523"\w*, \w fille|strong="H01323"\w* \w de|strong="H01121"\w* \w Jérusalem|strong="H03389"\w* ! \w Voici|strong="H02009"\w* \w que|strong="H01121"\w* \w ton|strong="H03467"\w* \w Roi|strong="H04428"\w* \w vient|strong="H00935"\w* \w à|strong="H01121"\w* \w toi|strong="H06440"\w* ; \w il|strong="H04428"\w* \w est|strong="H04428"\w* \w juste|strong="H06662"\w*, \w lui|strong="H04428"\w*, \w et|strong="H01121"\w* \w protégé|strong="H03467"\w* \w de|strong="H01121"\w* \w Dieu|strong="H00430"\w* ; \w il|strong="H04428"\w* \w est|strong="H04428"\w* \w humble|strong="H06041"\w* ; \w monté|strong="H07392"\w* \w sur|strong="H04428"\w* \w un|strong="H01121"\w* \w âne|strong="H02543"\w*\f + \fr 9:9 \ft \it Sur un âne\it*, par opposition au cheval de guerre (vers. 10) : symbole du caractère pacifique du Roi Messie. Comp. Deut. xvii, 16 ; Is. ii, 6-9. Dans les premiers temps de l’histoire d’Israël, l’âne était la monture des princes et des chefs (Jug. v, 10 ; x, 4). \it Le poulain\it* n’est ici mentionné qu’en vertu du parallélisme synonymique ; ce n’est pas un second animal.\f*, \w et|strong="H01121"\w* \w sur|strong="H04428"\w* \w un|strong="H01121"\w* poulain, \w petit|strong="H01121"\w* d’\w une|strong="H01121"\w* \w ânesse|strong="H00860"\w*.
\p 
\v 10 \w Je|strong="H05315"\w* \w retrancherai|strong="H03772"\w*\f + \fr 9:10 \ft \it Je retrancherai\it*. Cette 1 \sup re\sup* pers. suppose une parole du Messie introduite dans le texte d’une façon très abrupte.\f* d’Ephraïm \w les|strong="H03772"\w* \w chars|strong="H07393"\w* \w de|strong="H07393"\w* \w guerre|strong="H04421"\w*, \w et|strong="H07393"\w* \w de|strong="H07393"\w* \w Jérusalem|strong="H03389"\w* \w les|strong="H03772"\w* \w chevaux|strong="H05483"\w*, \w et|strong="H07393"\w* l’\w arc|strong="H07198"\w* \w du|strong="H03772"\w* \w combat|strong="H04421"\w* \w sera|strong="H03389"\w* \w détruit|strong="H03772"\w*. \w Il|strong="H03389"\w* \w parlera|strong="H01696"\w* \w de|strong="H07393"\w* \w paix|strong="H07965"\w* \w aux|strong="H01696"\w* \w nations|strong="H01471"\w* ; \w sa|strong="H01471"\w* \w domination|strong="H07985"\w* s’étendra d’\w une|strong="H01696"\w* \w mer|strong="H03220"\w* \w à|strong="H01696"\w* l’\w autre|strong="H01471"\w*, \w du|strong="H03772"\w* \w fleuve|strong="H05104"\w* jusqu’\w aux|strong="H01696"\w* \w extrémités|strong="H07098"\w* \w de|strong="H07393"\w* \w la|strong="H01696"\w* \w terre|strong="H00776"\w*.
\p 
\v 11 \w Pour|strong="H07971"\w* \w toi|strong="H06440"\w* \w aussi|strong="H01571"\w*, \w à|strong="H04325"\w* \w cause|strong="H06440"\w* \w du|strong="H04325"\w* \w sang|strong="H01818"\w* \w de|strong="H04325"\w* \w ton|strong="H07971"\w* \w alliance|strong="H01285"\w*\f + \fr 9:11 \ft 11. \ft \it De l’alliance\it* contractée entre Dieu et Israël au Sinaï, et scellée par le sang d’une victime (Exo 24, 8). — \it La fosse sans eau\it* figure le pays de la captivité où l’on souffre sans périr.\f*, \w je|strong="H01571"\w* \w retirerai|strong="H07971"\w* \w tes|strong="H07971"\w* \w captifs|strong="H07622"\w* \w de|strong="H04325"\w* \w la|strong="H07971"\w* \w fosse|strong="H00953"\w* \w sans|strong="H08141"\w* \w eau|strong="H04325"\w*.
\v 12 \w Revenez|strong="H07725"\w* \w au|strong="H07725"\w* \w lieu|strong="H04725"\w* \w fort|strong="H03966"\w*\f + \fr 9:12 \ft \it Au lieu fort\it*, au pays d’Israël.\f*, \w captifs|strong="H07622"\w* d’\w espérance|strong="H08615"\w* ! Aujourd’\w hui|strong="H03117"\w* \w encore|strong="H07725"\w* \w je|strong="H03117"\w* \w le|strong="H07725"\w* \w déclare|strong="H05046"\w* : \w je|strong="H03117"\w* \w te|strong="H07725"\w* \w rendrai|strong="H07725"\w* \w au|strong="H07725"\w* \w double|strong="H04932"\w*.
\p 
