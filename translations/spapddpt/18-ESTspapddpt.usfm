\p \w Entonces|strong="H3588"\w* sus atinados amigos \w y|strong="H3588"\w* \w su|strong="H3588"\w* esposa \w Zeres|strong="H2238"\w* le dijeron: \w Si|strong="H3588"\w* Mardoqueo, \w ante|strong="H6440"\w* \w quien|strong="H3605"\w* comenzaste \w a|strong="H3068"\w* \w caer|strong="H5307"\w*, \w es|strong="H3588"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w descendencia|strong="H2233"\w* \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w judíos|strong="H3064"\w*, \w no|strong="H3808"\w* prevalecerás \w contra|strong="H6440"\w* \w él|strong="H3588"\w*. \w Ciertamente|strong="H3588"\w* \w caerás|strong="H5307"\w* \w ante|strong="H6440"\w* \w él|strong="H3588"\w*.
\v 14 \w Aún|strong="H5750"\w* \w hablaban|strong="H1696"\w* ellos \w con|strong="H5973"\w* \w él|strong="H5973"\w*, cuando \w llegaron|strong="H5060"\w* \w los|strong="H5973"\w* servidores \w del|strong="H5973"\w* palacio \w del|strong="H5973"\w* \w rey|strong="H4428"\w* y se apresuraron \w a|strong="H3068"\w* llevar \w a|strong="H3068"\w* \w Amán|strong="H2001"\w* \w al|strong="H4428"\w* \w banquete|strong="H4960"\w* que Ester preparó.
\c 7
