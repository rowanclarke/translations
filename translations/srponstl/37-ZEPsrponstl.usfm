\id ZEP - Biblica® Open New Serbian Translation Latin 2017 
\h Knjiga proroka Sofonije 
\toc1 Knjiga proroka Sofonije 
\toc2 Knjiga proroka Sofonije 
\toc3 Sof 
\mt1 Knjiga proroka Sofonije 
\c 1  
\p  
\v 1 Reč Gospodnja koja je došla Sofoniji, Kušijevom sinu i potomku Godolije, Amarije i Jezekije u vreme Amonovog sina Josije, cara Jude. 
\s1 Sud cele zemlje na dan Gospodnji 
\q1  
\v 2 „Zbrisaću, dokrajčiću 
\q2 sve sa lica zemlje 
\q3 – govori Gospod. 
\q1  
\v 3 Dokrajčiću i čoveka i zver, 
\q2 dokrajčiću ptice s neba, 
\q2 ribe iz mora 
\q2 i pakosti sa sve pakosnima. 
\b  
\q1 Istrebiću ljude sa lica zemlje 
\q2 – govori Gospod. 
\b  
\q1  
\v 4 Podignuću svoju ruku na Judu 
\q2 i na sav živalj Jerusalima. 
\q1 Istrebiću sa ovog mesta Valov ostatak 
\q2 i spomen na idolopokloničke sveštenike 
\q2 s drugim sveštenicima; 
\q1  
\v 5 one što se po krovovima 
\q2 klanjaju vojsci nebeskoj, 
\q1 one koji se klanjaju i zaklinju Gospodu 
\q2 ali se zaklinju i Molohu\f + \fr 1,5 \ft Ili: \fqa Malhomu.\f*; 
\q1  
\v 6 one što se okreću od Gospoda, 
\q2 one što ne traže Gospoda i za njega ne pitaju.“ 
\b  
\q1  
\v 7 Tišina pred Gospodom Bogom 
\q2 jer je blizu dan Gospodnji! 
\q1 Spremio je Gospod žrtvu, 
\q2 sazvao je goste svoje. 
\b  
\q1  
\v 8 „A na dan Gospodnje žrtve 
\q2 sudiću glavare, 
\q2 careve sinove 
\q1 i sve koji nose 
\q2 odelo tuđinca. 
\q1  
\v 9 Kazniću sve koji toga dana 
\q2 preskaču preko praga, 
\q1 koji kuće svojih gospodara 
\q2 pune nasiljem i prevarom. 
\b  
\q1  
\v 10 Toga će se dana čuti 
\q2 – govori Gospod – 
\q1 plač nevolje sa Ribljih vrata, 
\q2 zapomaganje sa drugog kraja 
\q2 i velika lomljava sa brda. 
\q1  
\v 11 Kukajte, o, stanovnici Maktesa, 
\q2 jer gine sav narod koji trguje, 
\q2 biće pobijeni svi koji mere srebro. 
\q1  
\v 12 U to vreme ću svetiljkama da pretražim Jerusalim. 
\q2 Sudiću narodu poleglom \add ko vino\add* po talogu svome, 
\q1 koji u srcu svom govori: 
\q2 ’Gospod ne čini dobro, a ni zlo ne čini!’ 
\q1  
\v 13 Blago će im plen postati 
\q2 i opusteće im kuće. 
\q1 Kuće će zidati, 
\q2 ali živeti u njima neće, 
\q1 sadiće vinograde, 
\q2 ali vino njihovo neće piti.“ 
\b  
\q1  
\v 14 Blizu je veliki dan Gospodnji! 
\q2 Blizu je i sve je bliži i bliži! 
\q1 Gorak je povik dana Gospodnjeg 
\q2 i eno viče ratnik. 
\q1  
\v 15 Taj dan će biti dan gneva, 
\q2 dan nevolje i stradanja, 
\q3 dan razaranja i pustošenja, 
\q2 dan mrklog mraka, 
\q3 dan oblaka i guste tame; 
\q2  
\v 16 dan truba i bojnog pokliča 
\q1 nad gradovima utvrđenim, 
\q2 nad kulama visokim. 
\b  
\q1  
\v 17 „Naneću bol ljudima 
\q2 pa će ići kao da su slepi, 
\q2 jer su Gospodu sagrešili. 
\q1 Prosuće se krv njihova kao prah 
\q2 i kao đubrivo njihove utrobe. 
\q1  
\v 18 Ni njihovo srebro ni zlato njihovo 
\q2 neće moći da ih spase 
\q2 na dan gneva Gospodnjeg.“ 
\b  
\q1 Plamen njegove revnosti 
\q2 proždraće svu zemlju, 
\q1 jer će sigurno i strašno dokrajčiti 
\q2 sav živalj zemaljski. 
\c 2  
\s1 Juda i Jerusalim osuđeni sa narodima 
\s2 Juda sabrana na pokajanje 
\q1  
\v 1 Saberite se! Saberite se, 
\q2 o, narode koji stida nemaš, 
\q1  
\v 2 pre nego se osuda ostvari 
\q2 i dan prođe kao pleva; 
\q1 pre nego na vas dođe 
\q2 plamen gneva Gospodnjeg, 
\q1 pre nego na vas dođe 
\q2 dan gneva Gospodnjeg. 
\q1  
\v 3 Tražite Gospoda, o, svi ponizni u zemlji, 
\q2 koji izvršavate njegove sudove. 
\q1 Tražite pravednost! Tražite poniznost, 
\q2 pa možda na dan gneva Gospodnjeg 
\q2 skriveni budete. 
\s2 Filisteja 
\q1  
\v 4 Jer Gaza će biti napuštena, 
\q2 Askalon će pustoš postati, 
\q1 Azotu će narod isterati u po bela dana, 
\q2 a Akaron će biti iskorenjen. 
\q1  
\v 5 Jao Herećanima, 
\q2 stanovnicima primorskog kraja! 
\q1 O, Hanane, 
\q2 reč je Gospodnja protiv tebe, 
\q1 zemljo filistejska: 
\q2 „Uništiću ti svakog živog!“ 
\q1  
\v 6 Primorski će kraj postati pašnjaci, 
\q2 pastirske livade 
\q2 i torovi za ovce. 
\q1  
\v 7 Zato će ovaj kraj pripasti 
\q2 ostatku doma Judinog 
\q2 i po njemu će se napasati. 
\q1 Uveče će legati 
\q2 po kućama Askalona 
\q1 jer će ih se setiti Gospod, Bog njihov, 
\q2 i vratiće njihove izgnanike. 
\s2 Moav i Amon 
\q1  
\v 8 „Čuo sam ruganje Moavaca 
\q2 i ponižavanje Amonaca. 
\q1 Oni hule na moj narod, 
\q2 osilili su se na njihovoj granici. 
\q1  
\v 9 Zato, života mi moga 
\q2 – govori Gospod nad vojskama, 
\q2 Bog Izrailjev – 
\q1 Moavci će biti kao Sodoma, 
\q2 a Amonci kao Gomora: 
\q1 carstvo kopriva, slana jama 
\q2 i večna pustoš. 
\q1 Poharaće ih ostatak mog naroda, 
\q2 preostali od moga naroda će ih zaposesti.“ 
\b  
\q1  
\v 10 I ovo im je umesto njihovog ponosa, 
\q2 jer su osiono ponižavali 
\q2 narod Gospoda nad vojskama. 
\q1  
\v 11 Biće Gospod strašan prema njima 
\q2 jer će pomesti sve bogove zemaljske. 
\q1 Sva ostrva naroda će mu se pokloniti, 
\q2 baš svako sa svog mesta. 
\s2 Kuš 
\q1  
\v 12 „A i vi, o, Kušani, 
\q2 bićete sasečeni mačem mojim!“ 
\s2 Asirija 
\q1  
\v 13 Pružiće on ruku svoju na sever 
\q2 i uništiće Asiriju. 
\q1 Ninivu će učiniti pustarom 
\q2 sprženom kao pustinja. 
\q1  
\v 14 Krda će ležati po njoj 
\q2 i sve vrste životinja. 
\q1 Buljina i sova 
\q2 po njenim stubovima noć provode, 
\q2 huču na prozoru. 
\q1 Razvaljen će biti prag 
\q2 jer je on izlomio dasku od kedra. 
\q1  
\v 15 Takav će biti oholi grad 
\q2 što spokojno počiva, 
\q1 koji u svom srcu kaže: 
\q2 „Ja jedini i niko kao ja!“ 
\q1 Kako si postao pustoš, 
\q2 brlog svake zveri! 
\q1 Ko god mimo njega prođe zviždaće, 
\q2 odmahnuće rukom. 
\c 3  
\s2 Jerusalim 
\q1  
\v 1 Jao poganom i oskrnavljenom gradu siledžiji! 
\q1  
\v 2 On ne sluša glas 
\q2 i ne prihvata prekor Gospodnji. 
\q1 Ne pouzdaje se u Boga svoga 
\q2 i ne prilazi mu. 
\q1  
\v 3 Usred njega glavari njegovi 
\q2 su lavovi što riču, 
\q1 sudije su mu noćni vuci 
\q2 što do jutra sve kosti oglođu. 
\q1  
\v 4 Njegovi proroci su bahati, 
\q2 ljudi izdajnici. 
\q1 Sveštenici njegovi svetinju skrnave 
\q2 i Zakon krše. 
\q1  
\v 5 Pravedan je Gospod usred njega! 
\q2 On ne čini nepravdu. 
\q1 Svako jutro svoju pravdu daje 
\q2 i kad svane on se ne povlači. 
\q2 Ali zlotvor ni tad za sramotu ne zna. 
\s2 Jerusalim se ne kaje 
\q1  
\v 6 „Zatro sam narode 
\q2 i srušio im kule. 
\q1 Ulice sam im opustošio 
\q2 da ni prolaznika nema. 
\q1 Gradove im zarušio 
\q2 i nikoga nema, 
\q2 nema stanovnika. 
\q1  
\v 7 A rekoh: 
\q2 ’Svakako ćeš me se uplašiti, 
\q2 prihvatićeš prekor.’ 
\q1 Tada mu se neće porušiti prebivalište 
\q2 svim onim što sam naumio za njega. 
\q1 Ipak, uporno su grešili 
\q2 svim delima svojim. 
\q1  
\v 8 Zato me čekajte 
\q2 – govori Gospod – 
\q2 do dana kada ću se dići zbog plena. 
\q1 Jer je moja odluka da okupim narode, 
\q2 da saberem carstva 
\q1 i na njih izlijem svoju jarost 
\q2 i sav plamen gneva svoga. 
\q1 Tako će u vatri revnosti moje 
\q2 sva zemlja biti progutana. 
\s1 Obnova ostatka Izrailja 
\q1  
\v 9 Tada ću da dam narodima čista usta 
\q2 da svaki od njih priziva ime Gospodnje 
\q2 i rame uz rame mu služe. 
\q1  
\v 10 S druge strane, od reka kušanskih, 
\q2 doneće mi žitne žrtve moji molioci, 
\q2 ćerka mojih rasejanih. 
\q1  
\v 11 Nećeš se stideti toga dana svih svojih postupaka 
\q2 kojima si se bunio protiv mene. 
\q1 Tada ću ukloniti od tebe one ohole, 
\q2 tvoje ponosite, 
\q1 pa se više nećeš bahatiti 
\q2 na mojoj svetoj gori. 
\q1  
\v 12 U tebi ću ostaviti 
\q2 narod krotak i siromašan, 
\q1 i oni će utočište naći 
\q2 u imenu Gospodnjem. 
\q1  
\v 13 Ostatak Izrailja neće činiti nepravdu 
\q2 i laži neće govoriti. 
\q1 Neće im u ustima biti jezik obmane 
\q2 nego će se napasati i počivaće. 
\q1 Neće biti nikog da ih plaši.“ 
\b  
\q1  
\v 14 Kliči, ćerko sionska! 
\q2 Podvikuj, Izrailju! 
\q1 Raduj se i veličaj od sveg srca, 
\q2 o, ćerko jerusalimska! 
\q1  
\v 15 Uklonio je Gospod presudu protiv tebe, 
\q2 pomeo je dušmane tvoje. 
\q1 Car Izrailja – Gospod je u sredini tvojoj! 
\q2 Od zla se ti više ne plaši. 
\q1  
\v 16 Tog dana će se reći Jerusalimu: 
\q2 „O, Sione, ne plaši se! 
\q2 Neka ti ruke ne klonu! 
\q1  
\v 17 Gospod, Bog tvoj je usred tebe, 
\q2 ratnik što ti pobedu daje. 
\q1 Radovaće se silno zbog tebe, 
\q2 utišaće te ljubavlju svojom. 
\q2 Klicaće zbog tebe radosnim povikom.“ 
\b  
\q1  
\v 18 „Ojađene, odstranjene od praznika 
\q2 ja ću da okupim. 
\q1 Bili su daleko od tebe, 
\q2 obremenjeni sramotom. 
\q1  
\v 19 Evo, okrećem se svim tvojim tlačiteljima u vreme ovo. 
\q2 Spašću hrome i sabraću proterane. 
\q1 Daću čast i ime osramoćenima 
\q2 što su bili po celoj zemlji. 
\q1  
\v 20 Dovešću vas u ono vreme, 
\q2 u to vreme ja ću vas sabrati. 
\q1 Jer ja ću vam dati i ime i čast 
\q2 među svim zemaljskim narodima, 
\q2 kada na vaše oči vratim izgnane vaše“ – 
\q3 kaže Gospod.