\v 6 “\w And|strong="H4428"\w* \w I|strong="H5921"\w* \w have|strong="H4428"\w* anointed \w My|strong="H5921"\w* \w King|strong="H4428"\w*, || \w On|strong="H5921"\w* \w Zion|strong="H6726"\w*—\w My|strong="H5921"\w* \w holy|strong="H6944"\w* \w hill|strong="H2022"\w*.”
\v 7 \w I|strong="H3117"\w* \w declare|strong="H5608"\w* \w concerning|strong="H3068"\w* \w a|strong="H3068"\w* \w statute|strong="H2706"\w*: \w YHWH|strong="H3068"\w* said \w to|strong="H3068"\w* \w me|strong="H3205"\w*, “\w You|strong="H3117"\w* [\w are|strong="H3117"\w*] \w My|strong="H3068"\w* \w Son|strong="H1121"\w*, \w today|strong="H3117"\w* \w I|strong="H3117"\w* \w have|strong="H3068"\w* \w brought|strong="H3205"\w* \w You|strong="H3117"\w* \w forth|strong="H3205"\w*.
