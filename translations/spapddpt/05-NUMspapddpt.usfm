\v 2 \w Se|strong="H1961"\w* reunieron \w contra|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* Aarón \w porque|strong="H5921"\w* \w no|strong="H3808"\w* \w había|strong="H1961"\w* \w agua|strong="H4325"\w* \w para|strong="H5921"\w* \w la|strong="H5921"\w* congregación.  
\v 3 \w El|strong="H5973"\w* \w pueblo|strong="H5971"\w* contendió \w contra|strong="H5973"\w* \w Moisés|strong="H4872"\w*: ¡\w Ojalá|strong="H3863"\w* hubiéramos perecido cuando nuestros hermanos murieron \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*!  
\v 4 ¿\w Por|strong="H2088"\w* \w qué|strong="H4100"\w* trajiste \w a|strong="H3068"\w* la \w congregación|strong="H6951"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w desierto|strong="H4057"\w* para \w que|strong="H4100"\w* nosotros y nuestro ganado \w muramos|strong="H4191"\w* \w aquí|strong="H2088"\w*?  
\v 5 ¿\w Y|strong="H3068"\w* \w por|strong="H2088"\w* \w qué|strong="H4100"\w* \w nos|strong="H4100"\w* \w hicieron|strong="H4100"\w* salir \w de|strong="H4325"\w* \w Egipto|strong="H4714"\w* para traernos \w a|strong="H3068"\w* \w este|strong="H2088"\w* miserable \w lugar|strong="H4725"\w*? \w No|strong="H3808"\w* \w es|strong="H2088"\w* \w lugar|strong="H4725"\w* \w de|strong="H4325"\w* sementeras, \w de|strong="H4325"\w* \w higueras|strong="H8384"\w*, \w de|strong="H4325"\w* \w viñas|strong="H1612"\w*, \w ni|strong="H3808"\w* \w de|strong="H4325"\w* \w granadas|strong="H7416"\w*. \w Ni|strong="H3808"\w* siquiera hay \w agua|strong="H4325"\w* para \w beber|strong="H8354"\w*.   
\p
\v 6 \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* Aarón \w se|strong="H5921"\w* fueron \w de|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w congregación|strong="H6951"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w del|strong="H5921"\w* Tabernáculo \w de|strong="H5921"\w* \w Reunión|strong="H6951"\w*. \w Cayeron|strong="H5307"\w* \w sobre|strong="H5921"\w* sus \w rostros|strong="H6440"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w se|strong="H5921"\w* \w mostró|strong="H7200"\w* \w a|strong="H3068"\w* \w ellos|strong="H5921"\w*.  
\v 7 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 8 \wj \+w Toma|strong="H3947"\+w* la \+w vara|strong="H4294"\+w*. Tú y tu hermano Aarón reúnan la asamblea. \+w Hablen|strong="H1696"\+w* \+w a|strong="H3068"\+w* la \+w peña|strong="H5553"\+w* ante los \+w ojos|strong="H5869"\+w* \+w de|strong="H4480"\+w* \+w ellos|strong="H4480"\+w*, y \+w ella|strong="H4480"\+w* \+w dará|strong="H5414"\+w* sus \+w aguas|strong="H4325"\+w*. Les \+w sacarás|strong="H3318"\+w* \+w agua|strong="H4325"\+w* \+w de|strong="H4480"\+w* la \+w peña|strong="H5553"\+w* y \+w darás|strong="H5414"\+w* \+w de|strong="H4480"\+w* \+w beber|strong="H8248"\+w* \+w a|strong="H3068"\+w* la congregación y \+w a|strong="H3068"\+w* sus ganados.\wj*   
\p
\v 9 \w Moisés|strong="H4872"\w* \w tomó|strong="H3947"\w* la \w vara|strong="H4294"\w* \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, como le \w ordenó|strong="H6680"\w*.  
\v 10 \w Moisés|strong="H4872"\w* y Aarón congregaron la asamblea frente \w a|strong="H3068"\w* la \w peña|strong="H5553"\w*, y él les dijo: \w Oigan|strong="H8085"\w* \w ahora|strong="H4994"\w*, \w rebeldes|strong="H4784"\w*. ¿Les sacaremos \w agua|strong="H4325"\w* \w de|strong="H4480"\w* \w esta|strong="H2088"\w* \w peña|strong="H5553"\w*?  
\v 11 Entonces \w Moisés|strong="H4872"\w* \w alzó|strong="H7311"\w* su \w mano|strong="H3027"\w* y golpeó la \w peña|strong="H5553"\w* con su \w vara|strong="H4294"\w* \w dos|strong="H6471"\w* \w veces|strong="H6471"\w*, y \w salió|strong="H3318"\w* \w agua|strong="H4325"\w* abundante y \w bebieron|strong="H8354"\w*, tanto la congregación como su ganado.   
\p
\v 12 Pero \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón: \wj \+w Por|strong="H3282"\+w* \+w cuanto|strong="H3282"\+w* \+w no|strong="H3808"\+w* creyeron en Mí \+w para|strong="H5414"\+w* santificarme \+w a|strong="H3068"\+w* vista \+w de|strong="H1121"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*, \+w no|strong="H3808"\+w* introducirán \+w a|strong="H3068"\+w* \+w esta|strong="H2088"\+w* \+w congregación|strong="H6951"\+w* en la tierra \+w que|strong="H3808"\+w* les \+w di|strong="H5414"\+w*.\wj*   
\p
\v 13 \w Estas|strong="H1992"\w* son \w las|strong="H1992"\w* \w aguas|strong="H4325"\w* \w de|strong="H1121"\w* Meriba donde \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w contendieron|strong="H7378"\w* \w contra|strong="H3478"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, y \w Él|strong="H1121"\w* manifestó \w su|strong="H1992"\w* santidad entre \w ellos|strong="H1992"\w*.   
\p
\v 14 \w Moisés|strong="H4872"\w* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* desde \w Cades|strong="H6946"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de Edom, \w y|strong="H3541"\w* dijeron: Tu hermano \w Israel|strong="H3478"\w* dice: Tú \w sabes|strong="H3045"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* calamidad \w que|strong="H3045"\w* nos aconteció,  
\v 15 cómo nuestros antepasados \w bajaron|strong="H3381"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, cómo estuvimos en \w Egipto|strong="H4714"\w* largo \w tiempo|strong="H3117"\w* y cómo \w los|strong="H3427"\w* \w egipcios|strong="H4714"\w* nos maltrataron \w a|strong="H3068"\w* nosotros y \w a|strong="H3068"\w* nuestros antepasados.  
\v 16 Pero cuando clamamos \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w oyó|strong="H8085"\w* nuestra \w voz|strong="H6963"\w*, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* su \w Ángel|strong="H4397"\w* y nos \w sacó|strong="H3318"\w* de \w Egipto|strong="H4714"\w*. \w Ahora|strong="H2009"\w*, \w mira|strong="H2009"\w*, estamos \w en|strong="H3318"\w* \w Cades|strong="H6946"\w*, \w ciudad|strong="H5892"\w* que se encuentra \w en|strong="H3318"\w* el \w extremo|strong="H7097"\w* de tu territorio.  
\v 17 Te rogamos \w que|strong="H3808"\w* nos permitas \w pasar|strong="H5674"\w* \w por|strong="H1870"\w* tu tierra. \w No|strong="H3808"\w* \w pasaremos|strong="H5674"\w* \w por|strong="H1870"\w* labranzas \w ni|strong="H3808"\w* \w viñas|strong="H3754"\w*, \w ni|strong="H3808"\w* \w beberemos|strong="H8354"\w* \w agua|strong="H4325"\w* \w de|strong="H5704"\w* \w ningún|strong="H3808"\w* pozo. \w Iremos|strong="H3212"\w* \w por|strong="H1870"\w* \w el|strong="H5674"\w* \w camino|strong="H1870"\w* \w real|strong="H4428"\w*, \w sin|strong="H3808"\w* \w apartarnos|strong="H5186"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w derecha|strong="H3225"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w izquierda|strong="H8040"\w*, \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* \w pasemos|strong="H5674"\w* tu territorio.   
\p
\v 18 Pero Edom le respondió: \w No|strong="H3808"\w* \w pasarás|strong="H5674"\w* por mi tierra. De otro modo, \w saldré|strong="H3318"\w* \w contra|strong="H7125"\w* ti con la \w espada|strong="H2719"\w*.   
\p
\v 19 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* respondieron: \w Iremos|strong="H5927"\w* \w por|strong="H1697"\w* \w el|strong="H1121"\w* \w camino|strong="H4546"\w* real, y si nosotros y nuestros \w ganados|strong="H4735"\w* \w bebemos|strong="H8354"\w* tus \w aguas|strong="H4325"\w*, pagaremos \w el|strong="H1121"\w* precio. \w Solo|strong="H7535"\w* se trata \w de|strong="H1121"\w* \w pasar|strong="H5674"\w* \w a|strong="H3068"\w* \w pie|strong="H7272"\w*.  
\v 20 Pero \w él|strong="H5674"\w* dijo: \w No|strong="H3808"\w* \w pasarás|strong="H5674"\w*. \w Y|strong="H3068"\w* Edom \w salió|strong="H3318"\w* \w contra|strong="H7125"\w* \w él|strong="H5674"\w* con mucho \w pueblo|strong="H5971"\w* y \w mano|strong="H3027"\w* \w fuerte|strong="H2389"\w*.  
\v 21 Así Edom \w se|strong="H5921"\w* negó \w a|strong="H3068"\w* \w dejar|strong="H5414"\w* \w pasar|strong="H5674"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w por|strong="H5921"\w* su territorio, \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w se|strong="H5921"\w* desvió \w de|strong="H5921"\w* \w él|strong="H5921"\w*.   
\p
\v 22 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w toda|strong="H3605"\w* aquella congregación, \w salieron|strong="H5265"\w* \w de|strong="H1121"\w* \w Cades|strong="H6946"\w*, y fueron hacia \w la|strong="H3605"\w* montaña Hor.   
\s1 Muerte de Aarón  
\p
\v 23 \nd \+w Yavé|strong="H3068"\+w*\nd* habló \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w y|strong="H5921"\w* Aarón \w en|strong="H5921"\w* \w la|strong="H5921"\w* montaña Hor, \w en|strong="H5921"\w* \w los|strong="H5921"\w* confines \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* Edom:  
\v 24 \wj Aarón \+w será|strong="H3808"\+w* reunido \+w a|strong="H3068"\+w* \+w su|strong="H3588"\+w* \+w pueblo|strong="H5971"\+w*, \+w pues|strong="H3588"\+w* \+w no|strong="H3808"\+w* entrará \+w en|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w di|strong="H5414"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w*, \+w por|strong="H5921"\+w* \+w cuanto|strong="H3588"\+w* fueron \+w rebeldes|strong="H4784"\+w* \+w a|strong="H3068"\+w* \+w mi|strong="H5921"\+w* \+w Palabra|strong="H6310"\+w* \+w en|strong="H5921"\+w* \+w las|strong="H5921"\+w* \+w aguas|strong="H4325"\+w* \+w de|strong="H5921"\+w* Meriba.\wj*  
\v 25 \wj \+w Toma|strong="H3947"\+w* \+w a|strong="H3068"\+w* Aarón y \+w a|strong="H3068"\+w* su \+w hijo|strong="H1121"\+w* Eleazar, y hazlos \+w subir|strong="H5927"\+w* \+w a|strong="H3068"\+w* la montaña Hor.\wj*  
\v 26 \wj Quítale \+w a|strong="H3068"\+w* Aarón sus ropas, y viste con ellas \+w a|strong="H3068"\+w* su \+w hijo|strong="H1121"\+w* Eleazar. Aarón será reunido \+w a|strong="H3068"\+w* su pueblo y \+w morirá|strong="H4191"\+w* \+w allí|strong="H8033"\+w*.\wj*   
\p
\v 27 \w Moisés|strong="H4872"\w* \w hizo|strong="H6213"\w* como \nd \+w Yavé|strong="H3068"\+w*\nd* \w le|strong="H5869"\w* \w mandó|strong="H6680"\w*, y \w subieron|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* montaña Hor ante \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación.  
\v 28 Entonces \w Moisés|strong="H4872"\w* despojó \w a|strong="H3068"\w* Aarón \w de|strong="H4480"\w* sus ropas y \w vistió|strong="H3847"\w* \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* Eleazar \w con|strong="H4480"\w* ellas. \w Y|strong="H3068"\w* Aarón \w murió|strong="H4191"\w* \w allí|strong="H8033"\w* \w en|strong="H4480"\w* la \w cumbre|strong="H7218"\w* \w de|strong="H4480"\w* la montaña. Luego \w Moisés|strong="H4872"\w* y Eleazar \w descendieron|strong="H3381"\w* \w de|strong="H4480"\w* la montaña.  
\v 29 Al \w ver|strong="H7200"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación \w que|strong="H3588"\w* Aarón falleció, \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* le hizo duelo durante 30 \w días|strong="H3117"\w*.   
\c 21  
\s1 La Serpiente de Bronce  
\p
\v 1 \w Cuando|strong="H3588"\w* \w el|strong="H3588"\w* \w cananeo|strong="H3669"\w*, \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Arad|strong="H6166"\w*, quien \w habitaba|strong="H3427"\w* \w en|strong="H4480"\w* \w el|strong="H3588"\w* Neguev, \w oyó|strong="H8085"\w* \w que|strong="H3588"\w* \w Israel|strong="H3478"\w* iba \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H4480"\w* Atarim, combatió \w contra|strong="H4480"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* tomó \w cautivos|strong="H7628"\w* \w de|strong="H4480"\w* \w él|strong="H3588"\w*.  
\v 2 Entonces \w Israel|strong="H3478"\w* \w hizo|strong="H5088"\w* \w voto|strong="H5087"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*: Si en verdad entregas \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* en mi \w mano|strong="H3027"\w*, yo destruiré \w por|strong="H2088"\w* completo sus \w ciudades|strong="H5892"\w*.  
\v 3 \nd \+w Yavé|strong="H3068"\+w*\nd* \w escuchó|strong="H8085"\w* la \w voz|strong="H6963"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w* y le \w entregó|strong="H5414"\w* al \w cananeo|strong="H3669"\w*. Los destruyó \w a|strong="H3068"\w* ellos y \w a|strong="H3068"\w* sus \w ciudades|strong="H5892"\w*. \w Llamó|strong="H7121"\w* aquel \w lugar|strong="H4725"\w* \w Horma|strong="H2767"\w*.   
\p
\v 4 \w Salieron|strong="H5265"\w* \w de|strong="H5971"\w* la montaña Hor con dirección al \w mar|strong="H3220"\w* Rojo \w para|strong="H5971"\w* rodear la tierra \w de|strong="H5971"\w* Edom. Pero en el \w camino|strong="H1870"\w* el \w ánimo|strong="H5315"\w* del \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* impacientó.  
\v 5 \w Entonces|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w habló|strong="H1696"\w* contra \nd ʼElohim\nd* \w y|strong="H3588"\w* contra \w Moisés|strong="H4872"\w*: ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w nos|strong="H4100"\w* sacaron \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w* \w para|strong="H3588"\w* \w morir|strong="H4191"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w*? \w Pues|strong="H3588"\w* \w no|strong="H3588"\w* hay alimento ni \w agua|strong="H4325"\w*, \w y|strong="H3588"\w* detestamos esta miserable \w comida|strong="H3899"\w*.   
\p
\v 6 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* \w envió|strong="H7971"\w* entre el \w pueblo|strong="H5971"\w* \w serpientes|strong="H5175"\w* \w ardientes|strong="H8314"\w* \w que|strong="H5971"\w* mordían al \w pueblo|strong="H5971"\w*. \w Murió|strong="H4191"\w* \w mucha|strong="H7227"\w* \w gente|strong="H5971"\w* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*.  
\v 7 \w El|strong="H5921"\w* \w pueblo|strong="H5971"\w* fue \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w y|strong="H3588"\w* \w dijeron|strong="H1696"\w*: \w Pecamos|strong="H2398"\w* \w al|strong="H5921"\w* \w hablar|strong="H1696"\w* \w contra|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H3588"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*. ¡\w Habla|strong="H1696"\w* \w con|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w quite|strong="H5493"\w* \w de|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w las|strong="H5921"\w* \w serpientes|strong="H5175"\w*! \w Y|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w oró|strong="H6419"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w*.   
\p
\v 8 \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj \+w Hazte|strong="H6213"\+w* una serpiente ardiente \+w y|strong="H5921"\+w* ponla \+w sobre|strong="H5921"\+w* un asta, \+w y|strong="H5921"\+w* \+w cualquiera|strong="H3605"\+w* \+w que|strong="H5921"\+w* \+w sea|strong="H1961"\+w* mordido \+w y|strong="H5921"\+w* \+w mire|strong="H7200"\+w* \+w a|strong="H3068"\+w* \+w ella|strong="H5921"\+w*, \+w vivirá|strong="H2425"\+w*.\wj*  
\v 9 \w Moisés|strong="H4872"\w* \w hizo|strong="H6213"\w* una \w serpiente|strong="H5175"\w* \w de|strong="H5921"\w* bronce \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w puso|strong="H7760"\w* \w sobre|strong="H5921"\w* un asta. \w Cuando|strong="H1961"\w* una \w serpiente|strong="H5175"\w* \w mordía|strong="H5391"\w* \w a|strong="H3068"\w* alguno, \w miraba|strong="H5027"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w serpiente|strong="H5175"\w* \w de|strong="H5921"\w* bronce \w y|strong="H5921"\w* vivía.   
\p
\v 10 \w Salieron|strong="H5265"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y acamparon en Obot.  
\v 11 \w Salieron|strong="H5265"\w* \w de|strong="H5921"\w* Obot, \w y|strong="H5921"\w* acamparon \w en|strong="H5921"\w* Ije-Abarim, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w* \w que|strong="H5921"\w* \w está|strong="H5921"\w* frente \w a|strong="H3068"\w* \w Moab|strong="H4124"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w oriente|strong="H4217"\w*.  
\v 12 \w Salieron|strong="H5265"\w* de \w allí|strong="H8033"\w* y acamparon en el valle de Zared.  
