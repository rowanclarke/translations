\id HOS  
\h Knjiga proroka Osije 
\toc1 Knjiga proroka Osije 
\toc2 Osija 
\toc3 Os 
\mt1 Knjiga proroka Osije  
\c 1  
\s1 Izrailjevo idolopoklonstvo i kazna.  
\p
\v 1 Reč Gospodnja koja dođe Osiji sinu Veirijevom za vremena Ozije, Joatama, Ahaza i Jezekije careva Judinih i za vremena Jerovoama sina Joasovog cara Izrailjevog.   
\b  
\p
\v 2 Kad Gospod poče govoriti Osiji, reče Gospod Osiji: Idi, oženi se kurvom, i rodi kopilad, jer se zemlja prokurva odstupivši od Gospoda.  
\v 3 I otide, i uze Gomeru, kćer divlaimsku, koja zatrudne i rodi mu sina.   
\p
\v 4 Tada mu reče Gospod: Nadeni mu ime Jezrael; jer još malo, pa ću pohoditi krv jezraelsku na domu Jujevom i ukinuću carstvo doma Izrailjevog.  
\v 5 I u to ću vreme slomiti luk Izrailjev u dolini jezraelskoj.   
\p
\v 6 I ona opet zatrudne i rodi kćer; i Gospod mu reče: Nadeni joj ime Loruhama: jer se više neću smilovati na dom Izrailjev, nego ću ih ukinuti sasvim.  
\v 7 A na dom Judin smilovaću se, i izbaviću ih Gospodom Bogom njihovim, a neću ih izbaviti lukom ni mačem ni ratom ni konjima ni konjicima.   
\p
\v 8 Potom odbivši od sise Loruhamu opet zatrudne i rodi sina.  
\v 9 I reče Gospod: Nadeni mu ime Loamija; jer vi niste moj narod, niti ću ja biti vaš.   
\p
\v 10 Ali će ipak broj sinova Izrailjevih biti kao pesak morski, koji se ne može izmeriti ni izbrojati; i mesto da im se reče: Niste moj narod, reći će im se: Sinovi Boga Živoga.  
\v 11 I sabraće se sinovi Judini i sinovi Izrailjevi u jedno, i postaviće sebi jednog poglavara i otići će iz zemlje, jer će biti velik dan jezraelski.   
\c 2  
\s1 Savez Božiji s njegovim narodom raskinut i obnovljen.  
\p
\v 1 Recite braći svojoj: Narode moj; i sestrama svojim: Pomilovana.   
\b  
\q1
\v 2 Prite se s materom svojom, prite se,  
\q2 jer mi nije žena, niti sam joj ja muž;  
\q1 neka odbaci kurvarstva svoja od lica svog,  
\q2 i preljube svoje od dojaka svojih,   
\q1
\v 3 Da je ne bih svukao golu  
\q2 i učinio je kakva je bila onaj dan kad se rodila,  
\q1 i da je ne bih postavio da bude kao pustinja  
\q2 i obratio je da bude kao zemlja sasušena,  
\q2 i umorio je žeđu.   
\q1
\v 4 I neću se smilovati na decu njenu,  
\q2 jer su kopilad.   
\q1
\v 5 Jer se mati njihova kurva,  
\q2 sramoti se roditeljka njihova;  
\q1 jer govori: Ići ću za milosnicima svojim  
\q2 koji mi daju hleb moj i vodu moju,  
\q1 vunu moju i lan moj,  
\q2 ulje moje i piće moje.   
\q1
\v 6 Zato evo ja ću joj zagraditi put trnjem  
\q2 i zazidaću zidom da ne nađe staza svojih.   
\q1
\v 7 I trčaće za svojim milosnicima,  
\q2 ali ih neće stignuti;  
\q1 i tražiće ih,  
\q2 ali ih neće naći;  
\q1 pa će reći: Idem da se vratim k prvom mužu svom,  
\q2 jer mi beše bolje onda nego sada.   
\q1
\v 8 Jer ona ne zna da sam joj ja davao žito i vino i ulje,  
\q2 i umnožavao joj srebro i zlato,  
\q2 od kog načiniše Vala.   
\q1
\v 9 Zato ću uzeti natrag žito svoje, kad bude vreme,  
\q2 i vino svoje, kad bude vreme,  
\q1 i uzeću vunu svoju i lan svoj,  
\q2 kojim bi pokrivala golotinju svoju.   
\q1
\v 10 I otkriću rugobu njenu pred milosnicima njenim,  
\q2 i niko je neće izbaviti iz moje ruke.   
\q1
\v 11 I ukinuću svaku radost njenu,  
\q2 svetkovine njene,  
\q2 mladine njene i subote njene i sve praznike njene.   
\q1
\v 12 I potrću čokote njene i smokve,  
\q2 za koje govori: Plata su mi,  
\q2 što mi dadoše milosnici moji;  
\q1 i obratiću ih u šumu  
\q2 da ih jede zverje poljsko.   
\q1
\v 13 I pohodiću na njoj dane valimske,  
\q2 u koje im je kadila  
\q2 i kitila se obocima i grivnama,  
\q1 i išla za svojim milosnicima,  
\q2 i mene zaboravila,  
\q2 govori Gospod.   
\b  
\q1
\v 14 Ali evo, ja ću je primamiti  
\q2 i odvešću je u pustinju,  
\q2 i govoriću s njom lepo.   
\q1
\v 15 I daću joj vinograde njene od tog mesta,  
\q2 i dolinu Ahor za vrata nadanju,  
\q1 i onde će pevati kao za mladosti svoje  
\q2 i kao kad je išla iz Misira.   
\b  
\p
\v 16 I tada ćeš me, govori Gospod, zvati: Mužu moj; a nećeš me više zvati: Vale moj.  
\v 17 Jer ću ukloniti iz usta njenih imena Valova; i neće im se više pominjati imena.  
\v 18 I tada ću im učiniti zavet sa zverjem poljskim i sa pticama nebeskim i s bubinama zemaljskim; i polomiću luk i mač i rat da ih nestane u zemlji, i učiniću da leže bez straha.  
\v 19 I zaručiću te sebi doveka, zaručiću te sebi pravdom i sudom i milošću i milosrđem.  
\v 20 I zaručiću te sebi verom, i poznaćeš Gospoda.   
\b  
\q1
\v 21 I tada ću se odazvati, govori Gospod,  
\q2 odazvaću se nebesima,  
\q2 a ona će se odazvati zemlji.   
\q1
\v 22 A zemlja će se odazvati žitu i vinu i ulju,  
\q2 a to će se odazvati Jezraelu.   
\q1
\v 23 I posejaću je sebi na zemlji,  
\q2 i smilovaću se na Loruhamu,  
\q1 i reći ću Loamiji: Ti si moj narod,  
\q2 i on će reći: Bože moj!   
\c 3  
\s1 Božija će strpljivost najposle obratiti njegov narod.  
\p
\v 1 Potom reče mi Gospod: Idi opet, ljubi ženu koju ljubi ljubavnik a ona čini preljubu, kao što Gospod ljubi sinove Izrailjeve a oni gledaju za tuđim bogovima i ljube žbanove vinske.  
\v 2 I kupih je za petnaest sikala srebra i gomor i po ječma.  
\v 3 I rekoh joj: Sedi kod mene dugo vremena, i ne kurvaj se, i ne budi drugog; tako ću i ja biti tvoj.  
\v 4 Jer će dugo vremena sinovi Izrailjevi sedeti bez cara i bez kneza i bez žrtve i bez stupa i bez oplećka i likova.  
\v 5 Posle će se obratiti i tražiće Gospoda Boga svog i Davida cara svog, i u strahu će pristupiti ka Gospodu i blagosti Njegovoj u poslednja vremena.   
\c 4  
\s1 Govor za kaznu Izrailja zbog grehova. Opomena Judi da ne greši.  
\q1
\v 1 Čujte reč Gospodnju, sinovi Izrailjevi,  
\q2 jer Gospod ima parbu sa stanovnicima zemaljskim;  
\q2 jer nema istine ni milosti ni znanja za Boga u zemlji;   
\q1
\v 2 Zaklinju se krivo i lažu  
\q2 i ubijaju i kradu i čine preljubu,  
\q2 zastraniše, i jedna krv stiže drugu.   
\q1
\v 3 Zato će tužiti zemlja,  
\q2 i šta god živi na njoj prenemoći će,  
\q2 i zveri poljske i ptice nebeske; i ribe će morske pomreti.   
\b  
\q1
\v 4 Ali niko da se ne prepire ni da koga kori,  
\q2 jer je narod tvoj kao oni koji se prepiru sa sveštenikom.   
\q1
\v 5 Zato ćeš pasti danju,  
\q2 i s tobom će prorok pasti noću,  
\q2 i pogubiću mater tvoju.   
\q1
\v 6 Izgibe moj narod,  
\q2 jer je bez znanja;  
\q1 kad si ti odbacio znanje,  
\q2 i ja ću tebe odbaciti da mi ne vršiš službe svešteničke;  
\q1 kad si zaboravio Boga svog,  
\q2 i ja ću zaboraviti sinove tvoje.   
\b  
\q1
\v 7 Što se više množiše,  
\q2 to mi više grešiše;  
\q2 slavu njihovu pretvoriću u sramotu.   
\q1
\v 8 Od greha naroda mog hrane se,  
\q2 i lakome se na bezakonje njihovo.   
\q1
\v 9 Zato će biti svešteniku kao narodu;  
\q2 pohodiću ga za puteve njegove  
\q2 i platiću mu za dela njegova.   
\q1
\v 10 I oni će jesti, a neće se nasititi;  
\q2 kurvaće se, a neće se množiti;  
\q1 jer prestaše služiti Gospodu.   
\q2
\v 11 Kurvarstvo i vino i mast oduzima srce.   
\q1
\v 12 Narod moj pita drvo svoje,  
\q2 i palica mu njegova odgovara;  
\q1 jer duh kurvarski zavodi ih da se kurvaju  
\q2 odstupivši od Boga svog.   
\q1
\v 13 Navrh gora prinose žrtve,  
\q2 i na humovima kade pod hrastovima, topolama i brestovima,  
\q2 jer im je sen dobar;  
\q1 zato se kurvaju kćeri vaše  
\q2 i snahe vaše čine preljubu.   
\q1
\v 14 Neću karati kćeri vaših kad se kurvaju,  
\q2 ni snaha vaših kad čine preljubu;  
\q1 jer se oni odvajaju s kurvama  
\q2 i prinose žrtve s nevaljalim ženama;  
\q2 i narod nerazumni propašće.   
\b  
\q1
\v 15 Ako se ti kurvaš, Izrailju,  
\q2 neka ne greši Juda;  
\q1 i ne idite u Galgal  
\q2 niti idite u Vet-aven,  
\q2 i ne kunite se: Tako da je živ Gospod.   
\q1
\v 16 Jer je Izrailj uporan kao uporna junica;  
\q2 sada će ih pasti Gospod kao jagnje na prostranom mestu.   
\b  
\q1
\v 17 Jefrem se udružio s lažnim bogovima;  
\q2 ostavi ga.   
\q1
\v 18 Piće se njihovo prevrnu,  
\q2 jednako se kurvaju;  
\q1 milo im je: dajte.  
\q2 Braniči su njegovi sramota.   
\q1
\v 19 Vetar će ih stegnuti krilima svojim,  
\q2 i oni će se posramiti od žrtava svojih.   
\c 5  
\s1 Pretnja carstvima Judi i Izrailju.  
\q1
\v 1 Čujte, sveštenici,  
\q2 i pazi, dome Izrailjev,  
\q1 i slušaj, dome carev,  
\q2 jer je vama sud,  
\q1 jer ste zamka u Mispi  
\q2 i mreža razapeta na Tavoru.   
\q1
\v 2 Iz potaje klaše one koji zalaze;  
\q2 ali ću ih ja pokarati sve.   
\b  
\q1
\v 3 Ja poznajem Jefrema  
\q2 i Izrailj nije sakriven od mene;  
\q1 jer se sada kurvaš, Jefreme,  
\q2 Izrailj se oskvrni.   
\q1
\v 4 Ne upravljaju dela svojih  
\q2 da se vrate k Bogu svom;  
\q1 jer je duh kurvarski u njima  
\q2 i ne znaju Gospoda.   
\b  
\q1
\v 5 I ponositost Izrailjeva svedoči mu u oči;  
\q2 zato će Izrailj i Jefrem pasti za bezakonje svoje,  
\q2 pašće i Juda s njima.   
\q1
\v 6 Ići će s ovcama svojim i s govedima svojim da traže Gospoda,  
\q2 ali Ga neće naći;  
\q2 uklonio se je od njih.   
\q1
\v 7 Izneveriše Gospoda,  
\q2 jer izrodiše tuđe sinove;  
\q1 zato će ih proždreti mesec dana  
\q2 s dostojanjem njihovim.   
\b  
\q1
\v 8 Trubite u rog u Gavaji, u trubu u Rami;  
\q2 vičite u Vet-avenu: za tobom, Venijamine!   
\q1
\v 9 Jefrem će opusteti u dan kara;  
\q2 objavih među plemenima Izrailjevim šta će zacelo biti.   
\q1
\v 10 Knezovi su Judini kao oni koji premeštaju među;  
\q2 izliću na njih kao vodu jarost svoju.   
\q1
\v 11 Jefremu se čini nasilje,  
\q2 satrven je sudom,  
\q2 jer od svoje volje otide za zapovešću.   
\q1
\v 12 Zato ću ja biti Jefremu kao moljac  
\q2 i kao crv domu Judinom.   
\b  
\q1
\v 13 I Jefrem vide bolest svoju  
\q2 i Juda svoju ranu,  
\q1 i otide Jefrem k Asircu,  
\q2 i Juda posla k caru koji bi ga branio;  
\q1 ali vas on ne može isceliti  
\q2 niti će vas oprostiti rane vaše.   
\q1
\v 14 Jer ću ja biti kao lav Jefremu,  
\q2 kao lavić domu Judinom;  
\q1 ja, ja ću zgrabiti, i otići ću,  
\q2 odneću i niko neće izbaviti.   
\b  
\q1
\v 15 Otići ću  
\q2 i vratiću se na svoje mesto  
\q1 dokle ne priznaju svoju krivicu  
\q2 i potraže lice moje;  
\q2 kad budu u nevolji tražiće me.   
\c 6  
\s1 Božija kazna dovodi do pokajanja.  
\q1
\v 1 Hodite da se vratimo ka Gospodu;  
\q2 jer On razdre, i isceliće nas,  
\q2 rani, i zaviće nas.   
\q1
\v 2 Povratiće nam život do dva dana,  
\q2 treći dan podignuće nas,  
\q2 i živećemo pred Njim.   
\q1
\v 3 Tada ćemo poznati Gospoda  
\q2 i sve ćemo Ga više poznavati;  
\q1 jer Mu je izlazak uređen kao zora,  
\q2 i doći će nam kao dažd,  
\q2 kao pozni dažd koji natapa zemlju.   
\b  
\q1
\v 4 Šta da ti učinim, Jefreme?  
\q2 Šta da ti učinim, Juda?  
\q1 Jer je dobrota vaša kao oblak jutarnji  
\q2 i kao rosa koja u zoru padne, pa je nestane.   
\q1
\v 5 Zato ih sekoh preko proroka  
\q2 i ubijah rečima usta svojih,  
\q2 i svetlost sudova tvojih iziđe.   
\q1
\v 6 Jer je meni milost mila a ne žrtva,  
\q2 i poznavanje Boga većma nego žrtva paljenica.   
\b  
\q1
\v 7 Ali oni prestupiše zavet kao Adam;  
\q2 tu me izneveriše.   
\q1
\v 8 Galad je grad onih koji čine bezakonje,  
\q2 po njemu su krvavi tragovi.   
\q1
\v 9 A družina je sveštenička kao četa koja dočekuje ljude,  
\q2 ubijaju na putu u Sihem,  
\q2 čine grdilo.   
\q1
\v 10 U domu Izrailjevom vidim strahotu;  
\q2 onde je kurvanje Jefremovo,  
\q2 Izrailj se oskvrni.   
\b  
\q1
\v 11 I tebi je, Juda, pripravljena žetva,  
\q2 kad vratim roblje naroda svog.   
\c 7  
\s1 Jadikovanje nad pokvarenim Izrailjem i objavljivanje zasluženih kazni.  
\q1
\v 1 Kad lečim Izrailja,  
\q2 tada se pokazuje bezakonje Jefremovo  
\q2 i zloća samarijska;  
\q1 jer čine laž,  
\q2 i lupež ulazi,  
\q2 i napolju udara četa.   
\q1
\v 2 I ne govore u srcu svom  
\q2 da ja pamtim svako bezakonje njihovo;  
\q1 sada stoje oko njih dela njihova,  
\q2 preda mnom su.   
\q1
\v 3 Nevaljalstvom svojim vesele cara  
\q2 i lažima svojim knezove.   
\q1
\v 4 Svi čine preljubu;  
\q2 kao peć su koju užari hlebar,  
\q2 koji prestane stražiti kad zamesi testo pa dokle uskisne.   
\q1
\v 5 Na dan cara našeg razboleše se knezovi od meha vina,  
\q2 i on pruži ruku svoju podsmevačima.   
\q1
\v 6 Jer na zasede svoje upravljaju srce svoje,  
\q2 koje je kao peć;  
\q1 hlebar njihov spava celu noć,  
\q2 ujutru gori kao plamen ognjeni.   
\q1
\v 7 Svi su kao peć ugrejani  
\q2 i proždiru svoje sudije;  
\q1 svi carevi njihovi padaju,  
\q2 nijedan između njih ne viče k meni.   
\b  
\q1
\v 8 Jefrem se pomešao s narodima;  
\q2 Jefrem je pogača neprevrnuta.   
\q1
\v 9 Inostranci jedu mu silu,  
\q2 a on ne zna;  
\q1 sede kose popadaju ga,  
\q2 a on ne zna.   
\q1
\v 10 I ponositost Izrailjeva svedoči mu u oči,  
\q2 ali se ne vraćaju ka Gospodu Bogu svom  
\q2 niti Ga traže uza sve to.   
\b  
\q1
\v 11 I Jefrem je kao golub,  
\q2 lud, bezuman;  
\q1 zovu Misir,  
\q2 idu u Asirsku.   
\q1
\v 12 Kad otidu,  
\q2 razapeću na njih mrežu svoju,  
\q1 kao ptice nebeske svući ću ih,  
\q2 karaću ih kako je kazivano u zboru njihovom.   
\q1
\v 13 Teško njima,  
\q2 jer zađoše od mene;  
\q1 pogibao će im biti,  
\q2 jer me izneveriše;  
\q1 ja ih iskupih,  
\q2 a oni govoriše na me laž.   
\b  
\q1
\v 14 Niti me prizivaše iz srca svog,  
\q2 nego ridaše na odrima svojim;  
\q1 žita i vina radi skupljajući se  
\q2 odstupaju od mene.   
\q1
\v 15 Kad ih karah,  
\q2 ukrepih im mišice;  
\q2 ali oni misliše zlo na me.   
\q1
\v 16 Vraćaju se, ali ne ka Višnjem,  
\q2 postaše kao luk lažljiv;  
\q1 knezovi će njihovi popadati od mača  
\q2 s obesti jezika svog;  
\q2 to će im biti podsmeh u zemlji misirskoj.   
\c 8  
\s1 Neprijateljska navala i idolopoklonički narod.  
\q1
\v 1 Trubu na usta, i reci:  
\q2 Kao orao ide na dom Gospodnji;  
\q1 jer prestupiše zavet moj  
\q2 i otpadiše se od zakona mog.   
\q1
\v 2 Izrailj će vikati ka meni:  
\q2 Bože moj; poznajemo Te.   
\q1
\v 3 Izrailj je ostavio dobro;  
\q2 neprijatelj će ga goniti.   
\b  
\q1
\v 4 Postavljaju careve, ali ne od mene;  
\q2 podižu knezove, za koje ja ne znam;  
\q1 od srebra svog i od zlata svog grade sebi likove,  
\q2 da se istrebe.   
\q1
\v 5 Ostavilo te je tele tvoje, Samarijo;  
\q2 jarost se moja raspalila na njih;  
\q2 dokle se neće moći očistiti?   
\q1
\v 6 Jer je i ono od Izrailja,  
\q2 načinio ga je umetnik,  
\q1 i nije Bog;  
\q2 tele će samarijsko otići u komade.   
\b  
\q1
\v 7 Jer seju vetar,  
\q2 pa će žeti oluju;  
\q1 stabljike neće imati,  
\q2 klica neće dati brašno,  
\q1 da bi i dala,  
\q2 proždreće ga tuđinci.   
\q1
\v 8 Proždreće se Izrailj,  
\q2 biće među narodima kao sud na kome nema miline.   
\q1
\v 9 Jer otidoše k Asircu,  
\q2 divljem magarcu, koji je sam za se;  
\q2 Jefrem naima ljubavnike.   
\q1
\v 10 A što naimaše među narodima,  
\q2 ja ću ih sabrati;  
\q1 a već i okusiše malo  
\q2 radi bremena Cara nad knezovima.   
\b  
\q1
\v 11 Što umnoži Jefrem oltare da greši,  
\q2 biće mu oltari na greh.   
\q1
\v 12 Napisah mu velike stvari u zakonu svom;  
\q2 ali mu se čine kao nešto tuđe.   
\q1
\v 13 Za žrtve, koje mi prinose,  
\q2 prinose meso, i jedu ga;  
\q2 Gospod ih ne prima;  
\q1 sada će se opomenuti bezakonja njihova  
\q2 i pohodiće grehe njihove;  
\q2 oni će se vratiti u Misir.   
\q1
\v 14 Izrailj zaboravi Tvorca svog, i sagradi dvorove,  
\q2 i Juda umnoži tvrde gradove;  
\q1 ali ću pustiti oganj u gradove ovom,  
\q2 i spaliće dvorove onom.   
\c 9  
\s1 Radost prolazi, osveta je tu.  
\q1
\v 1 Ne raduj se, Izrailju, veseleći se kao narodi,  
\q2 što se kurvaš odstupivši od Boga svog,  
\q2 miluješ platu kurvarsku po svim gumnima žitnim.   
\q1
\v 2 Gumno i kaca neće ih hraniti,  
\q2 i mast će ih prevariti.   
\q1
\v 3 Oni neće nastavati u zemlji Gospodnjoj;  
\q2 nego će se vratiti Jefrem u Misir,  
\q2 i oni će jesti nečistotu u asirskoj.   
\b  
\q1
\v 4 Neće prinositi Gospodu vina,  
\q2 niti će Mu biti ugodne žrtve njihove,  
\q1 nego će im biti kao hleb onih koji tuže,  
\q2 ko ga god jede oskvrniće se,  
\q1 jer im je hleb za žrtve njihove,  
\q2 neće ući u dom Gospodnji.   
\b  
\q1
\v 5 Šta ćete činiti na dan svetkovine  
\q2 i na dan praznika Gospodnjeg?   
\q1
\v 6 Jer gle, otići će pustošenja radi;  
\q2 Misir će ih pribrati,  
\q2 Memfis će ih pogrepsti;  
\q1 zaklade njihove od srebra naslediće kopriva,  
\q2 trnje će im biti u šatorima.   
\b  
\q1
\v 7 Dođoše dani pohođenju,  
\q2 dođoše dani plaćanju;  
\q2 poznaće Izrailj;  
\q1 proroci su ludi,  
\q2 bezumni su u kojima je duh,  
\q1 za mnoštvo bezakonja tvog  
\q2 i veliku mržnju.   
\q1
\v 8 Stražar je Jefremov s Bogom mojim,  
\q2 prorok je zamka ptičarska po svim putevima njegovim,  
\q2 mržnja je u domu Boga njegovog.   
\q1
\v 9 Duboko su se pokvarili kao u vreme gavajsko;  
\q2 opomenuće se bezakonja njihova,  
\q2 i pohodiće grehe njihove.   
\b  
\q1
\v 10 Nađoh Izrailja kao grožđe u pustinji;  
\q2 videh oce vaše kao prve smokve na drvetu u početku njegovom;  
\q1 oni otidoše k Velfegoru,  
\q2 i odvojiše se za sramotom,  
\q2 i postaše gadni kako im beše milo.   
\q1
\v 11 Jefremova će slava odleteti kao ptica  
\q2 od rođenja i od utrobe i od začetka.   
\q1
\v 12 Ako li i othrani sinove svoje,  
\q2 ja ću ih učiniti da budu bez dece,  
\q1 da ne ostane nijedan;  
\q2 i teško njima kad odstupim od njih.   
\q1
\v 13 Jefrem, kad ga gledah, beše kao Tir,  
\q2 posađen na ljupkom mestu;  
\q2 ali će Jefrem izvesti krvniku sinove svoje.   
\q1
\v 14 Podaj im, Gospode; šta ćeš im dati?  
\q2 Podaj im utrobu pometljivu i dojke usahle.   
\b  
\q1
\v 15 Sva je zloća njihova u Galgalu;  
\q2 zato onde mrzim na njih;  
\q1 za zloću dela njihovih izgnaću ih iz doma svog;  
\q2 neću ih više ljubiti:  
\q2 svi su knezovi njihovi odmetnici.   
\b  
\q1
\v 16 Udaren bi Jefrem;  
\q2 koren im posahnu,  
\q2 neće roditi roda;  
\q1 ako i rode,  
\q2 ubiću mili porod utrobe njihove.   
\q1
\v 17 Odbaciće ih Bog moj,  
\q2 jer Ga ne slušaju,  
\q2 i skitaće se po narodima.   
\c 10  
\s1 Bez pravičnosti nema spasenja.  
\q1
\v 1 Izrailj je prazna loza vinova,  
\q2 ostavlja rod za se;  
\q1 što više roda ima,  
\q2 to više umnožava oltare;  
\q1 što mu je bolja zemlja,  
\q2 to više kiti likove.   
\q1
\v 2 Srce im je razdeljeno,  
\q2 zato su krivi;  
\q1 On će oboriti oltare njihove,  
\q2 polomiće likove njihove.   
\b  
\q1
\v 3 Jer sada govore: Nemamo cara;  
\q2 ne bojimo se Gospoda;  
\q2 i šta bi nam učinio car?   
\q1
\v 4 Govore reči kunući se lažno kad ugovaraju veru,  
\q2 i sud kao otrov raste u brazdama na njivi mojoj.   
\q1
\v 5 Za junice vet-avenske uplašiće se stanovnici samarijski;  
\q2 jer će za njima žaliti narod njihov,  
\q1 i sveštenici njihovi,  
\q2 koji im se radovahu,  
\q2 jer će slava njihova otići od njih.   
\q1
\v 6 I on će sam biti odveden u Asirsku  
\q2 na dar caru braniču;  
\q1 Jefrema će popasti stid,  
\q2 i Izrailj će se osramotiti namerom svojom.   
\b  
\q1
\v 7 Cara će samarijskog nestati  
\q2 kao pene povrh vode.   
\q1
\v 8 I oboriće se visine avenske,  
\q2 greh Izrailjev;  
\q2 trnje će i čkalj rasti po oltarima njihovim,  
\q1 i govoriće gorama: Pokrijte nas,  
\q2 i humovima: Padnite na nas.   
\b  
\q1
\v 9 Od vremena gavajskog grešio si, Izrailju;  
\q2 onde ostaše,  
\q2 ne stiže ih u Gavaji rat na bezakonike.   
\q1
\v 10 Po svojoj ću ih volji pokarati,  
\q2 i narodi će se skupiti na njih  
\q2 da ih zarobe za dvojako bezakonje njihovo.   
\b  
\q1
\v 11 Jefrem je junica naučena, koja rado vrše;  
\q2 ali ću joj doći na lepi vrat;  
\q2 upregnuću Jefrema, Juda će orati, Jakov će povlačiti.   
\q1
\v 12 Sejte pravdu, žećete milost;  
\q2 orite krčevinu,  
\q1 jer je vreme da tražite Gospoda,  
\q2 da bi došao i podaždio vam pravdom.   
\b  
\q1
\v 13 Oraste bezbožnost,  
\q2 žeste bezakonje,  
\q2 jedoste plod od laži;  
\q1 jer si se pouzdao u svoj put,  
\q2 u mnoštvo svojih junaka.   
\q1
\v 14 Zato će se podignuti vreva među tvojim narodom,  
\q2 i svi će se gradovi tvoji raskopati  
\q1 kao što Salman raskopa Vet-Arvel kad beše rat,  
\q2 majka bi razmrskana sa sinovima.   
\q1
\v 15 Tako će vam učiniti Vetilj za veliku zloću vašu;  
\q2 zorom će poginuti car Izrailjev.   
\c 11  
\s1 Usrdno Božije sažaljevanje.  
\q1
\v 1 Kad Izrailj beše dete, ljubih ga,  
\q2 i iz Misira dozvah sina svog.   
\q1
\v 2 Koliko ih zvaše,  
\q2 toliko oni odlaziše od njih;  
\q1 prinosiše žrtve Valima,  
\q2 kadiše likovima.   
\b  
\q1
\v 3 Ja učih Jefrema hoditi držeći ga za ruke,  
\q2 ali ne poznaše da sam ih ja lečio.   
\q1
\v 4 Vukoh ih uzicama čovečijim,  
\q2 užima ljubavnim;  
\q1 i bih im kao oni koji im skidaju jaram s čeljusti,  
\q2 i davah im hranu.   
\b  
\q1
\v 5 Neće se vratiti u zemlju misirsku,  
\q2 nego će mu Asirac biti car,  
\q2 jer se ne hteše obratiti.   
\q1
\v 6 I mač će stajati u gradovima njegovim,  
\q2 i potrće prevornice njegove  
\q2 i proždreti za namere njihove.   
\q1
\v 7 Narod je moj prionuo za otpad od mene;  
\q2 zovu ga ka Višnjem,  
\q2 ali se nijedan ne podiže.   
\b  
\q1
\v 8 Kako da te dam, Jefreme?  
\q2 Da te predam, Izrailju?  
\q1 Kako da učinim od tebe kao od Adame?  
\q2 Da te obratim da budeš kao Sevojim?  
\q1 Ustreptalo je srce moje u meni,  
\q2 uskolebala se utroba moja od žalosti.   
\q1
\v 9 Neću izvršiti ljutog gneva svog,  
\q2 neću opet zatrti Jefrema;  
\q1 jer sam ja Bog a ne čovek,  
\q2 Svetac usred tebe;  
\q2 neću doći na grad.   
\b  
\q1
\v 10 Ići će oni za Gospodom;  
\q2 On će rikati kao lav;  
\q1 kad rikne,  
\q2 sa strahom će dotrčati sinovi s mora;   
\q1
\v 11 Sa strahom će dotrčati iz Misira kao ptica,  
\q2 i kao golub iz zemlje asirske;  
\q1 i naseliću ih u kućama njihovim,  
\q2 govori Gospod.   
\c 12  
\s1 Praded Jakov ugled svom narodu.  
\q1
\v 1 Opkolio me je Jefrem lažju  
\q2 i dom Izrailjev prevarom;  
\q1 ali Juda još vlada s Bogom  
\q2 i veran je sa svetima.   
\q1
\v 2 Jefrem se hrani vetrom,  
\q2 i ide za ustokom;  
\q1 svaki dan množi laž i pogibao;  
\q2 i hvataju veru s Asircem  
\q2 i nose ulje u Misir.   
\b  
\q1
\v 3 I s Judom ima Gospod parbu  
\q2 i pohodiće Jakova prema putevima njegovim,  
\q2 platiće mu po delima njegovim.   
\q1
\v 4 U utrobi uhvati za petu brata svog,  
\q2 i u sili svojoj bori se s Bogom;   
\q1
\v 5 Bori se s anđelom, i nadjača;  
\q2 plaka, i moli Mu se;  
\q2 nađe Ga u Vetilju, i onde govori s nama.   
\q1
\v 6 Ali je Gospod Bog nad vojskama,  
\q2 Gospod mu je spomen.   
\q1
\v 7 Ti dakle obrati se k Bogu svom,  
\q2 čuvaj milost i pravdu,  
\q2 i uzdaj se vazda u Boga svog.   
\b  
\q1
\v 8 Trgovac je Jefrem,  
\q2 u ruci su mu merila lažna,  
\q2 milo mu je da čini krivo.   
\q1
\v 9 I govori Jefrem:  
\q2 Baš se obogatih, stekoh blago,  
\q2 ni u kome trudu mom neće mi naći nepravde koja bi bila greh.   
\q1
\v 10 A ja sam Gospod Bog tvoj od zemlje misirske,  
\q2 još ću ti dati da sediš u šatorima kao o praznicima.   
\b  
\q1
\v 11 I govoriću preko proroka,  
\q2 i umnožiću utvare,  
\q2 i davaću priču preko proroka.   
\q1
\v 12 Doista je Galad bezakonje,  
\q2 postaše sama taština;  
\q1 u Galgalu prinose junce na žrtvu,  
\q2 i oltari su im kao gomile kamenja po brazdama na njivi mojoj.   
\q1
\v 13 I Jakov pobeže u zemlju sirsku,  
\q2 i Izrailj služi za ženu,  
\q2 i za ženu čuva ovce.   
\q1
\v 14 I prorokom izvede Gospod Izrailja iz Misira,  
\q2 i prorokom čuva ga.   
\q1
\v 15 Jefrem Ga ljuto razgnevi;  
\q2 zato će ostaviti na njemu krv njegovu,  
\q2 i vratiće mu sramotu njegovu Gospod njegov.   
\c 13  
\s1 Spasenje od smrti. Propast greha.  
\q1
\v 1 Kad Jefrem govoraše, beše strah;  
\q2 beše se uzvisio u Izrailju;  
\q2 ali se ogreši o Vala, te umre.   
\q1
\v 2 I sada jednako greše  
\q2 i grade sebi lijući od srebra svog po razumu svom likove,  
\q2 koji su svi delo umetničko,  
\q1 a oni govore za njih:  
\q2 Ljudi koji prinose žrtve neka celuju teoce.   
\q1
\v 3 Zato će biti kao oblak jutarnji  
\q2 i kao rosa koja u zoru padne, pa je nestane,  
\q1 kao pleva, koju odnosi vetar s gumna,  
\q2 i kao dim iz dimnjaka.   
\b  
\q1
\v 4 A ja sam Gospod Bog tvoj od zemlje misirske,  
\q2 i Boga osim mene nisi poznao,  
\q2 i osim mene nema ko bi spasao.   
\q1
\v 5 Ja te poznah u pustinji,  
\q2 u zemlji zasušenoj.   
\q1
\v 6 Imajući dobru pašu behu siti;  
\q2 ali čim se nasitiše, ponese se srce njihovo,  
\q2 zato me zaboraviše.   
\q1
\v 7 Zato ću im biti kao lav,  
\q2 kao ris vrebaću ih na putu.   
\q1
\v 8 Srešću ih kao medvedica kojoj uzmu medvediće,  
\q2 i rastrgaću im sve srce njihovo  
\q1 i izješću ih onde kao lav;  
\q2 zverje poljsko raskinuće ih.   
\b  
\q1
\v 9 Propao si, Izrailju;  
\q2 ali ti je pomoć u meni.   
\q1
\v 10 Gde ti je car? Gde je?  
\q2 Neka te sačuva u svim gradovima tvojim;  
\q1 gde li su sudije tvoje,  
\q2 za koje si govorio: Daj mi cara i knezove?   
\q1
\v 11 Dadoh ti cara u gnevu svom,  
\q2 i uzeh ga u jarosti svojoj.   
\b  
\q1
\v 12 Svezano je bezakonje Jefremovo,  
\q2 ostavljen je greh njegov.   
\q1
\v 13 Bolovi kao u porodilje spopašće ga,  
\q2 sin je nerazuman,  
\q2 jer ne bi toliko vremena ostao u utrobi.   
\b  
\q1
\v 14 Od groba ću ih izbaviti,  
\q2 od smrti ću ih sačuvati;  
\q1 gde je, smrti, pomor tvoj,  
\q2 gde je, grobe, pogibao tvoja?  
\q1 Kajanje će biti sakriveno od očiju mojih.   
\b  
\q1
\v 15 Rodan će biti među braćom svojom;  
\q2 ali će doći istočni vetar,  
\q2 vetar Gospodnji, koji ide od pustinje,  
\q1 i usahnuće mu izvor,  
\q2 i studenac će mu zasušiti;  
\q2 on će odneti blago od svih dragih zaklada.   
\q1
\v 16 Samarija će opusteti,  
\q2 jer se odmetnu od Boga svog;  
\q1 oni će pasti od mača,  
\q2 deca će se njihova razmrskati  
\q2 i trudne žene njihove rasporiti.   
\c 14  
\s1 Izrailjevo obraćanje i procvetavanje u budućnosti.  
\q1
\v 1 Obrati se, Izrailju, ka Gospodu Bogu svom,  
\q2 jer si pao svog radi bezakonja.   
\q1
\v 2 Uzmite sa sobom reči,  
\q2 i obratite se ka Gospodu;  
\q1 recite Mu:  
\q2 Oprosti sve bezakonje, i primi dobro;  
\q2 i daćemo žrtve usana svojih.   
\q1
\v 3 Asirac nas ne može izbaviti,  
\q2 nećemo jahati na konjima,  
\q1 niti ćemo više govoriti delu ruku svojih: Bože naš;  
\q2 jer u Tebe nalazi milost sirota.   
\b  
\q1
\v 4 Isceliću otpad njihov,  
\q2 ljubiću ih drage volje;  
\q2 jer će se gnev moj odvratiti od njega.   
\q1
\v 5 Biću kao rosa Izrailju,  
\q2 procvetaće kao ljiljan  
\q2 i pustiće žile svoje kao drveta livanska.   
\q1
\v 6 Raširiće se grane njegove,  
\q2 i lepota će mu biti kao u masline  
\q2 i miris kao livanski.   
\q1
\v 7 Oni će se vratiti  
\q2 i sedeti pod senom njegovim,  
\q1 rađaće kao žito  
\q2 i cvetaće kao vinova loza;  
\q2 spomen će mu biti kao vino livansko.   
\b  
\q1
\v 8 Jefreme, šta će mi više idoli?  
\q2 Ja ću ga uslišiti i gledati;  
\q1 ja ću mu biti kao jela zelena;  
\q2 od mene je tvoj plod.   
\b  
\q1
\v 9 Ko je mudar, neka razume ovo;  
\q2 i razuman neka pozna ovo;  
\q1 jer su pravi putevi Gospodnji,  
\q2 i pravednici će hoditi po njima,  
\q2 a prestupnici će pasti na njima.   