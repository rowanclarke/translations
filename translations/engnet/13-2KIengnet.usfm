\v 19 ‘\w You|strong="H6440"\w* displayed \w a|strong="H3068"\w* sensitive \w spirit|strong="H3665"\w* \w and|strong="H3068"\w* \w humbled|strong="H3665"\w* \w yourself|strong="H3665"\w* \w before|strong="H6440"\w* \w the|strong="H6440"\w* \nd \w Lord|strong="H3068"\w*\nd* \w when|strong="H1961"\w* \w you|strong="H6440"\w* \w heard|strong="H8085"\w* \w how|strong="H8085"\w* \w I|strong="H5921"\w* \w intended|strong="H3824"\w* \w to|strong="H1696"\w* \w make|strong="H8085"\w* \w this|strong="H2088"\w* \w place|strong="H4725"\w* \w and|strong="H3068"\w* \w its|strong="H5921"\w* \w residents|strong="H3427"\w* \w into|strong="H5921"\w* \w an|strong="H1961"\w* \w appalling|strong="H8047"\w* \w example|strong="H7045"\w* \w of|strong="H3068"\w* \w an|strong="H1961"\w* \w accursed|strong="H7045"\w* \w people|strong="H3427"\w*. \w You|strong="H6440"\w* \w tore|strong="H7167"\w* \w your|strong="H3068"\w* clothes \w and|strong="H3068"\w* \w wept|strong="H1058"\w* \w before|strong="H6440"\w* \w me|strong="H6440"\w*, \w and|strong="H3068"\w* \w I|strong="H5921"\w* \w have|strong="H1961"\w* \w heard|strong="H8085"\w* \w you|strong="H6440"\w*,’ \w says|strong="H5002"\w* \w the|strong="H6440"\w* \nd \w Lord|strong="H3068"\w*\nd*.
\v 20 ‘\w Therefore|strong="H3651"\w* \w I|strong="H2005"\w* \w will|strong="H4428"\w* allow \w you|strong="H3605"\w* \w to|strong="H7725"\w* die \w and|strong="H7725"\w* \w be|strong="H3808"\w* buried \w in|strong="H5921"\w* \w peace|strong="H7965"\w*. \w You|strong="H3605"\w* \w will|strong="H4428"\w* \w not|strong="H3808"\w* \w have|strong="H5869"\w* \w to|strong="H7725"\w* \w witness|strong="H5869"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w disaster|strong="H7451"\w* \w I|strong="H2005"\w* \w will|strong="H4428"\w* \w bring|strong="H7725"\w* \w on|strong="H5921"\w* \w this|strong="H2088"\w* \w place|strong="H4725"\w*.’”’” \w Then|strong="H2088"\w* \w they|strong="H3651"\w* \w reported|strong="H7725"\w* \w back|strong="H7725"\w* \w to|strong="H7725"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*.
