\s1 A message for Shemaiah  
\p
\v 24  \add Yahweh told me to\add* send this message to \w Shemaiah|strong="H8098"\w*, \w a|strong="H3068"\w* man \w from|strong="H8098"\w* Nehelam \add town who was living in Babylon\add*:  
\v 25 \w This|strong="H3541"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \w the|strong="H3605"\w* Commander \w of|strong="H1121"\w* \w the|strong="H3605"\w* \w armies|strong="H6635"\w* \w of|strong="H1121"\w* angels, \w the|strong="H3605"\w* \w God|strong="H3068"\w* \w whom|strong="H5971"\w* \add we\add* Israelis \add worship\add*, \w says|strong="H3541"\w*: “\w You|strong="H3605"\w* wrote \w a|strong="H3068"\w* \w letter|strong="H5612"\w* \w that|strong="H5971"\w* \w no|strong="H3605"\w* \w one|strong="H3605"\w* told \w you|strong="H3605"\w* \w to|strong="H3478"\w* write. \w You|strong="H3605"\w* \w sent|strong="H7971"\w* \w it|strong="H8034"\w* \w to|strong="H3478"\w* \w Zephaniah|strong="H6846"\w* \w the|strong="H3605"\w* \w priest|strong="H3548"\w*, \w the|strong="H3605"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Maaseiah|strong="H4641"\w*, \w and|strong="H1121"\w* \add you sent copies\add* \w to|strong="H3478"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* \w priests|strong="H3548"\w* \w and|strong="H1121"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \add other\add* \w people|strong="H5971"\w* \w here|strong="H3541"\w* \w in|strong="H3478"\w* \w Jerusalem|strong="H3389"\w*. \add This is what\add* \w you|strong="H3605"\w* wrote \w to|strong="H3478"\w* \w him|strong="H7971"\w*:   
\pi1
\v 26  \add Zephaniah\add*, \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* \w appointed|strong="H5414"\w* \w you|strong="H5414"\w* \w to|strong="H3068"\w* \w be|strong="H1961"\w* \w the|strong="H3605"\w* \w priest|strong="H3548"\w* \w instead|strong="H8478"\w* \w of|strong="H1004"\w* \w Jehoiada|strong="H3077"\w*, \w to|strong="H3068"\w* supervise \w those|strong="H3605"\w* \w who|strong="H3605"\w* \w work|strong="H5414"\w* \w in|strong="H3068"\w* \w the|strong="H3605"\w* \w temple|strong="H1004"\w*. \w Anyone|strong="H3605"\w* \w who|strong="H3605"\w* acts \w like|strong="H1961"\w* \w a|strong="H3068"\w* crazy \w man|strong="H3605"\w* \w and|strong="H3068"\w* \w who|strong="H3605"\w* claims \w that|strong="H3605"\w* \w he|strong="H3068"\w* \w is|strong="H3068"\w* \w a|strong="H3068"\w* \w prophet|strong="H5012"\w*, \w you|strong="H5414"\w* \w should|strong="H3068"\w* \w put|strong="H5414"\w* \w his|strong="H3605"\w* arms \w and|strong="H3068"\w* legs \w and|strong="H3068"\w* head \w into|strong="H5414"\w* ◄\w stocks|strong="H4115"\w*/\w a|strong="H3068"\w* wooden \w frame|strong="H5414"\w* \add so that he cannot move►\add*.  
