\id EPH  
\h AR EFESIO 
\toc1 AR EFESIO Ar he̱ꞌmi bi ꞌyotꞌa ar Pablo bi me̱mpa ya me Efeso 
\toc2 AR EFESIO 
\toc3 Ef. 
\mt1 AR EFESIO 
\mt2 Ar he̱ꞌmi bi ꞌyotꞌa ar Pablo bi me̱mpa ya me Efeso 
\c 1  
\s1 Ar nze̱ngwa 
\p  
\v 1 Nuga dar Pablo ár mpo̱tegi ar tsi Hmu Hesukristo, ngetho njapꞌu̱ xki ko ár mu̱i Jö bi ꞌñexkagi nga pe̱pabi. Di pe̱ñꞌahu̱ nunar he̱ꞌminu̱ gar menguhu̱ Efeso, gi nkuhu̱ ne gi te̱ñhu̱ ar tsi Hmu. 
\p  
\v 2 Jö ma Dadahu̱ ne ma tsi Hmuhu̱ Hesukristo da ꞌraꞌahu̱ nꞌar hogamꞌu̱i ne da hwëkꞌahu̱ yá ñho. 
\s1 Jö xa jöpa nuꞌu̱ togo ñꞌemu̱i ar tsi Hmu Hesukristo 
\p  
\v 3 Ga ndöñhu̱ Jö ár Dada ar tsi Hmu Hesukristo, togo xi ꞌrakagihu̱ gatho ya jöpi xi ꞌwegagihu̱nu̱ mhetsꞌi, ngetho di nꞌatꞌwihu̱ ar tsi Hmu Hesukristo. 
\p  
\v 4 Núꞌmu̱ hinxki hoktho ar ximha̱i, Jö xki hwankagihu̱ nga nꞌatꞌwihu̱ ar tsi Hmu, ne njapꞌu̱ nda tꞌaxkagihu̱, ne hinte ma tsꞌoki nga pe̱ꞌsu̱ hár nthandiꞌö. 
\p  
\v 5 Jö pe̱ꞌsa nꞌar döta mhöte, ne xki hñutsꞌi nda tedegihu̱ hár ndöte ar tsi Hmu Hesukristo, ngetho njapꞌu̱ xki beñꞌö. 
\p  
\v 6 Nöꞌö bi ko ár mu̱i ba pe̱hna ár hmöka Tꞌu̱ bi tedegihu̱, ne njapꞌu̱ xa ga ndömfu̱ ár thuhu ga beñhu̱ ár nhwëki bi ꞌrakagihu̱. 
\p  
\v 7 Bi me̱hna ár Tꞌu̱, bi nöꞌma ár ji bi pumga ma tsꞌokihu̱, ne bi gutka ma tha̱ihu̱. Njapꞌu̱ bi zimgagihu̱ hár ꞌye̱ ar tsꞌoki, ngetho xa döta ár nhwëki Jö. 
\p  
\v 8 Xa bi hwëgagihu̱ nꞌar hoga mfeni ne nꞌar döta mfödi. 
\p  
\v 9 Ne bi za̱ da pöhu̱ nöꞌö himi tsa̱ nda fö mamꞌe̱tꞌo, tema xki ko ár mu̱i Jö nda ꞌyo̱tꞌe. Gese̱ xki benga njapꞌu̱, 
\p  
\v 10 nda njapa ar tsi Hmu Hesukristo nda ndö, di huxa mañö gatho nuꞌu̱ bi ꞌbu̱ mhetsꞌi ne gatho nuꞌu̱ ꞌbu̱kwa har ximha̱i. Njapꞌu̱ ma da thogi nu xta zo̱nga ar pa xi hñuxa Jö. 
\p  
\v 11 Jö xki beñꞌö nda hñuxkagihu̱ nga höñhu̱ yá ñho, ngetho di nꞌatꞌwihu̱ ar tsi Hmu. Ha Jö o̱tꞌa gatho nöꞌö xi benga hár mu̱i. 
\p  
\v 12 Jö bi hwankagihe mꞌe̱tꞌo nga jamfihe ar tsi Hmu Hesukristo ne njapꞌu̱ nga ndömfe ár thuhu. 
\p  
\v 13 Ne nuꞌahu̱ xka ꞌyo̱xu̱ ar mhö majöni, nunar mhönu̱ no̱nga ri mpo̱ho̱hu̱. Ne nga jamfihu̱ ga nꞌatꞌwihu̱ ar tsi Hmu Hesukristo, bi thusꞌahu̱ ár Hñö Jö ha ri mu̱ihu̱ ngu nꞌar nthixtꞌi yá me̱tiꞌihu̱ Jö, ngu xki ñötkagihu̱. 
\p  
\v 14 Ár Hñö Jö gehnu̱ ngu nꞌar ñho xi mꞌe̱tꞌogihu̱ yá bötsigihu̱ Jö, ho̱nse̱ ga to̱ꞌmhu̱ da zo̱ ar pa da zixkagihu̱ nꞌagitho ma ga ꞌbu̱hwihu̱. Gatho xi ꞌyo̱tꞌa Jö, ne njapꞌu̱ nda tꞌeꞌspabi ár nsu. 
\s1 Ar Pablo a̱di da tꞌumba ar hoga mfödi ne da sokwa yá da̱ ya gamfi 
\p  
\v 15 Jange nuga núꞌmu̱ nda o̱de xka jamfihu̱ ar tsi Hmu Hesukristo, ne xi zo ma gu xa gi möhu̱ nuꞌu̱ maꞌra ya gamfi, 
\p  
\v 16 hindi tsa̱ya̱ di umba njamödi Jö, ne di a̱pi da ma̱xꞌahu̱, 
\p  
\v 17 da ꞌraꞌahu̱ ar hoga mfödi, ne da xokꞌa ri da̱hu̱ gi pöthwu̱ ár mꞌu̱i ár Dada ma tsi Hmuhu̱ Hesukristo ꞌbu̱ hár nsunda. 
\p  
\v 18 Di a̱pa Jö nꞌehe da yotꞌa ri mfenihu̱ gi pöhu̱ xiñho te gatho di to̱ꞌmhu̱ ngetho xi zonkagihu̱, ne gi pöhu̱ tengu ár nza̱tho ne ár döta ya ñho da ꞌraju̱ xka mꞌu̱hwihu̱, nuya xta ñꞌemu̱ihu̱. 
\p  
\v 19 Ne di a̱pabi gi pöhu̱ tengu ár döta ár tsꞌe̱di mpe̱ ha ri mfenihu̱. Getnu̱ ar döta tsꞌe̱di xi utkagihu̱, 
\p  
\v 20 núꞌmu̱ bi japi bi nte manꞌagi ar tsi Hmu Hesukristo, ne bi gu̱xa habu̱ xki tꞌa̱hwi nuꞌu̱ xi du, ne bi ꞌñexa hár ñꞌe̱i núnu̱ mhetsꞌi habu̱ bi ꞌbu̱hwiꞌö. 
\p  
\v 21 Ne bi umba nꞌar döta nsu töta gatho ya ndö, nuꞌu̱ hö yá tsꞌu̱tꞌwi, nuꞌu̱ ja yá tsꞌe̱di, nuꞌu̱ ja yá nsu, ne gatho nuꞌu̱ nho̱mba yá thuhu har ximha̱i, töte ár nsu nuya payu̱ ne hiñhamꞌu̱ da götsꞌi. 
\p  
\v 22 Ne bi hñuxa da ndö gatho nöꞌö te jawa ne ꞌbu̱i, ne bi ꞌñexꞌö ngu ár ñöxhmu ar nijö. 
\p  
\v 23 Ha nu ar nijö jwatwabi da nxo̱ge ár ndoꞌyo, ha nunar tsi Hmu jwatwabi da nxo̱ge gatho nöꞌö te ja ne te ꞌbu̱i. 
\c 2  
\p  
\v 1 Nuꞌahu̱ xka mꞌe̱hmöhu̱ mamꞌe̱tꞌo ha ya tsꞌoki, ne ngi ꞌbu̱hu̱ har tsꞌomꞌu̱i, po̱ntho hinge ngi tehu̱, ha nupya Jö xi ꞌraꞌahu̱ nꞌar ꞌraꞌyo te. 
\p  
\v 2 Ngi ꞌbu̱hu̱ njapꞌu̱ ngetho ngi te̱mfu̱ ár mꞌu̱i ar ximha̱i. Ne ngi pe̱pabihu̱ ár ndö ya tsꞌondöhi, pe̱ꞌsa ár tsꞌe̱di har ndöhi, ne pumbyá mfeni ya me̱ꞌsku. 
\p  
\v 3 Mamꞌe̱tꞌo gathogihu̱ ngu ꞌbu̱ꞌu̱ nꞌehe, ndi umbabihu̱ gatho nöꞌö mi ne ma ndoꞌyohu̱, ne ndi o̱thu̱ gatho nöꞌö mi benga ma mfenihu̱. Jange nuju̱ ho̱nse̱ ár kwe̱ Jö ndi to̱ꞌmhu̱, ngu to̱ꞌma nuꞌu̱ hinxi ñꞌemu̱i. 
\p  
\v 4 Ha Jö xa döta ár nhwëki ne xa bi mökagihu̱. 
\p  
\v 5 Jange ngu bi japi bi nte manꞌagi ar tsi Hmu Hesukristo, njapꞌu̱ nuju̱ nꞌehe, bi ꞌraju̱ nꞌar ꞌraꞌyo te, ngetho xki mꞌe̱ ma tehu̱ har tsꞌoki, po̱ntho ngu xta tumhöhu̱, ne Jö bi hwëgagihu̱, bi ꞌraju̱ ar mpo̱ho̱. 
\p  
\v 6 Ne ngu bi gu̱xa ar tsi Hmu Hesukristo, njapꞌu̱ bi gu̱xkagihu̱ nꞌehe, ne bi ꞌñexkagihu̱ ga ꞌbu̱hwihu̱nu̱ mhetsꞌi. 
\p  
\v 7 Bi ꞌyo̱tkagihu̱ njapꞌu̱, mi honga nuya pa di ꞌñepꞌu̱ da födi hangu ar ñho xi hwëgagihu̱, bi ko ár mu̱i ba pe̱nkagihu̱ ar tsi Hmu Hesukristo. 
\p  
\v 8 Ngetho Jö bi hwëgagihu̱ ar mpo̱ho̱ núꞌmu̱ nda ñꞌemu̱ihu̱. Himbi po̱kagihu̱ ma tsꞌe̱dise̱hu̱, gehnu̱ nꞌár ntꞌuni Jö. 
\p  
\v 9 Hinto xi po̱se̱ yá hoga ꞌbe̱fi. Nuꞌmu̱ bi njapꞌu̱, tsa̱ da ꞌñexhmö ár nsu ꞌmu̱. 
\p  
\v 10 Jö go bi mengi bi hyógagihu̱ maꞌraꞌyo ngetho di nꞌatꞌwihu̱ ar tsi Hmu Hesukristo, ne njapꞌu̱ nga o̱thu̱ nöꞌö ar ñho xki ꞌye̱gagihu̱ Jö nga o̱thu̱. 
\s1 Nunár ndöte ar tsi Hmu Hesukristo bi ꞌyo̱tꞌa ar ñhogamu̱i 
\p  
\v 11 Jange nuꞌahu̱ hingar xodyohu̱, beñhu̱ mamꞌe̱tꞌo hinge xki thusꞌahu̱ ar nse̱gi ha ri ndoꞌyohu̱ ngu pe̱ꞌsa ya xodyo. Jange mi eñꞌahu̱ ngar tsꞌoktehu̱, mödi nunar nse̱ginu̱ mi huxase̱ ya jöꞌi. 
\p  
\v 12 Mamꞌe̱tꞌo hinge ngi ꞌbu̱hwihu̱ ar tsi Hmu Hesukristo, ngi ꞌbu̱hu̱ yapꞌu̱. Hinge ngar menguhu̱ Israel, ne hinge ndi ꞌñepꞌahu̱ nuya ñhötꞌi xki nkohwiꞌu̱. Hinte ngi to̱ꞌmhu̱, hinge ngi pöhu̱ Jö, ngi ꞌbu̱se̱hu̱ har ximha̱i. 
\p  
\v 13 Mapaꞌö ngi ꞌbu̱hu̱ yapꞌu̱ xka hye̱hu̱ Jö. Ha nupya xka ñꞌemu̱ihu̱ ar tsi Hmu Hesukristo, xi jaꞌahu̱ xka kwathu̱, ngetho bi nöꞌma ár ji har pontꞌi. 
\p  
\v 14 Nuje dar xodyohe ne nuꞌahu̱ hingar xodyohu̱, núꞌmu̱ mi du ar tsi Hmu Hesukristo bi textꞌa ar jödo ntꞌu̱tsa xki ꞌwegagihu̱. Njapꞌu̱ nda za̱ ngar nꞌada ar hninihu̱ ne nga ñhogamu̱ihu̱ nꞌa ngu nꞌa. 
\p  
\v 15 Núꞌmu̱ mi tsꞌu̱twa ár ndoꞌyo har pontꞌi, geꞌmu̱ bi hwata ar ntꞌu̱tsa, ngetho bi hñökwa ár tsꞌe̱di ya ꞌbe̱pate ne gatho yá ntꞌumbi. Mi yoho ya hnini bi hyoka nꞌase̱, ngetho nꞌatꞌwu̱ te̱ñꞌö ba e ar hogamꞌu̱i. 
\p  
\v 16 Gehnu̱ har pontꞌi bi hwata ar ntꞌu̱tsa mi pe̱ꞌsa nuꞌu̱ yoho ya hniniyu̱, bi mhödi ne bi ñhogamu̱iwi Jö, ngetho bi nꞌatwi ndoꞌyoꞌu̱ ar tsi Hmu Hesukristo. 
\p  
\v 17 Jange ar tsi Hmu Hesukristo ba hönkagihu̱ ar hoga mhö xta ñhogamu̱iwihu̱ Jö, nuꞌahu̱ ngi ꞌbu̱hu̱ yapꞌu̱, ne nuje ya xodyo ndi ꞌbu̱he getꞌu̱tho. 
\p  
\v 18 Ngetho bi ungár te ma tsi Hmuhu̱ Hesukristo, gathogihu̱ ngu ya xodyo ne nuꞌu̱ hingya xodyo, da tsa̱ ga ku̱thu̱ habu̱ bi ꞌbu̱ Jö ma Dadahu̱, ngetho di ꞌbu̱hwihu̱ ár Hñö Jö mahye̱gi xi tꞌakagihu̱. 
\p  
\v 19 Jange nupya hingar nꞌañꞌohu̱, ne hingar nzo̱ho̱hu̱. Gar menguhu̱ ár hnini Jö ngu gatho nu maꞌra ya gamfi, ne yá bötsiꞌihu̱ nꞌehe. 
\p  
\v 20 Ne mahye̱gi di ꞌbu̱hu̱ hár nijö Jö ꞌyo di thoki. Numa tsi Hmuhu̱ Hesukristo ñhe̱hwi ar mu̱dido. Nuje yá mpo̱tegihe ne nu maꞌra yá mꞌe̱hni Jö, di janguhe ár wa ar jödo. 
\p  
\v 21 Gathogihu̱ ya gamfi di njanguhu̱ nꞌar ngu thoki, ꞌyo di hetsꞌi mahye̱tho ya do, ne da ho nꞌar nijö xintꞌaxi ngetho nꞌatꞌwi di ꞌbu̱hwihu̱ ar tsi Hmu. 
\p  
\v 22 Nguꞌahu̱ ne nguje di nꞌatꞌwihu̱ ar tsi Hmu Hesukristo, ne di ꞌyo di tehu̱ mahye̱gi gatho maꞌra ya gamfi, ga tso̱ñhu̱ ngu ár nijögihu̱ Jö habu̱ ꞌbu̱ ár Hñö. 
\c 3  
\s1 Ar ꞌbe̱fi bi tꞌumba ar Pablo da hñöꞌspa ar hoga mhö nuꞌu̱ hingya xodyo 
\p  
\v 1 Nuga ar Pablo, di owa har fa̱di ngetho di zoꞌahu̱ ár hoga mhö ar tsi Hmu Hesukristo nuꞌahu̱ hingar xodyohu̱. 
\p  
\v 2 Zage gi pöhu̱ bi hwëgagi Jö ar ꞌbe̱fi ga hösꞌahu̱ ar hoga mhö. 
\p  
\v 3 Jö bi utkagi nöꞌö hinxki fö mamꞌe̱tꞌo, ngu xta otꞌahu̱ nꞌa tsi tu̱i. 
\p  
\v 4 Nu xki néhu̱ ma gi pöhu̱ tengu dí pödi nöꞌö himi fö mamꞌe̱tꞌo, tema nda ꞌyo̱tꞌa ma tsi Hmuhu̱ Hesukristo. 
\p  
\v 5 Nunar mfeninu̱ xki jwatatho, hinte ma jöꞌi xki tꞌuti, ngu xi utwabipya ár Hñö Jö yá hoga mpo̱te ne yá mꞌe̱hni Jö. 
\p  
\v 6 Xi tꞌutkagihe, nuꞌu̱ hingya xodyo mahye̱giwi nu maꞌra, ma da hñönga ya ñho nꞌehe, ne da nꞌadar ndoꞌyowi ya xodyo. Ne da ñhehwi yá ñhötꞌi pe̱sꞌu̱, ngetho mi ꞌyo̱ ar hoga mhö mi mhö, bi jamfi ar tsi Hmu Hesukristo. 
\p  
\v 7 Nunar mhöꞌö Jö bi hñuxkagi ga mö. Bi njapꞌu̱ ngetho bi hwëgagi ár ntꞌuni, ne nunár döta tsꞌe̱di bi mpe̱ ha ma mu̱i. 
\p  
\v 8 Xi tꞌaka nunar ꞌbe̱finu̱, mödi hinda tsa̱ ga ñhuxꞌbe nu maꞌra ya gamfi, di ko ya ha̱i. Xi nhwëgagi nunar ꞌbe̱finu̱, ga höꞌspabi nuꞌu̱ hingya xodyo ya hoga mhö no̱nga gatho ya ñho pe̱ꞌsa ar tsi Hmu Hesukristo, hingi tso xo̱ge ma mfenihu̱. 
\p  
\v 9 Ne ga otꞌwa ar ꞌñu gatho nöꞌö tema xki benga Jö nda ꞌyo̱tꞌe ne xki ꞌñögi, núꞌmu̱ hinxki hoktho gatho nöꞌö te japya. 
\p  
\v 10 Ne njapꞌu̱ da nheki hár nijö nuya ár nze̱ye̱ ár mfödi Jö, ne da bö nuꞌu̱ togo bi the̱ yá nsu ne nuꞌu̱ togo bi the̱ yá tsꞌe̱dinu̱ mhetsꞌi. 
\p  
\v 11 Gehnu̱ ar mfeni xki benga Jö mamꞌe̱tꞌo, mꞌe̱fa bi ꞌñu hár te ma tsi Hmuhu̱ Hesukristo. 
\p  
\v 12 Ngetho di ñꞌemu̱ihu̱ ar tsi Hmu Hesukristo, hinga ntsuhu̱ ne hinga ntsa̱hu̱ ga kwathu̱ ga ñöwihu̱ Jö. 
\p  
\v 13 Jange di a̱ꞌahu̱, hingi tu ri mu̱ihu̱ gi hanthu̱ di tho ya ntꞌu̱tsa ngetho di hösꞌahu̱ ar hoga mhö. Njohyahu̱, gehnu̱ esꞌahu̱ ri nsuhu̱. 
\s1 Nunar döta mhöte hingi tsa̱ da zo ma mfenihu̱ 
\p  
\v 14 Jange di nda̱ndihmö hár nthandi ár Dada ma tsi Hmuhu̱ Hesukristo. 
\p  
\v 15 Gehnu̱ ár Dada togo bi umba yá te gatho ya mꞌu̱i ꞌbu̱kwa har ximha̱i, ne gatho nuꞌu̱ ꞌbu̱hnu̱ mhetsꞌi. 
\p  
\v 16 Di a̱pabi ngu ár ntꞌe̱ni yá ñho pe̱ꞌsa hár nsunda, da ze̱tꞌa ri mu̱ihu̱ hár Hñö Jö gi ꞌbu̱hwihu̱. 
\p  
\v 17 Di a̱pabi nꞌehe da mꞌu̱ ha ri mu̱ihu̱ ar tsi Hmu Hesukristo, ngetho gi jamfihu̱, ne njapꞌu̱ gi mꞌa̱thu̱ xiñho hár mhöte. 
\p  
\v 18 Ne gatho nuꞌahu̱, ngu nu maꞌra ya gamfi, da tsa̱ gi pöhu̱ tengu ár nxidi, ár ma, ár ñhe ne ár ñhetsꞌi ár mhöte ar tsi Hmu Hesukristo. 
\p  
\v 19 Ne gi pöthwu̱ nunar döta mhötenu̱ hinto tsa̱ da zo xiñho hár mfeni, ne xa da ziñꞌahu̱ ár mꞌu̱i Jö. 
\p  
\v 20 Nsunda Jö togo pe̱ꞌsa ar tsꞌe̱di da ꞌyo̱tꞌa gatho nöꞌö neꞌö, töta ár nze̱ye̱ nöꞌö tsa̱ da zo ma mfenihu̱ ga a̱fu̱. Gathonu̱ o̱tꞌa ár tsꞌe̱di mpe̱ ha ma mu̱ihu̱. 
\p  
\v 21 Dá nsundabi ar nijö ꞌbu̱hwi ar tsi Hmu Hesukristo hyaxꞌmu̱ ne hiñhamꞌu̱ da götsꞌi. Dá njapꞌu̱. 
\c 4  
\s1 Di nꞌatꞌwihu̱ ár Hñö Jö 
\p  
\v 1 Nuga di owa har fa̱di ngetho di mömba ár mhö ma tsi Hmuhu̱, di a̱ꞌahu̱ gi ꞌbu̱hu̱ ngu di ꞌñepi da mꞌu̱ nuꞌu̱ togo xi tsꞌohni da mbötsi Jö. 
\p  
\v 2 Yo gi ñꞌexu̱, ntsꞌa̱ꞌmthohu̱. Pe̱ꞌsu̱ nꞌar hogamu̱i ne ar tsꞌe̱ti, ne gi mhöhu̱ nꞌa ngu nꞌa. 
\p  
\v 3 Nuꞌahu̱ gi nꞌase̱hu̱ ngetho nꞌada ár Hñö Jö ꞌbu̱ ha ri mu̱ihu̱. Jange umba ri mu̱ihu̱ gi pe̱ꞌsu̱ nꞌadar mfeni, ne gi ꞌbu̱hu̱ nꞌar hogamꞌu̱i. 
\p  
\v 4 Ngetho di nꞌadar ndoꞌyohu̱, nꞌadár Hñö Jö ꞌbu̱ ha ma mu̱ihu̱, jangu xi tsꞌonkagihu̱ nꞌehe ga pe̱ꞌsu̱ nꞌadar ndo̱ꞌmi. 
\p  
\v 5 Nꞌadar tsi Hmu di zohu̱, nꞌada ma ñꞌemu̱ihu̱, ne nꞌadar xixthe xta höñhu̱. 
\p  
\v 6 Nꞌadar Jö togo ma Dadahu̱ gatho nuꞌu̱ di ꞌbu̱hu̱. Ár tsꞌe̱di hexkagihu̱, ne ꞌrakagihu̱ ár mfa̱tsꞌi di gathohu̱, ne ꞌbu̱ ha ma mu̱ihu̱. 
\p  
\v 7 Nꞌa ngu nꞌa bi hwëgagihu̱ ar tsi Hmu Hesukristo nꞌar hogantꞌuni ngu ár ntꞌe̱niꞌö. 
\p  
\v 8 Jange bi thogi ngu mönga ár Tꞌofo Jö habu̱ enö: 
\q1 Ar tsi Hmu bi ntöte ne bi bo̱xa mhetsꞌi, bi zixa nuꞌu̱ xki döhö, 
\q1 ne bi hyemba ya ntꞌuni ya jöꞌi. 
\p  
\v 9 Te di bo̱nga nöꞌö enö bi bo̱xa mañö mhetsꞌi. Ne da ꞌñenö, nöꞌö mi ꞌbu̱ mhetsꞌi ba kökwa har ximha̱i. 
\p  
\v 10 Nöꞌö togo ba e har ximha̱i bi mengi bi bo̱xa manꞌagi har ngöxa mhetsꞌi, ne njapꞌu̱ bi hyexta ár nsunda xo̱ge nöꞌö xi thoki. 
\p  
\v 11 Gese̱ bi ꞌñexꞌö ꞌra ngu yá mpo̱te, maꞌra yá mꞌe̱hni, maꞌra nda mömba ár hoga mhö, maꞌra da mfa̱ꞌyo ha yá nijö, maꞌra da utwa ár mhö Jö. 
\p  
\v 12 Gathoyu̱ fa̱xte da ñöxa ár ñꞌemu̱i ya ku, ne da me̱pa Jöꞌu̱ nꞌehe. Ne njapꞌu̱ da te ar nijö, gehnu̱ ár ndoꞌyo ar tsi Hmu Hesukristo. 
\p  
\v 13 Njapꞌu̱ ga jwahu̱ gatho ga pe̱ꞌsu̱ nꞌadar ñꞌemu̱i, ne ga pötwabihu̱ xiñho ár Tꞌu̱ Jö. Ga tso̱ñhu̱ ga ñhogajöꞌihu̱, ne gatho ga ñhe̱hwihu̱ ár mꞌu̱i ar tsi Hmu Hesukristo. 
\p  
\v 14 Hindi hñöxkagihu̱ ya tꞌu̱lo bötsi hingi pötetho, to gatho tsa̱ da kadi da me̱wi te̱mba yá jamfi. Nuya jöꞌiyu̱ ju̱ ar nhemhñö ne ya tsꞌomfeni japa ya ku da de̱nga nöꞌö hingi ho. 
\p  
\v 15 Nöꞌö ma ga o̱thu̱, ga te̱ñhu̱ nöꞌö majöni ne ga pe̱ꞌsu̱ ar mhöte. Njapꞌu̱ da ñöxa ma jamfihu̱, ne ga ñhe̱hwihu̱ ar tsi Hmu Hesukristo togo ár ñöxhmu ar nijö. 
\p  
\v 16 Nunar nijö hömba ár tsꞌe̱di ar tsi Hmu, ne njapꞌu̱ nꞌa ngu nꞌa ya ku ꞌyo di ma̱xa maꞌra, ngu ar ꞌbe̱fi xi tꞌumbabi. Ne ꞌyo di te, ne da me̱ꞌsa yá tsꞌe̱di te̱nga ar mhöte. 
\s1 Ar ꞌraꞌyo mꞌu̱i tꞌakagihu̱ ngetho di ꞌbu̱hwihu̱ ar tsi Hmu Hesukristo 
\p  
\v 17 Di ꞌbe̱pꞌahu̱ hár thuhu ma tsi Hmuhu̱, gi hye̱hu̱ gi te̱mbathohu̱ yá mꞌu̱i nuꞌu̱ hinxi ñꞌemu̱i, ngetho hinte mañho beñꞌu̱. 
\p  
\v 18 Xi me yá ñö, hingi ne da hñöñꞌu̱ ar te unga Jö, ngetho hinte pöꞌu̱ ne xi gotꞌa yá mu̱i. 
\p  
\v 19 Bi ꞌbe̱ yá mfeni, bi ñꞌe̱ntꞌathoꞌu̱ bi ꞌyo̱tꞌa gatho nuꞌu̱ ya tsꞌoki mi neꞌu̱, ne gor johyaꞌu̱ da ꞌyo̱tꞌa nöꞌö xintsꞌotho. 
\p  
\v 20 Ha nuꞌahu̱ hinxi utꞌahu̱ njapꞌu̱ ar tsi Hmu Hesukristo, 
\p  
\v 21 nuꞌmu̱ xa majöni xka ꞌyo̱hu̱ nöꞌö xi möñꞌö, ne xka ꞌyo̱xu̱ nöꞌö xa majöni utꞌö. 
\p  
\v 22 Nöꞌö ar mꞌu̱i ngi pe̱ꞌsu̱ mahamꞌu̱, hye̱hu̱pꞌu̱ nꞌagitho. Ngu nꞌar ze̱ dutu kꞌothu̱ ꞌye̱ñhu̱pꞌu̱, xi zu̱ ar tsꞌoꞌyo, kate o̱tꞌa ar tsꞌoki. 
\p  
\v 23 Hye̱hu̱ da nꞌaꞌyo ri mu̱ihu̱ ne ri mfenihu̱. 
\p  
\v 24 Ne ꞌbu̱hu̱ nunar ꞌraꞌyo mꞌu̱i xi tꞌaꞌahu̱, ngu nꞌar ꞌraꞌyo he gi hyehu̱ xi thoki di hñöxa Jö, xa majöni ar hogajöꞌi ne xintꞌaxi. 
\p  
\v 25 Jange hye̱hupꞌu̱ ar nhemhñö. Möñhu̱ nöꞌö majöni núꞌmu̱ gi ñöwi ri ñꞌowihu̱, ngetho di nꞌadar ndoꞌyohu̱ nꞌa ngu nꞌa. 
\p  
\v 26 Nuꞌmu̱ da mbo̱ ri kwe̱hu̱, yo ma da hya̱ꞌahu̱ ri mfenihu̱ gi ꞌyo̱thu̱ nꞌar tsꞌoki. Ñhogamu̱ihu̱, yo gi to̱ꞌmhu̱ da tho ar pa. 
\p  
\v 27 Yo gi hofu̱ da hya̱ꞌahu̱ ar tsꞌondöhi. 
\p  
\v 28 Nöꞌö togo mar bë, dá hye̱pꞌu̱ ar mfë. Dá hyonga nꞌar hoga ꞌbe̱fi, ne njapꞌu̱ da me̱ꞌsa teme da mfa̱xkwi nöꞌö togo hinte pe̱tsꞌi. 
\p  
\v 29 Yogar tsꞌonehu̱, hyoñhu̱ hanja gi ñöhu̱ xiñho, ne njapꞌu̱ nuꞌu̱ togo da ꞌyo̱xꞌahu̱ da ma̱tsꞌi ne da numañho. 
\p  
\v 30 Ne yo gi tso̱thwu̱ ár mu̱i ár Hñö Jö. Xi thusꞌahu̱ ngu nꞌar nkohi, ne xta zo̱nga ar pa da tsꞌiñꞌahu̱, da fötho yá bötsiꞌihu̱ Jö. 
\p  
\v 31 Hye̱hu̱pꞌu̱ gatho ar ntso̱tmu̱i, ar kwe̱, ar ntꞌu̱tsa, ya mhafi, ya tsꞌate, ne gatho ya tsꞌomfeni. 
\p  
\v 32 Nöꞌö xiñho gi ꞌyo̱thu̱, ñhogajöꞌihu̱ nꞌa ngu nꞌa, mpe̱ꞌsu̱ ar nhwëki mpuñhu̱ nꞌa ngu nꞌa, ngu ar tsi Dada bi pumgagihu̱ mi unga ár te ar tsi Hmu Hesukristo. 
\c 5  
\s1 ꞌBu̱hu̱ xiñho ngetho yotꞌahu̱ Jö 
\p  
\v 1 Umba ri mu̱ihu̱ gi te̱mfu̱ ár mꞌu̱i Jö, ngetho go yá hmöka bötsiꞌihu̱. 
\p  
\v 2 ꞌBu̱hu̱ gi mhöhu̱ nꞌa ngu nꞌa ngu bi mökagihu̱ ar tsi Hmu Hesukristo. Bi gutka ma tha̱ihu̱ núꞌmu̱ mi unga ár te har pontꞌi, ngu nꞌar mꞌo̱ñho̱ yu̱ni xiñho mꞌo̱ꞌspa Jö. 
\p  
\v 3 Nuꞌu̱ xka jamfihu̱, yo gi ꞌbe̱ngwihu̱ nꞌar jöꞌi nöꞌö hingo ri nthötihu̱, yo gi benthu̱ nöꞌö xintsꞌotho, yo xa gi möhu̱ ar bojö, hingi no̱ñhu̱ nuya tsꞌokiyu̱. ꞌBu̱hu̱ ngu di ꞌñepi da mꞌu̱ nꞌar gamfi. 
\p  
\v 4 Yo gar tsꞌonehu̱, yo gi ñöhu̱ ñꞌentho, yo gi ñꞌöntꞌu̱hu̱, ngetho hingi ho da ꞌyo̱tꞌa njapꞌu̱ ya gamfi. Nöꞌö xiñho gi ꞌyo̱thu̱, umfu̱ njamödi Jö. 
\p  
\v 5 Pöhu̱ xiñho hinda ma da yu̱tꞌa da ndöwi ar tsi Hmu Hesukristo bi ꞌbu̱hwi Jö, gatho nuꞌu̱ ꞌbe̱ngwi ya jöꞌi, nuꞌu̱ te̱nga ar tsꞌoki, ne nuꞌu̱ xa mö ar bojö, po̱ntho ndöñꞌu̱. 
\p  
\v 6 Yo ma gi ñhe̱hu̱ togo da hya̱ꞌahu̱ ya nemhñö, ngetho nuya tsꞌokiyu̱ japi da e ár kwe̱ Jö da zu̱ nuya me̱ꞌsku. 
\p  
\v 7 Jange yo gi ñꞌowihu̱ nuꞌu̱ togo o̱tꞌa nuya tsꞌoꞌbe̱fiyu̱. 
\p  
\v 8 Mamꞌe̱tꞌo ngi ꞌbu̱hu̱ har ꞌbe̱xui, ha nupya gi ꞌbu̱hwihu̱ ar tsi Hmu har hyatsꞌi. ꞌBu̱hu̱ ngu nuꞌu̱ ꞌyo hár hyatsꞌi Jö. 
\p  
\v 9 Ngetho nuya ꞌbu̱ har hyatsꞌi, ár Hñö Jö fa̱tsꞌi da ñhogajöꞌi, da me̱ꞌsa ar hogamꞌu̱i, ne di mönga nöꞌö majöni. 
\p  
\v 10 Umba ri mu̱ihu̱ gi ꞌyo̱thu̱ nöꞌö numañho ar tsi Hmu. 
\p  
\v 11 Ne yo gi te̱mfu̱ yá ꞌbe̱fi nuꞌu̱ togo ꞌbu̱ har ꞌbe̱xui, hinte ár ñho. Nöꞌö gi ꞌyo̱thu̱, xipabihu̱ hingi ho nöꞌö pe̱ꞌu̱. 
\p  
\v 12 Ngetho nꞌar mꞌe̱tsa̱ ga no̱ñhu̱ nöꞌö o̱tꞌu̱ ñꞌöntho. 
\p  
\v 13 Ha nuꞌmu̱ da tꞌeꞌspa ar ñotꞌi nuya tsꞌoꞌbe̱fi pe̱ꞌu̱, nuꞌmú̱ hö, da födi tema di bo̱nga nuya te pe̱ꞌu̱, ngetho har ñotꞌi ka nhekinu̱ xo̱ge. 
\p  
\v 14 Jange xi tꞌenö njawa: 
\q1 Nuꞌge gi öhö, nuhu, 
\q1 po̱nga nupꞌu̱ hár tꞌa̱gi nuꞌu̱ xi du, 
\q1 ne ar tsi Hmu Hesukristo da yotꞌaꞌi. 
\p  
\v 15 Pöhu̱ xiñho hanja gi ꞌbu̱hu̱. ꞌBu̱hu̱ ngu nuꞌu̱ pe̱ꞌsa yá mfödi, hingi ꞌbu̱hu̱ ngu nuꞌu̱ hinte pödi. 
\p  
\v 16 Yo gi huhu̱, umba ri mu̱ihu̱ gi ꞌyo̱thu̱ nöꞌö xiñho, ngetho nuya payu̱ di ꞌbu̱hu̱ xintsꞌotho. 
\p  
\v 17 Yo gi ñhe̱hu̱tho, umba ri mu̱ihu̱ gi pöhu̱ nöꞌö ne Jö gi ꞌyo̱thu̱. 
\p  
\v 18 Yo gi ntihu̱, ngetho ar mihni ma da jaꞌahu̱ gi ntsꞌoju̱. Nöꞌö xiñho gi ꞌyo̱thu̱, hyoñhu̱ xa di ziñꞌahu̱ ár Hñö Jö. 
\p  
\v 19 Núꞌmu̱ gi ñöhu̱, no̱ñhu̱ ya hoga nsa̱di, ya jöhñö ne ya hoga thuhu. Tuthwu̱ ne gi ꞌye̱ntꞌa ri mu̱ihu̱ gi xa̱thu̱ Jö. 
\p  
\v 20 Gatho nöꞌö di ꞌñepꞌahu̱, umfu̱ njamödi Jö ar Dada hár thuhu ma tsi Hmuhu̱ Hesukristo. 
\s1 Ñꞌo̱thu̱ nꞌa ngu nꞌa ri kuhu̱ 
\p  
\v 21 Ngetho gi tsufu̱ ar tsi Hmu, ñꞌo̱thu̱ nꞌa ngu nꞌa. 
\p  
\v 22 ꞌBe̱hñöhu̱ xka nthöthu̱, ꞌyo̱thu̱ ri dömese̱hu̱ ngu gi o̱thu̱ ar tsi Hmu Hesukristo. 
\p  
\v 23 Ngetho ar döme gehnu̱ ár ñöxhmu ar ꞌbe̱hñö, ngu ar tsi Hmu Hesukristo ár ñöxhmu ar nijö, ne ar nijö gehnu̱ ár ndoꞌyo ar tsi Hmu togo ár Po̱ho̱te. 
\p  
\v 24 Jange ngu ar nijö o̱ta ar tsi Hmu Hesukristo, njapꞌu̱ nuya ꞌbe̱hñö da ꞌyo̱tꞌa gatho nöꞌö te da xipa yá döme. 
\p  
\v 25 Dömehu̱, mö ri ꞌbe̱hñöhu̱ ngu ar tsi Hmu Hesukristo bi mö ár nijö, ne bi unse̱ ár te bi po̱ho̱. 
\p  
\v 26 Bi du, ne njapꞌu̱ bi hñögagihu̱ ma tsꞌokihu̱, mi xu̱ga ma mu̱ihu̱ ndi o̱ꞌsfu̱ ne ndi o̱thwu̱ ár mhö. 
\p  
\v 27 Bi xu̱gagihu̱ ne nda ꞌba̱bgagihu̱ hár nthandise̱ ngu ár nijö xa nza̱tho, hinte xi ja̱xtꞌi ne hinxi gu̱xtꞌi, da thandi dar ntꞌaxi ne xa ꞌbu̱i xiñho. 
\p  
\v 28 Njahu̱pꞌu̱ nuꞌahu̱ gar dömehu̱ nꞌehe, möhu̱ ri ꞌbe̱hñöhu̱ ngu gi möse̱ ri ndoꞌyohu̱. Nöꞌö to mö ár ꞌbe̱hñö, mhöse̱ nꞌehe. 
\p  
\v 29 Ngetho hinto u̱tsase̱ ár ndoꞌyo, gi pöhu̱ ꞌwini ne su, jangu ar tsi Hmu Hesukristo su ar nijö. 
\p  
\v 30 Geju̱ ár ndoꞌyogihu̱ ar tsi Hmu Hesukristo, ne nꞌa ngu nꞌa dar nꞌa xe̱nigihu̱ ár ndoꞌyoꞌö. 
\p  
\v 31 Jange enga hár Tꞌofo Jö, ar ñꞌo̱ho̱ da zopꞌu̱ ár dada ne ár nönö, ne da mꞌu̱hwi ár ꞌbe̱hñö, ne nuya yohoyu̱ ma da nꞌatho. 
\p  
\v 32 Xa xi ñhembi nunar ntꞌutinu̱, mödi nuga di he̱ka ar tsi Hmu Hesukristo ne ár nijö. 
\p  
\v 33 Jange ma ga xiꞌahu̱: Nꞌa ngu nꞌa möhu̱ ri ꞌbe̱hñöhu̱ ngu gi mhöse̱hu̱, ne nuya ꞌbe̱hñö dá ꞌyo̱ta yá döme. 
\c 6  
\p  
\v 1 Bötsihu̱, ꞌyo̱thu̱ ri menguhu̱ ngetho gi ꞌbu̱hwihu̱ ar tsi Hmu. Gehnu̱ xiñhoꞌö. 
\p  
\v 2 ꞌYo̱thu̱ ngu mönga ár mhö Jö habu̱ enö: ꞌÑeꞌsfu̱ ár nsu ri dada ne ri nönö, gehnu̱ ar ꞌbe̱tꞌo ꞌbe̱pate ñötꞌahu̱ ar ñhötꞌi. 
\p  
\v 3 Nunar ñhötꞌinu̱ mö gi pe̱ꞌsa nꞌar hogamꞌu̱i ne gi ꞌbu̱kwa nze̱ye̱ ya pa har ximha̱i. 
\p  
\v 4 Ha nuꞌahu̱ gar dadahu̱ ne nuꞌahu̱ gar nönöhu̱, yo gi po̱mfu̱ ár kwe̱ ri bötsihu̱. Hñöjwu̱ nöꞌö hingi ho ne uthwu̱ ár ꞌñu ar tsi Hmu. 
\p  
\v 5 Nuꞌahu̱ gi mꞌe̱gohu̱, ꞌyo̱thu̱ ri hmuhu̱wa har ximha̱i. ꞌÑeꞌsfu̱ ár nsu, ne tsitꞌa ri mu̱i gi pe̱fu̱, to da ꞌñenö gi pe̱fu̱ ar tsi Hmu Hesukristo. 
\p  
\v 6 Mpe̱hu̱ xiñho, hinge ho̱nse̱ núꞌmu̱ hantꞌahu̱ ri hmuhu̱ gi ne gi kohu̱ xiñho. Ngu yá ꞌbe̱goꞌihu̱ ar tsi Hmu Hesukristo, di tsitꞌa ri mu̱ihu̱ gi ꞌyo̱thu̱ Jö. 
\p  
\v 7 Xa gi nese̱hu̱ gi mpe̱hu̱, hinge jangu gi pe̱fu̱ nꞌar jöꞌi, ꞌyo̱thu̱ wande gi pe̱pabihu̱ ar tsi Hmu. 
\p  
\v 8 Beñhu̱, nunar tsi Hmu ma da ꞌraꞌahu̱ ar njutꞌi, ngu nöꞌö ar ñho xka ꞌyo̱thu̱ nꞌa ngu nꞌa, wa gi ꞌñehu̱ ri hmuhu̱, wa gar hmuhu̱. 
\p  
\v 9 Nuꞌahu̱ gar hmuhu̱, ꞌyo̱tꞌwabihu̱ ar ñho ri ꞌbe̱gohu̱, yo gi pihu̱. Beñhu̱, nuꞌahu̱ nguꞌu̱ bi ꞌbu̱ nꞌa ri Hmuhu̱ mañö mhetsꞌi, ne nöꞌö hingi hwanta ya jöꞌi. 
\s1 Ga hehu̱ ar he xi ꞌraju̱ Jö ngu nꞌar ndogu 
\p  
\v 10 Nupya tsi kuhu̱, gi hömfu̱ ár döta tsꞌe̱di ar tsi Hmu, gehnu̱ da ze̱tꞌa ri mu̱ihu̱. 
\p  
\v 11 Ngu ñhoka nꞌar ndogu di ma har tuhni, njapꞌu̱ nuꞌahu̱ nꞌehe, hyehu̱ ar he xi ꞌraꞌahu̱ Jö, da ma̱xꞌahu̱ gi tse̱thwu̱ yá nhemhñö ar tsꞌondöhi. 
\p  
\v 12 Ngetho hindi ntunkwihu̱ ma mijöꞌihu̱. Di nto̱xkwihu̱ nuꞌu̱ pe̱ꞌsa yá nsu, ne pe̱ꞌsa yá tsꞌe̱di, ne ya ndö har ꞌbe̱xui nuya payu̱, ne gatho nuya tsꞌondöhi bi nsa̱nga mañö har ndöhi. 
\p  
\v 13 Jange hyehu̱ xiñho nöꞌö ar he tuhni xi ꞌraꞌahu̱ Jö, ne gi tse̱thu̱ nuya pa gi thohu̱ ya thogi. Ne xki ntötehu̱, yo ma gi ñhe̱hu̱ da hyo̱mꞌahu̱ ha̱i. 
\p  
\v 14 Jange umba ri mu̱ihu̱ gi tse̱thu̱, ne gi pe̱ꞌsu̱ nöꞌö majöni ngu nꞌar bötꞌi xka ngu̱thu̱ xiñho, ne ar hogajöꞌi ngu nꞌar hebo̱jö ta̱kꞌahu̱. 
\p  
\v 15 Ngu su yá wa nꞌar ndogu da za̱ da ñꞌo xiñho har tuhni, njapꞌu̱ nuꞌahu̱ nꞌehe, ñhoju̱ habu̱ gatho gi möhu̱ gi mömfu̱ ár mhö Jö unga ar hogamꞌu̱i. 
\p  
\v 16 Ne gi pe̱ꞌsu̱ ar jamfi, ngu nꞌar ntha̱ki gi ta̱jwu̱ gatho yá nkꞌahni ngu ya tsibi bi e̱mpꞌahu̱ ar tsꞌondöhi. 
\p  
\v 17 Gi suhu̱ ar mpo̱ho̱, ngu nꞌar fu̱ibo̱jö da da̱kꞌahu̱ ri ñöhu̱. Ne gi hñöhu̱ ár mhö Jö, ngu nꞌar ndo̱jwai ꞌraꞌahu̱ ár Hñö Jö. 
\p  
\v 18 Ne hyaxꞌmu̱ hinda za̱ꞌahu̱ gi ꞌya̱fu̱ Jö gi hömfu̱ ár tsꞌe̱di ár Hñö. Hingi tsa̱ya̱ gi to̱ꞌmthohu̱ da ma̱xꞌahu̱. Hinge ho̱nse̱ nuꞌahu̱, ꞌya̱fu̱ da ma̱xa gatho nu maꞌra ya gamfi nꞌehe. 
\p  
\v 19 ꞌYa̱pabihu̱ Jö da ma̱xkagiga nꞌehe. Núꞌmu̱ xka ñö, da tꞌaka tema ga mö. Ne hinga ntsu ga zo ya jöꞌi, ne da zo yá mfeni nunar hoga mhö hinxki fö mamꞌe̱tꞌo. 
\p  
\v 20 Jange nuga dar mꞌe̱hni di mönga ar hoga mhö, ne xi thutka nuya bo̱jöyu̱. ꞌYa̱fu̱ Jö da ma̱xkagi hinga ntsu ga mönga nunar hoga mhönu̱, ngu xiñho ga ñö. 
\s1 Ya ngöxanze̱ngwa 
\p  
\v 21 Di pe̱ñꞌahu̱ ma hmöka ku Tikiko, gehnu̱ da xiꞌahu̱ tema di pe̱fi ne tengu di thokwa. Nu xta zo̱mpꞌu̱, nuhu̱ ngu nꞌár hoga ꞌbe̱go ar tsi Hmu. 
\p  
\v 22 Jange di pe̱ñꞌaꞌihu̱pꞌu̱ da metꞌahu̱ tengu di ꞌbu̱hewa, ne da hupꞌa ri mu̱ihu̱. 
\p  
\v 23 Jö ar Dada ne ar tsi Hmu Hesukristo da jöpꞌahu̱ mahye̱gi gatho nu maꞌra ya ku, gi ꞌbu̱hu̱ ter entho, gi mhöhu̱ nꞌa ngu nꞌa, di pe̱wi ar jamfi. 
\p  
\v 24 Jö da hwëkꞌahu̱ yá ñho, gatho nuꞌahu̱ gi möhu̱ ar tsi Hmu Hesukristo ha nꞌar mhöte hingi thege. Dá njapꞌu̱.