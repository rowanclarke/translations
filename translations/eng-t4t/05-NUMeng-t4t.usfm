\q1 \w and|strong="H3068"\w* \w I|strong="H1697"\w* \w speak|strong="H1696"\w* \w to|strong="H1696"\w* \w him|strong="H3045"\w* \w in|strong="H3068"\w* \w dreams|strong="H2472"\w*.
\q1 
\v 7 \w But|strong="H3808"\w* \w that|strong="H3605"\w* \w is|strong="H1931"\w* \w not|strong="H3808"\w* \w the|strong="H3605"\w* \w way|strong="H3651"\w* \w I|strong="H3651"\w* speak \w to|strong="H1004"\w* \w my|strong="H3605"\w* \w servant|strong="H5650"\w* \w Moses|strong="H4872"\w*.
