\id 1TI  
\h 1 Timoteo 
\toc1 YA'A KUU CARTA ƗƗN JA NI CHAA SAN PABLO APOSTOL NUU TIMOTEO 
\toc2 1 Timoteo 
\toc3 1 Ti. 
\mt2 LA PRIMERA EPISTOLA DEL APOSTOL SAN PABLO A TIMOTEO 
\mt1 YA'A KUU CARTA ƗƗN JA NI CHAA SAN PABLO APOSTOL NUU TIMOTEO 
\c 1  
\p  
\v 1 Máá‑rí Pablo kúu apóstol Jesucristo, chi̱ súan ni̱ tá'ú tíñu Dios, I'a̱ náma yóó, jíín Jíto'o̱‑yo̱ Jesucristo, ja̱ káñukuu ini̱‑yo̱‑yá.  
\v 2 Cháa‑ri̱ tutu̱ yá'a nuu̱ Timoteo, se̱'e ndija‑ri̱ ja̱ ní skándíja‑ri̱: Tu̱'un luu íó ini̱‑ya̱, jíín tú'un kúndá'ú ini̱‑ya̱, jíín tú'un kuaká'nu ini̱ ja̱ kíi nuu̱ máá Táa̱‑yo̱ Dios, jíín núu̱ máá Jíto'o̱‑yo̱ Cristo Jesús, ná kóo jíín‑ró. 
\s1 Sɨkɨ̱ ñáyɨvɨ sɨ́ɨn sɨ́ɨn sa'a̱n 
\p  
\v 3 Nátu̱'un ni̱ ka'a̱n nda̱'ú‑ri̱ jíín‑ró já ná kéndo̱o‑ró ñúu̱ Éfeso ná ni̱ ki'in‑ri̱ ichi kuá'a̱n‑ri̱ ñuu̱ Macedonia, ja̱ ná ká'a̱n ni̱'in‑ró jíín sáva‑i, te suni ká'a̱n tuku‑ri̱ ja̱ má stá'a̱n‑i sɨ́ɨn sɨ́ɨn nuu̱ sá'a̱n,  
\v 4 ni ma̱ kuá'a‑i tu̱'un ja̱ ná ndúkú kuáchí‑i sɨkɨ̱ cuento, jíín sɨkɨ́ jíchi tu̱'un tá'an. Chi̱ sua nákaa̱‑ga̱ kua'a̱n, te skuikín tɨxɨ̱n, lugar ja̱ yíja‑ga̱ tu̱'un kándíja‑yó núu̱ Dios sá'a. Achí‑ri̱.  
\v 5 Ya̱'á kúu ja̱ kuní‑ri̱ tá'ú‑rí tiñu nuu̱‑ro̱, ja̱ ná kúndá'ú ini̱‑ro̱‑í jíín tú'un koo ndoo ini̱‑ro̱, jíín tú'un koo va̱'a ini̱ añú‑ro̱, jíín tú'un kándíja ja̱ tú yóso yú'u.  
\v 6 Ja̱ sɨkɨ́ yúán kájika yátá sáva‑i, te kákusɨ́ɨn ini̱‑i kájukuiñi̱‑i sɨkɨ̱ tú'un ja̱ tú ní'i̱n tíñu.  
\v 7 Kákuni̱‑i kuu‑i maestro ley, ko ni tú kájuku̱'un ini̱‑i na̱ún tu̱'un káka'a̱n‑i, ni na̱ún tu̱'un kájani ni̱'in‑i.  
\v 8 A kájini̱‑yo̱ já íó va̱'a ley, ko nú koo kájí iní‑ro̱ jíín.  
\v 9 Chi̱ a jiní‑yo̱ já ley, tú ní kúva̱'a ja̱ ndónda sɨkɨ̱ ñáyɨvɨ vá'a, chi̱ sua ndónda sɨkɨ̱ ñáyɨvɨ ñáá, sɨkɨ̱ ñáyɨvɨ tú kájandatu̱, sɨkɨ̱ ñáyɨvɨ tú káchiñú'ún‑i‑ya̱, sɨkɨ̱ ñáyɨvɨ kásá'a kua̱chi, sɨkɨ̱ ñáyɨvɨ kánda̱a ndɨva̱'a jíín ñáyɨvɨ chá'án, sɨkɨ̱ ñáyɨvɨ kája'ni táa̱ náa̱, jíín sɨkɨ́ ñáyɨvɨ kája'ni ndɨ́yi,  
\v 10 sɨkɨ̱ ñáyɨvɨ kájika téné, sɨkɨ̱ xí'ncha, sɨkɨ̱ ñáyɨvɨ sákuí'ná ñáyɨvɨ, sɨkɨ̱ ñáyɨvɨ káxndá'ú, sɨkɨ̱ ñáyɨvɨ kásátú'ún, jíín sɨkɨ̱ sáva‑ga̱ tu̱'un ja̱ tú káni tá'an jíín tú'un máá‑yá ja̱ íó ndéé ndánu.  
\v 11 Chi tu̱'un‑ún kúu máá tú'un va̱'a luu xaa̱n já vái nuu̱ máá Dios, I'a̱ ii̱. Te sɨkɨ̱ tú'un‑ún ni̱ chaa tíñu‑ya̱ rúu̱. 
\s1 Tiñu ni̱ chaa‑ya̱ sɨkɨ́ Pablo 
\p  
\v 12 Te nákuatá'ú‑rí nuu̱ máá I'a̱ ni̱ ja̱'a fuerza ini̱‑ri̱, kúu Cristo Jesús Jito'o̱‑yo̱, te ni̱ nakani ini̱‑ya̱ já cháa skíkuu va̱'a kúu‑ri̱, te ni̱ chaa tíñu‑ya̱ rúu̱.  
\v 13 Ko onde̱ sáá núú, chi ni̱ ka'a̱n ndɨva̱'a‑ri̱, te ni̱ chindiki̱n‑ri̱‑i, te ni̱ stují‑rí‑i. Ko ni̱ kundá'ú ini̱‑ya̱ rúu̱, chi̱ tú jiní‑ri̱ te ni̱ sá'a‑ri̱, te ni tú ní kándíja‑ri̱ sáá.  
\v 14 Ko tu̱'un luu íó ini̱ máá Jíto'o̱‑yo̱, ni̱ ndea̱‑ga̱ ini̱‑ri̱ jíín tú'un kándíja, jíín tú'un kúndá'ú ini̱ Cristo Jesús ruu̱.  
\v 15 Chi̱ íó va̱'a ja̱ ná kuátá'ú táká‑i tu̱'un ndaa̱ yá'a, ja̱ Cristo Jesús ni̱ kii‑ya̱ iní ñu̱yɨ́vɨ, náva̱'a nama‑ya̱ ñáyɨvɨ kándi̱so kua̱chi, te ruu̱ kúu máá já ní kaa‑ga̱ ni̱ sá'a.  
\v 16 Ko ni̱ kundá'ú ini̱‑ya̱ rúu̱, náva̱'a jíín rúu̱ ja̱ ní kaa‑ga̱ ni̱ sá'a‑ri̱, te kuni̱‑i ndasa íó xaa̱n paciencia ini̱ Jesucristo, náva̱'a kuu‑ri̱ ɨɨn muestra nuu̱ ñáyɨvɨ kúkuéé‑ga̱ kandíja‑i nuu̱‑yá, te nani'i̱n tá'u̱‑í kuchaku̱‑i nɨ́ɨ́ káni.  
\v 17 Núsáá te nɨ́ɨ́ káni nɨ́ɨ́ kuiá ná ká'a̱n jíñú'ún‑yo te ná nákana jaa‑yó máá Rey, I'a̱ ndíto chakú nɨ́ɨ́ káni, ja̱ tú jí'i̱‑ya̱, ja̱ tú kúu nde̱'é ndijín‑yo̱ núu̱‑yá, ja̱ máá ɨ́ɨn‑ni‑ya̱ kúu Dios ndíchí. Amén.  
\v 18 Hijo, súan tá'ú‑rí tiñu nuu̱ róó Timoteo. Chi̱ jíín kɨvɨ́ ní kaka'a̱n‑i ja̱ kúndii̱ máá‑ró. Te jíín tú'un ni̱ kaka'a̱n‑i‑ún, te ná skíkuu va̱'a‑ró jíín tíñu jíku‑ró.  
\v 19 Te kandíja ni̱'in‑ró, te ná káni va̱'a ini̱ añú‑ro̱, chi tu̱'un yá'a ni̱ ka̱ské'ichi̱ sava‑i, te ni̱ ka̱síjíta‑i máá‑i nuu̱ tú'un kándíja.  
\v 20 Te cha̱a yúan, Himeneo jíín Alejandro kákuu‑de, ko ni̱ chi'i‑ri̱‑de nda'a Satanás, náva̱'a ná skuá'a‑de ɨnga̱ jínu ma̱ ká'a̱n ndɨva̱'a‑ga̱‑de. 
\c 2  
\s1 Ndé cuenta kaka̱n ta'u̱‑yo̱ 
\p  
\v 1 Te ví'í‑gá ká'a̱n nda̱'ú‑ri̱ jíín‑ró núsáá, ja̱ ná kakán ta'u̱‑ro̱ já'a̱ táká ña̱yɨvɨ. Ka'a̱n nda̱'ú‑ro̱ jíín‑yá ja̱ kúu máá‑i, te kaka̱n‑ro̱ nú na̱ún jínu ñú'ún‑i, ko nene̱ ná nákuatá'ú‑ró já kúu máá‑i.  
\v 2 Suni ná ká'a̱n‑ro̱ já'a̱ táká rey jíín já'a̱ táká cha̱a kákuñá'nu, náva̱'a ná kúxiu̱kú ná'ín‑yó, te ná kóo paz nuu̱‑yo̱, te chiñú'ún‑yó‑yá, te koo ja̱ jíñú'ún‑yó núu̱ táká‑ni.  
\v 3 Chi ya̱'á kúu ja̱ íó va̱'a te sá'a ja̱ játa'a̱n ini̱ Dios, I'a̱ náma yóó.  
\v 4 Te máá‑yá kuní‑ya̱ já táká ña̱yɨvɨ ná káku‑i, te ná kuní‑i ndasa káa máá tú'un ndaa̱.  
\v 5 Chi̱ íó ɨɨn‑ni Dios, suni súan íó ɨɨn‑ni I'a̱ ká'a̱n ja'a̱ táká ña̱yɨvɨ onde̱ nuu̱ Dios, te I'a̱‑ún, máá cháa Jesucristo kúu‑ya̱.  
\v 6 Te I'a̱‑ún ni̱ soko̱‑yá máá‑yá ja̱ ní nakuaan‑ya̱ táká yóó, te onde̱ máá kɨvɨ́‑ún, ni̱ kenda testigo sɨkɨ̱ I'a̱‑ún.  
\v 7 Te ja̱ sɨkɨ́ yúán ní jani‑ya̱ rúu̱ ja̱ kúu‑ri̱ apóstol náva̱'a kani‑ri̱ tu̱'un. Cha̱a jiní stá'a̱n va̱'a nuu̱ ñáyɨvɨ sɨ́ɨn nación kúu‑ri̱. Te ja̱ndáa̱ ká'a̱n‑ri̱, te a jiní máá Cristo tú xndá'ú‑ri̱.  
\v 8 Te kuní‑ri̱ ja̱ ndéni ni̱ kuu, te ná kakán ta'u̱ táká cha̱a jíná'an‑de. Te ná kóo ndoo nda'a‑dé ndukani‑de. Te ma̱ kití ini̱‑de, te ni ma̱ kána̱á‑de.  
\v 9 Suni súan ta̱ká ñasɨ́'ɨ́, ná kasú va̱'a‑ña máá‑ña jíín sá'ma jíñú'ún, ja̱ tú kuka nuu̱ iní‑yo̱ sá'a. Te nasu̱ sáluu‑ña máá‑ña jíín lazo, xí oro, xí perla, xí sá'ma ncháá ya'u,  
\v 10 chi̱ sua ná sáluu‑ña máá‑ña jíín tíñu jíñú'ún sá'a‑ña, nátu̱'un kánúú sá'a ta̱ká ña'an já káka'a̱n‑ña já káchiñú'ún‑ña máá‑yá.  
\v 11 Te ñasɨ́'ɨ́, náskuá'a‑ña kasú‑ña yú'u‑ñá, te ma̱ ndúkú‑ña tá'ú‑ña tíñu.  
\v 12 Chi̱ tú já'a‑ri̱ tu̱'un ja̱ kánduu̱ ñasɨ́'ɨ́ stá'a̱n‑ña, ni tú tá'ú‑ña tíñu nuu̱ cháa, chi̱ ná'ín‑ni ná kóo‑ña.  
\v 13 Chi̱ Adán ni̱ sáva̱'a‑ya̱ xná'a̱n‑ga̱, te vásá ní sáva̱'a‑ya̱ Eva.  
\v 14 Chi̱ tú ní xndá'ú ja̱'ú Adán, chi̱ sua ñasɨ́'ɨ́‑de ni̱ kandíja‑ña, te ni̱ sáña'mu‑ña.  
\v 15 Ko ka̱ku‑ña sá'a ja̱ júku̱'un se̱'e‑ña, te nú túu sía̱‑ña tú'un kándíja‑ña jíín tú'un kúndá'ú ini̱‑ña, jíín tú'un koo ndoo ini̱‑ña, jíín tú'un ja̱ tú kuka nuu̱‑ñá sá'a. 
\c 3  
\s1 Ndasa koo cha̱a ndíto tɨku'ni̱ 
\p  
\v 1 Tu̱'un ndaa̱ kúu ya̱'á: Nú ɨɨn cha̱a kuní‑de kuu‑de cha̱a kundito tɨku'ni̱, bueno tiñu ndúkú‑de.  
\v 2 Núsáá te nɨ́nɨ ná kóo jíñú'ún cháa kundito‑ún, náva̱'a tú ndenda kua̱chi sɨkɨ̱‑dé. Te ɨɨn máá tú'ún‑ni ñasɨ́'ɨ́‑de ná kóo, te koo ndito ini̱‑de, koo kuándí'í‑de, koo kájí iní‑de, kundá'ú ini̱‑de ña̱yɨvɨ jíká, te koo ñama̱ ini̱‑de stá'a̱n‑de.  
\v 3 Ma̱ kóo ká'vá‑de, ma̱ stují‑dé ña̱yɨvɨ. Ma̱ ndío xaa̱n iní‑de sɨkɨ̱ xú'ún. Chi̱ sua ná kóo paciencia ini̱‑de. Ma̱ kútɨ́xɨ́n‑de. Ma̱ kútóó iní‑de.  
\v 4 Te jíñú'ún ná tá'ú‑de tiñu ini̱ ve̱'e‑de, te ná kúñava̱'a‑de se̱'e ja̱ skíkuu‑i tiñu tá'u̱ núu̱‑í jíín já kóo jíñú'ún‑i.  
\v 5 Chi cha̱a ja̱ tú jiní‑de tá'ú jíñú'ún‑de tiñu ini̱ ve̱'e‑de, ndasa koto‑de tɨku'ni̱ Dios núsáá.  
\v 6 Ko ma̱ kúu kɨ̱vɨ ɨɨn cha̱a jáá. Te nú túu, chi̱ sanaa te sávixi̱‑de máá‑de te ndonda ja̱'ú sɨkɨ̱‑dé.  
\v 7 Suni kánúú já kúu‑de ɨɨn cha̱a ja̱ kuátú'ún ñáyɨvɨ‑dé, va̱sa ká'i̱in‑i sɨ́ɨn ɨnga̱ sɨkɨ̱, náva̱'a ma̱ kuakú nchaa̱‑i‑de, ni ma̱ tɨ́ɨn yátá já'ú‑de. 
\s1 Ndasa koo cha̱a játíñu nuu̱ tɨ́ku'ni̱ 
\p  
\v 8 Suni súan cha̱a kájatíñu nuu̱ tɨ́ku'ni̱ kákandíja, ná kóo jíñú'ún‑de, ma̱ kóo tɨ́lakuá‑de, ma̱ kóo ká'vá‑de, ni ma̱ ndío xaa̱n iní‑de sɨkɨ̱ xú'ún.  
\v 9 Ko ná kóo ndoo ini̱ añú‑de, te ná kundii̱ ni̱'in‑de jíín tú'un sa̱'í kákandíja‑yó.  
\v 10 Te cha̱a yá'a, suni kuní ja̱ kóto nchaa̱‑yo̱‑dé xna'a̱n‑ga̱, náva̱'a kuni̱‑yo̱ nú túu kua̱chi yí'i sɨkɨ̱‑dé. Yúan‑na te kuu kuatíñu‑de.  
\v 11 Suni súan ná kóo va̱'a ini̱ ta̱ká ñasɨ́'ɨ́, ma̱ ndúkú tú'un‑ña tá'an‑ña, te ná kóo kuándí'í‑ña, te ná skíkuu‑ña táká na̱ún tiñu kúu.  
\v 12 Cha̱a kájatíñu nuu̱ tɨ́ku'ni̱, suni ɨɨn‑ni ñasɨ́'ɨ́‑de ná kóo, te ná tá'ú vá'a‑de tiñu nuu̱ sé'e‑de jíín núu̱ táká ini̱ ve̱'e‑de.  
\v 13 Chi cha̱a kájatíñu va̱'a, sua skákunu‑ga̱‑de máá‑de kua'a̱n‑de, te káchundéé‑gá ini̱‑de sá'a‑de sɨkɨ̱ tú'un kákandíja‑yó núu̱ Cristo Jesús.  
\v 14 Tu̱'un yá'a cháa‑ri̱ kujaa̱ nuu̱‑ro̱. Te ñúkuu ini̱ máá‑rí jaa̱ yachi̱‑ri̱ nuu̱‑ro̱.  
\v 15 Ko sanaa te kúkuéé‑ga̱ te jaa̱‑ri̱ nuu̱‑ro̱. Te ja̱ yúán cháa‑ri̱ ya̱'á, náva̱'a kuni̱‑ro̱ ndasa kánúú káka‑ró jíín ñáyɨvɨ káchiñú'ún Dios. Chi yu̱án kúu tɨku'ni̱ Dios, I'a̱ chakú. Te yu̱án kándi̱tuu te kásákútu‑gá máá tú'un ndaa̱.  
\v 16 Ndaa̱ ká'a̱n‑ri̱, ja̱ yíí xáa̱n káa máá tú'un sa̱'í káchiñú'ún‑yó: Ni̱ kenda ndiji̱n Dios jíín yíkɨ kúñu‑ya̱. Te ni̱ kendo̱o ndaa̱‑ya̱ ní sá'a máá Espíritu. Ni̱ kajini̱ ndajá'a̱‑yá nuu̱‑yá. Ni̱ jicha̱ nu̱u tu̱'un‑ya̱ núu̱ ñáyɨvɨ sɨ́ɨn nación. Ña̱yɨvɨ ñúyɨ́vɨ ní ka̱kandíja‑i nuu̱‑yá. Ni̱ ndaa‑ya̱ kuá'a̱n‑ya̱ núu̱ lúu ndíi ncháa̱ ni̱ sá'a Dios. 
\c 4  
\s1 Sɨkɨ̱ tú'un ndu'ichi̱ ini̱ 
\p  
\v 1 Ko máá Espíritu, a kástu̱'ún kájí núu̱‑yo̱, nú ná kúyani ndɨ'ɨ kɨvɨ̱ te ndu'ichi̱ ini̱ sava‑i jíín tú'un kákandíja‑i. Te kuatú'ún‑i máá já ká'a̱n tu̱'un xndá'ú jíín sá'a̱n tachi̱.  
\v 2 Kundiso‑i uu̱ xini̱, te ka'a̱n‑i tu̱'un tú'ún, chi̱ ndukava̱ iní añú‑i.  
\v 3 Ma̱ kuá'a‑i tu̱'un ta̱nda'a‑yo, ni ma̱ kuá'a‑i tu̱'un kee‑yo sáva ndeyu ní sá'a Dios ja̱ kuní máá‑yá ja̱ ná ní'i̱n cháa kákandíja jíín cháa kájini̱ ichi ndáa̱, chi̱ kánakuatá'ú‑de nuu̱‑yá te káyee‑dé.  
\v 4 Chi ta̱ká ja̱ ní sá'a Dios íó va̱'a, te ma̱ kúu ské'ichi̱‑yo̱, te nú ná nákuatá'ú‑yó núu̱‑yá te ná kée‑yo.  
\v 5 Chi̱ jíín tú'un Dios, te jíín tú'un kaka̱n ta'u̱‑yo̱ núu̱‑yá, te a ni̱ ndundoo‑ni ndeyu‑ún. 
\s1 Cha̱a játíñu va̱'a nuu̱ Jesucristo 
\p  
\v 6 Ko nú tu̱'un yá'a kastu̱'ún‑ró núu̱ táká ñani̱‑yo̱, cha̱a játíñu va̱'a nuu̱ Jesucristo kúu‑ró nú súan, chi̱ a ni̱ tɨ̱ɨn tu̱'un kándíja‑ró‑ún ini̱‑ro̱, onde̱ jíín sá'a̱n va̱'a ja̱ bueno skíkuu‑ró.  
\v 7 Ko ta̱ká tu̱'un yúkú, jíín táká tu̱'un aná'án, ná skána‑ró kí'i̱n, te ná skuá'a‑ró máni tu̱'un ja̱ chíñú'ún‑yó máá‑yá.  
\v 8 Tiñu ja̱ skuá'a‑yó ndúndéé yíkɨ kúñu, chi̱ yaku̱‑ni ní'i̱n tíñu. Ko tu̱'un chíñú'ún‑yó máá‑yá, chi ta̱ká‑ni modo ní'i̱n tíñu, chi̱ vida yá'a jíín vida chaa̱, bueno kee sá'a.  
\v 9 Tu̱'un ndaa̱ kúu tu̱'un yá'a, te íó va̱'a ja̱ ná kuátá'ú táká‑i.  
\v 10 Chi̱ sɨkɨ̱ yá'á kúu ja̱ kásátiñu ni̱'in‑yó, te kándo'o‑yó, chi̱ káñukuu ini̱‑yo̱ já kúu máá Dios, I'a̱ chakú, chi̱ máá‑yá kúu I'a̱ náma ta̱ká ña̱yɨvɨ, ko ví'í‑gá náma‑ya̱ ñáyɨvɨ kákandíja nuu̱‑yá.  
\v 11 Tu̱'un yá'a ná stá'a̱n‑ro̱, te tá'ú‑ró tíñu.  
\v 12 Ma̱ kuá'a‑ró tú'un ja̱ kújá'a̱ ini̱ ni ɨɨn‑i koto‑i róó va̱sa súchí‑ró. Te ná kóo va̱'a‑ró, náva̱'a ña̱yɨvɨ kákandíja kuu ndaku‑i róó jíín tú'un ká'a̱n‑ro̱, jíín modo jíka kuu‑ró, jíín tú'un kúndá'ú ini̱‑ro̱‑í, jíín tú'un kándíja‑ró, jíín tú'un ndoo ini̱‑ro̱.  
\v 13 Nini kúkuéé‑ga̱‑ri̱ te jaa̱‑ri̱, te ná kuítú iní‑ro̱ ká'u‑ró tutú nuu̱‑í, ná kána jíín‑ró núu̱‑í, ná stá'a̱n‑ro̱ tú'un nuu̱‑í.  
\v 14 Ma̱ kúkúxí‑ró jíín tá'u̱ ní ni'i̱n‑ro̱, chi cha̱a kákuu nuu̱, ni̱ chaa‑de nda'a‑dé xini̱‑ro̱, te ni̱ kuta'u̱‑ro̱ yúán, nátu̱'un ni̱ kaka'a̱n‑de onde̱ kɨvɨ̱ ní kuu‑ún.  
\v 15 Ná kúndee tu̱'un yá'a xini̱‑ro̱. Te kukuu ni̱'in‑ró jíín, náva̱'a ná kuní ta̱ká‑i ndasa bueno kua̱yija‑ró jíín.  
\v 16 Te koto va̱'a‑ró máá‑ró jíín tú'un stá'a̱n‑ro̱. Ma̱ sía̱‑ro̱. Chi̱ nú súan ná sá'a‑ró, te bueno nama‑ró máá‑ró jíín táká ña̱yɨvɨ chú'un ini̱ tu̱'un ka'a̱n‑ro̱. 
\c 5  
\p  
\v 1 Ma̱ kána jíín‑ró núu̱ cháa ñá'nu, chi̱ sua ka'a̱n nda̱'ú‑ro̱ jíín‑de nátu̱'un jíín táa̱‑ro̱. Te nuu̱ cháa súchí, ka'a̱n‑ro̱ jíín‑de nátu̱'un jíín ñaní‑ro̱,  
\v 2 te nuu̱ ñá'an ñá'nu, nátu̱'un jíín náa̱‑ro̱, te nuu̱ ñá'an súchí, nátu̱'un jíín kuá'a‑ró. Te tu̱'un ndoo ndatu̱'ún‑ró.  
\v 3 Te ná ká'a̱n jíñú'ún‑ró jíín ñá'an kákendo̱o ndá'ú, te nú ni̱ ka̱kendo̱o ndá'ú ndija‑ña.  
\v 4 Ko nú ɨɨn ña'an kéndo̱o ndá'ú íó se̱'e‑ña, xí sé'e tɨ́jání‑ña, ná kútu̱'a su̱chí yá'a xna'a̱n‑ga̱ kundiso jíñú'ún‑i responsable máá‑i ini̱ ve̱'e‑i, te ná nákoto‑i táa̱‑i náa̱‑i, chi̱ súan játa'a̱n ini̱ Dios.  
\v 5 Te nú ña'an já ní kendo̱o ndá'ú ndija kúu‑ña, te máá ɨ́ɨn‑ña, te ñúkuu ini̱‑ña Dios, te nene̱ ká'a̱n nda̱'ú‑ña jíín‑yá te jikán ta'u̱‑ñá ndúú ñúú‑ni nuu̱‑yá.  
\v 6 Ko nú ña'an jíka sɨkɨ̱ tú'un sɨɨ̱ iní kúu‑ña, va̱sa chakú‑ña, ko nátu̱'un a ni̱ ji'i̱‑ña.  
\v 7 Tu̱'un yá'a ná tá'ú‑ró tíñu nuu̱‑í, náva̱'a tú ndenda kua̱chi sɨkɨ̱‑í.  
\v 8 Te nú ɨɨn cha̱a tú ndíto‑de tá'an‑de, te ví'í‑gá nú jíín tá'an máá‑de ini̱ ve̱'e‑de, te a ni̱ ské'ichi̱‑de tu̱'un kándíja‑de nú súan, te cha̱a ñáá‑ga̱ kúu‑de vásá ɨ́ɨn cha̱a tú kándíja.  
\v 9 Ma̱ sá'a‑ró cuenta ja̱ ñá'an ní kendo̱o ndá'ú kúu‑ña, te nú té ji̱nu‑ga̱‑ña uní xiko uxi̱ kuia̱‑ña, jíín já máá ɨ́ɨn‑ni yii‑ñá ni̱ ncha̱ka‑ña,  
\v 10 jíín já kájatú'ún vá'a‑i ja̱ bueno tiñu ni̱ sá'a‑ña, jíín já ní skuá'nu‑ña sé'e, jíín já ní kundá'ú ini̱‑ña ñáyɨvɨ jíká, jíín já ní nakacha‑ña já'a̱ ñáyɨvɨ kákandíja, jíín já ní chindéé‑ña ñáyɨvɨ káta'a̱n tu̱ndó'o, jíín já ní'in ni̱ jika‑ña jíín táká tiñu va̱'a.  
\v 11 Ko ña'an súchí ja̱ kéndo̱o ndá'ú‑ña, ma̱ kuátá'ú‑ró‑ña, chi̱ nú a ni̱ ka̱isɨ́kɨ ncháa̱‑ña sɨkɨ́ Cristo, yúan‑na te kákuni̱‑ña já náta̱nda'a túku‑ña.  
\v 12 Nú súan, te ta'nu̱ ndatu̱‑ña sá'a máá‑ña, chi̱ tú ní skíkuu‑ña tú'un ni̱ keyu'u‑ñá xnáñúú.  
\v 13 Te suni káskuá'a‑ña kée kúxí‑ña, kájika‑ña ndɨ́ta'a̱n ve'e, te nasu̱ máá ɨ́ɨn ja̱ kée kúxí‑ña, chi̱ suni sɨkɨ̱ cuentú‑ni kájika kuu‑ña, te kɨ́vɨ nduu̱‑ña ká'a̱n‑ña tú'un ja̱ tú íó va̱'a.  
\v 14 Núsáá, te ta̱ká ñasɨ́'ɨ́ súchí kákendo̱o ndá'ú, kuní‑ri̱ ja̱ ná náta̱nda'a‑ñá, náskuá'nu‑ña sé'e‑ña, ná kóto va̱'a‑ña vé'e‑ña, te ma̱ kuá'a‑ña lugar ja̱ ká'a̱n ndɨva̱'a ja̱'ú sɨkɨ̱‑yo̱.  
\v 15 Chi̱ sava‑ña a ni̱ ka̱jika yátá‑ña, te ni̱ kandiki̱n‑ña yatá Satanás kája'a̱n‑ña jíín.  
\v 16 Ko nú ɨɨn cha̱a kándíja, xí ɨ́ɨn ña'an kándíja, káñava̱'a tá'an ja̱ kákuu ña'an ní kendo̱o ndá'ú, ná kóto‑de‑ña, te ma̱ cháa‑de carga sɨkɨ̱ tɨ́ku'ni̱ kákandíja, náva̱'a ni'i̱n tɨ́ku'ni̱ na̱jíín kúu ña'an kákendo̱o ndá'ú ndija.  
\v 17 Ná kóo jíñú'ún xáa̱n‑ro̱ núu̱ cháa kákuu nuu̱, te nú kátá'ú vá'a‑de tiñu, ko ví'í‑gá jíñú'ún ná kóo‑ró núu̱‑dé nú kájani ni̱'in‑de tu̱'un jíín já kástá'a̱n‑de.  
\v 18 Chi̱ áchí máá tutú ii̱: Ma̱ chú'un‑ró ñúnu yú'u xndɨkɨ̱ jíkó, áchí. Te: Cha̱a sátiñu kɨvɨ̱, chi̱ íó derecho‑de ja̱ kí'in‑de ya̱'u‑de, áchí.  
\v 19 Ma̱ kuátú'ún‑ró ní ɨɨn kua̱chi sɨkɨ̱ cháa kúu nuu̱, chi̱ onde̱ nú íó uu̱ xí uní testigo.  
\v 20 Te ña̱yɨvɨ kúkuu jíín kuáchi, kana jíín‑ró núu̱‑í, ko ná kuní jíín núu̱ táká‑i, náva̱'a suni ná yú'ú sava‑ga̱‑i.  
\v 21 Ko onde̱ jíín Dios, jíín máá Jíto'o̱‑yo̱ Jesucristo, jíín táká ndajá'a̱‑yá ja̱ ní ka̱ji‑ya̱, ká'a̱n ni̱'in‑ri̱ tu̱'un yá'a jíín‑ró, ja̱ ná skíkuu va̱'a‑ró, te ma̱ kúnchaa̱ nuu̱‑ro̱‑í, ma̱ ɨ́ɨn‑i kaa ɨɨn‑i kuun koto‑ró núu̱‑í.  
\v 22 Ma̱ xndée yachi̱‑ro̱ ndá'a‑ro xiní ní ɨɨn‑i, te ma̱ kɨ́vɨ nduu̱‑ro̱ kuáchi jíín ɨngá ña̱yɨvɨ. Koto va̱'a‑ró máá‑ró náva̱'a ná kéndo̱o ndoo‑ró.  
\v 23 Vina te nɨ́ɨ́‑gá kua'a̱n‑yo̱, ma̱ kó'o‑ga̱‑ro̱ máni máá ndúcha, ná kó'o‑ró ɨ́ɨn tí'li̱ vino sɨkɨ̱ já sá'a kue'e̱ chi̱i‑ró, jíín já núu‑ni núu‑ni kú'u̱‑ro̱.  
\v 24 Ta̱ká kua̱chi kásá'a sava‑i, a ni̱ natu̱u, te jiní‑yo̱ já náku̱xndíi‑ya̱ sɨkɨ́ yúán, ko kua̱chi kásá'a sava‑ga̱‑i, chi̱ kuéé‑ga̱ te natu̱u.  
\v 25 Suni súan kúu ta̱ká tiñu va̱'a, chi̱ a ni̱ natu̱u, te ja̱ ná té tuká‑ún, ma̱ kúu kundee sa̱'í. 
\c 6  
\p  
\v 1 Ta̱ká ña̱yɨvɨ kákuu mozo kásátiñu sáni‑i, ná kóo jíñú'ún vá'a‑i nuu̱ patrón‑i, náva̱'a tú koo ndɨva̱'a tu̱'un sɨkɨ̱ sɨ́'vɨ́ máá Jíto'o̱‑yo̱ jíín sɨkɨ́ sá'a̱n‑ya̱.  
\v 2 Te ña̱yɨvɨ káñava̱'a‑i patrón kákandíja, ma̱ sájá'a̱ ini̱‑i nuu̱‑dé sɨkɨ̱ já ñaní‑i kákuu cha̱a‑ún, chi̱ sua ná kuátíñu va̱'a‑ga̱‑i nuu̱‑dé, chi̱ kákandíja cha̱a‑ún ja̱ kájatíñu‑i nuu̱‑dé, te mani̱‑dé jíín‑i. Súan ká'a̱n ni̱'in tu̱'un yá'a, te suni stá'a̱n. 
\s1 Sɨkɨ̱ tú'un xndá'ú 
\p  
\v 3 Te nú ndé ɨɨn cha̱a stá'a̱n‑de ɨnga̱ tu̱'un, te nú tú játú'ún‑de ja̱ íó ndaa̱ tu̱'un máá Jíto'o̱‑yo̱ Jesucristo, te nú tú játú'ún‑de sa'a̱n ja̱ káchiñú'ún‑yó máá‑yá,  
\v 4 máni sávixi̱‑de máá‑de. Te ni ɨɨn tu̱'un tú júku̱'un ini̱‑de, chi̱ tɨ́xɨ́n jáni ini̱‑de, te kána̱á‑de jíín tú'un ká'a̱n sáni. Te yúan kákuu tu̱'un kuásún iní, tu̱'un tɨ́xɨ́n, tu̱'un ká'a̱n ndɨva̱'a, tu̱'un jáni ñáá ini̱ xini̱,  
\v 5 jíín já kákana̱á cha̱a kánda̱kú'u̱ xini̱, cha̱a tú káñu̱'un tu̱'un ndaa̱ ini̱‑de, te kájani ini̱‑de ja̱ ná chíñú'ún‑de máá‑yá náva̱'a ni'i̱n‑dé xu̱'ún. Ná kúxio‑ró ma̱ kétá'an‑ró jíín cháa kánda̱a súan.  
\v 6 Ko ja̱ á ni̱ ka̱an‑yó jíín‑yá, te káchiñú'ún‑yó máá‑yá, jíín yúán, chi̱ nátu̱'un a kua'a̱ ní kani'i̱n‑yo̱.  
\v 7 Tú na̱ún ní cháa̱ jíín‑yó iní ñu̱yɨ́vɨ yá'a, suni ma̱ kúu kiñi'in‑yó ní ɨɨn ki'i̱n‑yo̱ jíín.  
\v 8 Nú íó ja̱ kée‑yo, íó ja̱ kú'un‑yó, te sɨɨ̱‑ní ná kóo ini̱‑yo̱ jíín.  
\v 9 Te ña̱yɨvɨ já kákuni̱‑i kuu kúká‑i, chi̱ jíto nchaa̱ ja̱'ú‑i, te tɨ́ɨn yátá‑ún‑i. Te yachi̱ kɨ́vɨ‑i jíín tú'un ndío ñáá ini̱‑i te sá'a ndɨva̱'a ndɨtuní‑i, te náa ñáyɨvɨ‑ún, te síjíta‑i máá‑i sá'a tu̱'un‑ún.  
\v 10 Chi̱ nú xu̱'ún kúmani̱‑yo̱ jíín, te sɨkɨ̱ yúán káku ta̱ká tiñu ñáá. Yu̱án ní ka̱ndio ini̱ sava‑i, te ni̱ ka̱sía̱‑i ichi kákandíja‑i. Te ni̱ kɨ̱vɨ tu̱ndó'o xaa̱n iní añú‑i. 
\s1 Tu̱'un ndúkú ndéé kándíja va̱'a 
\p  
\v 11 Ko róó, cha̱a játíñu nuu̱ Dios kúu‑ró, te ná kúnu‑ró kóto‑ró táká tiñu yá'a. Te ná ndúkú‑ró já skíkuu‑ró tíñu ndaa̱, tu̱'un káchiñú'ún‑yó máá‑yá, tu̱'un kándíja, tu̱'un kúndá'ú ini̱ tá'an, tu̱'un paciencia, tu̱'un súchí iní.  
\v 12 Ná ndúkú ndéé‑ró kándíja va̱'a‑ró, te suni ná sá'a‑ró fuerza ni'i̱n tá'u̱‑ro̱ kúchaku̱‑ro̱ nɨ́ɨ́ káni, chi ja̱ yúán kúu ja̱ ní kana‑ya̱ xiní‑ro̱, te ni̱ ka'a̱n ndaa̱‑ro̱ tú'un‑ya̱ ní kajini̱ kua'a̱ ñáyɨvɨ.  
\v 13 Te onde̱ jíín Dios tá'ú‑rí tiñu yá'a nuu̱‑ro̱, chi ja̱ máá‑yá, te chakú ta̱ká ndatíñu, te suni jíín Jesucristo, I'a̱ ni̱ ka'a̱n ndaa̱ ta̱ká tu̱'un nuu̱ Poncio Pilato, ká'a̱n‑ri̱.  
\v 14 Ná skíkuu va̱'a‑ró jíín tíñu tá'u̱ núu̱‑ro̱, náva̱'a ma̱ kúchá'án, ni ma̱ kuakú nchaa̱‑i, onde̱ kɨvɨ̱ ndíi máá Jíto'o̱‑yo̱ Jesucristo.  
\v 15 Chi̱ ɨɨn kɨvɨ̱ te kuni̱ ndiji̱n‑yo̱ kíi‑ya̱, sá'a máá I'a̱ kúsɨɨ̱ iní‑yo̱ jíín. Te I'a̱‑ún, máá ɨ́ɨn‑ya̱ kúñá'nu, te kúu‑ya̱ Rey nuu̱ táká rey, te Jito'o̱ nuu̱ táká jito'o̱.  
\v 16 Te máá ɨ́ɨn‑ya̱ kúu I'a̱ ndíto chakú nɨ́ɨ́ káni. Te ncháá‑ya̱ ɨ́ɨn lugar nuu̱ ndíi ncháa̱, te ma̱ kúu jaa̱ ni ɨɨn‑i yúan. Te ña̱yɨvɨ tú ní jiní ndiji̱n nuu̱‑yá, ni ma̱ kúu kutɨ. Nuu̱ máá‑yá ná kóo tu̱'un jíñú'ún, te ná tá'ú máá‑yá tiñu nɨ́ɨ́ káni. Amén. 
\s1 Sɨkɨ̱ tú'un kúká 
\p  
\v 17 Nuu̱ táká ña̱yɨvɨ kúká ká'i̱o ini̱ ñu̱yɨ́vɨ yá'a, ná tá'ú‑ró tíñu ja̱ má sávixi̱‑i máá‑i. Ni ma̱ kúñukuu ini̱‑i ka̱ku‑i jíín xú'ún, chi̱ yachi̱ náa‑ún. Chi̱ sua ná kúñukuu ini̱‑i ka̱ku‑i sá'a Dios, I'a̱ chakú, chi̱ máá‑yá já'a kua'a̱‑yá ta̱ká‑ni ndatíñu nuu̱‑yo̱ já kúsɨɨ̱ iní‑yo̱ sá'a.  
\v 18 Ná sá'a va̱'a‑i jíná'an‑i. Ná kúu kúká‑i jíín táká tiñu va̱'a sá'a‑i. Yachi̱ ná kóto tá'an‑i, te yachi̱ ná chíndéé tá'an‑i.  
\v 19 Súan te kaya̱‑i ta̱ká tiñu va̱'a sɨkɨ̱ máá‑i ja̱ kúu‑i kuia̱ chaa̱, chi̱ súan te kutɨɨn‑i ichi kúchaku̱ ndija‑i.  
\v 20 Ko róó Timoteo, ma̱ sía̱‑ro̱ táká tu̱'un ni̱ chi'i‑ri̱ nda'a‑ro. Te ma̱ kɨ́vɨ nduu̱‑ro̱ jíín táká tu̱'un yúkú tu̱'un sáni, jíín táká tu̱'un ndíchí ñáá, ja̱ jasú nuu̱ máá tú'un júku̱'un ndaa̱ ini̱.  
\v 21 Chi̱ súan ni̱ ka̱jatú'ún sáva‑i tu̱'un yúkú‑ún. Te ni̱ ka̱xnáa‑í ichi ndíso tu̱'un kákandíja‑yó. Tu̱'un luu íó ini̱ máá‑yá ná kóo jíín‑ró. Súan ná kóo. Amén.