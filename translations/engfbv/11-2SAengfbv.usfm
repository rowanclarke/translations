\v 24 “\w No|strong="H3808"\w*, \w I|strong="H3588"\w* insist \w on|strong="H3068"\w* \w paying|strong="H2600"\w* \w you|strong="H3588"\w* \w for|strong="H3588"\w* \w it|strong="H3588"\w*,” \w the|strong="H3588"\w* \w king|strong="H4428"\w* replied. “\w I|strong="H3588"\w* won't present \w burnt|strong="H5930"\w* \w offerings|strong="H5930"\w* \w to|strong="H3068"\w* \w the|strong="H3588"\w* \w Lord|strong="H3068"\w* \w my|strong="H3068"\w* \w God|strong="H3068"\w* \w that|strong="H3588"\w* didn't \w cost|strong="H4242"\w* \w me|strong="H5927"\w* \w anything|strong="H3808"\w*.” \w David|strong="H1732"\w* \w bought|strong="H7069"\w* \w the|strong="H3588"\w* \w threshing|strong="H1637"\w* \w floor|strong="H1637"\w* \w and|strong="H3068"\w* \w the|strong="H3588"\w* \w oxen|strong="H1241"\w* \w for|strong="H3588"\w* \w fifty|strong="H2572"\w* \w shekels|strong="H8255"\w* \w of|strong="H4428"\w* \w silver|strong="H3701"\w*.
\p 
