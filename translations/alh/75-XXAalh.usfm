\p ▫
\q1 Godji nyingaya-neni nyalanga, juwi-namban Jisas.
\q1 Nurla nyingaya niba amabinu murrjirr niba.
\q1 Neji-gunu jangarl-nyiyi nurla juwi-nambi ngaba.
\q1 Nurla durn-nayiman waynma ala yumarri-ngarni.
\b
\q2 Nurla nyingaya niba amabinu murrjirr niba
