\tc2 Igal anak Yusuf
\tr 
\tc1 Efraim
\tc2 Hosea anak Nun
\tr 
\tc1 Benyamin
\tc2 Palti anak Rafu
\tr 
\tc1 Zebulon
\tc2 Gadiel anak Sodi
\tr 
\tc1 Manasye
\tc2 Gadi anak Susi
