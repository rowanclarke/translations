\v 13 Pero \w a|strong="H3068"\w* \w Caleb|strong="H3612"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jefone, \w le|strong="H1931"\w* \w dio|strong="H5414"\w* \w su|strong="H1931"\w* porción \w entre|strong="H8432"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w Palabra|strong="H6310"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \add dada\add* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w la|strong="H1931"\w* ciudad \w de|strong="H1121"\w* Arba, padre \w de|strong="H1121"\w* Anac, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* \w Hebrón|strong="H2275"\w*.  
\v 14 \w Caleb|strong="H3612"\w* \w echó|strong="H3423"\w* \w de|strong="H1121"\w* \w allí|strong="H8033"\w* \w a|strong="H3068"\w* \w tres|strong="H7969"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Anac: \w a|strong="H3068"\w* Sesai, Aimán y Talmai, descendientes \w de|strong="H1121"\w* Anac.   
