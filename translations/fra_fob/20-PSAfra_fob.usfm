\v 8 \w Il|strong="H3068"\w* jugera \w le|strong="H3068"\w* \w monde|strong="H3068"\w* \w avec|strong="H3427"\w* \w justice|strong="H4941"\w*; \w il|strong="H3068"\w* jugera \w les|strong="H3068"\w* peuples \w avec|strong="H3427"\w* \w équité|strong="H4941"\w*.
\v 9 \w L|strong="H3068"\w*'Éternel \w sera|strong="H1931"\w* \w le|strong="H8199"\w* refuge de l'opprimé, \w son|strong="H1777"\w* refuge \w au|strong="H8199"\w* temps de \w la|strong="H1931"\w* détresse.
\v 10 \w Et|strong="H3068"\w* \w ceux|strong="H3068"\w* \w qui|strong="H3068"\w* connaissent \w ton|strong="H3068"\w* \w nom|strong="H3068"\w*, \w se|strong="H3068"\w* confieront \w en|strong="H3068"\w* \w toi|strong="H3068"\w*; car \w tu|strong="H3068"\w* n'abandonnes \w pas|strong="H1961"\w* \w ceux|strong="H3068"\w* \w qui|strong="H3068"\w* \w te|strong="H3068"\w* cherchent, ô \w Éternel|strong="H3068"\w*!
\v 11 Chantez \w à|strong="H3068"\w* l'\w Éternel|strong="H3068"\w* \w qui|strong="H3068"\w* habite \w en|strong="H3068"\w* Sion; annoncez \w parmi|strong="H8034"\w* \w les|strong="H3068"\w* peuples \w ses|strong="H3045"\w* \w hauts|strong="H3068"\w* \w faits|strong="H3068"\w*!
