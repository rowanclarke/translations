\v 17 \w Amih|strong="H9908"\w* \w ham|strong="H9997"\w* \w buhkoknah|strong="H4960"\w* a \w om|strong="H1961"\w* duela \w hnin|strong="H3117"\w* \w rhih|strong="H7651"\w* khuiah \w samson|strong="H9909"\w* te a \w rhah|strong="H1058"\w* \w thil|strong="H5921"\w*. \w Tedae|strong="H9999"\w* a \w hnin|strong="H3117"\w* \w rhih|strong="H7636"\w* \w dongla|strong="H9996"\w* a \w pha|strong="H1961"\w* \w vaengah|strong="H9999"\w* tah \w Samson|strong="H9909"\w* te moelh a \w kilh|strong="H6693"\w* \w dongah|strong="H3588"\w* a \w yuu|strong="H9907"\w* ham \w te|strong="H9997"\w* a \w thui|strong="H5046"\w* pah \w tih|strong="H9999"\w* a yuu loh \w a|strong="H9907"\w* \w pilnam|strong="H5971"\w* khuikah a \w hlang|strong="H1121"\w* rhoek \w taengah|strong="H9997"\w* \w olkael|strong="H2420"\w* \w te|strong="H9998"\w* a \w thui|strong="H5046"\w* pah.  
