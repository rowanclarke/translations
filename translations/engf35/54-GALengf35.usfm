\v 11 \w But|strong="G1161"\w* \w I|strong="G1473"\w*, brothers, \w if|strong="G1487"\w* \w I|strong="G1473"\w* \w still|strong="G2089"\w* \w preach|strong="G2784"\w* \w circumcision|strong="G4061"\w*, \w why|strong="G5101"\w* \w am|strong="G1473"\w* \w I|strong="G1473"\w* \w still|strong="G2089"\w* \w being|strong="G1161"\w* \w persecuted|strong="G1377"\w*? \w In|strong="G1161"\w* \w that|strong="G3588"\w* event \w the|strong="G1161"\w* \w offense|strong="G4625"\w* \w of|strong="G3588"\w* \w the|strong="G1161"\w* \w cross|strong="G4716"\w* \w would|strong="G5101"\w* \w have|strong="G1473"\w* been \w removed|strong="G2673"\w*.
