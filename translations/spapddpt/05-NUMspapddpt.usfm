\v 21 \wj \+w Esta|strong="H2063"\+w* \+w es|strong="H3027"\+w* \+w la|strong="H5921"\+w* \+w ley|strong="H8451"\+w* \+w del|strong="H5921"\+w* \+w nazareo|strong="H5139"\+w* \+w que|strong="H5921"\+w* \+w hace|strong="H6213"\+w* un \+w voto|strong="H5087"\+w*. Su \+w ofrenda|strong="H7133"\+w* \+w para|strong="H5921"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w según|strong="H5921"\+w* su \+w consagración|strong="H5145"\+w*, \+w además|strong="H5921"\+w* \+w de|strong="H5921"\+w* aquello \+w que|strong="H5921"\+w* pueda ofrecer, \+w según|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w voto|strong="H5087"\+w* \+w que|strong="H5921"\+w* \+w hizo|strong="H6213"\+w*, \+w así|strong="H3651"\+w* \+w hará|strong="H6213"\+w* \+w conforme|strong="H6310"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H5921"\+w* \+w ley|strong="H8451"\+w* \+w de|strong="H5921"\+w* su \+w consagración|strong="H5145"\+w*.\wj*   
\s1 La bendición sacerdotal  
\p
\v 22 \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 23 \wj \+w Habla|strong="H1696"\+w* \+w a|strong="H3068"\+w* Aarón \+w y|strong="H3541"\+w* \+w a|strong="H3068"\+w* sus \+w hijos|strong="H1121"\+w*: \+w Así|strong="H3541"\+w* bendecirán \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*. Díganles: \wj*   
\q1
\v 24 \wj \+nd \+w Yavé|strong="H3068"\+w*\+nd* te \+w bendiga|strong="H1288"\+w* y te \+w guarde|strong="H8104"\+w*.\wj*   
\q1
\v 25 \wj \+nd \+w Yavé|strong="H3068"\+w*\+nd* haga resplandecer su \+w rostro|strong="H6440"\+w* sobre ti,\wj*  
\q1 \wj \+w Y|strong="H3068"\+w* tenga \+w de|strong="H6440"\+w* ti \+w misericordia|strong="H2603"\+w*.\wj*   
\q1
\v 26 \wj \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w alce|strong="H5375"\+w* sobre ti su \+w rostro|strong="H6440"\+w*,\wj*  
\q1 \wj \+w Y|strong="H3068"\+w* te \+w dé|strong="H6440"\+w* \+w paz|strong="H7965"\+w*.\wj*   
\p
\v 27 \wj Así \+w pondrán|strong="H7760"\+w* \+w mi|strong="H5921"\+w* \+w Nombre|strong="H8034"\+w* \+w sobre|strong="H5921"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w*, \+w y|strong="H5921"\+w* Yo \+w los|strong="H1121"\+w* \+w bendeciré|strong="H1288"\+w*.\wj*   
\c 7  
\s1 Consagraciones, ofrendas y sacrificios  
\p
\v 1 \w Aconteció|strong="H1961"\w* \w que|strong="H3117"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w Moisés|strong="H4872"\w* terminó de \w levantar|strong="H6965"\w* \w el|strong="H3605"\w* \w Tabernáculo|strong="H4908"\w*, de ungirlo y consagrarlo con \w todos|strong="H3605"\w* sus utensilios, y de ungir y consagrar \w el|strong="H3605"\w* \w altar|strong="H4196"\w* con \w todos|strong="H3605"\w* sus utensilios,  
\v 2 \w los|strong="H1992"\w* \w jefes|strong="H7218"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w cabezas|strong="H7218"\w* \w de|strong="H5921"\w* \w sus|strong="H1992"\w* \w casas|strong="H1004"\w* paternas, quienes eran \w los|strong="H1992"\w* líderes \w de|strong="H5921"\w* \w sus|strong="H1992"\w* \w tribus|strong="H4294"\w* \w que|strong="H5921"\w* dirigieron \w el|strong="H5921"\w* censo, presentaron \w sus|strong="H1992"\w* ofrendas.  
\v 3 Llevaron sus \w ofrendas|strong="H7133"\w* \w ante|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*: \w seis|strong="H8337"\w* carretas cubiertas \w y|strong="H5921"\w* 12 \w bueyes|strong="H1241"\w*: una carreta \w por|strong="H5921"\w* cada \w dos|strong="H8147"\w* jefes \w y|strong="H5921"\w* un \w buey|strong="H7794"\w* \w por|strong="H5921"\w* cada uno, \w y|strong="H5921"\w* \w los|strong="H5921"\w* presentaron \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w Tabernáculo|strong="H4908"\w*.   
\p
\v 4 \nd \+w Yavé|strong="H3068"\+w*\nd* habló \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 5 \wj Tómalos \+w de|strong="H5414"\+w* ellos, y \+w serán|strong="H1961"\+w* \+w para|strong="H5414"\+w* la obra del Tabernáculo \+w de|strong="H5414"\+w* Reunión. \+w Los|strong="H1961"\+w* \+w darás|strong="H5414"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H1961"\+w* \+w levitas|strong="H3881"\+w*, \+w a|strong="H3068"\+w* cada uno \+w conforme|strong="H6310"\+w* \+w a|strong="H3068"\+w* su servicio.\wj*   
\p
\v 6 Entonces \w Moisés|strong="H4872"\w* \w tomó|strong="H3947"\w* las carretas, los \w bueyes|strong="H1241"\w* \w y|strong="H1241"\w* los \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* los \w levitas|strong="H3881"\w*.  
\v 7 \w A|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gersón|strong="H1648"\w* \w dio|strong="H5414"\w* \w dos|strong="H8147"\w* carretas \w y|strong="H1241"\w* cuatro \w bueyes|strong="H1241"\w*, \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* su servicio.   
\p
\v 8 \w A|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Merari|strong="H4847"\w* \w dio|strong="H5414"\w* cuatro carretas \w y|strong="H1241"\w* \w ocho|strong="H8083"\w* \w bueyes|strong="H1241"\w*, \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* su servicio bajo la dirección \w de|strong="H1121"\w* Itamar, \w hijo|strong="H1121"\w* del \w sacerdote|strong="H3548"\w* Aarón.  
\v 9 \w Pero|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Coat \w nada|strong="H3808"\w* \w les|strong="H5921"\w* \w dio|strong="H5414"\w*, \w porque|strong="H3588"\w* \w ellos|strong="H5921"\w* \add solo\add* tenían \w el|strong="H5921"\w* servicio \w de|strong="H5921"\w* transportar \w las|strong="H5921"\w* cosas \w sagradas|strong="H6944"\w* \w sobre|strong="H5921"\w* sus \w hombros|strong="H3802"\w*.   
\p
\v 10 Los jefes también presentaron sus \w ofrendas|strong="H7133"\w* para la dedicación \w del|strong="H4196"\w* \w altar|strong="H4196"\w* el \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* éste fue \w ungido|strong="H4886"\w*. Ellos mismos presentaron sus \w ofrendas|strong="H7133"\w* \w delante|strong="H6440"\w* \w del|strong="H4196"\w* \w altar|strong="H4196"\w*,  
\v 11 pues \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj Presenten ellos mismos sus \+w ofrendas|strong="H7133"\+w*, un \+w jefe|strong="H5387"\+w* \+w cada|strong="H3117"\+w* \+w día|strong="H3117"\+w*, para la dedicación \+w del|strong="H4196"\+w* \+w altar|strong="H4196"\+w*.\wj*   
\p
