\v 1 \w La|strong="H3068"\w* \w parole|strong="H1697"\w* \w du|strong="H1121"\w* \w SEIGNEUR|strong="H3068"\w*\f + \fr 1.1 \ft Lorsqu'il est écrit en MAJUSCULES, « SEIGNEUR » ou « DIEU » est la traduction du nom propre de Dieu (en hébreu « \wh יהוה\wh* », généralement prononcé Yahvé).\f* \w fut|strong="H3068"\w* \w adressée|strong="H1697"\w* \w à|strong="H3068"\w* \w Jonas|strong="H3124"\w*, \w fils|strong="H1121"\w* d'Amittaï :
\v 2 « \w Lève-toi|strong="H6965"\w*, \w va|strong="H3068"\w* \w à|strong="H3212"\w* \w Ninive|strong="H5210"\w*, \w la|strong="H6440"\w* \w grande|strong="H1419"\w* \w ville|strong="H5892"\w*, \w et|strong="H1419"\w* prêche \w contre|strong="H6440"\w* \w elle|strong="H3588"\w*, \w car|strong="H3588"\w* \w sa|strong="H6440"\w* méchanceté \w est|strong="H7451"\w* \w montée|strong="H5927"\w* jusqu'\w à|strong="H3212"\w* \w moi|strong="H6440"\w*. »
\p 
\v 3 Mais \w Jonas|strong="H3124"\w* \w se|strong="H3068"\w* \w leva|strong="H6965"\w* \w pour|strong="H5414"\w* s'\w enfuir|strong="H1272"\w* \w à|strong="H3068"\w* \w Tarsis|strong="H8659"\w*, \w loin|strong="H6440"\w* \w de|strong="H6440"\w* \w la|strong="H5414"\w* \w présence|strong="H6440"\w* \w du|strong="H6440"\w* \w SEIGNEUR|strong="H6440"\w*. \w Il|strong="H3068"\w* \w descendit|strong="H3381"\w* \w à|strong="H3068"\w* Joppé \w et|strong="H3068"\w* \w trouva|strong="H4672"\w* \w un|strong="H3068"\w* \w navire|strong="H5414"\w* \w en|strong="H5414"\w* partance \w pour|strong="H5414"\w* \w Tarsis|strong="H8659"\w* ; \w il|strong="H3068"\w* \w paya|strong="H5414"\w* \w le|strong="H6440"\w* \w prix|strong="H6440"\w* \w du|strong="H6440"\w* transport \w et|strong="H3068"\w* s'\w y|strong="H3068"\w* \w embarqua|strong="H3381"\w* \w pour|strong="H5414"\w* \w aller|strong="H6440"\w* \w avec|strong="H5973"\w* \w eux|strong="H6440"\w* \w à|strong="H3068"\w* \w Tarsis|strong="H8659"\w*, \w loin|strong="H6440"\w* \w de|strong="H6440"\w* \w la|strong="H5414"\w* \w présence|strong="H6440"\w* \w du|strong="H6440"\w* \w SEIGNEUR|strong="H6440"\w*.
\p 
\v 4 Mais \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* déchaîna \w un|strong="H3068"\w* \w vent|strong="H7307"\w* violent \w sur|strong="H3068"\w* \w la|strong="H3068"\w* \w mer|strong="H3220"\w*, \w et|strong="H3068"\w* \w il|strong="H3068"\w* s'éleva \w une|strong="H3068"\w* si \w grande|strong="H1419"\w* \w tempête|strong="H5591"\w* \w que|strong="H2803"\w* \w le|strong="H3068"\w* \w navire|strong="H3068"\w* \w menaçait|strong="H2803"\w* \w de|strong="H7307"\w* \w se|strong="H3068"\w* \w briser|strong="H7665"\w*.
\v 5 \w Les|strong="H3220"\w* marins \w eurent|strong="H4419"\w* \w peur|strong="H3372"\w* \w et|strong="H5921"\w* \w chacun|strong="H2199"\w* \w cria|strong="H2199"\w* \w vers|strong="H3220"\w* \w son|strong="H3381"\w* \w dieu|strong="H5921"\w*. \w Ils|strong="H5921"\w* \w jetèrent|strong="H2904"\w* \w à|strong="H3381"\w* \w la|strong="H5921"\w* \w mer|strong="H3220"\w* \w la|strong="H5921"\w* cargaison \w qui|strong="H3627"\w* \w se|strong="H3220"\w* trouvait \w dans|strong="H5921"\w* \w le|strong="H3220"\w* \w navire|strong="H5600"\w* afin \w de|strong="H3627"\w* l'alléger. Or, \w Jonas|strong="H3124"\w* \w était|strong="H3220"\w* \w descendu|strong="H3381"\w* \w au|strong="H3381"\w* \w fond|strong="H3411"\w* \w du|strong="H5921"\w* \w navire|strong="H5600"\w*, s'\w était|strong="H3220"\w* \w couché|strong="H7901"\w* \w et|strong="H5921"\w* \w dormait|strong="H7901"\w* \w profondément|strong="H7290"\w*.
\v 6 \w Le|strong="H7121"\w* capitaine \w du|strong="H7121"\w* navire s'\w approcha|strong="H7126"\w* \w de|strong="H7227"\w* \w lui|strong="H3808"\w* \w et|strong="H6965"\w* \w lui|strong="H3808"\w* \w dit|strong="H3808"\w* : « \w Que|strong="H3808"\w* fais-tu, dormeur ? \w Lève-toi|strong="H6965"\w*, \w invoque|strong="H7121"\w* \w ton|strong="H7121"\w* \w Dieu|strong="H3808"\w* !\f + \fr 1.6 \ft ou, tes dieux\f* Peut-être \w que|strong="H3808"\w* \w ton|strong="H7121"\w* \w Dieu|strong="H3808"\w*\f + \fr 1.6 \ft ou, tes dieux \f* pensera \w à|strong="H7121"\w* \w nous|strong="H3808"\w*, \w et|strong="H6965"\w* \w nous|strong="H3808"\w* \w ne|strong="H3808"\w* \w périrons|strong="H3808"\w* \w pas|strong="H3808"\w*. »
\p 
\v 7 \w Ils|strong="H3212"\w* \w se|strong="H3212"\w* \w dirent|strong="H3212"\w* \w les|strong="H3045"\w* \w uns|strong="H3212"\w* \w aux|strong="H7451"\w* \w autres|strong="H7453"\w* : « \w Venez|strong="H3212"\w* ! \w Tirons|strong="H5307"\w* \w au|strong="H5307"\w* \w sort|strong="H1486"\w* \w pour|strong="H3212"\w* \w savoir|strong="H3045"\w* \w qui|strong="H4310"\w* \w attire|strong="H3212"\w* \w sur|strong="H5921"\w* \w nous|strong="H3212"\w* \w ce|strong="H3045"\w* \w malheur|strong="H7451"\w*. » \w Ils|strong="H3212"\w* \w tirèrent|strong="H5307"\w* \w au|strong="H5307"\w* \w sort|strong="H1486"\w*, \w et|strong="H3212"\w* \w le|strong="H3045"\w* \w sort|strong="H1486"\w* \w tomba|strong="H5307"\w* \w sur|strong="H5921"\w* \w Jonas|strong="H3124"\w*.
\v 8 \w Alors|strong="H2063"\w* \w ils|strong="H5971"\w* \w lui|strong="H5971"\w* demandèrent : « Dis-nous, s'\w il|strong="H5971"\w* \w te|strong="H5971"\w* plaît, \w qui|strong="H5971"\w* \w nous|strong="H5971"\w* attire \w ce|strong="H2088"\w* \w malheur|strong="H7451"\w* ? \w Quel|strong="H4100"\w* \w est|strong="H5971"\w* \w ton|strong="H5046"\w* métier ? \w D|strong="H3068"\w*'où viens-tu ? \w Quel|strong="H4100"\w* \w est|strong="H5971"\w* \w ton|strong="H5046"\w* \w pays|strong="H5971"\w*, \w et|strong="H5971"\w* \w de|strong="H5971"\w* \w quel|strong="H4100"\w* \w peuple|strong="H5971"\w* \w es-tu|strong="H4100"\w* ? »
\p 
\v 9 \w Il|strong="H3068"\w* \w leur|strong="H3068"\w* répondit : « \w Je|strong="H3068"\w* \w suis|strong="H3068"\w* \w Hébreu|strong="H5680"\w*, \w et|strong="H3068"\w* \w je|strong="H3068"\w* \w crains|strong="H3373"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w*, \w le|strong="H3068"\w* \w Dieu|strong="H3068"\w*\f + \fr 1.9 \ft Le mot hébreu traduit par « Dieu » est « \wh אֱלֹהִ֑ים\wh* » (Élohim).\f* \w du|strong="H6213"\w* \w ciel|strong="H8064"\w*, \w qui|strong="H3068"\w* \w a|strong="H3068"\w* \w fait|strong="H6213"\w* \w la|strong="H6213"\w* \w mer|strong="H3220"\w* \w et|strong="H3068"\w* \w la|strong="H6213"\w* \w terre|strong="H3068"\w* ferme. »
\p 
\v 10 \w Ces|strong="H6213"\w* \w hommes|strong="H3068"\w* \w furent|strong="H3068"\w* \w saisis|strong="H3372"\w* \w d|strong="H1992"\w*'\w une|strong="H6213"\w* \w grande|strong="H1419"\w* \w crainte|strong="H3372"\w* \w et|strong="H3068"\w* \w lui|strong="H3068"\w* \w dirent|strong="H5046"\w* : « \w Qu|strong="H3588"\w*'\w as-tu|strong="H4100"\w* \w fait|strong="H6213"\w* ? » \w Car|strong="H3588"\w* \w ils|strong="H1992"\w* \w savaient|strong="H3045"\w* \w qu|strong="H3588"\w*'\w il|strong="H3068"\w* s'\w enfuyait|strong="H1272"\w* \w loin|strong="H6440"\w* \w de|strong="H6440"\w* \w la|strong="H6213"\w* \w présence|strong="H6440"\w* \w du|strong="H6440"\w* \w SEIGNEUR|strong="H6440"\w*, parce \w qu|strong="H3588"\w*'\w il|strong="H3068"\w* \w le|strong="H6440"\w* \w leur|strong="H3068"\w* \w avait|strong="H3068"\w* \w déclaré|strong="H5046"\w*.
\v 11 \w Ils|strong="H3588"\w* \w lui|strong="H6213"\w* dirent : « \w Que|strong="H3588"\w* \w te|strong="H4100"\w* \w ferons-nous|strong="H3588"\w* \w pour|strong="H6213"\w* \w que|strong="H3588"\w* \w la|strong="H6213"\w* \w mer|strong="H3220"\w* s'\w apaise|strong="H8367"\w* \w envers|strong="H6213"\w* \w nous|strong="H6213"\w* ? » \w Car|strong="H3588"\w* \w la|strong="H6213"\w* \w mer|strong="H3220"\w* \w devenait|strong="H1980"\w* \w de|strong="H6213"\w* \w plus|strong="H5921"\w* \w en|strong="H6213"\w* \w plus|strong="H5921"\w* houleuse.
\p 
\v 12 \w Il|strong="H2088"\w* \w leur|strong="H5375"\w* répondit : « Prenez-moi \w et|strong="H1419"\w* \w jetez-moi|strong="H1419"\w* \w à|strong="H3588"\w* \w la|strong="H5921"\w* \w mer|strong="H3220"\w*, \w et|strong="H1419"\w* \w la|strong="H5921"\w* \w mer|strong="H3220"\w* s'apaisera envers \w vous|strong="H3588"\w* ; \w car|strong="H3588"\w* \w je|strong="H3588"\w* \w sais|strong="H3045"\w* \w que|strong="H3588"\w* c'\w est|strong="H3220"\w* \w à|strong="H3588"\w* \w cause|strong="H5921"\w* \w de|strong="H5921"\w* \w moi|strong="H5921"\w* \w que|strong="H3588"\w* \w cette|strong="H2088"\w* \w grande|strong="H1419"\w* \w tempête|strong="H5591"\w* s'\w est|strong="H3220"\w* abattue \w sur|strong="H5921"\w* \w vous|strong="H3588"\w*. »
\p 
\v 13 Néanmoins, \w les|strong="H7725"\w* \w hommes|strong="H7725"\w* ramèrent \w avec|strong="H1980"\w* force \w pour|strong="H5921"\w* regagner \w la|strong="H5921"\w* \w terre|strong="H3004"\w* ferme, \w mais|strong="H3588"\w* \w ils|strong="H7725"\w* \w ne|strong="H3808"\w* \w le|strong="H7725"\w* \w purent|strong="H3201"\w* \w pas|strong="H3808"\w*, \w car|strong="H3588"\w* \w la|strong="H5921"\w* \w mer|strong="H3220"\w* \w se|strong="H3588"\w* déchaînait \w de|strong="H7725"\w* \w plus|strong="H3808"\w* \w en|strong="H7725"\w* \w plus|strong="H3808"\w* \w contre|strong="H5921"\w* \w eux|strong="H5921"\w*.
\v 14 \w Alors|strong="H6213"\w* \w ils|strong="H5315"\w* \w crièrent|strong="H7121"\w* \w au|strong="H5414"\w* \w SEIGNEUR|strong="H5414"\w* \w et|strong="H3068"\w* \w dirent|strong="H3068"\w* : « \w Nous|strong="H3068"\w* t'\w en|strong="H5414"\w* prions, \w SEIGNEUR|strong="H5414"\w*, \w nous|strong="H3068"\w* t'\w en|strong="H5414"\w* prions, \w ne|strong="H3068"\w* \w nous|strong="H3068"\w* \w fais|strong="H6213"\w* \w pas|strong="H6213"\w* \w périr|strong="H6213"\w* \w à|strong="H3068"\w* \w cause|strong="H5921"\w* \w de|strong="H6213"\w* \w la|strong="H6213"\w* \w vie|strong="H5315"\w* \w de|strong="H6213"\w* \w cet|strong="H2088"\w* \w homme|strong="H5315"\w*, \w et|strong="H3068"\w* \w ne|strong="H3068"\w* \w nous|strong="H3068"\w* \w charge|strong="H5414"\w* \w pas|strong="H6213"\w* \w du|strong="H5414"\w* \w sang|strong="H1818"\w* \w innocent|strong="H5355"\w* ! \w Car|strong="H3588"\w* \w toi|strong="H3068"\w*, \w SEIGNEUR|strong="H5414"\w*, \w tu|strong="H3588"\w* \w as|strong="H3588"\w* \w agi|strong="H6213"\w* \w comme|strong="H3068"\w* \w il|strong="H3068"\w* t'\w a|strong="H3068"\w* \w plu|strong="H2654"\w*. »
\v 15 Puis \w ils|strong="H5375"\w* \w prirent|strong="H5375"\w* \w Jonas|strong="H3124"\w* \w et|strong="H5975"\w* \w le|strong="H5375"\w* \w jetèrent|strong="H2904"\w* \w à|strong="H5975"\w* \w la|strong="H5375"\w* \w mer|strong="H3220"\w* ; \w et|strong="H5975"\w* \w la|strong="H5375"\w* \w fureur|strong="H2197"\w* \w de|strong="H5375"\w* \w la|strong="H5375"\w* \w mer|strong="H3220"\w* s'\w apaisa|strong="H5975"\w*.
\v 16 \w Alors|strong="H3068"\w* \w ces|strong="H3068"\w* \w hommes|strong="H3068"\w* \w furent|strong="H3068"\w* \w saisis|strong="H3372"\w* d'\w une|strong="H3068"\w* \w très|strong="H3068"\w* \w grande|strong="H1419"\w* \w crainte|strong="H3372"\w* \w du|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* ; \w ils|strong="H3068"\w* \w offrirent|strong="H2076"\w* \w un|strong="H3068"\w* \w sacrifice|strong="H2077"\w* \w au|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* \w et|strong="H3068"\w* \w firent|strong="H3068"\w* \w des|strong="H3068"\w* \w vœux|strong="H5088"\w*.
\p 
\v 17 Le SEIGNEUR fit venir un grand poisson pour engloutir Jonas, et Jonas resta dans le ventre du poisson trois jours et trois nuits.
\c 2
\p 
\v 1 \w Alors|strong="H3117"\w* \w Jonas|strong="H3124"\w* pria \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w*, \w son|strong="H3117"\w* \w Dieu|strong="H3068"\w*, \w depuis|strong="H3117"\w* \w le|strong="H3068"\w* \w ventre|strong="H4578"\w* \w du|strong="H3117"\w* \w poisson|strong="H1709"\w*.
\v 2 \w Il|strong="H3068"\w* \w dit|strong="H3068"\w* :
\q1 « \w Dans|strong="H3068"\w* \w ma|strong="H3068"\w* détresse, \w j|strong="H3068"\w*'\w ai|strong="H3068"\w* \w fait|strong="H3068"\w* appel \w au|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w*,
\q2 \w et|strong="H3068"\w* \w il|strong="H3068"\w* m'\w a|strong="H3068"\w* répondu.
\q1 \w Du|strong="H3068"\w* \w ventre|strong="H4578"\w* \w du|strong="H3068"\w* Shéol\f + \fr 2.2 \ft Le Shéol est le lieu des morts.\f*, \w j|strong="H3068"\w*'\w ai|strong="H3068"\w* crié.
\q2 \w Tu|strong="H3068"\w* \w as|strong="H3068"\w* entendu \w ma|strong="H3068"\w* voix.
\q1 
\v 3 Car \w tu|strong="H3068"\w* m'\w as|strong="H3068"\w* \w jeté|strong="H3068"\w* \w dans|strong="H6963"\w* \w les|strong="H3068"\w* profondeurs,
\q2 \w au|strong="H3068"\w* \w cœur|strong="H3068"\w* \w des|strong="H3068"\w* mers.
\q1 \w Les|strong="H3068"\w* \w flots|strong="H3068"\w* m'\w ont|strong="H3068"\w* encerclé.
\q2 \w Toutes|strong="H3068"\w* \w tes|strong="H3068"\w* vagues \w et|strong="H3068"\w* \w tes|strong="H3068"\w* déferlantes \w ont|strong="H3068"\w* passé \w sur|strong="H3068"\w* \w moi|strong="H6030"\w*.
\q1 
\v 4 \w Je|strong="H3068"\w* disais : “\w J|strong="H3068"\w*'\w ai|strong="H3605"\w* \w été|strong="H7993"\w* chassé \w loin|strong="H5674"\w* \w de|strong="H5921"\w* \w ton|strong="H5921"\w* regard ;
\q2 pourtant, \w je|strong="H5437"\w* contemplerai \w encore|strong="H5921"\w* \w ton|strong="H5921"\w* saint temple.”
\q1 
\v 5 \w Les|strong="H5869"\w* eaux m'\w ont|strong="H5869"\w* environné,
\q2 jusqu'\w à|strong="H5869"\w* l'âme.
\q1 \w L|strong="H3068"\w*'abîme m'\w a|strong="H3068"\w* enveloppé.
\q2 \w Les|strong="H5869"\w* algues s'enroulaient autour \w de|strong="H5869"\w* \w ma|strong="H5048"\w* tête.
\q1 
\v 6 \w Je|strong="H3068"\w* \w suis|strong="H5315"\w* descendu \w aux|strong="H5315"\w* fondements \w des|strong="H7218"\w* montagnes.
\q2 \w La|strong="H5704"\w* \w terre|strong="H5704"\w* \w a|strong="H3068"\w* fermé \w ses|strong="H5315"\w* verrous \w sur|strong="H5315"\w* \w moi|strong="H5315"\w* \w pour|strong="H5704"\w* \w toujours|strong="H5704"\w* ;
\q2 mais \w tu|strong="H5704"\w* as \w fait|strong="H5315"\w* remonter \w ma|strong="H5315"\w* \w vie|strong="H5315"\w* \w de|strong="H7218"\w* \w la|strong="H5704"\w* fosse, \w SEIGNEUR|strong="H5315"\w* \w mon|strong="H5704"\w* \w Dieu|strong="H5315"\w*.
\b
\q1 
\v 7 \w Quand|strong="H3068"\w* \w mon|strong="H3068"\w* âme défaillait \w en|strong="H3068"\w* \w moi|strong="H3068"\w*, \w je|strong="H2022"\w* \w me|strong="H3068"\w* \w suis|strong="H3068"\w* souvenu \w du|strong="H5927"\w* \w SEIGNEUR|strong="H3068"\w*.
\q2 \w Ma|strong="H5769"\w* prière \w est|strong="H3068"\w* parvenue jusqu'\w à|strong="H3068"\w* \w toi|strong="H3068"\w*, \w dans|strong="H3068"\w* \w ton|strong="H3068"\w* saint temple.
\q1 
\v 8 \w Ceux|strong="H5315"\w* \w qui|strong="H3068"\w* s'attachent \w à|strong="H3068"\w* \w de|strong="H5921"\w* vaines idoles abandonnent \w la|strong="H3068"\w* \w miséricorde|strong="H3068"\w* \w qui|strong="H3068"\w* \w leur|strong="H3068"\w* \w est|strong="H3068"\w* offerte.
\q2 
\v 9 Mais moi, \w je|strong="H8104"\w* t'offrirai \w des|strong="H8104"\w* sacrifices \w avec|strong="H8104"\w* \w des|strong="H8104"\w* chants d'action \w de|strong="H8104"\w* \w grâces|strong="H2617"\w*.
\q2 \w J|strong="H3068"\w*'accomplirai \w ce|strong="H8104"\w* \w que|strong="H8104"\w* j'ai promis.
\q1 \w Le|strong="H8104"\w* salut appartient \w au|strong="H8104"\w* SEIGNEUR. »
\p 
\v 10 \w Alors|strong="H3068"\w* \w le|strong="H3068"\w* \w SEIGNEUR|strong="H3068"\w* parla \w au|strong="H3068"\w* poisson, \w et|strong="H3068"\w* \w il|strong="H3068"\w* vomit Jonas \w sur|strong="H3068"\w* \w la|strong="H3068"\w* \w terre|strong="H3068"\w* ferme.
\c 3
\p 
\v 1 \w La|strong="H3068"\w* \w parole|strong="H1697"\w* \w du|strong="H1697"\w* \w SEIGNEUR|strong="H3068"\w* \w fut|strong="H3068"\w* \w adressée|strong="H1697"\w* \w à|strong="H3068"\w* \w Jonas|strong="H3124"\w* \w une|strong="H3068"\w* \w seconde|strong="H8145"\w* \w fois|strong="H8145"\w* :
