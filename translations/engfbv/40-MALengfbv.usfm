\v 5 \w You|strong="H5921"\w*\f + \fr 1:5 \ft The people of Israel.\f* \w will|strong="H3068"\w* \w see|strong="H7200"\w* \w this|strong="H7200"\w* destruction \w with|strong="H3068"\w* \w your|strong="H3068"\w* \w own|strong="H5869"\w* \w eyes|strong="H5869"\w*, \w and|strong="H3478"\w* \w you|strong="H5921"\w* \w will|strong="H3068"\w* \w say|strong="H3478"\w*, “\w The|strong="H5921"\w* \w Lord|strong="H3068"\w* \w is|strong="H3068"\w* \w great|strong="H1431"\w*, \w even|strong="H5869"\w* \w beyond|strong="H5921"\w* \w the|strong="H5921"\w* \w borders|strong="H1366"\w* \w of|strong="H3068"\w* \w Israel|strong="H3478"\w*.”   
