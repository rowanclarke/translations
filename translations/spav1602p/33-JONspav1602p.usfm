\v 14 \w Entonces|strong="H3588"\w* clamaron \w al|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*, \w y|strong="H3588"\w* dijeron: \w Rogámoste|strong="H4994"\w* \w ahora|strong="H4994"\w*, oh \w SEÑOR|strong="H3068"\w*, \w que|strong="H3588"\w* \w no|strong="H6213"\w* perezca­mos \w nosotros|strong="H5921"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w vida|strong="H5315"\w* \w de|strong="H5921"\w* \w este|strong="H2088"\w* hombre, \w ni|strong="H5355"\w* \w pongas|strong="H5414"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w inocente|strong="H5355"\w*: \w por|strong="H5921"\w*­\w que|strong="H3588"\w* \w tú|strong="H6213"\w*, oh \w SEÑOR|strong="H3068"\w*, \w has|strong="H5414"\w* \w hecho|strong="H6213"\w* \w como|strong="H3588"\w* \w has|strong="H5414"\w* querido.   
