\id TIT  
\h Tito 
\toc1 YA'A KUU CARTA JA NI CHAA SAN PABLO APOSTOL NUU TITO 
\toc2 Tito 
\toc3 Tit. 
\mt2 LA EPISTOLA DEL APOSTOL SAN PABLO A TITO 
\mt1 YA'A KUU CARTA JA NI CHAA SAN PABLO APOSTOL NUU TITO 
\c 1  
\p  
\v 1 Máá‑rí kúu Pablo, mozo Dios te suni apóstol Jesucristo kúu‑ri̱ ni̱ sá'a‑ya̱, náva̱'a skándíja‑ga̱‑ri̱ ña̱yɨvɨ ní ka̱ji Dios, jíín já ná júku̱'un‑ga̱ ini̱‑i tu̱'un ndaa̱ ndasa chiñú'ún‑i‑ya̱.  
\v 2 Te ja̱ yúán káñukuu ini̱‑i kuchaku̱‑i nɨ́ɨ́ káni, chi̱ súan ni̱ keyu'u Dios onde̱ aná'án xáa̱n, te ma̱ kúu kutɨ xndá'ú‑ya̱‑í.  
\v 3 Te onde̱ ni̱ ji̱nu va̱'a máá kɨvɨ́, te ni̱ stá'a̱n ndiji̱n‑ya̱ tú'un‑ya̱ jíín tú'un kájani‑ri̱, ja̱ ní chi'i‑ya̱‑ún ndá'a‑rí, nátu̱'un ni̱ tá'ú tíñu Dios, I'a̱ náma yóó.  
\v 4 Cháa‑ri̱ tutu̱ yá'a nuu̱‑ro̱ Tito, chi se̱'e ndija‑ri̱ kúu‑ró sɨkɨ́ tú'un kákandíja ká'nu‑yó. Tu̱'un luu íó ini̱‑ya̱, jíín tú'un kúndá'ú ini̱‑ya̱ yóó, jíín tú'un kuaká'nu ini̱, ja̱ kíi nuu̱ máá Táa̱‑yo̱ Dios, jíín já kíi nuu̱ máá Jíto'o̱‑yo̱ Jesucristo, I'a̱ náma yóó, ná kóo jíín‑ró. 
\s1 Ndasa koo cha̱a kákuu nuu̱ 
\p  
\v 5 Ja̱ sɨkɨ́ yúán ní skéndo̱o‑ri̱ róó onde̱ ñuu̱ Creta, náva̱'a ná sándaa̱‑ro̱ nú tú kuní ji̱nu va̱'a tiñu, te náva̱'a kani‑ró cháa kuu nuu̱ ná ɨɨn ná ɨɨn ñuu̱, nátu̱'un ni̱ tá'ú‑rí tiñu nuu̱‑ro̱.  
\v 6 Kani‑ró cháa tú yí'i kua̱chi sɨkɨ̱, jíín nú ɨɨn‑ni ñasɨ́'ɨ́‑de íó, jíín nú kákandíja va̱'a se̱'e‑de, te nú tú kájaku̱ nchaa̱ ña̱yɨvɨ‑í ja̱ síjíta‑i máá‑i xí já ní'in ini̱‑i.  
\v 7 Te cha̱a ndíto tɨku'ni̱, nɨ́nɨ ná kúu‑de cha̱a tú yí'i kua̱chi sɨkɨ̱, chi̱ nchátíñu‑de tiñu Dios. Ma̱ kújá'a̱ ini̱‑de, ma̱ yachí kiti̱ ini̱‑de, ma̱ kóo ká'vá‑de, ma̱ stují‑dé ña̱yɨvɨ, ma̱ ndío xaa̱n iní‑de sɨkɨ̱ xú'ún.  
\v 8 Chi̱ sua ná kóto ndá'ú‑de nuu̱ ñáyɨvɨ jíká, ná chíñú'ún‑de tiñu va̱'a, ná kóo kuándí'í‑de, ná kóo ndaa̱ ini̱‑de, ná kóo ndoo‑de, ná kútɨɨn ni̱'in‑de máá‑de.  
\v 9 Te ná kúndii̱ ni̱'in‑de jíín tú'un ndaa̱ kákandíja‑yó jíín já kúu sa'a̱n‑ya̱, náva̱'a kuu stá'a̱n‑de ta̱ká sa'a̱n va̱'a, te náva̱'a kuu kundéé‑de jíín ñáyɨvɨ sáká núu. 
\s1 Ja̱ xndá'ú ña̱yɨvɨ 
\p  
\v 10 Chi̱ íó kua'a̱ cháa ja̱ tú kákuni̱‑de kuandatu̱‑de, te káka'a̱n sáni‑de, te káxndá'ú‑de ña̱yɨvɨ. Te cha̱a ni̱ kaxɨtɨ̱ ndúu̱, ví'í‑gá kásá'a‑de súan.  
\v 11 Nɨ́nɨ ná kasú‑ro̱ yú'u cháa‑ún, chi̱ kásáká núu‑de ini̱ ña̱yɨvɨ nɨ́ɨ́ nɨ́ɨ́‑ni‑i ve'e‑i. Te kástá'a̱n‑de tu̱'un ja̱ tú ká'i̱o va̱'a, te kándúkú‑de ni'i̱n‑dé xu̱'ún sɨkɨ́ tíñu ñáá‑ún.  
\v 12 Ɨɨn tá'an máá‑de, cha̱a jáni tu̱'un ñuu̱ máá‑de, ni̱ ka'a̱n súan: Ña̱yɨvɨ ñúu̱ Creta, chi̱ máni ña̱yɨvɨ xndá'ú kákuu, máni kɨtɨ sána kákuu, máni káyee kúxí, áchí‑de.  
\v 13 Ká'a̱n ndaa̱ tu̱'un ni̱ ka'a̱n cha̱a‑ún. Núsáá te kana jíín téyíí‑ró núu̱‑í, náva̱'a ná kándíja ni̱'in‑i.  
\v 14 Ma̱ chú'un ini̱‑i cuento káka'a̱n cha̱a judío, ni tiñu kátá'ú cháa ja̱ á ni̱ ka̱ské'ichi̱‑de tu̱'un ndaa̱.  
\v 15 Ña̱yɨvɨ ká'i̱o ndoo, jáni ini̱‑i ja̱ íó ndoo‑ni ta̱ká ndatíñu, ko ña̱yɨvɨ chá'án jíín ñáyɨvɨ tú kákandíja, ni ɨɨn ndatíñu tú íó ndoo jiní‑i, chi̱ sua ni̱ te'yu̱ añú‑i jíín já jiní tuní‑i.  
\v 16 Káka'a̱n‑i ja̱ á kájini̱‑i nuu̱ Dios, ko jíín tíñu kásá'a‑i, te kájasu̱‑i nuu̱‑yá, chi ña̱yɨvɨ chá'án, ña̱yɨvɨ ní'in ini̱ kákuu‑i, te tú ní'i̱n tíñu kutɨ‑í nuu̱ ní ɨɨn tiñu va̱'a. 
\c 2  
\s1 Sa'a̱n ja̱ íó va̱'a 
\p  
\v 1 Ko róó, ná ká'a̱n‑ro̱ sá'a̱n ja̱ íó va̱'a.  
\v 2 Kachi̱‑ro̱ núu̱ cháa ñá'nu ja̱ ná kóo kuándí'í‑de, ná kóo kájí xiní‑dé, ná kóo jíñú'ún‑de, ná kándíja ni̱'in‑de, ná kúndá'ú ini̱‑de‑i, ná kóo paciencia‑de.  
\v 3 Suni súan ña'an ñá'nu. Ná káka jíñú'ún‑ña, ma̱ sátú'ún‑ña, ma̱ kóo ká'vá‑ña, ná stá'a̱n‑ña núu̱‑í ndéja̱ kúu ja̱ vá'a,  
\v 4 te ná stá'a̱n‑ña núu̱ ñá'an súchí já ná kóo jíñú'ún‑i, ja̱ ná kúvixi̱‑i jíín yíi‑í, ná kúndá'ú ini̱‑i se̱'e‑i,  
\v 5 te ná kóo kuándí'í‑i, ma̱ káka téné‑i, ná kóto va̱'a‑i ve'e‑i, ná kóo tu̱'un mani̱ iní‑i, ná kuándatu̱‑i nuu̱ yíi‑í, náva̱'a tú ka'a̱n ndɨva̱'a ña̱yɨvɨ sɨkɨ́ tú'un Dios sá'a‑i.  
\v 6 Suni súan ka'a̱n nda̱'ú‑ro̱ jíín cháa súchí, ja̱ ná kútɨɨn ni̱'in‑i máá‑i.  
\v 7 Te róó, ná sá'a‑ró táká tiñu va̱'a, náva̱'a kuu‑ró ɨ́ɨn ejemplo va̱'a nuu̱‑í. Te jíín tú'un ká'a̱n‑ro̱, ná ká'a̱n ndaa̱, te ná ká'a̱n ñukájí iní‑ro̱.  
\v 8 Tu̱'un va̱'a ka'a̱n‑ro̱, náva̱'a ma̱ kuakú nchaa̱‑i yóó, náva̱'a kuka nuu̱ cháa jasú nuu̱‑yo̱, chi̱ tú kúu ndiñi'in‑de ni ɨɨn tiñu ñáá ká'a̱n‑de sɨkɨ̱‑yo̱.  
\v 9 Ka'a̱n nda̱'ú‑ro̱ jíín mozo ja̱ ná kuándatu̱‑i nuu̱ patrón‑i, ja̱ ná kúsɨɨ̱ iní patrón‑i sá'a‑i jíín táká tiñu‑i, te ma̱ ná chísó‑i tu̱'un nuu̱‑dé.  
\v 10 Ma̱ sákuí'ná‑i ndatíñu‑de, chi̱ sua ndaa̱ ná skíkuu va̱'a‑i nuu̱‑dé, náva̱'a jíín táká tiñu sá'a‑i, te skéndo̱o luu‑i sa'a̱n Dios máá‑yó, I'a̱ náma yóó, sá'a‑i.  
\v 11 Chi tu̱'un luu íó ini̱ Dios, ja̱ kúu ka̱ku ta̱ká ña̱yɨvɨ sá'a, a ni̱ kenda ndiji̱n.  
\v 12 Te tu̱'un‑ún stá'a̱n nuu̱‑yo̱ ndasa skána‑yó táká tu̱'un ja̱ tú chíñú'ún‑yó‑yá sá'a, jíín já ndío ini̱‑yo̱ sɨkɨ́ ñúyɨ́vɨ sá'a, te stá'a̱n nuu̱‑yo̱ ndasa koo kájí iní‑yo̱ káka kuu‑yó jíín já kóo ndaa̱ ini̱‑yo̱, jíín já ná chíñú'ún‑yó‑yá kuia̱ yá'a.  
\v 13 Káinda̱tu‑yó, chi̱ káñukuu ini̱‑yo̱ kéndo̱o ndatu̱‑yo̱ kɨvɨ́ ndíi ncháa̱ kenda ndiji̱n Jesucristo ja̱ kúu‑ya̱ Dios ñá'nu máá‑yó, I'a̱ náma yóó.  
\v 14 Te ni̱ ja̱'a‑ya̱ máá‑yá ja̱ sɨkɨ́ yóó, náva̱'a chunáa‑yá ta̱ká ja̱ ní ka̱stɨ́vɨ́‑yó, suni náva̱'a sándoo‑ya̱ ñáyɨvɨ kuíñi nuu̱ máá‑yá, jíín já ná kuítú iní‑i sá'a‑i tiñu va̱'a.  
\v 15 Súan ka'a̱n‑ro̱, te ka'a̱n nda̱'ú‑ro̱, te kana jíín‑ró núu̱‑í jíín tíñu ndíso‑ró. Ma̱ kuá'a‑ró tú'un ja̱ sájá'a̱ ini̱ ni ɨɨn‑i nuu̱‑ro̱. 
\c 3  
\p  
\v 1 Xndáku‑ró núu̱‑í ja̱ ná kuá'a‑i so̱'o‑i nuu̱ cháa kákuñá'nu, jíín núu̱ cháa kándi̱so tíñu. Ná kuándatu̱‑i, te yachi̱ ná tɨ́ɨn‑i ta̱ká tiñu va̱'a.  
\v 2 Ma̱ ká'a̱n‑i sɨkɨ̱ ní ɨɨn ña̱yɨvɨ, ma̱ kútɨ́xɨ́n‑i, ná kóo jíñú'ún‑i, te ná kóo súchí iní‑i jíín táká ña̱yɨvɨ.  
\v 3 Chi̱ sáá, suni ña̱yɨvɨ ñáá ni̱ ka̱kuu‑yó núú, tú ní kájandatu̱‑yo̱, ni̱ kasa̱na‑yó íchi, ni̱ ka̱chiñú'ún‑yó táká ja̱ ní ndio ñáá ini̱‑yo̱ jíín sɨ́ɨn sɨ́ɨn tiñu ni̱ ka̱kusɨɨ̱ iní‑yo̱ jíín, te ni̱ ka̱jika kuu‑yó jíín tú'un ñáá tu̱'un kuásún iní, ni̱ kakiti̱ ini̱‑i nuu̱‑yo̱, te ni̱ ka̱jito u'u̱ tá'an‑yó.  
\v 4 Te Dios kúu I'a̱ náma yóó. Te ni̱ kenda ndiji̱n tu̱'un kúmani̱ iní‑ya̱ jíín‑yó jíín tú'un kúndá'ú ini̱‑ya̱ táká ña̱yɨvɨ.  
\v 5 Yúan‑na te ni̱ nama‑ya̱ yóó, ko nasu̱ jíín tíñu ndaa̱ ni̱ ka̱sá'a‑yó, chi̱ jíín tú'un ni̱ kundá'ú ini̱‑ya̱ yóó. Te jíín tú'un ni̱ nakacha‑ya̱ yóó ni̱ nakaku‑yó, te ni̱ ndujáá‑yó ní sá'a máá Espíritu Santo.  
\v 6 Te Espíritu‑ún ni̱ jicha̱ nu̱u kua'a̱ iní añú‑yo̱ ní sá'a Jesucristo I'a̱ náma yóó,  
\v 7 náva̱'a kuu kendo̱o ndaa̱‑yo̱ sá'a tu̱'un luu íó ini̱‑ya̱, suni náva̱'a ni'i̱n‑yo̱ tá'u̱‑yo̱ já kúñukuu ini̱‑yo̱ kúchaku̱‑yo̱ nɨ́ɨ́ káni.  
\v 8 Ká'a̱n ndaa̱ tu̱'un yúan. Te kuní‑ri̱ ja̱ ná ká'a̱n ni̱'in‑ró táká tu̱'un yá'a, náva̱'a ña̱yɨvɨ ní ka̱kandíja‑i nuu̱ Dios ná kuítú iní‑i kukuu‑i jíín tíñu va̱'a. Ió va̱'a ta̱ká tu̱'un yá'a, te ní'i̱n tíñu ja̱ kúu ta̱ká ña̱yɨvɨ.  
\v 9 Ko ma̱ kɨ́vɨ nduu̱‑ro̱ jíín táká tɨxɨ̱n káñáá, ni sɨkɨ̱ tú'un ji̱chi tu̱'un tá'an, ni tu̱'un kana̱á, ni jíín tú'un kástátá'an sɨkɨ̱ ley. Chi̱ máni tu̱'un sáni kákuu‑ún te tú ní'i̱n tíñu.  
\v 10 Nú íó ɨɨn cha̱a tú játú'ún, te nú a ni̱ kana jíín‑ró núu̱‑dé ɨɨn uu̱ jínu, yúan‑na te ma̱ kɨ́vɨ nduu̱‑ga̱‑ro̱ jíín‑de.  
\v 11 A jiní ndija‑yó já ɨ́ɨn ña̱yɨvɨ sá'a súan, a ni̱ skuíta‑i ichi, te máni kua̱chi sá'a‑i, te kua̱chi máá‑i kúu ja̱ náku̱xndíi‑ya̱ sɨkɨ́‑í. 
\s1 Tu̱'un sándéé iní 
\p  
\v 12 Nú ni̱ tájí‑rí Artemas xí Tíquico jaa̱ nuu̱‑ro̱, yúan‑na te ndúkú ndéé‑ró kíi‑ró núu̱‑rí ñuu̱ Nicópolis, chi̱ cháa ini̱‑ri̱ kunchaa̱‑ri̱ yúan viko víjin.  
\v 13 Te ná ndúkú ndéé‑ró chú'un íchí‑ró Zenas, cha̱a kúu maestro ley, onde̱ jíín Apolos. Te koto‑ró‑de náva̱'a tú kuu falta ni ɨɨn nuu̱‑dé.  
\v 14 Te ña̱yɨvɨ ká'i̱in jíín‑yó, ná skuá'a‑i tɨɨn ni̱'in‑i tiñu va̱'a, náva̱'a ni'i̱n‑í ndasa ja̱'a tu̱ndó'o sava‑ga̱‑i, náva̱'a tú kundii̱ sáni‑i.  
\v 15 Ta̱ká ña̱yɨvɨ káxiu̱kú jíín‑rí yá'a, káka'a̱n‑i ja̱ ná sándéé iní‑ro̱. Ná sándéé iní ta̱ká ña̱yɨvɨ kákumani̱ jíín‑yó sɨkɨ́ tú'un kákandíja‑yó, kachi̱‑ro̱ kúni‑i. Tu̱'un luu íó ini̱‑ya̱, ná kóo jíín‑ró jíná'an‑ró. Súan ná kóo. Amén.