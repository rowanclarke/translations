\v 3 Entonces \w la|strong="H5921"\w* \w reina|strong="H4436"\w* Ester \w respondió|strong="H6030"\w*: Oh \w rey|strong="H4428"\w*, \w si|strong="H5921"\w* \w hallé|strong="H4672"\w* \w gracia|strong="H2580"\w* ante \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w si|strong="H5921"\w* \w place|strong="H2895"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w*, ¡\w concédase|strong="H5414"\w* \w mi|strong="H5921"\w* \w vida|strong="H5315"\w* \w por|strong="H5921"\w* \w mi|strong="H5921"\w* \w petición|strong="H7596"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w por|strong="H5921"\w* \w mi|strong="H5921"\w* \w demanda|strong="H1246"\w*!
\v 4 ¡\w Porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w y|strong="H3588"\w* mi \w pueblo|strong="H5971"\w* fuimos \w vendidos|strong="H4376"\w* \w para|strong="H3588"\w* ser \w destruidos|strong="H8045"\w*, asesinados \w y|strong="H3588"\w* exterminados! \w Si|strong="H3588"\w* \w como|strong="H3588"\w* esclavos \w y|strong="H3588"\w* esclavas fuéramos \w vendidos|strong="H4376"\w*, \w yo|strong="H3588"\w* habría callado, \w porque|strong="H3588"\w* \w aun|strong="H3588"\w* tal calamidad \w no|strong="H3588"\w* sería digna \w de|strong="H3588"\w* \w la|strong="H3588"\w* molestia \w al|strong="H4428"\w* \w rey|strong="H4428"\w*.
