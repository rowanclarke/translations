\v 9 \w Car|strong="G1063"\w* \w celui|strong="G3588"\w* \w à|strong="G3588"\w* \w qui|strong="G3588"\w* \w elles|strong="G1063"\w* \w font|strong="G3739"\w* défaut \w est|strong="G3588"\w* \w un|strong="G3739"\w* \w homme|strong="G3778"\w* \w qui|strong="G3588"\w* \w a|strong="G3588"\w* \w la|strong="G1063"\w* vue courte, \w un|strong="G3739"\w* \w aveugle|strong="G5185"\w* ; \w il|strong="G1063"\w* \w a|strong="G3588"\w* oublié \w la|strong="G1063"\w* façon \w dont|strong="G3739"\w* \w il|strong="G1063"\w* \w a|strong="G3588"\w* \w été|strong="G1510"\w* \w purifié|strong="G3588"\w* \w de|strong="G3588"\w* \w ses|strong="G3739"\w* \w anciens|strong="G3588"\w* \w péchés|strong="G3739"\w*.
