\s1 Jacob and Laban agreed to be good to each other  
\p
\v 43 \w Then|strong="H6030"\w* \w Laban|strong="H3837"\w* \w said|strong="H6030"\w*, “\w Your|strong="H3605"\w* wives \w are|strong="H3117"\w* \w my|strong="H3605"\w* \w daughters|strong="H1323"\w*. \w Your|strong="H3605"\w* \w kids|strong="H1121"\w* \w are|strong="H3117"\w* \w my|strong="H3605"\w* grand-kids. \w All|strong="H3605"\w* \w these|strong="H6213"\w* animals here, \w they|strong="H3117"\w* belong \w to|strong="H6213"\w* \w me|strong="H7200"\w*, \w and|strong="H1121"\w* \w everything|strong="H3605"\w* \w else|strong="H3605"\w* here belongs \w to|strong="H6213"\w* \w me|strong="H7200"\w* too. \w But|strong="H7200"\w* \w I|strong="H3117"\w* \w can|strong="H4100"\w*’t \w get|strong="H6213"\w* \w my|strong="H3605"\w* \w daughters|strong="H1323"\w* \w and|strong="H1121"\w* \w my|strong="H3605"\w* grand-kids back \w now|strong="H3117"\w*. \w I|strong="H3117"\w* know \w that|strong="H7200"\w* \w they|strong="H3117"\w* \w will|strong="H1121"\w* \w go|strong="H6030"\w* \w with|strong="H6213"\w* \w you|strong="H3605"\w* \w to|strong="H6213"\w* \w your|strong="H3605"\w* home country, \w and|strong="H1121"\w* \w I|strong="H3117"\w* \w will|strong="H1121"\w* \w go|strong="H6030"\w* back \w to|strong="H6213"\w* \w my|strong="H3605"\w* home country.  
\v 44 \w So|strong="H1961"\w* \w before|strong="H1961"\w* \w I|strong="H6258"\w* \w go|strong="H3212"\w*, \w let|strong="H6258"\w*’s agree \w that|strong="H1961"\w* \w we|strong="H3068"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* good \w to|strong="H3212"\w* each other. \w And|strong="H3212"\w* \w let|strong="H6258"\w*’s put some stones \w in|strong="H3212"\w* \w this|strong="H6258"\w* \w place|strong="H1961"\w* \w to|strong="H3212"\w* \w show|strong="H1961"\w* \w that|strong="H1961"\w* \w we|strong="H3068"\w* \w made|strong="H3772"\w* \w that|strong="H1961"\w* \w agreement|strong="H1285"\w*.”   
\p
