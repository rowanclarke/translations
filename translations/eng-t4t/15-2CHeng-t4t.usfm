\v 23 \w Then|strong="H1696"\w* \w Zedekiah|strong="H6667"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Kenaanah|strong="H3668"\w* walked \w over|strong="H5921"\w* \w to|strong="H1696"\w* \w Micaiah|strong="H4321"\w* \w and|strong="H1121"\w* \w slapped|strong="H5221"\w* \w him|strong="H5921"\w* \w on|strong="H5921"\w* \w his|strong="H3068"\w* face. \w He|strong="H3068"\w* \w said|strong="H1696"\w*, “\w Do|strong="H3068"\w* \w you|strong="H5921"\w* think \w that|strong="H3068"\w* \w Yahweh|strong="H3068"\w*’s \w Spirit|strong="H7307"\w* \w left|strong="H5674"\w* \w me|strong="H5921"\w* \w in|strong="H5921"\w* order \w to|strong="H1696"\w* \w speak|strong="H1696"\w* \w to|strong="H1696"\w* \w you|strong="H5921"\w*?”   
