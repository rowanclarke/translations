\v 5 Te \w phoeiah|strong="H9999"\w*,
\p “\w Aw|strong="H0577"\w*, \w vaan|strong="H8064"\w* kah \w Pathen|strong="H0430"\w* \w Yahweh|strong="H3068"\w*, ka om Khohni, \w Pathen|strong="H0410"\w* \w tah\w* \w len|strong="H1419"\w* \w tih|strong="H9999"\w* \w rhih|strong="H3372"\w* om pai. \w Amah|strong="H9909"\w* \w aka\w* \w lungnah|strong="H0157"\w* \w taeng|strong="H9997"\w* \w neh|strong="H9999"\w* \w a|strong="H9909"\w* \w olpaek|strong="H4687"\w* \w aka\w* \w ngaithuen|strong="H8104"\w* \w taengah|strong="H9997"\w* \w paipi|strong="H1285"\w* \w neh|strong="H9999"\w* \w sitlohnah|strong="H2617"\w* a \w ngaithuen|strong="H8104"\w* pah.
\v 6 \w Na|strong="H9905"\w* \w sal|strong="H5650"\w* kah \w thangthuinah|strong="H8605"\w* \w te|strong="H0413"\w* \w yaak|strong="H8085"\w* \w hamla|strong="H9997"\w* \w na|strong="H9905"\w* \w hna|strong="H0241"\w* \w khui|strong="H7183"\w* \w tih|strong="H9999"\w* \w na|strong="H9905"\w* \w mik|strong="H5869"\w* \w aka\w* \w dai|strong="H6605"\w* la \w om|strong="H1961"\w* \w laeh|strong="H4994"\w*. \w Kai|strong="H0595"\w* \w he\w* \w tihnin|strong="H3117"\w* \w ah\w* \w khaw\w* \w na|strong="H9905"\w* \w sal|strong="H5650"\w* \w Israel|strong="H3478"\w* \w ca|strong="H1121"\w* \w ham|strong="H5921"\w* \w khoyin|strong="H3915"\w* \w khothaih|strong="H3119"\w* \w na|strong="H9905"\w* \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w* \w ka\w* \w thangthui|strong="H6419"\w* \w coeng\w*. \w Namah|strong="H9905"\w* \w taengah|strong="H9997"\w* \w ka\w* \w tholh|strong="H2398"\w* uh \w bangla|strong="H0834"\w* \w Israel|strong="H3478"\w* \w ca|strong="H1121"\w* kah \w tholhnah|strong="H2403"\w* \w te|strong="H5921"\w* kam \w phoe|strong="H3034"\w*. \w Kamah|strong="H0589"\w* \w neh|strong="H9999"\w* \w a|strong="H9901"\w* \w pa|strong="H0001"\w* \w imkhui|strong="H1003"\w* khaw ka \w tholh|strong="H2398"\w* \w uh\w* \w coeng\w*.
\v 7 \w Na|strong="H9903"\w* \w taengah|strong="H9997"\w* \w laikoi|strong="H2254"\w* \w la\w* \w ka\w* \w laikoi|strong="H2254"\w* \w uh\w* \w coeng\w* \w tih|strong="H9999"\w* \w na|strong="H9905"\w* \w sal|strong="H5650"\w* \w Moses|strong="H4872"\w* taengah na \w uen|strong="H6680"\w* \w olpaek|strong="H4687"\w* \w neh|strong="H9999"\w* \w oltlueh|strong="H2706"\w* \w khaw|strong="H9999"\w*, \w laitloeknah|strong="H4941"\w* \w khaw\w* \w ka\w* \w ngaithuen|strong="H8104"\w* uh \w pawh|strong="H3808"\w*.
\v 8 \x - \xo 1.8 \xt Tho 26. 33.\x*\w Na|strong="H9905"\w* \w sal|strong="H5650"\w* \w Moses|strong="H4872"\w* \w ol|strong="H1697"\w* na \w uen|strong="H6680"\w* tih, “Boe \w na|strong="H0859"\w* \w koek|strong="H4603"\w* uh dongah \w nangmih|strong="H9904"\w* \w te|strong="H0853"\w* \w pilnam|strong="H5971"\w* lakli \w ah|strong="H9996"\w* \w kan|strong="H0589"\w* \w taekyak|strong="H6327"\w* ni,” na \w ti|strong="H0559"\w* nah \w te|strong="H0853"\w* \w thoelh|strong="H2142"\w* \w laeh|strong="H4994"\w*.
\v 9 \x - \xo 1.9 \xt Olr 30. 1-5.\x* \w Tedae|strong="H9999"\w* \w kai|strong="H9901"\w* \w taengla|strong="H0413"\w* na \w mael|strong="H7725"\w* uh \w tih|strong="H9999"\w* \w ka|strong="H9901"\w* \w olpaek|strong="H4687"\w* \w he\w* \w ngaithuen|strong="H8104"\w* \w neh|strong="H9999"\w* na \w vai|strong="H6213"\w* atah \w vaan|strong="H8064"\w* \w khobawt|strong="H7097"\w* \w la|strong="H9996"\w* \w nangmih|strong="H9904"\w* \w aka\w* \w heh|strong="H5080"\w* \w te\w* \w om|strong="H1961"\w* \w cakhaw|strong="H0518"\w* \w amih|strong="H9908"\w* \w te\w* \w te|strong="H8033"\w* \w lamloh|strong="H4480"\w* \w ka\w* \w coi|strong="H6908"\w* \w vetih|strong="H9999"\w* \w ka|strong="H9901"\w* \w ming|strong="H8034"\w* \w om|strong="H7931"\w* \w sak\w* \w ham|strong="H9997"\w* \w ka\w* \w coelh|strong="H0977"\w* \w hmuen|strong="H4725"\w* \w la|strong="H0413"\w* \w amih|strong="H9908"\w* te pahoi ka \w khuen|strong="H0935"\w* rhoe ka \w khuen|strong="H0935"\w* ni,’ na ti.
\v 10 \w Amih|strong="H1992"\w* \w te\w* \w na|strong="H9905"\w* \w sal|strong="H5650"\w* \w neh|strong="H9999"\w* \w na|strong="H9905"\w* \w pilnam|strong="H5971"\w* ni. \w Te|strong="H0834"\w* rhoek te \w na|strong="H9905"\w* \w len|strong="H1419"\w* \w thadueng|strong="H3581"\w* \w neh|strong="H9996"\w*, \w na|strong="H9905"\w* \w tlungluen|strong="H2389"\w* \w kut|strong="H3027"\w* \w neh|strong="H9996"\w* na \w lat|strong="H6299"\w*.
\v 11 \w Ka|strong="H9901"\w* \w Boeipa|strong="H0136"\w* \w aw|strong="H0577"\w*, \w na|strong="H9905"\w* \w sal|strong="H5650"\w* rhoek kah \w thangthuinah|strong="H8605"\w* \w taengah|strong="H0413"\w* \w khaw|strong="H9999"\w* \w na|strong="H9905"\w* \w ming|strong="H8034"\w* \w rhih|strong="H3372"\w* \w ham|strong="H9997"\w* \w aka\w* \w omtoem|strong="H2655"\w* \w na|strong="H9905"\w* \w sal|strong="H5650"\w* rhoek kah \w thangthuinah|strong="H8605"\w* \w dongah|strong="H0413"\w* \w na|strong="H9905"\w* \w hna|strong="H0241"\w* \w aka\w* \w khui|strong="H7183"\w* sak la \w om|strong="H1961"\w* \w laeh|strong="H4994"\w*. \w Tihnin|strong="H3117"\w* kah \w na|strong="H9905"\w* \w sal|strong="H5650"\w* \w te|strong="H9997"\w* \w khaw\w* \w thaihtak|strong="H6743"\w* \w sak\w* \w laeh|strong="H4994"\w*. \w Anih|strong="H9909"\w* \w te\w* \w hlang|strong="H0376"\w* \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w* \w haidamnah|strong="H7356"\w* \w neh|strong="H9997"\w* \w pae|strong="H5414"\w*,” ka \w ti|strong="H0559"\w*. \w Te\w* \w vaengah|strong="H9999"\w* \w kai|strong="H0589"\w* \w tah\w* \w manghai|strong="H4428"\w* \w taengah|strong="H9997"\w* \w tuitul|strong="H4945"\w* kung la ka \w om|strong="H1961"\w*.
\b
\c 2
\s1 Nehemiah te Jerusalem La A Tueih
\p 
\v 1 \w Artaxerxes|strong="H0783"\w* \w manghai|strong="H4428"\w* kah \w kum|strong="H8141"\w* \w kul|strong="H6242"\w* nah \w Nisan|strong="H5212"\w* \w hla|strong="H2320"\w* \w vaengah|strong="H9996"\w* \w tah\w* \w a|strong="H9909"\w* \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w* \w misurtui|strong="H3196"\w* \w om\w*. \w Te\w* \w dongah|strong="H9999"\w* \w misurtui|strong="H3196"\w* \w te|strong="H0853"\w* \w ka\w* \w pom|strong="H5375"\w* \w tih|strong="H9999"\w* \w manghai|strong="H4428"\w* \w te|strong="H9997"\w* \w ka\w* \w doe|strong="H5414"\w*. \w Tedae|strong="H9999"\w* \w a|strong="H9909"\w* \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w* a \w thae|strong="H7451"\w* la ka \w om|strong="H1961"\w* \w pawh|strong="H3808"\w*.
\v 2 Te \w vaengah|strong="H9999"\w* \w manghai|strong="H4428"\w* \w loh\w* \w kai|strong="H9901"\w* \w te|strong="H9997"\w*, “\w Balae|strong="H4069"\w* tih \w na|strong="H9905"\w* \w maelhmai|strong="H6440"\w* a \w thae|strong="H7451"\w*? \w Nang|strong="H0859"\w* \w pawt|strong="H0369"\w* nim? \w Na|strong="H9905"\w* \w tlo|strong="H2470"\w* \w pawt|strong="H0369"\w* nim \w te|strong="H2088"\w*? \w Lungbuei|strong="H3820"\w* \w thaenah|strong="H7455"\w* \w bueng|strong="H0518"\w* \w he\w* \w khaw|strong="H9999"\w* \w bahoeng|strong="H3966"\w* \w ka\w* \w rhih|strong="H3372"\w* aih,” a \w ti|strong="H0559"\w*.
\p 
\v 3 \x - \xo 2.3 \xt 2Mg 25. 8-10; 2Kh 36. 19; Jer 52. 12-14.\x* \w Tedae|strong="H9999"\w* \w manghai|strong="H4428"\w* \w te|strong="H9997"\w*, “\w Manghai|strong="H4428"\w* \w tah\w* \w kumhal|strong="H5769"\w* \w duela|strong="H9997"\w* \w hing|strong="H2421"\w* saeh, \w balae|strong="H4069"\w* tih \w ka|strong="H9901"\w* \w maelhmai|strong="H6440"\w* a \w thae|strong="H7489"\w* \w pawt|strong="H3808"\w* eh? \w A|strong="H9901"\w* \w pa|strong="H0001"\w* rhoek kah \w phuel|strong="H6913"\w* \w im|strong="H1003"\w* \w khopuei|strong="H5892"\w* \w loh\w* \w kaksap|strong="H2720"\w* \w tih|strong="H9999"\w* \w a|strong="H9907"\w* \w vongka|strong="H8179"\w* \w khaw\w* \w hmai|strong="H0784"\w* \w loh|strong="H9996"\w* a \w hlawp|strong="H0398"\w* coeng,” ka \w ti|strong="H0559"\w* nah.
\p 
\v 4 Te \w vaengah|strong="H9999"\w* \w manghai|strong="H4428"\w* \w loh\w* \w kai|strong="H9901"\w* \w taengah|strong="H9997"\w*, “\w Balae|strong="H4100"\w* \w nan|strong="H0859"\w* \w dawt|strong="H1245"\w*, \w vaan|strong="H8064"\w* \w Pathen|strong="H0430"\w* \w taengah|strong="H0413"\w* \w ka\w* \w thangthui|strong="H6419"\w* ngawn ta,” a \w ti|strong="H0559"\w*.
\p 
\v 5 Te \w vaengah|strong="H9999"\w* \w manghai|strong="H4428"\w* \w te|strong="H9997"\w*, “\w Manghai|strong="H4428"\w* \w taengah|strong="H5921"\w* \w then|strong="H2896"\w* \w mai|strong="H0518"\w* \w tih|strong="H9999"\w* \w na|strong="H9905"\w* \w sal|strong="H5650"\w* \w he\w* \w na|strong="H9905"\w* \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w* a \w thuem|strong="H3190"\w* \w atah|strong="H0518"\w* \w kai|strong="H9901"\w* \w he\w* \w Judah|strong="H3063"\w* \w ah|strong="H0413"\w* \w a|strong="H9901"\w* \w pa|strong="H0001"\w* rhoek kah \w phuel|strong="H6913"\w* \w kho|strong="H5892"\w* \w la|strong="H0413"\w* n'\w tueih|strong="H7971"\w* \w lamtah|strong="H9999"\w* \w ka\w* \w thoh|strong="H1129"\w* mai eh,” ka \w ti|strong="H0559"\w* nah.
\p 
\v 6 Te \w phoeiah|strong="H9999"\w* \w manghai|strong="H4428"\w* \w neh|strong="H9999"\w* \w a|strong="H9909"\w* \w taengah|strong="H0681"\w* \w aka\w* \w ngol|strong="H3427"\w* \w manghainu|strong="H7694"\w* \w loh\w* \w kai|strong="H9901"\w* \w taengah|strong="H9997"\w*, “\w Na|strong="H9905"\w* \w caehlong|strong="H4109"\w* te me \w hil|strong="H5704"\w* \w nim|strong="H4970"\w* a \w koe|strong="H1961"\w* \w vetih|strong="H9999"\w* me vaengah \w lae|strong="H4970"\w* na \w mael|strong="H7725"\w* eh?” a \w ti|strong="H0559"\w*. \w Manghai|strong="H4428"\w* \w mik|strong="H6440"\w* \w ah|strong="H9997"\w* a \w voelphoeng|strong="H3190"\w* \w dongah|strong="H9999"\w* \w kai|strong="H9901"\w* n'\w tueih|strong="H7971"\w* \w tih|strong="H9999"\w* \w a|strong="H9909"\w* \w tuetang|strong="H2165"\w* \w te|strong="H9997"\w* \w ka\w* \w paek|strong="H5414"\w*.
\p 
\v 7 Te \w dongah|strong="H9999"\w* \w manghai|strong="H4428"\w* \w te|strong="H9997"\w*, “\w Manghai|strong="H4428"\w* \w taengah|strong="H5921"\w* a \w then|strong="H2896"\w* \w mai\w* \w atah|strong="H0518"\w*, \w Tuiva|strong="H5104"\w* \w rhalvangan|strong="H5676"\w* kah \w rhalboei|strong="H6346"\w* rhoek \w ham|strong="H5921"\w* \w kamah|strong="H9901"\w* \w taengah|strong="H9997"\w* \w ca|strong="H0107"\w* m'\w paek|strong="H5414"\w* pah. \w Te|strong="H0834"\w* \w te\w* \w ka|strong="H9901"\w* \w poeng|strong="H5674"\w* tih \w Judah|strong="H3063"\w* \w ah|strong="H0413"\w* \w ka\w* \w pawk|strong="H0935"\w* \w vaengkah|strong="H0834"\w* \w hil|strong="H5704"\w* ham om saeh.
\v 8 \w Khotu|strong="H6508"\w* \w aka\w* \w tawt|strong="H8104"\w* \w Asaph|strong="H0623"\w* \w taengkah|strong="H0413"\w* \w ca|strong="H0107"\w* \w dongah\w* \w manghai|strong="H4428"\w* \w ham|strong="H9997"\w* daek pah lamtah \w im|strong="H1003"\w* \w taengkah|strong="H9997"\w* rhalmah \w im|strong="H1002"\w*, \w vongka|strong="H8179"\w* \w mak|strong="H7136"\w* vaengkah \w ham|strong="H9997"\w* \w khaw\w*, \w khopuei|strong="H5892"\w* \w vongtung|strong="H2346"\w* \w ham|strong="H9997"\w*, \w im|strong="H1003"\w* \w ham|strong="H9997"\w* \w khaw|strong="H9999"\w* \w a|strong="H9909"\w* \w khuiah|strong="H0413"\w* \w ka\w* \w kun|strong="H0935"\w* \w bangla|strong="H0834"\w*, \w kai|strong="H9901"\w* \w taengah|strong="H9997"\w* \w thing|strong="H6086"\w* m'\w pae|strong="H5414"\w* saeh,” ka \w ti|strong="H0559"\w* nah.
