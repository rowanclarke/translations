\v 9 \w Duengnah|strong="G1343"\w* te na \w lungnah|strong="G0025"\w* \w tih|strong="G2532"\w* \w olaeknah|strong="G0458"\w* te na \w hmuhuet|strong="G3404"\w*. \w Te|strong="G5124"\w* \w dongah|strong="G1223"\w* \w Pathen|strong="G2316"\w* \w loh|strong="G3588"\w* \w nang|strong="G4571"\w* n'\w koelh|strong="G5548"\w*. \w Na|strong="G4675"\w* \w Pathen|strong="G2316"\w* \w loh|strong="G3588"\w* \w na|strong="G4675"\w* \w pueipo|strong="G3353"\w* \w lakah|strong="G3844"\w* \w kohoenah|strong="G0020"\w* \w situi|strong="G1637"\w* n'koelh pai.
\v 10 \x - \xo 1.10 \xt Tgt 102. 25-27.\x*Te \w phoeiah|strong="G2532"\w*, a \w cuekca|strong="G0746"\w* \w vaengah|strong="G2596"\w* \w Boeipa|strong="G2963"\w* \w nang|strong="G4771"\w* loh \w diklai|strong="G1093"\w* na \w tong|strong="G2311"\w* \w tih|strong="G2532"\w* \w vaan|strong="G3772"\w* \w te|strong="G3588"\w* \w namah|strong="G4675"\w* \w kah|strong="G3588"\w* \w kutngo|strong="G2041,G5495"\w* \w ni|strong="G1526"\w*.
\v 11 \w Amih|strong="G0846"\w* tah \w poci|strong="G0622"\w* \w vetih|strong="G2532"\w* \w himbai|strong="G2440"\w* \w bangla|strong="G5613"\w* \w boeih|strong="G3956"\w* \w rhuem|strong="G3822"\w* ni. \w Tedae|strong="G1161"\w* \w nang|strong="G4771"\w* tah na \w nguel|strong="G1265"\w* ni.
