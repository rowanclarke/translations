\p
\v 39 “‘\w As|strong="H1004"\w* \w for|strong="H8034"\w* \w you|strong="H3808"\w*, \w O|strong="H3068"\w* \w house|strong="H1004"\w* \w of|strong="H1004"\w* \w Israel|strong="H3478"\w*, \w this|strong="H3541"\w* \w is|strong="H8034"\w* \w what|strong="H3541"\w* \w the|strong="H8085"\w* sovereign \nd \+w Lord|strong="H3069"\+w*\nd* \w says|strong="H3541"\w*: \w Each|strong="H3541"\w* \w of|strong="H1004"\w* \w you|strong="H3808"\w* \w go|strong="H3212"\w* \w and|strong="H3478"\w* \w serve|strong="H5647"\w* \w your|strong="H8085"\w* \w idols|strong="H1544"\w*, if \w you|strong="H3808"\w* \w will|strong="H3478"\w* \w not|strong="H3808"\w* \w listen|strong="H8085"\w* \w to|strong="H3478"\w* \w me|strong="H3808"\w*. \w But|strong="H3808"\w* \w my|strong="H8085"\w* \w holy|strong="H6944"\w* \w name|strong="H8034"\w* \w will|strong="H3478"\w* \w not|strong="H3808"\w* \w be|strong="H5750"\w* \w profaned|strong="H2490"\w* \w again|strong="H5750"\w* \w by|strong="H3478"\w* \w your|strong="H8085"\w* \w sacrifices|strong="H6944"\w* \w and|strong="H3478"\w* \w your|strong="H8085"\w* \w idols|strong="H1544"\w*.  
\v 40  \w For|strong="H3588"\w* \w there|strong="H8033"\w* \w on|strong="H1004"\w* \w my|strong="H3605"\w* \w holy|strong="H6944"\w* \w mountain|strong="H2022"\w*, \w the|strong="H3605"\w* \w high|strong="H4791"\w* \w mountain|strong="H2022"\w* \w of|strong="H1004"\w* \w Israel|strong="H3478"\w*, \w declares|strong="H5002"\w* \w the|strong="H3605"\w* sovereign \nd \+w Lord|strong="H3069"\+w*\nd*, \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w house|strong="H1004"\w* \w of|strong="H1004"\w* \w Israel|strong="H3478"\w* \w will|strong="H3478"\w* \w serve|strong="H5647"\w* \w me|strong="H1875"\w*, \w all|strong="H3605"\w* \w of|strong="H1004"\w* \w them|strong="H3588"\w* \w in|strong="H3478"\w* \w the|strong="H3605"\w* land. \w I|strong="H3588"\w* \w will|strong="H3478"\w* \w accept|strong="H7521"\w* \w them|strong="H3588"\w* \w there|strong="H8033"\w*, \w and|strong="H3478"\w* \w there|strong="H8033"\w* \w I|strong="H3588"\w* \w will|strong="H3478"\w* \w seek|strong="H1875"\w* \w your|strong="H3605"\w* \w contributions|strong="H8641"\w* \w and|strong="H3478"\w* \w your|strong="H3605"\w* \w choice|strong="H7225"\w* \w gifts|strong="H4864"\w*, \w with|strong="H1004"\w* \w all|strong="H3605"\w* \w your|strong="H3605"\w* \w holy|strong="H6944"\w* \w things|strong="H6944"\w*.  
\v 41  \w When|strong="H3318"\w* \w I|strong="H4480"\w* \w bring|strong="H3318"\w* \w you|strong="H4480"\w* \w out|strong="H3318"\w* \w from|strong="H4480"\w* \w the|strong="H4480"\w* \w nations|strong="H1471"\w* \w and|strong="H5971"\w* \w gather|strong="H6908"\w* \w you|strong="H4480"\w* \w from|strong="H4480"\w* \w the|strong="H4480"\w* lands \w where|strong="H4480"\w* \w you|strong="H4480"\w* \w are|strong="H5971"\w* \w scattered|strong="H6327"\w*, \w I|strong="H4480"\w* \w will|strong="H1471"\w* \w accept|strong="H7521"\w* \w you|strong="H4480"\w* along \w with|strong="H3318"\w* \w your|strong="H4480"\w* \w soothing|strong="H5207"\w* \w aroma|strong="H7381"\w*. \w I|strong="H4480"\w* \w will|strong="H1471"\w* display \w my|strong="H3318"\w* \w holiness|strong="H6942"\w* \w among|strong="H4480"\w* \w you|strong="H4480"\w* \w in|strong="H5971"\w* \w the|strong="H4480"\w* \w sight|strong="H5869"\w* \w of|strong="H5869"\w* \w the|strong="H4480"\w* \w nations|strong="H1471"\w*.  
\v 42  \w Then|strong="H5375"\w* \w you|strong="H5414"\w* \w will|strong="H3068"\w* \w know|strong="H3045"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w the|strong="H3588"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w when|strong="H3588"\w* \w I|strong="H3588"\w* \w bring|strong="H5375"\w* \w you|strong="H5414"\w* \w to|strong="H3478"\w* \w the|strong="H3588"\w* land \w of|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w to|strong="H3478"\w* \w the|strong="H3588"\w* land \w I|strong="H3588"\w* \w swore|strong="H5375"\w* \w to|strong="H3478"\w* \w give|strong="H5414"\w* \w to|strong="H3478"\w* \w your|strong="H3068"\w* fathers.  
\v 43  \w And|strong="H6440"\w* \w there|strong="H8033"\w* \w you|strong="H6440"\w* \w will|strong="H8033"\w* \w remember|strong="H2142"\w* \w your|strong="H3605"\w* \w conduct|strong="H1870"\w* \w and|strong="H6440"\w* \w all|strong="H3605"\w* \w your|strong="H3605"\w* \w deeds|strong="H5949"\w* \w by|strong="H1870"\w* \w which|strong="H8033"\w* \w you|strong="H6440"\w* \w defiled|strong="H2930"\w* \w yourselves|strong="H2930"\w*. \w You|strong="H6440"\w* \w will|strong="H8033"\w* despise \w yourselves|strong="H2930"\w* \w because|strong="H6440"\w* \w of|strong="H6440"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w evil|strong="H7451"\w* \w deeds|strong="H5949"\w* \w you|strong="H6440"\w* \w have|strong="H3605"\w* \w done|strong="H6213"\w*.  
