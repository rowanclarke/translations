\p
\v 21 \w Then|strong="H2088"\w* \w Isaac|strong="H3327"\w* said, “\w My|strong="H3290"\w* \w son|strong="H1121"\w*, \w come|strong="H5066"\w* \w close|strong="H5066"\w* \w to|strong="H1121"\w* \w me|strong="H4994"\w*, \w so|strong="H3808"\w* \w that|strong="H1121"\w* \w I|strong="H2088"\w* \w can|strong="H3808"\w* \w touch|strong="H5066"\w* \w your|strong="H4994"\w* arms. \w If|strong="H1121"\w* \w your|strong="H4994"\w* arms \w are|strong="H1121"\w* hairy, \w then|strong="H2088"\w* \w I|strong="H2088"\w* \w will|strong="H1121"\w* know \w that|strong="H1121"\w* \w you|strong="H3808"\w* \w really|strong="H2088"\w* \w are|strong="H1121"\w* \w my|strong="H3290"\w* \w son|strong="H1121"\w* \w Esau|strong="H6215"\w*.”   
\p
