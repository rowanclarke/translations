\v 45 \w Tedae|strong="G1161"\w* \w a|strong="G3588"\w* \w caeh|strong="G1831"\w* neh a \w tong|strong="G0756"\w* tih \w pung|strong="G4183"\w* a \w hoe|strong="G2784"\w* \w dongah|strong="G2532"\w* \w ol|strong="G3056"\w* \w te|strong="G3588"\w* \w yilhcet|strong="G1310"\w*. Te \w dongah|strong="G5620"\w* \w Jesuh|strong="G2424"\w* tah \w kho|strong="G4172"\w* \w khuiah|strong="G1519"\w* \w loloh|strong="G5320"\w* \w kun|strong="G1525"\w* \w thai|strong="G1410"\w* voel \w pawh|strong="G3371"\w*. Te \w phoeiah|strong="G0235"\w* tah \w khosoek|strong="G2048"\w* \w hmuen|strong="G5117"\w* \w ah|strong="G1909"\w* \w vawl|strong="G1854"\w* \w om|strong="G2258"\w* \w dae|strong="G2532"\w* \w anih|strong="G0846"\w* \w te|strong="G4314"\w* a \w taengvai|strong="G3840"\w* lamloh a \w paan|strong="G2064"\w* uh.   
\c 2  
\s1 Hlang Tlo Khaw Hoeih  
\p
\v 1 \w Khohnin|strong="G2250"\w* a di \w phoeiah|strong="G1223"\w* \w Kapernaum|strong="G2584"\w* \w la|strong="G1519"\w* \w koep|strong="G3825"\w* \w kun|strong="G1525"\w* \w tih|strong="G2532"\w* \w im|strong="G3624"\w* \w ah|strong="G1722"\w* \w om|strong="G2076"\w* \w tila|strong="G3754"\w* a \w yaak|strong="G0191"\w*.  
\v 2 Te \w dongah|strong="G2532"\w* \w muep|strong="G4183"\w* \w tingtun|strong="G4863"\w* uh \w tih|strong="G5620"\w* \w thohka|strong="G2374"\w* \w pataeng|strong="G3366"\w* \w te|strong="G3588"\w* \w hoeng|strong="G5562"\w* \w pawh|strong="G3371"\w*. Te \w vaengah|strong="G2532"\w* \w amih|strong="G0846"\w* ham \w ol|strong="G3056"\w* a \w thui|strong="G2980"\w* pah.  
