\v 17 \w He|strong="H3588"\w* \w died|strong="H4191"\w* \w just|strong="H1697"\w* \w as|strong="H1697"\w* \w the|strong="H3588"\w* \nd \w Lord|strong="H3068"\w*\nd* \w had|strong="H3068"\w* \w prophesied|strong="H1696"\w* \w through|strong="H3588"\w* \w Elijah|strong="H1696"\w*. \w In|strong="H8141"\w* \w the|strong="H3588"\w* \w second|strong="H8147"\w* \w year|strong="H8141"\w* \w of|strong="H1121"\w* \w the|strong="H3588"\w* \w reign|strong="H4427"\w* \w of|strong="H1121"\w* \w King|strong="H4428"\w* \w Jehoram|strong="H3088"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jehoshaphat|strong="H3092"\w* \w over|strong="H4427"\w* \w Judah|strong="H3063"\w*, Ahaziah’s brother \w Jehoram|strong="H3088"\w* \w replaced|strong="H8478"\w* \w him|strong="H4427"\w* \w as|strong="H1697"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* Israel, \w because|strong="H3588"\w* \w he|strong="H3588"\w* \w had|strong="H3068"\w* \w no|strong="H3808"\w* \w son|strong="H1121"\w*.
