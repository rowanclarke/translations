\s1 The \nd Lord\nd* Commissions Joshua
\p 
\v 1 \w After|strong="H1961"\w* \w Moses|strong="H4872"\w* \w the|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd*’s \w servant|strong="H5650"\w* \w died|strong="H4194"\w*, \w the|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd* said \w to|strong="H3068"\w* \w Joshua|strong="H3091"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Nun|strong="H5126"\w*, \w Moses|strong="H4872"\w*’ \w assistant|strong="H8334"\w*:
\v 2 “\w Moses|strong="H4872"\w* \w my|strong="H5414"\w* \w servant|strong="H5650"\w* \w is|strong="H2088"\w* \w dead|strong="H4191"\w*. \w Get|strong="H6965"\w* \w ready|strong="H6258"\w*! \w Cross|strong="H5674"\w* \w the|strong="H3605"\w* \w Jordan|strong="H3383"\w* River! Lead \w these|strong="H2088"\w* \w people|strong="H5971"\w* \w into|strong="H5414"\w* \w the|strong="H3605"\w* land \w which|strong="H5971"\w* \w I|strong="H5414"\w* am \w ready|strong="H6258"\w* \w to|strong="H3478"\w* \w hand|strong="H5414"\w* \w over|strong="H5674"\w* \w to|strong="H3478"\w* \w them|strong="H5414"\w*.
\v 3 \w I|strong="H5414"\w* am handing \w over|strong="H5414"\w* \w to|strong="H1696"\w* \w you|strong="H5414"\w* \w every|strong="H3605"\w* \w place|strong="H4725"\w* \w you|strong="H5414"\w* \w set|strong="H5414"\w* \w foot|strong="H7272"\w*, \w as|strong="H7272"\w* \w I|strong="H5414"\w* \w promised|strong="H1696"\w* \w Moses|strong="H4872"\w*.
\v 4 \w Your|strong="H3605"\w* \w territory|strong="H1366"\w* \w will|strong="H1961"\w* \w extend|strong="H1961"\w* \w from|strong="H5704"\w* \w the|strong="H3605"\w* \w wilderness|strong="H4057"\w* \w in|strong="H1419"\w* \w the|strong="H3605"\w* \w south|strong="H3220"\w* \w to|strong="H5704"\w* \w Lebanon|strong="H3844"\w* \w in|strong="H1419"\w* \w the|strong="H3605"\w* north. \w It|strong="H1961"\w* \w will|strong="H1961"\w* \w extend|strong="H1961"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w way|strong="H2088"\w* \w to|strong="H5704"\w* \w the|strong="H3605"\w* \w great|strong="H1419"\w* \w River|strong="H5104"\w* \w Euphrates|strong="H6578"\w* \w in|strong="H1419"\w* \w the|strong="H3605"\w* \w east|strong="H8121"\w* (\w including|strong="H5704"\w* \w all|strong="H3605"\w* \w of|strong="H1366"\w* Syria) \w and|strong="H1419"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w way|strong="H2088"\w* \w to|strong="H5704"\w* \w the|strong="H3605"\w* Mediterranean \w Sea|strong="H3220"\w* \w in|strong="H1419"\w* \w the|strong="H3605"\w* \w west|strong="H3220"\w*.
\v 5 \w No|strong="H3808"\w* \w one|strong="H3605"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* able \w to|strong="H1961"\w* resist \w you|strong="H6440"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w days|strong="H3117"\w* \w of|strong="H3117"\w* \w your|strong="H3605"\w* \w life|strong="H2416"\w*. \w As|strong="H3117"\w* \w I|strong="H3117"\w* \w was|strong="H1961"\w* \w with|strong="H5973"\w* \w Moses|strong="H4872"\w*, \w so|strong="H1961"\w* \w I|strong="H3117"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w with|strong="H5973"\w* \w you|strong="H6440"\w*. \w I|strong="H3117"\w* \w will|strong="H1961"\w* \w not|strong="H3808"\w* \w abandon|strong="H5800"\w* \w you|strong="H6440"\w* \w or|strong="H3808"\w* \w leave|strong="H5800"\w* \w you|strong="H6440"\w* \w alone|strong="H7503"\w*.
\v 6 \w Be|strong="H5414"\w* \w strong|strong="H2388"\w* \w and|strong="H5971"\w* brave! \w You|strong="H5414"\w* must lead \w these|strong="H2088"\w* \w people|strong="H5971"\w* \w in|strong="H5414"\w* \w the|strong="H3588"\w* conquest \w of|strong="H5971"\w* \w this|strong="H2088"\w* land \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w solemnly|strong="H7650"\w* \w promised|strong="H7650"\w* \w their|strong="H5414"\w* ancestors \w I|strong="H3588"\w* \w would|strong="H5971"\w* \w hand|strong="H5414"\w* \w over|strong="H5414"\w* \w to|strong="H5414"\w* \w them|strong="H5414"\w*.
\v 7 \w Make|strong="H6213"\w* \w sure|strong="H2388"\w* \w you|strong="H6680"\w* \w are|strong="H5650"\w* \w very|strong="H3966"\w* \w strong|strong="H2388"\w* \w and|strong="H4872"\w* brave! \w Carefully|strong="H6213"\w* \w obey|strong="H6213"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w law|strong="H8451"\w* \w my|strong="H8104"\w* \w servant|strong="H5650"\w* \w Moses|strong="H4872"\w* \w charged|strong="H6680"\w* \w you|strong="H6680"\w* \w to|strong="H3212"\w* \w keep|strong="H8104"\w*! \w Do|strong="H6213"\w* \w not|strong="H6213"\w* \w swerve|strong="H5493"\w* \w from|strong="H4480"\w* \w it|strong="H6213"\w* \w to|strong="H3212"\w* \w the|strong="H3605"\w* \w right|strong="H3225"\w* \w or|strong="H4480"\w* \w to|strong="H3212"\w* \w the|strong="H3605"\w* \w left|strong="H8040"\w*, \w so|strong="H4616"\w* \w that|strong="H3605"\w* \w you|strong="H6680"\w* \w may|strong="H6213"\w* \w be|strong="H5650"\w* \w successful|strong="H7919"\w* \w in|strong="H6213"\w* \w all|strong="H3605"\w* \w you|strong="H6680"\w* \w do|strong="H6213"\w*.
\v 8 \w This|strong="H2088"\w* \w law|strong="H8451"\w* \w scroll|strong="H5612"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w leave|strong="H4185"\w* \w your|strong="H3605"\w* \w lips|strong="H6310"\w*! \w You|strong="H3588"\w* \w must|strong="H3808"\w* memorize \w it|strong="H6213"\w* \w day|strong="H3119"\w* \w and|strong="H3119"\w* \w night|strong="H3915"\w* \w so|strong="H4616"\w* \w you|strong="H3588"\w* \w can|strong="H6213"\w* \w carefully|strong="H6213"\w* \w obey|strong="H6213"\w* \w all|strong="H3605"\w* \w that|strong="H3588"\w* \w is|strong="H2088"\w* \w written|strong="H3789"\w* \w in|strong="H6213"\w* \w it|strong="H6213"\w*. \w Then|strong="H2088"\w* \w you|strong="H3588"\w* \w will|strong="H3808"\w* \w prosper|strong="H6743"\w* \w and|strong="H3119"\w* \w be|strong="H3808"\w* \w successful|strong="H6743"\w*.
\v 9 \w I|strong="H3588"\w* repeat, \w be|strong="H3808"\w* \w strong|strong="H2388"\w* \w and|strong="H3068"\w* brave! Don’t \w be|strong="H3808"\w* \w afraid|strong="H2865"\w* \w and|strong="H3068"\w* don’t \w panic|strong="H2865"\w*, \w for|strong="H3588"\w* \w I|strong="H3588"\w*, \w the|strong="H3605"\w* \nd \w Lord|strong="H3068"\w*\nd* \w your|strong="H3068"\w* \w God|strong="H3068"\w*, \w am|strong="H3068"\w* \w with|strong="H5973"\w* \w you|strong="H3588"\w* \w in|strong="H3068"\w* \w all|strong="H3605"\w* \w you|strong="H3588"\w* \w do|strong="H3068"\w*.”
\s1 Joshua Prepares for the Invasion
\p 
\v 10 \w Joshua|strong="H3091"\w* \w instructed|strong="H6680"\w* \w the|strong="H6680"\w* leaders \w of|strong="H5971"\w* \w the|strong="H6680"\w* \w people|strong="H5971"\w*:
\v 11 “\w Go|strong="H5674"\w* \w through|strong="H5674"\w* \w the|strong="H3588"\w* \w camp|strong="H4264"\w* \w and|strong="H3068"\w* \w command|strong="H6680"\w* \w the|strong="H3588"\w* \w people|strong="H5971"\w*, ‘\w Prepare|strong="H3559"\w* \w your|strong="H3068"\w* \w supplies|strong="H6720"\w*, \w for|strong="H3588"\w* \w within|strong="H7130"\w* \w three|strong="H7969"\w* \w days|strong="H3117"\w* \w you|strong="H3588"\w* \w will|strong="H3068"\w* \w cross|strong="H5674"\w* \w the|strong="H3588"\w* \w Jordan|strong="H3383"\w* \w River|strong="H3588"\w* \w and|strong="H3068"\w* begin \w the|strong="H3588"\w* conquest \w of|strong="H3068"\w* \w the|strong="H3588"\w* \w land|strong="H7130"\w* \w the|strong="H3588"\w* \nd \w Lord|strong="H3068"\w*\nd* \w your|strong="H3068"\w* \w God|strong="H3068"\w* \w is|strong="H3068"\w* \w ready|strong="H3559"\w* \w to|strong="H3068"\w* \w hand|strong="H5414"\w* \w over|strong="H5674"\w* \w to|strong="H3068"\w* \w you|strong="H3588"\w*.’”
\p 
\v 12 \w Joshua|strong="H3091"\w* told \w the|strong="H3091"\w* \w Reubenites|strong="H7206"\w*, \w Gadites|strong="H1425"\w*, \w and|strong="H3091"\w* \w the|strong="H3091"\w* \w half|strong="H2677"\w* \w tribe|strong="H7626"\w* \w of|strong="H7626"\w* \w Manasseh|strong="H4519"\w*:
\v 13 “\w Remember|strong="H2142"\w* \w what|strong="H1697"\w* \w Moses|strong="H4872"\w* \w the|strong="H5414"\w* \nd \w Lord|strong="H3068"\w*\nd*’s \w servant|strong="H5650"\w* \w commanded|strong="H6680"\w* \w you|strong="H5414"\w*. \w The|strong="H5414"\w* \nd \w Lord|strong="H3068"\w*\nd* \w your|strong="H3068"\w* \w God|strong="H3068"\w* \w is|strong="H3068"\w* \w giving|strong="H5414"\w* \w you|strong="H5414"\w* \w a|strong="H3068"\w* \w place|strong="H5414"\w* \w to|strong="H3068"\w* \w settle|strong="H5117"\w* \w and|strong="H4872"\w* \w is|strong="H3068"\w* handing \w this|strong="H2063"\w* land \w over|strong="H5414"\w* \w to|strong="H3068"\w* \w you|strong="H5414"\w*.
