\id NAM - Biblica® Open Kurdi Sorani Standard Version
\h ناحوم
\toc1 ناحوم
\toc2 ناحوم
\toc3 ناحوم
\mt1 ناحوم
\c 1
\p 
\v 1 سروشێک\f + \fr 1:1 \ft فەرموودەیەکی خودایە کە لە ڕێگای ڕۆحی پیرۆزەوە بۆ مرۆڤ هاتبێت.‏\f* سەبارەت بە نەینەوا، پەڕتووکی بینینەکەی ناحومی ئەلقۆشی:
\s1 تووڕەیی خودا لە دژی نەینەوا
\q1 
\v 2 یەزدان خودایەکی ئیرەدار\f + \fr 1:2 \ft ئیرەدار: لێرەدا واتایەکی ئەرێنی لەخۆ دەگرێت، چونکە خودا مرۆڤی خۆشدەوێت و نایەوێت کەسێک پەیوەندی نێوانیان تێک بدات.\f* و تۆڵەسێنەرە،
\q2 یەزدان تۆڵەسێنەر و زۆر تووڕەیە.
\q1 یەزدان تۆڵەسێنەرە لە ناحەزانی و
\q2 هەڵچوونی لە دژی دوژمنانی بەردەوامە.
\q1 
\v 3 یەزدان پشوودرێژە و توانای مەزنە،
\q2 بەڵام چاو لە گوناه ناپۆشێت.
\q1 ڕێگای یەزدان لەناو گەردەلوول و ڕەشەبادایە،
\q2 هەور تۆزی پێیەکانیەتی.
\q1 
\v 4 دەریا سەرزەنشت دەکات و وشکی دەکات،
\q2 هەموو ڕووبارەکان بێ ئاو دەکات.
\q1 باشان و کارمەل سیس دەکات،
\q2 خونچەی لوبنان سیس دەبێت.
\q1 
\v 5 چیاکان لەبەر ئەو دەلەرزن و
\q2 گردەکان دەتوێنەوە.
\q1 زەوی لە ئامادەبوونی ئەو دەهەژێت،
\q2 جیهان و هەموو دانیشتووانەکەی.
\q1 
\v 6 کێ لەبەردەم تووڕەیی ئەو خۆی ڕادەگرێت؟
\q2 کێ بەرگەی جۆشی تووڕەیی ئەو دەگرێت؟
\q1 هەڵچوونی وەک ئاگر دەڕژێت و
\q2 تاشەبەردەکان لەبەردەمی دەشکێن.
\b
\q1 
\v 7 یەزدان چاکە،
\q2 لە ڕۆژی تەنگانە قەڵایە.
\q1 بایەخ بەوانە دەدات کە پشتی پێ دەبەستن،
\q2 
\v 8 بەڵام بە تۆفانێکی گەورە
\q1 بە تەواوی کۆتایی بە نەینەوا دەهێنێت،
\q2 دوژمنەکانی بەرەو تاریکی ڕاودەنێت.
\b
\q1 
\v 9 بیر لە چی دەکەنەوە لە دژی یەزدان؟
\q2 ئەو کۆتایی پێدەهێنێت،
\q2 کارەسات دوو جار بەرپا نابێت.
\q1 
\v 10 ئەوان وەک دڕک لێک دەئاڵێن،
\q2 بە شەرابەکەیان سەرخۆش دەبن،
\q2 هەموویان وەک کای وشک دەسووتێن.
\q1 
\v 11 ئەی نەینەوا، یەکێک لە تۆوە دەردەکەوێت،
\q2 ئەوەی بیر لە خراپە دەکاتەوە لە دژی یەزدان،
\q2 ڕاوێژکاری بەدکارییە.
\p 
\v 12 یەزدان ئەمە دەفەرموێت:
\q1 «هەرچەندە بەهێز و زۆریشن،
\q2 بەڵام دەبڕێنەوە و بەسەردەچن.
\q1 ئەی یەهودا، هەرچەندە زەلیلم کردیت
\q2 بەڵام ئیتر زەلیلت ناکەم.
\q1 
\v 13 ئێستاش ئەو نیرەی\f + \fr 1:13 \ft مەبەستی لە بارگرانییە.‏\f* کە لەسەر تۆی دایانناوە دەیشکێنم،
\q2 کۆتەکانت لێ دەکەمەوە.»
\b
\q1 
\v 14 ئەی نەینەوا، یەزدان سەبارەت بە تۆ فەرمانی داوە:
\q2 «هیچ نەوەیەک نامێنێت ناوی تۆی هەڵگرتبێت.
\q1 بتە داتاشراو و لەقاڵبدراوەکان
\q2 لە پەرستگای خوداوەندەکانت ڕیشەکێش دەکەم.
\q2 گۆڕت بۆ هەڵدەکەنم، چونکە تۆ شایانی ژیان نیت.»
\b
\q1 
\v 15 ئەوەتا لەسەر چیاکانە
\q2 پێیەکانی مزگێنیدەر،
\q2 ئاشتی ڕادەگەیەنێت!
\q1 ئەی یەهودا، جەژنەکانت بگێڕە،
\q2 نەزرەکانت\f + \fr 1:15 \ft نەزر: داوا لە خودا دەکرێت بۆ ئەنجامدانی کارێک و پابەند دەکرێت بە مەرجێکەوە. ئەگەر خودا ئەو کارە بکات، ئەوا دەرئەنجام ئەمیش ئەو کارە ئەنجام دەدات کە پێیەوە پابەندی کردووە. بڕوانە \xt سەرژمێری 21‏:2‏\xt*\ft ‏.‏\f* بەجێبهێنە،
\q1 ئیتر بەدکاران داگیرت ناکەن،
\q2 بەڵکو بە تەواوی بنبڕ دەبن.
\c 2
\s1 پاشایەتی نەینەوا دەڕووخێنرێت
\q1 
\v 1 ئەی نەینەوا، پەلاماردەر لە دژی تۆ هات.
\q2 قەڵاکە بپارێزە،
\q2 چاودێری ڕێگاکە بکە،
\q2 بازووی لێ هەڵبکە،
\q2 توانای زۆر بخەرە گەڕ!
\b
\q1 
\v 2 یەزدان سەروەری یاقوب دەگەڕێنێتەوە
\q2 وەک سەروەری ئیسرائیل،
\q1 هەرچەندە تاڵانکەران تاڵانیان کردن و
\q2 ڕەزەمێوەکانیان تێکدان.
\b
\q1 
\v 3 قەڵغانی پاڵەوانەکانی ئاڵ هەڵگەڕاون،
\q2 قارەمانەکانی لە بەرگی سووردان،
\q1 لە ڕۆژی خۆ ئامادەکردنیاندا
\q2 پۆڵای گالیسکەکان بریسکە دەداتەوە،
\q2 ئەو ڕمانەی لە دار سنەوبەر دروستکراون دەلەرنەوە.
\q1 
\v 4 گالیسکەکان لە شەقامەکان تیژڕەون،
\q2 لە گۆڕەپانەکان سەرەڕۆن.
\q1 دیمەنیان وەک مەشخەڵە،
\q2 وەک بروسک غار دەدەن.
\b
\q1 
\v 5 نەینەوا پاڵەوانەکانی بانگ دەکات،
\q2 بەڵام ساتمە دەکەن و لە ڕۆیشتنیاندا دەکەون.
\q1 پەلە دەکەن بۆ لای شووراکانی و
\q2 قەڵغانەکان ئامادە کراون.
\q1 
\v 6 دەروازەکانی ڕووبار دەکرێنەوە و
\q2 کۆشکەکە دەڕمێت.
\q1 
\v 7 بە فەرمانی خودا بە دیل دەگیرێت و
\q2 ڕاپێچ دەکرێت.
\q1 کەنیزەکانی هەروەک کۆتر دەگمێنن،
\q2 سنگیان دەکوتن.
\q1 
\v 8 نەینەوا وەک حەوزێکی وشکبووە.
\q2 هاوار دەکەن، «ڕاوەستن! ڕاوەستن!»
\q2 بەڵام کەس ئاوڕ ناداتەوە.
\q1 
\v 9 «زیو تاڵان بکەن!
\q2 زێڕ تاڵان بکەن!
\q1 گەنجینەکانی لەبن نایەن،
\q2 پڕە لە گەوهەری بەهادار.»
\q1 
\v 10 چۆڵ و تاڵانکراو و داماڵراوە،
\q2 دڵ دەتوێتەوە و ئەژنۆکان شلن،
\q2 هەموویان دەلەرزن، ڕەنگیان دەپەڕێت.
\b
\q1 
\v 11 کوا لانەی شێرەکان،
\q2 لەوەڕگای بەچکە شێران؟
\q1 لەوێدا شێر و شێرە مێ دەگەڕان
\q2 لەگەڵ بەچکە شێر، هیچ شتێک نەیدەترساندن.
\q1 
\v 12 شێر بۆ پێویستی بەچکەکانی پەلاماری دەدا و
\q2 نێچیرەکەی بۆ شێرە مێیەکەی دەخنکاند،
\q1 ئەشکەوتەکەی پڕ دەکرد لە نێچیر،
\q2 لانەکانیشی لەوانەی پەلاماری داون.
\b
\q1 
\v 13 یەزدانی سوپاسالار دەفەرموێت:
\q2 «من لە دژی تۆم.
\q1 گالیسکەکانت دەسووتێنم و دەبنە دووکەڵ،
\q2 بەچکە شێرەکانیشت شمشێر دەیانخوات و
\q1 نێچیرت لەسەر زەوی لێ دەبڕم.
\q2 ئیتر دەنگی نێردراوەکانت نابیسترێن.»
\c 3
\s1 قوڕبەسەر نەینەوا
\q1 
\v 1 ئەی شاری خوێن، قوڕبەسەرت،
\q2 سەراپای درۆیە،
\q1 پڕ لە تاڵانە،
\q2 نێچیری لێ نابڕێت!
\q1 
\v 2 شریقەی قامچی،
\q2 خشەخشی چەرخ،
\q1 غاردانی ئەسپ و
\q2 هەڵبەزینی گالیسکە!
\q1 
\v 3 سوارەکان پێشدەکەون،
\q2 بڵێسەی شمشێر و
\q2 بروسکەی ڕم!
\q1 زۆری برینداران و
\q2 زۆری کوژراوان،
\q1 تەرمی بێشومار،
\q2 خەڵکی ساتمە لە تەرمەکان دەکەن.
\q1 
\v 4 هەموو ئەمانە لەبەر زۆری داوێنپیسی لەشفرۆشەکەیە،
\q2 ڕوخسار جوان و جادووگەرە گەورەکە،
\q1 ئەوەی بە داوێنپیسییەکەی نەتەوەکانی کردە کۆیلە،
\q2 بە جادووگەرییەکەی خێڵەکان.
\b
\q1 
\v 5 یەزدانی سوپاسالار دەفەرموێت: «من لە دژی تۆم.
\q2 دامێنت هەڵدەبڕم بۆ سەر ڕووت،
\q1 ڕووتیت پیشانی نەتەوەکان دەدەم و
\q2 پاشایەتییەکانیش شەرمەزاریت دەبینن.
\q1 
\v 6 پیسایی فڕێدەدەمە سەرت،
\q2 ڕیسوات دەکەم و
\q2 دەتکەمە دیمەنێکی گاڵتەجاڕی.
\q1 
\v 7 جا هەرکەسێک بتبینێت لێت ڕادەکات و دەڵێت:
\q2 ”نەینەوا کاول بوو، کێ بۆی دەگریێت؟“
\q2 لەکوێ کەسێک ببینمەوە دڵنەواییت بکات؟»
\b
\q1 
\v 8 ئایا لە شاری تیب چاکتریت،
\q2 دانیشتووی سەر نیل،
\q2 ئاو چواردەوری دابوو؟
\q1 ئەوەی ڕووبارەکە دەیپاراست،
\q2 ئاوەکان شوورای بوون.
\q1 
\v 9 کوش\f + \fr 3:9 \ft وڵاتێک بووە لە سەرووی ڕووباری نیل.‏\f* و میسر هێزی لە ڕادەبەدەری بوون،
\q1 پووت و لیبییەکان هاوپەیمانی بوون.
\q1 
\v 10 بەڵام ئەو بە دیل گیرا و
\q2 ڕاپێچ کرا،
\q1 منداڵەکانی پارچەپارچە کران
\q2 لەسەر سووچی هەموو شەقامێک.
\q1 لەسەر پیاوماقوڵانی تیروپشک کرا و
\q2 هەموو گەورە پیاوانی کۆت و زنجیر کران.
\q1 
\v 11 هەروەها تۆش سەرخۆش دەبیت،
\q2 خۆت دەشاریتەوە و
\q2 لە پەنایەک دەگەڕێیت لە دەستی دوژمن.
\b
\q1 
\v 12 هەموو قەڵاکانت وەک داری هەنجیرن
\q2 بە یەکەم بەرەوە،
\q1 کە بتەکێن بەردەبنەوە
\q2 بۆ ناو دەمی ئەو کەسەی دەیخوات.
\q1 
\v 13 تەماشای سەربازەکانت بکە،
\q2 هەموویان وەک ژنن!
\q1 دەروازەکانی خاکەکەت
\q2 بۆ دوژمنانت دەخرێنە سەر پشت،
\q2 ئاگر شمشیرەی\f + \fr 3:13 \ft شمشیر، پارچە دارێک بووە لە جیاتی قوفڵ لە دواوەی دەرگا بە شێوەی ئاسۆیی دانراوە بۆ داخستنی دەرگا.‏\f* دەروازەکانت هەڵدەلووشێت.
\b
\q1 
\v 14 ئاو بکێشەوە بۆ کاتی گەمارۆدراویت،
\q2 قەڵاکانت بەهێز بکە!
\q1 بڕۆ ناو قوڕەوە،
\q2 قوڕ بشێلە و
\q2 خشتبڕەکانت توندوتۆڵ بکە!
\q1 
\v 15 لەوێدا ئاگر دەتخوات،
\q2 شمشێر دەتبڕێت و
\q2 وەک پۆلە کوللە دەتخوات.
\q1 وەک پۆلە کوللە زیادبە،
\q2 زیادبە وەک پێکوڕە!
\q1 
\v 16 بازرگانەکانی خۆت
\q2 لە ئەستێرەکانی ئاسمان زۆرتر کرد،
\q1 بەڵام وەک کوللە خاکەکە ڕووت دەکەنەوە و دەفڕن.
\q1 
\v 17 پاسەوانەکانت وەک کوللەن،
\q2 ئەفسەرەکانت وەک ڕەوە کوللەن،
\q2 کە لە ڕۆژێکی سارد لەسەر دیوار هەڵنیشتوون،
\q1 بەڵام کە خۆر هەڵهات دەفڕن،
\q2 کەس نازانێ بەرەو کوێ چوون.
\b
\q1 
\v 18 ئەی پاشای ئاشور، شوانەکانت خەوتن،
\q2 گەورە پیاوانت پاڵکەوتن پشوو بدەن.
\q1 گەلەکەت لەسەر چیاکان پەرتەوازە بوون،
\q2 کەس نییە کۆیان بکاتەوە.
\q1 
\v 19 شکانەکەت ناگیرێتەوە،
\q2 برینەکەت ساڕێژ نابێت.
\q1 هەموو ئەوانەی هەواڵی تۆ دەبیستن
\q2 لە خۆشیدا چەپڵە لێ دەدەن،
\q1 چونکە کێ نەیچێشتووە
\q2 خراپەی بەردەوامی تۆ؟
