\id SNG - Biblica® Open New Serbian Translation Cyrillic 2017
\h Песма над песмама
\toc1 Песма над песмама
\toc2 Песма над песмама
\toc3 Пес
\mt1 Песма над песмама
\c 1
\p 
\v 1 Соломонова песма над песмама.
\sp Она
\q1 
\v 2 Пољупцем усана својих ме пољуби,
\q2 јер је твоја љубав боља од вина.
\q1 
\v 3 Мирис је твоје помасти диван,
\q2 име је твоје као уље изливено
\q2 и зато те воле девојке.
\q1 
\v 4 Поведи ме са собом, побегнимо!
\q2 Нек ме цар уведе у одаје своје.
\sp Пријатељице
\q1 Радоваћемо се и уживаћемо у теби.
\q2 Славићемо твоју љубав више него вино.
\sp Она
\q1 Добро је што те оне воле.
\b
\q1 
\v 5 Тамнопута сам али љупка,
\q2 ћерке јерусалимске,
\q1 као шатори кедарски,
\q2 као крила Соломонових шатора.
\q1 
\v 6 Не гледајте ме што сам тамнопута,
\q2 јер ме је сунце опалило.
\q1 Моја су браћа љута на мене.
\q2 Поставили су ме да винограде чувам,
\q2 а ја свој сопствени виноград сачувала нисам.
\q1 
\v 7 Кажи ми, ти кога душа моја воли,
\q2 где ти стадо пасе
\q2 и где ти у подне пландује?
\q1 Зашто да се велом покривам\f + \fr 1,7 \ft Са неким мањим изменама изворног текста, овај део стиха може да се преведе: \fqa Зашто да тумарам…\f*
\q2 међу стадима пријатеља твојих?
\sp Пријатељице
\q1 
\v 8 Ако не знаш, о, најлепша међу женама,
\q2 иди по трагу стада
\q1 па напасај козлиће своје
\q2 крај пастирских коначишта.
\sp Он
\q1 
\v 9 О, вољена моја, ти си као моја ждребица
\q2 међу фараоновим упрегнутим ждрепцима!
\q1 
\v 10 Лепи су ти образи окићени ланчићима,
\q2 а на врату ти огрлице.
\q1 
\v 11 Сковаћемо ти наруквице златне
\q2 и украсити сребром.
\sp Она
\q1 
\v 12 Док је цар за столом својим,
\q2 мирисом својим мој нард одаје.
\q1 
\v 13 Смотуљак смирне што ноћи међ’ грудима мојим,
\q2 то је мени мој вољени.
\q1 
\v 14 Струк кане у цвату из винограда Ен-Гедија,
\q2 то је мени мој вољени.
\sp Он
\q1 
\v 15 Како ли си лепа, о, вољена моја!
\q2 Лепа си, а очи су ти голубице.
\sp Она
\q1 
\v 16 Како си згодан, о, вољени мој, и мио!
\q2 Ево, постеља је наша бујна трава.
\sp Он
\q1 
\v 17 Кедрови су греде куће наше,
\q2 а чемпреси рогови крова.
\c 2
\sp Она
\q1 
\v 1 Ја сам шафран са Сарона
\q2 и љиљан из долина.
\sp Он
\q1 
\v 2 Какав је љиљан међу трњем,
\q2 таква је вољена моја међу девојкама.
\sp Она
\q1 
\v 3 Као стабло јабуке међу шумским дрвећем,
\q2 такав је вољени мој међу момцима.
\q1 За хладом његовим чезнем, да седнем,
\q2 да плодом његовим осладим непце своје.
\q1 
\v 4 Унео ме је у кућу вина,
\q2 љубав је његова застава нада мном.
\q1 
\v 5 Крепите ме сувим грожђем,
\q2 јабукама ме освежите,
\q2 јер сам од љубави клонула.
\q1 
\v 6 Левица му је под главом мојом,
\q2 а десницом ме грли.
\q1 
\v 7 Ћерке јерусалимске, заклињем вас
\q2 ланадима и кошутама пољским,
\q1 не будите и не дижите моју љубав
\q2 док јој се не прохте.
\b
\q1 
\v 8 Чуј гласа вољеног мога!
\q2 Ево, долази,
\q1 поскакује по брдима
\q2 и горе прескаче.
\q1 
\v 9 Као газела и као срндаћ мој је вољени.
\q2 Гле, ено га стоји иза нашег зида,
\q1 провирује са прозора,
\q2 кроз решетке гледа.
\q1 
\v 10 А мој вољени ми одговори, рече ми:
\q2 „Устани, вољена моја,
\q2 дођи, најлепша моја!
\q1 
\v 11 Ево, зима је прошла
\q2 и киша умину, прође.
\q1 
\v 12 Земља је процветала,
\q2 стиже време орезивања\f + \fr 2,12 \ft Или: \fqa певања\ft , што је одлика игре једнакозвучних речи.\f*,
\q1 по нашој се земљи
\q2 чује цвркут грлице.
\q1 
\v 13 Плодови рани пупе на смоквином стаблу,
\q2 виногради цвату и мирисом одишу.
\q1 Устани и дођи,
\q2 о, вољена моја, дођи!“
\sp Он
\q1 
\v 14 Голубице моја у раселини стене,
\q2 заклоњена у врлети.
\q1 Дај ми да ти видим лице!
\q2 Дај ми гласа да ти чујем,
\q1 јер је глас твој меден
\q2 и лице је твоје љупко.
\q1 
\v 15 Лисице нам похватајте,
\q2 лисичиће што сатиру винограде,
\q2 јер наш је виноград у цвату.
\sp Она
\q1 
\v 16 Мој је драги мој и ја сам његова,
\q2 међу љиљанима он пасе.
\q1 
\v 17 Врати се док дан не мине
\q2 и сенке не ишчиле.
\q1 Као срна буди, о, вољени мој,
\q2 као срндаћ на брдима што нас деле.
\c 3
\q1 
\v 1 Тражила сам у ноћима на постељи својој
\q2 оног кога воли душа моја,
\q1 тражила сам
\q2 и нисам га нашла.
\q1 
\v 2 Устаћу, град ћу обиграти,
\q2 по улицама и по трговима ћу тражити
\q1 оног кога душа моја воли.
\q2 И тражила сам га, али га нисам нашла.
\q1 
\v 3 Нашли су ме стражари што обилазе град:
\q2 „Јесте ли видели онога
\q2 кога воли душа моја?“
\q1 
\v 4 И тек што сам их мало прошла,
\q2 нашла сам оног ког ми душа воли.
\q1 Зграбила сам га и пуштала га нисам
\q2 све док га нисам довела до куће мајке моје,
\q2 до одаје оне што ме је родила.
\q1 
\v 5 Ћерке јерусалимске, заклињем вас
\q2 ланадима и кошутама пољским,
\q1 не будите и не дижите моју љубав
\q2 док јој се не прохте.
\b
\q1 
\v 6 Шта се то из пустиње диже
\q2 ко облаци дима,
\q1 намирисано смирном, тамјаном
\q2 и свим мирисним помастима трговачким?
\q1 
\v 7 Гле, то је лежаљка Соломонова,
\q2 а око ње су шездесет делија,
\q2 неки од јунака Израиља.
\q1 
\v 8 Сваки од њих мач је дограбио,
\q2 ратовању су вични;
\q1 сваком од њих мач о бедру,
\q2 због ноћних страхота.
\q1 
\v 9 Од стабала ливанских је себи
\q2 носиљку начинио цар Соломон.
\q1 
\v 10 Од сребра јој је начинио мотке,
\q2 наслон од злата,
\q1 седиште од скерлета,
\q2 а унутрашњост су јој кожом\f + \fr 3,10 \ft Игра речи на изворном језику: \fqa кожа \ft – \fqa са љубављу.\f* обложиле ћерке јерусалимске.
\q1 
\v 11 Изађите и гледајте,
\q2 о, ћерке сионске, цара Соломона
\q1 с круном којом га окрунила мајка његова
\q2 на дан његовог венчања,
\q2 на дан када му се срце радовало!
\c 4
\sp Он
\q1 
\v 1 Лепа си, вољена моја, лепа си!
\q2 Очи су твоје голубице иза вела твога,
\q1 коса ти је попут стада коза
\q2 што се спушта низ гору Галад.
\q1 
\v 2 Зуби су ти као стадо остриганих оваца што долази са купања.
\q2 Свака од њих близанце носи и јалове међу њима нема.
\q1 
\v 3 Усне су ти попут нити скерлета,
\q2 а уста су ти љупка.
\q1 Као кришка нара
\q2 чело је твоје иза вела твога.
\q1 
\v 4 Твој је врат као кула Давидова,
\q2 начињена од поређаног камења.
\q1 Хиљаду штитова висе на њој,
\q2 све штитови од ратника.
\q1 
\v 5 Груди су твоје као ланад,
\q2 близанци срнини
\q2 који пасу међу љиљанима.
\q1 
\v 6 Док дан не мине
\q2 и сенке не ишчиле
\q1 отићи ћу на брдо смирнино
\q2 и на гору од тамјана.
\q1 
\v 7 Сва си лепа, вољена моја,
\q2 и на теби мане нема.
\b
\q1 
\v 8 Хајде са мном са Ливана, невесто,
\q2 хајде са мном са Ливана!
\q1 Сиђи са врха Амана,
\q2 са врха Сенира и Ермона;
\q1 из брлога лавова
\q2 и с гора рисових.
\q1 
\v 9 Срце си ми украла, сестро моја, невесто!
\q2 Срце си ми украла
\q1 једним погледом очију својих,
\q2 једним украсом огрлице своје.
\q1 
\v 10 Како је лепа љубав твоја,
\q2 сестро моја, невесто!
\q1 Љубав је твоја од вина боља
\q2 и мирис уља твојих од свих зачина.
\q1 
\v 11 Са усана твојих мед капље, о, невесто!
\q2 Мед и млеко под твојим су језиком,
\q1 а мирис хаљина твојих
\q2 је мирис Ливана.
\q1 
\v 12 Врт закључан ти си, сестро моја, невесто;
\q2 врело затворено, запечаћен извор.
\q1 
\v 13 Твоји су изданци царски врт нарова
\q2 с најбољим плодовима,
\q2 са каном и нардом;
\q2 
\v 14 са нардом и шафраном,
\q2 са мирисном трском и циметом,
\q2 са свим стаблима тамјана,
\q2 смирне и алоје,
\q2 са свим пробраним зачинима.
\q1 
\v 15 Ти си врело вртовима,
\q2 извор воде што жубори
\q2 и с Ливана тече.
\sp Она
\q1 
\v 16 Пробуди се, северни ветре!
\q2 Дођи, јужни ветре!
\q1 Дуни, вртом мојим,
\q2 нек полете његови зачини.
\q1 Нека дође мој вољени у свој врт,
\q2 нека једе од пробраног воћа.
\c 5
\sp Он
\q1 
\v 1 Дошао сам у врт свој, о, сестро моја, невесто!
\q2 Побрао сам смирну моју са зачинима мојим,
\q1 појео сам саће моје с медом мојим,
\q2 попио сам вино моје са млеком мојим.
\sp Пријатељи
\q1 Једите и пијте, о, пријатељи моји!
\q2 Опијте се, о, најмилији!
\sp Она
\q1 
\v 2 Спавам, ал’ срце ми будно.
\q2 Чуј! Вољени мој куца:
\q1 „Отвори ми, сестро моја, вољена моја,
\q2 голубице без мане!
\q1 Глава ми је натопљена росом,
\q2 увојке ми ноћ је овлажила.“
\q1 
\v 3 Одору сам своју свукла
\q2 и како да је навучем?
\q1 Ноге сам опрала своје
\q2 и како да их испрљам?
\q1 
\v 4 Кроз отвор је мој вољени провукао руку своју
\q2 и за њим је устрептала утроба моја.
\q1 
\v 5 Устала сам да отворим вољеноме своме
\q2 и с руку ми је прокапала смирна,
\q1 на резу је с прстију ми
\q2 процурила смирна.
\q1 
\v 6 И отворила сам вољеном свом,
\q2 али мој се вољени окренуо и отишао.
\q2 Душа ми је клонула што се удаљио.
\q1 Тражила сам га и нисам га нашла,
\q2 дозивала сам га и није ми се одазвао.
\q1 
\v 7 Нашли су ме стражари што обилазе град.
\q2 Истукли су ме, израњавали,
\q1 узели су вео с мене
\q2 стражари са зида.
\q1 
\v 8 Ћерке јерусалимске, заклињем вас,
\q2 ако нађете вољенога мога
\q1 шта да му кажете?
\q2 Да болујем од љубави.
\sp Пријатељице
\q1 
\v 9 А што је твој вољени бољи од других вољених,
\q2 о, ти најлепша међу женама?
\q1 Што је твој вољени бољи од других
\q2 па нас заклињеш тако?
\sp Она
\q1 
\v 10 Мој вољени блиста, румен је,
\q2 наочитији од десет хиљада!
\q1 
\v 11 Глава му је од злата злаћаног,
\q2 коса увојита
\q2 и ко гавран црна.
\q1 
\v 12 Очи су његове голубице
\q2 на воденим брзацима,
\q1 млеком умивене,
\q2 складно угнеждене.
\q1 
\v 13 Образи му ко леје зачина
\q2 и куле миришљавих трава;
\q1 усне су му љиљани
\q2 са којих се цеди смирна.
\q1 
\v 14 Руке су му ко палице златне
\q2 пуне хрисолита,
\q1 стомак му је плоча слоноваче
\q2 покривена сафирима.
\q1 
\v 15 Његове су ноге мермерни стубови
\q2 положени на темеље од сувога злата;
\q1 стасит је ко Ливан,
\q2 као пробрани кедрови.
\q1 
\v 16 Уста су му заслађена
\q2 и сав је пожељан;
\q1 такав је вољени мој, такав је драган мој,
\q2 о, ћерке јерусалимске!
\c 6
\sp Пријатељице
\q1 
\v 1 Где је отишао вољени твој,
\q2 о, најлепша међу женама?
\q1 Куда се окренуо вољени твој
\q2 да га тражимо са тобом?
\sp Она
\q1 
\v 2 Вољени је мој сишао у врт свој,
\q2 на леје зачина,
\q1 да пасе по вртовима
\q2 и љиљане бере.
\q1 
\v 3 Ја припадам моме вољеноме
\q2 и мени припада мој вољени
\q2 који пасе међу љиљанима.
\sp Он
\q1 
\v 4 Лепа си, вољена моја,
\q2 као Терса љупка и као Јерусалим,
\q2 страховита као војска с барјацима.
\q1 
\v 5 Очи своје с мене скрени
\q2 јер ме залуђују,
\q1 а коса ти је попут стада коза
\q2 што се спушта низ Галад.
\q1 
\v 6 Зуби су ти као стадо оваца
\q2 што долази са купања.
\q1 Свака од њих близанце носи
\q2 и јалове међу њима нема.
\q1 
\v 7 Као кришка нара
\q2 чело је твоје иза вела твога.
\q1 
\v 8 Нека је шездесет царица,
\q2 осамдесет иноча
\q2 и небројено младих жена;
\q1 
\v 9 ал’ је једна голубица моја без мане.
\q2 Она је љубимица мајке своје,
\q2 миљеница оне што је роди.
\q1 Виделе су је девојке и блаженом је прозвале,
\q2 а царице и иноче су је хвалиле.
\sp Пријатељице
\q1 
\v 10 Ко је она што се јавља као зора,
\q2 лепа као пуни месец, ко сунце без мане,
\q2 страховита као војска с барјацима?
\sp Он
\q1 
\v 11 Сишао сам у орашњак,
\q2 прегледао изданке у долу,
\q1 да видим хоће ли да пропупи лоза
\q2 и нар да процвета.
\q1 
\v 12 Ал’ ме душа, а да нисам знао,
\q2 посади на кола мојих великаша.
\sp Пријатељице
\q1 
\v 13 Врати се! Врати се, о, Суламко!
\q2 Врати се, врати да те погледамо!
\sp Он
\q1 Зашто да гледате у Суламку
\q2 као у игру два табора.
\c 7
\q1 
\v 1 Како су љупка стопала твоја у сандалама,
\q2 о, ћерко великашка!
\q1 Облине бокова твојих су као драгуљи,
\q2 као рукотворина уметника.
\q1 
\v 2 Пупак ти је ко округли пехар
\q2 коме никад не зафали вина;
\q1 стомак ти је ко снопић пшенице
\q2 окружен љиљанима.
\q1 
\v 3 Груди су твоје као ланад,
\q2 близанци срнини.
\q1 
\v 4 Врат ти је као кула од слоноваче,
\q2 очи језерца Есевона на вратима ватравимским;
\q1 нос ти је као кула ливанска
\q2 што гледа на Дамаск.
\q1 
\v 5 Глава је твоја попут Кармила,
\q2 коса ти је као царски скерлет.
\q2 У локне се твоје цар уплео.
\q1 
\v 6 Како си лепа!
\q2 Како си љупка вољена у својим чарима!
\q1 
\v 7 Стас ти је као дрво палме,
\q2 а груди ти ко гроздови.
\q1 
\v 8 Зато кажем: „Ја бих се на палму пео,
\q2 држао се за стабљике њеног воћа.“
\q1 Нек ми твоје груди буду ко гроздови на виновој лози,
\q2 дах носа твога ко мирис јабука.
\q2 
\v 9 Уста су твоја као добро вино.
\sp Она
\q1 Оно глатко клизи моме вољеноме,
\q2 оно нежно цури са усана оних што спавају.
\q1 
\v 10 Ја припадам моме вољеноме,
\q2 а он за мном жуди.
\q1 
\v 11 Дођи, вољени мој! Хајдемо у поља,
\q2 хајде да ноћимо по селима!
\q1 
\v 12 Дигнимо се рано, хајдемо у винограде
\q2 да видимо је ли пропупила лоза,
\q1 да ли се расцветала,
\q2 јесу ли се расцветали нарови.
\q2 И тамо ћу ти дати љубав своју.
\q1 
\v 13 Мандрагоре одишу мирисом,
\q2 а на вратима је нашим све пробрано воће.
\q1 А ја сам за тебе сачувала и ново и старо,
\q2 о, вољени мој!
\c 8
\q1 
\v 1 О, да си ми као брат био
\q2 што је груди мајке моје сисао!
\q1 Нашла бих те на пољу
\q2 и пољубила те
\q2 и нико ме презирао не би.
\q1 
\v 2 Водила бих те
\q2 и довела у дом мајке своје,
\q2 која ме је подигла.
\q1 Дала бих ти да попијеш вино зачињено
\q2 и сок од мога нара.
\q1 
\v 3 Левица му је под главом мојом,
\q2 а десницом ме грли.
\q1 
\v 4 Ћерке јерусалимске, заклињем вас,
\q2 не будите и не дижите моју љубав
\q2 док јој се не прохте.
\sp Пријатељице
\q1 
\v 5 Ко је она што долази из пустиње,
\q2 наслоњена на вољеног свога?
\sp Она
\q1 Под јабуком сам те пробудила,
\q2 тамо где те је мајка твоја родила,
\q2 тамо где те родила у мукама.
\q1 
\v 6 Стави ме као жиг на срце своје,
\q2 као прстен на руку своју.
\q1 Јер љубав је ко смрт јака,
\q2 а љубомора страшна попут Света мртвих\f + \fr 8,6 \ft У изворном тексту \tl Шеол\tl*, или \fqa подземље\ft , где пребивају душе умрлих.\f*.
\q1 Њен горући пламен
\q2 је моћна ватра.
\q1 
\v 7 Силне воде нису кадре да угасе љубав
\q2 и реке је згаснути не могу.
\q1 Ако неко за љубав даје
\q2 све богатство своје куће,
\q2 људи би то презрели.
\sp Пријатељи
\q1 
\v 8 Наша је сестра мала
\q2 и још нема груди.
\q1 Шта за њу да урадимо
\q2 на дан када о њој буде речи?
\q1 
\v 9 Ако као зид буде,
\q2 на њој ћемо дићи грудобран од сребра;
\q1 ако буде као врата,
\q2 заградићемо их кедровим даскама.
\sp Она
\q1 
\v 10 Ја сам зид!
\q2 Моје су груди као куле.
\q1 Тако сам постала она
\q2 што је нашла наклоност у његовим очима.
\b
\q1 
\v 11 У Вал-Амону Соломон је виноград имао.
\q2 Виноград је дао чуварима,
\q1 да му сваки од тог плода
\q2 доноси по хиљаду сребрника.
\q1 
\v 12 Преда мном је мој виноград,
\q2 моје је власништво.
\q1 Хиљаду сребрника припада теби, о, Соломоне,
\q2 а две стотине онима који му плод чувају.
\sp Он
\q1 
\v 13 О, ти која пребиваш у виноградима!
\q2 Глас твој ти другови помно ослушкују,
\q2 па дај да га и ја чујем.
\sp Она
\q1 
\v 14 Пожури, о, вољени мој!
\q2 Буди као јелен
\q1 или ко јеленче
\q2 на брдима што миришу.
