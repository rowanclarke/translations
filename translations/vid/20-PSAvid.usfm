\q1  
\v 59 Nandigajesa madito ga heni, 
\q1 nanyhiluka leka mbinze kwamula kwa hegwe. 
\q1  
\v 60 Ne kukawila ndangudita himahima, 
\q1 kujibatilila mizilo ja hegwe. 
\q1  
\v 61 Wehile nawawika midiwa leka wangwilize, 
\q1 ila heni sisemwa malajizo ga hegwe. 
\q1  
\v 62 Nechilo ng'hatu ndangulilimka kukutogola, 
\q1 kwa chiwalo cha nhaguso za hegwe zitanganiche. 
\q1  
\v 63 Heni nda goloko wa weng'ha walingukudumba, 
\q1 goloko wa hewo walingibatilila malajizo ga hegwe. 
\q1  
\v 64 Isi naimema igano lya kwimilila lya hegwe, gwa Mkulu Nguluwi, 
