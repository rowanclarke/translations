\v 18 \w Y|strong="H3068"\w* \w había|strong="H5324"\w* Absalom \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w vida|strong="H2416"\w* \w tomado|strong="H3947"\w* \w y|strong="H3588"\w* levantádose una columna, \w la|strong="H5921"\w* \w cual|strong="H3588"\w* \w está|strong="H2088"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w valle|strong="H6010"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*; \w porque|strong="H3588"\w* \w había|strong="H5324"\w* dicho: \w Yo|strong="H3588"\w* \w no|strong="H3588"\w* \w tengo|strong="H5921"\w* \w hijo|strong="H1121"\w* \w que|strong="H3588"\w* conserve \w la|strong="H5921"\w* \w memoria|strong="H2142"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w nombre|strong="H8034"\w*. \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* \w aquella|strong="H5921"\w* columna \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w nombre|strong="H8034"\w*: \w y|strong="H3588"\w* \w así|strong="H2088"\w* \w se|strong="H5921"\w* \w llamó|strong="H7121"\w* \w el|strong="H5921"\w* Lugar \w de|strong="H5921"\w* Absalom, \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
