\v 31 \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w ovejas|strong="H6629"\w*, \w Jaziz|strong="H3151"\w* \w agareno|strong="H1905"\w*. \w Todos|strong="H3605"\w* \w éstos|strong="H3605"\w* eran administradores \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w hacienda|strong="H7399"\w* particular \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w*.   
\p
\v 32 Jonatán, \w tío|strong="H1730"\w* \w de|strong="H5973"\w* \w David|strong="H1732"\w*, varón prudente, \w era|strong="H1931"\w* \w consejero|strong="H3289"\w* y \w escriba|strong="H5608"\w*, y \w Jehiel|strong="H3171"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Hacmoni, estaba \w con|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w*.   
