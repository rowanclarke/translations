\v 5 \w Porque|strong="H3588"\w* tú, oh Señor \w DIOS|strong="H3069"\w*, eres mi \w esperanza|strong="H8615"\w*: \w seguridad|strong="H4009"\w* mía desde mi \w juventud|strong="H5271"\w*.
\m 
\v 6 \w Por|strong="H5921"\w* \w ti|strong="H5921"\w* he sido sustentado \w desde|strong="H5921"\w* \w el|strong="H5921"\w* vientre: \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w entrañas|strong="H4578"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* madre tú fuiste \w el|strong="H5921"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* sacas­\w te|strong="H5921"\w*: \w de|strong="H5921"\w* \w ti|strong="H5921"\w* será \w siempre|strong="H8548"\w* \w mi|strong="H5921"\w* alaban­za.
