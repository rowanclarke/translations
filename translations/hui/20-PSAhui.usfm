\id PSA - Huli Bible [hui] -Papua New Guinea 2011 (web version -2013 bd) 
\h IBA GANA 
\toc1 Iba Gana 
\toc2 Iba Gana 
\toc3 Iba 
\mt1 Iba Gana  
\imt1 Mbuga ogoha gilibu ngarunaga nemandi ogo  
\ip Isaraele wali agalime Ngode Datagaliwabe mitangi bialu iba gana lolenebi ibuhondo bi lolenebi mbuga ogoniha gilibu winigo nga. Tigua Yarusalemeha ngoai holene wiangi harigani pialu howa iba gana lagabi Anduane Homogonaga andaha lotu lalu howa iba gana lagabi hene. Wali agalime turu howabi genda howabi iba gana lalu haga hene. Mali mbiraore ndo mali dewaore howa wali agali maru hearume iba gana gilibu yu ngoai howa mbuga mbiraoreni gilibu winigo nga. Iba gana tara tara gilibu ngaru Ngode Datagaliwabehondo iba gana lolenebi ibuhondo bi lolenebi uru.  
\ib  
\ip Ngode Datagaliwabenaga mini yaraga halu lolenebi  
\ip Ko birimaru lapani halu domabe lolenebi  
\ip Kini gahenge dabobagi helolene horongi bi lolenebi  
\ip Ina gi ho kamangi mamage holenagabi mini dunubia holenenagabi bi lolenebi  
\ip Turu howa ka̱i̱ lolenebi  
\ip Waitigi ibiragola pani mulenaga bi lolenebi  
\ip Wali agalime mana bayaleore mo tene holenaga bi lolenebi uruni nga.  
\ib  
\ip Iba gana uruni ina dindi holene hariga baya gibiore walia halu mo hongo haga nga. Yasuhanda iba gana mbuga ogoniha howa mana lawai haga hene. Keriso hamewaneigini pigane henerumebi hama ibalu áyu kamarumebi iba gana mbuga ogoni mo tene halu laga henego kama.  
\ip Ngode Datagaliwabehondo iba gana lolenebi bi lolenebi gilibu ngaruni ina wali agalime lolenenaga lo nga. Ina kamagoria horo marungi keba holene wialu horo marungi turu holene wiaga. Horo marungi wandari igiri bayale hongohe holene wialu horo marungi wali agali wahe holene horo wigi biaga. Iba gana mbugani howabi gilibu ngago wali agali holene áyu kamagoria ngolo be lo nga. Iba gana urunime Ngode Datagaliwabenaga wali agali bamba heneru biamogo bialu mini mo hongo hama ibaho winigo áyu inabi ogonidagua dege biaga.  
\iot Bu̱lu̱ baga buwa kuni gilibu ngago  
\ip Mbuga ogoniha iba gana mbira mbira lamaga halu handari mbirani pira duria (150) gilibu nga. Uruni tale buwa wabuni duria tu urubi wigi bida.  
\io1 Mbuga Mbira  
\io1 Iba Gana 1-41  
\io1 Mbuga Mende  
\io1 Iba Gana 42-72  
\io1 Mbuga Tebone  
\io1 Iba Gana 73-89  
\io1 Mbuga Mane  
\io1 Iba Gana 90-106  
\io1 Mbuga Dauni  
\io1 Iba Gana 107-150  
\c 1  
\ms1 Mbuga Mbira  
\mr (Iba Gana 1-41)  
\s1 Turu henene holenenaga ogo  
\q1
\v 1 Mbirali mana ko biaga karume ko bia larago hale halu nabiagabi\x + \xo 1.1 \xt Iba 26.4, Min 14.15, Yar 15.17\x*  
\q1 tigua ko biradagua nabiagabi  
\q1 Ngode Datagaliwabe deni habane nabuleneme mege bialu bedagoria nabiragabi kago  
\q2 ibu turu ho ka.   
\q1
\v 2 Ani nabi ibugua Anduane Homogohanda bi ledadagua bulenegoha  
\q1 turu holene ngaria handa walia howa  
\q2 mbiraga horombebi daga lalu mitangi biaabo haga ka.\x + \xo 1.2 \xt Yos 1.8, Iba 119.1, 119.35, 119.47, 119.92\x*   
\q1
\v 3 Ira iba angeni bu karu anda halu  
\q2 lini dolenengi dalu  
\q2 yuniru gau nalagadagua  
\q1 ibugua mbirale bigi birago bayale haga bulebira.\x + \xo 1.3 \xt Ais 3.10, Yar 17.8, Ese 47.12\x*   
\b  
\q1
\v 4 Ai ko biaga kago ibu ogonibi ndo ka.  
\q2 Ibu puyabume abalu hilu yalu piaganego ale ka.   
\q1
\v 5 Ani bidago Ngode Datagaliwabehanda godi larangi  
\q2 ko biaga karu tí koore biaga kamigoni lalu  
\q1 ibuninaga wali agali karu heba mandagi habe nahedagola  
\q1 ti dabo bagi holebira.   
\q1
\v 6 Mini tigabiwi karu Anduane Homogohanda ti haru howa mamage haga.\x + \xo 1.6 \xt Nah 1.7, Yo 10.14, 2 Ti 2.19\x*  
\q2 Ko biaga karume hariga pialu karu homoleneni tagira pole pora.   
\c 2  
\s1 Ngode Datagaliwabehanda Kini Dabo helenego ogo  
\q1
\v 1 Hameigini tara tara palu ngarume\x + \xo 2.1 \xt Iba 46.6\x*\x + \xo 2.1 \xt Ab 4.25-26\x*  
\q2 handabe manga hami̱ya lalu lo manda bialu kago aginagabe.  
\q1 Wali agali urunime aguaore bami̱ya lalu ndi nde lalu karu irane aginagabe.   
\q1
\v 2 Anduane Homogohondobi mbirali kini helo ibugua dabayagohondobi  
\q2 wali agali tinaga kinirume wai bule manda bu ka.  
\q1 Haru hagarumebi mandagi mo mogobu biruwa handabe manga halu ti hoba mialu kagoni.   
\q1
\v 3 Wali agali o biarume lalu,  
\q1 Libugua ina haru hole dariba hayago hado wahami̱ya, lalu ka.  
\q2 Libugua ina haru nahelo yu wahami̱ya, lalu ka.   
\b  
\q1
\v 4 Anidagua lalu kagoni.\x + \xo 2.4 \xt Iba 37.13, 59.8, Min 1.26\x*  
\q2 Anduane Homogo ibu dahuliya andaga ibuninaga dagiani handadaliho biruwa  
\q2 ti hondo oba halu ka.  
\q1 Tigua ni lo manda biraruni  
\q2 bame de gangabi henene halu buluba ndodagola  
\q2 ibugua mo yo hondo ka.   
\q1
\v 5 Ani bialu ti bayale bidabani keba holeneme  
\q2 ti mini wilo mo gi halu ka.   
\q1
\v 6 Ibugua keba howa lalu,  
\q1 I̱naga Hari Saiono loma bini ngagoria  
\q2 i̱naga kini ibu ogoriani tagira íbu heledo, lene.   
\b  
\q1
\v 7 Kini ogoni ibugua agua lolebira.\x + \xo 2.7 \xt Ab 13.33, Hi 1.5, 5.5\x*  
\q1 Anduane Homogohanda ledadagua latagi halu larogo.  
\q2 Ibugua i̱hondo lalu, Í̠ i̱ igini kegoni.  
\q2 Áyu i̱ í̠ aba harogoni.   
\q1
\v 8 Wali agali hameigini tara tara palu ngaru bibahende\x + \xo 2.8 \xt Iba 72.8, Dan 7.13-14, Yo 17.4-5\x*  
\q2 i̱na haru hoabe lariyagua ani bia lolebero.  
\q1 Dindi bibahendebi mbirale bibahende ngarunibi  
\q2 í̠naga dege holebira.   
\q1
\v 9 Uruni bibahende í̠na kangome bo podolebere.\x + \xo 2.9 \xt Iba 89.23, Mo 2.26-27, 12.5, 19.15\x*  
\q1 Mbodoli be gingiru laradagua  
\q2 bibahende bo gingirulo paya paya bulebere.   
\b  
\q1
\v 10 Bi hiriribi urunibi lene ngago manda buwa  
\q2 dindini kini harimidaru tíni tiga bialu halimu.  
\q1 Haru haga bibahende harimidaru tíbi hale halu bayuwa manda bilimu.   
\q1
\v 11-12 Gi howa Anduane Homogonaga biabe bialu halimu.\x + \xo 2.11-12 \xt Pb 2.12, Hi 12.28\x*\x + \xo 2.11-12 \xt Yo 5.23, 1 Pi 2.6\x*  
\q1 Duru lalu ma podope halu ibu igini mitangi bialu lotu lalimu.  
\q1 Ibu abale keba haragola tí homo tongolodaga holigo  
\q2 tí mini wialu ogonidagua bilimu.  
\q1 Ibuha mo humbi howa ha do ho karu ti turubioreni ka.   
\c 3  
\s1 Debidi ibu mo hongo helo egerebagi Anduane Homogohondo bi lenego ogo  
\q1
\v 1 Anduane Homogo-o i̱naga waitigi dewaore bu kagoni.\x + \xo 3.1 \xt 2 Sml 15.13–17.22\x*  
\q1 Tigua i̱ bole manda mandabu kagoni.   
\q1
\v 2 Tigua i̱ lo guralu howa lalu,  
\q2 Ngode Datagaliwabehanda í̠ biamogo nabulebira, lalu ka.   
\b  
\q1
\v 3 Ti ani laragoyu Anduane Homogo-o í̠ i̱naga wai humbi ale howa\x + \xo 3.3 \xt Iba 62.7\x*  
\q2 i̱ ho hangai haga kegoni.  
\q1 Í̠nime i̱ wayali holiya biamogo biaga ke.  
\q1 Í̠nime i̱naga genda bu ngago mo wahalu  
\q2 i̱ mo hongo haga kegoni.   
\q1
\v 4 I̱na Anduane Homogohondo, I̱ biamogo bia, lalu olaruli.\x + \xo 3.4 \xt Iba 4.3, 43.3\x*  
\q1 Ibuninaga hari loma biahene biagoria howa  
\q2 ibugua i̱na bi larogo ladai biaga ka.   
\b  
\q1
\v 5 Mbiraga i̱ paliahondo kogola  
\q2 Anduane Homogohanda i̱ handayaho haga ka.   
\q1
\v 6 Ami agali daosini pira agimame (10,000) i̱ ho hagira biragola\x + \xo 3.6 \xt Iba 23.4, 27.3, 118.10-13\x*  
\q2 i̱na ti hondowa gi naholebero.   
\b  
\q1
\v 7 Anduane Homogo-o í̠ ibabe.\x + \xo 3.7 \xt Yob 16.10, Iba 22.21, 57.4, 58.6\x*  
\q1 I̱naga Ngode Datagaliwabe-o i̱ biamogo bule ibabe.  
\q1 I̱naga waitigi karu baba wai biaga í̠ kegoni.  
\q1 Agali ko karume i̱ mo ko nahelo  
\q2 tinaga ne bo hondaga kegoni.   
\q1
\v 8 Anduane Homogo í̠ni hangume í̠naga wali agali karu haru dai biaga kegoni.\x + \xo 3.8 \xt Iba 28.8, 29.11\x*  
\q2 Ti bayale helo í̠na biamogo bibelo hamelo ko.   
\c 4  
\s1 Debidi ibuni mo hongo helo mbiraga bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o í̠na i̱ mo wayali haga kegoni.\x + \xo 4.1 \xt Iba 17.6, 18.6, 18.18-19\x*  
\q2 I̱na í̠ olarogola í̠na i̱naga bi larogo hale habe.  
\q1 Bamba i̱naga miniha genda yu hewagola  
\q2 í̠na i̱naga genda mo wahai harigoni.  
\q1 Í̠na áyubi i̱ dara holene irane nawini howa  
\q2 i̱naga bi hale halu biamogo bibe.   
\b  
\q1
\v 2 Agali bu kamiru tígua i̱naga mini mo ko haga bialu  
\q2 horo agiru holeberemibe.  
\q1 Ko ngaru hangu mo tene halu  
\q2 mana henene bulene ngaru nabi  
\q2 horo agiru holeberemibe.   
\b  
\q1
\v 3 Tígua bi ogoninaga irane manda bilimu.\x + \xo 4.3 \xt Iba 6.8-9, 50.5, 135.4\x*  
\q1 Wali agali Anduane Homogonaga andaneha haga karu  
\q2 ti ibuninagaore helo dabene ka.  
\q1 Horo bibahendengi i̱na ibuhondo olalu haabo kogola  
\q2 ibugua i̱na olarogo hale haga ka.   
\b  
\q1
\v 4 Tígua mana ko bialu kamigo wahalu\x + \xo 4.4 \xt Iba 77.6, 119.11, Eb 4.26\x*  
\q2 Anduane Homogohondo gi ho holene nga.  
\q1 Tígua dagiani paluwa bi maru nale  
\q2 mana ogoni baya hangu manda bilimu.   
\q1
\v 5 Tígua Anduane Homogo ibugua hame laga aleru ibunihondo lomabu milimu.\x + \xo 4.5 \xt Man 33.19, Iba 51.19, 62.8\x*  
\q2 Ibunihondo tí mini mbiraore wu halimu.   
\b  
\q1
\v 6 Wali agali dewalime lalu,\x + \xo 4.6 \xt Dag 6.26, Yob 7.7, 9.25\x*  
\q2 Anduane Homogo-o í̠naga mo bayale holene ngibelo.  
\q2 Í̠na ina dara halu biamogo bibelo hamelo kama, lalu lagane ka.   
\q1
\v 7 Tomo widi \w gerebi\w* liniru dewa andaho kagola\x + \xo 4.7 \xt Iba 97.11-12, 119.14, 119.72\x*  
\q2 mabu anduane karume ti turuho haga.  
\q1 Anigoyu í̠na i̱ha turu holene wia harigome  
\q2 tinaga turu holene bolangua heneore ngirigoni.   
\b  
\q1
\v 8 Anduane Homogo-o í̠nimeore i̱ handayaho kegome\x + \xo 4.8 \xt Yob 11.19, Iba 16.9\x* i̱ bayaleore kogoni.  
\q2 I̱ dagiani palialu howa mbirale mbirahondo gi nahe  
\q2 miniha dungulo howa paliahondo haruli.   
\c 5  
\s1 Anduane Homogohanda ibu handayaho helonaga bi lenego ogo  
\q1
\v 1 Anduane Homogo-o i̱na gendaore howa  
\q2 í̠hondo bi larogo hale habe.   
\q1
\v 2 I̱naga Ngode Datagaliwabebi Kinibi í̠ni hanguore kego mitangi bialu  
\q2 í̠na i̱ biamogo bibelo í̠hondo bi ogoni larogo bayuwa hale habe.\x + \xo 5.2 \xt Iba 3.4, 65.2\x*   
\q1
\v 3 Anduane Homogo-o egerebagi bibahendengi i̱na í̠hondo bi laruli.\x + \xo 5.3 \xt Iba 30.5, 88.13, 130.6\x*  
\q2 Ni dolene tu haragolabi i̱na í̠hondo bi laabo haruli.  
\q1 I̱na bi larugo ladai bibelo i̱ hondo kogoni.   
\b  
\q1
\v 4 Ngode Datagaliwabe-o wali agalime mana ko birago hondowa  
\q2 í̠na turu nahagaore kegoni.  
\q1 Wali agali mana ko biaabo haga karu  
\q2 ti í̠ kegoria haparaho habe naheore ka.   
\q1
\v 5 Wali agali mine haga bu karu\x + \xo 5.5 \xt Hab 1.13\x*  
\q2 ti í̠naga deni helo turu nahaga ke.  
\q1 Wali agali ko biaga karu  
\q2 tihondo handabe manga haga ke.   
\q1
\v 6 Wali agali ke̱ howa bi laga karu\x + \xo 5.6 \xt Iba 55.23, Mo 21.8\x*  
\q2 í̠na ti bo wahaga ke.  
\q1 Darama hangu noa haga karubi  
\q2 bi nagalone ngago lo payapaya biaga karubi  
\q1 í̠na urunihondo handabe manga haga kegoni.   
\b  
\q1
\v 7 Í̠na i̱hondo gubalini timbuni ho kegonaga\x + \xo 5.7 \xt 1 Kin 8.29-30, Iba 132.7, 138.2\x*  
\q2 i̱na í̠naga anda kegoha ibulebero.  
\q1 Í̠naga anda loma biahene kagoria howa  
\q2 i̱na ge duli hangaho biruwa  
\q2 í̠ mitangi bialu lotu lalu birulebero.   
\q1
\v 8 Anduane Homogo-o i̱naga waitigi dewaore kagonigo\x + \xo 5.8 \xt Iba 24.4-5, 27.11\x*  
\q2 i̱na í̠naga bi mana bayale ngagoria talialu holiya  
\q2 í̠na i̱ haru habe.  
\q1 I̱ ibagabu kogoha í̠na hariga bayale tigabi ngago mo walia habe.   
\b  
\q1
\v 9 I̱naga waitigi bu karu tiha henene lolenego nawi howa\x + \xo 5.9 \xt Iba 62.4, Lg 11.44, Lm 3.13\x*  
\q2 tigua agali ta nabi karu bo waholene hangu manda bu kagoni.  
\q1 Tinaga ne hariga homaliha homa ngu ale bialu helo howa  
\q2 tigua agali maru karu mana ko bulene ngago bilo  
\q2 bime ladebodebo biaga ka.   
\q1
\v 10 Ngode Datagaliwabe-o í̠na agali uruni tini ko biragonaga\x + \xo 5.10 \xt 2 Sml 15.31, 17.14, 17.23\x* pani nelo mibe.  
\q2 Tinaga mini wu kago mo wahabe.  
\q1 Tigua í̠ handabe manga howa mana ko ngaru bialu kago  
\q2 agali ko uruni ti í̠ kegoha nahelo  
\q2 kaundiaha bo batagi ho helabe.   
\b  
\q1
\v 11 Wali agali maru í̠na ti handayaho habelo haga karume\x + \xo 5.11 \xt Ais 65.13\x*  
\q2 ti turu timbuniore ho holebira.  
\q1 Tinaga bu miniha turu holene to̱lai ho howa  
\q2 tigua iba gana turu halu lolebira.  
\q1 Í̠na wali agali í̠ gubalini haga karu  
\q2 ti baya hangu handayaho habe.  
\q1 Tigua í̠ bayale kegonaga turu timbuni ho howa  
\q2 í̠naga mini yaraga holebira.   
\q1
\v 12 Anduane Homogo-o wali agali í̠naga bi mana taluwa bialu haga karu\x + \xo 5.12 \xt Iba 115.13\x*  
\q2 tihondo mana bayale biaga kegoni.  
\q1 Í̠naga gubalini holeneme wai humbi ale howa  
\q2 ti ho ge haga kegoni.   
\c 6  
\s1 Genda íbu wiagola biamogo bilo Anduane Homogohondo bi lenego ogo  
\q1
\v 1 Anduane Homogo-o í̠naga keba ho kegome\x + \xo 6.1 \xt Iba 38.1, Yar 10.24\x*  
\q2 i̱hondo keba nahabe.  
\q1 Í̠ miniha keba ho kegonigo  
\q2 i̱ pani nolene na mo ngibe.   
\q1
\v 2 Anduane Homogo-o i̱ hongo nahe kogo\x + \xo 6.2 \xt Iba 41.4, Hos 6.1\x*  
\q2 í̠na i̱ dara howa biamogo bibe.  
\q1 I̱naga hongo biba halu ereba hayago  
\q2 í̠nime i̱ lone mo hongo habe.   
\q1
\v 3 I̱ miniha genda timbuniore ho kogo  
\q2 Anduane Homogo-o ai agua bidebe.  
\q1 I̱ genda yu agiru holiya karulapedabe.\x + \xo 6.3 \xt Iba 90.13\x*   
\b  
\q1
\v 4 Anduane Homogo-o í̠na i̱ biamogo bialu gi mibe.  
\q2 I̱ nahomoliya í̠na dara howa abale pele ngibe.   
\q1
\v 5 Homene dindiha karume í̠ mitangi nabiagaya\x + \xo 6.5 \xt Iba 88.11, 118.17, Ais 38.18\x*  
\q1 Tini haga haga bidagoha howa  
\q2 í̠naga mini yaraga nahagaya.   
\b  
\q1
\v 6 I̱na olalu haabo kogola  
\q2 i̱naga hongo biba hai haya.  
\q1 Mbiraga bibahendengi i̱naga de ibame dagia goba ho wiaga.  
\q1 I̱na dugu bialu haabo kogola  
\q2 i̱naga haguanda de ibame goba ka.   
\q1
\v 7 I̱naga waitigi dewaore bu kagola\x + \xo 6.7 \xt Yob 17.7, Iba 38.10, Dug 5.17\x*  
\q2 i̱na dugu bialu haabo kogome  
\q2 i̱naga de to howa mbirale mbira bayuwa handabe nahe kogoni.   
\b  
\q1
\v 8 Anduane Homogo ibugua i̱na dugu berogo hale ho kagoni.\x + \xo 6.8 \xt Iba 119.115, Md 7.23, Lg 13.27\x*  
\q1 Wali agali mana ko biaga kamiru  
\q2 tí i̱ kogoria hapara nahe purogo ladaba.   
\q1
\v 9 I̱na Anduane Homogo olalu i̱ biamogo bia larogola  
\q2 ibugua hale halu i̱ biamogo biaga ka.   
\q1
\v 10 I̱naga waitigi bu karu  
\q2 ti genda timbuni yu holebira.  
\q1 Gi timbuniore howa ti taga timbuni ho holebira.  
\q1 Tigua i̱ abale yu wahalu puwa  
\q2 tini pu luluya hama ibaga bulebira.   
\c 7  
\s1 Debidi ibu genda yu howa Anduane Homogohondo bi laminigo ogo  
\q1
\v 1 Anduane Homogo i̱naga Ngode Datagaliwabe-o\x + \xo 7.1 \xt Iba 31.1, 31.15, 71.1\x*  
\q2 waitigi bu karume i̱ handa walia nahelo  
\q2 í̠niha ha do hole eberogoni.  
\q1 Agali i̱ minule talima ibalu karume  
\q2 i̱ bo wa nahelo biamogo bialu  
\q2 i̱ mo ko nahelo í̠na i̱ pele ngibe.   
\q1
\v 2 Laiono gabuame wali agali bo budabaga biagadagua  
\q2 i̱naga waitigi karume i̱ bo budabagabu waholani.  
\q1 Tigua dindi ko mbirali i̱ biamogo bulene nahe ngagoha  
\q2 minu waholigo i̱ pele ngibe.   
\b  
\q1
\v 3 Anduane Homogo i̱naga Ngode Datagaliwabe-o\x + \xo 7.3 \xt 1 Sml 24.11\x*  
\q2 i̱ha biako hene mbira wiaguabi  
\q2 i̱na mbirali kagohondo ko mbira bini wiaguabi   
\q2
\v 4 i̱na i̱naga nenege mendeali kago ndelene wiaguabi\x + \xo 7.4 \xt 1 Sml 24.7, 26.7, Iba 109.4-5\x*  
\q2 waitigi karuhondo bame ko biaede hene wiaguabi  
\q1 urunidagua i̱na bini wiagua nde   
\q2
\v 5 waitigime i̱ minilo wahabe laro.  
\q1 Tigua i̱ bo hengedo wahalu  
\q2 i̱naga tingini bo budabaga bialu  
\q2 dindini bame baa̱i̱ halu pelo wahabe.   
\b  
\q1
\v 6 Anduane Homogo-o í̠nime keba howa heyabelo hamelo ko.\x + \xo 7.6 \xt Iba 35.23, 94.2, 138.7\x*  
\q1 I̱naga waitigime i̱la wai hongo howa bialu karu  
\q2 ti mo ko halu bai habe.  
\q1 Í̠na mana tigabi hangu biaga kegoni ndobe.  
\q1 Ani kego ai í̠na abale ibalu i̱ biamogo bibe.   
\q1
\v 7 Í̠ni dahuliya andaga biragane dagia ngegoriani biruwa\x + \xo 7.7 \xt Iba 22.27\x*  
\q2 í̠na wali agali bibahende karu í̠ni kegoha mo ngoai halu  
