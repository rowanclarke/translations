\v 23 \nd \+w Yavé|strong="H3068"\+w*\nd* respondió \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj ¿\+w Se|strong="H3808"\+w* \+w acortó|strong="H7114"\+w* la \+w mano|strong="H3027"\+w* \+w de|strong="H1697"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*? ¡\+w Ahora|strong="H6258"\+w* \+w verás|strong="H7200"\+w* \+w si|strong="H3808"\+w* \+w se|strong="H3808"\+w* te cumple \+w o|strong="H3068"\+w* \+w no|strong="H3808"\+w* mi \+w Palabra|strong="H1697"\+w*!\wj*   
\p
\v 24 Entonces \w Moisés|strong="H4872"\w* \w salió|strong="H3318"\w* y \w dijo|strong="H1696"\w* al \w pueblo|strong="H5971"\w* las \w Palabras|strong="H1697"\w* \w de|strong="H5971"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \w También|strong="H3318"\w* reunió \w a|strong="H3068"\w* los 70 varones \w de|strong="H5971"\w* los \w ancianos|strong="H2205"\w* del \w pueblo|strong="H5971"\w* y los \w puso|strong="H5975"\w* \w alrededor|strong="H5439"\w* del Tabernáculo.  
\v 25 \nd \+w Yavé|strong="H3068"\+w*\nd* \w descendió|strong="H3381"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w nube|strong="H6051"\w* \w y|strong="H5921"\w* \w le|strong="H5921"\w* \w habló|strong="H1696"\w*. Luego tomó \w del|strong="H4480"\w* \w Espíritu|strong="H7307"\w* \w que|strong="H4480"\w* \w estaba|strong="H1961"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w lo|strong="H3808"\w* colocó \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* 70 \w ancianos|strong="H2205"\w*. \w Cuando|strong="H1961"\w* \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* descansó \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w profetizaron|strong="H5012"\w*, pero \w después|strong="H5921"\w* \w no|strong="H3808"\w* continuaron.   
\p
\v 26 \w Quedaron|strong="H7604"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w campamento|strong="H4264"\w* \w dos|strong="H8147"\w* \w hombres|strong="H8147"\w*. \w El|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* uno era Eldad \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w del|strong="H5921"\w* \w otro|strong="H8145"\w*, \w Medad|strong="H4312"\w*. \w El|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w reposó|strong="H5117"\w* \w también|strong="H3318"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H1992"\w*, pues figuraban \w entre|strong="H5921"\w* \w los|strong="H1992"\w* contados, pero \w no|strong="H3808"\w* fueron \w al|strong="H5921"\w* Tabernáculo. \w Ellos|strong="H1992"\w* \w profetizaron|strong="H5012"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w campamento|strong="H4264"\w*.  
\v 27 Un joven \w corrió|strong="H7323"\w* y dio \w aviso|strong="H5046"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: Eldad y \w Medad|strong="H4312"\w* \w profetizan|strong="H5012"\w* en \w el|strong="H4264"\w* \w campamento|strong="H4264"\w*.   
\p
\v 28 Entonces \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*, \w el|strong="H1121"\w* ayudante \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w* desde su juventud, \w respondió|strong="H6030"\w*: \w Moisés|strong="H4872"\w*, \tl ʼadón\tl* mío, ¡impídeles!   
\p
\v 29 \w Pero|strong="H3588"\w* \w Moisés|strong="H4872"\w* \w le|strong="H5921"\w* dijo: ¿Tienes \w celos|strong="H7065"\w* \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* \w mí|strong="H5921"\w*? ¡\w Ojalá|strong="H4310"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* fuera \w profeta|strong="H5030"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* impusiera \w su|strong="H3588"\w* \w Espíritu|strong="H7307"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*!  
\v 30 \w Moisés|strong="H4872"\w* volvió al \w campamento|strong="H4264"\w* junto con \w los|strong="H1931"\w* \w ancianos|strong="H2205"\w* de \w Israel|strong="H3478"\w*.   
\p
\v 31 \w Entonces|strong="H3117"\w* llegó un \w viento|strong="H7307"\w* \w de|strong="H4480"\w* parte \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H4480"\w* trajo \w codornices|strong="H7958"\w* \w desde|strong="H4480"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w dejó|strong="H5203"\w* caer \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w campamento|strong="H4264"\w*, \w como|strong="H5921"\w* un \w día|strong="H3117"\w* \w de|strong="H4480"\w* \w camino|strong="H1870"\w* \w por|strong="H5921"\w* un \w lado|strong="H7307"\w* \w y|strong="H5921"\w* un \w día|strong="H3117"\w* \w de|strong="H4480"\w* \w camino|strong="H1870"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* otro, \w a|strong="H3068"\w* casi 90 centímetros \w de|strong="H4480"\w* altura \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H4480"\w* \w la|strong="H5921"\w* tierra.   
