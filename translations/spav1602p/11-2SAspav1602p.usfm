\m
\v 6 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w mancebo|strong="H5288"\w* \w que|strong="H5921"\w* \w le|strong="H5921"\w* daba \w las|strong="H5921"\w* nuevas respondió: \w Casualmente|strong="H7122"\w* \w vine|strong="H7136"\w* \w al|strong="H5921"\w* \w monte|strong="H2022"\w* \w de|strong="H5921"\w* Gilboa, \w y|strong="H5921"\w* hallé \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* \w que|strong="H5921"\w* \w estaba|strong="H2009"\w* recostado \w sobre|strong="H5921"\w* su \w lanza|strong="H2595"\w*, \w y|strong="H5921"\w* venían tras \w él|strong="H5921"\w* \w carros|strong="H7393"\w* \w y|strong="H5921"\w* gente \w de|strong="H5921"\w* \w a|strong="H3068"\w* caballo.   
\m
\v 7 \w Y|strong="H3068"\w* como él \w miró|strong="H7200"\w* atrás, \w vióme|strong="H7200"\w* y llamóme; y yo dije: Heme \w aquí|strong="H2005"\w*.   
\m
\v 8 \w Y|strong="H3068"\w* \w él|strong="H4310"\w* \w me|strong="H4310"\w* dijo: ¿\w Quién|strong="H4310"\w* eres tú? \w Y|strong="H3068"\w* yo \w le|strong="H4310"\w* respondi: Soy Amalecita.   
\m
\v 9 \w Y|strong="H3068"\w* \w él|strong="H5921"\w* \w me|strong="H5921"\w* \w volvió|strong="H5750"\w* \w a|strong="H3068"\w* decir: \w Yo|strong="H3588"\w* \w te|strong="H5921"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w te|strong="H5921"\w* pongas \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H3588"\w* \w me|strong="H5921"\w* \w mates|strong="H4191"\w*, \w porque|strong="H3588"\w* \w me|strong="H5921"\w* toman \w angustias|strong="H7661"\w*, \w y|strong="H3588"\w* \w toda|strong="H3605"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w* \w está|strong="H5975"\w* \w aún|strong="H5750"\w* \w en|strong="H5921"\w* \w mí|strong="H5921"\w*.   
\m
\v 10 \w Yo|strong="H3588"\w* \w entonces|strong="H3588"\w* púseme \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H3588"\w* matélo, \w porque|strong="H3588"\w* \w sabía|strong="H3045"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w podía|strong="H3808"\w* \w vivir|strong="H2421"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* caída: \w y|strong="H3588"\w* \w tomé|strong="H3947"\w* \w la|strong="H5921"\w* corona \w que|strong="H3588"\w* tenía \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w cabeza|strong="H7218"\w*, \w y|strong="H3588"\w* \w la|strong="H5921"\w* ajorca \w que|strong="H3588"\w* traía \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w brazo|strong="H2220"\w*, \w y|strong="H3588"\w* helas traído \w acá|strong="H2008"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* señor.   
\m
\v 11 \w Entonces|strong="H1571"\w* \w David|strong="H1732"\w* trabando de sus vestiduras, rompiólas; \w y|strong="H1571"\w* \w lo|strong="H3605"\w* \w mismo|strong="H3605"\w* hicieron \w los|strong="H3605"\w* hombres \w que|strong="H1571"\w* estaban \w con|strong="H1571"\w* \w él|strong="H3605"\w*.   
