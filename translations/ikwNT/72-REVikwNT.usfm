\id REV - IKWERRE 
\h Okpume 
\toc1 Okpume Chiokike kpumennu Jọni 
\toc2 Okpume 
\toc3 Okpu 
\mt1 Okpume 
\mt2 Chiokike kpumennu 
\mt2 Jọni 
\imt1 Nhne gbasịri ọkwukwo ka 
\im Ọkwukwo ka neegesi nhne Jọni whnụrnu gbasịri izi Chiokike nụ nhne Jizọsi Karaịsi mernu (1:2). Izi ka warụ ngalaba ẹto. (1) Rikne ọjo nọornu ẹrnu n'ọwa, nye Karaịsi jaata awhnụwhnu, nwụ masị. (2) Jizọsi bụ Nyenwe aị, o jeemegbu kpakara ele badnụ nụ kpakara rikne ke neemegidne Chiokike. (3) Chiokike nwernu ọgwo ẹrnu ke ọ bịtannu kpakara ele ke a, ele kwesiri be kwnata be mkpọma, ele dazịgidnernu n'ọkwnata ovu be, ke kakwo ele nwụrnu n'ẹrnu Nyenwe aị. 
\ip Ka bụ izi ke nwernu olile anya nyee ele Karaịsi, ele tarụ awhnụwhnu, nwụ kwnornu ọkwnata mkpọma be nụ Karaịsi. Ọkwukwo izi ka nookwu nụ ọ bụ n'ezi nụ ọchichi aka rikne ele Rom zị naakpa rikne, kọvu Nnwọ Atnụrnu Chiokike nwe omegbu n'ipne-aznụ. Ka mernu be bụru ele kwesiri ọkwnata ovu dụ n'ẹnwu. 
\iot Nhne zị n'ọkwukwo ka 
\io1 Ọwhnurninya Jọni \ior (1:1-8) \ior* 
\io1 Nyenwe aị zị bụdnu \ior (1:9-20) \ior* 
\io1 Ọkwukwo izi ọgbako Chiokike ẹsau \ior (2:1---3:22) \ior* 
\io1 Okpukpe n'oligwe \ior (4:1-11) \ior* 
\io1 Ọkwukwo ke nwernu akara ẹsau \ior (5:1---6:17) \ior* 
\io1 Okpukpe nụ ruwhnu ngadna eze Chiokike \ior (7:1-17) \ior* 
\io1 Ọkwodu ẹsau \ior (8:1---11:19) \ior* 
\io1 Agwọ nụ anọhia lawụru wam \ior (12:1---13:18) \ior* 
\io1 Ikpe Chiokike nụ ochekwa a \ior (14:1---15:8) \ior* 
\io1 Okiko ovu owe ẹhni Chiokike \ior (16:1-21) \ior* 
\io1 Be megburu ele irno Chiokike \ior (17:1---20:10) \ior* 
\io1 Ikpe ipne-aznụ \ior (20:11-15) \ior* 
\io1 Oligwe ikne nụ ọwa ikne \ior (21:1-8) \ior* 
\io1 Jerusẹlem ikne \ior (21:9---22:6) \ior* 
\io1 Karaịsi jaava wara wara \ior (22:7-21) \ior* 
\c 1  
\p  
\v 1 Okpume Jizọsi Karaịsi, ke Chiokike nyernu a, ma o gesi ele izi a nhne jeeme n'ige matị ke vazne, o zizne enine izi a o gesi nye izi a Jọni.  
\v 2 Jọni gbarụ akebne ikwu-ọnu Chiokike nụ akebne Jizọsi Karaịsi, o kwuru kpakara nhne ọ whnụrnu.  
\v 3 Nye ọwa ọma bụ nye nọogwnu kpakara ikwu-ọnu ke ọkwukwo ọwhnurninya ka, nụ ele nụrnu be, bịta masị be, kwnornu nụ ige zị ndụndu. 
\s1 Obekwu ikwu 
\p  
\v 4 Mawa, Jọni naagbaznenu ọgbako Chiokike ẹsau ke zị n'Esia ọkwukwo. 
\p Oru nụ udno ke Chiokike nye zị, nye zị nụ mbọm, nụ nye ke jaava dazịnu anụ, hite n'aka enine ẹsau ke zị nụ ruwhnu ngadna eze a,  
\v 5 ma n'aka Jizọsi Karaịsi, nye akebne kwesiri be kwnata a mkpọma, nye mbọm ke hi n'ẹnwu lizọ, nye ke nẹechi ele eze k'ọwa. 
\p Nye whnụrnu aị n'anya, gweru ọvnarna a snụsnama kpakara mmehie aị,  
\v 6 o mee aị a bụru mbam ele ọkwa arịohna Chiokike a, nụ Nda a, igwugwu nụ rikne zịnu a hite kịtna dụ n'ige kwó okwo. Amịm. 
\q1  
\v 7 Le, ọ vawa nụ rime erumeru oligwe, 
\q2 kpakara anya jọowhnu a, 
\q1 ma ele dụru a ara, 
\q2 kpakara ele zị n'ọwa jaagbanụ a mkpe. 
\q1 Owe! Amịm. 
\p  
\v 8 “Mawa bụ Alịfa nụ Omega,” bụ nhne Nyenwe aị kwuru. “Mawa bụ Ọpanizo nụ Okwukwo, nye zị, nye zị nụ mbọm, nụ nye jaava, Nye Meli Nhne Dum.” 
\s1 Nye nụ lele  //  Nnwọ ke Badnụ 
\p  
\v 9 Mawa bụ Jọni, nye bụ nnwọ nda anụ, nye sno anụ nụ rime awhnụwhnu, a bụ ele ẹli-eze a, a naagidne awhnụwhnu. Be kwuznernu m nụ rime ẹli ọhia esilawụru osimini ke Patimọsi, kwnornu nụ m kpọru m okwo ikwu-ọnu Chiokike nụ nhne Jizọsi gbarụ ama a. 
\p  
\v 10 M zị m nụ rime Enine n'ọbochi Nyenwe aị, m nụrnu m okne nkọli n'aznụ m ke dnarnụ lele ọkwodu.  
\v 11 Nkọli ka kaa, “Gbasị nhne ị whnụrnu n'ọkwukwo, ziznenu a ọgbako Chiokike ẹsau ka, ziznenu Efesọsi, nụ Sịmaina, ziznenu Pegamọsi, nụ Taịtira, ziznenu Sadisi, nụ Filadefịa, zizne masịnu Laodisia.” 
\p  
\v 12 M tụhnasna ma m whnụrnu m nye nookwunu m ọka. M whnụrnu m nhne be tụkwasi tọnji ẹsau be wụru golu.  
\v 13 N'esilawụru nhne be tụkwasi tọnji ẹsau wam gwuzo otu nye nụ lele Nnwọ ke Badnụ. O wogwu iwo awura dụru a ẹli ọchi, o ji ajnị sụ nụ mkpọma a.  
\v 14 Risi a nụ rukeri-ize a noonwu va-a-a lele wulu, naachna va-a-a lele mkpụru-mini, anya a nụ lele riro bẹkwnu.  
\v 15 Ọchi a lawụru nụ lele ọla be gbarụ bẹkwnu nụ rime ite bẹkwnu, nkọli a naadna lele agịda mini.  
\v 16 O ji mbọ ẹsau n'akarikwnunga a, ama-ọgwnu nwernu ruwhnu lawụru tụga bụko neehi n'ọnu a nọowhuya, ruwhnu a noonwu lele ẹhnam n'esilawụru iwhnehnie. 
\p  
\v 17 Nga me whnụrnu a, m dna n'ẹli n'ọchi a lele nye nwụrnu ọnwu. Kọvu ọ tụkwasiri m akarikwnunga a, kaa, “Ogwnu tụ́ko ị, mawa bụ Nye Mbọm nụ Nye Ipne-aznụ.  
\v 18 M zị m bụdnu. M nwụrnu m ẹnwu, kọvu le, m zị m bụdnu tim tọm. M ji m snambị ẹnwu nụ ẹli rẹnwu. 
\p  
\v 19 “Gbasị nhne ị whnụrnu n'ọkwu-kwo, nhne zị kịtna, nụ nhne jeeme nụ ruwhnu.  
\v 20 Ka bụ nhne miri emi ke mbọ ẹsau wam ị whnụrnu n'akarikwnunga m, nụ nhne be tụkwasi tọnji ẹsau wam be wụru golu. Mbọ ẹsau wam bụ enine izi ọgbako Chiokike ẹsau, nhne be tụkwasi tọnji ẹsau wam ị whnụrnu bụ ọgbako ẹsau.” 
\c 2  
\s1 Izi ele Efesọsi 
\p  
\v 1 Gbaznenu enine izi ke ọgbako Chiokike ke zị n'Efesọsi ọkwukwo: Hite n'ọnu nye wam ji mbọ ẹsau wam n'akarikwnunga a, nye neezne izne n'esilawụru nhne be tụkwasi tọnji ẹsau wam.  
\v 2 M magwụ m nhne anụ neeme. Anụ nọodogbu ẹhni anụ n'ẹrnu nụ ọsnuta mkpọma anụ. Anụ kwéle o kwubnanya ele arụru-ẹli, anụ kparụ ele kwuru ẹhni be ele izi iru, kọvu be bụ́o, anụ whnụ nụ be bụ ele aghalaghala.  
\v 3 Anụ jiri ọsuta mkpọma nagidne awhnụwhnu anụ tarụ kwnornu rẹwhna m, anụ kwéle rikne gwụ anụ. 
\p  
\v 4 Kọvu m nwernu m otu nhne megidne anụ, anụ zị́ma n'ọwhnun'anya lele kpa anụ neeme nụ mbọm.  
\v 5 Anụ chenwanya hne anụ dnarnụ. Anụ hi nụ mmehie anụ tụhnasna, rnụ ẹrnu mbọm anụ rnụrnu. Ọ bụru nụ anụ jọ́otuhnasna hite nụ mmehie anụ, m jaavakwnusi anụ wara wara, gweme nhne be tụkwasi tọnji anụ nụ hne ọ zị, okwolem ma anụ tụhnasnarnu.  
\v 6 Kọvu anụ nwernu otu nhne bụru ọma, anụ sno ẹrnu ele Nikolata irno lele kpa me snornu a irno. 
\p  
\v 7 Nye nwernu nsnị, ọ nụrnu nhne Enine Nsọ naakanụ kpakara ọgbako Chiokike. Nye megburu, m jeenye a rikne o ri mkpụru isisi ke bụdnu ke zị n'ọbna Chiokike. 
\s1 Izi ele Sịmaina 
\p  
\v 8 Gbaznenu enine izi ke ọgbako Chiokike ke zị nụ Sịmaina ọkwukwo: Hite n'ọnu nye wam bụ Nye Mbọm nụ Nye Ipne-aznụ, nye nwụrnu, zịri kwno bụdnu.  
\v 9 M magwụ m awhnụwhnu anụ naata. M magwụ m nụ anụ bụ ele mboni, kọvu anụ bụ ele nwernu ẹkwnu k'agịda. M magwụ m ọka ọjo ele ka nụ be bụ ele Ju nookwugidne anụ, kọvu be bụ́o, be bụ ele ọro ọgbako Setani.  
\v 10 Ogwnu tụ́ko anụ kwnornu awhnụwhnu anụ jaata. Le Setani jeeyisi agwna anụ n'ikelu ma be kpa anụ iru. Anụ jeenwe ọkpagbu nri ọbochi. Anụ bụru ele kwesiri ọkwnata mkpọma dụ n'ẹnwu, m jeenye anụ okpu-eze ke bụ bụdnu. 
\p  
\v 11 Nye nwernu nsnị, ọ nụrnu nhne Enine Nsọ naakanụ kpakara ọgbako Chiokike. Nye megburu, ẹnwu ke ẹbo jóogbu a. 
\s1 Izi ele Pegamọsi 
\p  
\v 12 Gbaznenu enine izi ke ọgbako Chiokike ke zị nụ Pegamọsi ọkwukwo: 
\p Hite n'ọnu nye wam nwernu ama-ọgwnu ke nwernu ruwhnu lawụru zị bụko.  
\v 13 M magwụ m hne anụ wu bụ hne ngadna Setani zị. Anụ jidnesiri rẹwhna m rikne, anụ túwhule ọkwnata mkpọma anụ nụ hne me zị, ọ bụbedi nga be gburu Antipasi nye akebne m nye kwesiri ọkwnata mkpọma n'esilawụru anụ hne Setani wu.  
\v 14 Kọvu m nwernu m nhne ele nụ ele megidne anụ. Agwna ele noosno iznizni Balam nye znirni Balakị kpa o jeeme rụmu Izirẹli mmehie hite n'ori nhne be jiri kwanụ rẹnwu arịohna nụ hite n'ome ọyi.  
\v 15 Agwna ele noosno iznizni ele Nikolata zị masị n'esilawụru anụ.  
\v 16 Anụ hi nụ mmehie tụhnasna, ọ bụ́o kpam, m jaavakwnusi anụ wara wara, gweru ama-ọgwnu hi n'ọnu m whụya lụsi ele ka ọgwnu. 
\p  
\v 17 Nye nwernu nsnị, ọ nụrnu nhne Enine Nsọ naakanụ kpakara ọgbako Chiokike. Nye megburu, m jeenye a agwna mana ke tugwaru otugwa. M jeenye masị a otu akaworugwu abọchna ke be gbakwasịri rẹwhna ikne n'olu a, ọ zá nye berere marnụ a, okwolem nye wam nahịaru a. 
\s1 Izi ele Taịtira 
\p  
\v 18 Gbaznenu enine izi ke ọgbako Chiokike ke zị nụ Taịtira ọkwukwo: Ka bụ nhne Nnwọ Chiokike kwuru, nye wam anya a lawụru nụ lele bẹkwnu, nye ọchi a lawụru noonwu lele ọla chnarnụ achna.  
\v 19 M magwụ m nhne anụ neeme. M magwụ m ọwhnun'anya anụ, nụ ọkwnata mkpọma anụ, nụ izi anụ, nụ ọsnuta mkpọma anụ. M magwụ m masị nụ ẹrnu anụ kịtna kakwo ke mbọm. 
\p  
\v 20 Kọvu m nwernu otu nhne megidne anụ. Anụ gharụru nwerinya wam bụ Jezibẹli n'esilawụru anụ. Nwerinya ka kwuru ẹhni a nye ọwhnurninya Chiokike, neezni ele izi m kpa be mee ọyi, nụ o ri nhne be jiri kwa rẹnwu, nooduhie ele badnụ.  
\v 21 M nyernu m a ige ma ọ tụhnasna nụ mmehie ome ọyi, o kwéle.  
\v 22 Le, m jọotubna n'ọkpata ya nụ ele ọyi a, be jaata awhnụwhnu k'agịda, okwolem ma be tụhnasnarnu hite nụ nhne ọjo be mụhiaru n'aka a.  
\v 23 M joogbu rụmu a, ma kpakara ọgbako Chiokike mahịa nụ mawa bụ nye wam noonyosna mkpọma nụ echiche ke rụmu badnụ. M jọokwuhnasi nye ọbula lele kpa ẹrnu a jiri zịri.  
\v 24 Kọvu agwna anụ gwnarnụ nụ Taịtira, ele snóge iznizni ọjo ka, ele máa nhne be nookwu nhne tugwaru otugwa ke Setani, m jéenye anụ ivu rụna berere.  
\v 25 Kọvu anụ jidnesi rikne nhne anụ ji tem m va. 
\p  
\v 26 Nye megburu, bịta ikwu-ọnu m dụ okwukwo, 
\q1 m jeenye a rikne hne kpakara mba zị. 
\q1  
\v 27 O jeeji mkpara rugwe nẹechi be, 
\q2 ọ jẹeliwa be lele kpa be lịwa itechi, 
\m  
\v 28 lele kpa me nahịaru iknernema n'aka Nda m. M jeenye a mbọ ọsisi.  
\v 29 Nye nwernu nsnị, ọ nụrnu nhne Enine Nsọ naakanụ kpakara ọgbako Chiokike. 
\c 3  
\s1 Izi ele Sadisi 
\p  
\v 1 Gbaznenu enine izi ke ọgbako Chiokike ke zị Sadisi ọkwukwo: Ka bụ nhne nye wam ji enine ẹsau Chiokike n'aka a, nụ mbọ ẹsau. M magwụ m nhne anụ neeme. M magwụ m nụ anụ nwernu rẹwhna nụ anụ zị bụdnu, kọvu anụ nwụrnu ọnwu.  
\v 2 Anụ tnenya, jikwasi nhne ke gwnarnụ matị ọ nwụ rikne, kwnornu nụ m whnụ́ge m ẹrnu anụ ke zuru ozu nụ ruwhnu Chiokike m.  
\v 3 Anụ chenwanya nhne anụ nahịaru, ke anụ nụrnu, anụ mee be. Anụ hi nụ mmehie anụ tụhnasna. Ọ bụru nụ anụ jéetnenya, m jaavakwnusi anụ lele nye buznu, anụ jáamahịa ige me jaava. 
\p  
\v 4 Kọvu anụ nwernu badnụ ele nụ ele nụ Sadisi ele mérula awura be. Be joowo awura abọchna snornu m zne izne kwnornu nụ be kwesiri.  
\v 5 Nye megburu kpa, be joowote a awura abọchna, m jóokwnome rẹwhna a n'ọkwukwo ke bụdnu. M jookwuhịa rẹwhna a nụ ruwhnu Nda m ya nụ ruwhnu ele enine izi a.  
\v 6 Nye nwernu nsnị, ọ nụrnu nhne Enine Nsọ naakanụ kpakara ọgbako Chiokike. 
\s1 Izi ele Filadefịa 
\p  
\v 7 Gbaznenu enine izi ke ọgbako Chiokike ke zị nụ Filadefịa ọkwukwo: Ka bụ nhne nye wam zị nsọ nụ nye ezi ọka kwuru, nye jigwu snambị Devidi, nye ọ bụru nụ ọ gbama ọnuhna, ọ zá nye nwernu rikne ọ gbasni a, nye gbasni ọnuhna, ọ zá nye nwernu rikne ọ gbama a.  
\v 8 M magwụ m nhne anụ neeme. Le, m gbamannụ m anụ ọnuhna ke ọ zá nye nwernu rikne gbasni, kwnornu nụ anụ nwernu iknernema matị, kọvu anụ bịtaru ikwu-ọnu m, anụ gọ́nahorula rẹwhna m.  
\v 9 Anụ jọowhnu nhne me jeeme ele ọro ọgbako Setani, ele ka nụ be bụ ele Ju, kọvu be bụ́o, be bụ ele aghalaghala, m jeeme be va dna n'ẹli n'ọchi anụ, be jaamahịa nụ m whnụrnu m anụ n'anya.  
\v 10 Kwnornu nụ anụ bịtaru ikwu-ọnu m, snụta ovu, m jaabịta masị anụ n'ige ọrnurna ke jaadnakwasị kpakara ọwa, ọ rna ele wu n'ọwa ọrnurna. 
\p  
\v 11 Le, m vawa wara wara, anụ jidnesi nhne anụ ji rikne, ọ zị nye berere nahọru anụ okpu-eze anụ.  
\v 12 Nye megburu, m jeeme a nsnụsnu Ọro Nsọ Chiokike m. O jéehi nụ rime a whọga berere. M jaagbakwasị rẹwhna Chiokike m n'olu a, ya nụ rẹwhna ọhna ikne Chiokike m, ke bụ Jerusẹlem ikne, ke hi n'oligwe n'aka Chiokike m hiedna. M jaagbakwasị a rẹwhna ikne m n'olu a.  
\v 13 Nye nwernu nsnị, ọ nụrnu nhne Enine Nsọ naakanụ kpakara ọgbako Chiokike. 
\s1 Izi ele Laodisia 
\p  
\v 14 Gbaznenu enine izi ke ọgbako Chiokike ke zị nụ Laodisia ọkwukwo: Ka bụ nhne Amịm kwuru, nye akebne kwesiri be kwnata a mkpọma nụ nye ezi ọka, nye nẹechi kpakara nhne Chiokike keru.  
\v 15 M magwụ m nhne anụ neeme. Anụ kpéle bẹkwnu, anụ jị́la iyi. Ọ jọoburu ọma nụ anụ kperu bẹkwnu mọbu nụ anụ jịri iyi.  
\v 16 Kọvu kwnornu nụ anụ zị marna marna, anụ kpéle bẹkwnu, anụ jị́la iyi, m jọogbohala anụ n'ọnu m.  
\v 17 Anụ kwuru, “M barụ m eze, m nwernu m ẹkwnu, ọ zá nhne naara m,” kọvu nụ anụ máa nụ anụ bụ ele nọowhnuji anya, nụ ele be kwesiri ọ dọnu obirizi, ele mboni, ele isni nụ ele gba ẹto.  
\v 18 Me zni anụ ezni, anụ zụnahoru m golu be snụrnu, ma anụ nwernu ẹkwnu, nụ awura abọchna, ma anụ kpusni ẹto anụ gbagwụ, tna ẹgwnumisi n'anya anụ ma anụ whnụrnu ọsno.  
\v 19 M neebigbọ kpakara ele me whnụrnu n'anya, naapnịa masị be nhne. Anụ gbalị tụhnasna, hi nụ mmehie whụya.  
\v 20 Le, m gwuzogwu m n'ọnuhna, nooznu aka. Nye ọbula ke nụrnu nkọli m, gbama ọnuhna, m jaabnazne n'ọro a, snornu a ri wiri, ya snornu m masị ri wiri. 
\p  
\v 21 Nye megburu, m jeenye a rikne o snornu m dazịri ẹli nụ ngadna eze m, lele kpa me megburu, m snornu Nda m dazịri ẹli nụ ngadna eze a.  
\v 22 Nye nwernu nsnị, ọ nụrnu nhne Enine Nsọ naakanụ kpakara ọgbako Chiokike. 
\c 4  
\s1 Ngadna eze ke zị n'oligwe 
\p  
\v 1 Nga nhne ka mekworu, m whnụrnu m, le, otu ọnuhna gbamarnụ n'oligwe. Nkọli wam me nụrnu nụ mbọm ke dnarnụ lele ọkwodu karụ, “Vaa hna, m jeegesi i nhne jeemerịri nụ ruwhnu.”  
\v 2 Ngangam, m zị m n'Enine, m whnụrnu m nụ rime oligwe otu ngadna eze nụ nye dazị n'olu a.  
\v 3 Nye wam dazị nụ ngadna eze wam, ruwhnu a noogbu marna marna lele akaworugwu jasịpa nụ sadisi, eke nụ egwurugwu hnirni ngadna eze wam gburugburu ke naachna lele emiradi.  
\v 4 Nri ngadna eze lawụru nụ ẹno berere gbarụ ngadna eze wam gburugburu, ele okno badnụ nri lawụru nụ ẹno dazị n'olu ngadna eze berere wam woru awura abọchna, kpuru okpu-eze golu nụ risi be.  
\v 5 Amụma nụ egbe oligwe nụ ọdidna hi nụ ngadna eze wam naadna. Tọnji ẹsau zị nụ ruwhnu ngadna eze wam noonwu bẹkwnu, ke bụ enine ẹsau wam Chiokike.  
\v 6 Osimini nụ lele nyno nọowhnu ọsno zị nụ ruwhnu ngadna eze wam. 
\p N'esilawụru ngadna eze wam ya nụ gburugburu a bụ nhne ẹno zị bụdnu bụ anya anya ruwhnu nụ aznụ zị.  
\v 7 Nhne ke mbọm nụ lele odum, ke ẹbo nụ lele nnwọ ehni, ke ẹto nwernu ruwhnu lele ruwhnu badnụ, ke ẹno nụ lele igno neewhe ewhe.  
\v 8 Nhne zị bụdnu ẹno wam, ke ọbula nwernu aka-nkwu isunu, kpakara ẹhni be bụ anya anya. Be kpúsni ọnu be iwhnehnie nụ abalị, be nọogwnu eri naakaa, 
\q1 “Nsọ, nsọ, nsọ 
\q2 bụ Nyenwe aị Chiokike ke Meli Nhne Dum, 
\q1 Nye zị nụ mbọm, nye zị kịtna, nye jaava.” 
\p  
\v 9 Kpa nhne wam zị bụdnu zị neenye a igwugwu nụ ọson'anya, nọotunu nye wam dazịgwu nụ ngadna eze wam mmamma, nye zị bụdnu ọkwnukokwnu,  
\v 10 ele okno badnụ nri lawụru nụ ẹno wam dna n'ẹli nụ ruwhnu nye wam dazịgwu nụ ngadna eze, kpọ risi ẹli nụ ruwhnu nye wam zị bụdnu ọkwnukokwnu. Be tụbita okpu-eze be nụ ruwhnu ngadna eze wam, kaa, 
\q1  
\v 11 “Ị bụ nye kwesiri, Nyenwe aị Chiokike, 
\q2 ọ nahọru igwugwu nụ ọson'anya, nụ iknernema, 
\q1 kwnornu nụ ọ bụ jịwa keru kpakara nhne hite nụ echiche i, 
\q2 jị nyernu be bụdnu.” 
\c 5  
\s1 Ọkwukwo nụ Nnwọ Atnụrnu wam 
\p  
\v 1 M whnụrnu m otu ọkwukwo n'akarikwnunga nye wam dazị nụ ngadna eze wam, be gbarụ a nhne ruwhnu nụ aznụ, be kasịri a akara ẹsau.  
\v 2 M whnụrnu m otu enine izi nwernu rikne ji okno nkọli neesi okokoba, naakaa, “Ndaa nye kwesiri ọ gbaji akara ẹsau wam nụ o kpume ọkwukwo wam?”  
\v 3 Kọvu ọ zá nye be whnụrnu n'oligwe nụ ọwa mọbu nụ mkpururu ọwa, bụ nye kwesiri o kpume ọkwukwo wam mọbu lebna anya nụ rime a.  
\v 4 M kwna ẹkwna k'agịda kwnornu nụ ọ zá nye be whnụrnu kwesiri o kpume ọkwukwo wam mọbu lebna anya nụ rime a.  
\v 5 Otu nụ rime ele okno badnụ wam kanụ m, “Ị kwnáma ẹkwna, le, Odum ke ẹbnurnu Juda,\f + \fr 5:5 \fq Odum ke ẹbnurnu Juda \ft Jenesisi 49:9\f* Mgbarẹgwnugwnu Devidi,\f + \fr 5:5 \fq Mgbarẹgwnugwnu Devidi \ft Azaya 11:1, 10\f* o megbulem, o nwernu rikne o kpume ọkwukwo wam, nụ ọ tọma akara ẹsau wam.” 
\p  
\v 6 Ige wam m whnụrnu m otu Nnwọ Atnụrnu gwuzo n'esilawụru ngadna eze wam, ma nụ esilawụru nhne ẹno wam zị bụdnu ya nụ ele okno badnụ wam, lele nụ be gburu a ogbu. O nwernu mfu ẹsau, nụ anya ẹsau ke bụ enine ẹsau wam Chiokike, ke o zihalaru nụ rime kpakara ọwa.  
\v 7 Nnwọ Atnụrnu wam zne nahọru nye wam dazị nụ ngadna eze wam ọkwukwo n'akarikwnunga a.  
\v 8 Nga ọ nahọruru a ọkwukwo wam, nhne ẹno wam zị bụdnu nụ ele okno badnụ nri lawụru nụ ẹno wam dna n'ẹli nụ ruwhnu Nnwọ Atnụrnu wam, kpakara be ji ọbo be n'aka, ya nụ obele golu ke isensi jihịaru, ke bụ okpukpe ele nsọ.  
\v 9 Be gwnụ eri ikne, 
\q1 “I kwesiri ọ nahọru ọkwukwo wam, 
\q2 nụ ọ tọma akara a, 
\q1 kwnornu nụ be gburu i, 
\q2 i gweru ọvnarna ị gbahịa ele ke Chiokike 
\q2 hite nụ kpakara ẹbnurnu, nụ ikwu-ọnu, hite nụ mba nụ ele badnụ. 
\q1  
\v 10 I mernu be bụru mbam ele ọkwa arịohna, ke jeekpenu Chiokike, 
\q2 be jọobu ele eze nẹechi ọwa.” 
\p  
\v 11 M le anya, m nụrnu m nkọli agịda enine izi gbarụ ngadna eze wam gburugburu, nụ nhne ẹno wam zị bụdnu nụ ele okno badnụ, pokwu nụ pokwu nụ pokwu ndasị, nụ pokwu ndasị nụ ndasị.  
\v 12 Be nọogwnu eri nụ okno nkọli, naakaa, 
\q1 “Nnwọ Atnụrnu wam be gburu kwesiri 
\q1 ọ nahọru rikne, nụ ẹkwnu nụ akọniche, nụ iknernema 
\q2 nụ ọson'anya nụ igwugwu, nụ ọznarni.” 
\p  
\v 13 M nụrnu m hne kpakara nhne zị bụdnu zị n'oligwe, n'ọwa, nụ mkpururu ọwa, kpakara nhne zị bụdnu ke zị n'okno osimini nụ kpakara nhne zị nụ rime be, naakaa, 
\q1 “Ọznarni nụ ọson'anya nụ igwugwu nụ rikne zịnu 
\q2 nye wam dazị nụ ngadna eze, ya nụ Nnwọ Atnụrnu wam tim tọm.” 
\p  
\v 14 Nhne ẹno wam zị bụdnu, kaa, “Amịm.” Ele okno badnụ wam dna n'ẹli, kpọnu Chiokike nụ Nnwọ Atnụrnu risi ẹli. 
\c 6  
\s1 Akara ẹsau wam 
\p  
\v 1 M whnụrnu m nga Nnwọ Atnụrnu wam tọmarnu akara ke mbọm. Otu nhne zị bụdnu ẹno wam ji nkọli dnarnụ lele egbe oligwe kaa, “Vaa.”  
\v 2 M le anya, le otu ịyinya rịchna, nye gbagwụ a ji otu mgbata, be nyee a okpu-eze, ọ whọga nọolugbu, neemegbu. 
\p  
\v 3 Nnwọ Atnụrnu wam tọma akara ke ẹbo, m nụrnu m nhne ẹno wam zị bụdnu ke ẹbo, naakaa, “Vaa.”  
\v 4 Le, ịyinya berere naachna ihie ihie, be nyernu nye gbagwụ a rikne o gweme udno n'ọwa, mee ele badnụ noogbu ibne be, be nyernu a ama-ọgwnu hna ezi. 
\p  
\v 5 Nga Nnwọ Atnụrnu wam tọmarnu akara ke ẹto, m nụrnu m hne nhne ẹno wam zị bụdnu ẹto karụ, “Vaa.” M le anya whnụ ịyinya neeji riji, nye gbagwụ a ji nhne be nọotu nhne n'aka a.  
\v 6 M nụrnu m nkọli n'esilawụru nhne ẹno wam zị bụdnu, naakaa, “Otu ntụtu ịkpa wheti bụ ọgwo ẹrnu otu ọbochi, ntụtu ịkpa balị ẹto ọgwo ẹrnu otu ọbochi. Kọvu anụ lúlu mọno olivu nụ manya vaịni.” 
\p  
\v 7 Nnwọ Atnụrnu wam tọma akara k'ẹno, m nụrnu m nkọli nhne zị bụdnu k'ẹno karụ, “Vaa.”  
\v 8 M le anya, otu ịyinya ogbu-nụ-orio, rẹwhna nye dazị n'olu a bụ Ẹnwu, Ẹli Rẹnwu sno a n'aznụ. Be nyernu a rikne hne otu nga nụ nga ẹno ke ọwa zị, ma o gweru ama-ọgwnu nụ ọkwnunyo gbu be, ma nrịria ọjo nụ ọjo anọhia ke ọwa. 
\p  
\v 9 Nnwọ Atnụrnu wam tọmarnu akara ke isne, m whnụrnu m mkpụru ovu kpakara ele be gburu kwnornu ikwu-ọnu Chiokike nụ ama be gbarụ nụ mkpururu ojo arịohna.  
\v 10 Be ji okne nkọli neesi okokoba, naakaa, “Nyenwe aị zị nsọ, ị bụ ezi, dụ ngele, hne i jeekpe ele zị n'ọwa ikpe, megwnahịa ọvnarna aị?”  
\v 11 Be nyernu nye ọbula nụ rime be iwo awura abọchna, be kanụ be, be zukwaru inwe ige matị, tem ọnu ọgwnugwnu ele izi ibne be nụ rụmu nda be, ele be joogbu zute. 
\p  
\v 12 Nnwọ Atnụrnu wam tọmarnu akara ke isunu, okne ẹli otne enye dnarnụ, ẹhnam ji riji lele ikpe mkpe, ẹnwa chna ihie ihie lele ọvnarna.  
\v 13 Mbọ hi n'oligwe naadna n'ọwa lele ike isisi be kwu figi chná achna naadna nga ruwhere neewhe.  
\v 14 Be pịakota oligwe lele ọkwukwo, rugwu nụ ẹli ọhia esilawụru whọga n'ọnodi be. 
\p  
\v 15 Ele eze ke ọwa nụ ele dikne, ele nẹechi ele ọgwnu ele barụ eze, ele dimkpa, nye ọbula, ma ọhi ma nye nwernu ẹhni a, tugwa nụ rime ọgba nụ iketa rugwu.  
\v 16 Be kanụ rugwu kwu nụ rugwu matị, “Dnagidne aị, kpusni aị n'anya nye wam dazị nụ ngadna eze, ya nụ ovu owe ẹhni Nnwọ Atnụrnu wam.  
\v 17 Kwnornu nụ okne ọbochi ovu owe ẹhni be valẹm. Nyele joogwuzoli?” 
\c 7  
\s1 Be karụ 144,000 ele badnụ  //  akara 
\p  
\v 1 Nga nhne ka whemernu, m whnụrnu m enine izi ẹno gwuzo nụ ngeri ẹno ke ọwa, knernụ ruwhere k'ọwa n'aka, ma ruwhere gharụ o whe n'ọwa, ma n'osimini mọbu n'olu isisi ọbula.  
\v 2 M whnụrnu m enine izi berere hi n'ọbosi ẹhnam nọowhuya, o ji akara Chiokike ke zị bụdnu n'aka a, o ji okne nkọli naakanụ ele enine izi ẹno wam Chiokike nyernu rikne o lulu ọwa nụ osimini,  
\v 3 kaa, “Anụ lúlu ọwa, mọbu osimini, mọbu isisi, tem a ka ele izi Chiokike akara n'egedege ruwhnu be.”  
\v 4 M nụrnu m ọnu ọgwnugwnu ele be karụ akara n'egedege ruwhnu be, be bụ otu riwhu nụ nri ẹno nụ pokwu ẹno, hite nụ kpakara ẹbnurnu Izirẹli.  
\v 5 Be bụ hite nụ ẹbnurnu Juda, nri nụ pokwu lawụru, ẹbnurnu Rubẹni, nri nụ pokwu lawụru, ẹbnurnu Gadị, nri nụ pokwu lawụru,  
\v 6 hite nụ ẹbnurnu Asa, nri nụ pokwu lawụru, ẹbnurnu Nafịtali, nri nụ pokwu lawụru, ẹbnurnu Manase, nri nụ pokwu lawụru,  
\v 7 hite nụ ẹbnurnu Simiọni, nri nụ pokwu lawụru, ẹbnurnu Livaị, nri nụ pokwu lawụru, ẹbnurnu Ịsaka, nri nụ pokwu lawụru,  
\v 8 hite nụ ẹbnurnu Zebụloni, nri nụ pokwu lawụru, ẹbnurnu Josefu, nri nụ pokwu lawụru, ẹbnurnu Bẹnjamini, nri nụ pokwu lawụru. 
\s1 Igbudu ele badnụ wam 
\p  
\v 9 Nga nhne ka mekworu, m le anya whnụ igbudu badnụ ọ zá nye nwernu rikne gwnụli ọnu. Be hi nụ kpakara mba nụ ẹbnurnu, nụ ẹli, nụ ikwu-ọnu va, be gwuzoru nụ ruwhnu ngadna eze nụ nụ ruwhnu Nnwọ Atnụrnu wam, be wo awura abọchna, be ji masị igwugwu bụkwu n'aka be.  
\v 10 Be ji okne nkọli naakaa, 
\q1 “Ọznohia aị hi n'aka Chiokike, 
\q2 nye dazị nụ ngadna eze, 
\q2 ya nụ Nnwọ Atnụrnu.” 
\p  
\v 11 Kpakara ele enine izi gwuzo gba ngadna eze wam gburugburu nụ ele okno badnụ wam nụ nhne ẹno wam zị bụdnu, dna kpute ruwhnu n'ẹli nụ ruwhnu ngadna eze wam, kpọnu Chiokike risi ẹli.  
\v 12 Be kaa, 
\q1 “Amịm! Ngọzi nụ igwugwu 
\q1 nụ akọniche, nụ ọtu mmamma nụ ọson'anya 
\q1 nụ rikne nụ iknernema 
\q2 zịnu Chiokike dụ ọkwnukokwnu. 
\q1 Amịm.” 
\p  
\v 13 Otu nye okno badnụ sịkwa m, “Ele ka wogwu iwo awura abọchna be bụ ele ke ele? Ndaa hne be hi va?” 
\p  
\v 14 M sa a, “Nda-aị-kwu, m máam, jị magwụ.” 
\p Ọ kanụ m, “Ele ka bụ ele hiri n'okne mmekpẹhni wam whụya, be snụrnu iwo be, mee be zịri rịchna nụ rime ọvnarna Nnwọ Atnụrnu wam.  
\v 15 Kam kpayarụ, 
\q1 be jiri gwuzoru nụ ruwhnu ngadna eze Chiokike, 
\q1 be jeekpenu a iwhnehnie nụ abalị nụ rime Ọro Nsọ a. 
\q1 Nye wam dazị nụ ngadna eze jaagbasa ọro-ẹka a, be wuru nụ rime a. 
\q1  
\v 16 Wiri jọ́ogwnu be berere, 
\q2 akpịri jọ́okpo be bẹkwnu berere, 
\q1 ẹhnam jọ́omu kwno be berere, 
\q2 whụruwhuru ẹhni jéeme kwno be berere. 
\q1  
\v 17 Kwnornu nụ Nnwọ Atnụrnu nye ke zị n'esilawụru ngadna eze wam jọobu nye nọoznu be lele atnụrnu. 
\q2 O joodu be zne nụ risi mini ke bụdnu, 
\q2 Chiokike jookwnosnama anya-mini ẹkwna n'anya be.” 
\c 8  
\s1 Akara ke ẹsau 
\p  
\v 1 Nga Nnwọ Atnụrnu wam kpumernu akara ke ẹsau, oligwe dnarnụ bii dụ ichichi awa. 
\p  
\v 2 M whnụrnu m enine izi ẹsau ele gwuzo nụ ruwhnu Chiokike, be nyernu be ọkwodu ẹsau. 
\p  
\v 3 Enine izi berere ke jigwu nhne isensi golu varụ gwuzoru nụ ruwhnu ojo arịohna, be nyernu a agịda isensi, o gweru a yikọta nụ okpukpe ele nsọ Chiokike, gweru a kwa arịohna n'olu ojo arịohna golu ke zị nụ ruwhnu ngadna eze wam.  
\v 4 Rụnwurnu isensi wam nụ okpukpe ele nsọ Chiokike lizọ nụ ruwhnu Chiokike hite n'aka enine izi wam.  
\v 5 Enine izi wam gweru nhne isensi wam gharụ bẹkwnu n'ojo arịohna, ghasa a nụ rime ọwa. Agịda egbe oligwe nụ ọdidna nụ amụma nụ ẹli otne enye dnarnụ. 
\s1 Ọkwodu ẹsau wam 
\p  
\v 6 Enine izi ẹsau wam ji ọkwodu ẹsau jiknernu ọ gbụ be. 
\p  
\v 7 Enine izi ke mbọm gbụ ọkwodu a, mkpụru mini nụ bẹkwnu gwarụ ọvnarna wụsa n'ọwa, otu-ibewa nụ nga ẹto ke ọwa rne bẹkwnu, otu-ibewa nụ nga ẹto ke isisi nụ kpakara achara bụdnu rnernu bẹkwnu. 
\p  
\v 8 Enine izi ke ẹbo gbụ ọkwodu a, be tụbna nhne nụ lele rugwu okpotokpo neerne bẹkwnu nụ rime osimini, otu-ibewa nụ nga ẹto ke osimini ghọ ọvnarna.  
\v 9 Otu-ibewa nụ nga ẹto ke nhne zị bụdnu nụ rime osimini nwụma, otu-ibewa nụ nga ẹto ke ọgbo mini kpu. 
\p  
\v 10 Enine izi ke ẹto gbụ ọkwodu a. Otu okne mbọ hi n'oligwe dna, noonwu lele tọnji dnakwasị otu-ibewa nụ nga ẹto mini, ma nụ risi mini.  
\v 11 Rẹwhna mbọ wam bụ Nlulu. Otu-ibewa nụ nga ẹto mini noolu nlulu, agịda ele badnụ nwụrnu kwnornu nụ be nwọrnu mini wam. 
\p  
\v 12 Enine izi ke ẹno gbụ ọkwodu a. Be lulu otu-ibewa nụ nga ẹto ẹhnam, nụ otu-ibewa nụ nga ẹto ẹnwa, nụ otu-ibewa nụ nga ẹto mbọ, ke kpayarụ otu-ibewa nụ nga ẹto iwhne be zị́ma noonwu, otu-ibewa nụ nga ẹto ke ọbochi nwée iwhne ya nụ otu-ibewa nụ nga ẹto ke abalị. 
\p  
\v 13 M leru m anya, m nụrnu m otu igno neewhe n'esilawụru oligwe, gweru okne nkọli neesi okokoba, “Awhnụwhnu! Awhnụwhnu! Awhnụwhnu zịnu kpakara ele wu n'ọwa nga be jọonu ọdidna ọkwodu ke ele enine izi ẹto ke gwnarnụ jọogbu.” 
\c 9  
\p  
\v 1 Enine izi ke isne gbụ ọkwodu a. M whnụrnu m otu mbọ hiri n'oligwe dna n'ọwa, be nyee a snambị ọnuhna olulu awhnụwhnu.  
\v 2 Mbọ wam tụma ọnuhna olulu awhnụwhnu, rụnwurnu hi nụ rime a whụya nụ lele rụnwurnu hi n'okne ite bẹkwnu, iwhne ẹhnam nụ ruwhere gbarụ ọchichiri kwnornu rụnwurnu hi n'olulu awhnụwhnu wam whụya.  
\v 3 Igwurube hi nụ rụnwurnu wam whụya n'olu ọwa, be nyernu be rikne lele akpị ke ọwa.  
\v 4 Be kanụ be, be lúlu achara mọbu isisi, mọbu achara bụdnu berere, kọvu be gba nye ọbula ke nwée akara Chiokike n'egedege ruwhnu a.  
\v 5 Igwurube wam nwée rikne o gbu be, kọvu be ta be awhnụwhnu ẹnwa isne. Nhne igbugbu be nụ lele nye akpị gbarụ.  
\v 6 N'ẹnwa isne ka, ele badnụ ka joopio ẹnwu joogbu be, kọvu be jọ́owhnu ẹnwu, ẹnwu jọogwnu be, kọvu ẹnwu jaagba ẹso. 
\p  
\v 7 Igwurube wam nụ lele ịyinya jiknernu o zne ọgwnu, be kpu nhne nụ lele okpu-eze golu nụ risi be, ruwhnu be nụ lele ruwhnu badnụ.  
\v 8 Rukeru-ize risi be nụ lele rukeri-ize nyerinya, ize be nụ lele ize odum.  
\v 9 Mbno mkpọma be nụ lele mbno rugwe, ọdidna aka-nkwu be naadna lele ọgbo-ẹli agịda ịyinya nọodopnu neezne ọgwnu.  
\v 10 Ọdnu be nụ lele akpị, be nwernu nhne ọgbugba n'ọdnu be, nwe masịri rikne n'ọdnu ọ kpakna ele badnụ ẹhni ẹnwa isne.  
\v 11 Be nwernu eze nẹechi be, nye bụ enine izi olulu awhnụwhnu. Nye rẹwhna a n'ọnu Hiburu bụ Abadọni, n'ọnu Giriki, Apoloni, ke bụ nye noolulu nhne. 
\p  
\v 12 Nhne awhnụwhnu ke mbọm kwolem, nhne awhnụwhnu lawụru berere vawa. 
\p  
\v 13 Enine izi ke isunu gbụ ọkwodu a, m nụrnu m otu nkọli hi n'ahnịo nụ ngeri ẹno ke ojo arịohna golu wam bụ ke gwuzo nụ ruwhnu Chiokike whụya.  
\v 14 Nkọli wam kanụ enine izi ke isunu wam ke gbụru ọkwodu, “Sịgbasi enine izi ẹno wam ke be knernụ eriri n'okne Osimini Uferetisi.”  
\v 15 Be sịgbasi enine izi ẹno wam, ke be jiknernernu n'ọtnu-ige ka n'ọbochi ka, nụ ẹnwa ka, n'awha ka o gbu otu-ibewa nụ nga ẹto ke kpakara ele badnụ.  
\v 16 M nụrnu m ọnu ọgwnugwnu ele ọgwnu gba ịyinya bụ riwhu pokwu ndasị lawụru. 
\p  
\v 17 Nụ rime ọwhnurninya wam, m whnụrnu m ịyinya nụ ele naagba be, be nwernu mbno mkpọma naachna ihie ihie lele bẹkwnu, lele jasịnti, nụ rugwu bẹkwnu, risi ịyinya wam nụ lele risi odum, bẹkwnu nụ rụnwurnu nụ rugwu bẹkwnu neehi n'ọnu be nọowhuya.  
\v 18 Bẹkwnu nụ rụnwurnu nụ rugwu bẹkwnu ke hi n'ọnu ịyinya wam nọowhuya gburu otu-ibewa nụ nga ẹto ke ele badnụ.  
\v 19 Kwnornu nụ iknernema be hi n'ọnu be ya nụ ọdnu be. Ọdnu be nụ lele agwọ, ke be ji risi be neemeru ele badnụ ẹhni. 
\p  
\v 20 Ele badnụ gwnarnụ ke nhne igbugbu ka gbúle, kwéle ọ sịgbasi nhne aka be tụru, be kwéle ọ sịgbasi o kpenu rụmu rẹnwu ọjo, nụ rẹnwu golu nụ ke siliva, nụ ọla nụ akaworugwu nụ ke isisi, ke zá nọowhnu ọsno, zá nọonu nhne, zá neezne izne.  
\v 21 Ele badnụ wam tụ́hnasnana hite nụ ogbu badnụ be, nụ amusu be neeri, nụ ome ọyi be, mọbu nụ buznu be nooznu. 
\c 10  
\s1 Enine izi nụ  //  ọkwukwo matị 
\p  
\v 1 Omekwo, m whnụrnu m enine izi berere ke nwernu rikne hi n'oligwe hiedna. O wogwu erumeru oligwe, eke nụ egwurugwu zị n'olu risi a, ruwhnu a noonwu lele ẹhnam, ọchi a lawụru nụ lele nsnụsnu ọro bẹkwnu.  
\v 2 O ji otu ọkwukwo matị be kpumernu okpume n'aka a. Ọ bịta ọchikwunga a n'osimini, ọchirita a n'olu ẹli.  
\v 3 O ji okne nkọli si lụlo lele hne odum neebigbọ, nga o sikworu okokoba, egbe oligwe ẹsau wam gba n'ọsisa.  
\v 4 Nga egbe oligwe ẹsau wam gbakworu, m pioru m ọ gba n'ọkwukwo, m nụrnu m otu nkọli hiri n'oligwe naakanụ m, “Kpusnime nhne egbe oligwe ẹsau wam kwuru, ị gbá be n'ọkwukwo.” 
\p  
\v 5 Enine izi wam me whnụrnu gwuzo n'osimini nụ n'olu ẹli, gwelizọ akarikwnunga a olu.  
\v 6 O gweru nye wam zị ọkwnukokwnu dụ risi, bụ nye keru oligwe nụ kpakara nhne zị nụ rime a, nụ ọwa nụ kpakara nhne zị nụ rime a, nụ osimini nụ kpakara nhne zị nụ rime a. Enine izi wam karụ, “Ige kwolem.  
\v 7 Kọvu nga enine izi ke ẹsau jọogbu ọkwodu a, nhne tugwaru otugwa ke Chiokike jeemezu, lele kpa o kwuru hite n'ọnu ele izi a, bụ ele ọwhnurninya.” 
\p  
\v 8 Nkọli wam me nụrnu hi n'oligwe nookwunu m ọka, kwukwnonu m ọka berere, ọ kaa, “Zne, gweru ọkwukwo matị wam be kpumernu okpume ke zị n'aka enine izi wam gwuzo n'osimini n'olu ẹli.” 
\p  
\v 9 M znekwnusi enine izi wam, kanụ a o nyee m ọkwukwo matị wam. Ọ kaa, “Gweru a, ri a, o joolu nlulu nụ rụwho ị, kọvu ọ jọoso n'ọnu ị lele mọno ebeka.”  
\v 10 M gweru ọkwukwo wam n'aka a, ri a, ọ nụ lele mọno ebeka n'ọnu m, kọvu kpa me rikworu a, o mernu rụwho m lu nlulu.  
\v 11 Ọ kanụ m, “I jọokpo okwo ikwu-ọnu Chiokike ka berere nụ ruwhnu agịda ele badnụ, nụ mba zị ọdo n'ọdo, n'ikwu-ọnu zị ọdo n'ọdo, ma nụ ruwhnu ele eze.” 
\c 11  
\s1 Ele akebne lawụru 
\p  
\v 1 Be nyernu m otu isisi lele nhne be ji nọotu nhne, be kanụ m, “Lizọ, tụ Ọro Nsọ Chiokike, nụ ojo arịohna, gwnụ ele nọokpo risi ẹli nụ rime a.  
\v 2 Kọvu ị tụ́ n'ederezi, kwnornu nụ be nyernu a ele bụ́o ele Ju, ele jọozodna ẹli-ọhna nsọ wam nri ẹnwa ẹno nụ ẹnwa lawụru.  
\v 3 M jeezizne ele akebne m lawụru, be joowo iwo mkpe zni izi ọma otu pokwu ọbochi nụ riwhu ọbochi lawụru nụ nri isunu.”  
\v 4 Ka bụ isisi olivu lawụru wam nụ nhne be bịta tọnji lawụru wam gwuzo nụ ruwhnu Nyenwe ọwa.  
\v 5 Nye irno ọbula ke pioru ọ kpakna be ẹhni, bẹkwnu hi n'ọnu be jeernegbu be. Nye ọbula ke kpaknarnụ be ẹhni jọonwuriri kpam.  
\v 6 Ele ka nwernu rikne o knesni oligwe, ke mernu mini ozuzo zóle kpakara ige be nọokpo okwo ikwu-ọnu Chiokike, be nwernu rikne o mee kpakara mini ghọ ọvnarna, nụ rikne o mee ele zị n'ọwa rịa ẹhni igbugbu ọbula lele kpa be pioru. 
\p  
\v 7 Nga be gbasakworu ikwu-ọnu Chiokike, anọhia wam hi nụ olulu awhnụwhnu, lụsi be ọgwnu, megbu be, gbu be.  
\v 8 Iznu be joovubi n'esilawụru apna okne ẹli-ọhna wam be nookwu n'elulu Sọdom nụ Ijipiti, hne be kpọgburu Nyenwe be n'olu ọgba.  
\v 9 Kpakara ele badnụ, nụ ẹbnurnu, nụ ikwu-ọnu, nụ mba zị ọdo n'ọdo, jeelekiri iznu be ọbochi ẹto n'ichichi, be jéekwe be li be.  
\v 10 Kpakara ele zị n'ọwa jọonwudna, mkpọma sọ be n'ọnu kwnornu nụ be nwụrnu, be neeziznenu ibne be nkesi kwnornu ele ọwhnurninya lawụru ka nwụrnu ọnwu bụ ele mernu ele zị n'ọwa ta awhnụwhnu k'agịda.  
\v 11 Nga ọbochi ẹto n'ichichi whemernu, enine bụdnu hiri nụ Chiokike bnazne nụ rime be, be gwuzoru, okne ogwnu tụru kpakara ele whnụrnu be.  
\v 12 Ele ọwhnurninya lawụru wam nụrnu otu nkọli hiri n'oligwe noosukwu be, “Anụ va n'olu hna.” Be lizọ, la n'olu n'erumeru oligwe, kpa ele irno be neelekiri be. 
\p  
\v 13 N'ige wam, okne ẹli otne enye dnarnụ n'ọwa, ke mernu otu nga nụ nri nga ẹli-ọhna wam lulu, ẹli otne enye wam gburu pokwu badnụ ẹsau, ogwnu tụru ele ke gwnarnụ, be znarnị Chiokike ke oligwe. 
\p  
\v 14 Nhne awhnụwhnu ke ẹbo whemernu, kọvu le, nhne awhnụwhnu ke ẹto vawa wara wara. 
\s1 Ọkwodu ke ẹsau 
\p  
\v 15 Enine izi ke ẹsau gbụ ọkwodu a, agịda nkọli dnarnụ n'oligwe, naakaa, 
\q1 “Ẹli-eze k'ọwa ka ghọlam ẹli-eze ke Nyenwe aị nụ ke Karaịsi, 
\q2 ọ jaachị hite n'ige kwó okwo dụ n'ige kwó okwo.” 
\p  
\v 16 Nri ele okno badnụ lawụru wam nụ ẹno ele dazị nụ ngadna eze be nụ ruwhnu Chiokike, dna kpu ruwhnu n'ẹli, kpọnu Chiokike risi ẹli.  
\v 17 Be kaa, 
\q1 “A nọotunu ị mmamma, Nyenwe aị Chiokike ke Meli Nhne Dum, 
\q2 nye zị, nye zị nụ mbọm, 
\q2 kwnornu nụ i ji okne iknernema ị nẹechi. 
\q1  
\v 18 Ovu neewe ele zị n'ọwa ẹhni, kwnornu nụ ọnuma ị valẹm, 
\q2 ige i jeekpe ele nwụrnu ọnwu ikpe valẹm, 
\q1 nụ ige ị jọokwu ele izi i, ele ọwhnurninya ị ọgwo ẹrnu 
\q2 nụ kpakara ele ke i, nụ ele nọotu ogwnu i 
\q1 ma nye kwu nụ nye matị, 
\q2 nụ ige o lulu ele luluru ọwa.” 
\p  
\v 19 Be gbamarnụ Ọro Nsọ Chiokike n'oligwe, be whnụrnu Igbe Ọgba-Njọ-Ẹhni Chiokike nụ rime a, agịda amụma, nụ ọdidna, nụ egbe oligwe, nụ ẹli otne enye, nụ okne mkpụru mini dnarnụ. 
\c 12  
\s1 Nwerinya wam nụ  //  okne agwọ wam 
\p  
\v 1 Otu okne nhne ndu-ẹhni mernu n'oligwe. Otu nwerinya wogwu iwo ẹhnam, nye ẹnwa zị nụ mkpururu ọchi a, o kpu okpu-eze nwernu nri nụ mbọ lawụru nụ risi.  
\v 2 Nwerinya wam zị rime, rime ọmumu nnwọ neeme a, ọ kwna ẹkwna kpa ọ nọomu nnwọ.  
\v 3 Nhne ndu-ẹhni berere whụya kwno n'oligwe, otu agwọ okpotokpo ihie ke nwernu risi ẹsau nụ nri mfu, kpu okpu-eze ẹsau nụ risi ẹsau a.  
\v 4 O ji ọdnu a dọru otu-ibewa nga ẹto mbọ ke oligwe dọdna be n'ọwa, o zne gwuzoru nụ ruwhnu nwerinya wam nọomu nnwọ ma o ri nnwọ wam wara wara ọ mụhiaru a.  
\v 5 Nwerinya wam mụhia nnwọ rukna, nye jeeji mkpara rugwe nẹechi kpakara mba, kọvu be kwumernu nnwọ wam, kwuznenu a Chiokike nụ ngadna eze a.  
\v 6 Nwerinya wam gbawhu, gbabna nụ rime ẹli-ịkpa, hne Chiokike bịtannu a, ma be lekasi a anya pokwu ọbochi nụ riwhu ọbochi lawụru nụ nri isunu. 
\p  
\v 7 Ọgwnu dna n'oligwe, Maịkeli nụ ele enine izi a lụ ọgwnu megidne agwọ wam, agwọ wam nụ ele enine izi a lụ ọgwnu megidne be.  
\v 8 Kọvu Maịkeli nụ ele enine izi a megburu agwọ wam, oghere zị́mana agwọ wam nụ ele enine izi a n'oligwe berere.  
\v 9 Be chịdna agwọ okpotokpo wam, ke bụ agwọ ọknani wam bụ Ekwensu mọbu Setani n'ọwa, nye nooduwhu kpakara ele zị n'ọwa. Be chịdnarnu ya nụ kpakara ele izi a. 
\p  
\v 10 Ige wam, m nụrnu m otu okne nkọli n'oligwe, kaa, 
\q1 “Ọznohia valẹm, nụ rikne nụ ẹli-eze Chiokike aị, 
\q2 nụ iknernema Karaịsi a, 
\q1 kwnornu nụ be chịdnarnu nye noobno rụmu nda aị nhne, 
\q2 bụ nye noobno be nhne nụ ruwhnu Chiokike iwhnehnie nụ abalị. 
\q1  
\v 11 Be jiri ọvnarna Nnwọ Atnụrnu wam 
\q2 nụ akebne be gbarụ 
\q2 megbu a, 
\q1 be whnụ́na bụdnu be n'anya 
\q2 dụ n'ẹnwu. 
\q1  
\v 12 Kam kpayarụ, oligwe nwụdnahoru, 
\q2 ovu ọso anụ n'ọnu ele wu nụ rime a. 
\q1 Kọvu awhnụwhnu zịnu ọwa nụ osimini, 
\q2 kwnornu nụ Ekwensu vakwnusilem anụ, 
\q1 ọnuma jiri a mkpọma, 
\q2 kwnornu nụ ọ magwụ nụ ige a zị ichichi.” 
\p  
\v 13 Nga agwọ wam whnụrnu nụ be chịdnarnu a n'ọwa, o bete ọ chị nwerinya wam ẹso bụ nye mụrnu nnwọ rukna wam.  
\v 14 Be nyee nwerinya wam aka-nkwu lawụru ke okne igno ma o wheru iwhe zne hne o wu n'ẹli-ịkpa, hne be jeelekasi a anya awha ẹto nụ ẹnwa isunu hne agwọ wam bọ́ ọ whnụna a.  
\v 15 Agwọ wam gbụhia agịda ọnu-mini a gbasno nwerinya wam, ma o vuru nwerinya wam.  
\v 16 Kọvu ẹli yinnu nwerinya wam aka, kpumernu ọnu a, nwọkwo mini agwọ wam gbụhiaru n'ọnu a.  
\v 17 Agwọ wam we ovu ẹhni k'agịda megidne nwerinya wam, o zne nọolusi agwna rụmu nwerinya wam ke gwnarnụ ọgwnu, bụ ele bịtaru nhne Chiokike nyernu n'iwu, nụ ele kwesiri ọkwnata ovu n'ezi ọka Jizọsi gesiri.  
\v 18 Agwọ wam gwuzoru n'olu rịzna ke osimini. 
\c 13  
\s1 Anọhia lawụru 
\p  
\v 1 M whnụrnu m otu anọhia hi nụ rime osimini nọowhuya, o nwernu nri mfu nụ risi ẹsau, o kpu okpu-eze n'olu mfu a, be gbakwasịri n'olu kpakara risi a rẹwhna ọjo nookwulu Chiokike.  
\v 2 Anọhia me whnụrnu nụ lele agwnụ, ọchi a lawụru nụ lele anọhia bea, ọnu a nụ lele ọnu odum. Agwọ wam nyee anọhia wam rikne a, ngadna eze a nụ okne iknernema.  
\v 3 Ọ nụ lele nụ be gburu otu risi anọhia wam, kọvu nhne omernu ẹhni wam ke nwernu rikne o vuya ẹnwu gwọru, ọ tụ kpakara ọwa n'anya, be gbasnornu anọhia wam.  
\v 4 Be kpọnu agwọ wam risi ẹli ke nyernu anọhia wam iknernema a, be kpọ masịnu anọhia wam risi ẹli, naakaa, “Nyele nụ lele anọhia ka? Nyele nwernu rikne ọ lụsi a ọgwnu?” 
\p  
\v 5 Be nyernu anọhia wam rikne o ji nookwu agịda nhne zị ogwnu nụ ọka ọjo nookwulu Chiokike, o nwernu rikne nri ẹnwa ẹno nụ ẹnwa lawụru.  
\v 6 Anọhia wam kpume ọnu a nookwulu Chiokike, nụ rẹwhna a, nụ Ọro Nsọ a, nụ kpakara ele wu n'oligwe.  
\v 7 Be nyernu a rikne ọ lụsi ele nsọ ọgwnu nụ o megbu be, be nyee kwno a rikne megidne kpakara avnụrnu nụ ele badnụ nụ ikwu-ọnu nụ mba.  
\v 8 Kpakara ele wu n'ọwa jọokponu a risi ẹli, ele be gbála rẹwhna be nụ rime ọkwukwo bụdnu ke Nnwọ Atnụrnu nye be gburu hite n'okike ọwa. 
\p  
\v 9 Nye nwernu nsnị, ọ nụrnu. 
\q1  
\v 10 Nye ọbula be jọodoru n'ọgwnu 
\q2 be jọodoru a n'ọgwnu. 
\q1 Nye ọbula be jeeji ama-ọgwnu gbu, 
\q2 be jeeji ama-ọgwnu gbu a. 
\m Ele nsọ jeenwe ọkwnata ovu nụ ndidi. 
\p  
\v 11 M whnụ anọhia berere hi n'ẹli nọowhuya. O nwernu mfu lawụru lele mfu nnwọ atnụrnu, o nookwu ọka lele agwọ.  
\v 12 O ji rikne anọhia mbọm wam nụ ruwhnu a. O mernu kpakara ọwa nụ ele zị nụ rime a kpọnu anọhia mbọm wam risi ẹli, nye be gwọru nhne omernu ẹhni wam ke noovuya ẹnwu.  
\v 13 Anọhia ke ẹbo ka rnụ ẹrnu rikne, o mernu bẹkwnu hi n'oligwe dna n'ọwa n'anya ele badnụ.  
\v 14 O duhie kpakara ele wu n'ọwa kwnornu ẹrnu ndu-ẹhni ka ke be nyernu a rikne ọ rnụ nụ ruwhnu anọhia ke mbọm. Ọ kanụ ele zị n'ọwa be kpu igbudu anọhia wam ke be jiri ama-ọgwnu mernu ẹhni, kọvu ọ zị bụdnu.  
\v 15 Be nyernu anọhia ke ẹbo wam rikne o nwesi inwe bụdnu nụ rime igbudu anọhia mbọm wam, ke kpayarụ igbudu wam nookwu ọka, kaa be noogbu kpakara ele kwéle ọ kpọnu igbudu wam risi ẹli.  
\v 16 O mee kpakara ele badnụ ma nye matị ma nye kwu, nye barụ eze nụ nye mboni, ọhi nụ nye bụ́o ọhi, be narnụ akara nụ akarikwnunga be mọbu n'egedege ruwhnu be.  
\v 17 Ọ zá nye nwernu rikne zụ nhne mọbu re nhne, okwolem nye nwernu akara anọhia wam ke bụ rẹwhna anọhia wam, mọbu ọgwnugwnu rẹwhna a. 
\p  
\v 18 Nye ọbula nwehịa akọniche, nye ọbula ke nwernu ọgwnugwnu risi, ọ mahịa ọgwnugwnu anọhia wam, kwnornu nụ ọ bụ ọgwnugwnu badnụ, ọgwnugwnu a bụ riwhu isunu nụ nri isunu nụ isunu [666]. 
\c 14  
\s1 Nnwọ Atnụrnu nụ ele ke a 
\p  
\v 1 M leru m anya, whnụ Nnwọ Atnụrnu gwuzo n'olu rugwu Zayọni, ya nụ otu riwhu nụ nri ẹno nụ pokwu ẹno ele badnụ, be vu rẹwhna a nụ rẹwhna Nda a n'egedege ruwhnu be.  
\v 2 M nụrnu m otu nkọli hi n'oligwe dna lele agịda mini, nụ okne nkọli egbe oligwe, m nụrnu m ele naagba ọbo ji ọbo be naagba.  
\v 3 Be gwnụ eri ikne nụ ruwhnu ngadna eze wam, ma nụ ruwhnu nhne ẹno wam zị bụdnu, nụ ele okno badnụ wam. Ọ zá nye nwernu rikne sno be gwnụ eri wam, okwolem otu riwhu nụ nri ẹno nụ pokwu ẹno wam ele be gbahịaru n'ọwa.  
\v 4 Ka bụ ele mérula ẹhni be n'ẹhni nyerinya kwnornu nụ be bịtaru ẹhni be snam. Be joosno Nnwọ Atnụrnu wam penupe ọbula o neezne, be gbahịaru be n'esilawụru ele badnụ lele mkpụru mbọm be kesiri Chiokike nụ Nnwọ Atnụrnu a.  
\v 5 Ọ zá aghalaghala be whnụrnu n'ọnu be, be zị snam. 
\s1 Ele enine izi ẹto 
\p  
\v 6 M whnụrnu m enine izi berere neewhe n'oligwe, nọokpo okwo izi ọma ke zị ọkwnukokwnu n'ọwa, ma kpakara ele mba, nụ avnụrnu nụ ikwu-ọnu nụ ele badnụ nụrnu a.  
\v 7 O ji okne nkọli naakaa, “Anụ tụ ogwnu Chiokike, anụ znarnị ebube a, kwnornu nụ ige valẹm o jeekpe kpakara badnụ ikpe, anụ kpọnu nye keru oligwe, nụ ọwa, nụ osimini, nụ kpakara risi mini risi ẹli.” 
\p  
\v 8 Enine izi ke ẹbo snornu ke mbọm kaa, “Ọ dnanam, Babịloni dnanam, okne mba ke mernu kpakara ẹli nwọ manya okne ome ọyi a.” 
\p  
\v 9 Enine izi ke ẹto snornu be gweru okne nkọli kaa, “Nye ọbula ke kpọnnu anọhia wam nụ igbudu a risi ẹli, nahọru masị akara a n'egedege ruwhnu a, mọbu n'aka a,  
\v 10 ọ jọonwo manya okne ovu owe ẹhni Chiokike, ke ọ wụsaru nụ rikne, ke be gwála agwa nụ rime okiko ọnuma a, be jeeji bẹkwnu nụ rugwu bẹkwnu ta a awhnụwhnu nụ ruwhnu ele enine izi nsọ nụ ruwhnu Nnwọ Atnụrnu wam.  
\v 11 Rụnwurnu awhnụwhnu be zị naala olu ọkwnukokwnu, be zá noozukwa inwe iwhnehnie nụ abalị, bụ ele wam kpọnnu anọhia wam nụ igbudu a risi ẹli, nụ nye ọbula ke nahịaru akara rẹwhna a.”  
\v 12 Ele nsọ jeenwe ndidi, ele naabịta nhne Chiokike nyernu n'iwu nụ ele kwnatarụ Jizọsi mkpọma. 
\p  
\v 13 Nga wam m nụrnu m nkọli hiri n'oligwe kaa, “Gba n'ọkwukwo, ọwa ọma zịnu ele nwụrnu nụ rime Chiokike hite nụ kịtna.” 
\p Enine Nsọ kaa, “Owe, be joozukwa inwe n'ẹrnu be, kwnornu nụ ẹrnu be joosno be n'aznụ.” 
\s1 Ogwe nhne n'ẹkwu ke ọwa 
\p  
\v 14 M le anya, whnụ, otu erumeru abọchna, otu nye nụ lele Nnwọ ke Badnụ dazị n'olu erumeru wam, o kpu okpu-eze golu nụ risi a, o ji ama ẹkwu zị bụko n'aka a.  
\v 15 Enine izi berere hi nụ rime Ọro Nsọ whụya, gweru okne nkọli kanụ nye wam dazị n'erumeru, “Gweru ama ị, gweru nhne n'ẹkwu, kwnornu nụ ige o gwe nhne n'ẹkwu k'ọwa valẹm, mkpụru k'ọwa chnanam.”  
\v 16 Nye wam dazị n'erumeru gweru ama a yisi nụ rime ọwa, gweru nhne ẹkwu k'ọwa. 
\p  
\v 17 M whnụrnu m enine izi berere hi n'Ọro Nsọ n'oligwe, o ji masị ama zị bụko.  
\v 18 Enine izi berere ke nwernu rikne megidne bẹkwnu, hi n'ojo arịohna whụya. O gweru okne nkọli kanụ enine izi wam ji ama zị bụko, “Gweru ama ị ghọhia mkpụru vaịni ke ẹkwu, kwnornu nụ vaịni ke ọwa chnanam.”  
\v 19 Enine izi wam yisi ama a, ghọhia mkpụru vaịni, tụbna be nụ rime hne be jọozosna manya okne ovu owe ẹhni Chiokike.  
\v 20 Be zọsna manya vaịni wam n'aznụ ẹli-ọhna, ọvnarna a gbahịa nụ hne be nọozosna manya wam dụ nhne nụ lele riwhu maịli lawụru, dụ oknesni ọnu ịyinya n'olu. 
\c 15  
\s1 Nhne awhnụwhnu ẹsau 
\p  
\v 1 M whnụ nhne berere n'oligwe, okne nhne ndu-ẹhni. Enine izi ẹsau vu nhne awhnụwhnu ẹsau ke ipne-aznụ, okne ovu owe ẹhni Chiokike ke ipne-aznụ zị nụ rime be.  
\v 2 M whnụ kwno nhne nụ lele osimini nyno be gwarụ bẹkwnu, nụ ele wam megburu anọhia wam nụ igbudu a nụ ọnu ọgwnugwnu rẹwhna a, hne be gwuzo nụ ngeri osimini nyno wam, be ji ọbo Chiokike nyernu be.  
\v 3 Be nọogwnu eri Mozizi nye izi Chiokike nụ eri Nnwọ Atnụrnu wam, 
\q1 “Ẹrnu ị tụ n'anya, zị masị rikne! 
\q2 Nyenwe aị Chiokike ke Meli Nhne Dum, 
\q1 Kpakara apna ị snịrni asnị bụru ezi ọka, 
\q2 Eze zị ọkwnukokwnu. 
\q1  
\v 4 Nyele jọ́otu ogwnu i, Nyenwe aị? 
\q1 Nyele jóokwuhịa igwugwu ke rẹwhna ị? 
\q2 Kwnornu nụ jị nụ nsnụnu ị zị nsọ, 
\q1 kpakara mba jaava kpọ risi ẹli nụ ruwhnu i, 
\q2 kwnornu nụ ikpe bụru ọma ị zuru kpakara ọwa.” 
\p  
\v 5 Nga ka mekworu, m whnụ Ọro Nsọ Chiokike n'oligwe gbamarnụ bụ Ọro-Ẹka ruwhnu Chiokike.  
\v 6 Enine izi ẹsau wam vu nhne awhnụwhnu ẹsau hi nụ rime Ọro Nsọ wam whụya, be wogwu iwo noonwu onwu, be ji ajnị mkpọma golu kne nụ mkpọma be.  
\v 7 Otu nhne zị bụdnu wam nyega enine izi ẹsau wam obele ẹsau okne ovu owe ẹhni Chiokike jihịaru nụ rime be, bụ nye zị bụdnu ọkwnukokwnu.  
\v 8 Rụnwurnu jihịa Ọro Nsọ wam hite n'igwugwu nụ iknernema Chiokike, ọ zá nye nwernu rikne ọ bna Ọro Nsọ wam tem awhnụwhnu ẹsau wam enine izi ẹsau wam vuyarụ kwome. 
\c 16  
\s1 Obele ẹsau ovu owe ẹhni  //  Chiokike 
\p  
\v 1 Ige wam, m nụrnu m otu okne nkọli hi n'Ọro Nsọ wam naakanụ enine izi ẹsau wam, “Anụ zne wụsa obele ẹsau ovu owe ẹhni Chiokike n'ọwa.”  
\v 2 Enine izi ke mbọm zne wụsa obele a n'ọwa, esuso ẹhni tụ ogwnu noogbu igbugbu se kpakara ele vu akara anọhia wam n'ẹhni, nụ kpakara ele kpọnnu igbudu wam risi n'ẹli. 
\p  
\v 3 Enine izi ke ẹbo zne wụsa obele a n'osimini, ọ ghọ ọvnarna nụ lele ọvnarna nye nwụrnu ọnwu, kpakara nhne zị bụdnu nụ rime osimini nwụkwo. 
\p  
\v 4 Enine izi ke ẹto zne wụsa obele a nụ mini nụ kpakara risi mini, be ghọ ọvnarna.  
\v 5 M nụrnu m nga enine izi ke neelegidne mini karụ, 
\q1 “Jị bụ nye mee mma n'ikpe 
\q2 jị bụ nye zị, nye zị nụ mbọm, Nye zị Nsọ, 
\q1 kwnornu nụ i kperu ikpe nụ kpa. 
\q1  
\v 6 Be wụsaru ọvnarna ele nsọ ị nụ ele ọwhnurninya ị, 
\q2 i nyee be ọvnarna be nwọ lele mini, 
\q2 kwnornu nụ be kwesiri a.” 
\m  
\v 7 M nụrnu m otu nkọli hi n'ojo arịohna naakaa, 
\q1 “Owe! Nyenwe aị Chiokike ke Meli Nhne Dum, 
\q2 ikpe i bụru ọma, bụ masị ezi ọka.” 
\p  
\v 8 Enine izi ke ẹno zne wụsa obele a n'ẹhnam, o neerne ele badnụ lele bẹkwnu.  
\v 9 Okne okpe bẹkwnu rne ele badnụ, be kọsna rẹwhna Chiokike nye nwernu rikne nụ hne awhnụwhnu ka zị. Kọvu be kwéle ọ tụhnasna nụ mmehie be znarnị Chiokike. 
\p  
\v 10 Enine izi ke isne zne wụsa obele a n'olu ngadna eze anọhia wam. Okne ọchichiri gbasni ẹli-eze anọhia wam, ele badnụ naatabi riro be kwnornu nhne igbugbu.  
\v 11 Be kọsna Chiokike ke oligwe kwnornu nhne igbugbu be nụ nhne mernu ẹhni be. Kọvu be kwéle ọ tụhnasna nụ apna ọjo be. 
\p  
\v 12 Enine izi ke isunu zne wụsa obele a n'okne Osimini Uferetisi, mini a takwo, kpa mini a takworu, apna ele eze hi n'ọbosi ẹhnam whụya. \f + \fr 16:12 \ft Nga apna wam whụyaru, ele irno be whnụrnu oghere bnanya lụsi be ọgwnu. \f* 
\v 13 M whnụ rẹnwu ẹto zị́la rịchna lele rẹdekpo, hi n'ọnu agwọ wam, nụ ọnu anọhia wam, nụ ọnu nye ọwhnurninya aghalaghala wam nọowhuya.  
\v 14 Be bụ rẹnwu ọjo nọornu ẹrnu ndu-ẹhni. Rẹnwu ẹto ka znekwnusi ele eze ọwa, chịkota be n'otu kwnornu ọgwnu okne ọbochi Chiokike ke Meli Nhne Dum. 
\p  
\v 15 Le, m jaava lele nye buznu, ngọzi zịnu nye ọbula neese nse, bịkwata iwo a, ọ zị kpa ọ gbarụ ẹto znegharị, iwhnerne tụ a n'ọhna. 
\p  
\v 16 Rẹnwu ọjo wam chịkota kpakara eze nụ hne ele Hiburu nookwu Amagịdoni. 
\p  
\v 17 Enine izi ke ẹsau zne wụsa obele a nụ ruwhere. Otu okne nkọli hi nụ ngadna eze zị n'Ọro Nsọ wam, kaa, “Be menem a.”  
\v 18 Agịda amụma oligwe, nụ ọdidna, nụ egbe oligwe nụ okne ẹli otne enye dnarnụ, ẹli otne enye nụ kpam zị́gelele hite nga Chiokike kpuru badnụ. Ẹli otne enye ka kakwo ibne a.  
\v 19 Ẹli-ọhna kwu wam kewamarnụ nga ẹto, ẹli-ọhna kpakara mba luluru. Chiokike chenwanya Babịloni, mee a ọ nwọ manya hi n'ikiko okne ovu owe ẹhni a.  
\v 20 Kpakara ẹli ọhia esilawụru nụ rugwu gbawhu, whume.  
\v 21 Okne mkpụru mini nẹenyi rịnya \f + \fr 16:21 \ft Mkpụru mini wam nẹenyi nụ nhne ọtutu 50 kg. \f* naadnakwasị ele badnụ hite n'oligwe. Ele badnụ nọovu Chiokike ọnu kwnornu mkpụru mini wam, nụ kwnornu awhnụwhnu wam zị ogwnu ke agịda. 
\c 17  
\s1 Nwerinya nụ anọhia 
\p  
\v 1 Otu nụ rime ele enine izi ẹsau wam vu obele ẹsau vakwnusi m kaa, “Vaa, me gesi i awhnụwhnu okne nye ewhere wam ke dazị n'olu agịda mini,  
\v 2 nye ele eze ke ọwa snornu mee ọyi, ele zị n'ọwa nwọrnu manya ewhere a.” 
\p  
\v 3 Enine izi wam vuru m n'Enine zne nụ rime ẹli-ịkpa, hne me whnụrnu otu nwerinya dazị n'olu anọhia naachna ihie ihie. Anọhia wam nwernu agịda rẹwhna ọjo nookwulu Chiokike be gbakwasịri a, o nwernu risi ẹsau, nụ nri mfu.  
\v 4 Nwerinya wam wogwu iwo odno odno nụ ihie ihie, o jiri nhne ẹyi golu nụ rugwu okne ọnu ahịa nụ palị mee ẹhni a mma, o ji ikiko golu n'aka a, nhne rụru ọru nụ nhne zị́la rịchna ke ome ọyi a jihịaru nụ rime a.  
\v 5 Be gbakwasịri a otu rẹwhna n'egedege ruwhnu, 
\q1 Nhne miri emi, 
\q2 okne Babịloni, 
\q1 nne kpakara ele ewhere 
\q2 nụ nhne rụru ọru ke ọwa. 
\p  
\v 6 Ọvnarna ele nsọ nụ ele be gburu kwnornu Jizọsi noogbu a lele manya. 
\p Ọ gbarụ m anya agharị nga me whnụrnu a.  
\v 7 Enine izi wam kanụ m, “Ndaa kpa o jiri naagba i anya gharị? M jaakanụ ị nhne tugwaru otugwa gbasịri nwerinya ka nụ anọhia ke vu a, bụ anọhia ke nwernu risi ẹsau nụ nri mfu.  
\v 8 Anọhia ke i whnụrnu zị bụdnu nụ mbọm, kọvu ọ nwụrnu, o jeehi n'olulu awhnụwhnu whụya zne n'ẹnwu a. Kpakara ele wu n'ọwa ele be gbála rẹwhna be n'ọkwukwo ke bụdnu hite n'okike ọwa, ọ jọotu be n'anya nga be whnụrnu anọhia wam zị bụdnu nụ mbọm, kọvu ọ nwụrnu, ọ jaazị kwno bụdnu. 
\p  
\v 9 “A kwesiri o nwe ovu ke nwernu akọniche, risi ẹsau wam bụ rugwu matị ẹsau ke nwerinya wam dazị n'olu a. Be bụ masị ele eze ẹsau,  
\v 10 isne dnanam, otu nẹechi kọriri, otu ya váge. Nga ọ varụ, ọ jaadazị ige matị.  
\v 11 Anọhia wam zị bụdnu nụ mbọm, ke nwụrnu, bụ eze ke ẹsato, nye zị n'esilawụru eze ẹsau wam, jaala n'iyi. 
\p  
\v 12 “Nri mfu wam ị whnụrnu bụ masị nri eze ele ya váge ẹchi, kọvu be jeenye be rikne otu ọtnu-ige lele eze snornu anọhia wam chị.  
\v 13 Be nwernu otu mkpọma, be jeenye anọhia wam iknernema nụ rikne be.  
\v 14 Ele ka jọolusi Nnwọ Atnụrnu wam ọgwnu, kọvu Nnwọ Atnụrnu wam jeemegbu be, kwnornu nụ ọ bụ Nyenwe ke kakwo ele nwe nụ Eze kakwo ele eze. Ele sno a bụ ele o sukwuru, ele ọ họhiaru nụ ele kwesiri ọkwnata ovu.” 
\p  
\v 15 Ọ kanụ m, “Mini ke ị whnụrnu hne nwerinya ewhere wam dazị, bụ ele badnụ, nụ agịda ele badnụ, nụ mba nụ ikwu-ọnu zị ọdo n'ọdo.  
\v 16 Anọhia wam nụ nri mfu wam ị whnụrnu joosno nwerinya ewhere wam irno, be jaanahọru a kpakara nhne o nwernu, gbata a ẹto, be jeeri anọ-ẹhni a, kpọrne a nụ bẹkwnu.  
\v 17 Kwnornu nụ Chiokike yisiri a nụ mkpọma be, ma be mee echiche a, be jeekwerikọta o nyee anọhia wam ẹli-eze be, ọ jaachị be tem Chiokike mezu ikwu-ọnu a.  
\v 18 Nwerinya wam ị whnụrnu bụ okne ẹli-ọhna wam ke nẹechi kpakara ele eze ke ọwa.” 
\c 18  
\s1 Ọdudna Babịloni 
\p  
\v 1 Nga nhne ka mekworu, m whnụrnu m enine izi berere hi n'oligwe neehidna, o nwernu okne iknernema, ogbu marna marna ruwhnu a neenye iwhne n'ọwa.  
\v 2 O gweru okne nkọli siwama, kaa, 
\q1 “Ọ dnanam, okne Babịloni dnanam, 
\q2 ọ ghọlam hne rụmu rẹnwu ọjo wu, 
\q1 ọro ikelu kpakara rẹnwu zị́la rịchna, 
\q2 kpakara ọnunu ọjo ke be rí eri zị nụ rime a. 
\q1  
\v 3 Kwnornu nụ kpakara mba 
\q2 nwọrnu manya okne ome ọyi a, 
\q1 ele eze ke ọwa snornu a mee ọyi, 
\q2 ele nọozu ahịa ke ọwa barụ eze hite nụ okne ewhere a.” 
\p  
\v 4 M nụ kwno okne nkọli hi n'oligwe kaa, 
\q1 “Ele ke m, anụ hi n'esilawụru a whụya, 
\q2 ọ zị anụ snornu a kehịa igwe nụ mmehie a, 
\q1 ọ zị anụ snornu a ta awhnụwhnu. 
\q1  
\v 5 Kwnornu nụ mmehie a gwuzo dụ oligwe, 
\q2 Chiokike chenwanyalam kpakara mmehie a. 
\q1  
\v 6 Anụ mesno a lele kpa o mernu anụ, 
\q1 anụ mesno a mgba lawụru kpa o mernu, 
\q2 okiko ọ gbajiri, anụ gbajite a mgba lawụru ma ọ nwọrnu. 
\q1  
\v 7 Anụ ta a awhnụwhnu nụ anya-mini 
\q1 lele kpa o nyernu ẹhni a igwugwu nụ ẹgwnurnu ọjo a, 
\q2 kwnornu nụ ọ karụ nụ mkpọma a, 
\q1 ‘M bụ m eze nyerinya, m bụ́la m nnwerne nwée nzi, 
\q2 m jáagba mkpe.’ 
\q1  
\v 8 Kam kpayarụ, n'otu ọbochi, ọ jọowhnuji anya, 
\q1 ẹnwu, mkpe, nụ ọknunyo, 
\q2 bẹkwnu jeernegbu a, 
\q1 kwnornu nụ Nyenwe aị Chiokike ke neekpe a ikpe bụ dikne. 
\p  
\v 9 “Nga ele eze ke ọwa ele snornu a mee ọyi, n'ẹgwnurnu ọjo a, jọowhnu rụnwurnu bẹkwnu a, be jaakwna ẹkwna, gbanụ a mkpe.  
\v 10 Be joogwuzo nụ hne zị ikere kwnornu ogwnu awhnụwhnu a, kaa, 
\q1 ‘Chei, chei, okne ẹli-ọhna, 
\q2 Babịloni, bụ dikne, 
\q1 Chiokike tarụ ị awhnụwhnu n'otu ọtnu-ige.’ 
\p  
\v 11 “Ele nọozu ahịa ke ọwa jaakwanụ a ẹkwna, gbanụ a mkpe, kwnornu nụ ọ zá nye nọozu kwno mgwna ahịa be berere.  
\v 12 Be bụ ele nọozu ahịa golu, siliva, rugwu okne ọnu ahịa, palị, iwo marnụ mma, iwo naachna odno odno, siliki nụ iwo naachna ihie ihie, isisi ọbula, nhne ọbula be jiri ize eni kpu, nhne ọbula be jiri isisi zị okne ọnu ahịa pnịo, ọla, rugwe, rugwu mabulu,  
\v 13 nụ sinamọni, nụ nhne nwernu ẹknarna, isensi, maa, franki-isensi, nụ manya, nụ mọno olivu, nụ ịkpa nụ wheti, nụ anọhia, nụ atnụrnu, nụ ịyinya, nụ ọgbo-ẹli ịyinya nọodopnu, nụ ọhi, ma mkpụru ovu badnụ masị. 
\p  
\v 14 “Be kaa, ‘Nhne i pioru whnunahọru ị, kpakara ẹkwnu ị nụ ebube i whuru etekne, i jéenwe kwno be berere.’  
\v 15 Ele nọozu ahịa, ele barụ eze kwnornu nụ be neere nhne ka, joogwuzo nụ hne zị ikere, ogwnu nọotu be kwnornu awhnụwhnu a, be naakwna ẹkwna, gba masị mkpe.  
\v 16 Be jeesiwama okokoba, kaa, 
\q1 ‘Chei, chei, ẹli-ọhna kwu, 
\q2 ke jiri iwo marnụ mma odno odno nụ ihie ihie, 
\q1 nụ golu noogbu marna marna, nụ akaworugwu okne ọnu ahịa nụ palị mee ẹhni a mma. 
\q1  
\v 17 Agịda ẹkwnu hna kpa whuru etekne n'otu ọtnu-ige.’ 
\p “Kpakara ele nọokwo ọgbo mini nụ ele ji ọgbo mini neezne, nụ ele ẹrnu mini, nụ kpakara ele nhne be jiri wuru bụdnu hi nụ mini whụya, joogwuzo nụ hne zị ikere.  
\v 18 Nga be jọowhnu rụnwurnu bẹkwnu a, be jaakaa, ‘Ọ zị ẹli ke nụ lele okne ẹli-ọhna ka?’  
\v 19 Be jọowukwasi rẹtnu nụ risi be, kwna ẹkwna, gba mkpe, kaa, 
\q1 ‘Chei, chei, okne ẹli-ọhna, 
\q2 hne kpakara ele nwernu ọgbo mini 
\q1 barụ eze hite n'ẹkwnu a, 
\q2 n'otu ọtnu-ige hne ọ kọ tụbiri etekne. 
\q1  
\v 20 Ovu sọ ị n'ọnu, sụ oligwe, 
\q1 ele nsọ nụ ele izi nụ ele ọwhnurninya snornu anụ nwụdna, 
\q1 Chiokike kperu a ikpe kwnornu nhne o mernu anụ.’ ” 
\p  
\v 21 Otu enine izi gbasịri rikne gweru otu akaworugwu hna lele okne rugwu ogwe wiri tụbna nụ rime osimini, kaa, 
\q1 “Ọ bụ kpa be jeeji nhne rikne 
\q2 kwnadna okne ẹli-ọhna Babịloni, 
\q1 ọ zá nye jọowhnu a berere. 
\q1  
\v 22 Be jọ́onu kwno eri, mọbu ọbo, opi, 
\q2 mọbu ọkwodu nụ rime i berere, 
\q1 nye ọbula ke nwernu nka ẹrnu 
\q2 jáazị nụ rime i berere, 
\q1 ọ zá nye jọonu ọdidna ogwe wiri 
\q2 nụ rime i berere. 
\q1  
\v 23 Tọnji jóonwuma 
\q2 nụ rime i berere, 
\q1 akpịri nye nọolu nnwerne ikne nụ nye nọogbo nzi ikne, 
\q2 jáazịma nụ rime i berere, 
\q1 kwnornu nụ ele nọozu ahịa ị bụ ele dikne ke ọwa, 
\q2 i jiri amusu i duwhu kpakara mba. 
\q1  
\v 24 Be piohịaru nụ rime a ọvnarna ele ọwhnurninya nụ ọvnarna ele nsọ, 
\q2 nụ kpakara ele be gburu ogbu nụ rime ọwa.” 
\c 19  
\p  
\v 1 Nga nhne ele ka whemernu, m nụrnu m nhne nụ lele okne nkọli igbudu badnụ n'oligwe, naakaa, 
\q1 “Aleluya, 
\q2 ọznohia, nụ igwugwu nụ rikne bụ ke Chiokike aị, 
\q1  
\v 2 kwnornu nụ ikpe a bụru ọma nụ ezi ọka, 
\q1 ọ marnụ nwerinya okne ewhere wam ikpe 
\q2 nye jiri ome ọyi a meru ọwa, 
\q2 o megwnahịalam ọvnarna ele nsọ a n'aka a.” 
\p  
\v 3 Berere kwno be siwama, kaa, 
\q1 “Aleluya, 
\q2 rụnwurnu bẹkwnu a naala olu dụ ọkwnukokwnu.” 
\p  
\v 4 Ele okno badnụ nri lawụru nụ ẹno nụ nhne ẹno wam zị bụdnu wam dna n'ẹli kpọ risi ẹli nụ ruwhnu Chiokike nye dazị nụ ngadna eze. Be kaa, 
\q1 “Amịm, Aleluya.” 
\s1 Ọlulu nnwerne  //  ke Nnwọ Atnụrnu 
\p  
\v 5 Otu nkọli hiri nụ ngadna eze wam whụya kaa, 
\q1 “Znarnị Chiokike aị, 
\q2 anụ ele izi a, 
\q1 anụ ele nọotu ogwnu a, 
\q2 ma nye matị ma nye kwu.” 
\p  
\v 6 M nụrnu m nhne nụ lele nkọli igbudu badnụ lele ọdidna agịda mini, lele okne egbe oligwe, naakaa, 
\q1 “Aleluya, 
\q2 Nyenwe aị Chiokike ke Meli Nhne Dum nẹechi. 
\q1  
\v 7 Ngwa ma a nwụdna, ovu sọ aị n'ọnu, 
\q2 a nyee a igwugwu, 
\q1 kwnornu nụ ọlulu nnwerne ke Nnwọ Atnụrnu wam valẹm, 
\q2 nnwerne a jiknernunem ẹhni a. 
\q1  
\v 8 Be nyernu nnwerne a iwo abọchna, zị rịchna, noonwu onwu va-a-a, o woru.” 
\q1 (Iwo abọchna wam bụ ome mma ke ele nsọ.) 
\p  
\v 9 Enine izi wam kanụ m, “Gba n'ọkwukwo, ‘Ngọzi zịnu nye ọbula be sukwuru va n'iriri ọlulu nnwerne Nnwọ Atnụrnu wam.’ ” Ọ kaa kwno, “Ikwu-ọnu ka bụ ezi ọka Chiokike.” 
\p  
\v 10 M dna n'ẹli n'ọchi enine izi wam ma m kpọnu m a risi ẹli, kọvu ọ kanụ m, “I mée kpam, m bụ m nye izi ibne i nụ ke rụmu nda ị ele berere bụ ele ji akebne Jizọsi. Kpọnu Chiokike risi ẹli. Kwnornu nụ akebne Jizọsi gbarụ bụ enine ọwhnurninya.”\f + \fr 19:10 \ft ke neeyinu ele badnụ aka kpọ okwo ikwu-ọnu Chiokike.\f* 
\s1 Nye naagba  //  ịyinya abọchna 
\p  
\v 11 M whnụrnu m oligwe kpumernu nụ otu ịyinya abọchna, rẹwhna nye zị n'olu a bụ Nye Ọkwnata Ovu nụ Nye Ezi Ọka. O ji ikpe bụru ọma neekpe ikpe, nọolu ọgwnu.  
\v 12 Anya a lawụru nụ lele riro bẹkwnu, o kpu agịda okpu-eze nụ risi a. O nwernu rẹwhna be gbakwasịri a ke ọ zá nye magwụ, okwolem ya magwụ nhne ọ bụ.  
\v 13 Iwo o wogwu bụ ke be tụruru n'ọvnarna, be noosukwu a Ikwu-Ọnu Chiokike.  
\v 14 Ele ọgwnu ke oligwe sno a n'aznụ n'olu ịyinya abọchna woru iwo abọchna marnụ mma.  
\v 15 Ama-ọgwnu zị bụko hi n'ọnu a nọowhuya, ke o ji neemegbu kpakara mba. “O jeeji mkpara rugwe nẹechi be.”\f + \fr 19:15 \ft Eri Ọma 2:9\f* Ọ nọozosna manya ke okne ovu owe ẹhni Chiokike ke Meli Nhne Dum.  
\v 16 Be gbakwasịri n'olu iwo a ma nụ ọchi a rẹwhna, 
\pc “EZE KAKWO ELE EZE NỤ 
\pc NYENWE KAKWO ELE NWE.” 
\p  
\v 17 M whnụ otu enine izi gwuzo n'ẹhnam, o ji okne nkọli si okokoba, kanụ kpakara ọnunu oligwe, “Anụ va gbakọ n'okne iriri Chiokike.  
\v 18 Anụ va ri anọ-ẹhni ele eze, nụ ke ele risi ọgwnu, nụ ke ele dikne, nụ ke ịyinya nụ ke ele gba be, nụ anọ-ẹhni kpakara ele badnụ, ma ọhi nụ ke ele bụ́o ọhi, nye kwu nụ nye matị.” 
\p  
\v 19 M whnụ anọhia wam nụ ele eze ke ọwa nụ ele ọgwnu be gbakọru n'otu ma be lụsi nye wam dazị n'olu ịyinya ọgwnu ya nụ ele ọgwnu a.  
\v 20 Kọvu be nwudnernu anọhia wam ya nụ nye ọwhnurninya aghalaghala wam nye rnụrnu ẹrnu ndu-ẹhni wam nụ ruwhnu a, nye ji ẹrnu ndu-ẹhni wam rnawhu ele nwernu akara anọhia wam nụ ele kpọnnu igbudu anọhia wam risi ẹli. Anọhia wam nụ nye ọwhnurninya aghalaghala wam, be tụbna be nụ bụdnu nụ rime olulu bẹkwnu ji rugwu bẹkwnu neerne.  
\v 21 Be ji ama-ọgwnu neehi n'ọnu nye wam dazị n'olu ịyinya wam gbu kpakara ele ọgwnu be, ọnunu oligwe rijiri rụwho hite n'anọ-ẹhni be. 
\c 20  
\s1 Otu pokwu awha 
\p  
\v 1 M whnụ otu enine izi hi n'oligwe neehiedna, o ji snambị ọnuhna olulu awhnụwhnu, ji masị ijigba hna okpotokpo n'aka a.  
\v 2 Ọ nwudne agwọ wam, bụ agwọ gbaka wam, nye bụ Ekwensu, nụ Setani kne a eriri otu pokwu awha.  
\v 3 Ọ tụbna a nụ rime olulu awhnụwhnu, kasnị a akara, ma ọ gharụ o duwhu kpakara mba berere tem otu pokwu awha wheme. Omekwo, be jọotoma a eriri ige matị. 
\p  
\v 4 M whnụ agịda ngadna eze, be nyee ele dazị n'olu be rikne be jeeji kpe ikpe. M whnụ mkpụru ovu ele be gburu kwnornu akebne be gbannụ Jizọsi nụ ikwu-ọnu Chiokike, ele kpọ́la risi ẹli nyee anọhia wam, mọbu igbudu a, mọbu nahọru akara a n'egedege ruwhnu be, mọbu n'aka be. Be zịri bụdnu snornu Karaịsi nẹechi otu pokwu awha.  
\v 5 (Ele berere ke nwụrnu ọnwu lízọla n'ẹnwu tem otu pokwu awha wheme.) Ka bụ olizọ n'ẹnwu ke mbọm.  
\v 6 Chiokike jọogozi ele ke a, ele jeekehịa igwe n'olizọ n'ẹnwu ke mbọm. Ẹnwu ke gba lawụru jéenwe rikne n'ẹhni be. Be jọobu ele ọkwa arịohna Chiokike nụ ke Karaịsi, be joosno a chị otu pokwu awha. 
\s1 O megburu Setani 
\p  
\v 7 Nga otu pokwu awha whemernu, be jọotoma Setani, ọ whụya n'ikelu a.  
\v 8 Ọ jọowhoga duwhu agịda mba ke gbasarụ nụ nkala ẹno ke ọwa, Gọgi, nụ Magọgi, chịkota be zne ọgwnu. Ọnu ọgwnugwnu be hna lele rịzna zị nụ ngeri osimini.  
\v 9 Be gbasa kpakara ọwa, gahnata gburugburu hne ele nsọ zị, nụ ẹli-ọhna wam Chiokike whnụrnu n'anya, kọvu bẹkwnu hiri n'oligwe dna rnegbu kpakara be.  
\v 10 Be tụbna Ekwensu wam, nye duwhuru be nụ rime olulu bẹkwnu be ji rugwu bẹkwnu neerne hne anọhia wam nụ nye ọwhnurninya aghalaghala wam zị. Be jaata be awhnụwhnu iwhnehnie nụ abalị hna ọkwnukokwnu. 
\s1 Ikpe ipne-aznụ 
\p  
\v 11 M whnụ otu ngadna eze abọchna okpotokpo, nụ nye dazị n'olu a, ọwa nụ oligwe gbawhuru nụ ruwhnu a, be whnụ́na be berere.  
\v 12 M whnụ ele nwụrnu ọnwu, ele kwu nụ ele matị, gwuzo nụ ruwhnu ngadna eze wam. Be kpume agịda ọkwukwo, be kpume kwno ọkwukwo berere, ke bụ ọkwukwo ke bụdnu. Chiokike kpe ele nwụrnu ọnwu ikpe hite nụ nhne be gbarụ n'ọkwukwo wam lele kpa ẹrnu be jiri zịri.  
\v 13 Osimini gwehịa ele nwụrnu nụ rime a, ẹnwu nụ ẹli rẹnwu gwehịa ele zị nụ rime be, be kpe nye ọbula ikpe lele kpa ẹrnu ọ rnụrnu jiri zịri.  
\v 14 Be tụbna ẹnwu nụ ẹli rẹnwu nụ rime olulu bẹkwnu. Olulu bẹkwnu ka bụ ẹnwu ke mgba lawụru.  
\v 15 Nye ọbula ke be gbála rẹwhna a nụ rime ọkwukwo ke bụdnu, be tụbna nụ rime olulu bẹkwnu. 
\c 21  
\s1 Oligwe ikne nụ ọwa ikne 
\p  
\v 1 Omekwo, m whnụ oligwe ikne nụ ọwa ikne, kwnornu nụ oligwe ke mbọm nụ ọwa ke mbọm gawheru, osimini zị́ma masị.  
\v 2 M whnụ ẹli-ọhna nsọ wam, Jerusẹlem ikne, hi n'oligwe hne Chiokike zị neehiedna, be jiknernu a lele nnwerne ikne naalakwnusi nzi a.  
\v 3 M nụrnu m okne nkọli hi nụ ngadna eze wam nookwu ọka, kaa, “Le, Ọro Nsọ Chiokike zị n'esilawụru rụmu badnụ, Chiokike jaadazịnu be, be jọobu ele ke a, ọ jọobu Chiokike be, dazịgidnenu be.  
\v 4 O jookwnosnama kpakara anya-mini n'anya be, ẹnwu jáazịma, mọbu ọgba mkpe, mọbu ọkwna ẹkwna, nhne igbugbu jáazịma, kwnornu nụ nhne ọknani gawhelem.” 
\p  
\v 5 Nye wam dazị nụ ngadna eze wam, kaa, “Le, m neeme kpakara nhne bụru nhne ikne.” Ọ kanụ m, “Gba nhne ka n'ọkwukwo, kwnornu nụ ikwu-ọnu ka bụ ezi ọka ke kwesiri ọkwnata ovu.” 
\p  
\v 6 Ọ kanụ m, “Be menem a. Mawa bụ Alịfa nụ Omega, Ọpanizo nụ Okwukwo. Nye ọbula akpịri nọokpo bẹkwnu, m jeenye a mini ke hi nụ risi mini ke bụdnu n'etekne.  
\v 7 Nye megburu, jeekehịa kpakara nhne ka, m jọoburu Chiokike a, ọ jọoburu nnwọ m.  
\v 8 Kọvu ele ogwnu nụ ele kwé ekwe, nụ ele rụru ọru, ele noogbu badnụ, nụ ele neeme ọyi, nụ ele amusu, nụ ele naakwa rẹnwu, nụ kpakara ele aghalaghala jeekehịa igwe nụ rime olulu bẹkwnu ji rugwu bẹkwnu neerne. Ka bụ ẹnwu ke mgba lawụru.” 
\s1 Jerusẹlem ikne 
\p  
\v 9 Otu n'esilawụru ele enine izi ẹsau wam vu obele awhnụwhnu ipne-aznụ wam vakwnusi m, kaa, “Vaa, m jeegesi i nnwerne be nọolu ikne, bụ nnwerne Nnwọ Atnụrnu wam.”  
\v 10 O vuru m n'Enine zne n'olu okne rugwu zị n'olu, gesi m ẹli-ọhna nsọ wam, bụ Jerusẹlem hi n'oligwe hne Chiokike zị neehiedna.  
\v 11 O vu igwugwu Chiokike, noonwu lele akaworugwu zị okne ọnu ahịa, lele jasịpa, zịri snam lele nyno.  
\v 12 O nwernu mkpọ be tụru a hna n'olu, o nwernu nri nụ ọnuhna lawụru, nụ nri enine izi lawụru neese ọnuhna. Be gbasịri rẹwhna nri nụ avnụrnu lawụru rụmu Izirẹli n'ọnuhna a.  
\v 13 Ọnuhna ẹto zị n'ọbosi ẹhnam, n'olu olu ọnuhna ẹto, n'ẹli ẹli ọnuhna ẹto, n'ọdidna ẹhnam, ọnuhna ẹto.  
\v 14 Mkpọ ẹli wam nwernu ntụ-ẹli n'olu nri nụ akaworugwu lawụru, hne be gbakwasịri rẹwhna ele izi nri nụ ẹbo ke Nnwọ Atnụrnu wam. 
\p  
\v 15 Nye wam naakanụ m ọka ji otu nhne golu be neeji nọotu nhne, nọotu ike ẹli-ọhna wam, kpakara ọnuhna a, nụ ẹhni mkpọ a.  
\v 16 Ẹli-ọhna wam hna n'otu. Ogologo a nụ rude a hna n'otu. O gweru nhne be tụ nhne tụ ẹli-ọhna wam, ọ tụhia otu pokwu nụ riwhu maịli ẹno, ogologo a, nụ rude a, nụ olu a, hna n'otu.  
\v 17 Ọ tụ ẹhni mkpọ wam, tụhia riwhu rula lawụru, lele kpa ọtutu ke badnụ jiri zị, ke enine izi ji nọotu.  
\v 18 Ẹhni mkpọ wam bụ jasịpa, ẹli-ọhna wam bụ golu zị snam, lele nyno.  
\v 19 Be ji agịda akaworugwu zị okne ọnu ahịa mee ntụ-ẹli mkpọ ẹli-ọhna wam mma. Ntụ-ẹli ke mbọm bụ jasịpa, ke ẹbo bụ safịa, ke ẹto bụ kasịdoni, ke ẹno bụ emiradi,  
\v 20 ke isne bụ sadọnisi, ke isunu bụ kanẹlia, ke ẹsau bụ kirisoliti, ke ẹsato bụ berili, ke tolu bụ topasi, ke nri bụ kirisopasisi, ke nri nụ otu bụ jasịnti, ke nri nụ ẹbo bụ ametisi.  
\v 21 Nri nụ ọnuhna lawụru wam bụ palị nri nụ ẹbo, otu ọnuhna otu palị. Ogodo apna ẹli-ọhna wam bụ golu zị snam nọowhnu ọsno lele nyno. 
\p  
\v 22 M whnụ́na m Ọro Nsọ n'ẹli-ọhna wam, kwnornu nụ Nyenwe aị Chiokike ke Meli Nhne Dum nụ Nnwọ Atnụrnu wam bụ Ọro Nsọ a.  
\v 23 Mkpa ẹhnam mọbu ẹnwa zá naakpa a, be zá nọomu nụ rime a, kwnornu nụ igwugwu Chiokike nọomu nụ rime a, Nnwọ Atnụrnu wam bụ iwhne a.  
\v 24 Ele mba ke ọwa jeezne izne n'iwhne a, ele eze ke ọwa jeegweya igwugwu be nụ rime a.  
\v 25 Be jáagbasni ọnuhna ẹli wam, o jeegberu anya kwnornu nụ ọchichiri zị́la nụ rime a.  
\v 26 Be jeegwebnanya nhne igwugwu nụ ọson'anya kpakara mba nụ rime a.  
\v 27 Nhne ọbula ke zị́la rịchna jáabna nụ rime a rịa rịa, mọbu nye ọbula ke neeme nhne rụru ọru, mọbu nye aghalaghala, okwolem ele be gbarụ rẹwhna be nụ rime ọkwukwo ke bụdnu ke Nnwọ Atnụrnu wam. 
\c 22  
\s1 Mini ke bụdnu 
\p  
\v 1 Enine izi wam gesi m osimini ke bụdnu noonwu lele nyno, hi nụ ngadna eze Chiokike nụ ke Nnwọ Atnụrnu wam naagbahịa.  
\v 2 Naagbawhe n'esilawụru ogodo apna ẹli-ọhna wam, nụ ngeri lawụru mini wam isisi ke bụdnu zị, ke naamị nri nụ mgba mkpụru lawụru n'awha ke bụ otu mgba n'ẹnwa. Ọkwukwo isisi wam bụ nhne be ji nọogwo ẹhni igbugbu ele kpakara mba.  
\v 3 Ọvu ọnu zị́ma rịa rịa. Ngadna eze Chiokike nụ ke Nnwọ Atnụrnu wam jaazị n'ẹli-ọhna wam, ele izi a jeeznenu a izi.  
\v 4 Be jọowhnu ruwhnu a, rẹwhna a jaazị n'egedege ruwhnu be.  
\v 5 Abalị jáazịma berere, be jọ́omu tọnji, ẹhnam jọ́omu, kwnornu nụ Nyenwe aị Chiokike jeenye be iwhne, be jẹechi lele eze tim tọm.  
\v 6 Enine izi wam kanụ m, “Ikwu-ọnu ka bụ ezi ọka ke kwesiri ọkwnata ovu. Nyenwe aị Chiokike ke enine ele ọwhnurninya ziyaru enine izi a gesi ele izi a kpakara nhne jeemerịri n'ige matị vazne nụ ruwhnu.” 
\s1 Jizọsi vawa 
\p  
\v 7 “Le, m vawa wara wara, ngọzi jaazịnu ele jaabịta ikwu-ọnu ọwhnurninya ke ọkwukwo ka.” 
\p  
\v 8 Mawa, Jọni, nụrnu, whnụ masị kpakara nhne ka. Nga me nụrnu, whnụ kwo masị, m dna n'ẹli n'ọchi enine izi nye gesiri m kpakara nhne ka ma m kpọnu m a risi ẹli.  
\v 9 Kọvu ọ kannụ m, “I mée kpam, m bụ m nye izi ibne i, nụ ke rụmu nda ị ele ọwhnurninya, nụ kpakara ele jaabịta ikwu-ọnu ọkwukwo ka. Kpọnu Chiokike risi ẹli.” 
\p  
\v 10 Ọ kanụ m, “I túgwa ikwu-ọnu ke ọkwukwo ọwhnurninya ka, kwnornu nụ ige zị ndụndu.  
\v 11 Nye ọjo mernu nhne ọjo a zne ruwhnu, nye zị́la rịchna, ọ zị́la rịchna a zne ruwhnu, nye mee mma, mernu mma a zne ruwhnu, nye zị nsọ, zịri nsọ a zne ruwhnu.” 
\p  
\v 12 “Le, m vawa wara wara, ọgwo ẹrnu m zị m n'aka, m jeenye nye ọbula lele kpa ẹrnu a jiri zịri.  
\v 13 Mawa bụ Alịfa nụ Omega, Nye Mbọm nụ Nye Ipne-aznụ, Ọpanizo nụ Okwukwo. 
\p  
\v 14 “Ngọzi jaazịnu ele snụrnu iwo awura be, be nwernu rikne o ri mkpụru isisi ke bụdnu wam, be jeehi n'ogodo ọnuhna bnazne nụ rime ẹli-ọhna wam.  
\v 15 Kọvu rụmu nkịta, nụ ele amusu, nụ ele neeme ọyi, nụ ele noogbu badnụ, nụ ele naakwa rẹnwu, nụ ele whnụrnu aghalaghala n'anya neeme be jaazị n'ederezi. 
\p  
\v 16 “Mawa Jizọsi, ziyaru enine izi m ọ gba akebne kpakara nhne ka nụ rime kpakara ọgbako Chiokike. Mawa bụ Mgbarẹgwnugwnu nụ Nnwọ Devidi, Mbọ ọsisi marnụ mma.” 
\p  
\v 17 Enine Nsọ nụ nnwerne ikne karụ, “Vaa.” Nye ọbula ke nụrnu, kaa, “Vaa.” Nye ọbula akpịri nọokpo bẹkwnu, vaa, nye ọ masịri gweru mini ke bụdnu n'etekne nwọrnu. 
\p  
\v 18 M nọodo nye ọbula ke nụrnu ikwu-ọnu ke ọkwukwo ọwhnurninya ka aka nụ nsnị, nye ọbula ke tụkwasiri nhne n'olu a, Chiokike jọotukwasinu a nhne nụ kpakara awhnụwhnu be gbarụ n'ọkwukwo ka.  
\v 19 Nye ọbula ke gwemernu nhne n'ikwu-ọnu ke ọkwukwo ọwhnurninya ka, Chiokike jeegweme igwe a n'isisi ke bụdnu nụ ẹli-ọhna nsọ, ke bụ nhne be gbarụ n'ọkwukwo ka. 
\p  
\v 20 Nye gbarụ akebne kpakara nhne ka karụ, “Owe, m vawa wara wara.” 
\p Amịm. Vaa, Nyenwe aị Jizọsi. 
\p  
\v 21 Oru ke Nyenwe aị Jizọsi dazịnu kpakara anụ. Amịm.