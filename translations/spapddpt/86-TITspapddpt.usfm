\toc1 Carta de Pablo a Tito 
\mt1 Tito  
\c 1  
\s1 Saludo  
\p
\v 1 \w Pablo|strong="G3972"\w*, \w un|strong="G3588"\w* esclavo \w de|strong="G2596"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* apóstol \w de|strong="G2596"\w* \w Jesucristo|strong="G2424"\w*, \w según|strong="G2596"\w* \add la\add* \w fe|strong="G4102"\w* \w de|strong="G2596"\w* \w los|strong="G3588"\w* \w escogidos|strong="G1588"\w* \w de|strong="G2596"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \add el\add* \w conocimiento|strong="G1922"\w* \w de|strong="G2596"\w* \w la|strong="G3588"\w* \w verdad|strong="G4102"\w* \w en|strong="G2596"\w* \w la|strong="G3588"\w* \w piedad|strong="G2150"\w*,  
\v 2 \w con|strong="G1909"\w* respecto \w a|strong="G1909"\w* \add la\add* \w esperanza|strong="G1680"\w* \w de|strong="G1909"\w* \w vida|strong="G2222"\w* eterna, \w la|strong="G3588"\w* \w cual|strong="G3739"\w* \w Dios|strong="G2316"\w*, \w Quien|strong="G3739"\w* no miente, \w prometió|strong="G1861"\w* \w antes|strong="G4253"\w* \w de|strong="G1909"\w* \add los \add*\w tiempos|strong="G5550"\w* eternos.  
\v 3 \w Pero|strong="G1161"\w* \w a|strong="G1722"\w* \w su|strong="G3588"\w* debido \w tiempo|strong="G2540"\w* reveló \w su|strong="G3588"\w* \w Palabra|strong="G3056"\w* \w por|strong="G1722"\w* \add la \add*\w predicación|strong="G2782"\w* \w la|strong="G3588"\w* \w cual|strong="G3739"\w* \w me|strong="G1473"\w* fue encomendada \w por|strong="G1722"\w* orden \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*.   
\p
\v 4 \w A|strong="G2596"\w* \w Tito|strong="G5103"\w*, genuino \w hijo|strong="G5043"\w* \w según|strong="G2596"\w* \add la \add*\w fe|strong="G4102"\w* \w común|strong="G2839"\w*. \w Gracia|strong="G5485"\w* \w y|strong="G2532"\w* \w paz|strong="G1515"\w* \w de|strong="G2596"\w* \w Dios|strong="G2316"\w* \w Padre|strong="G3962"\w* \w y|strong="G2532"\w* \w de|strong="G2596"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w*, \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*.   
\s1 Tito en Creta  
\p
\v 5 \w Por|strong="G1722"\w* \w esta|strong="G3778"\w* \w razón|strong="G2596"\w* \w te|strong="G4771"\w* dejé \w en|strong="G1722"\w* \w Creta|strong="G2914"\w*, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w te|strong="G4771"\w* encargaras \w de|strong="G1722"\w* poner \w en|strong="G1722"\w* orden \w las|strong="G3588"\w* cosas desordenadas, \w y|strong="G2532"\w* designaras \w ancianos|strong="G4245"\w* \w en|strong="G1722"\w* \w cada|strong="G2596"\w* \w ciudad|strong="G4172"\w*, \w como|strong="G5613"\w* \w yo|strong="G1473"\w* \w me|strong="G1473"\w* propuse.   
\s1 Requisitos para los ancianos  
\p
\v 6 \w El|strong="G5100"\w* anciano debe \w ser|strong="G2192"\w* irreprochable, esposo \w de|strong="G1722"\w* \w una|strong="G1520"\w* sola \w esposa|strong="G1135"\w*, \w que|strong="G5101"\w* \w tenga|strong="G2192"\w* \w hijos|strong="G5043"\w* \w fieles|strong="G4103"\w*, \w no|strong="G3361"\w* \w con|strong="G1722"\w* \w acusación|strong="G2724"\w* \w de|strong="G1722"\w* relajamiento moral \w o|strong="G2228"\w* rebeldes.  
\v 7 \w Porque|strong="G1063"\w* es \w necesario|strong="G1163"\w* \w que|strong="G3588"\w* \w el|strong="G3588"\w* supervisor \w sea|strong="G3588"\w* irreprochable \w como|strong="G5613"\w* administrador \w de|strong="G3588"\w* \w Dios|strong="G2316"\w*: \w no|strong="G3361"\w* arrogante, \w no|strong="G3361"\w* \w iracundo|strong="G3711"\w*, \w no|strong="G3361"\w* adicto \w al|strong="G3588"\w* vino, \w no|strong="G3361"\w* pendenciero, \w no|strong="G3361"\w* codicioso \w de|strong="G3588"\w* ganancia deshonesta,  
\v 8 sino \w hospedador|strong="G5382"\w*, amante de lo bueno, prudente, \w justo|strong="G1342"\w*, \w santo|strong="G3741"\w*, disciplinado,  
\v 9 \w que|strong="G3588"\w* retenga \add la\add* \w palabra|strong="G3056"\w* \w fiel|strong="G4103"\w*, \w según|strong="G2596"\w* \w la|strong="G3588"\w* \w doctrina|strong="G1322"\w*, \w a|strong="G1722"\w* fin \w de|strong="G1722"\w* \w que|strong="G3588"\w* \w también|strong="G2532"\w* \w pueda|strong="G1415"\w* \w exhortar|strong="G3870"\w* \w con|strong="G1722"\w* \w la|strong="G3588"\w* \w sana|strong="G5198"\w* \w doctrina|strong="G1322"\w* \w y|strong="G2532"\w* \w convencer|strong="G1651"\w* \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* contradicen.   
\p
\v 10 \w Porque|strong="G1063"\w* \w hay|strong="G3588"\w* \w muchos|strong="G4183"\w* indisciplinados, habladores \w de|strong="G1537"\w* vanidades \w y|strong="G2532"\w* \w engañadores|strong="G5423"\w*, especialmente \w de|strong="G1537"\w* \w los|strong="G3588"\w* judíos,  
\v 11 a \w quienes|strong="G3739"\w* hay \w que|strong="G3739"\w* silenciar, \w que|strong="G3739"\w* trastornan familias \w enteras|strong="G3650"\w*, pues \w enseñan|strong="G1321"\w* \w lo|strong="G3739"\w* \w que|strong="G3739"\w* \w no|strong="G3361"\w* \w es|strong="G3739"\w* \w necesario|strong="G1163"\w* \w por|strong="G5484"\w* amor a \w una|strong="G3739"\w* ganancia deshonesta.   
\p
\v 12 \w Uno|strong="G5100"\w* \w de|strong="G1537"\w* \w ellos|strong="G1537"\w*, \w su|strong="G2398"\w* \w propio|strong="G2398"\w* \w profeta|strong="G4396"\w*, \w dijo|strong="G3004"\w*: \w Cretenses|strong="G2912"\w*, siempre \w mentirosos|strong="G5583"\w*, \w malas|strong="G2556"\w* \w bestias|strong="G2342"\w*, glotones ociosos.  
\v 13 \w Este|strong="G3778"\w* \w testimonio|strong="G3141"\w* \w es|strong="G3739"\w* verdadero. \w Por|strong="G1223"\w* \w lo|strong="G3588"\w* \w cual|strong="G3739"\w*, \w repréndelos|strong="G1651"\w* severamente \w para|strong="G2443"\w* \w que|strong="G3588"\w* sean \w sanos|strong="G5198"\w* \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w*,  
\v 14 \w que|strong="G3588"\w* \w no|strong="G3361"\w* fijen \add la\add* atención \w en|strong="G3588"\w* \w fábulas|strong="G3454"\w* \w judaicas|strong="G2451"\w* \w y|strong="G2532"\w* \w mandamientos|strong="G1785"\w* \w de|strong="G3588"\w* hombres \w que|strong="G3588"\w* \w se|strong="G2532"\w* apartan \w de|strong="G3588"\w* \w la|strong="G3588"\w* verdad.   
\p
\v 15 \w Todas|strong="G3956"\w* \w las|strong="G3588"\w* cosas son puras para \w los|strong="G3588"\w* puros, \w pero|strong="G1161"\w* para \w los|strong="G3588"\w* \w contaminados|strong="G3392"\w* \w e|strong="G2532"\w* incrédulos \w nada|strong="G3762"\w* es \w puro|strong="G2513"\w*. \w Pues|strong="G1161"\w* \w aun|strong="G2532"\w* \w la|strong="G3588"\w* \w mente|strong="G3563"\w* \w y|strong="G2532"\w* \w la|strong="G3588"\w* \w conciencia|strong="G4893"\w* \w de|strong="G3588"\w* \w ellos|strong="G3588"\w* fueron contaminadas.  
\v 16 Profesan \w conocer|strong="G1492"\w* \w a|strong="G4314"\w* \w Dios|strong="G2316"\w*, \w pero|strong="G1161"\w* \w con|strong="G4314"\w* \w los|strong="G3588"\w* \w hechos|strong="G2041"\w* \w lo|strong="G3588"\w* niegan, \w pues|strong="G1161"\w* \w son|strong="G1510"\w* repugnantes \w y|strong="G2532"\w* desobedientes, descalificados \w para|strong="G4314"\w* \w toda|strong="G3956"\w* buena \w obra|strong="G2041"\w*.   
\c 2  
\s1 Sana doctrina  
\p
\v 1 \w Pero|strong="G1161"\w* \w tú|strong="G4771"\w* \w habla|strong="G2980"\w* \w lo|strong="G3588"\w* \w que|strong="G3588"\w* \w es|strong="G3739"\w* conveniente \w a|strong="G1161"\w* \w la|strong="G3588"\w* \w sana|strong="G5198"\w* \w doctrina|strong="G1319"\w*.   
\p
\v 2 \w Que|strong="G3588"\w* \add los\add* hombres mayores sean sobrios, dignos \w de|strong="G3588"\w* respeto, sensibles, \w sanos|strong="G5198"\w* \w en|strong="G3588"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w*, \w en|strong="G3588"\w* \w el|strong="G3588"\w* amor \w y|strong="G1510"\w* \w en|strong="G3588"\w* \w la|strong="G3588"\w* perseverancia.   
\p
\v 3 \w Asimismo|strong="G5615"\w*, \w que|strong="G3361"\w* \add las\add* mujeres mayores sean dignas \w de|strong="G1722"\w* reverencia \w por|strong="G1722"\w* su conducta, \w no|strong="G3361"\w* \w calumniadoras|strong="G1228"\w*, \w no|strong="G3361"\w* esclavizadas \w a|strong="G1722"\w* \w mucho|strong="G4183"\w* \w vino|strong="G3631"\w*, \w maestras|strong="G2567"\w* \w de|strong="G1722"\w* cosas buenas,  
\v 4 \w que|strong="G3588"\w* animen \w a|strong="G2443"\w* \w las|strong="G3588"\w* jóvenes \w a|strong="G2443"\w* \w que|strong="G3588"\w* amen \w a|strong="G2443"\w* \w sus|strong="G3588"\w* esposos \w y|strong="G1510"\w* \w a|strong="G2443"\w* \w sus|strong="G3588"\w* hijos,  
\v 5 \w que|strong="G3588"\w* sean \w prudentes|strong="G4998"\w*, castas, cuidadoras \w de|strong="G3588"\w* \w su|strong="G3588"\w* casa, buenas, sometidas \w a|strong="G2443"\w* \w sus|strong="G3588"\w* esposos, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w la|strong="G3588"\w* \w Palabra|strong="G3056"\w* \w de|strong="G3588"\w* \w Dios|strong="G2316"\w* \w no|strong="G3361"\w* \w sea|strong="G3588"\w* blasfemada.   
\p
\v 6 \w Exhorta|strong="G3870"\w* también a \w los|strong="G3588"\w* jóvenes a ser razonables.   
\p
\v 7 Preséntate \w tú|strong="G3588"\w* mismo \w en|strong="G1722"\w* \w todo|strong="G3956"\w* \w como|strong="G1722"\w* \w ejemplo|strong="G5179"\w* \w de|strong="G4012"\w* \w buenas|strong="G2570"\w* \w obras|strong="G2041"\w*, \w con|strong="G1722"\w* pureza \w de|strong="G4012"\w* \w doctrina|strong="G1319"\w*, seriedad,  
\v 8 \w palabra|strong="G3056"\w* \w sana|strong="G5199"\w* e irreprochable, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w el|strong="G3588"\w* \w adversario|strong="G1537"\w* \w sea|strong="G3588"\w* avergonzado \w y|strong="G2443"\w* \w no|strong="G3367"\w* \w tenga|strong="G2192"\w* algo malo \w que|strong="G3588"\w* \w decir|strong="G3004"\w* \w en|strong="G1537"\w* \w cuanto|strong="G4012"\w* \w a|strong="G1537"\w* \w nosotros|strong="G2249"\w*.   
\p
\v 9 \w A|strong="G1722"\w* \add los \add*esclavos, \w que|strong="G3361"\w* sean sometidos \w a|strong="G1722"\w* \w sus|strong="G2398"\w* \w amos|strong="G1203"\w* \w en|strong="G1722"\w* \w todo|strong="G3956"\w*, \w que|strong="G3361"\w* sean complacientes, \w que|strong="G3361"\w* \w no|strong="G3361"\w* contradigan,  
\v 10 \w que|strong="G3588"\w* \w no|strong="G3361"\w* se apropien indebidamente \add de algo\add*, \w sino|strong="G3361"\w* \w que|strong="G3588"\w* muestren \w toda|strong="G3956"\w* buena \w fe|strong="G4102"\w* \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w en|strong="G1722"\w* \w todo|strong="G3956"\w* \w adornen|strong="G2885"\w* \w la|strong="G3588"\w* \w doctrina|strong="G1319"\w* \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*.   
\p
\v 11 \w Porque|strong="G1063"\w* \w la|strong="G3588"\w* \w gracia|strong="G5485"\w* salvadora \w de|strong="G3588"\w* \w Dios|strong="G2316"\w* se manifestó a \w todos|strong="G3956"\w* \w los|strong="G3588"\w* hombres,  
\v 12 \w y|strong="G2532"\w* nos enseñó \w que|strong="G3588"\w*, \w después|strong="G2532"\w* \w de|strong="G1722"\w* apartarnos \w de|strong="G1722"\w* \w la|strong="G3588"\w* impiedad \w y|strong="G2532"\w* \w de|strong="G1722"\w* \w las|strong="G3588"\w* pasiones mundanas, \w vivamos|strong="G2198"\w* sobria, \w justa|strong="G1346"\w* \w y|strong="G2532"\w* piadosamente \w en|strong="G1722"\w* \w el|strong="G3588"\w* mundo \w presente|strong="G3568"\w*,  
\v 13 \w que|strong="G3588"\w* \w nos|strong="G2316"\w* acojamos a \w la|strong="G3588"\w* \w esperanza|strong="G1680"\w* \w bienaventurada|strong="G3107"\w* \w y|strong="G2532"\w* \add la\add* \w aparición|strong="G2015"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w gloria|strong="G1391"\w* \w de|strong="G3588"\w* \w nuestro|strong="G2249"\w* \w gran|strong="G3173"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w Salvador|strong="G4990"\w* \w Jesucristo|strong="G2424"\w*,  
\v 14 \w Quien|strong="G3739"\w* \w se|strong="G1438"\w* \w dio|strong="G1325"\w* \w a|strong="G2443"\w* \w sí|strong="G1438"\w* mismo \w por|strong="G5228"\w* \w nosotros|strong="G2249"\w* \w para|strong="G2443"\w* librarnos \w de|strong="G1325"\w* \w toda|strong="G3956"\w* iniquidad, \w y|strong="G2532"\w* purificar \w para|strong="G2443"\w* \w sí|strong="G1438"\w* un \w pueblo|strong="G2992"\w* escogido, \w celoso|strong="G2207"\w* \w de|strong="G1325"\w* \w buenas|strong="G2570"\w* \w obras|strong="G2041"\w*.   
\p
\v 15 \w Habla|strong="G2980"\w* \w estas|strong="G3778"\w* cosas, \w exhorta|strong="G3870"\w* \w y|strong="G2532"\w* \w reprende|strong="G1651"\w* \w con|strong="G3326"\w* \w toda|strong="G3956"\w* \w autoridad|strong="G2003"\w*. \w Nadie|strong="G3367"\w* \w te|strong="G4771"\w* menosprecie.   
\c 3  
\s1 Salvación gratuita  
\p
\v 1 \w Recuérdales|strong="G5279"\w* que \w se|strong="G1438"\w* sometan \w a|strong="G4314"\w* gobernantes \w y|strong="G1510"\w* autoridades, que estén preparados \w para|strong="G4314"\w* \w toda|strong="G3956"\w* \w obra|strong="G2041"\w* buena,  
\v 2 que \w a|strong="G4314"\w* \w nadie|strong="G3367"\w* difamen, que sean apacibles, tolerantes, que muestren \w toda|strong="G3956"\w* \w mansedumbre|strong="G4240"\w* \w a|strong="G4314"\w* \w todos|strong="G3956"\w* \add los\add* hombres.   
\p
\v 3 \w Porque|strong="G1063"\w* \w nosotros|strong="G2249"\w* \w también|strong="G2532"\w* \w éramos|strong="G1510"\w* \w en|strong="G1722"\w* \w otro|strong="G4218"\w* tiempo insensatos, desobedientes, \w extraviados|strong="G4105"\w*. \w Éramos|strong="G1510"\w* esclavos \w de|strong="G1722"\w* \w deseos|strong="G1939"\w* apasionados \w y|strong="G2532"\w* placeres \w diversos|strong="G4164"\w*, \w y|strong="G2532"\w* vivíamos \w en|strong="G1722"\w* \w malicia|strong="G2549"\w* \w y|strong="G2532"\w* \w envidia|strong="G5355"\w*, \w aborrecibles|strong="G4767"\w* \w y|strong="G2532"\w* nos odiábamos unos \w a|strong="G1722"\w* otros.   
\p
\v 4 \w Pero|strong="G1161"\w* \w cuando|strong="G3753"\w* \w la|strong="G3588"\w* \w bondad|strong="G5544"\w* \w de|strong="G3588"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w* \w y|strong="G2532"\w* \add su\add* \w amor|strong="G5363"\w* \w por|strong="G3588"\w* \w la|strong="G3588"\w* humanidad \w se|strong="G2532"\w* manifestaron,  
\v 5 nos \w salvó|strong="G4982"\w*, \w no|strong="G3756"\w* \w por|strong="G1223"\w* \w obras|strong="G2041"\w* \w que|strong="G3588"\w* \w nosotros|strong="G2249"\w* \w hicimos|strong="G4160"\w* \w en|strong="G1722"\w* \w justicia|strong="G1343"\w*, sino \w según|strong="G2596"\w* \w su|strong="G3588"\w* \w misericordia|strong="G1656"\w*, \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w del|strong="G3588"\w* lavamiento \w de|strong="G1537"\w* \w la|strong="G3588"\w* \w regeneración|strong="G3824"\w* \w y|strong="G2532"\w* renovación \w del|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo,  
\v 6 \w el|strong="G3588"\w* \w cual|strong="G3739"\w* \w derramó|strong="G1632"\w* \w abundantemente|strong="G4146"\w* \w en|strong="G1909"\w* \w nosotros|strong="G2249"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1909"\w* \w Jesucristo|strong="G2424"\w*, \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*,  
\v 7 \w para|strong="G2443"\w* \w que|strong="G3588"\w*, \w justificados|strong="G1344"\w* \w por|strong="G2596"\w* \w aquella|strong="G1565"\w* \w gracia|strong="G5485"\w*, \w seamos|strong="G1096"\w* \w herederos|strong="G2818"\w* \w según|strong="G2596"\w* \add la \add*promesa \w de|strong="G2596"\w* \w vida|strong="G2222"\w* eterna.   
\p
\v 8 \w La|strong="G3588"\w* \w Palabra|strong="G3056"\w* \w es|strong="G3778"\w* \w fiel|strong="G4103"\w*. \w Con|strong="G2532"\w* \w respecto|strong="G4012"\w* \w a|strong="G2443"\w* \w esto|strong="G3778"\w* \w quiero|strong="G1014"\w* insistirte \w con|strong="G2532"\w* firmeza, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w creen|strong="G4100"\w* \w en|strong="G4012"\w* \w Dios|strong="G2316"\w* estén preocupados \w por|strong="G4012"\w* \w hacer|strong="G2041"\w* \w buenas|strong="G2570"\w* \w obras|strong="G2041"\w*. \w Estas|strong="G3778"\w* cosas \w son|strong="G1510"\w* \w buenas|strong="G2570"\w* \w y|strong="G2532"\w* beneficiosas \w para|strong="G2443"\w* \w los|strong="G3588"\w* hombres.   
\p
\v 9 \w Pero|strong="G1161"\w* \w evita|strong="G4026"\w* necedades, controversias, \w genealogías|strong="G1076"\w*, \w contiendas|strong="G2054"\w* \w y|strong="G2532"\w* discusiones sobre cosas pertenecientes \w a|strong="G1161"\w* la Ley, \w porque|strong="G1063"\w* \w son|strong="G1510"\w* peligrosas \w y|strong="G2532"\w* vacías.   
\p
\v 10 Rechaza al hombre \w que|strong="G2532"\w*, \w después|strong="G3326"\w* de \w una|strong="G1520"\w* \w y|strong="G2532"\w* \w otra|strong="G1208"\w* \w amonestación|strong="G3559"\w*, causa divisiones.  
\v 11 \w Sabes|strong="G1492"\w* \w que|strong="G3754"\w* \w se|strong="G1492"\w* pervirtió \w y|strong="G2532"\w* \w al|strong="G3588"\w* ser condenado \w por|strong="G3754"\w* \w sí|strong="G2532"\w* mismo, peca.   
\s1 Recomendaciones y despedida  
\p
\v 12 \w Cuando|strong="G3752"\w* \w te|strong="G4771"\w* \w envíe|strong="G3992"\w* \w a|strong="G1519"\w* Artemas \w o|strong="G2228"\w* \w a|strong="G1519"\w* Tíquico, haz todo esfuerzo \w por|strong="G1519"\w* visitarme \w en|strong="G1519"\w* \w Nicópolis|strong="G3533"\w*, \w porque|strong="G1063"\w* decidí pasar \w allí|strong="G1563"\w* el invierno.  
\v 13 Encamina diligentemente \w a|strong="G2443"\w* Zenas, \w el|strong="G3588"\w* abogado, \w y|strong="G2532"\w* \w a|strong="G2443"\w* Apolos, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w nada|strong="G3367"\w* les \w falte|strong="G3007"\w*.   
\p
\v 14 \w Aprendan|strong="G3129"\w* \w también|strong="G2532"\w* \w los|strong="G3588"\w* \w nuestros|strong="G2251"\w* \w a|strong="G1519"\w* ocuparse \w en|strong="G1519"\w* \w buenas|strong="G2570"\w* \w obras|strong="G2041"\w* \w para|strong="G1519"\w* \w las|strong="G3588"\w* \w necesidades|strong="G5532"\w* urgentes \w a|strong="G1519"\w* fin \w de|strong="G1519"\w* \w que|strong="G3588"\w* \w no|strong="G3361"\w* \w se|strong="G2532"\w* queden \w sin|strong="G3361"\w* fruto.   
\p
\v 15 \w Te|strong="G4771"\w* saludan \w todos|strong="G3956"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* están \w conmigo|strong="G3326"\w*. Saluda \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* nos \w aman|strong="G5368"\w* \w en|strong="G1722"\w* \add la\add* \w fe|strong="G4102"\w*. \w La|strong="G3588"\w* \w gracia|strong="G5485"\w* \w sea|strong="G3588"\w* \w con|strong="G3326"\w* \w todos|strong="G3956"\w* ustedes.   