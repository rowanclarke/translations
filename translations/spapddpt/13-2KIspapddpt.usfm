\v 8 Llamó \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, declaró impuros \w los|strong="H5921"\w* \w lugares|strong="H5892"\w* \w altos|strong="H1116"\w* \w donde|strong="H8033"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* quemaban incienso, \w desde|strong="H5704"\w* Geba \w hasta|strong="H5704"\w* Beerseba, \w y|strong="H5921"\w* \w destruyó|strong="H5422"\w* \w los|strong="H5921"\w* \w lugares|strong="H5892"\w* \w altos|strong="H1116"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w puertas|strong="H8179"\w* \w que|strong="H5921"\w* estaban \w en|strong="H5921"\w* \w la|strong="H5921"\w* entrada \w del|strong="H5921"\w* portón \w de|strong="H5921"\w* \w Josué|strong="H3091"\w*, \w gobernador|strong="H8269"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w izquierda|strong="H8040"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* entrada \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.
\v 9 \w Pero|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w sacerdotes|strong="H3548"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* lugares \w altos|strong="H1116"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* les permitió \w subir|strong="H5927"\w* al \w altar|strong="H4196"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w en|strong="H8432"\w* Jerusalén, \w aunque|strong="H3588"\w* \w sí|strong="H3588"\w* comían panes \w sin|strong="H3808"\w* levadura \w entre|strong="H8432"\w* sus hermanos.
