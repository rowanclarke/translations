\v 5 \w Khoyin|strong="G3571"\w* \w khothaih|strong="G2250"\w* \w phuel|strong="G3418"\w* \w ah|strong="G1722"\w* \w khaw|strong="G2532"\w*, \w tlang|strong="G3735"\w* \w ah|strong="G1722"\w* \w khaw|strong="G2532"\w* \w vawpvawp|strong="G3956"\w* \w pang|strong="G2896"\w* \w yoeyah|strong="G1223"\w* \w tih|strong="G2532"\w* \w amah|strong="G1438"\w* te \w lungto|strong="G3037"\w* neh \w huet|strong="G2629"\w* uh.   
\p
