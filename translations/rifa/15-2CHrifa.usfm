\id 2CH
\h 2 إِمزْرُوينْ 
\toc1 2 إِمزْرُوينْ 
\toc2 2 إِمزْرُوينْ 
\toc3 2 إِم. 
\mt1 2 إِمزْرُوينْ  
\c 1
\s1 ثُوثْرَا ن سُولِيمَانْ - أَضْهَارْ أَمزْوَارُو ن سِيذِي إِ سُولِيمَانْ  
\m
\v 1 سُولِيمَانْ، مِّيسْ ن ذَاوُوذْ، إِتّْوَاضْمنْ ذِي ثْڭلْذَا نّسْ، مِينْزِي سِيذِي، أَربِّي نّسْ، ثُوغَا-ث أَكِيذسْ ؤُشَا يَارْنِي ذِي ڒمْغَارثْ نّسْ أَڒْ طَّارْفْ. \x ◘ \xo 1:‏1 \xt [1 إِج. 3‏:‏1‏-‏15]\x*  
\v 2 سُولِيمَانْ إِسِّيوڒْ أَكْ-ذ مَارَّا إِسْرَائِيل، أَكْ-ذ إِمقّْرَاننْ خْ وَاڒفْ ؤُ خْ مْيَا، أَكْ-ذ ڒْقُوضَاثْ ؤُ أَكْ-ذ مَارَّا ڒْحُوكَّامْ ن مَارَّا إِسْرَائِيل، إِزدْجِيفنْ خْ إِبَابَاثنْ \add ن ڒَادْجَاثْ\add*.  
\v 3 نِيثْنِي طّْفنْ أَبْرِيذْ، سُولِيمَانْ ذ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* أَكِيذسْ، غَارْ ڒْڭعّْذثْ نِّي \add إِدْجَانْ\add* غَارْ جِيبْعُونْ، مِينْزِي ذِينِّي إِ ثُوغَا أَقِيضُونْ ن ؤُمْسَاڭَارْ ن أَربِّي إِ إِڭَّا مُوسَا، أَمْسخَّارْ ن سِيذِي، ذِي ڒخْڒَا.  
\v 4 مَاشَا ذَاوُوذْ يِيوِي تَّابُوثْ ن أَربِّي زِي قَارْيَاثْ-يَاعَارِيمْ \add غَارْ ومْشَانْ\add* إِ د أَسْ إِسّوْجذْ ذَاوُوذْ، مِينْزِي نتَّا إِوْثَا إِجّْ ن ؤُقِيضُونْ إِ \add تَّابُوثْ\add* ذِي ؤُرْشَالِيمْ.  
\v 5 أَعَالْطَارْ ن نّْحَاسْ نِّي إِڭَّا بَاصَالِييِيلْ، مِّيسْ ن ؤُرِي، مِّيسْ ن حُورْ، \add ثُوغَا\add* ذِينْ \add ذِي جِيبْعُونْ\add* زَّاثْ إِ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ن سِيذِي. سُولِيمَانْ يُويُورْ ذِينْ \add جْمِيعْ\add* أَكْ-ذ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add*  
\v 6 ؤُشَا إِقدّمْ ذِينْ سُولِيمَانْ، زَّاثْ إِ وُوذمْ ن سِيذِي، إِشْثْ ن ثْغَارْصْثْ خْ ؤُعَالْطَارْ ن نّْحَاسْ نِّي \add إِدْجَانْ\add* غَارْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. نتَّا إِقدّمْ خَاسْ أَڒفْ ن ثْغَارْصَا ن وشْمَاضْ.   
\m
\v 7 ذِي دْجِيڒثْ نِّي، إِبَانْ-د أَربِّي إِ سُولِيمَانْ، إِنَّا أَسْ: ”تَّارْ مِينْ \add ثخْسذْ\add* أَذْ أَشْ \add ث\add* وْشغْ!“  
\v 8 سُولِيمَانْ إِنَّا إِ أَربِّي: ”شكْ ثسّشْنذْ إِ بَابَا ذَاوُوذْ ثَامخْسِيوْثْ \add نّشْ\add* إِشوَّارنْ ؤُ ثڭِّيذْ أَيِي ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.  
\v 9 \add خنِّي\add* ڒخُّو، \add أَ\add* سِيذِي أَربِّي، أجّْ أَذْ إِفّغْ وَاوَاڒْ نّشْ إِ ثسِّيوْڒذْ أَكْ-ذ بَابَا ذَاوُوذْ س ثِيذتّْ، مِينْزِي ثڭِّيذْ أَيِي ذ أَجدْجِيذْ خْ إِجّْ ن ڒْڭنْسْ إِوْسعْ أَمْ ثْعجَّاجْثْ ن ثمُّورْثْ.  
\v 10 أوْشْ أَيِي ڒخُّو ثِيغِيثْ ذ ثُوسّْنَا، حِيمَا أَذْ فّْغغْ ؤُ أَذْ د-ذوْڒغْ زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ-أَ \add أَمْ ڒْحَاكمْ نْسنْ\add*، مِينْزِي وِي إِزمَّارنْ أَذْ إِحْكمْ خْ ڒْڭنْسْ-أَ أَمقّْرَانْ س ڒْحقّْ؟“   
\b  
\m
\v 11 \add خنِّي\add* إِنَّا أَربِّي إِ سُولِيمَانْ: ”مِينْزِي أَيَا غَاركْ ذڭْ وُوڒْ ؤُ مِينْزِي شكْ وَارْ ثتَّارذْ أَڭْڒَا، ڒكْسِيبثْ نِيغْ شَّانْ نِيغْ ثُوذَارْثْ ن يِينِّي إِ شكْ إِشَارّْهنْ، ؤُ وَارْ ثتَّارذْ ثُوذَارْثْ ثَازِيرَارْثْ، مَاشَا مِينْزِي ثتَّارذْ ثِيغِيثْ ذ ثُوسّْنَا حِيمَا أَذْ ثْڭوّْذذْ ڒْڭنْسْ إِنُو س ڒْحقّْ، إِ ونِّي ؤُمِي خفْ ڭِّيغْ شكْ ذ أَجدْجِيذْ،  
\v 12 أَقَا ثمّوْشْ أَشْ \add ڒخُّو\add* ثِيغِيثْ ذ ثُوسّْنَا، ؤُ أَذْ أَشْ وْشغْ عَاوذْ أَڭْڒَا ذ ڒكْسِيبثْ ذ شَّانْ أَمْ مَامّشْ وَارْ \add ثنْ\add* إِطِّيفْ ؤُڒَا ذ إِجّْ ن ؤُجدْجِيذْ قْبڒْ نّشْ ؤُ وَارْ \add ثنْ\add* تّطِّيفنْ \add عَاذْ أَمُّو\add* أَوَارْنِي أَشْ.   
\b  
\m  
\s1 أَفيّضْ ن وَاڭْڒَا ن سُولِيمَانْ  
\m
\v 13 زِي ڒْڭعّْذثْ \add إِ خْ تّْنُومَانْ تّْوهّْبنْ ثِيغَارْصَا\add*، \add ڒْڭعّْذثْ\add* نِّي \add إِدْجَانْ\add* ذِي جِيبْعُونْ أَرنْذَاذْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ، يِيوضْ-د سُولِيمَانْ \add غَارْ\add* ؤُرْشَالِيمْ ؤُشَا إِحْكمْ خْ إِسْرَائِيل. \x ◘ \xo 1:‏13 \xt [1 إِج. 10‏:‏26‏-‏29]\x*  
\v 14 سُولِيمَانْ إِسّْمُونْ إِكَارُّوثنْ ذ إِمْنَاينْ. نتَّا ثُوغَا غَارسْ أَڒفْ ؤُ-أَربْعَا-مْيَا ن إِكَارُّوثنْ ذ ثنْعَاشْ-أَڒفْ ن إِمْنَاينْ ؤُشَا يِيوْيِي ثنْ غَارْ ثْندَّامْ ن إِكَارُّوثنْ ؤُ غَارْ ؤُجدْجِيذْ ذِي ؤُرْشَالِيمْ.  
\v 15 أَجدْجِيذْ إِڭَّا نُّوقَارْثْ ذِي ؤُرْشَالِيمْ أَنشْثْ ن يژْرَا \add نِّي ثُوغَا ذِينْ إِدْجَانْ\add* ؤُشَا إِڭَّا ثِيشجُّورَا ن ثنْڭلْثْ أَنشْثْ إِزمُّورنْ نِّي \add ثُوغَا ذِينْ إِدْجَانْ\add* ذِي ثمُّورْثْ إِوَاطَانْ س وَاطَّاسْ.  
\v 16 إِوْينْ-د إِيْسَانْ إِ سُولِيمَانْ زِي مِيصْرَا، زِي قِيوِي. إِسبَّابنْ ن ؤُجدْجِيذْ إِوْينْ ثنْ س يِيجّْ ن تَّامَانْ \add إِمثْننْ\add* زِي قِيوِي.  
\v 17 إِوْينْ-د إِجّْ ن ؤُكَارُّو ؤُشَا سُّوفّْغنْ ث-إِ-د زِي مِيصْرَا س \add إِجّْ ن تَّامَانْ ن\add* ستَّا-مْيَا \add شِيقْلُو\add* ن نُّوقَارْثْ ؤُ إِجّْ ن ؤُيِيسْ س مْيَا ؤُ-خمْسِينْ \add شِيقْلُو\add*. أَمُّو إِ سُّوفّْغنْ ثنْ س ؤُفُوسْ نْسنْ إِ مَارَّا إِجدْجِيذنْ ن إِحِيتِّييّنْ ؤُ إِ إِجدْجِيذنْ ن أَرَامْ.  
\v 18 سُولِيمَانْ يُومُورْ، حِيمَا أَذْ ثتّْوَابْنَا إِشْثْ ن ثَادَّارْثْ إِ يِيسمْ ن سِيذِي ذ إِشْثْ ن ثَادَّارْثْ إِ ثْڭلْذَا نّسْ.   
\b  
\b  
\m  
\c 2
\s1 أَسوْجذْ إِ ڒبْنِي ن زَّاوشْثْ ثَامقّْرَانْثْ  
\m
\v 1 سُولِيمَانْ إِحْسبْ سبْعِينْ-أَڒفْ ن يرْيَازنْ إِ ثْربُّوثْ ن ڒهْمڒْ ذ ثْمنْيِينْ-أَڒفْ ن يرْيَازنْ حِيمَا أَذْ خدّْمنْ أَمْ يِيسُويْذَاينْ خْ إِذُورَارْ ؤُڒَا ذ ثْڒَاثَا-أَڒَافْ ؤُ ستَّا-مْيَا ن يِينِّي خَاسنْ \add إِدْجَانْ\add* ذ إِوقَّافنْ. \x ◘ \xo 2:‏1 \xt [1 إِج. 5‏:‏15‏-‏32]\x*  
\v 2 خنِّي إِسّكّْ سُولِيمَانْ \add إِجّْ ن ؤُرقَّاسْ\add* غَارْ حِيرَامْ، أَجدْجِيذْ ن صُورْ، إِنَّا: ”\add أڭّْ أَكِيذِي\add* أَمْ مَامّشْ ثڭِّيذْ أَكْ-ذ بَابَا ذَاوُوذْ، ثسّكّذْ غَارسْ أَكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ مَاحنْذْ أَذْ إِبْنَا ثَادَّارْثْ إِ يِيخفْ نّسْ حِيمَا أَذْ ذَايسْ إِزْذغْ.  
\v 3 خْزَارْ، نشّْ خْسغْ أَذْ بْنِيغْ إِشْثْ ن ثَادَّارْثْ إِ يِيسمْ ن سِيذِي، أَربِّي إِنُو، حِيمَا أَذْ أَسْ ت سّْقدّْسغْ، حِيمَا أَذْ سّْبخَّارغْ \add ذِينْ\add* ڒبْخُورْ إِتّْفُوحنْ زَّاثْ إِ وُوذمْ نّسْ، ؤُ حِيمَا أَذْ \add ذِينْ\add* سَّارْسغْ ڒبْذَا \add أَغْرُومْ ن وسْشَانْ\add* ؤُ حِيمَا \add أَذْ ذِينْ قدّْمغْ\add* ثِيغَارْصَا ن وشْمَاضْ، غَارْ ثُوفُّوثْ ؤُ غَارْ ثْمذِّيثْ، ذڭْ وُوسَّانْ ن سّبْثْ، ذڭْ وُوسَّانْ ن ؤُيُورْ ن جْذِيذْ ؤُ ذِي ڒعْيُوذَاثْ إِتّْوَاڭّنْ ن سِيذِي، أَربِّي نّغْ. ذ مَانْ أَيَا \add إِتّْوَاڭّْ\add* خْ إِسْرَائِيل إِ ڒبْذَا.   
\m
\v 4 ثَادَّارْثْ إِ غَا بْنِيغْ، أَذْ ثِيڒِي ذ ثَامقّْرَانْثْ، مَاغَارْ أَربِّي نّغْ ذ أَمقّْرَانْ خْ مَارَّا إِربِّيثنْ.  
\v 5 مَانْ ونْ إِ غَارْ ثدْجَا ثْزمَّارْ أَذْ أَسْ إِبْنَا إِشْثْ ن ثَادَّارْثْ؟ أَقَا أَجنَّا، \add وَاهْ،\add* أَجنَّا ن إِجنْوَانْ، وَارْ إِزمَّارْ أَذْ ث إِكْسِي! ؤُ مِينْ عْنِيغْ نشّْ، أَقَا نشّْ أَذْ أَسْ بْنِيغْ إِشْثْ ن ثَادَّارْثْ مْغِيرْ حِيمَا أَذْ أَسْ سّْبخَّارغْ زَّاثْ إِ وُوذمْ نّسْ؟  
\v 6 \add خنِّي\add* ڒخُّو، سكّْ أَيِي-د إِجّْ ن ورْيَازْ إِ إِزمَّارْ أَذْ إِخْذمْ س وُورغْ ذ نُّوقَارْثْ ذ نّْحَاسْ ذ وُوزَّاڒْ ؤُڒَا س \add ؤُفِيڒُو\add* أَذحْمِي ذ ؤُزڭّْوَاغْ إِحذْقنْ ذ ؤُذهْمَانِي، إِجّْ ن ورْيَازْ إِ إِسّنْ أَذْ إِڭّْ إِنْقَاشنْ، \add وَاهْ، سكّْ إِ-ث جْمِيعْ\add* أَكْ-ذ إِمِيغِيسنْ نِّي غَارِي ذِي يَاهُوذَا ؤُ ذِي ؤُرْشَالِيمْ، إِنِّي د-يِيوِي بَابَا ذَاوُوذْ.  
\v 7 سِيوضْ أَيِي-د ؤُڒَا ذ أَكشُّوضْ \add ن ثْشجَّارْثْ\add* ن ثنْڭلْثْ ذ ؤُمرْزِي ذ ؤُكشُّوضْ \add ن ثْشجَّارْثْ\add* ن صَانْذلْ أَزڭّْوَاغْ، مِينْزِي نشّْ سّْنغْ، أَقَا إِمْسخَّارنْ نّشْ تّْحَاكَانْ ذڭْ ؤُنزْذَامْ ن ثْشجُّورَا ن لُوبْنَانْ، ؤُ خْزَارْ، إِمْسخَّارنْ إِنُو \add أَذْ وْشنْ أَفُوسْ\add* إِ إِمْسخَّارنْ نّشْ، \f ◼ \fr 2:‏7 \ft \+bd ’أَمرْزِي‘\+bd* - نِيغْ ’أَمضْزِي‘.\f*  
\v 8 مَاحنْذْ أَذْ أَيِي سّْوجْذنْ مَارَّا أَكشُّوضْ \add نِّي\add*، مَاغَارْ ثَادَّارْثْ نِّي إِ غَا بْنِيغْ، أَذْ ثِيڒِي ذ ثَامقّْرَانْثْ ذ ڒعْجبْ.  
\v 9 خْزَارْ، نشّْ أَذْ وْشغْ إِ إِمْسخَّارنْ نّشْ، زعْمَا إِ إِنزْذَامنْ نِّي إِزدّْمنْ ثِيشجُّورَا، عِيشْرِينْ-أَڒفْ \add ن ڒْقدّْ\add* ن ؤُكُورُو ن يِيرْذنْ ذ عِيشْرِينْ-أَڒفْ \add ن ڒْقدّْ ن\add* ؤُكُورُو ن إِمنْذِي ذ عِيشْرِينْ-أَڒفْ \add ن ڒْقدّْ\add* ن ؤُبَاثُو ن بِينُو ذ عِيشْرِينْ-أَڒفْ \add ن ڒْقدّْ\add* ن ؤُبَاثُو ن زّشْثْ.“ \f ◼ \fr 2:‏9 \ft \+bd ’أَبَاثُو‘\+bd* - إِجّْ ن ’ؤُبَاثُو‘ عْرَاحَاڒْ 20 نِيغْ 40 لِيثْرُو.\f*   
\m
\v 10 حِيرَامْ، أَجدْجِيذْ ن صُورْ، يَارَّا-د س ثِيرَا ؤُشَا إِسّكّْ \add ثَابْرَاثْ-أَ\add* غَارْ سُولِيمَانْ: ”مَاغَارْ سِيذِي إِتّخْسْ ڒْڭنْسْ نّسْ، إِڭَّا شكْ ذ أَجدْجِيذْ خَاسنْ.“  
\v 11 ؤُشَا \add خنِّي\add* إِنَّا حِيرَامْ: ”أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي ن إِسْرَائِيل، ونِّي إِڭِّينْ أَجنَّا ذ ثمُّورْثْ، أَقَا نتَّا إِوْشَا إِ ذَاوُوذْ إِجّْ ن ؤُحنْجِيرْ ذ أَمِيغِيسْ، \add ونِّي\add* غَارْ ثدْجَا ڒفْهَامثْ ذ ڒعْقڒْ، ونِّي إِ غَا إِبْنَانْ إِشْثْ ن ثَادَّارْثْ إِ سِيذِي ؤُڒَا ذ إِشْثْ ن ثَادَّارْثْ إِ ثْڭلْذَا نّسْ!  
\v 12 \add خنِّي\add* ڒخُّو أَذْ سّكّغْ إِجّْ ن ورْيَازْ ذ أَمِيغِيسْ زِي بَابَا حِيرَامْ، ونِّي غَارْ ثدْجَا ثُوسّْنَا ذ ڒفْهَامثْ،   
\m
\v 13 مِّيسْ ن إِشْثْ ن ثمْغَارْثْ زڭْ يسِّيسْ ن دَان. بَابَاسْ ذ إِجّْ ن ورْيَازْ زِي صُورْ ونِّي غَارْ إِدْجَا ثُوسّْنَا حِيمَا أَذْ إِخْذمْ س وُورغْ، نُّوقَارْثْ، نّْحَاسْ، ؤُزَّاڒْ ؤُ س وژْرُو ذ ؤُكشُّوضْ، س \add ؤُفِيڒُو\add* أَرْجُووَانِي ذ ؤُذهْمَانِي، س ڒقْطنْ أَزْذَاذْ ؤُ س \add ؤُفِيڒُو\add* أَزڭّْوَاغْ إِحذْقنْ، حِيمَا أَذْ إِنْقشْ عْڒَامْ كُوڒْ إِنقَّاشنْ، ؤُ حِيمَا أَذْ يَارْشمْ عْڒَامْ كُوڒْ إِرقَّامنْ نِّي ذ أَسْ إِمّوْشنْ، \add ؤُ مَانْ أَيَا جْمِيعْ\add* أَكْ-ذ إِمِيغِيسنْ نّشْ ذ إِمِيغِيسنْ ن بَابَاشْ ذَاوُوذْ.  
\v 14 \add خنِّي\add* ڒخُّو، أَذْ إِسّكّْ سِيذِي إِنُو إِرْذنْ ذ إِمنْذِي ذ زّشْثْ ذ بِينُو، مِينْ خفْ ثُوغَا إِسَّاوَاڒْ، غَارْ إِمْسخَّارنْ نّسْ.  
\v 15 نشِّينْ أَذْ نزْذمْ ثِيشجُّورَا ن لُوبْنَانْ أَنشْثْ إِ ذ أَشْ إِتّْخصَّانْ ؤُشَا أَذْ أَشْ ثنْثْ إِ-د-نَاوِي خْ ثْغَارُّوبَا ن ثْحنْيَا خْ ڒبْحَارْ غَارْ يَافَا، ؤُ شكْ س يِيخفْ نّشْ أَذْ ثنْثْ ثسّْڭعّْذذْ \add سّنِّي\add* غَارْ ؤُرْشَالِيمْ.“  
\v 16 سُولِيمَانْ إِحْسبْ مَارَّا إِرْيَازنْ إِبَارَّانِييّنْ نِّي \add إِدْجَانْ\add* ذِي ثمُّورْثْ ن إِسْرَائِيل، أَوَارْنِي إِ ڒحْسَابْ ؤُمِي ثنْ إِحْسبْ بَابَاسْ ذَاوُوذْ. ؤُفِينْ \add أَقَا ذِينْ\add* مْيَا ؤُ-ثْڒَاثَا ؤُ-خمْسِينْ-أَڒفْ ؤُ-ستَّا مْيَا \add ن يرْيَازنْ\add*.   
\m
\v 17 سبْعِينْ-أَڒفْ زَّايْسنْ إِڭَّا إِ-ثنْ ذ إِمْسخَّارنْ إِ ثْربُّوثْ ن ڒهْمڒْ ؤُ ثْمنْيِينْ-أَڒفْ ذ إِسُويْذَاينْ خْ إِذُورَارْ ذ ستَّا ؤُ-ثْڒَاثِينْ-مْيَا \add إِڭَّا\add* إِ-ثنْ ذ إِوقَّافنْ حِيمَا أَذْ ڭّنْ ڒْڭنْسْ أَذْ إِخْذمْ.   
\b  
\b  
\m  
\c 3
\s1 ڒبْنِي ن زَّاوشْثْ ثَامقّْرَانْثْ  
\m
\v 1 سُولِيمَانْ إِبْذَا ڒبْنِي ن ثَادَّارْثْ ن سِيذِي ذِي ؤُرْشَالِيمْ خْ وذْرَارْ ن مُورِييَا، مَانِي د-إِبَانْ \add سِيذِي\add* إِ بَابَاسْ ذَاوُوذْ \add ؤُ\add* مَانِي إِسّوْجذْ ذَاوُوذْ إِجّْ ن ومْشَانْ خْ ؤُنذْرَارْ ن ؤُيابُوسِي ؤُرْنَانْ. \x ◘ \xo 3:‏1 \xt [1 إِج. 6‏:‏1‏-‏38؛ 7‏:‏13‏-‏51]\x*  
\v 2 نتَّا إِبْذَا ڒبْنِي ذڭْ ؤُيُورْ وِيسّْ ثْنَاينْ، ذڭْ وَاسّْ وِيسّْ ثْنَاينْ ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا ن ثْڭلْذَا نّسْ.  
\v 3 وَانِيثَا ذ ذْسَاسْ \add إِ إِسَّارْسْ\add* سُولِيمَانْ إِ ڒبْنِي ن ثَادَّارْثْ ن أَربِّي: ثُوزّڭَّارْثْ \add نّسْ\add* ذڭْ إِغَادْجنْ عْلَاحْسَابْ ڒقْيَاسْ أَمزْوَارُو \add ثُوغَا-ت\add* ستِّينْ ن إِغَادْجنْ، ذ ثِيرُو \add نّسْ\add* \add ثُوغَا-ث\add* عِيشْرِينْ ن إِغَادْجنْ.  
\v 4 أَسْقِيفْ ن وَاذَافْ، نِّي \add ثُوغَا إِدْجَانْ\add* غَارْ زَّاثْ ن ثُوزّڭَّارْثْ \add ن ثَادَّارْثْ\add*، \add ثُوغَا-ث\add* ذَايسْ عِيشْرِينْ ن إِغَادْجنْ \add ؤُمِي ثعبَّارنْ\add* غَارْ زَّاثْ ن ثِيرُو ن ثَادَّارْثْ، ؤُ ڒُوعْڒَا \add نّسْ\add* ثُوغَا-ث ذَايسْ مْيَا ؤُ-عِيشْرِينْ ن إِغَادْجنْ. ثُوغَا إِذْڒَا \add وسْقِيفْ ن وَاذَافْ\add* غَارْ ذَاخڒْ س وُورغْ إِصْفَانْ.  
\v 5 ثَادَّارْثْ ثَامقّْرَانْثْ إِڭَّا أَسْ ثَاژقَّا س ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُمرْزِي ؤُشَا يَارْنِي خَاسْ وُورغْ إِصْفَانْ ؤُ إِزوّقْ إِ-ث س ثْشجُّورَا ن ثِينِي ذ سّْنَاسڒْ \add إِزوّْقنْ\add*. \f ◼ \fr 3:‏5 \ft \+bd ’أَمرْزِي‘\+bd* - نِيغْ ’أَمضْزِي‘.\f*  
\v 6 عَاوذْ إِزوّقْ نتَّا ثَادَّارْثْ س يِيژْرَا إِغْڒَانْ. ؤُرغْ ثُوغَا ذ ؤُرغْ زِي فَارَاوَايِيمْ.  
\v 7 أَمُّو إِ إِذْڒَا نتَّا ثَادَّارْثْ، ثِيحنْيَا، ثِينبْذَاثِينْ، ڒحْيُوضْ نّسْ ذ ثوُّورَا نّسْ س وُورغْ، ؤُشَا إِنْقشْ إِكِيرُوبنْ ذِي ڒحْيُوضْ. \f ◼ \fr 3:‏7 \ft \+bd ’إِكِيرُوبنْ‘\+bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*   
\m
\v 8 نتَّا إِڭَّا ؤُڒَا ذ أَخَّامْ ن وقْذَاسْ خْ ؤُقدَّاسْ. ثُوزّڭَّارْثْ نّسْ ذَايسْ عِيشْرِينْ ن إِغَادْجنْ \add ؤُمِي ثعبَّارنْ\add* غَارْ زَّاثْ ن ثِيرُو ن ثَادَّارْثْ. ؤُڒَا ذ ثِيرُو نّسْ \add ثُوغَا-ث ذَايسْ\add* عِيشْرِينْ ن إِغَادْجنْ. نتَّا إِذْڒَا \add ڒحْيُوضْ غَارْ ذَاخڒْ ن\add* وخَّامْ س ستَّا-مْيَا ثَالِينْثْ ن وُورغْ إِصْفَانْ.  
\v 9 ڒوْزنْ ن إِمسْمَارنْ إِسكّْوَا خمْسِينْ شِيقْلُو ن وُورغْ. إِذْڒَا ؤُڒَا ذ ثِيغُورْفَاثِينْ ن سنّجْ س وُورغْ.  
\v 10 ذڭْ وخَّامْ ن وقْذَاسْ خْ ؤُقدَّاسْ إِڭَّا ثْنَاينْ ن إِكِيرُوبنْ، \add أَمْ\add* ڒْخذْمثْ ن ونْقَاشْ، ؤُ إِڒحّفْ إِ-ثنْ س وُورغْ.  
\v 11 أَفْرِيونْ ن إِكِيرُوبنْ \add جْمِيعْ\add* \add عبَّارنْ\add* عِيشْرِينْ ن إِغَادْجنْ ذِي ثُوزّڭَّارْثْ. أَفْرِيوْ أَمزْوَارُو \add إِعبَّارْ\add* خمْسَا ن إِغَادْجنْ ن ثُوزّڭَّارْثْ، إِتَّاكّْوَاضْ ڒْحِيضْ ن ثَادَّارْثْ، ؤُشَا أَفْرِيوْ نّغْنِي ن خمْسَا ن إِغَادْجنْ إِتَّاكّْوَاضْ أَفْرِيوْ ن ؤُكِيرُوبْ نّغْنِي.  
\v 12 أَفْرِيوْ ن ؤُكِيرُوبْ نّغْنِي \add إِعبَّارْ ؤُڒَا ذ\add* خمْسَا ن إِغَادْجنْ، إِتَّاكّْوَاضْ ڒْحِيضْ ن ثَادَّارْثْ. أَفْرِيوْ نّغْنِي ن خمْسَا ن إِغَادْجنْ إِڒقّفْ أَفْرِيوْ ن ؤُكِيرُوبْ نّغْنِي.  
\v 13 أَفْرِيونْ ن إِكِيرُوبنْ-أَ تّْوَابزّْعنْ عِيشْرِينْ ن إِغَادْجنْ ؤُ نِيثْنِي بدّنْ خْ إِضَارنْ نْسنْ ذ إِغمْبَابْ نْسنْ \add سّوْضنْ\add* غَارْ ذَاخڒْ.  
\v 14 نتَّا إِڭَّا ؤُڒَا ذ أَڒحَّافْ س \add ڒقْطنْ\add* أَذحْمِي ذ أَرْجُووَانِي ذ أَزڭّْوَاغْ إِحذْقنْ ؤُ سْ ڒقْطنْ أَزْذَاذْ، ؤُشَا إِڭَّا خَاسْ إِكِيرُوبنْ.   
\b  
\m
\v 15 غَارْ زَّاثْ ن ثَادَّارْثْ إِڭَّا نتَّا ثْنَاينْ ن إِپِيلَارنْ س إِشْثْ ن ثُوزُوڭَّارْثْ ن خمْسَا ؤُ-ثْڒَاثِينْ ن إِغَادْجنْ. تَّاجّْ خْ ثْقِيشَّاثْ نّسْ \add ثُوغَا-ث\add* خمْسَا ن إِغَادْجنْ.  
\v 16 نتَّا إِڭَّا ؤُڒَا ذ سّْنَاسڒْ \add إِزوّْقنْ\add* أَمْ ثِينِّي ذڭْ وخَّامْ ن ذَاخڒْ \add ن زَّاوشْثْ\add* ؤُشَا إِڭَّا إِ-ثنْثْ خْ ثْقِيشَّاثِينْ ن إِپِيلَارنْ. إِڭَّا ؤُڒَا ذ مْيَا ن إِرمَّامنْ ؤُشَا إِشدّْ إِ-ثنْ غَارْ سّْنَاسڒْ \add إِزوّْقنْ\add*.  
\v 17 نتَّا إِسّْبدّْ إِپِيلَارنْ غَارْ زَّاثْ ن زَّاوشْثْ ثَامقّْرَانْثْ، إِجّنْ خْ يفُوسْ ؤُ إِجّنْ خْ ؤُزڒْمَاضْ. ونِّي غَارْ يفُوسْ إِڭَّا أَسْ يَاخِينْ ؤُ ونِّي خْ ؤُزڒْمَاضْ إِڭَّا أَسْ بُوعَازْ.   
\b  
\b  
\m  
\c 4
\m
\v 1 نتَّا إِڭَّا ؤُڒَا ذ أَعَالْطَارْ ن نّْحَاسْ. ثُوزّڭَّارْثْ نّسْ \add ثُوغَا-ت\add* عِيشْرِينْ ن إِغَادْجنْ ؤُ ڒُوعْڒَا نّسْعشْرَا ن إِغَادْجنْ.  
\v 2 خنِّي إِڭَّا نتَّا ثَارِيمَانْثْ إِفسْينْ. \add ثُوغَا ڒعْبَارْ نّسْ\add*عشْرَا ن إِغَادْجنْ زِي طَّارْفْ أَڒْ طَّارْفْ \add نّغْنِي\add*، \add ثُوغَا-ت ذ\add* ثَاقُورَاشْثْ. ثِيذِّي نّسْ \add ثُوغَا-ت\add* خمْسَا ن إِغَادْجنْ ؤُ إِشْثْ ن ؤُفِيڒُو ن ڒعْبَارْ ن ثْڒَاثِينْ ن إِغَادْجنْ إِنّضْ أَسْ-د. \f ◼ \fr 4:‏2 \ft \+bd ’ثَارِيمَانْثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒبْحَارْ‘ نِيغْ ’إِلْ‘.\f*  
\v 3 سَاذُو نّسْ بدّنْثْ ڒخْيَاڒَاثْ ن إِفُونَاسنْ، أَقَا نّْضنْثْ أَسْ-د قَاعْ. \add نُّووَارَاثْ إِ وَارْ د-فِّيغنْثْ عَاذْ\add* ثُوغَا إِ ذ أَسْ د-إِنّْضنْ قَاعْ،عشْرَا ذِي كُوڒْ إِجّْ ن ؤُغِيڒْ، ثُوغَا قّْننْثْ أَكْ-ذ وَايَاوْيَا أَمْ قُووَّارنْثْ إِ ثْرِيمَانْثْ \add ذِي\add* ثْنَاينْ ن إِسذِّييّنْ. \add نُّووَارَاثْ إِ وَارْ د-فِّيغنْثْ عَاذْ\add* ثُوغَا تّْوَافسْينْثْ ذ إِجّنْ \add أَكْ-ذ ثْرِيمَانْثْ\add*.  
\v 4 ثَارِيمَانْثْ ثْبدّْ خْ ثنْعَاشْ ن إِفُونَاسنْ. ثْڒَاثَا زَّايْسنْ أَرِّينْ ؤُذمْ نْسنْ غَارْ شَّامَالْ، ثْڒَاثَا زَّايْسنْ أَرِّينْ ؤُذمْ نْسنْ غَارْ ڒْغَارْبْ، ثْڒَاثَا زَّايْسنْ أَرِّينْ ؤُذمْ نْسنْ غَارْ لْجَانُوبْ ؤُ ثْڒَاثَا زَّايْسنْ أَرِّينْ ؤُذمْ نْسنْ غَارْ شَّارْقْ. ثَارِيمَانْثْ \add ثَارْسَا\add* خَاسنْ ؤُ مَارَّا زّْعنْقُوقَاثْ نْسنْ ذوْڒنْثْ غَارْ ذَاخڒْ.  
\v 5 ثُوغَا \add ثَارِيمَانْثْ\add* ثڭْذَارْ إِجّْ ن شْبَارْ ن ؤُفُوسْ ؤُ ثْمَا نّسْ ثُوغَا أَمْ مَامّشْ تّڭّنْ ثْمَا ن إِجّْ ن ؤُفنْجَاڒْ، \add أَمْ\add* ثْنوَّاشْثْ ن إِشْثْ ن ثْلِيلّشْثْ. ثكْسِي ثْوَاوِيثْ نّسْ ثڒْثْ-أَڒَافْ ن إِبَاثُوثنْ. \f ◼ \fr 4:‏5 \ft \+bd ’ثَالِيلّشْثْ‘\+bd* - إِشْثْ ن مَارْكَا ن إِنُّووَّارنْ ذَايْسنْ أَژْرِي أَطَّاسْ. \+bd ’أَبَاثُو‘\+bd* - إِجّْ ن ’ؤُبَاثُو‘ عْرَاحَاڒْ 20 نِيغْ 40 لِيثْرُو.\f*  
\v 6 إِڭَّا نتَّاعشْرَا ن ثْبَانْيُوثِينْ ؤُشَا إِڭَّا خمْسَا \add زَّايْسنْثْ\add* خْ يفُوسْ ؤُ خمْسَا \add زَّايْسنْثْ\add* خْ ؤُزڒْمَاضْ، حِيمَا أَذْ ذَايْسنْثْ سِّيرْذنْ إِزِييْنَاثْ إِتّْوَاسّْوجْذنْ إِ ثْغَارْصْثْ ن وشْمَاضْ، سِّيرْذنْ \add ثنْثْ\add* ذَايْسنْثْ. \add مَاشَا\add* ثَارِيمَانْثْ ثُوغَا-ت إِ إِكهَّاننْ، مَاحنْذْ أَذْ ذَايسْ سِّيرْذنْ إِخفْ نْسنْ.  
\v 7 نتَّا إِڭَّاعشْرَا ن ڒقْنَاذڒْ ن وُورغْ عْلَاحْسَابْ لْفَارِيضَا ؤُ نتَّا إِسّْبدّْ إِ-ثنْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، خمْسَا خْ يفُوسْ ؤُ خمْسَا خْ ؤُزڒْمَاضْ.  
\v 8 نتَّا إِڭَّاعشْرَا ن ثْزوْضِيوِينْ ؤُشَا إِڭَّا إِ-ثنْثْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، خمْسَا خْ يفُوسْ ؤُ خمْسَا خْ ؤُزڒْمَاضْ. إِڭَّا ؤُڒَا ذ مْيَا ن طَّاوْيَاثْ إِ ؤُرُوشِّي ن وُورغْ.  
\v 9 نتَّا إِڭَّا ڒمْرَاحْ إِحْصَارنْ إِ إِكهَّاننْ ذ ڒمْرَاحْ أَمقّْرَانْ أَكْ-ذ ثوُّورَا إِ ڒمْرَاحْ، ؤُشَا إِڒحّفْ ثِيوُّورَا نْسنْ س نّْحَاسْ.  
\v 10 ثَارِيمَانْثْ إِڭَّا إِ-ت خْ ؤُغزْذِيسْ أَفُوسِي غَارْ زَّاثْ، غَارْ ؤُغزْذِيسْ ن شَّارْقْ، جِّيهثْ ن لْجَانُوبْ.  
\v 11 حِيرَامْ إِڭَّا ؤُڒَا ذ ثِييْذُورِينْ ذ إِغنْجَاجنْ ذ طَّاوْيَاثْ إِ ؤُرُوشِّي. أَمُّو إِ إِكمّڒْ حُورَامْ شْغڒْ إِ ڒقْشُوعْ إِ إِڭَّا إِ ؤُجدْجِيذْ سُولِيمَانْ إِ ثَادَّارْثْ ن أَربِّي.   
\m
\v 12 \add إِڭَّا\add* ثْنَاينْ ن إِپِيلَارنْ ذ إِقُورَارنْ، ذ تِّيجَانْ \add إِ إِدْجَانْ\add* خْ ؤُزدْجِيفْ ن ثْنَاينْ ن إِپِيلَارنْ، ذ ثْنَاينْ ن ثْرَاشِّيوِينْ حِيمَا أَذْ \add زَّايْسنْثْ\add* ذْڒنْ ثْنَاينْ ن إِقُورَارنْ ن تِّيجَانْ \add إِ إِدْجَانْ\add* خْ ؤُزدْجِيفْ ن إِپِيلَارنْ،  
\v 13 ؤُڒَا ذ أَربْعَا-مْيَا ن إِرمَّامنْ إِ ثْنَاينْ ن ثْرَاشِّيوِينْ: ثْنَاينْ ن إِسذِّييّنْ إِ كُوڒْ ثْرَاشَّا حِيمَا أَذْ \add زَّايْسنْ\add* ذْڒنْ ثْنَاينْ ن إِقُورَارنْ ن تِّيجَانْ نِّي \add إِدْجَانْ\add* ثِيوَا سنّجْ خْ وُوذمْ ن إِپِيلَارنْ.  
\v 14 إِڭَّا ثِيكَارُّوثِينْ ؤُ خْ ثْكَارُّوثِينْ إِڭَّا ثِيبَانْيُوثِينْ \add إِ ؤُسِيرْذْ\add*.  
\v 15 \add إِڭَّا ؤُڒَا ذ\add* ثَارِيمَانْثْ ذ إِشْثنْ، ؤُڒَا ذ ثنْعَاشْ ن إِفُونَاسنْ سَاذُو نّسْ.  
\v 16 إِڭَّا حِيرَامْ \add أَكْ-ذ\add* بَابَاسْ ؤُڒَا ذ ثيْذُورِينْ ذ إِغنْجَاجنْ ذ فُورْشَايَاثْ ذ مَارَّا ڒقْشُوعْ نّسْ، إِ ؤُجدْجِيذْ سُولِيمَانْ، إِ ثَادَّارْثْ ن سِيذِي، زِي نّْحَاسْ إِتّْوَاسُّويْذَانْ.  
\v 17 أَجدْجِيذْ إِكبّْ إِ-ثنْ ذڭْ ؤُذوَّارْ ن لْ-ؤُرْذُونْ، ذِي ثْڒَاخْثْ إِڭْذَارنْ جَارْ سُوكُّوثْ ذ صَارَاذَاثَا. \x ◘ \xo 4:‏17 \xt ياش. 3‏:‏16\x*   
\b  
\m
\v 18 سُولِيمَانْ إِڭَّا مَارَّا ڒقْشُوعْ-أَ خْ ؤُبَارُّو أَمقّْرَانْ، أَڒَامِي وَارْ بقّْشنْ شَا \add عَاذْ\add* ذِي ڒوْزنْ ن نّْحَاسْ.  
\v 19 سُولِيمَانْ إِڭَّا مَارَّا ڒقْشُوعْ إِ ثَادَّارْثْ ن أَربِّي: أَعَالْطَارْ ن وُورغْ، ثِيزوْضِيوِينْ مِينْ خفْ \add إِتّْوَامَّارْسْ\add* وغْرُومْ ن وسْشَانْ،  
\v 20 ڒقْنَاذڒْ أَكْ-ذ ڒفْنَارَاثْ نْسنْ نِّي إِتّْخصَّانْ أَذْ أَرْغنْ عْلَاحْسَابْ لْفَارِيضَا زَّاثْ إِ \add وخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add*، \add مَارَّا\add* زڭْ وُورغْ إِزذْڭنْ.  
\v 21 \add إِڭَّا عَاوذْ\add* نُّووَّارْ، ڒفْنَارَاثْ ذ ثْجقَّاضِينْ \add ن ثفْثِيتْشْ\add*، \add مَارَّا\add* زڭْ وُورغْ. ثُوغَا-ث ذ وُورغْ قَاعْ.  
\v 22 ؤُڒَا ذ ثِيجقَّاضِينْ، طَّاوْيَاثْ إِ ؤُرُوشِّي، ثِيغنْجَايِينْ ذ ثْقدُّوحِينْ ن جَّاوِي \add ثُوغَا أَثنْثْ\add* زڭْ وُورغْ إِزذْڭنْ. أَذَافْ ن ثَادَّارْثْ، ثِيوُّورَا ن ذَاخڒْ زَّاثْ إِ وقْذَاسْ خْ ؤُقدَّاسْ ذ ثوُّورَا ن ثَادَّارْثْ ن زَّاوشْثْ ثَامقّْرَانْثْ، \add ثُوغَا أَثنْثْ\add* زڭْ وُورغْ.   
\b  
\b  
\m  
\c 5
\s1 أَذشّنْ ن زَّاوشْثْ ثَامقّْرَانْثْ  
\m
\v 1 أَمُّو إِ ثتّْوَاكمّڒْ مَارَّا ڒْخذْمثْ إِ إِڭَّا سُولِيمَانْ إِ ثَادَّارْثْ ن سِيذِي. ؤُشَا إِسِّيذفْ سُولِيمَانْ مَارَّا ڒقْشُوعْ إِقدّْسنْ ن بَابَاسْ ذَاوُوذْ: نُّوقَارْثْ ذ وُورغْ ذ مَارَّا ڒقْشُوعْ، ؤُشَا إِسَّارْسْ \add مَانْ أَيَا مَارَّا\add* ذڭْ إِخَّامنْ ن ثْخُوبَايْ ن ثَادَّارْثْ ن أَربِّي. \x ◘ \xo 5:‏1 \xt [1 إِج. 8‏:‏1‏-‏66]\x*  
\v 2 خنِّي إِسّْمُونْ سُولِيمَانْ إِمقّْرَاننْ ن إِسْرَائِيل، مَارَّا إِزدْجِيفنْ ن ثْقبَّاڒْ ذ ڒْحُوكَّامْ ن \add ثُوذْرِينْ ن\add* إِبَابَاثنْ ن أَيْثْ ن إِسْرَائِيل. نتَّا إِسّْمُونْ إِ-ثنْ ذِي ؤُرْشَالِيمْ حِيمَا أَذْ سّْڭعّْذنْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي زِي ثنْذِينْثْ ن ذَاوُوذْ، ثنِّي ذ صِيهْيُونْ.  
\v 3 مَارَّا إِرْيَازنْ ن إِسْرَائِيل مُوننْ-د غَارْ ؤُجدْجِيذْ غَارْ ڒْعِيذْ. ثُوغَا-ت ذڭْ ؤُيُورْ وِيسّْ سبْعَا.   
\m
\v 4 مَارَّا إِمقّْرَاننْ ن إِسْرَائِيل ؤُسِينْ-د ؤُشَا سّْڭعّْذنْ إِلَاوِييّنْ تَّابُوثْ.  
\v 5 سّْڭعّْذنْ تَّابُوثْ ن سِيذِي أَكْ-ذ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ ؤُڒَا ذ مَارَّا ڒقْشُوعْ إِقدّْسنْ إِ ثُوغَا ذِينْ إِدْجَانْ ذڭْ ؤُقِيضُونْ. سّْڭعّْذنْ أَيَا إِكهَّاننْ ذ إِلَاوِييّنْ.  
\v 6 مَارَّا ثَامسْمُونْثْ ن إِسْرَائِيل، ثنِّي ثُوغَا غَارسْ إِمُوننْ، ثُوغَا ثْبدّْ أَكْ-ذ ؤُجدْجِيذْ سُولِيمَانْ زَّاثْ إِ تَّابُوثْ. نِيثْنِي وهّْبنْ ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نِّي إِدْجَانْ بْڒَا ڒحْسَابْ، وَارْ زمَّارنْ أَذْ ثنْ قدَّارنْ ذِي سِّيبّثْ ن ؤُبَارُّو نْسنْ.  
\v 7 إِوْينْ إِكهَّاننْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي غَارْ ومْشَانْ نّسْ، غَارْ \add وخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add* ن ثَادَّارْثْ، ذڭْ وقْذَاسْ خْ ؤُقدَّاسْ، أَڒْ سَاذُو وَافْرِيونْ ن إِكِيرُوبنْ. \f ◼ \fr 5:‏7 \ft \+bd ’إِكِيرُوبنْ‘\+bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*  
\v 8 إِكِيرُوبنْ بزّْعنْ ثْنَاينْ ن وَافْرِيونْ نْسنْ خْ ومْشَانْ ن تَّابُوثْ ؤُشَا \add أَمُّو إِ\add* ذْڒِينْ إِكِيرُوبنْ تَّابُوثْ ذ إِعُومَاذْ نّسْ \add إِ ثَاربُّوثْ\add* زِي سنّجْ.  
\v 9 أَوَارْنِي أَيَا سّْڒحْمنْ إِعُومَاذْ \add ن ثَاربُّوثْ\add*، مَاحنْذْ أَذْ بَاننْثْ ثخْفَاوِينْ ن إِعُومَاذْ، إِنِّي د-إِفّْغنْ زِي تَّابُوثْ، غَارْ ؤُغزْذِيسْ ن زَّاثْ ن \add وخَّامْ ن\add* ذَاخڒْ \add ن زَّاوشْثْ\add*، \add مَاشَا\add* وَارْ د-تّْبِينِينْثْ زِي بَارَّا. \add تَّابُوثْ\add* أَقَا-ت ذِينْ أَڒْ أَسّْ-أَ.  
\v 10 ثُوغَا وَارْ إِدْجِي شَا ذِي تَّابُوثْ، مْغِيرْ ثْنَاينْ ن ثڒْوِيحِينْ إِ ذَايسْ إِسَّارْسْ مُوسَا غَارْ هُورِيبْ، ڒَامِي إِڭَّا سِيذِي ڒْعَاهْذْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُمِي د-فّْغنْ زِي مِيصْرَا. \x ◘ \xo 5:‏10 \xt 1 إِج. 8‏:‏9\x*   
\m
\v 11 أَڒَامِي د-فّْغنْ إِكهَّاننْ زڭْ ؤُقدَّاسْ - مَاغَارْ مَارَّا إِكهَّاننْ نِّي ثُوغَا زمَّارنْ أَذْ أَفنْ، ثُوغَا سّْقدّْسنْ إِخفْ نْسنْ بْڒَا مَا أَذْ وْشنْ ثَايْنِيثْ إِ ثرْبِيعِينْ نْسنْ -  
\v 12 \add أَمْ\add* ثُوغَا إِلَاوِييّنْ - \add إِخْسْ أَذْ يِينِي\add* مَارَّا إِمذْيَازنْ: إِنِّي غَارْ أَسَافْ ذ يِينِّي غَارْ هَايْمَانْ ذ يِينِّي غَارْ يَاذُوثُونْ، ذ يِينِّي ن إِحنْجِيرنْ نْسنْ ذ يِينِّي ن أَيْثْمَاثْسنْ - يَارْضنْ ڒقْطنْ أَزْذَاذْ، ؤُشَا بدّنْ س ثَادْجُونِينْ ن وُوزَّاڒْ ذ لهَارْپَاثْ ذ ڒْڭَامْبْرِييَاثْ غَارْ ؤُغزْذِيسْ ن شَّارْقْ ن ؤُعَالْطَارْ ؤُ ثُوغَا أَكِيذْسنْ عْڒَاحَاڒْ مْيَا ؤُ-عِيشْرِينْ ن إِكهَّاننْ إِ إِتّْسُوضنْ ذِي ڒبْوَاقْ. \x ◘ \xo 5:‏12 \xt ڒخ. 1‏:‏15\x*  
\v 13 سُوضنْ نِيثْنِي ذِي ڒْغَايْطَا ؤُغنّْجنْ أَمْ يِيجّْ \add ن ورْيَازْ\add*، حِيمَا أَذْ إِتّْوَاسڒْ ڒْحسّْ ذ إِجّنْ أَمْ سّمْغَارَانْ ؤُ تّْقَاذَانْ نِيثْنِي سِيذِي. نِيثْنِي سّْڭعّْذنْ ثْمِيجَّا \add نْسنْ غَارْ ؤُجنَّا\add* س ڒبْوَاقْ ذ ثَادْجُونِينْ ن وُوزَّاڒْ ذ دُّوزَانَاثْ ن دْجْغَا نّغْنِي، سّمْغَارَانْ سِيذِي: ’مَاغَارْ نتَّا إِصْبحْ، مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ ثتّْغِيمَا إِ ڒبْذَا!‘ \add خنِّي\add* إِمْسَارْ أَقَا ثَادَّارْثْ، ثَادَّارْثْ ن سِيذِي، ثتّْوَاشُّورْ س ؤُسيْنُو،  
\v 14 ؤُشَا إِكهَّاننْ وَارْ زمَّارنْ أَذْ قِّيمنْ بدّنْ مَاحنْذْ أَذْ سخَّارنْ ذِي سِّيبّثْ ن ؤُسيْنُو، مِينْزِي أَعُودْجِي ن سِيذِي ثُوغَا إِشُّورْ ثَادَّارْثْ ن أَربِّي. \x ◘ \xo 5:‏14 \xt أَسَا. 15‏:‏8. \x*   
\b  
\b  
\m  
\c 6
\s1 ثَاژَادْجِيثْ ن سُولِيمَانْ غَارْ ؤُذشّنْ ن زَّاوشْثْ ثَامقّْرَانْثْ  
\m
\v 1 خنِّي إِنَّا سُولِيمَانْ:  
\b  
\m ”سِيذِي إِنَّا أَقَا نتَّا أَذْ إِزْذغْ ذڭْ يِيجّْ ن ؤُسيْنُو إِبُّومْبسْ.  
\v 2 \add س ثِيذتّْ\add* نشّْ بْنِيغْ إِشْثْ ن ثَادَّارْثْ، إِشْثْ ن ثْزذِّيغْثْ إِ شكْ، إِجّْ ن ومْشَانْ إِمْثنْ حِيمَا أَذْ \add ذِينْ\add* ثْزذْغذْ إِ ڒبْذَا.“  
\v 3 إِسّْنقْڒبْ ؤُجدْجِيذْ أَغمْبُوبْ نّسْ ؤُشَا إِبَاركْ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن إِسْرَائِيل ؤُمِي مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن إِسْرَائِيل ثُوغَا إِبدّْ.  
\v 4 نتَّا إِنَّا: ”أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي ن إِسْرَائِيل، ونِّي إِسِّيوْڒنْ س ؤُقمُّومْ نّسْ غَارْ بَابَا ذَاوُوذْ ذ \add ونِّي\add* \add ث\add* إِكمّْڒنْ س ؤُفُوسْ نّسْ ؤُمِي إِنَّا:  
\v 5 ’زڭْ وَاسّْ إِ ذِي نذْهغْ ڒْڭنْسْ إِنُو إِسْرَائِيل زِي مِيصْرَا، وَارْ إِخْضَارغْ ؤُڒَا ذ إِشْثْ ن ثنْذِينْثْ زِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل حِيمَا أَذْ \add ذِينِّي\add* بْنِيغْ ثَادَّارْثْ حِيمَا أَذْ \add ذِينْ\add* يِيڒِي إِسمْ إِنُو، ؤُ وَارْ إِخْضَارغْ أَرْيَازْ حِيمَا أَذْ يِيڒِي ذ ڒْحَاكمْ خْ ڒْڭنْسْ إِنُو إِسْرَائِيل، \x ◘ \xo 6:‏5 \xt 2 صم. 7‏:‏8؛ 1 إِج. 8‏:‏16‏-‏53\x*  
\v 6 \add مَاشَا ڒخُّو\add* إِخْذَارغْ ؤُرْشَالِيمْ، حِيمَا أَذْ \add ذِينْ\add* يِيڒِي إِسمْ إِنُو، ؤُ نشّْ إِخْضَارغْ ذَاوُوذْ، حِيمَا أَذْ يِيڒِي \add ذ ڒْحَاكمْ\add* خْ ڒْڭنْسْ إِنُو إِسْرَائِيل.‘  
\v 7 ثُوغَا ذڭْ وُوڒْ ن بَابَا ذَاوُوذْ مَاحنْذْ أَذْ إِبْنَا ثَادَّارْثْ إِ يِيسمْ ن سِيذِي، أَربِّي ن إِسْرَائِيل.  
\v 8 \add مَاشَا\add* سِيذِي إِنَّا إِ بَابَا ذَاوُوذْ: ’ؤُمِي ثڭِّيذْ ذڭْ وُوڒْ نّشْ حِيمَا أَذْ ثبْنِيذْ ثَادَّارْثْ إِ يِيسمْ إِنُو، أَقَا مْلِيحْ ؤُمِي ثڭِّيذْ مَانْ أَيَا ذڭْ وُوڒْ نّشْ.  
\v 9 مَاشَا وَارْ إِدْجِي ذ شكْ إِ غَا إِبْنَانْ ثَادَّارْثْ نِّي، مَاشَا مِّيشْ إِ د-إِفّْغنْ زِي ثجْعِينَّا نّشْ ذ نتَّا إِ غَا إِبْنَانْ ثَادَّارْثْ إِ يِيسمْ إِنُو.‘  
\v 10 سِيذِي إِسّمْثنْ أَوَاڒْ نّسْ نِّي إِسِّيوڒْ، مَاغَارْ نشّْ ذوْڒغْ بدّغْ ذڭْ ومْشَانْ ن بَابَا ذَاوُوذْ ؤُ قِّيمغْ خْ ڒْعَارْشْ ن إِسْرَائِيل، أَمْ مَامّشْ ثُوغَا إِسِّيوڒْ سِيذِي، ؤُ نشّْ بْنِيغْ ثَادَّارْثْ إِ يِيسمْ ن سِيذِي، أَربِّي ن إِسْرَائِيل.  
\v 11 نشّْ سَّارْسغْ ذِينِّي تَّابُوثْ ونِّي ذِي إِدْجَا ڒْعَاهْذْ ن سِيذِي إِ إِڭَّا نتَّا أَكْ-ذ أَيْثْ ن إِسْرَائِيل.“   
\b  
\m
\v 12 نتَّا إِبدّْ زَّاثْ إِ ؤُعَالْطَارْ ن سِيذِي، أَرنْذَاذْ ن مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن إِسْرَائِيل، ؤُشَا نتَّا إِكْسِي إِفَاسّنْ نّسْ غَارْ ؤُجنَّا.  
\v 13 مِينْزِي سُولِيمَانْ ثُوغَا إِڭَّا إِشْثْ ن ثنْهِيرْثْ ن نّْحَاسْ ؤُ إِڭَّا إِ-ت ذِي ڒْوسْطْ ن ڒمْرَاحْ. ثُوغَا ذَايسْ خمْسَا ن إِغَادْجنْ ن ثُوزّڭَّارْثْ، خمْسَا ن إِغَادْجنْ ن ثِيرُو ذ ثْڒَاثَا ن إِغَادْجنْ ن ثِيذِّي. نتَّا إِبدّْ خَاسْ، إِبنْذقْ خْ إِفَادّنْ نّسْ قِيبَاتْشْ إِ ثِيطَّاوِينْ ن مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن إِسْرَائِيل ؤُشَا إِكْسِي إِفَاسّنْ نّسْ غَارْ ؤُجنَّا، إِنَّا:   
\b  
\m
\v 14 ”\add أَ\add* سِيذِي، أَربِّي ن إِسْرَائِيل، ذڭْ ؤُجنَّا سنّجْ ؤُ خْ ثمُّورْثْ سْوَادَّايْ وَارْ إِدْجِي ؤُڒَا ذ إِجّْ ن أَربِّي أَمْ شكْ، ونِّي إِحْضَانْ ڒْعَاهْذْ ذ ثْمخْسِيوْثْ إِشوَّارنْ إِ إِمْسخَّارنْ نّشْ نِّي إِڭُّورنْ زَّاثْ إِ وُوذمْ نّشْ س مَارَّا ؤُڒْ نْسنْ،  
\v 15 ونِّي إِحْضَانْ إِ ؤُمْسخَّارْ نّشْ، بَابَا ذَاوُوذْ، خْ مِينْ خفْ أَكِيذسْ ثسِّيوْڒذْ، مِينْزِي س ؤُقمُّومْ نّشْ إِ ثسِّيوْڒذْ ؤُ س ؤُفُوسْ نّشْ إِ ث ثْكمّْڒذْ، أَمْ \add ثدْجَا\add* أَسّْ-أَ.  
\v 16 \add خنِّي\add* ڒخُّو، سِيذِي، أَربِّي ن إِسْرَائِيل، حْضَا ذِي طّْوعْ ن ؤُمْسخَّارْ نّشْ، بَابَا ذَاوُوذْ، خْ مِينْ خفْ كِيذسْ ثسِّيوْڒذْ ؤُمِي ثنِّيذْ: ’وَارْ إِتّْوَاقسّْ زَّايكْ ؤُڒَا ذ إِجّْ ن ورْيَازْ زِي زَّاثْ إِ وُوذمْ إِنُو ونِّي إِقِّيمنْ خْ ڒْعَارْشْ ن إِسْرَائِيل، مِينْ غَا كّنْ أَرَّاونْ نّشْ حطَّانْ أَذْ ؤُيُورنْ أَبْرِيذْ نْسنْ عْلَاحْسَابْ شَّارِيعَا أَمْ مَامّشْ ثُويُورذْ شكْ زَّاثْ إِ وُوذمْ إِنُو.‘  
\v 17 خنِّي ڒخُّو، \add أَ\add* أَربِّي ن إِسْرَائِيل، أڭّْ أَذْ ذوْڒنْ ذ ثِيذتّْ أَوَاڒنْ نِّي ثسِّيوْڒذْ أَكْ-ذ ؤُمْسخَّارْ نّشْ، أَكْ-ذ ذَاوُوذْ.“   
\m
\v 18 ”مَاغَارْ مَا س ثِيذتّْ أَذْ إِزْذغْ أَربِّي خْ ثمُّورْثْ؟ خْزَارْ أَجنَّا، \add وَاهْ،\add* أَجنَّا ن إِجنْوَانْ وَارْ إِزمَّارْ أَذْ شكْ إِكْسِي، مشْحَاڒْ س ذْرُوسْ \add خنِّي\add* ثَادَّارْثْ-أَ إِ سّْبدّغْ نشّْ!  
\v 19 ميّڒْ غَارْ ثْژَادْجِيثْ ن ؤُمْسخَّارْ نّشْ ؤُ غَارْ ؤُحشّمْ نّسْ، \add أَ\add* سِيذِي، أَربِّي إِنُو، حِيمَا أَذْ ثسْڒذْ غَارْ ؤُڒَاغِي ؤُ غَارْ ثْژَادْجِيثْ نِّي إِژُّودْجْ ؤُمْسخَّارْ نّشْ زَّاثْ إِ وُوذمْ نّشْ.  
\v 20 أجّْ ثِيطَّاوِينْ نّشْ أَذْ تّْوَارْزْمنْثْ أَسّْ ذ دْجِيڒثْ ثِيوَا إِ ثَادَّارْثْ-أَ، ثِيوَا إِ ومْشَانْ-أَ مِينْ خفْ ثسِّيوْڒذْ أَقَا إِسمْ نّشْ أَذْ إِتّْوَاسّمْثنْ ذِينْ، حِيمَا أَذْ ثسْڒذْ غَارْ ثْژَادْجِيثْ إِ إِژُّودْجْ ؤُمْسخَّارْ نّشْ ذڭْ ومْشَانْ-أَ.  
\v 21 سڒْ إِ ؤُحشّمْ ن ؤُمْسخَّارْ نّشْ ؤُ ن ڒْڭنْسْ نّشْ إِسْرَائِيل، إِ ثُوثْرَا إِ تّْژَادْجَانْ نِيثْنِي ذڭْ ومْشَانْ-أَ ؤُ سڒْ شكْ \add خنِّي\add* زِي ثْزذِّيغْثْ نّشْ، زڭْ ؤُجنَّا، \add وَاهْ،\add* سڒْ ؤُ غْفَارْ.“   
\m
\v 22 ”مَاڒَا إِخْضَا إِجّْ أَكْ-ذ جَّارْ نّسْ ؤُ ثتّْوَاڭّْ خَاسْ إِشْثْ ن ثْجَادْجِيثْ، حِيمَا أَذْ ت إِجُّودْجْ ؤُ وَانِيثَا يُوسَا-د ؤُشَا إِجُّودْجْ زَّاثْ إِ ؤُعَالْطَارْ نّشْ ذِي ثَادَّارْثْ-أَ،  
\v 23 سڒْ \bd شكْ\bd* \add خنِّي\add* ذڭْ ؤُجنَّا ؤُ كَّارْ ؤُ حْكمْ خْ إِمْسخَّارنْ نّشْ، \add حِيمَا\add* أَذْ إِتّْوَاعَاقبْ ؤُعفَّانْ، أجّْ أَبْرِيذْ نّسْ أَذْ إِهْوَا خْ ؤُزدْجِيفْ نّسْ ؤُ أڭّْ س ثْسڭْذَا إِ ؤُمْسڭّذْ ؤُ أوْشْ إِ-ث عْلَاحْسَابْ ثَاسڭْذَا نّسْ.“   
\m
\v 24 ”مَاڒَا ڒْڭنْسْ نّشْ إِسْرَائِيل إِتّْوَاغْڒبْ زَّاثْ إِ وُوذمْ ن ڒعْذُو، مِينْزِي نِيثْنِي خْضَانْ أَكِيذكْ ؤُ نِيثْنِي أَذْ غَاركْ د-ذوْڒنْ ؤُشَا أَذْ نعْمنْ س يِيسمْ نّشْ ؤُ أَذْ ژَّادْجنْ أَذْ حشّْمنْ زَّاثْ إِ وُوذمْ نّشْ ذِي ثَادَّارْثْ-أَ،  
\v 25 سڒْ \bd شكْ\bd* \add خنِّي\add* زڭْ ؤُجنَّا ؤُ غْفَارْ دّنْبْ ن ڒْڭنْسْ نّشْ إِسْرَائِيل ؤُشَا نْذهْ إِ-ثنْ أَذْ د-ذوْڒنْ غَارْ ثمُّورْثْ نِّي إِ ذ أَسنْ ثوْشِيذْ ؤُ إِ ڒجْذُوذْ نْسنْ.“   
\m
\v 26 ”مَاڒَا أَجنَّا إِتّْوَابلّعْ أَڒَامِي وَارْ ذِينْ إِتِّيڒِي ونْژَارْ، مِينْزِي نِيثْنِي خْضَانْ أَكِيذكْ، ؤُ نِيثْنِي أَذْ ژَّادْجنْ أَمْ أَرِّينْ أَزدْجِيفْ غَارْ ومْشَانْ-أَ، أَذْ نعْمنْ س يِيسمْ نّشْ ؤُ أَذْ د-ذوْڒنْ زِي دّْنُوبْ نْسنْ ؤُمِي ثنْ ثحْصَارذْ شكْ،  
\v 27 سڒْ-د \bd شكْ\bd* \add خنِّي\add* ذڭْ ؤُجنَّا ؤُ غْفَارْ أَسنْ دّنْبْ ن إِمْسخَّارنْ نّشْ ؤُ ن ڒْڭنْسْ نّشْ إِسْرَائِيل، مِينْزِي شكْ ثسّْڒمْذذْ أَسنْ أَبْرِيذْ أَصبْحَانْ نِّي إِتّْخصَّا أَذْ كّنْ، ؤُ أوْشْ شكْ \add خنِّي\add* أَنْژَارْ إِ ثمُّورْثْ نِّي ثوْشِيذْ ذ ڒْوَارْثْ إِ ڒْڭنْسْ نّشْ.“   
\m
\v 28 ”مَاڒَا ذِينْ ڒَاژْ ذِي ثمُّورْثْ، \add نِيغْ\add* طَّاعُونْ، \add نِيغْ\add* إِتّْوَاسّشْمضْ \add إِمنْذِي زڭْ ؤُسمِّيضْ\add*، \add نِيغْ مَاڒَا ذِينْ\add* جّْرِيحشْثْ ن وفْسُو \add نِيغْ\add* ثَامُوغْرِي \add ثنِّي\add* إِصَارّْضنْ، \add نِيغْ\add* مَاڒَا إِحْصَارْ إِ-ث ڒعْذُو \add غَارْ\add* ثوُّورَا نّسْ، \add نِيغْ\add* ثڒْقفْ إِ-ث مَامّشْ مَا ثڭَّا شَا ن جّْرِيحشْثْ \add نِيغْ\add* شَا ن ڒحْڒَاشْ،  
\v 29 \add سڒْ شكْ خنِّي\add* مِينْ مَا إِ غَا إِژُّودْجْ إِجّْ ن بْنَاذمْ زِي مَارَّا ڒْڭنْسْ نّشْ إِسْرَائِيل ؤُ مِينْ مَا إِ غَا إِتَّارْ، \add أَمْ\add* سّْننْ نِيثْنِي كُوڒْ إِجّْ جّْرِيحشْثْ نْسنْ ذ ڒحْرِيقْ نْسنْ، ؤُ نتَّا إِكْسِي \add خنِّي\add* إِفَاسّنْ نّسْ غَارْ ثَادَّارْثْ-أَ.  
\v 30 \add وَاهْ\add* سڒْ \bd شكْ\bd* \add خنِّي\add* زڭْ ؤُجنَّا، زڭْ ومْشَانْ إِمْثنْ مَانِي ثْزدّْغذْ، ؤُ غْفَارْ ؤُ أوْشْ كُوڒْ إِجّْ عْلَاحْسَابْ ثِيبْرِيذِينْ نّسْ، أَمْ مَامّشْ شكْ ثسّْنذْ ؤُڒْ نّسْ، مَاغَارْ شكْ وَاهَا إِ إِسّْننْ ؤُڒْ ن بْنَاذمْ،  
\v 31 حِيمَا أَذْ شكْ ڭّْوذنْ ؤُ أَذْ ؤُيُورنْ ذِي ثبْرِيذِينْ نّشْ مَارَّا ؤُسَّانْ إِ غَا كّنْ دَّارنْ خْ وُوذمْ ن ثمُّورْثْ نِّي ثوْشِيذْ إِ ڒجْذُوذْ نّغْ.“   
\m
\v 32 ”ؤُڒَا مَاڒَا نتَّا ذ أَبَارَّانِي، ونِّي وَارْ \add إِدْجِينْ\add* زِي ڒْڭنْسْ نّشْ، مَاشَا أَذْ د-يَاسْ ذِي طّْوعْ ن يِيسمْ نّشْ زڭْ إِشْثْ ن ثمُّورْثْ ثِيڭّْوجْ ذِي طّْوعْ ن يِيسمْ نّشْ أَمقّْرَانْ ذ ؤُفُوسْ نّشْ إِجهْذنْ ذ ؤُغِيڒْ نّشْ إِسّْوِيژّْضنْ، \add خنِّي مَاڒَا\add* د-يُوسِينْ نِيثْنِي، ؤُشَا أَذْ ژَّادْجنْ أَمْ أَرِّينْ أَزدْجِيفْ غَارْ ثَادَّارْثْ-أَ،  
\v 33 سڒْ \bd شكْ\bd* \add خنِّي\add* زڭْ ؤُجنَّا، زڭْ ومْشَانْ إِمْثنْ مَانِي ثْزدّْغذْ، ؤُ أڭّْ عْلَاحْسَابْ مَارَّا مِينْ خفْ غَاركْ إِ غَا إِڒَاغَا ؤُبَارَّانِي، حِيمَا مَارَّا ڒڭْنُوسْ ن دُّونشْثْ أَذْ سّْننْ إِسمْ نّشْ، حِيمَا نِيثْنِي أَذْ شكْ ڭّْوذنْ، أَمْ ڒْڭنْسْ نّشْ إِسْرَائِيل، ؤُ أَذْ سّْننْ أَقَا إِسمْ نّشْ إِتّْوَابَارّحْ ثِيوَا إِ ثَادَّارْثْ-أَ إِ بْنِيغْ.“   
\m
\v 34 ”مَاڒَا ڒْڭنْسْ إِفّغْ غَارْ ؤُمنْغِي أَكْ-ذ ڒْعذْيَانْ نّسْ ذڭْ وبْرِيذْ إِ خْ إِ ثنْ ثسّكّذْ، ؤُ نِيثْنِي أَذْ ژَّادْجنْ إِ شكْ \add أَمْ\add* أَرِّينْ أَزدْجِيفْ غَارْ ثنْذِينْثْ-أَ إِ ثِيخْضَارذْ شكْ، ؤُ غَارْ ثَادَّارْثْ إِ بْنِيغْ إِ يِيسمْ نّشْ،  
\v 35 سڒْ شكْ \add خنِّي\add* زڭْ ؤُجنَّا إِ ثْژَادْجِيثْ نْسنْ ؤُ إِ ؤُحشّمْ نْسنْ ؤُشَا أَغْ أَسنْ ثَاسْغَارْثْ.“   
\m
\v 36 ”مَاڒَا نِيثْنِي خْضَانْ أَكِيذكْ - مَاغَارْ وَارْ إِدْجِي ؤُڒَا ذ إِجّْ ن بْنَاذمْ إِ وَارْ إِخطِّينْ - ؤُ شكْ ثسْعَارذْ خَاسنْ، أَذْ ثنْ ثْسلّْمذْ زَّاثْ إِ وُوذمْ ن ڒعْذُو ؤُشَا نِيثْنِي أَذْ ثنْ نذْهنْ ذ إِمحْبَاسْ غَارْ ثمُّورْثْ ن ڒعْذُو، ثِيڭّْوجْ نِيغْ ثُوذسْ \add إِ ثدْجَا\add*،  
\v 37 ؤُ \add مَاڒَا\add* \add خنِّي\add* أَذْ ثُوبنْ ذڭْ وُوڒْ نْسنْ ذِي ثمُّورْثْ مَانِي تّْوَاحبّْسنْ، \add وَاهْ،\add* أَذْ ثُوبنْ ؤُ أَذْ خَاكْ د-ڒَْاغَانْ ذِي ثمُّورْثْ ن ثْحبَّاسْثْ نْسنْ، أَذْ إِنِينْ: نشِّينْ نخْضَا ؤُ نڭَّا مِينْ وَارْ إِسڭّْذنْ، أَقَا نڭَّا ثُوعفّْنَا!،  
\v 38 \add وَاهْ،\add* أَذْ غَاركْ د-ذوْڒنْ س مَارَّا ؤُڒْ نْسنْ ؤُ س مَارَّا ڒعْمَارْ نْسنْ ذِي ثمُّورْثْ ن ڒْعذْيَانْ نْسنْ مَانِي تّْوَاحبّْسنْ ؤُشَا أَذْ غَاركْ ژَّادْجنْ \add أَمْ\add* أَرِّينْ أَزدْجِيفْ غَارْ ثمُّورْثْ نِّي ثوْشِيذْ إِ ڒجْذُوذْ نْسنْ، غَارْ ثنْذِينْثْ-أَ إِ ثِيخْضَارذْ شكْ ؤُ غَارْ ثَادَّارْثْ-أَ إِ بْنِيغْ إِ يِيسمْ نّشْ،  
\v 39 سڒْ شكْ \add خنِّي\add* زڭْ ؤُجنَّا، أَمْشَانْ إِمْثنْ مَانِي ثْزدّْغذْ، إِ ثْژَادْجِيثْ نْسنْ ؤُ إِ ؤُحشّمْ نْسنْ ؤُشَا أَغْ أَسنْ ثَاسْغَارْثْ. غْفَارْ \add خنِّي\add* ڒْڭنْسْ نّشْ مِينْ زِي خَاكْ خْضَانْ.“   
\m
\v 40 ”\add خنِّي\add* ڒخُّو، أَربِّي إِنُو، أجّْ ثِيطَّاوِينْ نّشْ أَذْ إِڒِينْثْ أَرْزْمنْثْ ذ إِمزُّوغنْ نّشْ أَذْ إِڒِينْ حْضَانْ إِ ثْژَادْجِيثْ ذڭْ ومْشَانْ-أَ.  
\v 41 \add خنِّي\add* ڒخُّو، \add أَ\add* سِيذِي أَربِّي، \add أَذفْ\add* غَارْ أَرَّاحثْ نّشْ، شكْ ذ تَّابُوثْ ن جّهْذْ نّشْ. أجّْ أَذْ إِڒِينْ إِكهَّاننْ نّشْ، \add أَ\add* سِيذِي أَربِّي، أَرْضنْ س ؤُسنْجمْ، ؤُشَا إِڒِي أَذْ فَارْحنْ إِمْثِيقَّانْ نّشْ س ڒْخَارْ.  
\v 42 \add أَ\add* سِيذِي أَربِّي، وَارْ ثَارِّي أَغمْبُوبْ ن ؤُمذْهُونْ نّشْ، إِذَارْ ذِي ثْمڭَّا ن ثْمخْسِيوْثْ إِشوَّارنْ ن ؤُمْسخَّارْ نّشْ ذَاوُوذْ.“   
\b  
\b  
\m  
\c 7
\s1 أَعُودْجِي ن سِيذِي إِشُّورْ ثَادَّارْثْ  
\m
\v 1 ؤُمِي إِكمّڒْ سُولِيمَانْ ثَاژَادْجِيثْ \add نّسْ\add*، ثهْوَا-د ثْمسِّي زڭْ ؤُجنَّا ثشَّا ثَاغَارْصْثْ ن وشْمَاضْ ؤُڒَا ذ ثْغَارْصَا \add إِنّغْنِي\add*، ؤُشَا إِشُّورْ ؤُعُودْجِي ن سِيذِي ثَادَّارْثْ.  
\v 2 إِكهَّاننْ وَارْ زمَّارنْ أَذْ أَذْفنْ غَارْ ثَادَّارْثْ ن سِيذِي، مِينْزِي أَعُودْجِي ن سِيذِي ثُوغَا إِشُّورْ ثَادَّارْثْ ن سِيذِي.  
\v 3 \add ؤُمِي\add* ژْرِينْ مَارَّا أَيْثْ ن إِسْرَائِيل بلِّي ثهْوَا-د ثْمسِّي نِّي، ؤُڒَا ذ أَعُودْجِي ن سِيذِي إِبَانْ-د ثِيوَا ن ثَادَّارْثْ، ؤُضَارنْ نِيثْنِي س ؤُغمْبُوبْ نْسنْ غَارْ ثمُّورْثْ خْ ثِيسِي ن زّلِّيجْ، بنْذْقنْ، قَاذَانْ سِيذِي: ”مَاغَارْ نتَّا إِصْبحْ ؤُ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ \add ثتّْغِيمَا\add* إِ ڒبْذَا“.   
\m
\v 4 أَجدْجِيذْ، ؤُ مَارَّا إِسْرَائِيل أَكِيذسْ، وهّْبنْ ثِيغَارْصَا زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 5 أَجدْجِيذْ سُولِيمَانْ إِوهّبْ ثْنَاينْ ؤُ-عِيشْرِينْ-أَڒفْ ن إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ مْيَا ؤُ-عِيشْرِينْ أَڒفْ ن وُودْجِي ذ ثَاغَارْصْثْ ن ڒهْنَا. أَمُّو إِ إِذشّنْ ؤُجدْجِيذْ ذ مَارَّا أَيْثْ ن إِسْرَائِيل ثَادَّارْثْ ن أَربِّي.  
\v 6 إِكهَّاننْ \add ثُوغَا بدّنْ\add* غَارْ ثْسخَّارْثْ نْسنْ ؤُشَا إِلَاوِييّنْ \add بدّنْ\add* أَكْ-ذ دُّوزَانْ ن دْجْغَا ن سِيذِي، إِنِّي إِڭَّا ؤُجدْجِيذْ ذَاوُوذْ حِيمَا أَذْ قَاذَانْ سِيذِي - ’مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ \add ثتّْغِيمَا\add* إِ ڒبْذَا!‘ - س \add إِزْڒَانْ ن\add* ؤُصبّحْ ن ذَاوُوذْ ذڭْ ؤُفُوسْ نْسنْ، ؤُ أَرنْذَاذْ نْسنْ سُوضنْ إِكهَّاننْ ذِي ڒبْوَاقْ، أَمْ ثُوغَا إِبدّْ مَارَّا إِسْرَائِيل.  
\v 7 سُولِيمَانْ إِسّْقدّسْ ڒْوسْطْ ن ڒمْرَاحْ ن زَّاثْ، ونِّي \add إِدْجَانْ\add* زَّاثْ إِ ثَادَّارْثْ ن سِيذِي، مِينْزِي يِيوِي ذِينْ ثِيغَارْصَا ن وشْمَاضْ ذ ثَاذُونْثْ ن ثوْهِيبِينْ \add ن ڒْغِيدْجثْ\add*، مَاغَارْ أَعَالْطَارْ ن نّْحَاسْ نِّي إِڭَّا سُولِيمَانْ ثُوغَا وَارْ إِزمَّارْ أَذْ إِكْسِي ثَاغَارْصْثْ ن وشْمَاضْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ ثَاذُونْثْ.   
\m
\v 8 ذِي ڒْوقْثْ نِّي إِعيّذْ سُولِيمَانْ ڒْعِيذْ إِ يِيجّْ ن ڒْمِيجَارْ ن سبْعَا ن وُوسَّانْ ذ مَارَّا إِسْرَائِيل أَكِيذسْ، إِجّْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add* ذ أَمقّْرَانْ، زِي مَانِي غَا ثِيوْضذْ غَارْ حَامَاثْ أَڒْ ثَاغْزَارْثْ ن مِيصْرَا.  
\v 9 ذڭْ وَاسّْ وِيسّْ ثْمنْيَا ڭِّينْ إِجّْ ن ؤُمُونِي إِفَارْزنْ، مِينْزِي ذِي سبْعَا ن وُوسَّانْ ڭِّينْ نِيثْنِي أَذشّنْ ن ؤُعَالْطَارْ ؤُشَا ؤُڒَا ذ ڒْعِيذْ \add أَوَارْنِي مَانْ أَيَا\add* غَارسْ \add عَاوذْ\add* إِجّْ ن ڒْمِيجَارْ ن سبْعَا ن وُوسَّانْ.  
\v 10 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا ؤُ-عِيشْرِينْ ن ؤُيُورْ وِيسّْ سبْعَا يَارْخُو نتَّا إِ ڒْڭنْسْ أَذْ رَاحنْ غَارْ إِقِيضَانْ نْسنْ س وُوڒْ إِفَارْحنْ ؤُ س ڒْخَاضَارْ س مَارَّا ڒْخَارْ إِ إِڭَّا سِيذِي إِ ؤُمْسخَّارْ نّسْ ذَاوُوذْ ذ سُولِيمَانْ ؤُ إِ ڒْڭنْسْ نّسْ إِسْرَائِيل.   
\b  
\m  
\s1 أَضْهَارْ وِيسّْ ثْنَاينْ ن سِيذِي إِ سُولِيمَانْ  
\m
\v 11 \add أَمُّو إِ\add* إِكمّڒْ سُولِيمَانْ ڒبْنِي ن ثَادَّارْثْ ن سِيذِي ذ ثَادَّارْثْ ن ؤُجدْجِيذْ. مَارَّا مِينْ ثُوغَا ذڭْ وُوڒْ ن سُولِيمَانْ حِيمَا أَذْ ث إِڭّْ ذِي ثَادَّارْثْ ن سِيذِي ؤُ ذِي ثَادَّارْثْ نّسْ، أَقَا إِفْڒحْ \add أَذْ إِڭّْ\add* أَيَا. \x ◘ \xo 7:‏11 \xt [1 إِج. 9‏:‏1‏-‏9]\x*  
\v 12 سِيذِي إِبَانْ-د إِ سُولِيمَانْ ذِي دْجِيڒثْ، إِنَّا أَسْ:  
\m ”نشّْ سْڒِيغْ إِ ثْژَادْجِيثْ نّشْ ؤُ فَارْزغْ أَمْشَانْ-أَ إِ يِيخفْ إِنُو حِيمَا أَذْ يِيڒِي ذ ثَادَّارْثْ \add إِ ثوْهِيبْثْ ن\add* ثْغَارْصْثْ.  
\v 13 خْمِي غَا بلّْعغْ أَجنَّا مَاحنْذْ وَارْ إِشِّيثْ ونْژَارْ \add عَاذْ\add*، نِيغْ مَاڒَا ؤُمُورغْ ثَامُوغْرِي إِڒحّْفنْ مَاحنْذْ أَذْ ثشّْ ثمُّورْثْ نِيغْ خْمِي د-سّكّغْ طَّاعُونْ جَارْ ڒْڭنْسْ إِنُو،  
\v 14 ؤُشَا ڒْڭنْسْ إِنُو خْ مِينْ خفْ إِتّْوَاڒَاغَا إِسمْ إِنُو أَذْ إِسّهْوَا إِخفْ نّسْ، أَذْ إِژَّادْجْ، ؤُ نِيثْنِي أَذْ أَرْزُونْ ؤُذمْ إِنُو ؤُ أَذْ ثُوبنْ زِي ثبْرِيذِينْ نْسنْ ثِيعفَّانِينْ، \add خنِّي\add* نشّْ أَذْ غَارْسنْ سْڒغْ زڭْ ؤُجنَّا، أَذْ أَسنْ غْفَارغْ ؤُ أَذْ سّْڭنْفِيغْ ثَامُّورْثْ نْسنْ.  
\v 15 \add خنِّي\add* ڒخُّو، ثِيطَّاوِينْ إِنُو أَذْ إِڒِينْثْ أَرْزْمنْثْ ذ إِمزُّوغنْ إِنُو أَذْ حْضَانْ خْ ثْژَادْجِيثْ زڭْ ومْشَانْ-أَ،  
\v 16 مَاغَارْ ڒخُّو إِخْضَارغْ ثَادَّارْثْ-أَ ؤُ سّْقدّْسغْ ت حِيمَا أَذْ سّْمثْنغْ ذِينْ إِسمْ إِنُو إِ ڒبْذَا ؤُ ثِيطَّاوِينْ إِنُو ذ وُوڒْ إِنُو \add أَذْ\add* ذِينْ \add إِڒِينْ\add* مَارَّا ؤُسَّانْ.   
\m
\v 17 مَاڒَا شكْ ثُويُورذْ زَّاثْ إِ وُوذمْ إِنُو أَمْ مَامّشْ ثُوغَا إِڭُّورْ بَابَاشْ ذَاوُوذْ، ؤُ أَذْ ثڭّذْ أَمْ مَامّشْ مَارَّا إِ ذ أَشْ ؤُمُورغْ ؤُشَا أَذْ ثحْضِيذْ ثِيوصَّا إِنُو ذ لْفَارَايِيضْ  إِنُو،  
\v 18 \add خنِّي\add* أَذْ سّْمثْنغْ ڒْعَارْشْ ن ثْڭلْذِيثْ نّشْ أَمْ مَامّشْ ڒْعَاهْذْ إِ ڭِّيغْ أَكْ-ذ بَابَاشْ ذَاوُوذْ، نِّيغْ: ’وَارْ ذ أَشْ إِتّْخصَّا ؤُڒَا ذ إِجّْ ن ورْيَازْ نِّي إِحكّْمنْ ذِي إِسْرَائِيل!‘   
\m
\v 19 مَاشَا مَاڒَا كنِّيوْ ثْحيّْذمْ زِي ثْوصَّا إِنُو ذ ڒُومُورَاثْ إِنُو نِّي وْشِيغْ زَّاثْ إِ وُوذمْ نْومْ، ؤُشَا أَذْ ثُويُورمْ أَذْ ثْعبْذمْ إِ إِربِّيثنْ نّغْنِي، أَذْ أَسنْ ثْبنْذْقمْ،  
\v 20 خنِّي أَذْ قْضِيغْ خْ إِسْرَائِيل زِي ثمُّورْثْ نِّي ذ أَسنْ وْشِيغْ، ؤُشَا ثَادَّارْثْ-أَ، إِ سّْقدّْسغْ إِ يِيسمْ إِنُو، أَذْ ت نْضَارغْ زڭْ وُوذمْ إِنُو ؤُ إِسْرَائِيل أَذْ إِذْوڒْ ذ ؤُمذْيَا \add ؤُڒَا ذ ڒْقشْعثْ\add* ن ؤُبهْذڒْ إِتّقّْسنْ جَارْ مَارَّا ڒڭْنُوسْ.  
\v 21 ؤُ خْ ثَادَّارْثْ-أَ ثنِّي يُوعْڒَانْ قَاعْ، مَارَّا وِي خَاسْ إِ غَا إِكّنْ، أَذْ إِثبْهثْ، أَذْ يِينِي: ’مَايمِّي إِڭَّا سِيذِي أَمُّو ذِي ثمُّورْثْ-أَ ؤُ ذِي ثَادَّارْثْ-أَ؟‘  
\v 22 أَذْ إِنِينْ: ’مِينْزِي نِيثْنِي سمْحنْ ذِي سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ، ونِّي ثنْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، ؤُ مِينْزِي نِيثْنِي شبَّارنْ ذِي إِربِّيثنْ نّغْنِي ؤُ إِسْرَائِيل يُويُورْ أَذْ أَسنْ إِسْجذْ ؤُ أَذْ ثنْ إِعْبذْ، خْ ؤُيَا إِسّغْضڒْ نتَّا مَارَّا ڒْغَارْ-أَ خَاسنْ.‘ “   
\b  
\b  
\m  
\c 8
\s1 ڒبْنِييَاثْ ذ ثْسخَّارْثْ ذِي زَّاوشْثْ إِقدّْسنْ ذ وُورغْ  
\m
\v 1 أَوَارْنِي عِيشْرِينْ ن إِسڭّْوُوسَا إِ ذِي إِبْنَا سُولِيمَانْ ثْنَاينْ ن ثُوذْرِينْ، ثَادَّارْثْ ن سِيذِي ؤُ ثَادَّارْثْ ن ؤُجدْجِيذْ، إِمْسَارْ، \x ◘ \xo 8:‏1 \xt [1 إِج. 9‏:‏10‏-‏28]\x*  
\v 2 أَقَا سُولِيمَانْ إِبْنَا \add عَاوذْ\add* ثِيندَّامْ إِ ذ أَسْ إِوْشَا حِيرَامْ ؤُشَا إِسّزْذغْ ذِينْ أَيْثْ ن إِسْرَائِيل.  
\v 3 أَوَارْنِي أَسْ إِفّغْ سُولِيمَانْ غَارْ حَامَاثْ-صُوبَا ؤُشَا إِطّفْ إِ-ت.  
\v 4 نتَّا إِبْنَا ثَاذْمُورْ ذِي ڒخْڒَا. إِبْنَا \add عَاوذْ\add* مَارَّا ثِيندَّامْ ن ڒخْزنْ ذِي حَامَاثْ. \x ◘ \xo 8:‏4 \xt 1 إِج. 9‏:‏17‏-‏18\x*  
\v 5 نتَّا إِبْنَا ؤُڒَا ذ بَايْثْ-حُورُونْ ن نّجْ ذ بَايْثْ-حُورُونْ ن وَادَّايْ، ثْندَّامْ إِفَارْينْ س ڒحْيُوضْ ذ ثوُّورَا ذ إِعُومَاذْ إِ ؤُبلّعْ،  
\v 6 ؤُڒَا ذ بَاعْلَاثْ ذ مَارَّا ثِيندَّامْ ن ڒخْزنْ نِّي \add إِدْجَانْ\add* غَارْ سُولِيمَانْ، ذ مَارَّا ثِيندَّامْ ن إِكَارُّوثنْ ذ مَارَّا ثِيندَّامْ ن إِمْنَاينْ ؤُ \add خنِّي\add* مَارَّا مِينْ إِسِّيثمْ سُولِيمَانْ أَذْ ت إِبْنَا ذِي ؤُرْشَالِيمْ ؤُ ذِي لُوبْنَانْ ؤُ ذِي مَارَّا ثَامُّورْثْ ن ڒحْكَامْ نّسْ.   
\m
\v 7 خْ مَارَّا ڒْڭنْسْ إِ إِقِّيمنْ - \add خْ ڒْڭنْسْ\add* ن إِحِيتِّييّنْ، ن إِمُورِييّنْ، ن إِفِيرِيزِييّنْ، ن إِحِيوِييّنْ ؤُ ن إِيابُوسِييّنْ، إِنِّي وَارْ \add إِدْجِينْ\add* شَا زڭْ أَيْثْ ن إِسْرَائِيل،  
\v 8 ؤُ خْ وَارَّاونْ نْسنْ نِّي إِقِّيمنْ أَوَارْنِي أَسنْ ذِي ثمُّورْثْ، إِنِّي وَارْ تّْوَاقْضَانْ س ؤُفُوسْ ن أَيْثْ ن إِسْرَائِيل - إِڭَّا خَاسنْ سُولِيمَانْ دّْقُوڒَاثْ قسْحنْثْ أَڒْ أَسّْ-أَ.  
\v 9 \add مَاشَا\add* زڭْ أَيْثْ ن إِسْرَائِيل وَارْ إِڭِّي سُولِيمَانْ ذ إِسمْغَانْ إِ ڒخْذَايمْ نّسْ، مِينْزِي نِيثْنِي ثُوغَا أَثنْ ذ إِعسْكَارِييّنْ ذ إِمقّْرَاننْ خْ إِنغْرَافنْ نّسْ \add زِي ڒْعسْكَارْ\add*، ذ إِمقّْرَاننْ ن إِكَارُّوثنْ نّسْ ذ إِمْنَاينْ نّسْ.   
\m
\v 10 إِنَا ذ إِمحْضَاينْ إِمقّْرَاننْ نِّي ثُوغَا غَارْ ؤُجدْجِيذْ ن سُولِيمَانْ، مِيثَاينْ ؤُ-خمْسِينْ \add ن يرْيَازنْ\add* نِّي ثُوغَا إِتّْضبَّارنْ خْ ڒْڭنْسْ.   
\m
\v 11 سُولِيمَانْ إِسّْڭعّذْ يدْجِيسْ ن فِيرْعُونْ زِي ثنْذِينْثْ ن ذَاوُوذْ غَارْ ثَادَّارْثْ إِ ثُوغَا إِ ذ أَسْ إِبْنَا، مِينْزِي إِنَّا: ”ثَامْغَارْثْ إِنُو وَارْ ثْزذِّيغْ شَا ذِي ثَادَّارْثْ ن ذَاوُوذْ، أَجدْجِيذْ ن إِسْرَائِيل، مِينْزِي إِمُوشَانْ مَانِي د-ثُوسَا تَّابُوثْ ن سِيذِي، أَقَا أَثنْ قدّْسنْ.   
\b  
\m
\v 12 خنِّي إِسّْڭعّذْ سُولِيمَانْ ثِيغَارْصَا ن وشْمَاضْ إِ سِيذِي خْ ؤُعَالْطَارْ ن سِيذِي نِّي ثُوغَا إِبْنَا زَّاثْ إِ وسْقِيفْ ن وَاذَافْ \add ن زَّاوشْثْ ثَامقّْرَانْثْ\add*،  
\v 13 عْلَاحْسَابْ لْفَارِيضَا إِ كُوڒْ أَسّْ إِ ثوْهِيبْثْ ن ثْغَارْصَا، أَمْ مَامّشْ \add ثقَّارْ\add* ثوْصيّثْ ن مُوسَا إِ وُوسَّانْ ن سّبْثْ، إِ وُوسَّانْ ن ؤُيُورْ ن جْذِيذْ ؤُ إِ ثْڒَاثَا ڒعْيُوذَاثْ إِ إِتّْوَاڭّنْ إِ كُوڒْ أَسڭّْوَاسْ: ذِي ڒْعِيذْ ن وغْرُومْ بْڒَا أَنْثُونْ، ذِي ڒْعِيذْ ن سِّيمَانَاثْ ؤُ ذِي ڒْعِيذْ ن إِعُوشُّوثنْ.  
\v 14 أَمْ مَامّشْ د-ثُوسَا لْفَارِيضَا ن بَابَاسْ ذَاوُوذْ إِسّْبدّْ \add عَاوذْ\add* ثِيرْبِيعِينْ ن إِكهَّاننْ إِ ڒْخذْمثْ نْسنْ، ذ \add ثرْبِيعِينْ\add* ن إِلَاوِييّنْ إِ ثْسخَّارْثْ نْسنْ، حِيمَا أَذْ سّمْغَارنْ \add ذِي زَّاوشْثْ ثَامقّْرَانْثْ\add* ؤُ أَذْ سخَّارنْ إِ إِكهَّاننْ عْلَاحْسَابْ أَوَاڒْ \add ن لْفَارِيضَا\add* إِ كُوڒْ أَسّْ، ؤُشَا \add إِسّْبدّْ ؤُڒَا\add* ذ إِعسَّاسنْ ن ثوَّارْثْ ذِي ثرْبِيعِينْ نْسنْ غَارْ كُوڒْ ثَاوَّارْثْ، مِينْزِي أَمُّو إِ يدْجَا ڒُومُورْ ن ذَاوُوذْ، أَرْيَازْ ن أَربِّي.  
\v 15 نِيثْنِي وَارْ حيّْذنْ شَا ڒَا ذڭْ إِشْثْ ن جِّيهثْ خْ ڒُومُورْ ن ؤُجدْجِيذْ إِ إِكهَّاننْ ذ إِلَاوِييّنْ، وَارْ إِدْجِي ؤُڒَا زِي جِّيهثْ ن إِخَّامنْ ن ثْخُوبَايْ.  
\v 16 \add أَمُّو\add* إِ ثتّْوَاسّقْفڒْ مَارَّا ڒْخذْمثْ ن سُولِيمَانْ زڭْ وَاسّْ \add ن ؤُسَارْسِي ن\add* ذْسَاسْ ن ثَادَّارْثْ ن سِيذِي أَڒْ أَكمّڒْ نّسْ، \add وَاهْ أَمُّو\add* إِ ثتّْوَاكمّڒْ ثَادَّارْثْ ن سِيذِي.   
\b  
\m
\v 17 \add خنِّي\add* إِرُوحْ سُولِيمَانْ غَارْ عِيصْيُونْ-جَابِيرْ ؤُ غَارْ أَيْلَاثْ، غَارْ ثْمَا ن ڒبْحَارْ، ذِي ثمُّورْثْ ن إِذُومْ.  
\v 18 س ؤُفُوسْ ن إِمْسخَّارنْ نّسْ إِسّكّْ حِيرَامْ غَارسْ إِغَارُّوبَا، ؤُشَا إِمْسخَّارنْ نِّي إِسّْننْ ڒبْحَارْ، ؤُ نذْهنْ أَكْ-ذ إِمْسخَّارنْ ن سُولِيمَانْ غَارْ ؤُفِيرْ ؤُشَا إِوْينْ-د سّنِّي \bd أَربْعَا-مْيَا ؤُ خمْسِينْ ثَالِينْثْ ن وُورغْ\bd* ؤُشَا ؤُسِينْ-د \add زَّايسْ\add* غَارْ ؤُجدْجِيذْ سُولِيمَانْ.   
\b  
\b  
\m  
\c 9
\s1 ثَاوَاسِيثْ ن ثْجدْجِيذْثْ ن سَابَا غَارْ سُولِيمَانْ  
\m
\v 1 ثَاجدْجِيذْثْ ن شَابَا ثسْڒَا خْ شّنّْعثْ ن سُولِيمَانْ ؤُشَا، حِيمَا أَذْ ثْقدْجبْ سُولِيمَانْ س ثْحُوجَا ن ثْوَافِيثْ، ثُوسَا-د غَارْ ؤُرْشَالِيمْ س إِجّْ ن ؤُكَارَابَانْ س دّْقڒْ \add ن وَاڭْڒَا\add* أَطَّاسْ، س إِڒغْمَانْ نِّي يَاربُّونْ ڒعْطُورْ ذ وَاطَّاسْ ن وُورغْ ذ إِژْرَا إِغْڒَانْ ؤُ نتَّاثْ ثُوسَا-د غَارْ سُولِيمَانْ ؤُشَا ثسِّيوڒْ أَكِيذسْ خْ مَارَّا مِينْ غَارسْ ذڭْ وُوڒْ. \x ◘ \xo 9:‏1 \xt [1 إِج. 10‏:‏1‏-‏3]\x*  
\v 2 سُولِيمَانْ إِشَارْحْ مَارَّا أَوَاڒنْ نّسْ. وَارْ ذِينْ ؤُڒَا ذ إِجّْ ن وَاوَاڒْ \add س ڒمْعَانِي\add* إِنُّوفَّارنْ إِ سُولِيمَانْ أَڒَامِي وَارْ إِزمَّارْ أَذْ أَسْ ث إِشَارّحْ.   
\m
\v 3 \add ڒَْامِي\add* ثژْرَا ثْجدْجِيذْثْ ن شَابَا ثِيغِيثْ ن سُولِيمَانْ ذ ثَادَّارْثْ إِ إِبْنَا،  
\v 4 ذ مَاشَّا خْ طَّابْڒَا نّسْ، ذ مَامّشْ قِّيمنْ إِمْسخَّارنْ نّسْ، ذ مَامّشْ بدّنْ إِخدَّامنْ نّسْ، ذ وَارُّوضْ نْسنْ ذ إِوَارَّاذنْ نّسْ ذ وَارُّوضْ نْسنْ ذ مَامّشْ إِڭعّذْ أَمْ د-إِڭعّذْ غَارْ ثَادَّارْثْ ن سِيذِي، وَارْ إِقِّيمْ ذَايسْ \add عْڒَاحَاڒْ\add* بُوحْبڒْ \add عَاذْ\add*.  
\v 5 نتَّاثْ ثنَّا إِ ؤُجدْجِيذْ:  
\b  
\m ”أَوَاڒْ نِّي سْڒِيغْ ذِي ثمُّورْثْ إِنُو خْ وَاوَاڒنْ نّشْ ؤُ خْ ثِيغِيثْ نّشْ، نِيشَانْ ذ ثِيذتّْ.  
\v 6 نشّْ وَارْ ؤُمِينغْ شَا س وَاوَاڒنْ نِّي، أَڒَامِي د-ؤُسِيغْ ذَانِيثَا ؤُ \add خنِّي\add* ثِيطَّاوِينْ إِنُو ژْرِينْثْ أَيَا. خْزَارْ، أَزْينْ ن ثِيغِيثْ نّشْ ثَامقّْرَانْثْ وَارْ ذ أَيِي إِتّْوَانَّا. أَقَا شكْ سنّجْ خْ ڒخْبَارْ إِ \add خَاكْ\add* سْڒِيغْ.  
\v 7 سّعْذْ ن يرْيَازنْ نّشْ، سّعْذْ ن إِمْسخَّارنْ نّشْ، إِنِّي إِبدّنْ زَّاثْ إِ وُوذمْ نّشْ ڒبْذَا ؤُ إِتّسْڒَانْ غَارْ ثِيغِيثْ نّشْ!  
\v 8 أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي نّشْ، ونِّي ؤُمِي د-ثُوسِيذْ خْ ڒْخَاضَارْ حِيمَا أَذْ شكْ يڭّْ ذ أَجدْجِيذْ إِ سِيذِي، أَربِّي نّشْ، خْ ڒْعَارْشْ نّسْ. مِينْزِي أَربِّي إِتّخْسْ أَطَّاسْ أَذْ يجّْ إِسْرَائِيل أَذْ ثقِّيمْ إِ ڒبْذَا، س ؤُيَا إِڭَّا شكْ ذ أَجدْجِيذْ خَاسنْ إِ ڒبْذَا، مَاحنْذْ أَذْ ثڭّذْ ڒْحقّْ ذ ثْسڭْذَا.“   
\b  
\m
\v 9 نتَّاثْ ثوْشَا إِ ؤُجدْجِيذْ مْيَا ؤُ-عِيشْرِينْ ثَالِينْثْ ن وُورغْ ذ وَاطَّاسْ ن ڒبْزرْ ذ إِژْرَا إِغْڒَانْ. ڒبْزرْ أَمْ وَانِيثَا إِ ثوْشَا ثْجدْجِيذْثْ ن شَابَا إِ ؤُجدْجِيذْ سُولِيمَانْ،عمَّارْصْ وَارْ إِدْجِي \add عَاذْ\add*.   
\m
\v 10 إِمْسخَّارنْ ن حِيرَامْ إِ د إِوْينْ ؤُرغْ زڭْ ؤُفِيرْ أَكْ-ذ إِمْسخَّارنْ ن سُولِيمَانْ، إِوْينْ عَاوذْ أَكشُّوضْ ن \add ثْشجَّارْثْ ن\add* صَانْذَالْ أَزڭّْوَاغْ ذ يژْرَا إِغْڒَانْ.  
\v 11 أَجدْجِيذْ إِڭَّا زڭْ ؤُكشُّوضْ نِّي ن \add ثْشجَّارْثْ ن\add* صَانْذلْ أَزڭّْوَاغْ دّْرُوجَاثْ ثِيمقّْرَانِينْ إِ ثَادَّارْثْ ن سِيذِي ؤُ إِ ثَادَّارْثْ ن ؤُجدْجِيذْ، ؤُڒَا ذ ڒْڭَامْبْرِييَاثْ ذ لهَارْپَاثْ إِ إِمذْيَازنْ. أَمْ مَانْ أَيَا وَارْ ث ژْرِينْعمَّارْصْ قْبڒْ ذِي ثمُّورْثْ ن يَاهُوذَا.   
\m
\v 12 أَجدْجِيذْ سُولِيمَانْ إِوْشَا إِ ثْجدْجِيذْثْ ن شَابَا مَارَّا مِينْ ثُوغَا ذَايسْ ذ مژْرِي، مِينْ مَا ثتَّارْ، \add وَاهْ، كْثَارْ زِي\add* مِينْ د تِّيوِي غَارْ ؤُجدْجِيذْ. \add خنِّي\add* ثنّقْڒبْ ؤُ ثعْقبْ غَارْ ثمُّورْثْ نّسْ، نتَّاثْ ذ إِمْسخَّارنْ نّسْ.   
\b  
\m  
\s1 أَطَّاسْ ن وَاڭْڒَا ن سُولِيمَانْذْ ڒْموْثْ نّسْ  
\m
\v 13 ڒْقدّْ ن وُورغْ إِ إِتَّاذْفنْ غَارْ سُولِيمَانْ ذڭْ إِجّْ ن ؤُسڭّْوَاسْ ثُوغَا ستَّا-مْيَا ؤُ-ستَّا ؤُ-ستِّينْ ثَالِينْثْ ن وُورغْ، \x ◘ \xo 9:‏13 \xt [1 إِج. 10‏:‏14‏-‏29]] — 1 إِج. 10‏:‏14؛ عِز. 2‏:‏13؛ أَسَا. 17‏:‏9. \x*  
\v 14 نْهْڒَا أَرْبحْ زڭْ إِرْيَازنْ إِمْسوّْقنْ إِ د-إِتّنّْضنْ \add ذِي ثمُّورْثْ\add* ؤُ زِي ثْسبَّابْثْ ن إِسبَّابنْ، ؤُ نْهْڒَا أَرْبحْ ن وُورغْ ذ نُّوقَارْثْ إِ سُولِيمَانْ زڭْ مَارَّا إِجدْجِيذنْ ن ثمُّورْثْ ن عَارَابِييَّا ؤُ زِي لْوُولَاثْ ن ثمُّورْثْ.   
\m
\v 15 أَجدْجِيذْ سُولِيمَانْ إِڭَّا \add عَاوذْ\add* مِيثَاينْ ن ثْسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* ثِيمقّْرَانِينْ س وُورغْ إِتّْوَادّْزنْ. خْ إِشْثْ ن ثْسدَّارْثْ تّْوَاڭّنْ ستَّا-مْيَا \add شِيقْلُو\add* ن وُورغْ.  
\v 16 \add يَارْنِي إِڭَّا نتَّا\add* ثڒْثْ-مْيَا ن ثْسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* س وُورغْ إِتّْوَادّْزنْ. تّْوَاڭّنْثْ ثڒْثْ-مْيَا \add شِّيقْلُو\add* ن وُورغْ ذڭْ إِشْثْ ن ثْسدَّارْثْ. أَجدْجِيذْ إِسَّارْسْ إِ-ثنْثْ ذِي ثَادَّارْثْ ن وزْغَارْ ن لُوبْنَانْ. \f ◼ \fr 9:‏16 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*   
\m
\v 17 أَجدْجِيذْ إِڭَّا عَاوذْ إِجّْ ن ڒْعَارْشْ أَمقّْرَانْ ن ڒْعَاجْ ؤُشَا إِغڒْفْ إِ-ث س وُورغْ إِصْفَانْ. \f ◼ \fr 9:‏17 \ft \+bd ’ڒْعَاجْ‘\+bd* - إِخْسْ أَذْ يِينِي ’أَشَّاونْ ن لْفِيلْ‘.\f*  
\v 18 ڒْعَارْشْ وَانِيثَا غَارسْ ستَّا ن ثَارفِّيذِينْ ؤُ ثتّْوَاشدّْ إِشْثْ ن ثْندَّابْثْ ن وُورغْ إِ يِيضَارنْ إِ ڒْعَارْشْ. غَارْ ثْنَاينْ ن إِغزْذِيسنْ ن ڒْكُورْسِي ثُوغَا دْجَانْ إِغَادْجنْ ؤُ ثْنَاينْ ن وَايْرَاذنْ ثُوغَا بدّنْ زَّاثْ إِ إِغَادْجنْ \add ن ڒْعَارْشْ\add*.  
\v 19 ثنْعَاشْ ن وَايْرَاذنْ بدّنْ غَارْ ثْنَاينْ ن إِغزْذِيسنْ خْ ستَّا ن ثَارفِّيذِينْ. أَمْ نتَّا وَارْ إِتّْوَاڭّْ \add عَاذْ\add* ؤُڒَا ذڭْ إِشْثْ ن ثْڭلْذِيثْ.   
\m
\v 20 مَارَّا إِغَارَّافنْ ن ثِيسِّيثْ ن سُولِيمَانْ \add ثُوغَا أَثنْ\add* ن وُورغْ ؤُ مَارَّا ڒقْشُوعْ ن ثَادَّارْثْ ن وزْغَارْ ن لُوبْنَانْ \add ثُوغَا أَثنْ\add* س وُورغْ إِزذْڭنْ، وَارْ ذِينْ نُّوقَارْثْ \add ذَايسْ\add*، \add مَاغَارْ\add* ذڭْ وُوسَّانْ ن سُولِيمَانْ ثُوغَا حسّْبنْ ت ذ وَالُو.  
\v 21 مَاغَارْ أَجدْجِيذْ ثُوغَا غَارسْ إِغَارُّوبَا نِّي إِنذْهنْ غَارْ ثَارْشِيشْ أَكْ-ذ إِمْسخَّارنْ ن حِيرَامْ. إِشْثْ ن ثْوَاڒَا ذِي ثْڒَاثَا ن إِسڭّْوُوسَا ؤُسِينْ-د إِغَارُّوبَا زِي ثَارْشِيشْ، إِوْينْ-د ؤُرغْ ذ نُّوقَارْثْ، ڒْعَاجْ ذ إِبَاغُوسنْ ذ إِطَاوْسنْ.  
\v 22 أَجدْجِيذْ سُولِيمَانْ إِعْذُو مَارَّا إِجدْجِيذنْ ن دُّونشْثْ ذڭْ وَاڭْڒَا ذ ثِيغِيثْ.  
\v 23 مَارَّا إِجدْجِيذنْ ن دُّونشْثْ أَرْزُونْ \add أَذْ ژَترنْ\add* ؤُذمْ ن سُولِيمَانْ، مَاحنْذْ أَذْ سْڒنْ غَارْ ثِيغِيثْ نّسْ إِ ثُوغَا إِسَّارْسْ أَربِّي ذڭْ وُوڒْ نّسْ.  
\v 24 نِيثْنِي ؤُسِينْ-د أَسڭّْوَاسْ أَوَارْنِي إِ ؤُمَاسْ، كُوڒْ إِجّْ س ثَارْزفْثْ نّسْ، \add س\add* ڒقْشُوعْ ن نُّوقَارْثْ، ڒقْشُوعْ ن وُورغْ، أَرُّوضْ، ڒسْنَاحْ، ڒعْطُورْ، إِيْسَانْ ذ إِسَارْذَانْ.   
\m
\v 25 سُولِيمَانْ ثُوغَا غَارسْ أَربْعَا-أَڒَافْ ن ڒْكُورِيثْ إِ إِيْسَانْ ذ إِكَارُّوثنْ ؤُ إِ ثنْعَاشْ-أَڒفْ ن إِمْنَاينْ. إِڭَّا إِ-ثنْ ذِي ثْندَّامْ ن إِكَارُّوثنْ ؤُ غَارْ ؤُجدْجِيذْ ذِي ؤُرْشَالِيمْ.  
\v 26 نتَّا إِحْكمْ خْ مَارَّا إِجدْجِيذنْ زڭْ إِغْزَارْ \add لْفُورَاطْ\add* أَڒْ ثَامُّورْثْ ن إِفِيلِيسْطِينِييّنْ ؤُ أَڒْ أَيْمِيرْ ن مِيصْرَا.  
\v 27 أَجدْجِيذْ إِڭَّا نُّوقَارْثْ ذِي ؤُرْشَالِيمْ أَمْ يژْرَا ؤُ \add ثِيشجُّورَا ن\add* ثنْڭلْثْ إِڭَّا \add إِ-ثنْ\add* أَمْ يِيزمُّورنْ نِّي \add إِدْجَانْ\add* أَطَّاسْ ذِي ثمُّورْثْ إِوَاطَانْ.  
\v 28 إِوْينْ-د إِيْسَانْ إِ سُولِيمَانْ زِي مِيصْرَا ؤُ زِي مَارَّا ثِيمُّورَا.   
\b  
\m
\v 29 مِينْ إِقِّيمنْ ن إِمزْرُوينْ ن سُولِيمَانْ، إِمزْوُورَا ذ إِنڭُّورَا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن ؤُنَابِي نَاثَانْ ؤُ ذِي نُّوبُووَا ن أَخِييَا أَخِيلُونِي ؤُ ذڭْ إِوحَّانْ ن ؤُمْوَاڒَاوْ يَاعْذُو خْ يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ؟ \x ◘ \xo 9:‏29 \xt [1 إِج. 11‏:‏41‏-‏43]\x*  
\v 30 سُولِيمَانْ إِحْكمْ ذِي ؤُرْشَالِيمْ أَربْعِينْ ن إِسڭّْوُوسَا خْ مَارَّا إِسْرَائِيل.  
\v 31 سُولِيمَانْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ ؤُشَا نضْڒنْ ث ذِي ثنْذِينْثْ ن بَابَاسْ ذَاوُوذْ. مِّيسْ رَاحَابْعَامْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\b  
\m  
\c 10
\s1 أَبطُّو ن ثْڭلْذِيثْ  
\m
\v 1 رَاحَابْعَامْ يُويُورْ غَارْ شَاكِيمْ، مَاغَارْ مَارَّا إِسْرَائِيل ثُوغَا يُوسَا-د غَارْ شَاكِيمْ، حِيمَا أَذْ ث ڭّنْ ذ أَجدْجِيذْ. \x ◘ \xo 10:‏1 \xt [1 إِج. 12‏:‏1‏-‏24]\x*  
\v 2 ؤُمِي إِسْڒَا يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، خْ مَانْ أَيَا، ؤُمِي ث ثُوغَا عَاذْ ذِي مِيصْرَا - زعْمَا نتَّا ثُوغَا يَارْوڒْ زڭْ وُوذمْ ن ؤُجدْجِيذْ سُولِيمَانْ - إِمْسَارْ \add أَسْ\add* أَقَا إِعْقبْ-د.  
\v 3 سّكّنْ-د \add غَارسْ\add*، جِّينْ أَذْ خَاسْ ڒَاغَانْ. يُوسَا-ذ يَارُوبْعَامْ أَكْ-ذ مَارَّا ثَامسْمُونْثْ ن إِسْرَائِيل، سِّيوْڒنْ نِيثْنِي أَكْ-ذ رَاحَابْعَامْ، نَّانْ:  
\v 4 ”بَابَاشْ إِڭَّا خَانغْ إِجّْ ن ؤُزَايْڒُو إِقْسحْ. خنِّي ڒخُّو، سَارْخُو ڒْخذْمثْ إِقسْحنْ ن بَابَاشْ ؤُڒَا ذ أَزَايْڒُو إِذقْڒنْ إِ خَانغْ إِڭَّا، \add خنِّي\add* أَذْ شكْ نخْذمْ.“  
\v 5 نتَّا إِنَّا أَسنْ: ”ؤُيُورمْ ؤُعقْبمْ أَوَارْنِي إِ ثْڒَاثَا ن وُوسَّانْ.“ ؤُشَا يُويُورْ ڒْڭنْسْ.   
\m
\v 6 إِمْشَاوَارْ ؤُجدْجِيذْ رَاحَابْعَامْ أَكْ-ذ إِمقّْرَاننْ نِّي ثُوغَا إِبدّنْ زَّاثْ إِ وُوذمْ ن بَابَاسْ سُولِيمَانْ ؤُمِي ثُوغَا عَاذْ إِدَّارْ، إِنَّا: ”س مِينْزِي إِ ذ أَيِي ثْوصَّامْ أَذْ د-أَرّغْ خْ ڒْڭنْسْ-أَ؟“  
\v 7 نِيثْنِي سِّيوْڒنْ أَكِيذسْ، نَّانْ: ”مَاڒَا شكْ ثڭِّيذْ س ثْشُونِي أَكْ-ذ ڒْڭنْسْ-أَ، أَذْ كِيذْسنْ ثڭّذْ غَارْ ڒْخَاضَارْ نْسنْ ؤُشَا أَذْ كِيذْسنْ ثسِّيوْڒذْ س وَاوَاڒنْ إِشْنَانْ، \add خنِّي\add* أَذْ ذوْڒنْ ذ إِمْسخَّارنْ نّشْ مَارَّا مِينْ إِقِّيمنْ ن ؤُسَّانْ.“  
\v 8 \add مَاشَا\add* نتَّا إِنْضَارْ شّْوَارْ إِ ذ أَسْ ثُوغَا وْشِينْ إِمقّْرَاننْ ؤُشَا إِمْشَاوَارْ أَكْ-ذ إِحُوذْرِييّنْ نِّي ثُوغَا أَكِيذسْ إِمْغَارنْ ؤُ بدّنْ ڒخُّو زَّاثْ إِ وُوذمْ نّسْ.  
\v 9 نتَّا إِسّقْسَا إِ-ثنْ: ”س مِينْزِي إِ ذ أَنغْ ثْوصَّامْ أَذْ نَارّْ خْ وَاوَاڒْ ن ڒْڭنْسْ، مِينْزِي سّْوِيڒنْ أَكِيذِي، نَّانْ: ’سَارْخُو أَزَايْڒُو إِ خَانغْ إِڭَّا بَابَاشْ.‘ “  
\v 10 إِحُوذْرِييّنْ نِّي ثُوغَا مْغَارنْ أَكِيذسْ، سِّيوْڒنْ أَكِيذسْ، نَّانْ: ”أَمُّو إِ د غَا ثَارّذْ خْ ڒْڭنْسْ إِ كِيذكْ إِسِّيوْڒنْ ؤُ نَّانْ: ’بَابَاشْ إِسّذْقڒْ أَزَايْڒُو نّغْ، مَاشَا \add ڒخُّو\add* شكْ سَارْخُو ث خَانغْ!‘، \add وَاهْ،\add* أَمُّو إِ كِيذْسنْ إِ غَا ثسِّيوْڒذْ: ’\add أَضَاضْ\add* أَمژْيَانْ إِنُو أَذْ يِيڒِي ذ أَمقّْرَانْ خْ ثجْعِينَّا ن بَابَا.  
\v 11 مَاڒَا بَابَا إِقّنْ أَومْ إِجّْ ن ؤُزَايْڒُو إِقْسحْ، \add خنِّي\add* نشّْ أَذْ ث سّْذقْڒغْ \add عَاذْ\add*. مَاڒَا بَابَا يَاربِّي كنِّيوْ س ؤُركُّوضْ، نشّْ أَذْ كنِّيوْ أَربِّيغْ س إِغَارْضْمِيونْ.‘ “   
\m
\v 12 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا يُوسَا-د يَارُوبْعَامْ أَكْ-ذ مَارَّا ڒْڭنْسْ غَارْ رَاحَابْعَامْ، أَمْ مَامّشْ ثُوغَا إِسِّيوڒْ ؤُجدْجِيذْ، ثُوغَا إِنَّا: ”عقْبمْ-د غَارِي أَوَارْنِي إِ ثْڒَاثَا ن وُوسَّانْ!“  
\v 13 أَجدْجِيذْ يَارَّا-د خْ ڒْڭنْسْ س إِجّْ ن وبْرِيذْ إِقسْحنْ، مَاغَارْ أَجدْجِيذْ رَاحَابْعَامْ إِسْمحْ ذِي شّْوَارْ ن إِمقّْرَاننْ.  
\v 14 إِسِّيوڒْ أَكِيذْسنْ عْلَاحْسَابْ شّْوَارْ ن إِحُوذْرِييّنْ، إِنَّا: ”نشّْ أَذْ سّْذقْڒغْ عَاذْ أَزَايْڒُو نْومْ. بَابَا يَاربِّي كنِّيوْ س ؤُركُّوضْ، نشّْ أَذْ كنِّيوْ أَربِّيغْ س إِغَارْضْمِيونْ.“  
\v 15 أَجدْجِيذْ وَارْ إِسْڒِي شَا غَارْ ڒْڭنْسْ، مَاغَارْ أَنقْڒبْ-أَ ثُوغَا يُوسَا-د زِي أَربِّي، حِيمَا أَذْ إِسّمْثنْ سِيذِي أَوَاڒْ إِ ثُوغَا إِسِّيوڒْ س ؤُقمُّومْ ن أَخِييَا، أَشِيلُونِي، أَكْ-ذ يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ.   
\m
\v 16 \add ؤُمِي\add* إِژْرَا مَارَّا إِسْرَائِيل أَقَا أَجدْجِيذْ وَارْ غَارْسنْ د-إِسْڒِي شَا، يَارَّا-د ڒْڭنْسْ خْ ؤُجدْجِيذْ، إِنَّا: ”مَانْ ثَاسْغَارْثْ إِ غَارْنغْ أَكْ-ذ ذَاوُوذْ؟ نشِّينْ وَارْ غَارْنغْ بُو ثسْغَارْثْ أَكْ-ذ مِّيسْ ن يَاسَّا. مَارَّا \add كنِّيوْ،\add* ؤُيُورمْ غَارْ إِقِيضَانْ نْومْ، \add أَ\add* إِسْرَائِيل! ڒْهَا ڒخُّو أَكْ-ذ ثَادَّارْثْ نّشْ، ذَاوُوذْ!“ ؤُشَا مَارَّا إِسْرَائِيل يُويُورْ غَارْ إِقِيضَانْ نْسنْ. \f ◼ \fr 10:‏16 \ft \+bd ’مَارَّا كنِّيوْ غَارْ إِقِيضَانْ نْومْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَرْيَازْ غَارْ إِقِيضَانْ نّكْ!‘.\f*  
\v 17 ثُوغَا رَاحَابْعَامْ ذ أَجدْجِيذْ خْ أَيْثْ ن إِسْرَائِيل نِّي ثُوغَا إِزدّْغنْ ذِي ثْندَّامْ ن يَاهُوذَا.  
\v 18 أَجدْجِيذْ رَاحَابْعَامْ إِسّكّْ \add غَارْسنْ\add* أَذُورَامْ، ونِّي \add إِدْجَانْ\add* خْ لْجِيزْيَا، ؤُ أَيْثْ ن إِسْرَائِيل أَرْجْمنْ ث س يژْرَا أَڒَامِي إِمُّوثْ. أَجدْجِيذْ رَاحَابْعَامْ إِنْيَا ذغْيَا خْ ؤُكَارُّو، حِيمَا أَذْ يَارْوڒْ غَارْ ؤُرْشَالِيمْ.  
\v 19 \add أَمُّو إِ\add* إِغوّغْ إِسْرَائِيل خْ ثَادَّارْثْ ن ذَاوُوذْ أَڒْ أَسّْ-أَ.   
\b  
\b  
\m  
\c 11
\s1 أَجدْجِيذْ رَاحُوبْعَامْ إِحكّمْ خْ يَاهُوذَا  
\m
\v 1 رَاحَابْعَامْ يُوسَا-د غَارْ ؤُرْشَالِيمْ ؤُشَا إِسّْمُونْ مَارَّا ثَادَّارْثْ ن يَاهُوذَا ذ بِينْيَامِينْ، مْيَا ؤُ-ثْمنْيِينْ-أَڒفْ \add ن إِرْيَازنْ\add* إِتّْوَافَارْزنْ، تّْوَاذَارّْبنْ خْ ؤُمنْغِي، حِيمَا أَذْ مّنْغنْ أَكْ-ذ ثَادَّارْثْ ن إِسْرَائِيل، حِيمَا أَذْ د-أَرّنْ ثَاڭلْذِيثْ غَارْ رَاحُوبْعَامْ.  
\v 2 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن أَربِّي غَارْ شَامْعِييَا، أَرْيَازْ ن أَربِّي، إِنَّا:  
\v 3 ”سِيوڒْ أَكْ-ذ رَاحَابْعَامْ، مِّيسْ ن سُولِيمَانْ، أَجدْجِيذْ ن يَاهُوذَا، ؤُ أَكْ-ذ مَارَّا إِسْرَائِيل ذِي \add ثمُّورْثْ ن\add* يَاهُوذَا ذ بِينْيَامِينْ، ؤُشَا إِنِي:  
\v 4 ’أَمُّو إِ إِقَّارْ سِيذِي: وَارْ تّْڭعَّاذمْ شَا ؤُ وَارْ تّْمنْغِيمْ شَا أَكْ-ذ أَيْثْمَاثْومْ. إِتّْخصَّا أَذْ إِعْقبْ \add كُوڒْ إِجّْ ن\add* ورْيَازْ غَارْ ثَادَّارْثْ نّسْ، مَاغَارْ ذ مَانْ أَيَا إِ إِمْسَارنْ زِي غَارِي.‘ “ نِيثْنِي سْڒَانْ غَارْ وَاوَاڒْ ن سِيذِي ؤُشَاعقْبنْ، وَارْ ؤُيُورنْ شَا غَارْ يَارُوبْعَامْ.   
\b  
\m
\v 5 رَاحَابْعَامْ إِزْذغْ ذِي ؤُرْشَالِيمْ ؤُشَا إِڭَّا ثِيندَّامْ ذِي يَاهُوذَا أَذْ ذوْڒنْثْ فَارْينْثْ.  
\v 6 إِبْنَا بَايْثْ-لَاحَامْ، عِيطَامْ، ثَاقُوعَا،  
\v 7 بَايْثْ-صُورْ، سُوكُو، عَاذُولَّامْ،  
\v 8 جَاثْ، مَارِيشَا، زِيفْ،  
\v 9 أَذُورَايِيمْ، لَاخِيسْ، عَازِيقَا،  
\v 10 صُورْعَا، أَيَّالُونْ ذ حَابْرُونْ نِّي \add إِدْجَانْ\add* ذِي يَاهُوذَا ذ بِينْيَامِينْ. أَقَا-ثنْثْ ذ ثْندَّامْ إِفَارْينْ.  
\v 11 إِسّجْهذْ لْقلْعَاثْ ؤُ إِڭَّا خَاسنْ ڒْحُوكَّامْ ؤُ إِخْزنْ \add ذَايْسنْثْ\add* مَاشَّا، زّشْثْ ذ بِينُو.  
\v 12 \add إِسَّارْسْ\add* ثِيسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* ثِيمقّْرَانِينْ ذ إِحْرِيشنْ ذِي كُوڒْ ثنْذِينْثْ ؤُشَا إِسّجْهذْ إِ-ثنْثْ أَڒْ طَّارْفْ. \add أَمُّو إِ\add* ثُوغَا يَاهُوذَا ذ بِينْيَامِينْ \add ذڭْ ؤُفُوسْ\add* نّسْ.   
\m
\v 13 إِكهَّاننْ ذ إِلَاوِييّنْ نِّي \add إِدْجَانْ\add* ذِي مَارَّا إِسْرَائِيل، قّْننْ غَارسْ زِي مَارَّا جّْوَايهْ نْسنْ.  
\v 14 مِينْزِي إِلَاوِييّنْ جِّينْ دّْمَانِي نْسنْ ذ وَاڭْڒَا نْسنْ ؤُشَا ؤُسِينْ-د غَارْ يَاهُوذَا ذ ؤُرْشَالِيمْ، مَاغَارْ يَارُوبْعَامْ ذ إِحنْجِيرنْ نّسْ مّنْضَارنْ ثنْ زِي ثُوكهَّانْثْ ن سِيذِي.  
\v 15 \add خنِّي\add* يَاڒقّمْ يَارُوبْعَامْ إِكهَّاننْ إِ يِيخفْ نّسْ إِ ڒڭْعُوذِي، إِ \add ڒخْيَاڒَاثْ ن\add* إِمُويَانْ \add إِجنّنْ\add* ؤُ إِ \add ڒخْيَاڒَاثْ ن\add* إِعجْمِييّنْ نِّي ثُوغَا إِڭَّا. \f ◼ \fr 11:‏15 \ft \+bd ’أَمْوَا‘\+bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*  
\v 16 أَوَارْنِي أَسنْ ؤُسِينْ-د \add عَاوذْ\add* زِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل إِنِّي إِوْشِينْ إِخفْ نْسنْ س وُوڒْ حِيمَا أَذْ أَرْزُونْ سِيذِي، أَربِّي ن إِسْرَائِيل، حِيمَا أَذْ وهّْبنْ ثِيغَارْصَا إِ سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ.  
\v 17 \add أَمُّو\add* سّْجهْذنْ ثَاڭلْذِيثْ ن يَاهُوذَا ؤُ سّْمثْننْ رَاحَابْعَامْ، مِّيسْ ن سُولِيمَانْ، ثْڒَاثَا ن إِسڭّْوُوسَا. مَاغَارْ نِيثْنِي ؤُيُورنْ ثْڒَاثَا ن إِسڭّْوُوسَا ذڭْ وبْرِيذْ ن ذَاوُوذْ ذ سُولِيمَانْ.   
\m
\v 18 رَاحَابْعَامْ يِيوِي مَاحْلَاثْ، يدْجِيسْ ن يَارِيمُوثْ، مِّيسْ ن ذَاوُوذْ، ؤُڒَا ذ أَبِيحَايِيلْ، يدْجِيسْ ن إِلِييَابْ، مِّيسْ ن يَاسَّا، ذ ثَامْغَارْثْ إِ يِيخفْ نّسْ.  
\v 19 نتَّاثْ ثُورُووْ أَسْ-د إِحنْجِيرنْ\add -أَ\add*: يَاعُوشْ، شَامَارْيَا ذ زَاهَامْ.  
\v 20 أَوَارْنِي أَسْ يِيوِي مَاعْكَا، يدْجِيسْ ن أَبْشَالُومْ \add ذ ثَامْغَارْثْ\add*. نتَّاثْ ثُورُووْ أَسْ-د أَبِييَا، عَاتَّايْ، زِيزَا ذ شَالُومِيثْ.  
\v 21 رَاحَابْعَامْ ثُوغَا إِتّخْسْ مَاعْكَا، يدْجِيسْ ن أَبْشَالُومْ، أَطَّاسْ خْ ثمْغَارِينْ نّسْ نّغْنِيثْ ذ خْ ثِييَّا نّسْ. أَقَا يِيوِي رَاحَابْعَامْ ثْمنْطَاشْ ن ثمْغَارِينْ ذ ستِّينْ ن ثِييَّا. نتَّا يجّْ-د ثْمنْيَا ؤُ-عِيشْرِينْ ن إِحنْجِيرنْ ذ ستِّينْ ن يسِّيسْ.  
\v 22 رَاحَابْعَامْ إِڭَّا أَبِييَا، مِّيسْ ن مَاعْكَا، ذ أَزدْجِيفْ، حِيمَا أَذْ يِيڒِي ذ ڒْحَاكمْ جَارْ أَيْثْمَاسْ، حِيمَا أَذْ ث يَارّْ ذ أَجدْجِيذْ.  
\v 23 \add رَاحَابْعَامْ\add* إِڭَّا س ڒعْقڒْ ؤُشَا إِبْضَا مَارَّا إِحنْجِيرنْ نّسْ خْ مَارَّا ثِيمُّورَا ن يَاهُوذَا ذ بِينْيَامِينْ ؤُ ذِي مَارَّا ثِيندَّامْ إِفَارْينْ. نتَّا إِوْشَا أَسنْ مَاشَّا س وَاطَّاسْ ؤُ يَارْزُو أَسنْ إِجّْ ن ؤُبَارُّو ن ثمْغَارِينْ.   
\b  
\b  
\m  
\c 12
\s1 أَهجّمْ خْ يَاهُوذَا س ؤُفُوسْ ن سِيسَاكْ، أَجدْجِيذْ ن مِيصْرَا  
\m
\v 1 ؤُمِي ثُوغَا رَاحَابْعَامْ إِسّمْثنْ ثَاڭلْذَا \add ذڭْ ؤُفُوسْ نّسْ\add* ؤُ ثُوغَا إِجْهذْ، إِوْضَا نتَّا زِي شَّارِيعَا ن سِيذِي، نتَّا ؤُڒَا ذ مَارَّا إِسْرَائِيل أَكِيذسْ. \x ◘ \xo 12:‏1 \xt [1 إِج. 14‏:‏21‏-‏31]\x*  
\v 2 ذڭْ ؤُسڭّْوَاسْ وِيسّْ خمْسَا ن ؤُجدْجِيذْ رَاحَابْعَامْ، إِمْسَارْ - مِينْزِي نِيثْنِي ثُوغَاغوّْغنْ خْ سِيذِي - أَقَا شِيشَاكْ، أَجدْجِيذْ ن مِيصْرَا، إِڭعّذْ ضِيدّْ ؤُرْشَالِيمْ  
\v 3 س مِيثَاينْ-أَڒفْ ن إِكَارُّوثنْ \add ن ڒْعسْكَارْ\add*، ستِّينْ-أَڒَافْ ن إِمْنَاينْ ذ إِجّْ ن ڒْڭنْسْ وَارْ إِزمَّارْ أَذْ إِتّْوَاحْسبْ شَا إِ د-يُوسِينْ أَكِيذسْ زِي مِيصْرَا: إِلِيبِييّنْ، إِسُوكِّييّنْ ذ إِكُوشِييّنْ.  
\v 4 نتَّا إِطّفْ ثِيندَّامْ إِفَارْينْ ن يَاهُوذَا ؤُشَا يُوسَا-د غَارْ ؤُرْشَالِيمْ.   
\m
\v 5 خنِّي يُوسَا-د ؤُنَابِي شَامْعِييَا غَارْ رَاحَابْعَامْ ؤُ غَارْ ڒْحُوكَّامْ ن يَاهُوذَا، إِنِّي ثُوغَا إِمُوننْ ذِي ؤُرْشَالِيمْ ذِي سِّيبّثْ ن شِيشَاكْ، إِنَّا أَسنْ: ”أَمُّو إِ إِقَّارْ سِيذِي: ’مِينْزِي كنِّيوْ ثْحيّْذمْ خَافِي، خْ ؤُيَا حيّْذغْ ؤُڒَا ذ نشّْ خَاومْ، جِّيغْ كنِّيوْ ذڭْ ؤُفُوسْ ن شِيشَاكْ.‘ “  
\v 6 \add خنِّي\add* سّهْوَانْ ڒْحُوكَّامْ ن إِسْرَائِيل ذ ؤُجدْجِيذْ إِخفْ نْسنْ، نَّانْ: ”سِيذِي ذ أَمْسڭّذْ!“  
\v 7 ؤُمِي إِژْرَا سِيذِي، أَقَا نِيثْنِي سّهْوَانْ إِخفْ نْسنْ، إِفّغْ وَاوَاڒْ ن سِيذِي غَارْ شَامْعِييَا، إِنَّا: ”نِيثْنِي سّهْوَانْ إِخفْ نْسنْ. نشّْ وَارْ ثنْ ثحِّيغْ شَا، مَاشَا أَذْ أَسنْ د-أَوْيغْ أَسنْجمْ ذغْيَا، مَاحنْذْ أَسْعَارْ إِنُو س ؤُفُوسْ ن شِيشَاكْ وَارْ إِتّْوَازِيدْجِيعْ شَا خْ ؤُرْشَالِيمْ،  
\v 8 مَاشَا أَذْ ذوْڒنْ ذ إِمْسخَّارنْ نّسْ، حِيمَا أَذْ سّْننْ \add ڒْْفَارْقْ جَارْ\add* ثَاسخَّارْثْ إِ نشّْ ذ ثْسخَّارْثْ إِ ثْڭلْذِيوِينْ ن ثمُّورَا.“   
\m
\v 9 ؤُشَا شِيشَاكْ، أَجدْجِيذْ ن مِيصْرَا، إِڭعّذْ ضِيدّْ إِ ؤُرْشَالِيمْ ؤُ يِيوِي مَارَّا ثِيخُوبَايْ ن ثَادَّارْثْ ن سِيذِي ذ ثْخُوبَايْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ. نتَّا يِيوِي \add أَكِيسْ\add* مَارَّا، ؤُڒَا ذ ثِيسدَّارِييِّينْ \add ن ؤُعسْكَارِي\add* ن وُورغْ إِ ثُوغَا إِڭَّا سُولِيمَانْ.   
\b  
\m
\v 10 ذڭْ ومْشَانْ نْسنْثْ إِڭَّا ؤُجدْجِيذْ رَاحَابْعَامْ ثِيسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* ن نّْحَاسْ. إِڭَّا إِ-ثنْثْ ذڭْ إِفَاسّنْ ن إِمقّْرَاننْ خْ إِرقَّاسنْ ن ثَازْڒَا نِّي ثُوغَا إِتّْعسَّانْ غَارْ وَاذَافْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ.  
\v 11 مڒْمِي مَا إِ غَا يَاذفْ ؤُجدْجِيذْ غَارْ ثَادَّارْثْ ن سِيذِي، إِمْسَارْ، أَقَا إِرقَّاسنْ ن ثَازْڒَا ؤُسِينْ-د، أَربُّونْ ثنْثْ ؤُ إِوْينْ ثنْثْ خنِّي عَاوذْ غَارْ وخَّامْ ن إِرقَّاسنْ ن ثَازْڒَا.   
\m
\v 12 ؤُمِي إِسّْوَاضعْ ڒَاحَابْعَامْ إِخفْ نّسْ، إِجَّا وغْضَابْ ن سِيذِي خَاسْ، أَڒَامِي وَارْ ث إِضيّعْ مَارَّا. ثُوغَا ذِينْ عَاذْ ذِي يَاهُوذَا ثِيمسْڒَايِينْ صبْحنْثْ.  
\v 13 أَجدْجِيذْ رَاحَابْعَامْ إِسّجْهذْ إِخفْ نّسْ ؤُشَا إِقِّيمْ إِحكّمْ. رَاحَابْعَامْ \add ثُوغَا\add* غَارسْ وَاحِيثْ ؤُ-ربْعِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ نتَّا ذ أَجدْجِيذْ. نتَّا إِحْكمْ سْبعْطَاشْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ، ذِي ثنْذِينْثْ إِ إِخْضَارْ سِيذِي زِي جَارْ مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل حِيمَا أَذْ ذِينْ إِسّمْثنْ إِسمْ نّسْ. يمَّاسْ قَّارنْ أَسْ نِيعْمَا، \add ثنِّي ذ\add* ثَاعَامُّونِيثْ. \x ◘ \xo 12:‏13 \xt 1 إِج. 14‏:‏21، 31\x*  
\v 14 إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ، مَاغَارْ وَارْ إِسّوْجذْ ؤُڒْ نّسْ مَاحنْذْ أَذْ يَارْزُو خْ سِيذِي.   
\m
\v 15 إِمزْرُوينْ ن رَاحَابْعَامْ، إِمزْوُورَا ذ إِنڭُّورَا، ؤُڒَا ذ إِمنْغَانْ جَارْ رَاحَابْعَامْ ذ يَارُوبْعَامْ ذِي مَارَّا ؤُسَّانْ، مَا نِيثْنِي وَارْ تّْوَازمّمنْ شَا ذڭْ وَاوَاڒنْ ن ؤُنَابِي شَامْعِييَا ذ ؤُمْوَاڒَاوْ عِيدُّو ذِي طّْوعْ ن لِيسْثَاثْ ن جَّاذِيرَا؟  
\v 16 رَاحَابْعَامْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن ذَاوُوذْ. مِّيسْ أَبِييَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\b  
\m  
\c 13
\s1 أَغلّبْ ن أَبِييَا، أَجدْجِيذْ ن يَاهُوذَا، خْ يَارُوبْعَامْ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْطَاشْ ن ؤُجدْجِيذْ يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، إِذْوڒْ أَبِييَا ذ أَجدْجِيذْ خْ يَاهُوذَا. \x ◘ \xo 13:‏1 \xt [1 إِج. 15‏:‏1‏-‏8]\x*  
\v 2 نتَّا إِحْكمْ ثْڒَاثَا ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ مِيخَا-يَاهُو، يدْجِيسْ ن ؤُرِييِيلْ زِي جِيبْعَا. ثُوغَا \add ذِينْ\add* ؤُمنْغِي جَارْ أَبِييَا ذ يَارُوبْعَامْ.  
\v 3 أَبِييَا إِسّكَّارْ أَمنْغِي س إِجّْ ن ڒْعسْكَارْ ن أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، أَربْعَا-مْيَاثْ-أَڒفْ ن يرْيَازنْ إِتّْوَافَارْزنْ، ؤُشَا يَارُوبْعَامْ إِڭَّا أَسذِّي س ثمْنْ-مْيَاثْ-أَڒفْ ن يرْيَازنْ إِتّْوَافَارْزنْ، أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ.  
\v 4 إِبدّْ أَبِييَا خْ ثْقِيشَّاثْ ن وذْرَارْ ن صَامَارَايِيمْ نِّي \add إِدْجَانْ\add* خْ إِذُورَارْ ن إِفْرَايِيمْ، إِنَّا: ”سْڒمْ غَارِي، يَارُوبْعَامْ ذ مَارَّا إِسْرَائِيل!  
\v 5 مَا وَارْ ثسِّينمْ شَا أَقَا سِيذِي، أَربِّي ن إِسْرَائِيل، إِوْشَا ثَاڭلْذَا خْ إِسْرَائِيل س يِيجّْ ن ڒْعَاهْذْ ن ثْمدْجَاحْثْ إِ ذَاوُوذْ ؤُ إِ إِحنْجِيرنْ نّسْ إِ ڒبْذَا؟  
\v 6 \add مَاشَا\add* يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، أَمْسخَّارْ ن سُولِيمَانْ، مِّيسْ ن ذَاوُوذْ، إِكَّارْ ؤُشَا إِغوّغْ خْ سِيذِيسْ نّسْ.  
\v 7 إِرْيَازنْ إِخْوَانْ، أَيْثْ إِ وَارْ إِسكّْوِينْ، ؤُسِينْ-د غَارسْ ؤُشَا سّْجهْذنْ إِخفْ نْسنْ ضِيدّْ إِ رَاحَابْعَامْ، مِّيسْ ن سُولِيمَانْ، ؤُمِي رَاحَابْعَامْ ثُوغَا عَاذْ ذ أَمژْيَانْ ذ أَحْنِينْ ن وُوڒْ ؤُ وَارْ إِزمَّارْ أَكِيذْسنْ إِمْقُودَّا.  
\v 8 ؤُشَا ڒخُّو، إِتّْغِيڒْ أَومْ أَذْ ثِيڒِيمْ ثْجهْذمْ خْ ثْڭلْذِيثْ ن سِيذِي، ثنِّي \add إِدْجَانْ\add* ذڭْ إِفَاسّنْ ن إِحنْجِيرنْ ن ذَاوُوذْ. وَاخَّا، كنِّيوْ س يِيجّْ ن ڒْغَاشِي أَمقّْرَانْ إِ ثدْجَامْ، مَاشَا غَارْومْ إِعجْمِييّنْ ن وُورغْ نِّي إِڭَّا يَارُوبْعَامْ ذ إِربِّيثنْ إِ كنِّيوْ. \f ◼ \fr 13:‏8 \ft \+bd ’أَمْوَا‘\+bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*  
\v 9 مَا وَارْ ثنْضَارمْ كنِّيوْ إِكهَّاننْ ن سِيذِي، أَرَّاوْ ن هَارُونْ ذ وَارَّاوْ ن لَاوِي، ؤُ ثڭِّيمْ إِ يِيخفْ نْومْ إِكهَّاننْ أَمْ مَامّشْ \add ت تّڭّنْ\add* ڒڭْنُوسْ ذِي \add مَارَّا\add* ثِيمُّورَا؟ مَارَّا ونِّي د-يُوسِينْ س يِيجّْ ن ؤُفُونَاسْ، أَمژْيَانْ ن ثْفُونَاسْثْ، ؤُ س سبْعَا ن إِشَارِّييّنْ إِ إِخْسنْ أَذْ إِتّْوَاڭّْ ذ أَكهَّانْ، أَقَا إِذْوڒْ ذ أَكهَّانْ ن يِينِّي وَارْ إِدْجِينْ شَا ذ إِربِّيثنْ.  
\v 10 مَاشَا خَانغْ، أَقَا سِيذِي ذ أَربِّي نّغْ، ؤُ نشِّينْ وَارْ خَاسْ نْحيّذْ شَا، ؤُ إِكهَّاننْ نِّي إِسخَّارنْ إِ سِيذِي، أَقَا أَثنْ ذ أَرَّاوْ ن هَارُونْ، ؤُ إِلَاوِييّنْ \add بدّنْ أَكِيذْسنْ\add* ذِي ڒْخذْمثْ.  
\v 11 كُوڒْ صّْبحْ ذ ثْمذِّيثْ سّْبخَّارَانْ ثِيغَارْصَا ن وشْمَاضْ إِ سِيذِي. ؤُشَا \add حْضَانْ\add* عَاوذْ خْ ڒبْخُورْ إِتّْفُوحنْ ذ ؤُستّفْ ن وغْرُومْ ن وسْشَانْ خْ ثْزوْضَا ثزْذڭْ ؤُ خْ ڒْقنْذِيڒْ ن وُورغْ ؤُ خْ ڒفْنَارَاثْ، حِيمَا أَذْ ثنْثْ سَّارْغنْ كُوڒْ ثَامذِّيثْ، مَاغَارْ نشِّينْ نْخزَّارْ غَارْ ثْسخَّارْثْ ن سِيذِي، أَربِّي نّغْ، مَاشَا كنِّيوْ ثْحيّْذمْ خَاسْ.  
\v 12 خْزَارمْ، أَربِّي أَقَا-ث أَكِيذْنغْ غَارْ زَّاثْنغْ، ؤُ غَارْنغْ ؤُڒَا ذ إِكهَّاننْ نّسْ أَكْ-ذ ڒبْوَاقْ إِ ؤُسُوضِي س وسْرُودّحْ، مَاحنْذْ أَذْ ذَايْسنْ سُوضنْ س وسْرُودّحْ. \add أَ\add* أَيْثْ ن إِسْرَائِيل، وَارْ تّْمنْغَامْ شَا أَكْ-ذ سِيذِي، أَربِّي ن ڒجْذُوذْ نْومْ، مَاغَارْ كنِّيوْ وَارْ ثْفْڒِيحِيمْ شَا.“   
\b  
\m
\v 13 \add مَاشَا\add* يَارُوبْعَامْ إِجَّا \add إِشْثْ ن ثسْغَارْثْ ن يرْيَازنْ نّسْ\add* أَذْ ڭّنْ إِشْثْ ن دُّورَا مَاحنْذْ أَذْ ڭّنْ ثَاخْشفْثْ غَارْ ضفَّارْ نْسنْ. نِيثْنِي ثُوغَا أَثنْ زَّاثْ إِ وُوذمْ ن يَاهُوذَا، ؤُ غَارْ ضفَّارْ \add ن يرْيَازنْ ن يَاهُوذَا\add* ثُوغَا ذِينْ ڒْفخْ.  
\v 14 \add ؤُمِي\add* نْقڒْبنْ \add أَيْثْ ن\add* يَاهُوذَا، ژْرِينْ، أَقَا أَمنْغِي ثُوغَا-ث زِي زَّاثْ ذ زِي ضفَّارْ. نِيثْنِي سْغُوينْ غَارْ سِيذِي ؤُشَا سُوضنْ إِكهَّاننْ ذِي ڒبْوَاقْ.  
\v 15 إِرْيَازنْ ن يَاهُوذَا سّْڭعّْذنْ ذڭْ إِغُويَّانْ ن ؤُمنْغِي ؤُ ڒَامِي سّْڭعّْذنْ إِرْيَازنْ ن يَاهُوذَا ذڭْ إِغُويَّانْ، إِمْسَارْ، أَقَا أَربِّي إِوْثَا يَارُوبْعَامْ ذ مَارَّا إِسْرَائِيل زَّاثْ إِ ثِيطَّاوِينْ ن أَبِييَا ذ يَاهُوذَا.  
\v 16 أَرَّاونْ ن إِسْرَائِيل أَروْڒنْ زَّاثْ إِ وُوذمْ ن يَاهُوذَا ؤُشَا أَربِّي إِڭَّا إِ-ثنْ ذڭْ ؤُفُوسْ نْسنْ.  
\v 17 أَبِييَا أَكْ-ذ ڒْڭنْسْ نّسْ، وْثِينْ ثنْ س إِشْثْ ن ثشْثِي ذ ثَامقّْرَانْثْ، مِينْزِي وْضَانْ \add زَّايْسنْ\add* خمْسَا-مْيَاثْ-أَڒفْ ن يرْيَازنْ إِتّْوَافَارْزنْ زِي إِسْرَائِيل.  
\v 18 \add أَمُّو\add* إِ ذوْڒنْ أَيْثْ ن إِسْرَائِيل نّْبهْثْڒنْ ذِي ڒْوقْثْ نِّي، مَاشَا أَيْثْ ن يَاهُوذَا ذوْڒنْ جهْذنْ، مِينْزِي تّشْڒنْ خْ سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ.  
\v 19 أَبِييَا إِضْفَارْ يَارُوبْعَامْ ؤُشَا إِطّفْ زَّايسْ ثِيندَّامْ بَايْثْ-إِلْ أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ، يَاشَانَا أَكْ-ذ ذْشُورَاثْ نّسْ ذ إِفْرُونْ أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ.  
\v 20 وَارْ ثقِّيمْ عَاذْ جّهْذْ غَارْ يَارُوبْعَامْ ذڭْ وُوسَّانْ ن أَبِييَا. غَارْ ؤُنڭَّارْ إِوْثَا إِ-ث سِيذِي، أَڒَامِي إِمُّوثْ.   
\m
\v 21 أَبِييَا \add مَاشَا\add* إِذْوڒْ يَارنِّي ذِي جّهْذْ. نتَّا يِيوِي أَرْبعْطَاشْ ن ثمْغَارِينْ إِ يِيخفْ نّسْ ؤُ إِجَّا-د ثْنَاينْ ؤُ-عِيشْرِينْ ن وَارَّاونْ ذ سطَّاشْ ن يسِّيسْ.  
\v 22 مِينْ إِقِّيمنْ ن إِمزْرُوينْ ن أَبِييَا، أَمْ ثبْرِيذِينْ نّسْ أَمْ وَاوَاڒنْ نّسْ، أَقَا مَانْ أَيَا \add مَارَّا\add* إِتّْوَازمّمْ ذڭْ وذْلِيسْ ن ثْغُورِي ن ؤُنَابِي عِيدُّو.  
\v 23 أَبِييَا إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ ؤُشَا نضْڒنْ ث ذِي ثنْذِينْثْ ن ذَاوُوذْ، ؤُشَا مِّيسْ أَسَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. ذڭْ وُوسَّانْ نّسْ ثُوغَا ذِينْعشْرَا ن إِسڭّْوُوسَا ن ڒْهُوذْنثْ ذِي ثمُّورْثْ.   
\b  
\b  
\m  
\c 14
\s1 أَغلّبْ ن أَسَا، أَجدْجِيذْ ن يَاهُوذَا، خْ زَارَاحْ  
\m
\v 1 أَسَا إِڭَّا \add مِينْ إِدْجَانْ\add* نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَربِّي نّسْ. \x ◘ \xo 14:‏1 \xt [1 إِج. 15‏:‏9‏-‏12]\x*  
\v 2 نتَّا إِكّسْ إِعَالْطَارنْ ن \add إِربِّيثنْ\add* إِغْرِيبنْ ذ ڒڭْعُوذِي ؤُشَا يَارْژَا إِمَايْضُوثنْ \add إِقدّْسنْ\add* ؤُشَا إِهْذمْ ثِيربِّينْ ن شْوَارْثِي.  
\v 3 نتَّا إِنَّا إِ يَاهُوذَا، أَذْ أَرْزُونْ سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ ؤُشَا أَذْ ضْفَارنْ شَّارِيعَا ذ ثوْصيّثْ.  
\v 4 نتَّا إِكّسْ \add عَاوذْ\add* ڒڭْعُوذِي ذ إِپِيلَارنْ ن أَربِّي ن ثْفُوشْثْ زِي مَارَّا ثِيندَّامْ ن يَاهُوذَا. ثَاڭلْذِيثْ ثُوغَا غَارسْ ڒْهُوذْنثْ سَاذُو نتَّا.  
\v 5 إِبْنَا ثِيندَّامْ إِفَارْينْ ذِي يَاهُوذَا مَاغَارْ ثَامُّورْثْ ثُوغَا ذَايسْ ڒْهُوذْنثْ. وَارْ ثُوغِي ذِينْ أَمنْغِي أَكِيذسْ ذڭْ إِسڭّْوُوسَا نِّي، مِينْزِي سِيذِي إِوْشَا أَسْ ڒْهُوذْنثْ.  
\v 6 نتَّا إِنَّا إِ يَاهُوذَا: ”أجّْ أَنغْ أَذْ نبْنَا ثِيندَّامْ-أَ ؤُشَا أَذْ ثنْثْ نسَّارْ س ڒحْيُوضْ ذ لْبُورْجَاثْ ذ ثوُّورَا ذ إِعُومَاذْ إِ ؤُبلّعْ، مَاغَارْ ثَامُّورْثْ عَاذْ زَّاثْنغْ \add س ڒْهُوذْنثْ\add*، مِينْزِي نشِّينْ نَارْزُو خْ سِيذِي، أَربِّي نّغْ، نَارْزُو خَاسْ ؤُ نتَّا إِوْشَا أَنغْ ڒْهُوذْنثْ.“ ؤُ نِيثْنِي بْنَانْ ؤُشَا فڒْحنْ.   
\m
\v 7 أَسَا ثُوغَا غَارسْ إِجّْ ن ڒْعسْكَارْ ن ثڒْثْ-مْيَاثْ-أَڒفْ \add ن يرْيَازنْ\add* زِي يَاهُوذَا، إِنِّي إِكْسِينْ ثَاسدَّارْثْ \add ن ؤُعسْكَارِي\add* ثَامقّْرَانْثْ ذ لَانْسَا، مِيثَاينْ ؤُ-ثْمنْيِينْ-أَڒفْ \add ن يرْيَازنْ\add* زِي بِينْيَامِينْ، إِنِّي يَاربُّونْ ثَاسدَّارْثْ \add ن ؤُعسْكَارِي\add* ؤُ زمَّارنْ خْ ڒْقوْسْ. نِيثْنِي مَارَّا ثُوغَا أَثنْ ذ أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ.   
\m
\v 8 إِفّغْ أَكُوشِي، قَّارنْ أَسْ زَارَاحْ \add إِ ؤُمنْغِي\add* أَكِيذْسنْ س يِيجّْ ن ڒْعسْكَارْ ن إِجّْ ن ملْيُونْ \add ن يرْيَازنْ\add* ذ ثڒْثْ-مْيَا ن إِكَارُّوثنْ. نتَّا يُوسَا-د أَڒْ مَارِيشَا.  
\v 9 إِفّغْ أَسَا إِ ؤُمْسَاڭَارْ أَكِيذسْ ؤُشَا سدّنْ نِيثْنِي إِخفْ نْسنْ إِ ؤُمنْغِي ذِي ثغْزُورْثْ ن صَافَاثَا غَارْ مَارِيشَا.  
\v 10 أَسَا إِڒَاغَا غَارْ سِيذِي، أَربِّي نّسْ، إِنَّا: ”\add أَ\add* سِيذِي، أَيَا إِسْهڒْ خَاكْ حِيمَا أَذْ ثَاذْفذْ جَارْ \add ينِّي ذڭْ\add* وَاطَّاسْ ذ \add ينِّي\add* وَارْ غَارْ إِدْجِي جّهْذْ. عَاونْ أَنغْ، \add أَ\add* سِيذِي، أَربِّي نّغْ، مَاغَارْ نتّْشڒْ خَاكْ ؤُ نُوسَا-د قِيبَاتْشْ إِ ڒْغَاشِي-يَا س يِيسمْ نّشْ. \add أَ\add* سِيذِي، شكْ ذ أَربِّي نّغْ، وَارْ تّجِّي ؤُڒَا ذ إِجّْ ن ورْيَازْ أَذْ أَكِيذكْ إِمّْعَاڒَا.“  
\v 11 ؤُشَا سِيذِي إِوْثَا أَيْثْ ن كُوشْ زَّاثْ إِ وُوذمْ ن أَسَا ذ يَاهُوذَا، ؤُشَا أَروْڒنْ \add أَيْثْ ن\add* كُوشْ.  
\v 12 أَسَا ذ ڒْڭنْسْ إِ ثُوغَا أَكِيذسْ، ضْفَارنْ ثنْ أَڒْ جَارَارْ. وْضَانْ أَطَّاسْ زڭْ \add أَيْثْ ن\add* كُوشْ أَڒَامِي وَارْ زمَّارنْ أَذْ بدّنْ عَاذْ، مِينْزِي نِيثْنِي تّْوَاغڒْبنْ زَّاثْ إِ وُوذمْ ن سِيذِي ذ ڒْعسْكَارْ نّسْ. نِيثْنِي طّْفنْ إِشْثْ ن ثْكشَّاضْثْ ذ ثَامقّْرَانْثْ.  
\v 13 نِيثْنِي وْثِينْ مَارَّا ثِيندَّامْ إِ د-إِنّْضنْ إِ جَارَارْ، مَاغَارْ أَرّهْبثْ ن سِيذِي \add ثوْضَا-د\add* خَاسنْثْ. نِيثْنِي كشّْضنْ مَارَّا ثِيندَّامْ، مَاغَارْ ثُوغَا ثْبَانْ-د ذَايْسنْثْ أَطَّاسْ ن ثْكشَّاضْثْ.  
\v 14 نِيثْنِي هذْمنْ ؤُڒَا ذ إِقِيضَانْ ن ڒْمَاڒْ ؤُشَا طّْفنْ ؤُدْجِي ذ إِڒغْمَانْ. \add خنِّي\add*عقْبنْ غَارْ ؤُرْشَالِيمْ.   
\b  
\b  
\m  
\c 15
\s1 أَمنْغِي ن أَسَا ضِيدّْ إِ وعْبذْ ن لْ-أَصْنَامْ  
\m
\v 1 \add خنِّي\add* يُوسَا-د أَرُّوحْ ن أَربِّي خْ عَازَارْيَا، مِّيسْ ن عُوذِيذْ.  
\v 2 نتَّا يُويُورْ إِبدّْ زَّاثْ إِ أَسَا، إِنَّا أَسْ: ”سڒْ-د غَارِي، أَسَا ذ مَارَّا \add أَيْثْ ن\add* يَاهُوذَا ذ بِينْيَامِينْ! سِيذِي أَقَا-ث أَكِيذْومْ ؤُ كنِّيوْ أَكِيذسْ. مَاڒَا ثَارزُّومْ خَاسْ، نتَّا أَذْ كنِّيوْ يَارّْ أَذْ ث ثَافمْ، مَاشَا مَاڒَا كنِّيوْ ثْحيّْذمْ خَاسْ، أَذْ خَاومْ إِحيّذْ ؤُڒَا ذ نتَّا.  
\v 3 أَطَّاسْ ن وُوسَّانْ إِ إِقِّيمْ إِسْرَائِيل بْڒَا أَربِّي ن ثِيذتّْ ؤُ بْڒَا إِجّْ ن ؤُكهَّانْ إِسّْغَارَانْ ؤُ بْڒَا شَّارِيعَا.  
\v 4 مَاڒَا ذوْڒنْ-د نِيثْنِي غَارْ سِيذِي، أَربِّي ن إِسْرَائِيل، ذِي ڒحْصَارثْ ؤُ أَرْزُونْ خَاسْ، إِجَّا إِ-ثنْ أَذْ ث أَفنْ.  
\v 5 ذڭْ وُوسَّانْ نِّي وَارْ ذِينْ ثُوغِي ڒهْنَا إِ ونِّي د-إِفّْغنْ ؤُ إِ ونِّي يَارڭّْوْحنْ، مَاغَارْ أَقَا ذِينْ أَطَّاسْ ن ڒحْوڒْ جَارْ مَارَّا إِمزْذَاغْ ن ثمُّورَا.  
\v 6 \add إِجّْ ن\add* ڒْڭنْسْ إِتّْوَاعْفسْ زڭْ إِجّْ ن ڒْڭنْسْ \add نّغْنِي\add*، ؤُ إِشْثْ ن ثنْذِينْثْ زڭْ إِشْثْ ن ثنْذِينْثْ \add نّغْنِيثْ\add*، مَاغَارْ أَربِّي إِسِّيڭّْوذْ إِ-ثنْ س كُوڒْ ڒحْصَاڒثْ.  
\v 7 كنِّيوْ \add مَاشَا\add* إِڒِيمْ ذ إِرْيَازنْ، وَارْ تّجِّيمْ أَذْ أَرْخُونْ إِفَاسّنْ نْومْ، مَاغَارْ أَقَا ذِينْ ڒْمُونثْ إِ ڒْخذْمثْ نْومْ.“  
\v 8 ؤُمِي أَسَا إِسْڒَا أَوَاڒنْ-أَ ذ نُّوبُووَا ن ؤُنَابِي عُوذِيذْ، إِسّجْهذْ إِخفْ نّسْ ؤُشَا إِسّْبعّذْ نّْعَاوَاثْ ن لْ-أَصْنَامْ زِي مَارَّا ثَامُّورْثْ ن يَاهُوذَا ذ بِينْيَامِينْ ؤُ زِي مَارَّا ثِيندَّامْ نِّي ثُوغَا إِطّفْ خْ إِذُورَارْ ن إِفْرَايِيمْ ؤُشَا إِعْذڒْ أَعَالْطَارْ ن سِيذِي، ونِّي \add إِدْجَانْ\add* زَّاثْ إِ وسْقِيفْ ن وَاذَافْ \add إِ زَّاوشْثْ ثَامقّْرَانْثْ\add* ن سِيذِي.  
\v 9 إِسّْمُونْ مَارَّا يَاهُوذَا ذ بِينْيَامِينْ، ؤُڒَا ذ إِبَارَّانِييّنْ زڭْ إِفْرَايِيمْ، مَانَاسَّا ؤُ شِيمْعُونْ، مَاغَارْ أَطَّاسْ زِي إِسْرَائِيل عْذُونْ غَارسْ، ؤُمِي نِيثْنِي ژْرِينْ، أَقَا سِيذِي، أَربِّي نّسْ، ثُوغَا-ث أَكِيذسْ.  
\v 10 نِيثْنِي مُوننْ ذِي ؤُرْشَالِيمْ ذڭْ ؤُيُورْ وِيسّْ ثْڒَاثَا، ذڭْ ؤُسڭّْوَاسْ وِيسّْ خمّسْطَاشْ ن ثْڭلْذَا ن أَسَا.  
\v 11 ذڭْ وَاسّْ نِّي وهّْبنْ نِيثْنِي سبْعَا-مْيَا ن إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ سبْعَا-أَڒَافْ ن وُودْجِي ذ ثْغَارْصْثْ إِ سِيذِي زِي ثْكشَّاضْثْ إِ كِيذْسنْ إِوْينْ.  
\v 12 نِيثْنِي ؤُذْفنْ غَارْ إِجّْ ن ڒْعَاهْذْ مَاحنْذْ أَذْ أَرْزُونْ سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ، س مَارَّا ؤُڒْ نْسنْ ؤُ س مَارَّا ڒعْمَارْ نْسنْ.  
\v 13 مَارَّا ونِّي وَارْ يَارزُّونْ خْ سِيذِي، أَربِّي ن إِسْرَائِيل، إِتّْخصَّا أَذْ إِتّْوَانغْ، أَمْ ؤُمژْيَانْ أَمْ ؤُمقّْرَانْ، أَمْ ورْيَازْ أَمْ ثمْغَارْثْ.  
\v 14 نِيثْنِي جُّودْجنْ إِ سِيذِي س ثْمِيجَّا ثجْهذْ ؤُ س ؤُسْڒوْڒِيوْ، غَارْ وسْرُودّحْ ن ڒبْوَاقْ ذ وَاشَّاونْ ن إِشَارِّي.  
\v 15 مَارَّا يَاهُوذَا ثْفَارْحْ خْ ثْجَادْجِيثْ، مَاغَارْ نِيثْنِي ڭِّينْ ت س مَارَّا ؤُڒْ نْسنْ ؤُمِي نِيثْنِي أَرْزُونْ خَاسْ س مَارَّا أَرْضَا نْسنْ، ؤُ نتَّا إِجَّا إِ-ثنْ أَذْ ث أَفنْ ؤُشَا سِيذِي إِوْشَا أَسنْ ڒْهُوذْنثْ زِي مَارَّا إِغزْذِيسنْ نْسنْ.  
\v 16 إِسّْحيّذْ أَسَا ؤُڒَا ذ حنَّاسْ مَاعْكَا زِي جّهْذْ نّسْ، مَاغَارْ نتَّاثْ ثُوغَا ثڭَّا إِشْثْ ن جّْعِيفشْثْ ن ڒخْيَاڒْ إِ ثْربِّيثْ ن شْوَارْثِي. أَسَا إِشقَّارْ جّْعِيفشْثْ نّسْ، إِڒْبزْ إِ-ت ؤُشَا إِسّْشمْضْ إِ-ت غَارْ ثغْزَارْثْ ن قِيذْرُونْ. \x ◘ \xo 15:‏16 \xt 1 إِج. 15‏:‏13\x*  
\v 17 وَارْ تّْوَاحيّْذنْثْ ڒڭْعُوذِي، مَاشَا ؤُڒْ ن أَسَا ثُوغَا إِشْضَارْ \add نِيشَانْ إِ سِيذِي\add*، مَارَّا ؤُسَّانْ \add ن ثُوذَارْثْ\add* نّسْ. \x ◘ \xo 15:‏17 \xt 1 إِج. 15‏:‏14\x*  
\v 18 ثِيوْهِيبِينْ إِقدّْسنْ ن بَابَاسْ ذ مِينْ ثُوغَا إِسّْقدّسْ نتَّا \add س يِيخفْ نّسْ\add* يِيوْيِي-ث ذِي ثَادَّارْثْ ن أَربِّي، ؤُڒَا ذ ثِيوْهِيبِينْ نّسْ إِقدّْسنْ: نُّوقَارْثْ ذ وُورغْ ذ ڒقْشُوعْ \add نّغْنِي\add*. \x ◘ \xo 15:‏18 \xt 1 إِج. 15‏:‏15\x*  
\v 19 وَارْ ذِينْ إِقِّيمْ \add عَاذْ\add* ؤُمنْغِي أَڒْ أَسڭّْوَاسْ وِيسّْ خمْسَا ؤُ-ثْڒَاثِينْ ن ثْڭلْذَا ن أَسَا.   
\b  
\b  
\m  
\c 16
\s1 ڒْعَاهْذْ ن أَسَا أَكْ-ذ أَرَامْ ضِيدّْ إِ إِسْرَائِيل  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ستَّا ؤُ-ثْڒَاثِينْ ن ثْڭلْذَا ن أَسَا، إِفّغْ بَاشَا، أَجدْجِيذْ ن إِسْرَائِيل، \add إِ ؤُمنْغِي\add* أَكْ-ذ يَاهُوذَا. إِبْنَا رَامَا، حِيمَا وَارْ إِتّجِّي ؤُڒَا ذ إِجّْ أَذْ إِفّغْ غَارْ بَارَّا نِيغْ أَذْ د-إِعْقبْ غَارْ أَسَا، أَجدْجِيذْ ن يَاهُوذَا. \x ◘ \xo 16:‏1 \xt [1 إِج. 15‏:‏16‏-‏24]\x*  
\v 2 \add خنِّي\add* إِكْسِي أَسَا مَارَّا نُّوقَارْثْ ذ وُورغْ زڭْ إِخَّامنْ ن ثْخُوبَايْ زِي ثَادَّارْثْ ن سِيذِي ؤُ زِي ثَادَّارْثْ ن ؤُجدْجِيذْ ؤُشَا إِسّكّْ \add مَارَّا\add* أَيَا غَارْ بِينْهَاذَاذْ، أَجدْجِيذْ ن أَرَامْ، ونِّي ثُوغَا إِزدّْغنْ ذِي ذِيمَاشْقْ، إِنَّا:  
\v 3 ”\add أَقَا ذِينْ\add* إِجّْ ن ڒْعَاهْذْ جَارْ أَيِي ذ شكْ، جَارْ بَابَا ذ بَابَاشْ. خْزَارْ، نشّْ أَذْ أَشْ د-سّكّغْ نُّوقَارْثْ ذ وُورغْ. رُوحْ شكْ، فْسِييْ ڒْعَاهْذْ نّشْ أَكْ-ذ بَاعْشَا، أَجدْجِيذْ ن إِسْرَائِيل، مَاحنْذْ نتَّا أَذْ إِڭعّذْ أَذْ خَافِي إِڭّْوجْ.“  
\v 4 بِينْهَاذَاذْ إِسْڒَا غَارْ ؤُجدْجِيذْ أَسَا ؤُ إِسّكّْ إِكُومَانْذَارنْ ن ڒْعسْكَارْ نِّي غَارسْ \add إِدْجَانْ\add* غَارْ ثْندَّامْ ن إِسْرَائِيل. نِيثْنِيغڒْبنْ خْ عِييُونْ ذ ذَانْ ذ أَبَالْ-مَايِيمْ ؤُڒَا خْ مَارَّا ثِيندَّامْ ن ڒخْزنْ ن نَافْثَالِي.  
\v 5 ؤُمِي إِسْڒَا بَاعْشَا مَانْ أَيَا، إِمْسَارْ، أَقَا نتَّا إِسّْبدّْ ڒبْنِي ن رَامَا ؤُشَا إِسْمحْ ذِي ڒْخذْمثْ نّسْ.  
\v 6 \add خنِّي\add* يِيوِي ؤُجدْجِيذْ أَسَا مَارَّا \add أَيْثْ ن\add* يَاهُوذَا ؤُ نِيثْنِي كْسنْ إِژْرَا ن رَامَا ؤُڒَا ذ ثِيحنْيَا نّسْ إِ زِي ثُوغَا ت إِبْنَا بَاعْشَا، ؤُشَا إِبْنَا زَّايسْ جَابْعَا ذ مِيصْفَا.   
\m
\v 7 ذڭْ وُوسَّانْ نِّي يُوسَا-د ؤُمْوَاڒَاوْ حَانَانِي غَارْ أَسَا، أَجدْجِيذْ ن يَاهُوذَا، إِنَّا أَسْ: ”مِينْزِي ثتّشْڒذْ خْ ؤُجدْجِيذْ ن أَرَامْ ؤُ وَارْ إِدْجِي خْ سِيذِي، أَربِّي نّشْ، خْ ؤُيَا يَارْوڒْ ڒْعسْكَارْ ن ؤُجدْجِيذْ ن أَرَامْ زڭْ ؤُفُوسْ نّشْ. \f ◼ \fr 16:‏7 \ft \+bd ’ذڭْ وُوسَّانْ نِّي‘\+bd* - س ثْعِيبْرَانِيثْ ’ذِي ڒْوقْثْ نِّي ...‘\f*  
\v 8 مَا وَارْ ثُوغِي ؤُڒَا ذ \add أَيْثْ ن\add* كُوشْ ذ \add أَيْثْ ن\add* لِيبِييَا س يِيجّْ ن ڒْعسْكَارْ أَمقّْرَانْ أَكْ-ذ وَاطَّاسْ ن إِكَارُّوثنْ ذ إِمْنَاينْ؟ مَاشَا مِينْزِي ثتّشْڒذْ خْ سِيذِي، إِوْشَا إِ-ثنْ نتَّا ذڭْ ؤُفُوسْ نّشْ،  
\v 9 مَاغَارْ ثْحوّْمنْثْ ثِيطَّاوِينْ ن سِيذِي خْ ثَامُّورْثْ أَمْ ثكْمڒْ، حِيمَا أَذْ إِبدّْ س جّهْذْ أَكْ-ذ يِينِّي إِدْجَانْ س وُوڒْ إِمُونْ \add أَكِيذسْ\add*. ذِي مَانْ أَيَا ثڭِّيذْ ثُوبُّوهڒْيَا، مَاغَارْ زِي ڒخُّو ذ ثْسَاونْثْ أَذْ \add ذِينْ\add* إِڒِينْ إِمنْغَانْ أَكِيذكْ.“  
\v 10 أَسَا إِهَاجْ خْ ؤُمْوَاڒَاوْ ؤُشَا إِجَّا أَذْ ث ڭّنْ ذڭْ ؤُكشُّوضْ ذِي ڒحْبسْ، مَاغَارْ \add أَمُّو إِ\add* ذ أَسْ ثُوغَا إِسْخضْ خْ ؤُيَا. ذِي ڒْوقْثْ نِّي ذ إِشْثْ إِحْصَارْ أَسَا \add شَا\add* زِي ڒْڭنْسْ.   
\m
\v 11 خْزَارْ، إِمزْرُوينْ ن أَسَا، إِمزْوُورَا ذ إِنڭُّورَا، خْزَارْ، أَقَا تّْوَازمّمنْ ذڭْ وذْلِيسْ ن إِجدْجِيذنْ ن يَاهُوذَا ذ إِسْرَائِيل.  
\v 12 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثسْعَا ؤُ-ثْڒَاثِينْ ن ثْڭلْذَا نّسْ إِهْڒشْ أَسَا زڭْ إِضَارنْ. \add مَاشَا\add* ذِي ثْقِيشّثْ ن ڒهْڒَاشْ نّسْ ؤُڒَا ڒَامِي ثُوغَا إِهْڒشْ، وَارْ يَارْزُو شَا خْ سِيذِي، مَاشَا خْ إِمسْڭنْفَانْ \add وَاهَا\add*.  
\v 13 أَسَا إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. إِمُّوثْ ذڭْ ؤُسڭّْوَاسْ وِيسّْ وَاحِيثْ ؤُ-ربْعِينْ زِي ڒحْكَامثْ نّسْ.  
\v 14 نضْڒنْ ث ذڭْ ونْضڒْ  إِ ثُوغَا إِڭَّا إِ يِيخفْ نّسْ ذِي ثنْذِينْثْ ن ذَاوُوذْ ؤُشَا سَّارْسنْ ث خْ قَامَا إِ ثُوغَا ثْعمَّارْ س ڒعْطُورْ ذ مَارَّا مِينْ إِدْجَانْ ذ دَّارْبَاثْ \add إِفَارْزنْ\add* زِي مِينْ إِخدْجْضنْ س ؤُفُوسْ ن ؤُحْرَايْفِي. نِيثْنِي قّْذنْ أَسْ ثِيمسِّي ذ ثَامقّْرَانْثْ أَطَّاسْ.   
\b  
\b  
\m  
\c 17
\s1 ڒهْكَامثْ إِجهْذنْ ن يَاهُوشَافَاطْ خْ يَاهُوذَا  
\m
\v 1 مِّيسْ يَاهُوشَافَاطْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ ؤُ نتَّا إِسّجْهذْ إِخفْ نّسْ ضِيدّْ إِ إِسْرَائِيل.  
\v 2 نتَّا يِيوِي ڒْعسْكَارْ غَارْ مَارَّا ثِيندَّامْ إِفَارْينْ ن يَاهُوذَا ؤُ إِڭَّا ڒْعسْكَارَاثْ \add ن ؤُحوّسْ\add* ذِي ثمُّورْثْ ن يَاهُوذَا ؤُ ذِي ثْندَّامْ ن إِفْرَايِيمْ، ثِينِّي إِ ثُوغَا إِطّفْ بَابَاسْ أَسَا.  
\v 3 سِيذِي ثُوغَا-ث أَكْ-ذ يَاهُوشَافَاطْ، مَاغَارْ نتَّا إِضْفَارْ إِبْرِيذنْ إِمزْوُورَا ن بَابَاسْ ذَاوُوذْ، وَارْ يَارْزُو شَا خْ ’إِبَاعْلنْ‘، \f ◼ \fr 17:‏3 \ft \+bd ’إِبَاعْلنْ‘\+bd* - إِربِّيثنْ إِغْرِيبنْ، وَارْ دْجِينْ شَا ذ أَربِّي، مَاشَا ذ شّْوَاطنْ. إِسمْ ن يِيجّْ: ’بَاعْلْ‘.\f*  
\v 4 مَاشَا \add يَارْزُو\add* خْ أَربِّي ن بَابَاسْ ؤُشَا يُويُورْ ذِي ثْوصَّا نّسْ، وَارْ إِڭِّي أَمْ \add ث إِڭَّا\add* إِسْرَائِيل.  
\v 5 سِيذِي إِسّمْثنْ ثَاڭلْذَا \add ثنِّي\add* ذڭْ ؤُفُوسْ نّسْ، ؤُ مَارَّا يَاهُوذَا يِيوِي ثَارْزِيفِينْ إِ يَاهُوشَافَاطْ. إِذْوڒْ غَارسْ أَطَّاسْ ن وَاڭْڒَا ذ شَّانْ.  
\v 6 ؤُڒْ نّسْ إِتّْوَاسّمْحضْ ذڭْ إِبْرِيذنْ ن سِيذِي ؤُ نتَّا إِكّسْ ؤُڒَا ذ ڒڭْعُوذِي ذ ثْربِّينْ ن شْوَارْثِي زِي يَاهُوذَا.   
\m
\v 7 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا ن ڒحْكَامثْ نّسْ إِسّكّْ \add إِشْثْ ن ثبْرَاثْ\add* إِ ڒْحُوكَّامْ نّسْ، إِ بِينْ-حَايِيلْ، عُوبَاذْيَا، زَاكَارِييَّا، نَاثَانِييِيلْ ذ مِيخَا-يَاهُو، حِيمَا أَذْ سّْغَارنْ ذِي ثْندَّامْ ن يَاهُوذَا.  
\v 8 \add رُوحنْ\add* أَكِيذْسنْ إِلَاوِييّنْ شَامْعِييَا، نَاثَانْيَا، زَابَاذْيَا، عَسَائِيلْ، شَامِيرَامُوثْ، يُونَاثَانْ، ثُوبِييَا ذ طُوبْ-أَذُونِييَا، \add مَارَّا نِيثْنِي ذ\add* إِلَاوِييّنْ، ؤُشَا ؤُڒَا ذ إِكهَّاننْ أَلِيشَامَاعْ ذ يَاهُورَامْ \add رُوحنْ\add* أَكِيذْسنْ.  
\v 9 نِيثْنِي سّْغَارنْ ذِي يَاهُوذَا ؤُ ثُوغَا غَارْسنْ أَذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا ن سِيذِي. كِّينْ مَارَّا ثِيندَّامْ ن يَاهُوذَا ؤُشَا سّْغَارنْ ڒْڭنْسْ.  
\v 10 ثُوسَا-د أَرّهْبثْ ن سِيذِي خْ مَارَّا ثِيڭلْذِيوِينْ ن ثمُّورَا إِ-د-إِنّْضنْ إِ يَاهُوذَا، أَڒَامِي وَارْ سّكَّارنْثْ أَمنْغِي أَكْ-ذ يَاهُوشَافَاطْ.  
\v 11 زڭْ إِفِيلِيسْطِينِييّنْ إِوْينْ ثَارْزِيفِينْ ذ نُّوقَارْثْ أَمْ لْجِيزْيَا إِ يَاهُوشَافَاطْ. ؤُڒَا ذ أَعْرَابنْ سّكّنْ أَسْ ؤُدْجِي: سبْعَا-أَڒَافْ ؤُ-سبْعَا-مْيَا ن إِشَارِّييّنْ ذ سبْعَا-أَڒَافْ ؤُ-سبْعَا-مْيَا ن إِمُويَانْ.  
\v 12 أَمُّو إِ إِذْوڒْ يَاهُوشَافَاطْ يَارْنِي ذِي ڒمْغَارثْ أَڒْ طَّارْفْ ؤُشَا إِبْنَا لْقلْعَاثْ ذ ثْندَّامْ ن ڒخْزنْ ذِي يَاهُوذَا.  
\v 13 ثُوغَا غَارسْ أَطَّاسْ ن ڒْخذْمثْ ذِي ثْندَّامْ ن يَاهُوذَا، ؤُڒَا ذ إِعسْكَارِييّنْ، أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، ذِي ؤُرْشَالِيمْ.  
\v 14 ذ وَانِيثَا ذ ڒْقدّْ نْسنْ عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ. ذِي يَاهُوذَا \add أَقَا إِنَا\add* ذ ڒْقبْطَانَاثْ خْ ڒُوڒُوفْ: أَمقّْرَانْ أَذْنَا ؤُ أَكِيذسْ ثڒْثْ-مْيَاثْ-أَڒفْ ن أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ.  
\v 15 غَارْ ؤُغزْذِيسْ نّسْ ڒْقبْطَانْ يَاهُونَاثَانْ، أَكِيذسْ مِيثَاينْ ؤُ-ثْمَانْيِينْ-أَڒفْ \add ن يرْيَازنْ\add*.  
\v 16 غَارْ ؤُغزْذِيسْ نّسْ \add أَمقّْرَانْ\add* عَامَاسْيَا، مِّيسْ ن زِيكْرِي، ونِّي ثُوغَا إِسبّْڒنْ إِخفْ نّسْ س ڒْخَاضَارْ، ؤُ أَكِيذسْ مِيثَاينْ-أَڒفْ ن أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ.  
\v 17 زِي بِينْيَامِينْ \add ثُوغَا\add* أَلِييَاذَاعْ، إِجّْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، \add ذ أَمقّْرَانْ نْسنْ\add*، ؤُ أَكِيذسْ مِيثَاينْ-أَڒفْ \add ن يرْيَازنْ\add* س ڒْقوْسْ ذ ثْسدَّارْثْ \add ن ؤُعسْكَارِي\add* إِ ؤُمنْغِي.  
\v 18 غَارْ ؤُغزْذِيسْ نّسْ \add أَمقّْرَانْ\add* يَاهُوزَابَاذْ ؤُ أَكِيذسْ مْيَا ؤُ-ثْمَانْيِينْ-أَڒفْ \add ن يرْيَازنْ\add*، \add مَارَّا\add* حزّْمنْ إِ ؤُمنْغِي.  
\v 19 إِنَا ثُوغَا تّْسخَّارنْ إِ ؤُجدْجِيذْ، بْڒَا إِنِّي إِ ثُوغَا إِڭَّا ؤُجدْجِيذْ خْ ثْندَّامْ إِفَارْينْ ذِي مَارَّا يَاهُوذَا.   
\b  
\b  
\m  
\c 18
\s1 ڒْعَاهْذْ ن يَاهُوشَافَاطْ أَكْ-ذ أَخَابْ  
\m
\v 1 يَاهُوشَافَاطْ غَارسْ أَڭْڒَا ذ شَّانْ س ؤُفيّضْ، ؤُ نتَّا إِڭَّا أَذْ إِذْوڒْ ذ أَضڭّْوَاڒْ أَكْ-ذ أَخَابْ. \x ◘ \xo 18:‏1 \xt [1 إِج. 22‏:‏2‏-‏36]\x*  
\v 2 أَوَارْنِي شَا ن إِسڭّْوُوسَا إِهْوَا-د غَارْ أَخَابْ، غَارْ سَامَارْيَا. أَخَابْ إِغَارْصْ إِ وَاطَّاسْ ن وُودْجِي ذ إِفُونَاسنْ إِ ڒْڭنْسْ إِ ثُوغَا أَكِيذسْ إِدْجَانْ ؤُشَا إِغْوَا ث أَذْ إِفّغْ \add غَارْ ؤُمنْغِي\add* غَارْ رَامُوثْ-جِيلْعَاذْ.  
\v 3 أَخَابْ، أَجدْجِيذْ ن إِسْرَائِيل، إِنَّا إِ يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا: ”زعْمَا أَذْ كِيذِي ثفّْغذْ غَارْ رَامُوثْ ذِي جِيلْعَاذْ؟“ إِنَّا يَاهُوشَافَاطْ إِ ؤُجدْجِيذْ ن إِسْرَائِيل: ”نشّْ \add أَذْ إِڒِيغْ\add* أَمْ شكْ، ڒْڭنْسْ إِنُو أَمْ ڒْڭنْسْ نّشْ ؤُ نشِّينْ أَذْ كِيذكْ \add نفّغْ\add* غَارْ ؤُمنْغِي.“   
\m
\v 4 إِنَّا يَاهُوشَافَاطْ \add عَاوذْ\add* إِ ؤُجدْجِيذْ ن إِسْرَائِيل: ”سقْسَا عَافَاكْ أَسّْ-أَ خْ وَاوَاڒْ ن سِيذِي.“  
\v 5 \add خنِّي\add* إِسّْمُونْ ؤُجدْجِيذْ ن إِسْرَائِيل إِنَابِييّنْ، أَربْعَا-مْيَا ن يرْيَازنْ، إِنَّا أَسنْ: ”مَا أَذْ فّْغغْ غَارْ ؤُمنْغِي غَارْ رَامُوثْ ذِي جِيلْعَاذْ نِيغْ أَذْ ڭّغْ بْنَاقسْ؟“ نَّانْ: ”ڭعّذْ، مَاغَارْ أَربِّي أَذْ ثنْ إِوْشْ ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ.“  
\v 6 \add مَاشَا\add* يَاهُوشَافَاطْ إِنَّا: ”مَا وَارْ ذَا شَا عَاذْ أَنَابِي ن سِيذِي، مَاحنْذْ أَذْ \add نْزمَّارْ\add* أَذْ ث نسّقْسَا؟“  
\v 7 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ ن إِسْرَائِيل إِ يَاهُوشَافَاطْ: ”أَقَا ذَا عَاذْ إِجّْ ن ورْيَازْ زَّايسْ إِ نْزمَّارْ أَذْ نسّقْسَا سِيذِي. مَاشَا نشّْ شَارْهغْ ث، مَاغَارْ نتَّا وَارْ ذ أَيِي إِتّْنبَّاعمَّارْصْ س مِينْ إِصبْحنْ، مَاشَا مْغِيرْ س \add مِينْ إِدْجَانْ\add* ذ أَعفَّانْ. أَقَا ذ مِيخَا-يَاهُو، مِّيسْ ن يِيمْلَا.“ إِنَّا يَاهُوشَافَاطْ ”وَارْ تّجِّي أَجدْجِيذْ أَذْ إِسِّيوڒْ أَمنِّي!“  
\v 8 \add خنِّي\add* إِڒَاغَا-د ؤُجدْجِيذْ ن إِسْرَائِيل إِ يِيجّْ ن ؤُمْسخَّارْ أَمْشنّعْ، إِنَّا: ”ذغْيَا أَوِي-د مِيخَا-يَاهُو، مِّيسْ ن يِيمْلَا.“  
\v 9 أَجدْجِيذْ ن إِسْرَائِيل ذ يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا، قِّيمنْ \add ذِينْ\add*، كُوڒْ إِجّْ خْ ڒْعَارْشْ نّسْ، يَارْضنْ أَرُّوضْ ن إِجدْجِيذنْ، \add قِّيمنْ\add* خْ ؤُنذْرَارْ غَارْ وَاذَافْ ن ثوَّارْثْ \add ن ثنْذِينْثْ\add* ن سَامَارْيَا ؤُ مَارَّا إِنَابِييّنْ ثُوغَا تّْنبَّانْ زَّاثْ إِ وُوذمْ نْسنْ.  
\v 10 صِيذْقِييَا، مِّيسْ ن كَانْعَانَا، ثُوغَا إِڭَّا إِ يِيخفْ نّسْ أَشَّاونْ ن وُوزَّاڒْ، إِنَّا: ”أَمُّو إِ إِقَّارْ سِيذِي: ’س يِينَا إِ غَا ثسّْنُوقّْبذْ أَيْثْ ن أَرَامْ أَڒْ ثنْ غَا ثقْضِيضْ مَارَّا.‘ “  
\v 11 مَارَّا إِنَابِييّنْ ثُوغَا تّْنبَّانْ كِيفْكِيفْ، نَّانْ: ”ڭعّذْ غَارْ رَامُوثْ ذِي جِيلْعَاذْ، أَذْ ثِيڒِيذْ ثْفڒْحذْ، مِينْزِي سِيذِي أَذْ ثنْ إِوْشْ ذڭْ ؤُفُوسْ ن ؤُجدْجِيذْ.“   
\m
\v 12 أَرقَّاسْ نِّي ثُوغَا إِطّْفنْ \add أَبْرِيذْ\add* حِيمَا أَذْ إِڒَاغَا إِ مِيخَا-يَاهُو، إِسِّيوڒْ أَكِيذسْ، إِنَّا: ”خْزَارْ خنِّي، أَوَاڒنْ ن إِنَابِييّنْ \add أَخْمِي د-فّْغنْ\add* زڭْ إِجّْ ن ؤُقمُّومْ س ڒْخِيرْ غَارْ ؤُجدْجِيذْ. تّْزَاوْڭغْ أَذْ إِڒِينْ وَاوَاڒنْ نّشْ أَمْ وَاوَاڒنْ نْسنْ، إِنِي مِينْ إِصبْحنْ.“  
\v 13 \add مَاشَا\add* مِيخَا-يَاهُو إِنَّا: ”س ثِيذتّْ أَمْ إِدَّارْ سِيذِي، مِينْ ذ أَيِي غَا يِينِي أَربِّي، أَذْ ث إِنِيغْ.“  
\v 14 \add ؤُمِي\add* د-يُوسَا نتَّا غَارْ ؤُجدْجِيذْ، إِنَّا أَسْ ؤُجدْجِيذْ: ”مِيخَا، مَا أَذْ نفّغْ نشِّينْ غَارْ رَامُوثْ ذِي جِيلْعَاذْ نِيغْ أَذْ نڭّْ بْنَاقسْ؟“ إِنَّا أَسْ نتَّا: ”ڭَاعّْذمْ، أَذْ ثِيڒِيمْ ثْفڒْحمْ، مِينْزِي نِيثْنِي أَذْ تّْوَاڭّنْ ذڭْ ؤُفُوسْ نْومْ.“  
\v 15 إِنَّا أَسْ ؤُجدْجِيذْ: ”مشْحَاڒْ ن ثْوَاڒَاوِينْ إِ ذ أَيِي إِتّْخصَّا أَذْ أَشْ سّْجَادْجغْ، وَارْ ذ أَيِي ثنِّيذْ مْغِيرْ ثِيذتّْ س يِيسمْ ن سِيذِي؟“  
\v 16 \add خنِّي\add* إِنَّا وَانِيثَا: ”نشّْ ژْرِيغْ مَارَّا إِسْرَائِيل تّْوَابزّْعنْ خْ إِذُورَارْ أَمْ وُودْجِي إِ وَارْ غَارْ إِدْجِي ؤُمكْسَاوْ. إِقَّارْ سِيذِي: ’إِنَا وَارْ غَارْسنْ بُو إِسِيذِيثنْ، أجّْ \add كُوڒْ\add* أَرْيَازْ أَذْ د-إِذْوڒْ غَارْ ثَادَّارْثْ نّسْ ذِي ڒهْنَا.‘ “  
\v 17 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ ن إِسْرَائِيل إِ يَاهُوشَافَاطْ: ”مَا وَارْ ذ أَشْ نِّيغْ: ’نتَّا وَارْ خَافِي إِتّْنبَّا شَا ذِي مِينْ إِصبْحنْ، \add مَاشَا\add* مْغِيرْ س \add مِينْ إِدْجَانْ\add* ذ أَعفَّانْ‘؟“   
\m
\v 18 \add خَاسْ ؤُشَا\add* إِنَّا وَانِيثَا \add عَاوذْ\add*: ”س ؤُيَا سڒْ إِ وَاوَاڒْ ن سِيذِي. أَقَا ژْرِيغْ سِيذِي إِقِّيمْ خْ ڒْعَارْشْ نّسْ ؤُ مَارَّا ڒْعسْكَارْ ن ؤُجنَّا إِبدّْ خْ يفُوسْ نّسْ ذ ؤُزڒْمَاضْ نّسْ،  
\v 19 ؤُشَا سِيذِي إِنَّا: ’مَانْ ونْ إِ غَا إِغْوَانْ أَخَابْ، أَجدْجِيذْ ن إِسْرَائِيل، حِيمَا أَذْ إِڭعّذْ، أَذْ إِوْضَا ذِي رَامُوثْ ذِي جِيلْعَاذْ؟‘ وَا إِنَّا أَمُّو ؤُ وِينْ إِنَّا أَمُّو.  
\v 20 \add خنِّي\add* إِفّغْ-د إِجّْ ن أَرُّوحْ، إِبدّْ-د زَّاثْ إِ وُوذمْ ن سِيذِي، إِنَّا: ’نشّْ أَذْ ث غْوِيغْ.‘ إِسّقْسَا ث سِيذِي: ’س مِينْ زِي؟‘ \x ◘ \xo 18:‏20 \xt أَيُوبْ 1‏:‏6\x*  
\v 21 نتَّا إِنَّا: ’نشّْ أَذْ د-فّْغغْ ؤُ أَذْ ذوْڒغْ ذ إِجّْ ن بُوحْبڒْ إِسّْخَارِّيقنْ ذڭْ ؤُقمُّومْ ن مَارَّا إِنَابِييّنْ نّسْ.‘ ؤُ نتَّا إِنَّا: ’أَذْ ثَاوْضذْ مَاحنْذْ أَذْ ث ثغْوِيذْ. فّغْ، أڭّْ أَمنِّي!‘  
\v 22 \add خنِّي\add* ڒخُّو، خْزَارْ، سِيذِي إِوْشَا إِجّْ ن بُوحْبڒْ إِسّْخَارِّيقنْ ذڭْ ؤُفُوسْ ن إِنَابِييّنْ نّشْ ؤُ سِيذِي إِبَارّحْ خَاكْ س مِينْ إِدْجَانْ ذ أَعفَّانْ.“   
\m
\v 23 \add خنِّي\add* إِقَارّبْ-د صِيذْقِييَا، مِّيسْ ن كَانْعَانَا، غَارْ مِيخَا-يَاهُو، إِوّثْ إِ-ث غَارْ ؤُغسْمِيرْ، إِنَّا: ”خْ مَانْ أَبْرِيذْ ثُوغَا إِزمَّارْ أَذْ زَّايِي إِعْذُو أَرُّوحْ ن سِيذِي حِيمَا أَذْ كِيذكْ إِسِّيوڒْ؟“  
\v 24 إِنَّا مِيخَا-يَاهُو: ”خْزَارْ، أَذْ ث ثْژَارذْ ذڭْ وَاسّْ نِّي ذِي غَا ثمْهَافذْ زڭْ \add إِجّْ ن\add* وخَّامْ غَارْ وخَّامْ نّغْنِي حِيمَا أَذْ ثسّْنُوفَّارذْ إِخفْ نّشْ.“ \x ◘ \xo 18:‏24 \xt 1 إِج. 20‏:‏30؛ 1 إِج. 22‏:‏25\x*  
\v 25 أَجدْجِيذْ ن إِسْرَائِيل إِنَّا: ”طّْفمْ مِيخَا-يَاهُو، نذْهمْ عَاوذْ ث غَارْ أَمُونْ، أَمقّْرَانْ ن ثنْذِينْثْ، ؤُ غَارْ يُووَاشْ، مِّيسْ ن ؤُجدْجِيذْ،  
\v 26 أَذْ ثِينِيمْ: ’أَمُّو إِ إِقَّارْ ؤُجدْجِيذْ: نْضَارمْ وَا ذِي ڒحْبسْ ؤُ سشّمْ ث س وغْرُومْ ن ڒحْصَارثْ ؤُ س وَامَانْ ن ڒحْصَارثْ أَڒْ غَا ذوْڒغْ ذِي ڒهْنَا.‘ “  
\v 27 \add خَاسْ ؤُشَا\add* إِنَّا مِيخَا-يَاهُو: ”مَاڒَا ثْعقْبذْ-د \add شَا ن وَاسّْ\add* ذِي ڒهْنَا، خنِّي سِيذِي وَارْ خَافِي إِسِّيوڒْ!“ ؤُشَا إِنَّا \add عَاوذْ\add*: ”سْڒمْ-د أَ ڒڭْنُوسْ، مَارَّا \add كنِّيوْ\add*!“   
\m
\v 28 أَوَارْنِي أَسْ إِفّغْ-د ؤُجدْجِيذْ ن إِسْرَائِيل أَكْ-ذ يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا، غَارْ رَامُوثْ ذِي جِيلْعَاذْ.  
\v 29 إِنَّا ؤُجدْجِيذْ ن إِسْرَائِيل إِ يَاهُوشَافَاطْ: ”نشّْ أَذْ بدّْڒغْ أَرُّوضْ، \add خنِّي\add* أَذْ د-فّْغغْ غَارْ ؤُمنْغِي. \add مَاشَا\add* شكْ \add ثْزمَّارذْ\add* أَذْ ثْيَارْضذْ أَرُّوضْ نّشْ!“ أَجدْجِيذْ ن إِسْرَائِيل إِڭَّا أَرُّوضْ وَارْ إِدْجِي نّسْ ؤُشَا فّْغنْ-د غَارْ ؤُمنْغِي.  
\v 30 أَجدْجِيذْ ن أَرَامْ ثُوغَا يُومُورْ إِمقّْرَاننْ ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add* نِّي غَارسْ \add إِدْجَانْ\add*، إِنَّا: ”إِتّْخصَّا أَومْ وَارْ ثتّْمنْغِيمْ شَا أَكْ-ذ ؤُمقّْرَانْ نِيغْ أَكْ-ذ ؤُمژْيَانْ، مْغِيرْ أَكْ-ذ ؤُجدْجِيذْ ن إِسْرَائِيل!“  
\v 31 ؤُمِي إِمقّْرَاننْ ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add* ژْرِينْ يَاهُوشَافَاطْ، إِمْسَارْ، أَقَا نِيثْنِي نَّانْ: ”أَقَا ذ وَا، أَجدْجِيذْ ن إِسْرَائِيل!“ نِيثْنِي نّْضنْ أَسْ حِيمَا أَكِيذسْ مّنْغنْ، مَاشَا يَاهُوشَافَاطْ إِسْغُويْ، ؤُشَا سِيذِي إِوْشَا أَسْ أَفُوسْ ؤُ أَربِّي إِسّْحيّذْ إِ-ثنْ خَاسْ.  
\v 32 ؤُمِي ژْرِينْ إِمقّْرَاننْ ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add*، أَقَا نتَّا ثُوغَا وَارْ إِدْجِي ذ أَجدْجِيذْ ن إِسْرَائِيل، إِمْسَارْ، أَقَا ذوْڒنْ-د خْ وبْرِيذْ نْسنْ، وَارْ ث أَردّْفنْ عَاذْ.   
\m
\v 33 \add خنِّي\add* إِعيّنْ إِجّْ ن ورْيَازْ ڒْقوْسْ س ڒْبَاڒْ نّسْ ذ أَشمْڒَاڒْ ؤُشَا إِڒْقفْ \add فْڒِيثْشَا\add* أَجدْجِيذْ ن إِسْرَائِيل جَارْ وَاوَاضْ ن إِغَادْجنْ ن وَارُّوضْ نّسْ ن وُوزَّاڒْ. \add ڒخْذنِّي\add* إِنَّا وَانِيثَا إِ ونِّي إِندّْهنْ أَكَارُّو: ”قْڒبْ أَفُوسْ نّشْ، سُوفّغْ أَيِي-د زِي ڒْعسْكَارْ، مَاغَارْ أَقَا يزْمغْ.“  
\v 34 ذڭْ وَاسّْ نِّي إِذْوڒْ ؤُمنْغِي إِوْعَارْ أَطَّاسْ. إِقِّيمْ ؤُجدْجِيذْ ن إِسْرَائِيل إِبدّْ ذڭْ ؤُكَارُّو أَڒْ ثَامذِّيثْ \add ذڭْ ؤُمنْغِي\add* أَكْ-ذ أَيْثْ ن أَرَامْ، إِمُّوثْ غَارْ ڒْوقْثْ ن ؤُغدْجَايْ ن ثْفُوشْثْ.   
\b  
\b  
\m  
\c 19
\s1 يَاهُوشَافَاطْ ذ ؤُمْوَاڒَاوْ  
\m
\v 1 إِعْقبْ-د يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا، غَارْ ثَادَّارْثْ نّسْ ذِي ؤُرْشَالِيمْ ذِي ڒهْنَا.  
\v 2 يَاهُو، مِّيسْ ن حَانَانِي، أَمْوَاڒَاوْ، إِفّغْ-د غَارسْ حِيمَا أَذْ ث إِڒْقَا، إِنَّا إِ ؤُجدْجِيذْ يَاهُوشَافَاطْ: ”مَا شكْ ثڭِّيذْ ثْوِيزَا إِ ؤُعفَّانْ ؤُ أَذْ ثخْسذْ إِنِّي إِعِيفّنْ سِيذِي؟ أَمُّو إِ خَاكْ د-يُوسَا ؤُذُوقّزْ ن وغْضَابْ زِي زَّاثْ ن وُوذمْ ن سِيذِي.  
\v 3 وَاخَّا أَمنِّي إِتّْوَافْ ذَايكْ مِينْ إِصبْحنْ، مَاغَارْ ثكّْسذْ ثِيربِّينْ ن شْوَارْثِي زِي ثمُّورْثْ ؤُشَا ثسّْوجْذذْ ؤُڒْ نّشْ إِ ثَارزُّوثْ خْ أَربِّي.“   
\m
\v 4 يَاهُوشَافَاطْ إِقِّيمْ إِزدّغْ ذِي ؤُرْشَالِيمْ ؤُشَا إِفّغْ عَاوذْ جَارْ ڒْڭنْسْ، زِي بِئرْ-سبْعَا غَارْ إِذُورَارْ ن إِفْرَايِيمْ، ؤُشَا يَارَّا إِ-ثنْ أَذْ د-ذوْڒنْ غَارْ سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ.  
\v 5 نتَّا يَاڒقّمْ ڒْقُوضَاثْ ذِي ثمُّورْثْ، ذِي مَارَّا ثِيندَّامْ إِفَارْينْ ن يَاهُوذَا، زِي ثنْذِينْثْ أَڒْ ثَانْذِينْثْ.  
\v 6 نتَّا إِنَّا إِ ڒْقُوضَاثْ: ”خْزَارمْ مِينْ غَا ثڭّمْ، مَاغَارْ وَارْ ثْحكّْممْ إِ إِوْذَانْ، مَاشَا إِ سِيذِي ؤُ نتَّا أَقَا إِحْضَارْ أَكِيذْومْ ذڭْ وحْكَامْ.  
\v 7 \add خنِّي\add* ڒخُّو، أَذْ خَاومْ ثِيڒِي ثِيڭّْوُوذِي ن سِيذِي. حْضَامْ ؤُ ڭّمْ ث، مَاغَارْ غَارْ سِيذِي، أَربِّي نّغْ، وَارْ إِدْجِي ڒْغشّْ، نتَّا وَارْ إِتّڭّْ س وُوذْمَاونْ ؤُ وَارْ إِكسِّي ثِيرْزِيفِينْ.“   
\m
\v 8 ؤُمِي د -عقْبنْ غَارْ ؤُرْشَالِيمْ، إِڭَّا يَاهُوشَافَاطْ ذِي ؤُرْشَالِيمْ عَاوذْ \add شَا\add* ن إِلَاوِييّنْ ذ إِكهَّاننْ ذ إِزدْجِيفنْ ن \add ثُوذْرِينْ ن\add* إِبَابَاثنْ ن إِسْرَائِيل إِ ؤُذبَّارْ ن ڒحْكَامْ ن سِيذِي ؤُ إِ دّْعَاوِي.  
\v 9 نتَّا يُومُورْ إِ-ثنْ، إِنَّا: ”ڭّمْ س ثِيڭّْوُوذِي ن سِيذِي، س ڒَامَانْ ؤُ س يِيجّْ ن وُوڒْ \add نِيشَانْ\add* إِمُونْ.  
\v 10 غَارْ كُوڒْ دّعْوثْ إِ ذ أَومْ إِ ذ غَا يَاوْينْ أَيْثْمَاثْومْ نِّي إِزدّْغنْ ذِي ثْندَّامْ نْسنْ، جَارْ إِذَامّنْ ذ إِذَامّنْ ؤُ جَارْ شَّارِيعَا ذ ڒُومُورْ ذ ثْوصَّا ذ لْفَارَايِيضْ، إِتّْخصَّا أَذْ أَسنْ ثْعڒْممْ، مَاحنْذْ وَارْ خَاومْ سَّاربُّونْ دّنْبْ زَّاثْ إِ سِيذِي، أَڒَامِي خَاومْ د غَا إِوْضَا ؤُذُوقّزْ ذ أَمقّْرَانْ ن وغْضَابْ ؤُ خْ أَيْثْمَاثْومْ. ڭّمْ أَمنِّي، أَڒَامِي وَارْ ثسَّاربُّومْ دّنْبْ خْ يِيخفْ نْومْ.  
\v 11 خْزَارمْ، أَمَارْيَا ذ أَكهَّانْ أَمقّْرَانْ إِ خَاومْ إِدْجَانْ ذِي مَارَّا دّعْوثْ ن سِيذِي، ؤُ زَابَاذْيَا، مِّيسْ ن إِسْمَاعِيلْ، ڒْحَاكمْ خْ ثَادَّارْثْ ن يَاهُوذَا، أَقَا-ث خْ كُوڒْ دّعْوثْ ن ؤُجدْجِيذْ. ؤُڒَا ذ إِمحْضَاينْ، إِلَاوِييّنْ، \add أَقَا أَثنْ ذِينْ\add* زَّاثْ إِ وُوذمْ نْومْ. إِڒِيمْ ذ إِرْيَازنْ ؤُ ڭّمْ \add ث\add*، ؤُشَا سِيذِي أَذْ يِيڒِي أَكْ-ذ ونِّي إِصڒْحنْ.“   
\b  
\b  
\m  
\c 20
\s1 أَغلّبْ ن يَاهُوشَافَاطْ خْ مُوآبَ ذ عَامُّونْ  
\m
\v 1 أَوَارْنِي ؤُيَا إِمْسَارْ، أَقَا أَيْثْ ن مُوآبَ ذ أَيْثْ ن عَامُّونْ، ذ \add إِنّغْنِي\add* أَكِيذْسنْ زڭْ إِمَاعُونِييّنْ ؤُسِينْ-د مَاحنْذْ أَذْ مّنْغنْ أَكْ-ذ يَاهُوشَافَاطْ.  
\v 2 ؤُسِينْ-د \add إِرقَّاسنْ\add*، عَاوْذنْ إِ يَاهُوشَافَاطْ، نَّانْ: ”أَقَا أَطَّاسْ ن ڒْغَاشِي ؤُسِينْ-د حِيمَا أَذْ كِيذكْ مّنْغنْ زڭْ ؤُجمَّاضِينْ ن ڒبْحَارْ، زِي أَرَامْ. خْزَارْ، نِيثْنِي ذِي حَاصُّونْ-ثَامَارْ، إِخْسْ أَذْ يِينِي عَايْنْ-جَاذِي.“   
\m
\v 3 يَاهُوشَافَاطْ إِڭّْوذْ ؤُشَا إِنْضَارْ ثِيطَّاوِينْ نّسْ غَارْ سِيذِي. نتَّا إِجَّا أَذْ بَارّْحنْ س ؤُژُومِّي ذِي مَارَّا يَاهُوذَا.  
\v 4 سّْمُوننْ \add أَيْثْ ن\add* يَاهُوذَا مَاحنْذْ أَذْ أَرْزُونْ ثْوِيزَا ن سِيذِي. نِيثْنِي ؤُسِينْ-د ؤُڒَا زِي مَارَّا ثِيندَّامْ ن يَاهُوذَا، حِيمَا أَذْ أَرْزُونْ خْ سِيذِي.  
\v 5 إِبدّْ يَاهُوشَافَاطْ ذڭْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* ن يَاهُوذَا ذ ؤُرْشَالِيمْ، ذِي ثَادَّارْثْ ن سِيذِي، زَّاثْ إِ ڒمْرَاحْ ن جْذِيذْ، إِنَّا:   
\m
\v 6 ”\add أَ\add* سِيذِي، أَربِّي ن ڒجْذُوذْ نّغْ، مَا شكْ وَارْ ثدْجِيذْ شَا ذ أَربِّي ن إِجنْوَانْ ذ ڒْحَاكمْ خْ مَارَّا ثِيڭلْذِيوِينْ ن ڒڭْنُوسْ؟ ذڭْ ؤُفُوسْ نّشْ \add إِمَّارْسْ\add* جّهْذْ ذ ثْزمَّارْ، أَڒَامِي وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ إِقِّيمْ إِبدّْ زَّاثكْ.  
\v 7 \add أَ\add*، أَربِّي نّغْ، مَا وَارْ ثُوژِّيڒذْ شَا خْ إِمزْذَاغْ ن ثمُّورْثْ-أَ زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ نّشْ إِسْرَائِيل ؤُشَا ثوْشِيذْ \add ثَامُّورْثْ\add* إِ ڒبْذَا إِ زَّارِيعثْ ن إِبْرَاهِيمْ، \add أَمدُّوكّڒْ\add* نّشْ إِعِيزّنْ؟  
\v 8 نِيثْنِي قِّيمنْ زدّْغنْ ذَايسْ ؤُشَا بْنَانْ ذَايسْ إِشْثْ ن زَّاوشْثْ إِقدّْسنْ إِ شكْ، إِ يِيسمْ نّشْ، ؤُشَا نَّانْ:  
\v 9 ’مَاڒَا إِڒْقفْ أَنغْ شَا ن ڒْغَارْ، \add أَخْمِي\add* سِّيفْ ن ڒحْكَامْ نِيغْ طَّاعُونْ نِيغْ ڒَاژْ، خنِّي أَذْ نْبدّْ زَّاثْ إِ ثَادَّارْثْ-أَ ؤُ زَّاثْ إِ وُوذمْ نّشْ، مَاغَارْ إِسمْ نّشْ أَقَا-ث ذِي ثَادَّارْثْ-أَ. أَذْ خَاكْ د-نْڒَاغَا زِي ڒحْصَارثْ نّغْ ؤُشَا \add خنِّي\add* شكْ أَذْ \add غَارْنغْ\add* ثسْڒذْ ؤُ أَذْ \add أَنغْ\add* ثسّْنجْمذْ.  
\v 10 ؤُشَا ڒخُّو، خْزَارْ، أَيْثْ ن عَامُّونْ ذ \add أَيْثْ ن\add* مُوآبَ ذ يِينِّي زڭْ إِذُورَارْ ن سَاعِيرْ - إِنِّي إِ ؤُمِي وَارْ ثجِّيذْ شَا أَيْثْ ن إِسْرَائِيل أَذْ غَارْسنْ د-أَذْفنْ \add غَارْ ثمُّورْثْ نْسنْ\add*، ؤُمِي د-ؤُسِينْ زِي ثمُّورْثْ ن مِيصْرَا، مِينْزِي كِّينْ أَسنْ-د \add زڭْ وبْرِيذْ نّغْنِي\add* ؤُ وَارْ ثنْ أَردّْدْجنْ،  
\v 11 خْزَارمْ، نِيثْنِي خْسنْ أَذْ أَنغْ خدْجْصنْ ؤُشَا ؤُسِينْ-د حِيمَا أَذْ أَنغْ سُّوفّْغنْ زِي ثسْغَارْثْ نّشْ إِ ذ أَنغْ ثوْشِيذْ ذ ڒْوَارْثْ.  
\v 12 \add أَ\add*، أَربِّي نّغْ، مَا شكْ وَارْ خَاسنْ ثْحكّْمذْ شَا؟ مَاغَارْ نشِّينْ وَارْ خَاسنْ نْزمَّارْ خْ ڒْغَاشِي-يَا أَمقّْرَانْ وَانِيثَا إِ غَارْنغْ د-إِفّْغنْ ؤُ وَارْ نسِّينْ مِينْ غَا نڭّْ، مَاشَا \add أَقَا نَارَّا-د\add* ثِيطَّاوِينْ نّغْ غَاركْ.“   
\b  
\m
\v 13 مَارَّا \add أَيْثْ ن\add* يَاهُوذَا بدّنْ زَّاثْ إِ وُوذمْ ن سِيذِي، ؤُڒَا ذ إِحنْجِيرنْ إِمژْيَانِينْ نْسنْ ذ ثمْغَارِينْ نْسنْ ذ إِحنْجِيرنْ نْسنْ.  
\v 14 ؤُشَا إِهْوَا-د أَرُّوحْ ن سِيذِي \add ذِينْ\add* ذِي ڒْوسْثْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add* خْ يَاحْزِييِيلْ، مِّيسْ ن زَاكَارِييَّا، مِّيسْ ن بَانَايَا، مِّيسْ ن يَاعِييِيلْ، مِّيسْ ن ؤُلَاوِي مَاتَّانْيَا، زڭْ إِحنْجِيرنْ ن أَسَافْ.  
\v 15 نتَّا إِنَّا: ”سْڒمْ-د غَارِي، مَارَّا \add أَيْثْ ن\add* يَاهُوذَا ؤُڒَا ذ كنِّيوْ، إِمزْذَاغْ ن ؤُرْشَالِيمْ، ؤُ شكْ، \add أَ،\add* أَجدْجِيذْ يَاهُوشَافَاطْ! أَمُّو إِ ذ أَومْ إِقَّارْ سِيذِي: ’وَارْ تّڭّْوْذمْ شَا، وَارْ تّْنخْڒِيعمْ شَا زِي ڒْغَاشِي-يَا أَمقّْرَانْ وَانِيثَا، مِينْزِي أَمنْغِي وَارْ إِدْجِي س ؤُفُوسْ نّغْ، مَاشَا س ؤُفُوسْ ن أَربِّي.  
\v 16 هْوَامْ غَارْسنْ ثِيوشَّا. خْزَارْ، نِيثْنِي أَذْ ڭعّْذنْ زِي ثْسَاونْثْ ن صِيصْ، ؤُ كنِّيوْ أَذْ خَاسنْ ثْخشّمْ غَارْ ؤُنڭَّارْ ن ثغْزُورْثْ زَّاثْ إِ ڒخْڒَا ن يَارُووِيلْ.  
\v 17 كنِّيوْ \add مَاشَا\add* وَارْ ثتّْمنْغِيمْ شَا. كَّارمْ، \add قِّيممْ\add* ثْبدّمْ ؤُ خْزَارمْ، أَسنْجمْ ن سِيذِي \add أَذْ يِيڒِي\add* أَكِيذْومْ، \add أَ\add* يَاهُوذَا ذ ؤُرْشَالِيمْ! وَارْ تّڭّْوْذمْ شَا ؤُ وَارْ تّْنخْڒِيعمْ. ثِيوشَّا فّْغمْ إِ ؤُمْسَاڭَارْ أَكِيذْسنْ، مِينْزِي سِيذِي أَقَا-ث أَكِيذْومْ.‘ “  
\v 18 \add خنِّي\add* يُوضَارْ يَاهُوشَافَاطْ س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ، ؤُ مَارَّا \add أَيْثْ ن\add* يَاهُوذَا ذ مَارَّا إِمزْذَاغْ ن ؤُرْشَالِيمْ وْضَانْ \add خْ ثمُّورْثْ\add* زَّاثْ إِ وُوذمْ ن سِيذِي حِيمَا أَذْ بنْذْقنْ إِ سِيذِي.  
\v 19 كَّارنْ إِلَاوِييّنْ زڭْ أَيْثْ ن قُوهَاثْ ؤُ زڭْ أَيْثْ ن قُورَاحْ حِيمَا أَذْ سّْعُودْجَانْ سِيذِي، أَربِّي ن إِسْرَائِيل، س إِشْثْ ن ثْمِيجَّا ثجْهذْ أَطَّاسْ.   
\b  
\m
\v 20 ثِيوشَّا زِيشْ كَّارنْ ؤُشَا فّْغنْ غَارْ ڒخْڒَا ن ثَاقُوعَا. غَارْ وُوفُّوغْ نْسنْ إِبدّْ-د يَاهُوشَافَاطْ \add ذِينْ\add*، إِنَّا: ”سْڒمْ-د غَارِي، \add أَ\add* يَاهُوذَا، ذ كنِّيوْ، إِمزْذَاغْ ن ؤُرْشَالِيمْ. أَمْنمْ ذِي سِيذِي، أَربِّي نْومْ، \add خنِّي\add* أَذْ ثِيڒِيمْ ذِي ڒَامَانْ. أَمْنمْ زِي إِنَابِييّنْ، \add خنِّي\add* أَذْ ثْفڒْحمْ.“  
\v 21 نتَّا إِمْشَاوَارْ أَكْ-ذ ڒْڭنْسْ ؤُشَا إِسّْبدّْ إِمذْيَازنْ زَّاثْ إِ سِيذِي ذ يِينِّي ذ أَسْ إِ غَا إِصبّْحنْ أَشوَّاضْ ن ؤُمْقدَّاسْ، أَمْ غَا يُويُورنْ زَّاثْ إِ وُوذمْ ن \add يرْيَازنْ\add* إِ إِحزّْمنْ س ڒسْنَاحْ، أَذْ إِنِينْ: ”قَاذَامْ سِيذِي، مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ \add ثتّْغِيمَا\add* إِ ڒبْذَا!“  
\v 22 ذِي ڒْوقْثْ ڒَامِي بْذَانْ نِيثْنِي س ؤُسْڒِيوْڒوْ ذ ؤُصبّحْ، إِڭَّا سِيذِي ڒفْخُوخْ خْ أَيْثْ ن عَامُّونْ ذ مُوآبَ ؤُ خْ \add ينِّي\add* إِ ثُوغَا د-إِفّْغنْ ضِيدّْ إِ يَاهُوذَا زڭْ إِذُورَارْ ن سَاعِيرْ، ؤُشَا تّْوَاغلّْبنْ نِيثْنِي.   
\m
\v 23 أَيْثْ ن عَامُّونْ ذ \add أَيْثْ ن\add* مُوآبَ كَّارنْ خْ إِمزْذَاغْ ن إِذُورَارْ ن سَاعِيرْ، حِيمَا أَذْ ثنْ سّْهلّْكنْ ؤُ أَذْ ثنْ أَردّْدْجنْ. ؤُمِي قْضَانْ نِيثْنِي خْ إِمزْذَاغْ ن سَاعِيرْ، سّْهلّْكنْ إِجّْ ونّغْنِي.  
\v 24 \add ؤُمِي\add* د-يِيوِيضْ يَاهُوذَا غَارْ صُّومْعثْ ن ؤُحطُّو ذِي ڒخْڒَا، نْضَارنْ ثَامُوغْڒِي نْسنْ أَوَانِي أَسنْ خْ ڒْغَاشِي، ؤُ خْزَارْ، \add ژْرِينْ\add* مْغِيرْ ڒْخشْبَاثْ ثُوغَا وْضَانْثْ خْ ثمُّورْثْ، ؤُڒَا ذ إِجّْ وَارْ إِنْجِيمْ.  
\v 25 يَاهُوشَافَاطْ ذ ڒْڭنْسْ نّسْ ؤُسِينْ-د حِيمَا أَذْ طّْفنْ ثَاكشَّاضْثْ نْسنْ ؤُشَا ؤُفِينْ غَارْسنْ أَطَّاسْ ن سّڒْعثْ ذ ڒْخشْبَاثْ ذ ڒقْشُوعْ إِغْڒَانْ ؤُشَا كّْسنْ \add عْڒَامْ كُوڒْ زَّايسْ\add* إِ يِيخفْ نْسنْ، أَڒَامِي وَارْ زمَّارنْ أَذْ ث أَرْبُونْ. تّْكشَّاضنْ ثْڒَاثَا ن وُوسَّانْ، مَاغَارْ \add ثُوغَا\add* ذِينْ أَطَّاسْ.   
\b  
\m
\v 26 ذڭْ وَاسّْ وِيسّْ أَربْعَا مُوننْ نِيثْنِي ذِي ڒوْضَا ن ثغْزُورْثْ ن لْبَارَاكَا، مِينْزِي ذِينْ بَارْكنْ سِيذِي. خْ ؤُيَا ڭِّينْ أَسْ إِ ومْشَانْ نِّي: ثَاغْزُورْثْ ن لْبَارَاكَا، غَارْ إِ ڒخُّو.  
\v 27 أَوَارْنِي ؤُيَا ذوْڒنْ-د مَارَّا إِرْيَازنْ ن يَاهُوذَا ذ ؤُرْشَالِيمْ. يُويُورْ يَاهُوشَافَاطْ غَارْ زَّاثْ، حِيمَا أَذْعقْبنْ غَارْ ؤُرْشَالِيمْ \add شُّورنْ\add* س ڒفْرَاحثْ، مَاغَارْ سِيذِي ثُوغَا إِسّْفَارْحْ إِ-ثنْ خْ ڒْعذْيَانْ نْسنْ.  
\v 28 أَمْ \add تِّيرَارنْ س\add* لهَارْپَاثْ ذ ڒْڭَامْبْرِييَاثْ ذ ڒبْوَاقْ ؤُسِينْ-د غَارْ ؤُرْشَالِيمْ، غَارْ ثَادَّارْثْ ن سِيذِي.  
\v 29 ثُوغَا ثِيڭّْوُوذِي ن أَربِّي ثڒْقفْ مَارَّا ثِيڭلْذِيوِينْ ن ثمُّورَا ؤُمِي سْڒِينْثْ، أَقَا سِيذِي إِمّْنغْ أَكْ-ذ ڒْعذْيَانْ ن إِسْرَائِيل.  
\v 30 ثُوفَا ثْڭلْذِيثْ ن يَاهُوشَافَاطْ ڒْهُوذْنثْ ؤُشَا أَربِّي نّسْ إِوْشَا أَسْ ڒهْنَا زِي مَارَّا إِغزْذِيسنْ.   
\b  
\m  
\s1 ڒحْكَامثْ ن ؤُجدْجِيذْ يَاهُوشَافَاثْ  
\m
\v 31 أَمُّو إِ إِحْكمْ يَاهُوشَافَاطْ خْ يَاهُوذَا. \add ثُوغَا\add* غَارسْ خمْسَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا، ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ خمْسَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ عَازُوبَا، يدْجِيسْ ن شِيلْحِي. \x ◘ \xo 20:‏31 \xt [1 إِج. 22‏:‏41‏-‏51]\x*  
\v 32 نتَّا إِضْفَارْ إِبْرِيذنْ ن بَابَاسْ أَسَا، وَارْ خَاسنْ إِحيّذْ شَا ؤُ نتَّا إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي.  
\v 33 مْغِيرْ ڒڭْعُوذِي وَارْ تّْوَاكّْسنْثْ، مَاغَارْ ڒْڭنْسْ وَارْ ثُوغِي عَاذْ يَارَّا ؤُڒْ نّسْ غَارْ أَربِّي ن ڒجْذُوذْ نْسنْ.  
\v 34 مِينْ إِقِّيمنْ ن إِمزْرُوينْ ن يَاهُوشَافَاطْ، إِمزْوُورَا ذ إِنڭُّورَا، خْزَارْ، أَقَا مَانْ أَيَا \add مَارَّا\add* إِتّْوَازمّمْ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن يَاهُو، مِّيسْ ن حَانَانِي، إِنِّي إِڭَّا أَذْ تّْوَازمّمنْ ذڭْ وذْلِيسْ ن إِجدْجِيذنْ ن إِسْرَائِيل.   
\m
\v 35 أَوَارْنِي ؤُيَا إِڭَّا يَاهُوشَافَاطْ إِجّْ ن ڒْعَاهْذْ أَكْ-ذ أَخَازْيَا، أَجدْجِيذْ ن إِسْرَائِيل، ونِّي إِڭِّينْ ثُوعفّْنَا أَطَّاسْ ذِي \add مَارَّا مِينْ\add* ثُوغَا إِڭَّا.  
\v 36 نتَّا إِقّنْ أَكِيذسْ إِجّْ ن ڒْعَاهْذْ، حِيمَا أَذْ ڭّنْ إِغَارُّوبَا نِّي إِ غَا إِندّْهنْ غَارْ ثَارْشِيشْ. نِيثْنِي بْنَانْ إِغَارُّوبَا \add نِّي\add* ذِي عِيصْيُونْ-جَابَارْ.  
\v 37 \add مَاشَا\add* أَلِيعَازَارْ، مِّيسْ ن ذُوذَاوَاهُو زِي مَارِيشَا، إِتّْنبَّا خْ يَاهُوشَافَاطْ، إِنَّا: ”مِينْزِي ثقّْنذْ إِجّْ ن ڒْعَاهْذْ أَكْ-ذ أَخَازِييَا، أَقَا سِيذِي يَارْژَا ڒخْذَايمْ نّشْ.“ \add أَمُّو\add* إِمْسَارْ أَقَا تّْوَارْژنْ إِغَارُّوبَا أَڒَامِي وَارْ زمَّارنْ أَذْ نذْهنْ غَارْ ثَارْشِيشْ.   
\b  
\b  
\m  
\c 21
\s1 ڒحْكَامثْ إِعفّْننْ ن يُورَامْ  
\m
\v 1 يَاهُوشَافَاطْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن ذَاوُوذْ. مِّيسْ يَاهُورَامْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. \x ◘ \xo 21:‏1 \xt [2 إِج. 8‏:‏16‏-‏24]\x*  
\v 2 أَيْثْمَاسْ، إِحنْجِيرنْ ن يَاهُوشَافَاطْ \add ثُوغَا أَثنْ ذ\add* عَازَارْيَا، يَاحِييِيلْ، زَاكَارِييَّا، عَازَارْيَاهُو، مِيخَايِيلْ ذ شَافَاطْيَا. إِنَا مَارَّا \add ثُوغَا أَثنْ ذ\add* إِحنْجِيرنْ ن يَاهُوشَافَاطْ، أَجدْجِيذْ ن إِسْرَائِيل.  
\v 3 بَابَاثْسنْ إِوْشَا أَسنْ أَطَّاسْ ن ثرْزِيفِينْ ن نُّوقَارْثْ ذ وُورغْ ذ ڒقْشُوعْ إِغْڒَانْ ؤُڒَا ذ ثِيندَّامْ إِفَارْينْ ذِي يَاهُوذَا، مَاشَا ثَاڭلْذِيثْ إِوْشَا إِ-ت إِ يَاهُورَامْ، مَاغَارْ وَانِيثَا \add ثُوغَا\add* ذ أَمنْزُو.   
\m
\v 4 \add ؤُمِي\add* إِكَّارْ-د يَاهُورَامْ خْ ثْڭلْذِيثْ ن بَابَاسْ ؤُشَا إِمْنعْ ذِي ثِيزمَّارْ نّسْ، إِنْغَا مَارَّا أَيْثْمَاسْ س سِّيفْ، ؤُڒَا ذ شَا ن ڒْحُوكَّامْ ن إِسْرَائِيل.  
\v 5 يَاهُورَامْ \add ثُوغَا غَارسْ\add* ثْنَاينْ ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثْمنْيَا ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ.  
\v 6 نتَّا يُويُورْ ذڭْ وبْرِيذْ ن إِجدْجِيذنْ ن إِسْرَائِيل، أَمْ مَامّشْ ثُوغَا ثڭَّا ثَادَّارْثْ ن أَخَابْ، مَاغَارْ يدْجِيسْ ن أَخَابْ ثذْوڒْ ذ ثَامْغَارْثْ نّسْ. نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي.  
\v 7 \add مَاشَا\add* سِيذِي وَارْ إِخْسْ أَذْ يَاردّدْجْ ذَاوُوذْ ذِي طّْوعْ ن ڒْعَاهْذْ إِ إِڭَّا أَكْ-ذ ذَاوُوذْ، ؤُشَا ؤُڒَا ؤُمِي \add ذ أَسْ\add* ثُوغَا إِنَّا، أَقَا أَذْ أَسْ إِوْشْ ڒبْذَا إِجّْ ن ڒفْنَارْ زَّاثْ إِ ثِيطَّاوِينْ نّسْ، إِ نتَّا ؤُ إِ إِحنْجِيرنْ نّسْ.   
\m
\v 8 ذڭْ وُوسَّانْ نّسْ إِخْثُوتّڒْ إِذُومْ س ؤُغوّغْ زِي سَاذُو إِفَاسّنْ ن يَاهُوذَا، ؤُشَا ڭِّينْ إِجّْ ن ؤُجدْجِيذْ خْ يِيخفْ نْسنْ.  
\v 9 إِعْذُو يَاهُورَامْ أَكْ-ذ مَارَّا إِمقّْرَاننْ نّسْ ذ مَارَّا إِكَارُّوثنْ نّسْ \add ن ؤُمنْغِي\add*. أَقَا إِكَّارْ س دْجِيڒثْ ؤُ إِغْڒبْ خْ أَيْثْ ن إِذُومْ إِنِّي ثُوغَا إِ ذ أَسْ د-إِنّْضنْ، إِ نتَّا ؤُ إِ إِمقّْرَاننْ ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add*.  
\v 10 \add وَاخَّا أَمنِّي\add* خْثُوتّْڒنْ \add أَيْثْ ن\add* إِذُومْ س ؤُغوّغْ زِي جَارْ إِفَاسّنْ ن يَاهُوذَا، أَڒْ أَسّْ-أَ. ذِي ڒْوقْثْ نِّي بعْذَا إِغوّغْ ؤُڒَا ذ لِيبْنَا، مَاغَارْ ثُوغَا يَاهُوذَا إِحيّذْ خْ سِيذِي، أَربِّي ن ڒجْذُوذْ نّسْ.   
\m
\v 11 إِڭَّا يَاهُورَامْ ؤُڒَا ذ ڒڭْعُوذِي خْ إِذُورَارْ ن يَاهُوذَا. نتَّا يَارَّا إِمزْذَاغْ ن ؤُرْشَالِيمْ أَذْ سّْفسْذنْ إِخفْ نْسنْ \add س إِربِّيثنْ نّغْنِي\add*، \add وَاهْ،\add* ثُوغَا إِعَارْنْ يَاهُوذَا غَارْ مَانْ أَيَا.  
\v 12 ثِيوضْ-د غَارسْ إِشْثْ ن ثبْرَاثْ ن ؤُنَابِي إِلِييَا، ثقَّارْ: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن بَابَاشْ ذَاوُوذْ: ’مَاغَارْ وَارْ ثُويُورذْ خْ إِبْرِيذنْ ن بَابَاشْ يَاهُوشَافَاطْ ؤُ خْ إِبْرِيذنْ ن أَسَا، أَجدْجِيذْ ن يَاهُوذَا،  
\v 13 مَاشَا ثُويُورذْ خْ إِبْرِيذنْ ن إِجدْجِيذنْ ن إِسْرَائِيل، ؤُشَا ثَارِّيذْ يَاهُوذَا ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ أَذْ سّْفسْذنْ إِخفْ نْسنْ \add س إِربِّيثنْ نّغْنِي\add*، ذڭْ وبْرِيذْ ن فَارْقْ-شْغڒْ ن ثَادَّارْثْ ن أَخَابْ، ؤُ مِينْزِي شكْ ثنْغِيذْ ؤُڒَا ذ أَيْثْمَاشْ زِي ثَادَّارْثْ ن بَابَاشْ، إِنِّي ثُوغَا إِشْنَانْ خَاكْ،  
\v 14 خْزَارْ، \add خْ ؤُينِّي\add* سِيذِي أَذْ شكْ إِڒْقفْ س إِشْثْ ن ثشْثِي ذ ثَامقّْرَانْثْ جَارْ ڒْڭنْسْ نّشْ ذ إِحنْجِيرنْ نّشْ ذ ثمْغَارِينْ نّشْ ذ مَارَّا أَڭْڒَا نّشْ.  
\v 15 شكْ سِيمَانْثْ نّشْ أَذْ ثوْضِيذْ ذڭْ إِجّْ ن ڒهْڒَاشْ ن ثكْرِيشْثْ إِقسْحنْ، أَڒْ د غَا ثفّغْ \add عَاذْ\add* ثكْرِيشْثْ نّشْ غَارْ بَارَّا زِي سِّيبّثْ ن ڒهْڒَاشْ إِ إِتّْذُومَانْ.‘“   
\m
\v 16 سِيذِي إِسّهْوڒْ خْ يَاهُورَامْ أَرُّوحْ نْ إِفِيلِيسْطِينِييّنْ ذ وعْرَابنْ، إِنِّي إِزذْغنْ خْ ؤُغزْذِيسْ ن \add أَيْثْ ن\add* كُوشْ.  
\v 17 نِيثْنِي ڭعّْذنْ غَارْ يَاهُوذَا، ؤُذْفنْ غَارْ ثَامُّورْثْ ؤُ كْسِينْ مَارَّا أَڭْڒَا نِّي \add إِدْجَانْ\add* ذِي ثَادَّارْثْ ن ؤُجدْجِيذْ، ؤُڒَا ذ إِحنْجِيرنْ نّسْ ذ ثمْغَارِينْ نّسْ، أَڒَامِي وَارْ ذ أَسْ إِقِّيمْ مْغِيرْ يَاهُويَاحَازْ، أَمَاژُوژْ ن إِحنْجِيرنْ نّسْ.  
\v 18 أَوَارْنِي أَيَا إِوْثَا إِ-ث سِيذِي س يِيجّْ ن ڒهْڒَاشْ وَارْ إِزمَّارْ أَذْ \add زَّايسْ\add* إِڭّنْفَا.  
\v 19 ؤُمِي \add ثُوغَا نتَّا إِهْڒشْ أَمُّو\add* أَسّْ إِضْفَارْ ؤُمَاسْ، ؤُشَا ثعْذُو ڒْوقْثْ أَڒَامِي عْذُونْ ثْنَاينْ ن إِسڭّْوُوسَا، إِمْسَارْ، أَقَا ثَاكْرِيشْثْ نّسْ ثفّغْ-د غَارْ بَارَّا، ؤُ نتَّا إِمُّوثْ س ڒحْڒِيقْ ذ أَمقّْرَانْ. ڒْڭنْسْ نّسْ وَارْ ذ أَسْ إِسَّارْغْ شَا ثْمسِّي أَمْ \add ڭِّينْ\add* ثِيمسِّي إِ ڒجْذُوذْ نّسْ.  
\v 20 نتَّا \add ثُوغَا\add* غَارسْ ثْنَاينْ ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثْمنْيَا ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. نتَّا إِفْنَا، وَارْ خَاسْ إِنْذبْ حذْ. نضْڒنْ ث ذِي ثنْذِينْثْ ن ذَاوُوذْ، \add مَاشَا\add* وَارْ إِدْجِي ذڭْ إِمضْڒَانْ ن إِجدْجِيذنْ.   
\b  
\b  
\m  
\c 22
\s1 أَجدْجِيذْ أَخَازْيَا إِتّْوَانغْ س ؤُفُوسْ ن يَاهُو  
\m
\v 1 إِمزْذَاغْ ن ؤُرْشَالِيمْ ڭِّينْ أَخَازْيَا، مِّيسْ أَمَاژُوژْ، ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ، مَاغَارْ مَارَّا أَيْثْمَاسْ إِمقّْرَاننْ ثُوغَا تّْوَانْغنْ زڭْ إِشْثْ ن بَانْذِييَّا إِ ثُوغَا د-ثُوذفْ أَكْ-ذ وعْرَابنْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ. \add أَمُّو إِ\add* إِذْوڒْ أَخَازْيَا، مِّيسْ ن يَاهُورَامْ، ذ أَجدْجِيذْ ن يَاهُوذَا. \x ◘ \xo 22:‏1 \xt [2 إِج. 8‏:‏25‏-‏29؛ 9‏:‏27‏-‏29]\x*  
\v 2 أَخَازْيَا \add ثُوغَا\add* غَارسْ ثْنَاينْ ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا، ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ إِجّْ ن ؤُسڭّْوَاسْ ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ عَاثَالْيَا، يدْجِيسْ ن عُومْرِي.  
\v 3 نتَّا يُويُورْ ذڭْ إِبْرِيذنْ ن ثَادَّارْثْ ن أَخَابْ، مَاغَارْ يمَّاسْ ذ ثَامْشَاوَارْثْ نّسْ ذِي \add مَارَّا\add* ثُوعفّْنَا إِ إِڭَّا.  
\v 4 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَمْ ثَادَّارْثْ ن أَخَابْ، مَاغَارْ أَوَارْنِي إِ ڒْموْثْ ن بَابَاسْ ثُوغَا \add إِنِّي ن ثَادَّارْثْ ن أَخَابْ\add* ذ إِمْشَاوَارنْ نّسْ أَڒَامِي إِكَّا خْ ؤُزدْجِيفْ.   
\m
\v 5 نتَّا إِضْفَارْ شّْوَارْ نْسنْ ؤُشَا إِفّغْ أَكْ-ذ يُورَامْ، مِّيسْ ن أَخَابْ، أَجدْجِيذْ ن إِسْرَائِيل، إِ ؤُمنْغِي أَكْ-ذ حَازَايِيلْ، أَجدْجِيذْ ن أَرَامْ، غَارْ رَامُوثْ ذِي جِيلْعَاذْ ؤُشَا أَيْثْ ن أَرَامْغڒْبنْ خْ يُورَامْ.  
\v 6 \add خنِّي\add* يَارڭّْوحْ مَاحنْذْ أَذْ يَارْزُو ذِي يَازْرَاعِيلْ أَڭنْفُو زڭْ إِيزِّيمنْ نِّي إِ ذ أَسْ ثُوغَا ڭِّينْ \add أَيْثْ ن\add* أَرَامْ ؤُمِي إِمّْنغْ ذِي رَامُوثْ أَكْ-ذ ؤُجدْجِيذْ نْسنْ، حَازَايِيلْ، أَجدْجِيذْ ن أَرَامْ. إِهْوَا-د عَازَارْيَا، مِّيسْ ن يَاهُورَامْ، أَجدْجِيذْ ن يَاهُوذَا، \add غَارْ ذِينْ\add*، حِيمَا أَذْ إِسِّيجّْ خْ يُورَامْ، مِّيسْ ن أَخَابْ، ذِي يَازْرَاعِيلْ، ؤُمِي ثُوغَا إِهْڒشْ.  
\v 7 أَردّدْجْ ن أَخَازْيَا ثُوغَا زِي أَربِّي ؤُمِي د-يُوسَا غَارْ يُورَامْ. ؤُمِي د-يِيوضْ \add ذِينْ\add*، إِفّغْ أَكْ-ذ يُورَامْ غَارْ يَاهُو، مِّيسْ ن نِيمْشِي، ونِّي ثُوغَا إِذْهنْ سِيذِي، مَاحنْذْ أَذْ إِقْضَا خْ ثَادَّارْثْ ن أَخَابْ.  
\v 8 ؤُمِي إِقْضَا يَاهُو ڒْحُوكْمْ خْ ثَادَّارْثْ ن أَخَابْ، إِمْسَارْ، أَقَا يُوفَا ڒْحُوكَّامْ ن يَاهُوذَا ذ إِحنْجِيرنْ ن أَيْثْمَاسْ ن أَخَازْيَا، \add إِنِّي\add* إِ ثُوغَا إِتّْسخَّارنْ إِ أَخَازْيَا، ؤُشَا إِنْغَا إِ-ثنْ.  
\v 9 \add خنِّي\add* يَارْزُو خْ أَخَازْيَا. نِيثْنِي طّْفنْ ث أَمْ ثُوغَا إِنُّوفَّارْ ذِي سَامَارْيَا ؤُشَا إِوْينْ ث غَارْ يَاهُو. نْغِينْ ث ؤُ نضْڒنْ ث، مِينْزِي نَّانْ: ”نتَّا ذ مِّيسْ ن يَاهُوشَافَاطْ، ونِّي يَارزُّونْ خْ سِيذِي س مَارَّا ؤُڒْ نّسْ.“ \add أَمُّو\add* وَارْ إِقِّيمْ إِ ثَادَّارْثْ ن أَخَازْيَا ؤُڒَا ذ إِجّْ ونِّي ذِي إِدْجَا جّهْذْ حِيمَا أَذْ إِحْكمْ أَمْ ؤُجدْجِيذْ.   
\b  
\m  
\s1 يُووَاشْ وَارْ إِتّْوَانغْ س إِفَاسّنْ ن أَثَالْيَا  
\m
\v 10 \add ؤُمِي\add* عَاثَالْيَا، يمَّاسْ ن أَخَازْيَا ثژْرَا، أَقَا مِّيسْ إِمُّوثْ، ثكَّارْ، ثثحَّا مَارَّا ثَارْوَا ن ؤُجدْجِيذْ ن ثَادَّارْثْ ن يَاهُوذَا. \f ◼ \fr 22:‏10 \ft \+bd ’ثَارْوَا‘\+bd* - س ثْعِيبْرَانِيثْ ’زَّارِيعثْ‘.\f*  \x ◘ \xo 22:‏10 \xt [2 إِج. 11‏:‏1‏-‏3]\x*  
\v 11 \add مَاشَا\add* يَاهُوشِيبَا، يدْجِيسْ ن ؤُجدْجِيذْ، ثكْسِي يُووَاشْ، مِّيسْ ن أَخَازْيَا، ؤُشَا ثخْضفْ إِ-ث زِي جَارْ إِحنْجِيرنْ ن ؤُجدْجِيذْ نِّي إِتّْوَانْغنْ، ؤُشَا ثسِّيذفْ إِ-ث أَكْ-ذ ثنِّي ث إِسُّوطُوضنْ ذڭْ وخَّامْ ن ثَاسُّوثْ. \add أَمُّو\add* إِ ثڭَّا يَاهُوشِيبَا، يدْجِيسْ ن ؤُجدْجِيذْ يَاهُورَامْ، ثَامْغَارْثْ ن ؤُكهَّانْ يَاهُويَاذَاعْ - مَاغَارْ نتَّاثْ ذ ؤُتْشْمَاسْ ن أَخَازْيَا - ثسّْنُوفَّارْ إِ-ث إِ عَاثَالْيَا ؤُ ثَانِيثَا وَارْ ث ثنْغِي شَا.  
\v 12 ستَّا ن إِسڭّْوُوسَا إِقِّيمْ إِنُّوفَّارْ غَارْسنْ ذِي ثَادَّارْثْ ن أَربِّي ؤُ ثُوغَا عَاثَالْيَا ثْحكّمْ خْ ثمُّورْثْ.   
\b  
\b  
\m  
\c 23
\s1 يُووَاشْ ذ أَجدْجِيذْ أَمژْيَانْ خْ ثْڭلْذِيثْ ن يَاهُوذَا  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا إِسّجْهذْ يَاهُويَاذَاعْ إِخفْ نّسْ ؤُشَا إِڭَّا إِجّْ ن ڒْعَاهْذْ \add جْمِيعْ\add* أَكْ-ذ إِمقّْرَاننْ خْ مْيَا، عَازَارْيَا، مِّيسْ ن يرُوهَامْ ذ إِسْمَاعِيلْ، مِّيسْ ن يُوحَانَانْ، ذ عَازَارْيَا، مِّيسْ ن عُوبِيذْ، ذ مَاعَاسِييَا، مِّيسْ ن عَاذَايَا، ذ إِلِيشَافَاطْ، مِّيسْ ن زِيكْرِي. \x ◘ \xo 23:‏1 \xt [2 إِج. 11‏:‏4‏-‏20]\x*  
\v 2 نِيثْنِي كِّينْ خْ \add ثمُّورْثْ\add* ن يَاهُوذَا، سّْمُوننْ إِلَاوِييّنْ زِي ثْندَّامْ ن يَاهُوذَا ؤُڒَا ذ إِزدْجِيفنْ \add ن ثُوذْرِينْ\add* ن إِبَابَاثنْ ن إِسْرَائِيل ؤُشَا ؤُسِينْ-د غَارْ ؤُرْشَالِيمْ.  
\v 3 مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* إِڭَّا إِجّْ ن ڒْعَاهْذْ أَكْ-ذ ؤُجدْجِيذْ ذِي ثَادَّارْثْ ن أَربِّي ؤُ نتَّا إِنَّا أَسنْ: ”خْزَارْ، مِّيسْ ن ؤُجدْجِيذْ أَذْ إِذْوڒْ ذ أَجدْجِيذْ، أَمْ مَامّشْ إِ ث إِنَّا سِيذِي خْ إِحنْجِيرنْ ن ذَاوُوذْ!“  
\v 4 يُومُورْ إِ-ثنْ، إِنَّا: ”ذ مَانْ أَيَا إِ غَا ثڭّمْ: إِشْثْ ن تُّوڒُوثْ نْومْ، إِنِّي ن إِكهَّاننْ ذ إِلَاوِييّنْ إِ غَا يَاذْفنْ ذڭْ \add وَاسّْ ن\add* سّبْثْ، أَذْعسّنْ غَارْ ثوُّورَا.  
\v 5 إِشْثْ ن تُّوڒُوثْ \add أَذْ ثْبدّْ\add* غَارْ ثَادَّارْثْ ن ؤُجدْجِيذْ ؤُ إِشْثْ ن تُّوڒُوثْ غَارْ ثوَّارْثْ ن ذْسَاسْ ؤُ مَارَّا ڒْڭنْسْ \add أَذْ إِبدّْ\add* ذِي ڒمْرَاحَاثْ ن ثَادَّارْثْ ن سِيذِي.  
\v 6 ؤُڒَا ذ إِجّْ وَارْ إِتِّيذفْ غَارْ ثَادَّارْثْ ن سِيذِي، مْغِيرْ إِكهَّاننْ ذ \add أَيْثْ ن\add* لَاوِي نِّي إِتّْسخَّارنْ، أَذْ أَذْفنْ، مَاغَارْ نِيثْنِي ذ إِمْقدَّاسنْ ؤُ مَارَّا ڒْڭنْسْ أَذْ إِحْضَا مِينْ إِتّْخصَّانْ أَذْ إِتّْوَاحْضَا إِ سِيذِي.  
\v 7 أَيْثْ ن لَاوِي أَذْ قُووَّارنْ إِ ؤُجدْجِيذْ، \add كُوڒْ\add* أَرْيَازْ س ڒسْنَاحْ نّسْ ذڭْ ؤُفُوسْ نّسْ، ؤُ ونِّي إِ غَا يَارْزُونْ أَذْ يَاذفْ غَارْ ثَادَّارْثْ أَذْ إِتّْوَانغْ. كنِّيوْ أَذْ ثقِّيمنْ أَكْ-ذ ؤُجدْجِيذْ غَارْ ثْوَاسِيثْ نّسْ ؤُ غَارْ وُوفُّوغْ نّسْ. \x ◘ \xo 23:‏7 \xt أَسَا. 14‏:‏1، 4، 5\x*   
\m
\v 8 أَيْثْ ن لَاوِي ذ مَارَّا يَاهُوذَا ڭِّينْ أَمْ مَامّشْ مَارَّا مِينْ \add إِ ذ أَسنْ\add* يُومُورْ ؤُكهَّانْ يَاهُويَاذَاعْ، ؤُشَا إِوْينْ كُوڒْ إِجّْ \add زَّايْسنْ\add* إِرْيَازنْ نّسْ نِّي يُوذْفنْ ذِي سّبْثْ، ؤُڒَا ذ يِينِّي د-إِفّْغنْ ذِي سّبْثْ، مَاغَارْ أَكهَّانْ يَاهُويَاذَاعْ وَارْ إِوْشِي ڒعْوَاشَارْ إِ ثرْبِيعِينْ.  
\v 9 أَكهَّانْ يَاهُويَاذَاعْ إِوْشَا إِ إِمقّْرَاننْ خْ مْيَا لَانْسَاثْ ذ ثْسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* إِقسْحنْ إِ ثُوغَا إِدْجَانْ ن ؤُجدْجِيذْ ذَاوُوذْ، ثِينِّي \add ثُوغَا إِدْجَانْ\add* ذِي ثَادَّارْثْ ن أَربِّي.  
\v 10 إِسّْبدّْ ڒْڭنْسْ، كُوڒْ إِجّْ \add س\add* لَانْسَا نّسْ ذڭْ ؤُفُوسْ، زڭْ ؤُغزْذِيسْ أَفُوسِي ن ثَادَّارْثْ أَڒْ أَغزْذِيسْ أَزڒْمَاضْ ن ثَادَّارْثْ، غَارْ ؤُعَالْطَارْ ؤُ غَارْ ثَادَّارْثْ، \add أَمُّو إِ\add* د-قُووَّارنْ نِيثْنِي إِ ؤُجدْجِيذْ.  
\v 11 نِيثْنِي سُّوفّْغنْ-د مِّيسْ ن ؤُجدْجِيذْ غَارْ بَارَّا ؤُشَا ڭِّينْ أَسْ تَّاجْ \add ن وعْزَاڒْ\add* ؤُشَا وْشِينْ أَسْ شّْهَاذثْ. \add أَمُّو\add* إِ ث ڭِّينْ ذ أَجدْجِيذْ، ؤُشَا يَاهُويَاذَاعْ ذ إِحنْجِيرنْ نّسْ ذهْننْ ث، نَّانْ: ”ثُوذَارْثْ إِ ؤُجدْجِيذْ!“   
\m
\v 12 \add ؤُمِي\add* ثسْڒَا عَاثَالْيَا ڒْحسّْ ن ڒْڭنْسْ إِ د-يُوسِينْ تَّازّْڒنْ غَارْ ذِينْ ؤُشَا سّمْغَارنْ أَجدْجِيذْ، ثُوذفْ-د غَارْ ڒْڭنْسْ ذِي ثَادَّارْثْ ن سِيذِي.  
\v 13 ثژْرَا، ؤُ خْزَارْ، أَجدْجِيذْ إِبدّْ غَارْ ؤُپِيلَارْ غَارْ وَاذَافْ، ؤُ إِمقّْرَاننْ ذ \add إِنِّي إِتّْسُوضنْ ذِي\add* ڒبْوَاقْ \add بدّنْ\add* غَارْ ؤُجدْجِيذْ. مَارَّا ڒْڭنْسْ ن ثمُّورْثْ إِفْرَاحْ ؤُ إِسُوضْ ذِي ڒبْوَاقْ. \add ؤُڒَا ذ\add* إِمذْيَازنْ أَكْ-ذ دُّوزَانَاثْ ن لْمُوسِيقَا إِنِّي إِسّْننْ مَامّشْ غَا صبّْحنْ \add بدّنْ ذِينْ\add*. \add خنِّي\add* ثْشَارّڭْ عَاثَالْيَا أَرُّوضْ نّسْ ؤُشَا ثسْغُويْ: ”ثَامنْزِيوْثْ، ثَامنْزِيوْثْ!“   
\m
\v 14 \add مَاشَا\add* يُومُورْ ؤُكهَّانْ يَاهُويَاذَاعْ إِ إِمقّْرَاننْ ن مْيَا، إِنِّي إِ ثُوغَا إِدْجَانْ خْ ڒْعسْكَارْ، إِنَّا أَسنْ: ”سُوفّْغمْ ت-إِ-د جَارْ إِسذِّييّنْ \add ن ڒْعسْكَارْ\add* غَارْ بَارَّا ؤُشَا نْغمْ س سِّيفْ وِي ت غَا إِضْفَارنْ.“ مَاغَارْ أَكهَّانْ ثُوغَا إِنَّا: ”وَارْ ت نقّمْ ذِي ثَادَّارْثْ ن سِيذِي!“  
\v 15 نِيثْنِي سَّارْسنْ خَاسْ إِفَاسّنْ ؤُشَا \add ؤُمِي\add* إِوْضنْ غَارْ وَاذَافْ ن ثوَّارْثْ ن إِيْسَانْ \add غَارْ\add* ثَادَّارْثْ ن ؤُجدْجِيذْ، نْغِينْ ت ذِينِّي.   
\m
\v 16 إِڭَّا يَاهُويَاذَاعْ إِجّْ ن ڒْعَاهْذْ جَارْ أَسْ-د ذ مَارَّا ڒْڭنْسْ ذ ؤُجدْجِيذْ، حِيمَا أَذْ إِڒِينْ ذ إِجّْ ن ڒْڭنْسْ إِ سِيذِي.  
\v 17 \add خَاسْ ؤُشَا\add* يُوذفْ مَارَّا ڒْڭنْسْ غَارْ زَّاوشْثْ ن بَاعَالْ ؤُ هذْمنْ ت. إِعَالْطَارنْ نّسْ ذ ڒخْيَاڒَاثْ نّسْ أَرْژِينْ ثنْ قَاعْ. ؤُ نِيثْنِي نْغِينْ مَاتَّانْ، أَكهَّانْ ن بَاعَالْ، زَّاثْ إِ إِعَالْطَارنْ.  
\v 18 إِڭَّا يَاهُويَاذَاعْ ثَاسخَّارْثْ ذِي ثَادَّارْثْ ن سِيذِي ذڭْ ؤُفُوسْ ن إِكهَّاننْ ن \add أَيْثْ ن\add* لَاوِي نِّي ثُوغَا إِبْضَا ذَاوُوذْ \add ذِي ثرْبِيعِينْ\add* إِ ثَادَّارْثْ ن سِيذِي، حِيمَا أَذْ قدّْمنْ ثِيغَارْصَا ن وشْمَاضْ ن سِيذِي أَمْ مَامّشْ ثُورَا ذِي شَّارِيعَا ن مُوسَا، س ڒفْرَاحثْ ذ إِزْڒَانْ، أَمْ ث إِوصَّا ذَاوُوذْ.  
\v 19 نتَّا إِسّْبدّْ إِعسَّاسنْ خْ ثوُّورَا ن ثَادَّارْثْ ن سِيذِي، مَاحنْذْ ؤُڒَا ذ إِجّْ مَامّشْ مَا إِڭَّا مَاڒَا إِخْمجْ، وَارْ ذِينْ إِتِّيذفْ شَا.  
\v 20 نتَّا يِيوِي إِمقّْرَاننْ خْ مْيَا، ذ أَيْثْ ن جّهْذْ، ذ أَيْثْ ن بُو-صُّولْطَا جَارْ ڒْڭنْسْ ذ مَارَّا ڒْڭنْسْ ن ثمُّورْثْ ؤُشَا إِسّهْوَا أَجدْجِيذْ زِي ثَادَّارْثْ ن سِيذِي، ؤُ نِيثْنِي ؤُذْفنْ غَارْ ثَادَّارْثْ ن ؤُجدْجِيذْ زِي ثوَّارْثْ يُوعْڒَانْ ؤُشَا سّْغِيمنْ أَجدْجِيذْ خْ ڒْعَارْشْ ن ثْڭلْذِيثْ.  
\v 21 مَارَّا ڒْڭنْسْ ن ثمُّورْثْ إِفَارْحْ ؤُ ثَانْذِينْثْ ثذْوڒْ ثَارْسَا، أَوَارْنِي ؤُمِي نْغِينْ عَاثَالْيَا س سِّيفْ.   
\b  
\b  
\m  
\c 24
\s1 ڒحْكَامثْ ن يُووَاشْ خْ يَاهُوذَا  
\m
\v 1 يُووَاشْ \add ثُوغَا\add* غَارسْ سبْعَا ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ أَربْعِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ ضِيبْيَا زِي بِئرْ-سبْعَا. \x ◘ \xo 24:‏1 \xt [2 إِج. 12‏:‏1‏-‏22]\x*  
\v 2 يُووَاشْ إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، مَارَّا ؤُسَّانْ إِ ثُوغَا أَكهَّانْ يَاهُويَاذَاعْ إِدَّارْ.  
\v 3 يَاهُويَاذَاعْ يِيوِي أَسْ ثْنَاينْ ن ثمْغَارِينْ ؤُ نتَّا إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.  
\v 4 أَوَارْنِي ؤُيَا ثُوغَا إِنْوَا يُووَاشْ س وُوڒْ، حِيمَا أَذْ إِعْذڒْ ثَادَّارْثْ ن سِيذِي.  
\v 5 إِسّْمُونْ إِكهَّاننْ ذ إِلَاوِييّنْ، إِنَّا أَسنْ: ”كّمْ خْ ثْندَّامْ ن يَاهُوذَا ؤُ يَارْومْ إِجّْ ن ڒْقدّْ ن نُّوقَارْثْ ذِي كُوڒْ أَسڭّْوَاسْ زِي مَارَّا إِسْرَائِيل، حِيمَا أَذْ ثْعذْڒمْ ثَادَّارْثْ ن أَربِّي. بْذَامْ ذغْيَا س ؤُيَا!“ \add مَاشَا\add* إِلَاوِييّنْ وَارْ قدْجْقنْ شَا.   
\m
\v 6 أَجدْجِيذْ إِڒَاغَا إِ ؤُزدْجِيفْ يَاهُويَاذَاعْ، إِنَّا أَسْ: ”مَايمِّي وَارْ ثسّقْسِيذْ إِلَاوِييّنْ خْ مَامّشْ د-إِفّغْ وسْمُونِي زِي يَاهُوذَا ذ ؤُرْشَالِيمْ ن ثوْهِيبْثْ ن ؤُسْڭعّذْ ن مُوسَا، أَمْسخَّارْ ن سِيذِي، ؤُڒَا ن وڭْرَاوْ ن إِسْرَائِيل ذِي طّْوعْ ن ؤُقِيضُونْ ن شّْهَاذثْ؟  
\v 7 أَقَا إِحنْجِيرنْ ن عَاثَالْيَا ثَاعفَّانْثْ أَرْژِينْ ثَادَّارْثْ ن أَربِّي ؤُشَا سّْمُوطِّيينْ مَارَّا ڒقْشُوعْ إِقدّْسنْ ن ثَادَّارْثْ ن سِيذِي غَارْ ’إِبَاعْلنْ‘.“   
\m
\v 8 أَجدْجِيذْ يُومُورْ، حِيمَا أَذْ ڭّنْ إِشْثْ ن ثْصنْذُوقْثْ ؤُ نِيثْنِي سَّارْسنْ ت بَارَّا غَارْ ثوَّارْثْ ن ثَادَّارْثْ ن سِيذِي.  
\v 9 خنِّي ڒَاغَانْ ذِي يَاهُوذَا ذ ؤُرْشَالِيمْ، حِيمَا أَذْ يَارْونْ إِ سِيذِي ثَاوْهِيبْثْ ن ؤُسْڭعّذْ نِّي إِڭَّا مُوسَا، أَمْسخَّارْ ن أَربِّي، خْ إِسْرَائِيل ذِي ڒخْڒَا.  
\v 10 مَارَّا إِمقّْرَاننْ ذ مَارَّا ڒْڭنْسْ ثُوغَا فَارْحنْ ؤُ نِيثْنِي إِوْينْ-د \add ثِيوْهِيبِينْ\add* ؤُشَا نْضَارنْ ثنْثْ ذِي ثْصنْذُوقْثْ أَڒَامِي ثشُّورْ.  
\v 11 ذِي ڒْوقْثْ ؤُمِي د-سِّيذْفنْ ثَاسنْذُوقْثْ خْ ڒُومُورْ ن ؤُجدْجِيذْ س ؤُفُوسْ ن إِلَاوِييّنْ ؤُشَا ژْرِينْ أَقَا \add ذَايسْ\add* أَطَّاسْ ن نُّوقَارْثْ، إِمْسَارْ، أَقَا يُوسَا-د ؤُمَارِيرْ ن ؤُجدْجِيذْ ذ ؤُوقَّافْ ن ؤُكهَّانْ أَمقّْرَانْ ؤُشَا سّخْوَانْ نِيثْنِي ثَاسنْذُوقْثْ، سّْڭعّْذنْ ت ؤُ إِوْينْ ت \add عَاوذْ\add* غَارْ ومْشَانْ نّسْ. أَمُّو إِ ڭِّينْ نِيثْنِي أَسّْ إِضْفَارْ ؤُمَاسْ ؤُشَا سّْمُوننْ-د أَطَّاسْ ن نُّوقَارْثْ.   
\m
\v 12 أَجدْجِيذْ ذ يَاهُويَاذَاعْ وْشِينْ أَيَا \add خنِّي\add* إِ إِمْضبَّارنْ ن ڒْخذْمثْ ذِي طّْوعْ ن ثَادَّارْثْ ن سِيذِي. نِيثْنِي شْرَانْ إِسُويْذَاينْ ذ إِنقَّاشنْ ن ؤُكشُّوضْ، حِيمَا أَذْعذْڒنْ ثَادَّارْثْ ن سِيذِي، ؤُڒَا ذ إِمْزِيڒنْ ن وُوزَّاڒْ ذ نّْحَاسْ، حِيمَا \add ؤُڒَا ذ نِيثْنِي\add* أَذْعذْڒنْ ثَادَّارْثْ ن سِيذِي.  
\v 13 إِخدَّامنْ ثُوغَا خدّْمنْ ڒبْذَا ؤُ سَاذُو ؤُفُوسْ نْسنْ ثُويُورْ ڒْخذْمثْ نِيشَانْ غَارْ زَّاثْ. نِيثْنِي أَرِّينْ ثَادَّارْثْ ن أَربِّي أَمْ مَامّشْ ت ثُوغَا أَمزْوَارُو ؤُ أَرْنِينْ ذِي ڒمْثنْ نّسْ.  
\v 14 ڒَامِي كمّْڒنْ نِيثْنِي \add ڒْْخذْمثْ\add*، إِوْينْ مِينْ إِقِّيمنْ ن نُّوقَارْثْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ؤُ زَّاثْ إِ يَاهُويَاذَاعْ ؤُشَا إِڭَّا زَّايسْ ڒقْشُوعْ إِ ثَادَّارْثْ ن سِيذِي، ڒقْشُوعْ إِ ثْسخَّارْثْ ؤُ إِ ثوْهِيبِينْ ن وشْمَاضْ، ثِيغنْجَايِينْ ذ ڒقْشُوعْ ن وُورغْ ذ نُّوقَارْثْ. مَارَّا ؤُسَّانْ نِّي \add إِكَّا\add* يَاهُويَاذَاعْ \add إِدَّارْ\add*، تَّاوْينْ ڒبْذَا ثِيغَارْصَا ن وشْمَاضْ إِ ثَادَّارْثْ ن سِيذِي.   
\m
\v 15 يَاهُويَاذَاعْ إِوْسَارْ ؤُ ؤُزَانْ غَارسْ وُوسَّانْ \add ن ثُوذَارْثْ\add*، ؤُشَا إِمُّوثْ. نتَّا ثُوغَا غَارسْ مْيَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا ؤُمِي إِمُّوثْ.  
\v 16 نضْڒنْ ث جَارْ إِجدْجِيذنْ ذِي ثنْذِينْثْ ن ذَاوُوذْ، مَاغَارْ ثُوغَا إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي إِسْرَائِيل، أَمْ إِ أَربِّي، أَمْ إِ ثَادَّارْثْ نّسْ.   
\m
\v 17 أَوَارْنِي إِ ڒْموْثْ ن يَاهُويَاذَاعْ ؤُسِينْ-د ڒْحُوكَّامْ ن يَاهُوذَا ؤُشَا بنْذْقنْ إِ ؤُجدْجِيذْ، ؤُشَا إِسْڒَا غَارْسنْ ؤُجدْجِيذْ.  
\v 18 نِيثْنِي سمْحنْ ذِي ثَادَّارْثْ ن سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ، ؤُشَا سخَّارنْ إِ ثْربِّينْ ن شْوَارْثِي ذ ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ. \add خنِّي\add* إِذْوڒْ ؤُذُوقّزْ ذ أَمقّْرَانْ \add ن وغْضَابْ\add* خْ يَاهُوذَا ؤُ خْ ؤُرْشَالِيمْ ذِي سِّيبّثْ ن ڒْمُوعْصِييّثْ نْسنْ.  
\v 19 نتَّا إِسّكّْ جَارْ أَسنْ إِنَابِييّنْ، حِيمَا أَذْ ثنْ يَارَّا أَذْعقْبنْ غَارْ سِيذِي. نِيثْنِي شهْذنْ خَاسنْ، مَاشَا وَارْ ذ أَسنْ سْڒِينْ شَا. \f ◼ \fr 24:‏19 \ft \+bd ’نتَّا‘\+bd* - وَانِيثَا ذ سِيذِي.\f*  
\v 20 أَرُّوحْ ن أَربِّي إِهْوَا-د خْ زَاكَارِييَّا، مِّيسْ ن ؤُكهَّانْ يَاهُويَاذَاعْ. نتَّا إِبدّْ خْ إِجّْ ن دّْرُوجْ زَّاثْ إِ ڒْڭنْسْ، إِنَّا أَسنْ: ”أَمُّو إِ إِقَّارْ أَربِّي: ’مَايمِّي ثتّْعدَّامْ خْ ڒُومُورَاثْ ن سِيذِي؟ \add أَمُّو\add* وَارْ ثتّفْڒِيحمْ شَا. مِينْزِي ثْحيّْذمْ خْ سِيذِي، أَذْ خَاومْ إِحيّذْ نتَّا.‘ “  
\v 21 نِيثْنِي ڭِّينْ خَاسْ إِشْثْ ن ثْمعْمُوتْشْ ؤُ حجَّارنْ ث خْ ڒُومُورْ ن ؤُجدْجِيذْ ذِي ڒمْرَاحْ ن ثَادَّارْثْ ن سِيذِي.  
\v 22 أَجدْجِيذْ يُووَاشْ وَارْ إِخَارّصْ ذِي ثْمخْسِيوْثْ إِشوَّارنْ، ثنِّي إِ ذ أَسْ ثُوغَا إِسّْشنْ يَاهُويَاذَاعْ، بَابَاسْ \add ن زَاكَارِييَّا\add*، ؤُشَا \add يُووَاشْ\add* إِنْغَا مِّيسْ \add ن يَاهُويَاذَاعْ\add*. ؤُمِي إِمُّوثْ، إِنَّا زكَارِييَا: ”سِيذِي أَذْ ث إِژَارْ، أَذْ يَارْزُو \add أَذْ ث إِخْڒفْ\add*!“   
\m
\v 23 غَارْ ؤُنقْڒبْ ن ؤُسڭّْوَاسْ، إِمْسَارْ، أَقَا إِسّْڭعّذْ ڒْعسْكَارْ ن أَرَامْ خْ يُووَاشْ. نِيثْنِي ؤُسِينْ-د غَارْ يَاهُوذَا ذ ؤُرْشَالِيمْ ؤُ سّْهلّْكنْ زِي ڒْڭنْسْ مَارَّا ڒْحُوكَّامْ ن ڒْڭنْسْ ؤُشَا سّكّنْ مَارَّا ثَاكشَّاضْثْ نْسنْ غَارْ ؤُجدْجِيذْ ن ذِيمَاشْقْ.  
\v 24 وَاخَّا ثُوغَا ڒْعسْكَارْ ن أَرَامْ ذْرُوسْ ن يرْيَازنْ وَاهَا، أَقَا سِيذِي إِڭَّا أَسنْ إِجّْ ن ڒْعسْكَارْ ذ أَمقّْرَانْ ذڭْ ؤُفُوسْ نْسنْ، ؤُمِي نِيثْنِي حيّْذنْ خْ سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ. نِيثْنِي ڭِّينْ ڒحْكَامَاثْ خْ يُووَاشْ.  
\v 25 ؤُمِي خَاسْ فّْغنْ نِيثْنِي، أَقَا جِّينْ ث إِهْڒشْ أَطَّاسْ. ڭِّينْ خَاسْ إِمْسخَّارنْ نّسْ إِشْثْ ن ثْمعْمُوتْشْ ذِي سِّيبّثْ ن إِذَامّنْ إِ إِسِّيزّڒْ يُووَاشْ جَارْ إِحنْجِيرنْ ن ؤُكهَّانْ يَاهُويَاذَاعْ. نْغِينْ ث أَمْ إِدْجَا ذِي ثَاسُّوثْ نّسْ. نضْڒنْ ث ذِي ثنْذِينْثْ ن ذَاوُوذْ، مَاشَا وَارْ ث نْضِيڒنْ شَا ذِي ثْمضْڒِينْ ن إِجدْجِيذنْ.  
\v 26 إِنَا ذ إِنِّي إِ خَاسْ إِڭِّينْ إِشْثْ ن ثْمعْمُوتْشْ: زَابَاذْ، مِّيسْ ن شِيمْعَا، ثَاعَامُّونشْثْ، ؤُ يَاهُوزَابَاذْ، مِّيسْ ن شِيمْرِيثْ، ثَامُو‘أَبشْثْ.  
\v 27 خْ إِحنْجِيرنْ نّسْ ؤُ خْ ڒْقدّْ ن مِينْ إِ خَاسْ ڭِّينْ \add إِنَابِييّنْ\add* ؤُ خْ ذْسَاسْ ن ثَادَّارْثْ ن أَربِّي، خْزَارْ، أَقَا \add مَانْ أَيَا مَارَّا\add* يُورَا ذِي ثِيرَا ن وذْلِيسْ ن إِجدْجِيذنْ. مِّيسْ أَمَاصْيَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\b  
\m  
\c 25
\s1 أَغلّبْ ن أَمَاصْيَا، أَجدْجِيذْ ن يَاهُوذَا، خْ إِذُومْ  
\m
\v 1 أَمَاصْيَا \add ثُوغَا\add* غَارسْ خمْسَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثسْعَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ يَاهُوعَادَّانْ، \add ثُوغَا-ت\add* زِي ؤُرْشَالِيمْ. \x ◘ \xo 25:‏1 \xt [2 إِج. 14‏:‏1‏-‏22]\x*  
\v 2 نتَّا إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، مَاشَا وَارْ إِدْجِي س وُوڒْ إِمُونْ \add قَاعْ\add*.  
\v 3 ؤُمِي إِسّمْثنْ ثَاڭلْذَا نّسْ، إِمْسَارْ، أَقَا إِنْغَا إِمْسخَّارنْ نّسْ، إِنِّي إِ ثُوغَا إِنْغِينْ بَابَاسْ أَجدْجِيذْ.  
\v 4 مَاشَا إِحنْجِيرنْ ن إِقتَّاڒنْ وَارْ ثنْ إِنْغِي شَا، أَمْ مَامّشْ \add ث\add* يُورَا ذڭْ وذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا ن مُوسَا إِ ذِي إِوصَّا سِيذِي، إِنَّا: ”إِبَابَاثنْ وَارْ تّْوَانقّنْ ذِي سِّيبّثْ ن إِحنْجِيرنْ \add نْسنْ\add* ؤُ إِحنْجِيرنْ وَارْ تّْوَانقّنْ ذِي سِّيبّثْ ن إِبَابَاثنْ \add نْسنْ\add*، مَاغَارْ كُوڒْ إِجّْ أَذْ إِتّْوَانغْ خْ دّْنُوبْ \add ن يِيخفْ\add* نّسْ.“ \x ◘ \xo 25:‏4 \xt أَعَوذ. 24‏:‏16؛ حِز. 18‏:‏20\x*   
\m
\v 5 أَمَاصْيَا إِسّْمُونْ \add أَيْثْ ن\add* يَاهُوذَا ؤُشَا إِسّْبدّْ إِ-ثنْ عْلَاحْسَابْ ڒَادْجَاثْ ن إِبَابَاثنْ، أَكْ-ذ إِمقّْرَاننْ خْ وَاڒفْ ؤُ أَكْ-ذ إِمقّْرَاننْ خْ مْيَا إِ يَاهُوذَا ذ بِينْيَامِينْ مَارَّا. نتَّا إِسدّْ إِ-ثنْ زِي عِيشْرِينْ إِسڭّْوُوسَا سنّجْ ؤُشَا يُوفَا جَارْ أَسنْ ثڒْثْ-مْيَاثْ-أَڒفْ \add ن يرْيَازنْ\add* تّْوَافَارْزنْ، حِيمَا أَذْ فّْغنْ أَكْ-ذ ڒْعسْكَارْ، إِنِّي إِتّْوَاذَارّْبنْ خْ ؤُحْرِيشْ ذ ثْسدَّارْثْ \add ن ؤُعسْكَارِي\add* ثَامقّْرَانْثْ.  
\v 6 نتَّا إِشْرَا مْيَاثْ-أَڒفْ ن أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ زِي إِسْرَائِيل س مْيَا ثَالِينْثْ ن نُّوقَارْثْ.   
\m
\v 7 \add خنِّي\add* يُوسَا-د غَارسْ إِجّْ ن ورْيَازْ ن أَربِّي، إِنَّا: ”\add أَ\add*، أَجدْجِيذْ، وَارْ تّجِّي ڒْعسْكَارْ ن إِسْرَائِيل أَكِيذكْ إِتّفّغْ، مَاغَارْ سِيذِي وَارْ إِدْجِي أَكْ-ذ إِسْرَائِيل، أَكْ-ذ مَارَّا أَرَّاونْ \add نِّي\add* ن إِفْرَايِيمْ.  
\v 8 \add مَاشَا\add* مَاڒَا ثخْسذْ أَذْ ثْرَاحذْ \add عَاذْ\add* فّغْ، أڭّْ إِ-ث، \add إِوَا\add* إِڒِي ذ أَرْيَازْ ذڭْ ؤُمنْغِي. أَربِّي أَذْ شكْ إِسّْنقْڒبْ زَّاثْ إِ وُوذمْ ن ڒعْذُو، مَاغَارْ أَربِّي غَارسْ ثِيزمَّارْ مَاحنْذْ أَذْ إِعَاونْ ؤُ أَذْ إِسّْنقْڒبْ.“  
\v 9 أَمَاصْيَا إِنَّا إِ ورْيَازْ ن أَربِّي: ”مَاشَا مِينْ غَا إِمْسَارنْ س مْيَا ثَالِينْثْ إِ وْشِيغْ إِ ثرْبِيعِينْ ن \add ڒْْعسْكَارْ ن\add* إِسْرَائِيل؟“ أَرْيَازْ ن أَربِّي إِنَّا: ”سِيذِي غَارسْ كْثَارْ زِي مَانْ أَيَا حِيمَا أَذْ أَشْ ث إِوْشْ.“  
\v 10 ؤُشَا إِعْزڒْ أَمَاصْيَا ثِيرْبِيعِينْ \add ن ڒْعسْكَارْ\add* إِ ثُوغَا غَارسْ د-يُوسِينْ زِي إِفْرَايِيمْ، إِجَّا إِ-ثنْثْ أَذْ أَرڭّْوحنْثْ غَارْ ومْشَانْ نْسنْ. \add خنِّي\add* إِڒْقفْ إِ-ثنْ ؤُخيّقْ أَمقّْرَانْ خْ يَاهُوذَا ؤُشَاعقْبنْ س ثفْقحْثْ ذ ؤُفُوڭمْ غَارْ ومْشَانْ نْسنْ.   
\m
\v 11 أَمَاصْيَا إِڭَّا ثَارْيَاسْثْ، إِنْذهْ ڒْڭنْسْ نّسْ. إِفّغْ غَارْ ثغْزُورْثْ ن ثْمدْجَاحْثْ، إِنْغَاعشْرَا-أَڒَافْ \add ن يرْيَازنْ\add* زڭْ أَيْثْ ن سَاعِيرْ.  
\v 12 \add عَاوذْ\add* حبّْسنْ أَيْثْ ن يَاهُوذَاعشْرَا-أَڒَافْ \add ن يرْيَازنْ\add* أَمْ دَّارنْ، ؤُشَا إِوْينْ ثنْ غَارْ ثْقِيشَّاثْ ن جَّارْفْ ؤُشَا عَارْننْ ثنْ سّنِّي غَارْ سْوَادَّايْ أَڒَامِي فْثُوتّْينْ مَارَّا.  
\v 13 \add مَاشَا\add* إِرْيَازنْ ن ثرْبِيعِينْ ن ڒْعسْكَارْ نِّي ثُوغَا إِجَّا أَمَاصْيَا أَذْعقْبنْ أَڒَامِي وَارْ كِيذْسنْ د-تّفّْغنْ غَارْ ؤُمنْغِي، هجْمنْ خْ ثْندَّامْ ن يَاهُوذَا، زِي سَامَارْيَا أَڒْ بَايْثْ-حُورُونْ، ؤُشَا نْغِينْ زَّايْسنْ ثڒْثْ-أَڒَافْ \add ن يرْيَازنْ\add* ؤُشَا حوّْسنْ ثَاكشَّاضْثْ ثَامقّْرَانْثْ أَطَّاسْ.   
\m
\v 14 أَوَارْنِي ڒغْڒبْ خْ أَيْثْ ن إِذُومْ، ڒَامِي د-إِعْقبْ أَمَاصْيَا، يِيوِي نتَّا إِربِّيثنْ ن أَيْثْ ن سَاعِيرْ ؤُشَا إِسّْبدّْ إِ-ثنْ زَّاثسْ ؤُشَا إِبنْذقْ زَّاثْسنْ ؤُشَا إِسّْبخَّارْ أَسنْ.  
\v 15 ؤُشَا يَارْغَا وغْضَابْ ن سِيذِي خْ أَمَاصْيَا، ؤُشَا إِسّكّْ إِجّْ ن ؤُنَابِي غَارسْ. وَانِيثَا إِنَّا أَسْ: ”مَايمِّي ثَارْزُوذْ إِربِّيثنْ ن ڒْڭنْسْ \add نِّي\add*، إِنِّي إِ ثُوغَا وَارْ إِزمَّارنْ أَذْ فكّنْ ڒْڭنْسْ نْسنْ زڭْ ؤُفُوسْ نّشْ؟“  
\v 16 ؤُمِي نتَّا إِسِّيوڒْ \add أَمُّو\add*، إِمْسَارْ، أَقَا إِنَّا أَسْ: ”مَا ڭِّينْ شكْ ذ أَمْشَاوَارْ ن ؤُجدْجِيذْ؟ بدّْ، مَايمِّي إِ شكْ إِ غَا وْثنْ؟“ \add خنِّي\add* إِبدّْ ؤُنَابِي، إِنَّا: ”\add ڒخُّو\add* سّْنغْ، أَقَا سِيذِي إِعْزمْ حِيمَا أَذْ شكْ يَاردّدْجْ، مِينْزِي ثڭِّيذْ أَيَا ؤُ وَارْ ثسْڒِيذْ غَارْ شّْوَارْ إِنُو.“   
\b  
\m  
\s1 ثَاخسَّارْثْ ن يَاهُوذَا ذڭْ ؤُمنْغِي أَكْ-ذ إِسْرَائِيل  
\m
\v 17 أَمَاصْيَا، أَجدْجِيذْ ن يَاهُوذَا، إِمْشَاوَارْ. إِسّكّْ \add إِرقَّاصنْ\add* غَارْ يُووَاشْ، مِّيسْ ن يَاهُويَاحَازْ، مِّيسْ ن يَاهُو، أَجدْجِيذْ ن إِسْرَائِيل، إِنَّا: ”أَسْ-د، أجّْ أَنغْ أَذْ نمّڒْقَا \add إِ ؤُمنْغِي\add*.“  
\v 18 \add مَاشَا\add* يُووَاشْ، أَجدْجِيذْ ن إِسْرَائِيل، إِسّكّْ \add إِجّْ ن ؤُرقَّاصْ\add* غَارْ أَمَاصْيَا، أَجدْجِيذْ ن يَاهُوذَا، إِنَّا أَسْ: ”شْبَارْقْ أَكْ-ذ إِسنَّاننْ \add إِ إِغمّْينْ\add* خْ \add إِذُورَارْ ن\add* لُوبْنَانْ، إِسّكّْ \add إِشْثْ ن ثبْرَاثْ\add* غَارْ ثنْڭلْثْ خْ \add إِذُورَارْ ن\add* لُوبْنَانْ، إِنَّا: ’أوْشْ يدْجِيشْ ذ ثَامْغَارْثْ إِ مِّي!‘ \add مَاشَا\add* إِجّْ ن ڒْوحْشْ إِ \add ذِينْ يُويُورنْ\add* خْ \add إِذُورَارْ ن\add* لُوبْنَانْ، إِكَّا ؤُشَا إِعْفسْ خْ شْبَارْقْ أَكْ-ذ إِسنَّاننْ.  
\v 19 ثقَّارذْ \add أَكْ-ذ إِخفْ نّشْ\add*: ’خْزَارْ، أَقَاغڒْبغْ خْ إِذُومْ!‘، ؤُ \add ڒخُّو\add* ثُوذفْ نّْفَاخثْ غَارْ وُوڒْ نّشْ حِيمَا أَذْ ثَارْزُوذْ خْ شَّانْ كْثَارْ. قِّيمْ ذِي ثَادَّارْثْ نّشْ، \add مِينْزِي\add* مَايمِّي غَا ثْغضْڒذْ إِخفْ نّشْ ذِي ڒْغَارْ ؤُ أَذْ ثوْضِيذْ، شكْ ذ يَاهُوذَا أَكِيذكْ؟“  
\v 20 \add مَاشَا\add* أَمَاصْيَا وَارْ إِخْسْ أَذْ إِسڒْ، مَاغَارْ مَانْ أَيَا يُوسَا-د زِي أَربِّي مَاحنْذْ أَذْ ثنْ إِوْشْ ذڭْ ؤُفُوسْ \add نْسنْ\add*، مِينْزِي نِيثْنِي أَرْزُونْ إِربِّيثنْ ن إِذُومْ.  
\v 21 \add خنِّي\add* إِڭعّذْ يُووَاشْ، أَجدْجِيذْ ن إِسْرَائِيل. نتَّا ذ أَمَاصْيَا، أَجدْجِيذْ ن يَاهُوذَا، مّڒْقَانْ \add إِ ؤُمنْغِي\add* غَارْ بَايْثْ-شَامْسْ، إِ إِدْجَانْ ذِي يَاهُوذَا.  
\v 22 يَاهُوذَا إِتّْوَاغْڒبْ زَّاثْ إِ وُوذمْ ن إِسْرَائِيل ؤُشَا نِيثْنِي أَروْڒنْ، كُوڒْ إِجّْ غَارْ ؤُقِيضُونْ نّسْ.  
\v 23 يَاحُويَاحَازْ، أَجدْجِيذْ ن إِسْرَائِيل، إِطّفْ أَمَاصْيَا، أَجدْجِيذْ ن يَاهُوذَا، مِّيسْ ن يُووَاشْ، مِّيسْ ن يَاهُويَاحَازْ ذِي بَايْثْ-شَامْسْ ؤُشَا يِيوْيِي إِ-ث غَارْ ؤُرْشَالِيمْ. \add ذِينِّي\add* إِڭَّا إِشْثْ ن ثَازِّيثْ ذِي ڒْحِيضْ ن ؤُرْشَالِيمْ، زِي ثوَّارْثْ ن إِفْرَايِيمْ أَڒْ ثوَّارْثْ ن ثغْمَارْثْ، خْ إِجّْ ن وبْرِيذْ ن أَربْعَا-مْيَا ن إِغَادْجنْ.  
\v 24 يِيوِي مَارَّا ؤُرغْ ذ نُّوقَارْثْ ذ مَارَّا ڒقْشُوعْ إِ إِتّْوَافنْ ذِي ثَادَّارْثْ ن أَربِّي ؤُ ذڭْ إِخَّامنْ ن ثْخُوبَايْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ \add ؤُڒَا ذ\add* إِمرْهَاننْ، ؤُشَا إِعْقبْ غَارْ سَامَارْيَا.   
\m
\v 25 أَمَاصْيَا، مِّيسْ ن يُووَاشْ، أَجدْجِيذْ ن يَاهُوذَا، إِدَّارْ \add عَاذْ\add* خمّسْطَاشْ ن إِسڭّْوُوسَا أَوَارْنِي إِ ڒْموْثْ ن يُووَاشْ، مِّيسْ ن يَاهُويَاحَازْ، أَجدْجِيذْ ن إِسْرَائِيل.  
\v 26 مِينْ إِقِّيمنْ ن إِمزْرُوينْ ن أَمَاصْيَا، إِمزْوُورَا ذ إِنڭُّورَا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِجدْجِيذنْ ن يَاهُوذَا ذ إِسْرَائِيل؟  
\v 27 زڭْ وَامِي إِحيّذْ أَمَاصْيَا خْ سِيذِي، ڭِّينْ خَاسْ إِشْثْ ن ثْمعْمُوتْشْ ذِي ؤُرْشَالِيمْ، مَاشَا نتَّا يَارْوڒْ غَارْ لَاخِيشْ. \add خنِّي\add* سّكّنْ \add إِرْيَازنْ\add* أَوَارْنِي أَسْ ؤُشَا نْغِينْ ث ذِينِّي.  
\v 28 إِوْينْ ث-إِ-د خْ ييْسَانْ ؤُشَا نضْڒنْ ث جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن يَاهُوذَا.   
\b  
\b  
\m  
\c 26
\s1 عُوزِّييَا، أَجدْجِيذْ ن يَاهُوذَا، ڒحْڒَاشْ نّسْ ذ ڒْموْثْ نّسْ  
\m
\v 1 \add خَاسْ ؤُشَا\add* يِيوِي مَارَّا ڒْڭنْسْ ن يَاهُوذَا عُوزِّييَا، ونِّي ثُوغَا غَارْ إِدْجَا سطَّاشْ ن إِسڭّْوُوسَا، ڭِّينْ ث ذ أَجدْجِيذْ ذڭْ ومْشَانْ ن بَابَاسْ أَمَاصْيَا. \x ◘ \xo 26:‏1 \xt [2 إِج. 15‏:‏1‏-‏7]\x*  
\v 2 نتَّا إِبْنَا إِلَاثْ ؤُ يَارَّا إِ-ث \add ذڭْ ؤُفُوسْ\add* ن يَاهُوذَا، أَوَارْنِي ڒَامِي إِڭَّا ؤُجدْجِيذْ أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ.  
\v 3 عُوزِّييَا \add ثُوغَا\add* غَارسْ سطَّاشْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثْنَاينْ ؤُ-خمْسِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ يَاكُولْيَا زِي ؤُرْشَالِيمْ.  
\v 4 نتَّا إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، إِڭَّا نِيشَانْ أَمْ مَامّشْ ثُوغَا إِڭَّا بَابَاسْ أَمَاصْيَا.  
\v 5 نتَّا ثُوغَا يَارزُّو خْ أَربِّي ذڭْ وُوسَّانْ ن زَاكَارِييَّا، ونِّي ثُوغَا إِ ذ أَسْ إِسّڒْمَاذْ مَاحنْذْ أَذْ إِڭّْوذْ أَربِّي، ؤُشَا إِسّهْونْ أَربِّي أَبْرِيذْ نّسْ ذڭْ وُوسَّانْ إِ ذِي ثُوغَا يَارزُّو خْ سِيذِي.   
\m
\v 6 نتَّا إِفّغْ ؤُشَا إِمّْنغْ أَكْ-ذ إِفِيلِيسْطِينِييّنْ ؤُشَا إِڭَّا إِشْثْ ن ثَازِّيثْ ذِي ڒْحِيضْ ن جَاثْ ؤُ ذِي ڒْحِيضْ ن يَابْنَا ذ ڒْحِيضْ ن أَشْذُوذْ. نتَّا إِبْنَا ثِيندَّامْ غَارْ أَشْذُوذْ ؤُ ذِي \add ثمُّورْثْ ن\add* إِفِيلِيسْطِينِييّنْ.  
\v 7 أَربِّي إِبدّْ أَكِيذسْ ضِيدّْ إِ إِفِيلِيسْطِينِييّنْ ؤُ ضِيدّْ إِ وعْرَابنْ، إِنِّي إِزدّْغنْ ذِي جُورْ-بَاعْلْ، ؤُ ضِيدّْ إِ إِمَاعُونِييّنْ.  
\v 8 وْشِينْ أَيْثْ ن عَامُّونْ لْجِيزْيَا إِ عُوزِّييَا ؤُشَا إِذْوڒْ يِيسمْ نّسْ إِتّْوَاسّنْ أَڒْ وَاذَافْ ن مِيصْرَا، مَاغَارْ نتَّا ثُوغَا إِذْوڒْ إِجْهذْ أَطَّاسْ.  
\v 9 ذِي ؤُرْشَالِيمْ إِسّْبدّْ عُوزِّييَا صُّومْعَاثْ غَارْ ثوَّارْثْ ن ثغْمَارْثْ ؤُ غَارْ ثوَّارْثْ ن ثغْزُورْثْ ؤُ غَارْ ثْغمُّورْثْ ؤُشَا إِسّمْثنْ إِ-ثنْثْ.  
\v 10 نتَّا إِبْنَا \add عَاوذْ\add* صُّومْعَاثْ ذِي ڒخْڒَا ؤُشَا إِغْزَا أَطَّاسْ ن وَانُوثنْ، مَاغَارْ غَارسْ ڒبْهَايمْ أَطَّاسْ ذِي ثمُّورْثْ إِوَاطَانْ ؤُ ذِي ڒْوَاطَا \add يُوعْڒَانْ\add*. ثُوغَا غَارسْ إِفدْجَاحنْ ذ أَيْثْ ن ثْزَايَارْثْ ذڭْ إِذُورَارْ ؤُڒَا ذڭْ إِيَّارنْ إِعَارْصنْ، مَاغَارْ نتَّا ثُوغَا إِتّخْسْ ثَافدْجَاحْثْ.   
\m
\v 11 عُوزِّييَا ثُوغَا غَارسْ \add عَاوذْ\add* إِجّْ ن ڒْعسْكَارْ ن إِعسْكَارِييّنْ إِمْذَارّْبنْ، تّفّْغنْ غَارْ ؤُمنْغِي ذِي ثرْبِيعِينْ، عْلَاحْسَابْ لْعَاذَاذْ إِ ثُوغَا إِتّْوَاسدّْ زَّايْسنْ س ؤُفُوسْ ن ؤُمَارِيرْ يَاعِييِيلْ ذ ؤُوقَّافْ مَاعَاسِييَا، س ڒُومُورْ ن حَانَانْيَا، إِجّْ زِي ڒْحُوكَّامْ ن ؤُجدْجِيذْ.  
\v 12 ڒْقدّْ إِمُونْ ن إِزدْجِيفنْ خْ \add ڒَْادْجَاثْ ن\add* إِبَابَاثنْ، ن أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، \add ثُوغَا\add* أَڒْفَاينْ ؤُ-ستَّا-مْيَا \add ن يرْيَازنْ\add*.  
\v 13 سَاذُو أَفُوسْ نْسنْ \add ثُوغَا\add* ذِينْ إِجّْ ن ڒْعسْكَارْ ن ثڒْثْ-مْيَا ؤُ-سبْعَا-أَڒَافْ ؤُ-خمْسَا-مْيَا \add ن يرْيَازنْ\add*، إِعسْكَارِييّنْ إِمْذَارّْبنْ س جّهْذْ \add إِشُّورنْ\add* إِ ؤُمنْغِي، حِيمَا أَذْ وْشنْ أَفُوسْ إِ ؤُجدْجِيذْ ضِيدّْ إِ ڒعْذُو.  
\v 14 عُوزِّييَا إِسّوْجذْ أَسنْ ثِيسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* ذ إِحْرِيشنْ ذ لْكَاسْكَاثْ خْ ؤُزدْجِيفْ ذ وَارُّوضْ ن وُوزَّاڒْ ذ ڒقْوَاسْ ذ إِژْرَا ن يِيدْجِييْ، إِ مَارَّا ڒْعسْكَارْ.  
\v 15 ذِي ؤُرْشَالِيمْ إِڭَّا دُّوزَانَاثْ إِتّْوَاسُّوفّْغنْ زڭْ إِمْسُوفّْغنْ إِمِيغِيسنْ حِيمَا أَذْ ثنْثْ ڭّنْ خْ صُّومْعَاثْ ؤُ خْ ثْغمُّورَا حِيمَا أَذْ زَّايْسنْثْ وْثنْ فْڒِيثْشَاثْ ؤُ أَذْ حجَّارنْ إِژْرَا إِمقّْرَاننْ. أَمُّو إِ إِذْوڒْ إِسمْ نّسْ إِشْنعْ غَارْ ڒَاڭّْوَاجْ، مَاغَارْ إِ نتَّا ؤُمِي ثتّْوَاڭّْ ثْوِيزَا س ڒعْجبْ، أَڒَامِي إِذْوڒْ يَارْنِي ذِي جّهْذْ.   
\b  
\m
\v 16 مَاشَا ؤُمِي إِذْوڒْ إِجْهذْ، إِسّْڭعّذْ إِخفْ نّسْ ذڭْ وُوڒْ نّسْ أَڒَامِي إِسِّيوضْ \add إِخفْ نّسْ\add* غَارْ وَاريّبْ ؤُ إِغْذَارْ سِيذِي، أَربِّي نّسْ، مَاغَارْ يُوذفْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي، حِيمَا أَذْ إِسّْبخَّارْ خْ ؤُعَالْطَارْ نْ ڒبْخُورْ.  
\v 17 أَكهَّانْ عَازَارْيَا يُويُورْ أَوَارْنِي أَسْ، ؤُ ؤُيُورنْ أَكِيذسْ إِكهَّاننْ ن سِيذِي ذ إِلَاوِييّنْ، ثْمنْيِينْ ن يرْيَازنْ إِمحْضنْ. \f ◼ \fr 26:‏17 \ft \+bd ’عَازَارْيَا‘\+bd* - س ثْعِيبْرَانِيثْ ’عَازَارْ-يَاهُو‘. \+bd ’إِرْيَازنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’إِحنْجِيرنْ‘.\f*  
\v 18 نِيثْنِي قَاطْعنْ إِ ؤُجدْجِيذْ عُوزِّييَا، نَّانْ أَسْ: ”وَارْ شكْ إِشُووَّارْ، عُوزِّييَا، مَاحنْذْ أَذْ ثَاوْيذْ ڒبْخُورْ إِ سِيذِي، مْغِيرْ إِ إِكهَّاننْ، أَرَّاوْ ن هَارُونْ، إِنِّي إِتّْوَاقدّْسنْ إِ ثوْهِيبْثْ ن ڒبْخُورْ. فّغْ زِي زَّاوشْثْ إِقدّْسنْ، مَاغَارْ ثغْذَارذْ ؤُ مَانْ أَيَا وَارْ ذ أَشْ د-إِتِّيوِي شَّانْ زَّاثْ إِ سِيذِي، أَربِّي نّشْ.“  
\v 19 \add خنِّي\add* إِسْعَارْ عُوزِّييَا أَمْ إِطّفْ ڒبْخُورْ إِ ثوْهِيبْثْ نْ ڒبْخُورْ ذڭْ ؤُفُوسْ نّسْ. أَمْ إِسْعَارْ \add أَمُّو\add* خْ إِكهَّاننْ، إِفّغْ أَسْ د-ڒْْبَارْصْ ذِي ثنْيَارْثْ نّسْ، زَّاثْ إِ ثِيطَّاوِينْ ن إِكهَّاننْ ذِي ثَادَّارْثْ ن سِيذِي، غَارْ ؤُعَالْطَارْ ن ڒبْخُورْ. \f ◼ \fr 26:‏19 \ft \+bd ’عُوزِّييَا‘\+bd* - س ثْعِيبْرَانِيثْ ’عُوزِّي-يَاهُو‘. \+bd ’زَّاثْ إِ ثِيطَّاوِينْ ن‘\+bd* - س ثْعِيبْرَانِيثْ ’زَّاثْ إِ وُوذْمَاونْ ن‘.\f*  
\v 20 \add ؤُمِي\add* إِنّقْڒبْ ؤُكهَّانْ أَمقّْرَانْ عَازَارْيَا ذ مَارَّا إِكهَّاننْ غَارسْ، أَقَا ذَا، ذَايسْ ڒْبَارْصْ ذِي ثنْيَارْثْ نّسْ. نِيثْنِي حْسَارنْ ث ذغْيَا أَذْ سّنِّي يَاڭّْوجْ، ؤُڒَا ذ نتَّا سِيمَانْثْ نّسْ إِقدْجقْ أَذْ إِفّغْ، مِينْزِي سِيذِي ثُوغَا إِوْثَا إِ-ث.  
\v 21 ثُوغَا أَجدْجِيذْ عُوزِّييَا إِهْڒشْ س ڒْبَارْصْ أَڒْ أَسّْ ن ڒْموْثْ نّسْ. نتَّا إِقِّيمْ إِزدّغْ ذڭْ إِشْثْ ن ثَادَّارْثْ ثتّْوَاعْزڒْ، مَاغَارْ نتَّا ثُوغَا إِتّْوَاقسّْ زِي ثَادَّارْثْ ن سِيذِي. مِّيسْ يُوثَامْ ثُوغَا \add إِتّْوَاڒقّمْ\add* خْ ثْزذِّيغْثْ \add ن ؤُجدْجِيذْ\add* ؤُ إِحكّمْ خْ ڒْڭنْسْ ن ثمُّورْثْ.   
\m
\v 22 إِمزْرُوينْ إِقِّيمنْ ن عُوزِّييَا، إِمزْوُورَا ذ إِنڭُّورَا، أَقَا إِزمّْ إِ-ثنْ ؤُنَابِي إِشَاعْيَا، مِّيسْ ن أَمُوصْ.  
\v 23 عُوزِّييَا إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نضْڒنْ ث جَارْ ڒجْذُوذْ نّسْ ذڭْ إِيَّارْ ن ونْضڒْ ن إِجدْجِيذنْ، مَاغَارْ نَّانْ: ”أَقَا ذَايسْ ڒْبَارْصْ!“ مِّيسْ يُوثَامْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\b  
\m  
\c 27
\s1 يُوثَامْ إِذْوڒْ ذ أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 1 يُوثَامْ \add ثُوغَا\add* غَارسْ خمْسَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ سطَّاشْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ يَارُوشَا، يدْجِيسْ ن صَاذُوقْ. \x ◘ \xo 27:‏1 \xt [2 إِج.15‏:‏32‏-‏38]\x*  
\v 2 نتَّا إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، نِيشَانْ أَمْ مَامّشْ ث إِڭَّا بَابَاسْ عُوزِّييَا، مَاشَا نتَّا وَارْ يُوذِيفْ شَا غَارْ زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي. ڒْڭنْسْ \add مَاشَا\add* ثُوغَا \add عَاذْ\add* إِفْسذْ إِخفْ نّسْ أَطَّاسْ.  
\v 3 نتَّا إِبْنَا ثَاوَّارْثْ يُوعْڒَانْ ن ثَادَّارْثْ ن سِيذِي. ؤُڒَا غَارْ ڒْحِيضْ ن عُوفِيلْ إِبْنَا أَطَّاسْ.  
\v 4 إِبْنَا ثِيندَّامْ ذِي ثمُّورْثْ ن إِذُورَارْ ن يَاهُوذَا ؤُ ذڭْ إِزغْرَانْ إِبْنَا لْقلْعَاثْ ذ صُّومْعَاثْ.  
\v 5 نتَّا إِمّْنغْ أَكْ-ذ أَيْثْ ن عَامُّونْ ؤُ إِغْڒبْ خَاسنْ، أَڒَامِي أَيْثْ ن عَامُّونْ سِّيوْضنْ غَارسْ ذڭْ ؤُسڭّْوَاسْ نِّي \add عَاذْ\add* مْيَا ثَالِينْثْ ن نُّوقَارْثْ ذعشْرَا-أَڒَافْ ن إِكُورُوثنْ ن إِرْذنْ ذعشْرَا-أَڒَافْ إِكُورُوثنْ ن إِمنْذِي. ؤُڒَا ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ذ وِيسّْ ثْڒَاثَا سِّيوْضنْ أَيْثْ ن عَامُّونْ غَارسْ مَانْ أَيَا عَاوذْ.  
\v 6 \add أَمُّو إِ\add* إِذْوڒْ يُوثَامْ إِجْهذْ، مَاغَارْ إِسّوْجذْ إِبْرِيذنْ نّسْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّسْ.   
\m
\v 7 إِمزْرُوينْ إِقِّيمنْ ن يُوثَامْ، ذ مَارَّا إِمنْغَانْ إِ إِمّْنغْ ذ مَارَّا إِبْرِيذنْ نّسْ، أَقَا تّْوَازمّمنْ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا.  
\v 8 \add ثُوغَا\add* غَارسْ خمْسَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ سطَّاشْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ.  
\v 9 يُوثَامْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ ذِي ثنْذِينْثْ ن ذَاوُوذْ. مِّيسْ أَحَازْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\b  
\m  
\c 28
\s1 ڒحْكَامثْ ن أَحَازْ  
\m
\v 1 أَحَازْ \add ثُوغَا\add* غَارسْ عِيشْرِينْ ن إِسڭّْوُوسَا، ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ سطَّاشْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. نتَّا وَارْ إِڭِّي مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَربِّي نّسْ، أَمْ مَامّشْ \add إِڭَّا\add* بَابَاسْ ذَاوُوذْ. \x ◘ \xo 28:‏1 \xt [2 إِج. 16‏:‏1‏-‏20]\x*  
\v 2 نتَّا يُويُورْ ذڭْ إِبْرِيذنْ ن إِجدْجِيذنْ ن إِسْرَائِيل. عَاوذْ إِڭَّا ڒخْيَاڒَاثْ إِفسْينْ إِ ’إِبَاعْلنْ‘. \f ◼ \fr 28:‏2 \ft \+bd ’إِبَاعْلنْ‘\+bd* - أَقَا-ثنْ ذ لَاصْنَامْ.\f*  
\v 3 نتَّا ثُوغَا إِتَّاوِي-د ڒبْخُورْ ذِي ثغْزُورْثْ ن بِينْ-هِينُّومْ ؤُ إِسّشْمضْ إِحنْجِيرنْ نّسْ ذِي ثْمسِّي. نتَّا إِڭَّا عْلَاحْسَابْ جّْعَايفْ نِّي ڭِّينْ مَارَّا ڒڭْنُوسْ إِ خفْ يُوژّڒْ سِيذِي زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل.  
\v 4 نتَّا يِيوْيِي-د ثِيغَارْصَا ذ ثوْهِيبِينْ ن ڒبْخُورْ خْ ڒڭْعُوذِي ؤُ خْ ثوْرِيرِينْ ؤُ سَاذُو مَارَّا أَزْغَارْ أَزِيزَا.  
\v 5 سِيذِي، أَربِّي نّسْ، إِوْشَا إِ-ث ذڭْ إِفَاسّنْ ن ؤُجدْجِيذْ ن أَرَامْ. نِيثْنِي وْثِينْ ث ؤُ حبّْسنْ زَّايسْ إِجّْ ن ؤُبَارُّو إِمْغَارْ ؤُ إِوْينْ ثنْ غَارْ ذِيمَاشْقْ. إِمّوْشْ أَحَازْ ذڭْ إِفَاسّنْ ن ؤُجدْجِيذْ ن إِسْرَائِيل، ونِّي ذ أَسْ إِوْثِينْ س إِشْثْ ن ثشْثِي ذ ثَامقّْرَانْثْ. \f ◼ \fr 28:‏5 \ft \+bd ’ذڭْ إِفَاسّنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ذڭْ ؤُفُوسْ‘.\f*  
\v 6 فَاقَاحْ، مِّيسْ ن رَامَالْيَاهُو، إِنْغَا مْيَا ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add* ذڭْ إِجّْ ن وَاسّْ ذِي يَاهُوذَا، مَارَّا نِيثْنِي ذ أَيْثْ ن ؤُمنْغِي، مِينْزِي نِيثْنِي حيّْذنْ خْ سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ.  
\v 7 زِيكْرِي، إِجّْ ن بُو-ثغْرُوضْثْ زِي إِفْرَايِيمْ، إِنْغَا مَاعَاسِييَا، مِّيسْ ن ؤُجدْجِيذْ، ذ عَازْرِيقَامْ، أَمحْضَايْ ن ثَادَّارْثْ، ذ إِلْقَانَا، ونِّي ذ وِيسّْ ثْنَاينْ أَوَارْنِي إِ ؤُجدْجِيذْ.  
\v 8 نذْهنْ أَيْثْ ن إِسْرَائِيل زڭْ أَيْثْمَاثْسنْ مِيثَاينْ-أَڒفْ ن ثمْغَارِينْ ذ إِحنْجِيرنْ ذ ثْحنْجِيرِينْ ذِي ثْمحْبَاسْثْ ؤُ طّْفنْ زَّايْسنْ إِشْثْ ن ثْكشَّاضْثْ ذ ثَامقّْرَانْثْ. إِوْينْ ثَاكشَّاضْثْ \add نِّي\add* غَارْ سَامَارْيَا.   
\m
\v 9 ذِينِّي إِدْجَا إِجّْ ن ؤُنَابِي ن سِيذِي، قَّارنْ أَسْ عُوذِيذْ. وَانِيثَا إِفّغْ، إِمْسَاڭَارْ أَكْ-ذ ڒْعسْكَارْ إِ د-إِعقْبنْ غَارْ سَامَارْيَا، إِنَّا أَسنْ: ”خْزَارمْ، مِينْزِي س وسْعَارْ ن سِيذِي، أَربِّي ن ڒجْذُوذْ نْومْ، خْ يَاهُوذَا، إِڭَّا إِ-ثنْ ذڭْ ؤُفُوسْ نْومْ ؤُ كنِّيوْ ثنْغِيمْ ثنْ س إِجّْ ن وسْخضْ يِيوضْ أَڒْ أَجنَّا.  
\v 10 ؤُ ڒخُّو إِتّْغِيڒْ أَومْ أَذْ ثڭّمْ أَيْثْ ن يَاهُوذَا ذ ؤُرْشَالِيمْ سَاذُو ؤُفُوسْ نْومْ أَمْ يِيسمْغَانْ ذ ثِييَّا. مَا وَارْ كنِّيوْ إِضْفَارْ خنِّي ؤُمَارْوَاسْ غَارْ سِيذِي، أَربِّي نْومْ؟  
\v 11 سْڒمْ-د ڒخُّو غَارِي ؤُ أَرّمْ إِمحْبَاسْ نِّي ثْحبّْسمْ زڭْ أَيْثْمَاثْومْ، مَاغَارْ ڒْحَاذُوقْ ن وغْضَابْ ن سِيذِي \add إِ د-يُوسَا\add* خَاومْ.“  
\v 12 \add خنِّي\add* سّْبدّنْ يرْيَازنْ-أَ زڭْ إِزدْجِيفنْ ن إِحنْجِيرنْ ن إِفْرَايِيمْ \add إِخفْ نْسنْ\add* زَّاثْ إِ يِينِّي د-يَارڭّْوحنْ زِي ڒْعسْكَارْ: عَازَارْيَا، مِّيسْ ن يُوحَانَانْ، بَارَاخْيَا، مِّيسْ ن مَاشِيلِّيمُوثْ، حِيزْقِييَا، مِّيسْ ن شَالُّومْ، ذ عَامَاسَا، مِّيسْ ن هِيذْلَايْ.  
\v 13 نِيثْنِي نَّانْ أَسنْ: ”وَارْ ثْزمَّارمْ أَذْ ثسِّيذْفمْ إِمحْبَاسْ ذَانِيثَا، \add مَاغَارْ\add* نِيثْنِي أَذْ خَانغْ د-أَرنْينْ أَمَارْوَاسْ زَّاثْ إِ سِيذِي. مَا إِتّْغِيڒْ أَومْ \add نْزمَّارْ\add* أَذْ نَارْنِي \add عَاذْ\add* ذِي دّْنُوبْ نّغْ ذ ؤُمَارْوَاسْ نّغْ، وَاخَّا \add عَاذْ\add* غَارْنغْ أَطَّاسْ ن إِمرْوُوسَا ؤُ ڒْحَاذُوقْ ن وغْضَابْ \add ن أَربِّي\add* أَقَا-ث خْ إِسْرَائِيل؟“   
\m
\v 14 \add خنِّي\add* سمْحنْ يرْيَازنْ إِحزّْمنْ س ڒسْنَاحْ ذڭْ إِمحْبَاسْ ذ ثْكشَّاضْثْ زَّاثْ إِ إِمقّْرَاننْ ذ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add*.  
\v 15 إِرْيَازنْ، إِنِّي إِتّْوَاسمَّانْ قْبڒْ س إِسْمَاونْ نْسنْ، كَّارنْ ؤُشَا ثْهلَّانْ ذڭْ إِمحْبَاسْ. نِيثْنِي سّْيَارْضنْ مَارَّا إِنِّي ثُوغَا إِدْجَانْ ذ إِعَارْيَاننْ س \add وَارُّوضْ زِي\add* ثْكشَّاضْثْ، سّْيَارْضنْ ثنْ س وَارُّوضْ ذ ثْسِيڒَا ؤُ وْشِينْ أَسنْ أَذْ شّنْ، أَذْ سْونْ. \add عَاوذْ\add* ذهْننْ ثنْ ؤُشَا سّْغِيمنْ إِنِّي إِ ثُوغَا ڭُّورنْ تّنْقَارْضنْ خْ يغْيَاڒْ ؤُ \add أَمُّو\add* إِوْينْ ثنْ غَارْ أَيْثْمَاثْسنْ غَارْ أَرِيحَا، ثَانْذِينْثْ ن ثْشجِّيرَا ن ثِينِي. أَوَارْنِي مَانْ أَيَاعقْبنْ نِيثْنِي سِيمَانْثْ نْسنْ غَارْ سَامَارْيَا.   
\m
\v 16 ذِي ڒْوقْثْ نِّي إِسّكّْ أَحَازْ \add إِرقَّاسنْ\add* غَارْ إِجدْجِيذنْ ن أَشُّورْ، حِيمَا أَذْ أَسْ وْشنْ أَفُوسْ.  
\v 17 ؤُڒَا ذ أَيْثْ ن إِذُومْ ؤُسِينْ-د. نِيثْنِي وْثِينْ يَاهُوذَا ؤُ نذْهنْ \add ثنْ\add* ذِي ثْمحْبَاسْثْ.  
\v 18 إِفِيلِيسْطِينِييّنْ هجْمنْ خْ ثْندَّامْ ن ثمُّورْثْ إِوَاطَانْ ذ لْجَانُوبْ ن يَاهُوذَا ؤُشَا طّْفنْ بَايْثْ-شَامْسْ، أَيَّالُونْ، جَاذِيرُوثْ، سُوكُو ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ، ثِيمْنَاهْ ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ ذ جِيمْزُو ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ ؤُشَا زذْغنْ ذِينِّي.  
\v 19 مَاغَارْ سِيذِي إِسّهْوَا يَاهُوذَا ذِي سِّيبّثْ ن أَحَازْ، أَجدْجِيذْ ن يَاهُوذَا، مِينْزِي نتَّا إِفُّوشّحْ ذِي يَاهُوذَا، إِغْذَارْ سِيذِي.  
\v 20 ثِيغْلَاثْ-فِيلْنَاسِيرْ، أَجدْجِيذْ ن أَشُّورْ، يُوسَا-د غَارسْ. نتَّا إِڭَّا خَاسْ بزّزْ ؤُ وَارْ ث إِسّجْهذْ.  
\v 21 مَاغَارْ \add عَاذْ مَاڒَا\add* أَحَازْ إِكْسِي \add أَڭْڒَا\add* زِي ثَادَّارْثْ ن سِيذِي ؤُ زِي ثَادَّارْثْ ن ؤُجدْجِيذْ ؤُ زِي ڒْحُوكَّامْ، إِوْشَا أَيَا إِ ؤُجدْجِيذْ ن أَشُّورْ، أَقَا مَانْ أَيَا وَارْ ذ أَسْ إِنفِّيعْ شَا.   
\m
\v 22 ذِي ڒْوقْثْ إِ ذِي إِتّْوَاحْصَارْ، يَارْنِي ؤُجدْجِيذْ أَحَازْ عَاذْ ذِي ڒْغذْرَانْ نّسْ زَّاثْ إِ سِيذِي.  
\v 23 نتَّا إِقدّمْ ثِيغَارْصَا إِ إِربِّيثنْ ن ذِيمَاشْقْ، إِنِّي خَاسْ إِغڒْبنْ، إِنَّا: ”مَاغَارْ إِربِّيثنْ ن إِجدْجِيذنْ ن أَرَامْ وْشِينْ أَسنْ أَفُوسْ، نشّْ أَذْ أَسنْ وهّْبغْ، حِيمَا أَذْ أَيِي وْشنْ أَفُوسْ عَاوذْ.“ \add مَاشَا\add* نِيثْنِي ذوْڒنْ ذ سِّيبّثْ ن ؤُوطُّو نّسْ ؤُ ن مَارَّا إِسْرَائِيل.  
\v 24 أَحَازْ إِسّْمُونْ ڒقْشُوعْ زِي ثَادَّارْثْ ن أَربِّي ؤُشَا يَارْژَا ڒقْشُوعْ ن ثَادَّارْثْ ن أَربِّي ذِي إِوثْوِيثنْ ؤُشَا إِبلّعْ ثِيوُّورَا ن ثَادَّارْثْ ن سِيذِي. نتَّا إِڭَّا إِعَالْطَارنْ إِ يِيخفْ نّسْ ذِي كُوڒْ ثَاغْمَارْثْ ن ؤُرْشَالِيمْ.  
\v 25 إِڭَّا ؤُڒَا ذ ڒڭْعُوذِي ذِي كُوڒْ ثَانْذِينْثْ ن يَاهُوذَا، حِيمَا أَذْ أَوْينْ ڒبْخُورْ إِ إِربِّيثنْ نّغْنِي. \add أَمُّو إِ\add* إِسْعَارْ نتَّا سِيذِي، أَربِّي ن ڒجْذُوذْ نّسْ.   
\m
\v 26 إِمزْرُوينْ إِقِّيمنْ ذ مَارَّا إِبْرِيذنْ نّسْ، إِمزْوُورَا ذ إِنڭُّورَا، خْزَارْ، أَقَا تّْوَازمّمنْ ذڭْ وذْلِيسْ ن إِجدْجِيذنْ ن يَاهُوذَا ذ إِسْرَائِيل.  
\v 27 أَحَازْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نضْڒنْ ث ذِي ثنْذِينْثْ، ذِي ؤُرْشَالِيمْ، مَاشَا وَارْ ث سَّارْسنْ شَا ذڭْ إِمضْڒَانْ ن إِجدْجِيذنْ ن إِسْرَائِيل. مِّيسْ حِيزْقِييَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\b  
\m  
\c 29
\s1 أَسِيزْذڭْ ن زَّاوشْثْ ثَامقّْرَانْثْ س ؤُفُوسْ ن حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 1 حِيزْقِييَا إِذْوڒْ ذ أَجدْجِيذْ ؤُمِي \add ثُوغَا\add* غَارسْ خمْسَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا. نتَّا إِحْكمْ ثسْعَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ أَبِييَا، يدْجِيسْ ن زَاكَارِييَّا.  
\v 2 نتَّا إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، نِيشَانْ أَمْ مَامّشْ ث إِڭَّا بَابَاسْ ذَاوُوذْ.  
\v 3 ذڭْ ؤُسڭّْوَاسْ أَمزْوَارُو ن ڒحْكَامثْ نّسْ، ذڭْ ؤُيُورْ أَمزْوَارُو، يَارْزمْ ثِيوُّورَا ن ثَادَّارْثْ ن سِيذِي ؤُشَا إِعْذڒْ إِ-ثنْثْ.  
\v 4 إِسِّيذفْ إِكهَّاننْ ذ إِلَاوِييّنْ ؤُشَا إِسّْمُونْ إِ-ثنْ خْ وَازَّايْ غَارْ ؤُغزْذِيسْ ن شَّارْقْ.  
\v 5 إِنَّا أَسنْ: ”سْڒمْ-د غَارِي، \add أَ\add* إِلَاوِييّنْ. سْقدّْسمْ إِخفْ نْومْ ؤُڒَا ذ ثَادَّارْثْ ن سِيذِي، أَربِّي ن ڒجْذُوذْ نْومْ، ؤُ كّْسمْ مَارَّا مِينْ إِخمْجنْ زِي زَّاوشْثْ إِقدّْسنْ.  
\v 6 مَاغَارْ ڒجْذُوذْ نّغْ ثُوغَا أَثنْ ذ إِغدَّارنْ ؤُ ڭِّينْ مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَربِّي نّغْ. نِيثْنِي حيّْذنْ خَاسْ، نّْقڒْبنْ ؤُذْمَاونْ نْسنْ زِي ثْزذِّيغْثْ ن سِيذِي ؤُشَا أَرِّينْ س وعْرُورْ غَارْ \add سِيذِي\add*.  
\v 7 عَاذْ ؤُڒَا ذ ثِيوُّورَا ن وسْقِيفْ ن وَاذَافْ \add ن زَّاوشْثْ\add* بلّْعنْ ثنْثْ، سّْخسْينْ ڒفْنَارَاثْ، وَارْ سَّارْغنْ ڒبْخُورْ ؤُ وَارْ سّْڭِيعّْذنْ \add عَاذْ\add* ثَاغَارْصْثْ ن وشْمَاضْ إِ أَربِّي ن إِسْرَائِيل ذِي زَّاوشْثْ إِقدّْسنْ.  
\v 8 س ؤُيَا يُوسَا-د ؤُذُوقّزْ أَمقّْرَانْ \add ن وغْضَابْ\add* ن سِيذِي خْ يَاهُوذَا ذ ؤُرْشَالِيمْ، ؤُشَا نتَّا يَارَّا إِ-ثنْ ذ إِشْثْ ن ڒْقشْعثْ ن ؤُنخْڒِيعْ ذ ؤُسِيڭّْوذْ ذ ثْسضْحَاشْثْ أَمْ مَامّشْ ثتّْوَاڒَامْ كنِّيوْ س ثِيطَّاوِينْ نْومْ.  
\v 9 خْزَارمْ، ڒجْذُوذْ نّغْ وْضَانْ س سِّيفْ ؤُ إِحنْجِيرنْ نّغْ، ثِيحنْجِيرِينْ نّغْ ذ ثمْغَارِينْ نّغْ أَقَا أَثنْ ذِي ڒحْبسْ خْ ؤُيَا.  
\v 10 ڒخُّو أَقَا-ت غَارِي ذڭْ وُوڒْ  إِنُو مَاحنْذْ أَذْ ڭّغْ إِجّْ ن ڒْعَاهْذْ أَكْ-ذ سِيذِي، أَربِّي ن إِسْرَائِيل، حِيمَا ڒْحَاذُوقْ ن وغْضَابْ نّسْ أَذْ خَانغْ إِبعّذْ.  
\v 11 \add أَ\add* أَرَّاونْ إِنُو، وَارْ أَرخُّومْ، مِينْزِي سِيذِي إِفَارْزْ إِ كنِّيوْ، أَقَا أَذْ ثْبدّمْ زَّاثْ إِ وُوذمْ نّسْ، حِيمَا أَذْ أَسْ ثْسخَّارمْ ؤُ حِيمَا كنِّيوْ أَذْ أَسْ ثِيڒِيمْ ذ إِمْسخَّارنْ نّسْ ؤُ أَذْ \add أَسْ\add* ثْقدّْممْ ڒبْخُورْ.“   
\m
\v 12 \add خنِّي\add* كَّارنْ إِلَاوِييّنْ: مَاحَاثْ، مِّيسْ ن عَامَاسَايْ، ذ يُووِيلْ، مِّيسْ ن عَازَارْيَا، زڭْ إِحنْجِيرنْ ن قُوحَاثْ. زڭْ وَارَّاونْ ن مَارَارِي، قِيسْ، مِّيسْ ن عَابْذِي، ذ عَازَارْيَا، مِّيسْ ن يَاهْلَايِيلْ. زڭْ وَارَّاونْ ن جَارْشُونْ، يُووَاخْ، مِّيسْ ن زِيمَّا، ذ عِيذَانْ، مِّيسْ ن يُووَاخْ.  
\v 13 زڭْ وَارَّاونْ ن إِلِيصَافَانْ، شِيمْرِي ذ يَاعِييِيلْ، ؤُ زڭْ وَارَّاونْ ن أَسَافْ، زَاكَارِييَّا ذ مَاتَّانْيَا.  
\v 14 زڭْ وَارَّاونْ ن هَايْمَانْ، يَاحِييِيلْ ذ شِيمْعِي، ؤُ زڭْ وَارَّاونْ ن يَاذُوثُونْ، شَامْعِييَا ذ عُوزِّييِيلْ.  
\v 15 نِيثْنِي سّْمُوننْ أَيْثْمَاثْسنْ ؤُشَا سّْقدّْسنْ إِخفْ نْسنْ عْلَاحْسَابْ ڒُومُورْ ن ؤُجدْجِيذْ ونِّي إِعمّْذنْ خْ وَاوَاڒنْ ن سِيذِي، حِيمَا أَذْ سِّيزذْڭنْ ثَادَّارْثْ ن سِيذِي.  
\v 16 ؤُذْفنْ إِكهَّاننْ غَارْ ثَادَّارْثْ ن سِيذِي، حِيمَا أَذْ ت سِّيزذْڭنْ ؤُشَا سُّوفّْغنْ مَارَّا ڒخْمجْ إِ ؤُفِينْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي غَارْ ڒمْرَاحْ ن ثَادَّارْثْ ن سِيذِي، ؤُشَا إِلَاوِييّنْ كْسِينْ ث، حِيمَا أَذْ ث أَوْينْ غَارْ بَارَّا، غَارْ ثغْزَارْثْ ن قِيذْرُونْ.  
\v 17 ذڭْ \add وَاسّْ\add* أَمزْوَارُو ن ؤُيُورْ أَمزْوَارُو بْذَانْ أَذْ سّْقدّْسنْ \add ثَادَّارْثْ\add* ؤُشَا ذڭْ وَاسْ وِيسّْ ثْمنْيَا ن ؤُيُورْ إِوْضنْ نِيثْنِي غَارْ وسْقِيفْ ن وَاذَافْ \add ن زَّاوشْثْ\add* ن سِيذِي. \add أَمُّو إِ\add* سّْقدّْسنْ ثَادَّارْثْ ن سِيذِي ذِي ثْمنْيَا ن وُوسَّانْ. ذڭْ وَاسّْ وِيسّْ سطَّاشْ ن ؤُيُورْ أَمزْوَارُو ثُوغَا كمّْڒنْ \add ڒْْخذْمثْ\add*.  
\v 18 نِيثْنِي ؤُذْفنْ غَارْ ؤُجدْجِيذْ حِيزْقِييَا، نَّانْ: ”نشِّينْ نسِّيزْذڭْ مَارَّا ثَادَّارْثْ ن سِيذِي، أَعَالْطَارْ ن وشْمَاضْ أَكْ-ذ مَارَّا دُّوزَانَاثْ نّسْ ذ ثْزوْضَا س وغْرُومْ ن وسْشَانْ أَكْ-ذ مَارَّا دُّوزَانَاثْ نّسْ.  
\v 19 مَارَّا ڒقْشُوعْ إِ إِنْضَارْ ؤُجدْجِيذْ أَحَازْ زِي ڒغْذَارْ نّسْ ذڭْ وُوسَّانْ ن ثْڭلْذَا نّسْ، نعْذڒْ إِ-ثنْ ؤُ نسّْقدّسْ إِ-ثنْ. أَقَا أَثنْ زَّاثْ إِ ؤُعَالْطَارْ ن سِيذِي.“   
\m
\v 20 \add خنِّي\add* إِكَّارْ ؤُجدْجِيذْ حِيزْقِييَا زِيشْ ؤُشَا إِسّْمُونْ إِمقّْرَاننْ ن ثنْذِينْثْ ؤُشَا إِڭعّذْ غَارْ ثَادَّارْثْ ن سِيذِي.  
\v 21 نِيثْنِي إِوْينْ-د سبْعَا ن إِفُونَاسنْ إِمژْيَاننْ، سبْعَا ن إِشَارِّييّنْ، سبْعَا ن إِزْمَارنْ ذ سبْعَا ن إِمُويَانْ ن إِغَايْضنْ، مَاحنْذْ \add أَذْ إِڒِينْ\add* ذ ثَاغَارْصْثْ ن دّنْبْ إِ ثْڭلْذِيثْ، ڒَا إِ زَّاوشْثْ إِقدّْسنْ ؤُڒَا إِ يَاهُوذَا، ؤُشَا نتَّا إِنَّا إِ وَارَّاونْ ن هَارُونْ، إِكهَّاننْ، حِيمَا أَذْ ثنْ قدّْمنْ خْ ؤُعَالْطَارْ ن سِيذِي.  
\v 22 غَارْصنْ إِ إِفُونَاسنْ ؤُشَا سّڒْقَانْ إِكهَّاننْ إِ إِذَامّنْ ؤُشَا رُوشّنْ ثنْ خْ ؤُعَالْطَارْ. نِيثْنِي غَارْصنْ ؤُڒَا إِ إِشَارِّييّنْ ؤُشَا زدْجْعنْ إِذَامّنْ خْ ؤُعَالْطَارْ. غَارْصنْ ؤُڒَا إِ إِزْمَارنْ ؤُشَا زدْجْعنْ إِذَامّنْ خْ ؤُعَالْطَارْ.  
\v 23 نِيثْنِي إِوْينْ-د إِمُويَانْ إِ ثْغَارْصْثْ ن دّنْبْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ذ وڭْرَاوْ \add ن ڒْڭنْسْ\add*، ؤُشَا سَّارْسنْ خَاسنْ إِفَاسّنْ نْسنْ.  
\v 24 إِكهَّاننْ غَارْصنْ أَسنْ ؤُ س إِذَامّنْ نْسنْ سِّيزذْڭنْ أَعَالْطَارْ زِي دّنْبْ، حِيمَا أَذْ ڭّنْ أَصْڒَاحْ إِ مَارَّا إِسْرَائِيل، مَاغَارْ أَجدْجِيذْ ثُوغَا إِڭَّا ثَاغَارْصْثْ ن وشْمَاضْ ذ ثْغَارْصْثْ ن دّنْبْ \add نِّي\add* إِ مَارَّا إِسْرَائِيل.  
\v 25 نتَّا إِسّْبدّْ إِلَاوِييّنْ ذِي ثَادَّارْثْ ن سِيذِي س ثَادْجُونِينْ ن وُوزَّاڒْ ذ ڒْڭَامْبْرِييَاثْ ذ لهَارْپَاثْ، عْلَاحْسَابْ ڒُومُورْ ن ذَاوُوذْ ذ جَاذْ، أَمْوَاڒَاوْ ن ؤُجدْجِيذْ، ذ ؤُنَابِي نَاثَانْ، مِينْزِي ڒُومُورْ-أَ ثُوغَا إِ د-يُوسَا زِي سِيذِي س ؤُقمُّومْ ن إِنَابِييّنْ.  
\v 26 أَيْثْ ن لَاوِي بدّنْ \add ذِينْ\add* أَكْ-ذ دُّوزَانَاثْ \add ن لْمُوسِيقَا\add* ن ذَاوُوذْ ؤُ إِكهَّاننْ أَكْ-ذ ڒبْوَاقْ.   
\m
\v 27 \add خنِّي\add* يُومُورْ حِيزْقِييَا أَذْ أَوْينْ ثَاغَارْصْثْ ن وشْمَاضْ خْ ؤُعَالْطَارْ. ذِي ثْسَاعّثْ إِ ذِي ثبْذَا ثْغَارْصْثْ ن وشْمَاضْ، إِبْذَا ؤُڒَا ذ أَزهّذْ إِ سِيذِي س ڒبْوَاقْ ؤُ س دُّوزَانَاثْ \add ن لْمُوسِيقَا\add* ن ذَاوُوذْ، أَجدْجِيذْ ن إِسْرَائِيل.  
\v 28 مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* إِبنْذقْ، أَمْ تّْغنَّاجنْ ؤُ تّْسُوضَانْ ذِي ڒبْوَاقْ. مَانْ أَيَا مَارَّا إِكَّا أَڒَامِي ثتّْوَاكمّڒْ ثْغَارْصْثْ ن وشْمَاضْ.  
\v 29 \add ؤُمِي\add* إِكمّڒْ ؤُسِيوضْ ن ثْغَارْصْثْ ن وشْمَاضْ، إِوْضَا ؤُجدْجِيذْ خْ إِفَادّنْ نّسْ ذ مَارَّا إِنِّي ثُوغَا غَارسْ إِدْجَانْ، ؤُشَا بنْذْقنْ.  
\v 30 أَوَارْنِي ؤُيَا إِنَّا ؤُجدْجِيذْ حِيزْقِييَا ذ ڒْحُوكَّامْ إِ إِلَاوِييّنْ، أَذْ سّْعُودْجَانْ سِيذِي س وَاوَاڒنْ ن ذَاوُوذْ ؤُ ن ؤُمْوَاڒَاوْ أَسَافْ. سّْعُودْجَانْ \add عَاذْ\add* س ڒفْرَاحثْ، \add خنِّي\add* ؤُضَارنْ ؤُشَا بنْذْقنْ.   
\m
\v 31 حِيزْقِييَا يَارَّا-د، إِنَّا: ”ڒخُّو كنِّيوْ ثتّْوَاڒقّْممْ \add ذ إِكهَّاننْ\add* إِ سِيذِي. أَستِّيوْ-د ؤُشَا أَوْيمْ-د ثِيغَارْصَا ذ ثوْهِيبِينْ ن ؤُقَاذِي إِ ثَادَّارْثْ ن سِيذِي.“ \add خَاسْ ؤُشَا\add* يِيوِي-د وڭْرَاوْ \add ن ڒْڭنْسْ\add* ثِيغَارْصَا ذ ثوْهِيبِينْ ن ؤُقَاذِي، ؤُ مَارَّا إِنِّي إِ غَارْ ت ثُوغَا ذِي ڒْخَاذَارْ نْسنْ، إِوْينْ-د ثِيغَارْصَا ن وشْمَاضْ.  
\v 32 ڒْقدّْ ن ثْغَارْصَا ن وشْمَاضْ إِ د-يِيوِي وڭْرَاوْ \add ن ڒْڭنْسْ\add*، أَقَا-ث ذِي سبْعِينْ ن إِفُونَاسنْ ذ مْيَا ن إِشَارِّييّنْ ذ مِيثَاينْ ن إِزْمَارنْ. نِيثْنِي مَارَّا تّْوَاوْينْ-د ذ ثَاغَارْصْثْ ن وشْمَاضْ إِ سِيذِي.  
\v 33 ثِيوْهِيبِينْ إِقدّْسنْ أَقَا أَثنْثْ ذِي ستَّا-مْيَا ن إِفُونَاسنْ ذ ثڒْثْ-أَڒَافْ ن وُودْجِي.  
\v 34 مَاشَا أَقَا ذِينْ ذْرُوسْ ن إِكهَّاننْ، ؤُ نِيثْنِي وَارْ زمَّارنْ أَذْ سَّارْخُونْ ثِيڒْمشْثْ ن مَارَّا ثِيغَارْصَا ن وشْمَاضْ. س ؤُيَا عَاوْننْ ثنْ أَيْثْمَاثْسنْ إِلَاوِييّنْ، أَڒَامِي كمّْڒنْ ڒْخذْمثْ ؤُ أَڒَامِي إِكهَّاننْ نّغْنِي ثُوغَا سّْقدّْسنْ إِخفْ نْسنْ، مِينْزِي إِلَاوِييّنْ ثُوغَا سڭّْذنْ ذڭْ وُوڒْ كْثَارْ زڭْ إِكهَّاننْ حِيمَا أَذْ سّْقدّْسنْ إِخفْ نْسنْ.  
\v 35 ثُوغَا ذِينْ عَاوذْ أَطَّاسْ ن ثْغَارْصَا ن وشْمَاضْ أَكْ-ذ ثَاذُونْثْ ن ثوْهِيبِينْ ن ڒهْنَا ذ ثوْهِيبِينْ ن ؤُسيّبْ إِ ثْغَارْصَا ن وشْمَاضْ. \add أَمُّو\add* إِ ثتّْوَاعْذڒْ ثْسخَّارْثْ ن ثَادَّارْثْ ن سِيذِي.  
\v 36 حِيزْقِييَا ذ مَارَّا ڒْڭنْسْ فَارْحنْ خْ مِينْ ثُوغَا إِسّوْجذْ أَربِّي إِ ڒْڭنْسْ، مَاغَارْ ثَامسْڒَاشْثْ ثتّْوَاڭّْ بْڒَا مَا أَذْ أَسْ ڭّنْ ڒحْسَابْ.   
\b  
\b  
\m  
\c 30
\s1 ڒْعِيذْ ن ثَاغَارْصْثْ ن ؤُسعْذُو ذڭْ وُوسَّانْ ن ڒْحُوكْمْ ن حِيزْقِييَا  
\m
\v 1 \add أَوَارْنِي ؤُيَا\add* إِسّكّْ حِيزْقِييَا \add إِرقَّاسنْ\add* غَارْ مَارَّا إِسْرَائِيل ذ يَاهُوذَا ؤُ يُورَا ثِيبْرَاثِينْ إِ إِفْرَايِيمْ ذ مَانَاسَّا، حِيمَا أَذْ د-أَسنْ غَارْ ثَادَّارْثْ ن سِيذِي ذِي ؤُرْشَالِيمْ أَذْ ڭّنْ \add ڒْْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو إِ سِيذِي، أَربِّي ن إِسْرَائِيل.  
\v 2 مَاغَارْ إِمْشَاوَارْ ؤُجدْجِيذْ أَكْ-ذ ڒْحُوكَّامْ نّسْ ذ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ذِي ؤُرْشَالِيمْ، حِيمَا أَذْ ڭّنْ \add ڒْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو ذڭْ ؤُيُورْ وِيسّْ ثْنَاينْ،  
\v 3 مَاغَارْ نِيثْنِي وَارْ زمَّارنْ أَذْ ث ڭّنْ ذِي ڒْوقْثْ \add نّسْ إِتّْوَاڭّنْ\add*، مِينْزِي أَطَّاسْ ن إِكهَّاننْ وَارْ تّْوَاقدّْسنْ شَا أَمْ د-إِتّْڒِيقْ، ؤُ ڒْڭنْسْ وَارْ ثُوغِي إِمُونْ \add عَاذْ\add* ذِي ؤُرْشَالِيمْ.  
\v 4 ثَامسْڒَاشْثْ-أَ ثُوغَا-ت نِيشَانْ ذِي ثِيطَّاوِينْ ن ؤُجدْجِيذْ ؤُ ذِي ثِيطَّاوِينْ ن مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add*.  
\v 5 نِيثْنِي ڭِّينْ، أَذْ بَارّْحنْ ذِي مَارَّا إِسْرَائِيل زِي ذَانْ أَڒْ بِئرْ-سبْعَا، حِيمَا أَذْ د-أَسنْ أَذْ ڭّنْ \add ڒْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو إِ سِيذِي، أَربِّي ن إِسْرَائِيل، ذِي ؤُرْشَالِيمْ، مَاغَارْ وَارْ ت ڭِّينْ أَطَّاسْ \add ن ڒْوقْثْ\add* أَمْ مَامّشْ ثُوغَا ثُورَا.   
\m
\v 6 إِرقَّاسنْ ن ثَازْڒَا كِّينْ س ثبْرَاثِينْ ن ؤُجدْجِيذْ ذ ڒْحُوكَّامْ نّسْ ذڭْ ؤُفُوسْ خْ مَارَّا إِسْرَائِيل ذ يَاهُوذَا، ؤُ \add بَارّْحنْ\add* أَمْ مَامّشْ ث يُومُورْ ؤُجدْجِيذْ، نَّانْ: ”كنِّيوْ، أَيْثْ ن إِسْرَائِيل، ذوْڒمْ-د غَارْ سِيذِي، أَربِّي ن إِبْرَاهِيمْ، إِسْحَاقْ ذ إِسْرَائِيل، \add خنِّي\add* نتَّا أَذْ د-إِذْوڒْ غَارْ يِينِّي إِنّجْمنْ زڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن أَشُّورْ، غَارْ يِينِّي إِ غَارْومْ إِقِّيمنْ.  
\v 7 وَارْ تِّيڒِيمْ أَمْ ڒجْذُوذْ نْومْ ذ أَيْثْمَاثْومْ، إِنِّي إِغْذَارنْ سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ، أَڒَامِي ثنْ إِسلّمْ نتَّا غَارْ ؤُنخْڒِيعْ، أَمْ مَامّشْ ثتّْوَاڒَامْ \add س يِيخفْ نْومْ\add*.  
\v 8 وَارْ سّقْسَاحمْ ڒخُّو إِرَاونْ نْومْ، إِڒِيمْ أَمْ ڒجْذُوذْ نْومْ. وْشمْ أَفُوسْ إِ سِيذِي ؤُ أَسمْ-د غَارْ زَّاوشْثْ نّسْ إِقدّْسنْ ثنِّي إِسّْقدّسْ نتَّا إِ ڒبْذَا. سخَّارمْ إِ سِيذِي، أَربِّي نْومْ، \add خنِّي\add* أَذْ خَاومْ إِحيّذْ ڒْحَاذُوقْ ن وغْضَابْ نّسْ.  
\v 9 مَاڒَا كنِّيوْ ثْذوْڒمْ-د غَارْ سِيذِي، أَذْ أَفنْ أَيْثْمَاثْومْ ذ إِحنْجِيرنْ نْومْ أَرّحْمثْ زَّاثْ إِ وُوذمْ ن يِينِّي إِ-ثنْ إِحبّْسنْ أَڒَامِي غَا د-ذوْڒنْ غَارْ ثمُّورْثْ-أَ. مَاغَارْ سِيذِي، أَربِّي نْومْ، ذ بَابْ ن ؤُحِينِّي ذ أَرّحْمثْ ؤُ نتَّا وَارْ خَاومْ إِسّْحيِّيذْ شَا ؤُذمْ مَاڒَا كنِّيوْ ثْذوْڒمْ-د غَارسْ.“   
\m
\v 10 \add أَمُّو\add* إِ ؤُيُورنْ إِرقَّاسنْ ن ثَازْڒَا زِي ثنْذِينْثْ غَارْ ثنْذِينْثْ، \add كِّينْ\add* خْ ثمُّورْثْ ن إِفْرَايِيمْ ذ مَانَاسَّا أَڒْ زابُولُونْ، مَاشَا \add إِوْذَانْ\add* حشّنْ خَاسنْ ؤُ كّْوَارنْ ثنْ \add إِوْذَانْ\add*.  
\v 11 مَاشَا شَا ن يرْيَازنْ زِي أَشِيرْ، مَانَاسَّا ذ زابُولُونْ سّْوَاضْعنْ إِخفْ نْسنْ ؤُشَا ؤُسِينْ-د غَارْ ؤُرْشَالِيمْ.  
\v 12 ؤُڒَا ذِي يَاهُوذَا إِنْذهْ ؤُفُوسْ ن سِيذِي ؤُشَا إِڭَّا أَذْ ضْفَارنْ ڒُومُورْ ن ؤُجدْجِيذْ ؤُ ن ڒْحُوكَّامْ عْلَاحْسَابْ أَوَاڒْ ن سِيذِي، س وُوڒْ ذْ إِجّنْ.  
\v 13 مُوننْ وَاطَّاسْ \add ن يوْذَانْ زِي\add* ڒْڭنْسْ ذِي ؤُرْشَالِيمْ، حِيمَا أَذْعيّْذنْ ڒْعِيذْ ن وغْرُومْ بْڒَا أَنْثُونْ ذڭْ ؤُيُورْ وِيسّْ ثْنَاينْ. \add أَمُّو إِ ثُوغَا ذِينْ\add* إِجّْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add* ذ أَمقّْرَانْ أَطَّاسْ.   
\m
\v 14 نِيثْنِي كَّارنْ ؤُ كّْسنْ إِعَالْطَارنْ نِّي \add إِدْجَانْ\add* ذِي ؤُرْشَالِيمْ. كّْسنْ ؤُڒَا ذ مَارَّا إِعَالْطَارنْ ن ڒبْخُورْ ؤُشَا نْضَارنْ ثنْ ذِي ثغْزَارْثْ ن قِيذْرُونْ.  
\v 15 ذڭْ وَاسّْ وِيسّْ أَرْبعْطَاشْ ن ؤُيُورْ وِيسّْ ثْنَاينْ غَارْصنْ نِيثْنِي إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو. إِكهَّاننْ ذ إِلَاوِييّنْ إِوْضنْ أَذْ سضْحَانْ ؤُ بْذَانْ أَذْ سّْقدّْسنْ إِخفْ نْسنْ ؤُشَا إِوْينْ ثِيغَارْصَا ن وشْمَاضْ غَارْ ثَادَّارْثْ ن سِيذِي.  
\v 16 نِيثْنِي بدّنْ ذڭْ ومْشَانْ نْسنْ أَمْ مَامّشْ إِ ثڭُّورْ غَارْسنْ عْلَاحْسَابْ شَّارِيعَا ن مُوسَا، أَرْيَازْ ن أَربِّي. إِكهَّاننْ زدْجْعنْ إِذَامّنْ \add نِّي كْسِينْ\add* زڭْ إِفَاسّنْ ن إِلَاوِييّنْ.  
\v 17 مِينْزِي أَطَّاسْ ذڭْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* ثُوغَا وَارْ سّْقدّْسنْ إِخفْ نْسنْ. س ؤُيَا تّْوَاڭّنْ إِلَاوِييّنْ خْ ثْغَارْصْثْ ن إِزْمَارنْ ن \add ثْغَارْصْثْ ن\add* ؤُسعْذُو إِ مَارَّا إِنِّي وَارْ إِزْذِيڭنْ، حِيمَا أَذْ ثنْ سّْقدّْسنْ إِ سِيذِي.  
\v 18 مَاغَارْ أَزْينْ أَمقّْرَانْ ن ڒْڭنْسْ، \add زَّايْسنْ\add* أَطَّاسْ زِي إِفْرَايِيمْ ذ مَانَاسَّا ذ إِسَّاكَارْ ذ زابُولُونْ، ثُوغَا وَارْ سِّيزذْڭنْ إِخفْ نْسنْ. نِيثْنِي شِّينْ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو وَارْ إِدْجِي أَمْ مَامّشْ ثُورَا. مَاشَا حِيزْقِييَا إِژُّودْجْ إِ نِيثْنِي، إِنَّا: ”سِيذِي إِشْنَا، إِڒِي نتَّا أَذْ إِڭّْ أَصْڒَاحْ إِ نِيثْنِي، \f ◼ \fr 30:‏18 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78‏:35.\f*  
\v 19 \add خْ\add* كُوڒْ إِجّْ ونِّي إِنْوَانْ أَذْ يَارْزُو س مَارَّا ؤُڒْ نّسْ خْ أَربِّي، سِيذِي، أَربِّي ن ڒجْذُوذْ نّسْ، وَاخَّا وَارْ إِدْجِي س ؤُسِيزْذڭْ \add إِ إِتّْڒِيقنْ\add* إِ زَّاوشْثْ إِقدّْسنْ.“  
\v 20 إِسْڒَا سِيذِي غَاڒْ حِيزْقِييَا ؤُشَا إِسّْڭنْفَا ڒْڭنْسْ.   
\m
\v 21 \add أَمُّو\add* إِعيّْذنْ أَيْثْ ن إِسْرَائِيل، إِنِّي ثُوغَا إِنّْيَارْونْ ذِي ؤُرْشَالِيمْ، سبْعَا ن وُوسَّانْ ن ڒْعِيذْ ن وغْرُومْ بْڒَا أَنْثُونْ س ڒفْرَاحثْ ثَامقّْرَانْثْ. أَيْثْ ن لَاوِي ذ إِكهَّاننْ سّْعُودْجَانْ سِيذِي أَسّْ خْ وَاسّْ س جّهْذْ ن دُّوزَانَاثْ \add ن لْمُوسِيقَا\add* \add إِ ؤُعُودْجِي\add* ن سِيذِي.  
\v 22 إِسِّيوڒْ حِيزْقِييَا غَارْ وُوڒْ ن مَارَّا إِلَاوِييّنْ إِنِّي غَارْ ثدْجَا ڒفْهَامثْ إِشْنَانْ ن ثُوسّْنَا ن سِيذِي. شِّينْ سبْعَا ن وُوسَّانْ زِي ثْغَارْصَا ذِي ڒْوقْثْ إِتّْوَاڭّنْ \add ن ڒْعِيذْ\add*، \add أَمْ\add* ثُوغَا إِوْينْ ثِيوْهِيبِينْ ن ڒهْنَا ؤُ قَاذَانْ سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ.  
\v 23 \add ؤُمِي\add* إِمْشَاوَارْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* مَارَّا مَاحنْذْ أَذْ ث ڭّنْ إِشْثْ ن ثْوَاڒَا نّغْنِيثْ إِ سبْعَا ن وُوسَّانْ، أَرْنِينْ نِيثْنِي \add عَاذْ\add* سبْعَا ن وُوسَّانْ \add شُّورنْ\add* س ڒفْرَاحثْ،  
\v 24 مَاغَارْ حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ثُوغَا إِوْشَا أَڒفْ ن إِفُونَاسنْ إِمژْيَاننْ ذ سبْعَا-أَڒَافْ ن وُودْجِي ؤُشَا ڒْحُوكَّامْ ثُوغَا وْشِينْ أَڒفْ ن إِفُونَاسنْ إِمژْيَاننْ ذعشْرَا-أَڒَافْ ن وُودْجِي. إِجّْ ن ؤُبَارُّو ن إِكهَّاننْ ثُوغَا سّْقدّْسنْ \add إِخفْ نْسنْ زَّايْسنْ\add*.   
\m
\v 25 إِفَارْحْ مَارَّا وڭْرَاوْ \add ن ڒْڭنْسْ\add* ن يَاهُوذَا، ؤُڒَا ذ إِكهَّاننْ ذ إِلَاوِييّنْ ذ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن يِينِّي د-يُوسِينْ زِي إِسْرَائِيل، ؤُڒَا ذ إِبَارَّانِييّنْ نِّي د-يُوسِينْ زِي إِسْرَائِيل ذ يِينِّي إِزدّْغنْ ذِي \add ثمُّورْثْ ن\add* يَاهُوذَا.  
\v 26 ثُوغَا ذِينْ ڒفْرَاحثْ ذ ثَامقّْرَانْثْ ذِي ؤُرْشَالِيمْ، مَاغَارْ زڭْ وُوسَّانْ ن سُولِيمَانْ، مِّيسْ ن ذَاوُوذْ، أَجدْجِيذْ ن إِسْرَائِيل، ثُوغَا وَارْ إِمْسَارْ أَمْ ؤُيَا ذِي ؤُرْشَالِيمْ.  
\v 27 \add خنِّي\add* بدّنْ إِكهَّاننْ ن إِلَاوِييّنْ ؤُشَا بَارْكنْ ڒْڭنْسْ. ثْمِيجَّا نْسنْ ثتّْوَاسڒْ، مَاغَارْ ثَاژَادْجِيثْ نْسنْ ثُوذفْ غَارْ ثْزذِّيغْثْ ثَامْقدّسْثْ نّسْ ذڭْ ؤُجنَّا.   
\b  
\b  
\m  
\c 31
\s1 أَعْذَاڒْ ن ڒْخذْمثْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ  
\m
\v 1 أَوَارْنِي ڒَامِي كمّْڒنْ س مَانْ أَيَا مَارَّا، فّْغنْ-د مَارَّا أَيْثْ ن إِسْرَائِيل نِّي ثُوغَا ذِينْ إِدْجَانْ غَارْ ثْندَّامْ ن يَاهُوذَا ؤُ أَرْژِينْ إِمَايْضُوثنْ \add إِقدّْسنْ\add*، هذْمنْ ثِيربِّينْ ن شْوَارْثِي ؤُشَا كّْسنْ ڒڭْعُوذِي ذ إِعَالْطَارنْ زِي مَارَّا يَاهُوذَا ذ بِينْيَامِينْ. \add أَمُّو إِ ڭِّينْ ؤُڒَا\add* ذِي إِفْرَايِيمْ ذ مَانَاسَّا أَڒَامِي ت كمّْڒنْ. \add أَوَارْنِي ؤُيَا\add*عقْبنْ مَارَّا أَيْثْ ن إِسْرَائِيل، كُوڒْ إِجّْ غَارْ وَاڭْڒَا نّسْ، \add مَارَّا نِيثْنِي\add* غَارْ ثْندَّامْ نْسنْ.   
\m
\v 2 حِيزْقِييَا إِسّْبدّْ ثِيرْبِيعِينْ ن إِكهَّاننْ ذ إِلَاوِييّنْ عْلَاحْصَابْ ثِيرْبِيعِينْ نْسنْ، كُوڒْ إِجّْ عْلَاحْسَابْ ثَاسخَّارْثْ نّسْ: إِكهَّاننْ ذ إِلَاوِييّنْ إِ ثْغَارْصْثْ ن وشْمَاضْ ؤُ إِ ثوْهِيبِينْ ن ڒهْنَا، حِيمَا أَذْ سخَّارنْ، أَذْ قَاذَانْ ؤُ أَذْ سّْعُودْجَانْ ذِي ثوُّورَا ن ڒمْرَاڭحْ ن ڒْعسْكَارْ ن سِيذِي.   
\m
\v 3 \add نتَّا إِوْشَا\add* ؤُڒَا ذ ثَاوْهِيبْثْ ن ؤُجدْجِيذْ زڭْ وَاڭْڒَا نّسْ إِ ثْغَارْصَا ن وشْمَاضْ، إِ ثْغَارْصَا ن وشْمَاضْ غَارْ ثُوفُّوثْ ؤُ غَارْ ثْمذِّيثْ، ؤُڒَا ذ ثِيغَارْصَا ن وشْمَاضْ إِ وُوسَّانْ ن سّبْثْ، إِ ؤُيُورنْ إِمَايْنُوثنْ ؤُ إِ ڒعْيُوذَاثْ إِتّْوَاڭّنْ، أَمْ مَامّشْ ثُورَا ذِي شَّارِيعَا ن سِيذِي.  
\v 4 نتَّا إِنَّا إِ ڒْڭنْسْ، إِ إِمزْذَاغْ ن ؤُرْشَالِيمْ، أَذْ وهّْبنْ ثَاسْغَارْثْ ن إِكهَّاننْ ذ إِلَاوِييّنْ، حِيمَا إِنَا \add زمَّارنْ\add* أَذْ إِڒِينْ جهْذنْ ذِي ثْغُورِي ن شَّارِيعَا ن سِيذِي.  
\v 5 \add ؤُمِي\add* د-إِفّغْ وَاوَاڒْ نِّي، إِوْينْ-د أَيْثْ ن إِسْرَائِيل س ؤُفيّضْ \add زڭْ\add* ؤُسُوفّغْ أَمزْوَارُو ن إِمنْذِي، ن بِينُو ن جْذِيذْ ذ زّشْثْ ذ ثَامّنْثْ ؤُ زِي مَارَّا ڒْغِيدْجثْ ن ييَّارْ. إِوْينْ ؤُڒَا ذ ڒعْشُورْ زِي مَارَّا س ؤُفيّضْ.  
\v 6 ثَارْوَا ن إِسْرَائِيل ذ يَاهُوذَا، إِنِّي إِزذْغنْ ذِي ثْندَّامْ ن يَاهُوذَا، إِوْينْ ؤُڒَا ذ ڒعْشُورْ زڭْ إِفُونَاسنْ ؤُ زڭْ وُودْجِي ؤُڒَا ذ ڒعْشُورْ ن ثوْهِيبِينْ إِقدّْسنْ نِّي ثُوغَا سّْقدّْسنْ إِ سِيذِي، أَربِّي نْسنْ، ؤُشَا وْشِينْ \add ثنْ\add*، ڭِّينْ \add زَّايْسنْ\add* إِعُورَّاشْ.  
\v 7 ذڭْ ؤُيُورْ وِيسّْ ثْڒَاثَا بْذَانْ نِيثْنِي أَذْ \add زَّايْسنْ\add* ڭّنْ إِعُورَّاشْ زِي ثِيسِي ؤُ ذڭْ ؤُيُورْ وِيسّْ سبْعَا كمّْڒنْ ت.  
\v 8 \add ؤُمِي\add* حِيزْقِييَا ذ ڒْحُوكَّامْ ؤُسِينْ-د ؤُ ژْرِينْ إِعُورَّاشْ نِّي، بَارْكنْ سِيذِي ذ ڒْڭنْسْ نّسْ إِسْرَائِيل.  
\v 9 إِسّقْسَا حِيزْقِييَا إِكهَّاننْ ذ إِلَاوِييّنْ خْ إِعُورَّاشْ نِّي.  
\v 10 عَازَارْيَا، أَكهَّانْ أَمقّْرَانْ زِي ثَادَّارْثْ ن صَاذُوقْ يَارَّا-د خَاسْ، إِنَّا: ”زڭْ وَامِي د-نكَّارْ أَذْ نَاوِي ثَاوْهِيبْثْ ن ؤُسْڭعّذْ غَارْ ثَادَّارْثْ ن سِيذِي، أَقَا غَارْنغْ مِينْ غَا نشّْ أَڒْ ثْيَاوَانْثْ ؤُشَا عَاذْ إِقِّيمْ أَطَّاسْ إِشطّْ، مَاغَارْ سِيذِي إِبَاركْ ڒْڭنْسْ نّسْ، أَڒَامِي إِقِّيمْ ڒْقدّْ-أَ ن وَاطَّاسْ إِشطّْ.“   
\m
\v 11 \add خنِّي\add* إِنَّا حِيزْقِييَا، أَذْ سّْوجْذنْ إِخَّامنْ ن ثَادَّارْثْ ن سِيذِي، ؤُ نِيثْنِي سّْوجْذنْ ثنْ.  
\v 12 نِيثْنِي سِّيذْفنْ ثَاوْهِيبْثْ ن ؤُسْڭعّذْ ذ ڒعْشُورْ ذ ثوْهِيبِينْ إِقدّْسنْ ذِينْ س ڒَامَانْ. كُونَانْيَا، أَلَاوِي، أَمحْضَايْ، ذ ؤُمَاسْ شِيمْعِي، ونِّي ذ وِيسّْ ثْنَاينْ، ثُوغَا أَثنْ خْ مَانْ أَيَا \add مَارَّا\add*.  
\v 13 يَاحِييِيلْ، عَازَازْيَا، نَاحَاثْ، عَسَائِيلْ، يَارِيمُوثْ، يُوزَابَاذْ، إِلِييِيلْ، يِيسْمَاخْيَا، مَاحَاثْ، بَانَايَا \add ثُوغَا أَثنْ ذ\add* إِوقَّافنْ سَاذُو ؤُفُوسْ ن كُونَانْيَا ذ شِيمْعِي، ؤُمَاسْ، خْ ڒُومُورْ ن ؤُجدْجِيذْ حِيزْقِييَا ؤُ ن عَازَارْيَا، أَمحْضَايْ ن ثَادَّارْثْ ن أَربِّي.  
\v 14 قُورِي، مِّيسْ ن يِيمْنَا، أَلَاوِي، أَعسَّاسْ ن ثوَّارْثْ غَارْ ؤُغزْذِيسْ ن شَّارْقْ، \add إِتّْوَاڭّْ\add* خْ ثوْهِيبِينْ ن ڒْخَاضَارْ ن أَربِّي، حِيمَا أَذْ إِبْضَا ثَاوْهِيبْثْ ن ؤُسْڭعّذْ ن سِيذِي ذ ثوْهِيبِينْ إِقدّْسنْ قَاعْ.  
\v 15 عَاذَانْ، مِينْيَامِينْ، يشُوعَا، شَامْعِييَا، أَمَارْيَا ذ شَاكُونْيَا بدّنْ س ڒْمَانثْ غَارْ ؤُغزْذِيسْ نّسْ عْلَاحْصَابْ ثِيرْبِيعِينْ نْسنْ، حِيمَا أَذْ وزّْعنْ ذِي ثْندَّامْ ن إِكهَّاننْ إِ أَيْثْمَاثْسنْ، أَمْ إِ إِمقّْرَاننْ، أَمْ إِ إِمژْيَاننْ،  
\v 16 مَاشَا \add وَارْ إِدْجِي\add* إِ يِينِّي إِتّْوَازمّمنْ ذِي لِيسْثَا ن جَّاذِيرَا ن يرْيَازنْ إِ غَارْ إِدْجَا ثْڒَاثَا ن إِسڭّْوُوسَا سنّجْ، أَقَا مَارَّا إِنِّي د-يُوسِينْ غَارْ ثَادَّارْثْ ن سِيذِي إِ ڒْخذْمثْ ن كُوڒْ أَسّْ إِ وَاسّْ نِّي، إِ ڒْخذْمثْ نْسنْ ذِي ثْسخَّارْثْ نْسنْ، عْلَاحْسَابْ ثِيرْبِيعِينْ نْسنْ.  
\v 17 أَزمّنْ ذِي لِيسْثَا ن جَّاذِيرَا ن إِكهَّاننْ \add ثُوغَا-ث\add* عْلَاحْصَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْسنْ، \add مَاشَا\add* \add أَزمّمْ\add* ن إِلَاوِييّنْ زِي عِيشْرِينْ ن إِسڭّْوُوسَا سنّجْ، \add ثُوغَا-ث\add* عْلَاحْسَابْ ثَاسخَّارْثْ نْسنْ، عْلَاحْسَابْ ثِيرْبِيعِينْ نْسنْ.  
\v 18 \add نِيثْنِي وزّْعنْ\add* إِ يِينِّي إِتّْوَازمّمنْ ذِي لِيسْثَا ن جَّاذِيرَا أَكْ-ذ مَارَّا ثَارْوَا نْسنْ ذ ثمْغَارِينْ نْسنْ ذ إِحنْجِيرنْ نْسنْ ذ ثْحنْجِيرِينْ نْسنْ زِي مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add*، مَاغَارْ نِيثْنِي ڭِّينْ س ڒَامَانْ ؤُمِي سّْقدّْسنْ إِخفْ نْسنْ س ثِيذتّْ.  
\v 19 جَارْ وَارَّاونْ ن هَارُونْ، إِكهَّاننْ، ذڭْ إِيَّارنْ ن دّْمَانِي ن ثْندَّامْ نْسنْ، ذِي كُوڒْ ثَانْذِينْثْ، \add ثُوغَا ذِينْ\add* إِرْيَازنْ نِّي إِتّْوَازمّمنْ س إِسْمَاونْ \add نْسنْ\add* حِيمَا أَذْ وْشنْ ثَاسْغَارْثْ إِ مَارَّا أَوْثمْ جَارْ إِكهَّاننْ ؤُ إِ مَارَّا إِنِّي إِتّْوَازمّمنْ ذِي لِيسْثَا ن جَّاذِيرَا جَارْ إِلَاوِييّنْ.   
\m
\v 20 \add أَمُّو\add* إِ إِڭَّا حِيزْقِييَا ذِي مَارَّا يَاهُوذَا. نتَّا إِڭَّا مِينْ إِدْجَانْ إِشْنَانْ ذ إِسڭّْذنْ ذ نِيشَانْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّسْ.  
\v 21 مَارَّا ڒْخذْمثْ إِ إِبْذَا ذِي طّْوعْ ن ثْسخَّارْثْ ن ثَادَّارْثْ ن أَربِّي ؤُ ذِي طّْوعْ ن شَّارِيعَا ذ ثوْصيّثْ حِيمَا أَذْ يَارْزُو \add أَمُّو\add* أَربِّي، إِڭَّا إِ-ت س مَارَّا ؤُڒْ نّسْ ؤُشَا إِفْڒحْ.   
\b  
\b  
\m  
\c 32
\s1 أَهجّمْ ن سَانْحَارِيبْ ذ وعْقبْ نّسْ  
\m
\v 1 أَوَارْنِي ثمْسَارِينْ-أَ ذ وسْشَانْ-أَ ن ڒَامَانْ، يُوسَا-د سَانْحَارِيبْ، أَجدْجِيذْ ن أَشُّورْ. نتَّا يُوذفْ غَارْ يَاهُوذَا ؤُشَا إِنّضْ إِ ثْندَّامْ إِفَارْينْ، إِتّْغِيڒْ أَسْ أَذْ ثنْثْ إِطّفْ إِ يِيخفْ نّسْ. \x ◘ \xo 32:‏1 \xt [2 إِج. 18‏:‏13‏-‏37؛ 19‏:‏1‏-‏37؛ إِشا. 36‏:‏1‏-‏22؛ 37‏:‏1‏-‏38]\x*  
\v 2 إِژْرَا حِيزْقِييَا، أَقَا سَانْحَارِيبْ يُوسَا-د ؤُشَا إِنْوَا أَذْ إِحْجمْ خْ ؤُرْشَالِيمْ.  
\v 3 نتَّا إِمْشَاوَارْ أَكْ-ذ ڒْحُوكَّامْ نّسْ ذ أَيْثْ ن بُو-ثغْرُوضْثْ نّسْ، مَاحنْذْ أَذْ نثْينْ ثَاڒَاوِينْ ن وَامَانْ بَارَّا إِ ثنْذِينْثْ، ؤُ نِيثْنِي وْشِينْ أَسْ أَفُوسْ.  
\v 4 إِوْينْ-د أَطَّاسْ زِي ڒْڭنْسْ ؤُشَا نثْينْ مَارَّا ثَاڒَاوِينْ ؤُڒَا ذ ثغْزَارْثْ إِ ذ إِتَّازّْڒنْ ذِي ڒْوسْطْ ن ثمُّورْثْ، نَّانْ: ”مَايمِّي إِ د غَا يَاسنْ إِجدْجِيذنْ ن أَشُّورْ ؤُشَا أَذْ أَفنْ أَطَّاسْ ن وَامَانْ؟“  
\v 5 نتَّا إِسّجْهذْ \add ثَانْذِينْثْ\add*، إِعْذڒْ مَارَّا ڒْحِيضْ إِ ثُوغَا إِتّْوَارْژنْ ذ إِوثْوِيثنْ ؤُشَا يَارَّا إِ-ث أَذْ إِڭعّذْ أَڒْ صُّومْعَاثْ. ؤُ غَارْ بَارَّا \add إِعْذڒْ عَاذْ\add* إِجّْ ن ڒْحِيضْ نّغْنِي. نتَّا إِسّجْهذْ لْقلْعَا ن ثنْذِينْثْ ن ذَاوُوذْ ؤُشَا إِڭَّا أَطَّاسْ ن لَانْسَاثْ ذ ثْسدَّارِييِينْ \add ن ؤُعسْكَارِي\add*.  
\v 6 نتَّا إِڭَّا إِكُومَانْذَارنْ ن ڒْعسْكَارَاثْ خْ ڒْڭنْسْ ؤُشَا إِسّْمُونْ إِ-ثنْ غَارسْ ذڭْ وَازَّايْ ن ثوَّارْثْ ن ثنْذِينْثْ ؤُشَا إِسِّيوڒْ أَڒَامِي ذَايْسنْ إِڭَّا ؤُڒْ، إِنَّا:  
\v 7 ”إِڒِيمْ ذ إِرْيَازنْ ؤُ إِڒِيمْ ثْمحْضمْ، وَارْ تّْنخْڒِيعمْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ن أَشُّورْ ؤُڒَا زَّاثْ إِ وُوذمْ ن مَارَّا ڒْغَاشِي نِّي غَارسْ إِدْجَانْ، مَاغَارْ \add ونِّي\add* غَارْنغْ أَقَا-ث ذڭْ وَاطَّاسْ خْ ونِّي غَارسْ. \x ◘ \xo 32:‏7 \xt 2 إِج. 6‏:‏16؛ يُوح. 16‏:‏33؛ 1 يُوح. 4‏:‏4 \x*  
\v 8 غَارسْ إِجّْ ن ؤُغِيڒْ ن ويْسُومْ \add ن بْنَاذمْ\add*، \add مَاشَا\add* غَارْنغْ سِيذِي، أَربِّي نّغْ، حِيمَا أَذْ أَنغْ إِوْشْ أَفُوسْ ؤُ حِيمَا أَذْ إِمّْنغْ أَمنْغِي نّغْ.“ ؤُشَا ڒْڭنْسْ إِتّشّڒْ خْ وَاوَاڒنْ ن حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا. \x ◘ \xo 32:‏8 \xt إِرْم. 17‏:‏5، 1 يُوح. 4‏:‏4\x*   
\b  
\m
\v 9 أَوَارْنِي مَانْ أَيَا إِسّكّْ سَانْحَارِيبْ، أَجدْجِيذْ ن أَشُّورْ، إِمْسخَّارنْ نّسْ غَارْ ؤُرْشَالِيمْ، أَمْ ثُوغَا نتَّا زَّاثْ إِ لَاخِيشْ ذ مَارَّا ڒْحُوكَّامْ نّسْ أَكِيذسْ. \add إِسّكّْ إِ-ثنْ\add* غَارْ حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ؤُ غَارْ مَارَّا \add ڒْڭنْسْ ن\add* يَاهُوذَا نِّي \add إِدْجَانْ\add* ذِي ؤُرْشَالِيمْ، إِنَّا:  
\v 10 ”أَمُّو إِ إِنَّا سَانْحَارِيبْ، أَجدْجِيذْ ن أَشُّورْ: ’مِينْ خفْ ثتّشْڒمْ كنِّيوْ، زعْمَا كنِّيوْ \add ثْزمَّارمْ\add* أَذْ ثقِّيممْ ذِي ؤُرْشَالِيمْ أَمْ ثتّْوَاحْصَارمْ؟  
\v 11 مَا وَارْ يَارزُّو حِيزْقِييَا أَذْ كنِّيوْ إِغْوَا، حِيمَا أَذْ كنِّيوْ إِسلّمْ إِ ڒْموْثْ زِي ڒَاژْ ذ ؤُفَاذِي خْمِي إِقَّارْ: سِيذِي، أَربِّي نّغْ، أَذْ أَنغْ إِفكّْ زڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن أَشُّورْ!؟  
\v 12 مَا وَارْ إِكِّيسْ حِيزْقِييَا نِّي ؤُڒَا ذ ڒڭْعُوذِي نّسْ ذ إِعَالْطَارنْ نّسْ، ؤُ \add مَا وَارْ\add* إِسِّيوڒْ نتَّا أَكْ-ذ يَاهُوذَا ذ ؤُرْشَالِيمْ، إِنَّا: مْغِيرْ إِ يِيجّْ ن ؤُعَالْطَارْ أَذْ ثْبنْذْقمْ ؤُ أَذْ خَاسْ ثَاوْيمْ ڒبْخُورْ!؟  
\v 13 مَا وَارْ ثسِّينمْ كنِّيوْ مِينْ ڭِّيغْ نشّْ ذ ڒجْذُوذْ إِنُو س مَارَّا ڒڭْنُوسْ ن ثمُّورَا؟ مَا فكّنْ إِربِّيثنْ ن ڒڭْنُوسْ ن ثمُّورَا نِّي ثَامُّورْثْ نْسنْ زڭْ ؤُفُوسْ إِنُو؟  
\v 14 مَانْ ونْ زِي جَارْ مَارَّا إِربِّيثنْ ن ڒڭْنُوسْ نِّي خْ قْضَانْ ڒجْذُوذْ إِنُو، ثُوغَا إِزمَّارْ أَذْ إِسّنْجمْ ڒْڭنْسْ نّسْ زڭْ ؤُفُوسْ إِنُو، أَڒَامِي أَربِّي نْومْ إِزمَّارْ أَذْ كنِّيوْ إِفكّْ زڭْ ؤُفُوسْ إِنُو؟  
\v 15 \add خنِّي\add* ڒخُّو، وَارْ تّجِّيمْ حِيزْقِييَا أَذْ كنِّيوْ إِشْمثْ ؤُ \add وَارْ ث تّجِيمْ\add* أَذْ كنِّيوْ إِسّْغكّْوِي أَمُّو. وَارْ ثتِّيقَّامْ شَا، مَاغَارْ ؤُڒَا ذ إِجّْ ن أَربِّي زِي مَانْ مَا ڒْڭنْسْ نِيغْ ثَاڭلْذِيثْ ثُوغَا إِزمَّارْ أَذْ إِفكّْ ڒْڭنْسْ نّسْ زڭْ ؤُفُوسْ إِنُو نِيغْ زڭْ ؤُفُوسْ ن ڒجْذُوذْ إِنُو. مشْحَاڒْ قلّْ عَاذْ أَربِّي نْومْ أَذْ كنِّيوْ إِفكّْ زڭْ ؤُفُوسْ إِنُو!‘ “ \f ◼ \fr 32:‏15 \ft \+bd ’حَازَاقِييَا‘\+bd* - س ثْعِيبْرَانِيثْ ’حَازَاقِي-يَا-هُو‘. ؤُڒَا ذِي نُّومْرَاوَاثْ 24، 25، 26، 27 ذ 30.\f*   
\m
\v 16 ؤُشَا إِمْسخَّارنْ نّسْ سِّيوْڒنْ عَاذْ كْثَارْ ضِيدّْ إِ سِيذِي أَربِّي ؤُ ضِيدّْ إِ ؤُمْسخَّارْ نّسْ حِيزْقِييَا.  
\v 17 نتَّا يُورَا عَاوذْ ثِيبْرَاثِينْ حِيمَا أَذْ إِسّحْقَارْ سِيذِي، أَربِّي ن إِسْرَائِيل، ؤُ حِيمَا أَذْ خَاسْ إِسِّيوڒْ ذَايْسنْثْ، ؤُشَا إِنَّا: ”أَمْ مَامّشْ إِربِّيثنْ ن ڒڭْنُوسْ ن ثمُّورَا، إِنِّي وَارْ إِزمَّارنْ أَذْ فكّنْ ڒْڭنْسْ نْسنْ زڭْ ؤُفُوسْ إِنُو، أَمُّو وَارْ إِزمَّارْ أَربِّي ن حِيزْقِييَا أَذْ إِسّنْجمْ ڒْڭنْسْ نّسْ زڭْ ؤُفُوسْ إِنُو!“  
\v 18 نِيثْنِي سْغُوينْ س جّهْذْ س يِيڒسْ ن ثْيَاهُوذشْثْ غَارْ ڒْڭنْسْ ن ؤُرْشَالِيمْ نِّي \add إِبدّنْ\add* خْ ڒْحِيضْ حِيمَا أَذْ ثنْ سِّيڭّْوِيذنْ ؤُ أَذْ ثنْ سّْخَاروْضنْ، مَاحنْذْ زمَّارنْ أَذْ طّْفنْ ثَانْذِينْثْ.  
\v 19 نِيثْنِي سِّيوْڒنْ خْ أَربِّي ن ؤُرْشَالِيمْ أَمْ خْ إِربِّيثنْ ن ڒڭْنُوسْ ن \add مَارَّا\add* ثَامُّورْثْ، إِنِّي \add إِدْجَانْ\add* مْغِيرْ ڒْخذْمثْ ن إِوْذَانْ وَاهَا.   
\m
\v 20 أَجدْجِيذْ حِيزْقِييَا ذ ؤُنَابِي إِشَاعْيَا، مِّيسْ ن أَمُوصْ، ژُّودْجنْ خْ مَانْ أَيَا، ڒَاغَانْ غَارْ ؤُجنَّا.  
\v 21 ؤُشَا إِسّكّْ-د سِيذِي إِجّْ ن لْمَالَاكْ، ونِّي إِقْضَانْ خْ مَارَّا أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ ذ ڒْحُوكَّامْ ذ إِمقّْرَاننْ ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن ؤُجدْجِيذْ ن أَشُّورْ. \add خنِّي\add* إِذْوڒْ-د نتَّا غَارْ ثمُّورْثْ نّسْ س ڒحْيَا خْ ؤُغمْبُوبْ. ؤُمِي د-يُوسَا غَارْ ثَادَّارْثْ ن أَربِّي نّسْ، أَقَا إِنِّي د-إِفّْغنْ زِي أَرِّيمثْ نّسْ، نْغِينْ ث س سِّيفْ.  
\v 22 أَمُّو إِ إِسّنْجمْ سِيذِي حِيزْقِييَا ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ زڭْ ؤُفُوسْ ن سَانْحَارِيبْ، أَجدْجِيذْ ن أَشُّورْ، ؤُ زڭْ ؤُفُوسْ ن مَارَّا. نتَّا ثُوغَا إِسَّاريّحْ إِ-ثنْ غَارْ مَارَّا إِغزْذِيسنْ نْسنْ.  
\v 23 أَطَّاسْ إِ د يِيوْينْ ثِيوْهِيبِينْ غَارْ سِيذِي ذِي ؤُرْشَالِيمْ، ؤُڒَا ذ ڒقْشُوعْ إِغْڒَانْ غَارْ حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا. سّنِّي ثُوغَا غَارسْ ڒوْقَارْ ذ أَمقّْرَانْ ذِي ثِيطَّاوِينْ ن مَارَّا ڒڭْنُوسْ.   
\b  
\m  
\s1 ڒهْڒَاشْ ن حِيزْقِييَا، أَسْڭنْفِي نّسْ ذ ڒْموْثْ نّسْ  
\m
\v 24 ذڭْ وُوسَّانْ نِّي إِذْوڒْ حِيزْقِييَا إِهْڒشْ س إِجّْ ن ڒحْڒَاشْ إِنقّنْ أَڒَامِي ثُوغَا إِڭُّورْ أَذْ إِمّثْ. إِژُّودْجْ غَارْ سِيذِي ؤُ وَانِيثَا إِسِّيوڒْ-د غَارسْ ؤُشَا إِوْشَا أَسْ-د إِشْثْ نْ ڒعْڒَامثْ. \x ◘ \xo 32:‏24 \xt [2 إِج. 20‏:‏1‏-‏21؛ إِشا. 38‏:‏1‏-‏22؛ 39‏:‏1‏-‏8]\x*  
\v 25 \add مَاشَا\add* حِيزْقِييَا وَارْ إِڭِّي عْلَاحْسَابْ ثْشُونِي إِ ذ أَسْ إِتّْوَاسّشْننْ، مَاغَارْ ؤُڒْ نّسْ إِذْوڒْ ذَايسْ نّْفَاخثْ. \add خْ ؤُيَا\add* يُوسَا-د إِجّْ ن ؤُذُوقّزْ ذ أَمقّْرَانْ ن وغْضَابْ خَاسْ، خْ يَاهُوذَا ؤُ خْ ؤُرْشَالِيمْ.  
\v 26 حِيزْقِييَا \add مَاشَا\add* إِسّْوَاضعْ إِخفْ نّسْ ذِي سِّيبّثْ ن نّْفَاخثْ ن وُوڒْ نّسْ، أَمْ نتَّا أَمْ يِيمزْذَاغْ ن ؤُرْشَالِيمْ، أَڒَامِي أَذُوقّزْ ذ أَمقّْرَانْ ن وغْضَابْ ن سِيذِي وَارْ خَاسنْ د-يُوسِي ذڭْ وُوسَّانْ ن حِيزْقِييَا.  
\v 27 حِيزْقِييَا ثُوغَا غَارسْ أَڭْڒَا ذ شَّانْ س وَاطَّاسْ. نتَّا إِڭَّا إِ إِخفْ نّسْ إِخَّامنْ ن ثْخُوبَايْ إِ نُّوقَارْثْ، إِ وُورغْ، إِ يژْرَا إِغْڒَانْ، إِ ڒعْطُورْ، إِ ثْسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* ؤُ إِ مَارَّا مِينْ إِدْجَانْ ذ ڒقْشُوعْ إِغْڒَانْ.  
\v 28 \add إِڭَّا ؤُڒَا ذ\add* ثِيخُوبَايْ إِ ڒْغِيدْجثْ ن إِمنْذِي، إِ بِينُو ن جْذِيذْ ذ زّشْثْ، ؤُڒَا ذ ڒْكُورِيثْ إِ مَارَّا ڒْمَاڒْ ذ ڒعْرَاصِي إِفَارْينْ إِ ثْحِيمْرِيوِينْ.  
\v 29 نتَّا إِڭَّا ثِيندَّامْ إِ يِيخفْ نّسْ ؤُ ثُوغَا غَارسْ أَطَّاسْ ن وُودْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ، مَاغَارْ أَربِّي ثُوغَا إِوْشَا أَسْ إِجّْ ن وَاڭْڒَا إِمْغَارْ أَطَّاسْ.  
\v 30 حِيزْقِييَا وَانِيثَا ثُوغَا عَاوذْ إِبلّعْ ؤُفُّوغْ ن وَامَانْ ن \add ثغْزَارْثْ ن\add* جِيحُونْ \add إِ إِدْجَانْ\add* سنّجْ قَاعْ. نتَّا يَارَّا أَمَانْ نِيشَانْ غَارْ وَادَّايْ غَارْ ڒْغَارْبْ ن ثنْذِينْثْ ن ذَاوُوذْ، مَاغَارْ حِيزْقِييَا ثُوغَا إِفْڒحْ ذِي مَارَّا مِينْ إِڭَّا.  
\v 31 \add مَاشَا\add* زِي سِّيبّثْ ن إِمنْذُوبِييّنْ ن ڒْحُوكَّامْ ن بَابِيلْ إِنِّي غَارسْ د-إِتّْوَاسّكّنْ، حِيمَا أَذْ سّقْسَانْ خْ ڒعْڒَامثْ إِمْغَارنْ ثنِّي ثُوغَا ذِي ثمُّورْثْ، أَقَا إِجَّا إِ-ث أَربِّي، حِيمَا أَذْ ث إِقدْجبْ، حِيمَا أَذْ إِسّنْ مَارَّا \add مِينْ إِدْجَانْ\add* ذڭْ وُوڒْ نّسْ. \f ◼ \fr 32:‏31 \ft \+bd ’إِمْسكَّانْ‘\+bd* - نِيغْ ’سُّوفَارَا‘.\f*   
\m
\v 32 إِمزْرُوينْ إِقِّيمنْ ن حِيزْقِييَا ذ ثْمخْسِيوْثْ نّسْ إِشوَّارنْ، خْزَارْ، أَقَا مَانْ أَيَا \add مَارَّا\add* إِتّْوَازمّمْ ذِي ڒوْحِييْ ن ؤُنَابِي إِشَاعْيَا، مِّيسْ ن أَمُوصْ، ؤُ ذڭْ وذْلِيسْ ن إِجدْجِيذنْ ن يَاهُوذَا ذ إِسْرَائِيل. \f ◼ \fr 32:‏32 \ft \+bd ’حَازَاقِييَا‘\+bd* - س ثْعِيبْرَانِيثْ ’حَازَاقِي-يَاهُو‘. ؤُڒَا ذِي نُّومْرَاوَاثْ 33 ذ 33‏:3.\f*  
\v 33 حِيزْقِييَا إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نضْڒنْ ث \add ذڭْ ونْضڒْ\add* يُوعْڒَانْ قَاعْ ن إِمضْڒَانْ ن وَارَّاونْ ن ذَاوُوذْ. مَارَّا يَاهُوذَا ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ سّشْننْ أَسْ ڒوْقَارْ غَارْ ڒْموْثْ نّسْ. مِّيسْ مَانَاسَّا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\b  
\m  
\c 33
\s1 ڒحْكَامثْ إِعفّْننْ ن مَانَاسِّي، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 1 مَانَاسَّا \add ثُوغَا\add* غَارسْ ثنْعَاشْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ خمْسَا ؤُ-خمْسِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. \x ◘ \xo 33:‏1 \xt [2 إِج. 21‏:‏1‏-‏18]\x*  
\v 2 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَمْ جّْعَايفْ ن ڒڭْنُوسْ نِّي ثُوغَا إِسُّوفّغْ سِيذِي زِي زَّاثْ ن وُوذمْ ن أَيْثْ ن إِسْرَائِيل زِي ڒْوَارْثْ نْسنْ.  
\v 3 نتَّا إِبْذَا أَذْ إِعْذڒْ ڒڭْعُوذِي نِّي ثُوغَا إِهْذمْ بَابَاسْ حِيزْقِييَا. نتَّا إِسّْبدّْ إِعَالْطَارنْ إِ ’إِبَاعْلنْ‘ ؤُشَا إِڭَّا ثِيربِّينْ ن شْوَارْثِي ؤُشَا إِبنْذقْ زَّاثْ إِ مَارَّا ڒْعسْكَارْ ن ؤُجنَّا ؤُشَا إِعْبذْ أَسنْ.  
\v 4 إِسّْبدّْ عَاوذْ إِعَالْطَارنْ ذِي ثَادَّارْثْ ن سِيذِي إِ خْ إِنَّا سِيذِي: ”ذِي ؤُرْشَالِيمْ \add أَذْ سّْمثْنغْ\add* إِسمْ إِنُو إِ ڒبْذَا.“  
\v 5 نتَّا إِبْنَا \add عَاوذْ\add* إِعَالْطَارنْ إِ مَارَّا ڒْعسْكَارْ ن ؤُجنَّا ذِي ثْنَاينْ ن ڒمْرَاحَاثْ ن ثَادَّارْثْ ن سِيذِي.  
\v 6 نتَّا إِجَّا أَذْ كّنْ إِحنْجِيرنْ نّسْ ذِي ثْمسِّي ذِي ثغْزُورْثْ ن مِّيسْ ن هِينُّومْ، إِڭَّا س ثْبزْڭِيوْثْ ذ ثْڭزَّانْثْ ذ ثْسحَّارْثْ، ؤُ يِيوِي-د إِنِّي إِسَّاوَاڒنْ أَكْ-ذ إِمتَّانْ ذ إِڭزَّاننْ. إِڭَّا أَطَّاسْ مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي مَاحنْذْ أَذْ ث إِسْعَارْ.  
\v 7 إِسّْبدّْ إِجّْ ن ڒخْيَاڒْ إِنقْشنْ نِّي إِڭَّا ذِي ثَادَّارْثْ ن أَربِّي، إِ خْ ثُوغَا إِنَّا أَربِّي إِ ذَاوُوذْ ؤُ إِ مِّيسْ سُولِيمَانْ: ”ذِي ثَادَّارْثْ-أَ ؤُ ذِي ؤُرْشَالِيمْ، ثنِّي فَارْزغْ زِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل، أَذْ سّْمثْنغْ إِسمْ إِنُو إِ ڒبْذَا.  
\v 8 نشّْ وَارْ تّجِّيغْ أَضَارْ ن إِسْرَائِيل أَذْ إِتّْوَاكّسْ عَاذْ زِي ثمُّورْثْ نِّي ؤُرِيغْ إِ ڒجْذُوذْ نْومْ، مَاڒَا نِيثْنِي مْغِيرْ أَذْ حْضَانْ مَارَّا مِينْ إِ ذ أَسنْ ؤُمُورغْ مَاحنْذْ أَذْ ث ڭّنْ، عْلَاحْسَابْ مَارَّا شَّارِيعَا ذ مَارَّا ثِيوصَّا ذ مَارَّا لْفَارَايِيضْ \add نِّي ذ أَسنْ إِمّوْشنْ\add* س ؤُفُوسْ ن مُوسَا.“  
\v 9 مَانَاسَّا إِجَّا يَاهُوذَا ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ أَذْ ودَّارنْ، أَڒَامِي ڭِّينْ ذ أَعفَّانْ خْ ڒڭْنُوسْ إِ خْ ثُوغَا إِقْضَا سِيذِي زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل.   
\m
\v 10 \add إِوَا،\add* سِيذِي ثُوغَا إِسِّيوڒْ إِ مَانَاسَّا ؤُ إِ ڒْڭنْسْ نّسْ، مَاشَا نِيثْنِي وَارْ ذ أَسْ وْشِينْ شَا ثَايْنِيثْ.  
\v 11 سِيذِي إِسّكّْ غَارْسنْ إِكُومَانْذَارنْ ن ڒْعسْكَارْ ن ؤُجدْجِيذْ ن أَشُّورْ. نِيثْنِي حبّْسنْ مَانَاسَّا س ثْسنَّارِينْ، شَارْفنْ ث س ثْنَاينْ ن سّْنَاسڒْ ن نّْحَاسْ ؤُشَا جِّينْ ث أَذْ يُويُورْ \add أَمُّو\add* غَارْ بَابِيلْ.  
\v 12 ؤُمِي ث إِحْصَارْ نتَّا أَمُّو، إِزَاوڭْ وَانِيثَا زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّسْ، ؤُ إِسّْوَاضعْ إِخفْ نّسْ أَڒْ طَّارْفْ زَّاثْ إِ وُوذمْ ن أَربِّي ن ڒجْذُوذْ نّسْ.  
\v 13 إِژُّودْجْ غَارسْ ؤُشَا نتَّا إِجَّا أَذْ إِسَّارْضَا إِخفْ نّسْ زَّايسْ س ثْژَادْجِيثْ يُودْجْغنْ نّسْ ؤُ يَارَّا إِ-ث-إِ-د غَارْ ؤُرْشَالِيمْ. \add خنِّي\add* إِسّنْ مَانَاسَّا، أَقَا سِيذِي ذ أَربِّي.  
\v 14 أَوَارْنِي ؤُيَا إِبْنَا ڒْحِيضْ ن بَارَّا إِ ثنْذِينْثْ ن ذَاوُوذْ، غَارْ ؤُغزْذِيسْ ن ڒْغَارْبْ ن جِيحُونْ ذِي ثغْزُورْثْ، ؤُ \add إِبْنَا إِ-ث\add* أَڒْ ثَاوَّارْثْ ن إِسڒْمَانْ، إِقُووَّارْ \add ڒْحِيضْ\add* ؤُڒَا ذ عُوفِيلْ ؤُشَا إِسّْڭعّذْ \add مَانَاسِّي\add* ڒْحِيضْ أَطَّاسْ. إِڭَّا ؤُڒَا ذ إِكُومَانْذَارنْ ن ڒْعسْكَارْ ذِي مَارَّا ثِيندَّامْ إِفَارْينْ ن يَاهُوذَا.  
\v 15 نتَّا إِكّسْ إِربِّيثنْ إِغْرِيبنْ ذ ڒخْيَاڒْ ن صَّانَامْ زِي ثَادَّارْثْ ن سِيذِي ؤُڒَا ذ مَارَّا إِعَالْطَارنْ نِّي ثُوغَا إِبْنَا خْ وذْرَارْ ن ثَادَّارْثْ ن سِيذِي ذِي ؤُرْشَالِيمْ، ؤُشَا إِمّنْضَارْ إِ-ثنْ بَارَّا إِ ثنْذِينْثْ.  
\v 16 نتَّا إِڭَّا \add عَاوذْ\add* أَعَالْطَارْ ن سِيذِي ؤُشَا إِقدّمْ خَاسْ ثِيوْهِيبِينْ ن ڒهْنَا ذ ثوْهِيبِينْ ن ؤُقَاذِي ؤُشَا إِنَّا إِ \add أَيْثْ ن\add* يَاهُوذَا أَذْعبْذنْ سِيذِي، أَربِّي ن إِسْرَائِيل.  
\v 17 مَاشَا ڒْڭنْسْ يَارْنِي عَاذْ يِيوِي ثِيغَارْصَا خْ ڒڭْعُوذِي، مَاشَا مْغِيرْ إِ سِيذِي، أَربِّي نْسنْ، وَاهَا.   
\m
\v 18 إِمزْرُويّنْ إِقِّيمنْ ن مَانَاسَّا ذ ثْژَادْجِيثْ نّسْ غَارْ أَربِّي نّسْ ؤُڒَا ذ أَوَاڒنْ ن إِمْوَاڒَاونْ نِّي غَارسْ إِسِّيوْڒنْ ذڭْ يِيسمْ ن سِيذِي، أَربِّي ن إِسْرَائِيل، خْزَارْ، مَانْ أَيَا \add مَارَّا إِتّْوَازمّمْ\add* ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل.  
\v 19 ثَاژَادْجِيثْ نّسْ ذ مَامّشْ إِجَّا \add أَربِّي\add* أَذْ إِتّْوَاسّصْڒحْ إِخفْ نّسْ س ثْژَادْجِيثْ يُودْجْغنْ نّسْ، ؤُڒَا ذ مَارَّا دّْنُوبْ نّسْ ذ ڒغْذَارْ نّسْ ذ إِمُوشَانْ مَانِي إِبْنَا ڒڭْعُوذِي ؤُ إِسّْبدّْ ثِيربِّينْ ن شْوَارْثِي ذ ڒخْيَاڒَاثْ إِنقْشنْ قْبڒْ مَا إِتّْوَاسّْوَاضعْ، خْزَارْ، مَانْ أَيَا \add مَارَّا\add* إِتّْوَازمّمْ ذڭْ وَاوَاڒنْ ن إِمْوَاڒَاونْ.  
\v 20 مَانَاسَّا إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نضْڒنْ ث ذِي ثَادَّارْثْ نّسْ. مِّيسْ أَمُونْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\m  
\s1 أَمُونْ، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 21 أَمُونْ \add ثُوغَا\add* غَارسْ ثْنَاينْ ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثْنَاينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. \x ◘ \xo 33:‏21 \xt [2 إِج. 21‏:‏19‏-‏26]\x*  
\v 22 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، \add نِيشَانْ\add* أَمْ مَامّشْ ث إِڭَّا بَابَاسْ مَانَاسَّا. أَمُونْ إِقدّمْ ثِيغَارْصَا إِ مَارَّا ڒخْيَاڒَاثْ إِنقْشنْ إِ ثُوغَا إِڭَّا بَابَاسْ مَانَاسَّا ؤُشَا إِسخَّارْ أَسنْ.  
\v 23 نتَّا وَارْ إِسّْوَاضعْ إِخفْ نّسْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَمْ مَامّشْ إِسّْوَاضعْ بَابَاسْ مَانَاسَّا إِخفْ نّسْ، مَاشَا أَمُونْ وَانِيثَا يَارْنِي \add وَاهَا\add* ذڭْ ؤُمَارْوَاسْ.  
\v 24 إِمْسخَّارنْ نّسْ ڭِّينْ خَاسْ إِشْثْ ن ثْمعْمُوتْشْ ؤُشَا نْغِينْ ث ذِي ثَادَّارْثْ نّسْ.  
\v 25 ڒْڭنْسْ ن ثمُّورْثْ \add مَاشَا\add* نْغِينْ مَارَّا إِنِّي ثُوغَا إِڭِّينْ ثَامعْمُوتْشْ خْ ؤُجدْجِيذْ أَمُونْ. ڒْڭنْسْ ن ثمُّورْثْ ڭِّينْ مِّيسْ يُوشِييَا ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. \f ◼ \fr 33:‏25 \ft \+bd ’يُوشِييَا‘\+bd* - س ثْعِيبْرَانِيثْ ’يُوشِي-يَاهُو‘.\f*   
\b  
\b  
\m  
\c 34
\s1 يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 1 يُوشِييَا \add ثُوغَا\add* غَارسْ ثْمنْيَا ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ وَاحِيثْ ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. \x ◘ \xo 34:‏1 \xt [2 إِج. 22‏:‏1‏-‏20]\x*  
\v 2 نتَّا إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي. نتَّا يُويُورْ ذڭْ إِبْرِيذنْ ن بَابَاسْ ذَاوُوذْ، وَارْ إِفِّيغْ \add خْ وبْرِيذْ\add* \add ڒَْا غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ.  
\v 3 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْيَا ن ڒحْكَامثْ نّسْ، ؤُمِي ث ثُوغَا عَاذْ ذ أَحُوذْرِي، إِبْذَا أَذْ يَارْزُو خْ أَربِّي ن بَابَاسْ ذَاوُوذْ. ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثنْعَاشْ إِبْذَا أَذْ إِسِّيزْذڭْ يَاهُوذَا ذ ؤُرْشَالِيمْ زِي ڒڭْعُوذِي، زِي ثْربِّينْ ن شْوَارْثِي ؤُ زِي ڒخْيَاڒَاثْ إِنقْشنْ ذ ڒخْيَاڒَاثْ إِفسْينْ.  
\v 4 زَّاثْ إِ ثِيطَّاوِينْ نّسْ هذْمنْ إِعَالْطَارنْ ن ’إِبَاعْلنْ‘، ؤُشَا إِزْذمْ نتَّا إِپِيلَارنْ ن أَربِّي ن ثْفُوشْثْ نِّي خَاسنْ د-إِبَاننْ سنّجْ. ثِيربِّينْ ن شْوَارْثِي ذ ڒخْيَاڒَاثْ إِنقْشنْ ذ ڒخْيَاڒَاثْ إِفسْينْ يَارْژَا إِ-ثنْ ذِي إِوثْوِيثنْ ؤُشَا إِدّزْ إِ-ثنْ ؤُ ثَاعجَّاجْثْ نْسنْ يَاريّشْ إِ-ت خْ إِمضْڒَانْ ن يِينِّي ثُوغَا ذ أَسنْ د-يِيوْينْ ثَاغَارْصْثْ.  
\v 5 إِسَّارْغْ إِغْسَانْ ن إِكهَّاننْ خْ إِعَالْطَارنْ نْسنْ. \add أَمُّو\add* إِ إِسِّيزْذڭْ يَاهُوذَا ذ ؤُرْشَالِيمْ.  
\v 6 ؤُڒَا غَارْ ثْندَّامْ ن مَانَاسَّا ذ إِفْرَايِيمْ ذ شِيمْعُونْ، \add وَاهْ،\add* أَڒْ نَافْثَالِي، غَارْ مَارَّا إِغزْذِيسنْ ن إِمُوشَانْ نْسنْ إِتّْوَاردّْدْجنْ،  
\v 7 إِهْذمْ إِعَالْطَارنْ. نتَّا إِڒْبزْ ثِيربِّينْ ن شْوَارْثِي ذ ڒخْيَاڒَاثْ إِنقْشنْ، إِدّزْ إِ-ثنْثْ، ؤُشَا إِزْذمْ \add عَاوذْ\add* مَارَّا إِپِيلَارنْ ن أَربِّي ن ثْفُوشْثْ ذِي مَارَّا إِسْرَائِيل. أَوَارْنِي ؤُيَا إِعْقبْ-د غَارْ ؤُرْشَالِيمْ.   
\m
\v 8 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْطَاشْ ن ڒحْكَامثْ نّسْ، أَوَارْنِي ڒَامِي إِسِّيزْذڭْ ثَامُّورْثْ ذ ثَادَّارْثْ، إِسّكّْ نتَّا شَافَانْ، مِّيسْ ن أَصَالْيَا، ذ مَاعَاسِييَا، أَمقّْرَانْ ن ثنْذِينْثْ، ذ يُووَاخْ، مِّيسْ ن يَاهُويَاحَازْ، أَمَارِيرْ ن ؤُمزْرُويْ، حِيمَا أَذْعذْڒنْ ثَادَّارْثْ ن سِيذِي، أَربِّي نّسْ. \f ◼ \fr 34:‏8 \ft \+bd ’أَصَالْيَا‘\+bd* - س ثْعِيبْرَانِيثْ ’أَصَالْ-يَاهُو‘. \+bd ’مَاعَاسِييَا‘\+bd* - س ثْعِيبْرَانِيثْ ’مَاعَاسِي-يَاهُو‘.\f*  
\v 9 نِيثْنِي ؤُسِينْ-د غَارْ حِيلْقِييَا، أَرَّايْسْ ن إِكهَّاننْ، ؤُ وْشِينْ أَسْ نُّوقَارْثْ إِ د-إِتّْوَاوْينْ ذِي ثَادَّارْثْ ن أَربِّي، ذ ثنِّي د-يَارْونْ إِلَاوِييّنْ نِّي ثُوغَا إِعسّنْ غَارْ وَاذَافْ، زڭْ ؤُفُوسْ ن مَانَاسَّا ذ إِفْرَايِيمْ، زِي مَارَّا مِينْ إِقِّيمنْ ن إِسْرَائِيل، زِي مَارَّا يَاهُوذَا ذ بِينْيَامِينْ ؤُ زِي مَارَّا إِمزْذَاغْ ن ؤُرْشَالِيمْ.  
\v 10 نِيثْنِي وْشِينْ ت ذڭْ ؤُفُوسْ ن يِينِّي ثُوغَا إِڭِّينْ ڒْخذْمثْ، إِنِّي \add إِدْجَانْ\add* خْ ثَادَّارْثْ ن سِيذِي، ؤُشَا إِنَا وْشِينْ ت إِ يِينِّي إِڭِّينْ ڒْخذْمثْ ذِي ثَادَّارْثْ ن سِيذِي، مَاحنْذْ أَذْعذْڒنْ ؤُ أَذْ سّْجهْذنْ ثَادَّارْثْ.  
\v 11 نِيثْنِي وْشِينْ ت إِ إِحْرَايْفِييّنْ ؤُ إِ إِمَاصُّوثنْ إِ ثْمسْغِيوْثْ ن ثْصُوضَارْ إِتّْوَاسُّويْذَانْ ؤُ \add إِ ثْمسْغِيوْثْ\add* ن ؤُكشُّوضْ إِ ثْحنْيَا ن ؤُعَارّضْ، مَاحنْذْ أَذْ ڭّنْ ثِيغُورْفِينْ إِ ثُوذْرِينْ، ثِينِّي إِجِّينْ إِجدْجِيذنْ ن يَاهُوذَا أَذْ أَرْخُونْ.  
\v 12 إِرْيَازنْ خذْمنْ س ڒَامَانْ. يَاحَاثْ ذ عُوبَاذْيَا، إِلَاوِييّنْ زڭْ إِحنْجِيرنْ ن مَارَارِي، ثُوغَا أَثنْ ذ إِوقَّافنْ خَاسنْ، ؤُڒَا ذ زَاكَارِييَّا ذ مَاشُولَّامْ زڭْ إِحنْجِيرنْ ن قُوحَاثْ، حِيمَا أَذْ سيَّارنْ. إِلَاوِييّنْ، مَارَّا ثُوغَا تّْحَاكَانْ ذِي دُّوزَانَاثْ ن لْمُوسِيقَا،  
\v 13 \add ثُوغَا أَثنْ عَاوذْ\add* خْ يِينِّي يَاربُّونْ ڒحْمڒْ. نِيثْنِي ذ إِمْسيَّارنْ إِ مَارَّا إِنِّي ثُوغَا إِخدّْمنْ ذِي ڒخْذَايمْ إِفَارْزنْ. \add تّْوَاڒقّْمنْ\add* زڭْ إِلَاوِييّنْ ؤُڒَا ذ إِمَارِيرنْ ذ إِمحْضَاينْ ذ إِعسَّاسنْ ن ثوُّورَا.   
\m
\v 14 \add ؤُمِي\add* كْسِينْ \add ثْمنْيَاثْ ن\add* نُّوقَارْثْ نِّي ثُوغَا د-إِوْينْ ذِي ثَادَّارْثْ ن سِيذِي، يُوفَا ؤُكهَّانْ حِيلْقِييَا أَذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا ن سِيذِي، \add إِ ثُوغَا ذ أَسنْ إِمّوْشنْ\add* خْ ؤُفُوسْ ن مُوسَا.  
\v 15 حِيلْقِييَا إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا إِ ؤُمَارِيرْ شَافَانْ: ”نشّْ ؤُفِيغْ أَذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا ذِي ثَادَّارْثْ ن سِيذِي.“ ؤُشَا إِوْشَا حِيلْكِييَا أَذْلِيسْ إِ شَافَانْ.  
\v 16 شَافَانْ يِيوِي أَذْلِيسْ غَارْ ؤُجدْجِيذْ. نتَّا إِخبَّارْ أَجدْجِيذْ، إِنَّا: ”مَارَّا مِينْ ؤُمُورنْ إِ إِمْسخَّارنْ نّشْ، أَقَا تّڭّنْ ث.  
\v 17 نِيثْنِي سّْفَارّْغنْ \add ثمْنْيَاثْ ن\add* نُّوقَارْثْ إِ ؤُفِينْ ذِي ثَادَّارْثْ ن سِيذِي ؤُشَا وْشِينْ ثنْثْ ذڭْ ؤُفُوسْ ن إِوقَّافنْ ؤُ ن يِينِّي إِتّڭّنْ ڒْخذْمثْ.“  
\v 18 \add خنِّي\add* إِحَاجَا ؤُمَارِيرْ شَافَانْ إِ ؤُجدْجِيذْ \add أَمُّو\add*، إِنَّا: ”أَكهَّانْ حِيلْقِييَا إِوْشَا أَيِي إِجّْ ن وذْلِيسْ!“ شَافَانْ إِغْرَا زَّايسْ خْ ؤُجدْجِيذْ.  
\v 19 ؤُمِي إِسْڒَا ؤُجدْجِيذْ أَوَاڒنْ ن شَّارِيعَا، إِمْسَارْ، إِشَارّڭْ نتَّا أَرُّوضْ نّسْ.  
\v 20 يُومُورْ ؤُجدْجِيذْ إِ حِيلْقِييَا ؤُ إِ أَخِيقَامْ، مِّيسْ ن شَافَانْ، ؤُ إِ عَابْذُونْ، مِّيسْ ن مِيخَا، ؤُ إِ ؤُمَارِيرْ شَافَانْ إِ عَاسَايَا، أَمْسخَّارْ ن ؤُجدْجِيذْ، إِنَّا:  
\v 21 ”ؤُيُورمْ، سقْسَامْ سِيذِي ذِي طّْوعْ إِنُو ؤُ ذِي طّْوعْ ن مِينْ إِقِّيمنْ ذِي إِسْرَائِيل ؤُ ذِي يَاهُوذَا خْ وَاوَاڒنْ ن وذْلِيسْ إِ إِتّْوَافنْ. مَاغَارْ أَسْعَارْ ن سِيذِي نِّي خَانغْ إِتّْوَازدْجْعنْ، أَقَا-ث ذ أَمقّْرَانْ، مِينْزِي ڒجْذُوذْ نّغْ وَارْ حْضِينْ شَا أَوَاڒْ ن سِيذِي، حِيمَا أَذْ ڭّنْ أَمْ مَامّشْ مَارَّا مِينْ يُورِينْ ذڭْ وذْلِيسْ إِتّْوَانّْضنْ.“   
\m
\v 22 \add خنِّي\add* يُويُورْ حِيلْقِييَا أَكْ-ذ يِينِّي \add إِتّْوَاسّكّنْ\add* زڭْ ؤُجدْجِيذْ غَارْ ثْنَابِيثْ خُولْذَا، ثَامْغَارْثْ ن شَالُّومْ، مِّيسْ ن ثُوقَاهَاثْ، مِّيسْ ن حَاسْرَا، ونِّي إِبدّنْ خْ ڒهْرِي ن وَارُّوضْ. نتَّاثْ ثزْذغْ ذڭْ وزْينْ نّغْنِي ن ؤُرْشَالِيمْ ؤُشَا سِّيوْڒنْ أَكِيذسْ خْ مَانْ أَيَا.  
\v 23 نتَّاثْ ثنَّا أَسنْ: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’إِنِيمْ إِ ورْيَازْ نِّي كنِّيوْ غَارِي د-إِسّكّنْ:  
\v 24 ’أَمُّو إِ إِقَّارْ سِيذِي: خْزَارْ نشّْ أَذْ سِّيوْضغْ ثُوعفّْنَا خْ ومْشَانْ-أَ ؤُ خْ إِمزْذَاغْ نّسْ، مَارَّا نّْعَاڒِي إِ يُورِينْ ذڭْ وذْلِيسْ نِّي زَّايسْ إِتّْوَاغَارنْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ن يَاهُوذَا،  
\v 25 مَاغَارْ نِيثْنِي حيّْذنْ خَافِي ؤُ إِوْينْ ثِيوْهِيبِينْ ن ڒبْخُورْ إِ إِربِّيثنْ نّغْنِي أَڒَامِي ذ أَيِي سْعَارنْ س مَارَّا ڒخْذَايمْ ن إِفَاسّنْ نْسنْ. أَسْعَارْ إِنُو أَذْ إِتّْوَازدْجعْ خْ ومْشَانْ-أَ ؤُ وَارْ إِخسِّي.  
\v 26 \add مَاشَا\add* إِ ؤُجدْجِيذْ ن يَاهُوذَا، ونِّي كنِّيوْ د-إِسّكّنْ ذَا، حِيمَا أَذْ ثسّقْسَامْ سِيذِي، أَذْ أَسْ ثِينِيمْ: ’أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: خْ وَاوَاڒنْ نِّي ثسْڒِيذْ:  
\v 27 مَاغَارْ إِذْوڒْ وُوڒْ نّشْ يَارْضبْ ؤُ ثسّْوَاضْعذْ إِخفْ نّشْ زَّاثْ إِ وُوذمْ ن أَربِّي ؤُمِي ثسْڒِيذْ إِ وَاوَاڒنْ نّسْ خْ ومْشَانْ-أَ ؤُ خْ إِمزْذَاغْ نّسْ، ؤُ ؤُمِي ثسّْوَاضْعذْ إِخفْ نّشْ ؤُشَا ثْشَارّْڭذْ أَرُّوضْ نّشْ ؤُ ثْرُوذْ زَّاثْ إِ وُوذمْ إِنُو، س ؤُيَا سْڒِيغْ نشّْ عَاوذْ غَاركْ، إِقَّارْ سِيذِي.  
\v 28 خْزَارْ، أَذْ شكْ سّْمُونغْ غَارْ ڒجْذُوذْ نّشْ ؤُ أَذْ ثتّْوَاسَّارْسذْ ذڭْ ونْضڒْ نّشْ س ڒهْنَا ؤُ ثِيطَّاوِينْ نّشْ وَارْ تّْوِيڒِينْثْ شَا مَارَّا ثُوعفّْنَا نِّي غَا سِّيوْضغْ خْ ومْشَانْ-أَ ؤُ خْ إِمزْذَاغْ نّسْ.‘ “ نِيثْنِي عَاوْذنْ أَوَاڒْ-أَ إِ ؤُجدْجِيذْ.   
\m
\v 29 \add خنِّي\add* إِسّكّْ ؤُجدْجِيذْ \add إِرقَّاسنْ\add* ؤُشَا إِسّْمُونْ مَارَّا إِمقّْرَاننْ ن يَاهُوذَا ذ ؤُرْشَالِيمْ.  
\v 30 إِڭعّذْ ؤُجدْجِيذْ غَارْ ثَادَّارْثْ ن سِيذِي أَكْ-ذ مَارَّا إِرْيَازنْ ن يَاهُوذَا ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ، أَكْ-ذ إِكهَّاننْ ذ إِلَاوِييّنْ ؤُ أَكْ-ذ مَارَّا ڒْڭنْسْ، زڭْ ؤُمقّْرَانْ أَڒْ أَمژْيَانْ، ؤُ غْرِينْ خَاسنْ مَارَّا أَوَاڒنْ ن وذْلِيسْ ن ڒْعَاهْذْ نِّي ثُوغَا إِتّْوَافنْ ذِي ثَادَّارْثْ ن سِيذِي.  
\v 31 أَجدْجِيذْ إِبدّْ ذڭْ ومْشَانْ نّسْ ؤُشَا إِقّنْ ڒْعَاهْذْ زَّاثْ إِ وُوذمْ ن سِيذِي، حِيمَا أَذْ إِضْفَارْ سِيذِي ؤُ حِيمَا أَذْ إِحْضَا ڒُومُورَاثْ نّسْ ذ شّْهَاذَاثْ نّسْ ذ ثْوصَّا نّسْ س مَارَّا وُوڒْ نّسْ ؤُ س مَارَّا ڒعْمَارْ نّسْ ؤُ حِيمَا أَذْ إِڭّْ أَوَاڒنْ ن ڒْعَاهْذْ-أَ إِ يُورِينْ ذڭْ وذْلِيسْ-أَ.  
\v 32 نتَّا إِجَّا مَارَّا إِنِّي إِدْجَانْ ذِي ؤُرْشَالِيمْ ذ بِينْيَامِينْ، أَذْ كَّارنْ \add حِيمَا أَذْ ث سّْمثْننْ\add* ؤُشَا إِمزْذَاغْ ن ؤُرْشَالِيمْ ڭِّينْ عْلَاحْسَابْ ڒْعَاهْذْ ن أَربِّي، أَربِّي ن ڒجْذُوذْ نْسنْ.  
\v 33 إِكّسْ يُوشِييَا مَارَّا جّْعَايفْ \add نْ صَّانَامْ\add* زِي ثمُّورَا ن أَيْثْ ن إِسْرَائِيل ؤُ يَارَّا مَارَّا إِنِّي \add إِزذْغنْ\add* ذِي إِسْرَائِيل تّْسخَّارنْ إِ ثْسخَّارْثْ ن سِيذِي، أَربِّي نْسنْ. مَارَّا ؤُسَّانْ \add ن ثُوذَارْثْ\add* نّسْ وَارْ حيّْذنْ شَا زڭْ وضْفَارْ ن سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ. \f ◼ \fr 34:‏33 \ft \+bd ’يُوشِييَا‘\+bd* - س ثْعِيبْرَانِيثْ ’يُوشِي-يَاهُو‘.\f*   
\b  
\b  
\m  
\c 35
\s1 أَجدْجِيذْ يُوشِييَا إِعيّذْ ڒْعِيذْ ن ثْغَارْصْثْ ن ؤُسعْذُو  
\m
\v 1 \add خنِّي\add* إِڭَّا يُوشِييَا \add ڒْْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو إِ سِيذِي ذِي ؤُرْشَالِيمْ. غَارْصنْ إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو ذڭْ وَاسّْ وِيسّْ أَرْبعْطَاشْ ن ؤُيُورْ أَمزْوَارُو. \x ◘ \xo 35:‏1 \xt [2 إِج. 23‏:‏21‏-‏23]\x*  
\v 2 نتَّا إِسّْبدّْ إِكهَّاننْ غَارْ إِمُوشَانْ ن ثْعسَّاسْثْ نْسنْ ؤُشَا إِڭَّا ذَايْسنْ ؤُڒْ غَارْ ڒْخذْمثْ ذِي ثَادَّارْثْ ن سِيذِي.  
\v 3 إِنَّا إِ إِلَاوِييّنْ، إِنِّي إِسّڒْمَاذنْ مَارَّا إِسْرَائِيل، إِنِّي ثُوغَا إِقدّْسنْ إِ سِيذِي: ”سَارْسمْ تَّابُوثْ إِقدّْسنْ ذِي ثَادَّارْثْ نِّي إِبْنَا سُولِيمَانْ، مِّيسْ ن ذَاوُوذْ، أَجدْجِيذْ ن إِسْرَائِيل. وَارْ ذ أَومْ إِتّْخصَّا \add عَاذْ\add* أَذْ ثَارْبُومْ دّْقڒْ خْ ثْغَارْضِينْ نْومْ. سخَّارمْ ڒخُّو إِ سِيذِي، أَربِّي نْومْ، ؤُ إِ ڒْڭنْسْ نّسْ إِسْرَائِيل.  
\v 4 سْوجْذمْ إِخفْ نْومْ، \add أَمْ ثتّْوَاستّْفمْ\add* عْلَاحْسَابْ ثُوذْرِينْ ن إِبَابَاثنْ نْومْ، عْلَاحْسَابْ ثِيرْبِيعِينْ نْومْ، أَمْ مَامّشْ ت يُورَا ذَاوُوذْ، أَجدْجِيذْ ن إِسْرَائِيل، ؤُ أَمْ مَامّشْ ت يُورَا مِّيسْ سُولِيمَانْ.  
\v 5 سْبدّمْ إِخفْ نْومْ ذِي زَّاوشْثْ إِقدّْسنْ، \add أَمْ ثتّْوَاستّْفمْ كنِّيوْ\add* عْلَاحْسَابْ ثِيرْبِيعِينْ ن ڒَادْجَاثْ ن إِبَابَاثنْ، زَّاثْ إِ ثَاوْمَاثْ نْومْ، أَيْثْ ن ڒْڭنْسْ، \add أَمْ ثتّْوَاستّْفمْ\add* عْلَاحْسَابْ أَستّفْ ن ڒَادْجَاثْ ن جّذْ ن إِلَاوِييّنْ. \f ◼ \fr 35:‏5 \ft \+bd ’ڒْڭنْسْ‘\+bd* - س ثْعِيبْرَانِيثْ ’إِحنْجِيرنْ ن ڒْڭنْسْ‘ نِيغْ ’أَرَّاونْ ن ڒْڭنْسْ‘.\f*  
\v 6 غَارْصمْ إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو ؤُ سْقدّْسمْ إِخفْ نْومْ. سْوجْذمْ ت إِ أَيْثْمَاثْومْ، مَاحنْذْ أَذْ ڭّنْ عْلَاحْسَابْ أَوَاڒْ ن سِيذِي \add إِ إِمّوْشنْ\add* س ثْسخَّارْثْ ن مُوسَا.“   
\m
\v 7 إِوْشَا يُوشِييَا ؤُدْجِي، إِزْمَارنْ ذ إِمُويَانْ إِمژْيَاننْ إِ ثَارْوَا ن ڒْڭنْسْ. مَارَّا أَيَا ثُوغَا إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو إِ مَارَّا إِنِّي ذِينْ إِدْجَانْ. ثُوغَا ڒْقدّْ نْسنْ ثْڒَاثِينْ-أَڒفْ، ؤُ \add خنِّي عَاوذْ\add* ثڒْثْ-أَڒَافْ ن إِفُونَاسنْ ذ ثْفُونَاسِينْ. مَارَّا أَيَا إِ د-يُوسِينْ زڭْ وَاڭْڒَا ن ؤُجدْجِيذْ.  
\v 8 وْشِينْ ڒْحُوكَّامْ نّسْ إِشْثْ ن ثوْهِيبْثْ ن ؤُسْڭعّذْ أَمْ ثوْهِيبْثْ س ڒْخَاضَارْ إِ ڒْڭنْسْ، إِ إِكهَّاننْ ؤُ إِ إِلَاوِييّنْ. حِيلْقِييَا، زَاكَارِييَّا ذ يَاحِييِيلْ، إِمحْضَاينْ ن ثَادَّارْثْ ن أَربِّي، وْشِينْ إِ إِكهَّاننْ إِ \add ثْغَارْصَا ن\add* ؤُسعْذُو أَڒْفَاينْ ؤُ-ستَّا-مْيَا زڭْ وُودْجِي ؤُ \add سنّجْ مَانْ أَيَا عَاذْ\add* ثڒْثْ-مْيَا ن إِفُونَاسنْ ذ ثْفُونَاسِينْ.   
\m
\v 9 كُونَانْيَا، شَامْعِييَا ذ نَاثَانِييِيلْ، أَيْثْمَاسْ، ذ حَاشَابْيَا، يَاعِييِيلْ ذ يُوزَابَاذْ، إِمقّْرَاننْ ن إِلَاوِييّنْ، وْشِينْ إِ إِلَاوِييّنْ إِ \add ثْغَارْصَا ن\add* ؤُسعْذُو خمْسَا-أَڒَافْ زڭْ وُودْجِي ؤُ \add خنِّي\add* خمْسَا-مْيَا ن إِفُونَاسنْ ذ ثْفُونَاسِينْ.   
\m
\v 10 \add أَمُّو إِ\add* سّْوجْذنْ إِ ڒْخذْمثْ. إِكهَّاننْ ثُوغَا بدّنْ ذڭْ ومْشَانْ نْسنْ ؤُ إِلَاوِييّنْ ذِي ثرْبِيعِينْ نْسنْ، عْلَاحْسَابْ ڒُومُورْ ن ؤُجدْجِيذْ.  
\v 11 نِيثْنِي غَارْصنْ إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو ؤُشَا إِكهَّاننْ زدْجْعنْ إِذَامّنْ زڭْ إِفَاسّنْ نْسنْ، ؤُ كّْسنْ إِلَاوِييّنْ \add زَّايْسنْثْ\add* إِڒْمَاونْ.  
\v 12 نِيثْنِي حُوزنْ \add إِزِييْنَاثْ إِ\add* ثْغَارْصْثْ ن وشْمَاضْ حِيمَا أَذْ أَسنْ \add ثنْثْ\add* وْشنْ، إِ ڒفْرُوعْ ن ڒَادْجَاثْ ن إِبَابَاثنْ، إِ وَارَّاونْ ن ڒْڭنْسْ، حِيمَا أَذْ ثنْثْ وهّْبنْ ذ ثَاغَارْصْثْ إِ سِيذِي، أَمْ مَامّشْ ثُورَا ذڭْ وذْلِيسْ ن مُوسَا ؤُشَا أَمُّو \add إِ إِڭِّينْ\add* أَكْ-ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ.  
\v 13 خنِّي شنْفنْ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو ثِيوَا إِ ثْمسِّي أَمْ مَامّشْ ثدْجَا ذِي لْقَاعِيذَا. إِزِييْنَاثْ إِقدّْسنْ نّغْنِي شنْفنْ ثنْ ذِي مَارْمِيثَاثْ ذ إِطنْجِيرنْ ذ ثِيقْسِيڒِينْ ؤُشَا إِوْينْ \add ثنْثْ\add* ذغْيَا غَارْ مَارَّا ڒْڭنْسْ. \x ◘ \xo 35:‏13 \xt ؤُف. 12‏:‏9\x*  
\v 14 أَوَارْنِي أَيَا سّْوجْذنْ ؤُڒَا إِ يِيخفْ نْسنْ ؤُ إِ إِكهَّاننْ، مَاغَارْ إِكهَّاننْ، أَرَّاونْ ن هَارُونْ، ثُوغَا ڒْهَانْ أَكْ-ذ ؤُوهّبْ ن ثْغَارْصَا ن وشْمَاضْ ذ ثَاذُونْثْ أَڒْ دْجِيڒثْ. \add أَوَارْنِي أَيَا\add* سّْوجْذنْ إِلَاوِييّنْ إِ يِيخفْ نْسنْ ؤُ إِ إِكهَّاننْ، أَرَّاونْ ن هَارُونْ.   
\m
\v 15 إِمذْيَازنْ، إِحنْجِيرنْ ن أَسَافْ، \add ثُوغَا بدّنْ\add* ذڭْ ومْشَانْ نْسنْ، عْلَاحْسَابْ ڒُومُورْ ن ذَاوُوذْ، أَسَافْ، هَايْمَانْ ذ يَاذُوثُونْ، أَمْوَاڒَاوْ ن ؤُجدْجِيذْ، ؤُشَا إِعسَّاسنْ ن ثوُّورَا \add بدّنْ\add* غَارْ كُوڒْ ثَاوَّارْثْ. ثُوغَا وَارْ إِتّْخصِّي أَذْ جّنْ ڒْخذْمثْ نْسنْ، مَاغَارْ أَيْثْمَاثْسنْ، إِلَاوِييّنْ، سّْوجْذنْ أَسنْ \add ثَاغَارْصْثْ ن ؤُسعْذُو\add*.   
\m
\v 16 مَارَّا ثَاسخَّارْثْ ن سِيذِي ثعْذڒْ \add مْلِيحْ\add* ذڭْ وَاسّْ نِّي إِ ؤُحطُّو \add ن ڒْعِيذْ\add* ن \add ثْغَارْصْثْ ن\add* ؤُسعْذُو ؤُ إِ ؤُوهّبْ ن ثْغَارْصَا ن وشْمَاضْ خْ ؤُعَالْطَارْ ن سِيذِي عْلَاحْسَابْ ڒُومُورْ ن ؤُجدْجِيذْ يُوشِييَا.  
\v 17 أَيْثْ ن إِسْرَائِيل، إِنِّي \add ذِينْ\add* إِدْجَانْ، سّْوجْذنْ إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو ذڭْ وَاسّْ نِّي، ؤُ سبْعَا ن وُوسَّانْ \add ڭِّينْ نِيثْنِي\add* ڒْعِيذْ ن وغْرُومْ بْڒَا أَنْثُونْ.  
\v 18 وَارْ ذِينْ ثُوغِي ذِي إِسْرَائِيل بُو \add ڒْْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو أَمْ وَا زڭْ وُوسَّانْ ن ؤُنَابِي شَامْوِيلْ. ؤُڒَا ذ إِجّنْ زڭْ إِجدْجِيذنْ ن إِسْرَائِيل وَارْ إِڭِّي \add ڒْْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو أَمْ مَامّشْ ث إِڭَّا يُوشِييَا أَكْ-ذ إِكهَّاننْ ذ إِلَاوِييّنْ ؤُ أَكْ-ذ مَارَّا يَاهُوذَا ذ إِسْرَائِيل، نِّي \add ذِينْ\add* إِدْجَانْ، ؤُ أَكْ-ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ.  
\v 19 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْطَاشْ ن ثْڭلْذَا ن يُوشِييَا إِتّْوَاڭّْ \add ڒْْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو وَانِيثَا.   
\b  
\m
\v 20 أَوَارْنِي مَارَّا أَيَا، ؤُمِي إِكمّڒْ يُوشِييَا ثَادَّارْثْ، إِفّغْ-د نَاخُو، أَجدْجِيذْ ن مِيصْرَا، غَارْ لْفُورَاطْ حِيمَا أَذْ إِمّْنغْ أَكْ-ذ كَارْكَامِيشْ. ؤُشَا يُوشِييَا إِفّغْ-د إِ ؤُمْسَاڭَارْ أَكِيذسْ.  
\v 21 نَاخُو إِسّكّْ-د غَارسْ إِرقَّاسنْ، إِنَّا: ”مِينْ ذِينْ جَارْ أَيِي-د ذ شكْ، \add أَ\add* أَجدْجِيذْ ن يَاهُوذَا؟ وَارْ إِدْجِي غَاركْ إِ د فّْغغْ أَسّْ-أَ، مَاشَا غَارْ إِشْثْ ن ثَادَّارْثْ \add نّغْنِي\add* ثنِّي إِتّْمنْغَانْ أَكِيذِي. إِنَّا أَيِي أَربِّي إِتّْخصَّا أَيِي أَذْ قدْجْقغْ. س ؤُيَا حيّذْ خْ أَربِّي، ونِّي أَكِيذِي إِدْجَانْ، نِيغْ أَذْ شكْ يَاردّدْجْ.“  
\v 22 \add مَاشَا\add* يُوشِييَا وَارْ إِسّْنقْڒبْ أَغمْبُوبْ نّسْ زَّايسْ، مَاشَا إِڭَّا إِخفْ نّسْ وَارْ إِدْجِي ذ نتَّا حِيمَا أَكِيذسْ إِمّْنغْ، ؤُ نتَّا وَارْ إِسْڒِي غَارْ وَاوَاڒنْ ن نَاخُو \add إِنِّي د يُوسِينْ\add* زڭْ ؤُقمُّومْ ن أَربِّي، مَاشَا يُوسَا-د غَارْ ؤُمنْغِي ذِي ثغْزُورْثْ ن مَاجِيدُّو.  
\v 23 مَاشَا إِمْجبَّاذنْ نْ ڒْقوْسْ ڒقْفنْ أَجدْجِيذْ يُوشِييَا. \add خنِّي\add* إِنَّا ؤُجدْجِيذْ إِ إِمْسخَّارنْ نّسْ: ”نذْهمْ أَيِي سّنِّي، مَاغَارْ يزْمغْ أَطَّاسْ!“  
\v 24 إِمْسخَّارنْ نّسْ كْسِينْ ث ذڭْ ؤُكَارُّو ؤُشَا نذْهنْ ث ذڭْ إِجّْ ن ؤُكَارُّو نّغْنِي نِّي غَارسْ إِدْجَا، ؤُشَا إِوْينْ ث غَارْ ؤُرْشَالِيمْ. إِمُّوثْ \add ذِينِّي\add* ؤُشَا نضْڒنْ ث ذڭْ إِمضْڒَانْ ن ڒجْذُوذْ نّسْ. مَارَّا يَاهُوذَا ذ ؤُرْشَالِيمْ شضْننْ خْ يُوشِييَا.  
\v 25 إِڭَّا إِرْمِييَا إِشْثْ ن يزْڒِي ن وشْضَانْ خْ يُوشِييَا. أَڒْ أَسّْ-أَ مَارَّا إِمذْيَازنْ ذ ثْمذْيَازِينْ سَّاوَاڒنْ خْ يُوشِييَا ذڭْ إِزْڒَانْ نْسنْ ن وشْضَانْ، مِينْزِي نِيثْنِي ڭِّينْ ت ذ إِشْثْ ن ثوْصيّثْ ذِي إِسْرَائِيل. خْزَارْ، أَقَا-ثنْ تّْوَازمّمنْ ذڭْ إِزْڒَانْ س إِڭجْذُورنْ.   
\m
\v 26 إِمزْرُوينْ إِ إِقِّيمنْ ن يُوشِييَا ذ ثْمخْسِيوْثْ نّسْ إِشوَّارنْ عْلَاحْسَابْ مِينْ يُورِينْ ذِي شَّارِيعَا ن سِيذِي،  
\v 27 \add وَاهْ،\add* إِمزْرُوينْ نّسْ، إِمزْوُورَا ذ إِنڭُّورَا، أَقَا تّْوَازمّمنْ ذڭْ وذْلِيسْ ن إِجدْجِيذنْ ن إِسْرَائِيل ذ يَاهُوذَا.   
\b  
\b  
\m  
\c 36
\s1 يَاهُويَاحَازْ، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 1 كْسِينْ ڒْڭنْسْ ن ثمُّورْثْ يَاهُويَاحَازْ، مِّيسْ ن يُوشِييَا، ؤُشَا ڭِّينْ ث ذ أَجدْجِيذْ ذِي ؤُرْشَالِيمْ ذڭْ ومْشَانْ ن بَابَاسْ.\x ◘ \xo 36:‏1 \xt [2 إِج. 23‏:‏31‏-‏35]\x*  
\v 2 يَاهُويَاحَازْ \add ثُوغَا\add* غَارسْ ثْڒَاثَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا، ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثْڒَاثَا ن إِيُورنْ ذِي ؤُرْشَالِيمْ.  
\v 3 أَجدْجِيذْ ن مِيصْرَا إِكّسْ إِ-ث \add ذ أَجدْجِيذْ\add* زِي ؤُرْشَالِيمْ ؤُشَا إِڭَّا إِ ثمُّورْثْ إِجّْ ن مُولْثَا ن مْيَا ثَالِينْثْ ن نُّوقَارْثْ ذ إِشْثْ ن ثَالِينْثْ ن وُورغْ.  
\v 4 أَجدْجِيذْ ن مِيصْرَا إِڭَّا ؤُمَاسْ أَلْيَاقِيمْ ذ أَجدْجِيذْ خْ يَاهُوذَا ذ ؤُرْشَالِيمْ. نتَّا إِبدّڒْ إِسمْ نّسْ غَارْ يَاهُويَاقِيمْ. \add مَاشَا\add* ؤُمَاسْ يَاهُويَاحَازْ إِطّفْ إِ-ث نَاخُو ؤُشَا يِيوْيِي إِ-ث غَارْ مِيصْرَا.   
\b  
\m  
\s1 يَاهُويَاقِيمْ، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 5 يَاهُويَاقِيمْ \add ثُوغَا\add* غَارسْ خمْسَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ حِيطَاشْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَربِّي نّسْ. \x ◘ \xo 36:‏5 \xt [2 إِج. 23‏:‏36‏-‏37؛ 24‏:‏1‏-‏7]\x*  
\v 6 نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، إِفّغْ \add إِ ؤُمنْغِي\add* أَكِيذسْ ؤُشَا إِشَارْفْ إِ-ث س ثْنَاينْ ن سّْنَاسڒْ ن نُّوقَارْثْ، حِيمَا أَذْ ث يَاوِي غَارْ بَابِيلْ.  
\v 7 يِيوِي نابُوخَاذْنَاصَّارْ ؤُڒَا ذ \add إِجّْ ن وزْينْ\add* ن ڒقْشُوعْ زِي ثَادَّارْثْ ن سِيذِي غَارْ بَابِيلْ ؤُشَا إِسَّارْسْ إِ-ثنْ ذِي زَّاوشْثْ نّسْ ذِي بَابِيلْ.  
\v 8 إِمزْرُوينْ إِقِّيمنْ ن يَاهُويَاقِيمْ ذ جّْعَايفْ إِ إِڭَّا ؤُ مِينْ إِتّْوَافنْ ضِيدّْ نّسْ، خْزَارْ، \add مَارَّا\add* أَيَا إِتّْوَازمّمْ ذڭْ وذْلِيسْ ن إِجدْجِيذنْ ن إِسْرَائِيل ذ يَاهُوذَا. مِّيسْ يَاهُويَاكِينْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\m  
\s1 يَاهُويَاكِينْ، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 9 يَاهُويَاكِينْ \add ثُوغَا\add* غَارسْ ثْمنْطَاشْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثْڒَاثَا ن إِيُورنْ ذعشْرَا ن وُوسَّانْ ذِي ؤُرْشَالِيمْ. نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. \x ◘ \xo 36:‏9 \xt [2 إِج. 24‏:‏8‏-‏17]\x*  
\v 10 غَارْ ؤُبدّڒْ ن ؤُسڭّْوَاسْ إِجَّا ؤُجدْجِيذْ نابُوخَاذْنَاصَّارْ أَذْ ث يَاوِي غَارْ بَابِيلْ س ڒقْشُوعْ إِغْڒَانْ زِي ثَادَّارْثْ ن سِيذِي. نتَّا إِڭَّا ؤُمَاسْ صِيذْقِييَا ذ أَجدْجِيذْ خْ يَاهُوذَا ذ ؤُرْشَالِيمْ.   
\b  
\m  
\s1 صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ذِي ثْمحْبَاسْثْ غَارْ بَابِيلْ  
\m
\v 11 صِيذْقِييَا ثُوغَا غَارسْ وَاحِيثْ ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ حِيطَاشْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. \x ◘ \xo 36:‏11 \xt [2 إِج. 24‏:‏18‏-‏20؛ 25‏:‏1‏-‏12؛ إِرْم. 52‏:‏1‏-‏30]\x*  
\v 12 إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَربِّي نّسْ، وَارْ إِسّْوَاضعْ إِخفْ نّسْ زَّاثْ إِ وُوذمْ ن ؤُنَابِي إِرْمِييَا \add ونِّي إِسِّيوْڒنْ\add* خْ ڒُومُورْ ن سِيذِي.  
\v 13 ؤُڒَا ذ نتَّا إِغوّغْ خْ ؤُجدْجِيذْ نابُوخَاذْنَاصَّارْ، ونِّي ث إِجِّينْ أَذْ إِجَّادْجْ غَارْ أَربِّي. نتَّا إِسّمْحضْ إِرِي نّسْ ؤُشَا إِسّقْسحْ ؤُڒْ نّسْ مَاحنْذْ وَارْ د-إِذِّيكّْوِيڒْ غَارْ سِيذِي، أَربِّي ن إِسْرَائِيل.  
\v 14 ؤُ مَارَّا إِمقّْرَاننْ ن إِكهَّاننْ ؤُڒَا ذ ڒْڭنْسْ رُوحنْ، أَڭّْوجنْ أَطَّاسْ ذِي ڒغْذَارْ نْسنْ، \add ڭِّينْ\add* أَمْ مَامّشْ مَارَّا جّْعَايفْ ن ڒڭْنُوسْ. نِيثْنِي سّْخمْجنْ ثَادَّارْثْ ن سِيذِي ثنِّي ثُوغَا إِسّْقدّسْ ذِي ؤُرْشَالِيمْ.   
\m
\v 15 سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ إِسّكّْ-د غَارْسنْ \add إِنهَّارنْ\add* س ؤُفُوسْ ن إِرقَّاسنْ نّسْ، ڒخُّو نِيغْ ڒخْمِينْ، مَاغَارْ نتَّا ثُوغَا إِزِّيدْجِيزْ أَسْ ڒْڭنْسْ نّسْ ذ ثْزذِّيغْثْ نّسْ.  
\v 16 مَاشَا نِيثْنِي سْثهْزَانْ زڭْ إِرقَّاسنْ ن أَربِّي ؤُ سّحْقَارنْ أَوَاڒنْ نّسْ. نِيثْنِي ڭِّينْ ثَاضْصَا خْ إِنَابِييّنْ نّسْ، أَڒَامِي إِسْعَارْ سِيذِي خْ ڒْڭنْسْ نّسْ ؤُ وَارْ إِقِّيمْ عَاذْ ؤُسْڭنْفُو.  
\v 17 نتَّا إِڭَّا أَجدْجِيذْ ن إِكَالْذَانِييّنْ أَذْ غَارْسنْ د-إِفّغْ، ونِّي إِنْغِينْ إِحُوذْرِييّنْ نْسنْ س سِّيفْ ذِي ثَادَّارْثْ ن زَّاوشْثْ نْسنْ إِقدّْسنْ. نتَّا وَارْ إِسّْعِيزّْ خْ إِحُوذْرِييّنْ نِيغْ خْ ثعْزَارِييِّينْ ؤُڒَا خْ إِوسُّورَا ذ إِمشَّايْبُوثنْ. أَربِّي إِوْشَا إِ-ثنْ مَارَّا ذڭْ ؤُفُوسْ نّسْ.  
\v 18 مَارَّا ڒقْشُوعْ ن ثَادَّارْثْ ن أَربِّي، \add ڒقْشُوعْ\add* إِمقّْرَاننْ ذ إِمژْيَاننْ، ؤُڒَا ذ ثْخُوبَايْ ن ثَادَّارْثْ ن سِيذِي ذ ثْخُوبَايْ ن ؤُجدْجِيذْ ذ ڒْحُوكَّامْ نّسْ، أَقَا مَارَّا أَيَا يِيوْيِي إِ-ث غَارْ بَابِيلْ.  
\v 19 نِيثْنِي سّْشمْضنْ ثَادَّارْثْ ن أَربِّي، هذْمنْ ڒْحِيضْ ن ؤُرْشَالِيمْ ؤُشَا قّْذنْ مَارَّا ڒقْصُورْ نّسْ س ثْمسِّي ؤُ أَردّْدْجنْ مَارَّا ڒقْشُوعْ إِغْڒَانْ أَطَّاسْ زَّايسْ.  
\v 20 وِي إِقِّيمنْ زِي سِّيفْ إِنْذهْ إِ-ثنْ غَارْ لْمنْفَا غَارْ بَابِيلْ، ؤُشَا ذوْڒنْ نِيثْنِي ذ إِمْسخَّارنْ إِ نتَّا ؤُ إِ إِحنْجِيرنْ نّسْ أَڒْ ڒحْكَامثْ ن ثْڭلْذِيثْ ن لْفُورْسْ،  
\v 21 - حِيمَا أَذْ إِتّْوَاسّقْفڒْ وَاوَاڒْ ن سِيذِي \add إِ إِسِّيوڒْ\add* س ؤُقمُّومْ ن إِرْمِييَا - أَڒَامِي ثكْسِي ثَامُّورْثْ \add إِسڭّْوُوسَا نّسْ\add* ن سّبْثْ. مَارَّا ؤُسَّانْ ن وَاردّدْجْ ثُوغَا ثَامُّورْثْ ثَاريّحْ، أَڒَامِي كمّْڒنْ سبْعِينْ ن إِسڭّْوُوسَا. \x ◘ \xo 36:‏21 \xt عِز. 1‏:‏1‏-‏3، إِرْم. 25‏:‏12، 29‏:‏10، دَان. 9‏:‏2\x*   
\b  
\m  
\s1 أَعْقَابْ ن ڒْڭنْسْ س ؤُفُوسْ ن كُورَاشْ  
\m
\v 22 \add مَاشَا\add* ذڭْ ؤُسڭّْوَاسْ أَمزْوَارُو ن ؤُجدْجِيذْ كُورَاشْ، أَجدْجِيذْ ن لْفُورْسْ - حِيمَا أَذْ إِتّْوَاكمّڒْ وَاوَاڒْ ن سِيذِي س ؤُقمُّومْ ن إِرْمِييَا - إِسّكَّارْ-د سِيذِي بُوحْبڒْ ن كُورَاشْ، أَجدْجِيذْ ن لْفُورْسْ، ؤُشَا إِجَّا وَانِيثَا أَذْ د-إِفّغْ إِجّْ ن ؤُبَارّحْ ذِي مَارَّا ثَاڭلْذِيثْ نّسْ، ؤُڒَا ذِي ثِيرَا، مَاحنْذْ أَذْ يِينِي: \x ◘ \xo 36:‏22 \xt [عِز. 1‏:‏1‏-‏3؛ إِرْم. 25‏:‏12، 29‏:‏10؛ دَان. 9‏:‏2]\x*  
\v 23 ”أَمُّو إِ إِقَّارْ كُورَاشْ، أَجدْجِيذْ ن لْفُورْسْ: ’سِيذِي، أَربِّي ن إِجنْوَانْ، إِوْشَا أَيِي مَارَّا ثِيڭلْذِيوِينْ ن ثمُّورْثْ ؤُشَا نتَّا إِڭَّا خَافِي أَذْ بْنِيغْ إِشْثْ ن ثَادَّارْثْ إِ نتَّا ذِي ؤُرْشَالِيمْ ذِي يَاهُوذَا. أجّْ أَذْ إِڭعّذْ قَاعْ مَانْ ونْ زَّايْومْ زِي مَارَّا ڒْڭنْسْ نّسْ! أَذْ يِيڒِي سِيذِي، أَربِّي نّسْ، أَكِيذسْ!‘ “   