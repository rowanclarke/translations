\v 12 \w Pero|strong="G1161"\w* \w sobre|strong="G4253"\w* \w todas|strong="G3956"\w* \w las|strong="G3588"\w* \w cosas|strong="G5100"\w*, hermanos míos, \w no|strong="G3756"\w* juren \w por|strong="G5259"\w* \w el|strong="G3588"\w* \w cielo|strong="G3772"\w*, \w ni|strong="G2532"\w* \w por|strong="G5259"\w* \w la|strong="G3588"\w* \w tierra|strong="G1093"\w*, \w ni|strong="G2532"\w* \w por|strong="G5259"\w* \w ningún|strong="G3956"\w* \w otra|strong="G5100"\w* \w cosa|strong="G5100"\w*. \w Su|strong="G3588"\w* \w sí|strong="G3483"\w* \w sea|strong="G3588"\w* \w sí|strong="G3483"\w*, \w y|strong="G2532"\w* \w su|strong="G3588"\w* \w no|strong="G3756"\w* \w sea|strong="G3588"\w* \w no|strong="G3756"\w*, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w no|strong="G3756"\w* caigan \w en|strong="G3588"\w* \w juicio|strong="G2920"\w*.   
