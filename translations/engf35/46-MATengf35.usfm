\v 48 \w But|strong="G1161"\w* \w if|strong="G1437"\w* \w that|strong="G3588"\w* \w bad|strong="G2556"\w* \w servant|strong="G1401"\w* \w should|strong="G3588"\w* \w say|strong="G3004"\w* \w in|strong="G1722"\w* \w his|strong="G1722"\w* \w heart|strong="G2588"\w*, ‘\w My|strong="G1722"\w* \w lord|strong="G2962"\w* \w is|strong="G3588"\w* \w delaying|strong="G5549"\w* \w his|strong="G1722"\w* return,’  
\v 49 \w and|strong="G2532"\w* \w should|strong="G3588"\w* begin \w to|strong="G2532"\w* \w beat|strong="G5180"\w* \w his|strong="G2532"\w* \w fellow|strong="G4889"\w* \w servants|strong="G4889"\w*, \w and|strong="G2532"\w* \w to|strong="G2532"\w* \w eat|strong="G2068"\w* \w and|strong="G2532"\w* \w drink|strong="G4095"\w* \w with|strong="G3326"\w* \w the|strong="G2532"\w* \w drunkards|strong="G3184"\w*,  
