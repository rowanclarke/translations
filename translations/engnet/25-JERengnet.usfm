\v 4 “\w The|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w God|strong="H3068"\w* \w of|strong="H3068"\w* \w Israel|strong="H3478"\w* \w who|strong="H3605"\w* rules \w over|strong="H3068"\w* \w all|strong="H3605"\w* \w says|strong="H3541"\w* \w to|strong="H3478"\w* \w all|strong="H3605"\w* \w those|strong="H3605"\w* \w he|strong="H3068"\w* \w sent|strong="H1540"\w* \w into|strong="H1540"\w* \w exile|strong="H1540"\w* \w to|strong="H3478"\w* Babylon \w from|strong="H3478"\w* \w Jerusalem|strong="H3389"\w*,  
