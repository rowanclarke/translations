\v 18 Ishmael’s sons \w and|strong="H4714"\w* \w their|strong="H3605"\w* tribes, \w they|strong="H5921"\w* \w went|strong="H6440"\w* \w and|strong="H4714"\w* \w lived|strong="H7931"\w* \w far|strong="H5704"\w* \w away|strong="H5307"\w* \w from|strong="H6440"\w* \w their|strong="H3605"\w* \w other|strong="H3605"\w* relatives. \w They|strong="H5921"\w* \w went|strong="H6440"\w* \w and|strong="H4714"\w* \w lived|strong="H7931"\w* \w between|strong="H5704"\w* \w the|strong="H3605"\w* \w place|strong="H7931"\w* called \w Havilah|strong="H2341"\w* \w and|strong="H4714"\w* \w the|strong="H3605"\w* \w place|strong="H7931"\w* called \w Shur|strong="H7793"\w*, \w near|strong="H6440"\w* \w Egypt|strong="H4714"\w* country. \w Shur|strong="H7793"\w* \w is|strong="H3605"\w* also \w near|strong="H6440"\w* \w the|strong="H3605"\w* \w place|strong="H7931"\w* called Ashur.   
\s1 Isaac and Rebekah had 2 sons  
\p
