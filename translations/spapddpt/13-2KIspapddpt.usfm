\c 17
\s1 Reinado de Oseas en Israel
\p 
\v 1 \w El|strong="H5921"\w* \w año|strong="H8141"\w* 12 \w de|strong="H5921"\w* Acaz, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, comenzó \w a|strong="H3068"\w* reinar \w Oseas|strong="H1954"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Ela, \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w en|strong="H5921"\w* \w Samaria|strong="H8111"\w*, \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* \w nueve|strong="H8672"\w* \w años|strong="H8141"\w*.
\v 2 \w Hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* \w ante|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w aunque|strong="H7535"\w* \w no|strong="H3808"\w* \w como|strong="H1961"\w* \w los|strong="H1961"\w* \w reyes|strong="H4428"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w que|strong="H3808"\w* \w reinaron|strong="H4428"\w* \w antes|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H6213"\w*.
