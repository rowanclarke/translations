\id LAM - Biblica® Open Kurdi Sorani Standard Version 
\h شینەکانی یەرمیا 
\toc1 شینەکانی یەرمیا 
\toc2 شینەکانی یەرمیا 
\toc3 شینەکانی یەرمیا 
\mt1 شینەکانی یەرمیا 
\c 1  
\q1  
\v 1 چۆن ئەم شارە بەجێهێڵراوە، 
\q2 ئەوەی پڕبوو لە خەڵک! 
\q1 چۆن وەک بێوەژنی لێهات، 
\q2 ئەوەی لەناو نەتەوەکان مەزن بوو! 
\q1 ئەوەی لەنێو هەرێمەکان شاژن بوو 
\q2 ئێستا بووەتە کەنیزە! 
\b  
\q1  
\v 2 بە شەو بەکوڵ دەگریێت، 
\q2 فرمێسکی لەسەر گۆناکانییەتی. 
\q2 لەناو هەموو دۆستانی 
\q2 کەس نییە دڵنەوایی بکات. 
\q1 هەموو دڵدارانی ناپاکییان لەگەڵ کرد، 
\q2 بوون بە دوژمنی. 
\b  
\q1  
\v 3 لەدوای زەلیلی و کۆیلایەتی سەخت، 
\q2 یەهودا ڕاپێچ کرا، 
\q1 لەنێو نەتەوەکان نیشتەجێ دەبێت، 
\q2 شوێنی ئارام نابینێتەوە. 
\q1 ئەوانەی ڕاوی دەنێن 
\q2 لە ناوەڕاستی تەنگانەدا پێی دەگەن. 
\b  
\q1  
\v 4 ئەو ڕێگایانەی بەرەو سییۆنن شین دەگێڕن، 
\q2 لەبەر ئەوەی کەس بۆ جەژنەکان نایەت. 
\q1 هەموو دەروازەکانی چۆڵ دەکرێن، 
\q2 کاهینەکانی دەناڵێنن، 
\q1 پاکیزەکانی خەمبارن، 
\q2 ئەویش تاڵی دەچێژێت. 
\b  
\q1  
\v 5 ناحەزەکانی بوونە بە گەورەی ئەو، 
\q2 دوژمنەکانی سەرکەوتوون، 
\q1 چونکە یەزدان خەمباری کرد، 
\q2 لەبەر زۆری گوناهەکانی 
\q1 منداڵەکانی بەرەو خاکی غەریبی بردران، 
\q2 دوژمنەکانیان ڕاپێچیان کردن. 
\b  
\q1  
\v 6 سییۆنی کچ\f + \fr 1:6 \ft دەربڕینێکی خوازەیە بۆ پایتەخت، مەبەست لە هەموو دانیشتووانی شارەکەیە.‏\f* 
\q2 هەموو جوانییەکەی ڕۆیشت. 
\q1 میرەکانی وەک ئاسکیان لێهاتووە 
\q2 لەوەڕگایان دەست ناکەوێت، 
\q1 بە بێهێزی دەڕۆن 
\q2 لەبەردەم ئەوانەی ڕاویان دەنێن. 
\b  
\q1  
\v 7 لە ڕۆژانی زەلیلی و سەرگەردانی، 
\q2 ئۆرشەلیم هەموو خۆشییەکانی خۆی بەبیر هاتەوە، 
\q2 کە لە دێرزەمانەوە بوون. 
\q1 کاتێک گەلەکەی کەوتنە دەستی دوژمن، 
\q2 کەس نەبوو بە هانایەوە بێت. 
\q1 دوژمنان تەماشایان کرد، 
\q2 بە ڕووخانەکەی پێکەنین. 
\b  
\q1  
\v 8 ئۆرشەلیم بە تەواوی گوناهی کرد 
\q2 لەبەر ئەوە گڵاو بوو. 
\q1 هەموو ئەوانەی ڕێزیان لێی دەگرت سووکایەتی پێ دەکەن، 
\q2 چونکە ڕووتی ئەویان بینی. 
\q1 ئەویش دەناڵێنێت 
\q2 بەرەو دواوە ڕوو وەردەگێڕێت. 
\b  
\q1  
\v 9 گڵاوییەکەی بە دامێنییەوە بوو، 
\q2 بیری لە چارەنووسی خۆی نەکردەوە. 
\q1 کەوتنەکەی سامناک بوو، 
\q2 کەس نەبوو دڵنەوایی بکات. 
\q1 «ئەی یەزدان، تەماشای زەلیلیم بکە، 
\q2 چونکە دوژمن سەرکەوت.» 
\b  
\q1  
\v 10 دوژمن دەستی درێژکردووە 
\q2 بۆ سەر هەموو گەنجینەکانی، 
\q1 نەتەوەکانی بینی 
\q2 هاتنە ناو پیرۆزگاکەیەوە، 
\q1 ئەوانەی تۆ فەرمانت دا 
\q2 نەیێنە ناو کۆمەڵەکەی تۆوە. 
\b  
\q1  
\v 11 سەراپای خەڵکەکەی دەناڵێنن و 
\q2 بەدوای ناندا دەگەڕێن، 
\q1 گەنجینەکانی خۆیان بە خواردن دەدەن 
\q2 بۆ ئەوەی گیانیان بەبەردا بێتەوە. 
\q1 «ئەی یەزدان، تەماشا بکە و ببینە، 
\q2 چونکە سووک بووم.» 
\b  
\q1  
\v 12 «ئایا هیچ بۆ ئێوە نییە، ئەی هەموو ڕێبوارەکان؟ 
\q2 تەماشای دەوروبەر بکەن و ببینن. 
\q1 هیچ ئازارێک هەیە وەک ئازارەکەی من، 
\q2 ئەوەی کە تووشی منی کرد، 
\q1 ئەوەی کە یەزدان بەسەری هێنام، 
\q2 لە ڕۆژی جۆشانی تووڕەییەکەی. 
\b  
\q1  
\v 13 «لە سەرەوە ئاگری نارد، 
\q2 بۆ ناو ئێسکەکانم دایبەزاند، 
\q1 تۆڕی بۆ قاچەکانم دانایەوە 
\q2 منی بەرەو پاش گەڕاندەوە. 
\q1 منی وێران کرد، 
\q2 داهێزراو بە درێژایی ڕۆژ. 
\b  
\q1  
\v 14 «گوناهەکانم وەک نیر\f + \fr 1:14 \ft مەبەستی لە بارگرانییە.‏\f* خرانە سەرم، 
\q2 بە دەستەکانی ئەو هۆنرانەوە. 
\q1 گوناهەکانم خرانە سەر ملم و 
\q2 خودا هێزی لێ بڕیم. 
\q1 پەروەردگار منی ڕادەستی کەسانێک کرد 
\q2 کە ناتوانم بەرەنگاریان ببمەوە. 
\b  
\q1  
\v 15 «پەروەردگار هەموو پاڵەوانەکانی ڕەتکردەوە 
\q2 کە لەناو مندا بوون. 
\q1 لەشکرێکی لە دژی من بانگکرد 
\q2 بۆ تێکشکاندنی گەنجەکانم. 
\q1 پەروەردگار یەهودای کچە پاکیزەی 
\q2 لەناو گوشەر پڵیشاندەوە. 
\b  
\q1  
\v 16 «لەسەر ئەمەیە من دەگریێم، 
\q2 چاوەکانم فرمێسک دەڕێژن، 
\q1 ئەوەی دڵنەواییم دەکات لێم دوور کەوتووەتەوە، 
\q2 کەس نییە گیان ببوژێنێتەوە. 
\q1 کوڕەکانم وێران بوون، 
\q2 لەبەر ئەوەی دوژمن زاڵ بوو.» 
\b  
\q1  
\v 17 سییۆن دەستەکانی پان دەکاتەوە، 
\q2 بەڵام کەس نییە دڵنەوایی بکات. 
\q1 یەزدان فەرمانی دا لە دژی یاقوب 
\q2 کە دراوسێکانی دوژمنی ئەو بن. 
\q1 ئۆرشەلیم لەناویاندا 
\q2 گڵاو بوو. 
\b  
\q1  
\v 18 «یەزدان ڕاستودروستە، 
\q2 بەڵام من لە دژی فەرمانی ئەو یاخی بووم. 
\q1 ئەی هەموو گەلان، گوێ بگرن، 
\q2 تەماشای ئازارەکانم بکەن. 
\q1 پاکیزە و لاوەکانم 
\q2 ڕاپێچ کران. 
\b  
\q1  
\v 19 «هاوارم بردە لای هاوپەیمانەکانم، 
\q2 بەڵام هەڵیانخەڵەتاندم. 
\q1 کاهین و پیرەکانم 
\q2 لە شاردا لەناوچوون 
\q1 لەو کاتەی بەدوای خۆراکدا دەگەڕان 
\q2 بۆ ئەوەی لە ژیانیان بەردەوام بن. 
\b  
\q1  
\v 20 «ئەی یەزدان، ببینە، من لە تەنگانەدام! 
\q2 دڵم توندە، 
\q1 من لە ناخەوە پەستم، 
\q2 چونکە زۆر یاخی بووم. 
\q1 لە دەرەوە شمشێر دەستبەکارە، 
\q2 لە ماڵەوەش تەنها مردن هەیە. 
\b  
\q1  
\v 21 «خەڵک ناڵەی منیان بیست، 
\q2 بەڵام کەس نییە دڵنەواییم بکات. 
\q1 هەموو دوژمنەکانم بەڵای منیان بیست، 
\q2 دڵخۆش بوون بەوەی تۆ بە منت کردووە. 
\q1 خۆزگە ئەو ڕۆژەت بەسەردەهێنان کە باست کرد، 
\q2 ئینجا وەک منیان لێدێت. 
\b  
\q1  
\v 22 «با هەموو خراپەکانیان بێنە بەردەمت، 
\q2 وایان بەسەربهێنە 
\q1 وەک ئەوی بەسەر منت هێنا 
\q2 لەسەر هەموو گوناهەکانم. 
\q1 زۆر دەناڵێنم و 
\q2 دڵم لاواز بووە.» 
\b  
\b  
\c 2  
\q1  
\v 1 چۆن پەروەردگار سییۆنی کچی داپۆشی 
\q2 بە هەوری تووڕەییەکەی! 
\q1 لە ئاسمانەوە شکۆی ئیسرائیلی فڕێدا 
\q2 بۆ سەر زەوی، 
\q1 لە ڕۆژی تووڕەییدا 
\q2 تەختەپێی خۆی بەبیر نەهێنایەوە. 
\b  
\q1  
\v 2 پەروەردگار بەزەیی نەهاتەوە، 
\q2 هەموو نشینگەکانی یاقوبی هەڵلووشی، 
\q1 بە تووڕەیی خۆی 
\q2 قەڵاکانی یەهودای کچی ڕووخاند. 
\q1 پاشایەتی و میرەکانی زەلیل کرد 
\q2 دایگرتنە سەر زەوی. 
\b  
\q1  
\v 3 بە گڕی تووڕەیی خۆی بڕییەوە 
\q2 هەموو هێزی ئیسرائیل. 
\q1 دەستی ڕاستی بەرەو دواوە کێشایەوە 
\q2 لەبەردەم دوژمن. 
\q1 ئاگرێکی بەتینی لەناو یاقوبدا داگیرساند، 
\q2 هەموو دەوروبەرەکەی دەخوات. 
\b  
\q1  
\v 4 وەک دوژمنێک کەوانەکەی خۆی ڕاکێشا، 
\q2 دەستی ڕاستی ئامادە کرد. 
\q1 وەک ناحەز لەناوی برد 
\q2 هەموو ئەوەی چاو ئارەزووی دەکرد. 
\q1 لەناو چادرەکەی سییۆنی کچ 
\q2 تووڕەیی خۆی وەک ئاگر ڕشت. 
\b  
\q1  
\v 5 پەروەردگار وەک دوژمنی لێهات، 
\q2 ئیسرائیلی هەڵلووشی. 
\q1 هەموو کۆشکەکانی ئەوی هەڵلووشی، 
\q2 قەڵاکانی ڕووخاند. 
\q1 شیوەن و ماتەمی زۆر کرد 
\q2 بۆ یەهودای کچ. 
\b  
\q1  
\v 6 کەپرەکەی تێکدا، وەک باخچەیەک نەما، 
\q2 شوێنی کۆبوونەوەکەی ڕووخاند. 
\q1 یەزدان وای کرد سییۆن لەبیری بچێتەوە 
\q2 ڕۆژی شەممە و جەژنەکان. 
\q1 بە تووڕەیی خۆی 
\q2 پاشا و کاهینی ڕەتکردەوە. 
\b  
\q1  
\v 7 پەروەردگار قوربانگاکەی خۆی ڕەتکردەوە، 
\q2 وازی لە پیرۆزگاکەی خۆشی هێنا. 
\q1 دیواری کۆشکەکانی 
\q2 ڕادەستی دوژمنەکانی کرد. 
\q1 لەناو ماڵی یەزدان دەنگیان هەڵبڕی 
\q2 وەک لە ڕۆژی جەژندا. 
\b  
\q1  
\v 8 شووراکانی سییۆنی کچ 
\q2 یەزدان مەبەستی بوو بیڕووخێنێت. 
\q1 بە گوریس پێوای و 
\q2 دەستی لە وێرانکردنی نەگێڕایەوە. 
\q1 سەنگەر و دیواری هێنایە گریان و 
\q2 پێکەوە ڕووخان. 
\b  
\q1  
\v 9 دەروازەکانی نوقومی زەوی بوون، 
\q2 شمشیرەکانی\f + \fr 2:9 \ft شمشیر، پارچە دارێک بووە لە جیاتی قوفڵ لە دواوەی دەرگا بە شێوەی ئاسۆیی دانراوە بۆ داخستنی دەرگا.‏\f* لەناوبرد و شکاندی. 
\q1 پاشا و میرەکانی بۆ نێو گەلان ڕاپێچ کراون، 
\q2 فێرکردنی موسا نەماوە، 
\q1 هەروەها پێغەمبەرەکانیشی 
\q2 هیچ بینینێکیان لەلایەن یەزدانەوە بۆ ئاشکرا نەکراوە. 
\b  
\q1  
\v 10 پیرەکانی شاری سییۆن 
\q2 بە کپی لەسەر زەوی دادەنیشن، 
\q1 خۆڵ بەسەر سەریاندا دەکەن، 
\q2 جلوبەرگی گوش\f + \fr 2:10 \ft لە کاتی ماتەمگێڕان و تۆبەکردندا جلوبەرگی لە گوش دروستکراویان لەبەرکردووە کە ئەزیەتی پێستیانی داوە.‏\f* لەبەر دەکەن. 
\q1 پاکیزەکانی ئۆرشەلیم 
\q2 سەریان دادەنەوێنن. 
\b  
\q1  
\v 11 چاوەکانم ماندووبوون لە فرمێسک ڕشتن، 
\q2 دڵم توندە، 
\q1 جەرگ بڕاوم 
\q2 لەبەر ئەوەی گەلەکەم وێران بوو، 
\q1 لەبەر بوورانەوەی منداڵان و شیرەخۆران 
\q2 لەناو گۆڕەپانەکانی شاردا. 
\b  
\q1  
\v 12 بە دایکیان دەڵێن: 
\q2 «کوا نان و ئاو\f + \fr 2:12 \ft عیبری: نان و شەراب، دەربڕینێکە مەبەستی لێی خۆراکە بۆ بژێوی مرۆڤ.‏\f*؟» 
\q1 کاتێک وەک بریندار 
\q2 لەناو گۆڕەپانەکانی شاردا دەبوورێنەوە، 
\q1 کاتێک ڕۆحیان دەردەچێت 
\q2 لەناو باوەشی دایکیان. 
\b  
\q1  
\v 13 چیت پێ بڵێم؟ 
\q2 ئەی ئۆرشەلیمی کچ، 
\q2 بە چیت بچووێنم؟ 
\q1 بە چی بەراوردت بکەم، 
\q2 بۆ ئەوەی دڵت بدەمەوە، 
\q2 ئەی سییۆنی کچە پاکیزە؟ 
\q1 وێران بوونت وەک دەریا قووڵە. 
\q2 کێ دەتوانێت چاکت بکاتەوە؟ 
\b  
\q1  
\v 14 بینینی خودایی بۆ پێغەمبەرەکانت 
\q2 درۆ و فریودەر بوو، 
\q1 تاوانی تۆیان دەرنەخست 
\q2 بۆ ئەوەی لە ڕاپێچکردن بتپارێزن. 
\q1 بەڵکو سروشی\f + \fr 2:14 \ft ‏فەرموودەیەکی خودایە کە لە ڕێگای ڕۆحی پیرۆزەوە بۆ مرۆڤ هاتبێت.‏\f* 
\q2 درۆ و هەڵخەڵەتێنەریان بە تۆ گەیاند. 
\b  
\q1  
\v 15 هەموو ئەوەی بەوێدا تێدەپەڕێت 
\q2 بە گاڵتەپێکردنەوە چەپڵەت بۆ لێدەدات، 
\q1 فیکە لێ دەدەن و سەر بادەدەن 
\q2 لەبەر ئۆرشەلیمی کچ، 
\q1 دەڵێن: «ئەمە شارەکەیە 
\q2 کە پێی دەگوترا تەواوی جوانی و 
\q2 مایەی دڵخۆشی هەموو زەوییە؟» 
\b  
\q1  
\v 16 هەموو دوژمنەکانت 
\q2 دەمیان لێت دەکرێتەوە، 
\q1 فیشکەیان دێت و ددانیان لێت جیڕدەکەنەوە، 
\q2 دەڵێن: «هەڵمانلووشی. 
\q1 بێگومان ئەمە ئەو ڕۆژەیە کە چاوەڕوانی بووین، 
\q2 پێی گەیشتین و بینیمان.» 
\b  
\q1  
\v 17 یەزدان ئەوەی مەبەستی بوو کردی، 
\q2 قسەی خۆی بەجێگەیاند، 
\q2 ئەوەی لە ڕۆژانی کۆنەوە بەڵێنی پێیدا. 
\q1 بەبێ بەزەیی تۆی ڕووخاند، 
\q2 دوژمنی پێت خۆشکرد، 
\q2 هێزی ناحەزانی تۆی پتەو کرد. 
\b  
\q1  
\v 18 دڵی خەڵکەکە 
\q2 بۆ پەروەردگار هاوار دەکات. 
\q1 ئەی شووراکانی سییۆنی کچ، 
\q1 با فرمێسکەکانت وەک ڕووبار بڕژێت 
\q2 بە شەو و بە ڕۆژ. 
\q1 خۆت مەبووژێنەوە، 
\q2 چاوەکانت پشوو نەدات. 
\b  
\q1  
\v 19 هەستە، بە شەو هاوار بکە، 
\q2 لەگەڵ دەستپێکردنی ئێشکگرتن. 
\q1 وەک ئاو دڵت هەڵبڕێژە 
\q2 لەبەردەم پەروەردگار. 
\q1 دەستت بۆی بەرز بکەوە 
\q2 لە پێناوی ژیانی منداڵەکانت، 
\q1 ئەوانەی لە برسان بووراونەتەوە 
\q2 لەسەر سووچی هەموو شەقامەکان. 
\b  
\q1  
\v 20 «ئەی یەزدان، ببینە و تێڕابمێنە، 
\q2 ئەمەت بە کێ کردووە؟ 
\q1 ئایا ژن بەری سکی خۆی دەخوات، 
\q2 منداڵی باوەشی؟ 
\q1 ئایا کاهین و پێغەمبەر 
\q2 لە پیرۆزگای پەروەردگار دەکوژرێت؟ 
\b  
\q1  
\v 21 «گەنج و پیر پێکەوە پاڵکەوتن 
\q2 لەسەر زەوی شەقامەکان، 
\q1 پاکیزە و لاوەکانم 
\q2 بە شمشێر کوژراون. 
\q1 لە ڕۆژی تووڕەییتدا ئەوانت کوشت، 
\q2 ئەوانت بەبێ بەزەیی سەربڕی. 
\b  
\q1  
\v 22 «هەروەک بۆ ڕۆژی جەژن بانگهێشتت کردبن، 
\q2 ئاوا لە دژی من لە هەموو لایەکەوە بانگی تۆقینت کرد. 
\q1 لە ڕۆژی تووڕەیی یەزدان 
\q2 کەس ڕاینەکرد و کەس دەرباز نەبوو، 
\q1 ئەوانەی لە باوەشم کردن و بەخێوم کردن، 
\q2 دوژمن لەناوی بردن.» 
\b  
\b  
\c 3  
\q1  
\v 1 من ئەو پیاوەم کە زەلیلیم بینی 
\q2 بە گۆچانی تووڕەیی ئەو. 
\q1  
\v 2 منی بە پێش خۆی دا و 
\q2 منی بە تاریکاییدا برد، بەبێ هیچ ڕووناکییەک. 
\q1  
\v 3 بێگومان، دەستی لە دژی من بەرزدەکاتەوە 
\q2 بە بەردەوامی و بە درێژایی ڕۆژ. 
\b  
\q1  
\v 4 گۆشت و پێستی منی پیرکرد، 
\q2 ئێسکەکانی شکاندم. 
\q1  
\v 5 دەوری گرتم و گەمارۆی دام 
\q2 بە ژەهر و ناخۆشی. 
\q1  
\v 6 ناچاری کردم لەناو تاریکیدا نیشتەجێ بم 
\q2 وەک ئەوانەی لەمێژە مردوون. 
\b  
\q1  
\v 7 لەناو پەرژینێک بەندی کرد بۆ ئەوەی نەتوانم هەڵبێم، 
\q2 زنجیرەکانی منی قورس کرد. 
\q1  
\v 8 هەروەها کاتێک هاوار دەکەم و داوای فریاکەوتن دەکەم، 
\q2 بەڵام نزاکانم ڕادەگرێت. 
\q1  
\v 9 بەردی تاشراوی کەڵەکە کرد و ڕێگای منی پێ گرت، 
\q2 ڕێڕەوەکانی منی خواروخێچ کرد. 
\b  
\q1  
\v 10 وەک ورچێک بۆم لە بۆسەدایە، 
\q2 وەک شێرێک خۆی مات دەکات، 
\q1  
\v 11 منی لەڕێ لادا و پارچەپارچەی کردم، 
\q2 منی وێران کرد. 
\q1  
\v 12 کەوانەکەی ڕاکێشا 
\q2 منی کردە نیشانەی تیرەکانی. 
\b  
\q1  
\v 13 تیرەکانی تیردانەکەی 
\q2 لە دڵم چەقاند. 
\q1  
\v 14 هەموو گەلەکەم سووکایەتیم پێ دەکەن، 
\q2 بە درێژایی ڕۆژ بە گۆرانی گاڵتەم پێ دەکەن. 
\q1  
\v 15 تێری کردم لە تاڵی، 
\q2 زەقنەبووتی دەرخوارد دام. 
\b  
\q1  
\v 16 بە چەو ددانەکانی منی وردوخاش کرد، 
\q2 منی لەناو خۆڵەمێش پەستایەوە. 
\q1  
\v 17 من لە ئاشتی بێبەش کراوم، 
\q2 سەرکەوتنم لەبیرچووەوە. 
\q1  
\v 18 ئینجا گوتم، «شکۆمەندیم نەما، 
\q2 هەروەها هیوام بە یەزدان بڕا.» 
\b  
\q1  
\v 19 دێتەوە بیرم، ڕۆژانی زەلیلی و سەرگەردانیم، 
\q2 وەک ژەهر و زەقنەبووت بوون. 
\q1  
\v 20 بە باشی بەبیرم دێتەوە، 
\q2 لە ناخەوە ڕۆحم خەمبارە. 
\q1  
\v 21 بەڵام ئەوە دەهێنمەوە یادم و 
\q2 لەبەر ئەوە هیوام هەیە: 
\b  
\q1  
\v 22 بەهۆی خۆشەویستی نەگۆڕی یەزدانە کە لەناونەچووین، 
\q2 چونکە بەزەییەکەی تەواو نابێت. 
\q1  
\v 23 ئەوانەت هەموو بەیانییەک نوێن؛ 
\q2 دڵسۆزییەکەت چەند گەورەیە. 
\q1  
\v 24 بە خۆم دەڵێم: «یەزدان بەشی منە، 
\q2 لەبەر ئەوە هیوام بەوە.» 
\b  
\q1  
\v 25 یەزدان چاکە بۆ ئەوانەی هیوایان بەو هەیە، 
\q2 بۆ ئەو کەسەی داوای ئەو دەکات. 
\q1  
\v 26 باشە بۆ کەسێک بە بێدەنگی چاوەڕێ بکات 
\q2 بۆ هاتنی ڕزگاریی یەزدان. 
\q1  
\v 27 باشە پیاو نیر هەڵبگرێت 
\q2 هەر لە تەمەنی منداڵییەوە. 
\b  
\q1  
\v 28 با بە تەنها دانیشێت و بێدەنگ بێت، 
\q2 چونکە یەزدان ئەمەی بەسەرهێناوە. 
\q1  
\v 29 با سەری بخاتە ناو خاکوخۆڵ، 
\q2 لەوانەیە هێشتا هیوای مابێت. 
\q1  
\v 30 با ڕوومەتی بۆ ئەوە ڕابگرێت کە لێی دەدات، 
\q2 با تێربێت لە ڕیسوایی. 
\b  
\q1  
\v 31 چونکە کەس بۆ هەتاهەتایە 
\q2 لەلایەن پەروەردگارەوە ڕەت ناکرێتەوە. 
\q1  
\v 32 لەگەڵ ئەوەی دڵتەنگی دەهێنێت، میهرەبانیش نیشان دەدات، 
\q2 بەپێی گەورەیی خۆشەویستییە نەگۆڕەکەی. 
\q1  
\v 33 ئەو کەس لە دڵەوە زەلیل ناکات و 
\q2 دڵتەنگی ناکات. 
\b  
\q1  
\v 34 تێکشکاندنی دیلەکانی هەموو زەوی 
\q2 لەژێر پێ، 
\q1  
\v 35 یان بێبەشکردنی کەسێک لە مافی خۆی 
\q2 لەبەردەم خودای هەرەبەرز، 
\q1  
\v 36 یان بەدوورگرتنی مرۆڤ لە دادپەروەری، 
\q2 ئایا پەروەردگار هەموو ئەمانە نابینێت؟ 
\b  
\q1  
\v 37 کێ دەتوانێت قسە بکات قسەکەی بێتەجێ، 
\q2 ئەگەر پەروەردگار فەرمانی نەدابێت؟ 
\q1  
\v 38 ئایا ڕوودانی چاکە و خراپە 
\q2 بە فەرمایشتی خودای هەرەبەرز نییە؟ 
\q1  
\v 39 بۆچی مرۆڤی زیندوو گلەیی بکات 
\q2 کاتێک لەسەر گوناهەکانی سزا دەدرێت؟ 
\b  
\q1  
\v 40 با هەڵسوکەوتمان بپشکنین و تاقی بکەینەوە و 
\q2 بگەڕێینەوە بۆ لای یەزدان. 
\q1  
\v 41 با دڵ و دەستمان بەرزبکەینەوە 
\q2 بۆ خودا لە ئاسمان، بڵێین: 
\q1  
\v 42 «ئێمە گوناهمان کرد و یاخی بووین، 
\q2 تۆش لێمان خۆش نەبوویت. 
\b  
\q1  
\v 43 «خۆت بە تووڕەیی داپۆشی و ڕاوتناین، 
\q2 بەبێ بەزەیی ئێمەت کوشت. 
\q1  
\v 44 بە هەور خۆت داپۆشی 
\q2 بۆ ئەوەی نوێژەکانمان نەگاتە لات. 
\q1  
\v 45 ئێمەت کرد بە پاشەڕۆ و نەویستراو 
\q2 لەنێو گەلان. 
\b  
\q1  
\v 46 «هەموو دوژمنانمان 
\q2 دەمیان لێمان کردەوە. 
\q1  
\v 47 ترس و تەڵە باڵی بەسەرماندا کێشا، 
\q2 لەناوچوون و وێرانی.» 
\q1  
\v 48 چاوەکانم کانی فرمێسک هەڵدەڕێژن 
\q2 لەبەر ئەوەی گەلەکەم لەناوچوون. 
\b  
\q1  
\v 49 چاوەکانم فرمێسک هەڵدەڕێژن و ناوەستن 
\q2 بەبێ پسانەوە، 
\q1  
\v 50 تاوەکو یەزدان لە ئاسمانەوە 
\q2 تەماشای خوارەوە بکات و ببینێت. 
\q1  
\v 51 ئەوەی دەیبینم گیانم ئازار دەدات 
\q2 لەبەر ئازاری کچانی شارەکەم. 
\b  
\q1  
\v 52 ئەوانەی دوژمنی من بوون بەبێ هۆ 
\q2 وەک چۆلەکە ڕاویان کردم. 
\q1  
\v 53 بە زیندووێتی منیان فڕێدا ناو چاڵ، 
\q2 بەردیان تێمگرت. 
\q1  
\v 54 نوقومی ئاو بووم، 
\q2 گوتم: «خەریکە بمرم.» 
\b  
\q1  
\v 55 ئەی یەزدان، لە قووڵایی چاڵەوە 
\q2 بە ناوی تۆوە نزا دەکەم. 
\q1  
\v 56 گوێت لە دەنگم بوو: 
\q2 «گوێت دامەخە کاتێک هاوار و هانات بۆ دەهێنم.» 
\q1  
\v 57 ئەو ڕۆژەی نزام بۆ کردیت نزیک بوویتەوە، 
\q2 فەرمووت: «مەترسە!» 
\b  
\q1  
\v 58 ئەی پەروەردگار، بەرگریت لە کێشەی من کرد، 
\q2 ژیانی منت کڕییەوە. 
\q1  
\v 59 ئەی یەزدان، ستەمدیدەیی منت بینی. 
\q2 دادوەری کێشەکەم بکە! 
\q1  
\v 60 هەموو تۆڵەسەندنەوەکەی ئەوانت بینی، 
\q2 هەموو پیلانەکانیان لە دژی من. 
\b  
\q1  
\v 61 ئەی یەزدان، گوێت لە ڕیسواکردنەکەیان بوو، 
\q2 هەموو پیلانەکانیان لە دژی من؛ 
\q1  
\v 62 ئەوەی دوژمنەکانم بە درێژایی ڕۆژ لە دژی من 
\q2 باسی دەکەن و دەیچرپێنن. 
\q1  
\v 63 تەماشایان بکە! هەستان و دانیشتنیان، 
\q2 بە گۆرانییەکانیان گاڵتەم پێ دەکەن. 
\b  
\q1  
\v 64 ئەی یەزدان، سزایان بدە، 
\q2 بەپێی کردەوەکانی دەستیان. 
\q1  
\v 65 پێچە لەسەر دڵیان دابنێ، 
\q2 با نەفرەتت لەسەریان بێت! 
\q1  
\v 66 بە تووڕەییەوە ڕاویان بنێ و لەناویان ببە 
\q2 لەژێر ئاسمانی یەزداندا. 
\b  
\c 4  
\q1  
\v 1 چۆن زێڕ ڕەونەقی خۆی لەدەستدات، 
\q2 زێڕی بێگەرد گۆڕا! 
\q1 بەردەکانی پیرۆزگا پەرشوبڵاو بوونەوە 
\q2 لەسەر سووچی هەموو شەقامێک. 
\b  
\q1  
\v 2 چۆن کوڕە بەهادارەکانی سییۆن، 
\q2 ئەوانەی بە زێڕی بێگەرد دەکێشران، 
\q1 ئێستا بە گۆزەی گڵ دانران، 
\q2 دەستکردی دەستی گۆزەکەر! 
\b  
\q1  
\v 3 تەنانەت چەقەڵەکانیش گوانیان دەدەنە توولەکانیان 
\q2 بۆ ئەوەی شیریان پێبدەن، 
\q1 بەڵام گەلەکەی من دڵڕەقە 
\q2 وەک وشترمرغ لە چۆڵەوانی. 
\b  
\q1  
\v 4 لەبەر تینووێتی 
\q2 شیرەخۆرە زمانی بە مەڵاشوویەوە نووسا. 
\q1 منداڵەکان داوای نان دەکەن، 
\q2 بەڵام کەس نییە بۆیان بشکێنێت. 
\b  
\q1  
\v 5 ئەوانەی خواردنی خۆشیان دەخوارد 
\q2 لە شەقامەکاندا وێران بوون، 
\q1 ئەوانەی لەناو جلوبەرگی ئەرخەوانی بەخێو دەکران 
\q2 لەسەر زبڵدانەکان پاڵ دەدەنەوە. 
\b  
\q1  
\v 6 سزای تاوانی گەلەکەم گەورەتر بوو 
\q2 لە سزای گوناهەکەی سەدۆم، 
\q1 ئەوەی لە چرکەیەکدا سەرەوژێر بوو 
\q2 بێ ئەوەی دەستی یارمەتی بۆ درێژ بکرێت. 
\b  
\q1  
\v 7 میرەکانیان لە بەفر بێگەردتر بوون، 
\q2 لە شیر سپیتر بوون، 
\q1 جەستەیان لە یاقووت\f + \fr 4:7 \ft یاقووت: گەوهەری سووری تێر.‏\f* سوورتر بوو، 
\q2 وەک یاقووتی شین\f + \fr 4:7 \ft یاقووتی شین: دەشێت وەک لاجیوەرد بێت.‏\f* بوون. 
\b  
\q1  
\v 8 بەڵام ئێستا ڕەنگیان لە ڕەژوو ڕەشترە، 
\q2 لە شەقامەکاندا ناناسرێنەوە. 
\q1 پێستیان بە ئێسکیانەوە نووساوە 
\q2 وەک تەختەدار وشک هەڵگەڕاوە. 
\b  
\q1  
\v 9 ئەوانەی بە شمشێر کوژران باشتر بوون 
\q2 لەوانەی بە قاتوقڕی مردن. 
\q1 ئەوانە بە برسیێتی ئازاریان چێشت، 
\q2 چونکە خواردن لە کێڵگە نەبوو. 
\b  
\q1  
\v 10 دایکە میهرەبانەکان 
\q2 بە دەستی خۆیان منداڵەکانیان لێنا، 
\q1 کردیان بە خۆراک 
\q2 کاتێک گەلەکەم لەناوچوو. 
\b  
\q1  
\v 11 یەزدان تووڕەیی خۆی دەردەبڕێت، 
\q2 هەڵچوونی بە جۆشی خۆی هەڵدەڕێژێت. 
\q1 ئاگرێکی لە سییۆن بەرپا کرد 
\q2 بناغەکانی سووتاند. 
\b  
\q1  
\v 12 پاشاکانی زەوی و هەموو دانیشتووانی جیهان 
\q2 باوەڕیان نەکرد 
\q1 کە دوژمن و ناحەز 
\q2 دێنە ناو دەروازەکانی ئۆرشەلیمەوە. 
\b  
\q1  
\v 13 بەڵام لەبەر گوناهی پێغەمبەرەکانی\f + \fr 4:13 \ft مەبەستی لەوانەیە کە خۆیان وەک پێغەمبەر دەناساند و لە ڕاستیشدا پێغەمبەر نەبوون. بڕوانە یەرمیا 5‏:31؛ 6‏:13.‏\f* و 
\q2 تاوانی کاهینەکانی ڕوویدا، 
\q1 ئەوانەی لە ناوەڕاستیدا 
\q2 خوێنی ڕاستودروستانیان دەڕشت. 
\b  
\q1  
\v 14 بە شەقامەکاندا وێڵ بوون 
\q2 وەک کوێر. 
\q1 خۆیان بە خوێن گڵاوکرد، 
\q2 کەس ناتوانێت دەست لە جلەکانیان بدات. 
\b  
\q1  
\v 15 خەڵک هاواریان لێ دەکەن: «ئەی گڵاوەکان، دووربکەونەوە! 
\q2 دووربکەونەوە! دووربکەونەوە، دەستمان لێ مەدەن!» 
\q1 کاتێک ڕایانکرد و وێڵ بوون، 
\q2 لەناو گەلاندا گوتیان، 
\q2 «جارێکی دیکە ناتوانن لێرە نیشتەجێ بن.» 
\b  
\q1  
\v 16 یەزدان خۆی پەرتەوازەی کردن، 
\q2 ئیتر چاودێرییان ناکات. 
\q1 خەڵک ڕێزیان لە کاهینەکان نەگرت، 
\q2 لەگەڵ پیرەکان میهرەبان نەبوون. 
\b  
\q1  
\v 17 سەرباری ئەمەش، ئێمە چاومان کزبوو 
\q2 بێهوودە لە چاوەڕوانی یارمەتی، 
\q1 لە قوللەکانمان چاوەڕێ بووین 
\q2 بۆ گەلێک کە ناتوانێت ڕزگارمان بکات. 
\b  
\q1  
\v 18 تەڵەیان بۆ هەنگاوەکانمان ناوەتەوە 
\q2 بۆ ئەوەی لە گۆڕەپانەکانماندا هاتوچۆ نەکەین. 
\q1 کۆتاییمان نزیک بووەوە، چەند ڕۆژێکمان ماوە، 
\q2 چونکە کۆتاییمان هات. 
\b  
\q1  
\v 19 ئەوانەی ڕاویان دەناین سووکتر بوون 
\q2 لە هەڵۆکانی ئاسمان، 
\q1 بەسەر چیاکاندا شوێنمان کەوتن، 
\q2 لە چۆڵەوانیدا بۆسەیان بۆمان نایەوە. 
\b  
\q1  
\v 20 پاشای دەستنیشانکراوی یەزدان، ئەوەی هەناسەی ژیانمانە، 
\q2 لە بۆسەکانیان گیرا، 
\q1 ئەوەی گوتمان، لە سێبەری ئەودا 
\q2 لەنێو گەلان دەژین. 
\b  
\q1  
\v 21 ئەی کچی ئەدۆم، دڵخۆش و دڵشادبە، 
\q2 ئەی دانیشتووانی خاکی عوچ. 
\q1 بەڵام جامەکە بەسەر تۆشدا تێدەپەڕێت، 
\q2 سەرخۆش دەبیت و ڕووت دەبیتەوە. 
\b  
\q1  
\v 22 ئەی سییۆنی کچ، سزای تاوانەکەت تەواو دەبێت، 
\q2 ڕاپێچکراوییەکەت درێژ ناکاتەوە. 
\q1 بەڵام ئەی ئەدۆمی کچ، سزای تاوانەکەی تۆ دەدات، 
\q2 گوناهەکەت ئاشکرا دەکات. 
\b  
\b  
\c 5  
\q1  
\v 1 ئەی یەزدان، بەبیرت بێتەوە چیمان بەسەرهات، 
\q2 تەماشا بکە و ڕیسواییەکەمان ببینە. 
\q1  
\v 2 میراتەکەمان بۆ نامۆکان بوو، 
\q2 ماڵمان بۆ بێگانە. 
\q1  
\v 3 هەتیو و بێ باوک بووین، 
\q2 دایکانمان وەک بێوەژنن. 
\q1  
\v 4 دەبێ ئەو ئاوە بکڕین کە دەیخۆینەوە 
\q2 دارەکانمان بە نرخ بۆمان دێت. 
\q1  
\v 5 ئەوانەی ڕاومان دەنێن زۆر نزیک بوونەوە، 
\q2 ماندوو دەبین و حەوانەوەمان نییە. 
\q1  
\v 6 دەستمان لە میسری و ئاشورییەکان پانکردەوە 
\q2 بۆ بەدەستهێنانی نانی پێویست. 
\q1  
\v 7 باوکانمان گوناهیان کرد، نەمان، 
\q2 ئێمەش سزاکەیان وەردەگرین. 
\q1  
\v 8 کۆیلەکان فەرمانڕەوایەتیمان دەکەن، 
\q2 کەس نییە لە دەستیان ڕزگارمان بکات. 
\q1  
\v 9 بەهۆی شمشێر لە چۆڵەوانی ژیانمان لە مەترسیدایە 
\q2 هەتا بژێوی پەیدا دەکەین. 
\q1  
\v 10 پێستمان وەک تەنوور سووتاوە، 
\q2 لەبەر برسیێتی برژاوین. 
\q1  
\v 11 لە سییۆن دەستدرێژییان کردە سەر ژنان، 
\q2 پاکیزەکانیش لە شارۆچکەکانی یەهودا. 
\q1  
\v 12 میران بە دەستیانەوە هەڵدەواسرێن، 
\q2 ڕێز لە پیران ناگیرێت. 
\q1  
\v 13 لاوانیان دەهاڕدرێن، 
\q2 منداڵان لەژێر بارەداردا بەلادادێن. 
\q1  
\v 14 پیران دەستیان لە دەروازە هەڵدەگرن، 
\q2 لاوانیش وازیان لە گۆرانی هێنا. 
\q1  
\v 15 خۆشی دڵمان نەما، 
\q2 شاییمان بوو بە شیوەن. 
\q1  
\v 16 تاجی سەرمان کەوت. 
\q2 قوڕبەسەرمان، چونکە گوناهمان کرد! 
\q1  
\v 17 لەبەر ئەم شتانە دڵمان داهێزرا، 
\q2 لەبەر ئەم ڕووداوانە بەرچاومان تاریک بوو، 
\q1  
\v 18 لەبەر کێوی سییۆن، وێران بوو، 
\q2 چەقەڵ هاتوچۆی تێدا دەکەن. 
\b  
\q1  
\v 19 ئەی یەزدان، تۆ بۆ هەتاهەتایە حوکم دەکەیت، 
\q2 تەختی تۆ نەوە دوای نەوە بەردەوام دەبێت. 
\q1  
\v 20 بۆچی بەردەوام لەبیرمان دەکەیت؟ 
\q2 بۆچی کاتێکی درێژ بەجێمان دەهێڵیت؟ 
\q1  
\v 21 ئەی یەزدان، بمانگەڕێنەوە بۆ لای خۆت، هەتا بگەڕێینەوە، 
\q2 وەک جاران ڕۆژانمان نوێ بکەرەوە، 
\q1  
\v 22 یان تۆ زۆر لێمان تووڕە بوویت و 
\q2 بە تەواوی ئێمەت ڕەتکردووەتەوە؟