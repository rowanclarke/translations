\id 1JN Ika New Testament 2009 
\h 1 Jọnụ 
\toc1 Ẹhụhụọ-Ozi Nke Ibuzọ Jọnụ De 
\toc2 Jọnụ, Nke Ibuzọ 
\toc3 1Jn 
\mt2 Ẹhụhụọ-Ozi Nke Ibuzọ 
\mt2 Jọnụ 
\mt2 De 
\mt1 (Jọnụ, Nke Ibuzọ) 
\c 1  
\cl Isi Nke Ohu 
\s1 Oku Hụn E Ye Ndụn 
\p  
\v 1 Hụn ahụn rị gha mbidọn lala kẹ ẹnyi rị a gwa ọnụ oku ẹ, Hụn ahụn ẹnyi gi ntịn nụ, hụn ẹnyi gi ẹnya ẹnyi hụn. Ẹnyi e legụọ a, ẹnyi e mẹtụghọ a ẹka. Oku hụ e ye ndụn wụ Jizọsị kẹ ẹnyi rị e ku oku ẹ.  
\v 2 Ndụn hụ nọ pụha hụn w'e legha ẹnya. Ẹnyi a hụnghọ a. Ẹnyi hụ e ku banyen'ẹ, a gwa ụnụ banyeni ndụn itẹbitẹ hụ. Ndụn itẹbitẹ hụ lẹ Chuku-Nẹdi te rị, kanị ọ nọ pụha nị ẹnyi legha.  
\v 3 Ẹnyi rị nwan a gwa ụnụ ihiẹn ẹnyi hụn lẹ ihiẹn ẹnyi nụ, kẹni ụnụ hụn ụzọ du ẹnyi mẹkọ— makẹni Nẹdi-ẹnyi lẹ Nwa a wụ Jesu Kristi kẹ ẹnyi lẹ wẹ rị e mẹkọ.  
\v 4 Ẹnyi rị e de ihiẹn ndịnị kẹni ịghọghọ ẹnyi hụn ụzọ zu oke. 
\s1 Ukpẹ Sụọ Kẹ Osolobuẹ Wụ 
\p  
\v 5 Ọnwan wụ ozi hụ ẹnyi nụ ọnụ a, hụn ẹnyi rị nwan e zi ụnụ: nị Osolobuẹ wụ ukpẹ, ọ nwọnni ishi rị imẹ ẹ—kaka.  
\v 6 Omẹni ẹnyi sị nị ẹnyi lẹ ịya rị e mẹkọ bụ ẹnyi a tọ imẹ ishi e bi, ya wụ nị ẹnyi rị a tụ ntụ, ẹnyi a rị e gi ezioku e bi.  
\v 7 Kanị, omẹni ẹnyi hụ e bi imẹ ukpẹ, nọkẹ kẹ ya nwẹn dọn rị imẹ ukpẹ, ya wụ nị ẹnyi lẹ ịya hụ e mẹkọ nke-esi, ẹdeke Nwa a wụ Jizọsị k'a rị a chanchanfụ ẹnyi njọ ọwụlẹ ẹnyi mẹ. 
\p  
\v 8 Omẹni ẹnyi sị nị ẹnyi ara mẹ njọ, ẹnyi rị e dufie enwẹn ẹnyi, ezioku arị imẹ ẹnyi.  
\v 9 Kanị, omẹni ẹnyi e kupụha njọ ẹnyi, onyẹ wẹ gi e dọn-ẹnya lẹ onyẹ-ezioku k'ọ wụ, o k'a gbagharị ẹnyi njọ ẹnyi, chanchanpụchanrịn ẹnyi ihiẹn ile rịlẹni mma. 
\p  
\v 10 Omẹni ẹnyi sị nị ẹnyi e mẹni njọ, ya wụ nị ẹnyi rị a sị nị Osolobuẹ wụ onyẹ-ntụ, ya wụ nị oku ẹ a rị imẹ ẹnyi. 
\c 2  
\cl Isi Nke Ẹbụọ 
\s1 Kraịstị Ya E Dọnmẹ Ẹnyi Ụchan 
\p  
\v 1 Ụmụẹka m, m rị e de ni ụnụ ihiẹn ndịnị amamgbe ụnụ gha e mẹ njọ. Kanị, omẹni ịhịan mẹ njọ, ẹnyi nwọn onyẹ a rịọdọn ni ẹnyi ebe Chuku-Nẹdi rị—onyẹ hụ wụ Jesu Kristi, onyẹ hụ rị ọchan.  
\v 2 Ya lẹ enwẹn ẹ wụ ẹjan hụn wẹ gi wepụ njọ ẹnyi lẹ iwe-lẹ-ọnụma-Osolobuẹ; ẹlẹ njọ ẹnyi sụọ, kanị, kẹ njọ ụwa ile. 
\p  
\v 3 Ihiẹn o k'e gi nwan we ẹnyi ẹnya nị ẹnyi a marịnghọ Osolobuẹ nke-esi wụ nị ẹnyi e mẹsọnmẹ ihiẹn ọ sị ẹnyi mẹ.  
\v 4 Onyẹ ọwụlẹ hụn sị nị ọ maringhọ a bụ a ra mẹ ihiẹn ọ sị ẹnyi mẹ, onyẹ hụ wụ onyẹ-ntụ, ezioku arị imẹ onyẹ nọ ẹnịna.  
\v 5 Kanị, nke onyẹ ọwụlẹ hụn a gbaye oku Osolobuẹ, ezioku-ezioku, onyẹ ahụn nwẹ ihiẹn-ọsụsụọ zu oke jẹnni Osolobuẹ. 
\p Ihiẹn ẹnyi gi a marịn nị ẹnyi rị imẹ ẹ wụ ọnwan:  
\v 6 onyẹ sị n'ọ rị imẹ Osolobuẹ ya bi obibi kẹ Jizọs' Kraịstị dọn bi. 
\s1 Iwu Ọhụn 
\p  
\v 7 Ndị rị m obi, arị m e deni ụnụ iwu ọhụn; kama, iwu ohu ahụn wẹ ye ụnụ isi-ibuzọ rọ. Ozi hụ ụnụ nụ, ịya wụ iwu mbụ ahụn m rị e ku oku ẹ.  
\v 8 Kanị ọ wụzịkwọ iwu ọhụn. Iwu ọhụnnị wụ ezioku, ọ hụ imẹ Kraịstị, ọ hụzịkwọ imẹ ọnụ—makẹni ishi hụ a ghafe, ezigbo ukpẹ e nwunmẹgụọ. 
\p  
\v 9 Onyẹ ọwụlẹ sị n'ọ rị imẹ ukpẹ bụ ize onyẹ Itu-Kraịstị ibe ẹ hụ e ze ẹ, echẹn kẹ onyẹ hụ rịkwọ imẹ ishi.  
\v 10 Onyẹ ọwụlẹ nwẹ ihiẹn-ọsụsụọ onyẹ Itu-Kraịstị ibe ẹ bi imẹ ukpẹ—o nwọnni ihiẹn rị imẹ ẹ hụn e mẹ ịhịan a kpọgburu.  
\v 11 Kanị, onyẹ hụn e ze ize onyẹ Itu-Kraịstị ibe ẹ rị imẹ ishi; ọ ghakọ imẹ ishi, ọ marịn ebe o jẹnkọ—makẹni ishi hụ a gbakingụọ a ẹnya. 
\q1  
\v 12 Ụmụẹka, 
\q2 m rị e de ni ọnụ nị m gi gwa ọnụ 
\q2 nị Osolobuẹ e gigụọ ifiri ẹfan Jizọsị 
\q1 gbagharị ụnụ njọ. 
\q1  
\v 13 Ndị nẹdi, 
\q1 m rị e deni ụnụ nị m gi ẹ gwa ụnụ 
\q2 nị ụnụ a marịngụọ onyẹ hụ rịnị gha mbidọn lala. 
\q1 Ndị-ikoro, 
\q1 m rị e de ni ụnụ nị m gi ẹ gwa ụnụ 
\q2 nị ụnụ e mẹrigụọ Eje-onyẹ hụ. 
\q1  
\v 14 Ụmụẹka, 
\q1 m de ni ụnụ ihiẹnni nị m gi ẹ gwa ụnụ 
\q2 nị ụnụ a marịngụọ Chuku-Nẹdi ẹnyi. 
\q1 Ndị nẹdi, 
\q1 m de ni ụnụ ihiẹnni nị m gi ẹ gwa ụnụ 
\q2 nị ụnụ a marịngụọ onyẹ hụ rị gha mbidọn lala. 
\q1 Ndị-ikoro, 
\q1 m de ni ụnụ ihiẹnni nị m gi ẹ gwa ụnụ 
\q2 nị ụnụ e zeghọ, 
\q2 nị oku Osolobuẹ rị imẹ ụnụ 
\q2 lẹ ni ụnụ e mẹrigụọ Eje-onyẹ hụ. 
\s1 Ihiẹn-ụwa Y'a Sụọkwọlẹ Ụnụ! 
\p  
\v 15 Enwẹkwọlẹ ni ihiẹn-ọsụsụọ ụwa mọbụ ndị rị imẹ ụwa, makẹni ihiẹn Chuku-Nẹdi-ẹnyi ara sụọ onyẹ ihiẹn ụwa a sụọ.  
\v 16 Makẹni, ihiẹn ile rị imẹ ụwa, kẹ eje-ihiẹn ndị a gụnsọnmẹ ẹhụ kẹ ihiẹn-ọnịna-ẹnya kẹ nhọnrọn ịhịan a họnrọn makẹni o nwẹghọ ihiẹn-ụwa, aghanị ẹka Nẹdi-ẹnyi bịa—ụwa kẹ wẹ ile gha a bịa.  
\v 17 Ụwa lẹ ihiẹn-ọlịla-ẹnya ile rịn'a ghafekọ aghafekọ; kanị, onyẹ ọwụlẹ hụn e mẹ uche Osolobuẹ k'a tọ jẹnrin ejẹn. 
\s1 Eṅẹnrẹn Kraịstị Ahụn W'a Kpọ Anti-Kraịstị 
\p  
\v 18 Ụmụ m, ogẹnni wụ ogẹn ịkpazụụn! Kẹ ọnụ dọn nụ nị eṅẹnrẹn Kraịstị ahụn w'a kpọ anti-Kraịstị lala, ẹrịra k'ọ rị nwan nị ndị bu ọda wụ ndị-iṅẹnrẹn Kraịstị a pụhagụọ. Ịya kẹ ẹnyi gi a marịn nị ogẹnni wụ ogẹn ịkpazụụn.  
\v 19 Imẹ igunrun ẹnyi kẹ ndịnị gha pụ nke-esi, kanị, ẹlẹ wẹ ndị nke ẹnyi. Makẹni, omẹni wẹ te wụ ndị nke ẹnyi, nkẹ e sọn wẹ ẹnyi nọdị. Kanị, ọpụpụ wẹ gha imẹ igunrun ẹnyi pụ k'o gi wechanrịn ẹnya nị ẹlẹ wẹ ndị nke ẹnyi. 
\p  
\v 20 Kanị, ọnụ ile marịn ezioku makẹni Onyẹ-hụ-rị-nsọ e hukpugụọ ọnụ udẹn imẹ-mmọn gi tumẹ ụnụ ụmụ a.  
\v 21 Ẹlẹni ụnụ amarịn ezioku haịn m gi e deni ụnụ, kanị, makẹni ụnụ a marịngụọ a—ụnụ a marịnghọ n'o nwọnni ntụ a gha imẹ ezioku a fụha.  
\v 22 Onyẹ wụ nwan onyẹ ntụ emẹni ẹlẹ onyẹ kwerilẹni nị Jizọsị wụ Kraịstị, Onyẹ-nzụọpụha hụ Osolobuẹ tumẹ. Onyẹ nọ ẹrịra wụ eṅẹnrẹn Kraịstị hụ—hụn w'a kpọ Anti-Kraịstị; a ra kwerini Chuku-Nẹdi lẹ Nwa a.  
\v 23 Ẹghẹẹ! Makẹni, onyẹ ọwụlẹ jụ Nwa a ekwerini ni Chuku-Nẹdi; onyẹ ọwụlẹ kwerini Nwa a nwọnzikwọ Chuku-Nẹdi. 
\p  
\v 24 Nị nị ozi hụ ụnụ nụ isi-ibuzọ rịsọnmẹ imẹ ndụn ụnụ. Omẹni ihiẹn ụnụ nụ isi-ibuzọ hụ a rịsọnmẹ imẹ ndụn ụnụ, ụnụ k'a rịsọnmẹ imẹ Nwa Chuku lẹ imẹ Chuku-Nẹdi.  
\v 25 Ihiẹn o kwe ẹnyi nkwa n'o k'e ye ẹnyi wụ ndụn itẹbitẹ. 
\p  
\v 26 Ifiri ndị rị a chọ nị wẹ dufie ụnụ kẹ m gi rị e deni ụnụ ihiẹn ndịnị.  
\v 27 Kanị, o mẹ nke ụnụ, udẹn imẹ-mmọn hụ o hukpu ụnụ, hụn o gi tumẹ ụnụ ụmụ a hụ imẹ ndụn ụnụ a kuzi ụnụ ihiẹn ile. Ya wụ, o nwọnzini nwan mkpa ọ rị nị onyẹ ọwụlẹ k'a kuzi ụnụ. Ihiẹn udẹn ahụn o gi tumẹ ụnụ a kuzi ụnụ wụ ezioku—ntụ arị a. Nọkẹ kẹ ọ dọn kuzi ọnụ—nọdị nị imẹ Kraịstị.  
\v 28 Ẹghẹẹ ụmụ m, nọdị nị imẹ ẹ, kẹni obi ru ẹnyi ile alị ogẹn o k'e gi pụha; amamgbe ẹnyi e gi ifẹnrẹn warị Ụhụọhịn hụ. 
\s1 Kẹ W'a Dọn Marịn Ụmụ Osolobuẹ 
\p  
\v 29 Omẹni ọnụ a marịnghọ n'ọ rị ọchan, ọnụ k'e gi ẹ marịn nị ya mụ onyẹ ọwụlẹ hụn e bi obibi onyẹ rị-ọchan. 
\c 3  
\cl Isi Nke Ẹtọ 
\p  
\v 1 Lee ni nwan kẹ Chuku-Nẹdi nwẹhan ihiẹn-ọsụsụọ ẹnyi—nke wụ nị w'a kpọ ẹnyi ụmụ Osolobuẹ! Ezioku-ezioku, ịya kẹ ẹnyi wụ! Ihiẹn haịn ụwa gilẹni marịn ẹnyi wụ nị ụwa amarịn n'a.  
\v 2 Ndị rị m obi, ẹnyi wụ nwan ụmụ Osolobuẹ. Kanị, ihiẹn ẹnyi jẹnkọ d'a wụrụ e ke pụha ifọn—bụ ẹnyi a marịnghọ nị ogẹn o k'e gi bịa, ẹnyi k'a nọ kẹ ịya, makẹni ẹnyi k'a hụnchanrịn a k'ọ nọ.  
\v 3 Ndị ile nwọn olile-ẹnyanị imẹ wẹ e dọnmẹ enwẹn wẹ ọchan nọkẹ kẹ ya lẹ enwẹn ẹ dọn rị ọchan. 
\p  
\v 4 Onyẹ ọwụlẹ hụn e mẹ njọ rị a dan iwu makẹni imẹ-njọ wụ ịdan-iwu.  
\v 5 Ụnụ a marịnghọ nị Kraịstị bịa d'e wefụ njọ, ụnụ a marịnghọzị nị o nwọnni njọ rị imẹ ẹ.  
\v 6 O nwọnni onyẹ rị imẹ ẹ hụn e mẹ njọ; onyẹ ọwụlẹ hụn e mẹ njọ e ke hụntu ẹ mọbụ marịn a. 
\p  
\v 7 Ụmụẹka, anịlẹ ni onyẹ ọwụlẹ dufie ụnụ! Onyẹ hụn e bi obibi onyẹ rị-ọchan rị ọchan kẹ Kraịstị dọn rị ọchan.  
\v 8 Onyẹ ọwụlẹ e mẹ njọ wụ nke Ekwensụ—makẹni Ekwensụ gha alị mẹla njọ. Ịya haịn Nwa Osolobuẹ gi bịa—kẹni o tikpọ ọrụn Ekwensụ. 
\p  
\v 9 O nwọnni onyẹ hụn Osolobuẹ mụ hụn e mẹ njọ. Makẹni, mkpụrụ Osolobuẹ rị imẹ onyẹ ahụn. Ọ s'ẹka mẹ njọ, makẹni Osolobuẹ mụ a.  
\v 10 Ọnwan kẹ wẹ gi a marịn ndị wụ ụmụ Osolobuẹ lẹ ndị wụ ụmụ Ekwensụ: onyẹ ọwụlẹ ghalẹni e mẹ ihiẹn rị mma mọbụ hụn ihiẹn ndị Itu-Kraịstị ibe ẹ ghalẹni a sụọ ẹlẹ nwa Osolobuẹ. 
\s1 E Nwẹ Ni Ihiẹn-ọsụsụọ Ibe Ụnụ 
\p  
\v 11 Makẹni ozi hụn ụnụ nụ isi-ibuzọ wụ nị ẹnyi k'a gha e nwẹ ihiẹn-ọsụsụọ ibe ẹnyi.  
\v 12 Ẹnyi anọkọkwọ nị kẹ Keni—ọ wụ nke Eje-onyẹ hụ, o gbupụ nwẹnẹ ẹ. Kị haịn Keni gi gbu ẹ? Makẹni Keni lẹ enwẹn ẹ mẹ eje-ihiẹn kanị nwẹnẹ ẹ mẹ ihiẹn rị mma. 
\p  
\v 13 Umunẹ m, y'a tụlẹ ụnụ ẹnya nị ize ụnụ rị e ze ụwa.  
\v 14 Ihiẹn ẹnyi gi marịn nị ẹnyi a ghagụọ ọnwụn fụha, banye ndụn, wụ nị ẹnyi nwẹ ihiẹn-ọsụsụọ ibe ẹnyi. Onyẹ nwẹlẹni ihiẹn-ọsụsụọ ibe ẹ a nwụnhụngụọ. 
\p  
\v 15 Onyẹ ọwụlẹ ize nwẹnẹ ẹ e ze wụ izighẹ—bụ ụnụ a marịnghọ n'o nwọnni izighẹ ndụn itẹbitẹ rị imẹ ẹ.  
\v 16 Ihiẹn ẹnyi gi a marịn ihiẹn-ọsụsụọ nke-esi wụ ọnwan: nị Kraịstị gi ifiri ẹnyi we ndụn a ye. O furu nwan nị ẹnyi gizikwọ ifiri ibe ẹnyi we ndụn ẹnyi ye.  
\v 17 Nanị kẹ ihiẹn-ọsụsụọ Osolobuẹ gi rị imẹ ịhịan, omẹni ịhịan e nwọnghọ ihiẹn ụwanị, kanị ọ hụn nwẹnẹ ẹ ihiẹn rị a kọ, ọ jụ n'o yekọn'a ẹka?  
\v 18 Ụmụẹka, nị ẹnyi e nwọn ni ihiẹn-ọsụsụọ nke-esi—ẹlẹkwọ hụn wẹ gi ọnụ sụọ e ku, kanị, hụn wẹ gi ẹka e mẹ. 
\p  
\v 19 Ọhụn kẹ ẹnyi e gi marịn nị ẹnyi wụ nke ezioku, ịya kẹ ẹnyi gi e mẹ obi e ru ẹnyi anị ebe Osolobuẹ rị—  
\v 20 omẹni obi e gbumẹ ẹnyi mgbu. Makẹni, Osolobuẹ ka obi ẹnyi, ọ marịnghọzịkwọ ihiẹn ile. 
\p  
\v 21 Ndị rị m obi, omẹni ịhọrị ẹnyi hụ a ghọnị ẹnyi, obi e ruchanrịn ẹnyi alị ebe Osolobuẹ rị,  
\v 22 ẹnyi e nwẹhẹnzịkwọ ihiẹn ọwụlẹ ẹnyi rịọ a—makẹni ẹnyi hụ e dọnmẹ iwu ẹ, e mẹ ihiẹn a sụọ a ụsụọ ẹfọ. 
\p  
\v 23 Iwu ẹ wụ hụnnị: nị ẹnyi k'e kweri ni ẹfan Nwa a wụ Jesu Kristi lẹ ni ẹnyi k'e nwẹ ihiẹn-ọsụsụọ ibe ẹnyi—nọkẹ k'o dọn gwa ẹnyi.  
\v 24 Kẹ wẹ han hụn e dọnmẹ iwu ẹ rị imẹ ẹ, ịya nwẹn rịzịkwọ imẹ ndụn wẹ. Ihiẹn ẹnyi gi a marịn n'ọ hụ imẹ ẹnyi wụ ọnwan: n'o yeọlẹ ẹnyi Mmọn-nsọ. 
\c 4  
\cl Isi Nke Ẹnọ 
\s1 Mmọn Osolobuẹ Lẹ Mmọn Eṅẹnrẹn-Kraịstị 
\p  
\v 1 Ndị rị m obi, ẹlẹ mmọn ile gi ịhịan ku kẹ ụnụ k'e kweyeni, ka e lele ni wẹ, kẹni ụnụ marịn kẹ mmọn ndị hụ gha ẹka Osolobuẹ bịa nke-esi. Makẹni, ndị-amụma-ntụ bu ọda a pụhagụọ imẹ ụwa.  
\v 2 Kẹ ọnụ k'a dọn marịn nị Mmọn Osolobuẹ rọ wụ ọnwan: mmọn ọwụlẹ gi ẹ dọn nị Jizọsị hụn wụ Kraịstị, Onyẹ ahụn Osolobuẹ tumẹ, hẹnrin ịhịan bịa, e ku ẹ—mmọn hụ gha ẹka Osolobuẹ bịa,  
\v 3 kanị, mmọn ọwụlẹ hụn kwerilẹni nị Jizọsị hụn wụ Kraịstị, Onyẹ hụ Osolobuẹ tumẹ, hẹnrin ịhịan bịa, mmọn ahụn aghanị ẹka Osolobuẹ bịa. Ọhụn wụ mmọn Eṅẹnrẹn-Kraịstị, ya wụ, mmọn Anti-Kraịstị—hụn ọnụ nụ n'ọ lala alala; ọ rịgụọlẹ nwan imẹ ụwa. 
\p  
\v 4 Ụmụẹka, ụnụ wụ nke Osolobuẹ—ọnụ e mẹrigụọ wẹ, makẹni onyẹ hụ rị imẹ ụnụ ka onyẹ hụ rị imẹ ụwa.  
\v 5 Ndị-amụma-ntụ ndịnị wụ nke ụwa—ya wụ, ihiẹn w'e ku wụ nke ụwa, ụwa e gọn wẹ ntịn.  
\v 6 Ẹnyi nwẹn wụ nke Osolobuẹ. Onyẹ ọwụlẹ hụn marịn Osolobuẹ e gọn ẹnyi ntịn. Onyẹ ọwụlẹ hụn wụlẹni nke Osolobuẹ ara gọn ẹnyi ntịn. Ọnwan kẹ ẹnyi gi a marịn mmọn hụn wụ nke ezioku lẹ mmọn hụn wụ nke ndufie. 
\s1 Imẹ Osolobuẹ Kẹ Ihiẹn-ọsụsụọ Rị 
\p  
\v 7 Ndị rị m obi, nị ẹnyi e nwẹ ni ihiẹn-ọsụsụọ ibe ẹnyi, makẹni ihiẹn-ọsụsụọ gha ẹka Osolobuẹ a bịa. Onyẹ ọwụlẹ hụn nwọn ihiẹn-ọsụsụọ, Osolobuẹ mụ a, onyẹ hụ marịn Osolobuẹ.  
\v 8 Onyẹ hụn nwọnlẹni ihiẹn-ọsụsụọ amarịn Osolobuẹ, makẹni Osolobuẹ wụ ihiẹn-ọsụsụọ.  
\v 9 Osolobuẹ a ghọsịgụọ ihiẹn-ọsụsụọ o nwẹ ebe ẹnyi rị; ẹnịna k'o dọn mẹ ẹ: o zihẹ akpụ Nwa a ohu imẹ ụwa, kẹni ẹnyi hụn ụzọ rị ndụn ghahan'a.  
\v 10 Ọnwan wụ ihiẹn-ọsụsụọ: ẹlẹni ẹnyi nwẹ ihiẹn-ọsụsụọ Osolobuẹ, kama, nị Osolobuẹ nwẹ ihiẹn-ọsụsụọ ẹnyi, gi ẹ zihẹ Nwa a n'ọ wụrụ ẹjan wẹ gi wepụ njọ ẹnyi lẹ iwe-lẹ-ọnụma Osolobuẹ hụn njọ e buhẹ. 
\p  
\v 11 Ndị rị m obi, ebe o mẹ eziẹ nị Osolobuẹ nwẹhan ihiẹn-ọsụsụọ ẹnyi ẹnịna, o furu nị ẹnyi nwẹn nwẹzịkwọ ihiẹn-ọsụsụọ ibe ẹnyi.  
\v 12 O nwọntuni onyẹ gi ẹnya a hụn Osolobuẹ—kanị, omẹni ẹnyi e nwẹghọ ihiẹn-ọsụsụọ ibe ẹnyi, ya wụ nị Osolobuẹ bi imẹ ẹnyi; ya wụzị nị ihiẹn-ọsụsụọ a zu oke imẹ ẹnyi. 
\p  
\v 13 Ihiẹn ẹnyi gi marịn nị ẹnyi rị imẹ ẹ lẹ ni ya nwẹn rị imẹ ẹnyi wụ n'o yegụọ ẹnyi Mmọn-nsọ a. 
\p  
\v 14 Ẹnyi a hụngụọ a, ku ẹ, nị Chuku-Nẹdi e zihẹgụọ Nwa a d'a wụ Onyẹ-nzụọpụha ụwa.  
\v 15 Osolobuẹ bi imẹ ndị ile gi ẹ dọn, e ku ẹ, nị Jesu wụ Nwa Osolobuẹ—uwẹ lẹ enwẹn wẹ bi imẹ Osolobuẹ.  
\v 16 Ẹnyi a marịnghọ nwan, ẹnyi e giọlẹ ẹ nwan dọn, nị Osolobuẹ nwẹ ihiẹn-ọsụsụọ ẹnyi. 
\p Osolobuẹ wụ ihiẹn-ọsụsụọ. Onyẹ hụn gi ihiẹn-ọsụsụọ e bi rị imẹ Osolobuẹ, Osolobuẹ lẹ enwẹn ẹ rị imẹ onyẹ hụ.  
\v 17 Ẹrịra kẹ ihiẹn-ọsụsụọ e gi zu oke imẹ ndụn ẹnyi, kẹni obi ru ẹnyi alị Ụhụọhịn Okinkin-ikpe—makẹni kẹ Jesu nọ, ẹrịra kẹ ẹnyi nọ imẹ ụwanị.  
\v 18 Egun ara tụ onyẹ gi ihiẹn-ọsụsụọ e bi; ihiẹn-ọsụsụọ zu oke a chụpụ egun. Onyẹ rị a tụ egun rị a tụ egun afụnfụn o jẹnkọ d'a ta—ihiẹn-ọsụsụọ onyẹ rị a tụ egun ezuni oke. 
\p  
\v 19 Ihiẹn-ọsụsụọ o bu ụzọ nwọn jẹnni ẹnyi haịn ẹnyi gi a saẹka e nwọn ihiẹn-ọsụsụọ.  
\v 20 Omẹni ịhịan sị, “M nwẹ ihiẹn-ọsụsụọ jẹnni Osolobuẹ,” bụ ize nwẹnẹ ẹ rị e ze ẹ, onyẹ-ntụ k'ọ wụ. Makẹni, omẹni ịhịan e nwọnni ihiẹn-ọsụsụọ nwẹnẹ ẹ—nwẹnẹ ọ rị e legha, ọ sakọ ẹka nwẹ ihiẹn-ọsụsụọ Osolobuẹ—Osolobuẹ o leghatulẹni.  
\v 21 Iwu o ye ẹnyi wụ ọnwan: nị, onyẹ nwẹ ihiẹn-ọsụsụọ Osolobuẹ k'e nwẹzịkwọ ihiẹn-ọsụsụọ nwẹnẹ ẹ. 
\c 5  
\cl Isi Nke Isẹn 
\s1 Kẹ Ẹnyi Dọn E Mẹri Ụwa 
\p  
\v 1 Onyẹ ọwụlẹ hụn gi ẹ dọn nị Jesu wụ Kraịstị, Onyẹ hụ Osolobuẹ tumẹ, onyẹ hụ wụ nwa Osolobuẹ; onyẹ ọwụlẹ nwẹ ihiẹn-ọsụsụọ onyẹ mụ ịhịan, nwẹzịkwọ ihiẹn-ọsụsụọ nwa a.  
\v 2 Ihiẹn ẹnyi gi a marịn nị ẹnyi nwẹ ihiẹn-ọsụsụọ ụmụ Osolobuẹ wụ nị ẹnyi nwẹ ihiẹn-ọsụsụọ Osolobuẹ, e mẹsọnmẹ ihiẹn ndị ọ sị ẹnyi e mẹ.  
\v 3 Kẹ wẹ dọn e nwẹ Osolobuẹ ihiẹn-ọsụsụọ wụ: imẹsọnmẹ ihiẹn ọ sị ẹnyi mẹ—bụ ihiẹn ọ sị ẹnyi mẹ ẹlẹ ibu,  
\v 4 makẹni onyẹ ọwụlẹ Osolobuẹ mụ e mẹri ụwa. Ikẹn hụn ẹnyi gi e mẹri ụwa wụ okukwe ẹnyi nwọn.  
\v 5 Onyẹ a sa nwan ẹka e mẹri ụwa? Onyẹ hụn gi ẹ dọn nị Jesu wụ Nwa Osolobuẹ rọ. 
\s1 Ihiẹn Ndị Hụn A Ghọsị Nị Jesu Wụ Nwa Osolobuẹ 
\p  
\v 6 Jizọs' Kraịstị-nị wụ onyẹ hụ hụn bịa ghahanị mirin lẹ ẹdeke. Ẹlẹ ghahanị mirin sụọ, kanị ghahanị mirin lẹ ẹdeke. Mmọn-nsọ lẹ enwẹn ẹ wụ hụn a shịa ẹri, makẹni Mmọn-nsọ wụ Onyẹ ezioku.  
\v 7 Ya wụ nị wẹ rị ẹtọ hụn rị a shịa ẹri [elu-igwee: wẹ wụ Chuku-Nẹdi lẹ Oku hụ lẹ Mmọn-nsọ; wẹ rịzịkwọ ẹtọ hụn a shịa ẹri elu-ụwa:] wẹ wụ  
\v 8 Mmọn-nsọ lẹ mirin ahụn lẹ ẹdeke ahụn. Wẹ ẹtọ kuye ọnụ ohu.  
\v 9 Omẹni ẹnyi a nabanhan ẹri ịhịan shịa, hụn Osolobuẹ shịa kadẹ ezioku a wụ, bụ Osolobuẹ a shịagụọnị Nwa a ẹri.  
\v 10 Ya wụ, onyẹ ọwụlẹ kwerini Nwa Osolobuẹ nwọn ẹrini imẹ obi ẹ; kanị onyẹ hụn kwerilẹni a kpọgụọ Osolobuẹ onyẹ-ntụ, makẹni o gini ẹri Osolobuẹ shịa nị Nwa a dọn.  
\v 11 Ọnwan wụ ẹri hụ: Osolobuẹ e yegụọ ẹnyi ndụn itẹbitẹ—imẹ Nwa a kẹ ndụn itẹbitẹ hụ rị.  
\v 12 Onyẹ ọwụlẹ nwọn Nwa a hụ nwọn ndụn, kanị onyẹ hụn nwọnlẹni Nwa Osolobuẹ enwọn ndụn. 
\s1 Ndụn Itẹbitẹ 
\p  
\v 13 M rị e deni ụnụ ihiẹn ndịnị, ụnụ ndị hụn kwerini ẹfan Nwa Osolobuẹ, kẹni ọnụ marịn nị ọnụ e nwọnghọ ndụn itẹbitẹ. 
\p  
\v 14 Ihiẹn obi gi e ru ẹnyi alị ebe Osolobuẹ rị wụ ọnwan: nị omẹni ẹnyi rịọ a ihiẹn ọwụlẹ k'o dọn rị a obi, ọ nụ ekpere ẹnyi.  
\v 15 O mẹ nwan nị ẹnyi a marịnghọ nị ihiẹn ọwụlẹ ẹnyi rịọl'a, nị ọ nụ ekpere ẹnyi anụ, ya wụ ẹnyi a marịnghọzị nị ẹnyi e nwẹhẹngụọ ihiẹn ẹnyi rịọ a. 
\p  
\v 16 Onyẹ hụn nwẹnẹ ẹ k'ọ rị e mẹ njọ—ụdị njọ hụn ghalẹni ẹ buhẹ ọnwụn, ya mẹ ekpere, Chuku k'e ye nwẹnẹ ẹ hụ ndụn—ọnwan wụ nke ndị hụn mẹ ụdị njọ hụn ghalẹni e buhẹ ọnwụn. Njọ hụn e buhẹ ọnwụn rị arị: asịnị m ụnụ mẹmẹ ekpere banyeni ọhụn.  
\v 17 Eje-omumẹ ile wụ njọ, kanị o nwọn njọ hụn ghalẹni e buhẹ ọnwụn. 
\p  
\v 18 Ẹnyi a marịnghọ nị onyẹ ọwụlẹ Osolobuẹ mụ ara mẹ njọ, makẹni Jesu, Onyẹ hụ Osolobuẹ mụ, e che ẹ nche—Eje-onyẹ hụ ara mẹtụ a ẹka. 
\p  
\v 19 Ẹnyi a marịnghọ nị ẹnyi wụ nke Osolobuẹ; ẹnyi a marịnghọzịkwọ nị ụwa ile rị okpuru Eje-onyẹ hụ. 
\p  
\v 20 Ẹnyi a marịnghọ nị Nwa Osolobuẹ a bịagụọ, n'o yegụọ ẹnyi nghọta hụn ẹnyi e gi marịn onyẹ ahụn wụ onyẹ-ezioku. Ẹnyi rị nwan imẹ onyẹ ahụn wụ onyẹ-ezioku lẹ Nwa a wụ Jesu Kristi. 
\p Ịya wụ Osolobuẹ nke-esi lẹ ndụn-itẹbitẹ. 
\p  
\v 21 Ụmụ m, gba nị nị ife mmọn mọbụ ife ihiẹn ọzọ ọwụlẹ ọsọ!