\c 13
\s1 The Division of the Land Among the Tribes of Israel  
\p
\v 1 \w When|strong="H3117"\w* \w Joshua|strong="H3091"\w* \w was|strong="H3068"\w* \w old|strong="H2204"\w*, \w well|strong="H3966"\w* advanced \w in|strong="H3068"\w* \w years|strong="H3117"\w*, \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* said \w to|strong="H3068"\w* \w him|strong="H7604"\w*, “\w You|strong="H3117"\w* \w are|strong="H3117"\w* \w old|strong="H2204"\w*, \w well|strong="H3966"\w* advanced \w in|strong="H3068"\w* \w years|strong="H3117"\w*, \w and|strong="H3068"\w* \w yet|strong="H3068"\w* \w much|strong="H7235"\w* land still \w remains|strong="H7604"\w* \w to|strong="H3068"\w* \w be|strong="H3068"\w* occupied.  
