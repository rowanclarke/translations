\p
\v 5  \w So|strong="H3947"\w* \w King|strong="H4428"\w* \w David|strong="H1732"\w* \w had|strong="H1732"\w* \w him|strong="H7971"\w* \w brought|strong="H3947"\w* \w from|strong="H1121"\w* \w the|strong="H3947"\w* \w house|strong="H1004"\w* \w of|strong="H1121"\w* \w Makir|strong="H4353"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Ammiel|strong="H5988"\w* \w in|strong="H1004"\w* Lo Debar.  
