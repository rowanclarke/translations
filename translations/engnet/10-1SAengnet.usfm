\v 9  \w But|strong="H7200"\w* \w Doeg|strong="H1673"\w* \w the|strong="H5921"\w* Edomite, \w who|strong="H1931"\w* \w had|strong="H7586"\w* \w stationed|strong="H5324"\w* \w himself|strong="H1931"\w* \w with|strong="H5921"\w* \w the|strong="H5921"\w* \w servants|strong="H5650"\w* \w of|strong="H1121"\w* \w Saul|strong="H7586"\w*, \w replied|strong="H6030"\w*, “\w I|strong="H5921"\w* \w saw|strong="H7200"\w* \w this|strong="H1931"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jesse|strong="H3448"\w* \w come|strong="H7586"\w* \w to|strong="H5921"\w* Ahimelech \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ahitub \w at|strong="H5921"\w* \w Nob|strong="H5011"\w*.  
