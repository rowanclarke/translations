\id MIC
\h عَننَبِ مِكَ
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ مِكَ بّ
\toc2 عَننَبِ مِكَ
\toc3 مِك
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ مِكَ بّ
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip عَننَبِ مِكَ شَ كِتَابُي نْندِ هَفِفّ مَسٍنمَ تٌ مِشِيٍ بّ. عَلَ مُ وَ مَ قٍ حَاشِ شْن، عَ يُنُبِ بِرِن شْنمَ عَ بْحّ بِرِن نَ. نَ كُي عِبُنَدَ مَ نَ كٍلِ عَلَ شَ كِرَ شْن مَ، عَلَ شَ تِنشِنيِ عَ نِيَمَ نّ عَ شَ نَ مِشِيٍ حَشَنكَتَ عٍ شَ قٍ رَبَشِ مَ. عٍ نَ قِندِ عَ شَ حَمَ رَ، عٍ نَ قِندِ حَمَ رَ نَشَن مُ عَ كٌلٌن، عٍ بِرِن هَلَكِمَ نّ نَ يُنُبِيٍ شَ قٍ رَ.
\ip نَ قَهَامُقٍ مُ شْرْشْ عَدَ مَدِيٍ بّ، بَرِ مَ عٍ قَن نَ قٍ حَاشِ ندٍ تٌ، عٍ بْحّ تٍمَ نّ هَن. عٍ نَ عَ تٌ عٍ شَ مَنفّيٍ نَ سٍتَرٍيٍ تْورْقٍ عَلَكٌ ندٍ شَ سَ عٍ يّتّ شَ نَاقُلِ شْن مَ، عٍ شْنْمَ نّ. نَ شْنّ مَنِيَ عَلَ شَ شْنّ تِنشِنشِ رَ. قٍ نَشَن مُ رَقَن عَلَ مَ، قٍ قَنيِ مُ عَ رَ. عَ مِشِ تْورْ مَ نّ!
\ip كْنْ عَلَ شَ شْنّ قَتَنشِ عَ شَ بْحّ قَنيِ نَن نَ. عَ تٌ وَ عِبُنَدَ مَ شَ قٍ شَ سْونّيَ، عَ نَ سٍنتَنّ شَ كَسَرّ وَلِ تٌ، عَ شْنْمَ نّ، عَ مَن فٍرٍ تِ نَ شِلِ مَ. يُنُبِ رَبَ حَشَنكَتَقٍ كٍلِشِ نَ نَن مَ. كْنْ نَ بْحّ قَنيِ مَن عَ نِيَمَ نّ عَلَتَلَ شَ كَتّ بِرِن نَبَ عَلَكٌ عَ شَ عِبُنَدَ مَ رَفبِلٍن عَ شَ كِرَ قَنيِ مَ. عَ مُ وَ مَ عٍ حَشَنكَتَقٍ تُن. عَ وَ مَ نّ عٍ شَ فبِلٍن عَ مَ، عٍ شَ كِسِ سْتْ كِرَ قَنيِ شْن مَ.
\ip عَننَبِ مِكَ نُ عَلَ شَ مَسٍنيِ تِقٍ عِسِرَيِلَ نُن عٍ يَشُييٍ بّ، كْنْ عَ تِدٍ فبٌ تٌ مِشِيٍ قَن بّ. وٌن قَن شَ قَهَامُي سْتْ يِ مَسٍنيِ كُي؛ عَ يُنُبِ مُ رَقَن عَلَ مَ، عَ قَمَ يُنُبِتْييٍ حَشَنكَتَدٍ، عَ نُن عَ وَ مَ مِشِ رَكِسِقٍ عٍ شَ يُنُبِيٍ مَ عَلَكٌ عٍ شَ حّرّ عَ وَشْنقٍ قَنيِ كُي. عَلَ شَ وٌن مَلِ نَ كِسِ تِنشِنشِ سْتْقٍ رَ. عَمِنَ.
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ مِكَ بّ
\c 1
\s1 عَلَ شَ شْنّ عِسِرَيِلَ نُن يُدَيَ بّ
\p 
\v 1 عَلَتَلَ شَ مَسٍنيِ نَن يَ عَ نَشَن تِ عَننَبِ مِكَ مٌرٍ سٍتِكَ بّ سَمَرِ نُن دَرِ سَلَمُ شَ قٍ رَ. عَ عَ تِ عَ بّ يُدَيَ مَنفّ يٌتَمِ، عَشَسِ، نُن شٍسٍكِيَ شَ وَشَتِ نّ.
\q1 
\v 2 دُنِحَ سِ بِرِن، وٌ شَ وٌ تُلِ مَتِ ﭑ نَ.
\q1 عِبُنَدَ مَ بِرِن نَشٍيٍ نَ يِ بّندّ قُحِ قَرِ،
\q1 وٌ شَ ﭑ مَ مَسٍنيِ رَ مّ،
\q1 وٌن مَرِفِ عَلَتَلَ قَمَ وٌ كَلَمُدٍ نَشَن نَ،
\q1 كٍلِقٍ عَ شَ هْرْ مْبَنشِ سّنِيّنشِ كُي.
\b
\q1 
\v 3 وٌ شَ عَ مَتٌ، عَلَتَلَ نَ قَقٍ كٍلِقٍ عَ شَ لِنفِرَ،
\q1 عَ نَ فٌرٌقٍ فٍيَيٍ قَرِ، عَ عَ حّرّ.
\q1 
\v 4 فٍيَيٍ نَ شُنُقٍ عَ سَنيِ بُن مَ،
\q1 عَلْ كُمِ دٌلٍ نَشَن سَمَ تّ قّ مَ،
\q1 عَلْ يٍ نَشَن سُسُقٍ كٍلِقٍ يِرٍ عِتٍشِ.
\q1 فٍيَيٍ نَ عِبْوقٍ، عٍ قِندِ فُلُنبَيٍ رَ.
\q1 
\v 5 نَ بِرِن كٍلِشِ يَشُبَ بْنسْي شَ مُرُتّ نَن مَ،
\q1 عَ قَتَنشِ عِسِرَيِلَ حَمَ شَ يُنُبِيٍ نَن مَ.
\q1 ندٍ يَشُبَ بْنسْييٍ رَ مُرُتَشِ؟
\q1 سَمَرِ شَ مُ عَ رَ؟
\q1 ندٍ كُيٍ بَتُدٍ تِشِ يِرٍ عِتٍشِ قَرِ يُدَيَ؟
\q1 دَرِ سَلَمُ شَ مُ عَ رَ؟
\b
\q1 
\v 6 نَ كُي ﭑ قَمَ سَمَرِ قِندِدٍ فّمّ مَلَنشِيٍ نَن نَ،
\q1 ﭑ عَ قِندِ وّنِ سَنسِ سِدٍ رَ.
\q1 ﭑ عَ شَ فّمّ بِلِيٍ رَبِرَ، ﭑ عٍ رَدِن فُلُنبَيٍ كُي،
\q1 هَن عَ شَ بَنشِيٍ بُنيِ لُ كّنّ مَ.
\q1 
\v 7 ﭑ عَ شَ كُيٍيٍ بُتُشُنمَ نّ،
\q1 ﭑ عَ شَ بَتُ سٍيٍ فَنمَ نّ تّ رَ،
\q1 ﭑ عَ شَ عَلَ مَسٌلِشِيٍ شُن نَكَنَمَ نّ.
\q1 نٍيٍ قْلْشِ بَقَتَ نَن نَ نَشَن نَوَلِشِ لَنفٌي سَرٍ رَ،
\q1 نٍيٍ مَن قِندِ مَ بَقَتَ نَن نَ لَنفٌي سَرٍ قِمَ نَشَن نَ.
\b
\q1 
\v 8 ﭑ قَمَ سُننُندٍ نَ نَن مَ، ﭑ نَ ﭑ كُي عِوَ.
\q1 ﭑ نَ ﭑ حّرّ مَ نّ ﭑ سَنيِ نُن ﭑ قَتٍ مَفٍلِ رَ،
\q1 ﭑ نَ ﭑ فبٍلٍفبٍلٍ شُي عِتٍمَ نّ عَلْ وُلَءِ بَرٍ،
\q1 ﭑ نَ ﭑ كُي عِوَ عَلْ شُندِ.
\q1 
\v 9 سَمَرِ شَ قُرٍ حَاشِ مُ نْمَ دَندَندٍ،
\q1 عَ مَن بَرَ دِن يُدَيَ بْشِ رَ،
\q1 هَن عَ بَرَ دَرِ سَلَمُ مَسْتْ ﭑ مَ حَمَ سَبَتِشِ دّننَشّ.
\b
\q1 
\v 10 وٌ نَشَ نَ قٍ رَكٌلٌن فَتِكَيٍ رَ دٍ وٌ وَ شُي رَ.
\q1 ﭑ دْشْشِ شُبٍ شْورَ سُننُنيِ كُي بٍتِ لٍيَقٍرَ.
\q1 
\v 11 سَقِرِكَيٍ، وٌ شَ دَنفِ وٌ مَفٍلِ رَ يَافِ كُي.
\q1 سَانَن حَمَ مُ سُو سَمَ مِنِدٍ.
\q1 وٌ مُ نْمَ وٌ شَشِلِ تِدٍ بٍتِ عٍسٍلِ رَ، عٍ قَن نَ وَقٍ.
\q1 
\v 12 مَرٌتِكَيٍ بَرَ لُ كْنتْقِلِ كُي،
\q1 بَرِ مَ فبَلٌي بَرَ فٌرٌ كٍلِقٍ عٍ مَرِفِ عَلَتَلَ مَ،
\q1 عَ دَرِ سَلَمُ نَادّ لِ.
\q1 
\v 13 لَكِسِكَيٍ، وٌ شَ سْورِ رَفِسٍيٍ يَءِلَن.
\q1 وٌ بَرَ عَ نِيَ سِيٌنِكَيٍ شَ مُرُتَ عَلَ مَ،
\q1 عِسِرَيِلَ بَرَ بِرَ وٌ شَ يُنُبِيٍ قْشْ رَ.
\q1 
\v 14 عِ تَن نُن مٌرٍ سٍتِ فَتِكَيٍ قَتَنمَ نَ نَن مَ،
\q1 عَكِسِبُكَيٍ قَمَ نّ عِسِرَيِلَ مَنفّيٍ يَنقَدٍ.
\q1 
\v 15 مَرٍ سَكَيٍ، ﭑ فٍرٍقَ فبّتّ شّيمَ نّ عَ شَ وٌ فٍرٍ.
\q1 عِسِرَيِلَ مَنفّ حَلَمَ سِفَمَ نّ عَدُلَمَ.
\q1 
\v 16 وٌ وٌ شُنيِيٍ بِ عَلْ يُبّ، سُننُنيِ شَ قٍ رَ،
\q1 بَرِ مَ وٌ شَ دِ شَنُشِيٍ قَمَ شَنِندٍ كٌنيِيَ كُي حَمَنّ مَ.
\c 2
\s1 حَشَنكَتّ نُن كِسِ
\q1 
\v 1 حَشَنكَتّ نَ مِشِيٍ بّ،
\q1 نَشٍيٍ عٍ مَحْشُنمَ مَءِقُيَ نُن قٍ حَاشِ رَبَقٍ مَ عٍ سَ تّمُي،
\q1 كُيٍ نّقّ عِبَ، عٍ قَ قٍ كٌبِيٍ رَبَ،
\q1 بَرِ مَ نَ نْي نَ عٍ يِ رَ.
\q1 
\v 2 عٍ نَ مِلّ شّيٍ مَ، عٍ نٍيٍ بَ عٍ كَنيِيٍ يِ رَ.
\q1 عٍ نَ مِلّ بَنشِيٍ مَ، عٍ نٍيٍ تٌنفٌ عٍ سّنبّ رَ.
\q1 عٍ قُ مِشِ مَ، عٍ عَ شَ بَنشِ مُحَ.
\q1 عٍ قُ مِشِ مَ، عٍ عَ كّ رَ سُشُ عَ يِ.
\q1 
\v 3 نَ شَ قٍ رَ، مَرِفِ عَلَتَلَ نَشّ،
\q1 «ﭑ حَشَنكَتّ دْشْمَ نّ نَ مِشِ مْولِ مَ،
\q1 وٌ مُ نْمَ وٌ رَتَنفَدٍ نَشَن مَ.
\q1 ﭑ قَمَ وٌ شُن فٌرٌدٍ نَ حَشَنكَتّ تّمُي.
\q1 
\v 4 عٍ وٌ شَ قٍ عِقَلَمَ تَالِ دَاشِ نّ نَ لْشْي،
\q1 عٍ وٌ مَسِفِ عَ مَيٍلٍ كِ مَ، عٍ نُ قَ عَ قَلَ،
\q1 ‹مُشُ شَ قٍ بَرَ كَنَ قٍوٌ.
\q1 مُشُ شَ بْشِيٍ بَرَ بَ مُشُ يِ رَ.
\q1 عَ بَرَ عٍ بَ مُشُ يِ، عَ عٍ سٌ مُشُ يَشُييٍ يِ رَ.›»
\b
\q1 
\v 5 نَ نَن عَ رَ، وٌ مُ مِشِ يٌ سْتْمَ عَلَتَلَ شَ حَمَ يَ مَ،
\q1 نَشَن نْمَ بْشِ عِتَشُندٍ وٌ بّ عَلَ شَ تْنشُمَيٍ سَابُي رَ.
\q1 
\v 6 عٍ شَ نَمِحْنمّيٍ عَ قَلَمَ،
\q1 «بَ يِ مَسٍنيِ مْولِ تِقٍ،
\q1 نَمِحْنمّ مُ لَنمَ عَ شَ نَ قَلَ.
\q1 وٌن مُ قَمَ لُدٍ يَافِ يٌ كُي.
\q1 
\v 7 يَشُبَ بْنسْي، عَ لَنمَ عَ شَ قَلَ،
\q1 عَلَتَلَ شْنْمَ عَ بْحّ مَ؟
\q1 عَ دَرِشِ نَ وَلِ مْولِ رَبَ رَ؟»
\b
\q1 عَلَتَلَ نَشَ عٍ يَابِ،
\q1 «ﭑ مَ مَسٍنيِيٍ مُ قَنشِ شّ تِنشِنتْييٍ بّ؟
\q1 
\v 8 يِ وَشَتِ ﭑ مَ حَمَ بَرَ لُ عَلْ ﭑ يَشُي.
\q1 وٌ دٌنمَ قَنيِ بَمَ دَنفِ مِشِيٍ مَ،
\q1 نَشٍيٍ قَقٍ بْحّسَ كُي كٍلِقٍ فٍرٍ سٌدٍ.
\q1 
\v 9 وٌ ﭑ مَ حَمَ شَ فِنّيٍ كٍرِ مَ عٍ شَ بَنشِ قَنيِيٍ كُي،
\q1 وٌ عٍ شَ دِيٍ شَ شُننَكٍلِ بَمَ عٍ يِ رَ ﭑ نَشَن قِ عٍ مَ.
\q1 
\v 10 وٌ كٍلِ، وٌ سِفَ،
\q1 ﭑ بَرَ يِ بْشِ بَ وٌ يِ رَ سَبَتِدٍ رَ،
\q1 بَرِ مَ عَ مُ سّنِيّن، عَ بَرَ كَنَ كٍرٍنيِ رَ.
\q1 
\v 11 شَ وُلٍ قَلّ نُن مِشِ مَدَشُي قَ عَ قَلَ وٌ بّ،
\q1 ‹وٌ قَمَ بٍيرٍ نُن وّنِ سْتْدٍ›،
\q1 نَ مِشِ مْولِ نَن نَقَن وٌ مَ نَمِحْنمّ رَ.»
\b
\q1 
\v 12 «يَشُبَ بْنسْي، ﭑ وٌ بِرِن مَلَنمَ نّ.
\q1 عِسِرَيِلَ مِشِ دْنشْييٍ، ﭑ وٌ شُن لَنمَ نّ.
\q1 ﭑ وٌ مَلَنمَ نّ، عَلْ يّشّييٍ نَشٍيٍ مَلَنمَ فْورّ كُي،
\q1 عَلْ شُرُ سٍيٍ نَشٍيٍ نَ قِيلِ مَ عٍ دّ مَدٌندٍ.
\q1 حَمَ فبٍفبٍ سَبَتِمَ نّ نَا.
\q1 
\v 13 عٍ شَ مَنفّ قَمَ نّ تَا تّتّ عِبْودٍ،
\q1 عَ قَ تِ حَمَ يَ رَ،
\q1 عَ عٍ بِرِن نَمِنِمَ نّ نَا.
\q1 عَلَتَلَ نَن قِندِ عٍ شُنيِ رَ.»
\c 3
\s1 عِسِرَيِلَ يَرٍرَتِيٍ شَ يُنُبِيٍ
\q1 
\v 1 ﭑ نَشّ، «يَشُبَ بْنسْي مَنفّيٍ،
\q1 عِسِرَيِلَ يَرٍرَتِيٍ، وٌ شَ وٌ تُلِ مَتِ.
\q1 وٌ تَن شَ مُ دَشَ وٌ شَ سّرِيّ كٌلٌن؟
\q1 
\v 2 كْنْ وٌ قٍ قَنيِيٍ شْنمَ، قٍ حَاشِيٍ نَن نَقَن وٌ مَ.
\q1 وٌ مِشِيٍ تْورْ مَ هَن،
\q1 عَ لُشِ نّ عَلْ وٌ عٍ شَ كِرِ نُن سُبٍ بَمَ عٍ قَتٍيٍ مَ،
\q1 
\v 3 وٌ نَ عِبٌلٌن عَ شُنتُنيِيٍ رَ، وٌ عَ حِن تُندٍ كُي، وٌ قَ عَ دٌن.»
\b
\q1 
\v 4 نَ مِشِ مْولِ قَمَ نّ عَلَتَلَ شِلِدٍ،
\q1 كْنْ عَ مُ عٍ يَابِمَ.
\q1 نَ لْشْي عَ عَ كٌبٍ سٌمَ نّ عٍ رَ،
\q1 بَرِ مَ عٍ حّرّ كِ مُ قَن.
\q1 
\v 5 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 «وٌ تَن نَمِحْنمّ نَشٍيٍ ﭑ مَ حَمَ رَتَنتَنمَ،
\q1 نَشٍيٍ بْحّسَ مَسٍنمَ مِشِيٍ بّ نَشٍيٍ وٌ كِمَ،
\q1 كْنْ وٌ مِشِيٍ تَن فٍرٍ نَشٍيٍ وٌ كُمَ.
\q1 
\v 6 نَ شَ قٍ رَ، كْي سٌمَ نّ وٌ شُن،
\q1 وٌ مُ تٌي تِمَ، وٌ مُ لَامَتُنيِيٍ سْتْمَ، وٌ لُمَ دِ مِ نَن كُي تُن.
\q1 سٌفٍ دُلَمَ نّ نَ نَمِحْنمّيٍ شُن،
\q1 يَنيِ قَن عِقْورْ عٍ بّ.
\q1 
\v 7 سٍ مَتٌي يَافِمَ نّ،
\q1 نَشٍيٍ يَرٍ تٌمَ، عٍ شُن سِنمَ نّ،
\q1 عٍ عٍ يَتَفِ نْشُن،
\q1 بَرِ مَ ﭑ تَن عَلَ مُ عٍ يَابِمَ.»
\b
\q1 
\v 8 كْنْ عَلَ شَشِلِ سّنِيّنشِ بَرَ سّنبّ قِ ﭑ مَ،
\q1 تِنشِنيِ نُن لِمَنِيَ بَرَ لُ ﭑ يِ رَ،
\q1 عَلَكٌ ﭑ شَ يَشُبَ بْنسْييٍ رَكٌلٌن عٍ شَ مُرُتّ رَ،
\q1 ﭑ شَ عِسِرَيِلَ شَ يُنُبِيٍ مَسٍن عَ بّ.
\q1 
\v 9 وٌ تَن يَشُبَ بْنسْييٍ يَرٍرَتِيٍ،
\q1 وٌ تَن عِسِرَيِلَ حَمَ شَ مَنفّيٍ،
\q1 وٌ شَ وٌ تُلِ مَتِ ﭑ نَ.
\q1 وٌ نَ تِنشِنيِ شْنقٍ، وٌ عَ مَقِندِ.
\q1 
\v 10 وٌ نَ مِشِيٍ نِي بَقٍ سِيٌنِ تِقٍ رَ،
\q1 وٌ نَ دَرِ سَلَمُ تِقٍ تِنشِنتَرٍيَ كُي.
\q1 
\v 11 عٍ شَ مَنفّيٍ كِيتِ سَمَ كْبِرِ سْتْقٍ نَن مَ.
\q1 عٍ شَ سّرّشّدُبّيٍ شَرَنيِ تِمَ نَاقُلِ شَ قٍ نَن نَ.
\q1 عٍ شَ نَمِحْنمّيٍ مَسٍنيِيٍ تِمَ عٍ شَ فٍينِ نَن مَ.
\q1 كْنْ عٍ بِرِن عٍ يَ تِمَ عَلَتَلَ رَ، عٍ نُ عَ قَلَ مِشِيٍ بّ،
\q1 «عَلَتَلَ مُ نَ شّ وٌن يَ مَ؟
\q1 حَشَنكَتّ يٌ مُ وٌن لِمَ.»
\q1 
\v 12 وٌ شَ قٍ نَن يَتِ عَ نِيَمَ سِيٌنِ قَمَ بُشَدٍ عَلْ شّ،
\q1 دَرِ سَلَمُ قِندِ مَ نّ فّمّ مَلَنشِيٍ رَ،
\q1 قْتْنيِ قَ بُلَ هْرْ مْبَنشِ رَبِلِنيِ مَ.
\c 4
\s1 عَلَتَلَ شَ شُننَكٍلِ
\q1 
\v 1 تّمُي قَمَ عَ لِدٍ،
\q1 عَلَتَلَ شَ بَنشِ تِشِ فٍيَ نَشَن قَرِ،
\q1 نَ قَمَ نّ تِدٍ فٍيَ بِرِن شُن مَ.
\q1 عَ عِتٍمَ نّ تٍنتٍنيِ بِرِن بّ،
\q1 حَمَيٍ لُمَ نّ سِفَ رَ مّننِ.
\q1 
\v 2 سِ فبٍفبٍ عٍ شُن تِمَ نّ نَا رَ، عٍ عَ قَلَ،
\q1 «وٌن شَ سِفَ عَلَتَلَ شَ فٍيَ قَرِ،
\q1 يَشُبَ مَرِفِ عَلَ شَ بَنشِ.
\q1 عَ وٌن شَرَنمَ نّ عَ شَ سّرِيّ رَ،
\q1 عَلَكٌ وٌن شَ وٌن حّرّ عَ شَ كِرَ شْن مَ.»
\b
\q1 سّرِيّ قَتَنمَ سِيٌنِ نَن نَ،
\q1 عَلَتَلَ شَ مَسٍنيِ كٍلِمَ دَرِ سَلَمُ نَن كُي.
\q1 
\v 3 عَ قِندِ مَ نّ كِيتِسَ رَ سِ فبٍفبٍ تَفِ،
\q1 عَ قَ سِ سّنبّمَيٍ شَ فٍرٍ رَحْندٍ دُنِحَ بِرِن كُي.
\q1 عٍ عٍ شَ سَنتِدّفّمَيٍ شَبُمَ سَرِ شَ كٍرِيٍ نَن نَ،
\q1 عٍ عٍ شَ وْرْتّيٍ يَءِلَن تَنبّيٍ رَ.
\q1 سِ يٌ مُ عَ شَ سَنتِدّفّمَ عِتٍمَ سِ فبّتّ شِلِ مَ سْنْن.
\q1 نَ وَشَتِ، مِشِيٍ مُ فٍرٍ مْولِ يٌ مَتِنكَنمَ.
\q1 
\v 4 عٍ تِمَ عٍ شَ وّنِ سَنسِ نَن سّيتِ مَ،
\q1 عٍ دْشْ عٍ شَ شْرّ بِلِ نِينِ بُن مَ.
\q1 مِشِ يٌ مُ قَمَ عٍ بْحّ رَ مِنِدٍ،
\q1 بَرِ مَ عَلَتَلَ سّنبّمَ بَرَ وْيّن.
\q1 
\v 5 سِ بِرِن نْمَ حّرّدٍ عٍ شَ عَلَيٍ وَشْن كِ نّ،
\q1 كْنْ وٌن تَن وٌن حّرّ مَ عَلَتَلَ نَن وَشْن كِ عَبَدَن.
\b
\q1 
\v 6 عَلَتَلَ نَشَ عَ مَسٍن،
\q1 «لْشْي ندٍ قَمَ، ﭑ لَنيُرُتْييٍ مَلَنمَ نّ.
\q1 ﭑ مِشِيٍ شُنلَنمَ نّ، ﭑ نَشٍيٍ رَيٍنسٍنشِ تْورّ كُي.
\q1 
\v 7 ﭑ لَنيُرُتْييٍ قِندِ مَ نّ مِشِ كِسِشِ دْنشْييٍ رَ،
\q1 ﭑ مِشِ رَيٍنسٍنشِيٍ قِندِ مَ نّ سِ سّنبّمَ رَ.
\q1 عَلَتَلَ نَن تِمَ عٍ شُن مَ سِيٌنِ فٍيَ قَرِ عَبَدَن.
\q1 
\v 8 عِ تَن سِيٌنِ، نَشَن عَ حْشْ سَمَ حَمَ شْن مَ،
\q1 نَشَن قِندِشِ تَا مَكَنتَ شِ رَ،
\q1 نْي قِسَمَنتٍ فبِلٍنمَ عِ تَن نَن مَ،
\q1 مَنفّيَ قَ لُ دَرِ سَلَمُ يِ رَ.»
\b
\q1 
\v 9 وٌ قَ فبٍلٍفبٍلٍمَ مُنقٍ رَ؟
\q1 مَنفّ مُ نَ وٌ شْنيِ سْنْن؟
\q1 وٌ رَ سِمَ بَرَ قَشَ؟
\q1 نَ بَرَ عَ نِيَ وٌ شَ تْورْ عَلْ فِنّ نَشَن نَ دِتِنيِ رَ؟
\q1 
\v 10 سِيٌنِكَيٍ، وٌ قُرِيٍ شَ وٌ مَتٌلِن عَلْ قُرِ فِنّ،
\q1 بَرِ مَ عٍ وٌ رَ مِنِمَ نّ تَا كُي، وٌ قَ شِ بُرُنيِ.
\q1 عٍ وٌ شَنِنمَ بَبِلْن كٌنيِيَ كُي،
\q1 كْنْ مّننِ وٌ قَمَ نّ قُلُندٍ.
\q1 عَلَتَلَ وٌ بَمَ نّ وٌ يَشُييٍ بّلّشّ عِ.
\b
\q1 
\v 11 كْنْ يَكْسِ سِ فبٍفبٍ تِشِ وٌ شِلِ مَ،
\q1 عَ قَلَقٍ رَ، «سِيٌنِ شَ يَافِ وٌن يَ شْرِ!»
\q1 
\v 12 نٍيٍ مُ عَلَتَلَ شَ مَحْشُنيِ كٌلٌنشِ،
\q1 عٍ مُ عَ شَ وَلِ قَهَامُشِ.
\q1 عَلَتَلَ بَرَ عٍ مَلَن لٌنيِ مَ مَالٍ بْنبْمَ دّننَشّ.
\q1 
\v 13 سِيٌنِكَيٍ، وٌ كٍلِ وٌ شَ عٍ بْنبْ.
\q1 ﭑ وٌ سّنبّ فبٌمَ نّ عَلْ تُورَ،
\q1 نَشَن قٍرِيٍ يَءِلَنشِ وُرٍ رَ، نَشَن تٌرٍ قِندِشِ وُرٍ فبٍيلِ رَ.
\q1 نَ كُي وٌ حَمَنّ وُيَشِ بُتُشُنمَ نّ،
\q1 وٌ عٍ شَ نَاقُلِ قِندِ مَ ﭑ تَن دُنِحَ مَرِفِ عَلَتَلَ نَن فبٍ رَ.
\b
\q1 
\v 14 يَكْسِ وٌ شَ وٌ قَتٍيٍ مَبْو سُننُنيِ مَ،
\q1 بَرِ مَ عٍ نَ وٌن مَ تَا سُشُقٍ،
\q1 عٍ نَ عِسِرَيِلَ حَمَ شَ مَنفّ بْنبْقٍ عَ يَتَفِ مَ وُرِ رَ.
\c 5
\s1 عِسِرَيِلَ نَكِسِمَ
\q1 
\v 1 «عِ تَن، بّتّلّيمُ عٍقَرَتَ، نَشَن شُرُن يُدَ شَبِلّيٍ يَ مَ،
\q1 مِشِ ندٍ مِنِمَ نّ عِ يَ مَ نَشَن عِسِرَيِلَ يَمَرِ مَ ﭑ بّ.
\q1 عَ شَ قٍ قْلْشِ تّمُي دَنفِشِ نّ نَشَن مَكُيَ ثٌن.»
\b
\q1 
\v 2 نَ نَ عَ تٌمَ، عَلَتَلَ عِسِرَيِلَ رَبٌلٌمَ،
\q1 هَن قُرِ فِنّ قَ عَ شَ دِ بَرِدٍ.
\q1 نَ تّمُي، نَ دِ نفَشَكٍرٍنيِيٍ دْنشْييٍ قَمَ نّ فبِلٍندٍ عِسِرَيِلَ.
\q1 
\v 3 عَ كٍلِمَ نّ، عَ تِ عَ شَ شُرُ سٍيٍ يَ رَ،
\q1 عَ عٍ دّ مَدٌن عَ مَرِفِ عَلَتَلَ شِلِ شُنفبٍ كَنيِ سّنبّ رَ.
\q1 عٍ سَبَتِمَ نّ عَ قَنيِ رَ،
\q1 بَرِ مَ عَ شَ شُننَكٍلِ دُنِحَ بِرِن لِمَ نّ.
\q1 
\v 4 عَ تَن نَن قِندِ مَ وٌن مَ بْحّسَ رَ.
\q1 عَسِرِيَكَيٍ نَ قَ وٌن مَ بْشِ مَ،
\q1 عٍ سٌ وٌن مَ يِرٍ مَكَنتَشِيٍ كُي،
\q1 وٌن كَنتَمَ سٌلٌقٍرٍ نُن مَنفّ سٌلٌمَسَشَن نَن كٍلِمَ عٍ شِلِ مَ.
\q1 
\v 5 عٍ عَسِرِيَ بْشِ يَمَرِ مَ نّ سَنتِدّفّمَ رَ،
\q1 عٍ دْشْ نِمِرٌدِ شَ بْشِ شُن مَ تَنبّ رَ.
\q1 وٌن مَ مَنفّ وٌن بَمَ نّ عَسِرِيَكَيٍ يِ رَ،
\q1 عٍ نَ تُفَن وٌن مَ نَانِنيِ شُن مَ، عٍ سٌ وٌن مَ بْشِ كُي.
\b
\q1 
\v 6 يَشُبَ بْنسْي دْنشْييٍ لُمَ نّ دُنِحَ سِيٍ يَ مَ،
\q1 عَلْ شِنِ نَشَن كٍلِمَ عَلَتَلَ مَ،
\q1 عَلْ تُنّ يٍ نَشَن دْشْمَ بُرّشّ رَ.
\q1 عٍ مُ عٍ شَشِلِ تِمَ عِبُنَدَ مَ رَ،
\q1 عٍ مُ عٍ يّتّ تَشُمَ مِشِ يٌ رَ.
\q1 
\v 7 يَشُبَ بْنسْي دْنشْييٍ لُمَ نّ دُنِحَ سِ فبٍفبٍ يَ مَ،
\q1 عَلْ يّتّ نَشَن تِمَ وُلَءِ سُبٍيٍ تَفِ،
\q1 عَلْ يّتّ يْرّ نَشَن حّرّ مَ شُرُ سٍيٍ يَ مَ،
\q1 عَ قَ دُتُن ندٍيٍ مَ، عَ عٍ عِبْو، مِشِ يٌ مُ نْمَ عٍ بَدٍ عَ يِ رَ.
\q1 
\v 8 عِ شُن نَكٍلِمَ نّ عِ يَشُييٍ يَ عِ، عٍ بِرِن سْنتْ.
\b
\q1 
\v 9 عَلَتَلَ نَشَ عَ مَسٍن،
\q1 «لْشْ ندٍ قَمَ عَ لِدٍ،
\q1 ﭑ وٌ شَ سٌييٍ نُن وٌ شَ سْورِ رَفِسٍيٍ شَ قٍ كَنَمَ نّ.
\q1 
\v 10 ﭑ وٌ شَ بْشِ شَ تَايٍ كَنَمَ نّ،
\q1 ﭑ وٌ شَ يِرٍ مَكَنتَشِيٍ رَبِرَ.
\q1 
\v 11 ﭑ وٌ شَ دُورٍيَ كَنَمَ نّ،
\q1 ﭑ وٌ شَ سٍ مَتٌي رَيٍنسٍن يّ.
\q1 
\v 12 ﭑ وٌ شَ كُيٍيٍ نُن وٌ شَ فّمّ مَسٌلِشِ بِرِن كَنَمَ نّ.
\q1 نَ تّمُي، وٌ مُ سُيِدِ مَ سٍ يَءِلَنشِيٍ بّ سْنْن.
\q1 
\v 13 ﭑ وٌ شَ عَسٍرِ وُرِ مَسٌلِشِيٍ تَلَمَ نّ وٌ تَفِ،
\q1 ﭑ وٌ شَ تَايٍ كَنَمَ نّ،
\q1 
\v 14 ﭑ ﭑ فبٍحْشْمَ شْنّ نَن كُي، سِيٍ مَ
\q1 نَشٍيٍ مُ تِن ﭑ شُي سُشُدٍ.»
\c 6
\s1 عَلَتَلَ شَ كَلَمُي
\q1 
\v 1 وٌ وٌ تُلِ مَتِ عَلَتَلَ شَ مَسٍنيِ رَ؛
\q1 «كٍلِ، وٌ شَ وٌ شَ كَلَمُي تِ فٍيَيٍ يَ شْرِ،
\q1 دُنِحَ بِرِن شَ عِ شُي مّ.
\q1 
\v 2 فٍيَ نَشٍيٍ نَ دُنِحَ مَ كَبِ عَ قْلّ،
\q1 وٌ شَ ﭑ تَن عَلَتَلَ شَ كَلَمُي مّ،
\q1 ﭑ نَشَن تِمَ ﭑ مَ حَمَ عِسِرَيِلَ شِلِ مَ.»
\b
\q1 
\v 3 «ﭑ مَ حَمَ، ﭑ مُنسٍ رَبَشِ وٌ رَ؟
\q1 ﭑ كٌتٍ مُندُن دْشْشِ وٌ شُن مَ؟
\q1 وٌ شَ ﭑ يَابِ.
\q1 
\v 4 ﭑ وٌ رَ مِنِشِ نّ مِسِرَ بْشِ رَ،
\q1 ﭑ وٌ شُن سَرَ كٌنيِيَ كُي.
\q1 ﭑ نَشَ مُنسَ، هَرُنَ، نُن مَرِيَمَ شّي وٌ رَ مِنِدٍ.
\q1 
\v 5 ﭑ مَ حَمَ، وٌ شَ وٌ رَتُ عَ مَ،
\q1 مٌوَبَ مَنفّ بَلَكِ نُ وَ مَ نَشَن نَبَقٍ وٌ رَ،
\q1 عَ نُن بٍيٌرِ شَ دِ بَلَمِ شَ يَابِ.
\q1 وٌ شَ وٌ رَتُ وٌ شَ بِيَاسِ مَ كٍلِقٍ سِتِمِ هَن فِلِفَلِ،
\q1 عَلَتَلَ شَ قٍ تِنشِنشِيٍ عَ نَشٍيٍ رَبَشِ وٌ بّ.»
\b
\q1 
\v 6 ﭑ قَمَ مُنسٍ رَ عَلَتَلَ بّ ﭑ شَ مَنفّ عَلَ بَتُ؟
\q1 عَ لَنمَ ﭑ شَ قَ سّرّشّ نَن نَ عَ بّ،
\q1 سّرّشّ فَن دَاشِ عَلْ نِنفٍ نَشٍيٍ بَرَ حّ كٍرٍن سْتْ؟
\q1 
\v 7 عَلَتَلَ وَ مَ يّشّي كٌنتٌنيِ فَلِ نَن شْن مَ،
\q1 شَ نَ مُ عَ رَ، تُرٍ فبٍفبٍ نَشَن مُ حْنمَ؟
\q1 عَ لَنمَ ﭑ شَ ﭑ مَ دِ سِنفٍ بَ سّرّشّ رَ ﭑ مَ يُنُبِ سَرٍ رَ؟
\q1 ﭑ دِ نَشَن سْتْ، نَ نْمَ قِندِدٍ نَ شَقَرِ سٍ رَ؟
\q1 
\v 8 عَلَ بَرَ عَدَ مَدِ رَكٌلٌن قٍ رَ نَشَن قَن،
\q1 عَ وَ مَ عِ شَ نَشَن نَبَ؟
\q1 عَ وَ مَ نّ عِ شَ تِنشِن،
\q1 دُفُتّفّيَ شَ رَقَن عِ مَ،
\q1 عِ مَن شَ بِرَ عَلَتَلَ قْشْ رَ يّتّ مَفٌرٍ كُي.
\b
\q1 
\v 9 عَلَتَلَ نَ تَاكَيٍ شِلِقٍ.
\q1 شَشِلِمَ قَمَ نَ تٌدٍ، عَ قَ فَاشُ عَلَ يَ رَ.
\q1 «وٌ وٌ تُلِ مَتِ عَ شَ كِيتِ رَ، وٌ نَشَ وٌ كٌبٍ سٌ نَ كِيتِسَ رَ.
\q1 
\v 10 نَاقُلِ نَ وٌ شْنيِ وٌ نَشَن سْتْ تِنشِنتَرٍيَ كُي؟
\q1 مَنِيَ سٍ كَمَلِتَرٍيٍ نَ وٌ شْنيِ ﭑ نَشٍيٍ شْنشِ؟
\q1 
\v 11 ﭑ نْمَ دِحّدٍ مَنِيَ سٍ تِنشِنتَرٍيٍ كَنيِ مَ؟
\q1 
\v 12 تَا بَننَيٍ قِندِشِ قٍ كٌبِ رَبَيٍ نَن نَ،
\q1 تَاكَيٍ وُلٍ نَن تُن قَلَمَ، عٍ مِشِيٍ مَدَشُ.»
\b
\q1 
\v 13 «نَ كُي ﭑ بَرَ وٌ تْورْ قْلْ،
\q1 ﭑ شَ وٌ هَلَكِ وٌ شَ يُنُبِيٍ شَ قٍ رَ.
\q1 
\v 14 وٌ وٌ دّفٍمَ نّ، كْنْ وٌ مُ قَمَ لُفَدٍ،
\q1 وٌ دٌنسٍ رَفَتَمَ نّ، كْنْ عَ مُ لُمَ نَا.
\q1 نَ بَمَ نّ وٌ يِ رَ سَنتِدّفّمَ رَ.
\q1 
\v 15 وٌ شّ سَمَ نّ، كْنْ وٌ مُ عَ شَبَمَ،
\q1 وٌ عٌلِوِ بٌفِ بُندُ مَ نّ، كْنْ وٌ مُ عَ تُرٍ دٌنمَ،
\q1 وٌ وّنِ بٌفِ دُندُ مَ نّ، كْنْ وٌ مُ عَ مِنمَ.
\q1 
\v 16 وٌ بِرَ نّ عٌمِرِ شَ يَامَرِيٍ قْشْ رَ،
\q1 وٌ عَكَبُ شَ نَامُنيِيٍ قِندِ وٌ فبٍ رَ.
\q1 ﭑ وٌ سْنتْمَ نَ نَن مَ،
\q1 ﭑ وٌ شَ حَمَ قِندِ مَ نّ مَيٍلٍ سٍ رَ دُنِحَ يَ شْرِ،
\q1 ﭑ وٌ لُمَ نّ يَافِ كُي سِيٍ تَفِ.»
\c 7
\s1 عَلَ شَ حَشَنكَتّ نُن عَ شَ كِسِ
\q1 
\v 1 ﭑ نَ تْورْقٍ يِ كِ!
\q1 ﭑ لُشِ نّ عَلْ مِشِ نَشَن سِفَمَ سَنسِ بٌفِ بَدٍ عَ بَ تّمُي،
\q1 كْنْ عَ مُ وّنِ بٌفِ تٌمَ نَا،
\q1 عَ مُ شْرّ قَنيِ لِمَ وُرِ كْن نَ عَلْ عَ وَ مَ عَ شْن مَ كِ نَشّ.
\q1 
\v 2 عَلَ شَنُنتٍنيِيٍ بَرَ حْن بْشِ مَ،
\q1 تِنشِنتْي كٍرٍن مُ لُمَ نَا.
\q1 عٍ بِرِن نَ عٍ بٌورٍ تْورْقٍ عَ حَاشِ رَ،
\q1 كَنكَن فَنتَنيِ تٍمَ عَ نفَشَكٍرٍنيِ بّ.
\q1 
\v 3 عٍ بِرِن قَتَ قٍ حَاشِ رَبَدٍ.
\q1 مَنفّيٍ، نٍيٍ وَ مَ بُحَ تِنشِنتَرٍ شْن مَ.
\q1 كِيتِسَيٍ، نٍيٍ كِيتِ سَمَ كْبِرِ نَن تُن مَ قٍ رَ.
\q1 كُنتِفِيٍ، نٍيٍ قَن عٍ شَ وَ سَبَلِيَ مَسٍنمَ.
\q1 عٍ بِرِن نَ قٍ كٍرٍن نّ.
\q1 
\v 4 نَشَن نَ قِسَمَنتٍ رَ وٌ يَ مَ،
\q1 نَ تَن لُمَ نّ عَلْ تُنبٍ شْنّ.
\b
\q1 عَلَ شَ كِيتِ لْشْي بَرَ عَ لِ،
\q1 عَلْ حَمَ مَكَنتّ عَ قَلَ كِ نَشّ.
\q1 حَمَ بْحّ مِنِ تّمُي بَرَ قَ.
\q1 
\v 5 وٌ نَشَ لَ وٌ دّ قَن بٌورٍ رَ،
\q1 وٌ نَشَ لَ وٌ شَنُنتٍنيِ رَ،
\q1 هَلِ وٌ شَ فِنّ نَشَن عَ سَمَ وٌ قّ مَ،
\q1 وٌ نَشَ وٌ شَ فُندٌ بِرِن مَسٍن عَ بّ.
\q1 
\v 6 نَ وَشَتِ دِ شّمّ عَ بَبَ مَبٍرٍ مَ نّ،
\q1 دِ فِنّ تِ عَ نفَ كَنكٍ عِ،
\q1 مَمَدِ نُن عَ شَ مْرِ نفَ كْنحّمَ نّ.
\q1 كَنكَن يَشُي قِندِ مَ عَ بَرِ بٌورٍ يَتِ نَن نَ.
\q1 
\v 7 كْنْ ﭑ تَن، ﭑ يَ تِمَ عَلَتَلَ نَن نَ،
\q1 ﭑ نَ ﭑ شَشِلِ تِمَ ﭑ نَكِسِمَ عَلَ نَن نَ،
\q1 بَرِ مَ ﭑ مَرِفِ ﭑ شُي سُشُمَ نّ.
\b
\q1 
\v 8 عِ تَن عِسِرَيِلَ يَشُي،
\q1 عِ نَشَ حّلّشِن ﭑ مَ تْورّ رَ.
\q1 هَلِ ﭑ بِرَ نّ، ﭑ مَن كٍلِمَ نّ.
\q1 هَلِ ﭑ لُ نّ دِ مِ شْورَ، عَلَتَلَ نَن نَ ﭑ مَ يَنبّ رَ.
\q1 
\v 9 ﭑ تٌ يُنُبِ رَبَ عَلَتَلَ رَ،
\q1 ﭑ قَمَ نّ عَ شَ شْنّ سْتْدٍ هَن عَ كَمَلِ،
\q1 عَ قَ ﭑ شُن مَقَلَدٍ، عَ عَ شَ تِنشِنيِ مَسٍن ﭑ بّ.
\q1 
\v 10 ﭑ يَشُييٍ نَ نَ تٌ، عٍ يَافِمَ نّ.
\q1 سِنفٍ عٍ نُ عَ قَلَمَ، «عِ مَرِفِ عَلَتَلَ نَ مِندٍن؟»
\q1 كْنْ نَ تّمُي ﭑ تَن نَن عٍ شَ بِرّ تٌمَ،
\q1 عٍ مَبٌرٌن سَنيِ رَ عَلْ بٌورَ نَشَن نَ كِرَ رَ.
\b
\q1 
\v 11 عِ تَن عِسِرَيِلَ، وٌ شَ تّتّ رَكٍلِ لْشْي قَمَ نّ،
\q1 وٌ شَ نَانِنيِيٍ عِفبٌمَ نّ.
\q1 
\v 12 نَ لْشْي مِشِيٍ قَمَ نّ وٌ يِرٍ،
\q1 كٍلِقٍ عَسِرِيَ نُن مِسِرَ تَايٍ كُي،
\q1 كٍلِقٍ مِسِرَ بْشِ هَن عٍقِرَتِ شُرٍ،
\q1 كٍلِقٍ بَا ندٍ مَ عَ سَ دْشْ بَا فبّتّ رَ،
\q1 كٍلِقٍ فٍيَ ندٍ مَ عَ سَ دْشْ فٍيَ فبّتّ رَ.
\q1 
\v 13 دُنِحَ بْشِ قَمَ نّ كَنَدٍ مِشِيٍ شَ وَلِ حَاشِيٍ شَ قٍ رَ.
\b
\q1 
\v 14 مّينِ عِ شَ حَمَ مَ،
\q1 بَرِ مَ عٍ قِندِشِ عِ كّ نَن نَ،
\q1 نَشٍيٍ سَبَتِشِ عٍ كٍرٍنيِ مَ قْتْنيِ كُي قِيلِ قَنيِ سّيتِ مَ.
\q1 عٍ شَ عٍ دّ مَدٌن عَ قَنيِ رَ،
\q1 عَلْ عٍ نُ عَ رَبَشِ بَسَن نُن فَلَدِ بْشِ مَ تّمُي دَنفِشِ كِ نَشّ.
\q1 
\v 15 ﭑ كَابَنَكٌي مَسٍنمَ نّ عٍ بّ،
\q1 عَلْ عٍ مِنِ مِسِرَ بْشِ رَ لْشْي نَشّ.
\q1 
\v 16 سِيٍ نَ وٌ سّنبّ تٌ، عٍ يَافِمَ نّ عٍ شَ سّنبّتَرٍيَ كُي.
\q1 
\v 17 عٍ شُبٍ دٌنمَ نّ عَلْ بْشِمَسٍ،
\q1 عٍ لُمَ فَاشُي نَن كُي وٌن مَرِفِ عَلَتَلَ يَ رَ، عٍ قَ سّرّن.
\q1 
\v 18 عَلَ مُندُن نَ نَشَن مَنِيَ عِ رَ،
\q1 نَشَن يُنُبِ شَقَرِ مَ،
\q1 نَشَن دِحّمَ عَ شَ كّ تٌنفٌمَيٍ دْنشْييٍ مَ؟
\q1 عِ مُ شْنّ رَفَتَمَ عَبَدَن،
\q1 بَرِ مَ دُفُتّفّيَ مَسٍنقٍ مُشُ بّ عَ رَقَن عِ مَ.
\q1 
\v 19 عِ مَن كِنِكِنِمَ نّ مُشُ مَ،
\q1 عِ قَمَ نّ مُشُ شَ يُنُبِيٍ لُدٍ نَا،
\q1 عِ قَ عٍ وٌلِ بَا بْتِنِ مَ.
\q1 
\v 20 عِ عِ شُي رَكَمَلِمَ نّ يَشُبَ بْنسْي بّ،
\q1 عِ هِننّمَ نّ عِبُرَهِمَ بْنسْي رَ،
\q1 عَلْ عِ عِ كَلِ عَ رَ مُشُ بٍنبَيٍ بّ كِ نَشّ تّمُي دَنفِشِ.
