\p
\v 1 \w Ka|strong="H0589"\w* \w mael|strong="H7725"\w* \w tih|strong="H9999"\w* khomik hmuikah a \w hnaemtaek|strong="H6231"\w* rhoek \w boeih|strong="H3605"\w* \w te|strong="H0853"\w* ka \w sawt|strong="H7200"\w*. \w Te|strong="H0834"\w* te \w khomik|strong="H8121"\w* \w hmuiah|strong="H8478"\w* a \w saii|strong="H6213"\w* uh \w tih|strong="H9999"\w* a \w hnaemtaek|strong="H6231"\w* rhoek kah \w mikphi|strong="H1832"\w* aih \w ke|strong="H2009"\w*, \w amih|strong="H9908"\w* aka \w hloep|strong="H5162"\w* \w ham|strong="H9997"\w* khaw om \w pawh|strong="H0369"\w*. Aka \w hnaemtaek|strong="H6231"\w* rhoek kah \w kut|strong="H3027"\w* \w ah|strong="H4480"\w* tah \w a|strong="H9908"\w* \w thadueng|strong="H3581"\w* om \w tih|strong="H9999"\w* a haemtaek \w rhoek|strong="H9908"\w* \w te|strong="H9997"\w* aka \w hloep|strong="H5162"\w* om \w pawh|strong="H0369"\w*.  
