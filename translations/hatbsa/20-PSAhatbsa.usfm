\q1 paske Ou se \x + \xo 71:3 \xt Sòm 18:2\x*wòch mwen ak sitadèl mwen.   
\q1
\v 4 \x + \xo 71:4 \xt Sòm 140:1-4\x* Delivre mwen, O Bondye mwen, nan men a mechan yo,  
\q1 Fè m sòti nan ponyèt a malfektè a ak san pitye a,   
\q1
\v 5 Paske Ou se espwa m, O SENYÈ Bondye,  
\q1 Ou se \x + \xo 71:5 \xt Sòm 22:9\x* konfyans mwen soti nan jenès mwen.   
\q1
\v 6 Pa Ou menm, mwen te twouve \x + \xo 71:6 \xt Sòm 22:10\x* soutyen depi lè m te fèt.  
\q1 Se Ou menm ki te retire mwen nan vant manman m.  
\q1 Tout tan se Ou menm ke m louwe.   
\q1
\v 7 Mwen parèt kon yon \x + \xo 71:7 \xt És 8:18\x* mèvèy pou anpil moun,  
\q1 men se Ou ki fò refij mwen.   
\q1
\v 8 Bouch mwen plen avèk lwanj Ou  
\q1 ak \x + \xo 71:8 \xt Sòm 96:6\x* glwa Ou tout lajounen.   
\q1
\v 9 Pa jete mwen akote nan \x + \xo 71:9 \xt Sòm 71:18\x* tan vyeyès mwen.  
\q1 Pa abandone mwen lè fòs mwen vin febli.   
\q1
\v 10 Paske Lènmi m yo te pale kont mwen.  
\q1 Sila k ap veye pou pran lavi m yo \x + \xo 71:10 \xt Sòm 31:13\x* ap pran konsèy ansanm,   
\q1
\v 11 Y ap di: \x + \xo 71:11 \xt Sòm 3:2\x* “Bondye fin abandone li.  
\q1 Annou kouri dèyè l, e sezi li.  
\q1 Paske nanpwen moun ki pou delivre l.”   
\q1
\v 12 O Bondye, \x + \xo 71:12 \xt Sòm 10:1\x* pa rete lwen mwen.  
\q1 O Bondye m, fè vit a sekou mwen!   
\q1
\v 13 Kite sila ki advèsè a nanm mwen yo vin wont e manje nèt.  
\q1 Kite yo kouvri avèk repwòch ak dezonè k ap \x + \xo 71:13 \xt Est 9:2\x*chache blese mwen.   
\q1
\v 14 Men pou mwen, mwen va kenbe espwa m pou tout tan.  
\q1 Mwen va \x + \xo 71:14 \xt Sòm 71:8\x*bay Ou lwanj plis toujou.   
\q1
\v 15 Bouch mwen va pale ladwati Ou,  
\q1 ak sali Ou tout lajounen,  
\q1 menmsi mwen \x + \xo 71:15 \xt Sòm 40:5\x*pa kab fin konnen  
\q1 fòs valè tout jou sa yo.   
\q1
\v 16 Mwen va vini ak zèv pwisan SENYÈ Bondye a.  
\q1 Mwen va \x + \xo 71:16 \xt Sòm 51:14\x*pale ladwati Ou, sèl de Ou menm.   
\q1
\v 17 O Bondye, Ou \x + \xo 71:17 \xt Det 4:5\x* te enstwi mwen depi jenès mwen.  
\q1 Jiska prezan, mwen toujou deklare mèvèy Ou yo.   
\q1
\v 18 Wi, menm lè m vye ak cheve blanch, O Bondye, pa abandone m,  
\q1 jiskaske mwen fin \x + \xo 71:18 \xt Sòm 22:31\x*deklare fòs Ou a jenerasyon sila a,  
\q1 ak pwisans Ou a tout sila k ap vini yo.   
\q1
\v 19 Paske ladwati Ou, O Bondye, rive jis nan syèl yo.  
\q1 Ou menm ki te fè gwo bagay yo.  
\q1 O Bondye, se \x + \xo 71:19 \xt Det 3:24\x*kilès ki tankou Ou menm?   
\q1
\v 20 Ou menm ki te fè m wè anpil twoub ak gwo pwoblèm,  
\q1 va fè m viv.  
\q1 Ou va mennen mwen monte soti nan \x + \xo 71:20 \xt Sòm 86:13\x*fon tè yo.   
\q1
\v 21 Ke Ou fè lonè mwen vin plis e vire ban m konsolasyon ankò.   
\q1
\v 22 Konsa, mwen va louwe Ou avèk ap la pou fidelite Ou, O Bondye mwen.  
\q1 A Ou menm, mwen va chante lwanj avèk gita,  
\q1 O \x + \xo 71:22 \xt II Wa 19:22\x*Sila Ki Sen an Israël la.   
\q1
\v 23 Lèv mwen va rele ak jwa lè mwen chante lwanj a Ou menm  
\q1 pou \x + \xo 71:23 \xt Sòm 34:22\x* nanm mwen ke Ou te rachte a.   
\q1
\v 24 Lang mwen, anplis, va pale ladwati Ou tout lajounen.  
\q1 Paske yo wont, yo imilye,  
\q1 Sila ki te chache fè m mal yo.   
\c 72  
\d Yon Sòm a Salomon  
\q1
\v 1 Bay a wa a \x + \xo 72:1 \xt I Wa 3:9\x* sajès lajistis Ou, O Bondye,  
\q1 ak ladwati Ou a fis a wa a.   
\q1
\v 2 Li va \x + \xo 72:2 \xt És 9:7\x* jije pèp Ou a avèk ladwati,  
\q1 e aflije Ou yo, avèk jistis.   
\q1
\v 3 Mòn yo va pote \x + \xo 72:3 \xt És 2:4\x* lapè a pèp la,  
\q1 e kolin yo, fwi ladwati a.   
\q1
\v 4 Li va jije malere a pèp la.  
\q1 Li va fè sekou pou pitit a malere yo,  
\q1 e kraze opresè a an mòso.   
\q1
\v 5 Yo va krent Ou \x + \xo 72:5 \xt Sòm 72:17\x* pou tout tan ke solèy la klere  
\q1 ak tout tan ke genyen lalin, pandan tout jenerasyon yo.   
\q1
\v 6 Li va desann \x + \xo 72:6 \xt Det 32:2\x* tankou lapli sou chan zèb fenk koupe yo,  
\q1 tankou farinaj ki wouze tè a.   
\q1
\v 7 Nan jou li yo, moun ladwati yo va fleri,  
\q1 avèk \x + \xo 72:7 \xt És 2:4 \x*lapè an abondans jiskaske lalin nan pa wè ankò.   
\q1
\v 8 Anplis, l ap renye jiskaske yon \x + \xo 72:8 \xt Egz 23:31\x* lanmè rive nan yon lòt lanmè a,  
\q1 e soti nan Rivyè a jis rive nan dènye pwent tè a.   
\q1
\v 9 Pèp ki abite nan dezè a va bese devan l,  
\q1 e lènmi li yo \x + \xo 72:9 \xt És 49:23\x* va niche pousyè a.   
\q1
\v 10 Wa a Tarsis yo avèk lil yo va pote kado.  
\q1 Wa a Séba avèk \x + \xo 72:10 \xt Jen 10:7 \x*Saba yo ap ofri kado.   
\q1
\v 11 Konsa, tout wa yo va bese ba devan l, pou tout \x + \xo 72:11 \xt Sòm 86:9\x*nasyon yo sèvi li.   
\q1
\v 12 Paske li va \x + \xo 72:12 \xt Job 29:12\x* delivre malere a lè l kriye sekou;  
\q1 aflije a tou, lè l san soutyen an.   
\q1
\v 13 Li va gen \x + \xo 72:13 \xt Pwov 19:17\x* mizerikòd sou malere a avèk endijan an.  
\q1 Konsa, lavi a pòv yo, li va sove.   
\q1
\v 14 Li va rachte lavi yo soti nan opresyon avèk vyolans,  
\q1 e san yo va chè nan zye Li.   
\q1
\v 15 Konsa, li va viv, e \x + \xo 72:15 \xt És 60:6\x* lò a Séba va bay a li menm.  
\q1 Moun va priye pou li san rete.  
\q1 Yo va beni li tout lajounen.   
\q1
\v 16 Va genyen anpil sereyal sou tout kolin peyi a,  
\q1 fwi li yo k ap vannen nan van tankou pye sèd a Liban yo.  
\q1 Sa ki nan vil yo va fleri tankou \x + \xo 72:16 \xt Job 5:25\x* vèdi latè.   
\q1
\v 17 Non li va dire jis pou tout tan.  
\q1 Non li va la \x + \xo 72:17 \xt Sòm 89:36 \x*toutotan solèy la ap briye a.  
\q1 Tout lèzòm va beni pa li.  
\q1 Tout nasyon yo va rele li beni.   
\b  
\q1
\v 18 Beni se SENYÈ Bondye a, Bondye Israël la!  
\q1 Li sèl ki fè mèvèy!   
\q1
\v 19 Beni se \x + \xo 72:19 \xt Né 9:5\x* non laglwa Li jis pou tout tan!  
\q1 Ke tout tè a kapab ranpli ak glwa Li!  
\q1 Amen e amen.   
\b  
\q1
\v 20 Priyè a David yo, fis a Jesse a fini.   
\c 73  
\ms1 LIV 3  
\d Yon Sòm Asaph  
\q1
\v 1 Anverite, Bondye bon a Israël,  
\q1 a sila avèk kè ki \x + \xo 73:1 \xt Sòm 24:4\x* san tach yo!   
\q1
\v 2 Men pou mwen, \x + \xo 73:2 \xt Sòm 94:18\x* pye m te prèt pou glise tonbe,  
\q1 Pa m yo te prèt pou chape.   
\q1
\v 3 Paske mwen te gen anvi awogan yo,  
\q1 lè m te wè jan \x + \xo 73:3 \xt Job 21:7\x*mechan yo te byen reyisi.   
\q1
\v 4 Paske nan lanmò yo, nanpwen soufrans e kò yo byen gra.   
\q1
\v 5 Yo pa nan pwoblèm tankou lòt moun,  
\q1 ni yo pa toumante tankou limanite.   
\q1
\v 6 Pou sa, yo pote ògèy tankou yon bèl \x + \xo 73:6 \xt Jen 41:42\x* kolye.  
\q1 Abiman vyolans kouvri kon yon bèl rad.   
\q1
\v 7 Zye yo anfle nan mitan \x + \xo 73:7 \xt Job 15:27\x* grès yo.  
\q1 Imajinasyon a kè yo dechennen nèt.   
\q1
\v 8 Yo \x + \xo 73:8 \xt Sòm 1:1\x* giyonnen moun.  
\q1 Ak mechanste, yo pale afè oprime lòt moun.  
\q1 Yo pale konsi se anwo sa soti.   
\q1
\v 9 Nan bouch \x + \xo 73:9 \xt Rev 13:6\x* yo rive nan syèl la,  
\q1 pandan lang yo fè gwo pwomnad sou tout latè.   
\q1
\v 10 Akoz sa a, pèp pa yo retounen kote yo,  
\q1 e yo kontinye bwè \x + \xo 73:10 \xt Sòm 23:5\x* gran sous yo nèt.   
\q1
\v 11 Yo di: “Kòman Bondye konnen?  
\q1 Eske gen konesans kote Pi Wo a?”   
\q1
\v 12 Gade byen, sila yo se mechan yo ye.  
\q1 Konsi, toujou \x + \xo 73:12 \xt Jr 49:31\x* alèz, yo te agrandi richès yo.   
\q1
\v 13 Anverite, \x + \xo 73:13 \xt Job 21:15\x* se an ven mwen te kenbe kè m san tach,  
\q1 ak lave men m nan inosans.   
\q1
\v 14 Paske mwen te twouble tout lajounen  
\q1 e te resevwa \x + \xo 73:14 \xt Job 33:9\x* chatiman chak maten.   
\q1
\v 15 Si mwen te di: “Mwen va pale konsa,”  
\q1 gade byen, mwen ta trayi \x + \xo 73:15 \xt Sòm 14:5\x* jenerasyon pitit Ou yo.   
\q1
\v 16 Lè m te \x + \xo 73:16 \xt Ekl 8:17\x* reflechi pou konprann sa, zye m pa t wè klè menm.   
\q1
\v 17 Men jis lè m te antre nan sanktyè Bondye a,  
\q1 mwen te vin konprann jan yo ta \x + \xo 73:17 \xt Sòm 37:38\x* fini.   
\q1
\v 18 Anverite, Ou te mete yo kote ki \x + \xo 73:18 \xt Sòm 35:6\x* glise anpil.  
\q1 Ou te jete yo ba jiskaske yo fini nèt.   
\q1
\v 19 Men kijan yo va \x + \xo 73:19 \xt Nonb 16:21\x* detwi nan yon enstan!  
\q1 Y ap bale nèt ale avèk gran perèz kap rive sibitman!   
\q1
\v 20 Tankou yon rèv lè moun leve, O SENYÈ,  
\q1 lè Ou leve, Ou va \x + \xo 73:20 \xt I Sam 2:30\x* meprize pwòp fòm yo.  
\q1 Ou va rayi rèv de lespri yo.   
\q1
\v 21 Lè kè m te vin anmè,  
\q1 e kè m te \x + \xo 73:21 \xt Trav 2:37 \x*pike anndan m,   
\q1
\v 22 alò, mwen te vin ensansib e san bon konprann.  
\q1 Mwen te tankou yon \x + \xo 73:22 \xt Job 18:3\x*bèt devan Ou.   
\q1
\v 23 Sepandan, \x + \xo 73:23 \xt Sòm 16:8\x* mwen avè W tout tan.  
\q1 Ou te kenbe men dwat mwen.   
\q1
\v 24 Avèk konsèy Ou, Ou va gide mwen,  
\q1 e apre, \x + \xo 73:24 \xt Jen 5:24\x*resevwa mwen nan laglwa.   
\q1
\v 25 \x + \xo 73:25 \xt Sòm 16:2\x* Se kilès mwen gen nan syèl la sof ke Ou?  
\q1 Epi anplis ke Ou, mwen pa vle anyen sou latè.   
\q1
\v 26 \x + \xo 73:26 \xt Sòm 38:10\x* Chè mwen avèk kè mwen kab fè fayit,  
\q1 men Bondye se fòs kè mwen ak pòsyon mwen jis pou tout tan.   
\q1
\v 27 Paske gade byen, sila ki lwen yo va \x + \xo 73:27 \xt Sòm 37:20\x* peri.  
\q1 Ou te detwi tout sila ki pa t fidèl a Ou menm yo.   
\q1
\v 28 Men pou mwen, rete pre Bondye se bonte mwen.  
\q1 Mwen te fè Senyè a, BONDYE a, \x + \xo 73:28 \xt Sòm 14:6\x*refij mwen,  
\q1 Pou m kab pale tout zèv Ou yo.   
\c 74  
\d Yon Sòm Asaph  
\q1
\v 1 O Bondye, poukisa Ou te rejte nou pou tout tan?  
\q1 Poukisa kòlè Ou \x + \xo 74:1 \xt Det 29:20\x* fè lafimen kont mouton patiraj Ou an?   
\q1
\v 2 Sonje asanble Ou a, ke Ou te achte depi tan ansyen yo,  
\q1 sa yo ke Ou te \x + \xo 74:2 \xt Egz 15:13\x*rachte pou fè tribi eritaj pa Ou:  
\q1 Mòn Sion sila a, kote Ou te abite.   
\q1
\v 3 Vire pa Ou yo pou rive kote mazi ki kraze nèt yo,  
\q1 kote lènmi a \x + \xo 74:3 \xt Sòm 79:1\x* fin fè tout mechanste li anndan sanktyè a.   
\q1
\v 4 Advèsè Ou yo te vin anraje nan mitan kote asanble Ou a.  
\q1 Yo fin monte \x + \xo 74:4 \xt Nonb 2:2\x* pwòp drapo yo kon avètisman an.   
\q1
\v 5 Yo aji kòn yon moun k ap  
\q1 leve \x + \xo 74:5 \xt Jr 46:22\x* rach li nan mitan yon forè bwa.   
\q1
\v 6 Epi koulye a, tout travay skilpti li yo, \x + \xo 74:6 \xt I Wa 6:18-35\x*  
\q1 yo kraze ak rach avèk mato.   
\q1
\v 7 Yo fin \x + \xo 74:7 \xt II Wa 25:9\x* brile sanktyè Ou a jis rive atè.  
\q1 Yo te souye abitasyon ki fèt nan non Ou an.   
\q1
\v 8 Yo te \x + \xo 74:8 \xt Sòm 83:4\x* pale nan kè yo: “Annou kraze yo nèt.”  
\q1 Yo te brile tout kote asanble Bondye nan tout peyi a.   
\q1
\v 9 Nou paz ankò wè mèvèy yo.  
\q1 \x + \xo 74:9 \xt I Sam 3:1\x*Nanpwen pwofèt ankò.  
\q1 Ni pa genyen pami nou ki konnen konbyen de tan sa va dire.   
\q1
\v 10 Konbyen de tan, O Bondye,  
\q1 advèsè a va moke nou ak mo brile?  
\q1 Èske se pou tout tan lènmi an va \x + \xo 74:10 \xt Lev 24:16\x*giyonnen non Ou konsa?   
\q1
\v 11 Poukisa Ou retire men Ou?  
\q1 Sitou men dwat Ou?  
\q1 Fè l parèt sòti anndan lestonmak Ou pou \x + \xo 74:11 \xt Sòm 59:13\x*detwi yo!   
\b  
\q1
\v 12 Men Bondye se \x + \xo 74:12 \xt Sòm 44:4\x* Wa mwen depi nan tan ansyen yo.  
\q1 Li te fè zèv delivrans nan mitan latè.   
\q1
\v 13 Ou te divize lanmè a ak fòs kouraj Ou.  
\q1 Ou te kraze tèt \x + \xo 74:13 \xt Sòm 148:7\x*gwo bèt lanmè yo.   
\q1
\v 14 Ou te kraze tèt \x + \xo 74:14 \xt Job 41:1\x* Levyatan an.  
\q1 Ou te bay li kon manje pou bèt sovaj.   
\q1
\v 15 Ou te fè pete sous ki koule dlo fre.  
\q1 Ou te seche gwo rivyè pwisan yo.   
\q1
\v 16 Jou yo se pou Ou, anplis, nwit yo se pou Ou.  
\q1 Ou te \x + \xo 74:16 \xt Jen 1:14-18\x* prepare limyè a avèk solèy la.   
\q1
\v 17 Ou te etabli tout lizyè latè yo.  
\q1 Ou te fè \x + \xo 74:17 \xt Det 32:8\x* sezon ete ak sezon livè.   
\b  
\q1
\v 18 Sonje bagay sa a, O SENYÈ,  
\q1 ke lènmi yo te meprize Ou,  
\q1 e \x + \xo 74:18 \xt Det 32:6\x* yon pèp ki plen ak foli te refize non Ou.   
\q1
\v 19 Pa livre nanm a toutrèl Ou a bèt sovaj yo.  
\q1 Pa bliye lavi aflije Ou yo pou tout tan.   
\q1
\v 20 Konsidere akò Ou, paske  
\q1 \x + \xo 74:20 \xt Sòm 88:6\x* kote fènwa yo nan tout latè a,  
\q1 plen ak abitasyon vyolans yo.   
\q1
\v 21 Pa kite \x + \xo 74:21 \xt Sòm 103:6\x* oprime yo retounen nan gwo wont.  
\q1 Kite aflije yo ak malere yo louwe Non Ou.   
\q1
\v 22 Leve, O Bondye! Plede koz Ou!  
\q1 Sonje jan \x + \xo 74:22 \xt Sòm 14:1\x* lòm plen foli meprize Ou tout lajounen.   
\q1
\v 23 Pa bliye vwa advèsè Ou yo.  
\q1 \x + \xo 74:23 \xt Sòm 65:7\x* Gwo zen a sila ki leve kont Ou yo monte tout tan, san rete.   
\b  
\c 75  
\d Pou direktè koral la; pou jwe a melodi “Pa Detwi”  
\d Yon Sòm Asaph, yon Chanson  
\q1
\v 1 Nou bay remèsiman a Ou menm, O Bondye,  
\q1 Nou bay remèsiman, paske Non Ou toupre.  
\q1 Moun yo fè deklarasyon \x + \xo 75:1 \xt Sòm 26:7\x*zèv mèvèy Ou yo.   
\b  
\q1
\v 2 “Lè Mwen menm fikse yon tan ki apwente,  
\q1 Mwen va \x + \xo 75:2 \xt Sòm 9:8\x*jije avèk jistis.   
\q1
\v 3 Latè avèk tout sa ki ladann souke.  
\q1 Se Mwen menm ki kenbe pilye li yo.” \qs Tan\qs*   
\q1
\v 4 Mwen te di a awogan yo: “Pa vin ògeye!”  
\q1 A mechan an: \x + \xo 75:4 \xt Za 1:21\x* “Pa leve kòn nan.   
\q1
\v 5 Pa leve kòn ou anwo.  
\q1 \x + \xo 75:5 \xt I Sam 2:3\x* Pa pale kou rèd avèk ògèy ensolan.”   
\q1
\v 6 Paske ni sòti nan lès, ni nan lwès,  
\q1 ni bò kote \x + \xo 75:6 \xt Sòm 3:3\x* dezè a,  
\q1 kab gen fòs pou leve moun anwo;   
\q1
\v 7 Men Bondye se jij la.  
\q1 Li \x + \xo 75:7 \xt Sòm 50:6\x* fè yon moun desann,  
\q1 e li leve yon lòt fè l wo.   
\q1
\v 8 Paske gen yon tas nan men SENYÈ a,  
\q1 e diven an ap kimen.  
\q1 Li byen mele e Bondye vide fè l sòti ladann.  
\q1 Anverite, \x + \xo 75:8 \xt Ab 16\x* tout mechan yo oblije bwè l jis rive nan dènye ti gout li.   
\b  
\q1
\v 9 Men pou mwen, mwen va \x + \xo 75:9 \xt Sòm 22:22\x* deklare sa, jis pou tout tan.  
\q1 Mwen va chante lwanj a Bondye Jacob la.   
\q1
\v 10 Tout kòn a mechan yo, Mwen va koupe fè yo sòti nèt.  
\q1 Men \x + \xo 75:10 \xt I Sam 2:1\x* kòn a moun ladwati yo va leve wo.   
\c 76  
\d Pou direktè koral la; sou enstriman ak kòd  
\d Yon Sòm Asaph, yon Chanson  
\q1
\v 1 Bondye byen rekonèt nan Juda.  
\q1 Non Li \x + \xo 76:1 \xt Sòm 99:3\x*gran an Israël.   
\q1
\v 2 Tabènak Li a nan Salem.  
\q1 \x + \xo 76:2 \xt Sòm 27:5\x* Abitasyon Li an osi nan Sion.   
\q1
\v 3 La, Li te \x + \xo 76:3 \xt Sòm 46:9\x* kase flèch dife yo,  
\q1 boukliye ak nepe ak zam lagè yo.   
\q1
\v 4 Ou manyifik, pi majeste pase mòn  
\q1 ak bèt lachas yo.   
\q1
\v 5 Sila ak \x + \xo 76:5 \xt És 10:12\x* gran kouraj yo te piyaje,  
\q1 yo te fonse tonbe nan dòmi mò a.  
\q1 Okenn nan gèrye yo ka sèvi men yo.   
\q1
\v 6 Nan repwòch Ou, O Bondye Jacob,  
\q1 ni \x + \xo 76:6 \xt Egz 15:1-21\x* chevalye yo ak cheval la te tonbe nan yon pwofon somèy.   
\q1
\v 7 Ou menm, Ou merite lakrent.  
\q1 Se \x + \xo 76:7 \xt Esd 9:15\x* kilès ki kab kanpe nan prezans Ou lè Ou fache?   
\q1
\v 8 Ou te fè jijman tande soti nan syèl la.  
\q1 Latè te \x + \xo 76:8 \xt I Kwo 16:30\x* krent, e te kanpe rete an plas   
\q1
\v 9 lè Bondye te leve nan jijman an,  
\q1 pou sove tout enb sou latè yo. \qs Tan\qs*   
\q1
\v 10 Paske kòlè a lòm va bay Ou glwa.  
\q1 Se retay kòlè pa W, ki sispann fè mal.   
\q1
\v 11 \x + \xo 76:11 \xt Ekl 5:4-6\x* Fè ve Ou yo a SENYÈ a, Bondye Ou a e akonpli yo.  
\q1 Kite tout sila ki antoure Li yo  
\q1 mennen don a Sila ki merite lakrent lan.   
\q1
\v 12 Li va koupe retire nanm a prens yo.  
\q1 Wa latè yo \x + \xo 76:12 \xt Sòm 47:2\x* gen lakrent Li.   
\c 77  
\d Pou direktè koral la: pou Jeduthun. Yon Sòm Asaph  
\q1
\v 1 Vwa m leve vè Bondye!  
\q1 Mwen \x + \xo 77:1 \xt Sòm 3:4\x* kriye pou sekou.  
\q1 Vwa m leve vè Bondye pou L tande mwen.   
\q1
\v 2 Nan \x + \xo 77:2 \xt Sòm 50:15\x* jou gwo twoub mwen an, mwen te chache SENYÈ a.  
\q1 Nan nwit, mwen te lonje men m san poze.  
\q1 Nanm mwen te refize rekonfòte.   
\q1
\v 3 Lè mwen sonje Bondye, alò, lespri m twouble.  
\q1 Mwen fè soupi; \x + \xo 77:3 \xt Sòm 61:2\x*lespri m febli nèt.   
\b  
\q1
\v 4 Ou te kenbe zye mwen yo louvri.  
\q1 Mwen tèlman twouble ke m \x + \xo 77:4 \xt Sòm 39:9\x* pa kab pale.   
\q1
\v 5 Mwen te reflechi sou \x + \xo 77:5 \xt Det 32:7\x* jou lansyen yo, ane lontan yo.   
\q1
\v 6 Chanson mwen, mwen va sonje pandan lannwit.  
\q1 Mwen \x + \xo 77:6 \xt Sòm 4:4\x* reflechi tout tan nan kè mwen.  
\q1 Lespri m reflechi jis rive nan fon kè m:   
\q1
\v 7 “Èske Senyè a va rejte nou pou tout tan?  
\q1 Èske Li \x + \xo 77:7 \xt Sòm 85:1-5\x*p ap janm kite favè Li vini sou nou ankò?   
\q1
\v 8 Èske lanmou dous Li a kite nou pou tout tan?  
\q1 Èske \x + \xo 77:8 \xt II Pi 3:9\x*pwomès Li yo fini nèt?   
\q1
\v 9 Èske Bondye te bliye gras Li,  
\q1 Oswa nan kòlè Li, èske Li te retire mizerikòd Li a?” \qs Tan\qs*   
\q1
\v 10 Epi mwen te di: “Se chagren mwen ki fè m panse  
\q1 \x + \xo 77:10 \xt Sòm 44:2-3\x* men dwat a Wo Pwisan an vin chanje.”   
\q1
\v 11 Mwen va sonje \x + \xo 77:11 \xt Sòm 105:5\x* zèv SENYÈ yo.  
\q1 Anverite, Mwen va sonje mèvèy Ou yo nan tan ansyen yo.   
\q1
\v 12 Mwen va \x + \xo 77:12 \xt Sòm 145:5\x* reflechi tout tan sou tout zèv Ou yo,  
\q1 pou m sonje nan kè m tout sa Ou te fè.   
\q1
\v 13 Chemen Ou a, O Bondye, se apa.  
\q1 \x + \xo 77:13 \xt Egz 15:11\x* Ki dye ki gran tankou Bondye pa nou an?   
\q1
\v 14 Ou se Bondye ki fè zèv mèvèy.  
\q1 Ou te fè pwisans Ou rekonèt pami pèp yo.   
\q1
\v 15 Avèk pwòp pouvwa Ou, Ou te \x + \xo 77:15 \xt Egz 6:6\x* rachte pèp Ou a,  
\q1 fis a Jacob yo avèk Joseph. \qs Tan\qs*   
\q1
\v 16 \x + \xo 77:16 \xt Egz 14:21\x* Dlo yo te wè Ou, O Bondye.  
\q1 Dlo yo te wè Ou.  
\q1 Yo te nan gran doulè.  
\q1 Anplis, fon yo te boulvèse.   
\q1
\v 17 \x + \xo 77:17 \xt Jij 5:4\x* Nwaj yo te vide gwo dlo.  
\q1 Syèl yo te bay gwo kout loray.  
\q1 Flèch Ou yo te limen pa isit e pa lòtbò.   
\q1
\v 18 \x + \xo 77:18 \xt Sòm 18:13\x* Bwi tonnè a eklate nan toubiyon an.  
\q1 Loray yo te klere tout tè a.  
\q1 Mond lan te tranble.  
\q1 Li te souke.   
\q1
\v 19 \x + \xo 77:19 \xt És 51:10\x* Chemen Ou an te nan lanmè a,  
\q1 e vwa Ou nan dlo pwisan yo.  
\q1 Kote Ou mache p ap kab dekouvri menm.   
\q1
\v 20 Ou te dirije pèp Ou a tankou yon bann,  
\q1 pa men \x + \xo 77:20 \xt Egz 6:26\x*Moïse avèk Aaron.   
\b  
\c 78  
\d Yon Sòm a Asaph  
\q1
\v 1 \x + \xo 78:1 \xt És 51:4\x* Koute, O pèp mwen an a lenstriksyon mwen.  
\q1 Panche zòrèy Ou vè pawòl a bouch mwen.   
\q1
\v 2 Mwen va \x + \xo 78:2 \xt Sòm 49:4\x* ouvri bouch mwen avèk yon parabòl.  
\q1 Mwen va pale pawòl fonse a tan ansyen yo,   
\q1
\v 3 ke nou te tande, konnen e ke  
\q1 \x + \xo 78:3 \xt Sòm 44:1\x* papa zansèt nou yo te fè nou konprann.   
\q1
\v 4 Nou p ap kache yo a pitit nou yo,  
\q1 men nou va \x + \xo 78:4 \xt Egz 13:8\x*pale a jenerasyon k ap vini yo, tout lwanj SENYÈ a,  
\q1 fòs Li ak gran mèvèy ke Li te konn fè yo.   
\q1
\v 5 Paske Li te etabli yon temwayaj  
\q1 nan Jacob e te chwazi yon lwa an Israël,  
\q1 sou sila Li te kòmande papa zansèt nou yo  
\q1 pou yo ta \x + \xo 78:5 \xt Det 4:9\x* enstwi yo a pitit pa yo.   
\q1
\v 6 Ke jenerasyon k ap vini an ta kab konnen.  
\q1 Menm pou sila ki poko fèt yo,  
\q1 pou yo ta kab leve e \x + \xo 78:6 \xt Det 11:19\x* pale yo a pitit yo,   
\q1
\v 7 pou yo kab mete konfyans yo  
\q1 nan Bondye e pa bliye zèv Bondye yo,  
\q1 men \x + \xo 78:7 \xt Det 4:2 \x*kenbe kòmandman Li yo.   
\q1
\v 8 Pou yo \x + \xo 78:8 \xt II Wa 17:14\x* pa fè tankou papa zansèt yo,  
\q1 yon jenerasyon tèt di e rebèl,  
\q1 yon jenerasyon ki pa t gen kè fidèl,  
\q1 ki pa t gen lespri fidèl a Bondye.   
\q1
\v 9 Fis a Éphraïm yo ki konn tire flèch, te pote banza yo.  
\q1 Sepandan, nan jou batay la, \x + \xo 78:9 \xt Jij 20:39\x* yo te fè bak.   
\q1
\v 10 Yo \x + \xo 78:10 \xt Jij 2:20\x* pa t kenbe akò yo ak Bondye  
\q1 e te refize mache nan lalwa Li.   
\q1
\v 11 Yo te \x + \xo 78:11 \xt Sòm 106:13\x* bliye zèv Li yo avèk mirak ke Li te montre yo.   
\q1
\v 12 Li te fòje mirak yo devan zansèt yo,  
\q1 nan peyi Égypte la ak nan \x + \xo 78:12 \xt Nonb 13:22\x*chan Tsoan an.   
\q1
\v 13 Li te divize lanmè a e te fè yo pase ladann.  
\q1 Li te fè dlo yo \x + \xo 78:13 \xt Egz 15:8\x*kanpe wo tankou yon gwo pil.   
\q1
\v 14 Apre, Li te dirije yo avèk nwaj  
\q1 nan lajounen e nan tout nwit lan avèk \x + \xo 78:14 \xt Egz 14:24\x* limyè dife.   
\q1
\v 15 Li te \x + \xo 78:15 \xt Egz 17:6\x* fann wòch yo nan dezè a  
\q1 e te bay yo anpil dlo pou bwè tankou nan fon yo.   
\q1
\v 16 Li te \x + \xo 78:16 \xt Nonb 20:8\x* fè parèt sous ki te pete sòti nan wòch la,  
\q1 e te fè dlo desann tankou larivyè.   
\q1
\v 17 Sepandan, yo te kontinye peche kont Li,  
\q1 e fè \x + \xo 78:17 \xt Det 9:22\x* rebèl kont Pi Wo a nan dezè a.   
\q1
\v 18 Konsa, nan kè yo, yo te pase Bondye a leprèv  
\q1 lè yo te mande \x + \xo 78:18 \xt Nonb 11:4\x*manje selon dezi yo.   
\q1
\v 19 Wi, yo te pale kont Bondye.  
\q1 Yo te di: \x + \xo 78:19 \xt Egz 16:3\x* “Èske Bondye kapab prepare yon tab nan dezè a?   
\q1
\v 20 Gade byen, Li te frape wòch la pou dlo  
\q1 kouri sòti e gwo sous yo t ap debòde.  
\q1 Èske Li kapab bay pen tou?  
\q1 Èske Li kab \x + \xo 78:20 \xt Nonb 11:18\x*founi vyann pou pèp Li a?”   
\q1
\v 21 Pou sa, SENYÈ a te tande e te \x + \xo 78:21 \xt Nonb 11:1\x* ranpli ak kòlè.  
\q1 Konsa, yon dife te limen kont Jacob,  
\q1 e chalè te monte tou kont Israël.   
\q1
\v 22 Paske yo \x + \xo 78:22 \xt Det 1:32\x* pa t kwè nan Bondye,  
\q1 e pa t mete konfyans yo nan delivrans Li.   
\q1
\v 23 Men Li te kòmande nwaj anlè yo, e te \x + \xo 78:23 \xt Jen 7:11\x* louvri pòt syèl yo.   
\q1
\v 24 Li te fè lamàn vin tonbe tankou lapli sou yo,  
\q1 pou yo manje e te bay yo manje soti nan syèl la.   
\q1
\v 25 Lòm te manje manje a zanj yo.  
\q1 Li te voye manje ba yo an abondans.   
\q1
\v 26 Li te \x + \xo 78:26 \xt Nonb 11:31\x* fè van lès la vante nan syèl yo e avèk pwisans Li,  
\q1 Li te dirije van sid la.   
\q1
\v 27 Li te fè tonbe vyann sou yo tankou lapli, tankou pousyè,  
\q1 menm \x + \xo 78:27 \xt Egz 16:13\x* zwazo ak zèl tankou sab lanmè.   
\q1
\v 28 Alò, Li te kite yo tonbe nan mitan kan an, toupatou abitasyon yo.   
\q1
\v 29 Konsa, yo te \x + \xo 78:29 \xt Nonb 11:19-20\x* manje vant plen,  
\q1 e sa yo te mande, se sa Li te bay yo.   
\q1
\v 30 Avan, yo te satisfè dezi yo,  
\q1 \x + \xo 78:30 \xt Nonb 11:33\x* pandan manje a te toujou nan bouch yo,   
\q1
\v 31 \x + \xo 78:31 \xt Nonb 11:33-34\x* kòlè Bondye te leve kont yo e  
\q1 te touye kèk nan pi vanyan pami yo.  
\q1 Li te frape desann mesye pi chwazi Israël yo.   
\q1
\v 32 Malgre tout sa, yo te peche toujou,  
\q1 e pa t kwè nan zèv mèvèy Li yo.   
\q1
\v 33 Akoz sa, Li te fè \x + \xo 78:33 \xt Nonb 14:29-35\x* jou yo fini mal,  
\q1 e ane yo nan laperèz sibit.   
\q1
\v 34 Lè Li te touye yo, nan lè sa a, yo te \x + \xo 78:34 \xt Nonb 21:7\x* chache Li.  
\q1 Yo te retounen chache Li ak dilijans.   
\q1
\v 35 Konsa, yo te sonje ke Bondye te wòch yo, e Pi Wo a, \x + \xo 78:35 \xt Egz 15:13 \x*redanmtè yo.   
\q1
\v 36 Men yo te \x + \xo 78:36 \xt Egz 24:7-8\x* twonpe Li ak bouch yo.  
\q1 Yo te manti a Li ak lang yo.   
\q1
\v 37 Paske kè yo pa t \x + \xo 78:37 \xt Sòm 51:10\x* fèm vè Li menm,  
\q1 ni yo pa t fidèl selon akò Li.   
\q1
\v 38 Men Li menm, akoz mizerikòd Li,  
\q1 te padone inikite yo, e pa t detwi yo.  
\q1 Wi, souvan Li te ralanti kòlè Li e pa t kite tout kòlè li vin leve.   
\q1
\v 39 Konsa, Li te sonje ke se sèl chè yo te ye,  
\q1 yon \x + \xo 78:39 \xt Job 7:7-16 \x*van pase ki pa retounen ankò.   
\q1
\v 40 Konbyen fwa yo te fè rebèl kont Li nan dezè a,  
\q1 e te \x + \xo 78:40 \xt Sòm 95:10\x*fè L soufri lapèn la nan savann nan!   
\q1
\v 41 Anpil fwa, yo te pase Bondye a \x + \xo 78:41 \xt Nonb 14:22\x* leprèv,  
\q1 epi te fè Sila Ki Sen A Israël la soufri doulè.   
\q1
\v 42 Yo \x + \xo 78:42 \xt Jij 8:34\x* pa t sonje pwisans Li,  
\q1 ni jou ke Li te delivre yo nan men advèsè yo,   
\q1
\v 43 lè Li te akonpli mirak Li yo an Égypte  
\q1 ak \x + \xo 78:43 \xt Egz 4:21\x*mèvèy Li yo nan chan Tsoan an.   
\q1
\v 44 Li te chanje rivyè yo an san.  
\q1 Konsa, nan sous yo, yo pa t kab bwè.   
\q1
\v 45 Li te voye pami yo mouch  
\q1 an gran kantite ki te devore yo,  
\q1 avèk \x + \xo 78:45 \xt Egz 8:6\x*krapo ki te detwi yo.   
\q1
\v 46 Li te bay chan rekòlt a chwalbwa a,  
\q1 ak pwodwi travay yo a \x + \xo 78:46 \xt Egz 10:14\x* krikèt la.   
\q1
\v 47 Li te detwi chan fwi yo ak \x + \xo 78:47 \xt Egz 9:23-25\x* lagrèl e bwa sikomò yo ak fredi.   
\q1
\v 48 Li te bay \x + \xo 78:48 \xt Egz 9:19\x* bèt yo tou a lagrèl e twoupo yo a loray.   
\q1
\v 49 Li te \x + \xo 78:49 \xt Egz 15:7\x* voye sou yo chalè kòlè Li,  
\q1 gwo kòlè avèk endiyasyon ak twoub,  
\q1 ak yon bann zanj ki pou detwi yo.   
\q1
\v 50 Li te fè yon chemen pou lakòlè Li.  
\q1 Li pa t epagne nanm yo de lanmò,  
\q1 men te \x + \xo 78:50 \xt Egz 12:29-30\x* bay lavi yo a gwo fleyo.   
\q1
\v 51 Li te frape di tout premye ne an Égypte yo,  
\q1 premye sòti a fòs kouraj yo nan tant a Cham yo.   
\q1
\v 52 Men Li te mennen fè sòti pwòp pèp li a tankou mouton.  
\q1 Li te dirije yo nan dezè a \x + \xo 78:52 \xt Sòm 77:20 \x*tankou yon twoupo.   
\q1
\v 53 Li te dirije yo avèk swen pou yo pa pè, men \x + \xo 78:53 \xt Egz 14:27-28 \x*lanmè te vale lènmi yo.   
\q1
\v 54 Konsa, \x + \xo 78:54 \xt Egz 15:7\x* Li te mennen yo nan peyi sen Li an,  
\q1 vè peyi ti kolin ke men dwat Li te vin posede a.   
\q1
\v 55 Anplis, li te chase nasyon yo devan yo,  
\q1 te pataje pou yo yon eritaj selon mezi li, e  
\q1 te fè tribi Israël yo abite nan tant yo.   
\q1
\v 56 Sepandan, yo te tante e \x + \xo 78:56 \xt Jij 2:11-13\x* fè rebèl kont Bondye Pi Wo a,  
\q1 e pa t kenbe temwayaj Li yo,   
\q1
\v 57 men te vire fè bak e te aji nan malveyans tankou papa zansèt yo.  
\q1 Yo te vire akote tankou yon banza ki tòde.   
\q1
\v 58 Paske yo te pwovoke Li avèk \x + \xo 78:58 \xt Lev 26:30\x* wo plas yo,  
\q1 e te fè L jalou avèk imaj taye yo.   
\q1
\v 59 Lè Bondye te tande, Li te vin ranpli avèk kòlè,  
\q1 e te \x + \xo 78:59 \xt Lev 26:30\x*vin deteste Israël anpil.   
\q1
\v 60 Jiskaske Li te abandone abitasyon  
\q1 Silo, tant ke li te konn monte pami lòm nan,   
\q1
\v 61 e te bay yo menm ki te fòs Li, an kaptivite,  
\q1 glwa Li nan men advèsè a.   
\q1
\v 62 Anplis, Li te livre pèp Li a de nepe e  
\q1 te vin ranpli avèk kòlè kont eritaj Li a.   
\q1
\v 63 Dife te devore jennonm Li yo e  
\q1 \x + \xo 78:63 \xt Jr 7:34\x*vyèj Li yo pa t gen chan maryaj.   
\q1
\v 64 \x + \xo 78:64 \xt I Sam 4:17\x* Prèt Li yo te tonbe pa nepe e  
\q1 Vèv Li yo pa t kab kriye.   
\q1
\v 65 Konsa, SENYÈ a te leve tankou se nan dòmi Li te ye,  
\q1 tankou yon \x + \xo 78:65 \xt És 42:13\x* gèrye ki rele fò akoz diven.   
\q1
\v 66 Li \x + \xo 78:66 \xt I Sam 5:6\x* te pouse advèsè Li yo fè bak.  
\q1 Li te mete sou yo yon repwòch ki pa t ap fini menm.   
\q1
\v 67 Anplis, Li te \x + \xo 78:67 \xt Sòm 78:60\x* rejte tant Joseph la,  
\q1 ni pa t chwazi tribi Éphraïm nan.   
\q1
\v 68 Men Li te chwazi tribi Juda a,  
\q1 Mòn \x + \xo 78:68 \xt Sòm 87:2\x* Sion ke Li te renmen anpil la.   
\q1
\v 69 Li te \x + \xo 78:69 \xt I Wa 6:1-38\x* bati sanktyè Li tankou wotè mòn yo,  
\q1 tankou latè ke Li te etabli jis pou tout tan an.   
\q1
\v 70 Anplis, Li te chwazi David, sèvitè Li a.  
\q1 Li te pran l sòti nan Pak mouton yo,   
\q1
\v 71 sòti nan okipe mouton k ap fè pitit, avèk ti mouton nouris,  
\q1 Li te mennen li, pou vin bèje Jacob, pèp Li a,  
\q1 avèk \x + \xo 78:71 \xt I Sam 10:1\x*Israël, eritaj Li a.   
\q1
\v 72 Konsa, Li te fè bèje yo selon \x + \xo 78:72 \xt I Wa 9:4\x* entegrite kè l,  
\q1 e te gide yo avèk men abil li.   
\c 79  
\d Yon Sòm Asaph  
\q1
\v 1 O Bondye, nasyon yo te anvayi eritaj Ou a.  
\q1 Yo te souye sen tanp Ou an.  
\q1 Yo te fè Jérusalem kouche nan yon pil ranblè.   
\q1
\v 2 Yo te bay kadav sèvitè Ou yo kon manje pou zwazo syèl yo.  
\q1 Chè a fidèl Ou yo, yo fin bay a bèt latè yo.   
\q1
\v 3 Yo te vide san yo tankou dlo toupatou Jérusalem.  
\q1 \x + \xo 79:3 \xt Jr 14:16\x* Pa t genyen moun ki pou antere yo.   
\q1
\v 4 Nou gen tan vin yon repwòch pou vwazen nou yo,  
\q1 Yon rizib ak yon betiz pou sila ki antoure nou yo.   
\q1
\v 5 Jiskilè, O SENYÈ?  
\q1 Èske Ou va rete fache nèt?  
\q1 Èske jalouzi Ou va \x + \xo 79:5 \xt Sòm 89:46 \x*brile tankou dife tout tan?   
\q1
\v 6 \x + \xo 79:6 \xt Sòm 69:24\x* Vide kòlè Ou sou nasyon ki pa rekonèt Ou yo,  
\q1 ak sou wayòm yo ki pa rele non Ou yo.   
\q1
\v 7 Paske yo te \x + \xo 79:7 \xt Sòm 53:4\x* devore Jacob.  
\q1 Yo te devaste abitasyon Li an.   
\q1
\v 8 \x + \xo 79:8 \xt Sòm 106:6\x* Pa sonje inikite a papa zansèt nou yo pou kenbe kont nou.  
\q1 Kite mizerikòd Ou vini vit rankontre nou,  
\q1 paske nou fin rive ba nèt.   
\q1
\v 9 \x + \xo 79:9 \xt II Kwo 14:11\x* Fè nou sekou, O Bondye sali nou an, pou glwa a non Ou.  
\q1 Delivre nou e padone peche nou yo, pou koz a non Ou.   
\q1
\v 10 \x + \xo 79:10 \xt Sòm 42:10\x* Poukisa nasyon yo ta di: “Kote Bondye yo ye?”  
\q1 Kite li vin rekonèt pami nasyon yo devan zye nou,  
\q1 ke vanjans pou san sèvitè Ou yo ap vèse.   
\q1
\v 11 Kite \x + \xo 79:11 \xt Sòm 102:20\x* vwa prizonye k ap plenyen yo rive devan Ou.  
\q1 Selon grandè fòs Ou, prezève sila ki kondane a lamò.   
\q1
\v 12 Fè remèt a vwazen nou yo, \x + \xo 79:12 \xt Jen 4:15\x* sèt fwa  
\q1 antre nan vant yo, repwòch avèk sila  
\q1 yo te repwoche Ou a, O SENYÈ.   
\q1
\v 13 Konsa nou menm, pèp Ou a,  
\q1 ak \x + \xo 79:13 \xt Sòm 74:1\x* mouton a patiraj Ou a,  
\q1 Va bay Ou remèsiman jis pou tout tan.  
\q1 A tout jenerasyon yo, nou va pale lwanj Ou.   
\c 80  
\d Pou direktè koral la; pou jwe a “Lis Akò Yo”. Yon Sòm Asaph  
\q1
\v 1 O prete zòrèy Ou, Bèje Israël la,  
\q1 Ou menm ki mennen Joseph tankou yon twoupo,  
\q1 Ou menm ki \x + \xo 80:1 \xt Egz 25:22\x* chita sou twòn anwo cheriben yo, se pou ou briye.   
\q1
\v 2 Devan Éphraïm avèk Benjamin ak Manassé, fè vire tout fòs Ou.  
\q1 Vin bannou sekou!   
\q1
\v 3 O Bondye, restore nou!  
\q1 \x + \xo 80:3 \xt Nonb 6:25\x*Fè vizaj Ou briye sou nou  
\q1 e nou va sove.   
\b  
\q1
\v 4 O Bondye dèzame yo,  
\q1 \x + \xo 80:4 \xt Sòm 79:5\x* pou konbyen de tan Ou va fache kont lapriyè a pèp Ou a?   
\q1
\v 5 Ou te bay yo \x + \xo 80:5 \xt Sòm 42:3\x* pen fèt ak dlo ki t ap sòti nan zye yo.  
\q1 Ou te fè yo bwè dlo a zye yo an gran kantite.   
\q1
\v 6 Ou fè nou vin yon objè konfli devan \x + \xo 80:6 \xt Sòm 44:13\x* vwazen nou yo.  
\q1 Lènmi nou yo ri pami yo menm.   
\q1
\v 7 O Bondye dèzame yo, restore nou!  
\q1 Fè vizaj Ou klere sou nou e nou va sove.   
\b  
\q1
\v 8 Ou te rachte yon pye rezen soti an Égypte.  
\q1 Ou te chase mete nasyon yo deyò pou te \x + \xo 80:8 \xt Jr 11:17\x*plante li la.   
\q1
\v 9 Ou te netwaye tè a devan l.  
\q1 Li te \x + \xo 80:9 \xt Os 14:5\x*anrasine byen fon e te ranpli peyi a.   
\q1
\v 10 Mòn yo te kouvri ak lonbraj li.  
\q1 \x + \xo 80:10 \xt Jen 49:22\x* Branch li yo te kon bwa sèd Bondye yo.   
\q1
\v 11 Li te voye branch li yo rive \x + \xo 80:11 \xt Sòm 72:8\x* jis nan lanmè,  
\q1 ak boujon li yo jis nan Rivyè a.   
\q1
\v 12 Poukisa Ou te \x + \xo 80:12 \xt Sòm 89:40\x* kraze tout kloti li yo,  
\q1 pou tout sila ki pase la yo kab rekòlte fwi li yo?   
\q1
\v 13 Yon gwo mal kochon sovaj sòti nan forè pou manje ladann  
\q1 e bèt sovaj chan an manje sou li.   
\q1
\v 14 O Bondye dèzame yo, vire fè bak depi koulye a,  
\q1 nou sipliye Ou, souple.  
\q1 \x + \xo 80:14 \xt Sòm 102:19\x*Gade soti anwo nan syèl la pou wè,  
\q1 e okipe pye rezen sila a.   
\q1
\v 15 Menm boujon ke men dwat Ou te plante a,  
\q1 e branch ke Ou te bay fòs pou Ou menm nan.   
\q1
\v 16 Li fin brile ak dife.  
\q1 Li fin koupe atè nèt.  
\q1 Yo peri ak repwòch devan Ou.   
\q1
\v 17 Kite \x + \xo 80:17 \xt Sòm 89:21\x* men Ou rete sou nonm nan  
\q1 ki se moun men dwat Ou a,  
\q1 sou fis a lòm ke ou te fè pwisan pou Ou menm nan.   
\q1
\v 18 Konsa, nou p ap vire fè bak kite Ou.  
\q1 Fè nou leve ankò e nou va rele non Ou.   
\q1
\v 19 O SENYÈ dezame yo, restore nou.  
\q1 Fè figi Ou briye sou nou e nou va sove.   
\c 81  
\d Pou direktè koral la; pou jwe sou Gitia la. Yon Sòm Asaph  
\q1
\v 1 Chante avèk jwa a Bondye ki se fòs nou!  
\q1 Rele fò ak jwa a \x + \xo 81:1 \xt Sòm 84:8\x*Bondye a Jacob la!   
\q1
\v 2 Leve yon chan, bat \x + \xo 81:2 \xt Egz 15:20\x* tanbouren an,  
\q1 gita ak son ki dous la ansanm avèk ap la.   
\q1
\v 3 Sone twonpèt la nan nouvèl lin nan,  
\q1 sou plèn lin nan, nan jou \x + \xo 81:3 \xt Lev 23:24\x*fèt nou an.   
\q1
\v 4 Paske se yon règleman Israël,  
\q1 yon òdonans a Bondye Jacob la.   
\q1
\v 5 Li te etabli li kon yon temwayaj nan Joseph  
\q1 lè li te \x + \xo 81:5 \xt Egz 11:4\x* ale toupatou nan peyi Égypte la.  
\q1 Mwen te tande yon lang ke M pa t konnen.   
\q1
\v 6 Mwen te retire fado a sou zepòl li.  
\q1 Men li yo te vin lib panyen an.   
\q1
\v 7 Ou te \x + \xo 81:7 \xt Egz 2:23\x* rele nan twoub la e Mwen  
\q1 te fè ou sekou.  
\q1 Mwen te reponn Ou nan plas kote tonnè a kache a.  
\q1 Mwen te fè ou pase eprèv nan dlo Meriba yo. \qs Tan\qs*   
\b  
\q1
\v 8 Tande, O pèp Mwen an e Mwen va korije nou.  
\q1 O Israël, si ou \x + \xo 81:8 \xt Sòm 95:7\x* ta koute Mwen!   
\q1
\v 9 Pa kite okenn dye etranje rete pami nou.  
\q1 Ni nou pa pou adore okenn dye etranje.   
\q1
\v 10 \x + \xo 81:10 \xt Egz 20:2\x* Mwen menm, SENYÈ a, se Bondye nou an,  
\q1 ki te mennen nou sòti nan peyi Égypte la.  
\q1 Ouvri bouch nou byen laj e mwen va ranpli li.   
\q1
\v 11 Men pèp Mwen an \x + \xo 81:11 \xt Det 32:15\x* pa t koute vwa M.  
\q1 Ni Israël pa t obeyi Mwen.   
\q1
\v 12 Akoz sa, Mwen te \x + \xo 81:12 \xt Job 8:4\x* lage yo a kè di yo,  
\q1 pou mache nan pwòp manèv yo.   
\q1
\v 13 O ke pèp Mwen an ta koute Mwen,  
\q1 ke Israël ta \x + \xo 81:13 \xt Sòm 128:1\x* mache nan vwa Mwen yo!   
\q1
\v 14 Mwen ta \x + \xo 81:14 \xt Sòm 18:47\x* soumèt lènmi yo byen vit  
\q1 e ta vire men m kont advèsè yo.   
\q1
\v 15 \x + \xo 81:15 \xt Wo 1:30\x* Sila ki rayi SENYÈ yo ta tresayi devan Li menm  
\q1 e pinisyon yo ta pou tout tan.   
\q1
\v 16 Men ou menm, Mwen ta nouri ou avèk \x + \xo 81:16 \xt Det 32:14\x* pi bon kalite ble a.  
\q1 Avèk siwo ki sòti nan wòch, Mwen ta satisfè ou.   
\c 82  
\d Yon Sòm Asaph  
\q1
\v 1 Bondye vin kanpe nan mitan pwòp asanble Li a.  
\q1 Li fè jijman nan mitan \x + \xo 82:1 \xt Egz 21:6\x*dye yo.   
\q1
\v 2 Pou konbyen de tan nou va jije san jistis,  
\q1 e \x + \xo 82:2 \xt Det 1:17\x*montre favè a mechan yo?   
\b  
\q1
\v 3 “Fè defans fèb yo ak òfelen yo.  
\q1 Fè jistis a aflije ak malere yo.   
\q1
\v 4 \x + \xo 82:4 \xt Job 29:12\x* Sove fèb yo ak malere yo.  
\q1 Delivre fè yo sòti nan men a mechan yo.”   
\q1
\v 5 Yo pa konnen ni yo pa konprann.  
\q1 Yo \x + \xo 82:5 \xt Pwov 2:13\x*mache toupatou nan fènwa.  
\q1 Tout fondasyon tè yo fin souke nèt.   
\q1
\v 6 Mwen \x + \xo 82:6 \xt Sòm 82:1\x* te di: “Se dye ke nou ye,  
\q1 e nou tout se fis a Pi Wo a.   
\q1
\v 7 Sepandan, \x + \xo 82:7 \xt Job 21:32\x* nou va mouri tankou moun,  
\q1 e tonbe tankou nenpòt nan prens yo.”   
\q1
\v 8 Leve, O Bondye, jije tè a!  
\q1 Paske se Ou ki \x + \xo 82:8 \xt Sòm 2:8\x*posede tout nasyon yo.   
\c 83  
\d Yon Chan. Yon Sòm Asaph  
\q1
\v 1 O Bondye, \x + \xo 83:1 \xt Sòm 28:1\x* pa rete an silans.  
\q1 Pa fè silans, O Bondye.  
\q1 Pa rete trankil.   
\q1
\v 2 Paske gade byen, lènmi Ou yo ap fè zen.  
\q1 Sila ki rayi Ou yo leve tèt yo byen wo.   
\q1
\v 3 Yo fè plan malen kont pèp Ou a.  
\q1 Yo fè konplo ansanm kont sila ki se trezò Ou.   
\q1
\v 4 Yo te di: “Vini, \x + \xo 83:4 \xt Est 3:6\x* annou disparèt yo nèt kon nasyon,  
\q1 pou non Israël la pa sonje ankò menm.”   
\q1
\v 5 Paske yo te \x + \xo 83:5 \xt Sòm 2:2\x* fè konplo ansanm ak yon sèl panse.  
\q1 Kont Ou menm, yo fè yon akò.   
\q1
\v 6 Tant a Édom avèk Izmayelit yo, Moab ak Agarenyen yo,   
\q1
\v 7 Guebal, Ammon, Amalek, Filisten yo avèk pèp Tyr yo;   
\q1
\v 8 Anplis, Asiryen yo te vin jwenn ansanm avèk yo,  
\q1 yo te prete lamen a \x + \xo 83:8 \xt Det 2:9\x* pitit a Lot yo. \qs Tan\qs*   
\q1
\v 9 Aji avèk yo \x + \xo 83:9 \xt Jij 7:1-24\x* tankou Madian,  
\q1 tankou avèk Sisera ak Jabin nan ravin Kison an!   
\q1
\v 10 Ki te fin detwi nan En-Dor,  
\q1 ki te \x + \xo 83:10 \xt So 1:17\x* vin tankou fimye sou latè.   
\q1
\v 11 Fè tout chèf yo tankou Oreb avèk Zeeb  
\q1 e tout prens yo tankou \x + \xo 83:11 \xt Jij 8:12-21 \x*Zébach avèk Tsalmunna,   
\q1
\v 12 Ki te di: \x + \xo 83:12 \xt II Kwo 20:11\x* “Annou vin posede patiraj Bondye yo pou kont nou.”   
\q1
\v 13 O Bondye mwen, fè yo tankou pousyè toubiyon!  
\q1 Tankou pay devan van!   
\q1
\v 14 Tankou \x + \xo 83:14 \xt És 9:18\x* dife ki brile forè a, ak flanm ki  
\q1 limen nan tout mòn nan pou yo brile nèt.   
\q1
\v 15 Konsa, kouri dèyè yo \x + \xo 83:15 \xt Job 9:17\x* avèk tanpèt Ou  
\q1 e teworize yo ak gwo siklòn Ou.   
\q1
\v 16 \x + \xo 83:16 \xt Job 10:15\x* Plen figi yo ak gwo wont,  
\q1 pou yo kab chache non pa Ou, O SENYÈ.   
\q1
\v 17 Kite yo vin \x + \xo 83:17 \xt Sòm 35:4\x* wont e dekouraje jis pou tout tan.  
\q1 Wi, kite yo imilye e peri,   
\q1
\v 18 pou yo kapab konnen ke se Ou menm sèl  
\q1 ki pote non “Bondye”, \x + \xo 83:18 \xt Sòm 9:2 \x*Pi Wo sou tout tè a.   
\c 84  
\d Pou direktè koral la; sou gitia la. Yon Sòm a fis a Koré yo.  
\q1
\v 1 A la abitasyon Ou yo bèl, O SENYÈ dèzame yo!   
\q1
\v 2 \x + \xo 84:2 \xt Sòm 42:1-2\x* Nanm mwen anvi e menm gen gwo dezi pou lakou SENYÈ a.  
\q1 Kè m ak chè m chante avèk jwa a Bondye vivan an.   
\q1
\v 3 Zwazo a osi te twouve yon kay, e  
\q1 iwondèl la yon nich pou li menm,  
\q1 kote li kapab swaye pitit li yo pre lotèl Ou yo,  
\q1 Oh Wa m ak Bondye m.   
\q1
\v 4 A la \x + \xo 84:4 \xt Sòm 65:4\x* beni sila ki demere nan lakay Ou yo beni!  
\q1 Y ap ba Ou lwanj jis pou tout tan.   
\q1
\v 5 A la beni nonm ki \x + \xo 84:5 \xt Sòm 81:1\x* gen fòs li nan Ou,  
\q1 Nan kè a sila lide fè wout nan gran chemen vè Sion an ye.   
\q1
\v 6 Lè yo pase nan vale Baca a, yo fè l fè yon sous;  
\q1 \x + \xo 84:6 \xt Sòm 107:35\x* Premye lapli a kouvri li avèk benediksyon.   
\q1
\v 7 Yo sòti nan fòs pou antre nan fòs yo.  
\q1 Yo chak parèt devan Bondye nan Sion.   
\q1
\v 8 O SENYÈ dèzame yo, tande lapriyè mwen.  
\q1 Prete zorèy Ou, O \x + \xo 84:8 \xt Sòm 81:1\x* Bondye Jacob la! \qs Tan\qs*   
\q1
\v 9 Gade byen boukliye nou an.  
\q1 Gade sou vizaj \x + \xo 84:9 \xt I Sam 16:6\x* onksyone Ou a.   
\q1
\v 10 Paske \x + \xo 84:10 \xt Sòm 27:4\x* yon sèl jou nan lakou Ou a,  
\q1 pi bon pase mil jou deyò.  
\q1 Pito m te jeran pòt lakay Bondye mwen an,  
\q1 pase pou m ta abite nan tant a mechan yo.   
\q1
\v 11 Paske SENYÈ a, Bondye a, se \x + \xo 84:11 \xt És 60:19-20\x* yon solèy ak yon boukliye.  
\q1 SENYÈ a va bay gras avèk glwa.  
\q1 Li pa refize anyen ki bon a sila ki mache dwat yo.   
\q1
\v 12 O SENYÈ dèzame yo!  
\q1 A la moun ki mete konfyans li nan Ou a beni!   
\c 85  
\d Pou direktè koral la; Yon Sòm a fis a Koré yo  
\q1
\v 1 O SENYÈ, Ou te montre favè Ou a peyi Ou a.  
\q1 Ou te \x + \xo 85:1 \xt Egz 1:11\x* restore kaptivite a Jacob la.   
\q1
\v 2 Ou te \x + \xo 85:2 \xt Nonb 14:19\x* padone inikite a pèp Ou a.  
\q1 Ou te kouvri tout peche yo.   
\q1
\v 3 Ou te retire tout gran kòlè Ou.  
\q1 Ou te \x + \xo 85:3 \xt Egz 32:12\x* detounen kòlè Ou ki brile a.   
\q1
\v 4 Restore nou, O Bondye a sali nou an,  
\q1 e \x + \xo 85:4 \xt Dan 9:16 \x*fè endiyasyon Ou anvè nou, sispann.   
\q1
\v 5 Èske \x + \xo 85:5 \xt Sòm 74:1\x* Ou va fache avèk nou jis pou tout tan?  
\q1 Èske Ou va pwolonje kòlè Ou jis a tout jenerasyon yo?   
\q1
\v 6 Èske se pa Ou menm ki pou fè nou \x + \xo 85:6 \xt Sòm 71:20\x* reprann ankò?  
\q1 Pou pèp Ou a kapab rejwi nan Ou?   
\q1
\v 7 Montre nou lanmou dous Ou a, O SENYÈ.  
\q1 \x + \xo 85:7 \xt Sòm 106:4\x* Pèmèt nou resevwa sali Ou a.   
\q1
\v 8 Mwen va tande sa ke Bondye, SENYÈ a, va di.  
\q1 Paske L ap \x + \xo 85:8 \xt Sòm 29:11\x* pale lapè a pèp Li a, a fidèl Li yo,  
\q1 men pa kite yo retounen nan foli yo.   
\q1
\v 9 Anverite, sekou Li toupre a sila ki gen lakrent Li yo,  
\q1 pou laglwa Li kapab rete nan peyi nou an.   
\q1
\v 10 Lanmou dous avèk verite te vin jwenn ansanm.  
\q1 \x + \xo 85:10 \xt Sòm 72:3\x*Ladwati avèk lapè te vin bo youn lòt.   
\q1
\v 11 Verite \x + \xo 85:11 \xt És 45:8\x* vòltije sòti nan latè, e  
\q1 Ladwati veye depi anwo nan syèl la.   
\q1
\v 12 Anverite, SENYÈ a va bay sa ki bon,  
\q1 e \x + \xo 85:12 \xt Lev 26:4\x* peyi nou an va bay rekòlt li.   
\q1
\v 13 Ladwati va mache devan L.  
\q1 L ap prepare yon gran chemen pou mak pla pye Li yo.   
\c 86  
\d Yon priyè a David  
\q1
\v 1 Prete m zòrèy Ou, O SENYÈ e reponn mwen.  
\q1 Paske mwen \x + \xo 86:1 \xt Sòm 40:17\x* aflije e malere.   
\q1
\v 2 \x + \xo 86:2 \xt Sòm 25:20\x* Konsève nanm mwen, paske mwen se yon nonm fidèl.  
\q1 Ou menm, Bondye mwen an,  
\q1 sove sèvitè Ou ki mete konfyans nan Ou a.   
\q1
\v 3 Montre m gras Ou, O SENYÈ, paske  
\q1 se \x + \xo 86:3 \xt Sòm 25:5\x* a Ou menm mwen kriye tout lajounen.   
\q1
\v 4 Fè nanm a sèvitè Ou a kontan,  
\q1 paske a Ou menm, SENYÈ, mwen leve nanm mwen.   
\q1
\v 5 Paske Ou menm, Senyè a,  
\q1 Ou plen bonte e Ou \x + \xo 86:5 \xt Sòm 130:4\x*prèt pou padone,  
\q1 ranpli avèk lanmou dous, pou tout sila  
\q1 ki rele sou non Ou yo.   
\q1
\v 6 \x + \xo 86:6 \xt Sòm 55:1\x* Prete zòrèy Ou, O SENYÈ, a lapriyè mwen.  
\q1 Prete atansyon a vwa siplikasyon mwen yo.   
\q1
\v 7 Nan jou twoub mwen an, mwen va rele Ou,  
\q1 paske \x + \xo 86:7 \xt Sòm 17:6\x* Ou va reponn mwen.   
\q1
\v 8 Nanpwen tankou Ou pami dye yo, O Senyè,  
\q1 ni nanpwen zèv \x + \xo 86:8 \xt Det 3:24\x* tankou pa Ou yo.   
\q1
\v 9 \x + \xo 86:9 \xt Sòm 22:27\x* Tout nasyon ke Ou te fè yo, va vini pou  
\q1 adore devan Ou, O Senyè,  
\q1 e yo va bay non Ou glwa.   
\q1
\v 10 Paske Ou gran e \x + \xo 86:10 \xt Egz 15:11\x*fè zèv ki mèvèye.  
\q1 Se Ou sèl ki Bondye.   
\q1
\v 11 Montre m chemen Ou an, O SENYÈ.  
\q1 Mwen va mache nan verite Ou.  
\q1 \x + \xo 86:11 \xt Jr 32:39\x*Fè kè m dispoze pou krent non Ou.   
\q1
\v 12 Mwen va \x + \xo 86:12 \xt Sòm 111:1\x* ba Ou remèsiman,  
\q1 O SENYÈ, Bondye mwen an, avèk tout kè m.  
\q1 Mwen va bay glwa a non Ou jis pou tout tan.   
\q1
\v 13 Paske lanmou dous Ou anvè mwen gran,  
\q1 e Ou te \x + \xo 86:13 \xt Sòm 30:3\x* delivre nanm mwen soti nan fon sejou lanmò yo.   
\q1
\v 14 O Bondye, mesye awogan yo te \x + \xo 86:14 \xt Sòm 54:3\x* leve kont mwen,  
\q1 yon bann mesye vyolan ap chache lavi mwen.  
\q1 Yo pa mete Ou devan yo.   
\q1
\v 15 Men Ou menm, O SENYÈ,  
\q1 Ou se yon Bondye ki \x + \xo 86:15 \xt Sòm 86:5\x* plen ak gras avèk mizerikòd,  
\q1 lan nan kòlè e plen avèk lanmou dous ak verite.   
\q1
\v 16 Vire vè mwen e fè m gras.  
\q1 O \x + \xo 86:16 \xt Sòm 68:35\x* dispoze fòs Ou a sèvitè Ou a,  
\q1 e fè sekou a fis a sèvant Ou a.   
\q1
\v 17 Montre m yon sign bonte Ou,  
\q1 pou sila ki rayi mwen yo kapab wè l e vin wont.  
\q1 Paske Ou menm, O SENYÈ, \x + \xo 86:17 \xt Sòm 78:69\x* te fè m sekou, e te konsole mwen.   
\c 87  
\d Yon Sòm a fis a Koré yo; Yon Chan  
\q1
\v 1 \x + \xo 87:1 \xt Sòm 78:69\x* Fondasyon Li nan mòn sen yo.   
\q1
\v 2 SENYÈ a \x + \xo 87:2 \xt Sòm 78:67-68\x* renmen pòtay Sion yo  
\q1 plis pase tout lòt abitasyon a Jacob yo.   
\q1
\v 3 Yo pale sou gran mèvèy ou,  
\q1 O \x + \xo 87:3 \xt Sòm 46:4\x* gran vil Bondye. \qs Tan\qs*   
\q1
\v 4 Mwen va mete \x + \xo 87:4 \xt Job 9:13\x* Rahab avèk Babylone  
\q1 pami sila ki rekonèt Mwen yo.  
\q1 Men vwala, Philistie, Tyr, avèk Éthiopie:  
\q1 “Tèl moun te fèt la”.   
\q1
\v 5 Men selon Sion, li va pale,  
\q1 “Sa a ak sila a fèt ladann.”  
\q1 Pi Wo a, Li menm, va \x + \xo 87:5 \xt Sòm 48:8\x* etabli Sion.   
\q1
\v 6 SENYÈ a va konte lè Li \x + \xo 87:6 \xt Sòm 69:28\x* anrejistre  
\q1 tout pèp yo: “Sa a te fèt la”. \qs Tan\qs*   
\q1
\v 7 Epi sila ki chante ansanm avèk sila ki jwe flit yo va di:  
\q1 “Tout \x + \xo 87:7 \xt Sòm 36:9\x* sous bwote yo, se nan ou”.   
\c 88  
\d Yon Chan. Yon Sòm a fis Koré yo  
\d Pou direktè Koral la; selon melodi “Soufrans Afliksyon An”.  
\d Yon refleksyon pa Héman, Ezrachit la  
\q1
\v 1 O SENYÈ, Bondye sali mwen an,  
\q1 Mwen te kriye fò lajounen kon lannwit devan Ou.   
\q1
\v 2 Kite priyè mwen \x + \xo 88:2 \xt Sòm 18:6\x* vini devan Ou.  
\q1 Panche zòrèy Ou vè kri mwen an!   
\q1
\v 3 Paske nanm mwen gen kont twoub li.  
\q1 \x + \xo 88:3 \xt Sòm 107:18\x*Lavi m vin toupre sejou lanmò a.   
\q1
\v 4 Mwen vin konte pami sila ki \x + \xo 88:4 \xt Sòm 28:1\x* desann nan fòs yo.  
\q1 Mwen parèt tankou yon nonm san fòs,   
\q1
\v 5 abandone pami mò yo, tankou sila  
\q1 ki te touye e kouche nan tonm lan.  
\q1 Sila a nou pa sonje ankò menm,  
\q1 ki \x + \xo 88:5 \xt Sòm 31:22\x* koupe retire nan men Ou.   
\q1
\v 6 Ou te mete m nan \x + \xo 88:6 \xt Sòm 86:13\x* fòs pi ba a, nan plas fènwa yo, nan fon yo.   
\q1
\v 7 Kòlè Ou \x + \xo 88:7 \xt Sòm 32:4\x* vin poze sou mwen.  
\q1 Ou te aflije m ak tout vag lanmè Ou yo. \qs Tan\qs*   
\q1
\v 8 Ou te retire tout moun mwen konnen byen lwen m.  
\q1 Ou te fè m yon objè abominab devan yo.  
\q1 Mwen fèmen anndan nèt e mwen pa kab sòti.   
\q1
\v 9 Zye m gen tan pouri akoz afliksyon.  
\q1 Mwen te rele Ou chak jou, O SENYÈ.  
\q1 Mwen te lonje men m yo vè Ou menm.   
\q1
\v 10 Èske Ou va fè mirak pou mò yo?  
\q1 Èske \x + \xo 88:10 \xt Sòm 6:5\x* lespri ki fin pati yo va leve pou bay Ou lwanj? \qs Tan\qs*   
\q1
\v 11 Èske lanmò dous Ou a va deklare nan tonbo a?  
\q1 Fidelite Ou nan labim nan?   
\q1
\v 12 Èske mirak Ou yo va fèt parèt nan \x + \xo 88:12 \xt Job 10:21\x* tenèb la?  
\q1 Oswa ladwati Ou nan peyi kote tout bagay bliye yo?   
\q1
\v 13 Men anvè Ou, O SENYÈ, mwen te kriye.  
\q1 Nan maten, lapriyè mwen vini devan Ou.   
\q1
\v 14 O SENYÈ, poukisa Ou rejte nanm mwen?  
\q1 Poukisa Ou \x + \xo 88:14 \xt Job 13:24\x*kache figi Ou kont mwen?   
\q1
\v 15 Mwen te aflije e \x + \xo 88:15 \xt Pwov 24:11\x* prèt pou mouri depi nan jenès mwen.  
\q1 Pandan mwen soufri gwo laperèz Ou yo, mwen distrè nèt.   
\q1
\v 16 Kòlè Ou ki brile, fin pase sou mwen.  
\q1 Gwo laperèz Ou yo te \x + \xo 88:16 \xt Lam 3:54\x*koupe retire m.   
\q1
\v 17 Yo fin antoure mwen tankou dlo tout lajounen.  
\q1 Yo \x + \xo 88:17 \xt Sòm 17:11\x*ansèkle m nèt.   
\q1
\v 18 Ou te retire renmen mwen ak zanmi m nan lwen m nèt,  
\q1 ak zanmi m yo, nan tenèb.   
\c 89  
\d Yon Refleksyon pa Éthan, Ezrachit la  
\q1
\v 1 Mwen va chante lanmou dous SENYÈ a jis pou tout tan.  
\q1 Ak bouch mwen, mwen va fè tout jenerasyon yo konnen fidelite Ou.   
\q1
\v 2 Paske mwen te di: “Lanmou dous Ou a  
\q1 va kanpe dyanm jis pou tout tan.  
\q1 Ou te etabli syèl yo.  
\q1 Fidelite Ou rete nan yo.   
\b  
\q1
\v 3 “Mwen, Bondye, te fè yon akò avèk \x + \xo 89:3 \xt I Wa 8:16\x* moun apwente mwen an.  
\q1 Mwen te sèmante pa David, sèvitè mwen an,   
\q1
\v 4 ‘Mwen va etabli \x + \xo 89:4 \xt II Sam 7:16\x* jèm ou nèt  
\q1 e bati twòn Ou pandan tout jenerasyon yo.’” \qs Tan\qs*   
\q1
\v 5 Syèl yo va louwe mèvèy Ou yo, O SENYÈ,  
\q1 ansanm ak fidelite Ou nan asanble \x + \xo 89:5 \xt Job 5:1\x*sen yo.   
\q1
\v 6 Paske kilès nan syèl la ki konpare ak SENYÈ a?  
\q1 Kilès pami \x + \xo 89:6 \xt Sòm 29:1\x* fis a pwisan yo ki tankou SENYÈ a,   
\q1
\v 7 Yon Bondye ki resevwa lakrent anpil nan asanble a sen yo,  
\q1 e \x + \xo 89:7 \xt Sòm 96:4\x*mèvèye plis pase tout sila ki antoure Li yo?   
\q1
\v 8 O SENYÈ Bondye dèzame yo, \x + \xo 89:8 \xt Sòm 35:10\x* se kilès ki  
\q1 tankou Ou, O SENYÈ pwisan an?  
\q1 Anplis, fidelite Ou antoure Ou.   
\q1
\v 9 Ou domine ògèy lanmè a.  
\q1 Lè vag li yo vin leve, Ou \x + \xo 89:9 \xt Sòm 65:7\x* kalme yo.   
\q1
\v 10 Ou menm, Ou te kraze \x + \xo 89:10 \xt Sòm 87:4\x* Rahab (Égypte)  
\q1 tankou yon moun ki fin touye.  
\q1 Ou te gaye lènmi Ou yo avèk men pwisan Ou.   
\q1
\v 11 \x + \xo 89:11 \xt Jen 1:1\x* Syèl yo se pou Ou.  
\q1 Tè a se pa Ou tou.  
\q1 Lemond ak tout sa ki ladann,  
\q1 se Ou menm ki te etabli yo.   
\q1
\v 12 \x + \xo 89:12 \xt Jos 19:22\x* Nò ak sid, se Ou menm ki te kreye yo.  
\q1 Thabor avèk Hermon kriye avèk jwa a non Ou.   
\q1
\v 13 Ou gen yon men byen fò.  
\q1 \x + \xo 89:13 \xt Sòm 98:1\x* Men dwat Ou leve byen wo.   
\q1
\v 14 Ladwati avèk jistis se fondasyon twòn Ou an.  
\q1 \x + \xo 89:14 \xt Sòm 85:13\x*Lanmou dous avèk verite mache devan Ou.   
\q1
\v 15 A la beni, pèp ki konnen son lajwa a beni!  
\q1 O SENYÈ, yo mache nan \x + \xo 89:15 \xt Sòm 4:6\x* limyè a vizaj Ou a.   
\q1
\v 16 Nan \x + \xo 89:16 \xt Sòm 105:3\x* non Ou, yo rejwi tout lajounen,  
\q1 e pa ladwati Ou, yo vin egzalte.   
\q1
\v 17 Paske Ou se glwa a \x + \xo 89:17 \xt Sòm 28:8\x* fòs yo,  
\q1 e pa favè Ou, kòn nou vin egzalte.   
\q1
\v 18 Paske boukliye nou apatyen a SENYÈ a,  
\q1 e wa nou an se Sila Ki Sen An Israël la. \x + \xo 89:18 \xt I Wa 11:34\x*   
\b  
\q1
\v 19 Yon fwa, Ou te pale nan yon vizyon a fidèl Ou yo.  
\q1 Ou te di: “Mwen te bay soutyen a yon moun ki pwisan.  
\q1 Mwen te fè leve yon jennonm ki te chwazi pami pèp la.   
\q1
\v 20 Mwen te \x + \xo 89:20 \xt I Sam 13:14\x* twouve David, sèvitè Mwen an.  
\q1 Avèk lwil sen Mwen an, mwen te onksyone l.   
\q1
\v 21 Avèk li menm, \x + \xo 89:21 \xt Sòm 18:35\x* men M va vin etabli.  
\q1 Anplis, bra M va ranfòse li.   
\q1
\v 22 Lènmi an p ap \x + \xo 89:22 \xt II Sam 7:10\x* twonpe li.  
\q1 Ni fis a mechanste a p ap aflije li.   
\q1
\v 23 Men Mwen va \x + \xo 89:23 \xt II Sam 7:9\x* kraze advèsè li yo devan l,  
\q1 e frape sila ki rayi li yo.   
\q1
\v 24 Fidelite Mwen avèk lanmou dous Mwen va avèk li.  
\q1 Nan non Mwen, \x + \xo 89:24 \xt Sòm 132:7\x*kòn li va vin egzalte.   
\q1
\v 25 Mwen va osi mete men li \x + \xo 89:25 \xt Sòm 72:8\x* sou lanmè a,  
\q1 ak men dwat li sou rivyè yo.   
\q1
\v 26 Li va kriye a Mwen: ‘Ou se papa m,  
\q1 Bondye m \x + \xo 89:26 \xt II Sam 22:47\x*Wòch a sali mwen an.   
\q1
\v 27 Anplis, Mwen va fè li premye ne Mwen,  
\q1 pi wo pami tout wa latè yo.’   
\q1
\v 28 Lanmou dous Mwen va kenbe pou li jis pou tout tan,  
\q1 \x + \xo 89:28 \xt Sòm 89:3-34\x* e akò Mwen va konfime a li menm.   
\q1
\v 29 Konsa, Mwen va etabli \x + \xo 89:29 \xt Sòm 18:50\x* desandan li yo jis pou tout tan,  
\q1 e twòn li tankou jou syèl yo.   
\q1
\v 30 Si fis li yo \x + \xo 89:30 \xt II Sam 7:14\x* abandone lalwa Mwen an, e  
\q1 pa mache nan jijman Mwen yo,   
\q1
\v 31 si yo vyole règleman Mwen yo, e  
\q1 pa kenbe kòmandman Mwen yo,   
\q1
\v 32 alò Mwen va pini transgresyon yo  
\q1 avèk yon \x + \xo 89:32 \xt Job 9:34\x* baton,  
\q1 e inikite yo avèk kout fwèt.   
\q1
\v 33 Men Mwen p ap retire \x + \xo 89:33 \xt II Sam 7:15\x* lanmou dous sou li,  
\q1 ni aji avèk movèz fwa selon fidelite mwen.   
\q1
\v 34 Mwen p ap vyole \x + \xo 89:34 \xt Det 7:9\x* akò mwen an,  
\q1 ni fè okenn chanjman nan pawòl ki te sòti nan lèv Mwen yo.   
\b  
\q1
\v 35 Depi Mwen fin \x + \xo 89:35 \xt Sòm 60:6\x* sèmante selon sentete Mwen,  
\q1 Mwen p ap manti a David.   
\q1
\v 36 Desandan li yo va dire jis pou tout tan,  
\q1 e twòn li va \x + \xo 89:36 \xt Sòm 72:17 \x*tankou solèy la devan M.   
\q1
\v 37 Li va etabli jis pou tout tan tankou lalin nan,  
\q1 \x + \xo 89:37 \xt Job 16:19\x*temwen nan syèl la ki toujou fidèl.”   
\b  
\q1
\v 38 Men koulye a Ou vin \x + \xo 89:38 \xt Det 32:19\x*refize ak rejete,  
\q1 Ou te plen ak kòlè kont onksyone Ou a.   
\q1
\v 39 Ou te \x + \xo 89:39 \xt Sòm 60:6\x* desann e rejte akò a sèvitè ou a.  
\q1 Ou te pwofane kouwòn li an nan pousyè.   
\q1
\v 40 Ou te \x + \xo 89:40 \xt Sòm 80:12\x* kraze tout miray li yo.  
\q1 Ou te fè sitadèl li yo kraze nèt.   
\q1
\v 41 \x + \xo 89:41 \xt Sòm 80:12\x* Tout moun ki pase akote piyaje li.  
\q1 Li devni yon objè abominab pami vwazen li yo.   
\q1
\v 42 Ou te egzalte men dwat a advèsè li yo.  
\q1 Ou te \x + \xo 89:42 \xt Sòm 80:6 \x*fè lènmi li yo rejwi.   
\q1
\v 43 Anplis, ou te plwaye lam nepe li a, e  
\q1 \x + \xo 89:43 \xt Sòm 44:10\x* fè l pa kanpe pou batay la.   
\q1
\v 44 Ou te fè \x + \xo 89:44 \xt Éz 28:7\x* mayifisans li vin kraze fini e  
\q1 te jete twòn li jis atè.   
\q1
\v 45 Ou te fè jou a jenès li yo \x + \xo 89:45 \xt Sòm 102:23\x* vin kout.  
\q1 Ou te kouvri li ak gwo wont.   
\q1
\v 46 Jiskilè, O SENYÈ?  
\q1 Èske Ou va kache figi Ou jis pou tout tan?  
\q1 Èske \x + \xo 89:46 \xt Sòm 79:5\x*kòlè Ou va brile tankou dife pou tout tan?   
\q1
\v 47 \x + \xo 89:47 \xt Job 7:7\x* Sonje longè lavi mwen genyen  
\q1 tèlman kout ke li tankou yon foli!  
\q1 Se Ou ki te kreye tout fis a lòm yo!   
\q1
\v 48 Ki moun ki kab viv e pa \x + \xo 89:48 \xt Sòm 22:29\x* wè lanmò?  
\q1 Èske li kab delivre nanm li de pouvwa  
\q1 sejou lanmò a? \qs Tan\qs*   
\q1
\v 49 Kote lanmou dous Ou te konn genyen an, O SENYÈ?  
\q1 Sa Ou te \x + \xo 89:49 \xt II Sam 7:15\x* sèmante a David nan fidelite Ou a?   
\q1
\v 50 Sonje, O Senyè, \x + \xo 89:50 \xt Sòm 69:9\x* repwòch a sèvitè Ou yo,  
\q1 jan mwen pote nan lestonmak mwen,  
\q1 repwòch a tout nasyon pwisan yo,   
\q1
\v 51 Avèk sila, \x + \xo 89:51 \xt Sòm 74:10-22\x* lènmi Ou yo te fè repwòch yo, O SENYÈ.  
\q1 Se konsa yo te repwoche mak pla pye onksyone Ou a.   
\b  
\q1
\v 52 \x + \xo 89:52 \xt Sòm 41:13\x* Beni se SENYÈ a pou tout tan!  
\q1 Amen, e Amen.   
\c 90  
\ms1 LIV 4  
\d Yon priyè Moïse; Moun Bondye a.  
\q1
\v 1 Senyè, se te kote Ou, lakay nou te ye  
\q1 pandan tout jenerasyon yo.   
\q1
\v 2 Avan mòn yo te vin parèt,  
\q1 oswa Ou te bay nesans a mond lan avèk tè a,  
\q1 menm \x + \xo 90:2 \xt Sòm 93:2\x*pou tout tan e pou tout tan, Ou se Bondye.   
\q1
\v 3 Ou fè lòm retounen nan pousyè a, epi di:  
\q1 “Retounen, O pitit a lòm yo.”   
\q1
\v 4 Paske mil ane devan zye Ou  
\q1 se tankou ayè lè l fenk pase, oswa tankou yon veye lannwit lan.   
\q1
\v 5 Ou \x + \xo 90:5 \xt Job 22:16\x* bale yo ale pandan y ap dòmi.   
\q1
\v 6 Nan maten, yo vin tankou yon chan zèb nèf ki fènk leve.  
\q1 Vè aswè, chan an febli e fennen nèt ale.   
\q1
\v 7 Paske nou \x + \xo 90:7 \xt Sòm 39:11\x* fin manje nèt akoz kòlè Ou.  
\q1 E akoz kòlè Ou, nou boulvèse nèt.   
\q1
\v 8 Ou te \x + \xo 90:8 \xt Sòm 50:21\x* mete inikite nou yo devan Ou.  
\q1 Peche ki kache yo vin parèt nan limyè prezans Ou.   
\q1
\v 9 Paske \x + \xo 90:9 \xt Sòm 78:33\x* tout jou nou yo pase nan gran kòlè Ou.  
\q1 Ane nou yo ap fini kon souf.   
\q1
\v 10 Pou jou lavi nou yo, yo gen swasann-dizan,  
\q1 oswa akoz gwo fòs, katre-ventan.  
\q1 Men ògèy a jou sa yo se sèlman kòve ak tristès.  
\q1 Paske byen vit li prale, e nou \x + \xo 90:10 \xt Job 20:8 \x*vole ale.   
\q1
\v 11 Se kilès ki konprann \x + \xo 90:11 \xt Sòm 76:7\x* fòs a kòlè Ou a?  
\q1 Avèk gwo kòlè Ou, selon krent ke Ou merite a?   
\q1
\v 12 Pou sa, montre nou jan pou konte jou nou yo,  
\q1 pou nou kab \x + \xo 90:12 \xt Pwov 2:1-6\x*ofri Ou yon kè ki plen sajès.   
\q1
\v 13 Lache, O SENYÈ!  
\q1 Konbyen tan sa va ye?  
\q1 Pran sa akè pou kòz sèvitè ou yo!   
\q1
\v 14 O fè nou satisfè nan maten avèk lanmou dous Ou a,  
\q1 pou nou kab chante ak jwa e fè kè kontan pandan tout jou nou yo.   
\q1
\v 15 Fè nou rejwi pou menm kantite jou ke Ou te aflije nou yo,  
\q1 tout \x + \xo 90:15 \xt Det 2:14-16\x*ane ke nou te wè mal yo.   
\q1
\v 16 Kite zèv Ou yo vin parèt a sèvitè Ou yo,  
\q1 ak\x + \xo 90:16 \xt I Wa 8:11\x*majeste Ou a pitit yo.   
\q1
\v 17 Kite favè SENYÈ a, Bondye nou an, vini sou nou,  
\q1 epi \x + \xo 90:17 \xt Sòm 37:23\x*konfime pou nou menm, zèv men nou yo.  
\q1 Wi, konfime zèv men nou yo.   
\c 91  
\q1
\v 1 Sila ki rete nan abri Pi Wo a va poze nan \x + \xo 91:1 \xt Sòm 17:8\x*lonbraj Toupwisan an.   
\q1
\v 2 Mwen va di a SENYÈ a:  
\q1 “Se Li ki sitadèl mwen an, ak Bondye mwen an.  
\q1 Se nan Li mwen mete \x + \xo 91:2 \xt Sòm 25:2\x*konfyans!”   
\q1
\v 3 Paske se Li menm ki delivre ou soti nan pèlen a chasè a,  
\q1 ak \x + \xo 91:3 \xt I Wa 8:37\x* ravaj gwo maladi yo.   
\q1
\v 4 Li va \x + \xo 91:4 \xt És 51:16\x* kouvri ou ak plim Li yo.  
\q1 Anba zèl Li, ou kapab chache pwotèj.  
\q1 Fidelite Li se yon boukliye ak yon ranpa.   
\q1
\v 5 Ou p ap pè laperèz lannwit, ni \x + \xo 91:5 \xt Sòm 64:4\x*flèch k ap vole lajounen,   
\q1
\v 6 ni gwo maladi ki swiv nan fènwa,  
\q1 ni destriksyon ki devaste a midi.   
\q1
\v 7 Yon milye kapab tonbe bò kote dwat ou,  
\q1 ak di mil sou men agoch ou,  
\q1 men \x + \xo 91:7 \xt Jen 7:23\x* sa p ap pwoche ou.   
\q1
\v 8 Ou va sèlman gade avèk zye ou pou  
\q1 \x + \xo 91:8 \xt Sòm 37:34\x* wè rekonpans a mechan yo.   
\q1
\v 9 Paske ou te fè SENYÈ a, vin \x + \xo 91:9 \xt Sòm 91:2\x* sekou ou,  
\q1 menm Pi Wo a, kote pou ou rete.   
\q1
\v 10 \x + \xo 91:10 \xt Pwov 12:21\x* Nanpwen mal k ap rive ou,  
\q1 Ni okenn toumant k ap pwoche tant ou.   
\q1
\v 11 Paske Li va bay \x + \xo 91:11 \xt Sòm 34:7\x* zanj Li yo lòd konsènan ou menm,  
\q1 pou veye ou nan tout chemen ou yo.   
\q1
\v 12 Yo va \x + \xo 91:12 \xt Mat 4:6\x* leve ou byen wo nan men yo,  
\q1 pou ou pa frape pye ou kont wòch.   
\q1
\v 13 Ou va \x + \xo 91:13 \xt Jij 14:6\x* pile sou lyon an ak koulèv la.  
\q1 Jenn lyon an avèk sèpan an, ou va foule yo nèt.   
\q1
\v 14 Paske li te renmen M konsa,  
\q1 pou sa, Mwen va delivre li.  
\q1 Mwen va \x + \xo 91:14 \xt Sòm 59:1 \x*mete li byen solid an wo,  
\q1 akoz li te rekonèt non Mwen.   
\q1
\v 15 Li va \x + \xo 91:15 \xt Job 12:4\x* fè apèl non Mwen e Mwen va reponn li.  
\q1 Mwen va avèk Li nan tan twoub la.  
\q1 Mwen va delivre li e bay li lonè.   
\q1
\v 16 Mwen va satisfè li avèk yon lavi ki long,  
\q1 e kite li wè sali mwen.   
\c 92  
\d Yon Sòm. Yon chan pou jou Saba a  
\q1
\v 1 Li bon pou bay lwanj a SENYÈ a,  
\q1 pou chante lwanj a non Ou, O Pi Wo a,   
\q1
\v 2 pou deklare lanmou dous Ou nan maten  
\q1 avèk \x + \xo 92:2 \xt Sòm 89:1\x*fidelite Ou nan lannwit,   
\q1
\v 3 avèk \x + \xo 92:3 \xt I Sam 10:5\x* lenstriman a kòd e avèk ap,  
\q1 avèk mizik ki retanti sou lir.   
\q1
\v 4 Paske Ou menm, O SENYÈ, te fè m kontan avèk sa Ou te fè a.  
\q1 Mwen va chante chan viktwa a akoz \x + \xo 92:4 \xt Sòm 8:6\x*zèv men Ou yo.   
\q1
\v 5 A la zèv Ou yo gran, O SENYÈ!  
\q1 Panse Ou yo byen pwofon.   
\q1
\v 6 Yon \x + \xo 92:6 \xt Sòm 49:10\x* nonm ensanse pa gen konesans,  
\q1 ni yon nonm bèt pa konprann sa:   
\q1
\v 7 Ke lè mechan yo te pouse tankou zèb la,  
\q1 e tout sa ki fè inikite t ap byen reyisi yo,  
\q1 se te pou yo ta kapab \x + \xo 92:7 \xt Sòm 37:38\x*detwi jis pou tout tan.   
\q1
\v 8 Men Ou menm O SENYÈ, Ou \x + \xo 92:8 \xt Sòm 83:18\x* an wo jis pou tout tan.   
\q1
\v 9 Paske gade byen, lènmi Ou yo, O SENYÈ,  
\q1 paske gade byen, \x + \xo 92:9 \xt Sòm 37:20\x* lènmi Ou yo va peri.  
\q1 Tout moun ki fè inikite yo va gaye nèt.   
\q1
\v 10 Men Ou te fè kòn mwen an leve wo tankou bèf mawon.  
\q1 Mwen te onksyone avèk lwil nèf.   
\q1
\v 11 Epi zye mwen vin \x + \xo 92:11 \xt Sòm 54:7\x* gade avèk kè kontan  
\q1 malfektè ki leve kont mwen yo.   
\q1
\v 12 Moun dwat la va fleri tankou palmis.  
\q1 Li va grandi tankou pye sèd nan Liban.   
\q1
\v 13 Plante lakay SENYÈ a, yo va fleri tankou palmis.  
\q1 Yo va fleri nan lakou kay Bondye nou an.   
\q1
\v 14 Yo va \x + \xo 92:14 \xt Pwov 11:30\x* bay fwi toujou lè yo vin vye.  
\q1 Yo va plen ak dlo bwa vèt.  
\q1 Y ap rete vèt nèt.   
\q1
\v 15 Konsa, yo deklare ke SENYÈ a toujou dwat.  
\q1 Li se wòch mwen,  
\q1 e \x + \xo 92:15 \xt Wo 9:14\x* nanpwen anyen ki pa dwat nan Li.   
\c 93  
\q1
\v 1 SENYÈ a renye!  
\q1 Li abiye an majeste!  
\q1 SENYÈ a te abiye Li ak fòs.  
\q1 Anverite, mond lan etabli byen solid.  
\q1 Li pa ebranle menm.   
\q1
\v 2 Twòn Ou etabli depi tan ansyen an.  
\q1 Ou la depi nan etènite.   
\q1
\v 3 Flèv yo te leve, O SENYÈ,  
\q1 Flèv yo te leve vwa yo, flèv yo te leve gwo vag frapan yo.   
\q1
\v 4 Plis pase bri a anpil dlo, pase gwo vag lanmè debòde,  
\q1 SENYÈ anwo a pwisan.   
\q1
\v 5 \x + \xo 93:5 \xt Sòm 19:7\x* Regleman Ou yo kanpe nèt;  
\q1 Sentete byen bèl lakay Ou a  
\q1 O SENYÈ, jis pou tout tan.   
\c 94  
\q1
\v 1 O SENYÈ, Bondye a \x + \xo 94:1 \xt Det 32:35\x* vanjans lan,  
\q1 Bondye a vanjans lan, kite limyè vin parèt!   
\q1
\v 2 Vin leve, O \x + \xo 94:2 \xt Jen 18:25\x* Jij sou tè a.  
\q1 Bay rekonpans a moun ògeye yo.   
\q1
\v 3 Pou konbyen de tan mechan yo, O SENYÈ,  
\q1 pou konbyen de tan \x + \xo 94:3 \xt Job 20:5\x* mechan yo va leve tèt yo wo?   
\q1
\v 4 Yo vide pawòl yo, yo pale avèk ògèy.  
\q1 Tout moun ki fè mechanste yo \x + \xo 94:4 \xt Sòm 10:3\x* vante tèt yo.   
\q1
\v 5 Yo kraze pèp Ou a, O SENYÈ.  
\q1 \x + \xo 94:5 \xt És 3:15\x*Yo aflije eritaj Ou a.   
\q1
\v 6 Yo \x + \xo 94:6 \xt És 10:2\x* touye vèv yo avèk etranje a.  
\q1 Yo asasine òfelen yo.   
\q1
\v 7 \x + \xo 94:7 \xt Job 22:13\x* Yo fin di: “SENYÈ a pa wè, ni Bondye  
\q1 Jacob la p ap okipe sa a.”   
\q1
\v 8 Veye sa a, nou menm ki \x + \xo 94:8 \xt Sòm 92:6\x* ensansib pami pèp la;  
\q1 Kilè n ap konprann, nou menm ki bèt?   
\q1
\v 9 Sila ki te \x + \xo 94:9 \xt Egz 4:11\x* plante zòrèy la, èske Li pa tande?  
\q1 Sila ke te fòme zye a, èske Li pa wè.   
\q1
\v 10 Sila ki fè chatiman nasyon yo,  
\q1 èske Li p ap fè repwòch?  
\q1 Sila ki \x + \xo 94:10 \xt Job 35:11 \x*enstwi lòm; Li konnen!   
\q1
\v 11 SENYÈ a \x + \xo 94:11 \xt Job 11:11\x* konnen panse a lòm,  
\q1 ke se sèlman yon souf ke yo ye.   
\q1
\v 12 Beni se nonm ke Ou bay chatiman an,  
\q1 O SENYÈ,  
\q1 ke Ou \x + \xo 94:12 \xt Sòm 119:171\x* enstwi nan lalwa Ou a,   
\q1
\v 13 pou Ou kapab bay li sekou nan \x + \xo 94:13 \xt Sòm 49:5\x*jou advèsite yo,  
\q1 jiskaske yon fòs fin fouye pou mechan yo.   
\q1
\v 14 Paske SENYÈ a p ap abandone pèp Li a,  
\q1 ni Li p ap \x + \xo 94:14 \xt Sòm 37:28\x* lage pèp eritaj Li a.   
\q1
\v 15 Paske \x + \xo 94:15 \xt Sòm 97:2\x* jijman an va devni dwat ankò e  
\q1 tout pèp ladwati yo va swiv li.   
\q1
\v 16 Se kilès ki va \x + \xo 94:16 \xt Nonb 10:35\x* kanpe pou mwen kont malfektè yo?  
\q1 Se kilès ki va pran pozisyon li pou mwen kont sila ki fè mechanste yo?   
\q1
\v 17 Si \x + \xo 94:17 \xt Sòm 124:1-2\x* SENYÈ a pa t sekou mwen,  
\q1 nanm mwen ta fin abite nan andwa silans lan.   
\q1
\v 18 Si mwen ta di: \x + \xo 94:18 \xt Sòm 38:16\x* “Pye m glise,”  
\q1 Lanmou dous Ou a, O SENYÈ, va kenbe m.   
\q1
\v 19 Lè panse twoub mwen yo vin ogmante anndan m,  
\q1 \x + \xo 94:19 \xt És 57:18\x* konsolasyon Ou yo fè kè m kontan.   
\q1
\v 20 Èske yon \x + \xo 94:20 \xt Am 6:3\x* twòn mechan kapab fè amitye avèk Ou?  
\q1 Yon moun ki imajine fè mal pa dekrè?   
\q1
\v 21 Yo vin reyini ansanm kont lavi moun dwat yo,  
\q1 e \x + \xo 94:21 \xt Egz 23:7\x* kondane inosan yo a lanmò.   
\q1
\v 22 Men SENYÈ a se toujou sitadèl mwen e  
\q1 Bondye mwen an, \x + \xo 94:22 \xt Sòm 18:2 \x*wòch ki pwoteje mwen an.   
\q1
\v 23 Li te fè mechanste pa yo retounen sou yo, e  
\q1 va \x + \xo 94:23 \xt Sòm 7:16\x* koupe retire yo nèt nan mechanste pa yo.  
\q1 SENYÈ nou an va koupe retire yo.   
\c 95  
\q1
\v 1 O vini, annou chante a SENYÈ a!  
\q1 Annou rele fò avèk jwa a wòch ki sove nou an;   
\q1
\v 2 Annou vini devan prezans Li avèk remèsiman,  
\q1 Annou rele fò a Li menm avèk sòm.   
\q1
\v 3 Paske SENYÈ a se yon \x + \xo 95:3 \xt Sòm 48:1\x* gran Bondye, e  
\q1 yon gran wa pi wo ke tout dye yo.   
\q1
\v 4 Nan men Sila \x + \xo 95:4 \xt Sòm 135:6\x* pwofondè latè yo ye a.  
\q1 Pwent mòn yo osi se pou Li.   
\q1
\v 5 Lanmè a se pou Li, paske se te Li menm \x + \xo 95:5 \xt Jen 1:9-10\x* ki te fè l.  
\q1 Ak men L, Li te fòme tè sèch la.   
\q1
\v 6 Vini, annou fè adorasyon, e annou pwostène.  
\q1 Annou mete ajenou devan SENYÈ \x + \xo 95:6 \xt Sòm 100:3\x* ki te fè nou an.   
\q1
\v 7 Paske se Li menm ki Bondye nou an.  
\q1 Nou se moun patiraj Li ak mouton men Li yo.  
\q1 \x + \xo 95:7 \xt Eb 3:7-11-15\x* Jodi a, si nou ta vle tande vwa L,   
\q1
\v 8 pa fè kè nou vin di tankou nan \x + \xo 95:8 \xt Egz 17:2-7\x* Meriba,  
\q1 tankou nan jou a Massa nan dezè yo,   
\q1
\v 9 “lè papa zansèt nou yo te \x + \xo 95:9 \xt Nonb 14:22\x* pase M a leprèv.  
\q1 Yo te tante Mwen, malgre yo te deja wè zèv Mwen yo.   
\q1
\v 10 Pandan \x + \xo 95:10 \xt Trav 7:36\x* karantan, Mwen te rayi jenerasyon sila a e te di:  
\q1 “Yo se yon pèp ki egare nan kè yo.  
\q1 Yo pa rekonèt chemen Mwen yo.”   
\q1
\v 11 Akoz sa, Mwen te sèmante nan kòlè Mwen,  
\q1 “Anverite, yo p ap antre nan \x + \xo 95:11 \xt Det 12:9\x*repo Mwen an.”   
\c 96  
\q1
\v 1 Chante a SENYÈ a yon \x + \xo 96:1 \xt Sòm 40:3\x* chan tounèf!  
\q1 Chante a SENYÈ a tout latè a.   
\q1
\v 2 Chante a SENYÈ a!  
\q1 Beni non Li!  
\q1 \x + \xo 96:2 \xt Sòm 71:15\x* Pwoklame bòn nouvèl Sali a Li de jou an jou.   
\q1
\v 3 Pale \x + \xo 96:3 \xt Sòm 145:12\x* glwa Li pami nasyon yo,  
\q1 zèv mèvèy Li yo pami tout pèp yo.   
\q1
\v 4 Paske gran se SENYÈ a!  
\q1 Li merite gran lwanj.  
\q1 Fòk Li resevwa krentif nou \x + \xo 96:4 \xt Sòm 95:3\x*pi wo ke tout dye yo.   
\q1
\v 5 Paske tout dye a pèp yo se zidòl,  
\q1 men SENYÈ a te fè syèl yo.   
\q1
\v 6 \x + \xo 96:6 \xt Sòm 104:1\x* Tout bèlte ak majeste devan L.  
\q1 Pwisans ak bèlte rete nan sanktyè Li a.   
\q1
\v 7 Bay a SENYÈ a, O fanmi a pèp yo,  
\q1 \x + \xo 96:7 \xt I Kwo 16:28-29\x* bay a SENYÈ a glwa ak pwisans.   
\q1
\v 8 Bay a SENYÈ a \x + \xo 96:8 \xt Sòm 79:9\x* glwa a non Li.  
\q1 Pote yon ofrann e antre nan lakou Li yo.   
\q1
\v 9 Adore SENYÈ a nan abiman ki sen.  
\q1 \x + \xo 96:9 \xt Sòm 33:8\x* Tranble devan L, tout latè a.   
\q1
\v 10 Pale pami nasyon yo, “SENYÈ a renye.”  
\q1 Anverite, mond lan etabli byen solid.  
\q1 Li p ap ebranle menm.  
\q1 SENYÈ a va jije pèp yo avèk jistis.   
\q1
\v 11 Kite \x + \xo 96:11 \xt Sòm 69:34\x* syèl yo vin kontan e kite latè rejwi.  
\q1 Kite lanmè a fè gwo bri ansanm ak tout sa ki ladann.   
\q1
\v 12 Kite chan yo leve fè kè kontan, ak tout sa ki ladann yo.  
\q1 Epi tout \x + \xo 96:12 \xt És 44:23 \x*bwa nan forè yo va chante ak jwa   
\q1
\v 13 devan SENYÈ a, paske L ap vini.  
\q1 Paske L ap vini pou jije latè. \x + \xo 96:13 \xt Rev 19:11\x* Li va jije mond lan  
\q1 avèk ladwati e pèp yo ak fidelite Li.   
\c 97  
\q1
\v 1 SENYÈ a renye, kite latè rejwi!  
\q1 Kite tout \x + \xo 97:1 \xt És 42:10-12\x* lil yo fè kè kontan!   
\q1
\v 2 Nwaj ak fènwa pwofon ap antoure Li.  
\q1 \x + \xo 97:2 \xt Sòm 89:14\x* Ladwati avèk jistis se fondasyon twòn Li an.   
\q1
\v 3 Se \x + \xo 97:3 \xt Mal 4:1\x* dife ki ale devan L pou brile tout  
\q1 advèsè Li yo toupatou.   
\q1
\v 4 \x + \xo 97:4 \xt Egz 19:16\x* Loray Li yo klere tout mond lan.  
\q1 Latè wè e li tranble.   
\q1
\v 5 Mòn yo \x + \xo 97:5 \xt Sòm 46:6\x* fonn tankou lasi devan prezans SENYÈ a,  
\q1 devan prezans SENYÈ tout latè a.   
\q1
\v 6 \x + \xo 97:6 \xt Sòm 19:1\x* Syèl yo deklare ladwati Li e tout pèp yo te wè glwa Li.   
\q1
\v 7 Kite tout sila ki sèvi limaj taye yo vin wont,  
\q1 ki vin ògeye sou zafè \x + \xo 97:7 \xt Sòm 106:36\x*zidòl yo.  
\q1 Adore Li, tout dye yo.   
\q1
\v 8 Sion te tande sa e \x + \xo 97:8 \xt Sòm 48:11\x* te rejwi.  
\q1 Fi a Sion yo te rejwi akoz jijman Ou, O SENYÈ.   
\q1
\v 9 Paske Ou menm se SENYÈ Pi Wo a sou tout latè.  
\q1 Ou leve \x + \xo 97:9 \xt Sòm 83:18\x* pi wo anpil pase tout dye yo.   
\q1
\v 10 \x + \xo 97:10 \xt Sòm 34:14\x* Nou menm ki renmen SENYÈ a, rayi mal la!  
\q1 Li pwoteje nanm a fidèl Li yo.  
\q1 Li delivre yo nan men a mechan yo.   
\q1
\v 11 Se limyè ki simen kon semans pou moun ladwati yo,  
\q1 ak \x + \xo 97:11 \xt Sòm 64:10 \x*kè kontan pou sila ak kè ki dwat yo.   
\q1
\v 12 Fè kè kontan nan SENYÈ a, nou menm ki moun dwat yo e  
\q1 bay remèsiman a non sen Li an.   
\c 98  
\d Yon Sòm  
\q1
\v 1 O chante a SENYÈ a yon chan tounèf, paske Li te fè anpil bèl mèvèy.  
\q1 Men dwat Li ak \x + \xo 98:1 \xt És 52:10\x* bra sen Li yo te vin genyen viktwa pou Li.   
\q1
\v 2 SENYÈ a te fè sali Li rekonèt.  
\q1 Li te \x + \xo 98:2 \xt És 62:2\x*devwale ladwati Li pou tout nasyon yo wè.   
\q1
\v 3 Li te sonje lanmou dous Li a avèk fidelite Li pou lakay Israël.   
\q1
\v 4 Rele fò ak jwa a SENYÈ a, tout latè!  
\q1 Eklate ak chanson, wi chante lwanj Li yo!   
\q1
\v 5 Chante lwanj a SENYÈ a avèk ap,  
\q1 avèk ap ak \x + \xo 98:5 \xt És 51:3\x* vwa melodi a.   
\q1
\v 6 Avèk \x + \xo 98:6 \xt Nonb 10:10\x* twonpèt ak son a kòn.  
\q1 Rele fò devan Wa a, SENYÈ a.   
\q1
\v 7 Kite \x + \xo 98:7 \xt Sòm 96:11\x* lanmè a fè gwo bri ak tout sa ki ladann,  
\q1 Lemonn ak tout sa ki rete ladann yo.   
\q1
\v 8 Kite \x + \xo 98:8 \xt Sòm 93:3\x* larivyè yo bat men yo.  
\q1 Kite mòn yo chante ansanm ak jwa   
\q1
\v 9 devan SENYÈ a,  
\q1 paske l ap vini pou jije latè.  
\q1 Li va jije lemonn ak ladwati Li  
\q1 E \x + \xo 98:9 \xt Sòm 96:10\x*pèp yo avèk jistis.   
\c 99  
\q1
\v 1 SENYÈ a renye! Kite pèp yo pran tranble.  
\q1 Li \x + \xo 99:1 \xt Egz 25:22\x* plase twòn Li an anwo cheriben yo.  
\q1 Kite latè pran tranble!   
\q1
\v 2 SENYÈ a gran nan Sion.  
\q1 Li \x + \xo 99:2 \xt Sòm 97:9\x* leve wo anwo tout pèp yo.   
\q1
\v 3 Kite yo louwe non Ou ki \x + \xo 99:3 \xt Det 28:58\x* gran e mèvèye;  
\q1 Se sen ke Li ye.   
\b  
\q1
\v 4 Pwisans a Wa a \x + \xo 99:4 \xt Sòm 11:7\x* renmen lajistis.  
\q1 Ou te etabli ekite.  
\q1 Ou te fè jistis ak ladwati Ou vin rive nan Jacob.   
\q1
\v 5 Leve wo SENYÈ, Bondye nou an!  
\q1 \x + \xo 99:5 \xt Sòm 132:7 \x*Adore nan machpye twòn Li an.  
\q1 Se sen ke Li ye.   
\b  
\q1
\v 6 Moïse avèk Aaron te pami prèt Li yo e  
\q1 Samuel te pami sila ki te rele non Li yo.  
\q1 Yo te \x + \xo 99:6 \xt Egz 15:25 \x*rele non SENYÈ a e Li te reponn yo.   
\q1
\v 7 Li \x + \xo 99:7 \xt Egz 33:9\x* te pale ak yo nan pilye nwaj la.  
\q1 Yo te kenbe temwayaj Li yo,  
\q1 avèk règleman ke Li te bay yo.   
\q1
\v 8 O SENYÈ, Bondye nou an, Ou te reponn yo.  
\q1 Ou te pou yo yon Bondye ki padone,  
\q1 men Ou te pran \x + \xo 99:8 \xt Egz 32:28\x*vanjans sou zak mechan yo.   
\q1
\v 9 Egzalte SENYÈ, Bondye nou an!  
\q1 Adore nan mòn sen Li an,  
\q1 paske sen se SENYÈ a, Bondye nou an!   
\c 100  
\d Yon Sòm Remèsiman an  
\q1
\v 1 \x + \xo 100:1 \xt Sòm 95:1\x* Rele fò a SENYÈ tout latè a!   
\q1
\v 2 \x + \xo 100:2 \xt Det 12:11-12\x* Sèvi SENYÈ a avèk kè kontan!  
\q1 Vini devan Li avèk chan lajwa.   
\q1
\v 3 Konnen ke SENYÈ a, Li menm, se Bondye.  
\q1 Se Li menm ki te \x + \xo 100:3 \xt Job 10:3-8\x* fè nou, e se pou Li nou ye.  
\q1 Nou se pèp Li e mouton patiraj Li.   
\q1
\v 4 Antre nan pòtay Li yo avèk remèsiman,  
\q1 e nan lakou Li yo avèk lwanj.  
\q1 Ba Li remèsiman!  
\q1 Beni non Li!   
\q1
\v 5 Paske Bondye bon.  
\q1 Lanmou dous li a dire jis pou tout tan,  
\q1 \x + \xo 100:5 \xt Sòm 119:90\x* e fidelite Li a tout jenerasyon yo.   
\c 101  
\d Yon Sòm David  
\q1
\v 1 Mwen va \x + \xo 101:1 \xt Sòm 51:14\x* chante de lanmou dous avèk jistis.  
\q1 A Ou menm, O SENYÈ, mwen va chante lwanj.   
\q1
\v 2 Mwen va prete atansyon a chemen san repwòch la.  
\q1 Kilè Ou va vini kote mwen?  
\q1 Mwen va mache anndan lakay mwen ak \x + \xo 101:2 \xt I Wa 9:4\x*entegrite nan kè m.   
\q1
\v 3 Mwen p ap mete okenn vye bagay devan zye m.  
\q1 Mwen rayi zèv a sila ki \x + \xo 101:3 \xt Jos 23:6\x* chite yo.  
\q1 Sa p ap tache men l sou mwen.   
\q1
\v 4 Yon \x + \xo 101:4 \xt Pwov 11:20\x* kè ki pèvès va oblije kite prezans mwen.  
\q1 Mwen p ap aksepte konnen okenn mal.   
\q1
\v 5 Nenpòt moun ki bay vwazen li kout lang an sekrè,  
\q1 li menm, mwen va detwi.  
\q1 Nenpòt moun ak \x + \xo 101:5 \xt Sòm 10:4\x*rega awogan oswa ògèy, mwen p ap sipòte li.   
\q1
\v 6 Zye m va sou fidèl a peyi a pou yo kab rete avè m.  
\q1 Sila ki mache nan chemen \x + \xo 101:6 \xt Sòm 119:1\x* san fot la, se li menm  
\q1 ki va sèvitè mwen.   
\q1
\v 7 Sila ki \x + \xo 101:7 \xt Sòm 43:1\x*pratike manti p ap rete lakay mwen.  
\q1 Sila ki bay manti p ap kenbe pozisyon li devan m.   
\q1
\v 8 Chak maten mwen va detwi tout mechan nan peyi yo,  
\q1 Pou m kab \x + \xo 101:8 \xt Sòm 118:10-12\x*koupe retire nan vil SENYÈ a, tout moun ki fè inikite yo.   
\c 102  
\q1
\v 1 Koute lapriyè mwen, O SENYÈ!  
\q1 Epi kite kri sekou mwen \x + \xo 102:1 \xt Egz 2:23\x*rive bò kote Ou.   
\q1
\v 2 Pa kache figi Ou sou mwen nan jou gwo twoub mwen an;  
\q1 Panche zòrèy Ou bò kote m.  
\q1 Nan jou ke m rele Ou a, \x + \xo 102:2 \xt Sòm 69:17\x*reponn mwen vit.   
\q1
\v 3 Paske jou m yo \x + \xo 102:3 \xt Sòm 37:20\x*te manje nèt nan lafimen,  
\q1 e zo m te chofe tankou yon chemine.   
\q1
\v 4 Kè m \x + \xo 102:4 \xt Sòm 90:5-6\x*fin frape tankou zèb.  
\q1 Li fennen nèt.  
\q1 Anverite, mwen bliye manje pen mwen.   
\q1
\v 5 Akoz gwo bri kri mwen yo,  
\q1 \x + \xo 102:5 \xt Job 19:20\x*zo m yo kole sou chè m.   
\q1
\v 6 Mwen sanble ak yon \x + \xo 102:6 \xt És 34:11\x*grangozye nan dezè.  
\q1 Mwen tankou yon frize nan gran savann.   
\q1
\v 7 Mwen \x + \xo 102:7 \xt Sòm 77:4\x*kouche zye tou louvri.  
\q1 Mwen tankou yon zwazo izole sou twati kay la.   
\q1
\v 8 Lènmi m yo repwoche m tout lajounen.  
\q1 Sila ki \x + \xo 102:8 \xt Trav 26:11\x*moke m yo sèvi ak non mwen kon madichon.   
\q1
\v 9 Paske mwen te manje sann kon pen e  
\q1 \x + \xo 102:9 \xt Sòm 42:3\x*mele bwason m ak dlo zye m,   
\q1
\v 10 akoz endiyasyon avèk kòlè Ou.  
\q1 Ou te \x + \xo 102:10 \xt Job 27:21\x*leve m wo e te jete m lwen.   
\q1
\v 11 Jou m yo tankou yon \x + \xo 102:11 \xt Job 14:2\x*lonbraj ki vin long.  
\q1 Mwen vin fennen tankou zèb.   
\q1
\v 12 Men Ou menm, O SENYÈ, Ou dire jis pou tout tan  
\q1 E \x + \xo 102:12 \xt Egz 3:15\x*non Ou jis a tout jenerasyon yo.   
\q1
\v 13 Ou va leve pou fè pitye sou Sion,  
\q1 paske se lè pou \x + \xo 102:13 \xt És 60:10\x*fè li gras.  
\q1 Lè apwente a fin rive l.   
\q1
\v 14 Anverite, sèvitè Ou yo twouve plezi nan wòch li yo.  
\q1 Yo plen tristès akoz pousyè li.   
\q1
\v 15 Pou sa, \x + \xo 102:15 \xt I Wa 8:43\x*nasyon yo va krent non SENYÈ a,  
\q1 e tout wa latè yo va krent glwa Ou.   
\q1
\v 16 Paske se SENYÈ a ki te \x + \xo 102:16 \xt Sòm 142:2\x*ranfòse Sion.  
\q1 Li te parèt nan glwa Li.   
\q1
\v 17 Li te \x + \xo 102:17 \xt Né 1:6\x*prete atansyon a lapriyè malere yo,  
\q1 e pa t meprize priyè yo.   
\b  
\q1
\v 18 Sa va ekri pou jenerasyon k ap vini an.  
\q1 Pou \x + \xo 102:18 \xt Sòm 22:31\x*yon pèp ki poko kreye kapab bay lwanj a SENYÈ a.   
\q1
\v 19 Li te gade anba soti nan wotè sen Li an.  
\q1 \x + \xo 102:19 \xt Sòm 33:13\x*Soti nan syèl la, SENYÈ a te veye sou latè,   
\q1
\v 20 pou tande vwa plenyen a prizonye a,  
\q1 pou \x + \xo 102:20 \xt Sòm 146:7\x*mete an libète sila ki te kondane a lanmò yo,   
\q1
\v 21 Pou lèzòm ta kab \x + \xo 102:21 \xt Sòm 22:22\x*pale sou non SENYÈ a nan Sion,  
\q1 e bay lwanj Li nan Jérusalem,   
\q1
\v 22 pandan \x + \xo 102:22 \xt Sòm 22:27\x*pèp yo rasanble ansanm ak  
\q1 wayòm yo, pou sèvi SENYÈ a.   
\b  
\q1
\v 23 Li fin febli fòs mwen nan chemen an.  
\q1 Li \x + \xo 102:23 \xt Sòm 39:5\x*rakousi nonb de jou mwen yo.   
\q1
\v 24 Mwen te di: “O Bondye mwen an,  
\q1 \x + \xo 102:24 \xt Sòm 39:13\x*pa rache m nan mitan jou mwen yo.  
\q1 Ane pa Ou yo dire pandan tout jenerasyon yo.   
\q1
\v 25 Depi tan ansyen yo, Ou te \x + \xo 102:25 \xt Jen 1:1\x*fonde latè,  
\q1 e syèl yo se zèv lamen Ou yo.   
\q1
\v 26 Malgre yo \x + \xo 102:26 \xt És 34:4\x*peri, Ou menm va rete toujou.  
\q1 Wi, tout bagay nan yo va vin epwize tankou yon vètman.  
\q1 Tankou rad, Ou va chanje yo, e yo va chanje.   
\q1
\v 27 Men Ou menm, se menm jan an Ou ye.  
\q1 Ane pa Ou yo p ap janm fini.   
\q1
\v 28 Pitit a sèvitè Ou yo va kontinye,  
\q1 e desandan pa yo va etabli devan Ou.”   
\c 103  
\d Yon Sòm David  
\q1
\v 1 \x + \xo 103:1 \xt Sòm 104:1-35\x*Beni SENYÈ a, O nanm mwen!  
\q1 Tout sa ki nan mwen, beni sen non Li!   
\q1
\v 2 Beni SENYÈ a, O nanm mwen,  
\q1 e pa janm \x + \xo 103:2 \xt Det 6:12\x*bliye benefis Li yo,   
\q1
\v 3 ki \x + \xo 103:3 \xt Egz 34:7\x*padone tout inikite ou yo,  
\q1 ki geri tout maladi ou yo,   
\q1
\v 4 ki rachte lavi ou soti nan fòs la,  
\q1 ki kouwone ou avèk lanmou dous avèk  
\q1 mizerikòd;   
\q1
\v 5 ki satisfè ane ou yo avèk bon bagay,  
\q1 Pou jenès ou vin \x + \xo 103:5 \xt És 40:31\x*renouvle tankou èg la.   
\q1
\v 6 SENYÈ a \x + \xo 103:6 \xt Sòm 99:4\x*fè zèv ladwati pou tout sila ki oprime yo.   
\q1
\v 7 Li te fè chemen Li yo byen klè a Moïse,  
\q1 zèv Li yo a fis Israël yo.   
\q1
\v 8 SENYÈ a plen \x + \xo 103:8 \xt Egz 34:6 \x*mizerikòd ak gras,  
\q1 lan nan kòlè e ranpli avèk lanmou dous.   
\q1
\v 9 Li p ap toujou goumen ak nou,  
\q1 ni Li p ap \x + \xo 103:9 \xt Jr 3:5-12\x*kenbe kòlè Li jis pou tout tan.   
\q1
\v 10 Li \x + \xo 103:10 \xt Esd 9:13\x*pa t aji avèk nou selon peche nou yo,  
\q1 ni rekonpanse nou selon inikite nou yo.   
\q1
\v 11 Paske menm jan syèl yo pi wo pase tè a,  
\q1 menm jan an lanmou dous Li a ye anvè sila ki krent Li yo.   
\q1
\v 12 Menm jan lès lwen lwès la,  
\q1 Se konsa li te retire transgresyon nou yo lwen nou.   
\q1
\v 13 Menm jan \x + \xo 103:13 \xt Mal 3:17\x*ke yon papa gen konpasyon pou pitit li yo,  
\q1 se konsa ke SENYÈ a gen konpasyon pou sila ki krent Li yo.   
\q1
\v 14 Paske Li menm, Li konnen jan nou fèt.  
\q1 Li sonje byen ke nou pa plis ke \x + \xo 103:14 \xt Jen 3:19\x*pousyè.   
\q1
\v 15 Men pou lòm, jou li yo se \x + \xo 103:15 \xt Sòm 90:5\x*tankou zèb.  
\q1 Tankou yon flè nan chan, se konsa li fleri.   
\q1
\v 16 Depi \x + \xo 103:16 \xt És 40:7\x*van fin pase sou li, li pa la ankò e  
\q1 plas li a pa rekonèt li ankò.   
\q1
\v 17 Men \x + \xo 103:17 \xt Sòm 25:6\x*lanmou dous a SENYÈ a,  
\q1 soti pou tout tan jis rive pou tout tan  
\q1 sou sila ki gen lakrent Li yo  
\q1 e ladwati Li a pitit pitit li yo,   
\q1
\v 18 pou sila ki kenbe akò Li yo,  
\q1 e sonje règleman Li yo pou fè yo.   
\q1
\v 19 SENYÈ a te etabli twòn li nan syèl la  
\q1 e souverènte li regne sou tout bagay.   
\q1
\v 20 Beni SENYÈ a, nou menm, zanj Li yo,  
\q1 pwisan nan fòs, ki akonpli pawòl Li,  
\q1 ki obeyisan a vwa pawòl Li!   
\q1
\v 21 Beni SENYÈ a, nou tout, lame Li yo,  
\q1 nou menm \x + \xo 103:21 \xt Sòm 104:4\x*ki sèvi Li nan fè volonte Li.   
\q1
\v 22 Beni SENYÈ a, nou tout, zèv Li yo,  
\q1 nan tout kote nan wayòm Li an.  
\q1 Beni SENYÈ a, O nanm mwen!   
\c 104  
\q1
\v 1 Beni SENYÈ a, O nanm mwen!  
\q1 O SENYÈ, Bondye mwen an, Ou tèlman gran.  
\q1 Ou \x + \xo 104:1 \xt Sòm 93:1\x*abiye avèk bèlte ak majeste.   
\q1
\v 2 Li kouvri Li menm ak limyè kon yon manto.  
\q1 \x + \xo 104:2 \xt És 40:22\x*Ki ouvri syèl la tankou yon rido tant.   
\q1
\v 3 Li poze gran travès wo chanm nan nan dlo.  
\q1 Li fè \x + \xo 104:3 \xt És 19:1\x*nwaj yo sèvi kon cha Li.  
\q1 Li mache sou zèl van an.   
\q1
\v 4 Li fè van yo vin mesaje Li.  
\q1 Flanm \x + \xo 104:4 \xt II Wa 2:11\x*dife yo se minis Li.   
\q1
\v 5 Li te \x + \xo 104:5 \xt Job 38:4\x*etabli tè a sou pwòp fondasyon li,  
\q1 pou l pa varye pou tout tan ni pou tout tan.   
\q1
\v 6 Ou te \x + \xo 104:6 \xt Jen 1:2\x*kouvri li avèk fon an tankou yon vètman.  
\q1 Dlo yo te kanpe anwo mòn yo.   
\q1
\v 7 Ak repwòch Ou, yo te sove ale.  
\q1 Lè vwa Ou te \x + \xo 104:7 \xt Sòm 29:3\x*sone, yo te kouri ale.   
\q1
\v 8 Mòn yo te leve, vale yo te vin fon  
\q1 nan \x + \xo 104:8 \xt Sòm 33:7\x*plas ke Ou te kòmande pou yo a.   
\q1
\v 9 Ou te plase yon \x + \xo 104:9 \xt Job 38:10\x*limit pou dlo yo pa ta depase,  
\q1 pou yo pa retounen kouvri tè a.   
\q1
\v 10 Li fè \x + \xo 104:10 \xt Sòm 107:35\x*sous yo vin koule nan vale yo.  
\q1 Yo koule antre mòn yo.   
\q1
\v 11 Yo bay dlo pou bwè a tout bèt chan yo.  
\q1 \x + \xo 104:11 \xt Job 39:5\x*Bourik mawon yo bwè pou satisfè swaf yo.   
\q1
\v 12 Akote yo, zwazo syèl yo va \x + \xo 104:12 \xt Mat 8:20\x*poze kay.  
\q1 Yo va leve vwa yo pami branch bwa yo.   
\q1
\v 13 Li awoze mòn yo soti nan chanm anwo yo.  
\q1 \x + \xo 104:13 \xt Jr 10:13\x*Latè satisfè avèk fwi a zèv Li yo.   
\q1
\v 14 Li fè \x + \xo 104:14 \xt Job 38:27\x*zèb grandi pou bèt yo e vèdi  
\q1 pou zèv a lòm nan,  
\q1 pou li kab fè manje sòti nan tè a,   
\q1
\v 15 e diven ki fè kè a lòm kontan an,  
\q1 pou li kab fè figi li klere ak lwil,  
\q1 ak manje ki \x + \xo 104:15 \xt Jen 18:5\x*bay soutyen a kè lòm nan.   
\q1
\v 16 Pyebwa a SENYÈ yo bwè dlo jiskaske yo plen,  
\q1 pye sèd Liban ke Li te plante yo,   
\q1
\v 17 kote zwazo yo fè nich yo.  
\q1 Sigòy ki fè kay li nan pye sipre yo.   
\q1
\v 18 Mòn wo yo se pou kabrit mawon yo.  
\q1 Gwo falèz yo se yon kote pou \x + \xo 104:18 \xt Lev 11:5 \x*daman yo kache.   
\q1
\v 19 Li te fè lalin nan \x + \xo 104:19 \xt Jen 1:14\x*pou sezon yo.  
\q1 Solèy la konnen plas kote pou l vin kouche a.   
\q1
\v 20 Ou te chwazi tenèb la e li te devni lannwit,  
\q1 pou tout \x + \xo 104:20 \xt Sòm 50:10\x*bèt forè yo mache toupatou.   
\q1
\v 21 Jenn lyon yo rele fò dèyè viktim yo,  
\q1 e \x + \xo 104:21 \xt Sòm 145:15\x*chache manje yo nan men Bondye.   
\q1
\v 22 Solèy la vin leve.  
\q1 Yo retire yo pou ale kouche nan \x + \xo 104:22 \xt Job 37:8\x*tanyè yo.   
\q1
\v 23 Lòm ale fè \x + \xo 104:23 \xt Jen 3:19\x*travay li.  
\q1 Li fè fòs jis lannwit rive.   
\q1
\v 24 O SENYÈ, a la zèv Ou yo anpil!  
\q1 Nan sajès, Ou te fè tout bagay.  
\q1 Latè ranpli ak byen Ou yo.   
\q1
\v 25 Genyen \x + \xo 104:25 \xt Sòm 8:8\x*lanmè, gran e vast.  
\q1 Ladann, gen gwo ekip pwason ki pa kab menm konte  
\q1 gwo bèt, kòn ti bèt.   
\q1
\v 26 Genyen gwo bato k ap pase ladann, ak  
\q1 levyatan ke Ou te fòme pou fè spò ladann nan.   
\q1
\v 27 Yo tout ap tann Ou pou \x + \xo 104:27 \xt Job 36:31\x*bay yo manje nan lè yo.   
\q1
\v 28 Ou bay yo, e yo ranmase li.  
\q1 Ou \x + \xo 104:28 \xt Sòm 145:16\x*ouvri men Ou, e yo satisfè ak bonte.   
\q1
\v 29 Ou kache figi Ou, e yo chagren nèt.  
\q1 Ou retire \x + \xo 104:29 \xt Jen 3:19\x*lespri yo; yo mouri e yo retounen nan pousyè yo.   
\q1
\v 30 Ou voye \x + \xo 104:30 \xt Job 33:4\x*Lespri Ou deyò; yo vin kreye.  
\q1 Konsa, Ou renouvle fas tè a.   
\q1
\v 31 Kite \x + \xo 104:31 \xt Sòm 86:12\x*glwa SENYÈ a dire jis pou tout tan.  
\q1 Kite SENYÈ a rejwi nan zèv Li yo.   
\q1
\v 32 Li gade tè a e tè a vin \x + \xo 104:32 \xt Hab 3:10\x*tranble.  
\q1 Li touche mòn yo e yo fè lafimen.   
\q1
\v 33 Mwen va chante a SENYÈ a \x + \xo 104:33 \xt Sòm 63:4\x*toutotan ke m ap viv.  
\q1 Mwen va chante lwanj a Bondye mwen an toutotan ke m la.   
\q1
\v 34 Kite \x + \xo 104:34 \xt Sòm 19:4\x*refleksyon mwen yo fè L plezi.  
\q1 Pou kont mwen, mwen va kontan nan SENYÈ a.   
\q1
\v 35 Kite pechè yo vin disparèt sou tè a,  
\q1 E \x + \xo 104:35 \xt Sòm 37:10\x*mechan yo vin pa la ankò.  
\q1 Beni SENYÈ a, O nanm mwen.  
\q1 Bay SENYÈ a lwanj!   
\c 105  
\q1
\v 1 O bay remèsiman a SENYÈ a! Rele non Li!  
\q1 Fè zèv Li yo \x + \xo 105:1 \xt Sòm 145:12\x*rekonèt pami pèp yo.   
\q1
\v 2 Chante a Li menm. Chante lwanj a Li.  
\q1 \x + \xo 105:2 \xt Sòm 77:12\x*Pale sou tout mèvèy Li yo.   
\q1
\v 3 Bay non Li glwa!  
\q1 Kite \x + \xo 105:3 \xt Sòm 33:21\x* kè a sila ki chache SENYÈ yo vin kontan.   
\q1
\v 4 Chache SENYÈ a ak fòs Li.  
\q1 \x + \xo 105:4 \xt Sòm 27:8\x*Chache fas Li san rete.   
\q1
\v 5 Sonje mèvèy ke Li te fè yo,  
\q1 mirak Li yo avèk \x + \xo 105:5 \xt Sòm 119:13\x*jijman ke bouch Li te pale yo.   
\q1
\v 6 O jèm Abraham, sèvitè Li a, O fis Jacob la,  
\q1 sila ke Li te \x + \xo 105:6 \xt I Kwo 16:13\x*chwazi yo!   
\q1
\v 7 Li se SENYÈ a, Bondye nou an.  
\q1 \x + \xo 105:7 \xt És 26:9\x*Jijman Li yo nan tout latè.   
\q1
\v 8 Li te sonje akò Li a jis pou tout tan,  
\q1 pawòl ke Li te pase lòd bay pandan \x + \xo 105:8 \xt Det 7:9\x*mil jenerasyon.   
\q1
\v 9 Akò ke Li te fè avèk Abraham nan,  
\q1 ak \x + \xo 105:9 \xt Jen 26:3\x*sèman ke Li te fè avèk Isaac la.   
\q1
\v 10 Li te \x + \xo 105:10 \xt Jen 28:13-15\x*konfime li a Jacob kon yon règleman,  
\q1 a Israël kon yon akò ki la pou tout tan.   
\q1
\v 11 Konsa Li te di: “A ou menm, Mwen va bay peyi  
\q1 Canaan kon \x + \xo 105:11 \xt Jos 23:4\x*pòsyon eritaj ou,”   
\q1
\v 12 Sa te fèt lè se te sèlman kèk grenn moun ke yo te ye,  
\q1 pa anpil menm, mele ak moun \x + \xo 105:12 \xt Jen 23:4\x*etranje yo ladann l.   
\q1
\v 13 Yo t ap mache toupatou  
\q1 soti nan yon nasyon pou rive nan yon lòt,  
\q1 soti nan yon wayòm pou rive kote yon lòt pèp.   
\q1
\v 14 Li \x + \xo 105:14 \xt Jen 20:7\x*pa t kite pèsòn peze yo.  
\q1 Wi, Li te repwoche wa yo pou koz a yo menm:   
\q1
\v 15 \x + \xo 105:15 \xt Jen 26:11\x*“Pa touche onksyone mwen yo!  
\q1 Pa fè pwofèt Mwen yo okenn mal!”   
\q1
\v 16 Li te \x + \xo 105:16 \xt Jen 41:54\x*rele gwo grangou rive nan peyi a.  
\q1 Li te kraze sous pen an nèt.   
\q1
\v 17 Li te voye yon nonm devan yo, Joseph ki te vann kon esklav.   
\q1
\v 18 Yo te aflije \x + \xo 105:18 \xt Jen 39:20\x*pye li ak chenn.  
\q1 Joseph, pou kont li, te kouche nan fè yo,   
\q1
\v 19 jiskaske pawòl li te vin acheve.  
\q1 \x + \xo 105:19 \xt Jen 40:20\x*Pawòl SENYÈ a te fè l kanpe dyanm.   
\q1
\v 20 \x + \xo 105:20 \xt Jen 41:14\x*Wa a te voye lage li.  
\q1 Dirijan a pèp la menm, te bay li libète.   
\q1
\v 21 Li te \x + \xo 105:21 \xt Jen 41:40-44\x*fè li mèt lakay li ak chèf sou tout byen li yo,   
\q1
\v 22 pou mete prens li yo nan prizon lè l te pito,  
\q1 pou l te kab enstwi ansyen sa yo sajès.   
\q1
\v 23 Israël osi te rive an Égypte.  
\q1 Konsa Jacob te \x + \xo 105:23 \xt Trav 13:7 \x*vin demere nan peyi Cham nan.   
\q1
\v 24 SENYÈ a te fè pèp pa Li vin peple anpil.  
\q1 Li te \x + \xo 105:24 \xt Egz 1:7-9\x*fè yo vin pifò ke advèsè yo.   
\q1
\v 25 Li te \x + \xo 105:25 \xt Egz 1:8\x*vire kè yo pou yo rayi pèp Li a,  
\q1 pou yo aji ak gwo mechanste avèk sèvitè Li yo.   
\q1
\v 26 Li te \x + \xo 105:26 \xt Egz 3:10\x* voye Moïse, sèvitè Li a,  
\q1 avèk Aaron ke Li te chwazi.   
\q1
\v 27 Yo te \x + \xo 105:27 \xt Sòm 78:43-51\x*fè zèv mèvèy Li yo pami yo,  
\q1 avèk mirak nan peyi Cham yo.   
\q1
\v 28 Li te \x + \xo 105:28 \xt Egz 10:21-22\x*voye tenèb e te fè l fènwa.  
\q1 Epi yo pa t fè rebèl kont pawòl Li yo.   
\q1
\v 29 Li te \x + \xo 105:29 \xt Egz 7:20-21\x*fè dlo yo devni san  
\q1 e te fè pwason yo mouri.   
\q1
\v 30 Peyi yo te ranvaye avèk \x + \xo 105:30 \xt Egz 8:6\x*krapo,  
\q1 menm jis rive nan chanm a wa yo.   
\q1
\v 31 Li te pale e te vin rive yon \x + \xo 105:31 \xt Egz 8:16-21\x*epidemi  
\q1 mouch yo, ak vèmin nan tout tèritwa yo.   
\q1
\v 32 Li te bay yo \x + \xo 105:32 \xt Egz 9:23-25\x*lagrèl pou lapli,  
\q1 avèk dife brile nan peyi yo.   
\q1
\v 33 Li te frape fè desann tout chan fwi yo e  
\q1 te kraze fann pyebwa nan tèritwa yo.   
\q1
\v 34 Li te pale e \x + \xo 105:34 \xt Egz 10:12-15\x*krikèt volan yo te vini.  
\q1 Ak jenn krikèt san kontwòl.   
\q1
\v 35 Yo te manje tout sa ki te vèt nan peyi yo,  
\q1 e te manje fwi a tèren yo.   
\q1
\v 36 Anplis, Li te frape touye tout premye ne nan peyi yo,  
\q1 \x + \xo 105:36 \xt Jen 49:3 \x*premye fwi a fòs yo.   
\q1
\v 37 Li te fè yo sòti ak \x + \xo 105:37 \xt Egz 12:35-36\x*ajan ak lò.  
\q1 Pami pèp Li yo, pa t gen yon grenn ki te tonbe.   
\q1
\v 38 Égypte te \x + \xo 105:38 \xt Egz 12:33\x*kontan lè yo te sòti,  
\q1 paske laperèz yo te fin tonbe sou yo.   
\q1
\v 39 Li te louvri yon \x + \xo 105:39 \xt Egz 13:21\x*nwaj kon kouvèti,  
\q1 avèk dife ki pou klere nan nwit lan.   
\q1
\v 40 Yo te mande e li te pote zòtolan pou  
\q1 te satisfè yo avèk \x + \xo 105:40 \xt Egz 16:15 \x*pen syèl la.   
\q1
\v 41 Li te ouvri wòch la e \x + \xo 105:41 \xt Egz 17:6\x*dlo te sòti ladann.  
\q1 Li te koule kote sèch yo tankou yon rivyè.   
\q1
\v 42 Li te \x + \xo 105:42 \xt Jen 15:13-14\x*sonje pawòl sen Li yo avèk Abraham, sèvitè Li a.   
\q1
\v 43 Konsa, Li te mennen fè sòti pèp Li a avèk jwa,  
\q1 sila ke Li te chwazi avèk \x + \xo 105:43 \xt Egz 15:1\x*gwo kri ak kè kontan yo.   
\q1
\v 44 Li te \x + \xo 105:44 \xt Jos 11:16-23\x*bay yo, anplis, peyi a nasyon yo,  
\q1 Pou yo ta pran posesyon a zèv a pèp yo,   
\q1
\v 45 pou yo te kab \x + \xo 105:45 \xt Det 4:1-40\x*kenbe règleman Li yo, e swiv lwa Li yo.  
\q1 Louwe SENYÈ a!   
\c 106  
\q1
\v 1 Louwe SENYÈ a!  
\q1 O bay remèsiman a SENYÈ a, paske Li bon,  
\q1 paske \x + \xo 106:1 \xt I Kwo 16:34-41\x*lanmou dous Li an se pou tout tan.   
\q1
\v 2 Se kilès ki kab pale sou zèv pwisan a SENYÈ yo,  
\q1 Oswa fè vin parèt tout lwanj Li yo?   
\q1
\v 3 A la beni sila ki \x + \xo 106:3 \xt Sòm 15:2\x*kenbe jistis yo beni.  
\q1 Beni se sila ki pratike ladwati nan tout tan yo!   
\q1
\v 4 Sonje mwen, O SENYÈ, nan \x + \xo 106:4 \xt Sòm 44:3\x*favè Ou anvè pèp Ou a.  
\q1 Vizite mwen avèk sali Ou,   
\q1
\v 5 pou m kab wè sila ke Ou te chwazi yo \x + \xo 106:5 \xt Sòm 1:3\x*byen reyisi;  
\q1 pou m kab rejwi nan kè kontan a nasyon Ou an,  
\q1 pou m ka bay glwa de eritaj Ou.   
\b  
\q1
\v 6 Nou te peche menm jan \x + \xo 106:6 \xt II Kwo 30:7 \x*ak papa zansèt nou yo.  
\q1 Nou te fè inikite; nou te aji mal.   
\q1
\v 7 Papa zansèt nou yo an Égypte pa t konprann mèvèy Ou yo.  
\q1 Yo pa t sonje lanmou dous Ou,  
\q1 men yo te \x + \xo 106:7 \xt Egz 14:11-12\x*fè rebèl bò lanmè a, nan Lanmè Wouj la.   
\q1
\v 8 Sepandan, Li te sove yo pou koz non Li,  
\q1 pou L te kab \x + \xo 106:8 \xt Egz 9:16 \x*fè pwisans Li rekonèt.   
\q1
\v 9 Konsa, Li te repwoche Lanmè Wouj, e li te vin sèch,  
\q1 Li te \x + \xo 106:9 \xt És 63:11-13\x*mennen yo pase nan fon yo,  
\q1 menm jan yo te pase nan dezè a.   
\q1
\v 10 Konsa, Li te \x + \xo 106:10 \xt Egz 14:30\x*sove yo depi nan men a sila ki te rayi yo,  
\q1 e te rachte yo soti nan men a lènmi an.   
\q1
\v 11 \x + \xo 106:11 \xt Egz 14:27-28\x*Dlo yo te kouvri advèsè yo.  
\q1 Nanpwen nan yo ki te rete.   
\q1
\v 12 Nan lè sa a, yo te kwè nan pawòl Li yo.  
\q1 Yo te chante lwanj Li.   
\b  
\q1
\v 13 Men byen vit, yo te \x + \xo 106:13 \xt Egz 15:24\x*bliye zèv Li yo.  
\q1 Yo pa t tann konsèy Li,   
\q1
\v 14 men yo te vin gen \x + \xo 106:14 \xt Nonb 11:4\x*gwo anvi nan savann nan,  
\q1 e te pase Bondye a leprèv nan dezè a.   
\q1
\v 15 Pou sa, Li te \x + \xo 106:15 \xt Nonb 11:31\x*ba yo sa yo te mande a,  
\q1 men te voye yon maladi epwizan pami yo.   
\q1
