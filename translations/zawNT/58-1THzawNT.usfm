\id 1TH
\h 1 Tesalonicenses
\toc1 Guijtz Ganid Lo Rebeṉ Tesalónica
\toc2 1 Tesalonicenses
\toc3 1 Ts.
\mt1 Guijtz Ganid Lo Rebeṉ Tesalónica
\c 1
\s1 Bacuaa Pabl con rexamigwni lo guidoo guedx Tesalónica
\p 
\v 1 Narä, Pabl, näjza Silvan, näjza Timoteu cacuaanu guijtzre lojtu, resa'nu ni yu' guidoo lo guedx Tesalónica, reni yu' lo Dios Xtadnu näjza lo Dad Jesucrist. Guspaa Dios näjza Jesucrist lajztu, guscuecdxizareni lajztu.
\s1 Xho huililajz beṉ Tesalónica xtidx Dios
\p 
\v 2 Guet-guejt rdeednu xquixtios lo Dios xcuent guiraatu, rnaduxhza laaznu la'tu cheni rbejdx rniabnu lo Dios.
\v 3 Ruzä'tnu lo Dios xtadnu xho rujntu dzuun sa'csi rililajztu xtidx Dios; näjza xho runduxhtu dzuun te racnäjtu sa'tu ni xhet rajpdi sa'csi rinälajztu Dios; näjza xho rutip lajztu cabäjztu guibi' Dad Jesucrist lo guedxliuj.
\v 4 Bejtznu, racbeenu sanälajz Dios la'tu, laani aguleni la'tu.
\v 5 Sa'csi che basule'nu xtidx Dios lojtu, et ganax diidxtis gujcni, niluxh xcäḻrnibee Sprit Dxan xten Dios neṉ lastootu bejn gucbeepactu diidx ni najc didxlii. Nanchesa'ctu xho gujcnu che guyu'nu lojtu. Si'c baluiinu la'tu te guibaṉsa'ctu.
\p 
\v 6 Sigajcni nabaṉnäjnu Dad Jesucrist sigajcza gusloj cua'tu xmoodnu, basoobzatu diidx guideb xcäḻrbalajz Sprit Dxan xten Dios ni baniidxni lojtu, mase gudejdtu trabajw.
\v 7 Si'c gujc te baluiitu loj guiraa reni rililajz nez Macedonia näjza nez Acaya xho nungäjḻ gac.
\v 8 Ni'c abire'ch xtidx Dios, xhet nejzdi Macedonia näjza Acayatis, bire'chza diidx guira nejz. Ro'c najnreni xho sanälajztu Dios, ni'c xhetru nanabti guiniinu lojreni.
\v 9 Alga lagajc laareni rujyreni diidx xho guyu'nu lojtu; nägajcza xho basaantu gojṉtu rebanäjb te rajṉtu Dios ni nabajṉpac ni najc guliipac.
\v 10 Rujyzareni diidx xho cabäjzzatu guibisac Jesucrist lo guedxliuj. Laazani najc Xi'n Dios ni guläs Dios lo rebeṉgut, Jesucrist ni rusḻaa nuurnu lo xcäḻrdxe'ch Dios ni churu siääd.
\c 2
\s1 Xhi bejn Pabl neṉ guedx Tesalónica
\p 
\v 1 N̲aj lagajc la'tu najntu, bejtznu, et xlia'di bio'pnu lojtu.
\v 2 Et najntu xho gudéreni loonu, basacsíreni nuurnu guedx Filipos. Niluxh mase gudejdnu trabajw, gusutijpnu lo Dios, xhet bidxejbtinu basule'nu xtidx Dios lojtu, mase gudejdnu trabajwduxh.
\v 3 Sa'csi dinu nulijdx la'tu con didx-xhii, niclaza didx-dxuudx, niclaza diidx ni rusguee.
\v 4 Sa'csi rsoobnu xtidx Dios basannäjni nuurnu xtiidxni, ni'c rusule'nu xtidx Dios. Dinu guinii diidx te jiansa'cnu lo bejṉ, rniinu diidx te jiansa'cnu lo Dios ni ruhuii lastoonu.
\v 5 Anajntu xho basule'nu xtidx Dios. Nicla tej dinu ninii xhi stee diidx ni xhet sajcdi lojtu. Dizanu nusule' xtidx Dios te xhiga'tz niennu gaan xhi nica'nu. Dios nanchee xcuent ni riennu.
\v 6 Dizanu nidiil guiliä'p bejṉ xpala'nnu, niclaza la'tu, niclaza chu stee bejṉ, mase nungäjḻ niennu niacbeetu rajpnu yäḻrnibee sa'csi baxhaḻ Jesucrist nuurnu.
\v 7 Niluxh guc nadolajznu che guyu'nu lojtu, cuanäjnu la'tu si'c rcanäj te naṉ rexpäzni.
\v 8 Sa'csi huinälazduxhnu la'tu, biennu xhigab xhet ganaxdi xtidx Dios guiniidxnu lojtu, näjza lagajc xaimnu guniidxnu te guseednu la'tu xtidx Dios sa'csi sanälazduxhnu la'tu.
\v 9 Bejtznu, la'tu rnalajztu xho biennu dzuun te biennu gaan xcäḻnabaannu. Biennu dzuun dxej-yääl, te di niednäjtu nuurnu laḻ ni basule'nu xtidx Dios lojtu.
\p 
\v 10 Lagajc la'tu nancheetu, sigajc nanchee Dios, laaca biennu che guyu'nu lojtu: gujcnu bejṉ ni raṉduxh Dios, gujcnu beṉdxojṉ, gujcnu beṉsa'c.
\v 11 Anajntu xho baliidxnu la'tu, xho bascuecdxinu lajztu si'c runnäj te dad rexingaanni.
\v 12 Guiraa dee biennu, te guibaṉsa'ctu si'c nungäjḻ gun reni najc xi'n Dios, lagajc Dios ni gurejdx la'tu te chunäjtuni lo xcäḻrnibeeni näjza lo xcäḻrdimbicha'ni.
\p 
\v 13 Ni'cni rdedduxhnu xquixtios lo Dios sa'csi che biejn diajgtu xtidx Dios ni basule'nu lojtu, cua'tuni si'c xtidx Dios xhet si'c xtiidxdi beṉ guedxliuj. Niluxh gulii xtidx Diosni, sa'csi rusiani lastoo renani rililajz.
\v 14 Bejtznu, dxejcti bejntu lagajc si'c rujn rebejṉ xquidoo Dios neṉ reguedx Judea reni najc xpeṉ Jesucrist; luxh gusajctu lagajc ni gusajcreni, basacsí rebeṉ lajdxtu la'tu. Sigajcza birinajl rexpeṉ Israelreni.
\v 15 Rexpeṉ Israel bagu't Dad Jesucrist, si'cza bagu'treni lagajc rexprofe'treni, renani bacuaa xtidx Dios, barilaagwzareni nuurnu. Direni chanälajz Dios, dizareni gusaan chanajl rebejṉ Jesucrist.
\v 16 Che rlajznu gulijdxnu reni digac rexpeṉ Israel, te näjza laareni ḻaareni lo dojḻ, direni gusaan, si'ctis cagutajḻreni xtojḻreni. Niluxh ṉaj abiäädpac yäḻrdxe'ch xten Dios yejcreni.
\s1 Rlajz Pabl nihuisacni ro'c
\p 
\v 17 Bejtznu, mase biriinu ro'c, ṉaj dirunu guihuii lojtu, rnalazduxhnu la'tu, batijp lajznu jio'pnu ro'c, rlazduxhnu fisacnu lojtu.
\v 18 Rlajznu nio'pnu, narä, Pabl xhidal huält rlazä niälä, niluxh beṉdxab di nusaan.
\v 19 ¿Xhini'c najc xcäḻrbääznu, xcäḻrbalajznu, xcäḻracnaronu? Lagajc la'tu gactuni che suunu nez loj Jesucrist che jiädsac Dad Jesucrist.
\v 20 La'tu najc ni ruspaa lajznu ni rliä'pza xpala'nnu nez lo Dios.
\c 3
\p 
\v 1 Dxejc, che dirunu nutijp lajznu, biennu xhigab bianxtebä guedx Atenas.
\v 2 Dxejc baxhaḻä Timoteu, bejtznu nez loj Jesucrist, te biädhuiini la'tu, sa'csi laani najcni te xpeṉ Dios ni runnäj nuurnu dzuun, rniini xtidx Jesucrist, te guscuecdxini lajztu, guzudzu'tzni xcäḻrililajztu.
\v 3 Te nicla tejtu di guidxejb che jiääd reyäḻhuin sa'csi la'tu anajntu agule Dios nuurnu ni'c sidejdnu trabajw.
\v 4 Cheni yusijcnu lojtu, rnixgaanu lojtu sidejdnu trabajw; niluxh si'cni agusojb diidxga ṉaj.
\v 5 Ni'cni diruna nutiplazä, baxhaḻä chu jiädnä diidx xho najc xcäḻrililajztu, sa'csi cadxebä andi abasguee beṉdxab la'tu, luxh xlia'si biennu dzuun guyu'nu lojtu.
\p 
\v 6 N̲aj agubi' Timoteu, biädhuiini la'tu. Biadnäni ganax didxlii xho sanuu rililajztu xtidx Jesucrist, xho rinälajztuni, näjza sanuutis rnalajztu nuurnu, rlajzzatu fiitu loonu, sigajcza nuurnu rlajznu fiinu lojtu.
\v 7 Ni'cni, betznu, masä riäädx xhixtennu, masä rdeednu trabajw, rbalajznu sa'csi la'tu sanuutis rililajztu xtidx Dios.
\v 8 N̲aj laaca rdxunnu sa'csi racbeenu sudzu'tztu nez loj xtidx Dad Jesucrist.
\v 9 Xhocha gac guideednu xquixtios lo Dios xcuent guiraatu näj xcuent yäḻrbalajz ni yu' lastoonu xcuent la'tu nez lo Dios.
\v 10 Dxej-yääl rniabnu lo Dios gusaanni jiophuiinu la'tu te gusa'nu guiraa rediidx ni cayäädx gacbeetu xcuent xcäḻrlilajztu.
\p 
\v 11 Rniabnu lo Xtadnu Dios, näjza lo Dad Jesucrist, gacnäjreni nuurnu te gac jiophuiinu la'tu.
\v 12 Rniabzanu lo Dad Jesucrist, gunni gustiobruni lastootu te ga'prutu yäḻrinälajz loj resa'tu näjza loj guiraa rebejṉ, si'cni rinälajznu la'tu,
\v 13 te gunni sudzu'tz lastootu, na'c ga'ptu dojḻ nez lo Xtadnu Dios, che jiääd Jesucrist näjza guiraa rexpejṉni xhaguibaali.
\c 4
\s1 Guibajṉnu si'c rchaglajz Dios
\p 
\v 1 N̲aj, rebejtznu, rniabduxhnu lojtu, rulijdxnu la'tu con laj Dad Jesucrist, guibajṉtu si'cni baluiinu la'tu nungäjḻ guibajṉtu te guspaatu lajz Dios, te si'c chanuutis guibaṉsa'ctu nez lo Dios.
\p 
\v 2 La'tu, anajntu rediidx ni baluiinu lojtu con xcäḻrnibee Dad Jesucrist.
\v 3 Lagajc Dios rlajz nayatis guibaṉsa'ctu, na'c gun niguii dojḻ guesnäj gunaa ni di gac chäälni, sigajcza na'c guesnäj gunaa niguii ni di gac chäälni.
\v 4 Tejgatu gantu xho guibaṉnäjtu chäältu nayatis näjza xpala'nni.
\v 5 Xhet si'c ni rujndi regunadxab näjza reniguii, nicla si'c ni rujn rebejṉ ni di gumbee Dios.
\v 6 Rut chutejditu gusguee bejtzni lo redzunguijdxre, sa'csi Dios susacsí guiraa rebejṉ ni rujnza redojḻre, ni'cni abiniinu lojtu, agunixgaanu diidxre lojtu.
\v 7 Sa'csi Dios gurejdxni nuurnu te guibajṉnu lo yäḻnabaṉnaya xtenni, xhet lo yäḻnabaṉdxuudxdi.
\v 8 Ni'cni bejṉ ni di gucuadiajg rediidxre, dini gac xtiidx te bejṉ ni dini cuadiajg, xtiidxpac Dios ni dini cuadiajg, Dios nani abaniidx Sprit Dxan xtenni loonu.
\p 
\v 9 Ditu guiquiin gucuaäru diidx xho chanälajztu resa'tu, sa'csi lagajc Dios abaluiitu xho chanälajztu resa'tu.
\v 10 Luxh rinälajztu guiraa reni rililajz, guiraa reni siääd guideb nez Macedonia. Ni'cni rniabnu lojtu bejtznu, chä'pru xcäḻrinälajztu.
\v 11 Coḻgutijp lajztu, dxitis coḻguibajṉ, coḻjiu xtzuuncatu, lagajc ṉaatu coḻyejn dzuun si'cni agunibeenu guntu.
\v 12 Te fii rebejṉ ni di chalilajz laaca nabaṉsa'ctu, nägajcza te xhet jiäädxdi xhi rquiintu.
\s1 Xho gac che jiädsac Jesucrist lo guedxliuj
\p 
\v 13 Bejtznu, rlajznu gacbeetu xcuent rebeṉgut te di gac-huin lajztu si'c rujn rebejṉ ni di chalilajz xtidx Dios.
\v 14 Si'c ni rililajznu gujt Jesucrist, dxejc gubaṉsacni, sigajcza rililajznu suspaṉsac Dios guiraa reni nagayejs neṉ baa, renani huililajz xtidx Jesucrist. Luxh che guibi' Jesucrist, siädnänireni.
\p 
\v 15 Xcuent xcäḻrnibee Jesucrist rniä lojtu, nuurnu ni nabajṉnu che jiädsac Jesucrist, dinu nid loj reni nagayejs neṉ baa.
\v 16 Sa'csi lagajc Dad Jesucrist siäjt lo guedxliujre, sibedxa'ni, siejnza xse' guixhajg ni rnibee, sibedxa'za trompet xten Dios. Dxejc sibaṉxgaa reni nagayejs neṉ baa, reni huililajz xtidx Crist.
\v 17 Dxejc nuure ni nabaṉsijcnu sidxaagnureni neṉ rebäj te lo bej chachagloonu Dad. Si'c chonnu cholaznäjnuni par tejpas.
\v 18 Ni'cni rniä lojtu, coḻcuecdxilajz sa'tu con rediidxre.
\c 5
\p 
\v 1 Niluxh xcuent redxejga, reijzga, xhet riquiinditu gucuaäni lojtu,
\v 2 sa'csi la'tu anansa'ctu sidzujṉ dxej ni jiääd Jesucrist cheni rut cayunlojdini, sigajc che riääd te gubaan yääl.
\v 3 Che canii bejṉ: “laaca dxunnu, dxunsa'cnu”, chela gacbeereni acadejdreni trabajw si'c che rdzujṉ yäḻnayan te gunaa che rajl xi'nni, luxh digacdi guxuṉreni lojni.
\v 4 Niluxh bejtznu, di gac nayäältu te di che xhet cayunlojditu dxej xten Jesucrist, guidzuṉxhiga'tz dxejga si'c gubaan.
\v 5 Sa'csi guiraatu najctu beṉsa'c nabajṉtu lo bianij, lo rdxee, dinu gac beṉguijdx, dinu guibajṉ lo yääl, lo yäḻrcäjy.
\v 6 Ni'cni di nungäjḻ guidiesnu si'c rejs stecuaa bejṉ, ni'cni nungäjḻ sunasiṉnu na'cza jiennu redojḻ ni rlajz tiejxhnu.
\v 7 Reni rejs, rejsreni yääl, reni rsiojz, rsiojzreni yääl.
\v 8 Niluxh nuure nabajṉnu lo rdxee, ni'cni nanab na'c jiennu si'c, riäjḻ xca'nu yäḻrililajz näjza yäḻrinälajz si'c rca' soldaad gamangw guiib ni rajcwni, ni rusäuu lastooni. Riäjḻza guiläzdzu'tznu sa'csi yäḻrusḻaa lo dojḻ najc si'c xhumbrel-guiib ni ru' yejc soldaad ni rusäuu yejcni.
\v 9 Sa'csi di Dios nibe nuurnu te chonnu gabijl, alga guleni nuurnu te xca'nu yäḻnabajṉ ni rudeed xi'nni, Jesucrist.
\v 10 Sa'csi gujt Jesucrist lacuaa nuurnu, te guibaṉnäjnuni masä nabajṉnu lo guedxliujre o nagayejsnu neṉ baa che guibi'ni.
\v 11 Ni'cni, coḻguspaa lajz sa'tu, tejtu sigajcza steetu, sigajcni cayujntu ṉaj.
\s1 Rulijdx Pabl resa'ni
\p 
\v 12 Bejtznu, rniabduxhnu lojtu, coḻhuiduxh reni ruluii xtidx Dios lojtu, sa'csi agule'c Dadreni te guinibeereni, te gulijdxreni la'tu.
\v 13 Riäjḻza chanälazduxhtureni xcuent dzuun ni rujnreni. Coḻcuedxi con resa'tu.
\p 
\v 14 Rulijdxnu la'tu, bejtznu, coḻgulijdx reni najc beṉlatsiaj; coḻsudzu'tz lajz reni guxii rbalajz lo xnez Dios; coḻgacnäj reni di gumbesa'c xtidx Dios, coḻcuecdxi lajz guiraasi bejṉ.
\p 
\v 15 Coḻhuii di chu tejtu gunza doḻguijdx lo rebejṉ ni rujn doḻguijdx. Laaca guntu ganax dzunsa'c lo sa'tu, sigajcza lo chutis bejṉ.
\p 
\v 16 Coḻguibalajztis guideb nabajṉtu.
\v 17 Na'c cuääz guiniitu lo Dios.
\v 18 Mase xhitis rsiajctu, coḻdeed xquixtios lo Dios, sa'csi si'c rlajz Dios gun reni rililajz Jesucrist.
\p 
\v 19 Di cuälaztu xtidx Sprit Dxan xten Dios ni rniini neṉ lastootu.
\v 20 Na'c cuälaztu xtidx reni rnii xtidx Dios xcuent nani churu gac.
\v 21 Coḻquiil guiraa rediidx, coḻjiannäjtis rediidx ni najc didxsa'c.
\v 22 Coḻbicaj lo guiralii doḻguijdx.
\p 
\v 23 Lagajc Dios, Dios ni rbecdxi lajztu, gusiapac lastootu, te cucheeni xaimtu, näj lastootu, näjza tiejxhtu, te na'c guntu dojḻ ni di riäjḻ guntu te cuääztu dxej ni guibisac Dad Jesucrist.
\v 24 Dad ni gurejdx la'tu rujnza guiraa ni rniini, ni'c sujnzani guiraa redzuunre.
\s1 Ruzadiidxnireni
\p 
\v 25 Bejtznu, coḻnab lo Dios xcuent nuurnu.
\p 
\v 26 Coḻgudeed xtixtios lo rebejtznu ni yu' ro'c.
\p 
\v 27 Con laj Dad Jesucrist rnibeä, goḻtu guijtzre loj guiraa rebejtznu.
\p 
\v 28 Gacnäj Dad Jesucrist la'tu. Sugacni si'c.
