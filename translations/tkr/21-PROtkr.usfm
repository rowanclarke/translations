\id PRO – Tsakhur 
\toc3 Sıl. 
\toc2 Sıleymanın uvhiybı 
\toc1 Sıleyman peyğambarın k'oran uvhiybı 
\mt1 Sıleyman peyğambarın k'oran uvhiybı 
\c 3  
\q1  
\v 13 Hikmətılqa hirxhılyna, 
\q2 K'orana ək'el avaykına insan nimee baxtivariy! 
\q1  
\v 14 Mançiken xayir nuk'rayle geed vod, 
\q2 İn g'azanc məttıne k'ınəəğəyle q'iymatıka vod. 
\q1  
\v 15 Mana gıranne ekebışileb gıranba vob, 
\q2 Mançika vas ıkkanan nencad kar sa aqqas dexhe. 
\q1  
\v 16 Mançine sağne xılen xıliyna ı'mı'r, 
\q2 Solne xılenıd var-devletiy şöhrat hele ıxha. 
\q1  
\v 17 Mançin yəqbı q'abıledaxhenbı vod, 
\q2 Gırgın yəqbı əmin-amanınbı\f + \fr 3:17 \fq Əmin-amanınbı:\ft  yiqsumul in cuvab «nübəhı'nbı» vod.\f* vod. 
\q1  
\v 18 At'ipq'ı'ninbışdemee mana ı'mrena yivobna, 
\q2 Mançike it'umba alyt'ipq'ıninbı nimee baxtivarariy! 
\q1  
\v 19 Rəbbee dyunye hikmətıka itxhın, 
\q2 K'orane ək'elika xəybı hı'ı, 
\q1  
\v 20 Ats'aalika k'oralybışençe xhyan alqavhu, 
\q2 Xəybışençe çiy gyuarı'ı. 
\c 10  
\q1  
\v 26 Sirkayn silibışik, kumayn uleppışik ha'an, 
\q2 Tambalee iş hooleng'uk ha'a. 
\c 11  
\q1  
\v 28 Var-devletılqa umudeepxhaynbı k'yooçesınbı, 
\q2 Qopkıynbıb t'et'-t'ele g'ayhene yivaaşik akaraba vuxhes. 
\c 12  
\q1  
\v 4 Yugna xhunaşşe adamiyn tac vodun, 
\q2 Tesser ha'anar vuk'arne bark'uk akar. 
\q1  
\v 16 Bəç'əree qəl zaraba h'aagva, 
\q2 Ək'elikang'un rı'h tsimis qexhen deş. 
\q1  
\v 18 Nəxüd qadıy uvhuynçin ç'ik'ayn xhinne g'ats'ayk'van, 
\q2 K'orane ək'elika uvhuynçinıd yug qaa'a. 
\c 13  
\q1  
\v 3 Ghal sı'ına geer axhvas, 
\q2 Sidi'ınar ek'ra haq'varas. 
\c 14  
\q1  
\v 4 Yats deşdang'a axur məttıba vooxhe, 
\q2 Yugun g'ıkıd yatsbışde taq'atınxhe helen. 
\c 15  
\q1  
\v 4 G'üvənana miz ı'mrena yiv vobna, 
\q2 Horarlynançinıd yik' haq'vara'an. 
\q1  
\v 17 Mühübbatıka xhınakın ala otxhuniy, 
\q2 Qəlıka boğayn çuru otxhuniyle yugda vod. 
\q1  
\v 18 Qəlnang'vee g'almag'al haa'a, 
\q2 Sabırnang'vee ç'əv haa'a. 
\c 16  
\q1  
\v 24 T'ap'anedın itv xhinne uftanna yuşe, 
\q2 Canas yugba, rı'hı's ittuba. 
\q1  
\v 32 Gucnang'ule sabırnana yugra, 
\q2 Şaharbı alyaat'ang'uler vuc aqqaqqana yugra. 
\c 17  
\q1  
\v 1 Saç'uvkiy deşda qit'ipk'ınna xüvə, 
\q2 Saç'uvkiynane otxhun-ulyodğuyle ittuba vob. 
\q1  
\v 9 Hambaz ıkkanang'vee qəl yik'elivxanaa'ana, 
\q2 Yik'el qavaalya'ang'vee hambaz agval ha'ana. 
\q1  
\v 17 Hambazıs hammaşe ıkkiykanna, 
\q2 Çocur dağamne yiğıs iyxhanna. 
\c 18  
\q1  
\v 11 Karnanbışisqa həməxüd q'öö, con kar axtıne barugbışika 
\q2 alyav'una g'alaniyxan. 
\q1  
\v 19 Tsimisna çoc – alyapt'as dyooxhene g'alayk akar, 
\q2 Aldapxhıniybıd – akkalne rızayk. 
\c 19  
\q1  
\v 14 Xaviy var-devlet dekkına miras vobna, 
\q2 Ək'elikana xhunaşşer Rəbbikena. 
\c 20  
\q1  
\v 4 Tambale ezang'a ezu deş, 
\q2 Sa'anang'ad avaykı deş. 
\c 21  
\q1  
\v 9 Siç'eekvane xhunaşşeyka sa xaa axvasse, 
\q2 Daxayne vuttul axvee yugda eyxhe. 
\c 22  
\q1  
\v 1 Hı'rmat nuk'rayleyiy-k'ınəəğəyle geeb vukkiykne, 
\q2 Yugun doyud xənne var-devletıle geed ikkiykne. 
\q1  
\v 2 Karnanayiy kar deşda sana-sang'uk akar - 
\q2 Q'öyursanar Rəbbee ipxhın. 
\q1  
\v 6 Ts'eppacab uşaxık'le qopkuna yəq haagve, 
\q2 Q'əsvaleyir mana mançile sak'alas deş. 
\q1  
\v 22 Kar kılydanang'uka gucub kı'lybava g'ımeşşe, 
\q2 Kasibrava məhkamee himeşşe. 
\q1  
\v 23 Rəbb alikkas manbışil-alla, 
\q2 Manbı g'yootuynbı, hivşuynbı Rəbbee ı'mreke haa'as. 
\c 23  
\q1  
\v 4 Xətta kar ha'asva ğucar ğu gimek'a. 
\q2 Ək'elika ixhe, mane fıkrele ılğeç'e. 
\q1  
\v 5 Var-devlet ul gyapxasse deşxhesın, 
\q2 Q'acır xhinne xılibı aaqı xəybışeeqa alixasın. 
\c 24  
\q1  
\v 30 Tambalne ekıneençe 
\q2 G'anmazne t'ımıllığeençe ılğeç'u. 
\q1  
\v 31 G'acuyn gırgın sura zazaanıd aalyat'u, 
\q2 Mağaanıd aqqı, cabırbıd hı'ğətkırıd. 
\q1  
\v 32 Mançika ilyakkı fıkır opxhun, 
\q2 Mançike ı'brat aalyat'u: 
\q1  
\v 33 Sık'ırra qorku mırg he'ee, 
\q2 G'el-xıl hotku g'alirxhvee, 
\q1  
\v 34 Kasibiyvalla soyğunçiy xhinne, 
\q2 Ehtiyaccıb g'uldur xhinne sayangaba ooqa hophur ables. 
\c 25  
\q1  
\v 11 Cigal uvhuyn cuvab, 
\q2 nuk'rayne g'abılyne k'ınəəğəyne eçeeşik akar. 
\q1  
\v 15 Paççahnab fıkır sabırnang'vee badal haa'ana, 
\q2 İttune mizen bark'ub g'üvana qaa'ana. 
\q1  
\v 19 Xıl hudyoolena dağamne yiğıl 
\q2 Qiçiyne siliykiy k'aane g'elik akar. 
\q1  
\v 21 Duşman mıssıraxhee, oxhanasın hele, 
\q2 Xhyan ıkkanxhee, ulyoğasın hele. 
\q1  
\v 22 Məxüd ğu mang'us naş qa'as, 
\q2 Yiğna yugvallab Rəbbee savaak'al haa'as. 
\q1  
\v 28 Qəl avqas dəxəna insan, 
\q2 Cabırbı hı'ğətkırne şaharık akar. 
\c 26  
\q1  
\v 21 Nəxüdiy osake ts'a eyxhe, 
\q2 Ğiybatnang'ukeb g'almag'al vooxhe. 
\c 27  
\q1  
\v 6 Hambazın yik' aliq'alı'iy, 
\q2 Duşmanne geedne ubbabışile yugun vodun. 
\c 31  
\p  
\v 1 Lemuel donane paççahee uvhuynbı, yedee mang'us xət qıiyn cuvab.  
\v 2 Hucoona zı eyhes dix, zı uxuna dix, Düəbışika heeqqına dix?  
\v 3 Guc zəiyfabışis hımoole, Yiğın yəqbı paççahaaşikın ha'anbışik'le hımagva.  
\v 4 Lemuel, çaxır ulyoduy paççahaaşik avaakı deş, P'iyan haa'an ulyodğuy ıkkiykıniy vuk'lek vukkekkanbışik avaak'ı deş.  
\v 5 Ulyodğumee q'aanunxhe yik'el hiviyxan, Manbışe kar deşinbı hək' dena g'alyaa'as.  
\v 6 P'iyan haa'an ulyodğuy mançika qek'ang'us , Çaxırıd ver abıyng'us hele.  
\v 7 Hasre ulyodğu kar deşiyvalla yik'el hivxan hee'ecen, Culqa abına ver sayıb yik'el qavaal hımaa'acen.  
\v 8 Miz deşing'ul-alla ghal eeqe, Guc deşinbışda hək' avqe.  
\v 9 Ghal eeqe, qotkuyn eyhe, Kar deşinbışda, fağıraaşina hək' qevle. (Yugun ha'ana xhunaşşe)  
\v 10 Yugna xhunaşşe aveekına vuşune? Gıranne g'ayebışile mana gıranna vor.  
\v 11 Adamiyn yik' məng'ı'le arxayında vod, Mana məng'ı'ka barakat dena axvas deş.  
\v 12 I'mı'r volle adamiys pisın deş, yugun ha'as,  
\v 13 Xhayiy katan məng'ee g'əyxə, Xılençe yugda gırgın qöö.  
\v 14 Kar alişşu-massa helene gamibışik akar, Cesın oxhanasın kar əq'ənançe adayle.  
\v 15 Miç'axdanang'acar mana muğur qeexhe, Xizanısın oxhanasın otxhuniy ha'a, Həmbalaaşisda iş hoole.  
\v 16 Çoluka ilyakkiyle qiyğa çol ileşşe, Xılene əq'übayka bağ adaççe.  
\v 17 İş məng'ee geeb haa'a, Məng'ı'na guc cene işis g'iviyxharna.  
\v 18 Məng'ı'lqa kar alişşu-massa huvuyna ittulla hipxhırna, Xəmdeb məng'ı'na bazir k'əbəqqə deş.  
\v 19 Xıleka xha g'oodan kar iliyk'ar,))  
\v 20 Kar deşing'unemee məng'ee xıl aaqa, Fağıraaşis xıl avqaaqqa.  
\v 21 Yiz gyuoğang'ad mana cune xizannemee q'əyq'ən deş, Məng'ı'ne xizanne gırgınbışe ç'əran kar ali'ı.  
\v 22 Yic g'ileexhane tyuliys aq'vabı iyxhva, Məng'ee yicee k'ışşeyn ç'əran katanın kar alya'a.  
\v 23 Adamiy məng'ı'na şaharne akkabışisnee yugra ats'a, Milletne ağsaqqalaaşika gyu'ur-oza qexhe.  
\v 24 Məng'ee zəiyfabışis ts'irabı, Yicee iyxuyn katanıken tanalinbı massa hele.  
\v 25 (--)  
\v 26 Mana k'orane ək'elika yuşan hee'e, Məng'ı'ne mizel vukkiykıniy yugvalla vob.  
\v 27 Xizanne işbışika mana ileeka, Tanbalıs avaak'iyn gıney oyxhan deş.  
\v 28 Uşaxar oza qeepxha məng'ı's gappar ha'a, Adameeyib məng'ı'na yugna gaf haa'a:  
\v 29 "Yugun zəiyfabı geeb vob, Vaka sa ayqasdame deşda".  
\v 30 Zəiyfayna yugvallayiy micagiyvalla horbışikan kar vod, Saccu Rəbbile qiyeeq'ənne zəiyfayk'le yugun eyhes eyxhe.  
\v 31 Məng'ı's gyooxhana hək' qevle, Hasre məng'ı'n işbı şaharne akkabışisnee ələtqecen.