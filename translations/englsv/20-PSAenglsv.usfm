\v 4 Behold, God [\w is|strong="H6310"\w*] \w a|strong="H3068"\w* helper \w to|strong="H8085"\w* \w me|strong="H8085"\w*, || \w The|strong="H8085"\w* Lord [\w is|strong="H6310"\w*] \w with|strong="H8085"\w* \w those|strong="H8085"\w* supporting \w my|strong="H8085"\w* soul,
