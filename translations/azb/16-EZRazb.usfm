\id EZR Azeri-N: Azerbaijani Bible 2008 
\h EZRA 
\toc1 Ezra Kitabi 
\toc2 Ezra 
\toc3 Ezra 
\mt1 EZRA  
\mt2 KİTABI  
\imt1 GİRİŞ  
\ip \bk «Ezra»\bk* və \bk «Nehemya»\bk* Kitabları vəhdət təşkil edib \bk «Salnamələr»\bk* Kitabının davamıdır. Bu kitab yəhudilərin Babil sürgünlüyündən qayıtmasından və Yerusəlimdəki məbədin bərpa olunmasından danışır. Kitabın müəllifi sübut edir ki, yəhudilərin qovulmasına və padşahlığın dağılmasına baxmayaraq, onlar yenə də Allahın seçilmiş xalqı olaraq qalırlar. Kitabın baş qəhrəmanı ilahiyyatçı, Allahın qanununu yaxşı bilən və Ona sadiq olan Ezradır. O öz imanı ilə İsrailin mənəvi irsini qorumaq üçün xalqın ruhani və ictimai həyatının bərpasına kömək edir.  
\ip Kitabda hadisələr belə ardıcıllıqla qələmə alınıb:  
\ip Sürgündə olan yəhudilərin bir hissəsinin Fars padşahı Kirin əmri ilə vətənə qayıtması.  
\ip Məbədin yenidən tikilməsi və təqdis olunması; Yerusəlimdə Allaha ibadətin bərpası.  
\ip Sürgündə olan yəhudilərin başqa bir hissəsinin Yerusəlimə qayıtması və nikah problemi.  
\iot Kitabın məzmunu:  
\io2 1:1–2:70 Sürgündən Yəhudaya birinci qayıdanlar  
\io2 3:1–6:22 Məbədin yenidən tikilməsi və təqdis edilməsi  
\io2 7:1–10:44 Ezranın başqa sürgün olunanlarla birgə qayıtması  
\c 1  
\s1 Yerusəlimdəki məbədin bərpası  
\r (2Saln. 36:22-23)  
\p
\v 1 \x * \xo 1:1 \xt Yer. 25:11; 29:10 \x* Rəbb Fars padşahı Kirin hökmranlığının birinci ilində Yeremyanın dili ilə dediyi sözü yerinə yetirmək üçün Kiri ruhlandırdı. Ona görə Kir padşahlığının bütün ərazisində yazılı və şifahi elan etdi:   
\pi1
\v 2 \x * \xo 1:2 \xt Yeş. 44:28 \x* «Budur, Fars padşahı Kir belə deyir: “Göylərin Allahı Rəbb dünyanın bütün padşahlıqlarını mənə verdi və Yəhudanın Yerusəlim şəhərində Öz məbədini tikməyi mənə əmr etdi.  
\v 3 Aranızda Onun xalqına mənsub olanların hamısına qoy Allahı yar olsun! Qoy onlar Yəhudanın Yerusəlim şəhərinə qalxsın və İsrailin Allahı Rəbbin məbədini tiksinlər. Yerusəlimdə səcdə qılınan Allah Odur.  
\v 4 Sağ qalan İsraillilər hansı əhali arasında yaşayırsa, qoy onlar Yerusəlimdəki Allah evinə verəcəkləri könüllü ianələrdən başqa, qızıl-gümüş, əşya və heyvanlar verməklə bu adamlara kömək etsinlər”».   
\p
\v 5 Yəhuda, Binyamin qəbilələrinin nəsil başçıları, kahinlərlə Levililər, eləcə də Allahın ruhlandırdığı bütün adamlar Rəbbin Yerusəlimdəki məbədini tikmək üçün yola düşməyə hazırlaşdılar.  
\v 6 Aralarında yaşadıqları yerli əhalinin hamısı verdikləri könüllü ianələrdən başqa, qızılla, gümüş qablarla, əşyalarla, heyvanlarla və qiymətli şeylərlə onlara kömək etdilər.  
\v 7 Padşah Kir Navuxodonosorun Rəbbin Yerusəlimdəki məbədindən götürüb öz allahlarının məbədinə qoyduğu əşyaları çıxartdı.  
\v 8 Fars padşahı Kir onları xəzinədar Mitredatın əli ilə oradan çıxardaraq hamısını sayıb Yəhuda rəhbəri Şeşbassara verdi.  
\v 9 Onların sayı bu qədər idi: otuz qızıl ləyən, min gümüş ləyən, iyirmi doqquz bıçaq,  
\v 10 otuz qızıl boşqab, bir-birinə oxşayan dörd yüz on gümüş boşqab və min ədəd də başqa qablar.  
\v 11 Qızıl və gümüş əşyaların hamısı beş min dörd yüz ədəd idi. Sürgündə yaşayanlar Babildən Yerusəlimə qaytarılanda Şeşbassar bu əşyaların hamısını onlarla bərabər gətirdi.   
\c 2  
\s1 Sürgündən Yəhudaya qayıdanların siyahısı  
\r (Neh. 7:4-73)  
\p
\v 1 Babil padşahı Navuxodonosorun Babilə apardığı əsirlər yaşadıqları vilayətdən Yerusəlimə və Yəhudadakı öz şəhərlərinə qayıtdılar.   
\p
\v 2 Onlar Zerubbabil, Yeşua, Nehemya, Seraya, Reelaya, Mordokay, Bilşan, Mispar, Biqvay, Rexum, Baananın başçılığı ilə gəldilər.  
\p Sürgündən qayıdan İsraillilərin sayı:   
\li1
\v 3 Paroş övladları – 2172 nəfər;   
\li1
\v 4 Şefatya övladları – 372 nəfər;   
\li1
\v 5 Arah övladları – 775 nəfər;   
\li1
\v 6 Yeşua və Yoav nəslindən Paxat-Moav övladları – 2812 nəfər;   
\li1
\v 7 Elam övladları – 1254 nəfər;   
\li1
\v 8 Zattu övladları – 945 nəfər;   
\li1
\v 9 Zakkay övladları – 760 nəfər;   
\li1
\v 10 Bani övladları – 642 nəfər;   
\li1
\v 11 Bevay övladları – 623 nəfər;   
\li1
\v 12 Azqad övladları – 1222 nəfər;   
\li1
\v 13 Adoniqam övladları – 666 nəfər;   
\li1
\v 14 Biqvay övladları – 2056 nəfər;   
\li1
\v 15 Adin övladları – 454 nəfər;   
\li1
\v 16 Ater, yəni Xizqiya övladları – 98 nəfər;   
\li1
\v 17 Besay övladları – 323 nəfər;   
\li1
\v 18 Yora övladları – 112 nəfər;   
\li1
\v 19 Xaşum övladları – 223 nəfər;   
\li1
\v 20 Gibbar övladları – 95 nəfər;   
\li1
\v 21 Bet-Lexem övladları – 123 nəfər;   
\li1
\v 22 Netofa sakinləri – 56 nəfər;   
\li1
\v 23 Anatot sakinləri – 128 nəfər;   
\li1
\v 24 Azmavet övladları – 42 nəfər;   
\li1
\v 25 Qiryat-Arim, Kefira və Beerot övladları – 743 nəfər;   
\li1
\v 26 Rama və Geva övladları – 621 nəfər;   
\li1
\v 27 Mikmas sakinləri – 122 nəfər;   
\li1
\v 28 Bet-El və Ay sakinləri – 223 nəfər;   
\li1
\v 29 Nevo övladları – 52 nəfər;   
\li1
\v 30 Maqbiş övladları – 156 nəfər;   
\li1
\v 31 Digər Elam övladları – 1254 nəfər;   
\li1
\v 32 Xarim övladları – 320 nəfər;   
\li1
\v 33 Lod, Xadid və Ono övladları – 725 nəfər;   
\li1
\v 34 Yerixo övladları – 345 nəfər;   
\li1
\v 35 Senaa övladları – 3630 nəfər.   
\p
\v 36 Kahinlər:  
\li1 Yeşua nəslindən Yedaya övladları – 973 nəfər;   
\li1
\v 37 İmmer övladları – 1052 nəfər;   
\li1
\v 38 Paşxur övladları – 1247 nəfər;   
\li1
\v 39 Xarim övladları – 1017 nəfər.   
\p
\v 40 Levililər: Hodavya nəslindən yaranan Yeşua və Qadmiel övladları – 74 nəfər.   
\p
\v 41 İlahiçilər: Asəf övladları – 128 nəfər.   
\p
\v 42 Məbəd qapıçıları: Şallum övladları, Ater övladları, Talmon övladları, Aqquv övladları, Xatita övladları və Şovay övladları ilə birlikdə 139 nəfər.   
\p
\v 43 Məbəd qulluqçuları: Sixa övladları, Xasufa övladları, Tabbaot övladları,  
\v 44 Qeros övladları, Siaha övladları, Padon övladları,  
\v 45 Levana övladları, Xaqava övladları, Aqquv övladları,  
\v 46 Xaqav övladları, Şamlay övladları, Xanan övladları,  
\v 47 Giddel övladları, Qaxar övladları, Reaya övladları,  
\v 48 Resin övladları, Neqoda övladları, Qazzam övladları,  
\v 49 Uzza övladları, Paseah övladları, Besay övladları,  
\v 50 Asna övladları, Meunim övladları, Nefusim övladları,  
\v 51 Baqbuq övladları, Xaqufa övladları, Xarxur övladları,  
\v 52 Baslut övladları, Mexida övladları, Xarşa övladları,  
\v 53 Barqos övladları, Sisra övladları, Tamax övladları,  
\v 54 Nesiah övladları, Xatifa övladları.   
\p
\v 55 Süleymanın əyanlarının nəslindən: Sotay övladları, Hassoferet övladları, Peruda övladları,  
\v 56 Yela övladları, Darqon övladları, Giddel övladları,  
\v 57 Şefatya övladları, Xattil övladları, Pokeret-Hassevayim övladları, Ami övladları.   
\p
\v 58 Məbəd qulluqçuları ilə Süleymanın əyan qullarının övladları – cəmi 392 nəfər.   
\p
\v 59 Tel-Melahdan, Tel-Xarşadan, Keruvdan, Addondan, İmmerdən qayıdan, ancaq ailələrinin və nəsillərinin İsrail övladlarından olduğunu sübut edə bilməyənlər bunlardır:  
\v 60 Delaya övladları, Toviya övladları, Neqoda övladları – 652 nəfər.   
\p
\v 61 Kahinlərin nəslindən: Xovaya övladları, Haqqos övladları, Gileadlı Barzillayın qızlarından arvad alıb qayınatasının adını götürən Barzillay övladları.  
\v 62 Onlar nəsil şəcərəsini axtardılar, lakin öz adlarını tapa bilmədilər və buna görə murdar sayılaraq kahinlikdən çıxarıldılar.  
\v 63 Yəhuda valisi onlara əmr edib belə dedi: «Urim və Tummimi işlədən bir kahin olmayınca onlar ən müqəddəs yeməklərdən yeməsin».   
\p
\v 64 Bütün camaat birlikdə 42 360 nəfər idi.  
\v 65 Bundan başqa, 7337 nəfər kölə və kənizlər, 200 nəfər kişi və qadından ibarət ilahiçi var idi.  
\v 66 Bu adamların 736 atı, 245 qatırı,  
\v 67 435 dəvəsi, 6720 eşşəyi var idi.   
\p
\v 68 Rəbbin Yerusəlimdəki məbədinə gələn zaman bəzi nəsil başçıları Allahın evini öz yerində tikmək üçün könüllü ianələr verdilər.  
\v 69 Bu iş üçün yığılan xəzinəyə imkan daxilində altmış bir min darik \f + \fr 2:69 \fq Darik \ft – qızıl sikkə.\f* qızıl, beş min mina gümüş və yüz kahin geyimi verdilər.   
\p
\v 70  \x * \xo 2:70 \xt 1Saln. 9:2; Neh. 11:3 \x* Kahinlər, Levililər, xalqın bəziləri, ilahiçilər, məbəd qapıçıları və qulluqçuları öz şəhərlərində yerləşdilər. Beləliklə, İsraillilər isə öz şəhərlərində yerləşdilər.   
\c 3  
\s1 Yerusəlimdəki qurbangahın tikilməsi  
\p
\v 1 \x * \xo 3:1 \xt Neh. 8:1 \x* Artıq İsraillilər öz şəhərlərində idi. Yeddinci ay çatanda xalq bir nəfər kimi Yerusəlimdə toplandı.  
\v 2 \x * \xo 3:2 \xt Çıx. 27:1 \x* Yosadaq oğlu Yeşua ilə kahin qardaşları və Şealtiel oğlu Zerubbabillə qardaşları İsrailin Allahının qurbangahını qurdular ki, Allah adamı Musanın Qanununda yazıldığı kimi üstündə yandırma qurbanları təqdim edilsin.  
\v 3 \x * \xo 3:3 \xt Say. 28:1-8 \x* Ətrafda yaşayan xalqlardan qorxmalarına baxmayaraq, qurbangahı əvvəlki bünövrə üzərində qurdular. Sonra onun üzərində səhər-axşam Rəbbə yandırma qurbanları təqdim etdilər.  
\v 4 \x * \xo 3:4 \xt Say. 29:12-38 \x* Yazıya görə Çardaqlar bayramı keçirdilər və qaydaya görə günbəgün müəyyən miqdarda gündəlik yandırma qurbanları təqdim etdilər.  
\v 5 \x * \xo 3:5 \xt Say. 28:11–29:39 \x* Sonra daimi yandırma qurbanları verdilər. Təzə Ay mərasimlərinin, eləcə də Rəbbin təqdis etdiyi bütün bayramların təqdimlərini və hamının könüllü olaraq Rəbbə etdiyi təqdimləri verdilər.  
\v 6 Rəbbin məbədinin bünövrəsinin qoyulmamasına baxmayaraq, onlar yeddinci ayın birinci günündə Rəbbə yandırma qurbanları təqdim etməyə başladılar.   
\s1 Məbədin bünövrəsinin qoyulması  
\p
\v 7 Daşyonanlarla dülgərlərə pul verdilər. Fars padşahı Kirdən izin aldıqlarına görə Livandan dəniz yolu ilə Yafoya sidr ağacları gətirmələri üçün Sidonlularla Surlulara yemək-içmək və zeytun yağı verdilər.   
\p
\v 8 Allahın evinə, Yerusəlimə gəlişlərinin ikinci ilinin ikinci ayında Şealtiel oğlu Zerubbabil və Yosadaq oğlu Yeşua ilə digər qardaşları – kahinlər, Levililər, əsirlikdən Yerusəlimə qayıdanların hamısı işə başladılar. İyirmi və ondan yuxarı yaşda olan Levililəri Rəbbin məbədinin tikinti işinə nəzarətçi təyin etdilər.  
\v 9 Levililərdən Yeşua və övladları ilə qardaşları, Hodavya \f + \fr 3:9 \fq Hodavya \ft – ibrani mətnində \fq Yəhuda \ft yazılmışdır. Bax: Ezr. 2:40, Neh. 7:43.\f* nəslindən törənən Qadmiellə övladları, Xenadad övladları, nəvələri və qardaşları Allahın evində işləyənlərə nəzarət etdilər.  
\v 10 \x * \xo 3:10 \xt 1Saln. 25:1 \x* Bənnalar Rəbbin məbədinin təməlini qoyan zaman İsrail padşahı Davudun qoyduğu qaydaya əsasən kahinlər xüsusi libas geyinib əllərindəki kərənaylarla, Asəf övladlarından olan Levililərsə sinclərlə Rəbbə həmd etmək üçün öz yerlərini tutdular.  
\v 11 \x * \xo 3:11 \xt 1Saln. 16:34; 2Saln. 5:13; 7:3; Zəb. 100:5; 106:1; 107:1; 118:1; 136:1; Yer. 33:11 \x* Onlar Rəbbə həmd və şükür edib növbə ilə Onu tərənnüm edərək belə deyirdilər: «Rəbb yaxşıdır, çünki İsrailin üzərində məhəbbəti əbədidir». Onlar Rəbbə həmd edəndə bütün xalq ucadan qışqırdı, çünki Rəbb evinin bünövrəsi qoyulmuşdu.  
\v 12 Əvvəlki məbədi görmüş bir çox qoca kahinlər, Levililər və nəsil başçıları məbədin bünövrəsinin qoyulduğunu görəndə hönkürüb ağladılar, bir çoxları isə sevincdən haray çəkdilər.  
\v 13 Xalq gurultulu sevinc səsləri ilə ağlaşma səslərini bir-birindən ayıra bilmirdi, çünki onların gurultu ilə qopan haray səsləri uzaqlarda eşidilirdi.   
\c 4  
\s1 Samariyalılar məbəd tikintisinə mane olur  
\p
\v 1 Yəhudalıların və Binyaminlilərin düşmənləri eşitdilər ki, sürgündən qayıdanlar İsrailin Allahı Rəbb üçün məbəd tikirlər.  
\v 2 \x * \xo 4:2 \xt 2Pad. 19:37; Yeş. 37:38 \x* Onlar Zerubbabilə və nəsil başçılarına yaxınlaşıb belə dedi: «Qoy biz də sizinlə bərabər bu məbədi tikək, çünki biz də sizin kimi Allahınıza sitayiş edirik. Bizi buraya gətirən Aşşur padşahı Esar-Xaddonun dövründən bəri sizin Allaha qurban təqdim edirik».  
\v 3 Lakin Zerubbabil, Yeşua və İsrailin digər nəsil başçıları onlara belə dedilər: «Allahımızın evini qurmaq üçün sizin bizimlə heç bir ortaq işiniz yoxdur. Biz özümüz əlbir olaraq Fars padşahı Kirin əmrinə əsasən İsrailin Allahı Rəbbə məbəd tikəcəyik».  
\v 4 Onda bu ölkənin xalqı Yəhuda xalqının əllərini işdən soyutmaqla tikinti işində onlara əziyyət verdi.  
\v 5 Bu xalq Yəhudilərin məqsədlərini boşa çıxarmaq üçün Fars padşahları olan Kirin dövründən Daranın dövrünə qədər onlara qarşı çıxaraq özlərinə muzdla məsləhətçilər tutdu.  
\v 6 \x * \xo 4:6 \xt Est. 1:1 \x* Onlar Axaşveroş padşah olanda, onun hökmranlığının başlanğıcında Yəhuda və Yerusəlimdə yaşayanların əleyhinə bir ittiham məktubu yazdılar.   
\p
\v 7 Fars padşahı Artaxşastanın\f + \fr 4:7 \fq Artaxşasta \ft – Azərbaycanda indiki tarixi ədəbiyyatlarda Artakserks.\f* dövründə Bişlam Mitredat, Taveel və digər yoldaşları padşah Artaxşastaya məktub yazdı. Məktub Arami dilində yazılaraq\f + \fr 4:7 \ft 4:8–6:18-ə qədər mətn o dövrün rəsmi dili olan arami dilində yazılmışdır.\f* tərcümə edildi.   
\p
\v 8 Sərkərdə Rexum və mirzə Şimşay padşah Artaxşastaya Yerusəlimi ittiham edən bir məktub yazdı.  
\v 9 Sonra məktuba sərkərdə Rexumla mirzə Şimşay və qalan yoldaşları, hakimlər, əmirlər, qulluqçular, Farslar, Ereklilər, Babillilər, Şuşanlılar, yəni Elamlılar,  
\v 10 böyük və şanlı Aşurbanipalın\f + \fr 4:10 \fq Aşurbanipal \ft – arami mətnində \+tl Osnappar\+tl*.\f* sürgün edib Samariya şəhərlərində və Fərat çayının qərb torpaqlarında yerləşdirdiyi başqa xalqlar imza qoydular.   
\p
\v 11 Padşah Artaxşastaya göndərdikləri məktubun surəti belədir:  
\pi1 «Padşah Artaxşastaya  
\pi1 Fərat çayının qərb torpaqlarında yaşayan qullarından.   
\pi1
\v 12 Padşaha məlum olsun ki, sizin yanınızdan qayıdan Yəhudilər bizim yanımıza – Yerusəlimə gəlib bu pis, üsyankar şəhəri bərpa edirlər. Divarları hörüb qurtardılar və binaların təməlini bərpa etdilər.  
\v 13 Padşaha məlum edirik ki, əgər bu şəhər bərpa edilərsə, divarları hörülüb qurtararsa, onlar sənə vergi, xərac və gömrük verməyəcəklər. Bununla da padşahın gəlirinə böyük ziyan dəyəcək.  
\v 14 Əgər indi bu sarayın duzu ilə dolanırıqsa, gözümüz önündə padşaha ziyan dəyməsini görmək bizə yaraşmaz. Ona görə də padşaha bu xəbəri göndərib belə məlum edirik:  
\v 15 qoy ata-babalarının dəftərxanası axtarılsın. Qeyd kitablarında bu şəhər haqqında məlumat tapanda biləcəksiniz ki, bu şəhər həm üsyankar, həm də padşahlar və dövlətlər üçün zərərlidir. Qədimdən bəri oradan həmişə xəyanət törəyib və bunun üçün şəhər xarabaya çevrilib.  
\v 16 Padşaha məlum edirik ki, əgər bu şəhər bərpa edilərsə və divarları tikilib qurtararsa, sənin Fərat çayının qərb torpaqlarında payın olmayacaq».   
\p
\v 17 Padşah belə cavab göndərdi:  
\pi1 «Sərkərdə Rexuma, mirzə Şimşaya və Samariya ilə Fərat çayının digər qərb torpaqlarında yaşayan yoldaşlarına salamlar!   
\pi1
\v 18 Bizə göndərdiyiniz məktub hüzurumda tərcümə edildi.  
\v 19 Ona görə mən əmr verdim və əmrimə əsasən istintaq aparıldı. Bu şəhərin sakinlərinin qədimdən bəri padşahlara qarşı üsyan qaldırması təsdiq olundu. Üsyankarlıq və xəyanət bu şəhərin daxilindən baş qaldırıb.  
\v 20 O zaman Yerusəlimi idarə edən qüdrətli padşahlar var idi. Fərat çayının qərbindəki bütün torpaqlar üzərində bu padşahlar hökmranlıq edirdilər. Buranın əhalisi isə onlara xərac, vergi və gömrük verirdi.  
\v 21 İndi əmr verin, bu adamlar işi dayandırsınlar və mən əmr verənə qədər bu şəhəri bərpa etməsinlər.  
\v 22 Bu işə etinasız yanaşmaqdan çəkinin. Niyə şər artıb padşahlığıma ziyan vursun?»   
\p
\v 23 Padşah Artaxşastanın məktubunun surəti Rexumla mirzə Şimşayın və yoldaşlarının qarşısında oxunanda onlar tələsik Yerusəlimə Yəhudilərin yanına getdilər. Onların işini zorla, güclə dayandırdılar.  
\v 24 Beləliklə, Yerusəlimdəki Allah evinin tikinti işi dayandırıldı və bu iş Fars padşahı Daranın hökmranlığının ikinci ilinə qədər ləngidi.   
\c 5  
\s1 Tikintinin davam etdirilməsi  
\p
\v 1 \x * \xo 5:1 \xt Ezra 6:14; Haq. 1:1; Zək. 1:1 \x* Peyğəmbərlərdən peyğəmbər Haqqayla İddo oğlu Zəkəriyyə Yəhudada və Yerusəlimdə yaşayan Yəhudilərə İsrail Allahının adı ilə peyğəmbərlik etdi.  
\v 2 \x * \xo 5:2 \xt Haq. 1:12; Zək. 4:6-9 \x* \x * \xo 5:2 \xt Zək. 3:1 \x* O zaman Şealtiel oğlu Zerubbabil və Yosadaq oğlu Yeşua işə başlayaraq Yerusəlimdəki Allah evinin tikintisini davam etdirdilər. Allahın peyğəmbərləri də onlarla idi və onlara kömək etdi.   
\p
\v 3 O vaxtlar Fərat çayının qərb torpaqlarının valisi olan Tattenay, Şetar-Boznay və yoldaşları onların yanına gəlib dedi: «Bu məbədi bərpa etmək və tikintisini qurtarmaq üçün sizə kim icazə verib?»  
\v 4 Onda biz onlara bu binanı tikənlərin adlarını bildirdik.  
\v 5 Allahın nəzəri Yəhudi ağsaqqallarının üzərinə yönəlmişdi. Ona görə bu işin sorağı Daraya çatana və bu barədə məktubla cavab qayıdanadək onlar Yəhudilərin işini dayandırmadılar.   
\p
\v 6 Fərat çayının qərb torpaqlarının valisi Tattenay, Şetar-Boznay və yoldaşları, Fərat çayının qərb torpaqlarındakı məmurlar padşah Daraya bu surətdə məktub yolladı.  
\v 7 Ona yolladıqları məktubda belə yazılmışdı:  
\pi1 «Padşah Daraya böyük ehtiramla salamlar!   
\pi1
\v 8 Padşaha məlum olsun ki, biz Yəhuda vilayətindəki böyük Allahın məbədinə getdik. Məbəd böyük daşlardan tikilmiş, divarların içərisinə dirəklər qoyulmuşdur. Bu iş səylə görülərək uğurla idarə edilir.  
\v 9 O zaman oranın ağsaqqallarından soruşub belə dedik: “Bu məbədi bərpa etmək və tikintisini qurtarmaq üçün sizə kim icazə verib?”  
\v 10 Həm də onlardan bu işin başçılarının adını soruşduq ki, bunları yazaraq sizə bildirək.   
\pi1
\v 11 Onlar bizə belə cavab verdilər:  
\pi1 “Biz göylərin və yerin Allahının qullarıyıq. Bundan bir çox il əvvəl tikilən məbədi bərpa edirik. Vaxtı ilə oranı İsrailin böyük padşahı tikib başa çatdırmışdı.  
\v 12 \x * \xo 5:12 \xt 2Pad. 25:8-12; 2Saln. 36:17-20; Yer. 52:12-15 \x* Lakin atalarımız göylərin Allahını qəzəbləndirdiyi üçün Allah onları Babil padşahı Xaldeyli Navuxodonosora təslim etdi. O da bu məbədi xarabaya çevirdi və xalqını Babilə əsir apardı.  
\v 13 \x * \xo 5:13 \xt Ezra 1:2-11 \x* Lakin Babil padşahı Kirin hakimiyyətinin birinci ilində padşah Kir Allah evinin bərpası üçün əmr verdi.  
\v 14 Həmçinin Yerusəlimdəki Allah evindən Navuxodonosorun götürüb Babil məbədinə apardığı qızıl və gümüş qabları padşah Kir Babildəki məbəddən çıxartdı. Onları vali təyin etdiyi Şeşbassar adlı bir adama verərək dedi:  
\v 15 ‹Bu əşyaları götürüb get, Yerusəlimdəki məbədə qoy. Allahın evi qoy öz yerində bərpa olunsun›.  
\v 16 O zaman həmin Şeşbassar gəlib Yerusəlimdəki Allah evinin təməlini qoydu. O zamandan indiyə qədər bu məbəd tikilir, lakin hələ tamamlanmayıb”.   
\pi1
\v 17 İndi padşahın xoşuna gələrsə, qoy Babil sarayındakı dəftərxana axtarılaraq Yerusəlimdəki Allah evinin bərpası üçün padşah Kirin verdiyi əmr üzə çıxarılsın. Sonra isə bu iş barədə padşah öz iradəsini bizə bildirsin».   
\c 6  
\s1 Dara Kirin fərmanını təsdiq edir  
\p
\v 1 O zaman padşah Daranın verdiyi əmrə əsasən Babil xəzinəsində olan dəftərxana axtarıldı.  
\v 2 Midiya vilayətində olan Ekbatana qalasında bir tumar tapıldı. Bu tumarda belə qeyd edilmişdi:   
\pi1
\v 3 «Padşah Kirin hökmdarlığının birinci ilində Allahın Yerusəlimdəki məbədi barədə Kir belə əmr verib: “Bu məbəd – qurbanlar təqdim edilən bu yer əvvəlki bünövrəsi üzərində bərpa edilsin.  
\v 4 Üç cərgə böyük daş, bir cərgə təzə dirək qoyulmaqla altmış qulac hündürlükdə və altmış qulac uzunluqda olsun. Bu işin bütün xərci padşah xəzinəsindən ödənilsin.  
\v 5 Həm də Yerusəlimdəki Allah evindən Navuxodonosorun çıxarıb Babilə gətirdiyi qızıl və gümüş qablar geri qaytarılsın. Bunların hamısı öz yerinə, Yerusəlimdə olan məbədə aparılsın. Onları Allahın evinə qoyun”.   
\b  
\pi1
\v 6 Ona görə Fərat çayının qərb torpaqlarının valisi Tattenay, Şetar-Boznay və yoldaşları – Fərat çayının qərb torpaqlarındakı məmurlar qoy indi oradan uzaqlaşsın,  
\v 7 Allah evinin işinə qarışmasınlar. Yəhudilərin valisi və Yəhudilərin ağsaqqalları Allahın evini öz yerində bərpa etsinlər.  
\v 8 Mən əmr edirəm ki, Allahın bu evinin bərpasında Yəhudilərin bu ağsaqqallarına kömək edəsiniz, işlərinin dayandırılmaması üçün bu adamların xərci mütləq padşah xəzinəsindən, Fərat çayının qərb torpaqlarından yığılan vergilərdən ödənilsin.  
\v 9 Göylərin Allahına yandırma qurbanları vermək üçün hər gün ehtiyaclarına görə cavan buğalar, qoç və quzular, Yerusəlimdəki kahinlərin istədiyi miqdarda buğda, duz, şərab, zeytun yağı əskik edilmədən onlara verilsin.  
\v 10 Onlar göylərin Allahına xoş ətirli qurbanlar versinlər və buna görə padşahla övladları üçün dua etsinlər ki, canları sağ olsun.  
\v 11 Əmr edirəm ki, bu fərmanı dəyişdirən adamın evindən bir dirək çıxarıb dik basdırılsın və həmin adam bu dirəkdən asılsın. Qoy belə ev xarabalığa çevrilsin.  
\v 12 Bu məbədi isminə məskən edən Allah bu fərmanı dəyişdirməyə cəhd edən və Yerusəlimdəki məbədin dağılmasını istəyən hər padşahı və xalqı yox etsin. Mən Dara əmr edirəm, əmrim sözsüz yerinə yetirilsin».   
\s1 Allahın evinin təqdisi  
\p
\v 13 O zaman Fərat çayının qərb torpaqlarının valisi Tattenay, Şetar-Boznay və yoldaşları padşah Daranın göndərdiyi bu əmri alan kimi ona əməl etdilər.  
\v 14 \x * \xo 6:14 \xt Ezra 5:1; Haq. 1:1; Zək. 1:1 \x* Yəhudilərin ağsaqqalları tikintini davam etdirdilər və peyğəmbər Haqqay ilə İddo oğlu Zəkəriyyənin peyğəmbərlik sözlərinə əsasən onların işləri uğurlu gedirdi. İsrail Allahının buyruğuna görə Fars padşahları Kir, Dara və Artaxşastanın əmri ilə məbədi tikib qurtardılar.  
\v 15 Məbəd padşah Daranın hakimiyyətinin altıncı ili, Adar ayının üçündə başa çatdı.   
\p
\v 16 İsrail övladları – kahinlər, Levililər və sürgündən qayıdanların hamısı bu Allah evinin təqdis mərasimini sevinclə qeyd etdilər.  
\v 17 Allahın evinin təqdisi üçün yüz buğa, iki yüz qoç, dörd yüz quzu və bütün İsrail üçün qəbilələrinin sayına görə günah qurbanı olaraq on iki təkə təqdim etdilər.  
\v 18 Yerusəlimdə Allaha xidmət üçün Musanın Kitabında yazıldığı kimi kahinləri öz dəstələrində və Levililəri öz bölmələrində düzdülər.   
\s1 Pasxa bayramının keçirilməsi  
\p
\v 19 \x * \xo 6:19 \xt Çıx. 12:1-20 \x* Sürgündən qayıdanlar Pasxa bayramını birinci ayın on dördündə keçirdilər.  
\v 20 Çünki kahinlərlə Levililər bir nəfər kimi özlərini pak etdikləri üçün təmiz idilər. Levililər bütün sürgündən qayıdanlar üçün, kahin qardaşları və özləri üçün Pasxa qurbanı kəsdilər.  
\v 21 Sürgündən qayıdan İsrail övladları və İsrailin Allahı Rəbbə sitayiş etmək üçün özlərini ətraf millətlərin murdarlığından təcrid edənlərin hamısı qurban əti yedilər.  
\v 22 Yeddi gün sevinclə Mayasız Çörək bayramı keçirdilər, çünki onları sevindirən Rəbb idi. Rəbb İsrail Allahının evinin bərpasına kömək etmək üçün Aşşur padşahının ürəyində meyl yaratmışdı.   
\c 7  
\s1 Ezranın Yerusəlimə gəlməsi  
\p
\v 1 Bu işlərdən sonra Fars padşahı Artaxşastanın dövründə başçı kahin Harun oğlu Eleazar oğlu Pinxas oğlu Avişua oğlu  
\v 2 Buqqi oğlu Uzzi oğlu  
\v 3 Zerahya oğlu Merayot oğlu Azarya oğlu Amarya oğlu  
\v 4 Axituv oğlu Sadoq oğlu Şallum oğlu  
\v 5 Xilqiya oğlu Azarya oğlu Seraya oğlu Ezra Babildən çıxdı.  
\v 6 Babildən gələn bu Ezra İsrailin Allahı Rəbbin Musaya verdiyi Qanunu yaxşı bilən ilahiyyatçı idi. Allahı Rəbbin əli onun üzərində olduğuna görə padşah Ezranın istədiyi hər bir şeyi vermişdi.   
\p
\v 7 Padşah Artaxşastanın hakimiyyətinin yeddinci ilində İsrail övladlarından, kahinlərdən, Levililərdən, ilahiçilərdən, məbəddəki qapıçılardan və qulluqçulardan bəziləri Yerusəlimə qayıtdı.  
\v 8 Ezra Yerusəlimə çatanda Artaxşastanın hökmdarlığının yeddinci ilinin beşinci ayı idi.  
\v 9 O, birinci ayın birinci günündə Babildən yola düşüb beşinci ayın birində Yerusəlimə çatdı, çünki Allahın mərhəmətli əli onun üzərində idi.  
\v 10 Ezra özünü Rəbbin Qanununu tədqiq və tətbiq etməyə, İsraildə qayda-qanunları öyrətməyə həsr etmişdi.   
\s1 Padşah Artaxşastanın Ezraya verdiyi məktub  
\p
\v 11 Rəbbin əmrlərini və İsrailə buyurduğu qanunları öyrədən ilahiyyatçı, kahin Ezraya padşah Artaxşasta bu məzmunda məktub vermişdi:   
\pi1
\v 12 «Padşahlar\f + \fr 7:12 \ft 7:12-26-ya qədər mətn arami dilində yazılmışdır.\f* padşahı Artaxşastadan göylərin Allahının qanunlarını öyrədən kahin Ezraya bildiriş:   
\pi1
\v 13 İndi mən əmr edirəm ki, padşahlığımda olan İsrail xalqından, kahinlərdən, Levililərdən könüllü olaraq Yerusəlimə getmək istəyən hər kəs səninlə getsin.  
\v 14 İndi sən padşahla yeddi məsləhətçisi tərəfindən əlində olan Allahın Qanununa əsasən Yəhuda və Yerusəlimdəki vəziyyəti öyrənmək üçün göndərilirsən.  
\v 15 Yerusəlimi məskəni edən İsrailin Allahına padşah və məsləhətçilərinin könüllü təqdim etdikləri qızıl-gümüşü götür.  
\v 16 Xalqın və kahinlərin İsrailin Allahının Yerusəlimdəki məbədinə könüllü surətdə verdikləri hədiyyələrlə bərabər Babil vilayətinin hər tərəfindən yığacağın qızıl-gümüşün hamısını götür.  
\v 17 Sonra bu pulla tez buğalar, qoçlar, quzular, taxıl və şərab təqdimlərini alarsan. Onları Allahınızın Yerusəlimdəki məbədinin qurbangahında təqdim edərsiniz.  
\v 18 Sən və qardaşların qızıl-gümüşün qalan hissəsini Allahın iradəsinə uyğun, istədiyin kimi istifadə edə bilərsiniz.  
\v 19 Allahının məbədində ibadət zamanı işlətmək üçün sənə qaytarılan qabları isə Yerusəlim Allahının hüzurunda təhvil ver.  
\v 20 Allahın məbədinə başqa nə lazım olarsa, sən onu padşah xəzinəsindən ödə.   
\pi1
\v 21 Mən padşah Artaxşasta Fərat çayının qərb torpaqlarının bütün xəzinədarlarına əmr edirəm ki, göylər Allahının Qanununun ilahiyyatçısı, kahin Ezranın hər istəyini diqqətlə yerinə yetirin.  
\v 22 Yüz talanta qədər gümüş, yüz kora qədər buğda, yüz bata qədər şərab, yüz bata qədər zeytun yağı və istədikləri qədər duz verin.  
\v 23 Göylərin Allahının məbədi üçün, bu Allah tərəfindən hər nə əmr olunarsa, yerli-yerində ona əməl edilsin. Niyə padşahın və övladlarının ölkəsi qəzəbə düçar olsun?  
\v 24 Sizə bildiririk ki, kahinlərdən, Levililərdən, ilahiçilərdən, bu Allah evinin qapıçılarından, qulluqçularından, digər xidmətçilərindən xərac, vergi və gömrük istəməyə izin yoxdur.   
\pi1
\v 25 Sən Ezra Allahın sənə verdiyi müdrikliyə görə orada hakimlər və qazilər təyin et. Qoy onlar Fərat çayının qərbində olan bütün xalqa – sənin Allahının qanunlarını bilənlərin hamısına hökm etsinlər. Bilməyənləri də sən öyrətməlisən.  
\v 26 Sənin Allahının qanununa və padşahın qanununa əməl etməyən adam mütləq ölüm, sürgün, əmlak müsadirəsi yaxud həbs cəzaları ilə cəzalansın».   
\p
\v 27 Atalarımızın Allahı Rəbbə alqış olsun ki, padşahın qəlbində Rəbbin Yerusəlimdə olan məbədinə belə hörmət göstərmək istəyini yaratdı.  
\v 28 Rəbb padşahın, onun məsləhətçilərinin və bütün güclü rəislərinin mənə yaxşı münasibətini yaratdı. Üzərimdə olan Allahım Rəbbin əlindən qüvvət alaraq mənimlə bərabər getmək üçün İsrailin başçılarından bəzilərini yanıma topladım.   
\c 8  
\s1 Ezranın yol yoldaşlarının siyahısı  
\p
\v 1 Artaxşastanın padşahlığı zamanı mənimlə bərabər Babildən gələn və adları qeyd edilmiş nəsil başçıları bunlardır:  
\v 2 Pinxas övladlarından Gerşom, İtamar övladlarından Daniel, Davud övladlarından Xattuş,  
\v 3 Şekanya nəslindən, Paroş övladlarından, Zəkəriyyə və onunla bir nəsildən qeydə alınan yüz əlli kişi.  
\v 4 Paxat-Moav övladlarından Zerahya oğlu Elyehoenay və onunla bərabər iki yüz kişi.  
\v 5 Şekanya övladlarından Yaxazielin oğlu və onunla bərabər üç yüz kişi.  
\v 6 Adin övladlarından Yonatan oğlu Eved və onunla bərabər əlli kişi.  
\v 7 Elam övladlarından Atalya oğlu Yeşaya və onunla bərabər yetmiş kişi.  
\v 8 Şefatya övladlarından Mikael oğlu Zevadya və onunla bərabər səksən kişi.  
\v 9 Yoav övladlarından Yexiel oğlu Avdiya və onunla bərabər iki yüz on səkkiz kişi.  
\v 10 Şelomit övladlarından Yosifyanın oğlu və onunla bərabər yüz altmış kişi.  
\v 11 Bevay övladlarından Bevay oğlu Zəkəriyyə və onunla bərabər iyirmi səkkiz kişi.  
\v 12 Azqad övladlarından Haqqatan oğlu Yoxanan və onunla bərabər yüz on kişi.  
\v 13 Adoniqamın Elifelet, Yeiel, Şemaya adlı sonuncu oğulları və onlarla bərabər altmış kişi.  
\v 14 Biqvay övladlarından Utay, Zakkur və onlarla bərabər yetmiş kişi.   
\s1 Yerusəlimə qayıdış  
\p
\v 15 Onları Ahavaya tərəf axan çayın yanına yığdım və üç gün orada qaldıq. Mən orada xalqla kahinləri yoxladım, lakin orada Levi övladlarından heç kimi tapa bilmədim.  
\v 16 Başçılardan Eliezeri, Arieli, Şemayanı, Elnatanı, Yarivi, Elnatanı, Natanı, Zəkəriyyəni, Meşullamı, savadlılardan Yoyarivi və Elnatanı çağırtdırdım.  
\v 17 Sonra onları Kasifya deyilən yerdə başçılıq edən İddonun yanına göndərdim. Allahımızın məbədinə xidmət edən adamları bizə gətirmək üçün Kasifya deyilən yerdə İddoya və məbəd qulluqçuları olan qardaşlarına nə deyəcəklərini öyrətdim.  
\v 18 Allahımızın mərhəmətli əli üzərimizdə olduğuna görə İsrail oğlu Levi oğlu Maxli övladlarından zəkalı bir adam olan Şerevya ilə oğulları və soydaşlarından on səkkiz nəfəri,  
\v 19 Haşavyanı, onunla bərabər Merari övladlarından Yeşayanı və qardaşları ilə onların övladlarından iyirmi nəfəri,  
\v 20 Levililərə kömək etmək üçün Davudla başçılarının təyin etdikləri məbəd qulluqçularından iki yüz iyirmi nəfəri bizə gətirdilər. Onların hamısı adbaad qeyd olunmuşdu.   
\p
\v 21 Allahımızın qarşısında özümüzü aşağı tutub Ondan özümüz, övladlarımız və bütün malımız üçün təhlükəsiz yol diləməkdən ötrü Ahava çayı yanında oruc elan etdim.  
\v 22 Çünki düşmənə qarşı yolda bizə kömək etmək üçün padşahdan əsgər və atlılar istəməyə utanırdım, həm də padşaha belə söyləmişdik: «Allahımızın əli yaxşılıq etmək üçün Ona etiqad edənlərin üzərindədir. Lakin Ondan dönənlərə Öz gücünü və qəzəbini göstərir».  
\v 23 Elə buna görə də biz oruc tutub Allahımıza yalvardıq. O bizim duamızı qəbul etdi.   
\p
\v 24 Kahinlərin rəhbərləri arasından on iki nəfəri – Şerevya, Xaşavya ilə onların on nəfər soydaşını seçdim.  
\v 25 Padşahın, məsləhətçilərinin, rəislərinin və orada olan bütün İsraillilərin Allahımızın məbədi üçün təqdim etdikləri qızıl və gümüşlə bərabər əşyaları da çəkib onlara verdim.  
\v 26 Onların əlinə altı yüz əlli talant gümüş, yüz talant gümüş əşya, yüz talant qızıl,  
\v 27 min dariklik dəyəri olan iyirmi qızıl boşqab və qızıl qədər qiymətli olan parlaq misdən iki gözəl qabı da çəkib verdim.  
\v 28 Onlara dedim: «Siz Rəbbin müqəddəslərisiniz, bu əşyalar da müqəddəsdir. Bu qızılla gümüş atalarınızın Allahı Rəbbə edilən könüllü təqdimdir.  
\v 29 Diqqətli olun! Onları kahinlərin rəhbərləri, Levililər və İsrailin nəsil başçıları qarşısında Yerusəlimdəki Rəbbin məbədinin otaqlarında çəkib təhvil verənə qədər qoruyun».  
\v 30 Kahinlərlə Levililər çəkilmiş qızıl və gümüşlə qabları Yerusəlimə, Allahımızın məbədinə aparmaq üçün götürdülər.   
\p
\v 31 Yerusəlimə getmək üçün Ahava çayı sahilindən birinci ayın on ikinci günü köçdük. Allahımızın əli üzərimizdə idi və bizi düşmənin əlindən, yolumuzdakı pusqulardan qurtardı.  
\v 32 Biz Yerusəlimə çatıb orada üç gün qaldıq.  
\v 33 Dördüncü gün isə Allahımızın məbədində qızıl-gümüş əşyaları çəkib kahin Uriyanın oğlu Meremotun əlinə verdik. Pinxas oğlu Eleazar, habelə Levililərdən olan Yeşua oğlu Yozavad və Binnuy oğlu Noadya da onunla idi.  
\v 34 Əşyaların hamısı sayla, çəki ilə təhvil veriləndə bütün çəki miqdarı yazıldı.   
\p
\v 35 Bütün İsrail üçün sürgündən qayıdanlar İsrailin Allahına yandırma qurbanı olaraq on iki buğa, doxsan altı qoç, yetmiş yeddi quzu və günah qurbanı olaraq on iki təkə təqdim etdilər. Bunların hamısı Rəbbə təqdim edilən yandırma qurbanları idi.  
\v 36 Sonra onlar padşahın əmrlərini padşahın canişinlərinə və Fərat çayının qərb tərəfindəki valilərinə verdilər. Onlar da xalqa və Allahın evinə kömək etdilər.   
\c 9  
\s1 Ezranın tövbə duası  
\p
\v 1 Bu işlər qurtarandan sonra rəhbərlər mənə yaxınlaşıb dedilər: «Kahinlərlə Levililər daxil olmaqla İsrail xalqı ətraflarındakı xalqların – Kənanlıların, Xetlilərin, Perizlilərin, Yevusluların, Ammonluların, Moavlıların, Misirlilərin, Emorluların iyrənc adətlərinə uyub özlərini onlardan fərqləndirməyiblər.  
\v 2 Belə ki onlar özlərinə və oğullarına ətraflarındakı xalqların qızlarından alıblar. Bununla müqəddəs xalq başqa xalqlarla qarışıb. Rəhbərlərlə məmurlar bu xəyanətə ilk yol açmışlar».  
\v 3 Mən bu sözü eşidəndə paltarımla cübbəmi cırıb saç-saqqalımı yolaraq çarəsiz oturdum.  
\v 4 Sürgündən qayıdanların bu xəyanətinə görə İsrail Allahının sözlərindən lərzəyə gələnlərin hamısı yanıma yığıldı. Mən axşam qurbanı təqdim edilənə qədər çaşqın-çaşqın oturdum.   
\p
\v 5 Axşam qurbanı vaxtı pərişan halda ayağa qalxdım. Paltarım və cübbəm cırıq idi. Dizüstü oturub əllərimi Allahım Rəbbə açıb  
\v 6 belə dua etdim:  
\p «Ey Allahım, utanıram! Üzümü Sənə – Allahıma qaldırmağa xəcalət çəkirəm, çünki təqsirlərimiz başımızdan aşıb, günahlarımız böyüyərək göylərə çatıb.  
\v 7 Atalarımızın dövründən bu günə qədər böyük günah içindəyik. Ona görə də hər zaman bugünkü kimi biz, padşahlarımız, kahinlərimiz təqsirlərimiz üzündən yadelli padşahlara təslim edilib qılınca, əsirliyə, talana, rüsvayçılığa düçar olduq.  
\v 8 İndi isə bizə Allahımız Rəbb tərəfindən ani olaraq mərhəmət göstərildi. Əsirlikdən qurtulub sağ qalan bir neçə adamı Allahımız bizim üçün saxladı. Müqəddəs məkanında bizə möhkəm bir yer verdi ki, gözümüzə nur versin, bizi köləlikdən qurtarıb bir az həyata qovuşdursun.  
\v 9 Axı biz köləyik, lakin Allahımız bizi köləlikdə qoymadı. Bizi Allahımızın məbədini bərpa etmək, onun xarabalıqlarını abad etmək üçün Yəhuda ilə Yerusəlimdə özümüzə divar çəkməyə ruhlandırdı. Ona görə də Fars padşahlarının gözündə bizə qarşı lütf yaratdı.   
\p
\v 10 Ey Allahımız, daha nə deyə bilərik? Çünki Sənin əmrlərini tərk etmişdik.  
\v 11 Sən əmrlərini qulların peyğəmbərlər vasitəsilə verib dedin: “Mülk olaraq almaq üçün getdiyiniz ölkə öz əhalisinin pozğunluğu ilə, oranı başdan-başa dolduran iyrənc adətləri və murdarlıqları ilə çirkaba batan ölkədir.  
\v 12  \x * \xo 9:12 \xt Çıx. 34:11-16; Qanun. 7:1-5 \x* \x * \xo 9:12 \xt Qanun. 23:6 \x* Buna görə də nə qızlarınızı onların oğullarına verin, nə də qızlarından oğullarınıza alın. Əgər qüvvətli olmaq, bu torpağın nemətlərini yemək istəyirsinizsə, heç vaxt onların salamatlığı və firavanlığı üçün çalışmayın. Onda bu torpağı övladlarınıza irs olaraq əbədi saxlayarsınız”.   
\p
\v 13 Hər şey pis işlərimizdən və böyük günahlarımızdan ötrü başımıza gəldi, lakin, ey Allahımız, Sən bizi təqsirlərimizin layiq olduğundan az cəzalandırdın. Əsirlikdən qurtulub sağ qalan bir neçə adamı – bunları bizə verdin.  
\v 14 Bundan sonra yenə əmrlərinimi pozaq? Belə iyrənc işlər görən xalqlarla qohummu olaq? Biz qurtarana, sağ qalıb qurtula bilməyənə qədər bizə qəzəblənməyəcəksənmi?  
\v 15 Ey İsrailin Allahı Rəbb, Sən adilsən! Bugünkü kimi biz kiçik bir dəstə halında sağ qalmışıq. Budur, Sənin qarşında günah içindəyik və buna görə heç birimiz Sənin qarşında dayana bilmirik».   
\c 10  
\s1 Yadellilərlə nikahın pozulması  
\p
\v 1 Ezra Allah evinin qarşısında ağlayıb yerə sərilərək dua və etiraf edərkən İsraillilərdən çox böyük bir camaat – kişilər, qadınlar və uşaqlar onun yanına yığıldı. Xalq da acı-acı ağlayırdı.  
\v 2 Elam övladlarından Yexiel oğlu Şekanya Ezraya müraciət edib dedi: «Biz Allahımıza xəyanət edərək ətrafımızdakı xalqlardan yadelli arvadlar aldıq. Buna baxmayaraq, hələ də İsraillilərin ümidi var.  
\v 3 Ağamızın və Allahımızın əmri üzərində əsənlərin məsləhətinə görə bütün belə arvadları və onlardan doğulanları ataq. Gəlin bunun üçün indi Allahımızla əhd bağlayaq. Qoy bu Qanuna görə edilsin.  
\v 4 Qalx, çünki bu işin məsuliyyətini daşıyan sənsən və biz də səninləyik. Ürəkli ol, işə başla!»   
\p
\v 5 Ezra ayağa qalxdı. Kahinlərin rəhbərlərinə, Levililərə və digər İsraillilərə bu sözü yerinə yetirmələri üçün and içdirdi. Onlar da and içdilər.  
\v 6 Ezra Allah evinin qarşısından ayrılıb Elyaşivin oğlu Yehoxananın otağına girdi. Gecəni orada keçirib nə çörək yedi, nə də su içdi, çünki sürgündən qayıdanların bu xəyanətinə görə yas tuturdu.  
\v 7 Yəhudada və Yerusəlimdə sürgündən qayıdanların hamısına elan etdilər ki, Yerusəlimə yığılsınlar.  
\v 8 Başçıların və ağsaqqalların məsləhətinə görə üç gün ərzində buraya gəlməyən hər adamın bütün əmlakı müsadirə ediləcək və özü də sürgündən qayıdan camaatın içərisindən çıxarılacaq.   
\p
\v 9 Yəhudanın və Binyaminin bütün adamları üç gün ərzində Yerusəlimə yığıldı. Bu doqquzuncu ayın iyirmisində oldu. Bütün xalq bu hadisədən, həm də yağışdan ötrü əsə-əsə Allah evinin qarşısında, meydanda oturdu.  
\v 10 Kahin Ezra ayağa qalxıb onlara dedi: «Siz xəyanət etmisiniz. İsrailin günahını daha da artıraraq yadelli arvadlar almısınız.  
\v 11 İndi atalarınızın Allahı Rəbbə öz günahlarınızı etiraf edin və Onun iradəsini yerinə yetirin. Ətrafınızdakı xalqlardan, yadelli arvadlardan ayrılın».  
\v 12 Bütün camaat bərkdən cavab verib dedi: «Bəli, haqlısan, sənin sözlərinə əməl etmək bizim borcumuzdur.  
\v 13 Amma yağış vaxtıdır, bayırda dayanmağa taqətimiz yoxdur, xalq isə çoxdur. Bu iş bir-iki günün işi deyil. Çünki belə əməllə günahımızı artırmışıq.  
\v 14 Qoy bütün xalqı rəhbərlərimiz təmsil etsin. Bu işə görə Allahımızın coşan qəzəbi soyuyanadək şəhərlərimizdəki hər yadelli arvad alan şəxs şəhər ağsaqqalları və hakimlərlə bərabər təyin olunacaq vaxtda buraya gəlsin».  
\v 15 Buna qarşı yalnız Asahel oğlu Yonatan və Tiqva oğlu Yaxzeya çıxdı. Meşullamla Levili Şabbetay da onlara kömək etdi.   
\p
\v 16 Sürgündən qayıdanlar bu sözə əməl etdi. Kahin Ezra hər nəsildən nəsil başçısını seçib hamısının adını bəyan etdi. Onuncu ayın birində isə oturub bu işi araşdırmağa başladılar.  
\v 17 Onlar birinci ayın birinci gününə qədər yadelli arvad alanların hamısı barədə lazımi qərar çıxartdılar.   
\p
\v 18 Kahin övladları arasında yadelli arvad alanlardan bunlar tapıldı: Yosadaqın oğlu Yeşua övladlarından və qardaşlarından Maaseya Eliezer, Yariv və Gedalya.  
\v 19 Onlar da arvadlarını boşayacaqlarına dair əlbir oldu və öz təqsirlərinə görə təqsir qurbanı olaraq bir qoç təqdim etdi.  
\v 20 İmmer övladlarından Xanani və Zevadya,  
\v 21 Xarim övladlarından Maaseya, Eliya, Şemaya, Yexiel, Uzziya,  
\v 22 Paşxur övladlarından Elyoenay, Maaseya, İsmail, Netanel, Yozavad və Elasa;   
\p
\v 23 Levililərdən: Yozavad, Şimey, Qelaya, yəni Qelita, Petahya, Yəhuda və Eliezer;   
\p
\v 24 İlahiçilərdən: Elyaşiv, məbəd qapıçılarından Şallum, Telem və Uri;   
\p
\v 25 Digər İsraillilərdən – Paroş övladlarından Ramya, İzziya, Malkiya, Miyamin, Eleazar, Malkiya və Benaya;  
\v 26 Elam övladlarından Mattanya, Zəkəriyyə, Yexiel, Avdi, Yeremot və Eliya;  
\v 27 Zattu övladlarından Elyoenay, Elyaşiv, Mattanya, Yeremot, Zavad və Aziza;  
\v 28 Bevay övladlarından Yehoxanan, Xananya, Zabbay, Atlay;  
\v 29 Bani övladlarından Meşullam, Malluk, Adaya, Yaşuv, Şeal, Yeremot;  
\v 30 Paxat-Moav övladlarından Adna, Kelal, Benaya, Maaseya, Mattanya, Besalel, Binnuy və Menaşşe;  
\v 31 Xarim övladlarından Eliezer, İşşiya, Malkiya, Şemaya və Şimeon,  
\v 32 Binyamin, Malluk, Şemarya;  
\v 33 Xaşum övladlarından Mattenay, Mattata, Zavad, Elifelet, Yeremay, Menaşşe, Şimey;  
\v 34 Bani övladlarından Maaday, Amram, Uel,  
\v 35 Benaya, Bedeya, Keluhi,  
\v 36 Vanya, Meremot, Elyaşiv,  
\v 37 Mattanya, Mattenay, Yaasay,  
\v 38 Bani, Binnuy, Şimey,  
\v 39 Şelemya, Natan, Adaya,  
\v 40 Maknadvay, Şaşay, Şaray,  
\v 41 Azarel, Şelemya, Şemarya,  
\v 42 Şallum, Amarya, Yusif;  
\v 43 Nevo övladlarından Yeiel, Mattitya, Zavad, Zevina, Yadday, Yoel və Benaya.   
\p
\v 44 Bu adamların hamısı yadelli arvad almışdı və bəzilərinin bu arvadlardan uşaqları da var idi.   