\c 19  
\p
\v 1  \w The|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w spoke|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w* \w and|strong="H4872"\w* Aaron:  
\v 2 “\w This|strong="H2063"\w* \w is|strong="H3068"\w* \w the|strong="H5921"\w* \w ordinance|strong="H2708"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* \w law|strong="H8451"\w* \w which|strong="H3068"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w has|strong="H3068"\w* \w commanded|strong="H6680"\w*: ‘\w Instruct|strong="H6680"\w* \w the|strong="H5921"\w* \w Israelites|strong="H3478"\w* \w to|strong="H1696"\w* \w bring|strong="H5927"\w* \w you|strong="H6680"\w* \w a|strong="H3068"\w* red \w heifer|strong="H6510"\w* \w without|strong="H3808"\w* \w blemish|strong="H8549"\w*, \w which|strong="H3068"\w* \w has|strong="H3068"\w* \w no|strong="H3808"\w* \w defect|strong="H8549"\w* \w and|strong="H1121"\w* \w has|strong="H3068"\w* \w never|strong="H3808"\w* \w carried|strong="H5927"\w* \w a|strong="H3068"\w* \w yoke|strong="H5923"\w*.  
