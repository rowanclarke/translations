\c 8  
\s1 Huta rhoek loh a Bongyong  
\p
\v 1 \w Te|strong="G3588"\w* \w a\w* \w poeng|strong="G1096"\w* \w phoeiah|strong="G1722"\w* \w amah|strong="G0846"\w* \w loh \w*\w khopuei|strong="G4172"\w* \w boeih|strong="G2596"\w* \w neh|strong="G2532"\w* \w vangca|strong="G2968"\w* \w patoeng|strong="G2517"\w* \w a\w* \w hil|strong="G1353"\w*. \w Te\w* \w vaengah|strong="G2532"\w* \w Pathen|strong="G2316"\w* \w ram|strong="G0932"\w* \w te|strong="G3588"\w* \w a\w* \w hoe|strong="G2784"\w* tih a olthangthen \w a\w* \w thui|strong="G2097"\w*. A hnukbang \w hlainit|strong="G1427"\w* \w loh|strong="G3588"\w* \w anih|strong="G0846"\w* \w te|strong="G4862"\w* \w a \w* puei\w uh\w*.  
