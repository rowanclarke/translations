\v 35 \w y|strong="G2532"\w* \w le|strong="G1722"\w* \w dijo|strong="G5346"\w*: \w Te|strong="G4771"\w* \w oiré|strong="G1251"\w* \w cuando|strong="G3752"\w* comparezcan \w también|strong="G2532"\w* \w tus|strong="G3588"\w* \w acusadores|strong="G2725"\w*. \w Y|strong="G2532"\w* \w mandó|strong="G2753"\w* \w que|strong="G3588"\w* \w él|strong="G3588"\w* \w fuera|strong="G1722"\w* custodiado \w en|strong="G1722"\w* \w el|strong="G3588"\w* Palacio \w de|strong="G1722"\w* Justicia \w de|strong="G1722"\w* \w Herodes|strong="G2264"\w*.   
\c 24  
\s1 Acusación contra Pablo  
\p
\v 1 \w Cinco|strong="G4002"\w* \w días|strong="G2250"\w* \w después|strong="G3326"\w* \w el|strong="G3588"\w* sumo sacerdote Ananías bajó \add a Cesarea\add* \w con|strong="G3326"\w* \w algunos|strong="G5100"\w* \w ancianos|strong="G4245"\w* \w y|strong="G2532"\w* \w el|strong="G3588"\w* abogado \w Tértulo|strong="G5061"\w*, quienes comparecieron \w ante|strong="G2596"\w* \w el|strong="G3588"\w* \w gobernador|strong="G2232"\w* \w contra|strong="G2596"\w* \w Pablo|strong="G3972"\w*.  
\v 2 Cuando \w fue|strong="G1096"\w* \w llamado|strong="G2564"\w*, \w Tértulo|strong="G5061"\w* comenzó \w a|strong="G1161"\w* \w acusar|strong="G2723"\w*: Estamos disfrutando \w de|strong="G1223"\w* \w mucha|strong="G4183"\w* \w paz|strong="G1515"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1223"\w* ti. Debido \w a|strong="G1161"\w* \w tu|strong="G4771"\w* provisión \w se|strong="G1096"\w* \w hacen|strong="G1096"\w* reformas \w en|strong="G1223"\w* \w esta|strong="G3588"\w* \w nación|strong="G1484"\w*,  
\v 3 \add lo cual\add* recibimos \w por|strong="G1223"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* medios \w y|strong="G2532"\w* \w en|strong="G1223"\w* \w todas|strong="G3956"\w* partes \w con|strong="G3326"\w* gratitud, oh \w excelentísimo|strong="G2903"\w* \w Félix|strong="G5344"\w*.  
\v 4 \w Pero|strong="G1161"\w*, \w a|strong="G1909"\w* fin \w de|strong="G1909"\w* \w no|strong="G3361"\w* importunarte \w más|strong="G1161"\w*, \w te|strong="G4771"\w* suplico \w que|strong="G3588"\w* nos oigas \w brevemente|strong="G4935"\w* \w con|strong="G1909"\w* \w tu|strong="G4771"\w* bondad.   
\p
\v 5 \w Porque|strong="G1063"\w* descubrimos \w que|strong="G3588"\w* \w este|strong="G3778"\w* hombre \w es|strong="G3778"\w* \w una|strong="G3588"\w* amenaza pública \w que|strong="G3588"\w* promueve altercados \w entre|strong="G2596"\w* \w los|strong="G3588"\w* \w judíos|strong="G2453"\w* \w en|strong="G2596"\w* \w toda|strong="G3956"\w* \w la|strong="G3588"\w* \w tierra|strong="G3625"\w* habitada \w y|strong="G2532"\w* \w es|strong="G3778"\w* \w un|strong="G3588"\w* cabecilla \w de|strong="G2596"\w* \w la|strong="G3588"\w* secta \w de|strong="G2596"\w* \w los|strong="G3588"\w* \w nazarenos|strong="G3480"\w*.  
\v 6 Incluso intentó profanar \w el|strong="G3588"\w* \w Templo|strong="G2411"\w*. \w Por|strong="G3739"\w* \w tanto|strong="G3739"\w* \w lo|strong="G3588"\w* arrestamos. [[ 
\v 7 ]]  
\v 8 \w Al|strong="G4012"\w* examinarlo \w con|strong="G3844"\w* \w respecto|strong="G4012"\w* \w a|strong="G3844"\w* \w todo|strong="G3956"\w* \w esto|strong="G3778"\w*, \w tú|strong="G3844"\w* mismo \w podrás|strong="G1410"\w* \w saber|strong="G1921"\w* \w por|strong="G4012"\w* \w qué|strong="G3739"\w* \w lo|strong="G3739"\w* \w acusamos|strong="G2723"\w*.   
\p
\v 9 \w Los|strong="G3588"\w* \w judíos|strong="G2453"\w* \w también|strong="G2532"\w* \w se|strong="G3779"\w* unieron \w en|strong="G3588"\w* \w el|strong="G3588"\w* ataque \w y|strong="G2532"\w* afirmaron \w que|strong="G3588"\w* todo \w esto|strong="G3778"\w* \w era|strong="G2192"\w* cierto.   
\s1 Defensa de Pablo ante Félix  
\p
\v 10 \w El|strong="G3588"\w* \w gobernador|strong="G2232"\w* le hizo \w una|strong="G3588"\w* \w señal|strong="G3506"\w* \w para|strong="G4012"\w* \w que|strong="G3588"\w* hablara.  
\p \w Pablo|strong="G3972"\w* respondió: \w Por|strong="G1537"\w* \w cuanto|strong="G4012"\w* \w estoy|strong="G1510"\w* enterado \w de|strong="G1537"\w* \w que|strong="G3588"\w* \w desde|strong="G1537"\w* hace \w muchos|strong="G4183"\w* \w años|strong="G2094"\w* \w tú|strong="G4771"\w* \w eres|strong="G1510"\w* \w juez|strong="G2923"\w* \w para|strong="G4012"\w* \w esta|strong="G3778"\w* \w nación|strong="G1484"\w*, \w con|strong="G1537"\w* \w buen|strong="G1537"\w* ánimo \w me|strong="G1683"\w* defiendo \w de|strong="G1537"\w* \w esta|strong="G3778"\w* acusación.  
\v 11 Debes \w saber|strong="G1921"\w* \w que|strong="G3754"\w* solo hace 12 \w días|strong="G2250"\w* subí \w a|strong="G1519"\w* \w adorar|strong="G4352"\w* \w en|strong="G1519"\w* Jerusalén.  
\v 12 \w No|strong="G3777"\w* discutía \w con|strong="G1722"\w* \w alguno|strong="G5100"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w Templo|strong="G2411"\w*, \w ni|strong="G3777"\w* provocaba \w un|strong="G5100"\w* motín \w en|strong="G1722"\w* \w las|strong="G3588"\w* congregaciones judías, \w ni|strong="G3777"\w* \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w ciudad|strong="G4172"\w*,  
\v 13 \w ni|strong="G3761"\w* \w pueden|strong="G1410"\w* probarte aquello \w de|strong="G4012"\w* \w lo|strong="G3739"\w* \w cual|strong="G3739"\w* \w me|strong="G1473"\w* \w acusan|strong="G2723"\w*.   
\p
\v 14 \w Pero|strong="G1161"\w* \w te|strong="G4771"\w* \w confieso|strong="G3670"\w* \w que|strong="G3754"\w* \w según|strong="G2596"\w* \w el|strong="G3588"\w* \w Camino|strong="G3598"\w* \w que|strong="G3754"\w* \w ellos|strong="G3588"\w* \w llaman|strong="G3004"\w* \w secta|strong="G3598"\w*, \w sirvo|strong="G3000"\w* \w al|strong="G3588"\w* \w Dios|strong="G2316"\w* \w de|strong="G1722"\w* \w mis|strong="G2596"\w* antepasados. \w Creo|strong="G4100"\w* \w todo|strong="G3956"\w* \w lo|strong="G3588"\w* \w que|strong="G3754"\w* \w es|strong="G3739"\w* \w según|strong="G2596"\w* \w la|strong="G3588"\w* \w Ley|strong="G3551"\w* \w y|strong="G2532"\w* \w los|strong="G3588"\w* \w profetas|strong="G4396"\w*.  
\v 15 \w Tengo|strong="G2192"\w* \w la|strong="G3588"\w* \w esperanza|strong="G1680"\w* \w en|strong="G1519"\w* \w Dios|strong="G2316"\w*, \w la|strong="G3588"\w* \w cual|strong="G3739"\w* \w ellos|strong="G3588"\w* mismos \w también|strong="G2532"\w* aceptan, \w de|strong="G1519"\w* \w una|strong="G3588"\w* resurrección \w tanto|strong="G3739"\w* \w de|strong="G1519"\w* \w justos|strong="G1342"\w* \w como|strong="G2532"\w* \w de|strong="G1519"\w* injustos.  
\v 16 \w Por|strong="G1223"\w* \w esto|strong="G3778"\w*, \w también|strong="G2532"\w* yo mismo procuro \w tener|strong="G2192"\w* \w siempre|strong="G3588"\w* \w una|strong="G3588"\w* \w conciencia|strong="G4893"\w* irreprensible \w en|strong="G1722"\w* relación \w con|strong="G1722"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w con|strong="G1722"\w* \w los|strong="G3588"\w* hombres.   
\p
\v 17 \w Después|strong="G2532"\w* \w de|strong="G1519"\w* \w algunos|strong="G3588"\w* \w años|strong="G2094"\w* \w me|strong="G1473"\w* \w presenté|strong="G4376"\w* \w a|strong="G1519"\w* \w mi|strong="G3588"\w* \w nación|strong="G1484"\w* \w para|strong="G1519"\w* dar \w limosnas|strong="G1654"\w* \w y|strong="G2532"\w* \w ofrendas|strong="G4376"\w*.  
\v 18 \w Después|strong="G3326"\w* \w de|strong="G1722"\w* haberme purificado, \w me|strong="G1473"\w* \w hallaron|strong="G2147"\w* \w en|strong="G1722"\w* \w estas|strong="G3588"\w* \w cosas|strong="G3739"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w Templo|strong="G2411"\w*, \w no|strong="G3756"\w* \w con|strong="G3326"\w* turba \w ni|strong="G3761"\w* \w con|strong="G3326"\w* \w alboroto|strong="G2351"\w*,  
\v 19 \add pero me detuvieron\add* \w porque|strong="G1161"\w* \w algunos|strong="G5100"\w* \w judíos|strong="G2453"\w* \w de|strong="G1909"\w* Asia \add me acusaron\add*.  
\p Estos deberían \w comparecer|strong="G3918"\w* \w ante|strong="G1909"\w* \w ti|strong="G3739"\w* \w y|strong="G2532"\w* decir \w si|strong="G1487"\w* \w tienen|strong="G2192"\w* \w algo|strong="G5100"\w* \w de|strong="G1909"\w* \w que|strong="G3739"\w* acusarme.  
\v 20 \w O|strong="G2228"\w* digan \w éstos|strong="G3778"\w* \w cuál|strong="G5101"\w* delito \w hallaron|strong="G2147"\w* \w cuando|strong="G1909"\w* estuve \w ante|strong="G1909"\w* \w el|strong="G3588"\w* Tribunal Supremo \w de|strong="G1909"\w* \w los|strong="G3588"\w* judíos,  
