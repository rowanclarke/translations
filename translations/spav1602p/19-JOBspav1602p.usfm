\v 25 Calificaba yo \w el|strong="H3427"\w* \w camino|strong="H1870"\w* de ellos, y sentábame en cabecera; y \w moraba|strong="H3427"\w* \w como|strong="H7931"\w* \w rey|strong="H4428"\w* en \w el|strong="H3427"\w* \w ejército|strong="H1416"\w*, \w como|strong="H7931"\w* \w el|strong="H3427"\w* \w que|strong="H1416"\w* \w consuela|strong="H5162"\w* llorosos.
\c 30
\m 
\v 1 \w MAS|strong="H4480"\w* \w ahora|strong="H6258"\w* \w los|strong="H5921"\w* \w más|strong="H4480"\w* mozos \w de|strong="H4480"\w* \w días|strong="H3117"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w*, \w se|strong="H5921"\w* ríen \w de|strong="H4480"\w* \w mí|strong="H5921"\w*; \w cuyos|strong="H5921"\w* padres \w yo|strong="H4480"\w* desdeñara ponerlos \w con|strong="H5973"\w* \w los|strong="H5921"\w* \w perros|strong="H3611"\w* \w de|strong="H4480"\w* \w mi|strong="H5921"\w* \w ganado|strong="H6629"\w*.
