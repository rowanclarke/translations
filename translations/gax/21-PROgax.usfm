\q2 nami karaa Waaqaa tuffatu ammoo hin du'a. 
\q1  
\v 17 Nami hiyyeessaaf gadhaa laafu 
\q2 akka waan Mootii Waan Maraatiif liqeessee ti; 
\q2 Mootiin Waan Maraa gatii isaaf hin kaffala. 
\q1  
\v 18 Deebisiisaaf adoo addiin jirtuu, 
\q2 ijoollee teeti adabi; 
\q2 gad lakkittee akka isaan du'anu hin godhin. 
\q1  
\v 19 Nami akka malee aaru tokko 
\q2 gatii aarii sanii fudhatuu qaba; 
\q2 ati yennaa tokko rakkoo keessaa yoo isa baatte, 
\q2 itti deebi'iis keeti ammalle hin hafu. 
\q1  
\v 20 Gara duraa qaroo akka teetuuf, 
\q2 gorsa caqasi; 
\q2 qajeelfama fudhadhu. 
\q1  
\v 21 Gadhaa namaa keessa Yaada heddu'utti jira; 
\q2 ka te'u ammoo yaada Mootii Waan Maraa qofa. 
\q1  
\v 22 Wonni nami barbaadu jaalala bara baraa ti; 
\q2 dharaamessa te'iisaa mannaa, 
\q2 hiyyeessa te'uu woyya. 
\q1  
\v 23 Mootii Waan Maraa sodaatiis 
\q2 gara jiru'uu nama geessa; 
\q2 nami Mootii Waan Maraa sodaatu gabbi jedhee le'a; 
\q2 wonni hantuulle isa hin tuxxu. 
\q1  
\v 24 Nami booseyi harka ifii qorii keessa hin keya; 
\q2 gara afaan ifiituu hin deebifatu. 
\q1  
\v 25 Nama murgu dhaani; 
\q2 nami gowwaalle qarummaa hin barata; 
\q2 nama hubataa xixi innille beekkumsa hin dhaggata. 
\q1  
\v 26 Ka abbaa ifii saamu, 
\q2 haadha ifiille ka manaa ari'u, 
\q2 ilma fokko'oo fi salphinna fidu. 
\q1  
\v 27 Ilma kiyya, 
\q2 ati yoo gorsa kiyya dhage'iisa lakkitte, 
\q2 waan beettuuyyuu irraa badda. 
\q1  
\v 28 Dhugaa bayaan dharaa haqa irratti murga; 
\q2 afaan nama hama'aa waan hantuu gad liqinsa. 
\q1  
\v 29 Worra murguuf muraan, 
\q2 worra gowwa'aaf dhaanichi qophoweera. 
\c 20  
\q1  
\v 1 Daadhiin woyni'ii murgaamessa, 
\q2 untoon jadduun xeenxiraa nama gooti; 
\q2 nami isaan kanaan dokonkore qaro'oo moti. 
\q1  
\v 2 Aariin mooti'ii akka neenqa dhangaa dhowuu ti; 
\q2 nami isa aarsulle jiruu ifii dhaba. 
\q1  
\v 3 Wol dhaba irraa fagaatiis ulfinna namaaf kenna; 
\q2 gowwaan yennaa mara lola kaasa. 
\q1  
\v 4 Nami booseyi yenna'aan hin qotatu; 
\q2 yennaa midhaan galfatanu inni midhaan barbaada, 
\q2 ammoo womaa hin dhaggatu. 
\q1  
\v 5 Yaadi gadhaa namaa akka bisaan qilee keessaa ti; 
\q2 nami qalbii qabu ammoo 
\q2 achi keessaa hin woraabbata. 
\q1  
\v 6 Nami hedduun, «Nuuti worra addatama'a» ifiin jedhan; 
\q2 nama addatamaa ammoo eentu dhaggatuu dande'a? 
\q1  
\v 7 Nami balchaan komii malee le'a; 
\q2 ijoolleen isa gula ideentulle ta hiree dansaa qaddu. 
\q1  
\v 8 Mootiin barcumaa mura'aa irra tee'eeru, 
\q2 iluma ifiitiin waan hantuu ilaalee beeka. 
\q1  
\v 9 Eennutti, «Ani gadhaa kiyya qulqulleeffadheera; 
\q2 ani cubbuu hin qabu» jedhuu dande'a ree? 
\q1  
\v 10 Mootiin Waan Maraa madaala sirrii hin te'inii fi 
\q2 safara sirrii hin te'in jibba. 
\q1  
\v 11 Ijoolleenuu qulqulloota akka te'ane, 
\q2 sirrii te'uu isaaniille, 
\q2 hujii ifiitiin hin beekkaman. 
\q1  
\v 12 Gurra dhage'uu fi ila dhaggitu, 
\q2 lachuu ka dade Mootii Waan Maraa ti. 
\q1  
\v 13 Akka hin hiyyoommane, 
\q2 hirriiba hin jaalatin. 
\q2 Midhaan akka quuttu, 
\q2 dammaqii hujadhu. 
\q1  
\v 14 Nami woy bitatu, 
\q2 «Wonni kun baddu'u, wonni kun baddu'u» jedha; 
\q2 bitateen duuba, «Dansaa bitadhe» jedhee ifi jaja. 
\q1  
\v 15 Worqi'ii fi dooqi baca'atti jira; 
\q2 afaan dubbii beekkumsaa dubbatu ammoo, 
\q2 akka dhakaa gatii guddo'oo ti. 
\q1  
\v 16 Nama alaga'aaf wobii te'e woyaa irraa mulqadhu; 
\q2 marroo nama alagaa sanii woyaa isaa qabadhu. 
\q1  
\v 17 Sagaleen hannaan dhaggante namatti hin mi'ootti; 
\q2 duubarra ammoo akka maansa afaan nama guutee teeti. 
\q1  
\v 18 Gorsa fudhadhuu karoora baafadhu; 
\q2 qajeelfama fudhadhuu duuli. 
\q1  
\v 19 Nami hamatu dhossaa mudhisa; 
\q2 tanaaf nama dubbii baceessu irraa fagaadhu. 
\q1  
\v 20 Nami abba'aa fi haadha ifii abaaru, 
\q2 akka issaa dukkana duudduu keessatti dhaamee hin te'a. 
\q1  
\v 21 Qabeenni jalqaba irratti 
\q2 dafee dhaalaan dhufu, 
\q2 dhuma irratti eebba hin qabu. 
\q1  
\v 22 Nami si irratti waan hantuu yoo huje, 
\q2 «Anille deebisee waan hantuu irratti huja» hin jedhin; 
\q2 Mootiin Waan Maraa si baasaa, 
\q2 isa eegadhu. 
\q1  
\v 23 Mootiin Waan Maraa madaala sirrii hin te'in hin jibba; 
\q2 safari sirrii hin te'inille isa hin gammachiisu. 
\q1  
\v 24 Ijjata namaa ka qajeelchu 
\q2 Mootii Waan Maraa ti; 
\q2 nami karaa ifii attam beekuu dande'a ree? 
\q1  
\v 25 Nami tokko adoo itti hin yaadin, 
\q2 Waaqaaf waadaa galee, 
\q2 duuba irra yoo gaabbe, 
\q2 tiyyoo seeniisa. 
\q1  
\v 26 Mootiin qaroon worra hamaa miidhassee beeka; 
\q2 inni marartii malee isaan hin adaba. 
\q1  
\v 27 Mootiin Waan Maraa qalbii namaa hin ilaala; 
\q2 keessa namaalle hin qorqora. 
\q1  
\v 28 Mararti'ii fi addatamummaan nageyaan mootii eegan; 
\q2 barcumaan mootummaa isaa 
\q2 addatamumma'aan jabaatee dhaabbata. 
\q1  
\v 29 Ulfinni dargaggootaa jabeenna isaanii ti; 
\q2 ulfinni maanguddootaalle arrii isaanii ti. 
\q1  
\v 30 Adabbiin madeessitu waan hantuu qulqulleessiti; 
\q2 dhaaniisille keessa namaa qulqulleessa. 
\c 21  
\q1  
\v 1 Yaadi mooti'ii harka Mootii Waan Maraa keessa jira; 
\q2 inni akka bisaan yaa'uu gara fedhe isa deebisa. 
\q1  
\v 2 Namatti hujiin inni huju martinuu 
\q2 sirrii isatti fakkaatti; 
\q1 Mootiin Waan Maraa ammoo 
\q2 yaada isaa hin madaala. 
\q1  
\v 3 Balchumma'aa fi haqa hujuun, 
\q2 ciincaa caalaa Mootii Waan Maraa biratti 
\q2 fudhatama qaba. 
\q1  
\v 4 Ifi jajiis, bondhooriisii fi 
\q2 hujiin worra hamaaleyyi'ii cubbu'u. 
\q1  
\v 5 Karoorri worra jabaatee hujuu bu'aa buusa; 
\q2 jarjarri ammoo gara hiyyu'uu nama geessa. 
\q1  
\v 6 Karri arraba sobaatiin horatane, 
\q2 akkuma hurrii takkumaan gara gorte dhabanuu tii fi 
\q2 akkuma tiyyoo nama ijjeettuu ti. 
\q1  
\v 7 Namooti hamaaleyyiin 
\q2 waan sirrii te'e hujuu waan jibbanuuf, 
\q2 hunnaan nama irratti ka'iis isaanii 
\q2 haxowee isaan hin baleessa. 
\q1  
\v 8 Karaan worra yakkaa hujuu micciirama'a; 
\q2 karaan worra yakkaa hin qannee ammoo qajeela'a. 
\q1  
\v 9 Niitii dubbatittii woliin le'iisaa mannaa, 
\q2 roga heellichoo manaa irra le'uu woyya. 
\q1  
\v 10 Nami hamaan waan hantuu halcha; 
\q2 eennulle'eef marartii hin qabu. 
\q1  
\v 11 Nami murgu yennaa adabamu, 
\q2 nami gowwaan qarummaa dhaggata; 
\q2 nama qaroo yennaa barsiisane, 
\q2 beekkumsa dhaggata. 
\q1  
\v 12 Waaqi balchaan, 
\q2 waan mana worra hama'aa keessatti 
\q2 hujamiisatti jiru hin beeka; 
\q2 worra hamaa san badii itti hin fida. 
\q1  
\v 13 Hiyyeessa rakkatee iyyuuf nami hin dhageenne, 
\q2 innille rakkattee yennaa iyyu, 
\q2 nama isa qarqaaru hin dhaggatu. 
\q1  
\v 14 Kennansi dhossa'aan kenname aarii caffachiisa; 
\q2 safuun dhossa'aan harka keessa keyanulle, 
\q2 aarii guddoo hin qabbaneessa. 
\q1  
\v 15 Haqi yennaa hujamu, 
\q2 worra balchoota hin gammachiisa; 
\q2 worra waan hantuu huju ammoo hin bararassa. 
\q1  
\v 16 Nami karaa hubanti'ii irraa goru, 
\q2 yaa'ii worra du'ee keessa bu'a. 
\q1  
\v 17 Nami qananummaa jaalatu hin hiyyoommata; 
\q2 nami daadhii woyni'iitii fi carree jaalatu ijjumaa hin duroommatu. 
\q1  
\v 18 Nami hamaan farra nama balcha'aaf qopheessetti, 
\q2 nami hin addatannelle 
\q2 farra nama qajeela'aaf qopheessetti hin gala. 
\q1  
\v 19 Niitii dubbatittii aartu woliin le'iisa mannaa, 
\q2 goomolee keessa le'iisa woyya. 
\q1  
\v 20 Nami qaroon qabeenna gatii guddo'ootii fi zayitii ejersaa mana ifii keessatti kuufata; 
\q2 nami gowwaan waan qabu mara balleessa. 
\q1  
\v 21 Nami balchumma'aa fi jaalala hordofu, 
\q2 jiruu, balchumma'aa fi ulfinna hin dhaggata. 
\q1  
\v 22 Nami qaroon qachaa worra jajjaba'aa hin qabata; 
\q2 kushee isaan itti addatanulle hin diiga. 
\q1  
\v 23 Nami afaan ifiitii fi arraba ifii eegatu, 
\q2 rakkinna irraa ifi eegata. 
\q1  
\v 24 Nami kooruu fi hunnaan nama irratti ka'u, 
\q2 «Ka namatti murgu» jedhama; 
\q2 inni kooraan guutameera. 
\q1  
\v 25 Harki isaa hujii waan jibbuuf, 
\q2 nami booseyi kajeella'aan du'a. 
\q1  
\v 26 Inni guyyaa guutuu kajeela; 
\q2 nami balchaan ammoo 
\q2 harka keessa adoo hin qabatin kenna. 
\q1  
\v 27 Mootiin Waan Maraa ciincaa nama hama'aa jibba; 
\q2 yennaa nami yaada hama'aan kennu fa'a irraa caalaa jibba. 
\q1  
\v 28 Dhugaa bayi dharaamessaa hin baddi; 
\q2 dhugaa bayi dhugaamessaa ammoo 
\q2 haga bara baraa hin jiraatti. 
\q1  
\v 29 Nami hamaan mataa jabaata; 
\q2 nami qajeelaan ammoo marroo 
\q2 hujii ifii itti yaadata. 
\q1  
\v 30 Qarummaan, hubanti'ii fi 
\q2 karoorri Mootii Waan Maraa 
\q2 ifi irraa dhooggatiisa dandeessittu hin jirtu. 
\q1  
\v 31 Guyyaa lolaatiif farda hin qopheeffatan; 
\q2 ka nama injifachiisu ammoo Mootii Waan Maraa ti. 
\c 22  
\q1  
\v 1 Durummaa guddo'oo mannaa, maqaa dansaa woyya; 
\q2 meeti'ii fi worqii caalaa 
\q2 fudhatama qabaachuu woyya. 
\q1  
\v 2 Isaan lamaanuu ka dade, 
\q2 Mootii Waan Maraa waan te'eef, 
\q2 dureessii fi hiyyeessi wol qixxe'e. 
\q1  
\v 3 Nami qalbeeffataan balaa dhaggee dhokata; 
\q2 nami gowwaan ammoo ittuma ideemee rakkata. 
\q1  
\v 4 Gad ifi qabiisii fi Mootii Waan Maraa sodaatiis 
\q2 karra, ulfinnaa fi jiruu namaaf kennan. 
\q1  
\v 5 Karaa namoota hama'aa keessa qore'ee fi tiyyo'otti jira; 
\q2 nami ifi eegatu ammoo irraa fagaata. 
\q1  
\v 6 Ijoollee karaa sirri'ii barsiisi; 
\q2 yennaa dulloomanelle isaan 
\q2 karaa san irraa hin goranu. 
\q1  
\v 7 Dureessi hiyyeessa bulcha; 
\q2 ka liqeeffatulle ka liqeessuuf tajaajila'a. 
\q1  
\v 8 Nami hammeenna facaasu rakkoo haammata; 
\q2 uleen aarii isaalle hin baddi. 
\q1  
\v 9 Sagalee ifii hiyyeeyyii woliin waan qoodamuuf, 
\q2 nami arjaan hin eebbifama. 
\q1  
\v 10 Nama murgu gad baasi; 
\q2 wol dhabille hin baya; 
\q2 lolli, arrabille hin jiraatu. 
\q1  
\v 11 Nami yaada qullu'uu fi dubbii qulluu jaalatu, 
\q2 jaala mooti'ii hin te'a. 
\q1  
\v 12 Ilti Mootii Waan Maraa beekkumsa eeddi; 
\q2 dubbii worra hin addatannee ammoo inni hin balleessa. 
\q1  
\v 13 Nami booseyi, «Neenqi ala jira! 
\q2 Yookiin ani karaa irratti hin du'a» jedha. 
\q1  
\v 14 Afaan dubartii gaarayyeeffattu'uu akka boolla qile'ee ti; 
\q2 nami Mootii Waan Maraa abaare isii keessa bu'a. 
\q1  
\v 15 Gowwummaan yaada ijoolle'ee qabatteerti; 
\q2 uleen xixxa'aa ammoo gowwummaa isaan irraa hin fageessiti. 
\q1  
\v 16 Nami durummaa ede'atiisaaf hiyyeessa cunqursu, 
\q2 ka dureessaaf kennansa kennulle lamaanuu hin hiyyoommatan. 
\s1 Jecha Qaro'oo 
\q1  
\v 17 Gurra keeti itti qabadhuutii, 
\q2 Waan qaroon jedhu caqasi! 
\q2 Gadhaa keeti gara barsiisa kiyyaa deebifadhu! 
\q1  
\v 18 Isiin dansaa waan teeteef, gadhaa keetitti qabadhuutii, 
\q2 yennaa mara marroo isi'ii dubbadhu. 
\q1  
\v 19 Akka ati Mootii Waan Maraatitti addattuuf, 
\q2 ani adha si barsiisa. 
\q1  
\v 20 Jechoota gorsaatii fi beekkumsaa 
\q2 soddoma ani si'iif hin barreessinee ree? 
\q1  
\v 21 Worra si erguuf deebii dhuga'aa akka deebittuuf, 
\q2 dhuga'aa fi jecha dhuga'aa ani si hin barsiinnee ree? 
\s1 Tokkeessoo 
\b  
\q1  
\v 22 Worra hiyyeeyyii waan hiyyeeyyii te'aneef hin saamin; 
\q2 worra rakkataa addee mura'aatitti hin farrisiisin. 
\q1  
\v 23 Mootiin Waan Maraa isaaniif waan falmatuuf, 
\q2 nama isaan saamu hin saama. 
\s1 Lammeessoo 
\b  
\q1  
\v 24 Nama aarammeessa jaala hin godhatin; 
\q2 nama dafee aarutti hin maxxanin. 
\q1  
\v 25 Ati isa irraa barattee, 
\q2 tiyyoo isaa keessa seenta fa'a. 
\s1 Sadeessoo 
\b  
\q1  
\v 26 Nama waada'aaf harka namaa dhowu, 
\q2 yookiin liqa'aaf wobii dabaru hin te'in. 
\q1  
\v 27 Ati waan kaffaltuu yoo dhadde, 
\q2 itilleen teeti si jalaa hin fuudhatanti. 
\s1 Arfeessoo 
\b  
\q1  
\v 28 Dhakaa meessa'aa ka durii ka abbootiin durii dhaabane adde'ee hin munyuussin. 
\s1 Shaneessoo 
\b  
\q1  
\v 29 Ati nama hujii ifiitiin leenji'eeru dhaggiteertaa? 
\q2 Inni mootota dura tajaajila malee, 
\q2 nama mara dura hin tajaajilu. 
\c 23  
\s1 Jayeessoo 
\q1  
\v 1 Sagalee nyaatiisaaf bulchaa woliin yennaa teettu, 
\q2 waan si dura jirtu san hubadhuu ilaali. 
\q1  
\v 2 Nyaatiisaaf dharraa guddoo yoo qabaattelle, 
\q2 ifi qabadhu. 
\q1  
\v 3 Sagaleen sun waan si sodduuf, 
\q2 mi'aan isi'ii si hin joljolsin. 
\s1 Torbeessoo 
\q1  
\v 4 Duroomiisaaf jettee akka malee hin elowin; 
\q2 ifi qabatiisaaf qarummaa qabaadhu. 
\q1  
\v 5 Durummaan akka risaa koolaan ka'uu, 
\q2 haga lipheettii ilaatitti, 
\q2 nama duraa baduu hin dandeetti. 
\s1 Saddeetessoo 
\q1  
\v 6 Sagalee nama donnaa hin nyaatin; 
\q2 mi'aan isi'ii si hin joljolsin. 
\q1  
\v 7 Inni akka nama yennaa mara marroo gatii sagaleen sun baachu yaaduu ti; 
\q2 inni afaaniin, «Nyaadhu; uni» siin jedha; 
\q2 gadhaan isaa ammoo si woliin hin jiru. 
\q1  
\v 8 Diqqoo nyaatteeyyuu hin diddidda; 
\q2 dubbii galataa teetille hin balleessita. 
\s1 Sagaleessoo 
\q1  
\v 9 Inni dubbii qarumma'aa teetitti waan murguuf, 
\q2 gowwa'atti hin dubbatin. 
\s1 Kudhaneessoo 
\q1  
\v 10 Dhakaa meessa'aa ka durii adde'ee hin munyuussin 
\q2 yookiin fichaa ijoollee abbaa hin qannee 
\q2 meessaa hin dabarin. 
\q1  
\v 11 Waaqi isaan wodu jabaa waan te'eef, 
\q2 inni isaaniif hin falmata. 
\s1 Kudhanii Tokkeessoo 
\q1  
\v 12 Qalbii teeti gara gorsaa, 
\q2 gurra keetille gara beekkumsaa deebifadhu. 
\s1 Kudhanii Lammeessoo 
\q1  
\v 13 Ijoollee teeti adabiisa hin lakkisin; 
\q2 kuta'aan yoo dhaante isaan hin du'anu. 
\q1  
\v 14 Ati yoo kuta'aan isaan dhaante, 
\q2 lubbuu isaanii du'a irraa hin hamburta. 
\s1 Kudhanii Sadeessoo 
\q1  
\v 15 Ilma kiyya, ati qaroo yoo teete, 
\q2 gadhaan kiyya hin gammada. 
\q1  
\v 16 Yennaa afaan keeti waan sirrii te'e dubbatu, 
\q2 keessi kiyya guddoo gammada. 
\s1 Kudhanii Arfeessoo 
\q1  
\v 17 Yennaa mara Mootii Waan Maraa 
\q2 sodaatiisaaf hinaaf malee, 
\q2 cubbaaleyyi'itti hin hinaafin. 
\q1  
\v 18 Dhugumaan ati gara fuula duraa addii qadda; 
\q2 addiin teetille hin baddu. 
\s1 Kudhanii Shaneessoo 
\q1  
\v 19 Ilma kiyya, caqasi; 
\q2 qaroolle te'i; 
\q2 qalbii teetille daandii qajeelaa irratti eegadhu. 
\q1  
\v 20 Worra daadhii woyni'ii akka malee unuu fi 
\q2 worra foon akka malee nyaatu woliin hin jaalomin. 
\q1  
\v 21 Worri machowuu fi worri gadhitoon hin hiyyoommatan; 
\q2 hirriibi hamaan isaaniille woyaa ciccittuu isaanitti hin uffisa. 
\s1 Kudhanii Jayeessoo 
\q1  
\v 22 Abbaa keeti ka si uume dhage'i; 
\q2 haadha teetille yennaa isiin dulloonte hin tuffatin. 
\q1  
\v 23 Dhuga'aa fi qarummaa, 
\q2 gorsaa fi hubantii bitadhu malee hin gurgurin. 
\q1  
\v 24 Abbaan nama balcha'aa gammada guddaa qaba; 
\q2 ka ilma qaroo qabulle isatti hin gammada. 
\q1  
\v 25 Abbaan keetii fi haati teeti gammadanuu ti; 
\q2 haati si deette akka malee gammadduu ti. 
\s1 Kudhanii Torbeessoo 
\q1  
\v 26 Ilma kiyya, qalbii teeti naa kenni; 
\q2 ilti teetille karaa kiyya ilaaltuu ti. 
\q1  
\v 27 Dubartiin sagaagaltittiin akka boolla qile'ee ti; 
\q2 niitiin gaarayyeeffattuun akka balleessa dhipha'aa ti. 
\q1  
\v 28 Isaan akka worra nama saamuu riphanee si eegan; 
\q2 dhiira hedduu niitii ifiitiif akka hin addatanne godhan. 
\s1 Kudhanii Saddeetessoo 
\q1  
\v 29 Ka waacifu eennu? 
\q2 Ka gaddu eennu? 
\q2 Ka wol dhabu eennu? 
\q2 Ka nama komatu eennu? 
\q2 Ka sababa malee madowu eennu? 
\q2 Ka ila diimatu eennu? 
\q1  
\v 30 Worra daadhii woyni'ii irra turu, 
\q2 ka yennaa mara daadhii woyni'ii 
\q2 ta makaa qaddu barbaaduu motii ree? 
\q1  
\v 31 Daadhiin woyni'ii yennaa diimattu, 
\q2 shurrubbee keessaa yennaa calalaxxu, 
\q2 akka kasoo yennaa isii unanu 
\q2 si hin halchisiisin. 
\q1  
\v 32 Muummee irratti akka dhudhuufa'aa si idditi; 
\q2 akka buuti'iille hadhaa sitti naxxi. 
\q1  
\v 33 Ilti teeti waan haareya dhaggiti; 
\q2 qalbiin teetille hin cucurruuxxi. 
\q1  
\v 34 Akka nama abbaayaa irra rafuu, 
\q2 akka nama qaccee utubaa hobolo'oo irra irkatuu hin teeta. 
\q1  
\v 35 Ati, «Na dhowane; 
\q2 ani ammoo hin miidhanne; 
\q2 na dhaanane; 
\q2 ani ammoo hin dhukkuffanne; 
\q2 untoo dhibii barbaadatiisaaf, yoom dammaqa?» jetta. 
\c 24  
\s1 Kudhanii Sagaleessoo 
\q1  
\v 1 Namoota hamoolee hin hinaafin; 
\q2 jaalummaa isaanii hin halchin. 
\q1  
\v 2 Gadhaan isaanii hunnaan nama irratti ka'iisa yaada; 
\q2 afaan isaaniille marroo maltumma'aa dubbata. 
\s1 Diddameessoo 
\q1  
\v 3 Manni qarumma'aan ijaarama; 
\q2 hubantiille'een jabeeffama. 
\q1  
\v 4 Beekkumsaan kollooti mana sanii 
\q2 meya gatii guddo'ootii fi 
\q2 meya dadansa'aan guutaman. 
\s1 Diddamii Tokkeessoo 
\q1  
\v 5 Nami qaroon hunna jadduu qaba; 
\q2 nami beekkumsa qabulle jabeenna dabalata. 
\q1  
\v 6 Lolaaf bayiisaaf qajeelcha, 
\q2 injifatiisaafille gorsitoota hedduu barbaachisa. 
\s1 Diddamii Lammeessoo 
\q1  
\v 7 Nama gowwa'aaf qarummaan akka malee ol fagaatti; 
\q2 inni addee mari'ii keessatti 
\q2 afaan ifii hin saaqatu. 
\s1 Diddamii Sadeessoo 
\q1  
\v 8 Nami waan hantuu godhiisaaf mala dhowu, 
\q2 inni, «Malticha» jedhamee beekkama. 
\b  
\q1  
\v 9 Malli gowwa'aa cubbu'u; 
\q2 namooti nama murgu hin jibban. 
\s1 Diddamii Arfeessoo 
\q1  
\v 10 Ati bara rakko'oo keessa yoo raafante, 
\q2 jabeenni keeti attam attam diqqa'a! 
\s1 Diddamii Shaneessoo 
\q1  
\v 11 Worra gara du'aa geeffamanu baasi; 
\q2 worra gara qalamiisaa tintimanu deebisi. 
\q1  
\v 12 Ati, «Nuuti marroo waan kanaa hin beenne» yoo jette, 
\q2 ka gadhaa namaa qorqoru kana hin hubatuu ree? 
\q2 Ka jiruu teeti eegu hin beekuu ree? 
\q1 Inni nama tokko tokkoofuu 
\q2 akka hujii isaatitti gatii isaaf hin kaffaluu ree? 
\s1 Diddamii Jayeessoo 
\q1  
\v 13 Ilma kiyya, dammi dansaa waan te'eef, 
\q2 damma nyaadhu; 
\q2 nadhiin dhaaba dammaa keessaa sitti hin mi'ootti. 
\q1  
\v 14 Qarummaalle lubbuu teetiif 
\q2 akkuma san akka mi'oottu beeki; 
\q2 ati yoo isii dhaggatte, 
\q2 gara fuula duraa addii qadda; 
\q2 addiin teetille hin baddu. 
\s1 Diddamii Torbeessoo 
\q1  
\v 15 Akka nama hama'aa 
\q2 mana nama balcha'aa dhokattee hin gaadin. 
\q2 Mana isaa irralle'etti hunnaan hin ka'in. 
\q1  
\v 16 Nami balchaan yennaa torba jigulle deebi'ee hin ka'a; 
\q2 nami hamaan ammoo badii keessa bu'a. 
\s1 Diddamii Saddeetessoo 
\q1  
\v 17 Yennaa diinni keeti jigu hin gammadin; 
\q2 yennaa inni gufatulle gadhaan keeti hin firinxiixin. 
\q1  
\v 18 Itti gammadiisa keeti yoo dhagge, 
\q2 Mootiin Waan Maraa hin jaalatu; 
\q2 aarii ifii isa irraa hin deebisa. 
\s1 Diddamii Sagaleessoo 
\q1  
\v 19 Waan namooti hamaan hujanu hin qoxxisin; 
\q2 yookiin hamoolee hin hinaafin. 
\q1  
\v 20 Nami hamaan addii gara fuula duraa hin qabu; 
\q2 issaan nama hama'aalle hin dhaama. 
\s1 Soddomeessoo 
\q1  
\v 21 Ilma kiyya, Mootii Waan Maraatii fi mooticha sodaadhu; 
\q2 worra finqilaa woliin jaala hin te'in. 
\q1  
\v 22 Mootiin Waan Maraatii fi mootichi 
\q2 dedhuma badii worra finqilaa irratti hin fidan; 
\q2 badii isaan fidanu eentu beeka ree? 
\s1 Jecha Qaro'oo Ka Dhibii 
\q1  
\v 23 Isaan kunille jecha qaro'oo ti: 
\q2 Muraa keessatti nama wol caalchisuun dansa'aa moti. 
\q1  
\v 24 Nama hama'aan, «Ati yakkaa hin qaddu» nama jedhu, 
\q2 kolbaan hin abaarti; 
\q2 gosi biyya adda addaalle hin jibbiti. 
\q1  
\v 25 Worra nama hamaa xixuuf ammoo 
\q2 wonni dansaan hin teeti; 
\q2 eebbi dansaalle isaan irratti hin bu'a. 
\q1  
\v 26 Deebii dhuga'aa deebisuun, 
\q2 akka sunqaa hidhi'ii ti. 
\q1  
\v 27 Hujii alaa fixadhuu, 
\q2 fichaa keeti qopheeffadhu; 
\q2 achiin duuba mana keeti ijaaradhu. 
\q1  
\v 28 Sababa malee nama irratti dhugaa hin bayin 
\q2 yookiin hidhii teetiin nama hin sobin. 
\q1  
\v 29 Ati, «Waanuma nami na godhe, anille isa hin godha; 
\q2 gatuma hujii isaa isaaf hin deebisa» hin jedhin. 
\q1  
\v 30 Ani fichaa nama booseyaa keessa, 
\q2 oorruu woyni'ii ta nama qalbii hin qannee 
\q2 keessa dabaree deeme. 
\q1  
\v 31 Addee mara qoreen itti latteerti; 
\q2 shuqunaan lafa golliteerti; 
\q2 dalleenni dhaka'aalle irraa jigeera. 
\q1  
\v 32 Ani waan kana ilaalee itti yaadee, 
\q2 waan dhagge kana irraa barumsa dhaggadhe: 
\q1  
\v 33 Ati yennaa diqqoo isi'ii rafii, 
\q2 yennaa diqqoo isi'ii mugii, 
\q2 foorfatiisaaf yennaa diqqoo isi'ii 
\q2 harka wol irra naqadhu. 
\q1  
\v 34 Garuu hiyyuun akka saantu'uu, 
\q2 beelti akka nama meya lolaa hidhatee 
\q2 sitti hin dhufan. 
\c 25  
\s1 Jecha Qarummaa Solomoonii Ka Dhibii 
\q1  
\v 1 Isaan kunille fakkeenna Solomoonii ka dhibii, 
\q2 ka qondaaltoti Hisqiyaasii mootii 
\q2 Yihuda'aa barreeffama irraa garagalchane. 
\q1  
\v 2 Gofa woyii dhossuun ulfinna Waaqaa ti; 
\q2 gofa woyii qoratanee baasuun 
\q2 ulfinna moototaa ti. 
\q1  
\v 3 Akkuma ol-gubbaan ol fagaattu 
\q2 akkuma lattille gaddi fagaattu, 
\q2 yaadi moototaalle qorqoramuu hin dande'u. 
\q1  
\v 4 Ka meetii irraa meya huju meetii qulluu akka qabaatu, 
\q2 ati meetii san irraa xurii kaasi. 
\q1  
\v 5 Barcumaan mootumma'aa 
\q2 balchumma'aan akka dhaabbatu, 
\q2 nama hamaa addee mootiin jiruu kaasi. 
\q1  
\v 6 Mootii duratti ol ifi hin qabin; 
\q2 nama guddaa ifi hin fakkeessin. 
\q1  
\v 7 Mootichi nama guddaa duratti 
\q2 addee gad aantuu sii kenniisaa mannaa, 
\q2 addee ol aantuu sii kennu woyya. 
\q1  
\v 8 Waan tokko ilumaan dhaggite'eef 
\q2 ariifattee gara mura'aa hin dhikeessin; 
\q2 nami dhibiin dokonkora keeti yoo mirkaneesse, 
\q2 ati dhuma irratti maan teeta ree? 
\q1  
\v 9 Haajaa keetiif nama woliin yennaa falmattu, 
\q2 gofa nama dhibi'ii hin mudhisin. 
\q1  
\v 10 Yoo akkas hin te'in nami waan kana dhage'u si qaanessa; 
\q2 maqaan keeti ka bade sun ijjumaa si'iif hin deebi'u. 
\q1  
\v 11 Dubbiin yennaa isi'iititti dubbatantu, 
\q2 akka quumhaa worqi'ii ka qorii meeti'ii keessaa ti. 
\q1  
\v 12 Xixxaan nama qaro'oo nama isa dhage'uuf, 
\q2 akka worqii gurraa yookiin meya seesaa 
\q2 ka worqii qulluu irraa hujamee ti. 
\q1  
\v 13 Bisaan dhakaa roobaatiin qabbanowe, 
\q2 yennaa midhaan galcha'aa 
\q2 akkuma gadhaa namaa qabbaneessu, 
\q2 ergantooti addatamootille 
\q2 nama isaan ergatuuf akkasuma; 
\q2 isaan yaada goottolee ifii hin foorfachiisan. 
\q1  
\v 14 Nami kennansa namaaf hin kennineen ifi jaju, 
\q2 akka duumensaa fi qilleensa bokkeya hin qannee ti. 
\q1  
\v 15 Nami ossa qabu 
\q2 bulchaa biyyaa tokko gadhaa hin laaffifata; 
\q2 arrabi dansaan nama mataa jabaatu laaffisa. 
\q1  
\v 16 Damma yoo dhaggatte, 
\q2 haga si'iif barbaachisu qofa nyaadhu; 
\q2 akka malee nyaattu si diddissa. 
\q1  
\v 17 Si bagee waan si jibbuuf, 
\q2 miilli keeti mana ollaa keetiititti hin daandin. 
\q1  
\v 18 Nami dharaan dhugaa nama irratti bayu, 
\q2 akka ulee jirmaa yookiin 
\q2 akka shallaaga'aa yookiin 
\q2 akka daaya qara qabuu ti. 
\q1  
\v 19 Rakkinna keessa nama hin addatannetti addatiis, 
\q2 akka nama ilkaan tacho'etti 
\q2 yookiin miila laashowetti addatuu ti. 
\q1  
\v 20 Nama gaddeef faaruu faarsuun, 
\q2 akka nama guyyaa boojji'ii 
\q2 woyaa isaa isa irraa fuudhanee ti 
\q2 yookiin akka soodda mada'atti naqanee ti. 
\q1  
\v 21 Diinni keeti yoo beelote sagalee nyaatu kenniif; 
\q2 yoo dheebotelle bisaan unu kenniif. 
\q1  
\v 22 Tana godhiisaan gaabbee akka inni qaanowu hin goota; 
\q2 Mootiin Waan Maraalle gatii si'iif hin kaffala. 
\q1  
\v 23 Akkuma qilleensi kaabaa bokkeya fidu, 
\q2 arrabi hamatu ila aari'iin nama ilaaltu hin fida. 
\q1  
\v 24 Niitii dubbatittii woliin le'iisaa mannaa, 
\q2 roga heellichoo manaa irra le'uu woyya. 
\q1  
\v 25 Oduun dansaan biyya fago'oo, 
\q2 akkuma bisaan qabbanowaa 
\q2 lubbuu dheebotte dheebuu baasuu ti. 
\q1  
\v 26 Nami balchaan nama hama'aaf karaa kennu, 
\q2 akka madda boorayee, 
\q2 yookiin akka bisaan boollaa 
\q2 ka xurayee ti. 
\q1  
\v 27 Damma akka malee nyaatiis dansa'aa moti 
\q2 yookiin ulfinna mataa ifii barbaadatiisi ulfinnaa moti. 
\q1  
\v 28 Nami ifi qabatiisa hin dandeenne, 
\q2 akka qachaa guddicha dalleenni dhaka'aa irraa jigee ti. 
\c 26  
\q1  
\v 1 Dhakaan roobaa bona keessa, 
\q2 bokkeenni yennaa midhaan galfatanuuf akkuma hin teene, 
\q2 ulfinnille gowwa'aaf hin te'u. 
\q1  
\v 2 Abaarsi akkasumaan nama abaaranu, 
\q2 akkuma sinbirroota koolaan asii fi achi kaatuu ti malee, 
\q2 nama tokkolle hin miidhu. 
\q1  
\v 3 Licheen fardaaf, 
\q2 bixaalli gaange'eef akkuma barbaachisu, 
\q2 uleen dudda gowwa'aatiif hin barbaachitti. 
\q1  
\v 4 Atinuu akka isaa akka hin teene, 
\q2 gowwa'aaf akka gowwummaa isaatitti 
\q2 deebii gowwittii hin deebisin. 
\q1  
\v 5 Nami gowwaan qaroo akka ifi hin seene, 
\q2 akkuma gowwummaa isaatitti deebii isaaf kenni. 
\q1  
\v 6 Nami nama gowwaa ergatu, 
\q2 akka nama miila ifi irraa muree rakkinna ifitti fiduu ti. 
\q1  
\v 7 Fakkeenni afaan gowwa'aa keessaa bawu, 
\q2 akka miila naafatee rarra'uu ti. 
\q1  
\v 8 Nama gowwa'aaf ulfinna kenniis, 
\q2 akka nama looyya'atti dhakaa hidhuu ti. 
\q1  
\v 9 Fakkeenni afaan gowwa'aa keessaa bawu, 
\q2 akka qoree harka nama machowa'aa keessa jirtuu ti. 
\q1  
\v 10 Nami nama gowwaa yookiin nama karaa deemu qaxaru, 
\q2 akka nama daaya akkuma dhagge 
\q2 darbatee nama dhagge madeessuu ti. 
\q1  
\v 11 Sareen diddiga ifiititti akkuma deebitu, 
\q2 gowwaalle gowwummaa ifiititti hin deddeebi'a. 
\q1  
\v 12 Nama qaroo ifi sewu dhaggiteertaa? 
\q2 Isa caalaa gowwa'atti addii qaba. 
\q1  
\v 13 Nami booseyi, «Neenqi karaa keessa jira! 
\q1 Neenqi karaa guddaa keessa jira» jedha. 
\q1  
\v 14 Miilli saanqa'aa iloo keessa akkuma garagaggalu, 
\q2 nami booseyille taqee ifii irra garagaggala. 
\q1  
\v 15 Nami booseyi harka ifii qorii keessa hin keya; 
\q2 garuu gara afaan ifii deebifatiisa guddoo dadhaba. 
\q1  
\v 16 Nami booseyi, 
\q2 namoota torba ka hubanti'iin deebii deebisanu caalaa 
\q2 qaroo ifi seya. 
\q1  
\v 17 Nami akkasumaan dubbii namaa keessa galu, 
\q2 akka nama saree karaa ideentu gurra qabuu ti. 
\q1  
\v 18 Akkuma maraataan umeessaa ibiddaatii fi 
\q2 daaya nama ijjeesu namatti gad lakkisu, 
\q2  
\v 19 nami nama gowwoonsee, 
\q2 «Ani hin taphadhe» jedhulle akkasuma. 
\q1  
\v 20 Qoraan yoo hin jiraatin ibiddi hin dhaama; 
\q2 hamiin yoo hin jiraatin lolli hin hafa. 
\q1  
\v 21 Cileen kashila, 
\q2 muki ibidda akkuma gabbisu, 
\q2 nami dubbii tuttuqu lola kaasa. 
\q1  
\v 22 Jechi hami'ii akka tuuqata mi'owuu ti; 
\q2 gara keessa namaa gad seena. 
\q1  
\v 23 Nami afaan ifiitiin dansaa fakkaatee, 
\q2 gadhaa ifii keessaa yaada hamaa qabu, 
\q2 akka meya faaraa ka meetii itti gonfanee ti. 
\q1  
\v 24 Nami kijibu afaaniin nama sossoba; 
\q2 gadhaa ifiitiin hantuu yaadata. 
\q1  
\v 25 Yaadi hamaan torba 
\q2 waan gadhaa isaa keessa guuteeruuf, 
\q2 yennaa inni afaan laafee dubbatu, 
\q2 isa hin dhugeeffatin. 
\q1  
\v 26 Kijibummaa ifii maltumma'aan dhoffatulle, 
\q2 hammeenni isaa ammoo gumii 
\q2 keessatti diidatti hin baya. 
\q1  
\v 27 Nami boolla namaaf qotu, 
\q2 ifumaafuu keessa hin bu'a. 
\q1 Nami dhakaa namatti konkolaachisulle, 
\q2 dhakaan sun deebi'ee isuma irra hin konkolaata. 
\q1  
\v 28 Arrabi dharaamessi worruma ifiifuu miidhe jibba; 
\q2 afaan sobaan kookkisulle badii namatti fida. 
\c 27  
\q1  
\v 1 Waan Guyyaan fidu waan hin beenneef, 
\q2 waan boru te'uun ifi hin jajin. 
\q1  
\v 2 Nami si jajuu ti malee, ati ifi hin jajin; 
\q2 nami dhibiin si jajuu ti malee, afaan keetiin ifi hin jajin. 
\q1  
\v 3 Dhakaan hin ulfaata; 
\q2 maansille ba'a'a. 
\q1 Nunnussaan gowwaan tuttuqee nama aarsu ammoo, 
\q2 isaan lachuu caalaa hin ulfaatti. 
\q1  
\v 4 Mufiin gadhi-jabeenna; 
\q2 aariin lola'a; 
\q2 hinaaffaa dura ammoo 
\q2 eentu dhaabbatuu dande'a? 
\q1  
\v 5 Jaalala dhokate caalaa, 
\q2 xixicha mudhatu woyya. 
\q1  
\v 6 Sunqaa diinaatii mannaa, 
\q2 jaalli si madeessu woyya. 
\q1  
\v 7 Nama quufe, 
\q2 dammi itti bushowa; 
\q2 nama beelote ammoo 
\q2 wonni hadhowuuyyuu itti mi'owa. 
\q1  
\v 8 Nami qe'ee ifii keessaa baye, 
\q2 akka sinbirree mana ifii keessaa baatee ti. 
\q1  
\v 9 Fiqire'ee fi qayyi nama gammachiisan; 
\q2 gammachiisiis jaalaalle 
\q2 gorsa dansaa isaa irraa madda. 
\q1  
\v 10 Jaalota teetii fi jaalota abbaa keetii hin lakkisin; 
\q2 yennaa rakkinnaa mana obboleessa keetii hin dhaqin; 
\q2 obboleessa fagoo jiruu mannaa, 
\q2 ollaa dhikoo jiru woyya. 
\q1  
\v 11 Ilma kiyya, 
\q2 nama na arrassuuf deebii kennuu akka ani dande'u, 
\q2 ati qaroo te'i; 
\q2 gadhaa kiyyalle gammachiisi. 
\q1  
\v 12 Nami qalbeeffataan waan hantuu dhaggee duraa baqata; 
\q2 nami hubantii hin qanne ammoo ittuma ideemee, 
\q2 rakkoo keessa seena. 
\q1  
\v 13 Nama alaga'aaf wobii te'e woyaa irraa mulqadhu; 
\q2 haga inni waan alagaan fudhate san deebisutti 
\q2 woyaa san qabadhu. 
\q1  
\v 14 Nami barii ganamaan ka'ee, 
\q2 qoonqoo ol qabatee nama yoo eebbise, 
\q2 eebbi sun abaarsa nama sanitti fakkaata. 
\q1  
\v 15 Niitiin dubbattittiin akka mana 
\q2 guyyaa roobaa dhim'isaa ooluu ti. 
\q1  
\v 16 Isii ittisiis qilleensa ittisiisa, 
\q2 yookiin zayitii harkaan qabiisa. 
\q1  
\v 17 Akkuma sibiilli sibiila cabbu, 
\q2 namille nama cabba. 
\q1  
\v 18 Nami muka harru'uu kunuunsu 
\q2 midhaan isi'ii hin nyaata; 
\q2 nami goottaa ifii eegulle 
\q2 ulfinna hin dhaggata. 
\q1  
\v 19 Akkuma bisaan fuula namaa mudhisu, 
\q2 yaadi namaalle eennummaa namaa mudhisa. 
\q1  
\v 20 Addeen worri du'e jiruu fi 
\q2 addeen badi'ii ijjumaa hin quuttu; 
\q2 ilti namaalle ijjumaa hin quuttu. 
\q1  
\v 21 Meeti'ii fi worqiin addee itti baqisiisanu keessatti 
\q2 akkuma haga ilaallatamanu, 
\q2 namille leellifamiisaan haga ilaalama. 
\q1  
\v 22 Gowwaa akka midhaanii 
\q2 mooyye'etti tuma'aan yoo tuntelle, 
\q2 gowwummaa isa keessaa baasuu hin dandeettu. 
\q1  
\v 23 Hoolee teeti haala attamii keessaa akka jirtu 
\q2 midhassii beeki; 
\q2 loon keetille midhassii tiffadhu. 
\q1  
\v 24 Sababille durummaan haga bara baraa hin jiraatu; 
\q2 kallachille dhalootaa dhalootatti hin dabaru. 
\q1  
\v 25 Marri gogaan haamamee, 
\q2 marri haarenni yennaa latu, 
\q2 marri koobota irraa yennaa wolitti qabamu, 
\q2  
\v 26 buruusoo hoolota teetiitiin daara hin baata; 
\q2 re'oota teetille'een fichaa hin bitatta. 
\q1  
\v 27 Soorata keetiif, soorata maatii teetiitiif, 
\q2 soorata tajaajiltoota teetiifille ka gewu, 
\q2 aanan re'e'ee hin qabaatta. 
\c 28  
\q1  
\v 1 Nami hamaan adoo nami hin ari'in baqata; 
\q2 nami balchaan ammoo akka neenqaa ifi addata. 
\q1  
\v 2 Kolbaan yennaa finqila kaatu, 
\q2 bulchitooti isi'ii hin heddatti; 
\q2 nama hubata'aa fi beekaa yoo qabaatte ammoo 
\q2 mootummaan isi'ii jabaattee hin dhaabbatti. 
\q1  
\v 3 Bulchaan hiyyeessa cunqursu 
\q2 akka bokkeya midhaan balleessuu ti. 
\q1  
\v 4 Worri seera lakkisu nama hamaa leellisa; 
\q2 worri seera eegatanu ammoo isaaniin morma. 
\q1  
\v 5 Nami hamaan haqa hin beeku; 
\q2 worri Mootii Waan Maraa barbaadatu ammoo 
\q2 guutumaa guutu'utti haqa beekan. 
\q1  
\v 6 Dureessa ideensi isaa micciirama'aatii mannaa, 
\q2 hiyyeessa komii hin qanne woyya. 
\q1  
\v 7 Ka seera eegu ilma qalbeeffata'a; 
\q2 ka gadhitoo woliin jaalomu ammoo 
\q2 abbaa ifii salphisa. 
\q1  
\v 8 Nami liqaa dhala gudda'aatiin qabeenna ede'atu, 
\q2 nama hiyyeessaa nawuuf hin kuusa. 
\q1  
\v 9 Nama seeraaf hin ajajanne, 
\q2 daadimati isaatuu akka malee hin jibbisiisa. 
\q1  
\v 10 Nami nama qajeelaa karaa hama'atti geessu, 
\q2 boolla ifumaa qote keessa hin bu'a; 
\q2 nami komii hin qanne ammoo 
\q2 waan dansaa hin dhaala. 
\q1  
\v 11 Nami dureessi qaroo ifi seya; 
\q2 hiyyeessi hubantii qabu ammoo 
\q2 qorqoree keessa isaa hin beeka. 
\q1  
\v 12 Nami balchaan yennaa injifatu, 
\q2 martinuu hin gammadan; 
\q2 nami hamaan yennaa baallii qabatu ammoo 
\q2 namooti hin dhokatan. 
\q1  
\v 13 Nami cubbuu ifii dhoffatu, 
\q2 hin milkowu; 
\q2 nami cubbuu ifii faaci'atuu fi ka isii lakkisu ammoo 
\q2 marartii hin dhaggata. 
\q1  
\v 14 Nami yennaa mara Mootii Waan Maraa sodaatu 
\q2 ka gammade; 
\q2 nami mataa jabaatu ammoo rakkinna keessa gala. 
\q1  
\v 15 Bulchaan hamaan worra qarqaarsa hin qanne irratti 
\q2 akka neenqa dhangaa dhowuu 
\q2 yookiin akka doobbaa hiixatee woy qabuu ti. 
\q1  
\v 16 Bulchaan hubantii hin qanne 
\q2 akka malee nama cunqursa. 
\q1 Ka bu'aa haqa hin te'in jibbu ammoo 
\q2 bara dheeraa hin le'a. 
\q1  
\v 17 Nami nama ijjeese, 
\q2 haga du'utti baqataa hin le'a; 
\q2 nami tokkolle isa hin qarqaarin. 
\q1  
\v 18 Nami komii hin qanne waan hantuu irra hin bu'u; 
\q2 nami micciiramaan ammoo dedhuma jiga. 
\q1  
\v 19 Nami lafa qotatu sagalee bacaa hin qabaata; 
\q2 nami waan bu'aa hin qanne hordofu ammoo hin deega. 
\q1  
\v 20 Nami addatamaan guddoo hin eebbifama; 
\q2 nami durumma'aaf ariifatu ammoo 
\q2 adoo hin adabamin hin hafu. 
\q1  
\v 21 Nama wol caalchisuun dansa'aa moti; 
\q2 garuu nami bixee daabbo'oo takkatti'iif jedhee 
\q2 dokonkora huja. 
\q1  
\v 22 Nami donni duroomiisaaf ariifata; 
\q2 hiyyuun akka isa eegattu hin beeku. 
\q1  
\v 23 Nama afaaniin nama kookkisu caalaa, 
\q2 ka balleessaa namatti himee nama xixutti 
\q2 dhuma irratti saadama. 
\q1  
\v 24 Nami abbaa ifii yookiin haadha ifii saamee, 
\q2 «Kun dokonkoraa moti» jedhu, 
\q2 inni jaala nama woy balleessuu ti. 
\q1  
\v 25 Nami joljolaan lola kakkaasa; 
\q2 nami Mootii Waan Maraatitti addatu ammoo 
\q2 hin milkowa. 
\q1  
\v 26 Nami ifitti addatu gowwa'a; 
\q2 nami qarumma'aan deddeebi'u 
\q2 ammoo waan hantuu irra hin bu'u. 
\q1  
\v 27 Nami hiyyeessaaf kennu womaa hin dhabu; 
\q2 nami hiyyeessa ilaalee lakkisu ammoo 
\q2 abaarsa hedduu fudhata. 
\q1  
\v 28 Yennaa namooti hamooleen baallii fudhatanu, 
\q2 kolbaan hin dhokatti; 
\q2 yennaa isaan badanu ammoo 
\q2 balchooti hin bacatti. 
\c 29  
\q1  
\v 1 Nami yennaa hedduu xixameen duuba didee mataa jabaatu, 
\q2 cannana fayyuu hin dandeenne dedhuma caba. 
\q1  
\v 2 Balchooti yennaa baallii fudhatanu, 
\q2 kolbaan guddoo gammadi; 
\q2 yennaa nami hamaan bulchu 
\q2 ammoo kolbaan hin aaddi. 
\q1  
\v 3 Nami qarummaa jaalatu, 
\q2 abbaa ifii gammachiisa; 
\q2 nami jaala sagaagaltu'uu te'u ammoo 
\q2 qabeenna ifii bittinneessa. 
\q1  
\v 4 Mootiin haqa muriisaan biyya ifii hin jabeessa; 
\q2 ka safuu fudhatiisaaf joljolu ammoo 
\q2 biyya ifii hin balleessa. 
\q1  
\v 5 Nami afaan calla'aan nama kookkisu, 
\q2 fonxoroo miila ifiititti afa. 
\q1  
\v 6 Nami hamaan cubbuu ifiitiin qabama; 
\q2 nami balchaan ammoo hin faarfata; 
\q2 hin gammadalle'e. 
\q1  
\v 7 Nami balchaan marroo haqa hiyyeessaatiif hin haajama; 
\q2 Nami hamaan ammoo haajaa hin qabu. 
\q1  
\v 8 Namooti namatti murganu qachaa jeeqan; 
\q2 namooti qaroon ammoo aarii qabbaneessan. 
\q1  
\v 9 Nami qaroon nama gowwaa woliin gara seeraa yoo dhaqe, 
\q2 gowwaan sun hin mufata 
\q2 yookiin hin murga; 
\q2 nageennille hin jiraatu. 
\q1  
\v 10 Namooti dhiiga namaa dhangalaasanu, 
\q2 nama dhugaammessa jibban; 
\q2 nama qajeelaa ijjeesuu barbaadan. 
\q1  
\v 11 Nami gowwaan yaada aarii ifii mara dubbata; 
\q2 nami qaroon ammoo ossaan ifi qabataa dubbata. 
\q1  
\v 12 Bulchaan tokko oduu dharaa yoo caqase, 
\q2 qondaaltoti isaa martinuu hamoolee hin te'an. 
\q1  
\v 13 Mootiin Waan Maraa isaan lamaaniifuu ila waan kenneef, 
\q2 hiyyeessii fi ka hiyyeessa cunqursulle tanaan woluma qixxe'e. 
\q1  
\v 14 Mootiin hiyyeessaaf haqaan yoo mure, 
\q2 barcumaan mootummaa isaa 
\q2 bara dheeraa jabaatee hin dhaabbata. 
\q1  
\v 15 Ijoollee xixanee adabuun qarummaa kennitiif; 
\q2 ijoolleen gad lakkifante ammoo haadha ifii qaanessiti. 
\q1  
\v 16 Yennaa worri hamooleen baallii fudhatanu 
\q2 cubbuun hin bacatti; 
\q2 balchooti ammoo jinnana isaanii hin dhaggan. 
\q1  
\v 17 Ijoollee teeti adabi; 
\q2 isaan foora si'iif hin kennan; 
\q2 gadhaa keetille hin gammachiisan. 
\q1  
\v 18 Addee mudhiin hin jirre, 
\q2 kolbaan seera malee teeti; 
\q2 nami seera eegatu ammoo ka gammade. 
\q1  
\v 19 Tajaajilaan afaan calla'aan hin adabatu; 
\q2 inni yoo hubateeyyuu deebii hin kennu. 
\q1  
\v 20 Nama dubbii ariifatu dhaggitaa? 
\q2 Isa caalaa nama gowwa'atti addii qaba. 
\q1  
\v 21 Nami tajaajilaa ifii ijoollummaa isaatii jalqabee qananiisu, 
\q2 dhuma irratti gadda ifitti fida. 
\q1  
\v 22 Nami aarameessi lola kaasa; 
\q2 nami dafee mufatu cubbuu hedduu huja. 
\q1  
\v 23 Nami ol ifi qabu salphinna ifitti fida; 
\q2 nami gad ifi qabu ammoo ulfinna dhaggata. 
\q1  
\v 24 Nami jaala hattu'uu te'u ifi jibba; 
\q2 kakatee dhugaa akka bayuuf hin gaafatama; 
\q2 dhugaa bayiisaaf ammoo inni itti hin gamu. 
\q1  
\v 25 Nama sodaatiis tiyyoo keessa nama seensisa; 
\q2 nami Mootii Waan Maraatitti addatu ammoo nageyaan le'a. 
\q1  
\v 26 Namooti hedduun bulchaa duratti 
\q2 fudhatama dhaggatiisa barbaadan. 
\q1 Nami ammoo muraa haqaa 
\q2 Mootii Waan Maraa biraa dhaggata. 
\q1  
\v 27 Nami balchaan nama hamaa jibba; 
\q2 nami hamaalle nama qajeelaa jibba. 
\c 30  
\s1 Jecha Aguurii Ilma Yaaqee 
\q1  
\v 1 Jechi kun jecha Aguurii ilma Yaaqee ti; 
\q2 nami kun Itii'elitti, 
\q2 Itii'elii fi Ukaalitti dubbate, 
\q2  
\v 2 «Ani nama mara caalaa daafana'a; 
\q2 hubantii nami qabu ani hin qabu; 
\q2  
\v 3 ani qarummaa tokkolle hin baranne; 
\q2 ani marroo Waaqa Woyyichaalle womaa hin beeku. 
\q1  
\v 4 Ka gara ol-gubba'aa ol dhaqee gad deebi'ee dhufe eennu? 
\q2 Ka qilleensa harka ifiitiin wolitti qabe eennu? 
\q1 Ka bisaan woyaa ifiitiin mare eennu? 
\q2 Ka qaccee lafaa mara jabeessee dhaabe eennu? 
\q1 Maqaan isaa eennu? Maqaan ilma isaa eennu? 
\q2 Ati yoo beettu teete, 
\q2 natti himi! 
\b  
\q1  
\v 5 «Jechi Waaqaa marti dhuga'a; 
\q2 inni worra gara isaa baqate maraaf wonte'e. 
\q1  
\v 6 Jecha isaa irratti hin ede'in; 
\q2 yoo akkas hin te'in inni si xixa; 
\q2 dharaamessalle teetee hin dhagganta» jedhe. 
\b  
\q1  
\v 7 «Ee Mootii Waan Maraa, 
\q2 ani waan lama si kadhadha; 
\q2 adoo ani hin du'in 
\q2 waan kana lamaan na hin dhooggatin. 
\q1  
\v 8 Sobaa fi dhara dubbatiisa na irraa fageessi; 
\q2 sagalee guyyuma guyya'aan naa barbaachittu naaf kenni malee, 
\q2 durumma'aa fi hiyyummaalle naa hin kennin. 
\q1  
\v 9 Yoo akkas hin te'in, 
\q2 ani quufee si hin mormadha; 
\q1 ‹Mootiin Waan Maraa eennu inni?› si'iin hin jedha; 
\q2 yookiin hiyyoommadhee, 
\q2 hatee maqaa Waaqa kiyyaa, maqaa keeti hin salphisa. 
\b  
\q1  
\v 10 «Tajaajilaan akka si hin abaarre, 
\q2 atille akka hin rakkanne, 
\q2 marroo tajaajilaa tokkoo 
\q2 goottaa isaatitti isa hin hamatin. 
\q1  
\v 11 Namooti abbaa ifii abaaranu, 
\q2 haadha ifiille ka hin saadanne jiran. 
\q1  
\v 12 Worri qulluu ifi seyanee, 
\q2 ka battummaa ifii 
\q2 irraa hin qulqulloomin hin jiran. 
\q1  
\v 13 Worri ilaalcha kooraa qabanu, 
\q2 ka ila tuffi'iitiin nama ilaalanu, 
\q2  
\v 14 hiyyeessa lafa irraa, 
\q2 rakkataa odduu ilmaan namaatii 
\q2 nyaatanee balleessiisaaf, 
\q2 worri ilkaan isaanii shallaagaa, 
\q2 a'oon isaaniille billowa te'e jiran. 
\b  
\q1  
\v 15 «Ulaa'ulti ijoollee durraa 
\q2 ta, ‹Kenni! Kenni!› 
\q2 jedhaa iyyitu lama qaddi; 
\q1 ‹Ijjumaa quufe› ka hin jenne 
\q2 waan saditti jira; 
\q2 ta arfeesso'oolle ijjumaa ‹Na geye› 
\q2 hin jettu: 
\q2  
\v 16 isaanille, addee worri du'e jiru, 
\q2 gadaamessa maseena, 
\q2 lafa bisaan hin quunnee fi 
\q2 ibidda ijjumaa, ‹Na geye› hin jenne. 
\b  
\q1  
\v 17 «Nama abbaa ifiititti murguu fi 
\q2 ajaja haadha ifiille tuffatu, 
\q2 harraaqessi gammoojji'ii ila isaa 
\q2 isa keessaa hin fuudha; 
\q2 rumichille isa hin nyaata. 
\b  
\q1  
\v 18 «Wonni na baaseffachiisu sad yookiin 
\q2 afur ta hubatiisa hin dandeennetti jiraayyu; 
\q2  
\v 19 isaanille, karaa risa'aa ka gubbaa irraa, 
\q2 karaa bofaa ka rassaa irraa, 
\q2 karaa hobolo'oo ka abbaayaa irraatii fi 
\q2 karaa dhiirtii fi dubartiin wol jaalatanu. 
\b  
\q1  
\v 20 «Karaan dubartii gaarayyeeffattu'uu kana: 
\q2 Isiin nyaattee afaan ifii haxowattee, 
\q2 ‹Ani womaa dokonkora hin hunye› jetti. 
\b  
\q1  
\v 21 «Latti waan sadiiniin yookiin afuriin tachooti; 
\q2 dandeetteelle hin ba'attu; 
\q2  
\v 22 isaanille, garbichi yennaa mootii te'e, 
\q2 gowwaan yennaa quufe, 
\q2  
\v 23 dubartiin jibbatante yennaa dhirsa dhaggattee fi 
\q2 garbittiin yennaa addee giittii ifii fudhate. 
\b  
\q1  
\v 24 «Wonni didiqqoon afur, 
\q2 ka guddoo qaroo te'an biyya lafaa irra jiran: 
\q2  
\v 25 mixaan hunna hin qabu, 
\q2 te'uu malee sagalee ifii bona wolitti qabata; 
\q1  
\v 26 Osoleen hunnaa hin qaddu, 
\q2 te'uu malee odduu rassa'aatitti galti; 
\q1  
\v 27 Awwaannisi mootii hin qabu, 
\q2 te'uu malee akka loltootaa seeraan ideema. 
\q1  
\v 28 Qarcoon\f + \fr 30:28 \fqa Qarcoon: \ft Lafa tokko tokkotti lootuu jedhanti.\f* harkaan qabamuu dandeetti; 
\q2 te'uu malee mana mootumma'aa keessatti dhagganti. 
\b  
\q1  
\v 29 «Wonni ideensa tolanu sad yookiin afur 
\q2 ka arnya ulfinnaa qabanu jiran: 
\q1  
\v 30 Neenqa bineensota mara keessaa jaba'aa, 
\q2 ka waan mara irraa duubatti hin deebine; 
\q2  
\v 31 kormi lukku'uutii fi 
\q2 korbeessi re'e'ee ka bondhooranu, 
\q2 mootii loltoota ifiitiin marfamee ideemu. 
\b  
\q1  
\v 32 «Gowwaa teetee, yoo ol ol ifi qadde, 
\q2 yookiin hantuu yoo yaadatte, 
\q2 afaan keeti qabadhu. 
\q1  
\v 33 Akkuma aanan raasiis dhadhaa baasu, 
\q2 akkuma funnaan micciiriis dhiiga baasu, 
\q2 tuttuqanee nama aarsuun lola kaasa» jedhe. 
\c 31  
\s1 Gorsa Mootichaaf Kenname 
\p  
\v 1 Jechi asii gadii kun ka haati Lemu'elii mootichaa isa barsiitte: 
\q1  
\v 2 «Ee ilma kiyya, 
\q2 ilma gadaamessa kiyyaa, 
\q2 ilma Waadaa kiyyaa, 
\q2  
\v 3 hunna teeti dubartoota irratti hin fixin; 
\q2 yennaa teetille dubartoota mootota balleessitu irratti hin fixin. 
\b  
\q1  
\v 4 «Ee Lemu'el, moototi daadhii woyni'ii unuu hin qabanu; 
\q2 bulchitootille untoo nama macheessitu unuu hin qabanu. 
\q1  
\v 5 Isaan yoo unane, 
\q2 seera hin dedhan; 
\q2 worra cunqurfame mara haqa hin dhooggan. 
\q1  
\v 6 Untoo nama macheessitu, 
\q2 nama badiisatti jiruuf, 
\q2 daadhii woyni'iille nama farra hantuu keessa jiruuf kenni. 
\q1  
\v 7 Isaan unanee hiyyummaa ifii dedhanuu ti; 
\q2 farra ifiille deebi'anee hin qaabatin. 
\b  
\q1  
\v 8 «Ati worra ifiif dubbatuu hin dandeenneef dubbadhu; 
\q2 worra qarqaarsa hin qanne maraaf falmadhu. 
\q1  
\v 9 Dubbadhu; 
\q2 dhugaa muri. 
\q1 Haqa hiyyeessaatii fi 
\q2 rakkata'aatiif falmadhu» jette. 
\s1 Niitii Amala Dansaa qaddu 
\q1  
\v 10 Niitii qalbii qaddu eentu dhaggatuu dande'a? 
\q2 Isiin dooqa diimaa caalti. 
\q1  
\v 11 Dhirsi isi'ii gadhaa tokkochaan isii addata; 
\q2 Inni waan tokkolle hin dhabu. 
\q1  
\v 12 Bara jiruu isi'ii mara waan dansaa isaaf gooti malee, 
\q2 waan hantuu isa irratti hin hujju. 
\q1  
\v 13 Isiin rifeensa hoole'eetii fi quncee talba'aa barbaaddee, 
\q2 harka ifiitiin woyaa dhootti. 
\q1  
\v 14 Isiin akkuma hoboloota gugurdoo daldaltootaa, 
\q2 biyya fago'oo irraa sagalee fiddi. 
\q1  
\v 15 Isiin ganama adoo latti hin bari'in kaatee, 
\q2 maatii ifiitiif sagalee kenniti; 
\q2 durra tajaajiltoota ifiitiifille 
\q2 hujii isaanii itti qooddi. 
\q1  
\v 16 Isiin fichaa qorqortee bitatti; 
\q2 bu'aa hujii harka ifiitiin 
\q2 muka woyni'ii dhaabbatti. 
\q1  
\v 17 Isiin hunnaan hujii ifii hujatti; 
\q2 irreen isi'iille huji'iif jaddu'u. 
\q1  
\v 18 Hujiin isi'ii bu'aa akka qaddu hin beetti; 
\q2 issaan isi'iille halkan hin dhaamu. 
\q1  
\v 19 Harka ifiitiin fuuttaa qabatti. 
\q2 Quba ifiitiin liqaaqaa irbiti. 
\q1  
\v 20 Isiin hiyyeessaaf hin kenniti; 
\q2 rakkataalle hin qarqaarti. 
\q1  
\v 21 Maatiin isi'ii martinuu 
\q2 woyaa qorra nama irraa dhooggitu waan qabanuuf, 
\q2 yennaa rooba dhaka'aa isaaniif hin yaaddottu. 
\q1  
\v 22 Isiin woyaa taqee ifii irra afattu dhowatti; 
\q2 isiin woyaa dansaa quncee talba'aa irraa hujantee fi 
\q2 woyaa dhiillee uffatti. 
\q1  
\v 23 Dhirsi isi'ii jaarsolee biyyaa odduu, 
\q2 badhinna karra qacha'aa yennaa tee'u ulfinna qaba. 
\q1  
\v 24 Isiin quncee talba'aa irraa woyaa dhoottee gurgurti; 
\q2 daldaltootaafille hiituu gurgurti. 
\q1  
\v 25 Isiin hunnaa fi ulfinna akka woya'aa uffatti; 
\q2 bara dhufaaru itti gammaddi. 
\q1  
\v 26 Isiin qarumma'aan dubbatti; 
\q2 afaan isi'ii keessa barsiisa dansa'atti jira. 
\q1  
\v 27 Isiin jireenna maatii ifii akka dansaa eeddi; 
\q2 isiin booseyaa moti. 
\q1  
\v 28 Ijoolleen isi'ii lafaa kaatee, 
\q2 «Gammadee» jettee isii waanti; 
\q2 abbaan manaa isi'iille akkasuma jedhaa, isii leellisaa, 
\q1  
\v 29 «Dubartooti hedduun waan dansaa hujaneeran; 
\q2 ati ammoo isaan mara hin caalta» jedhaan. 
\q1  
\v 30 Miidhagiis nama soba; 
\q2 dansummaan hin baddi; 
\q2 dubartiin Mootii Waan Maraa sodaattu ammoo hin leellifanti. 
\q1  
\v 31 Bu'aa hujii isi'iitiif badhaasa kenna'aaf! 
\q2 Hujiin isi'ii badhinna karra 
\q2 qacha'aatitti isii leellittuu ti.