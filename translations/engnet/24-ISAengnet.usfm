\v 8  \w I|strong="H2005"\w* \w heard|strong="H8085"\w* \w the|strong="H8085"\w* \w voice|strong="H6963"\w* \w of|strong="H6963"\w* \w the|strong="H8085"\w* sovereign master \w say|strong="H6963"\w*, “\w Whom|strong="H4310"\w* \w will|strong="H4310"\w* \w I|strong="H2005"\w* \w send|strong="H7971"\w*? \w Who|strong="H4310"\w* \w will|strong="H4310"\w* \w go|strong="H3212"\w* \w on|strong="H7971"\w* \w our|strong="H8085"\w* behalf?” \w I|strong="H2005"\w* \w answered|strong="H8085"\w*, “\w Here|strong="H2005"\w* \w I|strong="H2005"\w* \w am|strong="H2005"\w*, \w send|strong="H7971"\w* \w me|strong="H7971"\w*!”  
