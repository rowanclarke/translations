\id LUK Sanskrit Bible (NT) in ITRANS Script (satyavedaH ।) 
\h Luke 
\toc1 lUkalikhitaH susaMvAdaH 
\toc2 lUkaH 
\toc3 lUkaH 
\mt1 lUkalikhitaH susaMvAdaH 
\c 1  
\p  
\v 1 prathamato ye sAkShiNo vAkyaprachArakAshchAsan te.asmAkaM madhye yadyat sapramANaM vAkyamarpayanti sma 
\p  
\v 2 tadanusArato.anyepi bahavastadvR^ittAntaM rachayituM pravR^ittAH| 
\p  
\v 3 ataeva he mahAmahimathiyaphil tvaM yA yAH kathA ashikShyathAstAsAM dR^iDhapramANAni yathA prApnoShi 
\p  
\v 4 tadarthaM prathamamArabhya tAni sarvvANi j nAtvAhamapi anukramAt sarvvavR^ittAntAn tubhyaM lekhituM matimakArSham| 
\p  
\v 5 yihUdAdeshIyaherodnAmake rAjatvaM kurvvati abIyayAjakasya paryyAyAdhikArI sikhariyanAmaka eko yAjako hAroNavaMshodbhavA ilIshevAkhyA 
\p  
\v 6 tasya jAyA dvAvimau nirdoShau prabhoH sarvvAj nA vyavasthAshcha saMmanya IshvaradR^iShTau dhArmmikAvAstAm| 
\p  
\v 7 tayoH santAna ekopi nAsIt, yata ilIshevA bandhyA tau dvAveva vR^iddhAvabhavatAm| 
\p  
\v 8 yadA svaparyyAnukrameNa sikhariya IshvAsya samakShaM yAjakIyaM karmma karoti 
\p  
\v 9 tadA yaj nasya dinaparipAyyA parameshvarasya mandire praveshakAle dhUpajvAlanaM karmma tasya karaNIyamAsIt| 
\p  
\v 10 taddhUpajvAlanakAle lokanivahe prArthanAM kartuM bahistiShThati 
\p  
\v 11 sati sikhariyo yasyAM vedyAM dhUpaM jvAlayati taddakShiNapArshve parameshvarasya dUta eka upasthito darshanaM dadau| 
\p  
\v 12 taM dR^iShTvA sikhariya udvivije shasha Nke cha| 
\p  
\v 13 tadA sa dUtastaM babhAShe he sikhariya mA bhaistava prArthanA grAhyA jAtA tava bhAryyA ilIshevA putraM prasoShyate tasya nAma yoेhan iti kariShyasi| 
\p  
\v 14 ki ncha tvaM sAnandaH saharShashcha bhaviShyasi tasya janmani bahava AnandiShyanti cha| 
\p  
\v 15 yato hetoH sa parameshvarasya gochare mahAn bhaviShyati tathA drAkShArasaM surAM vA kimapi na pAsyati, aparaM janmArabhya pavitreNAtmanA paripUrNaH 
\p  
\v 16 san isrAyelvaMshIyAn anekAn prabhoH parameshvarasya mArgamAneShyati| 
\p  
\v 17 santAnAn prati pitR^iNAM manAMsi dharmmaj nAnaM pratyanAj nAgrAhiNashcha parAvarttayituM, prabhoH parameshvarasya sevArtham ekAM sajjitajAtiM vidhAtu ncha sa eliyarUpAtmashaktiprAptastasyAgre gamiShyati| 
\p  
\v 18 tadA sikhariyo dUtamavAdIt kathametad vetsyAmi? yatohaM vR^iddho mama bhAryyA cha vR^iddhA| 
\p  
\v 19 tato dUtaH pratyuvAcha pashyeshvarasya sAkShAdvarttI jibrAyelnAmA dUtohaM tvayA saha kathAM gadituM tubhyamimAM shubhavArttAM dAtu ncha preShitaH| 
\p  
\v 20 kintu madIyaM vAkyaM kAle phaliShyati tat tvayA na pratItam ataH kAraNAd yAvadeva tAni na setsyanti tAvat tvaM vaktuMmashakto mUko bhava| 
\p  
\v 21 tadAnIM ye ye lokAH sikhariyamapaikShanta te madhyemandiraM tasya bahuvilambAd AshcharyyaM menire| 
\p  
\v 22 sa bahirAgato yadA kimapi vAkyaM vaktumashaktaH sa NketaM kR^itvA niHshabdastasyau tadA madhyemandiraM kasyachid darshanaM tena prAptam iti sarvve bubudhire| 
\p  
\v 23 anantaraM tasya sevanaparyyAye sampUrNe sati sa nijagehaM jagAma| 
\p  
\v 24 katipayadineShu gateShu tasya bhAryyA ilIshevA garbbhavatI babhUva 
\p  
\v 25 pashchAt sA pa nchamAsAn saMgopyAkathayat lokAnAM samakShaM mamApamAnaM khaNDayituM parameshvaro mayi dR^iShTiM pAtayitvA karmmedR^ishaM kR^itavAn| 
\p  
\v 26 apara ncha tasyA garbbhasya ShaShThe mAse jAte gAlIlpradeshIyanAsaratpure 
\p  
\v 27 dAyUdo vaMshIyAya yUShaphnAmne puruShAya yA mariyamnAmakumArI vAgdattAsIt tasyAH samIpaM jibrAyel dUta IshvareNa prahitaH| 
\p  
\v 28 sa gatvA jagAda he IshvarAnugR^ihItakanye tava shubhaM bhUyAt prabhuH parameshvarastava sahAyosti nArINAM madhye tvameva dhanyA| 
\p  
\v 29 tadAnIM sA taM dR^iShTvA tasya vAkyata udvijya kIdR^ishaM bhAShaNamidam iti manasA chintayAmAsa| 
\p  
\v 30 tato dUto.avadat he mariyam bhayaM mAkArShIH, tvayi parameshvarasyAnugrahosti| 
\p  
\v 31 pashya tvaM garbbhaM dhR^itvA putraM prasoShyase tasya nAma yIshuriti kariShyasi| 
\p  
\v 32 sa mahAn bhaviShyati tathA sarvvebhyaH shreShThasya putra iti khyAsyati; aparaM prabhuH parameshvarastasya piturdAyUdaH siMhAsanaM tasmai dAsyati; 
\p  
\v 33 tathA sa yAkUbo vaMshopari sarvvadA rAjatvaM kariShyati, tasya rAjatvasyAnto na bhaviShyati| 
\p  
\v 34 tadA mariyam taM dUtaM babhAShe nAhaM puruShasa NgaM karomi tarhi kathametat sambhaviShyati? 
\p  
\v 35 tato dUto.akathayat pavitra AtmA tvAmAshrAyiShyati tathA sarvvashreShThasya shaktistavopari ChAyAM kariShyati tato hetostava garbbhAd yaH pavitrabAlako janiShyate sa Ishvaraputra iti khyAtiM prApsyati| 
\p  
\v 36 apara ncha pashya tava j nAtirilIshevA yAM sarvve bandhyAmavadan idAnIM sA vArddhakye santAnamekaM garbbhe.adhArayat tasya ShaShThamAsobhUt| 
\p  
\v 37 kimapi karmma nAsAdhyam Ishvarasya| 
\p  
\v 38 tadA mariyam jagAda, pashya prabherahaM dAsI mahyaM tava vAkyAnusAreNa sarvvametad ghaTatAm; ananataraM dUtastasyAH samIpAt pratasthe| 
\p  
\v 39 atha katipayadinAt paraM mariyam tasmAt parvvatamayapradeshIyayihUdAyA nagaramekaM shIghraM gatvA 
\p  
\v 40 sikhariyayAjakasya gR^ihaM pravishya tasya jAyAm ilIshevAM sambodhyAvadat| 
\p  
\v 41 tato mariyamaH sambodhanavAkye ilIshevAyAH karNayoH praviShTamAtre sati tasyA garbbhasthabAlako nanartta| tata ilIshevA pavitreNAtmanA paripUrNA satI 
\p  
\v 42 prochchairgaditumArebhe, yoShitAM madhye tvameva dhanyA, tava garbbhasthaH shishushcha dhanyaH| 
\p  
\v 43 tvaM prabhormAtA, mama niveshane tvayA charaNAvarpitau, mamAdya saubhAgyametat| 
\p  
\v 44 pashya tava vAkye mama karNayoH praviShTamAtre sati mamodarasthaH shishurAnandAn nanartta| 
\p  
\v 45 yA strI vyashvasIt sA dhanyA, yato hetostAM prati parameshvaroktaM vAkyaM sarvvaM siddhaM bhaviShyati| 
\p  
\v 46 tadAnIM mariyam jagAda| dhanyavAdaM pareshasya karoti mAmakaM manaH| 
\p  
\v 47 mamAtmA tArakeshe cha samullAsaM pragachChati| 
\p  
\v 48 akarot sa prabhu rduShTiM svadAsyA durgatiM prati| pashyAdyArabhya mAM dhanyAM vakShyanti puruShAH sadA| 
\p  
\v 49 yaH sarvvashaktimAn yasya nAmApi cha pavitrakaM| sa eva sumahatkarmma kR^itavAn mannimittakaM| 
\p  
\v 50 ye bibhyati janAstasmAt teShAM santAnapaMktiShu| anukampA tadIyA cha sarvvadaiva sutiShThati| 
\p  
\v 51 svabAhubalatastena prAkAshyata parAkramaH| manaHkumantraNAsArddhaM vikIryyante.abhimAninaH| 
\p  
\v 52 siMhAsanagatAllokAn balinashchAvarohya saH| padeShUchcheShu lokAMstu kShudrAn saMsthApayatyapi| 
\p  
\v 53 kShudhitAn mAnavAn dravyairuttamaiH paritarpya saH| sakalAn dhanino lokAn visR^ijed riktahastakAn| 
\p  
\v 54 ibrAhImi cha tadvaMshe yA dayAsti sadaiva tAM| smR^itvA purA pitR^iNAM no yathA sAkShAt pratishrutaM| 
\p  
\v 55 isrAyelsevakastena tathopakriyate svayaM|| 
\p  
\v 56 anantaraM mariyam prAyeNa mAsatrayam ilIshevayA sahoShitvA vyAghuyya nijaniveshanaM yayau| 
\p  
\v 57 tadanantaram ilIshevAyAH prasavakAla upasthite sati sA putraM prAsoShTa| 
\p  
\v 58 tataH parameshvarastasyAM mahAnugrahaM kR^itavAn etat shrutvA samIpavAsinaH kuTumbAshchAgatya tayA saha mumudire| 
\p  
\v 59 tathAShTame dine te bAlakasya tvachaM Chettum etya tasya pitR^inAmAnurUpaM tannAma sikhariya iti karttumIShuH| 
\p  
\v 60 kintu tasya mAtAkathayat tanna, nAmAsya yohan iti karttavyam| 
\p  
\v 61 tadA te vyAharan tava vaMshamadhye nAmedR^ishaM kasyApi nAsti| 
\p  
\v 62 tataH paraM tasya pitaraM sikhariyaM prati sa Nketya paprachChuH shishoH kiM nAma kAriShyate? 
\p  
\v 63 tataH sa phalakamekaM yAchitvA lilekha tasya nAma yohan bhaviShyati| tasmAt sarvve AshcharyyaM menire| 
\p  
\v 64 tatkShaNaM sikhariyasya jihvAjADye.apagate sa mukhaM vyAdAya spaShTavarNamuchchAryya Ishvarasya guNAnuvAdaM chakAra| 
\p  
\v 65 tasmAchchaturdiksthAH samIpavAsilokA bhItA evametAH sarvvAH kathA yihUdAyAH parvvatamayapradeshasya sarvvatra prachAritAH| 
\p  
\v 66 tasmAt shrotAro manaHsu sthApayitvA kathayAmbabhUvuH kIdR^ishoyaM bAlo bhaviShyati? atha parameshvarastasya sahAyobhUt| 
\p  
\v 67 tadA yohanaH pitA sikhariyaH pavitreNAtmanA paripUrNaH san etAdR^ishaM bhaviShyadvAkyaM kathayAmAsa| 
\p  
\v 68 isrAyelaH prabhu ryastu sa dhanyaH parameshvaraH| anugR^ihya nijAllokAn sa eva parimochayet| 
\p  
\v 69 vipakShajanahastebhyo yathA mochyAmahe vayaM| yAvajjIva ncha dharmmeNa sAralyena cha nirbhayAH| 
\p  
\v 70 sevAmahai tamevaikam etatkAraNameva cha| svakIyaM supavitra ncha saMsmR^itya niyamaM sadA| 
\p  
\v 71 kR^ipayA puruShAn pUrvvAn nikaShArthAttu naH pituH| ibrAhImaH samIpe yaM shapathaM kR^itavAn purA| 
\p  
\v 72 tameva saphalaM karttaM tathA shatrugaNasya cha| R^iृtIyAkAriNashchaiva karebhyo rakShaNAya naH| 
\p  
\v 73 sR^iShTeH prathamataH svIyaiH pavitrai rbhAvivAdibhiH| 
\p  
\v 74 yathoktavAn tathA svasya dAyUdaH sevakasya tu| 
\p  
\v 75 vaMshe trAtAramekaM sa samutpAditavAn svayam| 
\p  
\v 76 ato he bAlaka tvantu sarvvebhyaH shreShTha eva yaH| tasyaiva bhAvivAdIti pravikhyAto bhaviShyasi| asmAkaM charaNAn kSheme mArge chAlayituM sadA| evaM dhvAnte.arthato mR^ityoshChAyAyAM ye tu mAnavAH| 
\p  
\v 77 upaviShTAstu tAneva prakAshayitumeva hi| kR^itvA mahAnukampAM hi yAmeva parameshvaraH| 
\p  
\v 78 UrdvvAt sUryyamudAyyaivAsmabhyaM prAdAttu darshanaM| tayAnukampayA svasya lokAnAM pApamochane| 
\p  
\v 79 paritrANasya tebhyo hi j nAnavishrANanAya cha| prabho rmArgaM pariShkarttuM tasyAgrAyI bhaviShyasi|| 
\p  
\v 80 atha bAlakaH sharIreNa buddhyA cha varddhitumArebhe; apara ncha sa isrAyelo vaMshIyalokAnAM samIpe yAvanna prakaTIbhUtastAstAvat prAntare nyavasat| 
\c 2  
\p  
\v 1 apara ncha tasmin kAle rAjyasya sarvveShAM lokAnAM nAmAni lekhayitum agastakaisara Aj nApayAmAsa| 
\p  
\v 2 tadanusAreNa kurINiyanAmani suriyAdeshasya shAsake sati nAmalekhanaM prArebhe| 
\p  
\v 3 ato heto rnAma lekhituM sarvve janAH svIyaM svIyaM nagaraM jagmuH| 
\p  
\v 4 tadAnIM yUShaph nAma lekhituM vAgdattayA svabhAryyayA garbbhavatyA mariyamA saha svayaM dAyUdaH sajAtivaMsha iti kAraNAd gAlIlpradeshasya nAsaratnagarAd 
\p  
\v 5 yihUdApradeshasya baitlehamAkhyaM dAyUdnagaraM jagAma| 
\p  
\v 6 anyachcha tatra sthAne tayostiShThatoH sato rmariyamaH prasUtikAla upasthite 
\p  
\v 7 sA taM prathamasutaM prAsoShTa kintu tasmin vAsagR^ihe sthAnAbhAvAd bAlakaM vastreNa veShTayitvA goshAlAyAM sthApayAmAsa| 
\p  
\v 8 anantaraM ye kiyanto meShapAlakAH svameShavrajarakShAyai tatpradeshe sthitvA rajanyAM prAntare prahariNaH karmma kurvvanti, 
\p  
\v 9 teShAM samIpaM parameshvarasya dUta Agatyopatasthau; tadA chatuShpArshve parameshvarasya tejasaH prakAshitatvAt te.atishasha Nkire| 
\p  
\v 10 tadA sa dUta uvAcha mA bhaiShTa pashyatAdya dAyUdaH pure yuShmannimittaM trAtA prabhuH khrIShTo.ajaniShTa, 
\p  
\v 11 sarvveShAM lokAnAM mahAnandajanakam imaM ma NgalavR^ittAntaM yuShmAn j nApayAmi| 
\p  
\v 12 yUyaM (tatsthAnaM gatvA) vastraveShTitaM taM bAlakaM goshAlAyAM shayanaM drakShyatha yuShmAn pratIdaM chihnaM bhaviShyati| 
\p  
\v 13 dUta imAM kathAM kathitavati tatrAkasmAt svargIyAH pR^itanA Agatya kathAm imAM kathayitveshvarasya guNAnanvavAdiShuH, yathA, 
\p  
\v 14 sarvvordvvasthairIshvarasya mahimA samprakAshyatAM| shAntirbhUyAt pR^ithivyAstu santoShashcha narAn prati|| 
\p  
\v 15 tataH paraM teShAM sannidhe rdUtagaNe svargaM gate meShapAlakAH parasparam avechan AgachChata prabhuH parameshvaro yAM ghaTanAM j nApitavAn tasyA yAtharyaM j nAtuM vayamadhunA baitlehampuraM yAmaH| 
\p  
\v 16 pashchAt te tUrNaM vrajitvA mariyamaM yUShaphaM goshAlAyAM shayanaM bAlaka ncha dadR^ishuH| 
\p  
\v 17 itthaM dR^iShTvA bAlakasyArthe proktAM sarvvakathAM te prAchArayA nchakruH| 
\p  
\v 18 tato ye lokA meSharakShakANAM vadanebhyastAM vArttAM shushruvuste mahAshcharyyaM menire| 
\p  
\v 19 kintu mariyam etatsarvvaghaTanAnAM tAtparyyaM vivichya manasi sthApayAmAsa| 
\p  
\v 20 tatpashchAd dUtavij naptAnurUpaM shrutvA dR^iShTvA cha meShapAlakA Ishvarasya guNAnuvAdaM dhanyavAda ncha kurvvANAH parAvR^itya yayuH| 
\p  
\v 21 atha bAlakasya tvakChedanakAle.aShTamadivase samupasthite tasya garbbhasthiteH purvvaM svargIyadUto yathAj nApayat tadanurUpaM te tannAmadheyaM yIshuriti chakrire| 
\p  
\v 22 tataH paraM mUsAlikhitavyavasthAyA anusAreNa mariyamaH shuchitvakAla upasthite, 
\p  
\v 23 "prathamajaH sarvvaH puruShasantAnaH parameshvare samarpyatAM," iti parameshvarasya vyavasthayA 
\p  
\v 24 yIshuM parameshvare samarpayitum shAstrIyavidhyuktaM kapotadvayaM pArAvatashAvakadvayaM vA baliM dAtuM te taM gR^ihItvA yirUshAlamam AyayuH| 
\p  
\v 25 yirUshAlampuranivAsI shimiyonnAmA dhArmmika eka AsIt sa isrAyelaH sAntvanAmapekShya tasthau ki ncha pavitra AtmA tasminnAvirbhUtaH| 
\p  
\v 26 aparaM prabhuNA parameshvareNAbhiShikte trAtari tvayA na dR^iShTe tvaM na mariShyasIti vAkyaM pavitreNa AtmanA tasma prAkathyata| 
\p  
\v 27 apara ncha yadA yIshoH pitA mAtA cha tadarthaM vyavasthAnurUpaM karmma karttuM taM mandiram AninyatustadA 
\p  
\v 28 shimiyon Atmana AkarShaNena mandiramAgatya taM kroDe nidhAya Ishvarasya dhanyavAdaM kR^itvA kathayAmAsa, yathA, 
\p  
\v 29 he prabho tava dAsoyaM nijavAkyAnusArataH| idAnIntu sakalyANo bhavatA saMvisR^ijyatAm| 
\p  
\v 30 yataH sakaladeshasya dIptaye dIptirUpakaM| 
\p  
\v 31 isrAyelIyalokasya mahAgauravarUpakaM| 
\p  
\v 32 yaM trAyakaM janAnAntu sammukhe tvamajIjanaH| saeva vidyate.asmAkaM dhravaM nayananagochare|| 
\p  
\v 33 tadAnIM tenoktA etAH sakalAH kathAH shrutvA tasya mAtA yUShaph cha vismayaM menAte| 
\p  
\v 34 tataH paraM shimiyon tebhya AshiShaM dattvA tanmAtaraM mariyamam uvAcha, pashya isrAyelo vaMshamadhye bahUnAM pAtanAyotthApanAya cha tathA virodhapAtraM bhavituM, bahUnAM guptamanogatAnAM prakaTIkaraNAya bAlakoyaM niyuktosti| 
\p  
\v 35 tasmAt tavApi prANAH shUlena vyatsyante| 
\p  
\v 36 apara ncha Asherasya vaMshIyaphinUyelo duhitA hannAkhyA atijaratI bhaviShyadvAdinyekA yA vivAhAt paraM sapta vatsarAn patyA saha nyavasat tato vidhavA bhUtvA chaturashItivarShavayaHparyyanataM 
\p  
\v 37 mandire sthitvA prArthanopavAsairdivAnisham Ishvaram asevata sApi strI tasmin samaye mandiramAgatya 
\p  
\v 38 parameshvarasya dhanyavAdaM chakAra, yirUshAlampuravAsino yAvanto lokA muktimapekShya sthitAstAn yIshorvR^ittAntaM j nApayAmAsa| 
\p  
\v 39 itthaM parameshvarasya vyavasthAnusAreNa sarvveShu karmmasu kR^iteShu tau punashcha gAlIlo nAsaratnAmakaM nijanagaraM pratasthAte| 
\p  
\v 40 tatpashchAd bAlakaH sharIreNa vR^iddhimetya j nAnena paripUrNa AtmanA shaktimAMshcha bhavitumArebhe tathA tasmin IshvarAnugraho babhUva| 
\p  
\v 41 tasya pitA mAtA cha prativarShaM nistArotsavasamaye yirUshAlamam agachChatAm| 
\p  
\v 42 apara ncha yIshau dvAdashavarShavayaske sati tau parvvasamayasya rItyanusAreNa yirUshAlamaM gatvA 
\p  
\v 43 pArvvaNaM sampAdya punarapi vyAghuyya yAtaH kintu yIshurbAlako yirUshAlami tiShThati| yUShaph tanmAtA cha tad aviditvA 
\p  
\v 44 sa sa NgibhiH saha vidyata etachcha budvvA dinaikagamyamArgaM jagmatuH| kintu sheShe j nAtibandhUnAM samIpe mR^igayitvA taduddeेshamaprApya 
\p  
\v 45 tau punarapi yirUshAlamam parAvR^ityAgatya taM mR^igayA nchakratuH| 
\p  
\v 46 atha dinatrayAt paraM paNDitAnAM madhye teShAM kathAH shR^iNvan tattvaM pR^ichChaMshcha mandire samupaviShTaH sa tAbhyAM dR^iShTaH| 
\p  
\v 47 tadA tasya buddhyA pratyuttaraishcha sarvve shrotAro vismayamApadyante| 
\p  
\v 48 tAdR^ishaM dR^iShTvA tasya janako jananI cha chamachchakratuH ki ncha tasya mAtA tamavadat, he putra, kathamAvAM pratItthaM samAcharastvam? pashya tava pitAha ncha shokAkulau santau tvAmanvichChAvaH sma| 
\p  
\v 49 tataH sovadat kuto mAm anvaichChataM? piturgR^ihe mayA sthAtavyam etat kiM yuvAbhyAM na j nAyate? 
\p  
\v 50 kintu tau tasyaitadvAkyasya tAtparyyaM boddhuM nAshaknutAM| 
\p  
\v 51 tataH paraM sa tAbhyAM saha nAsarataM gatvA tayorvashIbhUtastasthau kintu sarvvA etAH kathAstasya mAtA manasi sthApayAmAsa| 
\p  
\v 52 atha yIsho rbuddhiH sharIra ncha tathA tasmin Ishvarasya mAnavAnA nchAnugraho varddhitum Arebhe| 
\c 3  
\p  
\v 1 anantaraM tibiriyakaisarasya rAjatvasya pa nchadashe vatsare sati yadA pantIyapIlAto yihUdAdeshAdhipati rherod tu gAlIlpradeshasya rAjA philipanAmA tasya bhrAtA tu yitUriyAyAstrAkhonItiyApradeshasya cha rAjAsIt luShAnIyanAmA avilInIdeshasya rAjAsIt 
\p  
\v 2 hAnan kiyaphAshchemau pradhAnayAjAkAvAstAM tadAnIM sikhariyasya putrAya yohane madhyeprAntaram Ishvarasya vAkye prakAshite sati 
\p  
\v 3 sa yarddana ubhayataTapradeshAn sametya pApamochanArthaM manaHparAvarttanasya chihnarUpaM yanmajjanaM tadIyAH kathAH sarvvatra prachArayitumArebhe| 
\p  
\v 4 yishayiyabhaviShyadvaktR^igranthe yAdR^ishI lipirAste yathA, parameshasya panthAnaM pariShkuruta sarvvataH| tasya rAjapatha nchaiva samAnaM kurutAdhunA| 
\p  
\v 5 kAriShyante samuchChrAyAH sakalA nimnabhUmayaH| kAriShyante natAH sarvve parvvatAshchopaparvvatAH| kAriShyante cha yA vakrAstAH sarvvAH saralA bhuvaH| kAriShyante samAnAstA yA uchchanIchabhUmayaH| 
\p  
\v 6 IshvareNa kR^itaM trANaM drakShyanti sarvvamAnavAH| ityetat prAntare vAkyaM vadataH kasyachid ravaH|| 
\p  
\v 7 ye ye lokA majjanArthaM bahirAyayustAn sovadat re re sarpavaMshA AgAminaH kopAt palAyituM yuShmAn kashchetayAmAsa? 
\p  
\v 8 tasmAd ibrAhIm asmAkaM pitA kathAmIdR^ishIM manobhi rna kathayitvA yUyaM manaHparivarttanayogyaM phalaM phalata; yuShmAnahaM yathArthaM vadAmi pAShANebhya etebhya Ishvara ibrAhImaH santAnotpAdane samarthaH| 
\p  
\v 9 apara ncha tarumUle.adhunApi parashuH saMlagnosti yastaruruttamaM phalaM na phalati sa Chidyate.agnau nikShipyate cha| 
\p  
\v 10 tadAnIM lokAstaM paprachChustarhi kiM karttavyamasmAbhiH? 
\p  
\v 11 tataH sovAdIt yasya dve vasane vidyete sa vastrahInAyaikaM vitaratu kiM ncha yasya khAdyadravyaM vidyate sopi tathaiva karotu| 
\p  
\v 12 tataH paraM karasa nchAyino majjanArtham Agatya paprachChuH he guro kiM karttavyamasmAbhiH? 
\p  
\v 13 tataH sokathayat nirUpitAdadhikaM na gR^ihlita| 
\p  
\v 14 anantaraM senAgaNa etya paprachCha kimasmAbhi rvA karttavyam? tataH sobhidadhe kasya kAmapi hAniM mA kArShTa tathA mR^iShApavAdaM mA kuruta nijavetanena cha santuShya tiShThata| 
\p  
\v 15 apara ncha lokA apekShayA sthitvA sarvvepIti manobhi rvitarkayA nchakruH, yohanayam abhiShiktastrAtA na veti? 
\p  
\v 16 tadA yohan sarvvAn vyAjahAra, jale.ahaM yuShmAn majjayAmi satyaM kintu yasya pAdukAbandhanaM mochayitumapi na yogyosmi tAdR^isha eko matto gurutaraH pumAn eti, sa yuShmAn vahnirUpe pavitra Atmani majjayiShyati| 
\p  
\v 17 apara ncha tasya haste shUrpa Aste sa svashasyAni shuddharUpaM prasphoTya godhUmAn sarvvAn bhANDAgAre saMgrahIShyati kintu bUShANi sarvvANyanirvvANavahninA dAhayiShyati| 
\p  
\v 18 yohan upadeshenetthaM nAnAkathA lokAnAM samakShaM prachArayAmAsa| 
\p  
\v 19 apara ncha herod rAjA philipnAmnaH sahodarasya bhAryyAM herodiyAmadhi tathAnyAni yAni yAni kukarmmANi kR^itavAn tadadhi cha 
\p  
\v 20 yohanA tiraskR^ito bhUtvA kArAgAre tasya bandhanAd aparamapi kukarmma chakAra| 
\p  
\v 21 itaH pUrvvaM yasmin samaye sarvve yohanA majjitAstadAnIM yIshurapyAgatya majjitaH| 
\p  
\v 22 tadanantaraM tena prArthite meghadvAraM muktaM tasmAchcha pavitra AtmA mUrttimAn bhUtvA kapotavat taduparyyavaruroha; tadA tvaM mama priyaH putrastvayi mama paramaH santoSha ityAkAshavANI babhUva| 
\p  
\v 23 tadAnIM yIshuH prAyeNa triMshadvarShavayaska AsIt| laukikaj nAne tu sa yUShaphaH putraH, 
\p  
\v 24 yUShaph eleH putraH, elirmattataH putraH, mattat leveH putraH, levi rmalkeH putraH, malkiryAnnasya putraH; yAnno yUShaphaH putraH| 
\p  
\v 25 yUShaph mattathiyasya putraH, mattathiya AmosaH putraH, Amos nahUmaH putraH, nahUm iShleH putraH iShlirnageH putraH| 
\p  
\v 26 nagirmATaH putraH, mAT mattathiyasya putraH, mattathiyaH shimiyeH putraH, shimiyiryUShaphaH putraH, yUShaph yihUdAH putraH| 
\p  
\v 27 yihUdA yohAnAH putraH, yohAnA rIShAH putraH, rIShAH sirubbAbilaH putraH, sirubbAbil shaltIyelaH putraH, shaltIyel nereH putraH| 
\p  
\v 28 nerirmalkeH putraH, malkiH adyaH putraH, addI koShamaH putraH, koSham ilmodadaH putraH, ilmodad eraH putraH| 
\p  
\v 29 er yosheH putraH, yoshiH ilIyeSharaH putraH, ilIyeShar yorImaH putraH, yorIm mattataH putraH, mattata leveH putraH| 
\p  
\v 30 leviH shimiyonaH putraH, shimiyon yihUdAH putraH, yihUdA yUShuphaH putraH, yUShuph yonanaH putraH, yAnan ilIyAkImaH putraH| 
\p  
\v 31 iliyAkImH mileyAH putraH, mileyA mainanaH putraH, mainan mattattasya putraH, mattatto nAthanaH putraH, nAthan dAyUdaH putraH| 
\p  
\v 32 dAyUd yishayaH putraH, yishaya obedaH putra, obed boyasaH putraH, boyas salmonaH putraH, salmon nahashonaH putraH| 
\p  
\v 33 nahashon ammInAdabaH putraH, ammInAdab arAmaH putraH, arAm hiShroNaH putraH, hiShroN perasaH putraH, peras yihUdAH putraH| 
\p  
\v 34 yihUdA yAkUbaH putraH, yAkUb ishAkaH putraH, ishAk ibrAhImaH putraH, ibrAhIm terahaH putraH, terah nAhoraH putraH| 
\p  
\v 35 nAhor sirugaH putraH, sirug riyvaH putraH, riyUH pelagaH putraH, pelag evaraH putraH, evar shelahaH putraH| 
\p  
\v 36 shelah kainanaH putraH, kainan arphakShadaH putraH, arphakShad shAmaH putraH, shAm nohaH putraH, noho lemakaH putraH| 
\p  
\v 37 lemak mithUshelahaH putraH, mithUshelah hanokaH putraH, hanok yeradaH putraH, yerad mahalalelaH putraH, mahalalel kainanaH putraH| 
\p  
\v 38 kainan inoshaH putraH, inosh shetaH putraH, shet AdamaH putra, Adam Ishvarasya putraH| 
\c 4  
\p  
\v 1 tataH paraM yIshuH pavitreNAtmanA pUrNaH san yarddananadyAH parAvR^ityAtmanA prAntaraM nItaH san chatvAriMshaddinAni yAvat shaitAnA parIkShito.abhUt, 
\p  
\v 2 ki ncha tAni sarvvadinAni bhojanaM vinA sthitatvAt kAle pUrNe sa kShudhitavAn| 
\p  
\v 3 tataH shaitAnAgatya tamavadat tvaM chedIshvarasya putrastarhi prastarAnetAn Aj nayA pUpAn kuru| 
\p  
\v 4 tadA yIshuruvAcha, lipirIdR^ishI vidyate manujaH kevalena pUpena na jIvati kintvIshvarasya sarvvAbhirAj nAbhi rjIvati| 
\p  
\v 5 tadA shaitAn tamuchchaM parvvataM nItvA nimiShaikamadhye jagataH sarvvarAjyAni darshitavAn| 
\p  
\v 6 pashchAt tamavAdIt sarvvam etad vibhavaM pratApa ncha tubhyaM dAsyAmi tan mayi samarpitamAste yaM prati mamechChA jAyate tasmai dAtuM shaknomi, 
\p  
\v 7 tvaM chenmAM bhajase tarhi sarvvametat tavaiva bhaviShyati| 
\p  
\v 8 tadA yIshustaM pratyuktavAn dUrI bhava shaitAn lipirAste, nijaM prabhuM parameshvaraM bhajasva kevalaM tameva sevasva cha| 
\p  
\v 9 atha shaitAn taM yirUshAlamaM nItvA mandirasya chUDAyA upari samupaveshya jagAda tvaM chedIshvarasya putrastarhi sthAnAdito lamphitvAdhaH 
\p  
\v 10 pata yato lipirAste, Aj nApayiShyati svIyAn dUtAn sa parameshvaraH| 
\p  
\v 11 rakShituM sarvvamArge tvAM tena tvachcharaNe yathA| na laget prastarAghAtastvAM dhariShyanti te tathA| 
\p  
\v 12 tadA yIshunA pratyuktam idamapyuktamasti tvaM svaprabhuM pareshaM mA parIkShasva| 
\p  
\v 13 pashchAt shaitAn sarvvaparIkShAM samApya kShaNAttaM tyaktvA yayau| 
\p  
\v 14 tadA yIshurAtmaprabhAvAt punargAlIlpradeshaM gatastadA tatsukhyAtishchaturdishaM vyAnashe| 
\p  
\v 15 sa teShAM bhajanagR^iheShu upadishya sarvvaiH prashaMsito babhUva| 
\p  
\v 16 atha sa svapAlanasthAnaM nAsaratpurametya vishrAmavAre svAchArAd bhajanagehaM pravishya paThitumuttasthau| 
\p  
\v 17 tato yishayiyabhaviShyadvAdinaH pustake tasya karadatte sati sa tat pustakaM vistAryya yatra vakShyamANAni vachanAni santi tat sthAnaM prApya papATha| 
\p  
\v 18 AtmA tu parameshasya madIyopari vidyate| daridreShu susaMvAdaM vaktuM mAM sobhiShiktavAn| bhagnAntaH karaNAllokAn susvasthAn karttumeva cha| bandIkR^iteShu lokeShu mukte rghoShayituM vachaH| netrANi dAtumandhebhyastrAtuM baddhajanAnapi| 
\p  
\v 19 pareshAnugrahe kAlaM prachArayitumeva cha| sarvvaitatkaraNArthAya mAmeva prahiNoti saH|| 
\p  
\v 20 tataH pustakaM badvvA parichArakasya haste samarpya chAsane samupaviShTaH, tato bhajanagR^ihe yAvanto lokA Asan te sarvve.ananyadR^iShTyA taM vilulokire| 
\p  
\v 21 anantaram adyaitAni sarvvANi likhitavachanAni yuShmAkaM madhye siddhAni sa imAM kathAM tebhyaH kathayitumArebhe| 
\p  
\v 22 tataH sarvve tasmin anvarajyanta, ki ncha tasya mukhAnnirgatAbhiranugrahasya kathAbhishchamatkR^itya kathayAmAsuH kimayaM yUShaphaH putro na? 
\p  
\v 23 tadA so.avAdId he chikitsaka svameva svasthaM kuru kapharnAhUmi yadyat kR^itavAn tadashrauShma tAH sarvAH kriyA atra svadeshe kuru kathAmetAM yUyamevAvashyaM mAM vadiShyatha| 
\p  
\v 24 punaH sovAdId yuShmAnahaM yathArthaM vadAmi, kopi bhaviShyadvAdI svadeshe satkAraM na prApnoti| 
\p  
\v 25 apara ncha yathArthaM vachmi, eliyasya jIvanakAle yadA sArddhatritayavarShANi yAvat jaladapratibandhAt sarvvasmin deshe mahAdurbhikSham ajaniShTa tadAnIm isrAyelo deshasya madhye bahvyo vidhavA Asan, 
\p  
\v 26 kintu sIdonpradeshIyasAriphatpuranivAsinIm ekAM vidhavAM vinA kasyAshchidapi samIpe eliyaH prerito nAbhUt| 
\p  
\v 27 apara ncha ilIshAyabhaviShyadvAdividyamAnatAkAle isrAyeldeshe bahavaH kuShThina Asan kintu surIyadeshIyaM nAmAnkuShThinaM vinA kopyanyaH pariShkR^ito nAbhUt| 
\p  
\v 28 imAM kathAM shrutvA bhajanagehasthitA lokAH sakrodham utthAya 
\p  
\v 29 nagarAttaM bahiShkR^itya yasya shikhariNa upari teShAM nagaraM sthApitamAste tasmAnnikSheptuM tasya shikharaM taM ninyuH 
\p  
\v 30 kintu sa teShAM madhyAdapasR^itya sthAnAntaraM jagAma| 
\p  
\v 31 tataH paraM yIshurgAlIlpradeshIyakapharnAhUmnagara upasthAya vishrAmavAre lokAnupadeShTum ArabdhavAn| 
\p  
\v 32 tadupadeshAt sarvve chamachchakru ryatastasya kathA gurutarA Asan| 
\p  
\v 33 tadAnIM tadbhajanagehasthito.amedhyabhUtagrasta eko jana uchchaiH kathayAmAsa, 
\p  
\v 34 he nAsaratIyayIsho.asmAn tyaja, tvayA sahAsmAkaM kaH sambandhaH? kimasmAn vinAshayitumAyAsi? tvamIshvarasya pavitro jana etadahaM jAnAmi| 
\p  
\v 35 tadA yIshustaM tarjayitvAvadat maunI bhava ito bahirbhava; tataH somedhyabhUtastaM madhyasthAne pAtayitvA ki nchidapyahiMsitvA tasmAd bahirgatavAn| 
\p  
\v 36 tataH sarvve lokAshchamatkR^itya parasparaM vaktumArebhire koyaM chamatkAraH| eSha prabhAveNa parAkrameNa chAmedhyabhUtAn Aj nApayati tenaiva te bahirgachChanti| 
\p  
\v 37 anantaraM chaturdiksthadeshAn tasya sukhyAtirvyApnot| 
\p  
\v 38 tadanantaraM sa bhajanagehAd bahirAgatya shimono niveshanaM pravivesha tadA tasya shvashrUrjvareNAtyantaM pIDitAsIt shiShyAstadarthaM tasmin vinayaM chakruH| 
\p  
\v 39 tataH sa tasyAH samIpe sthitvA jvaraM tarjayAmAsa tenaiva tAM jvaro.atyAkShIt tataH sA tatkShaNam utthAya tAn siSheve| 
\p  
\v 40 atha sUryyAstakAle sveShAM ye ye janA nAnArogaiH pIDitA Asan lokAstAn yIshoH samIpam AninyuH, tadA sa ekaikasya gAtre karamarpayitvA tAnarogAn chakAra| 
\p  
\v 41 tato bhUtA bahubhyo nirgatya chItshabdaM kR^itvA cha babhAShire tvamIshvarasya putro.abhiShiktatrAtA; kintu sobhiShiktatrAteti te vividuretasmAt kAraNAt tAn tarjayitvA tadvaktuM niShiShedha| 
\p  
\v 42 apara ncha prabhAte sati sa vijanasthAnaM pratasthe pashchAt janAstamanvichChantastannikaTaM gatvA sthAnAntaragamanArthaM tamanvarundhan| 
\p  
\v 43 kintu sa tAn jagAda, IshvarIyarAjyasya susaMvAdaM prachArayitum anyAni purANyapi mayA yAtavyAni yatastadarthameva preritohaM| 
\p  
\v 44 atha gAlIlo bhajanageheShu sa upadidesha| 
\c 5  
\p  
\v 1 anantaraM yIshurekadA gineSharathdasya tIra uttiShThati, tadA lokA IshvarIyakathAM shrotuM tadupari prapatitAH| 
\p  
\v 2 tadAnIM sa hdasya tIrasamIpe naudvayaM dadarsha ki ncha matsyopajIvino nAvaM vihAya jAlaM prakShAlayanti| 
\p  
\v 3 tatastayordvayo rmadhye shimono nAvamAruhya tIrAt ki nchiddUraM yAtuM tasmin vinayaM kR^itvA naukAyAmupavishya lokAn propadiShTavAn| 
\p  
\v 4 pashchAt taM prastAvaM samApya sa shimonaM vyAjahAra, gabhIraM jalaM gatvA matsyAn dharttuM jAlaM nikShipa| 
\p  
\v 5 tataH shimona babhAShe, he guro yadyapi vayaM kR^itsnAM yAminIM parishramya matsyaikamapi na prAptAstathApi bhavato nideshato jAlaM kShipAmaH| 
\p  
\v 6 atha jAle kShipte bahumatsyapatanAd AnAyaH prachChinnaH| 
\p  
\v 7 tasmAd upakarttum anyanausthAn sa Ngina AyAtum i Ngitena samAhvayan tatasta Agatya matsyai rnaudvayaM prapUrayAmAsu ryai rnaudvayaM pramagnam| 
\p  
\v 8 tadA shimonpitarastad vilokya yIshoshcharaNayoH patitvA, he prabhohaM pApI naro mama nikaTAd bhavAn yAtu, iti kathitavAn| 
\p  
\v 9 yato jAle patitAnAM matsyAnAM yUthAt shimon tatsa Nginashcha chamatkR^itavantaH; shimonaH sahakAriNau sivadeH putrau yAkUb yohan chemau tAdR^ishau babhUvatuH| 
\p  
\v 10 tadA yIshuH shimonaM jagAda mA bhaiShIradyArabhya tvaM manuShyadharo bhaviShyasi| 
\p  
\v 11 anantaraM sarvvAsu nausu tIram AnItAsu te sarvvAn parityajya tasya pashchAdgAmino babhUvuH| 
\p  
\v 12 tataH paraM yIshau kasmiMshchit pure tiShThati jana ekaH sarvvA NgakuShThastaM vilokya tasya samIpe nyubjaH patitvA savinayaM vaktumArebhe, he prabho yadi bhavAnichChati tarhi mAM pariShkarttuM shaknoti| 
\p  
\v 13 tadAnIM sa pANiM prasAryya tada NgaM spR^ishan babhAShe tvaM pariShkriyasveti mamechChAsti tatastatkShaNaM sa kuShThAt muktaH| 
\p  
\v 14 pashchAt sa tamAj nApayAmAsa kathAmimAM kasmaichid akathayitvA yAjakasya samIpa ncha gatvA svaM darshaya, lokebhyo nijapariShkR^itatvasya pramANadAnAya mUsAj nAnusAreNa dravyamutmR^ijasva cha| 
\p  
\v 15 tathApi yIshoH sukhyAti rbahu vyAptumArebhe ki ncha tasya kathAM shrotuM svIyarogebhyo moktu ncha lokA AjagmuH| 
\p  
\v 16 atha sa prAntaraM gatvA prArthayA nchakre| 
\p  
\v 17 apara ncha ekadA yIshurupadishati, etarhi gAlIlyihUdApradeshayoH sarvvanagarebhyo yirUshAlamashcha kiyantaH phirUshilokA vyavasthApakAshcha samAgatya tadantike samupavivishuH, tasmin kAle lokAnAmArogyakAraNAt prabhoH prabhAvaH prachakAshe| 
\p  
\v 18 pashchAt kiyanto lokA ekaM pakShAghAtinaM khaTvAyAM nidhAya yIshoH samIpamAnetuM sammukhe sthApayitu ncha vyApriyanta| 
\p  
\v 19 kintu bahujananivahasamvAdhAt na shaknuvanto gR^ihopari gatvA gR^ihapR^iShThaM khanitvA taM pakShAghAtinaM sakhaTvaM gR^ihamadhye yIshoH sammukhe .avarohayAmAsuH| 
\p  
\v 20 tadA yIshusteShAm IdR^ishaM vishvAsaM vilokya taM pakShAghAtinaM vyAjahAra, he mAnava tava pApamakShamyata| 
\p  
\v 21 tasmAd adhyApakAH phirUshinashcha chittairitthaM prachintitavantaH, eSha jana IshvaraM nindati koyaM? kevalamIshvaraM vinA pApaM kShantuM kaH shaknoti? 
\p  
\v 22 tadA yIshusteShAm itthaM chintanaM viditvA tebhyokathayad yUyaM manobhiH kuto vitarkayatha? 
\p  
\v 23 tava pApakShamA jAtA yadvA tvamutthAya vraja etayo rmadhye kA kathA sukathyA? 
\p  
\v 24 kintu pR^ithivyAM pApaM kShantuM mAnavasutasya sAmarthyamastIti yathA yUyaM j nAtuM shaknutha tadarthaM (sa taM pakShAghAtinaM jagAda) uttiShTha svashayyAM gR^ihItvA gR^ihaM yAhIti tvAmAdishAmi| 
\p  
\v 25 tasmAt sa tatkShaNam utthAya sarvveShAM sAkShAt nijashayanIyaM gR^ihItvA IshvaraM dhanyaM vadan nijaniveshanaM yayau| 
\p  
\v 26 tasmAt sarvve vismaya prAptA manaHsu bhItAshcha vayamadyAsambhavakAryyANyadarshAma ityuktvA parameshvaraM dhanyaM proditAH| 
\p  
\v 27 tataH paraM bahirgachChan karasa nchayasthAne levinAmAnaM karasa nchAyakaM dR^iShTvA yIshustamabhidadhe mama pashchAdehi| 
\p  
\v 28 tasmAt sa tatkShaNAt sarvvaM parityajya tasya pashchAdiyAya| 
\p  
\v 29 anantaraM levi rnijagR^ihe tadarthaM mahAbhojyaM chakAra, tadA taiH sahAneke karasa nchAyinastadanyalokAshcha bhoktumupavivishuH| 
\p  
\v 30 tasmAt kAraNAt chaNDAlAnAM pApilokAnA ncha sa Nge yUyaM kuto bhaMgdhve pivatha cheti kathAM kathayitvA phirUshino.adhyApakAshcha tasya shiShyaiH saha vAgyuddhaM karttumArebhire| 
\p  
\v 31 tasmAd yIshustAn pratyavochad arogalokAnAM chikitsakena prayojanaM nAsti kintu sarogANAmeva| 
\p  
\v 32 ahaM dhArmmikAn AhvAtuM nAgatosmi kintu manaH parAvarttayituM pApina eva| 
\p  
\v 33 tataste prochuH, yohanaH phirUshinA ncha shiShyA vAraMvAram upavasanti prArthayante cha kintu tava shiShyAH kuto bhu njate pivanti cha? 
\p  
\v 34 tadA sa tAnAchakhyau vare sa Nge tiShThati varasya sakhigaNaM kimupavAsayituM shaknutha? 
\p  
\v 35 kintu yadA teShAM nikaTAd varo neShyate tadA te samupavatsyanti| 
\p  
\v 36 soparamapi dR^iShTAntaM kathayAmbabhUva purAtanavastre kopi nutanavastraM na sIvyati yatastena sevanena jIrNavastraM Chidyate, nUtanapurAtanavastrayo rmela ncha na bhavati| 
\p  
\v 37 purAtanyAM kutvAM kopi nutanaM drAkShArasaM na nidadhAti, yato navInadrAkShArasasya tejasA purAtanI kutU rvidIryyate tato drAkShArasaH patati kutUshcha nashyati| 
\p  
\v 38 tato heto rnUtanyAM kutvAM navInadrAkShArasaH nidhAtavyastenobhayasya rakShA bhavati| 
\p  
\v 39 apara ncha purAtanaM drAkShArasaM pItvA kopi nUtanaM na vA nChati, yataH sa vakti nUtanAt purAtanam prashastam| 
\c 6  
\p  
\v 1 achara ncha parvvaNo dvitIyadinAt paraM prathamavishrAmavAre shasyakShetreNa yIshorgamanakAle tasya shiShyAH kaNishaM ChittvA kareShu marddayitvA khAditumArebhire| 
\p  
\v 2 tasmAt kiyantaH phirUshinastAnavadan vishrAmavAre yat karmma na karttavyaM tat kutaH kurutha? 
\p  
\v 3 yIshuH pratyuvAcha dAyUd tasya sa Nginashcha kShudhArttAH kiM chakruH sa katham Ishvarasya mandiraM pravishya 
\p  
\v 4 ye darshanIyAH pUpA yAjakAn vinAnyasya kasyApyabhojanIyAstAnAnIya svayaM bubhaje sa Ngibhyopi dadau tat kiM yuShmAbhiH kadApi nApAThi? 
\p  
\v 5 pashchAt sa tAnavadat manujasuto vishrAmavArasyApi prabhu rbhavati| 
\p  
\v 6 anantaram anyavishrAmavAre sa bhajanagehaM pravishya samupadishati| tadA tatsthAne shuShkadakShiNakara ekaH pumAn upatasthivAn| 
\p  
\v 7 tasmAd adhyApakAH phirUshinashcha tasmin doShamAropayituM sa vishrAmavAre tasya svAsthyaM karoti naveti pratIkShitumArebhire| 
\p  
\v 8 tadA yIshusteShAM chintAM viditvA taM shuShkakaraM pumAMsaM provAcha, tvamutthAya madhyasthAne tiShTha| 
\p  
\v 9 tasmAt tasmin utthitavati yIshustAn vyAjahAra, yuShmAn imAM kathAM pR^ichChAmi, vishrAmavAre hitam ahitaM vA, prANarakShaNaM prANanAshanaM vA, eteShAM kiM karmmakaraNIyam? 
\p  
\v 10 pashchAt chaturdikShu sarvvAn vilokya taM mAnavaM babhAShe, nijakaraM prasAraya; tatastena tathA kR^ita itarakaravat tasya hastaH svasthobhavat| 
\p  
\v 11 tasmAt te prachaNDakopAnvitA yIshuM kiM kariShyantIti parasparaM pramantritAH| 
\p  
\v 12 tataH paraM sa parvvatamAruhyeshvaramuddishya prArthayamAnaH kR^itsnAM rAtriM yApitavAn| 
\p  
\v 13 atha dine sati sa sarvvAn shiShyAn AhUtavAn teShAM madhye 
\p  
\v 14 pitaranAmnA khyAtaH shimon tasya bhrAtA Andriyashcha yAkUb yohan cha philip barthalamayashcha 
\p  
\v 15 mathiH thomA AlphIyasya putro yAkUb jvalantanAmnA khyAtaH shimon 
\p  
\v 16 cha yAkUbo bhrAtA yihUdAshcha taM yaH parakareShu samarpayiShyati sa IShkarIyotIyayihUdAshchaitAn dvAdasha janAn manonItAn kR^itvA sa jagrAha tathA prerita iti teShAM nAma chakAra| 
\p  
\v 17 tataH paraM sa taiH saha parvvatAdavaruhya upatyakAyAM tasthau tatastasya shiShyasa Ngho yihUdAdeshAd yirUshAlamashcha soraH sIdonashcha jaladhe rodhaso jananihAshcha etya tasya kathAshravaNArthaM rogamuktyartha ncha tasya samIpe tasthuH| 
\p  
\v 18 amedhyabhUtagrastAshcha tannikaTamAgatya svAsthyaM prApuH| 
\p  
\v 19 sarvveShAM svAsthyakaraNaprabhAvasya prakAshitatvAt sarvve lokA etya taM spraShTuM yetire| 
\p  
\v 20 pashchAt sa shiShyAn prati dR^iShTiM kutvA jagAda, he daridrA yUyaM dhanyA yata IshvarIye rAjye vo.adhikArosti| 
\p  
\v 21 he adhunA kShudhitalokA yUyaM dhanyA yato yUyaM tarpsyatha; he iha rodino janA yUyaM dhanyA yato yUyaM hasiShyatha| 
\p  
\v 22 yadA lokA manuShyasUno rnAmaheto ryuShmAn R^iृtIyiShyante pR^ithak kR^itvA nindiShyanti, adhamAniva yuShmAn svasamIpAd dUrIkariShyanti cha tadA yUyaM dhanyAH| 
\p  
\v 23 svarge yuShmAkaM yatheShTaM phalaM bhaviShyati, etadarthaM tasmin dine prollasata Anandena nR^ityata cha, teShAM pUrvvapuruShAshcha bhaviShyadvAdinaH prati tathaiva vyavAharan| 
\p  
\v 24 kintu hA hA dhanavanto yUyaM sukhaM prApnuta| hanta paritR^iptA yUyaM kShudhitA bhaviShyatha; 
\p  
\v 25 iha hasanto yUyaM vata yuShmAbhiH shochitavyaM roditavya ncha| 
\p  
\v 26 sarvvailAkai ryuShmAkaM sukhyAtau kR^itAyAM yuShmAkaM durgati rbhaviShyati yuShmAkaM pUrvvapuruShA mR^iShAbhaviShyadvAdinaH prati tadvat kR^itavantaH| 
\p  
\v 27 he shrotAro yuShmabhyamahaM kathayAmi, yUyaM shatruShu prIyadhvaM ye cha yuShmAn dviShanti teShAmapi hitaM kuruta| 
\p  
\v 28 ye cha yuShmAn shapanti tebhya AshiShaM datta ye cha yuShmAn avamanyante teShAM ma NgalaM prArthayadhvaM| 
\p  
\v 29 yadi kashchit tava kapole chapeTAghAtaM karoti tarhi taM prati kapolam anyaM parAvarttya sammukhIkuru punashcha yadi kashchit tava gAtrIyavastraM harati tarhi taM paridheyavastram api grahItuM mA vAraya| 
\p  
\v 30 yastvAM yAchate tasmai dehi, yashcha tava sampattiM harati taM mA yAchasva| 
\p  
\v 31 parebhyaH svAn prati yathAcharaNam apekShadhve parAn prati yUyamapi tathAcharata| 
\p  
\v 32 ye janA yuShmAsu prIyante kevalaM teShu prIyamANeShu yuShmAkaM kiM phalaM? pApilokA api sveShu prIyamANeShu prIyante| 
\p  
\v 33 yadi hitakAriNa eva hitaM kurutha tarhi yuShmAkaM kiM phalaM? pApilokA api tathA kurvvanti| 
\p  
\v 34 yebhya R^iNaparishodhasya prAptipratyAshAste kevalaM teShu R^iNe samarpite yuShmAkaM kiM phalaM? punaH prAptyAshayA pApIlokA api pApijaneShu R^iNam arpayanti| 
\p  
\v 35 ato yUyaM ripuShvapi prIyadhvaM, parahitaM kuruta cha; punaH prAptyAshAM tyaktvA R^iNamarpayata, tathA kR^ite yuShmAkaM mahAphalaM bhaviShyati, yUya ncha sarvvapradhAnasya santAnA iti khyAtiM prApsyatha, yato yuShmAkaM pitA kR^itaghnAnAM durvTattAnA ncha hitamAcharati| 
\p  
\v 36 ata eva sa yathA dayAlu ryUyamapi tAdR^ishA dayAlavo bhavata| 
\p  
\v 37 apara ncha parAn doShiNo mA kuruta tasmAd yUyaM doShIkR^itA na bhaviShyatha; adaNDyAn mA daNDayata tasmAd yUyamapi daNDaM na prApsyatha; pareShAM doShAn kShamadhvaM tasmAd yuShmAkamapi doShAH kShamiShyante| 
\p  
\v 38 dAnAnidatta tasmAd yUyaM dAnAni prApsyatha, vara ncha lokAH parimANapAtraM pradalayya sa nchAlya pro nchAlya paripUryya yuShmAkaM kroDeShu samarpayiShyanti; yUyaM yena parimANena parimAtha tenaiva parimANena yuShmatkR^ite parimAsyate| 
\p  
\v 39 atha sa tebhyo dR^iShTAntakathAmakathayat, andho janaH kimandhaM panthAnaM darshayituM shaknoti? tasmAd ubhAvapi kiM gartte na patiShyataH? 
\p  
\v 40 guroH shiShyo na shreShThaH kintu shiShye siddhe sati sa gurutulyo bhavituM shaknoti| 
\p  
\v 41 apara ncha tvaM svachakShuुShi nAsAm adR^iShTvA tava bhrAtushchakShuShi yattR^iNamasti tadeva kutaH pashyami? 
\p  
\v 42 svachakShuShi yA nAsA vidyate tAm aj nAtvA, bhrAtastava netrAt tR^iNaM bahiH karomIti vAkyaM bhrAtaraM kathaM vaktuM shaknoShi? he kapaTin pUrvvaM svanayanAt nAsAM bahiH kuru tato bhrAtushchakShuShastR^iNaM bahiH karttuM sudR^iShTiM prApsyasi| 
\p  
\v 43 anya ncha uttamastaruH kadApi phalamanuttamaM na phalati, anuttamatarushcha phalamuttamaM na phalati kAraNAdataH phalaistaravo j nAyante| 
\p  
\v 44 kaNTakipAdapAt kopi uDumbaraphalAni na pAtayati tathA shR^igAlakolivR^ikShAdapi kopi drAkShAphalaM na pAtayati| 
\p  
\v 45 tadvat sAdhuloko.antaHkaraNarUpAt subhANDAgArAd uttamAni dravyANi bahiH karoti, duShTo lokashchAntaHkaraNarUpAt kubhANDAgArAt kutsitAni dravyANi nirgamayati yato.antaHkaraNAnAM pUrNabhAvAnurUpANi vachAMsi mukhAnnirgachChanti| 
\p  
\v 46 apara ncha mamAj nAnurUpaM nAcharitvA kuto mAM prabho prabho iti vadatha? 
\p  
\v 47 yaH kashchin mama nikaTam Agatya mama kathA nishamya tadanurUpaM karmma karoti sa kasya sadR^isho bhavati tadahaM yuShmAn j nAाpayAmi| 
\p  
\v 48 yo jano gabhIraM khanitvA pAShANasthale bhittiM nirmmAya svagR^ihaM rachayati tena saha tasyopamA bhavati; yata AplAvijalametya tasya mUle vegena vahadapi tadgehaM lADayituM na shaknoti yatastasya bhittiH pAShANopari tiShThati| 
\p  
\v 49 kintu yaH kashchin mama kathAH shrutvA tadanurUpaM nAcharati sa bhittiM vinA mR^iृdupari gR^ihanirmmAtrA samAno bhavati; yata AplAvijalamAgatya vegena yadA vahati tadA tadgR^ihaM patati tasya mahat patanaM jAyate| 
\c 7  
\p  
\v 1 tataH paraM sa lokAnAM karNagochare tAn sarvvAn upadeshAn samApya yadA kapharnAhUmpuraM pravishati 
\p  
\v 2 tadA shatasenApateH priyadAsa eko mR^itakalpaH pIDita AsIt| 
\p  
\v 3 ataH senApati ryIsho rvArttAM nishamya dAsasyArogyakaraNAya tasyAgamanArthaM vinayakaraNAya yihUdIyAn kiyataH prAchaH preShayAmAsa| 
\p  
\v 4 te yIshorantikaM gatvA vinayAtishayaM vaktumArebhire, sa senApati rbhavatonugrahaM prAptum arhati| 
\p  
\v 5 yataH sosmajjAtIyeShu lokeShu prIyate tathAsmatkR^ite bhajanagehaM nirmmitavAn| 
\p  
\v 6 tasmAd yIshustaiH saha gatvA niveshanasya samIpaM prApa, tadA sa shatasenApati rvakShyamANavAkyaM taM vaktuM bandhUn prAhiNot| he prabho svayaM shramo na karttavyo yad bhavatA madgehamadhye pAdArpaNaM kriyeta tadapyahaM nArhAmi, 
\p  
\v 7 ki nchAhaM bhavatsamIpaM yAtumapi nAtmAnaM yogyaM buddhavAn, tato bhavAn vAkyamAtraM vadatu tenaiva mama dAsaH svastho bhaviShyati| 
\p  
\v 8 yasmAd ahaM parAdhInopi mamAdhInA yAH senAH santi tAsAm ekajanaM prati yAhIti mayA prokte sa yAti; tadanyaM prati AyAhIti prokte sa AyAti; tathA nijadAsaM prati etat kurvviti prokte sa tadeva karoti| 
\p  
\v 9 yIshuridaM vAkyaM shrutvA vismayaM yayau, mukhaM parAvartya pashchAdvarttino lokAn babhAShe cha, yuShmAnahaM vadAmi isrAyelo vaMshamadhyepi vishvAsamIdR^ishaM na prApnavaM| 
\p  
\v 10 tataste preShitA gR^ihaM gatvA taM pIDitaM dAsaM svasthaM dadR^ishuH| 
\p  
\v 11 pare.ahani sa nAyInAkhyaM nagaraM jagAma tasyAneke shiShyA anye cha lokAstena sArddhaM yayuH| 
\p  
\v 12 teShu tannagarasya dvArasannidhiM prApteShu kiyanto lokA ekaM mR^itamanujaM vahanto nagarasya bahiryAnti, sa tanmAturekaputrastanmAtA cha vidhavA; tayA sArddhaM tannagarIyA bahavo lokA Asan| 
\p  
\v 13 prabhustAM vilokya sAnukampaH kathayAmAsa, mA rodIH| sa samIpamitvA khaTvAM pasparsha tasmAd vAhakAH sthagitAstamyuH; 
\p  
\v 14 tadA sa uvAcha he yuvamanuShya tvamuttiShTha, tvAmaham Aj nApayAmi| 
\p  
\v 15 tasmAt sa mR^ito janastatkShaNamutthAya kathAM prakathitaH; tato yIshustasya mAtari taM samarpayAmAsa| 
\p  
\v 16 tasmAt sarvve lokAH shasha Nkire; eko mahAbhaviShyadvAdI madhye.asmAkam samudait, Ishvarashcha svalokAnanvagR^ihlAt kathAmimAM kathayitvA IshvaraM dhanyaM jagaduH| 
\p  
\v 17 tataH paraM samastaM yihUdAdeshaM tasya chaturdiksthadesha ncha tasyaitatkIrtti rvyAnashe| 
\p  
\v 18 tataH paraM yohanaH shiShyeShu taM tadvR^ittAntaM j nApitavatsu 
\p  
\v 19 sa svashiShyANAM dvau janAvAhUya yIshuM prati vakShyamANaM vAkyaM vaktuM preShayAmAsa, yasyAgamanam apekShya tiShThAmo vayaM kiM sa eva janastvaM? kiM vayamanyamapekShya sthAsyAmaH? 
\p  
\v 20 pashchAttau mAnavau gatvA kathayAmAsatuH, yasyAgamanam apekShya tiShThAmo vayaM, kiM saeva janastvaM? kiM vayamanyamapekShya sthAsyAmaH? kathAmimAM tubhyaM kathayituM yohan majjaka AvAM preShitavAn| 
\p  
\v 21 tasmin daNDe yIshUrogiNo mahAvyAdhimato duShTabhUtagrastAMshcha bahUn svasthAn kR^itvA, anekAndhebhyashchakShuMShi dattvA pratyuvAcha, 
\p  
\v 22 yuvAM vrajatam andhA netrANi kha njAshcharaNAni cha prApnuvanti, kuShThinaH pariShkriyante, badhirAH shravaNAni mR^itAshcha jIvanAni prApnuvanti, daridrANAM samIpeShu susaMvAdaH prachAryyate, yaM prati vighnasvarUpohaM na bhavAmi sa dhanyaH, 
\p  
\v 23 etAni yAni pashyathaH shR^iNuthashcha tAni yohanaM j nApayatam| 
\p  
\v 24 tayo rdUtayo rgatayoH sato ryohani sa lokAn vaktumupachakrame, yUyaM madhyeprAntaraM kiM draShTuM niragamata? kiM vAyunA kampitaM naDaM? 
\p  
\v 25 yUyaM kiM draShTuM niragamata? kiM sUkShmavastraparidhAyinaM kamapi naraM? kintu ye sUkShmamR^iduvastrANi paridadhati sUttamAni dravyANi bhu njate cha te rAjadhAnIShu tiShThanti| 
\p  
\v 26 tarhi yUyaM kiM draShTuM niragamata? kimekaM bhaviShyadvAdinaM? tadeva satyaM kintu sa pumAn bhaviShyadvAdinopi shreShTha ityahaM yuShmAn vadAmi; 
\p  
\v 27 pashya svakIyadUtantu tavAgra preShayAmyahaM| gatvA tvadIyamArgantu sa hi pariShkariShyati| yadarthe lipiriyam Aste sa eva yohan| 
\p  
\v 28 ato yuShmAnahaM vadAmi striyA garbbhajAtAnAM bhaviShyadvAdinAM madhye yohano majjakAt shreShThaH kopi nAsti, tatrApi Ishvarasya rAjye yaH sarvvasmAt kShudraH sa yohanopi shreShThaH| 
\p  
\v 29 apara ncha sarvve lokAH karama nchAyinashcha tasya vAkyAni shrutvA yohanA majjanena majjitAH parameshvaraM nirdoShaM menire| 
\p  
\v 30 kintu phirUshino vyavasthApakAshcha tena na majjitAH svAn pratIshvarasyopadeshaM niShphalam akurvvan| 
\p  
\v 31 atha prabhuH kathayAmAsa, idAnIntanajanAn kenopamAmi? te kasya sadR^ishAH? 
\p  
\v 32 ye bAlakA vipaNyAm upavishya parasparam AhUya vAkyamidaM vadanti, vayaM yuShmAkaM nikaTe vaMshIravAdiShma, kintu yUyaM nAnarttiShTa, vayaM yuShmAkaM nikaTa arodiShma, kintu yuyaM na vyalapiShTa, bAlakairetAdR^ishaisteShAm upamA bhavati| 
\p  
\v 33 yato yohan majjaka Agatya pUpaM nAkhAdat drAkShArasa ncha nApivat tasmAd yUyaM vadatha, bhUtagrastoyam| 
\p  
\v 34 tataH paraM mAnavasuta AgatyAkhAdadapiva ncha tasmAd yUyaM vadatha, khAdakaH surApashchANDAlapApinAM bandhureko jano dR^ishyatAm| 
\p  
\v 35 kintu j nAnino j nAnaM nirdoShaM viduH| 
\p  
\v 36 pashchAdekaH phirUshI yIshuM bhojanAya nyamantrayat tataH sa tasya gR^ihaM gatvA bhoktumupaviShTaH| 
\p  
\v 37 etarhi tatphirUshino gR^ihe yIshu rbhektum upAvekShIt tachChrutvA tannagaravAsinI kApi duShTA nArI pANDaraprastarasya sampuTake sugandhitailam AnIya 
\p  
\v 38 tasya pashchAt pAdayoH sannidhau tasyau rudatI cha netrAmbubhistasya charaNau prakShAlya nijakachairamArkShIt, tatastasya charaNau chumbitvA tena sugandhitailena mamarda| 
\p  
\v 39 tasmAt sa nimantrayitA phirUshI manasA chintayAmAsa, yadyayaM bhaviShyadvAdI bhavet tarhi enaM spR^ishati yA strI sA kA kIdR^ishI cheti j nAtuM shaknuyAt yataH sA duShTA| 
\p  
\v 40 tadA yAshustaM jagAda, he shimon tvAM prati mama ki nchid vaktavyamasti; tasmAt sa babhAShe, he guro tad vadatu| 
\p  
\v 41 ekottamarNasya dvAvadhamarNAvAstAM, tayorekaH pa nchashatAni mudrApAdAn aparashcha pa nchAshat mudrApAdAn dhArayAmAsa| 
\p  
\v 42 tadanantaraM tayoH shodhyAbhAvAt sa uttamarNastayo rR^iNe chakShame; tasmAt tayordvayoH kastasmin preShyate bahu? tad brUhi| 
\p  
\v 43 shimon pratyuvAcha, mayA budhyate yasyAdhikam R^iNaM chakShame sa iti; tato yIshustaM vyAjahAra, tvaM yathArthaM vyachArayaH| 
\p  
\v 44 atha tAM nArIM prati vyAghuThya shimonamavochat, strImimAM pashyasi? tava gR^ihe mayyAgate tvaM pAdaprakShAlanArthaM jalaM nAdAH kintu yoShideShA nayanajalai rmama pAdau prakShAlya keshairamArkShIt| 
\p  
\v 45 tvaM mAM nAchumbIH kintu yoShideShA svIyAgamanAdArabhya madIyapAdau chumbituM na vyaraMsta| 
\p  
\v 46 tva ncha madIyottamA Nge ki nchidapi tailaM nAmardIH kintu yoShideShA mama charaNau sugandhitailenAmarddIt| 
\p  
\v 47 atastvAM vyAharAmi, etasyA bahu pApamakShamyata tato bahu prIyate kintu yasyAlpapApaM kShamyate solpaM prIyate| 
\p  
\v 48 tataH paraM sa tAM babhAShe, tvadIyaM pApamakShamyata| 
\p  
\v 49 tadA tena sArddhaM ye bhoktum upavivishuste parasparaM vaktumArebhire, ayaM pApaM kShamate ka eShaH? 
\p  
\v 50 kintu sa tAM nArIM jagAda, tava vishvAsastvAM paryyatrAsta tvaM kShemeNa vraja| 
\c 8  
\p  
\v 1 apara ncha yIshu rdvAdashabhiH shiShyaiH sArddhaM nAnAnagareShu nAnAgrAmeShu cha gachChan ishvarIyarAjatvasya susaMvAdaM prachArayituM prArebhe| 
\p  
\v 2 tadA yasyAH sapta bhUtA niragachChan sA magdalInIti vikhyAtA mariyam herodrAjasya gR^ihAdhipateH hoShe rbhAryyA yohanA shUshAnA 
\p  
\v 3 prabhR^itayo yA bahvyaH striyaH duShTabhUtebhyo rogebhyashcha muktAH satyo nijavibhUtI rvyayitvA tamasevanta, tAH sarvvAstena sArddham Asan| 
\p  
\v 4 anantaraM nAnAnagarebhyo bahavo lokA Agatya tasya samIpe.amilan, tadA sa tebhya ekAM dR^iShTAntakathAM kathayAmAsa| ekaH kR^iShIbalo bIjAni vaptuM bahirjagAma, 
\p  
\v 5 tato vapanakAle katipayAni bIjAni mArgapArshve petuH, tatastAni padatalai rdalitAni pakShibhi rbhakShitAni cha| 
\p  
\v 6 katipayAni bIjAni pAShANasthale patitAni yadyapi tAnya NkuritAni tathApi rasAbhAvAt shushuShuH| 
\p  
\v 7 katipayAni bIjAni kaNTakivanamadhye patitAni tataH kaNTakivanAni saMvR^iddhya tAni jagrasuH| 
\p  
\v 8 tadanyAni katipayabIjAni cha bhUmyAmuttamAyAM petustatastAnya NkurayitvA shataguNAni phalAni pheluH| sa imA kathAM kathayitvA prochchaiH provAcha, yasya shrotuM shrotre staH sa shR^iNotu| 
\p  
\v 9 tataH paraM shiShyAstaM paprachChurasya dR^iShTAntasya kiM tAtparyyaM? 
\p  
\v 10 tataH sa vyAjahAra, IshvarIyarAjyasya guhyAni j nAtuM yuShmabhyamadhikAro dIyate kintvanye yathA dR^iShTvApi na pashyanti shrutvApi ma budhyante cha tadarthaM teShAM purastAt tAH sarvvAH kathA dR^iShTAntena kathyante| 
\p  
\v 11 dR^iShTAntasyAsyAbhiprAyaH, IshvarIyakathA bIjasvarUpA| 
\p  
\v 12 ye kathAmAtraM shR^iNvanti kintu pashchAd vishvasya yathA paritrANaM na prApnuvanti tadAshayena shaitAnetya hR^idayAtR^i tAM kathAm apaharati ta eva mArgapArshvasthabhUmisvarUpAH| 
\p  
\v 13 ye kathaM shrutvA sAnandaM gR^ihlanti kintvabaddhamUlatvAt svalpakAlamAtraM pratItya parIkShAkAle bhrashyanti taeva pAShANabhUmisvarUpAH| 
\p  
\v 14 ye kathAM shrutvA yAnti viShayachintAyAM dhanalobhena eेhikasukhe cha majjanta upayuktaphalAni na phalanti ta evoptabIjakaNTakibhUsvarUpAH| 
\p  
\v 15 kintu ye shrutvA saralaiH shuddhaishchAntaHkaraNaiH kathAM gR^ihlanti dhairyyam avalambya phalAnyutpAdayanti cha ta evottamamR^itsvarUpAH| 
\p  
\v 16 apara ncha pradIpaM prajvAlya kopi pAtreNa nAchChAdayati tathA khaTvAdhopi na sthApayati, kintu dIpAdhAroparyyeva sthApayati, tasmAt praveshakA dIptiM pashyanti| 
\p  
\v 17 yanna prakAshayiShyate tAdR^ig aprakAshitaM vastu kimapi nAsti yachcha na suvyaktaM prachArayiShyate tAdR^ig gR^iptaM vastu kimapi nAsti| 
\p  
\v 18 ato yUyaM kena prakAreNa shR^iNutha tatra sAvadhAnA bhavata, yasya samIpe barddhate tasmai punardAsyate kintu yasyAshraye na barddhate tasya yadyadasti tadapi tasmAt neShyate| 
\p  
\v 19 apara ncha yIsho rmAtA bhrAtarashcha tasya samIpaM jigamiShavaH 
\p  
\v 20 kintu janatAsambAdhAt tatsannidhiM prAptuM na shekuH| tatpashchAt tava mAtA bhrAtarashcha tvAM sAkShAt chikIrShanto bahistiShThanatIti vArttAyAM tasmai kathitAyAM 
\p  
\v 21 sa pratyuvAcha; ye janA Ishvarasya kathAM shrutvA tadanurUpamAcharanti taeva mama mAtA bhrAtarashcha| 
\p  
\v 22 anantaraM ekadA yIshuH shiShyaiH sArddhaM nAvamAruhya jagAda, AyAta vayaM hradasya pAraM yAmaH, tataste jagmuH| 
\p  
\v 23 teShu naukAM vAhayatsu sa nidadrau; 
\p  
\v 24 athAkasmAt prabalajha nbhshagamAd hrade naukAyAM tara NgairAchChannAyAM vipat tAn jagrAsa|tasmAd yIshorantikaM gatvA he guro he guro prANA no yAntIti gaditvA taM jAgarayAmbabhUvuH|tadA sa utthAya vAyuM tara NgAMshcha tarjayAmAsa tasmAdubhau nivR^itya sthirau babhUvatuH| 
\p  
\v 25 sa tAn babhAShe yuShmAkaM vishvAsaH ka? tasmAtte bhItA vismitAshcha parasparaM jagaduH, aho kIdR^igayaM manujaH pavanaM pAnIya nchAdishati tadubhayaM tadAdeshaM vahati| 
\p  
\v 26 tataH paraM gAlIlpradeshasya sammukhasthagiderIyapradeshe naukAyAM lagantyAM taTe.avarohamAvAd 
\p  
\v 27 bahutithakAlaM bhUtagrasta eko mAnuShaH purAdAgatya taM sAkShAchchakAra| sa manuSho vAso na paridadhat gR^ihe cha na vasan kevalaM shmashAnam adhyuvAsa| 
\p  
\v 28 sa yIshuM dR^iShTvaiva chIchChabdaM chakAra tasya sammukhe patitvA prochchairjagAda cha, he sarvvapradhAneshvarasya putra, mayA saha tava kaH sambandhaH? tvayi vinayaM karomi mAM mA yAtaya| 
\p  
\v 29 yataH sa taM mAnuShaM tyaktvA yAtum amedhyabhUtam Adidesha; sa bhUtastaM mAnuSham asakR^id dadhAra tasmAllokAH shR^i Nkhalena nigaDena cha babandhuH; sa tad bhaMktvA bhUtavashatvAt madhyeprAntaraM yayau| 
\p  
\v 30 anantaraM yIshustaM paprachCha tava kinnAma? sa uvAcha, mama nAma bAhino yato bahavo bhUtAstamAshishriyuH| 
\p  
\v 31 atha bhUtA vinayena jagaduH, gabhIraM garttaM gantuM mAj nApayAsmAn| 
\p  
\v 32 tadA parvvatopari varAhavrajashcharati tasmAd bhUtA vinayena prochuH, amuM varAhavrajam Ashrayitum asmAn anujAnIhi; tataH sonujaj nau| 
\p  
\v 33 tataH paraM bhUtAstaM mAnuShaM vihAya varAhavrajam AshishriyuH varAhavrajAshcha tatkShaNAt kaTakena dhAvanto hrade prANAn vijR^ihuH| 
\p  
\v 34 tad dR^iShTvA shUkararakShakAH palAyamAnA nagaraM grAma ncha gatvA tatsarvvavR^ittAntaM kathayAmAsuH| 
\p  
\v 35 tataH kiM vR^ittam etaddarshanArthaM lokA nirgatya yIshoH samIpaM yayuH, taM mAnuShaM tyaktabhUtaM parihitavastraM svasthamAnuShavad yIshoshcharaNasannidhau sUpavishantaM vilokya bibhyuH| 
\p  
\v 36 ye lokAstasya bhUtagrastasya svAsthyakaraNaM dadR^ishuste tebhyaH sarvvavR^ittAntaM kathayAmAsuH| 
\p  
\v 37 tadanantaraM tasya giderIyapradeshasya chaturdiksthA bahavo janA atitrastA vinayena taM jagaduH, bhavAn asmAkaM nikaTAd vrajatu tasmAt sa nAvamAruhya tato vyAghuTya jagAma| 
\p  
\v 38 tadAnIM tyaktabhUtamanujastena saha sthAtuM prArthayA nchakre 
\p  
\v 39 kintu tadartham IshvaraH kIdR^i NmahAkarmma kR^itavAn iti niveshanaM gatvA vij nApaya, yIshuH kathAmetAM kathayitvA taM visasarja| tataH sa vrajitvA yIshustadarthaM yanmahAkarmma chakAra tat purasya sarvvatra prakAshayituM prArebhe| 
\p  
\v 40 atha yIshau parAvR^ityAgate lokAstaM AdareNa jagR^ihu ryasmAtte sarvve tamapekShA nchakrire| 
\p  
\v 41 tadanantaraM yAyIrnAmno bhajanagehasyaikodhipa Agatya yIshoshcharaNayoH patitvA svaniveshanAgamanArthaM tasmin vinayaM chakAra, 
\p  
\v 42 yatastasya dvAdashavarShavayaskA kanyaikAsIt sA mR^itakalpAbhavat| tatastasya gamanakAle mArge lokAnAM mahAn samAgamo babhUva| 
\p  
\v 43 dvAdashavarShANi pradararogagrastA nAnA vaidyaishchikitsitA sarvvasvaM vyayitvApi svAsthyaM na prAptA yA yoShit sA yIshoH pashchAdAgatya tasya vastragranthiM pasparsha| 
\p  
\v 44 tasmAt tatkShaNAt tasyA raktasrAvo ruddhaH| 
\p  
\v 45 tadAnIM yIshuravadat kenAhaM spR^iShTaH? tato.anekairana NgIkR^ite pitarastasya sa NginashchAvadan, he guro lokA nikaTasthAH santastava dehe gharShayanti, tathApi kenAhaM spR^iShTa_iti bhavAn kutaH pR^ichChati? 
\p  
\v 46 yIshuH kathayAmAsa, kenApyahaM spR^iShTo, yato mattaH shakti rnirgateti mayA nishchitamaj nAyi| 
\p  
\v 47 tadA sA nArI svayaM na gupteti viditvA kampamAnA satI tasya sammukhe papAta; yena nimittena taM pasparsha sparshamAtrAchcha yena prakAreNa svasthAbhavat tat sarvvaM tasya sAkShAdAchakhyau| 
\p  
\v 48 tataH sa tAM jagAda he kanye susthirA bhava, tava vishvAsastvAM svasthAm akArShIt tvaM kShemeNa yAhi| 
\p  
\v 49 yIshoretadvAkyavadanakAle tasyAdhipate rniveshanAt kashchilloka Agatya taM babhAShe, tava kanyA mR^itA guruM mA klishAna| 
\p  
\v 50 kintu yIshustadAkarNyAdhipatiM vyAjahAra, mA bhaiShIH kevalaM vishvasihi tasmAt sA jIviShyati| 
\p  
\v 51 atha tasya niveshane prApte sa pitaraM yohanaM yAkUba ncha kanyAyA mAtaraM pitara ncha vinA, anyaM ka nchana praveShTuM vArayAmAsa| 
\p  
\v 52 apara ncha ye rudanti vilapanti cha tAn sarvvAn janAn uvAcha, yUyaM mA rodiShTa kanyA na mR^itA nidrAti| 
\p  
\v 53 kintu sA nishchitaM mR^iteti j nAtvA te tamupajahasuH| 
\p  
\v 54 pashchAt sa sarvvAn bahiH kR^itvA kanyAyAH karau dhR^itvAjuhuve, he kanye tvamuttiShTha, 
\p  
\v 55 tasmAt tasyAH prANeShu punarAgateShu sA tatkShaNAd uttasyau| tadAnIM tasyai ki nchid bhakShyaM dAtum Adidesha| 
\p  
\v 56 tatastasyAH pitarau vismayaM gatau kintu sa tAvAdidesha ghaTanAyA etasyAH kathAM kasmaichidapi mA kathayataM| 
\c 9  
\p  
\v 1 tataH paraM sa dvAdashashiShyAnAhUya bhUtAn tyAjayituM rogAn pratikarttu ncha tebhyaH shaktimAdhipatya ncha dadau| 
\p  
\v 2 apara ncha IshvarIyarAjyasya susaMvAdaM prakAshayitum rogiNAmArogyaM karttu ncha preraNakAle tAn jagAda| 
\p  
\v 3 yAtrArthaM yaShTi rvastrapuTakaM bhakShyaM mudrA dvitIyavastram, eShAM kimapi mA gR^ihlIta| 
\p  
\v 4 yUya ncha yanniveshanaM pravishatha nagaratyAgaparyyanataM tanniveshane tiShThata| 
\p  
\v 5 tatra yadi kasyachit purasya lokA yuShmAkamAtithyaM na kurvvanti tarhi tasmAnnagarAd gamanakAle teShAM viruddhaM sAkShyArthaM yuShmAkaM padadhUlIH sampAtayata| 
\p  
\v 6 atha te prasthAya sarvvatra susaMvAdaM prachArayituM pIDitAn svasthAn karttu ncha grAmeShu bhramituM prArebhire| 
\p  
\v 7 etarhi herod rAjA yIshoH sarvvakarmmaNAM vArttAM shrutvA bhR^ishamudvivije 
\p  
\v 8 yataH kechidUchuryohan shmashAnAdudatiShThat| kechidUchuH, eliyo darshanaM dattavAn; evamanyalokA UchuH pUrvvIyaH kashchid bhaviShyadvAdI samutthitaH| 
\p  
\v 9 kintu heroduvAcha yohanaH shiro.ahamaChinadam idAnIM yasyedR^ikkarmmaNAM vArttAM prApnomi sa kaH? atha sa taM draShTum aichChat| 
\p  
\v 10 anantaraM preritAH pratyAgatya yAni yAni karmmANi chakrustAni yIshave kathayAmAsuH tataH sa tAn baitsaidAnAmakanagarasya vijanaM sthAnaM nItvA guptaM jagAma| 
\p  
\v 11 pashchAl lokAstad viditvA tasya pashchAd yayuH; tataH sa tAn nayan IshvarIyarAjyasya prasa NgamuktavAn, yeShAM chikitsayA prayojanam AsIt tAn svasthAn chakAra cha| 
\p  
\v 12 apara ncha divAvasanne sati dvAdashashiShyA yIshorantikam etya kathayAmAsuH, vayamatra prAntarasthAne tiShThAmaH, tato nagarANi grAmANi gatvA vAsasthAnAni prApya bhakShyadravyANi kretuM jananivahaM bhavAn visR^ijatu| 
\p  
\v 13 tadA sa uvAcha, yUyameva tAn bhejayadhvaM; tataste prochurasmAkaM nikaTe kevalaM pa ncha pUpA dvau matsyau cha vidyante, ataeva sthAnAntaram itvA nimittameteShAM bhakShyadravyeShu na krIteShu na bhavati| 
\p  
\v 14 tatra prAyeNa pa nchasahasrANi puruShA Asan| 
\p  
\v 15 tadA sa shiShyAn jagAda pa nchAshat pa nchAshajjanaiH paMktIkR^itya tAnupaveshayata, tasmAt te tadanusAreNa sarvvalokAnupaveshayApAsuH| 
\p  
\v 16 tataH sa tAn pa ncha pUpAn mInadvaya ncha gR^ihItvA svargaM vilokyeshvaraguNAn kIrttayA nchakre bha NktA cha lokebhyaH pariveShaNArthaM shiShyeShu samarpayAmbabhUva| 
\p  
\v 17 tataH sarvve bhuktvA tR^iptiM gatA avashiShTAnA ncha dvAdasha DallakAn saMjagR^ihuH| 
\p  
\v 18 athaikadA nirjane shiShyaiH saha prArthanAkAle tAn paprachCha, lokA mAM kaM vadanti? 
\p  
\v 19 tataste prAchuH, tvAM yohanmajjakaM vadanti; kechit tvAm eliyaM vadanti, pUrvvakAlikaH kashchid bhaviShyadvAdI shmashAnAd udatiShThad ityapi kechid vadanti| 
\p  
\v 20 tadA sa uvAcha, yUyaM mAM kaM vadatha? tataH pitara uktavAn tvam IshvarAbhiShiktaH puruShaH| 
\p  
\v 21 tadA sa tAn dR^iDhamAdidesha, kathAmetAM kasmaichidapi mA kathayata| 
\p  
\v 22 sa punaruvAcha, manuShyaputreNa vahuyAtanA bhoktavyAH prAchInalokaiH pradhAnayAjakairadhyApakaishcha sovaj nAya hantavyaH kintu tR^itIyadivase shmashAnAt tenotthAtavyam| 
\p  
\v 23 aparaM sa sarvvAnuvAcha, kashchid yadi mama pashchAd gantuM vA nChati tarhi sa svaM dAmyatu, dine dine krushaM gR^ihItvA cha mama pashchAdAgachChatu| 
\p  
\v 24 yato yaH kashchit svaprANAn rirakShiShati sa tAn hArayiShyati, yaH kashchin madarthaM prANAn hArayiShyati sa tAn rakShiShyati| 
\p  
\v 25 kashchid yadi sarvvaM jagat prApnoti kintu svaprANAn hArayati svayaM vinashyati cha tarhi tasya ko lAbhaH? 
\p  
\v 26 puna ryaH kashchin mAM mama vAkyaM vA lajjAspadaM jAnAti manuShyaputro yadA svasya pitushcha pavitrANAM dUtAnA ncha tejobhiH pariveShTita AgamiShyati tadA sopi taM lajjAspadaM j nAsyati| 
\p  
\v 27 kintu yuShmAnahaM yathArthaM vadAmi, IshvarIyarAjatvaM na dR^iShTavA mR^ityuM nAsvAdiShyante, etAdR^ishAH kiyanto lokA atra sthane.api daNDAyamAnAH santi| 
\p  
\v 28 etadAkhyAnakathanAt paraM prAyeNAShTasu dineShu gateShu sa pitaraM yohanaM yAkUba ncha gR^ihItvA prArthayituM parvvatamekaM samAruroha| 
\p  
\v 29 atha tasya prArthanakAle tasya mukhAkR^itiranyarUpA jAtA, tadIyaM vastramujjvalashuklaM jAtaM| 
\p  
\v 30 apara ncha mUsA eliyashchobhau tejasvinau dR^iShTau 
\p  
\v 31 tau tena yirUshAlampure yo mR^ityuH sAdhiShyate tadIyAM kathAM tena sArddhaM kathayitum ArebhAte| 
\p  
\v 32 tadA pitarAdayaH svasya sa Ngino nidrayAkR^iShTA Asan kintu jAgaritvA tasya tejastena sArddham uttiShThantau janau cha dadR^ishuH| 
\p  
\v 33 atha tayorubhayo rgamanakAle pitaro yIshuM babhAShe, he guro.asmAkaM sthAne.asmin sthitiH shubhA, tata ekA tvadarthA, ekA mUsArthA, ekA eliyArthA, iti tisraH kuTyosmAbhi rnirmmIyantAM, imAM kathAM sa na vivichya kathayAmAsa| 
\p  
\v 34 apara ncha tadvAkyavadanakAle payoda eka Agatya teShAmupari ChAyAM chakAra, tatastanmadhye tayoH praveshAt te shasha Nkire| 
\p  
\v 35 tadA tasmAt payodAd iyamAkAshIyA vANI nirjagAma, mamAyaM priyaH putra etasya kathAyAM mano nidhatta| 
\p  
\v 36 iti shabde jAte te yIshumekAkinaM dadR^ishuH kintu te tadAnIM tasya darshanasya vAchamekAmapi noktvA manaHsu sthApayAmAsuH| 
\p  
\v 37 pare.ahani teShu tasmAchChailAd avarUDheShu taM sAkShAt karttuM bahavo lokA AjagmuH| 
\p  
\v 38 teShAM madhyAd eko jana uchchairuvAcha, he guro ahaM vinayaM karomi mama putraM prati kR^ipAdR^iShTiM karotu, mama sa evaikaH putraH| 
\p  
\v 39 bhUtena dhR^itaH san saM prasabhaM chIchChabdaM karoti tanmukhAt pheNA nirgachChanti cha, bhUta itthaM vidAryya kliShTvA prAyashastaM na tyajati| 
\p  
\v 40 tasmAt taM bhUtaM tyAjayituM tava shiShyasamIpe nyavedayaM kintu te na shekuH| 
\p  
\v 41 tadA yIshuravAdIt, re AvishvAsin vipathagAmin vaMsha katikAlAn yuShmAbhiH saha sthAsyAmyahaM yuShmAkam AcharaNAni cha sahiShye? tava putramihAnaya| 
\p  
\v 42 tatastasminnAgatamAtre bhUtastaM bhUmau pAtayitvA vidadAra; tadA yIshustamamedhyaM bhUtaM tarjayitvA bAlakaM svasthaM kR^itvA tasya pitari samarpayAmAsa| 
\p  
\v 43 Ishvarasya mahAshaktim imAM vilokya sarvve chamachchakruH; itthaM yIshoH sarvvAbhiH kriyAbhiH sarvvairlokairAshcharyye manyamAne sati sa shiShyAn babhAShe, 
\p  
\v 44 katheyaM yuShmAkaM karNeShu pravishatu, manuShyaputro manuShyANAM kareShu samarpayiShyate| 
\p  
\v 45 kintu te tAM kathAM na bubudhire, spaShTatvAbhAvAt tasyA abhiprAyasteShAM bodhagamyo na babhUva; tasyA AshayaH ka ityapi te bhayAt praShTuM na shekuH| 
\p  
\v 46 tadanantaraM teShAM madhye kaH shreShThaH kathAmetAM gR^ihItvA te mitho vivAdaM chakruH| 
\p  
\v 47 tato yIshusteShAM manobhiprAyaM viditvA bAlakamekaM gR^ihItvA svasya nikaTe sthApayitvA tAn jagAda, 
\p  
\v 48 yo jano mama nAmnAsya bAlAsyAtithyaM vidadhAti sa mamAtithyaM vidadhAti, yashcha mamAtithyaM vidadhAti sa mama prerakasyAtithyaM vidadhAti, yuShmAkaM madhyeyaH svaM sarvvasmAt kShudraM jAnIte sa eva shreShTho bhaviShyati| 
\p  
\v 49 apara ncha yohan vyAjahAra he prabheा tava nAmnA bhUtAn tyAjayantaM mAnuSham ekaM dR^iShTavanto vayaM, kintvasmAkam apashchAd gAmitvAt taM nyaShedhAm| tadAnIM yIshuruvAcha, 
\p  
\v 50 taM mA niShedhata, yato yo janosmAkaM na vipakShaH sa evAsmAkaM sapakSho bhavati| 
\p  
\v 51 anantaraM tasyArohaNasamaya upasthite sa sthirachetA yirUshAlamaM prati yAtrAM karttuM nishchityAgre dUtAn preShayAmAsa| 
\p  
\v 52 tasmAt te gatvA tasya prayojanIyadravyANi saMgrahItuM shomiroNIyAnAM grAmaM pravivishuH| 
\p  
\v 53 kintu sa yirUshAlamaM nagaraM yAti tato heto rlokAstasyAtithyaM na chakruH| 
\p  
\v 54 ataeva yAkUbyohanau tasya shiShyau tad dR^iShTvA jagadatuH, he prabho eliyo yathA chakAra tathA vayamapi kiM gagaNAd Agantum etAn bhasmIkarttu ncha vahnimAj nApayAmaH? bhavAn kimichChati? 
\p  
\v 55 kintu sa mukhaM parAvartya tAn tarjayitvA gaditavAn yuShmAkaM manobhAvaH kaH, iti yUyaM na jAnItha| 
\p  
\v 56 manujasuto manujAnAM prANAn nAshayituM nAgachChat, kintu rakShitum AgachChat| pashchAd itaragrAmaM te yayuH| 
\p  
\v 57 tadanantaraM pathi gamanakAle jana ekastaM babhAShe, he prabho bhavAn yatra yAti bhavatA sahAhamapi tatra yAsyAmi| 
\p  
\v 58 tadAnIM yIshustamuvAcha, gomAyUnAM garttA Asate, vihAyasIyavihagAाnAM nIDAni cha santi, kintu mAnavatanayasya shiraH sthApayituM sthAnaM nAsti| 
\p  
\v 59 tataH paraM sa itarajanaM jagAda, tvaM mama pashchAd ehi; tataH sa uvAcha, he prabho pUrvvaM pitaraM shmashAne sthApayituM mAmAdishatu| 
\p  
\v 60 tadA yIshuruvAcha, mR^itA mR^itAn shmashAne sthApayantu kintu tvaM gatveshvarIyarAjyasya kathAM prachAraya| 
\p  
\v 61 tatonyaH kathayAmAsa, he prabho mayApi bhavataH pashchAd gaMsyate, kintu pUrvvaM mama niveshanasya parijanAnAm anumatiM grahItum ahamAdishyai bhavatA| 
\p  
\v 62 tadAnIM yIshustaM proktavAn, yo jano lA Ngale karamarpayitvA pashchAt pashyati sa IshvarIyarAjyaM nArhati| 
\c 10  
\p  
\v 1 tataH paraM prabhuraparAn saptatishiShyAn niyujya svayaM yAni nagarANi yAni sthAnAni cha gamiShyati tAni nagarANi tAni sthAnAni cha prati dvau dvau janau prahitavAn| 
\p  
\v 2 tebhyaH kathayAmAsa cha shasyAni bahUnIti satyaM kintu ChedakA alpe; tasmAddhetoH shasyakShetre ChedakAn aparAnapi preShayituM kShetrasvAminaM prArthayadhvaM| 
\p  
\v 3 yUyaM yAta, pashyata, vR^ikANAM madhye meShashAvakAniva yuShmAn prahiNomi| 
\p  
\v 4 yUyaM kShudraM mahad vA vasanasampuTakaM pAdukAshcha mA gR^ihlIta, mArgamadhye kamapi mA namata cha| 
\p  
\v 5 apara ncha yUyaM yad yat niveshanaM pravishatha tatra niveshanasyAsya ma NgalaM bhUyAditi vAkyaM prathamaM vadata| 
\p  
\v 6 tasmAt tasmin niveshane yadi ma NgalapAtraM sthAsyati tarhi tanma NgalaM tasya bhaviShyati, nochet yuShmAn prati parAvarttiShyate| 
\p  
\v 7 apara ncha te yatki nchid dAsyanti tadeva bhuktvA pItvA tasminniveshane sthAsyatha; yataH karmmakArI jano bhR^itim arhati; gR^ihAd gR^ihaM mA yAsyatha| 
\p  
\v 8 anyachcha yuShmAsu kimapi nagaraM praviShTeShu lokA yadi yuShmAkam AtithyaM kariShyanti, tarhi yat khAdyam upasthAsyanti tadeva khAdiShyatha| 
\p  
\v 9 tannagarasthAn rogiNaH svasthAn kariShyatha, IshvarIyaM rAjyaM yuShmAkam antikam Agamat kathAmetA ncha prachArayiShyatha| 
\p  
\v 10 kintu kimapi puraM yuShmAsu praviShTeShu lokA yadi yuShmAkam AtithyaM na kariShyanti, tarhi tasya nagarasya panthAnaM gatvA kathAmetAM vadiShyatha, 
\p  
\v 11 yuShmAkaM nagarIyA yA dhUlyo.asmAsu samalagan tA api yuShmAkaM prAtikUlyena sAkShyArthaM sampAtayAmaH; tathApIshvararAjyaM yuShmAkaM samIpam Agatam iti nishchitaM jAnIta| 
\p  
\v 12 ahaM yuShmabhyaM yathArthaM kathayAmi, vichAradine tasya nagarasya dashAtaH sidomo dashA sahyA bhaviShyati| 
\p  
\v 13 hA hA korAsIn nagara, hA hA baitsaidAnagara yuvayormadhye yAdR^ishAni AshcharyyANi karmmANyakriyanta, tAni karmmANi yadi sorasIdono rnagarayorakAriShyanta, tadA ito bahudinapUrvvaM tannivAsinaH shaNavastrANi paridhAya gAtreShu bhasma vilipya samupavishya samakhetsyanta| 
\p  
\v 14 ato vichAradivase yuShmAkaM dashAtaH sorasIdonnivAsinAM dashA sahyA bhaviShyati| 
\p  
\v 15 he kapharnAhUm, tvaM svargaM yAvad unnatA kintu narakaM yAvat nyagbhaviShyasi| 
\p  
\v 16 yo jano yuShmAkaM vAkyaM gR^ihlAti sa mamaiva vAkyaM gR^ihlAti; ki ncha yo jano yuShmAkam avaj nAM karoti sa mamaivAvaj nAM karoti; yo jano mamAvaj nAM karoti cha sa matprerakasyaivAvaj nAM karoti| 
\p  
\v 17 atha te saptatishiShyA Anandena pratyAgatya kathayAmAsuH, he prabho bhavato nAmnA bhUtA apyasmAkaM vashIbhavanti| 
\p  
\v 18 tadAnIM sa tAn jagAda, vidyutamiva svargAt patantaM shaitAnam adarsham| 
\p  
\v 19 pashyata sarpAn vR^ishchikAn ripoH sarvvaparAkramAMshcha padatalai rdalayituM yuShmabhyaM shaktiM dadAmi tasmAd yuShmAkaM kApi hAni rna bhaviShyati| 
\p  
\v 20 bhUtA yuShmAkaM vashIbhavanti, etannimittat mA samullasata, svarge yuShmAkaM nAmAni likhitAni santIti nimittaM samullasata| 
\p  
\v 21 tadghaTikAyAM yIshu rmanasi jAtAhlAdaH kathayAmAsa he svargapR^ithivyorekAdhipate pitastvaM j nAnavatAM viduShA ncha lokAnAM purastAt sarvvametad aprakAshya bAlakAnAM purastAt prAkAshaya etasmAddhetostvAM dhanyaM vadAmi, he pitaritthaM bhavatu yad etadeva tava gochara uttamam| 
\p  
\v 22 pitrA sarvvANi mayi samarpitAni pitaraM vinA kopi putraM na jAnAti ki ncha putraM vinA yasmai janAya putrastaM prakAshitavAn ta ncha vinA kopi pitaraM na jAnAti| 
\p  
\v 23 tapaH paraM sa shiShyAn prati parAvR^itya guptaM jagAda, yUyametAni sarvvANi pashyatha tato yuShmAkaM chakShUMShi dhanyAni| 
\p  
\v 24 yuShmAnahaM vadAmi, yUyaM yAni sarvvANi pashyatha tAni bahavo bhaviShyadvAdino bhUpatayashcha draShTumichChantopi draShTuM na prApnuvan, yuShmAbhi ryA yAH kathAshcha shrUyante tAH shrotumichChantopi shrotuM nAlabhanta| 
\p  
\v 25 anantaram eko vyavasthApaka utthAya taM parIkShituM paprachCha, he upadeshaka anantAyuShaH prAptaye mayA kiM karaNIyaM? 
\p  
\v 26 yIshuH pratyuvAcha, atrArthe vyavasthAyAM kiM likhitamasti? tvaM kIdR^ik paThasi? 
\p  
\v 27 tataH sovadat, tvaM sarvvAntaHkaraNaiH sarvvaprANaiH sarvvashaktibhiH sarvvachittaishcha prabhau parameshvare prema kuru, samIpavAsini svavat prema kuru cha| 
\p  
\v 28 tadA sa kathayAmAsa, tvaM yathArthaM pratyavochaH, ittham Achara tenaiva jIviShyasi| 
\p  
\v 29 kintu sa janaH svaM nirddoShaM j nApayituM yIshuM paprachCha, mama samIpavAsI kaH? tato yIshuH pratyuvAcha, 
\p  
\v 30 eko jano yirUshAlampurAd yirIhopuraM yAti, etarhi dasyUnAM kareShu patite te tasya vastrAdikaM hR^itavantaH tamAhatya mR^itaprAyaM kR^itvA tyaktvA yayuH| 
\p  
\v 31 akasmAd eko yAjakastena mArgeNa gachChan taM dR^iShTvA mArgAnyapArshvena jagAma| 
\p  
\v 32 ittham eko levIyastatsthAnaM prApya tasyAntikaM gatvA taM vilokyAnyena pArshvena jagAma| 
\p  
\v 33 kintvekaH shomiroNIyo gachChan tatsthAnaM prApya taM dR^iShTvAdayata| 
\p  
\v 34 tasyAntikaM gatvA tasya kShateShu tailaM drAkShArasa ncha prakShipya kShatAni baddhvA nijavAhanopari tamupaveshya pravAsIyagR^iham AnIya taM siSheve| 
\p  
\v 35 parasmin divase nijagamanakAle dvau mudrApAdau tadgR^ihasvAmine dattvAvadat janamenaM sevasva tatra yo.adhiko vyayo bhaviShyati tamahaM punarAgamanakAle parishotsyAmi| 
\p  
\v 36 eShAM trayANAM madhye tasya dasyuhastapatitasya janasya samIpavAsI kaH? tvayA kiM budhyate? 
\p  
\v 37 tataH sa vyavasthApakaH kathayAmAsa yastasmin dayAM chakAra| tadA yIshuH kathayAmAsa tvamapi gatvA tathAchara| 
\p  
\v 38 tataH paraM te gachChanta ekaM grAmaM pravivishuH; tadA marthAnAmA strI svagR^ihe tasyAtithyaM chakAra| 
\p  
\v 39 tasmAt mariyam nAmadheyA tasyA bhaginI yIshoH padasamIpa uvavishya tasyopadeshakathAM shrotumArebhe| 
\p  
\v 40 kintu marthA nAnAparicharyyAyAM vyagrA babhUva tasmAddhetostasya samIpamAgatya babhAShe; he prabho mama bhaginI kevalaM mamopari sarvvakarmmaNAM bhAram arpitavatI tatra bhavatA ki nchidapi na mano nidhIyate kim? mama sAhAyyaM karttuM bhavAn tAmAdishatu| 
\p  
\v 41 tato yIshuH pratyuvAcha he marthe he marthe, tvaM nAnAkAryyeShu chintitavatI vyagrA chAsi, 
\p  
\v 42 kintu prayojanIyam ekamAtram Aste| apara ncha yamuttamaM bhAgaM kopi harttuM na shaknoti saeva mariyamA vR^itaH| 
\c 11  
\p  
\v 1 anantaraM sa kasmiMshchit sthAne prArthayata tatsamAptau satyAM tasyaikaH shiShyastaM jagAda he prabho yohan yathA svashiShyAn prArthayitum upadiShTavAn tathA bhavAnapyasmAn upadishatu| 
\p  
\v 2 tasmAt sa kathayAmAsa, prArthanakAle yUyam itthaM kathayadhvaM, he asmAkaM svargasthapitastava nAma pUjyaM bhavatu; tava rAjatvaM bhavatu; svarge yathA tathA pR^ithivyAmapi tavechChayA sarvvaM bhavatu| 
\p  
\v 3 pratyaham asmAkaM prayojanIyaM bhojyaM dehi| 
\p  
\v 4 yathA vayaM sarvvAn aparAdhinaH kShamAmahe tathA tvamapi pApAnyasmAkaM kShamasva| asmAn parIkShAM mAnaya kintu pApAtmano rakSha| 
\p  
\v 5 pashchAt soparamapi kathitavAn yadi yuShmAkaM kasyachid bandhustiShThati nishIthe cha tasya samIpaM sa gatvA vadati, 
\p  
\v 6 he bandho pathika eko bandhu rmama niveshanam AyAtaH kintu tasyAtithyaM karttuM mamAntike kimapi nAsti, ataeva pUpatrayaM mahyam R^iNaM dehi; 
\p  
\v 7 tadA sa yadi gR^ihamadhyAt prativadati mAM mA klishAna, idAnIM dvAraM ruddhaM shayane mayA saha bAlakAshcha tiShThanti tubhyaM dAtum utthAtuM na shaknomi, 
\p  
\v 8 tarhi yuShmAnahaM vadAmi, sa yadi mitratayA tasmai kimapi dAtuM nottiShThati tathApi vAraM vAraM prArthanAta utthApitaH san yasmin tasya prayojanaM tadeva dAsyati| 
\p  
\v 9 ataH kAraNAt kathayAmi, yAchadhvaM tato yuShmabhyaM dAsyate, mR^igayadhvaM tata uddeshaM prApsyatha, dvAram Ahata tato yuShmabhyaM dvAraM mokShyate| 
\p  
\v 10 yo yAchate sa prApnoti, yo mR^igayate sa evoddeshaM prApnoti, yo dvAram Ahanti tadarthaM dvAraM mochyate| 
\p  
\v 11 putreNa pUpe yAchite tasmai pAShANaM dadAti vA matsye yAchite tasmai sarpaM dadAti 
\p  
\v 12 vA aNDe yAchite tasmai vR^ishchikaM dadAti yuShmAkaM madhye ka etAdR^ishaH pitAste? 
\p  
\v 13 tasmAdeva yUyamabhadrA api yadi svasvabAlakebhya uttamAni dravyANi dAtuM jAnItha tarhyasmAkaM svargasthaH pitA nijayAchakebhyaH kiM pavitram AtmAnaM na dAsyati? 
\p  
\v 14 anantaraM yIshunA kasmAchchid ekasmin mUkabhUte tyAjite sati sa bhUtatyakto mAnuSho vAkyaM vaktum Arebhe; tato lokAH sakalA AshcharyyaM menire| 
\p  
\v 15 kintu teShAM kechidUchu rjanoyaM bAlasibUbA arthAd bhUtarAjena bhUtAn tyAjayati| 
\p  
\v 16 taM parIkShituM kechid AkAshIyam ekaM chihnaM darshayituM taM prArthayA nchakrire| 
\p  
\v 17 tadA sa teShAM manaHkalpanAM j nAtvA kathayAmAsa, kasyachid rAjyasya lokA yadi parasparaM virundhanti tarhi tad rAjyam nashyati; kechid gR^ihasthA yadi parasparaM virundhanti tarhi tepi nashyanti| 
\p  
\v 18 tathaiva shaitAnapi svalokAn yadi viruNaddhi tadA tasya rAjyaM kathaM sthAsyati? bAlasibUbAhaM bhUtAn tyAjayAmi yUyamiti vadatha| 
\p  
\v 19 yadyahaM bAlasibUbA bhUtAn tyAjayAmi tarhi yuShmAkaM santAnAH kena tyAjayanti? tasmAt taeva kathAyA etasyA vichArayitAro bhaviShyanti| 
\p  
\v 20 kintu yadyaham Ishvarasya parAkrameNa bhUtAn tyAjayAmi tarhi yuShmAkaM nikaTam Ishvarasya rAjyamavashyam upatiShThati| 
\p  
\v 21 balavAn pumAn susajjamAno yatikAlaM nijATTAlikAM rakShati tatikAlaM tasya dravyaM nirupadravaM tiShThati| 
\p  
\v 22 kintu tasmAd adhikabalaH kashchidAgatya yadi taM jayati tarhi yeShu shastrAstreShu tasya vishvAsa AsIt tAni sarvvANi hR^itvA tasya dravyANi gR^ihlAti| 
\p  
\v 23 ataH kAraNAd yo mama sapakSho na sa vipakShaH, yo mayA saha na saMgR^ihlAti sa vikirati| 
\p  
\v 24 apara ncha amedhyabhUto mAnuShasyAntarnirgatya shuShkasthAne bhrAntvA vishrAmaM mR^igayate kintu na prApya vadati mama yasmAd gR^ihAd AgatohaM punastad gR^ihaM parAvR^itya yAmi| 
\p  
\v 25 tato gatvA tad gR^ihaM mArjitaM shobhita ncha dR^iShTvA 
\p  
\v 26 tatkShaNam apagatya svasmAdapi durmmatIn aparAn saptabhUtAn sahAnayati te cha tadgR^ihaM pavishya nivasanti| tasmAt tasya manuShyasya prathamadashAtaH sheShadashA duHkhatarA bhavati| 
\p  
\v 27 asyAH kathAyAH kathanakAle janatAmadhyasthA kAchinnArI tamuchchaiHsvaraM provAcha, yA yoShit tvAM garbbhe.adhArayat stanyamapAyayachcha saiva dhanyA| 
\p  
\v 28 kintu sokathayat ye parameshvarasya kathAM shrutvA tadanurUpam Acharanti taeva dhanyAH| 
\p  
\v 29 tataH paraM tasyAntike bahulokAnAM samAgame jAte sa vaktumArebhe, AdhunikA duShTalokAshchihnaM draShTumichChanti kintu yUnasbhaviShyadvAdinashchihnaM vinAnyat ki nchichchihnaM tAn na darshayiShyate| 
\p  
\v 30 yUnas tu yathA nInivIyalokAnAM samIpe chihnarUpobhavat tathA vidyamAnalokAnAm eShAM samIpe manuShyaputropi chihnarUpo bhaviShyati| 
\p  
\v 31 vichArasamaye idAnIntanalokAnAM prAtikUlyena dakShiNadeshIyA rAj nI protthAya tAn doShiNaH kariShyati, yataH sA rAj nI sulemAna upadeshakathAM shrotuM pR^ithivyAH sImAta AgachChat kintu pashyata sulemAnopi gurutara eko jano.asmin sthAne vidyate| 
\p  
\v 32 apara ncha vichArasamaye nInivIyalokA api varttamAnakAlikAnAM lokAnAM vaiparItyena protthAya tAn doShiNaH kariShyanti, yato hetoste yUnaso vAkyAt chittAni parivarttayAmAsuH kintu pashyata yUnasotigurutara eko jano.asmin sthAne vidyate| 
\p  
\v 33 pradIpaM prajvAlya droNasyAdhaH kutrApi guptasthAne vA kopi na sthApayati kintu gR^ihapraveshibhyo dIptiM dAtaM dIpAdhAroparyyeva sthApayati| 
\p  
\v 34 dehasya pradIpashchakShustasmAdeva chakShu ryadi prasannaM bhavati tarhi tava sarvvasharIraM dIptimad bhaviShyati kintu chakShu ryadi malImasaM tiShThati tarhi sarvvasharIraM sAndhakAraM sthAsyati| 
\p  
\v 35 asmAt kAraNAt tavAntaHsthaM jyoti ryathAndhakAramayaM na bhavati tadarthe sAvadhAno bhava| 
\p  
\v 36 yataH sharIrasya kutrApyaMshe sAndhakAre na jAte sarvvaM yadi dIptimat tiShThati tarhi tubhyaM dIptidAyiprojjvalan pradIpa iva tava savarvasharIraM dIptimad bhaviShyati| 
\p  
\v 37 etatkathAyAH kathanakAle phirushyeko bhejanAya taM nimantrayAmAsa, tataH sa gatvA bhoktum upavivesha| 
\p  
\v 38 kintu bhojanAt pUrvvaM nAmA NkShIt etad dR^iShTvA sa phirushyAshcharyyaM mene| 
\p  
\v 39 tadA prabhustaM provAcha yUyaM phirUshilokAH pAnapAtrANAM bhojanapAtrANA ncha bahiH pariShkurutha kintu yuShmAkamanta rdaurAtmyai rduShkriyAbhishcha paripUrNaM tiShThati| 
\p  
\v 40 he sarvve nirbodhA yo bahiH sasarja sa eva kimanta rna sasarja? 
\p  
\v 41 tata eva yuShmAbhirantaHkaraNaM (IshvarAya) nivedyatAM tasmin kR^ite yuShmAkaM sarvvANi shuchitAM yAsyanti| 
\p  
\v 42 kintu hanta phirUshigaNA yUyaM nyAyam Ishvare prema cha parityajya podinAyA arudAdInAM sarvveShAM shAkAnA ncha dashamAMshAn dattha kintu prathamaM pAlayitvA sheShasyAla NghanaM yuShmAkam uchitamAsIt| 
\p  
\v 43 hA hA phirUshino yUyaM bhajanagehe prochchAsane ApaNeShu cha namaskAreShu prIyadhve| 
\p  
\v 44 vata kapaTino.adhyApakAH phirUshinashcha lokAyat shmashAnam anupalabhya tadupari gachChanti yUyam tAdR^igaprakAshitashmashAnavAd bhavatha| 
\p  
\v 45 tadAnIM vyavasthApakAnAm ekA yIshumavadat, he upadeshaka vAkyenedR^ishenAsmAsvapi doSham Aropayasi| 
\p  
\v 46 tataH sa uvAcha, hA hA vyavasthApakA yUyam mAnuShANAm upari duHsahyAn bhArAn nyasyatha kintu svayam ekA NguुlyApi tAn bhArAn na spR^ishatha| 
\p  
\v 47 hanta yuShmAkaM pUrvvapuruShA yAn bhaviShyadvAdino.avadhiShusteShAM shmashAnAni yUyaM nirmmAtha| 
\p  
\v 48 tenaiva yUyaM svapUrvvapuruShANAM karmmANi saMmanyadhve tadeva sapramANaM kurutha cha, yataste tAnavadhiShuH yUyaM teShAM shmashAnAni nirmmAtha| 
\p  
\v 49 ataeva Ishvarasya shAstre proktamasti teShAmantike bhaviShyadvAdinaH preritAMshcha preShayiShyAmi tataste teShAM kAMshchana haniShyanti kAMshchana tADashShyinti| 
\p  
\v 50 etasmAt kAraNAt hAbilaH shoNitapAtamArabhya mandirayaj navedyo rmadhye hatasya sikhariyasya raktapAtaparyyantaM 
\p  
\v 51 jagataH sR^iShTimArabhya pR^ithivyAM bhaviShyadvAdinAM yatiraktapAtA jAtAstatInAm aparAdhadaNDA eShAM varttamAnalokAnAM bhaviShyanti, yuShmAnahaM nishchitaM vadAmi sarvve daNDA vaMshasyAsya bhaviShyanti| 
\p  
\v 52 hA hA vyavasthapakA yUyaM j nAnasya ku nchikAM hR^itvA svayaM na praviShTA ye praveShTu ncha prayAsinastAnapi praveShTuM vAritavantaH| 
\p  
\v 53 itthaM kathAkathanAd adhyApakAH phirUshinashcha satarkAH 
\p  
\v 54 santastamapavadituM tasya kathAyA doShaM dharttamichChanto nAnAkhyAnakathanAya taM pravarttayituM kopayitu ncha prArebhire| 
\c 12  
\p  
\v 1 tadAnIM lokAH sahasraM sahasram Agatya samupasthitAstata ekaiko .anyeShAmupari patitum upachakrame; tadA yIshuH shiShyAn babhAShe, yUyaM phirUshinAM kiNvarUpakApaTye visheSheNa sAvadhAnAstiShThata| 
\p  
\v 2 yato yanna prakAshayiShyate tadAchChannaM vastu kimapi nAsti; tathA yanna j nAsyate tad guptaM vastu kimapi nAsti| 
\p  
\v 3 andhakAre tiShThanato yAH kathA akathayata tAH sarvvAH kathA dIptau shroShyante nirjane karNe cha yadakathayata gR^ihapR^iShThAt tat prachArayiShyate| 
\p  
\v 4 he bandhavo yuShmAnahaM vadAmi, ye sharIrasya nAshaM vinA kimapyaparaM karttuM na shakruvanti tebhyo mA bhaiShTa| 
\p  
\v 5 tarhi kasmAd bhetavyam ityahaM vadAmi, yaH sharIraM nAshayitvA narakaM nikSheptuM shaknoti tasmAdeva bhayaM kuruta, punarapi vadAmi tasmAdeva bhayaM kuruta| 
\p  
\v 6 pa ncha chaTakapakShiNaH kiM dvAbhyAM tAmrakhaNDAbhyAM na vikrIyante? tathApIshvarasteShAm ekamapi na vismarati| 
\p  
\v 7 yuShmAkaM shiraHkeshA api gaNitAH santi tasmAt mA vibhIta bahuchaTakapakShibhyopi yUyaM bahumUlyAH| 
\p  
\v 8 aparaM yuShmabhyaM kathayAmi yaH kashchin mAnuShANAM sAkShAn mAM svIkaroti manuShyaputra IshvaradUtAnAM sAkShAt taM svIkariShyati| 
\p  
\v 9 kintu yaH kashchinmAnuShANAM sAkShAnmAm asvIkaroti tam Ishvarasya dUtAnAM sAkShAd aham asvIkariShyAmi| 
\p  
\v 10 anyachcha yaH kashchin manujasutasya nindAbhAvena kA nchit kathAM kathayati tasya tatpApasya mochanaM bhaviShyati kintu yadi kashchit pavitram AtmAnaM nindati tarhi tasya tatpApasya mochanaM na bhaviShyati| 
\p  
\v 11 yadA lokA yuShmAn bhajanagehaM vichArakartR^irAjyakartR^iNAM sammukha ncha neShyanti tadA kena prakAreNa kimuttaraM vadiShyatha kiM kathayiShyatha chetyatra mA chintayata; 
\p  
\v 12 yato yuShmAbhiryad yad vaktavyaM tat tasmin samayaeva pavitra AtmA yuShmAn shikShayiShyati| 
\p  
\v 13 tataH paraM janatAmadhyasthaH kashchijjanastaM jagAda he guro mayA saha paitR^ikaM dhanaM vibhaktuM mama bhrAtaramAj nApayatu bhavAn| 
\p  
\v 14 kintu sa tamavadat he manuShya yuvayo rvichAraM vibhAga ncha karttuM mAM ko niyuktavAn? 
\p  
\v 15 anantaraM sa lokAnavadat lobhe sAvadhAnAH satarkAshcha tiShThata, yato bahusampattiprAptyA manuShyasyAyu rna bhavati| 
\p  
\v 16 pashchAd dR^iShTAntakathAmutthApya kathayAmAsa, ekasya dhanino bhUmau bahUni shasyAni jAtAni| 
\p  
\v 17 tataH sa manasA chintayitvA kathayAmbabhUva mamaitAni samutpannAni dravyANi sthApayituM sthAnaM nAsti kiM kariShyAmi? 
\p  
\v 18 tatovadad itthaM kariShyAmi, mama sarvvabhANDAgArANi bha NktvA bR^ihadbhANDAgArANi nirmmAya tanmadhye sarvvaphalAni dravyANi cha sthApayiShyAmi| 
\p  
\v 19 aparaM nijamano vadiShyAmi, he mano bahuvatsarArthaM nAnAdravyANi sa nchitAni santi vishrAmaM kuru bhuktvA pItvA kautuka ncha kuru| kintvIshvarastam avadat, 
\p  
\v 20 re nirbodha adya rAtrau tava prANAstvatto neShyante tata etAni yAni dravyANi tvayAsAditAni tAni kasya bhaviShyanti? 
\p  
\v 21 ataeva yaH kashchid Ishvarasya samIpe dhanasa nchayamakR^itvA kevalaM svanikaTe sa nchayaM karoti sopi tAdR^ishaH| 
\p  
\v 22 atha sa shiShyebhyaH kathayAmAsa, yuShmAnahaM vadAmi, kiM khAdiShyAmaH? kiM paridhAsyAmaH? ityuktvA jIvanasya sharIrasya chArthaM chintAM mA kArShTa| 
\p  
\v 23 bhakShyAjjIvanaM bhUShaNAchCharIra ncha shreShThaM bhavati| 
\p  
\v 24 kAkapakShiNAM kAryyaM vichArayata, te na vapanti shasyAni cha na Chindanti, teShAM bhANDAgArANi na santi koShAshcha na santi, tathApIshvarastebhyo bhakShyANi dadAti, yUyaM pakShibhyaH shreShThatarA na kiM? 
\p  
\v 25 apara ncha bhAvayitvA nijAyuShaH kShaNamAtraM varddhayituM shaknoti, etAdR^isho lAko yuShmAkaM madhye kosti? 
\p  
\v 26 ataeva kShudraM kAryyaM sAdhayitum asamarthA yUyam anyasmin kAryye kuto bhAvayatha? 
\p  
\v 27 anyachcha kAmpilapuShpaM kathaM varddhate tadApi vichArayata, tat ka nchana shramaM na karoti tantUMshcha na janayati kintu yuShmabhyaM yathArthaM kathayAmi sulemAn bahvaishvaryyAnvitopi puShpasyAsya sadR^isho vibhUShito nAsIt| 
\p  
\v 28 adya kShetre varttamAnaM shvashchUllyAM kShepsyamAnaM yat tR^iNaM, tasmai yadIshvara itthaM bhUShayati tarhi he alpapratyayino yuShmAna kiM na paridhApayiShyati? 
\p  
\v 29 ataeva kiM khAdiShyAmaH? kiM paridhAsyAmaH? etadarthaM mA cheShTadhvaM mA saMdigdhva ncha| 
\p  
\v 30 jagato devArchchakA etAni sarvvANi cheShTanate; eShu vastuShu yuShmAkaM prayojanamAste iti yuShmAkaM pitA jAnAti| 
\p  
\v 31 ataeveshvarasya rAjyArthaM sacheShTA bhavata tathA kR^ite sarvvANyetAni dravyANi yuShmabhyaM pradAyiShyante| 
\p  
\v 32 he kShudrameShavraja yUyaM mA bhaiShTa yuShmabhyaM rAjyaM dAtuM yuShmAkaM pituH sammatirasti| 
\p  
\v 33 ataeva yuShmAkaM yA yA sampattirasti tAM tAM vikrIya vitarata, yat sthAnaM chaurA nAgachChanti, kITAshcha na kShAyayanti tAdR^ishe svarge nijArtham ajare sampuTake .akShayaM dhanaM sa nchinuta cha; 
\p  
\v 34 yato yatra yuShmAkaM dhanaM varttate tatreva yuShmAkaM manaH| 
\p  
\v 35 apara ncha yUyaM pradIpaM jvAlayitvA baddhakaTayastiShThata; 
\p  
\v 36 prabhu rvivAhAdAgatya yadaiva dvAramAhanti tadaiva dvAraM mochayituM yathA bhR^ityA apekShya tiShThanti tathA yUyamapi tiShThata| 
\p  
\v 37 yataH prabhurAgatya yAn dAsAn sachetanAn tiShThato drakShyati taeva dhanyAH; ahaM yuShmAn yathArthaM vadAmi prabhustAn bhojanArtham upaveshya svayaM baddhakaTiH samIpametya pariveShayiShyati| 
\p  
\v 38 yadi dvitIye tR^itIye vA prahare samAgatya tathaiva pashyati, tarhi taeva dAsA dhanyAH| 
\p  
\v 39 apara ncha kasmin kShaNe chaurA AgamiShyanti iti yadi gR^ihapati rj nAtuM shaknoti tadAvashyaM jAgran nijagR^ihe sandhiM karttayituM vArayati yUyametad vitta| 
\p  
\v 40 ataeva yUyamapi sajjamAnAstiShThata yato yasmin kShaNe taM nAprekShadhve tasminneva kShaNe manuShyaputra AgamiShyati| 
\p  
\v 41 tadA pitaraH paprachCha, he prabho bhavAn kimasmAn uddishya kiM sarvvAn uddishya dR^iShTAntakathAmimAM vadati? 
\p  
\v 42 tataH prabhuH provAcha, prabhuH samuchitakAle nijaparivArArthaM bhojyapariveShaNAya yaM tatpade niyokShyati tAdR^isho vishvAsyo boddhA karmmAdhIshaH kosti? 
\p  
\v 43 prabhurAgatya yam etAdR^ishe karmmaNi pravR^ittaM drakShyati saeva dAso dhanyaH| 
\p  
\v 44 ahaM yuShmAn yathArthaM vadAmi sa taM nijasarvvasvasyAdhipatiM kariShyati| 
\p  
\v 45 kintu prabhurvilambenAgamiShyati, iti vichintya sa dAso yadi tadanyadAsIdAsAn praharttum bhoktuM pAtuM maditu ncha prArabhate, 
\p  
\v 46 tarhi yadA prabhuM nApekShiShyate yasmin kShaNe so.achetanashcha sthAsyati tasminneva kShaNe tasya prabhurAgatya taM padabhraShTaM kR^itvA vishvAsahInaiH saha tasya aMshaM nirUpayiShyati| 
\p  
\v 47 yo dAsaH prabheाrAj nAM j nAtvApi sajjito na tiShThati tadAj nAnusAreNa cha kAryyaM na karoti sonekAn prahArAn prApsyati; 
\p  
\v 48 kintu yo jano.aj nAtvA prahArArhaM karmma karoti solpaprahArAn prApsyati| yato yasmai bAhulyena dattaM tasmAdeva bAhulyena grahIShyate, mAnuShA yasya nikaTe bahu samarpayanti tasmAd bahu yAchante| 
\p  
\v 49 ahaM pR^ithivyAm anaikyarUpaM vahni nikSheptum Agatosmi, sa ched idAnImeva prajvalati tatra mama kA chintA? 
\p  
\v 50 kintu yena majjanenAhaM magno bhaviShyAmi yAvatkAlaM tasya siddhi rna bhaviShyati tAvadahaM katikaShTaM prApsyAmi| 
\p  
\v 51 melanaM karttuM jagad Agatosmi yUyaM kimitthaM bodhadhve? yuShmAn vadAmi na tathA, kintvahaM melanAbhAvaM karttuMm Agatosmi| 
\p  
\v 52 yasmAdetatkAlamArabhya ekatrasthaparijanAnAM madhye pa nchajanAH pR^ithag bhUtvA trayo janA dvayorjanayoH pratikUlA dvau janau cha trayANAM janAnAM pratikUlau bhaviShyanti| 
\p  
\v 53 pitA putrasya vipakShaH putrashcha pitu rvipakSho bhaviShyati mAtA kanyAyA vipakShA kanyA cha mAtu rvipakShA bhaviShyati, tathA shvashrUrbadhvA vipakShA badhUshcha shvashrvA vipakShA bhaviShyati| 
\p  
\v 54 sa lokebhyoparamapi kathayAmAsa, pashchimadishi meghodgamaM dR^iShTvA yUyaM haThAd vadatha vR^iShTi rbhaviShyati tatastathaiva jAyate| 
\p  
\v 55 aparaM dakShiNato vAyau vAti sati vadatha nidAgho bhaviShyati tataH sopi jAyate| 
\p  
\v 56 re re kapaTina AkAshasya bhUmyAshcha lakShaNaM boddhuM shaknutha, 
\p  
\v 57 kintu kAlasyAsya lakShaNaM kuto boddhuM na shaknutha? yUya ncha svayaM kuto na nyAShyaM vichArayatha? 
\p  
\v 58 apara ncha vivAdinA sArddhaM vichArayituH samIpaM gachChan pathi tasmAduddhAraM prAptuM yatasva nochet sa tvAM dhR^itvA vichArayituH samIpaM nayati| vichArayitA yadi tvAM praharttuH samIpaM samarpayati praharttA tvAM kArAyAM badhnAti 
\p  
\v 59 tarhi tvAmahaM vadAmi tvayA niHsheShaM kapardakeShu na parishodhiteShu tvaM tato muktiM prAptuM na shakShyasi| 
\c 13  
\p  
\v 1 apara ncha pIlAto yeShAM gAlIlIyAnAM raktAni balInAM raktaiH sahAmishrayat teShAM gAlIlIyAnAM vR^ittAntaM katipayajanA upasthApya yIshave kathayAmAsuH| 
\p  
\v 2 tataH sa pratyuvAcha teShAM lokAnAm etAdR^ishI durgati rghaTitA tatkAraNAd yUyaM kimanyebhyo gAlIlIyebhyopyadhikapApinastAn bodhadhve? 
\p  
\v 3 yuShmAnahaM vadAmi tathA na kintu manaHsu na parAvarttiteShu yUyamapi tathA naMkShyatha| 
\p  
\v 4 apara ncha shIlohanAmna uchchagR^ihasya patanAd ye.aShTAdashajanA mR^itAste yirUshAlami nivAsisarvvalokebhyo.adhikAparAdhinaH kiM yUyamityaM bodhadhve? 
\p  
\v 5 yuShmAnahaM vadAmi tathA na kintu manaHsu na parivarttiteShu yUyamapi tathA naMkShyatha| 
\p  
\v 6 anantaraM sa imAM dR^iShTAntakathAmakathayad eko jano drAkShAkShetramadhya ekamuDumbaravR^ikShaM ropitavAn| pashchAt sa Agatya tasmin phalAni gaveShayAmAsa, 
\p  
\v 7 kintu phalAprApteH kAraNAd udyAnakAraM bhR^ityaM jagAda, pashya vatsaratrayaM yAvadAgatya etasminnuDumbaratarau kShalAnyanvichChAmi, kintu naikamapi prapnomi tarurayaM kuto vR^ithA sthAnaM vyApya tiShThati? enaM Chindhi| 
\p  
\v 8 tato bhR^ityaH pratyuvAcha, he prabho punarvarShamekaM sthAtum Adisha; etasya mUlasya chaturdikShu khanitvAham AlavAlaM sthApayAmi| 
\p  
\v 9 tataH phalituM shaknoti yadi na phalati tarhi pashchAt Chetsyasi| 
\p  
\v 10 atha vishrAmavAre bhajanagehe yIshurupadishati 
\p  
\v 11 tasmit samaye bhUtagrastatvAt kubjIbhUyAShTAdashavarShANi yAvat kenApyupAyena R^iju rbhavituM na shaknoti yA durbbalA strI, 
\p  
\v 12 tAM tatropasthitAM vilokya yIshustAmAhUya kathitavAn he nAri tava daurbbalyAt tvaM muktA bhava| 
\p  
\v 13 tataH paraM tasyA gAtre hastArpaNamAtrAt sA R^ijurbhUtveshvarasya dhanyavAdaM karttumArebhe| 
\p  
\v 14 kintu vishrAmavAre yIshunA tasyAH svAsthyakaraNAd bhajanagehasyAdhipatiH prakupya lokAn uvAcha, ShaTsu dineShu lokaiH karmma karttavyaM tasmAddhetoH svAsthyArthaM teShu dineShu AgachChata, vishrAmavAre mAgachChata| 
\p  
\v 15 tadA pabhuH pratyuvAcha re kapaTino yuShmAkam ekaiko jano vishrAmavAre svIyaM svIyaM vR^iShabhaM gardabhaM vA bandhanAnmochayitvA jalaM pAyayituM kiM na nayati? 
\p  
\v 16 tarhyAShTAdashavatsarAn yAvat shaitAnA baddhA ibrAhImaH santatiriyaM nArI kiM vishrAmavAre na mochayitavyA? 
\p  
\v 17 eShu vAkyeShu kathiteShu tasya vipakShAH salajjA jAtAH kintu tena kR^itasarvvamahAkarmmakAraNAt lokanivahaH sAnando.abhavat| 
\p  
\v 18 anantaraM sovadad Ishvarasya rAjyaM kasya sadR^ishaM? kena tadupamAsyAmi? 
\p  
\v 19 yat sarShapabIjaM gR^ihItvA kashchijjana udyAna uptavAn tad bIjama NkuritaM sat mahAvR^ikSho.ajAyata, tatastasya shAkhAsu vihAyasIyavihagA Agatya nyUShuH, tadrAjyaM tAdR^ishena sarShapabIjena tulyaM| 
\p  
\v 20 punaH kathayAmAsa, Ishvarasya rAjyaM kasya sadR^ishaM vadiShyAmi? yat kiNvaM kAchit strI gR^ihItvA droNatrayaparimitagodhUmachUrNeShu sthApayAmAsa, 
\p  
\v 21 tataH krameNa tat sarvvagodhUmachUrNaM vyApnoti, tasya kiNvasya tulyam Ishvarasya rAjyaM| 
\p  
\v 22 tataH sa yirUshAlamnagaraM prati yAtrAM kR^itvA nagare nagare grAme grAme samupadishan jagAma| 
\p  
\v 23 tadA kashchijjanastaM paprachCha, he prabho kiM kevalam alpe lokAH paritrAsyante? 
\p  
\v 24 tataH sa lokAn uvAcha, saMkIrNadvAreNa praveShTuM yataghvaM, yatohaM yuShmAn vadAmi, bahavaH praveShTuM cheShTiShyante kintu na shakShyanti| 
\p  
\v 25 gR^ihapatinotthAya dvAre ruddhe sati yadi yUyaM bahiH sthitvA dvAramAhatya vadatha, he prabho he prabho asmatkAraNAd dvAraM mochayatu, tataH sa iti prativakShyati, yUyaM kutratyA lokA ityahaM na jAnAmi| 
\p  
\v 26 tadA yUyaM vadiShyatha, tava sAkShAd vayaM bheाjanaM pAna ncha kR^itavantaH, tva nchAsmAkaM nagarasya pathi samupadiShTavAn| 
\p  
\v 27 kintu sa vakShyati, yuShmAnahaM vadAmi, yUyaM kutratyA lokA ityahaM na jAnAmi; he durAchAriNo yUyaM matto dUrIbhavata| 
\p  
\v 28 tadA ibrAhImaM ishAkaM yAkUba ncha sarvvabhaviShyadvAdinashcha Ishvarasya rAjyaM prAptAn svAMshcha bahiShkR^itAn dR^iShTvA yUyaM rodanaM dantairdantagharShaNa ncha kariShyatha| 
\p  
\v 29 apara ncha pUrvvapashchimadakShiNottaradigbhyo lokA Agatya Ishvarasya rAjye nivatsyanti| 
\p  
\v 30 pashyatetthaM sheShIyA lokA agrA bhaviShyanti, agrIyA lokAshcha sheShA bhaviShyanti| 
\p  
\v 31 apara ncha tasmin dine kiyantaH phirUshina Agatya yIshuM prochuH, bahirgachCha, sthAnAdasmAt prasthAnaM kuru, herod tvAM jighAMsati| 
\p  
\v 32 tataH sa pratyavochat pashyatAdya shvashcha bhUtAn vihApya rogiNo.arogiNaH kR^itvA tR^itIyehni setsyAmi, kathAmetAM yUyamitvA taM bhUrimAyaM vadata| 
\p  
\v 33 tatrApyadya shvaH parashvashcha mayA gamanAgamane karttavye, yato heto ryirUshAlamo bahiH kutrApi kopi bhaviShyadvAdI na ghAniShyate| 
\p  
\v 34 he yirUshAlam he yirUshAlam tvaM bhaviShyadvAdino haMsi tavAntike preritAn prastarairmArayasi cha, yathA kukkuTI nijapakShAdhaH svashAvakAn saMgR^ihlAti, tathAhamapi tava shishUn saMgrahItuM kativArAn aichChaM kintu tvaM naichChaH| 
\p  
\v 35 pashyata yuShmAkaM vAsasthAnAni prochChidyamAnAni parityaktAni cha bhaviShyanti; yuShmAnahaM yathArthaM vadAmi, yaH prabho rnAmnAgachChati sa dhanya iti vAchaM yAvatkAlaM na vadiShyatha, tAvatkAlaM yUyaM mAM na drakShyatha| 
\c 14  
\p  
\v 1 anantaraM vishrAmavAre yIshau pradhAnasya phirUshino gR^ihe bhoktuM gatavati te taM vIkShitum Arebhire| 
\p  
\v 2 tadA jalodarI tasya sammukhe sthitaH| 
\p  
\v 3 tataH sa vyavasthApakAn phirUshinashcha paprachCha, vishrAmavAre svAsthyaM karttavyaM na vA? tataste kimapi na pratyUchuH| 
\p  
\v 4 tadA sa taM rogiNaM svasthaM kR^itvA visasarja; 
\p  
\v 5 tAnuvAcha cha yuShmAkaM kasyachid garddabho vR^iShabho vA ched gartte patati tarhi vishrAmavAre tatkShaNaM sa kiM taM notthApayiShyati? 
\p  
\v 6 tataste kathAyA etasyAH kimapi prativaktuM na shekuH| 
\p  
\v 7 apara ncha pradhAnasthAnamanonItatvakaraNaM vilokya sa nimantritAn etadupadeshakathAM jagAda, 
\p  
\v 8 tvaM vivAhAdibhojyeShu nimantritaH san pradhAnasthAne mopAvekShIH| tvatto gauravAnvitanimantritajana AyAte 
\p  
\v 9 nimantrayitAgatya manuShyAyaitasmai sthAnaM dehIti vAkyaM ched vakShyati tarhi tvaM sa Nkuchito bhUtvA sthAna itarasmin upaveShTum udyaMsyasi| 
\p  
\v 10 asmAt kAraNAdeva tvaM nimantrito gatvA.apradhAnasthAna upavisha, tato nimantrayitAgatya vadiShyati, he bandho prochchasthAnaM gatvopavisha, tathA sati bhojanopaviShTAnAM sakalAnAM sAkShAt tvaM mAnyo bhaviShyasi| 
\p  
\v 11 yaH kashchit svamunnamayati sa namayiShyate, kintu yaH kashchit svaM namayati sa unnamayiShyate| 
\p  
\v 12 tadA sa nimantrayitAraM janamapi jagAda, madhyAhne rAtrau vA bhojye kR^ite nijabandhugaNo vA bhrAtR^iृgaNo vA j nAtigaNo vA dhanigaNo vA samIpavAsigaNo vA etAn na nimantraya, tathA kR^ite chet te tvAM nimantrayiShyanti, tarhi parishodho bhaviShyati| 
\p  
\v 13 kintu yadA bhejyaM karoShi tadA daridrashuShkakarakha njAndhAn nimantraya, 
\p  
\v 14 tata AshiShaM lapsyase, teShu parishodhaM karttumashaknuvatsu shmashAnAddhArmmikAnAmutthAnakAle tvaM phalAM lapsyase| 
\p  
\v 15 anantaraM tAM kathAM nishamya bhojanopaviShTaH kashchit kathayAmAsa, yo jana Ishvarasya rAjye bhoktuM lapsyate saeva dhanyaH| 
\p  
\v 16 tataH sa uvAcha, kashchit jano rAtrau bheाjyaM kR^itvA bahUn nimantrayAmAsa| 
\p  
\v 17 tato bhojanasamaye nimantritalokAn AhvAtuM dAsadvArA kathayAmAsa, khadyadravyANi sarvvANi samAsAditAni santi, yUyamAgachChata| 
\p  
\v 18 kintu te sarvva ekaikaM ChalaM kR^itvA kShamAM prArthayA nchakrire| prathamo janaH kathayAmAsa, kShetramekaM krItavAnahaM tadeva draShTuM mayA gantavyam, ataeva mAM kShantuM taM nivedaya| 
\p  
\v 19 anyo janaH kathayAmAsa, dashavR^iShAnahaM krItavAn tAn parIkShituM yAmi tasmAdeva mAM kShantuM taM nivedaya| 
\p  
\v 20 aparaH kathayAmAsa, vyUDhavAnahaM tasmAt kAraNAd yAtuM na shaknomi| 
\p  
\v 21 pashchAt sa dAso gatvA nijaprabhoH sAkShAt sarvvavR^ittAntaM nivedayAmAsa, tatosau gR^ihapatiH kupitvA svadAsaM vyAjahAra, tvaM satvaraM nagarasya sanniveshAn mArgAMshcha gatvA daridrashuShkakarakha njAndhAn atrAnaya| 
\p  
\v 22 tato dAso.avadat, he prabho bhavata Aj nAnusAreNAkriyata tathApi sthAnamasti| 
\p  
\v 23 tadA prabhuH puna rdAsAyAkathayat, rAjapathAn vR^ikShamUlAni cha yAtvA madIyagR^ihapUraNArthaM lokAnAgantuM pravarttaya| 
\p  
\v 24 ahaM yuShmabhyaM kathayAmi, pUrvvanimantritAnamekopi mamAsya rAtribhojyasyAsvAdaM na prApsyati| 
\p  
\v 25 anantaraM bahuShu lokeShu yIshoH pashchAd vrajiteShu satsu sa vyAghuTya tebhyaH kathayAmAsa, 
\p  
\v 26 yaH kashchin mama samIpam Agatya svasya mAtA pitA patnI santAnA bhrAtaro bhagimyo nijaprANAshcha, etebhyaH sarvvebhyo mayyadhikaM prema na karoti, sa mama shiShyo bhavituM na shakShyati| 
\p  
\v 27 yaH kashchit svIyaM krushaM vahan mama pashchAnna gachChati, sopi mama shiShyo bhavituM na shakShyati| 
\p  
\v 28 durganirmmANe kativyayo bhaviShyati, tathA tasya samAptikaraNArthaM sampattirasti na vA, prathamamupavishya etanna gaNayati, yuShmAkaM madhya etAdR^ishaH kosti? 
\p  
\v 29 noched bhittiM kR^itvA sheShe yadi samApayituM na shakShyati, 
\p  
\v 30 tarhi mAnuShoyaM nichetum Arabhata samApayituM nAshaknot, iti vyAhR^itya sarvve tamupahasiShyanti| 
\p  
\v 31 apara ncha bhinnabhUpatinA saha yuddhaM karttum udyamya dashasahasrANi sainyAni gR^ihItvA viMshatisahasreH sainyaiH sahitasya samIpavAsinaH sammukhaM yAtuM shakShyAmi na veti prathamaM upavishya na vichArayati etAdR^isho bhUmipatiH kaH? 
\p  
\v 32 yadi na shaknoti tarhi ripAvatidUre tiShThati sati nijadUtaM preShya sandhiM karttuM prArthayeta| 
\p  
\v 33 tadvad yuShmAkaM madhye yaH kashchin madarthaM sarvvasvaM hAtuM na shaknoti sa mama shiShyo bhavituM na shakShyati| 
\p  
\v 34 lavaNam uttamam iti satyaM, kintu yadi lavaNasya lavaNatvam apagachChati tarhi tat kathaM svAduyuktaM bhaviShyati? 
\p  
\v 35 tada bhUmyartham AlavAlarAshyarthamapi bhadraM na bhavati; lokAstad bahiH kShipanti|yasya shrotuM shrotre staH sa shR^iNotu| 
\c 15  
\p  
\v 1 tadA karasa nchAyinaH pApinashcha lokA upadeshkathAM shrotuM yIshoH samIpam AgachChan| 
\p  
\v 2 tataH phirUshina upAdhyAyAshcha vivadamAnAH kathayAmAsuH eSha mAnuShaH pApibhiH saha praNayaM kR^itvA taiH sArddhaM bhuMkte| 
\p  
\v 3 tadA sa tebhya imAM dR^iShTAntakathAM kathitavAn, 
\p  
\v 4 kasyachit shatameSheShu tiShThatmu teShAmekaM sa yadi hArayati tarhi madhyeprAntaram ekonashatameShAn vihAya hAritameShasya uddeshaprAptiparyyanataM na gaveShayati, etAdR^isho loko yuShmAkaM madhye ka Aste? 
\p  
\v 5 tasyoddeshaM prApya hR^iShTamanAstaM skandhe nidhAya svasthAnam AnIya bandhubAndhavasamIpavAsina AhUya vakti, 
\p  
\v 6 hAritaM meShaM prAptoham ato heto rmayA sArddham Anandata| 
\p  
\v 7 tadvadahaM yuShmAn vadAmi, yeShAM manaHparAvarttanasya prayojanaM nAsti, tAdR^ishaikonashatadhArmmikakAraNAd ya AnandastasmAd ekasya manaHparivarttinaH pApinaH kAraNAt svarge .adhikAnando jAyate| 
\p  
\v 8 apara ncha dashAnAM rUpyakhaNDAnAm ekakhaNDe hArite pradIpaM prajvAlya gR^ihaM sammArjya tasya prAptiM yAvad yatnena na gaveShayati, etAdR^ishI yoShit kAste? 
\p  
\v 9 prApte sati bandhubAndhavasamIpavAsinIrAhUya kathayati, hAritaM rUpyakhaNDaM prAptAhaM tasmAdeva mayA sArddham Anandata| 
\p  
\v 10 tadvadahaM yuShmAn vyAharAmi, ekena pApinA manasi parivarttite, Ishvarasya dUtAnAM madhyepyAnando jAyate| 
\p  
\v 11 apara ncha sa kathayAmAsa, kasyachid dvau putrAvAstAM, 
\p  
\v 12 tayoH kaniShThaH putraH pitre kathayAmAsa, he pitastava sampattyA yamaMshaM prApsyAmyahaM vibhajya taM dehi, tataH pitA nijAM sampattiM vibhajya tAbhyAM dadau| 
\p  
\v 13 katipayAt kAlAt paraM sa kaniShThaputraH samastaM dhanaM saMgR^ihya dUradeshaM gatvA duShTAcharaNena sarvvAM sampattiM nAshayAmAsa| 
\p  
\v 14 tasya sarvvadhane vyayaM gate taddeshe mahAdurbhikShaM babhUva, tatastasya dainyadashA bhavitum Arebhe| 
\p  
\v 15 tataH paraM sa gatvA taddeshIyaM gR^ihasthamekam Ashrayata; tataH sataM shUkaravrajaM chArayituM prAntaraM preShayAmAsa| 
\p  
\v 16 kenApi tasmai bhakShyAdAnAt sa shUkaraphalavalkalena pichiNDapUraNAM vavA nCha| 
\p  
\v 17 sheShe sa manasi chetanAM prApya kathayAmAsa, hA mama pituH samIpe kati kati vetanabhujo dAsA yatheShTaM tatodhika ncha bhakShyaM prApnuvanti kintvahaM kShudhA mumUrShuH| 
\p  
\v 18 ahamutthAya pituH samIpaM gatvA kathAmetAM vadiShyAmi, he pitar Ishvarasya tava cha viruddhaM pApamakaravam 
\p  
\v 19 tava putra_iti vikhyAto bhavituM na yogyosmi cha, mAM tava vaitanikaM dAsaM kR^itvA sthApaya| 
\p  
\v 20 pashchAt sa utthAya pituH samIpaM jagAma; tatastasya pitAtidUre taM nirIkShya dayA nchakre, dhAvitvA tasya kaNThaM gR^ihItvA taM chuchumba cha| 
\p  
\v 21 tadA putra uvAcha, he pitar Ishvarasya tava cha viruddhaM pApamakaravaM, tava putra_iti vikhyAto bhavituM na yogyosmi cha| 
\p  
\v 22 kintu tasya pitA nijadAsAn Adidesha, sarvvottamavastrANyAnIya paridhApayatainaM haste chA NgurIyakam arpayata pAdayoshchopAnahau samarpayata; 
\p  
\v 23 puShTaM govatsam AnIya mArayata cha taM bhuktvA vayam AnandAma| 
\p  
\v 24 yato mama putroyam amriyata punarajIvId hAritashcha labdhobhUt tatasta Ananditum Arebhire| 
\p  
\v 25 tatkAle tasya jyeShThaH putraH kShetra AsIt| atha sa niveshanasya nikaTaM AgachChan nR^ityAnAM vAdyAnA ncha shabdaM shrutvA 
\p  
\v 26 dAsAnAm ekam AhUya paprachCha, kiM kAraNamasya? 
\p  
\v 27 tataH sovAdIt, tava bhrAtAgamat, tava tAtashcha taM susharIraM prApya puShTaM govatsaM mAritavAn| 
\p  
\v 28 tataH sa prakupya niveshanAntaH praveShTuM na sammene; tatastasya pitA bahirAgatya taM sAdhayAmAsa| 
\p  
\v 29 tataH sa pitaraM pratyuvAcha, pashya tava kA nchidapyAj nAM na vilaMghya bahUn vatsarAn ahaM tvAM seve tathApi mitraiH sArddham utsavaM karttuM kadApi ChAgamekamapi mahyaM nAdadAH; 
\p  
\v 30 kintu tava yaH putro veshyAgamanAdibhistava sampattim apavyayitavAn tasminnAgatamAtre tasyaiva nimittaM puShTaM govatsaM mAritavAn| 
\p  
\v 31 tadA tasya pitAvochat, he putra tvaM sarvvadA mayA sahAsi tasmAn mama yadyadAste tatsarvvaM tava| 
\p  
\v 32 kintu tavAyaM bhrAtA mR^itaH punarajIvId hAritashcha bhUtvA prAptobhUt, etasmAt kAraNAd utsavAnandau karttum uchitamasmAkam| 
\c 16  
\p  
\v 1 apara ncha yIshuH shiShyebhyonyAmekAM kathAM kathayAmAsa kasyachid dhanavato manuShyasya gR^ihakAryyAdhIshe sampatterapavyaye.apavAdite sati 
\p  
\v 2 tasya prabhustam AhUya jagAda, tvayi yAmimAM kathAM shR^iNomi sA kIdR^ishI? tvaM gR^ihakAryyAdhIshakarmmaNo gaNanAM darshaya gR^ihakAryyAdhIshapade tvaM na sthAsyasi| 
\p  
\v 3 tadA sa gR^ihakAryyAdhIsho manasA chintayAmAsa, prabhu ryadi mAM gR^ihakAryyAdhIshapadAd bhraMshayati tarhi kiM kariShye.ahaM? mR^idaM khanituM mama shakti rnAsti bhikShitu ncha lajjiShye.ahaM| 
\p  
\v 4 ataeva mayi gR^ihakAryyAdhIshapadAt chyute sati yathA lokA mahyam AshrayaM dAsyanti tadarthaM yatkarmma mayA karaNIyaM tan nirNIyate| 
\p  
\v 5 pashchAt sa svaprabhorekaikam adhamarNam AhUya prathamaM paprachCha, tvatto me prabhuNA kati prApyam? 
\p  
\v 6 tataH sa uvAcha, ekashatADhakatailAni; tadA gR^ihakAryyAdhIshaH provAcha, tava patramAnIya shIghramupavishya tatra pa nchAshataM likha| 
\p  
\v 7 pashchAdanyamekaM paprachCha, tvatto me prabhuNA kati prApyam? tataH sovAdId ekashatADhakagodhUmAH; tadA sa kathayAmAsa, tava patramAnIya ashItiM likha| 
\p  
\v 8 tenaiva prabhustamayathArthakR^itam adhIshaM tadbuddhinaipuNyAt prashashaMsa; itthaM dIptirUpasantAnebhya etatsaMsArasya santAnA varttamAnakAle.adhikabuddhimanto bhavanti| 
\p  
\v 9 ato vadAmi yUyamapyayathArthena dhanena mitrANi labhadhvaM tato yuShmAsu padabhraShTeShvapi tAni chirakAlam AshrayaM dAsyanti| 
\p  
\v 10 yaH kashchit kShudre kAryye vishvAsyo bhavati sa mahati kAryyepi vishvAsyo bhavati, kintu yaH kashchit kShudre kAryye.avishvAsyo bhavati sa mahati kAryyepyavishvAsyo bhavati| 
\p  
\v 11 ataeva ayathArthena dhanena yadi yUyamavishvAsyA jAtAstarhi satyaM dhanaM yuShmAkaM kareShu kaH samarpayiShyati? 
\p  
\v 12 yadi cha paradhanena yUyam avishvAsyA bhavatha tarhi yuShmAkaM svakIyadhanaM yuShmabhyaM ko dAsyati? 
\p  
\v 13 kopi dAsa ubhau prabhU sevituM na shaknoti, yata ekasmin prIyamANo.anyasminnaprIyate yadvA ekaM janaM samAdR^itya tadanyaM tuchChIkaroti tadvad yUyamapi dhaneshvarau sevituM na shaknutha| 
\p  
\v 14 tadaitAH sarvvAH kathAH shrutvA lobhiphirUshinastamupajahasuH| 
\p  
\v 15 tataH sa uvAcha, yUyaM manuShyANAM nikaTe svAn nirdoShAn darshayatha kintu yuShmAkam antaHkaraNAnIshvaro jAnAti, yat manuShyANAm ati prashaMsyaM tad Ishvarasya ghR^iNyaM| 
\p  
\v 16 yohana AgamanaparyyanataM yuShmAkaM samIpe vyavasthAbhaviShyadvAdinAM lekhanAni chAsan tataH prabhR^iti IshvararAjyasya susaMvAdaH pracharati, ekaiko lokastanmadhyaM yatnena pravishati cha| 
\p  
\v 17 varaM nabhasaH pR^ithivyAshcha lopo bhaviShyati tathApi vyavasthAyA ekabindorapi lopo na bhaviShyati| 
\p  
\v 18 yaH kashchit svIyAM bhAryyAM vihAya striyamanyAM vivahati sa paradArAn gachChati, yashcha tA tyaktAM nArIM vivahati sopi paradArAna gachChati| 
\p  
\v 19 eko dhanI manuShyaH shuklAni sUkShmANi vastrANi paryyadadhAt pratidinaM paritoSharUpeNAbhuMktApivachcha| 
\p  
\v 20 sarvvA Nge kShatayukta iliyAsaranAmA kashchid daridrastasya dhanavato bhojanapAtrAt patitam uchChiShTaM bhoktuM vA nChan tasya dvAre patitvAtiShThat; 
\p  
\v 21 atha shvAna Agatya tasya kShatAnyalihan| 
\p  
\v 22 kiyatkAlAtparaM sa daridraH prANAn jahau; tataH svargIyadUtAstaM nItvA ibrAhImaH kroDa upaveshayAmAsuH| 
\p  
\v 23 pashchAt sa dhanavAnapi mamAra, taM shmashAne sthApayAmAsushcha; kintu paraloke sa vedanAkulaH san UrddhvAM nirIkShya bahudUrAd ibrAhImaM tatkroDa iliyAsara ncha vilokya ruvannuvAcha; 
\p  
\v 24 he pitar ibrAhIm anugR^ihya a NgulyagrabhAgaM jale majjayitvA mama jihvAM shItalAM karttum iliyAsaraM preraya, yato vahnishikhAtohaM vyathitosmi| 
\p  
\v 25 tadA ibrAhIm babhAShe, he putra tvaM jIvan sampadaM prAptavAn iliyAsarastu vipadaM prAptavAn etat smara, kintu samprati tasya sukhaM tava cha duHkhaM bhavati| 
\p  
\v 26 aparamapi yuShmAkam asmAka ncha sthAnayo rmadhye mahadvichChedo.asti tata etatsthAnasya lokAstat sthAnaM yAtuM yadvA tatsthAnasya lokA etat sthAnamAyAtuM na shaknuvanti| 
\p  
\v 27 tadA sa uktavAn, he pitastarhi tvAM nivedayAmi mama pitu rgehe ye mama pa ncha bhrAtaraH santi 
\p  
\v 28 te yathaitad yAtanAsthAnaM nAyAsyanti tathA mantraNAM dAtuM teShAM samIpam iliyAsaraM preraya| 
\p  
\v 29 tata ibrAhIm uvAcha, mUsAbhaviShyadvAdinA ncha pustakAni teShAM nikaTe santi te tadvachanAni manyantAM| 
\p  
\v 30 tadA sa nivedayAmAsa, he pitar ibrAhIm na tathA, kintu yadi mR^italokAnAM kashchit teShAM samIpaM yAti tarhi te manAMsi vyAghoTayiShyanti| 
\p  
\v 31 tata ibrAhIm jagAda, te yadi mUsAbhaviShyadvAdinA ncha vachanAni na manyante tarhi mR^italokAnAM kasmiMshchid utthitepi te tasya mantraNAM na maMsyante| 
\c 17  
\p  
\v 1 itaH paraM yIshuH shiShyAn uvAcha, vighnairavashyam AgantavyaM kintu vighnA yena ghaTiShyante tasya durgati rbhaviShyati| 
\p  
\v 2 eteShAM kShudraprANinAm ekasyApi vighnajananAt kaNThabaddhapeShaNIkasya tasya sAgarAgAdhajale majjanaM bhadraM| 
\p  
\v 3 yUyaM sveShu sAvadhAnAstiShThata; tava bhrAtA yadi tava ki nchid aparAdhyati tarhi taM tarjaya, tena yadi manaH parivarttayati tarhi taM kShamasva| 
\p  
\v 4 punarekadinamadhye yadi sa tava saptakR^itvo.aparAdhyati kintu saptakR^itva Agatya manaH parivartya mayAparAddham iti vadati tarhi taM kShamasva| 
\p  
\v 5 tadA preritAH prabhum avadan asmAkaM vishvAsaM varddhaya| 
\p  
\v 6 prabhuruvAcha, yadi yuShmAkaM sarShapaikapramANo vishvAsosti tarhi tvaM samUlamutpATito bhUtvA samudre ropito bhava kathAyAm etasyAm etaduDumbarAya kathitAyAM sa yuShmAkamAj nAvaho bhaviShyati| 
\p  
\v 7 aparaM svadAse halaM vAhayitvA vA pashUn chArayitvA kShetrAd Agate sati taM vadati, ehi bhoktumupavisha, yuShmAkam etAdR^ishaH kosti? 
\p  
\v 8 vara ncha pUrvvaM mama khAdyamAsAdya yAvad bhu nje pivAmi cha tAvad baddhakaTiH parichara pashchAt tvamapi bhokShyase pAsyasi cha kathAmIdR^ishIM kiM na vakShyati? 
\p  
\v 9 tena dAsena prabhorAj nAnurUpe karmmaNi kR^ite prabhuH kiM tasmin bAdhito jAtaH? netthaM budhyate mayA| 
\p  
\v 10 itthaM nirUpiteShu sarvvakarmmasu kR^iteShu satmu yUyamapIdaM vAkyaM vadatha, vayam anupakAriNo dAsA asmAbhiryadyatkarttavyaM tanmAtrameva kR^itaM| 
\p  
\v 11 sa yirUshAlami yAtrAM kurvvan shomiroNgAlIlpradeshamadhyena gachChati, 
\p  
\v 12 etarhi kutrachid grAme praveshamAtre dashakuShThinastaM sAkShAt kR^itvA 
\p  
\v 13 dUre tiShThanata uchchai rvaktumArebhire, he prabho yIsho dayasvAsmAn| 
\p  
\v 14 tataH sa tAn dR^iShTvA jagAda, yUyaM yAjakAnAM samIpe svAn darshayata, tataste gachChanto rogAt pariShkR^itAH| 
\p  
\v 15 tadA teShAmekaH svaM svasthaM dR^iShTvA prochchairIshvaraM dhanyaM vadan vyAghuTyAyAto yIsho rguNAnanuvadan tachcharaNAdhobhUmau papAta; 
\p  
\v 16 sa chAsIt shomiroNI| 
\p  
\v 17 tadA yIshuravadat, dashajanAH kiM na pariShkR^itAH? tahyanye navajanAH kutra? 
\p  
\v 18 IshvaraM dhanyaM vadantam enaM videshinaM vinA kopyanyo na prApyata| 
\p  
\v 19 tadA sa tamuvAcha, tvamutthAya yAhi vishvAsaste tvAM svasthaM kR^itavAn| 
\p  
\v 20 atha kadeshvarasya rAjatvaM bhaviShyatIti phirUshibhiH pR^iShTe sa pratyuvAcha, Ishvarasya rAjatvam aishvaryyadarshanena na bhaviShyati| 
\p  
\v 21 ata etasmin pashya tasmin vA pashya, iti vAkyaM lokA vaktuM na shakShyanti, Ishvarasya rAjatvaM yuShmAkam antarevAste| 
\p  
\v 22 tataH sa shiShyAn jagAda, yadA yuShmAbhi rmanujasutasya dinamekaM draShTum vA nChiShyate kintu na darshiShyate, IdR^ikkAla AyAti| 
\p  
\v 23 tadAtra pashya vA tatra pashyeti vAkyaM lokA vakShyanti, kintu teShAM pashchAt mA yAta, mAnugachChata cha| 
\p  
\v 24 yatastaDid yathAkAshaikadishyudiya tadanyAmapi dishaM vyApya prakAshate tadvat nijadine manujasUnuH prakAshiShyate| 
\p  
\v 25 kintu tatpUrvvaM tenAnekAni duHkhAni bhoktavyAnyetadvarttamAnalokaishcha so.avaj nAtavyaH| 
\p  
\v 26 nohasya vidyamAnakAle yathAbhavat manuShyasUnoH kAlepi tathA bhaviShyati| 
\p  
\v 27 yAvatkAlaM noho mahApotaM nArohad AplAvivAryyetya sarvvaM nAnAshayachcha tAvatkAlaM yathA lokA abhu njatApivan vyavahan vyavAhayaMshcha; 
\p  
\v 28 itthaM loTo varttamAnakAlepi yathA lokA bhojanapAnakrayavikrayaropaNagR^ihanirmmANakarmmasu prAvarttanta, 
\p  
\v 29 kintu yadA loT sidomo nirjagAma tadA nabhasaH sagandhakAgnivR^iShTi rbhUtvA sarvvaM vyanAshayat 
\p  
\v 30 tadvan mAnavaputraprakAshadinepi bhaviShyati| 
\p  
\v 31 tadA yadi kashchid gR^ihopari tiShThati tarhi sa gR^ihamadhyAt kimapi dravyamAnetum avaruhya naitu; yashcha kShetre tiShThati sopi vyAghuTya nAyAtu| 
\p  
\v 32 loTaH patnIM smarata| 
\p  
\v 33 yaH prANAn rakShituM cheShTiShyate sa prANAn hArayiShyati yastu prANAn hArayiShyati saeva prANAn rakShiShyati| 
\p  
\v 34 yuShmAnahaM vachmi tasyAM rAtrau shayyaikagatayo rlokayoreko dhAriShyate parastyakShyate| 
\p  
\v 35 striyau yugapat peShaNIM vyAvarttayiShyatastayorekA dhAriShyate parAtyakShyate| 
\p  
\v 36 puruShau kShetre sthAsyatastayoreko dhAriShyate parastyakShyate| 
\p  
\v 37 tadA te paprachChuH, he prabho kutretthaM bhaviShyati? tataH sa uvAcha, yatra shavastiShThati tatra gR^idhrA milanti| 
\c 18  
\p  
\v 1 apara ncha lokairaklAntai rnirantaraM prArthayitavyam ityAshayena yIshunA dR^iShTAnta ekaH kathitaH| 
\p  
\v 2 kutrachinnagare kashchit prADvivAka AsIt sa IshvarAnnAbibhet mAnuShAMshcha nAmanyata| 
\p  
\v 3 atha tatpuravAsinI kAchidvidhavA tatsamIpametya vivAdinA saha mama vivAdaM pariShkurvviti nivedayAmAsa| 
\p  
\v 4 tataH sa prADvivAkaH kiyaddinAni na tada NgIkR^itavAn pashchAchchitte chintayAmAsa, yadyapIshvarAnna bibhemi manuShyAnapi na manye 
\p  
\v 5 tathApyeShA vidhavA mAM klishnAti tasmAdasyA vivAdaM pariShkariShyAmi nochet sA sadAgatya mAM vyagraM kariShyati| 
\p  
\v 6 pashchAt prabhuravadad asAvanyAyaprADvivAko yadAha tatra mano nidhadhvaM| 
\p  
\v 7 Ishvarasya ye .abhiruchitalokA divAnishaM prArthayante sa bahudinAni vilambyApi teShAM vivAdAn kiM na pariShkariShyati? 
\p  
\v 8 yuShmAnahaM vadAmi tvarayA pariShkariShyati, kintu yadA manuShyaputra AgamiShyati tadA pR^ithivyAM kimIdR^ishaM vishvAsaM prApsyati? 
\p  
\v 9 ye svAn dhArmmikAn j nAtvA parAn tuchChIkurvvanti etAdR^igbhyaH, kiyadbhya imaM dR^iShTAntaM kathayAmAsa| 
\p  
\v 10 ekaH phirUshyaparaH karasa nchAyI dvAvimau prArthayituM mandiraM gatau| 
\p  
\v 11 tato.asau phirUshyekapArshve tiShThan he Ishvara ahamanyalokavat loThayitAnyAyI pAradArikashcha na bhavAmi asya karasa nchAyinastulyashcha na, tasmAttvAM dhanyaM vadAmi| 
\p  
\v 12 saptasu dineShu dinadvayamupavasAmi sarvvasampatte rdashamAMshaM dadAmi cha, etatkathAM kathayan prArthayAmAsa| 
\p  
\v 13 kintu sa karasa nchAyi dUre tiShThan svargaM draShTuM nechChan vakShasi karAghAtaM kurvvan he Ishvara pApiShThaM mAM dayasva, itthaM prArthayAmAsa| 
\p  
\v 14 yuShmAnahaM vadAmi, tayordvayo rmadhye kevalaH karasa nchAyI puNyavattvena gaNito nijagR^ihaM jagAma, yato yaH kashchit svamunnamayati sa nAmayiShyate kintu yaH kashchit svaM namayati sa unnamayiShyate| 
\p  
\v 15 atha shishUnAM gAtrasparshArthaM lokAstAn tasya samIpamAninyuH shiShyAstad dR^iShTvAnetR^in tarjayAmAsuH, 
\p  
\v 16 kintu yIshustAnAhUya jagAda, mannikaTam AgantuM shishUn anujAnIdhvaM tAMshcha mA vArayata; yata IshvararAjyAdhikAriNa eShAM sadR^ishAH| 
\p  
\v 17 ahaM yuShmAn yathArthaM vadAmi, yo janaH shishoH sadR^isho bhUtvA IshvararAjyaM na gR^ihlAti sa kenApi prakAreNa tat praveShTuM na shaknoti| 
\p  
\v 18 aparam ekodhipatistaM paprachCha, he paramaguro, anantAyuShaH prAptaye mayA kiM karttavyaM? 
\p  
\v 19 yIshuruvAcha, mAM kutaH paramaM vadasi? IshvaraM vinA kopi paramo na bhavati| 
\p  
\v 20 paradArAn mA gachCha, naraM mA jahi, mA choraya, mithyAsAkShyaM mA dehi, mAtaraM pitara ncha saMmanyasva, etA yA Aj nAH santi tAstvaM jAnAsi| 
\p  
\v 21 tadA sa uvAcha, bAlyakAlAt sarvvA etA AcharAmi| 
\p  
\v 22 iti kathAM shrutvA yIshustamavadat, tathApi tavaikaM karmma nyUnamAste, nijaM sarvvasvaM vikrIya daridrebhyo vitara, tasmAt svarge dhanaM prApsyasi; tata Agatya mamAnugAmI bhava| 
\p  
\v 23 kintvetAM kathAM shrutvA sodhipatiH shushocha, yatastasya bahudhanamAsIt| 
\p  
\v 24 tadA yIshustamatishokAnvitaM dR^iShTvA jagAda, dhanavatAm IshvararAjyapraveshaH kIdR^ig duShkaraH| 
\p  
\v 25 IshvararAjye dhaninaH praveshAt sUcheshChidreNa mahA Ngasya gamanAgamane sukare| 
\p  
\v 26 shrotAraH paprachChustarhi kena paritrANaM prApsyate? 
\p  
\v 27 sa uktavAn, yan mAnuSheNAshakyaM tad IshvareNa shakyaM| 
\p  
\v 28 tadA pitara uvAcha, pashya vayaM sarvvasvaM parityajya tava pashchAdgAmino.abhavAma| 
\p  
\v 29 tataH sa uvAcha, yuShmAnahaM yathArthaM vadAmi, IshvararAjyArthaM gR^ihaM pitarau bhrAtR^igaNaM jAyAM santAnAMshcha tyaktavA 
\p  
\v 30 iha kAle tato.adhikaM parakAle .anantAyushcha na prApsyati loka IdR^ishaH kopi nAsti| 
\p  
\v 31 anantaraM sa dvAdashashiShyAnAhUya babhAShe, pashyata vayaM yirUshAlamnagaraM yAmaH, tasmAt manuShyaputre bhaviShyadvAdibhiruktaM yadasti tadanurUpaM taM prati ghaTiShyate; 
\p  
\v 32 vastutastu so.anyadeshIyAnAM hasteShu samarpayiShyate, te tamupahasiShyanti, anyAyamAchariShyanti tadvapuShi niShThIvaM nikShepsyanti, kashAbhiH prahR^itya taM haniShyanti cha, 
\p  
\v 33 kintu tR^itIyadine sa shmashAnAd utthAsyati| 
\p  
\v 34 etasyAH kathAyA abhiprAyaM ki nchidapi te boddhuM na shekuH teShAM nikaTe.aspaShTatavAt tasyaitAsAM kathAnAm AshayaM te j nAtuM na shekushcha| 
\p  
\v 35 atha tasmin yirIhoH purasyAntikaM prApte kashchidandhaH pathaH pArshva upavishya bhikShAm akarot 
\p  
\v 36 sa lokasamUhasya gamanashabdaM shrutvA tatkAraNaM pR^iShTavAn| 
\p  
\v 37 nAsaratIyayIshuryAtIti lokairukte sa uchchairvaktumArebhe, 
\p  
\v 38 he dAyUdaH santAna yIsho mAM dayasva| 
\p  
\v 39 tatogragAminastaM maunI tiShTheti tarjayAmAsuH kintu sa punAruvan uvAcha, he dAyUdaH santAna mAM dayasva| 
\p  
\v 40 tadA yIshuH sthagito bhUtvA svAntike tamAnetum Adidesha| 
\p  
\v 41 tataH sa tasyAntikam Agamat, tadA sa taM paprachCha, tvaM kimichChasi? tvadarthamahaM kiM kariShyAmi? sa uktavAn, he prabho.ahaM draShTuM labhai| 
\p  
\v 42 tadA yIshuruvAcha, dR^iShTishaktiM gR^ihANa tava pratyayastvAM svasthaM kR^itavAn| 
\p  
\v 43 tatastatkShaNAt tasya chakShuShI prasanne; tasmAt sa IshvaraM dhanyaM vadan tatpashchAd yayau, tadAlokya sarvve lokA IshvaraM prashaMsitum Arebhire| 
\c 19  
\p  
\v 1 yadA yIshu ryirIhopuraM pravishya tanmadhyena gachChaMstadA 
\p  
\v 2 sakkeyanAmA karasa nchAyinAM pradhAno dhanavAneko 
\p  
\v 3 yIshuH kIdR^igiti draShTuM cheShTitavAn kintu kharvvatvAllokasaMghamadhye taddarshanamaprApya 
\p  
\v 4 yena pathA sa yAsyati tatpathe.agre dhAvitvA taM draShTum uDumbaratarumAruroha| 
\p  
\v 5 pashchAd yIshustatsthAnam itvA UrddhvaM vilokya taM dR^iShTvAvAdIt, he sakkeya tvaM shIghramavaroha mayAdya tvadgehe vastavyaM| 
\p  
\v 6 tataH sa shIghramavaruhya sAhlAdaM taM jagrAha| 
\p  
\v 7 tad dR^iShTvA sarvve vivadamAnA vaktumArebhire, sotithitvena duShTalokagR^ihaM gachChati| 
\p  
\v 8 kintu sakkeyo daNDAyamAno vaktumArebhe, he prabho pashya mama yA sampattirasti tadarddhaM daridrebhyo dade, aparam anyAyaM kR^itvA kasmAdapi yadi kadApi ki nchit mayA gR^ihItaM tarhi tachchaturguNaM dadAmi| 
\p  
\v 9 tadA yIshustamuktavAn ayamapi ibrAhImaH santAno.ataH kAraNAd adyAsya gR^ihe trANamupasthitaM| 
\p  
\v 10 yad hAritaM tat mR^igayituM rakShitu ncha manuShyaputra AgatavAn| 
\p  
\v 11 atha sa yirUshAlamaH samIpa upAtiShThad IshvararAjatvasyAnuShThAnaM tadaiva bhaviShyatIti lokairanvabhUyata, tasmAt sa shrotR^ibhyaH punardR^iShTAntakathAm utthApya kathayAmAsa| 
\p  
\v 12 kopi mahAlloko nijArthaM rAjatvapadaM gR^ihItvA punarAgantuM dUradeshaM jagAma| 
\p  
\v 13 yAtrAkAle nijAn dashadAsAn AhUya dashasvarNamudrA dattvA mamAgamanaparyyantaM vANijyaM kurutetyAdidesha| 
\p  
\v 14 kintu tasya prajAstamavaj nAya manuShyamenam asmAkamupari rAjatvaM na kArayivyAma imAM vArttAM tannikaTe prerayAmAsuH| 
\p  
\v 15 atha sa rAjatvapadaM prApyAgatavAn ekaiko jano bANijyena kiM labdhavAn iti j nAtuM yeShu dAseShu mudrA arpayat tAn AhUyAnetum Adidesha| 
\p  
\v 16 tadA prathama Agatya kathitavAn, he prabho tava tayaikayA mudrayA dashamudrA labdhAH| 
\p  
\v 17 tataH sa uvAcha tvamuttamo dAsaH svalpena vishvAsyo jAta itaH kAraNAt tvaM dashanagarANAm adhipo bhava| 
\p  
\v 18 dvitIya Agatya kathitavAn, he prabho tavaikayA mudrayA pa nchamudrA labdhAH| 
\p  
\v 19 tataH sa uvAcha, tvaM pa nchAnAM nagarANAmadhipati rbhava| 
\p  
\v 20 tatonya Agatya kathayAmAsa, he prabho pashya tava yA mudrA ahaM vastre baddhvAsthApayaM seyaM| 
\p  
\v 21 tvaM kR^ipaNo yannAsthApayastadapi gR^ihlAsi, yannAvapastadeva cha Chinatsi tatohaM tvatto bhItaH| 
\p  
\v 22 tadA sa jagAda, re duShTadAsa tava vAkyena tvAM doShiNaM kariShyAmi, yadahaM nAsthApayaM tadeva gR^ihlAmi, yadahaM nAvapa ncha tadeva Chinadmi, etAdR^ishaH kR^ipaNohamiti yadi tvaM jAnAsi, 
\p  
\v 23 tarhi mama mudrA baNijAM nikaTe kuto nAsthApayaH? tayA kR^ite.aham Agatya kusIdena sArddhaM nijamudrA aprApsyam| 
\p  
\v 24 pashchAt sa samIpasthAn janAn Aj nApayat asmAt mudrA AnIya yasya dashamudrAH santi tasmai datta| 
\p  
\v 25 te prochuH prabho.asya dashamudrAH santi| 
\p  
\v 26 yuShmAnahaM vadAmi yasyAshraye vaddhate .adhikaM tasmai dAyiShyate, kintu yasyAshraye na varddhate tasya yadyadasti tadapi tasmAn nAyiShyate| 
\p  
\v 27 kintu mamAdhipatitvasya vashatve sthAtum asammanyamAnA ye mama ripavastAnAnIya mama samakShaM saMharata| 
\p  
\v 28 ityupadeshakathAM kathayitvA sogragaH san yirUshAlamapuraM yayau| 
\p  
\v 29 tato baitphagIbaithanIyAgrAmayoH samIpe jaitunAdrerantikam itvA shiShyadvayam ityuktvA preShayAmAsa, 
\p  
\v 30 yuvAmamuM sammukhasthagrAmaM pravishyaiva yaM kopi mAnuShaH kadApi nArohat taM garddabhashAvakaM baddhaM drakShyathastaM mochayitvAnayataM| 
\p  
\v 31 tatra kuto mochayathaH? iti chet kopi vakShyati tarhi vakShyathaH prabheाratra prayojanam Aste| 
\p  
\v 32 tadA tau praritau gatvA tatkathAाnusAreNa sarvvaM prAptau| 
\p  
\v 33 gardabhashAvakamochanakAle tatvAmina UchuH, gardabhashAvakaM kuto mochayathaH? 
\p  
\v 34 tAvUchatuH prabhoratra prayojanam Aste| 
\p  
\v 35 pashchAt tau taM gardabhashAvakaM yIshorantikamAnIya tatpR^iShThe nijavasanAni pAtayitvA tadupari yIshumArohayAmAsatuH| 
\p  
\v 36 atha yAtrAkAle lokAH pathi svavastrANi pAtayitum Arebhire| 
\p  
\v 37 aparaM jaitunAdrerupatyakAm itvA shiShyasaMghaH pUrvvadR^iShTAni mahAkarmmANi smR^itvA, 
\p  
\v 38 yo rAjA prabho rnAmnAyAti sa dhanyaH svarge kushalaM sarvvochche jayadhvani rbhavatu, kathAmetAM kathayitvA sAnandam uchairIshvaraM dhanyaM vaktumArebhe| 
\p  
\v 39 tadA lokAraNyamadhyasthAH kiyantaH phirUshinastat shrutvA yIshuM prochuH, he upadeshaka svashiShyAn tarjaya| 
\p  
\v 40 sa uvAcha, yuShmAnahaM vadAmi yadyamI nIravAstiShThanti tarhi pAShANA uchaiH kathAH kathayiShyanti| 
\p  
\v 41 pashchAt tatpurAntikametya tadavalokya sAshrupAtaM jagAda, 
\p  
\v 42 hA hA chet tvamagre.aj nAsyathAH, tavAsminneva dine vA yadi svama Ngalam upAlapsyathAH, tarhyuttamam abhaviShyat, kintu kShaNesmin tattava dR^iShTeragocharam bhavati| 
\p  
\v 43 tvaM svatrANakAle na mano nyadhatthA iti heto ryatkAle tava ripavastvAM chaturdikShu prAchIreNa veShTayitvA rotsyanti 
\p  
\v 44 bAlakaiH sArddhaM bhUmisAt kariShyanti cha tvanmadhye pAShANaikopi pAShANopari na sthAsyati cha, kAla IdR^isha upasthAsyati| 
\p  
\v 45 atha madhyemandiraM pravishya tatratyAn krayivikrayiNo bahiShkurvvan 
\p  
\v 46 avadat madgR^ihaM prArthanAgR^ihamiti lipirAste kintu yUyaM tadeva chairANAM gahvaraM kurutha| 
\p  
\v 47 pashchAt sa pratyahaM madhyemandiram upadidesha; tataH pradhAnayAjakA adhyApakAH prAchInAshcha taM nAshayituM chicheShTire; 
\p  
\v 48 kintu tadupadeshe sarvve lokA niviShTachittAH sthitAstasmAt te tatkarttuM nAvakAshaM prApuH| 
\c 20  
\p  
\v 1 athaikadA yIshu rmanidare susaMvAdaM prachArayan lokAnupadishati, etarhi pradhAnayAjakA adhyApakAH prA nchashcha tannikaTamAgatya paprachChuH 
\p  
\v 2 kayAj nayA tvaM karmmANyetAni karoShi? ko vA tvAmAj nApayat? tadasmAn vada| 
\p  
\v 3 sa pratyuvAcha, tarhi yuShmAnapi kathAmekAM pR^ichChAmi tasyottaraM vadata| 
\p  
\v 4 yohano majjanam Ishvarasya mAnuShANAM vAj nAto jAtaM? 
\p  
\v 5 tataste mitho vivichya jagaduH, yadIshvarasya vadAmastarhi taM kuto na pratyaita sa iti vakShyati| 
\p  
\v 6 yadi manuShyasyeti vadAmastarhi sarvve lokA asmAn pAShANai rhaniShyanti yato yohan bhaviShyadvAdIti sarvve dR^iDhaM jAnanti| 
\p  
\v 7 ataeva te pratyUchuH kasyAj nayA jAtam iti vaktuM na shaknumaH| 
\p  
\v 8 tadA yIshuravadat tarhi kayAj nayA karmmANyetAti karomIti cha yuShmAn na vakShyAmi| 
\p  
\v 9 atha lokAnAM sAkShAt sa imAM dR^iShTAntakathAM vaktumArebhe, kashchid drAkShAkShetraM kR^itvA tat kShetraM kR^iShIvalAnAM hasteShu samarpya bahukAlArthaM dUradeshaM jagAma| 
\p  
\v 10 atha phalakAle phalAni grahItu kR^iShIvalAnAM samIpe dAsaM prAhiNot kintu kR^iShIvalAstaM prahR^itya riktahastaM visasarjuH| 
\p  
\v 11 tataH sodhipatiH punaranyaM dAsaM preShayAmAsa, te tamapi prahR^itya kuvyavahR^itya riktahastaM visasR^ijuH| 
\p  
\v 12 tataH sa tR^itIyavAram anyaM prAhiNot te tamapi kShatA NgaM kR^itvA bahi rnichikShipuH| 
\p  
\v 13 tadA kShetrapati rvichArayAmAsa, mamedAnIM kiM karttavyaM? mama priye putre prahite te tamavashyaM dR^iShTvA samAdariShyante| 
\p  
\v 14 kintu kR^iShIvalAstaM nirIkShya parasparaM vivichya prochuH, ayamuttarAdhikArI AgachChatainaM hanmastatodhikArosmAkaM bhaviShyati| 
\p  
\v 15 tataste taM kShetrAd bahi rnipAtya jaghnustasmAt sa kShetrapatistAn prati kiM kariShyati? 
\p  
\v 16 sa Agatya tAn kR^iShIvalAn hatvA pareShAM hasteShu tatkShetraM samarpayiShyati; iti kathAM shrutvA te .avadan etAdR^ishI ghaTanA na bhavatu| 
\p  
\v 17 kintu yIshustAnavalokya jagAda, tarhi, sthapatayaH kariShyanti grAvANaM yantu tuchChakaM| pradhAnaprastaraH koNe sa eva hi bhaviShyati| etasya shAstrIyavachanasya kiM tAtparyyaM? 
\p  
\v 18 aparaM tatpAShANopari yaH patiShyati sa bhaMkShyate kintu yasyopari sa pAShANaH patiShyati sa tena dhUlivach chUrNIbhaviShyati| 
\p  
\v 19 sosmAkaM viruddhaM dR^iShTAntamimaM kathitavAn iti j nAtvA pradhAnayAjakA adhyApakAshcha tadaiva taM dhartuM vavA nChuH kintu lokebhyo bibhyuH| 
\p  
\v 20 ataeva taM prati satarkAH santaH kathaM tadvAkyadoShaM dhR^itvA taM deshAdhipasya sAdhuveshadhAriNashcharAn tasya samIpe preShayAmAsuH| 
\p  
\v 21 tadA te taM paprachChuH, he upadeshaka bhavAn yathArthaM kathayan upadishati, kamapyanapekShya satyatvenaishvaraM mArgamupadishati, vayametajjAnImaH| 
\p  
\v 22 kaisararAjAya karosmAbhi rdeyo na vA? 
\p  
\v 23 sa teShAM va nchanaM j nAtvAvadat kuto mAM parIkShadhve? mAM mudrAmekaM darshayata| 
\p  
\v 24 iha likhitA mUrtiriyaM nAma cha kasya? te.avadan kaisarasya| 
\p  
\v 25 tadA sa uvAcha, tarhi kaisarasya dravyaM kaisarAya datta; Ishvarasya tu dravyamIshvarAya datta| 
\p  
\v 26 tasmAllokAnAM sAkShAt tatkathAyAH kamapi doShaM dhartumaprApya te tasyottarAd AshcharyyaM manyamAnA mauninastasthuH| 
\p  
\v 27 apara ncha shmashAnAdutthAnAna NgIkAriNAM sidUkinAM kiyanto janA Agatya taM paprachChuH, 
\p  
\v 28 he upadeshaka shAstre mUsA asmAn pratIti lilekha yasya bhrAtA bhAryyAyAM satyAM niHsantAno mriyate sa tajjAyAM vivahya tadvaMsham utpAdayiShyati| 
\p  
\v 29 tathAcha kechit sapta bhrAtara Asan teShAM jyeShTho bhrAtA vivahya nirapatyaH prANAn jahau| 
\p  
\v 30 atha dvitIyastasya jAyAM vivahya nirapatyaH san mamAra| tR^itIyashcha tAmeva vyuvAha; 
\p  
\v 31 itthaM sapta bhrAtarastAmeva vivahya nirapatyAH santo mamruH| 
\p  
\v 32 sheShe sA strI cha mamAra| 
\p  
\v 33 ataeva shmashAnAdutthAnakAle teShAM saptajanAnAM kasya sA bhAryyA bhaviShyati? yataH sA teShAM saptAnAmeva bhAryyAsIt| 
\p  
\v 34 tadA yIshuH pratyuvAcha, etasya jagato lokA vivahanti vAgdattAshcha bhavanti 
\p  
\v 35 kintu ye tajjagatprAptiyogyatvena gaNitAM bhaviShyanti shmashAnAchchotthAsyanti te na vivahanti vAgdattAshcha na bhavanti, 
\p  
\v 36 te puna rna mriyante kintu shmashAnAdutthApitAH santa Ishvarasya santAnAH svargIyadUtAnAM sadR^ishAshcha bhavanti| 
\p  
\v 37 adhikantu mUsAH stambopAkhyAne parameshvara IbrAhIma Ishvara ishAka Ishvaro yAkUbashcheshvara ityuktvA mR^itAnAM shmashAnAd utthAnasya pramANaM lilekha| 
\p  
\v 38 ataeva ya IshvaraH sa mR^itAnAM prabhu rna kintu jIvatAmeva prabhuH, tannikaTe sarvve jIvantaH santi| 
\p  
\v 39 iti shrutvA kiyantodhyApakA UchuH, he upadeshaka bhavAn bhadraM pratyuktavAn| 
\p  
\v 40 itaH paraM taM kimapi praShTaM teShAM pragalbhatA nAbhUt| 
\p  
\v 41 pashchAt sa tAn uvAcha, yaH khrIShTaH sa dAyUdaH santAna etAM kathAM lokAH kathaM kathayanti? 
\p  
\v 42 yataH mama prabhumidaM vAkyamavadat parameshvaraH| tava shatrUnahaM yAvat pAdapIThaM karomi na| tAvat kAlaM madIye tvaM dakShapArshva upAvisha| 
\p  
\v 43 iti kathAM dAyUd svayaM gItagranthe.avadat| 
\p  
\v 44 ataeva yadi dAyUd taM prabhuM vadati, tarhi sa kathaM tasya santAno bhavati? 
\p  
\v 45 pashchAd yIshuH sarvvajanAnAM karNagochare shiShyAnuvAcha, 
\p  
\v 46 ye.adhyApakA dIrghaparichChadaM paridhAya bhramanti, haTTApaNayo rnamaskAre bhajanagehasya prochchAsane bhojanagR^ihasya pradhAnasthAne cha prIyante 
\p  
\v 47 vidhavAnAM sarvvasvaM grasitvA Chalena dIrghakAlaM prArthayante cha teShu sAvadhAnA bhavata, teShAmugradaNDo bhaviShyati| 
\c 21  
\p  
\v 1 atha dhanilokA bhANDAgAre dhanaM nikShipanti sa tadeva pashyati, 
\p  
\v 2 etarhi kAchiddInA vidhavA paNadvayaM nikShipati tad dadarsha| 
\p  
\v 3 tato yIshuruvAcha yuShmAnahaM yathArthaM vadAmi, daridreyaM vidhavA sarvvebhyodhikaM nyakShepsIt, 
\p  
\v 4 yatonye svaprAjyadhanebhya IshvarAya ki nchit nyakShepsuH, kintu daridreyaM vidhavA dinayApanArthaM svasya yat ki nchit sthitaM tat sarvvaM nyakShepsIt| 
\p  
\v 5 apara ncha uttamaprastarairutsR^iShTavyaishcha mandiraM sushobhatetarAM kaishchidityukte sa pratyuvAcha 
\p  
\v 6 yUyaM yadidaM nichayanaM pashyatha, asya pAShANaikopyanyapAShANopari na sthAsyati, sarvve bhUsAdbhaviShyanti kAloyamAyAti| 
\p  
\v 7 tadA te paprachChuH, he guro ghaTanedR^ishI kadA bhaviShyati? ghaTanAyA etasyasashchihnaM vA kiM bhaviShyati? 
\p  
\v 8 tadA sa jagAda, sAvadhAnA bhavata yathA yuShmAkaM bhramaM kopi na janayati, khIShTohamityuktvA mama nAmrA bahava upasthAsyanti sa kAlaH prAyeNopasthitaH, teShAM pashchAnmA gachChata| 
\p  
\v 9 yuddhasyopaplavasya cha vArttAM shrutvA mA sha NkadhvaM, yataH prathamam etA ghaTanA avashyaM bhaviShyanti kintu nApAte yugAnto bhaviShyati| 
\p  
\v 10 apara ncha kathayAmAsa, tadA deshasya vipakShatvena desho rAjyasya vipakShatvena rAjyam utthAsyati, 
\p  
\v 11 nAnAsthAneShu mahAbhUkampo durbhikShaM mArI cha bhaviShyanti, tathA vyomamaNDalasya bhaya NkaradarshanAnyashcharyyalakShaNAni cha prakAshayiShyante| 
\p  
\v 12 kintu sarvvAsAmetAsAM ghaTanAnAM pUrvvaM lokA yuShmAn dhR^itvA tADayiShyanti, bhajanAlaye kArAyA ncha samarpayiShyanti mama nAmakAraNAd yuShmAn bhUpAnAM shAsakAnA ncha sammukhaM neShyanti cha| 
\p  
\v 13 sAkShyArtham etAni yuShmAn prati ghaTiShyante| 
\p  
\v 14 tadA kimuttaraM vaktavyam etat na chintayiShyAma iti manaHsu nishchitanuta| 
\p  
\v 15 vipakShA yasmAt kimapyuttaram Apatti ncha karttuM na shakShyanti tAdR^ishaM vAkpaTutvaM j nAna ncha yuShmabhyaM dAsyAmi| 
\p  
\v 16 ki ncha yUyaM pitrA mAtrA bhrAtrA bandhunA j nAtyA kuTumbena cha parakareShu samarpayiShyadhve; tataste yuShmAkaM ka nchana ka nchana ghAtayiShyanti| 
\p  
\v 17 mama nAmnaH kAraNAt sarvvai rmanuShyai ryUyam R^itIyiShyadhve| 
\p  
\v 18 kintu yuShmAkaM shiraHkeshaikopi na vinaMkShyati, 
\p  
\v 19 tasmAdeva dhairyyamavalambya svasvaprANAn rakShata| 
\p  
\v 20 apara ncha yirUshAlampuraM sainyaveShTitaM vilokya tasyochChinnatAyAH samayaH samIpa ityavagamiShyatha| 
\p  
\v 21 tadA yihUdAdeshasthA lokAH parvvataM palAyantAM, ye cha nagare tiShThanti te deshAntaraM palAyantA, ye cha grAme tiShThanti te nagaraM na pravishantu, 
\p  
\v 22 yatastadA samuchitadaNDanAya dharmmapustake yAni sarvvANi likhitAni tAni saphalAni bhaviShyanti| 
\p  
\v 23 kintu yA yAstadA garbhavatyaH stanyadAvyashcha tAmAM durgati rbhaviShyati, yata etAllokAn prati kopo deshe cha viShamadurgati rghaTiShyate| 
\p  
\v 24 vastutastu te kha NgadhAraparivva NgaM lapsyante baddhAH santaH sarvvadesheShu nAyiShyante cha ki nchAnyadeshIyAnAM samayopasthitiparyyantaM yirUshAlampuraM taiH padatalai rdalayiShyate| 
\p  
\v 25 sUryyachandranakShatreShu lakShaNAdi bhaviShyanti, bhuvi sarvvadeshIyAnAM duHkhaM chintA cha sindhau vIchInAM tarjanaM garjana ncha bhaviShyanti| 
\p  
\v 26 bhUbhau bhAvighaTanAM chintayitvA manujA bhiyAmR^itakalpA bhaviShyanti, yato vyomamaNDale tejasvino dolAyamAnA bhaviShyanti| 
\p  
\v 27 tadA parAkrameNA mahAtejasA cha meghArUDhaM manuShyaputram AyAntaM drakShyanti| 
\p  
\v 28 kintvetAsAM ghaTanAnAmArambhe sati yUyaM mastakAnyuttolya UrdadhvaM drakShyatha, yato yuShmAkaM mukteH kAlaH savidho bhaviShyati| 
\p  
\v 29 tatastenaitadR^iShTAntakathA kathitA, pashyata uDumbarAdivR^ikShANAM 
\p  
\v 30 navInapatrANi jAtAnIti dR^iShTvA nidAvakAla upasthita iti yathA yUyaM j nAtuM shaknutha, 
\p  
\v 31 tathA sarvvAsAmAsAM ghaTanAnAm Arambhe dR^iShTe satIshvarasya rAjatvaM nikaTam ityapi j nAsyatha| 
\p  
\v 32 yuShmAnahaM yathArthaM vadAmi, vidyamAnalokAnAmeShAM gamanAt pUrvvam etAni ghaTiShyante| 
\p  
\v 33 nabhobhuvorlopo bhaviShyati mama vAk tu kadApi luptA na bhaviShyati| 
\p  
\v 34 ataeva viShamAshanena pAnena cha sAMmArikachintAbhishcha yuShmAkaM chitteShu matteShu taddinam akasmAd yuShmAn prati yathA nopatiShThati tadarthaM sveShu sAvadhAnAstiShThata| 
\p  
\v 35 pR^ithivIsthasarvvalokAn prati taddinam unmAtha iva upasthAsyati| 
\p  
\v 36 yathA yUyam etadbhAvighaTanA uttarttuM manujasutasya sammukhe saMsthAtu ncha yogyA bhavatha kAraNAdasmAt sAvadhAnAH santo nirantaraM prArthayadhvaM| 
\p  
\v 37 apara ncha sa divA mandira upadishya rAchai jaitunAdriM gatvAtiShThat| 
\p  
\v 38 tataH pratyUShe lAkAstatkathAM shrotuM mandire tadantikam AgachChan| 
\c 22  
\p  
\v 1 apara ncha kiNvashUnyapUpotsavasya kAla upasthite 
\p  
\v 2 pradhAnayAjakA adhyAyakAshcha yathA taM hantuM shaknuvanti tathopAyAm acheShTanta kintu lokebhyo bibhyuH| 
\p  
\v 3 etastin samaye dvAdashashiShyeShu gaNita IShkariyotIyarUDhimAn yo yihUdAstasyAntaHkaraNaM shaitAnAshritatvAt 
\p  
\v 4 sa gatvA yathA yIshuM teShAM kareShu samarpayituM shaknoti tathA mantraNAM pradhAnayAjakaiH senApatibhishcha saha chakAra| 
\p  
\v 5 tena te tuShTAstasmai mudrAM dAtuM paNaM chakruH| 
\p  
\v 6 tataH so NgIkR^itya yathA lokAnAmagochare taM parakareShu samarpayituM shaknoti tathAvakAshaM cheShTitumArebhe| 
\p  
\v 7 atha kiNvashUnyapUpotmavadine, arthAt yasmin dine nistArotsavasya meSho hantavyastasmin dine 
\p  
\v 8 yIshuH pitaraM yohana nchAhUya jagAda, yuvAM gatvAsmAkaM bhojanArthaM nistArotsavasya dravyANyAsAdayataM| 
\p  
\v 9 tadA tau paprachChatuH kuchAsAdayAvo bhavataH kechChA? 
\p  
\v 10 tadA sovAdIt, nagare praviShTe kashchijjalakumbhamAdAya yuvAM sAkShAt kariShyati sa yanniveshanaM pravishati yuvAmapi tanniveshanaM tatpashchAditvA niveshanapatim iti vAkyaM vadataM, 
\p  
\v 11 yatrAhaM nistArotsavasya bhojyaM shiShyaiH sArddhaM bhoktuM shaknomi sAtithishAlAा kutra? kathAmimAM prabhustvAM pR^ichChati| 
\p  
\v 12 tataH sa jano dvitIyaprakoShThIyam ekaM shastaM koShThaM darshayiShyati tatra bhojyamAsAdayataM| 
\p  
\v 13 tatastau gatvA tadvAkyAnusAreNa sarvvaM dR^iShdvA tatra nistArotsavIyaM bhojyamAsAdayAmAsatuH| 
\p  
\v 14 atha kAla upasthite yIshu rdvAdashabhiH preritaiH saha bhoktumupavishya kathitavAn 
\p  
\v 15 mama duHkhabhogAt pUrvvaM yubhAbhiH saha nistArotsavasyaitasya bhojyaM bhoktuM mayAtivA nChA kR^itA| 
\p  
\v 16 yuShmAn vadAmi, yAvatkAlam IshvararAjye bhojanaM na kariShye tAvatkAlam idaM na bhokShye| 
\p  
\v 17 tadA sa pAnapAtramAdAya Ishvarasya guNAn kIrttayitvA tebhyo datvAvadat, idaM gR^ihlIta yUyaM vibhajya pivata| 
\p  
\v 18 yuShmAn vadAmi yAvatkAlam IshvararAjatvasya saMsthApanaM na bhavati tAvad drAkShAphalarasaM na pAsyAmi| 
\p  
\v 19 tataH pUpaM gR^ihItvA IshvaraguNAn kIrttayitvA bha NktA tebhyo datvAvadat, yuShmadarthaM samarpitaM yanmama vapustadidaM, etat karmma mama smaraNArthaM kurudhvaM| 
\p  
\v 20 atha bhojanAnte tAdR^ishaM pAtraM gR^ihItvAvadat, yuShmatkR^ite pAtitaM yanmama raktaM tena nirNItanavaniyamarUpaM pAnapAtramidaM| 
\p  
\v 21 pashyata yo mAM parakareShu samarpayiShyati sa mayA saha bhojanAsana upavishati| 
\p  
\v 22 yathA nirUpitamAste tadanusAreNA manuShyapuुtrasya gati rbhaviShyati kintu yastaM parakareShu samarpayiShyati tasya santApo bhaviShyati| 
\p  
\v 23 tadA teShAM ko jana etat karmma kariShyati tat te parasparaM praShTumArebhire| 
\p  
\v 24 aparaM teShAM ko janaH shreShThatvena gaNayiShyate, atrArthe teShAM vivAdobhavat| 
\p  
\v 25 asmAt kAraNAt sovadat, anyadeshIyAnAM rAjAnaH prajAnAmupari prabhutvaM kurvvanti dAruNashAsanaM kR^itvApi te bhUpatitvena vikhyAtA bhavanti cha| 
\p  
\v 26 kintu yuShmAkaM tathA na bhaviShyati, yo yuShmAkaM shreShTho bhaviShyati sa kaniShThavad bhavatu, yashcha mukhyo bhaviShyati sa sevakavadbhavatu| 
\p  
\v 27 bhojanopaviShTaparichArakayoH kaH shreShThaH? yo bhojanAyopavishati sa kiM shreShTho na bhavati? kintu yuShmAkaM madhye.ahaM parichAraka_ivAsmi| 
\p  
\v 28 apara ncha yuyaM mama parIkShAkAle prathamamArabhya mayA saha sthitA 
\p  
\v 29 etatkAraNAt pitrA yathA madarthaM rAjyamekaM nirUpitaM tathAhamapi yuShmadarthaM rAjyaM nirUpayAmi| 
\p  
\v 30 tasmAn mama rAjye bhojanAsane cha bhojanapAne kariShyadhve siMhAsaneShUpavishya chesrAyelIyAnAM dvAdashavaMshAnAM vichAraM kariShyadhve| 
\p  
\v 31 aparaM prabhuruvAcha, he shimon pashya tita_unA dhAnyAnIva yuShmAn shaitAn chAlayitum aichChat, 
\p  
\v 32 kintu tava vishvAsasya lopo yathA na bhavati etat tvadarthaM prArthitaM mayA, tvanmanasi parivarttite cha bhrAtR^iNAM manAMsi sthirIkuru| 
\p  
\v 33 tadA sovadat, he prabhohaM tvayA sArddhaM kArAM mR^iti ncha yAtuM majjitosmi| 
\p  
\v 34 tataH sa uvAcha, he pitara tvAM vadAmi, adya kukkuTaravAt pUrvvaM tvaM matparichayaM vAratrayam apahvoShyase| 
\p  
\v 35 aparaM sa paprachCha, yadA mudrAsampuTaM khAdyapAtraM pAdukA ncha vinA yuShmAn prAhiNavaM tadA yuShmAkaM kasyApi nyUnatAsIt? te prochuH kasyApi na| 
\p  
\v 36 tadA sovadat kintvidAnIM mudrAsampuTaM khAdyapAtraM vA yasyAsti tena tadgrahItavyaM, yasya cha kR^ipANoे nAsti tena svavastraM vikrIya sa kretavyaH| 
\p  
\v 37 yato yuShmAnahaM vadAmi, aparAdhijanaiH sArddhaM gaNitaH sa bhaviShyati| idaM yachChAstrIyaM vachanaM likhitamasti tanmayi phaliShyati yato mama sambandhIyaM sarvvaM setsyati| 
\p  
\v 38 tadA te prochuH prabho pashya imau kR^ipANau| tataH sovadad etau yatheShTau| 
\p  
\v 39 atha sa tasmAdvahi rgatvA svAchArAnusAreNa jaitunanAmAdriM jagAma shiShyAshcha tatpashchAd yayuH| 
\p  
\v 40 tatropasthAya sa tAnuvAcha, yathA parIkShAyAM na patatha tadarthaM prArthayadhvaM| 
\p  
\v 41 pashchAt sa tasmAd ekasharakShepAd bahi rgatvA jAnunI pAtayitvA etat prArthayA nchakre, 
\p  
\v 42 he pita ryadi bhavAn sammanyate tarhi kaMsamenaM mamAntikAd dUraya kintu madichChAnurUpaM na tvadichChAnurUpaM bhavatu| 
\p  
\v 43 tadA tasmai shaktiM dAtuM svargIyadUto darshanaM dadau| 
\p  
\v 44 pashchAt sotyantaM yAtanayA vyAkulo bhUtvA punardR^iDhaM prArthayA nchakre, tasmAd bR^ihachChoNitabindava iva tasya svedabindavaH pR^ithivyAM patitumArebhire| 
\p  
\v 45 atha prArthanAta utthAya shiShyANAM samIpametya tAn manoduHkhino nidritAn dR^iShTvAvadat 
\p  
\v 46 kuto nidrAtha? parIkShAyAm apatanArthaM prarthayadhvaM| 
\p  
\v 47 etatkathAyAH kathanakAle dvAdashashiShyANAM madhye gaNito yihUdAnAmA janatAsahitasteShAm agre chalitvA yIshoshchumbanArthaM tadantikam Ayayau| 
\p  
\v 48 tadA yIshuruvAcha, he yihUdA kiM chumbanena manuShyaputraM parakareShu samarpayasi? 
\p  
\v 49 tadA yadyad ghaTiShyate tadanumAya sa NgibhiruktaM, he prabho vayaM ki kha Ngena ghAtayiShyAmaH? 
\p  
\v 50 tata ekaH karavAlenAhatya pradhAnayAjakasya dAsasya dakShiNaM karNaM chichCheda| 
\p  
\v 51 adhUnA nivarttasva ityuktvA yIshustasya shrutiM spR^iShTvA svasyaM chakAra| 
\p  
\v 52 pashchAd yIshuH samIpasthAn pradhAnayAjakAn mandirasya senApatIn prAchInAMshcha jagAda, yUyaM kR^ipANAn yaShTIMshcha gR^ihItvA mAM kiM choraM dharttumAyAtAH? 
\p  
\v 53 yadAhaM yuShmAbhiH saha pratidinaM mandire.atiShThaM tadA mAM dharttaM na pravR^ittAH, kintvidAnIM yuShmAkaM samayondhakArasya chAdhipatyamasti| 
\p  
\v 54 atha te taM dhR^itvA mahAyAjakasya niveshanaM ninyuH| tataH pitaro dUre dUre pashchAditvA 
\p  
\v 55 bR^ihatkoShThasya madhye yatrAgniM jvAlayitvA lokAH sametyopaviShTAstatra taiH sArddham upavivesha| 
\p  
\v 56 atha vahnisannidhau samupaveshakAle kAchiddAsI mano nivishya taM nirIkShyAvadat pumAnayaM tasya sa Nge.asthAt| 
\p  
\v 57 kintu sa tad apahnutyAvAdIt he nAri tamahaM na parichinomi| 
\p  
\v 58 kShaNAntare.anyajanastaM dR^iShTvAbravIt tvamapi teShAM nikarasyaikajanosi| pitaraH pratyuvAcha he nara nAhamasmi| 
\p  
\v 59 tataH sArddhadaNDadvayAt paraM punaranyo jano nishchitya babhAShe, eSha tasya sa NgIti satyaM yatoyaM gAlIlIyo lokaH| 
\p  
\v 60 tadA pitara uvAcha he nara tvaM yad vadami tadahaM boddhuM na shaknomi, iti vAkye kathitamAtre kukkuTo rurAva| 
\p  
\v 61 tadA prabhuNA vyAdhuTya pitare nirIkShite kR^ikavAkuravAt pUrvvaM mAM trirapahnoShyase iti pUrvvoktaM tasya vAkyaM pitaraH smR^itvA 
\p  
\v 62 bahirgatvA mahAkhedena chakranda| 
\p  
\v 63 tadA yai ryIshurdhR^itaste tamupahasya praharttumArebhire| 
\p  
\v 64 vastreNa tasya dR^ishau baddhvA kapole chapeTAghAtaM kR^itvA paprachChuH, kaste kapole chapeTAghAtaM kR^itavAna? gaNayitvA tad vada| 
\p  
\v 65 tadanyat tadviruddhaM bahunindAvAkyaM vaktumArebhire| 
\p  
\v 66 atha prabhAte sati lokaprA nchaH pradhAnayAjakA adhyApakAshcha sabhAM kR^itvA madhyesabhaM yIshumAnIya paprachChuH, tvam abhiShikatosi na vAsmAn vada| 
\p  
\v 67 sa pratyuvAcha, mayA tasminnukte.api yUyaM na vishvasiShyatha| 
\p  
\v 68 kasmiMshchidvAkye yuShmAn pR^iShTe.api mAM na taduttaraM vakShyatha na mAM tyakShyatha cha| 
\p  
\v 69 kintvitaH paraM manujasutaH sarvvashaktimata Ishvarasya dakShiNe pArshve samupavekShyati| 
\p  
\v 70 tataste paprachChuH, rtiha tvamIshvarasya putraH? sa kathayAmAsa, yUyaM yathArthaM vadatha sa evAhaM| 
\p  
\v 71 tadA te sarvve kathayAmAsuH, rtiha sAkShye.ansasmin asmAkaM kiM prayojanaM? asya svamukhAdeva sAkShyaM prAptam| 
\c 23  
\p  
\v 1 tataH sabhAsthAH sarvvalokA utthAya taM pIlAtasammukhaM nItvAprodya vaktumArebhire, 
\p  
\v 2 svamabhiShiktaM rAjAnaM vadantaM kaimararAjAya karadAnaM niShedhantaM rAjyaviparyyayaM kurttuM pravarttamAnam ena prAptA vayaM| 
\p  
\v 3 tadA pIlAtastaM pR^iShTavAn tvaM kiM yihUdIyAnAM rAjA? sa pratyuvAcha tvaM satyamuktavAn| 
\p  
\v 4 tadA pIlAtaH pradhAnayAjakAdilokAn jagAd, ahametasya kamapyaparAdhaM nAptavAn| 
\p  
\v 5 tataste punaH sAhamino bhUtvAvadan, eSha gAlIla etatsthAnaparyyante sarvvasmin yihUdAdeshe sarvvAllokAnupadishya kupravR^ittiM grAhItavAn| 
\p  
\v 6 tadA pIlAto gAlIlapradeshasya nAma shrutvA paprachCha, kimayaM gAlIlIyo lokaH? 
\p  
\v 7 tataH sa gAlIlpradeshIyaherodrAjasya tadA sthitestasya samIpe yIshuM preShayAmAsa| 
\p  
\v 8 tadA herod yIshuM vilokya santutoSha, yataH sa tasya bahuvR^ittAntashravaNAt tasya ki ni्chadAshcharyyakarmma pashyati ityAshAM kR^itvA bahukAlamArabhya taM draShTuM prayAsaM kR^itavAn| 
\p  
\v 9 tasmAt taM bahukathAH paprachCha kintu sa tasya kasyApi vAkyasya pratyuttaraM novAcha| 
\p  
\v 10 atha pradhAnayAjakA adhyApakAshcha prottiShThantaH sAhasena tamapavadituM prArebhire| 
\p  
\v 11 herod tasya senAgaNashcha tamavaj nAya upahAsatvena rAjavastraM paridhApya punaH pIlAtaM prati taM prAhiNot| 
\p  
\v 12 pUrvvaM herodpIlAtayoH parasparaM vairabhAva AsIt kintu taddine dvayo rmelanaM jAtam| 
\p  
\v 13 pashchAt pIlAtaH pradhAnayAjakAn shAsakAn lokAMshcha yugapadAhUya babhAShe, 
\p  
\v 14 rAjyaviparyyayakArakoyam ityuktvA manuShyamenaM mama nikaTamAnaiShTa kintu pashyata yuShmAkaM samakSham asya vichAraM kR^itvApi proktApavAdAnurUpeNAsya kopyaparAdhaH sapramANo na jAtaH, 
\p  
\v 15 yUya ncha herodaH sannidhau preShitA mayA tatrAsya kopyaparAdhastenApi na prAptaH|pashyatAnena vadhaheेtukaM kimapi nAparAddhaM| 
\p  
\v 16 tasmAdenaM tADayitvA vihAsyAmi| 
\p  
\v 17 tatrotsave teShAmeko mochayitavyaH| 
\p  
\v 18 iti hetoste prochchairekadA prochuH, enaM dUrIkR^itya barabbAnAmAnaM mochaya| 
\p  
\v 19 sa barabbA nagara upaplavavadhAparAdhAbhyAM kArAyAM baddha AsIt| 
\p  
\v 20 kintu pIlAto yIshuM mochayituM vA nChan punastAnuvAcha| 
\p  
\v 21 tathApyenaM krushe vyadha krushe vyadheti vadantaste ruruvuH| 
\p  
\v 22 tataH sa tR^itIyavAraM jagAda kutaH? sa kiM karmma kR^itavAn? nAhamasya kamapi vadhAparAdhaM prAptaH kevalaM tADayitvAmuM tyajAmi| 
\p  
\v 23 tathApi te punarenaM krushe vyadha ityuktvA prochchairdR^iDhaM prArthayA nchakrire; 
\p  
\v 24 tataH pradhAnayAjakAdInAM kalarave prabale sati teShAM prArthanArUpaM karttuM pIlAta Adidesha| 
\p  
\v 25 rAjadrohavadhayoraparAdhena kArAsthaM yaM janaM te yayAchire taM mochayitvA yIshuM teShAmichChAyAM samArpayat| 
\p  
\v 26 atha te yIshuM gR^ihItvA yAnti, etarhi grAmAdAgataM shimonanAmAnaM kurINIyaM janaM dhR^itvA yIshoH pashchAnnetuM tasya skandhe krushamarpayAmAsuH| 
\p  
\v 27 tato loाkAraNyamadhye bahustriyo rudatyo vilapantyashcha yIshoH pashchAd yayuH| 
\p  
\v 28 kintu sa vyAghuTya tA uvAcha, he yirUshAlamo nAryyo yuyaM madarthaM na ruditvA svArthaM svApatyArtha ncha ruditi; 
\p  
\v 29 pashyata yaH kadApi garbhavatyo nAbhavan stanya ncha nApAyayan tAdR^ishI rvandhyA yadA dhanyA vakShyanti sa kAla AyAti| 
\p  
\v 30 tadA he shailA asmAkamupari patata, he upashailA asmAnAchChAdayata kathAmIdR^ishIM lokA vakShyanti| 
\p  
\v 31 yataH satejasi shAkhini chedetad ghaTate tarhi shuShkashAkhini kiM na ghaTiShyate? 
\p  
\v 32 tadA te hantuM dvAvaparAdhinau tena sArddhaM ninyuH| 
\p  
\v 33 aparaM shiraHkapAlanAmakasthAnaM prApya taM krushe vividhuH; taddvayoraparAdhinorekaM tasya dakShiNo tadanyaM vAme krushe vividhuH| 
\p  
\v 34 tadA yIshurakathayat, he pitaretAn kShamasva yata ete yat karmma kurvvanti tan na viduH; pashchAtte guTikApAtaM kR^itvA tasya vastrANi vibhajya jagR^ihuH| 
\p  
\v 35 tatra lokasaMghastiShThan dadarsha; te teShAM shAsakAshcha tamupahasya jagaduH, eSha itarAn rakShitavAn yadIshvareNAbhiruchito .abhiShiktastrAtA bhavati tarhi svamadhunA rakShatu| 
\p  
\v 36 tadanyaH senAgaNA etya tasmai amlarasaM datvA parihasya provAcha, 
\p  
\v 37 chettvaM yihUdIyAnAM rAjAsi tarhi svaM rakSha| 
\p  
\v 38 yihUdIyAnAM rAjeti vAkyaM yUnAnIyaromIyebrIyAkSharai rlikhitaM tachChirasa Urddhve.asthApyata| 
\p  
\v 39 tadobhayapArshvayo rviddhau yAvaparAdhinau tayorekastaM vinindya babhAShe, chettvam abhiShiktosi tarhi svamAvA ncha rakSha| 
\p  
\v 40 kintvanyastaM tarjayitvAvadat, IshvarAttava ki nchidapi bhayaM nAsti kiM? tvamapi samAnadaNDosi, 
\p  
\v 41 yogyapAtre AvAM svasvakarmmaNAM samuchitaphalaM prApnuvaH kintvanena kimapi nAparAddhaM| 
\p  
\v 42 atha sa yIshuM jagAda he prabhe bhavAn svarAjyapraveshakAle mAM smaratu| 
\p  
\v 43 tadA yIshuH kathitavAn tvAM yathArthaM vadAmi tvamadyaiva mayA sArddhaM paralokasya sukhasthAnaM prApsyasi| 
\p  
\v 44 apara ncha dvitIyayAmAt tR^itIyayAmaparyyantaM ravestejasontarhitatvAt sarvvadesho.andhakAreNAvR^ito 
\p  
\v 45 mandirasya yavanikA cha ChidyamAnA dvidhA babhUva| 
\p  
\v 46 tato yIshuruchchairuvAcha, he pita rmamAtmAnaM tava kare samarpaye, ityuktvA sa prANAn jahau| 
\p  
\v 47 tadaitA ghaTanA dR^iShTvA shatasenApatirIshvaraM dhanyamuktvA kathitavAn ayaM nitAntaM sAdhumanuShya AsIt| 
\p  
\v 48 atha yAvanto lokA draShTum AgatAste tA ghaTanA dR^iShTvA vakShaHsu karAghAtaM kR^itvA vyAchuTya gatAH| 
\p  
\v 49 yIsho rj nAtayo yA yA yoShitashcha gAlIlastena sArddhamAyAtAstA api dUre sthitvA tat sarvvaM dadR^ishuH| 
\p  
\v 50 tadA yihUdIyAnAM mantraNAM kriyA nchAsammanyamAna Ishvarasya rAjatvam apekShamANo 
\p  
\v 51 yihUdideshIyo .arimathIyanagarIyo yUShaphnAmA mantrI bhadro dhArmmikashcha pumAn 
\p  
\v 52 pIlAtAntikaM gatvA yIsho rdehaM yayAche| 
\p  
\v 53 pashchAd vapuravarohya vAsasA saMveShTya yatra kopi mAnuSho nAsthApyata tasmin shaile svAte shmashAne tadasthApayat| 
\p  
\v 54 taddinamAyojanIyaM dinaM vishrAmavArashcha samIpaH| 
\p  
\v 55 aparaM yIshunA sArddhaM gAlIla AgatA yoShitaH pashchAditvA shmashAne tatra yathA vapuH sthApitaM tachcha dR^iShTvA 
\p  
\v 56 vyAghuTya sugandhidravyatailAni kR^itvA vidhivad vishrAmavAre vishrAmaM chakruH| 
\c 24  
\p  
\v 1 atha saptAhaprathamadine.atipratyUShe tA yoShitaH sampAditaM sugandhidravyaM gR^ihItvA tadanyAbhiH kiyatIbhiH strIbhiH saha shmashAnaM yayuH| 
\p  
\v 2 kintu shmashAnadvArAt pAShANamapasAritaM dR^iShTvA 
\p  
\v 3 tAH pravishya prabho rdehamaprApya 
\p  
\v 4 vyAkulA bhavanti etarhi tejomayavastrAnvitau dvau puruShau tAsAM samIpe samupasthitau 
\p  
\v 5 tasmAttAH sha NkAyuktA bhUmAvadhomukhyasyasthuH| tadA tau tA Uchatu rmR^itAnAM madhye jIvantaM kuto mR^igayatha? 
\p  
\v 6 sotra nAsti sa udasthAt| 
\p  
\v 7 pApinAM kareShu samarpitena krushe hatena cha manuShyaputreNa tR^itIyadivase shmashAnAdutthAtavyam iti kathAM sa galIli tiShThan yuShmabhyaM kathitavAn tAM smarata| 
\p  
\v 8 tadA tasya sA kathA tAsAM manaHsu jAtA| 
\p  
\v 9 anantaraM shmashAnAd gatvA tA ekAdashashiShyAdibhyaH sarvvebhyastAM vArttAM kathayAmAsuH| 
\p  
\v 10 magdalInImariyam, yohanA, yAkUbo mAtA mariyam tadanyAH sa Nginyo yoShitashcha preritebhya etAH sarvvA vArttAH kathayAmAsuH 
\p  
\v 11 kintu tAsAM kathAm anarthakAkhyAnamAtraM buddhvA kopi na pratyait| 
\p  
\v 12 tadA pitara utthAya shmashAnAntikaM dadhAva, tatra cha prahvo bhUtvA pArshvaikasthApitaM kevalaM vastraM dadarsha; tasmAdAshcharyyaM manyamAno yadaghaTata tanmanasi vichArayan pratasthe| 
\p  
\v 13 tasminneva dine dvau shiyyau yirUshAlamashchatuShkroshAntaritam immAyugrAmaM gachChantau 
\p  
\v 14 tAsAM ghaTanAnAM kathAmakathayatAM 
\p  
\v 15 tayorAlApavichArayoH kAle yIshurAgatya tAbhyAM saha jagAma 
\p  
\v 16 kintu yathA tau taM na parichinutastadarthaM tayo rdR^iShTiH saMruddhA| 
\p  
\v 17 sa tau pR^iShTavAn yuvAM viShaNNau kiM vichArayantau gachChathaH? 
\p  
\v 18 tatastayoH kliyapAnAmA pratyuvAcha yirUshAlamapure.adhunA yAnyaghaTanta tvaM kevalavideshI kiM tadvR^ittAntaM na jAnAsi? 
\p  
\v 19 sa paprachCha kA ghaTanAH? tadA tau vaktumArebhAte yIshunAmA yo nAsaratIyo bhaviShyadvAdI Ishvarasya mAnuShANA ncha sAkShAt vAkye karmmaNi cha shaktimAnAsIt 
\p  
\v 20 tam asmAkaM pradhAnayAjakA vichArakAshcha kenApi prakAreNa krushe viddhvA tasya prANAnanAshayan tadIyA ghaTanAH; 
\p  
\v 21 kintu ya isrAyelIyalokAn uddhArayiShyati sa evAyam ityAshAsmAbhiH kR^itA|tadyathA tathAstu tasyA ghaTanAyA adya dinatrayaM gataM| 
\p  
\v 22 adhikantvasmAkaM sa NginInAM kiyatstrINAM mukhebhyo.asambhavavAkyamidaM shrutaM; 
\p  
\v 23 tAH pratyUShe shmashAnaM gatvA tatra tasya deham aprApya vyAghuTyetvA proktavatyaH svargIsadUtau dR^iShTAvasmAbhistau chAvAdiShTAM sa jIvitavAn| 
\p  
\v 24 tatosmAkaM kaishchit shmashAnamagamyata te.api strINAM vAkyAnurUpaM dR^iShTavantaH kintu taM nApashyan| 
\p  
\v 25 tadA sa tAvuvAcha, he abodhau he bhaviShyadvAdibhiruktavAkyaM pratyetuM vilambamAnau; 
\p  
\v 26 etatsarvvaduHkhaM bhuktvA svabhUtiprAptiH kiM khrIShTasya na nyAyyA? 
\p  
\v 27 tataH sa mUsAgranthamArabhya sarvvabhaviShyadvAdinAM sarvvashAstre svasmin likhitAkhyAnAbhiprAyaM bodhayAmAsa| 
\p  
\v 28 atha gamyagrAmAbhyarNaM prApya tenAgre gamanalakShaNe darshite 
\p  
\v 29 tau sAdhayitvAvadatAM sahAvAbhyAM tiShTha dine gate sati rAtrirabhUt; tataH sa tAbhyAM sArddhaM sthAtuM gR^ihaM yayau| 
\p  
\v 30 pashchAdbhojanopaveshakAle sa pUpaM gR^ihItvA IshvaraguNAn jagAda ta ncha bhaMktvA tAbhyAM dadau| 
\p  
\v 31 tadA tayo rdR^iShTau prasannAyAM taM pratyabhij natuH kintu sa tayoH sAkShAdantardadhe| 
\p  
\v 32 tatastau mithobhidhAtum Arabdhavantau gamanakAle yadA kathAmakathayat shAstrArtha nchabodhayat tadAvayo rbuddhiH kiM na prAjvalat? 
\p  
\v 33 tau tatkShaNAdutthAya yirUshAlamapuraM pratyAyayatuH, tatsthAne shiShyANAm ekAdashAnAM sa NginA ncha darshanaM jAtaM| 
\p  
\v 34 te prochuH prabhurudatiShThad iti satyaM shimone darshanamadAchcha| 
\p  
\v 35 tataH pathaH sarvvaghaTanAyAH pUpabha njanena tatparichayasya cha sarvvavR^ittAntaM tau vaktumArebhAte| 
\p  
\v 36 itthaM te parasparaM vadanti tatkAle yIshuH svayaM teShAM madhya protthaya yuShmAkaM kalyANaM bhUyAd ityuvAcha, 
\p  
\v 37 kintu bhUtaM pashyAma ityanumAya te samudvivijire treShushcha| 
\p  
\v 38 sa uvAcha, kuto duHkhitA bhavatha? yuShmAkaM manaHsu sandeha udeti cha kutaH? 
\p  
\v 39 eShohaM, mama karau pashyata varaM spR^iShTvA pashyata, mama yAdR^ishAni pashyatha tAdR^ishAni bhUtasya mAMsAsthIni na santi| 
\p  
\v 40 ityuktvA sa hastapAdAn darshayAmAsa| 
\p  
\v 41 te.asambhavaM j nAtvA sAnandA na pratyayan| tataH sa tAn paprachCha, atra yuShmAkaM samIpe khAdyaM ki nchidasti? 
\p  
\v 42 tataste kiyaddagdhamatsyaM madhu cha daduH 
\p  
\v 43 sa tadAdAya teShAM sAkShAd bubhuje 
\p  
\v 44 kathayAmAsa cha mUsAvyavasthAyAM bhaviShyadvAdinAM grantheShu gItapustake cha mayi yAni sarvvANi vachanAni likhitAni tadanurUpANi ghaTiShyante yuShmAbhiH sArddhaM sthitvAhaM yadetadvAkyam avadaM tadidAnIM pratyakShamabhUt| 
\p  
\v 45 atha tebhyaH shAstrabodhAdhikAraM datvAvadat, 
\p  
\v 46 khrIShTenetthaM mR^itiyAtanA bhoktavyA tR^itIyadine cha shmashAnAdutthAtavya ncheti lipirasti; 
\p  
\v 47 tannAmnA yirUshAlamamArabhya sarvvadeshe manaHparAvarttanasya pApamochanasya cha susaMvAdaH prachArayitavyaH, 
\p  
\v 48 eShu sarvveShu yUyaM sAkShiNaH| 
\p  
\v 49 apara ncha pashyata pitrA yat pratij nAtaM tat preShayiShyAmi, ataeva yAvatkAlaM yUyaM svargIyAM shaktiM na prApsyatha tAvatkAlaM yirUshAlamnagare tiShThata| 
\p  
\v 50 atha sa tAn baithanIyAparyyantaM nItvA hastAvuttolya AshiSha vaktumArebhe 
\p  
\v 51 AshiShaM vadanneva cha tebhyaH pR^ithag bhUtvA svargAya nIto.abhavat| 
\p  
\v 52 tadA te taM bhajamAnA mahAnandena yirUshAlamaM pratyAjagmuH| 
\p  
\v 53 tato nirantaraM mandire tiShThanta Ishvarasya prashaMsAM dhanyavAda ncha karttam Arebhire| iti||