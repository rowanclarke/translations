\id HEB  
\h Hebreos 
\toc1 Te Guijtz Nani Biääd Loj Rebeṉ Hebree 
\toc2 Hebreos 
\toc3 He. 
\mt1 Te Guijtz Nani Biääd Loj Rebeṉ Hebree 
\c 1  
\s1 Agunii Xi'n Dios xtidx Xtadni 
\p  
\v 1 Neṉ redxe galoo garen-garen mood guninäj Dios retoxtadgoldoonu. Xhidajlza huält guniini por reniguii ni bacuaa xtiidxni.  
\v 2 Neṉ redxejre aguniini loonu por Xi'nni, lojzani badeed Dios yäḻrnibee guncheeni guedxliujre, badeedzani guira'ti lojni.  
\v 3 Laani najc xtuxh xten xcäḻrdimbicha' Dios, laani najczani sigajc najc Dios, laazani rapchee guira'ti con xtiidxni ni rnibee. Cheni gulujx basiani xtojḻnu, gurejni xladbee Gueb Dios xhaguibaa te canibeeni. 
\s1 Sacduxhru Xi'n Dios loj rexangl Dios 
\p  
\v 4 Ro'c gurej Xi'n Dios sa'csi sajcruni loj reangl xten Dios, sa'csi acua'ni yäḻrnibee si'c te bejṉ ni riannäj xhixten Xtadni. Lajzani sajcru lo relaj rexangl Dios.  
\v 5 Sa'csi Dios di niäjb loj nicla tej rexanglni: 
\q1 Luj najclu Xi'nä. Narä guleälu te guinibeelu. 
\m Dizani niäjb xcuent nicla tej rexanglni: 
\q1 Narä gacä xtadni, laani gacni xi'nä. 
\m  
\v 6 Niluxh che biädnäni Xi'n xtebni lo guedxliuj, guniini: 
\q1 Guiraa rexangl xten Dios, ¡Coḻgaṉ Xi'nä! 
\m  
\v 7 Che gunii Dios xcuent rexanglni räjpni: 
\q1 Rujnni ruxhuṉ rexanglni si'c bej, rujnni rbebajl rexmosni. 
\m  
\v 8 Niluxh xcuent Xi'nni guniini: 
\q1 Luj najc Dios. 
\q1 Nabajṉlu par tejpas; 
\q1 xcäḻrnibeelu par tejpas najc te yäḻrnibesa'c. 
\q1  
\v 9 Ahuinälajzlu xhigabsa'c, dipaclu nichaglajz xhigabguijdx, 
\q1 ni'cni Dios ni najc Xtioslu, baniidxru yäḻrbalajz lojlu quela loj resa'lu. 
\m  
\v 10 Rniizani: 
\q1 Luj, Dad, che guslojli bencheelu guira'ti, 
\q1 bencheelu cad soob guedxliuj, ṉaazalu bencheelu reguibaa. 
\q1  
\v 11 Laareni sinitlojreni, niluxh luj nabajṉlu par tejpas. 
\q1 Guiraareni siujx si'c riujx te lajd. 
\q1  
\v 12 Suse'tlureni si'c rie't te la' lajd, sidxaareni si'c rdxaa te lajd. 
\q1 Niluxh luj dilu guidxaa. 
\q1 Laḻgajctis nabajṉlu, di rexijzlu ted. 
\m  
\v 13 ¿Gucxha räjp Dios lo te xanglni scree, ä? Räjpni: 
\q1 Gurej xladbeä te guinibeelu dxejli cheni gudzugä guiraa ni rdxe'ch lojlu ladz ni'lu. 
\m  
\v 14 Guiraa rexangl Dios najc sprit, ruxhaḻ Diosreni te chayacnäjreni rebejṉ ni xca' yäḻnabajṉ par tejpas. 
\c 2  
\s1 Na'c gusaanni diidx ni rusḻaani lo dojḻ 
\p  
\v 1 Ni'cni nanab jiunu xtidx Dios ni abiejn diajgnu, te na'c guibicajnu lo xnezyujni.  
\v 2 Anajntu aguzojb diidx ni gunii rexangl Dios neṉ redxe galoo. Luxh reni di nusoob diidxga bejnreni dojḻ, dxejc bateed Diosreni trabajw.  
\v 3 ¿Xho gac guibicaj xcäḻnaj Dios yejcnu palga dinu jiu rextidx Dios xcuent yäḻrusḻaa lo dojḻ, ä? Ni Dad, Jesucrist basa'n diidxga lo rexpejṉpacni, dxejc laareni basule'reni rediidxre loonu.  
\v 4 Niluxh Dios baluii najc diidxga guliipac sa'csi bejnni reseen, näjza yäḻrdxeloduxh, näjza xhidajl remilagrw. Badeedzani Sprit Dxan xtenni loj renani ahuililajz xtiidxni te gun tejgareni garen-garen xtzuunreni si'ctis ni rlajz Dios gunreni. 
\s1 Nani guläxtiej yäḻrusḻaa bejṉ lo dojḻ 
\p  
\v 5 Di Dios gudeed yäḻrnibee lo rexanglni te guinibeereni guedxliucoob ni cagusä'tnu ṉaj.  
\v 6 Guyu' tej ni bacuaa xtidx Dios lo guijtz, räjpni: 
\q1 ¿Chu najc niguii, te guinalajz Dios laani? 
\q1 ¿Chu najc xi'n niguii te jiädhuiizaluni? 
\q1  
\v 7 Nagabsi dxej guxiiru sajcni lo reangl xhaguibaa, 
\q1 dxejcti badedsaclu xcäḻnasa'cni, 
\q1 badedsaclu xpala'nni, 
\q1 badeedzalu yäḻrnibee lojni te guinibeeni guira'ti ni bencheelu. 
\q1  
\v 8 Badeedlu guinibeeni guiralii ni yu' lo guedxliuj. 
\m Cheni badeed Dios guira'ti te guinibeeni, xhetliidi basa'n Dios ni digacdi guinibeeni, niluxh ṉaj ruhuiinu gajdni guinibee guiralii ni'c.  
\v 9 Alga rhuiinu Jesucrist, ni bejn Dios guxiiru sajcni lo reangl xten Dios che guyu'ni lo guedxliuj balsi dxej. Che baluux Jesucrist xtzuunni lo guedxliuj, badeed Dios yäḻrdimbicha' näjza xpala'nni lojni. Sa'csi sanälajz Dios nuurnu basaanni gudejd Xi'nni trabajwduxh, gujtni lacuaa niejtnu. 
\p  
\v 10 Dios benchee guiralii ni yu' lo guedxliujre, ṉajli rnibeeza Dios guira'ti. Luxh Diosre rlajz chanäni xhidajl xi'nni xhaguibaa, ni'cni baxhaḻ Dios xi'npacni Jesucrist te guläxtiejni yäḻrusḻaa bejṉ lo dojḻ che gudejdni trabajwduxh lo crujz.  
\v 11 Sa'csi Jesucrist, ni rujn chasanäj bejṉ te yäḻnabaṉya, näjza reni risanäj yäḻnabaṉya, tejtis najc xtadreni. Ni'cni di Xi'n Dios guitujy guiniini lojreni: “betzä”.  
\v 12 Scree caj lo xtidx Dios: 
\q1 Chasule'ä lo rebetzä xho najclu, 
\q1 siliä'päza xpala'nlu lojreni. 
\m  
\v 13 Räjpzani: 
\q1 Sibäzä gacnäj Dios narä. 
\m Ste lajt guniini: 
\q1 Bahuii loä näjza rexi'nä ni baniidx Dios loä. 
\p  
\v 14 Te famiḻ najc tejsi bääl, tejsiza rejn; ni'cni che biääd Jesucrist lo guedxliuj guyu' tiejxhni näj xtiejnni si'c beṉguedxliuj, gujtzani te gujc bejnni gunijt nani rnibee yäḻgujt, nalajznu, beṉdxab.  
\v 15 Te si'c basḻaani guiraa reni rdxejb yäḻgujt, najcreni si'c reni yu'tis loj xlam̲ni guideb nabajṉreni, lacti rdxejbreni yäḻgujt.  
\v 16 Guliini dini niääd te gacnäjni reangl xten Dios, biäädni te gacnäjni guiralii rexajg toAbram.  
\v 17 Ni'cni gujcni si'cpac te bejtznu, te gac gacni te bixhojz xten Dios ni rulaslajz, te bixhozsa'cza xten Dios, si'cni rlajz Dios gacni te gusḻaani rebejṉ lo dojḻ.  
\v 18 Sa'csi lagajc laani gudejdni trabajw, luxh baquiilza beṉdxabni niujnni dojḻ, ni'c ṉaj sajc gacnäjni renani ruquiil beṉdxab gun dojḻ. 
\c 3  
\s1 Jesucrist sajcru loj Moisés 
\p  
\v 1 Ni'cni bejtznu, reni anabaṉsa'c, sa'csi najctu reni gurejdx Dios gac xi'nni, coḻyembee Jesucrist ni baxhaḻ Dios loonu. Laani najc bixhojz ni sajcru, rusule'zani xtidx Dios xcuent nani ahuililajznu.  
\v 2 Laani huinuutis guyu'ni lo Dios ni guleni te gunni dzuunre. Sigajc ni bensa'c toMoisés xtzuun Dios che guyu'ni loj rexpejṉ Israel, sigajcza bensa'c Jesucrist dzuun che biäädni lo guedxliuj.  
\v 3 Sigajc ni yu'ru xpala'n dad lo xpala'n rexi'nni, sigajcza yu'ru xpala'n Jesucrist lo xpala'n toMoisés.  
\v 4 Yu' xtad guiraa refamiḻ lo guedxliuj, niluxh gule'c Dios guiralii bejṉ, bencheezani guedxliuj.  
\v 5 Basoob Moisés diidx si'c te mos, cuanäjni rexpeṉ Dios si'cni gunibee Dios gunni, te baluiini xho gac redzuun ni gajd gac dxejc, luxh ṉaj agujc redzuunga.  
\v 6 Niluxh Jesucrist basoob diidx si'c xi'npac Dios. Cuanäjni xfamiḻ Dios. Nurnu najcnu xfamiḻ Dios palga chanuutis sudzu'tznu lo xtiidxni, palga guibalajztisnu, palga gutiplajznu dxejli ni guibi' Jesucrist. 
\s1 Yäḻrusilajz xten rexpejṉ Dios 
\p  
\v 7 Ni'cni, si'cpac rnii Sprit Dxan xten Dios: 
\q1 N̲aj, palga jiendiajgtu xse'ni, 
\q1  
\v 8 na'c gun-najdtu lastootu si'c bejn rebejṉ ni bidxechnäj Dios che cuansajreni lo reyubijdz. 
\q1  
\v 9 Ro'c bidxechnäj retoxtadgoldootu Dios sa'csi direni nililajz Dios siädnäreni, 
\q1 niluxh bahuiireni redzunduxh ni bejn Dios nez lojreni tiuu ijz. 
\q1  
\v 10 Ni'cni laḻ ni cadxe'ch Dios loj rebejṉga, bejn Dios xhigab: 
\q1 Sujiannäjreni xhigabguijdxreni, 
\q1 dina gusanä jiu'reni xcäḻrusilazä. 
\q1  
\v 11 Ni'cni bidxe'ch Dios lojreni, 
\q1 bejn Dios te xhigabduxh, 
\q1 di rebejṉga jiu' te gusilaznäjni. 
\p  
\v 12 Bejtznu, coḻnatiro andi chu tejtu rujn xhigabguijdx, rlajz guibicaj lo Dios, ni nabajṉ par tejpas, sa'csi dini chalilajz xtiidxni.  
\v 13 Ni'cni coḻgulijdx resa'tu guixe-guixee, laga najcni nadxej; te di chu tejtu gacnajd lastooni xcuent reyäḻrusguee xten redojḻ.  
\v 14 Sa'csi palga chanuunu sudzu'tznu lo xtidx Dios ni huililajznu che biembeenuni, dxejc yu' xhi rajpnu con Jesucrist.  
\v 15 Si'c caj lo guijtz: 
\q1 Nadxej, palga jiendiajgtu xse' Dios, 
\q1 na'c gunnajdtu lastootu si'c bejn rebejṉ ni bidxechnäj Dios lo reyubijdz. 
\m  
\v 16 ¿Chu reni'cni bidxechnäj Dios che biendiajgreni xtiidxni? ¿La et laadi guiraa rebejṉ ni gulää Moisés guedx Egipto, ä?  
\v 17 ¿Chuxh loj bidxe'ch Dios tiuu ijz lo reyubijdz, ä? ¿La et laadi reni biajb lo dojḻ, dxejc gujtreni, huijiajbreni nez loj reyubijdz, ä?  
\v 18 ¿Chu loj räjpni dipacreni jiu' lo xcäḻrusilajzni? Loj reni di nusoob xtiidxni.  
\v 19 Ni'c ruhuiinu di niajcdi niu'reni lo yäḻrusilajz sa'csi direni nililajz xtidx Dios. 
\c 4  
\p  
\v 1 Ni'cni palga bia'n diidx siu'pacnu lo yäḻrusilajz con Dios, nanab jia'pnu lagajc nuure didi yu' chu tejnu di gun gaan jiu' lo yäḻrusilajzga.  
\v 2 Sa'csi nuure abiejn diaagzanu diidx ni rusia dojḻ, sigajc biejn diajg rebejṉga; niluxh xlia'si biejn diajgreni diidxga sa'csi bacuadiajgrenini niluxh direni nililajzni.  
\v 3 Luxh nuure ni ahuililaaznu siu'nu lo yäḻrusilajzga; caj lo guijtz gunii Dios rediidxre: 
\q1 Ni'cni bidxe'chä lojreni, benä te xhigabduxh, 
\q1 di rebejṉga jiu' te gusilaznäjreni narä. 
\m Mase abaluuxni xtzuunni cheni birixtiejli guedxliuj.  
\v 4 Sa'csi loj stee guijtz caj diidx ni guniini xcuent dxej ni rusilajz bejṉ: 
\q1 Xho'p dxej bejn Dios xtzuunni, dxejcti basilajzni tebdxej. 
\q1 Xhet bejndini dxejga. 
\m  
\v 5 Stehuält guniini: 
\q1 Di rebejṉga jiu' te gusilaznäjreni narä. 
\m  
\v 6 Niluxh yu' reni gajd jiu' loj yäḻrusilajzga, luxh reni biejn diajgni diidx ni rusia dojḻ di niu' sa'csi direni nusoob xtiidxni.  
\v 7 Ni'cni basoob Dios ste dxej gac “nadxej”. Gudejd xhidajl ijz che gunisac Dios xcuent yäḻrusilajz. Badeed Dios gunii toDavid rediidxre: 
\q1 Nadxej, palga jiendiajgtu xse'ni, na'c gunnajdtu lastootu. 
\m  
\v 8 Paru nudeed Josué yäḻrusilajzga loj rexpeṉ Israel, diru Dios ninisac xcuent stee dxejre.  
\v 9 N̲aj ria'nza te yäḻrusilajz par rexpejṉ Dios,  
\v 10 sa'csi nani riu' lo xcäḻrusilaznäj Dios, rusilajzzani lo xtzuunni sigajc basilajz Dios lo xtzuunni.  
\v 11 Nanab chanuu gusoobnu xtiidxni te jiu'nu lo yäḻrusilajzga, te di chu tejnu ni gacnajd lajzni si'c ni gucnajd lajz renani di nililajz. 
\p  
\v 12 Sa'csi nasesduxh xtidx Dios, yuduxhza xcäḻrnibee xtidx Dios. Najcni si'c te guchiil ni caduxh ro'ni, rääzni nez neṉ redzujt näj yojb. Sigajcza xtidx Dios rääz nez cadro rlia' sa' xsprit näjza xaim bejṉ. Ruluiiza xtidx Dios rexhigab ni yu' lastoo bejṉ, näjza redzuun ni rlajz lastoo bejṉ gun.  
\v 13 Xheti xhi bencheedi Dios ni naga'tz nez lojni. Guiralii guyasi ruhuii Dios. Sajpnu gudeednu cuent lo Dios. 
\s1 Bixhojz ni sajcru najc Jesucrist 
\p  
\v 14 Jesucrist, Xi'n Dios, najc xpixhojzpacnu ni sajcru, nani abiu' loj Dios. Ni'cni nanab chanuu sudzu'tznu chalilaaznu xtidx Dios.  
\v 15 Xpixhojznu ni sajcru sajc gulaslajzni nuure te di jiajbnu lo dojḻ, sa'csi laani sigajcza gudejdni trabajw, baquiil beṉdxabni te niujnni dojḻ, niluxh dini niujn dojḻ.  
\v 16 Riäjḻpac na'c guidxeebnu cuedx-guiniabnu lo Xtiosnu ni sanälajz nuure. Na'cza guitujynu, te gulaslajzni nuure, guideb xcäḻracnäjni gacnäjzani nuure. 
\c 5  
\p  
\v 1 Galooli guiraa rebixhojz ni sajcru nabee lo rebejṉ. Bixhojz ni sajcru rniab lo Dios xcuent rebejṉ. Luxh lojni rudeed rebejṉ regon näjza reguidxaa ni gudeedni lo Dios te jiäu lo xtojḻreni nez lo Dios.  
\v 2 Rdejdza bixhojz trabajw sigajc beṉguedxliuj, ni'c sajc ga'pni yäḻnadolajz loj rebejṉ nani nayääl näjza reni abanijt lo Dios.  
\v 3 Niluxh sa'csi näjza laani rujnni dojḻ, nanab gudeedni guidxaa lo Dios te jiäu lo rextojḻni sigajc rudeedni guidxaa lo Dios te riäu lo xtojḻ rebejṉ. 
\p  
\v 4 Rut sajcdi gac bixhojz xcuentcani. Dios najc ni rbejdxni te gacni bixhojz, dxejc rudeedni xpala'nni lojni si'c badeednini lo Aarón.  
\v 5 Si'cza di Jesucrist niajc bixhojz ni sajcru xcuentcani. Dios najc nani gulälajni gacni bixhojz ni sajcru, räjpni lojni: 
\q1 Luj najclu Xi'nä, narä guleälu nadxej te guinibeelu. 
\m  
\v 6 Scree cajza lo xtidx Dios stee lajt: 
\q1 Luj najclu bixhojz par tejpas sigajc gujc te niguii ni laa Melquisedec. 
\m  
\v 7 Cheni gubajṉ Jesucrist lo guedxliujre, gurejdx-gunabzani lo Dios, guredxa'ni biinzani lo Dios nani sajc nudzucajni lo yäḻgujt; Dios bacuadiajg xtiidxni sa'csi huinälajz Jesucrist Dios.  
\v 8 Ni'cni Jesucrist mase najcni Xi'n Dios bisieedni basoobni diidx luxh näj ni'c gudejdni trabajw.  
\v 9 Che bidzujṉ dxej baluuxni guiraa redzuun ni rlajz Dios gunni, laani gujcni nani rudeed ḻaa bejṉ nani rusoob xtiidxni lo dojḻ par tejpas  
\v 10 sa'csi Dios gulälajni bixhojz ni sajcru, gujcni bixhojz sigajc gujc Melquisedec. 
\s1 Rxhuṉriezgw gusa'nni xcäḻrililajzni 
\p  
\v 11 Rlajznu guiniinu xhidalduxhru diidx xcuent Melquisedec, niluxh naganduxh gusule'nuni lojtu sa'csi nadyejctu, ditu gacbee.  
\v 12 Agujc xchej huililajztu rediidx xcuent Jesucrist. Ariäjḻ gusule'tu rediidxre ṉaj, niluxh alga rquiinrutu chu gusule' rediidxre lojtu stehuält, luxh rediidxre najc rediidx guyasi xten Dios. Agucsactu si'c bäz. Rlajztu yäsactu le'ch lacuaa gautu yäjt, bääl; nalajznu, redidxnagajn xten Dios.  
\v 13 Reni najc si'c bäz, rä' le'chtis, direni gumbesa'c redidxsa'c xten Dios.  
\v 14 Niluxh rebeṉ guyajl rajw yäjt. Sigajcza redidxnagajn xten Dios najc par rebejṉ ni aguyajl lo xtidx Dios, renani ayu' xcäriejnni, arumbeereni nani najc dzunsa'c, nani najcza dzunguijdx. 
\c 6  
\p  
\v 1 Nanab guisieedrunu xtidx Dios te churu xcäriejnnu. Na'c guisieedtisnu didx-guyasi xcuent Jesucrist. Na'c guluiitisnu diidx xcuent yäḻrusiechlajz, xcuent redzuun ni rujn rejt bejṉ, näj yäḻrililajz xtidx Dios.  
\v 2 Na'c guluiitisnu xcuent yäḻrobnis, näj yäḻrudzubṉaa yejc bejṉ, näj xcuent yäḻrbajṉsac rebeṉgut, näj xcuent yäḻguxhtis par tejpas.  
\v 3 Alga do'o guisieedru xtidx Dios te churu xcäriejnnu, palga si'c guniidx Dios jiennu. 
\p  
\v 4 Yu' bejṉ ni abianij xcäriejnni, ni acua' reyäḻnasa'c ni rudeed Dios, ni rbäjz Sprit Dxan xten Dios neṉ lastooreni,  
\v 5 luxh bidxaglajzreni xtidx Dios näj yäḻrnibee xten Dios ni churu jiääd.  
\v 6 Palga laareni guibisacreni lo sa' yäḻnabajṉ ni gojpreni galoo, diru gacdi guidxaa xmodreni stehuält, sa'csi dxejc sajcni si'c ni lagajc laareni gucuasacreni Xi'n Dios lo crujz, nalajznu susanxtujyreni Jesucrist nez loj rebejṉ.  
\v 7 Beṉ guedxliuj ni biejn diajgni najc si'c najc yuj ni rä' nis che riajbtis nisguij. Palga yujga gudeed yälnasa'c loj reni rujn dzuun lojni, sunle' Dios yujga.  
\v 8 Niluxh palga gudeed yujga ganax yaguejch näjza cuaan ni xhet sajcdi, xlia'sini, sujn rebejṉ gac nadeni te checni. 
\s1 Diidx ni rusudzu'tz lastoonu 
\p  
\v 9 Mase rniinu scree lojtu, anajnnu huililajztu xtidx Jesucrist näjza xtiidxni ni rusḻaa lo dojḻ.  
\v 10 Sa'csi Dios najc ni rujn yäḻguxhtissa'c, diza lajzni jiäḻ ni rujntu la'tu näj yäḻsanälajz ni rajptu par laani che racnäjtu rebejtznu lo yäḻrililajz, luxh guixe-guixee si'c rujntu.  
\v 11 N̲aj rlajznu tejgatu chanuu ga'p lagajc yäḻrbalajzre dxe lultli, te gac guiraa ni cabäjztu.  
\v 12 Rlajznu na'c gactu bejṉ ni rbedxitis, alga guntu sigajc bejn rebeṉ galoo, gopdzu'tzreni yäḻrililajz ni batipduxh lajzreni, guläjzreni te cua'reni reyäḻnasa'c ni bia'n diidx gudeed Dios lojreni. 
\p  
\v 13 Luxh che bia'n Dios diidx loj toxtadgoldoonu Abram, guniini por lagajc laani sa'csi ruti stee ni sajcru lojni.  
\v 14 Scree gunii Dios: “Guliä sacnää́ luj, sunidxäza xhidajl xi'nlu.”  
\v 15 Cheni aguläjz Abram xchej, gusojb diidx, cua'ni nani gunii Dios lojni.  
\v 16 Sa'csi cheni rniliipac bejṉ te diidx, rniireni diidxga por laj ste'ca bejṉ ni sajcru lojreni, sas che rusä'treni laj bejṉga xhetru yu'di xhi gunreni biejy.  
\v 17 Rlajz Dios gacbeepac rexagdoo toAbram sisiojbpac diidx ni bia'nni che guniini loj Abram galooli. Sisiojbpac xtiidxni, sa'csi guniini diidx con lagajc lajni che bia'nni diidxga.  
\v 18 Ni'cni ṉaj yu' tiop diidx ni digacdi guichaa sa'csi digacdi guinii Dios didx-xhii, rusoobpacni xtiidxni, rudeedzani yäḻrbedxilajz loj renani gubig-guxuṉ lojni, loj reni sanuu loj yäḻrililajz xtiidxni nani abaniidxni loonu por lagajc lajni.  
\v 19 Laa ni'cni cabääznu ni rusudzu'tz lajznu si'c duu-guiib con ancl ni rniazdzu'tz te barcw. Si'c rusudzu'tzni lastoonu te jionnu cadro yu'ni detz ladró.  
\v 20 Lagajc ro'c biu' Jesucrist xcuent nuure, te galooli baxhalni xnez Dios loonu, te gujcni bixhojzro par tejpas si'c gujcza bixhojz nani laa Melquisedec. 
\c 7  
\s1 Jesucrist najc bixhojzro si'c najc Melquisedec 
\p  
\v 1 Galoo che gujc Melquisedec ṟeii xten guedx Salem, gujcni bixhojzro xten Gueb Dios. Che gubi' Abram che gulujx gueṟ cadro bagu'tni reṟeii ni bidxe'ch lojni, huichagloj Melquisedecni, sas gunabni lo Dios te gacnäjru Dios Abram.  
\v 2 Dxejcti bejn Abram tzuu cuaa guiraa ni bejnni gaan, te badeedni tej cuaani loj Melquisedec. Laj Melquisedec säloj “ṟeii ni runsa'c yäḻguxhtis”, dxejctiru ṟeii xten guedx Salem sälojzani “ṟeii xten yäḻrbedxilajz”.  
\v 3 Baluiilojni lojreni, niluxh dinu gan chu najc xtadni, niclaza chu najc xnanni, niclaza chu najc resa'ni. Dizanu gan guc gojlni niclaza guc gujtni. Gujcni si'c najc Xi'n Dios. Najctiszani bixhojzro par tejpas. 
\p  
\v 4 N̲aj coḻhuii, lacti te beṉsa'c, te beṉro najc Melquisedec. Lojni badeed toxtadgoldoonu Abram tejga ni sajcru lo tejga tzuu ni bejnni gaan. Luxh Abram najc bejṉ ni sajcru lo rexpejṉni.  
\v 5 Leii xten Moisés, rnibee xca' rebixhojz ni najc xfamiḻ Leví te cuaa lo sa'reni si'c ni badeed toAbram loj Melquisedec, mase najcreni rexagdoo Abram.  
\v 6 Niluxh di Melquisedec gac xfamiḻ Leví. Niluxh badeed Abram te cuaa xhixtenni loj Melquisedec. Dxejcti benle'ni Abram ni biannäj xtidx Dios.  
\v 7 N̲aj rut sajcdi guinii garenca, sa'csi nani sajcru runle' yejc nani guxiiru sajc.  
\v 8 N̲aj rebixhojz ni rca' tejga lo tzuu ni rajpreni, najc bejṉ ni rejt. Niluxh rnii xtidx Dios xcuent Melquisedec ni cua' te cuaani galooli: najcni si'c te bixhojz nani nabajṉ par tejpas.  
\v 9 Ni'cni sajc guiniinu xcuent Leví nani rca' te cuaa, lagajc laani agudijx te cuaaga che badeed Abram tejga yejc tzuuga lo Melquisedec.  
\v 10 Sa'csi mase gajd xi'n toAbram chu che huichagloj Melquisedecni, batijpni lastooni sa'csi abia'n diidx sudeed Dios xajgni. Ni'cni che agudijxni te cuaaga najcni si'cni suganäjni rexajgni. 
\p  
\v 11 Rexpejṉ Israel cua' leii che gujc bixhojz relevitas, reni najc rexi'n toAarón. Paru niajc niujnreni nibaṉsa'c rebejṉ ni huisanäj leiiga, dirureni niquiin niääd stee bixhojz ni di gac si'c Aarón, alga si'c najc bixhojz Melquisedec najcni.  
\v 12 Sa'csi cheni rdxaa te cuaa bixhojz nanab näjza leiiga guidxaa.  
\v 13 Niluxh rnii xtidx Dios, Dad Jesucrist najc bejṉ xten garenca famiḻ. Luxh nicla tej bixhojz gajd gac bejṉ xten famiḻga.  
\v 14 Huenliisi najnnu najc Dad Jesucrist te bejṉ xten xfamiḻ toJudá, niluxh di Moisés ninii gac te rexpejṉ Judá bixhojz. 
\p  
\v 15 Luxh huenliisi najc ni rniinu, sa'csi abiricaj ste bixhojz ni najc sigajc gujc Melquisedec.  
\v 16 Luxh dini niajc bixhojz si'c rnii releii ni guyu' dxejc. Laani gujcni bixhojz xcuent yäḻrnibee ni najc par tejpas, ni rut gacdi gutzujḻ.  
\v 17 Scree najc diidx ni gunii Dios xcuentni: 
\q1 Luj najclu bixhojz par tejpas si'c gujc te niguii ni laa Melquisedec. 
\m  
\v 18 Dxejcti gunijt leii sa'csi xlia'si gujcni, di niajcdi niujn bejṉ si'cni rniini.  
\v 19 Di xleii toMoisés niujn gaan nibaṉsa'c bejṉ. N̲aj lacuaa leiiga rajpnu te xcäḻrililazsa'c; ni'c rujn rbignu lo Dios. 
\p  
\v 20 Dios bejn gacni bixhojz con xtidxliini, ni guniini con lagajc lajni.  
\v 21 Stecuaa rebixhojz gujcreni bixhojz niluxh et con didxliidire, con laj te beṉro, niluxh bixhojzre guc bixhojz con didxlii, con laj nani räjp: 
\q1 Agunilii Dios diidx con lagajc lajni, 
\q1 niluxh dini gusiech lajzni, räjpni: 
\q1 “Luj najclu te bixhojzro par tejpas, 
\q1 lagajc si'c gujc Melquisedec.” 
\m  
\v 22 Ni'cni, Jesucrist najc ni rujn rile' rediidxre, luxh diidxre sajcruni loj xleii Moisés.  
\v 23 Guyu' xhidalduxh stecuaa rebixhojz, sa'csi rejtreni, digacdi chanuureni gacreni bixhojz.  
\v 24 Niluxh Jesucrist rajpni yäḻnabajṉ par tejpas, ṉaj najczani bixhojz par tejpas.  
\v 25 Ni'c rajcza rusḻaani bejṉ lo dojḻ par tejpas. Rusḻaani guiraa renani rbig lo Dios por laani, sa'csi anabajṉni par tejpas te canabni lo Dios xcuent laareni. 
\p  
\v 26 Jesucrist najc bixhojzro nani rquiinnu. Laani najc dxan, dini niujn dojḻ, agubicajni lo rebeṉ-dojḻ, huäjszani jiaaru xhaguibaa.  
\v 27 Dini gac si'c stecuaa rebixhojz ni nanab ju't man guixe-guixee te guze'c bixhojzroni lo Dios te ganid jiaa lagajc xtojḻni. Dxejcti sajc guibi'ni guze'cnini lo Dios xcuent xtojḻ rebejṉ. Niluxh Jesucrist tejtis huält gudejdni trabajw, bejnnini cheni cuajni lo crujz, baxhe'ni xtiejnni xcuent nuure, gujtni. Si'c gudijxni xtojḻnu par tejpas.  
\v 28 Leii xten Moisés rusaan gac bixhojzro te bejṉ nani rejt, niluxh didxlii ni gunii Dios con lagajc lajni guleni tejni gac bixhojzro lagajc Xi'nni nani naya, nani nabaṉsa'c par tejpas. 
\c 8  
\s1 Jesucrist najc nani rusiäjḻ diidx 
\p  
\v 1 Diidx ni sajcru loj rediidx ni caniinu najc scree: bixhojz ni najc xpixhojzronu agurej xladbee Dios lo xcäḻrdimbicha'ni xhaguibaa.  
\v 2 Neṉ yu' ni najc dxan, neṉ guidoo ni benchee Dios yu' bixhojzre, xhet neṉdi guidoo ni runchee rebeṉ lo guedxliuj.  
\v 3 Guiraa rebixhojz rajc rudeedreni gojṉ lo Dios, rajcza ju'treni guidxaa te gusejcreni lo Dios xcuent xtojḻreni, ni'cni nanab ga'p Jesucrist xhi gudeedni lo Dios.  
\v 4 Paru suga'ni lo guedxliujre, nicla bixhojz dini niajc, sa'csi yu' bixhojz ni rudeed regojṉ si'c ni rnibee xleii Moisés.  
\v 5 Niluxh redzuun ni rujn rebixhojzga najc si'c te balaa xten guira'ti ni yu' xhaguibaa. Najnnu najcreni balaa sa'csi balijdx Dios Moisés cheni agojl gunni xquidoo Dios, räjp Dios lojni: “Bahuii te gunlu guira'ti si'cpac ni baluiä lojlu lo dan Sinaí.”  
\v 6 Niluxh xpixhojznu Jesucrist rujn dzuun ni sajcru, sa'csi najcni nani suga' galäii xnezyuj Dios loj rebeṉ guedxliuj, gusule'ni diidx ni gunii Dios cheni bejnni xhigabcoob, basa'nni didxcoob loj rebeṉ guedxliuj. Luxh didxcoobre sacduxhruni. 
\p  
\v 7 Paru niajc nusiejch leii ni badeed Dios galooli lo Moisés lajz rebejṉ, di niquiin niujn Dios ste xhigabcoob.  
\v 8 Niluxh bahuii Dios xhet cayunsa'cdi rebeṉ guedxluij, dxejc räjpni: 
\q1 N̲aj rniliä sidzujṉ redxej che gunä stee xhigab, 
\q1 jia'n stee diidx loj rexpejṉ Israel näjza loj rexpejṉ Judá te xca'reni didxcoob. 
\q1  
\v 9 Xhet si'cdi xhigab ni benä che bia'nä diidx loj retoxtadgoldooreni neṉ redxej ni gunazä ṉaareni te gulää́reni lajdx rebeṉ Egipto. 
\q1 Laareni direni nusoob xtidxä ni'c basa'näreni, diruna niuäreni. 
\q1 Si'c gunii Dad, Gueb Dios. 
\q1  
\v 10 Niluxh diidx nani runä xhigab rlazä jia'n diidx loj rexpejṉ Israel neṉ redxejre gac scree, räjp Dad: 
\q1 Sunä chu rexleiä lo xcäriejnreni, sucuaäza xtidxä neṉ lastooreni. 
\q1 Dxejcti narä gacä Xtiosreni, laareni gac rexpeṉä. 
\q1  
\v 11 Rut chu tejdi guluii sa'ni, 
\q1 nicla bejtzni, nicla chu stee bejṉ gäbreni, “coḻyembee Dad”, 
\q1 sa'csi alanumbee guiraareni narä, rebäz sigajc rebeṉgool. 
\q1  
\v 12 Narä sulaslazäreni susiaä redzundxuudx ni bejnreni, diru lazä guizaj rextojḻreni, nicla latzsiaj ni bejnreni. 
\m  
\v 13 Che bia'n Dios didxcoob, diidx nani bia'nni galoo agujcni didx-biejw, luxh nani anajc didx-biejw, xhetru sajcdini. 
\c 9  
\s1 Xquidoo guedxliujre näjza guidoo xhaguibaa 
\p  
\v 1 Laaca ṉaj. Diidx ni bia'n galoo badeed leii xho gunreni che rajṉreni Dios, näjza xho gac guidoo lo guidxliujre.  
\v 2 Guc-chee guidoo dxejcti gojḻ te ladro galäiini te gujcni tio'p yu'. Yu' ni najc ganid laani yudxan. Ro'c suga' candilieer, näjza mex cadro naga' yätxtiil ni aguc le'  
\v 3 Ni rojp yu'ga najc dejtz ladro, ro'c najc yudxanduxh.  
\v 4 Ro'c suga' te guiib cadro ru' yaal. Najcni ganax oor. Ro'c yu'za te guijn ni laa “arco de pacto”, najcwni ganax oor, sigajc dejtzni, sigajcza neṉni. Neṉga yu' te bo't ganax oor. Neṉ bo'tga, yu' yätxtiil ni laa mana. Lagajcza neṉ guijnga yu' bar xten toAarón nani biga', guyu' bid lojni, näjza guij cadro bacuaa Dios xleii toMoisés.  
\v 5 Yejc guijnga caj tio'p figur oor ni najc si'c xangl Dios. Laareni rujn racbee bejṉ suga' Dios ro'c. Lagajc redee rusäuu con rexhigareni cadro ruxhe' bixhojzro xtiejn guidxaa xcuent xtojḻ rebejṉ. Ro'cti di gacdiru guiniirunu xcuentreni ṉaj. 
\p  
\v 6 Che gulujx gusucheereni, riu' rebixhojz si'csi si'c neṉ guidoo, neṉ yudxan te rajṉreni Dios si'c gunibee Dios.  
\v 7 Niluxh neṉ stee yu'ga ni laa yudxanduxh, ro'c rajc riu' bixhojzrotis. Xtebtisni riu'ni, luxh tejtis huält neṉ teb ijz, te chanäni xtiejn reguidxaa ni gudeedni te jia xtojḻni näjza te jia xtojḻ rebejṉ ni najc xpejṉ Israel.  
\v 8 Luxh guiraa reni'c ruluii Sprit Dxan xten Dios loonu, gajd yudxanduxh guxal che sugasijc yu' ganid, yu' ni laa dxan, cadro sanuu rajṉreni Dios.  
\v 9 Guiraa ni gujc galoo najc si'c te balaa, baluiini xho gacni ṉaj. Regon näjza reman ni rudeedreni lo Dios direni nusansa'c xcäriejn reni rudeed gojn lo Dios, sa'csi xtiejn reman rusäutisni lo xtojḻ rebejṉ.  
\v 10 Dee najc ganaxtis xhi rajwni, ni rä'ni, con yäḻrobnis, o xhi stee dzuun ni rujn bejṉ te ria ganaxtis tiejxhreni che guidzujṉli dxej cheni guchaa Dios guira'ti. 
\p  
\v 11 Niluxh abiääd Jesucrist, ṉaj laani najc bixhojzro xcuent redidxcoob ni sajcru ṉaj. Nacoob guidoro cadro biu' bixhojzre, nasa'cruni ṉaj. Xhet con ṉaadi bejṉ guc-cheeni. Dizani gac guidoo guedxliujre.  
\v 12 Abiu' Jesucrist cadro najcpac yu' ni laa dxanduxh, niluxh xhet xtiejndi redxib, regon; ganax lagajc xtiejnni ca'ni biu'ni yudxanduxh tejtis huält, te si'c basḻaani nuure lo dojḻ par tejpas.  
\v 13 Reni basia xtojḻ bejṉ galoo najc redee: xtiejn regon näjza redxib, näj cobdäj xten reguidxaa ni rejc neṉ guidodxanga; bastiojbni guiro'preni yejc reni yu' xtojḻni.  
\v 14 Paḻga basia redee xtojḻ bejṉ, aticaxh xtiejn Jesucrist sajc gusia dojḻ, sa'csi rajpni yäḻnabajṉ par tejpas. Lagajc laani badeedni xtiejnni lo Dios. Niluxh najcni renya sa'csi dini niujn dojḻ, rusiazani xcäriejnnu xcuent retzuun ni xhet sajcdi, te chunu loj Dios ni nabajṉ par tejpas. 
\p  
\v 15 Ni'cni Jesucrist najc nani suga' galäii: nez lo Dios näjza nez loj rebeṉ guedxliuj xcuent didxcoob. Yäḻgujt xten Jesucrist najc te gudzucajni xtojḻ rebeṉ näjza xtojḻ renani bejn si'cni caj lo leii, te xca' guiraa reni agurejdx Dios yäḻnabajṉ par tejpas, si'c bia'n diidx galooli.  
\v 16 Didxcoobre najc si'c che rlajz tej bejṉ guinibee xho guidis xhixtenni che agojl guetni, nanab gucuaa bejṉga lo te guijtz xho guidisni, dxejcti gucuaani lajni. Niluxh xhet sajcdi guijtzga che gajd bejṉga guet.  
\v 17 Xhet sajcdi guijtzga che nabaṉsijc nani bejnni. Sajcni che agujt bejṉga.  
\v 18 Ni'cni che bia'n Dios diidx loj rexpejṉ Israel galoo, gujt te man te bixe' rejn.  
\v 19 Che gulujx gunii Moisés rediidx si'c ni caj lo leii loj guiraa rexpejṉ Israel, bagu'tni rebiseṟ, redxib, cua'ni rejnga näjza nis, bahuajdxni guid-xiil xniaa näjza te la' yajg balagbäz, hysopo, dxejcti bastiojbni rejn yejc guijtz cadro caj leii, näjza yejc rebejṉ.  
\v 20 Dxejc guniini lojreni: “Rejnre najc seen sile'pac diidx ni abaxhaḻ Dios lojtu.” 
\m  
\v 21 Sigajcza bastiojb Moisés rejn guidoo näj guiraa renani rquiin rebixhojz che rajṉreni Dios.  
\v 22 Leii xten Moisés rnibee jia guiralii con rejn, palga di rejn guixe', di xtojḻ bejṉ jia. 
\s1 Xtiejn Jesucrist rudzucaj dojḻ 
\p  
\v 23 Ni'cni biquiinpac gujt remanre, bixe' xtiejnni te basiani reni najc xpalaa reni yu' xhaguibaa, niluxh reni yu' xhaguibaa rquiin guixe' xtiejn te ni sajcru.  
\v 24 Di Jesucrist niu' neṉ guidoo ni benchee rebejṉ, ni najc xpalaa guidoopac xten Dios xhaguibaa. Laani biu'ni lagajc xhaguibaa, te laani suga'ni nez lojpac Dios te caniini xcuent nuure loj Dios.  
\v 25 Bixhojzro xten xpeṉ Israel biu' neṉ yu' ni laa dxanduxh tejtis huält neṉ teb ijz, ca'ni xtiejn reguidxaa. Niluxh Crist biu' xquidoopac Dios xhaguibaa tejtis huält par tejpas, luxh ca'ni lagajc xtiejnni. Di guiquiin jiu'runi balti huält.  
\v 26 Palga nanab gunni si'cni rujn rebixhojz, sajpni por niejtni te chinaduxh huält cheli birixtiej guedxliuj. Luxh ṉaj, cheni bidzujṉ dxej, baluiloj Jesucrist tejtis huält, lagajc laani badeedzani xtiejnni lo Dios cheni gujtni, cuajni lo crujz te si'c badzucajni par tejpas xtojḻ rebejṉ.  
\v 27 Guiraa bejṉ nanabpac guetreni tejtis huält, dxejctiru sidejdreni yäḻguxhtis xten Dios.  
\v 28 Sigajcza tejtis huält badeed Jesucrist xtiejnni ni bixe' lo crujz te badzucajni xtojḻ xhidalduxh bejṉ. Luxh loj renani cabäjzni suluiilojni stehuält, xhet te gudzucajdiruni dojḻ, alga te gusa'ni xcäḻrusḻaa renani cabäjzni. 
\c 10  
\p  
\v 1 Sa'csi leii xten toMoisés najctis si'c te balaa xten nani siääd ṉaj. Niluxh dini gac si'cpac redidxcoobga. Ni'cni leii, con xtiejn reguidxaa ni rxe' cazob ijz digacdi gunsa'cni rebejṉ nani guibig lo Dios, sa'csi di xtiejn man gudzucajpac rextojḻreni.  
\v 2 Paru niajc nibicajpac xtojḻ reni rudeed xtiejn guidxaa, aguläjz rudeedreni xtiejn guidxaa, sa'csi che gubicaj xtojḻreni, diru xcäriejnreni gumbee dojḻ.  
\v 3 Niluxh yäḻrejt man näj yäḻrudeedreni rejn casob ijz rusnajtisreni lajzreni xcuent dojḻ.  
\v 4 Sa'csi digacdi gudzucajpac regon näjza xtiejn redxib xtojḻ bejṉ. 
\p  
\v 5 Ni'cni che biääd Jesucrist lo guedxliuj räjpni lo Dios: 
\q1 Di rlajzlu xtiejn guidxaa niclaza regon niluxh abejnlu gacä nigui-guedxliuj. 
\q1  
\v 6 Dilu nichaglajz yäḻrejc xten guidxaa niclaza yäḻrudeed rejn, niclaza gojn ni rudeed rebejṉ te gusiani xtojḻreni. 
\q1  
\v 7 Dxejc räpä: “Narä basiälä te gunä si'cni rlajzlu Dad, Dios, (si'cni caj neṉ reguijtz xcuent ni sacä).” 
\p  
\v 8 Che gulujx gunii Jesucrist diidxga: “Di rlajzlu, dizalu guidxaglajz xcäḻrejt guidxaa näjza regon niclaza xcäḻrejc guidxaa, niclaza yäḻrudeed rejn xcuent xtojḻ bejṉ si'cni caj lo leii gun bejṉ.”  
\v 9 Dxejcti räjpni: “Narä siälä, te gunä si'cpac ni rlajzlu, Dad Dios.” Dxejc badzucaj Jesucrist nani gujc galoo, te guläxtiejni didxcoob ni bia'n Dios loonu ṉaj.  
\v 10 Abasia Dios lastoonu sa'csi bejn Jesucrist si'c rlajz Dios cheni baxhe'ni xtiejnni lo crujz tejtis huält par tejpas. 
\p  
\v 11 Guiraa rexpixhojz Israel rujnreni dzuun guixe-guixee te rudeedreni lagajctis guidxaa, näjza xtiejn reman, guiraa si'ctis ni caj lo leii, niluxh reni'c digacdi gudzucaj dojḻ.  
\v 12 Niluxh Jesucrist tejtis huält baxhe' xtiejnni lo crujz te badzucajni xtojḻ rebejṉ par tejpas. N̲aj agurejni xladbee Dios cadro rnibeeni.  
\v 13 Ro'c cabäjzni guiraa ni rdxe'ch lojni te cuereni ladzni'ni.  
\v 14 Ni'cni tejtis huält cuajni lo crujz te basiani par tejpas guiraa renani ahuililajz xtiidxni.  
\v 15 Sigajcza rnii Sprit Dxan xten Dios loonu; najni: 
\q1  
\v 16 Diidx nani jiannää́reni neṉ redxejre gac scree, 
\q1 naj Dad Dios: sucuaä rextidxä lo xcäriejnreni, 
\q1 susäḻäza xtidxä neṉ lastooreni. 
\m Dxejcti räjpni: 
\q1  
\v 17 Diru lazä guizaj rextojḻreni nicla rextoḻguijdxreni. 
\m  
\v 18 Ni'cni, cheni abia xtojḻ bejṉ, diru quiquiin gudeedreni guidxaa te jia rextojḻreni. 
\s1 Nanab guibignu lo Dios 
\p  
\v 19 Ni'cni resa'nu, na'c guidxejbtu, sajc jiu'nu yudxanduxh cadro bixe' xtiejn Dad Jesucrist nani abadeedni lo Dios.  
\v 20 N̲aj yu' te nezyuj, nezsiucoob, nezyuj xten xcäḻnabaṉcoobnu ni baxhalni che badzucajni ladroga. Ni'c säloj cheni biu'ni neṉ yudxanduxh, badeedni lagajc xtiejnni lo Dios.  
\v 21 Jesucrist najc xpixhojzronu nani rnibee rexpejṉ Dios.  
\v 22 Ni'cni do'o guibigrunu lo Dios guideb lastosa'cnu, na'c guidxejbdinu, na'cza guitujydinu. Con yäḻrililajzpac abia lastoonu xcuent rexhigabguijdx, abidiibza tiejxhnu lo nis-ya.  
\v 23 Do'o chanuu sudzu'tznu lo xtiidxni nani huililajznu, na'c guchaanu xhigabnu sa'csi susoob Dios diidx ni bia'nni loonu.  
\v 24 N̲aj do'o guihuii xho jiennu te gacnäj sa'nu te si'c chonälajznu sa'nu nägajcza te jiennu ganax dzunsa'c.  
\v 25 Na'c jiennu si'c rujn rebejṉ nani diru jiääd che rdxagsa'nu. Nanab guiliidxnu resa'nu sa'csi ṉaj asiäddzuṉgajxh dxej ni guibi' Dad Jesucrist. 
\p  
\v 26 Palga chanuu jienrunu dojḻ, niluxh abiejn diajgnu xtidx Jesucrist, diru gacdi guibicaj xtojḻnu dxejc.  
\v 27 Dxejcsii guidxeebtisnu guilääznu yäḻguxhtisduxh xten Dios näj guiboo ni guze'c renani rdxe'ch loj Dios.  
\v 28 Cheni guyu' chu tej ni di niujn si'c caj lo xleii Moisés, niluxh bidxaag xtidx tio'p o choṉ ni nancheepac, räjpreni dini nusoob leii, gujt bejṉga, rut balaslajzdini.  
\v 29 Maazru yäḻrusacsíduxh nanab ted renani ruläj yejc Xi'n Dios cheni direni gusobdiajg xtiidxni. Alga ruṟo'nreni xtiejnni ni baxhe'ni lo crujz te basianini. Rusanxtujyzani Sprit Dxan xten Dios nani badeed didxcoob lojni.  
\v 30 Anancheenu gunii Dios: “Narä susquixä bejṉ; loä siguijx bejṉ”, räjp Dios. Stehuält guniini: “Dad sujn yäḻguxhtis rexpejṉni.”  
\v 31 ¡Cosduxh gac bejṉ ni jiajb ladzṉaa Dios nani nabajṉ par tejpas! 
\p  
\v 32 Niluxh coḻsnaj lajztu xho gujctu galoo; cheni entis cua'tu xtidx Dios, xho batip lajztu, gudejdtu trabajw sa'csi cua'tu xtidx Dios.  
\v 33 Guyu' resa'tu gudéreni lojni, yu' reni basacsí la'tu nez loj rebejṉ. Guyu'za huält astoo gudejdzatu trabajw sa'csi cahuiitu rebejṉ nani basacsíreni, cadejdzareni trabajw.  
\v 34 La'tu banaj lajztu renani yu' latzguiib, guideb yäḻrbalajz batip lajztu che cua'reni guiraa xhixtentu, sa'csi gucbeetu xhaguibaa rajptu reyäḻnasa'c ni sajcru, niluxh yu'ni par tejpas.  
\v 35 Na'c gunijttu xcäḻrililajz xtidx Jesucrist, sa'csi yäḻrililajzga gun xca'tu yäḻnabajṉ par tejpas.  
\v 36 La'tu nanab cuedxitu te che abejntu ni rlajz Dios, dxejc xca'tu nani aguniini guniidxni.  
\v 37 Sa'csi xtidx Dios ni bia'n rnii: 
\q1 Asiäddzuṉgajxhpac dxej ni jiäädni, 
\q1 asiäddzuṉgajxhpac dxej ni jiääd nani siääd, dipacni gaclaa. 
\q1  
\v 38 Renani nabaṉsa'c sibaṉnäj yäḻrililajz, 
\q1 niluxh palga yu' chutej ni guidxejb chalilajz, 
\q1 dini'c gun guibaa lazä. 
\m  
\v 39 Niluxh nuure dinu gac si'c reni rusaan yäḻrililajz te nitreni loj dojḻ. Nuure najcnu renani rililajz xtidx Jesucrist te ḻaa xaimnu par tejpas. 
\c 11  
\s1 Yäḻrililajz 
\p  
\v 1 ¿Xhini'c najc yäḻrililajz? Yäḻrililajz säloj cabääznu sajcpac tejni gajd gac, yu'pacza ni mase dinu fiini, najcni si'cni abahuiinuni.  
\v 2 Dios huinälajz retoxtadgoldoonu sa'csi huililajzreni xtiidxni. 
\p  
\v 3 Sa'csi rililajznu, najnnu benchee Dios reguedxliuj, bencheeni guibaa, bencheezani guiraa nani rhuiinu. Con xtiidxtisni bencheeni nani dinu guihuii. 
\p  
\v 4 Gojpza toAbel yäḻrililajz badzubyaalni rexquidxaani lo Dios. Yäḻrbijbyaal xtenni sajcru loj yäḻrbibyaal xten toCaín. Ni'cni gunii Dios najc toAbel beṉsa'c. N̲aj mase agujt Abel, sanuutis racbeenu xcuent yäḻrililajz ni gojpni. 
\p  
\v 5 Sigajcza gojp Enoc yäḻrililajz, ni'c sinä Dios Enoc xhaguibaa, guideb nabajṉni, te na'c niejtni. Diru rebejṉ nidxälni sa'csi asinä Diosni xhaguibaa. Luxh räjp Dios xcuentni che gajd Dios jinäni, gubaṉsa'cni, baspaani lajz Dios.  
\v 6 Rut chu tejdi sajc guspaa lajz Dios palga dini chalilajz, sa'csi che guibigni lojni, nanab chalilajzni yu' Dios, chalilajzzani sudeed Dios xcäḻnasa'cni loj renani rguiilni, nalajznu renani rlajz gumbeepac Dios. 
\p  
\v 7 Gojpza toNoé yäḻrililajz. Che räjp Dios lojni siajbpac nisguij ni gajdreni fii, huililajzni. Bejnni si'c ni räjp Dios. Bidxejbni sa'csi najni rusoob Dios xtiidxni, ni'c bencheeni te canuduxh te di niejt rexi'nni. Sa'csi gojpni yäḻrililajzga, bejnni gubibde rebejṉ guedxliuj, gunijtreni sa'csi direni nililajz xtiidxni. Dxejcti cua'ni yäḻnabaṉsa'c ni siääd xcuent yäḻrililajz. 
\p  
\v 8 Sa'csi gojp toAbram yäḻrililajz, basoobni xtidx Dios che gurejdx Diosni, biriini lajdxni te huijni cadro gudeed Dios yuj lojni te cuääzni ro'c. Biriini lajdxni, mase dini gan caro chääni.  
\v 9 Gojp toAbram yäḻrililajz, ni'c huiläjzni si'c beṉzijt loj reyuj ni räjp Dios gudeedni lojreni. Ro'c guläjzreni si'c lajdx beṉzijt. Guläjzni neṉ reyuguijd, sigajcza bejn toIsaac näjza toJacoob, sa'csi näjza lojreni räjp Dios gudeedni yujga.  
\v 10 Niluxh toAbram cayunloj te guejdx nani sudzu'tz, te guejdx nani cuäxtiej Dios, nani gunchee lagajc Dios. 
\p  
\v 11 Sigajcza gojp toSara yäḻrililajz te mase anajcni beṉgool niluxh agudejd chu xi'nni, cua'ni yäḻrnibee xten Dios te gujcni nan, guyu' te xi'nni, sa'csi huililajzni susoob Dios xtiidxni.  
\v 12 Ni'cni mase siäddzuṉgajxh dxej ni guet toAbram, guyu' xhidalduxh xajgni. Si'c rebalxhaguibaa näj si'c reguibäzlule' xten yujxh ni tre' ro' nisdoo, si'c najcreni xhidalduxh, nicla gac guigabreni. 
\p  
\v 13 Guiraa rebejṉre gujt, direni nica' yuj nani räjp Dios gudeedni lojreni; niluxh sa'csi rajpreni yäḻrililajz, bahuiireni lo yujga zitro, ni'c bibalajzreni, sa'csi anajreni najcreni beṉzijt, cansajsireni lo guedxliuj.  
\v 14 Reni rnii si'c, rniliireni caguilsijcreni cadro gac lajdxreni.  
\v 15 Paru niujnreni xhigab lajdxreni najc guejdx cadro biriireni, pet niajc nibisacreni ro'c.  
\v 16 Niluxh laareni rlajzreni te lajdxreni ni sajcru, nalajznu lajdx Dios xhaguibaa, ni'c rguiilreni. Ni'cni di Dios guitujy gäbreni najcni Dios xtenreni, luxh alabencheeni guejdx cadro cuääzreni xhaguibaa. 
\p  
\v 17 Gojpza toAbram yäḻrililajz ni'cni cheni bateed Diosni preeb, räjpni loj Abram gudeedni Isaac lojni lacuaa gudeedni xhiil, cuäjbni gugu'tni xi'nni lacuaa xhiil, luxh Dios ni najc tejtis aräjp lojni galooli:  
\v 18 “Isaac guniidx chu xhidajl xajglu, xagdoolu.”  
\v 19 Sa'csi nanchee toAbram rajp Dios yäḻrnibee te guspajṉni rebeṉgut. Luxh si'cza cuasacni xi'nni, ascanu loj rebeṉgut cuasacni xi'nni. 
\p  
\v 20 Näjza toIsaac gojp yäḻrililajz benle'ni toJacoob näjza toEsaú, räjpni xhini'c gun tejgareni.  
\v 21 Gojpza toJacoob yäḻrililajz, che agojl guetni, benle'ni guiro'p rexi'n toJosé. Dxejcti huistieni guzucajni yejc bastoṉ xtenni te si'c gojṉni Dios.  
\v 22 ToJosé gojp yäḻrililajz. Che agojl guetni, räjpni sirii rexpejṉ Israel lajdx Egipto, gunibeezani xho gunnäjreni xtzujtni. 
\p  
\v 23 Gojp rexcuzajn Moisés yäḻrililajz, ni'c cheni gojḻ Moisés, bacua'tzrenini choṉ bäii, sa'csi bahuiireni bäzdaanni. Direni niu xtidx ṟeii ni gunibeeni, räjpni ju'treni bäz niguii.  
\v 24 ToMoisés gojp yäḻrililajz, ni'cni che aguroobni di rlajzni nirilajni xi'n xindxa'p ṟeii xten Egipto.  
\v 25 Bejnni xhigab tednäjni trabajw rexpejṉ Dios lacuaa niujnni redzuun ni rchaglajz rujn rebeṉ Egipto, sa'csi najc reni'c dojḻ, luxh tera'tsi ruspaareni lajz bejṉ.  
\v 26 Par laani maazru sajc tedni lagajc trabajw ni gudejd Jesucrist lacuaa niajpni reyäḻnasa'c xten Egipto sa'csi laani cabäjztisni reyäḻnasa'c nani churu gudeed Dios lojni.  
\v 27 Gojp toMoisés yäḻrililajz biriini lajdx reEgipto, dini nidxejb yäḻrdxe'ch xten ṟeii, huinuutis gusudzu'tzni si'cni najc xhigabni, ruhuiini loj nani di guzeṉ, nalajznu Dios. 
\p  
\v 28 Gojp Moisés yäḻrililajz bejnni lanij xten pascw. Gunibeeni baroobreni rejn ro' xpuert rexpejṉ Israel te che ted angl xten yäḻgujt nicla te xingan galoo xten rexpejṉ Israel di guet.  
\v 29 Gojp rexpejṉ Israel yäḻrililajz gudejdreni galäii nisdoo ni laa nisdoxniaa luxh asdoo loj yubijdz rsiajreni si'c gudejdreni. Niluxh che rlajz rebejṉ Egipto nidejd, gubi' nis, dxejc gulo'reni neṉ nis. 
\p  
\v 30 Xcuent yäḻrililajz gurebä'n paderguij xten guedx Jericó, cheni basa' gajdz dxej caded huält rexpejṉ Israel guejdxga.  
\v 31 ToRahab, te gunaguijdx, gojpzani yäḻrililajz ni'c dini niejt che gujt renani di nuzobdiidx, sa'csi laani bacua'tzni gaii bejṉ nani sagula'tz xho najc guejdxga. 
\p  
\v 32 ¿Xhiruxh guiniä? Di gaḻdi guiniä xcuent toGedeón, xcuent toBarac, xcuent toSansón, xcuent toJefté, xcuent toDavid, xcuent toSamuel, näjza xcuent retoprofe't.  
\v 33 Guiraareni gojp yäḻrililajz ni'c bejnreni gaan xhidajl reguejdx, bensa'creni yäḻguxhtis, cua'reni xcäḻracnäj Dios ni bia'n diidx xca'reni, basäureni ro' rebeedz.  
\v 34 Guyu'reni neṉ te balduxh luxh xhet gujcdireni, gojl baxuṉreni te di niejtreni con espaad. Reni gujc beṉrdxajg, guzutzu'tzreni gujcreni nadipduxh, gujcreni beṉduxh lo gueṟ, barilaagwreni resoldaad xten reni rdxe'ch lojreni.  
\v 35 Guyu' regunaa ni cuasac rextogoolreni, gubaṉsacreni lo rebeṉgut. 
\p Sgaiireni gujt xcuent yäḻrusacsí lacuaa nicäjbreni nusiech lajzreni te nusḻaa bejṉreni sa'csi rlajzreni xca'reni stee yäḻnabajṉ ni sajcru.  
\v 36 Sgaiireni gudejd trabajw guniyaj bejṉreni, gudinnäj bejṉreni chiir, cuaduuzareni cadeṉ, guyu'zareni latzguiib.  
\v 37 Guyu'za reni gujt che bacuaa bejṉ guij yejcreni o che gujcreni tio'p la' con sieṟ. Guyu'za reni basacsí bejṉ te guṟo'nreni yäḻrililajz. Guyu'za reni gujt con spaad. Guyu' reni cuanzaj nezree nezrec, gojtreni guid-xiil näjza guid-dxib, sa'csi xhet rajpdireni luxh entis rdejdreni trabajw rusacsí bejṉreni.  
\v 38 Sa' rebejṉga di nungäjḻ rebeṉ guedxliuj niääd rebejṉga lojreni. Cuanzaj rebejṉga nez lo reyubijdz cad xhet yu'di xhi gaureni nicla nis te yäreni; cuanzajreni nez neṉ redajn, nez neṉ rebiliää näj nez neṉ guedduxh ni yu' neṉ yuj.  
\v 39 Guiraa rebejṉga gojp yäḻrililajz, luxh ni'cni huä'p xpala'nreni, niluxh direni nica' ni bia'n diidx gudeed Dios lojreni,  
\v 40 sa'csi bejn Dios xhigab gunni te dzunsa'c lojreni. Bejn Dios xhigab guniidxni yälnasa'c loonu, ṉaj tejsi guica'nu con laareni nani bia'n diidx guniidx Dios. 
\c 12  
\s1 Guihuiitisnu lo Jesucrist 
\p  
\v 1 Ni'c najcni si'cni suga'nu galäii guiraa rebejṉre luxh cahuiireni xcäḻrililaaznu. Ni'c do'o guisa'n te laad guiraa reni rusäu lo xnejznu, näjza redojḻ ni ruxhiid nuure lo xcäḻnabajṉnu, te di jieednu chosaanu nez lo nezyuj ni sasanäänu nez cadro chonnu.  
\v 2 Do'o guihuidzu'tz nez loj Dad Jesucrist nani guläxtiej, nani guluuxza xcäḻrililajznu. Jesucrist gudejd trabajw lo crujz, dini nitujy gujtni lo sa' yäḻgujtga, sa'csi najnni cheni agudejdni trabajw, sica'ni yäḻrbalajz; ṉaj agurejni xladbee Dios cadro rnibeeni. 
\p  
\v 3 Coḻyujn xhigab la'tu xho gudejd Jesucrist ladzṉaa rebeṉ dojḻ, te na'c guidxajgtu, na'cza jieedtu laḻ ni cabäjztuni.  
\v 4 La'tu gajd xtiejntu guixe' lo yäḻrucuanäj dojḻ.  
\v 5 ¿La abiäḻ lajztu xho balijdx Dios la'tu si'c xi'nni, ä? Scree caj xtiidxni lo reguijtz; räjpni: 
\q1 Xinä, na'c cuälazlu xcäḻnaj Dad niclaza jieedlu che tiḻnäjni luj. 
\q1  
\v 6 Sa'csi si'c runnaj Dad renani sanälajzni, 
\q1 rujnni riaa guiraa renani rca'ni si'c xi'nni. 
\m  
\v 7 Palga gatijp lajzlu lo xcäḻnaj Dios, sica'ni luj si'c xi'nni, sa'csi ¿chu dad di gunnaj xi'nni?  
\v 8 Niluxh palga di Dios gunnaj la'tu si'cni runnajni guiraa rexi'nni, ditu gac xi'npacni, najctu xi'n redoḻguijdx.  
\v 9 Anajntu cheni gucnu biuux lo guedxliujre, bennaj xtadnu nuure te rsoobnu xtiidxni, te runsa'czanu si'cni rlajzni. ¿Xhicuent dinu cuadiajg xtidx xtadnu ni yu' xhaguibaa te si'c jia'pnu yäḻnabajṉ, ä?  
\v 10 Xtadnu lo guedxliujre bennajreni nuure tio'p-choṉ dxej, te gac gusoobnu xtiidxni. Niluxh si'c runnaj Dios nuure te jia'pnu te yäḻnabaṉya, te gac nayazanu sigajc najcni laani.  
\v 11 Guliini xhet xhi yäḻnajdi ni rchalonu najc laaca che rsiajcnuni, racnaj tiejxhnu niluxh ria'nnu et laadi. Niluxh guiraa renani agudejd loj yäḻnajga rusoob xtiidxni, rca'reni te yäḻnabaṉya ni rbecdxilajzreni. 
\s1 Riez guze'ni xtidx Dios 
\p  
\v 12 Ni'cni coḻsudzu'tz reṉaatu ni abadxajg, coḻsudzu'tz yecxhijbtu ni abadxajg,  
\v 13 te coḻquiil nezyuj xten xtidx Jesucrist te sudzu'tz ni'tu. Na'c guibicajtu lo xnezyujni. 
\p  
\v 14 Coḻquiil xho cuedxinäjtu guiraa rebejṉ. Coḻchanä te yäḻnabaṉya, sa'csi renani di guibaṉyadi, digacdi fiireni loj Dad Jesucrist.  
\v 15 Coḻhuisa'c te di gunijt chutejtu lo xcäḻracnäj Dios, coḻnatiro gac chu tejtu si'c te cuanlaa ni rujn daan, sa'csi sa' bejṉga suxhiṉni guiraa renani ahuililajz.  
\v 16 Nicla tejtu na'c ga'p stee gunaa te laad, nungäjḻ cuäznäjni chäältisni. Na'cza gactu bejṉ ni di jiu xtidx Dios, si'c gujc toEsaú cheni bato'ni xcäḻnasa'cni ni najc xtenni sa'csi najcni xingan galoo xtadni. Bato'nini te cua'ni yäḻrajwtis.  
\v 17 Anajntu, cheni rlajzni niunle' xtadnini te nica'ni ni najc xten xingangalooni, dini nica'ni mase guc-huin lajzni, binduxhni. Dxejcti diru niajcdi nica'nini. 
\p  
\v 18 Coḻnatiro, sa'csi la'tu di'tu nibig lo te dajn cadro rajc rsiaj bejṉ, te dajn ni galoo cayecduxh guiboo, cadro nacäjy, nacäiboo, cayajcza bedonduxh.  
\v 19 Diza diajgtu niejn xse' trompet, xse' Dios si'c biendiajg rexpejṉ Israel agujc xchero. Luxh che biejn diajgreni rediidxga, direni nutiplajz, gunabduxhreni na'cru guiniini lojreni.  
\v 20 (Sa'csi direni nutiplajz diidx ni caniini, räjpni: “Palga ted te mantis guläj xhuj dajnga, coḻju'tni con guij.”)  
\v 21 Te yäḻnadxebduxh najc nani guzeṉ ro'c, lagajc toMoisés räjp: “Cayacditä yäḻrdxejb.” 
\p  
\v 22 Niluxh la'tu agubigtu lo dajn xten Sión, cad najc lajdx Dios ni nabajṉpac, nalajznu guedx Jerusalén ni yu' xhaguibaa cadro yu' xhidalduxh xangl Dios,  
\v 23 cadro re' reni calä'p xpala'n Dios. Ro'c re'za reni najc xi'n Dios, renani acaj lajni xhaguibaa. Agubigzatu lo Diospac, ni najc Juejz xten guiraanu, näjza loj resprit xten rebejṉ nani abasia Dios te anajcreni beṉnasa'c.  
\v 24 Agubigzanu loj Jesucrist nani suga' galäii nez loj Dios näj beṉguedxliuj xcuent didxcoob ni bia'n Dios, näjza lo xtiejn Jesucrist ni badeedni lo Dios xcuent nuure. Jesucrist rniab jiäjḻ lajz Dios, luxh ni'c sajcru loj nani rniab xtiejn toAbel. Xtiejn toAbel rniab quiix nani bagu'tni. 
\p  
\v 25 Ni'c coḻnatiro te di cuälaztu nani canii lojtu rextiidxni. Palga di rebejṉ nidedbia sa'csi gulälaz nani baluii bejṉ ni siääd guedxliujre, ¿xho jiennu tedbianu palga guilälaznu nani ruluii nani siääd xhaguibaali?  
\v 26 Xse' Dios basniib guedxliuj galooli, niluxh ṉaj rnisacni: “Ste huält susnibä xhet ganaxdi guedxliuj, susnibä näjza xhaguibaa.”  
\v 27 Che gunii “ste huält”, ni'c säloj guibicaj renani benchee Dios ni rac rniib, te jia'n renani digacdi guiniib.  
\v 28 Luxh sa'csi lajdxnu ni guniidx Dios digacdi guiniibni, do'o guideed xquixtios lo Dios xcuentni, te si'c chunu loj Dios, chonälaaznuni guideb yäḻrdxejb näjza yäḻnadolajz,  
\v 29 sa'csi Xtiosnu najc si'c te balduxh ni ruse'c, ni runitlojza. 
\c 13  
\s1 Xho guspaa bejṉ lajz Dios 
\p  
\v 1 Coḻchanuu lo yäḻrinälajz sa'ni.  
\v 2 Di gusaantu gudeedtu rolijztu guidzujṉ biooz, sa'csi loj reni bejn si'c, yu'reni badeed rolijzreni bidzujṉ xangl Dios rolijzreni, niluxh direni niacbee chu najcreni. 
\p  
\v 3 Coḻsnaj lajztu reni yu' neṉ latzguiib, ascanu la la'tu ni yunäreni latzguiib. Coḻsnajza lajztu renani basacsí bejṉ, ascanu la la'tu ni cagusacsíreni sa'csi näjza la'tu najctu beṉguedxliuj si'c najcreni. 
\p  
\v 4 Coḻga'p xpala'n yäḻguchṉaa te guibaṉ-nayatu con chäältu sa'csi sujn Dios yäḻguxhtis rebejṉ ni resnäj chääl bejṉ näjza reni rusguee rebeṉxteb. 
\p  
\v 5 Na'c chanälajztu meel, coḻguibalaznäj ni rajptu, sa'csi Dios agunii: “Dipacna gusanälu, dizana cuälazälu.”  
\v 6 Ni'c dinu guidxeeb guiniinu: 
\q1 Dad ni yu' xhaguibaa najc ni rcanäj narä; 
\q1 dina guidxebä xhitis ni gunnäj bejṉ narä. 
\p  
\v 7 Coḻsnaj lajztu renani baluii guibaṉsa'ctu, ni basule'za xtidx Dios lojtu; coḻhuii xho nabajṉreni te sigajcza coḻchanä xcäḻrililajzreni. 
\p  
\v 8 Sigajc gujc Jesucrist naii, sigajcza najcni nadxej, sigajcza sajcni par tejpas.  
\v 9 Na'c gusaantu gusiejchreni lajztu xcuent ste'ca yäḻruluii ni digac si'c najc xtidx Jesucrist. Sacduxh sudzu'tz lastoonu lo yäḻracnäj ni ruluii xtidx Dios, xhet lojdi yäḻrajwtis. Xhet sajcdi rebejṉ nani rujntis xhigab xcuent yäḻrajw. 
\p  
\v 10 Nuurnu rajpnu garenca piään, ro'c digacdi xca' rebixhojz xhi gaureni si'c ni cua'reni neṉ guidoguijd galoo.  
\v 11 Sa'csi xpixhojzro xpejṉ Israel rinä xtiejn reman neṉ yu' ni laa dxanduxh te biäu lo dojḻ xten rebejṉ, niluxh rize'creni xpääl remanga te laad, dejtz guejdxga.  
\v 12 Si'cza gujt Jesucrist te laad, dejtz guejdx, te basiani xtojḻ rebejṉ xcuent lagajc xtiejnni.  
\v 13 N̲aj coḻcho' chonnu loj Jesucrist te laad dejtz guejdx te guideednu trabajw näjza yäḻxtujy si'cni gudejd Jesucrist.  
\v 14 Sa'csi lo guedxliujre dxunlaasinu, niluxh caguiilnu laadxnu ni chu jiäädru, te ro'c guidxunnu par tejpas.  
\v 15 Guideb xcäḻracnäj Jesucrist do'o guideedtisnu xquixtios lo Dios si'c te gojn ni gudeednu lojni, guiliä'pnu xpala'nni näj jieḻnu redij.  
\v 16 Na'cza jiäḻlajztu guntu huen, gacnäj sa'tu, sa'csi reni'cni najc redzuun ni rdxaglajz Dios. 
\p  
\v 17 Coḻcuadiajg xtidx reni rnibee la'tu, sa'csi laareni rcanäjreni lastoonu, si'cza laareni sudeedreni cuent lo Dios. Coḻyujn guibalajzreni gunreni xtzuunreni, na'c gac-huin lajzreni sa'csi palga gac-huin lajzreni, xhet sajcdini par la'tu. 
\p  
\v 18 Coḻnab lo Dios xcuent nuunu, sa'csi racbeenu naya xcäriejnnu, rlaaznu laaca jiennu guira'ti dzuun.  
\v 19 Rniä lojtu, guiniabrutu loj Dios, te gun Dios jiojb guibi'ä jiäḻä lojtu. 
\s1 Te didxle' näj lult xtixtios 
\p  
\v 20 Dios xten yäḻrbedxilajz ni baspajṉ Dad Jesucrist lo rebeṉgut, Jesucrist najc baxtorduxh xten rexiil xcuent rejn ni bejn gusojb didxcoob xtenni ni najc par tejpas.  
\v 21 Dios gun gactu beṉsa'c, beṉdxojn loj xhitis te guntu ni rlajzni, näj gunni loj guiraa nuure si'c ni rlajzni xcuent Jesucrist. ¡Coḻspaa lajz Jesucrist par tejpas! ¡Sugacni si'c! 
\p  
\v 22 Resa'nu, rniabä lojtu, coḻcuecdxi lajztu, coḻcuadiajg rediidx ni rulijdxre, sa'csi riojbga cacuaä te labäz guijtzre lojtu.  
\v 23 Coḻyacbee abirii bejtznu Timoteu latzguiib. Palga guidzuṉgajni ree, siädnää́ni jiädhuiä la'tu. 
\p  
\v 24 Coḻgudeed xtixtios loj guiraa renani ruluii la'tu näj loj guiraa rebejtznu ni rililajz. Rebeṉ Italia ruxhaḻ xtixtios lojtu. 
\p  
\v 25 Gacnäj Dios guiraatu. Sugacni si'c.