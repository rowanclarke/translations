\v 3  \w You|strong="H3605"\w* \w and|strong="H1121"\w* Aaron \w are|strong="H1121"\w* \w to|strong="H3318"\w* \w number|strong="H6485"\w* \w all|strong="H3605"\w* \w in|strong="H8141"\w* \w Israel|strong="H3478"\w* \w who|strong="H3605"\w* \w can|strong="H1121"\w* serve \w in|strong="H8141"\w* \w the|strong="H3605"\w* \w army|strong="H6635"\w*, \w those|strong="H3605"\w* \w who|strong="H3605"\w* \w are|strong="H1121"\w* \w twenty|strong="H6242"\w* \w years|strong="H8141"\w* \w old|strong="H1121"\w* \w or|strong="H1121"\w* \w older|strong="H4605"\w*, \w by|strong="H8141"\w* \w their|strong="H3605"\w* divisions.  
