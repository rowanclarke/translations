\id JOS
\h يَاشُووَا 
\toc1 يَاشُووَا 
\toc2 يَاشُووَا 
\toc3 ياش. 
\mt1 يَاشُووَا  
\c 1
\s1 ڒُومُورْ ن سِيذِي إِ ؤُطفُّو ن ثمُّورْثْ ن كنْعَانْ  
\m
\v 1 أَوَارْنِي إِ ڒْموْثْ ن مُوسَا، أَمْسخَّارْ ن سِيذِي، إِسِّيوڒْ سِيذِي أَكْ-ذ يَاشُووَا، مِّيسْ ن نُونْ، أَمْسخَّارْ ن مُوسَا، إِنَّا: \x ◘ \xo 1:‏1 \xt أَعَوذ. 34‏:‏5؛1‏:‏38\x*  
\v 2 ”مُوسَا، أَمْسخَّارْ إِنُو إِمُّوثْ. ڒخُّو كَّارْ، أكّْ خْ لْ-ؤُرْذُونْ-أَ، شكْ ذ مَارَّا ڒْڭنْسْ-أَ، غَارْ ثمُّورْثْ إِ ذ أَسنْ غَا وْشغْ نشّْ، إِ أَيْثْ ن إِسْرَائِيل.  
\v 3 كُوڒْ أَمْشَانْ مِينْ خفْ غَا ثعْجنْ ثْڒقَّا ن ؤُضَارْ نْومْ، أَقَا وْشِيغْ أَومْ ث إِ كنِّيوْ، أَمْ مَامّشْ إِ سِّيوْڒغْ نشّْ أَكْ-ذ مُوسَا. \x ◘ \xo 1:‏3 \xt أَعَوذ. 11‏:‏24؛ ياش. 14‏:‏9\x*  
\v 4 ثَامُّورْثْ نْومْ أَذْ ثِيڒِي زِي ڒخْڒَا أَڒْ لُوبْنَانْ-أَ، أَڒْ إِغْزَارْ أَمقّْرَانْ، إِغْزَارْ ن لْفُورَاطْ، مَارَّا ثَامُّورْثْ ن إِحِيتِّييّنْ أَڒْ ڒبْحَارْ أَمقّْرَانْ \add غَارْ ڒْغَارْبْ\add* مَانِي ثْغدْجِي ثْفُوشْثْ. \f ◼ \fr 1:‏4 \ft \+bd ’ڒبْحَارْ أَمقّْرَانْ‘\+bd* - نِيغْ ’إِلّْ أَمقّْرَانْ‘. ڒبْحَارْ-أَ قَّارنْ أَسْ ذِي أَرِيفْ ’ڒبْحَارْ أَمژْيَانْ‘ ؤُ إِسمْ نّسْ ن جْذِيذْ أَقَا-ث ’إِلّْ أَڭْرَاكَالْ‘.\f*  
\v 5 ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ إِقِّيمْ إِبدّْ زَّاثْ إِ وُوذمْ نّشْ مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّشْ. أَمْ مَامّشْ ذ أَيِي ثُوغَا أَكْ-ذ مُوسَا، أَذْ إِڒِيغْ ؤُڒَا أَكِيذكْ. نشّْ وَارْ ذَايكْ سمّْحغْ نِيغْ أَذْ شكْ تّجِّيغْ. \x ◘ \xo 1:‏5 \xt أَعَوذ. 31‏:‏6، 8؛ عبر. 13‏:‏5، 6\x*  
\v 6 إِڒِي ذ أَرْيَازْ ؤُ إِڒِي ثْمحْضذْ، مِينْزِي شكْ أَذْ ثَارّذْ ڒْڭنْسْ-أَ أَذْ إِطّفْ ثَامُّورْثْ ذ ڒْوَارْثْ، \add ثَامُّورْثْ نِّي\add* خْ نشّْ جُّودْجغْ إِ ڒجْذُوذْ نْسنْ أَذْ أَسنْ ت وْشغْ. \x ◘ \xo 1:‏6 \xt أَعَوذ. 31‏:‏23\x*  
\v 7 إِڒِي وَاهَا ذ أَرْيَازْ ؤُ إِڒِي ثْمحْضذْ، مَاحنْذْ أَذْ ثحْضِيذْ أَذْ ثڭّذْ مَارَّا شَّارِيعَا نِّي ذ أَشْ يُومُورْ مُوسَا، أَمْسخَّارْ إِنُو. وَارْ \add خَاسْ\add* تّْحيّذْ \add غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ، مَاحنْذْ أَذْ ثڭّذْ س ڒعْقڒْ مَانِي مَا إِ غَا ثْرَاحذْ. \x ◘ \xo 1:‏7 \xt أَعَوذ. 5‏:‏32؛ 28‏:‏14\x*  
\v 8 وَارْ تّجِّي شَا أَذْلِيسْ ن شَّارِيعَا-يَا أَذْ أَشْ إِتّْوَاكّسْ خْ يِيڒسْ نّشْ، مَاشَا خَارّصْ ذَايسْ أَسّْ ذ دْجِيڒثْ، مَاحنْذْ أَذْ ثحْضِيضْ أَذْ ثڭّذْ أَمُّو نِيشَانْ أَمْ مَامّشْ مَارَّا مِينْ ذَايسْ ثُورَا، مِينْزِي \add خنِّي\add* إِ غَا ثْفڒْحذْ ذڭْ وبْرِيذْ نّشْ ؤُشَا أَذْ ت ثڭّذْ س ڒعْقڒْ. \x ◘ \xo 1:‏8 \xt إِزهد. 1‏:‏2\x*  
\v 9 مَا وَارْ ذ أَشْ ث نِّيغْ؟ إِڒِي ذ أَرْيَازْ ؤُ إِڒِي ثْمحْضذْ، وَارْ تّڭّْوذْ ؤُ وَارْ تّجِّي أَذْ إِعْڭزْ وُوڒْ نّشْ، مِينْزِي سِيذِي، أَربِّي نّشْ، أَقَا-ث أَكِيذكْ قَاعْ مَانِي مَا إِ غَا ثْرَاحذْ.“   
\m
\v 10 ؤُشَا يُومُورْ يَاشُووَا إِ إِمحْضَاينْ ن ڒْڭنْسْ، إِنَّا:  
\v 11 ”ؤُيُورمْ خْ ڒْوسْطْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ ؤُشَا ؤُمُورْ ڒْڭنْسْ، إِنِيمْ \add أَسنْ\add*: ’سْوجْذثْ ڒعْوتْشْ إِ يِيخفْ نْومْ، مِينْزِي أَوَارْنِي إِ ثْڒَاثَا ن وُوسَّانْ أَذْ ثژْوَامْ لْ-ؤُرْذُونْ-أَ، حِيمَا أَذْ ثَاذْفمْ غَارْ ثمُّورْثْ إِ ذ أَومْ غَا إِوْشْ سِيذِي، أَربِّي نْومْ، ذ ڒْوَارْثْ ؤُشَا أَذْ ت ثكْسِيمْ ذ ڒْوَارْثْ.‘ “   
\m
\v 12 إِسِّيوڒْ يَاشُووَا أَكْ-ذ إِرُوبِينِييّنْ ذ إِجَاذِييّنْ ؤُ أَكْ-ذ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا، إِنَّا:  
\v 13 ”عقْڒثْ خْ وَاوَاڒْ نِّي خْ إِ ذ أَومْ يُومُورْ مُوسَا، أَمْسخَّارْ ن سِيذِي، ؤُمِي إِنَّا أَومْ: ’سِيذِي، أَربِّي نْومْ، إِوْشَا أَومْ أَرَّاحثْ ؤُشَا إِوْشَا أَومْ ثَامُّورْثْ-أَ.  
\v 14 ثِيمْغَارِينْ نْومْ، إِحنْجِيرنْ نْومْ ذ ڒبْهَايمْ نْومْ أَذْ قِّيمنْ ذِي ثمُّورْثْ إِ ذ أَومْ إِوْشَا مُوسَا خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ ؤُشَا كنِّيوْ أَذْ ثژْوَامْ ثْحزّْممْ زَّاثْ إِ وُوذمْ ن أَيْثْمَاثْومْ، مَارَّا أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، ؤُشَا كنِّيوْ أَذْ أَسنْ ثوْشمْ أَفُوسْ،  
\v 15 أَڒْ غَا يوْشْ سِيذِي أَرَّاحثْ إِ أَيْثْمَاثْومْ، أَمْ \add ثُوغَا إِوْشَا إِ\add* كنِّيوْ، ؤُشَا ؤُڒَا ذ نِيثْنِي أَذْ طّْفنْ ثَامُّورْثْ إِ ذ أَسنْ إِوْشَا سِيذِي، أَربِّي نْومْ، ذ ڒْوَارْثْ. \add خنِّي\add* أَذْ إِعدّڒْ أَذْ د-ثْذوْڒمْ غَارْ ثمُّورْثْ ثنِّي ذ ڒْوَارْثْ نْومْ ؤُشَا أَذْ ثْوَارْثمْ مِينْ ذ أَومْ إِوْشَا مُوسَا، أَمْسخَّارْ ن سِيذِي، خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ.“   
\m
\v 16 نِيثْنِي أَرِّينْ-د خْ يَاشُووَا، نَّانْ: ”مَارَّا مِينْ خفْ إِ ذ أَنغْ ثُومُورذْ، أَذْ ث نڭّْ ؤُ مَانِي مَا إِ ذ أَنغْ غَا ثسّكّذْ، أَذْ نُويُورْ.  
\v 17 أَمُّو نِيشَانْ أَمْ مَامّشْ نسْڒَا غَارْ مُوسَا، أَذْ غَاركْ نْسڒْ. مْغِيرْ إِڒِي أَذْ كِيكْ يِيڒِي سِيذِي، أَربِّي نّشْ، أَمْ مَامّشْ ثُوغَا إِدْجَا أَكْ-ذ مُوسَا!  
\v 18 كُوڒْ أَرْيَازْ نِّي إِ غَا إِعْصَانْ ڒُومُورْ نّشْ ؤُ وَارْ إِخْسْ أَذْ إِسڒْ إِ وَاوَاڒنْ نّشْ غَارْ مَارَّا مِينْ ذ أَسْ غَا ثُومُورذْ، أَذْ إِتّْوَانغْ. إِڒِي وَاهَا ذ أَرْيَازْ ؤُ إِڒِي ثْمحْضذْ!“   
\b  
\b  
\m  
\c 2
\s1 رَاحَابْ ذ ثْنَاينْ ن إِبرْڭَاڭنْ  
\m
\v 1 يَاشُووَا، مِّيسْ ن نُونْ، إِسّكّْ زِي شِيطِّيمْ ثْنَاينْ ن يرْيَازنْ مَاحنْذْ أَذْ برْڭَاڭنْ س ثْنُوفّْرَا، إِنَّا: ”ؤُيُورمْ، خْزَارمْ ثَامُّورْثْ ذ أَرِيحَا!“ فّْغنْ، إِوْضنْ غَارْ ثَادَّارْثْ ن إِشْثْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ، قَّارنْ أَسْ رَاحَابْ، ؤُشَا سّنْسنْ ذِينْ.  
\v 2 خبَّارنْ ث إِ ؤُجدْجِيذْ ن أَرِيحَا، نَّانْ: ”خْزَارْ، ذِي دْجِيڒثْ-أَ ؤُسِينْ-د ذَانِيثَا شَا ن يرْيَازنْ ن أَيْثْ ن إِسْرَائِيل، حِيمَا أَذْ برْڭَاڭنْ ذِي ثمُّورْثْ.“  
\v 3 إِسّكّْ ؤُجدْجِيذْ ن أَرِيحَا غَارْ رَاحَابْ مَاحنْذْ أَذْ أَسْ إِنِينْ: ”سُوفّغْ-د إِرْيَازنْ إِ د يُوذْفنْ غَارْ ثَادَّارْثْ نّمْ، مِينْزِي ؤُسِينْ-د، حِيمَا أَذْ كْسِينْ ڒخْبَارْ خْ مِينْ إِتّمْسَارَانْ ذِي مَارَّا ثَامُّورْثْ.“  
\v 4 أَقَا ثسِّيذفْ ثمْغَارْثْ ثْنَاينْ ن يرْيَازنْ نِّي ؤُشَا ثسّْنُوفَّارْ إِ-ثنْ. ثنَّا: ”س ثِيذتّْ، إِرْيَازنْ ؤُسِينْ-د غَارِي، مَاشَا وَارْ سِّينغْ مَانِيسْ نِيثْنِي.  
\v 5 ؤُمِي تّْوَابلّْعنْثْ ثوُّورَا \add ن ثنْذِينْثْ\add* غَارْ ؤُوطُّو ن ثَادْجسْثْ، فّْغنْ يرْيَازنْ. نشّْ وَارْ سِّينغْ مَانِي ؤُيُورنْ يرْيَازنْ \add نِّي\add*. ضْفَارمْ ثنْ ذغْيَا، خنِّي ثْزمَّارمْ أَذْ خَاسنْ ثْحَارْثمْ.“   
\m
\v 6 \add مَاشَا\add* نتَّاثْ ثسّْڭعّذْ إِ-ثنْ خْ ثْزقَّا ؤُشَا ثسّْنُوفَّارْ إِ-ثنْ سَاذُو إِغذِّيونْ ن ثِيفّسْثْ نِّي ثُوغَا تّْوَاسَّارْسنْ إِ نتَّاثْ خْ ثْزقَّا.  
\v 7 ثُوغَا ثنْ ضفَّارنْ يرْيَازنْ خْ وبْرِيذْ ن لْ-ؤُرْذُونْ أَڒْ إِمُوشَانْ ن ؤُژكّْوُو ؤُشَا أَوَارْنِي ڒَامِي فّْغنْ إِنِّي ثُوغَا ثنْ إِضفَّارنْ، بلّْعنْ خَاسنْ ثَاوَّارْثْ.  
\v 8 قْبڒْ إِ غَا طّْصنْ، ثْڭعّذْ \add رَاحَابْ\add* غَارْسنْ غَارْ ثْزقَّا،  
\v 9 ثنَّا أَسنْ: ”نشّْ سّْنغْ، أَقَا سِيذِي إِوْشَا أَومْ ثَامُّورْثْ-أَ ؤُ بلِّي ثِيڭّْوُوذِي زَّايْومْ ثوْضَا-د خَانغْ ؤُ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ فسْينْ ذڭْ وُوذمْ نْومْ.  
\v 10 مَاغَارْ نشِّينْ نسْڒَا، مَامّشْ إِسِّيژغْ سِيذِي أَمَانْ ن ڒبْحَارْ ن ثلْڭَا ذڭْ وُوذمْ نْومْ ؤُمِي د-ثفّْغمْ زِي مِيصْرَا، ؤُشَا \add نسْڒَا عَاوذْ\add* مِينْ ثڭِّيمْ أَكْ-ذ سِيحُونْ ذ عُوجْ، ثْنَاينْ ن إِجدْجِيذنْ ن إِمُورِييّنْ، إِنِّي ثُوغَا أَغِيرِينْ إِ لْ-ؤُرْذُونْ، إِنِّي ثْحَارّْممْ ؤُ ثتّحَّامْ.\x ◘ \xo 2:‏10 \xt ؤُف. 14‏:‏21؛ ڒخْڒ. 21‏:‏24، 34؛ ياش. 4‏:‏23\x*  
\v 11 \add ؤُمِي\add* نسْڒَا أَيَا، إِفْسِييْ وُوڒْ نّغْ، ؤُ وَارْ إِقِّيمْ شَا بُوحْبڒْ إِدَّارْ ذِي شَا ن يرْيَازْ ذِي سِّيبّثْ نْومْ، مِينْزِي سِيذِي، أَربِّي نْومْ، ذ أَربِّي، سنّجْ ذڭْ ؤُجنَّا ذ \add ذَا\add* سْوَادَّايْ خْ ثمُّورْثْ. \x ◘ \xo 2:‏11 \xt أَعَوذ. 4‏:‏39\x*  
\v 12 ڒخُّو \add خنِّي\add*، جَّادْجمْ أَيِي غَارْ سِيذِي، مِينْزِي نشّْ ڭِّيغْ زَّايْومْ س ثَامخْسِيوْثْ إِشوَّارنْ، أَقَا ؤُڒَا ذ كنِّيوْ أَذْ ثڭّمْ س ثْمخْسِيوْثْ إِشوَّارنْ أَكْ-ذ \add ڒَادْجْ ن\add* ثَادَّارْثْ ن بَابَا ؤُ وْشمْ أَيِي إِجّْ ن وعْڒَامْ ن ڒَامَانْ \add نْومْ\add*،  
\v 13 أَقَا كنِّيوْ أَذْ ثجّمْ بَابَا ذ يمَّا، أَيْثْمَا ذ سُويثْمَا أَكْ-ذ مَارَّا مِينْ إِدْجَانْ نْسنْ، أَذْ دَّارنْ ؤُ بلِّي كنِّيوْ أَذْ ثْفكّمْ ڒعْمُورَاثْ نّغْ زِي ڒْموْثْ.“   
\m
\v 14 أَرِّينْ-د خَاسْ يرْيَازنْ: ”مَاڒَا وَارْ ثفْضِيحمْ ثَامسْڒَاشْثْ نّغْ، أَذْ إِمّثْ ڒعْمَارْ نّغْ ذڭْ ومْشَانْ نْومْ. ؤُشَا أَذْ إِمْسَارْ خْمِي ذ أَنغْ غَا إِوْشْ سِيذِي ثَامُّورْثْ\add -أَ\add*، أَذْ أَمْ نسّْشنْ ثَامخْسِيوْثْ إِشوَّارنْ ذ ڒَامَانْ \add نّغْ\add*.“   
\m
\v 15 خَاسْ ؤُشَا ثْسيّبْ إِ-ثنْ ثمْغَارْثْ س يِيجّْ ن وسْغُونْ زِي ڒْكَازِي، مِينْزِي ثُوغَا ثَادَّارْثْ نّسْ غَارْ ڒْحِيضْ \add ن بَارَّا\add* ن وشْبَارْ \add ن ثنْذِينْثْ\add* ؤُشَا ثُوغَا ثْزدّغْ ذڭْ وشْبَارْ \add ن ثنْذِينْثْ\add*. *   
\b  
\m
\v 16 نتَّاثْ ثنَّا أَسنْ: ”فّْغمْ غَارْ إِذُورَارْ، مَاحنْذْ إِنِّي إِ كنِّيوْ إِضفَّارنْ وَارْ خَاومْ حَارّْثنْ ؤُ فَّارمْ ذِينِّي ثْڒَاثَا ن وُوسَّانْ أَڒْ غَاعقْبنْ إِنِّي \add كنِّيوْ\add* إِضفَّارنْ. أَوَارْنِي مَانْ أَيَا ثْزمَّارمْ أَذْ ثْمنْعمْ أَبْرِيذْ نْومْ.“  
\v 17 إِرْيَازنْ نَّانْ أَسْ: ”أَذْ نِيڒِي نتّْوَاسِّيزْذڭْ زِي ثْجَادْجِيثْ-أَ إِ ذ أَنغْ ثڭِّيذْ أَذْ ت نجَّادْجْ،  
\v 18 \add إِلَا مَاڒَا أَذْ ثڭّذْ أَمُّو:\add* خْزَارْ، خْمِي إِ غَا نَاذفْ غَارْ ثمُّورْثْ، إِتّْخصَّا أَذْ ثڭّذْ أَسْغُونْ-أَ أَزڭّْوَاغْ إِمُوذنْ إِ زِي ذ أَنغْ ثْسيّْبذْ غَارْ ڒْكَازِي، ؤُشَا أَذْ ثسّْمُونذْ بَابَامْ ذ يمَّامْ ذ أَيْثْمَامْ ذ مَارَّا ڒَادْجْ ن بَابَامْ غَارمْ ذِي ثَادَّارْثْ نّمْ.  
\v 19 \add مَاشَا\add* قَاعْ وِي غَا إِفّْغنْ زِي ثوُّورَا ن ثَادَّارْثْ نّمْ، أَذْ إِڒِينْ إِذَامّنْ نّسْ خْ ؤُزدْجِيفْ نّسْ، ؤُ نشِّينْ أَذْ نِيڒِي نتّْوَاسِّيزْذڭْ زَّايْسنْ، \add مَاشَا\add* قَاعْ ونِّي أَكِيذمْ غَا إِقِّيمنْ ذِي ثَادَّارْثْ، إِذَامّنْ نّسْ أَذْ إِڒِينْ خْ ؤُزدْجِيفْ نّغْ مَاڒَا \add شَا ن يِيجّْ\add* أَذْ خَاسْ إِسَّارْسْ أَفُوسْ. \x ◘ \xo 2:‏19 \xt مت. 27‏:‏25\x*  
\v 20 مَاڒَا شمْ ثسُّوفّْغذْ ثَامسْڒَاشْثْ نّغْ، \add خنِّي\add* أَذْ نِيڒِي نتّْوَاسِّيزْذڭْ \add عَاوذْ\add* زِي ثْجَادْجِيثْ إِ ذ أَنغْ ثڭِّيذْ أَذْ أَمْ نجُّودْجْ إِ شمْ.“  
\v 21 نتَّاثْ ثَارَّا-د خَاسنْ: ”عْلَاحْسَابْ أَوَاڒنْ نْومْ، أَمُّو \add إِ غَا يِيڒِي\add*!“ \add خنِّي\add* ثجَّا إِ-ثنْ أَذْ ؤُيُورنْ ؤُشَا ثْشدّْ أَسْغُونْ أَزڭّْوَاغْ غَارْ ڒْكَازِي. \x ◘ \xo 2:‏21 \xt إِشا. 1‏:‏18\x*   
\m
\v 22 ؤُيُورنْ نِيثْنِي ؤُشَا إِوْضنْ غَارْ وذْرَارْ ؤُشَا قِّيمنْ ذِينِّي ثْڒَاثَا ن وُوسَّانْ، أَڒَامِي د -عقْبنْ إِنِّي إِ ثنْ إِضفَّارنْ. إِنِّي ثنْ إِضفَّارنْ ثُوغَا أَرزُّونْ \add خَاسنْ\add* ذڭْ وبْرِيذْ مَارَّا، مَاشَا وَارْ \add ثنْ\add* ؤُفِينْ.  
\v 23 \add خنِّي\add* أَرڭّْوْحنْ-د ثْنَاينْ نِّي ن يرْيَازنْ، هْوَانْ-د زڭْ وذْرَارْ، ژْوَانْ-د ؤُشَا ؤُسِينْ-د غَارْ يَاشُووَا، مِّيسْ ن نُونْ، ؤُ حَاجَانْ أَسْ مَارَّا مِينْ ذ أَسنْ إِمْسَارنْ.  
\v 24 نَّانْ إِ يَاشُووَا: ”س ثِيذتّْ، سِيذِي إِڭَّا أَنغْ مَارَّا ثَامُّورْثْ ذڭْ إِفَاسّنْ ؤُ \add عَاوذْ\add* فسْينْ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ ذِي سِّيبّثْ نّغْ.“   
\b  
\b  
\m  
\c 3
\s1 أَژْوِي ن لْ-ؤُرْذُونْ  
\m
\v 1 غَارْ ثُوفُّوثْ زِيشْ، إِكَّارْ يَاشُووَا ؤُشَا كْسِينْ إِقِيضَانْ نْسنْ زِي شِيطِّيمْ ؤُشَا ؤُسِينْ-د غَارْ لْ-ؤُرْذُونْ، نتَّا ذ مَارَّا أَيْثْ ن إِسْرَائِيل، ؤُشَا سّنْسنْ ذِينِّي قْبڒْ إِ غَا ژْوَانْ.  
\v 2 إِمْسَارْ أَوَارْنِي ثْڒَاثَا ن وُوسَّانْ، أَقَا إِمحْضَاينْ ؤُيُورنْ خْ ڒْوسْطْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ  
\v 3 ؤُشَا ؤُمُورنْ ڒْڭنْسْ، نَّانْ: ”خْمِي غَا ثْژَارمْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي، أَربِّي نْومْ، ؤُشَا إِكهَّاننْ إِلَاوِييّنْ أَرْبُونْ ت، \add خنِّي\add* ؤُڒَا ذ كنِّيوْ أَذْ ثمُّوطّْيمْ زڭْ ومْشَامْ نْومْ، أَذْ ت ثضْفَارمْ.  
\v 4 مَاشَا إِتّْخصَّا أَذْ ثْعبَّارمْ تَّاسِيعْ عْڒَاحَاڒْ إِ أَڒْفَاينْ ن إِغَادْجنْ جَارْ أَومْ ذ نتَّا، وَارْ غَارسْ ثَاذْسمْ. أَمُّو إِ غَا ثسّْنمْ أَبْرِيذْ إِ غَا ثكّمْ، مَاغَارْ كنِّيوْ \add زِيشْ\add*عمَّارْصْ وَارْ ثكِّيمْ أَبْرِيذْ-أَ، \add وَارْ إِدْجِي\add* إِضنَّاضْ ؤُ \add وَارْ إِدْجِي\add* فَارِيضنَّاضْ.“   
\m
\v 5 إِنَّا يَاشُووَا إِ ڒْڭنْسْ: ”قدّْسمْ إِخفْ نْومْ، مِينْزِي ثِيوشَّا أَذْ إِڭّْ سِيذِي ڒعْجَايبْ ذِي ڒْوسْطْ نْومْ.“  
\v 6 إِسِّيوڒْ يَاشُووَا \add عَاوذْ\add* أَكْ-ذ إِكهَّاننْ، إِنَّا: ”سْڭعّْذمْ تَّابُوثْ ن ڒْعَاهْذْ ؤُشَا ژْوَامْ زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ!“ نِيثْنِي سّْڭعّْذنْ تَّابُوثْ ن ڒْعَاهْذْ ؤُ إِزْوَارنْ غَارْ زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ.  
\v 7 ثُوغَا سِيذِي إِنَّا إِ يَاشُووَا: ”أَسّْ-أَ أَذْ كَّارغْ أَذْ شكْ سّمْغَارغْ زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا إِسْرَائِيل، مَاحنْذْ مَارَّا أَذْ سّْننْ، أَقَا نشّْ أَكِيذكْ إِ دْجِيغْ، أَمْ مَامّشْ إِ ذ أَيِي ثُوغَا أَكْ-ذ مُوسَا. \x ◘ \xo 3:‏7 \xt ياش. 1‏:‏5\x*  
\v 8 شكْ أَذْ ثُومُورذْ إِكهَّاننْ إِنِّي يَاربُّونْ تَّابُوثْ ن ڒْعَاهْذْ، أَذْ ثِينِيذْ: ’خْ مِينِّي إِ غَا ثَاوْضمْ غَارْ ثْمَا ن وَامَانْ ن لْ-ؤُرْذُونْ، أَذْ ذِينْ ثْبدّمْ ذِي لْ-ؤُرْذُونْ!‘ “   
\m
\v 9 \add خَاسْ ؤُشَا\add* إِنَّا يَاشُووَا إِ أَيْثْ ن إِسْرَائِيل: ”أَسمْ-د ذَا ؤُ ثسْڒمْ أَوَاڒنْ ن سِيذِي، أَربِّي نْومْ.“  
\v 10 ؤُشَا إِنَّا يَاشُووَا: ”س مَانْ أَيَا أَذْ ثسّْنمْ، أَقَا إِجّْ ن أَربِّي إِدَّارْ أَقَا-ث جَارْ أَومْ ؤُ نتَّا أَذْ إِسُّوفّغْ أَيْثْ ن كنْعَانْ ذ إِحِيتِّييّنْ ذ إِحِيوِييّنْ ذ إِفَارِيزِييّنْ ذ إِجِيرْجَاشِييّنْ ذ إِمُورِييّنْ ذ إِيابُوسِييّنْ زَّاثْ إِ ثِيطَّاوِينْ نْومْ زِي ڒْوَارْثْ نْسنْ.  
\v 11 خْزَارمْ، تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي ن مَارَّا ثَامُّورْثْ ثزْوَارْ أَومْ زَّاثْ إِ وُوذمْ نْومْ ذِي لْ-ؤُرْذُونْ.  
\v 12 ڒخُّو \add خنِّي\add*، فَارْنمْ ثنْعَاشْ ن يرْيَازنْ زِي ثْقبَّاڒْ ن إِسْرَائِيل أَكِيذْومْ، إِجّْ ن ورْيَازْ زِي كُوڒْ ثَاقْبِيتْشْ.  
\v 13 خْمِي إِضَارنْ ن إِكهَّاننْ، إِنِّي يَاربُّونْ تَّابُوثْ ن سِيذِي، سِيذِي ن مَارَّا ثَامُّورْثْ، أَذْ بدّنْ ذڭْ وَامَانْ ن لْ-ؤُرْذُونْ، \add خنِّي\add* أَذْ إِمْسَارْ أَقَا أَمَانْ ن لْ-ؤُرْذُونْ أَذْ نْقضْعنْ، أَمَانْ إِ د-إِهكّْوَانْ زِي سنّجْ غَارْ سْوَادَّايْ، ؤُشَا أَذْ \add قِّيمنْ\add* بدّنْ أَمْ يِيجّْ ن وغْبَارْ.“ \x ◘ \xo 3:‏13 \xt إِزهد. 114‏:‏3\x*  
\v 14 \add ڒَْامِي\add* إِكّسْ ڒْڭنْسْ إِقِيضَانْ نّسْ حِيمَا أَذْ إِژْوَا لْ-ؤُرْذُونْ، أَرْبُونْ إِكهَّاننْ تَّابُوثْ ن ڒْعَاهْذْ زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ. \x ◘ \xo 3:‏14 \xt ڒخ. 7‏:‏45\x*  
\v 15 \add ؤُمِي\add* إِوْضنْ إِحمَّاڒنْ ن تَّابُوثْ غَارْ لْ-ؤُرْذُونْ ؤُشَا حَاذَانْ إِضَارنْ ن إِكهَّاننْ، إِنِّي يَارْبُونْ تَّابُوثْ، خْ ثْمَا ن وَامَانْ - ثُوغَا لْ-ؤُرْذُونْ إِسّْفِييْ خْ مَارَّا ثْموَّا نّسْ ذِي مَارَّا ؤُسَّانْ ن ثْميْرَا - \x ◘ \xo 3:‏15 \xt 1 إِم. 12‏:‏16\x*  
\v 16 بدّنْ وَامَانْ نِّي د-إِهكّْوَانْ زِي سنّجْ. \add أَمَانْ\add* بدّنْ نِيشَانْ أَمْ يِيجّْ ن وغْبَارْ إِڭّْوجْ أَطَّاسْ، غَارْ ثنْذِينْثْ ن أَذَامْ ثنِّي زَّاثْ إِ صَارْثَانْ. \add أَمُّو\add* إِ بدّنْ \add وَامَانْ\add* إِنِّي د-إِهكّْوَانْ غَارْ سْوَادَّايْ، غَارْ ڒبْحَارْ ن ڒوْضَا، غَارْ ڒبْحَارْ أَمدْجَاحْ، أَقَا تّْوَاقضْعنْ قَاعْ. \add خنِّي\add* إِژْوَا ڒْڭنْسْ ذڭْ ؤُرنْذَاذْ ن أَرِيحَا.  
\v 17 إِكهَّاننْ، إِنِّي يَارْبُونْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي، بدّنْ ذِي ڒَامَانْ خْ ڒَاژَاغْ، ذِي ڒْوسْطْ ن لْ-ؤُرْذُونْ \add ؤُمِي\add* إِژْوَا مَارَّا إِسْرَائِيل خْ ڒَاژَاغْ أَڒَامِي إِكمّڒْ مَارَّا ڒْڭنْسْ أَژْوِي خْ لْ-ؤُرْذُونْ.   
\b  
\b  
\m  
\c 4
\m
\v 1 ؤُمِي ثُوغَا إِكمّڒْ مَارَّا ڒْڭنْسْ أَژْوِي خْ لْ-ؤُرْذُونْ، إِمْسَارْ أَقَا سِيذِي إِسِّيوڒْ أَكْ-ذ يَاشُووَا، إِنَّا: \x ◘ \xo 4:‏1 \xt ياش. 3‏:‏12\x*  
\v 2 ”فَارْنمْ ثنْعَاشْ ن يرْيَازنْ زِي ڒْڭنْسْ، إِجّنْ ورْيَازْ زِي كُوڒْ ثَاقْبِيتْشْ،  
\v 3 ؤُ ثُومُورذْ خَاسنْ، إِنِي: ’كْسِيمْ سَّا، زِي ڒْوسْثْ ن لْ-ؤُرْذُونْ، زڭْ ومْشَانْ مَانِي ثُوغَا بدّنْ إِضَارنْ ن إِكهَّاننْ ذِي ڒَامَانْ، ثنْعَاشْ ن إِژْرَا، كْسِيمْ ثنْ أَكِيذْومْ غَارْ ؤُجمَّاضِينْ، سَّارْسمْ ثنْ ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ مَانِي غَا ثسّنْسمْ دْجِيڒثْ-أَ.‘ “   
\m
\v 4 \add خنِّي\add* إِڒَاغَا يَاشُووَا ثنْعَاشْ ن يرْيَازنْ نِّي إِفَارْنْ إِ-ثنْ زڭْ أَيْثْ ن إِسْرَائِيل، إِجّْ ن ورْيَازْ زِي كُوڒْ ثَاقْبِيتْشْ،  
\v 5 ؤُشَا يَاشُووَا إِنَّا أَسنْ: ”ؤُيُورمْ زَّاثْ إِ وُوذمْ ن تَّابُوثْ ن سِيذِي، أَربِّي نْومْ، غَارْ ڒْوسْطْ ن لْ-ؤُرْذُونْ ؤُشَا أَذْ إِكْسِي كُوڒْ أَرْيَازْ إِ يِيخفْ نّسْ إِجّْ ن وژْرُو خْ ثغْرُوضْثْ نّسْ، عْلَاحْسَابْ ڒْقدّْ ن ثْقبَّاڒْ ن أَيْثْ ن إِسْرَائِيل،  
\v 6 حِيمَا أَذْ يِيڒِي أَيَا ذ إِشْثْ ن ڒعْڒَامثْ جَارْ أَومْ. مِينْزِي \add مَاڒَا\add* إِحنْجِيرنْ نْومْ أَذْ سّقْسَانْ، أَذْ إِنِينْ: ’مِينْ \add إِخْسْ أَذْ إِنِينْ\add* يژْرَا-يَا إِ كنِّيوْ؟‘،  
\v 7 \add خنِّي\add* كنِّيوْ أَذْ أَسنْ ثِينِيمْ: ’\add أَقَا-ثنْ ذِينْ\add* مِينْزِي نْقضْعنْ وَامَانْ ن لْ-ؤُرْذُونْ زَّاثْ إِ وُوذمْ ن تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي! غَارْ ؤُژْوِي خْ لْ-ؤُرْذُونْ نْقضْعنْ وَامَانْ ن لْ-ؤُرْذُونْ ؤُشَا إِژْرَا-يَا ذ إِشْثْ ن ڒِيذَارثْ إِ أَيْثْ ن إِسْرَائِيل \add ذِي مَانْ أَيَا\add* إِ ڒبْذَا.‘ “ \x ◘ \xo 4:‏7 \xt ياش. 3‏:‏13\x*  
\v 8 أَيْثْ ن إِسْرَائِيل ڭِّينْ أَمْ مَامّشْ ثُوغَا يُومُورْ يَاشُووَا ؤُشَا كْسِينْ ثنْعَاشْ ن إِژْرَا زِي ڒْوسْطْ ن لْ-ؤُرْذُونْ، أَمْ مَامّشْ ثُوغَا إِسِّيوڒْ سِيذِي غَارْ يَاشُووَا، عْلَاحْسَابْ ڒْقدّْ ن ثْقبَّاڒْ ن أَيْثْ ن إِسْرَائِيل، ؤُشَا كْسِينْ ثنْ أَكِيذْسنْ غَارْ ؤُجمَّاضِينْ، غَارْ ڒْمَارْڭحْ مَانِي ثُوغَا سّنْسنْ، ؤُشَا سَّارْسنْ ثنْ ذِينْ.  
\v 9 إِسَّارْسْ يَاشُووَا \add عَاوذْ\add* ثنْعَاشْ ن إِژْرَا ذِي ڒْوسْطْ ن لْ-ؤُرْذُونْ، ذڭْ ومْشَانْ مَانِي ثُوغَا مَّارْسنْ إِضَارنْ ن إِكهَّاننْ، إِنِّي يَارْبُونْ تَّابُوثْ ن ڒْعَاهْذْ، ؤُ أَقَا أَثنْ عَاذْ ذِينْ أَڒْ أَسّْ-أَ.   
\m
\v 10 إِكهَّاننْ، إِنِّي يَارْبُونْ تَّابُوثْ، قِّيمنْ بدّنْ ذِي ڒْوسْطْ ن لْ-ؤُرْذُونْ، أَڒَامِي ثُوغَا إِتّْوَاكمّڒْ مِينْ إِنَّا سِيذِي إِ يَاشُووَا مَاحنْذْ أَذْ ث يِينِي إِ ڒْڭنْسْ عْلَاحْسَابْ مَارَّا مِينْ يُومُورْ مُوسَا إِ يَاشُووَا، ؤُشَا إِقدْجقْ ڒْڭنْسْ سّنِّي، إِژْوَا.  
\v 11 ؤُمِي ثُوغَا مَارَّا ڒْڭنْسْ إِكمّڒْ أَژْوِي، ثژْوَا تَّابُوثْ ن سِيذِي أَكْ-ذ إِكهَّاننْ زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ.  
\v 12 أَيْثْ ن رُوبِينْ ذ أَيْثْ ن جَاذْ ذ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا ژْوَانْ حزّْمنْ إِ ؤُمنْغِي زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل، أَمْ مَامّشْ ثُوغَا أَكِيذْسنْ إِسِّيوڒْ مُوسَا. \x ◘ \xo 4:‏12 \xt ڒخْڒ. 32‏:‏20، 29\x*  
\v 13 ثُوغَا-ثنْ عْڒَاحَاڒْ ذِي أَربْعِينْ-أَڒفْ \add ن يرْيَازنْ\add*، حزّْمنْ \add مَارَّا\add* إِ ؤُمنْغِي. نِيثْنِي ژْوَانْ غَارْ \add وَازَّايْ ن\add* ؤُمنْغِي زَّاثْ إِ وُوذمْ ن سِيذِي، غَارْ ڒوْضَاثْ ن أَرِيحَا.  
\v 14 سِيذِي إِسّمْغَارْ يَاشُووَا ذڭْ وَاسّْ نِّي ذِي ثِيطَّاوِينْ ن مَارَّا إِسْرَائِيل ؤُشَا ڭّْوذنْ زَّايسْ أَمْ مَامّشْ ثُوغَا ڭّْوذنْ زِي مُوسَا، مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّسْ. \x ◘ \xo 4:‏14 \xt ياش. 3‏:‏7\x*   
\m
\v 15 سِيذِي إِسِّيوڒْ أَكْ-ذ يَاشُووَا، إِنَّا:  
\v 16 ”ؤُمُورْ إِ إِكهَّاننْ، إِنِّي يَاربُّونْ تَّابُوثْ ن شّْهَاذثْ، أَذْ ڭعّْذنْ زِي لْ-ؤُرْذُونْ.“  
\v 17 \add خنِّي\add* يُومُورْ يَاشُووَا إِكهَّاننْ، إِنَّا: ”ڭَاعّْذمْ زِي لْ-ؤُرْذُونْ غَارْ سنّجْ!“  
\v 18 ؤُمِي ڭعّْذنْ إِكهَّاننْ، إِنِّي يَارْبُونْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي، زِي ڒْوسْطْ ن لْ-ؤُرْذُونْ ؤُ ثُوغَا ثِيسِي ن إِضَارنْ ن إِكهَّاننْ عَاذْ أَمْ مَامّشْ د-فّْغنْ \add زڭْ وَامَانْ\add*، إِمْسَارْ أَقَا أَمَانْ ن لْ-ؤُرْذُونْ ذوْڒنْ غَارْ ومْشَانْ نْسنْ ؤُشَا ذوْڒنْ سّْفَاينْ خْ مَارَّا ثِيمَّاوِينْ نّسْ أَمْ يِيضنَّاضْ ذ فَارِيضنَّاضْ.  
\v 19 ثُوغَا ڒْڭنْسْ إِڭعّذْ زِي لْ-ؤُرْذُونْ ذڭْ وَاسّْ وِيسّْعشْرَا ذڭْ ؤُيُورْ أَمزْوَارُو ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي جِيلْجَالْ، غَارْ شَّارْقْ ن أَرِيحَا.   
\m
\v 20 ذِي جِيلْجَالْ إِسّْبدّْ يَاشُووَا ثنْعَاشْ ن إِژْرَا إِ ثُوغَا أَكِيذْسنْ-د إِكْسِينْ زِي لْ-ؤُرْذُونْ.  
\v 21 ؤُشَا نتَّا إِسِّيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، إِنَّا: ”مَاڒَا سّقْسَانْ ثِيوشَّا إِحنْجِيرنْ نْومْ إِبَابَاثنْ نْسنْ ؤُشَا أَذْ إِنِينْ: ’مِينْ \add خْسنْ أَذْ إِنِينْ\add* يژْرَا-يَا؟‘  
\v 22 \add خنِّي\add* أَذْ ثْعڒْممْ إِ إِحنْجِيرنْ نْومْ، أَذْ ثِينِيمْ: ’\add ذَانِيثَا\add* إِژْوَا إِسْرَائِيل لْ-ؤُرْذُونْ-أَ خْ ڒَاژَاغْ،  
\v 23 مِينْزِي سِيذِي، أَربِّي نْومْ، إِسِّيژغْ أَمَانْ ن لْ-ؤُرْذُونْ زَّاثْ إِ وُوذمْ نْومْ أَڒَامِي ثژْوَامْ، أَمْ مَامّشْ إِ ثُوغَا إِڭَّا سِيذِي، أَربِّي نْومْ، \add عَاوذْ\add* أَكْ-ذ ڒبْحَارْ ن ثلْڭَا نِّي إِسِّيژغْ زَّاثْ إِ وُوذمْ نّغْ أَڒَامِي \add ذِينْ\add* نژْوَا، \x ◘ \xo 4:‏23 \xt ؤُف. 14‏:‏21\x*  
\v 24 حِيمَا مَارَّا ڒڭْنُوسْ خْ ثمُّورْثْ أَذْ سّْننْ، أَقَا أَفُوسْ ن سِيذِي إِجْهذْ، حِيمَا كنِّيوْ أَذْ ثڭّْوْذمْ سِيذِي، أَربِّي نْومْ، إِ ڒبْذَا.‘ “   
\b  
\b  
\m  
\c 5
\s1 أَخْثَانْ ن ڒْڭنْسْ ذِي جِيلْجَالْ  
\m
\v 1 ؤُمِي مَارَّا إِجدْجِيذنْ ن إِمُورِييّنْ \add إِ إِدْجَانْ\add* خْ ثْمَا ن ڒْغَارْبْ ن لْ-ؤُرْذُونْ ذ مَارَّا إِجدْجِيذنْ ن أَيْثْ ن كنْعَانْ \add إِ إِدْجَانْ\add* غَارْ ڒبْحَارْ، سْڒَانْ، أَقَا سِيذِي إِسِّيژغْ أَمَانْ ن لْ-ؤُرْذُونْ زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل، أَڒَامِي نژْوَا غَارْ ؤُجمَّاضِينْ، \add خنِّي\add* إِفْسِييْ وُوڒْ نْسنْ ؤُ وَارْ ذَايْسنْ إِقِّيمْ شَا أَرُّوحْ زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل.  
\v 2 ذِي ڒْوقْثْ نِّي إِسِّيوڒْ سِيذِي أَكْ-ذ يَاشُووَا: ”أڭّْ إِ يِيخفْ نّشْ إِفَارِّيشنْ ن وژْرُو ؤُشَا خْثنْ إِ أَيْثْ ن إِسْرَائِيل إِ ثْوَاڒَا وِيسّْ ثْنَاينْ!“ \x ◘ \xo 5:‏2 \xt ؤُف. 4‏:‏25\x*  
\v 3 \add خنِّي\add* إِڭَّا يَاشُووَا إِفَارِّيشنْ ن وژْرُو إِ يِيخفْ نّسْ ؤُشَا إِخْثنْ إِ أَيْثْ ن إِسْرَائِيل غَارْ جِيبْعَا-هَاعْرَالُوثْ، \add أَقَا ذ ’ثَاوْرِيرْثْ ن ڒعْذَاڒيَّاثْ ن وخْثَانْ‘\add*.  
\v 4 مَانْ أَيَا ذ ڒسْبَابْ إِ زِي إِخْثنْ إِ-ثنْ يَاشُووَا: مَارَّا ڒْڭنْسْ إِ ثُوغَا د-إِفّْغنْ زِي مِيصْرَا، \add مَارَّا\add* إِوثْمَانْ، \add إِخْسْ أَذْ يِينِي\add* مَارَّا إِعسْكَارِييّنْ مُّوثنْ ذڭْ وبْرِيذْ ذِي ڒخْڒَا أَوَارْنِي إِ وُوفُّوغْ نْسنْ زِي مِيصْرَا.  
\v 5 مِينْزِي مَارَّا ڒْڭنْسْ نِّي د-إِفّْغنْ، ثُوغَا-ث إِتّْوَاخْثنْ، \add مَاشَا\add* مَارَّا ڒْڭنْسْ نِّي د-إِتّْوَاخڒْقنْ ذڭْ وبْرِيذْ ذِي ڒخْڒَا أَوَارْنِي إِ ؤُفُّوغْ نْسنْ زِي مِيصْرَا، نِيثْنِي وَارْ تّْوَاخثْننْ شَا. \x ◘ \xo 5:‏5 \xt ؤُف. 12‏:‏48\x*  
\v 6 مِينْزِي أَربْعِينْ ن إِسڭّْوُوسَا ڭُّورنْ أَيْثْ ن إِسْرَائِيل ذِي ڒخْڒَا أَڒَامِي إِتّْوَاهلّكْ ڒْڭنْسْ مَارَّا، مَارَّا إِعسْكَارِييّنْ إِ ثُوغَا د-إِفّْغنْ زِي مِيصْرَا، إِنِّي ثُوغَا وَارْ إِسْڒِينْ غَارْ ثْمِيجَّا ن سِيذِي \add ذ إِنِّي\add* ثُوغَا إِجُّودْجْ أَسنْ سِيذِي، وَارْ ثنْ إِتّجِّي شَا أَذْ ژَترنْ ثَامُّورْثْ نِّي خْ ثُوغَا إِجُّودْجْ سِيذِي إِ ڒجْذُوذْ نْسنْ أَذْ أَسنْ ت إِوْشْ، إِشْثْ ن ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ. \x ◘ \xo 5:‏6 \xt ڒخْڒ. 14‏:‏23\x*  
\v 7 إِحنْجِيرنْ نْسنْ إِنِّي إِسّْنكَّارْ نتَّا ذڭْ ومْشَانْ نْسنْ، ذ إِنَا ذ إِنِّي ثُوغَا إِخْثنْ يَاشُووَا، مِينْزِي نِيثْنِي غَارْسنْ عَاذْ ڒعْذَاڒْيثْ مِينْزِي وَارْ ذ أَسنْ خثْننْ ذڭْ وبْرِيذْ.  
\v 8 ؤُمِي كمّْڒنْ أَذْ خْثنْ مَارَّا ڒْڭنْسْ، إِمْسَارْ بلِّي قِّيمنْ ذڭْ ومْشَانْ نْسنْ ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ أَڒَامِي ڭّنْفَانْ.  
\v 9 إِنَّا سِيذِي إِ يَاشُووَا: ”أَسّْ-أَ أَقَا كّْسغْ خَاومْ ڒفْضِيحثْ ن مِيصْرَا.“ \add خْ ؤُينِّي\add* قَّارنْ أَسْ إِ ومْشَانْ نِّي جِيلْجَالْ، أَڒْ أَسّْ-أَ.   
\b  
\m  
\s1 ثَاغَارْصْثْ ن ؤُسعْذُو - ’مَانَّ’، أَغْرُومْ ن ؤُجنَّا، إِبدّْ  
\m
\v 10 وْثِينْ أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ ذِي جِيلْجَالْ ؤُشَا سّْوجْذنْ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو ذڭْ وَاسّْ أَرْبعْطَاشْ ن ؤُيُورْ \add نِّي\add*، ذِي دْجِيڒثْ، ذِي ڒوْضَاثْ ن أَرِيحَا. \x ◘ \xo 5:‏10 \xt ؤُف. 12‏:‏6\x*  
\v 11 نِيثْنِي شِّينْ أَغْرُومْ بْڒَا أَنْثُونْ ذ ثغْوَاوِينْ إِشنّْفنْ زِي ڒْغِيدْجثْ ن ثمُّورْثْ، زِي ثِيوشَّا أَوَارْنِي إِ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو، ذڭْ وَاسّْ نِّي سِيمَانْثْ نّسْ. \x ◘ \xo 5:‏11 \xt ؤُف. 12‏:‏39؛ لَاوِي 2‏:‏14\x*  
\v 12 ثِيوشَّا نّسْ، أَوَارْنِي ڒَامِي شِّينْ زِي ڒْغِيدْجثْ ن ثمُّورْثْ، إِنّقْضعْ مَانَّا. سّنِّي وَارْ إِقِّيمْ عَاذْ ’مَانَّا‘ إِ أَيْثْ ن إِسْرَائِيل. ذڭْ ؤُسڭّْوَاسْ نِّي شِّينْ زِي ڒْغِيدْجثْ ن ثمُّورْثْ ن كنْعَانْ.   
\b  
\m  
\s1 يَاشُووَا إِژْرَا أَمقّْرَانْ ن ڒْعسْكَارْ ن سِيذِي  
\m
\v 13 ؤُمِي ثُوغَا إِدْجَا يَاشُووَا زَّاثْ إِ أَرِيحَا، إِسّْڭعّذْ ثِيطَّاوِينْ نّسْ، ؤُشَا خْزَارْ، ثُوغَا إِجّْ ن ورْيَازْ إِبدّْ زَّاثسْ، غَارسْ سِّيفْ نّسْ ذڭْ ؤُفُوسْ نّسْ. يَاشُووَا إِرُوحْ غَارسْ إِنَّا أَسْ: ”شكْ مَا زَّايْنغْ نِيغْ زڭْ إِغْرِيمنْ نّغْ؟“ \x ◘ \xo 5:‏13 \xt ؤُف. 23‏:‏23\x*  
\v 14 نتَّا يَارَّا-د: ”لَّ، مِينْزِي نشّْ ذ أَكُومَانْذَارْ ن ڒْعسْكَارْ ن سِيذِي. نشّْ ڒخُّو إِ د-ؤُسِيغْ!“ ؤُشَا إِوْضَا يَاشُووَا خْ ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ، يُوضَارْ، ؤُشَا إِنَّا أَسْ: ”مِينْ إِخْسْ أَذْ يِينِي سِيذِي إِنُو إِ ؤُمْسخَّارْ نّسْ؟“  
\v 15 \add خنِّي\add* إِنَّا أَكُومَانْذَارْ ن ڒْعسْكَارْ ن سِيذِي إِ يَاشُووَا: ”كّسْ ثِيسِيڒَا نّشْ زڭْ إِضَارنْ نّشْ، مِينْزِي أَمْشَانْ إِ خفْ ثْبدّذْ ذ أَمْقدَّاسْ \add إِ إِدْجَا\add*.“ ؤُشَا أَمنِّي إِ إِڭَّا يَاشُووَا. \x ◘ \xo 5:‏15 \xt ؤُف. 3‏:‏5\x*   
\b  
\b  
\m  
\c 6
\s1 أَوطُّو ن أَرِيحَا  
\m
\v 1 أَرِيحَا ثُوغَا ثقّنْ \add ثِيوُّورَا نّسْ\add* نِيشَانْ زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل. ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ إِفّغْ، ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ \add ذِينْ\add* يَاذفْ.  
\v 2 \add خنِّي\add* إِنَّا سِيذِي إِ يَاشُووَا: ”خْزَارْ، نشّْ ڭِّيغْ أَشْ أَرِيحَا أَكْ-ذ ؤُجدْجِيذْ نّسْ، أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، ذڭْ ؤُفُوسْ نّشْ.  
\v 3 إِتّْخصَّا كنِّيوْ أَذْ ثنّْضمْ إِ ثنْذِينْثْ. مَارَّا إِعسْكَارِييّنْ أَذْ نّْضنْ إِ ثنْذِينْثْ إِشْثْ ن ثْوَاڒَا. أَمْيَا إِ غَا ثڭّمْ ستَّا ن وُوسَّانْ.  
\v 4 سبْعَا ن إِكهَّاننْ أَذْ إِزْوَارنْ زَّاثْ إِ تَّابُوثْ أَذْ أَرْبُونْ سبْعَا ن وَاشَّاونْ ن إِشَارِّي إِ ؤُسْڒِيوْڒوْ. ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ ثنّْضمْ إِ ثنْذِينْثْ سبْعَا ن ثْوَاڒَاوِينْ ؤُ \add خنِّي\add* أَذْ سُوضنْ إِكهَّاننْ ذڭْ وَاشَّاونْ ن إِشَارِّي.  
\v 5 خْمِي غَا يِيڒِي إِجّْ ن ؤُسُوضِي ذ أَزِيرَارْ ذڭْ يِيشّْ ن ؤُسْڒِيوْڒوْ ؤُ كنِّيوْ أَذْ ثسْڒمْ ڒْحسّْ-أَ ن ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي، \add خنِّي\add* أَذْ يَارّژْ ڒْڭنْسْ إِمُونْ س ثْغُويِّيثْ ذڭْ ؤُجنَّا. خَاسْ ؤُشَا أَذْ إِوْضَا ڒْحِيضْ ن ثنْذِينْثْ ؤُشَا أَذْ خَاسْ إِژْوَا ڒْڭنْسْ، كُوڒْ إِجّْ ن ورْيَازْ أَذْ يُويُورْ نِيشَانْ غَارْ زَّاثْ.“   
\m
\v 6 \add خنِّي\add* إِڒَاغَا يَاشُووَا، مِّيسْ ن نُونْ، خْ إِكهَّاننْ، إِنَّا أَسنْ: ”كْسِيمْ كنِّيوْ تَّابُوثْ ن ڒْعَاهْذْ ؤُ تّجّمْ سبْعَا ن إِكهَّاننْ أَذْ إِزْوَارنْ غَارْ زَّاثْ إِ وُوذمْ ن تَّابُوثْ ن سِيذِي أَذْ أَرْبُونْ سبْعَا ن وَاشَّاونْ ن إِشَارِّي إِ ؤُسْڒِيوْڒوْ.“  
\v 7 نَّانْ إِ ڒْڭنْسْ: ”ژْوَامْ ؤُ ثنّْضمْ إِ ثنْذِينْثْ. جّمْ إِعسْكَارِييّنْ س ڒسْنَاحْ أَذْ ژْوَانْ زَّاثْ إِ وُوذمْ ن تَّابُوثْ ن سِيذِي.“   
\m
\v 8 إِمْسَارْ أَمْ مَامّشْ ثُوغَا إِنَّا يَاشُووَا إِ ڒْڭنْسْ. سبْعَا ن إِكهَّاننْ ثُوغَا أَربُّونْ سبْعَا ن وَاشَّاونْ ن إِشَارِّي إِ ؤُسْڒِيوْڒوْ ؤُشَا ژْوَانْ زَّاثْ إِ وُوذمْ ن سِيذِي، سُوضنْ ذڭْ وَاشَّاونْ ن إِشَارِّي ؤُشَا تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي ثڭُّورْ أَوَارْنِي أَسنْ.  
\v 9 \add إِرْيَازنْ\add* إِحزّْمنْ س ڒسْنَاحْ إِزْوَارنْ زَّاثْ إِ وُوذمْ ن إِكهَّاننْ نِّي إِسُوضنْ ذڭْ وَاشَّاونْ ن إِشَارِّي ؤُ خْ ضفَّارْ ن تَّابُوثْ يُوسَا-د ؤُغزْذِيسْ أَنڭَّارُو \add ن ڒْعسْكَارْ\add*، أَمْ ڭُّورنْ، تّْسُوضنْ نِيثْنِي ذڭْ وَاشَّاونْ ن إِشَارِّي.   
\m
\v 10 يَاشُووَا أَقَا يُومُورْ ڒْڭنْسْ، إِنَّا ”وَارْ تّسْغُويُّومْ، وَارْ تّجِّيمْ ثْمِيجَّا نْومْ أَذْ أَسْ إِسڒْ حذْ، وَارْ د-إِتّفّغْ ؤُڒَا ذ إِجّْ ن وَاوَاڒْ زڭْ ؤُقمُّومْ نْومْ أَڒْ أَسّْ نِّي ذ أَومْ غَا إِنِيغْ: ’سْغُويّمْ!‘ \add خنِّي\add* أَذْ ثسْغُويّمْ إِ ؤُمنْغِي.“  
\v 11 خَاسْ ؤُشَا يجَّا تَّابُوثْ ن سِيذِي أَذْ ثنّضْ إِ ثنْذِينْثْ، إِشْثْ ن ثْوَاڒَا ثنّضْ أَسْ-د. \add خنِّي\add* ذوْڒنْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ، سّنْسنْ ذِي ڒْمَارْڭحْ.  
\v 12 ثِيوشَّا نّسْ غَارْ ثُوفُّوثْ ن زِيشْ إِكَّارْ يَاشُووَا ؤُشَا أَرْبُونْ إِكهَّاننْ تَّابُوثْ ن سِيذِي.  
\v 13 سبْعَا ن إِكهَّاننْ نِّي ثُوغَا يَاربُّونْ سبْعَا ن وَاشَّاونْ ن إِشَارِّي إِ ؤُسْڒِيوْڒوْ زَّاثْ إِ وُوذمْ ن تَّابُوثْ ن سِيذِي، قِّيمنْ ڭُّورنْ، سُوضنْ ذڭْ وَاشَّاونْ ن إِشَارِّي ؤُ \add إِرْيَازنْ\add* إِحزّْمنْ س ڒسْنَاحْ إِزْوَارنْ غَارْ زَّاثْ ؤُ خْ ضفَّارْ ن تَّابُوثْ ن سِيذِي إِضْفَارْ ؤُغزْذِيسْ أَنڭَّارُو \add ن ڒْعسْكَارْ\add*، أَمْ \add قِّيمنْ\add* ڭُّورنْ أَمْ تّْسُوضنْ ذڭْ وَاشَّاونْ ن إِشَارِّي.  
\v 14 ذڭْ وَاسّْ وِيسّْ ثْنَاينْ نّْضنْ \add عَاوذْ\add* إِشْثْ ن ثْوَاڒَا إِ ثنْذِينْثْ ؤُشَا ذوْڒنْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ. أَمُّو إِ ڭِّينْ ستَّا ن وُوسَّانْ.  
\v 15 ذڭْ وَاسّْ وِيسّْ سبْعَا، إِمْسَارْ، أَقَا كَّارنْ زِيشْ، ؤُمِي إِصْبحْ ڒْحَاڒْ، ؤُشَا نّْضنْ أَمُّو سبْعَا ن ثْوَاڒَاوِينْ إِ ثنْذِينْثْ. ذڭْ وَاسّْ نِّي وَاهَا نّْضنْ إِ ثنْذِينْثْ سبْعَا ن ثْوَاڒَاوِينْ.  
\v 16 ؤُشَا إِمْسَارْ غَارْ ثْوَاڒَا وِيسّْ سبْعَا ؤُمِي سُوضنْ إِكهَّاننْ ذڭْ وَاشَّاونْ ن إِشَارِّي، أَقَا يَاشُووَا إِنَّا إِ ڒْڭنْسْ: ”سْغُويّمْ، مِينْزِي سِيذِي إِڭَّا أَومْ ثَانْذِينْثْ ذڭْ ؤُفُوسْ!  
\v 17 ثَانْذِينْثْ أَذْ ثتّْوَاحَارّمْ إِ سِيذِي، ثَانْذِينْثْ ذ مَارَّا مِينْ ذَايسْ. مْغِيرْ ثَامْغَارْثْ ن فَارْقْ-شّْغڒْ رَاحَابْ وَاهَا ذ مَارَّا إِنِّي غَارسْ إِدْجَانْ ذِي ثَادَّارْثْ نّسْ أَذْ قِّيمنْ دَّارنْ، مِينْزِي نتَّاثْ ثسّْنُوفَّارْ خْ إِرقَّاسنْ نِّي ثُوغَا نسّكّْ.  
\v 18 حْضَامْ إِخفْ نْومْ زِي مَارَّا مِينْ إِتّْوَاحَارّْمنْ، مَاحنْذْ كنِّيوْ وَارْ ثذِّيكّْوِيڒمْ ذ أَيْثْ ن ڒحْرَامْ \add أَمْ\add* ثكْسِيمْ \add شَا\add* ن مِينْ إِدْجَانْ ذ ڒحْرَامْ ؤُ أَذْ ثَارّمْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِسْرَائِيل ذ ڒحْرَامْ ؤُ أَذْ ث ثْغضْڒمْ ذ أَرّْژِييثْ.  
\v 19 مَارَّا نُّوقَارْثْ ذ وُورغْ ذ ڒقْشُوعْ ن نّْحَاسْ ذ وُوزَّاڒْ، \add مَارَّا أَيَا\add* ذ أَمْقدَّاسْ إِ سِيذِي ؤُشَا أَذْ ث ثسِّيذْفمْ ذڭْ وخَّامْ ن ثْخُوبَايْ ن سِيذِي.“ \x ◘ \xo 6:‏19 \xt ڒخْڒ. 31‏:‏54\x*  
\v 20 خَاسْ ؤُشَا إِسْغُويْ ڒْڭنْسْ إِ ؤُمنْغِي ؤُشَا سُوضنْ ذڭْ وَاشَّاونْ ن إِشَارِّي. ؤُشَا إِمْسَارْ، ؤُمِي إِسْڒَا ڒْڭنْسْ ڒْحسّْ ن ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي، أَقَا ڒْڭنْسْ يَارّژْ ذڭْ إِشْثْ ن ثْغُويِّيثْ ذڭْ ؤُجنَّا ؤُ ڒْحِيضْ ن ثنْذِينْثْ إِهْذمْ ؤُ ڒْڭنْسْ إِڭعّذْ، يُوذفْ غَارْ ثنْذِينْثْ، كُوڒْ إِجّْ ن ورْيَازْ يُويُورْ نِيشَانْ غَارْ زَّاثْ، ؤُشَا طّْفنْ نِيثْنِي ثَانْذِينْثْ. \x ◘ \xo 6:‏20 \xt عبر. 11‏:‏30\x*  
\v 21 حَارّْمنْ مَارَّا مِينْ إِدْجَانْ ذِي ثنْذِينْثْ إِ ڒْحُوكْمْ س ڒقْضعْ ن سِّيفْ، زڭْ إِرْيَازنْ أَڒْ ثِيمْغَارِينْ، زڭْ إِحْرَامنْ أَڒْ إِوسُّورَا، أَڒْ أَفُونَاسْ، ؤُدْجِي ذ وغْيُوڒْ.  
\v 22 إِنَّا يَاشُووَا إِ ثْنَاينْ ن يرْيَازنْ نِّي ثُوغَا إِتّْبرْڭَاڭنْ ثَامُّورْثْ: ”أَذْفمْ غَارْ ثَادَّارْثْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ، ؤُ سُّوفّْغمْ ثَامْغَارْثْ نِّي أَكْ-ذ مَارَّا مِينْ غَارسْ، أَمْ مَامّشْ كنِّيوْ إِ ذ أَسْ ثجُّودْجمْ.“ \x ◘ \xo 6:‏22 \xt ياش. 2‏:‏14؛ عبر. 11‏:‏31\x*  
\v 23 \add خنِّي\add* ؤُذْفنْ إِبْڒِيغنْ، إِبرْڭَاڭنْ، ؤُشَا سُّوفّْغنْ-د رَاحَابْ أَكْ-ذ بَابَاسْ ذ يمَّاسْ ذ أَيْثْمَاسْ ذ مَارَّا مِينْ إِدْجَانْ نّسْ. سُّوفّْغنْ مَارَّا ڒَادْجْ نّسْ ؤُشَا ڭِّينْ أَسنْ مَانِي غَا قِّيمنْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِسْرَائِيل.  
\v 24 سّْشمْضنْ ثَانْذِينْثْ ذ مَارَّا مِينْ ذَايسْ س ثْمسِّي. مْغِيرْ نُّوقَارْثْ ذ وُورغْ ذ ڒقْشُوعْ ن نّْحَاسْ ذ وُوزَّاڒْ، سِّيذْفنْ ثنْ غَارْ وخَّامْ ن ثْخُوبَايْ ذِي ثَادَّارْثْ ن سِيذِي.  
\v 25 رَاحَابْ، ثَامْغَارْثْ ن فَارْقْ-شّْغڒْ ذ \add ڒَْادْجْ ن\add* ثَادَّارْثْ ن بَابَاسْ ذ مَارَّا مِينْ إِدْجَانْ نّسْ، إِجَّا إِ-ثنْ يَاشُووَا أَذْ دَّارنْ. ؤُ نتَّاثْ ثْزدّغْ ذِي ڒْوسْطْ ن إِسْرَائِيل أَڒْ أَسّْ-أَ، مِينْزِي ثُوغَا ثسّْنُوفَّارْ خْ إِرقَّاسنْ إِ ثُوغَا إِسّكّْ يَاشُووَا، حِيمَا أَذْ برْڭَاڭنْ ثَامُّورْثْ.  
\v 26 ذِي ڒْوقْثْ نِّي إِجُّودْجْ يَاشُووَا، إِنَّا: ”أَرْيَازْ نِّي إِ غَا إِسّْبدّْ أَرِيحَا عَاوذْ أَذْ يِيڒِي إِتّْوَانْعڒْ زَّاثْ إِ وُوذمْ ن سِيذِي. أَذْ أَسْ يڭّْ ذْسَاسْ نّسْ ذِي ثَارژِّيثْ ن ؤُمنْزُو نّسْ، أَذْ إِسّْبدّْ ثِيوُّورَا نّسْ ذِي ثَارژِّيثْ ن مِّيسْ أَمَاژُوژْ.“ \x ◘ \xo 6:‏26 \xt 1 إِج. 16‏:‏34\x*  
\v 27 \add أَمُّو\add* إِ ثُوغَا سِيذِي أَكْ-ذ يَاشُووَا، ؤُشَا ڒخْبَارْ إِكَّا مَارَّا ثَامُّورْثْ.   
\b  
\b  
\m  
\c 7
\s1 دّنْبْ ن عَاخَانْ  
\m
\v 1 أَيْثْ ن إِسْرَائِيلغشّنْ أَكْ-ذ مِينْ إِدْجَانْ إِتّْوَاحَارّْمنْ \add إِ ؤُثحِّي\add*. عَاخَانْ، مِّيسْ ن كَارْمِي، مِّيسْ ن زَابْذِي، مِّيسْ ن زَارَاحْ، زِي ثقْبِيتْشْ ن يَاهُوذَا، إِكْسِي شَا زِي مِينْ إِتّْوَاحَارّْمنْ \add إِ ؤُثحِّي\add*. \add خنِّي\add* يَارْغَا وغْضَابْ ن سِيذِي خْ أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 7:‏1 \xt ياش. 22‏:‏20؛ 1 إِم. 2‏:‏7\x*   
\m
\v 2 يَاشُووَا إِسّكّْ إِرْيَازنْ زِي أَرِيحَا غَارْ عَايْ إِ إِدْجَانْ غَارْ بَايْثْ-أَوِينْ، غَارْ شَّارْقْ ن بَايْثْ-إِلْ. نتَّا إِسِّيوڒْ أَكِيذْسنْ، إِنَّا: ”ڭَاعّْذمْ، برْڭَاڭمْ ثَامُّورْثْ!“ إِرْيَازنْ فّْغنْ ؤُ برْڭَاڭنْ خْ عَايْ.  
\v 3 \add ؤُمِي\add* د -عقْبنْ غَارْ يَاشُووَا، نَّانْ أَسْ: ”نْهْڒَا مَا إِڭعّذْ ذِينْ مَارَّا ڒْڭنْسْ. أجّْ أَذْ ڭعّْذنْ ذِينْ عْڒَاحَاڒْ أَڒْفَاينْ نِيغْ ثڒْثْ-أَڒَافْ ن يرْيَازنْ حِيمَا أَذْغڒْبنْ خْ عَايْ. وَارْ د-تِّيوْيذْ شَا ذِينِّي مَارَّا ڒْڭنْسْ، مِينْزِي نِيثْنِي أَقَا أَثنْ ذِي ذْرُوسْ.  
\v 4 \add أَمُّو\add* إِ ڭعّْذنْ زِي ڒْڭنْسْ عْڒَاحَاڒْ ثڒْثْ-أَڒَافْ ن يرْيَازنْ، \add مَاشَا\add* نِيثْنِي أَروْڒنْ زَّاثْ إِ وُوذمْ ن يرْيَازنْ ن عَايْ.  
\v 5 إِرْيَازنْ ن عَايْ نْغِينْ زَّايْسنْ ستَّا ؤُ-ثْڒَاثِينْ ن يرْيَازنْ ؤُشَا ضْفَارنْ ثنْ زِي زَّاثْ ن وُوذمْ ن ثوَّارْثْ أَڒْ شَابَارِيمْ ؤُشَاغڒْبنْ خَاسنْ ذڭْ ؤُهكّْوُو. \add خنِّي\add* إِفْسِييْ وُوڒْ ن ڒْڭنْسْ، إِذْوڒْ أَمْ وَامَانْ.   
\m
\v 6 يَاشُووَا إِشَارّڭْ أَرُّوضْ نّسْ، إِوْضَا خْ ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ زَّاثْ إِ تَّابُوثْ ن سِيذِي، أَڒْ دْجِيڒثْ، نتَّا ذ إِمْغَارنْ ن إِسْرَائِيل، ؤُشَا نِيثْنِي سُّويُوسنْ ؤُشَاڒْ خْ ؤُزدْجِيفْ نْسنْ.  
\v 7 يَاشُووَا إِنَّا: ”أَ، سِيذِي إِنُو، سِيذِي، مَايمِّي ثجِّيذْ ڒْڭنْسْ-أَ أَذْ إِژْوَا لْ-ؤُرْذُونْ؟ مَا حِيمَا أَذْ أَنغْ ثڭّذْ ذڭْ ؤُفُوسْ ن أَيْثْ ن إِمُورِييّنْ، مَاحنْذْ أَذْ أَنغْ ثحَّانْ؟ إِڒِي، نڭَّا أَذْ نقْبڒْ أَذْ نزْذغْ غَارْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ.“  
\v 8 أَ سِيذِي إِنُو، مِينْ غَا إِنِيغْ، أَوَارْنِي إِ ؤُمِي يَارَّا إِسْرَائِيل أَعْرُورْ غَارْ وُوذمْ ن ڒْعذْيَانْ نّسْ \add مَاحنْذْ أَذْ يَارْوڒْ\add*؟  
\v 9 مَاڒَا أَذْ ث سْڒنْ أَيْثْ ن كنْعَانْ ذ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ، أَذْ أَنغْ قوَّارنْ، أَذْ قضْعنْ إِسمْ نّغْ زِي ثَامُّورْثْ. مِينْ إِ غَا ثڭّذْ \add خنِّي\add* إِ يِيسمْ نّشْ أَمقّْرَانْ؟“   
\m
\v 10 \add خنِّي\add* إِنَّا سِيذِي إِ يَاشُووَا: ”كَّارْ، مَايمِّي \add ذَا\add* ثْمدّذْ أَمُّو خْ ؤُغمْبُوبْ نّشْ غَارْ ثمُّورْثْ؟  
\v 11 أَقَا إِسْرَائِيل إِخْضَا ؤُشَا نِيثْنِيعدَّانْ ڒْعَاهْذْ إِنُو نِّي خْ ذ أَسنْ ؤُمُورغْ. كْسِينْ \add عَاوذْ\add* زِي مِينْ إِدْجَانْ إِتّْوَاحَارّْمنْ \add إِ ؤُثحِّي\add*، ؤُشَارنْ \add عَاوذْ\add*، سّْخَارّْقنْ \add عَاوذْ\add* ؤُشَا سَّارْسنْ \add أَيَا\add* \add عَاوذْ\add* غَارْ ڒقْشُوعْ نْسنْ.  
\v 12 \add خْ ؤُيَا\add* وَارْ زمَّارنْ أَيْثْ ن إِسْرَائِيل أَذْ قِّيمنْ بدّنْ زَّاثْ إِ وُوذمْ ن ڒْعذْيَانْ نْسنْ. أَذْ أَرِّينْ أَعْرُورْ غَارْ وُوذمْ ن ڒْعذْيَانْ نْسنْ \add مَاحنْذْ أَذْ أَروْڒنْ\add*، مِينْزِي نِيثْنِي ذوْڒنْ تّْوَاحَارّْمنْ \add قَاعْ\add* إِ لْحُوكْمْ. نشّْ وَارْ كِيومْ تِّيڒِيغْ عَاذْ، مَاڒَا وَارْ ثكّْسمْ زِي ڒْوسْطْ نْومْ مِينْ إِتّْوَاحَارّْمنْ \add إِ ؤُثحِّي\add*.  
\v 13 كَّارْ، سْقدّسْ ڒْڭنْسْ، أَذْ ثِينِيذْ: ’سْقدّْسمْ إِخفْ نْومْ إِ ثِيوشَّا، مِينْزِي أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: أَقَا ذِينْ شَا مِينْ إِتّْوَاحَارّْمنْ \add إِ ؤُثحِّي\add* ذِي ڒْوسْطْ نْومْ، إِسْرَائِيل! وَارْ ثْزمَّارذْ أَذْ ثسّْبدّذْ ڒْعذْيَانْ نّشْ، أَڒْ غَا ثكّْسمْ زِي ڒْوسْطْ نْومْ مِينْ إِتّْوَاحَارّْمنْ \add إِ ؤُثحِّي\add*.  
\v 14 ثِيوشَّا أَذْ د-ثْقَارّْبمْ، \add أَذْ ثِيڒِيمْ ثتّْوَاستّْفمْ\add* عْلَاحْسَابْ ثِيقبَّاڒْ نْومْ ؤُشَا \add خنِّي\add* أَذْ د-ثْقَارّبْ ثقْبِيتْشْ نِّي إِعدْجمْ سِيذِي، عْلَاحْسَابْ ڒَادْجَاثْ \add نّسْ\add* ؤُ ڒَادْجْ إِ غَا إِعدْجمْ سِيذِي أَذْ د-إِقَارّبْ عْلَاحْسَابْ \add ڒَادْجَاثْ ن\add* ثُوذْرِينْ \add نّسْ\add* ؤُشَا \add ڒَادْجْ ن\add* ثَادَّارْثْ نِّي إِ غَا إِعدْجمْ سِيذِي أَذْ د-إِقَارّبْ \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ \add إِرْيَازنْ\add* إِبْڒِيغنْ \add نْسنْ\add*.  
\v 15 ؤُشَا أَذْ إِمْسَارْ، أَقَا ونِّي إِكْسِينْ شَا زِي مِينْ إِتّْوَاحَارّْمنْ \add إِ ؤُثحِّي\add* أَذْ إِتّْوَاسّشْمضْ س ثْمسِّي أَكْ-ذ مَارَّا مِينْ غَارسْ إِدْجَانْ، مِينْزِي نتَّا إِعدَّا خْ ڒْعَاهْذْ ن سِيذِي ؤُ إِڭَّا ڒفْضِيحثْ ذِي إِسْرَائِيل.‘ “   
\m
\v 16 إِكَّارْ يَاشُووَا زِيشْ ؤُشَا إِجَّا أَذْ د-إِسْقَارّبْ إِسْرَائِيل ثَاقْبِيتْشْ ثَاقْبِيتْشْ ؤُشَا ثتّْوَاعدْجمْ ثقْبِيتْشْ ن يَاهُوذَا.  
\v 17 إِجَّا أَذْ د-ثْقَارّبْ ڒَادْجْ ن يَاهُوذَا ؤُشَا ثتّْوَاعدْجمْ ڒَادْجْ ن إِزَارَاحِييّنْ. \add خنِّي\add* إِجَّا أَذْ د-ثْقَارّبْ ڒَادْجْ ن إِزَارَاحِييّنْ، \add ثتّْوَاستّفْ\add* عْلَاحْسَابْ \add إِرْيَازنْ\add* إِبْڒِيغنْ \add نّسْ\add* ؤُشَا إِتّْوَاعدْجمْ زَابْذِي.  
\v 18 نتَّا إِجَّا أَذْ د-إِقَارّبْ \add ڒَْادْجْ ن\add* ثَادَّارْثْ نّسْ، \add أَمْ تّْوَاستّْفنْ نِيثْنِي\add* عْلَاحْسَابْ \add إِرْيَازنْ\add* إِبْڒِيغنْ \add نْسنْ\add*، ؤُشَا إِتّْوَاعدْجمْ عَاخَانْ، مِّيسْ ن كَارْمِي، مِّيسْ ن زَابْذِي، مِّيسْ ن زَارَاحْ، زِي ثقْبِيتْشْ ن يَاهُوذَا.   
\m
\v 19 يَاشُووَا إِنَّا إِ عَاخَانْ: ”أَ مِّي، أوْشْ ڒْعزّْ إِ سِيذِي، أَربِّي ن إِسْرَائِيل، ؤُ قَاذَا إِ-ث! إِنِي أَيِي، مِينْ ثڭِّيذْ شكْ، وَارْ خَافِي سْنُوفَّارْ شَا“  
\v 20 عَاخَانْ يَارَّا-د خْ يَاشُووَا، إِنَّا: ”أَقَا س ثِيذتّْ، نشّْ خْضِيغْ أَكْ-ذ سِيذِي، أَربِّي ن إِسْرَائِيل، \add مَاغَارْ\add* نشّْ ڭِّيغْ ثَا ذ ثَا.  
\v 21 نشّْ ژْرِيغْ جَارْ ثْكشَّاضْثْ إِجّْ ن ؤُپَارْثسُّو إِزوّْقنْ زِي شِينَارْ ذ مِيثَاينْ شِيقْلُو ن نُّوقَارْثْ ذ إِشْثْ ن ثْبَارَّاثْ ن وُورغْ ثوْزنْ خمْسِينْ شِيقْلُو. نشّْ مژْرغْ ذَايْسنْ ؤُشَا إِوْيغْ ثنْ-د غَارِي، أَقَا أَثنْ نُّوفَارنْ ذِي ثمُّورْثْ، ذِي ڒْوسْطْ ن ؤُقِيضُونْ إِنُو، ذ نُّوقَارْثْ سْوَادَّايْ.“  
\v 22 يَاشُووَا إِسّكّْ إِرقَّاسنْ. نِيثْنِي ؤُزّْڒنْ غَارْ ؤُقِيضُونْ، خْزَارْ، \add ڒحْوَايجْ\add* ثُوغَا أَثنْ نُوفَّارنْ ذڭْ ؤُقِيضُونْ، ذ نُّوقَارْثْ سْوَادَّايْ.  
\v 23 كْسِينْ نِيثْنِي \add ڒحْوَايجْ نِّي\add* زِي ڒْوسْطْ ن ؤُقِيضُونْ ؤُشَا إِوْينْ ثنْ غَارْ يَاشُووَا ؤُ غَارْ مَارَّا أَيْثْ ن إِسْرَائِيل ؤُشَا سَّارْسنْ ثنْ زَّاثْ إِ وُوذمْ ن سِيذِي. \f ◼ \fr 7:‏23 \ft \+bd ’سَّارْسنْ ثنْ ...‘\+bd* - س ثْعِيبْرَانِيثْ ’سيّْبنْ ثنْ‘.\f*   
\m
\v 24 يَاشُووَا، ذ مَارَّا إِسْرَائِيل أَكِيذسْ، إِكْسِي عَاخَانْ، مِّيسْ ن زَارَاحْ، ؤُڒَا ذ نُّوقَارْثْ ذ ؤُپَارْثسُّو إِزوّْقنْ ذ ثْبَارَّاثْ ن وُورغْ ذ إِحنْجِيرنْ نّسْ ذ يسِّيسْ نّسْ ذ إِفُونَاسنْ نّسْ ذ إِغْيَاڒْ نّسْ ذ وُودْجِي نّسْ ذ ؤُقِيضُونْ نّسْ ذ مَارَّا مِينْ غَارسْ ؤُشَا إِوْينْ ثنْ غَارْ ثغْزُورْثْ ن أَخُورْ.  
\v 25 إِنَّا يَاشُووَا: ”مَايمِّي ذ أَنغْ ثڭِّيذْ ذِي أَرّْژِييثْ؟ سِيذِي أَذْ شكْ يڭّْ ذِي أَرّْژِييثْ أَسّْ-أَ!“ ذ مَارَّا إِسْرَائِيل يَارْجمْ إِ-ث س إِژْرَا ؤُشَا سّْشمْضنْ ثنْ س ثْمسِّي ؤُشَا نْضَارنْ خَاسنْ إِژْرَا.  
\v 26 سّْبدّنْ خَاسْ إِجّْ ن ؤُعُورِّيشْ ذ أَمقّْرَانْ ن إِژْرَا \add ونِّي ذِينْ إِدْجَانْ\add* أَڒْ أَسّْ-أَ. ؤُشَا سِيذِي إِڭَّا أَذْ د-إِعْقبْ ڒْحَاذُوقْ ن وغْضَابْ نّسْ. خْ ؤُيَا قَّارنْ أَسْ إِ ثمُّورْثْ نِّي: ’ثَاغْزُورْثْ ن أَخُورْ‘ أَڒْ أَسّْ-أَ. \f ◼ \fr 7:‏26 \ft \+bd ’أَخُورْ‘\+bd* - مِينْ إِخْسْ أَذْ يِينِي ’ڒغْبنْ‘.\f*   
\b  
\b  
\m  
\c 8
\s1 أَغلّبْ خْ عَايْ  
\m
\v 1 \add خنِّي\add* إِنَّا سِيذِي إِ يَاشُووَا: ”وَارْ تّڭّْوذْ، وَارْ تّجِّي أَذْ إِعْڭزْ وُوڒْ نّشْ. كْسِي أَكِيذكْ مَارَّا ڒْڭنْسْ ن ڒْعسْكَارْ، كَّارْ، ثُويُورذْ غَارْ عَايْ! خْزَارْ، نشّْ ڭِّيغْ أَجدْجِيذْ ن عَايْ ذ ڒْڭنْسْ نّسْ ذ ثنْذِينْثْ نّسْ ذ ثمُّورْثْ نّسْ ذڭْ ؤُفُوسْ نّشْ. \x ◘ \xo 8:‏1 \xt أَعَوذ. 1‏:‏21؛ 7‏:‏18\x*  
\v 2 شكْ أَذْ ثڭّذْ أَكْ-ذ عَايْ ؤُ أَكْ-ذ ؤُجدْجِيذْ نّسْ أَمْ مَامّشْ ثڭِّيذْ أَكْ-ذ أَرِيحَا ؤُ أَكْ-ذ ؤُجدْجِيذْ نّسْ، أَذْ ثكْسِيمْ مْغِيرْ ثَاكشَّاضْثْ ذ ڒبْهَايمْ وَاهَا إِ يِيخفْ نْومْ. أڭّْ ذڭْ وعْرُورْ ن ثنْذِينْثْ إِجْنْ ن ڒْفخْ.“ \x ◘ \xo 8:‏2 \xt أَعَوذ. 20‏:‏14؛ ياش. 6‏:‏21\x*  *   
\b  
\m
\v 3 \add خَاسْ ؤُشَا\add* إِكَّارْ يَاشُووَا أَكْ-ذ مَارَّا ڒْڭنْسْ ن ڒْعسْكَارْ حِيمَا أَذْ إِڭعّذْ غَارْ عَايْ. إِخْضَارْ يَاشُووَا ثڒْثْ-أَڒَافْ ن يرْيَازنْ، أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، ؤُشَا إِسّكّْ إِ-ثنْ سْ دْجِيڒثْ  
\v 4 ؤُشَا يُومُورْ إِ-ثنْ، إِنَّا: ”خْزَارمْ، أَذْ ثڭّمْ ڒْفخْ غَارْ وعْڒُوڒْ ن ثنْذِينْثْ. وَارْ ثِيڭّْوجمْ أَطَّاسْ خْ ثنْذِينْثْ ؤُ إِڒِيمْ ثْحزّْممْ.  
\v 5 نشّْ أَذْ د-قَارّْبغْ غَارْ ثنْذِينْثْ أَكْ-ذ مَارَّا ڒْڭنْسْ. أَذْ إِمْسَارْ مَاڒَا فّْغنْ إِ ؤُمْسَاڭَارْ أَكِيذْنغْ أَمْ \add ثْوَاڒَاثْ\add* ثَامزْوَارُوثْ، \add خنِّي\add* أَذْ زَّايْسنْ نَارْوڒْ زَّاثْ إِ وُوذمْ نْسنْ.  
\v 6 نِيثْنِي أَذْ أَنغْ د-ضْفَارنْ أَڒْ ثنْ د-نسِّيڭّْوجْ خْ ثنْذِينْثْ، مِينْزِي نِيثْنِي أَذْ إِنِينْ: ’نِيثْنِي أَروْڒنْ زَّاثْ إِ وُوذمْ نّغْ أَمْ \add ثْوَاڒَاثْ\add* ثَامزْوَارُوثْ.‘ \add خْمِي\add* زَّايْسنْ غَا نَارْوڒْ زَّاثْ إِ وُوذمْ نْسنْ،  
\v 7 إِتّْخصَّا كنِّيوْ أَذْ ثكَّارمْ زڭْ وشْبَارْ، أَذْ ثطّْفمْ ثَانْذِينْثْ، مِينْزِي سِيذِي، أَربِّي نْومْ، أَذْ ت إِوْشْ ذڭْ ؤُفُوسْ نْومْ.  
\v 8 ؤُشَا أَذْ إِمْسَارْ خْ مِينِّي إِ غَا ثِيڒِي ثطّْفمْ ثَانْذِينْثْ، أَذْ ثسَّارْغمْ ثَانْذِينْثْ س ثْمسِّي. إِتّْخصَّا أَذْ ثڭّمْ عْلَاحْسَابْ أَوَاڒْ ن سِيذِي. خْزَارمْ، نشّْ أَقَا ؤُمُورغْ كنِّيوْ.“   
\m
\v 9 \add خنِّي\add* إِسّكّْ إِ-ثنْ يَاشُووَا ؤُشَا نِيثْنِي ڭِّينْ ڒْفخْ ؤُشَا قِّيمنْ جَارْ بَايْثْ-إِلْ ذ عَايْ، غَارْ ڒْغَارْبْ خْ عَايْ. يَاشُووَا إِسّنْسْ دْجِيڒثْ نِّي ذِي ڒْوسْطْ ن ڒْڭنْسْ.  
\v 10 ثِيوشَّا زِيشْ إِكَّارْ يَاشُووَا. إِحْسبْ ڒْڭنْسْ \add إِ ؤُمنْغِي\add* ؤُشَا إِڭعّذْ أَكْ-ذ إِمْغَارنْ ن إِسْرَائِيل زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ غَارْ عَايْ.  
\v 11 مَارَّا ڒْڭنْسْ ن ڒْعسْكَارْ، إِنِّي كِيسْ إِدْجَانْ، إِفّغْ-د ؤُشَا نِيثْنِي قَارّْبنْ-د ؤُشَا إِوْضنْ أَڒْ قِيبَاتْشْ إِ ثنْذِينْثْ. نِيثْنِي وْثِينْ إِقِيضَانْ نْسنْ غَارْ شَّامَالْ نْ عَايْ. ثُوغَا \add ذِينْ\add* إِشْثْ ن ثغْزُورْثْ جَارْ أَسْ-د ذ عَايْ.  
\v 12 إِكْسِي نتَّا عْڒَاحَاڒْ خمْسَا-أَڒَافْ ن يرْيَازنْ ؤُشَا إِڭَّا أَسنْ ڒْفخْ جَارْ بَايْثْ-إِلْ ذ عَايْ، غَارْ ڒْغَارْبْ ن ثنْذِينْثْ.  
\v 13 سّْبدّنْ ڒْڭنْسْ، زعْمَا مَارَّا ڒْعسْكَارْ غَارْ شَّامَالْ ن ثنْذِينْثْ، ؤُشَا أَغزْذِيسْ أَنڭَّارُو \add ن ڒْعسْكَارْ\add* غَارْ ڒْغَارْبْ ن ثنْذِينْثْ. يَاشُووَا إِرُوحْ دْجِيڒثْ نِّي غَارْ ڒْوسْطْ ن ڒوْضَا ن ثغْزُورْثْ.   
\m
\v 14 \add ؤُمِي\add* إِژْرَا-يَا ؤُجدْجِيذْ ن عَايْ، قدْجْقنْ ؤُشَا كَّارنْ زِيشْ. فّْغنْ إِرْيَازنْ ن ثنْذِينْثْ إِ ؤُمْسَاڭَارْ أَكْ-ذ إِسْرَائِيل، إِ ؤُمنْغِي، نتَّا أَكْ-ذ مَارَّا ڒْڭنْسْ نّسْ، غَارْ وَازَّايْ \add ن ؤُمنْغِي\add* زَّاثْ إِ وُوذمْ ن ڒوْضَا. مَاشَا نتَّا وَارْ إِسِّينْ بلِّي ثُوغَا ڭِّينْ أَسْ إِجّْ ن ڒْفخْ غَارْ وعْرُورْ ن ثنْذِينْثْ.  
\v 15 يَاشُووَا ذ مَارَّا إِسْرَائِيل ڭِّينْ أَخْمِي جِّينْ إِخفْ نْسنْ أَذْ تّْوَاوْثنْ قِيبَاتْشْ نْسنْ ؤُشَا أَروْڒنْ خْ وبْرِيذْ ن ڒخْڒَا.  
\v 16 مَارَّا ڒْڭنْسْ إِ ثُوغَا إِدْجَانْ ذِي ثنْذِينْثْ ڒَاغَانْ ثنْ حِيمَا أَذْ ثنْ ضْفَارنْ. ضْفَارنْ يَاشُووَا ؤُشَا ذوْڒنْ إِڭّْوجنْ خْ ثنْذِينْثْ.  
\v 17 ؤُڒَا ذ إِجّْ ن ورْيَازْ وَارْ إِقِّيمْ ذِي عَايْ نِيغْ ذِي بَايْثْ-إِلْ، ونِّي وَارْ د-إِفِّيغنْ شَا إِ وضْفَارْ أَوَارْنِي إِ إِسْرَائِيل، ؤُشَا نِيثْنِي جِّينْ ثَانْذِينْثْ ثَارْزمْ ؤُشَا قِّيمنْ ضفَّارنْ \add أَيْثْ ن\add* إِسْرَائِيل.   
\m
\v 18 \add خنِّي\add* إِسِّيوڒْ سِيذِي أَكْ-ذ يَاشُووَا: ”سْوِيژّضْ أَحْرِيشْ نِّي ذڭْ ؤُفُوسْ نّشْ غَارْ عَايْ، مِينْزِي نشّْ أَذْ وْشغْ ثَانْذِينْثْ ذڭْ ؤُفُوسْ نّشْ.“ \add خنِّي\add* إِسّْوِيژّضْ يَاشُووَا أَحْرِيشْ نِّي ذڭْ ؤُفُوسْ نّسْ غَارْ ثنْذِينْثْ. \f ◼ \fr 8:‏18 \ft \+bd ’نشّْ أَذْ وْشغْ ثَانْذِينْثْ ذڭْ ؤُفُوسْ نّشْ‘\+bd* - س ثْعِيبْرَانِيثْ ’نشّْ أَذْ ت وْشغْ ذڭْ ؤُفُوسْ نّشْ‘.\f*  
\v 19 \add خنِّي\add* إِكَّارْ ؤُغزْذِيسْ أَنڭَّارُو \add ن ڒْعسْكَارْ\add* ذغْيَا ؤُشَا ؤُمِي إِسَارّحْ \add يَاشُوعَا\add* أَفُوسْ نّسْ، بْذَانْ أَذْ أَزّْڒنْ ؤُشَا إِوْضنْ غَارْ ثنْذِينْثْ ؤُشَا طّْفنْ ت. ڭِّينْ ث س ثَازْڒَا ؤُشَا سّكَّارنْ ثِيمسِّي ذِي ثنْذِينْثْ.  
\v 20 إِرْيَازنْ ن عَايْ نّْقڒْبنْ ؤُشَا ژْرِينْ دّخَّانْ يُوڒِي غَارْ ؤُجنَّا زِي ثنْذِينْثْ. نِيثْنِي وَارْ زمَّارنْ أَذْ أَروْڒنْ غَارْ ذَا ؤُڒَا غَارْ ذِينْ، \add مِينْزِي\add* ڒْڭنْسْ إِ ثُوغَا يَاروْڒنْ غَارْ ڒخْڒَا، إِنّقْڒبْ-د \add إِ ؤُمنْغِي\add* خْ ونِّي ثنْ إِضفَّارنْ.  
\v 21 \add ؤُمِي\add* إِژَارْ يَاشُووَا ذ مَارَّا أَيْثْ ن إِسْرَائِيل بلِّي \add إِنِّي ثُوغَا رَاجَانْ ذِي\add* ثْنُوفّْرَا، طّْفنْ ثَانْذِينْثْ ؤُشَا يُوڒِي دّخَّانْ زِي ثنْذِينْثْ،عقْبنْ-د نِيثْنِي ؤُشَا وْثِينْ إِرْيَازنْ ن عَايْ.  
\v 22 إِنِّي د-إِفّْغنْ زِي ثنْذِينْثْ، رُوحنْ إِ ؤُمْسَاڭَارْ أَكِيذْسنْ، أَڒَامِي \add إِرْيَازنْ ن عَايْ\add* ذوْڒنْ ذِي ڒْوسْطْ ن إِسْرَائِيل إِيّنْ، إِنَا غَارْ ؤُغزْذِيسْ-أَ ذ إِنَا غَارْ ؤُغزْذِيسْ نّغْنِي، ؤُشَا نِيثْنِيغڒْبنْ خَاسنْ أَڒَامِي وَارْ زَّايْسنْ إِقِّيمْ ؤُڒَا ذ إِجّنْ أَذْ يَارْوڒْ نِيغْ أَذْ إِنْجمْ. \x ◘ \xo 8:‏22 \xt أَعَوذ. 7‏:‏2\x*  
\v 23 منْعنْ أَجدْجِيذْ ن عَايْ أَمْ إِدَّارْ \add عَاذْ\add* ؤُ إِوْينْ ث غَارْ يَاشُووَا.   
\m
\v 24 \add ؤُمِي\add* أَيْثْ ن إِسْرَائِيل كمّْڒنْ أَذْ نْغنْ مَارَّا إِمزْذَاغْ ن عَايْ، \add أَمْ\add* ذڭْ إِيَّارْ \add أَمْ\add* ذِي ڒخْڒَا مَانِي ثُوغَا ثنْ د-ضْفَارنْ ؤُشَا تّْوَانْغنْ مَارَّا س ڒقْضعْ ن سِّيفْ، \add خنِّي\add* إِعْقبْ إِسْرَائِيل غَارْ عَايْ ؤُشَا وْثِينْ ت س ڒقْضعْ ن سِّيفْ.  
\v 25 مَارَّا إِنِّي إِتّْوَانْغنْ ذڭْ وَاسّْ نِّي، إِرْيَازنْ ذ ثمْغَارِينْ، ثُوغَا أَثنْ ذِي ثنْعَاشْ-أَڒَافْ، ذَايسْ مَارَّا إِرْيَازنْ ن عَايْ.  
\v 26 يَاشُووَا وَارْ إِسّهْوِي أَفُوسْ نّسْ إِ إِسّْوِيژّْضنْ س ؤُحْرِيشْ أَڒَامِي ثُوغَا إِحَارّمْ مَارَّا إِمزْذَاغْ ن عَايْ \add إِ ؤُثحِّي\add*.  
\v 27 كْسِينْ إِسْرَائِيل إِيّنْ مْغِيرْ ڒبْهَايمْ ذ ثْكشَّاضْثْ ن ثنْذِينْثْ نِّي إِ يِيخفْ نْسنْ عْلَاحْسَابْ أَوَاڒْ ن سِيذِي، \add أَوَاڒْ\add* نِّي يُومُورْ نتَّا إِ يَاشُووَا. \x ◘ \xo 8:‏27 \xt ڒخْڒ. 31‏:‏22، 26؛ ياش. 8‏:‏2\x*  
\v 28 إِسّشْمضْ يَاشُووَا \add ثَانْذِينْثْ ن\add* عَايْ ؤُشَا يَارَّا إِ-ت ذ إِشْثْ ن ڒْخِيرْبثْ إِ ڒبْذَا، ذ إِشْثْ ن ثمُّورْثْ ذ ڒخْڒَا أَڒْ أَسّْ-أَ.  
\v 29 نتَّا يُويڒْ أَجدْجِيذْ ن عَايْ غَارْ إِشْثْ ن ثحْنَاشْثْ أَڒْ ثَامذِّيثْ ؤُ ؤُمِي ثغْڒِي ثْفُوشْثْ، يُومُورْ يَاشُووَا أَذْ كّْسنْ ڒْخشْبثْ نّسْ زِي ثحْنَاشْثْ. نْضَارنْ ت غَارْ وَاذَافْ ن ثوَّارْثْ ن ثنْذِينْثْ ؤُ سّْبدّنْ خَاسْ إِجّْ ن ؤُعُورِّيشْ ذ أَمقّْرَانْ ن يژْرَا، \add إِ ذِينْ إِدْجَانْ\add* عَاذْ أَڒْ أَسّْ-أَ. \x ◘ \xo 8:‏29 \xt أَعَوذ. 21‏:‏22، 23\x*   
\b  
\m  
\s1 أَعَالْثَارْ خْ وذْرَارْ ن إِبَالْ ذ ثْغُورِي ن شَّارِيعَا  
\m
\v 30 \add خنِّي\add* إِبْنَا يَاشُووَا إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي، أَربِّي ن إِسْرَائِيل، خْ وذْرَارْ ن عِيبَالْ،  
\v 31 أَمْ مَامّشْ \add ث\add* يُومُورْ مُوسَا، أَمْسخَّارْ ن سِيذِي، إِ أَيْثْ ن إِسْرَائِيل، عْلَاحْسَابْ مِينْ يُورَانْ ذڭْ وذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا ن مُوسَا: إِجّْ ن ؤُعَالْطَارْ ن وژْرُو قَاعْ، وَارْ خَاسْ ميّْڒنْ س \add ؤُڒَا ذ إِجّْ ن دُّوزَانْ ن\add* وُوزَّاڒْ زِي سَّا غَارْ ذَا. نِيثْنِي بخَّارنْ خَاسْ ثِيغَارْصَا ن ثْمسِّي إِ سِيذِي. غَارْصنْ \add عَاوذْ\add* ثِيغَارْصَا ن ڒهْنَا. \x ◘ \xo 8:‏31 \xt ؤُف. 20‏:‏25؛ أَعَوذ. 27‏:‏4\x*  
\v 32 خْ يژْرَا إِڭَّا نتَّا إِشْثْ ن ثِيڒمْثْ ن ثِيرَا ن شَّارِيعَا ن مُوسَا، ثنِّي يُورَا زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 8:‏32 \xt أَعَوذ. 27‏:‏3\x*  
\v 33 مَارَّا أَيْثْ ن إِسْرَائِيل ذ إِمْغَارنْ ذ إِمحْضَاينْ ذ ڒْقُوضَاثْ بدّنْ غَارْ ؤُغزْذِيسْ-أَ ؤُ غَارْ ؤُغزْذِيسْ نّغْنِي ن تَّابُوثْ قِيبَاتْشْ إِ إِكهَّاننْ زِي \add أَيْثْ ن\add* لَاوِي إِنِّي يَارْبُونْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي، أَمْ ؤُبَارَّانِي أَمْ أَيْثْبَابْ ن ثمُّورْثْ. أَزْينْ زَّايْسنْ ثُوغَا زَّاثْ ن وذْرَارْ ن جِيرِيزِيمْ ؤُ أَزْينْ نّغْنِي غَارْ زَّاثْ ن وذْرَارْ ن عِيبَالْ، أَمْ مَامّشْ ثُوغَا يُومُورْ مُوسَا، أَمْسخَّارْ ن سِيذِي زِيشْ، مَاحنْذْ أَذْ بَارْكنْ \add أَمُّو\add* أَيْثْ ن إِسْرَائِيل.  
\v 34 أَوَارْنِي ؤُيَا إِغْرَا مَارَّا أَوَاڒنْ ن شَّارِيعَا، لْبَارَاكَا ذ نّعْڒثْ، عْلَاحْسَابْ مَارَّا مِينْ يُورَانْ ذڭْ وذْلِيسْ ن شَّارِيعَا.  
\v 35 زِي مَارَّا مِينْ ثُوغَا يُومُورْ مُوسَا، وَارْ إِدْجِي ؤُڒَا ذ إِجّْ ن وَاوَاڒْ، وَارْ ث إِغْرِي يَاشُووَا إِ مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن إِسْرَائِيل، ؤُڒَا ذ ثِيمْغَارِينْ ذ إِحنْجِيرنْ إِمژْيَاننْ ذ ؤُبَارَّانِي ونِّي أَكِيذْسنْ إِرُوحنْ، \add ثُوغَا أَثنْ ذِينْ\add*. \x ◘ \xo 8:‏35 \xt أَعَوذ. 31‏:‏11\x*   
\b  
\b  
\m  
\c 9
\s1 ثَاحْرَايْمشْثْ ن أَيْثْ ن جِيبْعُونْ  
\m
\v 1 ؤُمِي مَارَّا إِجدْجِيذنْ، إِنِّي يدْجَانْ خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ صْرِينْ خْ مَانْ أَيَا - \add إِجدْجِيذنْ\add* خْ ثمُّورْثْ ن إِذُورَارْ، ذِي ثمُّورْثْ إِوَاطَانْ ؤُ غَارْ مَارَّا ثْمَا ن ڒبْحَارْ أَمقّْرَانْ أَڒْ قِيبَاتْشْ إِ \add إِذُورَارْ ن\add* لُوبْنَانْ: إِحِيتِّييّنْ ذ إِمُورِييّنْ ذ أَيْثْ ن كنْعَانْ ذ إِفَارِيزِييّنْ ذ إِحِيوِييّنْ ذ إِيابُوسِييّنْ -\f ◼ \fr 9:‏1 \ft \+bd ’ڒبْحَارْ أَمقّْرَانْ‘\+bd* - نِيغْ ’إِلّْ أَمقّْرَانْ‘. ڒبْحَارْ-أَ قَّارنْ أَسْ ذِي أَرِيفْ ’ڒبْحَارْ أَمژْيَانْ‘ ؤُ إِسمْ نّسْ ذ جْذِيذْ أَقَا-ث ’إِلّْ أَڭْرَاكَالْ‘.\f*  
\v 2 مُوننْ نِيثْنِي حِيمَا أَذْ مّنْغنْ أَكْ-ذ يَاشُووَا ؤُ أَكْ-ذ إِسْرَائِيل خْ إِجّْ ن أَرَّايْ.  
\v 3 \add ؤُمِي\add* إِمزْذَاغْ ن جِيبْعُونْ سْڒِينْ مِينْ ثُوغَا إِڭَّا يَاشُووَا أَكْ-ذ أَرِيحَا ذ عَايْ،  
\v 4 ڭِّينْ ث س ثحْرَايْمشْثْ. نِيثْنِي ؤُيُورنْ ذڭْ وبْرِيذْ ؤُشَا ڭِّينْ إِخفْ نْسنْ ذ إِمْسكَّانْ. إِوْينْ ثِيخُونْشَايْ ثِيبُوڒَايْ خْ إِغْيَاڒْ نْسنْ، ثِيخُونْشَايْ ن يِيڒمْ ثِيبُوڒَايْ تّْوَاشَارّْڭنْثْ ؤُ ثْوَاخيّْضنْثْ \add عَاوذْ\add* إِ بِينُو.  
\v 5 \add قّْننْ عَاوذْ\add* ثِيسِيڒَا ذ ڒْبَارِي، إِتّْوَاضَارّْفنْ خْ إِضَارنْ نْسنْ ؤُ يَارْضنْ أَرُّوضْ أَبُوڒَايْ، ؤُ مَارَّا أَغْرُومْ ن ڒعْوتْشْ نْسنْ ثُوغَا يُوژغْ إِتّْفْرُورُويْ.   
\m
\v 6 ؤُيُورنْ \add أَمُّو\add* غَارْ يَاشُووَا ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن جِيلْجَالْ، نَّانْ أَسْ إِ نتَّا ؤُ إِ أَيْثْ ن إِسْرَائِيل: ”نشِّينْ نُوسَا-د زڭْ إِشْثْ ن ثمُّورْثْ ثِيڭّْوجْ. ڒخُّو خنِّي، ڭّمْ إِجّْ ن ڒْعَاهْذْ أَكِيذْنغْ.“  
\v 7 أَرِّينْ-د إِرْيَازنْ ن إِسْرَائِيل خْ إِحِيوِييّنْ: ”أَذْ ثَاغْ كنِّيوْ ثْزدّْغمْ جَارْ أَنغْ. مَامّشْ نْزمَّارْ أَذْ كِيذْومْ نڭّْ إِجّْ ن ڒْعَاهْذْ؟“  
\v 8 نِيثْنِي مَاشَا نَّانْ إِ يَاشُووَا: ”نشِّينْ ذ إِمْسخَّارنْ نّشْ.“ \add خنِّي\add* إِنَّا أَسنْ يَاشُووَا: ”مِينْ ثعْنَامْ كنِّيوْ ذ مَانِيسْ إِ د-ثُوسِيمْ؟“  
\v 9 نِيثْنِي أَرِّينْ-د خَاسْ: ”إِمْسخَّارنْ نّشْ ؤُسِينْ-د زڭْ إِشْثْ ن ثمُّورْثْ ثِيڭّْوجْ أَطَّاسْ ذِي طّْوعْ ن يِيسمْ ن سِيذِي، أَربِّي نْومْ. مِينْزِي نشِّينْ نسْڒَا خَاسْ ڒخْبَارْ ؤُ خْ مَارَّا مِينْ إِڭَّا ذِي مِيصْرَا،  
\v 10 ذ مَارَّا مِينْ إِڭَّا نتَّا أَكْ-ذ إِجدْجِيذنْ ن أَيْثْ ن إِمُورِييّنْ إِنِّي يدْجَانْ أَغِيرِينْ إِ لْ-ؤُرْذُونْ، سِيحُونْ، أَجدْجِيذْ ن حَاشْبُونْ، ذ عُوجْ، أَجدْجِيذْ ن بَاشَانْ نِّي ثُوغَا إِزدّغْ ذِي عَاشْثَارُوثْ. \x ◘ \xo 9:‏10 \xt ڒخْڒ. 21‏:‏24، 33؛ أَعَوذ. 1‏:‏4\x*  
\v 11 ؤُشَا سِّيوْڒنْ أَكِيذْنغْ إِمْغَارنْ نّغْ ذ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ، نَّانْ: ’طّْفمْ ڒعْوتْشْ ذڭْ ؤُفُوسْ نْومْ إِ وبْرِيذْ، ؤُيُورمْ إِ ؤُمْسَاڭَارْ أَكِيذْسنْ ؤُشَا أَذْ أَسنْ ثِينِيمْ: نشِّينْ ذ إِمْسخَّارنْ نْومْ.‘ خنِّي ڒخُّو، ڭّمْ أَكِيذْنغْ إِجّْ ن ڒْعَاهْذْ.  
\v 12 أَغْرُومْ-أَ نّغْ ذَا ثُوغَا عَاذْ إِحْمَا ؤُمِي ث-إِ-د أَكِيذْنغْ نكْسِي زِي ثُوذْرِينْ نّغْ ذ ڒعْوتْشْ ذڭْ وَاسّْ أَڒَامِي غَارْومْ د-نطّفْ أَبْرِيذْ. ڒخُّو أَقَا-ث يُوژغْ إِذْوڒْ إِتّْفْرُورُويْ.  
\v 13 ؤُڒَا ذ ثِيخُونْشَايْ ن يِيڒمْ ن بِينُو نِّي نشُّورْ، ثُوغَا أَثنْثْ ن جْذِيذْ، مَاشَا خْزَارمْ، ڒخُّو فدْجْقنْثْ. أَقَا \add ذ\add* أَرُّوضْ نّغْ ذ سَانْذَالِييَاثْ نّغْ حْفَانْثْ س وبْرِيذْ إِ إِڭّْوجنْ س وَاطَّاسْ.“  
\v 14 \add خنِّي\add* كْسِينْ إِرْيَازنْ ن إِسْرَائِيل زِي ڒعْوتْشْ. وَارْ كْسِينْ شّْوَارْ زڭْ ؤُقمُّومْ ن سِيذِي.  
\v 15 إِڭَّا يَاشُووَا أَكِيذْسنْ ڒهْنَا ؤُ إِڭَّا أَكِيذْسنْ \add عَاوذْ\add* إِجّْ ن ڒْعَاهْذْ، أَذْ ثنْ يجّْ أَذْ دَّارنْ ؤُشَا ؤُڒَا ذ ڒْحُوكَّامْ ن ثْمسْمُونْثْ جُّودْجنْ أَسنْ.   
\b  
\m
\v 16 أَوَارْنِي ثْڒَاثَا ن وُوسَّانْ أَوَارْنِي إِ ؤُمِي ثُوغَا إِ ذ أَسنْ وْشِينْ ڒْعَاهْذْ، سْڒَانْ نِيثْنِي بلِّي أَقَا ذ جِّيرَانْ نْسنْ، ؤُ أَقَا زدّْغنْ ذِي ڒْوسْطْ نْسنْ.  
\v 17 \add مِينْزِي\add* أَيْثْ ن إِسْرَائِيل كّْسنْ \add إِقِيضَانْ نْسنْ\add* ؤُشَا إِوْضنْ غَارْ ثْندَّامْ نْسنْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا. ثُوغَا ثِيندَّامْ نْسنْ جِيبْعُونْ ذ كَافِيرَا ذ بِيعْرُوثْ ذ قَارْيَاثْ-يَاعَارِيمْ.  
\v 18 أَيْثْ ن إِسْرَائِيل وَارْ ثنْ نْغِينْ شَا، مِينْزِي ڒْحُوكَّامْ ن ثْمسْمُونْثْ ثُوغَا جُّودْجنْ أَسنْ \add أَيَا\add* غَارْ سِيذِي، أَربِّي ن إِسْرَائِيل. س ؤُينِّي إِ ثقِّيمْ مَارَّا ثْمسْمُونْثْ ثْمُوغْمُوغْ خْ ڒْحُوكَّامْ.  
\v 19 \add خنِّي\add* نَّانْ مَارَّا ڒْحُوكَّامْ ن ثْمسْمُونْثْ: ”نشِّينْ نجُّودْجْ أَسنْ \add أَيَا\add* غَارْ سِيذِي، أَربِّي ن إِسْرَائِيل. س ؤُينِّي ڒخُّو وَارْ نْزمَّارْ أَذْ ثنْ نْحَاذَا.  
\v 20 إِتّْخصَّا أَذْ نْكمّڒْ \add ثَاجَادْجِيثْ-أَ\add* ؤُ أَذْ ثنْ نجّْ أَذْ دَّارنْ، مَاحنْذْ وَارْ خَانغْ د-إِوطِّي ؤُذُوقّزْ ن وغْضَابْ ذِي سِّيبّثْ ن ثْجَادْجِيثْ نِّي ذ أَسنْ نڭَّا.  
\v 21 ڒْحُوكَّامْ نَّانْ أَسنْ: ”نِيثْنِي أَذْ قِّيمنْ دَّارنْ ؤُشَا أَذْ ذوْڒنْ ذ إِنزْذَامنْ ذ إِنُويَامْ إِ مَارَّا ثَامسْمُونْثْ، أَمْ مَامّشْ ذ أَسنْ ث نَّانْ ڒْحُوكَّامْ.“   
\m
\v 22 إِڒَاغَا إِ-ثنْ يَاشُووَا، إِنَّا: ”مَايمِّي خَانغْ ثْشمْثمْ، ثنَّامْ: ’نشِّينْ نْزدّغْ غَارْ ڒَاڭّْوَاجْ س وَاطَّاسْ خَاومْ!‘، وَاخَّا كنِّيوْ ثْزدّْغمْ ذِي ڒْوسْثْ ن ثمُّورْثْ نّغْ؟  
\v 23 ڒخُّو خنِّي، كنِّيوْ ثتّْوَانعْڒمْ. وَارْ زَّايْومْ إِتّْوَاكّسْ أَذْ ثِيڒِيمْ ذ إِمْسخَّارنْ، إِنزْذَامنْ ذ إِنُويَامْ إِ ثَادَّارْثْ ن أَربِّي إِنُو.“ \f ◼ \fr 9:‏23 \ft \+bd ’وَارْ زَّايْومْ إِتّْوَاكّسْ أَذْ ثِيڒِيمْ ....‘\+bd* - س ثْعِيبْرَانِيثْ ’وَارْ زَّايْومْ إِتّْوَاقصّْ ...‘.\f*  
\v 24 نِيثْنِي أَرِّينْ-د خْ يَاشُووَا، نَّانْ: ”إِ إِمْسخَّارنْ نّشْ إِتّْوَانَّا نِيشَانْ بلِّي سِيذِي، أَربِّي نْومْ، يُومُورْ أَمْسخَّارْ نّسْ مُوسَا، أَقَا نتَّا أَذْ أَومْ إِوْشَا مَارَّا ثَامُّورْثْ ؤُشَا أَذْ إِهلّكْ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ زَّاثْ إِ ثِيطَّاوِينْ نْومْ. \add س ؤُيَا\add* ثُوغَا نڭّْوذْ أَطَّاسْ خْ ثُوذَارْثْ نّغْ زَّاثْ إِ وُوذمْ نْومْ. س ؤُينِّي إِ نڭَّا نشِّينْ أَيَا. \f ◼ \fr 9:‏24 \ft \+bd ’خْ ثُوذَارْثْ نّغْ‘\+bd* - س ثْعِيبْرَانِيثْ ’خْ ڒعْمُورْ نّغْ‘.\f*  \x ◘ \xo 9:‏24 \xt أَعَوذ. 7‏:‏1، 2\x*  
\v 25 ڒخُّو \add خنِّي\add*، خْزَارْ، أَقَا أَنغْ ذڭْ ؤُفُوسْ نّشْ. أڭّْ أَكِيذْنغْ مِينْ ثتّْوَاڒِيذْ مْلِيحْ ذ مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ نّشْ حِيمَا أَذْ زَّايْنغْ ثڭّذْ.“  
\v 26 أَمُّو إِ زَّايْسنْ إِڭَّا ؤُشَا نتَّا إِفكّْ إِ-ثنْ زڭْ ؤُفُوسْ ن أَيْثْ ن إِسْرَائِيل، أَڒَامِي نِيثْنِي وَارْ ثنْ نْغِينْ شَا.  
\v 27 ذڭْ وَاسّْ نِّي سِيمَانْثْ نّسْ إِڭَّا إِ-ثنْ يَاشُووَا ذ إِنزْذَامنْ ذ إِنُويَامْ إِ ثْمسْمُونْثْ ؤُ إِ ؤُعَالْطَارْ ن سِيذِي، أَڒْ أَسّْ-أَ، ذڭْ ومْشَانْ نِّي غَا يِيخْضَارْ نتَّا.   
\b  
\b  
\m  
\c 10
\s1 أَمنْغِي غَارْ جِيبْعُونْ  
\m
\v 1 إِمْسَارْ، ؤُمِي أَذُونِي-صَاذَاقْ، أَجدْجِيذْ ن ؤُرْشَالِيمْ إِسْڒَا، أَقَا يَاشُووَا ثُوغَا إِطّفْ عَايْ، إِحَارّمْ إِ-ت قَاعْ ؤُشَا أَقَا إِڭَّا أَكْ-ذ عَايْ ذ أَجدْجِيذْ نّسْ أَمْ ثُوغَا إِڭَّا أَكْ-ذ أَرِيحَا ؤُ أَكْ-ذ ؤُجدْجِيذْ نّسْ ؤُ أَقَا إِمزْذَاغْ ن جِيبْعُونْ ڭِّينْ ڒهْنَا أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُ زدّْغنْ ذِي ڒْوسْطْ نْسنْ، \x ◘ \xo 10:‏1 \xt ياش. 6‏:‏15؛ 9‏:‏15\x*  
\v 2 \add أَقَا\add* نِيثْنِي ڭّْوذنْ أَطَّاسْ، مِينْزِي جِيبْعُونْ ثُوغَا ذ إِشْثْ ن ثنْذِينْثْ ثمْغَارْ، ؤُمِي ت ثُوغَا أَمْ يِيشْثنْ زِي \add جَارْ\add* ثْندَّامْ ن ثْڭلْذِيثْ. ثُوغَا-ت ثمْغَارْ خْ عَايْ ؤُ مَارَّا إِرْيَازنْ نّسْ ثُوغَا أَثنْ ذ أَيْثْ ن بُو-ثغْرُوضْثْ.  
\v 3 إِسّكّْ أَذُونِي-زذكْ، أَجدْجِيذْ ن ؤُرْشَالِيمْ، \add إِمْسكَّانْ\add* غَارْ هُوهَامْ، أَجدْجِيذْ ن حَابْرُونْ، غَارْ فِيرْ‘أَمْ، أَجدْجِيذْ ن يَارْمُوثْ، غَارْ يَافِيعْ، أَجدْجِيذْ ن لَاخِيشْ ؤُ غَارْ ذَابِيرْ، أَجدْجِيذْ ن عَاجْلُونْ، إِنَّا:  
\v 4 ”ڭعّْذمْ-د غَارِي ؤُ ثوْشمْ أَيِي أَفُوسْ. أجّْ أَنغْ أَذْ نوّثْ جِيبْعُونْ، مِينْزِي ثڭَّا ڒهْنَا أَكْ-ذ يَاشُووَا ؤُ أَكْ-ذ أَيْثْ ن إِسْرَائِيل.“  
\v 5 نِيثْنِي مُوننْ ؤُشَا ڭعّْذنْ خمْسَا ن إِجدْجِيذنْ ن إِمُورِييّنْ: أَجدْجِيذْ ن ؤُرْشَالِيمْ، أَجدْجِيذْ ن حَابْرُونْ، أَجدْجِيذْ ن يَارْمُوثْ، أَجدْجِيذْ ن عَاجْلُونْ، نِيثْنِي ذ مَارَّا ڒْعسْكَارْ نْسنْ ؤُشَا نّْضنْ إِ جِيبْعُونْ ؤُشَا كَّارنْ مّنْغنْ أَكِيذسْ.   
\m
\v 6 سّكّنْ إِرْيَازنْ ن جِيبْعُونْ \add إِرقَّاسنْ\add* إِ يَاشُووَا، غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ذِي جِيلْجَالْ، نَّانْ: ”وَارْ سمّحْ إِفَاسّنْ نّشْ ذڭْ إِمْسخَّارنْ نّشْ، أَسْ-د ذغْيَا غَارْنغْ. سنْجمْ أَنغْ ذ ثوْشذْ أَنغْ أَفُوسْ، مِينْزِي مَارَّا إِجدْجِيذنْ ن أَيْثْ ن إِمُورِييّنْ، إِنِّي إِ إِزدّْغنْ ذڭْ إِذُورَارْ، أَقَا مُوننْ خَانغْ.“   
\m
\v 7 \add خنِّي\add* إِڭعّذْ-د يَاشُووَا زِي جِيلْجَالْ، نتَّا ذ مَارَّا ڒْڭنْسْ ن ڒْعسْكَارْ أَكِيذسْ ذ مَارَّا أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ.  
\v 8 \add مِينْزِي\add* سِيذِي إِنَّا إِ يَاشُووَا ”وَارْ تّڭّْوذْ شَا زَّايْسنْ، مِينْزِي وْشِيغْ ثنْ ذڭْ ؤُفُوسْ نّشْ. ؤُڒَا ذ إِجّْ زَّايْسنْ وَارْ إِزمَّارْ أَذْ إِبدّْ زَّاثْ إِ وُوذمْ نّشْ.“  
\v 9 يَاشُووَا إِهْوَا-د خَاسنْ س ڒْغفْڒثْ. إِڭعَّاذنْ-د زِي جِيلْجَالْ دْجِيڒثْ أَمْ ثكْمڒْ.  
\v 10 سِيذِي إِسّْنخْڒعْ إِ-ثنْ زَّاثْ إِ وُوذمْ ن إِسْرَائِيل ؤُشَا إِڭَّا أَسنْ إِجّْ ن وغْضَارْ ذ أَمقّْرَانْ غَارْ جِيبْعُونْ ؤُشَا نتَّا إِضْفَارْ إِ-ثنْ خْ وبْرِيذْ إِتّْڭعَّاذنْ غَارْ بَايْثْ-حُورُونْ ؤُشَا إِوّثْ إِ-ثنْ أَڒْ طَّارْفْ ن عَازِيقَّا ذ مَاقِيذَا.  
\v 11 إِمْسَارْ ؤُمِي نِيثْنِي أَروْڒنْ زَّاثْ إِ وُوذمْ ن إِسْرَائِيل ذڭْ ؤُهكّْوُو غَارْ بَايْثْ-حُورُونْ، أَقَا سِيذِي إِنْضَارْ خَاسنْ إِژْرَا ذ إِمقّْرَاننْ زڭْ ؤُجنَّا أَڒْ عَازِيقَّا ؤُشَا مُّوثنْ. إِنِّي إِمُّوثنْ س إِبْقُوقنْ ن ثبْرُورِي ثُوغَا أَثنْ كْثَارْ زڭْ إِنِّي إِتّْوَانْغنْ س سِّيفْ س إِفَاسّنْ ن أَيْثْ ن إِسْرَائِيل.   
\m
\v 12 خنِّي إِسِّيوڒْ يَاشُووَا أَكْ-ذ سِيذِي، ذڭْ وَاسّْ ؤُمِي إِسلّمْ سِيذِي إِمُورِييّنْ إِ أَيْثْ ن إِسْرَائِيل، إِنَّا زَّاثْ إِ ثِيطَّاوِينْ ن إِسْرَائِيل إِيّنْ: ”\add أَ\add* ثَافُوشْثْ، بدّْ غَارْ جِيبْعُونْ، إِ \add شكْ أَ،\add* أَيُورْ، غَارْ ثغْزُورْثْ ن أَيَالُونْ“  
\v 13 ؤُشَا ثَافُوشْثْ ثْبدّْ ذ ؤُيُورْ إِقِّيمْ إِبدّْ أَڒَامِي يُوغَا ڒْڭنْسْ ثَاسْغَارْثْ خْ ڒْعذْيَانْ نّسْ. مَا وَارْ يُورَا مَانْ أَيَا ذڭْ وذْلِيسْ إِتّْوَانّْضنْ ن ؤُمْسڭّذْ؟ ثَافُوشْثْ ثْبدّْ ذِي ڒْوسْطْ ن ؤُجنَّا ؤُ وَارْ ثْقدْجقْ أَذْ ثْغدْجِي، عْڒَاينْ إِجّْ ن وَاسّْ إِكْمڒْ.  
\v 14 وَارْ ذِينْ إِدْجِي ؤُڒَا ذ إِجّْ ن وَاسّْ أَمْ وَانِيثَا، \add وَارْ إِمْسَارْ\add* زِيشْ ؤُڒَا أَوَارْنِي أَسْ، إِجّْ ن وَاسّْ إِ ذِي ثُوغَا إِسْڒَا سِيذِي غَارْ ثْمِيجَّا ن إِجّْ ن ورْيَازْ أَمُّو، مِينْزِي سِيذِي ثُوغَا إِمّْنغْ ذِي طّْوعْ ن إِسْرَائِيل.  
\v 15 \add خنِّي\add* إِعْقبْ-د يَاشُووَا ذ مَارَّا إِسْرَائِيل أَكِيذسْ، غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ذِي جِيلْجَالْ.   
\b  
\m
\v 16 خمْسَا ن إِجدْجِيذنْ نِّي أَروْڒنْ ؤُشَا نُّوفَارنْ ذڭْ إِفْرِي غَارْ مَاقِّيذَا.  
\v 17 إِتّْوَانَّا مَانْ أَيَا إِ يَاشُووَا، نَّانْ: ”أَقَا تّْوَافنْ خمْسَا ن إِجدْجِيذنْ. نِيثْنِي نُّوفَّارنْ ذڭْ إِفْرِي غَارْ مَاقِّيذَا.  
\v 18 \add خنِّي\add* إِنَّا يَاشُووَا: ”سقْنُونِّييمْ ثِيصُوضَارْ ذ ثِيمقّْرَانِينْ خْ ؤُقمُّومْ ن إِفْرِي ؤُشَا سّْبدّمْ إِرْيَازنْ خَاسنْ، حِيمَا أَذْ خَاسنْعسّنْ.  
\v 19 كنِّيوْ \add س يِيخفْ نْومْ\add*، وَارْ ثتّْغِيمَامْ ثْبدّمْ. ضْفَارمْ ڒْعذْيَانْ نْومْ، وْثمْ أَغزْذِيسْ أَنڭَّارُو نْسنْ. وَارْ ثنْ تّجِّيمْ أَذْ أَذْفنْ غَارْ ثْندَّامْ نْسنْ، مِينْزِي سِيذِي، أَربِّي نْومْ، إِڭَّا أَومْ ثنْ ذڭْ ؤُفُوسْ نْومْ.“  
\v 20 ؤُمِي إِكمّڒْ إِ-ثنْ يَاشُووَا ذ أَيْثْ ن إِسْرَائِيل س إِشْثْ ن ثشْثِي ثَامقّْرَانْثْ أَڒَامِي تّْوَاقْضَانْ نِيثْنِي، ؤُشَا إِوْضنْ \add مْغِيرْ\add* إِنِّي يَاروْڒنْ غَارْ ثْندَّامْ إِفَارْينْ،  
\v 21 أَقَا يَارڭّْوحْ مَارَّا ڒْڭنْسْ ذِي ڒهْنَا غَارْ يَاشُووَا ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ غَارْ مَاقِّيذَا. ؤُڒَا ذ إِجّْ \add وَارْ إِزْعِيمْ\add* أَذْ إِسّنْهزْ إِڒسْ نّسْ خْ أَيْثْ ن إِسْرَائِيل.   
\m
\v 22 \add خنِّي\add* إِنَّا يَاشُووَا: ”أَرْزْممْ أَقمُّومْ ن إِفْرِي ؤُشَا أَوْيمْ-د خمْسَا ن إِجدْجِيذنْ نِّي زڭْ إِفْرِي غَارِي ذَا!“  
\v 23 نِيثْنِي ڭِّينْ \add ث\add* أَمُّو، سُّوفّْغنْ-د خمْسَا ن إِجدْجِيذنْ زڭْ إِفْرِي غَارسْ: أَجدْجِيذْ ن ؤُرْشَالِيمْ، أَجدْجِيذْ ن حَابْرُونْ، أَجدْجِيذْ ن يَارْمُوثْ، أَجدْجِيذْ ن لَاخِيشْ ذ ؤُجدْجِيذْ ن عَاجْلُونْ.  
\v 24 ؤُمِي د-سُّوفّْغنْ نِيثْنِي إِجدْجِيذنْ نِّي غَارْ يَاشُووَا، إِڒَاغَا يَاشُووَا مَارَّا إِرْيَازنْ ن إِسْرَائِيل ؤُشَا إِنَّا إِ إِكُومَانْذَارنْ خْ إِعسْكَارِييّنْ نِّي ثُوغَا أَكِيذسْ إِرُوحنْ: ”قَارّْبمْ-د ؤُشَا سَارْسمْ إِضَارنْ نْومْ خْ ثْمجَّارِينْ ن إِجدْجِيذنْ-أَ.“ قَارّْبنْ-د نِيثْنِي ؤُشَا سَّارْسنْ إِضَارنْ خْ ثِيمجَّارِينْ نْسنْ.  
\v 25 \add خنِّي\add* إِنَّا أَسنْ يَاشُووَا: ”وَارْ تّڭّْوْذمْ شَا، وَارْ تّجِّيمْ أَذْ إِعْقزْ وُوڒْ نْومْ، إِڒِيمْ ذ إِرْيَازنْ ؤُ إِڒِيمْ ثْمحْضمْ، مِينْزِي أَمُّو إِ غَا إِڭّْ سِيذِي أَكْ-ذ مَارَّا ڒْعذْيَانْ نْومْ، إِنِّي أَكْ-ذ ثتّْمنْغَامْ.“  
\v 26 خنِّي إِوّثْ إِ-ثنْ يَاشُووَا ؤُشَا إِنْغَا إِ-ثنْ. يَايڒْ إِ-ثنْ غَارْ خمْسَا ن ثْحنْيَا ؤُشَا قِّيمنْ أَيْڒنْ غَارْ ثْحنْيَا أَڒَامِي ذ ثَامذِّيثْ. \x ◘ \xo 10:‏26 \xt أَعَوذ. 21‏:‏23؛ ياش. 8‏:‏29\x*  
\v 27 إِمْسَارْ غَارْ ڒْوقْثْ ن ؤُغدْجَايْ ن ثْفُوشْثْ، إِسّكّْ يَاشُووَا مَاحنْذْ أَذْ ثنْ-إِ-د-كّْسنْ زِي ثْحنْيَا، أَذْ ثنْ نْضَارنْ ذڭْ إِفْرِي إِ ذِي ثُوغَا نُّوفَّارنْ. خنِّي ڭِّينْ ثِيصُوضَارْ ذ ثِيمقّْرَانِينْ خْ ؤُقمُّومْ ن إِفْرِي، \add إِنِّي ذِينْ إِدْجَانْ\add* أَڒْ أَسّْ-أَ.  
\v 28 ذڭْ وَاسّْ نِّي إِطّفْ يَاشُووَا \bd مَاقِّيذَا\bd* ؤُشَا إِوّثْ إِ-ت س ڒقْضعْ ن سِّيفْ. ؤُشَا أَجدْجِيذْ نّسْ، إِحَارّمْ إِ-ث ؤُڒَا ذ \add مَارَّا\add* نِيثْنِي ذ كُوڒْ ڒعْمَارْ نِّي \add إِدْجَانْ\add* ذڭْ ومْشَانْ نِّي. وَارْ إِجِّي أَذْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن ؤُمَارْوڒْ ؤُشَا إِڭَّا أَكْ-ذ ؤُجدْجِيذْ ن مَاقِّيذَا أَمْ مَامّشْ ثُوغَا إِڭَّا أَكْ-ذ ؤُجدْجِيذْ ن أَرِيحَا.  
\v 29 \add خنِّي\add* إِژْوَا يَاشُووَا أَكْ-ذ مَارَّا أَيْثْ ن إِسْرَائِيل زِي مَاقِّيذَا غَارْ لِيبْنَا ؤُشَا إِمّْنغْ أَكْ-ذ لِيبْنَا.  
\v 30 ؤُشَا سِيذِي إِوْشَا إِ-ت ذڭْ ؤُفُوسْ ن إِسْرَائِيل، أَكْ-ذ ؤُجدْجِيذْ نّسْ. إِوّثْ إِ-ت س ڒقْضعْ ن سِّيفْ أَكْ-ذ مَارَّا ڒعْمَارْ إِ ذَايسْ \add إِدْجَانْ\add*، وَارْ إِجِّي أَذْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن ؤُمَارْوڒْ، ؤُشَا إِڭَّا أَكْ-ذ ؤُجدْجِيذْ نّسْ أَمْ مَامّشْ ثُوغَا إِڭَّا أَكْ-ذ ؤُجدْجِيذْ ن أَرِيحَا.   
\m
\v 31 \add خنِّي\add* إِژْوَا يَاشُووَا زِي لِيبْنَا غَارْ \bd لَاخِيشْ\bd* ذ مَارَّا إِسْرَائِيل أَكِيذسْ ؤُشَا إِنّضْ أَسْ-د إِ ثنْذِينْثْ ؤُشَا إِمّْنغْ أَكِيذسْ.  
\v 32 سِيذِي إِوْشَا لَاخِيشْ ذڭْ ؤُفُوسْ ن إِسْرَائِيل. ؤُشَا إِسْرَائِيل إِطّفْ إِ-ت ذڭْ وَاسّْ وِيسّْ ثْنَاينْ ؤُشَا إِوّثْ إِ-ت س ڒقْضعْ ن سِّيفْ أَكْ-ذ مَارَّا ڒعْمَارْ إِ ذَايسْ \add إِدْجَانْ\add*، أَمُّو نِيشَانْ أَمْ مَامّشْ ثُوغَا إِ-ت إِڭَّا أَكْ-ذ لِيبْنَا.  
\v 33 خنِّي إِڭعّذْ هُورَامْ، أَجدْجِيذْ ن جَازَارْ، مَاحنْذْ أَذْ إِعَاونْ لَاخِيشْ، \add مَاشَا\add* يَاشُووَا إِوّثْ إِ-ث ؤُڒَا ذ ڒْڭنْسْ نّسْ أَڒَامِي وَارْ إِجِّي أَذْ غَارسْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن ؤُمَارْوڒْ.   
\m
\v 34 يَاشُووَا إِژْوَا زِي لَاخِيشْ غَارْ \bd عَاجْلُونْ\bd* ذ مَارَّا إِسْرَائِيل أَكِيذسْ ؤُشَا نّْضنْ أَسْ-د ؤُشَا مّنْغنْ أَكِيذسْ.  
\v 35 طّْفنْ ت ذڭْ وَاسّْ نِّي ؤُشَا وْثِينْ ت س ڒقْضعْ ن سِّيفْ ؤُشَا ذڭْ وَاسّْ نِّي إِحَارّمْ مَارَّا ڒعْمَارْ إِ ذَايسْ \add إِدْجَانْ\add*، أَمُّو نِيشَانْ أَمْ مَامّشْ ثُوغَا إِڭَّا أَكْ-ذ لَاخِيشْ.   
\m
\v 36 إِژْوَا يَاشُووَا زِي عَاجْلُونْ غَارْ \bd حَابْرُونْ\bd* ذ مَارَّا إِسْرَائِيل أَكِيذسْ، ؤُشَا مّنْغنْ أَكِيذسْ.  
\v 37 نِيثْنِي طّْفنْ ت ؤُشَا وْثِينْ ت س ڒقْضعْ ن سِّيفْ، أَجدْجِيذْ نّسْ ذ مَارَّا ثِيندَّامْ نّسْ أَكْ-ذ مَارَّا ڒعْمَارْ إِ ذَايسْ \add إِدْجَانْ\add*. وَارْ إِجِّي أَذْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن ؤُمَارْوڒْ، أَمُّو نِيشَانْ أَمْ مَامّشْ ثُوغَا إِڭَّا أَكْ-ذ عَاجْلُونْ. نتَّا إِحَارّمْ إِ-ت أَكْ-ذ مَارَّا ڒعْمَارْ إِ ذَايسْ \add إِدْجَانْ\add*.   
\m
\v 38 ؤُشَا إِذْوڒْ-د يَاشُووَا غَارْ \bd ذَابِيرْ\bd* ذ مَارَّا إِسْرَائِيل أَكِيذسْ ؤُشَا إِمّْنغْ أَكِيذسْ.  
\v 39 نتَّا إِطّفْ إِ-ت ؤُ نِيثْنِي وْثِينْ أَجدْجِيذْ نّسْ ذ مَارَّا ثِيندَّامْ نّسْ س ڒقْضعْ ن سِّيفْ ؤُشَا حَارّْمنْ مَارَّا ڒعْمَارْ إِ ذَايسْ \add إِدْجَانْ\add*. نتَّا وَارْ إِجِّي أَذْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن ؤُمَارْوڒْ. أَمْ مَامّشْ ثُوغَا إِڭَّا نتَّا أَكْ-ذ حَابْرُونْ، أَمُّو إِڭَّا \add عَاوذْ\add* أَكْ-ذ ذَابِيرْ ؤُ أَكْ-ذ ؤُجدْجِيذْ نّسْ إِڭَّا أَمْ ثُوغَا إِڭَّا أَكْ-ذ ؤُجدْجِيذْ ن لِيبْنَا.  
\v 40 \add أَمُّو\add* إِ إِغْڒبْ يَاشُووَا خْ مَارَّا ثَامُّورْثْ: ثَامُّورْثْ ن إِذُورَارْ ذ \add ثمُّورْثْ ن\add* لْجَانُوبْ ذ ثمُّورْثْ إِوَاطَانْ، ذ مَارَّا إِجدْجِيذنْ نْسنْ. وَارْ إِجِّي أَذْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن ؤُمَارْوڒْ. مَارَّا مِينْ ثُوغَا إِتَّارَّانْ نّفْسْ، إِحَارّمْ إِ-ث إِ ؤُثحِّي، أَمْ مَامّشْ ثُوغَا إِ ذ أَسْ يُومُورْ سِيذِي أَربِّي ن إِسْرَائِيل. \x ◘ \xo 10:‏40 \xt أَعَوذ. 7‏:‏2؛ 20‏:‏16، 17؛ ياش. 8‏:‏2\x*  
\v 41 يَاشُووَا إِوّثْ إِ-ثنْ زِي قَاذَاشْ-بَارْنِيعْ أَڒْ غَازَّا ؤُ أَمُّو ؤُڒَا ذ مَارَّا ثَامُّورْثْ ن جُوشَانْ، أَڒْ جِيبْعُونْ.  
\v 42 إِطّفْ يَاشُووَا إِجدْجِيذنْ-أَ ذ ثمُّورْثْ نْسنْ س إِشْثْ ن ثشْثِي، مِينْزِي سِيذِي، أَربِّي ن إِسْرَائِيل، إِمّْنغْ ذِي طّْوعْ ن إِسْرَائِيل.  
\v 43 \add خنِّي\add* إِعْقبْ يَاشُووَا غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ذِي جِيلْجَالْ ذ مَارَّا إِسْرَائِيل أَكِيذسْ.   
\b  
\b  
\m  
\c 11
\s1 أَمنْغِي ضِيدّْ إِ ؤُجدْجِيذْ يَابِينْ ذ إِجدْجِيذنْ نِّي أَكِيسْ إِدْجَانْ  
\m
\v 1 ؤُمِي يَابِينْ، أَجدْجِيذْ ن \bd حَاصُورْ\bd*، إِسْڒَا أَيَا، إِسّكّْ غَارْ يُوبَابْ، أَجدْجِيذْ ن \bd مَاذُونْ\bd*، غَارْ ؤُجدْجِيذْ ن \bd شِيمْرُونْ\bd*، غَارْ ؤُجدْجِيذْ ن \bd أَكْشَافْ\bd*،  
\v 2 ؤُ غَارْ إِجدْجِيذنْ إِنِّي ثُوغَا \add إِزدّْغنْ\add* غَارْ شَّامَالْ ذِي ثمُّورْثْ ن إِذُورَارْ ؤُ ذِي ڒوْضَا غَارْ لْجَانُوبْ زِي كِينَّارُوثْ ؤُ ذِي ثمُّورْثْ إِوَاطَانْ ؤُ خْ ثِيوْرِيرِينْ ن ذُورْ غَارْ ڒْغَارْبْ،  
\v 3 غَارْ أَيْثْ ن كنْعَانْ ذِي شَّارْقْ ذ ڒْغَارْبْ، إِمُورِييّنْ، إِحِيتِّييّنْ، إِفِيرِيزِييّنْ، إِيابُوسِييّنْ ذڭْ إِذُورَارْ ذ إِحِيوِييّنْ غَارْ ؤُضَارْ ن \add وذْرَارْ\add* ن هِيرْمُونْ، ذِي ثمُّورْثْ ن مِيصْفَا.  
\v 4 فّْغنْ-د نِيثْنِي س مَارَّا ڒْعسْكَارْ نْسنْ أَكِيذْسنْ، إِجّْ ن ؤُبَارَّا أَمقّْرَانْ ن ڒْڭنْسْ، أَمْ يِيجْذِي غَارْ ثْمَا ن ڒبْحَارْ، أَنشْثْ أَطَّاسْ، ؤُشَا \add أَرْنِي غَارسْ\add* أَطَّاسْ س وَاطَّاسْ ن إِيْسَانْ ذ إِكَارُّوثنْ.  
\v 5 مَارَّا إِجدْجِيذنْ-أَ ڒَاغَانْ-د خَاسنْ ؤُشَا ؤُسِينْ-د، وْثِينْ إِقِيضَانْ نْسنْ جْمِيعْ غَارْ وَامَانْ ن مَايْرُومْ إِ ؤُمنْغِي ضِيدّْ إِ إِسْرَائِيل.*   
\b  
\m
\v 6 إِنَّا سِيذِي إِ يَاشُووَا: ”وَارْ زَّايْسنْ تّڭّْوذْ، مِينْزِي ثِيوشَّا غَارْ ڒْوقْثْ أَمُّو ڒخُّو أَذْ ثنْ ڭّغْ تّْوَاغڒْبنْ مَارَّا زَّاثْ إِ وُوذمْ ن إِسْرَائِيل. شكْ أَذْ ثْقسّذْ إِژوْرَانْ ن إِضَارنْ ن إِيْسَانْ نْسنْ ؤُشَا أَذْ ثسّْشمْضذْ إِكَارُّوثنْ نْسنْ ذِي ثْمسِّي.“   
\m
\v 7 يَاشُووَا س مَارَّا ڒْعسْكَارْ أَكِيذسْ، إِفّغْ-د غَارْسنْ س إِشْثْ ن ڒْغفْڒثْ غَارْ وَامَانْ ن مَايْرُومْ ؤُشَا وْضَانْ-د خَاسنْ.  
\v 8 سِيذِي إِڭَّا إِ-ثنْ ذڭْ ؤُفُوسْ ن إِسْرَائِيل ؤُشَا نِيثْنِي وْثِينْ ثنْ، ضْفَارنْ ثنْ أَڒْ صِيذُونْ-أَمقّْرَانْ ذ مِيسْرَافُوثْ-مَايِيمْ، ؤُ أَڒْ ثَايْسَارْثْ ن مِيصْفَا غَارْ شَّارْقْ. نِيثْنِي قْضَانْ ثنْ أَڒَامِي وَارْ زَّايْسنْ جِّينْ أَذْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن ؤُمَارْوڒْ.  
\v 9 يَاشُووَا إِڭَّا أَكِيذْسنْ أَمْ مَامّشْ ذ أَسْ إِنَّا سِيذِي. نتَّا إِقسّْ إِژوْرَانْ ن إِضَارنْ ن إِيْسَانْ نْسنْ ؤُشَا إِسّشْمضْ إِكَارُّوثنْ نْسنْ س ثْمسِّي.   
\m
\v 10 ذِي ڒْوقْثْ نِّي إِعْقبْ يَاشُووَا ؤُشَا إِطّفْ حَاصُورْ ؤُشَا إِوْثَا أَجدْجِيذْ نّسْ س \add ڒقْضعْ ن\add* سِّيفْ، مِينْزِي حَاصُورْ ثُوغَا-ث قْبڒْ ذ أَزدْجِيفْ خْ مَارَّا ثِيڭلْذِيوِينْ-أَ.  
\v 11 وْثِينْ مَارَّا ڒعْمَارْ \add إِدَّارنْ\add* نِّي ذَايسْ إِدْجَانْ س ڒقْضعْ ن سِّيفْ ؤُشَا حَارّْمنْ ثنْ ؤُ نْغِينْ ثنْ. وَارْ إِقِّيمْ وَالُو زِي مَارَّا مِينْ إِتَّارَّانْ نّفْسْ ؤُشَا إِسّشْمضْ حَاصُورْ س ثْمسِّي.  
\v 12 إِطّفْ يَاشُووَا مَارَّا ثِيندَّامْ ن إِجدْجِيذنْ-أَ س مَارَّا إِجدْجِيذنْ نْسنْ ؤُشَا إِوْثَا إِ-ثنْ س ڒقْضعْ ن سِّيفْ ؤُشَا إِحَارّمْ إِ-ثنْ، أَمْ مَامّشْ ثُوغَا يُومُورْ مُوسَا، أَمْسخَّارْ ن سِيذِي. \x ◘ \xo 11:‏12 \xt أَعَوذ. 20‏:‏16، 17؛ ياش. 10‏:‏40\x*  
\v 13 مَارَّا ثِيندَّامْ نِّي إِبدّنْ خْ ثِيوْرِيرِينْ وَارْ ثنْثْ سّْشمْضنْ إِسْرَائِيل إِيّنْ س ثْمسِّي، مْغِيرْ حَاصُورْ ؤُمِي إِسّشْمضْ يَاشُووَا س ثْمسِّي.  
\v 14 كشّْضنْ أَيْثْ ن إِسْرَائِيل مَارَّا ثَاكشَّاضْثْ ن ثْندَّامْ ذ ڒبْهَايمْ إِ إِخفْ نْسنْ. مَاشَا نِيثْنِي نْغِينْ مَارَّا إِوْذَانْ س ڒقْضعْ ن سِّيفْ، أَڒَامِي ثنْ ثحَّانْ. مَارَّا مِينْ إِتَّارَانْ نّفْسْ، وَارْ زَّايسْ جِّينْ ؤُڒَا ذ إِجّْ.   
\b  
\m  
\s1 لِيسْثَا ن مَارَّا مِينْ إِطّفْ يَاشُووَا ن ثمُّورْثْ ن كنْعَانْ  
\m
\v 15 أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي إِ ؤُمْسخَّارْ نّسْ مُوسَا، أَمُّو إِ ث إِڭَّا مُوسَا خْ يَاشُووَا، ؤُشَا أَمُّو \add إِ-ث\add* إِڭَّا يَاشُووَا. نتَّا وَارْ إِسْمِيحْ ؤُڒَا ذڭْ إِجّْ ن وَاوَاڒْ زِي مَارَّا \add أَوَاڒنْ\add* إِ يُومُورْ سِيذِي إِ مُوسَا \add مَاحنْذْ أَذْ ث إِڭّْ\add*. \x ◘ \xo 11:‏15 \xt ؤُف. 23‏:‏32، 33؛ 34‏:‏12؛ ڒخْڒ. 33‏:‏52؛ أَعَوذ. 7‏:‏2؛ 20‏:‏16\x*  
\v 16 \add أَمُّو\add* إِطّفْ يَاشُووَا مَارَّا ثَامُّورْثْ نِّي: ثَامُّورْثْ ن إِذُورَارْ ذ مَارَّا \add ثَامُّورْثْ ن\add* لْجَانُوبْ ذ مَارَّا ثَامُّورْثْ ن جُوشَانْ ذ ثمُّورْثْ إِوَاطَانْ ذ ڒوْضَا ذ إِذُورَارْ ن إِسْرَائِيل ذ ڒْوَاطَا نّسْ،  
\v 17 \add مَارَّا ثَامُّورْثْ\add* زڭْ وذْرَارْ ذ أَقشَّارْ، ونِّي إِسْڭعَّاذنْ غَارْ سَاعِيرْ أَڒْ بَاعْلْ-جَاذْ، ذِي ثيْسَارْثْ ن لُوبْنَانْ، سْوَادَّايْ إِ وذْرَارْ ن حِيرْمُونْ. مَارَّا إِجدْجِيذنْ نْسنْ إِحبّسْ إِ-ثنْ، إِوْثَا إِ-ثنْ ؤُشَا إِنْغَا إِ-ثنْ.  
\v 18 أَطَّاسْ ن وُوسَّانْ إِ إِمّْنغْ يَاشُووَا أَكْ-ذ مَارَّا إِجدْجِيذنْ-أَ.  
\v 19 وَارْ إِدْجِي ؤُڒَا ذ إِشْثْ ن ثنْذِينْثْ إِ إِڭِّينْ ڒهْنَا أَكْ-ذ أَيْثْ ن إِسْرَائِيل، مْغِيرْ إِحِيوِييّنْ، إِنِّي ثُوغَا إِزدّْغنْ ذِي جِيبْعُونْ. نِيثْنِي طّْفنْ ثنْثْ مَارَّا س ؤُمنْغِي.  
\v 20 مِينْزِي سِيذِي ثُوغَا إِڭَّا أَذْ إِسّقْسحْ ؤُڒْ نْسنْ أَڒْ د غَا فّْغنْ أَذْ مّنْغنْ أَكْ-ذ إِسْرَائِيل، حِيمَا أَذْ ثنْ إِحَارّمْ ؤُشَا وَارْ خَاسنْ يَارحّمْ، حِيمَا أَذْ ثنْ إِقْضَا، أَمْ مَامّشْ ثُوغَا يُومُورْ سِيذِي إِ مُوسَا.   
\m
\v 21 ذِي ڒْوقْثْ نِّي إِفّغْ يَاشُووَا ؤُشَا إِثحَّا \bd إِعَانَاقِييّنْ\bd* زِي ثمُّورْثْ ن إِذُورَارْ، زِي حَابْرُونْ، زِي ذَابِيرْ، زِي عَانَابْ، زِي مَارَّا ثَامُّورْثْ ن إِذُورَارْ ن يَاهُوذَا ؤُ زِي مَارَّا ثَامُّورْثْ ن إِذُورَارْ ن إِسْرَائِيل. يَاشُووَا إِحَارّمْ إِ-ثنْ أَكْ-ذ ثْندَّامْ نْسنْ إِ ؤُثحِّي.  
\v 22 ذِي ثمُّورْثْ ن أَيْثْ إِسْرَائِيل وَارْ قِّيمنْ عَاذْ إِعَانَاقِييّنْ. قِّيمنْ مْغِيرْ ذِي غَازَّا، جَاثْ ذ أَشْذُوذْ.   
\m
\v 23 إِطّفْ يَاشُووَا مَارَّا ثَامُّورْثْ نِّي، أَمْ مَامّشْ مَارَّا إِ ثُوغَا إِسِّيوڒْ سِيذِي غَارْ مُوسَا، ؤُشَا يَاشُووَا إِوْشَا إِ-ت ذ ڒْوَارْثْ إِ إِسْرَائِيل عْلَاحْسَابْ ثِيرْبِيعِينْ ن ثْقبَّاڒْ نْسنْ. \add خنِّي\add* ثُوغَا ثَامُّورْثْ ثَاريّحْ زڭْ ؤُمنْغِي.   
\b  
\b  
\m  
\c 12
\s1 أَغْڒبْ خْ وَاحْذْ ؤُ ثْڒَاثِينْ ن إِجدْجِيذنْ  
\m
\v 1 إِنَا ذ إِجدْجِيذنْ ن ثمُّورْثْ، إِنِّي خْغڒْبنْ أَيْثْ ن إِسْرَائِيل ؤُشَا \add خنِّي\add* طّْفنْ نِيثْنِي ثَامُّورْثْ نْسنْ ذ ڒْوَارْثْ، أَغِيرِينْ إِ لْ-ؤُرْذُونْ زِي مَانِيسْ إِ ذ ثْنقَّارْ ثْفُوشْثْ، زِي ثغْزَارْثْ ن أَرْنُونْ أَڒْ إِذُورَارْ ن حِيرْمُونْ ذ مَارَّا ڒوْضَا ذِي شَّارْقْ.   
\m
\v 2 غَارْ ؤُمزْوَارُو نْسنْ، سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ، ونِّي ثُوغَا إِزدّْغنْ ذِي حَاشْبُونْ، نتَّا إِحْكمْ \add خْ جّْوَايهْ\add* زِي عَارُوعِيرْ إِ إِدْجَانْ غَارْ ثْمَا ن ثغْزَارْثْ ن أَرْنُونْ، \add أَڒْ\add* ڒْوسْطْ ن ثغْزَارْثْ، ؤُ خْ وزْينْ ن جِيلْعَاذْ أَڒْ ثِيغْزَارْثْ ن يَابُّوقْ، \add أَقَا-ث\add* ذ أَيْمِيرْ ن أَيْثْ ن عَامُّونْ،  
\v 3 ؤُ خْ ڒوْضَا أَڒْ ڒبْحَارْ ن كِينَّارُوثْ ذِي شَّارْقْ ؤُ أَڒْ ڒبْحَارْ ن ڒوْضَا، ڒبْحَارْ أَمدْجَاحْ، ذِي شَّارْقْ، أَبْرِيذْ ن بَايْثْ-يَاشِيمُوثْ، ؤُ زِي لْجَانُوبْ أَڒْ سْوَادَّايْ إِ ثيْسَارِينْ ن فِيسْجَا.   
\m
\v 4 \add خنِّي\add* ثَامُّورْثْ ن عُوجْ، أَجدْجِيذْ ن بَاشَانْ، \add ونِّي إِدْجَانْ\add* زِي مِينْ إِقِّيمنْ زڭْ إِرَافَاوِييّنْ، \add جْوَاهڒْ\add* إِ ثُوغَا إِزدّْغنْ ذِي عَاشْثَارُوثْ ذ إِذْرَاعِي. \x ◘ \xo 12:‏4 \xt  أَعَوذ. 1‏:‏4\x*  
\v 5 نتَّا إِحْكمْ خْ إِذُورَارْ ن حِيرْمُونْ، خْ سَالْخَا ؤُ خْ مَارَّا بَاشَانْ أَڒْ ويْمِيرْ ن إِجَاشُورِييّنْ ذ إِمَاعْكِييّنْ ؤُ خْ وزْينْ ن جِيلْعَاذْ أَڒْ ثَامُّورْثْ ن سِيحُونْ، أَجدْجِيذْ ن حَاشْبُونْ.   
\m
\v 6 مُوسَا، أَمْسخَّارْ ن سِيذِي، أَكْ-ذ أَيْثْ ن إِسْرَائِيل، وْثِينْ ثنْ ؤُ مُوسَا، أَمْسخَّارْ ن سِيذِي، ثُوغَا إِوْشَا \add ثَامُّورْثْ نِّي\add* ذ ڒْوَارْثْ إِ إِرُوبِينِييّنْ ذ إِجَاذِييّنْ ؤُ إِ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا. \x ◘ \xo 12:‏6 \xt ڒخْڒ. 21‏:‏24؛ 32‏:‏33\x*   
\b  
\m
\v 7 إِنَا ذ إِجدْجِيذنْ ن ثمُّورْثْ إِنِّي خْ إِغْڒبْ يَاشُووَا ذ أَيْثْ ن إِسْرَائِيل، غَارْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ ذِي لْغَارْبْ، زِي بَاعْلْ-جَاذْ ذِي ثيْسَارْثْ ن لُوبْنَانْ أَڒْ أَذْرَارْ أَقشَّارْ ونِّي إِسّْڭعّْذنْ غَارْ سَاعِيرْ. ؤُشَا يَاشُووَا إِوْشَا إِ-ت ذ ڒْوَارْثْ إِ ثْقبَّاڒْ ن إِسْرَائِيل عْلَاحْسَابْ ثِيرْبِيعِينْ نْسنْ، \x ◘ \xo 12:‏7 \xt ياش. 10‏:‏40\x*  
\v 8 ذِي ثمُّورْثْ ن إِذُورَارْ ؤُ ذِي ثمُّورْثْ إِوَاطَانْ ؤُ ذِي ڒوْضَا ؤُ ذِي ثيْسَارِينْ ؤُ ذِي ڒخْڒَا ؤُ ذِي \add ثمُّورْثْ ن\add* لْجَانُوبْ: إِحِيتِّييّنْ، إِمُورِييّنْ، أَيْثْ ن كنْعَانْ، إِفَارِيزِييّنْ، إِحِيوِييّنْ ذ إِيابُوسِييّنْ.   
\b  
\m
\v 9 أَجدْجِيذْ ن أَرِيحَا: ذ إِجّْ.  
\m أَجدْجِيذْ ن عَايْ \add إِ إِدْجَانْ\add* غَارْ ؤُغزْذِيسْ ن بَايْثْ-إِلْ: ذ إِجّْ.   
\m
\v 10 أَجدْجِيذْ ن ؤُرْشَالِيمْ: ذ إِجّْ.  
\m أَجدْجِيذْ ن حَابْرُونْ: ذ إِجّْ.   
\m
\v 11 أَجدْجِيذْ ن يَارْمُوثْ: ذ إِجّْ.  
\m أَجدْجِيذْ ن لَاخِيشْ: ذ إِجّْ.   
\m
\v 12 أَجدْجِيذْ ن عَاجْلُونْ: ذ إِجّْ.  
\m أَجدْجِيذْ ن جَازَارْ: ذ إِجّْ.   
\m
\v 13 أَجدْجِيذْ ن ذَابِيرْ: ذ إِجّْ.  
\m أَجدْجِيذْ ن جَاذَارْ: ذ إِجّْ.   
\m
\v 14 أَجدْجِيذْ ن حُورْمَا: ذ إِجّْ.  
\m أَجدْجِيذْ ن عَارَاذْ: ذ إِجّْ.   
\m
\v 15 أَجدْجِيذْ ن لِيبْنَا: ذ إِجّْ.  
\m أَجدْجِيذْ ن عَاذُولَّامْ: ذ إِجّْ.   
\m
\v 16 أَجدْجِيذْ ن مَاقِّيذَا: ذ إِجّْ.  
\m أَجدْجِيذْ ن بَايْثْ-إِلْ: ذ إِجّْ.   
\m
\v 17 أَجدْجِيذْ ن ثَافُّوحْ: ذ إِجّْ.  
\m أَجدْجِيذْ ن حَافَارْ: ذ إِجّْ.   
\m
\v 18 أَجدْجِيذْ ن أَفِيقْ: ذ إِجّْ.  
\m أَجدْجِيذْ ن لَاشَّارُونْ: ذ إِجّْ.   
\m
\v 19 أَجدْجِيذْ ن مَاذُونْ: ذ إِجّْ.  
\m أَجدْجِيذْ ن حَاصُورْ: ذ إِجّْ.   
\m
\v 20 أَجدْجِيذْ ن شِيمْرُونْ-مَارَا‘ؤُنْ: ذ إِجّْ.  
\m أَجدْجِيذْ ن أَكْشَافْ: ذ إِجّْ.   
\m
\v 21 أَجدْجِيذْ ن ثَاعْنَاكْ: ذ إِجّْ.  
\m أَجدْجِيذْ ن مَاجِيدُّو: ذ إِجّْ.   
\m
\v 22 أَجدْجِيذْ ن قَاذَاشْ: ذ إِجّْ.  
\m أَجدْجِيذْ ن يُوقْنَاعَامْ غَارْ كَارْمَالْ: ذ إِجّْ.   
\m
\v 23 أَجدْجِيذْ ن ذُورْ خْ ثِيوْرِيرِينْ غَارْ ذُورْ: ذ إِجّْ.  
\m أَجدْجِيذْ ن جُويِيمْ ذِي جِيلْجَالْ: ذ إِجّْ.   
\m
\v 24 أَجدْجِيذْ ن ثِيرْصَا: ذ إِجّْ.  
\b  
\m مَارَّا إِجدْجِيذنْ-أَ أَقَا أَثنْ ذِي وَاحِيثْ ؤُ-ثْڒَاثِينْ.   
\b  
\b  
\m  
\c 13
\s1 سِيذِي إِسِّيوڒْ أَكْ-ذ يَاشُووَا  
\m
\v 1 ؤُمِي ثُوغَا يَاشُووَا ذ أَوسَّارْ ؤُشَا إِمْغَارْ ذڭْ وُوسَّانْ \add ن ثُوذَارْثْ نّسْ\add*، إِنَّا أَسْ سِيذِي: ”شكْ ثوْسَارذْ ؤُ ثمْغَارذْ ذڭْ وُوسَّانْ ؤُشَا \add عَاذْ\add* ثقِّيمْ أَطَّاسْ ن ثمُّورْثْ مَاحنْذْ أَذْ ت ثكْسِيذْ ذ ڒْوَارْثْ.  
\v 2 ثَا ذ ثَامُّورْثْ إِقِّيمنْ: مَارَّا إِذُووَّارنْ ن إِفِيلِيسْطِينِييّنْ ؤُ مَارَّا \add جّْوَايهْ ن\add* إِجَاشُورِييّنْ،  
\v 3 زڭْ \add يغْزَارْ ن\add* شِيحُورْ نِّي \add إِسِّيزّْڒنْ\add* زَّاثْ إِ وُوذمْ ن مِيصْرَا، أَڒْ أَيْمِيرْ ن عِيقْرُونْ ذِي شَّامَالْ نِّي إِتّْوَاحْسبْ-د \add ذ ثَامُّورْثْ\add* ن أَيْثْ ن كنْعَانْ، \add ذَايسْ\add* خمْسَا ن ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن إِفِيلِيسْطِينِييّنْ، \add إِخْسْ أَذْ يِينِي\add* أَغَازِي ذ أَشْذُوذِي ذ أَشْقَالُونِي، أَجِيتِّي، ذ أَعَاقْرُونِي، ذ إِعَاوِييّنْ،  
\v 4 \add ؤُشَا خنِّي\add* زِي لْجَانُوبْ مَارَّا ثَامُّورْثْ ن أَيْثْ ن كنْعَانْ ذ مُوغَارَا ثنِّي ن إِصِيذُونِييّنْ، أَڒْ أَفِيقْ ؤُ أَڒْ ويْمِيرْ ن إِمُورِييّنْ،  
\v 5 ؤُشَا \add خنِّي\add* ثَامُّورْثْ ن إِجِيبْلِييّنْ ذ مَارَّا لُوبْنَانْ مَانِيسْ إِ د-ثْنقَّارْ ثْفُوشْثْ، زِي بَاعْلْ-جَاذْ سْوَادَّايْ إِ وذْرَارْ ن حِيرْمُونْ أَڒْ مَانِي إِتَّاكّْوَاضْ \add بْنَاذمْ\add* غَارْ حَامَاثْ،  
\v 6 مَارَّا إِنِّي إِزدّْغنْ \add ذِي جّْوَايهْ\add* زڭْ إِذُورَارْ ن لُوبْنَانْ أَڒْ مِيسْرَافُوثْ-مَايِيمْ، مَارَّا إِصِيذُونِييّنْ. نشّْ أَذْ خَاسنْ أَژّْڒغْ زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل. أڭّْ \add مَاشَا\add* ثَامُّورْثْ ذ ڒْوَارْثْ إِ إِسْرَائِيل وَاهَا، أَمْ مَامّشْ ذ أَشْ ؤُمُورغْ.“ *   
\b  
\m  
\s1 ثَاسْغَارْثْ ن رُوبِينْ، ن جَاذْ ؤُ إِ وزْينْ ن ثقْبِيتْشْ ن مَانَاسِّي  
\m
\v 7 ”بْضَا ڒخُّو ثَامُّورْثْ-أَ ذ ڒْوَارْثْ جَارْ ثسْعَا ن ثْقبَّاڒْ ذ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا،  
\v 8 \add إِرْيَازنْ ن مَانَاسَّا\add* نِّي إِكْسِينْ أَكْ-ذ إِرُوبِينِييّنْ ذ إِجَاذِييّنْ ثَاسْغَارْثْ ن ڒْوَارْثْ نْسنْ نِّي إِ ذ أَسنْ إِوْشَا مُوسَا خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ ذِي شَّارْقْ، أَمْ مَامّشْ ذ أَسنْ \add ت\add* إِوْشَا مُوسَا، أَمْسخَّارْ ن سِيذِي:  
\v 9 زِي أَرُوعِيرْ \add إِ إِدْجَانْ\add* خْ ثْمَا ن أَرْنُونْ ذ ثنْذِينْثْ إِ إِدْجَانْ ذِي ڒْوسْطْ ن ثغْزُورْثْ ذ مَارَّا ڒْوَاطَا \add يُوعْڒَانْ\add* زِي مِييْذَابَا أَڒْ ذِيبُونْ، \x ◘ \xo 13:‏9 \xt أَعَوذ. 2‏:‏36\x*  
\v 10 ذ مَارَّا ثِيندَّامْ ن سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ ونِّي ثُوغَا إِحكّْمنْ ذِي حَاشْبُونْ، أَڒْ أَيْمِيرْ ن أَيْثْ ن عَامُّونْ  
\v 11 ؤُڒَا ذ جِيلْعَاذْ ذ ثمُّورْثْ ن إِجَاشُورِييّنْ ذ إِمَاعْكِييّنْ ذ قَاعْ وذْرَارْ ن حِيرْمُونْ ذ مَارَّا بَاشَانْ أَڒْ سَالْخَا،  
\v 12 مَارَّا ثَاڭلْذِيثْ ن عُوجْ، ذِي بَاشَانْ، ونِّي ثُوغَا إِحكّْمنْ ذِي عَاشْثَارُوثْ ذ إِذْرَاعِي. نتَّا ثُوغَا إِقِّيمْ زِي مِينْ إِقِّيمنْ ن إِرَافَاوِييّنْ نِّي ثُوغَا إِوْثَا إِ-ثنْ مُوسَا ؤُشَا يُوژّڒْ خَاسنْ \add زِي ثسْغَارْثْ نْسنْ\add*.  
\v 13 \add مَاشَا\add* أَيْثْ ن إِسْرَائِيل وَارْ ؤُژّْڒنْ خْ أَيْثْ ن إِجَاشُورِييّنْ ذ إِمَاعْكِييّنْ \add زِي ثسْغَارْثْ نْسنْ\add*. جَاشُورْ ذ مَاعْكَاثْ قِّيمنْ زدّْغنْ ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل أَڒْ أَسّْ-أَ.   
\m
\v 14 إِ ثقْبِيتْشْ ن لَاوِي وَاهَا ؤُمِي إِ وَارْ إِوْشِي ثَاسْغَارْثْ. ثِيغَارْصَا ن ثْمسِّي ن سِيذِي، أَربِّي ن إِسْرَائِيل، ذ ثَاسْغَارْثْ نّسْ، أَمْ مَامّشْ ثُوغَا إِ ذ أَسْ إِسِّيوڒْ نتَّا.   
\b  
\m
\v 15 إِوْشَا مُوسَا إِ \bd ثقْبِيتْشْ ن أَيْثْ ن رُوبِينْ\bd* \add ثَاسْغَارْثْ نْسنْ\add*، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.  
\v 16 إِ نِيثْنِي ؤُمِي د-ثكَّارْ ثمُّورْثْ ن أَرُوعِيرْ، ثنِّي إِ إِدْجَانْ غَارْ ثْمَا ن ثغْزَارْثْ ن أَرْنُونْ أَكْ-ذ ثنْذِينْثْ نِّي \add إِدْجَانْ\add* ذِي ڒْوسْطْ ن ثغْزُورْثْ ذ مَارَّا ڒْوَاطَا \add يُوعْڒَانْ\add* أَڒْ مِيذِيبَا.  
\v 17 حَاشْبُونْ ذ مَارَّا ثِيندَّامْ نّسْ نِّي \add إِدْجَانْ\add* خْ ڒْوَاطَا \add يُوعْڒَانْ\add*: ذِيبُونْ، بَامُوثْ-بَاعْلْ ذ بَايْثْ-بَاعْلْ-مَاعُونْ  
\v 18 ذ يَاهْصَا ذ قَاذِيمُوثْ ذ مَايْفَاعَا  
\v 19 ذ قَارْيَاثَايِيمْ ذ سِيبْمَا ذ صَارَاثْ-هَا-شَاحَارْ خْ وذْرَارْ ن ڒوْضَا ن ثغْزُورْثْ، \f ◼ \fr 13:‏19 \ft \+bd ’قِيرْيَاثَايِيمْ‘\+bd* - إِخْسْ أَذْ يِينِي ’ثْنَاينْ ن ثْندَّامْ‘.\f*  
\v 20 ذ بَايْثْ-فَاغُورْ ذ ثِيسَاوْنِينْ ن فِيسْجَا ذ بَايْثْ-يَاشِيمُوثْ،  
\v 21 مَارَّا ثِيندَّامْ خْ ڒْوَاطَا \add يُوعْڒَانْ\add* ذ مَارَّا ثَاڭلْذِيثْ ن سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ، إِنِّي إِ ثُوغَا إِحكّْمنْ ذِي حَاشْبُونْ، إِ خْ إِغْڒبْ مُوسَا، \add أَمْ إِغْڒبْ\add* ؤُڒَا خْ ڒْحُوكَّامْ ن مِيذْيَانْ: أَوِي ذ رَاقَامْ ذ صُورْ ذ حُورْ ذ رَابَاعْ، إِنِّي إِ ذ أَسنْ إِوْشَا صِيهُونْ جّهْذْ أَكِيذسْ، إِمزْذَاغْ ن ثمُّورْثْ.  
\v 22 سنّجْ إِ مَارَّا إِنِّي إِتّْوَانْغنْ ذِي ڭَارَّا، نْغِينْ أَيْثْ ن إِسْرَائِيل عَاوذْ بَالْعَامْ، مِّيسْ ن بَاعُورْ، أَڭزَّانْ، س ڒقْضعْ ن سِّيفْ. \x ◘ \xo 13:‏22 \xt ڒخْڒ. 31‏:‏8\x*  
\v 23 ثُوغَا لْ-ؤُرْذُونْ أَكْ-ذ جّْوَايهْ نّسْ ذ أَيْمِيرْ ن أَيْثْ ن رُوبِينْ أَكْ-ذ ثمُّورْثْ غَارْ ثْمَا نّسْ. ثَا ذ ثَاسْغَارْثْ ن أَيْثْ ن رُوبِينْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، أَكْ-ذ ثْندَّامْ ذ ذْشُورَاثْ نْسنْ. \x ◘ \xo 13:‏23 \xt ڒخْڒ. 34‏:‏14، 15\x*   
\m
\v 24 إِوْشَا مُوسَا إِ \bd ثقْبِيتْشْ ن جَاذْ\bd*، إِ أَيْثْ ن جَاذْ، \add ثَاسْغَارْثْ نْسنْ\add* عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.  
\v 25 إِ نِيثْنِي ؤُمِي د-ثكَّارْ ثمُّورْثْ ن يَاعَازِيرْ ذ مَارَّا ثِيندَّامْ ن جِيلْعَاذْ ذ وزْينْ ن ثمُّورْثْ ن أَيْثْ ن عَامُّونْ أَڒْ أَرُوعِيرْ نِّي \add إِدْجَانْ\add* زَّاثْ إِ وُوذمْ ن رَابَّا،  
\v 26 زِي حَاشْبُونْ أَڒْ رَامَاثْ-مِيصْفَا ذ بُوطُونِيمْ، ؤُ زِي مَاحَانَايِيمْ أَڒْ أَيْمِيرْ ن ذَابِيرْ.  
\v 27 ؤُ ذِي ڒوْضَا ن ثغْزُورْثْ: بَايْثْ-هَارَامْ ذ بَايْثْ-نِيمْرَا ذ سُوكُّوثْ ذ صَافُونْ ذ مِينْ إِقِّيمنْ ن ثْڭلْذِيثْ ن سِيحُونْ، أَجدْجِيذْ ن حَاشْبُونْ، لْ-ؤُرْذُونْ ذ جّْوَايهْ نّسْ أَڒْ أَنڭَّارْ نْ ڒبْحَارْ ن كِينَّارَاثْ خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ غَارْ شَّارْقْ.  
\v 28 ثَا ذ ثَاسْغَارْثْ ن أَيْثْ ن جَاذْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ثِيندَّامْ ذ ذْشُورَاثْ نّسْ.   
\m
\v 29 إِوْشَا مُوسَا إِ \bd وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا\bd* \add ثَاسْغَارْثْ نْسنْ\add*. ثكَّارْ أَسْ-د إِ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.  
\v 30 ثُوغَا ثَامُّورْثْ نْسنْ زِي مَاحَانَايِيمْ: مَارَّا بَاشَانْ، مَارَّا ثَاڭلْذِيثْ ن عُوجْ، أَجدْجِيذْ ن بَاشَانْ، ذ مَارَّا ذْشُورَاثْ ن يَا‘إِرْ نِّي \add إِدْجَانْ\add* ذِي بَاشَانْ، ستِّينْ ن ثْندَّامْ. \x ◘ \xo 13:‏30 \xt ڒخْڒ. 32‏:‏14، أَعَوذ. 3‏:‏4، 14\x*  
\v 31 ذ وزْينْ ن جِيلْعَاذْ ذ عَاشْثَارُوثْ ذ إِذْرِيعِي، ثِيندَّامْ ن ثْڭلْذِيثْ ن عُوجْ ذِي بَاشَانْ، كَّارنْ-د إِ إِحنْجِيرنْ ن مَاخِيرْ، مِّيسْ ن مَانَاسَّا، أَقَا إِ وزْينْ ن إِحنْجِيرنْ ن مَاخِيرْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.  
\v 32 ثِينَا ذ \add جّْوَايهْ\add* إِ ثُوغَا إِبْضَا مُوسَا ذ ڒْوَارْثْ ذِي ڒوْضَاثْ ن مُوآبَ، خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، غَارْ أَرِيحَا، غَارْ شَّارْقْ.   
\m
\v 33 مَاشَا إِ \bd ثقْبِيتْشْ ن لَاوِي\bd* وَارْ ذ أَسْ إِوْشِي مُوسَا شَا ثَاسْغَارْثْ. سِيذِي، أَربِّي ن إِسْرَائِيل ذ ثَاسْغَارْثْ نْسنْ، أَمْ مَامّشْ ثُوغَا أَكِيذْسنْ إِسِّيوڒْ. \x ◘ \xo 13:‏33 \xt ڒخْڒ. 18‏:‏20؛ أَعَوذ. 10‏:‏9؛ 18‏:‏2\x*   
\b  
\b  
\m  
\c 14
\s1 أَبطُّو ن ثمُّورْثْ غَارْ ؤُجمَّاضْ ن يغْزَارْ ن لْ-ؤُرْذُونْ  
\m
\v 1 ثِينَا ذ ثْسقَّارْ إِ طّْفنْ أَيْثْ ن إِسْرَائِيل ذِي ثمُّورْثْ ن كنْعَانْ، ثِينِّي إِ ذ أَسنْ إِبْضَا \add ذ ڒْوَارْثْ\add* ؤُكهَّانْ أَلِيعَازَارْ ذ يَاشُووَا، مِّيسْ ن نُونْ، ذ إِزدْجِيفنْ \add ن ثُوذْرِينْ\add* ن إِبَابَاثنْ ن ثْقبَّاڒْ ن أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 14:‏1 \xt ڒخْڒ. 34‏:‏17\x*  
\v 2 س ثْقدُّوحْثْ \add طّْفنْ\add* مَارَّا ثَاسْغَارْثْ نْسنْ، أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي س ثْسخَّارْثْ ن مُوسَا زِي جِّيهثْ ن ثسْعَا ن ثْقبَّاڒْ ذ وزْينْ ن ثقْبِيتْشْ. \x ◘ \xo 14:‏2 \xt ڒخْڒ. 26‏:‏55\x*  
\v 3 مَاغَارْ مُوسَا ثُوغَا إِوْشَا إِ ثْنَاينْ ن ثْقبَّاڒْ ذ وزْينْ ن ثقْبِيتْشْ إِشْثْ ن ثسْغَارْثْ أَغِيرِينْ إِ لْ-ؤُرْذُونْ، \add مَاشَا\add* إِ إِلَاوِييّنْ وَارْ ذ أَسنْ إِوْشِي شَا ثَاسْغَارْثْ ذِي ڒْوسْطْ نْسنْ.  
\v 4 أَقَا أَيْثْ ن يُوسُوفْ ڭِّينْ ثْنَاينْ ن ثْقبَّاڒْ، مَانَاسَّا ذ إِفْرَايِيمْ، ؤُ إِ إِلَاوِييّنْ وَارْ ذ أَسْ وْشِينْ شَا ثَاسْغَارْثْ ذِي ثمُّورْثْ مَاشَا \add مْغِيرْ\add* ثِيندَّامْ إِ ثْزذِّيغْثْ ذ مِينْ إِدْجَانْ زَّاثْسنْثْ ن دّْمَانِي ن ثَاروْسَا إِ ڒبْهَايمْ ؤُ إِ مِينْ غَارْسنْ إِدْجَانْ. \f ◼ \fr 14:‏4 \ft \+bd ’إِلَاوِييّنْ‘\+bd* - إِخْسْ أَذْ يِينِي ’أَيْثْ ن لَاوِي‘.\f*  
\v 5 أَمْ مَامّشْ ثُوغَا يُومُورْ سِيذِي إِ مُوسَا، أَمُّو إِ ڭِّينْ أَيْثْ ن إِسْرَائِيل ڒَامِي بْضَانْ ثَامُّورْثْ.   
\m
\v 6 \add خنِّي\add* قَارّْبنْ-د أَيْثْ ن يَاهُوذَا غَارْ يَاشُووَا ذِي جِيلْجَالْ. \bd كَالِيبْ\bd*، مِّيسْ ن يَافُونِّي، أَقِينِيزِي، إِنَّا أَسْ: ”شكْ ثسّْنذْ مِينْ خَافِي ذ خَاكْ إِنَّا سِيذِي إِ مُوسَا، أَرْيَازْ ن أَربِّي، ذِي قَاذَاشْ-بَارْنِيعْ. \x ◘ \xo 14:‏6 \xt ڒخْڒ. 14‏:‏24؛ أَعَوذ. 1‏:‏36\x*  
\v 7 نشّْ ڭِّيغْ أَربْعِينْ ن إِسڭّْوُوسَا، ؤُمِي إِ د أَيِي إِسّكّْ مُوسَا، أَمْسخَّارْ ن سِيذِي، زِي قَاذَاشْ-بَارْنِيعْ مَاحنْذْ أَذْ برْڭَاڭغْ ثَامُّورْثْ ؤُ نشّْعقْبغْ غَارسْ، خبَّارغْ أَسْ أَمْ مَامّشْ \add ث\add* ثُوغَا ذڭْ وُوڒْ إِنُو.  
\v 8 \add وَاخَّا أَمنِّي\add* أَيْثْمَا، إِنِّي إِ ثُوغَا أَكِيذِي إِڭعّْذنْ، سّْفسّْينْ ؤُڒْ ن ڒْڭنْسْ، \add مَاشَا\add* نشّْ ثُوغَا ڒبْذَا ضفَّارغْ سِيذِي، أَربِّي إِنُو. \x ◘ \xo 14:‏8 \xt ڒخْڒ. 14‏:‏24\x*  
\v 9 ذڭْ وَاسّْ نِّي إِجُّودْجْ مُوسَا، إِنَّا: ”\add وَايَّاوْ،\add* مَاڒَا ثَامُّورْثْ إِ ذِي ثسَّارْسذْ أَضَارْ نّشْ، وَارْ ثتِّيڒِي إِ شكْ ذ إِحنْجِيرنْ نّشْ ذ ثَاسْغَارْثْ إِ ڒبْذَا، مِينْزِي ثُوغَا شكْ ڒبْذَا ثْضفَّارذْ سِيذِي، أَربِّي إِنُو!“   
\m
\v 10 ڒخُّو، خْزَارْ، سِيذِي إِجَّا أَيِي دَّارغْ، أَمْ مَامّشْ إِسِّيوڒْ. ڒخُّو أَقَا خمْسَا ؤُ-ربْعِينْ ن إِسڭّْوُوسَا زڭْ وَامِي إِسِّيوڒْ سِيذِي غَارْ مُوسَا أَوَاڒْ-أَ، ؤُمِي إِسْرَائِيل يُويُورْ ذِي ڒخْڒَا. ؤُشَا ڒخُّو، أَقَا ذَا، أَمْ مَامّشْ ثتّْوَاڒِيذْ، غَارِي خمْسَا ؤُ-ثْمَانْيِينْ ن إِسڭّْوُوسَا.  
\v 11 نشّْ عَاذْ محْضغْ أَمْ مَامّشْ \add محْضغْ\add* ذڭْ وَاسّْ نِّي ؤُمِي إِ ذ أَيِي د-إِسّكّْ مُوسَا. أَمْ مَامّشْ ثُوغَا جهّْذغْ ذڭْ وُوسَّانْ نِّي، أَمُّو إِ جهّْذغْ عَاوذْ إِضَا إِ ؤُمنْغِي مَاحنْذْ أَذْ فّْغغْ ؤُ أَذْ أَرڭّْوْحغْ. \x ◘ \xo 14:‏11 \xt ڒخْڒ. 27‏:‏17؛ أَعَوذ. 31‏:‏2\x*  
\v 12 ڒخُّو \add خنِّي\add*، أوْشْ أَيِي \add ثَامُّورْثْ-أَ ن\add* إِذُورَارْ إِ خْ إِسِّيوڒْ سِيذِي ذڭْ وَاسّْ نِّي، مَاغَارْ شكْ ثسْڒِيذْ سِيمَانْثْ نّشْ ذڭْ وَاسّْ نِّي، أَقَا أَيْثْ ن إِعَانَاقِييّنْ أَقَا أَثنْ ذِينِّي ؤُڒَا ذ ثِيندَّامْ مْغَارنْثْ ؤُ فَارْينْثْ. أَذْ ثَاغْ أَذْ كِيذِي يِيڒِي سِيذِي، أَذْ أَوْضغْ أَذْ خَاسنْ أَژّْڒغْ أَمْ مَامّشْ إِنَّا سِيذِي.“   
\m
\v 13 \add خنِّي\add* إِبَاركْ إِ-ث يَاشُووَا ؤُشَا إِوْشَا حَابْرُونْ ذ ڒْوَارْثْ إِ كَالِيبْ، مِّيسْ ن يَافُونِّي.  
\v 14 خْ ؤُيَا ثدْجَا \add ثنْذِينْثْ ن\add* حَابْرُونْ ذ ڒْوَارْثْ ن كَالِيبْ، مِّيسْ ن يَافُونِّي، أَقِينِيزِي، أَڒْ أَسّْ-أَ، مِينْزِي نتَّا ثُوغَا ڒبْذَا إِضفَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل.  
\v 15 حَابْرُونْ ثُوغَا قَّارنْ أَسْ زِيشْ ’ثَانْذِينْثْ ن أَرْبَاعْ‘. ثُوغَا \add أَرْبَاعْ\add* ذ أَرْيَازْ ذ أَمقّْرَانْ ذڭْ أَيْثْ ن إِعَانَاقِييّنْ. ؤُشَا ثَامُّورْثْ ثُوغَا ذَايسْ ڒْهُوذْنثْ زڭْ ؤُمنْغِي. \f ◼ \fr 14:‏15 \ft \+bd ’ثَانْذِينْثْ ن أَرْبَاعْ‘\+bd* - نِيغْ ’قَارْيَاثْ-أَرْبَاعْ‘.\f*   
\b  
\b  
\m  
\c 15
\s1 ثَاسْغَارْثْ ن يَاهُوذَا  
\m
\v 1 \bd ثَاقدُّوحْثْ\bd* إِ أَيْثْ ن \bd يَاهُوذَا\bd*، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ثكَّارْ-أَسنْثْ غَارْ ويْمِيرْ ن إِذُومْ، ڒخْڒَا ن صِينْ، غَارْ لْجَانُوبْ، \add أَڒْ\add* لْجَانُوبْ قَاعْ.  
\v 2 \bd أَيْمِيرْ ن لْجَانُوبْ\bd* ثُوغَا-ث إِ نِيثْنِي زِي مَانِيسْ إِقطَّا ڒبْحَارْ أَمدْجَاحْ، زڭْ يِيڒسْ \add ن ؤُقمُّومْ\add* \add ن ڒبْحَارْ\add* إِ د-إِتّفّْغنْ غَارْ لْجَانُوبْ، \x ◘ \xo 15:‏2 \xt ڒخْڒ. 34‏:‏4\x*  
\v 3 ؤُشَا إِعدُّو \add خنِّي\add* غَارْ لْجَانُوبْ ن ثْسُونْثَا ن ثْغَارْضْمِيوِينْ ؤُشَا إِعدُّو غَارْ صِينْ ؤُشَا إِتّْڭعّذْ زِي لْجَانُوبْ ن قَاذَاشْ-بَارْنِيعْ، إِتّكّْ خْ حَاصْرُونْ ؤُ إِتّْڭعَّاذْ غَارْ أَدَّارْ ؤُشَا إِذكّْوَاڒْ غَارْ قَارْقَاعْ  
\v 4 ؤُ \add خنِّي\add* إِتّكّْ خْ عَاصْمُونْ ؤُ إِتّفّغْ غَارْ ثغْزَارْثْ ن مِيصْرَا ؤُشَا طّْرُوفَا ن ويْمِيرْ \add تَّاكّْوَاضنْ\add* أَڒْ ڒبْحَارْ. وَا أَقَا ذ أَيْمِيرْ ن لْجَانُوبْ إِ كنِّيوْ.   
\m
\v 5 \bd أَيْمِيرْ ن شَّارْقْ\bd* أَقَا-ث ذ ڒبْحَارْ أَمدْجَاحْ غَارْ قطُّو ن لْ-ؤُرْذُونْ ؤُ \bd أَيْمِيرْ ن شَّامَالْ\bd* زڭْ يِيڒسْ ن ڒبْحَارْ، زِي مَانِيسْ إِقطَّا لْ-ؤُرْذُونْ  
\v 6 ؤُ \add سّنِّي\add* إِتّْڭعّذْ ويْمِيرْ \add غَارْ\add* بَايْثْ-حُوجْلَا ؤُشَا إِعدُّو غَارْ شَّامَالْ ن بَايْثْ-عَارَابَا ؤُ \add خنِّي\add* إِتّْڭعّذْ أَڒْ وژْرُو ن بُوهَانْ، مِّيسْ ن رُوبِينْ،  
\v 7 ؤُشَا إِتّْڭعّذْ ويْمِيرْ زِي ذَابِيرْ زِي ثغْزُورْثْ ن أَخُورْ ؤُ إِتّنّضْ غَارْ شَّامَالْ غَارْ جِيلْجَالْ ونِّي \add إِدْجَانْ\add* أَجمَّاضْ إِ وبْرِيذْ ن ؤُژكّْوُو خْ إِذُورَارْ ن أَذُومِّيمْ إِ \add إِدْجَانْ\add* غَارْ لْجَانُوبْ ن ثغْزَارْثْ ؤُ \add خنِّي\add* إِعدُّو ويْمِيرْ غَارْ وَامَانْ ن عَايْنْ-شَامْشْ ؤُشَا إِتّفّغْ غَارْ عَايْنْ-رُوجَالْ.  
\v 8 \add زِي سَّا\add* إِتّْڭعّذْ ويْمِيرْ زِي ثغْزُورْثْ ن مِّيسْ ن هِينُّومْ، غَارْ ؤُغزْذِيسْ ن لْجَانُوبْ \add ن وذْرَارْ ن\add* ن ؤُيابُوسِي، أَقَا-ث ذ ؤُرْشَالِيمْ، ؤُ أَيْمِيرْ يَارنِّي إِتّْڭعّذْ غَارْ ثْقِيشَّاثْ ن وذْرَارْ ونِّي إِدْجَانْ غَارْ ڒْغَارْبْ ن ثغْزُورْثْ ن مِّيسْ ن هِينُّومْ ثنِّي إِدْجَانْ غَارْ جِّيهثْ ن شَّامَالْ ن ؤُنڭَّارُو ن ثغْزُورْثْ ن إِرَافَاوِييّنْ.  
\v 9 زِي ثْقِيشَّاثْ ن وذْرَارْ إِمَّارْسْ ويْمِيرْ غَارْ ثَاڒَا ن نفْثُوحَا ؤُ إِعدُّو غَارْ ثْندَّامْ ن إِذُورَارْ ن إِفْرُونْ ؤُ \add خنِّي\add* إِمَّارْسْ ويْمِيرْ غَارْ بَاعَالَا، ثنِّي ذ قَارْيَاثْ-يَاعَارِيمْ.  
\v 10 زِي بَاعَالَا إِتَّاكّْوَاضْ ويْمِيرْ غَارْ ڒْغَارْبْ غَارْ إِذُورَارْ ن سَاعِيرْ ؤُشَا إِعدُّو زِي شَّامَالْ غَارْ ؤُغزْذِيسْ ن وذْرَارْ ن يَاعَارِيمْ، أَقَا-ث ذ كَاسَالُونْ، ؤُشَا إِهكّْوَا غَارْ بَايْثْ-شَامْسْ ؤُ إِتّكّْ خْ ثِيمْنَاهْ.  
\v 11 \add خنِّي\add* إِعدُّو ويْمِيرْ غَارْ ؤُغزْذِيسْ ن شَّامَالْ ن عَاقْرُونْ. \add خنِّي\add* إِمَّارْسْ ويْمِيرْ غَارْ شَاكْرُونْ ؤُ إِتّكّْ خْ ؤُغزْذِيسْ ن وذْرَارْ ن بَاعْلَا ؤُ إِتّفّغْ غَارْ يَابْنِييِيلْ ؤُشَا طّْرُوفَا ن ويْمِيرْ ثَاكّْوَاضنْ أَڒْ ڒبْحَارْ.   
\m
\v 12 \bd أَيْمِيرْ ن ڒْغَارْبْ\bd* \add إِعدُّو\add* أَڒْ ڒبْحَارْ أَمقّْرَانْ ذ ثْمَا \add ن ڒبْحَارْ\add*. وَا ذ أَيْمِيرْ ن أَيْثْ ن يَاهُوذَا زِي مَارَّا إِغزْذِيسنْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ. \x ◘ \xo 15:‏12 \xt ڒخْڒ. 34‏:‏6\x*   
\m
\v 13 \add مَاشَا\add* \bd كَالِيبْ\bd*، مِّيسْ ن يَافُونِّي، إِوْشَا أَسْ إِشْثْ ن ثسْغَارْثْ ذِي ڒْوسْطْ ن أَيْثْ ن يَاهُوذَا، عْلَاحْسَابْ ثَاوْصيّثْ زڭْ ؤُقمُّومْ ن سِيذِي إِ يَاشُووَا، \add أَقَا-ت\add* ذ ثَانْذِينْثْ ن أَرْبَاعْ. \add أَرْبَاعْ\add* ثُوغَا ذ بَابَاسْ ن عَانَاقْ، إِخْسْ أَذْ يِينِي حَابْرُونْ. \x ◘ \xo 15:‏13 \xt ياش. 14‏:‏15؛ ڒقض. 1‏:‏20\x*  
\v 14 يُوژّڒْ كَالِيبْ سّنِّي خْ ثْڒَاثَا ن إِحنْجِيرنْ ن عَانَاقْ: شِيشَايْ، أَخِيمَانْ ؤُ ثَالْمَايْ، \add إِنِّي\add* د-إِتّْوَاخڒْقنْ إِ عَانَاقْ. \x ◘ \xo 15:‏14 \xt ڒقض. 1‏:‏10\x*  
\v 15 سّنِّي إِڭعّذْ غَارْ إِمزْذَاغْ ن ذَابِيرْ. ذَابِيرْ ثُوغَا قَّارنْ أَسْ زِيشْ: ثَانْذِينْثْ ن سِيفْرْ.  
\v 16 إِنَّا كَالِيبْ: ”مَانْ ونْ إِ غَا إِوْثنْ ثَانْذِينْثْ ن سِيفْرْ أَذْ ت إِطّفْ، أَذْ أَسْ وْشغْ يدْجِي أَخْسَا ذ ثَامْغَارْثْ!“  
\v 17 عُوثْنِييِيلْ، مِّيسْ ن قَانَازْ، ؤُمَاسْ ن كَالِيبْ، إِطّفْ إِ-ت ؤُ \add كَالِيبْ\add* إِوْشَا أَسْ يدْجِيسْ أَخْسَا ذ ثَامْغَارْثْ.  
\v 18 إِمْسَارْ ؤُمِي نتَّاثْ ثُوسَا-د غَارْ عُوثْنِييِيلْ، ثَارَّا إِ-ث أَذْ إِتَّارْ إِجّْ ن ييَّارْ خْ بَابَاسْ ؤُشَا ثضْرَا خْ وغْيُوڒْ \add نّسْ\add*. كَالِيبْ إِسّقْسَا ت: ”مِينْ شمْ يُوغِينْ؟“ \f ◼ \fr 15:‏18 \ft \+bd ’بَابَاسْ‘\+bd* - إِخْسْ أَذْ يِينِي ’بَابَاسْ ن ثمْغَارْثْ، كَالِيبْ.‘\f*  \x ◘ \xo 15:‏18 \xt ڒقض. 1‏:‏14\x*  
\v 19 نتَّاثْ ثَارَّا: ”أوْشْ أَيِي إِشْثْ ن لْبَارَاكَا، مَاغَارْ شكْ ثوْشِيذْ أَيِي إِشْثْ ن ثمُّورْثْ ثُوژغْ، \add خنِّي\add* أوْشْ أَيِي ؤُڒَا ذ ڒْعُونْصَارَاثْ ن وَامَانْ!“ ؤُشَا إِوْشَا أَسْ ڒْعُونْصَارَاثْ ن نّجْ ذ ڒْعُونْصَارَاثْ ن وَادَّايْ.   
\m
\v 20 ثَا ذ ثَاسْغَارْثْ ن ثقْبِيتْشْ ن أَيْثْ ن يَاهُوذَا، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.   
\b  
\m
\v 21 \add ثِينَا\add* ثُوغَا ذ \bd ثِيندَّامْ إِڭّْوجنْ\bd* ن ثقْبِيتْشْ ن أَيْثْ ن يَاهُوذَا، غَارْ ويْمِيرْ أَكْ-ذ إِذُومْ ذِي ثمُّورْثْ ن لْجَانُوبْ: قَابْصِييِيلْ ذ عِيذَارْ ذ يَاجُورْ  
\v 22 ذ قِينَا ذ ذِيمُونَا ذ عَاذَاذَا  
\v 23 ذ قَاذَاشْ ذ حَاصُورْ ذ يِيثْنَانْ  
\v 24 ذ زِيفْ ذ طَالَامْ ذ بَاعْلُوثْ  
\v 25 ذ حَاصُورْ-خَاذَاثَا ذ ثْندَّامْ \add ن\add* حَاصْرُونْ، ثَا ذ حَاصُورْ.  
\v 26 \add خنِّي\add* أَمَامْ ذ شَامَاعْ ذ مُولَاذَا  
\v 27 ذ حَاصَا-جَادَّا ذ حَاشْمُونْ ذ بَايْثْ-فَالَاطْ  
\v 28 ذ حَاصَارْ-شُوعَالْ ذ بِئرْ-سبْعَا ذ بِيزْيُوثِييَا  
\v 29 ذ بَاعْلَا ذ عَايِّيمْ ذ عَازَامْ،  
\v 30 ذ أَلْثُولَاذْ ذ كِيسِيلْ ذ حُورْمَا  
\v 31 ذ صِيقْلَاغْ ذ مَاذْمَانَّا ذ سَانْسَانَّا  
\v 32 ذ لَابَايُوثْ ذ شِيلْحِيمْ ذ عَايْنْ ذ رِيمُّونْ. مَارَّا ثِيندَّامْ أَقَا أَثنْثْ ذِي \bd ثسْعَا ؤُ-عِيشْرِينْ\bd* أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\m
\v 33 ذِي ثمُّورْثْ إِوَاطَانْ: إِشْثَاؤُولْ ذ صُورْعَا ذ أَشْنَا  
\v 34 ذ زَانُوخْ ذ عَايْنْ-جَانِّيمْ ذ ثَافُّوحْ ذ عَايْنَامْ،  
\v 35 ذ يَارْمُوثْ ذ أَذُولَّامْ ذ سُوكُو ذ أَزِيقَا  
\v 36 ذ شَاعَارَايِيمْ ذ عَاذِيثَايِيمْ ذ جُوذَايْرَا ذ جُوذَايْرَاثَايِيمْ. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd أَرْبعْطَاشْ\bd* ن ثْندَّامْ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\m
\v 37 صَانَانْ ذ حَاذَاشَا ذ مِيجْذَالْ-جَاذْ  
\v 38 ذ ذِيلَانْ ذ مِيصْفَا ذ يَاقْثِييِيلْ  
\v 39 ذ لَاخِيشْ ذ بُوصْقَاثْ ذ عَاجْلُونْ  
\v 40 ذ كَابُّونْ ذ لَاحْمَاسْ ذ كِيثْلِيشْ  
\v 41 ذ جُوذَايْرُوثْ ذ بَايْثْ-ذَاجُونْ ذ نَاعَامَا ذ مَاقَّاذَا. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd سطَّاشْ\bd* ن ثْندَّامْ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\m
\v 42 لِيبْنَا ذ عَاثِيرْ ذ عَاشَانْ  
\v 43 ذ يَافْثَاحْ ذ أَشْنَا ذ نَاصِيبْ  
\v 44 ذ قَاعِيلَا ذ أَكْسِيبْ ذ مَارِيشَا. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd ثسْعَا\bd* ن ثْندَّامْ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\m
\v 45 عَاقْرُونْ أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ ذ ڒذْشُورْ نّسْ.  
\v 46 زِي عَاقْرُونْ أَڒْ ربْحَارْ، مَارَّا مِينْ إِدْجَانْ غَارْ ؤُغزْذِيسْ ن أَشْذُوذْ أَكْ-ذ ڒذْشُورْ نْسنْ.  
\v 47 أَشْذُوذْ أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ ذ ڒذْشُورْ نّسْ، غَازَّا أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ ذ ڒذْشُورْ نّسْ أَڒْ ثَاغْزَارْثْ ن مِيصْرَا ذ ڒبْحَارْ أَمقّْرَانْ أَكْ-ذ \add ثمُّورْثْ ن\add* ثْمَا \add ن ڒبْحَارْ\add*.   
\m
\v 48 ذِي ثمُّورْثْ ن إِذُورَارْ: شَامِيرْ ذ يَاتِّيرْ ذ سُوكُو  
\v 49 ذ ذَانَّا ذ ثنْذِينْثْ ن سَانَّا، ثَا ذ ذَابِيرْ،  
\v 50 ذ عَانَابْ ذ أَشْثِيمُو ذ عَانِيمْ  
\v 51 ذ جُوشَانْ ذ حُولُونْ ذ جِيلُو. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd حِيطَاشْ\bd* ن ثْندَّامْ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\m
\v 52 أَرَابْ ذ ذُومَا ذ أَشْعَانْ  
\v 53 ذ يَانُومْ ذ بَايْثْ-ثَافُّوحْ ذ أَفِيقَا  
\v 54 ذ حُومْطَا ذ قَارْيَاثْ-أَرْبَاعْ، ثنِّي ذ حَابْرُونْ، ذ صَاعُورْ. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd ثسْعَا\bd* ن ثْندَّامْ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\m
\v 55 مَاعُونْ ذ كَارْمَالْ ذ زِيفْ ذ يُوطَا  
\v 56 ذ يِيزْرَاعِيلْ ذ يُوقْذَاعَامْ ذ زَانُوحْ  
\v 57 ذ قَايِينْ ذ جِيبْعَا ذ ثِيمْنَاهْ. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd عشْرَا\bd* ن ثْندَّامْ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\m
\v 58 حَالْحُولْ ذ بَايْثْ-صُورْ ذ جَاذُورْ  
\v 59 ذ مَاعَارَاثْ ذ بَايْثْ-عَانُوثْ ذ إِلْثَاقُونْ. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd ستَّا\bd* ن ثْندَّامْ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\m
\v 60 قَارْيَاثْ-بَاعْلْ، أَقَا-ث ذ قَارْيَاثْ-يِيعَارِيمْ ذ رَابَّا. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd ثْنَاينْ\bd* ن ثْندَّامْ أَكْ-ذ ڒذْشُورْ نْسنْثْ.  
\v 61 ذِي ڒخْڒَا بَايْثْ-عَارَابَا ذ مِيذِّينْ ذ سَاكَاكَا  
\v 62 ذ نِيبْشَانْ ذ ثنْذِينْثْ ن ؤُمدْجَاحْ ذ عَايْنْ-جَاذِي. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd ستَّا\bd* ن ثْندَّامْ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\m
\v 63 \add مَاشَا\add* أَيْثْ ن يَاهُوذَا وَارْ زمَّارنْ أَذْ أَژّْڒنْ خْ إِيابُوسِييّنْ إِنِّي ذ إِمزْذَاغْ ن ؤُرْشَالِيمْ. \add خْ ؤُينِّي\add* زدّْغنْ إِيابُوسِييّنْ \add عَاذْ\add* أَكْ-ذ أَيْثْ ن يَاهُوذَا ذِي ؤُرْشَالِيمْ أَڒْ أَسّْ-أَ.   
\b  
\b  
\m  
\c 16
\s1 ثَاسْغَارْثْ ن أَيْثْ ن يُوسُوفْ: مَانَاسِّي ذ إِفْرَايِيمْ  
\m
\v 1 \bd ثَاقدُّوحْثْ\bd* إِ أَيْثْ ن \bd يُوسُوفْ\bd* ثكَّارْ أَسْ-د زِي لْ-ؤُرْذُونْ غَارْ أَرِيحَا، \add ؤُشَا أَيْمِيرْ\add* إِتّكّْ خْ ثْمَا ن شَّارْقْ ن وَامَانْ ن أَرِيحَا، \add خْ\add* ڒخْڒَا نِّي د-إِتّْڭعَّاذنْ زِي أَرِيحَا خْ إِذُورَارْ ن بَايْثْ-إِلْ.  
\v 2 ؤُ زِي بَايْثْ-إِلْ إِتّفّغْ غَارْ لُوزْ، إِتّكّْ خْ ثمُّورْثْ ن أَيْثْ ن أَرْكِيثْ غَارْ عَاطَارُوثْ  
\v 3 ؤُشَا إِهكّْوَا-د غَارْ ڒْغَارْبْ غَارْ ثمُّورْثْ ن إِفَالَاطِييّنْ أَڒْ ثَامُّورْثْ ن بَايْثْ-حُورُونْ ن وَادَّايْ ؤُ أَڒْ جَازَارْ ؤُ طّْرُوفَا نّسْ تَّاكّْوَاضنْ أَڒْ ڒبْحَارْ.   
\m
\v 4 \add خنِّي\add* طّْفنْ ؤُڒَا ذ أَيْثْ ن يُوسُوفْ، مَانَاسَّا ذ إِفْرَايِيمْ، ڒْوَارْثْ نْسنْ.  
\v 5 أَيْمِيرْ ن أَيْثْ ن \bd إِفْرَايِيمْ\bd*، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ذ وَا. أَيْمِيرْ ن ثسْغَارْثْ نْسنْ إِبدَّا غَارْ شَّارْقْ ن عَاطَارُوثْ-أَذَارْ \add ؤُشَا إِڭُّورْ\add* أَڒْ بَايْثْ-حُورُونْ ن نّجْ،  
\v 6 ؤُشَا إِڭُّورْ غَارْ ڒْغَارْبْ غَارْ ؤُغزْذِيسْ ن شَّامَالْ ن مِيكْمَاثَا ؤُشَا إِتّفْرِيغْ ويْمِيرْ غَارْ شَّارْقْ غَارْ تَآنَثْ-شِيلُو ؤُ \add خنِّي\add* إِتّكّْ خَاسْ خْ ؤُغزْذِيسْ نّسْ ن شَّارْقْ غَارْ يَانُوحَا،  
\v 7 ؤُ زِي يَانُوحَا إِهكّْوَا غَارْ عَاطَارُوثْ ذ نَاعَارَاثَا ؤُشَا عْڒَاينْ إِنحّذْ أَرِيحَا ؤُ \add خنِّي\add* إِتّفّغْ غَارْ لْ-ؤُرْذُونْ.  
\v 8 زِي ثَافُّوحْ إِعدُّو ويْمِيرْ غَارْ ڒْغَارْبْ غَارْ ثِيغْزَارْثْ ن قَانَا ؤُشَا طّْرُوفَا نّسْ تَّاكّْوَاضنْ أَڒْ ڒبْحَارْ. ثَا ذ ثَاسْغَارْثْ ن ثقْبِيتْشْ ن أَيْثْ ن إِفْرَايِيمْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.   
\m
\v 9 \bd ثِيندَّامْ\bd* إِ إِتّْوَاحُوزنْ إِ أَيْثْ ن إِفْرَايِيمْ أَقَا أَثنْثْ ذِي ڒْوسْطْ ن ثسْغَارْثْ ن مَانَاسَّا، مَارَّا ثِيندَّامْ أَكْ-ذ ڒذْشُورْ نْسنْثْ.  
\v 10 وَارْ ؤُژِّيڒنْ شَا خْ أَيْثْ ن كنْعَانْ نِّي ثُوغَا إِزدّْغنْ ذِي جَازَارْ \add زِي ثسْغَارْثْ نْسنْ\add*. \add أَمُّو\add* زدّْغنْ إِكنْعَانِييّنْ \add عَاذْ\add* ذِي ڒْوسْطْ ن أَيْثْ ن إِفْرَايِيمْ أَڒْ أَسّْ-أَ. ثتّْوَاڭّْ خَاسنْ \add مَاشَا\add* لْجِيزْيَا ن ثْسخَّارْثْ.   
\b  
\b  
\m  
\c 17
\m
\v 1 ثُوغَا ذِينْ \add عَاوذْ\add* إِشْثْ ن \bd ثَاقدُّوحْثْ\bd* إِ ثقْبِيتْشْ ن \bd مَانَاسَّا\bd*، مِينْزِي نتَّا ثُوغَا ذ أَمنْزُو ن يُوسُوفْ، ثكَّارْ أَسْ-د إِ مَاكِيرْ، أَمنْزُو ن مَانَاسَّا، بَابَاسْ ن \add ثمُّورْثْ ن\add* جِيلْعَاذْ، جِيلْعَاذْ ذ بَاشَانْ، مَاغَارْ نتَّا ثُوغَا ذ إِجّْ ن ؤُعسْكَارِي إِمحْضنْ. \x ◘ \xo 17:‏1 \xt أَمز. 46‏:‏20\x*  
\v 2 ثكَّارْ أَسنْ-د ثْقدُّوحْثْ إِ أَيْثْ إِقِّيمنْ ن مَانَاسَّا عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، إِ أَيْثْ ن أَبِيعَازَارْ ذ أَيْثْ ن حَالَاقْ ذ أَيْثْ ن أَسْرِييِيلْ ذ أَيْثْ ن شَاكَامْ ذ أَيْثْ ن حَافَارْ ذ أَيْثْ ن شَامِيذَاعْ. إِنَا ذ أَيْثْ ن مَانَاسَّا، مِّيسْ ن يُوسُوفْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.   
\m
\v 3 ؤُ زلُوحْفَاذْ، مِّيسْ ن حَافَارْ، مِّيسْ ن جِيلْعَاذْ، مِّيسْ ن مَاكِيرْ، مِّيسْ ن مَانَاسَّا، وَارْ غَارسْ ثُوغِي شَا إِحنْجِيرنْ، مَاشَا ثُوغَا غَارسْ يسِّيسْ. إِنَا ذ إِسْمَاونْ ن يسِّيسْ: مَاحْلَا ذ نُوعَا، حُوجْلَا، مِيلْكَا ذ ثِيرْصَا. \x ◘ \xo 17:‏3 \xt ڒخْڒ. 26‏:‏33؛ 27‏:‏1\x*  
\v 4 نِيثنْثِي قَارّْبنْثْ-إِ-د زَّاثْ إِ وُوذمْ ن ؤُكهَّانْ أَلِيعَازَارْ ؤُ زَّاثْ إِ وُوذمْ ن يَاشُووَا، مِّيسْ ن نُونْ، ؤُ زَّاثْ إِ وُوذمْ ن ڒْحُوكَّامْ، نَّانْثْ: ”سِيذِي يُومُورْ مُوسَا، أَذْ أَنغْ إِوْشْ ثَاسْغَارْثْ جَارْ أَيْثْمَاثْنغْ.“ ؤُشَا إِوْشَا أَسنْثْ، عْلَاحْسَابْ ڒُومُورْ ن سِيذِي، إِشْثْ ن ثَاسْغَارْثْ جَارْ وَاوْمَاثنْ ن بَابَاثْسنْثْ. \x ◘ \xo 17:‏4 \xt ڒخْڒ. 27‏:‏7؛ 36‏:‏2\x*   
\m
\v 5 أَمُّو إِ إِوْضَانْ إِفِيڒَانْ \add ن ڒعْبَارْ\add*عشْرَا ن ثْوَاڒَاوِينْ إِ مَانَاسَّا، بْڒَا ثَامُّورْثْ ن جِيلْعَاذْ ذ بَاشَانْ إِ إِدْجَانْ أَغِيرِينْ ن لْ-ؤُرْذُونْ.  
\v 6 مَاغَارْ يسِّيسْ ن مَانَاسَّا طّْفنْثْ ثَاسْغَارْثْ ذِي ڒْوسْطْ ن وَارَّاونْ نّسْ ؤُ ثَامُّورْثْ ن جِيلْعَاذْ ثُوغَا إِ وَارَّاونْ ن مَانَاسَّا إِ إِقِّيمنْ.   
\m
\v 7 أَيْمِيرْ ن مَانَاسَّا إِتّفّغْ زِي أَشِيرْ إِعدُّو غَارْ مِيكْمَاثَا إِ إِدْجَانْ أَجمَّاضْ إِ شَاكِيمْ ؤُ أَيْمِيرْ إِتّفّغْ غَارْ ؤُفُوسِي غَارْ إِمزْذَاغْ ن عَايْنْ-ثَافُّوحْ.  
\v 8 مَانَاسَّا غَارسْ ثَامُّورْثْ ن ثَافُّوحْ، مَاشَا ثَافُّوحْ \add سِيمَانْثْ نّسْ\add* \add نِّي\add* إِدْجَانْ خْ ويْمِيرْ أَكْ-ذ مَانَاسَّا، ثُوغَا إِ أَيْثْ ن إِفْرَايِيمْ.  
\v 9 \add خنِّي\add* إِهكّْوَا ويْمِيرْ غَارْ ثغْزَارْثْ ن قَانَا غَارْ لْجَانُوبْ ن ثغْزَارْثْ. ثِيندَّامْ ن إِفْرَايِيمْ أَقَا-ثنْثْ ذِينْ جَارْ ثْندَّامْ ن مَانَاسَّا. ثَامُّورْثْ ن مَانَاسَّا ثدْجَا غَارْ ثْمَا ن شَّامَالْ ن إِغْزَارْ ؤُشَا طّْرُوفَا نّسْ تَّاكّْوَاضنْ أَڒْ ڒبْحَارْ.  
\v 10 لْجَانُوبْ أَقَا ن إِفْرَايِيمْ، شَّامَالْ أَقَا ن مَانَاسَّا ؤُ ڒبْحَارْ ذ أَيْمِيرْ نّسْ. ذِي شَّامَالْ تّنْحَاذَانْ خْ أَشِيرْ ؤُ ذِي شَّارْقْ خْ إِسَّاكَارْ.  
\v 11 ذِي إِسَّاكَارْ ؤُ ذِي أَشِيرْ ذوْڒنْ إِنَا غَارْ مَانَاسَّا: بَايْثْ-شَانْ أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ ؤُ يَابْلَاعَامْ أَكْ-ذ ثْندَّامْ نّسْ ذ إِمزْذَاغْ ن ذُورْ أَكْ-ذ ثْندَّامْ نّسْ ذ إِمزْذَاغْ ن عَايْنْ-ذُورْ أَكْ-ذ ثْندَّامْ نّسْ ذ إِمزْذَاغْ ن ثَاعْنَاكْ أَكْ-ذ ثْندَّامْ نّسْ ذ إِمزْذَاغْ ن مَاجِيدُّو أَكْ-ذ ثْندَّامْ نّسْ، ثْڒَاثَا ن ثْرقِّيعِينْ ؤُيْڒنْثْ.  
\v 12 أَيْثْ ن مَانَاسَّا وَارْ زمَّارنْ أَذْ \add زَّايْسنْ\add* طّْفنْ ثِيندَّامْ-أَ \add ذ ثسْغَارْثْ ن ڒْوَارْثْ\add*، مِينْزِي أَيْثْ ن كنْعَانْ ڭِّينْ \add أَذْ قِّيمنْ\add* زدّْغنْ ذِي ثمُّورْثْ. \x ◘ \xo 17:‏12 \xt ڒقض. 1‏:‏27\x*  
\v 13 ؤُمِي أَيْثْ ن إِسْرَائِيل ذوْڒنْ جهْذنْ، ڭِّينْ نِيثْنِي لْجِيزْيَا خْ أَيْثْ ن كنْعَانْ، \add مَاشَا\add* وَارْ خَاسنْ ؤُژّْڒنْ قَاعْ.  
\v 14 سِّيوْڒنْ أَيْثْ ن يُوسُوفْ أَكْ-ذ يَاشُووَا، نَّانْ: ”مَايمِّي ذ أَيِي ثوْشِيذْ ذ ثَاسْغَارْثْ مْغِيرْ إِشْثْ ن ثْقدُّوحْثْ ذ يِيجّْ ن ؤُفِيڒُو \add ن ڒعْبَارْ\add*، وَاخَّا نشّْ ذ إِجّْ ن ڒْڭنْسْ ذ أَمقّْرَانْ، أَوَارْنِي إِ ؤُمِي ذ أَيِي إِڭَّا سِيذِي لْبَارَاكَا أَمُّو؟“  
\v 15 يَاشُووَا إِنَّا أَسنْ: ”مَاڒَا شكْ \add خنِّي\add* ذ إِجّْ ن ڒْڭنْسْ أَمقّْرَانْ، ڭعّذْ \add خنِّي\add* غَارْ وزْغَارْ ؤُشَا زْذمْ ذِينِّي تَّاسِيعْ إِ يِيخفْ نّشْ ذِي ثمُّورْثْ ن إِفِيرِيزِييّنْ ذ إِرَافَاوِييّنْ، مَاڒَا حْصَارنْ خَاكْ إِذُورَارْ ن إِفْرَايِيمْ.“ \f ◼ \fr 17:‏15 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  
\v 16 \add خنِّي\add* نَّانْ أَيْثْ ن يُوسُوفْ: ”إِذُورَارْ نِّي وَارْ ذ أَنغْ تّْقِيذِّينْ. مَارَّا أَيْثْ ن كنْعَانْ نِّي إِزدّْغنْ ذِي ثمُّورْثْ ن ڒوْضَا ن ثغْزُورْثْ غَارْسنْ إِكَارُّوثنْ ن ؤُمنْغِي ن وُوزَّاڒْ، أَمْ يِينِّي \add إِزدّْغنْ\add* ذِي بَايْثْ-شَانْ أَكْ-ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ ؤُ أَمْ يِينِّي ذِي ڒوْضَا ن ثغْزُورْثْ ن يَازْرَاعِيلْ.“  
\v 17 إِسِّيوڒْ يَاشُووَا أَكْ-ذ ثَادَّارْثْ ن يُوسُوفْ، أَكْ-ذ إِفْرَايِيمْ ذ مَانَاسَّا، إِنَّا: ”كنِّيوْ ذ إِجّْ ن ڒْڭنْسْ ذ أَمقّْرَانْ ؤُ غَارْومْ جّهْذْ أَمقّْرَانْ. كنِّيوْ وَارْ ثتّطّْفمْ مْغِيرْ إِشْثْ ن ثْقدُّوحْثْ،  
\v 18 مَاغَارْ ؤُڒَا ذ إِذُورَارْ أَذْ إِڒِينْ نْومْ ؤُشَا ؤُمِي \add ثدْجَا\add* ذ أَزْغَارْ، إِتّْخصَّا أَذْ ثْزذْممْ ؤُشَا طّْرُوفَا نّسْ أَذْ إِڒِينْ إِ كنِّيوْ، مَاغَارْ أَذْ ثَاژّْڒمْ خْ أَيْثْ ن كنْعَانْ \add زِي ثسْغَارْثْ نْسنْ\add*، وَاخَّا غَارْسنْ إِكَارُّوثنْ ن ؤُمنْغِي ن وُوزَّاڒْ ؤُ وَاخَّا نِيثْنِي جهْذنْ.“   
\b  
\b  
\m  
\c 18
\s1 ثَازذِّيغْثْ ذ وَاڭْرَاوْ ن ڒْڭنْسْ ذِي شِيلُو  
\m
\v 1 مَارَّا ثَامسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل ثْمُونْ ذِي شِيلُو ؤُشَا ذِينِّي إِ وْثِينْ أَقِيضُونْ ن ؤُمْسَاڭَارْ، \add أَوَارْنِي\add* ؤُمِي سّْوَاضْعنْ ثَامُّورْثْ إِ يِيخفْ نْسنْ.  
\v 2 ثُوغَا قِّيمنْثْ جَارْ أَيْثْ ن إِسْرَائِيل سبْعَا ن ثْقبَّاڒْ، ثِينِّي ثُوغَا وَارْ ذ أَسنْثْ إِمّوْشنْ \add عَاذْ\add* ذ ثَاسْغَارْثْ نْسنْثْ.   
\m
\v 3 إِنَّا يَاشُووَا إِ أَيْثْ ن إِسْرَائِيل: ”أَڒْ مڒْمِي تّْرَاجَامْ \add عَاذْ\add* أَڒْ غَا ثَاذْفمْ أَذْ ثطّْفمْ ثَامُّورْثْ إِ ذ أَومْ إِوْشَا سِيذِي، أَربِّي ن ڒجْذُوذْ نْومْ، \add ذ ڒْوَارْثْ\add*؟  
\v 4 كْسِيمْ إِ يِيخفْ نْومْ ثْڒَاثَا ن يرْيَازنْ زِي كُوڒْ ثَاقْبِيتْشْ، حِيمَا نشّْ أَذْ ثنْ سّكّغْ ؤُشَا نِيثْنِي أَذْ كَّارنْ أَذْ كّنْ خْ ثمُّورْثْ ؤُشَا أَذْ ت زمّنْ زِي جِّيهثْ مَامّشْ إِتّْخصَّا أَذْ ثِيڒِي ثسْغَارْثْ نْسنْ، \add خنِّي\add* أَذْ غَارِي د -عقْبنْ.  
\v 5 أَذْ ت بْضَانْ خْ سبْعَا ن ثْسقَّارْ. يَاهُوذَا أَذْ إِقِّيمْ خْ ثمُّورْثْ نّسْ ذِي لْجَانُوبْ ؤُ ثَادَّارْثْ ن يُوسُوفْ أَذْ ثقِّيمْ خْ ثمُّورْثْ نّسْ ذِي شَّامَالْ.  
\v 6 كنِّيوْ أَذْ ثْزمّمْ ثَامُّورْثْ خْ سبْعَا ن ثْسقَّارْ ؤُشَا إِزمَّاننْ نِّي أَذْ أَيِي ثنْ د-ثَاوْيمْ ذَانِيثَا، \add خنِّي\add* نشّْ أَذْ أَومْ نْضَارغْ ثَاقدُّوحْثْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّغْ.  
\v 7 مِينْزِي إِلَاوِييّنْ وَارْ غَارْسنْ بُو ثَاسْغَارْثْ ذِي ڒْوسْثْ نْومْ، مِينْزِي ثُوكهَّانْثْ ن سِيذِي ذ ثَاسْغَارْثْ نْسنْ. جَاذْ ذ رُوبِينْ ذ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا طّْفنْ ثَاسْغَارْثْ نْسنْ خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، غَارْ شَّارْقْ، \add ثَاسْغَارْثْ\add* نِّي إِ ذ أَسنْ إِوْشَا مُوسَا، أَمْسخَّارْ ن سِيذِي.   
\m
\v 8 كَّارنْ إِرْيَازنْ ؤُشَا طّْفنْ أَبْرِيذْ. يُومُورْ يَاشُووَا إِ يِينِّي إِطّْفنْ أَبْرِيذْ مَاحنْذْ أَذْ زمّنْ ثَامُّورْثْ س ثِيرَا، إِنَّا: ”ؤُيُورمْ، تّكّمْ خْ ثمُّورْثْ ؤُشَا زمّممْ ت. \add خنِّي\add*عقْبتِّيوْ-د غَارِي ؤُ نشّْ أَذْ أَومْ ذَا نْضَارغْ ثَاقدُّوحْثْ ذِي شِيلُو زَّاثْ إِ وُوذمْ ن سِيذِي.“  
\v 9 إِرْيَازنْ طّْفنْ أَبْرِيذْ، شُوقنْ ثَامُّورْثْ ؤُشَا زمّنْ ت ذڭْ إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ، \add ستّْفنْ ت\add* عْلَاحْسَابْ ثِيندَّامْ، عْلَاحْسَابْ سبْعَا ن ثْسقَّارْ، ؤُشَاعقْبنْ غَارْ يَاشُووَا ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ ذِي شِيلُو.  
\v 10 \add خنِّي\add* إِنْضَارْ يَاشُووَا ثَاقدُّوحْثْ زَّاثْ إِ وُوذمْ ن سِيذِي. ذِينْ إِ ذ أَسنْ إِبْضَا يَاشُووَا ثَامُّورْثْ جَارْ أَيْثْ ن إِسْرَائِيل، عْلَاحْسَابْ ثِيرْبِيعِينْ نْسنْ.   
\b  
\m  
\s1 ثَاسْغَارْثْ ن بِينْيَامِينْ  
\m
\v 11 \bd ثَاقدُّوحْثْ\bd* ن ثقْبِيتْشْ ن \bd بِينْيَامِينْ\bd* ثضْهَارْ-د عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ؤُ ثَاسْغَارْثْ ن ثْقدُّوحْثْ نْسنْ ثُوسَا-د جَارْ أَيْثْ ن يَاهُوذَا ذ أَيْثْ ن يُوسُوفْ.   
\m
\v 12 إِتّفّغْ ويْمِيرْ نْسنْ غَارْ ؤُغزْذِيسْ ن شَّامَالْ زِي لْ-ؤُرْذُونْ ؤُشَا إِتّْڭعَّاذْ غَارْ وعْرُورْ ن شَّامَالْ ن أَرِيحَا، إِعدُّو \add خنِّي\add* غَارْ ڒْغَارْبْ إِتّكّْ خْ إِذُورَارْ ؤُشَا طّْرُوفَا نّسْ تَّاكّْوَاضنْ أَڒْ ڒخْڒَا ن بَايْثْ-أَوَانْ. \x ◘ \xo 18:‏12 \xt ياش. 7‏:‏2\x*  
\v 13 سّنِّي إِژكّْوَا ويْمِيرْ غَارْ لُوزْ خْ وعْرُورْ ن لْجَانُوبْ ن لُوزْ، وَا ذ بَايْثْ-إِلْ، ؤُشَا \add خنِّي\add* إِهكّْوَا-د غَارْ عَاطَارُوثْ خْ وذْرَارْ \add إِ إِدْجَانْ\add* غَارْ لْجَانُوبْ ن بَايْثْ-حُورُونْ ن وَادَّايْ.   
\m
\v 14 أَيْمِيرْ إِعدُّو ؤُشَا إِتّْميّڒْ جِّيهثْ ن ڒْغَارْبْ، \add خنِّي\add* غَارْ لْجَانُوبْ زڭْ وذْرَارْ \add إِ إِدْجَانْ\add* أَرنْذَاذْ ن بَايْثْ-حُورُونْ، \add خنِّي\add* يَارنِّي إِڭُّورْ غَارْ لْجَانُوبْ ؤُشَا طّْرُوفَا نّسْ تَّاكّْوَاضنْ أَڒْ قَارْيَاثْ-بَاعْلَا، ثَا ذ قَارْيَاثْ-يَاعَارِيمْ، إِشْثْ ن ثنْذِينْثْ ن أَيْثْ ن يَاهُوذَا. وَا ذ أَغزْذِيسْ ن ڒْغَارْبْ.   
\m
\v 15 أَغزْذِيسْ ن لْجَانُوبْ \add إِتّفّغْ\add* زِي طَّارْفْ أَنڭَّارْ ن قَارْيَاثْ-يَاعَارِيمْ. إِبدَّا ويْمِيرْ زِي ڒْغَارْبْ ؤُ إِتَّاكّْوَاضْ غَارْ ثَاڒَا ن وَامَانْ ن نَافْثُوحَا.  
\v 16 \add خنِّي\add* إِهكّْوَا-د ويْمِيرْ غَارْ طَّارْفْ ن وذْرَارْ إِ زِي ثتّْوَاڒِيذْ ثَاغْزُورْثْ ن مِّيسْ ن هِينُّومْ نِّي إِدْجَانْ غَارْ طَّارْفْ ن شَّامَالْ ن ثغْزُورْثْ ن إِرَافَاوِييّنْ ؤُشَا \add خنِّي\add* إِهكّْوَا-د خْ ثغْزُورْثْ ن هِينُّومْ غَارْ ؤُغزْذِيسْ ن لْجَانُوبْ ن \add وذْرَارْ ن\add* إِيابُوسِييّنْ ؤُشَا إِهكّْوَا-د غَارْ ثَاڒَا ن رُوجِيلْ.\x ◘ \xo 18:‏16 \xt ياش. 15‏:‏8، 7\x*  
\v 17 ؤُشَا إِتّكّْ خْ شَّامَالْ ؤُشَا إِتَّاكّْوَاضْ غَارْ عَايْنْ-شَامْشْ ؤُشَا إِعدُّو غَارْ جَالِيلُوثْ، نِّي \add إِدْجَانْ\add* أَرنْذَاذْ ن وبْرِيذْ ن ؤُژكّْوُو خْ إِذُورَارْ ن أَذُومِّيمْ ؤُشَا إِهكّْوَا-د غَارْ وژْرُو ن بُوهَانْ، مِّيسْ ن رُوبِينْ، \x ◘ \xo 18:‏17 \xt ياش. 15‏:‏6\x*  
\v 18 ؤُ إِژكّْوَا غَارْ ڒْڭعّْذثْ نِّي \add إِدْجَانْ\add* غَارْ شَّامَالْ أَرنْذَاذْ ن ڒوْضَا ؤُشَا \add خنِّي\add* إِهكّْوَا ذِي ڒوْضَا.  
\v 19 \add خنِّي\add* إِعدُّو ويْمِيرْ غَارْ شَّامَالْ غَارْ ڒْڭعّْذثْ ن بَايْثْ-حُوجْلَا ؤُ طّْرُوفَا نّسْ أَقَا أَثنْ غَارْ إِڒسْ ن شَّامَالْ ن ڒبْحَارْ أَمدْجَاحْ، غَارْ ؤُنڭَّارْ ن لْ-ؤُرْذُونْ ذِي لْجَانُوبْ. وَا ذ أَيْمِيرْ ن لْجَانُوبْ.   
\m
\v 20 لْ-ؤُرْذُونْ ثُوغَا ذ أَيْمِيرْ نّسْ خْ ؤُغزْذِيسْ ن شَّارْقْ. ثَا ذ ثَاسْغَارْثْ ن أَيْثْ ن بِينْيَامِينْ عْلَاحْسَابْ إِيْمِيرنْ نّسْ إِ ذ أَسْ إِقُووَّارنْ، عْلَاحَاسَابْ ڒَادْجَاثْ نْسنْ.   
\b  
\m
\v 21 ثِيندَّامْ ن ثقْبِيتْشْ ن أَيْثْ ن بِينْيَامِينْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ ذ ثِينَا: أَرِيحَا ذ بَايْثْ-حُوجْلَا ذ عِيمَاقْ-قِيصِيصْ  
\v 22 ذ بَايْثْ-عَارَابَا ذ صَامَارَايِيمْ ذ بَايْثْ-إِلْ  
\v 23 ذ إِعَاوِييّنْ ذ هَا-فَارَا ذ عُوفْرَا،  
\v 24 ذ كَافَارْ-عَامُّونِي ذ هَا-عُوفْنِي ذ جَابَاعْ. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd ثنْعَاشْ ن ثْندَّامْ\bd* أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\m
\v 25 جِيبْعُونْ ذ رَامَا ذ بِيعْرُوثْ  
\v 26 ذ مِيصْفَا ذ كَافِيرَا ذ مُوصَا  
\v 27 ذ رَاقَامْ ذ يَارَافْوِيلْ ذ ثَارَالَا  
\v 28 ذ صَالَاعْ ذ أَلَافْ ذ أَيابُوسِي، ونِّي ذ ؤُرْشَالِيمْ، ذ جِيبْعَا ذ قَارْيَاثْ. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd أَرْبعْطَاشْ ن ثْندَّامْ\bd* أَكْ-ذ ڒذْشُورْ نْسنْثْ. ثَا ذ ثَاسْغَارْثْ ن أَيْثْ ن بِينْيَامِينْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.   
\b  
\b  
\m  
\c 19
\s1 خْ ستَّا ن ثْسقَّارْ نّغْنِي  
\m
\v 1 \bd ثَاقدُّوحْثْ وِيسّْ ثْنَاينْ\bd* ثكَّارْ أَسْ-د إِ \bd شِيمْعُونْ\bd*، إِ ثقْبِيتْشْ ن شِيمْعُونْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ. ثَاسْغَارْثْ نْسنْ ثدْجَا ذِي ڒْوسْثْ ن ثسْغَارْثْ ن أَيْثْ ن يَاهُوذَا.  
\v 2 ذِي ثسْغَارْثْ نْسنْ ذوْڒنْثْ غَارْسنْ \add ثْندَّامْ-أَ\add*: بِئرْ-سبْعَا ذ شَابْعَا ذ مُولَاذَا  
\v 3 ذ حَاصَارْ-شُوعَالْ ذ بَاعْلَا ذ عَاصَامْ  
\v 4 ذ إِلْثُولَاذْ ذ بَاثُولْ ذ حُورْمَا  
\v 5 ذ صِيقْلَاغْ ذ بَايْثْ-مَارْكابُوثْ ذ حَاصَارْ-سُوسَا  
\v 6 ذ بَايْثْ-لَابَاوُوثْ ذ شَارُوحَايْنْ. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd ثْڒطَّاشْ ن ثْندَّامْ\bd* أَكْ-ذ ڒذْشُورْ نْسنْثْ.  
\v 7 \add خنِّي\add* عَايْنْ ذ رِيمُّونْ ذ عَاثَارْ ذ عَاشَانْ. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd أَربْعَا ن ثْندَّامْ\bd* أَكْ-ذ ڒذْشُورْ نْسنْثْ،  
\v 8 ؤُڒَا ذ مَارَّا ڒذْشُورْ إِ د-إِتّنّْضنْ إِ ثْندَّامْ-أَ أَڒْ بَاعْلَاثْ-بِي‘رْ، ثنِّي ذ رَامَا ن لْجَانُوبْ. ثَا ذ ثَاسْغَارْثْ ن ثقْبِيتْشْ ن أَيْثْ ن شِيمْعُونْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.   
\m
\v 9 ثَاسْغَارْثْ ن أَيْثْ ن شِيمْعُونْ ثُوغَا \add ثتّْوَاكْسِي\add* زِي \add مِينْعبَّارنْ س\add* ؤُفِيڒُو \add ن ڒعْبَارْ\add* إِ أَيْثْ ن يَاهُوذَا، مِينْزِي ثَاسْغَارْثْ ن أَيْثْ ن يَاهُوذَا ثُوغَا-ت إِ إِنَا ذ ثَامقّْرَانْثْ أَطَّاسْ. \add خْ ؤُينِّي\add* وَارْثنْ أَيْثْ ن شِيمْعُونْ إِشْثْ ن ثسْغَارْثْ ذِي ثسْغَارْثْ نْسنْ.   
\b  
\m
\v 10 \bd ثَاقدُّوحْثْ وِيسّْ ثْڒَاثَا\bd* ثضْهَارْ-د إِ أَيْثْ ن \bd زابُولُونْ\bd*، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ. أَيْمِيرْ ن ثسْغَارْثْ نْسنْ إِعدُّو أَڒْ سَارِيذْ.  
\v 11 إِتّْڭعّذْ ويْمِيرْ نْسنْ غَارْ ڒْغَارْبْ ؤُ \add غَارْ\add* مَارْعَالَا ؤُشَا إِتَّاكّْوَاضْ أَڒْ ذَابَّاشَا ؤُ أَڒْ ثِيغْزَارْثْ نِّي إِسِّيزّْڒنْ زَّاثْ إِ يُوكْنَاعَامْ.  
\v 12 زِي سَارِيذْ إِتّْميّڒْ ويْمِيرْ غَارْ شَّارْقْ، غَارْ مَانِيسْ ذ ثْنقَّارْ ثْفُوشْثْ، أَڒْ ويْمِيرْ ن كِيسْلُوثْ-ثابُورْ ؤُشَا إِتّفّغْ غَارْ ذُوبْرَا ؤُ إِتّْڭعّذْ غَارْ يَافِيعْ.  
\v 13 سّنِّي إِعدُّو غَارْ شَّارْقْ، غَارْ مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ، غَارْ جَاثْ-حَافَارْ ؤُ غَارْ عِيثْ-قَاصِينْ ؤُ إِتّفّغْ غَارْ رِيمُّونْ، إِتّفْرِيغْ \add خنِّي غَارْ\add* نَايْعَا.  
\v 14 إِتّفْرِيغْ ويْمِيرْ زِي شَّامَالْ غَارْ حَانَّاثُونْ ؤُ طّْرُوفَا نّسْ تَّاكّْوَاضنْ أَڒْ ثغْزُورْثْ ن جِيفْثَاحْ-إِلْ.  
\v 15 \add خنِّي\add* قَاطَّا ذ نَاهْلَالْ ذ شِيمْرُونْ ذ يَاذَالَا ذ بَايْثْ-لَاحْمْ. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd ثنْعَاشْ ن ثْندَّامْ\bd* أَكْ-ذ ڒذْشُورْ نْسنْثْ.  
\v 16 ثَا ذ ثَاسْغَارْثْ ن أَيْثْ ن زابُولُونْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ثِيندَّامْ-أَ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\b  
\m
\v 17 \bd ثَاقدُّوحْثْ وِيسّْ أَربْعَا\bd* ثكَّارْ أَسْ-د إِ \bd إِسَّاكَارْ\bd*، إِ أَيْثْ ن إِسَّاكَارْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.  
\v 18 إِعدُّو ويْمِيرْ نْسنْ غَارْ يَازْرَاعِيلْ ذ كِيسْلُوثْ ذ شُونَامْ  
\v 19 ذ حَافَارَايِيمْ ذ شِييُونْ ذ أَنَاحَارَا  
\v 20 ذ رَابِّيثْ ذ قِيشْيُونْ ذ أَبَاصْ  
\v 21 ذ رَامَا ذ عَايْنْ-جَانِّيمْ ذ عَايْنْ-حَادَّا ذ بَايْثْ-قَاصَّايْسْ.  
\v 22 إِتَّاكّْوَاضْ ويْمِيرْ أَڒْ ثابُورْ ذ شَاحْصِيمَا ذ بَايْثْ-شَامْسْ ؤُ طّْرُوفَا ن ويْمِيرْ تَّاكّْوَاضنْ أَڒْ لْ-ؤُرْذُونْ. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd سطَّاشْ ن ثْندَّامْ\bd* أَكْ-ذ ڒذْشُورْ نْسنْثْ.  
\v 23 ثَا ذ ثَاسْغَارْثْ ن أَيْثْ ن إِسَّاكَارْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ثِيندَّامْ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\b  
\m
\v 24 \bd ثَاقدُّوحْثْ وِيسّْ خمْسَا\bd* ثكَّارْ أَسْ-د إِ ثقْبِيتْشْ ن أَيْثْ ن \bd أَشِيرْ\bd*، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.  
\v 25 أَيْمِيرْ نْسنْ أَقَا-ث ذ حَالْقَا ذ حَالِي ذ بَاطَانْ ذ أَكْشَافْ  
\v 26 ذ أَلَّامَّالَاكْ ذ أَمْعَاذْ ذ مِيشْ-أَلْ، ؤُشَا إِتَّاكّْوَاضْ أَڒْ \add وذْرَارْ ن\add* كَارْمِيلْ ذِي ڒْغَارْبْ ؤُ أَڒْ شِيخُورْ-لِيبْنَا.  
\v 27 إِتّْميّڒْ ويْمِيرْ غَارْ مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ غَارْ بَايْثْ-ذَاجُونْ ؤُشَا إِتَّاكّْوَاضْ أَڒْ زابُولُونْ ذ ثغْزُورْثْ ن يِيفْثَاحْ-إِلْ غَارْ شَّامَالْ، \add خنِّي أَڒْ\add* بَايْثْ-عَامِيقْ ذ نَاعِييِيلْ، ؤُشَا إِتّفّغْ خْ ؤُزڒْمَاضْ ن كابُولْ  
\v 28 ؤُشَا \add إِعدُّو غَارْ\add* عَابْرُونْ ذ رَاحُوبْ ذ حَامُّونْ ذ قَانَا أَڒْ صِيذُونْ أَمقّْرَانْ.  
\v 29 إِتّْميّڒْ ويْمِيرْ غَارْ رَامَا إِڭُّورْ أَڒْ ثَانْذِينْثْ ن صُورْ إِ إِفَارْينْ ؤُ \add خنِّي\add* إِتّْميّڒْ ويْمِيرْ غَارْ حُوصَا ؤُ طّْرُوفَا نّسْ تَّاكّْوَاضنْ أَڒْ ڒبْحَارْ، زِي حِيبْلْ أَڒْ أَكْزِيبْ  
\v 30 ذ عُومَّا ذ أَفِيقْ ذ رَاحُوبْ. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd ثْنَاينْ ؤُ-عِيشْرِينْ ن ثْندَّامْ\bd* أَكْ-ذ ڒذْشُورْ نْسنْثْ.  
\v 31 ثَا ذ ثَاسْغَارْثْ ن ثقْبِيتْشْ ن أَيْثْ ن أَشِيرْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ثِيندَّامْ-أَ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\b  
\m
\v 32 \bd ثَاقدُّوحْثْ وِيسّْ ستَّا\bd* ثكَّارْ أَسْ-د إِ أَيْثْ ن \bd نَافْثَالِي\bd*، إِ أَيْثْ ن نَافْثَالِي، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.  
\v 33 إِعدُّو ويْمِيرْ نْسنْ زِي حَالَافْ، زِي ثْشجَّارْثْ ن يِيڭّْ ذِي صَاعَانَايِيمْ، ذ أَذَامِي-نَاقِيبْ ذ يَابْنِييِيلْ أَڒْ لَاقُّومْ ؤُشَا طّْرُوفَا نّسْ تَّاكّْوَاضنْ أَڒْ لْ-ؤُرْذُونْ.  
\v 34 إِتّْميّڒْ ويْمِيرْ غَارْ ڒْغَارْبْ غَارْ أَزْنُوثْ-ثابُورْ ؤُ سّنِّي إِعدُّو غَارْ حُوقُوقْ ؤُ إِتَّاكّْوَاضْ أَڒْ زابُولُونْ ذِي لْجَانُوبْ ؤُ ذِي ڒْغَارْبْ إِسُّوفُّوغْ أَڒْ أَشِيرْ ؤُ ذِي شَّارْقْ أَڒْ يَاهُوذَا \add غَارْ\add* لْ-ؤُرْذُونْ.  
\v 35 ثِيندَّامْ إِفَارْينْ أَقَا أَثنْثْ صِيذِّيمْ ذ صَايْرْ ذ حَامَّاثْ ذ رَاقَّاثْ ذ كِينَّارَاثْ  
\v 36 ذ أَذَامَا ذ رَامَا ذ حَاصُورْ  
\v 37 ذ قَاذَاشْ ذ إِذْڒَاعِي ذ عَايْنْ-حَاصُورْ  
\v 38 ذ يِيرُونْ ذ مِيجْذَالْ-إِلْ ذ حُورِيمْ ذ بَايْثْ-عَانَاثْ ذ بَايْثْ-شَامْسْ. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd ثْسعْطَاشْ ن ثْندَّامْ\bd* أَكْ-ذ ڒذْشُورْ نْسنْثْ.  
\v 39 ثَا ذ ثَاسْغَارْثْ ن أَيْثْ ن نَافْثَالِي، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ثِيندَّامْ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\b  
\m
\v 40 \bd ثَاقدُّوحْثْ وِيسّْ سبْعَا\bd* ثكَّارْ أَسْ-د إِ ثقْبِيتْشْ ن أَيْثْ ن \bd ذَانْ\bd*، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ.  
\v 41 أَيْمِيرْ ن ثسْغَارْثْ نْسنْ أَقَا-ث ذ صُورْعَا ذ إِشْثَاؤُولْ ذ عِيرْ-شَامْشْ  
\v 42 ذ شَاعَالْبِيمْ ذ أَيَالُونْ ذ يِيثْلَا،  
\v 43 ذ إِيْلُونْ ذ ثِيمْنَاثَا ذ عَاقْرُونْ  
\v 44 ذ إِلْثَاقَايْ ذ جِيبَّاثُونْ ذ بَاعْلَاثْ  
\v 45 ذ يَاهُوذْ ذ بَانِي-بَارَاقْ ذ جَاثْ-رِيمُّونْ  
\v 46 ذ مِييَاهْ-يَارْقُونْ ذ رَاقُّونْ أَكْ-ذ ثمُّورْثْ قِيبَاتْشْ إِ يَافَا.   
\m
\v 47 \add مَاشَا\add* \bd ثَامُّورْثْ ن أَيْثْ ن ذَانْ ثحْسَارْ إِ نِيثْنِي\bd*. خنِّي ڭعّْذنْ أَيْثْ ن ذَانْ غَارْ لَاشَامْ، أَرْزْمنْ أَمنْغِي أَكْ-ذ لَاشَامْ، ڒغْبنْ ت، وْثِينْ ت س ڒقْضعْ ن سِّيفْ ؤُشَا طّْفنْ ت \add ذ ثَاسْغَارْثْ نْسنْ\add* ؤُشَا قِّيمنْ زدّْغنْ ذِينْ. نِيثْنِي ڭِّينْ أَسْ إِ لَاشَامْ \add إِسمْ\add* ذَانْ عْلَاحْسَابْ إِسمْ ن بَابَاثْسنْ دَان.  
\v 48 ثَا ذ ثَاسْغَارْثْ ن ثقْبِيتْشْ ن أَيْثْ ن ذَانْ، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ثِيندَّامْ-أَ أَكْ-ذ ڒذْشُورْ نْسنْثْ.   
\b  
\m
\v 49 \add ؤُمِي\add* كمّْڒنْ أَيْثْ ن إِسْرَائِيل أَبطُّو ن ثمُّورْثْ ذِي ثْسقَّارْ ن ڒْوَارْثْ عْلَاحْسَابْ إِيْمِيرنْ نّسْ، وْشِينْ أَيْثْ ن إِسْرَائِيل ؤُڒَا إِ يَاشُووَا، مِّيسْ ن نُونْ، إِشْثْ ن ثسْغَارْثْ ذِي ڒْوسْطْ نْسنْ.  
\v 50 وْشِينْ أَسْ، س ڒُومُورْ ن سِيذِي، ثَانْذِينْثْ إِ ثُوغَا إِتَّارْ، ثِيمْنَاثْ-سَارَاحْ خْ إِذُورَارْ ن إِفْرَايِيمْ. نتَّا إِبْنَا ثَانْذِينْثْ نِّي، ؤُشَا إِرُوحْ إِزْذغْ ذِينِّي.  
\v 51 ثِينَا ذ ثِيسقَّارْ نِّي إِتّْوَابْضَانْ \add ذ ڒْوَارْثْ\add* س ثْقدُّوحْثْ إِ أَيْثْ ن إِسْرَائِيل ذِي شِيلُو زَّاثْ إِ وُوذمْ ن سِيذِي غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ س ؤُفُوسْ ن ؤُكهَّانْ أَلِيعَازَارْ ذ يَاشُووَا، مِّيسْ ن نُونْ، ذ إِمْغَارنْ \add ن ثُوذْرِينْ\add* ن إِبَابَاثنْ ن ثْقبَّاڒْ. \add أَمُّو\add* كمّْڒنْ أَبطُّو ن ثمُّورْثْ.   
\b  
\b  
\m  
\c 20
\s1 ثِيندَّامْ ن ثَاروْڒَا  
\m
\v 1 إِسِّيوڒْ سِيذِي أَكْ-ذ يَاشُووَا، إِنَّا:   
\m
\v 2 ”سِيوڒْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، إِنِي: ’أَذْ ثْفَارْزمْ ثِيندَّامْ ن ثَاروْڒَا إِ يِيخفْ نْومْ، مِينْ خفْ ذ أَومْ سِّيوْڒغْ س ثْسخَّارْثْ ن مُوسَا، \f ◼ \fr 20:‏2 \ft \+bd ’س ثْسخَّارْثْ ن مُوسَا‘\+bd* - س لْحَارْفْ: ’س ؤُفُوسْ ن مُوسَا‘، إِخْسْ أَذْ يِينِي ’س ؤُقمُّومْ ن مُوسَا‘ نِيغْ ’س ڒُومُورْ ن مُوسَا‘.\f*  \x ◘ \xo 20:‏2 \xt  ؤُف. 21‏:‏13؛ ڒخْڒ. 35‏:‏6؛ أَعَوذ. 19‏:‏1، 2\x*  
\v 3 حِيمَا أَذْ يَارْوڒْ ذِينْ ؤُقتَّاڒْ نِّي إِنْغِينْ إِجّْ ن بْنَاذمْ زڭْ ؤُودَّارْ، بْڒَا مَا أَذْ أَسْ إِڭّْ ڒحْسَابْ. أَذْ إِڒِينْثْ ذ إِمُوشَانْ مَانِي غَا ثَاروْڒمْ زڭْ ؤُنقَّامْ ن إِذَامّنْ. \f ◼ \fr 20:‏3 \ft \+bd ’بْنَاذمْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘.\f*  
\v 4 مَاڒَا نتَّا يَارْوڒْ غَارْ إِشْثنْ زِي ثْندَّامْ نِّي، أَذْ إِبدّْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ ؤُشَا أَذْ إِحَاجَا ثَامْسَارْثْ نّسْ ذڭْ إِمزُّوغنْ ن إِمقّْرَاننْ ن ثنْذِينْثْ. \add خنِّي\add* أَذْ ث سِّيذْفنْ ذِي ثنْذِينْثْ، أَذْ أَسْ وْشنْ إِجّْ ن ومْشَانْ مَاحنْذْ أَذْ غَارْسنْ إِزْذغْ. \x ◘ \xo 20:‏4 \xt  ڒخْڒ. 35‏:‏22، 23؛ أَعَوذ. 19‏:‏4، 5\x*  
\v 5 مَاڒَا \add خنِّي\add* إِضْفَارْ إِ-ث ؤُنقَّامْ ن إِذَامّنْ، وَارْ ذ أَسْ تِّيشنْ أَقتَّاڒْ ذڭْ ؤُفُوسْ نّسْ، مَاغَارْ نتَّا إِنْغَا جَّارْ نّسْ بْڒَا مَا أَذْ أَسْ إِڭّْ ڒحْسَابْ، ثُوغَا وَارْ ث إِشَارّهْ شَا إِضنَّاضْ نِيغْ فَارِيضنَّاضْ.  
\v 6 نتَّا أَذْ إِقِّيمْ إِزْذغْ ذِي ثنْذِينْثْ نِّي، أَڒْ غَا إِبدّْ إِ ڒحْكَامْ زَّاثْ إِ وُوذمْ ن ثْمسْمُونْثْ، \add ؤُشَا أَوَارْنِي مَانْ أَيَا\add* أَڒْ غَا إِمّثْ أَرَّايْسْ ن إِكهَّاننْ ونِّي ذِينْ إِدْجَانْ ذڭْ وُوسَّانْ نِّي. خنِّي إِزمَّارْ ؤُقتَّاڒْ أَذْ إِعْقبْ غَارْ ثنْذِينْثْ نّسْ ؤُ غَارْ ثَادَّارْثْ نّسْ، غَارْ ثنْذِينْثْ إِ زِي د-يَارْوڒْ.   
\m
\v 7 \add خنِّي\add* قدّْسنْ قَاذَاشْ ذڭْ إِذُورَارْ ن نَافْثَالِي ذِي لْجَالِيلْ ؤُ شَاكِيمْ خْ إِذُورَارْ ن إِفْرَايِيمْ ؤُ قَارْيَاثْ-أَرْبَاعْ، ثنِّي ذ حَابْرُونْ، ذِي ثمُّورْثْ ن إِذُورَارْ ن يَاهُوذَا.  
\v 8 أَغِيرِينْ ن لْ-ؤُرْذُونْ، ذِي جِّيهثْ ن شَّارْقْ زِي أَرِيحَا، وْشِينْ نِيثْنِي زِي ثقْبِيتْشْ ن رُوبِينْ بَاصَارْ ذِي ڒخْڒَا خْ ڒْوَاطَا \add يُوعْڒَانْ\add* ؤُ زِي ثقْبِيتْشْ ن جَاذْ \add وْشِينْ نِيثْنِي\add* رَامُوثْ ذِي جِيلْعَاذْ ؤُ زِي ثقْبِيتْشْ ن مَانَاسَّا \add ثَانْذِينْثْ ن\add* جُولَانْ ذِي بَاشَانْ. \x ◘ \xo 20:‏8 \xt أَعَوذ. 4‏:‏43\x*   
\m
\v 9 ثِينَا ذ ثِيندَّامْ نِّي إِتّْوَاڭّنْ إِ مَارَّا أَيْثْ ن إِسْرَائِيل ؤُ إِ ؤُبَارَّانِي نِّي إِ إِزدّْغنْ ذِي ڒْوسْطْ نْسنْ، حِيمَا كُوڒْ إِجّْ زڭْ إِنِّي إِنْغِينْ إِجّْ ن بْنَاذمْ س ؤُودَّارْ، إِزمَّارْ أَذْ ذِينْ يَارْوڒْ، حِيمَا وَارْ إِتّْمتِّي س ؤُفُوسْ ن إِنقَّامنْ ن إِذَامّنْ أَڒْ غَا إِبدّْ إِ ڒْحُوكْمْ زَّاثْ إِ وُوذمْ ن ثْمسْمُونْثْ. \f ◼ \fr 20:‏9 \ft \+bd ’بْنَاذمْ‘\+bd* - ذِي ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘.\f*   
\b  
\b  
\m  
\c 21
\s1 ثِيندَّامْ ن إِلَاوِييّنْ  
\m
\v 1 \add خنِّي\add* قَارّْبنْ-د إِزدْجِيفنْ ن \add ثُوذْرِينْ ن\add* إِبَابَاثنْ ن إِلَاوِييّنْ غَارْ ؤُكهَّانْ أَلِيعَازَارْ ذ يَاشُووَا، مِّيسْ ن نُونْ، ؤُ \add قَارّْبنْ-د\add* غَارْ إِزدْجِيفنْ ن \add ثُوذْرِينْ ن\add* إِبَابَاثنْ ن ثْقبَّاڒْ ن أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 21:‏1 \xt 1 إِم. 6‏:‏39\x*  
\v 2 سِّيوْڒنْ أَكِيذْسنْ ذِي شِيلُو ذِي ثمُّورْثْ ن كنْعَانْ، نَّانْ: ”سِيذِي يُومُورْ س ؤُفُوسْ ن مُوسَا، أَذْ أَنغْ مّوْشنْثْ ثْندَّامْ، حِيمَا أَذْ ذَايْسنْثْ نزْذغْ، أَكْ-ذ دّْمَانِي نْسنْثْ ن ثَاروْسَا إِ ڒبْهَايمْ نّغْ.“ \x ◘ \xo 21:‏2 \xt ڒخْڒ. 35\x*  
\v 3 \add خنِّي\add* وْشِينْ أَيْثْ ن إِسْرَائِيل س ڒُومُورْ ن سِيذِي، زِي ثسْغَارْثْ نْسنْ، ثِيندَّامْ أَكْ-ذ دّْمَانِي نْسنْثْ ن ثَاروْسَا إِ إِلَاوِييّنْ.   
\b  
\m
\v 4 ؤُشَا ثكَّارْ أَسنْثْ-د ثْقدُّوحْثْ إِ ڒَادْجَاثْ ن \bd قَاهَاثْ\bd*. س ثْقدُّوحْثْ كَّارنْثْ أَسنْ-د إِ وَارَّاوْ ن ؤُكهَّانْ هَارُونْ زڭْ إِلَاوِييّنْ \bd ثْڒطَّاشْ ن ثْندَّامْ\bd* زِي \add ثمُّورْثْ ن\add* ثقْبِيتْشْ ن يَاهُوذَا ؤُ ن ثقْبِيتْشْ ن شِيمْعُونْ ؤُ ن ثقْبِيتْشْ ن بِينْيَامِينْ.  
\v 5 إِ إِنِّي إِقِّيمنْ ن أَيْثْ ن قَاهَاثْ \add كَّارنْثْ أَسنْ-د\add* س ثْقدُّوحْثْعشْرَا ن ثْندَّامْ زِي \add ثمُّورْثْ ن\add* ڒَادْجَاثْ ن ثقْبِيتْشْ ن إِفْرَايِيمْ ؤُ ن ثقْبِيتْشْ ن ذَانْ ؤُ ن وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا.   
\m
\v 6 إِ \bd أَيْثْ ن جَارْشُونْ\bd* \add كَّارنْثْ أَسنْ-د\add* س ثْقدُّوحْثْ \bd ثْڒطَّاشْ ن ثْندَّامْ\bd* زِي \add ثمُّورْثْ ن\add* ڒَادْجَاثْ ن ثقْبِيتْشْ ن إِسَّاكَارْ ؤُ ن ثقْبِيتْشْ ن أَشِيرْ ؤُ ن ثقْبِيتْشْ ن نَافْثَالِي ؤُ ن وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا ذِي بَاشَانْ.   
\m
\v 7 إِ \bd أَيْثْ ن مَارَارِي\bd* \add كَّارنْثْ أَسنْ-د س ثْقدُّوحْثْ\add* \bd ثنْعَاشْ ن ثْندَّامْ\bd*، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، زِي \add ثمُّورْثْ ن\add* ثقْبِيتْشْ ن رُوبِينْ ؤُ ن ثقْبِيتْشْ ن جَاذْ ؤُ ن ثقْبِيتْشْ ن زابُولُونْ.  
\v 8 أَيْثْ ن إِسْرَائِيل وْشِينْ ثِيندَّامْ-أَ أَكْ-ذ دّْمَانِي نْسنْثْ ن ثَاروْسَا س ثْقدُّوحْثْ إِ إِلَاوِييّنْ، أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي س ثْسخَّارْثْ ن مُوسَا.   
\b  
\m
\v 9 زِي \add ثمُّورْثْ ن\add* ثقْبِيتْشْ ن أَيْثْ ن يَاهُوذَا ؤُ زِي ثقْبِيتْشْ ن أَيْثْ ن شِيمْعُونْ وْشِينْ أَسنْ ثِيندَّامْ-أَ إِ إِتّْوَانَّانْ س يِيسمْ نْسنْثْ  
\v 10 ؤُ \add مَارَّا أَيَا\add* إِكَّارْ أَسنْ-د \bd إِ وَارَّاوْ ن هَارُونْ \+bdit نِّي إِدْجَانْ\+bdit* زِي ڒَادْجَاثْ ن إِقَاهَاثِييّنْ\bd* زڭْ أَيْثْ ن لَاوِي، مِينْزِي ثَاقدُّوحْثْ ثَامزْوَارُوثْ ثوْضَا خَاسنْ.  
\v 11 نِيثْنِي وْشِينْ أَسنْ ثَانْذِينْثْ ن أَرْبَاعْ، بَابَاسْ ن عَانَاقْ، ثنِّي ذ حَابْرُونْ، ذِي ثمُّورْثْ ن إِذُورَارْ ن يَاهُوذَا أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا إِ ذ أَسْ د-إِنّْضنْ. \f ◼ \fr 21:‏11 \ft \+bd ’ثَانْذِينْثْ ن أَرْبَاعْ‘\+bd* - نِيغْ ’قَارْيَاثْ-أَرْبَاعْ‘.\f*  
\v 12 \add مَاشَا\add* إِيَّارنْ ن ثنْذِينْثْ ذ ڒذْشُورْ نّسْ وْشِينْ ثنْ ذ أَڭْڒَا إِ كَالِيبْ، مِّيسْ ن يَافُونِّي.  
\v 13 إِ أَيْثْ ن ؤُكهَّانْ هَارُونْ وْشِينْ أَسنْ \add ثِيندَّامْ-أَ ذ\add* ثَانْذِينْثْ ن ثَاروْڒَا إِ ؤُقتَّاڒْ: حَابْرُونْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ لِيبْنَا أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا،  
\v 14 ذ يَاتِّيرْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ إِشْثُومَاعْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا،  
\v 15 ذ حُولُونْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ ذَابِيرْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا،  
\v 16 ذ عَايْنْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ يُوطَّا أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ بَايْثْ-شَامْسْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd ثسْعَا ن ثْندَّامْ\bd* زِي ثْنَاينْ ن ثْقبَّاڒْ-أَ.   
\m
\v 17 زِي ثقْبِيتْشْ ن بِينْيَامِينْ \add وْشِينْ أَسنْ\add* جِيبْعُونْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ جِيبْعَا أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا،  
\v 18 عَانَاثُوثْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ عَالْمُونْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd أَربْعَا ن ثْندَّامْ\bd*.  
\v 19 مَارَّا ثِيندَّامْ ن وَارَّاوْ ن هَارُونْ، ن إِكهَّاننْ، \add ثُوغَا أَثنْثْ ذِي\add* \bd ثْڒطَّاشْ ن ثْندَّامْ\bd* أَكْ-ذ دّْمَانِي نْسنْثْ ن ثَاروْسَا.   
\m
\v 20 \bd إِ ڒَادْجَاثْ ن أَيْثْ ن قَاهَاثْ، إِلَاوِييّنْ، نِّي إِقِّيمنْ زڭْ أَيْثْ ن قَاهَاثْ\bd* كَّارنْثْ أَسنْ-د س ثْقدُّوحْثْ ثِيندَّامْ زِي \add ثمُّورْثْ ن\add* ثقْبِيتْشْ ن إِفْرَايِيمْ.  
\v 21 وْشِينْ أَسنْ \add ثِيندَّامْ-أَ ذ\add* ثَانْذِينْثْ ن ثَاروْڒَا إِ ؤُقتَّاڒْ: شَاكِيمْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا خْ إِذُورَارْ ن إِفْرَايِيمْ، ذ جَازَارْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا،  
\v 22 ذ قِيبْصَايِيمْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ بَايْثْ-حُورُونْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd أَربْعَا ن ثْندَّامْ\bd*.   
\m
\v 23 زِي ثقْبِيتْشْ ن ذَانْ \add كَّارنْثْ أَسنْ-د:\add* إِلْثَاقَا أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، جِيبَّاثُونْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا،  
\v 24 أَيَالُونْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا ذ جَاذْ-رِيمُّونْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd أَربْعَا ن ثْندَّامْ\bd*.   
\m
\v 25 زِي \add ثمُّورْثْ ن\add* وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا \add كَّارنْثْ أَسنْ-د\add* ثَاعْنَاكْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا ذ جَاذْ-رِيمُّونْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd ثْنَاينْ ن ثْندَّامْ\bd*.  
\v 26 مَارَّا ثِيندَّامْ إِ ڒَادْجَاثْ ن أَيْثْ ن قَاهَاثْ نِّي إِقِّيمنْ \add ثُوغَا أَثنْثْ\add* ذِيعشْرَا ن ثْندَّامْ أَكْ-ذ دّْمَانِي نْسنْثْ ن ثَاروْسَا.   
\b  
\m
\v 27 زِي \add ثمُّورْثْ ن\add* وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا \add كَّارنْثْ أَسنْ-د ثْندَّامْ-أَ\add* \bd إِ أَيْثْ ن جَارْشُونْ\bd*، زِي ڒَادْجَاثْ ن إِلَاوِييّنْ، أَمْ ثنْذِينْثْ ن ثَاروْڒَا إِ ؤُقتَّاڒْ: جُولَانْ ذِي بَاشَانْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا ذ بَاعَاشْثَارَا أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا. \add مَارَّا جْمِيعْ\add* \add ثُوغَا أَثنْثْ ذِي\add* \bd ثْنَاينْ ن ثْندَّامْ\bd*.   
\m
\v 28 زِي \add ثمُّورْثْ ن\add* ثقْبِيتْشْ ن إِسَّاكَارْ \add كَّارنْثْ أَسنْ-د:\add* قِيشْيُونْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ ذَابْرَاثْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا،  
\v 29 يَارْمُوثْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ عَايْنْ-جَانِّيمْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا. \add مَارَّا جْمِيعْ\add* \add ثُوغَا أَثنْثْ ذِي\add* \bd أَربْعَا ن ثْندَّامْ\bd*.   
\m
\v 30 زِي \add ثمُّورْثْ ن\add* ثقْبِيتْشْ ن أَشِيرْ \add كَّارنْثْ أَسنْ-د:\add* مِيشْ-أَلْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ عَابْذُونْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا،  
\v 31 ذ حَالْقَاثْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا ذ رَاحُوبْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا. \add مَارَّا جْمِيعْ\add* \add ثُوغَا أَثنْثْ ذِي\add* \bd أَربْعَا ن ثْندَّامْ\bd*.   
\m
\v 32 زِي \add ثمُّورْثْ ن\add* ثقْبِيتْشْ ن نَافْثَالِي \add كَّارنْثْ أَسنْ-د\add* أَمْ ثنْذِينْثْ ن ثَاروْڒَا إِ ؤُقتَّاڒْ: قَاذَاشْ ذِي لْجَالِيلْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ حَامُّوثْ-ذُورْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا ذ قَارْثَانْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا. \add مَارَّا جْمِيعْ\add* \add ثُوغَا أَثنْثْ\add* ذِي \bd ثْڒَاثَا ن ثْندَّامْ\bd*.  
\v 33 مَارَّا ثِيندَّامْ ن أَيْثْ ن جَارْشُونْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ \add ثُوغَا أَثنْثْ ذِي\add* ثْڒطَّاشْ ن ثْندَّامْ أَكْ-ذ دّْمَانِي نْسنْثْ ن ثَاروْسَا.   
\b  
\m
\v 34 \bd إِ ڒَادْجَاثْ ن أَيْثْ ن مَارَارِي\bd*، أَقَا أَثنْ ذ إِنِّي إِقِّيمنْ \add عَاذْ\add* زڭْ إِلَاوِييّنْ، \add مّوْشنْثْ أَسنْ\add* زِي \add ثمُّورْثْ ن\add* ثقْبِيتْشْ ن زابُولُونْ، جُوقْنَاعَامْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، قَارْثَا أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا،  
\v 35 ذِيمْنَا أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا ذ نَاهَالَالْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا. \add مَارَّا جْمِيعْ\add* ثُوغَا أَثنْثْ ذِي \bd أَربْعَا ن ثْندَّامْ\bd*.   
\m
\v 36 زِي \add ثمُّورْثْ ن\add* ثقْبِيتْشْ ن رُوبِينْ \add كَّارنْثْ أَسنْ-د\add* بَاصَارْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ يَاهْصَا أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا،  
\v 37 قَاذِيمُوثْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا ذ مَافَاعَا أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا. \add مَارَّا جْمِيعْ\add* \add ثُوغَا أَثنْثْ ذِي\add* \bd أَربْعَا ن ثْندَّامْ\bd*.   
\m
\v 38 زِي \add ثمُّورْثْ ن\add* ثقْبِيتْشْ ن جَاذْ \add كَّارنْثْ أَسنْ-د\add* أَمْ ثنْذِينْثْ ن ثَاروْڒَا إِ ؤُقتَّاڒْ: رَامُوثْ ذِي جِيلْعَاذْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ مَاحَانَايِيمْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا،  
\v 39 حَاشْبُونْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا، ذ يَاعْزِيرْ أَكْ-ذ دّْمَانِي نّسْ ن ثَاروْسَا. \add مَارَّا جْمِيعْ\add* \add ثُوغَا أَثنْثْ ذِي\add* \bd أَربْعَا ن ثْندَّامْ\bd*.   
\m
\v 40 \add ثُوغَا ثِينَا\add* مَارَّا ذ ثِيندَّامْ إِ أَيْثْ ن مَارَارِي، عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، ثِينِّي إِقِّيمنْ زِي ڒَادْجَاثْ ن إِلَاوِييّنْ، ثِينِّي خْ د-ثوْضَا ثْقدُّوحْثْ نْسنْ، \bdit مَارَّا جْمِيعْ ثُوغَا ثنْثْ ذِي\bdit* \bd ثنْعَاشْ ن ثْندَّامْ\bd*.   
\b  
\m
\v 41 \bd مَارَّا ثِيندَّامْ\bd* ذِي ڒْوسْطْ ن ڒْوَارْثْ ن أَيْثْ ن إِسْرَائِيل \add ثُوغَا أَثنْثْ ذِي\add* \bd ثْمنْيَا ؤُ-ربْعِينْ ن ثْندَّامْ\bd* أَكْ-ذ دّْمَانِي نْسنْثْ ن ثَاروْسَا.  
\v 42 ثِيندَّامْ-أَ ثُوغَا أَثنْثْ مَارَّا أَكْ-ذ دّْمَانِي نْسنْثْ ن ثَاروْسَا إِ ذ أَسنْثْ إِنّْضنْ. أَمُّو \add إِ ثُوغَا ثدْجَا\add* غَارْ مَارَّا ثِيندَّامْ-أَ.   
\m
\v 43 أَمُّو إِوْشَا سِيذِي إِ إِسْرَائِيل مَارَّا ثَامُّورْثْ نِّي ثُوغَا إِجُّودْجْ أَذْ ت إِوْشْ إِ ڒجْذُوذْ نْسنْ ؤُشَا نِيثْنِي وَارْثنْ ت ؤُشَا رُوحنْ زدّْغنْ ذَايسْ.  
\v 44 ؤُشَا سِيذِي إِڭَّا أَسنْ ڒْهُوذْنثْ زِي مَارَّا إِغزْذِيسنْ، أَمْ مَامّشْ مَارَّا نِّي ثُوغَا إِجُّودْجْ إِ ڒجْذُوذْ نْسنْ. ؤُڒَا ذ إِجّْ زِي ڒْعذْيَانْ نْسنْ وَارْ ذ أَسنْ إِزمَّارْ زَّاثْ إِ وُوذمْ نْسنْ. سِيذِي إِوْشَا أَسنْ مَارَّا ڒْعذْيَانْ ذڭْ ؤُفُوسْ نْسنْ.  
\v 45 ؤُڒَا ذ إِجّْ ن وَاوَاڒْ زِي مَارَّا أَوَاڒنْ إِشْنَانْ إِ زِي إِسِّيوڒْ سِيذِي غَارْ ثَادَّارْثْ ن إِسْرَائِيل إِوْضَا. مَارَّا \add أَيَا\add* إِتّْوَاكمّڒْ.   
\b  
\b  
\m  
\c 22
\s1 أَعْقَابْ ن ثْقبَّاڒْ إِ إِدْجَانْ غَارْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ  
\m
\v 1 خنِّي إِڒَاغَا-د يَاشُووَا إِ إِرُوبِينِييّنْ ذ إِجَاذِييّنْ ذ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا،  
\v 2 إِنَّا أَسنْ: ”كنِّيوْ ثحْضَامْ مَارَّا مِينْ خفْ إِ ذ أَومْ يُومُورْ مُوسَا، أَمْسخَّارْ ن سِيذِي، ؤُ كنِّيوْ ثسْڒَامْ \add عَاوذْ\add* إِ ثْمِيجَّا إِنُو ذِي مَارَّا مِينْ خفْ ذ أَومْ ؤُمُورغْ. \x ◘ \xo 22:‏2 \xt ڒخْڒ. 32‏:‏20؛ أَعَوذ. 3‏:‏18\x*  
\v 3 كنِّيوْ وَارْ ثسْمِيحمْ شَا ذڭْ أَيْثْمَاثْومْ ذڭْ وَاطَّاسْ ن وُوسَّانْ أَڒْ أَسّْ-أَ ؤُ ثحْضَامْ أَحطُّو ن ڒُومُورْ ن سِيذِي، أَربِّي نْومْ.  
\v 4 ؤُشَا ڒخُّو إِڭَّا سِيذِي، أَربِّي نْومْ، إِ أَيْثْمَاثْومْ أَرَّاحثْ، أَمْ مَامّشْ ثُوغَا إِ ذ أَسنْ ت إِوَاعْذْ.عقْبمْ خنِّي ڒخُّو غَارْ إِقِيضَانْ نْومْ ذِي ثمُّورْثْ ن ڒْوَارْثْ نْومْ نِّي ذ أَومْ إِوْشَا مُوسَا، أَمْسخَّارْ ن سِيذِي، خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ. \x ◘ \xo 22:‏4 \xt ڒخْڒ. 32‏:‏33؛ أَعَوذ. 3‏:‏13؛ 29‏:‏8؛ ياش. 13‏:‏8\x*  
\v 5 مَاشَا حْضَامْ مْلِيحْ أَذْ ثڭّمْ ڒُومُورْ ذ شَّارِيعَا إِ ذ أَومْ إِوْشَا مُوسَا، أَمْسخَّارْ ن سِيذِي، حِيمَا أَذْ ثخْسمْ سِيذِي، أَربِّي نْومْ، أَذْ ثُويُورمْ ذِي مَارَّا إِبْرِيذنْ نّسْ، أَذْ ثحْضَامْ مَارَّا ڒُومُورَاثْ نّسْ ؤُشَا أَذْ غَارسْ ثْڒصْقمْ ؤُ أَذْ أَسْ ثْسخَّارمْ س مَارَّا وُوڒْ ذ مَارَّا ڒعْمَارْ نْومْ.“ \x ◘ \xo 22:‏5 \xt أَعَوذ. 10‏:‏12\x*   
\m
\v 6 إِبَاركْ إِ-ثنْ يَاشُووَا، إِجَّا إِ-ثنْ أَذْ ؤُيُورنْ ؤُشَا نِيثْنِي أَرڭّْوْحنْ غَارْ إِقِيضَانْ نْسنْ.  
\v 7 إِ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا ثُوغَا إِوْشَا مُوسَا إِشْثْ ن ثسْغَارْثْ ذِي بَاشَانْ، مَاشَا إِ يِيجّْ ن وزْينْ نّغْنِي إِوْشَا أَسْ يَاشُووَا إِشْثْ ن ثسْغَارْثْ غَارْ أَيْثْمَاثْسنْ خْ ؤُغزْذِيسْ-أَ ن لْ-ؤُرْذُونْ زِي مَانِيسْ ثْغدْجِي ثْفُوشْثْ. ؤُمِي ثنْ إِسّكّْ يَاشُووَا غَارْ إِقِيضَانْ نْسنْ، إِبَاركْ إِ-ثنْ  
\v 8 ؤُشَا إِسِّيوڒْ أَكِيذْسنْ، إِنَّا: ”س وَاڭْڒَا ذ أَمقّْرَانْ أَذْ ثْعقْبمْ غَارْ إِقِيضَانْ نْومْ، س وَاطَّاسْ ن ڒبْهَايمْ ؤُ س نُّوقَارْثْ ذ وُورغْ ؤُ س نّْحَاسْ ذ وُوزَّاڒْ ؤُ س وَاطَّاسْ ن وَارُّوضْ. بْضَامْ ثَاكشَّاضْثْ ن ڒْعذْيَانْ نْومْ أَكْ-ذ أَيْثْمَاثْومْ.“  
\v 9 عقْبنْ أَيْثْ ن رُوبِينْ ذ أَيْثْ ن جَاذْ ذ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا، فّْغنْ زِي غَارْ أَيْثْ ن إِسْرَائِيل، إِڭّْوجّنْ خْ شِيلُو \add نِّي إِدْجَانْ\add* ذِي ثمُّورْثْ ن كنْعَانْ، حِيمَا أَذْ رَاحنْ غَارْ ثمُّورْثْ ن جِيلْعَاذْ، غَارْ ثمُّورْثْ ن ڒْمُوڒْكْ نْسنْ نِّي إِطّْفنْ ذ أَڭْڒَا عْلَاحْسَابْ ڒُومُورْ ن سِيذِي س ثْسخَّارْثْ ن مُوسَا.   
\b  
\m  
\s1 أَعَالْثَارْ ن ثْقبَّاڒْ غَارْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ  
\m
\v 10 \add ؤُمِي\add* إِوْضنْ نِيثْنِي غَارْ ثْمُووَّا ن لْ-ؤُرْذُونْ نِّي \add إِدْجَانْ عَاذْ\add* ذِي ثمُّورْثْ ن كنْعَانْ، بْنَانْ أَيْثْ ن رُوبِينْ ذ أَيْثْ ن جَاذْ ذ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا ذِينِّي إِجّْ ن ؤُعَالْطَارْ غَارْ لْ-ؤُرْذُونْ، إِجّْ ن ؤُعَالْطَارْ إِمْغَارْ أَطَّاسْ. \x ◘ \xo 22:‏10 \xt ياش. 18‏:‏7\x*  
\v 11 ؤُشَا سْڒِينْ أَيْثْ ن إِسْرَائِيل أَقَا قَّارنْ: ”خْزَارمْ، أَيْثْ ن رُوبِينْ ذ أَيْثْ ن جَاذْ ذ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا بْنَانْ إِجّْ ن ؤُعَالْطَارْ غَارْ ويْمِيرْ ن ثمُّورْثْ ن كنْعَانْ خْ ثْمُووَّا ن لْ-ؤُرْذُونْ، خْ ؤُغزْذِيسْ \add ن لْ-ؤُرْذُونْ\add* ن أَيْثْ ن إِسْرَائِيل.“  
\v 12 \add ؤُمِي\add* سْڒِينْ أَيْثْ ن إِسْرَائِيل أَيَا، ثْمُونْ مَارَّا ثْمسْمُونْثْ ن أَيْثْ ن إِسْرَائِيل ذِي شِيلُو حِيمَا أَذْ فّْغنْ إِ ؤُمنْغِي أَكِيذْسنْ س إِجّْ ن ڒْعسْكَارْ.  
\v 13 ؤُشَا سّكّنْ أَيْثْ ن إِسْرَائِيل فِينَاحَاسْ، مِّيسْ ن ؤُكهَّانْ أَلِيعَازَارْ، غَارْ أَيْثْ ن رُوبِينْ ؤُ غَارْ أَيْثْ ن جَاذْ ؤُ غَارْ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا ذِي جِيلْعَاذْ،  
\v 14 ؤُ \add سّكّنْ\add* أَكِيذسْعشْرَا ن ڒْحُوكَّامْ، إِجّْ ن ڒْحَاكمْ زِي كُوڒْ ثَادَّارْثْ ن بَابَاسْ، زِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل. كُوڒْ إِجّْ \add زَّايْسنْ\add* ثُوغَا ذ أَزدْجِيفْ ن ثَادَّارْثْ ن ڒجْذُوذْ نْسنْ إِ ڒُوڒُوفْ ن إِسْرَائِيل.   
\m
\v 15 ؤُسِينْ-د نِيثْنِي غَارْ أَيْثْ ن رُوبِينْ ؤُ غَارْ أَيْثْ ن جَاذْ ؤُ غَارْ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا ذِي ثمُّورْثْ ن جِيلْعَاذْ، نَّانْ أَسنْ:  
\v 16 ”أَمُّو إِ ثسِّيوڒْ مَارَّا ثْمسْمُونْثْ ن سِيذِي: مِينْ إِخْسْ أَذْ يِينِي ڒغْذَارْ-أَ إِ زِي ثغْذَارمْ أَربِّي ن إِسْرَائِيل ؤُمِي ثْحيّْذمْ أَسّْ-أَ زِي ضفَّارْ ن سِيذِي، ؤُمِي ثبْنَامْ إِ يِيخفْ نْومْ إِجّْ ن ؤُعَالْطَارْ مَاحنْذْ أَذْ ثْغوّْغمْ خْ سِيذِي أَسّْ-أَ؟  
\v 17 مَا وَارْ إِدْجِي شْفَا أَنغْ ڒْمُوعْصِييّثْ ن فَاغُورْ، \add ڒْمُوعْصِييّثْ إِ زِي\add* غَارْ أَسّْ-أَ \add عَاذْ\add* وَارْ نتّْوَاسِّيزْذڭْ ؤُ زَّايسْ إِ ثوْضَا جّْرِيحشْثْ خْ ثْمسْمُونْثْ ن سِيذِي؟\x ◘ \xo 22:‏17 \xt ڒخْڒ. 25‏:‏3؛ أَعَوذ. 4‏:‏3\x*  
\v 18 مَا أَقَا كنِّيوْ أَسّْ-أَ ثوْشِيمْ س وعْرُورْ إِ سِيذِي ؤُشَا أَذْ إِمْسَارْ \add خنِّي\add*، ؤُمِي غَا ثْغوّْغمْ أَسّْ-أَ خْ سِيذِي، أَذْ إِفُّوڭمْ نتَّا خْ مَارَّا ثْمسْمُونْثْ ن إِسْرَائِيل؟  
\v 19 مَاڒَا زعْمَا ثخْمجْ ثمُّورْثْ إِ إِدْجَانْ ذ أَڭْڒَا نْومْ، \add خنِّي\add* عْذُومْ غَارْ ثمُّورْثْ نِّي إِدْجَانْ ذ أَڭْڒَا ن سِيذِي ؤُ مَانِي ثدْجَا ثْزذِّيغْثْ ن سِيذِي ؤُشَا كْسِيمْ إِ يِيخفْ نْومْ إِجّْ ن وڭْرَا ذِي ڒْوسْطْ نّغْ، \add مَاشَا\add* وَارْ ثْغوّْغمْ شَا خْ سِيذِي ؤُ وَارْ ثْغوّْغمْ شَا خَانغْ ؤُمِي غَا ثبْنَامْ إِجّْ ن ؤُعَالْطَارْ إِ يِيخفْ نْومْ، مْغِيرْ أَعَالْطَارْ ن سِيذِي، أَربِّي نّغْ.  
\v 20 مَا ثُوغَا عَاخَانْ، مِّيسْ ن زَارَاحْ، وَارْ إِغْذَارْ ذِي ثْمسْڒَاشْثْ ن مِينْ إِتّْوَاحَارّْمنْ \add إِ ؤُثحِّي\add* ؤُ خنِّي مَا وَارْ د-إِتِّيسْ ؤُذُوقّزْ ن وغْضَابْ خْ مَارَّا ثَامسْمُونْثْ ن إِسْرَائِيل؟ ؤُشَا أَرْيَازْ نِّي وَارْ إِمُّوثْ وحّْضسْ وَاهَا ذِي ڒْمُوعْصِييّثْ نّسْ.‘ “   
\m
\v 21 \add خنِّي\add* أَرِّينْ-د أَيْثْ ن رُوبِينْ ذ أَيْثْ ن جَاذْ ذ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا ؤُشَا سِّيوْڒنْ أَكْ-ذ إِزدْجِيفنْ خْ ڒُوڒُوفْ ن إِسْرَائِيل:  
\v 22 ”أَربِّي خْ \add مَارَّا\add* إِربِّيثنْ، سِيذِي، أَربِّي خْ \add مَارَّا\add* إِربِّيثنْ إِسّنْ \add إِ-ث\add* ؤُ إِسْرَائِيل أَذْ \add ث\add* إِسّنْ \add عَاوذْ\add*! مَاڒَا إِفّغْ-د أَيَا زڭْ ؤُغوّغْ نِيغْ زِي ڒغْذَارْ خْ سِيذِي، \add خنِّي\add* وَارْ خَانغْ ثْشطَّارْ شَا أَسّْ-أَ، \x ◘ \xo 22:‏22 \xt إِزهد. 50‏:‏1\x*  
\v 23 \add مَاڒَا ثُوغَا\add* حِيمَا أَذْ نبْنَا إِ نشِّينْ إِجّْ ن ؤُعَالْطَارْ مَاحنْذْ أَذْ نوْشْ س وعْرُورْ إِ سِيذِي نِيغْ \add مَاڒَا ثُوغَا\add* حِيمَا أَذْ نْقدّمْ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ نِيغْ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* نِيغْ إِ ؤُسوْجذْ ن ثْغَارْصَا ن ڒهْنَا، أجّْ سِيذِي سِيمَانْثْ نّسْ أَذْ \add ث\add* إِبقّشْ.  
\v 24 \add ؤُشْثْ خَانغْ\add*، مَاڒَا وَارْ نڭِّي أَيَا زڭْ ومْنُوسْ ؤُمِي نقَّارْ: ’إِحنْجِيرنْ نْومْ \add زمَّارنْ\add* أَذْ إِنِينْ إِ إِحنْجِيرنْ نّغْ ثِيوشَّا: مِينْ جَارْ أَومْ-د أَكْ-ذ سِيذِي، أَربِّي ن إِسْرَائِيل؟  
\v 25 سِيذِي إِڭَّا لْ-ؤُرْذُونْ ذ أَيْمِيرْ جَارْ أَنغْ ذ كنِّيوْ، أَيْثْ ن رُوبِينْ ذ أَيْثْ ن جَاذْ! كنِّيوْ وَارْ غَارْومْ شَا ثَاسْغَارْثْ ذِي سِيذِي!‘ \add أَمُّو\add* زمَّارنْ أَذْ سّْبدّنْ إِحنْجِيرنْ نْومْ إِحنْجِيرنْ نّغْ خْ ثِيڭّْوُوذِي ن سِيذِي.  
\v 26 \add خْ ؤُينِّي\add* ننَّا: أجّْ أَنغْ أَذْ نبْنَا أَعَالْطَارْ-أَ، وَارْ إِدْجِي إِ ثْغَارْصْثْ ن وشْمَاضْ ؤُڒَا إِ ثْغَارْصْثْ،  
\v 27 \add مَاشَا\add* حِيمَا أَذْ يِيڒِي ذ أَشهَّاذْ جَارْ نشِّينْ ذ كنِّيوْ ؤُ جَارْ جِّيڒَاثْ نّغْ أَوَارْنِي أَنغْ، حِيمَا أَذْ نْسخَّارْ ذِي ثْسخَّارْثْ ن سِيذِي زَّاثْ إِ وُوذمْ نّسْ س ثْغَارْصِي نّغْ ن وشْمَاضْ ذ ثْغَارْصِي نّغْ \add نّغْنِي\add* ذ ثْغَارْصِي نّغْ ن ڒهْنَا ؤُ حِيمَا إِحنْجِيرنْ نْومْ وَارْ قَّارنْ إِ إِحنْجِيرنْ نّغْ: كنِّيوْ وَارْ غَارْومْ شَا ثَاسْغَارْثْ ذِي سِيذِي. \x ◘ \xo 22:‏27 \xt أَمز. 31‏:‏48؛ ياش. 24‏:‏27\x*  
\v 28 نشِّينْ ننَّا: مَاڒَا إِمْسَارْ ثِيوشَّا أَذْ إِنِينْ نِيثْنِي أَيَا إِ نشِّينْ ؤُ إِ جِّيڒَاثْ \add أَوَارْنِي أَنغْ\add*، خنِّي أَذْ نِينِي: ’خْزَارمْ، أَمذْيَا ن ڒبْنِي ن ؤُعَالْطَارْ-أَ ن سِيذِي نِّي إِڭِّينْ ڒجْذُوذْ نّغْ، وَارْ إِدْجِي إِ ثْغَارْصْثْ ن وشْمَاضْ نِيغْ إِ ثْغَارْصْثْ \add نّغْنِي\add*، \add مَاشَا\add* حِيمَا أَذْ يِيڒِي ذ أَشهَّاذْ جَارْ نشِّينْ ذ كنِّيوْ.‘  
\v 29 إِڭّْوجْ خَانغْ أَقَا نشِّينْ أَذْ نْغوّغْ خْ سِيذِي نِيغْ أَسّْ-أَ أَذْ نوْشْ س وعْرُورْ إِ سِيذِي ؤُمِي غَا نبْنَا إِجّْ ن ؤُعَالْطَارْ إِ ثْغَارْصْثْ ن وشْمَاضْ نِيغْ إِ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* نِيغْ إِ ثْغَارْصْثْ \add نّغْنِي\add*، إِلَّا أَعَالْطَارْ ن سِيذِي، أَربِّي نّغْ، ونِّي إِدْجَانْ زَّاثْ إِ ثْزذِّيغْثْ نّسْ.“   
\m
\v 30 أَكهَّانْ فِينَاحَاسْ ذ ڒْحُوكَّامْ ن ثْمسْمُونْثْ ذ إِزدْجِيفنْ خْ ڒُوڒُوفْ ن إِسْرَائِيل نِّي كِيذسْ \add إِدْجَانْ\add*، سْڒِينْ أَوَاڒنْ إِ إِسِّيوْڒنْ أَيْثْ ن رُوبِينْ ذ أَيْثْ ن جَاذْ ذ أَيْثْ ن مَانَاسَّا ؤُ ثُوغَا أَيَا ذ لمْلِيحْ ذِي ثِيطَّاوِينْ نْسنْ.  
\v 31 فِينَاحَاسْ، مِّيسْ ن أَلِيعَازَارْ، إِنَّا إِ أَيْثْ ن رُوبِينْ ؤُ إِ أَيْثْ ن جَاذْ ؤُ إِ أَيْثْ ن مَانَاسَّا: ”أَسّْ-أَ أَذْ ثسّْنمْ بلِّي سِيذِي أَقَا-ث ذِي ڒْوسْطْ نّغْ ؤُمِي كنِّيوْ وَارْ ثغْذَارمْ شَا سِيذِي. س ؤُيَا كنِّيوْ ثْفكّمْ أَيْثْ ن إِسْرَائِيل زڭْ ؤُفُوسْ ن سِيذِي.“   
\m
\v 32 \add خنِّي\add* يَارڭّْوحْ ؤُكهَّانْ فِينَاحَاسْ، مِّيسْ ن أَلِيعَازَارْ، أَكْ-ذ ڒْحُوكَّامْ زڭْ أَيْثْ ن رُوبِينْ ذ أَيْثْ ن جَاذْ، زِي ثمُّورْثْ ن جِيلْعَاذْ غَارْ ثمُّورْثْ ن كنْعَانْ، غَارْ أَيْثْ ن إِسْرَائِيل، ؤُشَا نِيثْنِي ڭِّينْ ذَايْسنْ ڒخْبَارْ.  
\v 33 ثُوغَا ثَامسْڒَاشْثْ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ ن أَيْثْ ن إِسْرَائِيل ؤُشَا حمْذنْ أَيْثْ ن إِسْرَائِيل أَربِّي ؤُ وَارْ ذ أَسنْ نَّانْ عَاذْ أَذْ فّْغنْ أَذْ مّنْغنْ مَاحنْذْ أَذْ أَردّْدْجنْ ثَامُّورْثْ إِ ذِي ثُوغَا زدّْغنْ أَيْثْ ن رُوبِينْ ذ أَيْثْ ن جَاذْ.  
\v 34 أَيْثْ ن رُوبِينْ ذ أَيْثْ ن جَاذْ ڒَاغَانْ أَسْ إِ ؤُعَالْطَارْ نِّي: ”أَذْ يِيڒِي ذ أَشهَّاذْ جَارْ أَنغْ أَقَا سِيذِي ذ أَربِّي.“   
\b  
\b  
\m  
\c 23
\s1 أَوَاڒْ ن يَاشُووَا إِ إِزدْجِيفنْ ن إِسْرَائِيل  
\m
\v 1 إِمْسَارْ ؤُمِي عْذُونْ أَطَّاسْ ن وُوسَّانْ أَوَارْنِي ؤُمِي سِيذِي ثُوغَا إِڭَّا إِ إِسْرَائِيل ڒْهُوذْنثْ زِي مَارَّا ڒْعذْيَانْ نّسْ إِ ذ أَسْ د-إِنّْضنْ ؤُ ؤُمِي ثُوغَا يَاشُووَا إِوْسَارْ، إِمْغَارْ ذڭْ وُوسَّانْ،  
\v 2 أَقَا إِڒَاغَا يَاشُووَا إِ مَارَّا إِسْرَائِيل، إِمْغَارنْ نّسْ ذ إِزدْجِيفنْ نّسْ ذ ڒْقُوضَاثْ نّسْ ذ إِمحْضَاينْ نّسْ، إِنَّا أَسنْ: ”نشّْ وْسَارغْ ؤُ مْغَارغْ ذڭْ وُوسَّانْ  
\v 3 ؤُشَا كنِّيوْ ثژْرِيمْ مَارَّا مِينْ إِڭَّا سِيذِي، أَربِّي نْومْ، أَكْ-ذ مَارَّا ڒڭْنُوسْ-أَ زَّاثْ إِ ثِيطَّاوِينْ نْومْ، مَاغَارْ سِيذِي، أَربِّي نْومْ سِيمَانْثْ نّسْ، ذ ونِّي ثُوغَا إِمّنْغنْ ذِي طّْوعْ نْومْ.  
\v 4 خْزَارْ نشّْ بْضِيغْ أَومْ ڒڭْنُوسْ-أَ إِ إِقِّيمنْ جَارْ أَومْ س ثْقدُّوحْثْ، أَمْ ثسْغَارْثْ \add ن ڒْوَارْثْ\add* إِ ثْقبَّاڒْ نْومْ، أَكْ-ذ مَارَّا ڒڭْنُوسْ إِ ثحِّيغْ زِي لْ-ؤُرْذُونْ أَڒْ ڒبْحَارْ أَمقّْرَانْ مَانِي ثْغدْجِي ثْفُوشْثْ.  
\v 5 سِيذِي، أَربِّي نْومْ، أَذْ خَاسنْ إِبَارّزْ زَّاثْ إِ وُوذمْ نْومْ ؤُ أَذْ خَاسنْ يَاژّڒْ زَّاثْ إِ وُوذمْ نْومْ زِي ڒْوَارْثْ نْسنْ ؤُ كنِّيوْ أَذْ ثطّْفمْ ثَامُّورْثْ نْسنْ ذ ڒْوَارْثْ، أَمْ مَامّشْ إِ ذ أَومْ إِسِّيوڒْ سِيذِي، أَربِّي نْومْ. \x ◘ \xo 23:‏5 \xt ؤُف. 14‏:‏14؛ 23‏:‏27؛ ڒخْڒ. 33‏:‏53؛ أَعَوذ. 6‏:‏19؛ ياش. 13‏:‏6\x*  
\v 6 حْضَامْ أَطَّاسْ س جّهْذْ ؤُ ڭّمْ مَارَّا مِينْ يُورِينْ ذڭْ وذْلِيسْ-أَ إِتّْوَانّْضنْ ن شَّارِيعَا ن مُوسَا، حِيمَا وَارْ خَاسْ ثْحيِّيذمْ ؤُڒَا \add غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ، \x ◘ \xo 23:‏6 \xt أَعَوذ. 5‏:‏32؛ 28‏:‏14\x*  
\v 7 حِيمَا كنِّيوْ وَارْ تّْصُورَامْ إِخفْ نْومْ أَكْ-ذ ڒڭْنُوسْ-أَ إِنِّي \add عَاذْ\add* إِقِّيمنْ غَارْومْ، ؤُ وَارْ تّْفكَّارمْ \add عَاذْ\add* ذڭْ يِيسمْ ن إِربِّيثنْ نْسنْ ؤُ وَارْ \add خَاسنْ\add* تّْجَادْجَامْ ؤُ \add حِيمَا\add* كنِّيوْ وَارْ ذ أَسنْ ثْعبّْذمْ ؤُ وَارْ ذ أَسنْ ثتّْبنْذْقمْ. \x ◘ \xo 23:‏7 \xt ؤُف. 23‏:‏13؛ إِزهد. 16‏:‏4؛ إِرْم. 5‏:‏7؛ صَاف. 1‏:‏5؛ أَفا. 5‏:‏3\x*  
\v 8 مَاغَارْ إِتّْخصَّا أَذْ ثْڒصْقمْ إِ سِيذِي، أَربِّي نْومْ، أَمْ مَامّشْ إِ ث ثڭِّيمْ أَڒْ أَسّْ-أَ. \x ◘ \xo 23:‏8 \xt أَعَوذ. 11‏:‏22\x*  
\v 9 سِيذِي يُوژّڒْ خْ ڒڭْنُوسْ مْغَارنْ ؤُ جّهْذنْ زَّاثْ إِ وُوذمْ نْومْ. ؤُ خَاومْ كنِّيوْ، أَڒْ أَسّْ-أَ وَارْ ذِينْ حذْ إِ إِزمَّارنْ أَذْ إِبدّْ زَّاثْ إِ وُوذمْ نْومْ.  
\v 10 إِجّْ ن ورْيَازْ زَّايْومْ إِزمَّارْ أَذْ يَاژّڒْ خْ وَاڒفْ \add ن يرْيَازنْ\add*، مِينْزِي سِيذِي، أَربِّي نْومْ سِيمَانْثْ نّسْ، ذ ونِّي إِتّْمنْغَانْ ذِي طّْوعْ نْومْ، أَمْ مَامّشْ ثُوغَا أَكِيذْومْ إِسِّيوڒْ. \x ◘ \xo 23:‏10 \xt لَاوِي 26‏:‏8؛ أَعَوذ. 32‏:‏30\x*  
\v 11 حْضَامْ \add خنِّي\add* أَڒْ طَّارْفْ خْ ڒعْمُورْ نْومْ حِيمَا أَذْ ثخْسمْ سِيذِي، أَربِّي نْومْ.  
\v 12 مِينْزِي مَاڒَا كنِّيوْ ثْحيّْذمْ خَاسْ ؤُڒَا ذ إِشْثْ ن جُّورّثْ \add وَاهَا\add*، ؤُشَا أَذْ ثْڒصْقمْ إِ مِينْ كِيذْومْ إِقِّيمنْ \add عَاذْ\add* ن ڒڭْنُوسْ، إِ يِينِّي كِيومْ إِقِّيمنْ، ؤُشَا أَذْ ثْذوْڒمْ ذ إِضڭّْوَاڒنْ ؤُ أَذْ غَارْسنْ ثَاذْفمْ ؤُ نِيثْنِي أَمْ نّغْنِي،  
\v 13 خنِّي أَذْ ثسّْنمْ نِيشَانْ، أَقَا سِيذِي، أَربِّي نْومْ، وَارْ إِتِّيژّڒْ عَاذْ خْ ڒڭْنُوسْ-أَ زَّاثْ إِ وُوذمْ نْومْ. نِيثْنِي أَذْ ذوْڒنْ ذ ڒْفخْ ذ ثْرَاشَّا إِ كنِّيوْ، ذ \add ثِييِّيثَا س\add* ؤُركُّوضْ خْ إِغزْذِيسنْ نْومْ ذ إِسنَّاننْ إِ ثِيطَّاوِينْ نْومْ، أَڒْ غَا ثتّْوَاثحَّامْ زِي ثمُّورْثْ ثَاصبْحَانْثْ إِ ذ أَومْ إِوْشَا سِيذِي، أَربِّي نْومْ.  
\v 14 خْزَارْ، أَسّْ-أَ نشّْ سِيمَانْثْ إِنُو أَذْ ؤُيُورغْ أَبْرِيذْ ن مَارَّا ثَامُّورْثْ ؤُ كنِّيوْ أَذْ ثسّْنمْ س مَارَّا ؤُڒْ نْومْ ؤُ س مَارَّا ڒعْمَارْ نْومْ، أَقَا ؤُڒَا ذ إِجّْ ن وَاوَاڒْ زِي مَارَّا أَوَاڒنْ إِ خَاومْ إِنَّا سِيذِي، أَربِّي نْومْ، وَارْ د-إِفِّيغْ. مَارَّا فّْغنْ-د خَاومْ، ؤُڒَا ذ إِجّْ ن وَاوَاڒْ وَارْ إِقِّيمْ وَارْ د-إِفِّيغْ.  
\v 15 ؤُشَا أَذْ إِمْسَارْ، أَمْ مَامّشْ خَاومْ د-يُوسَا مَارَّا أَوَاڒْ إِشْنَانْ إِ كِيذْومْ إِسِّيوڒْ سِيذِي، أَربِّي نْومْ، أَمُّو إِ خَاومْ إِ غَا إِسّقْفڒْ سِيذِي ؤُڒَا ذ كُوڒْ أَوَاڒْ إِعفّْننْ أَڒْ نتَّا كنِّيوْ إِثحَّا زِي ثمُّورْثْ-أَ ثَاصبْحَانْثْ إِ ذ أَومْ إِوْشَا سِيذِي، أَربِّي نْومْ.  
\v 16 مَاڒَا كنِّيوْ ثْعدَّامْ خْ ڒْعَاهْذْ ن سِيذِي، أَربِّي نْومْ، \add ڒْعَاهْذْ\add* نِّي خْ ذ أَومْ يُومُورْ نتَّا ؤُشَا كنِّيوْ أَذْ ثُويُورمْ أَذْ ثْعبْذمْ إِ إِربِّيثنْ نّغْنِي ؤُشَا أَذْ أَسنْ ثُوضَارمْ، \add خنِّي\add* أَذْ خَاومْ يَارغْ وغْضَابْ ن سِيذِي ؤُشَا كنِّيوْ أَذْ ثتّْوَاثحَّامْ ذغْيَا زِي ثمُّورْثْ ثَاصبْحَانْثْ إِ ذ أَومْ إِوْشَا نتَّا.   
\b  
\b  
\m  
\c 24
\s1 ثَاجْذِيذْ ن ڒْعَاهْذْ ن إِسْرَائِيل أَكْ-ذ سِيذِي  
\m
\v 1 يَاشُووَا إِسّْمُونْ مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل ذِي شَاكِيمْ ؤُشَا إِڒَاغَا إِ إِمْغَارنْ ن إِسْرَائِيل ذ إِزدْجِيفنْ نْسنْ ذ ڒْقُوضَاثْ نْسنْ ذ إِمحْضَاينْ نْسنْ ؤُشَا نِيثْنِي سّْبدّنْ إِخفْ نْسنْ زَّاثْ إِ وُوذمْ ن أَربِّي.  
\v 2 \add خنِّي\add* إِنَّا يَاشُووَا إِ مَارَّا ڒْڭنْسْ: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’ڒجْذُوذْ نْومْ زدّْغنْ زِي شْحَاڒْ ؤُيَا خْ ؤُجمَّاضْ ن يغْژَارْ \add ن لْفُورَاطْ\add*، ثَارَاحْ، بَابَاسْ ن إِبْرَاهِيمْ ذ بَابَاسْ ن نَاحُورْ، ؤُ نِيثْنِي ثُوغَا تّْسخَّارنْ إِ إِربِّيثنْ نّغْنِي. \x ◘ \xo 24:‏2 \xt أَمز. 11‏:‏26، 31؛ أَعَوذ. 26‏:‏5\x*  
\v 3 \add خنِّي\add* إِوْيغْ-د جذِّيثْومْ إِبْرَاهِيمْ زڭْ ؤُغِيرِينْ إِ إِغْزَارْ \add ن لْفُورَاطْ\add* ؤُ جِّيغْ ث يُويُورْ ذِي مَارَّا ثَامُّورْثْ ن كنْعَانْ. نشّْ أَرْنِيغْ إِ زَّارِيعثْ نّسْ ؤُ وْشِيغْ أَسْ إِسْحَاقْ. \x ◘ \xo 24:‏3 \xt أَمز. 12‏:‏1، 21‏:‏2\x*  
\v 4 إِ إِسْحَاقْ وْشِيغْ يَاعْقُوبْ ذ عِيسُو، ؤُ إِ عِيسُو وْشِيغْ \add ثَامُّورْثْ ن\add* إِذُورَارْ ن سَاعِيرْ ذ ثَاسْغَارْثْ، \add مَاشَا\add* يَاعْقُوبْ ذ إِحنْجِيرنْ نّسْ هْوَانْ غَارْ مِيصْرَا. \x ◘ \xo 24:‏4 \xt أَمز. 25‏:‏24، 36‏:‏8، 46‏:‏1\x*  
\v 5 \add خنِّي\add* سّكّغْ مُوسَا ذ هَارُونْ ؤُشَا وْثِيغْ مِيصْرَا أَمْ مَامّشْ \add ث\add* ڭِّيغْ ذِي ڒْوسْطْ نّسْ ؤُ أَوَارْنِي أَسْ سُّوفّْغغْ-د كنِّيوْ. \x ◘ \xo 24:‏5 \xt ؤُف. 3‏:‏10‏-‏4‏:‏17؛ 12‏:‏37\x*  
\v 6 نشّْ سُّوفّْغغْ-د ڒجْذُوذْ نْومْ زِي مِيصْرَا ؤُ كنِّيوْ ثِيوْضمْ-د غَارْ ڒبْحَارْ ؤُ إِمِيصْرِييّنْ ضْفَارنْ إِبَابَاثنْ نْومْ س إِكَارُّوثنْ ذ إِمْنَاينْ أَڒْ ڒبْحَارْ ن ثلْڭَا. \x ◘ \xo 24:‏6 \xt ؤُف. 14‏:‏1\x*  
\v 7 ؤُشَا سْغُوينْ غَارْ سِيذِي ؤُ نتَّا إِڭَّا ثَادْجسْثْ جَارْ أَومْ ذ إِمِيصْرِييّنْ ؤُشَا إِجَّا ڒبْحَارْ إِسّْفيّضْ خَاسنْ أَڒَامِي ثنْ إِذْڒَا. س ثِيطَّاوِينْ نْومْ ثژْرِيمْ مِينْ ڭِّيغْ ذِي مِيصْرَا. \add أَوَارْنِي أَيَا\add* ثُوغَا ثْزدّْغمْ أَطَّاسْ ن وُوسَّانْ ذِي ڒخْڒَا.  
\v 8 نشّْ إِوْيغْ-د كنِّيوْ غَارْ ثمُّورْثْ ن إِمُورِييّنْ إِ ثُوغَا إِزدّْغنْ أَغِيرِينْ إِ لْ-ؤُرْذُونْ. نِيثْنِي مّنْغنْ أَكِيذْومْ، \add مَاشَا\add* نشّْ ڭِّيغْ ثنْ ذڭْ ؤُفُوسْ نْومْ ؤُ كنِّيوْ ثطّْفمْ ثَامُّورْثْ نْسنْ ؤُ نشّْ قْضِيغْ خَاسنْ زَّاثْ إِ وُوذمْ نْومْ. \x ◘ \xo 24:‏8 \xt ڒخْڒ. 21‏:‏21، 33\x*  
\v 9 \add خنِّي\add* إِكَّارْ بَالَاكْ، مِّيسْ ن سَافُّورْ، أَجدْجِيذْ ن مُوآبَ، ؤُشَا إِمّْنغْ أَكْ-ذ إِسْرَائِيل. نتَّا إِسّكّْ حِيمَا أَذْ ڒَاغَانْ إِ بِيلْعَامْ، مِّيسْ ن بَاعُورْ، مَاحنْذْ أَذْ كنِّيوْ إِنْعڒْ.  
\v 10 \add مَاشَا\add* نشّْ وَارْ خْسغْ أَذْ سْڒغْ إِ بَالْعَامْ. \add س ؤُيَا\add* إِبَاركْ نتَّا إِ كنِّيوْ أَطَّاسْ ؤُ نشّْ فكّغْ-د كنِّيوْ زڭْ ؤُفُوسْ نّسْ.  
\v 11 \add خنِّي\add* ثژْوَامْ لْ-ؤُرْذُونْ، ثُوسِيمْ-د غَارْ أَرِيحَا. إِمزْذَاغْ ن أَرِيحَا، مّنْغنْ أَكِيذْومْ، إِمُورِييّنْ ذ إِفِيرِيزِييّنْ ذ أَيْثْ ن كنْعَانْ ذ إِحِيتِّييّنْ ذ إِجِيرْجَاسِييّنْ ذ إِحِيوِييّنْ ذ إِيابُوسِييّنْ ؤُشَا وْشِيغْ أَومْ ثنْ ذڭْ ؤُفُوسْ نْومْ. \x ◘ \xo 24:‏11 \xt ياش. 3‏:‏14؛ 6‏:‏1، 20؛ 10‏:‏8؛ 11‏:‏8\x*  
\v 12 نشّْ سّكّغْ إِرزَّانْ إِضَارْغَاڒنْ ؤُشَا ؤُژّْڒنْ خَاسنْ زَّاثْومْ، \add أَمْ مَامّشْ تّْوَاژّْڒنْ\add* ثْنَاينْ ن إِجدْجِيذنْ نِّي زَّاثْ إِ وُوذمْ نْومْ. \add ذ مَانْ أَيَا\add* وَارْ إِدْجِي س سِّيفْ نْومْ ؤُڒَا س ڒْقوْسْ نْومْ. \x ◘ \xo 24:‏12 \xt ؤُف. 23‏:‏28؛ أَعَوذ. 7‏:‏20؛ إِزهد. 44‏:‏4\x*  
\v 13 نشّْ وْشِيغْ أَومْ ثَامُّورْثْ إِ خْ وَارْ ثَاربْرمْ ؤُ ثِيندَّامْ نِّي وَارْ ثبْنِيمْ، حِيمَا أَذْ ثْزدّْغمْ ذَايْسنْثْ. ؤُشَا ثشِّيمْ \add عَاوذْ\add* زِي ثْزَايَارِينْ ذ إِزمُّورنْ إِ ثُوغَا وَارْ ثژُّومْ.‘\x ◘ \xo 24:‏13 \xt أَعَوذ. 6‏:‏10، 11، 12\x*  
\v 14 \add خنِّي\add* ڒخُّو، ڭّْوذمْ سِيذِي ؤُشَا سخَّارمْ أَسْ س ڒكْمَارثْ ذ ڒَامَانْ. نْضَارمْ إِربِّيثنْ نِّي ؤُمِي سخَّارنْ ڒجْذُوذْ نْومْ أَغِيرِينْ إِ إِغْزَارْ \add ن لْفُورَاطْ\add* ؤُ ذِي مِيصْرَا ؤُشَا سخَّارمْ إِ سِيذِي.  
\v 15 \add مَاشَا\add* مَاڒَا وَارْ د-ثُوسِي خْ ثِيطَّاوِينْ نْومْ مَاحنْذْ أَذْ ثْسخَّارمْ إِ سِيذِي، خنِّي إِخْضَارمْ أَسّْ-أَ إِ مَانْ ونْ ؤُمِي إِ غَا ثْسخَّارمْ، إِ إِربِّيثنْ نِّي ؤُمِي سخَّارنْ ڒجْذُوذْ نْومْ أَغِيرِينْ إِ إِغْزَارْ \add ن لْفُورَاطْ\add*، نِيغْ إِ إِربِّيثنْ ن إِمُورِييّنْ نِّي ذِي ثمُّورْثْ نْسنْ ثْزدّْغمْ. نشّْ مَاشَا ذ ثَادَّارْثْ إِنُو، نشِّينْ أَذْ نْسخَّارْ إِ سِيذِي!“  
\v 16 \add خنِّي\add* يَارَّا-د ڒْڭنْسْ: ”مَانْ أَيَا إِڭّْوجْ أَنغْ، أَقَا نشِّينْ أَذْ نجّْ سِيذِي أَذْ نخْذمْ إِربِّيثنْ نّغْنِي.  
\v 17 مَاغَارْ سِيذِي ذ أَربِّي نّغْ ذ نتَّا إِ ذ أَنغْ-د إِسّْڭعّْذنْ زِي ثمُّورْثْ ن مِيصْرَا، نشِّينْ ذ ڒجْذُوذْ نّغْ، زِي ثَادَّارْثْ ن ثسْمُوغِي ؤُ نتَّا ذ ونِّي إِڭِّينْ ڒعْڒَامَاثْ ثِيمقّْرَانِينْ زَّاثْ إِ ثِيطَّاوِينْ نّغْ ؤُ نتَّا إِسّْڒقَّا خَانغْ ذِي مَارَّا أَبْرِيذْ إِ نُويُورْ ؤُ جَارْ مَارَّا ڒڭْنُوسْ إِ ؤُمِي نْشُوقْ \add ثَامُّورْثْ نْسنْ\add*.  
\v 18 سِيذِي يُوژّڒْ خْ مَارَّا ڒڭْنُوسْ زَّاثْ إِ وُوذمْ نّغْ، ؤُڒَا خْ إِمُورِييّنْ، إِمزْذَاغْ ن ثمُّورْثْ. ؤُڒَا ذ نشِّينْ أَذْ نْسخَّارْ إِ سِيذِي، مَاغَارْ نتَّا ذ أَربِّي نّغْ.“  
\v 19 \add خنِّي\add* إِنَّا يَاشُووَا إِ ڒْڭنْسْ: ”كنِّيوْ وَارْ ثْزمَّارمْ أَذْ ثْسخَّارمْ إِ سِيذِي، مَاغَارْ نتَّا ذ أَربِّي أَمْقدّسْ أَطَّاسْ ؤُ نتَّا ذ إِجّْ ن أَربِّي إِتَّاسْمنْ. نتَّا وَارْ ذ أَومْ إِغفَّارْ إِخطَّانْ نْومْ ذ دّْنُوبْ نْومْ.  
\v 20 مَاڒَا كنِّيوْ ثجِّيمْ سِيذِي، أَذْ ثْسخَّارمْ إِ إِربِّيثنْ نّغْنِي، \add خنِّي\add* نتَّا أَذْ خَاومْ إِنّقْڒبْ، أَذْ ذ أَومْ إِڭّْ ڒْغَارْ ؤُشَا أَذْ كنِّيوْ إِقْضَا، أَوَارْنِي ڒَامِي نتَّا إِڭَّا أَكِيذْومْ \add قْبڒْ\add* ثَاصبْحَانْثْ.“ \x ◘ \xo 24:‏20 \xt ياش. 23‏:‏15\x*  
\v 21 \add خنِّي\add* إِنَّا ڒْڭنْسْ إِ يَاشُووَا: ”لَّ، مِينْزِي نشِّينْ أَذْ نْسخَّارْ إِ سِيذِي.“  
\v 22 إِنَّا يَاشُووَا إِ ڒْڭنْسْ: ”كنِّيوْ ذ ڒشْهُوذْ خْ إِخفْ نْومْ، أَقَا كنِّيوْ ثْفَارْزمْ سِيذِي، حِيمَا أَذْ أَسْ ثْسخَّارمْ.“ نِيثْنِي نَّانْ ”\add نشِّينْ\add* ذ ڒشْهُوذْ!“  
\v 23 ”\add خنِّي\add* ڒخُّو، نْضَارمْ إِربِّيثنْ إِغْرِيبنْ نِّي \add إِدْجَانْ\add* ذِي ڒْوسْطْ نْومْ ؤُ ثَارّمْ ؤُڒَاونْ نْومْ غَارْ سِيذِي، أَربِّي ن إِسْرَائِيل!“  
\v 24 إِنَّا ڒْڭنْسْ إِ يَاشُووَا: ”نشِّينْ أَذْ نْسخَّارْ إِ سِيذِي، أَربِّي نّغْ، ؤُشَا أَذْ نْسڒْ إِ ثْمِيجَّا نّسْ.“  
\v 25 ذڭْ وَاسّْ نِّي إِڭَّا يَاشُووَا إِجّْ ن ڒْعَاهْذْ أَكْ-ذ ڒْڭنْسْ ؤُشَا إِڭَّا أَسنْ ذِي شَاكِيمْ ثَاوْصيّثْ ذ لْفَارِيضَا. \x ◘ \xo 24:‏25 \xt ؤُف. 15‏:‏25\x*  
\v 26 يُورَا يَاشُووَا أَوَاڒنْ-أَ ذڭْ وذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا ن سِيذِي ؤُشَا نتَّا إِكْسِي إِجّْ ن وژْرُو ذ أَمقّْرَانْ ؤُشَا إِسّْبدّْ إِ-ث ذِي شَاكِيمْ سَاذُو إِشْثْ ن ثْشجَّارْثْ ن يِيڭّْ نِّي إِبدّنْ غَارْ زَّاوشْثْ إِقدّْسنْ ن سِيذِي.  
\v 27 إِنَّا يَاشُووَا إِ مَارَّا ڒْڭنْسْ: ”خْزَارمْ، أَژْرُو-يَا أَذْ خَانغْ يِيڒِي ذ أَشهَّاذْ، مِينْزِي نتَّا إِسْڒَا مَارَّا أَوَاڒنْ ن سِيذِي نِّي كِيذْنغْ إِسِّيوڒْ ؤُ نتَّا أَذْ يِيڒِي ذ أَشهَّاذْ إِ كنِّيوْ حِيمَا وَارْ تّْغشَّامْ أَربِّي نْومْ.“  
\v 28 \add خنِّي\add* يَارْخُو يَاشُووَا إِ ڒْڭنْسْ، كُوڒْ أَرْيَازْ \add إِرُوحْ\add* غَارْ ثسْغَارْثْ نّسْ.   
\b  
\m  
\s1 ڒْموْثْ ن يَاشُووَا ذ أَلِيعَازِيرْ  
\m
\v 29 أَوَارْنِي إِ ثْمسْڒَايِينْ-أَ إِمْسَارْ، بلِّي يَاشُووَا، مِّيسْ ن نُونْ، أَمْسخَّارْ ن سِيذِي، إِمُّوثْ، نتَّا ذ إِجّْ ن مِّيسْ \add ن بْنَاذمْ\add* غَارسْ مْيَا ؤُ -عشْرَا ن إِسڭّْوُوسَا.  
\v 30 نضْڒنْ ث ذِي ثمُّورْثْ ن ثسْغَارْثْ نّسْ ذِي ثِيمْنَاثْ-سَارَاحْ نِّي إِدْجَانْ خْ إِذُورَارْ ن إِفْرَايِيمْ، غَارْ شَّامَالْ ن وذْرَارْ ن جَاعَاشْ. \x ◘ \xo 24:‏30 \xt ياش. 19‏:‏50؛ ڒقض. 2‏:‏9\x*  
\v 31 إِسْرَائِيل إِسخَّارْ إِ سِيذِي مَارَّا ؤُسَّانْ ن يَاشُووَا ذ مَارَّا ؤُسَّانْ ن إِمْغَارنْ نِّي إِقِّيمنْ دَّارنْ إِشْثْ ن ڒْوقْثْ ذ أَزِيرَارْ أَوَارْنِي إِ يَاشُووَا ؤُ سّْننْ مَارَّا مِينْ إِڭَّا سِيذِي ذِي طّْوعْ ن إِسْرَائِيل.  
\v 32 إِخْسَانْ ن يُوسُوفْ إِ ثُوغَا د-إِوْينْ أَكِيذْسنْ أَيْثْ ن إِسْرَائِيل زِي مِيصْرَا، نضْڒنْ ثنْ ذِي شَاكِيمْ ذِي ثْكِيرَاثْ ن ييَّارْ إِ ثُوغَا إِسْغَا يَاعْقُوبْ خْ أَيْثْ ن حَامُورْ، بَابَاسْ ن شَاكِيمْ، س مْيَا ن إِزِييْنَاثْ ن نُّوقَارْثْ إِوزْننْ ؤُشَا ثذْوڒْ ذ ثَاسْغَارْثْ ن أَيْثْ ن يُوسُوفْ. \x ◘ \xo 24:‏32 \xt أَمز. 33‏:‏18‏-‏20؛ أَمز. 50‏:‏25؛ ؤُف. 13‏:‏19\x*  
\v 33 ؤُڒَا ذ أَلِيعَازَارْ، مِّيسْ ن هَارُونْ، إِمُّوثْ ؤُشَا نضْڒنْ ث ذِي ثوْرِيرْثْ ن مِّيسْ ن فِينَاحَاسْ، \add ثَاوْرِيرْثْ\add* إِ ذ أَسْ إِمّوْشنْ \add إِ فِينَاحَاسْ\add* ذڭْ إِذُورَارْ ن إِفْرَايِيمْ.   