\v 3 \w God|strong="H3068"\w* \w looked|strong="H3068"\w* \w at|strong="H3068"\w* everything \w that|strong="H3117"\w* \w was|strong="H3068"\w* happening. \w He|strong="H1931"\w* said, “\w I|strong="H3117"\w* \w gave|strong="H1961"\w* \w people|strong="H1320"\w* \w their|strong="H3068"\w* \w breath|strong="H7307"\w*, \w but|strong="H3808"\w* \w I|strong="H3117"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w let|strong="H3808"\w* \w it|strong="H1931"\w* stay \w in|strong="H8141"\w* \w them|strong="H1961"\w* \w for|strong="H3068"\w* \w ever|strong="H5769"\w*. \w They|strong="H3117"\w* \w are|strong="H3117"\w* \w just|strong="H1571"\w* \w people|strong="H1320"\w*. \w They|strong="H3117"\w* \w will|strong="H3068"\w* \w live|strong="H3117"\w* \w for|strong="H3068"\w* \w only|strong="H1571"\w* 120 \w years|strong="H8141"\w*.”   
\p
\v 4 \w Those|strong="H1992"\w* \w men|strong="H1368"\w* \w that|strong="H3117"\w* \w were|strong="H1961"\w* \w called|strong="H8034"\w* \w the|strong="H3205"\w* \w Sons|strong="H1121"\w* \w of|strong="H1121"\w* God, \w they|strong="H1992"\w* slept \w with|strong="H3117"\w* \w the|strong="H3205"\w* pretty \w women|strong="H1323"\w*, \w like|strong="H1961"\w* \w men|strong="H1368"\w* usually sleep \w with|strong="H3117"\w* \w their|strong="H1992"\w* wives, \w and|strong="H1121"\w* \w then|strong="H1961"\w* \w those|strong="H1992"\w* \w women|strong="H1323"\w* \w had|strong="H1961"\w* \w kids|strong="H1121"\w* \w called|strong="H8034"\w* Nefalim. \w Those|strong="H1992"\w* Nefalim \w kids|strong="H1121"\w* \w grew|strong="H1121"\w* \w up|strong="H3205"\w* \w to|strong="H1961"\w* \w be|strong="H1961"\w* big, \w strong|strong="H1368"\w* fighting \w men|strong="H1368"\w*. \w They|strong="H1992"\w* \w were|strong="H1961"\w* \w the|strong="H3205"\w* \w great|strong="H1368"\w* fighters \w in|strong="H3117"\w* \w the|strong="H3205"\w* stories \w from|strong="H1121"\w* \w a|strong="H3068"\w* \w long|strong="H3117"\w* \w time|strong="H3117"\w* \w ago|strong="H5769"\w*.\x * \xo 6:4 \xt Numbers 13:33\x*   
\s1 People kept on doing bad things  
\p
\v 5 \w God|strong="H3068"\w* \w looked|strong="H7200"\w* \w at|strong="H3068"\w* \w the|strong="H3605"\w* \w people|strong="H7200"\w* \w on|strong="H3117"\w* \w the|strong="H3605"\w* earth, \w and|strong="H3068"\w* \w he|strong="H3588"\w* \w saw|strong="H7200"\w* \w them|strong="H7200"\w* \w doing|strong="H7451"\w* lots \w of|strong="H3068"\w* \w bad|strong="H7451"\w* \w things|strong="H3605"\w*. \w He|strong="H3588"\w* knew \w the|strong="H3605"\w* \w way|strong="H3605"\w* \w they|strong="H3588"\w* \w were|strong="H3117"\w* thinking. \w They|strong="H3588"\w* \w were|strong="H3117"\w* thinking \w bad|strong="H7451"\w* \w things|strong="H3605"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w time|strong="H3117"\w*. \w God|strong="H3068"\w* \w saw|strong="H7200"\w* \w that|strong="H3588"\w* \w the|strong="H3605"\w* \w people|strong="H7200"\w* \w were|strong="H3117"\w* \w very|strong="H7227"\w* \w bad|strong="H7451"\w*.  
