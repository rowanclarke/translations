\v 8 \x - \xo 14.8 \xt Olc 25. 6,7.\x*Te vaengah \w amih|strong="G0848"\w* \w te|strong="G4314"\w*, \wj “ \+w Yuluei|strong="G1062"\+w* kung \+w la|strong="G1519"\+w* hlang \+w khat|strong="G5100"\+w* khat \+w loh|strong="G5259"\+w* \+w n'khue|strong="G2564"\+w* uh \+w vaengah|strong="G3752"\+w*, \+w hmuensang|strong="G4411"\+w* \+w ah|strong="G1519"\+w* \+w ngol|strong="G2625"\+w* uh \+w boeh|strong="G3361"\+w*, \+w anih|strong="G0846"\+w* \+w loh|strong="G5259"\+w* a \+w khue|strong="G2564"\+w* te \+w nang|strong="G4675"\+w* lakah a \+w khoelh|strong="G1784"\+w* la vik \+w om|strong="G5600"\+w* \+w ve|strong="G3379"\+w*\wj*.  
