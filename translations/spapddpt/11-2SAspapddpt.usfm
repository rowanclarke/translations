\p 
\v 23 \w Joab|strong="H3097"\w* \w era|strong="H1121"\w* \w el|strong="H5921"\w* general \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w ejército|strong="H6635"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* \w Benaía|strong="H1141"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Joiada|strong="H3077"\w*, \w era|strong="H1121"\w* comandante \w de|strong="H5921"\w* \w los|strong="H1121"\w* cereteos \w y|strong="H5921"\w* \w los|strong="H1121"\w* peleteos.
