\p 
\v 6 \w Then|strong="H6030"\w* \w he|strong="H3588"\w* \w told|strong="H1697"\w* \w me|strong="H6030"\w*, “\w This|strong="H2088"\w* \w is|strong="H3068"\w* \w the|strong="H3588"\w* \w Lord|strong="H3068"\w*'s \w message|strong="H1697"\w* \w to|strong="H3068"\w* \w Zerubbabel|strong="H2216"\w*: \w Not|strong="H3808"\w* \w by|strong="H3068"\w* \w might|strong="H3581"\w*, \w nor|strong="H3808"\w* \w by|strong="H3068"\w* \w power|strong="H3581"\w*, \w but|strong="H3588"\w* \w by|strong="H3068"\w* \w my|strong="H3068"\w* \w spirit|strong="H7307"\w*, \w says|strong="H1697"\w* \w the|strong="H3588"\w* \w Lord|strong="H3068"\w* \w Almighty|strong="H6635"\w*.
\v 7 Even obstacles \w as|strong="H3318"\w* big \w as|strong="H3318"\w* \w mountains|strong="H2022"\w* \w will|strong="H4310"\w* \w be|strong="H2022"\w* flattened \w before|strong="H6440"\w* \w Zerubbabel|strong="H2216"\w*. Finally \w he|strong="H6440"\w* \w will|strong="H4310"\w* \w bring|strong="H3318"\w* \w out|strong="H3318"\w* \w the|strong="H6440"\w* capstone\f + \fr 4:7 \ft Probably meaning the topmost stone of the rebuilt Temple. \f* \w to|strong="H3318"\w* \w shouts|strong="H8663"\w* \w of|strong="H2022"\w* ‘Blessings \w on|strong="H3318"\w* \w it|strong="H6440"\w*!’”
\p 
\v 8 \w Then|strong="H1961"\w* \w the|strong="H3068"\w* \w Lord|strong="H3068"\w* \w gave|strong="H1961"\w* \w me|strong="H1697"\w* another \w message|strong="H1697"\w*.
\v 9 \w Zerubbabel|strong="H2216"\w* \w with|strong="H1004"\w* \w his|strong="H3068"\w* \w own|strong="H3027"\w* \w hands|strong="H3027"\w* \w laid|strong="H3245"\w* \w the|strong="H3588"\w* \w foundations|strong="H3245"\w* \w for|strong="H3588"\w* \w this|strong="H2088"\w* \w Temple|strong="H1004"\w*, \w and|strong="H3068"\w* \w it|strong="H3588"\w* \w will|strong="H3068"\w* \w be|strong="H3027"\w* \w completed|strong="H1214"\w* \w the|strong="H3588"\w* \w same|strong="H2088"\w* \w way|strong="H7971"\w*. \w Then|strong="H2088"\w* \w you|strong="H3588"\w*\f + \fr 4:9 \ft “You” here is singular, and so is taken to mean Zerubbabel.\f* \w will|strong="H3068"\w* \w know|strong="H3045"\w* \w the|strong="H3588"\w* \w Lord|strong="H3068"\w* \w Almighty|strong="H6635"\w* \w has|strong="H3068"\w* \w sent|strong="H7971"\w* \w me|strong="H7971"\w*.
\v 10 \w For|strong="H3588"\w* \w who|strong="H4310"\w* dares \w look|strong="H7200"\w* \w down|strong="H3027"\w* \w on|strong="H3117"\w* \w this|strong="H7200"\w* \w time|strong="H3117"\w* \w of|strong="H3068"\w* \w small|strong="H6996"\w* \w beginnings|strong="H3117"\w*? \w They|strong="H1992"\w* \w will|strong="H3068"\w* \w be|strong="H3027"\w* \w happy|strong="H8055"\w* \w when|strong="H3588"\w* \w they|strong="H1992"\w* \w see|strong="H7200"\w* \w the|strong="H3605"\w* plumb line \w in|strong="H3068"\w* \w Zerubbabel|strong="H2216"\w*'s \w hand|strong="H3027"\w*.
\p “\w The|strong="H3605"\w* \w seven|strong="H7651"\w* lamps represent \w the|strong="H3605"\w* \w eyes|strong="H5869"\w* \w of|strong="H3068"\w* \w the|strong="H3605"\w* \w Lord|strong="H3068"\w* \w which|strong="H3068"\w* \w see|strong="H7200"\w* \w all|strong="H3605"\w* \w over|strong="H3027"\w* \w the|strong="H3605"\w* world.”\f + \fr 4:10 \ft The angel is answering his own question from \xt 4:5\xt*\ft regarding the meaning of the lamps.\f*
\p 
\v 11 \w Then|strong="H6030"\w* \w I|strong="H5921"\w* \w asked|strong="H4100"\w* \w the|strong="H5921"\w* angel, “\w What|strong="H4100"\w* \w are|strong="H4100"\w* \w the|strong="H5921"\w* \w two|strong="H8147"\w* \w olive|strong="H2132"\w* \w trees|strong="H2132"\w* \w that|strong="H5921"\w* stand \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w right|strong="H3225"\w* \w and|strong="H6030"\w* \w the|strong="H5921"\w* \w left|strong="H8040"\w* \w of|strong="H5921"\w* \w the|strong="H5921"\w* \w lampstand|strong="H4501"\w*?”
\v 12 \w And|strong="H6030"\w* \w I|strong="H5921"\w* \w also|strong="H3027"\w* \w asked|strong="H4100"\w* \w him|strong="H5921"\w*, “\w What|strong="H4100"\w* \w are|strong="H3027"\w* \w the|strong="H5921"\w* \w two|strong="H8147"\w* \w olive|strong="H2132"\w* \w branches|strong="H7641"\w* \w from|strong="H5921"\w* \w which|strong="H4100"\w* \w the|strong="H5921"\w* \w golden|strong="H2091"\w* \w oil|strong="H7324"\w* pours \w out|strong="H7324"\w* \w from|strong="H5921"\w* \w through|strong="H3027"\w* \w golden|strong="H2091"\w* \w pipes|strong="H6804"\w*?”
\p 
\v 13 “Don't \w you|strong="H3045"\w* \w know|strong="H3045"\w*?” \w the|strong="H3045"\w* angel replied.
\p “\w No|strong="H3808"\w*, \w my|strong="H3045"\w* lord,” \w I|strong="H3045"\w* responded.
\p 
\v 14 “\w These|strong="H8147"\w* \w are|strong="H1121"\w* \w the|strong="H3605"\w* \w two|strong="H8147"\w* \w who|strong="H3605"\w* \w have|strong="H1121"\w* \w been|strong="H3605"\w* \w anointed|strong="H3323"\w*\f + \fr 4:14 \ft The identity of these two beings is debated. Some see them as heavenly beings, while others identify them as Joshua and Zerubbabel.\f* \w who|strong="H3605"\w* \w stand|strong="H5975"\w* \w by|strong="H5921"\w* \w the|strong="H3605"\w* Lord \w of|strong="H1121"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* earth,” \w he|strong="H3605"\w* replied.
\b
\c 5
\p 
\v 1 \w I|strong="H2009"\w* \w looked|strong="H7200"\w* \w again|strong="H7725"\w* \w and|strong="H7725"\w* \w saw|strong="H7200"\w* \w a|strong="H3068"\w* \w flying|strong="H5774"\w* \w scroll|strong="H4039"\w*.
\p 
\v 2 “\w What|strong="H4100"\w* \w do|strong="H4100"\w* \w you|strong="H4100"\w* \w see|strong="H7200"\w*?” \w asked|strong="H4100"\w* \w the|strong="H7200"\w* \w angel|strong="H5774"\w*.
\p “\w I|strong="H7200"\w* \w see|strong="H7200"\w* \w a|strong="H3068"\w* \w flying|strong="H5774"\w* \w scroll|strong="H4039"\w*,” \w I|strong="H7200"\w* replied. “\w It|strong="H7200"\w*'s thirty feet \w long|strong="H4100"\w* \w and|strong="H6242"\w* fifteen feet \w wide|strong="H7341"\w*.”\f + \fr 5:2 \ft Literally, “Twenty cubits in length and ten cubits in width.”\f*
\p 
\v 3 \w He|strong="H3588"\w* told \w me|strong="H6440"\w*, “\w This|strong="H2088"\w* \w is|strong="H2088"\w* \w the|strong="H3605"\w* \w curse|strong="H7650"\w* \w that|strong="H3588"\w* \w is|strong="H2088"\w* \w going|strong="H3318"\w* \w out|strong="H3318"\w* \w to|strong="H3318"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* world. \w Anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w steals|strong="H1589"\w* \w will|strong="H2088"\w* \w be|strong="H6440"\w* \w purged|strong="H5352"\w*\f + \fr 5:3 \ft Or “cut off.”\f* \w from|strong="H3318"\w* society, \w according|strong="H5921"\w* \w to|strong="H3318"\w* \w one|strong="H2088"\w* \w side|strong="H2088"\w* \w of|strong="H6440"\w* \w the|strong="H3605"\w* scroll. \w Anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w swears|strong="H7650"\w* lies \w under|strong="H5921"\w* \w oath|strong="H7650"\w* \w will|strong="H2088"\w* \w be|strong="H6440"\w* \w purged|strong="H5352"\w* \w from|strong="H3318"\w* society, \w according|strong="H5921"\w* \w to|strong="H3318"\w* \w the|strong="H3605"\w* \w other|strong="H2088"\w* \w side|strong="H2088"\w* \w of|strong="H6440"\w* \w the|strong="H3605"\w* scroll.”\f + \fr 5:3 \ft One side of the scroll/other side. This is the commonest understanding of the meaning here, but there are other interpretations. \f*
\p 
