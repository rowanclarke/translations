\mt1 Proverbios  
\c 1
\m
\v 1 \w LOS|strong="H1121"\w* \w proverbios|strong="H4912"\w* \w de|strong="H1121"\w* \w Salomón|strong="H8010"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*:   
\m
\v 2 Para entender \w sabiduría|strong="H2451"\w* y \w la|strong="H2451"\w* ins­trucción; para conocer las palabras de entendimiento;   
\m
\v 3 Para \w recibir|strong="H3947"\w* la instrucción de sabiduría, \w justicia|strong="H6664"\w*, y \w juicio|strong="H4941"\w* y equi­\w dad|strong="H3947"\w*;   
\m
\v 4 \w Para|strong="H5414"\w* \w dar|strong="H5414"\w* sagacidad \w a|strong="H3068"\w* los \w simples|strong="H6612"\w*, y \w a|strong="H3068"\w* los jóvenes \w conocimiento|strong="H1847"\w* y discreción.   
\m
\v 5 \w Oirá|strong="H8085"\w* el \w sabio|strong="H2450"\w*, y \w aumentará|strong="H3254"\w* el saber; y el hombre de entendimiento \w adquirirá|strong="H7069"\w* consejos \w sabios|strong="H2450"\w*;   
\m
\v 6 Para entender un proverbio y la interpretación; las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* \w sabios|strong="H2450"\w*, y sus dichos oscuros.   
\m
\v 7 El \w temor|strong="H3374"\w* del \w SEÑOR|strong="H3068"\w* \add es e\add*l \w principio|strong="H7225"\w* del \w conocimiento|strong="H1847"\w*: \add pero\add* los insen­satos desprecian \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* y \w la|strong="H2451"\w* instrucción.   
\m
\v 8 \w Oye|strong="H8085"\w*, \w hijo|strong="H1121"\w* mío, la instrucción \w de|strong="H1121"\w* tu padre, y no \w desprecies|strong="H5203"\w* la \w ley|strong="H8451"\w* \w de|strong="H1121"\w* tu madre:   
\m
\v 9 \w Porque|strong="H3588"\w* \w adorno|strong="H3880"\w* \w de|strong="H3588"\w* \w gracia|strong="H2580"\w* \w serán|strong="H1992"\w* \w a|strong="H3068"\w* tu \w cabeza|strong="H7218"\w*, \w y|strong="H3588"\w* collares \w a|strong="H3068"\w* tu cuello.   
\m
\v 10 \w Hijo|strong="H1121"\w* mío, si \w los|strong="H1121"\w* \w pecadores|strong="H2400"\w* te incitaren, no consientas.   
\m
\v 11 Si dijeren: \w Ven|strong="H3212"\w* con nosotros, pongamos asechanzas para \add derramar\add* \w sangre|strong="H1818"\w*, \w acechemos|strong="H6845"\w* secretamente al \w inocente|strong="H5355"\w*;   
\m
\v 12 Los tragaremos \w vivos|strong="H2416"\w* como el \w sepulcro|strong="H7585"\w*, y enteros, como los que caen al abismo;   
\m
\v 13 \w Hallaremos|strong="H4672"\w* \w toda|strong="H3605"\w* sustancia \w preciosa|strong="H3368"\w*, henchiremos nuestras \w casas|strong="H1004"\w* de \w despojos|strong="H7998"\w*;   
\m
\v 14 \w Echa|strong="H5307"\w* tu \w suerte|strong="H1486"\w* \w entre|strong="H8432"\w* \w nosotros|strong="H3605"\w*; \w tengamos|strong="H1961"\w* \w todos|strong="H3605"\w* una \w bolsa|strong="H3599"\w*:   
\m
\v 15 \w Hijo|strong="H1121"\w* mío, \w no|strong="H1870"\w* \w andes|strong="H3212"\w* \w en|strong="H3212"\w* \w camino|strong="H1870"\w* con ellos; \w aparta|strong="H4513"\w* tu \w pie|strong="H7272"\w* \w de|strong="H1121"\w* sus \w veredas|strong="H5410"\w*:   
\m
\v 16 \w Porque|strong="H3588"\w* sus \w pies|strong="H7272"\w* \w correrán|strong="H7323"\w* al \w mal|strong="H7451"\w*, \w y|strong="H3588"\w* hacen prisa \w para|strong="H3588"\w* derramar \w sangre|strong="H1818"\w*.   
\m
\v 17 \w Porque|strong="H3588"\w* \w en|strong="H3588"\w* \w vano|strong="H2600"\w* está tendida \w la|strong="H3605"\w* \w red|strong="H7568"\w* ante \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w ave|strong="H1167"\w*;   
\m
\v 18 \w Y|strong="H3068"\w* \w ellos|strong="H1992"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* \add propia\add* \w sangre|strong="H1818"\w* ponen asechanzas, y acechan secretamente por \w sus|strong="H1992"\w* \add propias\add* \w vidas|strong="H5315"\w*.   
\m
\v 19 \w Tales|strong="H3651"\w* \add son\add* las sendas de \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H3605"\w* es dado \w a|strong="H3068"\w* \w la|strong="H3605"\w* codicia, \add que\add* \w quita|strong="H3947"\w* \w la|strong="H3605"\w* \w vida|strong="H5315"\w* de sus poseedo­res.   
\m
\v 20 La \w sabiduría|strong="H2454"\w* \w clama|strong="H7442"\w* \w de|strong="H5414"\w* \w fuera|strong="H2351"\w*, \w da|strong="H5414"\w* su \w voz|strong="H6963"\w* en las \w calles|strong="H7339"\w*:   
\m
\v 21 \w Clama|strong="H7121"\w* ella en los \w principales|strong="H7218"\w* \w lugares|strong="H5892"\w* de concurso; en las entra­das de las \w puertas|strong="H8179"\w* de la \w ciudad|strong="H5892"\w* dice sus razones \add diciendo\add*:   
\m
\v 22 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w*, oh \w simples|strong="H6612"\w*, amaréis la simpleza, \w y|strong="H5704"\w* \w los|strong="H1992"\w* \w burladores|strong="H3944"\w* desearán \w el|strong="H1992"\w* burlar, \w y|strong="H5704"\w* \w los|strong="H1992"\w* insensatos \w aborrecerán|strong="H8130"\w* \w el|strong="H1992"\w* conoci­miento?   
\m
\v 23 \w Volveos|strong="H7725"\w* \w a|strong="H3068"\w* \w mi|strong="H2009"\w* \w reprensión|strong="H8433"\w*: he \w aquí|strong="H2009"\w* \w yo|strong="H2009"\w* os derramaré \w mi|strong="H2009"\w* \w espíritu|strong="H7307"\w*, y os haré \w saber|strong="H3045"\w* mis \w palabras|strong="H1697"\w*.   
\m
\v 24 \w Por|strong="H3282"\w* \w cuanto|strong="H3282"\w* he \w llamado|strong="H7121"\w*, y \w no|strong="H3985"\w* quisis­teis; he \w extendido|strong="H5186"\w* mi \w mano|strong="H3027"\w*, y \w no|strong="H3985"\w* hubo quien escuchase;   
\m
\v 25 Antes desechasteis \w todo|strong="H3605"\w* con­sejo mío, y mi \w reprensión|strong="H8433"\w* \w no|strong="H3808"\w* qui­sisteis:   
\m
\v 26 \w También|strong="H1571"\w* yo me reiré en vues­tra calamidad, \w y|strong="H1571"\w* me burlaré \w cuando|strong="H1571"\w* \add os\add* viniere lo \w que|strong="H1571"\w* teméis;   
\m
\v 27 Cuando viniere \w como|strong="H5921"\w* una destrucción \w lo|strong="H5921"\w* \w que|strong="H5921"\w* teméis, \w y|strong="H5921"\w* vuestra calamidad llegare \w como|strong="H5921"\w* un \w torbellino|strong="H5492"\w*; cuando \w sobre|strong="H5921"\w* vosotros viniere \w tribulación|strong="H6869"\w* \w y|strong="H5921"\w* \w angustia|strong="H6869"\w*.   
\m
\v 28 Entonces me \w llamarán|strong="H7121"\w*, y \w no|strong="H3808"\w* \w responderé|strong="H6030"\w*; \w buscarme|strong="H7836"\w* han de mañana, y \w no|strong="H3808"\w* me hallarán:   
\m
\v 29 \w Por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w aborrecieron|strong="H8130"\w* \w el|strong="H3588"\w* \w conocimiento|strong="H1847"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* escogieron \w el|strong="H3588"\w* \w temor|strong="H3374"\w* del \w SEÑOR|strong="H3068"\w*,   
\m
\v 30 \w Ni|strong="H3808"\w* quisieron \w nada|strong="H3808"\w* mi \w consejo|strong="H6098"\w*, y menospreciaron \w toda|strong="H3605"\w* \w reprensión|strong="H8433"\w* mía:   
\m
\v 31 Comerán pues del \w fruto|strong="H6529"\w* \w de|strong="H7646"\w* su propio \w camino|strong="H1870"\w*, y se hartarán \w de|strong="H7646"\w* sus pro­pios \w consejos|strong="H4156"\w*.   
\m
\v 32 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* descarrío \w de|strong="H3588"\w* \w los|strong="H3588"\w* igno­rantes \w los|strong="H3588"\w* \w matará|strong="H2026"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* prosperi­dad \w de|strong="H3588"\w* \w los|strong="H3588"\w* necios \w los|strong="H3588"\w* destruirá.   
\m
\v 33 Mas el \w que|strong="H6343"\w* me \w oyere|strong="H8085"\w*, \w habita|strong="H7931"\w*­rá confiadamente, y vivirá repo­sado, sin \w temor|strong="H6343"\w* \w de|strong="H7451"\w* \w mal|strong="H7451"\w*.   
\c 2
\m
\v 1 \w HIJO|strong="H1121"\w* mío, si recibieres mis palabras, y mis \w mandamientos|strong="H4687"\w* \w guardares|strong="H6845"\w* dentro \w de|strong="H1121"\w* ti.   
\m
\v 2 Para que inclines tu oído \w a|strong="H3068"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*; \add si\add* \w inclinares|strong="H5186"\w* tu cora­zón al \w entendimiento|strong="H3820"\w*;   
\m
\v 3 \w Si|strong="H3588"\w* \w clamares|strong="H7121"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* conocimien­to, \add y\add* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w entendimiento|strong="H8394"\w* \w dieres|strong="H5414"\w* tu \w voz|strong="H6963"\w*;   
\m
\v 4 Si como \w a|strong="H3068"\w* la \w plata|strong="H3701"\w* lo \w buscares|strong="H1245"\w*, y lo escudriñares como \w a|strong="H3068"\w* \w tesoros|strong="H4301"\w*;   
\m
\v 5 Entonces entenderás el \w temor|strong="H3374"\w* del \w SEÑOR|strong="H3068"\w*, y \w hallarás|strong="H4672"\w* el conoci­miento de \w Dios|strong="H3068"\w*.   
\m
\v 6 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* \w da|strong="H5414"\w* \w la|strong="H2451"\w* sabi­duría, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w boca|strong="H6310"\w* \add viene\add* \w el|strong="H3588"\w* cono­cimiento \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w entendimiento|strong="H8394"\w*.   
\m
\v 7 Él atesora de sólida \w sabiduría|strong="H8454"\w* para los \w rectos|strong="H3477"\w*: \add es\add* \w escudo|strong="H4043"\w* \w a|strong="H3068"\w* los que \w caminan|strong="H1980"\w* rectamente.   
\m
\v 8 \add Es\add* el que \w guarda|strong="H8104"\w* las veredas del \w juicio|strong="H4941"\w*, y preserva el \w camino|strong="H1870"\w* de sus \w santos|strong="H2623"\w*.   
\m
\v 9 Entonces entenderás \w justicia|strong="H6664"\w*, \w juicio|strong="H4941"\w*, y equidad, y \w todo|strong="H3605"\w* \w buen|strong="H2896"\w* \w camino|strong="H4570"\w*.   
\m
\v 10 \w Cuando|strong="H3588"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* entrare \w en|strong="H3588"\w* tu \w corazón|strong="H3820"\w*, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w conocimiento|strong="H1847"\w* fuere agradable \w a|strong="H3068"\w* tu \w alma|strong="H5315"\w*,   
\m
\v 11 \w La|strong="H5921"\w* discreción \w te|strong="H5921"\w* preservará, \w te|strong="H5921"\w* \w guardará|strong="H8104"\w* \w el|strong="H5921"\w* \w entendimiento|strong="H8394"\w*:   
\m
\v 12 Para librarte del \w camino|strong="H1870"\w* del \add hombre\add* \w malo|strong="H7451"\w*, \w de|strong="H7451"\w* los hombres que \w hablan|strong="H1696"\w* per­versidades;   
\m
\v 13 Que dejan las sendas dere­chas, \w por|strong="H1870"\w* \w andar|strong="H3212"\w* \w en|strong="H3212"\w* \w caminos|strong="H1870"\w* tene­brosos;   
\m
\v 14 Que se regocijan \w haciendo|strong="H6213"\w* \w mal|strong="H7451"\w*, \add y\add* que se deleitan en las perversida­des \w de|strong="H7451"\w* los \w malos|strong="H7451"\w*;   
\m
\v 15 Cuyas veredas \add son\add* torcidas, y torcidos sus \w caminos|strong="H4570"\w*.   
\m
\v 16 Para librarte de la mujer \w extraña|strong="H5237"\w*, \add aun\add* de la \w ajena|strong="H5237"\w* que halaga con sus palabras;   
\m
\v 17 Que \w desampara|strong="H5800"\w* el príncipe \w de|strong="H7911"\w* su \w mocedad|strong="H5271"\w*, y se olvida del \w pacto|strong="H1285"\w* \w de|strong="H7911"\w* su Dios.   
\m
\v 18 \w Por|strong="H3588"\w* lo \w cual|strong="H3588"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w* está incli­nada \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w*, \w y|strong="H3588"\w* sus veredas hacia \w los|strong="H3588"\w* \w muertos|strong="H7496"\w*:   
\m
\v 19 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3808"\w* \w a|strong="H3068"\w* \w ella|strong="H3605"\w* entraren, \w no|strong="H3808"\w* \w volverán|strong="H7725"\w*, \w ni|strong="H3808"\w* \w tomarán|strong="H5381"\w* las vere­das de \w la|strong="H3605"\w* \w vida|strong="H2416"\w*.   
\m
\v 20 \w Para|strong="H4616"\w* \w que|strong="H4616"\w* \w andes|strong="H3212"\w* \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* \w de|strong="H6662"\w* los \w buenos|strong="H2896"\w*, y \w guardes|strong="H8104"\w* las veredas \w de|strong="H6662"\w* los \w justos|strong="H6662"\w*.   
\m
\v 21 \w Porque|strong="H3588"\w* \w los|strong="H3588"\w* \w rectos|strong="H3477"\w* \w habitarán|strong="H7931"\w* \w la|strong="H3588"\w* tierra, \w y|strong="H3588"\w* \w los|strong="H3588"\w* perfectos permanece­rán \w en|strong="H8549"\w* ella;   
\m
\v 22 \w Mas|strong="H4480"\w* los \w impíos|strong="H7563"\w* serán cortados \w de|strong="H4480"\w* la tierra, y los transgresores serán \w de|strong="H4480"\w* \w ella|strong="H4480"\w* desarraigados.   
\c 3
\m
\v 1 \w HIJO|strong="H1121"\w* mío, no te \w olvides|strong="H7911"\w* \w de|strong="H1121"\w* mi \w ley|strong="H8451"\w*; y tu \w corazón|strong="H3820"\w* \w guarde|strong="H5341"\w* mis \w mandamientos|strong="H4687"\w*:   
\m
\v 2 \w Porque|strong="H3588"\w* largura \w de|strong="H3588"\w* \w días|strong="H3117"\w*, \w y|strong="H3588"\w* \w años|strong="H8141"\w* \w de|strong="H3588"\w* \w vida|strong="H2416"\w* \w y|strong="H3588"\w* \w paz|strong="H7965"\w* \w te|strong="H3588"\w* \w añadirán|strong="H3254"\w*.   
\m
\v 3 \w Misericordia|strong="H2617"\w* \w y|strong="H5921"\w* verdad \w no|strong="H5921"\w* \w te|strong="H5921"\w* desamparen; \w átalas|strong="H7194"\w* \w a|strong="H3068"\w* tu cuello, \w escríbelas|strong="H3789"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tabla \w de|strong="H5921"\w* tu cora­zón:   
\m
\v 4 Así \w hallarás|strong="H4672"\w* \w gracia|strong="H2580"\w* y \w buen|strong="H2896"\w* \w entendimiento|strong="H7922"\w* en los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* Dios y \w de|strong="H5869"\w* los hombres.   
\m
\v 5 Confía en \w el|strong="H3605"\w* \w SEÑOR|strong="H3068"\w* de \w todo|strong="H3605"\w* tu \w corazón|strong="H3820"\w*, y no estribes en tu \w entendimiento|strong="H3820"\w*.   
\m
\v 6 \w Reconócelo|strong="H3045"\w* en \w todos|strong="H3605"\w* tus \w caminos|strong="H1870"\w*, y \w él|strong="H1931"\w* \w enderezará|strong="H3474"\w* tus veredas.   
\m
\v 7 \w No|strong="H1961"\w* \w seas|strong="H1961"\w* \w sabio|strong="H2450"\w* \w en|strong="H5493"\w* tus propios \w ojos|strong="H5869"\w*: \w teme|strong="H3372"\w* al \w SEÑOR|strong="H3068"\w*, y \w apártate|strong="H5493"\w* del \w mal|strong="H7451"\w*;   
\m
\v 8 Porque \w será|strong="H1961"\w* \w medicina|strong="H7500"\w* \w a|strong="H3068"\w* tu \w ombligo|strong="H8270"\w*, y tuétano \w a|strong="H3068"\w* tus \w huesos|strong="H6106"\w*.   
\m
\v 9 \w Honra|strong="H3513"\w* al \w SEÑOR|strong="H3068"\w* con tu sustancia, y con las \w primicias|strong="H7225"\w* de \w todos|strong="H3605"\w* tus \w frutos|strong="H8393"\w*;   
\m
\v 10 Así serán \w llenos|strong="H4390"\w* tus graneros con abundancia, y tus lagares rebosa­rán de \w mosto|strong="H8492"\w*.   
\m
\v 11 No \w deseches|strong="H3988"\w*, \w hijo|strong="H1121"\w* mío, \w el|strong="H1121"\w* cas­tigo del \w SEÑOR|strong="H3068"\w*; ni te fatigues \w de|strong="H1121"\w* su \w corrección|strong="H4148"\w*:   
\m
\v 12 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* al \w que|strong="H3588"\w* ama \w castiga|strong="H3198"\w*, \w como|strong="H3588"\w* \w el|strong="H3588"\w* padre al \w hijo|strong="H1121"\w* \add a quien\add* quiere.   
\m
\v 13 Bienaventurado \add es\add* el hombre \add que\add* \w halla|strong="H4672"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*, y que obtiene el \w entendimiento|strong="H8394"\w*:   
\m
\v 14 \w Porque|strong="H3588"\w* \w su|strong="H3588"\w* mercadería \add es\add* \w mejor|strong="H2896"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* mercadería \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w plata|strong="H3701"\w*, \w y|strong="H3588"\w* sus \w frutos|strong="H8393"\w* \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* oro fino.   
\m
\v 15 \w Más|strong="H3808"\w* \w preciosa|strong="H3368"\w* \add es\add* \w que|strong="H1931"\w* \w los|strong="H3605"\w* rubí­\w es|strong="H1931"\w*; y \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* puedes desear, \w no|strong="H3808"\w* \w se|strong="H1931"\w* puede comparar \w a|strong="H3068"\w* \w ella|strong="H1931"\w*.   
\m
\v 16 Largura de \w días|strong="H3117"\w* \add está\add* en su mano \w derecha|strong="H3225"\w* \add y\add*; en su \w izquierda|strong="H8040"\w* \w riquezas|strong="H6239"\w* \w y|strong="H3519"\w* \w honra|strong="H3519"\w*.   
\m
\v 17 Sus \w caminos|strong="H1870"\w* \add son\add* \w caminos|strong="H1870"\w* \w deleitosos|strong="H5278"\w*, y \w todas|strong="H3605"\w* sus \w veredas|strong="H5410"\w* \w paz|strong="H7965"\w*.   
\m
\v 18 \w Ella|strong="H1931"\w* \add es\add* \w árbol|strong="H6086"\w* de \w vida|strong="H2416"\w* \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w que|strong="H1931"\w* de \w ella|strong="H1931"\w* toman: y bienaventurados \add son todos\add* \w los|strong="H1931"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* retienen.   
\m
\v 19 El \w SEÑOR|strong="H3068"\w* con \w sabiduría|strong="H2451"\w* ha fundado \w la|strong="H2451"\w* tierra; estableció los cie­los con \w entendimiento|strong="H8394"\w*.   
\m
