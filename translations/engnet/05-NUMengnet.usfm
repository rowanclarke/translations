\p
\v 6  \w The|strong="H8085"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w said|strong="H1696"\w*, “\w Hear|strong="H8085"\w* \w now|strong="H4994"\w* \w my|strong="H8085"\w* \w words|strong="H1697"\w*: \w If|strong="H1961"\w* \w there|strong="H1961"\w* \w is|strong="H3068"\w* \w a|strong="H3068"\w* \w prophet|strong="H5030"\w* among \w you|strong="H3045"\w*, \w I|strong="H1697"\w* \w the|strong="H8085"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w will|strong="H3068"\w* \w make|strong="H3045"\w* \w myself|strong="H3045"\w* \w known|strong="H3045"\w* \w to|strong="H1696"\w* \w him|strong="H3045"\w* \w in|strong="H3068"\w* \w a|strong="H3068"\w* \w vision|strong="H4759"\w*; \w I|strong="H1697"\w* \w will|strong="H3068"\w* \w speak|strong="H1696"\w* \w with|strong="H3068"\w* \w him|strong="H3045"\w* \w in|strong="H3068"\w* \w a|strong="H3068"\w* \w dream|strong="H2472"\w*.  
\v 7  \w My|strong="H3605"\w* \w servant|strong="H5650"\w* \w Moses|strong="H4872"\w* \w is|strong="H1931"\w* \w not|strong="H3808"\w* \w like|strong="H3651"\w* \w this|strong="H3651"\w*; \w he|strong="H1931"\w* \w is|strong="H1931"\w* faithful \w in|strong="H1004"\w* \w all|strong="H3605"\w* \w my|strong="H3605"\w* \w house|strong="H1004"\w*.  
\v 8  \w With|strong="H3068"\w* \w him|strong="H4872"\w* \w I|strong="H5650"\w* \w will|strong="H3068"\w* \w speak|strong="H1696"\w* \w face|strong="H6310"\w* \w to|strong="H1696"\w* \w face|strong="H6310"\w*, \w openly|strong="H4758"\w*, \w and|strong="H4872"\w* \w not|strong="H3808"\w* \w in|strong="H3068"\w* \w riddles|strong="H2420"\w*; \w and|strong="H4872"\w* \w he|strong="H3068"\w* \w will|strong="H3068"\w* \w see|strong="H5027"\w* \w the|strong="H3068"\w* \w form|strong="H8544"\w* \w of|strong="H3068"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd*. \w Why|strong="H4069"\w* \w then|strong="H1696"\w* \w were|strong="H5650"\w* \w you|strong="H3808"\w* \w not|strong="H3808"\w* \w afraid|strong="H3372"\w* \w to|strong="H1696"\w* \w speak|strong="H1696"\w* \w against|strong="H1696"\w* \w my|strong="H3068"\w* \w servant|strong="H5650"\w* \w Moses|strong="H4872"\w*?”  
\v 9  \w The|strong="H3068"\w* anger \w of|strong="H3068"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w burned|strong="H2734"\w* \w against|strong="H2734"\w* \w them|strong="H3068"\w*, \w and|strong="H3068"\w* \w he|strong="H3068"\w* \w departed|strong="H3212"\w*.  
