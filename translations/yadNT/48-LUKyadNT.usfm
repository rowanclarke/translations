\id LUK - Yagua NT -Peru 2008 (web -2013) 
\h Dúcasiy 
\toc1 Samitu̱choda Sanu̱yada Ducasiy Jesucristunchiy 
\toc2 Dúcasiy 
\toc3 Du 
\mt1 Samitu̱choda Sanu̱yada Ducasiy Jesucristunchiy 
\c 1  
\s1 Ramyu̱chuvay samiy ji, Jaamyi Tiyójinu 
\p  
\v 1-2 Jiryatiy rirya̱ntya tavajyuu jdutya̱dara tu̱choda ranchiy ti̱ta̱ju̱ jiryatiy jto̱tanichara nu̱quebyimu darya, daryani̱ nu̱ñi̱mutya̱ ruumusiy jiryatiy rajo̱ta̱damusiy rivyichanu̱yada Jesucrístujsa̱ rupivye, saniquejada tu̱chuvay jarye risa̱ju̱riy.  
\v 3 Daryatiy radyetyatityiyada rajo̱ttya̱musiy sivaayadanchiy Jesús, rajechipiya̱jada variy samirya dyetya ra̱nu̱y vatadeca̱ jiijyu̱ra, Jaamyi Tiyójinu.  
\v 4 Rañu̱rya ya̱tidye datya ramusiy, si̱tenuni̱viy rani̱cha tavay datyadoda jiryatiy jityuva̱chu dyetya ranchiy. 
\s1 Juán Ji̱tyanu̱ rupedanchiy 
\p  
\v 5 Savichanu̱yadanumatiy Jeródesbe Judéya mucadi nutyityu̱, variy savichanu̱yada nu̱ vanu, Sacaryé jtyati̱bay, Abíyabavyeda tenu, ni̱tiy jvaañu̱yada Ju̱denu mo̱mu. Savatura Chabédabay jarye vichanu̱yada Arú̱bay ju̱débi, Ju̱denu mo̱mu jvaavye tenuntiy.  
\v 6 Nanuvichanu̱yada vase vicharu̱jyu̱y Ju̱denu diya, nanuvichasara siityeraju̱y daryaju̱ Nutyityu̱ jtedamu, ne nanusu̱tyeryi̱nu̱yada tarundamu yivaayadamusiy.  
\v 7 Ne detanu̱jyu̱y daryaju̱ nadavichanu̱yada, suri̱ daryaju̱ni̱ savatura Chabéda, nanurimyityuuñuma danu̱ju̱myusiy ti̱ta̱ju̱, mitya. 
\p  
\v 8 Tarundamu ji̱ta sivaañu̱yada Sacaryébay Ju̱denu mo̱muntiy, jiryatiy satevay jiyaru̱rya daryaju̱ra.  
\v 9 Daryaday ruuvaañu̱yada satevay Ju̱denu mo̱muntiy, rito̱jada saju̱ sa̱tidye jay Ju̱denu rorimyu, jasityi su̱ntatya Ju̱denumura nuvachiy, jiryatiy vu̱rudi juru rupacharamusirya.  
\v 10 Rivyichanu̱yada rajuu nijya̱nvay Ju̱denu rorityuunu bimu variy, rijyoráyada variy jasiy, rintuyada vu̱rudi juru rupedajiju̱ daryaju̱.  
\v 11 Mityamusiy samu̱ti̱jada Ju̱denu jpa̱nu, saradeda vu̱rudi juru rupajyo nutyityudamyu, Sacaryébay diya.  
\v 12 Sadiyadanumatiy Sacaryébay siva, sati̱tta̱da yintedamu variy.  
\v 13 Su̱teda ji̱ta Ju̱denu jpa̱nu variy siva: 
\p “Ne ya̱suvu̱y, Sacaryé, tuva̱chusaranuma daryaju̱ra jijechiñu̱rya, tapi sa̱day detuy jivyatura Chabéda jidyenuju̱, ya̱ma̱ jtyanu variy Juán jtyati̱ju̱ni̱.  
\v 14-15 Jaryi jchana̱yada ra̱cha variy jiijyu̱, rirya̱jchana̱y tavajyuu sarupedamuntiy, tapi sa̱cha jaryiñu̱ variy Ju̱denu diya. Ne sa̱jatura bínuja̱, dantyamu̱y ne pisijya̱ mitya. Sa̱cha mu̱chanichi̱ Ju̱denu Jnututa jipyi̱ru̱yadamusiy.  
\v 16 Sa̱janumitya ji̱ta riy rajuu jityevay Irayénuveda simuju̱ntiy, rintyityu̱ Vuryi̱ndenumuju̱ntiy.  
\v 17 Sa̱jiya Ju̱denujiju̱, Edíyasiy jnututa, savanu̱yadata jarye, sa̱tidye janumityara ja̱myi jachiy jidyedyeñu na̱cho̱ju̱, sa̱tidye janumitya riy tuva̱chu̱sa̱miy vase vicha̱damuju̱, rirya̱tidye vichasara nijya̱nvay ratyanusavay Vu̱ntyityu̱ Ju̱denuju̱.” 
\p  
\v 18 Su̱mutya̱jada ji̱ta Sacaryébay variñi̱ Ju̱denu jpa̱nu: 
\p “¿Nu̱tyuramusiy ra̱datya si̱tenuni̱viy rani̱cha jirya, nu̱tyuramusiy? rimyityunuma daryaju̱ darye, ravyatura jarye rimyityodadenuma.” 
\p  
\v 19 Su̱mutya̱jada ji̱ta Ju̱denu jpa̱nu variñi̱: 
\p “Ray rañi̱cha Cabryénu, jiryatiy raryanichara Ju̱denu tuunu. Su̱pa̱jasiy yimu ray, ra̱tidye niqueta ji, ra̱tu̱chu varirya jirya samitu̱choda yiva.  
\v 20 Ya̱jnu̱y diye, ya̱ma̱cho̱ niquejasa̱. Ne ya̱nique variñu̱day, rarundasa̱ra̱ju̱ jasityi ra̱jto̱ ri̱teda, jiryatimyu̱ ne jityuva̱churu̱y rañiquejadamu jiryatiy ra̱jto̱ rarundamu.” 
\p  
\v 21 Nijya̱nvay ji̱ta nutuyada sa̱jiju̱ Sacaryébay, rityi̱tta̱da variy jiryatiy saricheyada ta̱rijyu̱ daryaju̱ Ju̱denu rorivyimu.  
\v 22 Sama̱sedanumatiy rumusiy, ne vana̱y saniquejada variy ruusa̱. Ridyetya̱da variy: Sadiy tariva Ju̱denu rorivyimu, jiryatiy su̱mu̱ya̱jada mitya vapuu riñe̱cho̱ nijya̱nvay, jiryatimyu̱ ne vana̱y niquera daryaju̱ savicha̱da. 
\p  
\v 23 Tarundamuju̱ntiy sito̱tadedanumatiy Sacaryébarya jiyaru̱rya jvaayada Ju̱denu rorimyu, sata̱rya̱da rivasiy jiryorimyuju̱ntiy.  
\v 24-25 Rivasiñuma ji̱ta samudasiiyada Chabédabañi̱ jidyenu, sadutya̱da variy tadajyo jarimyuni̱sa̱ra̱ju̱yu, su̱teda daryaju̱: 
\p “Daryani̱ savichaniy Vu̱ntyityu̱ ray, jiryatiy su̱nu̱y samiryamu rañe̱cho̱, sa̱tidye pu̱y rivasirya ra̱na̱da nijya̱nvay cabyimu, jiryatiy ravyichanu̱yada suri̱.” 
\s1 Ju̱denu jpa̱nu tu̱choda ji̱tyaju̱ Jesús rupedanchiy 
\p  
\v 26 Ti̱quinijyate jarimyuni̱musiy, su̱pa̱jada ji̱ta Ju̱denuntiñi̱ yipa̱nu Cabryénuntiy. Su̱pa̱jada Cadidéya mucadimu vicha̱dademuni̱, jiryatiy Nasaryé ri̱tya vicha̱da jasiy.  
\v 27 Su̱pa̱jada vinu vaturabamyuni̱, jiryatimyu̱ ne saja̱tyo̱ vanunidyidye. Saja̱mu̱ryu̱yadamu jiñi̱cha̱da jasiy, sani ja̱mu̱ryu̱yada daryaju̱ni̱ Jusíbe jtyati̱, Davyíbe ju̱débi. Maríya ravichanu̱yada si̱tya vinu vaturabay.  
\v 28 Ju̱denu jpa̱nu jayada simu, samu̱chuveda variy jasiñi̱: 
\p “¡Chu̱! Jiiñi̱ ji̱ta Ju̱denu va̱tasi̱ jaryi. Vu̱ntyityu̱ Ju̱denu ji̱ta si̱tenu yisa̱.” 
\p  
\v 29 Sati̱tta̱da Maríyabay varirya saniquejada, sajachipiya̱jada ji̱ta variy: 
\p “¿Nu̱tyura mu̱chuvedata sani mu̱chuvay jiñu darye, nu̱tyura?” 
\p  
\v 30 Su̱teda ji̱ta Ju̱denu jpa̱nu siva: “Ne ya̱suvu̱y Maríya, jiiñi̱ ji̱ta Ju̱denu va̱tasi̱ jaryi.  
\v 31 Sa̱numa pi̱ru̱y jidyenu jivyimu, ya̱rupachu variñi̱, ya̱ma̱ bay si̱tyaju̱ra Jesús (Vuryeyada Rá̱ñu).  
\v 32 Ni̱ni̱ ra̱cha jaryiñu̱, Jarichumuvichi̱ denu rirya̱jtañi̱. Vu̱ntyityu̱ Ju̱denu ra̱bay nutyityu̱ju̱ni̱ Jesús, samunatyi̱ Davyíbe ju̱bivaju̱.  
\v 33 Ni̱numa ra̱chajaya̱sara Jacóbubay ju̱devay nutyityu̱ju̱, ne ra̱baryi̱sara nutyityu̱ vicha̱da saju̱ variñu̱day.” 
\p  
\v 34 Su̱teda ji̱ta Maríyabay variy siva Ju̱denu jpa̱nu: 
\p “¿Nu̱tyichirya ra̱cha daryá, nu̱tyichiy? ¡Tama̱ raje̱tyo̱ vanunidyidye, tama̱!” 
\p  
\v 35 Ju̱denu jpa̱nu jmutya̱jada variñi̱: 
\p “Ju̱denu Jnutu ra̱jti̱ yivaju̱. Jarichumuvichi̱ vanu̱yada ra̱canuvu̱nu ji. Ramuni̱tiy rirya̱jtachara Ju̱denu denuni̱ ni̱tiy ra̱pi̱ru̱y yimusiy, jiryatiy sa̱cha jiintyasi̱ Ju̱denuju̱.  
\v 36 Ya̱datya sanchiy jityeryatu vichi̱ Chabédantiy, rimyityodanuma samudasiiy pariche, jiryatiy ru̱tañu̱tyi suri̱ni̱. Ti̱quinijyate jarimyuni̱ti̱numa mudasiñi̱.  
\v 37 Ne saramicha Ju̱denu tara jvaayadiva daryaju̱.” 
\p  
\v 38 Su̱teda ji̱ta Maríyabay variy: 
\p “Jiyunrye, ratyidye ra̱cha Nutyityu̱ jmu̱tyi̱si̱ju̱. Daryani̱ ra̱cha rajyu̱, nu̱tyu jiñiquejasityi daryá.” 
\p Saya̱da ji̱ta Ju̱denu jpa̱nu simusiy variy. 
\s1 Maríyabay jañu̱yada simu Chabédabay 
\p  
\v 39 Sanubesubeda ji̱ta Maríyabay variryundamimyu, saya̱da vani̱ra jaryuve musityomuju̱, Judéya mucadi vicha̱damuju̱.  
\v 40 Jasiy sajañuvejada Maríyabay, Sacaryébay rorivyimu, samu̱chuvañuvejada variñi̱ jityeryatu vichi̱ Chabédabay jasiy.  
\v 41 Satuva̱chodanumatiy Chabédabarya Maríyabay mu̱chuveda, sasiquityaja̱jada sadenu jaryi variy jivyimu, sama̱cho̱jada Chabédabay mu̱chanichi̱ Ju̱denu Jnututa variy.  
\v 42 Sasa̱ñe̱ya̱jada ji̱ta Chabédabay variy: 
\p “Jiiñi̱ rañi̱cha jaryi jchana̱tyasi̱ ti̱ta̱ju̱ vatumyusiy, daryaday sa̱cha jchana̱tyasi̱ jiryupachú̱ntiy.  
\v 43 ¿Tesirya rani̱cha jirya day, tesiy? jiryatiy siti̱ rayntyityu̱ jno̱daju̱si̱ rimu.  
\v 44 Ne yinu̱y, varicha̱ra̱ju̱tiy ratyuva̱chosirya jimyu̱chuveda, sasiquityaja̱jasiy radyenu variy jaryi yichana̱yadamu ravyimu.  
\v 45 Jchana̱tyasi̱ ji̱tateni̱, jiryatiy satuva̱chuma̱ ramu Vu̱ntyityu̱ niquejada jto̱tadeda, jiryatiy su̱tachiy darya siva.” 
\s1 Maríyabay jchana̱tya̱da murra̱yadatani̱ Ju̱denu 
\p  
\v 46-55 Su̱teda ji̱ta Maríyabay variy: “Ri̱chana̱tyate rajechimyuni̱ Vu̱ntyityu̱te, ri̱ntuta ji̱ta ri̱chana̱tye simu ri̱ndenu Rayada Rá̱ñute. Su̱nu̱y daryaju̱ samirya rañe̱cho̱, dañuma rañi̱cha su̱mu̱tyi̱ datyi̱sa̱. Ramuni̱ rirya̱jtachara ti̱ta̱ju̱ nijya̱nvay: Ju̱denu jmu̱tyasanu̱y nada, jiryatiy sivaamya̱ Jaryi Vanu̱yadati̱ra ti̱ttasara rajyu̱. Jiintyasarate si̱tyate. Sa̱ntyutyajaya̱sara riy nijya̱nvay dadyeñu, ridyedyeñujuu jarye ti̱ta̱ju̱, rityi tuva̱chu jichuvu̱yadamu simu. Sadityanuma̱ra jivyanu̱yada, jiryatiy su̱rema̱ riy yinnu̱tyavay, jiryatiy riñi jachipiya̱ ye̱cha ti̱ nta. Sajatyama̱ ji̱ta riy nutyityu̱veda jintyityu̱vedamusiy. Sanubesumityanintyiryi jantyutyasavantyi. Sapotyanimya̱te samirya jmyicharatateriy jachi̱numu vichavay, jaryi taratavay ji̱ta su̱pa̱ mitya yimusiy. Su̱mu̱tyama̱teriy jiñijya̱nvay Irayénuvedate, jiryatiy sa̱ntyutya daryaju̱riy. Daryani̱ su̱teda ta̱riy ruuva vu̱myunatyavabetye, vu̱myunatyi̱ Avurá̱bay, sadadyeñu yisa̱ju̱ ju̱na̱reju̱te.” 
\p Daryani̱day samurra̱yada ti̱ta̱ju̱ Maríyabay. 
\p  
\v 56 Sama̱cho̱jada ji̱ta Chabédabaysa̱ mu̱nvay jarimyuni̱tuunusa̱ra̱ju̱, sata̱rya̱da ji̱ta jiryorimyuju̱ rivasintyi. 
\s1 Juán Bautístabay rupedanchiy 
\p  
\v 57 Riti̱jada ji̱ta Chabédabay rupachoda runda, sarupachoda variñi̱ jidyenu.  
\v 58 Rityuva̱chodanumatiy nanutuunu vichavabe, nanutevabe jarye jiryatiy sa̱ntyutyasara Vu̱ntyityu̱ jaryiñada, riichana̱yada variy nadisa̱ju̱.  
\v 59 Mumurundamiñijyatemusiy ji̱ta riintye̱ryadeda derapu jtyu̱yadamuyu, riñi jtyanuru̱yada variñi̱ derapu jijye̱be jtyati̱ju̱.  
\v 60 Nani̱mutya̱jada ji̱ta su̱no̱dabay variy: 
\p “Nenu, Juán ji̱ta ra̱cha si̱tya day.” 
\p  
\v 61 Ru̱teda variy nadiva: 
\p “Ne ti̱ Juán jtyati̱ jiryetyenu.” 
\p  
\v 62 Ru̱mu̱ya̱jada ji̱ta Sacaryébay na̱cho̱ variy, sa̱tidye dityanura miryara ra̱cha sadenu jtya.  
\v 63 Sajachiñu̱yada ji̱tara nu̱pedye variy yimuju̱, sanu̱yada riva: 
\p “Rani̱ ra̱cha si̱tya, Juán.” 
\p Rityi̱tta̱da ti̱ta̱ju̱ varirya.  
\v 64 Ramutteda varicha̱ra̱ju̱ sajú̱ Sacaryébay, sadachiy jarye jmu̱rya̱da varicha̱ra̱ju̱yu, saniquenu̱yada ji̱tara Ju̱denu jchana̱tyasa̱da.  
\v 65 Ru̱nteda ji̱ta rityuunu vichavabe ti̱ta̱ju̱ ramusiy, ra̱ticheyada jirya niquejada ti̱ta̱ju̱ Judéya musityo su̱tyeryasa̱ra̱ju̱.  
\v 66 Ribeyada ji̱ta tuva̱chuvay jijechimyu ti̱ta̱ju̱ra, ru̱teda variy: “¿Nu̱tyu̱na̱ sa̱cha̱siy jiñu dera, nu̱tyu̱?” 
\p Vu̱ntyityu̱ jomutu ji̱ta vicha̱da sisa̱ derapu, sa̱tidye ja̱vye vani̱ri̱ ramusiy. 
\s1 Sacaryébay niquejada ji̱tyaju̱ ra̱jiju̱ tará 
\p  
\v 67 Saja̱y Sacaryébay ji̱ta vicha̱da mu̱chanichi̱ Ju̱denu Jnututa, satu̱choda ji̱tyaju̱ variy: 
\q1  
\v 68-79 “Jchana̱tyasi̱ Vu̱ntyityu̱, Irayénuveda Ju̱denu, jiryatiy sajañu̱mya̱te vuryimu, su̱mu̱ryatanimya̱ntiryi jiñijya̱nvantyi, sanubesityanimya̱ni̱ Vuryeyada Rá̱ñu, jimyuchechiy Davyíbe ju̱devay cabyimusiy, darya saniquejada jijyu̱ tu̱chuvabe jtosiy, jiryatiy jiintyasavay sáju̱ ta̱ridyeryi. Sa̱day jantyuy vuryiva vu̱myityasimyijisiy, ti̱ta̱ju̱ jiryatiy rirya̱vittyuchara vu̱y, sa̱tidye dityanu yentyutya̱da riy vu̱myunatyavay, daryatiy su̱teda ruuva, sa̱tidye jachipityara yiteda si̱tenu, darya su̱teda si̱tenu niquejadata siva vu̱myunatyi̱ Avurá̱bay: Ra̱sá̱y jiryejyu̱ra, jirya̱tidye vicha jmu̱ryasavay jiryemyityasimyijisiy, jirya̱tidye jvaajeya̱sara jiryechuvu̱yasa̱damu jiintyasavay rajyu̱, vase vichavay jarye radyiya jijyomu. Va̱ ji, radyenudera, rirya̱jtachara Jarichumuvichi̱ jiyadaju̱ tu̱chu̱ ji, ya̱jiya Vu̱ntyityu̱jiju̱, ya̱tidye jdutyara nú̱ sa̱jiju̱, rirya̱tidye datya sanijya̱nvarya jiyada ra̱yada, jiryatiy sa̱ramityanirya rijyuuchuveda yivasiy, Vuryi̱ndenu jantyutya̱damusiy, ramusityi sa̱jasacha jiñi̱ mu̱ti̱jomusiy vuryiva, sa̱tidye no̱no̱nu̱y rijyu̱, jiryatiy rimya̱sasara nupocudinube, diiyada nuvachiy jare, sa̱tidye mutay samirya vicha̱damuju̱ vu̱y.” 
\m Daryani̱ su̱teda Sacaryébay Ju̱denu Jnutumusiy. 
\p  
\v 80 Sadenubay ji̱ta ja̱vyeñu̱yada, ra̱sa̱tyityiñu̱yada su̱ntu vanu̱yada variy yiva. Savicha̱da mityatomu samu̱ti̱jada rundasa̱ra̱ju̱ Irayénuveda cabyimu. 
\c 2  
\s1 Sarupeda Jesús 
\r (Matévu 1.18-25) 
\p  
\v 1 Su̱pa̱jada ji̱ta ja̱mu nutyityu̱ Acústubay tarundamura jiñiquejada: 
\p “Ti̱ta̱ju̱ nijya̱nvay ra̱nu̱tyaniyu.” 
\p  
\v 2 Ratani̱ rijyo̱ta̱da nu̱tyadedariy nijya̱nvay, japunuma savicha̱da variy Siréñubay, jiryatiy Síriya mucadi japuni̱.  
\v 3 Riyanu̱yada ji̱ta nu̱ñi jivyicha̱damuju̱, jasityi riñu̱tyaniñu̱yadayu. 
\p  
\v 4 Sa̱subeda Jusíbe Cadidéya mucadimusiy variy, Nasaryémusiy. Nasaryémusiy saya̱da Judéya mucadimuju̱, Bení̱muju̱. Jiryatiy savicha̱da Jusíbe, Davyíbe ju̱débi, saryena̱bay daryaju̱ jasiñi̱, ramuni̱tiy saya̱da samucadimuju̱.  
\v 5 Nadaya̱da ji̱ta jiñu̱tyadedana̱cho̱ savatura Maríyabatya, mudasiñuma savicha̱da variy.  
\v 6 Savicha̱datidye jasiy, sito̱tadeda ji̱ta variy jasirya jiryupachoda runda.  
\v 7 Sarupachodanumatiñi̱ jijyo̱ttya̱, nanurayada ji̱ta sasujajyuutayu, nanubayada ji̱ta voca jmyityanijyovimu variñi̱. Netara jna̱y vicha̱da vidavijo daryaju̱ nadaju̱ savaturu̱betya nu̱day, ramuni̱tiy nanubayada voca jmyityanijyovimuni̱. 
\s1 Ju̱denu jpa̱nu tu̱choda ruuva jasi̱jnu̱tyavabe Jesús rupedanchiy 
\p  
\v 8 Tajiñe̱cho̱ju̱dera rivyicha̱da jasi̱ jnu̱tyavabe varintyi. Ru̱nu̱tyanu̱yada riy yasi̱veda nupora.  
\v 9 Samu̱ti̱jada ji̱ta Ju̱denu jpa̱nu ruumu. Ju̱denuda nu̱yada variryi vandaju̱. Jaryi ru̱nteda jasi̱ jnu̱tyavabe variy.  
\v 10 Su̱teda Ju̱denu jpa̱nu variy ruuva: 
\p “Ne jirya̱jnutay, jiyunuma ra̱tu̱chunuvi̱ jiryivara tu̱choda jiryi̱chana̱yadaju̱. Jirya tu̱choda ra̱chasara ti̱ta̱ju̱ nijya̱nvajyu̱.  
\v 11 Sarupesiy curaca Davyíbe vicha̱damu, ni̱tiy ra̱ra̱chara jiryeyadaju̱, ni̱numa sani̱cha Vu̱ntyityu̱, Ju̱denu jaryeti̱.  
\v 12 Ránchiñi̱ jirya̱datya̱siñi̱, jirya̱tiy diñuve siva derapudera sujajyuuta rachi̱, voca jmyityanijyovimu sa̱tiryo̱.” 
\p  
\v 13 Mityamusiy rimyu̱ti̱jada Ju̱denu su̱tarujuu jarichumu vichavay, su̱pa̱nujsa̱ju̱. Riichana̱tya̱dani̱ Ju̱denu, ru̱teda variy siva: 
\q1  
\v 14 “Jachipiya̱jada ra̱chasara jiñijyu̱, Jarichumuvichi̱ Ju̱denu, jirya mucadinchantiy, samirya ra̱chasara jivya̱tavajyu̱.” 
\p  
\v 15 Rijiintyedanumatiy Ju̱denu jpa̱vay rinchiy, na̱vajyu̱, jasi̱ jnu̱tyavabe jteda variy yiva: “Vañú, vurya̱jnu̱ya rumu, Bení̱mu, jiryatiy Ju̱denu datyadosivyu̱y.”  
\v 16 Riya̱da ji̱ta vanu̱dyi sana̱cho̱, ridyiñuvejada nadiva Maríyaju̱be, Jusíbe jarye, vu̱ryupi̱deva jarye, detiryo̱ voca jmyityanijyovimu.  
\v 17 Ridyiyadanumatiy siva, rityu̱chunuvejada ji̱ta sanchiy jiñu vadinu, daryatiy satu̱choda Ju̱denu jpa̱nu munatya ruuva.  
\v 18 Ti̱ta̱ju̱ rityi tuva̱choda rana̱cho̱, rityi̱tta̱da varirya riñiquejada jasi̱ jnu̱tyavabe.  
\v 19 Maríyaju̱be ji̱ta bañu̱yada jijechimyu ti̱ta̱ju̱ra riñiquejada, nanujachipiya̱nu̱yada varidye.  
\v 20 Jasi̱ jnu̱tyavabe ta̱ryi̱jada variy. Riñiquejada samirya Ju̱denunijyu̱ varintyi, riichana̱tya̱da ji̱ta ti̱ta̱ju̱ variñi̱ Ju̱denu, varidye rityuva̱chodara, ti̱ta̱ju̱ ridyiyada variy rivantiy: 
\p “Darya ni̱day si̱tenu su̱tesiy vuryiva.” 
\p  
\v 21 Sito̱tadedanumatiy mumurundamiñijyate si̱tyu̱yadaju̱, riityadoda ji̱ta variy jasiñi̱ Jesús, daryani̱ sabayada Ju̱denu jpa̱nu si̱tyaju̱ sapi̱ru̱yadajiju̱. 
\s1 Jesús ja̱jyu̱be dityadoda Ju̱denu nijyu̱ jachipiya̱jomuyu 
\p  
\v 22 Rito̱jadanumatiy nanurupachodamusiy pu̱cha̱da runda, jiryatiy sabayada Muyusésiberya daryá rijyu̱ vatuy, nanupu̱cheda Jerusarí̱muju̱ni̱ Jesús, nana̱tidye dityanu simu Ju̱denuni̱.  
\v 23 Darya nu̱chara ni̱day Ju̱denu niquejadamura: 
\p “Jiryatiy sarupay munatyi̱ vanu, vurya̱jiintya Ju̱denuju̱ni̱.” 
\p  
\v 24 Vurya̱jnutatya simu varirya mitya sa̱chara, darya nu̱charatiy cateramura: 
\p “Danu̱ju̱y pundutu, varimyata danu̱ju̱y ja̱rityu denuju̱dyera.” 
\p  
\v 25 Jadchintyi savicha̱da nu̱ vanubay Jerusarí̱mu, ravicha̱da si̱tya Simeyú̱. Ni̱ni̱ vichanu̱yada vase vichara, samirya jachityi̱ risa̱ju̱ni̱. Santuñu̱yada sa̱jiju̱ Irayénuveda Jiyada Rá̱ñu, Ju̱denu Jnutu vicha̱da sivantiy.  
\v 26 Ju̱denu Jnutu datyadoda ji̱tyaju̱ni̱: “Ne ya̱diiy netimyu̱ ne ya̱diy siva Vu̱ntyityu̱ jaryeti̱ didye.”  
\v 27 Ju̱denu Jnutu jtedamuju̱ sivi̱jada Ju̱denunijyu̱ jachipiya̱jomu naditi̱ta̱danumatiy saja̱betyani̱ Jesús pi̱ra, nana̱tidye jto̱tanirya Ju̱denu niquejada, daryatiy ranique derapunchiy.  
\v 28 Saryeda ji̱ta Simeyú̱bay nadimusiy yimuju̱ variñi̱. Samiy su̱teda siva Ju̱denu variy.  
\v 29 Su̱teda ji̱ta: 
\p “Ya̱numa ji̱ta jmu̱rya ti̱ta̱ju̱ jiyusidyerye, ra̱tidye jiya ji̱ta ri̱chana̱yadamu, jiryatiy jicyumude ray, daryani̱ rani̱cha jiñiquejada, Nutyityu̱.  
\v 30-31 Tapi radyimya̱ rañi̱sitya siva Nu̱dyeyada Rá̱ñu yimusi̱, jiryatiy yidutya̱dara su̱deda ridyiya nijya̱nvay ti̱ta̱ju̱.  
\v 32 Ni̱ni̱ sani̱cha no̱no̱, rirya̱tidye diy nijya̱nvay riva, sa̱cha vanda rijyu̱ jiñijya̱nvay Irayénuveda.” 
\p  
\v 33 Nanuti̱tta̱da ji̱ta saja̱jyu̱berya Simeyú̱bay niquejada jidyenunchiy.  
\v 34 Saniquejada ji̱ta Simeyú̱bay samirya Ju̱denumusiy nadayadaju̱, su̱teda variy nadiva su̱no̱da Maríyaju̱bentyi: 
\p “Sa̱na̱jnu̱y, jiñu ji̱ta sani̱cha Ju̱denumusiy bachi̱, rirya̱tidye díryo̱vay rajuu Irayénuveda tevay, rityevay ji̱ta ra̱mi̱sa̱sumiy ramusiy diiryo̱vedantiy. Sani̱cha dityanu̱ju̱ bachi̱ntiy, sayaro̱ju̱tiy rirya̱nique tavay.  
\v 35 Sa̱daju̱ ji̱ta ra̱nuvaday jijechiy, nu̱tyu jichityitya̱ta jichityichara, ra̱tidye vichasara jvadichara rijechipiya̱jada nijya̱nvajyuu.” 
\p  
\v 36-37 Jadchiy ji̱ta nanuvichanu̱yada tanu̱qui bacheno̱dabay, Ju̱denuju̱ tu̱chunu̱be. Ravicha̱da nani̱tya Ánaju̱y, jiryatiy Januvébay detu̱ñada, Áser ju̱riiñutanu̱y. Nanuvichanu̱yada jutumusiy danijya̱ju̱ñijyate jivyanubaysa̱, rivasiy ji̱ta nanuma̱cho̱jada bacheno̱da, vu̱ryimityuuñu̱ñuma nadavichanu̱yada variy, jiryatiy mumuri̱nijyate vu̱yaju̱y nijya̱tanu̱ñuma daryaju̱ nada, dañijya̱ju̱yu ranchaju̱ntiy. Ne nanuparu̱yada riva jmu̱tya̱da Ju̱denu rorimyu yinra̱data, joráyadata jarye, ju̱daca̱, nuporaca̱ risa̱ju̱.  
\v 38 Nanutuudiyadanumatiy Ánaju̱beñi̱ Jesús pi̱ra, nani̱chana̱tya̱da variñi̱ Ju̱denu, nanutu̱chunu̱yada nijya̱nvavya sanchiy Jesús, jiryatiy rintuñu̱yada ra̱jiju̱ Jerusarí̱ jiyada ra̱yada. 
\s1 Jesús ja̱jyu̱be ta̱rya̱da Nasaryémuju̱ 
\p  
\v 39 Nadito̱tadedanumatiy Ju̱denu jtedamuju̱ra tara ti̱ta̱ju̱, nanuta̱rya̱da ji̱ta Jesús ja̱jyu̱be Nasaryémuju̱ntiy, jiryatiy Cadidéyamura.  
\v 40 Jaryi datyara saja̱vyeñu̱yada Jesús pi̱ra, jaryi vanu̱rya savicha̱da variy risa̱ju̱. Ju̱denu jachipiya̱jada daryaju̱ simuju̱, ramutiy savichanu̱yada daryá. 
\s1 Jesús pi̱ra jañu̱yada Ju̱denunijyu̱ jachipiya̱jomu 
\p  
\v 41 Nanuviche̱chanu̱y ji̱ta jivyichanu̱yada, nu̱ñi tanijya̱quimusiy sayanu̱yada Jesús ja̱be jivyaturu̱betya Jerusarí̱mu, Pásco vichtyamu.  
\v 42 Taraqui vu̱yaju̱y nijya̱ti̱numatiy savicha̱da Jesús, danijya̱ju̱y ranchaju̱, riya̱da ji̱ta vichtyamuntiy, nu̱tyu ta̱rityi nadayanu̱yada saja̱jyu̱be daryantiy.  
\v 43 Ripyaruta̱danumatirya vichtya runda, ritye̱rya̱da ji̱ta variy rivasintyi. Sama̱cho̱jada ji̱ta Jesús pi̱ra rumu ru̱biva, riñiya̱resiy, Jerusarí̱mu day, ne nanudatya̱da su̱no̱dabay saja̱bétya daryaju̱.  
\v 44 Nani̱tamya̱ta jasiñuma riquebyimu rupivyejyuuni̱, tarundaquinuma nanurupiyada varidye. Nani va̱ta̱da ji̱ta sana̱cho̱ jidyenu, satevabe cabyimu, sadatyavabe cabyimuntiy.  
\v 45 Netimyu̱ ne nanudiyada jasiy siva, nanuta̱rya̱da variy vá̱tanu̱y Jerusarí̱muju̱ sana̱cho̱ntiy. 
\p  
\v 46 Mumurundamimyusiñuma ji̱ta nanusaryeda Ju̱denunijyu̱ jachipiya̱jomuni̱. Sama̱sa̱da riquebyimu Ju̱denu niquejada datyanuvabe. Satuva̱choda jasiy riñe̱cho̱, sitaja̱doda variy jasiryi.  
\v 47 Rityi tuva̱chuta̱da jasiñi̱, rityi̱tta̱da varirya nu̱ryate sadatya̱dateday, nu̱rya, jiryatiy su̱mutya̱jada vase daryaju̱ ridyiya.  
\v 48 Nanudiñuvejadanumatiy saja̱betya siva jidyenu, nanuti̱tta̱da variñi̱. Nani̱teda su̱no̱dabay variy yiva: 
\p “¿Ta̱raju̱ra jivyicha darya na̱dyisa̱siy, Pi̱chiy, ta̱raju̱? ¿Ne yinu̱y na̱vya̱ta jiñuvayadamu jiñe̱cho̱ day?” 
\p  
\v 49 Su̱teda ji̱ta variy jasiy nadiva: 
\p “¿Ta̱raju̱ra sa̱nuva̱ta rañe̱cho̱, ta̱raju̱? ¿Ne sa̱nudatya̱damu rajye̱ bajyomu jiyu darye?” 
\p  
\v 50 Ne samiy nanutuva̱choda rana̱cho̱, jiryatiy saniquejada nadivara. 
\p  
\v 51 Sata̱rya̱da ji̱ta variy nadisa̱ Nasaryémuju̱ntiy, satuva̱chunu̱yada ji̱ta jasiy nadimu. Mitya nanubañu̱yada su̱no̱dabay jijechivyara saniquejada.  
\v 52 Jesús ja̱vyeñu̱yada datya̱da jachityi̱, vani̱ri̱ ti̱ta̱ju̱ variy savichanu̱yada. Savicha̱da samiy jvadichi̱ variy Ju̱denuju̱, nijya̱nvajyu̱ jarye risa̱ju̱. 
\c 3  
\s1 Juán Bautístabay datyadoda mityatomu 
\r (Matévu 3.1-12; Márcu 1.1-8; Juán 1.19-28) 
\p  
\v 1 Jadchiy ji̱ta savichanu̱yada ja̱mu nutyityu̱ Rómamu, Tibéryu jtyati̱bay. Savicha̱danumatiy Tibéryubay nu̱tyu ja̱mu nutyityu̱ taraqui vu̱yaju̱y nijya̱, tadajyo nijya̱ ranchaju̱, savicha̱da Púnsiyu Pyidátubay variy nu̱tyu cadnadu Judéyamu, Jeródesbe jarye vicha̱da Cadidéya nutyityu̱ntidye. Jeródesbe taryi̱ Vedípebe jarye vicha̱da nutyityu̱ variy Ituréyamu day, Traconítyimyu jarye. Disáñabantyi vicha̱da nutyityu̱ variy Abidénemuntidye.  
\v 2 Nanuvichanu̱yada ji̱ta Anásibe, Cayivásubatya caserdóte nutyityu̱ju̱y varintyi. Sabayada ji̱ta Ju̱denu varirya jiñiquejada simu Juánbay, Sacaryébay denu, jiryatiy mityatomu savicha̱da variy.  
\v 3 Siti̱jada Juánbay Jurdá̱ja̱ tuudiche, saniquenumaya̱jada jidyetyadodamu: 
\p “Jirya̱paru̱y riva taji jachipiya̱jada, jirya̱tidye jtyanutaniy variyu, sa̱tidye ramityaniy Ju̱denu variy jiryivara jiryejyuuchuveda.” 
\p  
\v 4-6 Darya nu̱chara ni̱day catera padyevyara daryatiy saniquejada Isayíyasibe, jiryatiy Ju̱denuju̱ tu̱chu̱ni̱: 
\q1 “Ti̱ jtani̱te natuye̱ tajityomudaque: Ya̱numa jdutya ji̱tyaju̱ra nú̱ Vu̱ntyityu̱jiju̱, vasenú̱ ya̱barya nú̱ sa̱jiju̱. Ja̱mumu̱vicha̱ ji̱ta ra̱ma̱cho̱ mu̱chanichara, musiquivicha̱ ji̱ta riryá̱miy, ra̱ma̱cho̱ ji̱ta jidchavu̱ variy risa̱ju̱. Varuyunú̱ jarye ra̱ma̱cho̱ vasenú̱; varivyununú̱ jarye ra̱ma̱cho̱ vasidyanú̱, rirya̱jnu̱y nijya̱nvajyuu varirya Ju̱denu ramityadeda.” 
\p  
\v 7 Su̱teda Juánbay variy ruuva nijya̱nvajyuu, jiryatiy ruuti̱tityiyada rirya̱tidye jtyu̱y variy simu: 
\p “¡Codityevay rapu̱ryamiy! ¿Chi̱ra datyadosiy ji̱tyaju̱ jirye, chi̱? ¡Jirya̱numa bay ra̱jisiy Ju̱denu nique̱yada!  
\v 8 Daryatiy rajontay ni̱nu, daryaday jirya̱jontay samirya vicha̱damuju̱ntidye, jirya̱tidye dityanu ratara va̱cha jvaayadiva paru̱yada. Ne jirya̱jachipiya̱ jivyimu: Avurá̱bay ji̱ta vu̱myunatyi̱, ramutiy sa̱jantyuy Ju̱denu vuryiva. Ri̱tatye jiryiva: Saryi ju̱de Ju̱denu jiñu ravichu̱musiy Avurá̱bay dadyeñuju̱, rityidye ra̱tuva̱chu variy simu Ju̱denu.  
\v 9 Netimyu̱ ne jirya̱jontay samirya vicha̱damuju̱, jirya̱ma̱ datya: Ni̱nu ruva̱tuununumara jaseé, ru̱nusa̱daju̱. Ramuni̱day rirya̱jnura jirya ni̱nuvicha̱ jiryatimyu̱ ne samirya jorara, rirya̱tidye jatya jiidamyu variy rivara.” 
\p  
\v 10 Ruutaja̱doda ji̱ta nijya̱nvajyuu variñi̱ Juánbay: 
\p “¿Ta̱ra nu̱ña̱jvaay variy, ta̱ra?” 
\p  
\v 11 Su̱mutya̱jada Juánbay variryi: 
\p “Ni̱tiy dajajyu̱y jasetajatyi̱, sa̱ma̱ sa̱y tajaquini̱ jasetajajsa̱; ni̱tiy jmyicharati̱, sa̱ma̱ jvaay daryantiy.” 
\p  
\v 12 Criquiy jmutya̱vay jarye jti̱jada variy simuntiy, rirya̱tidye jtyu̱y simuntiy, ruutaja̱dodantiñi̱: 
\p “Datyanu̱, ¿Ta̱ra nu̱ña̱jvaadye, ta̱ra?” 
\p  
\v 13 Su̱teda variy ruuva: 
\p “Ne jirya̱murichenutaniy ju̱na̱y jiyaru̱ryanchaju̱.” 
\p  
\v 14 Ruutaja̱doda su̱tarumintyiñi̱: “Va̱ nu̱que, ¿ta̱ra nu̱ña̱jvaadye, ta̱ra?” 
\p Su̱teda ji̱ta ruuva: “Ne jirya̱paranura tara suvu̱chodamusiy, dantyamu̱y ne quivu̱chodata. Jirya̱ma̱cho̱ samirya jachityavay ramusiy ji yaru̱rya, jiryatiy jiryi̱mutya̱ra criquiy.” 
\p  
\v 15 Rijechipiya̱jada ji̱ta nijya̱nvay variy Juánbaynchiy: 
\p “Ni̱ni̱ dyetya sani̱chate Ju̱denu jaryeti̱.”  
\v 16 Su̱mutya̱jada ji̱ta Juánbay variy ti̱ta̱ju̱riy: “Ray ji̱ta jtyanu ja̱a̱ta jiryedye. Jativyenumani̱ ni̱tiy ra̱jti̱ ri̱bivaju̱, ni̱ni̱ ji̱ta jaryi datyara rimusidye. Ne vinu sasaapatu vita̱dasa̱ra̱ jtate darye, jiryatiy jaryiñu̱ daryaju̱ rimusidyeñi̱. Ni̱ni̱ ji̱ta ra̱jtyanu Ju̱denu Jnututa jiryedye, jiidatya jarye risa̱ju̱.  
\v 17 Sapa̱pe̱tyu variy jijyomu, sa̱tidye ju̱pay varirya yivaajyo, sa̱tidye jato varirya rasiy rabajyovimuju̱, raqui̱suy ji̱ta sa̱rupay jiidatya, jiryatimyu̱ ne vana̱y ji̱richasara darya.”\f * \fr 3:17 \ft Su̱tarya rasiy yimu tuva̱chuvajyu̱, raqui̱suy ji̱ta su̱tay rijyu̱ jiryatimyu̱ ne rityuva̱churu̱y simu.\f* 
\p  
\v 18 Daryani̱ sajachipiya̱tadeda Juánbay ratarya niquejadata riy nijya̱nvay, satu̱choda varirya samitu̱choda ruuva.  
\v 19-20 Nutyityu̱ Jeródesbe ji̱ta tanuvu̱dodani̱ Juánbay, jiryatiy sanique̱tyanu̱yada va̱cha jvaayadiva daryaju̱ni̱, jiryatiy saja̱mu̱yada nada jityeryi̱ vaturu̱y Jerodíyaju̱y daryaju̱, ratarya jamirya vichasa̱diva jarye sanique̱tyanu̱yada Juánbay variy jasiñi̱. Rivasiy ji̱ta sajatyiiyada jvaayada Jeródesbe va̱cha ranchaju̱ntiy, jiryatiy satanuvu̱dodani̱ Juánbay riva. 
\s1 Jesús jtyu̱yadanchiy 
\r (Matévu 3.13-17; Márcu 1.9-11) 
\p  
\v 21-22 Riityu̱myu̱yadanumatiy nijya̱nvay, si̱tyu̱yada ji̱ta Jesús varintyidye. Rivasidye ji̱ta sajoráyadanumatiy, rasetejada jarichu variy, saju̱u̱jeyada ji̱ta Ju̱denu Jnutu, nu̱tyu ja̱rityude saju̱u̱jeyada variy sivaju̱. Rara̱yada niquejada jarichuvimusiy variy simuntiy: 
\p “Jiiñi̱day radyenu jaryi ravya̱tasi̱, jaryi ri̱chana̱tya variy ji.” 
\s1 Jesucrístu munatyavay 
\r (Matévu 1.1-17) 
\p  
\v 23 Sajo̱ta̱danumatiy jvaayada Jesúsra mityamusiy ju̱dejada, jdiva̱jnuvay mi̱sanicha̱da jarye risa̱ju̱, savicha̱da mumuri̱ vu̱yaju̱y nijya̱ti̱ jta variy. Savicha̱da Jusíbe denu nta, Jusíbe ji̱ta vicha̱da Edíbe jadchá̱.  
\v 24-38 Edíbe ji̱ta vicha̱da Matátubay denu, 
\q1 jadchintyi Matátubay vicha̱da Devyíbe denu, 
\q1 jadchintyi Devyíbe vicha̱da Mérquibe denu, 
\q1 jadchintyi Mérquibe vicha̱da Janábe denu, 
\q1 jadchintyi Janábe vicha̱da Jusíbe denu, 
\q1 jadchintyi Jusíbe vicha̱da Matatíyasibe denu, 
\q1 jadchintyi Matatíyasibe vicha̱da Amúsibe denu, 
\q1 jadchintyi Amúsibe vicha̱da Navú̱bay denu, 
\q1 jadchintyi Navú̱bay vicha̱da Esdíbe denu, 
\q1 jadchintyi Esdíbe vicha̱da Nacáyibe denu, 
\q1 jadchintyi Nacáyibe vicha̱da Má̱tubay denu, 
\q1 jadchintyi Má̱tubay vicha̱da Matatíyasibe denu, 
\q1 jadchintyi Matatíyasibe vicha̱da Saméñubay denu, 
\q1 jadchintyi Saméñubay vicha̱da Jusíbe denu, 
\q1 jadchintyi Jusíbe vicha̱da Judábay denu, 
\q1 jadchintyi Judábay vicha̱da Juanánbay denu, 
\q1 jadchintyi Juanánbay vicha̱da Résabay denu, 
\q1 jadchintyi Résabay vicha̱da Sorobabénubay denu, 
\q1 jadchintyi Sorobabénubay vicha̱da Sadatyérubay denu, 
\q1 jadchintyi Sadatyérubay vicha̱da Nérubay denu, 
\q1 jadchintyi Nérubay vicha̱da Mérquibe denu, 
\q1 jadchintyi Mérquibe vicha̱da Adíbe denu, 
\q1 jadchintyi Adíbe vicha̱da Cusámibe denu, 
\q1 jadchintyi Cusámibe vicha̱da Erumadámubay denu, 
\q1 jadchintyi Erumadámubay vicha̱da Éribe denu, 
\q1 jadchintyi Éribe vicha̱da Josuvébay denu, 
\q1 jadchintyi Josuvébay vicha̱da Edyasárubay denu, 
\q1 jadchintyi Edyasárubay vicha̱da Jurí̱bay denu, 
\q1 jadchintyi Jurí̱bay vicha̱da Matátubay denu, 
\q1 jadchintyi Matátubay vicha̱da Devyíbe denu, 
\q1 jadchintyi Devyíbe vicha̱da Simeyú̱bay denu, 
\q1 jadchintyi Simeyú̱bay vicha̱da Judábay denu, 
\q1 jadchintyi Judábay vicha̱da Jusíbe denu, 
\q1 jadchintyi Jusíbe vicha̱da Junámbay denu, 
\q1 jadchintyi Junámbay vicha̱da Edyaquí̱bay denu, 
\q1 jadchintyi Edyaquí̱bay vicha̱da Medéyabay denu, 
\q1 jadchintyi Medéyabay vicha̱da Mayinánbay denu, 
\q1 jadchintyi Mayinánbay vicha̱da Matátubay denu, 
\q1 jadchintyi Matátubay vicha̱da Natá̱bay denu, 
\q1 jadchintyi Natá̱bay vicha̱da Davyíbe denu, 
\q1 jadchintyi Davyíbe vicha̱da Isayíbe denu, 
\q1 jadchintyi Isayíbe vicha̱da Jobénubay denu, 
\q1 jadchintyi Jobénubay vicha̱da Boósibe denu, 
\q1 jadchintyi Boósibe vicha̱da Sarumú̱bay denu, 
\q1 jadchintyi Sarumú̱bay vicha̱da Na̱sú̱bay denu, 
\q1 jadchintyi Na̱sú̱bay vicha̱da Amyinadábebe denu, 
\q1 jadchintyi Amyinadábebe vicha̱da Ará̱bay denu, 
\q1 jadchintyi Ará̱bay vicha̱da Esrúmibe denu, 
\q1 jadchintyi Esrúmibe vicha̱da Várvisibe denu, 
\q1 jadchintyi Várvisibe vicha̱da Judábay denu, 
\q1 jadchintyi Judábay vicha̱da Jacóbubay denu, 
\q1 jadchintyi Jacóbubay vicha̱da Isácubay denu, 
\q1 jadchintyi Isácubay vicha̱da Avurá̱bay denu, 
\q1 jadchintyi Avurá̱bay vicha̱da Tarébay denu, 
\q1 jadchintyi Tarébay vicha̱da Nacórubay denu, 
\q1 jadchintyi Nacórubay vicha̱da Sírubay denu, 
\q1 jadchintyi Sírubay vicha̱da Racá̱bay denu, 
\q1 jadchintyi Racá̱bay vicha̱da Pedyébay denu, 
\q1 jadchintyi Pedyébay vicha̱da Ebérubay denu, 
\q1 jadchintyi Ebérubay vicha̱da Sádabay denu, 
\q1 jadchintyi Sádabay vicha̱da Cayiná̱bay denu, 
\q1 jadchintyi Cayiná̱bay vicha̱da Aruvasá̱bay denu, 
\q1 jadchintyi Aruvasá̱bay vicha̱da Sémyibay denu, 
\q1 jadchintyi Sémyibay vicha̱da Nuvébay denu, 
\q1 jadchintyi Nuvébay vicha̱da Damécubay denu, 
\q1 jadchintyi Damécubay vicha̱da Matúsabay denu, 
\q1 jadchintyi Matúsabay vicha̱da Enócubay denu, 
\q1 jadchintyi Enócubay vicha̱da Jarébay denu, 
\q1 jadchintyi Jarébay vicha̱da Marurábay denu, 
\q1 jadchintyi Marurábay vicha̱da Cayiná̱bay denu, 
\q1 jadchintyi Cayiná̱bay vicha̱da Jenósibe denu, 
\q1 jadchintyi Jenósibe vicha̱da Sétubay denu, 
\q1 jadchintyi Sétubay vicha̱da Ará̱bay denu, 
\q1 Ará̱bay ji̱ta vicha̱da Ju̱denu denu su̱ndayadamusiy ti̱ta̱ju̱. 
\c 4  
\s1 Bayantu nutyityu̱ juuchanuru̱yadani̱ Jesús 
\r (Matévu 4.1-11; Márcu 1.12-13) 
\p  
\v 1 Jesús ji̱ta ta̱rya̱da Jurdá̱ja̱musiy. Savicha̱da mu̱chanichi̱ Ju̱denu Jnututa variy. Sayatanumaya̱jada Ju̱denu Jnutu tajityomu variñi̱.  
\v 2 Daryaju̱yu vu̱yaju̱y rundasa̱ra̱ju̱ sani juuchanityaniryu̱yada bayantu nutyityu̱ variy jasiñi̱. Ne si̱byeda variryundamimyu tara, mitya. Rito̱jadanumatiy variryunda sajachi̱jada ji̱ta variy.  
\v 3 Su̱teda bayantu nutyityu̱ variy siva Jesús: “Jiñi̱chatiy si̱tenu Ju̱denu denu, ya̱jtay siva jiñu ravichu̱, sa̱tidye ti̱tuy pa̱ju̱.” 
\p  
\v 4 Su̱mutya̱jada ji̱ta Jesús variñi̱: 
\p “Ne, nu̱charanuma Ju̱denu niquejadamu daryaju̱ darya: Ne sa̱jnu̱chara nijya̱mi̱ vinu pa̱ta.” 
\p  
\v 5 Sa̱sumityadeda ji̱ta bayantu nutyityu̱ variñi̱, sadityadoda mityamusiy variy ti̱ta̱ju̱ nijya̱nvay mucadini̱, rasu̱tyeryasa̱ra̱ju̱ ti̱ta̱ju̱.  
\v 6 Su̱teda variy siva Jesús: “Raryi sa̱y jiirya jirya nijya̱nvay mucadijuu, ti̱ta̱ju̱ rádá jarye risa̱ju̱, ya̱tidye nusu̱y ránchá ti̱ta̱ju̱ riy nijya̱nvay, jiryatiy ri̱mutya̱jada daryaju̱ra. Ramuni̱ raryiche̱ñi̱ saju̱tiy raryisa̱ryu̱rya.  
\v 7 Jiryityi jadasiñu rañijyu̱ ji, jiiberya raryicha variy ti̱ta̱ju̱.” 
\p  
\v 8 Su̱mutya̱jada ji̱ta Jesús variñi̱: 
\p “Nu̱chara day, 
\q1 Vurya̱jadasiñu ji̱ta Vu̱ntyityu̱ Vuryi̱ndenunijyu̱ vu̱y, vinu sanijyu̱ ni̱day vurya̱jachipiya̱sara ti̱ta̱ju̱.” 
\p  
\v 9-11 Sapu̱cheda ji̱ta bayantu nutyityu̱ Jerusarí̱muju̱ variñi̱, saranityaniñuvejada Ju̱denu rorivyu̱ rodejcha variñi̱, su̱teda variy siva: 
\p “Jiñi̱chatiy si̱tenu Ju̱denu denu, ya̱jatyate jiyusiy jicyu̱, nu̱charanuma daryaju̱ darya: 
\q1 Sa̱jpa̱ Ju̱denu riy yipa̱vay rirya̱tidye jnu̱tya samiy ji, rirya̱jiryesumiy jijyomututa ji, jiiñuma jpatyara jiñumutu saniy ravichu̱.” 
\m  
\v 12 Su̱mutya̱jada ji̱ta Jesús variñi̱: 
\q1 “Jtachara day: Ne ya̱jantya mitya simu yintyityu̱ Ju̱denu.” 
\p  
\v 13 Sa̱ntyamu̱yadanumatiy bayantu nutyityu̱ va̱cha vicha̱data saniy Jesús, satocheda variy tarundamuju̱ jasiñi̱. 
\s1 Jesús jo̱ta̱da jvaayada Cadidéyamu 
\r (Matévu 4.12-17; Márcu 1.14-15) 
\p  
\v 14 Sata̱rya̱da ji̱ta Jesús, Ju̱denu Jnutu vanu̱yadata Cadidéyamuju̱. Rara̱yada ji̱ta sa̱ticheyada variy rityuunu vichavamyuju̱ ti̱ta̱ju̱.  
\v 15 Sadatyanunuvejada ji̱ta riintye̱ryanijyomuyu, jasityi riichana̱tya̱da nijya̱nvajyuuni̱. 
\s1 Jesús jto̱jada jañú̱ñu Nasaryému 
\r (Matévu 13.53-58; Márcu 6.1-6) 
\p  
\v 16 Su̱deda ji̱ta variy Nasaryémuju̱, saja̱vyejyomuju̱. Jiituyada rundamu sajañuvejada Judíyuveda ju̱tye̱ryanijyovimu, jiryatiy saju̱tya̱da raniy. Sanubesubeda variy catera niquetta̱daju̱.  
\v 17 Riche̱yada ji̱ta caterapadye variñi̱ Jesús, Isayíyasibe nu̱rya, jiryatiy Ju̱denu niquejada nu̱chara riva. Samuttatityiyadara caterapadye, sasaryejada varirya Ju̱denu niquejada nu̱chara jasityi su̱teda: 
\q1  
\v 18-19 “Ju̱denu Jnutu riva, jiryatiy sabayada daryaju̱ ray, ra̱tidye tu̱chusara jantyuyadavavyara samitu̱choda. Su̱pa̱jada ji̱ta tanuvu̱nusavamyu ray, ra̱tidye tu̱chu richipyatedaju̱ yivara; ni̱sipyuryivyedamuntiy ru̱nu̱yadaju̱, sabonichavamyuntiy jantyutya̱daju̱, ra̱tidye tu̱chu ti̱ta̱ju̱ra: Rito̱ma̱ Vu̱ntyityu̱ nijya̱, varityi sa̱jnu̱y samiy vu̱ñe̱cho̱.” 
\m  
\v 20 Satamutyadedanumatirya caterapadye, sata̱ryatadeda ji̱ta jmu̱tyi̱muju̱ntirya, sama̱sa̱da ji̱ta variy. Mitya ru̱nu̱choda ju̱tye̱ryanijyovimu vichavay variñi̱.  
\v 21 Sajo̱ta̱da jteda variy ruuva: “Diye rundani̱ rito̱ jirya niquejada nu̱chara jiryedyiya.” 
\p  
\v 22 Riñiquenu̱yada ji̱ta ti̱ta̱ju̱ variy samirya sanijyu̱, rityi̱tta̱da varirya saniquejada, jiryatiy jaryi samirya saniquejada daryaju̱. Ru̱teda variy: “¿Neviy ni̱ Jusíy denu day?” 
\p  
\v 23 Su̱teda ji̱ta variy ruuva: 
\p “Jirya̱jtay dyetya riva, daryatiy ru̱tachara nijya̱nvadyecyu̱: ¡Ya̱mi̱saniy ji, ju̱danu̱! Daryatiy nu̱tyuva̱chusara yivaachara Capernavú̱mu, ya̱jvaatye darya jiyu, jimyucadimuntidyecyu̱.”  
\v 24 Su̱teda variy: “Ri̱tatye jiryiva: Ne ridyiryeru̱y samucadimu Ju̱denuju̱ tu̱chu̱yu.\f * \fr 4:24 \ft Daryatiy ne rityuva̱churu̱yada ta̱riy rimyunatyavay simu Ju̱denu, daryantimyu̱ ne rityuva̱churu̱yada nijya̱nvay simu Jesús.\f* 
\v 25 Si̱tenu ri̱tay jiryiva: Rivyichanu̱yada rajuu bacheno̱damiy Irayénuveda tevay, Edíyasiy rundamu. Variryundamu samutadoda Ju̱denura jarichu ru̱murajisiy, mumunijya̱miy sa̱ra̱ju̱, ti̱quinijyate jarimyuni̱ ranchaju̱ntiy. Ravicha̱da ji̱ta jachi̱nu rivasiy ti̱ta̱ju̱ mucadiva.  
\v 26 Ne su̱pa̱jada Ju̱denu variñi̱ Edíyasiy nadimuju̱ Irayénuveda tenu̱y bacheno̱da. Su̱pa̱jada ji̱ta taji vichanu̱y bacheno̱damuju̱ni̱, jiryatiy Saréptamu vichanu̱ñada, Sitú̱ mucadimu.  
\v 27 Rivyichanu̱yada rajuu vatajo̱ju̱vye Irayénuveda tevay Edisévubay rundamu, jiryatiy Ju̱denuju̱ tu̱chu̱ni̱. Ne sapu̱yada Ju̱denu variñi̱ rityenu, mitya, vinu Na̱má̱bay, jiryatiy savicha̱da ma̱y Síriyamusi̱.” 
\p  
\v 28 Rityuva̱chodanumatiy ju̱tye̱ryanijyovimu vichavarya jiryatiy saniquejada Jesús darya, riñique̱tta̱da ji̱ta varirya.  
\v 29 Riñubesubedanumatiy, ribetya̱da ji̱ta vicha̱damusiñi̱ Jesús. Riyata̱da variy jadchiy nubañuco̱muju̱ni̱, musiquisumancha daryaju̱ra rivyicha̱da. Riñi jteda ya̱jatya musiy ramiryamusiñi̱, nubañuco̱vimu.  
\v 30 Jasidye ji̱ta saramiryi̱tityiyada riquebyivantiy, puryityeni̱, saya̱da variy. 
\s1 Ti̱qui vanubay nchiy jiryatiy bayantu jamirya vichara siva 
\r (Márcu 1.21-28) 
\p  
\v 31 Su̱musa̱da ji̱ta jadchiy Capernavú̱muju̱, jiryatiy Cadidéyamura. Sadatyanunu̱yada jiituyada rundamu jasiryi.  
\v 32 Rityi̱tta̱da ji̱ta variy sadatyadodanchiy, jiryatiy saniquejada daryaju̱ jidyirya datya̱data. 
\p  
\v 33-34 Savicha̱da nu̱ vanubay riintye̱ryanijyovimu, bayantu jamirya vichara vichanu̱yada siva. Sasa̱ñeya̱jadamu jiñiquejada variy: 
\p “¡Jaa! ¿Ta̱ra jivya̱ta nu̱dyisa̱, Jesús Nasaryémusi̱, ta̱ra? ¿Yidesivyi nu̱ñi̱vacha̱dana̱cho̱? Radyetyama̱ ji, chi̱ra ji. Jiiñi̱day Ju̱denu jiintyasi̱.” 
\p  
\v 35 Saniquejada ji̱ta Jesús jamiryamu variy siva: 
\p “Ya̱ndasa, ya̱sipyatay sivasiy.” 
\p Sajatya̱danumatiy bayantu riquebyimuni̱, sasipyateda samiryamusiy variy sivasiy.  
\v 36 Rityi̱tta̱da nijya̱nvay varirya, ru̱tañu̱yada variy yiva: “¿Nu̱tyura niquejada jirya, nu̱tyura? jiryatiy sadirya datya̱data, savanu̱yadata jarye yipa̱ sivasiryi bayantuveda va̱cha vichavay. ¿Nu̱tyu rityuva̱chute variy simunticyu̱, nu̱tyu?” 
\p  
\v 37 Raramityityiyada ji̱ta sa̱ticheyada Jesús rivyicha̱divaju̱ ti̱ta̱ju̱. 
\s1 Jesús mi̱sadeda nada Pyítrubay desedabay 
\r (Matévu 8.14-15; Márcu 1.29-31) 
\p  
\v 38 Saradesubeda ji̱ta Jesús, sasipyateda variy ju̱tye̱ryanijyovimusiy, sajañuvejada Siimyó̱bay rorivyimu variy. Siimyó̱bay desedabay ji̱ta saduyada jaryi variy. Riyasanta̱da variy nadaju̱ni̱ Jesús.  
\v 39 Saraniñuvejada ji̱ta nanutuunu, sanique̱tya̱da varirya nanusaduyada, raparu̱yada variy nadiva. Nanunubesubeda varicha̱ra̱ju̱, nanupotyadeda variy jasiryi Jesúsveda. 
\s1 Jesús mi̱sadeda riy jdiva̱jnuvajyuu 
\r (Matévu 8.16-17; Márcu 1.32-34) 
\p  
\v 40 Sapuryeyadanumatiy jiñi̱, ruuti̱ta̱da nijya̱nvay Jesúsmu riy jdiva̱jnuvay, jaryedo jdiva̱jadatavay. Saja̱tyo̱tityiyada jijyomututa variy riñiy, sami̱sadeda ti̱ta̱ju̱ variryi.  
\v 41 Bayantuveda jarye sipyateda rajuuvasiy variy, riche̱ñe̱ya̱nu̱yada bayantuveda variy: 
\p “Jiiñi̱ ji̱ta si̱tenu Ju̱denu denu.” 
\p Sanique̱tya̱da ji̱ta variryi, su̱bayada rirya̱jisirya niquejada, jiryatiy ridyetya̱da daryaju̱ sani̱cha Ju̱denu jaryeti̱. 
\s1 Jesús datyanunumaya̱jada vicha̱diva 
\r (Márcu 1.35-39) 
\p  
\v 42 Ra̱sacha̱danumatiy, saya̱da Jesús variy jadchiy yasiquita tajityomuju̱. Rivya̱tanu̱yada nijya̱nvay variy sana̱cho̱, richeryedanumatiñi̱, riñi tutaniya̱ru̱yada variy jasiñi̱, sañuma tochiryi.  
\v 43 Su̱teda variy ruuva: 
\p “Ra̱ma̱ tu̱chunuvera samitu̱choda Ju̱denu nusu̱yadanchiy taji vicha̱damu, jiryatiy ráju̱ jpa̱si̱ ray.” 
\p  
\v 44 Satu̱chunumaya̱jada variy Judéya ja̱nvay ju̱tye̱ryanijyovara. 
\c 5  
\s1 Riicyadoda jaryi ti̱ttasara 
\r (Matévu 4.18-22; Márcu 1.16-20) 
\p  
\v 1 Rivyiñutyaja̱jada nijya̱nvay variy rivani̱, rirya̱tidye tuva̱chu simusirya Ju̱denu niquejada. Saradeda Jesús variy Jenesaryé jmityo̱jiniy.  
\v 2 Sadiyada riva dajnuju̱y cartye jasiy, munañijyu̱ tiichara. Rirya̱subeda riicyanuvay ravimusiy jicyartye, richuuta̱da varirya ja̱mu riicya.  
\v 3 Su̱musa̱da Jesús ravimuju̱ tajnuqui cartye, jiryatiy ravicha̱da Siimyó̱bay cartye. Su̱teda variy siva Siimyó̱bay: “Ya̱siityaniy taraqui rajachena̱cho̱ju̱ra.” Sama̱sa̱danumatiy ravimu cartye, jadchiñuma sadatyadoda riy nijya̱nvay varintyi.  
\v 4 Saniquemu̱yadanumatiy ruuva, su̱teda ji̱ta variy Siimyó̱bavya: “Ya̱siityaniy taraqui nicha̱rijya̱muju̱. Jirya̱jmu̱ryara ja̱mu riicya jiyu, vinu taraqui ju̱redaju̱.”  
\v 5 Su̱mutya̱jada Siimyó̱bay variñi̱: “Ya̱jnu̱y Maestru, ti̱ta̱ju̱ nuporaca̱ nu̱ñi jantyana̱ya̱jasiy riicyadoda, ne nu̱dyiryiryu̱y nta ti̱. Yitedamuju̱numa nu̱ña̱jmu̱rya darya ja̱mu riicya day.”  
\v 6 Rijetya̱danumatirya ja̱mu riicyantiy, rureda ji̱ta variy rajuuni̱ quiva̱, rani rotyeryu̱yadanuma riicya variy sáju̱ quiva̱.  
\v 7 Riñuvatyaja̱jada variryi ratarya jnuvimu riicyanuvay, ru̱mu̱tyi̱savajyu̱. Ruuti̱jadanumatiy ruumu, rimyu̱chadeda varirya dajnuju̱y cartye quiva̱ta, riñi jaryu̱yadanuma variy sáju̱ day.  
\v 8 Su̱nu̱yadanumatiy Siimyó̱ Pyítrubay ti̱ta̱ju̱ra quiva̱ ju̱reda, sa̱dasidyoda sana̱cho̱ju̱ Jesús variyu, su̱teda variy siva: “Ya̱jiintye ratyuunusiy, Nutyityu̱, tapi ravyitya yinu̱y vanu juuchati̱.”  
\v 9 Sati̱tta̱da ji̱ta Pyítrubay, ti̱ta̱ju̱ yisa̱ vichavatyara quiva̱viñusuma ju̱richa̱da.  
\v 10 Daryaday nanuti̱tta̱da Santiyácubajyu̱y Juánbatyantirya, jiryatiy Sebedévubay denuju̱beñada. Nanuvichanu̱yada Siimyó̱bay jmu̱tyi̱ju̱y. Su̱teda ji̱ta Jesús variy siva Siimyó̱bay: “Ne ya̱jnutay, diyemusiy ji̱ta ya̱ca̱na̱y rimu tuva̱chodaju̱ riy nijya̱nvay.”  
\v 11 Riyata̱danumatirya jicyartye munañijyu̱, rityochiya̱jada variy jasiy ti̱ta̱ju̱ra, richiityari̱jada variy jadchiñi̱ Jesús. 
\s1 Jesús mi̱sadedani̱ vatajo̱ju̱ñubay 
\r (Matévu 8.1-4; Márcu 1.40-45) 
\p  
\v 12 Savicha̱danumatiy Jesús tavicha̱damu variy, siti̱jada ji̱ta nu̱ vanubay vatajo̱ju̱ñu simu. Sadiyadanumatiy siva Jesús, sara̱yada ji̱ta jimyo̱ta satuunu, sayasanta̱da variñi̱: “Nutyityu̱, jivya̱tatiy, ya̱pu̱y rivasirya vatajo̱.”  
\v 13 Saratya̱da ji̱ta Jesúsra jijyase variy sana̱cho̱ju̱, “Jo,” saja̱tyo̱jada variy saniy. Su̱teda ji̱ta variy siva: “Ravya̱tantye, sami̱numa ye̱cha.” Varicha̱ra̱ju̱ rabayada vatajo̱ sivasiy.  
\v 14 Su̱bayada ji̱ta sa̱jisirya tu̱choda ti̱va. “Ya̱numa ji̱ta jiya, ya̱tidye dityanunuve caserdóte ji. Jiryatiy rapu̱chama̱ daryaju̱ jivyatajo̱ yivasiyu, ne ti̱ ji̱ta ra̱suvu̱ñu̱day ji. Ramuni̱ ya̱sa̱dyerya jnutatyasara Ju̱denumu day, jiryatiy Muyusésibe jtedamuju̱ra, rirya̱tidye datya nijya̱nvay variy ranchiy: Ne ra̱ja̱tay ji̱ta jivyatajo̱ ti̱vaju̱nu̱day.”  
\v 15 Rara̱yada jaryivya̱ju̱ variy sa̱ticheyada, ripyana̱ryi̱jada nijya̱mi̱juu saniy variy, rirya̱tidye tuva̱chura saniquejada, rirya̱tidye mi̱sa yidiva̱jadamusintyi.  
\v 16 Ni̱day numutañu̱yada nijya̱nvayjisiy tajityomuju̱, sa̱tidye tu̱chu sisa̱ Ju̱denu rumu. 
\s1 Jesús mi̱sadedani̱ ju̱richi̱ni̱bay 
\r (Matévu 9.1-8; Márcu 2.1-12) 
\p  
\v 17 Rarundamu ji̱ta, sadatyadodanumatirya Ju̱denu niquejada, rimya̱sanuvejada Varyisévuvedabay, Ju̱denu niquejada datyanuvabe jarye ruusa̱ju̱ satuunu. Riñi jti̱jada rajuu vicha̱damusiy, Cadidéyamusiy, Judéyamusiy jarye, Jerusarí̱musiy jarye ti̱ta̱ju̱. Ravicha̱da ji̱ta Ju̱denu datya̱da simu Jesús variy jdiva̱jnuvay mi̱sadedaju̱.  
\v 18 Ru̱tutityiyada ji̱ta vadubeñi̱ ju̱richi̱ni̱bay. Riñi jteda ya̱jto̱ta ma̱yancha Jesúsmu ni̱.  
\v 19 Jiryatimyu̱ ne ridyiyada riva jajyo, ne tesiy riryijechuni̱ jdiva̱jni̱, jaryi nijya̱mi̱juu vicha̱da rorijyu̱mu daryaju̱, rirya̱subeda ji̱ta variy roriy nupadanchaju̱, rimyutta̱dara panu̱chadi variy sa̱jisiy, rirya̱tidye jmusaniy jadchiñi̱, nijya̱nvay cabyimuju̱, Jesústuunuju̱.  
\v 20 Su̱nu̱yadanumatiy Jesús riñe̱cho̱, jiryatiy rijechipityaja̱jada si̱tenu mi̱sanirya daryaju̱ni̱, su̱teda ji̱ta siva jdiva̱jni̱: “Jijyuuchuveda ra̱ramiy mitya yiva, jaamyicyu.” 
\p  
\v 21 Rijyo̱ta̱da ji̱ta jtaja̱doda Ju̱denu niquejada datyanuvabe Varyisévuvedabatyayu: “¿Chi̱ra jiñu, chi̱? jiryatiy sa̱vityiye̱ñi̱ Ju̱denu. ¿Chi̱ ramityanichara mityara juuchuveda, chi̱? Vinu Ju̱denu ramityanichara mityara.”  
\v 22 Sadatya̱danumatiy Jesúsra rijechipiya̱jada, su̱mutya̱jada ji̱ta variryi: “¿Nu̱tyuraju̱ra jiryitaja̱nu jiryejechimyuyu, nu̱tyuraju̱?  
\v 23 ¿Miryara jaryi datyasara, mirya? ra̱tiy jtay: Jijyuuchuveda ra̱ramiy mitya jijyu̱, varimyata ra̱jtay: Ya̱nubesumiy, ya̱rupichiy variy.  
\v 24 Jirya̱tidye jnu̱yasiy sa̱vidye ramityaniy Nijya̱mi̱denu sivara jijyuuchuveda jirya mucadimu,” su̱teda variy siva vanu ju̱richi̱ni̱: “Ri̱tay yiva: Ya̱nubesumiy, ya̱nchura jime̱ya, ya̱numa jiya jiryorimyuju̱ day.”  
\v 25 Saradesubeda ji̱ta varicha̱ra̱ju̱ ridyiya, sanchucheda varirya jityiryo̱jo, saya̱da ji̱ta jiryorimyuju̱, si̱chana̱tyachedani̱ Ju̱denu variy.  
\v 26 Rityi̱tta̱da jaryi variy, riichana̱tya̱da variñi̱ Ju̱denu, jiryatiy ru̱nteda jaryi daryaju̱, ru̱teda ji̱ta yiva: “¡Vu̱dyimya̱te riva ti̱ttasarate diye!” 
\s1 Jesús natuyadani̱ Devyíbe 
\r (Matévu 9.9-13; Márcu 2.13-17) 
\p  
\v 27 Rivasiñuma ji̱ta sasipyateda Jesús, su̱nu̱chunuvejadani̱ criquiy jmutya̱nu, Devyíy jtyati̱bay. Su̱mutya̱nu̱yadara criquiy ja̱mu nutyityu̱ju̱. Sama̱sa̱da Devyíbe criquiy jmutya̱jomu. Su̱teda ji̱ta Jesús variy siva: “Ya̱siityari̱sara ray.”  
\v 28 Satocheda Devyíbe ti̱ta̱ju̱ra jiberya, sanubeseda ji̱ta variy, sasiityari̱jada variñi̱ Jesús. 
\p  
\v 29 Sivaayada ji̱ta Devyíberya ja̱mu vichtya Jesúsju̱ jiryorimyu, nijya̱nvay jbyedaju̱. Jasiy rivyicha̱da variy rajuu criquiy jmutya̱vay sisa̱ jivyichtyamu, tavay nijya̱nvay jarye.  
\v 30 Ricyucuye̱yada ji̱ta Varyisévuvedabay,\f * \fr 5:30 \ft Varyisévuveda vichanu̱yada Ju̱denumu tuva̱chuvay, jiryatiy jaryi jaryuvu̱vye ruuvaaryu̱yadamu ti̱ta̱ju̱ daryatiy sanu̱yada Muyusésibe Ju̱denu jtedamu, ratarya datyadoda jarye risa̱ju̱ntiy, jiryatiy nijya̱nvay jachipiya̱jadamusirya.\f* jicyatera nu̱vyevyedabatya riñijyu̱ Jesúsjsa̱ datyavavyedabay. Ru̱teda ji̱ta variy ruuva: “¿Ta̱raju̱ jiryi̱myi ruusa̱, ta̱raju̱? jirya̱tu variy ruusa̱ criquiy jmutya̱vantyi. ¿Ne jiryi̱nu̱y juuchatavadyeryi?”  
\v 31 Su̱mutya̱jada ji̱ta Jesús riy: “Jiryatimyu̱ ne jdiva̱jnuvadyeryi, ne rivya̱tani̱ ju̱danu̱nu̱day; jiryatiy jdiva̱jnuvadyeryi, riñi̱ ji̱ta va̱ta dañi̱.  
\v 32 Ne ri̱niy samirya vichavay natuyadana̱cho̱ day, juuchatavay natuyadana̱cho̱ ji̱ta ri̱nidye, rirya̱tidye paru̱y riva taji jachipiya̱jada variy.” 
\s1 Ruutaja̱dodani̱ Jesús jmyichara jnura̱danchiy 
\r (Matévu 9.14-17; Márcu 2.18-22) 
\p  
\v 33 Ru̱teda ji̱ta tavay variy siva Jesús: “Juánjsa̱ datyavay ji̱ta jnurasara japichirya jmyichara, rityu̱chu sisa̱ Ju̱denu variy, daryani̱ ruuvaay Varyisévuvedajsa̱ datyavantyi. Yisa̱ datyavay ji̱tamu̱y ne datyara jmyichara jnura̱da day; richiityari̱ jibyeda varidye, rirya̱tu variy risa̱ju̱ntiy.”  
\v 34 Su̱teda Jesús variy ruuva: “¿Vurya̱ni̱viy jnurasutaniryi musuchavay ja̱mu̱yada rundamu, netimyu̱ ne sani jiintye ja̱mu̱ñu ruusa̱sidyidye?  
\v 35 Ra̱jti̱ rarunda varityi rirya̱so̱vay riquebyimusiñi̱ vadi ja̱mu̱ñu, variryundamu ji̱ta rirya̱ndara jmyichara.” 
\p  
\v 36 Satu̱choda variy ruuvara niquejada dityanusara: “Ne vu̱cheta sujay vadijatye, ta̱rijepyo curuchuta̱ju̱. Vu̱ryityi vicha darya, vu̱ryicheta varirya vu̱chujay vadijay, dantyamu̱y ne ra̱ma̱cho̱ samirya ta̱rijepyo ramusiy.  
\v 37 Dantyamu̱y ne vu̱bey bínuja̱ vadija̱ ravimu ta̱rijevyu̱po; vu̱betyi ravimura vadija̱, ra̱bucha varirya ta̱rijevyu̱po, rumichaja̱ ra̱cha variy, ra̱pa̱chitye variy sajavyu̱ risa̱ju̱ntiy.  
\v 38 Vu̱ryibe dyetya vadijavyu̱vimura bínuja̱ vadija̱.  
\v 39 Daryantyamu̱y ne vurya̱turu̱rya saboja̱, vurya̱tunumatirya casiya̱, vuryi̱tay ji̱ta variy: Casiya̱ ji̱ta jaryi samiryava̱ju̱.” Daryani̱ su̱mutya̱jada Jesús variryi.\f + \fr 5:39 \ft Jirya niquejadata sadityadoda Jesús: Ne vana̱y vu̱chiityari̱ samiñi̱, netimyu̱ ne vu̱tyi̱tuy munatya vadi nijya̱mi̱ju̱ simusiy.\f* 
\c 6  
\s1 Jesúsjsa̱ datyavavyedabay rotyatityiyadara jaruusibyi jiituyada rundamu 
\r (Matévu 12.1-8; Márcu 2.23-28) 
\p  
\v 1 Jiituyada rundamu ji̱ta, saramiryi̱jadanumatiy Jesús racabyimu jaruusiñi̱, riryotyatityiyada sisa̱ datyavavyedabay varirya rabi. Riibyeda varirya rasiy, jiryatiy rirya̱sutya jijyomura.  
\v 2 Ru̱teda Varyisévuvedabay tevay variy siva: “¿Ta̱ju̱ra jiryivaarya jiryatiy ju̱bachara Judíyuvedaju̱ jiituyada rundamu jvaayadaju̱ra, ta̱ju̱?”  
\v 3 Su̱mutya̱jada ji̱ta Jesús riy: “¿Ne jiryeñiquettara catera padye didye, nu̱tyura sivaayada Davyíbe sajachi̱jadanumatiy, nu̱tyura? yisa̱ vichavatya.  
\v 4 Varityi sajayada Ju̱denu rorivyimu, sireda ji̱ta varirya pa̱, jiryatiy ribeñu̱yada Ju̱denu jiyadaju̱ra, si̱byeda varirya. Sasa̱yada ji̱ta yisa̱ vichavay ratentiy, jiryatiy ju̱bachara rani̱chanu̱yada riibyedajisiy daryaju̱ra, tapi vinu caserdótevyeda jbyedaju̱ rani̱chanu̱yada day, jiryatiy Ju̱denu nijyu̱ jnutatyasara darya.”  
\v 5 Su̱teda Jesús variy ruuva: “Nijya̱mi̱denu ji̱ta jiituyada runda ja̱mi̱ day.” 
\s1 Vanu jomutu susa̱ñubay nchiy 
\r (Matévu 12.9-14; Márcu 3.1-6) 
\p  
\v 6 Ratarya jiituyada rundamu ji̱ta, sajayadanumatiy Jesús ju̱tye̱ryanijyovimu jidyetyadodaju̱, savicha̱da nu̱ vanubay jasiy, nutyityuday jomutu susa̱ñu.  
\v 7 Ru̱nu̱choda ji̱ta Ju̱denu niquejada datyanuvabe, Varyisévuvedabatyani̱ Jesús, sa̱vidye mi̱saniy jiituyada rundamuni̱, rirya̱tidye tu̱chuta variy darya jvaayadivani̱.  
\v 8 Sadatya̱da ji̱ta varirya rijechipiya̱jada, su̱teda variy siva jomutu susa̱ñu: “Ya̱nubesumiy, ya̱raniy rajache.” Saradesubeda ji̱ta variy.  
\v 9 Su̱teda ji̱ta Jesús variy ruuva: “Ritaja̱nu jirye, ¿Samiryavidye vu̱ryi jvaarya samirya jvaayada jiituyada rundamu, varimyata vu̱ryi jvaay dyetyara javatya̱da? ¿Vu̱ryivyidye jantyuy siva nijya̱mi̱, varimyata vu̱ryi javatyani̱?”  
\v 10 Su̱nu̱ya̱jada variy jamiryamu riñe̱cho̱, su̱teda ji̱ta siva jomutu susa̱ñu: “Ya̱ratyara jijyomutu.” Saratya̱danumatirya jijyase, rú̱dutyeda sajomutu varicha̱ra̱ju̱ ti̱ta̱ju̱.  
\v 11 Ramu̱chadeda ji̱ta nique̱yada varirya Varyisévuveda jachiy, rityu̱chudoda variy jasiyu: “¿Nu̱tyura vurye̱chaniñi̱ Jesús, nu̱tyura?” 
\s1 Jesús jaryeta̱da riy vu̱yaju̱y vadube, danu̱ju̱y rinchaju̱, sansu̱byimijyu̱ 
\r (Matévu 10.1-4; Márcu 3.13-19) 
\p  
\v 12 Variryundamu ji̱ta saya̱da Jesús musimyuju̱, sa̱tidye tu̱chu sisa̱ Ju̱denu jasiy, nuporaca̱ satu̱choda jasiy sisa̱.  
\v 13 Ra̱sacha̱danumatiy, sanatuyada yimuju̱ riy yisa̱ datyavay variy, sajaryeta̱da riquebyimusiy taraqui vu̱yaju̱y vadube, danu̱ju̱y rinchaju̱, sabayada variy yinsu̱byimijyu̱ riy.  
\v 14-16 Sabayadani̱ Siimyó̱bay, jiryatiy si̱tyadoda Pyítruni̱, jadchintyi sataryi̱ Antrésibe, jadchintyi Santiyácubay, Juánbay, Vedípebe, Bartodomévubay, Matévubay, Tumásabay, Santiyácubay jarye jiryatiy Ajéñubay denubañi̱. Jadchintyi Siimyó̱bay jiryatiy ru̱tachara jaryi vani̱ra niquerani̱, jadchintyi Judásibe, jiryatiy Santiyácubay denubadyeñi̱, jadchintyi Judásiy Iscaryótibe jiryatiy samityasiiñu̱yadani̱ Jesús. 
\s1 Jesús datyadoda riy rajuuvay nijya̱nvajyuu 
\r (Matévu 4.23-25) 
\p  
\v 17 Su̱musa̱da ji̱ta variy ruusa̱, saraniñuvejada vapa̱tyomu. Rivyicha̱da ji̱ta rajuu sisa̱ datyavay jasiy, tavay nijya̱nvajyuu jarye, jiryatiy ruuti̱jada Jesúsmu, rirya̱tidye tuva̱chu saniquejadamu, rirya̱tidye mi̱sa yidiva̱jadamusiy varintyi. Riintye̱ryadeda Judéya ja̱nvabeyu, Jerusarí̱ ja̱nvabe jarye. Jadchintyi ja̱mu na̱vajido vichavay, jiryatiy Tíru tuunu vichavaberyi, Sitú̱ ja̱nvabe jarye ruusa̱ju̱.  
\v 18 Jarupantasavay ji̱ta, jiryatiy jamirya vichara bayantu ruuva, rimyi̱sa̱da variy.  
\v 19 Rirya̱ntya̱da ja̱tyo̱jada nijya̱nvajyuu saniy Jesús, jiryatiy rasipyateda vanu̱yada simusiy, sami̱sadeda ji̱ta ti̱ta̱ju̱ variryi. 
\s1 Ratiy samirya ratya̱ju̱ dárya; ratiy vamiryamuju̱ dárya 
\r (Matévu 5.1-12) 
\p  
\v 20 Su̱nu̱yada ji̱ta riñe̱cho̱ yisa̱ datyavavyedabay, su̱teda variy ruuva: 
\q1 “Ju̱denu jmu̱tyasavay ji̱ta jiryeñi̱cha jantyuyani̱miy, jiryatiy jiryejyu̱ ravichasara Ju̱denu nusu̱jyo day. 
\q1  
\v 21 Ju̱denu jmu̱tyasavay ji̱ta jiryeñi̱cha jiryatiy diyedemusiy jachi̱vay jirye, jiryatiy jirye̱chasara potyadimyi variy. Ju̱denu jmu̱tyasavay ji̱ta jiryeñi̱cha jiryatiy diyedemusiy jirye̱cha ju̱na̱vye, jiryatiy jirya̱todiye̱chara rivasintyi. 
\q1  
\v 22 Ju̱denu jmu̱tyasavay ji̱ta jiryeñi̱cha, rirya̱numatiy javittyuy nijya̱nvay jirye, jiryatiy rirya̱vittyuy Nijya̱mi̱denu jiyadasiy jirye, rirya̱numatiy rrachu variy jiryentyi, rirya̱numatiy javityiye̱ jiryentyi, rirya̱numatiy jatya nu̱tyu nicyara̱y ntara jiryi̱tya variy risa̱ju̱ntiy. 
\q1  
\v 23 Jirya̱jchana̱yasiy variryundamu, jirya̱caviñe̱chichesiy yichana̱yadamu varintyi, ne jiryi̱nu̱y, ja̱murasuma ra̱cha jiryemyurichenusa̱da jarichumu; daryaday rivyichadeda ta̱rijye̱myiryi Ju̱denuju̱ tu̱chuvabentyi, rivyicha̱da Ju̱denu jmu̱tyasavay ru̱co̱siy varintyi. 
\p  
\v 24 Jiii, ta̱ju̱na̱te jirye, ta̱ju̱, jiryatiy jaryi tara tavañuma jirye, jiryi̱mutya̱mu̱mya̱ daryaju̱ra jiyaru̱rya. 
\p  
\v 25 Jiii, ta̱ju̱na̱te jirye, ta̱ju̱, jiryatiy povyeñumate ti̱ta̱ju̱ jirye, jirya̱day jachi̱ tapi rivasintyi. 
\p Jiii, ta̱ju̱na̱te jiryetyodiye̱tye day, ta̱raju̱, jirya̱day nuvavya̱ rivasintyique jiryi̱na̱yadasa̱ra̱ju̱. 
\p  
\v 26 Jiii, ta̱ju̱na̱te jirye, ta̱ju̱, rirya̱numatiy baya̱ nijya̱nvay jiryeñijyu̱, rirya̱jvatanu variy rata jirye, darya ni̱day rivyichadeda ta̱rijye̱myiryi, jiryatiy ránubesivye Ju̱denuju̱ tu̱chuvabentyiryi.” 
\s1 Jesús datyadoda: “Vurya̱ntya va̱tasara riy vu̱myityasimyi” 
\r (Matévu 5.38-48; 7.12) 
\p  
\v 27 “Ri̱tatye ji̱ta jiryiva tuva̱chuvay: Vurya̱ma̱ va̱tasara riy vu̱myityasimyi; vurya̱ma̱ vichanichara samiryariy jiryatiy rirya̱vittyuvyu̱y.  
\v 28 Vurya̱ma̱ jachiñu̱y riyadaju̱ jiryatiy ridyeya̱ vu̱ñijyu̱; vurya̱ma̱ tu̱chu sisa̱ Ju̱denu riyadaju̱ jiryatiy rirya̱vatya vu̱y.  
\v 29 Vurya̱ma̱ janumitya sana̱cho̱ju̱ra ratarya ma̱yantiy, ni̱tiy jvay vu̱me̱yaniy vu̱jyu̱; ne vurya̱ju̱bay sa̱jisintyirya vu̱chujantyi ni̱tiy so̱vay vurya̱jisirya vu̱cho̱tajay.  
\v 30 Vurya̱ma̱ sa̱y tarani̱ ni̱tiy jachiñu̱y tara vuryiva; ne vurya̱jachiñu̱y ju̱na̱y sivantirya vu̱beryantiy, jiryatiy saso̱vay vuryimusirya.  
\v 31 Vurya̱ma̱ vichaniy darya riy tavantyidye, daryatiy vu̱ryivya̱ta rirya̱vichanintyidyevyu̱y. 
\p  
\v 32 Vu̱ryityi va̱ta riy, vinuriy rityi va̱ta̱da munatya vu̱y, ¿ta̱raju̱ra rirye̱jchana̱tya nijya̱nvay ramusiy vu̱y, ta̱raju̱? Juuchatavay jarye va̱tantiryi rityi va̱ta̱da munatya riy.  
\v 33 Vu̱ryityi vichaniy samiñi̱, ni̱tiy vichaniy samiy munatya vu̱y, ¿ta̱raju̱ra rirye̱jchana̱tya nijya̱nvay riva vu̱y, ta̱raju̱? Juuchatavay jarye vichanichara daryantiy.  
\v 34 Vu̱ryityi sa̱y tarani̱, vurya̱tidye jmutya̱ tarundamu tara simusintyidye, ¿ta̱raju̱ra rirye̱jchana̱tya nijya̱nvay riva vu̱y, ta̱raju̱? Juuchatavay jarye sa̱chara riy jiryenu juuchatavay tarantidye, rirya̱tidye jmutya̱ darya tara ruumusintyidye.  
\v 35 Vurya̱ma̱ va̱tasara riy vu̱myityasimyi, vurya̱ma̱ vichasara samirya jachityavay; vurya̱ma̱ sa̱chara tarani̱ ti̱, dañumamu̱y ne vurya̱jmutya̱ tara simusintyidye. Ja̱murasuma ji̱ta ra̱cha daryaju̱ vu̱myurichenusa̱da variy, vurye̱cha variy Jarichumuvichi̱ dadyeñu; tapi ni̱vitya sani̱cha samirya jachityi̱ riñijyu̱ jiryatimyu̱ ne jchana̱tyavaryi, va̱cha jachipiya̱vañijyu̱ jarye.  
\v 36 Vurye̱cha jantyutyavay, daryani̱ sani̱cha jantyutyi̱ Vu̱jye̱ Ju̱denuntidye.” 
\s1 Jesús datyadoda: “Ne vurya̱jachipiya̱ taji tu̱chuta̱da ti̱nijyu̱” 
\r (Matévu 7.1-5) 
\p  
\v 37 “Ne vurya̱jachipiya̱ taji ti̱nijyu̱, dantyamu̱y ne vinu ni̱ ra̱jachipiya̱ taji variy vu̱ñijyu̱ntidye. Ne vurya̱tu̱chutani̱ ti̱, dantyamu̱y ne sa̱tu̱chuta ti̱ varintyidyevyu̱y. Vurya̱ramityaniy mityara ti̱ juuchuveda; ramityanichara dyetya ra̱cha̱siy variy vu̱jyu̱ntidye.  
\v 38 Vurya̱ma̱ vichasara sa̱yada jachityavay, Sa̱sa̱y saranusara varivyu̱y, samiy mu̱chanichara sa̱sa̱y varivyu̱y, samiy sana̱sara; muchutyasara, nupadaquinusara sa̱sa̱y varivyu̱y. Daryatiy vu̱charanu tavajyu̱ tara, daryaday rirya̱saranu variy vu̱jyu̱ntidye.” Sadatyadoda ji̱ta Jesús darya niquejadata jasiryi. 
\p  
\v 39 Satu̱choda ji̱ta variy ruuvara niquejada datyanusarantiy: “¿Vana̱vyidye sa̱mutay ni̱sipyuryiñi̱ jiryenu ni̱sipyuryi? ¿Neviy nana̱ju̱u̱y mityijyijyu̱y vatajomu day?  
\v 40 Ne rivyichasara sisa̱ datyavay jaryiñuvay simusiy jidyetyanu̱. Samiy datyanusavañumatiy rirye̱cha, rirye̱cha ji̱ta variy nu̱tyu jidyetyanu̱. 
\p  
\v 41 ¿Nu̱tyichiy vu̱ryidyi vu̱tyeryi̱ ni̱simyu riva radaryudyera, nu̱tyichiy? netimyu̱ ne vu̱dyetya ravicha jiipudaryuy vu̱ñi̱simyu.  
\v 42 ¿Nu̱tyuramusiy vurya̱jtay siva vu̱tyeryi̱, nu̱tyuramusiy? Pi̱, ra̱day sipyata jiñi̱simyusirya radaryudyera, netimyu̱ ne vu̱dyi vu̱ñi̱simyu riva jiipudaryuy didye. Netimyu̱ ne vuryi̱tu̱yadamu vichavavyu̱y, vurya̱sipyata munatya vu̱ñi̱simyusirya jiipudaryuy, rivasiy ji̱ta vurya̱diy riva vanda, vurya̱tidye sipyata variy vu̱tyeryi̱ ni̱simyusirya radaryudyentidye.” 
\s1 Jesús datyadoda: “Vu̱dyetyara ni̱nu rajomusiy” 
\r (Matévu 7.17-20; 12.34-35) 
\p  
\v 43 “Ne rajontay samiñu darya nicyara̱jyo day, dantyamu̱y ne vana̱y rajontay nicyara̱ñu samijyontidye.  
\v 44 Vu̱dyetyara ni̱nu nu̱ñi rajonchiy daryaju̱. Ne vu̱chora ramuya̱ ju̱bonumusiy, dantyamu̱y ne vu̱cho cariitunumusirya sámu̱síy.  
\v 45 Daryaday vuryivaachara samiy nijya̱mi̱ra samiy jvaayadantiy, jiryatiy rajontay vu̱jechiy samirya jachipiya̱jadamusiy. Vuryivaachara jamirya vicharara va̱cha jvaayada, jiryatiy rajontay vu̱jechiy va̱cha jachipiya̱jadamusiy. Vuryi̱tosiy ji̱ta rasipyatachara niquejada daryaju̱ jiryatiy vu̱beyada vu̱jechimyura.” 
\s1 Jesús datyadoda nu̱tyura ju̱daryancha vu̱ryi vichajaya̱sara ti̱ta̱ju̱ 
\r (Matévu 7.24-27) 
\p  
\v 46 “¿Ta̱raju̱ra jiryi̱tay Nutyityu̱ ray, ta̱raju̱? tama̱ jiryeñi tuva̱churu̱y ramu rañiquejada.  
\v 47 Ra̱dityanu jirye nu̱tyura sani̱cha nijya̱mi̱ ni̱tiy ju̱ti̱ rimu, ni̱tiy tuva̱chusara variy ramu rañiquejada, sasiityesara variy raju̱ntiy.  
\v 48 Ni̱ni̱ sani̱cha nu̱tyu vanu roriiñu. Su̱beda ji̱ta nicha̱rijyu̱, sa̱tidye bay surraju̱ra yituvu̱. Ranijye̱yadanumatiy na̱va, raja̱tya̱jada ja̱a̱ saroriñiy, ne vana̱y rasiquityatadedara, jiryatiy samiy jvaachara daryaju̱ra.  
\v 49 Ni̱ni̱ ji̱ta ni̱tiy tuva̱chura rañiquejada, dantyamu̱y ne sasiityeru̱y variy raju̱, ni̱ni̱ sani̱cha nu̱tyu vanu roriiñuntiy. Su̱sitya̱da vattadera jiryorintuvu̱. Raja̱tya̱jadanumatiy ja̱a̱ raniy roriy, rajottimyu̱yada ti̱ta̱ju̱ varirya, pattaryityera.” 
\c 7  
\s1 Jesús mi̱sadedani̱ su̱tarumiy nutyityu̱bay muchechibe 
\r (Matévu 8.5-13; Juán 4.43-54) 
\p  
\v 1 Saniquemu̱yadanumatiy nijya̱nvay tuva̱chodaju̱ra yiteda, sajañuvejada Capernavú̱mu variy.  
\v 2 Savicha̱da ji̱ta su̱tarumiy nutyityu̱bay, muchechityi̱. Samuchechiy jaryi sava̱tasi̱ jdiva̱jada variy, vadiiryo̱numa variñi̱.  
\v 3 Satuva̱chodanumatiy sanchiy Jesús, su̱pa̱jada ji̱ta simuriy Judíyuveda rimyityumibe, rirya̱tidye jiyasantani̱: “Ye̱jiya, ya̱tidye jantyuñuve siva su̱tarumiy nutyityu̱ muchechiy.”  
\v 4-5 Ruuto̱jadanumatiy simu Jesús, riyasantanuvejada variñi̱: “Nu̱ñi va̱ta ye̱chaniy daryani̱, sava̱ta daryaju̱riy vu̱tyevay, saroriiyada varirya ju̱tye̱ryanijyo nu̱jyu̱.”  
\v 6 Saya̱da ji̱ta Jesús variy ruusa̱. Nu̱jipyudenumatiy ravicha̱da su̱tarumiy nutyityu̱bay roriy, su̱pa̱jada ji̱ta su̱tarumiy nutyityu̱baryi jidyetyavabe, rirya̱tidye jtay siva Jesús: “Ne ya̱jarupanu ji raryorimyu jto̱jadate, tama̱ racha̱ra̱nu ntate day ji, tama̱ ya̱jto̱jay raryorimyu.  
\v 7 Dantyamu̱y ne rajechipiya̱ samiy jvadichi̱ ray, ra̱jto̱jay yimu. Mitya ya̱niquera niquejada, sa̱tidye mi̱sa̱sumiy ramyuchechiy variy.  
\v 8 Tapi ray ji̱ta vichasara sabonichi̱ rayntyityu̱ju̱ day, rachabonintyiryi su̱tarumintyi. Ri̱tay siva ti̱: ¡Ye̱jiya! saya variy; nu̱vantiy: ¡Ya̱jniy! su̱niy varintyi; ri̱tatyi ramyuchechivyantiy, ¡Ya̱jvaarya jirya! sivaay varintyirya.”  
\v 9 Satuva̱chodanumatiy Jesúsra saniquejada, sati̱tta̱da variñi̱, sa̱numityeda nijya̱nvajyuuna̱cho̱ju̱ jiryatiy richiityari̱nu̱yadani̱, su̱teda variy ruuva: “Ri̱tay jiryiva: Netaramu vinu ratyevay Irayénuveda cabyimu radyi ti̱va nu̱tyu jiñu, vuryimu tuva̱churá.”  
\v 10 Ruuti̱jadanumatiy su̱tarumiy nutyityu̱bay jpa̱vabe jiryorimyuntiy, ridyiñuvi̱jada ji̱ta siva muchechiy, mi̱si̱numa day. 
\s1 Jesús mi̱sadeda diibyimusiñi̱ bacheno̱dabay denubay 
\p  
\v 11 Tarundamunuma ji̱ta saya̱da Jesús vicha̱damuntiy, Nayí̱ jtyataramu. Riya̱da sisa̱ datyavavyedabay yisa̱, rajuu nijya̱nvay jarye ruusa̱ntiy.  
\v 12 Rityuudiyadanumatirya vicha̱da ju̱ro̱ puryesara rorijyu̱, jadchiy ji̱ta ru̱nu̱yada ru̱tutityiyadani̱ diidabi. Vinu ni̱deni̱ sani̱chanu̱yada nanudenu su̱no̱da, jiryatiy bacheno̱da nada. Rajuu vicha̱da ja̱nvay jnu̱yada nadisa̱ni̱.  
\v 13 Sadiyadanumatiy Jesús nadiva, sa̱ntyutya̱da variñada. Su̱teda ji̱ta nadiva: “Ne sa̱na̱ju̱na̱y.”  
\v 14 Saja̱tya̱nuvejada ji̱ta raniy sabapyojo variy. Riryadeda ji̱ta nichuvay variy jasiy. Su̱teda ji̱ta variy diibyiva: “Yiva ri̱tay, Vadero̱nu, ¡Ya̱numa nubesumiy!”  
\v 15 Sama̱sa̱subeda ji̱ta diibyi variy, sajo̱ta̱da niquejada varintyi. Sasa̱yada ji̱ta Jesús su̱no̱dayu.  
\v 16 Ru̱nteda ti̱ta̱ju̱ nijya̱nvay variy, riichana̱tya̱da ji̱ta variñi̱ Ju̱denu, jiryatiy ru̱teda: “¡Sanubesesitye Ju̱denuju̱ tu̱chu̱ jaryiñu̱te vu̱quebyimu! ¡Sajañu̱mya̱ ji̱ta Ju̱denu jiñijya̱nvamyu!”  
\v 17 Ra̱ticheyada ji̱ta jirya tu̱choda, Judéya ju̱ro̱ju̱ ti̱ta̱ju̱. 
\s1 Ruuti̱jada Juán Bautístabay jpa̱vabe simu Jesús 
\r (Matévu 11.2-19) 
\p  
\v 18 Juánbaysa̱ datyavay ji̱ta tu̱chunuvejada variy yiva ti̱ta̱ju̱.  
\v 19 Sanatuyada ji̱ta Juánbay variñada danu̱ju̱y yisa̱ datyanu̱jyu̱be, su̱pa̱jada variy Jesúsmu jtaja̱nu̱jyu̱ñada: “¿Jiñi̱viy jiryatiy yatiche jti̱jada, varimyata nu̱ryi nutuyasiy ti̱jiju̱ntiy?”  
\v 20 Nadito̱jadanumatiy Juánbaysa̱ datyanu̱jyu̱be simu Jesús, nani̱teda ji̱ta siva: “Su̱pa̱jasiy Juán Bautísta yimu na̱y, na̱ña̱tidye jtaja̱nu ji: ¿Jiñi̱viy jiryatiy yatiche jti̱jada, varimyata nu̱ryi nutuyasiy ti̱jiju̱ntiy.”  
\v 21 Varidye ji̱ta sami̱sadeda Jesús riy rajuu jdiva̱jnuvay, jarupantasavay jarye, jamiryanu bayantu tavay jarye, su̱nu̱yasumityaniy variryi ni̱sipyuryimyi ruusa̱ju̱ntiy.  
\v 22 Su̱mutya̱jada ji̱ta variñada Juánbaysa̱ datyanu̱jyu̱be: “Sa̱na̱tu̱chunuve siva Juán jiryatiy sa̱nudimya̱ riva, sa̱nutuva̱chuma̱ risa̱ju̱ra, nu̱tyuramusiy ru̱nu̱yasumiy ni̱sipyuryimyi, nu̱tyuramusiy, canuya̱sivyeda jarye rupi, vatajo̱ju̱vye jarye mi̱sa, tu̱yupuryimyi jarye tuva̱chu, diibyimiy jarye mi̱sa̱sumiy, jantyuyadavay jarye tuva̱chusarara samitu̱choda.  
\v 23 Ju̱denu jmu̱tyasi̱ ji̱ta sa̱cha mi̱ni̱tyimyu̱ ne ra̱casinu̱ya̱ rachiityari̱sa̱dajisiy.” 
\p  
\v 24 Nadaya̱danumatiy Juánbaysa̱ datyanu̱jyu̱be, sajo̱ta̱da niquejada Jesús variy nijya̱nvavya sanchiy Juánbay. “Ta̱rana̱cho̱ jiryevya̱tanuveti tajityomu, ta̱rana̱cho̱? ¿Jiryeyati vinu jirya̱tidye diñuve ti̱va jiryatiy rajuura jachipiya̱rani̱, nu̱tyu vachutyi nuvatyaja̱sara riichomusiy?  
\v 25 ¿Jiryevya̱tati dyetya sana̱cho̱ nijya̱mi̱ vasidyajay sujatyi̱? Ne jiryi̱nu̱y, rityi vichasara jaryi sujatyavay, jaryi samirya baryatavay jarye, rivyichasara ji̱ta ja̱mu nutyityu̱ rorivyimu.  
\v 26 ¿Ta̱rana̱cho̱ ji̱ta jiryevya̱tati si̱tenu variy, ta̱rana̱cho̱? ¿Ju̱denuju̱ tu̱chu̱na̱cho̱ dyetya? Jo, jaryivya̱ju̱ Ju̱denuju̱ tu̱chu̱ jiyadaju̱teni̱.  
\v 27 Ni̱ni̱ ji̱ta sani̱cha, jiryatiy nu̱chara sanchiy: 
\q1 Ri̱pa̱ ji̱tani̱ raynsu̱byi jimyo̱muju̱, sa̱tidye jdutyara nú̱ yajiju̱. 
\m  
\v 28 Ri̱tay ji̱ta jiryiva: Ne ti̱ jaryiñu̱ Juánmusiy, jiryatiy vaturu̱myusiy rupi̱ni̱. Dañuma ri̱tay daryá, mi̱ni̱tyi vichasara rirya̱rijyu̱ játarya Ju̱denu siityari̱vamyusiy, sani̱cha jaryiñu̱ simusiy Juán.  
\v 29 Ti̱ta̱ju̱ Juánmu tuva̱chuvay, criquiy jmutya̱vay jarye, riñi̱ ji̱ta dityanunu̱yada vasera Ju̱denu jvaayada, jiryatiy riityu̱yada Juán jtyadodata.  
\v 30 Varyisévuveda ji̱ta, Ju̱denu niquejada datyanuvay ruusa̱, riñi rrachodara Ju̱denu jteda jiñijyu̱, jiryatimyu̱ ne riityu̱ryu̱yada Juánmu. 
\p  
\v 31 ¿Nu̱tyura ni̱ta ra̱jtay riñijyu̱ nijya̱nvay jijyomucu̱, nu̱tyura? ¿Nu̱tyura jantyasarata ra̱dityanu rinchiy, nu̱tyura?  
\v 32 Riñi̱cha ji̱ta nu̱tyu deramiy pudásamu ma̱savay. Rityiyi̱saru̱yadamu jityu̱chuta tavayu: Dañuma nu̱ñi ruudiye̱ jiryejyu̱, ne jiryerye̱ya̱ru̱y nta variy. Dañuma nu̱ñi sutyaniy nu̱tyu diibyituunu jna̱yadamu nta, ne jiryi̱na̱ryu̱y nta variy ranchintyi.  
\v 33 Darya ri̱tay, jiryatiy su̱deda Juán Bautísta jmyichara jnurará: ne si̱byedara pa̱, dantyamu̱y ne sa̱todara bínuja̱, jiryi̱teda variy sanchiy: Bayantu siva.  
\v 34 Siti̱ma̱ ji̱ta Nijya̱mi̱denu ne jmyichara jnurará, jiryatiy si̱myi, sa̱tu jarye variy risa̱ju̱. Jiryi̱tay variy: Ta̱ jaryi jibyedajachi̱ ni̱day, niyu̱yadacanuy risa̱ju̱ni̱. Ni̱ni̱day criquiy jmutya̱vay jaamyicyu, jiryatiy juuchatavaryi.  
\v 35 Dañuma rirye̱chasara vasevay jiryatiy Ju̱denumusiy datyavadyeryi.” 
\s1 Jesús vicha̱da musuchi̱ Varyisévumu, jiryatiy Siimyó̱ jtyati̱bañi̱ 
\p  
\v 36 Samusuyada ji̱ta Varyisévuveda tenubay jbyedaju̱ni̱ Jesús, sajañuvejada ji̱ta variy sarorivyimu, sata̱yada ji̱ta jbyedaju̱ mi̱saniy.  
\v 37 Nanuvichanu̱yada ji̱ta tanu̱qui vaturu̱be juuchatanu̱y jasiy. Nanudatya̱danumatiy: Mu̱y si̱myi Jesús, Varyisévu rorimyu, nani̱toda variy rumura vu̱rudija̱vu̱, jiryatiy adabástrura ravichu̱teravu̱dera.  
\v 38 Nanuraniñuvejada sarudivasiy sanumututuunu Jesús, nani̱na̱ñuvejada variy jasiy. Rajo̱ta̱da paruyada sanumutu nani̱na̱ya̱ta, nanususa̱jada ji̱ta yino̱jasitya varirya sanumutu. Nanusiidyoda ji̱ta sanumutuvantiy, vu̱rudija̱ nadiva̱da sanumutuva varintyi.  
\v 39 Sadiyadanumatiy vichtya ja̱mi̱ riva vaturu̱y vicha̱da, sajachipiya̱jada yimu variy: “Si̱tenu Ju̱denuju̱ tu̱chu̱tiy saryivyichasara jiñu, saryidyetya̱siñada vaturu̱y, chanu̱rya nani̱cha, nu̱tyura vaturu̱y nani̱cha day, jiryatiy nadivá sivara vu̱rudija̱, tapi juuchatanu̱y vitya nani̱cha daryaju̱ day.”  
\v 40 Su̱mutya̱jada ji̱ta Jesúsra Siimyó̱bay jachipiya̱jada: “Siimyó̱, ri̱taryu̱y tara yiva.” “Jo, ya̱numa jtarya, Datyanu̱.”  
\v 41 Su̱teda Jesús variy siva: “Nanuvichanu̱yada danu̱ju̱y divyityanu̱jyu̱y, nanudivyiyadani̱ criquityi̱. Ti̱qui divyiyada davaatajyu̱y jvaayada murichirya, nu̱ntiy divyiyada danu̱ju̱y jarimyuni̱ jvaayada murichirya.  
\v 42 Jiryatimyu̱ ne tarajna̱y tara nadimu, ta̱rata nana̱murichenura jidyivyi, saramityadedara nanudivyiy ti̱ta̱ju̱ mitya. ¿Mi̱ra ra̱va̱ta jaryi nadimusiy rivasiñi̱ jipyatru̱, mi̱?”  
\v 43 Su̱mutya̱jada ji̱ta Siimyó̱bay: “Rañi jtatye mi̱vara saramityaniy jaryivya̱ju̱ra.” Su̱teda ji̱ta Jesús variy siva: “Jasidye yitay vasera.” 
\p  
\v 44 Sa̱numityeda Jesús variy vaturu̱y na̱cho̱ju̱, su̱teda ji̱ta siva Siimyó̱bay; “¿Jidyi nadiva jiñu̱y vaturu̱y? Rajeyasiñumatiy jiryorivyimu, ne jiche̱yasiy ja̱a̱ rañumutu suuta̱ja̱ju̱ ray. Nada ji̱ta parodesiy yina̱ya̱tara rañumutuday, nanususa̱ jasiy variy yino̱jasityantirya.  
\v 45 Dantyamu̱y ne jimyu̱chuvesiy siidyodata rajeyadamu ray, nada ji̱tamu̱y ne paru̱y riva siidyoda rañumutuva rajeyadamusidye.  
\v 46 Ne jiryubesirya ni̱ja̱ ri̱no̱muntiy, nu̱tyu jivyichanicharatiy daryani̱ jañu̱ñu, nada ji̱ta jva̱siy vu̱rudija̱ rañumutuva day.  
\v 47 Ramuni̱tiy ri̱tay yiva: Ramityanicharanuma nanujuuchuvedavicha̱ day, ramuni̱ nanuva̱tasara jaryirye. Ne sava̱ta jaryi daryaju̱ ray, saju̱timyu̱y ne ramityanichara jaryirya jijyuuchuveda.”  
\v 48 Su̱teda ji̱ta variy nadiva vaturu̱y: “Ramityanicharanuma sa̱nujuuchuveda.”  
\v 49 Jasiñuma ji̱ta rijyo̱ta̱da niquejada Jesúsjsa̱ jmyivyebe jivyimu: “¿Chi̱ra sani̱cha jiñu day, chi̱? jiryatiy saramityaniy mityara juuchuvedantiy.”  
\v 50 Su̱teda ji̱ta Jesús variy vaturu̱vya: “Sa̱nutuva̱choda ji̱ta jantyuy yiva, sa̱nunuma jiya samiy.” 
\c 8  
\s1 Vatuvyedabay jiryatiy ru̱mu̱tyanu̱yadani̱ Jesús 
\p  
\v 1 Jadchiy ji̱ta sarupiñumaya̱jada ja̱mu vicha̱da cabyiva, pasivyicha̱da cabyiva jarye. Sadatyanunumaya̱jada, satu̱chunumaya̱jada risa̱ju̱ra samitu̱choda Ju̱denu nusu̱yadanchiy, jiryatiy sansu̱ryu̱ñuma vuryi̱nu̱yadamu. Rivyichanu̱yada sisa̱ datyavay yisa̱ vu̱yaju̱y, danu̱ju̱y rinchaju̱.  
\v 2 Rivyichanu̱yada vatuvyedabay mi̱savay sisa̱ntiy, jiryatiy sami̱sadeda jamiryanu bayantujisiryi, va̱cha jdiva̱jadajisiy jarye. Nanuvicha̱da Maríyaju̱be jasiy, Mardánamusiñu̱y, rimya̱seda ji̱ta danu̱ju̱ñijyate bayantuveda nadivasiy.  
\v 3 Nanuvicha̱da nadisa̱ntiy Juánaju̱be, Chúsabay vaturu̱y, jiryatiy Jeródesbe nusu̱byini̱, Susánabay jarye, tavay jarye vicha̱da ruusa̱. Ru̱mu̱tyanumaya̱jada jiberyata riy Jesúsveda. 
\s1 Jesús tu̱choda nuti̱nchiy 
\r (Matévu 13.1-9; Márcu 4.1-9) 
\p  
\v 4-5 Rajuu nijya̱nvay ju̱tye̱ryadeda ti̱ta̱ju̱ vicha̱divasiyu, jiryatiy ru̱niñu̱yada Jesúsmuju̱. Riintye̱ryadedanumatiyu, su̱teda Jesús variy jidyetyadoda niquejadamu ruuva: “Saya̱da ji̱ta ti̱qui nuti̱, sa̱tidye nutara nutasarasiy. Santa̱damu ji̱ta raju̱u̱yada ratesiy nú̱va, jasityi riryaniye̱yada nijya̱nvarya, riimyimyu̱yada ji̱ta nipya̱tavay variy jadchirya.  
\v 6 Ratesiy jarye ju̱u̱yada ravichu̱ cabyiva. Rani dipuvedanumatiy ramu̱myu̱yada variy jasiy, jiryatiy rasu̱tyeda ja̱a̱ daryaju̱ raju̱.  
\v 7 Ratesiy jarye ju̱u̱yada cariitujnutiy cabyiva, rani̱ cariitu jo̱ta̱da ja̱vyeda ra̱jisiy nutasarasidye, radiryo̱doda variy jasirya.  
\v 8 Tasiñi̱ ju̱u̱yada samiy mucadimu day, raja̱vyeda variy, ra̱sa̱yada ji̱ta rasiy variy, taraqui pachasiy sa̱ra̱ju̱.” Satu̱chodamu yiteda jaryi: “Jiryetyuva̱chuta̱ta tu̱yutavay.” 
\s1 Nu̱tyuraju̱ saniquejada Jesús dityadoda tu̱chodata, nu̱tyuraju̱ 
\r (Matévu 13.10-17; Márcu 4.10-12) 
\p  
\v 9 Ruutaja̱dodanumatiy sisa̱ datyavayu: “¿Ta̱ra ranique jirya jidyetyadoda tu̱choda, ta̱ra?”  
\v 10 Su̱mutya̱jada ji̱ta: “Vinu jiryeñiy sasa̱yada Ju̱denu darya mityamusiy datya̱da day, jiryatiy mityamusiy datya̱da Ju̱denu nusu̱yadanchidyerya; tavajyu̱ ji̱ta ratyu̱chu vinu dityadoda tu̱chodata dárya, dañuma rirya̱jnu̱y, ne rirya̱diy tariva; dañuma rirya̱tuva̱chu, ne rirya̱datya varirya.” 
\s1 Jesús datyatadedara tu̱choda nuti̱nchiy 
\r (Matévu 13.18-23; Márcu 4.13-20) 
\p  
\v 11 “Jirya ji̱tara datyanusa̱da tu̱chodanchiy: Nutasarasiy ji̱ta Ju̱denu niquejada day.  
\v 12 Jivye jiryatiy nú̱va riy, rityuva̱chuma̱ra Ju̱denu niquejada. Su̱niy bayantu nutyityu̱ varidye, saso̱vay varirya Ju̱denu niquejada rijechivyasiy, riñuma tuva̱chu variy ramu yentyutyasa̱damuju̱.  
\v 13 Jivyentyi jiryatiy ravichu̱ cabyiva riy, rityuva̱chunumatirya saniquejada, ru̱mutya̱ variy jichana̱yadamura. Jiryatimyu̱ ne jnutityavay nta daryaju̱ riy, ne richuru̱ryu̱y jityuva̱chodamu, jarupantasa̱da rundamu ji̱ta ripyaru̱y variy riva.  
\v 14 Jirya ji̱ta, jiryatiy cariitu jnutiy cabyiva ju̱u̱ryara, dañuma riñi̱cha tu̱yutavay, ripyaru̱mya̱ variy riva jichiityari̱jada, jiryatiy rijechipiya̱ daryaju̱ taranijyu̱, nu̱tyuramusiy vu̱ryicha taratavay, nu̱tyuramusiy vu̱ryicha jchana̱yadacanumiy. Ne rajay rityuva̱choda variy samirya vicha̱damuju̱.  
\v 15 Jirya ji̱ta, jiryatiy samiy mucadincha ju̱u̱ryara, riñi̱day tuva̱chu samirya jachityavay vicha̱damuju̱ra saniquejada, rajay rivyicha̱da tapimusiy vicha̱data variy.” 
\s1 Jesús datyadoda no̱no̱danchiy 
\r (Márcu 4.21-25) 
\p  
\v 16 “Vu̱ryupañumatirya no̱no̱siiy, ne vu̱myutanu tarata varirya, dantyamu̱y ne vu̱bey vu̱me̱ya jarirya. Vu̱bey ji̱ta rabajyonchayu, rirya̱tidye diy nijya̱nvay jañu̱vye variy riva rada.  
\v 17 Ti̱ta̱ju̱ jiryatiy dutyasara diyera, ra̱cha variy dityanusara rivasintyi; ti̱ta̱ju̱ jiryatiy mityamusiy datyasara diyera, jvadatyasara ra̱cha varintyi. 
\p  
\v 18 Jiryetyuva̱chuta̱ta samiy radyetyadodamu, tapi simu jiryatiy tarati̱ni̱, sa̱sa̱y Ju̱denu variy ju̱na̱ntyiñi̱; simusiy ji̱ta jiryatimyu̱ ne tarati̱ni̱, sa̱so̱vay Ju̱denu variy simusintyirya jiryatiy sadatya nta yimura.” 
\s1 Muvye riñi̱cha si̱tenu Jesús jno̱da, sataryi̱veda jarye nadisa̱ju̱ 
\r (Matévu 12.46-50; Márcu 3.31-35) 
\p  
\v 19 Naditi̱jada ji̱ta variy Jesús jno̱dabay, sataryi̱vedabatya, ne vana̱y rityuudiyada nijya̱mi̱juumuni̱.  
\v 20 Rityu̱choda ji̱ta siva Jesús variy: “Jiyunuma bimu nada yino̱da, jityeryi̱vedata, riñi diryu̱y daryaju̱ yiva.”  
\v 21 Su̱teda ji̱ta variy ruuva: “Ri̱no̱da, ratyeryi̱vedata riñi̱cha ti̱ta̱ju̱ jiryatiy rityuva̱chu ramu Ju̱denu niquejada, ruuvaachara varintyirya.” 
\s1 Jesús ndasadedara riicho, ri̱ye̱rya jarye risa̱ju̱ 
\r (Matévu 8.23-27; Márcu 4.35-41) 
\p  
\v 22 Tarundamu ji̱ta su̱musa̱da Jesús yisa̱ datyavatya cartyevimu. Su̱teda ji̱ta variy ruuva: “Vurya̱ramityeryi̱ jmityo̱ rudamyuju̱.” Riya̱da ji̱ta variy jadchiy.  
\v 23 Riya̱damu sama̱yada Jesús. Raju̱u̱jeyada ji̱ta ja̱mu riicho jmityo̱mu variy, rani mu̱charu̱yadanuma cartye variy ja̱a̱ta day, riñi janumityeryu̱yadanuma variy jasiy.  
\v 24 Rityuudiyadanumatiy sisa̱ datyavayu, ridyoseda ji̱ta variñi̱ Jesús jiñiquejadata: “¡Maestru, Maestru, vurya̱numa caraye̱ ri̱ye̱ryamu!” Si̱dyojadanumatiy Jesús, sanique̱tya̱da ji̱tara riicho, ri̱ye̱rya jarye risa̱ju̱. Randasa̱da ji̱ta mityijyijyu̱y riicho, ri̱ye̱rya risa̱ju̱, ju̱vaya̱numa rama̱cho̱jada variy.  
\v 25 Su̱teda ji̱ta variy ruuva: “¿Nu̱tyijirya rani̱cha jiryejechipiya̱jada sanijyu̱ Ju̱denu day, nu̱tyijiy?” Rityi̱tta̱da variy jichuvu̱yadamu, ru̱teda nu̱ñi riy variy yiva: “¿Chi̱rana̱ sani̱cha jiñu day, chi̱? ¿Nu̱tyi ratuva̱chu riicho simu, nu̱tyi, ri̱ye̱rya jarye, su̱pa̱numatirya?” 
\s1 Jerásaja̱mi̱bay bayantuti̱ 
\r (Matévu 8.28-34; Márcu 5.1-20) 
\p  
\v 26 Ruuto̱jada ji̱ta Jesúsveda Jerásaja̱nvay mucadimu, jiryatiy Cadidéya mucadisa̱ra̱ra.  
\v 27 Sa̱subedanumatiy Jesús siinumu, sasaryejadani̱ ti̱qui vanubay bayantuvedati̱, jiryatiy ja̱mu vicha̱damusi̱ni̱. Ta̱ripyunuma ne sajachuru̱yadara sujay yiva, dantyamu̱y ne savicharu̱yada rorimyunu̱day, sama̱cho̱jada ji̱ta bapyo cabyimu variy.  
\v 28 Sadiyadanumatiy siva Jesús, sasa̱ñe̱ya̱jada ji̱ta, sara̱yada variy sanumututuunu. Saniquejasubeda ji̱ta variy: “¿Ta̱ra rimu jiijyu̱ Jesús, ta̱ra? jiryatiy Ju̱denu Jarichumuvichi̱ denu dajyi. Rañi jiyasanta ji, ne ya̱jantyunuva̱y ji̱tate ray.”  
\v 29 Su̱pa̱nu̱yada Jesús daryaju̱ni̱ jamirya vichara bayantu: “¡Ya̱numa sipyatay nijya̱mi̱vasiy!” Tapi ta̱riñuma siriñu̱yada bayantu jivyanu̱yadata daryaju̱dañi̱. Ripyuchunu̱yada ji̱ta nijya̱nvay cadyidyaju̱u̱ta varirya sajomutu, sanumutu risa̱ju̱, ru̱nu̱tya̱da jiivu̱setavay variy jasiñi̱. Sarotyatimyu̱yadanumatirya cadyidyaju̱u̱, bayantu batya̱da variy tajityomuju̱ni̱.  
\v 30 Sitaja̱doda ji̱ta Jesús variñi̱: “¿Ta̱ra yityate day, ta̱ra?” Su̱mutya̱jada ji̱ta: “Rajuura Vara̱nca,” jiryatiy rivyicha̱da rajuu bayantuveda daryaju̱ siva.  
\v 31 Riyasanta̱da ji̱ta bayantuveda variñi̱ Jesús: “Ne ya̱jpa̱ vatato̱vimuju̱ nu̱y.” 
\p  
\v 32 Savicha̱da tajuuqui cuchiy jasiy, si̱byesa̱deda musimyare. Riyasanta̱da ji̱ta bayantuveda variñi̱ Jesús: “Nu̱ña̱jay cuchivya.” Su̱teda variy ruuva bayantuveda: “Dañuma jirya̱jay ruuva cuchimyi.”  
\v 33 Richipyateda ji̱ta bayantuveda nijya̱mi̱vasiy variy, rijeyada ji̱ta variy cuchivyedava. Richiichiye̱yada ji̱ta cuchijyuu nubañuco̱vimu jmityo̱muju̱, rijeye̱yada ti̱ta̱ju̱ variy, puritye.  
\v 34 Ridyiyadanumatiy cuchiy jnu̱tyavay riva, nu̱tyura rivyicha cuchijyuu, nu̱tyura, ribeye̱yada ji̱ta, rityu̱chunuvejada ji̱ta ja̱mu vicha̱damu varirya, rú̱ro̱ vichavavya jarye.  
\v 35 Riya̱da ji̱ta nijya̱mi̱juu jnu̱vye variy, nu̱tyunuma ravicha̱sintyi, nu̱tyura. Ruuti̱jadanumatiy simu Jesús, ridyiñuvi̱jada siva vanu sanumututuunu Jesús. Ne tavay jna̱y bayantuveda sivanu̱day, sama̱sa̱da variy sujatyi̱, raratyedama̱ su̱no̱ variy. Mitya jnutacha̱ rivyicha̱da nijya̱nvay variy.  
\v 36 Jiryatiy ridyiyada ti̱ta̱ju̱ riva, rityu̱choda ji̱ta variy ruuva: “Nu̱ryamusiy sami̱sa̱siy bayantuvedati̱.”  
\v 37 Rijechiñu̱yada ji̱ta nijya̱nvajyuu siva Jesús: “¡Ya̱numa jiya nu̱dyisa̱siy!” jiryatiy rireda jaryi suvu̱yada variy jasiryi Jerása mucadi ju̱ro̱ vichavay. Su̱musa̱da ji̱ta Jesús cartyevimu variy sata̱rya̱daju̱.  
\v 38-39 Ni̱ni̱ ji̱ta jiryatiy savichanu̱yada bayantuvedati̱, sajachiñu̱ñu̱yada siva Jesús: “Ravyicharu̱y yisa̱.” Su̱bayada ji̱ta Jesús sa̱jisirya: “Ne, ya̱numa ta̱rya jiryorimyuju̱, ya̱tu̱chunuve ruuva, ta̱ jaryi ti̱ttasarani̱te savichadesiy Ju̱denu jiyadaju̱.” Saya̱da ji̱ta jadchiy, satu̱chunumaya̱jada ti̱ta̱ju̱ vicha̱diva: “Nu̱rya savichadesitye Jesús jaryi rayadaju̱.” 
\s1 Jáyirubay detubay; vaturu̱y ja̱mundatanu̱be jarye, jiryatiy nanumutyeda raniy Jesús sujay 
\r (Matévu 9.18-26; Márcu 5.21-43) 
\p  
\v 40 Sata̱rya̱danumatiy Jesús Cadidéyamuju̱, ridyiryejada ji̱ta nijya̱nvañi̱, rintuñu̱yada daryaju̱ rumu sa̱jiju̱.  
\v 41 Su̱deda ji̱ta ti̱qui vanu variy, Jáyiru jtyati̱bay, savichanu̱yada ju̱tye̱ryanijyo nutyityu̱. Sara̱yadanumatiy Jesús numututuunu, sayasanta̱da ji̱ta variñi̱: “¡Ya̱jniy raryorimyuju̱!”  
\v 42 Sadetu ti̱qui vichi̱dera vichanu̱yada vadiiryo̱ daryaju̱, savicha̱da vu̱yaju̱y nijya̱ti̱, danijya̱ju̱y tuunu ranchaju̱. 
\p Saya̱damu Jesús, riñi na̱yatiryu̱yada nijya̱nvay variyu.  
\v 43 Nanuvichanu̱yada ji̱ta runu̱y vaturu̱ntyi, ja̱munudatanu̱y, taraqui vu̱yaju̱y nijya̱ ravicha̱da nadiva, danijya̱ju̱y ranchaju̱. Nanupa̱chityamu̱yadanumatirya yimu vichara ti̱ta̱ju̱ jdanu̱vamyu, ne nanumi̱saru̱yada ti̱mu tiii, mitya.  
\v 44 Nani̱deda ji̱ta sarudivasiy Jesús, nanuja̱tyo̱jada variy raniy sasujacho, raparu̱yada ji̱ta varicha̱ra̱ju̱ nuda nadiva.  
\v 45 Su̱teda ji̱ta Jesús variy: “¿Chi̱ra sani̱cha jiñutiy saja̱tyo̱ rañiy, chi̱?” Rirye̱yada variy ti̱ta̱ju̱ jiyada, su̱teda ji̱ta Pyítrubay variy: “¡Maestru, jiryatiy nijya̱mi̱juusuma yiro̱, riñi ja̱tyo̱ jasiy jiiñiy!”  
\v 46 Su̱teda ji̱ta Jesús variy: “Ne, ti̱qui jtani̱te ja̱tyo̱jasiy rañidye, jiryatiy radyetya̱siy rasipyatay vanu̱yada varicha̱ra̱ju̱ rivasiy.”  
\v 47 Nanudatya̱danumatiy vaturu̱yu: “Ne dutyasi̱ rañi̱chanu̱day,” nani̱deda jimyichutyedanube simu, nanubutyanuvi̱jada Jesúsna̱cho̱ju̱yu, nanutu̱choda vijyo̱mujache nijya̱nvay diya: “Nu̱tyura ratya̱ju̱ raje̱tyo̱jasiy saniy, ramyi̱sa̱subesiy ti̱ta̱ju̱ varicha̱ra̱ju̱.”  
\v 48 Su̱teda ji̱ta Jesús variy nadiva: “Samiy sa̱nujachipiya̱jadamu jimyi̱sa, Popoju̱y. Sa̱na̱numa jiya samiy.” 
\p  
\v 49 Saniquejadatidye Jesús, siti̱jada nu̱ vanu Jáyirubay rorimyusiy, su̱tañuvi̱jada siva: “Sadiimya̱ jidyetu. Ne ya̱jarupanta nu̱dañi̱ Datyanu̱ nu̱day.”  
\v 50 Satuva̱chodanumatiy Jesúsra, su̱teda ji̱ta variy siva Jáyirubay: “Ne ya̱suvu̱y ranchiy, ya̱jachipiya̱ jijechitya, sa̱day mi̱sa̱sumiy jidyetu.”  
\v 51 Sito̱jadanumatiy Jesús Jáyirubay rorimyu, su̱bayada Jesús rirya̱jisirya jayada yisa̱. Vinu Pyítrubay jayada sisa̱, Juánbatya, Santiyácubay jarye, diibyi ja̱jyu̱be jarye ruusa̱ju̱.  
\v 52 Ru̱na̱cha̱deda ji̱ta nijya̱nvay variy jasiy, riñuvayada daryaju̱ jaryiñi̱. Su̱teda ji̱ta Jesús variy ruuva: “Ne jirya̱jna̱y, tama̱ diiñu sani̱cha dera, tama̱, nu̱tyu sani ma̱ñi̱ndye.”  
\v 53 Rityodiyada ji̱ta variy siva, ridyetya̱da daryaju̱ diiñunuma sani̱cha.  
\v 54 Jesús ji̱ta ju̱reda sajomutuniy dera babyi, sanatuyada variñi̱: “¡Pochityu, ya̱numa nubesumiy!”  
\v 55 Sata̱rya̱jada su̱ntu variy yivaju̱ntiy, sanubesubeda varicha̱ra̱ju̱. Su̱teda ji̱ta Jesús: “Jirya̱sa̱y tara si̱byedaju̱yu.”  
\v 56 Nanuti̱tta̱da ji̱ta saja̱jyu̱berya; Jesús ju̱bayada rirya̱jisiy tavavya tu̱chodara jivyicha̱da. 
\c 9  
\s1 Jesús jpa̱jada tu̱chuvaryi yisa̱ datyavay 
\r (Matévu 10.5-15; Márcu 6.7-13) 
\p  
\v 1 Sanatuyadanumatiy Jesús riy yisa̱ datyavay jiryatiy rivyichanu̱yada vu̱yaju̱y, danu̱ju̱y rinchaju̱, sasa̱yada ji̱ta jivyanu̱yada tera riy, sadatya̱da tera risa̱ju̱, ratatidye rirya̱jatyanumaya̱ ti̱ta̱ju̱ riy bayantuveda nijya̱nvavyasiy, rirya̱jdanura jdiva̱jadantiy.  
\v 2 Su̱pa̱cheda ji̱ta variy tu̱chodaju̱riy, rirya̱tidye tu̱chu Ju̱denu nusu̱yadanchiy, rirya̱tidye jdanu riy jdiva̱jnuvantyi.  
\v 3 Su̱teda Jesús variy ruuva: “Ne jirya̱jtu tara jiryupiyadaju̱, ne vinu ruvese, dantyamu̱y ne dusuuy, dantyamu̱y pa̱, dantyamu̱y criquiy, dantyamu̱y ne dajajyu̱y sujacya̱, mitya.  
\v 4 Jasityi jirya̱jto̱ rorimyu, jasiñuma jirya̱ma̱cho̱ variy jiryeya̱da rundasa̱ra̱ju̱.  
\v 5 Jasityimyu̱ ne rirya̱diryeru̱y jirye, jirya̱numatiy sipyatay jadchintyi, jirya̱muchutyara rirujuu riñijyu̱ jiryeñumutuvasiy, rirya̱tidye datya̱siy rata: Vuryeyasacha̱damundyerya.”  
\v 6 Riya̱da ji̱ta variy, rityu̱chutityiyada ti̱ta̱ju̱ vicha̱divara samitu̱choda, rimyi̱sanityityiyada varintyiryi jdiva̱jnuvantyi. 
\s1 Juán Bautístabay jvacha̱da, jiryatiy rirye̱cha̱dara su̱no̱ 
\r (Matévu 14.1-12; Márcu 6.14-29) 
\p  
\v 7 Satuva̱chodanumatiy nutyityu̱ Jeródesberya Jesús jaticheyada, sama̱cho̱jada jachipiya̱nu variy, jiryatiy ru̱teda tavay: Sami̱sa̱sumimya̱ Juán Bautístabay.  
\v 8 Tavay jarye jteda: “Samu̱ti̱ma̱ Edíyasintyi,” (jiryatiy savichanu̱yada ta̱riy Ju̱denuju̱ tu̱chu̱.) Tavay jarye jtedantiy: “Sami̱sa̱simyu̱mya̱ Ju̱denuju̱ tu̱chuvabe tenu ta̱rijye̱.”  
\v 9 Su̱teda ji̱ta Jeródesbe variy: “Rarye̱chatadedara Juánbay jno̱, ¿chi̱rana̱te sani̱cha jiñu, chi̱? chi̱nchiña̱te ratyuva̱chura jirya niquejada.” Sani jantya̱da diryu̱yada variy siva Jesús. 
\s1 Jesús potyadeda riy tadajyo vara̱nca vaduy 
\r (Matévu 14.13-21; Márcu 6.30-44; Juán 6.1-14) 
\p  
\v 10 Ritye̱rya̱danumatiy Jesús nusu̱byimiy yimuju̱ntiy, rityu̱chunuvi̱jada ji̱tara yivaayada ti̱ta̱ju̱ variy siva. Sapu̱cheda Jesús variryi, riñumuteda variy Betsáyinamuju̱.  
\v 11 Ridyetya̱danumatiy nijya̱nvarya riya̱da Jesúsveda, richiityari̱jada variryi. Sadiryejada ji̱ta Jesús variryi, saniquejada ruuva Ju̱denu nusu̱yadanchiy variy, sami̱sadedantiryi rityi va̱ta̱dara mi̱sa̱da.  
\v 12 Ri̱ñuvayadamu ji̱ta, ruuti̱jada sisa̱ datyavay yimuntiy, ru̱tañuvi̱jada siva Jesús: “Ya̱tu̱chu ruuva nijya̱nvajyuu rirya̱tidye jiya̱siy rorivyicha̱mu, nudivya jarye, jiryatiy ru̱ro̱ra, rirya̱tidye jachiñu̱rya roriy jijiitujyoju̱, jmyichara jarye, vu̱vyicha vayitomu daryaju̱ jiyu.”  
\v 13 Su̱teda ji̱ta Jesús variy ruuva yisa̱datyavay: “Jirya̱ntya potyaniy tarata riy nijya̱nvajyuu.” Ru̱teda ji̱ta variy siva: “Ne tara rajuura jmyichara nu̱dyimu, vinu tadajyojo pa̱, danu̱ju̱y quiva̱ju̱y risa̱ju̱, netimyu̱ ne nu̱dyeya ta̱ryu̱vye jmyicharana̱cho̱ nijya̱nvajyu̱ didye.”  
\v 14 Rivyicha̱da ji̱ta tadajyo vara̱nca tuunu vaduy jasiy. Su̱teda ji̱ta Jesús variy ruuva yisa̱ datyavay: “Jirya̱ma̱sataniy ji̱ta rajuumusiy vatadeca̱ riy, nu̱ñi tadajyo vu̱yaju̱y nijya̱mi̱.”  
\v 15 Ruuvaayada ji̱ta sisa̱ datyavay darya, rimya̱satadedariy nijya̱nvay ti̱ta̱ju̱.  
\v 16 Siredanumatiy Jesús varirya tadajyojo pa̱, danu̱ju̱y quiva̱ju̱y risa̱ju̱, sapatatiyada ji̱ta varirya, su̱nu̱yada ji̱ta jarichuna̱cho̱ variy, si̱chana̱tya̱da variñi̱ jijye̱: “Yentyutyama̱te pa̱ta nu̱y.” Sasa̱yada ji̱ta yisa̱ datyavarya rirya̱tidye sa̱myu̱ ti̱ta̱ju̱ ruuvara.  
\v 17 Riibyeda ji̱ta ti̱ta̱ju̱, ripyoyada variy riva. Rirya̱tojada ji̱ta varirya riinda, vu̱yaju̱y jtyu, dajtyuju̱y ranchaju̱. 
\s1 Pyítrubay jteda vijyo̱mujache Jesúsva: “Ju̱denu jaryeti̱ ji” 
\r (Matévu 16.13-19; Márcu 8.27-29) 
\p  
\v 18 Tarundamu ji̱ta rivyicha̱da sisa̱ datyavay yisa̱ sajoráyadamu mityatomu. Sitaja̱doda ji̱ta Jesús variryi: “¿Nu̱tyura riñique nijya̱nvay raynchiy, nu̱tyura? ¿chi̱ra ru̱tarye, chi̱?”  
\v 19 Ru̱mutya̱jada ji̱ta variñi̱: “Juán Bautístabay ru̱tay ji; ti̱ni̱ jtadye: Edíyasiy ji; ti̱ni̱ jtadye: Sami̱sa̱sumiy ti̱qui Ju̱denuju̱ tu̱chuvabe tenu.”  
\v 20 Su̱teda ji̱ta Jesús variy ruuva: “Va̱ jiryeque, ¿chi̱ra jiryi̱tadyerye, chi̱?” Su̱mutya̱jada ji̱ta Pyítrubañi̱: “Ju̱denu jaryeti̱.” 
\s1 Jesús tu̱choda jibetyedajiju̱ 
\r (Matévu 16.20-28; Márcu 8.30–9.1) 
\p  
\v 21-22 Su̱bayada ji̱ta rirya̱jisirya rátu̱chusa̱da: “Ne jirya̱tu̱chosiy ti̱devara,” su̱teda daryaju̱: “Nijya̱mi̱denu ji̱ta ra̱paru̱tyajaya̱sarayu. Rirya̱rrachu rimyityumiy variñi̱, caserdótevyeda nutyityu̱miy, Ju̱denu niquejada datyanuvay jarye ra̱rrachuni̱, rirya̱jvay variy rivani̱, rurundamunuma ji̱ta sa̱mi̱saniy Ju̱denu varintyiñi̱.” 
\p  
\v 23 Su̱teda ji̱ta Jesús variy ruuva ti̱ta̱ju̱: “Saryityi siityari̱ru̱y ti̱ ray, sa̱ma̱ paru̱y riva yivaaryu̱yada, sa̱ma̱ nichujaya̱ ntara jicyurusiy, jiryatiy sa̱bay nu̱tyu diiñuyu, ne sa̱riryi̱ varirya ta̱riy jivyicha̱danu̱day sa̱tidye siityari̱ varirye.  
\v 24 Tapi mi̱ni̱tyi ramityaniryu̱rya yinu̱yada, sa̱pa̱chitya variy mityara; mi̱nintyi ji̱ta pa̱chityara yinu̱yada rayadaju̱, sa̱ramityaniy varirya.  
\v 25 Tapi ¿ta̱raju̱ra saryi ca̱na̱y nijya̱mi̱ra criquiy ti̱ta̱ju̱ vicha̱divasidye, ta̱raju̱? saryityi caray variy ra̱jisintyi.  
\v 26 Mi̱nintyi ra̱jada riva, rañiquejadiva jarye, daryaday sa̱jada Nijya̱mi̱denu sivantidye ra̱numatiy ju̱ti̱ radyata, rajye̱data jarye, su̱pa̱vay jiintyasavaydata jarye risa̱ju̱.  
\v 27 Ri̱tatye ji̱ta jiryiva: Jiyu daryi jiryetyevay nijya̱nvay jiryatimyu̱ ne rirya̱datyara diiyada, netimyu̱ ne ridyi munatya riva Ju̱denu nusu̱yada.” 
\s1 Jesús ti̱tuyadanchiy 
\r (Matévu 17.1-8; Márcu 9.2-8) 
\p  
\v 28 Mumurundamiñijyatemusiy ji̱ta jiryatiy su̱tedara jirya niquejada, sa̱ra̱yada ji̱ta Jesús yisa̱ju̱ riy Pyítrubay, Juánbay, Santiyácubay jarye, sa̱ra̱cheda ji̱ta ja̱mumusimyuju̱ riy, sa̱tidye joráy jasiy.  
\v 29 Sajoráyadamu ji̱ta rati̱tuyada jimyo̱ ridyiyadajache variy, sasujay jarye danu̱yada jaryi pupajay varintyi.  
\v 30 Mityamusiy ji̱ta, nanutu̱choda danu̱ju̱y vanuju̱y Jesúsjsa̱, jiryatiy nani̱cha Muyusésiy, Edíyasitya.  
\v 31 Nanumu̱ti̱jada vandanu̱jyu̱y, nanuniquejada variy Jesús batyedanchiy jiryatiy sa̱paru̱tya Jerusarí̱muyu.  
\v 32 Pyítrubay ji̱ta, sisa̱ vichanu̱jyu̱y jarye ma̱yada vatunu. Ri̱dyojasubedanumatiy, ridyiyada ji̱ta variy riva Jesús da, nanuda jarye jiryatiy nanuradeda Muyusésiy, Edíyasitya satuunu.  
\v 33 Nanutochiryu̱yadanumatiy Muyusésibe, Edíyasityani̱ Jesús, su̱teda ji̱ta Pyítrubay variy siva Jesús: “Ta̱ jaryi samiryani̱te nu̱jyu̱te jiyu, Maestru. Nu̱ña̱ma̱ su̱ta̱y mumuta̱myi: tata̱qui jijyu̱ day, da tata̱qui Muyusésijyu̱, da tata̱qui Edíyasijyu̱ntidye.” Sadatyi̱sa̱damu jiñiquejada Pyítrubay variy daryá.  
\v 34 Saniquejadasa̱ra̱ju̱ ji̱ta, racanuvu̱doda virisumarya variryi. Richuvu̱yada ji̱ta jayada ranube virisuma.  
\v 35 Rara̱yada ji̱ta niquejada virisumaryanubesiy variy: “Jiñu ji̱ta radyenu jaryetasi̱, jirya̱ma̱ tuva̱chu Simu.”  
\v 36 Niquejadivasiy, ridyiyada sa̱siquita Jesús yiva. Rime̱cho̱jada mitya vapuu ranchiy variy, ne rityu̱choda variryundamu ti̱vara yivadiyada. 
\s1 Jesús mi̱sadedani̱ derabay, jamiryanu bayantuti̱ 
\r (Matévu 17.14-21; Márcu 9.14-29) 
\p  
\v 37 Rurundamu ji̱ta, ru̱musa̱danumatiy Jesúsveda ja̱mumusimyusiy, richeryeda nijya̱nvajyuuni̱.  
\v 38 Mityamusiy saniquejasubeda ti̱qui vanubay riquebyimusiy: “Rajechiñu̱y yiva, Datyanu̱, ya̱jnu̱y sana̱cho̱ radyenu, jiryatiy ti̱qui vichi̱deni̱ radyenu.  
\v 39 Mityamusiy siresumiy bayantuni̱ radyenu, sasa̱ñe̱ya̱jasumiy radyenu variy. Sasiichinuja̱ bayantumusiyu jasicha̱ra̱ju̱tiy rajippudivay su̱to, paru̱cha̱rijyu̱ sabay javatyasi̱ni̱.  
\v 40 Rayasanta̱siryi yisa̱ datyavay: Jirya̱jatyani̱ bayantu radyenuvasiy, ne vana̱y rijetyani̱, tii, mitya.”  
\v 41 Su̱mutya̱jada ji̱ta Jesús variñi̱: “¡Jiii, ta̱ra nijya̱nvay jachipiya̱jadaruyutavay jiryeñi̱cha day, jiryatimyu̱ ne jiryetyuva̱churu̱y simu Ju̱denu! ¿Nuriryundasa̱ra̱ju̱ ra̱ma̱cho̱ jiryisa̱, nuriryundasa̱ra̱ju̱? ra̱tidye jachi̱niy jiryetyuva̱chu̱sa̱damusirye. Ya̱pu̱chiy rumusiñi̱ jidyenu.”  
\v 42 Su̱nityityiyadamu ji̱ta sajatya̱da bayantu mucadincha derapuyu, sasiichunuja̱jada variy jasiñi̱. Jesús ji̱ta nique̱tya̱dani̱ bayantu jamirya vichara, sami̱sadeda variñi̱ derapu, sata̱ryatadeda ji̱ta variy saja̱myuju̱yu.  
\v 43-44 Rityi̱tta̱da ji̱ta ti̱ta̱ju̱ra: “Ta̱ jaryi datyarani̱ sani̱cha Ju̱denu.” 
\s1 Jesús jatyiyada tu̱choda jibetyedajiju̱ntiy 
\r (Matévu 17.22-23; Márcu 9.30-32) 
\p Rityi̱tta̱danumatirya sivaayada, su̱teda Jesús variy yisa̱ datyavavya: “Jiryetyuva̱chuta̱ta samiy rañiquejadamu, tapi ra̱numa ju̱to̱ Nijya̱mi̱denu sa̱cha̱da runda, jiryatiy sa̱sa̱y ti̱ nijya̱nvay jomuni̱.”  
\v 45 Riñi̱ ji̱tamu̱y ne datyaru̱yadara saniquejada, dutyasara daryaju̱ rirya̱jisirya, riñuma datyara. Richuvu̱yada ji̱ta sisa̱ datyavay jtaja̱doda Jesúsyu saniquejadanchiy. 
\s1 ¿Chi̱ra sani̱cha jaryiñu̱ Ju̱denu diya, chi̱? 
\r (Matévu 18.1-5; Márcu 9.33-37) 
\p  
\v 46 Rijyo̱ta̱da ji̱ta niquetta̱da sisa̱ datyavayu: “¿Mi̱ra jaryiñu̱ vu̱quebyimu, mi̱?”  
\v 47 Sadatya̱danumatiy Jesúsra rijechimyu jachipiya̱jada, sireda ji̱ta variñi̱ derapu, saranityadeda jityuunude variñi̱.  
\v 48 Su̱teda ji̱ta variy ruuva: “Mi̱ni̱tyi ra̱dirye ri̱tyamuni̱ jiñu derapu, daryaday sa̱dirye varintyirye; mi̱ni̱tantiy ra̱dirye ray, daryaday sa̱dirye varintyiñi̱ jiryatiy su̱pa̱jada jiyuju̱ ray; tapi ni̱tiy vichasara jirya̱rijyu̱ játarya jiryequebyimu, ni̱numa sani̱cha jaryiñu̱ jiryimusiy.” 
\s1 Mi̱ni̱tyimyu̱ ne jiyaro̱nu jirye, ni̱ni̱ vichasara jiryeyadaju̱ rá̱ñu 
\r (Márcu 9.38-40) 
\p  
\v 49 Su̱mutya̱jada ji̱ta Juánbay variñi̱ Jesús: “Maestru, nu̱dyiyasiy siva vanu jiryatiy sajatya yityamuni̱ bayantu. Nu̱ñi̱bayasiy variy sa̱jisirya, jiryatimyu̱ ne sani siityari̱ nu̱dyisa̱ daryaju̱ ji.”  
\v 50 Su̱teda ji̱ta Jesús variy siva Juánbay: “Ne ya̱ju̱bay ra̱jisiñi̱, tapi ni̱timyu̱ ne jiyaro̱nu jirye, ni̱ni̱ vichasara jiryisa̱ju̱.” 
\s1 Jesús nique̱tya̱da nada Santiyácubay, Juánbatya 
\p  
\v 51 Ratuudiya̱jadanumatirya rarunda varityi sa̱jasumiy Jesús na̱vajyu̱, sajachipiya̱jada variy jiya̱da Jerusarí̱muju̱.  
\v 52-53 Su̱pa̱jada ji̱ta yajiju̱ variryi yinsu̱byimiy. Rijeñuvejadanumatiy Samáriya ja̱nvay vicha̱damu rirya̱tidye jdutyara vichajo sa̱jiju̱, ne ridyiryeru̱yada nijya̱nvay variy jasiñi̱ Jesús, jiryatiy sani jachipiya̱jada jiya̱da Jerusarí̱muju̱.  
\v 54 Nanudiyadanumatiy Juánbay, Santiyácubatya riva rrachoda, nani̱taja̱doda variy jasiñi̱ Jesús: “¿Nutyityu̱, jivya̱tavidye na̱ña̱natuy jarichuvimusirya jiiday ripyarutedaju̱ daryatiy sivaayada Edíyasiy?”  
\v 55 Sa̱numityejada ji̱ta Jesús nanuna̱cho̱ju̱, sanique̱tya̱da variñada: “Ne sa̱nudatya nu̱tyura jachipiya̱jadatanu̱y sa̱da.  
\v 56 Tapi ne su̱deda Nijya̱mi̱denu nijya̱nvay paruta̱daju̱, su̱deda ji̱ta ruuva jantyuyadaju̱ day.” Riya̱da ji̱ta tavicha̱damuju̱ variy. 
\s1 Rityi siityari̱ru̱yadani̱ Jesús 
\r (Matévu 8.19-22) 
\p  
\v 57 Riya̱danumatiy nú̱va, su̱teda ti̱qui vanubay variy siva Jesús: “Ra̱siityari̱ ji rumutiy ye̱jiya.”  
\v 58 Su̱teda ji̱ta Jesús variy siva: “Vitiñu ji̱ta vuditi̱, viiche jarye ruutyi̱, Nijya̱mi̱denu ji̱tamu̱y ne vichajoti̱ jasityi sa̱tiryo̱ jime̱yadaju̱.” 
\p  
\v 59 Ti̱vani̱ ji̱ta su̱teda Jesús varidye: “Ya̱siityari̱sara ray.” Su̱mutya̱jada ji̱tani̱: “Nutyityu̱, ra̱jmuchuchidyi munatyara rajye̱ babyi.”  
\v 60 Su̱teda ji̱ta Jesús variy siva: “Rityi vichasara jijyuuchuvedamu diivye, rirya̱ma̱ jmuchuni̱ jiryenu diibyi day, jiiñi̱ ji̱ta ra̱jiya tu̱chu̱ju̱ Ju̱denu nusu̱yadanchiy.” 
\p  
\v 61 Su̱teda ji̱ta nu̱ siva Jesúsntiy: “Ra̱siityari̱ ji, Nutyityu̱. Munatya ji̱ta ra̱jiya, ra̱mu̱chuvachiryi raryorimyu vichavay.”  
\v 62 Su̱mutya̱jada ji̱ta Jesús variñi̱: “Ni̱tiy jo̱ta̱da siityari̱jada ray, netimyu̱ ne saparu̱ryu̱y variy riva ta̱riy jivyicha̱dana̱cho̱ jachipiya̱jada, ne vana̱y ntate saryi jatye Ju̱denu nusu̱jyovimu day.” 
\c 10  
\s1 Jesús jpa̱jada riy daraju̱ñijyate vu̱yaju̱y vaduy 
\p  
\v 1 Rivasiy ji̱ta sabayada Nutyityu̱ riy tavay nijya̱nvay, daraju̱ñijyate vu̱yaju̱y nijya̱mi̱, danu̱ju̱y rinchaju̱. Su̱pa̱jada ji̱ta yajiju̱ nu̱ñi danu̱ju̱myusiryi nijya̱nvay, vicha̱damuju̱, vichajomuju̱ jarye ti̱ta̱ju̱ jasityi sa̱jto̱nuve.  
\v 2 Su̱teda ji̱ta Jesús variy ruuva: “Jasinryi rajuuvay nijya̱nvay caravye jatojadaju̱, jatóvay ji̱ta ne rajuuvay. Ramuni̱ jirya̱jachiñu̱y siva jatojadaja̱mi̱, sa̱tidye jpa̱ riy jvaavye jatojadana̱cho̱.  
\v 3 Jirya̱numa jiya. Ri̱pa̱ ji̱ta jirye nu̱tyu ra̱si̱midyera, jmyiryajuu cabyimuju̱.  
\v 4 Ne jirya̱jtu yimu tara, ne vinu criquichuy, dantyamu̱y ne dusuuy, dantyamu̱y ne saapatu. Dantyamu̱y ne jirya̱riche mu̱chuvatyityiyada nú̱va.  
\v 5 Jirya̱numatiy jañuve ti̱ rorimyu, jirya̱jtay munatya ruuva: ¡Samirya jirye̱cha jiryorimyu!  
\v 6 Saryityi vichasara rorijya̱mi̱ samirya jachityi̱, raryime̱cho̱ samirya jiryeñiquejada variy saju̱; netimyu̱ ne saryicha samirya jachityi̱, rá̱ta̱ryá jiryeñiquejada variy yimuju̱ntiy.  
\v 7 Jirya̱ma̱cho̱nuve variy jasiy rorimyu, jasityi jirya̱jto̱. Jirya̱ma̱ jmyi, jirya̱ma̱ jatura ratiy rirya̱muti jirye, tapi sava̱tasara Ju̱denuju̱ ju̱vaañu daryaju̱ra jimyurichenusa̱da. Ne jirya̱ja̱tay rorimyusiy, ratarya rorimyuju̱.  
\v 8 Jirya̱numatiy jañuve vicha̱damu, rirya̱numatiy dirye jirye, jirya̱ma̱ jmyirya ratiy rirya̱sa̱y jasiy jirye.  
\v 9 Jirya̱ma̱ mi̱saniryi jdiva̱jnuvay jasiy vichavay, jirya̱jtay variy ruuva: Ratuudiñuma Ju̱denu nusu̱yada jirye.  
\v 10-11 Jirya̱numatiy jañuve vicha̱damu jasityimyu̱ ne rirya̱diryeru̱y jirye, jirya̱jtay vijyo̱mujache riñijyu̱: Jiryevyichajojuru ji̱ta nu̱ña̱pu̱y jiñumutuvasiy jiryeñijyu̱: jirya̱ntya datya si̱tenu variy, jiryatiy ratuudiya̱numa Ju̱denu nusu̱yada jirye.  
\v 12 Ri̱tatye ji̱ta jiryiva: Jachi̱ntyava̱ju̱ day ra̱cha Sodóma ja̱nvajyu̱ Ju̱denu paruta̱da rundamu, jasiy vicha̱da ja̱nvamyusiy, jiryatimyu̱ ne ridyiryeru̱yada jasiy jirye.” 
\s1 Vicha̱daja̱nvay tuva̱chu̱sa̱minchiy 
\r (Matévu 11.20-24) 
\p  
\v 13 “¡Acuu jiryeñijyu̱ Curasí̱ ja̱nvay! ¡Acuu jiryeñijyu̱ Betsáyina ja̱nvay! tapi raryitiy jvaayada Tíru ja̱nvay cabyimura rivaayada ti̱ttasara, nu̱tyu jiryequebyimutiy rivaayasiy daryantiy, ta̱riñuma riryi paru̱yada riva va̱cha vicha̱da, riryi dityadoda varirya jiñuvaya̱da riva jiryatiy riryimya̱sa varivyunujay sujatyavay pupujurunube. Sitú̱ ja̱nvay jarye raryi jvaayada daryantidye.  
\v 14 Jachi̱ntya̱da ra̱cha rijyu̱ Tíru ja̱nvay, Sitú̱ ja̱nvay jarye jiryimusiy, juuchuveda murichenutadeda rundamu.  
\v 15 ¿Va̱ jiryeque, Capernavú̱ ja̱nvay? jiryi̱tay vidye jirye̱cha jasuminichavay jarichumuju̱ day. Jiryedye day ra̱chava̱ jmusanichavay jiidatyo̱muju̱ cay.” 
\p  
\v 16 Su̱teda ji̱ta Jesús yisa̱ datyavavya varintyi: “Ni̱tiy tuva̱chu jiryimu, daryaday satuva̱chu variy rimuntidye; jiñu ji̱ta jiryatiy sani rrachu jirye, daryaday sani rrachu varintyidyerye. Ni̱tiy rrachu ray, daryaday sani rrachu varintyidyeñi̱ jiryatiy su̱pa̱jada ray.” 
\s1 Daraju̱ñijyate vu̱yaju̱y jpa̱savay ta̱rya̱jadanchiy 
\p  
\v 17 Ritye̱rya̱da ji̱ta sansu̱vye yichana̱yadamu, jiryatiy su̱pa̱jada riy daraju̱ñijyate vu̱yaju̱y vaduy, danu̱ju̱y rinchaju̱. Rityu̱chunuvi̱jada ji̱ta siva Jesús: “¡Bayantuveda jarye ji̱ta tuva̱chunu̱chiy yityamu nu̱dyimu, Nutyityu̱!”  
\v 18 Su̱teda ji̱ta Jesús variy ruuva: “Ri̱nu̱chusiñi̱ Satanásiy, jiryatiy saju̱u̱jechiy nu̱tyu ra̱duya̱ra jarichuvimusiy.  
\v 19 Jirya̱jnu̱y, rache̱mya̱ jiryerya jirya̱tidye raniye̱ rincha codimyi, norityumincha jarye, vu̱myityasiy vanu̱yadancha jarye ti̱ta̱ju̱. Ne ra̱jarupanu tara variy jirye, mitya.  
\v 20 Dañumamu̱y ne jiryi̱chana̱chara ramusiy jiryatiy richabuy bayantuveda jiryejyu̱. Jirya̱ma̱ jchana̱chara ji̱ta jiryatiy nu̱charanuma jiryi̱tya jarichumu.” 
\s1 Jesús jchana̱tya̱dani̱ jijye̱ 
\r (Matévu 11.25-27; 13.16-17) 
\p  
\v 21 Varidyenuma ji̱ta si̱chana̱yada Jesús Ju̱denu Jnutumu, su̱teda ji̱ta variy: “Ri̱chana̱tyate ji, Ye̱ye̱, jarichu Nutyityu̱, jiryatiy mucadi Nutyityu̱ jarye risa̱ju̱ ji, jiryatiy jidyutya̱dara jirya datya̱da rirya̱jisiy mityamusiy datyavay, datya̱da jachityavay jarye. Jidyityadoda ji̱ta datyi̱sa̱mimyura. Jo, Ye̱ye̱, jiryatiy samiy jvadichara jidyiya darya.  
\v 22 Sasa̱mya̱ ji̱ta rajye̱ ti̱ta̱ju̱ ray. Ne ti̱ datya chi̱ra sani̱cha sadenu, chi̱, vinu rajye̱ datya, dantyamu̱y ne ti̱ datya chi̱ra sani̱cha rajye̱, chi̱, vinu sadenu datya, ni̱ jarye jiryatiy radyityanuru̱ñi̱.” 
\p  
\v 23 Sa̱numityejada ji̱ta variy yisa̱ datyavañe̱cho̱, su̱teda vinu ruuva: “¡Ju̱denu jmu̱tyasavay ji̱ta riy rityi ra̱diy riva rivatiy jiryedyi!  
\v 24 Ri̱tay daryaju̱ jiryiva: Rajuu Ju̱denuju̱ tu̱chuvabe, ja̱mu nutyityu̱mibe jarye, riñi diryu̱yada riva jiryatiy jiryedyi diye riva, tama̱ ridyiyada riva, tama̱; daryantya riñi tuva̱churu̱yadantidyerya jiryatiy jiryetyuva̱chura, tama̱ rityuva̱chodanu̱darya, tama̱, mitya.” 
\s1 Jesús tu̱choda Samáriya ja̱mi̱nchiy, jiryatiy jaryi jantyutyarani̱ 
\p  
\v 25 Sanubeseda ji̱ta niquejada datyi̱, sa̱tidye jantya variy saniy Jesús. Sitaja̱doda ji̱tani̱: “¿Datyanu̱, ta̱ra jvaayadiva ra̱jmutya̱ra rayaru̱rya ju̱na̱reju̱ jnu̱yadamu, ta̱ra?”  
\v 26 Su̱mutya̱jada ji̱ta Jesús variñi̱: “¿Ta̱ra ranique Ju̱denu niquejada, ta̱ra? ¿Nu̱tyura jiñiquettara, nu̱tyura?”  
\v 27 Su̱mutya̱jada ji̱ta niquejada datyi̱ni̱ Jesús: “Vurya̱ma̱ va̱tasara ti̱ta̱ju̱ vu̱jechityani̱ Vu̱ntyityu̱ Ju̱denu, ti̱ta̱ju̱ vuryi̱ntuta jarye, ti̱ta̱ju̱ vu̱vyanu̱yadata jarye, ti̱ta̱ju̱ vu̱jechipiya̱jadata jarye risa̱ju̱. Vurya̱ma̱ va̱tasarani̱ vu̱tyuunu vichi̱ntidye, nu̱tyu vu̱vya̱tasaratiy daryantidyevyu̱y.”  
\v 28 Su̱teda ji̱ta Jesús variy siva: “Yimutya̱jasiy vase. Ya̱jvaay daryacu̱, ya̱tidye jnu̱jeya̱sara variy.”  
\v 29 Ni̱ni̱ ji̱ta jiryatiy sani̱charu̱y samirya jvadichi̱ variy nijya̱nvay diya, su̱teda ju̱na̱y variy siva Jesús: “¿Chi̱ra sani̱chate ratyuunuvichi̱ day, chi̱?”  
\v 30 Su̱mutya̱jada ji̱ta Jesús variy tu̱chodatani̱: “Savichanu̱yada ti̱qui vanu, su̱musa̱da ji̱ta Jerusarí̱musiy Jericó na̱cho̱ju̱. Saya̱damu, yito̱jada vase paranu̱nuvay jomuju̱. Richipyata̱da sivasirya jichujay, rimyusiye̱yada variñi̱, rityocheda vadiiryo̱de variy jasiñi̱.  
\v 31 Ta̱ripyudemusiy ji̱ta, sani ramiryi̱jada ti̱qui caserdóte nú̱va varintyi; sadiyadanumatiy siva vadiiryo̱, sanumutatyityiyada variy sa̱jisiy.  
\v 32 Daryaday sito̱jada ti̱qui Ju̱denu rorimyu ju̱vaañu simu vadiiryo̱ jityiryo̱jomuntiy, sadiyadanumatiy siva, daryaday sanumutatyityiyada variy sa̱jisintyi.  
\v 33 Samáriyaja̱mi̱ jarye jto̱jada jiryupiyadamu simuntiy. Sadiyadanumatiy sivantiy, sa̱ntyutya̱da variy jasiñi̱.  
\v 34 Satuudiyadanumatiñi̱, si̱ndadoda ji̱ta ni̱ja̱ta variy jasirya savatajo̱, bínuja̱ta jarye risa̱ju̱, sarayada ji̱ta variy rivasirya savatajo̱. Sama̱sadeda variy jicyavañunchani̱, sa̱tidye jto̱ta nijya̱nvay jto̱jomuni̱, su̱nu̱yada variy jasiñi̱.  
\v 35 Rata̱rimyusiy ji̱ta sasipyata̱dara criquiy, danu̱ju̱y jarimyuni̱ jnu̱tya̱da murichirya, sasa̱yada ji̱ta jti̱joja̱mi̱ra, su̱teda variy siva: Ya̱jnu̱tyani̱ musiyé̱chí̱; ra̱numatiy ta̱rya jiyuju̱ntiy, ra̱murichenunuvi̱ varirya jiryatiy rasu̱tye murichedoda ranchaju̱ ji.” 
\p  
\v 36 Sitaja̱doda Jesús variñi̱ niquejada datyi̱: “Jijechipiya̱jadamu, ¿mi̱ra jivye mu̱nvamyusiy vichadeda nu̱tyu jityuunu vichi̱ni̱, mi̱? jiryatiy sito̱jada paranu̱nuvay jomuju̱.”  
\v 37 Su̱mutya̱jada ji̱tani̱ Jesús: “Ni̱ni̱ ji̱ta jiryatiy sa̱ntyutya̱dani̱.” “Jo. Ye̱jiya, daryani̱ ya̱jvaajeya̱sara ti̱ta̱ju̱.” 
\s1 Jesús jañu̱yada nadimu Mártabay, sataryatubay Maríyabatya 
\p  
\v 38 Jesúsveda jiya̱damu ji̱ta, sajañuvejada vicha̱da rapu̱ryademu; jasiy savicha̱da ti̱qui vatura, Márta jtyati̱bay, ni̱tiy diryejada jiryorimyuni̱ Jesús.  
\v 39 Savicha̱da ji̱ta sataryatuntiy, Maríya jtyati̱bay, ni̱tiy ma̱sa̱da sanumututuunu Jesús, satuva̱chunu̱yada rana̱cho̱ saniquejada jasiy.  
\v 40 Mártabay ji̱ta jaryuvu̱yada Jesús potyadedivayu. Mityamusiy satuudiyada ji̱tani̱ Jesús, su̱teda ji̱ta variy siva: “¿Ne yitaryu̱y nta tara variy, jiryatiy ratyeryatu tochiy ra̱siquita ray, jiryatiy ravyichaniy samirya jiyu day ji, Nutyityu̱? Ya̱jtay variy siva sa̱tidye jmu̱tya ray.”  
\v 41 Su̱mutya̱jada ji̱ta Nutyityu̱ ni̱: “Márta, Márta, jaryi jijechipityaja̱ra tara jvaayada, jipyaru̱tyanuma dyetya riva rajuura jvaayada ji.  
\v 42 Vinu rani̱ taraqui va̱tasara. Jityeryatu Maríya jaryeta̱sirya samirya jiyaru̱rya, jiryatimyu̱ ne ra̱so̱vachara simusiñu̱darya.” 
\c 11  
\s1 Jesús datyadoda nu̱tyuramusiy vu̱ryityu̱chu Ju̱denusa̱, nu̱tyuramusiy 
\r (Matévu 6.9-15; 7.7-11) 
\p  
\v 1 Tarundamu ji̱ta sajoráñu̱yada Jesús. Sajorámyu̱yadanumatiy, su̱teda ji̱ta sisa̱ datyavay tenu yiva: “Ya̱datyanu joráyadata nu̱ntyidye, nu̱tyu sadatyadoda Juán Bautístabaryi yisa̱ datyavay daryantidye.”  
\v 2-4 Su̱teda ji̱ta Jesús variy ruuva: “Jirya̱numatiy joráy, jirya̱jtay variy: 
\q1 Ye̱ye̱, suvu̱chara ra̱cha yitya. Ra̱ma̱ ju̱ti̱ yinsu̱yada. Ya̱sa̱y nu̱ñi tarundaquiju̱ jmyichara nu̱y. Ya̱ramityaniy mityara nu̱jyuuchuveda, tapi nu̱vyitya ramityanichara mityara ridyivyiyada ti̱ta̱ju̱, jiryatiy ridyivyichara nu̱y. Ne ya̱jara̱y jantya̱damuju̱ nu̱y, dantyamu̱y ne ya̱tochiy nu̱ña̱siquita ramuyu.” 
\p  
\v 5-6 Su̱teda ji̱ta variy ruuva: “Saryityi jiya jiryetyenu nuporata̱sa simu jijemyicyu, saryi jiyasanta variñi̱: Jaamyicyu, ya̱sa̱y mumujomiy pa̱ ray jiryatiy sani jviryi̱ rajyu̱tyánubi rimu, ne ta̱rata raryi potyaniñi̱.  
\v 7 Tama̱ saryi jmutya̱ sajaamyicyu jiryorivyimusiñi̱, tama̱: Ne ya̱jarupanta ray. Mutanusaranuma raryorijyu̱day, radyedyeñu jarye rajyiitutyaniy risa̱ju̱. Ne vana̱y rañubesumiy, ne nu̱tyichiy raryiche̱ tara ji.  
\v 8 Ri̱tatye jiryiva, dañumamu̱y ne sa̱nubesumiy tara sa̱yadaju̱ni̱ jiryatiy sani̱cha sajaamyicyu, ramusiy ji̱ta, jiryatiy sayasanta̱nchani̱, sa̱day nubesumiy sa̱tidye sa̱y tarani̱, ratiy sava̱ta.  
\v 9 Ri̱tay ji̱ta variy jiryiva: Vurya̱ma̱ jachiñu̱yencha Ju̱denuvara vu̱vya̱tara, sa̱sa̱y ji̱ta variy vu̱rya; vurya̱ma̱ va̱ta̱numucha Simu rana̱cho̱, vurya̱sarye ji̱ta varirya; vurya̱ma̱ natuye̱yencha rorijyu̱mu, Sa̱muttay ji̱ta variy vurya̱jisirya rorijyu̱.  
\v 10 Tapi ni̱tiy jachiñu̱yencha, sa̱jmutya̱ varirya; ni̱tiy va̱ta̱numucha rana̱cho̱ntiy, sa̱sarye varintyirya; ni̱tiy natuye̱yencha rorijyu̱mu, daryaday ra̱muttay variy saju̱ntiy. 
\p  
\v 11 ¡Saryityi jachiñu̱y dera siva jijye̱ñi̱ quiva̱, sa̱ni̱tiy sa̱y codyidyeñi̱!  
\v 12 Varimyata sa̱tiy jachiñu̱y jijye̱vyara tavaryi jvada, ¡sa̱ni̱tiy sa̱y norityu varidyeñi̱!  
\v 13 Jirye ji̱ta, jiryatiy jamirya vichavay jiryedye, jiryetyi datya sa̱yada tara samirya riy jidyedyeñu, ta̱ jaryivya̱ju̱ sa̱sa̱y Vu̱jye̱ Jarichumuvichi̱ Yintu vu̱y, vu̱tyi jachiñu̱y sivani̱.” 
\s1 Rityu̱chuta̱dani̱ Jesús: “Bayantu nutyityu̱ vanu̱yadata sajatyasara riy bayantuveda nijya̱nvavyasiy” 
\r (Matévu 12.22-30; Márcu 3.20-27) 
\p  
\v 14 Jadchiy ji̱ta sajatya̱dani̱ bayantu niquejasa̱ vanubavyasiy. Sasipyatedanumatiy vanuvasiy, saniquejada ji̱ta vanu variy. Rityi̱tta̱da ji̱ta nijya̱nvay varirya.  
\v 15 Rityevay ji̱ta jteda variy: “Bayantu nutyityu̱ Satanásimyusiy sajatyajaya̱sara riy bayantuveda nijya̱nvavyasiy.”  
\v 16 Rityevay ji̱ta rañi jantyaru̱yada saniy Jesús, riñi va̱ta̱da rana̱cho̱ mityamusiy datya̱da jarichumusirya simu.  
\v 17 Jesús ji̱ta sadatyanu̱yadanumatirya rijechipiya̱jada, su̱teda variy ruuva: “Riryiñumatiy panaryi̱ jiñique̱yadamu curaca nijya̱nvay nu̱ñi riy jiñi̱jyu̱, rirya̱jraay variyu, mityanuma ra̱ma̱cho̱ rivyicha̱da variy.  
\v 18 Daryaday ravicha Satanásiy nusu̱yadamuntiy; riryityi panaryi̱ jiñique̱yadamu Satanásivyeda jiñi̱jyu̱, ¿nu̱tyichiñuma ra̱suru̱y sansu̱yada varintyi, nu̱tyichiy? tapi jiryi̱tay ray jatya Satanásiy vanu̱yadata riy bayantuveda nijya̱nvavyasiy.  
\v 19 Raryityi jatya Satanásimyusiryi bayantuveda, ¿chi̱ vanu̱yadata rijetyasara jiryetyevadyeryi bayantuveda nijya̱nvavyasidye, chi̱? Ramuni̱tiy rirya̱dityanu jiryetyevarya jiryecyarayada.  
\v 20 Ray ji̱ta raryi jatya Ju̱denu jana̱ta riy bayantuveda, riti̱ma̱ Ju̱denu nusu̱yada variy jiryimu. 
\p  
\v 21 Su̱nu̱tyanumatiy vanu̱ryara jivyichajo, jiryatiy jvatya̱ti̱ daryaju̱ni̱, ne ti̱ jvaay varirya sabarya mitya, rama̱cho̱ samirya ti̱ta̱ju̱ variy.  
\v 22 Sasiijetyanumatiy jiryatiy vanu̱ryava̱ju̱ni̱, saryi vuunu ji̱ta variñi̱, saryi so̱vay simusirya yivatya̱, ranijyu̱tiy sani vanu̱y, saryi sa̱ñuve varirya vanu̱rya barya so̱vachara jichiityari̱vamyu. 
\p  
\v 23 Mi̱ni̱tyimyu̱ ne vichasara risa̱ jvaañu, savichasara ji̱ta rayaro̱ju̱; daryadantyi mi̱nintyimyu̱ ne jmu̱tyaru̱rye, jiryatiy rañi ju̱tye̱ryaniryu̱ryi nijya̱nvay, su̱resara variryi.” 
\s1 Jesús datyadoda bayantu jamirya vicharanchiy, jiryatiy sata̱rya̱jada yibivaju̱ 
\r (Matévu 12.43-45) 
\p  
\v 24 “Sasipyatedanumatiy bayantu jamirya vichara sivasiy vanu, savu̱taya̱numaya̱ vassatova variy, sava̱tana̱ya̱ rana̱cho̱ samityo yajiju̱, jasityi sani nta ya̱jiituy. Netimyu̱ ne sasaryedara, sajachipiya̱ ji̱ta variy: Ra̱ta̱ryava̱ ri̱bivaju̱ day.  
\v 25 Sasaryenuvi̱ ji̱ta ntani̱ vanu, nu̱tyu roriy nunichara, mitya roriy, samiy jdutyasara ti̱ta̱ju̱ra.  
\v 26 Saya ji̱ta variy, sapu̱chiy yisa̱ju̱ riy danu̱ju̱ñijyate bayantu rapu̱ryamiy, jiryatiy jaryi jamirya vichavavya̱ju̱ simusiryi. Rije ji̱ta jivyicha̱daju̱ jasiy siva. Sa̱ma̱cho̱ ji̱ta vanu variy jaryi jamiryanu, ta̱riy jivyicha̱da jiyadaju̱.” 
\s1 Samirya ratya̱ju̱ si̱tenura 
\p  
\v 27 Jadchiy ji̱ta Jesús niquejadasa̱ra̱ju̱, nanuniquejasubeda tanu̱qui vaturu̱y nijya̱nvajyuu cabyimusiy, nani̱teda variy siva Jesús: “Jchana̱tyasanu̱y ji̱ta nada, jiryatiy nanurupachodate jivyimusitye ji, nanurupatyadedate jí̱tya̱ varintyi ji.”  
\v 28 Su̱mutya̱jada ji̱ta Jesús variñada: “Jchana̱tyasavavya̱ju̱ ji̱ta riy, rityi tuva̱chusara ramu Ju̱denu niquejada.” 
\s1 Va̱cha vichavay jachiñu̱yadara mityamusiy dityadoda 
\r (Matévu 12.38-42; Márcu 8.12) 
\p  
\v 29 Riñe̱yaru̱yadanumatiy nijya̱nvay variñi̱ Jesús, sajo̱ta̱da ji̱ta niquejada variy: “Diye vichavay ji̱ta jamirya vichavadye. Rivya̱tasara ji̱ta rana̱cho̱ mityamusiy dityadoda. Ne rirya̱diy ji̱ta riva mityamusiy dityadoda, vinu rá jiryatiy sabayada Ju̱denu Jonásibenchiy tu̱chodara.  
\v 30 Tapi Jonásibetya rañi̱cha̱da vatanu̱ni̱ rijyu̱ Ñíñivye ja̱nvabe, daryaday sa̱cha Nijya̱mi̱denu diye vichavajyu̱ntiy.  
\v 31 Nana̱nubesiy ji̱ta ranro nutyityu̱toda bayanu tamitya rundamu, nana̱tidye tu̱chuta variryi diye vichavay, jiryatiy naditi̱jada mucadi su̱tyeryamusiy, nana̱tidye tuva̱chura Sadumú̱bay datya̱da. Dañuma sani̱cha ti̱qui vanu jiyu, jaryi datyarava̱ju̱ Sadumú̱bamyusiy, dantyamu̱y ne rityuva̱churu̱y diye nijya̱nvay ramusiy simu day.  
\v 32 Ñíñivye ja̱nvay bayanumiy ji̱ta ra̱nubesumiy tamitya rundamu, rirya̱tidye tu̱chuta riy diye vichavay, tapi rivyitya paru̱yada variy riva ta̱riy jivyicha̱da, rityuva̱chodanumatirya Jonásibe niquejada Ju̱denunchiy. Dañuma sani̱cha ti̱qui vanu jaryi datyara simusiy Jonásibe, dantyamu̱y ne rityuva̱churu̱y diye nijya̱nvay variy simu day.” 
\s1 Jesús datyadoda: “Vu̱ñi̱siy nu̱tyu vu̱vyu̱ no̱no̱siiy nta” 
\r (Matévu 5.15; 6.22-23) 
\p  
\v 33 “Vu̱ryupañumatirya no̱no̱siiy, ne vu̱dyutya variy tajirya, dantyamu̱y ne vu̱myutanu tarata varirya. Vu̱bey ji̱ta rabajyonchayu, rirya̱tidye diy jañu̱vye jasiy riva rádá.  
\v 34 Vu̱ñi̱siy ji̱ta vu̱vyu̱ no̱no̱siiy; samichityirya vu̱ñi̱siy, jiryatiy vu̱jechipiya̱sara samirya jvaacharanijyu̱, ti̱ta̱ju̱ vu̱vyu̱ ji̱ta ra̱cha variy no̱no̱mu day; netimyu̱ raryi jnu̱y vu̱ñi̱siy samiryana̱cho̱, vu̱vyu̱ ji̱ta raryicha variy nupocudi.  
\v 35 Vuryi̱nu̱tyata̱ta vu̱y, rañuma vichasara nupocudi vu̱ño̱no̱.  
\v 36 Panujotiy vuryivara no̱no̱, ne nupocudide tara variy vuryiva, vurye̱cha variy vandamu ti̱ta̱ju̱, nu̱tyu rano̱no̱nu̱chara no̱no̱siiy daryá vu̱jyu̱.” 
\s1 Jesús tu̱chuta̱da riy Varyisévuveda, Ju̱denu niquejada datyanuvay ruusa̱ju̱ 
\r (Matévu 23.1-36; Márcu 12.38-40; Dúcasiy 20.45-47) 
\p  
\v 37 Saniquejada cabyimu Jesús, samusuyada ji̱ta ti̱qui Varyisévu jbyedaju̱ variñi̱. Sajayada ji̱ta Jesús jibyedaju̱, sata̱ñuvejada ji̱ta variy jmyijyomu.  
\v 38 Sati̱tta̱da ji̱ta Varyisévu variñi̱ Jesús, jiryatimyu̱ ne sasuuta̱dara jijyomutu jimyitya̱ju̱.  
\v 39 Su̱teda ji̱ta Nutyityu̱ variñi̱: “Jirye Varyisévuveda ji̱ta rañi suutasara rarudivasiy jatusiidye, siidye jarye, jiryevyimu ji̱tara paradoda day, va̱cha vichasa̱da jarye.  
\v 40 ¡Si̱tenu datyi̱sa̱miy jirye! Ni̱ni̱ ji̱ta jiryatiy su̱ndejadara jiryatiy vuryivara, nu̱tyu ni̱ni̱day rañi ju̱dejadantirya jiryatiy vu̱vyimuntirya.  
\v 41 Jirya̱ma̱ sa̱y ji̱ta samiy jiryevyimu jachipiya̱jadata riy jantyuyadavay, ti̱ta̱ju̱ ra̱cha samirya Ju̱denu diya variy jiryejyu̱. 
\p  
\v 42 Jiii, ráni̱tte jiryejyu̱te, rá, Varyisévuveda. Jiryemyurichenu daryaju̱ Ju̱denu jiyaru̱ryaju̱ra nutasaratera, jiryatiy jiryejye̱vyechu jmyichara jaryedoju̱ra, dantyamu̱y ne jirya̱jachipityara vase vichasa̱da, dantyamu̱y ne jiryejeryuvu̱y dityadodara Ju̱denu va̱tasara. Jirya̱ma̱ jvaayasiy daryá, jiryatiy daraju̱y nu̱chara jiyura Ju̱denu va̱tasara, dantyamu̱y ne jirya̱paru̱y riva murichedoda Ju̱denu jiyaru̱rya, tapi daryatya ru̱tay saniquejada. 
\p  
\v 43 ¡Jiii, ta̱ju̱na̱te darya jiryejyu̱te day, ta̱ju̱, Varyisévuveda! Jiryeñi va̱tasara daryaju̱ rana̱cho̱ samirya ma̱sajoncha ma̱sa̱da ju̱tye̱ryanijyovimu, jiryi̱canuy jaryintyirya mu̱chuvedantiy jiryatiy rimyu̱chuvay nijya̱nvay samiy jidyetya̱data pudásamu jirye. 
\p  
\v 44 Jiii, ta̱ju̱na̱te darya jiryejyu̱te day, ta̱ju̱, jiryatiy jiryevyicha daryaju̱ nu̱tyu bapyo puryerya, jiryatiy riryaniya̱ nijya̱nvay rancha jiñiya̱resiy.” 
\p  
\v 45 Su̱mutya̱jada ji̱ta ti̱qui niquejada datyi̱ variñi̱ Jesús: “Nu̱jerye yavityiye̱ jirya niquejadata.”  
\v 46 Su̱teda ji̱ta Jesús variy siva: “¡Jiii, ta̱ jaryi niquejada datyavañi̱te jiryevyichasarate day, ta̱ju̱! Jiryetyiityataniy daryaju̱ nijya̱nvarya tiityasara, jiryedyetyadodata, jiryatimyu̱ ne vinu jiryejyomutu jana̱ta jiryejye̱tyo̱ru̱chara raniy, jiryatiy ne vinu jiryivaaryu̱rya daryatiy jiryeñi jvaatyaniryu̱y nijya̱nvarya. 
\p  
\v 47 ¡Acuu jiryedyeri̱dentya day! jiryatiy jiryeryoriicharara bapyo roriy rijechipityasa̱daju̱ Ju̱denuju̱ tu̱chuvabe, jiryatiy ru̱veda jiryemyunatyavaberyi.  
\v 48 Ramuni̱ jiryedyi samirya riva jimyunatyavabe vichasa̱da, jiryatiy ru̱veda riy Ju̱denuju̱ tu̱chuvabe, jirye ji̱ta roriichara daryaju̱ra bapyo roriy rijechipityasa̱daju̱.  
\v 49-51 Ramuni̱day su̱teda Ju̱denu jidyetya̱damu: Ra̱jpa̱ ruumu riy rajyu̱ tu̱chuvay, raynsu̱byimiy jarye, tavay ra̱batye ritye, rityevay ma̱cho̱vay jarye rirya̱jarupantantiy, ra̱tidye jiryi diye vichavamyusirya rimyurichirya Ju̱denuju̱ tu̱chuvabe, jiryatiy ribetyeda mucadi jo̱ta̱damusiy, Abénubay batyedamusiy, Sacaryébay batyedasa̱ra̱ju̱, jiryatiy sabatyeda raparudamu jnutatyasara rupajyo, Ju̱denu nijyu̱ jachipiya̱jo jarye. Jo, ri̱tatye jiryiva: Ra̱jiryi diye vichavamyusirya rimyurichirya ti̱ta̱ju̱. 
\p  
\v 52 Jiii, ráni̱tte jiryejyu̱te rá, niquejada datyavay, jiryatiy jiryecho̱vamya̱ra yevyi nta, ratatiy riryi datya nijya̱nvarya Ju̱denu niquejada. Ne jiryejeryu̱yada nta ramu Ju̱denu niquejada day, daryaday jiryi̱bayada tavayjisintyirya ramu jayadantiy.” 
\p  
\v 53-54 Jesús sipyateda jadchiy, rijyo̱ta̱da ji̱ta siryi̱jada Ju̱denu niquejada datyanuvay, Varyisévuvedata simu yavittyuyadamu. Rijyo̱ta̱da ji̱ta jtaja̱doda ti̱ta̱ju̱ tarivani̱, saryityi jmutya̱jada taji nta riy, varityi riñi jtay ya̱tu̱chuta rivani̱. 
\c 12  
\s1 Jesús datyadoda rayaro̱ju̱ vuryi̱tu̱yada jteda 
\p  
\v 1 Jesús jvaayadasa̱ra̱ju̱ ji̱ta riñe̱yatiiñu̱yada nijya̱nvajyuuyu, jiryatiy riintye̱ryadeda rajuura vara̱nca nijya̱nvayu. Sajo̱ta̱da ji̱ta jteda Jesús munatya ruuva yisa̱ datyavay: “Jiryi̱nu̱tyata̱ta Varyisévuveda cari̱vatya̱ rapu̱ryajisiyu, jiryatiy ru̱tay yitu̱yadamu vichavaryi.  
\v 2 Ne taradera yitu̱yadamu vichasa̱da jiryatiy ra̱ma̱cho̱ samiy mutanusara, mitya; ti̱ta̱ju̱tidye ra̱chasara dityanusara; dantyamu̱y ne ra̱ma̱cho̱sara tara dutyasara, ti̱ta̱ju̱ ra̱chasara datyasara.  
\v 3 Ramuni̱day, miryani̱ntyi vu̱ñiquejada nupocudimu, rirya̱tuva̱chu tavay vidavira; daryadantyi, jiryatiy vu̱cyucuye̱yada tu̱yumu ti̱, vu̱me̱jevyimura, rirya̱tu̱chu vijyo̱mujachera.” 
\s1 Jesús datyadoda chi̱ra vu̱ryi suvu̱chara, chi̱ 
\r (Matévu 10.26-31) 
\p  
\v 4 “Ri̱tatye ji̱ta jiryiva, rajemyicyuveda: Ne vurya̱suvu̱ryi jivye, jiryatiy ru̱varya vu̱vyu̱, rivasiy ji̱ta ne rirya̱vichaniy taranu̱davyu̱y.  
\v 5 Ra̱dityanu ji̱ta jirye mi̱ra vurya̱suvu̱y jaryi. Vurya̱ma̱ suvu̱ñi̱ jiryatiy vuryi̱vacha̱divasiy saryi jpa̱sara jiidatyo̱muju̱ni̱ vu̱beyanu. Ri̱tatye jiryiva: Ni̱ni̱ ji̱ta vurya̱suvu̱y. 
\p  
\v 6 Rajuura criquivyitya samurichevay tadajyo vachuchiy, dañumamu̱y ne sajachipuchara Ju̱denuni̱ ti̱quide sate.  
\v 7 Vuryi̱no̱jasiy jarye saranusara ti̱ta̱ju̱ saju̱ Ju̱denu. Ramuni̱mu̱y ne vurya̱suvu̱y; vu̱ñi̱ ji̱ta murichevay jaryi ruumusiy vachuchimyi.” 
\s1 Rityi tu̱chusara vijyo̱mujache Jesús jiyadaju̱ 
\r (Matévu 10.32-33; 12.32; 10.19-20) 
\p  
\v 8 “Ri̱tay jiryivantiy: Mi̱ni̱tyi tu̱chu vijyo̱mujache nijya̱nvavya: Ray ji̱ta datyani̱ Jesús, sa̱tu̱chu Nijya̱mi̱denu vijyo̱mujache ruuva Ju̱denu jpa̱vantyi: Ray datyani̱ jiñu.  
\v 9 Ni̱ni̱ ji̱ta jiryatiy sa̱tu̱chu nijya̱nvavya raynchiy: Ne radyetyani̱ Jesús, daryaday ra̱tu̱chu ruuva Ju̱denu jpa̱vay varintyidye: Ne radyetya dañi̱ jiñu day. 
\p  
\v 10 Mi̱nintyi ra̱nique sayaro̱ju̱ Nijya̱mi̱denu, sa̱ramityaniy mitya rajye̱rya. Jiñu ji̱ta jiryatiy sa̱javityiye̱ñi̱ Ju̱denu Jnutu, ne sa̱ramityaniy mityara sa̱vityiye̱yada. 
\p  
\v 11-12 Rirya̱numatiy jti̱ta ju̱tye̱ryanijyo ja̱nvamyuju̱ jirye, nutyityu̱mimyuju̱ jarye, japuvedamuju̱ jaryentiy, ne jirya̱jachipiya̱ jaryi variy nu̱tyuramusiy jirya̱jmutya̱ riy, nu̱tyuramusiy, dantyamu̱y ne ta̱ra jirya̱jtay ruuva, ta̱ra, tapi sa̱datyanu ji̱ta Ju̱denu Jnutu variy jiryedyerya, ta̱ra jirya̱jtay variy ruuva.” 
\s1 Vuryi̱nu̱tyasara rajuura baryaveda ni̱ru̱yadajisivyu̱y 
\p  
\v 13 Su̱teda ji̱ta ti̱qui vanu nijya̱nvay cabyimusiy siva Jesús: “Datyanu̱, ya̱tu̱chu siva ratyeryi̱ sa̱ma̱ sa̱y rate ray, jiryatiy su̱mutya̱ra na̱jye̱be barya.”  
\v 14 Su̱teda ji̱ta Jesús variy siva: “Vadero̱nu, ¿chi̱rana̱te bayada cadnadu jiryequebyimu ray, chi̱? ra̱tidye nantara jiryeberya.”  
\v 15 Su̱teda ji̱ta Jesús variy ruuva: “Jiryi̱nu̱tyata̱ta samiy ti̱ barya ni̱ru̱yadajisiyu, jiryatimyu̱ ne vinu tarati̱ vichasara samirya. Daryaday savichasara samiryantiy, jiryatimyu̱ ne tarati̱ sani̱cha.” 
\p  
\v 16 Satu̱choda ji̱ta varirya datyadoda niquejada ti̱ barya ni̱ru̱yadanchiy: “Rani̱rañu̱yada ji̱ta sántará jaryi tarati̱ variy.  
\v 17 Sajachipiya̱jada ji̱ta variy: Ta̱ra ra̱jvaay diye, jiryatimyu̱ ne tara jna̱y vidavijo ra̱torajiju̱nu̱day.  
\v 18 Su̱teda ji̱ta variy: Nu̱rya ra̱jvaay. Ra̱jottirya ra̱tora bajyo rapu̱rya, ra̱tidye roriiy vadiramusiy ja̱murava̱ju̱ra, jasityi ra̱barya ra̱torá, raberya jarye ti̱ta̱ju̱ risa̱ju̱.  
\v 19 Ra̱jtay variy ravyimu, ri̱ntumu jarye: Rajuuranuma raberya, ratanuma ra̱jnu̱jeya̱sara ta̱rijyu̱ ti̱ta̱ju̱. Ra̱numa jiituy, ra̱jmyi, ra̱jatu, ra̱jchana̱y.  
\v 20 Nu̱tyu ni̱day Ju̱denu jteda variy siva: ‘¡Datyi̱sa̱! Diye nupora ra̱va̱tani̱ yintu jibebyimusiy. ¿Chi̱ju̱numa ra̱ma̱cho̱sara jiberya varidye, chi̱ju̱?’  
\v 21 Darya ni̱day, ni̱tiy bacharara jiberya ja̱viñu vinu jijyu̱, ne sajachipiya̱ variy sanijyu̱ Ju̱denu, ne tarati̱ nta variy Ju̱denu diya dañi̱.” 
\s1 Su̱nu̱tyasara Ju̱denu riy jidyedyeñu 
\r (Matévu 6.25-34) 
\p  
\v 22 Su̱teda ji̱ta Jesús variy ruuva yisa̱ datyavay: “Ramuni̱ ri̱tay jiryiva: Ne vurya̱jachipiya̱ jaryi: ¿Ta̱ra vurye̱jmyi vuryi̱nu̱yadaju̱, ta̱ra? dantyamu̱y ne vurya̱jachipiya̱: ¿Ta̱ra vurya̱jachu vuryiva, ta̱ra?  
\v 23 Tapi vuryi̱nu̱yadatya ji̱ta jaryi jmyichara jiyadaju̱ day, vu̱vyu̱ ji̱ta sujay jiyadaju̱ntidye.  
\v 24 Vurya̱jachipiya̱ riñijyu̱ to̱no̱veda, varajonuveda, pu̱ñivyeda jarye ti̱ta̱ju̱ ruusa̱ju̱: ne rinta, dantyamu̱y ne rirya̱to. Ne bajyotavay, dantyamu̱y ne rorichityavay, jasityi rirya̱barya tara. Ju̱denu ji̱ta potyanichara varidyeryi. Vu̱y ji̱ta murichevay jaryi ruumusiy nipya̱tavay.  
\v 25 ¿Mi̱ra vuryisa̱ vichi̱ ra̱sityechu jijechipiya̱jadamusirya yinu̱yada, mi̱? rata̱savu̱ métrusa̱ra̱ju̱.  
\v 26 Netimyu̱ ne vana̱y vu̱chityechu pasidyerara vuryi̱nu̱yada, ¿ta̱raju̱na̱ vurya̱jachipiya̱ taranijyu̱ vuryi̱nu̱yadaju̱, ta̱raju̱? 
\p  
\v 27 Vurya̱jachipiya̱ ranijyu̱ javu̱ñi̱sityu, nu̱tyuramusiy raja̱vye, nu̱tyuramusiy. Ne rivaay, dantyamu̱y ne raruyinura nura̱biju̱u̱ jichujajyu̱sara; ri̱tatye ji̱ta jiryiva: ne vinu nutyityu̱ Sadumú̱bay vicha̱da sami̱va̱ju̱ dutyasi̱ ramusiy.  
\v 28 Saryityi sujañu Ju̱denu daryára samiy vachuy jiryatiy raja̱vye diye, ta̱rimyusiy rirya̱jatya jiidamyura, ta̱ jaryivya̱ju̱ sa̱sujañu Ju̱denu jirye, nijya̱nvay pasidye jachipiya̱vay.  
\v 29 Ne jirya̱va̱ta jaryi jachipiya̱vay rana̱cho̱ tara jiryi̱byedaju̱, dantyamu̱y ne jirya̱todaju̱; dantyamu̱y ne jirya̱vichasara jaryi jachipiya̱vay.  
\v 30 Tapi ti̱ta̱ju̱ mucadiva vichavay va̱tasara rana̱cho̱. Vu̱jye̱ ji̱ta datyara jiryatiy vu̱vya̱tasarara.  
\v 31 Vurya̱ma̱ va̱tajaya̱sara nijya̱nvay jachipiya̱jada jiyasachirya Ju̱denu nusu̱yada, vurya̱sarye varirya vuryi̱myi̱sara, vurya̱tu̱sara jarye risa̱ju̱ ti̱ta̱ju̱.” 
\s1 Jesús datyadoda nu̱tyuramusiy vurye̱cha jaryi taratavay jarichumu 
\r (Matévu 6.19-21) 
\p  
\v 32 “Ne jirya̱suvu̱y, ri̱nu̱tyavadyeri̱, jiryatiy samiy datyasara rajye̱ diyara, sa̱sa̱y yisa̱ nusu̱yadaju̱ jirye.  
\v 33 Jirya̱ma̱ ta̱ryu̱tyara jiberya, jirya̱sa̱y variy yentyutya̱damu riy jantyuvye. Jirya̱ma̱ jvaarya criquiy jiryatimyu̱ ne ra̱rimyityuuchara, jirya̱tidye vichajaya̱sara si̱tenu taratavay jarichumu variy, jasityimyu̱ ne vana̱y satuudichara paranu̱ni̱, dantyamu̱y ne ti̱de ra̱javatyasara jasirya vu̱chujay, ne vinu ruvádera, mitya.  
\v 34 Jasityi ravichasara vu̱berya jaryi murichevarya, jasintya ra̱chasara vu̱jechipiya̱jada varintyi.” 
\s1 Jesús datyadoda vurya̱ma̱ vichasara jdutyasavay 
\p  
\v 35-36 “Vurya̱ma̱ vichasara jdutyasavay jvaayadaju̱, varimyata jañu̱ñu jmutya̱vajyu̱, jiryatiy panujosiirya vu̱ño̱no̱siiy, nu̱tyu rintuy vaduy sa̱jiju̱ jipyatru̱, jiryatiy sata̱rya ja̱mu̱jyomusiy jiryorimyuju̱, rirya̱tidye mutta sa̱jiju̱ra rorijyu̱, sa̱numatiy jvatyiñuvi̱ raniy.  
\v 37 Jchana̱tyasavay ji̱ta samuchechimyi, jiryatiy sasaryeñuvi̱ samiy jnu̱tyavaryi. Ri̱tay si̱tenu jiryiva, sa̱jdutya ripyatru̱ variyu, sa̱ma̱sataniy variryi jimyuchechimyi jmyijyomu, nu̱tyu saryicha rimyuchechiy, sa̱tidye potyaniy jasiryi.  
\v 38 Saryityi saryeñuvi̱ jnu̱tyavaryi jimyuchechimyi nuporata̱sa, varimyata ra̱sacharajisiy, rirye̱cha jaryi jchana̱tyasavay variy.  
\v 39 Vurya̱ma̱ datya ji̱tara jirya. Saryityi datya̱da rorijya̱mi̱: Sa̱jti̱ paranu̱ni̱, ne saryi sipyateda jiryorimyusiy, ramutiy sajayada paranu̱ni̱ variy su̱biva.  
\v 40 Jiryejerye ji̱ta ra̱ma̱cho̱ jnu̱tyavay, tapi varityimyu̱ ne jirya̱nutuy sa̱jiju̱ Nijya̱mi̱denu, mityamusiy sa̱jti̱sara variy jiryi̱biva.” 
\s1 Jesús datyadoda muchechiy siityeranchiy, sasiityejadasa̱nchiy jarye 
\r (Matévu 24.45-51) 
\p  
\v 41 Sitaja̱doda ji̱ta Pyítrubay variñi̱ Jesús: “¿Nutyityu̱, jiñiquejasiy nu̱ñijyu̱ra jirya datyadoda niquejada, varimyata tavañijyu̱ ti̱ta̱ju̱?”  
\v 42 Su̱mutya̱jada Nutyityu̱ variñi̱: “¿Mi̱rana̱te muchechiy siityera, mi̱? datyara jarye risa̱ju̱ni̱, jiryatiy sa̱bay sapatru̱ jiryoriy jnu̱tyi̱si̱ju̱ni̱, sa̱tidye sa̱chara riyaru̱rya jmyichara jiryenu muchechimyiyu.  
\v 43 Jchana̱tyasi̱ ji̱ta jiñu muchechiy, ni̱tiy sasaryenuvi̱ sapatru̱ yivaayadamu.  
\v 44 Ri̱tay si̱tenu jiryiva: Sa̱day bay jiberya jnu̱tyi̱ju̱ni̱, sa̱tidye jnu̱tyajaya̱ ti̱ta̱ju̱ jasirya.  
\v 45-46 Saryityi jachipiya̱jada jiñu muchechiy jivyimu: Saricheñuma rapyatru̱, saryijyo̱ta̱da ji̱ta musiye̱yada variryi jiryenu muchechimyi, muchechityuveda jarye, saryi jmyi, saryi jatu, saryi jniyu̱y varintyi, sa̱jti̱ ji̱ta sapatru̱ varityimyu̱ ne sa̱nutuy sa̱jiju̱, jiryatimyu̱ ne sadatya sa̱jti̱ daryaju̱. Sa̱musiye̱tyaniñuvi̱ sapatru̱ jaryi variyu, sa̱tanuvu̱nu siityejasa̱mivyeda jsa̱ju̱ variñi̱. 
\p  
\v 47 Jiñu muchechiy ji̱ta, jiryatiy sadatya̱dara jipyatru̱ va̱tara, ne vinu daryamusiy su̱dutyaru̱y samiy saju̱ jipyatru̱ra jiberya, dantyamu̱y ne sivaaryu̱rya sava̱tara, sa̱jmutya̱sara variy rajuuraju̱ra jimyusiye̱cha̱da rivasiy.  
\v 48 Ni̱ni̱ ji̱ta ni̱timyu̱ ne datya̱dara jipyatru̱ va̱tara, sivaayada ji̱ta varirya jiryatimyu̱ ne su̱canuy sapatru̱ra, sa̱day ji̱ta jmutya̱ra tapi ratya̱ musiye̱cha̱da rivasiy. Mi̱ni̱tyi vu̱che̱y jaryiñi̱, vu̱ntuy variy jaryintyiñi̱. Jiryatiy ribe ja̱mura criquiy simu ti̱, rayadaju̱numa ji̱ta rirya̱murichenutaniy rivantidyeñi̱.” 
\s1 Rirya̱mityasiiy nu̱ñi tevajyuu Jesúsnchiyu 
\r (Matévu 10.34-36) 
\p  
\v 49 Su̱teda ji̱ta Jesús jadchintyi: “Ri̱deda ji̱ta ra̱tidye jatya mucadinchara jiiday, rañuma tote ji̱quinchusarara.  
\v 50 ¡Ra̱jachi̱niy vamiryamu ray, jaryi vaparu̱tyasa̱ ravyichasara rarunda jto̱jadasa̱ra̱ju̱!  
\v 51-52 Jiryejechipiya̱ dyetya riti̱jada ra̱tidye sa̱rya samirya vichasa̱da jirya mucadimu. Ri̱tatye ji̱ta jiryiva: Ne daryá, ne rirya̱jachipiya̱sara nijya̱nvay taraqui variy ramyo̱musiy, tapi diyemusiy ji̱ta jasityi rirye̱cha tadajyo nijya̱nvay taroriquimu, danu̱ju̱y ra̱cha mu̱nvay jiyaro̱ju̱, mu̱nvay jarye ra̱cha danu̱ju̱y jiyaro̱ju̱, daryani̱ ra̱chasara ti̱ta̱ju̱.  
\v 53 Sa̱jiyaro̱nu ji̱ta vanuni̱ jidyenu, sadenunuma ji̱ta ra̱jiyaro̱nu varintyidyeyu. Nadayaro̱nu ji̱ta vaturu̱ñi̱ jidyetu, daryaday sa̱jiyaro̱nu nanudetu varintyidyeyu. Sadeseda jarye ra̱jiyaro̱nu vaturayu, daryaday sa̱jiyaro̱nu nana̱si̱ntu varintyidyeyu.” 
\s1 Nu̱tyuramusiy vurya̱datya ranchiy vu̱ryunda, nu̱tyuramusiy 
\r (Matévu 16.1-4) 
\p  
\v 54 Saniquetityiyada Jesús variy ruuva nijya̱nvajyuu: “Ru̱nu̱ñumatiy nijya̱nvay radacutyityi rapuryerya, ru̱tay varidye: Ra̱numa jmu, ru̱mu ji̱ta variy.  
\v 55 Ru̱nu̱ñumatiy ra̱sacha samiryunda, ru̱tay variy: Diye ra̱viiday jaryi, si̱tenuni̱day raviiday variy.  
\v 56 ¡Jiryi̱tu̱yadamu vichavayu! Jiryedyetya tu̱chodara nu̱tyura runda ra̱cha tariva, ¿nu̱tyuramusimyu̱ ne jiryedyetya jirya rundanchiy, nu̱tyuramusiy? nu̱tyura rivyiche̱chavay nijya̱nvay diye rundamu vichavayu.  
\v 57 ¿Nu̱tyuramusimyu̱ ne jiryedyetya jidyiryamusirya jiryatiy vase vichasara darya, nu̱tyuramusiy?” 
\s1 Vurya̱jantya jdutya̱da ruusa̱ vu̱myityasimyi 
\r (Matévu 5.25-26) 
\p  
\v 58-59 “Jityi jiya̱da jityu̱chutasa̱damu simu japu, ya̱jantya jdutya̱da sisa̱ jimyityasiy ji, sañuma pu̱chiy cadnadumu ju̱na̱ntyi ji, sañuma sa̱y cadnadu jiivu̱setavay jomu variy ji, sañuma jatyataniy tanuvu̱nujovimuju̱ ji, jadchityimyu̱ ne vana̱y ya̱sipyatay netimyu̱ ne ya̱murichenu tamitya sonuta jiyadaju̱ didye.” 
\c 13  
\s1 Netimyu̱ ne vurya̱paru̱y riva va̱cha vichasa̱da, vurya̱parutay variy riva 
\p  
\v 1 Rivyicha̱da ji̱ta nijya̱nvay varicha̱ra̱ju̱ jasiy, rityu̱choda ji̱ta siva Jesús rinchiy Cadidéyaja̱nvay. Ru̱ntatya̱danumatiy Cadidéyaja̱nvay Ju̱denumu riy yasi̱veda, jiryatiy ru̱veda munatya riy yasi̱veda, su̱vatyadeda ji̱ta japu Pyidátubay varintyidyeryi, sajaryenutadedara rindaja̱ risa̱ rirya̱si̱veda nudaja̱ variy. Darya ni̱day rityu̱chunuvi̱jada siva Jesús.  
\v 2 Su̱mutya̱jada ji̱ta Jesús variryi: “Jiryejechipiya̱ dyetya rivyicha̱da jivye Cadidéyaja̱nvay jaryi juuchatavay jityevamyusiy, jiryatiy rávichadeda darya riy.  
\v 3 Ri̱tatye jiryiva: Ne. Dañuma, netimyu̱ ne jirya̱paru̱y riva va̱cha vicha̱da, jirya̱day parutavya̱ daryantidyeque.  
\v 4 Varimyata daryaday jiryejechipiya̱ rinchiy vu̱yaju̱y nijya̱nvay, mu̱nvañijyate rinchaju̱, Siduvémuntiy. Raju̱u̱yada ji̱ta panu̱chavu̱ rincha, ramudoda variy jasiryi. ¿Jiryejechipiya̱ dyetya rivyicha̱da jamirya vichavay jaryi ruumusiy Jerusarí̱mu vichavay?  
\v 5 Ri̱tatye jiryiva: Ne. Dañuma, netimyu̱ ne jirya̱paru̱y riva va̱cha vicha̱da, jirya̱day parutavya̱ daryantidyeque.” 
\s1 Jesús tu̱choda ni̱nunchiy jiryatimyu̱ ne jarya ravicha̱da 
\p  
\v 6 Satu̱choda ji̱ta Jesús varirya jirya dityadoda tu̱choda: “Ravicha̱da ji̱ta ni̱nu ti̱qui vanu nutara cabyimu. Sava̱ta̱danumatiy raja̱mi̱ rajona̱cho̱ rancha, ne sadiyada variy tariva tiii, mitya.  
\v 7 Su̱teda ji̱ta variy siva jimyuchechiy: Ya̱jnu̱y, mumunijya̱miñuma rañi va̱ta rajona̱cho̱, ne radyichara tariva, tiii, mitya. Ya̱numa jnura; ¿ta̱raju̱ ra̱pa̱chitya mityara ramyucadi jiyu, ta̱raju̱?  
\v 8 Su̱mutya̱jada ji̱ta samuchechiy variyu: Jasiñuma ra̱cha day, Nutyityu̱. Tanijya̱quisa̱ra̱ju̱ ra̱ja̱siy munatya ru̱ro̱, ra̱day bay raruva̱vara voca ju̱vu̱di.  
\v 9 Ra̱tiy jay variy, ra̱ma̱cho̱ samirya variy; netimyu̱ ra̱jaryu̱y variy, ya̱jnutaniy ji̱ta varirya.” 
\s1 Jesús mi̱sadeda jiituyada rundamu nada vaturu̱be butyanu̱y 
\p  
\v 10 Sadatyanunu̱yada ji̱ta Jesús ju̱tye̱ryanijyomu riy nijya̱nvay, jiituyada rundamu.  
\v 11 Nanuvichanu̱yada ji̱ta tanu̱qui vaturu̱y variy jasiy, jdiva̱jada ja̱mi̱tanu̱y. Vu̱yaju̱y nijya̱ nanuvichanu̱yada jdiva̱jnu̱y, mumunijya̱miñijyate ranchaju̱ntiy. Mityanuma nanubutyanumaya̱jadayu, ne vana̱y nanuradeda vasenu̱day.  
\v 12 Sadiyadanumatiy Jesús nadiva, sanatuyada ji̱ta variy yimuju̱ nada, su̱teda ji̱ta variy nadiva: “Popoju̱y, jdanusanu̱ñuma sa̱ni̱diva̱jadajisiyu.”  
\v 13 Sabayada ji̱tara jijyomutu variy nanuniy, nanuseveda ji̱ta varicha̱ra̱ju̱ variy. Nani̱chana̱tya̱da ji̱ta variñi̱ Ju̱denu.  
\v 14 Sanique̱yada ji̱ta ju̱tye̱ryanijyo nutyityu̱ variy ranchiy, jiryatiy sami̱sadeda Jesús nada jdiva̱jnu̱y, jiituyada rundamu. Sanique̱tya̱da ji̱ta ju̱tye̱ryanijyo nutyityu̱ variryi nijya̱nvay: “Jasidyerya tarundaquinijyate vuryivaayadaju̱. Variryundamuni̱ ji̱ta jirya̱jniy mi̱sa̱dana̱cho̱ day; ne jirya̱jniy ji̱ta jiituyada rundamu.”  
\v 15 Su̱mutya̱jada ji̱ta Jesús variñi̱: “Jiryi̱tu̱yadamu jivyicha darya. ¿Va̱ jiryeque, ne jiryeñi jvaay jiryatiy jiryeñi vita jiituyada rundamuni̱ yasi̱ si̱myityanijyomusintyi, jirya̱tidye jti̱ta sa̱tujomuyu?  
\v 16 Va̱ jiñu̱y vaturu̱que, nadani̱ nani̱cha ta̱riy vu̱myunatyi̱ Avurá̱bay jasatu̱y. Jiryatiy nanuvichanu̱yada Satanásiy puchunu̱y, nanuvichanu̱yada jdiva̱jnu̱y vu̱yaju̱y nijya̱sa̱ra̱ju̱, mumunijya̱miñijyate ranchaju̱, ¿samiryavidye raryivyita nada puchusanu̱y jiituyada rundamu?”  
\v 17 Jirya Jesús niquejadanchiy, rirya̱na̱da ji̱ta ti̱ta̱ju̱ samityasivyeda variy. Riichana̱tya̱da ji̱ta nijya̱nvay varirya, jiryatiy mityamusiy sivaañu̱yadara ti̱ttasara ridyiya. 
\s1 Jesús tu̱choda quica̱tadinchiy 
\r (Matévu 13.31-32; Márcu 4.30-32) 
\p  
\v 18 Ramuni̱ su̱teda Jesús variy ruuva: “¿Nu̱tyurani̱ntyi dyetya rani̱cha Ju̱denu nusu̱yadacu̱, nu̱tyu? ¿Mirya tu̱chodatani̱ntyi ra̱datyanuracu̱, mirya?  
\v 19 Nu̱tyu quica̱tadi nta rani̱cha, jiryatiy rinta nijya̱nvay jivyatupada ju̱ro̱ra, raja̱vye ni̱nuju̱ variy, saruuvye ji̱ta nipya̱ti̱ rajiica̱mu varintyi.” 
\s1 Jesús tu̱choda pa̱ cari̱vatya̱nchiy 
\r (Matévu 13.33) 
\p  
\v 20 Su̱teda ji̱ta ju̱na̱y ruuvantiy: “¿Ta̱ra tu̱chodata ra̱datyanura Ju̱denu nusu̱yada, ta̱ra?  
\v 21 Nu̱tyu pa̱ cari̱vatya̱ nta rani̱cha, jiryatiy nanubayada vaturu̱y mumuri̱ quinu pa̱jurudinubera, jasicha̱ra̱ju̱tiy racari̱vay ti̱ta̱ju̱ variy.” 
\s1 Pasijyu̱ jajyonchiy 
\r (Matévu 7.13-14, 21-23) 
\p  
\v 22 Sadatyanutityiñu̱yada ji̱ta Jesús ja̱mu vicha̱diva, pasivyicha̱diva jarye, jiryatiy sarupiñu̱yada variy Jerusarí̱ na̱cho̱ju̱.  
\v 23-24 Su̱teda ji̱ta rityenu siva Jesús: “¿Mitya vamidyenuma jantyutyasavay?” Su̱teda ji̱ta Jesús variy ruuva: “Jirya̱ma̱ jantya jayada paru̱cha̱rimyusiy pasijyu̱ rorijyu̱demusiy jiryeryamitya̱daju̱, jiryatiy ti̱quitya jiryi̱nu̱y rañi jaryu̱y Ju̱denu nusu̱jyomu, ne vana̱y nta rirya̱jay.  
\v 25 Sa̱numatiy mutanu rorijya̱mi̱ra rorijyu̱, jirya̱numa jo̱ta radeda rorijyu̱tuunu, jirya̱tidye jvatyi raniy rorijyu̱day. Jirya̱jtay variy siva rorijya̱mi̱: Nutyityu̱, ya̱mutta nu̱ña̱jisiy. Sa̱jmutya̱ variy jirye: Tama̱ radyetya tesivyerya jirye, tama̱.  
\v 26 Jirya̱jo̱ta jteda variy siva rorijya̱mi̱: Nu̱tyu nu̱dye rañi jibyeda jidyiya, nu̱ña̱toda variy risa̱ju̱ntiy, nu̱tyu jiñi̱ day rañi datyadoda nu̱vyicha̱dajache.  
\v 27 Ni̱ni̱ ji̱ta ra̱jmutya̱ variy jirye: Ri̱tatye jiryiva: Ne radyetya tesivyerya jirye; ¡Jirya̱numa jiya ratyuunusiy va̱cha vichavay!  
\v 28 Jasidye ji̱ta jirya̱jna̱vya̱ varique, jirya̱su̱y ji̱ta jijya̱dajcha varintyi, jirya̱numatiy diy siva Avurá̱ bayanu, Isácu bayanu jarye, Jacóbu bayanu jarye sisa̱ju̱, ti̱ta̱ju̱ Ju̱denuju̱ tu̱chuvay bayanuveda jarye ruusa̱ju̱ntiy, Ju̱denu nusu̱jyomu. Jirye ji̱ta ra̱chasara jatyasavay bimuju̱ variy.  
\v 29 Rirya̱jti̱ ji̱ta nijya̱nvay variy jiñi̱ mu̱ti̱jomusiy, sapuryejomusintyi, ravita̱sa vichavantyi, jidye vita̱sa vichavay jarye, rirya̱ma̱sa jmyijyomu Ju̱denu nusu̱jyomu variy.  
\v 30 Rityi vichasara ji̱ta tamityavay diye, rirye̱chasara ji̱ta munatyavay variy rivasintyi; daryaday rityi vichasara munatyavay diye, rirye̱chasara ji̱ta tamityavay variy rivasintyidye.” 
\s1 Jesús jna̱yada rivasiy Jerusarí̱ 
\r (Matévu 23.37-39) 
\p  
\v 31 Varidye ji̱ta ruuto̱jada Varyisévuveda simu Jesús, ru̱tañuvejada variy siva: “Ya̱numa jiya jiyusiy, jiryatiy su̱varyu̱ñuma Jeródes ji.”  
\v 32 Su̱teda ji̱ta Jesús variy ruuva Varyisévuveda: “Jirya̱numa tu̱chu siva quivu̱rya Jeródes: Diye ji̱ta, ta̱rimyusiy jarye, ra̱jatyatityiryi bayantuveda, ra̱mi̱sanityityi variryi jdiva̱jnuvay; rata̱rimyusiy ji̱ta ra̱jto̱tanirya rivaayada. Darya ni̱day jirya̱tu̱chosiy siva Jeródes.  
\v 33 Ra̱numa ji̱ta jiya rupiñu diye, ta̱rimyusintyi, rata̱rimyusiy jarye ti̱ta̱ju̱, tapi ne vana̱y sabatye Ju̱denuju̱ tu̱chu̱ Jerusarí̱jisiy taji.  
\v 34 Jerusarí̱, Jerusarí̱, jiñijya̱nvay ji̱ta jvachara riy Ju̱denuju̱ tu̱chuvabe, rijechichara ravichu̱ta riy, jiryatiy su̱pa̱sara Ju̱denu riy yinsu̱byimiy ruumu. Rajuuraju̱ rañi ju̱tye̱ryaniryu̱yadanumucha riy ridyedyeñu, nu̱tyu tavaryityoda mutanusara jiñipya̱ta suvu̱charajisiryi jidyenujuu daryá; tiii, riryivya̱tava̱ra.  
\v 35 ¡Tijyiii, satochimya̱ttye Ju̱denura jiryevyichajo! Ri̱tatye ji̱ta jiryivantiy: Ne jirya̱diy ju̱na̱y riva rabetyedivasiñu̱day, netimyu̱ ne jirya̱jtadyidye: ¡Jchana̱tyasi̱te ni̱tiy jnitye Nutyityu̱ jtyamute!” 
\c 14  
\s1 Jesús mi̱sadedani̱ vanubay ja̱mura pa̱chityi̱ 
\p  
\v 1 Tarundamu ji̱ta jiryatiy jiituyada runda ravicha̱da, sajayadanumatiy Jesús jibyedaju̱ sarorivyimu Varyisévuveda nutyityu̱, ru̱nu̱choda Varyisévuveda variy jasiñi̱.  
\v 2 Savichanu̱yada ti̱qui jdiva̱jni̱ sadiya, ja̱mura pa̱chityi̱.  
\v 3 Sitaja̱doda ji̱ta Jesús variryi Ju̱denu niquejada datyanuvay, Varyisévuveda jarye: “¿Samiryavidye Ju̱denu diya, mi̱sadeda jiituyada rundamu, varimyatamu̱y?”  
\v 4 Rime̱cho̱jada mitya vajeryade variy. Sapu̱cheda ji̱ta Jesús variñi̱ jdiva̱jni̱, sami̱sadeda variñi̱, su̱mu̱rya̱da ji̱ta variy jadchiñi̱.  
\v 5 Sitaja̱doda ji̱ta Jesús variryi: “¿Ne jiryeñi jvaay jiituyada rundamuntiy? ¿Mi̱ra jiryetyenu ne saryi sipyata varicha̱ra̱ju̱ni̱ jidyenu varimyata savoca, mi̱ra? saryityi ju̱u̱y jiituyada rundamu jmuchaju̱vimu.”  
\v 6 Ne vana̱y ru̱mutya̱jada variy ranchiy. 
\s1 Ja̱mu̱yada vichtyamuju̱ musuchavay 
\p  
\v 7-9 Su̱nu̱yadanumatiy Jesús jiryatiy rijeryetanu̱yada musuchavarya ma̱sajo rorijya̱mi̱tuunu rirya̱tidye dityanura jivyicha̱da jaryiñuvay jityevamyusiy, satu̱choda ji̱ta variy ruuvara datyadoda niquejada. Su̱teda ji̱ta ruuva: “Ti̱tiy raryi musuy ja̱mu̱jyomuju̱ ji, ne ya̱ma̱sanuve vase vadi ja̱mu̱ñutuunu, saryityi ju̱ti̱ ti̱ jaryiñu̱va̱ju̱ yimusiy, sa̱jti̱ ja̱mu̱yada ja̱mi̱ variy yimu, sa̱jtay variy yiva: Ya̱sa̱y jimya̱sajoni̱. Ya̱jo̱ta ji̱ta variy va̱ta̱da tamitya ma̱sajona̱cho̱ yana̱danube.  
\v 10 Sa̱numatiy musuy ti̱ ji, ya̱ntya ma̱sanuve ji̱ta tamitya ma̱sajoncha, sa̱tidye jtañuvi̱ vadi ja̱mu̱ñu jasiy yiva: Jaamyicyu, ya̱ma̱sa ratyuunudera, jityidye ra̱cha jchana̱tyasi̱ ridyiya musuchavay ti̱ta̱ju̱ variy.  
\v 11 Tapi mi̱ni̱tyi jchana̱tya nu̱tyu jaryiñu̱yu, sa̱cha jantanichi̱ riva, daryaday mi̱ni̱tyi jtay jidyetya pasidyeva̱ju̱, sa̱cha ji̱ta jchana̱tyasi̱ rivantidye.” 
\p  
\v 12 Su̱teda ji̱ta Jesús variy siva jimyusubyintiy: “Ya̱numatiy jvaarya vichtya, ne ya̱musuy variryi jijemyicyuveda, dantyamu̱y ne jityeryi̱veda, dantyamu̱y ne jiryena̱miy, dantyamu̱y ne jityuunu vichavay jaryi taratavay, riñuma musuy ramurichiryantidye ji.  
\v 13 Ya̱numatiy jvaarya vichtya, ya̱ma̱ musuy ji̱ta riy jantyuyadavay, pa̱ñimyi, canuya̱simyi, ni̱sipyuryimyi jarye ruusa̱ju̱.  
\v 14 Jaryi jchana̱tyasi̱ ji̱ta ye̱cha variy, jiryatimyu̱ ne vana̱y rimyurichenu ramurichirya ji, tii, mitya. Ya̱day ji̱ta jmutya̱ra ramurichirya, vase vichavay mi̱sa̱subeda rundamu.” 
\s1 Jesús tu̱choda ja̱mu vichtyanchiy 
\r (Matévu 22.1-10) 
\p  
\v 15 Satuva̱chodanumatiy ti̱qui Jesúsjsa̱ musuchi̱ra saniquejada, su̱teda variy siva: “Jchana̱tyasi̱ ji̱ta sa̱cha, ni̱tiy ra̱jmyi Ju̱denu nusu̱jyomu.”  
\v 16 Su̱teda ji̱ta Jesús variy siva: “Ta̱riy savichanu̱yada ti̱qui vanu. Sivaayada ji̱tara ja̱mu vichtya rajuuvay musuchavajyu̱.  
\v 17 Vichtya rundamu ji̱ta su̱pa̱jadani̱ jimyuchechiy ruumu musuchavay, sa̱tidye jtay ruuva: Jirya̱numa jiya vichtyamu, jdutyasaranuma daryaju̱ ti̱ta̱ju̱ra.  
\v 18 Rijyo̱ta̱da ji̱ta jteda variy siva vichtya ja̱mi̱ muchechiy, jiryatimyu̱ ne vana̱y nta rirye̱jiya. Su̱teda munatya musuchi̱ siva muchechiy: Ratye̱ryu̱mya̱ diyedera nudiy, ra̱jnu̱jedyi riva. Rajechiñu̱y yiva sa̱ma̱ ramityaniy vichtya ja̱mi̱ mitya rivara.  
\v 19 Su̱teda ji̱ta nu̱ntiy: Ratye̱ryu̱mya̱ vu̱yaju̱y voca, ra̱jnu̱jedyiryi. Rajechiñu̱y yiva sa̱ma̱ ramityaniy mitya rivara.  
\v 20 Su̱teda ji̱ta nu̱ntiy: Rajya̱mu̱mya̱ ravyaturaju̱, ramuni̱mu̱y ne vana̱y ra̱jiya.  
\v 21 Satu̱chunuvi̱jada ji̱ta muchechiy variy siva jipyatru̱ra riñiquejada. Satuva̱chodanumatiy rorijya̱mi̱ra, su̱teda ji̱ta jamiryamu siva jimyuchechiy variy: Vani̱ra jaryuve ye̱jiya vicha̱da cabyiva, ja̱mu nú̱va, racu̱siñu̱deva jarye, jiipyu̱chitya̱ta vani̱ra rumusiryi jantyuyadavay, pa̱ñimyi jarye, canuya̱sivyeda jarye ruusa̱ju̱.  
\v 22 Satu̱chunuvi̱jada ji̱ta muchechiy siva jipyatru̱ntiy: Rito̱tanimya̱ra yiteda, jasidye ji̱tara vidavijontiy.  
\v 23 Su̱teda ji̱ta variy siva jimyuchechiy: Ye̱jiya ja̱munú̱quiva, mantyanú̱va jarye, ya̱tidye jaryuvu̱ryi nijya̱nvay rumusiy, ra̱tidye mu̱cha̱siy raryoriy variy rijyu̱.  
\v 24 Ri̱tatye si̱tenute yivacu̱, ¡ne sa̱jmyi ti̱ musuchavay tenute ravyichtyamu, tii, mitya!” 
\s1 Vu̱ryi rrachu ti̱ta̱ju̱ra vu̱berya, Jesús siityari̱sa̱daju̱ 
\r (Matévu 10.37-38) 
\p  
\v 25-26 Riya̱danumatiy rajuuvay nijya̱nvay sisa̱ Jesús, sa̱numityejada ji̱ta variy riñe̱cho̱ju̱, su̱teda variy ruuva: “Ni̱tiy siityari̱ru̱rye, netimyu̱ sa̱va̱tasara jaryivya̱ju̱ nadimusiy jijye̱jyu̱rye, savaturu̱y jarye nadisa̱ju̱, sataryi̱veda, si̱tyamutuveda jarye ti̱ta̱ju̱, jo, su̱nu̱yadasa̱ra̱ju̱, ne vana̱y sa̱chasara risa̱ datyi̱.  
\v 27 Mi̱ni̱tyimyu̱ ne nichusara jidyiiyadajiju̱ra crusiy, dantyamu̱y ne sasiityari̱tityi varirye, ne vana̱y sa̱chasara risa̱ datyi̱.  
\v 28 Tapi mi̱ra jiryetyenu, saryityi roriiryu̱rya panu̱chavu̱, ¿ne viy sa̱ma̱sa munatya jimyi̱saniy, ramurichirya suradodaju̱, rasa̱ra̱numaviy rani̱cha criquiy, ratatiy saryi ca̱sirya panu̱chavu̱?  
\v 29 Netimyu̱ ne saryi suranu samirya ramurichirya, saryiñumatiy jo̱ta roriiyada, netimyu̱ ne vana̱y nta sa̱ca̱sirya, riryi jo̱ta jarupanta̱da tavañi̱, jiryatiy ridyi riva sadatya̱da su̱tyeda.  
\v 30 Riryi jtay ji̱ta variy: Sani jo̱tama̱ ji̱ta roriiyada, ne vana̱y ntate saca̱sirya.  
\v 31 Daryadantyi, ¿mi̱ra ja̱mu nutyityu̱, mi̱? saryityi datya: Su̱niñuma ratarya nutyityu̱ vu̱ñe̱cho̱, daraju̱y vu̱yaju̱y vara̱nca su̱tarumitya, ne viy sa̱ma̱sa munatya, sa̱tidye jachipiya̱ samiy: ‘Vana̱vyidye vurya̱suru̱y vu̱yaju̱y vara̱nca su̱tarumitya rijyu̱.’  
\v 32 Vu̱ryityi datya: Ne vu̱cha̱ra̱vay ntate day, ripyapudetidye riryicha vu̱myityasimyi, vu̱ryi jpa̱ riy vu̱nsu̱vye rimyo̱muju̱, rirya̱tidye jdutya nu̱ñi mityasivyedara.  
\v 33 Ramuni̱tiy, mi̱ni̱tyi jiryetyenu, netimyu̱ ne sajachipiya̱ samiy sa̱tidye rrachura jiberya ti̱ta̱ju̱, ne vana̱y sa̱chasara risa̱ datyi̱ variñu̱ndye.” 
\s1 Jesús tu̱choda tivyi tivyijyu̱vyedanchiy 
\r (Matévu 5.13; Márcu 9.50) 
\p  
\v 34 “Tivyi ji̱ta samirya. Varityi ji̱ta raryi baryi̱ rativyijyu̱vyeda, ¿nu̱tyuramusiña̱ vu̱ryi ta̱ryataniy tivyijyu̱ryaju̱ntirya, nu̱tyuramusiy?  
\v 35 Ne samirya mucadiju̱ra, mitya, dantyamu̱y ne voca ju̱vu̱dimuntiy. Vu̱ryi jatya mitya ruujyuuju̱ra. Daryani̱ ji̱ta savicha ni̱timyu̱ ne siityari̱ samirya. Jiryetyuva̱chuta̱ta tu̱yutavay.” 
\c 15  
\s1 Jesús tu̱choda carni̱ru carañunchiy 
\r (Matévu 18.10-14) 
\p  
\v 1 Rityuudiñu̱yada ji̱ta criquiy jmutya̱vañi̱ Jesús, juuchatavay jarye ruusa̱ju̱, rirya̱tidye tuva̱chu varirya saniquejada.  
\v 2 Ricyucutya̱da ji̱ta Varyisévuveda variyu, Ju̱denu niquejada datyanuvay jarye. Ru̱teda ji̱ta: “Sadirye ji̱ta jiñu riy juuchatavay, si̱byeda variy ruusa̱.”  
\v 3 Satu̱choda ji̱ta Jesús varirya jirya datyadoda tu̱choda ruuva:  
\v 4 “¿Mi̱ra jiryetyenu, mi̱? saryityi caray ti̱qui sa̱si̱ taraqui pachamusiy, saryiñi̱tiy tochi̱sadaryi yasi̱veda binda day, sa̱tidye va̱ta sana̱cho̱ carañu, sasaryecha̱dasa̱ra̱ju̱.  
\v 5 Saryiñumatiy saryeñi̱, saryi nichu ji̱ta yichana̱yadamu variñi̱.  
\v 6 Saryiñumatiy ju̱ti̱ jiryorimyuntiy, saryi naturyi jijemyicyuveda yimuju̱ variy, satuunuvichavay jaryentiy, saryi jtay variy ruuva: Jirya̱jchana̱y risa̱, jiryatiy racharyemya̱ni̱ ra̱si̱ carañu.  
\v 7 Darya ni̱day jarichumu, rirye̱jchana̱chara Ju̱denu tuunu vichavay sanchiy ti̱qui juuchati̱, jiryatiy saparu̱y riva ta̱riy jivyicha̱da. Rirye̱jchana̱chara jaryivya̱ju̱ sanchiy, taraqui pacha nijya̱nvamyusiy, jiryatimyu̱ ne rivya̱ta paru̱yada riva samiy jivyicha̱da Ju̱denu diya.” 
\s1 Jesús tu̱choda criquidye cararyanchiy 
\p  
\v 8 “Daryadantyi, ¿miñu̱y vaturu̱rya, miñu̱y? raryi carera tadaqui criquidye, vu̱yaju̱dye tera, neviy naryi ruparya jiño̱no̱siiy, naryi nuniy varirya jiryoriy, naryi va̱tana̱ya̱ samiy rana̱cho̱, rasaryecha̱dasa̱ra̱ju̱.  
\v 9 Naryityi saryerya, naryi natuy ji̱ta variryi jijemyicyuveda yimuju̱, tavay nanutuunu vichavay jaryentiy, nana̱tidye jtay variy jasiy ruuva: Jirya̱jchana̱chara risa̱, jiryatiy racharyemya̱ra racyuriquidye cararya.  
\v 10 Darya ni̱day ra̱chasara jarichumuntiy, jchana̱yada ra̱chasara Ju̱denu jpa̱vay diya sanchiy ti̱qui juuchati̱, jiryatiy saparu̱y riva ta̱riy jivyicha̱da.” 
\s1 Jesús tu̱choda vadero̱nunchiy, jiryatiy sapa̱chitya̱da mityara jivyicha̱da 
\p  
\v 11 Su̱teda ji̱ta Jesús variy ruuva: “Savichanu̱yada ti̱qui vanu, danu̱ju̱y denuju̱tyi̱.  
\v 12 Su̱teda ji̱ta sadenu tamityi̱ yiva: Ye̱ye̱, ya̱numa sa̱y rayaru̱rya jiberyate ray. Sanantaja̱jada ji̱ta saja̱rya jiberya variy danu̱ju̱jyu̱.  
\v 13 Ne rajuu rundamusiy, sa̱richumu̱yada sadenu tamityi̱ra jiberya ti̱ta̱ju̱, saya̱da ji̱ta variy tara mucadimuju̱. Rumunuma ji̱ta sapa̱chityanuvejadara jicyuriquiy, va̱cha vichasajomu.  
\v 14 Saca̱siyadanumatiy ti̱ta̱ju̱ra jicyuriquiy, rajo̱ta̱subeda ji̱ta jachi̱nu runda variy jasiy mucadimu, sasu̱tyejada ji̱ta yinu̱tya̱vasiy variy.  
\v 15 Satuudiñuvejada ji̱tani̱ ti̱qui jasiy mucadija̱nvay tenu. Ni̱ni̱ ji̱ta jpa̱jada yindimyu, jicyuchiy jnu̱tya̱daju̱ni̱.  
\v 16 Sani turiryu̱yada ji̱tara ja̱nuja̱ tera, jiryatiy cuchiy jmyichara darya. Ne ti̱de jmyityaniryu̱yada daryaju̱ tarani̱.  
\v 17 Sata̱rya̱danumatiy yibivaju̱ntiy, sajachipiya̱jada ji̱ta variy jijechimyu: ¿Nurivyerya rajye̱jsa̱ jvaavye vichasara jmyicharatavay, nurivye? netimyu̱ rasu̱tyeryi̱ tara jmyichara ruumusiy, ¡radyentya diiryu̱vya̱ rajechi̱jadamu jiyu daquiii!  
\v 18 Ra̱day nubesumiy, ra̱jiya rajye̱myuju̱, ra̱jtañuve variy siva: Ye̱ye̱, rajyuuchuvamya̱ Ju̱denunijyu̱, jidyiya jarye risa̱ju̱.  
\v 19 Ne ravya̱ta ntate rirya̱jtay tavay jidyenu nu̱ndyerye. Ya̱vichaniy nu̱tyu yivaatyaniy nta ray.  
\v 20 Sanubesubeda ji̱ta variy, saya̱da ji̱ta simu jijye̱. Ripyapudetidye savicha̱da, sadiyada ji̱ta saja̱y yiva, sa̱ntyutya̱da variñi̱. Sasiicheda ji̱ta variy sana̱cho̱, samariñuvejada ji̱tani̱ jidyenu, sasiiñuva̱ye̱yada variy jasiñi̱.  
\v 21 Su̱teda ji̱ta sadenu variy yiva: Ye̱ye̱, rajyuuchuvamya̱ Ju̱denunijyu̱, jidyiya jarye risa̱ju̱: ne ravya̱ta ntate, rirya̱jtay tavay jidyenu nu̱ndyerye.  
\v 22 Su̱teda ji̱ta saja̱y variy ruuva jimyuchechimyi: Varenu jaryuve jirye̱jiryera samichujay, jiryatiy samijevya̱ju̱ra, jirya̱jachosiy variy radyenuvara; jirya̱bañi̱ jana̱jatu sa̱na̱ta̱sa, saapatu jarye jirya̱jachu sanumutuvantiy.  
\v 23-24 Jadchintyi, jirya̱jiryeni̱ vocadenu, jiryatiy vu̱ñu̱chuma̱ni̱, jirya̱jvañuvi̱jasiy variñi̱. Vurya̱jmyi, vurya̱jchana̱y variy risa̱ju̱, jiryatiy jiñu radyenu rañi̱chanu̱tyi diiñu, diye ji̱ta jnu̱ñuntiñi̱; sani̱chanu̱tyi carañu, diye ji̱ta saryechi̱ntiñi̱. Rijyo̱ta̱da jchana̱tya̱da variñi̱. 
\p  
\v 25 Sadenu munatyi̱ ji̱ta vicha̱da yindimyu variy. Sata̱rya̱jada ji̱ta, satuudiyadanumatirya jiryoriy, satuva̱choda ji̱tara riryudiyada, rirye̱ya̱jada jarye risa̱ju̱.  
\v 26 Sanatuyada ji̱ta yimuju̱ni̱ ti̱qui muchechiy, sitaja̱doda ji̱tani̱: ¿Ta̱ra rani̱cha jirya, ta̱ra?  
\v 27 Su̱mutya̱jada ji̱tani̱: Siti̱jasimya̱ jityeryi̱. Su̱vatyadesiy jijye̱ñi̱ vocadenu, jiryatiy vu̱ñu̱chusiñi̱, jiryatiy su̱mutya̱jasiy vani̱ri̱ni̱ jityeryi̱.  
\v 28 Sanique̱yada ji̱ta samunatyi̱ variy ranchiy, sajaryu̱yada vitya ji̱ta variy jasiy. Sasipyateda ji̱ta saja̱y variy yimu, sayasanta̱da variy jasiñi̱.  
\v 29 Tiii, saryijeryu̱vya̱. Su̱mutya̱jada ji̱tani̱ jijye̱. Ya̱jnu̱cyu̱, nurirya nijya̱sa̱ra̱ju̱ra rivaayada siityera yisa̱, nurirya, tama̱ jiche̱yada ti̱ jasi̱ rapu̱ryate darye, tama̱, ra̱tidye jvaarya vichtya rajyemyicyuvedatantidye.  
\v 30 Diye ji̱ta, jiryatiy siti̱ jiñu jidyenu, ni̱tiy pa̱chityara jicya̱na̱rya cadnatuvedava, yivatyadesiy ji̱ta saju̱ni̱ vocadenuntiy, jiryatiy vu̱ñu̱chusiñi̱.  
\v 31 Su̱teda ji̱ta saja̱y variy yiva: Ya̱jnu̱y Pi̱, jivyichajaya̱sara ji̱ta risa̱. Jiryatiy ti̱ta̱ju̱ raberyara, daryaday jiberya varintyidyerya.  
\v 32 Vu̱ryi dyetya jchana̱y samo̱musiy, jiryatiy jiñu jityeryi̱ rañi̱chanu̱tyi diiñu, diye ji̱ta jnu̱ñuntiñi̱; sani̱chanu̱tyi carañu, diye ji̱ta saryechi̱ntiñi̱.” 
\c 16  
\s1 Jesús tu̱choda patru̱ barya jnu̱tyi̱nchiy, jiryatiy sapa̱chityanu̱yadara jipyatru̱ jvaadyi 
\p  
\v 1 Su̱teda ji̱ta Jesús yisa̱ datyavavyantiy: “Savichanu̱yada ji̱ta nu̱ vanu, jiryatiy su̱nu̱tyanu̱yadara jaryi tarati̱ barya. Rityu̱chuta̱da ji̱ta tavay sapatru̱vayu, jiryatiy sapa̱chityanu̱yadara sivaadyi daryaju̱.  
\v 2 Sanatuyada ji̱ta sapatru̱ yimuju̱ni̱ muchechiy, sitaja̱doda ji̱ta variy jasiñi̱: ¿Ta̱rana̱te ratyuva̱chu jiinchiy, ta̱ra? Jiyuju̱ rumusirya cuentapadye. Ne vana̱y ya̱jvaay ju̱na̱y risa̱nu̱day.  
\v 3 Sajachipiya̱jada ji̱ta jnu̱tyi̱ variy jijechimyu: ¿Ta̱rana̱te ra̱jvaay diye, ta̱ra? Saso̱vamya̱ daryaju̱ rapyatru̱ rimusirya rivaayada day. Ne vanu̱rya ray, ra̱jvaaje nudimyu, ra̱a̱da ji̱ta mitya jachiñu̱yadiva tara.  
\v 4 Radyetya̱dapu̱ñuma ta̱ra ra̱jvaay, ta̱ra, rirya̱tidye jmutya̱ nijya̱nvay ri̱nu̱tya̱divasiy jiryorimyuju̱ ray.  
\v 5 Jadchiy ji̱ta sanatuyada nu̱ñi ti̱quimusiy yimuju̱ riy nijya̱nvay, jiryatiy ridyivyiñi̱ jipyatru̱. Su̱teda ji̱ta siva munatyi̱: ¿Nuriryana̱te jidyivyiñi̱ vu̱pyatru̱, nurirya?  
\v 6 Su̱mutya̱jada ji̱tani̱: Taraqui pacha ni̱ja̱vu̱ data. Su̱teda ji̱ta jnu̱tyi̱ variy siva: Jiryatirya jicuentavi̱. Ya̱ma̱sa, ya̱nu̱y varenu riva cateravi̱ra tadajyo vu̱yaju̱y ni̱ja̱vu̱ data.  
\v 7 Su̱teda ji̱ta siva nu̱ntiy: ¿Va̱ ji, nurirya jidyivyidye, nurirya? Su̱mutya̱jadani̱: Taraqui pacha jaruusichuy. Su̱teda ji̱ta variy siva: Jiryatirya jicuentavi̱. Ya̱nu̱y mumuri̱nijyate vu̱yaju̱chuy.  
\v 8 Si̱chana̱tya̱da ji̱ta sapatru̱ variy jnu̱tyi̱yu, dañumamu̱y ne sani̱cha vase jvaarya, jiryatiy sivaayada jidyetya̱da rapu̱ryatara. Tapi va̱cha jvaavye ji̱ta vichasara jityevatya jaryivya̱ju̱ datyavay ruumusiy no̱no̱ dadyeñu, jiryatiy Ju̱denu no̱no̱mu vichavaryi. 
\p  
\v 9 Ray ji̱ta ra̱nique rimusiy jiryiva: Jirya̱ma̱ datya jvaayada criquiy rapu̱ryata, jirya̱tidye ca̱na̱y ramusiy jiryejyu̱ riy jaamyicyuveda, ra̱numatiy baryi̱ jiryecyuriquiy, sa̱dirye Ju̱denu yisa̱ vichavatya ju̱na̱re vichajomuju̱ variy jirye. 
\p  
\v 10 Ni̱ni̱ ji̱ta jiryatiy savichasara jto̱taniryá pasidyemusiy, daryaday savichasara jto̱taniryá ja̱mura jvaayadamuntiy. Daryadantyi, ni̱tiy ne jto̱taniy pasidyetara, daryaday saquivu̱chara ja̱mura jvaayadatantiy.  
\v 11 Netimyu̱ ne vuryivaachara jto̱tanivye criquitya, ¿chi̱rana̱ ra̱baryu̱y vuryimura jiryatiy si̱tenu jaryi murichetara darya, chi̱?  
\v 12 Netimyu̱ ne vuryivaachara jto̱tanivye rata, jiryatiy ti̱ barya darya, ¿ta̱ju̱rana̱ sa̱sa̱ryu̱y vuryi̱nu̱tya̱da murichirya vu̱y, ta̱ju̱? 
\p  
\v 13 Ne vana̱y sivaachara muchechiy danu̱ju̱y patru̱sa̱. Saryityi jvaaryu̱y nadisa̱, saryi javittyuñi̱ ti̱qui, saryi va̱tasara variñi̱ ratarya patru̱; varimyata saryi jvaay vani̱ri̱ sisa̱ ti̱qui, saryi javiryu̱tya variñi̱ ratarya patru̱. Dantyamu̱y ne vana̱y vuryivaay sisa̱ Ju̱denu, criquisa̱ jarye, jiryatiy vu̱vyichasara criquiy ju̱redacanumiy.” 
\s1 Jesús niquejada Varyisévuvedava 
\p  
\v 14 Rityuva̱choda ji̱ta Varyisévuvedara Jesús niquejada ti̱ta̱ju̱. Jiryatiy rivyichasara criquiy jachavay, rirya̱viryu̱tya̱da variñi̱.  
\v 15 Su̱teda ji̱ta Jesús variy ruuva: “Jirye ji̱ta rañi dityanu vase vichavay nijya̱nvay diyayu, Ju̱denu ji̱ta datyasarara jiryejechiy; tapi jiryatiy samiy jvadichara rani̱chasara nijya̱nvay diya day, Ju̱denu diya ji̱ta javityichara varidyerya.” 
\s1 Ju̱denu jtedanchiy, sansu̱yadanchiy jarye 
\p  
\v 16 “Saniquenu̱yada ji̱ta Ju̱denu jiñiquejada nu̱charamusiy, saju̱ tu̱chuvabemyusiy jarye, Juán Bautístabay rundasa̱ra̱ju̱ ti̱ta̱ju̱. Variryundamusiy ji̱ta, nu̱tyu̱chunumaya̱ra samitu̱choda Ju̱denu nusu̱jyonchiy, riñi pana̱tyityi nijya̱nvajyuu ramu jayadaju̱. 
\p  
\v 17 Tama̱ jvadatyi̱sasara rani̱cha, tama̱, raryityi parutay jarichu, mucadi jarye risa̱ju̱ ramusiy, jiryatiy raryi su̱tye pasidyeradera Ju̱denu niquejada jto̱tadedaju̱.” 
\s1 Jesús datyadoda tova̱jadanchiy 
\r (Matévu 19.1-12; Márcu 10.1-12) 
\p  
\v 18 “Mi̱ni̱tyi tova̱nada jivyaturu̱y, saryityi ja̱mu̱y variy ti̱ nadivasintyi, sa̱jarupanu variy ratara nanuvicha̱da nijya̱nvay diya, jiryatiy rirya̱diy variy nadiva nu̱tyu jmuchanutanu̱y nada; daryadantyi, saryityi ja̱mu̱y vinu vanu nada vaturu̱y tova̱sanu̱y, daryaday sa̱jarupanu ratantirya jivyicha̱da nijya̱nvay diyantiy, jiryatiy rirya̱diy nu̱tyu jmuchanutodati̱ variy siva.” 
\s1 Jesús tu̱choda jaryi tarati̱nchiy, jantyuyani̱ Dásarubaynchiy jarye 
\p  
\v 19 “Savichanu̱yada ji̱ta ti̱qui vanu jaryi tarati̱, sajachunu̱yada yivara samichujay, jiryatiy jaryi vasidyajarya, sapotyaniñu̱yada ji̱ta samirya jmyicharatayu.  
\v 20 Savicha̱da ji̱ta ti̱qui jantyuyani̱ Dásaru jtyati̱, satiryo̱jada ji̱ta vatajo̱ju̱ñu sarorijyu̱tuunu jatyasi̱de.  
\v 21 Sani potyaniryu̱yada jmyichara daryuutya variy jasiyu, jiryatiy raju̱u̱ya̱ riimyijyomusiy. Nibyiveda ji̱ta ju̱deda variy savatajo̱mu tana̱yadana̱cho̱.  
\v 22 Sadiiyada ji̱ta tarundamu Dásaru variy, ripyu̱cheda ji̱ta Ju̱denu jpa̱vay Avurá̱bay bayanu tuunuju̱ni̱ sabayanu. Daryaday sadiiyada jaryi tarati̱ntiy, ru̱muchoda variñi̱.  
\v 23 Savicha̱da ji̱ta tarati̱ bayanu diiye̱vye bayanu vichajovimu; sapiradeda jipyaru̱tya̱damu na̱vajyu̱, sadiyada ji̱ta ripyapu siva Avurá̱ bayanu, Dásaru bayanu jarye satuunu.  
\v 24 Saniquejasubeda ji̱ta variy: ¡Ye̱ye̱ Avurá̱! ¡Ya̱jantyutyate ray! ¡Ya̱jpa̱ni̱ Dásaru, sa̱tidye paroniy ja̱a̱mura yana̱mo̱, sa̱tidye canuvu̱nu ratara radyechiy, jiryatimyu̱ ne rajechi̱nitye jiiday nu̱ya̱ranube nu̱ndyerye, ja cuu!  
\v 25 Su̱mutya̱jada ji̱ta Avurá̱ variñi̱: Pi̱, ya̱jachipitya ji̱ta diyera, jiryatiy yimutya̱nu̱yada ta̱riy yinu̱yadamura jiyaru̱rya samirya, nu̱tyu Dásaru jmutya̱nu̱yadara nicyara̱y varicha̱ra̱ju̱ntiy. Diye ji̱ta savichasara jmu̱tyasi̱ jiyu ru̱co̱mu, ji ji̱ta siichunuja̱si̱ jasiy.  
\v 26 Jadchiy ji̱ta sabayada Ju̱denura vataju̱quíintiy, riñuma ramije jiryimuju̱ rityi rañi ramijeryu̱y jiyusiy, dantyamu̱y ne vana̱y rirya̱ramije rumusiy jiyuju̱nu̱dantyi.  
\v 27-28 Su̱teda ji̱ta variy siva Avurá̱: Rayasantate varidye ji, Ye̱ye̱, ya̱tidye jpa̱ rajye̱be rorimyuni̱ Dásaru, tapi tadajyo taryi̱ti̱ vitya jasirye. Sa̱ma̱ tu̱chunuve va̱cha vicha̱dajisiy samiy ruuva, riñuma ju̱ti̱ jirya paru̱tyasajomuju̱ntiy.  
\v 29 Su̱mutya̱jada ji̱ta Avurá̱ variñi̱: Jasidye ruumura Ju̱denu niquejada nu̱chara, jiryatiy Muyusésibemyusirya, Ju̱denuju̱ tu̱chuvabe nu̱rya jarye. Rirya̱ma̱ tuva̱chu ramu.  
\v 30 Saniquejada ji̱tantiy: Ne, Tatya Avurá̱, ti̱tiy raryi jiya diibyicabyimusiy ruumu, riryi janumitye variy vase vicha̱daju̱.  
\v 31 Su̱mutya̱jada ji̱ta variñi̱: Netimyu̱ ne rityuva̱churu̱y ramu Ju̱denu niquejada, jiryatiy Muyusésibe nu̱yadara, ne vinu Ju̱denuju̱ tu̱chuvabe nu̱ryamu jarye, dantyamu̱y ne riryi tuva̱churu̱y ranchiy, dañuma saryi mi̱sa̱sumiy ti̱ diibyicabyimusiy ridyiya.” 
\c 17  
\s1 Ta̱ju̱na̱te saju̱, ta̱ju̱, ni̱tiy ra̱jti̱tara juuchanitya̱ 
\r (Matévu 18.6-7, 21-22; Márcu 9.42) 
\p  
\v 1 Su̱teda ji̱ta Jesús variy ruuva yisa̱ datyavay: “Si̱tenuco day ra̱jti̱ juuchanitya̱, ta̱ju̱na̱te saju̱te day, ta̱ju̱, ni̱tiy ra̱jti̱tara juuchanitya̱.  
\v 2 Samiryava̱ju̱ ji̱ta raryicha saju̱, riryityi puchu nijya̱nvañi̱ ravichu̱suma sapita̱sa, riryi jatya ji̱ta variy ja̱mu na̱vajacheni̱, sañuma juuchanu ti̱ ra̱jisiy riquebyimusiy rachiityari̱vay.  
\v 3 ¡Jiryi̱nu̱tyata̱tayu! Saryityi juuchuvay ti̱ jityeryi̱ jiñijyu̱, ya̱nique samiy ra̱jisiy siva. Saryityi tuva̱chu yimu, saryi paru̱y variy riva, ya̱ramityaniy variy mitya sivara.  
\v 4 Saryityi juuchuvatyityi daraju̱ñijyateju̱ tarundaquimu jiiñijyu̱, saryityi janumityetyityi daraju̱ñijyateju̱ jiñe̱cho̱ju̱ntiy, sa̱tidye jtay variy yiva: Rapyaru̱mya̱ riva, ya̱ma̱ ramityadesiy variy mitya sivara jijyuuchuvedantiy.” 
\s1 Ju̱denumu tuva̱choda vanu̱yada 
\p  
\v 5 Sansu̱byimiy jteda variy Nutyityu̱ yiva: “Ya̱jasa̱chura nu̱tyuva̱choda yimu.”  
\v 6 Su̱teda ji̱ta Nutyityu̱ variy ruuva: “Raryityi vicha jiryetyuva̱choda pasidye nu̱tyu quica̱tadide, jiryejtay variy riva jirya ni̱nu: Ye̱cha daputasara jiryuva̱ta ti̱ta̱ju̱, ye̱cha ji̱ta nutasara rivasiy na̱vajachentiy, raryityuva̱chu varicha̱ra̱ju̱ jiryimu.” 
\s1 Nu̱tyuramusiy vu̱ryi jvaay Ju̱denuju̱ 
\p  
\v 7 “Saryityi vichasara muchechityi̱ jiryetyenu, varimyata saryicha jasi̱ jnu̱tyi̱, varimyata nudimyu jvaañu, saryityi ju̱ti̱ samuchechiy yivaajyomusiy, ne dyetya saryi ntay sapatru̱ yiva: Ya̱numa jmyi.  
\v 8 Temusiy dyetya saryi ntay siva: Ya̱mutivyerya jmyichara rajyu̱, ya̱jdutya variy ji, ya̱tidye potyaniy varirye. Ra̱numatiy jmyimyu̱y, ra̱jatu ranchaju̱ntiy, rivasiy ji̱ta ye̱jmyi variy jiidye, ya̱jatu jarye variy risa̱ju̱.  
\v 9 ¿Saryi ntavya̱ variy siva jimyuchechiy: ¡Yentyumya̱te riva!?  
\v 10 Daryaday jirye, jirya̱numatiy jvaamyu̱y ti̱ta̱ju̱ jiryatiy su̱pa̱sara Ju̱denu jirye, jirya̱jtay variy siva: Nu̱ñi̱cha muchechimyi datyi̱sa̱miy. Nu̱dyivaamyu̱mya̱ra vinu jiryatiy yipa̱ nu̱dyivaayadaju̱ra.” 
\s1 Jesús mi̱sadeda riy vu̱yaju̱y vatajo̱ju̱vye 
\p  
\v 11 Jesús jiya̱damu Jerusarí̱na̱cho̱, saramiryi̱jada ji̱ta raparudamu Cadidéya, Samáriya jarye.  
\v 12-13 Sajayadanumatiy vicha̱da rapu̱ryademu, rimyu̱ti̱jada ji̱ta vu̱yaju̱y nijya̱nvay vatajo̱ju̱vye si̱dcho̱ju̱. Riryadeda ji̱ta ripyapude variy, riñiquejasubeda ji̱ta jaryi variy jadchiy: “¡Maestru Jesús, ya̱jantyutyate nu̱y!”  
\v 14 Sadiyadanumatiy ruuva, su̱teda ji̱ta variy ruuvantiy: “Jirya̱jiya jidyityanusa̱dana̱cho̱ caserdótevyedamu.” Riya̱damu, rabayada rivyatajo̱ variy yivasiy.  
\v 15 Ti̱qui rityenu, su̱nu̱yadanumatirya jimyi̱sa̱da, sata̱rya̱da ji̱ta Jesúsna̱cho̱ju̱, si̱chana̱tyatityiyada jaryi niquejadata variñi̱ Ju̱denu.  
\v 16 Sabutya̱da ji̱ta mucomuju̱ Jesús numutu tuunuyu: “Rasa̱ra̱numa ray. Jimyi̱sanimya̱te ray.” Ni̱ni̱ ji̱ta vicha̱da Samáriya ja̱mi̱.  
\v 17 Saniquejada ji̱ta Jesús variy: “¿Ne rivyicha̱siy vu̱yaju̱dye, jiryatiy rimyi̱sa̱siy? ¿Nu̱tyijiña̱riy dañuju̱yunijyate day, nu̱tyijiy?  
\v 18 ¿Neviy ritye̱rya̱ru̱y satevadye, rirya̱tidye jchana̱tyani̱ Ju̱denu? ¿Vinu jiñu ranrota̱sa vichi̱ni̱ ta̱rya̱ day?”  
\v 19 Su̱teda ji̱ta Jesús variy siva: “Ya̱nubesumiy, ya̱numa jiya. Rami̱sanimya̱ jityuva̱choda ji.” 
\s1 Nu̱tyuramusiy ra̱jti̱ Ju̱denu nusu̱yada vuryimu, nu̱tyuramusiy 
\r (Matévu 24.23-28, 36-41) 
\p  
\v 20-21 Ruutaja̱doda ji̱ta Varyisévuvedani̱ Jesús: “¿Nu̱tyeryivye ra̱jti̱ Ju̱denu nusu̱yada vuryimu, nu̱tyeryivye?” Su̱mutya̱jada ji̱ta Jesús variryi: “Ne riti̱ Ju̱denu nusu̱yada jvadichara vuryimu, dantyamu̱y ne rirya̱jtay jiryiva: ¡Jiryatirya! ne vinu rirya̱jtay jiryatiy ¡Mu̱rya! Jirya̱ma̱ datya: Jasiñuma rani̱cha jiryequebyimu Ju̱denu nusu̱yada.” 
\p  
\v 22 Su̱teda ji̱ta Jesús variy yisa̱ datyavavya: “Ra̱day ju̱ti̱ runda, varityi jirya̱diryu̱y jaryi riva tarundaquide Nijya̱mi̱denu rundate, ne vinu daryamusiy jirya̱diy riva.  
\v 23 Rirya̱jtay ji̱ta tavay variy: ¡Mu̱ñumani̱! varimyata sa̱jmutya̱ ti̱ variy: ¡Jiñutiy jiyuni̱! Ne jirya̱jiya mu̱y, dantyamu̱y ne jirya̱siityari̱ variryi tu̱chuvay.  
\v 24 Tapi Nijya̱mi̱denu jti̱jada rundamu ji̱ta ra̱cha nu̱tyu ra̱duya̱ra, jiryatiy ra̱jaduya̱ jarichu dutuuvya.  
\v 25 Munatya ji̱ta sa̱paru̱tyasara Nijya̱mi̱denu rajuura sa̱ra̱ju̱yu, rirya̱rrachu diye vichavay variñi̱.  
\v 26 Daryatiy rivyicha̱da Nuvébay rundamuntiy, ja̱mu nijya̱ paruta̱dajisiy, daryaday ra̱cha Nijya̱mi̱denu jti̱jada rundamuntiy.  
\v 27 Riimyiñu̱yada, rirya̱tunu̱yada risa̱ju̱, rijya̱mu̱ñu̱yada, rijya̱mu̱tyaniñu̱yadantiyu, Nuvévedabay jmusa̱dasa̱ra̱ju̱ cartyequiivimu, ranijye̱yada ji̱ta nijya̱nvay parutedaju̱ variy.  
\v 28 Daryaday rivyichanu̱yada Dótubay rundamuntiy, riimyiñu̱yada, rirya̱tunu̱yada risa̱ju̱, ritye̱ryu̱ñu̱yadantiy, ritye̱ryu̱tyanu̱yada varintyi; rintanu̱yada, riryoriiñu̱yada jarye risa̱ju̱.  
\v 29 Variryundamu ji̱ta varityi sasipyateda Dótubay Sodómamusiy, ru̱boda ji̱ta jiiday jarichumusiy variy, asújuru quivarya jarye risa̱ju̱, raparuta̱da ji̱ta riy nijya̱nvay ti̱ta̱ju̱, pattaryitye riy.  
\v 30 Daryaday ra̱cha Nijya̱midenu rundamuntiy, sa̱numatiy dityanu Ju̱denu mityamusiy variñi̱.  
\v 31 Variryundamu ji̱ta, ni̱tiy ra̱tu̱chu sisa̱ jityuunu vichi̱, dañuma ra̱vicha sabarya jiryorivyimu, ne sa̱jay variy jiberya ju̱redana̱cho̱, dantyamu̱y ni̱tiy ra̱cha yindimyu, ne sa̱siityityi tara ju̱redana̱cho̱ jiryorivyimusiy.  
\v 32 Jirya̱jachipitya nada Dótubay vaturu̱be (jiryatiy nanuti̱tuyada tivyivyu̱ju̱ jiryatiy nana̱numityejada jnu̱yada rana̱cho̱ jiberya ma̱cho̱ra.)  
\v 33 Mi̱ni̱tyi ramityaniryu̱yadara yinu̱yada, sa̱care varirya, mi̱nintyi ji̱ta ra̱carera yinu̱yada, sa̱bajeya̱sara varirya.  
\v 34 Ri̱tay jiryiva: Nana̱cha danu̱ju̱y vanuju̱y jime̱yamu variñupora, Nijya̱mi̱denu rundamu, ti̱qui ji̱ta ra̱cha pu̱chichi̱, sisa̱ ma̱ñu ji̱ta ra̱cha tochichi̱ jasiy.  
\v 35 Nana̱cha danu̱ju̱y vaturu̱jyu̱y tunu̱nuvimu tanunu̱jyu̱y, tanu̱qui ji̱ta ra̱cha pu̱chichanu̱y, nadisa̱ vichanu̱y ji̱ta ra̱cha tochichanu̱y.  
\v 36 Danu̱ju̱y vanuju̱y ra̱cha yindimyu, ti̱qui ji̱ta ra̱cha jara̱chi̱, sisa̱ vichi̱ ji̱ta ra̱cha tochichi̱.”  
\v 37 Ruutaja̱doda ji̱ta variñi̱ Jesús riva: “¿Tera rani̱cha daryá, Nutyityu̱, te?” Su̱teda ji̱ta ruuva: “Jasityiñi̱\f * \fr 17:37 \ft Jasityi rivyichasara nijya̱nvay jaryi nicyara̱myi, rapotiye̱ rivyichasa̱da Ju̱denuju̱ nu̱tyu rapotiye̱chara diidabi daryá.\f* diibyi, jasiñi̱ ji̱ta rirya̱ji̱tye̱ryaniy didapasuyanuvedayu.” 
\c 18  
\s1 Jesús tu̱choda bacheno̱danchiy, cadnadunchiy jarye 
\p  
\v 1 Satu̱choda ji̱ta Jesús datyadoda niquejadata ruuva, nu̱tyuramusiy riryityu̱chujaya̱sara sisa̱ Ju̱denu, nu̱tyuramusiy, ne riryipyaru̱y tarundamu variy riva.  
\v 2 Satu̱choda ji̱ta: “Savichanu̱yada ti̱qui cadnadu, ja̱mu vicha̱damu. Ne sasuvu̱ñu̱yadani̱ Ju̱denu, dantyamu̱y ne su̱nu̱yada ti̱na̱cho̱, mitya.  
\v 3 Nanuvichanu̱yada ji̱ta bacheno̱da jasintyi, jiryatiy nani̱niñu̱yada japichiy simu cadnadu, nani̱tañu̱yada ji̱ta siva: Ya̱jdutya rajyu̱ra ratyu̱chutasa̱da ratyu̱chuti̱sa̱.  
\v 4-5 Ne sani jmu̱tyaru̱yada munatya nada. Rivasiy ji̱ta sajachipiya̱jada jivyimu: Danimyu̱y ne rachuvu̱charani̱ Ju̱denu, dantyamu̱y ne nijya̱mi̱, jiryatiy nadayasanta̱danumucha jiñu̱y bacheno̱da ray, ra̱jdutya nadaju̱ra jityu̱chutasa̱da, nañuma paru̱tyatadedanumucha yidedata ray.” 
\p  
\v 6 Saniquejada ji̱ta Nutyityu̱ Jesús variy: “Jiryetyuva̱chuta̱tara cadnadu niquejada, jiryatimyu̱ ne vase jvaaryani̱.  
\v 7 Saryityi jdutya cadnadu va̱cha vicharara tara, ¡ta̱ jaryivya̱ju̱ sa̱jdutya Ju̱denura jijeryetasavay tu̱chutasa̱da, jiryatiy rijechiñu̱jeya̱ jna̱rya, nupora jarye siva, dañuma santutyaniy rijechiñu̱ryajiju̱yu!  
\v 8 Ri̱tay jiryiva: Sa̱jdutya varenu jaryuve Ju̱denura rityu̱chutasa̱da. Dañuma sa̱numatiy ju̱ti̱ Nijya̱mi̱denu rayadaju̱ ¿sa̱vidye sarye mucadimu riy nijya̱nvay jiryatiy rityuva̱chusara simu?” 
\s1 Jesús tu̱choda Varyisévunchiy, criquiy jmutya̱nunchiy jarye sisa̱ju̱ 
\p  
\v 9 Satu̱choda ji̱tara jirya datyadoda tu̱choda ruuva nijya̱nvay, jiryatiy ru̱nnuva̱yu, rijechipiya̱jadamu daryaju̱ yiteda jivyicha vase jvaavye, rirya̱viryu̱tya̱da variryi tavay.  
\v 10 Satu̱choda ruuva: “Nana̱subeda ji̱ta danu̱ju̱y vanuju̱y Ju̱denu roriñe̱cho̱ju̱, nana̱tidye tu̱chu sisa̱ Ju̱denu. Ti̱qui vicha̱da Varyisévu, nu̱ ji̱ta vicha̱da criquiy jmutya̱nu.  
\v 11 Varyisévu ji̱ta radeda tu̱chu̱ yasiquita: Ju̱denu, ri̱chana̱tya ji, jiryatimyu̱ ne ravyichasara nu̱tyu tavay nijya̱nvay, jiryatiy paranu̱ni̱miryi, varuyu jvaavye, jmuchanutodatavay jarye, varimyata nu̱tyu jiñu criquiy jmutya̱nu rapu̱rya.  
\v 12 Ri̱ndasarara jmyichara daraju̱jyu̱ nu̱ñi taraqui simyanumu; rache̱chara ji̱ta Ju̱denuju̱ra taraquidera nu̱ñi taraqui vu̱yaju̱y ri̱mutya̱ramusiy.  
\v 13 Criquiy jmutya̱nu ji̱ta radeda ripyapude Ju̱denu roriyjisiy, ne sani piradeda na̱vajyu̱, tii, mitya. Mityanuma su̱vatyiñu̱yada jidyutudincha yana̱damu, su̱tañu̱yada variy: ¡Ya̱jantyutyate ray, jiryatiy juuchati̱ ray!  
\v 14 Ri̱tay jiryiva: Su̱musa̱da jaryi samiy jvadichi̱ Ju̱denu diya jiryorimyuju̱ Varyisévumusiy, tapi mi̱ni̱tyi jchana̱tyayu, sa̱cha jantanichi̱ riva; daryaday sa̱chantiy mi̱ni̱tyi jtay jidyetya pasidyeva̱ju̱, sa̱cha ji̱ta jchana̱tyasi̱ rivantidye.” 
\s1 Jesús jachiñu̱yadara Ju̱denu jmu̱tya̱da deramiy jiyadaju̱ 
\r (Matévu 19.13-15; Márcu 10.13-16) 
\p  
\v 15 Ruuti̱tanu̱yada ji̱ta nijya̱nvaryi deramidyera pasiñude sa̱ra̱ju̱ simu Jesús, sa̱tidye ju̱riy riñiy, riryetyanusa̱daju̱. Ru̱nu̱yadanumatiy sisa̱ datyavay ru̱tutityiryi deramidyera, ru̱bayada ji̱ta rirya̱jisirya jidyedyeñu jti̱tasa̱da.  
\v 16 Jesús ji̱ta natuyada yimuju̱ varidyeryi, su̱teda ji̱ta yisa̱ datyavavya: “Ne jirya̱niquetta riy deramiy, rirya̱ma̱ ju̱ti̱ rimu. Ne jirya̱jbarya ruuti̱jada, tapi rityi ra̱chasara Ju̱denu nusu̱jyomu, riñi̱cha nu̱tyu deramidyera.  
\v 17 Ri̱tay si̱tenu jiryiva: Mi̱ni̱tyimyu̱ ne ra̱jmutya̱ra Ju̱denu nusu̱yada, nu̱tyu su̱mutya̱ derade samiy jachitya daryara, ne sa̱jachara variy Ju̱denu nusu̱jyomu, tii, mitya.” 
\s1 Satu̱choda vadero̱nu jaryi tarati̱ sisa̱ Jesús 
\r (Matévu 19.16-30; Márcu 10.17-31) 
\p  
\v 18 Sitaja̱doda ji̱ta ti̱qui nutyityu̱ni̱ Jesús: “Datyanu̱ sami̱, ¿ta̱ra jvaayadata ra̱jmutya̱ra rayaru̱rya ju̱na̱reju̱ jnu̱yada, ta̱ra jvaayadata?”  
\v 19 Su̱teda ji̱ta Jesús variy siva: “¿Ta̱ju̱ra yitay sami̱ darye, ta̱ju̱? Ne ti̱ sami̱, vinu Ju̱denu.  
\v 20 Jiñi̱ ji̱ta datyara Ju̱denu datyadoda: Ne vurya̱rupi ti̱ vaturu̱jsa̱, ne vurya̱jvañi̱ ti̱, ne vurya̱paranu risa̱ju̱, ne vurya̱niquera quivu̱yada ti̱nijyu̱ntiy; vurya̱ma̱ tuva̱chu simu vu̱jye̱, vuryi̱no̱damu jarye.”  
\v 21 Su̱teda ji̱ta nutyityu̱ variy siva Jesús: “Vadinudemusiy ratyuva̱chunu̱yada ramu ti̱ta̱ju̱.”  
\v 22 Satuva̱chodanumatiy Jesúsra saniquejada, su̱teda ji̱ta siva: “Rasu̱tyedye tarade ji. Ya̱ta̱ryu̱tyara jiberya ti̱ta̱ju̱, jadchiy ji̱ta ya̱sa̱y ruuva jantyuyadavarya ramurichirya. Variñi̱ ji̱ta ye̱cha tarati̱ jarichumu. Varenumacu̱, ya̱siityari̱sara varirye.”  
\v 23 Satuva̱chodanumatirya Jesús niquejada, sayiveda ji̱ta jaryi variy, jiryatiy jaryi tarati̱ daryaju̱ dañi̱.  
\v 24 Jesús jnu̱yada jiñiquejada sa̱ra̱ju̱ sana̱cho̱, saniquejada ji̱ta variy: “Ta̱ jaryi surra ravichasara rijyu̱ jaryi taratavay Ju̱denu nusu̱jyomu jayada day.  
\v 25 Saryityi ramije camélluquisuma rodanru̱ju̱ vimu, saryi jay ji̱ta jaryi tarati̱ variy Ju̱denu nusu̱jyomuntidye.”  
\v 26 Rityi tuva̱chodara saniquejada, ruutaja̱doda ji̱ta variñi̱: “¿Chi̱na̱ ra̱ramityasarate, chi̱?”  
\v 27 Su̱teda ji̱ta variy ruuva: “Jiryatimyu̱ ne vana̱y sivaayada nijya̱mi̱ra, vinu Ju̱denu ji̱ta ra̱jvaachara darya.”  
\v 28 Su̱teda ji̱ta Pyítrubay variy siva: “Nu̱y ji̱ta tochedara jiryoridye, nu̱chiityari̱jada variy ji.”  
\v 29-30 Su̱teda ji̱ta Jesús variy ruuva: “Ri̱tay si̱tenu jiryiva: Ni̱tiy tochiy Ju̱denu nusu̱yada jiyasachirya jiryoriy, varimyata savaturu̱y, varimyata sataryi̱veda, varimyata saja̱vyeda, varimyata sadadyeñu, sa̱day jmutya̱ ji̱ta jijyomu jaryi rayadaju̱, tarundamunuma ji̱ta sa̱jmutya̱ra ju̱na̱reju̱ jnu̱yadantiy.” 
\s1 Sajatyiiyada tu̱choda Jesús jibetyedajiju̱ 
\r (Matévu 20.17-19; Márcu 10.32-34) 
\p  
\v 31 Sa̱ra̱cheda ji̱ta Jesús variryi yisa̱ datyavay, vu̱yaju̱y, danu̱ju̱y rinchaju̱, su̱teda ji̱ta variy ruuva: “Vurya̱sumiñuma ji̱ta Jerusarí̱muju̱. Jto̱tanichara ra̱cha variy Ju̱denuju̱ tu̱chuvabe niquejada ti̱ta̱ju̱, jiryatiy riñu̱yada sanchiy Nijya̱mi̱denura.  
\v 32 Rirya̱sa̱y ji̱ta ma̱myimyuni̱ Nijya̱mi̱denu, rirya̱jarupanta variñi̱, rirya̱javityiye̱ risa̱ju̱ni̱, rirya̱tochiye̱ variy siva risa̱ju̱ntiy.  
\v 33 Rimyusiye̱yadivasiy ya̱jvañi̱. Mumurundamimyusiy ji̱ta, sa̱mi̱sa̱sumiy diibyimusintyi.”  
\v 34 Sisa̱ datyavay ji̱ta, ne datya̱dara Jesús niquejada, mitya. Dutyasara daryaju̱ rijyu̱ra saniquejada, ramuni̱mu̱y ne ridyetya̱dara. 
\s1 Jesús mi̱sadedani̱ ni̱sipyuryi, Jericó ja̱mi̱ 
\r (Matévu 20.29-34; Márcu 10.46-52) 
\p  
\v 35 Satuudiyadanumatiy Jesúsra Jericó, savicha̱da ji̱ta ni̱sipyuryi nú̱tuva̱rya, jadchityi sajachiñu̱ñu̱yada jimya̱sajomusiy tara ruuva nijya̱nvay.  
\v 36 Satuva̱chodanumatiy ni̱sipyuryirya riryamityityiyada nijya̱nvajyuu, sitaja̱doda ji̱ta variy: “¿Ta̱ra rani̱cha daryamusiy, ta̱ra?”  
\v 37 Ru̱mutya̱jada ji̱ta variñi̱: “Ni̱numa Jesús ramiryi̱, Nasaryémusi̱.”  
\v 38 Saniquejasubeda ji̱ta variy: “¡Jesús, Davyíbe jasi̱, ya̱jantyutyate ray!”  
\v 39 Rityi rupiryi̱jada Jesúsjisiy, riñique̱tya̱da variñi̱, riñi ndasaniryu̱yada variy jasiñi̱. Sasa̱ñe̱ya̱jada ji̱ta jaryi varidye: “¡Davyíbe jasi̱, ya̱jantyutyate ray! ¡Ya̱jantyutyate ray!”  
\v 40 Saraniñuvi̱jada ji̱ta Jesús variy jasiy, saryitya̱tadeda yimuju̱ variñi̱. Satuudiyadanumatiy ni̱sipyuryiñi̱, sitaja̱doda Jesús variñi̱:  
\v 41 “¿Nu̱tyura jivya̱ta ra̱chaniy ji, nu̱tyura?” Su̱mutya̱jada ji̱tani̱: “¡Ri̱nu̱yasumiryu̱y ju̱na̱dye, Nutyityu̱!”  
\v 42 Su̱teda ji̱ta Jesús variy siva: “Ya̱numa jnu̱yasumíy, ra̱ntyumya̱ jityuva̱choda yiva.”  
\v 43 Varicha̱ra̱ju̱de raratyesubeda sani̱siy varidye, sasiityari̱jada ji̱ta variñi̱ Jesús, si̱chana̱tyatityiyada variñi̱ Ju̱denu. Nijya̱nvay jarye, jiryatiy ridyi daryaju̱ riva sami̱sa̱da, riichana̱tya̱da ji̱ta variñi̱ Ju̱denu riva. 
\c 19  
\s1 Saquívubay diryu̱yada siva Jesús 
\p  
\v 1 Sajaryi̱jada ji̱ta Jesús Jericómu.  
\v 2 Savicha̱da ji̱ta ti̱qui vanu jasiy, Saquívu jtyati̱bay, jiryatiy criquiy jmutya̱nu nutyityu̱ni̱. Savichanu̱yada jaryi tarati̱, jiryatiy su̱mutya̱nu̱yadara criquiy, ma̱myi nutyityu̱ju̱.  
\v 3 Sani va̱tanu̱yada diyada siva Jesús, ¿chi̱ra sani̱cha, chi̱? Saryi divya̱ siva, jiryatiy nijya̱mi̱juu daryaju̱ jarupanu sayada, jiryatiy japunude daryaju̱ni̱.  
\v 4 Sasiicheda ji̱ta nijya̱nvayjiju̱, sa̱sumiñuvejada ji̱ta ni̱nuncha, sa̱tidye diy jadchiy siva Jesús, tapi jasitya sa̱ramiryi̱ daryaju̱.  
\v 5 Sito̱jadanumatiy Jesús simu Saquívubay, su̱nu̱yasubeda ji̱ta sana̱cho̱, su̱teda ji̱ta variy siva: “Saquívu, varenude ya̱jmusa, tapi diye rundamu dyetya raryime̱cho̱nuve jiryorimyu.”  
\v 6 Varenude sajaryuvu̱yada jmusa̱da variyu, sadiryejada ji̱ta jichana̱yadamuni̱ Jesús.  
\v 7 Ridyiyadanumatiy nijya̱nvay riva sivaayada Jesús, ricyucuye̱yada ji̱ta variy: “Vanu juuchati̱mu sajañu̱y.”  
\v 8 Saradeda ji̱ta Saquívubay variy, su̱teda ji̱ta siva Jesús: “Ya̱jnu̱y, Nutyityu̱, ra̱sa̱y raberya tadaryi jantyuyadavay; raryityi murichenutadeda ja̱murani̱ ti̱, raryi ta̱ryataniy daryaju̱yuju̱ simuju̱ntirya.”  
\v 9 Su̱teda ji̱ta Jesús variy siva: “Diye ji̱ta riti̱jasiy ramityadeda jirya rorimyu vichavajyu̱, rorijya̱mi̱ Saquívuju̱ jarye, jiryatiy vu̱myunatyi̱ Avurá̱bay jasi̱ daryaju̱ dañi̱.  
\v 10 Tapi siti̱ma̱ ji̱ta Nijya̱mi̱denu, sa̱tidye va̱ta riñe̱cho̱ nijya̱nvay caravye, sa̱tidye jantyuy variy ruuva.” 
\s1 Jesús tu̱choda vu̱yaju̱y criquiy jmutya̱vanchiy 
\r (Matévu 25.14-30) 
\p  
\v 11 Rityuva̱chodanumatirya Jesús niquejada, satu̱choda ji̱ta ranchaju̱ra datyadoda tu̱choda, jiryatiy rityuudiñu̱yada varirya Jerusarí̱, rijechipiya̱jada sisa̱ datyavay variy: “Mityamusiy dyetyate ra̱mu̱ti̱sarate Ju̱denu nusu̱yada vu̱jyu̱.”  
\v 12 Ramuni̱ satu̱choda Jesús variy ruuva: “Savicha̱da ti̱qui vanu, samiy jriiñuti̱, saya̱da ji̱ta tavicha̱damu, sa̱tidye bay ja̱mu nutyityu̱ nu̱tyu nutyityu̱ satevay cabyimuyu, sa̱ta̱rya ji̱ta variy rivasintyi.  
\v 13 Saya̱dajisiy, sanatuyada ji̱ta yimuju̱riy vu̱yaju̱y jimyuchechimyityevay, sasa̱cheda ji̱ta tamo̱siqui criquitye ruuva, nu̱ñi darya ti̱ta̱ju̱ sasa̱yada variy ruuva. Su̱teda ji̱ta variy ruuva: Jirya̱ntya jvaay jirya criquitya samiy ra̱jiju̱, riti̱jada sa̱ra̱ju̱.  
\v 14 Rityevay ji̱ta javittyuyadani̱, ru̱pa̱jada ji̱ta su̱siryi nusu̱chavay, ja̱mu nutyityu̱mu, rirya̱tidye jtay siva: Ne nu̱vya̱ta jintyityu̱ju̱ni̱ jiñu, mitya. Ne satuva̱choda ja̱mu nutyityu̱ variy ruumu.  
\v 15 Sata̱rya̱danumatiy vanu, nutyityu̱numa savicha̱da variy. Sanatutyadeda yimuju̱ variryi jimyuchechimyi criquiy jmutya̱vay, sa̱tidye datya nu̱tyura ruuvaañu̱chiy nu̱ñi ti̱quimusiy jicyuriquitya, nu̱tyura.  
\v 16 Su̱tañuvi̱jada rimyunatyi̱ siva: Patru̱, rá̱sa̱mya̱ jicyuriquiy mo̱siy vu̱yaju̱y mo̱sijyu̱.  
\v 17 Su̱teda ji̱ta sapatru̱ variy yiva: ¡Rántyé ji, samirya muchechiy ri̱tay variy ji! Jiryatiy yito̱tanicharara yinsu̱cha̱da pasidyeta, ya̱nsu̱chara variy vu̱yaju̱y vicha̱damu.  
\v 18 Su̱tañuvi̱jada nu̱ sivantiy: Patru̱, ra̱sa̱mya̱ jicyuriquiy mo̱siy tadajyo mo̱sijyu̱.  
\v 19 Su̱teda patru̱ variy siva: Ji ji̱ta ra̱nsu̱chara tadajyo vicha̱damu.  
\v 20 Su̱tañuvi̱jada ji̱ta nu̱ sivantiy: Patru̱, jiryatirya jicyuriquiy mo̱siy, jiryatiy rabeyada pa̱a̱ñi̱vimu mo̱siicharara.  
\v 21 Rachuvu̱chara daryaju̱ ji, jiryatiy jaryi nusu̱yadajvaañu daryaju̱ ji. Yirichara ji̱tate jadchirya, jiryatimyu̱ ne jibeyada tara jasiy; yatosara ji̱tate, teni̱ntimyu̱ ne jiñi nuta̱da tara.  
\v 22 Su̱teda ji̱ta patru̱ variy siva: ¡Jiñiquejadivadentya ra̱tu̱chutava̱ ji, muchechiy nicyara̱y rapu̱rya! Jidyetya̱da viy ravyichasara jaryi jaryuvu̱rya, jiryatiy ririchara jadchirya, jasityimyu̱ ne rañi bay tara, rajarye, jiryatiy ra̱tosarara teni̱ntimyu̱ ne rañi nuta̱da tara.  
\v 23 ¿Ta̱raju̱mu̱y ne jibetyi variy criquiy jasa̱chujomura racyuriquiy, ta̱raju̱? raryityi jmutya̱nuvi̱ ra̱sa̱ryata variyu.  
\v 24 Su̱teda ji̱ta variy ruuva jityuunu ranivye: Jirya̱so̱vay simusirya racyuriquiy, jirya̱tidye sa̱ñi̱ ni̱tiy jasa̱choda vu̱yaju̱y mo̱sijyu̱ra.  
\v 25 (Ru̱teda ji̱ta siva patru̱, ¡Nutyityu̱, nu̱tyu vu̱yaju̱y mo̱siy criquityi̱numa sani̱cha!)  
\v 26 Ri̱tay jiryiva: Mi̱ni̱tyi tarati̱, ni̱ni̱ ji̱ta ra̱sa̱y ju̱na̱y ranchaju̱ntiy; daryadantyi, mi̱ni̱tyimyu̱ ne tarati̱, simusiñi̱ ji̱ta ra̱so̱vatyanirya jiryatiy simuntidyerya.  
\v 27 Jivye ji̱ta, jiryatiy ramyityasimyiryi, jiryatimyu̱ ne rivya̱ta̱da jintyityu̱ju̱ ray, ¡jirya̱jiryitya̱ jiyuju̱ riy, jirya̱jvamyu̱y radyiya riy!” 
\s1 Jesús jayada nijya̱nvay jiyaro̱vaya̱jadanube Jerusarí̱mu 
\r (Matévu 21.1-11; Márcu 11.1-11; Juán 12.12-19) 
\p  
\v 28 Saniquemu̱yadanumatiy Jesúsra, saya̱da ji̱ta jiyanti̱ Jerusarí̱ na̱cho̱ju̱ variy.  
\v 29-30 Satuudiyadanumatirya Betuváje, Betániya jaryentiy, Odivu musiquituunu vichara, su̱pa̱jada ji̱ta nada yisa̱ datyanu̱jyu̱y: “Sa̱na̱jiya vicha̱dademu, jiryatiy vu̱cha̱ra̱ra. Sa̱na̱numatiy jay ramu, sa̱na̱diñuve jasiy siva cavañudenu puchusi̱, jiryatimyu̱ ne ti̱ jasumiy sancha didye. Sa̱na̱vita̱siñi̱, sa̱na̱jirye variy rumusiñi̱.  
\v 31 Ti̱tiy ra̱jtaja̱nu sa̱da: ¿Ta̱raju̱ra sa̱nuvitani̱, ta̱raju̱? sa̱na̱jmutya̱jasiy variñi̱: Nutyityu̱ va̱tani̱.”  
\v 32 Nadaya̱da ji̱ta su̱pa̱nuju̱y variy, nanudiñuvejada ji̱ta riva, daryatiy su̱teda nadiva.  
\v 33 Nanuvita̱danumatiñi̱ cavañudenu, saja̱nvay jteda variy nadiva: “¿Ta̱raju̱ sa̱nuvitani̱ cavañudenu, ta̱raju̱?”  
\v 34 Nani̱mutya̱jada ji̱ta variryi: “Nutyityu̱ va̱tani̱.”  
\v 35 Nani̱toda ji̱ta Jesúsmuju̱ variñi̱ cavañudenu. Nanujatya̱danumatirya jichujajyuu cavañudenuncha, nanuma̱sadeda ji̱tani̱ Jesús sanchantiy.  
\v 36 Saya̱danumatiy, ribetyityiyada nijya̱nvarya jichujajyuu nú̱va, rivatidye sa̱rupitya cavañuderani̱ Jesús.  
\v 37 Satuudiyadanumatiy Jesúsra Jerusarí̱, Odivu musiqui ju̱u̱jeryamu, rijyo̱ta̱da ji̱ta jchana̱yada sisa̱ datyavajyuu jasiy, riichana̱tya̱dani̱ Ju̱denu variy jiyaro̱vaya̱jadata, ramusiy mityamusiy ti̱tudoda ti̱ta̱ju̱ jiryatiy ridyiñu̱yada riva.  
\v 38 Ru̱teda ji̱ta variy: “¡Jchana̱tyasi̱ ji̱ta si̱tenuni̱ ja̱mu nutyityu̱, ni̱tiy jniy Ju̱denu jtyamu! ¡Samirya vichasa̱da ra̱chasaraté jarichumu, sa̱ma̱ vichasara Jarichumuvichi̱ Ju̱denudamu!”  
\v 39 Varyisévuveda tevay ji̱ta, jiryatiy nijya̱nvay cabyivariy, ru̱teda variy siva Jesús: “¡Datyanu̱, ya̱ndasaniryi yisa̱ datyavay!”  
\v 40 Su̱mutya̱jada ji̱ta Jesús riy: “Ri̱tatye jiryiva, riryityi dasa jivye, riryi sa̱ñe̱ya̱ ravichu̱miy variy.” 
\p  
\v 41 Satuudiyadanumatiy Jesúsra Jerusarí̱, jadchityi sadiñuvejada riva, su̱na̱yada ji̱ta variy rinchiy ranijya̱nvay.  
\v 42 Saniquejada ji̱ta variy: “Rañuma tote jiryedyetyate diyeni̱darya samirya vichata̱cu̱, jiryatiy dutyasaranuma ji̱ta jiryedyetya̱dajisidyerya.  
\v 43 Ra̱day jti̱ ji̱ta rarunda jiryimu, rirya̱numatiy purye jiryemyityasimyi jimyo̱mu jiryechipyatedajisiy, rirya̱ramitya variy jirye, rirye̱jcho̱nu variy jiryentyi.  
\v 44 Rirya̱jatya mucadincha variy jiryentyi, jiryedyedyeñu jarye yisa̱ju̱, ne rirya̱ma̱cho̱taniñi̱ ti̱ ravichu̱ jiryenu ravichu̱ncha, jiryevyicha̱damu. Jirya ti̱ta̱ju̱ ra̱cha ramusiy, jiryatimyu̱ ne jiryedyetyara Ju̱denu jañu̱yada yimu.” 
\s1 Jesús jatya̱dariy ta̱ryu̱tyavay Ju̱denu nijyu̱ jachipiya̱jomusiy 
\r (Matévu 21.12-17; Márcu 11.15-19; Juán 2.13-22) 
\p  
\v 45 Sajañuvejadanumatiy Jesús ravimu Ju̱denunijyu̱ jachipiya̱jo, sajo̱ta̱da ji̱ta jatya̱da rumusiryi ta̱ryu̱tyavay.  
\v 46 Su̱teda ji̱ta variy ruuva: “Nu̱charanuma: 
\q1 Rani̱chasara raryoriy Ju̱denusa̱ tu̱chujoju̱, jirye ji̱ta bay variy paranujoju̱ dárya.” 
\p  
\v 47 Sadatyanunu̱yada ji̱ta ti̱ta̱ju̱ rundamu Ju̱denunijyu̱ jachipiya̱jomu. Caserdótevyeda nutyityu̱miy ji̱ta, Ju̱denu niquejada datyanuvay jarye ruusa̱ju̱, riñi jvedapu̱ryi̱ru̱yada variñi̱ Jesús, nijya̱nvay munatyavay jarye ruusa̱ju̱.  
\v 48 Riryi saryevya̱ tara sayaro̱ju̱, jiryatiy rityuva̱chonumucha nijya̱nvajyuu daryaju̱ rana̱cho̱ saniquejada. 
\c 20  
\s1 ¿Chi̱ jtedamuju̱ sivaayada Jesús, chi̱ jtedamuju̱? 
\r (Matévu 21.23-27; Márcu 11.27-33) 
\p  
\v 1 Tarundamuntiy, sadatyadodanumatiy Jesús Ju̱denunijyu̱ jachipiya̱jomu riy nijya̱nvay, satu̱chodanumatirya samitu̱choda risa̱ju̱, ruuti̱jada ji̱ta caserdótevyeda nutyityu̱miy, Ju̱denu niquejada datyanuvay jarye ruusa̱ju̱, Judíyuveda rimyityumiy jaryentiy.  
\v 2 Ru̱tañuvi̱jada ji̱ta variy siva: “Ya̱tu̱chu nu̱dyiva, ¿nu̱tyura jpa̱jadata yivaacharara yivaayada day, nu̱tyura? ¿chi̱ jtedamuju̱ jiiñi jvaadyerya, chi̱ jtedamuju̱?”  
\v 3-4 Su̱mutya̱jada ji̱ta Jesús riy: “Rajerye ra̱jtaja̱nu jiryentyidye, jirya̱ntya tu̱chu variy rivantidyerya: ¿Tesiy ravicha̱da Juán Bautístabay jtyadoda day, tesiy? ¿varimyata Ju̱denu jtedamusivyirya, nijya̱mi̱ jtedamusiy dyetyara?”  
\v 5 Jadchiy ji̱ta riñiquettasa̱deda riva dayu: “Vurya̱tiy jtay: Ju̱denu jtedamusirya Juánbay jtyadoda, sa̱jtay ji̱ta variy vuryiva day: ¿Daryamuni̱mu̱y ne jiryetyuva̱churu̱yada simu?  
\v 6 Vurya̱tiy jmutya̱ ji̱ta: Nijya̱mi̱ jtedamusirya Juánbay jtyadoda, rirya̱jachiy nijya̱nvay ravichu̱ta riva vu̱y, tapitya rijechipiya̱ daryaju̱ sanijyu̱ Juánbay: Ni̱ni̱ dyetyate Ju̱denuju̱ tu̱chu̱.”  
\v 7 Ru̱mutya̱jada ji̱ta ramusiñi̱ Jesús: “Ne nu̱dyetya tesirya Juán jtyadoda day.”  
\v 8 Su̱teda ji̱ta Jesús variy ruuvantiy: “Dantyamu̱y ne vinu ray ra̱tu̱chuntidyerya nu̱tyura jpa̱jadata rivaacharara rivaayada, nu̱tyura.” 
\s1 Jesús tu̱choda jamirya jvaavyenchiy 
\r (Matévu 21.33-46; Márcu 12.1-12) 
\p  
\v 9 Sajo̱ta̱da ji̱ta tu̱choda nijya̱nvavyara jirya dityadoda tu̱choda variy: “Santa̱da ji̱ta vanura ni̱nsijyu̱u̱ni̱. Satocheda ji̱ta nuta̱da ja̱mi̱ ruumu nijya̱nvarya, riñuma ra̱jvaadyerya, rateratanuma nutasarasiy rirya̱murichenu dañi̱ mucadi ja̱mi̱ day, rateranuma ra̱ma̱cho̱ rijyu̱ varintyidye. Saya̱da ji̱ta variy ta̱rijyu̱ tajijyu̱ day.  
\v 10 Rito̱jadanumatiy ra̱tosa̱da runda, su̱pa̱jada ji̱tani̱ ti̱qui jimyuchechiy ruumu. Su̱tañuvejada ji̱ta muchechiy ruuva: ‘Jirya̱sa̱y rapyatru̱ jiyaru̱rya ni̱nusitye ray.’ Rimyusiye̱yada variy jvaavyeñi̱, ru̱pa̱jada mitya variy yimusiñi̱.  
\v 11 Su̱pa̱jada ji̱ta patru̱ni̱ saryenu muchechintyi, ni̱ jarye rimyusiye̱yada, rirya̱vityiye̱yada risa̱ju̱ni̱, daryaday ru̱pa̱jada mitya yimusintiñi̱.  
\v 12 Sajatyiiyada jpa̱jadani̱ nu̱ntiy. Ni̱ni̱ ji̱ta rivyatajo̱doda, rijetya̱da variy rumusiñi̱.  
\v 13 Sajachipiya̱jada ji̱ta patru̱ variy: ¿Ta̱rana̱te ra̱jvaay diye, ta̱ra? Raryi jpa̱ dyetyani̱ radyenu jaryi va̱tasi̱; temusiy simu dyetya riryityuva̱chu.  
\v 14 Ridyiyadanumatiy jvaavye siva sadenu, riñiquejada ji̱ta variy yiva: Jiñu ji̱ta mucadi ja̱mi̱ denu day. Sa̱numatiy diichara saja̱y, ni̱numa ra̱ma̱cho̱sara raja̱mi̱ju̱ varintyidye. Vurya̱jvañi̱, ra̱tidye ma̱cho̱ samucadi variy vu̱jyu̱.  
\v 15 Rijetya̱da ji̱ta bimuju̱ni̱, ru̱veda variy jasiñi̱, puutyityeni̱. 
\p ¿Nu̱tyura sa̱chaniy mucadi ja̱mi̱ variryi, nu̱tyura?  
\v 16 Sa̱ta̱rya̱ ji̱ta patru̱ variy rumusiy, sa̱paruta variryi jvaavye rapu̱ryamiy. Variñi̱ ji̱ta sa̱sa̱y tavantyidyerya ni̱nsijyu̱u̱ni̱ntidye.” Rityuva̱chodanumatiy nijya̱nvarya satu̱choda, ru̱teda ji̱ta variy: “¡Vuryi̱tedamuju̱ ne ráryichate daryatecu̱!”  
\v 17 Jesús ji̱ta jnu̱yada riñe̱cho̱, saniquejada variy: “¿Ta̱ra rani̱cha jirya day, jiryatiy nu̱chara Ju̱denu niquejadamura: 
\q1 Ravichu̱ ji̱ta jiryatiy rrachusi̱ roriy jvaavyejyu̱ni̱, ni̱numa rañi̱cha ji̱ta roriy suru̱tya̱, jiryenu ravichu̱musiy?\x * \xo 20:17 \xt Murra̱pedye 118.22; Jvaayada 4.11; 1 Pyítru 2.7\x* 
\m  
\v 18 Mi̱ni̱tyi raryijyu̱u̱y jiñu ravichu̱ncha, saryiryotyatimyu̱y variy sanchasiy; jiñu ji̱ta, sanchatiy saryijyu̱u̱y jiñu ravichu̱, saryiñe̱ya vamidideju̱ variñi̱.” 
\p  
\v 19 Riñi jantya̱da ju̱reda Ju̱denu niquejada datyanuvay varidyeñi̱ Jesús day, caserdóte nutyityu̱miy jarye ruusa̱ju̱, riryi ju̱rivya̱ni̱, jiryatiy richuvu̱yada daryaju̱ riy nijya̱nvay. Ridyetya̱da daryaju̱: jiñijyu̱ra sani datyadoda Jesúsra jirya tu̱choda. 
\s1 Criquinchiy, jiryatiy ja̱mu nutyityu̱ murichenutaniy nijya̱nvarya 
\r (Matévu 22.15-22; Márcu 12.13-17) 
\p  
\v 20 Ru̱nu̱choda ji̱ta variñi̱ Jesús, ru̱pa̱jada dutya̱damusiryi nijya̱nvay, jiryatiy ru̱tu̱yadamu vase vichavayu, rirya̱tidye ju̱riy taji niquejadivani̱, rirya̱tidye sa̱y japu jtedamuju̱ni̱.  
\v 21 Ru̱teda ji̱ta variy siva Jesús: “Datyanu̱, nu̱dyetyara jiryatiy jiiñi̱ ji̱ta niquesara samiy, vase jarye jidyetyanusara. Ne yinu̱y jaryi sami̱va̱ju̱ ti̱na̱cho̱, dañuma sani̱cha ti̱. Jidyetyanusara ji̱ta si̱tenura Ju̱denu nú̱.  
\v 22 Nu̱dyetyaru̱y yimusirya: ¿Samiryavidye vurya̱murichenura criquiy, jiryatiy ja̱mu nutyityu̱ Sésar murichenutaniy vuryi̱nu̱yadamusiy?”  
\v 23-24 Sadatya̱da ji̱ta Jesúsra riquivu̱churu̱yada, su̱teda variy ruuva: “Jirya̱dityanu rarya criquidyecyu̱. ¿Chi̱ra sani̱cha criquitya̱sa jantyasi̱ day, chi̱? su̱ro̱ nu̱chara jarye, ¿ta̱ra rani̱cha daryamusidye, ta̱ra?” Ru̱mutya̱jada ji̱ta variñi̱: “Ja̱mu nutyityu̱ Sésar jantyasi̱.”  
\v 25 Su̱teda ji̱ta variy ruuva: “Jirya̱murichenu variñi̱ Sésar jiryatiy sabarya darya, jirya̱murichenuni̱ Ju̱denuntiy jiryatiy sabaryantidyerya.” 
\p  
\v 26 Ne vana̱y rureda nijya̱nvay diya taji niquejadivani̱ Jesús. Rityi̱tta̱da ji̱tara su̱mutya̱jada, rindasa̱da variy. 
\s1 Saadusévuveda jtaja̱dodani̱ Jesús diibyimusiy mi̱sa̱subedanchiy 
\r (Matévu 22.23-33; Márcu 12.18-27) 
\p  
\v 27 Ruuti̱jada ji̱ta Saadusévuveda tevay variy simu Jesús. Ne ridyetyaru̱ñu̱yada rimyi̱sa diibyimiñu̱day.  
\v 28 Ruutaja̱doda ji̱ta variñi̱ Jesús: “Datyanu̱, sanu̱yada Muyusésibe vu̱jyu̱ra niquejada: Ti̱qui nijya̱mi̱tiy ra̱diiy dejsa̱, sataryi̱numa ra̱ja̱mu̱y variñi̱ savatura ma̱cho̱nu, sa̱tidye detuchu jityeryi̱bay jiyadaju̱ni̱.  
\v 29 Rivyichanu̱yada danu̱ju̱ñijyate nu̱ñi taryi̱veda. Saja̱mu̱yada ji̱ta rimyunatyi̱ vaturajsa̱, sadiiyada ji̱ta mitya dejsa̱.  
\v 30 Daryaday savicha̱da sanijyu̱ vichi̱ntiy.  
\v 31 Ni̱numa rañi ja̱mu̱ntyiñi̱, daryaday sadiiyada sisa̱sintyi. Sani ja̱mu̱y nu̱ntiñi̱, sani ja̱mu̱y nu̱ntiñi̱, daryamusiy ridyiiye̱myu̱yada ti̱ta̱ju̱ sisa̱siy nu̱ñi taryi̱veda, pattaryitye riy. Ne ti̱de detuchodani̱ vatura, mitya ti̱ta̱ju̱.  
\v 32 Tamityanuma ji̱ta sadiiyada vaturantidye, puutyityentiñi̱.  
\v 33 Daryamusiy, rirya̱numatiy mi̱sa jidyiijyomusintyi, mi̱ju̱rate sa̱ma̱cho̱ vatura variy, tapi danu̱ju̱ñijyatetya rañi ja̱mu̱yadani̱ vaturanu̱day.”  
\v 34 Su̱teda ji̱ta Jesús variy ruuva: “Jiryunda ja̱nvay ji̱ta rañi ja̱mu̱charayu, rijya̱mu̱tyanicharantiyu.  
\v 35-36 Jivye ji̱ta jiryatiy sabachara Ju̱denu rijyu̱ rirya̱jti̱ satuunuju̱, rirya̱mi̱sa̱sumiy diibyimusiy risa̱ju̱, ne rirya̱ja̱mu̱charayu, dantyamu̱y ne rirya̱ja̱mu̱tyanicharayu, tapitya ne vana̱y rirya̱diiñu̱day, jiryatiy riñi̱cha jidchavu̱ ruusa̱ Ju̱denu jpa̱vay. Riñi̱cha Ju̱denu dadyeñu daryaju̱, jiryatiy mi̱sanichavañuma daryaju̱ daryi.  
\v 37 Muyusésibe jarye dityadodara jiryatiy rimyi̱sasara diibyimiy, sanu̱yadanumatiy jiryunuse tu̱chusa̱danchiy, jasityi su̱teda Ju̱denunchiy: 
\q1 Ni̱ni̱ sani̱cha Ju̱denu Avurá̱bajyu̱, Isácubajyu̱ jarye, Jacóbubajyu̱ jarye nadisa̱ju̱ntiy. 
\m Va̱ diibyimiy riñi̱chacay, jnu̱vyentya riñi̱cha jasidye.  
\v 38 Ni̱ni̱ta diibyimiy Ju̱denu day, nu̱tyu ni̱ni̱ ji̱ta sani̱cha jnu̱vye Ju̱denu, tapi vu̱ñi̱cha jnu̱vye ti̱ta̱ju̱ sáju̱.”  
\v 39 Ru̱mutya̱jada ji̱ta Ju̱denu niquejada datyanuvay tevay variñi̱: “¡Datyanu̱, rántyéra yimutya̱jada!”  
\v 40 Ramuni̱timyu̱ ne ruutaja̱nuru̱yada tara ju̱na̱y jadchiñu̱nñi̱. 
\s1 ¿Chi̱ denu sani̱cha Ju̱denu jaryeti̱ day, chi̱ denu? 
\r (Matévu 22.41-46; Márcu 12.35-37) 
\p  
\v 41 Sitaja̱doda ji̱ta variryi: “¿Nu̱tyu riñi jtay Davyíbe jasi̱ni̱ Crístu, Ju̱denu jaryeti̱, nu̱tyu?  
\v 42-43 Nu̱tyu ni̱day Davyíbe rañi jtay murra̱pedyemyu: 
\q1 Su̱teda ji̱ta Ju̱denu siva rayntyityu̱: Ya̱ma̱sa rayntyityudamyuju̱, jasicha̱ra̱ju̱tiy ra̱vuunutaniryi jimyityasimyi. 
\m  
\v 44 Davyíbeñuma ji̱ta jtay jintyityu̱ntidyeñi̱, ¿nu̱tyichiy sa̱cha variy sa̱si̱, nu̱tyichiy?” 
\s1 Jesús tu̱chuta̱da riy Ju̱denu niquejada datyanuvay 
\r (Matévu 23.1-36; Márcu 12.38-40; Dúcasiy 11.37-54) 
\p  
\v 45-46 Ti̱ta̱ju̱ nijya̱nvay tuva̱chodiva su̱teda variy ruuva yisa̱ datyavay: “Jiryi̱nu̱tyata̱ta Ju̱denu niquejada datyanuvayjisiyu, jiryatiy ru̱canurya vu̱taya̱jada ja̱muca̱jay sujatya, jadchintyi ru̱canurya nijya̱nvay mu̱chuveda pudásamu. Daryaday ru̱canurya samirya ma̱sajoncha ma̱sa̱dantiy, ju̱tye̱ryanijyovimuntiy, vichtya ja̱mi̱tuunu jarye jivyichtyamu.  
\v 47 Rivyiche̱chavañumadayu nu̱ñi riñi so̱vacharara bacheno̱daveda barya, jadchintyi ru̱tu̱yada jityu̱chu jamuca̱ sisa̱ Ju̱denu. Riñi̱ ji̱ta ra̱jmutya̱ jaryirya jijyuuchuveda murichenusa̱da.” 
\c 21  
\s1 Bacheno̱da sa̱yada yentyuyadamusirya jicyuriquiy 
\r (Márcu 12.41-44) 
\p  
\v 1 Su̱nu̱yasubeda ji̱ta Jesús, sadiyada variy ruuva jaryi taratavay, jiryatiy ribeya̱jada criquiy jmutya̱jovimura jiche̱rya.  
\v 2 Sadiyada ji̱ta nadiva jantyuyanu̱y bacheno̱da, nanubañuvi̱jada ji̱tara criquidye dadajyu̱dyeru̱y.  
\v 3 Saniquejada ji̱ta Jesús variy: “Ri̱tay si̱tenu jiryiva: Jiñu̱y jantyuyanu̱y bacheno̱da bayasiy rajuudadyeva̱ju̱ ti̱ta̱ju̱ ruumusiy nijya̱nvay, jiryatiy ribe criquiy jmutya̱jomura.  
\v 4 Tapi ribemya̱ day jiryatiy jaryi taratavadyeryi, nada ji̱ta bay yentyuyadata day, ti̱ta̱ju̱ jiryatiy rani̱cha nadimu yinu̱yadaju̱ day.” 
\s1 Jesús jteda ra̱parutachara Ju̱denu nijyu̱ jachipiya̱jo 
\r (Matévu 24.1-2; Márcu 13.1-2) 
\p  
\v 5-6 Riñiquejada ji̱ta tavay variy ranchiy Ju̱denu nijyu̱ jachipiya̱jo, jiryatiy randanivachara sami̱ ravichu̱ta, ratarya sa̱charata jarye, jiryatiy riche̱ñu̱yada nijya̱nvay Ju̱denu nijyu̱ra. Saniquejada ji̱ta Jesús variy: “Ranchiy ji̱ta jiryatiy jiryedyiñu̱y riva, ra̱jti̱ rarunda varityimyu̱ ne sa̱ma̱cho̱ ti̱ ravichu̱ jiryenu ravichu̱nchanu̱day. Rirya̱jotatimyu̱rya roriy variy, pattaryitye ti̱ta̱ju̱ra.” 
\s1 ¿Nu̱tyuramusiy vurya̱datya rajo̱tanuma mucadi baryi̱jada, nu̱tyuramusiy? 
\r (Matévu 24.3-14; Márcu 13.3-13) 
\p  
\v 7 Ruutaja̱doda ji̱ta variñi̱: “Datyanu̱, ¿nu̱tyeryivye ra̱cha daryá, nu̱tyeryivye? jiryatiy yitesiy darya ra̱cha. ¿Mirya ra̱cha rajo̱tara, mirya? ranchityi vurya̱datya: Diye ni̱day ra̱cha.”  
\v 8 Su̱teda ji̱ta Jesús variy ruuva: “Jiryi̱nu̱tyata̱ta quivu̱chodajisiyu, tapi rirya̱jniy rajuuvay ri̱tyamu, rirya̱jtay variy: ¡Rañi rañi̱cha Crístu, rito̱ma̱ rarunda! Ne jirya̱siityari̱ variryi.  
\v 9 Jirya̱numatiy tuva̱chu ranchiy ju̱veda, nijya̱nvay jatachusa̱da jarye risa̱ju̱, ne jirya̱suvu̱yasumiy variy ranchiy, tapitya daryani̱ ra̱cha munatya. Ra̱viy baryi̱te jiryi̱tay varicha̱ra̱ju̱.”  
\v 10 Jadchiy ji̱ta su̱teda ruuvantiy: “Ra̱numa richatay ju̱veda tavicha̱dajsa̱, rirya̱numa richata tavicha̱da ja̱nvay munu̱ñumirya ju̱veda runda.  
\v 11 Ra̱numa vicha jaryi muco siityeya̱jada tajijyu̱ ti̱ta̱ju̱, jachi̱nu jarye risa̱ju̱ntiy, jdiva̱jada rapu̱rya jarye risa̱ju̱. Ra̱numa vicha suvu̱chara variy, jarichumusiy vatadoda jarye risa̱ju̱.  
\v 12-13 Ra̱jisiy ji̱ta rirya̱ju̱riy nijya̱nvay jirye, rirya̱tidye jarupanta jiryentyi, rirya̱sa̱y variy ju̱tye̱ryanijyo nutyityu̱mimyu jirye, tanuvu̱nujomuju̱ jarye risa̱ju̱. Rirya̱jara̱y ja̱mu nutyityu̱muju̱ jirye, japumuju̱ jarye, jirya̱tidye tu̱chu vijyo̱mujache ri̱tya jiyadaju̱.  
\v 14-15 Jirye̱ntya datya samiy jijechimyu: Ne vurya̱jachipiya̱ ji̱tyaju̱ vuryi̱mutya̱jadajiju̱, tapi ra̱day sa̱y jiryerya niquejada, datya̱da jarye, ratatiy jirya̱jmutya̱ riy, jiryatimyu̱ ne vana̱y rirya̱jachi̱niy jiryemyityasimyi jiryejyu̱yu, dantyamu̱y ne vana̱y rirya̱nique tara.  
\v 16 Rirya̱jti̱ta ji̱ta jiryejye̱vyeda variy tu̱chujomuyu, jiryetyeryi̱veda, jiryetyevay jarye ruusa̱ju̱, jiryejemyicyuveda jarye ra̱jti̱tayu. Rivasiy ji̱ta, japuveda ra̱jvaryi jiryetyevay variy riva.  
\v 17 Jirya̱vichasara javittyuchavay variy ti̱ta̱ju̱ nijya̱nvajyu̱, ri̱tya jiyadaju̱.  
\v 18 Jiryi̱nojasitye ji̱ta, ne ra̱caray ne vinu tajasiquide mitya ti̱ta̱ju̱.  
\v 19 Jiryejechi̱dedata jirya̱ca̱na̱rya jiryi̱nu̱jeya̱jada.” 
\s1 Paru̱tya̱da rundanchiy 
\r (Matévu 24.15-21; Márcu 13.14-23) 
\p  
\v 20 “Jirya̱numatiy diy riva Jerusarí̱ ramitya̱sara su̱tarujuuta, jiryedyetyata̱ta variy: Ratuudiya̱numara rarunda, varityi ra̱ma̱cho̱ javatyasaramusiy vayi.  
\v 21-22 Rityi vichasara Judéyamu variryundamu, riryi bay variy ja̱mu musimyuju̱. Rityi vicha variy vicha̱damu, riryi sipyatay variy jadchiy; rityi vicha varicha̱ra̱ju̱ yindimyu, daryaday, ne riryitye̱rya̱ variy vicha̱damuju̱ntiy, jiryatiy ra̱cha Ju̱denu murichenutadeda runda, varityi sa̱jto̱tanirya ti̱ta̱ju̱ jiryatiy sanu̱tyanirya: Ra̱jti̱ juuchuveda murichenutadeda nijya̱nvamyu.  
\v 23 Ta̱ju̱na̱ ta̱ju̱, rityi mudasiichara variy, daryadantyi rityi ra̱rupatyaniy variryundamuriy jidyedyeñu, tapitya ra̱cha paru̱cha̱riy jirya mucadimu, Ju̱denu nique̱yada daryaju̱ ra̱ju̱u̱y jivye nijya̱nvancha.  
\v 24 Rirya̱batye variy rityevay jichityitya̱ta, rirye̱cha variy ju̱richavay ribyindamiy rajuu, ripya vicha̱daja̱nvay cabyimu. Jerusarí̱ ji̱ta ra̱cha raniye̱chara rijyu̱ jiryatimyu̱ ne Judíyuveda daryi, variryunda sa̱ra̱ju̱tiy ra̱baryi̱ riryunda.” 
\s1 ¿Nu̱tyura ra̱chasara Nijya̱mi̱denu jti̱jada, nu̱tyura? 
\r (Matévu 24.29-31, 42-44; Márcu 13.24-27; Dúcasiy 17.22-37) 
\p  
\v 25 Su̱teda ji̱ta Jesús varintyi: “Variñi̱ ji̱ta ra̱cha vatadoda jiñi̱mu, jarimyuni̱mu jarye, jdarichijyuumu jarye risa̱ju̱; mucadinchantiy rirye̱cha nijya̱nvajyuu paru̱cha̱rimyusiy, jiryatimyu̱ ne ridyetya nu̱tyuramusiy ra̱nsa jaryi ja̱mu na̱va jiye̱rya, nu̱tyuramusiy.  
\v 26 Rirya̱diiy nijya̱nvay mityamusiy taraquideju̱ jichuvu̱yadamu, jiryatimyu̱ ne ridyetyaru̱y nu̱tyura ra̱chasara vu̱jyu̱, nu̱tyura. Tapi ra̱muchutyasara jarichu vanu̱yadayu.  
\v 27 Rirya̱diy nijya̱nvay variy siva Nijya̱mi̱denu, jiryatiy su̱niy rapuryeryadinube, jaryi vanu̱yadata, jaryi vandanube jarye risa̱ju̱.  
\v 28 Ra̱numatiy jo̱ta vicha̱da daryá, jirya̱piradesiy variy na̱vajyu̱, ratuudiya̱numa daryaju̱ra jirye̱ntyutyasa̱da.” 
\s1 Jiivyíryanu datyadoda 
\r (Matévu 24.32-35; Márcu 13.28-31) 
\p  
\v 29-30 Satu̱choda ji̱ta Jesús variy ruuvara niquejada datyadoda: “Jirya̱jnu̱y rana̱cho̱ jiivyíryanu, tara ni̱nu jarye risa̱ju̱: ra̱numatiy dipuvesumiy ravi̱, jirya̱diy variy riva, jirya̱numa datya variy ranchiy: Ravicharu̱ñuma nijya̱ runda.  
\v 31 Daryaday ra̱chantiy, jirya̱numatiy diy riva jiryá, daryatiy ratyu̱chosiy jiryivara, ránchiñi̱dáy jirya̱datya̱siy: Ne ripya nu̱nrya Ju̱denu nusu̱yadanu̱day.  
\v 32 Ri̱tay si̱tenute jiryiva: Ne rirya̱baryi̱ jivye va̱cha vichavay, netimyu̱ ne ra̱jto̱taniy jirya ti̱ta̱ju̱ didye.  
\v 33 Jarichu, mucadi jarye ra̱baryi̱sara risa̱ju̱, rañiquejada ji̱tamu̱y ne ra̱ma̱cho̱sara mitya, ra̱jto̱tanichara ti̱ta̱ju̱yu.” 
\s1 Ne ti̱ datyara nu̱tyeryivye ra̱cha paru̱tya̱da runda, nu̱tyeryivye 
\r (Matévu 24.36-44; Márcu 13.32-37; Dúcasiy 17.26-30) 
\p  
\v 34-35 “Jiryi̱nu̱tyata̱ta nu̱ñi ti̱quimusiyu, jiryeñuma vichasara mitya jiiño̱suma jivyu̱mu cadnavedaco̱siy, niyu̱yadaco̱siy jarye risa̱ju̱, jaryi taranijyu̱ jachipiya̱jada datya̱daco̱siy jarye ti̱ta̱ju̱, ráñuma jti̱ paruteda runda jiryeñiya̱resiy, nu̱tyu ta̱a̱nu̱ jiryimu, tapi ra̱jti̱ rarunda ruumu ti̱ta̱ju̱ mucadincha vichavay.  
\v 36 Jirya̱ma̱ jnu̱jeya̱sara ra̱jiju̱, jirya̱jachiñu̱y Ju̱denuvara vanu̱yadate, ratatiy jirya̱ramityanicharara jirya ti̱ta̱ju̱, jirya̱tidye ranichara Nijya̱mi̱denu tuunu variy.” 
\p  
\v 37 Sadatyanunu̱yada ji̱ta Jesús ti̱ta̱ju̱ rundamu Ju̱denu nijyu̱ jachipiya̱jovimu, vinu nupora ji̱ta sayanu̱yada Odivu musiquinchaju̱ jime̱yadaju̱.  
\v 38 Nijya̱nvajyuu ji̱ta ju̱u̱ryi̱nu̱yada, rirya̱tidye tuva̱chunuvera sadatyadoda. 
\c 22  
\s1 Judíyuveda tu̱chudoda Jesús ju̱redaju̱yu 
\r (Matévu 26.1-5, 14-16; Márcu 14.1-2, 10-11; Juán 11.45-53) 
\p  
\v 1 Ratuudiyada ji̱tara vichtya runda, varityi riimyiñu̱yadara pa̱ suro̱, jiryatiy ru̱tachara Pásco vichtyara.  
\v 2 Rivya̱ta̱da ji̱ta caserdótevyeda nutyityu̱miy, Ju̱denu niquejada datyanuvavyedata rana̱cho̱, nu̱tyuramusiy rirya̱jvatyaniñi̱ Jesús, nu̱tyuramusiy, tapitya richuvu̱ryi nijya̱nvay.  
\v 3 Sajayada ji̱ta Satanásiy variy siva Judásibe, jiryatiy ru̱tachara Iscaryótiy musi̱ni̱. Ni̱ni̱ vichanu̱yada Jesúsjsa̱ datyavay tenu, jiryatiy richiityari̱nu̱yada mityijyiñi̱ Jesús.  
\v 4 Saya̱da ji̱ta jtaja̱dodana̱cho̱ ruusa̱ caserdótevyeda nutyityu̱miy, jiivu̱setavay nutyityu̱miy jarye ruusa̱ju̱: “¿Nu̱tyuramusiy raryiche̱ jiryejyomuju̱ni̱ Jesús, nu̱tyuramusiy?”  
\v 5 Riichana̱yada ji̱ta variy ranchiy, ru̱teda ji̱ta variy siva: “Nu̱ña̱day murichenu criquitya ramurichirya ji.”  
\v 6 Su̱mutya̱jada ji̱ta Judásibe variryi: “Jo, rántyéra.” Sajachipiya̱jada variy jivyimu: “¿Nu̱tyuramusiña̱ raryi sa̱y nutyityu̱vedani̱ Jesús, nu̱tyuramusiy? nijya̱nvajyuu niya̱resiy dyetya.” 
\s1 Jesús jbyedara tamitya jidye jmyi̱sara vatajuu yisa̱ datyavatya 
\r (Matévu 26.17-25; Márcu 14.12-21; Juán 13.21-30) 
\p  
\v 7 Rito̱jada ji̱ta Pa̱ Suro̱ vichtya runda variy. Riryi jvañi̱ carni̱rudenu variy, ratatidye riryi jachipityara Ju̱denu ramityadeda riy jimyunatyavabe.  
\v 8 Su̱pa̱jada ji̱ta Jesús variñada Pyítruju̱be Juánbatya: “Sa̱na̱jdutyara Pásco rundamu jmyi̱sara vu̱jyu̱, vurya̱tidye jmyirya.”  
\v 9 Nani̱teda ji̱ta variy siva: “¿Tera jivya̱ta na̱ña̱jdutyara, te?”  
\v 10 Su̱mutya̱jada Jesús variñada: “Sa̱na̱jnu̱y, sa̱na̱numatiy jañuve ja̱mu vicha̱damu sa̱na̱jdcho̱niñi̱ vanu, javiñu nichu̱. Sa̱na̱siityari̱ jasiy rorivyimuju̱ variñi̱, jasityi sa̱jañuve sa̱nudiya.  
\v 11 Sa̱na̱jtesiy siva rorijya̱mi̱: Su̱tesiy Datyanu̱ jiñijyu̱: ¿Nu̱tyijiña̱ rani̱cha rorichichumarya, nu̱tyijiy? jasityi ra̱jmyicha Pásco vichtya rundamu jmyi̱sarayu, risa̱ datyavavyedata.  
\v 12 Ni̱ni̱ ji̱ta ra̱dityanu variy sa̱dara rorichichuma samiy jdutyasara, na̱varyoriy. Jasiñi̱day sa̱na̱jdutya̱siy nu̱ña̱jiju̱ra jmyichara.”  
\v 13 Nadaya̱da ji̱ta variy, darya ni̱day nanudiñuvejada ti̱ta̱ju̱ riva, nu̱tyu su̱teda Jesús darya nadiva. Nani̱dutya̱da ji̱tara Pásco rundamu jmyi̱sara variy jasiy. 
\s1 Sadatyadoda Jesús riy: “Pa̱ ravyu̱, bínuja̱ ji̱ta rayndaja̱day” 
\r (Matévu 26.26-30; Márcu 14.22-26; 1 Coríntyu 11.23-26) 
\p  
\v 14 Jdutyasaranumatiy ravicha̱da jmyichara, sata̱ñuvejada ji̱ta Jesús variy jmyijyomu, sisa̱ datyavay jarye yisa̱ju̱.  
\v 15-16 Su̱teda Ji̱ta Jesús variy ruuva yisa̱ datyavay: “Jaryi rañi̱ru̱yadamu ri̱myiryu̱rya jirya Páscomu jmyi̱sara jiryisa̱, ra̱vatyasa̱da rundajisiy, tapi ri̱tatye jiryiva: Ne ra̱jmyiñu̱darya Páscomu jmyi̱saranu̱day, jasicha̱ra̱ju̱tiy ra̱jto̱taniy Ju̱denu nusu̱jyomura.”  
\v 17-18 Saryeda ji̱ta Jesúsra jatuvu̱ variy, si̱chana̱tya̱danumatiñi̱ Ju̱denu ranchiy, su̱teda variy ruuva: “Jiryatirya, jirya̱jatutaniy ti̱ta̱ju̱ ramuyu, ri̱tay daryaju̱ jiryiva: Ne ra̱jatunu̱darya nutasara nuri̱ju̱u̱sijya̱ nu̱day, jasicha̱ra̱ju̱tiy ra̱jti̱ Ju̱denu nusu̱yada.”  
\v 19 Saryeda ji̱ta Jesús varirya pa̱, si̱chana̱tya̱danumatiñi̱ Ju̱denu ranchiy, sapata̱da ji̱ta varirya, sasa̱yada ji̱ta variryi. Saniquejada variy: “Rani̱ jirya ravyu̱, jiryatiy rache̱y jiryeyadaju̱ra. Jirye̱ntya jmyichara daryara, jirya̱tidye jachipityasara riva ray.”  
\v 20 Daryamusidye saryeda jibyedivasirya jatuvu̱ntiy, saniquejada ji̱ta variy: “Jirya jatuvu̱ rañi̱cha vadi jnu̱tya̱, jiryatiy rayndaja̱musirya, jiryatiy rumicharanuma jiryeyadaju̱ra.  
\v 21 Jirya̱jnu̱y, ravichanuma mi̱sancha rajyomutujsa̱, sajomutu ni̱tiy sa̱y ramyityasimyimyu ray.  
\v 22 Sa̱jyasara ji̱ta Nijya̱mi̱denu jiyusiy, darya bacharatiy saju̱ra. Jiii, ta̱ju̱na̱te darya, ta̱ju̱, chi̱na̱ sa̱yasitye ni̱ Nijya̱mi̱denute day, chi̱.”  
\v 23 Rijyo̱ta̱da ji̱ta jtaja̱doda nu̱ñi danu̱ju̱myusiy variyu: “¿Mi̱ra vu̱tyenu ra̱sa̱ñi̱ Jesús jimyityasimyimyu, mi̱?” 
\s1 Ni̱tiy vicharu̱y jaryiñu̱, saryi vichasara nu̱tyu muchechiy 
\p  
\v 24 Jadchiy ji̱ta riñiquetta̱dantiyu: “¿Mi̱ra vu̱tyenu ra̱cha jaryetasi̱ vu̱ntyityu̱ju̱, mi̱?”  
\v 25 Su̱teda ji̱ta Jesús variy ruuva: “Rinsu̱chara ji̱ta ja̱mu nutyityu̱veda riy nijya̱nvajyuu. Ru̱tachara ji̱ta samiy jvaavye variryi, rityi sabonichara riy nijya̱nvajyuu.  
\v 26 Jiryequebyimu ji̱tamu̱y ne ra̱chasara daryá; daryani̱ ji̱ta raryicha̱siy, jiryatiy sa̱cha nu̱tyu tamityi̱ jiryequebyimu ni̱tiy vichasara jaryiñu̱; jiryentyityu̱ ji̱ta ra̱cha nu̱tyu jiryemyuchechiy.  
\v 27 ¿Mi̱rana̱ jaryiñu̱, mi̱? varimyata jmyijyomu ma̱si̱, varimyata samuchechiy. ¿Ne viy jaryiñu̱nu̱day ni̱tiy ma̱sa jmyijyomu? Ray ji̱ta vichasara jiryequebyimu nu̱tyu jiryemyuchechidye. 
\p  
\v 28 Jirye ji̱ta ma̱cho̱jaya̱sara rapyaru̱tya̱danube risa̱.  
\v 29-30 Ray ji̱ta bay jiryejyu̱ra nusu̱jyo, nu̱tyu sabayada rajye̱ darya rajyu̱ntidyerya, jirya̱tidye jmyichara, jirya̱jatusara variy risa̱ju̱ ri̱myijyomu, raynsu̱jyomu jarye. Jirya̱ma̱sasara variy cadnadu ma̱sajonchantiy, jasityi jirya̱jdutyasarara rityu̱chutasa̱da Irayénuveda, jiryatiy taraqui vu̱yaju̱y nijya̱nvaryi, danu̱ju̱y rinchaju̱, jiryatiy jaryedo ju̱riiñutavaryi.” 
\s1 Jesús tu̱chudoda ji̱tyaju̱ni̱ Pyítrubay: “Ya̱ra̱yasiy rayada” 
\r (Matévu 26.31-35; Márcu 14.27-31; Juán 13.36-38) 
\p  
\v 31 “Siimyó̱, Siimyó̱, ya̱jnu̱y Satanásiy jachiñu̱yasiy Ju̱denuva jirye, sa̱tidye jantya nu̱tyu jaruusiy muchutyasara jirye, si̱tenu rachiityari̱vay vidye jiryeñi̱cha.  
\v 32 Ray ji̱ta tu̱chosiy sisa̱ Ju̱denu jiyadaju̱, Siimyó̱, ráñuma su̱tye jityuva̱choda rimu. Ya̱numatiy janumitye rañe̱cho̱ntiy, ya̱ma̱ vanu̱tyaniryi jityevay varintyidye.”  
\v 33 Su̱teda ji̱ta Siimyó̱bay variy siva Jesús: “Nutyityu̱, jdutyasi̱numa ray, ra̱tidye jiya tanuvu̱nujomuju̱ yisa̱, varimyata diiyadasa̱ra̱ju̱ ti̱ta̱ju̱.”  
\v 34 Su̱teda ji̱ta Jesús variy siva: “Ri̱tatye yiva Pyítru, diye, netimyu̱ ne sa̱suy tavaryi didye, ya̱ra̱yasiy mumuri̱ju̱ rayada. Ya̱jtesiy variy: Ne radyetyani̱.” 
\s1 Ratuudiya̱numa Ju̱denu jantya̱da runda 
\p  
\v 35 Jadchiy ji̱ta su̱teda Jesús ruuva yisa̱ datyavay: “Ri̱pa̱jadanumatiy raynsu̱yadata criquisa̱miy jirye, ne vinu dusuutyavay, dantyamu̱y ne saapatu, ¿rásu̱tyeda vidye tara jiryejyu̱ variy?” Ru̱mutya̱jada ji̱ta: “Ne, mitya.”  
\v 36 Su̱teda Jesús variy ruuva: “Diye ji̱ta, ni̱tiy criquityi̱, sa̱ma̱ jtosirya; daryadantyi, ni̱tiy dusuutyi̱, sa̱ma̱ jtosiy varintyidyerya. Mi̱nintyimyu̱ ne jichityitya̱ ti̱, sa̱ma̱ ta̱ryu̱tyara jichujay, sa̱tidye ta̱ryu̱y ramurichiryatara muruta̱ jichityitya̱ju̱.  
\v 37 Tapi ri̱tay jiryiva: Ra̱day jto̱taniy rimura jirya niquejada nu̱chara: Rivyichadeda nu̱tyu jvi̱ nta variñi̱, tapi jiryatiy nu̱chara raynchirya, ra̱day jto̱tanimyu̱y ti̱ta̱ju̱ra.”  
\v 38 Ru̱teda ji̱ta sisa̱ datyavay variy yiva: “Nutyityu̱, jiryatirya dadajyu̱y muruta̱ jichityitya̱.” Su̱teda variy ruuva: “Rasa̱ra̱numa.” 
\s1 Jesús tu̱choda sisa̱ jijye̱ Jetsemaní̱mu 
\r (Matévu 26.36-46; Márcu 14.32-42) 
\p  
\v 39 Sasipyateda ji̱ta variy jadchiy, saya̱da ji̱ta daryatiy saju̱tyadoda Odivu musiquimuyu. Richiityari̱jada ji̱ta sisa̱ datyavay variy rumuntiyu.  
\v 40 Sito̱jadanumatiy vichajomu, jasityi sito̱ru̱yada, su̱tañuvejada ji̱ta ruuva: “Jirya̱numa tu̱chu sisa̱ Ju̱denu, jirya̱tidye jto̱ su̱mu̱tya̱data jiryimu jantyasa̱damu.”  
\v 41 Sanumuteda ji̱ta variy nu̱jipyudeju̱ rirya̱jisiy, sa̱dasidyoda ji̱ta variy jasiyu, satu̱choda variy sisa̱ Ju̱denu.  
\v 42 Saniquejada variy: “Ye̱ye̱, jivya̱tatiy, ya̱ramityaniy rivara jirya paru̱tyasa̱da; dañumamu̱y ne ye̱chaniy daryá, daryatiy ravya̱ta yivara, daryani̱ ji̱ta ye̱chanidyerye, daryatiy jivya̱ta dacyu̱.” 
\p  
\v 43 Samu̱ti̱jada ji̱ta ti̱qui Ju̱denu jpa̱nu jarichumusiy simu Jesús, savanu̱tyadeda ji̱ta variy jasiñi̱.  
\v 44 Jiryatiy saparu̱tya̱da jaryi jijechimyuyu, satu̱choda jaryivya̱ju̱ sisa̱ Ju̱denu variy. Saja̱ta̱yada ji̱ta variy, rasuteda saja̱ta̱ya̱ nu̱tyu nudaja̱ yivasiy mucadincha variy.  
\v 45 Sanubesubedanumatiy joráyadivasiy, sata̱rya̱jada ji̱ta yisa̱ datyavamyuju̱ntiy, sadiñuvi̱jada ma̱vye variy ruuva, riñuvayadanube jime̱.  
\v 46 Su̱teda Jesús variy ruuva: “¿Ta̱ju̱na̱ jiryeme̱, ta̱ju̱? ¡Jirya̱nubesumiy, jirya̱tu̱chu sisa̱ Ju̱denu, jirya̱tidye ramijeryi̱ su̱mu̱tya̱data jiryimu jantyasa̱damu!” 
\s1 Ruredani̱ Jesús 
\r (Matévu 26.47-56; Márcu 14.43-50; Juán 18.1-12) 
\p  
\v 47 Jesús niquejadamu ji̱ta ruuto̱jada nijya̱nvajyuu. Riyanti̱ ji̱ta savicha̱da Judásiy jtyati̱bay, Jesúsjsa̱ datyavay tenu. Satuudiyada ji̱ta Judásibe variñi̱ Jesús, sa̱tidye siiñuva̱y jasiñi̱.  
\v 48 Su̱teda ji̱ta Jesús variy siva: “Judásiy, ¿siiñuva̱yadatate jiche̱ñi̱ Nijya̱mi̱denu jimyityasimyimyutecu̱?”  
\v 49 Ridyiyadanumatiy Jesúsjsa̱ vichavay riva nu̱tyura ra̱cha, nu̱tyura, ru̱teda variy siva: “Nutyityu̱, ¿vurya̱vidye jvatye jichityitya̱ta riy, vurya̱?”  
\v 50 Savatajo̱doda ji̱ta ti̱qui rityenu variñi̱ caserdótevyeda nutyityu̱ muchechiy, jiryatiy sara̱cha̱da daryaju̱ra satuva̱y.  
\v 51 Jesús ji̱ta niquejada variy: “¡Ra̱cha̱miy!” Saja̱tyo̱jada ji̱ta variy muchechiy tuva̱cco̱mu, sami̱sadeda variy ratani̱.  
\v 52 Su̱teda ji̱ta variy ruuva caserdótevyeda nutyityu̱miy, jiivu̱setavay nutyityu̱miy jarye ruusa̱ju̱, rimyityumiy jaryentiy: “¿Nu̱tyichiy jiryemya̱siñu̱y rayaro̱ju̱ jichityitya̱ta, nu̱tyichiy? ju̱mu̱tya jarye, nu̱tyu paranu̱ni̱ nta ravyicha variy jiryejyu̱.  
\v 53 Rañi̱chanu̱chityi Ju̱denu nijyu̱ jachipiya̱jomu jiryisa̱, tama̱ jiryiriñu̱chiy variy jasirye, tama̱. Rito̱ma̱ ji̱ta jiryeryunda, nupocudi jtacha̱da jarye risa̱ju̱.” 
\s1 Pyítrubay ra̱yada Jesús jiyadaju̱ 
\r (Matévu 26.57-58, 69-75; Márcu 14.53-54, 66-72; Juán 18.12-18, 25-27) 
\p  
\v 54 Ruurityadeda ji̱ta variñi̱ Jesús, ruuto̱ta̱da ji̱ta caserdótevyeda ja̱mu nutyityu̱ rorimyuni̱. Pyítrubay ji̱ta siityari̱jada nu̱jipyudeju̱ variryi.  
\v 55 Ru̱quinchodanumatirya jiiday vatapadajache, rimya̱sasa̱deda variy jasiy ratuunu, Pyítrubay jarye ruusa̱.  
\v 56 Sadiyada ji̱ta muchechityu siva Pyítrubay, sama̱sa̱da jiidadyamu, su̱nu̱yadanumatiy samiy sana̱cho̱, saniquejada variy: “Jiñu vanu jarye vichasara sisa̱ Jesús.”  
\v 57 Sara̱yada ji̱ta Pyítrubay variy sayada: “Vatura, ne radyetya dañi̱ Jesús day.”  
\v 58 Rivasidye ji̱ta sadiyada nu̱ sivantiy, su̱teda ji̱ta siva: “¿Jiñi̱ta vichasara rityenuntiy?” Su̱mutya̱jada ji̱ta Pyítrubay variñi̱: “¡Vanu, ne radye!”  
\v 59 Taraqui jóramusintyi, saniquejada ji̱ta nu̱ jaryivya̱ju̱: “¡Si̱tenu savichasara jiñu vanu sisa̱ Jesús, tapi ni̱ vitya Cadidéyamusi̱!”  
\v 60 Saniquejada ji̱ta Pyítrubay variy: “¡Vanu, ne radyetya ta̱ranchiy jiñique, ta̱ranchiy!” Saniquejadasa̱ra̱ju̱ sasuyada tavaryi variy jasiy.  
\v 61 Sa̱numityejada ji̱ta nutyityu̱ Jesús variy, su̱nu̱yada sana̱cho̱ Pyítrubay. Sajachipitya̱da ji̱ta Pyítrubay varirya saniquejada, jiryatiy su̱tesiy riva: “Tavaryi suyadajisiy diye, ya̱ra̱y mumuri̱ju̱ rayada.”  
\v 62 Sasipyateda ji̱ta Pyítrubay variy, su̱na̱yada jivyara jachipiya̱jadamu variy. 
\s1 Rirya̱rupanta̱da jidyetyi̱sa̱damuni̱ Jesús 
\r (Matévu 26.67-68; Márcu 14.65) 
\p  
\v 63 Jadchiy ji̱ta, jiryatiy vaduy rañi jnu̱chuni̱ Jesús, rirya̱rupanta̱da jvatyiyada yavatya̱damuni̱.  
\v 64 Ripyuryejada ji̱tantirya sani̱sintyi, ruutaja̱doda variñi̱: “¡Ya̱datyacu̱! ¿Chi̱ra ju̱vesiy jiñiy, chi̱?”  
\v 65 Riñiquejada ji̱tara va̱cha niquejada yavityiye̱yadamu sanijyu̱ntiy. 
\s1 Ripyu̱cheda nutyityu̱miy rimyityumimyuju̱ni̱ Jesús 
\r (Matévu 26.59-66; Márcu 14.55-64; Juán 18.19-24) 
\p  
\v 66-67 Ra̱sacharamu ji̱ta, riintye̱ryadeda nijya̱nvay rimyityumiyu. Rivyicha̱da ji̱ta caserdótevyeda nutyityu̱miy, Ju̱denu niquejada datyanuvay jarye ruusa̱ju̱ jasiy. Ripyu̱cheda ji̱ta variñi̱ Jesús jityu̱chujomuju̱. Riñiquejada ji̱ta variy: “Jiityi rañi̱cha Ju̱denu jaryeti̱, ya̱tu̱chu nu̱dyivaracu̱.” Su̱teda ji̱ta Jesús variy ruuva: “Raryityi tu̱chu jiryivara, ne jiryetyuva̱chu variy rimu.  
\v 68 Raryityi jtaja̱nu darya jiryentyidye, jirya̱vidye jmutya̱ varintyidyerye.  
\v 69 Diyemusiy ji̱ta, sa̱ma̱sajaya̱sara Nijya̱mi̱denu santyityudamyu Ju̱denu jaryi vanu̱rya.”  
\v 70 Ru̱tacha̱deda ji̱ta variy siva: “¿Jiñi̱ta si̱tenu Ju̱denu denu day?” Su̱mutya̱jada ji̱ta variryi: “Jiryetyi jtay daryadaryecyu̱.”  
\v 71 Riñiquejada ji̱ta variy: “¿Ta̱ju̱ra vu̱vya̱ta riy tu̱chuvay sanijyu̱nu̱day, ta̱ju̱? ¡Vu̱ñi tuva̱chuma̱ra su̱tosiy niquejada!” 
\c 23  
\s1 Ripyu̱cheda japu Pyidátubamyuju̱ni̱ Jesús 
\r (Matévu 27.1-2, 11-14; Márcu 15.1-5; Juán 18.28-38) 
\p  
\v 1 Jadchiy ji̱ta, riñubesumimyu̱yada nutyityu̱miy ti̱ta̱ju̱ variy, ripyu̱cheda japu Pyidátubamyuju̱ variñi̱.  
\v 2 Rijyo̱ta̱da ji̱ta tu̱chuta̱da variy jasiñi̱: “Nu̱charyeñi̱ jiñu vanu, jiryatiy sa̱tachunu̱ryi nu̱tyevay, jiryatiy su̱bay daryaju̱ nu̱ña̱jisirya criquitya murichedodara jiryatiy ja̱mu nutyityu̱ Sésar jiyaru̱rya rani̱cha, su̱tañu̱y variy: Rañi ji̱ta Ju̱denu jaryeti̱ ja̱mu nutyityu̱ju̱.”  
\v 3 Sitaja̱doda ji̱ta Pyidátubay variñi̱ Jesús: “¿Jiñi̱ta Judíyuveda ja̱mu nutyityu̱?” Su̱mutya̱jada ji̱tani̱: “Jityi jtay daryadacyu̱.”  
\v 4 Su̱teda ji̱ta Pyidátubay variy ruuva caserdótevyeda nutyityu̱miy, nijya̱nvajyuuva jarye: “Tama̱ sani̱cha jiñu vanu tara nta rajyu̱ day, tama̱.”  
\v 5 Ju̱na̱y rityu̱chuta̱numucha varidyeñi̱ Jesús day: “Nu̱tyu ni̱ni̱day rañi jatachunumaya̱ jidyetyadodata riy nijya̱nvay Judéya vicha̱diva ti̱ta̱ju̱ day. Sajo̱ta̱da datyadoda Cadidéya vicha̱diva, jiyusa̱ra̱ju̱ ti̱ta̱ju̱.” 
\s1 Japu Pyidátubay jpa̱jada Jeródesbemyuju̱ni̱ Jesús 
\p  
\v 6 Satuva̱chodanumatiy Pyidátubarya, sitaja̱doda ji̱ta riy: “¿Ni̱ni̱ta sani̱cha Cadidéyamusi̱ day?”  
\v 7 Sadatya̱danumatiy Pyidátubay, Jeródesbe nusu̱jyomusi̱ni̱ Jesús, su̱pa̱jada variy Jeródesbemyuju̱ni̱, jiryatiy Jeródesbe jarye vichanu̱yada variryundamu Jerusarí̱muntiy.  
\v 8 Sadiyadanumatiy Jeródesbe siva Jesús, si̱chana̱yada ji̱ta variy samo̱musiy, tapi ne diyetya sani diryu̱ñu̱yada sivanu̱day. Satuva̱chunu̱yada daryaju̱ va̱cha sanchiy Jesús, ramuni̱tiy sani diryu̱ñu̱yada riva tara mityamusiy ju̱dejada simusiy.  
\v 9 Sitaja̱doda ji̱ta variy rajuurani̱ Jesús, saryi jmutya̱va̱ tara jasiñi̱, tii, mitya.  
\v 10 Ju̱na̱y richiityari̱jada tu̱chuta̱da caserdótevyedani̱ Jesús varidye. Ju̱denu niquejada datyanuvatya rityu̱chutanu̱yada jaryi niquejadatani̱.  
\v 11 Sa̱vityiye̱yada ji̱ta Jeródesbe jichu̱taruvedata yarupanta̱damu variñi̱ Jesúsntiy. Jadchiy ji̱ta, sani jachutadeda Jeródesbe vandajay siva Jesús, su̱pa̱jada ji̱ta Pyidátubamyuju̱ rivasintyiñi̱.  
\v 12 Nanujamyicyuveda ji̱ta Jeródesbejyu̱y Pyidátubatya variryundamuyu, tapitya ra̱jisiy nani mityasiiñu̱yadayu. 
\s1 Pyidátubay sa̱yada crusitya̱sa jvatyadedaju̱ni̱ Jesús 
\r (Matévu 27.15-26; Márcu 15.6-15; Juán 18.39–19.16) 
\p  
\v 13 Pyidátubay ji̱ta ju̱tye̱ryanityadedantiryi caserdótevyeda nutyityu̱mintyi, nijya̱nvay nutyityu̱miy jarye, nijya̱nvay jarye ti̱ta̱ju̱.  
\v 14 Su̱teda ji̱ta variy ruuva: “Jiryeñi pu̱chesiy rumusiy rimuju̱ni̱ jiñu vanu nu̱tyu nijya̱nvay jatachú̱ nta sani̱cha variy. Nu̱tyu rañi jtaja̱numa̱ samiy jiryetyuununi̱, tama̱ rañi jnu̱y tara ntani̱ jiñu vanu, tama̱, ta̱rivara jiryeñi tu̱chutani̱, ta̱riva.  
\v 15 Dantyamu̱y ne sadiyasiy Jeródes tariva, ramuni̱ su̱pa̱jasiy ju̱na̱y rimuntiñi̱. Tama̱ sani̱cha tara, tama̱, ta̱rivara nu̱ña̱tanuvu̱nutaniy diiyadasa̱ra̱ju̱ni̱, ta̱riva.  
\v 16 Ramuni̱tiy ra̱jmu̱rya musiye̱yadivasiñi̱.”  
\v 17 Saju̱tyasaranuma jmu̱rya̱da Pyidátubay, nijya̱nvay jiyadaju̱ni̱ ti̱qui tanuvu̱nusi̱, vichtya rundamu day.  
\v 18 Riñi sa̱ñe̱ya̱jada ji̱ta jidchavu̱ variy sanijyu̱ Pyidátubay: “Ya̱parutani̱ jiñu Jesús, ya̱jmu̱rya nu̱jyu̱ni̱ Barába.”  
\v 19 Barábabay vichanu̱yada tanuvu̱nusi̱, jiryatiy sajo̱ta̱da siryi̱jada ja̱mu vicha̱dajache, jityevayjiju̱, ma̱myi nusu̱yada jidcho̱ju̱, jasityi ru̱vedani̱ nijya̱mi̱ntiy.  
\v 20 Ju̱na̱y saniquejasubeda Pyidátubay nijya̱nvañijyu̱ varidye, jiryatiy sani jmu̱ryaru̱yadani̱ Jesús.  
\v 21 Riche̱ñe̱ya̱jasubeda ji̱ta variy sanijyu̱ Pyidátubay: “¡Crusimyuju̱, ya̱ni jvay crusitya̱sani̱!”  
\v 22 Mumuri̱ju̱ su̱teda Pyidátubay ruuva: “¿Ta̱raju̱ra? ¿Ta̱ra sivaay nicyara̱y, ta̱ra? Tama̱ rañi jnu̱y savicha nta tara, tama̱, ta̱rivara ra̱tanuvu̱nu diiyadasa̱ra̱ju̱ni̱. Ramuni̱tiy ra̱jmu̱rya musiye̱yadivasiñi̱.”  
\v 23 Riyasanta̱numucha ja̱mu niquejadatani̱ Pyidátubay, sa̱tidye jvatyaniy crusitya̱sani̱ Jesús. Rivyuudoda ji̱ta jiche̱ñe̱ya̱jadata variñi̱ Pyidátubay.  
\v 24 Jadchiy ji̱ta, su̱teda Pyidátubay ruuva su̱tarumiy, rirya̱ma̱ vichaniy daryani̱, daryatiy rivyichaniryu̱dyeñi̱.  
\v 25 Su̱mu̱rya̱da ji̱ta rijechiñu̱yadiva jijyu̱ variñi̱ Barábabay, jiryatiy tanuvu̱nusi̱ni̱, jiryatiy sasiryi̱tadeda ma̱y nusu̱yada jiyaro̱ju̱ riy nijya̱nvay, su̱vedani̱ nijya̱mi̱ variy risa̱ju̱. Jesús ji̱ta sasa̱yada rajuura rivyichadedaju̱. 
\s1 Ru̱veda crusitya̱sani̱ Jesús 
\r (Matévu 27.32-44; Márcu 15.21-32; Juán 19.17-27) 
\p  
\v 26 Rirya̱ra̱chedanumatiñi̱ Jesús, rureda variy jasiñi̱ ti̱qui vanu, ni̱tiy rañi ramiryi̱jada variy yindimyusiy. Ni̱ni̱ vicha̱da Sirénemusi̱, jiryatiy Siimyó̱ jtyati̱bañi̱. Ribeyada ji̱tara crusiy variy sancha, sa̱tidye nichu Jesús ju̱sirya. 
\p  
\v 27 Richiityari̱jada ji̱ta nijya̱nvajyuu variñi̱ Jesús, vatuy jarye, jiryatiy richutyanityityi nu̱tyu diibyi jnu̱tya̱damu, ru̱na̱cha̱deda risa̱ju̱ sivasiy.  
\v 28-29 Sa̱numityejadanumatiy Jesús riñe̱cho̱ju̱, su̱teda ji̱ta variy ruuva: “Vatuy, Jerusarí̱ ja̱nvay, ne jirya̱jna̱y rivasiy. Jirya̱ma̱ ju̱na̱y yivasidye, jiryedyedyeñuvasiy jarye risa̱ju̱, tapi jiryi̱nu̱y, ra̱jti̱ rarunda varityi rirya̱jtay: Jchana̱tyasavaryi vatuy suru̱vye, jiryatimyu̱ ne riryupachusara ti̱ jivyimusiy, dantyamu̱y ne riryupatyanichara ti̱ yitya̱niy.  
\v 30 Rirya̱jo̱ta jteda variy riva musiqui: ¡Ya̱ju̱u̱y nu̱ncha, ya̱jmuchunu̱y quiii!  
\v 31 Tapi riryityi jvaay daryá jatyápuuta (jiryatiy vuryi̱tay va̱cha jvaayada jo̱taranchiy daryá), nu̱tyuramuna̱ raryicha vassaputantiy (jasityi ra̱suduchara juuchuveda).” 
\p  
\v 32 Rirya̱ra̱cheda ji̱ta nada danu̱ju̱y jvi̱ju̱ntyi, rirya̱tidye jvay variy Jesúsjsa̱ju̱ nada.  
\v 33 Ruuto̱jadanumatiy vichajomu, jiryatiy ru̱tachara: Nijya̱mi̱ Jno̱siirya, ru̱veda ji̱ta yivamyurota crusitya̱sani̱ Jesús variy jasiy, danu̱ju̱y jvi̱ju̱y sisa̱ju̱ntiy, ti̱qui santyityudamyuju̱, nu̱ntiy samidámyuju̱.  
\v 34 Saniquejada ji̱ta Jesús variy: “Ye̱ye̱, ya̱ramityaniy ruuvara jijyuuchuveda, riryidyetyava̱ daryaju̱ cay: ta̱ra nu̱dyivaay.” 
\p Jasiñi̱ ji̱ta riñantaja̱jada su̱tarumiy yivara Jesús sujay, jiryatiy rityiyi̱sa̱damusiy jicya̱na̱yadara.  
\v 35 Nijya̱nvajyuu radeda variy jasiy, ru̱nu̱yada ji̱ta variy jadchiy. Rirya̱vityiye̱yada ji̱ta nijya̱nvay nutyityu̱miy jasiñi̱ Jesús: “¡Nu̱tyu sa̱ntyuyada ruuva tavantyidye, sa̱ma̱ jantyuy darya yivantidye, si̱tenutiy sajaryeta̱da Ju̱denu vuryeyadaju̱ ra̱yasi̱ju̱ni̱!” 
\p  
\v 36 Su̱tarumiy jarye jarupanta̱dani̱, jiryatiy ru̱ntatyanuvejadara bínuja̱ jivyaja̱a̱ siva.  
\v 37 Riñi jteda variy siva: “¡Judíyuveda nutyityu̱tiy si̱tenu ji, ya̱ma̱ ramityaniy yivara!” 
\p  
\v 38 Ravicha̱da ji̱ta nu̱chara si̱nyuju̱, ranique jasiy ramu: “Jiñu ji̱ta Judíyuveda ja̱mu nutyityu̱.” 
\s1 Ti̱qui jvi̱ tuva̱choda simu Jesús crusitya̱sasiy 
\p  
\v 39 Ti̱qui jvi̱ tenu ji̱ta jasiy so̱ti̱, rañi javityiye̱yada variñi̱ Jesús: “¿Neviy Ju̱denu jaryeti̱ ji? ¡Ya̱jantyuy yiva! ¡Na̱dyiva jarye ya̱jantyuy yisa̱ju̱!”  
\v 40 Su̱mutya̱jada ji̱ta satenu nique̱yadamu varintyidyeyu: “¿Ne jichuvu̱dyeñi̱ Ju̱denu day? ¿Neviy yinu̱y diiyadaju̱ bachi̱ jiyuntiy ji?  
\v 41 Vu̱y ji̱ta jmutya̱ra vuryi̱veda murichirya; jiñu ji̱tamu̱y ne rañi jvaachara tara, mitya.”  
\v 42 Su̱teda ji̱ta variy siva Jesús: “¡Ya̱jachipityaja̱ ray, ya̱numatiy ju̱to̱ yinsu̱jyomu, Jesús!”  
\v 43 Su̱mutya̱jada ji̱ta Jesús variñi̱: “Ri̱tay si̱tenu yiva: Diyerundamu ji̱ta ye̱cha Parayísumu risa̱, jasityi rivyichajaya̱sara Ju̱denu jaryetavay.” 
\s1 Jesús diiyadanchiy: nu̱tyura ravicha Jesús diiyada rundamu, nu̱tyura 
\r (Matévu 27.45-56; Márcu 15.33-41; Juán 19.28-30) 
\p  
\v 44-45 Nu̱tyu vase jiñi̱ta rani̱cha̱da variy, ri̱ñupuyada ji̱ta variy mucadiva ti̱ta̱ju̱, ni̱nutijcha vichi̱tasa̱ra̱ju̱ ri̱ñupuyada, jiryatiy sanupocudiveda jiñi̱ variy. Raseteda ji̱ta Ju̱denu rorivyimu mutanujay jache varintyi, ¡siyooo!\x * \xo 23:44-45 \xt Ebrévuveda 9.3-15; 10.19\x* 
\v 46 Jadchiy ji̱ta, saniquejada Jesús jaryi niquejadamu: “¡Ye̱ye̱, jijyomuju̱ rabecharani̱ ri̱ntu!” Saniquejadanumatiy darya, satiijeya̱cheda variy tamityayu. 
\p  
\v 47 Sadiyadanumatiy su̱tarumiy nutyityu̱ riva darya vichadeda, si̱chana̱tya̱da variñi̱ Ju̱denu: “¡Si̱tenu vase vichara savichanu̱tyi jiñu vanu!” 
\p  
\v 48 Nijya̱nvajyuu ji̱ta, jiryatiy riintye̱ryadeda rana̱cho̱ variyu, ridyiyadanumatiy riva rajuura vichadeda, riñi ta̱rya̱da ji̱ta jiryoriñe̱cho̱ju̱ntiy, riñuvayadamu yivatyiyada variy jidyutudiva.  
\v 49 Riryadeda ji̱ta Jesús datyavay ti̱ta̱ju̱musiy nu̱jipyudera, vatuy jarye, jiryatiy richiityari̱nu̱yada Cadidéyamusiñi̱. Ru̱nu̱yada variy rana̱cho̱ ti̱ta̱ju̱. 
\s1 Jesús jmuchusa̱danchiy 
\r (Matévu 27.57-61; Márcu 15.42-47; Juán 19.38-42) 
\p  
\v 50-51 Savicha̱da ji̱ta ti̱qui vanu, Jusíy jtyati̱bay, jiryatiy Arimatéyamusi̱ni̱. Ni̱ni̱ vichanu̱yada Judíyuveda nutyityu̱miy tenu, samiy jvadichi̱, vase jvaarya jarye risa̱ju̱ni̱, jiryatimyu̱ ne sajachipiya̱nu̱yada vatajuu ruusa̱ jityevay nutyityu̱miy ruuvaayadamu, jiryatiy riñi jvaaryu̱yada sanijyu̱ Jesúsra, tapitya santuchara daryaju̱ Ju̱denu nusu̱yadajiju̱.  
\v 52 Ni̱day jto̱jada Pyidátubamyuntiy, sa̱tidye jachiñu̱y sivara Jesús babyi.  
\v 53 Su̱musadedanumatiy crusitya̱sasirya sababyi, sarayada ji̱ta variy sujajyuutara, sajachunuvejada ji̱ta bapyovimu varirya sababyi, ravichu̱nube ju̱michara, jasityimyu̱ ne ru̱muchoda ti̱ didye.  
\v 54 Ravichanu̱yada jdutya̱da runda, jiituyada rundajiju̱. Rajo̱ta̱danuma ji̱ta jiituyada runda variy. 
\p  
\v 55 Vatuy ji̱ta, jiryatiy ruuti̱jada Jesúsjsa̱ Cadidéyamusiy, riñi̱day siityari̱jada variryi jmuchuvay, ridyiyada ji̱ta riva bapyo, ru̱teda variy: “Nu̱tyurana̱te riberya sababyi ravimu, nu̱tyura.”  
\v 56 Ritye̱rya̱da ji̱ta vatuy variy, ru̱dutya̱da varirya jaryi varudi potiye̱rya, puyadajisiy ni̱di jarye risa̱ju̱. Jiituyada rundamu ji̱ta rijiituyada variy Ju̱denu niquejada nu̱chara jtedamuju̱. 
\c 24  
\s1 Jesús mi̱sa̱subeda diibyimusiy 
\r (Matévu 28.1-10; Márcu 16.1-8; Juán 20.1-10) 
\p  
\v 1 Tumyícyurundamu ji̱ta, rijyu̱ryi̱jada vatuy, ru̱toda ji̱ta bapyomura vu̱rudija̱ jdutyasara.  
\v 2 Ridyiñuvejada siva ravichu̱ siichunusi̱numa bapyo vudiju̱musidyeñi̱.  
\v 3 Rijeyadanumatiy ravimu, riryidyivya̱ riva Jesús babyinu̱daque, mitya.  
\v 4 Ne ridyetya̱da jijechipiya̱jada taranijyu̱ variy yintedamu. Mityamusiñi̱day nanumu̱ti̱jada danu̱ju̱y vanuju̱y rityuunu, vandajay sujatyanu̱jyu̱y.  
\v 5 Jiryatiy richuvu̱yada variy, ribyutyaja̱jada mucomuju̱ variyu. Nani̱teda ji̱ta danu̱ju̱y vanuju̱y variy ruuva: “¿Ta̱raju̱ jiryevya̱ta diibyimiy cabyimu sana̱cho̱ ju̱nu̱ñu day, ta̱raju̱?  
\v 6-7 Ne ti̱jna̱y jiyu, sami̱sa̱simya̱ day. Jirya̱jachipityara saniquejada, nu̱tyu satu̱chusiy Cadidéyamu jiryiva: Sa̱vicha sa̱chi̱ Nijya̱mi̱denu juuchatavamyu, rirya̱jvay variy crusitya̱sani̱, sa̱mi̱sa ji̱ta mumurundamiy jasacharamuntiy.”  
\v 8 Rijechipitya̱da ji̱ta vatuy varirya Jesús niquejada.  
\v 9 Ritye̱rya̱danumatiy bapyomusiy, rityu̱chunuvi̱jada ji̱ta ruuva Jesúsjsa̱ datyavay ti̱ta̱ju̱ra, jiryatiy rivyicha̱da jasiy vu̱yaju̱y, ti̱qui rinchaju̱, ruusa̱ vichavay jarye ti̱ta̱ju̱.  
\v 10 Rityi tu̱choda ruuva sansu̱byimirya jiryá, savicha̱da Maríyabay jiryatiy Mardánamusi̱ni̱, Juánabay jarye, Maríyaju̱be jiryatiy Santiyácubay jno̱dabay nada, tavay vatuy jarye ruusa̱ju̱ ti̱ta̱ju̱.  
\v 11 Sansu̱byimijyu̱ ji̱ta, riñi niquejada vatuy yatayadamura, riryityuva̱chuva̱ variy ramu.  
\v 12 Sanubesubeda ji̱ta Pyítrubay variy, sasiicheda ji̱ta bapyomu, sabutyajomusiy yinu̱ñuvejada bapyovimu, sadiyada ji̱ta riva sujajyuu viña̱sara jasiy, sata̱rya̱da ji̱ta mitya jnutacha̱ variy jadchiy. 
\s1 Jesús saryejada nada yisa̱ datyanu̱jyu̱y, Emavúsiy nú̱ta̱sa 
\r (Márcu 16.12-13) 
\p  
\v 13 Variryundamu ji̱ta, nadaya̱da Jesús siityari̱nu̱jyu̱y Jerusarí̱musiy, vicha̱da rapu̱rya na̱cho̱ju̱, jiryatiy Emavúsiy jtyatarara.  
\v 14 Jativyepudeviy nanutu̱chutityiyada jiryupiyadamu yivara, nu̱rya rivyichanichiy ti̱ta̱ju̱ni̱ Jesús.  
\v 15 Jadchiy ji̱ta, nanuniqueta̱danumatiyu, ni̱day Jesús tuudiyada variñada, mityijyiñuma riryupiyada variy jadchiy.  
\v 16 Mitya jruryaquisuma nani̱nu̱yada varicha̱ra̱ju̱, nañuma datya variy jasiñi̱ Jesús.  
\v 17 Su̱teda ji̱ta Jesús variy jasiy nadiva: “¿Ta̱ra niquejada sa̱ni jvaatyityi jiryupiyadamu day, ta̱ra?” Jadchiy ji̱ta, nanuraniñuvejada jiñuvayadamu variy.  
\v 18 Su̱mutya̱jada ji̱ta nu̱, Cudéyupa jtyati̱bañi̱ Jesús: “¿Vinu jiñi̱ rañi̱cha tavicha̱da ja̱mi̱ Jerusarí̱mu datyi̱sa̱ day? ¿Ne jidyetyava̱ nu̱tyura rivyichajay jiryundamimyucu̱, nu̱tyura?”  
\v 19 Su̱mutya̱jada ji̱ta nada: “¿Ta̱ra?” Nani̱mutya̱jada variñi̱: “Nu̱tyura rivyichanijeñi̱ Jesús Nasaryémusi̱, nu̱tyura. Ni̱ni̱ sani̱cha Ju̱denuju̱ tu̱chu̱, jiryatiy sivaañu̱yada jaryi datya̱data, saniquejada jarye vichanu̱yada jaryi datya̱datara Ju̱denu diya, nijya̱nvay diya jaryentiy.  
\v 20 Riñi sa̱je daryaju̱ caserdótevyeda nutyityu̱miy, vicha̱da nutyityu̱vedata japuni̱ Jesús, sa̱tidye jtay variy sivara jidyiiyada, rirya̱tidye batyaniy crusitya̱sa jasiñi̱.  
\v 21 Nu̱ñi jachipiya̱nu̱y sanijyu̱ day, nu̱tyu ni̱ni̱ ji̱ta ra̱jantyuy vuryiva, jiryatiy Irayénuveda davyu̱y. Jadchiy ji̱ta, mumurundamiñuma jiryatiy rivyichanije rajuura ti̱ta̱ju̱musiñi̱.  
\v 22-23 Jadchintyi, tavay vatuy, nu̱quebyimu vichavay jnuta̱siy nu̱y, jiryatiy rijyu̱ryi̱jay bapyomu jiya̱daju̱, riryi saryevya̱ra Jesús babyinu̱day. Ritye̱rya̱jasiy variy tu̱chuvay: Nu̱dyimya̱ nadiva Ju̱denu jpa̱nu̱ju̱y, nadani̱ tu̱chosiy nu̱dyiva: Nu̱tyi jnu̱ñu day sani̱cha Jesús.  
\v 24 Jadchiy ji̱ta riya̱siy tavay nu̱quebyimusiy bapyomuntiy, daryaday ridyiñuvejasiy rivantiy, nu̱tyu vatutyi tu̱chosiy daryantiy. Dantyamu̱y ne ridyiyasiy siva Jesús day.”  
\v 25 Su̱teda ji̱ta Jesús variy nadiva: “Ne datya̱da jachityanu̱jyu̱y sa̱da. Ne sa̱nutuva̱churu̱y nta ramu Ju̱denuju̱ tu̱chuvabe niquejada.  
\v 26 ¿Neviy saryi paru̱tyasara Ju̱denu jaryeti̱ daryadayu, saryi jañuve variy jivyandamuju̱ day?”  
\v 27 Sajo̱ta̱da ji̱ta Muyusésibe nu̱ryanchiy, ti̱ta̱ju̱ Ju̱denuju̱ tu̱chuvabe nu̱ryanchiy jarye, sadatyadoda ti̱ta̱ju̱ rata nada: “Nu̱rya riñu̱yada sanchiy Ju̱denu jaryeti̱.”  
\v 28 Rityuudiyada ji̱tara vicha̱da jasityi nadaya̱da, jadchiy ji̱ta sani ramiryi̱ru̱yada Jesús jiya̱da varidye.  
\v 29 Nani̱bayada ji̱ta variy jasiñi̱: “Jiyunuma ya̱ma̱cho̱ na̱dyisa̱, nu̱tyu rani ji̱ñuvañuma ri̱nu̱y, tama̱ na̱vay sani̱cha jiñi̱ nu̱day, tama̱.” Sajayada ji̱ta variy nanurorivyimu sa̱tidye ma̱cho̱ variy jasiy nadisa̱.  
\v 30 Sata̱yadanumatiy jmyijyomu nadisa̱, saryeda ji̱tara pa̱, si̱chana̱tya̱dani̱ Ju̱denu variy raju̱. Sapata̱da ji̱tara, sasa̱yada variy nadivara.  
\v 31 Ramutteda ji̱ta nanuni̱siy variy nanudatya̱daju̱, nanudatya̱da ji̱ta variñi̱. Varicha̱ra̱ju̱ sacarayada nanutuunusiy variy.  
\v 32 Nani̱teda ji̱ta variy yiva: “¡Nu̱ryamutiy ri̱chana̱yasiy vu̱jechicyu̱, jiryatiy saniquetityiyasiy nú̱va vuryiva, jiryatiy sadatyadosiy catera nu̱charata vu̱y!”  
\v 33 Nanunubesubeda ji̱ta varicha̱ra̱ju̱, nanuta̱rya̱da variy Jerusarí̱muju̱ntiy, nanusaryeñuvejada riy Jesúsjsa̱ datyavay, jasityi riintye̱ryadedayu, vu̱yaju̱y, ti̱qui rinchaju̱, ruusa̱ vichavay jarye ti̱ta̱ju̱.  
\v 34 Riñi̱ ji̱ta tu̱choda variy nadiva: “¡Si̱tenuni̱ sami̱sa̱siy Vu̱ntyityu̱, sadityadosimya̱ Siimyó̱ntiyu!”  
\v 35 Jadchiy ji̱ta nanutu̱chodara jiryupiyada ruuva: “Nu̱ryamusiy na̱dyetya̱siñi̱ Jesús, jiryatiy sapata̱sirya pa̱ na̱jyu̱.” 
\s1 Jesús dityadoda yisa̱ datyavayu 
\r (Matévu 28.16-20; Márcu 16.14-18; Juán 20.19-23; Jvaayada 1.6-8) 
\p  
\v 36 Nanuniquejada niya̱re, ni̱day Jesús mu̱ti̱jada riquebyimu varintyi. Su̱teda ji̱ta variy ruuva: “Samirya ra̱cha jiryejechiy, ne jirya̱jnutay.”  
\v 37 Jaryi ru̱ntedamu jime̱cho̱jada variy jasiy, jiryatiy richuvu̱yada daryaju̱, ru̱tamya̱ta bayantuva jidyi.  
\v 38 Su̱teda ji̱ta Jesús variy ruuvantiy: “¿Ta̱ju̱ra jiryi̱ntañumaya̱ jaryi varidye, ta̱ju̱? ¿Ta̱ju̱ra raryesumiya̱ jiryejechiy jiryejechipiya̱jadamu dayu, ta̱ju̱?  
\v 39 Jirya̱jnu̱y rajyomucu̱, rañumutuvimuntiy, ravyidye rañi̱cha. Jirya̱ju̱riy rañicyu̱, jirya̱jnu̱y rañe̱cho̱ntiy; ¿savityi̱ni̱viy jiryi̱nu̱ñi̱ bayantu day? dantyamu̱y ne duuti̱ risa̱ju̱ni̱.”  
\v 40 Su̱tedanumatiy darya ruuva, sadityadoda ji̱ta jijyomutu variryi, sanumutu jarye.  
\v 41 Riichana̱yadamu, rityi̱tta̱damu jarye, ne rityuva̱churu̱yada variy ramu. Sitaja̱doda ji̱ta variryi: “¿Taravidye jbyedaju̱ jiyu?”  
\v 42 Riche̱yada ji̱ta quiva̱saviy jansara variñi̱.  
\v 43 Su̱mutya̱jada ji̱ta variy ruumusirya, si̱byeda ji̱ta variy ridyiyadajachera. 
\p  
\v 44 Jadchiy ji̱ta su̱teda Jesús ruuva: “Jiryatirya rañiquejada jto̱tadeda, jiryatiy rañiquenu̱yada raryupiyadamu jiryisa̱ra. Ri̱tatyi variy jiryiva: Ra̱day jto̱taniy ti̱ta̱ju̱ra jiryatiy nu̱chara ranchidyerya, varimyata Muyusésibe niquejada, varimyata Ju̱denuju̱ tu̱chuvabe jteda, varimyata jiryatiy murra̱pedyemyu nu̱chara darya.”  
\v 45 Variñi̱ ji̱ta samutta̱dara rijechiy rirya̱tidye datya varirya Ju̱denu niquejada nu̱chara.  
\v 46 Su̱teda ji̱ta variy ruuva: “Darya nu̱chara ni̱day, jiryatiy sa̱paru̱tyasara Ju̱denu jaryeti̱yu, sa̱mi̱sa ji̱ta mumurundamiy jasacharamuntiy.  
\v 47 Jirya̱ma̱ tu̱chujaya̱ ri̱tyamu ruuva ti̱ta̱ju̱ mucadi ja̱nvay: rirya̱ntya paru̱y riva va̱cha jvaayada, sa̱tidye ramityaniy Ju̱denu ruuvara jijyuuchuveda. Jirya̱ma̱ jo̱ta tu̱choda jiyu, Jerusarí̱mu.  
\v 48 Jirye ji̱ta diñu̱yada daryaju̱ riva ti̱ta̱ju̱ tara, ramuni̱ jirya̱tu̱chuntirya.  
\v 49 Jirya̱jnu̱y, ray ji̱ta ra̱jpa̱ jiryivani̱ jiryatiy su̱teda rajye̱: Ra̱sa̱y jiryeñi̱. Jiryeñi̱ ji̱ta raryime̱cho̱ ja̱mu vicha̱damu jasicha̱ra̱ju̱tiy jirye̱cha jachusavay Ju̱denu vanu̱yadata, jiryatiy na̱vachirya.” 
\s1 Jesús jasubeda jarichunchaju̱ 
\r (Márcu 16.19-20; Jvaayada 1.9-11) 
\p  
\v 50 Jadchiy ji̱ta sa̱ra̱cheda Jesús Betániya sa̱ra̱ju̱ riy, saryesubedanumatirya jijyomutu na̱vajyu̱, sajachiñu̱yada variy siva Ju̱denu riyadaju̱.  
\v 51 Sajachiñu̱yadamu ji̱ta jityocheda variy jasiryi, sa̱suminicha̱damu jarichuvimuju̱.  
\v 52 Rijechipiya̱jadanumatiy sanijyu̱, ritye̱rya̱da ji̱ta variy yichana̱yadamu Jerusarí̱muju̱.  
\v 53 Rivyichasara ji̱ta Ju̱denu nijyu̱ jachipiya̱jomu, riichana̱tyajaya̱sara ti̱ta̱ju̱musiy variy jasiñi̱ Ju̱denu.