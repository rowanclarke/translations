\id PHM - SYN-Siyin Bible 
\ide 65001 - Unicode (UTF-8)
\h PHILEMON 
\toc1 PHILEMON 
\toc2 Philemon 
\toc3 Phlm 
\mt1 PHILEMON  
\mt1 Laithak  
\mt2 Philemon  
\c 1  
\s1 Nuksetna  
\p
\v 1 Jesus Christ hang in thong a tak keima Paul le i suapui Timothy in ka it mama uh le ka naseppui uh a hi Philemon,   
\p
\v 2 \x - \xo 1:2 \xt Co. 4:17\x*Ka it mama uh Apphia, ka ngalkap seppui Archippus le na inn a om pawlpi te tung ah:   
\p
\v 3 I Pa Pathian le Topa Jesus Christ tung pan thuthiamna le thinnopna hong om tahen.   
\s1 Philemon i Itna le Upna  
\p
\v 4 Ka thungetna theampo ah nangma hong phawk tawntung in ka Pathian tung lungdam ka ko hi,   
\p
\v 5 Banghangziam cile, Topa Jesus le mithiangtho te tungah na nei itna le upna thu ka za hi;   
\p
\v 6 Christ Jesus sungah, nasung a om napha theampo heakna hang in na upna sia ngualdang na hil ciang vang nei tu in thu kong ngetsak hi.   
\p
\v 7 Banghangziam cile, suapui pa awng, na itna sungah, lungdamna le hanthotna lian mama nei khu hi, banghangziam cile mithiangtho te thinsung ah, nangma hang in thathak hong dim hi.   
\s1 Onesimas Atu Ngetna  
\p
\v 8 Tua ahikom Christ sungah hangsantak in thu kong piak tu hunnuam hong suak hi.   
\p
\v 9 Ahihang kum tam zo le tu zong in Jesus Christ hang in thong a tak keima Paul in, itna taw in kong thum nuam zaw hi.   
\p
\v 10 \x - \xo 1:10 \xt Co. 4:9\x*Kolhawng taw henna ka thuak lai in ka nei ka tapa Onesimus atu kong thum hi:   
\p
\v 11 A bosa hun sungah nang atu in bangma phatuam ngawl hi, ahihang tu in nangma le keima atu in phatuam mama hi:   
\p
\v 12 Ama kong heakkik sak hi: tua ahikom, ka thinsung laingil bang in na sang in:   
\p
\v 13 Lungdamna thu hang in kolhawng taw ka om laitak in, nangma tang in hong khoi tu in ama sia ka kungah omsak nuam khi hi:   
\p
\v 14 Ahitazong, na thukimna sia, kong sawl hamtang hang hi ngawl in, nangma thinsung suak in na khensat a hi thei natu in, nong heakpui ngawl in bangma ka ngamta nuam bua hi.   
\p
\v 15 Hun tomno sung a taina thu sia a tawntung in na nei kik thei natu hi zaw tu hi;   
\p
\v 16 Tu in ama sia sila bang hi ngawl in, sila sang in a sangzaw in ama na sang in, ama sia keima atu, a tuan in ka it suapui hi a, cilesa lam le Topa lam ah nangma atu in bangza in pha seseam tu ziam?   
\p
\v 17 Tua ahikom naseppui bangin nong ngaisun a hile, keima nong san tu bangin, ama na sangkik in.   
\p
\v 18 Nang tungah khial a hile, a hibale nangtung ah bat hong nei a hile, keima bat bang in hong ngaisutsak tan;   
\p
\v 19 Keima Paul in ka khut tatak taw ma in hong at khi hi, keima in hong lokik tu khi hi: ahihang keima tung tatak ma ah nangma in zong hong ba ni hi, kong ci bua hi.   
\p
\v 20 Hi hi, suapui pa, Topa sungah nangma hang in lungdamna hong neisak tan: Topa sungah ka thinsung laingil thathak hong dimsak tan.   
\p
\v 21 Thu ni na hina sungah muanna nei in na tungah lai hong at khi hi, kong son za sang a tam zaw seam tu ni hi, ci kong he hi.   
\p
\v 22 Tabang cikteak ma in ka ngia natu mun hong puakholsak tan: banghangziam cile na thungetna uh hang in note kungah hong theng thei tu khi hi, ci zong lametna ka nei hi.   
\s1 A Khakbel Vaithakna  
\p
\v 23 \x - \xo 1:23 \xt Col 1:7; 4:12\x*Christ Jesus hang in ka thongtakpui Epaphras;   
\p
\v 24 \x - \xo 1:24 \xt Sawl 12:12,25; 13:13; 15:37-39; Col 4:10; \xt Sawl 19:29; 27:2; Col 4:10; \xt Col 4:14; 2Tim 4:10; \xt Col 4:14; 2Tim 4:11.\x*Ka naseppui Marcus, Aristarchus, Demas le Lucas te in hong nukset hi.   
\p
\v 25 I Topa Jesus Christ i hesuakna na tha taw hong om tahen. Amen.   