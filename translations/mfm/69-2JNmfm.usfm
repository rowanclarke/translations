\id 2JN - Margi Tiwi Ənga Tǝm [mfm]
\h Yahwana Nǝ Mǝthlǝkura Nyi
\toc3 Yah Mǝth
\toc2 Yahwana Nǝ Mǝthlǝkura Nyi
\toc1 Cama Tsǝtsǝfǝ Nǝ Yahwana
\mt2 Cama Tsǝtsǝfǝ Nǝ Mǝthlǝu Nǝ
\mt1 Yahwana
\c 1
\s1 Usa Dzau
\p 
\v 1 Sara ara ndǝra degal nǝ daɓǝ dzǝ njir nu, a nda nǝ mala dǝgal ki cacaɗau ǝnga wazha nyi kǝra ya vǝr yiwu ǝnga jirkur, aˈyi nayi zhizhi ɗa nga vǝr yiwu nyi mai, ama daɓǝ ǝnga kalar njira wu sǝn jiri.
\v 2 ˈYu yiwu hyi arya jirkur kǝra a vǝr nggya wu mǝn ǝnga ju nda nggya wu mǝn baˈanuwa.
\v 3 Bǝgǝ mayiwakur, ǝnga tǝhuɗǝu, ǝnga huɗǝ pǝrtu sara ara Hyal Tada ǝnga Yesu Kǝrsiti, Zǝr Tada nyi, nda nggya ǝnga mǝn wu jirkur ǝnga yiwukur.
\p 
\v 4 Huɗa yi pipida gagaɗau ǝnga yi thlǝwa alenyi wazha ngau a vǝr nu jiri, ǝnggǝr kǝra Tada cuwa mǝn mǝna mǝl.
\v 5 Kabangǝkau, mala dǝgal, vanyi ndǝr mafǝliyangǝ nga ya vǝr tsǝfǝ anǝ ngǝ mai, ama kǝra ara mǝn tsu ɗǝɗǝmǝ ta ngau. Ya vǝr na abǝr, mǝna yiwu kǝrmǝn.
\v 6 Ara yiwudzǝ kǝra dudur ca ngǝ mǝna ɓau wu ɓǝlar ndǝr Hyal. Ənggǝr kǝra hyi nggari tsu kaɗǝu, ca ngǝ hya nggya wu yiwukur.
\p 
\v 7 Njir sukwa nji gangǝ kǝra gǝra hǝnggǝri abǝr Yesu Kǝrsiti aˈyi shili wu kumǝr dzǝ mai, a tǝtǝlnar nda dzǝ a ndu duniya. Kalar culi najaka nji, njir sukwa nji ngau ǝnga dawa nǝ Kǝrsiti.
\v 8 Hya hangǝkal ǝnga kǝrhyi hya sara sana sǝra hyi mǝl thlǝr aga nyi, ama aga hya uya akkǝra nyi.
\v 9 Kalar ndǝra cakǝr sau a dar kǝra najaka highiɓau, naja aˈyi taˈyi ar kǝra highiɓǝ nǝ Kǝrsiti mai, Hyal aˈyi ǝnga ja tsu mai, kalar ndǝra dumwa ǝnga highiɓǝ nǝ Kǝrsiti, Tada ǝnga Zǝr nyi aˈyi wu ja.
\v 10 Kalar ndǝra shili ǝgya hyi, ma aˈyi ji shili ǝnga najaka highiɓǝ mai, hya hǝ nyi a vu kir hyi mai, ǝnga hya sara dlǝwu nyi mai.
\v 11 Kalar ndǝra dlǝwur nyi ju nda ɗa wu cir zǝm wu shishikur nyi kau.
\s1 Ndǝr Nǝ Jomǝndǝl
\p 
\v 12 Sǝ aˈyi gangǝ kǝra ya kyaga tsǝfǝr hyi, ama nayu yiwu ya ɓǝra tsǝfǝr nda mai, ama arya kau, yu yiwu ya lar hyi bama ǝnga bama aga huɗǝ pipidar mǝn a nyabiya dzau.
\p 
\v 13 Wazha kwamǝ ngǝ kǝra cacaɗǝ nda vǝr usa ngau.
