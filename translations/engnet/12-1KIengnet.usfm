\c 1  
\s1 Adonijah Tries to Seize the Throne  
\p
\v 1  \w King|strong="H4428"\w* \w David|strong="H1732"\w* \w was|strong="H1732"\w* very \w old|strong="H2204"\w*; \w even|strong="H3808"\w* \w when|strong="H3117"\w* \w they|strong="H3117"\w* \w covered|strong="H3680"\w* \w him|strong="H1732"\w* \w with|strong="H3117"\w* blankets, \w he|strong="H3117"\w* could \w not|strong="H3808"\w* get \w warm|strong="H3179"\w*.  
\v 2  \w His|strong="H6440"\w* \w servants|strong="H5650"\w* advised \w him|strong="H6440"\w*, “\w A|strong="H3068"\w* \w young|strong="H5291"\w* \w virgin|strong="H1330"\w* must \w be|strong="H1961"\w* found \w for|strong="H6440"\w* \w our|strong="H1961"\w* master, \w the|strong="H6440"\w* \w king|strong="H4428"\w*, \w to|strong="H1961"\w* \w take|strong="H1961"\w* \w care|strong="H2436"\w* \w of|strong="H4428"\w* \w the|strong="H6440"\w* \w king|strong="H4428"\w*’s \w needs|strong="H1961"\w* \w and|strong="H4428"\w* \w serve|strong="H1961"\w* \w as|strong="H1961"\w* \w his|strong="H6440"\w* \w nurse|strong="H5532"\w*. \w She|strong="H6440"\w* \w can|strong="H5650"\w* \w also|strong="H4428"\w* \w sleep|strong="H7901"\w* \w with|strong="H6440"\w* \w you|strong="H6440"\w* \w and|strong="H4428"\w* \w keep|strong="H2552"\w* \w our|strong="H1961"\w* master, \w the|strong="H6440"\w* \w king|strong="H4428"\w*, \w warm|strong="H2552"\w*.”  
\v 3  \w So|strong="H4672"\w* \w they|strong="H3605"\w* \w looked|strong="H1245"\w* \w through|strong="H3605"\w* \w all|strong="H3605"\w* \w Israel|strong="H3478"\w* \w for|strong="H3478"\w* \w a|strong="H3068"\w* \w beautiful|strong="H3303"\w* \w young|strong="H5291"\w* \w woman|strong="H5291"\w* \w and|strong="H3478"\w* \w found|strong="H4672"\w* Abishag, \w a|strong="H3068"\w* \w Shunammite|strong="H7767"\w*, \w and|strong="H3478"\w* \w brought|strong="H3478"\w* \w her|strong="H3605"\w* \w to|strong="H3478"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*.  
\v 4  \w The|strong="H3045"\w* \w young|strong="H5291"\w* \w woman|strong="H5291"\w* \w was|strong="H1961"\w* \w very|strong="H3966"\w* \w beautiful|strong="H3303"\w*; \w she|strong="H5704"\w* \w became|strong="H1961"\w* \w the|strong="H3045"\w* \w king|strong="H4428"\w*’s \w nurse|strong="H5532"\w* \w and|strong="H4428"\w* \w served|strong="H8334"\w* \w him|strong="H3045"\w*, \w but|strong="H3808"\w* \w the|strong="H3045"\w* \w king|strong="H4428"\w* \w did|strong="H3808"\w* \w not|strong="H3808"\w* \w have|strong="H1961"\w* sexual \w relations|strong="H3045"\w* \w with|strong="H3045"\w* \w her|strong="H3045"\w*.   
\p
\v 5  Now Adonijah, \w son|strong="H1121"\w* \w of|strong="H1121"\w* David \w and|strong="H1121"\w* \w Haggith|strong="H2294"\w*, \w was|strong="H1121"\w* promoting \w himself|strong="H6213"\w*, boasting, “\w I|strong="H1121"\w* \w will|strong="H1121"\w* \w be|strong="H1121"\w* \w king|strong="H4427"\w*!” \w He|strong="H6213"\w* managed \w to|strong="H6213"\w* acquire \w chariots|strong="H7393"\w* \w and|strong="H1121"\w* \w horsemen|strong="H6571"\w*, \w as|strong="H6213"\w* well \w as|strong="H6213"\w* \w fifty|strong="H2572"\w* \w men|strong="H1121"\w* \w to|strong="H6213"\w* \w serve|strong="H6440"\w* \w as|strong="H6213"\w* \w his|strong="H6440"\w* royal \w guard|strong="H7323"\w*.  
\v 6  (\w Now|strong="H3117"\w* \w his|strong="H6213"\w* \w father|strong="H3205"\w* \w had|strong="H3205"\w* \w never|strong="H3808"\w* \w corrected|strong="H6087"\w* \w him|strong="H3205"\w* \w by|strong="H3117"\w* saying, “\w Why|strong="H4069"\w* \w do|strong="H6213"\w* \w you|strong="H3117"\w* \w do|strong="H6213"\w* \w such|strong="H1931"\w* \w things|strong="H2896"\w*?” \w He|strong="H1931"\w* \w was|strong="H1931"\w* \w also|strong="H1571"\w* \w very|strong="H3966"\w* \w handsome|strong="H2896"\w* \w and|strong="H3117"\w* \w had|strong="H3205"\w* \w been|strong="H3808"\w* \w born|strong="H3205"\w* \w right|strong="H2896"\w* \w after|strong="H3117"\w* Absalom. )  
\v 7  \w He|strong="H1697"\w* collaborated \w with|strong="H5973"\w* \w Joab|strong="H3097"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Zeruiah|strong="H6870"\w* \w and|strong="H1121"\w* \w with|strong="H5973"\w* Abiathar \w the|strong="H1697"\w* \w priest|strong="H3548"\w*, \w and|strong="H1121"\w* \w they|strong="H1697"\w* supported \w him|strong="H5973"\w*.  
\v 8  \w But|strong="H3808"\w* \w Zadok|strong="H6659"\w* \w the|strong="H1961"\w* \w priest|strong="H3548"\w*, \w Benaiah|strong="H1141"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jehoiada|strong="H3077"\w*, \w Nathan|strong="H5416"\w* \w the|strong="H1961"\w* \w prophet|strong="H5030"\w*, \w Shimei|strong="H8096"\w*, \w Rei|strong="H7472"\w*, \w and|strong="H1121"\w* \w David|strong="H1732"\w*’s elite \w warriors|strong="H1368"\w* \w did|strong="H3808"\w* \w not|strong="H3808"\w* ally themselves \w with|strong="H5973"\w* Adonijah.  
\v 9  Adonijah \w sacrificed|strong="H2076"\w* \w sheep|strong="H6629"\w*, \w cattle|strong="H1241"\w*, \w and|strong="H1121"\w* fattened \w steers|strong="H4806"\w* \w at|strong="H4428"\w* \w the|strong="H3605"\w* Stone \w of|strong="H1121"\w* \w Zoheleth|strong="H2120"\w* \w near|strong="H5973"\w* En Rogel. \w He|strong="H3605"\w* \w invited|strong="H7121"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* \w brothers|strong="H1121"\w*, \w the|strong="H3605"\w* \w king|strong="H4428"\w*’s \w sons|strong="H1121"\w*, \w as|strong="H1121"\w* \w well|strong="H5973"\w* \w as|strong="H1121"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w men|strong="H1121"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*, \w the|strong="H3605"\w* \w king|strong="H4428"\w*’s \w servants|strong="H5650"\w*.  
\v 10  \w But|strong="H3808"\w* \w he|strong="H8010"\w* \w did|strong="H3808"\w* \w not|strong="H3808"\w* \w invite|strong="H7121"\w* \w Nathan|strong="H5416"\w* \w the|strong="H7121"\w* \w prophet|strong="H5030"\w*, \w Benaiah|strong="H1141"\w*, \w the|strong="H7121"\w* elite \w warriors|strong="H1368"\w*, \w or|strong="H3808"\w* \w his|strong="H7121"\w* brother \w Solomon|strong="H8010"\w*.   
\p
\v 11  \w Nathan|strong="H5416"\w* \w said|strong="H8085"\w* \w to|strong="H8085"\w* \w Bathsheba|strong="H1339"\w*, \w Solomon|strong="H8010"\w*’s mother, “\w Has|strong="H3588"\w* \w it|strong="H3588"\w* \w been|strong="H3808"\w* \w reported|strong="H8085"\w* \w to|strong="H8085"\w* \w you|strong="H3588"\w* \w that|strong="H3588"\w* \w Haggith|strong="H2294"\w*’s \w son|strong="H1121"\w* Adonijah \w has|strong="H3588"\w* \w become|strong="H4427"\w* \w king|strong="H4427"\w* behind \w our|strong="H8085"\w* master \w David|strong="H1732"\w*’s \w back|strong="H3045"\w*?  
\v 12  \w Now|strong="H6258"\w* \w let|strong="H4994"\w* \w me|strong="H4994"\w* \w give|strong="H3289"\w* \w you|strong="H3289"\w* \w some|strong="H5315"\w* \w advice|strong="H6098"\w* \w as|strong="H5315"\w* \w to|strong="H3212"\w* \w how|strong="H4994"\w* \w you|strong="H3289"\w* \w can|strong="H4994"\w* \w save|strong="H4422"\w* \w your|strong="H4994"\w* \w life|strong="H5315"\w* \w and|strong="H1121"\w* \w your|strong="H4994"\w* \w son|strong="H1121"\w* \w Solomon|strong="H8010"\w*’s \w life|strong="H5315"\w*.  
\v 13  Visit \w King|strong="H4428"\w* \w David|strong="H1732"\w* \w and|strong="H1121"\w* say \w to|strong="H3212"\w* \w him|strong="H5921"\w*, ‘\w My|strong="H1732"\w* \w master|strong="H3427"\w*, \w O|strong="H3068"\w* \w king|strong="H4428"\w*, \w did|strong="H1732"\w* \w you|strong="H3588"\w* \w not|strong="H3808"\w* \w solemnly|strong="H7650"\w* \w promise|strong="H7650"\w* \w your|strong="H5921"\w* servant, “\w Surely|strong="H3588"\w* \w your|strong="H5921"\w* \w son|strong="H1121"\w* \w Solomon|strong="H8010"\w* \w will|strong="H4428"\w* \w be|strong="H3808"\w* \w king|strong="H4428"\w* \w after|strong="H5921"\w* \w me|strong="H5921"\w*; \w he|strong="H1931"\w* \w will|strong="H4428"\w* \w sit|strong="H3427"\w* \w on|strong="H5921"\w* \w my|strong="H1732"\w* \w throne|strong="H3678"\w*”? \w So|strong="H3808"\w* \w why|strong="H4069"\w* \w has|strong="H4428"\w* Adonijah \w become|strong="H4427"\w* \w king|strong="H4428"\w*?’  
\v 14  \w While|strong="H5750"\w* \w you|strong="H5973"\w* \w are|strong="H1697"\w* \w still|strong="H5750"\w* \w there|strong="H8033"\w* \w speaking|strong="H1696"\w* \w to|strong="H1696"\w* \w the|strong="H4390"\w* \w king|strong="H4428"\w*, \w I|strong="H2009"\w* \w will|strong="H4428"\w* arrive \w and|strong="H4428"\w* verify \w your|strong="H4390"\w* \w report|strong="H1697"\w*.”   
\p
\v 15  \w So|strong="H3966"\w* \w Bathsheba|strong="H1339"\w* visited \w the|strong="H8334"\w* \w king|strong="H4428"\w* \w in|strong="H4428"\w* \w his|strong="H4428"\w* private quarters. (\w The|strong="H8334"\w* \w king|strong="H4428"\w* \w was|strong="H4428"\w* \w very|strong="H3966"\w* \w old|strong="H2204"\w*, \w and|strong="H4428"\w* Abishag \w the|strong="H8334"\w* \w Shunammite|strong="H7767"\w* \w was|strong="H4428"\w* \w serving|strong="H8334"\w* \w the|strong="H8334"\w* \w king|strong="H4428"\w*.)  
\v 16  \w Bathsheba|strong="H1339"\w* \w bowed|strong="H7812"\w* \w down|strong="H7812"\w* \w on|strong="H4100"\w* \w the|strong="H7812"\w* floor before \w the|strong="H7812"\w* \w king|strong="H4428"\w*. \w The|strong="H7812"\w* \w king|strong="H4428"\w* said, “\w What|strong="H4100"\w* \w do|strong="H4100"\w* \w you|strong="H4100"\w* want?”  
\v 17  \w She|strong="H1931"\w* replied \w to|strong="H3068"\w* \w him|strong="H5921"\w*, “\w My|strong="H3068"\w* \w master|strong="H3427"\w*, \w you|strong="H3588"\w* \w swore|strong="H7650"\w* \w an|strong="H7650"\w* \w oath|strong="H7650"\w* \w to|strong="H3068"\w* \w your|strong="H3068"\w* servant \w by|strong="H5921"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w your|strong="H3068"\w* \w God|strong="H3068"\w*, ‘\w Solomon|strong="H8010"\w* \w your|strong="H3068"\w* \w son|strong="H1121"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* \w king|strong="H4427"\w* \w after|strong="H5921"\w* \w me|strong="H5921"\w* \w and|strong="H1121"\w* \w he|strong="H1931"\w* \w will|strong="H3068"\w* \w sit|strong="H3427"\w* \w on|strong="H5921"\w* \w my|strong="H3068"\w* \w throne|strong="H3678"\w*.’  
\v 18  \w But|strong="H3808"\w* \w now|strong="H6258"\w*, \w look|strong="H2009"\w*, Adonijah \w has|strong="H4428"\w* \w become|strong="H4427"\w* \w king|strong="H4428"\w*! \w But|strong="H3808"\w* \w you|strong="H3045"\w*, \w my|strong="H3045"\w* master \w the|strong="H3045"\w* \w king|strong="H4428"\w*, \w are|strong="H4428"\w* \w not|strong="H3808"\w* \w even|strong="H3808"\w* \w aware|strong="H3045"\w* \w of|strong="H4428"\w* \w it|strong="H3045"\w*!  
\v 19  \w He|strong="H3605"\w* \w has|strong="H6635"\w* \w sacrificed|strong="H2076"\w* \w many|strong="H7230"\w* \w cattle|strong="H6629"\w*, \w steers|strong="H4806"\w*, \w and|strong="H1121"\w* \w sheep|strong="H6629"\w* \w and|strong="H1121"\w* \w has|strong="H6635"\w* \w invited|strong="H7121"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*’s \w sons|strong="H1121"\w*, Abiathar \w the|strong="H3605"\w* \w priest|strong="H3548"\w*, \w and|strong="H1121"\w* \w Joab|strong="H3097"\w*, \w the|strong="H3605"\w* \w commander|strong="H8269"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* \w army|strong="H6635"\w*, \w but|strong="H3808"\w* \w he|strong="H3605"\w* \w has|strong="H6635"\w* \w not|strong="H3808"\w* \w invited|strong="H7121"\w* \w your|strong="H3605"\w* \w servant|strong="H5650"\w* \w Solomon|strong="H8010"\w*.  
\v 20  \w Now|strong="H3478"\w*, \w my|strong="H3605"\w* \w master|strong="H3427"\w*, \w O|strong="H3068"\w* \w king|strong="H4428"\w*, \w all|strong="H3605"\w* \w Israel|strong="H3478"\w* \w is|strong="H4310"\w* \w watching|strong="H5869"\w* anxiously \w to|strong="H3478"\w* \w see|strong="H5869"\w* \w who|strong="H4310"\w* \w is|strong="H4310"\w* \w named|strong="H5921"\w* \w to|strong="H3478"\w* succeed \w my|strong="H3605"\w* \w master|strong="H3427"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w on|strong="H5921"\w* \w the|strong="H3605"\w* \w throne|strong="H3678"\w*.  
\v 21  \w If|strong="H1961"\w* \w a|strong="H3068"\w* decision \w is|strong="H4428"\w* \w not|strong="H1961"\w* \w made|strong="H1961"\w*, \w when|strong="H1961"\w* \w my|strong="H1961"\w* master \w the|strong="H1961"\w* \w king|strong="H4428"\w* \w is|strong="H4428"\w* buried \w with|strong="H5973"\w* \w his|strong="H1961"\w* ancestors, \w my|strong="H1961"\w* \w son|strong="H1121"\w* \w Solomon|strong="H8010"\w* \w and|strong="H1121"\w* \w I|strong="H1121"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w considered|strong="H1961"\w* state \w criminals|strong="H2400"\w*.”   
\p
\v 22  \w Just|strong="H1696"\w* \w then|strong="H1696"\w*, \w while|strong="H5750"\w* \w she|strong="H5973"\w* \w was|strong="H4428"\w* \w still|strong="H5750"\w* \w speaking|strong="H1696"\w* \w to|strong="H1696"\w* \w the|strong="H1696"\w* \w king|strong="H4428"\w*, \w Nathan|strong="H5416"\w* \w the|strong="H1696"\w* \w prophet|strong="H5030"\w* arrived.  
\v 23  \w The|strong="H6440"\w* \w king|strong="H4428"\w* \w was|strong="H4428"\w* \w told|strong="H5046"\w*, “\w Nathan|strong="H5416"\w* \w the|strong="H6440"\w* \w prophet|strong="H5030"\w* \w is|strong="H2009"\w* \w here|strong="H2009"\w*.” \w Nathan|strong="H5416"\w* entered \w and|strong="H4428"\w* \w bowed|strong="H7812"\w* \w before|strong="H6440"\w* \w the|strong="H6440"\w* \w king|strong="H4428"\w* \w with|strong="H5921"\w* \w his|strong="H6440"\w* \w face|strong="H6440"\w* \w to|strong="H5921"\w* \w the|strong="H6440"\w* floor.  
\v 24  \w Nathan|strong="H5416"\w* said, “\w My|strong="H5921"\w* \w master|strong="H3427"\w*, \w O|strong="H3068"\w* \w king|strong="H4428"\w*, did \w you|strong="H5921"\w* announce, ‘Adonijah \w will|strong="H4428"\w* \w be|strong="H4428"\w* \w king|strong="H4428"\w* \w after|strong="H5921"\w* \w me|strong="H5921"\w*; \w he|strong="H1931"\w* \w will|strong="H4428"\w* \w sit|strong="H3427"\w* \w on|strong="H5921"\w* \w my|strong="H5921"\w* \w throne|strong="H3678"\w*’?  
\v 25  \w For|strong="H3588"\w* \w today|strong="H3117"\w* \w he|strong="H3588"\w* \w has|strong="H6635"\w* \w gone|strong="H3381"\w* \w down|strong="H3381"\w* \w and|strong="H1121"\w* \w sacrificed|strong="H2076"\w* \w many|strong="H7230"\w* \w cattle|strong="H6629"\w*, \w steers|strong="H4806"\w*, \w and|strong="H1121"\w* \w sheep|strong="H6629"\w* \w and|strong="H1121"\w* \w has|strong="H6635"\w* \w invited|strong="H7121"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*’s \w sons|strong="H1121"\w*, \w the|strong="H3605"\w* \w army|strong="H6635"\w* \w commanders|strong="H8269"\w*, \w and|strong="H1121"\w* Abiathar \w the|strong="H3605"\w* \w priest|strong="H3548"\w*. \w At|strong="H3117"\w* \w this|strong="H3588"\w* moment \w they|strong="H3588"\w* \w are|strong="H3117"\w* \w having|strong="H3588"\w* \w a|strong="H3068"\w* feast \w in|strong="H4428"\w* \w his|strong="H3605"\w* \w presence|strong="H6440"\w*, \w and|strong="H1121"\w* \w they|strong="H3588"\w* \w have|strong="H1121"\w* declared, ‘\w Long|strong="H3117"\w* \w live|strong="H2421"\w* \w King|strong="H4428"\w* Adonijah!’  
\v 26  \w But|strong="H3808"\w* \w he|strong="H3808"\w* \w did|strong="H5650"\w* \w not|strong="H3808"\w* \w invite|strong="H7121"\w* \w me|strong="H7121"\w* – \w your|strong="H3808"\w* \w servant|strong="H5650"\w* – \w or|strong="H3808"\w* \w Zadok|strong="H6659"\w* \w the|strong="H7121"\w* \w priest|strong="H3548"\w*, \w or|strong="H3808"\w* \w Benaiah|strong="H1141"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jehoiada|strong="H3077"\w*, \w or|strong="H3808"\w* \w your|strong="H3808"\w* \w servant|strong="H5650"\w* \w Solomon|strong="H8010"\w*.  
\v 27  \w Has|strong="H4310"\w* \w my|strong="H5921"\w* \w master|strong="H3427"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w authorized|strong="H1961"\w* \w this|strong="H2088"\w* \w without|strong="H3808"\w* \w informing|strong="H3045"\w* \w your|strong="H5921"\w* \w servants|strong="H5650"\w* \w who|strong="H4310"\w* \w should|strong="H4428"\w* succeed \w my|strong="H5921"\w* \w master|strong="H3427"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w on|strong="H5921"\w* \w his|strong="H5921"\w* \w throne|strong="H3678"\w*?”   
\s1 David Picks Solomon as His Successor  
\p
\v 28  \w King|strong="H4428"\w* \w David|strong="H1732"\w* \w responded|strong="H6030"\w*, “\w Summon|strong="H7121"\w* \w Bathsheba|strong="H1339"\w*!” \w She|strong="H7121"\w* \w came|strong="H4428"\w* \w and|strong="H6030"\w* \w stood|strong="H5975"\w* \w before|strong="H6440"\w* \w the|strong="H6440"\w* \w king|strong="H4428"\w*.  
