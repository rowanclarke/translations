\v 16  \w Let|strong="H4994"\w* \w our|strong="H5921"\w* lord \w instruct|strong="H3045"\w* \w his|strong="H6440"\w* \w servants|strong="H5650"\w* \w who|strong="H5650"\w* \w are|strong="H3027"\w* \w here|strong="H5921"\w* \w before|strong="H6440"\w* \w you|strong="H6440"\w* \w to|strong="H1961"\w* \w look|strong="H1245"\w* \w for|strong="H5921"\w* \w a|strong="H3068"\w* \w man|strong="H7451"\w* \w who|strong="H5650"\w* \w knows|strong="H3045"\w* \w how|strong="H3045"\w* \w to|strong="H1961"\w* \w play|strong="H5059"\w* \w the|strong="H6440"\w* \w lyre|strong="H3658"\w*. \w Then|strong="H1961"\w* \w whenever|strong="H1961"\w* \w the|strong="H6440"\w* \w evil|strong="H7451"\w* \w spirit|strong="H7307"\w* \w from|strong="H6440"\w* \w God|strong="H3027"\w* \w comes|strong="H1961"\w* \w upon|strong="H5921"\w* \w you|strong="H6440"\w*, \w he|strong="H3027"\w* \w can|strong="H5650"\w* \w play|strong="H5059"\w* \w the|strong="H6440"\w* \w lyre|strong="H3658"\w* \w and|strong="H3027"\w* \w you|strong="H6440"\w* \w will|strong="H1961"\w* \w feel|strong="H3045"\w* \w better|strong="H2895"\w*.”  
