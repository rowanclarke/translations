\v 1 \w ESTÁ|strong="H5921"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w* aburrida \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w vida|strong="H5315"\w*: daré \w yo|strong="H5315"\w* suelta \w a|strong="H3068"\w* \w mi|strong="H5921"\w* queja \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*, \w hablaré|strong="H1696"\w* \w con|strong="H5921"\w* \w amargura|strong="H4751"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w*.
