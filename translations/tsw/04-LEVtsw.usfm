\id LEV - Tsishingini (tsw)
\h Nan Ganu
\toc3 N.Gn
\toc2 Nan Ganu
\toc1 Nan Ganu
\mt1 Nan ganu
\imt1 Ucuɗuwu wa Aatagada a Nan ganu
\im Aatagada a Nan ganu a̱ ta̱ na̱ wila̱ adama a̱ a̱ga̱nda̱ na̱ kucci na A̱sula̱ a cayi aza a Isra'ila na̱ nan ganu na aa walato wila̱ nda'a.
\ip Aciyadanshi a gbain a Aatagada'a a̱yi ɗa Akiza a̱ A̱sula̱ na̱ cine ama a̱ yi aa yuwaan yi a̱ga̱nda̱, reve a yuwan wuma u le ne, adama a̱ guza̱ muwwulai n le na̱, <<A̱sula̱ a Akiza a Isra'ila.>>
\ip Idanshi i na a la'a revei ne ele a̱tsuma̱ a Aatagada'a aza a na a̱a̱ tsura̱ a̱ 19:18 ele ɗa aza a na Yesu ɗeyi wila̱ u gbain we ire, <<Vu ciga moron ma̱ nden ma̱ wu cine vu cigai aciya̱wu.>>
\iot Ili i na i ri pe a Aatagada a nda
\io1 Wila̱ adama a̱ kucci nu ucasu (1:1-7:38)
\io1 Ukatalasa u tsuganu wa Haruna no olobo a̱ yi (8:1-10:20)
\io1 Wila̱ adama e cece ni idaba (11:1-15:33)
\io1 Urana u Matara mo Ume mo Unusu (16:1-34)
\io1 Wila̱ adama a̱ nden ma akiza na̱ a̱ga̱nda̱ (17:1-27:34)
\c 1
\s1 Kucci vu ukula̱tosu
\r (N.Gn 6:8-13)
\p 
\v 1 A̱sulazuva e ɗe ta̱ Musa reve u yuwan adanshi na̱ a̱yi diga o Oogodo o Uga'asusan. Reve u damma yi,
\v 2 <<Yuwan adanshi na ama a Isra'ila vu damma le: Mantsa ma na za ro ɗu a̱a̱ ta̱wa̱a̱ A̱sulazuva na̱ kucci, u ta̱wa̱a̱ na̱ kucci vi iliyamunga ko vo oɓolo e inan ko vu mgbele ko vi ikyon.
\p 
\v 3 <<Na̱ kucci'i za vu ukula̱tosu u ɗa wi inan, u ta ca ogono a nan na ri usa̱du shi. U ta̱wa̱ na̱ a̱yi o una̱ntsu wo Oogodo o Uga'asusa'an adama wo o'wo kucci na A̱sulazuva a̱a̱ usu.
\v 4 U ta̱ kuru ukere wa̱ yi a aaci a̱ kucci vu ukula̱tosu'u, reve a̱ usuwa̱ yi a̱yi wo o'wo kucci matara mo ume mo unusu wa̱ yi.
\v 5 Vuma'a u ta paɗa moggono'o a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva. Reve olobo a Haruna nan ganu a̱ ta̱wa̱ na̱ mpasa'a, reve o kyo'onu yi e eɓele a masa'a'a suru ma na ma̱ ri o una̱ntsu wo Oogodo o Uga'asusan.
\v 6 U ta muna kucci vu ukula̱tosu'u, reve wu paɗa yi mupaɗi mupaɗi.
\v 7 Reve olobo a Haruna ganu a zuwa akina a masa'a reve e gere ɗanga a akina'a.
\v 8 Reve e gere mupaɗi'i oɓolo na aaci na abaji a mani'in a ɗanga madala na ri a masa'a'a.
\v 9 Amma wu za̱'wa̱ iliya̱tsuma̱ no okotsu a̱ yi na̱ mini. Reve ganu kula̱to yi suru a masa'a. Kucci vu ukula̱tosu ɗa, kucci na a yuwain na akina, ili i ma̱guru ma na A̱sulazuva aa uwwusa uyo'o wa yi.
\p 
\v 10 <<Nna̱ kucci vu ukula̱tosu va̱ yi za vi ikyon i ɗa ko mgbele, reve u ca ogono a na a̱ ri usa̱du shi.
\v 11 U ta paɗa yi upasu wu ugana u masa'a'a a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva. Reve olobo a Haruna nan ganu o kyo'onu mpasa ma̱ yi e eɓele a masa'a'a suru a̱ ka̱nda̱ruwa̱.
\v 12 Wu paɗa yi mupaɗi mupaɗi, reve ganu gere le, oɓolo na aaci na abaji a mani'in a ɗanga madala na ri a masa'a'a.
\v 13 Wu za̱'wa̱ iliya̱tsuma̱ no okotsu na̱ mini, reve ganu ta̱wa̱ na̱ a̱yi suru, a̱vu u kula̱to yi a masa'a'a. Kucci vu ukula̱tosu ɗa, kucci na a yuwain na akina, ili i ma̱guru ma na A̱sulazuva aa uwwusa uyo'o wa yi.
\p 
\v 14 <<Na̱ kucci vu ukula̱tosu a̱ tyo ya̱ A̱sulazuva'a za vu nnunu n ɗa, u ta ca muɗa ko ma̱ma̱rukuku.
\v 15 Ganu ta̱ ta̱wa̱ na̱ a̱yi a masa'a reve u punda̱ra̱ yi yinlu u mula̱ aaci'i. Reve u kula̱to yi a masa'a'a. Reve a lyawa mpasa ma̱ yi mo ocusho a̱ nge'en m masa'a'a.
\v 16 U to foɗo owofun ni ili i na i ri pe suru, reve u vari yi e eeɓele a asana a masa'a'a, uba̱ta̱ wo okomo.
\v 17 U te reme evelu a̱ yi reve u ɗa̱ra̱la̱ niyi, amma waa karala niyi shi. Reve ganu'u u kula̱to yi a masa'a'a a ɗanga na ri a madala. Kucci vu ukula̱tosu ɗa, kucci na a yuwain na akina, ili i ma̱guru ma na A̱sulazuva aa uwwusa uyo'o wa̱ yi.
\c 2
\s1 Kucci vi ishina
\r (N.Gn 6:14-23)
\p 
\v 1 <<Na̱ vuma ta̱wa̱a̱ A̱sulazuva na̱ kucci vi ishina, u ta̱ ta̱wa̱ na̱ yira i lashi. U ta̱ tsun yi mani'in ni ili i ma̱guru i na a̱ tsu ɗe furenkisen.
\v 2 Reve u ta̱wa̱ na̱ a̱yi uba̱ta̱ wo olobo a Haruna nan ganu. Ganu to shiton ukere na̱ yira i lashi'i na̱ mani'in oɓolo na̱ furenkisen suru. Reve u kula̱to yi ili yu ucuwusan zuva masa'a'a, kucci na a yuwain na akina, ili i ma̱guru ma na A̱sulazuva aa uwwusa uyo'o wa̱ yi.
\v 3 Akapi a̱ kucci vi ishina na buwai, u to o'wo za va Haruna no olobo a̱ yi, a̱yi ɗa u la'ai akiza u kucci na a cayi A̱sulazuva va akina.
\p 
\v 4 <<A mantsa ma na i ta̱wa̱i na̱ kucci vi ishina i na a zatsuyi a wuwan, wo o'wo za yira i lashi, opopofu a na a̱ ri na̱ wolilo shi na a̱ ja̱mba̱ra̱i na̱ mani'in, ko emeshen a na a yuwain babu wolilo na a putalai na̱ mani'in ma ɗa.
\v 5 Na̱ kucci yira vi ishina va̱ wu yi za na a kangalai a ataɗa a ɗa, a yuwan yi na̱ yira i lashi i na a̱ ja̱mba̱ra̱i na̱ mani'in babu wolilo.
\v 6 Vu busa yi mubushi mubushi, reve vu tsun yi mani'in, kucci vi ishina ɗa.
\v 7 Nna̱ kucci yira vi ishina va̱ wu vi ili i na a raluyi a ataɗa a ɗa, a yuwan yi na̱ yira i lashi na̱ mani'in.
\v 8 I ta̱wa̱a̱ A̱sulazuva kucci vi ishina vi ili i na a yuwain ni ili i nda. I ca ganu ele, a̱yi ɗa wa̱a̱ ta̱wa̱ ne ele a masa'a.
\v 9 U te kene pe ili yu ucuwusan a̱tsuma̱ a̱ kucci vi ishina'a, reve u kula̱to yi a masa'a'a. Kucci na a yuwain na akina, ili i ma̱guru ma na A̱sulazuva aa uwwusa uyo'o wa yi.
\v 10 Akapi a̱ kucci vi ishina na buwai u to o'wo za va Haruna no olobo a̱ yi, a̱yi ɗa u la'ai akiza u kucci na a cayi A̱sulazuva va akina.
\p 
\v 11 <<Babu kucci vi ishina na a̱a̱ ta̱wa̱a̱ A̱sulazuva i na aa yuwan na̱ wolilo, adama a na ya̱a̱ kula̱to wolilo ko ishiki a̱tsuma̱ a̱ kucci na a cayi A̱sulazuva na akina shi.
\v 12 I ta gura ta̱wa̱ ne ele tsa̱ kucci vu umatsun wu ufaru ya̱ A̱sulazuva, agba aa yuwan kucci ne ele a masa'a kucci ma̱guru mo uyo'o shi.
\v 13 I ta̱ tsun kucci vi ishina i ɗu suru akpaɗi. She i kuɗa̱ a̱ tsun akpaɗi a akucunu\f + \fr 2:13 \fq akpaɗi a akucunu \ft Akpaɗi pa nda a̱ ta̱ o una̱ wu nzuwulai n na A̱sulazuva a yuwain na aza a Isra'ila\f* a̱ A̱sula̱ a̱ ɗu a̱ kucci vi ishina ɗu wan. I tsun akpaɗi a̱ kucci ɗu suru.
\p 
\v 14 <<Nni i ta̱wa̱a̱ A̱sulazuva na̱ kucci vi ishina vu umatsun wu ufaru, i ca a̱ga̱za̱ e ishina i sa'avu o uzuwun i na a kparai.
\v 15 Reve i tsun yi mani'in na̱ furenkisen, kucci vi ishina ɗa.
\v 16 Ganu ta̱ kula̱to ili yu ucuwusan diga pe e ishina i na a kparai'i na̱ mani'in oɓolo ni ili i furenkise'en suru, kucci na a cayi A̱sulazuva va akina.
\c 3
\s1 Kucci muwwulai
\r (N.Gn 7:11-21)
\p 
\v 1 <<Nna̱ kucci na vuma a̱a̱ ta̱wa̱a̱ za muwwulai ɗa, u ta ca diga a̱tsuma̱ o oɓolo e inan ogono ko a̱na̱wu. U ta ca za na ri usa̱du shi e ekere a̱ A̱sulazuva.
\v 2 U ta̱ kuru ukere wa̱ yi a aaci e ili i na u cayi, reve u paɗa yi o u'uwata wo Oogodo o Uga'asusan. Reve olobo a Haruna nan ganu o kyo'onu mpasa'a e eɓele a masa'a'a suru a̱ ka̱nda̱ruwa̱.
\v 3 Diga pe a̱ kucci muwwulai'i u ta̱ ta̱wa̱a̱ A̱sulazuva na̱ kucci vi ili i nda na a yuwain na akina: abaji a mani'in ma na ma palai iliya̱tsuma̱ suru na̱ za na ri uɓoluloi ni iliya̱tsuma̱'a̱,
\v 4 oɓolo na a'ilu e re na abaji a mani'in ma na ma̱ ri uɓoluloi ne ele ma na ma̱ ri zuzu ne eetele e ikyun, nu upasu wa assuvu u na u la'ai ulobonu, za na woo foɗo oɓolo na a'ilu'u.
\v 5 Reve olobo a Haruna a̱ kula̱to le a masa'a'a oɓolo na̱ kucci vu ukula̱tosu u na u ri a ɗanga madala, kucci na a yuwain na akina, ili i ma̱guru ma na A̱sulazuva aa uwwusa uyo'o wa̱ yi.
\p 
\v 6 <<Nnu u ca diga e ikyon ko e mgbele kucci muwwulai e ekere a̱ A̱sulazuva, u ta ca ogono ko a̱na̱wu a na a̱ ri usa̱du shi.
\v 7 Nnu u ca ma̱giri'i, u ta̱ ta̱wa̱ na̱ a̱yi a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 8 U ta̱ kuru ukere wa̱ yi a aaci e ili i na u cayi, reve u paɗa yi elime o Oogodo o Uga'asusan. Reve olobo a Haruna o kyo'onu mpasa ma̱ yi e eɓele a masa'a'a suru a̱ ka̱nda̱ruwa̱.
\v 9 Diga pe a̱ kucci muwwulai'i u ta ca kucci vi ili i nda na a yuwain na akina uba̱ta̱ wa̱ A̱sulazuva: mani'in ma̱ yi na̱ wizan u na u ri na̱ mani'in suru za na aa paɗa zuzu ne eetele e ikyun, oɓolo na̱ mani'in ma na ma palai iliya̱tsuma̱ suru ko za na ri uɓoluloi ni iliya̱tsuma̱'a̱,
\v 10 na a'ilu e re na̱ mani'in ma na ma̱ ri uɓoluloi ne ele ma na ma̱ ri zuzu ne eetele e ikyun, nu upasu wa assuvu u na u la'ai ulobonu, za na woo foɗo oɓolo na a'ilu'u.
\v 11 Ganu ta̱ kula̱to le a masa'a, tsi ilyalya kucci na a cayi A̱sulazuva na akina.
\p 
\v 12 <<Na̱ kucci va̱ yi za megbele ma ɗa, u ta̱ ta̱wa̱ na̱ a̱yi a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 13 U ta̱ kuru ukere wa̱ yi a aaci a̱ yi, reve u paɗa yi elime o una̱ntsu wo Oogodo o Uga'asusan. Reve olobo a Haruna o kyo'onu mpasa ma̱ yi e eɓele a masa'a'a suru a̱ ka̱nda̱ruwa̱.
\v 14 Diga e ili i na u cayi'i u ta ca A̱sulazuva ili i nda kucci va akina: abaji a mani'in ma na ma palai iliya̱tsuma̱ suru na̱ za na ri uɓoluloi ne ele,
\v 15 na a'ilu e re na̱ mani'in ma na ma̱ ri uɓoluloi ne ele ma na ma̱ ri zuzu ne eetele e ikyun, nu upasu wa assuvu u na u la'ai ulobonu, za na woo foɗo oɓolo na a'ilu'u.
\v 16 Ganu ta̱ kula̱to le a masa'a tsi ilyalya, kucci na a yuwain va akina ili i ma̱guru mo uyo'o. Abaji a mani'in suru za va A̱sulazuva a ɗa.
\p 
\v 17 <<A̱yi nda u to o'wo ili i mayan kuci hali a̱ tyo mantsa suru, uba̱ta̱ u na i da̱nuyi suru. She i tama abaji a mani'in ko mpasa wan.>>
\c 4
\s1 Kucci vu unusu
\r (N.Gn 6:25-30)
\p 
\v 1 Reve A̱sulazuva a damma Musa,
\v 2 <<Damma aza a Isra'ila, na̱ vuma yuwan unusu o ucigu wa̱ yi shi a̱vu u yuwan ili i ta̱ e ili i na A̱sulazuva a zuwai she a yuwan wan,
\v 3 nna̱ ganu na a̱ tsuwa̱yin mani'in yuwan unusu, reve u ta̱wa̱a̱ ama nu unusu, u ta̱ ta̱wa̱a̱ A̱sulazuva na̱ moggono ma nan ma na ma̱ ri usa̱du shi kucci adama o unusu u na u yuwain.
\v 4 U ta̱ ta̱wa̱a̱ na̱ moggono'o o u'uwata wo Oogodo o Uga'asusan a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva. U ta̱ kuru ukere wa̱ yi a aaci a̱ yi, reve u paɗa yi a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 5 Reve ganu na a̱ tsuwa̱yin mani'i'in u kene mpasa m moggono'o reve u tara yi a uwa o Oogodo o Uga'asusan.
\v 6 Waru u tsupu aakatsu a̱ yi a mpasa'a, reve wu kyo'onu yi toto ucindere a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva elime o umuna wa̱ A̱a̱'isa̱.
\v 7 Reve ganu putala mpasa n ro a avana a masa'a e ili i ma̱guru mo uyo'o ma na ma̱ ri a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva o Oogodo o Uga'asusan. Reve u tsun akapi a mpasa m moggono'o e ikyun i masa'a ma̱ kucci vu ukula̱tosu o u'uwata wo Oogodo o Uga'asusan.
\v 8 Reve u foɗo abaji a mani'in o moggono ma na a cayi kucci adama o unusu'u suru, na̱ mani'in ma na ma palai iliya̱tsuma̱ na̱ za na ri uɓoluloi ni iliya̱tsuma̱ suru,
\v 9 na a'ilu e re na̱ mani'in ma na ma̱ ri uɓoluloi ne ele ma na ma̱ ri zuzu ne eetele e ikyun, nu upasu wa assuvu u na u la'ai ulobonu, za na woo foɗo oɓolo na a'ilu'u.
\v 10 U to foɗo mani'i'in cine o tsu foɗo za vo ogono a na a cayi adama a muwwulai. Reve ganu kula̱to le a masa'a mo ukula̱tosu u kucci.
\v 11 Amma ukwan u moggono'o ni inama ya̱ yi suru na aaci a̱ yi na ana a̱ yi ni iliya̱tsuma̱ ya̱ yi na̱ a̱ya̱n a̱ yi,
\v 12 na akapi o moggono'o suru, u ta tara le o uta̱ o ucina̱ wu uva̱la̱ta̱ a̱ tyo uba̱ta̱ u na u ri cece, uba̱ta̱ u na oo ocosu okomo. Reve u kula̱to le ɗe na̱ ɗanga madala e edemu o okomo'o.
\p 
\v 13 <<Nna ama a Isra'ila suru a yuwan unusu o ucigu u le shi a̱vu a yuwan ili i ta̱ e ili i na A̱sulazuva a zuwai she a yuwan wan, ko na̱ a̱ shi e reve ni ili'i shi, a̱ ta̱ nu unusu.
\v 14 Nna̱ a̱ ta̱wa̱ e reve nu unusu u na a yuwain, a ta ca kucci moggono ma nan adama a̱ kucci vu unusu o una̱ntsu wo Oogodo o Uga'asusan.
\v 15 Mbara ma ama a Isra'ila'a n ta̱ kuru ekere e le a aaci o moggono ma na'an a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva, reve a paɗa yi lo.
\v 16 Reve ganu na a̱ tsuwa̱yin mani'in u kene mpasa m moggono'o a uwa pe o Oogodo o Uga'asusa'an.
\v 17 U ta̱ tsupu aakatsu a̱ yi a̱tsuma̱ a mpasa'a reve wu kyo'onu yi a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva toto ucindere elime o umuna'a.
\v 18 Reve ganu'u u putala mpasa n ro a avana a masa'a'a ma na ma̱ ri a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva o Oogodo o Uga'asusan. Akapi a mpasa n na m buwai reve u tsun yi e ikyun i masa'a ma̱ kucci vu ukula̱tosu o u'uwata wo Oogodo o Uga'asusan.
\v 19 U to foɗo abaji a mani'in ma̱ yi suru, reve u kula̱to yi a masa'a'a.
\v 20 U ta yuwan na̱ moggono ma na'an cine u yuwain na̱ moggono ma na a cayi kucci adama o unusu. Ne tsunda tsa ɗa ganu a yuwaan le kucci matara mo ume mo unusu, reve gba a yuwaan le gafura.
\v 21 Reve u tara na'an o uta̱ o ucina̱ wu uva̱la̱ta̱ a̱vu u kula̱to yi cine u kula̱toi nan vu ufaru. A̱yi nda a̱yi ɗa kucci vu unusu adama a ama a Isra'ila.
\p 
\v 22 <<Nna̱ zagbain yuwan unusu o ucigu wa̱ yi shi, a̱vu u yuwan ili i ta̱ e ili i na A̱sulazuva A̱sula̱ a̱ yi a zuwai, u ta̱ nu unusu.
\v 23 Nno o roco yi unusu u na u yuwain, u ta ca kucci ma̱ga̱ji ma na ma̱ ri usa̱du shi.
\v 24 U ta̱ kuru ukere wa̱ yi a aaci a̱ ma̱ga̱ji'i, reve u paɗa yi uba̱ta̱ u na a tsu paɗasa kucci na a̱ kula̱tosu a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva. Kucci adama o unusu u ɗa.
\v 25 Reve ganu shepe mpasa n kucci adama o unusu'u na aakatsu a̱ yi, reve u putala a avana a masa'a ma̱ kucci vu ukula̱tosu, a̱vu u tsun akapi a mpasa'a e ikyun i masa'a'a.
\v 26 U ta̱ kula̱to abaji a mani'i'in suru a masa'a cine u kula̱toi mani'in ma̱ kucci muwwulai. Ne ɗa ganu aa ca kucci adama a matara mo ume mo unusu adama a zagbai'in, reve a yuwaan yi gafura.
\p 
\v 27 <<Na̱ vuma ro a̱tsuma̱ a ama yuwan unusu nu ucigu wa̱ yi shi, a̱vu u yuwan ili i ta̱ e ili i na A̱sulazuva a zuwai, u ta̱ nu unusu.
\v 28 Nno o roco yi unusu u na u yuwain, u ta̱ ta̱wa̱a̱ na̱ a̱na̱wu e megbele a na a̱ ri usa̱du shi kucci o una̱ wu unusu u na u yuwain.
\v 29 U ta̱ kuru ukere wa̱ yi a aaci a̱ kucci vu unusu'u reve u paɗa yi uba̱ta̱ u kucci vu ukula̱tosu.
\v 30 Reve ganu shepe mpasa'a na aakatsu a̱ yi, reve u putala a avana a masa'a ma̱ kucci vu ukula̱tosu. Reve u tsun akapi a na a buwai e ikyun i masa'a'a.
\v 31 U to foɗo abaji a mani'in suru cine o tsu foɗo mani'in ma̱ kucci muwwulai. Reve ganu kula̱to yi a masa'a ili i ma̱guru mo uyo'o e ekere a̱ A̱sulazuva. Ne ɗa ganu a yuwaan yi kucci matara mo ume mo unusu, a̱ ta̱ gba a yuwaan yi gafura.
\p 
\v 32 <<Nna̱ mokyokyon ma ɗa wa̱a̱ ta̱wa̱a̱ kucci vu unusu va̱ yi, a̱na̱wu a ɗa wa̱a̱ ta̱wa̱a̱ za na ri usa̱du shi.
\v 33 U ta̱ kuru ukere wa̱ yi a aaci a̱ yi, reve u paɗa yi adama a̱ kucci vu unusu uba̱ta̱ u na a tsu paɗasa kucci vu ukula̱tosu.
\v 34 Ganu ta̱ shepe mpasa n kucci vu unusu'u na aakatsu a̱ yi reve u putala a avana a masa'a ma̱ kucci vu ukula̱tosu. Reve u tsun akapi a mpasa'a e ikyun i masa'a'a.
\v 35 U to foɗo abaji a mani'in suru cine o tsu foɗo mani'in mo kyon kucci muwwulai. Reve ganu kula̱to yi a masa'a'a zuva kucci na a cayi A̱sulazuva va akina. Ne ɗa ganu aa yuwaan vuma'a kucci matara mo ume mo unusu u na u yuwain, a̱ ta̱ gba a yuwaan yi gafura.
\c 5
\p 
\v 1 <<Nna̱ vuma kuɗa̱ a yuwan adanshi a mantsa ma na e ɗe niyi adama u damma ili i na we enei ko u revei, u yuwan ta̱ unusu, waru ume wu unusu u ndolo u ta̱ a aci a̱ yi.
\v 2 Ko gba na̱ vuma ju'wa̱n ili i na a tarai ili yi idaba i ɗa nu urevu wa̱ yi shi, ko a̱kwa̱kwa̱ a nama vu una ɗa, ko a̱kwa̱kwa̱ a nama vu u'wa ko a̱kwa̱kwa̱ e ili i na i ri e ika̱ta̱pu, wo o'wo ta̱ idaba. Waru u ta̱ nu unusu ko na wo o'woi u ri nu urevu shi.
\v 3 Ko gba nu u ju'wa̱n cu'un vi ili yi idaba i na i tsu uta̱ uba̱ta̱ u vuma i na i tsu zuwa vuma o o'wo idaba biti, ko nu u ri nu urevu shi, nnu u ta̱wa̱ u reve wo o'wo ta̱ za vu unusu.
\v 4 Ko gba na̱ vuma yuwan akucunu nu una̱ wa̱ yi iwa̱u a na waa yuwan ili i ro, ko ni iwuya i ɗa ko isa'ani, a̱tsuma̱ e ili i na suru vuma yuwain akucunu na̱ majiyan shi, ko nu u reve na̱ a̱yi shi, nnu u ta̱wa̱ u reve wo o'wo ta̱ za vu unusu.
\v 5 Nna̱ vuma yuwan ta̱ unusu u ta̱ a̱tsuma̱ a̱ nusu nda, u damma unusu u na u yuwain.
\v 6 U ta̱ ta̱wa̱a̱ na̱ mokyokyon ko megbele kucci vu unusu va̱ yi uba̱ta̱ wa̱ A̱sulazuva adama o unusu u na u yuwain. Reve ganu ca kucci matara mo ume mo unusu adama o unusu wa̱ yi.
\p 
\v 7 <<Agba nna̱ wa̱a̱ tsura̱ mokyokyon shi, reve u ta̱wa̱a̱ A̱sulazuva na̱ muɗa n re ko murukuku n re adama a atsupu o unusu u na u yuwain, za ta̱ ta̱ adama a̱ kucci vu unusu za ta̱ ta̱ waru adama a̱ kucci vu ukula̱tosu.
\v 8 U ta̱ ta̱wa̱ ne ele uba̱ta̱ wa ganu, za na aa fara ca za vu unusu. U ta̱ punda̱ra̱ yi yinlu amma wa̱a̱ mula̱ aaci'i shi.
\v 9 U to kyo'onu mpasa n kucci vu unusu e eɓele a masa'a'a, reve u koso kpoko akapi a mpasa n na m buwai e ikyun i masa'a'a, kucci adama o unusu u ɗa.
\v 10 Reve u ca za ire kucci vu ukula̱tosu cine a zuwai a yuwan. Ne ɗa ganu aa yuwan kucci matara mo ume mo unusu adama o unusu u na vuma'a u yuwain, reve gba a yuwaan yi gafura.
\p 
\v 11 <<Agba na̱ waa gura tsura̱ muɗa n re ko murukuku n re shi, to u ta̱ ta̱wa̱a̱ nu ukunzuwu u ta̱ u efa\f + \fr 5:11 \fq efa \ft Efa a̱yi ɗa makundatsu ma gbain ma na aza a Isra'ila a yuwusayin akunda\f* u yira i lashi kucci adama o unusu wa̱ yi. She u tsun yi mani'in wan waru she u tsun yi ili i ma̱guru wan, adama a na kucci adama o unusu u ɗa.
\v 12 Vuma'a u ta tara yira'a a̱ tyo ya ganu, reve ganu'u u kene ukere u ta̱ tapu ili yu ucuwusan. Reve u kula̱to yi a masa'a zuva vi ilyalya i na a cayi A̱sulazuva va akina. Kucci adama o unusu u ɗa.
\v 13 Ne tsunda tsa ɗa ganu aa yuwan kucci matara mo ume mo unusu adama o unusu u na vuma'a u yuwain, reve gba a yuwaan yi gafura. Ili i na i buwai u to o'wo za va ganu, cine u ri a̱ kucci vi ishina.>>
\s1 Kucci makuɗa ma̱ wila̱
\p 
\v 14 Reve A̱sulazuva a damma Musa,
\v 15 <<Nna̱ za ro a̱tsuma̱ a̱ ɗu yuwan ulambu wa̱ a̱ɓula̱, reve u yuwan unusu nu ucigu wa̱ yi shi e ekere e ili i na a tarai na akiza ya̱ A̱sulazuva, u ta̱ ta̱wa̱a̱ A̱sulazuva kucci vu unusu a̱a̱giri'i a̱tsuma̱ o oɓolo a̱ yi za na ri usa̱du shi. Ikebe ya̱ a̱a̱giri'i'i u te reme azurufa vi ili i na aa yuwusaan ulinga na̱ a̱yi a̱ a̱a̱'isa̱. Kucci makuɗa ma̱ wila̱ ma ɗa.
\v 16 Vuma'a u ta tsupa adama e ili i na u yuwain unusu e ili ya akiza'a. Reve u da̱shi za ta̱ a̱tsuma̱ o ozo o ton, reve u ca ganu. Ganu ta yuwan kucci matara mo ume mo unusu adama a̱ yi oɓolo na̱ a̱a̱giri'i a̱ kucci makuɗa ma̱ wila̱, reve gba a yuwaan yi gafura.
\p 
\v 17 <<Nna̱ vuma yuwan unusu a̱vu u yuwan ili i ta̱ a̱tsuma̱ e ili i na A̱sulazuva a zuwai she a yuwan wan, ko nu u shi u reve na̱ a̱yi shi, u kuɗa ta̱ wila̱ waru ume wu unusu u ndolo u ta̱ a aci a̱ yi.
\v 18 U ta̱ ta̱wa̱a̱ ganu na̱ a̱a̱giri'i a na a̱ ri usa̱du shi kucci makuɗa ma̱ wila̱ diga o oɓolo e ikyon ya̱ yi, ikebe ya̱ yi i yuwan una̱ta̱ nu ukunzuwu u na a zuwai. Ne ɗa ganu aa yuwan kucci matara mo ume mo unusu u vuma'a adama o unusu u na u yuwain nu ucigu shi. Reve gba a yuwaan yi gafura.
\v 19 Kucci vu unusu u ɗa, u yuwaan ta̱ A̱sulazuva unusu na amayun.>>
\c 6
\p 
\v 1 Reve A̱sulazuva a damma Musa,
\v 2 <<Nna̱ vuma yuwan unusu wu ulambu wa̱ a̱ɓula̱ e ekere a̱ A̱sulazuva wu luma̱ moron ma̱ nden ma̱ yi, ni ili i na a ca niyi izuwa ko u yuwan yi wivu ko gba shi u paala moron ma̱ nden ma̱ yi,
\v 3 ko gba u tsura̱ ili i na i puwa̱yin, reve u yuwan epen adama a̱ yi ko u kucina ne epen, ko u yuwan unusu u ro u na ama aa gura yuwan,
\v 4 nu u nusan a̱vu u ta̱wa̱ u reve nu unusu wa̱ yi, u ta̱ ka̱mbuwa̱ ili i na wi iva̱i ko ili i na u tsura̱i na a'usa ko ni ili i na a ca niyi izuwa ko ili i na u tsura̱i i na i puwa̱yin,
\v 5 ko e ili i na u yuwain akucunu e epen adama a̱ yi. U ta̱ ka̱mbuwa̱ yi suru hali u da̱shi za ta̱ a̱tsuma̱ o ozo o ton. Reve u ca za vi ili o urana u na waa ca kucci vu unusu va̱ yi.
\v 6 Reve u ta̱wa̱a̱ ganu atsupu o unusu a̱a̱giri'i a na a̱ ri usa̱du shi diga o oɓolo e ikyon kucci makuɗa ma̱ wila̱ e ekere a̱ A̱sulazuva, ikebe ya̱ yi i yuwan una̱ta̱ nu ukunzuwu u na a zuwai.
\v 7 Ne ɗa ganu aa yuwan kucci matara mo ume mo unusu u vuma'a a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva. Reve a yuwaan yi gafura vu unusu u na u yuwain e ili i nda i na i zuwa niyi wo o'woi za vu unusu.>>
\s1 Kucci vu ukula̱tosu
\r (N.Gn 1:1-17)
\p 
\v 8 A̱sulazuva waru a damma ta̱ Musa,
\v 9 <<Vu damma Haruna no olobo a̱ yi a na, apa nda wila̱ u kucci vu ukula̱tosu: Kucci vu ukula̱tosu u ta̱ asa a akinkina zuva masa'a hali usana, waru akina'a a̱ ta̱ da̱na̱ a madala.
\v 10 Reve ganu oto a̱tugu o okoro na̱ mokoɗi ma aacaka ma̱ yi. Reve u pura̱ okomo a̱ kucci vu ukula̱tosu u tsun a̱ nge'en m masa'a.
\v 11 Reve u foɗo itana i nda a̱vu wo oto ozo o ro. Reve u tanu okomo'o a̱ tyo o ucina̱ wu uva̱la̱ta̱ uba̱ta̱ u cece.
\v 12 Akina a na a̱ ri a masa'a'a u ta̱ da̱na̱ a madala, she u kima̱ wan. Ganu ta̱ ri n da̱shishi ɗanga a akina'a usana suru. Reve u gere ɗe kucci vu ukula̱tosu a akina'a u kula̱to abaji a mani'in kucci muwwulai ɗe.
\v 13 Akina'a u da̱na̱ a̱ madala a masa'a'a, she u kima̱ wan.
\s1 Kucci vi ishina
\r (N.Gn 2:1-6)
\p 
\v 14 <<Apa nda cine a̱ ri n yuwusan kucci vi ishina: Olobo a Haruna a̱ ta̱ ta̱wa̱ na̱ a̱yi uba̱ta̱ wa̱ A̱sulazuva elime a masa'a'a.
\v 15 Ganu te kene ukere u ta̱ tapu pe a yira i lashi'i na̱ mani'in oɓolo ni ili i ma̱guru suru, reve u kula̱to le ili yu ucuwusan a masa'a'a, ili i ma̱guru mo uyo'o e ekere a̱ A̱sulazuva.
\v 16 Haruna no olobo a̱ yi a ta tama akapi a na a buwai. A ta tama yi babu wolilo uba̱ta̱ wa akiza o ukowo wo Oogodo o Uga'asusan.
\v 17 A̱a̱ zun yi na̱ wolilo shi, n ca ta̱ nan ganu a̱yi wo o'wo akunda e le e ili i na a ca numu va akina. A̱yi ɗa ili i na i la'ai akiza, tsa̱ kucci vu unusu na̱ kucci makuɗa ma̱ wila̱.
\v 18 Ulobo suru a̱tsuma̱ o olobo a Haruna u ta tama yi, cine a zuwai hali a̱ tyo a mantsa me elime, ili i na a cayi A̱sulazuva va akina. Ili i na suru i ju'wa̱in nle, u to o'wo na akiza.>>
\p 
\v 19 A̱sulazuva a yuwan ta̱ adanshi na̱ Musa u damma,
\v 20 <<Apa nda kucci na Haruna no olobo a̱ yi aa ca A̱sulazuva urana u na a̱ tsun niyi mani'in: ukunzuwu u ta̱ u efa u yira i lashi a̱tsuma̱ a kupa, cine a̱ tsu ta̱wa̱a̱ na̱ kucci vi ishina. A̱ ta̱ ta̱wa̱a̱ na akapi nu usana akapi waru nu ulivu.
\v 21 A̱ ta̱ ja̱mba̱ra̱ yi na̱ mani'in a̱vu a kangala yi a ataɗa o ukangalu. A̱ ta̱ ta̱wa̱ na̱ a̱yi uja̱mba̱ru ulobonu, ukangalu mukutsu mukutsu tsa̱ kucci vi ishina, ili i ma̱guru mo uyo'o e ekere a̱ A̱sulazuva.
\v 22 Ulobo u na waa tara e ekere a̱ yi tsa ganu na a̱ tsuyin mani'in, a̱yi ɗa woo foɓo yi. Akunda a̱ A̱sulazuva a ɗa kuci, a̱ ta̱ kula̱to yi suru.
\v 23 Kucci vi ishina va ganu suru a̱ ta̱ kula̱to yi suru, aa lyuwa yi shi.>>
\s1 Kucci vu unusu
\r (N.Gn 4:1-35)
\p 
\v 24 Reve A̱sulazuva a damma Musa,
\v 25 <<Yuwan adanshi na̱ Haruna no olobo a̱ yi: Apa nda ure u mayan ma̱ kucci vu unusu: uba̱ta̱ u na a tsu paɗa kucci vu ukula̱tosu lo ɗa aa paɗa kucci vu unusu a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva. A̱yi ɗa kucci na la'ai akiza.
\v 26 Ganu na cayi kucci'i u ta tama inama'a. U ta tama yi uba̱ta̱ wa akiza, o ukowo wo Oogodo o Uga'asusan.
\v 27 Ili i na biti i ju'wa̱in inama ya̱ yi u to o'wo na akiza, waru na̱ mpasa ma̱ yi n daɓa utugu, a̱ ta̱ za̱'wa̱ utugu'u uba̱ta̱ wa akiza.
\v 28 Reve o ɓoso upondo u ci'in u na a su'wain inama'a. Amma na a su'wan yi ta̱ o upondo wu rumushili o to kongoro yi reve e lece yi na̱ mini.
\v 29 Ulobo suru a̱tsuma̱ o umatsun wa ganu u ta gura tama inama'a, a̱yi ɗa u la'ai akiza.
\v 30 Amma kucci vu unusu u na suru a̱ ta̱wa̱yi na̱ mpasa ma̱ yi o Oogodo o Uga'asusan adama a matara mo ume mo unusu Uba̱ta̱ wa Akiza, a̱ ta̱ kula̱to yi na akina.
\c 7
\s1 Kucci Makuɗa ma̱ wila̱
\r (N.Gn 5:1-6:7)
\p 
\v 1 <<Apa nda re mayan ma̱ kucci adama a makuɗa ma̱ wila̱. Kucci na la'ai akiza a ɗa.
\v 2 A ta paɗa ili i na a̱ ta̱wa̱yi kucci adama o unusu'u uba̱ta̱ u na a tsu paɗa kucci vu ukula̱tosu. Reve o kyo'onu mpasa ma̱ yi e eɓele a masa'a'a suru a̱ ka̱nda̱ruwa̱.
\v 3 A ta ca abaji a mani'in ma̱ yi suru, abaji a mani'in ma wizan na̱ mani'in ma na ma̱ ri uɓoluloi ni iliya̱tsuma̱,
\v 4 oɓolo na a'ilu e re na abaji a mani'in me ele ma na ma̱ ri zuzu ne eetele e ikyun, nu upasu wa assuvu u na u la'ai ulobonu, za na oo foɗo oɓolo na a'ilu'u.
\v 5 Ganu ta̱ kula̱to le a masa'a'a kucci na a cayi A̱sulazuva va akina, a̱yi ɗa kucci makuɗa ma̱ wila̱.
\v 6 Ulobo suru o u'wa wa ganu u ta gura tama yi. A ta tama yi uba̱ta̱ wa akiza. Kucci na la'ai akiza a ɗa.
\p 
\v 7 <<Ure u mayan ma̱ kucci makuɗa ma̱ wila̱ una̱ta̱ u ɗa u ri na̱ za kucci vu unusu. Ganu na yuwain kucci matara mo ume mo unusu u to o'wo ni ili i na i buwai.
\v 8 Waru ganu na yuwain kucci vu ukula̱tosu o una̱ u vuma suru, u to o'wo nu ukwan u kucci vu ukula̱tosu u na u cayi'i.
\v 9 Waru kucci vi ishina na a̱ zatsuyi suru a wuwan oɓolo ni ili i na o raluyi e ebelu o ukangalu ko a ataɗa o ukangalu, u to o'wo za va ganu na yuwan niyi.
\v 10 Amma kucci vi ishina na a̱ ja̱mba̱ra̱i na̱ mani'in ko babu mani'in e te ne'esheen olobo a Haruna una̱ta̱.
\s1 Kucci muwwulai
\r (N.Gn 3:1-17)
\p 
\v 11 <<Apa nda re mayan ma̱ kucci muwwulai na vuma aa gura ta̱wa̱a̱ A̱sulazuva:
\v 12 Nnu u ca yi o una̱ wu ugodyusho, u ta ca emeshen a na a̱ ja̱mba̱ra̱i na̱ mani'in oɓolo no opopofu a na a̱ ri na̱ wolilo shi a na a̱ ja̱mba̱ra̱i na̱ mani'in, no opopofu a yira i lashi i na i ri na̱ wolilo shi i na a̱ ja̱mba̱ra̱i na̱ mani'in ulobonu.
\v 13 Reve u ca akpatali o opopofu a na a̱ ri na̱ wolilo oɓolo na̱ kucci muwwulai.
\v 14 A̱ kucci'i suru u ta ca aakpatali o opopofu a̱ ta̱ uneꞌe la̱nga̱ e ekere a̱ A̱sulazuva. Opopofu'u o to o'wo za va ganu na kyo'onuyi mpasa n kucci muwwulai'i.
\v 15 Waru a ta tama inama i kucci muwwulai vu ugodyusho'o urana u na a yuwan niyi. Waa lyawa akapi a asa shi.
\p 
\v 16 <<Amma nna̱ kucci na u cayi za vu ushitosun wa akucunu a ɗa ko gba kucci vu ucigu wo okolo a ɗa, a ta tama yi o urana u na a yuwan niyi. Agba akapi a na a buwai a ta gura tama yi nu usana u tawa.
\v 17 Amma nnu u pasa hali o urana wa ta'atsu a̱ ta̱ kula̱to yi.
\v 18 Nna a tama nama kucci muwwulai o urana wa ta'atsu, a̱a̱ ushi kucci va̱ yi shi. Waru aa tara kucci va̱ yi ili i ro shi, adama a na ili yi idaba i ɗa. Za na waru tamai inama'a ume wu unusu u ndolo u ta̱ a aci a̱ yi.
\p 
\v 19 <<Nama na ju'wa̱in ili yi idaba suru aa tama yi shi. A̱ ta̱ kula̱to yi. Adama e inama gba, za na suru ri cece ta gura tama inama'a.
\v 20 Amma za na suru tamai inama i kucci muwwulai ya̱ A̱sulazuva a̱yi gba u ta̱ idaba, a ta tawa yi a̱tsuma̱ a ama a̱ yi.
\v 21 Nna̱ vuma ju'wa̱n ili yi idaba, ko za vuma ko za vu nama ko ili yi idaba i ro, reve waru u tama nama na a cayi A̱sulazuva kucci muwwulai, a ta tawa vuma ndolo a̱tsuma̱ a ama a̱ yi.>>
\s1 A putsa ta̱ utamu wa abaji a mani'in na̱ mpasa
\p 
\v 22 A̱sulazuva a damma ta̱ Musa,
\v 23 <<Damma aza a Isra'ila, she i tama abaji a mani'in ma nan ko mo kyon ko me megbele wan.
\v 24 Waru she i tama mani'in ma nama na kuwa̱i na aciya̱yi wan, ko gba nama na nama vu una vu unai wan. Amma i ta gura yuwan ili i ro na̱ a̱yi.
\v 25 Za na suru tamai abaji a mani'in ma nama na a cayi A̱sulazuva kucci va akina, a ta tawa yi a̱tsuma̱ a ama a̱ yi.
\v 26 Waru uba̱ta̱ u na i da̱nuyi suru she i tama mpasa wan, ko za manunu ko za vu nama.
\v 27 Za na suru tamai mpasa, a ta tawa yi a̱tsuma̱ a ama a̱ yi.>>
\s1 Akunda a nan ganu
\p 
\v 28 Reve A̱sulazuva a damma Musa,
\v 29 <<Yuwan adanshi na aza a Isra'ila a na, za na suru ta̱wa̱i na̱ kucci muwwulai e ekere a̱ A̱sulazuva, u ta ca A̱sulazuva upasu u ro u kucci va̱ yi.
\v 30 Ne ekere a̱ yi a ɗa wa̱a̱ ta̱wa̱a̱ A̱sulazuva na̱ kucci na a yuwain na akina. U ta̱ ta̱wa̱a̱ na abaji a mani'in oɓolo na̱ ma̱ka̱ka̱n, reve u 'ya̱sa̱n ma̱ka̱ka̱'a̱n kucci vu u'ya̱susa̱n a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 31 Ganu ta̱ kula̱to mani'i'in a masa'a, amma ma̱ka̱ka̱'a̱n u to o'wo akunda a Haruna no olobo a̱ yi.
\v 32 A ta ca ganu uneꞌe wa aagutsu o usa'ani wa̱ kucci muwwulai'i.
\v 33 A̱tsuma̱ o olobo a Haruna za na suru cayi mpasa na abaji a mani'in vu kucci muwwulai'i u ta tara aagutsu o usa'ani'i woo o'wo akunda a̱ yi.
\v 34 Diga a̱ kucci muwwulai va aza a Isra'ila, ma̱ka̱ka̱n ma na suru a̱ 'ya̱sa̱in na aagutsu a na a cayi n tara le ta̱, reve n ca Haruna ganu no olobo a̱ yi wo o'wo akunda e le kuci.
\v 35 A̱yi nda a̱yi ɗa akunda a̱ kucci va akina na a cayi A̱sulazuva a na a tawayi Haruna no olobo a̱ yi diga o urana u na a tawa nle a yuwan ulinga u tsuganu wa̱ A̱sulazuva.
\v 36 Diga o urana u na a̱ tsun nle mani'in, A̱sulazuva a zuwa ta̱ a casu le akunda kuci hali a̱ tyo mantsa me elime.>>
\p 
\v 37 Ele nda ele ɗa re mayan ma̱ kucci vu ukula̱tosu, na̱ kucci vi ishina na̱ za vu unusu na̱ za makuɗa ma̱ wila̱ na̱ za vu ukatalasa wa ganu, na̱ za muwwulai,
\v 38 aza a na A̱sulazuva a dammai Musa a Masasan ma Sinai, o urana u na u zuwai aza a Isra'ila a̱ ta̱wa̱a̱ na̱ kucci le a̱ A̱tsumona a Sinai.
\c 8
\s1 Ukatalasa wa Haruna no olobo a̱ yi
\r (Mta̱ 29:1-37)
\p 
\v 1 Reve A̱sulazuva a yuwan adanshi na̱ Musa u damma,
\v 2 <<Tara Haruna oɓolo no olobo a̱ yi na̱ a̱tugu a tsuganu tse le, na̱ mani'in mo utsusun no oogono a nan a̱ kucci vu unusu na̱ a̱giri'i e re na aasaka o opopofu a na a̱ ri na̱ wolilo shi.
\v 3 Reve vu ɓoloto ama suru o una̱ntsu wo Oogodo o Uga'asusan.>>
\v 4 Reve Musa yuwan cine A̱sulazuva a zuwa niyi u yuwan. Reve ama o ɓoloto o una̱ntsu wo Oogodo o Uga'asusa'an.
\p 
\v 5 Ɗaɗa Musa dammai ama'a, <<A̱yi nda a̱yi ɗa ili i na A̱sulazuva a zuwai a yuwan.>>
\v 6 Reve wu uta̱a̱ Haruna no olobo a̱ yi elime, a̱vu u sumba̱ le na̱ mini.
\v 7 Reve wo oto Haruna utugu wu uga'an, reve wu nla̱a̱ yi gbakala e ikyun. A̱vu wo oto yi utugu, na̱ ma̱tugu ma̱ epo. Reve wu nla̱a̱ yi gbakala vu uɗavu wu ukere ulinga wu ɗavi adama u guza̱ yi ulobonu.
\v 8 Reve u sa̱ga̱da̱wa̱ yi oosonu a̱ ma̱ka̱ka̱n, reve u zuwa Urim na̱ Tumim pe.
\v 9 Reve u katala yi ookokolo a tsuganu a aaci. Reve u zuwa ɗe ma̱pa̱ta̱ta̱ ma zinariya ma̱ cin o ookokolo'o, ookokolo a akiza, cine A̱sulazuva a zuwai.
\p 
\v 10 Reve Musa tara mani'in mo utsusun reve u tsun a̱a̱'isa̱ ni ili i na i ri pe suru, a̱vu u tawa le oo o'wo na akiza.
\v 11 Reve wu kyo'onu masa'a mani'in toto ucindere. A̱vu u tsuwa̱n masa'a ni itana i na i ri pe suru na aasa'atsu nu ukuruwa̱ta̱ wa̱ yi adama u tawa le oo o'wo na akiza.
\v 12 Reve u tsuwa̱n Haruna mani'in a aaci adama a tawa yi na akiza.
\v 13 Reve Musa ta̱wa̱ no olobo a Haruna a̱vu wo oto le a̱tugu, reve wu nla̱a̱ le igbakala a̱ nkyun n le. Reve wo oto le okokolo a tsuganu, cine A̱sulazuva a zuwai Musa.
\p 
\v 14 Reve u ta̱wa̱ no oogono a nan a̱ kucci vu unusu. Reve Haruna no olobo a̱ yi a̱ kuru ekere e le a aaci a na'an.
\v 15 A̱vu Musa paɗa yi, a̱vu kene mpasa, reve u daɓa mpasa'a na aakatsu a̱ yi u putala yi a avana a masa'a'a adama wo o'woto yi na akiza. Reve u tsun akapi a mpasa'a e ikyun i masa'a'a, a̱vu u tawa yi na akiza adama a matara mo ume mo unusu.
\v 16 A̱vu Musa foɗo abaji a mani'in ma na ma palai iliya̱tsuma̱ suru nu upasu wa assuvu u na u la'ai ulobonu na a'ilu e re na̱ mani'in me ele, reve u kula̱to le a masa'a'a.
\v 17 Amma a̱vu u kula̱to oogono a na'an nu ukwan wa̱ yi ni inama ya̱ yi na̱ a̱ya̱n a̱ yi o ucina̱ wu uva̱la̱ta̱'a̱, cine A̱sulazuva a zuwa niyi u yuwan.
\p 
\v 18 Reve u ta̱wa̱a̱ na̱ a̱a̱giri'i a̱ kucci vu ukula̱tosu. A̱vu Haruna no olobo a̱ yi a̱ kuru ekere e le a aaci a̱ a̱a̱giri'i'i.
\v 19 Ɗaɗa Musa paɗa niyi, reve u kyo'onu mpasa'a e eɓele a masa'a'a suru a̱ ka̱nda̱ruwa̱.
\v 20 Reve wu paɗa a̱a̱giri'i'i mupaɗi mupaɗi, a̱vu u kula̱to aaci oɓolo na̱ mupaɗi'i na̱ mani'in.
\v 21 Reve wu za̱'wa̱ iliya̱tsuma̱ na ana na̱ mini. Reve u kula̱to a̱a̱giri'i'i suru a masa'a'a, kucci vu ukula̱tosu, ili i ma̱guru mo uyo'o, kucci na a yuwayin A̱sulazuva va akina, cine A̱sulazuva a zuwai Musa.
\p 
\v 22 Reve u ta̱wa̱ na̱ a̱a̱giri'i e ire, za vu ukatalasa u tsuganu. Reve Haruna no olobo a̱ yi a̱ kuru ekere e le a aaci a̱ a̱a̱giri'i'i.
\v 23 Reve Musa paɗa yi. A̱vu u kene mpasa'a a̱vu u daɓa e lege vu utsuvu vu usa'ani wa Haruna na a aakatsu a gbain o ukere u sa'ani wa̱ yi na a aakatsu a gbain a anana o usa'ani wa̱ yi.
\v 24 Reve u ta̱wa̱ no olobo a Haruna, reve u daɓa mpasa e nlege ma atsuvu o usa'ani e le na a akatsu a gbagbain e ekere a sa'ani e le na a akatsu a gbagbain a ana a sa'ani e le. A̱vu Musa kyo'onu mpasa n na m buwai e eɓele a masa'a'a suru a̱ ka̱nda̱ruwa̱.
\v 25 Reve u tara mani'i'in na̱ wizan u mani'in na abaji a mani'in ma na ma palai iliya̱tsuma̱ suru, nu upasu wa assuvu u na u la'ai ulobonu, na a'ilu e re'e oɓolo na̱ mani'in me le, oɓolo na aagutsu o usa'ani.
\v 26 Diga pe a aasaka o opopofu a na a̱ ri na̱ wolilo shi za na ri a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva, u tara ta̱ oopopofu a̱ ta̱ na̱ za na a yuwain na̱ mani'in ne emeshen. Reve u kuru le a mani'i'in na a aagutsu o usa'ani'i.
\v 27 Reve u zuwa le suru e ekere a Haruna no olobo a̱ yi. Reve a̱ 'ya̱sa̱n le a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva kucci vu u'ya̱susa̱n.
\v 28 Reve Musa tawa le e ekere e le, reve u kula̱to le a masa'a zuva kucci vu ukula̱tosu vu ukatalasa wa tsuganu, ili i ma̱guru mo uyo'o, kucci na a yuwayin A̱sulazuva va akina.
\v 29 Reve Musa tara ma̱ka̱ka̱'a̱n reve u 'ya̱sa̱n yi kucci vu u'ya̱susa̱n e ekere a̱ A̱sulazuva. A̱yi ɗa akunda a Musa a̱ a̱a̱giri'i o ukatalasa wa ganu cine A̱sulazuva a zuwai Musa yuwan.
\p 
\v 30 Reve Musa kene mani'in mo utsusun na̱ mpasa n na n ri a masa'a, reve wu kyo'onuwo Haruna na̱ a̱tugu a̱ yi, no olobo a̱ yi waru na̱ a̱ a̱tugu e le. Ne ɗa u tawai Haruna na̱ a̱tugu a̱ yi na akiza oɓolo no olobo a̱ yi na̱ a̱tugu e le.
\p 
\v 31 Reve Musa damma Haruna no olobo a̱ yi, <<Su'wain inama'a o una̱ntsu wo Oogodo o Uga'asusan, reve i tama le lo oɓolo no opopofu a na a̱ ri a aasaka a̱ kucci vu ukatalasa cine a̱mu A̱sulazuva n zuwai, a na,<Haruna no olobo a̱ yi a ɗa aa tama le.>
\v 32 Agba ili i na i pasai yi inama no opopofu'u, i kula̱to le.
\v 33 Agba she yu uta̱ o una̱ntsu wo Oogodo o Uga'asusa'an wan rana cindere, hali she na̱ rana vu ukatalasa ɗu koto adama a na rana vu ukatalasa ɗu ta yuwan rana cindere.
\v 34 Ili i na a yuwain ana'an, A̱sulazuva a zuwa yi ta̱ adama a matara mo ume mo unusu ma̱ ɗu.
\v 35 I ta̱ da̱na̱ o una̱ntsu wo Oogodo o Uga'asusan ayin nu usana hali ayin e cindere, a yuwusan ili i na A̱sulazuva a zuwai, adama i kuwa̱ wan. A̱yi ɗa ili i na A̱sulazuva a zuwai.>>
\v 36 Reve Haruna no olobo a̱ yi a yuwan ili i na A̱sulazuva a zuwa nle a yuwan suru cine a uwwai o una̱ wa Musa.
\c 9
\s1 Nan ganu e temei ulinga
\p 
\v 1 O urana wa̱ kunla̱ u na u kuruyi rana cindere va̱ a̱buki o ukatalasa u tsuganu, reve Musa ɗe Haruna no olobo a̱ yi, na̱ mbara ma aza a Isra'ila.
\v 2 A̱vu u damma Haruna, <<Taraa aciya̱wu oogono a nan adama a̱ kucci vu unusu, na̱ a̱a̱giri'i adama a̱ kucci vu ukula̱tosu. Suru nle a̱ da̱na̱ usa̱du wan, a̱vu vu ta̱wa̱ ne ele a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 3 Reve vu damma aza a Isra'ila, <Tarai ma̱ga̱ji adama a̱ kucci vu unusu, na̱ ma̱dindim na̱ kyon, suru nle aa'wan a̱ ta̱ ta̱ nu umatsun aza a na a̱ ri usa̱du shi adama a̱ kucci vu ukula̱tosu.
\v 4 Reve waru a̱ ta̱wa̱a̱ no oogono a nan na̱ a̱a̱giri'i adama a̱ kucci muwwulai a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva, na̱ kucci vi ishina i na a̱ ja̱mba̱ra̱i na̱ mani'in, adama a na A̱sulazuva a̱ ta̱ ta̱wa̱ ya̱'a̱ ɗu ana'an.> >>
\v 5 Reve a̱ ta̱wa̱a̱ ni ili i na Musa zuwai elime o Oogodo o Uga'asusan. Reve ama suru a rawa zuzu e isawan a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 6 Reve Musa damma, <<Apa nda ili i na A̱sulazuva a zuwa nɗu i yuwan, adama tsugbain tsa̱ A̱sulazuva tsa̱ ta̱wa̱ ya̱'a̱ ɗu.>>
\p 
\v 7 Reve Musa damma Haruna, <<Ta̱wa̱ zuzu na̱ masa'a vu ca kucci vu unusu na̱ kucci vu ukula̱tosu va̱ wu. Vu yuwan kucci matara mo ume mo unusu va aciya̱wu na adama a ama. Reve vu ta̱wa̱a̱ na̱ kucci va ama, vu ca adama a matara mo ume mo unusu me le, cine A̱sulazuva a zuwai.>>
\p 
\v 8 Ɗaɗa Haruna rawai zuzu na̱ masa'a'a a̱vu u paɗa ma̱dindim ma̱ kucci vu unusu adama a aciya̱yi.
\v 9 Reve olobo a Haruna a ca yi mpasa'a. Reve u daɓa aakatsu a̱ yi a mpasa, a̱vu u putala yi a avana a masa'a'a. Reve u tsun akapi a mpasa'a e ikyun i masa'a.
\v 10 Amma mani'in na a'ilu nu upasu wa assuvu u kucci vu unusu u kula̱to le ta̱ a masa'a, cine A̱sulazuva a zuwai Musa.
\v 11 Reve u kula̱to inama nu ukwa'an o ucina̱ wu uva̱la̱ta̱.
\p 
\v 12 Reve Haruna paɗa kucci vu ukula̱tosu'u. Reve olobo a̱ yi a ca yi mpasa'a, reve wu kyo'onu le e eɓele a masa'a'a suru a̱ ka̱nda̱ruwa̱.
\v 13 Reve a ca yi kucci vu ukula̱tosu mupaɗi mupaɗi oɓolo na aaci, reve u kula̱to le a masa'a'a.
\v 14 Reve wu za̱'wa̱ iliya̱tsuma̱ no okotsu a̱vu u kula̱to le oɓolo na̱ kucci vu ukula̱tosu zuva masa'a'a.
\p 
\v 15 Reve Haruna ca kucci va ama, a̱vu u tara megbele adama a̱ kucci vu unusu adama a ama reve u paɗa yi. Reve u yuwan kucci vu unusu na̱ a̱yi tsu za vu ufaru.
\v 16 Reve u ta̱wa̱a̱ na̱ kucci vu ukula̱tosu, reve u yuwan na̱ a̱yi o ure u na a zuwai.
\v 17 Reve u ta̱wa̱a̱ na̱ kucci vi ishina, a̱vu u kene ukere u ta̱, reve u kula̱to yi a masa'a oɓolo na̱ kucci vu ukula̱tosu vu usana.
\p 
\v 18 Reve waru Haruna paɗa oogono a nan na̱ a̱a̱giri'i adama a̱ kucci muwwulai adama a ama. Reve olobo a̱ yi a ca yi mpasa, reve wu kyo'onu le e eɓele a masa'a'a suru a̱ ka̱nda̱ruwa̱.
\v 19 Agba mupaɗi ma abaji a mani'in mo oogono ma nan na̱ a̱a̱giri'i na̱ wizan u mani'in na̱ mani'in ma na ma palai iliya̱tsuma̱ na a'ilu nu upasu wa assuvu,
\v 20 u kuru le ta̱ a̱ nka̱ka̱n mi inama'a, reve u kula̱to mupaɗi m mani'i'in a masa'a'a.
\v 21 Amma reve Haruna ca kucci vu u'ya̱susa̱n vu nka̱ka̱n na agutsu o usa'ani'i a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva, cine Musa zuwai a yuwan.
\p 
\v 22 Reve Haruna 'ya̱sa̱n ekere a̱ yi a̱ tyo uba̱ta̱ wa ama, a̱vu u zuwaa le aba'un. Reve ana u kotoi ucasu u kucci vu unusu na̱ kucci vu ukula̱tosu, na̱ kucci muwwulai, reve u cipa̱ diga uba̱ta̱ u masa'a'a.
\p 
\v 23 A̱vu Musa na̱ Haruna a uwa a̱tsuma̱ o Oogodo o Uga'asusan. Ana o uta̱i reve a zuwaa ama aba'un. Ɗaɗa tsugbain tsa̱ A̱sulazuva tsa̱ ta̱wa̱i uba̱ta̱ wa ama suru.
\v 24 Reve akina o uta̱ uba̱ta̱ wa̱ A̱sulazuva, reve u tama kucci vu ukula̱tosu na abaji a mani'in a na a̱ ri a masa'a'a. Ana ama suru e ene niyi, reve o oruwo na̱ ma̱za̱nga̱. A̱vu a̱ riya̱ ma̱kpa̱ɓa̱.
\c 10
\s1 Ukwa̱ wa Nadab na̱ Abihu
\p 
\v 1 Nadab na̱ Abihu olobo a Haruna, za suru tara ta̱ aayimba a akina a̱ yi, u tsun akina pe a̱vu u kula̱to a̱tsuka̱ pe. Reve a ca A̱sulazuva akina a na o lobonoi shi, cu'un na u zuwa nle a̱ ta̱wa̱a̱ shi.
\v 2 Ɗaɗa akina o uta̱i uba̱ta̱ wa̱ A̱sulazuva, a̱vu u kula̱to le. A̱vu a̱ kuwa̱ a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 3 Reve Musa damma Haruna, <<Apa nda ili i na A̱sulazuva a dammai, <Uba̱ta̱ wa aza a na a̱ ri zuzu na̱ a̱mu a ta tara mu na akiza, waru a ta ca mu tsugbain e esu a ama suru.> >> Haruna gba isawan ta̱ kuci kuci.
\p 
\v 4 Reve Musa ɗe Mishe na̱ Elizafan olobo a Uziye dada ke'en va Haruna, a̱vu u damma le, <<Rawai zuzu i pura̱ a̱za̱ a̱ ɗu o uta̱ a alanga a̱ a̱a̱'isa̱ a̱ tyo o ucina̱ wu uva̱la̱ta̱.>>
\v 5 Reve a rawa zuzu a tanu le a̱tsuma̱ a̱ a̱tugu e le o uta̱ a̱ tyo o ucina̱ o uva̱la̱ta̱, cine Musa zuwai.
\p 
\v 6 Reve Musa damma Haruna no olobo a̱ yi Eliyaza na̱ Itama, <<She i lyawa a̱nji a̱ ɗu ukacaru wan, waru she yi kara a̱tugu a̱ ɗu wan ta̱wa̱ i kuwa̱ wan, reve i ronoo ama upan wa̱ A̱sula̱. Amma i lyawa a̱za̱ a̱ ɗu, u'wa wa Isra'ila suru e showen aza a na A̱sulazuva a̱ kula̱toi.
\v 7 Waru she yu uta̱ o una̱ntsu wo Oogodo o Uga'asusan wan, ta̱wa̱ i kuwa̱ wan, adama a na mani'in mo utsusun ma̱ A̱sulazuva ma̱ ta aci a̱ ɗu.>> Reve gba a yuwan cine Musa dammai.
\p 
\v 8 A̱vu A̱sulazuva a damma Haruna,
\v 9 <<Na̱ a̱vu no olobo a̱ wu she i sowo masayan ma̱ ina̱bi ko ili yo oso i na i tsu tsura̱to wan, a mantsa ma na suru yaa uwa o Oogodo o Uga'asusan, adama i kuwa̱ wan. A̱yi nda u to o'wo ili i mayan kuci hali a̱ tyo mantsa suru.
\v 10 Ni i ciga i 'yuwan yi kasa ili i na a tawai na akiza ni ili ya ndana, ni ili yi idaba ni ili i cece.
\v 11 Waru ni i ciga i 'yuwan i rito ama a Isra'ila suru wila̱ u na A̱sulazuva a cayi e ekere a Musa.>>
\p 
\v 12 Musa gba yuwan ta̱ adanshi na̱ Haruna na akapi o olobo a̱ yi, Eliyaza na̱ Itama u damma, <<Tarai kucci vi ishina i na i pasai a̱ kucci na a cayi A̱sulazuva va akina, reve i lyuwa yi a̱ nge'en m masa'a babu wolilo, adama a na u ta̱ na akiza lon.
\v 13 I lyuwa yi uba̱ta̱ wa akiza, adama a na akunda a̱ wu a ɗa na̱ za vo olobo a̱ wu a̱ kucci na cayi A̱sulazuva va akina, adama a na ne ɗa a zuwa numu n yuwan.
\v 14 Agba na̱ a̱vu no olobo a̱ wu oɓolo ne esheli a̱ wu i ta tama ma̱ka̱ka̱n ma̱ kucci ma na a̱ 'ya̱sa̱in na aagutsu a na a cayi, i tama le uba̱ta̱ u na u ri cece. A ca wu ele ta̱ akunda a̱ wu a ɗa na̱ a̱vu no olobo a̱ wu ne esheli a̱ wu diga a̱ kucci muwwulai va aza a Isra'ila.
\v 15 Aagutsu a na a cayi na̱ ma̱ka̱ka̱n ma na a̱ 'ya̱sa̱i'in a̱ ta̱ ta̱wa̱ ne ele oɓolo na abaji a mani'in ma na a cayi va akina, a̱a̱ 'ya̱sa̱n yi a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva tsa̱ kucci vu u'ya̱susa̱n. O to o'wo akunda a̱ wu na̱ a̱vu no olobo a̱ wu kuci, cine A̱sulazuva a zuwai.>>
\p 
\v 16 Ana Musa ecei adama e megbele ma na a cayi adama a̱ kucci vu unusu, a̱vu u cina a̱ kula̱to yi ta̱ ɗe. Reve u yuwan upan na̱ Eliyaza na̱ Itama olobo a Haruna a na a buwai, a̱vu we ece,
\v 17 <<Adama a̱ nye i tamai kucci vu unusu'u a̱ a̱a̱'isa̱ shi? Kucci va akiza lon ɗa, waru a ca ɗu ta̱ ele adama a tawa unusu wa ama a tara ume wu unusu u le a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 18 Ana wo o'woi aa tara mpasa ma̱ yi a uwa Uba̱ta̱ wa Akiza shi, u shi to o lobono i tama inama'a a̱tsuma̱ a̱ a̱a̱'isa̱ cine n zuwai.>>
\p 
\v 19 Reve Haruna usu Musa, <<Uwwa nda, ana'an ɗa a cayi kucci le adama o unusu na̱ kucci le vu ukula̱tosu a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva, agba suru na̱ ne a̱vu ili i nda i fara na̱ a̱mu! Nna̱ n shi n tama kucci vu unusu ana'an, A̱sulazuva a̱ shi ta̱ a uwwa uyo'o va̱?>>
\v 20 Ana Musa uwwai ili i nda, wu uwwa ta̱ uyo'o wi ili'i.
\c 11
\s1 Ilyalya i cece na̱ za vi idaba
\r (U.Wl 14:3-21)
\p 
\v 1 Reve A̱sulazuva a yuwan adanshi na̱ Musa na̱ Haruna u damma le,
\v 2 <<Yuwain adanshi na ama a Isra'ila a na, a̱tsuma̱ e inama i na i ri o uvaɗi suru, apa nda aza a na yaa gura tama:
\v 3 Nama na suru ookotsu a̱ yi a ɓatsalai, waru u tsu ka̱mbuwisa̱ ta̱ utamu, i ta gura tama yi.
\v 4 Suru na̱ ne a̱tsuma̱ a aza a na a̱ tsu ka̱mbuwisa̱ utamu, ko a̱ ri no okotsu e le uɓatsulai ya tama ele nda shi: Yaa tama arakumi shi ko a na u tsu ka̱mbuwisa̱ utamu, okotsu a̱ yi a̱ ri uɓatsulai shi. Ili yi idaba i ɗa e ekere a̱ ɗu.
\v 5 Magima, ko a na u tsu ka̱mbuwisa̱ utamu, okotsu a̱ yi a̱ ri uɓatsulai shi. Ili yi idaba i ɗa e ekere a̱ ɗu.
\v 6 Mozomu waru, ko a na u tsu ka̱mbuwisa̱ utamu, okotsu a̱ yi a̱ ri uɓatsulai shi. Ili yi idaba i ɗa e ekere a̱ ɗu.
\v 7 Ma̱gurusumu waru, ko a na u ri no okotsu uɓatsulai u tsu ka̱mbuwisa̱ utamu shi, ili yi idaba i ɗa e ekere a̱ ɗu.
\v 8 She i tama inama i le wan, agba she i ju'wa̱in a̱kwa̱kwa̱ e le wan, ili yi idaba i ɗa e ekere a̱ ɗu.
\p 
\v 9 <<A̱tsuma̱ e ili i na i ri a̱ mini suru ko a mala ko o ɗolu, i ta gura tama ili i na i ri na̱ a̱ka̱ɓa̱ na̱ a̱fa̱ɓa̱ a̱ lipu.
\v 10 Amma ili i wuma i na i ri a mala ko o ɗolu suru, agba u ri na̱ a̱ka̱ɓa̱ ko a̱fa̱ɓa̱ a̱ lipu shi, ili yi idaba i ɗa e ekere a̱ ɗu.
\v 11 I tara le ili yi idaba, she i tama inama i le wan. A̱kwa̱kwa̱ e le waru o o'wo ili yi idaba e ekere a̱ ɗu.
\v 12 Ili i na suru i ri a̱ mini agba u ri na̱ a̱ka̱ɓa̱ ko a̱fa̱ɓa̱ shi, ili yi idaba i ɗa e ekere a̱ ɗu.
\p 
\v 13 <<Apa nda icu'un yi nnunu n na yaa tara ili yi idaba, yaa tama le shi, ili yi idaba i ɗa: a̱a̱kuru na aasala na amikiya
\v 14 na aajimba na̱ cu'un va aajimba suru,
\v 15 na̱ cu'un va aakakan suru,
\v 16 na azamina, na̱ vori na̱ papagula ni icu'un i le suru,
\v 17 na̱ vori ke'en na̱ mecivecive na̱ a̱a̱pa̱mu,
\v 18 na̱ mototon na̱ ma̱gba̱shimo na aasala e ke'en,
\v 19 na aashamuwa na̱ cu'un va atakuba suru, na̱ a̱a̱burutu no oogyon.
\p 
\v 20 <<Mubumbu n na ri ne evelu aza a na a tsu wala na ana a̱ na̱shi suru, ili yi idaba i ɗa e ekere a̱ ɗu.
\v 21 Amma i ta gura tama mubumbu n na n ri ne evelu aza a na a tsu wala na ana a̱ na̱shi aza a na a̱ ri na agutsu a na a tsu zuwa le a gura 'yawan.
\v 22 I ta gura tama cu'un va aapapari biti, na̱ cu'un vu jon suru na̱ cu'un va akyun suru.
\v 23 Amma akapi a̱ mubumbu n na n ri ne evelu na ana a̱ na̱shi suru ili yi idaba i ɗa e ekere a̱ ɗu.
\p 
\v 24 <<Ili i nda i ta zuwa ɗu yoo o'wo idaba. Za na suru ju'wa̱in a̱kwa̱kwa̱ e le u to o'wo idaba hali she ulivu.
\v 25 Waru za na suru tarai a̱kwa̱kwa̱ a za ta̱ a̱tsuma̱ e le, u ta̱ za̱'wa̱ a̱tugu a̱ yi, agba u to o'wo idaba hali she ulivu.
\p 
\v 26 <<Nama na suru ookotsu a̱ yi a ɓatsalai shi, waru u tsu ka̱mbuwisa̱ utamu shi ili yi idaba i ɗa e ekere a̱ ɗu. Za na suru ju'wa̱in a̱kwa̱kwa̱ a za ta̱ le u to o'wo idaba.
\v 27 A̱tsuma̱ e inama i na i ri na ana a̱ na̱shi suru, aza a na a tsu wala na apata a ana, ili yi idaba i ɗa e ekere a̱ ɗu. Za na suru ju'wa̱in a̱kwa̱kwa̱ e le u to o'wo idaba hali ulivu.
\v 28 Waru za na suru sheɗei a̱kwa̱kwa̱ e le u ta̱ za̱'wa̱ a̱tugu a̱ yi, agba u to o'wo idaba hali ulivu. Ili yi idaba i ɗa a̱ ri e ekere a̱ ɗu.
\p 
\v 29 <<A̱tsuma̱ e inama i na i tsu ka̱ta̱pa̱ e iɗa, apa nda aza a na oo o'wo idaba e ekere a̱ ɗu: ashan na̱ a̱a̱ga̱ɗa̱ na̱ cu'un va aagada a gbain suru,
\v 30 na̱ mopolyo'o na̱ kuna̱ na̱ ga̱ngu na̱ meruweruwen na aakanla.
\v 31 Ele nda ili yi idaba i ɗa e ekere a̱ ɗu a̱tsuma̱ e ili i na i tsu ka̱ta̱pa̱ e iɗa. Za na suru ju'wa̱in a̱kwa̱kwa̱ e le u to o'wo idaba hali she ulivu.
\v 32 Waru ili i na a̱kwa̱kwa̱ e le a̱ riya̱yi suru u to o'wo idaba, ko ni ili i na a yuwain na akpata a ɗa, ko umuna ko ukwan ko a̱buhu, cu'un vi ili i na aa yuwusan ulinga na̱ a̱yi, a̱ ta̱ tsupu yi a̱ mini. Waru u ta̱ da̱na̱ idaba hali she ulivu, reve wo o'wo cece.
\v 33 Na̱ za ro a̱tsuma̱ e le riya̱ o upondo u ci'in, ili i na i ri pe suru u to o'wo idaba. I ta̱ gba o ɓoso upondo'o.
\v 34 Ilyalya ya alya suru, i na mini mo upondo'o ma̱ ju'wa̱in, u to o'wo idaba. Ili yo oso suru yu upondo u ndolo u to o'wo idaba.
\v 35 Ili i na suru a̱kwa̱kwa̱'a̱ a̱ riya̱yi u to o'wo idaba. Ko na̱ shi elele a ɗa ko uba̱ta̱ wu uzusun wo opopofu u ɗa i to ɓoso yi. Ili yi idaba i ɗa, waru o to o'wo ili yi idaba e ekere a̱ ɗu.
\v 36 Agba suru na̱ ne, na̱ a̱kwa̱kwa̱ a̱ cu'un vu nama ndolo riya̱ a̱ lyusu mini ko o ooko'o, a̱ ta̱ da̱na̱ cece. Amma za na suru ju'wa̱in a̱kwa̱kwa̱'a̱ a̱tsuma̱ e le u to o'wo idaba.
\v 37 Agba ko na̱ a̱kwa̱kwa̱'a̱ u riya̱a̱ icu'un, icu'u'un a ta buwa cece.
\v 38 Agba n ne e re'weto ta̱ icuꞌuꞌun reve a̱kwa̱kwa̱'a̱ a̱ riya̱a̱ le, ili yi idaba i ɗa e ekere a̱ ɗu.
\p 
\v 39 <<Nna̱ nama na a lyawa nɗu i tama kuwa̱, za na suru ju'wa̱in a̱kwa̱kwa̱'a̱ u to o'wo idaba hali she ulivu.
\v 40 Za na suru tamai a̱kwa̱kwa̱'a̱ u ta̱ za̱'wa̱ a̱tugu a̱ yi, waru u to o'wo idaba hali she ulivu. Waru za na suru tanuyi a̱kwa̱kwa̱'a̱ u ta̱ za̱'wa̱ a̱tugu a̱ yi, reve waru wo o'wo idaba hali she ulivu.
\p 
\v 41 <<Ili i wuma i kekeꞌen i na suru i ri e ika̱ta̱pu e iɗa biti ili yi idaba i ɗa, yaa tama le shi.
\v 42 Ili i na biti i tsu sa̱ɓa̱ru a̱tsuma̱ ko ili i na i tsu wala na ana a̱ na̱shi, ko ili i na i ri na ana a̱ a̱bunda̱, ili i na i tsu sa̱ɓa̱ru e iɗa suru yaa tama yi shi adama a na ili yi idaba i ɗa.
\v 43 She yoo o'woto aciya̱ɗu ili i tsugya ni ili i na ya̱a̱ sa̱ɓa̱rusu wan. Waru she i ka̱mba̱to aciya̱ɗu ili yi idaba adama e le wan, ko a zuwa ɗu yo o'wo idaba wan.
\v 44 A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu. Adama o ndolo i tawa aciya̱ɗu yo o'wo na akiza, adama a na a̱mu za va akiza ɗa. She yo o'woto aciya̱ɗu idaba ni ili i na i tsu sa̱ɓa̱ra̱ e iɗa wan.
\v 45 A̱mu ɗa A̱sulazuva za na uta̱a̱ nɗu diga e iɗa ya Masar adama mo o'wo A̱sula̱ a̱ ɗu. Adama o ndolo, yo o'wo na akiza, adama a na a̱mu za va akiza ɗa.
\p 
\v 46 <<A̱yi nda wila̱ u ɗa adama e inama suru na̱ nnunu ni ili i wuma i na i ri a̱ mini suru na̱ cu'un vi ili i wuma i na i tsu sa̱ɓa̱ra̱ e iɗa.
\v 47 Yi kasa ili yi idaba ni ili i na i ri cece, ni ili i wuma i na waru aa tama ni ili i wuma i na aa tama shi.>>
\c 12
\s1 Usumbu na̱ ka matsan
\p 
\v 1 Reve A̱sulazuva a yuwan adanshi na̱ Musa u damma,
\v 2 <<Yuwan adanshi na ama a Isra'ila a na: nna̱ ka yuwan a̱a̱tsuma̱ reve u matsan ulobo, u to o'wo idaba rana cindere, tsa mantsa ma̱ a̱shinda̱ ma̱ yi.
\v 3 Reve o urana wa̱ kunla̱ a paɗa ulobo'o uryumbu.
\v 4 U ta lyuwa elime a̱tsuma̱ a̱ a̱shinda̱ a limatan hali rana mata'atsu na aza a ta'atsu rana vu usumbu va̱ yi. A̱tsuma̱ a mantsa ma nda wa̱a̱ ju'wa̱n ili ya akiza shi, ko u ta̱wa̱ a̱ a̱a̱'isa̱ shi, she na̱ rana vu usumbu va̱ yi koto.
\v 5 Agba nu u mantsa usheli, u to o'wo idaba hali ajuma e re, tsa mantsa ma̱ a̱shinda̱ ma̱ yi. U ta lyuwa elime a̱tsuma̱ a̱ a̱shinda̱'a̱ hali rana kupota̱li na̱ a̱za̱ a̱ ta̱li, she na̱ rana vu usumbu va̱ yi koto.
\p 
\v 6 <<A mantsa ma na rana vu usumbu va̱ yi kotoi, ko vu umatsun wu ulobo ko usheli, reve u ta̱wa̱a̱ ganu na̱ ma̱giri'i ma aa'wan a̱ ta̱ o una̱ntsu wo Oogodo o Uga'asusan adama a̱ kucci vu ukula̱tosu, na̱ ma̱ma̱rukuku ko muɗa adama a̱ kucci vu unusu.
\v 7 Reve ganu'u ca A̱sulazuva ele adama a̱ kucci matara mo ume mo unusu ma ka'a. Reve wo o'wo cece diga a mpasa n na mo oco niyi. A̱yi ɗa wila̱ wu ka na matsain mawun, ko ulobo ko usheli.
\v 8 Agba na̱ wa̱a̱ tsura̱ ma̱giri'i shi, u ta̱wa̱ na̱ muɗa n re ko murukuku n re za ta̱ adama a̱ kucci vu ukula̱tosu za ta̱ waru adama a̱ kucci vu unusu. Ne ɗa ganu aa ca kucci matara mo ume mo unusu wa̱ yi, u ta̱ gba o'wo cece.>>
\c 13
\s1 Wila̱ adama a̱ mɓa̱la̱ mu ukutu
\p 
\v 1 A̱sulazuva a yuwan ta̱ adanshi na̱ Musa na̱ Haruna u damma,
\v 2 <<Na̱ vuma ri na atsutsu o ukwan u lipu va̱ yi, ko ikavuru ko mɓa̱la̱ ma abasa, reve u ka̱mba̱ mɓa̱la̱ n wuya mu ukwan u lipu, a̱ ta̱ ta̱wa̱ na̱ a̱yi uba̱ta̱ wa ganu Haruna ko uba̱ta̱ wu ulobo u ta̱ a̱tsuma̱ o olobo a Haruna ganu.
\v 3 Ganu'u u ta̱ ka̱lyuwa̱ mɓa̱la̱ mu ukwan u lipu va̱ yi. Reve ne eleme a na a̱ ri uba̱ta̱ a̱ mɓa̱la̱'a̱ a̱ ka̱mba̱ u'uri, a̱vu mɓa̱la̱'a̱ n yuwan a̱ru'un u la'a a̱ru'un o ukwan u lipu va̱ yi, mɓa̱la̱ n vama n ɗa. Na̱ ganu ka̱lyuwa̱ yi u ta damma u ta̱ idaba.
\v 4 Agba nna abasa a na a̱ ri a̱ lipu va̱ yi'i u ta̱ u'uri reve wo o'wo u ka̱ra̱ ukwan u lipu shi, waru eleme a na a̱ ri pe a̱ ka̱mba̱ u'uri shi, ganu ta̱ ɓa̱ru vuma vu mɓa̱la̱'a̱ ayin e cindere a̱yi a̱ nde'en.
\v 5 O urana we cindere ganu ta̱ ka̱lyuwisa̱ yi, reve ne e yeni ya̱ yi mɓa̱la̱'a̱ koto u bala o ukwan u lipuꞌu shi, reve u da̱shi ɓa̱ru yi ayin e cindere o ro a̱yi a̱ nde'en.
\v 6 O urana we cindere reve ganu ka̱lyuwisa̱ yi waru. Reve nnu upasu u na mɓa̱la̱'a̱ n ri u teme a̱ fa̱ɓusa̱ agba mɓa̱la̱'a̱ m bala o ukwa'an shi, reve ganu'u u damma u ta̱ cece, ikavuru i ɗa goon. Reve vuma'a wu za̱'wa̱ a̱tugu a̱ yi wo o'wo cece.
\v 7 Agba nni ikavuru'u i bala o ukwan u lipu cina ɗe u roco aciya̱yi ya ganu adama ganu damma u ta̱ cece, u ta̱ ta̱wisa̱ ya ganu waru.
\v 8 Ganu ta̱ ka̱lyuwa̱ yi, reve ni ikavuru'u i bala o ukwan, u ta damma u ta̱ idaba, mɓa̱la̱ mu ukutu n ɗa.
\p 
\v 9 <<A mantsa ma na nanza ri na̱ mɓa̱la̱ n vama mu ukwan u lipu, a̱ ta̱ ta̱wa̱ na̱ a̱yi uba̱ta̱ wa ganu.
\v 10 Ganu ta̱ ka̱lyuwa̱ yi. Nna̱ we ene utsutsu u u'uri o ukwan u na u ka̱mba̱toi eleme o uba̱ta̱'a̱ u'uri, waru nna̱ wuntsu wu lo o utsutsu'u,
\v 11 mɓa̱la̱ mu ukutu n ɗa. Ganu ta damma u ta̱ idaba. Wa̱a̱ ɓa̱ru yi shi adama a na wo o'wo ta̱ ɗe idaba.
\v 12 Agba nna̱ mɓa̱la̱'a̱ m ɓa̱ru lipu va̱ yi suru diga a aaci a̱ tyo a ana cine ganu aa gura ene,
\v 13 ganu'u u ta̱ ka̱lyuwa̱ yi. Reve nna̱ mɓa̱la̱'a̱ n ta̱ɓa̱luwa̱ a̱ lipu hali u ɓa̱ru lipu va̱ yi suru, ganu'u u ta damma u ta̱ cece, a na wo o'woi u'uri suru, u ta̱ cece.
\v 14 Amma a mantsa ma na wuntsu u sa'avu wu uta̱i a̱ lipu va̱ yi, u to o'wo idaba.
\v 15 Ganu'u u ta̱ ka̱lyuwa̱ wuntsu'u, reve u damma u ta̱ idaba. Wuntsu ili yi idaba i ɗa, adama a na mɓa̱la̱ mu ukutu n ɗa.
\v 16 Amma nna̱ wuntsu'u u ka̱mbisa̱ u'uri, za vu mɓa̱la̱'a̱ u ta̱ ka̱mba̱ ya ganu.
\v 17 Reve ganu'u u ka̱lyuwa̱ yi. Reve nna̱ wuntsu'u u ka̱mba̱ u'uri, reve u damma za vu mɓa̱la̱'a̱ u ta̱ cece, reve wo o'wo cece.
\p 
\v 18 <<Nna̱ vuma ri na aamicin a̱ lipu va̱ yi, reve wi ina,
\v 19 nu uba̱ta̱ u na aamici'in u shi, utsutsu wa abasa a̱ u'uri o uta̱ lo ko abasa a sawun sawun, reve u roco ganu.
\v 20 Ganu ta̱ ka̱lyuwa̱ uba̱ta̱'a̱ nnu u yuwan a̱ru'un za̱la̱ vu ukwan u lipu, reve waru eleme o uba̱ta̱'a̱ a̱ ka̱mba̱ u'uri, ganu'u u ta damma u ta̱ idaba. Mɓa̱la̱ mu ukutu n ɗa m ɓosoi aamicin.
\v 21 Agba nna̱ ganu ka̱lyuwa̱ yi agba u ri ne eleme a̱ u'uri shi, waru u la'a ukwan u lipu a̱ru'un shi, waru u kporo ta̱, ganu ta̱ ɓa̱ru yi hali rana cindere.
\v 22 Amma nnu u bala o ukwan, ganu ta damma u ta̱ idaba. Ukutu u ɗa.
\v 23 Amma nna abasa'a e isawan uba̱ta̱ u ta̱ agba u baza shi, alana a amicin a ɗaɗa, ganu ta damma u ta̱ cece.
\p 
\v 24 <<Ko gba nna̱ vuma ri na̱ wukulu a̱ lipu va̱ yi, reve inama i wukulu'u yo o'wo u'uri sawun sawun ko abasa a̱ u'uri,
\v 25 ganu ta̱ ka̱lyuwa̱ yi. Reve nne eleme a abasa'a a̱ ka̱mba̱ u'uri a̱vu u la'a ukwan u lipu a̱ru'un, to, mɓa̱la̱ mu ukutu n ɗa n na m ɓosoi uba̱ta̱ u wukulu. Reve ganu damma u ta̱ idaba, adanshi a̱ mɓa̱la̱ mu ukutu n ɗa.
\v 26 Amma nna̱ ganu ka̱lyuwa̱ yi agba eleme a̱ u'uri o lo a abasa'a shi waru u la'a ukwan u lipu a̱ru'un shi, amma u fa̱ɓa̱ ta̱, ganu ta̱ ɓa̱ru yi hali rana cindere.
\v 27 Reve ganu ka̱lyuwisa̱ yi o urana we cindere. Na̱ waa balasa o ukwan, reve ganu damma u ta̱ idaba. Adanshi a̱ mɓa̱la̱ mu ukutu n ɗa.
\v 28 Agba nna abasa'a e isawan uba̱ta̱ u ta̱ u bala o ukwan shi agba u fa̱ɓa̱ ta̱, utsutsu u ɗa a̱ wukulu. Ganu ta damma u ta̱ cece, aalana a̱ wukulu a ɗa goon.
\p 
\v 29 <<Na̱ vali ko ka ri na̱ mɓa̱la̱ a aaci ko e ilegu,
\v 30 ganu ta̱ ka̱lyuwa̱ mɓa̱la̱'a̱. Reve nnu u la'a ukwan u lipu a̱ru'un, eleme o uba̱ta̱'a̱ waru a̱ ta̱ mini ma tsusumba waru babu ugba̱mu, reve ganu damma u ta̱ idaba. Ikavuru i ɗa, mɓa̱la̱ n vama mu ukwan n ɗa va aaci ni ilegu.
\v 31 Amma nna̱ ganu ka̱lyuwa̱ mɓa̱la̱ mi ikavuru'u agba u ka̱ra̱ a̱ru'un o ukwan shi, waru u ri ne eleme a̱ lima̱ shi, ganu ta̱ ɓa̱ru za vu mɓa̱la̱'a̱ hali ayin e cindere.
\v 32 Reve o urana we cindere ganu ka̱lyuwisa̱ mɓa̱la̱'a̱. Nna̱ mɓa̱la̱'a̱ m bala shi, waru u ri ne eleme a̱ mini ma tsusumba shi, waru ikavuru'u u ka̱ra̱ a̱ru'un o ukwan shi,
\v 33 to, u ta puna aaci'i, agba waa puna uba̱ta̱ e ikavuru'u shi. Reve ganu da̱shi ɓa̱ru yi ayin e cindere o ro.
\v 34 Reve o urana we cindere ganu ka̱lyuwisa̱ ikavuru'u, reve nnu u bala o ukwan u lipu shi waru u ka̱ra̱ a̱ru'un o ukwan shi, ganu'u u ta damma u ta̱ cece. Reve wu za̱'wa̱ a̱tugu a̱ yi wo o'wo cece.
\v 35 Agba ni ikavuru'u i bala o ukwan u lipuꞌu cina a damma u ta̱ cece,
\v 36 reve ganu ka̱lyuwisa̱ yi, a̱vu ni ikavuru'u i bala o ukwan, ganu'u waa zami eleme a̱ mini ma tsusumba waru shi, u ta̱ idaba.
\v 37 Agba nne e yeni ya̱ yi ikavuru'u i vadala shi, waru eleme a̱ lima̱ o uta̱ ta̱ pe, ikavuru'u i koto ta̱, waru wo o'wo ta̱ cece. Ganu ta damma u ta̱ cece.
\p 
\v 38 <<Na̱ vali ko ka ri na abasa a̱ u'uri a̱ lipu va̱ yi,
\v 39 ganu ta̱ ka̱lyuwa̱ yi. Reve na abasa'a a̱ ri uryoryo, muboto n ɗa mu uta̱i o ukwan, u ta̱ cece.
\p 
\v 40 <<Na̱ a̱nji a aaci a vuma o oco, reve wo o'wo nu ukparu, u ta̱ cece.
\v 41 Na̱ a̱nji a̱ cin vuma ɗa o ocoi reve wo o'wo nu ukparu wu cin, u ta̱ cece.
\v 42 Agba nna̱ mɓa̱la̱ n shili uryoryo mu ɗe o ukparu wa aaci'i ko a̱ cin, mɓa̱la̱ n vama mu ukwan n ɗa mu uta̱i a aaci ko a̱ cin va̱ yi.
\v 43 Reve ganu ka̱lyuwa̱ yi, nna̱ utsutsu wu mɓa̱la̱'a̱ u tu ushili uryoryo o ukparu wa aaci a̱ yi ko a̱ cin, tsu mɓa̱la̱ mu ukutu,
\v 44 to, vuma'a u ta̱ nu ukutu, waru u ta̱ idaba. Na a ciga a 'yuwan ganu damma u ta̱ idaba, adama a na u ri nu ukutu a aaci.
\p 
\v 45 <<Za vu cu'un vu mɓa̱la̱ n ndolo, to oto akari a̱ a̱tugu, reve u lyawa a̱nji a̱ yi za̱kpa̱kpa̱. Reve u ɓa̱ru urewesu wa̱ yi za̱la̱ vunu reve u saala, <N ta̱ idaba, N ta̱ idaba!>
\v 46 Mantsa ma na u ri na̱ mɓa̱la̱'a̱ suru, u ta̱ da̱na̱ idaba. U ta̱ da̱nu a̱ nde'en. Uba̱ta̱ a̱ nden ma̱ yi u to o'wo o ucina̱ wu uba̱ta̱ o uva̱la̱ta̱.
\s1 Wila̱ adama e itana i na i pa̱luwa̱i
\p 
\v 47 <<Na̱ a̱ tsura̱ mɓa̱la̱ mu upa̱luwusa̱ o utugu, ko utugu wu uɗavu ko okoro,
\v 48 ko ili yu uɗavu ko o okoro ko o ukwan ko a̱ cu'un vi ili i na biti a yuwain nu ukwan,
\v 49 na̱ mɓa̱la̱'a̱ n ta̱ mini ma̱ a̱vu'un ko ushili o utugu'u, ko o ukwa'an ko o uɗavu ko o okoro, ko a̱ cu'un vi ili i na a yuwain nu ukwa'an biti, adanshi a̱ mɓa̱la̱ mu upa̱luwusa̱ u ɗa, o to roco ganu a̱yi.
\v 50 Ganu ta̱ ka̱lyuwa̱ mɓa̱la̱'a̱, reve u ɓa̱ru ili i na i ri na̱ mɓa̱la̱'a̱ hali rana cindere.
\v 51 Reve u ka̱lyuwisa̱ mɓa̱la̱'a̱ o urana we cindere. Na̱ mɓa̱la̱'a̱ n bala o utugu ko o uɗavu ko o ukwan ko a̱ cu'un vi ili i na a yuwain nu ukwan biti, mɓa̱la̱'a̱ mɓa̱la̱ m mona ma ɗa, ili'i wo o'wo ta̱ idaba.
\v 52 U ta̱ kula̱to utugu'u, ko za vu uɗavu ko ukwan ko cu'un vi ili i na a yuwain nu ukwan biti, i na i la̱nga̱i na̱ a̱yi, adama a na mɓa̱la̱ m mona ma ɗa. A̱ ta̱ kula̱to le a akina.
\p 
\v 53 <<Agba na̱ ganu ka̱lyuwa̱ a̱vu mɓa̱la̱'a̱ n bala o utugu'u shi, ko a za vu uɗavu ko o ukwan ko a̱ cu'un vi ili i na a yuwain nu ukwan biti,
\v 54 reve u zuwa a̱ za̱'wa̱ ili i na mɓa̱la̱'a̱ n ri ɗe. Reve u ɓa̱ru ili'i hali rana cindere waru.
\v 55 Na̱ a̱ za̱'wa̱ uba̱ta̱ u na ri na̱ mɓa̱la̱'a̱, reve ganu ka̱lyuwa̱ yi. No oroci a̱ mɓa̱la̱'a̱ a vadala shi, ko ana mɓa̱la̱'a̱ m balai shi, u ta̱ idaba. A̱ ta̱ kula̱to yi na akina, ko na̱ shi upa̱luwu'u u ta̱ pe a̱ a̱tsuma̱ ko na alanga.
\p 
\v 56 <<Waru na̱ ganu'u u ka̱lyuwa̱, reve upa̱luwu'u u kporo cina a̱ za̱'wa̱ yi ɗe, u ta paɗa uba̱ta̱'a̱ o utugu'u, ko o uɗavu ko o ukwan ko e ili i na a yuwain nu ukwa'an.
\v 57 Reve na̱ wu utisa̱ o utugu'u ko o uɗavu ko o ukwan ko a̱ cu'un vi ili i na a yuwain nu ukwan biti, u ta balasa. A̱ ta̱ kula̱to ili i na suru i ri na̱ mɓa̱la̱'a̱.
\v 58 Agba utugu'u ko za vu uɗavu ko ukwan ko cu'un vi ili i na a yuwain nu ukwan biti, za na mɓa̱la̱'a̱ m puwa̱yin ana a̱ za̱'wa̱ niyi, a̱ ta̱ za̱'wisa̱ yi ire, reve u ka̱mba̱ cece.>>
\p 
\v 59 A̱yi nda a̱yi ɗa wila̱ adama a̱ mɓa̱la̱ mu upa̱luwusa̱ n na n ri o utugu ko za vu uɗavu ko o okoro ko o ukwan ko a̱ cu'un vi ili i na a yuwain nu ukwan biti, adama u roco ko u ta̱ cece ko idaba.
\c 14
\s1 Uka̱mba̱tosu wu ukwan u lipu u na u ri na̱ mɓa̱la̱ cece
\p 
\v 1 A̱sulazuva a yuwan ta̱ adanshi na̱ Musa u damma,
\v 2 <<Apa nda wila̱ adama a za na ri na̱ mɓa̱la̱ mu ukwan u lipu adama o urana u na wa̱a̱ ka̱mba̱ cece, na̱ a̱ ta̱wa̱ na̱ a̱yi uba̱ta̱ wa ganu:
\v 3 ganu to uta̱ o ucina̱ wu uba̱ta̱ o uva̱la̱ta̱, reve u ka̱lyuwa̱ yi. Na̱ mɓa̱la̱'a̱ n koto ta̱ a vuma vu mɓa̱la̱ mu ukwa'an,
\v 4 u ta zuwa a̱ ta̱wa̱a̱ na̱ nnunu n cece n re n wuma adama a za na a̱a̱ ka̱mba̱to cece'e, na̱ ɗanga seda na̱ a̱punda̱ a̱ shili o uɗavu no oroci o osondori.
\v 5 Reve ganu zuwa le a paɗa manunu ma̱ ta̱ a̱ nnunu n re'e zuva vu upondo u ci'in u na u ri na̱ mini ma sa'ani.
\v 6 Reve u tara manunu ma wuma ma na ma buwai oɓolo na̱ ɗanga seda na̱ a̱punda̱ a̱ shili o uɗavu no oroci o osondori. A̱vu u tsupu le a mpasa m manunu ma na a paɗai zuva mini ma sa'ani'i.
\v 7 Reve wu kyo'onuwo za na a̱a̱ ka̱mba̱to cece diga a̱ mɓa̱la̱ mu ukwan toto ucindere. Reve u damma u ta̱ cece, a̱vu u lyawa manunu ma wuma'a u ka̱ra̱ a̱tsumona.
\v 8 Reve a̱yi za na a̱a̱ ka̱mba̱to cece'e wu za̱'wa̱ a̱tugu a̱ yi, u puna a̱nji a̱ yi, a̱vu u sumba̱ na̱ mini. U ta̱ gba o o'wo cece. Reve no o koto za ndolo u ka̱mba̱ o uva̱la̱ta̱, amma wa̱a̱ da̱nu o oogodo a̱ yi shi hali rana cindere.
\v 9 O urana we cindere, reve u puna a̱nji a aaci a̱ yi suru, na̱ ntsuka̱ ma̱ yi na̱ a̱ga̱pa̱na̱ a̱ yi. U ta puna eleme a̱ lipu va̱ yi suru. Reve wu za̱'wa̱ a̱tugu a̱ yi, a̱vu u sumba̱ na̱ mini, a̱vu wo o'wo cece.
\p 
\v 10 <<Agba o urana wa̱ kunla̱ u ta tara mugiri'i n re n na n ri usa̱du shi na̱ mokyokyon ma̱ ta̱ ma aa'wan a̱ ta̱ nu umatsun za na ri usa̱du shi, na̱ makundatsu uta'atsu u yira i lashi a̱tsuma̱ a kupa u efa u na a̱ ja̱mba̱ra̱i nu uɓatsulai u ta̱ wu ta'atsu u mata'an ma mani'in.
\v 11 Reve ganu na a̱a̱ ka̱mba̱to yi cece'e u ta̱ ta̱wa̱ na̱ za na a̱a̱ ka̱mba̱to cece'e oɓolo na̱ kucci va̱ yi a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva o una̱ntsu wo Oogodo o Uga'asusan.
\v 12 Reve ganu tara ma̱giri'i ma̱ ta̱, a̱vu u yuwaan kucci makuɗa ma̱ wila̱ oɓolo nu uɓatsulai u ta̱ wu ta'atsu u mata'an ma mani'in. A̱vu u 'ya̱sa̱n le kucci vu u'ya̱susa̱n e ekere a̱ A̱sulazuva.
\v 13 Reve u paɗa a̱a̱giri'i'i uba̱ta̱ u na a tsu paɗa kucci vu unusu na̱ kucci vu ukula̱tosu Upasu wa Akiza. Tsa̱ kucci vu unusu, kucci makuɗa ma̱ wila̱ fo akunda a ganu a ɗa, a̱yi ɗa u la'ai akiza.
\v 14 Ganu te kene mpasa n kucci vu unusu'u, reve u daɓa yi e lege vu utsuvu wu za na a̱a̱ ka̱mba̱to cece'e, na a aakatsu a gbain o ukere u sa'ani wa̱ yi na a aakatsu a gbain a anana o ukere u sa'ani wa̱ yi.
\v 15 Reve ganu kene mani'in, reve u tsun yi a apata o ukere wu ugula̱ wa̱ yi.
\v 16 Reve u tsupu aakatsu e ire o usa'ani wa̱ yi a mani'in ma na ma̱ ri a apata o ukere wu ugula̱ wa̱ yi'i, reve wu kyo'onu toto ucindere a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 17 Reve akapi a na a buwai o ukere wa̱ yi'i, u daɓa e lege vu utsuvu vu ukere u sa'ani wu za na a̱a̱ ka̱mbuwa̱ cece'e na a aakatsu a gbain o ukere u sa'ani na a aakatsu a gbain a anana o usa'ani wa̱ yi zuva vu mpasa m makuɗa ma̱ wila̱.
\v 18 Reve akapi a mani'in ma na ma buwai o ukere wa ganu'u u tsun le a aaci a za na a̱a̱ ka̱mba̱to cece'e u yuwaan yi kucci matara mo ume mo unusu a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\p 
\v 19 <<Ganu ta ca kucci vu unusu u yuwaan za na a̱a̱ ka̱mba̱to cece'e kucci matara mo ume mo unusu diga e idaba ya̱ yi. Reve na̱ a̱yi ndolo koto u paɗa kucci vu ukula̱tosu'u.
\v 20 Reve ganu'u u yuwan kucci'i a masa'a oɓolo na̱ kucci vi ishina, u yuwaan yi kucci matara mo ume mo unusu. Reve gba u ka̱mba̱ cece.
\p 
\v 21 <<Amma na̱ za vu ulambu ɗa, agba waa gura tsura̱ ili i nda shi, reve u tara ma̱giri'i ma̱ ta̱ adama a̱ kucci makuɗa ma̱ wila̱ za na a̱a̱ 'ya̱sa̱n, adama a matara mo ume mo unusu wa̱ yi na̱ makundatsu ma̱ ta̱ ma yira i lashi a̱tsuma̱ a kupa u efa uja̱mba̱ru nu uɓatsulai u ta̱ wu ta'atsu u mata'an ma mani'in adama a̱ kucci vi ishina na̱ mani'in,
\v 22 na̱ muɗa n re ko murukuku n re, za na suru waa gura tsura̱. Za ta̱ to o'wo kucci vu unusu za ta̱ waru adama kucci vu ukula̱tosu.
\v 23 Reve o urana wa̱ kunla̱ u ta̱wa̱ ne ele ya ganu o una̱ntsu wo Oogodo o Uga'asusan a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva adama o uka̱mba̱tosu wa̱ yi cece.
\v 24 Reve ganu tara ma̱giri'i ma̱ kucci makuɗa ma̱ wila̱ oɓolo nu uɓatsulai u ta̱ wu ta'atsu u mata'an u mani'in. Reve ganu 'ya̱sa̱n le kucci vu u'ya̱susa̱n a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 25 Reve u paɗa ma̱giri'i'i ma̱ kucci makuɗa ma̱ wila̱ꞌa̱. Reve u kene mpasa n kucci m makuɗa ma̱ wila̱ꞌa̱, reve u daɓa e lege vu utsuvu vu ukere wu usa'ani wu za na a̱a̱ ka̱mba̱to cece'e, na a aakatsu a gbain o ukere u sa'ani wa̱ yi na a aakatsu a gbain a anana o usa'ani wa̱ yi.
\v 26 Reve ganu tsun akapi a mani'in a apata o ukere wu ugula̱ wa̱ yi.
\v 27 Reve wu kyo'onu akapi a mani'in ma na ma̱ ri o ukere wu ugula̱ wa̱ yi'i na aakatsu e ire o usa'ani toto ucindere a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 28 Reve akapi a mani'in ma na ma buwai o ukere wa̱ yi u daɓa yi e lege vu utsuvu wu usa'ani wu za na a̱a̱ ka̱mba̱to cece'e, na a aakatsu a gbain o ukere wu sa'ani na a aakatsu a gbain a anana o usa'ani, uba̱ta̱ u na a̱ tsuyin mpasa n kucci makuɗa ma̱ wila̱.
\v 29 Reve akapi a mani'in ma na ma buwai o ukere wa ganu'u u tsun yi a aaci a za na a̱a̱ ka̱mba̱to cece'e, adama a yuwaan yi kucci matara mo ume mo unusu a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 30 Reve u ca muɗa n re ko murukuku n re, ili i na waa gura tsura̱ suru.
\v 31 Za ta̱ adama a kucci vu unusu za ve ire waru adama a̱ kucci vu ukula̱tosu, oɓolo na̱ kucci vi ishina. Reve ganu ca kucci matara mo ume mo unusu'u a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva o una̱ wu za na a̱a̱ ka̱mba̱to cece'e.
\p 
\v 32 <<A̱yi nda a̱yi ɗa wila̱ adama a za na ri na̱ mɓa̱la̱ mu ukwan u lipu n vama, za na aa gura ta̱wa̱a̱ na̱ kucci na a zuwai adama o uka̱mba̱tosu wa̱ yi cece shi.>>
\s1 Uka̱mba̱tosu cece diga o upa̱luwusa̱
\p 
\v 33 A̱sulazuva a yuwan ta̱ adanshi na̱ Musa na̱ Haruna u damma,
\v 34 <<Ni i uwa e iɗa ya Ka'ana za na maa ca ɗu wo o'wo za ɗu, na̱ n zuwa mɓa̱la̱ n vama n uwa o u'wa u ro e iɗa'a,
\v 35 za vu u'wa'a u ta̱ ta̱wa̱ u damma ganu, <Me ene ta̱ gashi mɓa̱la̱ n uwa ta̱ o u'wa u va̱.>
\v 36 Reve ganu zuwa a̱ pura̱ itana yu u'wa'a kafu ganu 'ya̱wa̱ u ka̱lyuwa̱ mɓa̱la̱'a̱, adama a damma ili i na i ri pe o u'wa'a suru a̱ ta̱ idaba wan. No o koto, reve ganu uwa u ka̱lyuwa̱ u'wa'a.
\v 37 Reve u ka̱lyuwa̱ mɓa̱la̱'a̱. Na̱ mɓa̱la̱'a̱ u ri o uɓaɓu wu u'wa'a na abasa a̱ mini ma̱ a̱vu'un ko sawun, nu u uwa pe o uɓaɓu'u,
\v 38 reve ganu uta̱ o u'wa'a a̱ tyo o una̱ntsu, reve u ɓa̱ru u'wa'a rana cindere.
\v 39 Reve ganu ta̱wisa̱ o urana we cindere u ka̱lyuwa̱. Na̱ mɓa̱la̱'a̱ m bala o uɓaɓu wu u'wa'a,
\v 40 reve ganu'u u zuwa a ta tawa atali a na a̱ ri na̱ mɓa̱la̱'a̱ reve a vari le uba̱ta̱ wi idaba o ugyuru u lyuci.
\v 41 Reve a̱ ra̱ɓuwa̱ uɓaɓu wa̱ a̱tsuma̱ o u'wa'a suru. Reve o oco ili i na a̱ ra̱ɓuwa̱i'i uba̱ta̱ wi idaba o ugyuru u lyuci.
\v 42 Reve a tara atali o ro a zuwa uba̱ta̱ u na o foɗoi ozo o ndolo. Reve a̱ zura̱ ci'in tso ro reve a sura u'wa'a.
\p 
\v 43 <<Na̱ mɓa̱la̱'a̱ mu utisa̱ o u'wa'a, cina wu uta̱a̱ atali'i, reve vuma'a u ra̱ɓuwa̱ u'wa'a a̱vu u sura yi.
\v 44 Reve ganu'u u 'ya̱wa̱ u ka̱lyuwa̱. Reve nna̱ mɓa̱la̱'a̱ m bala pe o u'wa'a, mɓa̱la̱ n vama mu upa̱luwusa̱ n ɗa o uwa'a'a. U'wa'a wo o'wo ta̱ idaba.
\v 45 Reve o ɓoso u'wa'a, na atali a̱ yi na akpata nu usura wu u'wa'a suru. Reve a̱ pura̱ le a̱ tyo o uba̱ta̱ wi idaba o ugyuru u lyuci'i.
\v 46 Za na suru uwai o u'wa'a a̱yi uɓa̱ruwu u to o'wo idaba hali she ulivu.
\v 47 Waru za na asai pe o u'wa'a, ko u lyuwai pe o u'wa'a u ta̱ za̱'wa̱ a̱tugu a̱ yi.
\p 
\v 48 <<Agba na̱ ganu ta̱wa̱ u ka̱lyuwa̱, na̱ mɓa̱la̱'a̱ koto m bala o u'wa'a shi cina a sura yi, u ta damma u'wa'a u ta̱ cece, adama a na mɓa̱la̱'a̱ n koto ta̱.
\v 49 Adama a̱ ka̱mba̱to u'wa'a cece, vuma'a u ta tara nnunu n re na̱ ɗanga seda na̱ a̱punda̱ o uɗavu a̱ shili no oroci o osondori.
\v 50 Reve u paɗa manunu ma̱ ta̱ o upondo u ci'in u na u ri na̱ mini ma sa'ani.
\v 51 Reve u tara ɗanga seda no oroci o osondori na̱ a̱punda̱ a̱ shili o uɗavu oɓolo na̱ manunu ma wuma. Reve u tsupu le a mpasa m manunu ma na a paɗai na̱ mini'i, reve wu kyo'onu u'wa'a toto ucindere.
\v 52 Ne ɗa wa̱a̱ ka̱mba̱to u'wa'a cece na̱ mpasa m manunu'u na̱ mini ma sa'ani na̱ manunu ma wuma na̱ ɗanga seda no oroci o osondori na̱ a̱punda̱ o uɗavu a̱ shili.
\v 53 Reve u lyawa manunu ma wuma'a o ugyuru u lyuci wu 'yawan a̱ tyo o ogozo. Ne ɗa waa yuwan kucci matara mo ume mo unusu adama o u'wa'a, reve gba wo o'wo cece.>>
\p 
\v 54 A̱yi nda a̱yi ɗa wila̱ adama a̱ mɓa̱la̱ mu ukwan u lipu: adama e ikavuru,
\v 55 na adama a̱ mɓa̱la̱ mu upa̱luwusa̱ o utugu ko o u'wa,
\v 56 na adama o utsutsu ko adama e ikavuru ko abasa o uryoryo,
\v 57 adama u roco a mantsa ma na u ri idaba na̱ mantsa ma na u ri cece. A̱yi ɗa wila̱ adama a̱ mɓa̱la̱ mu ukwan n lipu.
\c 15
\s1 Ma̱ɗa̱wa̱ ma na ma tsu ta̱wa̱ ni idaba
\p 
\v 1 A̱sulazuva a yuwan ta̱ adanshi na̱ Musa na̱ Haruna u damma,
\v 2 <<Yuwain adanshi na aza a Isra'ila i damma le, na̱ vali ri a̱ ɗa̱wusa̱ a̱ lipu tsali tsa̱ yi, wuɗa̱wusa̱'a̱ ili yi idaba i ɗa.
\v 3 Ko na̱ ma̱ɗa̱wa̱'a̱ u lyuwa elime ko u gulu, u ta zuwa yi wo o'wo idaba. Apa nda cine ma̱ɗa̱wa̱ ma̱ yi maa zuwa idaba:
\v 4 Uba̱ta̱ wu nven n na vuma na a̱a̱ ɗa̱wusa̱ voyin suru u to o'wo idaba. Waru e ili i na u da̱nuyi suru u to o'wo idaba.
\v 5 Za na suru ju'wa̱in uba̱ta̱ wu nven wa̱ yi u ta̱ za̱'wa̱ a̱tugu a̱ yi, reve u sumba̱ na̱ mini, a̱vu wo o'wo idaba hali ulivu.
\v 6 Waru za na suru da̱nuyi e ili i na za na a̱a̱ ɗa̱wusa̱ da̱nuyi, u ta̱ za̱'wa̱ a̱tugu a̱ yi. Reve u sumba̱ na̱ mini, reve u buwa idaba hali she ulivu.
\v 7 Za na suru ju'wa̱in lipu vu za na a̱ ɗa̱wusa̱, u ta̱ za̱'wa̱ a̱tugu a̱ yi, reve u sumba̱ na̱ mini, reve wo o'wo idaba she ulivu.
\p 
\v 8 <<Na̱ za na a̱a̱ ɗa̱wusa̱ tsuwa̱a̱n za na ri cece ma̱tsa̱n, za na a̱ tsuwa̱yin ma̱tsa̱'a̱n u ta̱ za̱'wa̱ a̱tugu a̱ yi, reve u sumba̱ na̱ mini, reve wo o'wo idaba she ulivu.
\v 9 Urutsu u na za ma̱ɗa̱wa̱'a̱ u da̱nuyi suru u to o'wo idaba.
\v 10 Waru za na suru ju'wa̱in ili i na biti i ri za̱la̱ vu urutsu'u u to o'wo idaba hali ulivu. Waru za na suru tanuyi ili i ndolo u ta̱ za̱'wa̱ a̱tugu a̱ yi, reve u sumba̱ na̱ mini. Reve wo o'wo idaba she ulivu.
\v 11 Za na suru za ma̱ɗa̱wa̱ ju'wa̱in agba u sa'a ekere a̱ yi na̱ mini shi, u ta̱ za̱'wa̱ a̱tugu a̱ yi reve u sumba̱ na̱ mini, a̱vu wo o'wo idaba she ulivu.
\v 12 Upondo u ci'in u na za ma̱ɗa̱wa̱ ndolo ju'wa̱in suru o to ɓoso yi, agba ili i na suru u ju'wa̱in i na a yuwain nu uɗanga a̱ ta̱ za̱'wa̱ yi na̱ mini.
\p 
\v 13 <<Na̱ a̱ ka̱mba̱to vuma cece diga a̱ ma̱ɗa̱wa̱ ma̱ yi, reve u kecee aciya̱yi rana cindere vu uka̱mba̱tosu cece va̱ yi, reve wu za̱'wa̱ a̱tugu a̱ yi. A̱vu u sumba̱ aciya̱yi na̱ mini ma sa'ani a̱vu wo o'wo cece.
\v 14 Reve o urana wa̱ kunla̱ u tara muɗa n re ko murukuku n re, a̱vu u ta̱wa̱ a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva o una̱ntsu wo Oogodo o Uga'asusan, a̱vu u ca ganu ele.
\v 15 Reve ganu ca kucci le, za ta̱ kucci adama o unusu za ta̱ kucci vu ukula̱tosu. Ne ɗa ganu aa yuwan kucci matara mo ume mo unusu o una̱ wa̱ yi a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva adama a̱ ma̱ɗa̱wa̱ ma̱ yi.
\p 
\v 16 <<Na̱ tsali tsa vuma tso oco, u ta̱ sumba̱ lipu va̱ yi suru na̱ mini a̱vu wo o'wo idaba hali she ulivu.
\v 17 Utugu ko ukwan u na tsali'i tsa̱ ju'wa̱in biti a̱ ta̱ za̱'wa̱ yi na̱ mini reve wo o'wo idaba hali she ulivu.
\v 18 Na̱ vuma von na̱ ka hali tsali tso uta̱, ele ra a̱ ta̱ sumba̱ na̱ mini, reve o o'wo idaba hali she ulivu.
\p 
\v 19 <<Na̱ ka e eneshe a̱shinda̱ o usumbu a̱ yi, u ta̱ da̱na̱ a̱tsuma̱ e idaba yu usumbu wa̱ yi hali rana cindere. Za na suru ju'wa̱n niyi u to o'wo idaba hali she ulivu.
\v 20 E ili i na ka'a u voyin suru a mantsa mo usumbu ma̱ yi u to o'wo idaba. Waru e ili i na u da̱nuyi suru u to o'wo idaba.
\v 21 Za na suru ju'wa̱in ili yi nven ya̱ yi u ta̱ za̱'wa̱ a̱tugu a̱ yi a̱vu u sumba̱ na̱ mini, reve wo o'wo idaba hali she ulivu.
\v 22 Za na waru ju'wa̱in ili i na wa̱a̱ da̱nusu, u ta̱ za̱'wa̱ a̱tugu a̱ yi reve u sumba̱ na̱ mini, reve wo o'wo idaba hali she ulivu.
\v 23 Ko ili yi nven i ɗa ko ili i na u shi nden, na̱ vuma ro ju'wa̱n yi u to o'wo idaba hali she ulivu.
\v 24 Waru na̱ vuma von na̱ a̱yi reve mpasa mu usumbu ma̱ yi n ju'wa̱n yi, u to o'wo idaba rana cindere. Ili yi nven i na suru vali'i u voyin u to o'wo idaba.
\p 
\v 25 <<Na̱ ka ri ocosu mpasa hali rana a̱bunda̱ agba mpasa mu usumbu ma̱ yi n ɗa shi, ko gba moco ma mpasa'a ma̱ ka̱ra̱ mantsa mo usumbu ma̱ yi, rana moco ma mpasa'a suru u ta̱ da̱na̱ a̱tsuma̱ e idaba. U ta̱ da̱na̱ a̱tsuma̱ e idaba tsa rana vu usumbu va̱ yi.
\v 26 Ili yi nven i na u voyin suru a rana moco ma mpasa ma̱ yi u to o'wo idaba tsa mantsa mo usumbu wa̱ yi. Waru e ili i na suru u da̱nuyi u to o'wo idaba, tsa rana vu usumbu va̱ yi.
\v 27 Za na suru ju'wa̱in ili i nda u to o'wo idaba. U ta̱ za̱'wa̱ a̱tugu a̱ yi reve u sumba̱, reve wo o'wo idaba hali she ulivu.
\v 28 Amma na̱ wo o'wo cece diga o moco ma mpasa'a, u te kecee aciya̱yi rana cindere, na a yuwan ne, u to o'wo cece.
\v 29 O urana wa̱ kunla̱ reve u tara muɗa n re ko murukuku n re. Reve u ta̱wa̱ ne ele ya ganu o una̱ntsu wo Oogodo o Uga'asusan.
\v 30 Reve ganu ca za ta̱ kucci adama o unusu za ve ire waru kucci vu ukula̱tosu. Ne tsunda tsa ɗa ganu a yuwan kucci ma matara mo ume mo unusu o una̱ wa̱ yi a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva adama e idaba i wocosu wa̱ yi.
\p 
\v 31 <<Ne ɗa vaa kasa aza a Isra'ila ni ili i na yoo o'woto le idaba, adama a̱ kuwa̱ a̱tsuma̱ e idaba i le wan na̱ a̱ lungusa̱ uba̱ta̱ wu nden n va̱ n na n ri e memere me le.>>
\p 
\v 32 A̱yi nda a̱yi ɗa ili i na aa yuwan adama a za na o o'woi idaba adama a̱ ma̱ɗa̱wa̱ ko za na tsali tsa̱ yi tsoo ocusho.
\v 33 Na adama a ka na ri na̱ a̱shinda̱ o usumbu wa̱ yi, adama a vali ko ka na suru ri o ocosu, waru na adama a vali na voyin na̱ ka na ri idaba.
\c 16
\s1 Urana u matara mo ume mo unusu
\p 
\v 1 A̱sulazuva a yuwan ta̱ adanshi na̱ Musa cina olobo e re a Haruna a̱ kuwa̱ ɗe, ana a̱ ta̱wa̱i a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva na akina a na a ntsayi shi, a̱vu gba a̱ kuwa̱.
\v 2 Reve A̱sulazuva a damma Musa, <<Damma mawun ma̱ a̱na̱wu ma̱ wu Haruna, she u uwa Upasu wa Akiza o ucina̱ wu umuna elime e ikpa̱ta̱tsu ya Akpati mantsa ma na u cigai biti wan, ta̱wa̱ u kuwa̱ wan. Adama a na n ta̱ ta̱wa̱ e eleshe e ikpa̱ta̱tsu ya Akpati'i.
\v 3 Apa nda cine Haruna aa uwa Upasu wa Akiza: u ta uwa na̱ moggono ma nan ma̱ kucci vu unusu na̱ a̱a̱giri'i a̱ kucci vu ukula̱tosu.
\v 4 U to oto a̱tugu a akiza o okoro na̱ mokoɗi ma aacaka a̱ lipu va̱ yi. Reve wu nla̱ gbakala vu umuna e ikyun ya̱ yi, a̱vu wo oto ookokolo o okoro. A̱tugu a akiza a ɗa adama o ndolo u ta̱ sumba̱ kafu wo oto le.
\v 5 U ta̱ ushi nga̱ji n re e ekere a ama a Isra'ila adama a̱ kucci vu unusu, na̱ a̱a̱giri'i a̱ ta̱ adama a̱ kucci vu ukula̱tosu.
\p 
\v 6 <<Haruna ta ca nan kucci vu unusu adama a aciya̱yi, u yuwan kucci matara mo ume mo unusu wa̱ yi na adama o u'wa wa̱ yi.
\v 7 Reve u tara nga̱ji n re'e, a̱vu u ta̱wa̱ ne ele a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva o una̱ntsu wo Oogodo o Uga'asusan.
\v 8 Reve u zuwa agita e mgbele n re'e, za ta̱ adama a̱ A̱sulazuva za ta̱ adama a Azaze\f + \fr 16:8 \ft Azaze a̱yi ɗa nama na vaa tara unusu o una̱ u vuma\f*.
\v 9 Reve Haruna ta̱wa̱ na̱ za na agita a̱ riya̱yi adama a̱ A̱sulazuva u yuwan kucci vu unusu na̱ a̱yi.
\v 10 Amma za na agita a̱ riya̱yi adama a Azaze a̱ ta̱ ta̱wa̱ na̱ a̱yi wuma a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva a yuwan ili i na a tsu yuwan i matara mo ume mo unusu. A̱ gba̱ra̱ yi a̱ tyo a̱tsumona tsa̱ a̱gba̱ri a Azaze.
\p 
\v 11 <<Haruna ta̱ ta̱wa̱a̱ no ogono a nan kucci vu unusu wa̱ yi. Reve u yuwan kucci matara mo ume mo unusu adama a aciya̱yi na adama o u'wa wa̱ yi. U ta paɗa na'an kucci vu unusu va aciya̱yi.
\v 12 Reve u tara aayimba tapu na akinkina a na a̱ ri na akina diga a masa'a a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva. Reve u shiton ukere u re ni ili i ma̱guru u uwa ne ele a̱tsuma̱ o umuna.
\v 13 Reve u tsun ili i ma̱guru'u a akina'a a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva adama mikyon ma a̱tsuka̱'a̱ m ɓa̱ru ikpa̱ta̱tsu ya akpati'i, uba̱ta̱ u matara mo ume mo unusu, ta̱wa̱ u kuwa̱ wan.
\v 14 Reve u kene mpasa mo ogono a na'an reve wu kyo'onu yi na aakatsu a̱ yi elime e ikpa̱ta̱tsu ya akpati a matara mu ume mo unusu upasu wa asana. Reve waru wu kyo'onu akapi na aakatsu a̱ yi toto ucindere elime e ikpa̱ta̱tsu ya akpati'i.
\p 
\v 15 <<Reve u paɗa megbele ma̱ kucci vu unusu'u adama a ama. Reve u ta̱wa̱ na̱ mpasa'a o ucina̱ wu umuna'a, a̱vu u yuwan na̱ a̱yi cine u yuwain na̱ mpasa mu na'an. Wu kyo'onu yi zuva vi ikpa̱ta̱tsu va akpati'i na̱ a̱ ma̱ka̱ka̱n ma̱ yi.
\v 16 Ne ɗa waa yuwan kucci matara mo ume mo unusu adama o Upasu u na u La'ai Akiza, adama e idaba ya aza a Isra'ila na adama a aciyogbamu u le, ko cu'un vu unusu ne a yuwain. Ne ɗa waa yuwaan fo Oogodo o Uga'asusan a na a̱ ri uba̱ta̱ u le, e memere me idaba i le.
\v 17 Ko za da̱na̱ pe o Oogodo o Uga'asusan wan a̱ mantsa ma na Haruna ganu aa uwa u yuwan kucci matara mo ume mo unusu Upasu u na u La'ai Akiza, hali she na̱ wu uta̱ nu u koto mayan ma̱ kucci matara mo ume mo unusu adama a aciya̱yi nu u'wa wa̱ yi na adama a ama a Isra'ila suru.
\v 18 Reve wu uta̱ a̱ 'ya̱wa̱ uba̱ta̱ u masa'a ma na ma̱ ri a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva u yuwan kucci matara mo ume mo unusu adama a̱ yi. Reve u kene mpasa mo ogono a na'an na̱ mpasa m megbele'e u putala yi a avana a masa'a'a.
\v 19 U to kyo'onuwo yi mpasa'a na aakatsu a̱ yi toto ucindere, adama wo o'woto yi cece, waru u lapula yi e ekere e idaba ya aza a Isra'ila.
\p 
\v 20 <<Nu u koto mayan ma̱ kucci matara mo ume mo unusu adama o Upasu u na u La'ai Akiza'a no Oogodo o Uga'asusan na̱ masa'a, reve u ta̱wa̱a̱ na̱ megbele ma wuma'a.
\v 21 Reve Haruna kuru ekere a̱ yi ra a aaci a megbele ma wuma'a reve u damma iwuya na aciyogbamu nu unusu wa aza a Isra'ila suru. U zuwa le suru a aaci e megbele'e reve u gba̱ra̱ yi a̱ tyo a̱tsumona e ekere a vuma na a zuwai ulinga u ndolo.
\v 22 Megbele'e ma ta tanu unusu wa ama'a suru a̱ tyo uba̱ta̱ u na za ri shi, reve vuma'a u lyawa yi a̱ a̱tsumona.
\p 
\v 23 <<Reve Haruna uwa a̱tsuma̱ o Oogodo o Uga'asusa'an, reve u foɗo a̱tugu o okoro a na u shi wo otoi kafu u uwa Upasu u na u La'ai Akiza'a reve u lyawa le pe.
\v 24 Reve u sumba̱ lipu va̱ yi na̱ mini uba̱ta̱ wa akiza, a̱vu wo oto a̱tugu a̱ yi. A̱vu wu uta̱ u ca kucci vu ukula̱tosu va̱ yi na̱ kucci vu ukula̱tosu va ama, u yuwan kucci matara mo ume mo unusu wa̱ yi na̱ za va ama'a.
\v 25 Agba u ta̱ kula̱to abaji a mani'in ma̱ kucci vu unusu a masa'a.
\v 26 Vuma na lyawai megbele Azaze ma̱ ka̱ra̱ a̱gba̱ri, u ta̱ za̱'wa̱ a̱tugu a̱ yi, reve u sumba̱ na̱ mini. Na a yuwan u ta gura uwa o uva̱la̱ta̱.
\v 27 Agba nan na̱ megbele ma na a yuwayin kucci vu unusu'u aza a na a̱ ta̱wa̱i na̱ mpasa n le Upasu u na u La'ai Akiza adama a̱ kucci matara mo ume mo unusu a ta tara le a̱ tyo o ucina̱ wu uva̱la̱ta̱ a̱ kula̱to le. A̱vu a̱ kula̱to kwan le ni iliya̱tsuma̱ i le na̱ a̱ya̱n e le.
\v 28 Vuma na kula̱to nle'e u ta̱ za̱'wa̱ a̱tugu a̱ yi, reve u sumba̱ na̱ mini. Na a yuwan ne u ta gura uwa o uva̱la̱ta̱.
\p 
\v 29 <<A̱yi nda u to o'wo ili i na i ri n yuwusan kukuci: o urana wa kupa u woto we cindere, yaa lyuwa shi waru yaa yuwan ulinga shi, umatsun u lyuci ko omocin a na ri o limocin a̱tsuma̱ a̱ ɗu.
\v 30 Adama a na o urana u nda u ɗa aa yuwan kucci matara mo ume mo unusu adama a̱ ɗu, adama a̱ ka̱mba̱to ɗu cece. I to o'wo cece a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva diga a̱ nusu ɗu suru.
\v 31 Ashibi a̱ wivuwun a ɗa la̱nga̱ e ekere a̱ ɗu, yaa lyuwa gba ili shi. A̱yi nda ili i na ya̱a̱ da̱na̱ a yuwusan ɗa kukuci.
\v 32 Ganu na a̱ tsuyin mani'in a tawa niyi wo o'wo ganu o una̱ wa dada va̱ yi ɗa aa ca kucci matara mo ume mo unusu, wotowu na̱ a̱tugu a akiza o okoro.
\v 33 Reve u yuwan kucci matara mo ume mo unusu adama o Upasu u na u La'ai Akiza. Reve u ca kucci matara mo ume mo unusu adama o Oogodo o Uga'asusa'an na adama a masa'a na adama a nan ganu na adama o oɓolo a ama'a suru.
\p 
\v 34 <<A̱yi nda u to o'wo ili i na i ri n yuwusan kukuci. A̱ ta̱ a̱ ri n yuwusan kucci matara mo ume mo unusu adama o unusu wa ama a Isra'ila suru u ta̱ a aa'wan.>> Reve Musa yuwan cine A̱sulazuva a damma niyi.
\c 17
\s1 Uba̱ta̱ u mayan ma̱ kucci
\p 
\v 1 A̱sulazuva a yuwan ta̱ adanshi na̱ Musa u damma,
\v 2 <<Yuwan adanshi na̱ Haruna no olobo a̱ yi na ama a Isra'ila suru vu damma le, <Apa nda ili i na A̱sulazuva a zuwai:
\v 3 na̱ vuma na a̱tsuma̱ a aza a Isra'ila paɗa ogono a nan ko mokyokyon ko megbele pe o uva̱la̱ta̱ ko ucina̱ wu uva̱la̱ta̱,
\v 4 agba u ta̱wa̱ na̱ a̱yi o una̱ntsu wo Oogodo o Uga'asusan u ca kucci vu uneꞌe wa̱ yi e ekere a̱ A̱sulazuva elime a̱ a̱a̱'isa̱ a̱ A̱sulazuva shi, ume wu unusu wu mpasa u ta a aci a̱ yi. Wo oco ta̱ mpasa, a ta tawa vuma ndolo a̱tsuma̱ a ama a̱ yi.
\v 5 A̱yi nda u ta dansa ama a Isra'ila a̱ ta̱ a̱ ri n ta̱wusa̱a̱ na̱ kucci na aa casu a atsusa uba̱ta̱ wa̱ A̱sulazuva e ekere a ganu o una̱ntsu wo Oogodo o Uga'asusan. Reve a ca kucci le vu muwwulai e ekere a̱ A̱sulazuva.
\v 6 Reve ganu kyo'onu mpasa'a a masa'a ma̱ A̱sulazuva o una̱ntsu wo Oogodo o Uga'asusan. Reve u kula̱to abaji a mani'i'in ili i ma̱guru mo uyo'o a̱ tyo e ekere a̱ A̱sulazuva.
\v 7 A̱a̱ da̱shi ca otoni a̱ lima̱ a na a̱ ri no oroci e mgbele kucci shi, aza a na aa yuwusan tsushakala ne ele. A̱yi nda u to o'wo ili i na a̱a̱ da̱na̱ a yuwusan kukuci hali a̱ tyo a mantsa me elime.>
\p 
\v 8 <<Vu damma le, za va Isra'ila ko mocin na suru cayi kucci vu ukula̱tosu ko cu'un kucci ro,
\v 9 agba u ta̱wa̱ na̱ a̱yi o una̱ntsu wo Oogodo o Uga'asusan u ca A̱sulazuva shi, a ta tawa vuma ndolo a̱tsuma̱ a ama a̱ yi.
\s1 A putsa ta̱ nu utamu wa̱ a̱kutsu a mpasa
\p 
\v 10 <<Za va Isra'ila ko mocin na ri nden ne ele suru na tamai a̱kutsu a mpasa, n ta yuwan tsurala na̱ a̱yi, reve n tawa yi a̱tsuma̱ a ama a̱ yi.
\v 11 Adama a na wuma wi ili i wuma i ta̱ a̱tsuma̱ a mpasa ma̱ yi. N ca ɗu ta̱ a̱yi adama i yuwan a̱ga̱nda̱ a matara mo ume mo unusu adama a aciya̱ɗu a masa'a, adama a na mpasa n ɗa n tsu tara ume wu unusu u vuma.
\v 12 Adama o ndolo a ɗa n dammai aza a Isra'ila: ko za a̱tsuma̱ a̱ ɗu ko mocin na ri na̱ nden na̱ a̱ɗu aa tama mpasa shi.
\p 
\v 13 <<Za va Isra'ila na suru, ko mocin na ri na̱ nden a̱tsuma̱ a̱ ɗu na vu unai nama o ugenge ko manunu ma na a tsu tama u to oco mpasa ma̱ yi reve u ciɗo yi na̱ ma̱bula̱.
\v 14 Adama a na wuma wi ili i wuma i ta̱ a̱tsuma̱ a mpasa ma̱ yi. Adama o ndolo a ɗa n dammai aza a Isra'ila: she i tama mpasa mi ili i wuma wan, adama a na wuma wi ili i wuma suru i ta̱ a̱tsuma̱ a mpasa ma̱ yi. Za na suru tama niyi a ta tawa yi.
\p 
\v 15 <<Za na suru tamai a̱kwa̱kwa̱ ko ili i na nama vu una kakarai, ko umatsun u lyuci ko mocin, u ta̱ za̱'wa̱ a̱tugu a̱ yi reve u sumba̱ na̱ mini. Reve u da̱na̱ idaba hali she ulivu, reve wo o'wo cece.
\v 16 Agba na̱ vuma'a wu za̱'wa̱ a̱tugu ko u sumba̱ shi, ume wu unusu u ndolo u ta̱ a aci a̱ yi.>>
\c 18
\s1 Wila̱ adama e tsipere
\p 
\v 1 Reve A̱sulazuva a damma Musa,
\v 2 <<Yuwan adanshi na aza a Isra'ila vu damma le: a̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.
\v 3 She i yuwan cine aa yuwusan a̱tsuma̱ a Masar wan, uba̱ta̱ u na i da̱na̱i na̱ nden. Waru she i yuwan cine aa yuwusan a̱tsuma̱ e iɗa ya Ka'ana wan, uba̱ta̱ u na ma̱a̱ ta̱wa̱to ɗu. She i yuwan cine ele aa yuwusan wan.
\v 4 I toni wila̱ u va̱ reve i kuru ili i na n dammai ulobonu. A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.
\v 5 I toni ili i na n dammai na̱ wila̱ u va̱, adama a na vuma na toniyi nle u ta̱ tsura̱ wuma e ekere e le. A̱mu ɗa A̱sulazuva.
\p 
\v 6 <<She i yuwan zuzu ni imaci i na i ri zuzu na̱ a̱ɗu na yoo von ne ele wan. A̱mu ɗa A̱sulazuva.
\v 7 She vu von na̱ mma va̱ wu vu zuwa dada va̱ wu o'wo ili yi izo'oshi wan. Mma va̱ wu ɗa. She vu von na̱ a̱yi wan.
\v 8 She vu von na̱ ka va dada va̱ wu wan, ili i ndolo i ta zuwa dada va̱ wu o'wo ili yi izo'oshi.
\v 9 She vu von na̱ mawun ma̱ a̱na̱wu ma̱ wu mo usheli wan, ko mawun ma̱ a̱sha̱wu ma̱ wu mo usheli wan, ko mawun mo usheli ma mma va̱ wu wan, ko o u'wa u ta̱ u ɗa a matsan nɗu ko a matsan yi ta̱ uba̱ta̱ u ro.
\v 10 She vu von na̱ mawun ma tsukaya ma̱ wu usheli wu ulobo wa̱ wu wan, ko usheli wu usheli wa̱ wu wan, ili i ndolo i to o'wo wu ili yi izo'oshi.
\v 11 She vu von nu usheli wu ka va dada va̱ wu za na a matsaan niyi wan, mawun ma̱ a̱sha̱wu ma̱ wu ma ɗa.
\v 12 She vu von na̱ mawun ma̱ a̱na̱wu ma dada va̱ wu mo usheli wan, adama a na maci zuzu va dada va̱ wu ɗa.
\v 13 She vu von na̱ mawun ma̱ a̱na̱wu ma mma va̱ wu mo usheli wan, adama a na maci zuzu va mma va̱ wu ɗa.
\v 14 She vu von na̱ ka mawun ma̱ a̱na̱wu ma dada va̱ wu wan, adama a na a̱yi mma va̱ wu ɗa.
\v 15 She vu von na̱ jene va̱ wu wan, ka mawun ma̱ wu ma ɗa. She vu von na̱ a̱yi wan.
\v 16 She vu von na̱ ka mawun ma̱ a̱na̱wu ma̱ wu wan, adama a na ili i nda i to o'wo yi ili yi izo'oshi.
\v 17 She vu von na̱ mma oɓolo nu usheli wa̱ yi wan. Waru she vu von na̱ mawun ma tsukaya ma̱ yi usheli wu ulobo wa̱ yi ko mo usheli wa̱ yi wan, adama a na imaci i zuzu ya̱ yi i ɗa. Iwuya i ɗa ndolo'o.
\v 18 She vu zuwa zawa'a vu ka va̱ wu wo o'wo shewun va̱ yi ka va̱ wu gba ubuwu wuma, a̱vu vu von na̱ a̱yi wan.
\p 
\v 19 <<She vu von na̱ ka a̱yi a mantsa mo usumbu ma̱ yi wan.
\v 20 She vu von na̱ ka moron ma̱ nden ma̱ wu, a̱vu vu lungusa̱ aciya̱wu na̱ a̱yi wan.
\v 21 She vu yuwan kucci na̱ ko mawun ma̱ ta̱ a̱tsuma̱ a̱ muwun ma̱ wu e ekere a̱ a̱a̱ma̱li Mole wan, adama vu ta̱wa̱a̱ na̱ wono e ekere a̱ A̱sulazuva wan. A̱mu ɗa A̱sulazuva.
\v 22 She vu von na̱ vali na̱ vali cine a tsu yuwan na̱ ka wan. Ili yi idaba i ɗa e ekere a̱ A̱sulazuva.
\v 23 She vu von na̱ nama wan a̱vu vu lungusa̱ aciya̱wu. She ka ca lipu va̱ yi nama von na̱ a̱yi wan, ili yi idaba i ɗa.
\p 
\v 24 <<A̱tsuma̱ e re nda suru she i lungusa̱ aciya̱ɗu wan, adama a na tsundolo tsa ɗa ama a na moo lo a̱ ma̱ka̱ka̱n ma̱ ɗu o o'woi ili yi idaba.
\v 25 Tsundolo tsa ɗa iɗa'a yo o'woi idaba. Reve n ca yi oforo adama o unusu wa̱ yi, adama o ndolo a ɗaɗa iɗa'a i shaamai aza a na a̱ ri pe nden.
\v 26 Amma i to toni ili i na n dammai na̱ wila̱ u va̱ agba she i yuwan ili yi idaba i nda wan, ko umatsun wi iɗa i ɗa vu ri ko mocin na ri nden na̱ a̱ɗu,
\v 27 adama a na ili i nda i ɗa suru ama'a a yuwain aza a na a̱ da̱na̱i elime a̱ ɗu, reve iɗa'a yo o'wo idaba.
\v 28 Na̱ yo o'woto iɗa'a ili yi idaba, u ta shaama ɗu cine u shaamai ama a na a̱ shi elime a̱ ɗu.
\v 29 Vuma na yuwain cu'un vi ili yi idaba i nda suru, cu'un vuma ndolo a tawa yi a̱tsuma̱ a ama yi.
\v 30 I toni ili i na n dammai, she i yuwan ili yi idaba ya agadu ya ama a na a yuwusain kafu i ta̱wa̱ pa wan. Waru she i lungusa̱ aciya̱ɗu ne ele wan. A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.>>
\c 19
\s1 Wila̱ icu'un icu'un
\p 
\v 1 Reve A̱sulazuva a damma Musa,
\v 2 <<Vu yuwan adanshi na aza a Isra'ila suru vu damma le, i da̱na̱ na akiza adama a na a̱mu A̱sulazuva A̱sula̱ a̱ ɗu za va akiza ɗa.
\v 3 Vuma suru a̱tsuma̱ a̱ ɗu u ca dada na̱ mma ɗu tsugbain. Reve i yuwan tsutoni nu urana wa Ashibi a̱ va̱. A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.
\v 4 She i zuwa okolo a̱ ɗu a̱ musula̱ wan ko i zuɗa̱a̱ aciya̱ɗu ruma musula̱ mi irumu wan. A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.
\p 
\v 5 <<Ni i ca kucci muwwulai a̱ tyo uba̱ta̱ wa̱ A̱sulazuva, i ca yi cine wu ntsayi a̱ usu yi o una̱ u ɗu.
\v 6 I ta tama kucci'i o urana u ndolo ko nu usana u tawa, ili i na gba i buwai hali urana wa ta'atsu i ta̱ kula̱to yi.
\v 7 Na a tama akapi o urana wa ta'atsu wo o'wo ta̱ ili yi idaba, waru a̱ usu yi shi.
\v 8 Vuma na tama niyi o urana wa ta'atsu biti, imini ya̱ yi i ɗa, adama a na u ka̱mba̱to ta̱ ili ya akiza ya̱ A̱sulazuva wo o'wo ili yi idaba, a ta tawa cu'un vuma ndolo a̱tsuma̱ a ama a̱ yi.
\p 
\v 9 <<A mantsa ma na i gasai itana ya̱ a̱ɗuma̱ a̱ ɗu, she i gasa a̱ tyo a̱ nge'en ma̱ a̱ɗuma̱'a̱ wan ko i toni nu u'yanlu uba̱ta̱ u na i gasai wan.
\v 10 She i ka̱mba̱ u'yanlu o uɗuma̱ wa ataci a̱ ina̱bi wan ko yi ta̱ɗa̱ aza a na o ocoi e iɗa wan. I lyawa le adama a alambi no omocin. A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.
\p 
\v 11 <<She i yuwan wivu wan. She i yuwan epen wan. She i luluma̱ nanza wan.
\v 12 She i kucina na ala a̱ va̱ ne epen wan. Mayuwan ne u to rono ala a̱ A̱sula̱ a̱ wu e iɗa. A̱mu ɗa A̱sulazuva.
\p 
\v 13 <<She i paala moron ma̱ nden ma̱ ɗu wan, waru she i usa itana ya̱ yi wan. She i lyawa ikebe ya aza a azamalinga ya asa o ukere u ɗu wan.
\v 14 She yi isula agulani wan ko i zuwa ili i na irumba̱ ya̱a̱ ta̱ɗa̱tsa̱ wan, amma yu uwwa wovon wa̱ A̱sula̱ a̱ ɗu. A̱mu ɗa A̱sulazuva.
\p 
\v 15 <<She i yuwan uge'etosu wu ulambu u mejege wan. She i roco aɗangulu e ekere a alambi wan ko icigi ba̱ta̱ wu zagbain wan, amma i yuwan uge'etosu wa amayun a̱tsuma̱ o nron mu nden n ɗu.
\v 16 She i baza adanshi e epen a̱tsuma̱ a ama a̱ ɗu wan. She i yuwan ili i na yaa zuwa wuma wu nanza a̱tsuma̱ e meleshe wan. A̱mu ɗa A̱sulazuva.
\p 
\v 17 <<She vu 'yuwan za va̱ wu o okolo a̱ wu wan. Vu ɓara moron ma̱ nden ma̱ wu a alanga e eteshe adama vu tsura̱ akunda o unusu wa̱ yi wan.
\v 18 She i zami ure u na yaa tsupa ko i zuwa nanza o okolo a̱ ɗu wan, amma i ciga moron ma̱ nden ma̱ ɗu tsa aciya̱ɗu. A̱mu ɗa A̱sulazuva.
\p 
\v 19 <<I toni ili i na n dammai. She i ɓolo cu'un vi iliyamunga i ro na̱ cu'un ro adama a yuwan tsukumbi wan. She i cu'wa̱n uɗuma̱ u ɗu ni icu'un, yi icu'un i re wan. She yo oto itana i na a ɗavai na̱ a̱punda̱ e re koko'o wan.
\p 
\v 20 <<Na̱ vuma von na̱ ka na ri aagbashi, za na waru a yuwayin ɗe nanza nzuwulai n na waa zuwa, agba koto a tsupaa yi shi ko wo o'wo fa̱a̱n shi, a ca le oforo a na a ntsayi. O una le wan, adama a na koto wo o'wo fa̱a̱n shi.
\v 21 Amma vuma'a u ta̱ ta̱wa̱ na̱ a̱a̱giri'i o una̱ntsu wo Oogodo o Uga'asusan adama a̱ kucci vu unusu uba̱ta̱ wa̱ A̱sulazuva.
\v 22 Ganu ta yuwaan yi kucci matara mo ume mo unusu na̱ a̱a̱giri'i'i na̱ kucci makuɗa ma̱ wila̱ a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva adama o unusu u na u yuwain, a̱vu a yuwaan yi gafura vu unusu wa̱ yi.
\p 
\v 23 <<Mantsa ma na i uwai a̱tsuma̱ e iɗa'a reve i cu'wa̱n cu'un vu uɗanga na suru tsu matsan muwun ma alya, i tara muwu'un o o'wo ɗu ili yi idaba hali a'wan a ta'atsu, she i lyuwa le wan.
\v 24 A aa'wan a̱ na̱shi umatsun wu ɗanga suru to o'wo ili ya akiza, kucci vi ica uba̱ta̱ wa̱ A̱sulazuva.
\v 25 Amma gba a aa'wan a tawun i ta lyuwa umatsun wu ɗanga'a. Ne ɗa ugasa u ɗu wa̱a̱ da̱shi a̱bunda̱ a̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.
\p 
\v 26 <<She i tama nama a̱yi ubuwu na̱ mpasa ma̱ yi wan. She i yuwan yindi ko tsuboci wan.
\v 27 She i ye'we cin ɗu, ko i ye'we ntsuka̱ n ɗu wan.
\v 28 She yi paɗa lipu ɗu adama a na i ri e mesun mo ukwa̱ wan, ko i yuwan iɗana a̱ lipu ɗu wan. A̱mu ɗa A̱sulazuva.
\p 
\v 29 <<She vu lungusa̱ usheli wa̱ wu o ure u tsipere wan a̱vu ka̱mba̱to yi aashakala, na̱ ne ɗa shi iɗa'a i ta̱ ka̱mba̱ a tsushakala, a̱vu wo o'wo tapu ni iwuya.
\v 30 I toni urana wa Ashibi u va̱, waru i ca a̱a̱'isa̱ a̱ va̱ tsugbain. A̱mu ɗa A̱sulazuva.
\p 
\v 31 <<She i 'ya̱wa̱ uba̱ta̱ wa aza a na o ɓoloso aci na̱ ruhu va̱ a̱kwa̱kwa̱ ko yindi tsa̱ra̱ i zami a̱sa̱la̱ ko ikambishi ya̱'a̱ le wan. She i zami le wan ta̱wa̱ a̱ lungusa̱ ɗu wan. A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.
\p 
\v 32 <<I ca za na ri na̱ yono na abara tsugbain adama a na yaa uwwusa wovon wa̱ A̱sula̱ a̱ ɗu. A̱mu ɗa A̱sulazuva.
\p 
\v 33 <<Na̱ mocin ri nden na̱ a̱ɗu e iɗa i ɗu, she i ɓongi yi wan.
\v 34 I ta yuwaan mocin na ri oɓolo na̱ a̱ɗu cine yaa yuwaan umatsun wi iɗa i ɗu. I ciga yi cine i cigai aciya̱ɗu, adama a na a̱ɗu fo omocin a ɗa i da̱na̱i a̱tsuma̱ a Masar. A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.
\p 
\v 35 <<She i paala nanza ba̱ta̱ o uritosu wu uga'an e iɗa ko ume ko e ili ya̱ a̱bunda̱ wan.
\v 36 I yuwan ulinga ni ili yu uritosu u mejege, ni ili yu ume i mejege. Makundatsu ma na yoo rito ili yu u'yewu u da̱na̱ mejege. A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu za na uta̱a̱ nɗu a̱tsuma̱ a Masar.
\v 37 I reve i toni ta̱ ili i na n dammai suru oɓolo na̱ wila̱ u va̱ suru, i toni le. A̱mu ɗa A̱sulazuva.>>
\c 20
\s1 Oforo adama o unusu
\p 
\v 1 A̱vu A̱sulazuva a yuwan adanshi na̱ Musa u damma,
\v 2 <<Damma aza a Isra'ila, suru za va Isra'ila ko mocin na ri na̱ nden a̱tsuma̱ e le za na cayi ko mawun ma̱ ta̱ a̱tsuma̱ a̱ muwun ma̱ yi a̱ tyo ya̱ a̱a̱ma̱li Mole, a ciga a 'yuwan o una yi. Ama a̱ lyuci'i a ta vuvara yi na atali.
\v 3 N ta yuwan tsurala na̱ vuma ndolo, waru n ta tawa yi a̱tsuma̱ ama a̱ yi. Adama a na u ca ta̱ mawun ma̱ ta̱ a̱tsuma̱ a̱ muwun ma̱ yi a̱ tyo ya̱ Mole. U ka̱mbuwa̱ ta̱ uba̱ta̱ wa akiza a̱ va̱ idaba, waru u tara ala a akiza a̱ va̱ ili ya̱ a̱ɓula̱ shi.
\v 4 Na ama a̱ lyuci'i ene ta̱ ana u cayi mawun ma̱ ta̱ a̱tsuma̱ a̱ muwun ma̱ yi a̱ tyo ya̱ Mole reve a̱ rungwa̱, agba o una yi shi,
\v 5 to n ta yuwan tsurala na̱ vuma'a nu u'wa wa̱ yi. Waru n ta tawa u'wa̱ wa̱ yi nu ugundo wa̱ yi a̱tsuma̱ a ama e le, na̱ suru aza a na a yuwusan tsushakala oɓolo na̱ a̱yi a̱ tyo ya̱ Mole.
\p 
\v 6 <<N ta yuwan tsurala na̱ za na vadalai uba̱ta̱ u moɓolo ma aci no ozo o otoni, no oboci a yuwusan tsushakala uba̱ta̱ e itoni i le. Waru n ta tawa yi a̱tsuma̱ a ama a̱ yi.
\v 7 I tawa aciya̱ɗu waru yo o'wo aza a akiza, adama a na a̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.
\v 8 I guza̱ wila̱ u va̱ reve i kuru le. A̱mu ɗa A̱sulazuva, za na tawa nɗu na akiza.
\p 
\v 9 <<Suru za na isulai dada va̱ yi ko mma va̱ yi a ciga a 'yuwan o una yi, adama a na wi isula ta̱ dada va̱ yi ko mma va̱ yi. Ume wu mpasa ma̱ yi n ta̱ da̱na̱ a aci a̱ yi.
\p 
\v 10 <<Na̱ vuma yuwan tsipere na̱ ka moron ma̱ nden ma̱ yi, ele ra na a yuwain tsipere'e a ciga a 'yuwan o una le.
\v 11 Na̱ vuma von na̱ ka va dada va̱ yi, u zuwa ta̱ dada va̱ yi o'wo ili i wono. Ele ra na a ciga a 'yuwan o una le, ume wu mpasa n le n ta̱ da̱na̱ a aci e le.
\v 12 Na̱ vuma von na̱ jene va̱ yi, ele ra a ciga a 'yuwan o una le, adama a na a yuwan ta̱ ili yu uwuyanu, ume wu mpasa n le n ta̱ da̱na̱ a aci e le.
\v 13 Na̱ vuma von na̱ za va̱ yi vali cine a̱ tsu von na̱ ka, ele ra a yuwan ta̱ ili yi idaba. Na a ciga a 'yuwan o una le, ume wu mpasa n le n ta̱ da̱na̱ a aci e le.
\p 
\v 14 <<Na̱ vuma zuwa usheli na̱ mma va̱ yi, a̱yi ndolo iwuya i ɗa. A̱yi ne ele ra a ciga a 'yuwan a̱ kuloto le a̱tsuma̱ akina, ta̱wa̱ she iwuya i da̱na̱ a̱tsuma̱ a̱ ɗu wan.
\p 
\v 15 <<Na̱ vuma yuwan tsipere na̱ nama a ciga a 'yuwan o una yi, reve fo o una nama'a.
\v 16 Na̱ ka rawa zuzu na̱ nama adama u von na̱ a̱yi, a̱ to una ka'a oɓolo na̱ nama'a. A ciga a 'yuwan o una le, ume wu mpasa n le n ta̱ da̱na̱ a aci e le.
\p 
\v 17 <<Na̱ vuma tara mawun ma̱ a̱na̱wu ma̱ yi, mawun mo usheli ma dada va̱ yi ko mawun mo usheli ma mma va̱ yi, reve a yuwan tsipere, wo o'wo ta̱ ili yi izo'oshi. Na a ciga a 'yuwan a tawa le a̱ ma̱ka̱ka̱n ma ama e le. Adama a na u ca ta̱ zawa'a wono, waru ume wu mpasa ma̱ yi n ta a aci a̱ yi.
\p 
\v 18 <<Nna̱ vali von na̱ ka mantsa ma na we inda a̱shinda̱, u kpa̱tu'wa̱ ataɓu a̱ yi, waru a̱yi ka'a u kpa̱tu'wa̱ ta̱ ataɓu a mpasa ma̱ yi a alanga. Ele ra na a ciga a 'yuwan a tawa le a̱tsuma̱ a ama e le.
\p 
\v 19 <<She vu yuwan tsipere na̱ mawun ma̱ a̱na̱wu ma mma ko za va dada va̱ wu wan, adama a na a̱yi ndolo u ta zuwa yi wo o'wo ili yi izo'oshi, ele ra ume wu mpasa n le n ta̱ da̱na̱ a aci e le.
\v 20 Nna̱ vuma von na̱ ka va dada ke'en va̱ yi, u ta̱wa̱a̱ ta̱ dada ke'en va̱ yi na̱ wono. Ume wu mpasa n le n ta̱ da̱na̱ a aci e le, ele ra a̱ ta̱ kuwa̱ babu mawun.
\v 21 Nna̱ vuma zuwa ka mawun ma̱ a̱na̱wu ma̱ yi, a̱yi ndolo ili yi idaba i ɗa, u ta̱wa̱a̱ ta̱ mawun ma̱ a̱na̱wu ma̱ yi na̱ wono. A̱ ta̱ da̱na̱ babu mawun.
\p 
\v 22 <<I toni adanshi a̱ va̱ na̱ wila̱ u va̱ suru reve i kuru le, adama ta̱wa̱ iɗa i na ma̱a̱ tyowetyo ɗu i shaama ɗu wan.
\v 23 She i yuwan mmalu cine agadu e iɗa i na ma̱a̱ gba̱ra̱ a̱ ma̱ka̱ka̱n ma̱ ɗu a̱ ri wan, adama a na a yuwan ta̱ suru ili i nda, a̱yi ɗa i zuwai me inda idaba i le.
\v 24 Amma n damma ɗu ta̱, i to o'wo na agadu e iɗa i le. N ta ca ɗu a̱yi agadu, iɗa i na yee yeneshe na̱ maani ni ishiki. A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu za na tawa nɗu diga a akapi e elentsu.
\p 
\v 25 <<I ta kakasa inama i na i ri idaba na aza na a̱ ri idaba shi, na̱ nnunu n na n ri idaba na aza a na a̱ ri idaba shi. She yo o'woto aciya̱ɗu idaba o una̱ wu nama ko manunu wan, ko ili i ro i na i ri e ika̱ta̱pu e iɗa, aza a na n tawai a̱ ri idaba uba̱ta̱ u ɗu wan.
\v 26 I to o'wo aza a akiza ya̱'a̱ va̱, adama a na a̱mu A̱sulazuva, za va akiza ɗa. Waru n tawa ɗu ta̱ a̱tsuma̱ a akapi e elentsu adama yo o'wo a̱za̱ a̱ va̱.
\p 
\v 27 <<Vali ko ka na ri o ɓoloso aci na̱ ruhu va̱ a̱kwa̱kwa̱ ko yindi na a ciga a 'yuwan o una yi. A ta vuvara yi na atali, waru ume wu mpasa ma̱ yi n ta̱ da̱na̱ a aci a̱ yi.>>
\c 21
\s1 Wila̱ adama a nan Ganu
\p 
\v 1 Reve A̱sulazuva a damma Musa, <<Yuwan adanshi na̱ nan ganu, olobo a Haruna, vu damma le: She za ta̱ a̱tsuma̱ e le u ju'wa̱n a̱kwa̱kwa̱ a̱tsuma̱ a ama a̱ yi wan u ka̱mba̱to aciya̱yi ili i idaba.
\v 2 She maci va̱ yi i zuzu i ɗa goon wa̱a̱ ju'wa̱n, tsa mma va̱ yi, na̱ dada va̱ yi, nu ulobo wa̱ yi, ko usheli wa̱ yi na̱ mawun ma̱ a̱na̱wu ma̱ yi,
\v 3 ko zakpara ko zawa'a va̱ yi vu ka za na koto revei vali shi, waru koto wo oloi shi za na ri e ekere a̱ yi, adama a̱ yi u ta gura ka̱mba̱to aciya̱yi ili yi idaba.
\v 4 Waru she u ka̱mba̱to aciya̱yi ili yi idaba o una̱ u tsumaci tso lolo va̱ yi wan.
\v 5 Nan ganu'u waru aa puna ogbondo shi, waru she e ye'we cin le, ko e ye'we ntsuka̱ n le wan, waru she a paɗa lipu le wan.
\v 6 A̱ ta̱ da̱na̱ aza a akiza e ekere a̱ A̱sula̱ e le waru a̱ ka̱mba̱to ala A̱sula̱ e le ili ye pere shi, adama a na ele ɗa aa casu A̱sulazuva kucci va akina, ilyalya ya̱ A̱sula̱ e le, adama o ndolo a 'yuwan a ciga a̱ da̱na̱ na akiza.
\v 7 She a zuwa ka na lungusa̱i aciya̱yi na̱ tsushakala wan. Ne ɗa waru a zuwa ka na kakasai na̱ vali va̱ yi wan, adama a nan ganu ama a akiza a ɗa e ekere a̱ A̱sula̱ e le.
\v 8 I tara nan ganu na akiza adama a na ele ɗa a tsu tara kucci vi ilyalya ɗu a ca A̱sula̱ a̱ ɗu. A̱ ta̱ da̱na̱ na akiza e ekere a̱ ɗu, adama a na a̱mu A̱sulazuva a̱ ɗu za na tsu zuwa ɗu aza a akiza, a̱mu akiza a ɗa.
\v 9 Waru usheli wa ganu u na suru u lungusa̱i aciya̱yi wo o'woi ashakala, u ca ta̱ dada va̱ yi wono, a̱ ta̱ kula̱to yi na akina.
\p 
\v 10 <<Ganu gbain na ri zagbain a̱tsuma̱ a̱ a̱za̱ a̱ yi, za na a̱ tsuwa̱yin mani'in a aaci a̱ yi, waru za na a cayi ucira wo oto utugu u tsuganu waa lyawa a̱nji a̱ yi iwa̱u shi ko wu kara a̱tugu a̱ yi shi.
\v 11 Waa rawa uba̱ta̱ u na a̱kwa̱kwa̱ a̱ ri shi tsa̱ra̱ u ka̱mba̱to aciya̱yi ili yi idaba wan, ko adama a mma va̱ yi ɗa ko dada va̱ yi.
\v 12 Woo uta̱ u lyawa uba̱ta̱ wa akiza shi. Adama u ka̱mba̱to a̱a̱'isa̱ a̱ A̱sula̱ a̱ yi idaba wan, adama a na a tawa yi ta̱ o ure wu utsusun u mani'in wa̱ A̱sula̱ a̱ yi. A̱mu ɗa A̱sulazuva.
\v 13 U zuwa ka na koto revei vali shi.
\v 14 Waa zuwa ka na vali va̱ yi kuwa̱i ko ka na kakasai na̱ vali va̱ yi ko ka na lungusa̱i aciya̱yi a tsushakala shi. Agba u zuwa ka diga a̱tsuma̱ a ama a̱ yi za na koto revei vali shi,
\v 15 tsa̱ra̱ u lungusa̱ muwun mu ugundo ma̱ yi a̱tsuma̱ a ama a̱ yi wan. A̱mu ɗa A̱sulazuva za na ka̱mbuwa̱ niyi za va akiza.>>
\p 
\v 16 Reve A̱sulazuva a damma Musa,
\v 17 <<Vu yuwan adanshi na̱ Haruna, vu damma yi, diga gogo hali a̱ tyo mantsa me elime ko za a̱tsuma̱ o ugundo wa̱ wu za na ri na̱ mɓa̱la̱ aa lyawa yi u rawa zuzu u ca kucci vi ilyalya ya̱ A̱sula̱ a̱ yi shi.
\v 18 Adama a na vuma na ri na̱ mɓa̱la̱ suru wu ntsaa u rawa zuzu shi: irumba̱ ko a̱a̱kutsuma̱, ko za na utsuvu ko vunu ko urewesu wa̱ yi u ri dere shi ko za na ri danguɗu danguɗu,
\v 19 ko vuma na ri nu ukuɗu a anana ko o ukere,
\v 20 ko vuma na ri no oboto o ucina̱ ko mokoɗi ma vuma ko vuma na ri na̱ da'un a̱ lyusu ko za na ri na̱ mɓa̱la̱ mi ikavuru ko za na ri na ajakata ko za na o foɗoi arawa.
\v 21 She za diga o ugundo wa Haruna ganu na ri na̱ mɓa̱la̱ u ta̱wa̱ zuzu na waa ca A̱sulazuva kucci va akina wan, adama a na u ri usa̱du. She u rawa zuzu na waa ca kucci vi ilyalya ya̱ A̱sula̱ a̱ yi wan.
\v 22 U ta gura tama opopofu a̱ A̱sula̱ a̱ yi, a na a la'ai akiza ni ilyalya ya akiza waru.
\v 23 Agba she u rawa zuzu nu umuna ko masa'a wan, adama a na u ri usa̱du, adama u lungusa̱ uba̱ta̱ wa akiza a̱ va̱ wan. Adama a na a̱mu ɗa A̱sulazuva a na a̱ ka̱mba̱to niyi za va akiza.>>
\v 24 Ne ɗaɗa gba Musa yuwain adanshi na̱ Haruna no olobo a̱ yi, na ama a Isra'ila suru.
\c 22
\p 
\v 1 Reve A̱sulazuva a yuwan adanshi na̱ Musa,
\v 2 <<Vu damma Haruna no olobo a̱ yi a̱ guza̱ ili ya akiza ya ama a Isra'ila i na a ca numu ulobonu tsa̱ra̱ a̱ lungusa̱ ala a̱ va̱ wan. A̱mu ɗa A̱sulazuva.
\v 3 Vu damma le, <Nna̱ za ta̱ a̱tsuma̱ a̱ muwun mu ugundo n ɗu diga gogo hali a̱ tyo mantsa me elime u rawa zuzu ni ili ya akiza i na ama a Isra'ila a cayi A̱sulazuva a̱yi na̱ nshinda̱, a ta tawa vuma ndolo a̱ ma̱ka̱ka̱n ma̱ va̱. A̱mu ɗa A̱sulazuva.
\v 4 Nna̱ a̱tsuma̱ o ugundo wa Haruna vuma ro ri na̱ mɓa̱la̱ mu ukwan u lipu ko u ri a̱ ma̱ɗa̱wa̱ waa lyuwa ili ya akiza shi, she na̱ wo o'wo cece. Ne ɗa fo nu u ju'wa̱n ili suru i na i ri idaba ya̱ a̱a̱kwa̱kwa̱ ko vuma na tsali tso ocoi u to o'wo idaba.
\v 5 Waru ne ɗa, za na ju'wa̱in ili i na i ri e ika̱ta̱pu suru i na yaa zuwa yi wo o'wo ili yi idaba. Ko vuma na zuwa niyi wo o'woi idaba, a̱yi fo u to o'wo ili yi idaba.
\v 6 Za na ju'wa̱in cu'un vi ili i ndolo suru u to o'wo idaba hali ulivu, waru waa lyuwa ilyalya ya akiza shi she nu u sumba̱.
\v 7 Nu urana u riya̱ ɗaɗa woo o'wo cece, diga lo u ta gura lyuwa ilyalya ya akiza, adama a na ilyalya ya̱ yi i ɗa.
\v 8 Waa tama ili i na i kuwa̱yi aciya̱yi shi, ko ili i na inama yu una yi karai shi. Ele nda a ta zuwa yi wo o'wo idaba. A̱mu ɗa A̱sulazuva.>
\p 
\v 9 <<A yuwan tsutoni ni ili i na n damma nle adama o ronoo aciyele unusu ta̱wa̱ a̱ kuwa̱ o una̱ u na a 'yuwain a yuwan tsutoni wan. A̱mu ɗa A̱sulazuva za na o'woto nle na akiza.
\p 
\v 10 <<Vuma na ri a̱tsuma̱ o ugundo wa ganu shi, waa lyuwa ilyalya ya akiza shi. Waru mocin va ganu ko za zamalinga waa lyuwa ilyalya ya akiza shi.
\v 11 Amma nna̱ ganu tsula ta̱ aagbashi ni ikebe, aagbashi'i u ta gura lyuwa ilyalya'a. Waru za na a matsain a̱tsuma̱ o u'wa wa̱ yi u ta gura lyuwa ilyalya'a.
\v 12 Nnu usheli wa ganu wo olo vuma na ri ganu shi, waa lyuwa a̱tsuma̱ e ili ya akiza i na a̱ tafai shi.
\v 13 Amma nnu usheli wa ganu za na o'woi ma̱runa̱ ko wu uta̱i lolo waru u ri na̱ mawun shi, reve u ka̱mba̱ o u'wa wa dada va̱ yi, a̱yi ubuwu yawa, u ta gura lyuwa ilyalya ya dada va̱ yi. Vuma na ri ganu shi, ko cine a yuwain waa lyuwa ilyalya'a shi.
\v 14 Waru na̱ za lyuwa ilyalya ya akiza a̱tsuma̱ o unusu, u ta̱ ka̱mbuwa̱a̱ ganu ili i na u lyuwai'i reve u da̱shi za ta̱ a̱tsuma̱ o ozo o ton wa̱ a̱bunda̱ e ili'i.
\v 15 She nan ganu aa tara ilyalya ya akiza i na ama a Isra'ila a̱ ta̱wa̱yi A̱sulazuva ili yi idaba wan.
\v 16 Na a lyawa vuma na ntsayi shi u lyuwa ilyalya ya akiza u ta̱ ta̱wa̱a̱ le nu unusu u na woo ronoo le uge'etosu, adama a na a̱mu ɗa A̱sulazuva za na ka̱mba̱to nle na akiza.>>
\s1 Kucci na a̱a̱ ushi shi
\p 
\v 17 Reve A̱sulazuva a yuwan adanshi na̱ Musa,
\v 18 <<Vu yuwan adanshi na̱ Haruna no olobo a̱ yi na ama a Isra'ila suru, vu damma le, na̱ za suru a̱tsuma̱ o u'wa wa ama a Isra'ila ko mocin na ri nden a̱tsuma̱ a ama a Isra'ila ta̱wa̱a̱ na̱ kucci vu ukula̱tosu e ekere a̱ A̱sulazuva, ko o shiton akucunu ko kucci vu ucigu wo okolo,
\v 19 nnu u ciga a̱ ushi kucci va̱ yi, u ta̱wa̱a̱ na̱ no oogono a nan ko kyon ko megbele ma na ma̱ ri usa̱du shi.
\v 20 She i ca kucci na ri na̱ usa̱du wan, adama a na a̱a̱ ushiya̱ ɗu a̱yi shi.
\v 21 Na̱ vuma ta̱wa̱a̱ A̱sulazuva kucci muwwulai adama u shiton nzuwulai ko kucci vu ucigu wo okolo diga o oɓolo e inan ko oɓolo e ikyon ko o oɓolo e mgbele, na a 'yuwan a ciga u ca nama na ri gbaga, za na ri usa̱du shi.
\v 22 She a ca A̱sulazuva kucci vu nama na ri ne esu shi wan, ko za na ri ukuɗu wan, ko za vu usa̱du wan, ko za na ri na̱ wuntsu a̱ lipu wan ko za na ri nu ukparu wan. She a yuwan kucci vu ukula̱tosu na̱ cu'un vi iliyamunga i ndolo a masa'a wan.
\v 23 A ta gura ca oogono a nan ko kyon aza a na pasu lipu le a̱ ri usa̱du kucci vu ucigu wo okolo. Agba aa ca le adama a̱ kucci vu ushitosun wa akucunu shi.
\v 24 Yaa ca A̱sulazuva nama na a̱ kula̱i ko o ɓosoi, ko a ɓatsai, ko o foɗoi arawa shi. Yaa yuwan ne e iɗa i ɗu shi.
\v 25 Ne ɗa gba waru ya̱a̱ ushi icu'un yi iliyamunga i ndolo e ekere o mocin, reve i ca A̱sula̱ a̱ ɗu kucci vi ilyalya shi. A̱a̱ ushiya̱ ɗu ele shi adama a na a ntsaa a yuwan kucci ne ele shi, adama a na a̱ ri usa̱du waru a̱ ta̱ na̱ mɓa̱la̱ a̱ lipu le.>>
\p 
\v 26 Reve A̱sulazuva a damma Musa a na,
\v 27 <<Nna a matsan moggono ma nan ko mo kyon ko me megbele, u ta̱ da̱na̱ oɓolo na̱ mma va̱ yi hali rana cindere, o urana wa̱ kunla̱ a̱ tyo elime a̱ ta̱ ushi yi kucci na aa yuwaan A̱sulazuva va akina.
\v 28 Agba yaa paɗa nan ko kyon urana u ta̱ na̱ mawun ma̱ yi shi.
\v 29 Waru na̱ yaa casu kucci vu ugodyusho e ekere a̱ A̱sulazuva, i ca yi cine a̱ ushiya̱ ɗu.
\v 30 A ta tama yi a̱ a̱tsuma̱ o urana u ta̱, yaa lyawa ili i pasa a̱ tyo usana u ro shi. A̱mu ɗa A̱sulazuva.
\p 
\v 31 <<Adama o ndolo i guza̱ ili i na n damma nɗu waru i yuwan le. A̱mu ɗa A̱sulazuva.
\v 32 Waru she i ka̱mba̱to ala a akiza a̱ va̱ ili ye pere wan, agba a̱ɗu ama a Isra'ila i zuwa ala a̱ va̱ a̱ da̱na̱ na akiza. A̱mu ɗa A̱sulazuva za na ka̱mba̱to nɗu aza a akiza.
\v 33 A̱mu ɗa mu uta̱a̱ nɗu diga a̱tsuma̱ e iɗa ya Masar adama mo o'wo A̱sula̱ a̱ ɗu. A̱mu ɗa A̱sulazuva.>>
\c 23
\p 
\v 1 Reve A̱sulazuva a yuwan adanshi na̱ Musa,
\v 2 <<Vu yuwan adanshi na ama a Isra'ila, vu damma le: Ele nda ele ɗa a̱buki a na n zuwai, a̱buki a na A̱sulazuva a zuwai a na a cuɗuwa a mantsa me iɓolo ya akiza ya aza a Isra'ila.
\s1 Urana wa Ashibi
\p 
\v 3 <<A ta yuwan ulinga a̱tsuma̱ a rana ta̱li, agba urana wa̱ cindere, urana u wivuwun la̱nga̱ ɗa. Urana u ɗa a na aa yuwan iɓolo ya akiza. Uba̱ta̱ u na i ri suru yaa yuwan ulinga a̱tsuma̱ o urana u ndolo shi ko ke'en, adama a na urana wa Ashibi u ɗa e ekere a̱ A̱sulazuva.
\s1 A̱buki a mapasa
\r (Mkc 28:16-25)
\p 
\v 4 <<Ele nda ele ɗa a̱buki a na A̱sulazuva a zuwai iɓolo ya akiza. A ta saala ama a Isra'ila ele a mantsa ma na a zuwa nle:
\v 5 O urana wa kupa na̱ a̱za̱ a̱ na̱shi a̱tsuma̱ o woto wu ufaru nu ulivu ɗaɗa ee teme mayan ma̱ A̱buki a Mapasa ma̱ A̱sulazuva.
\v 6 Reve o urana u kupa no ozo ton o woto'o i yuwaan A̱sulazuva a̱buki o Opopofu a na a̱ ri na̱ Wolilo shi. I ta yuwan rana cindere a tamusa Opopofu a na a̱ ri na̱ Wolilo'o shi.
\v 7 O urana wu ufaru wa̱ a̱buki'i i ta yuwan iɓolo ya̱ a̱ga̱nda̱ ya akiza. Yaa yuwan linga va ana'an na̱ nfa'an shi.
\v 8 Agba i ca A̱sulazuva kucci vu ukula̱tosu hali rana cindere. O urana wa̱ cindere u ɗa yaa yuwan iɓolo ya akiza. A̱tsuma̱ o urana u nda yaa yuwan linga ɗu va ana'an na̱ nfa'an shi.>>
\s1 Ucasu wu matsun vu ufaru va̱ a̱ɗuma̱
\p 
\v 9 Reve A̱sulazuva a yuwan adanshi na̱ Musa,
\v 10 <<Vu yuwan adanshi na ama a Isra'ila vu damma le: Nni i ta̱wa̱ a̱tsuma̱ e iɗa i na maa ca ɗu, waru ni i yuwan ugasa, i tara aakatalu a̱tsuma̱ e itana yu una i na i fara inai i 'ya̱wa̱a̱ ganu.
\v 11 Ganu'u u ta ca A̱sulazuva aakatalu'u kucci vu u'ya̱susa̱n o una̱ u ɗu tsa̱ra̱ a̱ usu ɗu. Ganu'u u ta̱ 'ya̱sa̱n yi nu usana u tawa o urana u na u kuruyi urana wa Ashibi.
\v 12 Waru o urana u na a cayi kucci vu u'ya̱susa̱'a̱n i ta ca ma̱giri'i ma na ma̱ ri na aa'wan a̱ ta̱, za na ri usa̱du shi adama a ca A̱sulazuva kucci vu ukula̱tosu.
\v 13 Oɓolo na̱ ma̱giri'i'i, i ta ca kucci vi ishina makundatsu ure u efa u yira i lashi a̱tsuma̱ a kupa i na a̱ ja̱mba̱ra̱i na̱ mani'in ma̱ zetun, a ca A̱sulazuva kucci vi ilyalya i ma̱guru, agba kucci vi ili yo oso u da̱na̱ magasutsu ma̱ ta̱ ma masayan ma̱ ina̱bi.
\v 14 Waru yaa tama opopofu ko ishina i na a̱ zuyin ko ishina i sa'avu shi. She urana u na i ta̱wa̱yi A̱sula̱ a̱ ɗu na̱ kucci nda. A̱yi nda wila̱ u ɗa u na ya̱a̱ guza̱ hali a̱ tyo a̱ muwun mu gundo ɗu uba̱ta̱ u na i da̱nuyi biti.
\s1 A̱buki o ugasa
\r (Mkc 28:26-31)
\p 
\v 15 <<I kece ajuma e cindere cip cip cip diga o urana u na u kuruyi Ashibi, urana u na i ta̱wa̱i na aakatalu a̱ kucci vu u'ya̱susa̱n.
\v 16 I kece rana kupoton a̱ca̱pa̱ a Ashibi a ajuma e cindere'e, reve i ca A̱sulazuva kucci vi ishina i sa'avu.
\v 17 Uba̱ta̱ u na i ri nden suru i ta̱wa̱a̱ no opopofu e re a na aa ca A̱sulazuva kucci vu u'ya̱susa̱n. A yuwan opopofu suru na̱ makundatsu ure u efa ma yira i lashi a̱tsuma̱ a kupa na̱ wolilo, reve a ca A̱sulazuva kucci vu umatsun wu ufaru.
\v 18 I ta ca mugiri'i n cindere oɓolo no opopofu'u, aza a na a̱ ri na aa'wan a̱ ta̱ ta̱ waru a̱ ri usa̱du shi oɓolo na̱ moggono ma nan na̱ a̱giri'i e re. A ta ca A̱sulazuva ele kucci vu ukula̱tosu oɓolo na̱ kucci vi ishina na̱ kucci vi ili yo oso, kucci na a yuwain na akina ili i ma̱guru mo uyo'o e ekere a̱ A̱sulazuva.
\v 19 Waru i ta ca ma̱ga̱ji adama a̱ kucci vu unusu na̱ mugiri'i n re aza a na a̱ ri na aa'wan a̱ ta̱ ta̱ kucci muwwulai.
\v 20 Ganu ta̱ 'ya̱sa̱n mugiri'i n re'e a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva kucci vu u'ya̱susa̱n oɓolo no opopofu o umatsun wu ufaru. O to o'wo ili ya akiza e ekere a̱ A̱sulazuva, reve o o'wo aza a ganu.
\v 21 O urana u ndolo a ta saala iɓolo ya akiza i ɗa. Yaa yuwan linga ɗu va na'an na̱ nfa'an shi. A̱yi nda u to o'wo ɗu wila̱ uba̱ta̱ u na i da̱nuyi suru hali a̱ tyo a̱ muwun mu gundo n ɗu.
\p 
\v 22 <<Waru mantsa ma na i ri o ugasa, she i yuwan ugasa hali a̱ tyo a̱ nge'en ma̱ a̱ɗuma̱'a̱ wan. Waru yaa yuwan u'yanlu shi. I lyawa u'yanlu adama a alambi no omocin. A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.>>
\s1 A̱buki a̱ wivulu wa avana
\r (Mkc 29:1-6)
\p 
\v 23 Reve A̱sulazuva a yuwan adanshi na̱ Musa,
\v 24 <<Vu damma ama a Isra'ila: O urana wu ufaru u woto we cindere, i yuwan wivuwun wu urana la̱nga̱ adama a na urana u ɗa wu ucuwusan na̱ wivulu wa avana iɓolo ya akiza.
\v 25 Yaa yuwan ulinga u ɗu wa ana'an na̱ nfa'an shi, agba i ca A̱sulazuva kucci na a yuwain na akina.>>
\s1 Urana u matara mo ume mo unusu
\r (Mkc 29:7-11)
\p 
\v 26 Reve A̱sulazuva a yuwan adanshi na̱ Musa,
\v 27 <<Urana wa kupa u woto we cindere, Urana u Matara mo ume mo Unusu ma ɗa. U to o o'wo ɗu urana wi iɓolo wa akiza. She i lyuwa ilyalya o urana'a wan, reve i ca A̱sulazuva kucci na a yuwain na akina.
\v 28 Waru yaa yuwan ulinga a̱tsuma̱ o urana u ndolo shi, adama a na Urana u ɗa u Matara mo ume mo Unusu, na aa ca kucci adama a matara mo ume mo unusu u ɗu a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva A̱sula̱ a̱ ɗu.
\v 29 Za na suru lyuwai ilyalya o urana u ndolo a ta tawa yi a̱tsuma̱ a ama a̱ yi.
\v 30 Waru za na suru yuwain ulinga o urana u ndolo, n to kototo vuma ndolo a̱tsuma̱ a ama a̱ yi.
\v 31 Yaa yuwan ulinga shi suru suru. Wila̱ u ɗa u na ya̱a̱ guza̱ hali a̱ tyo a̱ muwun mu gundo n ɗu uba̱ta̱ u na i da̱nu yi suru.
\v 32 U to o o'wo ɗu Urana wa Ashibi u na yee ivuwan waru yaa lyuwa ilyalya shi. Diga o ulivu wu urana wa̱ kucci u woto'o hali a̱ tyo o ulivu wu urana wa kupa i cuwan a na Ashibi a ɗa.>>
\s1 A̱a̱buki o Ogodo
\r (Mkc 29:12-40)
\p 
\v 33 Reve A̱sulazuva a yuwan adanshi na̱ Musa,
\v 34 <<Vu yuwan adanshi na ama a Isra'ila vu damma, o urana u kupa no ozo o ton u woto we cindere u nda u ɗa A̱buki o Ogodo o Ucuwusan a̱ A̱sulazuva ee teme. Waru u ta tara rana cindere
\v 35 Urana wu ufaru u to o o'wo iɓolo ya akiza. She i yuwan ulinga wa ana'an na̱ nfa'an wan.
\v 36 I ta ca A̱sulazuva kucci na a yuwain na akina rana cindere. Reve o urana wa̱ kunla̱ i yuwan a̱buki a akiza waru i ca A̱sulazuva kucci na a yuwain na akina. A̱yi nda u to o o'wo ɗu iɓolo ya akiza, she i yuwan ulinga wa ana'an na̱ nfa'an wan.
\p 
\v 37 <<Ele nda ele ɗa a̱buki a̱ A̱sulazuva aza a na a zuwaa nɗu ana ya̱a̱ da̱na̱ a yuwusan, aza a na ya̱a̱ da̱na̱ a yuwusan mantsa me iɓolo ya akiza na ya̱a̱ da̱na̱ a casu A̱sulazuva kucci va akina, kucci vu ukula̱tosu, na̱ kucci vi ishina na̱ nan kucci waru i ta ca kucci vo oso vu urana suru.
\v 38 A̱buki a nda a̱ ta̱ a̱tsuma̱ o uda̱shiyi wa̱ a̱buki o urana wa Ashibi na̱ a̱buki a̱ ne'e na̱ a̱buki a̱ kucci va akucunu na̱ a̱buki a̱ kucci vu ucigu wo okolo na yaa ca A̱sulazuva.
\p 
\v 39 <<Adama o ndolo urana wa kupa no ozo o ton u woto we cindere, a mantsa ma na i ɓolotoi itana ya̱ a̱ɗuma̱ a̱ ɗu, reve i yuwan a̱buki o urana we cindere wa̱ A̱sulazuva. Urana wu ufaru urana u wivuwun u ɗa, waru urana wa̱ kunla̱ fo urana u wivuwun u ɗa.
\v 40 O urana wu ufaru u ɗa yaa lyuwa umatsun vu ɗanga sa'ani, reve i gasa ashiwashiwa oɓolo ne eten a ɗanga na ri na̱ a̱vu'un lon, reve i yuwan ma̱za̱nga̱ a̱ ma̱ka̱ka̱n ma A̱sulazuva A̱sula̱ a̱ ɗu hali rana cindere.
\v 41 I ta yuwaan A̱sulazuva a̱buki a nda hali rana cindere a̱tsuma̱ a aa'wan suru. Wila̱ u ɗa u na ya̱a̱ guza̱ hali a̱ tyo a̱ muwun mu gundo ɗu. O woto wa̱ cindere u ɗa yaa yuwan a̱buki'i.
\v 42 I da̱nu a̱tsuma̱ o ogodo a̱ ɗu hali rana cindere. Ne ɗa fo umatsun wa Isra'ila suru a̱a̱ da̱nu o ogodo e le.
\v 43 Ne ɗa muwun mu ugundo n ɗu mee reve a na a̱mu ɗa n zuwai ama a Isra'ila a̱ da̱nu a̱tsuma̱ o ogodo e le a mantsa ma na mu uta̱a̱ nle a̱tsuma̱ e iɗa ya Masar. A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.>>
\p 
\v 44 Ne ɗa Musa cuɗuwai ama a Isra'ila a̱buki a nda a na A̱sulazuva a zuwayi ama a Isra'ila.
\c 24
\s1 Mani'in no opopofu a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva
\p 
\v 1 Reve A̱sulazuva a yuwan adanshi na̱ Musa,
\v 2 <<Vu zuwa ama a Isra'ila a̱ ta̱wa̱a̱ wu na̱ mani'in ma̱ Zetun can adama a fitila tsa̱ra̱ a zuwa fitila'a u da̱na̱ a madala.
\v 3 Haruna ta zuwa fitila'a elime o umuna u gbain u na u palai Oogodo o Uga'asusan. U ta̱ da̱na̱ a lapulusa ifitila'a diga ulivu a̱ tyo usana a̱ 'ya̱wa̱. Wila̱ u ɗa u na woo koto shi diga gogo hali a̱ tyo a̱ muwun mu ugundo n ɗu.
\v 4 A̱yi ɗa wa̱a̱ da̱na̱ a̱ ka̱lyuwusa̱ ifitila'a a wisawatan u zinariya can a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva kuci.
\p 
\v 5 <<I kene yira i lashi reve i yuwaan opopofu kupa ne ejere na̱ a̱yi. Opopofu suru u lyuwa yira i na i ri ume u makundatsu u re u efa u yira i lashi a̱tsuma̱ a kupa.
\v 6 Reve vu gere le udaru u re, o udaru suru vu zuwa a̱kutsu a̱ ta̱li zuva va apada a zinariya can na ri a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva.
\v 7 Reve vu tsun ili i ma̱guru o udaru suru adama wo o'wo kucci vu ucuwusan o una̱ wo opopofu'u, waru wo o'wo kucci na a cayi A̱sulazuva va akina.
\v 8 O urana wa Ashibi suru Haruna gere le a̱ ma̱ka̱ka̱n ma̱ A̱sulazuva o una̱ wa aza a Isra'ila, akucunu a aza a Isra'ila a na a̱ ri n koto shi.
\v 9 Opopofu'u o to o'wo aza a Haruna no olobo a̱ yi, waru a ta tama le pe uba̱ta̱ wa akiza adama a na akunda e le ɗa a na a la'ai akiza a̱tsuma̱ a̱ kucci va akina a na a cayi A̱sulazuva.>>
\s1 A vara ta̱ za na yuwain unusu u gbain
\p 
\v 10 Urana u ro a̱vu ulobo wu ka va Isra'ila za na dada va̱ yi za vi iɗa va Masar ɗa, u ka̱ra̱ o uta̱ oɓolo na ama a Isra'ila. Reve ulobo'o na̱ vuma va Isra'ila'a a yuwan nla̱ngi o uva̱la̱ta̱ wa ama a Isra'ila.
\v 11 A̱vu ulobo wu ka va Isra'ila'a u yuwan unusu u gbain na Ala a̱ A̱sulazuva. Reve a̱ ta̱wa̱to yi uba̱ta̱ wa Musa. (Aala a mma va̱ yi a ɗa Shelomi usheli wa Dibiri o ugundo wa Dan.)
\v 12 Reve a̱ ɓa̱ru yi uba̱ta̱ u ro, hali she ne ee reve ili i na A̱sulazuva aa damma a alanga eteshe.
\v 13 Reve A̱sulazuva a yuwan adanshi na̱ Musa u damma:
\v 14 <<Vu uta̱a̱ na̱ vuma na yuwain unusu u gbai'in diga o uva̱la̱ta̱ u ɗu. Reve vu zuwa ama suru a na a uwwai ili i na u dammai a̱ kuruwa̱ yi ekere a aaci. Reve a zuwa ama'a suru a vara yi na atali.
\v 15 Reve vu damma ama a Isra'ila a na: Vuma na suru yuwain adanshi isulai A̱sula̱ a̱ yi, u ta tara ume wu unusu wa̱ yi.
\v 16 Vuma na yuwain unusu u gbain na ala A̱sulazuva suru amayun a̱ to una yi. Oɓolo a ama a ta vuvara yi na atali ko na̱ mocin ɗa ko umatsun wi iɗa nu u yuwaan Ala'a unusu u gbain na amayun a̱ to una yi.
\p 
\v 17 <<Waru za na unai vuma suru, na amayun a̱yi fo a̱ to una yi.
\v 18 Za na waru suru unai iliyamunga yi za ro, u ta̱ ka̱mbuwa̱ iliyamunga, wuma o una̱ u wuma.
\v 19 Vuma na waru amaton yi moron ma̱ nden ma̱ yi suru, cine u yuwaan niyi ne ɗa fo a yuwaan yi.
\v 20 Nu u kuɗa yi ta̱ eetele, a̱yi fo a ta kuɗa yi eetele. Nnu u foɗo yi lyusu, a̱yi fo o to foɗo yi lyusu. Nnu u mula̱ yi anga, a̱yi fo a̱ ta̱ mula̱ yi anga. Cine wa amaton niyi, ne ɗa fo aa amaton yi.
\v 21 Za na unai iliyamunga suru, u ta̱ ka̱mbuwa̱ za ro. Waru za na unai vuma suru, a̱yi fo a̱ to una yi.
\v 22 Wila̱ꞌa̱ u te reme mocin nu umatsun wi iɗa'a, a̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.>>
\p 
\v 23 Reve Musa yuwan adanshi na ama a Isra'ila. A̱vu o uta̱a̱ vuma na yuwain adanshi o unusu u gbain o uva̱la̱ta̱'a̱, reve a vara yi na atali. Ama a Isra'ila a yuwan ta̱ cine A̱sulazuva a dammai Musa.
\c 25
\s1 Aa'wan a̱ wivuwun
\p 
\v 1 Reve A̱sulazuva a yuwan adanshi na̱ Musa a Masasan ma Sinai, u damma,
\v 2 <<Vu yuwan adanshi na ama a Isra'ila, vu damma le, nni i uwa a̱tsuma̱ e iɗa i na maa ca ɗu, iɗa'a na aciya̱yi u toni wila̱ u wivuwun wa̱ A̱sulazuva.
\v 3 I cu'wa̱n a̱ɗuma̱ a̱ ɗu a'wan a̱ ta̱li, waru i lapula a̱ɗuma̱ a̱ ina̱bi a̱ ɗu a'wan a̱ ta̱li'i, reve i ɓoloto matsun le.
\v 4 Agba aa'wan e cindere u to o'wo aa'wan a̱ wivuwun e iɗa'a, wivuwun wa̱ A̱sulazuva. Ya̱a̱ cu'wa̱n a̱ɗuma̱ ɗu shi waru yaa lapula ɗanga ina̱bi ɗu shi.
\v 5 Waru yaa gasa a̱ta̱pa̱shi shi, waru yaa ta'an umatsun wa̱ a̱ɗuma̱ a̱ ina̱bi a̱ ɗu a na i lapulai shi. Aa'wan o ndolo u to o'wo aa'wan a̱ wivuwun wi iɗa.
\v 6 Ili i na iɗa'a yaa matsan a aa'wan a̱ wivuwun u to o'wo ɗu ilyalya, a̱ɗu na agbashi a̱ ɗu a̱ma̱ci na ali, hali fo na aza a zamalinga a̱ ɗu no omocin a na a̱ ri nden oɓolo na̱ a̱ɗu,
\v 7 hali fo ni inan i ɗu hali na̱ inama yu una i na i ri a̱tsuma̱ e iɗa i ɗu. Ili i na i kungwai e iɗa'a suru o to o'wo ilyalya.
\s1 Aa'wan a̱ a̱buki o uka̱mbusa̱ fa̱a̱n
\p 
\v 8 <<I kece a'wan e cindere a̱ wivuwun, a'wan e cindere udoɓonu toto ucindere'e, u to o'wo a'wan a̱ wivuwun amunga na̱ kucci.
\v 9 Reve o urana wa kupa u woto we cindere yi ivula̱ aavana. O urana u kucci matara mo ume mo unusu yi ivula̱ aavana a̱tsuma̱ e iɗa i ɗu ma̱ɓula̱.
\v 10 Reve i tawa aa'wan a kupoton na akiza, reve a lapa ulingi u na woo roco a na ama o o'woi fa̱a̱n a̱tsuma̱ e iɗa i ɗu nu uba̱ta̱ a̱ nden n ɗu suru. U to o'wo ɗu aa'wan a na ama o o'wo fa̱a̱n. Vuma suru ta̱ ka̱mba̱ e itana ya agadu yu umatsun wa̱ yi. Waru vuma suru ta̱ ka̱mba̱ a̱tsuma̱ o umatsun wa̱ yi.
\v 11 Aa'wan a kupoto'on u to o'wo ɗu aa'wan a̱ a̱buki o uka̱mbusa̱ fa̱a̱n. A̱tsuma̱ a aa'wan o ndolo, ya̱a̱ cu'wa̱n shi waru yaa gasa a̱ta̱pa̱shi shi waru yoo ɓoloto umatsun wa̱ ina̱bi u na a̱ kuɗa̱i a lapula shi.
\v 12 Adama a na aa'wan a̱ a̱buki o uka̱mbusa̱ fa̱a̱n ɗa waru i tara yi na akiza. A̱ta̱pa̱shi a ɗa goon yaa lyuwa.
\p 
\v 13 <<A̱tsuma̱ a Aa'wan a̱ A̱buki a nda, za suru a̱tsuma̱ a̱ ɗu u ka̱mba̱ uba̱ta̱ e itana ya̱ yi.
\v 14 Waru na̱ vu winaa za va̱ wu iɗa yi cimba, ko vu tsula e ekere a̱ yi, she i paalulai wan.
\v 15 Na̱ vaa tsula iɗa e ekere a za va̱ wu, vu ta tsupa o una̱ wa̱ a̱bunda̱ a a'wan a na a̱ ri a̱ca̱pa̱ kafu a̱buki'i, waru u ta winaa wu o una̱ wa̱ a̱bunda̱ a a'wan a na a buwai a̱ tyo o ugasa.
\v 16 Nna̱ a'wan a buwa a̱bunda̱, vu da̱shi a̱bunda̱ e ikebeꞌe. Agba nna̱ a'wan a buwa a̱bunda̱ shi, vu jebe ikebeꞌe. Adama a na ili i na waa winasa wu o una̱ wa̱ a̱bunda̱ e itana yu uɗuma̱ i ɗa.
\v 17 She i paalulai wan, amma yu uwwa wovon wa A̱sula̱ a̱ ɗu, adama a na a̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.
\p 
\v 18 <<Adama o ndolo i yuwan ili i na n damma nɗu waru i kuru wila̱ u na n zuwaa nɗu adama i yuwan nden n lafiya a̱tsuma̱ e iɗa'a.
\v 19 Iɗa'a i ta matsan ulobonu, i ta lyuwa i cuwa̱n, waru i ta̱ da̱nu gbaga.
\v 20 Agba nni i damma, <Nye tsaa lyuwa a̱tsuma̱ a aa'wan e cindere'e na̱ tsu cu'wa̱n shi waru tsaa gasa itana yu uɗuma̱ shi?>
\v 21 I reve gba, n ta zuwaa ɗu aba'un a̱ va̱ a̱tsuma̱ a aa'wan a̱ ta̱li, adama iɗa'a i matsan ulobonu i na yaa lyuwa hali a'wan a ta'atsu.
\v 22 Nni i yuwan ca̱'a̱n a aa'wan a̱ kunla̱, i ta̱ da̱na̱ a lyuwusa akuci e itana yu uɗuma̱, waru i ta lyuwa le hali a aa'wan a̱ kuci, a mantsa ma na ilyalya ya̱ yi i kutsai.
\p 
\v 23 <<Yaa wina iɗa'a suru suru shi, adama a na iɗa'a za va̱ ɗa. Waru a̱ɗu omocin a ɗa tsa̱ a̱za̱ a̱ nden ma atsupu.
\v 24 Waru iɗa i na yo o'woi za ɗu suru, nna̱ yaa wina yi, i ca ure u na aa gura tsupisa yi.
\p 
\v 25 <<Nnu ulambu u reme za ta̱ a̱tsuma̱ a̱ ɗu, hali u kene pe a̱tsuma̱ e iɗa ya̱ yi u wina, vuma ta̱ a̱tsuma̱ e imaci i zuzu ya̱ yi u ka̱mba̱ u tsupisa iɗa'a.
\v 26 Nna̱ gba za na winai uba̱ta̱'a̱ u ri ni imaci i na yaa gura tsupisa uba̱ta̱'a̱ shi, agba a̱ tyo ɗe elime a̱vu u tsura̱ ikebe i na waa gura tsupisa uba̱ta̱'a̱,
\v 27 to, u kece a̱bunda̱ a a'wan a na u yuwain a na u winai uba̱ta̱'a̱. Reve u ka̱mbuwa̱ ili i na i buwai e ekere a vuma na u winayi, ne ɗa uɗuma̱'a̱ wa̱a̱ ka̱mbisa̱ za va̱ yi.
\v 28 Agba nnu u ri ni ikebe i na waa gura tsupisa uba̱ta̱'a̱ shi, to, uba̱ta̱ u na a winai u ta̱ da̱na̱ e ekere a vuma na tsulai uba̱ta̱'a̱, hali a̱ tyo a Aa'wan a̱ A̱buki o uka̱mbusa̱ fa̱a̱n. A Aa'wan a̱ A̱buki'i a̱ ta̱ ka̱mbuwa̱a̱ yi, reve u ka̱mbisa̱ a̱ nden ma̱ yi.
\p 
\v 29 <<Nna̱ vuma wina u'wa wu nden a̱tsuma̱ a̱ lyuci na ri nu ukari, u ta gura tsupisa u'wa'a a̱tsuma̱ a aa'wan a̱ ta̱. Aa'wan a̱ ta̱ ma̱ɓula̱ u ta̱ nu ucira u na waa gura tsupisa yi.
\v 30 Agba nnu u gura tsupisa u'wa'a a̱tsuma̱ a aa'wan a̱ ta̱ o ndolo shi, to, u'wa'a wo o'wo ta̱ u'wa u vuma na tsula niyi, hali a̱ tyo a̱ muwun n tsukaya ma̱ yi. A̱a̱ ka̱mbuwa̱a̱ za vi ili shi a Aa'wan a̱ A̱buki'i.
\v 31 Agba 'wa na ri a̱ mulyuci n na n ri uka̱nda̱ruwu nu ukari shi, a ta tara le tsi iɗa yi cimba, a ta gura tsupisa ikebe o una̱ u le. A ta gura waru ka̱mbuwa̱a̱ aza a 'wa na̱ 'wa le a̱tsuma̱ a Aa'wan a̱ A̱buki'i.
\p 
\v 32 <<Agba aɗa a nan Levi na̱ 'wa le na ri a̱tsuma̱ e ilyuci i le, a̱ ta̱ na aa gura tsupisa ili i le a mantsa suru.
\v 33 Agba na̱ vuma va̱ Levi wina u'wa a̱tsuma̱ e ilyuci ya ama a̱ Levi, agba u gura tsupisa u'wa'a shi, a̱ ta̱ ka̱mbuwa̱a̱ yi nu u'wa wa̱ yi a̱tsuma̱ a Aa'wan a̱ A̱buki'i, adama a na 'wa a̱tsuma̱ e ilyuci i nan Levi ili ya agadu i ɗa le a̱tsuma̱ aza a Isra'ila .
\v 34 Agba aa wina atsusa a alyuna a na a̱ ri uka̱nda̱ruwu na̱ 'wa le shi adama a na ili ya agadu i ɗa le hali hali hali.
\s1 Ucasu wo okopu e ekere a alambi
\p 
\v 35 <<Nnu ulambu u reme za va̱ wu, agba waa gura kamba aciya̱yi shi, vu kamba yi cine vu revei vaa kamba mocin ko za vu mmalu a̱tsuma̱ a̱ ɗu. Adama u lyuwa elime na̱ nden oɓolo na̱ a̱ɗu.
\v 36 Vu ca yi okopu agba vu ushi nu uda̱shiyi wan, amma vu uwwa wovon wa̱ A̱sula̱ a̱ wu. Vu lyawa yi u da̱nu oɓolo na̱ a̱vu.
\v 37 Vu ca yi okopu agba vu ushi nu uda̱shiyi wan, ko vu winaa yi ilyalya nu uda̱shiyi wan.
\v 38 A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu za na uta̱a̱ nɗu a̱tsuma̱ e iɗa ya Masar, adama n ca ɗu iɗa ya Ka'ana, tsa̱ra̱ mo o'wo A̱sula̱ a̱ ɗu.
\p 
\v 39 <<Nna̱ za va̱ wu o'wo alambi hali u rawa a na u winai aciya̱yi uba̱ta̱ wa̱ wu, she vu zuwa yi ulinga tsa aagbashi wan.
\v 40 U ta̱ da̱nu oɓolo na̱ a̱vu tsu za zamalinga ko za vu mmalu, waru u ta yuwaan wu ulinga hali she na Aa'wan a̱ A̱buki'i a rawa.
\v 41 A mantsa mo ndolo ma ɗa a̱yi na̱ muwun ma̱ yi aa lyawa le, reve u ka̱mba̱ o ugundo nu uba̱ta̱ wu nkaya ma̱ yi.
\v 42 Adama a na ama a Isra'ila agbashi a̱ va̱ a ɗa aza a na mu uta̱yi a̱tsuma̱ e iɗa ya Masar. Waru aa wina le tsa agbashi shi.
\v 43 Waru vaa yuwan tsugono a aci e le ni iɓongi shi, amma vu uwwa wovon wa A̱sula̱ a̱ wu.
\p 
\v 44 Agba agbashi e esheli no olobo a na vu cigai vu tsula o o'wo diga a nɗa n na n ri uka̱nda̱ruwu na̱ a̱vu, ele ɗa goon vaa gura tsula.
\v 45 I ta gura tsula agbashi diga o omocin a na a̱ ri a̱ nden na̱ a̱ɗu na̱ muwun mu ugundo n le n na a matsain e iɗa i ɗu. Ele nda o to o'wo itana i ɗu.
\v 46 I ta gura ca muwun n ɗu ele adama wo o'wo le agadu. O to o'wo ɗu agbashi hali hali. Agba a̱za̱ a̱ ɗu ama a Isra'ila, yaa yuwan tsugono a aci e le ni iɓongi shi.
\p 
\v 47 <<Nna̱ mocin na ri nden a̱tsuma̱ a̱ ɗu za vu mmalu o o'wo za vu utsuru, reve za ta̱ a̱tsuma̱ a̱ ɗu wo o'wo alambi hali u wina aciya̱yi e ekere o moci'in, ko e ekere o umatsun wu mocin ro,
\v 48 a ta gura tsupisa vuma va Isra'ila'a cina u wina ɗe aciya̱yi. Vuma ta̱ a̱tsuma̱ a mmaci ma̱ yi u ta gura tsupisa yi.
\v 49 U ta gura o o'wo mawun ma̱ a̱na̱wu ma dada va̱ yi, ko mawun ma mawun ma̱ a̱na̱wu ma dada va̱ yi, ko imaci i lipu va̱ yi i ta gura tsupaa yi. Ko a̱yi a aciya̱yi u ta gura tsupisa aciya̱yi nnu u ri ni ikebe.
\v 50 A̱yi na̱ za na tsula niyi, e te kece a̱bunda̱ e ikebe'e. A̱bunda̱ e ikebe i na aa tsupa adama a lyawa yi fa̱a̱n e te kece le o una̱ wa̱ a̱bunda̱ a a'wan a na a buwai kafu Aa'wan a̱ A̱buki'i a rawa. E te kece o una̱ wi ikebe i na a tsu tsupa za zamalinga.
\v 51 Nna a'wan a na a buwai a̱ ri a̱bunda̱, u ta tsupa ili i na i la'ai a̱bunda̱ a̱tsuma̱ e ikebe i na u ushiyi a mantsa ma na u winai aciya̱yi.
\v 52 Amma nna a'wa'an a buwa wa'a a rawa Aa'wan a̱ A̱buki'i, u te kece reve u tsupaa aciya̱yi cine wu ntsayi.
\v 53 Moci'in u ta tara vuma va Isra'ila'a tsu za zamalinga va aa'wan suru. She i lyawa za na tsula niyi'i u yuwan tsugbain a aci a̱ yi ni iɓongi wan.
\p 
\v 54 Nna̱ gba a gura tsupaa yi a̱tsuma̱ e re nda shi, a̱yi na̱ muwun ma̱ yi a ta lyawa le a̱tsuma̱ a Aa'wan a̱ A̱buki'i.
\v 55 Adama a na ama a Isra'ila agbashi a̱ va̱ ɗa. Ele agbashi a̱ va̱ a ɗa aza a na mu uta̱yi a̱tsuma̱ e iɗa ya Masar. A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.
\c 26
\s1 Aba'un adama o tsutoni
\r (U.Wl 27:12-24; 28:1-14)
\p 
\v 1 <<I yuwaan aciya̱ɗu a̱ma̱li wan ko i shuwa̱ uruma ko ijigo wan waru she i she'en aatali e iɗa i ɗu a na ya̱a̱ ka̱ɗa̱ta̱wa̱ yi wan adama a na a̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu.
\v 2 I tara Ashibi a̱ va̱ na akiza waru i ca a̱a̱'isa̱ a̱ va̱ tsugbain. A̱mu ɗa A̱sulazuva.
\p 
\v 3 <<Nni i kuru ili i na n zuwaa nɗu reve waru i toni wila̱ u va̱ ulobonu,
\v 4 n ta̱ lyunguwa̱a̱ ɗu ni iro'i a̱tsuma̱ a mantsa, iɗa i ta ca limatan va̱ yi waru ɗanga ta ca limatan le.
\v 5 Itana ya̱ a̱ɗuma̱ a̱ ɗu a ta yuwan a̱bunda̱ reve i da̱na̱ o ugasa hali a̱ tyo a mantsa mo uta'an wa̱ inabi, waru i ta̱ da̱na̱ a ta'asan umatsun wa̱ ina̱bi u ɗu hali mantsa ma̱ ca̱'a̱n mo ro ma̱ ka̱nda̱ruwisa̱. I ta lyuwa ilyalya i cuwa̱n waru i yuwan nden n ɗu a̱tsuma̱ a asuvu nden a̱tsuma̱ e iɗa i ɗu.
\p 
\v 6 <<N ta ca ɗu asuvu nden e iɗa'a. I to von i lantsa babu wovon wu za. N to loso inama yu una i na i ri na̱ meleshe a̱tsuma̱ e iɗa'a, waru a̱a̱ da̱shi yuwan uvon a̱tsuma̱ e iɗa i ɗu shi.
\v 7 I ta saɓa n'yuwatan n ɗu. Waru i to una le na̱ matsun me pe'eni.
\v 8 Ama o ton a̱ ɗu, o to loso ama ukpaku (100,) ama ukpaku u ɗu gba o to loso ama ukpakukupa kupa (10,000.) I to una n'yuwatan n ɗu na̱ matsun mepe'eni reve a̱ riya̱ elime a̱ ɗu.
\p 
\v 9 <<N ta̱ ka̱lyuwa̱ ɗu nu urewesu wi isa'ani, waru n ta zuwa ɗu i matsan lon i bala. Waru n to shiton akucunu a na n yuwain na̱ a̱ɗu.
\v 10 I ta̱ da̱na̱ a lyuwusa itana ya̱ a̱ɗuma̱ a̱ ɗu ya aa'wan a na a̱ ka̱ra̱i hali a̱ tyo a mantsa ma na yoo uta̱a̱ le adama i ca aza a sa'avu ure.
\v 11 N ta zuwa uba̱ta̱ wu nden n va̱ a̱tsuma̱ a̱ ɗu, waru mee ene ɗu ili yi idaba shi.
\v 12 N ta̱ da̱na̱ oɓolo na̱ a̱ɗu, moo o'wo A̱sula̱ a̱ ɗu. A̱ɗu waru yo o'wo ama a̱ va̱.
\v 13 A̱mu ɗa A̱sulazuva A̱sula̱ a̱ ɗu za na uta̱a̱ nɗu a̱tsuma̱ e iɗa ya Masar, adama i da̱na̱ agbashi e le wan. Reve mu kuɗa a̱a̱gba̱la̱ a na a tsugba nɗu, reve n zuwa ɗu i yuwan mmalu mejege.
\s1 A̱tsuma̱lima̱ adama o ulambu u tsutoni u wila̱
\r (U.Wl 28:15-68)
\p 
\v 14 <<Agba nni i 'yuwan a uwwa mu, waru i 'yuwan a yuwan ili i na n damma nɗu suru,
\v 15 waru nni i kuɗa wila̱ u va̱, hali i tara le ili yi idaba, reve i kuɗa̱ o toni ili i na n dammai, reve waru i kuɗa akucunu a̱ va̱,
\v 16 to, n ta gba a yuwaan ɗu ili i nda: N ta̱ lyunguwa̱ ɗu upepu u cingi wi iwuya lon, oɓolo na̱ mɓa̱la̱ icu'un icu'un, hali na̱ mɓa̱la̱ n na ma̱a̱ lungusa̱ ɗu esu. Reve i ka̱ra̱ a rumba̱na̱sa̱ a̱vu u zuwa mɓa̱la̱ mo okolo. I ta yuwan ca̱'a̱n ve pere, adama a na n'yuwatan n ɗu n ɗa maa lyuwa le.
\v 17 N ta yuwan tsurala na̱ a̱ɗu adama n'yuwatan n ɗu n lyuwa ɗu nu uvon. Aza a na a 'yuwan nɗu ele ɗa aa yuwan tsugono tsa̱ ɗu, waru i ta̱ ka̱ra̱ e ilaɗi ko na̱ za lo a saɓusa ɗu shi.
\p 
\v 18 <<Agba suru na̱ ne, ni i 'yuwan a zuwaa mu atsuvu, to n ta̱ gba o doɓonuwo ɗu a̱tsuma̱lima̱ a̱ ɗu toto ucindere.
\v 19 N ta kuɗa ucira wu uvaɗu wa aciyogbamu u ɗu. N ta zuwa eleshe a na a̱ ri zuva ɗu o o'wo tsu rumu, iɗa i na i ri za̱la̱ ɗu waru tsu rumushili.\f + \fr 26:19 \ft Tsu rumu na̱ rumushili ta yuwusan adanshi o ulambu wi iro'i\f*
\v 20 I to una ucira u ɗu pere adama a na iɗa i ɗu yaa matsan ili shi, waru ɗanga vi iɗa i ɗu aa matsan ili shi.
\p 
\v 21 <<Agba hali n gogo ni i yuwaan mu aciyogbamu, waru ni i 'yuwan a zuwaa mu atsuvu, n ta̱ gba a̱ da̱shi ɗu a̱tsuma̱lima̱ udoɓonuwu toto ucindere adama o unusu u ɗu.
\v 22 N ta̱ waru a̱ lyungu inama yu una a aci a̱ ɗu aza a na oo una muwun n ɗu ni iliyamunga i ɗu. Waru a ta jiba a̱bunda̱ a̱ ɗu hali re ɗu vo o'wo babu ama.
\p 
\v 23 <<Agba suru ni ili i nda, ni i 'yuwan a̱ usu tsuɓari tsa̱ va̱, reve i lyuwa elime a yuwusaan mu aciyogbamu,
\v 24 a̱mu fo, n to ronu na̱ a̱ɗu. A̱mu na aciya̱va̱ a ɗa maa yuwan nla̱ngi na̱ a̱ɗu. A̱vu n ca ɗu a̱tsuma̱lima̱ toto ucindere adama a̱ nusu ɗu.
\v 25 N ta̱ ta̱wa̱a̱ ɗu nu uvon u na waa tsupaa mu adama a na i kuɗai akucunu a̱ va̱. Nni i rono a̱ ka̱mba̱ na̱ a̱ca̱pa̱ a̱ tyo a̱tsuma̱ e ilyuci i ɗu, n ta̱ lyunguwa̱ ɗu na̱ mɓa̱la̱, reve i riya̱ e ekere a n'yuwatan n ɗu.
\v 26 N te geshe ure u ma̱tsura̱ me ilyalya i ɗu hali she na̱ a̱ma̱ci kupa a̱ zun opopofu e eelele a̱ ta̱, reve a ca ɗu uritowu. I ta lyuwa agba ya̱a̱ cuwa̱n shi.
\p 
\v 27 <<Agba suru na̱ ne, nna̱ yu uwwa mu shi, reve i ka̱ra̱ a mmalu n ɗu a̱ 'ya̱susa̱a̱n mu aci,
\v 28 a̱mu gba n ta̱ 'ya̱sa̱a̱n ɗu nu upan lon. Reve a̱mu na aciya̱va̱ n doɓonuwo ɗu a̱tsuma̱lima̱ toto ucindere adama a̱ nusu ɗu.
\v 29 I ta tama inama i muwun n ɗu mo olobo ne esheli.
\v 30 N ta̱ lungusa̱ a̱'isa̱ a̱ a̱ma̱li a̱ ɗu a agaɗi. Waru n ta̱ lungusa̱ musa'a ma̱ a̱tsuka̱ a̱ ma̱guru n ɗu. N ta̱ waru gba a̱ kunguru a̱kwa̱kwa̱ a̱ ɗu zuva va̱ a̱kwa̱kwa̱ va̱ a̱ma̱li a̱ ɗu. I to o'wo ili yi idaba e ekere a̱ va̱.
\v 31 N ta̱ ka̱mba̱to ilyuci i ɗu asa'a. Waru n ta̱ lungusa̱ a̱'isa̱ a̱ ɗu. Ma̱a̱ da̱shi ciga ma̱guru ma̱ kucci ɗu shi.
\v 32 N ta̱ lungusa̱ iɗa i ɗu hali wo o'wo cine n'yuwatan n na n ri na̱ nden pe aa lamba ili i na aa damma.
\v 33 N te bete'we ɗu a̱ tyo a̱tsuma̱ a nɗa n ro, reve n tala matsun me pe'eni ma̱ va̱ n saɓa ɗu. A̱vu n zuwa iɗa i ɗu yo o'wo asa'a waru a̱ lungusa̱ ilyuci i ɗu.
\v 34 Ɗaɗa iɗa i ɗu ya̱a̱ tsura̱ yu uwwa uyo'o wa Aa'wan a̱ wivuwun wa̱ yi a mantsa ma na u ri okongo. Ni i ri e iɗa yi n'yuwatan n ɗu, iɗa'a i ta̱ tsura̱ wivuwun wa̱ yi waru wu uwwa uyo'o u wivuwun.
\v 35 Mantsa ma na u ri okongo suru, iɗa'a i ta̱ tsura̱ wivuwun u na u shi tsura̱i shi a mantsa ma̱ wivuwun wa Ashibi ma na na i da̱na̱i pe nden.
\p 
\v 36 <<Amma o una̱ u ɗu gba aza a na a buwai, n ta zuwa wovon wa̱ a̱bunda̱ o okolo a̱ ɗu a̱tsuma̱ e iɗa yi n'yuwatan n ɗu. Hali ni ilama ya̱ a̱vu'un yaa saɓa ɗu. I ta suma she damma aza a na aa sumusa matsun mepe'eni, reve i riya̱, ko na wo o'woi za lo aa saɓusa ɗu shi.
\v 37 I ta̱ da̱na̱ a ngamulai va̱ni ɗu tsa ama a na a sumusaa una̱ u matsun me pe'eni ko na wo o'woi za lo aa saɓusa le shi. Adama o ndolo yaa gura isawan a̱ ma̱ka̱ka̱n ma n'yuwatan n ɗu shi.
\v 38 I ta̱ kuwa̱ a̱tsuma̱ a nɗa n ro. Iɗa yi n'yuwatan n ɗu i ta lyuwa ɗu.
\v 39 Amma o una̱ u ɗu gba aza a na a buwai, i ta̱ kuwa̱ a̱tsuma̱ e iɗa yi n'yuwatan n ɗu adama a̱ nusu ɗu na̱ wa aza a nkaya n ɗu.
\p 
\v 40 <<Agba nna a pati gafura vu nusu le na̱ nusu vu nkaya n le nu ulambu wa amayun e le e ekere a̱ va̱ waru nna̱ a̱ usu a yuwaan mu ta̱ aciyogbamu,
\v 41 ili i na i zuwai n 'yuwan nle hali n keɓe nle a̱ tyo e iɗa yi n'yuwatan nle, nna̱ a̱ ka̱ɗa̱to okolo a aciyogbamu e le reve a̱ usu unusu u le,
\v 42 n ta cuwan na akucunu a na n yuwain na̱ Yakubu, na̱ Ishaku na̱ Ibrahim. N ta gba a cuwan ni iɗa'a.
\v 43 Amma a ta lyawa iɗa'a i tsura̱ wivuwun a mantsa ma na u ri okongo. A ta̱ gba a tsupa o una̱ wu nusu le adama a na a 'yuwain wila̱ u va̱ waru e enei wila̱ u va̱ idaba.
\v 44 Agba suru na̱ ne, a mantsa ma na a̱ ri e iɗa yi n'yuwatan n le, maa lyawa le shi, ko me ene le idaba shi hali na moo kototo le suru suru shi ko n kuɗa akucunu a na n yuwaan n le. A̱mu ɗa A̱sulazuva A̱sula̱ e le.
\v 45 Amma adama a̱ ɗu n ta cuwan na̱ akucunu a na n yuwain na̱ nkaya n ɗu aza a na mu uta̱yi a̱tsuma̱ e iɗa ya Masar e esu a ama a nɗa n ro adama moo o'wo A̱sula̱ e le. A̱mu ɗa A̱sulazuva.>>
\p 
\v 46 Ele nda e le ɗa ili i na a zuwai na̱ wila̱ nu uritosu u na A̱sulazuva a yuwain na ama a Isra'ila e ekere a Musa a Masasan ma Sinai.
\c 27
\s1 Atsupu e ili i na i ri za va̱ A̱sulazuva
\p 
\v 1 Reve A̱sulazuva a yuwan adanshi na̱ Musa, u damma,
\v 2 <<Vu yuwan adanshi na ama a Isra'ila vu damma le, nna̱ vuma yuwan akucunu la̱nga̱ a na waa ca A̱sulazuva vuma u ta gura tsupaa vuma'a ni ikebe o una̱ u vuma'a,
\v 3 apa cine o rito ikebe i vuma'a o una̱ u makundatsu ma̱ a̱a̱'isa̱ a akiza. Vali na ri na a'wan ushin a̱ tyo kupota̱li, a ta tsupa azurufa kupoton.
\v 4 Agba na̱ ka ɗa, a ta tsupa azurufa mata'atsu.
\v 5 Ulobo u na u ri a'wan o ton a̱ tyo a'wan ushin, a ta tsupa azurufa ushin. Usheli u na u ri na a'wan o ndolo a ta tsupa azurufa kupa.
\v 6 Mawun mo ulobo ma na ma̱ ri na̱ woto u ta̱ a̱ tyo a'wan o ton, a ta tsupa azurufa ton. Usheli gba na u ri na a'wa'an, a ta tsupa azurufa ta'atsu.
\v 7 Vuma na gba ri na a'wan kupota̱li a gawan, a ta tsupa azurufa kupa no ozo o ton o una̱ u vali. O una̱ wu ka gba, a ta tsupa azurufa kupa.
\v 8 Nna̱ vuma ciga yuwan cu'un va akucunu a nda agba alambi a ɗa na waa gura tsupa ili i na a paɗaa niyi shi, to, u 'ya̱wa̱ na̱ vuma'a uba̱ta̱ wa ganu, adama ganu paɗa ili i na i lobonoi na vuma'a waa gura tsupa.
\p 
\v 9 <<Nna̱ akucunu'u e reme ta̱ a na waa ca iliyamunga i na yi ntsayi a ca A̱sulazuva a ɗa, to iliyamunga i ndolo wo o'wo ta̱ ili ya akiza.
\v 10 Nu u 'yuwan u ciga u kita'wan iliyamunga'a wan, waru she u vadala za vu ulobonu na̱ za babu ulobonu wan, ko za babu ulobonu na̱ za vu ulobonu wan. Na̱ waa kita'wan iliyamunga ni iliyamunga, a̱yi na̱ za na a kita'wai'in ele ra o to o'wo ili ya akiza.
\v 11 Agba nni ili i na a yuwain nzuwulai iliyamunga yi idaba i ɗa i na yi ntsayi a ca A̱sulazuva shi, to, vuma'a u 'ya̱wa̱a̱ ni iliyamunga'a ya ganu.
\v 12 Ganu gba u ta̱ ka̱lyuwa̱ ulobonu wi iliyamunga'a ko u tu ulobonu ko u ri ulobonu shi, cine ganu paɗaa niyi ne ɗaɗa wa̱a̱ da̱na̱.
\v 13 Amma nna̱ za vi ili'i u ciga ta̱ u ka̱mba̱ u tsupisa iliyamunga'a, to, u ta̱ da̱shi za ta̱ a̱tsuma̱ o ozo o ton a aci e ili i na a paɗai.
\p 
\v 14 <<Nna̱ vuma ca u'wa wa̱ yi wo o'wo ili ya akiza e ekere a̱ A̱sulazuva, to ganu ka̱lyuwa̱ ulobonu wu u'wa'a. U ka̱lyuwa̱ ko u'wa'a u tu ulobonu ko u ri ulobonu shi. Ili i na ganu paɗai suru, ne ɗaɗa wa̱a̱ da̱na̱.
\v 15 Nna̱ za na cayi u'wa'a u ciga u ka̱mba̱ u tsupisa u'wa'a, to u ta̱ da̱shi za ta̱ a̱tsuma̱ o ozo o ton a aci e ili i na a paɗayi u'wa'a, reve u'wa'a wo o'wiso za va̱ yi.
\p 
\v 16 <<Na̱ vuma ca A̱sulazuva upasu u na wi iɗa wa agadu a̱ yi, to, a paɗaa iɗa'a ikebe a̱bunda̱ o una̱ wi icu'un i na a̱a̱ cu'wa̱n pe. Shekel azurufa kupoton o una̱ u makundatsu ushin vi icu'un.
\v 17 Nu u ca ta̱ uɗuma̱ wa̱ yi a̱tsuma̱ a Aa'wan a̱ A̱buki o uka̱mbusa̱ fa̱a̱n, ikebe i na a paɗayi uɗuma̱'a̱ ya aa'wan i ɗaɗa wee reme.
\v 18 Amma nnu u ca ta̱ uɗuma̱'a̱ cina Aa'wan a̱ A̱buki'i a̱ ka̱ra̱, to, ganu paɗaa uɗuma̱'a̱ ikebe o una̱ wa a'wan a na a buwai Aa'wan a̱ A̱buki'i a̱a̱ ka̱nda̱ruwisa̱. Waru a ta jiba a̱bunda̱ e ikebe i na a paɗai.
\v 19 Agba na̱ vuma na cayi uɗuma̱'a̱ u ciga u ka̱mba̱ u tsupisa yi, to u ta̱ da̱shi za ta̱ a̱tsuma̱ o ozo o ton e ikebe yu uɗuma̱'a̱. Reve uɗuma̱'a̱ wo o'wiso za va̱ yi.
\v 20 Agba nu u ciga u tsupisa uɗuma̱'a̱ shi, ko u shi ta̱ ɗe u winaa za ro uɗuma̱'a̱, to u ri n yuwan u ka̱mba̱ u tsupisa uɗuma̱'a̱ shi.
\v 21 Na a ca uɗuma̱ a̱tsuma̱ a aa'wan a̱ A̱buki'i, uɗuma̱'a̱ u to o'wo ili ya akiza tsu uɗuma̱ u na a tawayi A̱sulazuva. U to o'wo uɗuma̱ u nan ganu.
\p 
\v 22 <<Na̱ vuma ca uɗuma̱ u na u tsulai, uɗuma̱ u na u ri pe a̱tsuma̱ e iɗa ya agadu shi,
\v 23 ganu ta paɗaa uɗuma̱'a̱ ikebe i na wu ntsayi hali a̱ tyo a a'wan a na a buwai a cina Aa'wan a̱ A̱buki'i. Vuma'a u ta tsupa ikebeꞌe o una̱ wi ikebe i na a paɗai o urana'a, ili ya akiza i ɗa e ekere a̱ A̱sulazuva.
\v 24 A Aa'wan a̱ A̱buki'i uɗuma̱'a̱ u ta̱ ka̱mba̱ e ekere a za na tsula niyi, za na uɗuma̱'a̱ u shi za va̱ yi.
\v 25 A ta paɗa ili i na yi ntsayi a tsupa suru o una̱ u makundatsu ma̱ a̱a̱'isa̱ a akiza.
\p 
\v 26 <<Agba ko za aa ca umatsun wu ufaru wi iliyamunga shi, a na wo o'woi umatsun wu ufaru wi iliyamunga suru za va̱ A̱sulazuva ɗa, ko nan ko kyon, za va̱ A̱sulazuva ɗa.
\v 27 Amma ni iliyamunga'a za vi idaba ɗa, a ta gura ka̱mba̱ a tsupisa yi o una̱ wi ikebe i na ganu paɗaa niyi oɓolo na̱ za ta̱ a̱tsuma̱ o ozo o ton. Nna̱ gba aa tsupisa yi shi, a wina yi o una̱ wi ikebe i na a paɗa niyi.
\p 
\v 28 <<Agba ili yi lo a̱tsuma̱ e ili i na vuma ri na̱ a̱yi, na a cayi A̱sulazuva, ko vuma, ko iliyamunga, ko iɗa ya agadu, na aa gura wina ko a tsupa shi. Ili i na a tawai suru ili ya akiza i ɗa e ekere a̱ A̱sulazuva.
\v 29 Babu vuma na a cayi adama o ukototosu na a tsupisa adama a̱ yi. Na a 'yuwan a ciga o una yi.
\p 
\v 30 <<Za ta̱ a̱tsuma̱ a kupa suru vi ili yi iɗa'a, ko vi ishina, ko vu matsun vu ɗanga, a̱za̱ a̱ A̱sulazuva a ɗa. Ili ya akiza i ɗa e ekere a̱ A̱sulazuva.
\v 31 Na̱ vuma ciga u tsupisa za ta̱ a̱tsuma̱ a kupa suru na u cayi, u da̱shi za ta̱ a̱tsuma̱ o ozo o ton a aci e ili'i.
\v 32 Za ta̱ a̱tsuma̱ a kupa vi iliyamunga suru, ko vi inan, ko vi ikyon, ko vu mgbele, za va kupa suru na va̱a̱ ka̱ra̱ za̱la̱ va aaɗanga a za va aaguɓa, u to o'wo ili ya akiza e ekere a̱ A̱sulazuva.
\v 33 Waa ɗangula iliyamunga i kupa o una̱ wu ulobonu wa̱ yi shi ko o ulambu wu ulobonu wa̱ yi shi. Agba waru waa kita'wa yi shi. Na a kita'wa yi, iliyamunga'a na̱ za na a kita'wai o to o'wo na akiza. A̱ ri na aa gura tsupisa le shi.>>
\v 34 Ele nda, ele ɗa wila̱ u na A̱sulazuva a cayi Musa a Masasan ma Sinai adama a ama a Isra'ila.
