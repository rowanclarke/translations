\id 1SA - Mbembe Okohm [mfnOK]
\h 1 Samwẹl
\toc1 Ocheden-nwẹr kwa Samwẹl
\toc2 1 Samwẹl
\mt1 Ocheden-nwẹr kwa Samwẹl
\c 1
\s1 Ẹ́mmaanà cha Samwẹl
\p 
\v 1 Iwa ọkhaam ojinọng kw'okpen Ẹlkana. Ofon Rama k'okhubha kwa Zuph, ka mgbegbeho s'Ephraim. Kẹ wa ode nnwa kw'ijinọng kwa Jeroham. Jeroham wa ode nnwa kw'Elihu, Elihu ode nnwa kwa Tohu, kwa Zuph kw'ofon Ephraim obhoni.
\v 2 Iwa Ẹlkana ọtzọk panọng afa p'akpen Hana ọmaana Pẹnina. Wa Pẹnina ọmaani va, yina, Hana nnwa kọmaani.
\p 
\v 3 Wa cho kpenamkpen, Ẹlkana om-obina k'obhon kwẹ, ọtza okpobha Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir ka Shilo, obiro osi ẹjafọhni ọnang-ẹ. Wa va p'ijinọng p'Ẹli p'ade Hophni, ọmaana Phinẹhas, bọ iwa ade afọhnẹja p'Ọvaar Ibinọkpaabyi ka Shilo.
\v 4 Ogbe obebeng kw'Ẹlkana otza osi ẹjafọhni, om-okkema nden ọtzọkha ọnang Pẹnina, ttara va pẹ biphyir, p'ijinọng ọmaana p'ipanọng.
\v 5 Yina, wa ọm-ọnang Hana ekkema ch'ede igbe ifa ka ch'ọnangi oyok, okhuri idadaakha s'ọkhaam ọmaana Hana, ttara bi da iwa Ọvaar Ibinọkpaabyi oni Hana ọmmaan ọ̀nangi.
\v 6 Iwa oyokh-ọbhọbha kwa Hana om-olukh-ẹ, okhuri da Ọvaar Ibinọkpaabyi oni Hana ọmmaan ọnangi, ifha ettem ẹyakh-ẹ atzim.
\v 7 Iwa ilulukhi nna ichin ororo ka cho kpenamkpen. K'ogbe kpenamkpen kwa Hana ochin k'ọhọhm kw'Ọvaar Ibinọkpaabyi, oyokh-ọbhọbha om-olukh-ẹ maa, Hana om-obhom, obiro obhum ọchattọhk ochichi.
\v 8 Ẹlkana kw'ode odim kwẹ, ọm-ọbọbh-ẹ bi, “Hana, mbọng f'am-abhom o? Asi yan am-abhum ọchattọhk ochichi o? Nkwu-osisi sọ s'ettem nde yan o? Kaam mbar odik mach'ira va p'ijinọng jobh abar e.”
\p 
\v 9 Iwa ewu dani ka Shilo, mada bẹ akk'ọchattọhk akyera ochichi, bẹ abira akyera atzuk ogwo-ogwo, Hana obina obobe. M'ogbe nwa, Ẹli kw'ode ọfọhnẹja owobh ẹwọr k'ogbera kw'om-owobha k'ẹkpọmmachi ch'ọhọhm kw'Ọvaar Ibinọkpaabyi.
\v 10 K'ọmmamma kw'owobh-ẹ k'ettem, Hana obhom, ozi njọhm ọnang Ọvaar Ibinọkpaabyi.
\v 11 Ọn-ọtzọkha ọnwọhngi, oben bi, “O Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir, idikha kọ afha are ọmmamma kwa kaam ọtzọhmnọng kwọ, abira ajim-m, ọtzọhmnọng kwọ karaam, anang-m nnwa kw'ijinọng, kaam ńdọkh-ẹ nnang-ọ k'akpen pẹ biphyir, ẹkpẹr manda dani ch'ephyuri isisa sẹ kéde.”
\p 
\v 12 Wa mada Hana ochin ororo om-ozi njọhm ọnang Ọvaar Ibinọkpaabyi, Ẹli om-okhẹ-ẹ otzum k'ẹmma.
\v 13 Wa Hana om-ozi njọhm k'ettem ẹtzaanga, mmakpa sẹ mminyebh, yina, ọwọhng k'iyaan koyini. Mẹ wọ, Ẹli on-ochibhi bi, Hana ọkk'atzuk obuma.
\v 14 On-oben-ẹ bi, “Ogbe obhir otzuma yan, kwa kọ awobha k'etzuk-buma o? Kwọbha ibubuma sọ.”
\p 
\v 15 Mẹ wọ, Hana on-obhina bi, “Itta kwaam, kwẹ mando kode. Kaam nde kwanọng kw'owobh k'ọmmamma kw'ideden e. Kaam atzuk manda bani ndimi mmingwa, kaam mmimgbaak Ọvaar Ibinọkpaabyi ọmmamma kw'ettem chaam e.
\v 16 Kọ, kaam ọtzọhmnọng kwọ mach'inọng-dama kàtzọkha. Kaam mminzi njọhm s'ifon k'iyayakhi-dik saam s'ideden, ttara ittem-dọkhiji-dik saam e.”
\p 
\v 17 Mẹ wọ e, Ẹli obhin-ẹ bi, “Kọ rọhng k'odidiri. Tte Ibinọkpaabyi kw'anọng p'Israẹl akpobh, ọnang-ọ idik s'akk'ẹ aphyema.”
\p 
\v 18 Hana obhin-ẹ bi, “Tte kaam ọtzọhmnọng kwọ ndọkha ọphyaam ka kọ k'itzitzikha.” Mẹ wọ, on-okpira itzitzikha, obiro ofona ọtza ochi ọchattọhk.
\p 
\v 19 K'ekpekpebha ch'ewu ehobh, bẹ abina atza akpobha Ọvaar Ibinọkpaabyi. Mada bẹ akk'akyera, bẹ akpa nnam abhana ka Rama, kw'ode obhon kwabẹ. Iwa Ẹlkana oyima Hana abẹ, Ọvaar Ibinọkpaabyi ọbhaanga njọhm sa Hana.
\v 20 Okwu opyiri k'ogbe mẹ, Hana otzima ibhọr, ọmaan ojinọng, ọkpẹ-ẹ Samwẹl\f + \fr 1.20 \ft K'eHiburu, Samwẹl ede che ch'eyini odik, ebir ekher ọwọhng kw'ode bi, “Che chẹ ede Ibinọkpaabyi.” Wa Hana ọnangi nnwa kwẹ che nda ifha ọnang Ọvaar Ibinọkpaabyi abarada, okhuri da Ọvaar Ibinọkpaabyi ọnang-ẹ ebhina k'ephyema chẹ.\f*, oben bi, “Kaam mphyem-ẹ k'Ọvaar Ibinọkpaabyi.”
\s1 Hana ọtzọk Samwẹl ọnang Ibinọkpaabyi
\p 
\v 21 Mada Ẹlkana otzim ẹhọhmmọr chẹ biphyir ochina k'ọhọhm kw'Ọvaar Ibinọkpaabyi, ifha otza osi ẹjafọhni cha cho, obiro otzuk ọnwọhngi kwẹ,
\v 22 wa Hana bẹ abẹ kọ̀tzọni. On-oben odim bi, “Idikha nkk'nnwa ẹba ndima, kaam ńdọkh-ẹ nchena Ọvaar Ibinọkpaabyi k'ọhọhm kwẹ, kẹ óruk akpen pẹ mẹ biphyir, k'ogbe kpenamkpen.”
\p 
\v 23 Mẹ wọ, Ẹlkana obhin-ẹ bi, “Si mach'abeni, kọ wobha ma matzẹmaa atzim-ẹ ẹba. Tte Ọvaar Ibinọkpaabyi okhinggẹ ohok echekhi ch'atzim pọ.” Mẹ wọ, kwanọng nwa owobha ọrọk nnwa kwẹ, maa otzim-ẹ ẹba.
\p 
\v 24 Mada okk'nnwa ẹba otzima, ọtzọkh-ẹ da otzim ọkhar-ọkhara, ọmaana ọbhaamnwa kwa cho attaan, ọmaana ẹgbangbang-dim ch'abubuma, ttara otzuk-gbere otzima ochina k'ọhọhm kw'Ọvaar Ibinọkpaabyi ka Shilo.
\v 25 Mada bẹ akk'ọbhaam-nwa nwa afha atzima asi ẹjafọhni, bẹ atzọkha nnwa nwa achena Ẹli.
\v 26 Hana on-oben Ẹli bi, “O itta kwaam tzotzokhaan, da kọ achin ororo aruk akpen, kaam nchekhi k'akpen pọ bi, kaam wọ nde kwanọng kw'iwa mbe ma, mminzi njọhm nnang Ọvaar Ibinọkpaabyi e.
\v 27 Wa kaam nzi njọhm mphyem Ọvaar Ibinọkpaabyi nnwa nwa, ma, okk'ephyema nduma chaam ọbhaanga e.
\v 28 Mẹ wọ, kaam nna-ndọk nnwa nwa nnang Ọvaar Ibinọkpaabyi e. Kẹ ón-ode kw'Ọvaar Ibinọkpaabyi k'akpen pẹ biphyir.” Mẹ wọ e, bẹ achunga mẹ anang Ọvaar Ibinọkpaabyi ikpokpobha.
\c 2
\s1 Hana ọtzọhng Ibinọkpaabyi
\p 
\v 1 Mẹ wọ, Hana ozi njọhm oben bi,
\q1 “Kaam ngaam ọdadaami kw'ideden k'ettem chaam k'Ọvaar Ibinọkpaabyi;
\q2 Ọvaar Ibinọkpaabyi ọkk'aam ẹfa ch'ekhema\f + \fr 2.1 \ft EHiburu ẹkkẹri bi, “Obhik kwaam okk'otzini k'ẹrọng k'Ọvaar Ibinọkpaabyi.” Ọwọhng nwa oyini bi, “Ọvaar Ibinọkpaabyi ọkk'aam ẹfa ch'ekhema ọnanga.”\f* ọnanga.
\q1 Kaam nsi ẹmma nnang attattaanga-nọng paam,
\q2 kaam ndaami ettem, okhuri ẹnaanga cha kọ akk'aam ananga.
\b
\q1 
\v 2 “Ọnọng kode kw'owuri macha kọ Ọvaar Ibinọkpaabyi;
\q2 ọnọng ọdọdọk kode kw'oyongi kọ Ọvaar Ibinọkpaabyi;
\q2 Ẹtzakpa kede ch'ẹgaangi mach'Ibinọkpaabyi kwaman.
\b
\q1 
\v 3 “Bọng ka mgbagbaakha kàge,
\q2 Bọng ẹmma kàben,
\q1 okhuri bi, Ọvaar Ibinọkpaabyi ode Ibinọkpaabyi kw'eronga,
\q2 kẹ wọ ọm-ọttọhna aponga p'osisi kw'anọng.
\b
\q1 
\v 4 “Ayuk p'akkakkaama akk'aphyakhi,
\q2 yina, anọng p'asar atto, akk'ẹfa abira akhaama.
\q1 
\v 5 Anọng mbuma p'iwa am-achi adọhbh, an-ayini ayok abẹ yina bẹ an-are ọchattọhk,
\q2 yina, ayok mbuma p'iwa am-ayima okwo, an-achi ọchattọhk adọhbh.
\q1 Kwanọng kw'iwa ọkpaan-ọkpaana, okk'va azenamfa ọn-ọmmaana,
\q2 yina, oyok kw'iwa okk'va ọmmaana k'ọhaabh, manda wani dọk kọ̀khaam.
\b
\q1 
\v 6 “Ọvaar Ibinọkpaabyi wọ otzim obo, obiro otzima akpen;
\q2 kẹ wọ otzim apfura ochina k'opfura-bhon, obiro otzima bani ọkpa nnam.
\q1 
\v 7 Ọvaar Ibinọkpaabyi wọ ọtzọhmi opyibhada, obiro ọtzọhm ojibhaada;
\q2 kẹ wọ ọm-ọhakha anọng bani ewobha, obiro otzini ayok bani k'ẹrọng.
\q1 
\v 8 Kẹ wọ om-otzini agbogbora k'ọkpọm, obiro otzini anọng p'arukhi k'owora k'ẹraamma.
\q2 Otzini bẹ ohok ẹwọr k'ibe s'avaar-vaara, obiro osi bẹ atzọkha mvaar-chi s'ikpokpobha.
\b
\q1 “Ọvaar Ibinọkpaabyi wọ ọkhaam ittẹwọr s'ọyagbin;
\q2 okk'ọyagbin otzini ọnana m'atza mba.
\q1 
\v 9 Kẹ wọ ọ́baabha orenga kw'anọng pẹ p'akhaam nnam-ophephe,
\q2 yina, kẹ wọ ódimi anọng-dama k'ipyerungi.
\b
\q1 “Ẹfa arang ch'ọnọng om-otzima okhema erima,
\q2 
\v 10 Ọvaar Ibinọkpaabyi ódimi anọng p'arim-ẹ abẹ odimi.
\q1 Kẹ owobha k'ẹrọng otto bẹ etzum,
\q2 Ọvaar Ibinọkpaabyi wọ ọ́kpaara aponga p'ọyagbin biphyir.
\b
\q1 “Kẹ ọ́nang ọvaarnọng kwẹ agbọhkhiji,
\q2 ọnang kẹ nwuma kw'okk'ana obyengi k'eho ẹfa ch'ekhema.”
\p 
\v 11 Mẹ wọ e, Ẹlkana obina ọbhana ka Rama. Yina, wa odikkobh nwa owobha k'irekh-irek kw'Ẹli kw'ode ọfọhnẹja, osi ọtzọhm k'itzitzikha s'Ọvaar Ibinọkpaabyi.
\s1 Abyibya-va p'Ẹli
\p 
\v 12 Iwa va p'Ẹli ade ajinọng-dukhi. Bẹ Ọvaar Ibinọkpaabyi mach'ọttọhk katzọk.
\v 13 Wa ode ẹmmaana ch'afọhnẹja k'ottem kw'anọng p'Israẹl bi, k'ogbe kpenamkpen kw'ọnọng ọfọhni ẹja, mẹ da etzen cha bẹ atzim afọhni ẹja etzim ẹnọhn k'ekpon, ọtzọhmnọng kw'ọfọhnẹja okwu ttara ejum ch'ẹkhaam aha attaan,
\v 14 okhum k'irọkha kpenamkpen sa bẹ awọhni etzen nda. Nden kpenamkpen s'ọfọhnẹja ohobhi k'irọkha, kẹ ọfọhnẹja ọtzọkha bi, sẹ nde sẹ. M'eden nda dọ ch'iwa bẹ am-asi anang anọng p'Israẹl biphyir, p'atza ka Shilo.
\v 15 Yina bẹ awọhn iyaak s'etzen ch'ẹjafọhni, ọtzọhmnọng kw'ọfọhnẹja ọm-ọtza okheba ọnọng kw'osi ẹjafọhni oben-ẹ bi, “Kọ nang ọfọhnẹja nden nani ọbhaabh, kẹ kokhera bi ọtzọkha etzen ẹwọnachẹ, oyongi ekhekhebhi.”
\p 
\v 16 Idikha ọnọng nwa kw'osi ẹjafọhni on-okher, on-oben-ẹ bi, “Tte bẹ abhabhaabh iyaak nnuma ọbhabh, ifha atzọkha ekkema ch'ẹdaakh-ọ.” Ọtzọhmnọng kw'ọfọhnẹja obhin-ẹ bi, “Mma, kọ nang-m chẹ madeden nwa, oni mando ode, kaam ńdọkha chẹ k'ẹfa.”
\p 
\v 17 Wa osisi kw'adikkobh mba p'Ẹli ode ẹkhọngkwuri ch'ideden k'itzitzikha s'Ọvaar Ibinọkpaabyi, okhuri da iwa bẹ am-atzọkha nnanga s'anọng anangi Ọvaar Ibinọkpaabyi, atzima atta igbọrọ.
\p 
\v 18 Wa Samwẹl kw'ode odikkobh ọfọr ẹphọd cha bẹ atzim ndik nyokhasẹ nkkakka asi, om-osi ọtzọhm k'itzitzikha s'Ọvaar Ibinọkpaabyi.
\v 19 Cho kpenamkpen, Hana kw'ode ọkka om-okhum ọnọhma-baba ochena Samwẹl, k'ogbe kwa kẹ ọmaana odim am-atza asi ẹjafọhni cha cho.
\v 20 Cho kpenamkpen, Ẹli om-odo Ẹlkana ttara kwanọng kwẹ, oben bi, “Tte Ọvaar Ibinọkpaabyi ọdọ-ọ, ttara va adọdọk p'afona ma kwanọng nwa, p'atzọkha ewobha ch'oyok kw'ophyemi, obiro otzin-ẹ ọnang Ọvaar Ibinọkpaabyi.” Mada bẹ akk'akyera, bẹ afona abhana.
\v 21 Wa Ọvaar Ibinọkpaabyi osi ọphyaam ọnang Hana. Hana obiro ọmaan ajinọng attaan, ọmaana panọng afa. Yina, wa Samwẹl odikkobh nwa ọkk'ọbara ka cho k'itzitzikha s'Ọvaar Ibinọkpaabyi.
\p 
\v 22 Wa Ẹli kw'ọkk'ọtzama kpọng, ọm-ọbhaang idik kpenamkpen sa va pẹ am-asi, anọng p'Israẹl biphyir, ọmaana odem kwa bẹ am-ayima panọng p'am-asi ọtzọhm k'ẹbaakhamma ch'ikhira s'etzobha abẹ.
\v 23 Mẹ wọ, oben bẹ bi, “Kaam nkk'ẹmmaana-tzama chabọng mmaanga k'anọng mba biphyir. Bọng asi yan asi idik-dema nna?
\v 24 Mma e, va paam, idik sa kaam mmaang okhuri bọng s'im-inyaami k'ottem kw'anọng p'Ọvaar Ibinọkpaabyi, kijibh e.
\v 25 Idikha ọnọng ọkhaam ottotto k'itzitzikha s'oyokh-ọnọngẹya, Ibinọkpaabyi ofha okhukhi k'eho ch'ọnọng nwuma kw'ọkhaam ottotto. Yina, ọnọng on-osi ẹkhọngkwuri k'itzitzikha s'Ọvaar Ibinọkpaabyi, anyi wọ on-okhukhi k'eho ch'ọnọng nwuma o?” Kaambi mẹ wọ, wa va mba ẹtzọhng-dọra ch'otte katzọk, okhuri da ode ochibhi kw'Ọvaar Ibinọkpaabyi bi, ọtzọkha akpen pa va mba.
\p 
\v 26 Iwa Samwẹl ochin ororo ọbar ka cho, ọmaana k'ọphyaam f'Ọvaar Ibinọkpaabyi, ttara anọngẹya.
\s1 Eponga-ttọhna ch'ẹhọhmmọr ch'Ẹli
\p 
\v 27 Iwa ewu dani, ọsi-ẹjaakhi kw'Ibinọkpaabyi okhebh Ẹli, oben-ẹ bi, “Ma wọ ode odik kw'Ọvaar Ibinọkpaabyi obeni, ‘Kaam wọ iwa nsi ẹjaakhi cha for saam nnang ẹhọhmmọr ch'atte\f + \fr 2.27 \ft Otte nwa wa ode Aarọn kw'iwa ode otte kw'ideden kw'afọhni-nja biphyir k'Israẹl biphyir.\f* e, k'ogbe kw'iwa bẹ awobh k'Ijip, k'irekh-irek kwa Phero.
\v 28 Kaam wa ndek atte ka nnọmma s'Israẹl bi, ode ọfọhnẹja kwaam, ifha om-obiro ochina k'ijafọhnibe saam, obir ọkwọmi insẹns, obiro ọfọra ẹphọd k'itzitzikha saam. Kaam wa ndọk ẹnanga ẹkwọmichẹ kpenamkpen ch'anọng p'Israẹl anangi, nnang ẹhọhmmọr ch'atte.
\v 29 Bọng an-asi yan atzọkha njafọhni saam, ttara nnanga saam, sa ndek k'ọhọhm kwaam, abari mmo o? Kọ Ẹli, va pọ an-asi yan abar kọ odik ọtzam ọyọhnga kaam o, bi am-atte bẹ ọbọhk, bọng atzekha nden ọkkakka k'ẹjafọhni ch'anọng paam p'Israẹl o?’
\p 
\v 30 “Mẹ wọ, Ọvaar Ibinọkpaabyi kw'ode Ibinọkpaabyi kw'Israẹl, osi ẹjaakhi bi, ‘Kaam nchekhi bi, anọng p'ẹhọhmmọr chọ, ọmaana ẹhọhmmọr ch'atte kwọ am-asi ọtzọhm k'itzitzikha saam, maa ogbe ode.’ Yina, kaam Ọvaar Ibinọkpaabyi nna nsi ẹjaakhi bi, ‘Tzọmi-tzọmi okponga k'idachen, anọng mbuma p'anang-m ikpokpobha bọ pa kaam ńnang abarada, mbuma p'alukh-m, ńnang bẹ ẹmma.
\v 31 Ogbe okwuma, kwa kaam ḿkpaara akpen p'anọng p'enọmma chọ, ttara ẹhọhmmọr cha kọ Ẹli. Ọnọng kw'obiro óruk ọtzam-ọtzam k'ẹnọmma chọ kóde.
\v 32 Kọ are ọmmamma k'irukhabe saam. Kaambi bẹ atte ojibhada ọbọhk anang Israẹl, ọnọng kw'obiro oruk ọtzam-ọtzam k'efonamma chọ kóde.
\v 33 Ọnọng kpenamkpen kwa kaam nni akpen pẹ mkpaar k'ijafọhnibe saam, óruk akpen pẹ k'obhoma, ttara nkwu-osisi k'ettem chẹ. Va pọ, ttara va pa va pọ biphyir, ápe k'edikkobh.
\p 
\v 34 “ ‘Odik kw'otto okhebha va pọ p'ijinọng afa, Hophni ọmaana Phinẹhas, óde ẹkhọhkha ọnang-ọ. Bẹ anọng afa ápe k'ewu dani.
\v 35 Kaam ńdekha ọfọhnẹja nnang for saam, kw'ọ́hakha eho ọnang-m, kw'obiro osi odik kpenamkpen otzor k'ochibhi kw'ettem chaam. Kaam ńttima ẹhọhmmọr chẹ \it bi gbuk\it*, kẹ óbiro ósi ọtzọhm k'itzitzikha s'ọnọng kwa kaam nkk'ana mbengyi k'eho k'ogbe kpenamkpen.
\v 36 Mẹ wọ, ọnọng kpenamkpen kw'ẹnọmma chọ, ọ́hakha eho ọnang-ẹ ka silva, ọmaana k'obiribiri kwa brẹd, ttara ekhukhi bi, “Tzotzokhaan, rọbha kaam nsi ọtzọhm f'ọfọhnẹja wani, ifha ngaama ọchattọhk fa nchi.” ’ ”
\c 3
\s1 Ọvaar Ibinọkpaabyi oyeri Samwẹl
\p 
\v 1 Iwa odikkobh Samwẹl om-osi ọtzọhm k'irekh-irek kw'Ẹli k'itzitzikha s'Ọvaar Ibinọkpaabyi. K'ogbe nwuma, wa ọkhaar-ọkhaara bi ọnọng ọbhaanga atzim p'ẹjaakhi p'Ọvaar Ibinọkpaabyi, idik s'anọng are ttara chen anna kibiri ihaabh.
\p 
\v 2 Wa k'erungiwu dani, Ẹli kw'iwa oni iyaan \it bi kpaar\it* dọk om-ore, oyim k'ibe s'om-okkekkeni oyima.
\v 3 K'ogbe kw'otwikhikkaang kw'Ibinọkpaabyi on-otzima odimi, wa Samwẹl oyim k'iwuradabe s'Ọvaar Ibinọkpaabyi, kẹ da Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi ewobh.
\v 4 Mẹ wọ, Ọvaar Ibinọkpaabyi oyeri Samwẹl.
\p Samwẹl okhera bi, “Itta, kkeri kaam ma e.”
\v 5 Ọrọbh otzor Ẹli oben bi, “Kkeri kaam ma e; kọ wọ ayer-m.”
\p Yina, Ẹli obhin-ẹ bi, “Kaam kọ kinyeri. Kpa nnam atza ayima.” Mẹ wọ, Samwẹl otza oyima.
\p 
\v 6 Ọvaar Ibinọkpaabyi obiro oyer-ẹ, “Samwẹl.” Samwẹl obiro obina otzor Ẹli, oben bi, “Kkeri kaam ma e, kọ wọ ayer-m.”
\p Ẹli obhin-ẹ bi, “Nnwa kwaam, kaam kọ kinyeri, kpa nnam atza ayima.”
\p 
\v 7 Wa Samwẹl Ọvaar Ibinọkpaabyi otzim-om-oronga, bẹ ẹjaakhi ch'atzim p'Ọvaar Ibinọkpaabyi atzima-amasa anang kẹ Samwẹl.
\p 
\v 8 Ọvaar Ibinọkpaabyi oyeri Samwẹl ottong igbe ittaan, obina otzor Ẹli oben bi, “Kkeri kaam ma e, kọ wọ ayer-m.”
\p Mẹ wọ, Ẹli otzin bi, Ọvaar Ibinọkpaabyi wọ om-oyeri odikkobh nwa.
\v 9 Mẹ wọ, Ẹli oben Samwẹl bi, “Kọ rọhng atza ayima. Idikha obiro oyer-ọ, ben bi, ‘Ọvaar Ibinọkpaabyi, gbaak kkeri ọtzọhmnọng kwọ om-oyong itzọhng.’ ” Mẹ wọ, Samwẹl ofona otza oyima k'ibe sẹ.
\p 
\v 10 Ọvaar Ibinọkpaabyi okwu obe mẹ, oyeri mach'ira om-oyeri, “Samwẹl! Samwẹl!”
\p Mẹ wọ, Samwẹl obhina bi, “Gbaak, kkeri ọtzọhmnọng kwọ om-oyong itzọhng.”
\p 
\v 11 Ọvaar Ibinọkpaabyi on-oben Samwẹl bi, “Kker e, kaam nna nsi odik m'Israẹl, kw'ókkoni itzọhng kpenamkpen s'ibhaanga kwẹ.
\v 12 M'ogbe nwuma, kaam ńttaanga nnang Ẹli, ọmaana ẹhọhmmọr chẹ, k'odik kpenamkpen kwa nkk'mgbaakha, ttẹwọr k'ittẹwọr maa apyiri k'okpong.
\v 13 Kaam ńsi macha nkk'ẹ mgbaakha bi, mkpaara aponga p'ẹhọhmmọr chẹ m'ogbe ode, k'ẹkhọngkwuri cha kẹ orong odik okhuri kẹ bi, va pẹ p'ijinọng am-asi epyibha anang-m, yina, kẹ bẹ eden kọ̀kpa a.
\v 14 Mẹ wọ, kaam nchekhi nnang ẹhọhmmọr ch'Ẹli bi, ‘Ẹjafọhni kede, ẹnanga kebir ede ch'éfha egbobhi oponga-pyibha kw'ẹhọhmmọr ch'Ẹli.’ ”
\p 
\v 15 Wa Samwẹl oyima maa ewu ehobha, obina okwunga amma p'ọhọhm kw'Ọvaar Ibinọkpaabyi. Yina, wa ojora ọsẹ-ẹ bi, ọgbaak Ẹli odik kw'ore ka chen anna.
\v 16 Yina, wa Ẹli oyer-ẹ, oben bi, “Nnwa kwaam, Samwẹl.”
\p Samwẹl obhin-ẹ bi, “Kkeri kaam ma e.”
\p 
\v 17 Ẹli ọbọbh bi, “Kẹ ọgbaakh-ọ yan o? Kọ kaam odik kadubha. Tte Ibinọkpaabyi ọnang-ọ ettuma ch'ẹbaan-ọ k'iden-dama, idikha adubh-m odik manda wani kwa kẹ ọgbaakh-ọ.”
\v 18 Mẹ wọ e, Samwẹl ọgbaakh-ẹ odik kpenamkpen, kẹ manda wani kodubh. Mẹ wọ, Ẹli oben bi, “Kẹ wọ ode Ọvaar Ibinọkpaabyi e, tte osi odik kw'ojibh-ẹ abẹ.”
\p 
\v 19 Mada Samwẹl ọm-ọbar, wa Ọvaar Ibinọkpaabyi owobh ttar-ẹ, obiro osi odik kpenamkpen kwa Samwẹl ọgbaakhi, ọkhaama ẹjaakhi.
\v 20 Wa anọng p'Israẹl biphyir, ttẹwọr ka Dan maa atza apyiri Beershẹba, atzin k'odik ọkkakka bi, Samwẹl ode ọsi-ẹjaakhi kw'Ọvaar Ibinọkpaabyi.
\v 21 Wa Ọvaar Ibinọkpaabyi ochina ororo om-osi ẹjaakhi cha for sẹ ka Shilo, ma Shilo wọ kw'osi ẹjaakhi cha for sẹ ọnang Samwẹl.
\c 4
\p 
\v 1 Iwa mgbagbaakha sa Samwẹl mpyiri Israẹl makhọra.
\s1 APhilistiya abọk Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi
\p M'ogbe nwa, anọng p'Israẹl abina bi, atza arima aPhilistiya abẹ. Wa anọng p'Israẹl abhingi k'Ẹbẹneza, aPhilistiya abhing k'Aphẹk.
\v 2 APhilistiya atzọhm ẹkhaan ch'agbongnọng pabẹ bi, bẹ atza attema anọng p'Israẹl abẹ. Mada egbong ẹnyaami, wa aPhilistiya akhema anọng p'Israẹl, bẹ afhu anọng nnọhna jobh k'egbong-dam.
\v 3 Mada agbong-nọng p'anaang egbong an-akhun k'ibhingabe, adenho p'Israẹl abọbh ayok bi, “Oreng yan kw'Ọvaar Ibinọkpaabyi otte aPhilistiya ọbọhk bẹ akhema man mayina o? Tte mọtza ọtzọkha Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi ka Shilo, ifha ẹtzọn man abẹ, ebire ẹkkaana man ka mbọhk s'attattaanga-nọng paman.”
\p 
\v 4 Mẹ wọ e, bẹ atzọhm anọng ka Shilo, atza atzọkha Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir, kw'owobh k'ottem kw'achẹrubim, atzima akwu. Wa va p'Ẹli afa p'ijinọng Hophni ọmaana Phinẹhas awobh mẹ, ttara Ẹkkọhbhi nda ch'Echekhi ch'Ọvaar Ibinọkpaabyi.
\p 
\v 5 Mada Ẹkkọhbhi nda ch'Echekhi ch'Ọvaar Ibinọkpaabyi edimi k'ibhingabe, anọng p'Israẹl biphyir awuri ẹmọng, ch'enyengi irerek.
\v 6 Mada aPhilistiya abhaang iyọkhi nna, bẹ abọbh bi, “Bọng ẹmọng cha bẹ am-awuri k'ibhingabe s'aHiburu mando o?”
\p Mada bẹ arong bi Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi ekk'epyiri k'ibhingabe s'abaHiburu,
\v 7 wa ojora osi aPhilistiya. Bẹ aben bi, “Ọkha vani okk'opyiri k'ibhingabe e. Mọkk'ọdama e. Odik dema nwa otzim-ọm-ọtta o.
\v 8 Kwaman ọkk'ọha ma! Anyi wọ ọ́rọbha man ka mbọhk s'akha mba p'akhaam ẹfa manda o? Akha mba bọ iwa asi yina itzama k'adem-k'adem, itto ikhebha anọng p'Ijip k'ibe s'anọng anarukhi e.
\v 9 Bọng bar ettem, aPhilistiya! Bọng de ajinọng \it bi gbuk\it*, oni mando ode, bọng án-abhakhi ade abira p'aHiburu, mach'iwa bẹ akk'ada anang bọng. Bọng de ajinọng \it bi gbuk\it*, arima erima!”
\p 
\v 10 Mẹ wọ e, aPhilistiya arima erima, bẹ akhema anọng p'Israẹl, p'arọbhi, ọnọng-ọnọng otza ochubha k'ikhira sẹ. Wa ẹnọng-fha ẹbari maa, agbong-nọng p'areng k'irerek anọng nnọhna arọbh attaan obhiri chi, adimi anọng p'Israẹl.
\v 11 Wa aPhilistiya abọkha anọng p'Israẹl Ẹkkọhbhi nda ch'Echekhi ch'Ibinọkpaabyi ana. Va p'Ẹli afa p'ijinọng, Hophni ọmaana Phinẹhas abira ape.
\s1 Obo kw'Ẹli
\p 
\v 12 M'ewu nduma dani, ọnọng wani kw'efona cha Bẹnjamin ofona k'egbong-dam ochina ka Shilo, ttara ọbara fa for ọkk'ọjaakhi, k'eho, ọkpọhm obiro obubh-ẹ.
\v 13 Mada okwu opyiri, ore Ẹli kw'owobh ẹwọr k'ogbera kwẹ, om-okkeri k'eden da ojora ọsẹ-ẹ okhuri ẹkkọbhi ch'Echekhi ch'Ibinọkpaabyi. Mada ojinọng nwa odimi k'obhon, obiro ọgbaak anọng odik kw'ọkk'ọtta, anọng biphyir k'obhon abhom ẹmọng k'ẹrọng.
\p 
\v 14 Ẹli ọbhaang ẹmọng nduma, ọn-ọbọbh bi, “Iyọkhi nnuma iyini yan o?”
\p Ojinọng nwa otzini mmo otzor Ẹli,
\v 15 kw'on-ode cho arọbh anna obhiri chi obhiri attaan, kw'on-obiro ọkpa chen mebubuni.
\v 16 Ojinọng nwa ọgbaak Ẹli bi, “Yina kwa kaam mfon k'egbong-dam ma e. Kaam nnọbhi kẹ mayina nwa e.”
\p Ẹli ọn-ọbọbh bi, “Nnwa kwaam, bọng odik wọ otto o?”
\p 
\v 17 Ojinọng nwa kw'otzim ẹkkaabha nda okwu, obhina bi, “Anọng p'Israẹl arọbhi k'itzitzikha s'aPhilistiya, anọng akk'man abira apa k'ọhaabh. Va pọ afa p'ijinọng, Hophni ttara Phinẹhas akk'abira apa. APhilistiya akk'Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi abir abọkha atzima afona.”
\p 
\v 18 Mada ojinọng nwa ọgbaakhi odik opyi ẹmma k'Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi, Ẹli obikhi k'ogbera kw'owobh ẹwọr k'ẹbhabhaanga ch'ẹbaakhamma, otto nnam-annam, ọphyakhi ekhokhora, ope, da ọkk'ọtzama, obiro ọdọhbh-ọdọhbh ọttara. Wa kẹ okk'Israẹl ọdabha, ka cho arọbh afa.
\p 
\v 19 Wa kwanọng kwa nnwa kwẹ, Phinẹhas otzim ibhọr s'on-okkekkeni ọmaan. Mada kwanọng nwa ọbhaang bi, bẹ akk'Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi abọkha atzima afona, ọmaana bi otte kw'odim, ttara odim kwẹ akk'apa, ọmaan ọsẹ-ẹ k'ẹfa, ọmaan. Yina, wa ọmaan ọnẹ-ẹ ẹfa.
\v 20 Mada ọm-ọtzọr ebodik, panọng p'akker-ẹ ọmaan aben-ẹ bi, “Tte ojora oning-ọ osi, kkeri akk'ojinọng amaana.” Yina, bẹ ẹmọng kosi, bẹ itzọhng kobiro oyonga.
\p 
\v 21 Wa okpe nnwa nwa Ikabọd, oben bi, “Abarada p'Israẹl akk'adimi” okhuri Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi cha bẹ abọk atzima afona, ọmaana obo kw'otte kw'odim, ttara odim kwẹ.
\v 22 Oben bi, “Abarada p'Israẹl akk'adimi, okhuri bi bẹ akk'Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi abọkha atzima afona.”
\c 5
\s1 Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi k'ibhon sa Philistiya
\p 
\v 1 Mada aPhilistiya akk'Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi abọkha atzima afona, bẹ atzọkha chẹ k'Ẹbẹneza, atzima achina k'Ashdọd.
\v 2 Wa bẹ atzini chẹ atza ahok k'ọkhapa kwa bẹ ahokhi ọkha f'okpen Dagọn, bẹ ahok Ẹkkọhbhi nda, ẹbaanga ọgbatza kwa Dagọn.
\v 3 Mada anọng p'Ashdọd an-aphyọbh k'ekpekpebha, bẹ an-are bi, Dagọn ọkk'ọtta okhubha itzitzikha k'irerek, m'itzitzikha s'Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi, bẹ atzini Dagọn ahok k'ibe sẹ.
\v 4 Yina, mada ewu ehobh, bẹ aphyọbha atza are bi, Dagọn okk'obiro ọtta okhubha itzitzikha k'irerek m'ibhokhi, k'itzitzikha s'Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi, eho ẹkk'ẹkpaara, mbọhk nkk'mbiri mphyakhi, nyima m'ereremachi ch'ẹhọhmma, ọkkafor kẹ-khẹ on-omunga.
\v 5 Kẹ wọ osi maa apyiri k'ewu cha mayina, k'obhon kw'Ashdọd, ode afọhnẹja pa Dagọn o, obiro ode anọng adọdọkh o, ọnọng kw'odimi k'ọkhapa kwa Dagọn kw'ọbari ereremachi ch'ẹhọhmma kode.
\p 
\v 6 Wa Ọvaar Ibinọkpaabyi ọnang anọng p'Ashdọd, ọmmamma kw'ideden, obiro ọnang bẹ ettuma, osi ikhọmanna s'abirakpo imma anọng p'Ashdọd.
\v 7 Mada anọng p'Ashdọd are idik s'itto ikhebha bẹ, bẹ aben bi, “Ẹkkọhbhi ch'Echekhi ch'ọkha f'Israẹl, kẹkhaambi ewobha ma ttara man, okhuri bi, chẹ ekk'maman, ọmaana Dagọn kw'ode ọkha faman ọmmamma ẹnanga.”
\v 8 Mẹ wọ, bẹ ayeri adabhi p'ẹkhọma cha Philistiya biphyir atzobha, abọbh bẹ bi, “Mosi yan ọmaana Ẹkkọhbhi nda ch'Echekhi ch'ọkha f'anọng p'Israẹl o?”
\p Wa bẹ abhina bi, “Bọng dini Ẹkkọhbhi nda ch'Echekhi ch'ọkha f'Israẹl atzima achina k'obhon kwa Gat.” Mẹ wọ e, bẹ atzini chẹ atzima achina ka Gat.
\p 
\v 9 Yina, mada bẹ akk'chẹ atzini, ettem ebhem Ọvaar Ibinọkpaabyi, okhe anọng p'obhon nwuma k'opoma f'ideden. Osi ọkhọhmmana f'abirakpo ọmma vava, ọmaana adeden-nọng.
\v 10 Mẹ wọ, bẹ atzima Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi achina k'Ẹkrọn.
\p Mada bẹ akk'Ẹkkọhbhi nda ch'Echekhi ch'Ibinọkpaabyi atzima achina k'Ẹkrọn, anọng p'Ẹkrọn abhom k'ẹrọng aben bi, “Bẹ akk'Ẹkkọhbhi ch'Echekhi ch'ọkha f'Israẹl atzima akwu ka bi, chẹ ekwu efhu man, ọmaana anọng paman e.”
\p 
\v 11 Wa bẹ ayeri adabhi pa Philistiya biphyir aben bẹ bi, “Tte Ẹkkọhbhi ch'Echekhi ch'ọkha f'anọng p'Israẹl ebina ka man k'obhon, ẹkpa nnam k'obhon kw'anọng p'akhaam chẹ e, ifha eningi man, ọmaana anọng paman efhu e.” Da ojora f'obo ọkk'ọnyaami k'ebhonmọr biphyir. Wa Ibinọkpaabyi ọnangi anọng mba ọmmamma kw'ideden.
\v 12 Anọng p'iwa ani ope-ope ape, an-abira awobha k'ọkhọkhọhmi kw'abirakpo, ebhonmọr biphyir en-ewobha k'obhoma kw'ogori maa opyiri k'ẹrọng.
\c 6
\s1 Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi ẹkpa nnam k'Israẹl
\p 
\v 1 Mada Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi ẹkk'aphe azenamfa ewobha k'okhubha kw'abaPhilistiya,
\v 2 aPhilistiya ayeri afọhnẹja, ọmaana abọhnga-nọng pabẹ, abọbh bi, “Mbọng vọ fa mosi ọmaana Ẹkkọhbhi nda ch'Echekhi ch'Ọvaar Ibinọkpaabyi o? Bọng gbaak man eden cha morenga ọtzọhm chẹ ẹkpa nnam kẹ da efon.”
\p 
\v 3 Bẹ abhina bi, “Bọng Ẹkkọhbhi nda ch'Echekhi ch'ọkha f'Israẹl mbọhk-mbọhk kàtzọhm ẹkpa nnam o, k'eden kpenamkpen, bọng dọhm chẹ, ttara ẹnanga ch'oponga-phyibha kwa bọng arim anọng p'Israẹl abẹ. Mẹ wọ, bọng án-abina k'ikhọmmana, bọng abira áronga odik kw'osi yina om-ochina ororo ọnang bọng ettuma.”
\p 
\v 4 Anọng pa Philistiya an-abọbh bi, “Bọng ẹnanga-dem ch'oponga-pyibha cha mọfha otzima ochen-ẹ o?”
\p Bẹ abhina bi, “Abirakpo azen pa gol, akhetze azen pa gol, atzor k'obhik kw'adabhi pa Philistiya, okhuri bi, itzama nna rani rọ itto ikhebha bọng, ttara adabhi pabọng.
\v 5 Bọng si akheri p'abirakpo, ọmaana akheri p'akhetze p'am-akhibhi irerek nna, bọng abira anang ọkha f'Israẹl ikpokpobha. Asimẹ, fẹ ótte bọng ọbọhk otte, ọmaana akha pabọng, ttara irerek sabọng.
\v 6 Okhuri yan kwa bọng abari nttem mach'iwa Phero ọmaana anọng p'Ijip, abar o? Mada iwa Ibinọkpaabyi ọnangi bẹ ihem s'ideden, wa bẹ anọng p'Israẹl kàbeni bẹ abina orenga kwabẹ o?
\p 
\v 7 “Mẹ wọ, bọng ogbe kàkhibhi, bọng do ọkpaar ọbhakwẹ kwa nden mmindọr, ttara abhaam afa p'atzima arọkhi va ọrọk, pa bẹ ani ọyak atzim am-akha. Bọng kẹ abhaam mba afa k'ọkpaar kwa nden mmindọr, yina kọ tzima va p'abhaam mba akpa nnam k'ikwuri sabẹ.
\v 8 Mẹ wọ, tzini Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi anana k'ọkpaar nwa, abira atzokha ekpo pya gol py'atzọhm mach'ẹnanga ch'oponga-pyibha achen-ẹ, akhe k'Ẹkkọhbhi ahok chẹ abaanga Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi. Bọng atzọhm chẹ efona,
\v 9 yina, bọng kẹ chẹ otzum. Idikha evur echina kẹ da efon, k'okhubha kwa Bẹt-Shẹmẹsh, mẹ wọ oyini bi, Ọvaar Ibinọkpaabyi kw'anọng p'Israẹl, wọ ọtzọhmi itzama-deden nna ochena man. Yina, idikha eni k'okhubha nwa echin, móronga bi, ọbọhk kwẹ mẹ kode, kw'oyini bi, kwẹ okwu bi ode mando.
\p 
\v 10 Mẹ wọ e, ajinọng mba asi mando. Wa bẹ atzọkha abhaam afa agbana k'ọkpaar nwa, abira atzọkha va p'abhaam mba agbak k'ikwuri.
\v 11 Bẹ ayikha Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi k'ọkpaar nwa, ọmaana ẹkkọhbhi cha bẹ akhe akhetze pa gol, ttara adem p'abirakpo.
\v 12 Mẹ wọ, abhaam mba arenga \it bi gbeng\it* atzor k'eden ch'echin ka Bẹt-Shẹmẹsh, bẹ am-amẹmma k'eden, bẹ kàtten achina k'odimbọhk, bẹ kabira attena achina ka kwabọhk. Wa adabhi pa Philistiya atzọn bẹ abẹ maa apyiri k'enem cha Bẹt-Shẹmẹsh.
\p 
\v 13 M'ogbe nwa wa anọng pa Bẹt-Shẹmẹsh am-asi ipha s'awit k'ẹttẹri. Mada bẹ atzini chen akkeri k'ororo, bẹ are Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi, ettem ẹdaam bẹ k'ọttọhk fa bẹ are.
\v 14 Mada ọkpaar nwa okwu opyiri k'owoni kwa Joshua kw'ofon Bẹt-Shẹmẹsh, ophikha mẹ ọbaanga itzakpa s'ideden. Anọng mba akpọk ọkpaar nwa atzima akhọma ekpon, bẹ abira atzọkha abhaam mba atzima asi ẹjafọhni ẹkwọmichẹ anang Ọvaar Ibinọkpaabyi.
\v 15 AbaLẹvi atzini Ẹkkọhbhi nda ch'Echekhi ch'Ọvaar Ibinọkpaabyi, ọmaana ẹkkọhbhi ch'ekpo pya gol eyik, atzọkha anana m'itzakpa nna s'ideden. M'ewu nduma, anọng pa Bẹt-Shẹmẹsh asi nnanga nkwọmisẹ, abira asi njafọhni, anang Ọvaar Ibinọkpaabyi.
\v 16 Mẹ ewu nduma dani, adabhi mba azen p'ibhon sa Philistiya are idik nna biphyir, yina bẹ an-afon abhana k'Ẹkrọn.
\p 
\v 17 Ma wọ ode abirakpo pa gol p'iwa aPhilistiya atzọhmi anang Ọvaar Ibinọkpaabyi mach'ẹnanga ch'oponga-pyibha. Wa obhon kpenamkpen kw'ode Ashdọd, ọmaana Gaza, ọmaana Ashkẹlọn, ọmaana Gat, ttara Ẹkrọn otzim ẹnanga chẹ.
\v 18 Wa obhik kw'akhetze mba pa gol otzori k'obhik kw'adabhi mba azen, p'idibhon s'aPhilistiya s'igaang-ọgaangi, ttara abhobhona pabẹ p'an-agaangi. Itzakpa nna s'ideden s'iwa bẹ anan Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi, itzimi iwobh k'owoni kwa Joshua kw'ofon Bẹt-Shẹmẹsh, mach'owobhore kw'odik kw'iwa otto mẹ, maa apyiri ma.
\p 
\v 19 Yina, Ibinọkpaabyi osi ajinọng pa Bẹt-Shẹmẹsh anọng arọbh attaan obhiri jobh ape, okhuri da iwa bẹ akkeri k'ẹtzaanga kw'Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi. Wa anọng mba awobha ka nkwu-osisi, okhuri ettuma ch'Ọvaar Ibinọkpaabyi okk'bẹ ọnanga.
\v 20 Mẹ wọ e, anọng pa Bẹt-Shẹmẹsh an-abọbh bi, “Anyi wọ ofha obe Ọvaar Ibinọkpaabyi k'itzitzikha, Ibinọkpaabyi nwa kw'awurada o? Anyi wọ kw'am-ofha ochena Ẹkkọhbhi nda ch'Echekh o?”
\p 
\v 21 Mẹ wọ, wa bẹ atzọhm anọng ka Kiriyat-Jẹrim, aben bi, “Anọng pa Philistiya akk'Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi arikha e. Bọng hakha akwu atzima chẹ avura ka bọng k'ibe e.”
\c 7
\p 
\v 1 Mẹ wọ, ajinọng pa Kiriyat-Jẹrim atza atzọkha Ẹkkọhbhi ch'Echekhi ch'Ọvaar Ibinọkpaabyi, atzima avura achina k'egbegbeho kẹ da ọhọhm kw'Abinadab owobh. Wa bẹ atzekha Ẹleyaza kw'ode nnwa kw'ijinọng kw'Abinadab, bẹ anan-ẹ ọbọhk k'eho bi, okkeri Ẹkkọhbhi nda ch'Echekhi ch'Ọvaar Ibinọkpaabyi.
\s1 Samwẹl otzima anọng p'Israẹl eden
\p 
\v 2 Wa Ẹkkọhbhi nda ch'Echekhi ch'Ọvaar Ibinọkpaabyi ewobh ka Kiriyat-Jẹrim k'ogbe, kw'obhir-obhir. Biphyir-phyir wa ewobh cho ẹrọbh. Wa anọng p'Israẹl biphyir an-awobha ka nkwu-osisi, bẹ aror Ọvaar Ibinọkpaabyi.
\v 3 Wa Samwẹl oben anọng p'Israẹl biphyir bi, “Idikha bọng abeni bi akpa nnam atzor Ọvaar Ibinọkpaabyi, ttara nttem sabọng biphyir, bọng nọbha for sabọng k'akha p'idibhon idọdọk, ọmaana k'agbatza p'Ashtọrẹt, bọng abira atte for sabọng ọbọhk anang Ọvaar Ibinọkpaabyi, abira akpobha kẹ-khẹ. Kẹ ọ́kkaana bọng ọ́kkaana k'ihem s'anọng pa Philistiya am-anang bọng.”
\v 4 Mẹ wọ e, anọng p'Israẹl atte akha pa Baal ọmaana agbatza p'Ashtọrẹt ọbọhk, an-akpobha Ọvaar Ibinọkpaabyi kẹ-khẹ.
\p 
\v 5 Mẹ wọ, Samwẹl oben bi, “Bọng dobha anọng p'Israẹl biphyir ka Mizpa, kaam ńzi njọhm nnang Ọvaar Ibinọkpaabyi ka nho sabọng.”
\v 6 Mada bẹ akk'atzobha ka Mizpa, bẹ atzọr asi abyengi m'itzitzikha s'Ọvaar Ibinọkpaabyi. Mẹ ewu nduma bẹ atzim ọchattọhk, bẹ abira ajaakhi itzama sabẹ aben bi, “Maman okk'ẹkhọngkwuri ọsa ọnang Ọvaar Ibinọkpaabyi.” Wa Samwẹl ode ọttọhn-aponga kw'anọng p'Israẹl ka Mizpa.
\p 
\v 7 Mada aPhilistiya abhaang bi, anọng p'Israẹl akk'atzobha ka Mizpa, adabhi pa Philistiya adabh egbong bi, bẹ atza arima bẹ abẹ. Mada anọng p'Israẹl abhaang odik nwa, ojora bẹ, okhuri aPhilistiya.
\v 8 Wa anọng p'Israẹl an-aben Samwẹl bi, “Kọ njọhm kàkwọhbha ozizi anang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwaman ka nho saman, ifha kẹ ọkkaana ọrọbha man ka mbọhk s'aPhilistiya.”
\v 9 Mẹ wọ e, wa Samwẹl ọtzọkha orukhimaan-nwa kw'ọtzima ọjaabh ẹba, ọtzọkh-ẹ biphyir ọnang Ọvaar Ibinọkpaabyi mach'ẹnanga ẹkwọmichẹ. Wa ozi njọhm ọnang Ọvaar Ibinọkpaabyi, ka nho s'anọng p'Israẹl, Ọvaar Ibinọkpaabyi ọbhaang-ẹ.
\p 
\v 10 Mada Samwẹl om-ọfọhni ẹja nda ch'ẹnanga ẹkwọmichẹ, aPhilistiya arenga amyi anọng p'Israẹl ifha bẹ arima egbong ttara bẹ. Yina, Ọvaar Ibinọkpaabyi ọtzọhm ẹbhaangkpon etto-etzum m'ewu nduma, ọttaanga ọnang aPhilistiya, on-okhe bẹ k'opoma maa, bẹ arọbh k'itzitzikha s'anọng p'Israẹl afona.
\v 11 Mẹ wọ e, anọng p'Israẹl arọbh ayin ka Mizpa, bẹ akhubh aPhilistiya, abira afhu bẹ k'ọkkadeden, maa bẹ apyiri k'irekh-irek kwa Bẹt-Kar.
\p 
\v 12 Wa Samwẹl ọtzini ọtza ofhu ebebe, k'ottem kwa Mizpa ọmaana Shen. Oyeri ọtza nwa Ẹbẹneza, oben bi, “Ọvaar Ibinọkpaabyi ọkk'man ọkkaana, ma apyiri ma.”
\v 13 Mẹ wọ e, wa anọng p'Israẹl akhema aPhilistiya. Wa abaPhilistiya k'ẹkhọma ch'Israẹl dọk kamanwa.
\p K'akpen pa Samwẹl biphyir, wa Ọvaar Ibinọkpaabyi ọttaang ọnang aPhilistiya.
\v 14 Ibhon s'iwa aPhilistiya akk'atzọkha ttẹwọr k'Ẹkrọn maa apyiri Gat, anọng p'Israẹl abira akpa nnam atzọkha sẹ biphyir. Anọng p'Israẹl abira akkaana ayokh-ẹbaanga pabẹ, ka mbọhk s'aPhilistiya. Wa anọng p'Israẹl, ttara anọng p'Amọr an-aruk k'odidiri.
\p 
\v 15 Wa Samwẹl ọdabhi Israẹl k'akpen pẹ biphyir.
\v 16 Cho kpenamkpen, om-orenga k'ibhon k'ibhon, ttẹwọr ka Bẹtẹl, akwu apyiri ka Gilgal, maa atza apyiri Mizpa, ọm-ọttọhna aponga p'anọng p'Israẹl m'obe mvuma biphyir.
\v 17 Yina, wa om-okhuna ka Rama, kẹ da osi oruk kwẹ, om-obiro ọttọhna aponga p'anọng p'Israẹl mẹ. Mẹ kw'iwa obiro osi ijafọhnibe ọnang Ọvaar Ibinọkpaabyi.
\c 8
\s1 Anọng p'Israẹl arori ọvaarnọng
\p 
\v 1 Mada Samwẹl ọkk'ọtzama, ọrọbha va pẹ p'ijinọng bi bẹ ade akpaar-aponga p'Israẹl.
\v 2 Ocheden-nwa kwẹ wa okpen Joẹl, ottong afa okpena Abija, wa bẹ ade akpaar-aponga ka Beershẹba.
\v 3 Yina, wa va mba pẹ, kẹ ka ndọkhi katzori. Wa bẹ asi afhọra, bẹ am-abira achi ngwu, atzima abhakhi aponga ewobha.
\p 
\v 4 Mẹ wọ, adeden-nọng p'Israẹl biphyir ayeri ayok bẹ atzobha, bẹ afona atza akhebha Samwẹl ka Rama.
\v 5 Bẹ aben-ẹ bi, “Kọ akk'atzama, yina, va pọ p'ijinọng, kọ ka ndọkhi katzori. Mẹ wọ, nang man ọvaarnọng kw'ọ́dabh man, mach'idibhon idọdọk biphyir ikhaam.”
\p 
\v 6 Yina, mada bẹ abeni bi, “Kọ nang man ọvaarnọng kw'ọttọhna aponga paman.” Wa odik nwa obhem Samwẹl ettem. Mẹ wọ, ozi njọhm ọnang Ọvaar Ibinọkpaabyi.
\v 7 Ọvaar Ibinọkpaabyi oben Samwẹl bi, “Yonga itzọhng anang anọng mba k'odik kpenamkpen kwa bẹ am-agbaak anang-ọ. Kọ rang kwa bẹ abhumi e, bẹ abhumi kaam mach'ọvaarnọng kwabẹ e.
\v 8 Ttẹwọr kẹ da ndim bẹ mbina k'Ijip, ma apyiri ma, bẹ am-akpa nnam abọr-m, bẹ am-abira akpobha akha, mando kwa bẹ am-asọ-ọ mẹ e.
\v 9 Kọ yonga itzọhng anang bẹ, yina, tzọr bẹ itzọhng. Tte bẹ aronga odik dema kw'ọvaarnọng kw'ọ́daabh bẹ ósi bẹ o.”
\p 
\v 10 Wa Samwẹl ọtzọkha idik nna biphyir s'Ọvaar Ibinọkpaabyi ọgbaakhi, ọgbaak anọng mba p'am-aror ọvaarnọng abọbh-ẹ.
\v 11 Oben bẹ bi, “Ma wọ ode odik kw'ọvaarnọng kw'ọ́dabh bọng ósi, kẹ ọ́tzọkha va pabọng p'ijinọng, bẹ an-ade anọng p'abaabh-ẹ p'áyaar akpaar pẹ pa nnyanyaang mmindọr, ọmaana ayari-nnyanyaang. Bẹ án-arọbh k'itzitzikha s'akpaar mba.
\v 12 Ósi ayok bani adenho p'agbong-nọng nnọhna nnọhna, bani adenho p'agbong-nọng arọbh afa obhiri jobh. Ótzekha ayok bani bẹ ade anọng p'áyaabha ekpo pyẹ, bẹ abira asi ipha sẹ. Ayongi mẹ, kẹ ótzekha ayok bani bẹ ade atzetzekha p'am-aduk egbongkpo, ọmaana ẹtzọhmkpo py'akpaar pẹ.
\v 13 Kẹ ọ́tzọkha va pabọng p'ipanọng, ifha bẹ am-asi ana p'adaami eruk anang-ẹ, abira awọhn ọchattọhk, abira asi brẹd pẹ.
\v 14 Kẹ ọ́bọkha bọng iwoni ọkkakka sabọng ọna, ọmaana iwoni sa grep ttara s'oliv, ọ́tzọkha ọnang akhaan-nọng pẹ akkeri.
\v 15 Kẹ ọ́tzọkha okhung wani k'akhung jobh p'abọkpa pabọng, ọmaana ka grep pabọng, ọ́tzọkha ọnang akhaan-nọng pẹ, ttara atzọhmnọng pẹ.
\v 16 Kẹ ọ́tzọkha atzọhmnọng pabọng p'ijinọng, ọmaana p'ipanọng, ọmaana abhaam pabọng akkakka, ttara nnyanyaang sabọng biphyir ótzima osi itzọhm sẹ.
\v 17 Kẹ ọ́tzọhka ibe rani k'obe jobh k'arukhimaan pabọng, bọbọng ọkhaam ma for sabọng ábira ade abira pẹ.
\v 18 Mada ewu nduma ebenga, bọng ábhom áror ẹkkaana ka mbọhk s'ọvaarnọng kwa bọng akk'atzekha, yina, Ọvaar Ibinọkpaabyi bọng ẹmọng kósi.”
\p 
\v 19 Kaambi mẹ wọ, anọng mba bẹ Samwẹl itzọhng kayong, be an-aben bi, “Man kokher! Morori ọvaarnọng kw'ọ́daabh man e.
\v 20 Mẹ wọ kwa móde mach'idibhon idọdọk biphyir, da mọ́khaama ọvaarnọng kw'ọ́dabh man, kw'óm-obiro ochi man eden, óbiro órima mgbong saman.”
\p 
\v 21 Mada Samwẹl ọbhaang idik nna biphyir s'anọng mba agbaakhi, obiro ọtzọkha sẹ ọgbaak Ọvaar Ibinọkpaabyi.
\v 22 Mẹ wọ e, Ọvaar Ibinọkpaabyi obhina bi, “Kọ khera macha bẹ abeni, anang bẹ ọvaarnọng.”
\p Mẹ wọ, wa Samwẹl oben ajinọng p'Israẹl bi, “Tte ọnọng-ọnọng ọrọhng ọbhana ka kẹ k'obhon.”
\c 9
\s1 Saul otza okhebha Samwẹl
\p 
\v 1 Wa ọkhaam ojinọng wani kw'ọtza che k'ẹfa ch'ọkhaam, kw'ofon k'efonamma cha Bẹnjamin, kw'okpen Kish. Kẹ wa ode nnwa kw'Abiyẹl, kw'ode nnwa kwa Zẹrọ, kw'ode nnwa kw'ijinọng kwa Bekorat, kw'ode nnwa kw'ijinọng kw'Aphiya kw'ofon Bẹnjamin.
\v 2 Kẹ wa obhoni nnwa kw'okpen Saul, kw'ojibhi odikkobh, ọnọng kw'obeng-ẹ abẹ k'ebhonmọr ch'Israẹl kode, obiro ofu ka for \it bi gbuk\it* ogori ebe ọyọhnga anọng biphyir.
\p 
\v 3 Wa nnyanyaang sa Kish kw'ode otte kwa Saul nkwu ndimi. Mẹ wọ, Kish oben nnwa kwẹ Saul bi, “Tzọkha ọtzọhmnọng wani, atzima atza aror nnyanyaang nna.”
\v 4 Mẹ wọ, orenga ka mgbegbeho s'Ephraim, ọmaana k'okhubha kwa Shalisha, yina, bẹ nnyanyaang nna kàre. Bẹ an-achina k'okhubha kwa Shaalim, yina, bẹ nnyanyaang nna kàre. Mẹ wọ, on-orenga k'okhubha kwa Bẹnjamin, yina, bẹ nnyanyaang nna kabira are.
\p 
\v 5 Mada bẹ apyiri k'ẹkhọma cha Zuph, Saul oben ọtzọhmnọng kwẹ kwa bẹ atzọni bi, “Tte mọkpa nnam, oni mando ode, otte kwaam ọn-ọrọbha ochibhi kwẹ ka nnyanyaang, on-ochibhi maman.”
\p 
\v 6 Yina, ọtzọhmnọng nwa obhina bi, “Kker e, ọkhaam ọsi-ẹjaakhi wani kw'Ibinọkpaabyi m'obhon nwa e. Kẹ ode ọnọng kw'anọng am-anang ikpokpobha s'ideden, ọmaana bi, odik kpenamkpen kw'ọgbaakhi om-ode odik ọkkọkka. Tte mochina kẹ, asimẹ kẹ ọfha ọgbaak man ọgbaak eden cha morenga.”
\p 
\v 7 Mẹ wọ, Saul obhina ọtzọhmnọng kwẹ bi, “Idikha mọtza kẹ, mbọng fa mọ́nang ojinọng nwa o? Ọchattọhk fa motzim ọkk'ọha. Mọttọhk kọ̀khaam fa mọtza ọnang ọsi-ẹjaakhi kw'Ibinọkpaabyi e. Mbọng fa mọkhaam o?”
\p 
\v 8 Ọtzọhmnọng obiro obhin-ẹ bi, “Kker e, kaam ngaam ishẹkẹl-bhaakha sa silva ma sa ńnang ọtzọhmnọng kw'Ibinọkpaabyi, ifha ọgbaak man eden cha morenga.
\v 9 Wa k'Israẹl, idikha ọnọng ofon bi, ọtza ọdọn Ibinọkpaabyi, om-oben bi, “Tte mochina kẹnya orekha-chen e,” okhuri bi, ọsi-ẹjaakhi kwa mayina bẹ am-ayer-ẹ orekha-chen.
\p 
\v 10 Mẹ wọ, Saul obhina ọtzọhmnọng kwẹ bi, “Kwẹ ojibhi khẹ. Tte mofona.” Mẹ wọ, bẹ abina orenga achina k'obhon nwuma kw'ọsẹjaakhi kw'Ibinọkpaabyi owobh.
\p 
\v 11 Mada bẹ am-avura egbegbeho achina k'obhon nwa, bẹ akhebha aminava bani p'akwu bi, akwu atzọr asi k'esipe, bẹ abọbh bẹ bi, “Orekha-chen owobh ma o?”
\p 
\v 12 Aminava mba abhina bi, “Oo o, kẹ owobh k'ororo, bọng dini mmo, mayina kwa kẹ opyiri ka man k'obhon e, okhuri bi, anọng mba akhaam ẹja cha bẹ afọhni, k'ijafọhnibe e.
\v 13 Abọng adimi m'obhon \it bi kpaaar\it*, bọng árẹ-ẹ ore yina ochina k'ijafọhnibe bi, otza ochi ọchattọhk. Anọng ọchattọhk káchi maa kẹ opyiri, okhuri bi, kẹ ọkhaambi, ozi njọhm m'ẹja nda. Okyekyer njọhm, yina anọng pa bẹ abheri án-attẹwọr áchi ọchattọhk. Bọng china kẹ madeden, bọng afha akhebh-ẹ okhebha m'ogbe nwa.”
\p 
\v 14 Mẹ wọ, bẹ afona achina k'obhon ebira, mada bẹ arami odidim m'obhon, bẹ are Samwẹl, da om-orenga otzor bẹ ka for bi, ochina k'ijafọhnibe.
\p 
\v 15 Ewu ch'ẹkwọbh mẹ, yina Saul okwu, Ọvaar Ibinọkpaabyi ọkk'ẹjaakhi cha odik nwa ọsa ọnang Samwẹl bi,
\v 16 “Ophyini m'ogbe-dema nwa, kaam ńdọhm ojinọng wani kw'ofon k'ẹkhọma cha Bẹnjamin ńchen-ọ. Kọ ábyeng-ẹ ana k'eho bi ode ọdabhi kw'anọng paam p'Israẹl; kẹ wọ ọ́rọbha anọng paam ka mbọhk s'ihem s'aPhilistiya. Kaam nkk'anọng paam nkwo nna e, nkk'ẹmọng chabẹ cha bẹ abhomi, mbiri mmaanga.”
\p 
\v 17 Mada Samwẹl otzini chen ore Saul, Ọvaar Ibinọkpaabyi oben-ẹ bi, “Ojinọng nwa kwa mgbaakh-ọ odik okhuri wọ ma e; kẹ wọ ọ́dabh anọng paam.”
\p 
\v 18 Mẹ wọ, Saul orenga okhebha Samwẹl k'ẹnya ẹbaakhamma ọbọbh bi, “Tzotzo o tzim-m, ibe s'ọhọhm kw'orekha-chen owobh.”
\p 
\v 19 Samwẹl obhina Saul bi, “Kaam wọ nde orekha-chen nwuma e. Kọ chi-m eden avura achina k'ijafọhnibe, kkeri kọ áchi ọchattọhk ttar-m mayina. k'ekpebha, kaam ḿgbaakh-ọ odik kpenamkpen kw'ọyakh-ọ atzim k'ettem, ḿbiri ńttọ-ọ ọbọhk afona.
\v 20 Onode nnyanyaang sa ndim-ọ k'iwu ittaan s'ikk'ikwọbha, for sọ atzim kayak, kkeri bẹ akk'sẹ ara e. Nduma s'anọng p'Israẹl biphyir anang, ngaam kọ, ọmaana efonamma ch'atte e.”
\p 
\v 21 Mẹ wọ, Saul obhina bi, “Kaam mfon k'efonamma cha Bẹnjamin, ch'ẹkhar-ọtzaam k'Israẹl, ẹnọmma chaam arang ẹkhar ọtzam ka nnọmma s'efonamma cha Bẹnjamin o? On-orenga yan kọ agbaakh-m odik dema nwa o?”
\p 
\v 22 Mẹ wọ e, Samwẹl otzima Saul, ọmaana ọtzọhmnọng kwẹ bẹ adim k'ọhọhm, ohok bẹ ẹwọr k'ibe s'ibari ọtzam iyọhnga s'anọng pa bẹ abheri. Wa anọng pa awobh mẹ apyiri anọng ẹrọbh obhiri jobh.
\v 23 Samwẹl oben ọnọng kw'ọwọni ọchattọhk f'ewobha nda bi, “Tzima itzengbokha nna s'ira nnang-ọ akwu, nna s'ira mben-ọ bi, tte ahok ngọmi.”
\p 
\v 24 Mẹ wọ, ọwọn-ọchattọhk nwa ọtza ọtzọkha ọtzaak kw'etzen nda, ọmaana ettonga-kpo py'ẹttar mẹ, obera Saul m'itzitzikha. Samwẹl oben bi, “Ma wọ ode ọttọhk fa bẹ akk'ọ ahokha. Chi, okhuri bi, bẹ areng kọ abẹ ahok fẹ, ttẹwọr m'ogbe kwa mbeni bi, ‘Kaam nkk'anọng ẹrọm nkkaabha.’ ” Mẹ wọ, m'ewu nduma, Saul ochi ọchattọhk ttara Samwẹl.
\p 
\v 25 Mada bẹ afon k'ijafọhnibe am-ahakha k'obhon, Samwẹl ọmaana Saul agbaak atzim ttara ayok k'ebir-ebir kw'ọhọhm, kẹ da Saul oyim.
\v 26 Mada bẹ aphyọbh m'owuhobha, Samwẹl oyeri Saul k'ebir-ebir kw'ọhọhm, oben-ẹ bi, “Kọ do for, ifha ńdọhm-ọ akpa nnam abhana.” Saul odo for biphyir, kẹ ọmaana Samwẹl atzọn ayin k'iyaan.
\v 27 Mada bẹ am-arenga abanga enem ch'obhon, Samwẹl oben Saul bi, “Ben ọtzọhmnọng nwa ochi man eden k'ororo.” Ọtzọhmnọng e ọkwọbha, Samwẹl obiro oben bi, “Yina, kọ wobha ma \it bi kọọbh\it*, ifha mgbaakh-ọ ẹkkaabha ch'efon k'Ibinọkpaabyi.”
\c 10
\s1 Samwẹl obyengi Saul ana k'eho
\p 
\v 1 Mẹ wọ, Samwẹl ọtzọkha ogbere kw'ana obyengi Saul ana k'eho, ọbaakh-ẹ oben bi, “Ọvaar Ibinọkpaabyi ọkk'ọ ana obengyi k'eho bi, ádabh anọng pẹ p'Israẹl p'okhokhi ettem.
\v 2 Mada mayina atte-m ọbọhk abhana, kọ áttema ajinọng afa abẹ kẹ abaanga ẹpẹkhubh cha Rachẹl, ka Zẹlza k'enem cha Bẹnjamin. Bẹ ágbaakh-ọ bi, bẹ akk'nyanyaang sa bọng am-aror ara e. Manya, atte odik kw'okhuri sẹ dọk kochibh e, ọn-am-ochibhi ko e. Kẹ ọn-am-ọbọbh bi, ‘Manya kaam ńsi yan okhuri nnwa kwaam o?’ ”
\p 
\v 3 “Mẹ wọ, kọ árenga mẹ áchina kẹ da echi ch'ideden ebe, ka Tabọr. Ajinọng attaan p'atza bi atza akpobha Ibinọkpaabyi ka Bẹtẹl ákhebh-ọ mẹ. Oyok wani ótzima avu-va attaan, oyok wani obiro otzima brẹd-dukha attaan, nwonggo wani otzima ogbere kw'atzuk.
\v 4 Bẹ árim-ọ, bẹ abira ánang-ọ brẹd-dukha afa, kọ átzọkha bẹ.
\p 
\v 5 “Ayongi mẹ, kọ áchina Gibea kw'Ibinọkpaabyi, kẹ da ibhingabe s'aPhilistiya iwobh. Mada apyiri m'obhon, kọ áttema ẹkhaan ch'asi-ẹjaakhi p'afon k'ijafọhnibe, p'am-ákhir agaangaang, ọmaana mbin, ọmaana aphoropho, ttara agim-ogim, bẹ am-abira asi ẹjaakhi.
\v 6 Mẹ wọ, Egwugwuma ch'Ọvaar Ibinọkpaabyi ẹ́hakha k'ẹfa ewobha ẹmaan-ọ, kọ abira ási ẹjaakhi ttara bẹ. Kọ án-abhakhi ade ngọmi.
\v 7 Ngọhkha nna ngakhaam ẹjaakhi, kọ si odik kpenamkpen kw'akhaambi asi, kkeri Ibinọkpaabyi owobh ttar-ọ.
\p 
\v 8 “Kọ áchi-m eden achina ka Gilgal. K'odik ọkkakka, kaam ńhakha-ọhakha ńkwu ńgebh-ọ, ifha nsi ẹjafọhni cha nnanga-nkwọmisẹ, ọmaana cha nnanga s'odidiri. Yina, kọ akhaambi awobha atzik k'iwu izenamfa, matzẹmaa nkwu, ifha ńjaakhi ḿgbaakh-ọ odik kw'ási.”
\p 
\v 9 Mada Saul ọbhakhi nnam bi ofona oji Samwẹl, wa Ibinọkpaabyi ọn-ọbhakhi Saul ode ngọmi, ngọhkha nna biphyir ngaama ẹjaakhi m'ewu nduma.
\v 10 Mada bẹ apyiri ka Gibea, ẹkhaan ch'asi-ẹjaakhi akhẹbh-ẹ; ẹfa ch'Egwugwuma ch'Ibinọkpaabyi ẹnwa Saul, ọn-ọttara bẹ k'ẹjaakhi chabẹ, cha bẹ am-asi.
\v 11 Mada anọng biphyir p'akk'ẹ aronga, an-arẹ-ẹ da ọn-am-osi ẹjaakhi ttara asi-ẹjaakhi, bẹ abhakhi abọbh ayok bi, “Mbo o, bọng odik wọ okhebh nnwa kw'ijinọng kwa Kish ma o? Saul kẹ obiro ode ọnọng wani k'ottem kw'asi-ẹjaakh o?”
\p 
\v 12 Ojinọng wani kw'orukhi mẹ obiro obhina bi, “Bọng anọng bọ abhoni bẹ ẹ?” Mẹ wọ, kwẹ on-ode ẹtzama bi, “Ode bi Saul kẹ obiro ode ọsi-ẹjaakh o?”
\v 13 Mada Saul okyer ẹjaakhi nduma osisi, ofona ochina k'ijafọhnibẹ.
\p 
\v 14 Mẹ wọ, ọgbaanotte kw'otte kwa Saul ọbọbh kẹ Saul, ọmaana ọtzọhmnọng kwẹ bi, “Ira bọng atza man o?”
\p Obhina bi, “Mọtza nnyanyaang ororor e, yina, mada moni sẹ ofha ore, mon-ofona ochina ka Samwẹl.”
\p 
\v 15 Ọgbaanotte kw'otte oben-ẹ bi, “Kọ gbaak-m odik kwa Samwẹl ọgbaakh-ọ.”
\p 
\v 16 Saul obhina bi, “Kẹ ọgbaakhi man ọjaakh-ọjaakhi bi, bẹ akk'nnyanyaang ara e.” Yina, wa Saul ọgbaanotte kw'otte odik manda wani kw'okhuri ẹvaar, kwa Samwẹl ọkk'ẹ ọgbaakha kọ̀gbaakhi.
\s1 Saul ọdaabhi ẹvaar
\p 
\v 17 Mẹ wọ e, Samwẹl oyeri anọng p'Israẹl akwu k'itzitzkha s'Ọvaar Ibinọkpaabyi, ka Mizpa,
\v 18 ọgbaak bẹ bi, “Ọvaar Ibinọkpaabyi kw'anọng p'Israẹl, obeni bi, ‘Kaam wọ iwa ndim anọng p'Israẹl mbina k'Ijip, kaam wọ iwa mbiri nnọbha bọng ka mbọhk s'anọng p'Ijip, ọmaana ka mbọhk s'idibhon idọdọk biphyir, s'ihokhi bọng k'ihem.’
\v 19 Yina, mayina bọng akk'Ibinọkpaabyi kwabọng abhuma, kw'ọkkaan bọng k'idiktama kpenamkpen s'itto ikhebha bọng, ọmaana ọwọwọhngi kwabọng. Bọng akk'abira abena bi, ‘Man kokhera, nang man ọvaarnọng!’ Mẹ wọ, bọng yin Ọvaar Ibinọkpaabyi k'itzitzikha, ka mfonamma ttara ka nnọmma sabọng.”
\p 
\v 20 Mada Samwẹl otzim mfonamma s'Israẹl biphyir oyin ka, bẹ akwu abhari ose, otto k'efonamma cha Bẹnjamin.
\v 21 Mẹ wọ, oyeri efonamma cha Bẹnjamin eyin ka, k'ẹhọhmmọr k'ẹhọhmmọr, ose okwu otto k'ẹnọmma cha Matri. K'ẹkpongannam wa bẹ atzekha Saul, kw'ode nnwa kw'ijinọng kwa Kish, atzor k'ẹjaakhi ch'ose. Yina, mada bẹ aror-ẹ, bẹ kẹ kàre.
\v 22 Bẹ an-achina ororo abọbh Ọvaar Ibinọkpaabyi bi, “Ojinọng nwuma okk'ma opyir o?”
\p Ọvaar Ibinọkpaabyi obhina bẹ bi, “Oo o, kẹ okk'ochubha k'ibe sa bọng ahokhi ekpo pyabọng e.”
\p 
\v 23 Mẹ wọ, bẹ arọbh achina kẹ da ochubh, atza atzọkh-ẹ atzima ayin ka, mada otza obe k'ottem kw'ayok, wa ogori ebe ọyọhnga ayok biphyir.
\v 24 Samwẹl oben anọng mba biphyir bi, “Bọng akk'ojinọng ara kw'Ọvaar Ibinọkpaabyi okk'otzekha o? Ọnọng kw'ode mach'ẹ m'ottem kw'anọng mba biphyir kode.”
\p Mẹ wọ e, anọng mba an-akpẹbh bi, “Tte ọvaarnọng oruk akpen p'adum-eden.”
\p 
\v 25 Samwẹl e, okwu ọtzọkha ndori s'ẹvaar ọgbaak anọng mba. Ọkkẹr sẹ ka nnwẹr, ọtzọkha sẹ ohok m'itzitzikha s'Ọvaar Ibinọkpaabyi. Mẹ wọ, wa Samwẹl ọgbak ewobha nda, oben ọnọng-ọnọng ọbhana k'ọhọhm kwẹ.
\p 
\v 26 Wa Saul obiro ọbhana k'obhon kwẹ ka Gibea, ttara afanọng p'atzọn-ẹ abẹ p'Ibinọkpaabyi okk'nttem sabẹ ọda.
\v 27 Yina, akhọkhọra bani an-abọbh bi, “Yan wọ kw'ojinọng nwa ọfha ọkkaana man ka mbọhk s'attattaanga-nọng paman o?” Ofona mẹ, bẹ alukh-ẹ, bẹ kẹ ndumma kabira achena. Yina, wa Saul bẹ emọng kosi.
\c 11
\s1 Saul ọkkaan obhon kwa Jabesh
\p 
\v 1 Wa Nahash kw'ọdabhi ẹkhọma ch'Ammọn ofon ọtza ọkhọri obhon kwa Jabẹsh-Gilead okhe k'ottem bi, orima bẹ abẹ. Mẹ wọ, ajinọng pa Jabẹsh biphyir aben-ẹ bi, “Si echekhi ttara man, ifha maman ón-owobha k'irekh-irek kwọ.”
\p 
\v 2 Yina, Nahash kw'ofon Ammọn obhina bẹ bi, “Kaam ńsi echekhi ttara bọng, idikha bọng akher bi, nnọbha chen ch'odimbọhk ch'ọnọng kpenamkpen, ifha nge Israẹl biphyir ka mgbar.”
\p 
\v 3 Mẹ wọ, adenho pa Jabẹsh aben-ẹ bi, “Kọ nang man iwu izenamfa, ifha mọtzọhm akkaabh-ẹkkaabha agbaak anọng p'Israẹl makhọra, idikha ọnọng manda wani on-okwu bi, ọkkaana man, maman ón-otte for saman ọbọhk ọnang-ọ.”
\p 
\v 4 Mada akkaabh-ẹkkaabha mba apyiri Gibea, kw'ode obhon kwa Saul, bẹ atzọkha idik nna agbaak anọng. Anọng biphyir abhom abomọng k'ẹrọng.
\v 5 M'ẹbaa mẹ, Saul om-ofona k'owoni okhuna, otzor abhaam pẹ nnam. Mada opyiri ọbọbh bi, “Mbọng vọ osi anọng mba a? Bẹ am-abhom mbọng o?” Mẹ wọ e, bẹ abira agbaakh-ẹ idik nna s'ira ajinọng pa Jabẹsh akk'agbaakha.
\p 
\v 6 Mada Saul ọbhaang ẹkkaabha nda cha bẹ atzima akwu, ẹfa ch'Egwugwuma ch'Ibinọkpaabyi ẹnwẹ-ẹ, ettem en-ebhem-ẹ.
\v 7 Mẹ wọ, ọtzọkha abhaam pẹ afa ọkpọhk k'abir-ibiri, ọtzọkha ọnang akkaabh-ẹkkaabha mba bi, bẹ atza akkema k'Israẹl makhọra, oben bi, “Manda wọ kwa bẹ asi abhaam p'ọnọng kpenamkpen kw'oni Saul, ọmaana Samwẹl, abẹ ọtzọni.” Mẹ wọ e, ojora f'Ọvaar Ibinọkpaabyi ọnwa anọng, bẹ biphyir an-akhaama ochibhi wani.
\v 8 Mada Saul oyeri bẹ ọkwa ka Bẹzẹk, ọnọng-mik kw'ajinọng p'Israẹl ode, nnọhna nnọhna obhiri arọbh chi obhiri afa obhiri jobh, ọnọng-mik kw'ajinọng pa Juda ode, nnọhna arọbh attaan obhiri chi.
\p 
\v 9 Bẹ agbaak akkaabh-ẹkkaabha mba bi, “Bọng gbaak ajinọng pa Jabẹsh-Gilead bi, ‘Ophyini m'ogbe kw'ekpikhira ẹkk'ẹkhọma, bọng akhaama ẹnaanga ọkhaama.’ ” Mada akkaabh-ẹkkaabha mba afon atza agbaak ajinọng pa Jabẹsh ẹkkaabha nda, ettem ẹdaam bẹ.
\v 10 Mẹ wọ, bẹ agbaak anọng p'Ammọn p'ade ajinọng pa Jabẹsh bi, “Ophyini maman ótte for saman ọbọhk otte ọnang bọng, bọng abira afha atzima man asi odik kpenamkpen kw'ọdaakhi bọng e.”
\p 
\v 11 Ewu ekhobh mẹ, Saul ọbhaangi ajinọng pẹ ka ngaan nttaan. M'owukhobha, bẹ anwa k'ibhingabe s'ab'Ammọn, bẹ afhu bẹ maa apyiri mẹ da ewu ẹkk'ẹkhọma. Anọng p'iwa anaang araami, ọnọng-ọnọng ọrọbh ochina ọgbaho kwẹ.
\s1 Ẹvaar cha Saul ettim aranga
\p 
\v 12 Wa anọng an-abọbh Samwẹl bi, “Anyi wọ ode ọnọng nwuma kw'iwa ọbọbhi bi, ‘Saul wọ ón-ode man ọvaarnọng o?’ Bọng dima ajinọng mba ayin ka chenna man, mófhu bẹ.”
\p 
\v 13 Yina, Saul oben bi, “Mma e, ọnọng manda wani kwa bẹ afhu k'ewu cha mayina kode, da Ọvaar Ibinọkpaabyi okk'Israẹl ọkkaana, k'ewu cha mayina e.”
\p 
\v 14 Mẹ wọ, Samwẹl oben anọng bi, “Bọng kwu mochina ka Gilgal, mobiro ọtza okhera ttara ẹvaar nda kẹ.”
\v 15 Mẹ wọ e, anọng biphyir achina ka Gilgal, atza akhera k'itzitzikha s'Ọvaar Ibinọkpaabyi bi, Saul wọ ode ọvaarnọng. Bẹ afọhni nja sa nnaanga s'odidiri k'itzitzikha s'Ọvaar Ibinọkpaabyi. Mẹ wọ, Saul ọmaana anọng p'Israẹl biphyir asi ọdadaami kw'ideden.
\c 12
\s1 Akpongannam-dim pa Samwẹl
\p 
\v 1 Mẹ wọ, Samwẹl oben anọng p'Israẹl biphyir bi, “Kaam nkk'itzọhng nyonga k'odik kpenamkpen kwa bọng agbaakh-m, nkk'bọng ọvaarnọng mbiri nnanga kw'ọ́dabh bọng.
\v 2 Mẹ wọ, bọbọng akk'ọvaarnọng akhaama kw'otzima bọng. On-ode kaam, nkk'ndama mbiri mmen ahọbh, va paam p'ijinọng awobh ma ttara bọng. Kaam nkk'bọng ndabha ttẹwọr k'edikkobh chaam maa apyiri k'ewu cha mayina.
\v 3 M'ẹbaa nda cha mbe ma, bọng gbaak-m m'itzitzikha s'Ọvaar Ibinọkpaabyi, ọmaana m'itzitzikha s'ọtzọhmnọng nwa kwẹ, kwa kẹ okk'ana obyengi k'eho. Anyi wọ kwa kaam nkk'ẹbhaam chẹ ndọkha? Anyi wọ kwa kaam nkk'ẹnyanyaang chẹ ndọkha? Anyi wọ kwa kaam nkk'chen nsa? Anyi kwa kaam nkk'ihem nhokha? Anyi wọ oben bi, kaam nkk'ngwu ka mbọhk sẹ ndọkha, kw'orenga mẹ kaam eponga-kpaara ch'etzor-otzor ka nnang o? Idikha kaam nkk'ottotto manda wani ngaama m'idik nna, kaam ńsi-osi kwẹ otzor.”
\p 
\v 4 Bẹ abhina bi, “Man chen atzima asa, man k'ihem kabira ahok, mada ogbe odede ọttọhk f'ọnọng katzọk.”
\p 
\v 5 Samwẹl oben bẹ bi, “Ọvaar Ibinọkpaabyi, ọmaana ọtzọhmnọng kwẹ kw'okk'ana obyengi k'eho, bọ ade awobhare p'attaanga anang bọng m'odik nwa, k'ewu cha mayina e, bi kaam ottotto manda wani k'itzitzikha sabọng kingaam.”
\p Bẹ abhina bi, “Kẹ wọ ode owobh-ore kwaman.”
\p 
\v 6 Mẹ wọ, Samwẹl ọgbaak bẹ bi, “Wa Ọvaar Ibinọkpaabyi wọ otzek Mosẹs ọmaana Aarọn. Kẹ wọ iwa obiro otzima abatte obina k'Ijip.
\v 7 Mẹ wọ e, bọng be mẹ, ifha kaam ndima ẹkhọhkha mpyima bọng k'itzitzikha s'Ọvaar Ibinọkpaabyi, k'idik s'itzor-otzor biphyir sa kẹ ọkk'ọsa ọnang bọng ttara abatte.
\p 
\v 8 “Mada Jekọb ọnwa k'Ijip, bẹ abhom ẹkkaana anang Ọvaar Ibinọkpaabyi. Wa Ọvaar Ibinọkpaabyi ọtzọhm Mosẹs ọmaana Aarọn, p'atzim abatte abina k'Ijip akwu ahok bẹ m'ibe nna.
\p 
\v 9 “Yina, bẹ araama Ọvaar Ibinọkpaabyi kwabẹ. Mẹ wọ, Ibinọkpaabyi otte bẹ ọbọhk ọnang Sisẹra, kw'ode odenho kw'agbong-nọng pa Hazọr, obiro otte bẹ ọbọhk ọnang aPhilistiya, ttara ọvaarnọng kwa Moab, p'arim bẹ abẹ.
\v 10 Wa bẹ abhom anang Ọvaar Ibinọkpaabyi, aben bi, ‘M'okk'ẹkhọngkwuri ọsa, m'okk'nnam ọkpa ọbọra Ọvaar Ibinọkpaabyi, mon-okpobha akha pa Baal, ọmaana agbatza p'Ashtọrẹt. Yina, rọbha man ka mbọhk s'attattaanga-nọng paman, ifha mókpobh-ọ.’
\v 11 Mẹ wọ, iwa Ọvaar Ibinọkpaabyi ọtzọhm Jerubaal, ọmaana Barak, ọmaana Jẹphta, ttara Samwẹl, obiro ọrọbha bọng ka mbọhk s'attattaanga-nọng pabọng, k'eden kpenamkpen, ifha bọng aruk k'odidiri.
\p 
\v 12 “Yina, mada bọng an-are ọvaar Nahash kw'ọdabhi ab'Ammọn da om-okwu bi okwu orima bọng abẹ, bọng an-aben bi, ‘Mma e, maman orori ọvaarnọng kw'ọdabh man e’ kaambi ode bi Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng wọ ode bọng ọvaarnọng.
\v 13 Mẹ wọ, bọng kkeri ọvaarnọng kwa bọng akk'atzekha mẹ, nwuma kwa bọng arori. Bọng kker e, Ọvaar Ibinọkpaabyi okk'bọng ọvaarnọng kw'ọdabh bọng ọnanga e.
\v 14 Idikha ira bọng akhaam ojora f'Ọvaar Ibinọkpaabyi, bọng akpobh-ẹ, abira ahakha eho anang asana pẹ, idikha bọbọng ttara ọvaarnọng kw'ọdabhi bọng, akher k'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng, ira ojibh-ojibh ọnang bọng.
\v 15 Yina, idikha bọng ani eho ahak anang Ọvaar Ibinọkpaabyi, bọng an-agaangi eho anang asana pẹ, kẹ ọ́nang bọng ettuma mach'iwa ọnangi abatte.
\p 
\v 16 “Mẹ wọ, bọng wobha \it bi sẹẹbh\it* atzima chen pabọng are odik barambar kw'Ọvaar Ibinọkpaabyi om-oben bi osi o.
\v 17 Ogbe kw'ipha s'awit arang ma? Kaam ńyeri Ọvaar Ibinọkpaabyi bi otte ẹbhaangkpon ọbọhk etto etzum, obiro otte ẹrọng ọbọhk etzebh. Mẹ wọ kwa bọng atzima atzin itzama-dema sa bọng asi k'itzitzikha s'Ọvaar Ibinọkpaabyi, da bọng arori ọvaarnọng abọbh-ẹ.”
\p 
\v 18 Mẹ wọ e, Samwẹl oyeri Ọvaar Ibinọkpaabyi. Mẹ ewu nduma dani, Ọvaar Ibinọkpaabyi otte ẹbhaangkpon ọbọhk etto etzum, obiro otte ẹrọng ọbọhk etzebh. Ofona mẹ, anọng biphyir an-awobha k'ojora f'Ọvaar Ibinọkpaabyi, ọmaana fa Samwẹl.
\p 
\v 19 Anọng biphyir an-aben Samwẹl bi, “Zi njọhm anang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ, ka nho sa maman atzọhmnọng pọ e, ifha moningi ópe e, kkeri mokk'itzama ọsa ttara ka ngọngkwuri saman biphyir e, bi moror ọvaarnọng ọbọbh-ẹ e.”
\p 
\v 20 Samwẹl obhina bẹ bi, “Oningi bọng ojor e. Bọng akk'itzama nna biphyir asa; yina, bọng nnam kàkpa abọra Ọvaar Ibinọkpaabyi, bọng na kpobha Ọvaar Ibinọkpaabyi ttara ettem obungichẹ.
\v 21 Bọng agbatza kàkpobha kkeri bẹ k'eden kayini. Agbatza ejibha katzim achena bọng, bẹ bọng kabira afha akkaana, okhuri bi, bẹ k'eden kayini.
\v 22 Ọvaar Ibinọkpaabyi órenga abarada pa che chẹ abẹbẹ, bọng kóbhum, okhuri bi, wa ode odik kw'ọdaami Ọvaar Ibinọkpaabyi ettem bi, otzima bọng osi anọng pẹ.
\v 23 On-ode kaam, tzọmi-tzọmi okponga k'idachen bi, kaam nsi ẹkhọngkwuri k'itzitzikha s'Ọvaar Ibinọkpaabyi, cha kaam nni njọhm nzi ka bọng ka nho. Kaam ḿbiri ḿkpebhi bọng idik s'ijibh-ojibh, ibiri itzor-otzor.
\v 24 Yina, bọng konga akhaama ojora f'Ọvaar Ibinọkpaabyi, bọng abira akpobh-ẹ ka nnam-ophephe ttara ettem obungichẹ. Bọng jima idik-barada s'ọkk'ọsa ọnang bọng.
\v 25 Yina, bọng an-achin ororo k'itzama, bọbọng ọmaana ọvaarnọng kwabọng, bẹ ádimi bọng odimi biphyir-phyir.”
\c 13
\s1 Saul orim aPhilistiya abẹ
\p 
\v 1 Wa Saul ode cho ẹrọbh obhiri jobh k'ogbe kw'ode ọvaarnọng. Wa kẹ ọdabhi Israẹl ka cho arọbh afa obhiri afa.\f + \fr 13.1 \ft Akkẹra adọdọk akhaam nden k'adem-k'adem sa bẹ akkeri ọnaanga nwa, yina, ẹMbẹmbẹ etzor NIV nnam manya. \f*
\p 
\v 2 Wa Saul otzek ajinọng p'Israẹl nnọhna nzenamfa obhiri arọbh jobh. Ohok nnọhna nzen nwobha ttara kẹ ka Mikmash, ọmaana ka mgbegbeho sa Bẹtẹl. Ajinọng nnọhna mfa obhiri arọbh jobh awobha ttara Jonatan ka Gibea k'ẹkhọma cha Bẹnjamin. Ọtzọhm ajinọng mbongo nnọhna mfa obhiri arọbh jobh, akpa nnam k'ihọhm sabẹ.
\p 
\v 3 Jonatan e, orima odenho kw'agbong-nọng p'aPhilistiya p'abe k'ẹbaakhamma abẹ, ka Gẹba. Wa abaPhilistiya abhaanga odik nwuma. Mẹ wọ, Saul ọnang ẹfa bi bẹ agyi obukpọhng, asi eronga anang anọng m'ẹkhọma nda \it bi waam\it*, aben bi, “Tte aHiburu abhaanga e!”
\v 4 Mẹ wọ, anọng p'Israẹl biphyir abhaanga ẹkkaabha nda bi, “Saul okk'aPhilistiya abẹ ọtza orima k'ibhingabe sabẹ e, ttara bi, anọng p'Israẹl an-akpukhi aPhilistiya idik okpukhi.” Wa bẹ atzọhm ajinọng achena Saul ka Gilgal.
\p 
\v 5 Mẹ wọ, abaPhilistiya atzobha bi bẹ arima anọng p'Israẹl abẹ, bẹ atzima akpaar pa nnyanyaang mindọr, nnọhna ẹrọbh obhiri nttaan obhiri chi, ọmaana agbong-nọng p'ayaar akpaar mbuma pa nnyanyaang mindọr nnọhna chi, ttara agbong-nọng adọdọk nnọhna nnabhik mach'oyeyeng kw'ẹraanga-kha. Bẹ avura atza abhing ka Mikmash, k'okhubha kw'ewuchen em-eyin ka Bẹt-Avẹn.
\v 6 Mada anọng p'Israẹl an-are bi, bẹ an-awobh ka dama-dama ttara bi, ayok an-ayọhng bẹ mkpaan, bẹ arọbh atza achubha k'atzakpamma, ọmaana k'araan, k'ottem kw'atzakpa, ọmaana k'apekhuma, ttara ka nsipe.
\v 7 Wa aHiburu bani arọbhi ajekha Jọrdan, achina k'obhon kwa Gad, ọmaana Gilead.
\p Wa Saul otzim owobh ka Gilgal, ttara ẹkhaan ch'agbong-nọng p'atzọn-ẹ p'opoma osi.
\v 8 Saul owobha k'iwu izenamfa otzik ogbe kwa Samwẹl okhe bi, okwu, yina, wa Samwẹl ka Gilgal otzima ọkwa. Mẹ wọ, agbong-nọng pa Saul attẹwọr araami.
\v 9 Mẹ wọ e, Saul oben bi, “Bọng chẹn-m, ẹnanga ẹkwọmichẹ, ọmaana nnanga s'odidiri.” Wa Saul ọfọhni ẹja ẹkwọmichẹ.
\v 10 Mada Saul okyer ẹjafọhni \it bi kpaar\it*, Samwẹl opyiri, Saul oyin k'iyaan otza orim-ẹ.
\p 
\v 11 Samwẹl e, ọbọbh-ẹ bi, “Bọng odik kw'asi ma a?”
\p Saul obhina bi, “Mada nna nne bi anọng mba am-araami, ọmaana bi m'ogbe kw'akhe dọk kakwu, ttara bi aPhilistiya am-atzobh ka Mikmash.
\v 12 Kaam nna nchibhi bi, ‘APhilistiya áhakh-óhakha ákwu arim-m abẹ ka Gilgal. Kaam Ọvaar Ibinọkpaabyi kimbiri ndọn bi, ọkkaana man.’ Kẹ wọ osi nna nchibhi bi, mfọhni ẹja nda e.”
\p 
\v 13 Samwẹl oben bi “Kọ asi kwẹ k'edidingi-den e, kọ asana p'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ, p'ọnang-ọ kahokhi, ira akk'ahokha, ira kẹ ọkk'ẹvaar chọ k'Israẹl aranga ottima, k'ogbe kpenamkpen.
\v 14 Yina, ttẹwọr mayina, ẹvaar chọ ororo dọk kéchina. Ọvaar Ibinọkpaabyi okk'ọnọng otzekha kw'ofon-ẹ k'ettem, kw'ọdabh anọng pẹ, okhuri bi, kọ asana p'Ọvaar Ibinọkpaabyi kàhokhi.”
\p 
\v 15 Mẹ wọ, Samwẹl obina ka Gilgal, ochina ka Gibea k'ẹkhọma cha Bẹnjamin. Saul e, ọtzọkha obhik kw'ajinọng p'awobh ttara kẹ. Wa ajinọng p'awobh ttar-ẹ, apyiri ẹnọhna obhiri arọbh jobh.
\p 
\v 16 Wa Saul ọmaana nnwa kwẹ Jonatan, ọmaana ajinọng p'awobh ttara bẹ, awobh ka Gibea k'ẹkhọma cha Bẹnjamin, aPhilistiya abhing ka Mikmash.
\v 17 Asoja p'erima abina ka ngaan nttaan k'ibhingabe s'aPhilistiya. Ẹkhaan dani echina k'okhubha kw'Ọphra k'ẹkhọma cha Shual,
\v 18 dani echina ka Bẹt-Họrọn, ndongo ch'ettong nttaan echina k'okhubha kw'enem ch'ẹrọni ẹttẹri cha Zeboyim, ch'ekkeri itzitzikha k'ibe s'anọng anarukhi.
\p 
\v 19 Wa otzetzekha manda wani kw'owobh k'ebhonmọr ch'Israẹl \it bi waam\it* kode, okhuri da aPhilistiya akk'bẹ eden akpa k'egbongkpo osisi, aben bi, “Oni mando ode, aHiburu mba áduk akkangkkaang ọmaana akhọhn!”
\v 20 Mẹ wọ, anọng p'Israẹl biphyir an-ahakha akhebha aPhilistiya bi bẹ atza abọhnga ngubh, ọmaana akhukhubha, ọmaana mbar sabẹ, ttara ngubh ndọdọk sabẹ.
\v 21 Ẹphya cha ngubh ọmaana akhukhubha ọbọbọhnga ede ishẹkẹl-bhaakha, ọmaana ọttọhk f'opyiri ishẹkẹl-bhaakha cha sọvẹl kw'ọkhaam aha ọmaana mbar, ttara ọbọbọhnga kw'ẹmma ch'echi ch'akkeri-nden ede shẹkẹl k'obe ọttaan.
\v 22 Mẹ wọ, m'ewu nduma ch'egbong, orim-egbong manda wani kw'owobh ttara Saul ọmaana Jonatan, kw'ọkhaam ọkkangkkaang ọmaana ọkhọhn k'ọbọhk kwẹ, kode, ayongi Saul ọmaana nnwa kwẹ Jonatan, bọ akhaam pyẹ.
\s1 Jonatan orim aPhilistiya abẹ
\p 
\v 23 Mẹ wọ, ẹkhaan dani ch'agbong-nọng p'aPhilistiya ekk'efona ẹtza ẹkpa ọkkadeden kwa Mikmash.
\c 14
\p 
\v 1 Wa ewu dani, Jonatan kw'ode nnwa kwa Saul oben odikkobh kw'ode otzim-egbongkpo kwẹ bi, “Kwu mojekha k'okhubha kw'agbong-nọng pa Philistiya p'akkeri ẹbaakhamma awobh.” Yina, wa Jonatan otte kọ̀gbaakhi.
\p 
\v 2 Wa Saul owobh k'obhon okhaan-okhaan kwa Gibea k'ochigbagba kw'apomegrenet ka Migrọn. Wa kẹ otzim anọng p'apyiri ẹnọhna obhiri arọbh jobh.
\v 3 K'ottem kw'anọng p'awobh ttar-ẹ, wa ode Ahija kw'ọm-ọfọra ẹphọd. Ahija nwa wa ode nnwa kw'ijinọng kw'ọgbaanọkka kw'Ikabọd, kw'okpen Ahitub. Ahitub ode nnwa kw'ijinọng kwa Phinẹhas, kw'ode nnwa kw'ijinọng kw'Ẹli, kw'ode ọfọhnẹja kw'Ọvaar Ibinọkpaabyi ka Shilo. Ọnọng kw'iwa orong bi Jonatan okk'obina ofona kode.
\p 
\v 4 K'okhubha kpenamkpen kwa Jonatan oreng bi, ojekha okhebha agbong-nọng pa Philistiya p'akkeri ẹbaakhamma, ọkhaam egbegbeho ch'ede atzakpa-tzakpa. Dani ekpen Bozẹz, ndongo ekpena Sẹnẹ.
\v 5 Egbegbeho dani ch'ede atzakpa-tzakpa ebe ekkeri k'obhon-ebira kwa Mikmash, ndonggo ebe k'obhon-ẹrakha kwa Gẹba.
\p 
\v 6 Jonatan oben odikkobh kw'ode otzim-egbongkpo pyẹ bi, “Kọ kwu mochina k'anọng mba p'akkeri ẹbaakhamma ch'aPhilistiya mba p'ani ọkpakkọrikkọ am-asi. Asi mẹ, Ọvaar Ibinọkpaabyi ofha orima erima nda orima ọnang man. Kaambi ode bi, mọhaabh-ọhaabh man kobiro ọhaabh o, ọttọhk manda vani f'ọfha ọkpa Ọvaar Ibinọkpaabyi eden bi, oningi man ọkkaan kode.”
\p 
\v 7 Otzim-egbongkpo pya Jonatan oben bi, “Kọ si odik kpenamkpen kw'ojibh ọnang-ọ. Kọ china ororo, kkeri kaam ndum-ọ mbọhk ka nnam k'achibhi p'ettem chọ.”
\p 
\v 8 Mẹ wọ, Jonatan oben bi, “Kwu mojekha k'okhubha nwonggo motza okhebha ajinọng mba, ifha bẹ are man.
\v 9 Idikha bẹ abeni man bi, ‘Bọng be kẹ mokhebha bọng kẹ,’ mówobha mẹ da mowobh, man kóvura okhebha bẹ kẹ.
\v 10 Yina, idikha bẹ abeni man bi, ‘Bọng vura khebha man ka,’ móvura okhebha bẹ kẹ, okhuri bi, mẹ wọ óde ẹkhọhkha ọnang man bi, Ọvaar Ibinọkpaabyi okk'bẹ ọbọhk ọtta ọnang man, bi mokhema.”
\p 
\v 11 Mẹ wọ e, bẹ anọng afa atza ajana for sabẹ k'ẹbaakhamma cha Philistiya. APhilistiya aben bi “Bọng kker e! AHiburu mba am-abẹkhi ayini k'amma p'ira bẹ am-achubha e.”
\v 12 Ajinọng p'awobh k'ẹbaakhamma, akpẹbh Jonatan ọmaana otzim-egbongkpo kwẹ amọng, aben bi, “Bọng vura akhebha man ka, ifha mọkhọkha bọng nkkwuri.”
\p Mẹ wọ, Jonatan oben otzim-egbongkpo kwẹ bi, “Vura atzor-m nnam. Ọvaar Ibinọkpaabyi okk'bẹ ọtzọkha ọnang anọng p'Israẹl bi, bẹ akhema.”
\v 13 Jonatan otzima mbọhk ọmaana mmo ovura, otzim-egbongkpo kwẹ otzor-ẹ nnam. Wa Jonatan ofhu aPhilistiya, otzim-egbongkpo kwẹ obira otzor-ẹ nnam ofhu bẹ.
\v 14 M'echeden-nima nduma, Jonatan ọmaana otzim-egbongkpo kwẹ, afhu anọng ẹrọbh k'ibe s'ibari ipyiri ndọkhi arọbh jobh.
\p 
\v 15 Mẹ wọ e, opoma ọnwa agbong-nọng pa Philistiya biphyir p'awobh k'ibhingabe, ọmaana p'awobh k'egbong-dam, ọmaana agbong-nọng p'awobh k'ẹbaakhamma, ttara ngaan s'arim-erima. Wa irerek inyengi. Ibinọkpaabyi wọ iwa ọtzọhmi opoma mva.
\s1 Anọng p'Israẹl akhem aPhilistiya
\p 
\v 16 Wa akker-ibe pa Saul ka Gibea k'ẹkhọma cha Bẹnjamin, are da agbong-nọng p'aPhilistiya an-am-arọbh ajaang-jaang.
\v 17 Mẹ wọ, Saul oben ajinọng p'atzọn-ẹ abẹ bi, “Bọng dọkha obhik kw'agbong-nọng ifha moronga ọnọng kw'oni ma ode.” Mada bẹ akk'mando asa, bẹ are bi Jonatan ọmaana otzim-egbongkpo kwẹ, bọ ani mẹ ade.
\p 
\v 18 Saul e, oben Ahija kw'ode ọfọhnẹja bi, “Tzima Ẹkkọhbhi ch'Echekhi ch'Ibinọkpaabyi kwu.” M'ogbe nwa, wa ẹkkọhbhi nda ewobh ọmaana anọng p'Israẹl.
\v 19 Mada Saul otzim-otzim atzim m'ẹmma da ọm-ọgbaak ọnang ọfọhnẹja, dama-dama kw'owobh k'ibhingabe sa Philistiya odo ọttar-ọttara. Mẹ wọ, Saul oben ọfọhnẹja bi, “Rọbha ọbọhk kwọ m'odik nwa.”
\p 
\v 20 Mẹ wọ e, Saul ọmaana anọng pẹ biphyir atzobha, bẹ abina atza egbong. Bẹ akhebha aPhilistiya k'opoma, da bẹ an-atzim akkangkkaang abhakhi afhu ayok.
\v 21 AHiburu mbuma p'iwa akkekkeni awobha ttara aPhilistiya, p'abira atzọn bẹ avura k'ibhingabe, ajekha akhebha anọng p'Israẹl p'awobh ọmaana Saul, ttara Jonatan.
\p 
\v 22 Mada anọng p'Israẹl biphyir p'iwa akk'achubha ka mgbegbeho s'Ephraim abhaang bi, aPhilistiya am-arọbhi, bẹ an-anwa egbong akhubh aPhilistiya, m'ẹkhọma-ẹkhọma.
\v 23 Mẹ wọ, Ọvaar Ibinọkpaabyi ọkkaana anọng p'Israẹl m'ewu nduma, egbong ẹnyaami ẹkwọbha Bẹt-Avẹn.
\s1 Ọnwọhngi kwa Saul kw'okhuri ọchattọhk
\p 
\v 24 M'ewu nduma, wa ajinọng p'Israẹl an-awobh ka dama-dama, okhuri da Saul okk'anọng mba ọtzọkha okhe k'ọnwọhngi, oben bi, “Opyibh-opyibh ọnang ojinọng kpenamkpen kw'ochi ọchattọhk yina ẹchọhkha, koyongi bi kaam nkk'odik kw'attattaanga-nọng paam asi, ndukha.” Mẹ wọ, ọnọng manda wani kw'ochi ọttọhk kode.
\p 
\v 25 Mẹ wọ, agbong-nọng mba biphyir adim k'ẹtzam, bẹ atza are akhọkhọnana m'irerek.
\v 26 Mada bẹ adimi k'ẹtzam, bẹ are da akhọkhọnana am-abhobh, yina, ọnọng manda wani kw'okhe ọbọhk mẹ ọttaakhi kode, okhuri ojora f'ọnwọhngi kwa Saul.
\v 27 Yina, wa Jonatan otzim ọbhaanga bi, otte okk'anọng mba ọkha k'ọnwọhngi. Mẹ wọ, on-otzima ikhokhori s'ochikhura kw'otzim ọrana k'akhọkhọnana-kpa, otzini ọbọhk okhe k'ẹmma ọttaakhi, on-odo ẹfa ọkhaama.
\v 28 Mẹ wọ, orim-egbong wani ọgbaakh-ẹ bi, “Atte okhe agbong-nọng mba k'ọnwọhngi kw'ọgaang-ọgaangi, oben bi, ‘Opyibh-opyibh ọnang ojinọng kpenamkpen kw'ochi ọchattọhk mayina.’ Odik nwuma wọ osi ẹfa ẹm-ẹha anọng mba, bẹ am-awọhnga e.”
\p 
\v 29 Jonatan obhina bi, “Otte kwaam okk'anọng paman ọkha ka dama-dama e. Kkeri odem kwa kaam nkk'ẹfa mbiri ngaama ka, da nttaakhi akhọkhọnana mba ibebaa.
\v 30 Ira ode odik kw'ojibh-ojibh, idikha ajinọng mba akk'ọttọhk acha k'ọgbọm fa bẹ achi k'attattaanga-nọng pabẹ e. Mẹ kw'ira ekhema ch'anọng mba, akhema aPhilistiya ẹbar ọtzam e.”
\p 
\v 31 M'ewu nduma, mada anọng p'Israẹl akk'aPhilistiya afha ttẹwọr ka Mikmash maa apyiri k'Aijalọn, wa ọkhọhn bẹ.
\v 32 Mẹ wọ, bẹ akhur atto k'ọgbọm ochichi, atzọkha arukhimaan, ọmaana andaamogbodo, ttara abhaamva, bẹ akpọk pyẹ m'ẹbaa, achi ttara izi.
\v 33 Mẹ wọ, ọnọng wani oben Saul bi, “Kker e, ajinọng mba am-asi ẹkhọngkwuri k'itzitzikha s'Ọvaar Ibinọkpaabyi bi, bẹ am-achi nden ttara izi.”
\p Oben bẹ bi, “Bọng akk'apina e! Bọng bingi ọtza kw'ideden ẹbhar-ẹbhar atzima akwu ma.”
\v 34 Mẹ wọ e, Saul oben bẹ bi, “Bọng nọng k'ottem kw'ajinọng mba, aben bẹ bi, ‘Ọnọng-ọnọng ótzima ẹbhaam chẹ, ọmaana orukhimaan kwẹ ótzima ókwu ma. Bọng fhu pyẹ ma, achi. Bọng ẹkhọngkwuri k'itzitzikha s'Ọvaar Ibinọkpaabyi kàsi bi, bọng achi nden ttara izi o.’ ”
\p Mẹ wọ e, ọnọng-ọnọng otzima ẹbhaam chẹ, okwu m'erungi nduma ofhu chẹ mẹ.
\v 35 Mẹ wọ, Saul osi ijafọhnibe ọnang Ọvaar Ibinọkpaabyi; ma wọ ode ochedengbe kw'osi mando.
\p 
\v 36 Mẹ wọ, Saul oben bi, “Tte mọkhakha m'erungi otza orima aPhilistiya abẹ, mobiro ochi bẹ ọgbọm maa ewu ehobha, tte moningi ọnọng manda wani ọbọhk otte oruk akpen.”
\p Bẹ an-abhina bi, “Si odik kpenamkpen kw'ojibh-ọ abẹ.”
\p Yina, ọfọhn-ẹja oben bi, “Tte moror odik nwa ọbọbh Ibinọkpaabyi manya.”
\p 
\v 37 Mẹ wọ, Saul ọbọbh Ibinọkpaabyi bi, “Ma ńhakha nda nnima aPhilistiya abẹ o? Na kọ ánang anọng p'Israẹl ekhema o?” Yina, wa Ibinọkpaabyi kẹ ebhina kọ̀nangi m'ewu nduma.
\p 
\v 38 Mẹ wọ e, Saul on-oben bi, “Adenho p'agbong-nọng biphyir bọng kwu, ifha mọdọhn eden ch'ẹkhọngkwuri cha mayina ereng ekwu.
\v 39 Odem nwa kw'Ọvaar Ibinọkpaabyi kw'ọkkaan anọng p'Israẹl orukhi akpen, kaambi ode bi nnwa kwaam Jonatan wọ osi odik nwa, kẹ ọkhaambi da ope.” Yina, ojinọng manda wani kw'osi ẹmọng kode.
\p 
\v 40 Mẹ wọ, Saul on-oben anọng p'Israẹl biphyir bi, “Bọng be kana, ifha kaam ọmaana nnwa kwaam Jonatan mobe kanya.”
\p Ajinọng mba abhina bi, “Si odik kpenamkpen kw'ojibh-ọ abẹ.”
\p 
\v 41 Mẹ wọ, Saul on-ozi njọhm ọnang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'Israẹl, oben bi, “Kọ nang-m ebhina ẹkkakka. Idikha ose otto ka kaam, ode bi obiro otto ka nnwa kwaam Jonatan o, kọ bhina ttara Urim. Yina, idikha otto k'ajinọng mba p'Israẹl, kọ bhina ttara Tumim. Mẹ wọ, bẹ abhari ose, otto ka Jonatan ọmaana Saul. Wa ajinọng mbongo anaanga odik nwa.
\v 42 Saul on-oben bi, bọng mari ose k'eho chaam ọmaana cha Jonatan.” Wa ose otto ka Jonatan.
\p 
\v 43 Mẹ wọ, Saul oben Jonatan bi, “Kọ gbaak-m odik kw'akk'asa.”
\p Jonatan e ọgbaakh-ẹ bi, “Kaam ngingẹ nttaakhi akhọkhọnana pa ndim ikhokhori s'ochikhura kwa ndim k'ọbọhk kwaam nttọmi. Aa, kkeri kaam ma e, kaam ngaambi mpe.”
\p 
\v 44 Saul on-oben bi, “Jonatan, tte Ibinọkpaabyi ọnang-m ettuma k'iden-dama ọttar-ọttara, idikha kọ Jonatan án-apẹ.”
\p 
\v 45 Yina, ajinọng mba an-aben Saul bi, “Ode bi Jonatan nwa kw'okk'Israẹl ẹnaanga barada nda ọnanga ope o? Kwẹ mando kode! Odem nwa kw'Ọvaar Ibinọkpaabyi orukhi akpen, esisa-naanga manda dani chẹ ch'etto m'irerek kede, okhuri bi, kẹ osi odik nwa mayina ttara ẹkkaana ch'Ibinọkpaabyi.” Mẹ wọ, ajinọng mba akkaana Jonatan, bẹ kẹ dọk kàfhu.
\p 
\v 46 Mẹ wọ, Saul ọkwọbha aPhilistiya okhukhubh, aPhilistiya akpa nnam abhana ka bẹ k'ibe.
\p 
\v 47 Mada Saul okk'ẹvaar k'Israẹl ọn-ọdabha, wa orim egbong ttara idibhon s'ide attattaanga-nọng pabẹ makhọra. Wa idibhon nna ide; Moab, ọmaana Ammọn, ọmaana Edom, ọmaana avaarnọng pa Zoba, ttara abaPhilistiya. Wa kẹ ọnangi anọng mba ihem k'ibe kpenamkpen s'okkeri itzitzikha.
\v 48 Wa orima egbong mach'ojinọng okhema ab'Amalẹk, obiro ọkkaana ọrọbha anọng p'Israẹl ka mbọhk s'anọng p'akk'bẹ ọgbọm acha.
\s1 Ẹhọhmmọr cha Saul
\p 
\v 49 Wa va p'ijinọng pa Saul ade Jonatan, ọmaana Ishvi, ttara Malki-Shua. Ocheden nnwa kwẹ kw'ikwanọng okpena Mẹrab, oyok kw'ikwanọng kw'ojem-ẹ okpena Mikal.
\v 50 Kwanọng kwa Saul wa okpen Ahinoam kw'ode nnwa kw'Ahimaz. Abnẹr wọ iwa ode odenho kw'agbong-nọng pa Saul, obiro ode nnwa kwa Nẹr. Nẹr nwa wa ode ọgbaanotte kw'otte kwa Saul.
\v 51 Abiyẹl wọ iwa obhoni Kish, kw'ode otte kwa Saul, obiro obhon Nẹr, kw'ode otte kw'Abnẹr.
\p 
\v 52 Wa ogbe kwa Saul biphyir, ode ogbe kw'egbong ch'ẹgaang-ọgaangi ttara aPhilistiya. Wa ogbe kpenamkpen kwa Saul ore ojinọng kw'ọkhaam ẹfa, obiro ode okkenggitza o, ọm-ọtzọkh-ẹ ttara k'agbong-nọng pẹ.
\c 15
\s1 Ọvaar Ibinọkpaabyi obhumi Saul mach'ọvaarnọng
\p 
\v 1 Samwẹl oben Saul bi, “Kaam wọ kw'iwa Ọvaar Ibinọkpaabyi ọtzọhmi bi mbyeng-ọ ana k'eho e, ifha ade ọvaarnọng kw'Israẹl. Mẹ wọ, na yonga itzọhng abhaanga ẹkkaabha ch'efon k'Ọvaar Ibinọkpaabyi.
\v 2 Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir obeni bi, ‘Kaam ńnang ab'Amalẹk ettuma, k'odem kw'iwa bẹ attaang anang anọng p'Israẹl k'ọkkadeden, k'ogbe kwa bẹ abin k'Ijip.
\v 3 Mẹ wọ, kọ rọhng atza arima ab'Amalẹk abẹ, abira adimi ọttọhk kpenamkpen f'ode fabẹ. Ọttọhk ọbọhk kàtte oruk akpen, fhu ajinọng, ọmaana panọng, ọmaana igbọ, ọmaana vava, ọmaana andaamogbodo, ọmaana arukhimaan, ọmaana akamẹl, ttara nnyanyaang.’ ”
\p 
\v 4 Mẹ wọ, Saul oyeri anọng ọkwa, obiro ọtzọkha obhik kwabẹ ka Telayim. Wa agbong-nọng p'areng k'irerek ade anọng nnọhna ẹnọhna obhiri arọbh azen, ọmaana anọng nnọhna ẹrọbh obhiri nzen p'afon Juda.
\v 5 Saul ofona ochina k'obhon kw'Amalẹk, ọtza ochubha k'ẹttẹri otzik bẹ.
\v 6 Mẹ wọ, Saul oben abaKen bi, “Bọng nọng afona, bọng atte ab'Amalẹk ọbọhk, kaam kinnori bi ndimi bọng ttara bẹ, da iwa bọng asi ọphyaam anang anọng p'Israẹl biphyir, mada bẹ abin k'Ijip.” Mẹ wọ, abaKen abina k'obhon kw'abAmalẹk afona.
\p 
\v 7 Mẹ wọ e, wa Saul orima ab'Amalẹk abẹ ttẹwọr ka Havila, maa apyiri ka Shur, achina k'okhubha kw'ewuchen em-eyin k'Ijip.
\v 8 Wa Saul ọbọkha Agag kw'ode ọvaarnọng kw'Amalẹk ekhekhebhi, kẹ kofhu, yina, otzima ọkkangkkang ofhu anọng pẹ biphyir.
\p 
\v 9 Yina, Saul ọmaana agbong-nọng pẹ, atte Agag ọbọhk ọmaana arukhimaan pẹ akkakka, ọmaana andaamogbodo, ọmaana abhaam abhaarapẹ, ọmaana arukhimaanva, ttara ọttọhk kpenamkpen f'ojibh-ojibh oruk akpen. Wa ekpo mbya ẹmma bẹ ettem bi bẹ afhu. Yina, ọttọhk kpenamkpen f'iwa okpukhi bẹ okpukhi, ọmaana f'ọmọmmi for bẹ akhibhi pyẹ biphyir-phyir.
\p 
\v 10 Mẹ wọ, wa Ọvaar Ibinọkpaabyi ọgbaak Samwẹl atzim, oben bi,
\v 11 “Kwẹ ọmmaam-m k'ettem bi, nkk'Saul ọvaarnọng nsa, kẹ okk'nnam ọkpa ọbọr-m, ndọhna saam kọ̀tzọk.” Wa odik nwa ọyak Samwẹl atzim maa, obhom ozi njọhm m'erungiwu nduma biphyir ọnang Ọvaar Ibinọkpaabyi.
\p 
\v 12 K'ekpekpebha, Samwẹl obina bi ọtza ore Saul, yina, bẹ agbaakh-ẹ bi, “Saul okk'ofona ochina ka Kaamẹl. Kẹ wọ kw'iwa ọbaang ọgbatza kwa bẹ am-atzima ajim-ẹ, yina ọn-ọkpa nnam ọhakha ochina ka Gilgal.”
\p 
\v 13 K'ogbe kwa Samwẹl on-okhebh-ẹ, Saul oben bi, “Tte Ọvaar Ibinọkpaabyi ọdọ-ọ! Kaam nkk'nsa mach'Ọvaar Ibinọkpaabyi ọtzọhn-m.”
\p 
\v 14 Yina, Samwẹl ọbọbh bi, “Mbọng vọ f'arukhimaan am-amẹmma o? Mbọng f'andaamogbodo am-amẹmma a?”
\p 
\v 15 Saul obhina bi “Arim-egbong bọ atzim pyẹ k'Amalẹk akwu e, bẹ ahokhi arukhimaan akkakka mba, ọmaana andaamogbodo mba bi bẹ atzima afọhni ẹja anang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ e, yina, mokk'ekpo mbyonggo odimi biphyir.”
\p 
\v 16 Samwẹl oben Saul bi, “Odik dema nwuma dọk kàgbaak. Tte mgbaakh-ọ odik kw'Ọvaar Ibinọkpaabyi ọgbaakh-m k'erungi ch'ikhena e.”
\p Saul obhina bi, “Gbaak-m.”
\p 
\v 17 Mẹ wọ, Samwẹl oben bi, “Okhinggẹ ode bi, kọ wọ iwa are for sọ ọkhara e, kọ wa akk'odenho kwa mfonamma s'Israẹl ada. Wa Ọvaar Ibinọkpaabyi obyeng-ọ ana k'eho ifha adabh anọng e.
\v 18 Ọvaar Ibinọkpaabyi ọtzọhm-ọ ọtzọhm, oben bi, ‘Kọ rọhng atza adimi anọng-dama mbuma p'Amalẹk biphyir, arima bẹ abẹ maa are bi akk'bẹ adimi biphyir-phyir.’
\v 19 Okhuri yan kwa kọ arẹkhi Ọvaar Ibinọkpaabyi? Okhuri yan kw'achi ọgbọm, abira asi epyibha k'itzitzikha s'Ọvaar Ibinọkpaabyi o?”
\p 
\v 20 Yina, Saul obhina Samwẹl bi, “Kaam nkk'Ọvaar Ibinọkpaabyi ikpokpobha nnanga. Kaam nkk'ọtzọhm nda f'Ọvaar Ibinọkpaabyi ọtzọhm-m. Nkk'anọng p'Amalẹk mfha biphyir, mbiri mbọkha Agag kw'ode ọvaarnọng kwabẹ ndima ngwuna.
\v 21 Arim-egbong atzọk arukhimaan, ọmaana andaamogbodo akkakkapẹ p'afon k'ọgbọm, ifha bẹ atzima asi ẹjafọhni anang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ ka Gilgal.”
\p 
\v 22 Mẹ wọ, Samwẹl obhina bi,
\q1 “Kọ achibhi bi, Ọvaar Ibinọkpaabyi ọm-ọtzọkha ottemdaamiji ka nnanga nkwọmisẹ, ọmaana njafọhni,
\q2 ọyọhnga bi ọnọng ọhakha eho ọnang ndọhna s'Ọvaar Ibinọkpaabyi o?
\q1 Eho ọhahakha ejibhi ọtzam ẹyọhnga ẹja ọfọfọhni,
\q2 ndọhna ọbhabhaanga njibhi ọtzam nyọhnga iyaak s'erukhimaan-dim.
\q1 
\v 23 Da irẹrẹkhi ide mach'ẹkhọngkwuri ch'abọhkpakpa ọbhabhari,
\q2 for ogege ode mach'epyibha ch'ọkha ọtzatzaam.
\q1 Kọ akk'atzim p'Ọvaar Ibinọkpaabyi abhuma,
\q2 kwẹ kwọ osi kẹ obhum kọ mach'ọvaarnọng.”
\p 
\v 24 Mẹ wọ, Saul oben Samwẹl bi, “Kaam nkk'ẹkhọhngkwuri nsa. Kaam nkk'asana p'Ọvaar Ibinọkpaabyi, ọmaana ndọhna sọ mvọhkhi. Ira agbong-nọng paam bọ ajor-m, yina ira nsi kw'ọpaani bẹ e.
\v 25 Tzotzokhaan, bina mẹ anang-m k'ẹkhọngkwuri chaam, abira atzim-m akpa nnam, ifha mbiri mkpobha Ọvaar Ibinọkpaabyi.”
\p 
\v 26 Yina, Samwẹl oben-ẹ bi, “Kaam kọ abẹ kindọn mkpa nnam. Kọ akk'atzim p'Ọvaar Ibinọkpaabyi abhuma, mẹ wọ, Ọvaar Ibinọkpaabyi ọkk'ọ obiro obhuma mach'ọvaarnọng kw'Israẹl.”
\p 
\v 27 Mada Samwẹl ọbhakhi nnam bi ofona, Saul ọgban-ẹ k'owura-baba kwẹ, ọjaakhi.
\v 28 Samwẹl e, oben-ẹ bi, “K'ewu cha mayina, Ọvaar Ibinọkpaabyi okk'ẹvaar ch'Israẹl ọtzọkha ka mbọhk sọ, kẹ ọkk'chẹ ọn-ọtzọkha ọnang oyokh-ẹbaanga kwọ wani, kw'ọjibhi ọyọhng-ọ.
\v 29 Kẹ nwuma, kw'ode Abarada p'Israẹl ibhora komosi, ochibhi kwẹ komobiro obhona, kẹ ọnọngẹya kode, kw'ira ọn-ọsẹ-ẹ obhona ochibhi.”
\p 
\v 30 Saul obhina bi, “Kaam nkk'ẹkhọhngkwuri nsa. Yina, tzotzokhaan nang-m ikpokpobha k'itzitzikha s'adedennọng p'anọng paam, ọmaana k'itzitzikha s'anọng p'Israẹl. Kọ kwu mọtzọn ọkpa nnam, ifha kaam mkpobha Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ”
\v 31 Mẹ wọ, Samwẹl otzima Saul ọkpa nnam, wa Saul okpobha Ọvaar Ibinọkpaabyi.
\p 
\v 32 Mẹ wọ e, Samwẹl oben bẹ bi, “Bọng chen-m Agag kw'ode ọvaarnọng kw'abAmalẹk.”
\p Agag obina ttara ottembara okwu okhebha Samwẹl, ochibhi bi, “K'odik ọkkọkka, ọmmamma kw'obo dọk kode.”
\p 
\v 33 Yina, Samwẹl oben bi,
\q1 “Odem nwa kw'ọkkangkkaang kwọ ọkk'ọsa panọng va dọk kakhaam,
\q2 mando wọ, ọkka kwọ va dọk kọ́khaama k'ottem kwa panọng e.”
\m Mẹ wọ, Samwẹl ọtaabh Agag k'abir-ibiri k'itzitzikha s'Ọvaar Ibinọkpaabyi ka Gilgal.
\p 
\v 34 Mẹ wọ e, Samwẹl ofona ọbhana ka Rama, yina, Saul ovura ochina k'obhon kwẹ ka Gibea.
\v 35 Ttẹwọr mẹ, maa wa Samwẹl ope, Saul be ayok dọk kàre. Kaambi mẹ wọ, Samwẹl okk'owobha ka nkwu-osisi sa Saul. Wa ettem ẹmma Ọvaar Ibinọkpaabyi da osi Saul ọvaarnọng kw'Israẹl.
\c 16
\s1 Samwẹl obyengi Devid ana k'eho
\p 
\v 1 Wa ewu dani Ọvaar Ibinọkpaabyi oben Samwẹl bi, “Óbhir otzuma yan yina akwọbha nkwu-osisi sa Saul owowobha, da kaam nkk'ẹ mmuma mach'ọvaarnọng kw'Israẹl? Tzọkha ana p'ẹbọhk-nana akhe k'erukhimaanha chọ, abikhi orenga, kaam ndọhm-ọ ka Jẹsẹ kw'ofon Bẹtẹlẹhẹm. Kaam nkk'nnwa wani kwẹ kw'ijinọng ndekha bi, ode ọvaarnọng.”
\p 
\v 2 Yina, Samwẹl oben bi, “Kaam ńnenga yan nda o? Idikha Saul ọ́bhaang kwẹ, ófhu-m ofhu e.”
\p Ọvaar Ibinọkpaabyi oben bi, “Tzima ọbhaamnwa kwakwẹ atzima afona, apyiri ben-ẹ bi, ‘Nkk'nkwa bi nkwu mfọhni ẹja nnang Ọvaar Ibinọkpaabyi e.’
\v 3 Kọ bher Jẹsẹ okwu m'ẹjafọhni nduma, kaam ńdibh-ọ otzibh ọttọhk f'asi. Kọ ábyengi nwuma kwa ńgọhkh-ọ ana k'eho anang-m.”
\p 
\v 4 Samwẹl osi mach'Ọvaar Ibinọkpaabyi obeni. Mada opyiri ka Bẹtẹlẹhẹm, adenho p'obhon ojora bẹ mada bẹ arẹ-ẹ. Bẹ abọbh-ẹ bi, “Akwu k'odidir o?”
\p 
\v 5 Samwẹl obhina bi, “Oo o, k'odidiri wọ kwa kaam nkwu bi nkwu mfọhni ẹja nnang Ọvaar Ibinọkpaabyi. Mẹ wọ, bọng do for sabọng, akwu mọtza ọfọhni ẹja.” Mẹ wọ, osi Jẹsẹ ọmaana va pẹ p'ijinọng awur, obher bẹ ẹjafọhni.
\p 
\v 6 Mada bẹ apyiri kẹ, Samwẹl ore Eliyab ochibhi bi, “K'odik ọkkakka, ọnọng kw'Ọvaar Ibinọkpaabyi okk'otzekha bi, bẹ ábyengi ana k'eho obe m'itzitzikha s'Ọvaar Ibinọkpaabyi e.”
\p 
\v 7 Yina, Ọvaar Ibinọkpaabyi oben Samwẹl bi, “Kẹ k'eden ch'ode ọmaana ebe chẹ kàkkeri, okhuri bi kaam nkk'ẹ mmumma. Eden ch'Ọvaar Ibinọkpaabyi om-ore idik ede ngọmi ttara eden ch'ọnọngẹya ore. Da ọnọngẹya om-ore odik k'iyaan-iyaan, yina, Ọvaar Ibinọkpaabyi om-okkeri ettem.”
\p 
\v 8 Mẹ wọ, Jẹsẹ oyeri Abinadab, otzim-ẹ ọkwọbha Samwẹl k'itzitzikha. Yina, Samwẹl oben bi, “Ọvaar Ibinọkpaabyi oyok nwa kobiro otzekha.”
\v 9 Jẹsẹ on-obiro otzima Shama okwu, yina, Samwẹl obiro oben bi, “Kẹ rang kw'Ọvaar Ibinọkpaabyi obiro otzekha.”
\v 10 Wa Jẹsẹ otzim va pẹ p'ijinọng azenamfa ọkhọkha Samwẹl, yina, Samwẹl oben-ẹ bi, “Ọvaar Ibinọkpaabyi ọnọng ma kotzek e.”
\v 11 Mẹ wọ, ọbọbh Jẹsẹ bi, “Va pọ p'ijinọng p'akhaam biphyir bọ ma o?”
\p Jẹsẹ obhin-ẹ bi, “Oyok kw'ikhakhari owobh kẹ e, yina, kẹ om-okkeri arukhimaan e.”
\p Mẹ wọ, Samwẹl oben Jẹsẹ bi, “Tzọhm ọnọng otza oyer-ẹ, m'ẹwọr kówobha maa opyiri.”
\p 
\v 12 Jẹsẹ ọtzọhm anọng atza ayeri Devid okwu. Wa Devid ojibhi ka for, obiro ojibhi odikkobh, obiro ojibh ikkekkeri.
\p Mẹ wọ, Ọvaar Ibinọkpaabyi oben Samwẹl bi, “Kẹ wọ mẹ e, bina abyeng-ẹ ana k'eho.”
\p 
\v 13 Mẹ wọ, Samwẹl ọtzọkha ana p'otzim k'erukhimaanha obyeng-ẹ k'eho m'itzitzikha s'agbaanotte pẹ. Ttẹwọr m'ewu nduma, Egwugwuma ch'Ọvaar Ibinọkpaabyi ẹhakha ttara ẹfa ẹnwa Devid. Mẹ wọ, Samwẹl obina ọbhana ka Rama.
\s1 Devid owobh k'irekh-irek kwa Saul
\p 
\v 14 Wa Egwugwuma ch'Ọvaar Ibinọkpaabyi ekk'Saul ọbọhk ẹtta. Ọvaar Ibinọkpaabyi obiro ọtzọhm egwugwuma-tzama ẹyakh-ẹ atzim.
\p 
\v 15 Atzọhmnọng pa kẹ Saul aben-ẹ bi, “Kker e, egwugwuma-tzama ch'Ibinọkpaabyi ọtzọhmi dọ ẹm-ẹyakh-ọ aztim ma e.
\v 16 Tte itta kwaman ọtzọhm maman atzọhmnọng pẹ ma, mọtza oror ọnọng kw'ofha okhir ọgangaang. Mada egwugwuma-tzama nduma ẹ́nwọ-ọ, kẹ ókhir ọ́nang-ọ, for igaang-ọ.
\p 
\v 17 Mẹ wọ, Saul oben atzọhmnọng pẹ bi, “Bọng nor ọnọng kw'okpo ọgangaang okhikhir, achen-m.”
\p 
\v 18 Ọtzọhmnọng wani on-obhina bi, “Kaam nkk'nnwa kw'ijinọng kwa Jẹsẹ kw'ofon Bẹtẹlẹhẹm kw'okpo ọgangaang okhikhir nna e. Kẹ ode ọkkakkaama, ọmaana okkenggitza, ọkhaama ekkoji ch'etzim-gbaakha, obiro ojibh odikkobh. Ọvaar Ibinọkpaabyi obir owobha ttar-ẹ.”
\p 
\v 19 Mẹ wọ, Saul ọtzọhm akkaabh-nkkaabha ochena Jẹsẹ, oben bi, “Tzọhm nnwa kwọ Devid, kw'om-okkeri arukhimaan achen-m.”
\v 20 Mẹ wọ, Jẹsẹ ọtzọkha ẹnyanyaang ch'ọnan brẹd, ọmaana otzuk-gbere, ọmaana ovu-nwa ttara ka nnwa kwẹ Devid ọtzọhm ochena Saul.
\p 
\v 21 Devid okwu owobha k'irekh-irek kwa Saul. Ọdaak Saul idik m'ejibh-ejibha maa, Devid on-okwu ode otzim-egbongkpo kwẹ.
\v 22 Mẹ wọ, Saul ọtzọhm ẹkkaabha ọnang Jẹsẹ oben bi, “Tte Devid ọbọhk owobha ma osi ọtzọhm faam, okhuri bi, osi ettem ẹdaam-m.”
\p 
\v 23 Ogbe kpenamkpen kw'egwugwuma ch'efon k'Ibinọkpaabyi ẹnwa Saul, Devid ọm-ọtzọkha ọgangaang okhir. Yina for in-igaangi Saul, ọgbagbatzama nwa obiro ọttẹ-ẹ ọbọhk.
\c 17
\s1 Devid ọmaana Golayat
\p 
\v 1 Mẹ wọ, wa aPhilistiya ado for s'egbong. Bẹ ayeri agbong-nọng pabẹ atzobha ka Soko k'ẹkhọma cha Juda. Wa bẹ attima ibhingabe sabẹ k'Ẹphẹs-Damim, kw'owobh k'ottem kwa Soko ọmaana Azeka.
\v 2 Wa Saul ọmaana anọng p'Israẹl attima ibhingabe sabẹ k'ẹttẹri ch'Ela, bẹ atzari ọkpaama kwabẹ bi bẹ arima aPhilistiya abẹ.
\v 3 Wa aPhilistiya abe k'egbegbeho dani, anọng p'Israẹl abe k'egbegbeho ndongo, akhe ẹttẹr m'ottem.
\p 
\v 4 Okkengitza wani kw'okpen Golayat, kw'ofon Gat, ofona k'ibhingabe s'aPhilistiya oyin k'iyaan. Kẹ wa odumi ebe ọyọhnga ndọhkhi ọhawani.
\v 5 Wa kẹ ọfọr ikpo sa brons k'eho, obiro ọfọra egbong-nya cha bẹ atzim brons asi, py'epyiri ashẹkẹl nnọhna jobh obhiri mfa obhiri arọbh jobh.
\v 6 Ka mmo, okhe ekpo-pya-mmo pya brons, ka nnam, obiro orena ọkhọhn kw'ode brons.
\v 7 Ẹkhọhnmma ch'oyuk kwẹ eroni mach'irokka, epyiri ashẹkẹl ẹnọhna obhiri arọbh jobh. Otzim-ọkhọhnkpa kwẹ, otzima ọkhọhnkpa ochẹ-ẹ eden.
\p 
\v 8 Wa Golayat obe, obiro ọkpẹbh ngaan agbong-nọng p'Israẹl amọng, ọbọbh bi, “Ode yan kwa bọng ayini k'iyaan abe k'odik bi, bọng arima egbong o? Kaam wọ nde okkenggitza kw'aPhilistiya, bọbọng biphyir ade atzọhmnọng pa Saul. Bọng dekha ejinọng-dim chabọng oyin ka, ẹhakha ekwu erim-m abẹ.
\v 9 Idikha kẹ ofha orim-m abẹ, obiro ofhu-m, maman biphyir on-ode abira pabọng, yina, idikha kaam nnyọhng-ẹ mkpaan, mbiri mfhẹ-ẹ, maman óde abitta pabọng, bọbọng án-ade abira paman.”
\v 10 Mẹ wọ e, oPhilistiya-jinọng nwa oben bi, “Mayina, kaam nkkaar agbong-nọng p'Israẹl ẹmma. Bọng nang-m ojinọng kwa morima ayok abẹ.”
\v 11 Mada Saul omaana anọng p'Israẹl biphyir abhaang ọmma-kkakkaari kw'oPhilistiya-jinọng nwa ọm-ọnang bẹ, ojora bẹ, bẹ afọni ẹkpẹkpa biphyir.
\p 
\v 12 Devid kẹ wa ode nnwa kwa Jẹsẹ, kw'ofon k'obhon kw'Ẹphrat ka Bẹtẹlẹhẹm k'ẹkhọma cha Juda. Wa Jẹsẹ ọkhaam va p'ijinọng azenanttaan, obiro ode ọnọng kw'ọkk'ọtzama k'ogbe kwa Saul ọdabhi ẹvaar.
\v 13 Wa acheden va p'ijinọng attaan pa Jẹsẹ atzọni Saul abẹ atza egbong. Ocheden okpen Eliyab, ojemẹ okpena Abinadab, ottong attaan okpena Shama.
\v 14 Iwa Devid wọ ode okpong-nnam kw'ayok biphyir. Ayok mbanga anọng attaan p'akk'abara, bọ iwa atzọni Saul abẹ atza egbong,
\v 15 yina, wa Devid ọm-ọtza ka Saul ọkpa nnam otza okkeri arukhimaan p'otte ka Bẹtẹlẹhẹm.
\p 
\v 16 K'iwu arọbh afa oPhilistiya-jinọng nwa om-ofona k'ibhingabe sabẹ, okwu okkaar ẹmma ọnang anọng p'Israẹl.
\p 
\v 17 Wa Jẹsẹ oben nnwa kwẹ Devid bi, “Yoma ẹgbangbang-dim ch'abọkpa-bhabha attara ka brẹd jobh, atzima achena abagbaanatte ẹbhar-ẹbhar k'ibhingabe sabẹ.
\v 18 Kọ biri tzọhka abukpa k'obe jobh anang odenho kwabẹ. Abira atza are eden cha bẹ awobh kẹ, akpa nnam akwu agbaakh-m.
\v 19 Wa bẹ awobh kẹ da Saul owobh, ttara agbong-nọng p'Israẹl biphyir kẹnya ẹttẹri ch'Ela, am-arima aPhilistiya abẹ.”
\p 
\v 20 K'ekpekpebha Devid otte arukhimaan p'om-okkeri ọbọhk ọnang ọnọng kw'om-okkeri etzirakpo, ofona ọtza osi macha Jẹsẹ okk'obena. Wa opyiri k'ibhingabe da agbong-nọng am-ayin k'iyaan abe k'ọkpaama, bẹ am-awuri egbongmọng.
\v 21 Wa anọng p'Israẹl ọmaana aPhilistiya am-atzari akpaama, akkeri ayok itzitzikha.
\v 22 Wa Devid ọtzọkha ekpo py'otzim ọgbaara ọnọng kw'om-okkeri egbongkpo, ọrọbh ochina k'egbong-dam ọtza okhebha agbaanotte pẹ kẹ, orima bẹ.
\v 23 Mada Devid otzim-om-ọgbaak atzim ttara bẹ, Golayat kw'ode okkenggitza kwa Philistiya kw'ofon Gat oyin okwu obe m'akpaama. Ọkpẹbh amọng p'ọm-ọkpẹbh, Devid obe kẹ ọbhaanga.
\v 24 Mada anọng p'Israẹl are ojinọng nwa, ojora f'ideden osi bẹ biphyir, bẹ atzọr akpa nnam.
\p 
\v 25 Mẹ wọ, anọng p'Israẹl an-am-aben ayok bi, “Bọng am-are da ojinọng nwa om-oyin k'iyaan ogbe kpenamkpen o? Om-oyin okwu ọkkaara anọng p'Israẹl ẹmma e. Ọnọng kw'ofhu ojinọng nwa, ọvaarnọng ọ́nang-ẹ ikkọr s'ideden, óbiro ọ́nang-ẹ ominanwa kwẹ k'ọbada, óbiro ọ́rọbha otte kw'ọnọng nwuma k'atasi ọnanang k'Israẹl.”
\p 
\v 26 Mẹ wọ, Devid ọbọbh ajinọng p'abe abaang-ẹ bi, “Mbọng fa bẹ ási ánang ọnọng kw'ofhu oPhilistiya nwa, kw'óbiro ọ́rọbha anọng p'Israẹl ka mgbar nna o? Anyi wọ ode oPhilistiya nwa kw'oni ọkpakkọrikkọr osi, ọm-ọkkaara agbong-nọng p'Ibinọkpaabyi kw'orukhi akpen ẹmma o?”
\p 
\v 27 Bẹ abira agbaakh-ẹ mach'ira bẹ akk'am-agbaakha bi, “Ma wọ ode ọttọhk fa bẹ ási ánang ọnang kw'ófhu ojinọng nwa.”
\p 
\v 28 Mada Eliyab kw'ode ọgbaanọtte kwa Devid kw'ideden, ọbhaang da Devid om-ọgbaak atzim ọmaana ajinọng mba, ettem epyibh-ẹ etzima etzor-ẹ, ọbọbh-ẹ bi, “Mbọng vọ otzim-ọ okwu ma o? Kọ atte arukhimaan p'an-akkọri ọbọhk k'ibe s'anọng anarukhi anang anyi bi, okker o? Kaam nnong odem kw'age for, abira apyibh achibhi kẹ, akwu bi akwu are egbong nda e.”
\p 
\v 29 Mẹ wọ, Devid ọbọbh bi, “Bọng odik wọ kwa nso o, ode bi, kaambi atzim bọ, nningi mgbaak o?”
\v 30 Devid on-obina ọjẹ-ẹ mẹ, ochina k'ọnọng ọdọdọk ọgbaak odik nwuma wani, ajinọng mbuma abira anang-ẹ ebhina nduma dani ch'ira ayok anang-ẹ.
\v 31 Wa bẹ abhaanga odik kwa Devid ọgbaakhi, bẹ afona atza agbaak Saul. Saul e, ọtzọhm bẹ ayeri Devid achen-ẹ.
\p 
\v 32 Devid oben Saul bi, “Tte ọnọng manda wani oning-ẹ ojor okhuri oPhilistiya-jinọng nwa, kaam ọtzọhmnọng kwọ ńda ọtza nda nnim-ẹ abẹ.”
\p 
\v 33 Saul on-obhina Devid bi, “Atta o, kọ atzima ade nnwa-nnwa e, kọ ẹfa kakhaam ch'atza arima oPhilistiya-jinọng nnwa abẹ e, kẹ ọkk'ọttẹwọr k'edikkobh chẹ om-orima nnima e.”
\p 
\v 34 Yina, Devid obhina Saul bi, “Kaam ọtzọhmnọng kwọ, mmi nkkeri arukhimaan p'otte kwaam. Ogbe kw'ekye ekwu, obiro ode okyenyam wọ okwu bi, ọkwu ọbọkha orukhimaan wani k'arukhimaan pa ndim,
\v 35 kaam e, ngwubh chẹ maa mbọkha chẹ k'iphyubha, nnọbha orukhimaan k'ẹmma chẹ, mbiri nttum chẹ mfhu.
\v 36 Kaam ọtzọhmnọng kwọ nkk'ekye, ọmaana okyenyam ifha, mando wọ kw'óde ttara oPhilistiya-jinọng nwa kw'oni ọkpakkọrikkọ osi, okhuri bi, kẹ okk'agbong-nọng p'Ibinọkpaabyi kw'orukhi akpen olukhi kpọng-kpọng.
\v 37 Ọvaar Ibinọkpaabyi kw'iwa ọrọbh-m ka mbọhk s'ekye, ọmaana ka mbọhk s'okyenyam, kẹ ọ́rọbh-m ọ́rọbha ka mbọhk s'oPhilistiya-jinọng nwa.”
\p Mẹ wọ e, Saul oben Devid bi, “Rọhng, tte Ọvaar Ibinọkpaabyi owobha ọttar-ọ.”
\p 
\v 38 Saul ọtzọkha ọnọhma-baba kwẹ ọfọra Devid. Ọtzọkha egbong-nya chẹ, ọmaana ikpo s'ide brons ọfọra k'eho.
\v 39 Devid ọtzọkha ọkkaangkkaang kwa Saul ọdaabh k'erin, mada okhong bi orenga, kofha orenga, okhuri da ekpo mbya ẹn-ẹkpaang.
\p On-oben Saul bi, “Kaam ekpo mbya kimfha ndima nnenga e.” Mẹ wọ, ọwọra pyẹ.
\v 40 Mẹ wọ, ọtzọkha ochikhura kwẹ, ochina k'ehekha otzekha atza azen p'akwọhng-ọkwọhnga k'ẹttẹri, okhe bẹ k'ẹkpa ch'ọbhaak, obiro ọtzọkha ibhar-atza sẹ otzima k'ọbọhk orenga otzor oPhilistiya-jinọng nwuma ka for.
\p 
\v 41 Ayongi mẹ, oPhilistiya-jinọng nwa, otzim-ọkhọnkpa kwẹ om-orenga k'itzitzikha otzor Devid ka for.
\v 42 Mada oPhilistiya-jinọng nwa ore bi, Devid ode nnwa-nnwa, kw'ojibhi odikkobh obiro ojibh ka for, ọn-ọrẹ-ẹ ọkhara.
\v 43 Oben Devid bi, “Ngeri ẹpfa k'itzitzikha sọ ọ, kw'atzim nchi bi, akwa arim-m abẹ?” Mẹ wọ, oPhilistiya-jinọng nwa otzima che p'akha pẹ ọsaakhi Devid.
\v 44 OPhilistiya-nọng nwa oben bi, “Renga baang-m ka, mbọkh-ọ, ndọkha ayaara pọ pa for nnang ọnọhn f'ẹrọng, ọmaana nden s'ẹtzam.”
\p 
\v 45 Devid e, obhina oPhilistiya-jinọng nwa bi, “Kọ atzim ọkkangkkaang, ọmaana oyuk ttara ọkhọhn bi, akwu arim-m abẹ, yina, kaam nkwu ttara che ch'Ọvaar Ibinọkpaabyi kw'Ẹfa biphyir, kw'ode Ibinọkpaabyi kw'agbong-nọng p'Israẹl, pa kọ am-akkaara ẹmma.
\v 46 Mẹ wọ, mayina, Ọvaar Ibinọkpaabyi ọ́tzọkh-ọ ókhe-m ka mbọhk, ifha kaam ḿfhọ-ọ, ḿbiri ḿkpaara eho chọ. Mayina, kaam ńdọkha abukhi p'agbong-nọng mba p'aPhilistiya ńnang ọnọhn f'ẹrọng, ọmaana nden s'ẹtzam, ifha ọyagbin biphyir óronga bi, Ibinọkpaabyi kw'anọng p'Israẹl owobh kẹ.
\v 47 Anọng mba biphyir p'atzobh ma, aronga bi, ọkkangkkaang ọmaana ọkhọhn araang p'Ọvaar Ibinọkpaabyi om-otzima ọkkaana anọng, da erima nda ede ch'Ọvaar Ibinọkpaabyi, kẹ wọ ọ́tzọkha bọng ókhe man ka mbọhk.”
\p 
\v 48 Mada oPhilistiya-jinọng nwa oreng ọbaanga bi orima Devid abẹ, Devid ọn-ọrọbh otzor-ẹ ka for k'ọkpaama.
\v 49 Devid ọnọhma ọbọhk k'ẹkpa chẹ ọrọbha ọtza okhe k'ibhar-atza sẹ, ọtzọbh oPhilistiya-jinọng nwa m'itzitzikha-ttem. Ọtza nwuma otzor-otzor ọnwẹ-ẹ k'itzitzikha-ttem, otto okhubha itzitzikha m'irerek.
\p 
\v 50 Mẹ wọ, wa Devid otzima ibhar-atza sẹ-sẹ ọmaana ọtza okhema oPhilistiya-jinọng nwa, kaambi da iwa oni ọkkangkkaang otzim, wa okhebha mẹ ọfhẹ-ẹ.
\p 
\v 51 Devid ottima ẹbhar otza okhebh-ẹ kẹ da otto, ọrọbha ọkkangkkaang kw'oPhilistiya-jinọng nwuma k'ọpa kwẹ. Mẹ wọ, otzima ọkkangkkang nwuma ọkpaar-ẹ eho \it bi tteng. \it*
\p Mẹ wọ, mada aPhilistiya an-are bi, okkenggitza kwabẹ ọkk'ọpa, bẹ abhakhi nnam arọbh.
\v 52 Mẹ wọ, ajinọng p'Israẹl ọmaana pa Juda am-awuri amọng, achina ororo akhubh aPhilistiya ka nnam maa, bẹ atza apyiri k'ebhonho cha Gat, ọmaana mbaakhamma s'Ẹkrọn. Abukhi pabẹ ayima m'ọkkadeden kw'achin Sharayim maa apyiri Gat ọmaana Ẹkrọn.
\v 53 Mada anọng p'Israẹl akpa nnam kẹ da bẹ akhubhi aPhilistiya, bẹ atzima ẹkhakhaama ch'ẹhaabh-ọhaabh cha bẹ achi ọgbọm atzima afona k'ibhingabe s'aPhilistiya, akhuna.
\p 
\v 54 Wa Devid otzima eho ch'oPhilistiya-jinọng nwuma, ọbhana ka Jẹrusalẹm, ọtzọkha egbongkpo py'oPhilistiya-jinọng nwa, ohok k'ikhira sẹ.
\p 
\v 55 Mada Saul ore da Devid om-ofona bi, otza orima oPhilistiya-jinọng nwa abẹ, wa ọbọbh Abnẹr kw'ode odenho kw'agbong-nọng bi, “Odikkobh nwa ode nnwa kw'anyi o?”
\p Abnẹr obhina bi, “O ọvaarnọng, k'odem kw'arukhi akpen, kaam otte kwẹ kinnong e.”
\p 
\v 56 Mẹ wọ, ọvaarnọng oben bi, “Rọhng atza aronga ọnọng kw'ode otte kw'odikkobh nnwa nwa.”
\p 
\v 57 Mada Devid ofon kẹ da ofhu oPhilistiya-jinọng nwa okhuna \it bi, kpaar\it*, Abnẹr otzim-ẹ k'ọbọhk ochena Saul, da otzim-otzim eho ch'oPhilistiya-jinọng nwa ma mbọhk.
\p 
\v 58 Mẹ wọ e, Saul ọbọbh-ẹ bi, “Odikkobh, kọ ade nnwa kw'anyi?”
\p Devid obhina bi, “Kaam nde nnwa kw'ọtzọhmnọng kwọ Jẹsẹ, kw'ofon Bẹtẹlẹhẹm.”
\c 18
\s1 Saul ọkhaam ottemmamma ttara Devid
\p 
\v 1 Mẹ wọ, mada Devid okk'atzim okyera ọgbagbaak ttara Saul, Jonatan e, ọbọkha Devid ittem-yok. Devid ọn-ọdaakh-ẹ macha for sẹ idaakh-ẹ.
\v 2 Ttẹwọr mẹ ewu nduma, Devid on-oruk ọmaana Saul, wa Saul dọk kokher bi, Devid ọbhana k'otte k'ọhọhm.
\v 3 Wa Jonatan ọtzọkha echekhi ọmaana Devid, okhuri idadaakha s'ọkhaam ttara Devid.
\v 4 Mẹ wọ, Jonatan ọwọra ọnọhma-baba kw'ọfọr ka for, ọmaana ẹnya ẹdọdọk, ọmaana ọkkangkkaang, akwu attara k'oyuk, ọmaana mkpansin kwẹ, ọtzọkha ọnang Devid.
\p 
\v 5 Wa Devid om-osi kpenamkpen fa Saul ọtzọhm-ẹ k'eden ọkkakka, ofona mẹ, Saul ọsẹ-ẹ odenho kw'agbong-nọng. Wa odik nwa ọdaam anọng biphyir, ttara akhaan-nọng pa Saul ettem.
\p 
\v 6 Mada ajinọng mba am-akhuna da Devid okk'okkenggitza kw'aPhilistiya ọfha, panọng k'ibhon s'Israẹl biphyir, an-abina ttara ọkkọhna kw'ọdadaami ọmaana otzubha, ọmaana mbin, ttara agaangaang atza akhebha ọvaar Saul.
\v 7 Mada bẹ atzubhi, bẹ akkọhn aben bi,
\q1 “Saul okk'nnọhna sẹ ọfha,
\q2 Devid okk'nnọhna-nabhik sẹ ọfha.”
\p 
\v 8 Wa Saul ẹmọng nda kẹ kẹdaakhi, ọdọkh-ẹ kpọng-kpọng da ochibhi bi, “Bẹ akk'Devid atzọhnga ttara che cha nnọhna-nabhik, yina, kaam bẹ atzọhng-m ttara nnọhna sẹ-sẹ. Mbọng vọ on-orik oyongi bi okyera ẹvaar nda ọtzọkha!”
\v 9 Ttẹwọr m'ewu nduma, Saul ọn-ọkhaama ottemmamma otzima otzor Devid.
\p 
\v 10 Ewu ch'ejem mẹ, egwugwuma-tzama ch'efon k'Ibinọkpaabyi ẹnwa Saul itzama-itzama. Wa kẹ ọm-ọgbaak aborokko k'ọhọhm kwẹ, Devid om-okhir ọgaang-gaang ọnang-ẹ mach'om-okkekkeni okhir. Wa Saul otzim ọkhọhn k'ọbọhk kwẹ.
\v 11 Saul ọbhari ọkhọhn nwa, ochibhi k'ettem chẹ bi, “Ńgum Devid mmaana k'echumi.” Yina, wa Devid ọrọbh ọnaanga k'igbe manda ifa.
\p 
\v 12 Wa Devid on-ojora Saul, okhuri da Ọvaar Ibinọkpaabyi on-owobh ọmaana Devid, yina, okk'Saul ọbọhk ọtta.
\v 13 Mẹ wọ, wa Saul okhubh Devid k'ọhọhm kwẹ, ọn-ọsẹ-ẹ odenho kw'agbong-nọng p'ayongi anọng nnọhna mfa obhiri arọbh jobh. Wa Devid om-otzima agbong-nọng mba eden, bẹ atza mgbong akhuna.
\v 14 Ọttọhk kpenamkpen f'iwa Devid osi om-ojibh-ojibh, okhuri da iwa Ọvaar Ibinọkpaabyi owobh ttar-ẹ.
\v 15 Mada Saul ore bi ọttọhk kpenamkpen fa Devid osi om-ojibh-ojibh, wa Devid ojora Saul.
\v 16 Yina, wa Devid ọdaakhi anọng p'Israẹl ọmaana pa Juda biphyir idik, okhuri da iwa om-otzima agbong-nọng ọtza egbong akhuna.
\p 
\v 17 Mẹ wọ, Saul oben Devid bi, “Kkeri Mẹrab kw'ode ocheden-nwa kwaam kw'ikwanọng ma. Kaam ńdọkh-ẹ ńnang-ọ k'ọbada, ka ntak bi, kọ si ọtzọhm anang-m mach'okkenggitza, abira arima mgbong s'Ọvaar Ibinọkpaabyi.” Wa Saul ochibhi, oben k'ettem bi, “Kaam kẹ ọbọhk kwaam kínttọmi. Tte aPhilistiya afhẹ-ẹ!”
\p 
\v 18 Mando kwa Devid on-obeni Saul bi, “Akpen paam ape mbọng o, echimma chaam, ọmaana efonamma chaam ade bọng anọng m'Israẹl o, kw'ira kaam nna nde ọnyẹ kw'ọvaarnọng o?”
\v 19 Mẹ wọ e, mada on-opyiri m'ogbe kw'ira ọbaan bi, bẹ an-atzọkha Mẹrab kw'ode ominanwa kwa Saul, anang Devid k'ọbada, bẹ an-atzọkh-ẹ anang Adriyẹl kw'ofon Mẹhola, k'ọbada.
\p 
\v 20 Wa Devid okwu ọdaak Mikal kw'ode nnwa kwa Saul kw'ikwanọng. Mada Saul ọbhaang odik nwa, ettem ẹdaam-ẹ.
\v 21 Saul on-ochibhi k'ettem bi, “Kaam ńdọkha Mikal ńnang-ẹ k'ọbada, ifha ndim-ẹ nsi otzena, ttara bi aPhilistiya afha arenga mẹ, afhẹ-ẹ.” Mẹ wọ, Saul on-oben Devid bi, “Kọ akk'ọphaangi ọdọdọk abira akhaama bi, ade ọnyẹ kwaam e.”
\p 
\v 22 Wa Saul ọtzọhn akhaan-nọng pẹ bi, “Bọng nọng atza agbaak Devid atzim k'ide-afa, aben bi, ‘Kkeri ka e, kọ adaakhi ọvaarnọng idik kpọng-kpọng e, mando kw'abira adaak akhaan-nọng pẹ biphyir idikh e, mẹ wọ, kọ khera bi, áde ọnyẹ kwẹ ode.’ ”
\p 
\v 23 Wa bẹ agbaak Devid odik kwa Saul ọtzọhni bẹ bi, bẹ agbaakh-ẹ. Yina, wa Devid oben bẹ bi, “Kwẹ okheri bọng ididikha k'achibhi pabọng bi, ọnọng ode ọnyẹ kw'ọvaarnọng o? Kaam mach'anyi o? Kaam nde ogbogbora e, anọng kaam kabira aronga.”
\p 
\v 24 Mada akhaan-nọng pa Saul agbaakh-ẹ eden cha Devid ọgbaakhi bẹ,
\v 25 Saul on-oben bi, “Bọng ben Devid bi, ‘Ọvaarnọng, imina ọdọdọk korori e, oyongi mkpatzọr arọbh azen s'aPhilistiya, ifha otzima otzukha idik s'attattaanga-nọng pẹ akk'ẹ asa.’ ” Wa Saul ọkhami bi, aPhilistiya afhu Devid.
\p 
\v 26 Mada akhaan-nọng pa Saul agbaakhi Devid idik nna, wa ettem ẹdaam-ẹ bi, kẹ ón-ode ọnyẹ kw'ọvaarnọng. Mẹ wọ, yina ogbe kw'ọkhẹ-ẹ opyiri,
\v 27 Devid ọmaana agbong-nọng pẹ abina atza afhu aPhilistiya arọbh jobh, otzima mkpatzọr sabẹ biphyir ochena ọvaarnọng, ifha on-ode ọnyẹ kw'ọvaarnọng. Mẹ wọ, Saul ọtzọkha nnwa kwẹ Mikal ọnang Devid k'ọbada.
\p 
\v 28 Mada Saul okwu otzin bi, Ọvaar Ibinọkpaabyi owobh ttara Devid, ọmaana bi, nnwa kwẹ Mikal, Devid ọdaakh-ẹ ọdaak,
\v 29 Saul e, Devid ọn-ọdẹ-ẹ ojor-ojora, on-obiro ohok Devid k'ittattaanga k'akpen pẹ biphyir.
\p 
\v 30 Wa adenho p'agbong-nọng p'aPhilistiya achina ororo atza egbong, yina, k'ogbe kpenamkpen kwa bẹ atza, Devid ọm-ọkhaama ọwọbh ọtzam ọyọhnga akhaan-nọng pa Saul biphyir, ofona mẹ, Devid ọn-ọtza che.
\c 19
\s1 Saul okhong bi ofhu Devid
\p 
\v 1 Iwa Saul ọgbaakhi nnwa kwẹ Jonatan, ọmaana akhaan-nọng pa kẹ Saul biphyir bi, bẹ afhu Devid. Yina, da wa Jonatan osi Devid oyokh-odikkobh-ttem chẹ,
\v 2 Jonatan ọn-ọtzọr Devid itzọhng, oben-ẹ bi, “Otte kwaam Saul ọm-ọkham bi, ọfhọ-ọ e. Kker-ọ for o, ophyini k'ekpebha ror eden arọbh, atza aror ibe achubha.
\v 3 Kaam ńdọn otte kwaam abẹ, mbẹ-ẹ mẹ ẹbhabhaanga m'ibe s'achubh, ḿgbaakh-ẹ odik okhuri kọ, ifha ńkwu ḿgbaakh-ọ ebhina chẹ.”
\p 
\v 4 Wa Jonatan ọgbaak ejibha cha Devid ọnang otte Saul, oben-ẹ bi, “Kọ ọvaarnọng, ọtzọhmnọng kwọ Devid itzama kàsi, okhuri bi, kẹ kọ itzama kosi, ayongi mẹ, kọ akk'iru s'ideden atzọkha k'idik s'ọkk'ọsa.
\v 5 Kẹ wa okher obo k'ogbe kw'ofhu oPhilistiya nwa. Wa Ọvaar Ibinọkpaabyi ọnang anọng p'Israẹl biphyir ekhema, ch'atzim chen pọ are, ettem ebire ẹdaam-ọ. Ira on-orenga yan kọ asi ọnọng macha Devid kw'oni ottotto ọkhaam itzama, am-abira achibhi bi afhẹ-ẹ o?”
\p 
\v 6 Wa Saul okhera odik kwa Jonatan ọgbaakhi, ọtzọkha ọnwọhngi oben bi, “K'odik ọkka kw'Ọvaar Ibinọkpaabyi kw'orukhi akpen, bẹ Devid káfhu.”
\p 
\v 7 Mẹ wọ, Jonatan oyeri Devid ọgbaakh-ẹ idik nna biphyir, otzim-ẹ ọkpa nnam ka Saul, wa Devid obiro oruk ttara Saul mach'iwa orukhi.
\p 
\v 8 Wa egbong ebire etto, Devid ọtza orima aPhilistiya abẹ, ofhu bẹ k'ọhaabh maa, bẹ arọbh ajẹ-ẹ.
\p 
\v 9 Yina, mada Saul owobh ẹwọr k'ọhọhm kwẹ ọmaana ọkhọhn kw'otzim k'ọbọhk, wa Ọvaar Ibinọkpaabyi otte egwugwuma-tzama ọbọhk ẹnwẹ-ẹ. K'ogbe kwa Devid om-okhir ọgaang-gang,
\v 10 Saul okhonga bi, okhum-ẹ ọkhọhn ọmana k'echumi, yina, wa Devid ọrọbh ọnaanga. M'erungiwu nduma Devid ọrọbh ọnaanga, ọkkaana akpen pẹ.
\p 
\v 11 Wa Saul ọtzọhm ajinọng bẹ atza abaabha ọhọhm kwa Devid m'erungiwu nduma, ifha bẹ afhẹ-ẹ k'ekpebha. Yina, wa Mikal, kw'ode kwanọng kwa Devid, ọtzọr odim Devid itzọhng bi, “Idikha an-arori bi ape m'erungiwu cha mayina, arọbh akkaana akpen pọ, ophyini bẹ afhọ-ọ ofhu e.”
\v 12 Mẹ wọ, Mikal orenga ka ọmma kw'ikhakhari kw'echumi ọkkaana Devid. Devid ọrọbh ọnaanga.
\v 13 Mikal e, ọn-ọtzọkha ọgbatza oruri k'eyima, ọtzọkha ẹnọhmakpa obubh-ẹ, obiro ọtzọkh-ẹ ọnana eho k'ichikhuma s'ivu-phyubha.
\p 
\v 14 Mada Saul ọtzọhmi ajinọng mba bi, bẹ atza abọkha Devid, Mikal ọgbaak bẹ bi, “Devid ọmmẹ-ẹ ọmma e.”
\p 
\v 15 Mẹ wọ, Saul ọtzọhm ajinọng mbuma bẹ akpa nnam ka Devid, oben bẹ bi, “Bọng din-ẹ k'eyima chẹ ch'oyim achen-m, ifha mfhẹ-ẹ.”
\v 16 Yina, mada ajinọng mba an-adimi k'ọhọhm kwa Devid, bẹ atza are bi, ọgbatza kw'ọnan eho k'ichikhuma s'ivu-phyubha wọ oyim kẹ.
\p 
\v 17 Wa Saul ọn-ọbọbh Mikal bi, “Ode yan kw'abọr-m manda maa, asi ọttattaanga-nọng kwaam ọrọbh o?”
\p Mikal obhin-ẹ bi, “Kẹ oben-m bi, ‘Idikha nnẹ-ẹ ọbọhk ntte ọrọbh, kẹ ófhu-m ófhu.’ ”
\p 
\v 18 Mada Devid ọkk'ọrọbha otza okhebha Samwẹl ka Rama, ọtzọkha odik kpenamkpen kwa Saul ọkk'ẹ ọsa ọgbaakh-ẹ. Mẹ wọ, kẹ ttara Samwẹl bẹ afona achina ka Naiyọt atza aruk kẹ.
\v 19 Wa ẹkkaabha epyiri Saul, bẹ agbaakh-ẹ bi, “Devid orukhi ka Naiyọt k'okhubha kwa Rama e.”
\v 20 Mẹ wọ, wa Saul ọtzọhm akkaabh-nkkaabha bi, bẹ atza abọkha Devid achen-ẹ. Yina, mada bẹ apyiri kẹ, bẹ are da ẹkhaan ch'asi-ẹjaakhi am-agbaak ettem ch'Ọvaar Ibinọkpaabyi, ọmaana Samwẹl kw'obe mẹ mach'otzim eden kwabẹ, Egwugwuma ch'Ibinọkpaabyi ẹhakha ẹnwa ajinọng mba pa Saul, bẹ abira agbaak ettem ch'Ọvaar Ibinọkpaabyi.
\v 21 Wa Saul ọbhaanga odik nwa, obiro ọtzọhm akkaabh-nkkaabha adọdọk p'ahaabhi ayọhnga p'ira ochenden ọtzọhm, ayok mba abira agbaak ettem ch'Ọvaar Ibinọkpaabyi. Mẹ wọ e, Saul obir ọtzọhm ẹkhaan ch'ettong nttaan, bẹbẹ abira agbaak ettem ch'Ọvaar Ibinọkpaabyi mach'ayok.
\v 22 K'ekponga-nnam kẹ ọkhaam ma for sẹ on-obina ochina ka Rama k'esipe ch'ideden ch'ewobh ka Seku. Mada opyiri kẹ, ọbọbh bi, “Man kwa Samwẹl ọmaana Devid bẹ awobh o?”
\p Bẹ abhina bi, “Bẹ awobh ka Naiyọt ka Rama e.”
\p 
\v 23 Mẹ wọ, Saul ofona ochina ka Naiyọt k'ẹkhọma cha Rama. Yina, Egwugwuma ch'Ibinọkpaabyi ẹhakha ẹnwa Saul dọk, ọttẹwọr mẹ da oreng osi ẹjaakhi maa opyiri ka Naiyọt.
\v 24 Wa ọwọra ọnọhma-baba kwẹ, osi ẹjaakhi m'itzitzikha sa Samwẹl. On-oyima ikpakpadukhi k'erungiwu nduma, ọmaana ẹya nduma biphyir. Kẹ wọ osi anọng an-am-abọbh bi, “Ode bi Saul kẹ obiro ode wani k'ottem kw'asi-ẹjaakh o?”
\c 20
\s1 Devid ọmaana Jonatan
\p 
\v 1 Mẹ wọ, Devid ọrọbh ka Naiyọt k'ẹkhọma cha Rama, otza okhebha Jonatan, ọbọbh-ẹ bi, “Bọng odik kwa kaam nsi o? Kaam nji bọng odikh o? Bọng itzama rọ sa kaam nsi atte, kw'ọm-ọkham bi ofhu-m o?”
\p 
\v 2 Jonatan obhin-ẹ bi, “Kwẹ mando kode! Kọ ópe-ope kape! Tte mgbaakh-ọ e, odik kode kw'otte kwaam ọkhami bi osi, kw'ọn'aam ọm-ọgbaak. On-orenga yan odubh-m nwa o? Kwẹ mando kode!”
\p 
\v 3 Yina, Devid ọnwọhngi oben bi, “K'odik ọkkakka, atte orong eden cha kaam ndaakh-ọ idik mpyiri kẹ e, kẹ okk'obena k'ettem bi, ‘Jonatan kọkhaambi oronga odik nwa, oni mando ode, ettem kẹ kẹ́daam.’ Yina, odem nwa kw'Ọvaar Ibinọkpaabyi orukhi akpen, ọmaana odem nwa kwa kọ abira aruk akpen, kaam nna nwobh k'ottem kw'obo ọmaana akpen e.”
\p 
\v 4 Jonatan oben Devid bi, “Odik kpenamkpen kw'abeni bi nsi, kaam ńsi-osi ńnang-ọ.”
\p 
\v 5 Mẹ wọ, Devid oben Jonatan bi, “Jima bi, ophyini wọ ode ẹdadaamiwu ch'ophe ọbhakwẹ, kw'ira ọbaana bi, kaam nchi ọchattọhk ttara ọvaarnọng. Yina, tte nda nchubha k'owoni maa opyiri ophyini k'ẹchọhkha.
\v 6 Idikha atte ọbọbh-ọ kaam, gbaakh-ẹ bi, ‘Ira Devid ọtzọk ẹfa bi, nttẹ-ẹ ọbọhk ọtza ka Bẹtẹlẹhẹm kw'ode obhon kwẹ, okhuri da bẹ am-afọhni ẹja cha cho k'ẹhọhmmọr chẹ.’
\v 7 Idikha obeni bi, ‘Ojibhi kẹ,’ oyini bi, odik kode. Yina, idikha ettem epyibh-ẹ, ronga bi, ọkhami itzima k'ettem otzima otzor-m.
\v 8 Kọ si ejibha atzima atzor kaam ọtzọhmnọng kwọ, atzor k'echekhi ch'akk'asa ttar-m, k'itzitzikha s'Ọvaar Ibinọkpaabyi. Idikha aponga apyibh-m, kọ fhu-m ka for sọ! On-orenga yan kw'an-atte-m ọbọhk anang atte ofhu o?”
\p 
\v 9 Jonatan oben bi, “Kwẹ mando kode! Ode bi kaam mmaang yabhi-yabhi bi, otte kwaam ọkhami bi, ọfhọ-ọ, kọ kímgbaakh o?”
\p 
\v 10 Devid ọn-ọbọbh Jonatan bi, “Kaam ńnenga yan ńnonga, idikha ira atte obhin-ọ k'idọdọhkhi?”
\p 
\v 11 Jonatan oben Devid bi, “Kọ kwu mochina k'owoni.” Iwa bẹ atzọn achina k'owoni.
\p 
\v 12 Mẹ wọ, Jonatan oben Devid bi, “Kaam nwọhngi k'itzitzikha s'Ọvaar Ibinọkpaabyi kw'ode Ibinọkpaabyi kw'Israẹl bi, k'iwu ifa k'itzitzikha kaam ḿgbaak otte kwaam odik nwa ọgbaak. Idikha kẹ ọkhaam ochibhi ọkkakka okhur-ọ, kaam ńnsọ-ọ ósi aronga.
\v 13 Yina, idikha otte kwaam ọkhami bi ọsọ-ọ itzama, kaam ńnsọ-ọ osi aronga, kaam mbiri nkkaan-ọ ọkkaana bi arọbh afona. Tte Ọvaar Ibinọkpaabyi ọnang kaam Jonatan ettuma ch'ẹbaan-m, nni mando nsi. Tte Ọvaar Ibinọkpaabyi owobha ttar-ọ, mach'okk'owobha ttara otte kwaam.
\v 14 Yina, kọ khọkh-m idadaakha s'idum eden macha s'Ọvaar Ibinọkpaabyi, atzor k'odem kwa ńnuk akpen nduma, ifha bẹ aningi kaam afhu.
\v 15 Kọ idadaakha sọ kàkpaara k'ẹhọhmmọr chaam, kaambi k'ogbe kw'ikhina Ọvaar Ibinọkpaabyi okk'attattaanga-nọng pa kọ Devid biphyir odimi m'ọyagbin wọ.”
\p 
\v 16 Mẹ wọ, wa Jonatan osi echekhi ttara ẹhọhmmọr cha Devid, oben bi, “Tte Ọvaar Ibinọkpaabyi ọnang attattaanga-nọng pa kọ Devid ettuma ch'ẹbaan bẹ.”
\v 17 Wa Jonatan oben Devid bi obiro ọtzọkha ọnwọhngi k'idadaakha sa kẹ Devid ọkhaam ttar-ẹ, okhuri da iwa Jonatan, Devid ọdaakh-ẹ macha fọr sa kẹ ọkhaam.
\p 
\v 18 Wa Jonatan oben Devid bi, “Ophyini wọ ode ọdadaami kw'ophe ọbhakwẹ. Anọng árong-óronga bi kọ kade, da ọnọng oni ẹwọr k'ogbera kwọ ówobha.
\v 19 K'ẹchọhkha ch'iwu ifa k'itzitzikha, rọhng k'ibe nnuma s'iwa achubh mada odik nnwa ọttẹwọr, achubha mẹ ọtza kw'Ẹzẹl atzik.
\v 20 Kaam ńtta ayuk attaan k'okhubha wani kw'ọtza nwuma, macha ngami bi ntta ọttọhk.
\v 21 Mẹ wọ, ńdọhm odikkobh, mben-ẹ bi, ‘Rọhng atza aror ayuk mba.’ Idikha abhaang da mben-ẹ bi, ‘Kkeri bẹ k'ọbọhk nwana, rọhng atza atzima bẹ akwu,’ kw'oyini bi, mbeni bi tte kọ akwu, okhuri bi, k'odik ọkkakka kw'Ọvaar Ibinọkpaabyi kw'orukhi akpen, kọ akk'anaanga, itzama kibiri ìde.
\v 22 Yina, idikha mbeni odikkobh nwa bi, ‘Kker e, ayuk mba awobh ayongi mẹ da abe,’ kw'oyini bi, kọ akhaambi afona, okhuri bi, Ọvaar Ibinọkpaabyi ọkk'ọsa bi, kọ arọbh anaanga.
\v 23 Yina, odik okhuri echekhi cha mọtzọk kàrama o, bi Ọvaar Ibinọkpaabyi wọ ode owobh-ore kwa kaam ọmaana kọ, maa ogbe ode.”
\p 
\v 24 Mẹ wọ, wa Devid ochubha k'owoni. Mada ọdadaami kw'ophe ọbhakwẹ opyiri, ọvaar Saul otza owobha ẹwọr bi, ochi ọchattọhk.
\v 25 Wa ọvaarnọng owobha ẹwọr mach'ẹmmaana ede, okkeri Jonatan itzitzikha, Abnẹr owobha ọbaanga Saul, yina, wa ọnọng kw'owobh k'ogbera kwa Devid kode.
\v 26 Saul odik m'ewu nduma kọ̀gbaakhi, da ochibhi bi, “Asimẹ odik ọkk'ọtta okhebha Devid kw'ọsẹ-ẹ ochibhi bi, kẹ kowuri k'odem kw'ira kw'osi ọdadaami nwa, k'odik ọkkakka, kẹ kowuri k'itzitzikha s'Ibinọkpaabyi.”
\v 27 Yina, ewu ehobh mẹ ch'ettong iwu ifa s'ọdadaami nwuma, Devid kobiro okwu bi, okwu owobha ẹwọr k'ogbera kwẹ. Wa Saul ọbọbh nnwa kwẹ Jonatan bi, “Ode yan kwa nnwa kwa Jẹsẹ on-ode iwu ifa ma ẹwọr ma kowobh bi, ochi ọchattọhk ttara man, ikhena ma kode, mayina ma kobiro ode dọk?”
\p 
\v 28 Jonatan obhina Saul bi, “K'odik ọkka Devid ọtzọk ẹfa ophyem-m bi, nttẹ-ẹ ọbọhk ọtza ka Bẹtẹlẹhẹm.
\v 29 Kẹ oben-m bi, ‘Tzotzokhaan tte-m ọbọhk mfona, okhuri bi, ẹhọhmmọr chaman esi ẹjafọhni k'obhon e, ọgbaanotte kwaam ọtzọhmi bi, kaam nda e. Idikha nkk'ọphyaam ndọkha k'itzitzikha sọ, tte nda nne agbaanotte paam.’ Kẹ wọ osi kẹ Devid ma kode bi, ochi ọchattọhk k'okpokkoro kwa kọ ọvaarnọng.”
\p 
\v 30 Saul ọn-ọdọkh-ẹ ọmaana Jonatan maa oben-ẹ bi, “Kọ ade nnwa kw'ọrẹrẹkhi kwanọng, kaam nnọng kẹ bi, kọ abe ka nnam sa nnwa kwa Jẹsẹ e, mgbar nde sọ, mgbar mbiri nde s'akka kw'ọmmaan-ọ.
\v 31 Eden nda cha nnwa nwuma kwa Jẹsẹ oruk akpen m'ọyagbin, kọ ọmaana ẹvaar chọ aranga káttima e. Idikha arong atzim, kọ tzim-ẹ achen-m, kkeri kẹ ọkhaambi ope.”
\p 
\v 32 Jonatan ọbhakhi obhina otte Saul bi, “Da kẹ oji bọng odik, kw'ọn-ọbaan k'obo o?”
\v 33 Wa Saul ọtzọkha ọkhọhn kwẹ ọbhari bi ofhu Jonatan. Mẹ wọ e, Jonatan otzin bi, otte ọkhami bi, ofhu Devid.
\p 
\v 34 Jonatan obina \it bi bik\it*, ọmaana idọdọkhi s'ideden. Ottong iwu ifa s'ophe, Jonatan ọchattọhk kochi, okhuri da ọdọkh-ẹ k'ọgbarsa-dik kw'otte osi ọnang Devid.
\p 
\v 35 K'ekpebha ch'ewu ehobh mẹ, wa Jonatan otzima odikkobh wani otzima ochina kẹ da Devid ochubh,
\v 36 oben odikkobh nwuma bi, “Rọbh ẹbhar atza aror ayuk mba pa ńtta.” Mada odikkobh nwa ọttẹwọr ọrọbh ofona, Jonatan ọtta oyuk k'odem kwa bẹ atto ayongi k'ibe s'ọn-am-ọrọbh.
\v 37 Mada odikkobh nwa opyiri mẹ da oyuk kwa Jonatan otto, Jonatan ọkpẹbh-ẹ oben bi, otto k'itzitzikha sọ e.”
\v 38 Jonatan on-ọkpebh, oyer-ẹ, oben bi, “Jabhi mmo ẹbhar-ẹbhar, k'eden kàbe.” Mẹ wọ, odikkobh nwuma odungi oyuk nwuma ọkpa nnam okwu okhebha itta kwẹ.
\v 39 Odikkobh nwa odik manda wani kw'ọttaan-ẹ ọttaani kode, oyongi Jonatan ọmaana Devid bọ iwa arong odik kwa bẹ am-asi.
\v 40 Wa Jonatan otzini egbongkpo pyẹ ọnang odikkobh nwa, oben-ẹ bi, “Kọ tzima ekpo mbya kpa nnam k'obhon.”
\p 
\v 41 Mada odikkobh nwa okk'ofona, Devid obina k'ichubhabe k'okhubha kw'ẹrakha-ẹrakha, orenga ka kwabọhk kw'ọtza nwa kw'ochubh oyin ka, otza okhebha Jonatan, Devid ọrakha ottima itzitzikha k'irerek igbe ittaan orima Jonatan. Bẹ abaakha ayok, bẹ abira abhom, yina, Devid on-obhom ọyọhnga Jonatan.
\p 
\v 42 Wa Jonatan on-oben Devid bi, “Na rọhng e, tte Ọvaar Ibinọkpaabyi owobha ttara kọ k'odidiri. Mada mokk'eyok-chekhi nda ọsa, ‘Tte Ọvaar Ibinọkpaabyi ode owobh-ore kwaman, ttara va pa va pọ, ọmaana va pa va paam maa ogbe ode.’ ” Wa Devid obina ofona, Jonatan obiro ọkpa nnam k'obhon.
\c 21
\s1 Devid ọrọbh okhebha Ahimẹlẹk k'obhon kwa Nọb
\p 
\v 1 Wa Devid ọrọbh ochina k'obhon kwa Nọb, otza okhebha Ahimẹlẹk kw'ode ọfọhn-ẹja. Mada Ahimẹlẹk ottem-ẹ abẹ, opoma ọsẹ-ẹ, ọbọbh bi, “Ode yan kw'areng mancheni o? Mbọng vọ osi ọnọng kọ abẹ kọ̀tzọni?”
\p 
\v 2 Devid obhina Ahimẹlẹk bi, “Ọvaar Saul ọtzọr-m itzọhng oben-m bi, ‘Ọnọng manda wani oningi ọtzọhm fa ndọhm-ọ ọmaana ndọhna sa kaam nnang-ọ orong o.’ Kaam nkk'agbong-nọng paam mbena bi, bẹ atzikh-m k'ibe rani kẹ e.
\v 3 Kọ akhaam mbọng ka mbọhkh o? Kọ nang-m brẹd-duk azen, ode ọttọhk kpenamkpen f'akhaam nang-m.”
\p 
\v 4 Yina, ọfọhn-ẹja nwuma obhina Devid bi, “Kaam brẹd kw'oni ọttọhk ope \it bi kpaar\it* ka mbọhk kingaam e. Yina, idikha ira ajinọng mba ani panọng abẹ ayim, kaam ndim brẹd kw'awurada ma e.”
\p 
\v 5 Devid obhina bi, “K'odik ọkkakka, man panọng abẹ koyim e mach'om-okkekkeni ode k'ogbe kpenamkpen kwa moyini k'iyaan e. Ijinọng-for saman iwuri ka e, kaambi ira k'itzọhm s'awurada arang, ọn-ọyọhng ewu cha mayina o.”
\v 6 Mẹ wọ, ọfọhn-ẹja nwa ọnang-ẹ brẹd nwa kw'awurada, okhuri da ọdọdọk on-ode, oyongi brẹd kw'okpokkoro kw'awurada kw'Ọvaar Ibinọkpaabyi, bẹ atzọkha atzera brẹd kwa bẹ arami akkima m'ewu nduma dani.
\p 
\v 7 Wa ọkhaam ọtzọhmnọng wani kwa Saul kw'owobh mẹ m'ewu nduma, kwa bẹ abọk ahok okhuri ọtzọhm f'ọkhaam bi osi m'Ọvaar Ibinọkpaabyi k'itzitzikha. Kẹ wa okpen Doẹg ofona Edom, obiro ode oho kw'akkeri-arukhimaan pa Saul.
\p 
\v 8 Devid oben Ahimẹlẹk bi, “Ode bi kọ ọkhọhn, obiro ode ọkkaangkkaang kakhaam kw'anang-m o? Kaam ọkkaangkkaang kwaam, obir ode ogbongttọhk manda vani kindim nkwu ma e, okhuri da ọvaar Saul ọtzọhm-m ọtzọhm f'idudukha.”
\p 
\v 9 Ọfọhn-ẹja nwa obhin-ẹ bi, “Ọkkaangkkaang kw'owobh ma, ode nwuma kwa Golayat kw'ofon Philistiya, kw'iwa afhu k'igbegbewọna s'Ẹla. Bẹ abhọr-ẹ k'ọbara ahok k'ẹphọd nnam-annam. Idikha abeni bi, atzọkh-ẹ, kọ tzọkha, ọkkaangkkaang ọdọdọk ma kode, oyongi nwuma.”
\p Devid oben bi, “Ọdọdọk kw'ode macha nwuma kode. Kọ tzọkh-ẹ anang-m.”
\s1 Devid ọrọbh ochina Gat
\p 
\v 10 M'ewu nduma, Devid ọrọbh ka Saul, ochina k'Akish, kw'ode ọvaarnọng kwa Gat.
\v 11 Yina, atzọhmnọng p'Akish abọbh-ẹ bi, “Devid kw'ode ọvaarnọng kw'irek s'Israẹl arang ma o? Kẹ rang ode ọnọng kwa bẹ am-akkọhn ka mbin sabẹ aben bi:
\q1 ‘Saul okk'nnọhna sẹ ọfha,
\q2 Devid okk'nnọhna-nabhik sẹ ọfha o’?”
\p 
\v 12 Wa Devid ọtzọkha atzim mba okhe k'ettem, Akish kw'ode ọvaarnọng kwa Gat on-ojora Devid maa ọkwọbha eden.
\v 13 Mẹ wọ, Devid on-osi nkkari otzubh-etzen ma bẹ k'itzitzikha. M'itzitzikha sabẹ, on-osi idik mach'otzubh-etzen-nọng, ọkkẹr ekpo ka mgbaakhamma, om-obiro otte attabọhng ọbọhk asaarẹ-ẹ k'agbaphyubha.
\p 
\v 14 Akish on-oben akhaan-nọng pẹ bi, “Bọng kkeri ojinọng nwuma kwa bọng am-atzima achen-m e, osi etzubh-etzen. Bọng atzim-ẹ akwu mbọng o?
\v 15 Ode bi, atzubh-etzen-tzena ma dọk kingaam, kwa bọng abira atza atzima oyok nwa achen-m bi, om-otzubh-etzen m'itzitzikha saam o? Ma ọnọng dema nwa obir ode okhekhennọng kwaam o?”
\c 22
\s1 Devid owobh k'ọmma kw'itzakpa kw'Adulam
\p 
\v 1 Wa Devid obina oji Gat, ọrọbh otza ochubha k'ọtzakpamma kw'Adulam. Mada abagbaanatte pẹ ọmaana ẹhọhmmọr ch'otte biphyir abhaang kwẹ, bẹ afona atza akhebh-ẹ kẹ.
\v 2 Anọng mbuma biphyir p'iwa awobh ka dama-dama, ọmaana p'atzim ayok ibhori, ttara mbuma p'akhaam ọmmamma k'ettem, akwu awobha akhọr-ẹ, on-ode bẹ oho. Wa anọng p'apyiri ẹnọhna bọ awobh ttar-ẹ.
\p 
\v 3 Mẹ wọ, wa Devid ofona ochina ka Mizpa k'ẹkhọma cha Moab, otza oben ọvaarnọng kwa Moab bi, “Tzotzokhaan, tte otte kwaam ọmaana ọkka kwaam ọbọhk, bẹ akwu awobha ma ttar-ọ, matzẹmaa kaam nnonga odik kw'Ibinọkpaabyi ósi ọnang-m.”
\v 4 Mẹ wọ, Devid ohok otte ọmaana ọkka m'ọvaarnọng kwa Moab. Wa bẹ awobha mẹ ttar-ẹ, k'ogbe nwuma biphyir kwa Devid owobh k'ichubhabe.
\p 
\v 5 Yina, Gad kw'ode ọsi-ẹjaakhi kw'Ibinọkpaabyi oben Devid bi, “Kọ m'ichubhabe nna dọk kàchubha. Rọhng k'ẹkhọma cha Juda.” Mẹ wọ, Devid ofona ochina k'ẹtzam cha Hẹrẹt.
\s1 Saul ofhu afọhnẹja p'Ọvaar Ibinọkpaabyi ka Nọb
\p 
\v 6 Saul okwu ọbhaanga bi, bẹ akk'Devid ọmaana ajinọng pẹ ara. Wa Saul otzim ọkhọhn k'ọbọhk, om-owobha ẹwọr k'irekh-irek kwa echi cha tamarisk k'egbegbeho cha Gibea, ọmaana akhaan-nọng pẹ biphyir p'abe akhọr-ẹ.
\v 7 Saul oben bẹ bi, “Ajinọng pa Bẹnjamin, bọng yong-m itzọhng e! Na nnwa nwa kwa Jẹsẹ ónang bọng biphyir iwoni s'agrep ọmaana iwoni ọdọdọkh o? Na kẹ osi bọng adenho p'agbong-nọng ka nnọhna-nabhik, ọmaana k'arọbh azen-azen o?
\v 8 Ma, kwẹ wọ osi bọng biphyir attaanga anang-m o? Ọnọng kw'ọgbaakh-m ogbe kwa nnwa kwaam osi echekhi ọmaana nnwa kwa Jẹsẹ kode. Ọnọng kwa mkpak odik kabọng k'ottem kode, ọnọng kode kw'obiro ọgbaakh-m bi, ọtzọhmnọng kwaam okk'Devid ottem-bara ọnanga bi ofhu-m, mach'om-osi mayina.”
\p 
\v 9 Mẹ wọ e, Doẹg kw'ofon Edom, kw'iwa obe mẹ ttara akhaan-nọng pa Saul, oben bi, “Ira kaam nne da nnwa kwa Jẹsẹ okwu k'Ahimẹlẹk kw'ode nnwa kw'Ahitub ka Nọb.
\v 10 Ahimẹlẹk ọdọhn Ọvaar Ibinọkpaabyi odik okhuri Devid, obiro ọnang-ẹ ọchattọhk, ọmaana ọkkangkkaang kwa Golayat kw'ofon Philistiya.”
\p 
\v 11 Mẹ wọ, ọvaar Saul ọtzọhm bi bẹ ayeri Ahimẹlẹk kw'ode ọfọhnẹja, ode nnwa kw'Ahitub, ọmaana afọhni-ẹja p'ẹhọhmmọr ch'otte biphyir, ka Nọb. Wa bẹ biphyir akhera eyeri nda ch'ọvaarnọng.
\v 12 Saul oben bi, “Nnwa kw'Ahitub, yong-m itzọhng.”
\p Obhina bi, “Itta kwaam, kkeri kaam ma e!”
\p 
\v 13 Saul oben-ẹ bi, “Okhuri yan kwa bọng am-akham-m? Kọ ọmaana nnwa kwa Jẹsẹ, kọ akk'ẹ ọchattọhk ananga, anang-ẹ ọkkangkkaang, abira adọhn Ibinọkpaabyi k'eho chẹ. Ma, Devid ọkk'ọttaanga ọnang-m, obiro ochubha otzikh-m, mach'om-osi mayina.”
\p 
\v 14 Ahimẹlẹk obhina ọvaar Saul oben bi, “K'akhaan-nọng pọ biphyir, anyi wọ ọhak eho macha Devid, kw'ode ọnyẹ kwa kọ ọvaarnọng o? Kẹ mach'oho kw'anọng p'am-abaabh-ọ, kwa bẹ abir anang ikpokpobha s'ideden k'ẹhọhmmọr cha kọ ọvaarnọng.
\v 15 Echedenwu arang mẹ cha kaam ndọhni Ibinọkpaabyi okhuri kẹ! Tte ọvaarnọng oningi kaam ọtzọhmnọng kwẹ odik obubh, kaambi ọnọng kpenamkpen kẹ ẹhọhmmọr chẹ dọ, okhuri bi, ọtzọhmnọng kwọ odik manda wani kw'okhuri idik nna biphyir korong.”
\p 
\v 16 Yina, ọvaarnọng oben bi, “Kọ Ahimẹlẹk k'odik ọkka akhaambi da ápe, kọ ọmaana ẹnọmma ch'atte k'obungi biphyir.”
\p 
\v 17 Mẹ wọ, ọvaarnọng on-oben abaabhi pẹ p'abe abaang-ẹ mẹ bi, “Bọng makhi nnam afhu afọhni-ẹja p'Ọvaar Ibinọkpaabyi, okhuri bi, bẹbẹ dọk akk'Devid an-abir aba ka nnam. Bẹ akk'aronga bi, kẹ ọm-ọrọbh-ọrọbh, yina, bẹ kaam kagbaakhi.”
\p Yina, wa akhaan-nọng p'ọvaarnọng bẹ for kado sa bẹ ayebhi ọbọhk afhu afọhni-ẹja p'Ọvaar Ibinọkpaabyi.
\p 
\v 18 Mẹ wọ, wa ọvaar Saul on-oben Doẹg bi, “Kọ bhakhi afhu afọhni-ẹja.” Doẹg kw'ofon Edom ọbhakhi ofhu bẹ. M'ewu nduma, ofhu afọhni-ẹja arọbh anna obhiri azen p'afọr ẹphọd.
\v 19 Wa obiro ochina ka Nọb, kw'ode obhon kw'afọhni-nja, ofhu ajinọng ọmaana panọng, va p'akk'abara ọmaana vava, obir ofhu andaamogbodo, ọmaana abhaam ttara arukhimaan.
\p 
\v 20 Yina, wa Abiyata, nnwa wani kw'Ahimẹlẹk kw'ode nnwa kw'Ahitub, ọrọbh ọnaanga, otza okhebha Devid.
\v 21 Abiyata ọgbaak Devid eden cha Saul okk'afọhnẹja p'Ọvaar Ibinọkpaabyi ọfha.
\v 22 Mẹ wọ, Devid oben Abiyata bi, “Kaam nnong k'odik ọkka kẹ bi, mada iwa Doẹg kw'ofon Edom owobh mẹ, eden kede ch'oni Saul ọgbaak. Obo kw'ẹnọmma ch'abatte biphyir ofon ka kaam ka mbọhkh e.
\v 23 Wobha ma ttar-m, oning-ọ ojor. Kẹ nwuma kw'om-oror-ọ bi ofhu, om-obiro oror-m bi, ofhu e. Kọ ákhaama ẹnaanga ọkhaama, awobh ma ttar-m.”
\c 23
\s1 Devid ọkkaan obhon kwa Keyila
\p 
\v 1 Wa ewu dani anọng agbaakhi Devid bi, “Kker e, aPhilistiya am-arima obhon kwa Keyila abẹ e, bẹ am-abira achi bẹ ọgbọm k'obe fa bẹ am-awobha akhaani achimọma.”
\v 2 Wa Devid ọdọhn Ọvaar Ibinọkpaabyi, ọbọbh bi, “Ńda ńnima aPhilistiya mba abẹ o?”
\p Ọvaar Ibinọkpaabyi obhin-ẹ bi, “Rọhng atza arima aPhilistiya abẹ ifha akkaana Keyila.”
\p 
\v 3 Yina, ajinọng pa Devid aben-ẹ bi, “Ojemi manya Juda, moruk k'ojora, idikha mon-ochin ka Keyila bi, motza orima agbongnọng pa Philistiya abẹ, kwẹ on-opyibh ọyọhnga mẹ e.”
\p 
\v 4 Devid obir ọdọhn Ọvaar Ibinọkpaabyi, Ọvaar Ibinọkpaabyi obhin-ẹ bi, “Kọ rọhng ka Keyila, okhuri bi, kaam ńtte aPhilistiya ọbọhk ńnang-ọ ákhema.”
\v 5 Mẹ wọ, Devid ọmaana ajinọng pẹ achina ka Keyila, atza arima anọng pa Philistiya abẹ, achi bẹ ọgbọm k'etzirakpo pyabẹ. Wa Devid ofhu anọng pa Philistiya k'ọhaabh, ọkkaana anọng pa Keyila.
\p 
\v 6 M'ogbe nwuma, wa Abiyata kw'ode nnwa kw'Ahimẹlẹk, otzim ẹphọd k'ọbọhk ọrọbh otza okhebha Devid ka Keyila.
\s1 Saul okhubh Devid
\p 
\v 7 Wa anọng agbaakhi Saul bi, Devid okk'ochina ka Keyila, Saul on-oben bi, “Ibinọkpaabyi ọkk'ẹ ka mbọhk saam ọkha. Devid okk'for sẹ mgbakkọhbh ọkha bi, odim k'obhon kw'ọkhaam mbaakhamma, ọmaana abaakha.”
\v 8 Mẹ wọ, Saul oben agbongnọng pẹ biphyir bi, bẹ ado for s'egbong achina ka Keyila, atza akhọri Devid ọmaana ajinọng pẹ akhe k'ottem.
\p 
\v 9 Mada Devid orong bi, Saul ọm-ọkhami bi ọsẹ-ẹ itzama, oben Abiyata kw'ode ọfọhnẹja bi, “Tzima ẹphọd nduma akwu.”
\v 10 Devid ozi njọhm oben bi, “O Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'Israẹl, k'odik ọkka kaam ọtzọhmnọng kwọ nkk'mmaanga bi, Saul ọkhami bi, okwu ka Keyila, okwu odimi obhon nwa okhuri kaam.
\v 11 Ma na anọng pa Keyila átzọkh-m anang-ẹ o? Na Saul ókwu ma Keyila o? O Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'Israẹl, tzotzokhaan si ẹjaakhi nang kaam ọtzọhmnọng kwọ.”
\p Mẹ wọ, Ọvaar Ibinọkpaabyi oben bi, “K'odik-ọkka, kẹ ókwuma.”
\p 
\v 12 Devid obiro ọbọbh bi, “Ma na anọng pa Keyila átzọkh-m ọmaana ajinọng paam ánang Saul o?”
\p Ọvaar Ibinọkpaabyi obhina bi, “Bẹ ási-osi mando.”
\p 
\v 13 Mẹ wọ, Devid ọmaana ajinọng pẹ, p'apyiri anọng ẹnọhna obhiri arọbh jobh, abina aji Keyila. Bẹ achina ororo arenga apyiri k'obe k'obe. Mada bẹ agbaakhi Saul bi, Devid ọkk'ọrọbha oji Keyila, wa Saul ka Keyila dọk kọ̀tza.
\p 
\v 14 Wa Devid ochubha k'ichubhabe s'ibe s'anọng anarukhi, ka mgbegbeho s'ibe s'anọng anarukhi ka Ziph. K'ewu kpenamkpen, Saul ochina ororo ochimi Devid, yina, wa Ibinọkpaabyi Devid ọbọhk kotte ọnang Saul.
\p 
\v 15 Mada Devid owobh ka Horẹsh k'ibe s'anọng anarukhi ka Ziph, ọn-ọbhaanga bi, Saul ọkk'ọkwa bi okwu ọfhẹ-ẹ.
\v 16 Wa Jonatan kw'ode nnwa kwa Saul, ofona otza okhebha Devid ka Horẹsh, ọkhẹ-ẹ ẹfa bi, odo ettem ọbar ophe nnam k'Ibinọkpaabyi.
\v 17 Oben-ẹ bi, “Tte oning-ọ ojor. Otte kwaam Saul, kọ ọbọhk kọ́tọhmi. Kọ wọ áde ọvaarnọng kw'Israẹl, kaam ńjem-ọ mbọhk ka nnam. Kaambi otte kwaam Saul wọ, orong odik nwa kẹ e.”
\v 18 Bẹ anọng afa asi echekhi k'itzitzikha s'Ọvaar Ibinọkpaabyi. Wa Jonatan ọbhana, Devid ochina ororo owobha ka Horẹsh.
\p 
\v 19 Wa anọng pa Ziph afona atza akhebha Saul ka Gibea, aben bi, “Kker e, Devid ochubh m'ichubhabe saman ka Horẹsh e, k'egbegbeho cha Hakila, k'okhubha kw'ẹrakh-ẹrakha ka Jẹshimọn.
\v 20 Mẹ wọ, o ọvaarnọng, kọ hakha akwu, k'ogbe kpenamkpen kw'ọdaakh-ọ, maman ọ́tzọkha kwẹ mach'ọtzọhm faman bi, mọtzọkh-ẹ otte ọbọhk ọnang-ọ.”
\p 
\v 21 Saul obhina bi, “Tte Ọvaar Ibinọkpaabyi odo bọng k'ejibha cha bọng akk'aam akhọhkha.
\v 22 Bọng nọhng atza ado kwẹ adọhn. Bọng dọhn obe fa Devid ọm-ọtza, ọmaana ọnọng kw'ọkk'ẹ ọra mẹ. Bẹ agbaakh-m bi, kẹ odongi kpọng-kpọng e.
\v 23 Bọng dọhn aronga obe f'om-ochubha biphyir, ifha bọng akpa nnam akwu agbaakh-m mach'ode. Mẹ wọ, kaam ńdọn bọng abẹ mochina kẹ. Idikha ochubh k'ibe nnuma, kaam ḿbọkh-ẹ k'ibe kpenamkpen s'ochubh k'ottem kwa nnọmma sa Juda biphyir.”
\p 
\v 24 Mẹ wọ, anọng mba achi Saul eden achina ka Ziph. Wa Devid ọmaana ajinọng pẹ awobh k'ibe s'anọng anarukhi ka Maọn, k'Araba k'ẹrakha-ẹrakha kwa Jẹshimọn.
\v 25 Saul ọmaana ajinọng pẹ attẹwọr anwa ẹtzam aror-ẹ. Mada Devid ọbhaang kwẹ, on-ochina k'itzakpa s'iwobh k'ibe s'anọng anarukhi ka Maọn. Mada Saul ọbhaang bi Devid ochubh ka Maọn, okhubh-ẹ ochina kẹ.
\p 
\v 26 Wa Saul om-orenga k'ọbọhk wani kw'egbegbeho nduma dani, Devid ọmaana ajinọng pẹ arenga k'ọbọhk nwonggo, bẹ am-adukha bi, bẹ arọbh anaanga Saul. Mada Saul ọmaana agbongnọng pẹ akk'Devid ọmaana ajinọng pẹ afora k'odem kwa bẹ abọkha bẹ,
\v 27 wa ọkkaabh-ẹkkaabha okwu okhebha Saul oben bi, “Kwu ẹbhar-ẹbhar, ogbe kàkhibhi, kkeri aPhilistiya am-achi ẹkhọma nda k'egbong e.”
\v 28 Mẹ wọ e, wa Saul ọkwọbha Devid okhukhubh, on-ofona bi, otza orima anọng pa Philistiya abẹ. Kẹ wọ osi bẹ ayeri ibe nna Ẹtzakpa ch'Ẹrọbh-ẹnaanga\f + \fr 23.28 \ft K'eHiburu, bẹ ayeri ibe nna Sela Hammahlekoth kw'oyini Ẹtzakpa ch'Ẹrọbh-ẹnaanga.\f*.
\v 29 Devid on-obina mẹ, ovura otza ochubha k'Ẹn-Gẹdi\f + \fr 23.29 \ft K'eHiburu, Ẹn-Gẹdi oyini okhekhaho kw'avu-va. Ode okhekhaho kw'owobh k'okhubha kw'ewuchen em-edimi k'Ọraanga kw'Onung. Okhekhaho nwa ọkhaam asi akkakka ọmaana asi p'apọhkh-ọpọhkha. \f*.
\c 24
\s1 Devid oyobh akpen pa Saul
\p 
\v 1 Mada Saul ọkpa nnam kẹ da ọtza okhubh aPhilistiya, bẹ agbaakh-ẹ bi, “Devid ochubh k'ibe s'anọng anarukhi s'Ẹn-Gẹdi.”
\v 2 Wa Saul otzekha ajinọng nnọhna nzenamfa obhiri arọbh jobh, makhọra Israẹl, otzima bẹ otza oror Devid ọmaana ajinọng pẹ, kẹ ọbaanga Atzakpa p'Avu p'Ẹtzam.
\p 
\v 3 Mada Saul opyiri k'avukwuri bani k'ọkkadeden, ore ọtzakpamma, wa ọyaakha mẹ bi, ọtza k'ẹpa-nnam. Yina, wa Devid ọmaana ajinọng pẹ achubh ka nnam okhubha kw'ọtzakpamma nwa.
\v 4 Ajinọng pa Devid aben-ẹ bi, “Ewu nduma dọ ma ch'iwa Ọvaar Ibinọkpaabyi ọgbaakh-ọ bi, ‘Kaam ńtte ọttattaanga-nọng kwọ ọbọhk nnang-ọ, ifha ásẹ-ẹ mach'ọdaakh-ọ.’ ” Devid obina ọbẹkhi, ọnọng kẹ kore, maa ọkpaara ẹbaramma ch'ọnọhma-baba kwa Saul.
\p 
\v 5 Ayongi mẹ, wa achibhi ayak Devid atzim okhuri ẹbaramma ch'ọnọhma-baba kwa Saul ch'ọkk'ọkpaara.
\v 6 On-oben ajinọng pẹ bi, “Tzọhmi-tzọhmi okponga k'idachen bi, kaam nsi odik dema nwa nnang itta kwaam, ọnọng kw'Ọvaar Ibinọkpaabyi okk'ana obyengi k'eho, bi ira kaam nna mbiri nttọhm-ẹ ọbọhk, kẹ ode ọnọng kw'Ọvaar Ibinọkpaabyi okk'ana obyengi k'eho.”
\v 7 Wa Devid otzima atzim mba ọkpa ajinọng pẹ eden, bẹ Saul abẹ karim. Saul e, obina k'ọtzakpamma ofona.
\p 
\v 8 Mẹ wọ, Devid oyin k'ọtzakpamma, oyeri Saul bi, “Itta ọvaarnọng kwaam!” Mada Saul ọbhakhi nnam, Devid ọrakha ottima itzitzikha k'irerek k'ikpokpobha.
\v 9 Oben Saul bi, “Okhuri yan kw'am-ayonga itzọhng k'ogbe kw'anọng am-aben bi, ‘Devid ọm-ọkham bi, ọsọ-ọ itzama o?’
\v 10 Mayina, kọ akk'chen pọ atzima are odem kw'Ọvaar Ibinọkpaabyi ọttọ-ọ ọbọhk ọnang-m \it bi pọọbh,\it* k'ọtzakpamma. Anọng achọm-m bi, mfhọ-ọ, yina, kaam nttọ-ọ ọbọhk, mben bi, ‘Kaam itta kwaam ọbọhk kínttọmi, okhuri bi kẹ ode ọnọng kw'Ọvaar Ibinọkpaabyi okk'ana obyengi k'eho.’
\v 11 Kker e, itta kwaam, kọ kkeri ẹbarakpa ch'ọnọhma-baba kwọ k'ọbọhk kwaam e. Kaam mkpaar chẹ k'ẹnọmma ch'ọnọhma-baba kwọ, yina, kọ kimfhu. Tte kwẹ ọttaan-ọ ma bi, kaam ottotto kw'oponga-pyibha, obiro ode oho-gaangi kingaam. Kaam kọ kimbiri ntto, yina, kọ akham-m mẹ bi, atzọkha akpen paam.
\v 12 Tte Ọvaar Ibinọkpaabyi ọttọhna aponga pa kaam ọmaana kọ. Tte Ọvaar Ibinọkpaabyi otzukha itzama s'akk'aam asa. Yina, kaam kọ ọbọhk kwaam kínttọmi.
\v 13 K'odem kw'ẹtzama ebeni, ‘Ọbhọkhi adimichi kẹ kwa mbọhk njobhi,’ mẹ wọ, kaam kọ ọbọhk kwaam kínttọmi.
\p 
\v 14 “Ọvaarnọng kw'Israẹl oreng anyi abẹ oyin k'iyaan o? Anyi wọ kw'am-akhubh o? Ọpfa-bukhi wọ ra a? Ẹtzatzaana dọ ọ?
\v 15 Tte Ọvaar Ibinọkpaabyi ode ọttọhna-ponga kwaman, obiro ọnang ẹjaakhi k'ottem kwa man anọng afa. Tte kẹ obe aponga paam, tte kẹ obiro ọkkaana ọrọbh-m ka mbọhk sọ.”
\p 
\v 16 Mada Devid okyer odik nwa ọgbagbaak, Saul ọbọbh bi, “Nnwa kwaam Devid, kọ wọ am-agbaak ma o?” Mẹ wọ, on-obhom ẹmọng k'ẹrọng.
\v 17 Obiro oben Devid bi, “Kọ wọ atzori ọtzam ayọhnga kaam e. Kọ akk'aam ejibha asa, yina, kaam nkk'kọ itzama nsa.
\v 18 Mayina akk'aam ejibha ch'asi anang-m agbaakha. Da Ọvaar Ibinọkpaabyi ọtzọkh-m ọkhọ-ọ ka mbọhk, yina, kaam kafhu.
\v 19 Bọng ọnọng wọ ore ọttataanga-nọng kwẹ, otte ọbọhk ofona kẹ itzama kosi o? Tte Ọvaar Ibinọkpaabyi ochor-ọ, k'ejibha ch'asi anang-m mayina.
\v 20 Kaam nnong kẹ k'odik ọkka bi, kọ ikhina áde ọvaarnọng ode, ọmaana bi, ikhina ẹkhọma ch'Israẹl éttima aranga ottima k'ogbe kw'ẹvaar chọ.
\v 21 Kọ chekhi ka che ch'Ọvaar Ibinọkpaabyi anang-m bi, kọ va pa va paam kadimi, che chaam k'ẹhọhmmọr ch'otte kwaam kabira áfuri.”
\p 
\v 22 Mẹ wọ, Devid ọnwọhngi ọnang Saul. Saul e ọbhana, yina, Devid ọmaana ajinọng pẹ akpa nnam k'ichubhabe sabẹ.
\c 25
\s1 Obo kwa Samwẹl
\p 
\v 1 Samwẹl e ope, anọng p'Israẹl biphyir atzọbha, abẹ abhom-ẹ. Bẹ atza anọhng-ẹ ka Rama kw'ode obhon kwẹ.
\s1 Devid, ọmaana Abigẹl
\p Mẹ wọ, Devid obina ochina k'ibe s'anọng anarukhi sa Paran.
\v 2 Wa ọkhaam ojinọng wani ka Maọn kw'ọkhaam ẹkhakhaama ka Kaamẹl, kẹ wa ode ọkkọkka kw'ideden. Kẹ wa ọkhaam avugbokha nnọhna mfa obhiri arọbh jobh, obiro ọkhaama arukhimaan nnọhna nzenamfa obhiri arọbh jobh p'iwa om-ophyiri ophyubha ka Kaamẹl.
\v 3 Ojinọng nwa wa okpen Nabal, kwanọng kwẹ okpena Abigẹl. Wa Kwanọng nwa ọkhaam eronga, obiro ojibh kwanọng, yina, odim kwẹ ode oKalẹb-nọng kw'ọkhaam ẹmmaana ch'ikkamgbagbara, obiro osi ẹrama.
\p 
\v 4 Mada Devid owobh k'ibe s'anọng anarukhi ọbhaanga bi, Nabal om-ophyiri arukhimaan pẹ ophyubha,
\v 5 Wa Devid okwu ọtzọhm adikkobh jobh oben bẹ bi, “Bọng nọhng ka Kaamẹl atza arima Nabal anang-m.
\v 6 Bọng ben-ẹ bi, ‘Kọ ruk akpen p'adumi eden! Ofor-gaangi owobha ttar-ọ ọmaana ẹhọhmmọr chọ, ttara ọttọhk kpenamkpen f'ode fọ.
\p 
\v 7 “ ‘Mmaang bi, ogbe wọ ma kw'arukhimaan ophyubha ophyi-phyiri. Mada iwa akkeri-arukhimaan pọ awobh ttara man, wa man bẹ itzama kosi. Ogbe kw'iwa bẹ awobh ka Kaamẹl biphyir, ọttọhk manda vani fabẹ f'odimi kode.
\v 8 Kọ bọbh atzọhmnọng pọ, bẹ ágbaakh-ọ ọgbaak. Mẹ wọ, kọ si ọphyaam anang adikkobh paam, da mokwu k'ẹdadaami-wu. Tzotzokhaan kọ nang atzọhmnọng pọ, ọmaana kaam nnwa kwọ Devid kpenamkpen f'akhaam bi anang bẹ.’ ”
\p 
\v 9 Mada ajinọng pa Devid apyiri, bẹ atzọkha ẹkkaabha cha Devid agbaak Nabal. Bẹ an-awobha atzik.
\p 
\v 10 Nabal obhina atzọhmnọng pa Devid bi, “Anyi wọ ode Devid ode? Anyi wọ ode nnwa nwa kwa Jẹsẹ ode? Iwu nna atzọhmnọng haabhada an-am-abhaangi ka mbọhk sa abitta pabẹ.
\v 11 Okhuri yan kw'ira kaam nna ndọkha brẹd kwaam, ọmaana asi, ttara etzen cha kaam mfhu bi, nnang anọng paam p'am-aphyiri arukhimaan-phyubha, ndọkha nnang anọng p'ọnọng oni orong ibe sa bẹ afona akwu o?”
\p 
\v 12 Ajinọng pa Devid abhakhi nnam abhana. Mada bẹ apyiri, bẹ agbaak Devid odem kwa kwẹ ode biphyir.
\v 13 Devid oben ajinọng pẹ bi, “Bọng dabh akkangkkaang pabọng!” Mẹ wọ, bẹ adabh akkangkkaang pabẹ, Devid obiro ọdabh kwẹ. Wa anọng ẹnọhna bọ atzọni Devid abẹ, yina, ọtzọkha anọng arọbh jobh ohok bi, bẹ akkeri egbongkpo.
\p 
\v 14 Ọtzọhmnọng wani kwa Nabal ọgbaak Abigẹl kw'ode kwanọng kwa Nabal bi, “Devid ọtzọhmi akkaabh-nkkaabha p'afon k'ibe s'anọng anarukhi bi, bẹ akwu arima itta kwaman e, yina, kẹ on-otzer ọnang bẹ mgbarsa-dik.
\v 15 K'odik ọkka, wa anọng mba ajibhi idik atzima atzor man. Wa bẹ man itzama kàsi, ogbe nwa biphyir kwa mowobh k'iwoni ọbaanga bẹ, ọttọhk manda vani faman kobiro odimi.
\v 16 Bẹ akkeri man k'ẹya, akkeri man k'erungi k'ogbe nwa kw'am-om-okkeri arukhimaan paman biphyir, ọbaanga bẹ.
\v 17 Kọ si ochibhi atzena mẹ, are odem kw'asi, okhuri bi, itzama in-ibe ma s'itto ikhebha itta kwaman ọmaana ẹhọhmmọr chẹ biphyir. Kẹ ọkhaam ikkaam-gbagbara ọyọhnga ọbọhk, itzọhng k'om-oyonga ọnang ọnọng manda wani.”
\p 
\v 18 Abigẹl ogbe kokhibhi, ọtzọkha brẹd arọbh jobh, ọmaana atzuk-gbere afa, ọmaana arukhimaan azen p'ọkk-ọbhaabha, ọmaana agbangbang-dim azen p'abọkpa-bhaabha, ọmaana agwọk arọbh azen p'agrep p'agwu-ogwu, ttara agwọk arọbh jobh p'afig p'agwu-ogwu ọnana nnyanyaang.
\v 19 Mẹ wọ, on-oben atzọhmnọng pẹ bi, “Bọng chi-m eden arọhng; kaam ńdor bọng nnam nkwuma e.” Yina, wa odim kwẹ Nabal kọgbaakhi.
\p 
\v 20 Mada ọm-ọyaar ẹnyanyaang chẹ ọwọna egbegbeho, ore da Devid ọmaana ajinọng pẹ am-abira ahakha atzor-ẹ ka for, bẹ atza attema ayok abẹ.
\v 21 Devid okk'ọtzam obena bi, “K'odik ọkka, kwẹ ode ndidimi ọnang bi, nkkeri ẹkhakhaama ch'ayi nwa k'ibe s'anọng anarukhi, ifha ọttọhk manda vani fẹ oningi odimi. Ma, kẹ okk'itzama on-otzima ochora ejibha chaam e.
\v 22 Tte Ibinọkpaabyi osi attattaanga-nọng pa Devid mach'ọdaakh-ẹ, idikha ntte ojinọng manda wani kwẹ ọbọhk oruk akpen ophyini k'ekpebha.”
\p 
\v 23 Mada Abigẹl ore Devid, ọhakha k'ẹnyanyaang chẹ m'ẹbhar k'ẹbhar, ọrakha ottima itzitzikha k'irerek m'itzitzikha sa Devid.
\v 24 Ọttẹ-ẹ ma mmo oben bi, “Itta kwaam, tte oponga-pyibha ode kwaam manchen e. Tzotzokhaan, tte kaam ọtzọhmnọng kwọ mgbaak atzim nnang-ọ, yong-m itzọhng abhaanga odik kwa kaam ọtzọhmnọng kwọ ngaam bi, mgbaakh-ọ.
\v 25 Tte itta kwaam oningi ẹmmaana-tzama ch'ojinọng nwuma kwa bẹ ayeri Nabal ọsaan e. Kẹ osi edidingi otzor ka che chẹ, che chẹ eyini odidingi-nọng, mando kw'orukhi akpen ochina. Yina, kaam ọtzọhmnọng kwọ, ajinọng p'itta kwaam ọtzọhmi kinne e.
\p 
\v 26 “Mada Ọvaar Ibinọkpaabyi ọkk'ọsa bi, kọ itta kwaam aningi oponga-phyibha kw'ẹnọngmon atzọk, ọmaana bi, kọ aningi odik ka for sọ abira atzukha. Da Ọvaar Ibinọkpaabyi orukhi akpen, kọ abira aruk akpen, tte attattaanga-nọng pọ ọmaana anọng biphyir p'achibhi itzama ọmaana itta kwaam, atzọkha ettuma macha Nabal.
\v 27 Mẹ wọ, tte itta kwaam okhera bi, ọtzọkha ẹnanga nda cha kaam ọtzọhmnọng kwọ nkk'ndimi nkwu, ọnang ajinọng p'am-atzọn-ẹ abẹ.
\v 28 Tzotzokhaan, bina nang ottotto kwa kaam ọtzọhmnọng kwọ. Ọvaar Ibinọkpaabyi óttima ẹhọhmmọr ch'itta kwaam aranga \it bi gbuk,\it* okhuri da kẹ om-orima mgbong s'Ọvaar Ibinọkpaabyi. Itzama s'íkhọbh-ọ itzor k'odem kw'arukhi akpen kide.
\v 29 Kaambi ode bi, ọnọng okhubh-ọ bi ọfhọ-ọ, Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ, wọ ókkeri akpen p'itta kwaam, mach'ọnọng okkeri ọttọhk f'ohokhi ettem. Yina, kẹ odimi akpen p'attattanga-nọng pọ mach'ọtza kwa bẹ abhari k'ibhar-atza.
\v 30 Ọvaar Ibinọkpaabyi ósi odik-jibhada kpenamkpen kw'ochekhi ọ́nang itta kwaam, obiro ótzekh-ẹ mach'ọdabhi kw'Israẹl.
\v 31 For sọ kápyima k'ẹnọngmon, for sọ kabira ápyima bi arengmmo atzukha odik. K'ogbe kw'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ, okk'itta kwaam ọda, jima kaam ọtzọhmnọng kwọ o.”
\p 
\v 32 Devid oben Abigẹl bi, “Ẹtzọhnga ẹkhaam Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'Israẹl, kw'ọkk'ọ ọtzọhma k'ewu cha mayina ochen-m.
\v 33 Tte Ọvaar Ibinọkpaabyi ọdọ-ọ k'eronga chọ, da obiro otzim-ọ akkaan-m nnaanga ẹnọngmon k'ewu cha mayina, mbọhk saam kimbiri ndima ndukha odik.
\v 34 Oni mando ode, k'odik ọkka, mach'Ọvaar Ibinọkpaabyi kw'ode Ibinọkpaabyi kw'Israẹl orukhi akpen, kw'obiro ọkpa-m bi nning-ọ itzama nsi, idikha ira ani ẹbhar-ẹbhar akwu bi more ayok, ojinọng manda wani kw'ode kwa Nabal kw'oruk akpen yina ewu ehobha kode.”
\p 
\v 35 Mẹ wọ, Devid ọn-ọtzọkha ekpo py'Abigẹl otzim ochen-ẹ, oben-ẹ bi, “Rọhng abhana k'odidiri. Kaam nkk'atzim pọ mmaanga, ńsi-osi mach'abeni.”
\p 
\v 36 Mada Abigẹl ọbhan, otza okhebha Nabal k'ọhọhm da om-osi ọdadaami mach'ọvaarnọng, Nabal okk'ọgwa obuma da ettem ẹdaam-ẹ. Mẹ wọ, kwanọng kẹ odik kọgbaakhi maa ewu ehobha.
\v 37 Mada ewu en-ehobh, da atzuk akk'Nabal attoni, kwanọng kwẹ ọtzọkha idik nna biphyir ọgbaakh-ẹ, okhubhachi ọbọkh-ẹ, on-oyima mach'ọtza.
\v 38 Ọttọhk k'iwu jobh k'itzitzikha, Ọvaar Ibinọkpaabyi obun Nabal ofhu, Nabal e, ope.
\p 
\v 39 Mada Devid ọbhaang bi, Nabal ọkk'ọpa, oben bi, “Ẹtzọhnga ewobha ẹnang Ọvaar Ibinọkpaabyi kw'okk'Nabal abẹ orima ọnang-m okhuri da om-osi idik s'olukh-m. Ibinọkpaabyi ọkk'ọtzọhmnọng kwẹ eden ọkpa bi, oningi itzama osi, on-obiro osi itzama sa Nabal ikpa nnam itzor kẹ ọkhaam.”
\p Mẹ wọ, Devid ọn-ọtzọhm ẹkkaabha bi, bẹ atza abọbh Abigẹl eyonga bi ode kwanọng kwẹ.
\v 40 Atzọhmnọng pẹ achina ka Kaamẹl atza aben Abigẹl bi, “Devid okk'man ọtzọhma bi, mokwu ọtzọkh-ọ, atza ade kwanọng kwẹ e.”
\p 
\v 41 Abigẹl ochunga ottima itzitzikha k'irerek, oben bi, “Kkeri kaam ọtzọhmnọng kwọ ma e, kaam nkk'for nda bi nsi ọtzọhm nnang-ọ e, bi mbiri mgbobhi mmo s'atzọhmnọng p'itta kwaam e.”
\v 42 Abigẹl ogbe kokhibhi obina ovura ẹnyanyaang, otzima aminava azen p'ade atzọhmnọng pẹ, ọtzọn atzọhmnọng pa Devid abẹ, ọtza ọba Devid.
\v 43 Wa Devid okk'Ahinoam kw'ofon Jẹzrẹl ọtzam ọtzọkha, bẹ anọng afa an-ade panọng pẹ.
\v 44 Yina, wa Saul okk'nnwa kwẹ Mikal kw'ode kwanọng kwa Devid, ọtzọkha ọnang Palti kw'ode nnwa kwa Laish kw'iwa ofon Galim, k'ọbada.
\c 26
\s1 Devid obiro oyobh akpen pa Saul
\p 
\v 1 Anọng pa Ziph afona atza akhebha Saul ka Gibea, aben bi, “Devid ochubh k'egbegbeho cha Hakila ch'ẹrọni Jẹshimọn itzitzikha e.”
\p 
\v 2 Mẹ wọ, Saul ọmaana anọng nnọhna arọbh azenamfa obhiri arọbh jobh p'Israẹl, afona ahakha k'ibe s'anọng anarukhi ka Ziph, bi bẹ atza aror Devid.
\v 3 Saul osi ibhingabe k'eden ọkhaan-ọkhaan kw'egbegbeho cha Hakila ch'ẹrọni Jẹshimọn itzitzikha, yina, wa Devid owobha k'ibe s'anọng anarukhi. Mada ore bi Saul ọkk'ẹ nnam otzora opyiri mẹ,
\v 4 Devid ọn-ọtzọhm nttọ bi, bẹ atza aronga k'odik ọkka, sa Saul okk'opyiri m'ibe nnuma.
\p 
\v 5 Wa Devid obina ochina k'ibhingabe sa Saul, ore da Saul ọmaana Abnẹr kw'ode nnwa kwa Nẹr obiro ode oho kw'agbong-nọng am-attaabha, k'ottem kw'akkengitza pẹ p'akk'abira attaabha.
\p 
\v 6 Devid ọn-ọbọbh Ahimẹlẹk kw'ofon Het, ọmaana Abishayi kw'ode nnwa kwa Zeruya, kw'obiro ode ọgbaanọkka kwa Joab bi, “Anyi ọ́tzọn-m abẹ mọtza k'ibhingabe sa Saul?”
\p Abishayi oben bi, “Kaam wọ ńdọn-ọ abẹ.”
\p 
\v 7 Mẹ wọ, Devid ọmaana Abishayi abina m'erungi achina kẹ da agbong-nọng pa Saul awobh, ore da Saul ọm-ọttaabha k'ibhingabe ttara ọkhọhn kwa bẹ afhu abaang-ẹ m'eho. Abnẹr ọmaana agbong-nọng ayima akhọr-ẹ akhe k'ottem.
\p 
\v 8 Abishayi oben Devid bi, “Mayina Ibinọkpaabyi ọkk'ọttataanga-nọng kwọ ọtzọkha okhe ka mbọhk sọ. Mẹ wọ, tte-m ọbọhk ngwum-ẹ ọkhọhn ogbe wani mmana m'irerek, kaam kẹ igbe ifa kingwum.”
\p 
\v 9 Yina, Devid oben Abishayi bi, “Kẹ kàdimi! Ọnọng kw'ọttọhmi ọnọng kw'Ọvaar Ibinọkpaabyi okk'ana obyengi k'eho ọbọhk, yina aponga aning-ẹ apyibhi kode.
\v 10 Devid ọttara bi, k'odik-ọkka, mach'Ọvaar Ibinọkpaabyi orukhi akpen, Ọvaar Ibinọkpaabyi ọkhaam wọ óbun-ẹ, oni mando obiro ode, kẹ Saul ópe k'ogbe kwẹ, oni mando obiro ode, kẹ ódimi k'egbong.
\v 11 Ọvaar Ibinọkpaabyi oningi okher bi, kaam nttọhmi ọnọng kw'Ọvaar Ibinọkpaabyi okk'ana obyengi k'eho ọbọhk. Kọ họbhi ọkhọhn, abira atzini esi-gora ch'eber ẹbaang-ẹ m'eho, akwu mofona.”
\p 
\v 12 Mẹ wọ, Devid ọhọbhi ọkhọhn obiro otzini esi-gora ch'eber ẹbaanga Saul m'eho, bẹ afona. Ọnọng manda wani kw'ore bẹ, kw'obiro oronga odik nwa, obiro ọphyọbha ọda kode. Wa bẹ biphyir am-attaabha ọda, okhuri da Ọvaar Ibinọkpaabyi okk'bẹ ọsa attaabha amọm.
\p 
\v 13 Mẹ wọ, Devid ojekha k'okhubha, on-obe k'egbegbeho ẹrọng k'oden-mir; wa bẹ abhir ayok eden.
\v 14 Wa Devid ogwon agbong-nọng pa Saul ọmaana Abnẹr kw'ode nnwa kwa Nẹr, “Abnẹr, ode bi kaam ẹmọng kakhera?”
\p Abnẹr obhin-ẹ bi, “Kọ anyi wọ am-agwon ọvaarnọng o?”
\p 
\v 15 Devid oben bi, “Kaambi sa ade ojinọng o? Anyi wọ ode macha kọ k'Israẹl o? Okhuri yan kw'ani itta kwọ, kw'ode ọvaarnọng abaabh o? Ọnọng ọkk'ọkwa bi, okwu odimi itta kwọ, kw'ode ọvaarnọng e.
\v 16 Odik kw'asi ma kojibhi. Mach'Ọvaar Ibinọkpaabyi orukhi akpen, kọ ọmaana ajinọng pọ abaan k'obo, okhuri bi, bọng itta kwabọng kw'Ọvaar Ibinọkpaabyi okk'ana obyengi k'eho, kabaabh. Bọng kkeri akhọri, ọkhọhn ọmaana esi-gora py'ira ewobh ẹbaanga eho ch'ọvaarnọng ko o?”
\p 
\v 17 Wa Saul otzin ẹmọng cha Devid oben bi, “Nnwa kwaam Devid, ẹmọng chọ dọ ma o?”
\p Devid obhina bi, “O o, itta kwaam kw'ode ọvaarnọng, ẹmọng chaam dọ e.
\v 18 Okhuri yan kw'itta kwaam om-okhubh kaam ọtzọhmnọng kwẹ o? Kaam nsi yan ọ, oponga-pyibha kwaam ode yan o?
\v 19 Mẹ wọ, tte itta kwaam kw'ode ọvaarnọng, oyonga itzọhng k'atzim pa kaam ọtzọhmnọng kwẹ e. Idikha ofon k'Ọvaar Ibinọkpaabyi bi, attaang-m, tte kẹ okhera ọtzọkha ẹnanga chaam. Yina, on-obiro ofona k'anọngẹya, tte Ọvaar Ibinọkpaabyi ọnang bẹ ẹmma. Bẹ akk'aam an-akhubha bi, nningi ekkema chaam ka Ọvaar Ibinọkpaabyi ndọk, aben bi, ‘Kọ rọhng atza akpobha akha.’
\v 20 Mẹ wọ, bọng kaam k'oden-mir k'itzitzikha s'Ọvaar Ibinọkpaabyi kafhu. Ọvaarnọng kw'Israẹl ọkk'ọkwa bi, okwu oror ẹtzatzaana mach'ọnọng ọtza ẹgbaaji ch'inọhn s'ẹtzam k'egbegbeho.”
\p 
\v 21 Mẹ wọ, Saul oben bi, “Kaam nkk'ẹkhọhngkwuri nsa. Nnwa kwaam Devid o, kọ kpa nnam e. Da kọ akpen paam abar-ọ odik mayina, kaam kọ dọk kingaam e. K'odik ọkka, kaam nkk'edidingi ttara epina ch'ideden nsa e.”
\p 
\v 22 Devid obhina bi, “Kkeri ọkhọhn kw'Ọvaarnọng ma e. Tte ogbong-nọng wani kwọ ojekha okwu ọtzọkha.
\v 23 Ọvaar Ibinọkpaabyi om-ochora ọnọng kpenamkpen k'etzora chẹ, ọmaana ka nnam-ophephe kwẹ e. Mayina, Ọvaar Ibinọkpaabyi ọkk'ọ ọtzọkha okhe-m ka mbọhk, yina, kaam ọnọng kw'Ọvaar Ibinọkpaabyi okk'ana obyengi k'eho ọbọhk kinttọmi.
\v 24 K'odik ọkkakka mach'akpen pọ abar-m odik mayina, tte akpen paam abar Ọvaar Ibinọkpaabyi odik, obiro ọrọbh-m ka dama-dama kpenamkpen.”
\p 
\v 25 Mẹ wọ e, Saul oben Devid bi, “Nnwa kwaam Devid, tte Ọvaar Ibinọkpaabyi ọdọ-ọ; kọ ási idik s'ibari odik, k'odik ọkka abira ákhaama ekhemma.”
\p Mẹ wọ, Devid ofona, Saul obiro ọkpa nnam ọbhana k'obhon kwẹ.
\c 27
\s1 Devid oruk ttara aPhilistiya
\p 
\v 1 Mẹ wọ, wa Devid ochibhi k'ettem chẹ, oben bi, “Ewu dani Saul ófhu-m ofhu. Odik obongikwẹ kwa kaam ifha nkkaana for saam, ode bi, nnọbh nchina k'ẹkhọma cha Philistiya e. Mẹ wọ kwa Saul ọ́kwọbh-m ororor k'ibe kpenamkpen m'Israẹl, kaam mbir ńnaang ẹ.”
\p 
\v 2 Mẹ wọ, Devid obina ttara anọng pẹ ẹnọhna obhiri arọbh jobh ochina k'ọvaar Akish kwa Gat, kw'ode nnwa kwa Maok.
\v 3 Devid ọmaana ajinọng pẹ arukhi ttara Akish ka Gat. Ojinọng kpenamkpen ọmaana ẹhọhmmọr chẹ. Wa Devid ọkhaam panọng afa p'ade Ahinoam kwa Jẹzrẹl ọmaana Abigẹl kwa Kaamẹl kw'ode opopa kwa Nabal.
\v 4 Mada Saul ọbhaang bi, Devid ọkk'ọrọbha ochina ka Gat, ọkwọbh-ẹ ororor.
\p 
\v 5 Mẹ wọ, Devid oben Akish bi, “Idikha nkk'ọphyaam ndọkha ka kọ k'itzitzikha, tte bẹ anang-m ibe m'obhon nwa ifha nnuk. Okhuri yan kwa kaam ọtzọhmnọng kwọ nna-nnuk k'ivaar-be ttar-ọ o?”
\p 
\v 6 Mẹ wọ, m'ewu nduma, Akish ọn-ọnang-ẹ obhon kwa Ziklag, in-ide irerek s'avaarnọng pa Juda, ttẹwọr kẹ ma apyiri ma.
\v 7 Wa Devid orukhi cho wani ọmaana aphe anna k'ẹkhọma cha Philistiya.
\p 
\v 8 Wa Devid ọmaana anọng pẹ, atza arima abaGeshur, ọmaana abaGirz ttara ab'Amalẹk abẹ. Anọng mba akk'arukha m'irerek nna s'ittẹwọr ka Shur inyaami ipyiri k'Ijip, ttẹwọr k'ọtzama-gbe.
\v 9 Ogbe kpenamkpen kwa Devid orim anọng abẹ, ọnọng manda wani ọbọhk k'om-otte oruk akpen, ode ojinọng obiro ode kwanọng. Yina, ọm-ọtzọkha arukhimaan, ọmaana ndamogbodo, ọmaana nnyanyaang, ọmaana akamẹl ttara ọbara otzima ọkpa nnam otza okhebha Akish.
\p 
\v 10 Ogbe kw'Akish ọbọbhi bi, “Bọng anọng p'arim abẹ mayina?” Devid om-oben bi, “Morim Nẹgẹv kwa Juda ọmaana Nẹgẹv kwa Jẹramẹl ttara Nẹgẹv kwa abaKen abẹ e.”
\v 11 Devid ọnọng manda wani ọbọhk kotte, ode ojinọng obiro ode kwanọng oruk akpen ọkpa nnam ka Gat, okhuri da kẹ ochibhi bi “Bẹ afha ajaakhi agbaak man aben bi, ‘Kkeri odik-dema kwa Devid osi e.’ ” Osisi kwa Devid wọ mẹ mada orukhi k'ẹkhọma cha Philistiya.
\v 12 Wa Akish ọkhaam ekhera ka Devid ochibhi k'ettem chẹ bi, “Devid ọkk'anọng pẹ p'Israẹl idik okpukhi, mẹ wọ, kẹ ón-ode ọtzọhmnọng kwaam maa ogbe ode.”
\c 28
\s1 Saul ọmaana ọbọhnga-nọng kw'Ẹndọr
\p 
\v 1 K'ogbe nwuma, aPhilistiya atzobh agbong-nọng pabẹ bi, bẹ arima anọng p'Israẹl abẹ. Akish oben Devid bi, “Kọ ronga bi, kọ ọmaana anọng pọ, bọng átzor-m egbong o.”
\p 
\v 2 Devid oben bi, “Tte kwẹ ode mando, yina kw'an-are ọttọhk fa kaam ọtzọhmnọng kwọ mfha nsi ẹ.”
\p Akish obhina bi, “Ojibhi kẹ, kaam nna nsọ-ọ ade ọbaabh-akpen paam maa ogbe ode.”
\p 
\v 3 M'ogbe nwa, wa Samwẹl ọkk'ọpa, bẹ anọhng-ẹ ka Rama kw'ode obhon kwẹ, anọng p'Israẹl biphyir akk'abira awobha ka nkwu-osisi sẹ. Wa Saul ọkk'abhar-abọhkpakpa ọmaana abọhnga-nọng okhubha k'Israẹl.
\p 
\v 4 APhilistiya akwu atzobha asi ibhingabe ka Shunẹm. Yina Saul otzobha anọng p'Israẹl biphyir, asi ibhingabe ka Gilboa.
\v 5 Mada Saul ore agbong-nọng pa Philistiya, opoma ọsẹ-ẹ, ojora obiro ọfhẹ-ẹ k'ettem \it bi pyẹẹr\it*
\v 6 Mẹ wọ, Saul ọdọhn Ọvaar Ibinọkpaabyi, yina, kaambi k'ọdachen vọ, obiro ode k'ose ọbhabhari, ọmaana k'asi-ẹjaakhi, Ọvaar Ibinọkpaabyi kẹ ebhina kọnangi.
\v 7 Mẹ wọ, Saul ọgbaak akhaan-nọng pẹ bi, “Bọng nnor kwanọng kw'ọbhari abọhkpakpa anang-m ifha nda ndọhn-ẹ.”
\p Bẹ aben bi, “ọbhari abọhkpakpa wani owobh k'Ẹndọr.”
\p 
\v 8 Mẹ wọ, Saul obhona ẹnya chẹ, ọn-ọfọra ẹnya ẹdọdọk ifha bẹ aning-ẹ atzini. M'erungi, kẹ ọmaana ajinọng afa atzọn achina ka kwanọng nwuma. Oben-ẹ bi, “Kọ bhari abọhkpakpa pọ anang-m, ifha opfuranọng kwa nyeri che, oyin.”
\p 
\v 9 Mẹ wọ, kwanọng nwuma obhin-ẹ bi, “Kọ akk'aronga k'odik-ọkka bi, Saul ọkk'ibọhk ọsana, okhubh abhar-abọhkpakpa ọmaana abọhnga-nọng p'obhon nwa. Okhuri yan kwa bọng amun-m ọmma kw'obo-dema nwa o?”
\p 
\v 10 Mẹ wọ, Saul ọnwọhngi ọnang-ẹ, ka che ch'Ọvaar Ibinọkpaabyi bi, “K'odik ọkkọkka mach'Ọvaar Ibinọkpaabyi orukhi akpen, ọnọng kw'ọsọ-ọ ọttọhk kode.”
\p 
\v 11 Mẹ wọ, kwanọng nwuma ọbọbh-ẹ bi, “Anyi wọ kw'arori bi nsi oyin k'epe o?” Obhin-ẹ bi, “Si Samwẹl oyin k'epe.”
\p 
\v 12 Mada kwanọng nwuma ore Samwẹl, ọkpẹbh ẹmọng k'ẹrọng, oben Saul bi, “Okhuri yan kw'abọr-m o? Kọ ade Saul.”
\p 
\v 13 Ọvaarnọng oben-ẹ bi, “Ojora oning-ọ osi. Mbọng f'are o?”
\p Kwanọng nwuma obhina Saul bi, “Nne opfuranọng kw'oyini k'epe e.”
\p 
\v 14 Saul ọbọbh-ẹ bi, “Okheri mbọng o?”
\p Kwanọng nwuma obhin-ẹ bi, “Okheri ojinọng kw'ọkk'ọtzama, kw'ọfhọr owura-baba.”
\p Mẹ wọ, wa Saul oronga bi, Samwẹl wọ, ofona mẹ, ọrakha ottima itzitzikha k'irerek.
\p 
\v 15 Samwẹl oben Saul bi, “Okhuri yan, kw'ayakh-m atzim bi, asi-m mphyọbha k'epekhung o?”
\p Saul obhin-ẹ bi, “Okhuri bi kaam nwobh ka dama-dama kw'ideden. Anọng pa Philistiya am-arimm-m abẹ e, kaam bi mẹ wọ, Ibinọkpaabyi okk'nnam ọkpa ọbọr-m. Kaam ebhina k'ọdachen ọmaana k'agbaakhi-nkkaabha dọk kọmọnang. Mẹ wọ, nkwu bi agbaakh-m odem kwa nsi.”
\p 
\v 16 Samwẹl oben bi, “Okhuri yan kwa akwu dọhn-m o, mada Ọvaar Ibinọkpaabyi okk'nnam ọkpa ọbọrọ-ọ, on-ode ọttattaanga-nọng kwọ o?
\v 17 Ọvaar Ibinọkpaabyi ọkk'ọsa mach'iwa otzim-m osi ẹjaakhi bi osi. Ọvaar Ibinọkpaabyi okk'ẹvaar otzini ka mbọhk sọ, ọnang oyok ẹkhaan kwọ, kw'ode Devid.
\v 18 Da kọ ani mach'Ọvaar Ibinọkpaabyi ọtzọhn-ọ bi, adimi anọng p'Amalẹk ọmaana etzirakpo pyabẹ biphyir asi, kẹ wọ si Ọvaar Ibinọkpaabyi ọsọ-ọ manda mayina.
\v 19 Ọvaar Ibinọkpaabyi on-ọtzọkha kọ ọmaana anọng p'Israẹl okhe ka mbọhk s'anọng pa Philistiya, mẹ wọ, k'ewu ch'ophyini, kọ ọmaana va pọ ápe ópe. Ọvaar Ibinọkpaabyi obiro ósi agbongnọng p'Israẹl awobha k'irekh-irek kw'anọng pa Philistiya.”
\p 
\v 20 Ogbe kobhiri, Saul otto onemi idumsẹ m'irerek, k'opoma okhuri atzim pa Samwẹl ọgbaakhi. Ẹfa dọk kọkhaam, okhuri ofor-mọma kwa oyim okwo k'ewu nduma ọmaana erungi biphyir.
\p 
\v 21 Mada kwanọng nwuma ore bi, ojora okk'Saul ọsa, oben-ẹ bi, “Tzotzokhaan itta, ọtzọhmnọng kwọ ọkk'ọ okpobha. Mbar ettem, nsi mach'aben-m bi nsi.
\v 22 Tzotzokhaan kọ biri yonga ọtzọhmnọng kwọ itzọhng, tte nnang-ọ ọchattọhk achi ifha akhaama ẹfa ch'atzima arenga k'eden abhana.”
\p 
\v 23 Wa Saul obhum, oben bi, “Ọttọhk kinchi.”
\p Mẹ wọ, atzọhmnọng pẹ, ọmaana kwanọng nwuma achina ororo agban-ẹ bi ochi ọttọhk, wa ọbhaanga bẹ. Ọbina k'irerek owobha ẹwọr k'eyima.
\p 
\v 24 Kwanọng nwuma ọtzọkha ọbhaamnwa kw'ojibhi for kw'ọgban k'ọhọhm ofhu. Obiro ogberi abubuma p'awit otzima osi brẹd kwa bẹ ani yist akhe.
\v 25 Mẹ wọ, otzini brẹd nnwa obera Saul ọmaana atzọhmnọng pẹ, bẹ achi. M'erungiwu nduma dani bẹ abina abhana.
\c 29
\s1 Anọng pa Philistiya abhumi Devid
\p 
\v 1 Wa aPhilistiya atzobh agbong-nọng pabẹ k'Aphẹk, anọng p'Israẹl abira abhing k'ikhekhekha kwa Jẹzrẹl.
\v 2 Mada adaabhi p'aPhilistiya am-arenga ka ngaan sabẹ s'arọbh azen-azen, ọmaana ka nnọhna-nnọhna, Devid ọmaana ajinọng pẹ am-arenga Akish ka nnam-annam.
\v 3 Odenho kw'aPhilistiya ọbọbh bi, “AHiburu mba am-asi mbọng ma o?”
\p Akish obhina bi, “Devid kw'ode odenho wani kwa Saul, ọvaarnọng kw'Israẹl wọ ma e. Kẹ okk'owobha ttara kaam ọttọhk ka cho ọmaana-ọmaana, ttẹwọr k'ewu ch'owobh ttara kaam maa opyiri ma, epina otzim ọkhaama.”
\p 
\v 4 Yina, adenho p'agbong-nọng pa Philistiya ọdọhkhi bẹ ttara Akish, bẹ aben bi, “Kọ ben ojinọng nwa ọkpa nnam k'obhon kw'akk'ẹ ananga. Kẹ kọkhaambi ọtzọn man abẹ ọtza egbong, ifha oningi man abẹ ọbhakhi k'égbong-dam. Yan wọ kwa kẹ otzima osi ettem ẹdaam itta kwẹ o, idikha oni nho s'ajinọng paman otzim o?
\v 5 Devid nwa arang ma kwa bẹ akkọhni k'ẹmọng aben bi,
\q1 “ ‘Saul okk'nnọhna sẹ ọfha,
\q2 Devid okk'nnọhna-nabhik sẹ ọfha.’ ”
\p 
\v 6 Mẹ wọ, Akish oyeri Devid oben-ẹ bi, “Mach'Ọvaar Ibinọkpaabyi orukhi akpen, kọ akk'oyokh-ẹkhaan ọkkakka ada, kaam ira ọdaakh-m bi, mọtzọn osi ọtzọhm f'arim-egbong e. Ttẹwọr k'ewu ch'iwa arọbhi atzor-m, maa apyiri ma, epina ka kọ ndimi nna, yina, adabhi kakher bi, atza egbong e.
\v 7 Kọ kpa nnam abhana k'odidiri, odik kasi kw'ọdọkhi adabhi pa Philistiya.”
\p 
\v 8 Devid ọn-ọbọbh bi, “Kaam nsi yan o? Bọng epina cha kọ akk'ara ka kaam ọtzọhmnọng kwọ, tzọni k'ewu ch'iwa nnọbhi ndor-ọ, maa apyiri ma o? Mbọng vọ ira osi kaam nningi attattaanga-nọng p'itta kwaam kw'ode ọvaarnọng abẹ nda nnima?”
\p 
\v 9 Akish obhina Devid bi, “Kaam nnong kẹ bi, kọ epina k'itzitzikha saam kakhaam mach'oreng-eden kw'Ibinọkpaabyi kw'oni epina ọkhaam, odik ode bi, adenho p'agbong-nọng pa Philistiya abeni bi, ‘Kẹ kọkhaambi ọtzọn man abẹ ọtza egbong.’
\v 10 Mẹ wọ, ophyini k'ekpekpebha, kọ bina atzima atzọhmnọng p'itta kwọ p'atzọn-ọ abẹ, abhana mada ewu ẹttaani.”
\p 
\v 11 Mẹ wọ e, Devid otzima anọng pẹ obina k'ekpekpebha ọkpa nnam ọbhana k'ẹkhọma cha Philistiya, aPhilistiya abira achina ka Jẹzrẹl.
\c 30
\s1 Devid ofhu anọng p'Amalẹk
\p 
\v 1 Wa Devid ọmaana ajinọng pẹ, atzim iwu ittaan apyiri Ziklag. M'ogbe nwuma, ab'Amalẹk akk'Nẹgẹv ọmaana Ziklag acha k'egbong. Bẹ akk'Ziklag abẹ arima maa bẹ atzima ekpon akwọm-ẹ.
\v 2 Bẹ abira abọkha panọng ọmaana anọng p'awobh mẹ biphyir, vava ttara adenden-nọng k'ẹmmọri. Wa bẹ ọnọng manda wani kafhu, yina, bẹ atzim bẹ ekhekhebhi afona.
\p 
\v 3 Mada Devid ọmaana ajinọng pẹ apyiri Ziklag, bẹ an-are bi, bẹ akk'Ziklag akwọmi biphyir, bẹ abira abọkha panọng pabẹ ọmaana va pabẹ p'ijinọng ọmaana p'ipanọng k'ẹmmọri.
\v 4 Mẹ wọ, Devid ọmaana anọng pẹ abhom amọng k'ẹrọng maa, ẹfa ch'obhoma ẹha bẹ.
\v 5 Wa bẹ akk'panọng pa Devid afa p'ade; Ahinoam kw'ofon Jẹzrẹl, ọmaana Abigẹl kw'ode opopa kwa Nabal kw'ofon Kaamẹl, abọkha atzima afona.
\v 6 Wa odik nwa ọyak Devid atzim k'iden-dama, okhuri da iwa anọng pẹ an-am-aben bi atzọbh-ẹ atza. Wa ọnọng kpenamkpen ettem ekk'ẹpyibha itzama-itzama, okhuri panọng ọmaana va pabẹ p'ijinọng ọmaana p'ipanọng. Yina, Devid ọtzọk ottem-bara k'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwẹ.
\p 
\v 7 Mẹ wọ, Devid oben Abiyata kw'ode ọfọhnẹja, obiro ode nnwa kw'Ahimẹlẹk bi, “Kọ tzọkha ẹphọd chen-m.” Abiyata ọtzọkha ẹphọd ochen-ẹ.
\v 8 Devid e, ọdọhn Ọvaar Ibinọkpaabyi bi, “Itta, ma ńgubh ẹkhaan nda ch'echi obhon o? Na mfha ngọbha bẹ o?” Ọvaar Ibinọkpaabyi obhina bi, “Kọ khubh bẹ, kkeri ábọkha bẹ ọbọkha, abira árọbha anọng pọ ọrọbha ka mbọhk sabẹ.”
\p 
\v 9 Mẹ wọ, Devid ọmaana ajinọng pẹ ẹnọhna obhiri arọbh jobh p'atzọn-ẹ abẹ apyiri k'ẹttẹri cha Bẹsọr, mẹ da bẹ ahokhi ayok bani.
\v 10 Wa anọng arọbh jobh ọkhọhn bẹ maa, bẹ ẹttẹri nduma kafha ajekha. Yina, Devid ọmaana ajinọng pẹ ẹnọhna achina ororo okhubh anọng mba.
\p 
\v 11 Wa bẹ are oJipnọng wani kw'owobh k'owoni, bẹ abọkh-ẹ achena Devid. Bẹ anang-ẹ asi ogwo, abira anang-ẹ ọchattọhk ochi.
\v 12 Bẹ abira atzọkha afig p'agwu-ogwu ọmaana agrep p'agwu-ogwu anang-ẹ, ochi obiro ọkhaama ẹfa. Kẹ wa ọchattọhk manda vani k'iwu ittaan ọmaana nnungiwu nttaan otzim ọm-ọmọcha. Asi manda bani k'iwu ittaan ọmaana nnungiwu nttaan otzim ọm-ọgwa.
\p 
\v 13 Wa Devid ọbọbh-ẹ bi, “Anyi wọ ode atte? Kọ afon man?”
\p Oben bi, “Kaam mfon Ijip, nde obira kw'ọnọng kw'ofon Amalẹk. Itta kwaam obhum-m da ọmmaam-m k'iwu ittaan s'ikk'ikwọbha e.
\v 14 Mokk'Nẹgẹv kw'aKẹrẹt, ọmaana okhubha kwa Juda, ttara Nẹgẹv kwa Kalẹb ọcha k'egbong e. Mokk'ekpon obiro otzima ọkwọmi Ziklag.”
\p 
\v 15 Devid ọbọbh-ẹ bi, “Na kọ atzim-m nda ngebha ẹkhaan ch'akhọkhọhra mbuma o?”
\p Obhina bi, “Kọ chekhi m'itzitzikha s'Ibinọkpaabyi bi, kọ kaam kafhu, kaam ọbọhk kabira atte anang itta kwaam. Kaam ndim-otzima nda kẹ da bẹ awobh.”
\p 
\v 16 Mẹ wọ, oJip-nọng nwuma otzima Devid eden ofona, bẹ atza akhebha ab'Amalẹk p'akk'anyaami makhọri ibe kpenamkpen. Bẹ am-achi, abira am-agwo, am-asi ọdadaami okhuri ọgbọm-barada fa bẹ akk'acha k'ẹkhọma ch'aPhilistiya, ọmaana ka Juda.
\v 17 Devid orima bẹ abẹ ttẹwọr m'ẹchọhkha nduma maa, otza opyiri ẹchọhkha ch'ẹwu ẹdọdọk. Wa ọnọng manda wani kw'ọnaang kode, oyongi adikkobh ẹnọhna p'avur akamẹl arọbh afona.
\v 18 Wa Devid ọkpa nnam ọtzọkha ọttọhk kpenamkpen, ttara panọng pẹ afa p'ab'Amalẹk akk'atzọkha.
\v 19 Ọttọhk manda vani f'iwa odimi kode. Wa Devid otzim ọttọhk kpenamkpen ọkpa nnam, ttẹwọr k'igbọ ọmaana adeden-nọng, adikkobh ttara aminava, ọgbọm ọmaana ọttọhk kpenamkpen fa bẹ akk'atzọkha.
\v 20 Wa Devid ọkpa nnam ọtzọkha arukhimaan ọmaana abhaam biphyir, agbongnọng pẹ akpena pyẹ k'itzitzikha s'etzirakpo ọdọdọk, am-aben bi, “Ma wọ ode ọgbọm fa Devid e.”
\p 
\v 21 Wa Devid ọkpa nnam okwu okhebha ajinọng arọbh jobh mba p'ira ẹfa ẹkk'ẹha, bẹ kẹ abẹ kafha atzọn, bẹ an-atte bẹ ọbọhk k'ẹttẹri cha Bẹsọr. Anọng mba ayin ka akwu akhebha Devid ọmaana ajinọng p'atzọn-ẹ abẹ. Mada Devid ọmaana ajinọng pẹ areng ọbaanga bẹ, Devid orima bẹ.
\v 22 Yina, abyibyanọng ọmaana akhọkhọra biphyir p'awobh k'ottem kw'anọng p'atzọni Devid abẹ, aben bi, “Bẹ ekkema manda dani m'ọgbọm mva kátzọkha, okhuri bi, ira bẹ man abẹ katzọni. Tte ojinọng kpenamkpen okhinggẹ ọtzọkha kwanọng kwẹ ọmaana va pẹ, ọrọhng ọbhana.”
\p 
\v 23 Devid obhina bi, “Mma e, votte paam, bọng mando kakhaambi asi ttara ekpo py'Ọvaar Ibinọkpaabyi okk'man ọnanga e. Kẹ okk'man ọkkaana, obiro otte agbong-nọng p'arim man abẹ ọbọhk ọnang man.
\v 24 Anyi wọ óyonga bọng itzọhng k'odik kwa bọng agbaakh o? Ekkema ch'anang ọnọng kw'ira okkeri egbongkpo, ede mbenga-mbọhk ttara ọnọng kw'ira ọtza egbong. Anọng biphyir átzọkha ekkema odem wani.”
\v 25 Wa Devid ọtzọkha odik nwa ohok mach'ọsana, ttara ọphaangi ọnang anọng p'Israẹl, ttẹwọr kẹ maa apyiri mayina.
\p 
\v 26 Mada Devid opyiri ka Ziklag, ọtzọhm ekkema ch'ọgbọm ochena adenho pa Juda, p'ade ayokh-odikkobh pẹ, oben bi, “Ma wọ ode ẹnanga cha bọng ch'efon k'ọgbọm fa mochi k'attattaanga-nọng p'Ọvaar Ibinọkpaabyi.”
\p 
\v 27 Wa okkema ẹnanga nda ọtzọhm ochena anọng ka Bẹtẹl, ọmaana ka Ramọt Nẹgẹv, ttara ka Jatir,
\v 28 ọmaana k'Aroe, ọmaana ka Siphmọt, ttara Ẹstẹmoa,
\v 29 ọmaana ka Rakal, ọmaana k'ibhon s'abaJẹramẹl ttara abaKen,
\v 30 ọmaana ka Họma, ọmaana ka Bor-Ashan, ttara k'Atak,
\v 31 ọmaana ka Hẹbrọn, ttara anọng k'obe kpenamkpen mva fa Devid ọmaana anọng pẹ, akk'awena apyiri.
\c 31
\s1 Obo kwa Saul ọmaana va pẹ
\p 
\v 1 M'ogbe nwa, wa aPhilistiya atza arima anọng p'Israẹl abẹ. Ajinọng p'Israẹl arọbh k'itzitzikha s'aPhilistiya. Wa anọng p'Israẹl haabhada ape k'egbegbeho cha Gilboa.
\v 2 Wa aPhilistiya akhubh Saul ọmaana va pẹ p'ijinọng m'ẹkhoma-ẹkhọma, bẹ afhu va pa Saul p'ijinọng p'ade; Jonatan, ọmaana Abinadab, ttara Malki-Shua.
\v 3 Egbong nduma echina ororo ẹgaangi maa ekhe Saul k'ottem. Mada abhar-ayuk akhọbh Saul, bẹ ammum-ẹ ekpo itzama-itzama.
\p 
\v 4 Mẹ wọ e, Saul oben otzim-egbongkpo pyẹ bi, “Tzọr ọkkangkkaang kwọ akhum-m, oni mando ode, akpatzọr-nọng mba ákwu akhebh-m okhebha ma akhum afhu, bẹ abira aben-m ẹmma.”
\p Yina, otzim-egbongkpo pyẹ odik nwuma ojor-ẹ, kẹ kokher ofhu, ofona mẹ, Saul ọtzọkha ọkkangkkaang kwa kẹ khaam, otto ọkpẹkhi ofhu for sẹ.
\v 5 Mada otzim-egbongkpo ore bi Saul ọkk'ọpa, kẹ obiro otto ọkpẹkhi ọkkangkkaang kwa kẹ kaam, ofhu for sẹ.
\v 6 Mẹ wọ, Saul ọmaana va pẹ attaan, ọmaana otzim-egbongkpo kwẹ, ttara ajinọng pẹ biphyir, ape ewu nduma dani.
\p 
\v 7 Mada anọng p'Israẹl p'arukhi k'okhubha nwonggo kw'ẹttẹr, ọmaana ayok p'arukhi ka Jọrdan okhubha, an-are bi agbong-nọng p'Israẹl akk'arọbha, ọmaana bi Saul ttara va pẹ akk'apa, bẹ abina aji ibhon sabẹ, arọbh afona. Wa aPhilistiya an-akwu atzọkha ibhon nnuma aruk.
\p 
\v 8 Ewu ekhobh mẹ, mada aPhilistiya akwu bi akwu afhọhngi abukhi mbuma, bẹ are abukhi pa Saul, ọmaana va pẹ attaan p'atto ayima k'egbegbeho cha Gilboa.
\v 9 Bẹ akpaara eho cha Saul, abira atzọkha egbongkpo pyẹ. Bẹ atzọhm akkaabh-nkkaabha bi, bẹ asi ẹjaakhi k'ẹkhọma cha Philistiya \it bi waam,\it* k'ọkhapa kw'akha pabẹ, ọmaana k'anọng pabẹ.
\v 10 Bẹ atzọkha egbongkpo pya Saul ahok k'ọkhapa kw'agbatza p'Ashtọrẹt. Bẹ atzọkha obukhi kwẹ adabh k'echumi ch'obhon kwa Bẹt-Shan.
\p 
\v 11 Mada anọng pa Jabẹsh-Gilead abhaang odik kw'aPhilistiya asi Saul,
\v 12 akkakkaama pabẹ biphyir abina orenga m'erungi nduma achina ka Bẹt-Shan. Bẹ akhanga obukhi kwa Saul ọmaana pa va pẹ p'ijinọng k'echumi cha Bẹt-Shan, atzima bẹ atza akwọmi ka Jabẹsh.
\v 13 Mẹ wọ e, bẹ atzọkha akhọbhi pabẹ anọhnga k'irekh-irek kw'echi cha tamarisk ka Jabẹsh. Bẹ atzim ọchattọhk k'iwu izenamfa.
