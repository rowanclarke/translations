\id 1PE - Biblica® Open Igbo Contemporary Bible 2020
\h 1 Pita
\toc1 1 Pita
\toc2 1 Pita
\toc3 1Pt
\mt1 1 Pita
\c 1
\p 
\v 1 Pita, onyeozi Jisọs Kraịst,
\b
\p Na-edegara unu ndị niile ndị a họpụtara, ndị gbara ọsọ ndụ gaa biri na Pọntọs, na Galeshịa, na Kapadosia, Eshịa na Bitinia, akwụkwọ a.
\v 2 Unu ndị Chineke bụ Nna họpụtara dị ka o bururị ụzọ mata na ọ ga-eme, jirikwa Mmụọ Nsọ ya doo unu nsọ, ka unu na-erubere Jisọs Kraịst isi, ka ewerekwa ọbara ya sachaa unu:
\b
\p Ka amara na udo baara unu ụba.
\b
\s1 Olileanya dị ndụ
\p 
\v 3 Otuto dịrị Chineke Nna Onyenwe anyị Jisọs Kraịst! Site nʼịba ụba nke ebere ya, o nyela anyị ndụ ọhụrụ baa nʼolileanya dị ndụ site na mbilite nʼọnwụ Jisọs Kraịst.
\v 4 Anyị nwekwara ihe nketa nke na-apụghị imebi emebi, nke na-agaghị ere ure, maọbụ gbanwee ụdịdị ya, nke e debeere anyị nʼeluigwe.
\v 5 Anyị bụ ndị e sitere nʼokwukwe na-echekwa nʼike Chineke, tutu ruo ọbịbịa nzọpụta ahụ, nke a na-ejikere ime ka ọ pụta ìhè nʼọgwụgwụ oge.
\v 6 Nʼime ihe ndị a ka unu na-aṅụrị oke ọṅụ, ọ bụ ezie na nʼoge ndị a dị nta, unu agabigala ọtụtụ ihe mgbu nʼihi ụdị ọnwụnwa dị iche iche bịakwasịrị unu.
\v 7 Ọnwụnwa ndị a na-abịa ime ka okwukwe unu, nke dị oke ọnụahịa karịa ọlaedo na-ala nʼiyi nʼagbanyeghị na e ji ọkụ nụchaa ya; bụrụ nke ga-eweta otuto, na ebube, na nsọpụrụ, mgbe e mere ka Jisọs Kraịst pụta ìhè.
\v 8 Ọ bụ ezie na unu ejibeghị anya unu hụ ya mgbe ọbụla, ma unu hụrụ ya nʼanya, ọ bụkwa ezie na unu adịghị ahụ ya anya ugbu a, ma unu kwere na ya. Unu jupụtakwara nʼọṅụ ahụ dị ebube nke ọnụ na-apụghị ịkọwa.
\v 9 Ụgwọ ọrụ ọzọ unu ga-enweta nʼihi okwukwe unu nʼime ya ga-abụ nzọpụta a ga-azọpụta mkpụrụobi unu.
\p 
\v 10 Banyere nzọpụta a, ndị amụma ahụ kwuru ihe banyere amara ahụ gaje ịbịara unu jiri nnọọ nwayọọ nyochasịa
\v 11 ma gbalịsie ike ịchọpụta oge na ọnọdụ ahụ bụ nke Mmụọ Kraịst dị nʼime ha kwuru banyere ya, mgbe ọ gbara ama maka ahụhụ Kraịst na ebube nke ga-eso ya.
\v 12 E mere ka ha mata na ọrụ ha na-arụ abụghị maka ọdịmma nke ha onwe ha, kama ọ bụ nʼihi ọdịmma nke unu, mgbe ha kwuru okwu banyere ihe ndị a ahụ bụ ndị a gwarala unu ugbu a site nʼọnụ ndị ziri unu oziọma nʼike Mmụọ Nsọ nke e si nʼeluigwe zite. Ọ bụladị ndị mmụọ ozi ka ọ gụrụ agụụ ịmata ihe ndị a.
\s1 Bụrụnụ ndị dị nsọ
\p 
\v 13 Nʼihi ya, werenụ uche unu niile jikere ịrụ ọrụ, anya dokwaa unu. Nweenụ olileanya zuruoke nʼamara nke a ga-ewetara unu mgbe a ga-ekpughe Jisọs Kraịst.
\v 14 Dị ka ụmụ na-erube isi, unu ekwela ka ihe ọjọọ ndị ahụ na-agụ unu agụụ mgbe unu nọ nʼọchịchịrị, na-achị ndụ unu.
\v 15 Kama bụrụnụ ndị dị nsọ nʼihe niile unu na-eme, dịka onye kpọrọ unu si dị nsọ.
\v 16 Nʼihi na e dere ya ede, “Dịnụ nsọ, nʼihi na adị m nsọ.”\f + \fr 1:16 \ft \xt Lev 11:44,45; 19:2\xt*\f*
\p 
\v 17 Ebe unu na-akpọku Nna ahụ na-ekpe onye ọbụla ikpe dị ka ọrụ ya sịrị dị na-eleghị mmadụ anya nʼihu, bienụ ndụ unu nʼịtụ egwu Chineke, dịka ndị mbịarambịa nʼụwa a.
\v 18 Nʼihi na unu matara na-ejighị ihe pụrụ imebi emebi, dịka ọlaọcha na ọlaedo gbapụta unu site nʼibi ndụ ọjọọ ahụ nna nna unu ha nyefere unu nʼaka
\v 19 kama ọ bụ ọbara dị oke ọnụahịa nke Kraịst bụ nwa atụrụ na-enweghị ntụpọ ọbụla maọbụ ọrụsị.
\v 20 A họpụtara ya tupu e kee ụwa. Kama, ọ bụ nʼọgwụgwụ oge ndị a ka e mere ka ọ pụta ìhè nʼihi unu.
\v 21 Ọ bụkwa site nʼaka ya ka unu ji bụrụ ndị kwere na Chineke, onye mere ka o si nʼọnwụ bilie, na onye nyekwara ya ebube. Ya mere, okwukwe unu na olileanya unu dị na Chineke.
\p 
\v 22 Ugbu a, ebe unu sitere nʼirubere eziokwu ahụ isi mee ka obi unu dị ọcha, nke mere na unu nwere ịhụnanya nke ihu abụọ nʼadịghị nʼebe ụmụnna unu nọ, sitenụ nʼobi unu na-ahụrịtanụ onwe unu nʼanya nʼebe ọ dị ukwuu.
\v 23 Nʼihi na amụọla unu ọzọ ugbu a, ọ bụghị site na mkpụrụ nke na-emebi emebi, kama site na nke na-apụghị imebi emebi, site nʼokwu Chineke nke dị ndụ ma na-adịgidekwa.
\v 24 Nʼihi na,
\q1 “Mmadụ niile dị ka ahịhịa,
\q2 ma ebube ha niile dị ka okoko osisi nke ọhịa,
\q1 ahịhịa na-akpọnwụ, okoko osisi na-achanwụ,
\q2 
\v 25 ma okwu Onyenwe anyị na-anọgide ruo mgbe ebighị ebi.”\f + \fr 1:25 \ft \xt Aịz 40:6-8\xt*\f*
\m Okwu ahụ bụkwa oziọma ahụ e zisaara unu.
\c 2
\p 
\v 1 Ya mere, wezuganụ nʼibu iro nʼobi na aghụghọ niile unu, kwụsịnụ ịgha ụgha, ịbụ ndị ihu abụọ, ndị na-ekwo ekworo, na ndị na-ekwutọ mmadụ ibe ha.
\v 2 Dịka ụmụ a mụrụ ọhụrụ, bụrụnụ ndị agụụ ịṅụ mmiri ara nke Mmụọ Nsọ a na-agwaghị ihe ọbụla na-agụ, ka unu nwee ike site na ya na-eto eto nʼime nzọpụta unu.
\v 3 Ugbu a, unu detụrụla ya ire matakwa na Onyenwe anyị dị mma.
\s1 Nkume dị ndụ na ndị a họpụtara
\p 
\v 4 Bịakwutenụ ya, Nkume ahụ dị ndụ, onye ụmụ mmadụ jụrụ, maọbụ onye Chineke họpụtara, onye dị oke ọnụahịa nye ya.
\v 5 Unu onwe unu kwa dị ka nkume dị ndụ ka a na-ewu ime ka unu ghọọ ụlọ ime mmụọ, ka unu bụrụkwa ndị nchụaja dị nsọ, ndị na-achụ aja ime mmụọ nke Chineke na-anabata site na Jisọs Kraịst.
\v 6 Nʼihi nʼakwụkwọ nsọ kwuru,
\q1 “Lee, ana m atọgbọ na Zayọn otu nkume,
\q2 nke a họpụtara, bụkwa nkume isi ntọala dị oke ọnụahịa.
\q1 Onye ọbụla kweere na ya,
\q2 agaghị eme ka ihere mee ya.”\f + \fr 2:6 \ft \xt Aịz 28:16\xt*\f*
\m 
\v 7 Ma nye unu ndị kwere ekwe nkume a dị oke ọnụahịa, ma nʼebe ndị ahụ na-ekweghị ekwe nọ,
\q1 “Ọ bụ nkume nke ndị na-ewu ụlọ jụrụ
\q2 nke ghọrọ nkume isi ntọala ụlọ.”\f + \fr 2:7 \ft \xt Abụ 118:22\xt*\f*
\m 
\v 8 Ọ bụ kwa,
\q1 “Nkume nke na-eme ka ndị mmadụ sọọ ngọngọ,
\q2 oke nkume nke na-eme ka ha daa.”\f + \fr 2:8 \ft \xt Aịz 8:14\xt*\f*
\m Ha na-asọ ngọngọ nʼihi na ha jụrụ irube isi nʼokwu ahụ. Nke a bụkwa ihe a kara aka banyere ha.
\p 
\v 9 Ma unu bụ ndị a họpụtara, otu ndị nchụaja eze, mba dị nsọ, ndị nke Chineke nʼonwe ya, ka unu bụrụ ndị na-ekwusa otuto ya, bụ onye ahụ si nʼọchịchịrị kpọbata unu nʼìhè ya dị ebube.
\v 10 Nʼoge gara aga, unu abụghị ndị Chineke, ma ugbu a, unu bụ ndị ya. Na mbụ, unu amaghị ihe ọbụla banyere obi ebere ya, ma ugbu a, obi ebere ya erutela unu aka.
\s1 Mmeso onye Kraịst nye ndị ụwa
\p 
\v 11 Nʼihi ya, ndị enyi m, ana m arịọ unu, dịka ndị bụ ọbịa na ndị na-agba ọsọ ndụ nʼụwa a, nke unu bụ, na-asị unu, wezuganụ onwe unu site nʼagụụ mmehie nke na-ebuso mkpụrụobi unu agha.
\v 12 Bienụ ezi ndụ nʼetiti ndị mba ọzọ, ka ọ ga-abụ na a sị na ha ebo unu ebubo ime ihe ọjọọ, ha ga-ahụ ọrụ ọma unu, ma nye Chineke otuto nʼụbọchị ahụ ọ ga-abịa.
\p 
\v 13 Werenụ onwe unu nyefee, nʼihi Onyenwe anyị, nʼokpuru ọchịchị niile e guzobere nʼetiti ụmụ mmadụ, ma ọchịchị ahụ ọ bụ nke eze, dịka onye ike ya kacha nke ibe ya,
\v 14 maọbụ nke ọchịchị gọvanọ, onye e guzobere nʼihi ịta ndị na-eme ihe ọjọọ ahụhụ, na ito ndị na-eme ezi ihe otuto.
\v 15 Nʼihi na ọ bụ uche Chineke na unu ga-esite nʼezi ọrụ unu kpuchie ọnụ ndị ahụ na-esite na-amaghị ihe ha, na-ekwu okwu nzuzu.
\v 16 Na-ebinụ ndụ dị ka ndị nwere onwe ha, ma unu ejikwala mnwere onwe unu mere ihe mkpuchi nke ajọ ihe. Bienụ dịka ụmụodibo Chineke.
\v 17 Sọpụrụnụ mmadụ niile dịka o si kwesi. Gosi ndị niile kwere ekwe ịhụnanya. Tụọ Chineke egwu, ma na-asọpụrụ eze.
\s1 Jisọs bụ ihe ọmụmatụ
\p 
\v 18 Ndị ohu, ruberenụ ndị nwe unu isi, na-enyekwa ha nsọpụrụ na ugwu ruuru ha. Unu emela nke a nye naanị ndị bụ ezi mmadụ, na ndị nwere obiọma nʼebe unu nọ, kama meekwanụ ya ọ bụladị nye ndị afọ tara mmiri.
\v 19 Nʼihi na nke a bụ ihe inye ekele ma ọ bụrụ na unu ejiri ntachiobi na-edi ahụhụ na-ezighị ezi na-adakwasị unu, nʼihi na unu na-eme ihe Chineke na-achọ.
\v 20 Ma o nweghị otuto ọbụla dịrị unu mgbe a tara unu ahụhụ nʼihi na unu mejọrọ, unu na-edikwa ya? Ma ọ bụrụ na unu enwee ntachiobi mgbe a na-ata unu ahụhụ nʼihi ihe ọma unu na-eme, nke a na-ewetara Chineke otuto.
\v 21 Ọ bụ nʼihi ihe dị otu a, ka e jiri kpọọ unu, nʼihi na Kraịst hụrụ ahụhụ nʼihi unu. Ọ bụkwa ihe ịmaatụ nye unu. Na-esonụ nzọ ụkwụ ya.
\q1 
\v 22 “O nweghị mgbe ọbụla o mehiere,
\q2 o nwekwaghị mgbe onye ọbụla nụrụ okwu aghụghọ nʼọnụ ya.”\f + \fr 2:22 \ft \xt Aịz 53:9\xt*\f*
\m 
\v 23 O kwutọghị onye ọbụla mgbe ha na-ekwutọ ya. Ọ baghị mba ọbụla mgbe ha na-ata ya ahụhụ, kama o were ya nyefee nʼaka onye ahụ na-ekpe ikpe ziri ezi.
\v 24 Nʼelu obe ahụ, o buuru mmehie anyị niile bokwasị onwe ya mgbe ọ nwụrụ, ime ka anyị nwee ike ịbụ ndị nwụrụ anwụ nʼebe mmehie dị; ma dịrị ndụ nʼebe ezi omume dị. Ọ bụkwa site nʼapa ọnya dị ya nʼahụ ka o ji gwọọ unu.\f + \fr 2:24 \ft \xt Aịz 53:5\xt*\f*
\v 25 Na mbụ, unu dị ka ụmụ atụrụ na-awagharị na-achọ ụzọ,\f + \fr 2:25 \ft \xt Aịz 53:6\xt*\f* ma ugbu a, e meela ka unu laghachikwute Onye ahụ na-azụ unu dị ka atụrụ, na Onye na-elekọtakwa mkpụrụobi unu anya.
\c 3
\s1 Di na nwunye
\p 
\v 1 Unu ndị bụ nwunye na-eruberenụ di unu isi, ka ụfọdụ nʼime ha na-ekweghị nʼokwu Chineke, nwee ike isi nʼezi ndụ unu na-ebi chegharịa nʼekwughị okwu ọbụla,
\v 2 mgbe ha na-ahụ ibi ndụ unu nke dị ọcha na nke inwe nsọpụrụ.
\v 3 Ịchọ mma unu agaghị abụ ịchọ mma nke anụ ahụ, nke bụ ịkpa isi, na iyikwasị ihe ọlaedo, maọbụ iyikwasị uwe mara mma.
\v 4 Kama, ka ịchọ mma unu bụrụ mmadụ nke ime mmụọ, nke mma ya na-adịghị aṅacha, nke bụ mmụọ ịdị nwayọọ na ịdị juu. Nke dị oke ọnụahịa nʼihu Chineke.
\v 5 Nke a bụ ụzọ ndị inyom mgbe ochie, bụ ndị dị nsọ, ndị olileanya ha dị nʼime Chineke siri chọọ onwe ha mma. Ha debekwara onwe ha nʼokpuru di nke aka ha.
\v 6 Dịka Sera rubeere Ebraham isi, na-akpọkwa ya onyenwe m. Unu bụ ụmụ Sera ma ọ bụrụ na unu e mee ihe ziri ezi, na-ekweghị ka egwu tụọ unu.
\p 
\v 7 Nʼotu aka ahụ, ndị bụ di na-echenụ echiche dị mma banyere nwunye unu, ma nyenụ ha ugwu ruuru ha dịka ndị na-adịghị ike na dịka ndị unu na ha ga-eso keta onyinye amara nke ndụ ahụ. Nke a ga-eme ka ihe ọbụla hapụ igbochi ekpere unu.
\s1 Ịhụ ahụhụ nʼihi ime ihe dị mma
\p 
\v 8 Nʼikpeazụ, nweenụ otu mmụọ, ka ihe na-ewute ibe unu na-ewute unu, na-ahụrịtanụ onwe unu nʼanya, nwekwanụ obi ọmịiko na obi dị umeala.
\v 9 Unu ejila ihe ọjọọ akwụghachi ụgwọ ihe ọjọọ e mere unu, maọbụ nkwutọ nʼọnọdụ nkwutọ. Kama gọzienụ ha, nʼihi na ọ bụ ngọzị ka e kwere unu na nkwa iketa, mgbe a kpọrọ unu.
\v 10 Nʼihi na,
\q1 “Onye ọbụla nke na-achọ ndụ,
\q2 nke chọrọ ịhụ ụbọchị ndị ahụ dị mma,
\q1 ya mee ka ire ya ghara ikwu okwu ọjọọ
\q2 meekwa ka egbugbere ọnụ ya ghara ikwu okwu aghụghọ.
\q1 
\v 11 Ka ha tụgharịa site nʼajọ ihe ma mee ezi ihe;
\q2 ka ha chọọ udo, ma na-agbasokwa ya.
\q1 
\v 12 Nʼihi na anya Onyenwe anyị dị nʼahụ ndị ezi omume,
\q2 ntị ya gheekwa oghe nye ekpere ha,
\q1 ma ihu Onyenwe anyị na-emegide ndị na-eme ihe ọjọọ.”\f + \fr 3:12 \ft \xt Abụ 34:12-16\xt*\f*
\s1 Nọgide na-eme ihe ọma
\p 
\v 13 Onye ga-emegide unu ma ọ bụrụ na unu na-anụ ọkụ nʼobi ime ezi ihe?
\v 14 Ma a sịkwarị na unu ahụ ahụhụ nʼihi na unu mere ihe ziri ezi, ngọzị dịrị unu. “Unu atụla egwu ihe ha na-atụ egwu, ka obi gharakwa ịlọ unu mmiri.”\f + \fr 3:14 \ft \xt Aịz 8:12\xt*\f*
\v 15 Na-edonụ Kraịst nsọ nʼime obi unu dịka Onyenwe anyị. Nọọkwanụ na njikere mgbe niile iguzo kọwaara onye ọbụla jụrụ unu ajụjụ banyere olileanya ahụ unu nwere nʼime unu. Ma unu were obi dị nwayọọ na nsọpụrụ na-eme nke a.
\v 16 Ma na-enwenụ akọnuche dị ọcha, ka ndị ahụ na-ekwulu ibi obi ọma unu nʼime Kraịst, bụrụ ndị ihere ga-eme banyere nkwutọ ha na-ekwutọ unu.
\v 17 Nʼihi na ọ ka mma ịta ahụhụ nʼihi ezi ihe ma ọ bụrụ uche Chineke, karịa ịta ahụhụ nʼihi ajọ ihe.
\v 18 Nʼihi na Kraịst nʼonwe ya hụrụ ahụhụ nwụọ nʼihi unu otu mgbe. Onye ezi omume nwụrụ nʼihi ndị ajọ omume, ka ọ kpọrọ unu bịakwute Chineke. Nʼihi na e mere ka ọ nwụọ nʼanụ ahụ ma e mekwara ka ọ dị ndụ na mmụọ ya.
\v 19 Mgbe emesịrị ka ọ dị ndụ na mmụọ ya, ọ gara kwusaa oziọma nye mmụọ ndị ahụ a kpọchiri nʼụlọ mkpọrọ.
\v 20 Nke a bụ mmụọ ndị ahụ jụrụ ime ihe Chineke chọrọ mgbe ahụ o ji ntachiobi chere ha nʼoge ahụ Noa nọ na-ewu ụgbọ mmiri ya. Ọ bụ naanị mmadụ asatọ nʼime ndị bi nʼoge ahụ ka a zọpụtara site na mmiri ahụ.
\v 21 Mmiri a nọ ọnọdụ dị ka baptizim nke na-azọpụta unu ugbu a. Ọ anaghị asapụ unyi site nʼahụ mmadụ, kama ọ bụ ihe na-egosi ezi akọnuche nʼebe Chineke nọ. Ọ na-azọpụta unu site na mbilite nʼọnwụ nke Jisọs Kraịst,
\v 22 onye nọ nʼeluigwe, nʼaka nri Chineke, ebe ndị mmụọ ozi niile, na ịchị isi niile, na ike niile na-erube isi nye ya.
\c 4
\s1 Iso Kraịst ga-eweta ihe mgbu
\p 
\v 1 Ya mere, ebe ọ bụ na Kraịst hụrụ ahụhụ nʼanụ ahụ, unu onwe unu kwesiri inwe ụdị obi ahụ o nwere. Nʼihi na onye tara ahụhụ nʼanụ ahụ akwụsịla ime mmehie.
\v 2 Nʼihi nke a, onye dị otu ahụ anaghị ebi ndụ fọdụrụ ya nʼụwa nʼihi agụụ ọjọọ nke ọchịchọ mmadụ, kama ọ na-ebi ya nʼihi imezu ọchịchọ Chineke.
\v 3 Nʼoge gara aga unu tufuru ọtụtụ oge ime ihe ndị ahụ na-atọ ndị mba ọzọ ụtọ. Ndụ unu jupụtara nʼagụụ ịkwa iko, na agụụ ime ihe ọjọọ, na ịṅụbiga mmanya oke, na ịkpọ oriri, na ikpere arụsị niile, bụ ihe jọgburu onwe ya na njọ.
\v 4 Ma ndụ unu na-ebi ugbu a na-eju ha anya ebe ọ bụ na unu anaghị esokwa ha ebi ndụ ọjọọ ndị ahụ ọzọ, nʼihi nke a ha na-ekwutọkwa unu.
\v 5 Ma ha ga-eji ọnụ ha kwupụta ihe ha mere nʼihu onye ahụ ga-ekpe ndị dị ndụ na ndị nwụrụ anwụ ikpe.
\v 6 Ọ bụ nke a mere e ji kwusaa oziọma ọ bụladị nye ndị ahụ nwụrụ anwụ bụ ndị e kperela ikpe mgbe ha dị ndụ, dịka e si ekpe mmadụ niile ikpe, ka ha site na nke a bie ndụ dị ka Chineke si chọọ site na mmụọ ahụ.
\s1 Ọgwụgwụ oge dị nso
\p 
\v 7 Ọgwụgwụ ihe niile adịla nso. Bụrụnụ ndị nwere akọnuche zuruoke, ndị anya doro, ka unu nwee ike na-ekpekwa ekpere.
\v 8 Nke kachasị nke, na-ahụrịtanụ onwe unu nʼanya nke ukwuu nʼihi na ịhụnanya na-ekpuchi ọtụtụ mmehie.
\v 9 Jirinụ obiọma na-elerịta ibe unu ọbịa na-enweghị ntamu ọbụla.
\v 10 Onye ọbụla nʼime unu dịka ndị ozi natara onyinye amara nke Chineke, jirinụ onyinye ọbụla unu natara na-ejeritara onwe unu ozi.
\v 11 Onye na-ekwu okwu ya kwuo ya dị ka ọ bụ nnọọ okwu Chineke ka ọ na-ekwu. Onye na-eje ozi ya jee ya site nʼike ahụ Chineke na-enye. Nʼime ihe niile ka otuto dịrị Chineke site na Jisọs Kraịst. Ọ bụ ya ka otuto niile na ike niile dịrị ruo mgbe niile ebighị ebi. Amen.
\s1 Ịhụ ahụhụ dị ka onye Kraịst
\p 
\v 12 Ụmụnna m, ka ọ hapụ iju unu anya mgbe ọnwụnwa dị iche iche na-abịara unu nʼihi na ihe dị otu a abụghị ihe ọhụrụ nʼebe unu nọ.
\v 13 Kama ṅụrịanụ ọṅụ nʼihi na unu so Kraịst na-eketa oke nʼahụhụ ya, ka e sikwa otu a mee ka obi unu jupụta nʼọṅụ, unu ga-etikwa mkpu ọṅụ mgbe a ga-eme ka ebube ya pụta ìhè.
\v 14 Ọ bụrụ na a na-ekwutọ unu nʼihi aha Kraịst, unu bụ ndị a gọziri agọzi. Nke a na-ezipụta na mmụọ nke ebube ahụ bụ mmụọ Chineke na-ebi nʼime unu.
\v 15 Ka onye ọbụla nʼime unu ghara ịta ahụhụ nʼihi na o gburu mmadụ maọbụ dị ka onye ohi, maọbụ dị ka onye na-eme ihe ọjọọ, maọbụ dị ka onye na-anara mmadụ ihe nʼaka ike.
\v 16 Ma ihere ekwesighị ime unu mgbe unu na-ata ahụhụ dị ka ndị Kraịst. Kama nyenụ Chineke otuto na unu bụ ndị a na-akpọ aha ahụ.
\v 17 Nʼihi na oge eruola, mgbe a ga-amalite ikpe nʼezinaụlọ Chineke. Ọ bụrụ na a ga-ebu ụzọ kpee anyị ikpe, gịnị ga-abụkwanụ ọnọdụ ndị ahụ na-ekwenyeghị nʼoziọma Chineke?
\v 18 Ma,
\q1 “Ọ bụrụkwa na ọ dị ike ịzọpụta onye ezi omume,
\q2 oleekwanụ olileanya dịrị onye na-amaghị Chineke na onye mmehie?”\f + \fr 4:18 \ft \xt Ilu 11:31\xt*\f*
\p 
\v 19 Ya mere, ndị na-ata ahụhụ dị ka nzube Chineke si dị, nyefeenụ onwe unu nʼaka onye okike, onye kwesiri ntụkwasị obi, ma nọgidenụ na-eme ezi ihe.
\c 5
\s1 Ndụmọdụ dị iche iche
\p 
\v 1 Mụ onwe m, onye bụ okenye na onyeama banyere ahụhụ Kraịst, bụrụkwa onye ga-eso keta oke nʼebube ya nke a gaje ikpughe, a na m arịọ ndị okenye nʼetiti unu arịrịọ a,
\v 2 na-azụnụ igwe atụrụ ahụ Chineke nyefere unu nʼaka. Ka unu na-elekọta ha, ọ bụghị nʼihi na unu agaghị ime otu a, kama ọ bụ ihe sitere nʼọchịchọ obi unu, dị ka Chineke chọrọ ka unu mee. Ọ bụkwaghị nʼihi ego unu ga-enweta, kama ọ bụ ịnụ ọkụ unu nʼije ozi.
\v 3 Unu abụla ọkaaka nʼebe ndị e nyefere unu nʼaka nọ. Kama bụrụnụ ihe ịma atụ nye igwe atụrụ ahụ.
\v 4 Ma mgbe Onyeisi ndị ọzụzụ atụrụ ahụ ga-abịa unu ga-anata okpueze ebube nke na-agaghị agbanwe agbanwe.
\p 
\v 5 Nʼotu aka ahụ, unu ụmụ okorobịa, doonụ onwe unu nʼokpuru ndị bụ okenye. Unu niile werenụ obi umeala na-ejeritara onwe unu ozi, nʼihi na,
\q1 “Chineke na-eguzo imegide ndị na-ebuli onwe ha elu,
\q2 ma ọ na-enye ndị dị umeala nʼobi amara.”\f + \fr 5:5 \ft \xt Ilu 3:34\xt*\f*
\m 
\v 6 Ya mere, wedanụ onwe unu nʼokpuru aka dị ike nke Chineke, ka o bulie unu elu nʼoge ya.
\v 7 Hapụrụnụ ya nsogbu unu na nchegbu unu, nʼihi na ihe banyere unu na-emetụ ya nʼobi.
\p 
\v 8 Nọọnụ na njikere, na-echekwanụ nche nʼihi na onye iro unu bụ ekwensu ji oke ịgbọ ụja na-awagharị dịka ọdụm, na-achọ onye ọ ga-ala nʼiyi.
\v 9 Guzosienụ ike nʼokwukwe unu. Unu ekwela ka o merie unu, kama tụkwasịnụ Onyenwe anyị obi. Chetanụ na e nwere ọtụtụ ndị kwere ekwe dị ka unu ndị nọkwa nʼụdị ahụhụ a unu na-ahụ nʼụwa niile.
\p 
\v 10 Chineke onye nwe amara niile, onye kpọbatara unu na ebube ebighị ebi ya nʼime Kraịst, mgbe unu hụrụ ahụhụ ndị a nwa oge, ya onwe ya ga-eweghachi unu nʼọnọdụ unu, mee ka unu dị nnọọ ike, ndị guzo chịm ma kwesikwa ntụkwasị obi.
\v 11 Ọ bụ ya nwe ike niile ruo mgbe niile ebighị ebi. Amen.
\b
\s1 Ekele ikpeazụ
\p 
\v 12 Ọ bụ site nʼinyeaka Saịlas onye m hụtara dị ka nwanna kwesiri ntụkwasị obi ka m ji deere unu mkpụrụ okwu ole na ole ndị a nke m ji agbaa unu ume na-ekwupụtakwa na nke a bụ eziokwu dị nʼamara Chineke. Guzosienụ ike nʼime ya.
\b
\p 
\v 13 Nwanyị ahụ nọ na Babilọn, nke a họpụtara unu na ya, na-ekele unu. Mak, ezi nwa m nwoke na-ekelekwa unu.
\p 
\v 14 Jirinụ isurita ọnụ ịhụnanya kelerịta onwe unu.
\b
\p Ka udo dịnyere unu niile nọ nʼime Kraịst.
