\v 9 \w D|strong="G2532"\w*’\w ailleurs|strong="G1534"\w*, \w puisque|strong="G3303"\w* \w nos|strong="G2532"\w* \w pères|strong="G3962"\w* \w selon|strong="G2532"\w* \w la|strong="G2532"\w* \w chair|strong="G4561"\w* \w nous|strong="G2249"\w* \w ont|strong="G3588"\w* \w châtiés|strong="G3810"\w* \w et|strong="G2532"\w* \w que|strong="G2532"\w* \w nous|strong="G2249"\w* \w les|strong="G2532"\w* \w avons|strong="G2192"\w* \w respectés|strong="G1788"\w*, combien \w plus|strong="G2532"\w* \w nous|strong="G2249"\w* devons \w nous|strong="G2249"\w* \w soumettre|strong="G5293"\w* \w au|strong="G2532"\w* \w Père|strong="G3962"\w* \w des|strong="G2532"\w* \w esprits|strong="G4151"\w*, \w pour|strong="G2532"\w* \w avoir|strong="G2532"\w* \w la|strong="G2532"\w* \w vie|strong="G2198"\w* ?
