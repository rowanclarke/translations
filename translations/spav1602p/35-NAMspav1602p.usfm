\c 1
\m
\v 1 \w CARGA|strong="H4853"\w* de \w Nínive|strong="H5210"\w*. \w Libro|strong="H5612"\w* de la \w visión|strong="H2377"\w* de Nahum, el elcosita.   
\m
\v 2 \w Dios|strong="H3068"\w* \w celoso|strong="H7072"\w* y \w vengador|strong="H5358"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w SEÑOR|strong="H3068"\w*; \w vengador|strong="H5358"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w SEÑOR|strong="H3068"\w*, y \w SEÑOR|strong="H3068"\w* de \w ira|strong="H2534"\w*; \w el|strong="H1931"\w* \w SEÑOR|strong="H3068"\w*, \w que|strong="H1931"\w* \w se|strong="H1931"\w* venga de \w sus|strong="H1931"\w* \w adversarios|strong="H6862"\w*, y \w que|strong="H1931"\w* \w guarda|strong="H5201"\w* \add enojo\add* para \w sus|strong="H1931"\w* \w enemigos|strong="H6862"\w*.   
\m
\v 3 El \w SEÑOR|strong="H3068"\w* es tardo para la ira, y \w grande|strong="H1419"\w* en \w poder|strong="H3581"\w*, y \w no|strong="H3808"\w* \w tendrá|strong="H5352"\w* \add al culpado\add* \w por|strong="H1870"\w* inocente. El \w SEÑOR|strong="H3068"\w* \w marcha|strong="H1870"\w* \w entre|strong="H3808"\w* la tempes­tad y turbión, y las \w nubes|strong="H6051"\w* \w son|strong="H3808"\w* el polvo de sus \w pies|strong="H7272"\w*.   
\m
\v 4 \w Él|strong="H3605"\w* reprende al \w mar|strong="H3220"\w*, y \w lo|strong="H3605"\w* hace secar, y agosta \w todos|strong="H3605"\w* \w los|strong="H3605"\w* ríos: \w Basán|strong="H1316"\w* desfallece, y \w el|strong="H3605"\w* Carmelo, y \w la|strong="H3605"\w* \w flor|strong="H6525"\w* del \w Líbano|strong="H3844"\w* desfallece.   
\m
\v 5 \w Los|strong="H3427"\w* \w montes|strong="H2022"\w* \w tiemblan|strong="H7493"\w* \w de|strong="H4480"\w* \w él|strong="H3605"\w*, y \w los|strong="H3427"\w* \w collados|strong="H1389"\w* \w se|strong="H4480"\w* deslíen; y \w la|strong="H3605"\w* tierra \w se|strong="H4480"\w* abrasa \w a|strong="H3068"\w* su \w presencia|strong="H6440"\w*, y \w el|strong="H3605"\w* \w mundo|strong="H8398"\w*, y \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w que|strong="H4480"\w* \w en|strong="H4480"\w* \w él|strong="H3605"\w* \w habitan|strong="H3427"\w*.   
\m
\v 6 ¿\w Quién|strong="H4310"\w* \w permanecerá|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* su \w ira|strong="H2534"\w*? ¿y \w quién|strong="H4310"\w* \w quedará|strong="H6965"\w* \w en|strong="H4480"\w* \w pié|strong="H5975"\w* \w en|strong="H4480"\w* \w el|strong="H4310"\w* \w furor|strong="H2740"\w* \w de|strong="H4480"\w* su \w enojo|strong="H2534"\w*? Su \w ira|strong="H2534"\w* \w se|strong="H4480"\w* derrama como fuego, y \w por|strong="H4480"\w* \w él|strong="H4310"\w* \w se|strong="H4480"\w* hienden las peñas.   
\m
\v 7 \w Bueno|strong="H2896"\w* es el \w SEÑOR|strong="H3068"\w* para \w fortaleza|strong="H4581"\w* en el \w día|strong="H3117"\w* de la \w angustia|strong="H6869"\w*; y \w conoce|strong="H3045"\w* \w a|strong="H3068"\w* los \w que|strong="H3045"\w* en él confían.   
\m
\v 8 Mas con inundación \w impetuosa|strong="H5674"\w* \w hará|strong="H6213"\w* \w consumación|strong="H3617"\w* de su \w lugar|strong="H4725"\w*, y \w tinieblas|strong="H2822"\w* \w perseguirán|strong="H7291"\w* \w a|strong="H3068"\w* sus ene­migos.   
\m
\v 9 ¿\w Qué|strong="H4100"\w* imagináis contra \w el|strong="H1931"\w* \w SEÑOR|strong="H3068"\w*? \w Él|strong="H1931"\w* \w hará|strong="H6213"\w* \w consumación|strong="H3617"\w*: \w la|strong="H1931"\w* \w tribulación|strong="H6869"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* \w levantará|strong="H6965"\w* \w dos|strong="H6471"\w* \w veces|strong="H6471"\w*.   
\m
\v 10 \w Porque|strong="H3588"\w* \w como|strong="H3588"\w* \w espinas|strong="H5518"\w* entrete­jidas, \w mientras|strong="H5704"\w* se embriagarán \w los|strong="H3588"\w* borrachos, serán consumidos \w como|strong="H3588"\w* las estopas \w llenas|strong="H4390"\w* \w de|strong="H3588"\w* sequedad.   
\m
\v 11 \w De|strong="H4480"\w* \w ti|strong="H5921"\w* \w salió|strong="H3318"\w* \w el|strong="H5921"\w* \w que|strong="H4480"\w* imagina \w mal|strong="H7451"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*, un \w consejero|strong="H3289"\w* \w impío|strong="H1100"\w*.   
\m
\v 12 \w Así|strong="H3541"\w* \w ha|strong="H3541"\w* dicho \w el|strong="H5674"\w* \w SEÑOR|strong="H3068"\w*: \w Aunque|strong="H3808"\w* \w reposo|strong="H8003"\w* tengan, \w y|strong="H3541"\w* sean tantos, \w así|strong="H3541"\w* serán talados, \w y|strong="H3541"\w* \w él|strong="H5674"\w* \w pasará|strong="H5674"\w*. \w Bien|strong="H3651"\w* \w que|strong="H3808"\w* te he \w afligido|strong="H6031"\w*, \w no|strong="H3808"\w* \w más|strong="H5750"\w* te afligiré.   
\m
\v 13 \w Porque|strong="H5921"\w* \w ahora|strong="H6258"\w* \w quebraré|strong="H7665"\w* su \w yugo|strong="H5921"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* romperé tus bandas.   
\m
\v 14 \w Mas|strong="H5750"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w mandará|strong="H6680"\w* \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*, \w que|strong="H3588"\w* \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* sea \w sembrado|strong="H2232"\w* \w alguno|strong="H5750"\w* \w de|strong="H5921"\w* tu \w nombre|strong="H8034"\w*: \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* tu \w dios|strong="H3068"\w* \w talaré|strong="H3772"\w* escul­tura \w y|strong="H3588"\w* estatua \w de|strong="H5921"\w* \w fundición|strong="H4541"\w*, \w haré|strong="H7760"\w*­\w la|strong="H5921"\w* tu \w sepulcro|strong="H6913"\w*; \w porque|strong="H3588"\w* fuiste vil.   
\m
\v 15 He aquí sobre los montes los pies del que trae buenas nuevas, del que pregona la paz. Celebra, oh Judá, tus fiestas, cumple tus votos: porque nunca más pasará por ti el impío; pereció del todo.   
\c 2
\m
\v 1 SUBIÓ destruidor \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*: guarda \w la|strong="H5921"\w* fortaleza, \w mira|strong="H2009"\w* \w el|strong="H5921"\w* camino, fortifica \w los|strong="H5921"\w* lomos, fortalece mucho \w la|strong="H5921"\w* fuerza.   
\m
\v 2 \w Porque|strong="H5921"\w* \w el|strong="H5921"\w* SEÑOR restituirá \w la|strong="H5921"\w* gloria \w de|strong="H5921"\w* Jacob \w como|strong="H5921"\w* \w la|strong="H5921"\w* gloria \w de|strong="H5921"\w* Israel; \w porque|strong="H5921"\w* vaciadores \w los|strong="H5921"\w* vaciaron, \w y|strong="H5921"\w* estropearon sus mugrones.   
\m
\v 3 \w El|strong="H3588"\w* escudo \w de|strong="H3588"\w* sus valientes será bermejo, \w los|strong="H3588"\w* \w varones|strong="H3588"\w* \w de|strong="H3588"\w* \add su\add* ejér­cito vestidos \w de|strong="H3588"\w* grana: \w el|strong="H3588"\w* carro \w como|strong="H3588"\w* fuego \w de|strong="H3588"\w* hachas; \w el|strong="H3588"\w* día \w que|strong="H3588"\w* se aparejará, temblarán las hayas.   
\m
\v 4 Los \w carros|strong="H7393"\w* se precipitarán \w a|strong="H3068"\w* las plazas, discurrirán por las calles: su aspecto como hachas encendi­das; correrán como relámpagos.   
\m
\v 5 Acordaráse él de sus valientes; andando tropezarán; se apresura­rán \w a|strong="H3068"\w* su muro, y la cubierta se aparejará.   
\m
\v 6 Las puertas de los ríos se abri­rán, y el palacio será destruido.   
\m
\v 7 \w Y|strong="H3068"\w* la reina fue cautiva; mandar­le han que suba, y sus criadas la llevarán gimiendo como palo­mas, batiendo sus pechos.   
\m
\v 8 \w Y|strong="H3068"\w* \w fue|strong="H1540"\w* Nínive \w de|strong="H5921"\w* tiempo antiguo \w como|strong="H5921"\w* estanque \w de|strong="H5921"\w* aguas; \w mas|strong="H5921"\w* \w ellos|strong="H5921"\w* huyen: Parad, parad; \w y|strong="H5921"\w* nin­guno mira.   
\m
\v 9 Saquead plata, saquead oro: no hay fin \w de|strong="H4325"\w* \w las|strong="H1992"\w* riquezas \add y\add* suntuo­sidad \w de|strong="H4325"\w* todo ajuar \w de|strong="H4325"\w* codicia.   
\m
\v 10 Vacía, \w y|strong="H3519"\w* agotada, \w y|strong="H3519"\w* despeda­zada está, \w y|strong="H3519"\w* \w el|strong="H3605"\w* corazón derretido: batimiento de rodillas, \w y|strong="H3519"\w* dolor en \w todos|strong="H3605"\w* riñones, \w y|strong="H3519"\w* \w los|strong="H3605"\w* rostros de \w todos|strong="H3605"\w* tomarán negrura.   
\m
\v 11 ¿\w Qué|strong="H3605"\w* es \w de|strong="H6440"\w* \w la|strong="H3605"\w* morada \w de|strong="H6440"\w* \w los|strong="H3605"\w* leones, y \w de|strong="H6440"\w* \w la|strong="H3605"\w* majada \w de|strong="H6440"\w* \w los|strong="H3605"\w* cachorros \w de|strong="H6440"\w* \w los|strong="H3605"\w* leones, donde se recogía \w el|strong="H3605"\w* león, y \w la|strong="H3605"\w* leona, y \w los|strong="H3605"\w* cachorros del león, y \w no|strong="H6440"\w* había \w quien|strong="H3605"\w* les pusiese \w miedo|strong="H2479"\w*?   
\m
\v 12 \w El|strong="H1931"\w* león arrebataba en abun­dancia para \w sus|strong="H1931"\w* cachorros, y aho­gaba para \w sus|strong="H1931"\w* leonas, y henchía de presa \w sus|strong="H1931"\w* cavernas, y de robo \w sus|strong="H1931"\w* moradas.   
\m
\v 13 Heme aquí contra ti, dice el SEÑOR de los ejércitos. Encenderé y \add reduciré\add* \w a|strong="H3068"\w* humo \add tus\add* carros, y espada devorará tus leoncillos; y raeré de la tierra tu robo, y nunca más se oirá voz de tus embajadores.   
\c 3
\m
\v 1 ¡\w AY|strong="H1945"\w* \w de|strong="H1818"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w de|strong="H1818"\w* \w sangres|strong="H1818"\w*, \w toda|strong="H3605"\w* llena \w de|strong="H1818"\w* \w mentira|strong="H3585"\w* y \w de|strong="H1818"\w* rapiña, \w sin|strong="H3808"\w* \w apartarse|strong="H3808"\w* \add de ella\add* \w el|strong="H3605"\w* pillaje!   
\m
\v 2 \w Sonido|strong="H6963"\w* de látigo, y \w estruendo|strong="H6963"\w* de movimiento de ruedas; y \w caballo|strong="H5483"\w* \w atropellador|strong="H1725"\w*, y \w carro|strong="H4818"\w* sal­tador;   
\m
\v 3 \w Caballero|strong="H6571"\w* \w enhiesto|strong="H5927"\w*, y resplan­dor de \w espada|strong="H2719"\w*, y resplandor de \w lanza|strong="H2595"\w*; y \w multitud|strong="H7230"\w* de \w muertos|strong="H2491"\w*, y \w multitud|strong="H7230"\w* de cadáveres; y de sus cadáveres no habrá fin, y en sus cadáveres \w tropezarán|strong="H3782"\w*:   
\m
\v 4 \w A|strong="H3068"\w* causa de la \w multitud|strong="H7230"\w* de las \w fornicaciones|strong="H2183"\w* de la \w ramera|strong="H2181"\w* de \w hermosa|strong="H2896"\w* \w gala|strong="H2580"\w*, \w maestra|strong="H1172"\w* de brujerías, que \w vende|strong="H4376"\w* las \w naciones|strong="H1471"\w* con sus \w fornicaciones|strong="H2183"\w*, y los \w pueblos|strong="H1471"\w* con sus hechizos.   
\m
\v 5 Heme \w aquí|strong="H2005"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*, \w dice|strong="H5002"\w* \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w ejércitos|strong="H6635"\w*, \w y|strong="H5921"\w* des­cubriré tus faldas \w en|strong="H5921"\w* tu \w cara|strong="H6440"\w*, \w y|strong="H5921"\w* \w mostraré|strong="H7200"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* tu desnu­dez, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* tu vergüenza.   
\m
\v 6 \w Y|strong="H3068"\w* \w echaré|strong="H7993"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* suciedades, \w y|strong="H5921"\w* \w te|strong="H5921"\w* afrentaré, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w pondré|strong="H7760"\w* \w como|strong="H5921"\w* estiércol.   
\m
\v 7 \w Y|strong="H3068"\w* \w será|strong="H1961"\w* \w que|strong="H4480"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H4480"\w* \w te|strong="H4480"\w* vie­ren, \w se|strong="H1961"\w* apartarán \w de|strong="H4480"\w* \w ti|strong="H4480"\w*, y dirán: \w Nínive|strong="H5210"\w* \w es|strong="H1961"\w* asolada: ¿\w quién|strong="H4310"\w* \w se|strong="H1961"\w* compadecerá \w de|strong="H4480"\w* \w ella|strong="H4480"\w*? ¿dónde \w te|strong="H4480"\w* \w buscaré|strong="H1245"\w* \w consoladores|strong="H5162"\w*?   
\m
\v 8 ¿Eres tú mejor \w que|strong="H4325"\w* No la populosa, \w que|strong="H4325"\w* \w estaba|strong="H3427"\w* asentada entre \w ríos|strong="H2975"\w*, \w cercada|strong="H2346"\w* \w de|strong="H4325"\w* \w aguas|strong="H4325"\w*, cuyo \w baluarte|strong="H2426"\w* era \w el|strong="H2975"\w* \w mar|strong="H3220"\w*, \add y\add* del \w mar|strong="H3220"\w* su muralla?   
\m
\v 9 \w Etiopía|strong="H3568"\w* \w era|strong="H1961"\w* su fortaleza, y \w Egipto|strong="H4714"\w* \add lo era\add* sin \w límite|strong="H7097"\w*; \w Put|strong="H6316"\w* y Libia \w fueron|strong="H1961"\w* en tu \w ayuda|strong="H5833"\w*.   
\m
\v 10 \w También|strong="H1571"\w* \w ella|strong="H1931"\w* \w fue|strong="H1980"\w* \w llevada|strong="H1980"\w* \w en|strong="H5921"\w* \w cautiverio|strong="H1473"\w*: \w también|strong="H1571"\w* \w sus|strong="H1931"\w* \w chiquitos|strong="H5768"\w* \w fueron|strong="H1980"\w* estrellados \w en|strong="H5921"\w* \w las|strong="H5921"\w* encruci­jadas \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w calles|strong="H2351"\w*; \w y|strong="H1571"\w* \w sobre|strong="H5921"\w* \w sus|strong="H1931"\w* \w varones|strong="H3513"\w* \w echaron|strong="H3032"\w* \w suertes|strong="H1486"\w*, \w y|strong="H1571"\w* \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* \w magnates|strong="H1419"\w* \w fueron|strong="H1980"\w* apri­sionados \w con|strong="H5921"\w* grillos.   
\m
\v 11 Tú \w también|strong="H1571"\w* \w serás|strong="H1961"\w* embriagada, \w serás|strong="H1961"\w* \w encerrada|strong="H5956"\w*; tú \w también|strong="H1571"\w* bus­carás \w fortaleza|strong="H4581"\w* \w a|strong="H3068"\w* causa del ene­migo.   
\m
\v 12 \w Todas|strong="H3605"\w* tus fortalezas \w cual|strong="H5973"\w* \w higueras|strong="H8384"\w* \w con|strong="H5973"\w* \w brevas|strong="H1061"\w*; \w que|strong="H5921"\w* \w si|strong="H5921"\w* \w las|strong="H5921"\w* sacuden, \w caen|strong="H5307"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w del|strong="H5921"\w* \w que|strong="H5921"\w* \w las|strong="H5921"\w* ha \w de|strong="H5921"\w* comer.   
\m
\v 13 He \w aquí|strong="H2009"\w*, tu \w pueblo|strong="H5971"\w* será como mujeres en \w medio|strong="H7130"\w* \w de|strong="H5971"\w* ti: las puer­tas \w de|strong="H5971"\w* tu tierra \w se|strong="H5971"\w* abrirán \w de|strong="H5971"\w* par en par \w a|strong="H3068"\w* tus enemigos: fuego consumirá tus \w barras|strong="H1280"\w*.   
\m
\v 14 \w Provéete|strong="H7579"\w* \w de|strong="H4325"\w* \w agua|strong="H4325"\w* para el cerco, \w fortifica|strong="H2388"\w* tus fortalezas; entra en el lodo, \w pisa|strong="H7429"\w* el \w barro|strong="H2563"\w*, \w fortifica|strong="H2388"\w* el horno.   
\m
\v 15 \w Allí|strong="H8033"\w* te consumirá el fuego, te \w talará|strong="H3772"\w* la \w espada|strong="H2719"\w*, te devorará como pulgón: \w multiplícate|strong="H3513"\w* como langosta, \w multiplícate|strong="H3513"\w* como lan­gosta.   
\m
\v 16 \w Multiplicaste|strong="H7235"\w* tus mercaderes \w más|strong="H7235"\w* que las \w estrellas|strong="H3556"\w* del \w cielo|strong="H8064"\w*: el pulgón hizo presa, y voló.   
\m
\v 17 Tus príncipes serán como lan­gostas, y tus grandes como lan­gostas de langostas \w que|strong="H3808"\w* \w se|strong="H3045"\w* sien­tan en vallados en \w día|strong="H3117"\w* de frío: \w salido|strong="H2224"\w* el \w sol|strong="H8121"\w* \w se|strong="H3045"\w* mudan, y \w no|strong="H3808"\w* \w se|strong="H3045"\w* \w conoce|strong="H3045"\w* el \w lugar|strong="H4725"\w* \w donde|strong="H4725"\w* estuvie­ron.   
\m
\v 18 \w Durmieron|strong="H5123"\w* tus \w pastores|strong="H7462"\w*, oh \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, \w reposaron|strong="H7931"\w* tus valientes: tu \w pueblo|strong="H5971"\w* \w se|strong="H5921"\w* derramó \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*, \w y|strong="H5921"\w* \w no|strong="H5921"\w* hay quien \w lo|strong="H5921"\w* junte.   
\m
\v 19 \w No|strong="H3808"\w* \w hay|strong="H4310"\w* cura \w para|strong="H5921"\w* tu quebra­dura; tu herida \w se|strong="H5921"\w* encrudeció: \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w oyeron|strong="H8085"\w* tu fama, \w batirán|strong="H8628"\w* \w las|strong="H5921"\w* \w manos|strong="H3709"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w por|strong="H5921"\w*­\w que|strong="H3588"\w* ¿\w sobre|strong="H5921"\w* \w quién|strong="H4310"\w* \w no|strong="H3808"\w* \w pasó|strong="H5674"\w* conti­nuamente tu malicia?   