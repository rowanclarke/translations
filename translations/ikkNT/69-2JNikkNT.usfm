\id 2JN Ika New Testament 2009
\h 2 Jọnụ
\toc1 Ẹhụhụọ-Ozi Nke Ẹbụọ Jọnụ De
\toc2 Jọnụ, Nke Ẹbụọ
\toc3 2Jn
\mt2 Ẹhụhụọ-Ozi Nke Ẹbụọ
\mt2 Jọnụ
\mt2 De
\mt1 Jọnụ, Nke Ẹbụọ
\c 1
\s1 Ekele
\p 
\v 1 Mmẹ wụ onyẹ-isi de ẹhụhụọ-ozini. M rị e dejẹnni okpoho hụ Osolobuẹ họrị lẹ ụmụ a. Ndị m nwẹ ihiẹn-ọsụsụọ wẹ ebe Ezioku rị kẹ wẹ wụ. Ẹlẹdẹ mmẹ sụọ nwẹ ihiẹn-ọsụsụọ wẹ, kama, ndị ile marịn Ezioku nwẹzịkwọ ihiẹn-ọsụsụọ wẹ.
\v 2 Ẹnyi nwẹ ihiẹn-ọsụsụọ wẹ makẹ Ezioku ahụn rị imẹ ndụn ẹnyi—hụn k'a rịsọnmẹkwọ imẹ ndụn ẹnyi jẹnrin ejẹn.
\p 
\v 3 Ẹfọma lẹ omikẹn lẹ udọn, hụn gha ẹka Chuku-Nẹdi lẹ Nwa a wụ Jizọs' Kraịst' a bịa, ya rịsọnmẹ ni ẹnyi, kẹ ẹnyi dọn rị e bisọnmẹ imẹ ezioku lẹ ihiẹn-ọsụsụọ.
\s1 Ezioku Lẹ Ihiẹn-ọsụsụọ
\p 
\v 4 Ẹfọ a sụọkẹnmẹkẹ m ụsụọ ogẹn m gi hụn a nị o nwẹghọ ụmụ ị ndị rị e bi imẹ Ezioku nọkẹ kẹ Nẹdi ẹnyi dọn gwa ẹnyi.
\p 
\v 5 M rị nwan a rịọ ị, ezi okpoho, nị ẹnyi ile e nwẹ ihiẹn-ọsụsụọ ibe ẹnyi. Ẹlẹ ni m rị e de n'i iwu ọhụn, kama, iwu ohu ahụn o ye ẹnyi gha anị lala kẹ m rị e de n'i.
\v 6 Ihiẹn-ọsụsụọ wụ nị ẹnyi rị e mẹsọnmẹ ihiẹn ọ sị ẹnyi e mẹ; ịya wụ iwu hụ—nọkẹ kẹ ụnụ dọn nụ a gha alị lala—ọnụ k'e girịrị a e bi.
\s1 Eṅẹnrẹn-Kraịstị Ahụn W'a Kpọ Anti-Kraịstị
\p 
\v 7 Ndị-ndufie bu ọda a bangụọ imẹ ụwa. Ndịnị ara kweri nị Jesu Kristi gi ẹhụ ịhịan bịa—n'ọ wụchanrịn ịhịan k'ọ bịa. Onyẹ ọwụlẹ nọ ẹnịna, ịya wụ onyẹ-ndufie hụ lẹ Eṅẹnrẹn-Kraịstị hụ wụ anti-Kraịstị!
\p 
\v 8 Kpachanfụ nị nwan ẹnya, amamgbe ọnụ e tuhu ihiẹn ẹnyi rụngụụ, ka turusọnmẹ ni kẹni ẹnyi nwọnhẹn ụgwọ ọrụn zu oke.
\p 
\v 9 Onyẹ ọwụlẹ hụn sọnsọnmẹlẹni nkuzi Kraịstị, kanị o fe mgbọn—onyẹ hụ e nwọn Osolobuẹ. Onyẹ hụn sọnsọnmẹ nkuzi hụ k'ọ rị e nwọnghọ kẹ Chuku-Nẹdi kẹ Nwa.
\v 10 Onyẹ bịa iwe i d'a kuzi, bụ ẹlẹ hụn Kraịstị kuzi k'o gi bịa, anabanhal'a mọbụ kele ẹ ọhụnma.
\v 11 Makẹni, onyẹ hụn kele ẹ ọhụnma rị e sọn ẹ a rụn eje-ọrụn ọ rị a rụn.
\s1 Oku Mmẹkin
\p 
\v 12 M nwọn ihiẹn bu ọda hụn nkẹ m'e deni ọnụ, kanị ẹlẹ hụn m k'e de ede. M rị a tụ ẹnya nị m k'a bịa d'a hụndẹ ụnụ, ẹnyi e kutarị, elee-m, elee-i, kẹni ịghọghọ ẹnyi ile hụn ụzọ zu oke.
\p 
\v 13 Ụmụ nwẹnẹ-i-okpoho-\it Osolobuẹ\it*-họrị e zi ekele ụnụ.
