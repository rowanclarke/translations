\p
\v 12 \w Balaam|strong="H1109"\w* \w respondió|strong="H1109"\w* \w a|strong="H3068"\w* \w Balac|strong="H1111"\w*: ¿\w No|strong="H3808"\w* \w hablé|strong="H1696"\w* yo \w a|strong="H3068"\w* los \w mensajeros|strong="H4397"\w* \w que|strong="H3808"\w* me \w enviaste|strong="H7971"\w*:  
\v 13 \w Aunque|strong="H3808"\w* \w Balac|strong="H1111"\w* me \w diera|strong="H5414"\w* su \w casa|strong="H1004"\w* \w llena|strong="H4393"\w* \w de|strong="H5414"\w* \w plata|strong="H3701"\w* y \w oro|strong="H2091"\w*, \w no|strong="H3808"\w* podría \w traspasar|strong="H5674"\w* la \w Palabra|strong="H1696"\w* \w de|strong="H5414"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w haciendo|strong="H6213"\w* \w por|strong="H5414"\w* mi propio impulso \w cosa|strong="H1696"\w* \w buena|strong="H2896"\w* \w ni|strong="H3808"\w* \w mala|strong="H7451"\w*? \w Lo|strong="H3808"\w* \w que|strong="H3808"\w* \w diga|strong="H1696"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* eso \w diré|strong="H1696"\w*.  
