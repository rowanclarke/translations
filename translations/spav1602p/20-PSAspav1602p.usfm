\v 27 \w Y|strong="H3068"\w* \w entiendan|strong="H3045"\w* \w que|strong="H3588"\w* \w ésta|strong="H2063"\w* \w es|strong="H3027"\w* \w tu|strong="H6213"\w* \w mano|strong="H3027"\w*; \add que\add* \w tú|strong="H6213"\w*, \w SEÑOR|strong="H3068"\w*, has \w hecho|strong="H6213"\w* \w esto|strong="H2063"\w*.
