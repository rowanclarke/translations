\id 1CH
\h 1 Imezruyen
\toc1 1 Imezruyen
\toc2 1 Imezruyen
\toc3 1 Im.
\mt1 1 Imezruyen
\c 1
\s1 Jjiřat n Adam ař Ibrahim d Isḥaq d Yaɛqub
\m 
\v 1 \bd Adam\bd*, Cit, Anuc, \x ◘ \xo 1:1 \xt [Amz. 5:1-32; 10:1-32; 11:10-26; 25:1-6]\x*
\v 2 Qinan, Mahalal-Il, Yarad,
\v 3 Ḥanux, Matucalaḥ, Lamak,
\m 
\v 4 \bd Nuḥ\bd*, Cam, Ḥam, Yafat.
\b
\m 
\v 5 \bd Arrawen n Yafat\bd* \add tuɣa aten d\add* Jumar, Majuj, Maday, Yawan, Tubal, Macik d Tiras. \f ◼ \fr 1:5 \fk Majuj\ft - niɣ ‘Maxux’, niɣ ‘Magug’.\f*
\m 
\v 6 Arrawen n Jumar \add tuɣa aten d\add* Ackanaz, Difat d Tujarma. \f ◼ \fr 1:6 \fk Difat\ft - deg wedlis Amz. 10:3 nufa ‘Rifat’.\f*
\m 
\v 7 Arrawen n Yawan \add tuɣa aten d\add* Ilica, Tarcica, Ikittiyyen d Idudaniyyen. \f ◼ \fr 1:7 \fk Tarcica\ft - deg wedlis Amz. 10:4 nufa ‘Tarcic’.\f*
\b
\m 
\v 8 \bd Arrawen n Ḥam\bd* \add tuɣa aten d\add* Kuc, Miṣrayim, Fuṭ d Kenɛan.
\m 
\v 9 Arrawen n Kuc \add tuɣa aten d\add* Seba, Ḥawila, Sabta, Raɛama d Sabtaka.
\m Arrawen n Raɛama \add tuɣa aten d\add* Caba d Dadan.
\m 
\v 10 Kuc ijja-dd Nimrud. Wanita ibda ad yiři d ijj n jjiheř x temmurt.
\m 
\v 11 Miṣrayim ijja-dd Iludiyyen, Iɛanamiyyen, Ilahabiyyen, Inaftuḥiyyen,
\m 
\v 12 Ifatrusiyyen, Ikasluḥiyyen, inni zi i dd-iqqarṣen Ifilisṭiniyyen, uřa d Ikafturiyyen.
\m 
\v 13 Kenɛan ijja-dd Ṣidun, amenzu nnes, d Ḥit,
\v 14 Ayabusi, Amuri, Ajirjaci,
\v 15 Aḥiwi, Aɛarqi, Asiniy,
\v 16 Arwadi, Aṣamari d Uḥamati.
\b
\m 
\v 17 \bd Arrawen n Cam\bd* \add tuɣa aten d\add* Ɛilam Accur, Arfakcad, Lud, Aram, Ɛuz, Ḥul, Jatar d Macik.
\m 
\v 18 Arfakcad ijja-dd Calaḥ u Calaḥ ijja-dd Ɛabir.
\m 
\v 19 Ttwarwen-dd i Ɛabir tnayen n warrawen. Ijjen qqaren as Falaj, minzi deg wussan nnes tᵉttwabḍa temmurt, uca qqaren as i umas Yuqṭan.
\m 
\v 20 Yuqṭan ijja-dd Almudad, Calaf, Haḍarmawt, Yaraḥ,
\v 21 Haduram, Uzal, Diqla,
\v 22 Ɛibal, Abimayil, Caba, \f ◼ \fr 1:22 \fk Ɛibal\ft - deg wedlis Amz. 10:28 nufa ‘Ɛubal’.\f*
\v 23 Ufir, Ḥawila d Yubab. Marra ina \add tuɣa aten d\add* arrawen n Yuqṭan.
\b
\m 
\v 24 \bd Cam\bd*, Arfakcad, Calaḥ,
\v 25 Ɛabir, Falaḥ, Raɛuw,
\v 26 Saruj, Naḥur, Taraḥ,
\v 27 Abram, wa d \bd Ibrahim\bd*.
\m 
\v 28 Arrawen n Ibrahim \add tuɣa aten d\add* \bd Isḥaq\bd* d \bd Ismaɛil\bd*.
\b
\m 
\v 29 Ina d inni zzaysen dd-ittwarwen:
\m amenzu \bd n Ismaɛil\bd* \add tuɣa-t d\add* Nabayut, \add xenni\add* Qidar, Adabil, Mibsam, \x ◘ \xo 1:29 \xt Amz. 25:12-18\x*
\v 30 Micmaɛ, Duma, Massa, Ḥadad d Tayma,
\v 31 Yaṭur, Nafic d Qidma. Ina \add tuɣa aten d\add* arrawen n Ismaɛil.
\b
\m 
\v 32 \bd Arrawen n Qaṭura\bd*, tayya n Ibrahim: nettat turuw-dd Zimran, Yuqcan, Madan, Midyan, Yicbaq d Cuḥa. Arrawen n Yuqcan \add tuɣa aten d\add* Caba d Dadan. \x ◘ \xo 1:32 \xt Amz. 25:1-6\x*
\m 
\v 33 Arrawen n Midyan \add tuɣa aten d\add* Ɛiyfa, Ɛifar, Ḥanux, Abidaɛ d Aldaɛa.
\m Nitni marra \add tuɣa aten d\add* arrawen n Qaṭura.
\b
\m 
\v 34 Ibrahim ijja-dd \bd Isḥaq\bd*. Arrawen n Isḥaq \add tuɣa aten d\add* \bd Ɛisu\bd* d \bd Israil\bd*. \x ◘ \xo 1:34 \xt Amz. 25:1-6\x*
\b
\m 
\v 35 \bd Arrawen n Ɛisu\bd* \add tuɣa aten d\add* Ilifaz, Raɛuwil, Yaɛuc, Yaɛlam d Quraḥ.
\m 
\v 36 Arrawen n Ilifaz \add tuɣa aten d\add* Tayman, Umar, Ṣafi, Jaɛtam, Qinaz, Timnaɛ d Ɛamaliq. \f ◼ \fr 1:36 \fk Qinaz\ft - deg wedlis Amz. 36:11 nufa ‘Zifu’. \fk Timnaɛ\ft - isem wanita war t nufa deg wedlis Amezwaru, udem 36. Ad taɣ iceyyar isem wanita ɣar ict n temɣart tenni taru Ɛamaliq i Ilifaz.\f*
\m 
\v 37 Arrawen n Raɛuyil \add tuɣa aten d\add* Naḥat, Zaraḥ, Camma d Mizza.
\m 
\v 38 \bd Arrawen n Saɛir\bd* \add tuɣa aten d\add* Luṭan, Cubal, Ṣibɛun, Ɛana, Dicun, Iṣar d Dican. \x ◘ \xo 1:38 \xt Amz. 36:20-30\x*
\m 
\v 39 Arrawen n Luṭan \add tuɣa aten d\add* Axuri d Humam uca \add tuɣa\add* Timnaɛ d učmas n Luṭan. \f ◼ \fr 1:39 \fk Humam\ft - deg wedlis Amz. 1:39 nufa ‘Haymam’.\f*
\m 
\v 40 Arrawen n Cubal \add tuɣa aten d\add* Ɛalyan, Manaḥat, Ɛibal, Cafi d Unam.
\m Arrawen n Ṣibɛun \add tuɣa aten d\add* Aya d Ɛana.\f ◼ \fr 1:40 \fk Ɛalyan\ft - deg wedlis Amz. 36:23 nufa ‘Ɛalwan’. \fk Cafi\ft - deg wedlis Amz. 36:23 nufa ‘Cafu’. \fk Ṣibɛun\ft - deg wedlis Amz. 36:24 nufa ‘Ṣabɛun’.\f*
\m 
\v 41 Arrawen n Ɛana \add mɣir\add*: Dicun.
\m Arrawen n Dicun \add tuɣa aten d\add* Ḥamran, Icban, Yitran d Karan.
\m 
\v 42 Arrawen n Iṣar \add tuɣa aten d\add* Bilhan d Zaɛwan d Yaɛkan.
\m Arrawen n Dicun \add tuɣa aten d\add* Ɛuṣ d Aran. \f ◼ \fr 1:42 \fk Yaɛkan\ft - deg wedlis Amz. 36:27 nufa ‘Ɛaqan’.\f*
\m 
\v 43 Ina d \bd ijeǧiden i tuɣa iǧan x Idum\bd*, qbeř ma tuɣa iḥekkem ijj n ujeǧid x ayt n Israil:
\m Bilaɛ, mmis n Baɛur. Tandint nnes qqaren as Dinhaba. \x ◘ \xo 1:43 \xt Amz. 36:31-43\x*
\m 
\v 44 Immut Bilaɛ uca Yuwab, mmis n Zaraḥ, zi Buṣra, idweř d ajeǧid deg wemcan nnes.
\m 
\v 45 Immut Yuwab uca Ḥucam zi temmurt n Itaymaniyyen idweř d ajeǧid deg wemcan nnes.
\m 
\v 46 Immut Ḥucam uca Hadad mmis n Badad wenni iɣeřben Midyan deg iyyar n Mu’ab, idweř d ajeǧid deg wemcan nnes. Isem n tendint nnes qqaren as Ɛawit.
\m 
\v 47 Immut Hadad uca Samla zi Masriqa idweř d ajeǧid deg wemcan nnes.
\m 
\v 48 Immut Samla uca Cawul, zi Raḥubut ɣar yeɣzar \add n Lfuraṭ\add*, idweř d ajeǧid deg wemcan nnes.
\m 
\v 49 Immut Cawul uca Baɛl-Ḥanan, mmis n Ɛakbur, idweř d ajeǧid deg wemcan nnes.
\m 
\v 50 Immut Baɛl-Ḥanan uca Hadad idweř d ajeǧid deg wemcan nnes. Tandint nnes qqaren as Faɛi u tamɣart nnes qqaren as Mahiṭab’il, yeǧis n Maṭrid, yeǧis n Ma-Dahab. \f ◼ \fr 1:50 \fk Hadad\ft - deg wedlis Amz. 36:39 nufa ‘Hadar’. \fk Pahi\ft - deg wedlis Amz. 36:39 nufa ‘Pahu’.\f*
\b
\m 
\v 51 Immut Hadad uca \add xenni\add* dewřen \add yina\add* d \bd imɣaren n Idum\bd*:
\m amɣar Timnaɛ, d umɣar Ɛalwa, d umɣar Yatit,
\m 
\v 52 d umɣar Ahulibama, d umɣar Ila, d umɣar Finun,
\m 
\v 53 d umɣar Qanaz, d umɣar Tayman, d umɣar Mibṣar,
\m 
\v 54 d umɣar Majdiyil, d umɣar Ɛiram.
\m Ina \add tuɣa aten d\add* imɣaren n tqebbař n Idum.
\b
\b
\c 2
\s1 Tenɛac n iḥenjiren n Israil
\m 
\v 1 Ina \add tuɣa aten d\add* \bd ayt n Israil\bd*: Rubin, Cimɛun, Lawi d Yahuda, Issakar d Zabulun,
\v 2 Dan, Yusuf d Binyamin, Naftali, Jad d Acir.
\b
\m 
\v 3 \bd Arrawen n Yahuda\bd* \add tuɣa aten d\add* Ɛir d Unan d Cayla. Aqa třata\add -ya\add* ttwarwen as-dd zeg yeǧis n Cuɛa, Takenɛanit. Ɛir, amenzu n Yahuda, tuɣa d aɛeffan di tiṭṭawin n SIDI. S uyenni inɣa i-t.
\m 
\v 4 Tamar, tasřit nnes, turuw as-dd Fariṣ d Zaraḥ. Yahuda \add tuɣa ɣares\add* s marra xemsa n warrawen.
\b
\m 
\v 5 \bd Arrawen n Fariṣ\bd* \add tuɣa aten d\add* Ḥaṣrun d Ḥamul.
\m 
\v 6 Arrawen n Zaraḥ \add tuɣa aten d\add* Zimri, Itan, Hayman, Kalkul d Daraɛ. S marra xemsa.
\m 
\v 7 Arrawen n Karmi \add tuɣa aten d\add* Ɛaxar, wenni iɣeḍřen Israil di řeɣben, minzi igga s řeɣdar ak-d min tuɣa ittwaḥarrmen \add i uteḥḥi\add*.
\m 
\v 8 Arrawen n Itan: \add mɣir\add* Ɛazarya.
\b
\m 
\v 9 \bd Arrawen n Ḥaṣrun\bd* inni d as dd-ittwarwen \add tuɣa aten d\add* Yarḥam’il d Ram d Kalubay.
\b
\m 
\v 10 \bd Ram\bd* ijja-dd Ɛamminadab.
\m Ɛamminadab ijja-dd Naḥcun, řḥakem n ayt n Yahuda.
\m 
\v 11 Naḥcun ijja-dd Salmu.
\m Salmu ijja-dd Buɛaz.
\m 
\v 12 Buɛaz ijja-dd Ɛubid.
\m Ɛubid ijja-dd Yassa.
\m 
\v 13 \bd Yassa\bd* ijja-dd Iliyab, amenzu nnes, wiss tnayen Abinadab, wiss třata Cimɛa,
\v 14 wiss arebɛa Natanayil, wiss xemsa Radday,
\v 15 wiss setta Uṣam d wiss sebɛa \bd Dawud\bd*.
\m 
\v 16 Suyᵉtmatsen \add tuɣa aten d\add* Ṣaruya d Abijayil.
\m Arrawen n Ṣaruya \add tuɣa aten d\add* Abicay d Yuwab d Ɛasa’il, třata \add n warrawen\add*.
\m 
\v 17 Abijayil turuw-dd Ɛamasa u babas n Ɛamasa \add tuɣa-t\add* d Yatru, wenni d Asmaɛili.
\b
\m 
\v 18 \bd Kalib\bd*, mmis n Ḥaṣrun, ijja-dd ak-d Ɛazuba, tamɣart \add nnes\add*, \add yeǧis\add* Yariɛut.
\m D ina \add tuɣa aten\add* d arrawen nnes: Yacar, Cubab d Ardun.
\m 
\v 19 \add Umi\add* immut Ɛazuba, yiwi Kalib Ifrat\add a\add* \add d tamɣart\add* i yixef nnes u nettat turuw as-dd Ḥur.
\m 
\v 20 Ḥur ijja-dd Uri u Uri ijja-dd Baṣalyil.
\b
\m 
\v 21 Awarni as yudef Ḥaṣrun x yeǧis n Maxir, babas n Jilɛad, u netta yiwyi tt \add d tamɣart\add* umi ɣares tuɣa settin n iseggʷusa u nettat turuw as-dd \bd Sajub\bd*.
\m 
\v 22 Sajub ijja-dd Ya’ir. Netta \add tuɣa\add* ɣares třata u-ɛicrin n tneddam di temmurt n Jilɛad.
\m 
\v 23 Jacur ak-d Aram ikkes zzaysen dcurat n Ya’ir, uřa d Qanat d tneddam i ɣares dd-iqqnen, s marra settin n tneddam.
\m Ina marra \add tuɣa aten d\add* arrawen n Maxir, babas n Jilɛad. \x ◘ \xo 2:23 \xt Řxř. 32:41, 42; Aɛwd. 3:4, 14\x*
\m 
\v 24 Awarni řmewt n Ḥaṣrun di Kalib-Ifrata, turuw as-dd Abiya, tamɣart n Ḥaṣrun, \bd Acḥur\bd*, babas n Taquɛa.
\b
\m 
\v 25 \bd Arrawen n Yarḥam’il\bd*, amenzu n Ḥaṣrun, \add tuɣa aten d\add* Ram, amenzu, \add xenni\add* Buna, Awran, Uṣam d Axiya.
\m 
\v 26 Yarḥam’il tuɣa ɣares ɛad ict n temɣart nneɣnit, qqaren as Aṭara. Nettat \add tuɣa\add* d yemmas n Unam.
\b
\m 
\v 27 Arrawen n Ram, amenzu n Yarḥam’il, \add tuɣa aten d\add* Maɛaṣ d Yamin d Ɛaqar.
\m 
\v 28 Arrawen n Unam \add tuɣa aten d\add* Cammay d Yadaɛ.
\m Arrawen n Cammay \add tuɣa aten d\add* Nadab d Abicur.
\m 
\v 29 Tamɣart n Abicur qqaren as Abiḥayil. Nettat turuw as-dd Aḥban d Mulid.
\m 
\v 30 Arrawen n Nadab \add tuɣa aten d\add* Salad d Affayim.
\m Salad immut břa arrawen.
\m 
\v 31 Arrawen n Affayim: \add mɣir\add* Yicɛi.
\m Arrawen n Yicɛi: \add mɣir\add* Cican.
\m Arrawen n Cican: \add mɣir ict n yeǧis\add*, Aḥlay.
\m 
\v 32 Arrawen n Yadaɛ, umas n Cammay, \add tuɣa aten d\add* Yatru d Yunatan.
\m Yatru immut břa arrawen.
\m 
\v 33 Arrawen n Yunatan \add tuɣa aten d\add* Falat d Zaza.
\m Ina \add tuɣa aten d\add* arrawen n Yarḥam’il.
\b
\m 
\v 34 Cican tuɣa war ɣares bu warrawen maca yessis \add wah\add*. Cican tuɣa ɣares ijj n umsexxar d Amiṣri, qqaren as Yarḥaɛ.
\v 35 Cican iwca yeǧis d tamɣart i umsexxar nnes Yarḥaɛ u nettat turuw as-dd Ɛattay.
\m 
\v 36 Ɛattay ijja-dd Natan,
\m Natan ijja-dd Zabad,
\m 
\v 37 Zabad ijja-dd Iflal,
\m Iflal ijja-dd Ɛubid,
\m 
\v 38 Ɛubid ijja-dd Yahu,
\m Yahu ijja-dd Ɛazarya,
\m 
\v 39 Ɛazarya ijja-dd Ḥalaṣ,
\m Ḥalaṣ ijja-dd Ilɛasa,
\m 
\v 40 Ilɛasa ijja-dd Sismay,
\m Sismay ijja-dd Callum,
\m 
\v 41 Callum ijja-dd Yaqamya
\m u Yaqamya ijja-dd Ilicamaɛ.
\b
\m 
\v 42 \bd Arrawen n Kalib\bd*, umas n Yarḥam’il: \add mɣir\add* Micaɛ, amenzu nnes wenni d babas n Zif, uřa d arrawen n Marica, babas n Ḥabrun.
\m 
\v 43 Arrawen n Ḥabrun \add tuɣa aten d\add* Quraḥ, Taffuɛ, Raqam d Camaɛ.
\m 
\v 44 Camaɛ ijja-dd Raḥam, babas n Jaraqɛam,
\m u Raqam ijja-dd Cammay.
\m 
\v 45 Mmis n Cammai \add tuɣa-t d\add* Maɛun.
\m Maɛun tuɣa d babas n Bayt-Ṣur.
\m 
\v 46 Ɛiyfa, tayya n Kalib, turuw-dd Ḥaran, Muṣa d Jaziz.
\m Ḥaran ijja-dd Jaziz.
\m 
\v 47 Arrawen n Jah-Day \add tuɣa aten d\add* Rajam, Yutam, Jican, Falaṭ, Ɛiyfa d Caɛaf.
\m 
\v 48 \add Ak-d\add* tayya n Kalib, Maɛka, ijja-dd netta Cabar d Tarḥana.
\m 
\v 49 Nettat turuw-dd Caɛaf, babas n Madmanna, d Cawa, babas n Makbina d babas n Jibɛa. Yeǧis n Kalib tuɣa Ɛaksa.
\m 
\v 50 Ina d arrawen n Kalib: mmis n Ḥur, amenzu n Ifrata, \add tuɣa\add* Cubal, babas n Qaryat-Yaɛarim,
\v 51 Salma, babas n Bayt-Laḥm, \add d\add* Ḥarif, babas n Bayt-Jadir.
\m 
\v 52 Arrawen n Cubal, babas n Qaryat-Yaɛarim, \add tuɣa aten d\add* Haruwa d Ḥaṣi-ha-Manuḥut.
\m 
\v 53 Tiwacunin n Qaryat-Yaɛarim \add tuɣa aten d\add* Iyitriyyen, Iffutiyyen, Icamatiyyen d Imacraɛiyyen. Zzaysen i dd-iqqarṣen Iṣarɛiyyen d Ictawuliyyen.
\m 
\v 54 Arrawen n Salma: \add mɣir\add* Bayt-Laḥm, uca Inaṭufatiyyen \add tuɣa aten\add*: Ɛaṭarut-Bayt-Yu’ab d Ḥaṣi-ha-Manaḥti d Iṣurɛiyyen.
\m 
\v 55 Tiwacunin n imariren nni izeddɣen di Yaɛbiṣ, \add tuɣa aten d\add* Itirɛatiyyen d Icamɛayyen d Isukaniyyen. Nitni d Iqiniyyen inni dd-iqqarṣen zi Ḥammat, babas n taddart n Rakab.
\b
\b
\c 3
\m 
\v 1 Ina \add tuɣa\add* d \bd arrawen n Dawud inni d as dd-ittwarwen di Ḥabrun\bd*: amenzu \add tuɣa\add* d Amnun n Axinuɛam, Tayazraɛilit; wiss tnayen Daniyal n Abijayil, Takarmalit; \f ◼ \fr 3:1 \fk Tayazraɛilit\ft - ict n temɣart zi Yazraɛil. \fk Takarmalit\ft - ict n temɣart zi Karmil.\f*
\v 2 wiss třata Abcalum, mmis n Maɛka, yeǧis n Talmay, ajeǧid n Jacur; wiss arebɛa Aduniya, mmis n Hajjit;
\v 3 wiss xemsa Cafaṭya n Abiṭal, wiss setta Yitarɛam, n temɣart nnes Ɛajla.
\v 4 Ttwarwen as-dd setta di Ḥabrun, minzi iḥkem dinni sebɛa n iseggʷusa d setta n iyuren u di Urcalim iḥkem třata u-třatin n iseggʷusa.
\b
\m 
\v 5 \bd Ina ttwarwen as-dd di Urcalim:\bd* Cimɛa, Cubab, Natan, Suliman. Arebɛa-ya tuɣa aten d arrawen n Bat-Cuɛ, yeǧis n Ɛammiyil. \f ◼ \fr 3:5 \fk Bat-Cuɛ\ft - isem-a wanita urin t ‘Batcabaɛ’ mani nneɣni.\f*
\m 
\v 6 \add Xenni\add* Yibḥar, Ilicamɛa, Ilifalaṭ,
\v 7 Nujah, Nafaj, Yafiɛ,
\v 8 Ilicamaɛ, Iliyadaɛ, Ilifalaṭ, tesɛa \add n warrawen\add*.
\m 
\v 9 Ina marra d arrawen n Dawud, nhřa arrawen n tiyya, u Tamar \add tuɣa\add* d učmatsen.
\b
\m 
\v 10 \bd Mmis n Suliman \bdit tuɣa-t d\bdit* Raḥabɛam\bd*, mmis Abiya, mmis Asa, mmis Yahucafaṭ,
\v 11 mmis Yahuram, mmis Axazya, mmis Yuwac,
\v 12 mmis Amaṣya, mmis Ɛazarya, mmis Yutam,
\v 13 mmis Aḥaz, mmis Ḥizqiya, mmis Manassa,
\v 14 mmis Amun \add d\add* mmis Yuciya.
\m 
\v 15 Arrawen n Yuciya \add tuɣa aten d\add* amenzu Yuḥanan, wiss tnayen Yahuyaqim, wiss třata Ṣidqiya, wiss arebɛa Callum.
\m 
\v 16 Arrawen n Yahuyaqim: mmis Yakunya \add d\add* mmis Ṣidqiya.
\m 
\v 17 Arrawen n Yakunya: Assir, Caɛaltiyil \add tuɣa\add* d mmis,
\v 18 u \add xenni\add* Malkiram d Fadaya d Cinaṣṣar d Yaqamya d Hucamɛa d Nadabya.
\m 
\v 19 Arrawen n Fadaya \add tuɣa aten d\add* Zarubbabil d Cimɛi.
\m Arrawen n Zarubbabil \add tuɣa aten d\add* Macullam d Ḥananya, u učmatsen \add tuɣa-tt d\add* Calumit,
\v 20 u \add xenni\add* Ḥacuba d Uwhil d Baraxya d Ḥasadya d Yucab-Ḥasad, xemsa \add n warrawen\add*.
\m 
\v 21 Arrawen n Ḥanan-Yah \add tuɣa aten\add* Falaṭ-Yah, d Icaɛya. Arrawen n Rafaya, arrawen n Arnan, arrawen n Ɛubadya, arrawen n Cakanya.
\m 
\v 22 Arrawen n Caxanya, \add mɣir\add* Camɛiya.
\m Arrawen n Cimɛiya \add tuɣa aten d\add* Ḥattuc, Yijɛal, Bariḥ, Naɛarya d Cafat, setta \add n warrawen\add*.
\m 
\v 23 Arrawen n Naɛarya \add tuɣa aten d\add* Ilyuɛinay, Ḥizqiya d Ɛazriqam, třata \add n warrawen\add*.
\m 
\v 24 Arrawen n Ilyuɛinay \add tuɣa aten d\add* Hudawyahu, Ilyacib, Falaya, Ɛaqqub, Yuḥanan, Dalaya d Ɛanani, sebɛa \add n warrawen\add*.
\b
\b
\c 4
\m 
\v 1 \bd Arrawen n Yahuda\bd* \add tuɣa aten d\add* Fariṣ, Ḥaṣrun d Karmi d Ḥur d Cubal.
\b
\m 
\v 2 \bd Ra’aya, mmis n Cubal\bd*, ijja-dd Yaḥat u Yaḥat ijja-dd Axumay d Lahad. Tina \add tuɣa atent\add* d řaǧat n Iṣarɛiyyen.
\m 
\v 3 \bd Ina \bdit tuɣa aten d arrawen\bdit* n Abi-Ɛiṭam\bd*: Yazraɛil, Yacma d Yadbac. Isem n učmatsen \add tuɣa-t d\add* Haṣṣalalfuni.
\m 
\v 4 \bd Fanuwil\bd* \add tuɣa-t d\add* babas n Jadur, u Ɛazar \add tuɣa-t d\add* babas n Ḥuca. Ina \add tuɣa aten d\add* arrawen n Ḥur, amenzu n Ifrata, babas n Bayt-Laḥm.
\m 
\v 5 \bd Acḥur, babas n Taquɛa\bd*, tuɣa ɣares tnayen n temɣarin, Ḥala d Naɛara.
\v 6 Naɛara turuw as-dd Axuzzam, Ḥafar, Taymani d Ixactariyyen. Ina \add tuɣa aten d\add* arrawen n Naɛara.
\v 7 Arrawen n Ḥala \add tuɣa aten d\add* Ṣarat, Ṣuḥar d Itnan.
\m 
\v 8 \bd Quṣ\bd* ijja-dd Ɛanub d Haṣubiba, d řaǧat n Axarḥil, mmis n Harum.
\m 
\v 9 \bd Yaɛbiṣ\bd* tuɣa ɣares ccan x yaytmas. Yemmas tuɣa tegga as Yaɛbiṣ, maɣar nettat tenna: “Necc urweɣ t-i-dd s řeḥriq.”
\v 10 Iřaɣa Yaɛbiṣ x AREBBI n Israil, inna: “Mařa Cek tbarked ayi u ad twessɛed aymir \add n temmurt\add* inu uca ad kidi yiři ufus nnec, ad xafi tessiggʷejed řɣar ḥima war d ayi třeqqef tamara ...!” Uca AREBBI issiweḍ \add as\add* min ittar.
\m 
\v 11 \bd Kalub\bd*, umas n Cuḥa, ijja-dd Maḥir. Wanita d babas n Ictun.
\v 12 Ictun ijja-dd Bayt-Rafa d Fasiḥ d Taḥinna, babas \add n tendint\add* n Ɛir-Naḥac. Ina d iryazen n Rayka. \f ◼ \fr 4:12 \fk Ɛir-Naḥac\ft - isem wanita ixs ad yini ‘tandint n ufiɣrar’\f*
\m 
\v 13 \bd Arrawen n Qanaz\bd* \add tuɣa aten d\add* Ɛutniyil d Saraya. Arrawen n Ɛutniyil, \add mɣir\add* Ḥatat.
\m 
\v 14 \bd Maɛunatay\bd* ijja-dd Ɛafra, u Saraya ijja-dd Yuwab, babas n Teɣzurt n Iḥrayfiyyen, maɣar nitni d iḥrayfiyyen, \add ayt n bu-ṣṣenɛet\add*.
\m 
\v 15 \bd Arrawen n Kalib\bd*, mmis n Yafunni, \add tuɣa aten d\add* Ɛiru, Iyla d Naɛam. Arrawen n Ila, \add mɣir\add* Qinaz.
\m 
\v 16 \bd Arrawen n Yahlaliyil\bd* \add tuɣa aten d\add* Zif d Zifa d Tiriya d Asarayil.
\m 
\v 17 \bd Arrawen n Ɛizra\bd* \add tuɣa aten d\add* Yatar d Marad d Ɛifar d Yalun. Nettat, \add Bitya\add*, turuw-dd Maryam d Cammay d Yicbaḥ, babas n Ictamuɛ,
\v 18 u tamɣart nnes Tayahudect turuw-dd Yarad, babas n Jadur, d Ḥabir, babas n Suku, d Yaqutiyil, babas n Zanuḥ, \add maca\add* \add inneɣni\add* nitni \add tuɣa aten d\add* arrawen n Bitya, yeǧis n firɛun, tenni yiwi Marad \add d tamɣart\add*. \f ◼ \fr 4:18 \fk Tayahudit\ft - ict n temɣart zi Yahuda.\f*
\m 
\v 19 \bd Arrawen n temɣart n Hudiya\bd*, učmas n Naḥam, \add tuɣa aten d\add* babas \add n tendint\add* n Qaɛila, Ajarmi, d Ictamuɛa, Amaɛki.
\m 
\v 20 \bd Arrawen n Cimun\bd* \add tuɣa aten d\add* Amnun d Rinna, Bin-Ḥanan d Tilun. Arrawen n Yiɛci \add tuɣa aten d\add* Zuḥayt d Ban-Zuḥayt.
\m 
\v 21 \bd Arrawen n Cayla\bd*, mmis n Yahuda, \add tuɣa aten d\add* Ɛir, babas n Lika, Laɛda, babas n Marica, d řaǧat n taddart n yinni ixeddmen s tiffest n taddart n Acbiɛa.
\m 
\v 22 U \add xenni\add* Yuqim d yeryazen n Kuziba, d Yuwac d Saraf, inni iṣeǧḍen x Mu’ab, d Yacubi-Laḥm. D man aya d řexbarat tiqdimin.
\v 23 Nitni \add tuɣa aten\add* d ayt n bu-třaxt u zeddɣen di Nataɛim d Jadira. Nitni qqimen zeddɣen din ḥima ad sexxaren i ujeǧid.
\b
\m 
\v 24 \bd Arrawen n Cimɛun\bd* \add tuɣa aten d\add* Namuyil d Yamin, Yarib, Zaraḥ, Cawul.
\m 
\v 25 Callum d mmis, mmis Mibsam, mmis Micmaɛ.
\m 
\v 26 Arrawen n Micmaɛ: mmis Ḥammuyil, mmis Zakkur \add d\add* mmis Cimɛi.
\m 
\v 27 Cimɛi tuɣa ɣares seṭṭac n warrawen d setta n tḥenjirin. \add Maca\add* aytmas war ɣarsen tuɣi bu warrawen aṭṭas u marra řaǧat nsen war mmarnint ca am tinni n warrawen n Yahuda.
\v 28 Nitni tuɣa zeddɣen di Bi’r-Sebɛa, di Mulada, di Ḥaṣar-Cuɛal,
\v 29 di Bilha di Ɛaṣim, di Tulad,
\v 30 di Bituwil, di Ḥurma, di Ṣiqlaɣ,
\v 31 di Bayt-Markabut, di Ḥaṣar-Susim, di Bayt-Biri u di Caɛarayim. Ař idweř Dawud d ajeǧid \add tuɣa\add* ina d tineddam nsen,
\v 32 d dcurat nsen: Ɛiṭam, Ɛayn, Rimmun, Tukan d Ɛacan, xemsa n tneddam
\v 33 ak-d marra dcurat i d asent-i-dd innḍen i tneddam-a, ař Baɛl. Tina d jjwayeh mani zedɣen u nitni ḥḍan s yixef nsen lista n jjadira.
\m 
\v 34 Macubab d Yamlik d Yuca, mmis n Amaṣya,
\v 35 d Yuwil d Yahu, mmis n Yuciba, mmis n Saraya, mmis n Ɛasiyil,
\v 36 d Ilyuɛinay d Yaɛquba d Yacuḥaya d Ɛasaya d Ɛadiyil d Yasimiyil d Banaya
\v 37 d Ziza, mmis n Cifɛi, mmis n Allun, mmis n Yadaya, mmis n Cimri, mmis n Camɛiya.
\v 38 Ina, \add inni i da\add* ittwařaɣan s yisem \add nsen\add*, \add tuɣa aten d\add* řḥukkam di řaǧat nsen, uca tudrin n ibabaten nsen tuɣa mmarnint aṭṭas.
\v 39 Nitni uyuren, kkin x uɣezdis n řɣarb n Jadur ař ccarq n teɣzurt, ḥima ad ufin mani ɣa hedden wuǧi nsen.
\v 40 Nitni ufin \add din\add* ddmani n tarewsa ccuren mliḥ, cnan. Tuɣa tammurt tewseɛ ɣar marra iɣezdisen, tarsa u dayes řhudnet, maɣar inni n Ḥam tuɣa zeddɣen din zic.
\v 41 Ina, inni ittwazemmemen s ismawen \add nsen\add*, usin-dd deg wussan n ujeǧid Ḥizqiya, ajeǧid n Yahuda, u nitni hedmen iqiḍan nsen, uřa d Imaɛuniyyen inni din ufin, teḥḥan ten ař ass-a. Nitni ggin ad zedɣen deg wemcan nsen, maɣar tuɣa dinni \add tammurt n\add* tarewsa i wuǧi nsen. \f ◼ \fr 4:41 \fk Ḥazaqiya\ft - s Tɛibranit ‘Yeḥazqiyahu’.\f*
\m 
\v 42 Zeg ina, zeg warrawen n Cimɛun, ffɣen \add ɛawed\add* xemsa mya n yeryazen ɣar idurar n Saɛir. Falaṭya d Naɛriya d Rafaya d Ɛuzziyil, arrawen n Yicɛi, \add bedden\add* ɣar uzeǧif nsen.
\v 43 Nitni nɣin min iqqimen n ayt n Ɛamaliq inni dd innejmen u nitni zeddɣen dinni ař ass-a.
\b
\b
\c 5
\m 
\v 1 \bd Arrawen n Rubin\bd*, amenzu n Israil - minzi netta tuɣa-t d amenzu, maca umi netta issexsar tassut n babas, temmewc tasɣart n tmenzut nnes i warrawen n Yusuf, mmis n Israil, maca war iǧi amenni ařami \add Yusuf\add* ittwazemmem di lista n jjadira ɛlaḥsab tasɣart n tmenzut nnes, \f ◼ \fr 5:1 \fk tamenzut\ft - niɣ ‘axeřqeḍ amezwaru’ niɣ ‘tařařit tamezwarut’ niɣ ‘tawařut tamezwarut’.\f*
\v 2 maɣar Yahuda idweř d bu-teɣruḍt jar aytmas u zzayes iffeɣ řḥakem \add waxxa\add* tasɣart n tmenzut tuɣa-tt ɣar Yusuf -
\v 3 arrawen n Rubin, amenzu n Israil, \add tuɣa aten d\add* Ḥanuk d Fallu, Ḥaṣrun d Karmi.
\m 
\v 4 Arrawen n Yuwil: mmis Camɛiya, mmis \add Ha\add*juj mmis Cimɛi,
\v 5 mmis Mixa, mmis Ra’aya, mmis Baɛl
\v 6 \add d\add* mmis Ba’ira, wenni yiwyi Tiɣlat-Filasir, ajeǧid n Accur, di lmenfa. Netta tuɣa d řḥakem n Irubiniyyen.
\m 
\v 7 Aytmas, \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, umi nitni ttwazemmemen di lista n jjadira ɛlaḥsab axřaq nsen, \add tuɣa aten d\add* azeǧif Yaɛiyil d Zakariyya \f ◼ \fr 5:7 \fk tařařit\ft - niɣ ‘axřaq’.\f*
\m 
\v 8 d Bilaɛ, mmis n Asa, mmis n Camɛi, mmis n Yuwil. Netta tuɣa izeddeɣ di Ɛaruɛir ař Nabu d Baɛl-Maɛun.
\v 9 Izdeɣ di ccarq ař wadaf ɣar řexřa i isswiẓẓḍen ixef nnes zeg iɣzar n Lfuraṭ, maɣar řebhayem nsen dewřen s waṭṭas di temmurt n Jilɛad.
\v 10 Deg wussan n Cawul ggin nitni amenɣi ak-d Ihajriyyen, inni iwḍan s ufus nsen. Nitni ggin ad zedɣen deg iqiḍan nsen x marra aɣezdis ɣar ccarq n Jilɛad.
\b
\m 
\v 11 \bd Arrawen n Jad\bd* tuɣa zeddɣen ajemmaḍin nsen di temmurt n Bacan ař Salxa.
\v 12 Yuwil \add tuɣa-t d\add* azeǧif nsen u Cafam \add tuɣa-t d\add* wiss tnayen, d Yaɛnay d Cafat. \add Nitni tuɣa zeddɣen\add* di Bacan.
\m 
\v 13 Aytmatsen, \add ttwasettfen\add* ɛlaḥsab tudrin n ibabaten nsen, \add tuɣa aten d\add* Mixayil d Macullam d Cabɛa d Yuray d Yaɛkan d Ziɛa d Ɛabir, sebɛa \add n wawmaten\add*.
\m 
\v 14 Ina \add tuɣa aten d\add* arrawen n Abiḥayil, mmis n Ḥuri, mmis n Yaruḥ, mmis n Jilɛad, mmis n Mixayil, mmis n Yacicay, mmis n Yahdu, mmis n Buz.
\m 
\v 15 Axi, mmis n Ɛabdiyil, mmis n Juni, \add tuɣa-t d\add* azeǧif n taddart n ibabaten nsen.
\m 
\v 16 Nitni tuɣa zeddɣen di Jilɛad, di Bacan u di tneddam i ɣares dd-iqqnen u di marra ddmani n tarewsa n Carun ař timawwin nsen.
\v 17 Marra ina ttwazemmemen di listat n jjadira deg wussan n Yutam, ajeǧid n Yahuda, u deg wussan n Yarubɛam, ajeǧid n Israil.
\b
\m 
\v 18 Zeg warrawen n Rubin d warrawen n Jad d wezyen n teqbič n Manassa, zeg ayt n umenɣi, \add zeg\add* iryazen inni yarebbun taseddart \add n uɛeskari\add* d ssif d yinni imeḥḍen řqews u tuɣa darrben deg umenɣi, aqa \add din\add* arebɛa u-rebɛin-ařef u-sebɛa-mya u-settin inni dd-iffɣen ak-d řɛeskar.
\v 19 Nitni mmenɣen ak-d Ihajriyyen u \add ak-d\add* Yaṭur d Nafic d Nudab.
\v 20 Nitni ttwaɛawnen \add deg umenɣi\add* akidsen uca Ihajriyyen d marra inni akidsen \add iǧan\add*, mmewcen deg ufus nsen, maɣar nitni sɣuyen deg umenɣi ɣar AREBBI u wanita ijja ad issarḍa ixef nnes s tẓaǧit yuǧɣen nsen, minzi nitni tecřen xas.
\v 21 Nitni ḥewwsen řmař nsen: xemsin-ařef n iřeɣman nsen, mitayen u-xemsin-ařef n wuǧi u ařfayen n yeɣyař u myat-ařef n iwdan. \f ◼ \fr 5:21 \fk iwdan\ft - s Tɛibranit ‘řeɛmuř’.\f*
\v 22 Minzi tuɣa \add din\add* aṭṭas n yinni ittwanɣen, maɣar tuɣa-t d ijj n umenɣi n AREBBI. Nitni ggin ad \add din\add* zedɣen deg wemcan nsen ař lmenfa.
\b
\m 
\v 23 \bd Arrawen n wezyen n teqbič n Manassa\bd* zedɣen di temmurt \add nni\add*. Nitni mmarnin zi Bacan ař Baɛl-Ḥirmun d Sanir d wedrar n Ḥarmun.
\v 24 Ina \add tuɣa aten d\add* izeǧifen n tudrin n ibabaten nsen: Ɛifar d Yicɛi d Iliyil d Ɛazriyil d Irmiya d Hudaya d Yaḥdiyil. \add Nitni tuɣa aten d\add* ayt n bu-teɣruḍt, iryazen imeḥḍen, iryazen n yisem, izeǧifen n tudrin n ibabaten nsen.
\v 25 Nitni ɣdaren AREBBI n řejdud nsen u ssfesden ixef nsen s irebbiten n řegnus n temmurt, inni tuɣa iteḥḥa AREBBI zzat i wudem nsen.
\v 26 \add Xenni\add* issekkar AREBBI n Israil buḥbeř n Ful, ajeǧid n Accur, d buḥbeř n Tiɣlat-Filnasir, ajeǧid n Accur, u wanita indeh i-ten ɣar lmenfa: ayt n Rubin d ayt n Jad d wezyen n teqbič n Manassa. Netta yiwyi ten ɣar Ḥalaḥ d Xabur d Hara\add n\add* u ɣar iɣzar n Juzan, \add u nitni qqimen dinni\add* ař ass-a. \x ◘ \xo 5:26 \xt 2 Ij. 18:11\x*
\b
\s1 Zi Lawi ař akehhan ameqqran Harun d tarwa nnes
\m 
\v 27 \bd Arrawen n Lawi\bd* \add tuɣa aten d\add* Jarcun, Qahat d Marari.
\m 
\v 28 \bd Arrawen n Qahat\bd* \add tuɣa aten d\add* Ɛamram, Yiṣhar d Ḥabrun d Ɛuzziyil.
\m 
\v 29 \bd Arrawen n Ɛamram\bd* \add tuɣa aten d\add* Harun d Musa, u Maryam \add učmatsen\add*.
\m \bd Arrawen n Harun\bd* \add tuɣa aten d\add* Nadab d Abihu, Aliɛazar d Itamar.
\m 
\v 30 Aliɛazar ijja-dd Finaḥas, Finaḥas ijja-dd Abicuɛa,
\m 
\v 31 Abicuɣa ijja-dd Buqqi, Buqqi ijja-dd Ɛuzzi,
\m 
\v 32 Ɛuzzi ijja-dd Zaraḥ-Yah, Zaraḥ-Yah ijja-dd Marayut,
\m 
\v 33 Marayut ijja-dd Amarya, Amarya ijja-dd Axiṭub,
\m 
\v 34 Axiṭub ijja-dd Ṣaduq, Ṣaduq ijja-dd Aximaɛaṣ,
\m 
\v 35 Aximaɛaṣ ijja-dd Ɛazarya, Ɛazarya ijja-dd Yuḥanan
\m 
\v 36 u Yuḥanan ijja-dd Ɛazarya. Wanita tuɣa d wenni ittsexxaren am ukehhan di Taddart i ibna Suliman di Urcalim.
\m 
\v 37 Ɛazarya ijja-dd Amarya, Amarya ijja-dd Axiṭub,
\m 
\v 38 Axiṭub ijja-dd Ṣaduq, Ṣaduq ijja-dd Callum,
\m 
\v 39 Callum ijja-dd Ḥilqiya, Ḥilqiya ijja-dd Ɛazarya,
\m 
\v 40 Ɛazarya ijja-dd Saraya u Saraya ijja-dd Yahuṣadaq.
\m 
\v 41 Yahuṣadaq yuyur \add akidsen\add* umi SIDI indeh Yahuda d Urcalim ɣar lmenfa s ufus n Nabuxadnaṣṣar.
\b
\b
\c 6
\s1 Ayt n Lawi - Ilawiyyen
\m 
\v 1 \bd Arrawen n Lawi\bd* \add tuɣa aten d\add* Jarcun, Qahat d Marari.
\m 
\v 2 Ina d ismawen n \bd warrawen n Jarcun:\bd* Libni d Cimɛi.
\m 
\v 3 \bd Arrawen n Qahat\bd* \add tuɣa aten d\add* Ɛamram, Yiṣḥar, Ḥabrun d Ɛuzziyil.
\m 
\v 4 \bd Arrawen n Marari\bd* \add tuɣa aten d\add* Maḥli d Muci. Tina d řaǧat n Ilawiyyen, ɛlaḥsab řejdud nsen.
\b
\m 
\v 5 \bd N Jarcun:\bd* mmis Libni, mmis Yaḥat, mmis Zimma,
\v 6 mmis Yuwax, mmis Ɛiddu, mmis Zaraḥ \add d\add* mmis Yatray.
\b
\m 
\v 7 \bd Arrawen n Qaḥat:\bd* mmis Ɛamminadab, mmis Quraḥ, mmis Assir,
\v 8 mmis Ilqana, mmis Abiyasaf, mmis Assir,
\v 9 mmis Taḥat, mmis Uriyil, mmis Ɛuzziya \add d\add* mmis Cawul.
\m 
\v 10 Arrawen n Ilqana \add tuɣa aten d\add* Ɛamasay d Aximut.
\v 11 Ilqana: mmis \add tuɣa-t\add* Ilqana, mmis Ṣufay, mmis Naḥat,
\v 12 mmis Iliyab, mmis Yaruḥam \add d\add* mmis Ilqana.
\m 
\v 13 Arrawen n Camwil \add tuɣa aten d\add* \add Yuwil\add*, amenzu nnes, u \add wenni d\add* wiss tnayen \add tuɣa-t\add* Abiya.
\b
\m 
\v 14 \bd Arrawen n Marari:\bd* Maḥli, mmis Libni, mmis Cimɛi, mmis Ɛuzza,
\v 15 mmis Cimɛa, mmis Ḥajiya \add d\add* mmis Ɛasaya.
\b
\m 
\v 16 Ina d inni igga Dawud ḥima ad iřin \bd x uɣennej n yizřan di Taddart n SIDI\bd*, awarni řami tuɣa tiweḍ Ttabut ɣar wemcan n arraḥet nnes.
\v 17 Nitni tuɣa ttsexxaren s izřan zzat i Tzeddiɣt, zzat i Uqiḍun n Umsagar, ař ikemmeř Suliman řebni n Taddart n SIDI di Urcalim. Nitni bedden di tsexxart nsen ɛlaḥsab lfariḍa nsen.
\v 18 Ina d inni i \add din\add* ibedden ak-d warrawen nsen:
\m Zeg warrawen \bd n Iqaḥatiyyen\bd*: \bd Hayman\bd*, amedyaz, mmis n Yuwil, mmis n Camwil,
\v 19 mmis n Ilqana, mmis n Yaruḥam, mmis n Iliyil, mmis n Tuwaḥ,
\v 20 mmis n Ṣuf, mmis n Ilqana, mmis n Maḥat, mmis n Ɛamasay,
\v 21 mmis n Ilqana, mmis n Yuwil, mmis n Ɛazarya, mmis n Ṣafanya, \f ◼ \fr 6:21 \fk Ṣafanya\ft - isem-a wanita ixs ad yini ‘wenni t issnuffaren SIDI’.\f*
\v 22 mmis n Taḥat, mmis n Assir, mmis n Abiyasaf, mmis n Quraḥ,
\v 23 mmis n Yiṣhar, mmis n Qahat, mmis n Lawi, mmis n Israil.
\m 
\v 24 Umas \bd Asaf\bd* tuɣa ittbedda \bd ɣar ufusi nnes\bd*. Tuɣa Asaf d mmis n Baraxya, mmis n Cimɛi,
\v 25 mmis n Mixayil, mmis n Baɛasiya, mmis n Malkiya,
\v 26 mmis n Itni, mmis n Zaraḥ, mmis n Ɛadaya,
\v 27 mmis n Itan, mmis n Zimma, mmis n Cimɛi,
\v 28 mmis n Yaḥat, \bd mmis n Jarcum\bd*, mmis n Lawi.
\m 
\v 29 Aytmatsen, \bd arrawen n Marari\bd*, bedden ɣar uzeřmaḍ: \bd Itan\bd*, mmis n Qici, mmis n Ɛabdi, mmis n Mallux,
\v 30 mmis n Ḥacabya, mmis n Amaṣya, mmis n Ḥilqiya,
\v 31 mmis n Amṣi, mmis n Bani, mmis n Camar,
\v 32 mmis n Maḥli, mmis n Muci, mmis n Marari, mmis n Lawi.
\b
\m 
\v 33 Aytmatsen, \bd Ilawiyyen\bd*, \add tuɣa\add* ttwaggen i qaɛ tsexxart di Tzeddiɣt n Taddart n AREBBI.
\v 34 \add Maca\add* \bd Harun d warrawen nnes\bd*, inni issbexxaren tiɣarṣa x uɛalṭar n wecmaḍ u x uɛalṭar n řebxur, aqa aten ḥima ad bedden ak-d qaɛ řxedmet deg Weqdas x Uqeddas u ḥima ad ggen aṣřaḥ i Israil am mammec marra min tuɣa yumur Musa, amsexxar n AREBBI.
\m 
\v 35 Ina d \bd arrawen n Harun\bd*: mmis Aliɛazar, mmis Finaḥas, mmis Abicuɛa,
\v 36 mmis Buqqi, mmis Ɛuzzi, mmis Zaraḥ-Yah
\v 37 mmis Marayut, mmis Amarya, mmis Axiṭub,
\v 38 mmis Ṣaduq \add d\add* mmis Aximaɛaṣ.
\b
\m 
\v 39 Ina d \bd imucan mani tuɣa zeddɣen\bd*, ɛlaḥsab řemrageḥ nsen x temmurt nsen:
\m i warrawen n Harun, \bd i řaǧ n Iqahatiyyen\bd*, minzi tuɣa-tt teqduḥt i nitni.
\m 
\v 40 Wcin asen Ḥabrun di temmurt n Yahuda ak-d ddmani n tarewsa nnes i d as dd-innḍen.
\v 41 Iyyar n tendint d dcurat nnes wcin t i Kalib, mmis n Yafunni.
\m 
\v 42 I warrawen n Harun wcin asen tineddam n tarewřa Ḥabrun d Libna ak-d ddmani n tarewsa nnes, Yattir d Ictamuɛa ak-d ddmani n tarewsa nnes,
\v 43 Ḥilayn ak-d ddmani n tarewsa nnes, d Dabir ak-d ddmani n tarewsa nnes,
\v 44 d Ɛacan ak-d ddmani n tarewsa nnes, d Bayt-Cams ak-d ddmani n tarewsa nnes.
\m 
\v 45 Zi teqbič n Binyamin \add ksin nitni\add* Jabɛa ak-d ddmani n tarewsa nnes, d Ɛallimat ak-d ddmani n tarewsa nnes, d Ɛanatut ak-d ddmani n tarewsa nnes. Marra tineddam nsen \add tuɣa atent d\add* třeṭṭac n tneddam ak-d řaǧat nsen.
\m 
\v 46 I warrawen n Qahat i iqqimen zi řaǧ n teqbič, \add ttwaɛeyynent\add* s tqedduḥt ɛecra n tneddam zeg wezyen n teqbič, zeg wezyen n Manassa.
\m 
\v 47 \bd I warrawen n Jarcun\bd* \add ttwaɛeyynent\add* ɛlaḥṣab řaǧat nsen zi teqbič n Issakar, u zi teqbič n Acir, u zi teqbič n Naftali, u zi teqbič n Manassa di Bacan třeṭṭac n tneddam.
\m 
\v 48 \bd I warrawen n Marari\bd* ɛlahsab řaǧat nsen \add ttwaɛeyynent\add* s tqedduḥt tenɛac n tneddam zi teqbič n Rubin, u zi teqbič n Jad u zi teqbič n Zabulun.
\m 
\v 49 Ayt n Israil wcin i Ilawiyyen tineddam-a ak-d ddmani nsent n tarewsa.
\v 50 S tqedduḥt wcin nitni tineddam-a i ittwařaɣan s yisem nsent zi teqbič n warrawen n Yahuda u zi teqbič n warrawen n Cimɛun u zi teqbič n warrawen Binyamin.
\b
\m 
\v 51 Uca zi řaǧat n \bd warrawen n Qahat\bd* ṭṭfen nitni \add ɛawed\add* tineddam zi teqbič n Ifrayim di temmurt nsen.
\v 52 Minzi wcin asen zi tneddam n tarewřa Cakim ak-d ddmani n tarewsa nnes x idurar n Ifrayim, d Jazar ak-d ddmani n tarewsa nnes,
\v 53 d Yaqmaɛam ak-d ddmani n tarewsa nnes, d Bayt-Ḥurun ak-d ddmani n tarewsa nnes,
\v 54 d Ayalun ak-d ddmani n tarewsa nnes d Jat-Rimmun ak-d ddmani n tarewsa nnes.
\m 
\v 55 Zeg wezyen n teqbič n Manassa \add ksin nitni\add* Anir ak-d ddmani n tarewsa nnes, d Bilɛam ak-d ddmani n tarewsa nnes i min iqqimen zi řaǧ n warrawen n Qahat.
\m 
\v 56 \bd Arrawen n Jarcum\bd* \add ksin ɛawed\add* zi řaǧ n wezyen n teqbič n Manassa: Julan di Bacan ak-d ddmani n tarewsa nnes d Ɛactarut ak-d ddmani n tarewsa nnes.
\m 
\v 57 U zi teqbič n Issakar \add ksin nitni\add* Qadac ak-d ddmani n tarewsa nnes, Dubra ak-d ddmani n tarewsa nnes,
\v 58 Ramut ak-d ddmani n tarewsa nnes u Ɛanim ak-d ddmani n tarewsa nnes.
\m 
\v 59 Zi teqbič n Acir \add ksin nitni\add* Macal ak-d ddmani n tarewsa nnes, d Ɛabdun ak-d ddmani n tarewsa nnes,
\v 60 d Ḥuquq ak-d ddmani n tarewsa nnes, d Raḥub ak-d ddmani n tarewsa nnes.
\m 
\v 61 Zi teqbič n Naftali \add ksin nitni\add* Qadac di Ljalil ak-d ddmani n tarewsa nnes, d Ḥammun ak-d ddmani n tarewsa nnes d Qaryatayim ak-d ddmani n tarewsa nnes.
\m 
\v 62 \bd Inni iqqimen n warrawen n Marari\bd* \add ksin ɛawed\add* zi teqbič n Zabulun Rimmunu ak-d ddmani n tarewsa nnes, d Tabur ak-d ddmani n tarewsa nnes
\m 
\v 63 u x ujemmaḍ n L’Urdun ɣar Ariḥa, ccarq n L’Urdun, \add ksin nitni\add* zi teqbič n Rubin Baṣar di řexřa ak-d ddmani n tarewsa nnes, d Yahṣa ak-d ddmani n tarewsa nnes,
\v 64 d Qadimut ak-d ddmani n tarewsa nnes, d Mayfaɛa ak-d ddmani n tarewsa nnes,
\m 
\v 65 u zi teqbič n Jad \add ksin nitni\add* Ramut di Jilɛad ak-d ddmani n tarewsa nnes, d Maḥanayim ak-d ddmani n tarewsa nnes,
\v 66 d Ḥacbun ak-d ddmani n tarewsa nnes, d Yaɛzir ak-d ddmani n tarewsa nnes.
\b
\b
\c 7
\m 
\v 1 \bd Arrawen n Issakar\bd* \add tuɣa aten d\add* Tulaɛ d Fuwwa d Yacub d Cimrun, arebɛa \add n warrawen\add*.
\m 
\v 2 Arrawen n Tulaɛ \add tuɣa aten d\add* Ɛuzzi, Rafaya, Yariyil, Yaḥmay, Yibcam d Cimuwil, izeǧifen n tudrin n ibabaten nsen n Tulaɛ, ayt n bu-teɣruḍt imeḥḍen, \add nitni ttwazemmemen\add* ɛlaḥsab axřaq nsen. Deg wussan n Dawud tuɣa řqedd nsen tnayen u-ɛicrin-ařef u-setta-mya \add n yeryazen\add*.
\m 
\v 3 Arrawen n Ɛuzzi, \add mɣir\add* Yazraḥya, u arrawen n Yazraḥya \add tuɣa aten d\add* Mixayil, Ɛubadya, Yuwil d Yacci-Yah, nitni marra \add tuɣa aten\add* xemsa n izeǧifen.
\v 4 \add Tuɣa\add* xasen \add řumur x\add* terbiɛin n řɛeskar, \add u nitni tuɣa ttwasettfen\add* ɛlaḥsab jjadira nsen, ɛlaḥsab taddart n ibabaten nsen. \add Aqa-ten\add* di setta u-třatin-ařef \add n yeryazen\add*, maɣar nitni tuɣa ɣarsen aṭṭas n temɣarin d warrawen. \f ◼ \fr 7:4 \fk terbiɛin\ft - s Tɛibranit ‘bandiyyat’. Uřa di 12:19.\f*
\v 5 Uca \add xenni\add* aytmatsen zi marra řaǧat n Issakar, sebɛa u-tmanyin-ařef n ayt n bu-teɣruḍt imeḥḍen, \add inni\add* ittwazemmemen marra di listat n jjadira.
\b
\m 
\v 6 \bd \bdit Arrawen n\bdit* Binyamin\bd* \add tuɣa aten d\add* Bilaɛ, Bakar d Yadiɛayil, třata \add n warrawen\add*.
\m 
\v 7 Arrawen n Bilaɛ \add tuɣa aten d\add* Iṣbun, Ɛuzzi, Ɛuzziyil, Yarimut d Ɛayri, xemsa n izeǧifen n řaǧat n ibabaten, ayt n bu-teɣruḍt imeḥḍen. Ttwazemmemen zzaysen tnayen u-ɛicrin-ařef u-arebɛa u-třatin \add n yeryazen\add* di listat n jjadira.
\m 
\v 8 Arrawen n Bakar \add tuɣa aten d\add* Zamira, Yuɛac, Iliɛazar, Ilyuɛinay, Ɛumri, Yarimut, Abiya, Ɛanatut d Ɛalamat. Nitni marra \add tuɣa aten d\add* arrawen n Bakar.
\v 9 Ttwazemmemen zzaysen ɛicrin-ařef u-mitayn n ayt n bu-teɣruḍt imeḥḍen di listat n řaǧat, ɛlaḥsab jjadira nsen \add u nitni tuɣa ttwasettfen ɛlaḥsab\add* izeǧifen n tudrin n ibabaten nsen.
\m 
\v 10 Arrawen n Yadiɛil, \add mɣir\add* Bilhan. U arrawen n Bilhan \add tuɣa aten d\add* Yaɛic, Binyamin, Ihud, Kanɛana, Zaytan, Tarcic d Axicaḥar.
\v 11 Nitni marra \add tuɣa aten d\add* arrawen n Yadiɛil. Sbeɛṭac-ařef u-mitayn n ayt n bu-teɣruḍt imeḥḍen ffɣen ɣar umenɣi ak-d řɛeskar, \add am ttwasettfen nitni\add* ɛlaḥsab izeǧifen n řaǧat nsen.
\m 
\v 12 Cuffim d Huffim \add tuɣa aten d\add* arrawen n Ɛir, Hucim, arrawen n Aḥir.
\b
\m 
\v 13 \bd Arrawen n Naftali\bd* \add tuɣa aten d\add* Jaḥṣiyil, Juni, Yaṣar d Callum, arrawen n Bilha.
\b
\m 
\v 14 \bd Arrawen n Manassa:\bd* Acriyil, wenni i d as dd-turuw \add temɣart nnes\add*. Tayya nnes, \add ict n temɣart\add* Taramit, turuw-dd Maxir, babas n Jilɛad. \f ◼ \fr 7:14 \fk Taramit\ft - ict n temɣart zi temmurt n Aram.\f*  \x ◘ \xo 7:14 \xt Řxř. 26:28-34\x*
\m 
\v 15 Maxir iksi ict n temɣart i Ḥuffim d Cuffim. Isem n učmas \add tuɣa-tt d\add* Maɛka. Isem n wenni wiss tnayen \add tuɣa-t d\add* Ṣalufḥad. Ṣalufḥad ɣares yessis \add waha\add*.
\m 
\v 16 Maɛka, tamɣart n Maxir, turuw-dd ijj n mmis uca tegga as Farac u umas qqaren as Carac u arrawen nnes \add tuɣa aten d\add* Ulam d Raqam.
\m 
\v 17 Arrawen n Ulam: \add mɣir\add* Badan. Ina d arrawen n Jilɛad, mmis n Maxir, mmis n Manassa.
\m 
\v 18 X učmas Hamulakat, nettat turuw-dd Ichud, Abiɛazar d Maḥla.
\m 
\v 19 Arrawen n Camidaɛ \add tuɣa aten d\add* Ixyan, Cakim d Laqḥi d Aniɛam.
\b
\m 
\v 20 \bd Arrawen n Ifrayim\bd*, \add mɣir\add* Cutalaḥ. Mmis tuɣa Barad, mmis Taḥat, mmis Ilɛada, mmis Taḥat, \x ◘ \xo 7:20 \xt Řxř. 26:35-37\x*
\v 21 mmis Zabad, mmis Cutalaḥ u \add xenni\add* Ɛazar d Ilɛad. Iryazen n Jat, inni dd-ittwaxeřqen di temmurt, nɣin ten, minzi nitni tuɣa hwan, ḥima ad kksen řmař nsen.
\m 
\v 22 Ifrayim, babatsen, icḍen aṭṭas n wussan uca aytmas usin-dd ḥima ad t ɛezzan.
\v 23 Xenni yudef netta x temɣart nnes uca teksi ddeyset uca turuw-dd ijj n uḥenjir. Netta igga as Bariɛa, minzi \add deg wussan nni\add* tuɣa d arẓiyyet di taddart nnes.
\m 
\v 24 Yeǧis \add tuɣa\add* Cira. Nettat tessbedd Bayt-Ḥurun n wadday d \add Bayt-Ḥurun\add* n nnej d Uzzin-Cira.
\m 
\v 25 Rafaɛ \add tuɣa\add* d mmis uřa d Racaf. Uca mmis tuɣa d Talaḥ, mmis Taḥan,
\v 26 mmis Laɛdan, mmis Ɛammihud, mmis Ilicamaɛ,
\v 27 mmis Nun \add d\add* mmis Yacuwa. \f ◼ \fr 7:27 \fk Yacuwa\ft - isem ikkemřen nnes ‘Yahu-Cuwa’.\f*
\m 
\v 28 Agřa nsen d imucan mani zeddɣen \add tuɣa\add* Bayt-Il ak-d tneddam i ɣares dd-iqqnen, d Naɛran ɣar ccarq u Jazar ɣar řɣarb ak-d tneddam i ɣarsent dd-iqqnen, uřa d Cakim ak-d tneddam i ɣares dd-iqqnen ař Ɣazza ak-d tneddam i ɣares dd-iqqnen.
\v 29 Tuɣa Bayt-Can ak-d tneddam i ɣares dd-iqqnen, Taɛnak ak-d tneddam i ɣares dd-iqqnen, Majiddu ak-d tneddam i ɣares dd-iqqnen \add u\add* Dur ak-d tneddam i ɣares dd-iqqnen deg ifassen n ayt n Manassa. Ayt n Yusuf, mmis n Israil, tuɣa zeddɣen daysent.
\b
\m 
\v 30 \bd Arrawen n Acir\bd* \add tuɣa aten d\add* Yimna, Yicwa, Yicwi, Bariɛa d Saraḥ \add tenni d\add* učmatsen.
\m 
\v 31 Arrawen n Bariɛa \add tuɣa aten d\add* Ḥabir d Malkiyil. Netta d baba n Birzawat.
\m 
\v 32 Ḥabir ijja-dd Yafliṭ, Cumir, Ḥutam d Cuɛa, učmatsen
\v 33 Arrawen n Yafliṭ \add tuɣa aten d\add* Fasak, Bimhal d Ɛacwat. Ina \add tuɣa aten d\add* arrawen n Yafliṭ.
\m 
\v 34 Arrawen n Camar \add tuɣa aten d\add* Axi, Ruhja, Yahubba d Aram.
\m 
\v 35 Arrawen n umas Hilam \add tuɣa aten d\add* Ṣufaḥ, Yimnaḥ, Calac d Ɛamal.
\m 
\v 36 Arrawen n Ṣufaḥ \add tuɣa aten d\add* Suwaḥ, Ḥaranfar, Cuɛal, Biri, Yamra,
\v 37 Baṣar, Hud, Camma, Cilca, Yitran d Ba’ira.
\m 
\v 38 Arrawen n Yitram \add tuɣa aten d\add* Yafunni, Ficfa d Ara.
\m 
\v 39 Arrawen n Ɛulla \add tuɣa aten d\add* Araḥ, Ḥaniyil d Riṣya.
\m 
\v 40 Marra ina \add tuɣa aten d\add* arrawen n Acir, izeǧifen n řaǧat n ibabaten, ayt n bu-teɣruḍt ifarzen imeḥḍen, izeǧifen n řḥukkam. Nitni ttwazemmemen di listat n jjadira n řɛeskar i umenɣi. \add Tuɣa\add* řqedd nsen setta u-ɛicrin-ařef n yeryazen.
\b
\b
\c 8
\s1 Tarwa n Binyamin
\m 
\v 1 Binyamin ijja-dd Bilaɛ, amenzu nnes, Acbil d wiss tnayen, Axrax d wiss třata,
\v 2 Naḥu d wiss arebɛa u Rafa d wiss xemsa.
\m 
\v 3 Bilaɛ tuɣa ɣares arrawen-a: Addar, Jira d Abihud,
\v 4 Abicuɛa, Nuɛman, Axuxa,
\v 5 Jira, Cafufan d Ḥuram.
\m 
\v 6 Ina d arrawen n Aḥud. Nitni \add tuɣa aten d\add* izeǧifen x ibabaten \add n řaǧat\add* n imezdaɣ n Jibɛa. Nedhen i-ten ɣar Manaḥat,
\v 7 aqa d Naɛman, Axiya d Jira. Netta indeh i-ten. U netta ijja-dd Ɛuzza d Axiḥud.
\m 
\v 8 Caḥarayim ijja-dd \add iḥenjiren\add* di temmurt n Mu’ab, awarni i umi tuɣa issuffeɣ timɣarin nnes Ḥucim d Baɛra.
\v 9 Ak-d temɣart nnes Xudac ijja-dd Yubab, Ḍibya, Mica, Malkam,
\v 10 Yaɛuṣ, Cabiya d Mirma. Ina \add tuɣa aten d\add* arrawen nnes, izeǧifen x ibabaten \add n řaǧat\add*.
\v 11 Ak-d Ḥucim ijja-dd netta Abiṭub d Ilfaɛal.
\m 
\v 12 Arrawen n Ilfaɛal \add tuɣa aten d\add* Ɛabir, Micɛam, Camid nni ibnan Unu d Lud ak-d tneddam i ɣares dd-iqqnen,
\v 13 Bariɛa d Camaɛ. Ina \add tuɣa aten d\add* izeǧifen n ibabaten \add n řaǧat\add* n imezdaɣ n Ayalun. Nitni uẓẓřen x imezdaɣ n Jat.
\m 
\v 14 Axiyu, Cacaq, Yarimut,
\v 15 Zabadya, Ɛarad, Ɛadar,
\v 16 Mixayil, Jicfa d Yuxa \add tuɣa aten d\add* arrawen n Bariɛa.
\m 
\v 17 Zabadya, Macullam, Ḥazki, Ḥabir,
\v 18 Yicmaray, Yazliya d Yubab \add tuɣa aten d\add* arrawen n Ilfaɛal.
\m 
\v 19 Yaqim, Zikri, Zabdi,
\v 20 Iliɛinay, Ṣillatay, Iliyil,
\v 21 Ɛadaya, Baraya d Cimra \add tuɣa aten d\add* arrawen n Cimi.
\m 
\v 22 Yicfan, Ɛabir, Iliyil,
\v 23 Ɛabdun, Zixri, Ḥanan,
\v 24 Ḥananya, Ɛilam, Ɛntutiya,
\v 25 Yafdiya d Fanuwil \add tuɣa aten d\add* arrawen n Cacaq.
\m 
\v 26 Camcaray, Caḥarya, Ɛatalya,
\v 27 Yaɛracya, Iliya d Zikri \add tuɣa aten d\add* arrawen n Yaruḥam.
\m 
\v 28 Ina \add tuɣa aten d\add* izeǧifen x ibabaten, \add ttwasettfen\add* ɛlaḥsab jjadira nsen, izeǧifen \add i iǧan\add*. Nitni tuɣa zeddɣen di Urcalim.
\b
\s1 Familya n Cawul
\m 
\v 29 Di Jibɛun izdeɣ babas n Jibɛun u tamɣart nnes qqaren as Maɛka.
\v 30 Amenzu nnes \add tuɣa\add* Ɛabdun, \add xenni\add* Ṣur, Qis, Baɛal, Nadab,
\v 31 Jadur, Axxiyu d Zakir.
\m 
\v 32 Miqlut ijja-dd Cama. Uřa d nitni zedɣen di Urcalim ajemmaḍ n aytmatsen, \add jmiɛ\add* ak-d yaytmatsen.
\m 
\v 33 Nir ijja-dd Qis u Qis ijja-dd Cawul u Cawul ijja-dd Yunatan, Malkicuɛa, Abinadab d Icbaɛal.
\m 
\v 34 Mmis n Yunatan \add tuɣa\add* Marib-Baɛal. Marib-Baɛal ijja-dd Mixa.
\m 
\v 35 Arrawen n Mixa \add tuɣa aten d\add* Fitun, Malik, Tariɛ d Aḥaz.
\m 
\v 36 Aḥaz ijja-dd Yahuɛadda u Yahuɛadda ijja-dd Ɛalmat, Ɛazmawet d Zimri. Zimri ijja-dd Muṣa,
\m 
\v 37 u Muṣa ijja-dd Binɛa. Mmis \add tuɣa\add* Rafaɛ, mmis Ilɛasa \add d\add* mmis Aṣiyal.
\m 
\v 38 Aṣiyal tuɣa ɣares setta n warrawen u ina d ismawen nsen: Ɛazriqam, Bukra, Ismaɛil, Caɛarya, Ɛubadya d Ḥanan. Nitni marra \add tuɣa aten d\add* arrawen n Aṣiyal.
\m 
\v 39 Arrawen n umas Ɛaciq \add tuɣa aten d\add* Ulam, amezwaru nnes, \add u\add* wiss tnayen \add tuɣa-t d\add* Yaɛuc d wiss třata Ilifalaṭ.
\m 
\v 40 Arrawen n Ulam \add tuɣa aten d\add* iryazen, ayt n bu-teɣruḍt imeḥḍen nni imeḥḍen řqews. Nitni tuɣa ɣarsen aṭṭas n warrawen d wayyawen, \add s marra\add* mya u-xemsin. Marra ina zeg warrawen n Binyamin.
\b
\b
\c 9
\s1 Imezdaɣ n Urcalim
\m 
\v 1 Marra Israil ittwazemmem \add di listat n jjadira\add* u xzar, nitni ttwazemmemen deg wedlis n ijeǧiden n Israil d Yahuda. Ittwandeh Yahuda ɣar lmenfa ɣar Babil di ssibbet n řeɣdar nsen.
\b
\m 
\v 2 Imezdaɣ imezwura \add i iggin ad zedɣen\add* x wagřa nsen di tneddam nsen, \add tuɣa aten\add* \add ayt n\add* Israil, \add uca uřa\add* d ikehhanen d Ilawiyyen d imsexxaren n Zzawect Tameqqrant.
\b
\m 
\v 3 Zeg warrawen n \bd Yahuda\bd* u zeg warrawen n \bd Binyamin\bd* u zeg warrawen n \bd Ifrayim\bd* u zeg warrawen n \bd Manassa\bd* zedɣen \add ina\add* di Urcalim:
\m 
\v 4 Ɛutay, mmis n Ɛammihud, mmis n Ɛumri, mmis n Imri, mmis n Bani. \add Netta tuɣa\add* zeg warrawen n Fariṣ, mmis n Yahuda.
\m 
\v 5 Zeg Aciluni\add yyen\add*: Ɛasaya, amenzu ak-d warrawen nnes,
\m 
\v 6 u zeg warrawen n Zaraḥ: Yaɛuyil \add waha\add*.
\m Aytmatsen \add tuɣa aten\add* di setta mya u-tesɛin.
\b
\m 
\v 7 Zeg warrawen n Binyamin: Sallu, mmis n Macullam, mmis n Huduya, mmis n Hasnuwa,
\v 8 d Yibniya, mmis n Yaruḥam; u Ila, mmis n Ɛuzzi, mmis n Mikri; u Macullam, mmis n Cafaṭya, mmis n Raɛuyil, mmis n Yibniya.
\m 
\v 9 Aytmatsen, \add ttwasettfen\add* ɛlaḥsab jjadira nsen, \add tuɣa aten di\add* tesɛa-mya u-setta u-xemsin \add n yeryazen\add*. Marra iryazen-a \add tuɣa aten\add* d izeǧifen x ibabaten n řaǧat nsen.
\b
\m 
\v 10 Zeg \bd ikehhanen\bd*: Yadaɛya, Yahuyarib d Yakin;
\v 11 d Ɛazarya, mmis n Ḥilqiya, mmis n Macullam, mmis n Ṣaduq, mmis n Marayut, mmis n Axiṭub, řḥakem n Taddart n AREBBI;
\v 12 d Ɛadaya, mmis n Yaruḥam, mmis n Facḥur, mmis n Malkiya; u Maɛsay, mmis n Ɛadiyil, mmis n Yaḥzira, mmis n Macullam, mmis n Macillimit, mmis n Immir.
\m 
\v 13 Aytmatsen \add inni tuɣa iqqnen ɣar\add* izeǧifen n tudrin n ibabaten nsen, \add tuɣa aten deg\add* ařef u-sebɛa-mya u-settin n ayt n bu-teɣruḍt imeḥḍen, \add inni iggin\add* řxedmet n tsexxart di Taddart n AREBBI.
\b
\m 
\v 14 Zeg \bd Ilawiyyen\bd*: Camɛiya, mmis n Ḥacub, mmis n Ɛazriqam, mmis n Ḥacabya, zeg warrawen n Marari,
\v 15 d Baqbaqar d Ḥarac d Jalal d Matanya, mmis n Mixa, mmis n Zikri, mmis n Asaf;
\v 16 d Ɛubaya, mmis n Camɛiya, mmis n Jalal, mmis n Yadutun; d Baraxya, mmis n Asa, mmis n Ilqana, wenni izeddɣen di ředcur n Inaṭufatiyyen.
\b
\m 
\v 17 \bd Iɛessasen n tewwart\bd* \add tuɣa aten d\add* Callum, Ɛaqqub, Ṭalmun d Aximan d tawmat nsen. Callum \add tuɣa-t d\add* azeǧif.
\v 18 Ař řexxu \add bedden nitni\add* ɣar Tewwart n Ujeǧid di manis i dd-tneqqar tfuct. Nitni d iɛessasen n tewwart ɣar řemrageḥ n řɛeskar n ayt n Lawi. \x ◘ \xo 9:18 \xt 1 Ki. 10:5; 2 Ij. 16:18\x*
\v 19 Callum, mmis n Quri, mmis n Abiyasaf, mmis n Quraḥ, d aytmas, \add inni tuɣa iqqnen\add* ɣar taddart n babas, ixs ad yini Iquraḥiyyen, \add tuɣa aten\add* x řxedmet n tsexxart. Nitni tuɣa-ten d iɛessasen ɣar tnebdatin n Uqiḍun, am mammec tuɣa řejdud nsen d iɛessasen n wadaf ɣar řmargeḥ n řɛeskar n SIDI.
\v 20 Finaḥas, mmis n Aliɛazar, \add tuɣa-t\add* zic d řḥakem nsen. SIDI \add tuɣa\add* akides.
\v 21 Zakariyya, mmis n Macalmiya, \add tuɣa-t d\add* aɛessas n tewwart ɣar wadaf n Uqiḍun n Umsagar.
\m 
\v 22 Marra inni ittwafarzen am yiɛessasen n tewwart ɣar wadafen, \add tuɣa aten di\add* mitayen u-tenɛac \add n yeryazen\add*. Nitni ttwazemmemen \add di lista n jjadira\add* di ředcur nsen. Dawud d Camwil, amwařaw, ssmetnen ten di řfusina i d asen dd-ittwawekkřen.
\v 23 Nitni tuɣa ttɛessan ak-d warrawen nsen ɣar tewwura n Taddart n SIDI, ɣar Taddart n Uqiḍun.
\v 24 Iɛessasen n tewwura \add tuɣa bedden\add* ɣar arebɛa \add n iɣezdisen\add* n usemmiḍ: ɣar ccarq, ɣar řɣarb, ɣar ccamal, ɣar ljanub.
\v 25 Tuɣa x aytmatsen, \add inni tuɣa izeddɣen\add* di ředcur nsen, ad dd-asen deg wass wiss sebɛa, ḥima \add ad sexxaren řmijař n ict n ssimana\add* di řwawqat ittwaggen, \add jmiɛ\add* akidsen,
\v 26 maɣar di řxedmet i d asen-dd ittwawekkřen tuɣa nitni d arebɛa n iɛessasen imezwura x tewwura. Nitni, ixs ad yini Ilawiyyen, ttwařeqqmen x ixxamen u x txubay n Taddart n AREBBI.
\v 27 Di ǧiřet ssensen deg wenneḍ n Taddart n AREBBI, maɣar tuɣa ttwakellfen s tɛessast d warzam \add n tewwura\add* kuř ṣṣbeḥ.
\v 28 \add Ca\add* zzaysen \add ttwaggen\add* x dduzanat n tsexxart, maɣar nitni ḥessben \add ten\add* umi ten ssidfen u umi ten ssuffɣen.
\v 29 \add Ca nneɣni\add* zzaysen ttwaggen x dduzanat u x marra řeqcuɛ iqeddsen u x waren azdad d binu d zzect d jjawi d řeɛṭur.
\m 
\v 30 Imsewjjaden n txeǧeḍt ittfuḥen ak-d řeɛṭur \add tuɣa aten\add* zeg warrawen n ikehhanen.
\m 
\v 31 Mattitya, \add ijjen\add* zeg ayt n Lawi, \add tuɣa\add* d amenzu n Callum, Aquraḥi. Ittwawekkeř as maḥend ad issewjed min ittxeṣṣa ad ssengwen.
\v 32 Zeg warrawen n Iqahatiyyen, zeg aytmatsen, \add tuɣa ca\add* ttwařeqqmen x weɣrum n wescan, ḥima ad t ssarsen \add di ṭṭabřa\add* kuř ass n ssebt.
\m 
\v 33 Nitni \add tuɣa aten\add* uřa d imedyazen, izeǧifen n ibabaten \add n řaǧat\add* n Ilawiyyen, inni ittwanfekken \add zi řexdayem nneɣni\add* minzi tuɣa xasen ḥima ad ceɣřen ak-d řxedmet-a ass d ǧiřet.
\m 
\v 34 Ina \add tuɣa aten d\add* izeǧifen n ibabaten \add n řaǧat\add* n Ilawiyyen, \add ttwasettfen\add* ɛlaḥsab jjadira nsen, izeǧifen \add i iǧan\add*. Nitni tuɣa zeddɣen di Urcalim.
\b
\s1 Tarwa n Jibɛun
\m 
\v 35 Di Jibɛun zedɣen Yaɛiyil, babas n Jibɛun, u isem n temɣart nnes tuɣa-t Maɛka.
\v 36 Mmis amenzu \add tuɣa\add* Ɛabdun. \add Tuɣa zeddɣen din ɛawed\add* Ṣur, Qis, Nir, Nadab,
\v 37 Jadur, Axiyu, Zakariyya d Miqlut.
\v 38 Miqlut ijja-dd Cimɛa. Nitni tuɣa zeddɣen ajemmaḍ n aytmatsen di Urcalim, \add jmiɛ\add* ak-d aytmatsen \add inneɣni\add*.
\m 
\v 39 Nir ijja-dd Qis, Qis ijja-dd Cawul u Cawul ijja-dd Yunatan, Malkicuɛa, Abinadab d Icbaɛal.
\m 
\v 40 Mmis n Yunatan \add tuɣa\add* Marib-Baɛal, u Marib-Baɛal ijja-dd Mixa.
\m 
\v 41 Arrawen n Mixa \add tuɣa aten d\add* Fitun, Malak d Taḥriɛa.
\m 
\v 42 Aḥaz ijja-dd Yaɛra, u Yaɛra ijja-dd Ɛalmat, Ɛazmawet d Zimri, u Zimri ijja-dd Muṣa,
\m 
\v 43 u Muṣa ijja-dd Binɛa. Mmis \add tuɣa\add* Rafaya, mmis Ilɛasa \add d\add* mmis nnes Aṣil.
\m 
\v 44 Aṣil tuɣa ɣares setta n warrawen u ina d ismawen nsen: Ɛazriqam d Bukra d Ismaɛil d Caɛarya d Ɛubadya d Ḥanan. Ina \add tuɣa aten d\add* arrawen n Aṣil.
\b
\b
\c 10
\s1 Řmewt n Cawul
\m 
\v 1 Mmenɣen Ifilisṭiniyyen ak-d Israil. Iryaz\add en\add* n Israil arewřen zzat i wudem n Ifilisṭiniyyen uca wḍan d imettan x temmurt n idurar n Jilbuɛa. \x ◘ \xo 10:1 \xt [1 Ṣm. 31:1-13]\x*
\v 2 Ifilisṭiniyyen ḍfaren Cawul d arrawen nnes břa qeṭṭu. Ifilisṭiniyyen nɣin Yunatan, Abinadab d Malkicuɛa, arrawen n Cawul.
\v 3 Tuɣa amenɣi ak-d Cawul iwɛar. Imjebbaden n řqews ufin t u netta tuɣa iggʷed aṭṭas zeg imjebbaden n řqews.
\v 4 Inna Cawul i uḥemmař n řesnaḥ nnes: “Suffeɣ-dd ssif nnec, snuqqeb ayi zzayes! Niɣ ad dd-asen inni war ittwaxetnen, ad zzayi stehzan.” \add Maca\add* aḥemmař nnes n řesnaḥ war ixs \add ad tt igg\add*, maɣar tuɣa iggʷed aṭṭas. \add Xenni\add* iksi Cawul ssif uca isseɣḍeř ixef nnes xas.
\v 5 \add Umi\add* iẓra uḥemmař n řesnaḥ, aqa Cawul immut, iwḍa řa d netta x ssif nnes uca immut.
\v 6 Immut Cawul ak-d třata n warrawen nnes uca \add ammu\add* temmut qaɛ taddart nnes.
\v 7 \add Umi\add* ẓrin marra yeryazen n Israil, inni tuɣa di řewḍa n teɣzurt, belli iryazen n Israil arewřen u Cawul d warrawen nnes ttwanɣen, semḥen nitni di tneddam nsen uca arewřen. \add Řexdenni\add* usin-dd Ifilisṭiniyyen uca dewřen zeddɣen din.
\m 
\v 8 Tiwecca nnes umi dd-usin Ifilisṭiniyyen ḥima ad keccḍen inni ittwanɣen, imsar, aqa ufin Cawul d warrawen nnes, inni tuɣa iwḍan x wedrar n Jilbuɛa.
\v 9 Nitni keccḍen t uca iwyen azeǧif nnes d řesnaḥ nnes uca ssekken ten di temmurt n Ifilisṭiniyyen, ḥima ad ssiwḍen řexbar aṣebḥan ɣar řexyařat n l’aṣnam nsen u ɣar řgens.
\v 10 Nitni ssarsen řesnaḥ n Cawul di taddart n arebbi nsen u aceqquf n uzeǧif nnes semmaren t ɣar řḥiḍ n Bayt-Can.
\m 
\v 11 Umi sřan marra \add imezdaɣ n\add* Yabic min ggin Ifilisṭiniyyen ak-d Cawul,
\v 12 kkaren marra iryazen imeḥḍen, ksin řxecbet n Cawul d řxecbat n warrawen nnes uca iwyen tent ɣar Yabic. Nitni neḍřen iɣsan nsen sadu i tcejjart n yigg di Yabic uca ẓummen sebɛa n wussan.
\m 
\v 13 Cawul immut di ssibbet n řeɣdar nnes i zi tuɣa iɣeddar SIDI, di ssibbet n wawař n SIDI i war dayes iṭṭif netta, u umi yarzu ccwar ɣar wenni issawařen ak-d imettan,
\v 14 war isseqsi SIDI. S uyenni inɣa i-t \add SIDI\add* uca issmuṭṭiy tagelda i Dawud, mmis n Yassa.
\b
\b
\c 11
\s1 Dawud idweř d ajeǧid uca iṭṭef Urcalim
\m 
\v 1 Marra Israil yusa-dd ɣar Dawud ɣar Ḥabrun, nnan: “Xzar, neccin d iɣsan d weysum nnec. \x ◘ \xo 11:1 \xt [2 Ṣm. 5:1-10]\x*
\v 2 Ɛad umi tuɣa Cawul d ajeǧid xaneɣ, aqa d cek i dd-issuffɣen Israil \add ɣar umenɣi\add* uca tjebded t-i-dd ad dd-idweř. Ɛawed inna ac SIDI, AREBBI nnec: ‘Cek ad tarewsed řgens inu Israil u cek ad tiřid d řḥakem x Israil.’”
\v 3 \add Xenni\add* usin-dd marra imɣaren n Israil ɣar ujeǧid di Ḥabrun uca igga ujeǧid Dawud ijj n řɛahd akidsen di Ḥabrun zzat i wudem n SIDI. Nitni dehnen Dawud d ajeǧid x Israil ɛlaḥsab awař n SIDI s uqemmum n Camwil. \f ◼ \fr 11:3 \fk s uqemmum\ft - s Tɛibranit ‘s ufus’.\f*  \x ◘ \xo 11:3 \xt 1 Ṣm. 16\x*
\m 
\v 4 Dawud iffeɣ ak-d marra Israil ɣar Urcalim, aqa-t d Yabus. Dinni \add tuɣa zeddɣen\add* ayt n Yabus, imezdaɣ n temmurt.
\v 5 Imezdaɣ n Yabus nnan i Dawud: “Cek war da tᵉttidfed ca.” \add Maca\add* Dawud iṭṭef lburj n Ṣihyun, aqa-t d tandint n Dawud.
\v 6 \add Maɣar\add* Dawud inna: “Kuř ijj wenni i ɣa iwten ayt n Yabus d amezwaru, ad idweř d azeǧif n ikumandaren. Uca Yuwab, mmis n Saraya, igeɛɛed d amezwaru, \add s uyenni\add* idweř netta d azeǧif.
\v 7 Tuɣa Dawud izeddeɣ di lqelɛa. X uya qqaren as \add i lqelɛa\add* tandint n Dawud.
\v 8 Netta ibna tandint i d as dd-innḍen, zi lqelɛa u ssenni iquwwar as-dd. Iɛdeř Yuɛab min iqqimen n tendint.
\v 9 Idweř Dawud yarenni di řemɣaret, maɣar SIDI n řɛeskarat tuɣa-t akides.
\b
\s1 Ayt n bu-teɣruḍt n Dawud
\m 
\v 10 \bd Ina d izeǧifen n ayt n bu-teɣruḍt n Dawud\bd* inni issjjehden akides tagelda nnes di marra Israil, ḥima ad t ggen d ajeǧid x Israil ɛlaḥsab awař n SIDI. \x ◘ \xo 11:10 \xt [2 Ṣm. 23:8-39]\x*
\v 11 Ta d lista n lɛadad n ayt n bu-teɣruḍt n Dawud: \bd Yacubɛam, mmis n Hakmuni, azeǧif n třatin\bd*. Netta iḥenneḍ s lansa nnes x teřt-mya \add n yeryazen\add* nni issnuqqeb deg ijj n umur.
\v 12 Awarni as \add yusa-dd\add* \bd Aliɛazar, mmis n Dudu, Axuxi. Netta tuɣa d ijj zi třata n ayt n bu-teɣruḍt\bd*.
\v 13 Netta tuɣa-t ak-d Dawud di Fas-Dammim. Ifilisṭiniyyen nnyarwen din i umenɣi. Ijj n wezyen n yeyyar tuɣa iccur s imendi umi yarweř řgens zeg Ifilisṭiniyyen.
\v 14 Nitni bedden di řwest n wezyen n yeyyar nni, fekken t, uca ɣeřben x Ifilisṭiniyyen. \add Ammu\add* i yarra SIDI d asenjem d ameqqran.
\m 
\v 15 Třata zi třatin n izeǧifen hwan ař taṣḍart, \add usin-dd\add* ɣar Dawud deg ifri n Abdullam. Řɛeskar n Ifilisṭiniyyen tuɣa iwta iqiḍan nnes di teɣzurt n Irafawiyyen.
\v 16 Dawud \add tuɣa-t\add* di lqelɛa u \add tuɣa\add* din ijj n řɛeskar n uḥewwes n Ifilisṭiniyyen di Bayt-Laḥm.
\v 17 Dawud iřqef i-t ufadi, inna: “Wi i d ayi dd ɣa yawyen aman zi tařa n Bayt-Laḥm nni \add iǧan\add* ɣar tewwart \add n tendint\add*?”
\v 18 \add Xenni\add* cuqen třata nni řmargeḥ n řɛeskar n Ifilisṭiniyyen, uymen-dd aman zi tařa n Bayt-Laḥm, tenni \add iǧan\add* ɣar tewwart \add n tendint\add*. Ksin ten akidsen uca iwḍen ɣar Dawud. Netta yugi ad ten isu, maca izeǧeɛ i-ten zzat i SIDI.
\v 19 Netta inna: “Aya iggʷej xafi, \add a\add* AREBBI inu, aqa necc ad ggeɣ man aya. Ma ad sweɣ idammen n yeryazen s řeɛmar nsen \add daysen\add*, maɣar nitni sebbřen tudart nsen simant nsen?” U netta war ixs ad ten isu. D man aya i ggin třata n ayt n bu-teɣruḍt \add nni\add*.
\v 20 \bd Abicay, mmis n Yuwab\bd*, tuɣa d azeǧif n třata \add nni\add*. Netta iḥenneḍ lansa nnes x teřt-mya \add n yeryazen\add*, issnuqqeb \add i-ten\add*. Netta ɣares ijj n yisem \add ittwacennɛen\add* jar třata \add nni\add*.
\v 21 Jar třata\add -ya\add* tuɣa \add Abicay\add* d wenni ittwacennɛen tnayen n imuren, u netta tuɣa d řqebṭan i nitni. \add Maca\add* netta war yiwiḍ uřa am třata imezwura.
\m 
\v 22 \add Xenni\add* \bd Banaya, mmis n Yahuyadaɛ\bd*, mmis n ijj n weryaz imeḥḍen, timegga nnes mɣarent. Netta zi Qabḍiyil. Iɣřeb x tnayen n iyraden jehden zi Mu’ab. Ɛawed tuɣa ihwa \add ict n twařa\add*, iɣřeb x ijj n weyrad di řwesṭ n ijj n wanu deg ijj n wass umi iwta wedfeř.
\v 23 \bd Netta\bd* iɣřeb uřa x yijj n weryaz d Amiṣri, s yijj tiddi n xemsa n iɣaǧen. Amiṣri tuɣa ɣares lansa deg ufus \add nnes\add* \add tegga\add* am yijj n weɛmud n ukeccuḍ n uxeyyeḍ. Ihwa ɣares s weɛmud, ikkes as lansa zeg ufus n Umiṣri uca inɣa i-t s lansa nnes.
\v 24 D man aya i igga Banaya, mmis n Yahuyadaɛ. S uya ɣares iǧa isem \add icneɛ\add* jar třata n ayt n bu-teɣruḍt.
\v 25 Netta tuɣa d wenni ittwacennɛen aṭṭas zi třatin, maca war yiweḍ ař třata \add imezwura\add*. Dawud igga i-t jar imtiqqan nnes.
\b
\m 
\v 26 Ayt bu-teɣruḍt imeḥḍen \add i iqqimen\add* \add tuɣa aten\add*:
\m Ɛasa’il, umas n Yuwab,
\m Ilḥanan, mmis n Dudu, zi Bayt-Laḥm,
\m 
\v 27 Cammut, Aharudi,
\m Ḥaliṣ, Alfaluni,
\m 
\v 28 Ɛira, mmis n Ɛiqqic, Atiqquɛi,
\m Abiɛazar, Aɛanatuti,
\m 
\v 29 Sibbikay, Aḥucati,
\m Ɛilay, Axuxi,
\m 
\v 30 Maharay, Anaṭufati,
\m Xalid, mmis n Baɛna, Anaṭufati,
\m 
\v 31 Ittay, mmis n Ribay, zi Jibɛa, zeg warrawen n Binyamin,
\m Banaya, zi Firɛatun,
\m 
\v 32 Huray zi teɣzarin n Jaɛac,
\m Abiyil, Aɛarabati,
\m 
\v 33 Ɛazmawet, Abaḥrumi,
\m Ilyaḥba, Acaɛalbuni,
\m 
\v 34 arrawen n Hacim, Ajazuni,
\m Yunatan, mmis n Cajay, Aharari,
\m 
\v 35 Axiyam, mmis n Sakar, Aharari,
\m Ilifal, mmis n Ur,
\m 
\v 36 Ḥafir, Amakirati,
\m Axiya, Afaluni,
\m 
\v 37 Ḥaṣru, Akarmali,
\m Naɛray, mmis n Izbay,
\m 
\v 38 Yuwil, umas n Natan,
\m Mibḥar, mmis n Hajri,
\m 
\v 39 Ṣaliq, Aɛammuni,
\m Naḥray, Aba’iruti, -
\m aḥemmař n řesnaḥ n Yuwab, mmis n Ṣaruya,
\m 
\v 40 Ɛira, Ayitri,
\m Jarib, Ayitri,
\m 
\v 41 Uriya, Aḥitti,
\m Zabad, mmis n Aḥlay,
\m 
\v 42 Adina, mmis n Ciza, zi teqbič n Rubin,
\m \add wenni\add* d azeǧif n ayt n Rubin,
\m u sennej nnes \add ɛad\add* třatin \add n yeryazen\add*,
\m 
\v 43 Ḥanan, mmis n Maɛka,
\m d Yucafaṭ, Amatni,
\m 
\v 44 Ɛuzziya Aɛactaruti,
\m Camaɛ d Yaɛiyil, arrawen n Ḥutam, Aɛaruɛiri,
\m 
\v 45 Yadiɛil, mmis n Cimri,
\m Yuḥa, umas, Atiṣi,
\m 
\v 46 Iliyil Amaḥwim,
\m Yaribay d Yucuwya, arrawen n Ilnaɛam,
\m d Yitma Amu’abi,
\m 
\v 47 Iliyil, Ɛubid d Yaɛsiyil zi Maṣubaya.
\b
\b
\c 12
\s1 Imeḍfaren n Dawud di Ṣiqlaɣ
\m 
\v 1 Ina i dd-yusin ɣar Dawud ɣar Ṣiqlaɣ, umi tuɣa ittxeṣṣa ɛad ad iqqim \add Dawud\add* itteggʷej x wudem n Cawul, mmis n Qic. Nitni \add tuɣa tteqqen i\add* ayt n bu-teɣruḍt inni iwcin afus \add i Dawud\add* deg umenɣi.
\v 2 Nitni tuɣa ḥezmen s řeqwas u zemmaren \add ad ḥejjaren\add* s yeẓra u ad wten fřitcat s řqews s ufus afusi u s ufus azeřmaḍ. Nitni tuɣa aten \bd zeg aytmas n Cawul, zi Binyamin\bd*.
\m 
\v 3 Axiɛazar \add tuɣa\add* d azeǧif nsen, \add xenni\add* Yuwac, \add nitni s tnayen idsen\add* d arrawen n Camaɛa, zi Jibɛa,
\m \add xenni\add* Yazu’il d Falaṭ, \add nitni s tnayen idsen d\add* arrawen n Ɛazmawet,
\m u Baraxya d Yahu, zi Ɛanatut,
\m 
\v 4 u Yacmaɛya, zi Jibɛun, \add wenni tuɣa\add* d ijj n bu-teɣruḍt jar třatin u \add tuɣa\add* x třatin,
\m 
\v 5 uřa d Irmiya, Yaḥziyil, Yuḥanan d Yuzabad, Ajadiri,
\m 
\v 6 Ilɛuzay, Yarimut, Baɛliya, Camarya, Cafaṭya, Aḥarufi,
\m 
\v 7 Ilqana, Yacci-Yah, Ɛazriyil, Yuɛazar d Yacubɛam, \add nitni d\add* Iquraḥiyyen,
\m 
\v 8 u \add ɣar uneggar\add* Yuɛila d Zabadya, \add nitni s tnayen idsen d\add* arrawen n Yaruḥam zi Jadur.
\b
\m 
\v 9 \bd Zeg \bdit ayt\bdit* n Jad\bd* aqa din inni immsebḍan ixef nsen \add ḥima ad ẓwan\add* ɣar Dawud, di lqelɛa di řexřa. Ayt n bu-teɣruḍt imeḥḍen, iɛeskariyyen \add wejden\add* i umenɣi, ttwaḥezmen s tseddariyin \add n uɛeskari\add* timeqqranin u s iḥricen. Udmawen nsen am wudmawen n weyraden u nitni uyuren s tazřa amecnaw iɣayḍen n wezɣar x idurar.
\m 
\v 10 Ɛazar tuɣa-t d azeǧif,
\m Ɛubadya d wiss tnayen, Iliyab d wiss třata,
\m 
\v 11 Micmanna d wiss arebɛa, Irmiya d wiss xemsa,
\m 
\v 12 Ɛattay d wiss setta, Iliyil d wiss sebɛa,
\m 
\v 13 Yuḥanan d wiss tmenya, Ilzabad d wiss tesɛa,
\m 
\v 14 Irmiya d wiss ɛecra, Maxbanay d wiss ḥiṭac.
\m 
\v 15 Ina tuɣa aten zeg warrawen n Jad, imeqqranen n řɛeskar. Ameẓyan ḥesben t am mya \add n yeryazen\add* u ameqqran am ařef.
\v 16 Ina d inni iẓwan L’Urdun deg uyur amezwaru, umi isfi \add L’Urdun\add* barra marra timuwwa nnes u nitni uẓẓřen x marra imezdaɣ n řewḍat n teɣzurt \add i iǧan\add* ɣar ccarq d řɣarb.
\b
\m 
\v 17 Uřa \bd zeg warrawen n Binyamin u zeg warrawen n Yahuda\bd* usin-dd \add yeryazen\add* ɣar Dawud ɣar lqelɛa n wedrar.
\v 18 Dawud iffeɣ-dd ɣarsen ḥima ad ten iřqa, uca iṭṭef deg wawař, inna asen: “Mařa kenniw tusim-dd ɣari ḥima ad ayi tewcem afus, xenni necc ad iřiɣ s wuř d ijj akidwem, \add maca\add* mařa \add kenniw tusim-dd\add* ḥima ad ayi tsellmem i iɣrimen inu, waxxa war \add din teǧi\add* řexcunet ɣar ifassen inu, \add xenni\add* iři ad t iẓar AREBBI n řejdud nneɣ u ad kenniw ixeǧes!”
\v 19 Iwḍa-dd Arruḥ am warruḍ x Ɛamasay, azeǧif n třatin, netta inna: “Neccin akidek, Dawud, u neccin akidek, mmis n Yassa. Řehna, řehna \add ad\add* kidek \add yiři\add* u řehna \add ad yiři\add* ak-d yinni d ac iwcin afus, maɣar AREBBI nnec iwca ac afus.” \add Xenni\add* issidef i-ten Dawud u igga i-ten d izeǧifen x terbiɛt n řɛeskar.
\b
\m 
\v 20 Uřa \bd zi Manassa\bd* \add tuɣa din\add* inni iɛdun ɣar Dawud, umi dd-iffeɣ ak-d Ifilisṭiniyyen ɣar umenɣi ak-d Cawul. \add Ifilisṭiniyyen maca\add* war d asen jjin ad wcen afus, minzi řbacat \add n tneddam\add* n Ifilisṭiniyyen ssekken t, nnan: “\add Zeɛma\add* netta izemmar ad iɛdu s izeǧifen nneɣ \add deg ufus nnes\add* ɣar Cawul, sides.”
\v 21 Umi dd-iɛqeb ɣar Ṣiqlaɣ, ɛdun \add ina\add* ɣares zeg \add ayt n\add* Manassa: Ɛadnaḥ, Yuzabad, Yadiɛil, Mixayil, Yuzabad, Ilihu d Ṣilltay, řqebṭanat x řuruf n Manassa.
\v 22 Nitni wcin afus i Dawud ḥima ad igewwed tirbiɛin \add n řɛeskar\add*, maɣar nitni marra tuɣa aten d ayt n bu-teɣruḍt imeḥḍen u nitni tuɣa aten d ikumandaren n řɛeskar.
\v 23 Maɣar di řweqt nni usin-dd \add yeryazen\add* ɣar Dawud zeg wass ař ass ḥima ad as wcen afus, ařami \add dewřen\add* d řɛeskar d ameqqran, am řɛeskar n AREBBI.
\b
\s1 X řɛeskar n Dawud di Ḥabrun
\m 
\v 24 Wa d řqedd n izeǧifen nni ittwaḥesben n yinni i tuɣa isswejden i umenɣi, inni dd-yusin ɣar Dawud di Ḥabrun maḥend ad ɣares sseɛdun tagelda n Cawul, am mammec t yumur SIDI:
\m 
\v 25 \bd Zeg warrawen n Yahuda\bd* \add tuɣa řqedd\add* n yinni yarbun tiseddariyin \add n uɛeskari\add* timeqqranin d iḥricen setta-ařaf u-temn-mya \add n yeryazen\add*. Nitni tuɣa wejden i umenɣi.
\m 
\v 26 \bd Zeg warrawen n Cimɛun\bd* \add tuɣa řqedd\add* n ayt n bu-teɣruḍt imeḥḍen i řɛeskar sebɛa-ařaf u-mya \add n yeryazen\add*.
\m 
\v 27 \bd Zeg warrawen n Lawi\bd* arebɛa-ařaf u-setta-mya \add n yeryazen\add*.
\m 
\v 28 Yahuyadaɛ tuɣa d řḥakem i \add warrawen n\add* Harun. Netta yiwi akides teřt-ařaf u-sebɛa-mya \add n yeryazen\add*.
\m 
\v 29 Ṣaduq \add tuɣa\add* d aḥudri, bu-teɣruḍt imeḥḍen. \add Zi\add* taddart n babas \add tuɣa din\add* tnayen u-ɛicrin n řqebṭanat.
\m 
\v 30 \bd Zeg warrawen n Binyamin\bd*, aytmas n Cawul, \add tuɣa din\add* teřt-ařaf \add n yeryazen\add*, minzi azyen ameqqran zzaysen tuɣa ḥeṭṭan taddart n Cawul.
\m 
\v 31 \bd Zeg warrawen n Ifrayim\bd* \add tuɣa din\add* ɛicrin-ařef u-tmenya-mya \add n yeryazen\add*, ayt n bu-teɣruḍt imeḥḍen, iryazen s yisem di taddart n ibabaten nsen.
\m 
\v 32 \bd Zeg wezyen n teqbič n Manassa\bd* \add tuɣa din\add* tmenṭac-ařef \add n yeryazen\add*, inni tuɣa ttwařaɣan s yismawen nsen maḥend ad dd-asen ad ggen Dawud d ajeǧid.
\m 
\v 33 \bd Zeg warrawen n Issakar\bd*, inni ɣarsen řefahmet n řmijařat n řweqt ḥima ad ssnen min tuɣa x Israil ad igg, \add tuɣa\add* řqebṭanat nsen mitayen \add n yeryazen\add*, u marra aytmatsen \add tuɣa aten\add* sadu afus nsen. \f ◼ \fr 12:33 \fk sadu afus nsen\ft - s Tɛibranit ‘sadu aqemmum nsen’.\f*
\m 
\v 34 \bd Zeg \bdit warrawen n\bdit* Zabulun\bd*, \add zeg yinni\add* dd-iffɣen ak-d řɛeskar s marra řesnaḥ nsen, \add tuɣa din\add* xemsin-ařef \add n yeryazen\add*. \add Nitni tuɣa sswejden\add* ḥima ad settfen ixef nsen deg useddi s wuř imun nican.
\m 
\v 35 \bd Zeg \bdit warrawen n\bdit* Naftali\bd* \add tuɣa din\add* ařef n řqebṭanat. Tuɣa-ten di sebɛa u-třatin-ařef \add n yeryazen\add* inni yarbun taseddart \add n uɛeskari\add* tameqqrant d lansa,
\m 
\v 36 \bd Zeg \bdit warrawen n\bdit* Dan\bd* \add tuɣa din\add* tmenya u-ɛicrin ařef u-setta-mya \add n yeryazen\add*, wejden i umenɣi.
\m 
\v 37 \bd Zeg \bdit warrawen n\bdit* Acir\bd* ffɣen-dd arebɛa-ařaf \add n yeryazen\add* ak-d řɛeskar ḥima ad ssbedden ixef nsen deg useddi.
\m 
\v 38 \bd Zeg ujemmaḍ n L’Urdun, zeg warrawen n Rubin u zeg warrawen n Jad u zeg wezyen n teqbič n Manassa\bd* \add tuɣa din\add* mya u-ɛicrin-ařef \add n yeryazen\add* ak-d marra řesnaḥ i umenɣi.
\m 
\v 39 Marra iɛeskariyyen-a usin-dd ɣar Ḥabrun, ttwasettfen deg iseddiyyen s wuř imun, ḥima ad ggen Dawud d ajeǧid x marra Israil. Uřa d min iqqimen n \add ayt n\add* Israil tuɣa aten s wuř d ijj ḥima ad ggen Dawud d ajeǧid.
\v 40 Nitni qqimen třata n wussan dinni ɣar Dawud, ccin swin, maɣar aytmatsen tuɣa bedden akidsen.
\v 41 Uřa d yinni yudsen ař Issakar d Zabulun d Naftali usin-dd, iwyen-dd weɣrum x iɣyař, x iřeɣman, x isarḍan u x ifunasen, \add s\add* řeɛweč \add am\add* farina d iɣrumen n tazart d iɣrumen n zzbib d binu d zzect d ifunasen d wuǧi s ufeyyeḍ, maɣar \add tuɣa din\add* řefraḥet di Israil.
\b
\b
\c 13
\s1 Asmuṭṭi n Ttabut ɣar taddart n Ɛubid-Idum
\m 
\v 1 Dawud imcawar ak-d imeqqranen x wařef d x mya u ak-d mkuř řḥakem. \x ◘ \xo 13:1 \xt [2 Ṣm. 6:1-11]\x*
\v 2 Dawud inna i marra agraw \add n řgens\add* n Israil: “Mařa yarḍa i kenniw uřa i SIDI, AREBBI nneɣ, ejj aneɣ ad nessekk deɣya \add ireqqasen\add* ɣar aytmatneɣ nni iqqimen di marra timmura n Israil u ɣar ikehhanen d Ilawiyyen nni izeddɣen akidsen di tneddam ak-d ddmani nsent n tarewsa, ḥima nitni ad ɣarneɣ nnyarwen.
\v 3 Uca ejj aneɣ ad ɣarneɣ dd-narr Ttabut n AREBBI, maɣar deg wussan n Cawul war kides neřhi.
\v 4 Marra agraw \add n řgens\add* inna belli ad ggen ammu, maɣar d man aya d ict n tmesřact d taṣebḥant di tiṭṭawin n marra řgens.
\m 
\v 5 Dawud issmun marra Israil, zeg \add yeɣzar n\add* Ciḥur ɣar Miṣra ař mani ɣa tiwḍed ɣar Ḥamat, ḥima ad ssgeɛɛden Ttabut n AREBBI zi Qaryat-Yaɛarim.
\v 6 \add Xenni\add* iffeɣ Dawud ak-d marra Israil ɣar Baɛla, ɣar Qaryat-Yaɛarim wenni \add iǧan\add* di Yahuda ḥima ad ssgeɛɛden Ttabut n AREBBI ssenni. \add Ttabut\add* n SIDI wenni ittɣiman \add jar\add* ikiruben mani ittwařaɣa x Yisem \add nnes\add*. \f ◼ \fr 13:6 \fk ikiruben\ft - ict n marka n lmalakat.\f*
\v 7 Nitni iwyen-dd Ttabut n AREBBI x ijj n ukarru n jdid zi taddart n Abinadab. Ɛuzza d Axiyu nedhen akarru.
\v 8 Dawud d marra Israil ttiraren lmusiqa s marra jjehd nsen zzat i wudem n AREBBI s yezřan d řgambriyat d lharpat d ibendiren d teǧunin n wuzzař d řebwaq.
\m 
\v 9 \add Umi\add* dd-iwḍen nitni ɣar unedrar n Kidun, isswiẓẓeḍ Ɛuzza afus nnes, ḥima ad iṭṭef Ttabut minzi nderfen ifunasen.
\v 10 \add Xas uca\add* yarɣa weɣḍab n SIDI x Ɛuzza uca iwta i-t maɣar wanita isswiẓẓeḍ afus nnes ɣar Ttabut uca immut din zzat i wudem n AREBBI.
\m 
\v 11 Yiweḍ ssem ɣar wuř n Dawud, aqa SIDI isɛar ammu x Ɛuzza u igga as i wemcan nni Fariṣ-Ɛuzza ař ass-a.
\v 12 Deg wass nni teřqef Dawud tiggʷudi zi AREBBI, inna: “Mammec i ɣa ggeɣ ad ɣari dd-awyeɣ Ttabut n AREBBI?”
\v 13 \add X uya\add* Dawud war ijji ad ɣares dd-awyen Ttabut di tendint n Dawud, \add maca\add* ijja i-tt ad taggʷej ɣar taddart n Ɛubid-Idum, Ajitti.
\v 14 Tekka Ttabut n AREBBI třata n iyuren di taddart nnes ɣar \add aytbab n\add* taddart n Ɛubid-Idum, u ibarek SIDI taddart n Ɛubid-Idum d marra min ɣares iǧan.
\b
\b
\c 14
\s1 Ccan n Dawud
\m 
\v 1 Ḥiram, ajeǧid n Ṣur, issekk ireqqasen ɣar Dawud \add ak-d\add* tcejjura n tengelt, d ineqqacen n weẓru n řḥiḍ d ineqqacen n ukeccuḍ. Nitni ssbedden as ict n taddart. \x ◘ \xo 14:1 \xt [1 Ṣm. 5:11-25]\x*
\v 2 Dawud issen, aqa SIDI tuɣa igga i-t d ajeǧid x Israil, maɣar issgeɛɛed \add SIDI\add* tagelda nnes aṭṭas di ṭṭweɛ n řgens nnes Israil.
\m 
\v 3 Dawud iksi ɛad timɣarin nneɣnit di Urcalim u Dawud yarni ijja-dd ɛad arrawen d tḥenjirin nneɣni.
\v 4 Ina d ismawen n warrawen i ɣares-dd \add ittwarwen\add* di Urcalim: Cammuɛ, Cubab, Natan, Suliman,
\v 5 Ibḥar, Ilicuɛ, Ilfalaṭ,
\v 6 Nujah, Nafaj, Yafiɛ,
\v 7 Ilicamaɛ, Baɛalyadaɛ d Ilifalaṭ.
\m 
\v 8 \add Umi\add* sřin Ifilisṭiniyyen, aqa dehnen Dawud d ajeǧid x Israil, geɛɛden marra Ifilisṭiniyyen ḥima ad arzun x Dawud. Dawud isřa \add i man aya\add* uca iffeɣ maḥend ad kidsen imsagar.
\v 9 Usin-dd Ifilisṭiniyyen uca bezzɛen ixef nsen di teɣzurt n Irafawiyyen.
\v 10 \add Xenni\add* isseqsa Dawud AREBBI, inna: “Ma ad geɛɛdeɣ ḍidd i Ifilisṭiniyyen? Ma ad ten tegged deg ufus inu?” Inna as SIDI: “Geɛɛed, Necc ad ten ggeɣ deg ufus nnec!”
\v 11 Nitni geɛɛden ɣar Baɛl-Faraṣim. Dinni iwta Dawud Ifilisṭiniyyen, inna: “S ufus inu icuq AREBBI di řɛedyan inu am waman arẓin \add ijj n řḥiḍ\add*.” X uya ggin as i wemcan nni Baɛl-Faraṣim.
\v 12 Ifilisṭiniyyen jjin irebbiten nsen dinni, uca yumur Dawud maḥend ad ten sscemḍen s tmessi.
\m 
\v 13 Ifilisṭiniyyen geɛɛden ɛawed uca bezzɛen ixef nsen di řewḍa n teɣzurt.
\v 14 Dawud isseqsa AREBBI u AREBBI inna as: “War ttgiɛɛid ca awarni asen, maca nneḍ asen-dd, ad ɣarsen dd-tased zeg uɣezdis n tcejjura n umetti.
\v 15 Xmi ɣa tesřed i tecři n iṣuraf di tqiccat n tcejjura n umetti, xenni ad teffɣed ɣar umenɣi, maɣar \add xenni\add* ad ac yizwar AREBBI zzat i wudem nnec, ḥima ad iwwet řɛeskar n Ifilisṭiniyyen.”
\v 16 Dawud igga am mammec d as yumur AREBBI, u nitni wtin řɛeskar n Ifilisṭiniyyen zi Jibɛun ař Jazar.
\v 17 Ammu i iffeɣ isem n Dawud di marra timmura, uca SIDI issiweḍ tiggʷudi zzayes x marra řegnus.
\b
\b
\c 15
\s1 Asmuṭṭi n Ttabut zi taddart n Ɛubid-Idum ɣar Urcalim
\m 
\v 1 Dawud igga i yixef nnes tudrin di tendint n Dawud u netta igga \add ɛawed\add* ijj n wemcan i Ttabut n AREBBI uca issbedd as ijj n uqiḍun.
\v 2 \add Xenni\add* inna Dawud: “War iɛeddeř aqa uřa d ijjen ad yarbu Ttabut n AREBBI, mɣir Ilawiyyen waha, maɣar SIDI ifarz i-ten ḥima ad arbun Ttabut n AREBBI u ḥima ad as sexxaren i řebda.”
\v 3 Dawud issmun-dd marra Israil ɣar Urcalim ḥima ad ssgeɛɛden Ttabut n SIDI ɣar wemcan nnes nni tuɣa d as igga.
\m 
\v 4 Dawud issmun arrawen n Harun d Ilawiyyen.
\m 
\v 5 Zeg warrawen n Qahat \add tuɣa\add* Uriyil d ameqqran \add nsen\add*. Aytmas \add tuɣa aten di\add* mya u-ɛicrin.
\m 
\v 6 Zeg warrawen n Marari \add tuɣa\add* Ɛasaya d ameqqran \add nsen\add*. Aytmas \add tuɣa aten di\add* mitayen u-ɛicrin.
\m 
\v 7 Zeg warrawen n Jarcum \add tuɣa\add* Yuwil d ameqqran \add nsen\add*. Aytmas \add tuɣa aten di\add* mya u-třatin.
\m 
\v 8 Zeg warrawen n Iliṣafan \add tuɣa\add* Camɛiya d ameqqran \add nsen\add*. Aytmas \add tuɣa aten di\add* mitayen.
\m 
\v 9 Zeg warrawen n Ḥabrun \add tuɣa\add* Iliyil d ameqqran \add nsen\add*. Aytmas \add tuɣa aten di\add* tmenyin.
\m 
\v 10 Zeg warrawen n Ɛuzziyil \add tuɣa\add* Ɛamminadab d ameqqran \add nsen\add*. Aytmas \add tuɣa aten di\add* mya u-tenɛac \add n yeryazen\add*.
\m 
\v 11 Dawud iřaɣa i ikehhanen Ṣaduq d Abyatar, uřa i Ilawiyyen Uriyil, Ɛasaya, Yuwil, Camɛiya, Iliyil d Ɛamminab.
\v 12 Netta inna asen: “Kenniw d izeǧifen n ibabaten \add n řaǧat\add* n Ilawiyyen. Sqeddsem ixef nwem, kenniw d aytmatwem, ḥima ad tessgeɛɛdem Ttabut n SIDI, AREBBI n Israil \add ɣar wemcan\add* nni d as sswejdeɣ.
\v 13 Minzi kenniw war teggim aya twařa tamezwarut, aqa SIDI, AREBBI nneɣ, isɛar xaneɣ, minzi war xas narzu ɛlaḥsab lfariḍa.
\v 14 Ikehhanen d Ilawiyyen ssqeddsen ixef nsen ḥima ad ssgeɛɛden Ttabut n SIDI, AREBBI n Israil.
\v 15 Ayt n Lawi arbun Ttabut n AREBBI ak-d iɛumad n trebbut x tɣarḍin nsen, am mammec \add t\add* yumur Musa ɛlaḥsab awař n SIDI.
\m 
\v 16 Dawud inna i imeqqranen n Ilawiyyen, aqa ad ssbedden aytmatsen, imedyazen ak-d dduzan n ǧɣa, ak-d lharpat, ak-d řgambriyat u ak-d taǧunin n wuzzař, maḥend ad ittwaseř řḥess issefraḥen ijhed.
\v 17 Nitni ssbedden Hayman, mmis n Yuwil, u zeg aytmas: Asaf, mmis n Baraxya, u zeg ayt n Marari, umatsen, Itan, mmis n Qucaya,
\v 18 u akidsen aytmatsen di dduq \add n tɛessast\add* wiss tnayen: Zakariyya, Bin, Yaɛziyil, Camiramut, Yaḥiyil, Ɛunni, Iliyab, Banaya, Maɛasya, Mattitya, Ilifalya, Maqniya, Ɛubid-Idum d Yaɛiyil, \add nitni tuɣa aten\add* d iɛessasen n tewwart.
\m 
\v 19 Imedyazen tuɣa aten d Hayman d Asaf d Itan ak-d teǧunin n nnḥas, ḥima ad \add tent\add* jjen ad ddendunen,
\v 20 u Zakariyya, Ɛuzziyil, Camiramut, Yaḥiyil, Ɛunni, Iliyab, Maɛasya d Banaya ak-d lharpat ittwarriglan ɣar sennej,
\v 21 d Mattitya, Ilifalya, Maqniya, Ɛubid-Idum, Yaɛiyil d Ɛazazya ak-d řgambriyat di řmeftaḥ wiss tmenya, ḥima ad ssuyuren \add izřan\add*.
\v 22 Kananya, ameqqran n Ilawiyyen, tuɣa-t x tarebbut \add n Ttabut\add*. Netta isseřmed asen mammec tuɣa ittxeṣṣa ad arbun, maɣar netta issen \add as\add*.
\v 23 Baraxya d Ilqana tuɣa aten d iɛessasen n tewwart ɣar Ttabut.
\v 24 Ikehhanen Cabanya, Yahucafaṭ, Natanayil, Ɛamasay, Zakariyya, Banaja d Iliɛazar suḍen di řebwaq zzat i Ttabut n AREBBI u Ɛubid-Idum d Yaḥiya tuɣa aten d iɛessasen n tewwart ɣar Ttabut.
\b
\s1 Asmuṭṭi n Ttabut ɣar tendint n Dawud
\m 
\v 25 \add Ammu\add* i imsar, aqa Dawud d imɣaren n Israil d imeqqranen x wařef ṭṭfen abrid ḥima ad ssgeɛɛden Ttabut n Řɛahd n SIDI s řefraḥet zi taddart n Ɛubid-Idum. \x ◘ \xo 15:25 \xt [1 Ṣm. 6:16-23]\x*
\v 26 \add Řami\add* arbun Ilawiyyen Ttabut n Řɛahd n SIDI am d asen iwca AREBBI \add a\add*fus, imsar aqa nitni qeddmen sebɛa n ifunasen imeẓyanen d sebɛa n icarriyyen d taɣarṣt.
\v 27 Dawud tuɣa yarḍ ijj n useřham n řeqṭen azdad, uřa marra Ilawiyyen, inni yarbun Ttabut d yinni tuɣa ittɣennajen, d Kananya, ameḥḍayi x yinni ittɣennajen. Dawud yarḍ ijj n upalṭu \add n ukehhan\add* n řeqṭen.
\v 28 Ammu i issgeɛɛed marra Israil Ttabut n Řɛahd n SIDI s iɣuyyan n řefraḥet u s řḥess n usuḍi deg uyicc n icarri u di řebwaq u s řḥess n taǧunin n wuzzař, u nitni tuɣa ttiraren s lharpat d řgambriyat.
\v 29 Řami dd-tiweḍ Ttabut n Řɛahd n SIDI ɣar tendint n Dawud, imsar, aqa Mixal, yeǧis n Cawul, texzar zi řkazi, teẓra mammec ineggez u mammec iceṭṭeḥ ujeǧid Dawud, uca tesseḥqar i-t deg wuř nnes.
\b
\b
\c 16
\s1 Dawud idebbar aɛbed n SIDI s tɣarṣa d izřan d tẓaǧit
\m 
\v 1 Nitni ssidfen Ttabut n AREBBI ɣar daxeř uca ssarsen tt di řwesṭ n Uqiḍun nni tuɣa d as dd-icedd Dawud, uca qeddmen nitni tiɣarṣa n wecmaḍ d tiɣarṣa n řehna zzat i wudem n AREBBI.
\v 2 \add Umi\add* ikemmeř Dawud asgeɛɛed n tɣarṣt n wecmaḍ d tɣarṣa n řehna, ibarek netta řgens deg Yisem n SIDI.
\v 3 Netta ibḍa i marra di Israil, i yeryazen d temɣarin, i kuř ijj, ijj n wengur n weɣrum, ijj n uceǧiq n weysum n ufunas d ijj n wareqqiɛ n zzbib.
\v 4 Netta igga ca n Ilawiyyen d imsexxaren i Ttabut n SIDI, ḥima ad ssɛeqřen u ad qadan u ad ssemɣaren SIDI, AREBBI n Israil.
\v 5 Asaf \add tuɣa-t d\add* azeǧif d Zakariyya \add tuɣa-t d\add* wiss tnayen awarni as \add u xenni\add* Yaɛiyil, Camiramut, Yaḥiyil, Mattitya, Iliyab, Banaya, Ɛubid-Idum d Yaɛiyil ak-dduzanat am lharpat d řgambriyat, uca Asaf igga ad as sřen s teǧunin n wuzzař.
\v 6 Ikehhanen Banaya d Yaḥziyil \add uyuren\add* s řebwaq zzat i Ttabut n Řɛahd n AREBBI.
\m 
\v 7 Deg wass nni igga Dawud i twařa tamezwarut x Asaf d aytmas maḥend ad ssemɣaren SIDI.
\b
\s1 Iẓři n uṣebbeḥ n Dawud
\m 
\v 8 \qt “Qadam SIDI, řaɣam x Yisem nnes,\qt*
\m \qt barrḥem s tmegga nnes jar řegnus.\qt*\x ◘ \xo 16:8 \xt [Izhd. 105:1-15; 96:1-13; 106:1, 47-48]\x*
\m 
\v 9 \qt Ɣennjem as, zehhdem i Netta,\qt*
\m \qt siwřem x marra lmuɛjizat nnes.\qt*
\m 
\v 10 \qt Cennɛem s Yisem nnes amqeddes,\qt*
\m \qt ḥima uř n yinni yarezzun SIDI,\qt*
\m \qt ad ifarḥ.\qt*
\m 
\v 11 \qt Seqsam x SIDI d jjehd nnes,\qt*
\m \qt arzum udem nnes řebda.\qt*
\m 
\v 12 \qt Ɛeqřem x řeɛjayeb nnes i igga,\qt*
\m \qt x řeɛřamet nnes\qt*
\m \qt u x řeḥkamat n uqemmum nnes.\qt*
\m 
\v 13 \qt Zzariɛet n Israil, amsexxar nnes,\qt*
\m \qt iḥenjiren n Yaɛqub,\qt*
\m \qt inni zzayes ittwafarzen!\qt*
\m 
\v 14 \qt Netta d SIDI, AREBBI nneɣ.\qt*
\m \qt Řeḥkamat nnes \tl i dd-ittasen\tl*\qt*
\m \qt x marra tammurt.\qt*
\m 
\v 15 \qt Ɛeqřem x Řɛahd nnes i řebda,\qt*
\m \qt awař nni iweṣṣa i ařef n jjiřat,\qt*
\m 
\v 16 \qt \tl Řɛahd\tl* i igga ak-d Ibrahim,\qt*
\m \qt \tl issemten i-t s\tl* tjaǧit nnes i Isḥaq.\qt*
\m 
\v 17 \qt Netta igga i-t d ict n tewṣeyyet i Yaɛqub,\qt*
\m \qt i Israil \add igga i-t\add* d ijj n Řɛahd i řebda,\qt*
\m 
\v 18 \qt umi inna:\qt*
\m \qt ‘Ad ac wceɣ tammurt n Kenɛan,\qt*
\m \qt tasɣart i d awem dd-ikkaren!’,\qt*
\m 
\v 19 \qt umi kenniw tuɣa d ijj n wuru n yeryazen,\qt*
\m \qt s drust \tl waha\tl*,\qt*
\m \qt d ibarraniyyen di \tl temmurt\tl*.\qt*
\m 
\v 20 \qt Telɛen zi řgens ɣar řgens \tl nneɣni\tl*,\qt*
\m \qt zeg ict n tgeldit ɣar ijj n řgens nneɣni.\qt*
\m 
\v 21 \qt Netta war ijji uřa d ijj ad ten iḥṣar,\qt*
\m \qt u Netta iɛaqeb ijeǧiden di ṭṭweɛ nsen.\qt*
\m 
\v 22 \qt ‘War ttḥadam ca imedhan inu,\qt*
\m \qt war tteggem řɣar deg inabiyyen inu!’\qt*
\m 
\v 23 \qt Ɣennjem i SIDI, marra tammurt,\qt*
\m \qt barrḥem i usenjem nnes ass x wass.\qt*
\m 
\v 24 \qt Ḥajam aɛuǧi nnes jar řegnus,\qt*
\m \qt řeɛjayeb nnes jar marra řegnus.\qt*
\m 
\v 25 \qt Maɣar SIDI d ameqqran,\qt*
\m \qt issdaḥeǧ asemɣar aṭṭas,\qt*
\m \qt Netta d amaggʷed mahu marra irebbiten.\qt*
\m 
\v 26 \qt Minzi marra irebbiten n řegnus\qt*
\m \qt aqa aten d l’aṣnam,\qt*
\m \qt \tl maca\tl* SIDI igga ijenwan.\qt*
\m 
\v 27 \qt Tissiqt d řɛezz \tl aqa aten\tl*\qt*
\m \qt zzat i wudem nnes,\qt*
\m \qt jjehd d řefraḥet deg wemcan nnes.\qt*
\m 
\v 28 \qt Wcem i SIDI, \tl a\tl* tiqebbař n řegnus,\qt*
\m \qt wcem i SIDI aɛuǧi d jjehd.\qt*
\m 
\v 29 \qt Wcem i SIDI aɛuǧi n Yisem nnes,\qt*
\m \qt awyem tawhibt uca asem-dd\qt*
\m \qt zzat i wudem nnes,\qt*
\m \qt bendqem i SIDI\qt*
\m \qt deg ucuwwaḍ n Zzawect Iqeddsen.\qt*
\m 
\v 30 \qt Arjijem zzat i wudem nnes,\qt*
\m \qt \tl a\tl* marra tammurt!\qt*
\m \qt Nican, \tl řexxu\tl* ddunect tbedd temten,\qt*
\m \qt war ttenhezzi \tl ɛad\tl*.\qt*
\m 
\v 31 \qt Ejj ajenna ad ifarḥ\qt*
\m \qt u tammurt ad tfarḥ,\qt*
\m \qt ad inin jar řegnus:\qt*
\m \qt SIDI iḥekkem.\qt*
\m 
\v 32 \qt Ejj ad izhar řebḥar d uɛemmar nnes, \qt*
\m \qt ejj ad isřiwřew yeyyar s řefraḥet,\qt*
\m \qt s marra min dayes.\qt*
\m 
\v 33 \qt Xenni ad sřiwřiwent\qt*
\m \qt marra ticejjura n wezɣar\qt*
\m \qt zzat i wudem n SIDI,\qt*
\m \qt maɣar Netta ad dd-yas,\qt*
\m \qt ḥima ad isegged tammurt.\qt* \f ◼ \fr 16:33 \fk azɣar\ft - niɣ ‘řɣabet’ niɣ ‘tazgant’.\f*
\m 
\v 34 \qt Qadam SIDI, maɣar Netta iṣbeḥ,\qt*
\m \qt maɣar tamexsiwt nnes icewwaren\qt*
\m \qt \tl tᵉttɣima\tl* i řebda.\qt*
\m 
\v 35 \qt Inim: Senjem aneɣ,\qt*
\m \qt \tl a\tl* AREBBI n usenjem nneɣ,\qt*
\m \qt ndeh aneɣ nmun, fekk aneɣ zi řegnus,\qt*
\m \qt ḥima ad nqada Isem iqeddsen nnek\qt*
\m \qt u ad Cek nṣebbeḥ s izřan n uṣebbeḥ.\qt*
\b
\m 
\v 36 \qt Ad ittwabarek SIDI, AREBBI n Israil,\qt*
\m \qt zi řebda ař řebda!”\qt*
\b
\m U marra řgens inna: “Amin!” uca imdeḥ SIDI.
\b
\m 
\v 37 Netta igga din zzat i wudem n Ttabut n SIDI, i Asaf d yaytmas, ḥima ad sexxaren řebda zzat i wudem n Ttabut, \add ḥima ad ggen\add* kuř ass min yurin i wass nni.
\v 38 Ɛubid-Idum ak-d aytmatsen, \add tuɣa aten jmiɛ\add* tmenya u-settin \add n yeryazen\add*. Ɛubid-Idum, mmis n Yaditun, d Ḥusa \add tuɣa aten d\add* iɛessasen n tiwwura,
\v 39 uca akehhan Ṣaduq d yaytmas, ikehhanen, \add tuɣa ttsexxaren\add* zzat i Tzeddiɣt n SIDI x řgeɛɛdet nni \add iǧan\add* ɣar Jibɛun,
\v 40 ḥima ad awyen tiɣarṣa n wecmaḍ břa \add a\add*qeṭṭu i SIDI x uɛalṭar n wecmaḍ, ɣar tuffut u ɣar tmeddit, am mammec marra min yuran di Ccariɛa n SIDI, tenni igga x Israil.
\v 41 Ɣarsen \add tuɣa\add* Hayman d Yadutun ak-d inneɣni inni ittwafarzen u ittwaggen s yismawen \add nsen\add*, ḥima ad qadan SIDI: ‘Maɣar tamexsiwt nnes icewwaren \add tᵉttɣima\add* i řebda!’
\v 42 Tuɣa ɣar Hayman d Yadutun \add d wenneɣni\add* řebwaq d taǧunin n wuzzař, maḥend ad ggen ad asen sřen \add yewdan\add*, uřa d dduzanat n lmusiqa \add inneɣni\add* \add i usemɣar\add* n AREBBI. Arrawen n Yadutun \add tuɣa bedden\add* ɣar tewwart \add n wadaf\add*.
\v 43 \add Xenni\add* yuyur marra řgens, kuř ijj ɣar taddart nnes. Uřa d Dawud iɛqeb ɣar taddart nnes ḥima ad ibarek taddart nnes.
\b
\b
\c 17
\s1 Awař n Arebbi x Zzawect Tameqqrant d řkursi igellden
\m 
\v 1 Umi izdeɣ Dawud di taddart nnes, inna Dawud i unabi Natan: “Xzar, necc zeddɣeɣ deg ict n taddart n ukeccuḍ n \add tcejjart n\add* tengelt, \add maca\add* Ttabut n Řɛahd n SIDI aqa-tt sadu řkettan \add n Uqiḍun\add*.” \x ◘ \xo 17:1 \xt [2 Ṣm. 7:1-15]\x*
\v 2 Natan yarra-dd x Dawud: “Egg marra min ɣarek deg wuř nnec, maɣar AREBBI akidek.”
\m 
\v 3 Di ǧiřet nni imsar aqa yusa-dd wawař n AREBBI ɣar Natan, inna:
\v 4 “Uyur, ini i umsexxar inu Dawud: ‘Ammu i iqqar SIDI: War d ayi tbennid Taddart i Necc, ḥima ad dayes zedɣeɣ,
\v 5 maɣar zeg wass umi dd-ssgeɛɛdeɣ Israil zi Miṣra, Necc war zdiɣeɣ \add ɛemmarṣ\add* deg ict n taddart. Maca Necc tuɣa ggureɣ zeg uqiḍun ɣar uqiḍun, zi tzeddiɣt ɣar tzeddiɣt.
\v 6 Mani ma uyureɣ ak-d marra Israil, ma Necc ssiwřeɣ \add ɛemmarṣ uřa s\add* ijj n wawař ak-d ijjen zi řquḍat n Israil, inni tuɣa ggiɣ ad arewsen řgens inu Israil, nniɣ: Mayemmi kenniw war d ayi tbennim ca taddart s ukeccuḍ n \add tcejjart n\add* tengelt?’ \x ◘ \xo 17:6 \xt 2 Ṣm. 7:7\x*
\v 7 Xenni řexxu, ammu i ɣa tinid i umsexxar inu, i Dawud: ‘Ammu i iqqar SIDI n řɛeskarat ijehden: Necc iwyeɣ-dd cek zi řkuri, zi ḍeffar n wuǧi, maḥend ad tdewřed d řḥakem x řgens inu Israil.
\v 8 Mani ma tuyured, tuɣa ayi akidek u Necc teḥḥiɣ marra řɛedyan zzat i tiṭṭawin nnec u Necc ggiɣ ac ijj n yisem am yisem n imeqqranen x temmurt.
\v 9 Necc neyyceɣ ijj n wemcan i řgens inu uca ẓẓuɣ t \add din\add*, maḥend ad izdeɣ deg wemcan \add nnes\add*, war ittwassnexřiɛ ɛad u war t ḥeṣṣaren ɛad ayt n řmuɛṣiyyet am zic,
\v 10 zeg wussan umi Necc ggiɣ řquḍat x řgens inu Israil. Necc sswaḍɛeɣ marra řɛedyan nnec u ssargbeɣ cek belli SIDI ad ac ibna ict n taddart.
\v 11 X minni i ɣa qefřen wussan nnec u ad tegged ad tareyyḥed jar řejdud nnec, ad imsar, Necc ad ssekkareɣ mmic awarni ac, wenni i ɣa iffɣen zeg warrawen nnec, u Necc ad ssmetneɣ tageldit nnes. \f ◼ \fr 17:11 \fk mmic\ft - s Tɛibranit ‘zzariɛet nnec’.\f*
\v 12 Netta ad ayi ibna ict n Taddart u Necc ad ssbeddeɣ řɛarc nnes i řebda.
\v 13 Necc ad iřiɣ d Babas i netta u netta ad ayi yiři d Mmi u Necc war xas ssḥeyyideɣ ca tamexsiwt inu icewwaren am mammec tt sḥeyydeɣ x wenni tuɣa d ac izwaren.
\v 14 Necc ad t ssmetneɣ di Taddart inu u di Tgeldit inu i řebda u řɛarc nnes ad ibedd imten i řebda.’”
\v 15 Issiweř Natan ak-d Dawud nican am mammec marra awařen-a u am mammec marra řewḥiy-a.
\b
\s1 Taẓaǧit n uqadi n Dawud
\m 
\v 16 \add Xenni\add* yudef ujeǧid Dawud uca iqqim zzat i wudem n SIDI, inna: “Min ɛniɣ necc, SIDI AREBBI, u min teɛna taddart inu aqa Cek tnedhed ayi-dd ař danita? \x ◘ \xo 17:16 \xt [2 Ṣm. 7:18-29]\x*
\v 17 Di tiṭṭawin nnec tuɣa man aya drus \add waha\add*, \add a\add* AREBBI, u \add řexxu\add* tessiwřed \add ɛad\add* x taddart n umsexxar nnec deg ijj n yimar iggʷej u txezzared dayi am yijj n ufiřu \add n warrawen\add* n bnadem i dd-ittawyen ɣar sennej, \add a\add* SIDI AREBBI!
\v 18 Min d ac i ɣa yini Dawud ɛad ktar x ccenɛet i tessecned i umsexxar nnec? Aqa Cek tessned amsexxar nnec!
\v 19 \add A\add* SIDI, aqa teggid marra řemɣaret-a di ṭṭweɛ n umsexxar nnec u ɛlaḥsab uř nnec, ḥima ad tessargbed \add ammu\add* marra timesřayin-a timeqqranin.
\v 20 \add A\add* SIDI, uřa d ijj war iǧi am Cek. War din AREBBI mɣir Cek s marra min nesřa s imezzuɣen nneɣ.
\v 21 Man wen \add i iǧan\add* am řgens nnec Israil, ayenni n řgens i iǧan x temmurt i ɣar iraḥ AREBBI ḥima ad t ifdi i Yixef nnes d řgens, ḥima ad igg i Yixef nnes ijj n Yisem s tmegga timeqqranin d issiggʷden, u ḥima ad yaẓẓeř x řegnus zzat i wudem n řgens nnec, wenni tefdid zi Miṣra? \f ◼ \fr 17:21 \fk ifdi\ft - xzar Izhd. 78:35.\f*
\v 22 Cek teggid řgens nnec Israil d ijj n řgens i Yixef nnec i řebda. Cek, \add a\add* SIDI, aqa Cek tdewřed d AREBBI i nitni.
\v 23 Xenni řexxu, \add a\add* SIDI AREBBI, ejj awař nni tessiwřed x umsexxar nnec u x taddart nnes ad ibedd i řebda u egg am mammec tessiwřed.
\v 24 Ejj Isem nnec ad ittwassemɣar i řebda umi ɣa inin: SIDI n řɛeskarat ijehden, AREBBI n Israil, aqa-t d AREBBI x Israil, uca iři ad tᵉttwassemten taddart n umsexxar nnec Dawud zzat i wudem nnec.
\v 25 Maɣar Cek, AREBBI inu, tessargbed deg imezzuɣen n umsexxar nnec aqa Cek ad as tebnid ict n taddart. X uya tusa-dd i umsexxar nnec deg wuř, ḥima ad iẓẓaǧ zzat i wudem nnec.
\v 26 Xenni řexxu, \add a\add* SIDI, Cek d AREBBI nni u Cek tessiwřed s \add marra\add* tcuni-ya x umsexxar nnec.
\v 27 Xenni řexxu, aqa yarḍa i Cek ad tbarked taddart n umsexxar nnec, ḥima ad tiři zzat i wudem nnec i řebda. Minzi Cek, \add a\add* SIDI, tbarked tt uca ad tᵉttwabarek i řebda.”
\b
\b
\c 18
\s1 Iɣellaben n Dawud
\m 
\v 1 Awarni aya imsar, aqa Dawud iɣřeb x Ifilisṭiniyyen uca yarra i-ten sadu nnes. Netta ikkes Jat d tneddam i ɣares dd-iqqnen zeg ufus n Ifilisṭiniyyen. \x ◘ \xo 18:1 \xt [2 Ṣm. 8:1-15]\x*
\v 2 Iɣřeb uřa x \add ayt n\add* Mu’ab ařami \add ayt n\add* Mu’ab dewřen d imsexxaren i Dawud, inni ittxeṣṣan ad wcen tarzifin.
\m 
\v 3 Dawud iɣřeb \add ɛawed\add* x Hadad-Ɛazar, ajeǧid n Ṣuba, ař Ḥamat, umi tuɣa dd-iffeɣ wanita ḥima ad issemtem řeḥkamet nnes ɣar yeɣzar n Lfuraṭ. \f ◼ \fr 18:3 \fk řeḥkamet nnes\ft - s Tɛibranit ‘afus nnes’.\f*
\v 4 Dawud ikkes zzayes ařef n ikarruten d sebɛa-ařaf n imnayen d ɛicrin-ařef n yeryazen x iḍaren u Dawud iqess iẓewran n iḍaren n marra \add iysan n\add* ikarruten uca ijja zzaysen mya n \add iysan n\add* ikarruten \add waha\add*.
\m 
\v 5 Yusa-dd Aram zi Dimacq, ḥima ad iwc afus i Hadar-Ɛazar, ajeǧid n Ṣuba, \add maca\add* Dawud iɣřeb x tnayen u-ɛicrin-ařaf n yeryazen n Aram.
\v 6 Dawud igga řɛeskarat n uḥewwes jar ayt n Aram n Dimacq, u ayt n Aram dewřen d imsexxaren n Dawud inni ittxeṣṣan ad \add as\add* wcen tarzifin \add d ljizya\add*. SIDI igga ttasiɛ i Dawud mani ma iruḥ wanita.
\v 7 Dawud yiwi tiseddariyin \add n uɛeskari\add* iqesḥen i ttwaggent s wureɣ, tinni tuɣa \add iǧan\add* n imsexxaren n Hadad-Ɛazar u yiwyi tent ɣar Urcalim.
\v 8 Dawud iksi aṭṭas n nnḥas zi Ṭabḥat d Xun, tineddam n Hadad-Ɛazar. Zzayes igga Suliman tarimant tameqqrant n nnḥas d ipilaren d řeqcuɛ n nnḥas. \f ◼ \fr 18:8 \fk tarimant\ft - s Tɛibranit ‘řebḥar’ niɣ ‘il’.\f*
\m 
\v 9 \add Umi\add* Tuɛi, ajeǧid n Ḥamat, isřa aqa Dawud iɣřeb x marra řɛeskar n Hadad-Ɛazar, ajeǧid n Ṣuba,
\v 10 issekk netta mmis Haduram ɣar ujeǧid Dawud ḥima ad isseqsa x umeddur nnes u ḥima ad as ibarek, minzi \add Dawud\add* immneɣ ak-d Hadad-Ɛazar uca iɣřeb xas - maɣar Hadad-Ɛazar tuɣa i Tuɛi d ijj n weryaz yarezzu amenɣi \add řebda\add* - u \add netta yiwi akides\add* ɛřam kuř řeqcuɛ n wureɣ d nnuqart d nnḥas.
\v 11 Ajeǧid Dawud issqeddes i-ten i SIDI, \add jmiɛ\add* ak-d nnuqart d wureɣ i d yiwi zi marra řegnus, zi Idum, zi Mu’ab, n ayt n Ɛammun, n Ifilisṭiniyyen u n \add ayt n\add* Ɛamaliq.
\m 
\v 12 Abicay, mmis n Ṣarawya, iɣřeb x Idum di teɣzurt n Tameǧaḥt, tmenṭac-ařef \add n yeryazen\add*.
\v 13 Netta igga řɛeskarat n uḥewwes di Idum ařami marra Idumiyyen dewřen d imsexxaren i Dawud, u SIDI igga ttasiɛ i Dawud mani ma iffeɣ netta.
\b
\s1 Imdebbaren ak-d ujeǧid Dawud
\m 
\v 14 Dawud iḥkem x marra Israil u igga s řḥeqq d tsegda i marra řgens nnes. \x ◘ \xo 18:14 \xt [2 Ṣm. 8:16-18; 20:23-26]\x*
\v 15 Yuwab, mmis n Ṣaruya, \add tuɣa-t\add* x řɛeskar u Yahucafaṭ, mmis n Axilud, \add tuɣa-t d\add* amarir n umezruy.
\m 
\v 16 Ṣaduq, mmis n Axiṭub, d Abimalik, mmis n Abyatar, tuɣa aten d ikehhanen, u Cawca tuɣa-t d amarir.
\m 
\v 17 Banaya, mmis n Yahuyadaɛ, \add tuɣa-t x\add* iɛessasen n arrimet u x ireqqasen n tazřa. Arrawen n Dawud \add tuɣa aten\add* d imezwura ɣar ufus n ujeǧid.
\b
\b
\c 19
\s1 Amenɣi ak-d Amun d Aram
\m 
\v 1 Awarni aya imsar, aqa Naḥac, ajeǧid n ayt n Ɛammun, immut. Mmis idweř d ajeǧid deg wemcan nnes. \x ◘ \xo 19:1 \xt [2 Ṣm. 10:1-19]\x*
\v 2 \add Xenni\add* inna Dawud: “Necc xseɣ ad ssecneɣ tamexsiwt icewwaren i Ḥanun, mmis n Naḥac, am mammec d ayi isscen babas tamexsiwt icewwaren.” Dawud issekk ireqqasen, ḥima ad t iɛezza x \add řmewt n\add* babas, uca iwḍen imsexxaren n Dawud ɣar temmurt n ayt n Ɛammun.
\v 3 \add Xenni\add* nnan řḥukkam n ayt n Ɛammun i sidi nsen Ḥanun: “Ma \add ixs\add* Dawud ad iweqqar babac \add s tidett\add* di tiṭṭawin nnec, minzi issekk-dd inni cek i ɣa iɛezzan? Ma war dd-issekk Dawud imsexxaren nnes ɣarek, ḥima ad arzun di temmurt maḥend ad \add tt\add* ssenqeřben u ad \add tt\add* bergagen?”
\v 4 \add Xenni\add* iṭṭef Ḥanun imsexxaren n Dawud, iḥeff asen azyen zi tmart, iqess asen azyen n warruḍ ař ḍeffar uca issekk i-ten.
\v 5 Nitni ṭṭfen \add abrid\add* uca ḥajan \add ireqqasen\add* x yeryazen-a i Dawud. S uyenni d asen issekk, minzi nitni tuɣa ttseḍḥan aṭṭas. Inna ujeǧid: “Qqimem di Ariḥa ař d i ɣa temɣar tmart nwem, xenni ad dd-tdewřem.”
\m 
\v 6 \add Umi\add* ẓrin ayt n Ɛammun belli nitni tuɣa ssarzgen ixef nsen ɣar Dawud, issekk Hanun d ayt n Ɛammun ařef talint n nnuqart, ḥima ad cran i yixef nsen ikarruten d imnayen zi Aram-Nahrayn, \add aqa-tt d Misuputamya\add*, zi Aram-Maɛka u zi Ṣuba.
\v 7 Nitni cran i yixef nsen tnayen u-třatin-ařef n ikarruten \add n umenɣi\add* u \add cran ɛawed\add* ajeǧid n Maɛka d řgens nnes. Nitni usin-dd uca wtin iqiḍan nsen zzat i wudem n \add tendint n\add* Maydaba. \add Uřa d\add* ayt n Ɛammun nnyarwen zi tneddam nsen uca ffɣen ɣar umenɣi.
\v 8 \add Umi\add* isřa Dawud aya, issekk Yuwab s marra řɛeskar nnes, ayt n bu-teɣruḍt.
\v 9 Ffɣen-dd ayt n Ɛammun uca sedden ixef nsen i umenɣi ɣar wadaf n tendint, am ijeǧiden nni dd-usin, \add tuɣa aten\add* s weḥḥedsen deg iyyar.
\v 10 \add Umi\add* iẓra Yuwab, aqa amenɣi řa zeg urendad uřa zi ḍeffar n uɣembub nnes, ixḍar zi marra inni ittwafarzen \add di řɛeskar\add* n Israil uca issbedd i-ten \add i umenɣi\add* ajemmaḍ n ayt n Aram.
\v 11 Min iqqimen n řgens igga i-ten sadu i ufus n umas Abicay u nitni ssbedden ixef nsen ajemmaḍ n ayt n Ɛammun.
\v 12 Inna netta: “Mařa Aram ijhed xafi, xenni as-dd, ewc ayi afus! Mařa ayt n Ɛammun jehden xak, xenni ad dd-aseɣ ad cek fekkeɣ.
\v 13 Iři d aryaz u ejj aneɣ ad niři nemḥeḍ di ṭṭweɛ n řgens nneɣ u di ṭṭweɛ n tneddam n AREBBI. Ad igg SIDI min iǧan mliḥ di tiṭṭawin nnes.”
\v 14 \add Xenni\add* ibda Yuwab d řgens i ɣares iǧan ad immneɣ ak-d ayt n Aram uca ina ṭṭfen di tarewřa zzat i wudem nsen.
\v 15 \add Umi\add* ẓrin ayt n Ɛammun, aqa ayt n Aram arewřen, ṭṭfen uřa d nitni di tarewřa zzat i wudem n umas Abicay uca ɛeqben ɣar tendint. \add Xenni\add* yiweḍ Yuwab \add ɣar\add* Urcalim.
\m 
\v 16 \add Umi\add* iẓra Aram aqa nitni ttwawten zzat i wudem n Israil, ssekken nitni ireqqasen uca ggin ad ffɣen ayt n Aram inni \add tuɣa izeddɣen\add* x ujemmaḍ n iɣzar \add n Lfuraṭ\add*, u Cubak, akumandar n řɛeskar n Hadad-Ɛazar yuyur zzat i uɣembub nsen.
\v 17 \add Umi\add* nnan aya i Dawud, issmun netta marra Israil, iẓwa L’Urdun, yusa-dd ɣarsen uca isedd ixef nnes i umenɣi. \add Umi\add* isedd Dawud ixef nnes i umenɣi ak-d ayt n Aram, mmenɣen nitni akides.
\v 18 Ayt n Aram arewřen zzat i wudem n Israil uca iqḍa Dawud x sebɛa-ařaf n \add yenni ineddhen\add* ikarruten \add n umenɣi\add* u x arebɛin-ařef n yeraz\add en\add* x iḍaren zeg ayt n Aram. \add Ɛawed\add* inɣa netta Cubak, akumandar n řɛeskar.
\v 19 \add Umi\add* ẓrin marra imsexxaren n Hadad-Ɛazar, aqa ttwarnan zzat i wudem n ayt n Israil, ggin nitni řehna ak-d Israil uca sexxaren as. War dd-yusi di řeɛqeř ɣar ayt n Aram ɛad ad fekken ayt n Ɛammun ict n twařa nneɣnit.
\b
\b
\c 20
\s1 Aɣelleb x tendint n Rabba n Ɛammun
\m 
\v 1 Ɣar uqeṭṭu n useggʷas \add n jdid\add*, di řweqt i dd itteffɣen ijeǧiden \add ɣar umenɣi\add*, imsar aqa Yuwab igewwed jjehd n řɛeskar. Yareddeǧ tammurt n ayt n Ɛammun uca inneḍ i Rabba, iḥṣar i-tt, \add umi\add* iqqim Dawud di Urcalim. Yuwab iɣřeb x Rabba uca iteḥḥa i-tt. \x ◘ \xo 20:1 \xt [2 Ṣm. 12:26-31]\x*
\v 2 Dawud ikkes ttaj n ujeǧid x uzeǧif nnes, u netta yufa řewzen nnes d ict n talint n wureɣ. Tuɣa xas tayaqutin iɣřan. Ssarsen ttaj nni x uzeǧif n Dawud. Netta yiwi-dd \add ɛawed\add* takeccaḍt d tameqqrant aṭṭas zi tendint. \x ◘ \xo 20:2 \xt 2 Ṣm. 12:30\x*
\v 3 Řgens nni \add iǧan\add* di \add tendint\add* issuffeɣ i-t uca ihjem xasen s řmencarat d iyařzimen n wuzzař d ccwaqar n wuzzař. Ammu i igga Dawud ak-d marra tineddam n ayt n Ɛammun. \add Xenni\add* iɛqeb Dawud d marra řgens ɣar Urcalim. \x ◘ \xo 20:3 \xt 2 Ṣm. 12:31\x*
\b
\s1 Amenɣi ak-d Ifilisṭiniyyen
\m 
\v 4 Awarni as imsar, aqa ikkar ɛawed umenɣi ak-d Ifilisṭiniyyen di Jazar. Řexdenni iɣřeb Sabkay, Aḥucayi, x Saffay, wenni d ijj zeg warrawen n Rafa, uca ttwasswaḍɛen nitni. \x ◘ \xo 20:4 \xt [2 Ṣm. 21:18-22]\x*
\m 
\v 5 Tuɣa din ɛawed amenɣi ak-d Ifilisṭiniyyen. Ilḥanan, mmis n Yaɛir, iɣřeb x Laḥmi, umas n Juliyat, zi Jat. Akeccuḍ n lansa nnes igga am yijj n weɛmud n ukeccuḍ n uxeyyeḍ.
\v 6 Uca ikkar ɛawed umenɣi di Jat. Tuɣa din ijj n weryaz d azirar s setta n iḍewḍan \add deg ifassen nnes\add* u setta \add n tfednin deg iḍaren nnes\add*, \add marra\add* řqedd nsen arebɛa u-ɛicrin. Uřa d netta ittwaxřeq-dd i Rafa.
\v 7 Netta istehza zi Israil, maca Yunatan, mmis n Cimɛa, umas n Dawud, iɣřeb xas.
\v 8 Ina d inni ittwaxeřqen-dd i Rafa di Jat u nitni wḍan s ufus n Dawud u s ufus n imsexxaren nnes.
\b
\b
\c 21
\s1 Aḥesseb n řgens d řɛiqab
\m 
\v 1 \add Xenni\add* ikkar-dd ijj n weɣrim x Israil uca iɣarr Dawud ḥima ad iḥseb Israil. \x ◘ \xo 21:1 \xt [2 Ṣm. 24:1-25]\x*
\v 2 Dawud inna i Yuwab u i řḥukkam n řgens: “Uyurem, ḥessbem Israil zi Bi’r-Sebɛa ař Dan uca awyem ayi-dd \add mecḥař\add*, maḥend ad ssneɣ mecḥař idsen.”
\v 3 \add Xenni\add* inna Yuwab: “Iři ad yarni SIDI di řgens nnes am iǧa řexxu ɛad mya n tseqqar. Ma war ǧin marra, \add a\add* sidi inu ajeǧid, d imsexxaren n sidi inu? Mayemmi \add i zzayi\add* ittmeẓri sidi inu man aya? Mayemmi ɣa issarbu Israil amarwas x yixef nnes?”
\v 4 \add Maca\add* awař n ujeǧid ijhed x Yuwab u Yuwab iffeɣ. Ikka marra Israil uca iɛqeb-dd ɣar Urcalim.
\v 5 Yuwab iwca i Dawud řqedd n řeḥsab n řgens am ikmeř. Marra Israil \add dayes\add* milyun u-mya-ařef n yeryazen inni izemmaren x ssif u Yahuda \add dayes\add* arebɛa-mya u-sebɛin-ařef n yeryazen nni izemmaren x ssif.
\v 6 \add Maca ayt n\add* Lawi d Binyamin war ten iḥsib ca, maɣar awař n ujeǧid tuɣa d aɛiffi i Yuwab.
\m 
\v 7 Tamesřact-a tuɣa d taɛeffant di tiṭṭawin n AREBBI uca Netta iřqef Israil s ict n jjriḥect.
\v 8 \add Xenni\add* inna Dawud i AREBBI: “Necc xḍiɣ \add xak\add* aṭṭas, s minzi necc ggiɣ aya. Xenni řexxu, kkes řmuɛṣiyyet x umsexxar nnec, minzi necc ggiɣ s tubbuheřya aṭṭas.”
\v 9 Issiweř SIDI ɣar Jad, amwařaw n Dawud, inna:
\v 10 “Uyur, siweř ɣar Dawud, ini: ‘Ammu i iqqar SIDI: Ad ac ssarseɣ třata n tmesřayin. Ixḍar ict \add zzaysent\add* i cek. Ad ac tt ggeɣ.’”
\v 11 Jad yusa-dd ɣar Dawud, inna as: ‘Ammu i iqqar SIDI: ‘Ixḍar cek:
\v 12 třata n iseggʷusa n řaẓ, niɣ třata n iyuren i di i ɣa tᵉttwahellked zzat i wudem n yinni cek iḥṣaren u ssif n řɛedyan nnec ad cek iḍfar, niɣ třata n wussan n ssif n SIDI, aqa-t d ṭṭaɛun di temmurt u lmalak n SIDI ad iḍeyyeɛ marra tammurt n Israil. Xenni řexxu, xzar, mammec ɣa yarreɣ x wenni d ayi dd-issekken.’”
\v 13 \add Xenni\add* inna Dawud i Jad: “Necc ttwaḥṣareɣ aṭṭas, \add maca\add* ejj ayi ad wḍiɣ deg ufus n SIDI, maɣar arreḥmet nnes d tameqqrant aṭṭas, war ttegg ad wḍiɣ deg ufus n bnadem.”
\m 
\v 14 Uca issiweḍ SIDI ṭṭaɛun x Israil uca wḍan sebɛin-ařef n yeryazen zi Israil.
\v 15 Issekk AREBBI lmalak ɣar Urcalim ḥima ad t iḍeyyeɛ. Umi ibda netta ad tt iḍeyyeɛ, iẓra i-tt SIDI uca indem x tuɛeffna, inna i lmalak n uḍeyyeɛ: “Cfa, sehwa řexxu afus nnec!” Tuɣa lmalak n SIDI ibedd ɣar unedrar n Uyabusi Urnan.
\m 
\v 16 \add Umi\add* issgeɛɛed Dawud tiṭṭawin nnes, iẓra lmalak n SIDI ibedd jar temmurt d ujenna am iṭṭef ufus nnes ssif, isswiẓẓeḍ i-t x Urcalim. \add Xenni\add* iwḍa Dawud d imeqqranen n řgens s uɣembub nsen \add ɣar temmurt\add* am tuɣa řeḥḥfen s txuncay \add n wecḍan\add*.
\v 17 Uca inna Dawud i AREBBI: “Ma war iǧi d necc i innan aqa ittxeṣṣa ad ḥesben řgens? Wah, d necc i tuɣa ixḍan d necc i iggin řmuɛṣiyyet aṭṭas, maca uǧi-ya, min ggint? \add A\add* SIDI, AREBBI inu, ejj ad yiři ufus nnec i tecti ɣari u ɣar taddart n baba, war iǧi maca ɣar řgens nnec.”
\b
\s1 Amcan n Taddart n SIDI Arebbi
\m 
\v 18 \add Xenni\add* inna lmalak n SIDI i Jad, ad yini i Dawud belli ittxeṣṣa i Dawud ad igeɛɛed ḥima ad issbedd ijj n uɛalṭar i SIDI x unedrar n Uyabusi Arnan.
\v 19 Uca Dawud igeɛɛed ɛlaḥsab awař n Jad nni issiweř s Yisem n SIDI.
\m 
\v 20 Uca inneqřeb-dd Arnan, iẓra lmalak. Arebɛa n warrawen nnes i tuɣa ɣares \add iǧan\add*, nnuffaren. Urnan tuɣa issarwat irden.
\m 
\v 21 Yiweḍ Dawud ɣar Arnan uca issgeɛɛed Arnan tiṭṭawin, iẓra Dawud. \add Xenni\add* iffeɣ-dd zeg unedrar uca ibendeq zzat i Dawud s uɣembub nnes ɣar temmurt.
\v 22 Inna Dawud i Arnan: “Ewc ayi andrar, ḥima ad xas bniɣ ijj n uɛalṭar i SIDI. Ewc ayi \add amcan\add* s ttaman nnes imun, ḥima ad tbedd ticti-ya di řgens.”
\v 23 Arnan inna i Dawud: “Ksi t i cek uca ad yegg sidi inu ajeǧid min iǧan d lemliḥ di tiṭṭawin nnes. Xzar, ad wceɣ ifunasen-a am tɣarṣa n wecmaḍ, u tiřwiḥin itteḥřuǧuḍen i usarwet d ukeccuḍ \add i tmessi\add* d irden, ad ten wceɣ i tewhibt \add n řɣiǧet\add*. Necc ad wceɣ aya marra.”
\v 24 \add Maca\add* inna ujeǧid Dawud i Arnan: “Lla, necc xseɣ nican ad t sɣeɣ s ttaman nnes ikmeř, minzi min iǧan nnec war t kessiɣ i SIDI, \add ḥima\add* \add ammu i\add* ɣa wehhbeɣ taɣarṣt n wecmaḍ i SIDI břa ad tt xeǧṣeɣ.”
\v 25 Ammu i iwca Dawud i Arnan i wemcan nni ijj n řewzen n setta-mya ciqlu n wureɣ.
\v 26 Dawud issbedd dinni ijj n uɛalṭar i SIDI uca yiwi xas tiɣarṣa n wecmaḍ d tewhibin \add n řɣiǧet\add*. Netta iřaɣa i SIDI u wanita yarra-dd xas s tmessi zeg ujenna x uɛalṭar n wecmaḍ.
\v 27 Inna SIDI i lmalak maḥend d yarr ssif deg ufurru n weɣřaf nnes.
\m 
\v 28 Di řweqt nni, umi iẓra Dawud aqa SIDI yarra-dd xas x unedrar n Uyabusi Arnan, yiwi \add din\add* tiɣarṣa.
\v 29 Di řweqt nni tuɣa Tazeddiɣt n SIDI, tenni tuɣa igga Musa di řexřa, d uɛalṭar i tɣarṣa n wecmaḍ x řgeɛɛdet n Jibɛun.
\v 30 Dawud \add maca\add* war izemmar ad din yuyur ḥima ad yarzu x AREBBI, maɣar tuɣa teřqef i-t tiggʷudi zi ssif n lmalak n SIDI.
\b
\b
\c 22
\s1 Asewjed i řebni n Zzawect Tameqqrant
\m 
\v 1 Inna Dawud: “Da \add i ɣa tbedd\add* Taddart n SIDI AREBBI, u da \add i ɣa yiři\add* uɛalṭar n tɣarṣa n wecmaḍ i Israil.”
\v 2 Yumur Dawud ad ssmunen ibarraniyyen nni iǧan di temmurt n Israil, u netta igga isuydayen ḥima ad ssuydan iẓra i řebni n Taddart n AREBBI. \f ◼ \fr 22:2 \fk yumur\ft - s Tɛibranit ‘inna’.\f*
\v 3 Dawud issewjed aṭṭas n wuzzař i řewtadat i tewwura n wadaf u i tḥenya n uɛarreḍ uřa d waṭṭas n nnḥas, \add ařami\add* war izemmar ad ittwawzen řqedd nnes,
\v 4 uřa d akeccuḍ n tengelt, s ijj n řqedd war izemmar ad ittwaḥseb, minzi ayt n Ṣidun d ayt n Ṣur ssiwḍen aṭṭas n ukeccuḍ n \add tcejjart n\add* tengelt ɣar Dawud.
\v 5 Dawud inna: “Mmi Suliman \add ɛad\add* d aḥudri arhef. Taddart i ɣa bnan i SIDI ad tiři d tameqqrant d issɛuǧen ḥima Isem \add nnes\add* d řɛezz nnes ad idweř ɣar marra timmura. Necc ad as sswejdeɣ.” Ammu i issewjed Dawud aṭṭas qbeř i řmewt nnes.
\m 
\v 6 \add Xenni\add* iřaɣa netta i mmis Suliman uca yumur i-t ḥima ad ibna ict n Taddart i SIDI, AREBBI n Israil.
\v 7 Inna Dawud i Suliman: “Mmi, necc simant inu tuɣa-t deg wuř inu, ḥima ad bniɣ ict n Taddart i Yisem n SIDI, AREBBI inu.
\v 8 \add Maca\add* yusa-dd ɣari wawař n SIDI, inna: ‘Cek tessizzřed aṭṭas n idammen u teggid imenɣan iqesḥen. Cek war tbennid i Yisem inu Taddart, maɣar cek tessizzřed zzat i wudem inu aṭṭas n idammen x temmurt.
\v 9 Xzar, mmic wenni i d ac ɣa dd-ittwarwen, ad yiři d ijj n weryaz n řḥudnet, maɣar Necc ad as wceɣ řhudnet zi marra řɛedyan nnes i d as dd-innḍen, maɣar isem nnes ad yiři Suliman u deg wussan nnes ad wceɣ řehna d řhudnet i Israil.
\v 10 Netta ad ibna ict n Taddart i Yisem inu u netta ad yiři i Necc d mmis u Necc ad as iřiɣ d Babas u Necc ad ssmetneɣ řɛarc n tgelda nnes x Israil i řebda.’
\v 11 Xenni řexxu, \add a\add* mmi, SIDI ad yiři akidek u cek ad tfeřḥed u ad tebnid Taddart n SIDI, AREBBI nnec, am mammec tuɣa xak issiweř.
\v 12 Iři ad ac iwc SIDI řeɛqeř d řefhamet uřa d usuyar x Israil ḥima ad teḥḍid Ccariɛa n SIDI, AREBBI nnec.
\v 13 Xenni ad tiřid tfeřḥed, xmi ɣa teḥḍid ḥima ad ggen tiweṣṣa d lfarayiḍ, tinni yumur SIDI s Musa i Israil. Iři d aryaz u iři tmeḥḍed, war tteggʷed ca u war tefciř!
\m 
\v 14 Xzar-dd, di řeḥṣaret inu sswejdeɣ ɣar ufus i Taddart n SIDI myat-ařef talint n wureɣ d wařef x wařef talint n nnuqart uřa d nnḥas d wuzzař, ařami war zemmaren ad weznen. Iwyeɣ uřa d akeccuḍ d yeẓra. U cek ad xas tarenyed ɛad.
\v 15 Cek ɣarek \add ɛawed\add* aṭṭas \add n yeryazen\add* ḥima ad ggen řxedmet, isuydayen d řemɛuǧam i \add uneqqac n\add* weẓru d ukeccuḍ d ɛřam kuř \add iwdan\add* nni ɣar teǧa řefhamet di ɛřam kuř řxedmet.
\v 16 Ureɣ d nnuqart d nnḥas d wuzzař anect war izemmar ad t ḥesben. Kkar, egg i-t uca SIDI ad kidek yiři.”
\m 
\v 17 Dawud yumur \add ɛawed\add* i marra řḥukkam n Israil, maḥend ad wcen afus i mmis Suliman, inna:
\v 18 “Ma war iǧi SIDI, AREBBI nwem, akidwem u \add ma war\add* d awem iwci řhudnet ɣar marra iɣezdisen nwem? Maɣar Netta igga marra imezdaɣ n temmurt deg ufus inu uca tᵉttwagg temmurt sadu ufus \add inu\add* zzat i wudem n SIDI u zzat i wudem n marra řgens.
\v 19 \add Xenni\add* řexxu, wcem uř d řeɛmar \add nwem\add* ḥima ad tarzum x SIDI, AREBBI nwem, uca kkarem, ad tebnam Zzawect Iqeddsen n SIDI AREBBI ḥima Ttabut n Řɛahd n SIDI d marra řeqcuɛ iqeddsen n AREBBI zemmaren ad ttwassidfen di Taddart i ɣa ittwabnan i Yisem n SIDI.”
\b
\b
\c 23
\s1 Dawud idebbar řxedmet n Ilawiyyen
\m 
\v 1 \add Umi\add* tuɣa Dawud iwsar u ijjiwen ussan, igga netta mmis Suliman d ajeǧid x Israil.
\v 2 Netta issmun-dd marra řḥukkam n Israil uřa d ikehhanen d Ilawiyyen.
\v 3 Ttwaḥesben Ilawiyyen zi třatin n iseggʷusa d sennej. \add Tuɣa\add* řqedd nsen azeǧif azeǧif tmenya u-třatin-ařef n yeryazen.
\v 4 Zzaysen \add tuɣa din\add* arebɛa u-ɛicrin-ařef n yinni ittwaggen d imseyyaren x řxedmet di Taddart n SIDI uca \add aqa din ɛad\add* setta-ařaf n imeḥḍayen d řquḍat,
\v 5 arebɛa-ařaf n iɛessasen n tewwart d arebɛa-ařaf n imedyazen i iẓran n uṣebbaḥ i SIDI, ak-d dduzanat \add n lmusiqa\add* nni ggiɣ necc, \add inna Dawud\add*, ḥima ad ssemɣaren \add SIDI\add* s yezřan n uṣebbaḥ.
\b
\m 
\v 6 Dawud ibḍa ten di terbiɛin, \add am ttwasettfen nitni\add* ɛlaḥsab arrawen n Lawi: Jarcun, Qahat d Marari.
\b
\m 
\v 7 Zeg \bd Ijarcuniyyen\bd* \add tuɣa aten d\add* Laɛdan d Cimɛi.
\m 
\v 8 Arrawen n Laɛdan \add tuɣa aten d\add* azeǧif Yaḥiyil, Zitam d Yuwil, třata \add n yeryazen\add*.
\m 
\v 9 Arrawen n Cimɛi \add tuɣa aten d\add* Calumit, Ḥaziyil d Haran, třata \add n yeryazen\add*. Ina \add tuɣa aten d\add* izeǧifen x ibabaten \add n řaǧat\add* n Laɛdan.
\m 
\v 10 Arrawen n Cimɛi \add tuɣa aten d\add* Yaḥat, Zayna, Yaɛuc d Bariɛa. Ina \add tuɣa aten d\add* arrawen n Cimɛi.
\m 
\v 11 Yaḥat tuɣa-t d azeǧif u Ziza d wiss tnayen, \add maca\add* Yaɛuc d Bariɛa war tuɣi ɣarsen arrawen aṭṭas. Ɣar řeḥsab ttwaḥesben nitni d icten taddart n ibabaten.
\b
\m 
\v 12 \bd Arrawen n Qahat\bd* \add tuɣa aten d\add* Ɛamram, Yiṣhar, Ḥabrun d Ɛuzziyil, arebɛa \add n yeryazen\add*.
\m 
\v 13 Arrawen n Ɛamram \add tuɣa aten d\add* Harun d Musa.
\m Ittwaɛzeř Harun ḥima ad ittwaqeddes d amqeddes qaɛ, netta d arrawen nnes, i řebda, ḥima ad issbexxar zzat i wudem n SIDI, ḥima ad as isexxar u ḥima ad ibarek s Yisem nnes i řebda.
\m 
\v 14 Arrawen n Musa, aryaz n AREBBI, ttwařaɣan jar teqbič n Lawi.
\v 15 Arrawen n Musa \add tuɣa aten d\add* Jarcum d Iliɛazar.
\m 
\v 16 \add Zeg\add* warrawen n Jarcun \add tuɣa\add* Cabuwil d azeǧif.
\m 
\v 17 Mmis n Iliɛazar \add tuɣa\add* d azeǧif Raḥabya. War tuɣi ɣares ɣar Iliɛazar arrawen nneɣni. Arrawen n Raḥabya \add maca\add* \add tuɣa aten\add* deg waṭṭas.
\m 
\v 18 \add Zeg\add* warrawen n Yiṣhar \add tuɣa\add* Calumit d azeǧif.
\m 
\v 19 \add Zeg\add* warrawen n Ḥabrun \add tuɣa\add* Yariya d azeǧif, Amarya wiss tnayen, Yaḥziyil wiss ṭrata d Yaqmaɛam wiss arebɛa.
\m 
\v 20 \add Zeg\add* warrawen n Ɛuzziyil \add tuɣa\add* Mixa d azeǧif, u Yacci-Yah wiss tnayen.
\b
\m 
\v 21 \bd Arrawen n Marari\bd* \add tuɣa aten d\add* Maḥli d Muci.
\m Tarwa n Maḥli \add tuɣa aten d\add* Aliɛazar d Qis.
\v 22 Aliɛazar immut u netta war ɣares tuɣi bu warrawen maca yessis \add wah\add*. Arrawen n Qis, aytmatsen, iwyen tent \add d tamɣart\add*.
\m 
\v 23 Arrawen n Muci \add tuɣa aten d\add* Maḥli d Ɛadir d Yarimut, třata \add n yeryazen\add*.
\b
\m 
\v 24 Ina \add tuɣa aten\add* d arrawen n Lawi, \add ttwasettfen\add* ɛlaḥsab tudrin n ibabaten nsen, ɛlaḥsab izeǧifen n řaǧat, inni \add ittwazemmen\add* ɣar řeḥsab nsen s řqedd n ismawen nsen azeǧif azeǧif, inni iggin tasexxart i Taddart n SIDI, zi ɛicrin iseggʷusa sennej.
\v 25 Maɣar Dawud tuɣa inna: “SIDI, AREBBI n Israil, iwca řhudnet i řgens nnes u Netta ad izdeɣ di Urcalim i řebda.”
\v 26 \add Netta inna\add* ɛawed x Ilawiyyen: “Nitni war ḥdijen ɛad ad arbun Tazeddiɣt d marra řeqcuɛ nni dd ittasen ak-d tsexxart.”
\v 27 Minzi ɛlaḥsab awařen ineggura n Dawud, \add tuɣa\add* řqedd n warrawen n Lawi d inni \add iǧan\add* zi ɛicrin iseggʷusa sennej.
\v 28 Nitni bedden ak-d warrawen n Harun di tsexxart di Taddart n SIDI, \add ɣar uḥeṭṭu\add* x řemraḥat, x ixxamen n řexzen, x usizdeg n marra řeqcuɛ iqeddsen, x řxedmet n tsexxart di Taddart n AREBBI,
\v 29 x \add usewjed n\add* aɣrum n wescan, x waren azdad i tewhibt \add n řɣiǧet\add*, x teřfaf břa antun, x wexdim u x \add mammec ggʷin\add* arecti u x marra řqedd d řeqyas.
\v 30 Tuɣa ittxeṣṣa ad bedden \add wejden\add* di kuř tuffut ḥima ad ṣebbḥen u ad ssemɣaren SIDI, uřa ɣar tmeddit,
\v 31 uřa řami dd-yiwyen marra tiɣarṣa n wecmaḍ i SIDI, deg wussan n ssebt, deg wussan n uyur n jdid u di řeɛyudat ittwaggen, ɛlaḥsab řqedd i yeǧa di lfariḍa i d as ittřiqan, břa \add a\add*qeṭṭu zzat i wudem n SIDI.
\v 32 Ittxeṣṣa asen ad ḥḍan taweqqaft nsen i Uqiḍun n Umsagar d tweqqaft nsen i Zzawect Iqeddsen d tweqqaft \add nsen\add* ɣar uɣezdis n warrawen n Harun, aytmatsen, ɣar tsexxart n Taddart n SIDI.
\b
\b
\c 24
\s1 Tirbiɛin n ikehhanen
\m 
\v 1 Tirbiɛin n warrawen n Harun. Arrawen n Harun \add tuɣa aten d\add* Nadab, Abihu, Aliɛazar d Itamar.
\v 2 Nadab d Abihu mmuten zzat i wudem n babatsen. War ɣarsen bu warrawen. Aliɛazar d Itamar tuɣa ttsexxaren am yikehhanen.
\m 
\v 3 \add Jmiɛ\add* ak-d Ṣaduq zeg warrawen n Aliɛazar u ak-d Aximalik zeg warrawen n Itamar ibḍa i-ten Dawud ɛlaḥsab taweqqaft nsen i tsexxart nsen.
\v 4 Ufin aqa ɣar warrawen n Aliɛazar aṭṭas n izeǧifen x \add izeǧifen\add* \add nni iǧan\add* ɣar warrawen n Itamar. Bḍan ten \add amenni\add*: jar warrawen n Iliɛazar \add tuɣa din\add* seṭṭac n izeǧifen i tudrin n ibabaten \add nsen\add* u jar warrawen n Itamar \add tuɣa din\add* tmenya \add n izeǧifen\add* i tudrin n ibabaten nsen.
\v 5 Nitni bḍan ten s tqedduḥt, am yina am yinni, maɣar imeqqranen n Zzawect Iqeddsen, imeqqranen n AREBBI, \add tuɣa aten\add* zeg warrawen n Aliɛazar u zeg warrawen n Itamar.
\m 
\v 6 Camɛiya, mmis n Natanyil, \add wenni tuɣa\add* d amarir zi \add teqbič\add* n Lawi, izemmen i-ten zzat i wudem n ujeǧid d řḥukkam d ukehhan Ṣaduq, d Aximalik, mmis n Abyatar, u zzat i wudem n izeǧifen n řaǧat jar ikehhanen u jar Ilawiyyen. Ggin \add taqedduḥt\add* i yijj n řaǧ n Aliɛazar, \add xenni\add* i \add yijj n řaǧ\add* n Itamar.
\b
\m 
\v 7 Taqedduḥt tamezwarut tekkar as-dd
\m i Yahuyarib,
\m wiss tnayen i Yadaɛya,
\m 
\v 8 wiss třata i Ḥarim,
\m wiss arebɛa i Saɛurim,
\m 
\v 9 wiss xemsa i Malkiya,
\m wiss setta i Miyamin,
\m 
\v 10 wiss sebɛa i Haqquṣ,
\m wiss tmenya i Abiya,
\m 
\v 11 wiss tesɛa i Yecuɛa,
\m wiss ɛecra i Cakanya,
\m 
\v 12 wiss ḥitac i Ilyacib,
\m wiss tenɛac i Yaqim,
\m 
\v 13 wiss třeṭṭac i Ḥuffa,
\m wiss arbeɛṭac i Yacabad,
\m 
\v 14 wiss xemmesṭac i Bilja,
\m wiss seṭṭac i Immir,
\m 
\v 15 wiss sbeɛṭac i Ḥizir,
\m wiss tmenṭac i Ḥafṣiṣ,
\m 
\v 16 wiss tseɛṭac i Faqaḥya,
\m wiss ɛicrin i Yaḥazqiyil,
\m 
\v 17 wiss waḥit u-ɛicrin i Yaxin,
\m wiss tnayen u-ɛicrin i Jamul,
\m 
\v 18 wiss třata u-ɛicrin i Dalaya,
\m wiss arebɛa u-ɛicrin i Maɛazya.
\b
\m 
\v 19 Ina tuɣa xasen taweqqaft maḥend ad adfen ɣar Taddart n SIDI ɛlaḥsab \add asettef n\add* tsexxart nsen am mammec lfariḍa \add i dd-yusin\add* s ufus n babatsen Harun am mammec d as yumur SIDI, AREBBI n Israil.
\b
\s1 Řaǧ n Ilawiyyen
\m 
\v 20 Zi jjihet \add n usettef\add* n min iqqimen n warrawen n Lawi:
\m Cubayil \add tuɣa d azeǧif\add* i warrawen n Ɛamram,
\m Yaḥadya \add tuɣa d azeǧif\add* i warrawen n Cubayil.
\m 
\v 21 X Raḥabya: x warrawen n Raḥabya \add tuɣa\add* Yacci-Yah d azeǧif.
\m 
\v 22 X \add warrawen\add* n Yiṣhar \add tuɣa\add* Calumit \add d azeǧif\add*.
\m X warrawen n Calumit \add tuɣa\add* Yahat \add d azeǧif\add*.
\m 
\v 23 U \add x\add* warrawen \add n Ḥabrun\add* \add tuɣa\add* Yariya \add d azeǧif\add*, Amarya \add tuɣa-t\add* d wiss tnayen, Yaḥziyil d wiss třata, Yaqmaɛam dd wiss arebɛa.
\m 
\v 24 \add X\add* warrawen n Ɛuzziyil \add tuɣa\add* Mixa \add d azeǧif\add*.
\m X warrawen n Mixa \add tuɣa\add* Camir \add d azeǧif\add*.
\m 
\v 25 Umas n Mixa \add tuɣa\add* d Yacci-Yah. X warrawen n Yacci-Yah \add tuɣa\add* Zakariyya \add d azeǧif\add*.
\m 
\v 26 Arrawen n Marari \add tuɣa aten d\add* Maḥli d Muci. X warrawen n Yaɛazya \add tuɣa\add* Banu \add d azeǧif\add*.
\m 
\v 27 Arrawen n Marari s Yaɛazya \add tuɣa aten d\add* Banu d Cuham d Zakkur d Ɛibri.
\m 
\v 28 I Maḥli \add tuɣa\add* Aliɛazar \add d mmis\add*. Wanita tuɣa war ɣares bu warrawen.
\m 
\v 29 X Qis: arrawen n Qis: \add mɣir\add* Yarḥamyil.
\m 
\v 30 Arrawen n Muci \add tuɣa aten d\add* Maḥli, Ɛadir d Yarimut.
\b
\m Ina \add tuɣa aten d\add* arrawen n Lawi, \add ttwasettfen\add* ɛlaḥsab řaǧat n ibabaten nsen.
\m 
\v 31 Uřa d nitni nḍaren tiqedduḥin am yaytmatsen, arrawen n Harun, zzat i wudem n ujeǧid Dawud d Ṣaduq d Aximalik d izeǧifen x ibabaten \add n řaǧat\add* n ikehhanen u x Ilawiyyen, am yibabaten \add nni iǧan\add* d azeǧif am umatsen d amaẓuẓ.
\b
\b
\c 25
\s1 Imedyazen
\m 
\v 1 Zeg warrawen n Asaf d Hayman d Yadutun iɛzeř Dawud ak-d ikumandaren n řɛeskar \add iryazen\add* i tsexxart nni ittnebban s řgambriyat d lharpat d taǧunin n wuzzař. Řqedd n yeryazen i iggin řxedmet n tsexxart nsen \add tuɣa-t d wa\add*:
\b
\m 
\v 2 \bd I warrawen n Asaf\bd*: Zakkur, Yusuf, Natanya d Acriyil, \add nitni d\add* arrawen n Asaf. Tuɣa-ten sadu ufus n Asaf. Netta tuɣa ittnebba x iceyyaren n ujeǧid.
\m 
\v 3 I Yadutun: \bd arrawen n Yadutun\bd* \add tuɣa aten d\add* Jadalya, Ṣari, Icaɛya, Ḥacabya d Mattitya, setta \add n warrawen\add*. Tuɣa-ten sadu ufus n babatsen Yadutun, wenni tuɣa ittnebban \add am ittirar\add* x řgambri, am ittqada d issemɣara SIDI.
\m 
\v 4 I Himan: \bd arrawen n Hayman\bd* \add tuɣa aten d\add* Buqqiya, Mattanya, Ɛuzziyil, Cabuwil, Yarimut, Ḥananya, Ḥanani, Iliyata, Jiddalti, Rumamti-Ɛazar, Yucbaqaca, Malluti, Hutir \add d\add* Maḥziyut.
\v 5 Nitni marra \add tuɣa aten d\add* arrawen n Hayman, amwařaw n ujeǧid s řefhamet n wawařen n AREBBI, ḥima ad ssgeɛɛden icc \add nnes\add*, \add minzi i uya\add* yarzef AREBBI i Hayman arbeɛṭac n warrawen d třata n tḥenjirin.
\m 
\v 6 Marra ina \add tuɣa aten\add* sadu ufus n babatsen, \add n\add* Asaf, Yadutun d Hayman, maḥend ad ɣennjen izřan di Taddart n SIDI s taǧunin n wuzzař d lharpat d řgambriyat i tsexxart di Taddart n AREBBI sadu ufus n ujeǧid.
\v 7 Řqedd nsen, \add jmiɛ\add* ak-d aytmatsen, inni tuɣa ittwassřemden deg izřan i SIDI, \add řqedd n\add* marra inni ɣarsen tizemmar \add di man aya\add*, tuɣa-t mitayen u-tmenya u-tmanyin.
\m 
\v 8 Nitni nḍaren tiqedduḥin i tɛessast, am umeẓyan am umeqqran, am umseřmad am umeḥḍar.
\b
\m 
\v 9 Taqedduḥt tamezwarut tekkar as-dd i Yusuf.
\m Wiss tnayen i Jadalya. Netta d aytmas d warrawen nnes, tenɛac \add n yeryazen\add*.
\m 
\v 10 Wiss třata \add tekkar as-dd\add* i Zakkur, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 11 Wiss arebɛa \add tekkar as-dd\add* i Yaṣri, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 12 Wiss xemsa \add tekkar as-dd\add* i Natanya, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 13 Wiss setta \add tekkar as-dd\add* i Buqqiya, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 14 Wiss sebɛa \add tekkar as-dd\add* i Yacaryila, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 15 Wiss tmenya \add tekkar as-dd\add* i Icaɛya, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 16 Wiss tesɛa \add tekkar as-dd\add* i Mattanya, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 17 Wiss ɛecra \add tekkar as-dd\add* i Cimɛi, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 18 Wiss ḥiṭac \add tekkar as-dd\add* i Ɛazaryil, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 19 Wiss tenɛac \add tekkar as-dd\add* i Hacabya, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 20 Wiss třeṭṭac \add tekkar as-dd\add* i Cubayil, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 21 Wiss arbeɛṭac \add tekkar as-dd\add* i Mattitya. \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 22 Wiss xemmesṭac \add tekkar as-dd\add* i Yarimut, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 23 Wiss seṭṭac \add tekkar as-dd\add* i Ḥanan-Yah, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 24 Wiss sbeɛṭac \add tekkar as-dd\add* i Yacbaqaca, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 25 Wis tmenṭac \add tekkar as-dd\add* i Ḥanani, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 26 Wiss tseɛṭac \add tekkar as-dd\add* i Malluti, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 27 Wiss ɛicrin \add tekkar as-dd\add* i Iliyata, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 28 Wiss waḥit u-ɛicrin \add tekkar as-dd\add* i Hutir, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 29 Wiss tnayen u-ɛicrin \add tekkar as-dd\add* i Jiddalti, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 30 Wiss třata u-ɛicrin \add tekkar as-dd\add* i Maḥziyut, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\m 
\v 31 Wiss arebɛa u-ɛicrin \add tekkar as-dd\add* i Rumamti-Ɛazar, \add netta ak-d\add* warrawen nnes d aytmas, tenɛac \add n yeryazen\add*.
\b
\b
\c 26
\s1 Iɛessasen n tewwart, iweqqafen n řeknuz, imeḥḍayen d řquḍat
\m 
\v 1 Tirbiɛin n \bd iɛessasen n tewwura:\bd*
\b
\m \bd N Iquraḥiyyen:\bd* Macalamya, mmis n Quri, zeg warrawen n A\add biya\add*saf.
\b
\m 
\v 2 Macalamya tuɣa ɣares warrawen:
\m Zakariyya \add tuɣa-t d\add* amenzu,
\m Yadiɛil wiss tnayen,
\m Zabadya wiss třata,
\m Yatniyil wiss arebɛa,
\m 
\v 3 Ɛilam wiss xemsa,
\m Yuḥanan wiss setta,
\m Ilyuɛinay wiss sebɛa.
\b
\m 
\v 4 Uřa \bd Ɛubid-Idum\bd* tuɣa ɣares warrawen:
\m Camɛiya \add tuɣa-t d\add* amenzu,
\m Yahuzabad wiss tnayen,
\m Yuwax wiss třata,
\m Sakar wiss arebɛa,
\m Natanayil wiss xemsa,
\m 
\v 5 Ɛamiyil wiss setta,
\m Issakar wiss sebɛa,
\m Faɛaltay wiss tmenya,
\m maɣar ibarek i-t AREBBI.
\b
\m 
\v 6 Uřa i mmis Camɛiya ttwaxeřqen as-dd warrawen. \add Nitni tuɣa aten d\add* řḥukkam di taddart n babatsen, minzi nitni \add tuɣa aten d\add* ayt n bu-teɣruḍt imeḥḍen.
\v 7 Arrawen n Camɛiya \add tuɣa aten\add*: Ɛutni, Rafayil, Ɛubid, Ilzabad \add ak-d\add* aytmas, iryazen imeḥḍen: Ilihu d Camakya.
\b
\m 
\v 8 Ina marra \add tuɣa aten\add* zeg warrawen n Ɛubid-Idum, nitni d warrawen nsen d wawmaten nsen, iryazen imeḥḍen, \add ccuren\add* s jjehd i tsexxart nsen, tnayen u-settin \add n yeryazen\add* n Ɛubid-Idum.
\b
\m 
\v 9 Macalamya \add tuɣa\add* ɣares warrawen d wawmaten, iryazen imeḥḍen, tmenṭac \add n yeryazen\add*.
\b
\m 
\v 10 Ḥusa, \bd zeg warrawen n Marari\bd*, \add tuɣa\add* ɣares warrawen-a:
\m Cimri \add tuɣa\add* d azeǧif, waxxa netta war iǧi d amenzu, \add maca\add* babas igga i-t d azeǧif.
\m 
\v 11 Ḥilqiya \add tuɣa-t d\add* wiss tnayen,
\m Tabalya wiss třata,
\m Zakariyya wiss arebɛa.
\m Marra arrawen d wawmaten n Ḥusa \add tuɣa aten di\add* třeṭṭac \add n yeryazen\add*.
\b
\m 
\v 12 X terbiɛin-a n iɛessasen n tewwura, x izeǧifen n ayt n bu-teɣruḍt, tuɣa ccɣeř n tsexxart di Taddart n SIDI, jmiɛ ak-d aytmatsen.
\m 
\v 13 Nitni nḍaren taqedduḥt, am umeẓyan am umeqqran, i tudrin n ibabaten nsen, i tewwart u i tewwart \add nneɣni\add*.
\m 
\v 14 Taqedduḥt i \add tɛessast n\add* ccarq tekkar as-dd i Calamya.
\m Uřa i mmis Zakariyya, wenni d amcawar s řeɛqeř, tewḍa \add as-dd\add* taqedduḥt u taqedduḥt nnes tekkar \add as-dd\add* i ccamal.
\m 
\v 15 I Ɛubid-Idum \add tekkar as-dd tqedduḥt\add* i ljanub u i warrawen nnes i taddart n ixxamen n řexzen. \f ◼ \fr 26:15 \fk řehrit\ft - niɣ ‘ixxamen n uxemmeř’.\f*
\m 
\v 16 I Cuffim d Ḥusa \add tekkar asen-dd tqedduḥt\add* i lɣarb, ak-d tewwart n Calakat ɣar webrid ameqqran igeɛɛden \add ɣar Zzawect Tameqqrant\add*. Ijj n uɛessas \add tuɣa ibedd\add* ɣar \add ijj n\add* uɛessas \add nneɣni\add*.
\m 
\v 17 Ɣar manis i dd-tneqqar tfuct \add bedden\add* setta n Ilawiyyen u ɣar ccamal \add bedden din\add* kuř ass arebɛa. Ɣar ljanub \add ɛawed\add* kuř ass arebɛa u ɣar ixxamen n řexzen tnayen \add u ɛawed\add* tnayen.
\v 18 Ɣar řebni n uɣezdis n lɣarb \add n Zzawect Tameqqrant\add* arebɛa ɣar webrid ameqqran u tnayen ɣar řebni n uɣezdis.
\m 
\v 19 Tina \add tuɣa\add* d tirbiɛin n iɛessasen n tewwura zeg warrawen n Quraḥ u zeg warrawen n Marari.
\b
\m 
\v 20 \bd Aytmatsen Ilawiyyen \bdit tuɣa aten\bdit* x ixxamen n txubay\bd* n Taddart n AREBBI u x ixxamen n txubay n tewhibin ittwaqeddsen.
\m 
\v 21 Arrawen n Laɛdan, arrawen n Ujarcuni \add nni tuɣa\add* ɣar Laɛdan, \add ixs ad yini\add* izeǧifen n ibabaten \add n řaǧat\add* n Laɛdan, Ajarcuni: Jaḥiyili \add waha\add*.
\m 
\v 22 Iḥenjiren n Yaḥyili \add tuɣa aten d\add* Zitam d Yuwil, umas. Nitni \add tuɣa aten\add* x ixxamen n txubay n Taddart n SIDI.
\m 
\v 23 N Ɛamramiyyen, d Iyiṣhariyyen, d Iḥabruniyyen, d Iɛaziyiliyyen
\v 24 \add tuɣa\add* Cabuwil, mmis n Jarcum, mmis n Musa, d ameḥḍayi x ixxamen n txubay.
\m 
\v 25 Aytmas \add zi jjadira\add* n Iliɛazar \add tuɣa aten d\add* mmis Raḥabya, mmis Icaɛya, mmis Yuram, mmis Zikri \add d\add* mmis Calumit.
\v 26 Calumit wanita d aytmas \add tuɣa aten\add* x ixxamen n txubay n tewhibin ittwaqeddsen, tinni issqeddes i-tent ujeǧid Dawud ak-d izeǧifen x ibabaten \add n řaǧat\add* u ak-d imeqqranen x wařef d x mya, u ak-d ikumandaren n řɛeskar.
\v 27 Nitni tuɣa ssqeddsen \add tiwhibin nni\add* zi garrat u zi tkeccaḍt, ḥima ad zzaysent ɛedřen Taddart n SIDI.
\v 28 \add Ɛawed\add* marra min tuɣa issqeddes i-t umwařaw Camwil, d Cawul, mmis n Qis, d Abnir, mmis n Nir, d Yuwab, mmis n Ṣaraya. Marra min tuɣa ittwaqeddsen \add tuɣa\add* sadu afus n Calumit d aytmas.
\b
\m 
\v 29 Zeg Iyiṣhariyyen \add tuɣa\add* Kananya d warrawen nnes xeddmen am \bd imeḥḍayen d řquḍat\bd* barra di \add temmurt n\add* Israil.
\m 
\v 30 Zeg Iḥabruniyyen \add tuɣa\add* taweqqaft x Israil ɣar Ḥacabya d aytmas, iryazen imeḥḍen, ařef u-sebɛa-mya \add n yeryazen\add*, x ujemmaḍ n L’Urdun ɣar lɣarb, \add tuɣa aten\add* x marra řxedmet i SIDI u x tsexxart i ujeǧid.
\v 31 I Iḥabruniyyen \add tuɣa\add* Yariya d azeǧif, i Iḥabruniyyen, i jjiřat nnes, jar ibabaten \add n řaǧat\add*. Deg useggʷas wiss arebɛin n tgelda n Dawud ttwarzun u ttwafen ayt n bu-teɣruḍt imeḥḍen di Yaɛzir di Jilɛad.
\v 32 Aytmas \add tuɣa aten d\add* iryazen imeḥḍen, ařfayen u-sebɛa-mya n izeǧifen x ibabaten \add n řaǧat\add*. Ajeǧid Dawud igga ten x ayt n Rubin, x ayt n Jad u x wezyen n teqbič n Manassa, x marra timesřayin n AREBBI u \add x marra\add* timesřayin n ujeǧid.
\b
\b
\c 27
\s1 Ikumandaren n řɛeskar
\m 
\v 1 Ina d ayt n Israil ak-d řqedd nsen, izeǧifen x ibabaten \add n řaǧat\add*, uřa d imeqqranen x wařef u x mya ak-d imeḥḍayen nsen, inni tuɣa ittsexxaren i ujeǧid di marra timesřayin n terbiɛin, \add am\add* zi jjihet n man wen i dd-ittasen, \add am\add* zi jjihet n man wen ittraḥen, u \add man aya\add* zeg uyur ař uyur \add nneɣni\add* di marra iyuren n useggʷas. Ict n terbiɛt \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\m 
\v 2 Yasubɛam, mmis n Zabdiyil, \add tuɣa\add* x terbiɛt tamezwarut \bd i uyur wiss amezwaru\bd*. Tarbiɛt nnes \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\m 
\v 3 \add Netta tuɣa\add* zeg warrawen n Fariṣ. \add Netta\add* d akumandar ameqqran x marra ikumandaren n řɛeskarat deg uyur amezwaru.
\m 
\v 4 Duday, Axuxi, \add tuɣa\add* x terbiɛt \bd n uyur wiss tnayen\bd*. Miqlut d ameḥḍay n terbiɛt nnes. Tarbiɛt nnes \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\m 
\v 5 Banaya, mmis n Yahuyadaɛ, akehhan ameqqran tuɣa d akumandar wiss třata n řɛeskar \bd i uyur wiss třata\bd*. Tarbiɛt nnes \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\m 
\v 6 Banaya wa \add tuɣa\add* d bu-teɣruḍt n třatin u netta \add tuɣa\add* x třatin. Mmis Ɛammizabad \add tuɣa\add* x terbiɛt nnes.
\m 
\v 7 Ɛasa’il, mmis n Yuwab, d wiss arebɛa \bd i uyur wiss arebɛa\bd* u mmis Zabadya \add tuɣa\add* awarni as. Tarbiɛt nnes \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\m 
\v 8 Camḥut, Ayazraḥi, akumandar, \add tuɣa\add* x \add terbiɛt\add* wiss xemsa \bd i uyur wiss xemsa\bd*. Tarbiɛt nnes \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\m 
\v 9 Ɛira, mmis n Ɛiqqis, Atiqquɛi, \add tuɣa\add* d wiss setta \bd i uyur wiss setta\bd*. Tarbiɛt nnes \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\m 
\v 10 Ḥaliṣ, Afalituni, zeg warrawen n Ifrayim, \add tuɣa\add* d wiss sebɛa \bd i uyur wiss sebɛa\bd*. Tarbiɛt nnes \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\m 
\v 11 Sibkay, Aḥucati, n Izaraḥiyyen, \add tuɣa\add* d wiss tmenya \bd i uyur wiss tmenya\bd*. Tarbiɛt nnes \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\m 
\v 12 Abiɛazar, Aɛanatuti, n ayt n Binyamin, \add tuɣa\add* d wiss tesɛa \bd i uyur wiss tesɛa\bd*. Tarbiɛt nnes \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\m 
\v 13 Maharay, Anaṭufati, i Izaraḥiyyen, \add tuɣa\add* d wiss ɛecra \bd i uyur wiss ɛecra\bd*. Tarbiɛt nnes \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\m 
\v 14 Banaya, Afarɛatuni, zeg warrawen n Ifrayim, \add tuɣa\add* d wiss ḥiṭac \bd i uyur wiss ḥiṭac\bd*. Tarbiɛt nnes \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\m 
\v 15 Xalday, Anaṭufati, \add i dd-iqqarṣen\add* zi Ɛutniyil, \add tuɣa\add* d wiss tenɛac \bd i uyur tenɛac\bd*. Tarbiɛt nnes \add dayes\add* arebɛa u-ɛicrin-ařef \add n yeryazen\add*.
\b
\s1 Imeqqranen n tqebbař
\m 
\v 16 \add Ina bedden\add* x tqebbař n Israil:
\m \bd I Irubiniyyen\bd* \add tuɣa\add* Iliɛazar, mmis n Zikri, d řḥakem.
\m \bd I Icamɛuniyyen:\bd* Cafaṭya, mmis n Maɛka.
\m 
\v 17 \bd I Lawi:\bd* Ḥacabya, mmis n Qamuwil.
\m \bd I Harun:\bd* Ṣaduq.
\m 
\v 18 \bd I Yahuda:\bd* Ilihu, zeg aytmas n Dawud.
\m \bd I Issakar:\bd* Ɛumri, mmis n Mixayil.
\m 
\v 19 \bd I Zabulun:\bd* Yicmaɛya, mmis n Ɛubadya.
\m \bd I Naftali:\bd* Yarimut, mmis n Ɛazaryil.
\m 
\v 20 \bd I warrawen n Ifrayim:\bd* Ḥuciɛa, mmis n Ɛazarya.
\m \bd I wezyen n teqbič n Manassa:\bd* Yuwil, mmis n Fadaya.
\m 
\v 21 \bd I wezyen n teqbič n Manassa di Jilɛad:\bd* Jaddu, mmis n Zakariyya.
\m \bd I Binyamin:\bd* Yaɛisiyil, mmis n Abnir.
\m 
\v 22 \bd I Dan:\bd* Ɛazaryil, mmis n Yaruḥam.
\b
\m Ina tuɣa d řḥukkam n tqebbař n Israil.
\m 
\v 23 Dawud war iksi ca řqedd n yinni ɣar iǧa ɛicrin n iseggʷusa d swadday, maɣar SIDI tuɣa inna aqa Netta ad yarr Israil deg waṭṭas am yitran n ujenna.
\v 24 Yuwab, mmis n Ṣaruya, tuɣa ibda ad iḥseb \add řgens\add*, maca war t ikemmeř umi dd-yusa uduqqez d ameqqran n weɣḍab x Israil. S uyenni war ittwagg řqedd deg wedlis n imezruyen n ujeǧid Dawud.
\b
\s1 Iwkiřen n ujeǧid
\m 
\v 25 \bd Ɛazmawet, mmis n Ɛadiyil\bd*, \add tuɣa\add* x ixxamen n txubay n ujeǧid.
\m \bd Yunatan, mmis n Ɛuzziya\bd*, \add tuɣa\add* x ixxamen n txubay n temmurt, di tneddam, di dcurat u di lburjat.
\m 
\v 26 \bd Ɛazri, mmis n Kalub\bd*, \add tuɣa iṭṭef acbar\add* x mammec ggin řxedmet deg iyyar ḥima ad carzen acař.
\m 
\v 27 \bd Cimɛi, Aramati\bd*, \add tuɣa iṭṭef acbar\add* x imarjaɛen n uḍiř.
\m \bd Zabdi, Acifmi\bd*, \add tuɣa\add* x zzad n binu \add nni iǧan\add* deg imarjaɛen n uḍiř.
\m 
\v 28 \bd Baɛl-Ḥanan, Ajadiri\bd*, \add tuɣa iṭṭef acbar\add* x iḥwicen n zzitun u x izemmuren nni \add iǧan\add* di Temmurt Iwaṭan.
\m \bd Yuwac\bd* \add tuɣa\add* x zzad n zzect.
\m 
\v 29 \bd Ciṭray, Acaruni\bd*, \add tuɣa iṭṭef acbar\add* x ifunasen d tfunasin, inni ihedda di řewḍa n Carun.
\m \bd Cafat, mmis n Ɛalay\bd*, \add tuɣa\add* x ifunasen d tfunasin di řewḍat n teɣzurt.
\m 
\v 30 \bd Ubil, Asmaɛili\bd*, \add tuɣa iṭṭef acbar\add* x iřeɣman.
\m \bd Yaḥadya, Amirunuti\bd*, \add tuɣa\add* x tiɣyař.
\m 
\v 31 \bd Yaziz, Ahajri\bd*, \add tuɣa iṭṭef acbar\add* x wuǧi.
\m Nitni marra tuɣa aten d imeḥḍayen x wagřa nni \add iǧan\add* n ujeǧid Dawud.
\m 
\v 32 \bd Yunatan, ɛemmis n Dawud\bd*, \add tuɣa\add* d amcawar, ijj n bnadem d amiɣis. Netta tuɣa ɛawed d amarir.
\m \bd Yaḥiyil, mmis n Ḥakmuni\bd*, \add tuɣa\add* ɣar warrawen n ujeǧid, \add yarebba i-ten\add*.
\m 
\v 33 \bd Axitufil\bd* \add tuɣa\add* d amcawar n ujeǧid,
\m u \bd Ḥucay, Ayarki\bd*, \add tuɣa\add* d ameddukkeř n ujeǧid.
\m 
\v 34 \bd Yahuyadaɛ, mmis n Banaya, d Abyatar\bd* \add tuɣa aten\add* awarni i Axitufil.
\m \bd Yu’ab\bd* \add tuɣa-t d\add* akumandar n řɛeskar n ujeǧid.
\b
\b
\c 28
\s1 Dawud igga x Suliman maḥend ad ibna Zzawect Tameqqrant
\m 
\v 1 Dawud issmun di Urcalim marra imeqqranen n Israil: imeqqranen n tqebbař d imeqqranen n terbiɛin d imsexxaren n ujeǧid d imeqqranen x wařef d imeqqranen x mya d imeqqranen \add i iǧan\add* x marra agřa d řkesbet n řmař n ujeǧid d warrawen nnes, \add jmiɛ\add* ak-d imsexxaren icennɛen d ayt n bu-teɣruḍt, \add wah,\add* kuř bu-teɣruḍt imeḥḍen.
\m 
\v 2 Ikkar ujeǧid Dawud, inna: “Sřem-dd ɣari, aytma d řgens inu! Necc simant inu tuɣa-t ɣari deg wuř inu ḥima ad bniɣ ict n Taddart n arraḥet i Ttabut n Řɛahd n SIDI u i tnebdat n iḍaren n AREBBI nneɣ. \add X uyenni\add* sswejdeɣ i řebni.
\v 3 Maca AREBBI inna ayi: ‘Cek war tbennid i Yisem inu Taddart, maɣar cek d ijj n weryaz n imenɣan u tessizřed aṭṭas n idammen.’
\v 4 SIDI, AREBBI n Israil, ifarz ayi zi marra taddart n baba, ḥima ad dewřeɣ d ajeǧid x Israil i řebda, minzi Netta ifarz Yahuda ḥima ad yiři d řḥakem, uca \add xenni\add* taddart n baba zi taddart n Yahuda, uca jar warrawen n baba yarḍa dayi ařami igga ayi d ajeǧid x marra Israil.
\v 5 Zi jar marra arrawen inu - maɣar SIDI iwca ayi aṭṭas n warrawen - ifarz Netta mmi Suliman, ḥima ad iqqim x řɛarc n tgelda n SIDI x Israil.
\v 6 Netta inna ayi: ‘Mmic Suliman ad ibna Taddart inu d řemraḥat inu, maɣar netta i farzeɣ d mmi u Necc ad as iřiɣ d babas.
\v 7 Necc ad ssmetneɣ tageldit nnes i řebda mařa netta ad iḍfar tiweṣṣa d lfarayiḍ inu s jjehd, am mammec teǧa ass-a.’
\v 8 Xenni řexxu, \add ad awem ɛeřmeɣ\add* zzat i tiṭṭawin n marra Israil, agraw \add n řgens\add* n SIDI, u deg imezzuɣen n AREBBI nneɣ, ḥima ad teḥḍam u ad tarzum marra tiweṣṣa n SIDI, AREBBI nwem, maḥend ad teqqimem tᵉttᵉṭṭfem tammurt taṣebḥant tanita d řwart, uca ad tt tejjem d řwart i řebda i warrawen nwem awarni awem.
\v 9 U cek, mmi Suliman, ssen AREBBI n babac u sexxar as s wuř imun d s řeɛmar iwejden minzi SIDI ittbeqqec marra uřawen uca ifehhem marra min dd-ittasen ɣar ixarriṣen \add n uzeǧif nneɣ\add*. Mařa cek tarzud xas, Netta ad zzayek ittwaf, maca mařa tsemḥed dayes, ad cek inḍar i řebda.
\v 10 Xzar řexxu, minzi SIDI ifarz i cek ḥima ad as tebnid ict n Taddart d Zzawect Iqeddsen. Iři d aryaz uca egg i-t!”
\m 
\v 11 Dawud iwca i mmis Suliman amedya n wesqif n wadaf, n řebniyat nnes, d ixxamen n txubay d tɣurfatin nnes, d ixxamen nnes n daxeř, d wexxam i tqebbart n weṣřaḥ,
\v 12 uřa d ijj n umedya n marra min ɣares-dd yusa s Arruḥ x řemraḥat n Taddart n SIDI, x marra ixxamen i d as dd-innḍen, x marra ixxamen n txubay n Taddart n AREBBI u x ixxamen n txubay n tewhibin ittwaqeddsen,
\v 13 x terbiɛin n ikehhanen d Ilawiyyen, x marra řxedmet i tsexxart di Taddart n SIDI u x marra řeqcuɛ i tsexxart di Taddart n SIDI.
\v 14 X wureɣ, aqa iwca řewzen n wureɣ i marra řeqcuɛ n tsexxart, uřa i řeqcuɛ n nnuqart \add iwca\add* řewzen \add nsen\add*, i marra řeqcuɛ i kuř tasexxart.
\v 15 \add Iwca uřa\add* řewzen i řeqnadeř n wureɣ d řefnarat nsen n wureɣ, řewzen n kuř řqendiř ak-d řefnarat nnes \add weḥḥdes\add*, uřa \add řewzen\add* i řeqnadeř n nnuqart, řewzen i yijj n řqendiř ak-d řefnarat nnes \add weḥḥdes\add*, am mammec dd-yusa ak-d tsexxart n kuř řqendiř.
\v 16 \add Ɛawed\add* řewzen n wureɣ i ṭṭabřat i x bezzɛen aɣrum, i kuř ṭṭabřa \add řewzen nnes weḥḥdes\add*, uřa d \add řewzen n\add* nnuqart i ṭṭabřat n nnuqart,
\v 17 uřa d ureɣ iṣfan i furcayat, i ṭṭawyat i urucci, i ifenjařen n wureɣ ak-d řewzen n kuř afenjař \add weḥḥdes\add*, i ifenjařen n nnuqart ak-d řewzen i kuř afenjař \add weḥḥdes\add*,
\v 18 i uɛalṭar n řebxur ak-d řewzen \add nnes\add* s wureɣ iqqur, uřa \add ammu ɛawed řewzen n\add* wureɣ i umedya n ukarru \add n ijenwan\add* n ikiruben inni ibezzɛen \add wafriwen nsen\add* uca dřin Ttabut n Řɛahd n SIDI. \f ◼ \fr 28:18 \fk ikiruben\ft - ict n marka n lmalakat.\f*
\m 
\v 19 Man aya marra, \add inna Dawud\add*, ittwassefhem ayi s tira zeg ufus n SIDI, marra řexdayem \add i dd ittasen ak-d\add* umedya n řebni, aqa yurant di tira-ya.
\m 
\v 20 Xenni inna Dawud i mmis Suliman: “Iři d aryaz, iři tmeḥḍed u egg i-t! War tteggʷed ca u war arexxu, maɣar SIDI AREBBI, AREBBI inu, ad yiři akidek. Netta war dayek isemmeḥ niɣ cek ittejji ař akemmeř n marra řxedmet i tsexxart di Taddart n SIDI.
\v 21 Xzar, aqa din tirbiɛin n ikehhanen d Ilawiyyen i marra tasexxart di Taddart n AREBBI u i marra řxedmet \add aqa din\add* ɣarek marra inni i ɣar teǧa di řxadar nsen \add ḥima ad tt ggen\add* s tiɣit i kuř řxedmet. Uřa d řḥukkam d marra řgens \add bedden akidek,\add* ḥima \add ad ggen\add* marra awařen nnec.”
\b
\b
\c 29
\s1 Dawud isellem řebni n Zzawect Tameqqrant d řɛarc i mmis Suliman
\m 
\v 1 Uca inna ujeǧid Dawud i marra agraw \add n řgens\add*: “Mmi Suliman d ayenni wenni ifarz i-t AREBBI. Netta \add ɛad\add* d aḥudri d arexfen uca řxedmet d tameqqrant, maɣar war iǧi řeqṣar i yijj n bnadem, maca i SIDI AREBBI.
\v 2 S marra tizemmar inu sswejdeɣ i Taddart n AREBBI inu ureɣ i \add řeqcuɛ\add* n wureɣ, nnuqart i \add řeqcuɛ\add* n nnuqart, nnḥas i \add řeqcuɛ\add* n nnḥas, uzzař i \add řeqcuɛ\add* n wuzzař, akeccuḍ i \add řeqcuɛ\add* n ukeccuḍ, d iẓra n uniks d iẓra ibarcanen yareqqen uřa d iẓra ittwassqareqcen maḥend ad ttwaggen di tcuyar, uřa \add ɛad\add* ɛřam kuř iẓra iɣřan \add nneɣni\add*, uca \add xenni\add* aṭṭas n iẓra n řmarmur d acemřař.
\v 3 Zi tayri inu i Taddart n AREBBI inu, ad arzfeɣ zeg wagřa inu ɛad ureɣ d nnuqart tiwa i min sswejdeɣ i Taddart n Zzawect Iqeddsen,
\v 4 \add ɛad\add* teřt-ařaf talint n wureɣ zeg wureɣ n Ufir d sebɛa-ařaf talint n nnuqart iṣfan maḥend ad zzaysen ḥenncen řeḥyuḍ n ixxamen.
\v 5 Ureɣ i \add řeqcuɛ n\add* wureɣ, nnuqart i \add řeqcuɛ n\add* nnuqart, i marra řxedmet \add i ɣa tᵉttwagg\add* s ufus n iḥrayfiyyen. Man wen \add xenni\add* iṭṭewwɛen ass-a maḥend ad iwc i SIDI?”
\m 
\v 6 \add Xas uca\add* iwyen imeqqranen x ibabaten \add n řaǧat\add* d imeqqranen n tqebbař n Israil d imeqqranen x wařef u x mya tiwhibin nsen s řxaḍar, \add jmiɛ\add* ak-d imeqqranen x řxedmet n ujeǧid.
\v 7 Nitni arzfen i tsexxart n Taddart n AREBBI xemsa-ařaf talint n wureɣ d ɛecra-ařaf n draxmat d ɛecra-ařaf talint n nnuqart d tmenṭac-ařef talint n nnḥas d myat-ařef talint n wuzzař.
\v 8 Wenni ɣar ufin iẓra \add iɣřan\add*, iwca i-ten i wexxam n txubay n Taddart n SIDI wenni tuɣa sadu ufus n Yaḥiyil, Ajarcuni.
\v 9 Ifarḥ řgens s tewhibin nsen \add i immewcen\add* s řxaḍar, maɣar nitni wcin zeg wuř imun qaɛ s řxaḍar i SIDI, uca ifarḥ ujeǧid Dawud řefraḥet d tameqqrant aṭṭas.
\v 10 Dawud ibarek SIDI zzat i tiṭṭawin n marra agraw \add n řgens\add*, inna:
\b
\m “Ad tᵉttwabarked Cek, \add a\add* SIDI, AREBBI n babatneɣ Israil, zi řebda ař řebda!
\m 
\v 11 I Cek, \add a\add* SIDI, řemɣaret d ṣṣulṭa d řɛezz d min ittduman i řebda d lɛaḍama, minzi marra min iǧan deg ujenna u x temmurt aqa-t Nnec. Zzayek, \add a\add* SIDI, \add i teǧa\add* tageldit, \add zzayek Cek,\add* Wenni issgeɛɛden Ixef nnec d Azeǧif tiwa marra.
\v 12 Agřa d ccan zzat i wudem nnec u Cek tṣeǧḍed x marra \add min iǧan\add*. Aqa-t jjehd d ṣṣulṭa deg ufus nnec, aqa-t deg ufus nnec \add ḥima ad tewced\add* řemɣaret d jjehd i marra.
\m 
\v 13 Xenni řexxu, AREBBI nneɣ, neccin nettqada Cek u nettṣebbeḥ deg Yisem n řɛezz nnec.
\v 14 Maɣar min ɛniɣ necc d min iɛna řgens inu, aqa neccin ɣarneɣ tizemmar ad newc ammu s řxaḍar? Maɣar zzayek dd-ittas marra u min i d ac newca, \add newca i-t\add* zeg ufus nnec.
\v 15 Maɣar neccin mɣir d ibarraniyyen d imeɛzab zzat i wudem nnec, am řejdud nneɣ. Ussan nneɣ x temmurt am tiři u řayas war din iǧi.
\m 
\v 16 \add A\add* SIDI, AREBBI nneɣ, zeg ufus nnec \add yusa-dd\add* marra afeyyeḍ-a i nessewjed, ḥima ad nebna ict n Taddart i Cek, i Yisem nnec iqeddsen. Marra aya d Nnec.
\v 17 Necc ssneɣ, \add a\add* AREBBI inu, aqa Cek tqeǧbed uř u aqa itteɛjib ac useggem. Necc, di řeṣfayet n wuř inu, wciɣ marra aya s řxaḍar, u řexxu aqa uřa d řgens nnec i da iǧan - iwa ẓriɣ t s řefraḥet - iwca ac \add tiwhibin\add* s řxaḍar.
\m 
\v 18 \add A\add* SIDI, AREBBI n řejdud nneɣ, \add n\add* Ibrahim d Isḥaq d Israil, ḥḍa \add xenni\add* i řebda aqa aya ad yejj ṭṭabeɛ x ixariṣṣen deg wuř n řgens nnec u ndeh uř nsen ɣarek!
\v 19 Ewc uřa i mmi Suliman ijj n wuř imun qaɛ, maḥend ad iḥḍa řumurat nnec d cchadet nnec d tiweṣṣa nnec, maḥend ad yegg marra u maḥend ad ibna řeqṣar-a \add n Zzawect Tameqqrant\add* i x sswejdeɣ necc.”
\b
\m 
\v 20 \add Xenni\add* inna Dawud i marra agraw \add n řgens\add*: “Barkem, SIDI, AREBBI nwem!” \add Xenni\add* ibarek marra agraw \add n řgens\add* SIDI, AREBBI n řejdud nsen. Nitni uḍaren, bendqen i SIDI u i ujeǧid.
\v 21 Tiwecca nnes iwyen nitni tiɣarṣa i SIDI. Nitni iwyen ařef n ifunasen imeẓyanen d ařef n icarriyyen d ařef n izmaren ak-d marra tiwhibin nsen n useyyeb d tɣarṣa n wecmaḍ i SIDI u \add xenni\add* aṭṭas n tɣarṣa i marra Israil.
\v 22 Deg wass nni ccin u swin nitni s řefraḥet tameqqrant zzat i wudem n SIDI u ggin Suliman, mmis n Dawud, d ajeǧid i twařa wiss tnayen u dehnen \add t\add* d řḥakem zzat i SIDI, u Ṣaduq \add dehnen t\add* d akehhan.
\v 23 Suliman iqqim x řɛarc n SIDI am ujeǧid deg wemcan n babas Dawud. Netta ifřeḥ u marra Israil isřa as.
\v 24 Marra řḥukkam d ayt n bu-teɣruḍt uřa d marra arrawen n ujeǧid Dawud, wtin deg ufus ad qqimen sadu \add afus n\add* ujeǧid Suliman.
\v 25 Yarra SIDI Suliman ad idweř d ameqqran ař ṭṭarf zzat i tiṭṭawin n Israil. Netta iwca as aweqqar igellden i tuɣa war iǧi uřa ɣar ijj n ujeǧid x Israil qbeř nnes.
\b
\m 
\v 26 \add Ammu\add* i iḥkem Dawud, mmis n Yassa, x marra Israil.
\v 27 Ussan nni tuɣa iḥkem x Israil, aqa aten arebɛin n iseggʷusa. Netta iḥkem di Ḥabrun sebɛa n iseggʷusa u di Urcalim třata u-třatin n iseggʷusa.
\m 
\v 28 Netta immut umi icab mliḥ, ijjiwen ussan, agřa d uɛuǧi. Mmis Suliman idweř d ajeǧid deg wemcan nnes.
\b
\m 
\v 29 Imezruyen n ujeǧid Dawud, imezwura d ineggura, aqa ttwazemmemen deg wedlis n imezruyen n umwařaw Camwil u deg wedlis n imezruyen n unabi Natan u deg wedlis n imezruyen n umwařaw Jad,
\v 30 s marra \add min yuran\add* x tgeldit nnes u x ṣṣulṭa nnes u x řmijařat n řweqt i xas dd-ikkin uřa x Israil u x marra tigeldiwin n temmura. 
