\id JER .01, Jeremiah 1, Motu, PNG, RTWP 11/92
\h IEREMIA
\toc1 IEREMIA
\toc2 IEREMIA
\mt1 IEREMIA
\c 1
\s1 Iehova ese Ieremia e boiria
\p 
\v 1 Ieremia, Hilkia natuna, hahelaḡa taudia Anatoto ai, Beniamina tanona ai, e nohova edia orea tauna ta, ena hereva.
\v 2 Iehova ena hereva na ia dekenai e kau, Iosia Amon, Iuda pavapavana, ena nega ai, ena lohia laḡanina ihagwauta-toina lalonai;
\v 3 ma e kau Iou, Iehoiakim Iosia, Iuda pavapavana, ena nega ai, ela bona Sedekia Iosia, Iuda pavapavana, ena lohia laḡanina ihagwauta-tana dokona, ela bona hua iha-imana ai Ierusalem taudia e ḡuidia.
\p 
\v 4 Iehova ena hereva na egu ai e kau, eto:
\q1 
\v 5 Sinamu bogana ai do asina hadudumu negana ai na dibamu,
\q2 bona do so vara negana ai na hahelagamu;
\q1 bona na duanaimu, peroveta tauna ai baola,
\q2 basileia idau-idau ediai.
\p 
\v 6 Bena lau nato, Ḡaubada Iehova e, a itagu, lau na asi dibagu ede baina hereva toma, badina be lau na tauhau mo.
\v 7 A Iehova ese e haere henigu, eto:
\q1 Basioto “Lau na tauhau mo”;
\q2 badina be dekediai baina siaimu taudia iboudiai ediai baola,
\q2 bona baina haḡanilai henimu herevadia ba gwaurai.
\q1 
\v 8 Idia garidia basio gari,
\q2 badina be lau na oi ida, bena baina harohomu mauri.
\q2 Iehova na e herevamu.
\p 
\v 9 Bena Iehova ese imana e toia roro, udugu e daua toho. Bena Iehova ese e hereva henigu, eto:
\q1 A itaia, egu hereva na udumu ai vada na atodia,
\q2 
\v 10 a itaia, hari dina ai vada na haginimu,
\q1 bese idau-idau bona basileia idau-idau daediai,
\q2 ba butu oho bona ba ḡiḡi dobi,
\q1 ba hahebua tari bona ba hahedarere,
\q2 ba hagini-hagini bona ba hadohado totona.
\p 
\v 11 Iehova ena hereva egu ai ma e kau, eto, Ieremia e, dahaka o itaiamu! Bena lau nato, Sakada\f + \fr 1:11 \ft “Sakada” na au huahua ta ladana, Heberu gado ai. A reḡena mia heḡereḡere herevana ta be “sokede”; ia anina be “balaia heni”.\f* auna rigina ta na itaiamu.
\v 12 Bena Iehova ese ma e hamaorogu, eto, O itaia balahenimu, badina be lau ese egu hereva na balaia henimu, anina baina karaia totona.
\p 
\v 13 Iehova ena hereva na nega iharuana ai egu ai e kau, eto, Dahaka o itaiamu? Bena lau nato, E daidaimu urona na itaiamu, bona lahi ihahemetaina na mirigini kahana ai.
\v 14 Bena Iehova ese e hamaorogu, eto, Mirigini kahana amo dika baine daidaia dobi, ina tano e noholaiamu taudia iboudiai latadiai.
\v 15 Badina be Iehova na e tomu, A itaia, mirigini kahana basileiadia besedia iboudiai na boiridiamu; bena idia na baema, ta ta ese ena terono ena terono bae haginidia, Ierusalem ikoukoudia raka-vareaidia ai, bona e haheḡeḡea daemu maḡudia iboudiai hevaira-henidia ai, bona Iuda hanuadia iboudiai hevaira-henidia ai.
\v 16 Bona egu hahemaoro herevadia na idia latadiai baina gwaurai, edia kara dika iboudiai ikaradia ai e rakatanigu dainai. Idia ese muramura mai bonadia vada e gabu, dirava idaudia ediai, bona idia sibodia imadia amo e kara ḡaudia vada e toma henidia diho.
\v 17 A oi na emu rami ba hekasilaia; ba tore isi, na haḡanilaimumu herevadia iboudiai ba hamaorolaidia. Kudoumu basine hetaha idia daidiai, lau ese idia vairadiai oi kudoumu baina hahetahaia na garina.
\v 18 A itaia, hari dina ai lau ese hanua aukana bona auri au-tubuana bona auri-laboralabora maḡudia heḡereḡeredia ai baina halaomu, tano idoinai ilodu-henina bona Iuda tanona pavapavadia bona lohiadia bona ena hahelaḡa taudia bona ena taunimanima iboudiai iloduhenidia totona.
\v 19 Idia ese bae tuari henimu; to basie hadareremu, badina be lau na oi ida, bena baina hamaurimu. Iehova na e herevamu.
\c 2
\s1 Iehova ese Israel e gwau henia
\p 
\v 1 Iehova ena hereva na egu ai e kau, eto,
\v 2 Aola, Ierusalem taudia vairatuhutuhudia ai ba hereva, baoto, Iehova ini e gwau tomamu:
\q1 Emu lalokau eregabemu negana ai
\q2 bona emu uraheni emu headava matamata negana ai
\q2 na lalo taomu;
\q1 tano ḡaḡaena ai, ḡau ta asie hadoa tanona ai,
\q2 oi ese lau murigu ai o rakava.
\q1 
\v 3 Una negana ai Israel na helaḡa Iehova ena,
\q2 ena taboro anidia roboadia.
\q1 E ani taudia iboudiai e kerere,
\q2 bena dika na latadiai e kau.
\q2 Iehova na e herevamu.
\b
\p 
\v 4 Iakob besena e, bona Israel besena iduhudia iboudiai, Iehova ena hereva a kamonai.
\v 5 Iehova ini e gwau tomamu:
\q1 Senemui ese dahaka kerere egu ai e davaria,
\q2 bena e rakatanigu, dauha ela?
\q1 Idia ese ḡau asi namodia e ḡavadia,
\q2 bena taunimanima asi namodia ai e hahelao.
\q1 
\v 6 Idia asieto, Iehova be edeseni ai?
\q2 Aigupto amo e hakauda lasi
\q1 bona tano ḡaḡaena ai e hakauda,
\q2 tano kaukauna, tano mai guridia,
\q1 ranu-mase bona dibura-masemase tanona,
\q2 ta ese se rakaia hanaimu bona ta ese se noholaiamu tanona,
\q1 Diravana be edeseni ai?
\q1 
\v 7 Lau ese aniani momo tanona lalonai na hakaumui vareai,
\q2 ena au-huahua bona ena ḡau namodia ba moalelai totona.
\q1 A umui o raka vareai negana ai egu lano o hamiroa,
\q2 bona lau ahugu emui ai na ḡau dika-rohorohona ai o halaoa.
\q1 
\v 8 Hahelaḡa taudia asieto, Iehova be edeseni ai?
\q2 Taravatu e ḡaukaralaimu taudia na asi dibadia lau;
\q1 lohia taudia na egu ai e kerereva;
\q2 peroveta taudia na Baal ladana ai e perovetava,
\q2 bona ḡau asi anidia e gavadiava.
\b
\q1 
\v 9 Taunabunai, Iehova na e tomu:
\q2 Lau na doini na habadelaimuimu,
\q2 bona garamui danu do baina habadelaidia.
\q1 
\v 10 Badina be ba hanai, Kupro kone-tanodia ai ba itaia,
\q2 eiava ba hesiai lao Kedara, ba tahua namonamo;
\q2 ba itaia, kara inihetomana nega ta ai e vara eiava.
\q1 
\v 11 Bese ta, ena be edia dirava na dia momomokakani,
\q2 to bema bolodia a?
\q1 A lauegu orea taudia ese hairaidia vada e boloa,
\q2 ḡau asi anina vada e bololaia.
\q1 
\v 12 Guba e, ina na ba dara-dokolaia,
\q2 ba lalaḡalaia, lalomui bae ḡaḡae.
\q2 Iehova na e herevamu.
\q1 
\v 13 Badina be egu orea taudia ese dika rua vada e kara:
\q2 lau, mauri ranuna helohilohina, vada e rakatanigu,
\q1 bona sibodia edia ranu guridia vada e tara,
\q2 e parara guridia, ranu na idia lalodiai basine mia.
\b
\q1 
\v 14 Israel na hesiai tauna a? Ia na hesiai iḡuidia ai e vara a?
\q2 Matona, dahaka dainai damuga ai vada ela?
\q1 
\v 15 Ieona ese vada e ḡou henia,
\q2 vada e ḡou badabada.
\q1 Ena tano vada e havahua;
\q2 ena hanua vada e heḡiḡi dobi, asi inoholaidia ta.
\q1 
\v 16 Ina danu, Memefisi bona Tapanese taudia ese
\q2 oi kwaramu tubuana vada e hapararaia.
\q1 
\v 17 Iehova, emu Dirava, ese dala ai e hakaumu negana ai o rakatania,
\q2 una dainai ina na oi sibomu latamu ai vada o hadihoa, ani?
\q1 
\v 18 Harihari Nilo sinavaina ranuna i'inuna totona Aigupto o laomu
\q2 be dahaka namona ba davaria?
\q1 Eiava Eufrate sinavaina ranuna i'inuna totona Asuna o laomu
\q2 be dahaka namona ba davaria?
\q1 
\v 19 Emu kara dika ese matamu baine hakania,
\q2 bona emu raka-muri ese baine sisiba henimu.
\q1 Ba diba bona ba itaia, Iehova, emu Dirava, irakatanina na
\q2 ḡau dikana bona iditana.
\q1 Ḡaubada Iehova Sabaota e tomu,
\q2 Lau igari-henigu na oi lalomu ai se miamu.
\b
\q1 
\v 20 Badina be idau nega ai emu maduna o hakwaidua,
\q2 bona emu iḡui o hamotu,
\q2 oto “Hesiai karadia basina kara”.
\q1 Oibe, ororo badadia iboudiai doridia ai,
\q2 bona au mauridia iboudiai henudiai,
\q2 oi o toma dihova, ariara hahinena na heto.
\q1 
\v 21 Ḡau tamona lau ese na hadomu, abi-hidi vinena,
\q2 vine korikorina uhena.
\q1 Edeheto oi na vada o vara dika,
\q2 uda vinena ai vada ola?
\q1 
\v 22 Ena be muramura amo bona sopu momo amo ba hehuri,
\q2 to emu kerere mirona na doini vairagu ai mia.
\q2 Ḡaubada Iehova na e herevamu.
\q1 
\v 23 Ba hereva diba a, baoto “Lau na asina miro,
\q2 Baal muridiai asinala” a?
\q1 Emu dala koura ai ba itaia;
\q2 ba diba ede vada o kara toma.
\q1 Oi na kamelo natuna e tau maurimu na heto,
\q2 
\v 24 eiava uda donikina hahinena, tano ḡaḡaena ai e noho manadamu ḡauna, na heto;
\q1 ena heḡaima ai lai e ha-iruamu,
\q2 bona ena heḡahusi ai daika ese baine rua?
\q1 Itahuna ai ta basine hekwarahi,
\q2 ena nega ai idia ese bae davaria.
\q1 
\v 25 Aemu ba nari, asi tamakamu basio raka;
\q2 gadomu ba naria, basio ranu mase.
\q1 A oi oto: Asi dalana,
\q2 badina be dirava idaudia vada na ura henidia,
\q2 bona idia baina ḡavadia.
\b
\q1 
\v 26 Henao tauna e davariamu negana ai e hemaraimu na heto,
\q2 Israel taudia na unu bae hemarai toma,
\q1 idia bona edia pavapava bona edia lohia,
\q2 edia hahelaḡa taudia bona edia peroveta taudia danu.
\q1 
\v 27 Badina be idia ese au ta e hereva heniamu, e tomu
\q2 “Oi na tamagu”,
\q1 bona nadi ta e hamaoroamu, e tomu
\q2 “Oi ese o havaragu”.
\q1 Badina be vada e gini muri henigu,
\q2 asie vaira henigu;
\q1 to edia hekwakwanai negana ai e tomamu
\q2 “A tore isi ba hamaurimai”.
\q1 
\v 28 A emu dirava sibomu o kara ḡaudia,
\q2 be edeseni ai?
\q1 Bema ihamaurimu mai dibadia emu hekwakwanai negana ai,
\q2 idia hari bae tore isi;
\q1 badina be, Iuda e, emu hanua na momo heḡereḡerena,
\q2 emu dlrava danu unu e hoho tomamu.
\b
\q1 
\v 29 Iehova na e tomu:
\q2 Dahaka dainai o maumauraigumu?
\q2 Iboumui ai ese vada o daḡedaḡe henigu.
\q1 
\v 30 Natumui vada na hahisidia na asi anina,
\q2 idia na matadia asie kani;
\q1 umui sibomui emui dare ese emui peroveta taudia vada e aladia,
\q2 e gadoamu leonana na heto.
\q1 
\v 31 Ina uru taumui e, Iehova ena hereva ba kamonai;
\q2 Israel enai lau na tano ḡaḡaena
\q2 eiava dibura-masemase tanona a?
\q1 Benaini, dahaka dainai egu orea taudia na e tomu
\q2 “Ai sibomai; ai na basia vasi lou” a?
\q1 
\v 32 Hane-ulato ta ese ena herahera ḡaudia baine lalodia boio diba, a?
\q2 Eiava headava matamata hahinena ese ena dabua basine laloa a?
\q1 A lauegu orea taudia ese
\q2 nega momo herea vada e lalogu boio.
\b
\q1 
\v 33 Nahuamu o tohoa namonamomu emu mata-bodaga karadia ai,
\q2 taunabunai hahine dikadia danu emu dala vada o hadibalaidia.
\q1 
\v 34 Bona emu dabua ai danu
\q2 ogoḡami taudia, asi edia kerere taudia, raradia vada e miamu,
\q2 a ruma idarena ai asio davaridia.
\q1 Ini ḡau iboudiai na latamu ai,
\q2 
\v 35 to o tomu “Lau na asi egu kerere;
\q2 ena badu na egu amo vada eme heabi oho ani?”
\q1 A itaia, lau ese baina hahemaoro henimu,
\q2 oto “Asi egu kerere” dainai.
\q1 
\v 36 O loa kava loa kavamu,
\q2 emu dala o ha-idaua louloumu;
\q1 Aigupto ese baine hahemaraimu,
\q2 Asuria ese e hahemaraimu na heto.
\q1 
\v 37 Ina danu, imamu na kwaramu ai heatona ai ba raka oho,
\q2 badina be o abidadama henidiamu taudia na
\q1 Iehova ese vada e dadaraidia,
\q2 bona idia ese namomu basie habadaia.
\c 3
\q1 
\v 1 Iehova na e tomu:
\q2 Tau ta ese adavana bema hadihoa,
\q1 bena una hahine ese bema rakatania
\q2 bona tau ta ma bema adavaia,
\q1 adavana gunana ese ma bema lou henia a?
\q2 Una tano basinema miro bada a?
\q1 Oi na vada o mata bodaga tatau momo ediai;
\q2 bena lau dekegu ai ba lou mai a?
\q1 
\v 2 Ba gaga isi, ororo nemuka-nemukadia ba itadia!
\q2 Edena gabu ai oi na tau ta ida asio eno bou?
\q1 Dala isedia ai vada o helai, tatau vada o naridia,
\q2 Arabia hahinena tano ḡaḡaena ai na heto.
\q1 Emu mata-bodaga karadia amo
\q2 tano vada o hamiroa.
\q1 
\v 3 Taunabunai, batugu vada e helao ahu,
\q2 bona hadohado negana ai medu se diho;
\q1 ḡau tamona bagumu ita-itana na ariara hahinena baguna na heto,
\q2 so uramu ba hemarai.
\q1 
\v 4 Ina harihari vada o boi henigu, ani,
\q2 oto, Tamagu e! Kekenigu ai o hetura henigu.
\q1 
\v 5 Baine badu ela bona hanaihanai,
\q2 bona lalona baine siahu ela bona dokona a?
\q1 A itaia, vada o hereva vaitani,
\q2 to vada o kara dika mai goadamu idoinai.
\b
\s1 Iehova ese Israel bona Iuda e sisiba henidia
\p 
\v 6 King Iosia ena nega ai, Iehova ese e hereva henigu, eto, Una kara hebeatai besena, Israel, ena kara vada o itaia a? Ia na ororo badadia iboudiai e dara daeva, bona au mauridia iboudiai henudiai elava, urluseni ai lebulebu karadia e karava.
\v 7 Bena lau nato “Ina idoinai baine ha-orea murinai ia ese baine lou henigu”; a ia na se lou mai, tadikakana koikoina Iuda ese karana e itaia.
\v 8 Ia ese e itaia, una kara hebeatai besena Israel ena heuda-hanai karadia iboudiai daidiai lau ese na hadihoa bona hekoho revarevana na henia; ḡau tamona ia tadikakana koikoina Iuda na se gari, a ia danu ela, eha lebulebu.
\v 9 lenai lebulebu na ḡau pipikina dainai, ia ese tano e hamiroa, nadi bona au ediai e lebulebu.
\v 10 Ḡau tamona, ia tadikakana koikoina Iuda ese ina idoinai e itaia, to lau dekegu ai se lou mai mai lalona idoinai ida, a mai koikoina ida ema. Iehova na e herevamu.
\p 
\v 11 Bena Iehova ese e hereva henigu, eto, Kara hebeatai besena Israel ena kerere vada eme hedinarai na taina maraḡi, a koikoi besena Iuda ena kerere na bada.
\v 12 Aola, ina hereva na mirigini kahana ba gwaurai henia, baoto:
\q1 Iehova na e tomu:
\q2 Kara hebeatai besena Israel e, a lou!
\q1 Iehova na e tomu:
\q2 Mai badugu ida basina haḡeremu,
\q1 badina be lau na mai hebogahisigu;
\q2 lau na basina badu hanaihanai.
\q1 
\v 13 Iehova na e tomu:
\q2 Emu kerere a gwaurai hedinarai mo;
\q1 Iehova, emu Dirava, o daḡedaḡe henia,
\q2 bona idau taudia ida o eno bou au mauridia iboudiai henudiai,
\q1 bona lau gadogu so kamonai henia,
\q2 vada ba gwaurai hedinarai.
\q1 
\v 14 Iehova na e tomu:
\q2 Kara hebeatai memeromui e, a lou;
\q2 badina be biagumui na lau.
\q1 Lau ese baina abimui, hanua ta amo ta,
\q2 bona iduhu ta amo rarua,
\q2 bena Siona ai baina hakaumui dae.
\b
\p 
\v 15 Lau ese iregumui taudia baina henimui, na lalo namo henidiamu taudia; bena idia ese aonega bona lalo-parara amo bae ubumui.
\v 16 Iehova na e tomu, Tano ai ba vara rohoroho bona ba hutuma negana baine kau ai, unu dinadia ai idia ese Iehova ena taravatu mauana basie herevalaia lou. Basie laloa une, basie laloa tao, basie henanadailaia, bona ta ma basine hekara lou.
\v 17 Una negana ai Ierusalem na bae gwauraia Iehova ena terono; bona bese iboudiai na ienai bae hebou Iehova vairanai, Ierusalem ai; bona sibodia edia lalo-hadai dikadia iḡavadia ai basie hetoahu.
\v 18 Unu dinadia ai Iuda besena na Israel besena ida bae tami hebou, bona mirigini tanona amo baema bou, senemui na henidia tanona na ma bae mai henia.
\q1 
\v 19 Lau na laloa natugu bogaragidiai baina atomu,
\q2 bona tano namona baina henimu, tano mai hairaina,
\q2 basileia iboudiai edia e hereadiamu tanona.
\q1 Bona na laloa danu oi ese boma gwauraigu “Tamagu”,
\q2 bona lau igavagu amo basioma raka siri.
\q1 
\v 20 Iehova na e tomu:
\q2 Israel besena e!
\q1 Momokani, kara hebeatai hahinena ese adavana e dihotaniamu na heto,
\q2 oi ese vada o kara hebeatai henigu.
\b
\q1 
\v 21 Ororo nemuka-nemukadia ai gado ta e hekamonaimu,
\q2 Israel garana edia taitai bona edia noinoi;
\q1 badina be edia dala vada e hagagevaia,
\q2 Iehova, edia Dirava, vada e laloa boio.
\q1 
\v 22 Kara hebeatai memeromui, a lou mai;
\q2 emui kara hebeatai amo baina hamaurimui.
\q1 A itaia, ai na a vasimu,
\q2 badina be oi na Iehova, emai Dirava.
\q1 
\v 23 Momokani, ororo ese e koimaimu,
\q2 bona lebulebu karadia ororo badadia ai ese e dibaḡanimaimu.
\q1 Momokani, Israel ihamaurina be
\q2 Iehova, emai Dirava, enai.
\b
\p 
\v 24 A eregabemai negadia amo hari hemarai ḡauna ese tamamai edia hekwarahi anidia iboudiai vada e hadonodia: edia mamoe seridia bona edia boromakau seridia, natudia mamaruanedia bona natudia hahinedia danu.
\v 25 Emai hemarai ai baia hekure; emai hemarai ese baine ḡovamai ahu; badina be ai ese Iehova, emai Dirava, vada a kara dika henia, ai bona tamamai danu, eregabemai negadia amo ema bona ina dina; bona Iehova, emai Dirava, gadona asia kamonai henia.
\c 4
\q1 
\v 1 Iehova na e tomu:
\q2 Israel e, oi na boma lou,
\q2 lau dekegu ai ba lou mai.
\q1 Emu ḡau dika-rohorohodia na vairagu amo boma abi oho,
\q2 bona basioma daradara.
\q1 
\v 2 Momokani ai bona hahemaoro ḡoevaḡoeva ai bona kara maoromaoro ai boma gwau hamata,
\q2 boma toma “Iehova e maurimu heḡereḡerena”,
\q1 bena basileia idau-idau na sibodia bae hahenamo ia dainai,
\q2 bona ia bae imodaia.
\p 
\v 3 Badina be Iehova ese Iuda taudia bona Ierusalem inoholaina taudia na ini e hamaorodia tomamu:
\q1 Emui vahu tanona ba ruaia,
\q2 au ginigini gabudia ai basio hadohado.
\q1 
\v 4 Iuda taumui bona Ierusalem inoholaina taumui e,
\q2 sibomui ba haheperitome Iehova enai,
\q2 peritome ai lalomui ba hahelaḡadia,
\q1 egu badu ḡaraḡara na lahi na heto baine lasi na garina,
\q2 bena baine ara, asi tauna ta ese baine habodoa,
\q2 emui kara vada e dika dainai.
\s1 Iuda bae daea
\p 
\v 5 Iuda ai ba gwauraia, bona Ierusalem ai ba gwauraia hedinarai, baoto:
\q1 Tano heḡeḡemadai ai kibi ba hiriria;
\q2 ba boi lolo, baoto “A hegogo, baitala,
\q2 hanua mai maḡudia lalodiai”.
\q1 
\v 6 Pepe ba duduia isi Siona enai,
\q2 ba heau, mauri ba tahua, basio halahe.
\q1 badina be hahedika na mirigini kahana amo na mailaimu,
\q2 bona hahebua-tari badana danu.
\q1 
\v 7 Leona na uda hedoma-hedomana vada e rakatania,
\q2 basileia ihabua-taridia tauna vada e tore isi;
\q1 ena gabu amo vada e raka lasi,
\q2 emu tano ihavahuna totona;
\q1 emu hanua na bae heḡiḡi dobi,
\q2 asi inoholaidia bae mia.
\q1 
\v 8 Ina dainai puse dabuadia ba rio,
\q2 ba tai, ba tai lolololo;
\q1 badina be Iehova ena badu ḡaraḡara na
\q2 ita eda amo se heabi oho.
\p 
\v 9 Iehova na e tomu, Una dina ai hanua pavapavana bona hanua lohiadia edia boga-auka baine ore; hahelaḡa taudia bae gari dikadika bona peroveta taudia bae hoa bada.
\v 10 Bena lau nato, Ḡaubada Iehova e, oi na ina bese bona Ierusalem hanuana vada o koidia vaitani, ani, oto “Vada ba namo”; ḡau tamona, dare ese be aladiamu.
\p 
\v 11 Una negana ai ta ese ina bese bona Ierusalem hanuana baine hamaorodia, baineto, Lai siahuna na tano ḡaḡaena ororodia nemuka-nemukadia amo e maimu, egu bese natuna hahinena e toa heniamu, dia itapona eiava ihaḡoevana totona.
\v 12 A lai badana na daigu ai e maimu. Harihari lau ese hahemaoro ai na hereva henidiamu.
\q1 
\v 13 A itaia, ia na duba na heheto e tubu e maimu,
\q2 ena kariota na koe-hirihiri na heto;
\q1 ena hosi na haraḡa herea, idia ese ugava e hereadiamu;
\q2 madi ihabaida, vada ta dika vaitani.
\q1 
\v 14 Ierusalem e, lalomu ena dika ba huri oho,
\q2 ba mauri helaoreana;
\q1 emu lalo-hadai dikadia na lalomu ai bae mia
\q2 ela bona edena nega ai?
\q1 
\v 15 Badina be gado ta Dan amo e herevamu,
\q2 bona Efraim ororona amo hahedika e gvauraiamu.
\q1 
\v 16 Bese idau-idau ba sisiba henidia, ia na e maimu;
\q2 Ierusalem ba gwaurai henia, baoto:
\q1 Hanua idaena taudia na tano daudau amo e maimu,
\q2 Iuda hanuadia e hone henidiamu.
\q1 
\v 17 Tano igimana taudia na heheto e ginia heḡeḡe,
\q2 badina be ia ese vada e gwau edeede henigu.
\q2 Iehova na e herevamu.
\q1 
\v 18 Emu dala bona emu kara ese
\q2 ina kara na latamu ai vada e hadihoa.
\q1 Ina na oi irevamu, vada eme idita;
\q2 oi lalomu korikorina ai vada e vareai.
\q1 
\v 19 Lalogu e, lalogu e, hisihisi ese e gugubagumu!
\q2 Kudougu e!
\q1 Kudougu na e hetaha dikadikamu,
\q2 udugu basina hakapua diba;
\q1 badina be kibi reḡena na kamonaimu,
\q2 bona tuari honena danu.
\q1 
\v 20 Dika ta dika ta latanai e kaumu,
\q2 ela bona tano idoinai vada e vahu.
\q1 Asi vanahana egu kalaga e hegiḡi rohorohomu;
\q2 asi vanahana egu seseahu e heabi ohomu.
\q1 
\v 21 Pepe baina itaia ela bona edena nega ai?
\q2 kibi reḡena baina kamonai ela bona edena nega ai?
\q1 
\v 22 Badina be egu bese taudia na kakavakava,
\q2 idia na asi dibadia lau;
\q1 idia na lalo-duhu memerodia,
\q2 asi edia lalo-parara.
\q1 Kara dika ikaradia mai dibadia,
\q2 a kara namo ikaradia na asi dibadia.
\b
\q1 
\v 23 Tanobada na itaia, vada e vahu bona asi anina;
\q2 guba na itaia, ia na asi diarina.
\q1 
\v 24 Ororo badadia na itadia, idia na e tabubu-tabubu,
\q2 bona ororo maraḡidia e heude-heude.
\q1 
\v 25 Na roha lao, tau ta asina itaia,
\q2 bona atai manudia iboudiai vada e roho boio.
\q1 
\v 26 Na roha lao, nomu tanona na itaia, vada e ḡaḡae,
\q2 bona hanuana iboudiai vada e heḡiḡi dobi,
\q2 Iehova vairanai, ena badu ḡaraḡara vairanai.
\p 
\v 27 Badina be Iehova ini e gwau tomamu: Tano idoinai baine hahevahura; to basina havahuraia vaitani.
\q1 
\v 28 Ina dainai tanobada baine taitai,
\q2 bona atai ai guba baine dubaduba;
\q1 badina be lau vada na hereva bona lalogu vada na hadaia,
\q2 basina helalo kerehai bona lalogu basina haloua.
\q1 
\v 29 Hosi tauna bona peva tauna reḡedia dainai,
\q2 hanua iboudiai taunimanimadia na e heau maurimu;
\q1 uda hedoma-hedomadia ai e heau vareaimu, haga nadidia ai e dara daemu;
\q2 hanua iboudiai e heautanidiamu, lalodiai tau ta se nohomu.
\q1 
\v 30 Oi, vada e negemu daure hahinemu e,
\q2 emu lalo-hadai be dahaka bena dabua kakakakana o hahedokilaiamu;
\q1 bona \it gold\it* heraheradia o heralaimu,
\q2 bona matamu na umu amo o habadamu?
\q1 Asi badina sibomu o hahairaimu;
\q2 e ura henimuva taudia ese e dadaraimumu,
\q2 idia ese emu mauri iabi-ohona dalana e tahuamu.
\q1 
\v 31 Badina be taitai ta na kamonai,
\q2 e hekamonaimu hahinena ena tai na heto,
\q1 natuna roboana e havaraiamu hahinena ese
\q2 hisi e animu na heto;
\q1 Siona natuna hahinena ena tai,
\q2 e laḡa dae laḡa daemu, bona imana e toi roromu,
\q1 e tomu “Lau madi ihabaigu,
\q2 roroma taudia vairadiai na mase reamu”.
\c 5
\s1 Ierusalem bona Iuda edia kara dika
\q1 
\v 1 Ierusalem ariaradia ai ba heau lao ba heau mai,
\q2 ba itaia bona ba haeroa.
\q1 Ena ariara lalodiai ba ita hetahu-hetahu,
\q2 tau ta ba davaria eiava lasi,
\q1 e hahemaoro ḡoevaḡoevamu bona hereva momokanina e tahuamu tauna;
\q2 unu amo ena dika bama gwau tao.
\q1 
\v 2 Ena be e tomamu “Iehova e maurimu heḡereḡerena”,
\q2 to e gwau hamata koikoimu.
\q1 
\v 3 Iehova e, oi matamu ese kara momokanina e tahuamu, ani?
\q2 Oi ese vada o harahudia mase,
\q2 a lalodia asie hisihisi;
\q1 oi ese vada o aladia ore,
\q2 a mata-hakani asie ura.
\q1 Idia ese vairadia e ha-aukadia,
\q2 vairadia na nadi-aukadia na heheto,
\q2 a idia na asie ura bae helalo kerehai.
\b
\q1 
\v 4 Bena lau nato: Ini na ogoḡami taudia mo,
\q2 lalodia na asie pararamu;
\q1 badina be Iehova ena dala na asi dibadia,
\q2 edia Dirava ena taravatu danu asi dibadia.
\q1 
\v 5 Lohia dekedia bainala, baina hereva henidia;
\q2 badina be idia na Iehova ena dala dibadia,
\q2 edia Dirava ena taravatu danu dibadia.
\q1 A idia iboudiai ese danu maduna auna vada e hakwaidua,
\q2 bona iḡuidia vada e hamotudia.
\b
\q1 
\v 6 Taunabunai, uda amo leona ta ese baine aladia mase;
\q2 tano ḡaḡaena amo sisia daḡedaḡena ta ese baine habuadia tari.
\q1 Taiga ta ese edia hanua e bani henidiamu,
\q2 bae raka lasi taudia iboudiai na ia ese baine daredia patapata;
\q1 badina be edia kara dika na momo,
\q2 edia raka-muri na bada.
\b
\q1 
\v 7 Emu dika na ede baina gwaua tao toma?
\q2 Oi natumu ese vada e rakatanigu,
\q2 dirava koikoidia ladadia ai vada e gwau hamata.
\q1 Bogadia na hakunuva negadia ai,
\q2 idia na e heuda hanaiva,
\q2 ariara hahinedia edia ruma ai e didi vareaiva.
\q1 
\v 8 Idia na hosi mamaruanedia,
\q2 bogadia e kunumu bona taudia e lokalokamu,
\q2 ta ta dekena tauna dekena tauna adavadia e tubebe henidiamu.
\q1 
\v 9 Iehova na e tomu:
\q2 Unu ḡau daidiai davadia basina henidia a?
\q2 Bese unuhetomana latanai dava basina atoa a?
\b
\q1 
\v 10 Ena vine imeana ba rakaia hanai, ba havahua,
\q2 a basio havahuraia vaitani;
\q1 ia rigina ba padadia oho,
\q2 badina be idia na dia Iehova ena.
\q1 
\v 11 Badina be Israel iduhuna bona Iuda iduhuna na
\q2 egu ai vada e hebeatai vaitani.
\q2 Iehova na e herevamu.
\q1 
\v 12 Idia ese Iehova e herevalaia koikoi, eto:
\q2 Ḡau ta basine karaia;
\q1 dika ta ita eda ai basine kau,
\q2 dare bona doe basita mamidia.
\q1 
\v 13 Peroveta taudia na lai kavakava ai bae hahelao,
\q2 hereva momokanina na dia idia ediai.
\q2 Unu bae halou henidia toma.
\b
\q1 
\v 14 Taunabunai Dirava, Iehova Sabaota, na ini e gwau tomamu:
\q2 Ina hereva vada e gwauraia dainai,
\q1 a itaia, egu hereva na lahi ai baina halaodia oi udumu ai,
\q2 bona ina bese na au rakuraku ai baina halaoa,
\q2 bena lahi ese baine aradia ore.
\q1 
\v 15 Israel besena e, a itaia,
\q2 bese ta na dauha amo baina mailaia umui latamui ai.
\q2 Iehova na e herevamu.
\q1 Una bese na e hesiriu hanaihanaimu besena,
\q2 ia na bese gunana;
\q1 ia na gadona asi dibamu besena,
\q2 bae hereva negadia ai lalomu basine parara.
\q1 
\v 16 Edia diba pauana na gara hekehona na heto;
\q2 idia iboudiai na goada-dikadika taudia.
\q1 
\v 17 Emu taboro bae ha-orea,
\q2 bona emu aniani ḡaudia danu;
\q1 natumu mamaruanedia bona hahinedia bae ha-oredia,
\q2 bona emu mamoe seridia bona emu boromakau seridia danu;
\q1 emu vine bae haoredia,
\q2 bona emu suke audia danu;
\q1 emu hanua aukadia, o abidadama henidiamu hanuadia, na
\q2 dare ai bae habuadia tari.
\p 
\v 18 Iehova na e tomamu: To unu dinadia ai lau ese basina ha-oremui vaitani.
\v 19 Bena emu bese taudia baeto “Badina be dahaka Iehova, eda Dirava, ese ini kara iboudiai rla eda ai vada e kara?” negana ai, oi ese ba hamaorodia, baoto “Umui ese vada o rakatanigu, bona emui tano lalonai dirava idaudia isiaidia vada o lao heni heḡereḡerena, umui ese danu idau tano, dia emui tano, lalonai idau taudia isiaidia do ba lao heni”.
\b
\q1 
\v 20 Iakob iduhuna ai ina hereva ba gwauraia,
\q2 Iuda tanona ai ba gwauraia hedinarai, baoto:
\q1 
\v 21 Asi lalomui bona asi daramui taumui e, a kamonai,
\q2 mai matamui, to asio heitamu;
\q2 mai taiamui, to asio kamonaimu.
\q1 
\v 22 Iehova na e tomamu:
\q2 Asio gari henigumu a?
\q2 Lau vairagu ai asio heude-heudemu a?
\q1 Lau ese kone na atoa, davara hetoana,
\q2 davara ilao-ahuna, baine mia hanaihanai ḡauna,
\q2 davara ese basine hanaia diba ḡauna.
\q1 Ena be hurehure na e heabi isimu, to basie kwalimu diba;
\q2 ena be kone ai e poumu, to basie hanaia diba.
\q1 
\v 23 A ina bese taudia lalodia na a'auka, bona mai gwau-edeededia;
\q2 idia na vada e raka siri, dauha vada ela.
\q1 
\v 24 Lalodia ai idia na asie tomu:
\q2 Iehova, eda Dirava, garina baita gari;
\q1 ia ese medu e henidamu, negana korikori ai,
\q2 lahara medudia bona guitau medudia;
\q1 bona vada e duanaidia taboro puradia ai baela puradia na
\q2 ia ese e badinadiamu, eda.
\q1 
\v 25 Ini na emui kara havara ese emui amo vada e abi oho,
\q2 bona emui kara dika ese namo na emui amo vada e laoa ahu.
\q1 
\v 26 Badina be kara dika taudia na egu orea taudia bogaragidiai e nohomu;
\q2 bona idia na e komumu, manu ibani-henidia taudh na heheto.
\q1 Idia ese rikiriki e atoamu,
\q2 taunimanima e abidiamu.
\q1 
\v 27 Edia ruma na kara dibaka ai e honumu,
\q2 bosea na manu ai e honumu na heto;
\q1 taunabunai idia na vada e lohia, vada e taḡa,
\q2 
\v 28 taudia vada e bada bona vada e raho namo.
\q1 Edia kara dikadia na asie hamaragidiamu;
\q2 asie hahemaoro ḡoevaḡoevamu;
\q1 ihareha idurudia asie goadalaiamu,
\q2 bona e dabumu taudia ahudia korikori asie gimadiamu.
\q1 
\v 29 Iehova na e tomu:
\q2 Ini ḡau daidiai matadia basina hakanidia a?
\q1 Bese inihetomana latanai
\q2 dava basina atoa a?
\b
\q1 
\v 30 Hoa bada bona gari bada ḡauna ta na
\q2 tano ai vada e vara:
\q1 
\v 31 peroveta taudia na e peroveta koikoimu,
\q2 bona edia hahedua heḡereḡeredia ai hahelaḡa taudia na e lohiamu;
\q1 bona egu orea taudia na e uramu unu baine heto,
\q2 a nega dokona baine kau ai be ede ba kara toma?
\c 6
\s1 Ierusalem bona Iuda bae dika
\q1 
\v 1 Beniamina taumui e,
\q2 Ierusalem bogaragina amo a heau mauri!
\q1 Tekoa ai kibi ba hiriria,
\q2 Bete-hakerereme ai pepe ba duduia isi!
\q1 Badina be hahedika na mirigini kahana amo e hedinarai e maimu,
\q2 bona hahebua-tari badana danu.
\q1 
\v 2 Hane namo, aboni-noho hahinena, baine alaia,
\q2 Siona natuna hahinena baine alaia mase.
\q1 
\v 3 Mamoe ireḡudia taudia mai edia seri ida na ia ivaira-henina baema,
\q2 edia kalaga bae haginidia, bae ḡeḡea ahu,
\q2 edia mamoe bae ubudia, ta ta ena gabu ena gabu ai.
\q1 
\v 4 Tuari a haheḡaeḡaea, ia ihadikana;
\q2 a tore isi, dina tubua ai baita daea.
\q1 Madi ihabaida, ado e rahimu,
\q2 dina na e kerekeremu.
\q1 
\v 5 A tore isi, hanuaboi ai baita daea,
\q2 ena lohia rumadia baita habuadia tari.
\b
\q1 
\v 6 Badina be Iehova Sabaota na ini e gwau tomamu:
\q2 Ena au ba hagaridia,
\q2 tano ba larebaia dae, Ierusalem hevaira-henina ai.
\q1 Ina hanua na matana bae hakania;
\q2 ia lalonai na hahehisi karadia mo.
\q1 
\v 7 Ranu gurina ese ranuna e hamatamataia na heto,
\q2 ia ese ena kara havara unu e hamatamata tomamu;
\q1 daḡedaḡe bona hahebua-tari karadia reḡedia na ia lalonai e hekamonaimu,
\q2 gorere bona bero na vairagu ai nega idoinai.
\q1 
\v 8 Ierusalem e, nahuamu a tohoa,
\q2 emu ai lalogu baine dika na garina,
\q2 baina havahumu bona tano deḡedeḡena-rahu ai baina halaomu na garina.
\b
\q1 
\v 9 Iehova Sabaota na ini e gwau tomamu:
\q2 vine huahuadia kwabudia e buruki oremu na heto,
\q2 Israel kwabukwabudia ba burukidia ore;
\q1 vine huahuadia igogodia tauna na heto,
\q2 oi imamu ese rigina baine darahua lou.
\q1 
\v 10 Daidia baina hereva henidia bona baina sisiba henidia,
\q2 bae kamonai helaoreana?
\q1 A itadia, taiadia na hehekou,
\q2 idia na asi kamonai dibadia.
\q1 A itadia, Iehova ena hereva na e ḡonaḡonalaiamu,
\q2 asie moalelaiamu.
\q1 
\v 11 Taunabunai lau na Iehova ena badu ai na honumu,
\q2 ihalahelaina ai na hesikumu.
\q1 Taunabunai ariara ai memero kekeni latadiai ba bubua diho,
\q2 bona eregabe taudia edia hegogo latadiai danu;
\q1 tau mai adavana ida bae abidia hebou,
\q2 taunimanima badadia bona burukadia danu.
\q1 
\v 12 Edia ruma na haida bae henidia,
\q2 edia uma bona adavadia danu;
\q1 badina be lau ese imagu baina toia roro,
\q2 tano inoholaina taudia ihadikadia totona.
\q2 Iehova na e herevamu.
\b
\q1 
\v 13 Maraḡina ela bona badana,
\q2 iboudiai ese mata-ḡaniḡani karadia e gugulaimu;
\q1 bona peroveta tauna ela bona hahelaḡa tauna,
\q2 iboudiai e kara koikoimu.
\q1 
\v 14 Egu orea taudia berodia vada e haḡoevadia lamai-lamai,
\q2 eto “Maino, maino”,
\q2 maino do lasi negana ai.
\q1 
\v 15 Kara dika-rohorohona e karaia negana ai,
\q2 idia na e hemarai a?
\q1 Idia na asie hemarai, lasi ona lasi vaitani;
\q2 hemarai mamina na asi dibadia.
\q1 Taunabunai, e ketomu taudia bogaragidiai bae keto;
\q2 matadia baina hakanidia negana ai idia na bae henege daure.
\q2 Iehova na e herevamu.
\b
\q1 
\v 16 Iehova ini e gwau tomamu:
\q2 Dala badidiai ba gini, ba roharoha;
\q2 dala gunadia ba henanadailai;
\q1 bena lao dalana namona ba davaria, ia lalonai ba raka,
\q2 bona laumamui edia laḡa-ani ba davaria.
\q2 A idia eto “Ai na ia lalonai basia raka”.
\q1 
\v 17 Gima taudia na duanaidia, umui igimamui;
\q2 nato “Kibi reḡena ba hakala henia”.
\q2 A idia eto “Ai na basia hakala”.
\q1 
\v 18 Bese idau-idau e, a kamonai!
\q2 Hebou taumui e, ba diba dahaka na ediai baine vara.
\q1 
\v 19 Tanobada e, a kamonai! A itaia!
\q2 Lau ese dika na havaraiamu ina bese taudia latadiai,
\q2 idia sibodia edia lalo-hadai huahuadia;
\q1 badina be egu hereva na asie hakala henidia,
\q2 bona egu taravatu na vada e dadaraia.
\q1 
\v 20 Anina be dahaka egu muramura mai bonana na Sieba amo e mailaiamu,
\q2 eiava kane\f + \fr 6:20 \ft “Kane” na Heberu taudia edia muramura mai bonana ta.\f* namona tano daudauna amo?
\q1 Emu ḡole-oho boubou ḡaudia na asina abidia daemu,
\q2 bona emu boubou karadia na asina moalelaidiamu.
\q1 
\v 21 Taunabunai, Iehova na ini e gwau tomamu:
\q2 A itaia, hetutuhi ḡaudia na ina bese taudia vairadiai baina atodia,
\q2 idia ihahetutuhidia.
\q1 Tama bona natudia na bae hetutuhi hebou;
\q2 ruma tauna mai turana ida bae mase hebou.
\b
\q1 
\v 22 Iehova ini e gwau tomamu:
\q2 A itaia, bese ta na mirigini kahana amo e maimu;
\q1 basileia badana ta na e tore isimu,
\q2 tanobada kahadia daudau-hereadia ai.
\q1 
\v 23 Idia ese peva bona io na imadia ai e abimu,
\q2 idia na e daḡedaḡemu, bona asie hebogahisimu;
\q2 reḡedia na davara guruna na heto.
\q1 Siona natuna hahinemu e,
\q2 idia na hosi ai e guimu, e heḡaeḡaemu,
\q1 tau ta na tuari dainai e heḡaeḡaemu na heto,
\q2 oi ihadikamu totona.
\q1 
\v 24 Ita ese harina vada ta kamonai,
\q2 a imada na asi goadadia;
\q1 hisihisi bada-hereana ese e gugubadamu,
\q2 hahine ta ena hekamonai hisina na heto.
\q1 
\v 25 Basio raka lasi tano paka ai,
\q2 bona dala ai basio raka,
\q1 badina be inai tauna na mai darena ida e loamu,
\q2 bona gari bada ese e ḡeḡeda ahumu.
\q1 
\v 26 Egu bese natuna hahinemu e,
\q2 puse dabuadia ba rio,
\q2 kahu ai ba hekui-hekui;
\q1 ba taitai, natuna vara-edeana e taitailaiamu na heto,
\q1 herohe-ahu idita hereana;
\q2 badina be hahebua-tari tauna ese
\q1 baine hatakuda.
\b
\q1 
\v 27 Lau ese hidi-hidi tauna bona hahetoho tauna ai vada na halaomu egu orea taudia bogaragidiai,
\q2 edia dala ba dibadia bona ba hididia totona.
\q1 
\v 28 Idia iboudiai na e gwau ede-ede dikadikamu,
\q2 hahebade koikoi herevadia e loalaidiamu;
\q1 idia na auri bona auri labora-labora,
\q2 iboudiai na e kara koikoimu.
\q1 
\v 29 Lahi ihiririlaina ḡauna ese lahi e hahururuamu,
\q2 e vevemu aurina na lahi ai e veve ohomu;
\q1 haheḡoeva ḡaukarana e karaiamu na asi anina,
\q2 badina be kara dika taudia na asie heabi ohomu.
\q1 
\v 30 \it Silver\it* momorudia bae gwauraidia,
\q2 badina be Iehova ese vada e dadaraidia.
\c 7
\s1 Ieremia ena haroro herevadia
\p 
\v 1 Ina hereva na Iehova ena amo Ieremia enai e kau:
\v 2 Iehova ena dubu ikoukouna ai ba gini, unuseni ai hereva ba gwauraia, baoto, Iehova ena hereva ba kamonai, umui Iuda taumui, Iehova itomadiho-henina totona ini ikoukou lalodiai o raka vareaimu taumui iboumui ai.
\v 3 Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Emui dala bona emui kara ba hamaoromaorodia, bena ina gabu ai do baina hanohomui.
\v 4 Ini hedibagani herevadia basio abidadama herlidia: “Ina na Iehova ena dubu, Iehova ena dubu, Iehova ena dubu”.
\p 
\v 5 Badina be emui dala bona emui kara boma hamaoromaorodia vaitani, bona boma hahemaoro heheni mai maoromaoromui ida,
\v 6 idau tauna eiava ihareha eiava vabu basioma hahisihisidia, eiava asi ena kerere tauna rarana basioma hahebubua irla gabu ai, bona dirava idaudia igavadia ai sibomui basioma hahehisi,
\v 7 bena lau ese ina gabu ai do baina hanohomui, nega gunadia ai senemui na henidia vaitani tanona lalonai.
\p 
\v 8 A itaia, umui ese hedibaḡani herevadia o abidadama henidiamu na asi anina.
\v 9 Ba henao, ba roroma, ba heuda hanai, ba gwauhamata koikoi, muramura mai bonana ba gabua Baal enai, bona asio dibadia guna diravadia ba ḡavadia;
\v 10 bena baoma, lau vairagu ai ba gini, ina lau ladagu e henemailaia dubuna lalonai, baoto “Ai na vada a roho mauri”; bena unu kara dika-rohorohodia ma ba kara lou a?
\v 11 Ina lau ladagu e henemailaia dubuna na emui ita-ita ai dadidadi taudia edia kohua ai vada ela a? Iehova na e tomu, Lau sibogu ese vada na itaia.
\v 12 Egu gabu Silo ai, lau ladagu na hamialaia guna gabuna, baola; ba itaia, ede na karaia toma, egu bese Israel taudia edia kara dika daidiai.
\v 13 Iehova ma e tomu Harihari, unu ḡau iboudiai vada o karadia, bona igwau-henimui di asina hesiku lo asio kamonai, bona na boirimui to asio haere, dainai
\v 14 lau ese ina dubu, lau ladagu vada e henemailaia bona o abidadama heniamu dubuna, bona ina gabu, umui bona senemui na henimui gabuna, baina kara henidia, Silo na kara henia heḡereḡerena.
\v 15 Bona lau vairagu amo baina negemui daure, varavaramui, Efraim garana, iboudiai na negedia daure heḡereḡerena.
\s1 Iehova ena hereva Ieremia enai
\p 
\v 16 Oi na ina bese taudia daidiai basio noinoi, eiava idia daidiai basio taitai eiava basio ḡuriḡuri eiava egu ai heraua basio tahua, badina be asina kamonai henimumu.
\v 17 Iuda hanuadia ai bona Ierusalem ariaradia ai e karamu karadia na so itamu a?
\v 18 Memero bona kekeni ese au rakuraku e haboumu, tamadia ese lahi e ha-aramu, bona hahine ese flaoa e kuiamu, guba pavapavana hahinena ena ataga bae gabu totona; bona inuinu bouboudia e bubudiamu, dirava idaudia ediai. Unu amo e habadugumu.
\v 19 Iehova na e tomu, Lau e haraivagumu eiava sibodia e haheraivamu bena hemarai na latadiai e kaumu a?
\v 20 Taunabunai Ḡaubada Iehova na ini e gwau tomamu: A itaia, egu badu, egu badu ḡaraḡara, na ina gabu latanai baina bubua dobi, taunimanima bona ubu-ubu ḡaudia, bona imea audia bona uma anidia danu, latadiai; ia na baine ara, basine bodo.
\s1 Iuda ena gwau-edeede davana
\p 
\v 21 Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Emui kara helaḡadia ba kara negadia ai, emui ḡole-oho boubou ḡaudia danu ba hahelaḡadia, bena vamudia bavani.
\v 22 Badina be Aigupto amo na hakaudia lasi dinana amo ema, lau ese senemui asina hereva henidia, bona asina haḡanidia idia ese ḡole-oho bouboudia bona kara helaḡadia bae kara.
\v 23 To ina haheḡani na henidia, nato, Lau gadogu ba kamonai, bena lau na emui Dirava ai bainala, bona umui na egu bese ai baola; bona na haḡanilaimuimu dalana idoinai lalonai ba raka, bena ba namo.
\v 24 A idia na asie kamonaiva, taiadia asie hakalava, to sibodia edia hahealo ai bona sibodia edia lalo-hadai dikadia bona aukadia lalodiai e rakava, e raka duava, asie raka vairava.
\v 25 Senemui na Aigupto tanona amo e raka lasi dinana amo ema bona ina dina, lau ese peroveta taudia, egu hesiai taudia, iboudiai na dina ta ta ai idia dekedia na siaidiava, asina hesiku;
\v 26 ḡau tamona, idia na asie kamonai heniguva bona taiadia asie hakalava, a aiodia e ha-aukadiava. Edia kara dika ese tamadia edia kara dika e hereadiava.
\p 
\v 27 Taunabunai, ini hereva iboudiai na ba hamaorolaidia, to basie kamonai henimu. Ba boi henidia, to basie haere henimu.
\v 28 Bena ba hamaorodia, baoto, Ina na Iehova, edia Dirava, gadona asie kamonai bona mata-hakani asie abia dae besena. Hereva momokani vada e boio vaitani, bona idia bibinadia amo vada e ore.
\q1 
\v 29 Huimu ba utu nege,
\q2 ororo nemuka-nemukadia ai ba rohe ahu;
\q1 badina be Iehova ese e badu heniamu uruna na
\q2 vada e dadaraia bona vada e rakatania.
\p 
\v 30 Iehova na e tomu: Badina be Iuda taudia na lau vairagu ai vada e kara dika; edia ḡau dika-rohorohodia na lau ladagu vada e henemailaia dubuna lalonai vada e atodia, unu amo vada e hamiroa.
\v 31 Tofete ai, Hinom natuna ena koura ai, idia ese atai gabuna helaḡana ta vada e hadaia, natudia mamaruanedia bona hahinedia na lahi ai bae haḡoledia oho helaoreana; lau ese unu asina haḡanidia toma, bona unu asina laloa toma.
\v 32 Taunabunai, Iehova na e tomu, negana vada be maimu “Tofete” bona “Hinom natuna ena koura” basie gwauraia, a ladana bae hatoa “Ala-ala Kourana”; mase taudia na Tofete ai bae guridia, badina be idau gabu ai na asi gabudia.
\v 33 Bena ina bese taudia tau-anidia na atai manudia bona uda boromadia ese bae anidia; ta ese basine luludia oho.
\v 34 Bena Iuda hanuadia bona Ierusalem ariaradia lalodiai lau ese kiri bona moale reḡedia baina hadokodia, bona headava matamata tauna bona hahinena gadodia danu; badina be tano na baine mia ḡaḡae.
\c 8
\p 
\v 1 Iehova na e tomu, Una negana ai Iuda pavapavadia bona Iuda lohiadia turiadia, bona hahelaḡa taudia bona peroveta taudia turiadia, bona Ierusalem inoholaina taudia turiadia, garadia amo bae lasilai;
\v 2 bena bae atodia rohoroho, dina bona hua bona hisiu iboudiai, e ura henidiava bona isiaidia e lao heniva ḡaudia, e ḡavadiava bona e tahudiava bona e toma henidia dihova ḡaudia, vairadiai. Basie haboudia bona basie guridia; a tano kopina ai bae mia, boromakau tagena e atoa rohoroho na heto.
\v 3 Iehova Sabaota na e tomu, Ina kara dika oreana kwabukwabudia iboudiai ese mase bae ura henia bada, mauri bae ura henia maraḡi, vada na luludia lao gabudia iboudiai Ialodiai.
\s1 Kara Dika bona Hahemaoro
\q1 
\v 4 Ba hamaorodia, baoto,
\q2 Iehova ini e gwau tomamu:
\q1 Taunimanima e ketomu negadia ai e tore isi loumu ani?
\q2 Ta bema raka siri, bena ma bema lou, ani?
\q1 
\v 5 Matona, dahaka dainai ina bese taudia vada e raka siri,
\q2 vada e raka muri dabudabu?
\q1 Koikoi e badinaia tarika-tarikamu,
\q2 asie uramu bae kerehai.
\q1 
\v 6 Vada na hakala, vada na kamonai,
\q2 a idia na asie hereva maoromaoro;
\q1 asi tauna ta na ena kara dika amo e helalo kerehaimu,
\q2 e tomu “Dahaka vada na karaia?”
\q1 Iboudiai na ta ta ena dala ena dala ai e laomu,
\q2 hosi na tuari gabuna e heau lalo-dika heniamu na heto.
\q1 
\v 7 Boḡe na atai ai e nohomu,
\q2 bona ena nega dibana,
\q1 bona pune bona aibisi bona noko na
\q2 edia mai negadia na dibadia;
\q1 a lauegu bese taudia na.
\q2 Iehova ena taravatu asi dibadia.
\b
\q1 
\v 8 Edeheto o herevamu, o tomu
\q2 “Ai na mai aonegamai
\q2 bona Iehova ena taravatu na ai emai ai” a?
\q1 A itaia, itorena taudia edia puri koikoina ese
\q2 hereva koikoina ai vada e halaoa.
\q1 
\v 9 Aonega taudia na bae hahemaraidia;
\q2 daradia bae doko, bena vada bae abidia.
\q1 A itaia, Iehova ena hereva vada e dadaraia,
\q2 daka aonega na idia lalodiai?
\q1 
\v 10 Taunabunai lau ese adavadia na haida baina henidia,
\q2 bona edia uma na kwalimu taudia baina henidia;
\q1 badina be maragina ela bona badana,
\q2 iboudiai ese mata-ganigani karadia e gugulaimu;
\q1 bona peroveta tauna ela bona hahelaḡa tauna,
\q2 iboudiai e kara koikoimu.
\q1 
\v 11 Egu orea taudia berodia vada e haḡoevadia lamai-lamai,
\q2 eto “Maino, maino”,
\q2 maino do lasi negana ai.
\q1 
\v 12 Kara dika-rohorohona e karaia negana ai,
\q2 idia na e hemarai a?
\q1 Idia na asie hemarai, lasi ona lasi vaitani;
\q2 hemarai mamina na asi dibadia.
\q1 Taunabunai vada e keto taudia bogaragidiai bae keto;
\q2 baina hadava henidia negana ai vada bae darere.
\q2 Iehova na e hereva nu.
\q1 
\v 13 Iehova na e tomu:
\q2 Iburukidia na urava negana ai,
\q1 vine audia na asi vinedia,
\q2 bona suke audia na asi sukedia;
\q1 rau danu vada e marai,
\q2 bona na henidia ḡaudia na ediai vada e boio.
\b
\q1 
\v 14 Dahaka dainai ta helai kavamu?
\q2 Aita hegogo, hanua mai maḡudia lalodiai baitala,
\q2 unuseni ai baita mase;
\q1 badina be Iehova, eda Dirava, vada e revada mase,
\q2 e imoraia ranuna vada e henida, baita inua,
\q2 badina be Iehova enai vada ta kara dika.
\q1 
\v 15 Maino ta naria, a ḡau namona ta asinema;
\q2 hahemauri negana ta naria, to, a itaia, hahegari mo e hedinarai.
\b
\q1 
\v 16 Edia hosi edia hakoko na Dan amo e kamonaimu;
\q2 edia hosi mamaruanedia e tubebemu negadia ai na tano idoinai e tabubumu.
\q1 Idia na e maimu, tano mai anina idoinai ida e ani oremu,
\q2 hanua badana danu, mai inoholaina taudia ida.
\q1 
\v 17 Badina be gaigai na bogaragimui ai na siaidia vasimu,
\q2 duba, basie hamanadadia diba ḡaudia;
\q1 bena idia ese bae korimui.
\q2 Iehova na e herevamu.
\s1 Rohe-ahu Iuda bona Ierusalem latadiai
\q1 
\v 18 Egu lalo-hisihisi na asi ihamarumaruna,
\q2 lalogu na e manoka-manokamu.
\q1 
\v 19 A hakala, egu bese kekenina e taitaimu,
\q2 tano ena lata bona ena lababa amo,
\q1 e tomu, Iehova na Siona lalonai se nohomu a?
\q2 Pavapavana na ia lalonai se nohomu a?
\q1 Badina be dahaka vada e habadugu,
\q2 e koro laulaudia bona idau taudia edia kaivakuku amo?
\q1 
\v 20 Taboro negana vada e ore, lailai huana vada e kau,
\q2 bona ta ese do se hamaurida;
\q1 
\v 21 badina be egu bese kekenina berona dainai lalogu na e hisihisimu,
\q2 na taitaimu, bena gari ese e butugu taomu.
\b
\q1 
\v 22 Gilead na asi ena dahudahu muramurana a?
\q2 Asi gorere ihanamona tauna ta unuseni ai a?
\q1 Matona, dahaka dainai egu bese kekenina
\q2 ena gorere na se namomu.
\c 9
\q1 
\v 1 Kwaragu anina bema ranu mo,
\q2 bena matagu amo iruru-mata bema aru;
\q1 bena bama tai boi tai rani,
\q2 egu bese kekenina ena mase taudia taidia bama tai.
\q1 
\v 2 Bema mai egu taruha ta tano ḡaḡaena ai,
\q2 bena egu bese taudia bama rakatanidia,
\q2 edia amo bama raka oho!
\q1 Badina be idia iboudiai na heuda-hanai taudia,
\q2 kara dibaka oreana;
\q1 
\v 3 maladia e marediamu peva na heto,
\q2 koikoi karadia vada e goada tano lalonai,
\q2 dia kara momokanidia;
\q1 badina be dika ta amo e laomu ela bona ma dika ta,
\q2 bona asi dibadia lau.
\q2 Iehova na e herevamu.
\b
\q1 
\v 4 Ta ta ese dekena tauna dekena tauna nahuadia bae toho,
\q2 bona tadikakana ta basie abidadama henia;
\q1 badina be tadikakamui iboudiai ese bae laimui oho,
\q2 bona dekemui taudia iboudiai na e loa eva-evamu,
\q2 hesivarai totona.
\q1 
\v 5 Ta ta ese dekena tauna dekena tauna e koidiamu,
\q2 bona asi tauna ta ese hereva momokanina e gwauraiamu;
\q1 maladia vada e hadibadia, bae hereva koikoi,
\q2 kara havara e karamu, bona helalo-kerehai ai e hebala reamu.
\q1 
\v 6 Hahehisi na hahehisi latanai e senuamu,
\q2 bona koikoi na koikoi latanai;
\q1 asie uramu bae dibagu.
\q2 Iehova na e herevamu.
\b
\q1 
\v 7 Taunabunai Iehova Sabaota na ini e gwau tomamu:
\q2 A itaia, baina haḡoevadia bona baina tohodia,
\q1 badina be ede ma bama kara toma,
\q2 egu bese taudia daidiai?
\q1 
\v 8 Idia maladia na hahemase hakorena,
\q2 e hereva koikoimu;
\q1 ta ta uduna uduna amo maino e herevalaiamu, dekedia taudia ediai,
\q2 a lalodiai ibani-henidia dalana e tahuamu.
\q1 
\v 9 Iehova na e tomu,
\q2 Matadia basina hakanidia ini kara daidiai,
\q2 bona bese inihetomana davana basina henia, a?
\b
\q1 
\v 10 Ororo ba tailaidia, ba tai lolololo,
\q2 tano ḡaḡaena ena rei gabudia daidiai ba rohe ahu;
\q1 badina be vada e havahudia, ta ese se rakadia hanaimu,
\q2 bona boromakau ḡoudia asie hekamonaimu;
\q2 atai manudia bona boroma idau-idau vada e heau boio.
\q1 
\v 11 Ierusalem baina ḡiḡia dobi,
\q2 uda sisiadia edia kohua ai baina halaoa;
\q1 Iuda hanuadia baina habuadia tari,
\q2 asi inoholaina gabuna ai bainela.
\s1 Hahebua-tari na e maimu
\p 
\v 12 Daika ena aonega na bada, bena ina na dibana? Iehova uduna ese daika vada e hereva henia, bena ia ese baine gwauraia? Badina be dahaka tano vada e hebua tari bona vada e vahu, tano ḡaḡaena na heto, bena tau ta ese se rakaia hanaimu?
\v 13 Iehova na e tomu, Badina be egu taravatu, vairadiai na atoa ḡauna, vada e rakatania, bona lau gadogu asie kamonai bona asie rakalaia;
\v 14 a sibodia edia lalo-hadai vada e ḡavadia mai lalo-aukadia ida, bona Baal muridiai vada ela, tamadia ese e hadibadia heḡereḡerena.
\v 15 Taunabunai, Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: A itaia, ina bese taudia na ava iditana amo baina ubudia, bona e imoraia ranuna baina henidia, bae inua.
\v 16 Baina hakarohodia rohoroho, bese idau-idau, idia bona tamadia danu asi dibadia besedia, bogaragidiai; bona dare na idia muridiai baina siaia ela bona baina ha-oredia.
\b
\q1 
\v 17 Iehova Sabaota na ini e gwau tomamu:
\q2 A haeroa, tai-hevale hahinedia a boiridia;
\q2 ima-idibaka hahinedia a boiridia baema.
\q1 
\v 18 Idia na bae kara haraḡa, bae tailaidia,
\q2 bena iruru-matada bae diho;
\q2 matada kopidia amo ranu baine aru diho.
\q1 
\v 19 Badina be taitai reḡena na Siona amo e maimu, e tomu,
\q2 Madi, vada ta dika vaitani,
\q2 vada ta hemarai vaitani;
\q1 badina be eda tano vada ta rakatania,
\q2 badina be eda ruma vada e gigidia dobi.
\b
\q1 
\v 20 Hahine e! Iehova ena hereva ba kamonai,
\q2 ia uduna herevana na taiamui ai baine vareai;
\q1 natumui kekenidia na rohe-ahu ba hadibadia,
\q2 bona dekemui hahinedia na tai hahane ba hadibalaidia.
\q1 
\v 21 Badina be mase na eda ruma gaba-maurudia ai vada e dae vareai,
\q2 eda lohia rumadia ai vada e dae kau;
\q1 memero bona kekeni na ruma ariaradia ai vada e hamasedia,
\q2 bona eregabe taudia danu hanua ariaradia ai.
\q1 
\v 22 A hereva, baoto,
\q2 Iehova na ini e gwau tomamu:
\q1 Mase taudia na bae heḡiḡi dobi,
\q2 boromakau tagena tano paka ai na heto,
\q1 eiava uit ikumidia uit iutuna tauna murinai na heto,
\q2 ta ese basine haboudia.
\s1 Dirava i'imodaina
\p 
\v 23 Iehova na ini e gwau tomamu: Aonega tauna ese ena aonega basine heaḡilaia; goada tauna ese ena goada basine heaḡilaia; taḡa tauna ese ena taḡa basine heaḡilaia.
\v 24 A heaḡi e wamu tauna ese ina na baine heaḡilaia: ia dibana lau bona egu ai lalona e pararamu; dibana lau na Iehova, hebogahisi karadia bona hahemaoro ḡoevaḡoeva bona kara maoromaorodia na karamu tanobada ai; badina be unu ḡau na moalelaidiamu. Iehova na e herevamu.
\p 
\v 25 Iehova na e tomu. A itaia, negana vada e maimu, vada e heperitome to asi anina peritomena taudia iboudiai na lau ese davadia baina henidia,
\v 26 Aigupto, Iuda, Edom, Amono besena, Moab, bona tano ḡaḡaena ai e nohomu bona bagudia huidia e merameramu taudia iboudiai. Badina be ini bese iboudiai na asie peritomedia, bona Israel taudia danu peritome ai lalodia asie hahelaḡadia.
\c 10
\s1 Dirava koikoina: Dirava momokanina
\q1 
\v 1 Israel besena e, Iehova ese e hereva henimu herevana na ba kamonai!
\q2 Iehova na ini e gwau tomamu:
\q1 
\v 2 Basileia idau-idau edia dala basio hahedibalai,
\q2 bona guba toadia basio garilai,
\q1 basileia idau-idau ese e garilaidiamu dainai;
\q2 
\v 3 badina be bese idau-idau edia kara na kokoikoi.
\q1 Uda auna ta e hagariamu,
\q2 bena ima-idibaka tauna ese ira amo e haḡoevaiamu;
\q1 
\v 4 taunimanima ese \it silver\it* bona \it gold\it* amo e ḡovaiamu,
\q2 bona lavu bona ikoko amo e kokoa kaumu,
\q2 ia basine marere-marere helaoreana.
\q1 
\v 5 Edia kaivakuku na manu ihagaridia ḡaudia kiukamba umana ai na heheto;
\q2 idia na asi hereva dibadia.
\q1 Haida ese e huadia loaloamu,
\q2 badina be asi raka dibadia.
\q1 Garidia basio gari,
\q2 badina be dika ikarana asi dibadia,
\q2 bona namo ikarana danu asi dibadia.
\b
\q1 
\v 6 Iehova e, oi na asi idaimu;
\q2 oi na bada, bona oi ladamu siahuna na bada.
\q1 
\v 7 Bese idau-idau edia pavapava e!
\q2 Daika ese basine gari henimu?
\q2 Badina be oi ahumu korikori bunai.
\q1 Badina be bese idau-idau edia aonega taudia iboudiai bogaradiai,
\q2 bona edia basileia iboudiai lalodiai,
\q2 oi na asi idaimu.
\q1 
\v 8 Idia na lalo-duhu bona kavakava ḡaudia;
\q2 kaivakuku edia hahediba na au ena mo.
\q1 
\v 9 \it Silver\it*, e botaia palakamu ḡauna, na Tarasisi amo e mailaiamu,
\q2 bona \it gold\it* na Ufasa amo.
\q1 Ikaradia na ima-idibaka taudia edia ḡaukara,
\q2 bona \it gold\it* iḡaukaralaina taudia imadia ḡaukaradia;
\q1 edia dabua na ḡahukaḡahuka bona mia-kaka,
\q2 iboudiai na ima-idibaka taudia ese e karadia.
\q1 
\v 10 A Iehova na Dirava korikorina;
\q2 ia na mauri Diravana bona noho-hanaihanai Pavapavana.
\q1 E badumu negadia ai tano e lagamu;
\q2 ena badu henunai basileia idau-idau na asi haheauka dibadia.
\p 
\v 11 Taunabunai ini ba hamaorodia toma, baoto: Guba bona tanobada asie karadia diravadia na tanobada amo bona guba henuna auno bae boio.
\q1 
\v 12 Ia ese ena siahu amo tanobada e karaia,
\q2 bona ena aonega amo tanobada idoinai e haginia,
\q2 bona ena lalo-parara amo guba e idia roro.
\q1 
\v 13 Ia e herevamu negadia ai, ranu na e heguruamu guba ai;
\q2 ia ese ninoa e hadaeamu, tanobada dokodia amo.
\q1 Ia ese medu kevarudia e halasidiamu,
\q2 bona lai na ena habou-habou rumadia amo e hakaudia lasimu.
\q1 
\v 14 Taunaimanima iboudiai na kakavakava bona asi aonegadia,
\q2 bona \it gold\it* igaukaralaina taudia iboudiai na edia kaivakuku ese e hahemaraidiamu;
\q1 badina be edia kaivakuku na koikoi ḡaudia,
\q2 bona asi laḡadia.
\q1 
\v 15 Idia na asi anidia, haero-kerere ese e havaradia;
\q2 edia dava-abi negana ai bae mase.
\q1 
\v 16 Iakob ahuna na dia unuheto;
\q2 badina be ia ese ḡau iboudiai vada e karadia.
\q1 Ia dihina na Israel besena;
\q2 ia ladana na Iehova Sabaota.
\s1 Iuda ihavahuna
\q1 
\v 17 Emui kohu ikumidia na tano amo bavabi isi,
\q2 umui e daia ahumu hanuana ai o nohomu taumui.
\q1 
\v 18 Badina be Iehova na ini e gwau tomamu:
\q2 A itaia, ina nega ai tano inoholaina taudra na davedia lasimu;
\q1 hisihisi na idia latadiai baina mailaia,
\q2 bae mamia helaoreana.
\b
\q1 
\v 19 Madi ihabaigu, egu hisihisi dainai;
\q2 vada na bero dikadika.
\q1 A lau nato, Momokani, ina na hisihisi ta;
\q2 baina haheaukalaia.
\q1 
\v 20 Egu dabua kalagana vada e ḡiḡia dobi,
\q2 egu kalaga varodia iboudiai vada e motu;
\q1 natugu ese vada e rakatanigu,
\q2 idia na lasihidia.
\q1 Asi tauna ta ese egu dabua kalagana baine veria roro lou,
\q2 eiava egu seseahu dabuadia baine taudia dae.
\q1 
\v 21 Badina be mamoe ireḡudia taudia na kakavakava,
\q2 idia na Iehova enai asie henanadaimu;
\q1 taunabunai edia namo asie habadaia,
\q2 bona edia seri idoinai vada e karoho rohoroho.
\b
\q1 
\v 22 A hakala, hari ta! A itaia, e maimu!
\q2 Heloḡo-heloḡo badana mirigini kahana amo e maimu,
\q1 Iuda hanuadia ihabua-taridia,
\q2 bona uda sisiadia edia komu gabudia ai ihalaodia.
\b
\q1 
\v 23 Iehova e, lau dibagu taunimanima ena dala na dia ia sibona lalona ai,
\q2 bona taunimanima ena raka na ia sibona ese basine gwauraia hidi.
\q1 
\v 24 Iehova e, egu kerere dodinai mo matagu ba hakania,
\q2 dia emu badu ai, ba habuagu tari na garina.
\b
\q1 
\v 25 Emu badu na ba seia dobi, asie dibamumu basileiadia latadiai,
\q2 bona oi ladamu asie hahaneamu besedia latadiai;
\q1 badina be idia ese Iakob vada e hadonoa;
\q2 vada e hadonoa, vada e ha-orea,
\q2 bona ena noho gabuna vada e havahua.
\c 11
\s1 Taravatu itata-utuna
\p 
\v 1 Ina hereva na Iehova ena amo ema, Ieremia enai:
\v 2 Ina taravatu herevadia ba kamonai, bona Iuda taudia bona Ierusalem inoholaina taudia ba hereva henidia.
\v 3 Ba hamaorodia, baoto, Iehova, Israel Diravana, na ini e gwau tomamu: Ina taravatu herevadia basine kamonai henidia tauna na bae uduguiraia.
\v 4 Taravatuna binai senemui na haḡanilaidia, Aigupto tanona, auri amuna, amo na hakaudia lasi negana ai, nato, Lau gadogu ba kamonai, bona na haḡanilaimuimu karadia iboudiai na ba. kara, unu amo umui na egu bese ai baola bona lau na emui Dirava ai bainala;
\v 5 bena senemui na gwaurai henidia gwauhamatana, nato rata bona badaranuna e arumu tanona baina henimui, na baina hamomokania, hari ina dina ai heḡereḡerena. Bena lau na haere, nato, Iehova e, unu baine heto.
\p 
\v 6 Bena Iehova ese e hamaorogu, eto, Ini hereva iboudiai na Iuda hanuadia ai bona Ierusalem ariaradia ai ba g vaurai hedinarai, baoto: Ina taravatu herevadia ba kamonai, bona karadia ba kara.
\v 7 Badina be senemui na sisiba henidia auka, Aigupto tanona amo na hakaudia lasi negana ai, na sisiba henidia loulou, asina hesiku, ema bona ina dina ai, nato, Lau gadogu ba kamonai.
\v 8 Ḡau tamona, asie kamonai henigu bona taiadia asie hakala, a iboudiai na edia lalo-hadai dikadia ai bona edia lalo-auka ai e raka. Taunabunai, ina taravatu herevadia iboudiai, na haḡanidia bae kara to asie kara ḡaudia, na idia latadiai na hadihodia.
\p 
\v 9 Iehova ese ma e hamaorogu, eto, Iuda taudia bona Ierusalem inoholaina taudia bogaragidiai haida na e gwau dagemu.
\v 10 Idia ese senedia, egu hereva ikamonaidia asie urava taudia, edia kara havara vada e lou heni, dirava idaudia muridiai vada ela, isiaidia bae lao heni totona. Israel besena bona Iuda besena taudia ese egu taravatu, senedia na henidia ḡauna, vada e tataia utu.
\v 11 Taunabunai, Iehova na ini e gwau tomamu: Lau ese dika na latadiai ba hadihoamu, basie roho mauri diba; ena be bae tai henigu, to basina kamonai.
\v 12 Bena Iuda hanuadia bona Ierusalem inoholaina taudia na baela, muramura mai bonadia e gabu henidiamu diravadia bae tai henidia, to edia hekwakwanai negana ai unu idia ese basie hamauridia diba.
\v 13 Badina be, Iuda e, emui dirava na emui hanua hohodia heḡereḡeredia; bona ihaboulaina patadia vada o hadai, sibomui ihahemaraimui, latadiai muramura mai bonadia Baal ba gabu henia totona, na Ierusalem ariaradia hohodia heḡereḡeredia.
\p 
\v 14 Taunabunai, ina bese taudia daidiai basio ḡuriḡuri; idia daidiai basio tai bona basio noinoi. Badina be edia hekwakwanai negana ai bae boi henigu, to lau na basina kamonai.
\v 15 Egu lalokau hahinena ese kara dikadia e karamu bena egu ruma ai e raka vareaimu na maoro eiava? Gwauhamata bona boubou ḡaudia hidiodia ese ihabua-tarimui baine laoa ahu diba a? Bena ba heaḡi diba a?
\v 16 Nega ta ai Iehova ese e gwauraimu “Olive auna maurina, huahuana e dobi badabadamu ḡauna”; a mai lai-gubana bada-hereana ida ia ese baine ha-araia, bena rigina bae ara ore.
\v 17 Iehova Sabaota, e hadomui Diravana, ese dika na latamui ai vada e gwauraia, badina be Israel besena bona Iuda besena vada e kara dika, bona vada e habadugu, muramura mai bonadia na Baal e gabu henia dainai.
\s1 Ieremia ihadikana e henegalaia
\q1 
\v 18 Iehova ese e hadibagu, bena na diba;
\q2 bena edia kara dika o haheitalaigu.
\q1 
\v 19 A lau na mamoe natuna manadana ta
\q2 bae alaia mase gabuna e hakaua laomu na heto.
\q1 Asi dibagu lau ihadikagu totona e henega bou, eto,
\q2 Au mai huahuana ida baita habuadia tari,
\q1 mauri taudia edia tano amo baita negea daure,
\q2 ia ladana basie laloa tao helaoreana.
\q1 
\v 20 A Iehova Sabaota e, oi ese o hahemaoro ḡoevaḡoevamu,
\q2 oi ese taunimanima lalodia bona daradia o dibadiamu;
\q1 emu dava-ihenina idia latadiai na bama itaia,
\q2 badina be egu dala na oi imamu ai vada na atoa.
\p 
\v 21 Taunabunai, hari Anatoto taudia, egu mauri iabi-ohona e tahuamu, e tomu “Iehova ladana ai basio peroveta, ai imamai amo ba mase na garina”, taudia na Iehova ese ini e herevalaia tomamu.
\v 22 Taunabunai, Iehova Sabaota na e tomu, A itaia, davadia baina henidia; eregabe taudia na dare ai bae mase; natudia mamaruanedia bona hahinedia na hitolo ese baine hamasedia;
\v 23 idia ta basine mauri. Badina be dika na Anatoto taudia latadiai baina hadihoa, edia dika davana ihenina laḡanina ai.
\c 12
\s1 Ieremia ese Iehova e tai henia
\q1 
\v 1 Iehova e, emu kara na maoromaoro,
\q2 na tai henimumu negadia ai;
\q1 ḡau tamona, egu ginikau gabuna herevadia na
\q2 oi vairamu ai baina gwaurai.
\q1 Badina be dahaka kara dika taudia edia dala na e namo e laomu?
\q2 Dahaka dainai kara dibaka taudia edia namo na e bada e laomu?
\q1 
\v 2 Oi ese o hadodiamu, bena ramudia na e hekaramu;
\q2 idia na e tubumu, e huahuamu;
\q1 ududia ai oi na kahikahi,
\q2 a lalodia ai oi na dauhai.
\q1 
\v 3 Iehova e, oi dibamu lau;
\q2 o itagumu, bona lalogu emu ai o dibaiamu.
\q1 Ba veridia lasi, bae aladia mamoedia na heheto;
\q2 bavatodia tabe, ala-ala dinana ena.
\q1 
\v 4 Tano baine taitai ela bona edena nega ai?
\q2 Gabu iboudiai reidia bae marai ela bona edena nega ai?
\q1 Tano inoholaina taudia edia kara dika daidiai,
\q2 tano boromadia bona manudia na e mase oremu;
\q1 badina be taunimanima na eto
\q2 “Eda dala dokona basine itaia”.
\b
\q1 
\v 5 Bema taunimanima ida o heau helulumu negadia ai taumu vada e boera,
\q2 hosi ida ede ba heau helulu toma?
\q1 Bona bema tano namona ai o ketomu,
\q2 ede ba kara toma Ioridane udana lalonai?
\q1 
\v 6 Badina be tadikakamu bona tamamu ena iduhu taudia ese danu
\q2 vada e kara dibaka henimumu;
\q2 bona mai lolodia ida e hahavamu.
\q1 Ena be bae hereva namo henimu,
\q2 to edia hereva basio abi dae.
\b
\q1 
\v 7 Egu ruma vada na rakatania,
\q2 ahugu vada na negea.
\q1 Egu lalokau hahinena na
\q2 inaina imadia ai vada na atoa.
\q1 
\v 8 Lau ahugu egu ai na uda leonana na heto;
\q2 vada e lolo henigu, una dainai na inai heniamu.
\q1 
\v 9 Ahugu egu ai na bogibada na heto a?
\q2 Vamu-ani manudia ese e daia ahumu a?
\q1 Aola, uda boromadia iboudiai ba haboudia;
\q2 ba hakaudia mai, bae ania ore.
\q1 
\v 10 Mamoe ireḡudia taudia hutuma ese egu vine imeana vada e habuaia tari,
\q2 egu inogo vada e moia tao;
\q1 egu inoḡo namona na
\q2 tano ḡaḡaena asi inoholaina ai vada e halaoa.
\q1 
\v 11 Idia ese vada e havahua,
\q2 vahuna ese e tai henigumu;
\q1 tano idoinai vada e vahu,
\q2 bona tau ta ese se laloamu.
\q1 
\v 12 Tano-gaḡaena ororodia nemuka-nemukadia iboudiai latadiai,
\q2 hahebua-tari taudia vada e kau;
\q1 badina be Iehova ena dare na e ala-alamu,
\q2 tano hetoana dokona ta amo ela bona hetoa kahana dokona,
\q2 ta asine mainomu.
\q1 
\v 13 Idia ese uit vada e hadoa, to au giniginidia vada e utu;
\q2 vada e hekwarahi mase, to edia hekwarahi na asi anina.
\q1 Edia taboro daidiai bae hemarai,
\q2 Iehova ena badu ḡaraḡara dainai.
\b
\p 
\v 14 Dekegu taudia dikadia, egu bese Israel ahuna, vada na henidia bae ḡaunaia tanona, e dadia tohomu taudia, iboudiai na Iehova ese ini e herevalaidia tomamu: A itaia, edia tano amo baina dabuidia lasi, bona idia bogaragidia amo Iuda iduhuna baina dabuia lasi.
\v 15 Bena vada na dabuia lasi murinai ma baina bogadia hisi bona baina loulaidia, ta ta ahuna ahuna bona ta ta ena tano ena tano ediai.
\v 16 Una negana ai ia ese egu bese taudia edia dala bema tahu goadagoada, bona lau ladagu ai bema gwau hamata, bema toma “Iehova na e maurimu heḡereḡerena”, guna egu bese taudia na Baal ladana igwau-hamatalaina e hadibadiava na heto; bena idia na egu bese taudia bogaragidiai baina haginidia.
\v 17 A bese ta basinema kamonai, bena lau ese baina dabuia lasi vaitani bona baina habuaia tari. Iehova na e herevamu.
\c 13
\s1 Hereva heḡereḡerena: Riorio dabuana e mouka-mouka
\p 
\v 1 Iehova ese ini e hamaorogu toma: Aola, riorio dabuana aukana ta ba hoia, bena ba rioa, ranu ai basio urua diho.
\v 2 Taunabunai lau ese riorio dabuana ta na hoia, Iehova ena hereva heḡereḡerena, bena na rioa.
\v 3 Bena nega iharuana Iehova ena hereva na egu ai e kau, eto,
\v 4 Vada o hoia bona o rioamu dabuana avabia, ba tore isi, Eufrate sinavaina baola, unuseni ai nadi kohua-kohuana ta ai ba hunia.
\v 5 Taunabunai lau nala, Eufrate sinavaina badibadinai na hunia, Iehova ese e haganigu heḡereḡerena.
\p 
\v 6 Dina hoho muridiai Iehova ese ma e hamaorogu, eto, A tore isi, Eufrate sinavaina baola, vada na haḡanilaimu bena unuseni ai o hunia dabuana na unu amo ma bavabia lou.
\v 7 Bena Eufrate sinavaina nala, tano na ḡeia, hari riorio dabuana na na hunia gabuna amo ma na abia. A na itaia, una norio dabuana vada e mouka-mouka; ia na negenege ḡauna mo.
\p 
\v 8 Bena Iehova ena hereva na egu ai e kau, eto,
\v 9 Iehova ini e gwau tomamu: Lau ese Iuda ena heaḡi bona Ierusalem ena heaḡi-bada na ene baina hadikadia toma.
\v 10 Ina kara dika besena, egu hereva ikamonaidia asie uramu to sibodia edia lalo-hadai e ḡavadiamu mai lalo-aukadia ida, bona dirava idaudia muridia amo e laomu, isiaidia bae lao heni bona bae toma henidia diho totona, taudia na ina riorio dabuana, negenege ḡauna, heḡereḡerena ai baela.
\v 11 Badina be riorio ḡauna na tau ta koekoena ai e herio kunuka-kunuka na heto, lau ese Israel besena idoinai bona Iuda besena idoinai na koekoegu ai na riodia kunuka-kunuka, egu ai bese ta bona lada ta bona heimodai ta bona hairai ta ai bema lao; a idia na asie ura bae kamonai. Iehova na e herevamu.
\s1 Hereva heḡereḡerena: Vine ranuna hodudia
\p 
\v 12 Ina hereva ba hamaorolaidia, baoto, Iehova, Israel Diravana, na ini e gwau tomamu: Hodu iboudiai na vine ranuna ai bae honu. Bena bae haere henimu, baeto “Ai na asi dibamai hodu iboudiai na vine ranuna ai bae honu a?”.
\v 13 Bena ba hamaorodia, baoto, Iehova ini e gwau tomamu: A itaia, lau ese ina tano inoholaina taudia iboudiai na baina hakekerodia vaitani - pavapava, David ena terono ai e helaimu taudia, bona hahelaḡa taudia, bona peroveta taudia, bona Ierusalem inoholaina taudia iboudiai.
\v 14 Bena baina huaridia, ta ta, tama bona natuna, tama bona natuna, bae hehuari heheni. Basina bogadia hisi, basina hamauridia, ihabua-taridia ai basina bogalaidia. Iehova na e herevamu.
\s1 Iuda ena lalo-auka davana
\q1 
\v 15 A kamonai, taiamui a hakala, basio hekokoroku;
\q2 badina be Iehova vada e hereva.
\q1 
\v 16 Iehova, emui Dirava, ba imodaia,
\q2 ia ese tano do se hadiburaiamu negana ai,
\q1 ororo do asie vabura-vabura
\q2 bena aemui do asie hetutuhi negana ai,
\q1 diari ba tahua a ia ese vabura ai baine halaoa
\q2 bona dibura masemase baine havaraia
\q1 negana do se kau ai,
\q2 ia ba imodaia.
\q1 
\v 17 A basioma kamonai,
\q2 bena lalogu baine tai hehuni, emui hekokoroku dainai;
\q1 baina tai dikadika, iruru-matagu bae diho,
\q2 badina be Iehova ena mamoe serina na vada e abia mauri.
\b
\q1 
\v 18 Hanua pavapavana mai sinana ida ba hamaorodia,
\q2 baoto: Henu ai ba helai;
\q1 badina be emui havava ḡauna herea-daena na
\q2 kwaramui amo vada eme heabi oho.
\q1 
\v 19 Diho kahana hanuadia vada e hekou ahu,
\q2 asi ikehodia tauna ta;
\q1 Iuda taudia iboudiai na vada e laohaidia, gabu daudau ai vada e hanohodia;
\q2 vada e laohaidia vaitani.
\b
\q1 
\v 20 Matamui a gaga isi,
\q2 mirigini kahana amo e maimu taudia ba itadia.
\q1 Mamoe serina, e henimu ḡauna, na edeseni ai?
\q2 Emu mamoe serina herea-daena be edeseni ai?
\q1 
\v 21 Emu ai vada o hamanadadia
\q2 bona turamu ai vada o halaodia taudia na
\q1 ikwaramu taudia ai bae halaodia negana ai,
\q2 ede ba hereva toma?
\q1 Hisihisi ese basine gugubamu,
\q2 hahine ena hekamonai hisidia na heheto, a?
\q1 
\v 22 Bena lalomu boma tahua, boma toma
\q2 “Dahaka dainai ini ḡau na latagu ai vada e kau?”;
\q1 emu kara dika bada-hereana dainai ramimu vada e abia isi,
\q2 bena vada e hadikamu.
\b
\q1 
\v 23 Etiopia tauna ese kopina baine ha-idaua,
\q2 eiava taiga ese kopina toutouna baine ha-idaudia, a?
\q1 Bema unuheto, umui kara dikadia vada o manadailai taumui ese
\q2 kara namodia ba kara diba.
\q1 
\v 24 Lau ese baina hakarohomui rohoroho,
\q2 lai tano ḡaḡaena amo ese uit momodia e oda ohomu na heto.
\q1 
\v 25 Iehova na e tomu: Oi ahumu binai,
\q2 vada na hahetoho henimu ḡauna;
\q1 badina be vada o lalogu boio,
\q2 bona hereva koikoidia vada o abidadama heni.
\q1 
\v 26 Lau sibogu ese vairamu ramina baina abia isi,
\q2 bona emu hemarai badina baine hedinarai.
\q1 
\v 27 Emu kara dika-rohorohodia vada na itadia,
\q2 emu heuda-hanai bona emu tubebe,
\q2 bona emu lebulebu karadia ororo gabaedia ai.
\q1 Ierusalem e, madi ihabaimu!
\q2 Ela bona edena nega ai ba haheḡoeva?
\c 14
\s1 Doe herevana
\p 
\v 1 Ina doe herevana na Iehova ena amo Ieremia enai e kau, eto:
\q1 
\v 2 Iuda na e taitaimu,
\q2 ena ikoukou na e manokamu;
\q1 ena taunimanima na tano ai e rohe ahumu,
\q2 bona Ierusalem ena taitai na e daemu.
\q1 
\v 3 Ena lohia ese edia hesiai taudia na e siaidia laomu,
\q2 ranu bae utu totona;
\q1 idia ese ranu gabudia e lao henidiamu,
\q2 a ranu asie davariamu;
\q1 edia hodu na asi anidia e loulaidiamu,
\q2 e hemaraimu bona e baiamu,
\q2 kwaradia e ḡovadia ahumu.
\q1 
\v 4 Ruarua taudia daradia e dokomu,
\q2 medu na tano ai se dihomu dainai;
\q1 biru taudia na e hemaraimu,
\q2 kwaradia e ḡovadia ahumu.
\q1 
\v 5 Dia hahinena tano paka ai ese natuna, vara matamata ḡauna, na e rakataniamu,
\q2 rei lasi dainai;
\q1 
\v 6 uda donikidia na ororo nemuka-nemukadia ai e ginimu,
\q2 e laḡa dae laḡa daemu, uda sisiadia na heheto,
\q1 matadia na e valahu-valahumu,
\q2 aniani avadia lasi dainai.
\b
\q1 
\v 7 Iehova e, ena be emai kara havara ese e habadelaimaimu,
\q2 to oi ladamu bagunai ba ḡaukara;
\q1 badina be emai raka-muri na momo,
\q2 ai ese vada a kara dika henimu.
\q1 
\v 8 Israel ena helaro e,
\q2 ena hahemauri dika negadia ai,
\q1 anina be dahaka tano ai ba noho idau tauna na heto,
\q2 eiava laolao tauna dala amo e raka sirimu, ena mahuta gabuna e tahuamu, na heto?
\q1 
\v 9 Anina be dahaka daradara tauna heḡereḡerena ai baola,
\q2 eiava goada tauna hahemauri karadia asi dibana heḡereḡerena ai?
\q1 Ḡau tamona, Iehova e, oi na ai bogaragimai ai,
\q2 bona ai na oi ladamu vada e henemailaimai;
\q2 basio rakatanimai.
\b
\q1 
\v 10 Iehova ese ina bese na ini e herevalaia tomamu:
\q2 Unu loa-kava loa-kava daladia mo e ura henidia bona aedia na asie rudia dainai,
\q2 Iehova ese se abidia daemu;
\q1 harihari edia kara havara baine lalodia tao,
\q2 bona edia kara dika davadia baine henidia.
\p 
\v 11 Iehova ese e hamaorogu, eto: Ina bese taudia edia noho-namo basio ḡuriḡurilaia.
\v 12 Ena be e anivagamu, to edia taitai basina kamonai; ena be gole-oho bouboudia bona flaoa bouboudia bae hahelaḡad-ia, to basina abidia dae; a dare amo bona doe amo bona dai-hanai goreredia amo baina aladia mase.
\p 
\v 13 Bena lau nato, Ḡaubada Iehova e, a itaia, peroveta taudia ese vada e hamaorodiamu, e tomu “Dare basio itaia bona doe basio mamia, a lau ese maino korikori baina henimui ina gabu ai”.
\v 14 Bena Iehova ese e hamaorogu, eto, Peroveta taudia ese hereva koikoidia e gwauraimu lau ladagu ai; lau ese asina siaidia, bona asina haḡanidia eiava asina hereva henidia. Idia ese mata-hanai koikoina bona bagu-haoro asi anina bona sibodia edia lalo-hadai koikoidia na e perovetalai henimuimu.
\v 15 Taunabunai, hari peroveta taudia, lau ladagu ai e perovetamu to asina siaidiamu taudia, e gwaumu “Dare bona doe na ina tano ai basie kau” taudia, na Iehova ese ini e herevalaidia tomamu: Unu peroveta taudia na dare bona doe ese baine ha-oredia;
\v 16 bona e peroveta henidiamu taudia na Ierusalem ariaradia ai bae negedia lasi, doe bona dare ese bae aladia mase, bena idia bona adavadia bona natudia mamaruanedia bona hahinedia iguridia tauna ta basine noho; badina be idia sibodia edia kara dika na idia latadiai ma baina bubu.
\p 
\v 17 Ina hereva ba hamaorolaidia, baoto:
\q1 Iruru-matagu bae diho boi bae diho rani,
\q2 idia na basie doko;
\q1 badina be egu bese natuna hane-ulato rami-hebouna vada e haberoa dikadika,
\q2 vada e rahua mase.
\q1 
\v 18 Tano paka ai bama raka lasi,
\q2 a itaia, dare ai vada e mase taudia mo;
\q1 bona hanua ai bama raka vareai,
\q2 a itaia, doe ese e havaradia goreredia mo.
\q1 Badina be peroveta tauna bona hahelaḡa tauna ese
\q2 edia ḡaukara na tano idoinai e karamu,
\q2 to asi aonegadia.
\b
\q1 
\v 19 Iuda vada o dadaraia vaitani a?
\q2 Oi laumamu ese Siona e inai heniamu a?
\q1 Dahaka dainai vada o rahumai mamase,
\q2 bena asi ihamaurimai dalana?
\q1 Maino a tahua, a ḡau namona ta se vara;
\q2 ihamaurimai dalana a tahua, a hahegari mo a davaria.
\q1 
\v 20 Iehova e, emai kara dika a gwaurai hedinaraimu,
\q2 bona tamamai edia kara havara danu;
\q2 badina be vada a kara dika henimu.
\q1 
\v 21 Oi ladamu bagunai basio dadaraimai,
\q2 emu terono herea-daena basio hahemaraia;
\q1 ba helalo tao,
\q2 bona emu gwauhamata emai ai na basio tataia utu.
\q1 
\v 22 Bese idau-idau edia dirava bogaragidiai
\q2 ta ese medu ihadihona mai dibana a?
\q1 Eiava guba sibona ese
\q2 batugu baine hadihoa a?
\q1 Iehova e, emai Dirava, oi benai ani?
\q2 Emai helaro na oiemu ai,
\q2 badina be oi ese ini ḡau iboudiai o karadiamu.
\c 15
\s1 Iehova ena badu se dokomu Iuda latanai
\p 
\v 1 Bena Iehova ese e hamaorogu, eto, Ena be Mose bona Samuel na vairagu ai bema gini, to lalogu basinema heḡereḡere ina bese taudia bama hageredia. Vairagu amo ba siaidia oho, ba kahudia nege!
\v 2 Bena bae nanadaimu, baeto “Ede baiala?”, negana ai, ba hamaorodia, baoto, Iehova na ini e gwau tomamu:
\q1 Dai-hanai gorerena ena, dai-hanai gorerena ese baine abidia,
\q2 bona dare ena, dare ese baine abidia;
\q1 doe ena, doe ese baine abidia,
\q2 bona abi-mauri ena, vada bae abidia mauri.
\p 
\v 3 Iehova ma e tomu: Lau ese hahebua-tari ḡaudia hani baina duanaidia, bae biagudia: dare, iala-masedia totona; sisia, idaredia totona; bona atai manudia bona uda boromadia, iani-oredia bona ihabua-taridia totona.
\v 4 Lau ese hahegari ḡauna ai baina halaodia, tanobada basileiadia iboudiai ediai, Manase Hesekia, Iuda pavapavana, ese Ierusalem ai e karaia ḡauna dainai.
\b
\q1 
\v 5 Ierusalem e, daika ese baine bogamu hisi?
\q2 Daika ese oi taimu baine tai?
\q1 Daika baine raka siri,
\q2 oiemu noho dalana inanadailaina totona?
\q1 
\v 6 Iehova na e tomu: Vada o dadaraigu,
\q2 bona murimu kahana o lao henia louloumu;
\q1 taunabunai, lau imagu vada na toia roro, oi ihadikamu totona,
\q2 bona vada na habuamu tari;
\q2 hebogahisi ai na hesikumu.
\q1 
\v 7 Itapo amo vada na tapodia hidi,
\q2 tano ikoukoudia ai;
\q1 egu hahemase ese natudia na edia amo vada e abidia oho,
\q2 egu bese taudia vada na habuadia tari;
\q2 idia na edia dala amo asie raka siri.
\q1 
\v 8 Edia vabu vada na hahutumadia,
\q2 kone mirina na heto;
\q1 dina tubua ai hahebua-tari tauna vada na siaia,
\q2 eregabe taudia sinadia ihadikadia totona;
\q1 hisihisi-bada bona gari-bada na
\q2 latadiai vada na hadiho taku.
\q1 
\v 9 Natuna hahitu e havaradia hahinena na tauna vada e manori,
\q2 vada e mase rea;
\q1 do dina ai iena dina vada e diho,
\q2 vada e hahemaraia bona vada na dadaraia.
\q1 Idia taudia oredia na dare baina henia, inaidia vairadiai.
\q2 Iehova na e herevamu.
\b
\p 
\v 10 Sinagu e, madi ihabaigu! O havaragu, heai bona hepapahuahu taugu, tano idoinai enai. Asina heni torehai bona asina abi torehai, to idia iboudiai ese e uduguiraigumu.
\v 11 Iehova e, bema asina noimu, idia ihanamodia totona, bona inai taudia daidiai asina noi henimu, hekwakwanai bona hisi-ani negadia lalodiai, unu bema vara toma.
\v 12 Auri, mirigini kahana aurina, bona auri labora-laborana, na ta ese baine hakwaidua diba, a?
\p 
\v 13 Emu taḡa bona emu kohu namodia na dadidadi ḡaudia ai baina halaodia, asi davadia, emu kara dika iboudiai daidiai, emu tano hetoadia iboudiai lalodiai.
\v 14 Oi inaimu edia hesiai tauna ai baina halaomu, asi dibamu tanona ai, badina be egu badu ese lahi ta vada e ha-araia, bena baine ara hanaihanai.
\s1 Iehova ena gwauhamata Ieremia enai
\q1 
\v 15 Iehova e, oi dibamu;
\q2 ba lalogu tao, ba vadivadigu;
\q1 bona e hahisihisigumu taudia na davadia ba henidia,
\q2 lau daigu ai.
\q1 Emu haheauka ai basio abigu oho;
\q2 ba diba, oi daimu ai hereva metaudia na huamu.
\q1 
\v 16 Emu hereva na davaridia, bena na anidia,
\q2 emu hereva ese e hamoalegu,
\q2 lau lalogu ihamoalena ḡaudia ai ela;
\q1 badina be Dirava, Iehova Sabaota e,
\q2 lau be oi ladamu vada na henemailaia.
\q1 
\v 17 E moale hebouva taudia bogaragidiai asina helai,
\q2 bona asina moale.
\q1 Sibogu na helai, badina be oi imamu na latagu ai;
\q2 badina be oi ese badu ai o hahonugu.
\q1 
\v 18 Dahaka dainai egu hisihisi na asi dokona,
\q2 bona berogu na asi ihanamona,
\q2 se uramu baine namo lou?
\q1 Oi na sinavai-sinavai koikoina heḡereḡerena ai baola egu ai,
\q2 e kororomu ranudia heḡereḡeredia ai a?
\b
\q1 
\v 19 Taunabunai Iehova ini e gvau tomamu:
\q2 Boma lou mai, bama haginimu lou,
\q2 bena vairagu ai boma gini.
\q1 Bema hereva namo-hereadia ba gwaurai, dia hereva asi anidia,
\q2 oi na lau udugu heḡereḡerena ai baola.
\q1 Idia ese bae haḡeregu,
\q2 a oi ese basio haḡeredia.
\q1 
\v 20 Bena ina bese taudia ediai
\q2 lau ese auri-laboralabora maguna aukana ai baina halaomu;
\q1 idia ese bae tuari henimu,
\q2 to basie hadareremu;
\q1 badina be lau na oi ida,
\q2 oi ihamaurimu bona irauamu totona.
\q2 Iehova na e herevamu.
\q1 
\v 21 Kara dika tauna imana amo baina rauamu,
\q2 bona asi ena hebogahisi tauna imana amo baina hamaurimu.
\c 16
\s1 Iehova ena hahemaoro
\p 
\v 1 Iehova ena hereva na egu ai e kau, eto:
\v 2 Hahine ta basio adavaia, bona natumu mamaruanedia eiava hahinedia basio havaradia ina gabu ai.
\v 3 Badina be Iehova ese ina tano ai e varamu memerodia bona kekenidia, bona e abidia hahinedia bona e havaradia taudia na ini e herevalaidia tomamu:
\v 4 Idia na mase goreredia amo bae mase. Haida ese basie rohedia ahu bona basie guridia; idia na tano kopina ai bae mia, boromakau taḡena na heto. Dare bona doe ese bae hamasedia, bena tau-ani masedia na atai manudia bona uda boromadia adia aniani ai baela.
\p 
\v 5 Badina be Iehova na ini e gwau tomamu: Taitai rumana lalonai basio raka vareai, rohe-ahu totona basiola, basio tailaidia; badina be egu maino bona egu lalokau bona egu hebogahisi na ina bese taudia edia amo vada na abi oho. Iehova na e herevamu.
\v 6 Kikina-badana na ina tano ai bae mase; haida ese basie guridia; bona tau ta ese basine tailaidia, eiava basine tai hekakasi eiava kwarana basine naua, idia daidiai.
\v 7 Ta ese aniani basine dabaraia taitai tauna ana, mase dainai tauna baine haloa totona; bona ta ese tauhalo keherena basine henia, tamana eiava sinana daidiai baine inua totona.
\v 8 Aria rumana lalonai basio raka vareai, aria taudia ida basio helai hebou, idia ida basio aniani bona basio inuinu.
\v 9 Badina be Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: A itaia, umui vairamui ai bona umui emui nega ai, kiri reḡedia bona moale reḡedia, headava matamata tauna gadona bona headava matamata hahinena gadona, na ina gabu ai baina hadokodia.
\p 
\v 10 Ini hereva iboudiai na ina bese taudia ba hamaorodia negana ai, idia ese bae hereva henimu, baeto, Dahaka dainai Iehova ese ina dika badana idoinai na ai latamai ai vada e gwauraia? Emai kara havara be dahaka? Emai kara dika, Iehova, emai Dirava, enai vada a karaia, be dahaka?
\v 11 Una negana ai oi ese ba haere henidia, baoto, Iehova na e tomu: Badina be tamamui ese vada e rakatanigu, dirava idaudia muridia amo vada ela, isiaidia vada e lao heni, bona vada e toma henidia diho; lau vada e rakatanigu bona egu taravatu asie badinaia,
\v 12 bona tamamui edia kara dika vada o hereadia; a itaia, iboumui ai emui ura dikadia auka-hereadia o badinadiamu, bona asio uramu lau ba kamonai henigu.
\v 13 Taunabunai, lau ese ina tano lalona amo baina tahomui lasi, umui asi dibamui bona tamamui asi dibadia tanona ai, unuseni ai dirava idaudia isiaidia ba lao heni, dina ai bona hanuaboi ai; badina be lau ese basina lalo namo henimui.
\p 
\v 14 Iehova na e tomu: Taunabunai ba itaia, dinadia na e maimu, taunimanima na basie hereva lou, basieto “Iehova; Israel taudia na Aigupto tanona amo e hakaudia lasi Diravana, e maurimu heḡereḡerena”,
\v 15 a baeto “Iehova, Israel taudia na mirigini kahana tanona amo bona e luludia lao tanodia iboudiai amo vada e loulaidia Diravana, e maurimu heḡereḡerena”. Badina be lau ese ma baina hakaudia lou, edia tano korikori, senedia na henidia tanona, lalonai.
\p 
\v 16 Iehova na e tomu: A itaia, haoda taudia hutuma na boiridiamu; idia ese bae aladia. Una murinai, labana taudia hutuma baina boiridia; bena ororo badadia bona maraḡidia iboudiai latadiai bae tahudia, bona kohuakohua lalodiai danu.
\v 17 Badina be lau matagu ese edia dala iboudiai e raraidiamu; egu ai idia na asie hehunimu, bona edia kara-havara na lau matagu amo asie helavahumu.
\v 18 Edia kara havara bona edia kara dika davadia baina henidia harua, badina be idia ese egu tano na edia kaivakuku dika-hereadia tau-anidia amo vada e hamiroa, bona lau ahugu tanona na edia ḡau dika-rohorohodia amo vada e hahonua.
\b
\q1 
\v 19 Iehova e, egu goada bona egu gabu-aukana,
\q2 egu roho-mauri gabuna, hekwakwanai dinana ai;
\q1 tanobada dokodia amo
\q2 bese iboudiai bae vasi, baeto:
\q1 Tamamai ahudia na koikoi mo,
\q2 ḡau asi anidia bona asi namodia.
\q1 
\v 20 Tau ta ese sibona ena dirava baine karadia diba a?
\q2 Unuhetomadia na dia dirava.
\b
\p 
\v 21 Taumabunai, a itaia, lau ese baina hadibadia, ina nega tamona egu siahu bona egu goada baina hadibalaidia, bona bae diba lau ladagu na Iehova.
\c 17
\s1 Iuda taudia lalodia vada e kerere
\p 
\v 1 Iuda taudia edia kara dika na auri purina amo vada e torea; vasiga matana amo idia lalodia ai vada e gasia, bona edia ihaboulaina patadia doadia ai;
\v 2 bona natudia ese danu edia ihaboulaina patadia e lalodia taomu, bona edia au-tubua helaḡadia danu, au mauridia iboudiai badibadidiai, bona ororo doridia ai,
\v 3 bona tano paka ororodia ai. Emu taḡa bona emu kohu namodia iboudiai na haida baina henidia, edia dadidadi ḡaudia, emu kara dika davana emu tano idoinai lalonai.
\v 4 Imamu na ahumu, na henimu ḡauna, amo do bavabia oho, bena baina siaimu, asi dibamu tanona ai inaimu isiaidia ba lao heni; badina be egu badu ai lahi ta vada e ara, bona baine ara hanaihanai.
\b
\p 
\v 5 Iehova ini e gwau tomamu:
\q1 Taunimanima e abidadama henidiamu,
\q2 bona hidio na ena goada badina ai e halaoamu,
\q1 bona lalona na Iehova ena amo e raka ohomu,
\q2 tauna na bae uduguiraia.
\q1 
\v 6 Ia na au rabatarina tano kaukauna ai na heto;
\q2 ḡau namona ta ia vairanai basine hedinarai.
\q1 Tano ḡaḡaena haura-hauradia ai baine noho,
\q2 laguta ai, tau ta ese se noholaiamu tanona ai.
\b
\q1 
\v 7 Iehova e abidadama heniamu tauna na namo;
\q2 ena heabidadama na Iehova.
\q1 
\v 8 Ia na ranu badinai e hadoamu auna na heto,
\q2 ia ramuna na e hetoimu, sinavai badibadinai;
\q1 siahu negana ai ia na se garimu,
\q2 badina be ia rauna dounu e maurimu;
\q1 laḡani dikana ai ia na se hekwarahimu,
\q2 badina be huahuana ihavarana se hadokoamu.
\b
\q1 
\v 9 Taunimanima lalodia na koikoi herea bona dika rohoroho,
\q2 daika ese baine dibadia?
\q1 
\v 10 Lau Iehova ese taunimanima daradia na tahudiamu,
\q2 bona lalodia na tohodiamu,
\q1 taunimanima ta ta ena dala ena dala
\q2 bona ena kara anina ena kara anina heḡereḡeredia
\q2 baina henidia totona.
\b
\q1 
\v 11 Aba ese natuna, se hapapadia ḡaudia, na e haboudiamu na heto,
\q2 taḡa e habouamu, a dia kara maoromaoro amo, tauna na unuheto;
\q1 ena mauri bogaraginai idia ese bae rakatania,
\q2 bona ena mauri dokona ai ia na kavakava tauna ai bainela.
\q1 
\v 12 Matamana amo atai ai e atoa teronona helea-daena na
\q2 eda gabu helaḡana.
\q1 
\v 13 Iehova e! Israel ena helaro e!
\q2 E rakatanimu taudia iboudiai na bae hahemaraidia;
\q1 oiemu amo e raka murimu taudia ladadia na tanobada ai mo bae hetore,
\q2 badina be Iehova, mauri ranuna lohilohina, vada e rakatania.
\b
\q1 
\v 14 Iehova e, ba hanamogu, bena do baina namo;
\q2 ba hamaurigu, bena do baina mauri;
\q2 badina be oi na egu heimodai Diravana.
\q1 
\v 15 A itaia, idia ese e hereva henigumu, e tomu
\q2 “Iehova ena hereva be edeseni ai? Bainema!”
\q1 
\v 16 Lau ese asina noimu dika ba siaia,
\q2 bona hahebua-tari dinana asina uralaia;
\q2 oi danu dibamu;
\q1 udugu bibinadia amo e lasi herevana na
\q2 oi vairamu ai mo e lasi.
\q1 
\v 17 Basio hagarigu;
\q2 oi na egu roho-mauri gabuna, dika e kaumu dinana ai.
\q1 
\v 18 E hahisihisigumu taudia na bae hahemaraidia,
\q2 a lau na basie hahemaraigu;
\q1 idia na kudoudia bae hetaha,
\q2 a lau kudougu basine hetaha;
\q1 dika dinana na latadiai ba hadihoa,
\q2 ba habuadia tari vaitani.
\s1 Dina Helaḡa ihahelaḡana
\p 
\v 19 Iehova ese ini e hereva henigu toma, eto: Aola, Beniamina Ikoukouna, Iuda pavapavadia e raka vareaimu bona e raka lasimu ikoukouna, enai ba gini, bona Ierusalem ikoukoudia iboudiai ediai danu.
\v 20 Bena baoto: Iuda pavapavamui bona Iuda taumui iboumui ai bona Ierusalem inoholaina taumui iboumui ai, ini ikoukou amo o raka vareaimu taumui, Iehova ena hereva ba kamonai.
\v 21 Iehova ini e gwau tomamu: Emui mauri nahuadia ba toho, Dina Helaga ai maduna ta basio huaia, eiava ini Ierusalem ikoukoudia amo basio vareailaia,
\v 22 bona Dina Helaga ai maduna ta na emui ruma amo basio huaia lasi. A Dina Helaḡa na ba hahelaḡaia, lau ese senemui na haḡanilaidia heḡereḡerena.
\v 23 Ḡau tamona, idia na asie kamonai, taiadia asie hakala, a aiodia e ha-aukadia, basie kamonai bona hahediba herevadia basie abi dae dainai.
\p 
\v 24 Iehova na e tomu: Boma kamonai henigu, Dina Helaḡa ai maduna ta ina hanua ikoukoudia amo basioma vareailaia, a Dina Helaḡa na boma hahelaḡaia bona ia lalonai ḡaukara ta basioma karaia;
\v 25 bena pavapava haida, David ena terono ai e helaimu taudia, na ina hanua ikoukoudia amo bae heau vareai, kariota ai bona hosi latadiai, idia bona edia lohia taudia, Iuda taudia bona Ierusalem inoholaina taudia; bena ina hanua na bae noholaia hanaihanai.
\v 26 Bena taunimanima na Iuda hanuadia bona Ierusalem hegegemadaina hanuadia bona Beniamina tanona bona taora tanodia bona ororo tanodia bona diho kahana tanodia amo baema, ḡole-oho boubou ḡaudia bona boubou idau-idau ḡaudia bona naoa boubou ḡaudia bona muramura mai bonadia na bae mailai, bona hahenamo herahiadia danu bae mailai, Iehova ena dubu lalonai bae vareailai.
\v 27 A basioma kamonai henigu, Dina Helaḡa basioma hahelaḡaia, bona Dina Helaḡa ai maduna ta boma huaia, Ierusalem ikoukoudia ai boma vareailaia; bena lau ese lahi ta baina ha-ariaa ena ikoukou ai, bena una lahi ese Ierusalem ena lohia rumadia baine aradia ore; tau ta ese basine habodoa.
\c 18
\s1 Hereva heḡereḡerena: Uro ikarana tauna
\p 
\v 1 Iehova ena hereva Ieremia enai e kau, eto:
\v 2 A tore isi, uro ikarana tauna ena ruma a diho henia lao, unuseni ai baina hereva henimu.
\v 3 Taunabunai, uro ikarana tauna ena ruma na diho henia lao, unuseni ai ena uro na igirogirona patana ai e ḡaukaralaiava.
\v 4 E karaiava urona na uro ikarana tauna imana ai e dika; bena ia ese e kuia lou, uro idauna ta e karaia, uro ikarana tauna ena lalo-hadai heḡereḡerena.
\p 
\v 5 Bena Iehova ena hereva na egu ai e kau, eto:
\v 6 Israel besena e, ina uro ikarana tauna vada e karaia heḡereḡerena ai lau ese basina kara henimu diba a? Iehova na e herevamu. Israel besena e, a itaia, raro na uro ikarana tauna imana ai na heto, umui na lau imagu ai.
\v 7 Bema nega ta ai lau ese bese ta eiava basileia ta baina herevalaia, bainato baina butua oho, baina hahegiḡia dobi, baina habuaia tari;
\v 8 bena una na herevalaia besena ese ena kara dika baine rakatania, lau na baina helalo kerehai, bona na haeroa karana, ia ihadikana karana, na basina kara henia.
\v 9 Bona bema nega ta ai lau ese bese ta eiava basileia ta baina herevalaia, bainato baina haginia bona baina hadaia,
\v 10 bena ia na lau vairagu ai baine kara dika bona lau gadogu basine kamonai, lau na baina helalo kerehai, bona na haeroa karana, ia ihanamona karana, na basina karaia.
\v 11 Taunabunai, harihari Iuda taudia bona Ierusalem inoholaina taudia na ba hamaorodia, baoto, Iehova ini e gwau tomamu: A itaia, lau ese umui ihadikalaimui karana ta na hegaegaelaiamu bona ihadikalaimui dalana ta na haeroa heḡaeḡaemu. Ibouboumui ai emui dala dikadia amo ba lou, bona emui dala bona emui kara ba haḡoevadia.
\p 
\v 12 A idia na e tomu, Una na asi anina; ai na sibomai emai lalo-hadai baia badinadia, bona ta ta emai lalo-hadai dikadia baia goadalai, mai lalo-aukamai ida.
\p 
\v 13 Taunabunai Iehova na ini e gwau tomamu:
\q1 Bese idau-idau bogaragidiai ba henanadai,
\q2 daika ese hereva inihetomana vada e kamonai?
\q1 Hane-ulato rami-hebouna Israel ese
\q2 ḡau dika-rohorohona ta vada e karaia.
\q1 
\v 14 Lebanon \it snow\it*-dia na Sirion hagadia amo e veve ohomu a?
\q2 Ororo ranudia, sinavai keruma-kerumadia, e kororomu a?
\q1 
\v 15 A lauegu bese taudia ese vada e lalogu boio;
\q2 muramura mai bonadia na dirava koikoidia e gabu henidia.
\q1 Idia na edia dala ai vada e hetutuhi,
\q2 sene negana daladia;
\q1 uda daladia ai vada e raka,
\q2 dia laolao dalana ai.
\q1 
\v 16 Edia tano na hahegari ḡauna ai vada e halaoa,
\q2 bae si henia hanaihanai ḡauna;
\q1 e rakaia hanaimu taudia iboudiai na gari ese e butudia taomu,
\q2 bona kwaradia e taiko-taikomu.
\q1 
\v 17 Laurabada na heto baina odadia rohoroho inaidia vairadiai,
\q2 baina muri henidia, basina vaira henidia, edia hahedika dinana ai.
\s1 Ieremia ena ḡuriḡuri
\p 
\v 18 Bena idia eto, Aoma, Ieremia ihadikana daladia baita haero, badina be taravatu na hahelaḡa tauna enai basine boio, bona hahealo herevadia na aonega tauna enai basie boio, bona hereva na peroveta tauna enai basine boio. Aoma, baita uduguiraia, bona ena hereva ta basita abia dae.
\q1 
\v 19 Iehova e, a hakala henigu,
\q2 egu noinoi a kamonai!
\q1 
\v 20 Dika be namo davana a?
\q2 Ḡau tamona guri ta vada e ḡeia,
\q2 egu mauri iabi-ohona totona.
\q1 Ba laloa tao, lau na oi vairamu ai na gini,
\q2 idia ihanamodia herevadia baina gwaurai totona,
\q2 bona emu badu na idia edia amo baina laoa ahu totona.
\q1 
\v 21 Taunabunai, natudia na doe amo ba hahitolodia,
\q2 dare ena siahu henunai bavatodia,
\q2 adavadia na ba hagabanidia bona ba havabudia.
\q1 Edia tatau na dai-hanai gorerena ese baine hamasedia,
\q2 bona edia uhau na dare ese baine aladia mase tuari lalonai.
\q1 
\v 22 Dadidadi taudia ba siaidia bena bae hahoadia negana ai,
\q2 taitai na edia ruma amo baine hekamonai;
\q1 badina be guri vada e ḡeia lau iabigu totona,
\q2 bona idoa vada e atodia, lau aegu idoadia totona.
\q1 
\v 23 Ḡau tamona, Iehova e, edia kara iboudiai oi dibamu,
\q2 idia na e henega boumu, lau iala-masegu totona.
\q1 Edia kara havara basio gwaua tao;
\q2 edia kara dika na oi vairamu amo basio kokia oho.
\q1 Oi vairamu ai bae darere;
\q2 emu badu negana ai ba kara henidia.
\c 19
\s1 Hereva heḡereḡerena: hodunodu e makohi
\p 
\v 1 Iehova ini e gwau toma: Aola, uro ikarana tauna ena hoduhodu ta ba hoia, bena hanua taubadadia haida bona hahelaḡa taudia badadia haida na bavabidia;
\v 2 bena ba raka lasi, Hinom natuna ena koura baola, Ataga Ikoukouna raka-vareaina ai. Unuseni ai na hamaorolaimunu herevadia ba gwaurai hedinarai.
\v 3 Baoto: Iuda pavapavana hahidaosi bona Ierusalem inoholaina taumui e, Iehova ena hereva ba kamonai. Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: A itaia, lau ese dika badana ta ina gabu latanai baina havaraia; bena bae kamonai taudia iboudiai na taiadia bae hemai-hemai.
\v 4 Badina be taunimanima ese vada e rakatanigu, ina gabu vada e hamiroa, ia lalonai muramura mai bonadia vada e gabu, dirava idaudia, idia bona tamadia bona Iuda pavapavadia iboudiai na asi dibadia diravadia, ediai; bona, badina be ina gabu na asi edia kerere taudia raradia ai e hahonua,
\v 5 bona Baal ena atai gabudia vada e larebadia, natudia mamaruanedia na lahi ai bae haḡoledia, Baal ena gole oho boubou ḡaudia ai bae halaodia, totona; a lau ese una kara asina haheḡanilaia eiava asina hahedualaia, bona asina laloa davari.
\v 6 Iehova na e tomu: Taunabunai, ba itaia, nega na e maimu ina gabu ladana basie hatoa “Tofete” eiava “Hinom natuna ena koura”, a bae hatoa “Ala-ala Kourana”.
\v 7 Ina gabu ai lau ese Iuda bona Ierusalem edia lalo-hata ḡaudia na asi anidia ḡaudia ai baina halaodia, bona edia taunimanima na inaidia edia dare amo bona edia mauri iabi-ohona dalana e tahuamu taudia imadia amo baina hamasedia. Bena lau ese tau-anidia masedia na atai manudia bona uda boromadia baina henidia, adia.
\v 8 Ina hanua na gari ihavarana ḡauna ai baina halaoa, taunimanima ese bae silaia ḡauna; e rakaia hanaimu taudia iboudiai na bae gari bona bae si dagu, enai e varamu karadia dika-hereadia daidiai.
\v 9 Bena inaidia bona edia mauri iabi-ohona dalana e tahuamu taudia ese bae koudia ahu bona bae hahisihisidia negana ai, lau ese natudia mamaruanedia bona hahinedia hidiodia baina ha-anidia, bona ta ta dekena tauna dekena tauna hidiodia bae ani danu.
\p 
\v 10 Bena oi ese hari hoduhodu ba hamakohia, oi ida baola taudia vairadiai.
\v 11 Bena ba hamaorodia, baoto, Iehova Sabaota na ini e gwau tomamu: Ina bese bona ina hanua na unu baina hamakohidia toma, uro ikarana tauna ena hoduhodu e hamakohiamu, asi ibanina, na heto. Mase taudia na Tofete ai bae guridia, badina be asi iguridia gabuna idauna ta.
\v 12 Iehova na e tomu: Lau ese ina gabu mai inoholaina taudia ida na unu baina karadia toma; ina hanua na Tofete heḡereḡerena ai baina halaoa.
\v 13 Bena Ierusalem taudia edia ruma bona Iuda pavapavana hahidaosi edia ruma, guhidia ai muramura mai bonadia e gabu, dina bona hua bona hisiu iboudiai ediai, bona inuinu bouboudia e bubu, dirava idaudia ediai, rumadia na bae hamirodia, gabu ladana Tofete heḡereḡerena.
\p 
\v 14 Bena Ieremia na Iehova ese e siaia lao unuseni ai baine peroveta totona gabuna, Tofete, amo vada ema, Iehova ena dubu maguna lalonai e gini; bena ia ese taunimanima iboudiai e hereva henidia, eto,
\v 15 Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: A itaia, ina hanua badana latanai bona digina hanuadia iboudiai latadiai lau ese dika idoinai ia latanai vada na gwauraia na baina hadihoa; badina be idia ese aiodia vada e ha-aukadia, bona egu hereva ikamonaidia asie ura.
\c 20
\s1 Pasahuru iuduguiraina
\p 
\v 1 Hahelaḡa tauna Pasahuru, Imere natuna, Iehova ena dubu itataona tauna badana, na e kamonai, Ieremia ese ini ḡau vada e perovetalai.
\v 2 Bena Pasahuru ese peroveta tauna Ieremia e dadabaia, bena hekahi-tao audia ai e atoa, Iehova ena dubu ikoukouna, ladana Beniamina Ikoukouna, atai ḡauna, enai.
\v 3 Daba rerena ai, Pasahuru ese Ieremia na hekahi-tao audia amo e kahua nege. Bena Ieremia ese e hamaoroa, eto, Iehova ese ladamu se hatoamu “Pasahuru”, a e hatoamu “Hahegari heḡegemadai”.
\v 4 Badina be Iehova ini e gwau tomamu: A itaia, lau ese oi sibomu ihagarimu bona oi turamu iboudiai ihagaridia ḡauna ai baina halaomu. Idia na inaidia edia dare matadia ai bae mase, oi vairamu ai. Bena lau ese Iuda taudia iboudiai na Babulono pavapavana imana ai baina atodia; ia ese baine ḡuidia, Babulono baine laohaidia, dare amo baine aladia mase.
\v 5 Ina danu, hanua badana ena taḡa idoinai, vada e habou ḡaudia bona e heaḡilaimu kohudia iboudiai, bona Iuda pavapavadia edia kohu namodia iboudiai, na inaidia imadia ai baina atodia; idia ese bae dadihaidia, bae dabaidia tao, bena Babulono bae laohaidia.
\v 6 Bona oi Pasahuru, bona emu ruma inoholaina taudia iboudiai, na bae ḡuimui, oi bona turamu iboudiai, ediai vada o peroveta koikoi taudia, Babulono do baola, unuseni ai ba mase, unuseni ai bae gurimui.
\s1 Ieremia ena herohe-ahu
\q1 
\v 7 Iehova e, oi ese vada o dibaḡanigu,
\q2 bena vada o koigu;
\q1 oi ese goada ai vada o hereagu,
\q2 vada o kwalimu.
\q1 Dina idoinai e kirikirilaigumu;
\q2 iboudiai ese e ḡonaḡonalaigumu.
\q1 
\v 8 Lau na herevamu negadia ai na ḡabamu,
\q2 na lolomu, na tomu “Daḡedaḡe bona hahebuatari”.
\q1 Badina be Iehova ena hereva na egu ai
\q2 gwau-gwau bona hekirikirilai ḡauna ai e laomu, dina idoinai.
\q1 
\v 9 Bama toma “Ia ladana basina hatoa
\q2 eiava ia ladana ai basina hereva lou”,
\q1 to lalogu na e kara lahi e aramu na heto,
\q2 turiagu ai e miamu;
\q1 ihaheaukalaina ai na hesikumu,
\q2 asi haheauka dibagu.
\q1 
\v 10 Badina be hutuma edia hemaunu na kamonaimu,
\q2 hahegari ese e ḡeḡegu daemu.
\q1 “A habadelaia; aita habadelaia”;
\q2 na manada henidiamu taudia iboudiai na unu e hereva tomamu;
\q2 e raraigu taomu, baina keto e tomamu.
\q1 E tomu “Reana ta ese baine koia, bena baita hadarerea,
\q2 bena davada baita abia ienai”.
\q1 
\v 11 A Iehova na egu tuari tauna mai garina na heto,
\q2 taunabunai ihahisihisigu taudia na bae hetutuhi;
\q2 idia ese basie hadareregu.
\q1 Idia na bae hemarai dikadika,
\q2 badina be basie kwalimu;
\q1 idadaraidia na baine hesiriu,
\q2 bona basine boio ela bona hanaihanai.
\q1 
\v 12 Iehova Sabaota e, oi ese kara maoromaorodia taudia o tohodiamu,
\q2 taunimanima lalodia bona daradia o dibadiamu;
\q1 emu dava-abi idia latadiai mani baina itaia,
\q2 badina be egu ginikau gabuna na emu ai vada na atoa.
\q1 
\v 13 Ane avabia, Iehova ena;
\q2 Iehova ba imodaia!
\q1 Badina be e dabu taudia na ia ese vada e hamauridia,
\q2 kara dika taudia imadia amo.
\b
\q1 
\v 14 Na vara dinana na
\q2 na uduguiraiamu;
\q1 sinagu ese e havaragu dinana na
\q2 ta ese basine hanamoa.
\q1 
\v 15 Hereva na tamagu dekena e laohaia, eto
\q2 “Natumu maruanena ta vada e vara”,
\q1 bena unu amo e hamoalea bada,
\q2 tauna na na uduguiraiamu.
\q1 
\v 16 Una tau na Iehova ese e ḡiḡia dobi, se bogaia hisi, hanuana
\q2 heḡereḡerena ai bainela;
\q1 daba ai taitai ta baine kamonai,
\q2 bona dina tubua ai dika harina ta.
\q1 
\v 17 Badina be sinagu bogana ai se alagu mase;
\q2 unu bema kara toma sinagu na egu gara ai bema lao,
\q2 bona bogana bema bada hanaihanai.
\q1 
\v 18 Dahaka dainai sinagu bogana amo na lasi,
\q2 hekwarahi bona lalo-hisihisi na mamidia,
\q2 bona egu mauri dinadia na hemarai ai na ha-orediamu?
\c 21
\s1 Peroveta herevadia Ierusalem latanai
\p 
\v 1 Ina na Iehova ena hereva, Ieremia enai e kau, King Sedekia ese Pasahuru Malkia bona hahelaḡa tauna Sefania Maaseia na ia dekena e siaidia lao negana ai. Idia eto,
\v 2 Iehova ba nanadaia ai daimai ai, badina be Nebukadresara, Babulono pavapavana, ese e tuari henimaimu; reana Iehova ese ena hoa karadia iboudiai heḡereḡeredia ai baine kara henimai, bona ai emai amo baine haloua.
\p 
\v 3 Bena Ieremia ese e haere henidia, eto,
\v 4 Sedekia na ini ba hamaoroa toma, baoto, Iehova, Israel Diravana, na ini e gwau tomamu: A itaia, tuari ḡaudia imamui ai mimia, Babulono pavapavana bona Kaldea taudia, emui hanua maguna murimurinai e gegemui ahumu taudia, o tuarilai henidiamu ḡaudia, na baina laodia ahu, bona inaimui na ina hanua bogaraginai baina haheboudia.
\v 5 Lau sibogu ese baina tuari henumui mai imagu hetoi-rorona bona imagu goadana ida, badu ai bona daḡedaḡe ai bona badu-garagara bada-hereana ai.
\v 6 Bona ina hanua inoholaina taudia baina harahudia mase, taunimanima bona ubu-ubu ḡaudia danu; dai-hanai gorerena badana ta ese baine hamasedia.
\v 7 Iehova ma e tomamu: Una murinai lau ese Sedekia, Iuda pavapavana, bona ena hesiai taudia, bona ina hanua taudia hahidaosi dai-hanai gorerena bona dare bona doe amo bae roho mauri taudia, na Nebukadresara, Babulono pavapavana, bona adia inai taudia, edia mauri iabi-ohona dalana e tahuamu taudia, imadia ai baina atodia. Ia ese dare matana amo baine aladia mase; basine bogadia hisi, basine kahudia nege, basine bogalaidia.
\p 
\v 8 Bena ina bese taudia danu ba hamaorodia, baoto, Iehova na ini e gwau tomamu: A itaia, lau ese mauri dalana bona mase dalana na vairamui ai vada na atodia.
\v 9 Ina hanua lalonai baine noho tauna na dare bona doe bona dai-hanai gorerena amo baine mase; a baine raka lasi, sibona hari Kaldea taudia, e gegemui ahumu taudia, imadia ai baine heato, tauna na baine mauri; ena mauri na kwalimu ahuna ai bainela.
\v 10 Iehova ma e tomamu: Badina be lau ese vairagu vada na ha-aukaia ina hanua enai, dika ihavarana totona, dia namo ihavarana; Babulono pavapavana imana ai baine heato, bena ia ese lahi amo baine doua.
\s1 Peroveta herevadia Iuda pavapavadia latadiai
\p 
\v 11 Iuda pavapavana ena iduhu taudia ba hamaorodia, baoto, David iduhuna e, Iehova ena hereva ba kamonai!
\v 12 Iehova ini e gwau tomamu:
\q1 Hahemaoro karadia ḡoevaḡoevadia na daba ai ba kara,
\q2 bona ena ḡau e henao tauna na ihahisihisina tauna imana amo ba hamauria;
\q1 egu badu ḡaraḡara na lahi heḡereḡerena ai baine lasi na garina,
\q2 bena baine ara, ta basine habodoa diba,
\q2 emui kara dikadia daidiai.
\b
\q1 
\v 13 Koura inoholaina taumui e!
\q2 Taora nadi-ginina e!
\q1 A itaia, lau ese na inai henimuimu;
\q2 Iehova na e herevamu.
\q1 Umui na o tomamu:
\q2 Daika ese baine tuari henimai?
\q2 Daika ese emai noho gabudia lalodiai baine vareai?
\q1 
\v 14 Iehova na e tomamu:
\q2 Davamui baina henimui, emui kara anidia heḡereḡeredia;
\q1 ena uda ai lahi ta baina ha-araia,
\q2 bena ia heḡeḡe-madaina idoinai baine araia ore.
\c 22
\p 
\v 1 Iehova ini e gwau tomamu: Ba diho lao, Iuda pavapavana ena ruma baola, unuseni ai ina hereva ba gwauraia,
\v 2 baoto, Iuda pavapavana e, David teronona ai o helaimu tauna, Iehova ena hereva ba kamonai, oi bona emu hesiai taudia bona emu bese taudia, ini ikoukou lalodiai e raka vareaimu taudia, danu.
\v 3 Iehova ini e gwau tomamu: Hahemaoro goevaḡoevadia bona kara maoromaorodia ba kara; bona ena ḡau vada e henao tauna na ihahisihisina tauna imana amo ba hamauria. Idau tauna bona ihareha bona vabu na basio kara dika henidia bona basio daḡedaḡe henidia, bona asi ena kerere tauna rarana basio hahebubua ina gabu ai.
\v 4 Badina be ina hereva boma kamonai momokani, bena ina ruma ikoukoudia lalodiai pavapava haida, David teronona ai e helaimu taudia, na kariota ai bona hosi ai ḡuidia ai bae vareai, idia bona edia hesiai taudia bona edia bese taudia danu.
\v 5 A ini hereva nahuadia basio toho, lau na sibogu ladagu ai na gwau hamatamu, ina ruma na baine mia ḡaḡae.
\v 6 Badina be Iehova ese Iuda pavapavana ena ruma na ini e herevalaia tomamu:
\q1 Oi na Gilead na heto lauegu ai,
\q2 eiava Lebanon dorina na heto;
\q1 ḡau tamona, lau ese tano ḡaḡaena ai
\q2 bona hanua asi inoholaina ai baina halaomu.
\q1 
\v 7 Hahebua-tari taudia baina abidia heḡaeḡae, umui ihadikamui,
\q2 ta ta mai edia tuari ḡaudia;
\q1 bena idia ese emu sida audia ḡoeva-daedia bae hagaridia,
\q2 lahi ai bae tahodia kau.
\b
\p 
\v 8 Bese momo ese ina hanua badana bae rakaia hanai, bena ta ta ese dekena tauna dekena tauna bae nanadaidia, baeto, Dahaka dainai Iehova ese ina hanua bada-hereana na ini vada e kara henia toma?
\v 9 Bena idia na bae haere, baeto, Badina be idia ese Iehova, edia Dirava, ena taravatu e rakatania, dirava idaudia e toma henidia dihova bona isiaidia e lao heniva.
\b
\q1 
\v 10 Mase tauna basio tailaia bona basio lalo-hisihisilaia,
\q2 a e raka ohomu tauna dainai ba tai badabada;
\q1 badina be ia na nega ta ai basine lou mai,
\q2 ena tano korikori basine itaia lou.
\b
\p 
\v 11 Badina be Iehova ese Salumu, Iuda pavapavana Iosia natuna, tamana Iosia gabuna ai e lohiava bena ina gabu amo e raka oho tauna, na ini e herevalaia tomamu: Ia na nega ta basine lou mai iniseni ai,
\v 12 a heabi-mauri iḡuina ai vada e laohaia gabuna ai baine mase; ina tano na nega ta basine itaia lou.
\b
\q1 
\v 13 Kara gageva-gageva amo ena ruma e haginiamu
\q2 bona ena atai daiutudia hahemaoro kererena amo danu,
\q1 bona ia dekena tauna na ena hesiai tauna ai e halaoamu asi ahuna,
\q2 bona ena ḡaukara davana se heniamu, tauna na
\q2 madi, ihabaina!
\q1 
\v 14 Ia na e tomu “Egu ruma badana auta baina haginia
\q2 mai atai daiutudia badadia”;
\q1 bena ia ese gaba-mauru haida e karamu,
\q2 bona habana na sida reireidia amo e ḡovaiamu,
\q2 bona muramura kakakaka-hereana amo e dahuamu.
\q1 
\v 15 Sida audia iḡaukaralaidia ai o hereamu dainai,
\q2 oi na o laloamu oi na pavapava ta a?
\q1 Oi tamamu na e anianiva, e inuinuva,
\q2 bona hahemaoro ḡoevaḡoevadia bona kara maoromaorodia e karava, ani?
\q2 Bena ienai namo e varava.
\q1 
\v 16 Ia ese oḡoḡami taudia bona e dabuva taudia edia gini-kau gabuna e hahemaorolaia,
\q2 bena vada e namo.
\q1 Iehova na e tomamu
\q2 “Ina na dia lau idibalaigu dalana a?”
\q1 
\v 17 A oi matamu ese ḡau ta se itaiamu,
\q2 bona lalomu ese ḡau ta se laloamu,
\q1 a o abi koikoi kohudia mo,
\q2 bona asi ena kerere tauna rarana ihahebubuna mo,
\q2 bona hahehisi bona daḡedaḡe karadia ikaradia mo.
\b
\p 
\v 18 Taunabunai, Iehova ese Iehoiakim, Iuda pavapavana Iosia natuna, na ini e herevalaia tomamu:
\q1 Basie tailaia, basieto
\q2 “Tadikakagu o!” eiava “Taihugu o!”
\q1 Basie rohea ahu, basieto
\q2 “Lohia o!” eiava “Pavapava o!”
\q1 
\v 19 Doniki igurina heḡereḡerena ai bae ḡuria;
\q2 bae veria lao, Ierusalem ikoukouna murimuridiai bae negea lao.
\b
\q1 
\v 20 Lebanon ba dara dae, ba tai lolo,
\q2 gadomu ba habadaia Basan ai;
\q1 Abarimi amo ba tai,
\q2 badina be e ura henimuva taudia iboudiai vada e mase ore.
\q1 
\v 21 Emu noho namo ai na hereva henimu,
\q2 a oi oto “Basina kamonai”;
\q1 eregabemu negana amo emu kara na eneheto,
\q2 lau gadogu so kamonai henia.
\q1 
\v 22 Lai ese emu hereḡu taudia baine odadia oho,
\q2 bona e ura henimumu taudia na bae heabi mauri;
\q1 bena ba hemarai bona ba baia,
\q2 emu kara dika iboudiai daidiai.
\q1 
\v 23 Lebanon inoholaina taumu e,
\q2 sida audia bogaragidiai o nohomu;
\q1 hisihisi baine gugubamu negana ai,
\q2 hahine ena hekamonai hisidia na heheto,
\q2 emu ḡanaḡana na baine bada.
\p 
\v 24 Iehova na e tomu, Lau na maurimu heḡereḡerena, ena be Konia, Iuda pavapavana Iehoiakim natuna, na lau imagu kwakikwakina vagivagina, egu toa ḡauna, imagu idibana ai, to bama kokimu oho,
\v 25 emu mauri iabi-ohona dalana e tahuamu taudia, o gari henidiamu taudia, imadia ai bama atomu; oibe, Nebukadresara, Babulono pavapavana, bona Kaldea taudia, i nadia ai danu.
\v 26 Lau ese oi bona sinamu, e havaramu hahinena, na idau tano, lalonai so vara tanona, enai baina tahomu lao, unuseni ai vada ba mase.
\v 27 A ilou-henina bae ura dikadika tanona na basie lou henia.
\b
\q1 
\v 28 Ina tau Konia na e dadaraiamu ḡauna,
\q2 wo makohina, ta ese se ura heniamu ḡauna, a?
\q1 Dahaka dainai ia mai natuna ida vada e tahodia lao,
\q2 asi dibadia tanona ai vada e negedia?
\q1 
\v 29 Tano e, tano e, tano e,
\q2 Iehova ena hereva ba kamonai!
\q1 
\v 30 Iehova ini e gwau tomamu:
\q2 Ina tau ladana ba torea “asi natuna”;
\q2 ena mauri dinadia lalodiai namo basine abia.
\q1 Badina be ia garana ta basine namo,
\q2 David ena terono ai basine helai kau,
\q2 bona Iuda ai basine lohia lou.
\c 23
\s1 Kwabukwabudia edia lou
\p 
\v 1 Iehova na e tomu, Mamoe ireḡudia taudia, egu rei gabudia mamoedia e habuadia tarimu bona e hakarohodiamu taudia, madi, ihabaidia!
\v 2 Taunabunai, Iehova, Israel Diravana, ese egu bese e reḡuamu taudia na ini e herevalaidia tomamu: Egu seri vada o hakarohodia rohoroho, vada o luludia oho, asio regudia. Iehova na e tomu, A itaia, lau ese emui kara dika davadia do baina henimui.
\v 3 Bena egu seri mamoedia kwabukwabudia na na luludia lao tanodia iboudiai amo ma baina haboudia, edh magu ai ma baina hakaudia vareai; bena natudia bae havaradia, vada bae hutuma.
\v 4 Lau ese mamoe ireḡudia taudia na daediai baina atodia, bena idia ese bae regudia; bena basie gari lou bona kudoudia basie hetaha lou, bona ta basine boio. Iehova na e herevamu.
\p 
\v 5 Iehova na e tomu, A itaia, negana vada e maimu, lau ese kara maoromaoro Rigina ta baina haginia David ena; ia na baine pavapava, bona baine kara aonega; ia ese hahemaoro ḡoevaḡoeva bona kara maoromaoro na ina tano ai baine kara.
\v 6 lena nega ai Iuda na baine roho mawi, bona Israel na baine noho namonamo. ia ladana bae hatoa “Iehova na eda kara maoromaoro”.
\p 
\v 7 Iehova na e tomu, Taunabunai, negana vada e maimu, taunimanima na basie hereva lou, basieto “Iehova, Israel taudia na Aigupto tanona amo e hakaudia lasi Diravana, e maurimu heḡereḡerena”,
\v 8 a baeto “Iehova, Israel garana na mirigini kahana tanona bona e luludia lao tanodia iboudiai lalodia amo e hakaudia lou mai Diravana, e maurimu heḡereḡerena”. Bena idia na edia tano korikori ai bae noho.
\s1 Peroveta koikoidia
\p 
\v 9 Peroveta taudia herevadia:
\q1 Daragu vada e doko,
\q2 turiagu iboudiai na e heude-heudemu;
\q1 lau na kekero tauna na heto,
\q2 vine ranuna ese vada e hakekeroa tauna na heto,
\q1 Iehova dainai,
\q2 bona ena hereva helagadia daidiai.
\q1 
\v 10 Badina be tano na heuda-hanai taudia ai eme honu;
\q2 heuduguirai dainai tano na e taimu,
\q2 bona tano ḡaḡaena reidia vada e kakoro.
\q1 Edia dala na dika,
\q2 bona edia goada na dia maoro.
\q1 
\v 11 Peroveta tauna bona hahelaḡa tauna,
\q2 raruosi ese Dirava se matauraiamu;
\q1 egu dubu ai danu edia kara dika vada na davaria.
\q2 Iehova na e herevamu.
\q1 
\v 12 Taunabunai, edia dala na ediai
\q2 dala dedika-dedikadia dibwa ai heḡereḡeredia ai baela;
\q2 lalodiai bae luludia vareai, bena bae keto;
\q1 taunabunai lau ese dika na latadiai baina hadihoa,
\q2 edia mata-hakani laḡanina lalonai.
\q2 Iehova na e herevamu.
\q1 
\v 13 Samaria ena peroveta taudia ediai
\q2 mamina dika karana ta na itaia:
\q1 idia na Baal ladana ai e perovetava,
\q2 bona egu bese Israel e hakaua kerereva.
\q1 
\v 14 A Ierusalem ena peroveta taudia ediai
\q2 ḡau dika-rohorohona ta vada na itaia:
\q1 idia na e heuda hanaimu,
\q2 bona koikoi daladia ai e rakamu;
\q1 kara dika taudia umadia na e ha-aukadiamu,
\q2 taunabunai ta na ena kara dika amo se raka ohomu;
\q1 iboudiai na egu ai vada e hekara Sodoma na heto,
\q2 bona inoholaina taudia na Gomora na heto.
\p 
\v 15 Taunabunai, Iehova Sabaota ese peroveta taudia na ini e herevalaidia tomamu:
\q1 A itaia, ava iditana baina ubulaidia,
\q2 bona e imoraia ranuna baina ha-inulaidia;
\q1 badina be Ierusalem ena peroveta taudia edia amo,
\q2 Dirava idadaraina karadia na tano idoinai vada e piua lao.
\p 
\v 16 Iehova Sabaota na ini e gwau tomamu: Peroveta taudia edia hereva basio abi dae. Idia ese e peroveta henimuimu, helaro asi anidia ai e hahonumuimu; idia ese sibodia lalodia ai e mata hanaimu ḡaudia mo e gwauraimu, dia Iehova uduna herevadia.
\v 17 Idia ese Iehova ena hereva e dadaraiamu taudia na e hamaorodia louloumu, e tomu “Umui na do ba namo”; bona sibodia edia lalo-auka daladia ai e rakamu taudia na e hamaorodiamu, e tomu “Dika ta na latamui ai basine kau”.
\q1 
\v 18 Badina be idia bogaragidia amo
\q2 daika na Iehova ena henega ai vada e gini,
\q2 ena hereva baine dibaia bona baine kamonaia totona?
\q1 Eiava daika ese ena hereva vada e hakala henia
\q2 bona vada e abia dae?
\q1 
\v 19 A itaia, Iehova ena lai gubana!
\q2 Badu vada e lasi, koe-hirihiri bada-hereana na heto,
\q2 kara dika tauna kwarana ai baine kau.
\q1 
\v 20 Iehova ena badu na basine lou,
\q2 ela bona ia lalona ena ura iboudiai
\q2 baine kara bona baine haguguru.
\q1 Dina gabedia ai
\q2 ba lalo-pararalaia ḡoevaḡoeva.
\b
\q1 
\v 21 Peroveta taudia na asina siaidia,
\q2 to idia na e heau;
\q1 lau ese asiua hereva henidia,
\q2 to idia na e perovetava.
\q1 
\v 22 A lauegu henega ai bema gini,
\q2 idia ese egu bese taudia na egu hereva bema gwaurai henidia,
\q1 bona edia dala dikana amo bema hakaudia oho,
\q2 bona edia kara dikadia amo danu.
\b
\p 
\v 23 Iehova na e tomu, Lau na gabu kahikahidia Diravana a dia gabu daudaudia Diravana a?
\v 24 Iehova na e tomu, Tau ta na gabu hehunidia ai baine komu diba bena basina itaia a? Iehova na e tomu, Lau ese guba bona tanobada asina hahonudiamu a?
\v 25 Peroveta taudia, hari lau ladagu ai e peroveta koikoimu taudia, edia hereva vada na kamonai; idia na e tomu “Vada na nihi, vada na nihi”.
\v 26 Hari e peroveta koikoimu bona sibodia lalodia ai e hekoimu taudia lalodia ai koikoi baine mia ela bona edena nega ai?
\v 27 Idia na e laloamu edia nihi, e hesivarailai hehenimu ḡaudia, daidiai lau ladagu ilalo-taona na egu bese taudia lalodia amo bae abia oho, tamadia ese Baal dainai lau ladagu e laloa boio heḡereḡerena.
\v 28 Peroveta tauna mai ena nihi ese ena nihi baine gwauraia, a egu hereva na enai e miamu tauna ese egu hereva baine gwauraia balaheni. Iehova na e tomu, Uit momona ena namo bona uit mai anina ena namo ede bae heḡereḡere toma?
\v 29 Iehova na e tomu, Lauegu hereva na dia lahi heḡereḡerena a? Ia na dia nadi e hamakohidia sisisisimu aurina heḡereḡerena a?
\v 30 Iehova na e tomu, Taunabunai, a itaia, lau ese peroveta taudia na inai henidiamu; idia ese egu hereva na bamodia edia amo e henaomu.
\v 31 Iehova na e tomu, A itaia, lau ese peroveta taudia na inai henidiamu; idia na ududia amo e herevamu, e tomu “Iehova na e herevamu”.
\v 32 Iehova na e tomu, Nihi koikoidia e perovetalaidiamu taudia na inai henidiamu, idia ese e gwauraidiamu, bona edia koikoi bona edia kavakava amo egu bese taudia e hakaudia kereremu, a lau ese asina siaidia bona asina haduadia. Taunabunai idia ese ina bese taudia edia namo sisina taina asie havaraia. Iehova na e herevamu.
\p 
\v 33 Ina bese taudia ta, eiava peroveta tauna ta, eiava hahelaḡa tauna ta, ese baine nanadaimu, baineto “Iehova ena maduna be dahaka?”, negana ai oi na ba haere henia, baoto “Iehova na e tomu, Maduna na umui, bona baina negemui daure”.
\v 34 Bona peroveta tauna eiava hahelaḡa tauna eiava bese taudia ta, “Iehova ena maduna” e herevalaiamu tauna, lau ese una tau mai ena ruma taudia ida na matadia baina hakanidia.
\v 35 Umui na ini ba hereva toma, ta ta dekena tauna dekena tauna ediai, bona ta ta tadikakana tadikakana ediai, baoto “Iehova ena haere be dahaka?” eiava “Iehova ena hereva be dahaka?”
\v 36 A “Iehova ena maduna”, basio herevalaia lou, badina be maduna be taunimanima iboudiai ta ta ena hereva ena hereva; bona umui ese Mauri Diravana, Iehova Sabaota, iseda Dirava, ena hereva o hagagevadiamu.
\v 37 Taunabunai, peroveta tauna ba nanadaia, baoto “Iehova ese ede e haere henimu toma?” eiava “Iehova na ede e hereva toma?”
\v 38 A boma toma “Iehova ena maduna”, Iehova na ini e gwau tomamu: Badina be ini hereva “Iehova ena maduna” vada o gwaurai, a lau ese hereva na emui ai na siaia vasi, nato, Basioto “Iehova ena maduna”,
\v 39 taunabunai, a itaia, momokani lau ese baina abimui isi bona vairagu amo baina negemui daure, umui, bona umui mai senemui ida na henimui hanuana danu.
\v 40 Bona lau ese gwau-tora bona hemarai na latamui ai baina hadiho hanaihanai, basie boio.
\c 24
\s1 Hereva heḡereḡerena: Suke namodia
\s1 bona suke dikadia
\p 
\v 1 Nebukadresara, Babulono pavapavana, ese lekonia, Iuda pavapavana Iehoiakim natuna, bona Iuda lohiadia bona ima karakara dibaka taudia bona awi igaukaralaidia taudia na Ierusalem ai e abidia bena gabu daudau ai, Babulono ai, e hanohodia murinai, Iehova ese ina mata-hanai ḡauna e haheitalaigu. Suke huahuadia bosea rua Iehova ena dubu vairanai heheato na itadia.
\v 2 Bosea ta lalonai suke na nanamo heherea, e mage guna ḡaudia na heheto; a bosea iharuana lalonai suke na didika rorohoroho, vada e dika bada-herea dainai basie heani diba.
\v 3 Bena Iehova ese e nanadaigu, eto, Ieremia e, dahaka o itaiamu? Lau nato, Suke huahuadia, namodia be nanamo heherea, a dikadia na didika rorohoroho, vada e dika bada-herea dainai basie heani diba.
\p 
\v 4 Bena Iehova ena hereva na egu ai e kau, eto,
\v 5 Iehova, Israel Diravana, na ini e gwau tomamu: Ini suke namodia heḡereḡeredia, lau ese Iuda tanona amo e heabi oho taudia, ina gabu amo na siaidia oho Kaldea taudia edia tano na siaidia lao taudia, baina gwauraidia, idia na nanamo.
\v 6 Lau ese baina haḡeredia, ihanamodia totona, bona baina hakaudia lou mai ina tano lalonai. Lau ese baina haginidia, basina ḡiḡidia dobi; baina hadodia, basina raḡadia.
\v 7 Lalodia na baina hapararadia, vada bae diba, lau na Iehova; bena idia na lauegu bese ai baela, bona lau na edia Dirava ai bainala; badina be idia ese bae lou henigu, mai lalodia idoidiai ida.
\p 
\v 8 A Iehova na ini e gwau tomamu: Hari suke dikadia, vada e dika herea dainai basie heani diba ḡaudia, heḡereḡeredia, Sedekia, Iuda pavapavana, bona ena lohia taudia bona Ierusalem taudia kwabukwabudia, ina tano ai e nohomu bona Aigupto tanona ai e nohomu taudia, na unu baina kara henidia toma.
\v 9 Lau ese hahegari ḡauna ai baina halaodia, tanobada basileiadia iboudiai ediai; idia na gvau-tora bona udu gwaurai-gwaurai bona hegonagonalai bona heuduguirai ḡaudia ai baela, baina luludia lao gabudia iboudiai lalodiai.
\v 10 Lau ese dare bona doe bona dai-hanai gorerena na latadiai baina siaidia, ela bona idia bona senedia na henidia tanoua lalona amo bae hebua tari vaitani.
\c 25
\s1 Noho-hedoa laḡanidia hitu- ahui
\p 
\v 1 Iehoiakim, Iuda pavapavana Iosia natuna, ena lohia laḡanina ihahanina ai (una na Nebukadresara, Babulono pavapavana, ena lohia laḡanina gini-gunana), hereva na Ieremia enai e kau, Iuda taudia iboudiai daidiai;
\v 2 bena Ieremia, peroveta tauna, ese una hereva na Iuda taudia iboudhi bona Ierusalem inoholaina taudia iboudiai e hamaorolaidia, eto:
\v 3 Laḡani ruahui-toi lalodiai, Iosia Amon, Iuda pavapavana, ena lohia laḡanina ihagwautatoina amo ema bona ina dina, Iehova ena hereva na egu ai vada e kau, bona vada na hereva henimui havara-havara to umui na asio kamonai.
\v 4 Asio kamonai, bona taiamui asio hakala, ena be Iehova ese ena peroveta hesiai taudia iboudiai na dekemui e siaidia havara-havara,
\v 5 eto, Iboumui ai ba helalo kerehai, ta ta emui dala dikadia bona emui kara dikadia amo ba raka oho; bena Iehova ese umui bona senemui nega gunadia amo ela bona hanaihanai vada e henimui tanona ai do ba noho;
\v 6 bona dirava idaudia vairadiai basiola, isiaidia basio lao heni bona basio toma henidia diho, bona imamui ḡaukaradia amo basio habadugu; bena lau ese basina hadikamui.
\v 7 Ḡau tamona (Iehova na e tomu), umui ese asio kamonai henigu, imamui ḡaukaradia amo ba habadugu totona, sibomui ihadikalaimui.
\p 
\v 8 Taunabunai, Iehova Sabaota na ini e gwau tomamu: Egu hereva asio abidia dae dainai,
\v 9 a itaia, lau ese mirigini kahana besedia iboudiai baina boiridia (Iehova na e tomu), bona Nebukadresara, Babulono pavapavana, egu hesiai tauna, danu baina boiria; ina tano mai inoholaina taudia ida, bona ini heḡeḡemadai besedia iboudiai danu, ihadikadia totona baina mailaidia; bena baina habuadia tari vaitani, hahegari bona si-dagu bona gwau-tora hanaihanai ḡaudia ai baina halaodia.
\v 10 Ina danu, kiri bona moale reḡedia na idia edia amo baina abi oho, bona headava matamata tauna bona hahinena eredia danu, bona uit e idia patapata reḡedia bona lamepa diarina danu.
\v 11 Ina tano idoinai na e ḡiḡia dobi bona e havahua ḡauna ai bainela, bona ini bese ese Babulono pavapavana isiaina bae ho heni, laḡani hitu-ahui lalodiai.
\v 12 Bena laḡani hitu-ahui bae ore murinai, lau ese Babulono pavapavana bona una basileia, Kaldea tanona basileiana, na edia kara havara davana baina henidia, bona edia tano baina havahua ela bona hanaihanai. Iehova na e herevamu.
\v 13 Una tano latanai vada na gwaurai herevadia iboudiai na anidia baina havara, ia ihadikana; ina buka ai e hetore, Ieremia ese basileia iboudiai ihadikadia e gwaurai guna ḡaudia iboudiai.
\v 14 Badina be basileia momo bona pavapava badadia ese idia bae ḡuidia, edia hesiai taudia ai bae halaodia; bona lau ese baina hadava henidia, edia kara bona imadia ḡaukaradia heḡereḡeredia.
\s1 Badu keherena
\p 
\v 15 Iehova, Israel Diravana, ese ini e hereva henigu toma, eto: Ina kehere, badu vine-ranuna keherena, na lau imagu amo avabia, bena dekedia baina siaimu lao basileiadia iboudiai na ba ha-inulaidia.
\v 16 Idia na bae inu, bena bae raraga bona bae kavadia, bogaragidiai na siaiamu darena dainai.
\p 
\v 17 Taunabunai, lau ese kehere na Iehova imana amo na abia, Iehova ese dekedia e siaigu lao basileiadia iboudiai na na ha-inulaidia;
\v 18 Ierusalem bona Iuda hanuadia, bona pavapavana bona lohiana iboudiai danu; idia na gabu ḡaḡaena bona e vahu gabuna ai bona si-dagu bona heuduguirai ḡauna ai baela, ina dina ai heḡereḡerena;
\v 19 Farao, Aigupto pavapavana, mai ena hesiai taudia bona ena lohia taudia bona ena orea taudia iboudiai ida danu;
\v 20 bona idau bese taudia idia bogaragidiai e nohomu danu; bona Usu tanona pavapavana iboudiai, bona Filistia taudia edia tano pavapavana iboudiai (Askelono, Gasa, Ekron bona Asdod kwabukwabudia) danu;
\v 21 bona Edom bona Moab bona Amono garana,
\v 22 bona Turo pavapavana iboudiai bona Sidono pavapavana iboudiai bona davara unukahana konena pavapavadia danu;
\v 23 bona Dedan, Tema, Busu, bona bagudia huidia e naudiamu taudia iboudiai,
\v 24 bona Arabia pavapavadia iboudiai bona e headava hanai besedia tano ḡaḡaena ai e nohomu edia pavapava iboudiai danu;
\v 25 bona Simiri, Elam, Media pavapavadia iboudiai,
\v 26 bona mirigini kahana pavapavadia iboudiai, gabu daudaudia bona kahikahidia, murina murina amo, bona tanobada basileiadia iboudiai tano kopina idoinai latanai danu. Idia muridiai, Babulono pavapavana ese baine inua.
\p 
\v 27 Bena ba hamaorodia, baoto, Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Ba inua, ba kekero, ba mumuta, ba keto, basio tore isi lou, bogaragimui ai na siaia vasimu darena dainai.
\p 
\v 28 Idia na basiema ura inuinu keherena na oi imamu amo bae abia, boma hamaorodia, boma toma, Iehova Sabaota na ini e gwau tomamu: Vada ba inua!
\v 29 Badina be lau ladagu e henemailaia hanuana lalonai dika ihavarana baina matamaia, bena dava iabina amo ba roho mauri a? Dava iabina amo basio roho mauri, badina be dare ta maina na gwauraiamu, tanobada inoholaina taudia iboudiai ihadikadia ḡauna. Iehova Sabaota na e herevamu.
\p 
\v 30 Taunabunai, idia latadiai ba peroveta, ini hereva iboudiai ba gwaurai, baoto:
\q1 Iehova na atai amo baine ḡaba,
\q2 ena noho gabuna helaḡana amo ia gadona baine habadaia.
\q1 Baine ḡaba badabada, ena mamoe serina latanai;
\q2 baine lolo, vine huahuadia e moimoilaimu taudia na heheto,
\q2 tanobada inoholaina taudia iboudiai latadiai.
\q1 
\v 31 Reḡe na baine reḡe dae ela bona tanobada dokodia,
\q2 badina be Iehova na mai ena hahebade ta, basileia idau-idau latadiai;
\q1 ia ese taunimanima iboudiai be hahemaoro henidiamu,
\q2 bona kara dika taudia na dare amo baine aladia mase.
\q2 Iehova na e herevamu.
\p 
\v 32 Iehova Sabaota iui e gwau tomamu:
\q1 A itaia, kara dika na e laomu,
\q2 basileia ta amo ela bona ma basileia ta;
\q1 lai gubana badana ta e toa matamamu,
\q2 tanobada daudaudia kahadia amo.
\p 
\v 33 Una dina ai, Iehova ese baine aladia mase taudia na tanobada dokona amo ela bona ma tanobada dokona bae hesiriu. Ta ese basine rohedia ahu, ta ese basine haboudia, ta ese basine guridia; idia na boromakau taḡena heḡereḡerena ai baela, tano kopina ai.
\q1 
\v 34 Mamoe ireḡudia taudia, ba tai, ba tai lolololo!
\q2 Mamoe seridia biagudia, kahu ai ba hekui-hekui!
\q1 Badina be iala-masemui bona ihakarohomui dinadia vada e kau,
\q2 bena ba keto, mamoe mamaruanedia namo-hereadia na heheto.
\q1 
\v 35 Mamoe ireḡudia taudia edia komu gabuna ta basine mia,
\q2 mamoe seridia biagudia edia roho-mauri gabuna ta danu basine mia.
\q1 
\v 36 A hakala, mamoe ireḡudia taudia na e taimu,
\q2 mamoe seridia biagudia na e tai lolomu;
\q1 badina be Iehova ese edia rei gabudia e havahudiamu,
\q2 
\v 37 bona edia magu, edia maino gabudia, vada e habuadia tari,
\q2 Iehova ena badu ḡaraḡara dainai.
\q1 
\v 38 Leona na heto ia na ena komu gabuna amo vada e raka lasi,
\q2 badina be edia tano vada e vahu,
\q1 e hahisihisidiamu tauna ena dare dainai,
\q2 bona ena badu ḡaraḡara dainai.
\c 26
\s1 Ieremia e tohonaia
\p 
\v 1 Iehoiakim, Iuda pavapavana Iosia natuna, e lohia matama negana ai, ina hereva na Iehova ena amo ema.
\v 2 Iehova na ini e gwau tomamu: Iehova ena dubu maguna ai ba gini, bona Iuda hanuadia iboudiai amo tomadiho totona Iehova ena dubu baema taudia na ba hereva henidia, na haganilaimumu herevadia iboudiai na ba hamaorolaidia; hereva ta basio hunia.
\v 3 Readia bae kamonai, bona iboudiai ese ta ta ena dala dikana ena dala dikana bae rakatani; bena unu amo lau baina helalo kerehai, bona ihadikadia karana, edia kara dikadia daidiai vada na laloa hata ḡauna, na basina karaia.
\v 4 Ba hamaorodia, baoto, Iehova ini e gwvau tomamu: Bema basio kamonai henigu, egu taravatu, vairamui ai vada na atoa ḡauna, lalonai basio raka,
\v 5 bona egu hesiai peroveta taudia, ena be asio hakala to dekemui na siaidia ḡava taudia, na basio hakala henidia;
\v 6 bena ina dubu na Silo heḡereḡerena ai baina halaoa, bona ina hanua na heuduguirai ḡauna ai baina halaoa, tanobada besedia iboudiai ediai.
\p 
\v 7 Hahelaḡa taudia bona peroveta taudia bona taunimanima iboudiai na e kamonai, Ieremia ese unu hereva e gwaurai, Iehova ena dubu lalonai.
\v 8 Iehova ese e haganilaia taunimanima iboudiai baine hamaorolaidia herevadia na Ieremia ese e gwaurai ore; bena hahelaḡa taudia bona peroveta taudia bona taunimanima iboudiai ese e dabaia tao, eto, Oi na ba mase.
\v 9 Ma eto, Badina be dahaka oi na Iehova ladana ai vada o peroveta, oto “Ina dubu na Silo heḡereḡerena ai bainela, bona ina hanua na baine vahu, asi inoholaina” a? Bena taunimanima iboudiai ese Ieremia e daia ahu, Iehova ena dubu ai.
\p 
\v 10 Iuda lohiadia ese ini ḡau e kamonai, bena pavapava ena ruma amo e dae lao, Iehova ena dubu ela; bena Iehova ena dubu Ikoukouna Matamatana raka-vareaina ai e helai diho.
\v 11 Bena hahelaḡa taudia bona peroveta taudia ese lohia taudia bona taunimanima iboudiai e hamaorodia, eto, Ina tau na baita revaia mase be namo, badina be ia ese ina hanua ihadikana vada e perovetalaia, umui sibomui taiamui ai vada o kamonai.
\p 
\v 12 Bena Ieremia ese lohia taudia bona taunimanima iboudiai na e hereva henidia, eto, Iehova ese e siaigu, vada o kamonai herevadia iboudiai na ina dubu bona ina hanua latadiai baina gwaurai guna.
\v 13 Taunabunai, emui dala bona emui kara ba hanamodia, bona Iehova, emui Dirava, gadona ba kamonaia, bena Iehova na baine helalo kerehai, kara dika na umui latamui ai vada e gwauraia na basine karaia.
\v 14 A lau be umui imamui ai; emui lalohadai namona bona maorona heḡereḡerena ai ba kara henigu.
\v 15 Ḡau tamona ba diba momokani, boma hamasegu, umui ese asi ena kerere tauna rarana na sibomui latamui ai bona ina hanua mai inoholaina taudia ida latadiai boma hadihoa; badina be momokani Iehova ese dekemui e siaigu, ini hereva na taiamui ai baina gwaurai halaoreana.
\p 
\v 16 Bena hanua lohiadia bona taunimanima iboudiai ese hahelaḡa taudia bona peroveta taudia na e hamaorodia, eto, Asi badina ina tau baita revaia mase, badina be ia ese Iehova, eda Dirava, ladana ai vada e hereva henida.
\v 17 Bena una tano tau-badadia haida na e tore isi, hebou taudia iboudiai e hereva henidia, eto,
\v 18 Mika, tau Moresete, na Hesekia, Iuda pavapavana, ena nega ai e perovetava; bena ia ese Iuda taudia iboudiai e hamaorodia, eto, Iehova Sabaota na ini e gwau tomamu:
\q1 Siona na bae ruaia, biru gabuna na heto, bona Ierusalem baine heḡiḡi dobi,
\q2 bona dubu ororona na ororo mai udana ta ai bainela.
\m 
\v 19 Hesekia, Iuda pavapavana, bona Iuda idoinai ese e alaia mase a? Ia ese Iehova garina e gari bona Iehova e noia baine lalo namo henia, ani? Bena Iehova na e helalo kerehai, dika idia latadiai vada e gwauraia na se havaraia, ani? A ita ese dika badana na ita siboda latadai baita hadihoamu.
\p 
\v 20 Ma lau ta danu Iehova ladana ai e perovetava, ladana na Uria Semaia, Kiriat-iearimi tauna. Ia ese peroveta herevadia na ina hanua bona ina tano latadiai e gwaurai; ena hereva na Ieremia ena heḡereḡeredia.
\v 21 Bena King Iehoiakim, mai ena tuari taudia bona ena lohia taudia iboudiai ida, na iena hereva e kamonai negana ai, hanua pavapavana ese ia iala-masena dalana e tahua. A Uria e kamonai, bena e gari, e heau mauri, Aigupto ela.
\v 22 Bena King Iehoiakim ese tatau haida na Aigupto e siaidia lao; taudia be Elnatan Akaboro bona haida ia ida.
\v 23 Bena idia ese Uria na Aigupto amo e hakaua mai, King Iehoiakim dekenai; bena ia ese dare amo e alaia mase, bena tau-anina na hanua taudia edia gara gabuna ai e negea.
\p 
\v 24 A Ahikama Safana imana ese Ieremia e rauaia, una dainai hanua audia imadia ai asie atoa, bena asie alaia mase.
\c 27
\s1 Hereva heḡereḡerena: Boromakau madunadia
\p 
\v 1 Sedekia, Iuda pavapavana Iosia natuna, e lohia matama negana ai, ina hereva na Iehova ena amo ema, Ieremia enai e kau.
\v 2 Iehova ese ini e hamaorogu toma, eto: Boromakau kopidia varodia bona boromakau madunadia ba kara, sibomu aiomu ai bavato.
\v 3 Hereva na ba siaia, Edom bona Moab pavapavadia, bona Amono taudia edia pavapava, bona Turo bona Sidono pavapavadia, dekediai; hari gwukau taudia, Ierusalem vada ema Sedekia, Iuda pavapavana, dekenai, imadia amo ba siaia lao.
\v 4 Ina gwaukau herevana ba henidia, biagudia edia, baoto, Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Biagumui na ini ba hamaorodia toma, baoto,
\v 5 Lau ese egu siahu badana amo bona imagu hetoi-rorona amo tanobada vada na karaia, bona tanobada taudia bona tanobada boromadia danu, bena na lalohadailai maoromu taudia na henidiamu.
\v 6 Harihari ini tano iboudiai na egu hesiai tauna Nebukadnesara, Babulono pavapavana, imana ai vada na atodia, bona tanobada boromadia danu vada na henia, idia ese ia isiaina bae lao heni.
\v 7 Bese iboudiai ese ia bona natuna bona tubuna isiaidia bae lao heni, ela bona iena tano korikori ena nega baine kau, bena bese momo bona pavapava badadia ese ia bae ḡuia, edia hesiai tauna ai bae halaoa.
\p 
\v 8 A bese ta eiava basileia ta ese hari Nebukadnesara, Babulono pavapavana, isiaina basinema lao heni, bona aiona na Babulono pavapavana ena maduna henunai basinema atoa, bena lau ese una bese davana baina henia, dare bona doe bona dai-hanai gorerena amo, ela bona hari pavapava imana amo baina ha-orea. Iehova na e herevamu.
\v 9 Una dainai, emui peroveta taudia eiava emui mari-abi taudia eiava emui nihi taudia eiava emui rohe taudia eiava emui mea taudia ese bema hamaoromui, bema toma “Babulono pavapavana isiaina basio lao heni”, umui ese basioma kamonai henidia.
\v 10 Badina be idia na emui ai e peroveta koikoimu, bena una dainai umui na emui tano amo ba heabi oho dauhai; lau ese baina lulumui lasi, bena ba mase.
\v 11 A edena bese ta ese aiona na Babulono pavapavana ena maduna henunai baine atoa, bona isiaina baine lao heni, lau ese ena tano korikori ai baina rakatania, bena bae birulaia bona bae noholaia. Iehova na e haevamu.
\p 
\v 12 Sedekia, Iuda pavapavana, danu unu na hereva henia toma, nato, Aiomui na Babulono pavapavana ena maduna henunai bavato, ia bona ena bese taudia isiaidia ba lao heni, bena ba mauri.
\v 13 Anina be dahaka oi bona emu bese taudia na dare bona doe bona dai-hanai gorerena amo ba mase, Iehova ese Babulono pavapavana isiaina basine lao heni besena vada e herevalaia heḡereḡerena, a?
\v 14 Hari peroveta taudia, e tomu “Babulono pavapavana isiaina basio lao heni” taudia, na edia hereva basio kamonai; badina be idia ese koikoi herevana e perovetalai henimuimu.
\v 15 Iehova na e tomu, Lau ese asina siaidia, ḡau tamona idia na lau ladagu ai e peroveta koikoimu, una dainai lau ese baina lulumui lasi, bena ba mase, umui bona e peroveta henimuimu taudia danu.
\p 
\v 16 Bena lau ese hahelaḡa taudia bona ina bese idoinai na hereva henidia, nato, Iehova ini e gwau tomamu: Emui peroveta taudia na e perovetamu, e tomu “A itaia, Iehova ena dubu kohudia na asi vanahana Babulono amo bae loulai”, to edia hereva basio kamonai, badina be idia ese koikoi herevana e perovetalai henimuimu.
\v 17 Basio kamonai henidia; Babulono pavapavana isiaina ba lao heni, bena ba mauri. Anina be dahaka ina hanua badana na baine vahu?
\v 18 Bema idia na peroveta taudia bona Iehova ena hereva bema idia dekediai, idia ese Iehova Sabaota bema noia, Iehova ena dubu ai bona Iuda pavapavana ena ruma ai bona Ierusalem ai doini mimia kohudia na Babulono basie laohai.
\v 19 Badina be Iehova Sabaota ese au-tubua bona nau bada-hereana bona rerue bona kohu orena ina hanua ai doini mimia ḡaudia,
\v 20 Nebukadnesara, Babulono pavapavana, ese Iekonia, Iuda pavapavana Iehoiakim natuna, bona Iuda bona Ierusalem lohiadia iboudiai, e abidia mauri, Ierusalem amo e laohaidia ela bona Babulono, negana ai se laohai ḡaudia, na ini e herevalaidia tomamu.
\v 21 Iehova Sabaota, Israel Diravana, ese Iehova ena dubu ai bona Iuda pavapavana ena ruma ai bona Ierusalem ai doini mimia kohudia na ini e herevalaidia tomamu:
\v 22 Babulono bae laohaidia, unuseni ai bae mia, ela bona iau ese baina helalolaidia; bena ma baina loulaidia, ina gabu ai ma baina atodia lou. Iehova na e herevamu.
\c 28
\s1 Hanania e peroveta koikoi
\p 
\v 1 Una laḡani tamona ai, Sedekia, Iuda pavapavana, ena lohia negana matamana ai, laḡani ihahanina huana iha-imana ai, Hanania Asuru, peroveta tauna Gibeon amo, ese e hereva henigu, Iehova ena dubu ai, hahelaḡa taudia bona taunimanima iboudiai vairadiai, eto,
\v 2 Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Babulono pavapavana ese e atoa madunana vada na hakwaidua.
\v 3 Laḡani rua do basie ore ai, Iehova ena dubu kohudia iboudiai, Nebukadnesara, Babulono pavapavana, ese ina gabu amo e abi oho Babulono e laohai ḡaudia, na lau ese baina loulai ina gabu ai.
\v 4 Bona Iekonia, Iuda pavapavana Iehoiakim natuna, bona Iuda amo Babulono e laohaidia taudia iboudiai danu, lau ese baina hakaudia lou mai ina gabu ai, badina be Babulono pavapavana ese e atoa madunana na baina hakwaidua. Iehova na e herevamu.
\p 
\v 5 Bena peroveta tauna Ieremia ese peroveta tauna Hanania e hereva henia, hahelaḡa taudia bona Iehova ena dubu Ialonai e gini taudia iboudiai vairadiai.
\v 6 Peroveta tauna Ieremia eto, Amen! Iehova unu baine kara toma baine namo. Iehova ese oiemu peroveta herevadia baine hamomokanidia, Iehova ena dubu kohudia iboudiai bona abi-mauri taudia danu na Babulono amo baine loulaidia ema bona ina gabu, una na baine namo.
\v 7 Ḡau tamona, ina hereva oi vairamu ai bona taunimanima iboudiai vairadiai na gwauraiamu na ba kamonai.
\v 8 Peroveta taudia, ita raruosi e gunalaida taudia, ese nega gunadia amo tuari bona doe bona dai-hanai goreredia na tano momo bona basileia badadia latadiai e per vetalai.
\v 9 A maino e perovetalaiamu tauna be una peroveta tauna ena hereva anina baine vara negana ai vada bae diba Momokani, Iehova ese una peroveta tauna vada e siaia.
\p 
\v 10 Bena peroveta tauna Hanania ese maduna audia na peroveta tauna Ieremia aiona amo e abidia, bena e hakwaidudia.
\v 11 Bena Hanania na taunimanima iboudiai vairadiai e hereva, eto, Iehova ini e gwau tomamu: Laḡani rua do basie ore ai lau ese Nebukadnesara, Babulono pavapavana, ese e atodia madunadia na bese iboudiai aiodia amo unu baine hakwaidudia toma. Bena peroveta tauna Ieremia na ena ura dalana amo ela.
\p 
\v 12 Peroveta tauna Hanania ese maduna audia na peroveta tauna Ieremia aiona amo e hakwaidudia murinai, nega taina vada ela, bena Iehova ena hereva na Ieremia enai e kau, eto,
\v 13 Aola, Hanania ba hamaoroa, baoto, Iehova ini e gwau tomamu: Oi ese au madunadia vada o hakwaidudia, a lau ese auri madunadia baina kara, idia ibolodia.
\v 14 Badina be Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Lau ese ini bese iboudiai aiodia ai auri madunadia vada na atodia, Nebukadnesara, Babulono pavapavana, isiaina ilao-henina ḡaudia; bona idia ese ia isiaina bae lao heni, badina be lau ese tanobada boromadia danu vada na henia.
\p 
\v 15 Bena peroveta tauna Ieremia ese peroveta tauna Hanania e hamaoroa, eto, Hanania e, a kamonai! Iehova ese se siaimu; bona oi ese ina bese taudia lalodia e ha-uradia bena koikoi herevana vada e abidadama henia.
\v 16 Taunabunai, Iehova ini e gwau tomamu: A itaia, lau ese tanobada kopina amo baina abimu oho; hari ina laḡani lalonai vada ba mase, badina be Iehova igwau-edeede-henina herevadia vada o gwaurai.
\p 
\v 17 Una laḡani lalonai, hua ihahituna ai, peroveta tauna Hanarua na e mase.
\c 29
\s1 Ieremia ena revareva
\p 
\v 1 Peroveta launa Ieremia ena revareva, Ierusalem amo e siaia lao, Nebukadnesara ese Ierusalem amo Babulono e laohaidia unuseni ai e hanohodia taudia edia tau-badadia bona hahelaḡa taudia bona peroveta taudia bona taunimanima iboudiai edia, revarevana herevadia bini.
\v 2 Ina be King Iekonia mai sinana bona mai ena hesiai taudia ida, bona Iuda bona Ierusalem lohiadia, bona ima karakara dibaka bona auri iḡaukaralaina taudia, ese Ierusalem e rakatania murinai.
\v 3 Ina revareva na Elasa Safana bona Gemaria Hilkia, Iuda pavapavana Sedekia ese Babulono e siaidia lao Babulono pavapavana Nebukadnesara dekenai taudia, imadia ai e siaia lao. Ini e torea toma:
\p 
\v 4 Iehova Sabaota, Israel Diravana, ese Ierusalem amo vada e siaidla lao bena Babulono ai vada e hanohodia taudia na ini e hamaorodia tomamu:
\v 5 Ruma ba hagini, bena ba noholai; uma ba kara, bena anidia bavani.
\v 6 Hahine bavadavadia, natumui mamaruanedia bona hahinedia ba havaradia; hahine haida ma bavabidia, natumui mamaruanedia adavadia, bona natumui hahinedia na ba haheadavadia. Bena idia ese natudia mamaruanedia bona hahinedia ma bae havaradia eneseni ai; bena bae hutuma, basie gadoi.
\v 7 A vada na siaimui lao eneseni ai ba noho hanuana ena namo ba tahua, bona Iehova ba ḡuria ia dainai; badina be iena namo ai emui namo ba davaria.
\v 8 Badirla be Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Emui peroveta taudia bona emui bagu-haoro taudia bogaragimui ai e nohomu ese basie koimui, bona edia nihi sivaraidia basio kamonai;
\v 9 badina be idia ese e hereva koikoi henimuimu lau ladagu ai; lau ese asina siaidia. Iehova na e herevamu.
\p 
\v 10 Badina be Iehova ini e gwau tomamu: Laḡani hitu-ahui bae ha-ore Babulono enai, bena baina vadivadi henimui, bona egu gwauhamata na emui ai baina hamomokania, bona baina hakaumui lou mai ina gabu ai.
\v 11 Iehova na e tomu, Badina be egu lalo-hata ḡaudia emui ai na dibagu, ihanamomui ḡaudia, dia ihadikamui ḡaudia, nega vaira ḡaudia bona helaro ḡaudia.
\v 12 Bena ba hahanegu bona igurigu baoma; bena lau ese baina kamonai henimui.
\v 13 Ba tahugu, bena ba davarigu; mai lalomui idoidiai ba tahugu negana ai na
\v 14 ba davarigu. Iehova na e herevamu; ma e tomu, Emui taḡa ma baina henimui lou, bona bese iboudiai bogaragidia amo bona na lulumui lao gabudia iboudiai amo ma baina haboumui. Iehova ma e tomu, Ina gabu amo na siaimui oho dauhai, bona ina gabu ai ma baina hakaumui lou.
\p 
\v 15 Umui vada oto “Iehova ese peroveta taudia haida na Babulono ai vada e haginidia eda” dainai,
\v 16 hanua pavapavana, David ena terono ai e helaimu tauna, bona ina hanua e noholaiamu taudia iboudiai, umui varavaramui, abi-mauri ai gabu daudau asiela taudia, na Iehova ese ini e herevalaidia tomamu.
\v 17 Iehova Sabaota na ini e gwau tomamu: A itaia, lau ese dare bona doe bona dai-hanai gorerena na latadiai na siaimu; bona suke huahuadia dikadika, dika-rohoroho dainai basie heani diba ḡaudia, heḡereḡeredia ai baina halaodia.
\v 18 Dare, doe, dai-hanai goreredia amo baina ḡavadia loa, bona hahegari ḡauna ai baina halaodia, tanobada basileiadia iboudiai ediai; idia na ediai vada na luludia lao basileiadia bogaragidiai heuduguirai bona hahegari bona si-dagu bona gwau-tora ḡauna ai baela.
\v 19 Badina be (Iehova na e tomu) egu hereva na asie kamonaidia, egu hesiai peroveta taudia ududia amo na siaidia havara-havara herevadia na asio hakala henidia. Iehova na e herevamu.
\p 
\v 20 Umui Ierusalem amo na siaimui lao, Babulono ai, gabu daudau ai, na hanohomui taumui iboumui ai, Iehova ena hereva ba kamonai.
\v 21 Iehova Sabaota, Israel Diravana, ese Ahaba Kolaia bona Sedekia Maaseia, lau ladagu ai e peroveta henimui koikoimu taudia, na ini e herevalaidia tomamu: A itaia, Nebukadresara, Babulono pavapavana, imana ai baina atodia, bena ia ese umui vairamui ai baine aladia mase.
\v 22 Idia daidiai ina heuduguirai herevana na Iuda taudia Babulono ai e hanohodia iboudiai ese bae gwauraia loulou, baeto “Iehova ese Sedekia bona Ahaba, Babulono pavapavana ese lahi ai e gabudia taudia, heḡereḡeredia ai baine halaomui”.
\v 23 Badina be Israel ai vada e kara kava kara kava, bona dekedia taudia adavadia ida vada !l e heuda hanai, bona lau ladagu ai hereva koikoidia, lau ese asina haḡanilaidia herevadia, vada e gwaurai hedinaraimu. Iehova na e tomu, Lau be dibagu, bona na ita ḡaudia na herevalaimu.
\p 
\v 24 Semaia, tau Nehelama, na ini ba hamaoroa toma, baoto,
\v 25 Iehova Sabaota, Israel Diravana, na ini e gwau tomamu; Revareva na oi sibomu ladamu ai vada o siai lao, Ierusalem ai e nohomu taudia iboudhi ediai, bona Sefania Maaseia, hahelaḡa tauna, enai, bona hahelaḡa taudia iboudiai ediai, oto:
\v 26 Iehova ese hahelaḡa tauna ai vada e halaomu, hahelaḡa tauna Iehoiada gabuna ai, Iehova ena dubu ba biagua, bona kava taudia iboudiai unuseni ai e perovetamu na aedia bona aiodia hekahi-tao audia ai bavatodia.
\v 27 Be, dahaka dainai hari e peroveta henimumu tauna, Ieremia, tau Anatoto, so gwau henia?
\v 28 Badina be hereva na ai dekemal ai vada e siaia mai, Babulono ai, eto, Emui noho hedoa na baine daudau; ruma ba hagini, bena ba noholai; bona uma ba kara, bena anidia bavani.
\p 
\v 29 Hahelaḡa tauna Sefania ese una revareva na peroveta tauna Ieremia vairanai e duahia.
\v 30 Bena Iehova ena hereva na Ieremia enai e kau, eto:
\v 31 Hereva na dauhai e nohomu taudia iboudiai dekedia ba siaia lao, baoto, Iehova ese Semaia, tau Nehelama, ini e herevalaia tomamu: Badina be Semaia ese vada e peroveta henimui bona vada e dibaganimui, hereva koikoina ba badinaia totona, a lau ese ia asina siaia,
\v 32 una dainai Iehova na ini e gwau tomamu: A itaia, Semaia, tau Nehelama, mai garana ida, davadia baina henidia; ina bese bogaraginai ia garana ta basine mauri, bona egu bese taudia baina hanamolaidia karadia basine itaia; badina be Iehova igwau-edeede-henina vada e gwauraia. Iehova na e herevamu.
\c 30
\s1 Noho-hedoa taudia na bae lou
\p 
\v 1 Iehova ena amo Ieremia enai e kau herevana binai.
\v 2 Iehova, Israel Diravana, na ini e gwau tomamu: Vada na gwaurai henimu herevadia iboudiai na buka ta ai ba tore.
\v 3 Badina be (Iehova na e tomu) negana be maimu lau ese egu bese taudia edia noho baina hanamoa lou, Israel taudia bona Iuda taudia danu; bona baina hakaudia lou mai, senedia na henidia tanona lalonai; bena bae ḡaunaia. Iehova na e herevamu.
\p 
\v 4 Iehova ese Israel bona Iuda e herevalai herevadia bini.
\v 5 Iehova ini e gwau tomamu:
\q1 Gari taku lolona vada a kamonai,
\q2 gari bada lolona, a dia maino.
\q1 
\v 6 Ba henanadai bena ba diba,
\q2 tau ta baine rogorogo diba a?
\q1 Matona, badina be dahaka tatau iboudiai na itadiamu,
\q2 imadia na koekoedia ai heheato, e hekamonaimu hahinena na heto?
\q2 bona dahaka dainai vaira iboudiai vada e lalabora?
\q1 
\v 7 Madi, una dina na bada herea,
\q2 ia heḡereḡerena ta na lasi;
\q1 una na lalo-hisihisi negana, Iakob ena;
\q2 ḡau tamona, ena amo do bae hamauria.
\p 
\v 8 Iehova Sabaota na e tomu: Una dina ai lau ese aiodia madunadia baina hakwaidu, bona iḡuidia auridia baina hamotu, bena idau taudia ese edia hesiai taudia ai basie halaodia lou.
\v 9 A idia ese edia Dirava Iehova bona edia pavapava David, idia daidiai baina hatorea isi lou tauna, na isiaidia bae lao heni.
\v 10 Iehova na e tomu:
\q1 Egu hesiai tauna Iakob e, basio gari!
\q2 Israel e, kudoumu basine hetaha!
\q1 A itaia, dauha amo baina hamaurimu,
\q2 bona garamu danu iḡui ai e nohomu tanodia amo baina hamauridia.
\q1 Iakob baine lou, asi reḡereḡena baine laḡa ani,
\q2 bona ta ese basine hagaria.
\q1 
\v 11 Badina be lau na oi ida, baina hamaurimu totona;
\q2 Iehova na e herevamu.
\q1 Bese iboudiai baina ha-oredia vaitani,
\q2 hari bogaragidiai na hakarohomui rohoroho besedia;
\q2 a oi na basina ha-oremu vaitani.
\q1 Dika davana korikorina baina henimu,
\q2 momokani, matamu ihakanina basina reaia.
\p 
\v 12 Badina be Iehova ini e gwau tomamu:
\q1 Emu hisihisi na asi ihanamona,
\q2 bona beromu na dika herea.
\q1 
\v 13 Ta ese emu ginikau gabuna basine durua,
\q2 beromu na asi muramurana,
\q2 asi ihamaurimu dalana ta.
\q1 
\v 14 E lalokau henimuva taudia ese vada e lalomu boio;
\q2 idia ese asie lalomumu;
\q1 badina be inai tauna na heto vada na rahumu mase,
\q2 inai tauna asi ena hebogahisi na heto davaniu vada na henimu;
\q1 badina be emu kerere na bada,
\q2 bona emu kara dika na hehedinararai horea-horea.
\q1 
\v 15 Dahaka dainai beromu o tailaiamu?
\q2 Emu hisihisi na asi ihanamona.
\q1 Badina be emu kerere na bada,
\q2 bona emu kara dika na hehedinararai horea-horea;
\q2 una dainai ini vada na kara henimu toma.
\q1 
\v 16 Taunabunai, e ha-oremumu taudia iboudiai na bae ha-oredia,
\q2 bona inaimu iboudiai na iḡuidia ai bae laohaidia;
\q1 e dadimumu taudia na bae dadihaidia,
\q2 bona damudia ai bae halaomu taudia iboudiai na
\q2 damu ai baina halaodia.
\q1 
\v 17 Badina be baina hamaurimu lou,
\q2 bona beromu baina hanamodia.
\q2 Iehova na e herevamu.
\q1 Badina be vada e gwauraimu “e lulua oho tauna”,
\q2 “Siona, ta ese se laloamu hanuana”.
\p 
\v 18 Iehova ini e gwau tomamu:
\q1 A itaia, Iakob ena kalaga baina hanamoa lou,
\q2 bona ena noho gabudia baina bogadia hisi;
\q1 hanua na ena tano latalatana ai bae haginia lou,
\q2 bona pavapava rumana na ena gabu gunana ai baine gini.
\q1 
\v 19 Idia lalodia amo hahenamo anedia bae dae,
\q2 bona moale taudia gadodia danu.
\q1 Lau ese baina hahutumadia, idia na basie gadoi;
\q2 baina imodaidia, bena basie maraḡi.
\q1 
\v 20 Natudia na bae noho, nega gunadia heḡereḡeredia,
\q2 bona edia orea na lau vairagu ai bae haginia;
\q1 bona bae hahisihisidia taudia iboudiai na
\q2 matadia baina hakanidia.
\q1 
\v 21 Idia ta ese baine lohiadia;
\q2 idia bogaragidia amo ta ese baine biagudia.
\q1 Lau ese baina harakaia kahi, bena baine raka henigu kahi;
\q2 badina be daika na mai boga-aukana sibona baine raka henigu kahi.
\q2 Iehova na e herevamu.
\q1 
\v 22 Umui na lauegu bese ai baola,
\q2 bona lau na emui Dirava ai bainala.
\b
\q1 
\v 23 A itaia, Iehova ena lai gubana!
\q2 Badu vada e lasi, koe-hirihiri ta,
\q2 kara dika tauna kwarana ai baine kau.
\q1 
\v 24 Iehova ena badu garagarana na basine doko,
\q2 ela bona ia ese ena lalo-hata ḡaudia iboudiai na
\q2 baine kara bona baine haguḡuru.
\q1 Ina ḡau do ba diba,
\q2 dina gabedia ai.
\c 31
\p 
\v 1 Iehova na e tomu: Una negana ai, lau na Israel iduhudia iboudiai edia Dirava ai bainala, bona idia na lauegu bese taudia ai baela.
\v 2 Iehova ini e gwau tomamu:
\q1 Dare amo vada e roho mauri taudia ese
\q2 harihari-bada na e davaria, tano ḡaḡaena ai.
\q1 Israel ese laḡa-ani e tahua negana ai,
\q2 
\v 3 Iehova na dauha amo ienai e hedinarai.
\q1 Mia-hanaihanai urahenina amo vada na ura henimu;
\q2 uda dainai egu heabidadama na emu ai vada e hahesiriua.
\q1 
\v 4 Baina haginimu lou, bena vada ba gini,
\q2 Israel, hane-ulato rami-hebouna, e!
\q1 Tareko ba heralai lou, ba raka lasi;
\q2 e moale heboumu taudia edia mavaru lalonai ba vareai.
\q1 
\v 5 Vine imeadia ma ba hado lou,
\q2 Samaria ororodia ai;
\q1 biru taudia na bae hadohado,
\q2 bena uma anidia bae ani.
\q1 
\v 6 Badina be dinana baine kau, gima taudia na bae boiboi,
\q2 Efraim ororodia ai, baeto
\q1 “A tore isi, Siona ai baita dara dae,
\q2 Iehova, eda Dirava, dekenai”.
\p 
\v 7 Badina be Iehova na ini e gwau tomamu:
\q1 Ane avabi mai moalemui ida, Iakob dainai;
\q2 ba lolo, bese loḡora ikwaradia tauna enai;
\q1 ba haroro, ba heimodai, baoto
\q2 “Iehova ese ena bese taudia Israel kwabukwabudia vada e hamauridia”.
\q1 
\v 8 A itaia, mirigini kahana amo baina mailaidia,
\q2 tanobada kaha-daudaudia amo baina haboudia;
\q1 bogaragidiai na mata-kepulu bona ae-hedairike taudia,
\q2 e rogorogomu hahinena bona e hekamonaimu hahinena danu e raka heboumu;
\q2 orea badana bae lou mai iniseni ai.
\q1 
\v 9 Mai taiadia ida baema,
\q2 bena mai egu tauhalo ida baina hakaudia lou mai;
\q1 sinavai-sinavai badibadidiai baina harakadia,
\q2 dala maoromaorona ai, bena basie hetutuhi;
\q1 badina be lau na Israel tamana,
\q2 bona Efrai na natugu roboana.
\b
\q1 
\v 10 Bese idau-idau e, Iehova ena hereva ba kamonai;
\q2 dauhai, kone tanodia ai, ba gwauraia hedinarai, baoto
\q1 “Israel taudia e hakarohodia Diravana ese
\q2 ma baine gogodia,
\q1 bona mamoe ireḡudia tauna ese ena mamoe e regudiamu na heto,
\q2 ia ese baine regudia”.
\q1 
\v 11 Badina be Iehova ese Iakob vada e davalaia,
\q2 bona ena goada e hereaia taudia imadia amo vada e hamauria.
\q1 
\v 12 Idia na baema, Siona dorina ai ane bae abi badabada,
\q2 bona vairadia bae diari-diari, Iehova ena hahenamo dainai,
\q1 bona aniani, vine ranuna, dehoro daidiai,
\q2 bona mamoe natudia bona boromakau natudia daidiai;
\q1 edia mauri na e haparipariamu umana na heto,
\q2 bona taudia basie manori lou.
\q1 
\v 13 Bena ulato na mavaru ai bae moale,
\q2 bona uhau bona iahu bae hisi dae.
\q1 Lau ese edia taitai na moale ai baina halaoa;
\q2 taudia baina halodia, bona moale baina henidia,
\q2 lalo-hisihisi gabuna ibolona.
\q1 
\v 14 Hahelaḡa taudia lalodia na ḡau namodia amo baina ubudia badabada,
\q2 bona egu bese taudia bogadia na egu hahenamo ai bae kunu.
\q2 Iehova na e herevamu.
\p 
\v 15 Iehova ini e gwau tomamu:
\q1 Gado ta Rama ai e hekamonaimu,
\q2 rohe-ahu bona tai ḡadegade bada.
\q1 Rahela be natuna taidia e taimu,
\q2 natuna daidiai tauhalo se uramu,
\q2 badina be idia na lasihidia.
\p 
\v 16 Iehova ini e gwau tomamu:
\q1 Ba haheauka, basio tai,
\q2 bona iruru-matamu basie diho;
\q1 badina be emu ḡaukara ahuna bavabia (Iehova na e herevamu),
\q2 bona idia na inai taudia edia tano amo bae lou mai.
\q1 
\v 17 Nega vairai emu helaro ḡaudia bavabi (Iehova na e herevamu),
\q2 bona natumu na bae lou mai, edia tano korikori ai.
\q1 
\v 18 Efraim ena ḡanaḡana vada na kamonai, eto
\q2 “Matagu o hakania, bena matagu e kani,
\q2 boromakau natuna, do asie hamanadaia ḡauna, na heto;
\q1 ba hakaugu lou, baina namo lou helaoreana,
\q2 badina be oi na Iehova, egu Dirava;
\q1 
\v 19 badina be na raka oho murinai na helalo kerehai,
\q2 e hadibadibagu murinai mamugu na pataia;
\q1 na hemarai, na baia,
\q2 badina be eregabegu hemaraina na huaia”.
\q1 
\v 20 Efraim be na lalokau heniamu merona ani?
\q2 Ia na natugu lalokau ani?
\q1 Badina be ihadikana na gwauraiamu negadia iboudiai na
\q2 doini na laloa taomu.
\q1 Taunabunai lau lalogu ese e ura henia badamu;
\q2 momokani lau ese baina bogaia hisi.
\q2 Iehova na e herevamu.
\b
\q1 
\v 21 Dala toadia ba hagini emui,
\q2 emui dala iduanaidia audia ba kara;
\q1 laolao dalana ba haeroa namonamo,
\q2 o rakalaiamu dalana ba haeroa.
\q1 Israel e, hane-ulato rami-hebouna e, a lou;
\q2 ini emui hanua ba lou heni.
\q1 
\v 22 Kara hebeatai kekenimu e,
\q2 ba daradara ela bona edena nega ai?
\q1 Badina be Iehova ese kara matamaLana ta tanobada ai vada e havaraia:
\q2 hahine ta ese tau ta e gimaiamu.
\p 
\v 23 Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Ma nega ta ini hereva na Iuda tanona ai bona ena hanua lalodiai bae gwaurai lou, edia noho ma baina hanamoa lou negana ai.
\q1 Kara maoromaoro e nohomu gabuna e! Ororo helaḡana e!
\q2 Iehova ese baine hanamomu.
\m 
\v 24 Bena Iuda bona ena hanua iboudiai na unuseni ai bae noho hebou, bona biru taudia bona edia seri ida e loaloamu taudia danu.
\v 25 Badina be lalona e manokamu tauna na lalona baina hagoadaia, bona lalodia e hisihisimu taudia iboudiai na lalodia baina hagoadadia lou.
\p 
\v 26 Bena na noga, na roharoha; egu mahuta mamina vada e namo egu ai.
\s1 Taravatu Matamatana
\p 
\v 27 Iehova na e tomu: A itaia, negana vada e maimu lau ese taunimanima bona ubu-ubu ḡaudia na baina havaradia, Israel iduhuna ai bona Iuda iduhuna ai.
\v 28 Bena iragadia bona iḡiḡi-dobidia, ihadareredia, ihabua-taridia bona ihadikadia totona vada na itadia tao heḡereḡerena ai, lau ese ihaginidia bona ihadaidia totona vada na itadia tao. Iehova na e herevamu.
\v 29 Unu dinadia ai idia na basie hereva lou, basieto
\q1 “Tama ese vine huahuadia kasiridia vada e ani,
\q2 bona natudia isedia e urimu”.
\m 
\v 30 A ta ta na ena kara dika ena kara dika daidiai bae mase; vine huahuadia iditadia e animu taudia na sibodia isedia bae uri.
\p 
\v 31 Iehova na e tomu: A itaia, negana vada e maimu lau ese taravatu matamatana na Israel iduhuna bona Iuda iduhuna enai baina kara,
\v 32 dia senedia ediai na karaia taravatu na na heto, imadia na abidia Aigupto tanona amo baina hakaudia lasi totona negana ai na karaia taravatuna, bena, ena be lau na idia adavadia, to idia ese e tataia utu. (Iehova na e herevamu.)
\v 33 A ina na Israel iduhuna enai baina karaia taravatuna, unu dina muridiai. Iehova na e tomu: Egu taravatu na ediai baina atoa, bona lalodia ai baina torea; bena lau na edia Dirava ai bainala, bona idia na lauegu bese taudia ai baela.
\v 34 Una murinai asi tauna ta ese dekena tauna eiava tadikakana baine hadibaia, baineto “Iehova na ba dibaia”; badina be iboudiai ese bae dibagu, maragina amo ela bona badana (Iehova na e herevamu); badina be edia kara havara baina gwaua tao bona edia kara dika basina laloa tao lou.
\q1 
\v 35 Iehova, dina e henimu, diari ihavarana,
\q2 bona hua bona hisiu edia dala korikori e henidiamu,
\q1 hanuaboi diarina ai baela, Diravana na
\q2 ini e gwau tomamu.
\q1 Ia ese davara e haginiamu ela bona hurehure na mai gurudia ida e poumu;
\q2 ia ladana na Iehova Sabaota.
\q1 
\v 36 Iehova na e tomu:
\q2 Ini edia dala korikori na vairagu amo bema heabi oho,
\q1 bena Israel vevena na basie noho bese ta lau vairagu ai,
\q2 ela bona hanaihanai.
\q1 
\v 37 Iehova ini e gwau tomamu:
\q2 Guba atai ai bema hahetohoa diba,
\q2 bona tano badidia henu ai bema tahudia diba,
\q1 bena Israel vevena iboudiai bama negedia daure,
\q2 edia kara iboudiai daidiai.
\q2 Iehova na e herevamu.
\p 
\v 38 Iehova na e tomu: A itaia, nega na e maimu, hanua na bae haginia lou, Iehova ena, Hananele kohorona amo ela bona Daiguni Ikoukouna.
\v 39 Bena hahetoho varona na ma bae veria lao, maoromaoro bainela ela bona Gareb ororona, ma bae veria mageva ela bona Goa.
\v 40 Mase tau-anidia bona kahu kourana idoinai bona rei gabudia iboudiai ela bona Kidron dokadokana, ela bona Hosi Ikoukouna daigunina, mairiveina kahana ai, idoinai baine helaḡa Iehova ena. Ia na nega ta ai basine heraga eiava basine heḡiḡi dobi ela bona hanaihanai.
\c 32
\s1 Ieremia ese tano ta e hoia Anatoto ai
\p 
\v 1 Ina hereva na Iehova ena amo Ieremia enai e kau, Sedekia, Iuda pavapavana, ena lohia laḡanina ihagvautana ai. Una na Nebukadresara ena lohia laḡanina ihagwauta-taurahanina.
\v 2 Una negana ai Babulono pavapavana ena tuari oreana ese Ierusalem vada e daia heḡeḡe; bona peroveta tauna Ieremia na hegima taudia edia magu lalonai vada e hekou, Iuda pavapavana ena ruma ai.
\v 3 Badina be Sedekia, Iuda pavapavana, ese vada e koua ahu, eto, Badina be dahaka o perovetamu, o tomu, Iehova ini e gwau tomamu: A itaia, lau ese ina hanua na Babulono pavapavana imana ai na atoamu, ia ese baine abia;
\v 4 bona Sedekia, Iuda pavapavana, na Kaldea taudia imadia amo basine roho mauri diba, a ia na momokani Babulono pavapavana imana ai baine heato, ia ida hevaira-hehenidia ai bae hereva heheni bona bae heroha heheni.
\v 5 Bena ia ese Sedekia na Babulono baine laohaia, unuseni ai baine noho ela bona lau ese baina vadivadi henia; Iehova na e herevamu. Ena be Kaldea taudia ba tuari henidia to basio kwalimu.
\p 
\v 6 Ieremia eto, Iehova ena hereva na egu ai e kau, eto,
\v 7 A itaia, Hanamele, tamamu lahaina Salumu natuna, na baine vasi, baineto “Egu tano Anatoto ai, Beniamina tanona ai, ba hoia, badina be iabi-taona siahuna na oiemu ai”.
\v 8 Bena tadikakagu Hanamele na dekegu ema, hegima taudia edia magu ai, Iehova ena hereva heḡereḡerena ai, e hereva henigu, eto, Egu tano Anatoto ai, Beniamina tanona ai, ba hoia, badina be iabina mai siahuna tauna na oi; ba hoia emu. Bena na diba una na Iehova ena hereva.
\p 
\v 9 Bena una tano Anatoto ai na tadikakagu Hanamele ena amo na hoia, moni na hahetohoa, na henia, \it silver\it* sekeledia gwauta-hitu.
\v 10 Ladagu na tano ibiaguna pepana ai na torea, na koua kunuka-kunuka, bena kara ihamomokanina taudia na abidia, bona moni na metau ihahetohona ḡauna ai na hahetohoa.
\v 11 Bena hari tano ibiaguna pepana, e koua kunuka-kunuka ḡauna, bona ia ida-idana pepana ta, e hulala ḡauna, na abidia;
\v 12 bena hari tano ibiaguna pepana na Baruku, Neria Mahaseia natuna, na henia, tadikakagu Hanamele vairanai, bona kara ihamomokanidia totona ladadia na una pepa ai e tore taudia vairadiai, bona Iuda taudia, hegima taudia edia maḡu ai e helaiva taudia, iboudiai vairadiai danu.
\v 13 Idia vairadiai Baruku na haḡania, nato,
\v 14 Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Ini tano ibiaguna pepadia, hari e koua kunuka-kunuka ḡauna, bona hari e hulala ḡauna danu, avabidia, hodu ta ai ba udadia, bae mia daudau helaoreana.
\v 15 Badina be Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Ruma bona tano bona vine imeadia ma bae hoi lou ina tano ai.
\p 
\v 16 Hari tano ibiaguna pepana na Baruku Neria na henia murinai, lau ese Iehova na ḡuria, nato,
\v 17 Ḡaubada Iehova e, oi ese guba bona tanobada na emu siahu badana bona imamu hetoi-rorona amo vada o kara. Ḡau ta na dia auka oiemu;
\v 18 oi na daha daha o bogadia hisimu, a tama edia kerere davadia na muridiai natudia o henidiamu. Dirava badana, Siahu Diravana e, oi ladamu na Iehova Sabaota;
\v 19 emu hahealo na bada, bona emu kara na mai siahudia; oi matamu e papamu, taunimanima edia kara iboudiai o itadiamu, ta ta ena dala ena dala bona ena kara anidia ena kara anidia heḡereḡeredia davadia o henidiamu.
\v 20 Oi ese toa bona hoa karadia na Aigupto tanona ai vada o hahedinarai, bona Israel ai bona taunimanima iboudiai bogaragidiai danu, ema bona ina dina; bona sibomu ladamu vada o hadaea ina dina ai.
\v 21 Oi ese emu bese Israel na Aigupto tanona amo o hakaudia lasi, mai toa bona hoa karadia, bona mai imamu goadana, mai imamu hetoi-rorona, bona mai hahegari badana ida.
\v 22 Ina tano danu vada o henidia, senedia o gwau henidia hamata ba henidia oto tanona, rata bona bada ranuna e arumu tanona;
\v 23 bena e raka vareai, e ḡaunaia. A idia na oi eremu asie kamonai, bona oiemu taravatu ai asie raka; o haganilaidia karadia iboudiai na ta asie karaia. Una dainai ina dika idoinai na idia latadiai vada o hadihoa.
\v 24 A itaia, tano vada e senua, hanua badana iabina totona, bena dare bona doe bona dai-hanai gorerena daidiai hanua na Kaldea taudia, e tuari heniamu taudia, imadia ai vada e atoa. O gwaurai herevadia anidia vada e vara, bena vada o itaia.
\v 25 A oi, Ḡaubada Iehova e, vada o hamaorogu, oto, Ena be hanua na Kaldea taudia imadia ai vada na atoa, to oi ese tano na moni amo ba hoia, kara ihamomokanina taudia danu bavabidia.
\p 
\v 26 Iehova ena hereva na Ieremia enai e kau, eto:
\v 27 A itaia, lau na Iehova, mauri ḡaudia iboudiai edia Dirava. Kara ta na auka herea, bena basina karaia diba a?
\v 28 Taunabunai Iehova ini e gwau tomamu: A itaia, lau ese ina hanua na Kaldea taudia imadia ai bona Nebukadresara, Babulono pavapavana, imana ai baina atoa, bena ia ese baine abia.
\v 29 Kaldea taudia, ina hanua e tuari heniamu taudia, na baema, ina hanua na bae daea, bae doua; guhidia ai muramura mai bonana na Baal e gabu henia bona inuinu bouboudia na dirava idaudia e bubu henidia bena unu amo e habadugu rumadia danu bae dou.
\v 30 Badina be Israel garana bona Iuda garana na kara dikadia mo vada e kara lau vairagu ai, merodia negadia amo, Israel garana imadia ḡaukaradia na lau ihabadugu karadia mo. Iehova na e herevamu.
\v 31 Ina hanua ese egu badu bona egu lalo-siahu vada e havaradia, e haginia dinana amo ema bona ina dina, una dainai lau ese vairagu amo baina abia oho,
\v 32 Israel garana bona Iuda garana edia kara dika iboudiai daidiai. Idia ese lau ihabadugu karadia e kara: edia pavapava bona edia lohia, edia hahelaḡa taudia bona edia peroveta taudia, Iuda taudia bona Ierusalem inoholaina taudia ese.
\v 33 Idia ese vada e gini muri henigu, asie vaira henigu. Ena be na hadibadia havara-havara to idia ese hahediba herevadia na asie hakala henidia.
\v 34 Edia ḡau dika-rohorohodia na e haginidia, lau ladagu e henemailaia dubuna lalonai, bae hamiroa totona.
\v 35 Baal ena atai gabudia helagadia e larebadia, Hinom natuna ena koura ai, natudia mamaruanedia bona hahinedia na boubou ḡaudia ai bae halaodia totona, Molek ena. A lau ese asina haḡanidia bona asina laloa idia ese una kara dika-rohorohona amo Iuda taudia bae hakaradia dika.
\p 
\v 36 Taunabunai, ina hanua, umui ese o herevalaiamu, o tomu “Dare bona doe bona dai-hanai gorerena amo Babulono pavapavana imana u vada e atoa”, hanuana na Iehova, Israel Diravana, ese ini e herevalaia tomamu:
\v 37 A itaia, egu badu bona egu lalo-siahu bona egu lalo-garagara bada-herea lalonai na luludia lao tanodia iboudiai amo ma baina haboudia lou; baina loulaidia ina gabu ai, bona baina hanohodia namonamo.
\v 38 Idia na lauegu bese ai baela bona lau na edia Dirava ai bainala.
\v 39 Lalo tamona bona dala tamona baina henidia, bena lau bae gari henigu hanaihanai, idia bona muridhi natudia danu ihanamodia.
\v 40 Lau ese egu gwauhamata baina henidia hanaihanai, bainato, idia ihanamodia karadia amo basina raka siri; bona lau garigu na lalodia ai baina atoa, egu amo basie raka siri helaoreana.
\v 41 Idia ihanamodia karadia baina moalelaidia, bona heabidadama ai ina tano ai baina hadaidia, mai lalogu idoinai bona mai laumagu idoinai ida.
\p 
\v 42 Badina be Iehova ini e gwau tomamu: Ina dika badana idoinai na ina bese taudia latadiai vada na hadihoa heḡereḡerena, lau ese danu na gwauhamatalai henidiamu kara-namodh iboudiai ma baina hadiho.
\v 43 Ina tano, umui ese o herevalaiamu, o tomu “Ia na vada e vahu, asi tauna bona asi ubu-ubu ḡauna; Kaldea taudia imadia ai vada e atoa”, tanona lalonai inogo vada ba hoi;
\v 44 Inoḡo na moni amo ba hoi, bona tano ibiagudia pepadia ai ladamui ba tore, bena ba koudia kunuka-kunuka, bona kara ihamomokanina taudh ese bae hamomokanidia, Beniamina tanona ai, bona Ierusalem hetabirana ai, bona Iuda hanuadia ai, bona ororo kahadia hanuadia bona taora hanuadia bona diho kahana hanuadia ai; badina be edia noho ma baina hanamoa lou. Iehova na e herevamu.
\c 33
\s1 Ierusalem ihanamo-louna
\p 
\v 1 Nega iharuana Iehova ena hereva na Ieremia enai e kau, ia na dounu hegima taudia edia maḡu ai e hekou ahu negana ai.
\v 2 Iehova, tanobada e karaia bona baine gini tutuka-tutuka totona oromana e henia Diravana (ia ladana na Iehova) ini e gwau tomamu:
\v 3 Ba boi henigu, bena baina haere henimu, bona ḡau badadia, hehuni ḡaudia, do asi dibamu ḡaudia, na baina hamaorolaimu.
\v 4 Badina be Iehova, Israel Diravana, ese ina hanua rumadia bona Iuda pavapavadia edia ruma, e larebadia tanodia bona dare ilao-ahudia totona e ḡiḡidia dobi rumadia, na ini e herevalaidia tomamu:
\v 5 Kaldea taudia na e aru e maimu, bae tuari henidia, bona egu badu bona egu lalo-siahu ai baina rahudh mase taudia tau-anidia masedia amo bae hahonudia; badina be lau ese vairagu na ina hanua amo vada na hunia, edia kara dikadia iboudiai daidiai.
\v 6 A itaia, lau ese goada bona tauhalo baina henia; baina hanamodia, bona noho-namo bona noho-maino na baina hahedinarai henidia badabada.
\v 7 Iuda bona Israel edia noho-namo ma baina henidia lou, bona baina haginidia lou, e gini gunava heḡereḡerena.
\v 8 E kara dika henigu dikana mirona idoinai amo baina haḡoevadia, bona edia kara dika bona edia gwau-edeede egu ai mirona idoinai na baina gwaua tao.
\v 9 Bena ina hanua na egu ai lada mai moalena, heimodai ḡauna bona hairai ḡauna ai bainela, tanobada besedia iboudiai vairadiai. Idia ese kara namo iboudiai, lau ese na kara henidiamu karadia, sivaraidia bae kamonai; idia na bae gari, taudia bae heude-heude, kara namo iboudiai bona noho-namo idoinai ina hanua baina karalai henia dainai.
\p 
\v 10 Iehova ini e gwau tomamu: Ina gabu, o herevalaiamu o tomu “Ia na vada e vahu, asi tauna ta eiava asi ubu-ubu ḡauna ta” gabuna ai, bona Iuda hanuadia ai bona Ierusalem ariaradia ai, idia danu vada e vahu, asi tauna ta eiava asi inoholaina ta eiava asi ubu-ubu ḡauna ta, unuseni ai
\v 11 kiri gadona bona moale gadona, headava matamata tauna gadona bona headava matamata hahinena gadona, bae kamonaidia lou; bona ane-abi taudia gadodia danu. Idia ese hahenamo boubouna ḡaudia na Iehova ena dubu ai bae mailaidia, baeto,
\q1 Iehova Sabaota ba hanamoa,
\q2 badina be Iehova na namo;
\q1 badina be ena hebogahisi na
\q2 e hesiriu hanaihanaimu.
\m Badina be lau ese tano ena noho-namo gunana ma baina henia lou. Iehova na e herevamu.
\p 
\v 12 Iehova Sabaota ini e gwau tomamu: Ina gabu ḡaḡaena, asi tauna ta eiava asi ubu-ubu ḡauna ta gabuna, lalonai, bona hanuana iboudiai lalodiai, mamoe ireḡudia taudia, edia mamoe e halaḡa-anidiamu taudia, edia noho gabudia ma bae hekara lou.
\v 13 Ororo kahadia hanuadia ai bona taora hanuadia ai bona diho kahana hanuadia ai, bona Beniamina tanona ai bona Ierusalem hetabirana gabudia ai, bona Iuda hanuadia ai, mamoe seridia na iduahidia tauna imana henudia amo bae raka hanai. Iehova na e herevamu.
\p 
\v 14 Iehova na e tomu: A itaia, negana be maimu, lau ese Israel iduhuna bona Iuda iduhuna na henidia gwauhamatana baina hamomokania.
\v 15 Unu dinadia ai bona una nega ai, lau ese Rigi ta, kara maoromaoro ḡauna, na baina hatubua, David ena; bena ia ese hahemaoro ḡoevaḡoeva bona kara maoromaoro baine kara ina tano ai.
\v 16 Unu dinadia ai Iuda na baine mauri, bona Ierusalem baine noho namonamo. Bona ladana na ini bae hatoa toma: “Iehova na eda kara maoromaoro”.
\p 
\v 17 Badina be Iehova ini e gwau tomamu: David iduhuna amo nega ta ai Israel ena bese teronona ihelai-kauna taudia ta ai basine dabu,
\v 18 bona hahelaḡa taudia Levi oreana amo nega ta lau vairagu ai ḡole-oho bouboudia ihahelaḡadia bona flaoa bouboudia igabudia bona boubou karadia ikaradia taudia ta ai basie dabu, ela bona hanaihanai.
\p 
\v 19 Iehova ena hereva na Ieremia enai e kau, eto,
\v 20 Iehova ini e gwau tomamu: Egu haheḡani dina enai eiava hanuaboi enai boma utua diba, bena dina bona hanuaboi na edia nega korikoridia ai basiema hedinarai,
\v 21 bena egu gwauhamata egu hesiai tauna David enai danu ba utua diba, bena garana ta basine vara ena terono ihelai-kauna; bona egu gwauhamata hahelaḡa taudia Levi oreana amo, egu hesiai taudia, ediai danu ba utua diba.
\v 22 Guba hisiudia na asi iduahidia bona kone miridia na asi ihahetohodia na heto, egu hesiai tauna David garana bona hahelaḡa taudia Levi oreana amo garadia unu baina hahutumadia toma.
\p 
\v 23 Iehova ena hereva na Ieremia enai ma e kau, eto,
\v 24 Ini taunimanima edia hereva so kamonai, eto “Iehova ese e abidia hidi iduhudia ruaosi vada e dadaraidia”, a? Unuheto, idia ese egu bese taudia vada e dadaraidia, bena harihari idia na dia bese ta idia vairadiai.
\v 25 Iehova ini e gwau tomamu: Egu haheḡani dina bona hanuaboi ediai basinama haginia bona guba bona tanobada taravatudia danu,
\v 26 bena lau ese Iakob bona egu hesiai tauna David garadia baina dadaraidia, bona ia garana ta basina abia hidi, Abraham bona Isaak bona Iakob vevedia ilohiadia. Badina be edia noho-namo baina havara henidia lou, bona baina bogadia hisi.
\c 34
\s1 Ieremia ese Sedekia e sisiba henia
\p 
\v 1 A Nebukadresara, Babulono pavapavana, bona ena tuari oreana idoinai, bona tanobada basileiadia iboudiai, iena siahu henunai e nohova oreadia, bona bese idau-idau iboudiai, ese Ierusalem mai ena hanua iboudiai ida e tuari henidiava negana ai, Iehova ena hereva ta na Ieremia enai e kau, eto,
\v 2 Iehova, Israel Diravana, na ini e gwau tomamu: Aola, Sedekia, Iuda pavapavana, ba hereva henia, baoto, Iehova ini e gwau tomamu: A itaia, ina hanua na Babulono pavapavana imana ai baina atoa; ia ese lahi amo baine doua.
\v 3 Oi na ia imana amo basio roho mauri; momokani, haida ese bae abimu mauri, bena ia imana ai bae atomu. Oi na Babulono pavapavana ida ba heroha heheni, ba hevaira heheni, bona ba hereva heheni; bena Babulono baola.
\v 4 Sedekia, Iuda pavapavana, e! Iehova ena hereva ba kamonai. Iehova ese ini e herevalaimu tomamu: Dare ai basio mase.
\v 5 Maino ai ba mase. Senemu, pavapava dagina ai e gunalaimu taudia, daidiai muramura mai bonadia e gabu heḡereḡerena ai, taunimanima ese muramura mai bonadia bae gabu oi daimu ai, bona oi daimu ai bae rohe ahu, baeto “Ḡauka e, ihabaimu!” Iehova na e tomu: Vada na hereva.
\p 
\v 6 Bena peroveta tauna Ieremia ese ini hereva iboudiai na Sedekia, Iuda pavapavana, e hamaorolaia, Ierusalem ai,
\v 7 Babulono pavapavana ena tuari oreana ese Ierusalem bona Iuda hanuadia oredia iboudiai, Lakisi bona Aseka, dounu e tuari henidiava negana ai. Badina be hanua mai maḡudia dounu Iuda ai e miava be unu ruaosi mo.
\s1 Hesiai taudia iruhadia bona iḡui-loudia sivaraina
\p 
\v 8 King Sedekia ese Ierusalem taudia iboudiai taravadia e atu, hekahu-nege herevadia e gwaurai henidia, murinai Iehova ena hereva ta na Ieremia enai e kau.
\v 9 E gwaurai henidia herevana binai: idia iboudiai ese edia hesiai taudia, Heberu taudia vada e ḡuidia bona isiaidia ilao-henidia taudia ai vada e halaodia taudia, tatau bona hahine, bae ruhadia nege; bena tau ta ese tadikakana Iuda tauna ta basine ḡuia, ena hesiai tauna ai basine halaoa.
\v 10 Bena e kamonai, hanua lohiadia bona hanua taudia iboudiai ese taravatu vada e abia dae, iboudiai ese edia hesiai taudia, tatau eiava hahine, bae ruhadia nege, bena basie ḡuidia lou eto. Idia na e kamonai, e ruhadia nege.
\v 11 A gabeamo idia na e kerehai, edia hesiai taudia mamaruanedia bona hahinedia, vada e ruhadia nege taudia, na ma e abidia lou, e ḡuidia, hesiai taudia ai ma e halaodia.
\v 12 Bena Iehova ena hereva na Iehova ena amo Ieremia enai e kau, eto,
\v 13 Iehova, Israel Diravana, na ini e gwau tomamu: Senemui na Aigupto tanona amo bona iḡui rumana amo na hakaudia lasi negana ai lau ese taravadia na atu, nato
\v 14 “Laḡani tauratoi dokodia ai, iboumui ai ese tadikakamui Heberu taudia vada o hoidia bena laḡani tauratoi lalodiai isiaimui vada e lao heni taudia, vada ba ruhadia nege; isiaimui ilao-henina amo ba ruhadia nege”. A senemui ese asie kamonai henigu bona asie hakala henigu.
\v 15 Vanegai mo umui na o helalo kerehai, bena kara maoromaorona na lau vairagu ai vada o karaia, hekahu-nege o gwaurai hedinarai, ta ta dekena tauna dekena tauna ediai; bona lau vairagu ai o gwau hamata, lau ladagu e henemailaia dubuna lalonai.
\v 16 A ma o kerehai lou, lau ladagu o hamiroa; iboumui ai emui hesiai taudia mamaruanedia bona hahinedia, edia ura heḡereḡerena ai vada o ruhadia nege taudia, ma o abidia lou, o ḡuidia, hesiai taudia ai ma o halaodia.
\v 17 Taunabunai, Iehova ini e gwau tomamu: Asio kamonai henigu, hekahu-nege igwauraina ai, ta ta tadikakana tadikakana ediai, bona ta ta dekena tauna dekena tauna ediai; benaini, lau ese hekahu-nege na gwaurai henimuimu, dare bona dai-hanai gorerena bona doe na latamui ai na kahudia negemu, bona hahegari ḡauna ai baina halaomui tanobada basileiadia iboudiai ediai.
\v 18 Bona egu taravatu e tataia utu bona edia gwauhamata, lau vairagu ai e gwauraia ḡauna, asie badinaia taudia na boromakau natuna, idia ese e utua parara bona kahana kahana padadia amo e rakaia hanai ḡauna, heḡereḡerena ai baina halaoa:
\v 19 Iuda lohiadia, Ierusalem lohiadia, hesiai taudia, hahelaḡa taudia, bona hanua taudia, boromakau natuna kahana kahana padadia amo e raka hanai taudia iboudiai.
\v 20 Bena lau ese inaidia imadia ai bona edia mauri iabi-ohona dalana e tahuamu taudia imadia ai baina atodia. Tau-anidia masedia na atai manudia bona tanobada boromadia ese bae ani.
\v 21 Bona Sedekia, Iuda pavapavana, bona ena lohia taudia, na lau ese inaidia imadia ai, bona edia mauri iabi-ohona dalana e tahuamu taudia imadia ai, bona Babulono pavapavana ena tuari oreana, hari emui amo vada e raka oho oreana, imadia ai, baina atodia.
\v 22 Iehova na e tomu: A itaia, lau baina haheḡani, bena ma baina loulaidia mai, ina hanua ma baema; bena idia ese bae tuari henia, bae abia, lahi amo bae doua. Iuda hanuadia na baina havahudia, asi unoholaidia bae mia.
\c 35
\s1 Rekab taudia herevadia
\p 
\v 1 Iehoiakim, Iuda pavapavana Iosia natuna, ena nega ai, Iehova ena hereva na Ieremia enai e kau, eto,
\v 2 Rekab taudia edia ruma baola, ba hereva henidia, bena ba hakaudia mai, Iehova ena dubu ai, daiutuna ta lalonai. Bena vine ranuna ba dudui henidia, bae inua totona.
\v 3 Taunabunai, Iaasania, Ieremia Habasinia natuna, mai tadikakana bona natuna iboudiai ida, bona Rekab iduhuna idoinai, na abidia.
\v 4 Na hakaudia mai, Iehova ena dubu ai, Hanana Igdalia, Dirava ena tau, natuna edia daiutu lalonai. Una daiutu na lohia taudia edia daiutu badibadinai, bona Ma-aseia Salumu, dubu raka-vareaina igimana tauna, ena daiutu daenai.
\v 5 Bena hodu haida, vine ranuna ai e honu ḡaudia, bona kehere haida na idia vairadiai na ato; bena na hereva henidia, nato, Vine ranuna ba inua.
\v 6 A idia na e haere, eto, Ai na vine ranuna basia inua, badina be ai senemai Ionadab Rekab ese e haḡanimai, eto, Vine ranuna basio unua, umui bona garamui danu, ela bona hanaihanai;
\v 7 ruma auta basio haginia; basio hadohado; vine imeana ta basio hadoa eiava basio abia emui; a emui mauri dinadia iboudiai kalaga ai ba noho, o noholaiamu tanona ai emui mauri dinadia bae hoho helaoreana.
\v 8 Ai ese senemai Ionadab Rekab gadona vada a badinaia, e haganilaimai karadia iboudiai lalodiai, emai mauri dinadia iboudiai vine ranuna asia inuamu, ai bona adavamai bona natumai mamaruanedia bona hahinedia danu;
\v 9 bona ruma danu asia haginidia, asia noholaidia. Asi emai vine imeadia, asi emai uma, asi emai uhe;
\v 10 a kalaga ai vada a noho, bona senemai Ionadab ese e haganilaimai karadia iboudiai vada a badinadia bona a karadia.
\v 11 A Nebukadresara, Babulono pavapavana, na tano idaena totona ema negana ai, ai ato “Aoma, Ierusalem aitala, Kaldea taudia bona Suria taudia edia tuari oreadia na garidia”. Taunabunai ai na Ierusalem ai a nohomu.
\p 
\v 12 Bena Iehova ena hereva na Ieremia enai e kau, eto,
\v 13 Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Aola, Iuda taudia bona Ierusalem inoholaina taudia ba hamaorodia, baoto, Iehova na e tomu: Hahediba herevadia basio abi dae bona egu hereva basio kamonai a?
\v 14 Haheḡani, Ionadab Rekab ese garana e henidia ḡauna, vine ranuna basie inua, na vada e badinaia; idia na asie inuamu ema bona ina dina, badina be senedia ena haheḡani vada e badinaia. Lau ese vada na hereva henimui havara-havara, a umui ese asio kamonai henigu.
\v 15 Lau ese egu peroveta hesiai taudia iboudiai vada na siaidia vasi, na siaidia havara-havara, nato, Iboumui ai emui dala dikadia amo ba raka siri, bona emui kara ba haḡoevadia, bona dirava idaudia muridia amo basiola, isiaidia basio lao heni; bena umui na henimui bona senemui na henidia tanona ai do ba noho. A taiamui asio hakala bona asio kamonai henigu.
\v 16 Ionadab Rekab garana ese senedia ena haheḡani vada e badinaia, a ina bese ese se kamonai henigu.
\v 17 Taunabunai, Ḡaubada Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: A itaia, hahedika Iuda bona Ierusalem inoholaina taudia iboudiai latadiai vada na gwaurai ḡauna na ediai baina havaraia; badina be vada na hereva henidia to asie kamonai, vada na boi henidia to asie haere.
\p 
\v 18 A Rekab iduhuna taudia na Ieremia ese e hereva henidia, eto, Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Badina be senemui Ionadab ena haheḡani vada o badinaia, bona ena hahediba herevadia iboudiai vada o badinadia, bona e haganilaimui karadia iboudiai vada o kara,
\v 19 una dainai Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Ionadab Rekab iduhuna na nega ta ai lau vairagu ai iginina taudia ta ai basine dabu.
\c 36
\s1 King Iehoiakim ese peroveta pepana e doua
\p 
\v 1 Iehoiakim, Iuda pavapavana Iosia natuna ena lohia laḡanina ihahanina ai, ina hereva Iehova ena amo na Ieremia enai e kau, eto:
\v 2 Pepa ta avabia, Israel bona Iuda bona bese idau-idau iboudiai ihadikadia herevadia, vada na gwaurai henimu ḡaudia, na hereva henimu matama dinana amo, Iosia ena nega ai, ema bona ina dina, vada ba tore.
\v 3 Readia Iuda iduhuna taudia na ihadikadia karadia iboudiai vada na lalo hata baina kara henidia nato herevadia bae kamonai, bena una dainai iboudiai ese edia dala dikadia bae rakatani, bena lau ese edia kara havara bona edia kara dika baina gwau tao.
\p 
\v 4 Bena Ieremia ese Baruku Neria e boiria; bona Iehova ese vada e hamaorolaia herevadia iboudiai na Ieremia ese e gwaurai, bena Baruku ese pepa ta ai e tore.
\v 5 Bena Ieremia ese Baruku e haduaia, eto, Vada e g vaugu tao, Iehova ena dubu ilao-henina ai;
\v 6 una dainai oi hari baola, bena anivaga dinana ta ai Iehova ena hereva, lau ese vada na gwaurai bona oi ese pepa ai vada o tore ḡaudia, na Iehova ena dubu ai e heboumu taudia iboudiai vairadiai ba duahi. Iuda taudia, edia hanua amo vada e raka lasi taudia iboudiai, vairadiai danu ba duahi.
\v 7 Readia edia noinoi na Iehova enai baine kau, bena iboudiai ese edia dala dikadia bae rakatanidia, badina be badu bona lalo-siahu Iehova ese ina bese latanai vada e gwaurai na bada herea.
\v 8 Bena Baruku Neria ese peroveta tauna Ieremia ena hahedua idoinai heḡereḡerena ai e karaia, Iehova ena hereva na pepa amo e duahia, Iehova ena dubu ai.
\p 
\v 9 Iehoiakim, Iuda pavapavana Iosia natuna, ena lohia laḡanina iha-imana huana ihataurahani-tana ai, Ierusalem taudia iboudiai bona Iuda hanuadia amo Ierusalem vada ema taudia iboudiai ese anivaga e gwauraia Iehova vairanai.
\v 10 Bena taunimanima iboudiai vairadiai Baruku ese Ieremia ena hereva na pepa amo e duahia, Iehova ena dubu ai, toretore tauna Gemaria Safana ena daiutu lalonai. Una daiutu na alai maguna ai, Iehova ena dubu ikoukouna, ladana Ikoukou Matamatana, badibadinai.
\p 
\v 11 Mikaia Gemaria Safana natuna, ese Iehova ena hereva iboudiai, pepa amo e duahi ḡaudia, na e kamonai negana ai,
\v 12 ia na pavapava ena ruma e diho lao, toretore tauna ena daiutu ai e raka vareai. Lohia iboudiai unuseni ai e helaiva: toretore tauna Elisama, Semaia natuna Delaia, Akaboro natuna Elnatan, Safana natuna Gemaria, Hanania natuna Sedekia, bona lohia iboudiai.
\v 13 Bena Mikaia ese e kamonai herevadia iboudiai, Baruku ese taunimanima vairadiai pepa amo e duahi herevadia, na e hamaorolaidia.
\v 14 Bena lohia iboudiai ese lehudi (ia na Netania natuna, Netania na Selemia natuna, Selemia na Kusi natuna) e siaia lao, Baruku baine hamaoroa, baineto, Hari taunimanima vairadiai o duahia pepana na imamu ai bavabia, vada baoma. Taunabunai, Baruku Neria ese pepa na imana ai e abia, bena dekedia ela.
\v 15 Idia ese e hamaoroa, eto, A helai diho, ba duahia. Taunabunai, Baruku ese e duahi henidia.
\v 16 Unu hereva iboudiai e kamonai negana ai, idia na mai garidia ida e heroha heheni. Bena idia ese Baruku e hamaoroa, eto, Ini-hereva iboudiai na hanua pavapavana do baia hamaorolaia.
\v 17 Bena idia ese Baruku e nanadaia, eto, A hamaoromai, ini hereva iboudiai ede o tore toma? Ia ese e gwaurai bena o tore a?
\v 18 Bena Baruku ese e haere henidia, eto, Ia ese ini hereva iboudiai e gwaurai henigu, bena lau ese ink amo na tore, pepa ai.
\v 19 Bena hari lohia ese Baruku e hamaoroa, eto, Aola, a komu, oi bona Ieremia danu, bona tau ta basine diba umui na edeseni ai.
\p 
\v 20 Taunabunai, idia ese pepa na toretore tauna Elisama ena daiutu ai e atoa, bena hanua pavapavana ena maḡu lalonai e raka vareai, unu hereva iboudiai na hanua pavapavana e hamaorolaia.
\v 21 Bena hanua pavapavana ese Iehudi na pepa iabina totona e siaia lao; bena ia ese toretore tauna Elisama ena daiutu lalona amo.e abia. Bena Iehudi ese hanua parapavana bona hanua pavapavana badibadinai e giniva lohiadia e duahi henidia.
\v 22 Nega na hua ihataurahani-tana; hanua pavapavana na keru negana rumana ai e helaiva, bona lahi na rahurahu ai vada e ha-araia ia vairanai.
\v 23 Iehudi ese ere toi eiava hani e duahidia, bena hanua pavapavana ese kaia maragina amo e utudia oho, hari rahurahu ai e arava lahina lalonai e tahodia vareai. Unu mo e kara toma ela bona pepa Idoinai na una rahurahu ai e arava lahina ai e ara ore.
\v 24 Ḡau tamona, ini hereva iboudiai e kamonai vaitani murinai, hanua pavapavana eiava ena hesiai taudia ta se gari, eiava edia dabua asie dare.
\v 25 Ena be Elnatan bona Delaia bona Gemaria ese hanua pavapavana e hereva henia goadagoada, pepa na basine doua, to ia ese se kamonai henidia.
\v 26 Bena hanua pavapavana ese Ierahamele, hanua pavapavana natuna, bona Seraia, Asriel natuna, bona Selemia, Abdele natuna, na e haḡanidia, idia ese toretore tauna Baruku bona peroveta tauna leremia bae dabaidia tao. A Iehova ese e hunidia.
\p 
\v 27 Ieremia ese e gwaurai bena Baruku ese e tore herevadia pepana na hanua pavapavana ese e doua murinai, Iehova ena hereva ta Ieremia enai e kau, eto,
\v 28 Ma pepa ta bavabia, hereva gunadia, pepa gini-gunana, Iehoiakim, Iuda pavapavana, ese e doua ḡauna, ai e tore herevadia ma ba tore lou.
\v 29 Bona Iehoiakim, Iuda pavapavana, na ini ba herevalaia toma, baoto, Iehova ini e gwau tomamu: Ina pepa vada o doua, oto “Dahaka dainai ia lalonai vada o torea Babulono pavapavana na momokani bainema, ina tano baine habuaia tari bona taunimanima bona ubu-ubu ḡaudia na ia lalona amo baine negedia daure?”
\v 30 Taunabunai, Iehova ese Iehoiakim, Iuda pavapavana, na ini e herevalaia tomamu: Ia garana ta ese David ena terono ai basine helai kau; bona ia tau-anina masena na murimuri ai bae negea lasi, dina garaḡarana ai bona hanuaboi parakana ai baine mia.
\v 31 Lau ese ia bona natuna bona ena hesiai taudia na davadia baina henidia, edia kara havara daidiai. Idia latadiai, bona Ierusalem inoholaina taudia bona Iuda taudia latadiai, dika idoinai, idia latadiai vada na gwauraia ḡauna, na baina hadihoa; a idia na asie ura bae kamonai.
\p 
\v 32 Bena Ieremia ese pepa ta ma e abia, itorena tauna Baruku Neria e henia; bena Iehoiakim, Iuda pavapavana, ese lahi ai e doua pepana herevadia iboudiai na Ieremia ese ma e gwaurai bona Baruku ese ma e tore; bona hereva unuhetomadia momo na idia latadiai ma e tore kau.
\c 37
\s1 Ieremia na dibura rumana ai e koua
\p 
\v 1 Sedekia Iosia, Nebukadresara, Babulono pavapavana, ese Iuda tanona pavapavana ai e halaoa tauna, na Iuda ai e lohiava, Konia Iehoiakim gabuna ai.
\v 2 A ia bona ena hesiai taudia bona tano taudia ese Iehova ena hereva, peroveta tauna Ieremia uduna amo e gwaurai ḡaudia, na asie kamonaidia.
\p 
\v 3 King Sedekia ese Iehukala Selemia bona hahelaḡa tauna Sefania Maaseia na peroveta tauna Ieremia dekena e siaidia lao, eto, Iehova, eda Dirava, na ai daimai ai ba ḡuria.
\v 4 Una negana ai Ieremia na dounu taunimanima bogaragidiai e raka vareaiva e raka lasiva; badina be dibura rumana ai do asie koua.
\v 5 Farao ena tuari oreana na Aigupto amo vada e raka lasi; bena Kaldea taudia, Ierusalem e daia heḡeḡe oreana, ese haridia e kamonai negana ai, idia na Ierusalem amo e raka oho.
\p 
\v 6 Bena Iehova ena hereva na peroveta tauna Ieremia dekenai e kau, eto,
\v 7 Iehova, Israel Diravana, na ini e gwau tomamu: Iuda pavapavana, dekegu ai e siaimu ba nanadaigu totona tauna, na ini ba hamaoroa toma, baoto, A itaia, Farao ena tuari oreana, oi idurumu totona ema ḡauna, na be lou laomu, edia tano korikori Aigupto ai.
\v 8 Bena Kaldea taudia ma bae lou mai, ina hanua bae tuari henia, bae abia, bena lahi amo bae doua.
\v 9 Iehova na ini e gwau tomamu: Sibomui basio hekoi, basioto “Kaldea taudia na momokani dauhai bae noho”; badina be idia na dauhai basie noho.
\v 10 Badina be, ena be Kaldea taudia, e tuari henimuimu taudia, edia tuari oreana idoinai boma hadarerea, bona mai berodia taudia sibodia bema noho, ta ta ena kalaga ena kalaga ai, to idia na ben a tore isi, bena ina hanua na lahi ai bema doua.
\p 
\v 11 Kaldea taudia edia tuari oreana na Ierusalem amo vada e raka oho, Farao ena tuari oreana e raka kahira negana ai.
\v 12 Bena Ieremia na Ierusalem ai e tore isi, Beniamina tanona bainela, unuseni ai ahuna do baine abia, taunimanima bogaragidiai.
\v 13 Ia na Beniamina Ikoukouna ai, bena hegima tauna ta, ladana Iria, Selemia Hanania natuna, ese peroveta tauna Ieremia e dabaia tao, eto, Oi na Kaldea taudia ediai bo hanaimu.
\v 14 Ieremia eto, Oi na o koikoimu; lau na Kaldea taudia ediai asina hanaimu. A Iria na se ura baine kamonai henia; bena ia ese Ieremia e dabaia tao, hanua lohiadia dekedia e laohaia.
\v 15 Hanua lohiadia ese Ieremia e badu henia lalo-dika; e dadabaia, bena toretore tauna Ionatan ena ruma ai e koua, badina be una ruma na dibura rumana ai vada e halaoa.
\p 
\v 16 Ieremia na dibura rumana ai e koua, bena dina hoho unuseni ai e nohova.
\v 17 Una murinai King Sedekia ese e boiria, bena e abia dae. Hanua pavapavana ese e nanadaia hehuni ena ruma ai, eto, Hereva ta na Iehova ena amo vada ema a?
\v 18 Ieremia eto, Oibe. Ma eto, Babulono pavapavana imana ai bae atomu. Ieremia ese danu King Sedekia e hamaoroa, eto, Oi eiava emu hesiai taudia eiava ina bese taudia na ede vada na hadikamui toma dainai dibura rumana ai vada o kougu?
\v 19 Emu peroveta taudia, e peroveta henimu eto “Babulono pavapavana basinema, oi bona ina tano basine tuari henimui” taudia na edeseni ai?
\v 20 Pavapava e, egu lohia, mani emu kara a kamonai: egu noinoi, mai hematauraigu ida na gwauraiamu ḡauna, na emu ai baine kau; bena toretore tauna Ionatan ena ruma basio siaigu lao lou, unuseni ai baina mase na garina.
\v 21 Taunabunai King Sedekia e hahedua, bena Ieremia na hegima taudia edia magu ai e koua; bena dina ta ta ai flaoa igabu ta ta e henia, flaoa igabuna taudia edia ariara amo, ela bona hanua flaoana idoinai vada e ore. Taunabunai Ieremia na hegima taudia edia maḡu ai e nohova.
\c 38
\s1 Ieremia na ranu gurina amo e hamauria
\p 
\v 1 Ieremia ese taunimanima iboudiai e hamaorolaidia herevadia na Sefatia Matan, Gedalia Pasahuru, Iukala Selemia, bona Pasahuru Malkia na e kamonai. Ia eto,
\v 2 Iehova ini e gwau tomamu: Ina hanua ai baine noho tauna na dare eiava doe eiava dai-hanai gorerena amo baine mase; a Kaldea taudia dekedia baine raka lasi tauna na baine mauri; ena mauri na kwalimu ahuna ai bainela, bena baine mauri.
\v 3 Iehova ini e gwau tomamu: Momokani ina hanua na Babulono pavapavana imana ai bae atoa, bena baine abia.
\p 
\v 4 Bena hanua lohiadia ese hanua pavapavana e hamaoroa, eto, Ina tau bae alaia mase be namo, badina be ia ese tuari taudia doini hanua ai e nohomu na imadia e hamanokadiamu, bona taunimanima iboudiai imadia danu, unu hereva e hamaorolaidiamu dainai. Badina be ina tau ese taunimanima ihanamodia se tahuamu a ihadikadia mo.
\v 5 King Sedekia eto, A itaia, ia na umui imamui ai; badina be hanua pavapavana ese basine laomui ahu diba.
\v 6 Taunabunai, idia ese Ieremia e abia, Malkia, hanua pavapavana natuna, ena ranu gurina, hegima taudia edia magu ai, lalonai e tua dobi. Idia ese Ieremia na kwanau amo e tua dobi. Guri na asi ranuna, kopukopu mo; bena Ieremia na kopukopu ai e hepuni.
\p 
\v 7 Ebede-melek, tau Etiopia, hesiai tauna ta pavapava ena ruma ai, e kamonai idia ese Ieremia na guri lalonai vada e tua dobi. Hanua pavapavana na Beniamina Ikoukouna ai e helaiva,
\v 8 bena Ebede-melek na pavapava ena ruma amo ela, hanua pavapavana e hamaoroa, eto,
\v 9 Pavapava e, egu lohia, ini tatau na vada e kara dika, peroveta tauna Ieremia e kara henia karadia iboudiai lalodiai; idia ese ranu gurina lalonai vada e tua dobi, unuseni ai ia na baine hitolo mase, badina be flaoa taina dia mia hanua ai.
\v 10 Bena hanua pavapavana ese Ebede-melek, tau Etiopia, e hagania, eto, Ini amo tatau tatoi avabidia, oi ida baola, peroveta tauna Ieremia do se masemu ai na guri amo ba veria dae.
\v 11 Taunabunai, Ebede-melek ese unu tatau e abidia, bena pavapava ena ruma ela, habou-habou daiutuna ai maua ta lalona amo dabua seadia gunadia bona hahedoki, vada e dika ḡaudia, e abi; bena kwanau amo guri lalonai e tudia dobi, Ieremia enai.
\v 12 Bena Ebede-melek, tau Etiopia, ese Ieremia e hamaoroa, eto, Dabua seadia bona hahedoki na kadidihamu bona kwanau padadiai bavatodia. Ieremia na unu e kara toma.
\v 13 Bena idia ese Ieremia na kwanau amo e veria dae, guri amo e abia lasi. Bena Ieremia na hegima taudia edia magu ai e nohova.
\p 
\v 14 King Sedekia ese peroveta tauna Ieremia e boiria, Iehova ena dubu iraka-vareaina ihatoina ai e abia dae. Hanua pavapavana ese Ieremia e hamaoroa, eto, Aina nanadaimu, ḡau ta egu ai basio hunia.
\v 15 Ieremia ese Sedekia e haere henia, eto, Bama hamaoromu bena boma alagu mase ani? Bona bama hahealo henimu bena basioma kamonai henigu.
\v 16 Bena King Sedekia ese Ieremia e gwau henia hamata hehuni, eto, Iehova, laumada e karadia Diravana, na e maurimu heḡereḡerena, lau ese basina alamu mase eiava emu mauri iabi-ohona dalana e tahuamu taudia imadia ai basina atomu.
\p 
\v 17 Bena Ieremia ese Sedekia e hamaoroa, eto, Ḡaubada Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Babulono pavapavana ena lohia taudia ediai boma hahemanau, bena idia ese bae hamaurimu; ina hanua danu lahi amo basie doua, bona oi bona emu ruma taudia na ba mauri.
\v 18 A hari Babulono pavapavana ena lohia taudia ediai basioma hahemanau, bena ina hanua na Kaldea taudia imadia ai baine heato; bena idia ese lahi amo bae doua, bona oi na idia imadia amo basio roho mauri.
\v 19 King Sedekia ese Ieremia e hamaoroa, eto, Iuda taudia Kaldea taudia ediai vada e hanai na garidia na garimu, idia imadia ai bae atogu bena idia ese bae hadikagu na garina.
\v 20 Ieremia eto, Idia imadia ai basie atomu. Iehova gadona hari na hamaorolaimumu na ba badinaia, bena ba namo, emu mauri na basie abia oho.
\v 21 A hahemanau basioma ura, Iehova ese ina mata-hanai vada e henigu:
\v 22 A itaia, Iuda pavapavana ena ruma ai doini e nohomu hahinedia na e hakaudia lasimu, Babulono pavapavana ena lohia taudia dekediai; bena hahine na e tomu:
\q1 Turamu, o abidadama henidia taudia, ese vada e koimu,
\q2 bona vada e hadareremu;
\q1 oi aemu na kopukopu ai vada e hepuni dainai,
\q2 idia na emu amo e raka ohomu.
\m 
\v 23 Adavamu bona natumu iboudiai na Kaldea taudia dekedia bae hakaudia lasi; bona oi danu idia imadia amo basio roho mauri, a Babulono pavapavana ese baine dabaimu tao; bena ina hanua na lahi amo bae doua.
\p 
\v 24 Bena Sedekia ese Ieremia e hamaoroa, eto, Ini hereva na tau ta basio hadibalaia, bena basio mase.
\v 25 Hanua lohiadia bema kamonai lau na oi ida vada ta hereva-hereva, bena bae vasi, bae nanadaimu, baeto “A hamaoromai, hanua pavapavana ede o hamaoroa toma bona hanua pavapavana ese ede e hamaoromu toma; ḡau ta emai ai basio hunia, bena basia alamu mase”.
\v 26 Bena oi ese ba haere henidia, baoto “Hanua pavapavana na noia mai manaugu ida, ia ese Ionatan ena ruma basine siaigu lao lou, unuseni ai baina mase na garina”.
\v 27 Bena hanua lohiadia iboudiai na Ieremia dekena ela, e nanadaia; bena ia ese e haere henidia, hanua pavapavana ese vada e hagania heḡereḡerena. Taunabunai, idia ese ia ihereva-henina e hadokoa; badina be tau ta ese unu hereva asie kamonai.
\v 28 Bena Ieremia na hegima taudia edia maḡu ai e nohova, ela-bona Ierusalem e abia dinana.
\c 39
\s1 Iereusalem e daea
\p 
\v 1 Sedekia, Iuda pavapavana, ena lohia laḡanina ihataurahani-tana huana ihagvautana lalonai, Nebukadresara, Babulono pavapavana, bona ena tuari oreana idoinai ese Ierusalem e daea bona e koua heḡeḡe;
\v 2 bena Sedekia ena lohia laḡanina ihagwauta-tana huana ihahanina dinana ihataurahani-tana ai, hanua maguna e gwadaia uru.
\v 3 Ierusalem e abla negana ai, Babulono pavapavana ena lohia taudia iboudiai ema, bogaragi ikoukouna ai e helai: Neregala-saresere, Samagara-nebo, Sarasekimi (ena dagi be Rabsarisi), Neregalasaresere (ena dagi be Rabmaga), bona Babulono pavapavana ena tuari lohiadia oredia iboudiai.
\v 4 Sedekia, Iuda pavapavana, bona tuari taudia iboudiai ese e itadia negana ai, idia na e heau; hanuaboi ai hanua e rakatania pavapava ena uma-uma bogaragina amo, bena magu ruaosi padadia ikoukouna amo e raka lasi, Araba dalana ai ela.
\v 5 A Kaldea tuari oreana ese e hahavadia; bena idia ese Sedekia e lasia tao Ieriko taoradia ai. E abia mauri, bena Nebukadresara, Babulono pavapavana, dekena e laohaia, Ribla ai, Hamat tanona ai; bena ia ese ena kerere ahuna e gwauraia.
\v 6 Bena Babulono pavapavana ese Sedekia natuna mamaruanedia na ia vairanai e aladia mase, Ribla ai; Babulono pavapavana ese danu Iuda lohiadia iboudiai e aladia mase.
\v 7 Bena ia ese Sedekia matana e hakepuludia, bona auri gadeadia ai e ḡuia, Babulono baine laohaia totona.
\v 8 Kaldea taudia ese pavapava ena ruma e doua, bona taunimanima edia ruma danu e dou, bona Ierusalem maguna e ḡiḡia dobi.
\v 9 Bena Nebusaradana, hegima oleana biaguna, ese taunimanima oredia dounu hanua ai nonoho na e laohaidia, Babulono ai e hanohodia, ienai e hanai taudia bona taunimanima oredia danu.
\v 10 Nebusaradana, hegima oreana biaguna, ese ogoḡami taudia haida, asi edia kohu taudia, na Iuda tanona ai e rakatanidia, bona una negana ai vine imeadia bona biru tanodia e henidia.
\s1 Nebukadresara ese Ieremia e bogaia hisi
\p 
\v 11 Nebukadresara, Babulono pavapavana, na Nebusaradana, hegima oreana biaguna, ena amo e haheḡani, Ieremia dainai, eto,
\v 12 Avabia, ba naria namonamo, basio hadikaia, a ia ese baine hamaorolaimui heḡereḡerena ai ba kara henia.
\v 13 Taunabunai, Nebusaradana, hegima oreana biaguna, bona Nebusasabana, Rabsarisi tauna, bona Neregala-saresere, Rabmaga tauna, bona Babulono pavapavana ena tuari lohiadia badadia iboudiai na
\v 14 e hesiai, Ieremia na hegima taudia edia magu amo e abia. Idia ese Gedalia, Ahikama Safana natuna, imana ai e atoa, iena ruma baine laohaia totona. Taunabunai ia na taunimanima bogaragidiai e nohova.
\s1 Iehova ese Ebede-melek e hanamoa
\p 
\v 15 Ieremia na hegima taudia edia magu ai e hekouva negana ai, Iehova ena hereva na ienai e kau, eto,
\v 16 Aola, Ebede-melek, tau Etiopia, ba hamaoroa, baoto, Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: A itaia, egu hereva baina hamomokanidia, ina hanua ihadikana ai, baina hadikaia, basina hanamoa. Una dina ai egu hereva anidia do bae vara oi vairamu ai.
\v 17 A Iehova na e tomu: Una dina ai lau ese baina hamaurimu, o gari henidiamu taudia imadia ai basio heato.
\v 18 Badina be momokani lau ese baina hamaurimu, dare ai basio mase; a emu mauri bavabia, kwalimu ahuna ai bainela, badina be lau vada o abidadama henigu. Iehova na e herevamu.
\c 40
\s1 Ieremia bona Gedalia
\p 
\v 1 Nebusaradana, hegima oreana biaguna, ese Ieremia na auri gadeadia ai e ḡuia, Ierusalem ai bona Iuda ai e abidia mauri Babulono baine laohaidia totona taudia ida; bena Rama ai ma e ruhaia nege. Una murinai, ina hereva Iehova ena amo na Ieremia enai e kau.
\v 2 Hari hegima oreana biaguna ese Ieremia e abia, e hereva henia, eto, Iehova, emu Dirava, ese ina dika vada e gwauraia ina gabu latanai;
\v 3 Iehova ese anina vada e havaraia, ena hereva heḡereḡerena ai vada e karaia. Badina be umui na vada o kerere Iehova enai, bona ia gadona asio kamonai, una dainai ina kara na latamui ai vada e kau.
\v 4 A harihari, auri gadeadia na imamu amo na kokidia ohomu, na ruhamu nege, ina dina ai. Boma laloa lau ida Babulono baitala be namo, baitama lao, bena lau ese bama narimu namonamo. A boma laloa lau ida Babulono baitala na dia namo, basitama lao. A itaia, tano idoinai na vairamu ai; edena gabu ilao-henina o haeroamu namo bona maoro na unu baola.
\v 5 Bema ba-noho, Gedalia, Ahikama Safana natuna, Babulono pavapavana ese vada e duanaia Iuda hanuadia ikwaradia tauna ai bainela tauna, dekena ba lou lao, bena ia ida ba noho, taunimanima bogaragidiai; eiava, edena gabu ilao-henina o haeroamu namo na unu baola. Taunabunai, hegima oreana biaguna ese dala lakwana e henia, bona harihari ḡauna ta danu, bena e kahua nege.
\v 6 Bena Ieremia na Gedalia Ahikama dekena ela, Mispa ai, bena ia ida e nohova, una tano ai dounu nohodia taudia bogaragidiai.
\p 
\v 7 Tano paka ai e nohova oreadia biagudia iboudiai bona edia orea taudia na e kamonai, Babulono pavapavana ese Gedalia Ahikama na tano ikwarana tauna ai vada e halaoa, bona tatau bona hahine mai natudia ida, una tano ogogami-herea taudia Babulono asie laohaidia, na iena hereḡu ai vada e atodia.
\v 8 Bena idia na Gedalia dekena ela, Mispa ai: Ismael Netania; Iohanan Karea; Seraia Tanahumete; Efai tau Netofa natuna mamaruanedia, bona Iesania, tau Maakata natuna maruanena; idia bona edia orea taudia danu.
\v 9 Bena Gedalia, Ahikama Safana natuna, ese idia bona edia orea taudia na e gwau henidia hamata, eto, Kaldea taudia isiaidia ilao-henina basio garilaia. Tano ai ba noho, Babulono pavapavana isiaina ba lao heni, bena vada ba namo.
\v 10 Lau na Mispa ai baina noho, bena umui daimui ai Kaldea amo dekedai baema taudia vairadiai baina gini. A umui ese vine ranuna bona au-huahua bona dehoro ba habou, emui tohe ai ba baladia heni; bona vada o abi hanuadia ai ba noho.
\v 11 Una heḡereḡerena ai, Iuda taudia iboudiai Moab ai bona Amono taudia bogaragidiai bona Edom ai bona tano haida ai e nohova na e kamonai, Babulono pavapavana ese kwabukwabudia vada e rakatanidia Iuda ai, bona Gedalia, Ahikama Safana natuna, vada e duanaia, idia ikwaradia tauna ai bainela;
\v 12 bena Iuda taudia iboudiai na vada e luludia lao gabudia iboudiai amo ma e lou mai, Iuda tanona ema, Gedalia dekenai, Mispa ai. Bena idia ese vine ranuna bona au-huahua momo herea e habou.
\s1 Ismael ese Gedalia iala-masena dalana e tahua
\p 
\v 13 Una negana ai lohanan Karea bona tano paka ai e nohova oreadia biagudia na Gedalia dekena ela, Mispa ai,
\v 14 e hereva henia, eto, Oi mai dibamu Baalisi, Amono pavapavana, ese Ismael Netania vada e siaia mai oi iala-masemu totona a? A Gedalia Ahikama ese edia hereva se abia dae.
\v 15 Bena Iohanan Karea ese Gedalia e hereva henia hehuni Mispa ai, eto, Mani ainala, Ismael Netania baina alaia mase, bena tau ta basine diba. Anina be dahaka ia ese oi baine alamu mase, bena Iuda taudia oi dekemu ai vada e hebou na bae heau karoho, bena Iuda kwabukwabudia bae mase ore?
\v 16 A Gedalia Ahikama ese Iohanan Karea e haere henia, eto, Una na basio karaia, badina be Ismael o herevalaia koikoimu.
\c 41
\p 
\v 1 Hua ihahituna ai, Ismael, Netania Elisama natuna, pavapava iduhuna tauna bona hanua pavapavana ena heitatao tauna badana ta, na tatau gwauta ida Gedalia Ahikama dekena ema, Mispa ai. Bena Mispa ai e aniani hebouva lalonai,
\v 2 Ismael Netania bona hari tatau gwauta ia ida na e tore isi; bena idia ese Gedalia, Ahikama Safana natuna, Babulono pavapavana ese tano ikwarana tauna ai e halaoa tauna, na dare amo e tutua gwada, e alaia mase.
\v 3 Ismael ese Iuda taudia iboudiai Gedalia ida Mispa ai e nohova danu e aladia mase, bona Kaldea tuari taudia hahidaosi unuseni ai danu.
\p 
\v 4 Gedalia iroromana dinana murina dinana ai, tau ta ese sivaraina do se kamonai negana ai,
\v 5 tatau taurahani-ahui na Sekem bona Silo bona Samaria amo ema. Auki-huidia vada e abi, edia dabua vada e dare, bona kopidia vada e gasidia. Idia ese flaoa boubou ḡaudia bona muramura mai bonadia e mailaidia, Iehova ena dubu ai bae herahialai totona.
\v 6 Bena Ismael Netania na Mispa amo e raka lasi mai taina ida, idia ihedavari-henidia totona. Idia ida e hedavari negana ai, ia ese e hamaorodia, eto, Gedalia Ahikama dekenai ba raka vareai.
\v 7 Bena hanua lalonai e raka vareai negana ai, Ismael Netania mai bamona ida ese e aladia mase, bena ranu habou gurina ta ai e tahodia dobi.
\v 8 A tatau gwauta idia bogaragidia amo-ese Ismaele hamaoroa, eto, Basio alamai mase, badina be ai na mai emai uit bona bali bona dehoro bona bada-ranuna, uma ai a huni. Taunabunai, ia ese kara e hadokoa, idia mai bamodia ida se aladia mase.
\p 
\v 9 Hari ranu habou gurina, Ismael ese e aladia mase taudia tau-anidia na lalonai vada e tahodia dobi gurina, na guri badana, King Asa ese Baasa, Israel pavapavana, ena kwalimu ilao-ahuna totona e ḡeia ḡauna. Ismael Netania ese mase taudia tau-anidia amo e hahonua.
\v 10 Bena Ismael ese taunimanima oredia Mispa ai na e abidia mauri, hanua pavapavana natuna hahinedia bona Mispa ai e nohova taudia kwabukwabudia iboudiai, Nebusaradana, hegima oreana biaguna, ese Gedalia Ahikama ena heregu ai e atodia taudia iboudiai. Ismael Netania ese e abidia mauri, bena e tore isi, Amono taudia dekediai bae hanai eto.
\p 
\v 11 A Iohanan Karea bona orea biagudia iboudiai ia ida ese Ismael Netania ena kara dikadia iboudiai sivaraidia e kamorlai negana ai,
\v 12 idia ese edia orea taudia iboudiai e abidia, Ismael Netania ituari-henina ela; bena gohu badana Gibeon ai badibadinai e lasia tao.
\v 13 Bena Ismael ida ela taudia iboudiai ese Iohanan Karea bona orea biagudia iboudiai ia ida, e itadia negana ai na e moale.
\v 14 Taunabunai, Ismael ese e abidia mauri Mispa amo e laohaidia taudia iboudiai na e raka lou, Iohanan Karea dekena e lou lao.
\v 15 A Ismael Netania na Iohanan ena amo e roho mauri, tatau taurahani ida, bena Amono taudia dekedia ela.
\p 
\v 16 Bena Ismael Netania ese Gedalia Ahikama e alaia mase murinai Mispa amo abi-mauridia ai e laohaidia taudia oredia iboudiai na Iohanan Karea bona orea biagudia iboudiai ia ida ese e abidia: tuari taudia, hahine, memero kekeni, bona hesiai taudia, lohanan ese Gibeon amo e hakaudia lou taudia.
\v 17 Idia na ela, Gerutu Kimuhamu ai e noho, Betelehem kahana ai. Edia lalo-hadai be Aigupto baela eto,
\v 18 Kaldea taudia daidiai; badina be e gari henidia, badina be Gedalia Ahikama, Babulono pavapavana ese tano ikwarana tauna ai e halaoa tauna, na Ismael Netania ese vada e alaia mase.
\c 42
\s1 Ieremia ena gwaukau Iohanan enai
\p 
\v 1 Tuari oreadia biagudia bona Iohanan Karea bona Asaria Hosaia, bona taunimanima iboudiai, asi dagidia bona mai dagi-badadia taudia, na e raka kahira,
\v 2 peroveta tauna Ieremia e hereva henia, eto, Emai noinoi bavabia dae; bona Iehova, emu Dirava, ba noia, ini kwabukwabumai daimai ai, badina be ai na orea badana taumai to, o itamaimu, gadoimai mo e rakatanimai.
\v 3 Iehova, emu Dirava, ese baia rakalaia dalana bona baia karaia karana na baine hadibalaimai.
\p 
\v 4 Peroveta tauna Ieremia ese e haere henidia, eto, Emui hereva vada na kamonai; a itaia, lau ese Iehova, emui Dirava, baina ḡuria, emui noinoi heḡereḡerena, bena Iehova na ede baine haere toma, una na baina hamaorolaimui; ḡau ta emui ai basina hunia.
\v 5 Bena idia ese Ieremia e hamaoroa, eto, Bema Iehova, emu Dirava, ese ai daimai ai baine henimu herevana idoinai heḡereḡerena ai basia karaia, Iehova ese baine habadelaimai mai maoromaorona bona mai momokanina ida.
\v 6 Bema hereva namona eiava hereva dikana, to ai ese Iehova, eda Dirava, dekena a siaimumu Diravana, gadona baia badinaia, Iehova, eda Dirava, gadona ibadinana ai baia namo helaoreana.
\p 
\v 7 Dina gwauta e ore ai Iehova ena hereva na Ieremia enai e kau.
\v 8 Bena ia ese Iohanan Karea bona tuari oreadia biagudia iboudiai, ia ida e nohova taudia, bona taunimanima iboudiai, asi dagidia bona mai dagibadadia taudia, na e boiridia, e hereva henidia,
\v 9 eto, Iehova, Israel Diravana, dekena o siaigu, daimui ai baina noia totona, Diravana, na ini e gwau tomamu:
\v 10 Ina tano ai boma noho, bena lau ese baina haginimui, basina gigimui dobi; baina hadomui, basina ragamui oho; badina be na hadikalaimui karana na helalo kerehailaiamu.
\v 11 Babulono pavapavana, o gari heniamu tauna, na garina basio gari. Iehova na e tomu, Basio gari henia, badina be lau na umui ida, baina hamaurimui bona ia imana amo baina harohomui mauri totona.
\v 12 Lau ese baina bogamui hisi; unu amo ia ese danu baine bogamui hisi, bona emui tano korikori ai baine hanohomui.
\v 13 A boma toma “Ina tano ai basia noho”; Iehova, emui Dirava, boma gwau edeede henia,
\v 14 boma toma “Lasi, Aigupto tanona baiala, unuseni ai tuari basia itaia, bona kibi reḡena basia kamonai, bona basia hitolo, bena unuseni ai baia noho”;
\v 15 Iuda kwabukwabumui e, Iehova ena hereva ba kamonai. Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Lalomui boma ha-auka Aigupto ai boma raka vareai bona unuseni ai boma noho,
\v 16 bena o garilaiamu darena ese unuseni ai, Aigupto tanona ai, baina lasimui tao, bona o garilaiamu doena ese baine gavamui havara-havara ela bona Aigupto; bena unuseni ai ba mase.
\v 17 Lalodia bae ha-auka Aigupto baela unuseni ai bae noho taudia iboudiai na dare eiava doe eiava dai-hanai gorerena amo bae mase; asi kwabukwabuna, asi tauna ta, na lau ese latadiai baina hadihoa dikana amo baine roho mauri.
\p 
\v 18 Badina be Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Egu badu bona egu badu-garagara na Ierusalem inoholaina taudia latadiai na bubu dobi heḡereḡerena ai, egu badu-garaḡara na umui latamui ai danu baina bubua dobi, Aigupto baola negana ai. Heihi-ihirai, hahegari, heuduguirai, hegonaḡonalai ḡaudia ai baola. Ina gabu na ma basio itaia lou.
\v 19 Iehova ese vada e hamaoromui, eto, Iuda kwabukwabumui e, Aigupto basiola. Ba diba momokani, hari ina dina ai vada na sisiba henimui,
\v 20 vada o raka siri davana na emui mauri. Badina be o siaigu, Iehova, emui Dirava, dekenai, oto “Iehova, eda Dirava, ba fiuria ai daimai ai, bena Iehova, eda Dirava, ede baine gwau toma na ba hamaoromai, bena baia karaia”.
\v 21 Bena hari dina ai vada na gwaurai henimui, to e siaigu baina hamaorolaimui ḡauna ta ai Iehova, emui Dirava, gadona asio badinaia.
\v 22 Taunabunai, ba diba momokani, ilao-henina bona inoholaina o uramu gabuna ai dare eiava doe eiava dai-hanai gorerena amo vada ba mase.
\c 43
\s1 Kwabukwabudia na Aigupto ela
\p 
\v 1 Ieremia ese taunimanima iboudiai e hereva henidia vaitani, unu Iehova, edia Dirava, ena hereva iboudiai, Iehova, edia Dirava, ese vada e siailaia herevadia, e gwaurai ore murinai,
\v 2 Asaria Hosaia bona lohanan Karea bona asi edia hemataurai taudia iboudiai ese Ieremia na e hamaoroa, eto, Oi na o koikoimu. Iehova, eda Dirava, ese se siaimu, seto “Aigupto basiola, unuseni ai basio noho”,
\v 3 a Baruku Neria ese lalomu vada e hadikaia ai emai ai, Kaldea taudia imadia ai bavatomai totona, bena bae alamai mase, eiava Babulono bae laohaimai, unuseni ai bae hanohomai.
\v 4 Taunabunai, Iohanan Karea bona tuari oreadia biagudia iboudiai bona taunimanima iboudiai ese Iehova ena hereva, Iuda tanona inoholaina herevana, na asie badinaia.
\v 5 A Iohanan Karea bona tuari oreadia biagudia iboudiai ese Iuda taudia kwabukwabudia iboudiai, bese idau-idau iboudiai bogaragidiai e luludia lao bena ma e lou, Iuda tanona ai ma e nohova, taudia, na e abidia:
\v 6 tatau, hahine, memero, kekeni, hanua pavapavana natuna hahinedia, bona Nebusaradana, hegima oreana biaguna, ese Gedalia, Ahikama Safana natuna, dekenai e rakatanidia taudia iboudiai; bona peroveta tauna Ieremia bona Baruku Neria danu.
\v 7 Bena Aigupto tanona ai e kau; badina be Iehova gadona asie badinaia. Bena Tapanese ai e kau.
\p 
\v 8 Bena Iehova ena hereva na Ieremia enai e kau, Tapanese ai, eto:
\v 9 Nadi badadia haida imamu ai bavabi, Iuda taudia vairadiai raro-kaka ai ba hunidia, Farao ena ruma raka-vareaina ariarana ai, Tapanese ai.
\v 10 Bena ba hamaorodia, baoto, Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: A itaia, lau na baina hesiai, Nebukadresara, Babulono pavapavana, egu hesiai tauna, baina abia; bena ia ese ena terono baine atoa, ini vada na hunidia nadidia latadiai, bona pavapava hahekerukeruna na idia daediai baine haginia.
\v 11 Ia na bainema, Aigupto tanona baine havahuraia, dai-hanai gorerena enai vada e revadia taudia na dai-hanai gorerena amo baine hamasedia, bona abi-mauri enai vada e revadia taudia na abi-mauri ai baine siaidia lao, bona dare enai vada e revadia taudia na dare amo baine aladia mase.
\v 12 Ia ese lahi ta baine ha-araia, Aigupto diravadia edia dubu ai; baine doudia bona abi-mauri ai baine laohaidia. Ia ese Aigupto tanona baine haḡoevaia, mamoe ireḡudia tauna ese ena dabua mai darurana e hagoevaiamu na heto. Bena unu amo ma baine raka oho mai mainona ida.
\v 13 Heliopolisi, Aigupto tanona hanuana ta, ena nadi-gini pupudia na baine hamakohidia; bona Aigupto diravadia edia dubu na lahi amo baine doudia.
\c 44
\s1 Ieremia ese Iuda taudia na
\s1 Aigupto ai e peroveta henidia
\p 
\v 1 Ieremia enai e kau herevadia, Iuda taudia iboudiai Aigupto tanona ai e nohova herevadia, bini. Idia na Migdol ai bona Tapanese ai bona Memefisi ai bona Pataro tanona ai e nohova.
\v 2 Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Dika idoinai Ierusalem latanai bona Iuda hanuadia iboudiai latadiai vada na hadihoa na vada o itaia. A itaia, ina nega ai idia na vada e vahu, asi tauna ta idia lalodiai e nohomu,
\v 3 edia kara dikadia daidiai. Unu kara amo idia ese e habadugu; badina be idia na ela, muramura mai bonadia e gabu, bona dirava idaudia, idia asi dibadia, umui asi dibamui, bona senemui asi dibadia diravadia, isiaidia e lao heni.
\v 4 Ḡau tamona, egu peroveta hesiai taudia na siaidia havara-havara dekemui ai, nato, Mani ina kara dika-rohorohona, na inai heniamu ḡauna, na basio karaia.
\v 5 A idia na asie kamonai, taiadia asie kirara, edia kara dika asie rakatania, bona muramura mai bonadia igabudia dirava idaudia ediai na asie hadokoa.
\v 6 Taunabunai egu badu-garagara bona egu badu na bubudia dobi, Iuda hanuadia ai bona Ierusalem ariaradia ai e ara; bena vada e ḡaḡae bona vada e vahu, ina dina ai heḡereḡerena.
\v 7 Harihari Ḡaubada Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Dahaka dainai ina dika badana o karaiamu, umui sibomui ihadikamui, bena tau bona hahine, mero karukaruna bona meromero, na emui amo eme henege daure, Iuda bogaragina amo, bona kwabukwabumui ta basine noho.
\v 8 Badina be dahaka imamui ḡaukaradia amo o habadugumu? Dahaka dainai muramura mai bonadia o gabudiamu dirava idaudia edia, ina Aigupto tanona, vada o mai henia bona o noholaiamu tanona, lalonai; bena unu amo vada ba henege daure, heuduguirai bona hegonagonalai ḡauna ai ba hahelao, tanobada besedia iboudiai bogaragidiai.
\v 9 Senemui edia kara dika, Iuda pavapavadia mai adavadia ida edia kara dika, bona umui mai adavamui ida emui kara dika, Iuda tanona ai bona Ierusalem ariaradia ai e karava ḡaudia, vada o lalodia boio a?
\v 10 Ema bona ina dina idia na asie hahemanau, bona asie gari, bona egu taravatu bona egu hiahedua herevadia, umui bona senemui vairamui ai na ato ḡaudia, lalodiai asie raka.
\p 
\v 11 Taunabunai, Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: A itaia, vairagu baina ha-aukaia emui ai, ihadikamui totona; Iuda idoinai baina negea daure.
\v 12 Iuda taudia kwabukwabudia, vairadia vada e ha-aukadia Aigupto tanona baema bona bae noholaia taudia, na baina abidia, iboudiai baina ha-oredia; Aigupto tanona ai bae hekida diho, dare bona doe amo bae mase ore; asi dagidia bona mai dagibadadia taudia na dare bona doe ese bae hamasedia; idia na heihi ihirai bona hahegari bona heuduguirai bona heḡonaḡonalai ḡaudia ai baela.
\v 13 Aigupto tanona ai e nohomu taudia na edia dika davana baina henidia, Ierusalem davana na henia heḡereḡerena, dare bona doe bona dai-hanai gorerena amo;
\v 14 taunabunai, Iuda taudia kwabukwabudia Aigupto tanona inoholaina totona; ema taudia, na ta basine heau mauri eiava basine roho mauri eiava Iuda tanona, harihari e uramu bae lou henia, na basine lou lao; badina be basie lou lao, a heau mauri taudia ta ta mo.
\p 
\v 15 Bena dibadia adavadia ese muramura mai bonadia na duava idaudia ediai vada e gabu taudia iboudiai, bona badibadidiai e giniva hahinedia iboudiai, hebou bada-hereana, Pataro ai, Aigupto tanona ai, e nohova taudia iboudiai, ese Ieremia e haere henia, eto,
\v 16 Hereva ta vada o hamaorolaimai Iehova ladana ai, to ai na basia kamonai henimu.
\v 17 A vada a gwaurai hamata karadia iboudiai baia kara, muramura mai bonana baia gabua guba pavapavana hahinena ena, bona inuinu bouboudia baia bubu nege ia ena, a karaia guna heḡereḡerena, ai bona senemai, bona emai pavapava bona emai lohia, Iuda hanuadia ai bona Ierusalem ariaradia ai. Badina be una negana ai, amai aniani na momo, bona namomai na e bada e laova, dika ta asia itaia.
\v 18 A guba pavapavana hahinena ena muramura mai bonana igabuna bona ena inuinu bouboudia ibubudia a hadokoa murinai, ai na ḡau iboudiai vada e dabu bona dare bona doe ese vada e haoremai.
\v 19 Hahine ma eto, Ai na muramura mai bonana a gabua, guba pavapavana hahinena ena, bona inuinu bouboudia a bubu nege ia ena, negana ai, adavamai asie gwau maoro bena ai ese ena ataga a kara latadiai na mai ia laulauna bona inuinu bouboudia a bubu nege ia ena danu a?
\p 
\v 20 Bena Ieremia ese taunimanima iboudiai, tatau bona hahine, unu e haere henia toma taudia iboudiai, na e hereva henidia, eto,
\v 21 Hari muramura mai bonadia, Iuda hanuadia ai bona Ierusalem ariaradia ai o gabu ḡaudia, umui bona senemui, emui pavapava bona emui lohia, bona tano taudia, Iehova ese se laloa tao a? Ia ese se helalolaia une a?
\v 22 Iehova ena haheauka emui kara havara bona emui kara dika-rohorohodia ediai vada e ore; taunabunai emui tano na vada e ḡagae bona vada e vahu, heuduguirai ḡauna ai vada ela, asi inoholaina tauna ta, ina dina ai e miamu heḡereḡerena.
\v 23 Muramura mai bonadia o gabu dainai, bona Iehova o kara dika henia bona Iehova gadona asio badinaia bona ena taravatu bona ena hahedua herevadia bona ena haheḡani lalodiai asio raka dainai, ina dika na latamui ai vada e kau, ina dina ai heḡereḡerena.
\p 
\v 24 Ieremia ese taunimanima iboudiai bona hahine iboudiai e hamaorodia, eto, Iuda taumui Aigupto tanona ai o nohomu iboumui ai, Iehova ena hereva ba kamonai.
\v 25 Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: Umui bona adavamui ese udumui amo vada o gwauraia bona imamui amo vada o karadia, oto “Ai na momokani emai gwauhamata karadia baia kara, guba pavapavana hahinena ena muramura mai bonaula baia gabua bona inuinu bouboudia baia bubu nege”. Benaini, emui gwauhamata ba hamomokanidia bona karadia ba kara.
\v 26 Taunabunai, umui Iuda taumui Aigupto ai o nohomu iboumui ai, Iehova ena hereva ba kamonai. Iehova na e tomu: A itaia, lau ladagu herea-daena bagunai vada na gwau hamata auka, Aigupto tanona idoinai Iuda tauna ta ese uduna amo lau ladagu basine hahanea, basineto “Ḡaubada Iehova e maurimu heḡereḡerena”.
\v 27 A itaia, lau ese na itadia taomu, dika ihavarana dainai, dia namo ihavarana dainai. Iuda taudia iboudiai Aigupto tanona ai na dare bona doe ese bae ha-oredia, ela bona bae ore vaitani.
\v 28 Bena dare amo bae roho mauri taudia na Aigupto tanona amo bae lou lao, Iuda tanona baela, a gadoidia mo; bona Iuda taudia kwabukwabudia iboudiai, Aigupto tanona ema bena e noholaia taudia iboudiai, na bae diba daika ena hereva baine gini, lauegu eiava idia edia.
\v 29 Iehova na e tomu: Toana binai emui ai, emui dika davana baina henimui ina gabu ai, bena ba diba lauegu hereva na bae gini, umui ihadikamui totona.
\v 30 Iehova ini e gwau tomamu: A itaia, lau ese Farao Hofra, Aigupto pavapavana, na inaina imadia ai bona ena mauri iabi-ohona dalana e tahuamu taudia imadia ai baina atoa, Sedekia, Iuda pavapavana, na Nebukadresara, Babulono pavapavana, ana inai tauna bona ena mauri iabi-ohona dalana e tahuava tauna, imana ai na atoa heḡereḡerena.
\c 45
\s1 Ieremia ena gwaukau Baruku enai
\p 
\v 1 Iehoiakim, Iuda pavapavana Iosia natuna, ena lohia laḡanina ihahanina lalonai, Ieremia ese ini hereva e gwaurai, bena Baruku Neria ese buka ta ai e toredia. Una negana ai peroveta tauna Ieremia ese Baruku Neria ini e hereva henia toma, eto,
\v 2 Baruku e, Iehova, Israel Diravana, ese ini e hereva henimu tomamu:
\v 3 Oi oto “Madi ihabaigu, badina be Iehova ese egu hisihisi latanai lalo-hisihisi ma vada e atoa kau; vada na ḡanaḡana ema bona name hesiku, bona laḡa-ani taina asiname davaria”.
\v 4 Ini ba hereva henia toma, baoto, Iehova ini e gwau tomamu: A itaia, vada na haginia ḡauna na ḡiḡia dobimu, bona vada na hadoa ḡauna na ragaia ohomu: ḡauna be tano idoinai.
\v 5 A oi ese ḡau hereadia o tahudiamu sibomu emu a? Iehova na e tomu: Basio tahudia; badina be lau ese dika na havaraiamu, taunimanima iboudiai latadiai; a emu mauri baina herumu, kwalimu ahuna ai bainela, ba lao heni gabudia iboudiai lalodiai.
\c 46
\s1 Peroveta herevadia Aigupto latanai
\p 
\v 1 Iehova ena hereva na peroveta tauna Ieremia enai e kau, bese idauidau daidiai.
\p 
\v 2 Aigupto herevana, Farao Neko, Aigupto pavapavana, ena tuari oreana dainai; Karakemisi ai e taruhava, Eufrate sulavaina isena ai, bena Nebukadresara, Babulono pavapavana, ese e hadarerea, Iehoiakim, Iuda pavapavana Iosia natuna, ena lohia laḡanina ihahanina lalonai.
\q1 
\v 3 Keme aurina bona kesi avabi hata,
\q2 tuari baola!
\q1 
\v 4 Hosi kohudia a kwatu;
\q2 hosi-gui taumui e, a gui!
\q1 Ta ta ena gabu ena gabu ai ba gini,
\q2 mai emui auri kwara ḡaudia ida;
\q1 emui io ba hakimore-kimoredia,
\q2 emui auri hahedokidia ba hedokilai!
\q1 
\v 5 Iehova na e tomu,
\q2 Dahaka dainai vada na itaia?
\q1 Kudoudia vada e hetaha,
\q2 vada e raka lou.
\q1 Edia tuari taudia vada e darere,
\q2 vada e heau haraga-haraga;
\q1 asie roha murimu,
\q2 gari na gabu iboudiai.\f + \fr 46:5 \ft Apisi na Aigupto taudia edia dirava ta, ita-itana na boromakau maruanena na heto.\f*
\q1 
\v 6 Heau haraḡa taudia na asi heau mauri dibadia,
\q2 tuari tauna na asi roho mauri dibana;
\q1 mirigini kahana ai, Eufrate sinavaina badibadinai,
\q2 vada e hetutuhi, vada e hekida diho.
\b
\q1 
\v 7 Ina be daika, Nilo sinavaina na heto e daemu,
\q2 abatadia e lasimu sinavaidia na heheto?
\q1 
\v 8 Aigupto na e daemu, Nilo sinavaina na heto,
\q2 abatadia e lasimu sinavaidia na heheto.
\q1 Ia eto, Aina tore isi, tanobada baina habubunia,
\q2 hanua badadia baina habuadia tari,
\q2 mai inoholaidia taudia ida.
\q1 
\v 9 Hosi e, a heau vaira!
\q2 Kariota e, a heau lalo-dika!
\q1 Tuari taudia na bae raka lasi,
\q2 Etiopia bona Put taudia, mai kesidia,
\q2 Lud taudia, peva ai mai diudia.
\q1 
\v 10 Una dina na Ḡaubada Iehova Sabaota ena dina,
\q2 dika davana ihenina dinana,
\q2 inaina davadia baine henidia totona.
\q1 Dare ese baine anidia, bogana baine kunu,
\q2 raradia baine inu lalo-dika.
\q1 Badina be Ḡaubada Iehova Sabaota ese boubou karana e karaiamu,
\q2 mirigini kahana tanona ai, Eufrate sinavaina badibadinai.
\q1 
\v 11 Aigupto hane-ulato rami-hebouna e!
\q2 Gilead baola, dahudahu muramurana bavabia.
\q1 Muramura momo o gaukaralaidia kava,
\q2 a asi ihanamomu dalana ta.
\q1 
\v 12 Bese idau-idau ese emu hemarai sivaraina vada e kamonai,
\q2 tanobada na emu tai ai vada eme honu.
\q1 Badina be tuari tauna ta na tuari tauna ma ta ida e hetata heheni,
\q2 bena raruosi e keto bou.
\p 
\v 13 Iehova ese peroveta tauna Ieremia e hereva henia, Nebukadresara, Babulono pavapavana, ese Aigupto tanona ituari-henina bainema herevana, eto:
\q1 
\v 14 Aigupto ai ba herevalaia, Migdol ai ba gwauraia,
\q2 Memefisi ai bona Tapanese ai ba gwauraia hedinarai;
\q1 baoto “Ba gini hata, ba hegaegae,
\q2 badina be dare ena ala-ala ese baine hahegegemu dae”.
\q1 
\v 15 Dahaka dainai Apisi vada e heau?
\q2 Dahaka dainai emu boromakau maruanena na se gini?
\q2 Badina be Iehova ese e doria dobi dainai.
\q1 
\v 16 Emu hutuma na e hetutuhi, e keto,
\q2 e hereva heheni, eto
\q1 “A tore isi, eda bese korikori bona eda vara tanona baita lou henidia,
\q2 daḡedaḡe tauna ena dare dainai”.
\q1 
\v 17 Farao, Aigupto pavapavana, ladana ba hatoa
\q2 “Hereva momo tauna, nega e reaiamu tauna”.
\b
\q1 
\v 18 Pavapava badana, ladana Iehova Sabaota, na e tomu:
\q2 Lau na maurimu heḡereḡerena, ta bainema,
\q1 Taboro ororona ororo badadia bogaragidiai na heto,
\q2 bona Karamele ororona, davara badibadinai, na heto.
\q1 
\v 19 Aigupto inoholaina taumui e!
\q2 Emui abikau kohudia ba habou hegaegae,
\q2 dauhai bae laohaimui dainai.
\q1 Badina be Memefisi baine vahu,
\q2 hanua ahutuna ai bainela, asi inoholaina ta.
\b
\q1 
\v 20 Aigupto na boromakau hahinena matamatana mai hairaina,
\q2 a kahuhu ta mirigini kahana amo na ia latanai vada e kau.
\q1 
\v 21 Ena tuari taudia, e vatudia taudia, na
\q2 boromakau natudia, ubu-ubu ḡaudia, na heheto,
\q2 ia bogaraginai.
\q1 Oibe, vada e kerehai, vada e heau hebou, asie gini,
\q2 badina be edia hahehisi dinana na ediai vada e kau,
\q2 edia dava-abi negana.
\q1 
\v 22 Ia reḡena na gaigai e rau ohomu reḡena na heto,
\q2 badina be ia inaina na mai goadadia ida e raka e maimu;
\q1 idia na mai iradia ida ia ihadikana totona e mai nu,
\q2 au e hagaridiamu taudia na heheto.
\q1 
\v 23 Iehova na e tomu:
\q2 Ena be ena uda na basie tuia hanai diba, to bae segaia;
\q1 badina be idia na hutuma herea, kwadi edia hutuma e hereadiamu,
\q2 ta basine duahidia diba.
\q1 
\v 24 Aigupto hane-ulatona na bae hahemaraia,
\q2 mirigini kahana amo baema besena imadia ai bae atoa.
\p 
\v 25 Iehova Sabaota, Israel Diravana, eto: A itaia, Amon, Tebe diravana, bona Farao, bona Aigupto tanona mai diravana bona pavapavana iboudiai ida, edia dika davadia baina henidia, Farao latanai bona ia e abidadama heniamu taudia latadiai.
\v 26 Edia mauri iabi-ohona dalana e tahuamu taudia imadia ai baina atodia, Nebukadresara, Babulono pavapavana, bona ena lohia taudia imadia ai. Gabeamo Aigupto na bae noholaia, nega gunadia ai heḡereḡerena. Iehova na e herevamu.
\b
\q1 
\v 27 Egu hesiai tauna Iakob e, basio gari!
\q2 Israel e, kudoumu basine hetaha!
\q1 A itaia, dauha amo baina hamaurimu,
\q2 bona garamu danu iḡui ai e nohomu tanodia amo baina hamauridia.
\q1 Iakob baine lou, asi reḡeregena baine laḡa ani,
\q2 bona ta ese basine hagaria.
\q1 
\v 28 Iehova na e tomu:
\q2 Egu hesiai tauna Iakob e, basio gari!
\q2 Badina be lau na oi ida.
\q1 Bese iboudiai baina ha-oredia vaitani,
\q2 hari dekedia na lulumu lao besedia;
\q2 a oi na basina ha-oremu vaitani.
\q1 Dika davana korikorina baina henimu;
\q2 momokani, matamu ihakanina basina reaia.
\c 47
\s1 Peroveta herevana Filistia taudia latadiai
\q1 
\v 1 Farao ese Gasa do se habuaia tari negana ai, Iehova ena hereva
\q2 na peroveta tauna Ieremia enai e kau, Filistia taudia daidiai.
\q1 
\v 2 Iehova ini e gwau tomamu:
\q2 A itaia, mirigini kahana amo ranu na e daemu,
\q2 bena abata na baine lasi;
\q1 tano na baine utua dae, bona latana ḡaudia iboudiai danu,
\q2 hanua badana danu, mai inoholaina taudia ida.
\q1 Taunimanima na bae lolo,
\q2 tano inoholaina taudia iboudiai na bae tai lolololo.
\q1 
\v 3 Ena hosi mamaruanedia aedia e pana dagumu reḡedia daidiai,
\q2 ena kariota edia heau bona ava-keikeidia reḡedia daidiai,
\q1 tama ese natudia asie roha kerehai henidiamu,
\q2 imadia e manoka-manoka hereamu dainai;
\q1 
\v 4 badina be hahebua-tari dinana na e maimu,
\q2 Filistia taudia iboudiai ihabua-taridia;
\q1 bona Turo bona Sidono ikahadia taudia oredia
\q2 iboudiai na bae negedia daure.
\q1 Badina be Iehova ese Filistia taudia e habuadia tarimu,
\q2 Kaftoro konena taudia kwabukwabudia.
\q1 
\v 5 Gasa kwarana e naua,
\q2 Askelono vada e mase.
\q1 Anakimi taumui kwabukwabumui e!
\q2 Sibomui ba heiva ela bona edena nega ai?
\q1 
\v 6 Iehova ena dare e!
\q2 Edena nega ai asi regeregemu ba noho?
\q1 Pauamu ai ba heuda,
\q2 ba laḡa ani, basio marere-marere.
\q1 
\v 7 Iehova ese e haduaiamu negana ai,
\q2 asi reḡereḡena baine noho dalana be edena?
\q1 Ia ese vada e duanaia,
\q2 Askelono bona kone kahadia baine hadikadia.
\c 48
\s1 Peroveta herevadia Moab latanai
\p 
\v 1 Moab herevana. Iehova Sabaota, Israel Diravana, na ini e gwau tomamu:
\q1 Nebo madi ihabaina, badina be vada e havahua!
\q2 Kiriataimi vada e hahemaraia, vada e abia;
\q1 kohoro vada e hahemaraia, vada e ḡiḡia dobi;
\q2 
\v 2 Moab harina namona vada e boio.
\q1 Hesebon ai ia ihadikana e henegalaia, eto,
\q2 “Aoma, basileia dagina amo baita negea daure”.
\q1 Oi danu, Madmene, udumu bae koua,
\q2 dare ese baine hahavamu.
\b
\q1 
\v 3 A hakala! Taitai Horonaimi amo:
\q2 “Hahevahu bona hahebua-tari bada-herea!”
\q1 
\v 4 Moab vada e habuaia tari;
\q2 taitai na e hekamonaimu ela bona Soara.
\q1 
\v 5 Badina be Luhiti e dae heniamu dalana ai,
\q2 idia na mai taidia ida e dae laomu,
\q1 bona Horonaimi e hekei heniamu dalana ai,
\q2 hahebua-tari taitaina vada e kamonai.
\q1 
\v 6 A heau, sibomui maurimui ba tahua!
\q2 Tano ḡaḡaena ai ba noho, uda donikina na heto!
\q1 
\v 7 Badina be, emui gabu aukadia bona emui kohu o abidadama henidia dainai,
\q2 umui danu bae abimui.
\q1 Kemoso\f + \fr 48:7 \ft Kemoso na Moab taudia edia dirava.\f* danu bainela, dauhai bae hanohoa,
\q2 mai ena hahelaḡa taudia bona ena lohia taudia ida.
\q1 
\v 8 Hahebua-tari tauna na hanua iboudiai latadiai baine kau,
\q2 hanua ta basine roho mauri.
\q1 Koura na baine vahu,
\q2 bona taora na baine hahebua tari,
\q2 Iehova vada e hereva heḡereḡerena.
\q1 
\v 9 Moab na hanina ba henia,
\q2 badina be e uramu baine roho lao;
\q1 ena hanua loḡora bae vahu,
\q2 asi inoholaidia bae mia.
\b
\p 
\v 10 Iehova ena ḡaukara na mai Iahedona ida e karaiamu tauna bae uduguiraia; ena dare na rara ihahebubuna amo e ruamu tauna na bae uduguiraia.
\q1 
\v 11 Moab na merona negana amo vada e noho namonamo,
\q2 vine ranuna asi nurinurina na heto;
\q1 hodu ta amo hodu ta ai asie vedaia,
\q2 bona dauhai asie hanohoa;
\q1 taunabunai ia mamina na doini lalonai e miamu,
\q2 bona bonana na se idaumu.
\p 
\v 12 Taunabunai Iehova na e tomu: A itaia, dinana be maimu lau ese ihaegena taudia na ia dekena baina siaidia lao; bena idia ese bae haegea, ena hodu anidia bae bubu ore, bona ena hodu bae hamakohidia.
\v 13 Bena Moab ese Kemoso hemaraina baine hemarai, Israel iduhuna ese Betele, edia heabidadama, hemaraina e hemaraiva heḡereḡerena.
\q1 
\v 14 Dahaka dainai o tomu “Ai na haheauka taumai
\q2 bona tuari taumai mai goadamai” a?
\q1 
\v 15 Pavapava badana, ladana Iehova Sabaota, na e tomu:
\q2 Moab mai ena hanu loḡora ida ihabua-taridia tauna vada e dae ema,
\q2 bona ena eregabe taudia herea-daedia na mase ai vada e diho lao.
\q1 
\v 16 Moab ena hahehisi vada eme kahikahi,
\q2 bona ena hisi-ani e mai haraḡamu. q1
\v 17 Ia taina ba tai, o nohoa hegegemu taumui iboumui ai,
\q1 bona ia ladana mai dibamui taumui iboumui ai,
\q2 baoto “Dagi auna herea-daena, au mai hairaina,
\q1 madi vada e kwaidu”.
\b
\q1 
\v 18 Dibon inoholaina taumu e!
\q2 Hairaimu amo a diho, tano haura-haurana ai ba helai.
\q1 Badina be Moab ihabua-tarina tauna vada ema, oi ihadikamu totona;
\q2 emu gabu aukadia vada e habuadia tari.
\q1 
\v 19 Aroere inoholaina taumu e!
\q2 Dala isena ai ba gini, ba gima,
\q1 heau tauna bona roho-mauri hahinena ba nanadaidia,
\q2 baoto “Edeheto?”
\q1 
\v 20 Moab vada e hahemaraia, badina be vada e makohi.
\q2 A lolo, a tai!
\q1 Aranon badibadinai ba gwauraia, baoto
\q2 “Moab vada e vahu”.
\b
\p 
\v 21 Hahemaoro na atai taorana ai vada e kau, Holon, Iahasaha Mefata,
\v 22 Dibon, Nebo, Bete-diblataimi,
\v 23 Kiriataimi, Bete-gamulu, Bete-meono,
\v 24 Kerioto, Bosra, bona Moab tanona hanuadia iboudiai, daudaudia bona kahikahidia, latadiai.
\v 25 Moab ena doa vada e utua oho, bona imana vada e kwaidu. Iehova na e herevamu.
\p 
\v 26 Ba hakekeroa; badina be ia na sibona e hahebada, Iehova e hamaraḡia. Taunabunai, Moab na sibona ena mumuta ai baine hekui-hekui; taunimanima ese bae kirihrilaia.
\v 27 Israel na so kirikirilaia a? Henao taudia bogaragidiai o davaria, bena o herevalaia negadia iboudiai kwaramu o haladoladoa a?
\b
\q1 
\v 28 Moab inoholaina taumui e!
\q2 Hanua ba rakatanidia, haga nadina ai ba noho,
\q2 koura dobudobu hagahagadia ai ena ruma e karaiamu punena na heto ba noho.
\q1 
\v 29 Moab ena heaḡi sivaraina vada ta kamonai;
\q2 ia na e heaḡi dikadikamu;
\q1 ena heabi-isi, ena heaḡi, ena hekokoroku, na dibada,
\q2 bona lalona ena hedadarai danu.
\q1 
\v 30 Iehova na e tomu:
\q2 Ena ere-daḡedage dibagu;
\q1 ena hekokoroku herevadia na kokoikoi,
\q2 ena kara danu kokoikoi.
\q1 
\v 31 Taunabunai, Moab taina na taimu,
\q2 Moab idoinai dainai na tai lolomu,
\q2 Kuri-here taudia daidiai na taimu.
\q1 
\v 32 Sibma vinena e!
\q2 Oi na tailaimu badamu, lasere na tailaia maraḡimu.
\q1 Oi rigimu ese davara e hanaia,
\q2 ela bona lasere ai e kau;
\q1 emu au huahuadia bona emu vine huahuadia na
\q2 vada e habuadia tari.
\q1 
\v 33 Moab tanona, huahua momo tanona, amo
\q2 lalo-namo bona moale vada e abi oho.
\q1 Lau ese vine ranuna vada na hadodoa, vine itaolaina gabuna ai;
\q2 asi tauna ta ese e moimoilaiamu mai moale lolona ida,
\q2 lolo na dia moale lolona.
\b
\p 
\v 34 Hesebon bona Eleale e taimu; gadodia e daemu ela bona Iahasa, bona Soara amo ela bona Horonaimi bona Eglata-selisia. Badina be Nimirimi ranudia vada e kororo.
\v 35 Iehova na e tomu: Moab ai atai gabuna ai boubou karadia e karamu bona muramura mai bonana na ena dirava e gabu heniamu tauna na baina hadokoa.
\v 36 Taunabunai lalogu na e taimu ivilikou na heto, Moab dainai; bona lalogu na e taimu ivilikou na heto Kiri-here taudia daidiai; una dainai e habou kohudia na vada e ore.
\p 
\v 37 Badina be kwara iboudiai bae nau, bona auki iboudiai huidia bae abi; ima iboudiai bae hegasi, bona koekoe ai puse dabuadia bae herio.
\v 38 Moab rumadia iboudiai guhidia ai bona hanua ariaradia ai e herohe ahumu, badina be Moab vada na huaria, ta ese se balaia henimu hoduna na heto. Iehova na e herevamu.
\v 39 Madi, vada e makohi! Madi ihabaidia, e tai lolololomu! Moab madi, ena hemarai dainai vada e gini muri! Taunabunai Moab na e kirikirilaiamu bona e garilaiamu ḡauna ai vada e hahelao, e noho hetabiramu taudia ediai.
\p 
\v 40 Badina be Iehova ini e gwau tomamu:
\q1 A itaia, ta baine roho haraḡa-haraḡa, ugava na heto,
\q2 hanina baine toi roro, Moab ihadikana totona;
\q1 
\v 41 hanua na bae abidia,
\q2 bona gabu aukadia bae dadi.
\q1 Una dina ai Moab ena tuari taudia lalodia na
\q2 e hekamonaimu hahinena lalona heḡereḡerena ai baela.
\q1 
\v 42 Moab na bae habuaia tari, basie gwauraia lou bese ta;
\q2 badina be ia sibona e hahebada, Iehova e hamaraḡia.
\q1 
\v 43 Moab inoholaina taumu e!
\q2 Laḡaga bona hedai-dobi gurina bona idoa na vairamu ai.
\q2 Iehova na e herevamu.
\q1 
\v 44 Mai laḡagana ḡauna amo baine heau oho tauna na
\q2 hedai-dobi gurina lalonai baine moru,
\q1 bona guri lalona amo baine hekamo dae tauna na
\q2 idoa ese baine idoaia.
\q1 Badina be lau ese ini ḡau na Moab latanai baina hadihoa,
\q2 edia dika davarta iabina laḡanina ai.
\q2 Iehova na e herevamu.
\b
\q1 
\v 45 Hesebon ikerukeruna ai
\q2 heau taudia na e ginimu,
\q2 edia goada na vada e ore;
\q1 badina be lahi na Hesebon amo vada e lasi,
\q2 lahi hururu-hururuna Sihon ena ruma amo;
\q1 Moab baguna vada e huaria,
\q2 bona heloḡo-heloḡo taudia kwaradia tubuadia danu vada e huaridia.
\q1 
\v 46 Moab e, madi ihabaimu!
\q2 Kemoso ena orea taudia vada e baia;
\q1 badina be natumu mamaruanedia vada e ḡuidia,
\q2 bona natumu hahinedia na iḡuidia ai vada e laohaidia.
\q1 
\v 47 Moab ena noho ma baina hanamoa lou,
\q2 dina gabedia ai.
\q2 Iehova na e herevamu.
\m Hahemaoro Moab latanai herevadia bunu.
\c 49
\s1 Peroveta herevadia Amono taudia latadiai
\p 
\v 1 Amono taudia herevadia. Iehova ini e gwau tomamu:
\q1 Israel na asi natuna maruanena a?
\q2 Ia na asi dihina a?
\q1 Matona, badina be dahaka Milkom\f + \fr 49:1 \ft bona Milkom be Amono taudia edia dirava ladana.\f* ese Gad vada e lahea oho,
\q2 bona iena taunimanima ese hanuadia vada e noholaidia?
\q1 
\v 2 Taunabunai, Iehova na e tomu:
\q2 Negana be maimu,
\q1 lau ese haida baina hagoadadia, bena bae hone,
\q2 Raba, Amono taudia edia hanua, bae hare henia.
\q1 Ia na senu ḡaḡaena ai bainela,
\q2 bona ena hanua maraḡidia na lahi amo bae doudia;
\q1 bena Israel e lahea oho taudia na
\q2 Israel ese ma baine lahedia oho.
\q2 Iehova na e herevamu.
\q1 
\v 3 Hesebon e, ba tai, badina be Ai vada e havahua!
\q2 Raba hahinemui e, a tai!
\q1 Puse dabuadia ba rio,
\q2 ba herohe ahu, ba tai hekakasi.
\q2 Badina be Milkom na bae laohaia, tano idauna ai bae hanohoa,
\q1 mai ena hahelaḡa taudia bona ena lohia taudia ida.
\q2 
\v 4 Kara hebeatai kekenimu e!
\q1 Emu taḡa o abidadama henia, oto
\q2 “Daika na lau ihadikagu bainema?”
\q1 O, badina be dahaka emu koura o heaḡilaidiamu?
\q2 
\v 5 Ḡaubada Iehova Sabaota na e tomu:
\q1 A itaia, laḡaḡa na latamui ai baina hadihoa,
\q2 e ḡeḡemui dae taudia iboudiai edia amo;
\q1 bae lulumui lasi, ta ta ena dala ena dala ai bae heau,
\q2 bona ta ese heau taudia basine gogodia lou.
\p 
\v 6 Iehova na e tomu: A gabeamo Amono taudia edia noho-namo baina havaraia lou.
\s1 Peroveta herevadia Edom latanai
\p 
\v 7 Edom herevana. Iehova Sabaota ini e gwau tomamu:
\q1 Aonega vada e ore Teman ai a?
\q2 Lalo-parara taudia ediai hahealo vada e doko a?
\q2 Edia aonega vada e boio a?
\q1 
\v 8 Dedan inoholaina taumui e!
\q2 A heau, a lou, dobu gabudia ai ba noho.
\q1 Badina be Esau ena hisihisi na ia latanai baina hadihoa,
\q2 bona ena dika davana iabina negana danu.
\b
\q1 
\v 9 Vine huahuadia ihaboudia taudia bema vasi,
\q2 idia ese vine abitanidia bema rakatani ani?
\q1 Henao taudia na hanuaboi ai bema mai,
\q2 idia ese edia ura ḡaudia mo bema abi ani?
\q1 
\v 10 A lau ese Esau ena vada na dadi ore,
\q2 ena komu gabudia vada na hulalai;
\q2 ia na asi ena komu dalana.
\q1 Ia natuna vada e aladia ore,
\q2 tadikakana bona dekena taudia danu;
\q2 ia na vada e ore.
\q1 
\v 11 Emu ihareha ba rakatanidia, lau ese baina hamauridia;
\q2 emu vabu ese lau bae abidadama henigu.
\b
\p 
\v 12 Badina be Iehova ini e gwau tomamu: Bema basiema inua taudia ese kehere bae inua, oi na dika davana basio abia a? Dika davana basio reaia, a vada ba inua.
\v 13 Iehova na e tomu: Badina be sibogu ladagu ai vada na gwau hamata, Bosra na hahegari bona hegonaḡonalai bona hahevahu bona heuduguirai ḡauna ai bainela; bona ena hanua iboudiai na bae vahu hanaihanai.
\q1 
\v 14 Hari ta Iehova ena amo vada na kamonai,
\q2 bona gwaukau tauna ta vada e siaia lao,
\q2 bese idau-idau bogaragidiai, e tomu
\q1 “A hegogo, ia ihadikana totona baoma,
\q2 a tore isi, ba tuari”.
\q1 
\v 15 Badina be lau ese bese idau-idau bogaragidiai baina hamaraḡimu,
\q2 taunimanima ese bae dadaraimu.
\q1 
\v 16 Emu hahegari karadia ese vada e koimu,
\q2 bona lalomu ena heaḡi danu.
\q1 Haga nadidia kohuadia ai o nohomu taumu,
\q2 ororo dorina o gimaiamu taumu,
\q1 ena be emu noho gabuna na atai ai o karaiamu, ugava ena heḡereḡerena,
\q2 to unu amo baina verimu dobi.
\q2 Iehova na e herevamu.
\b
\p 
\v 17 Edom na hahegari ḡauna ai bainela; e rakaia hanaimu taudia iboudiai na bae gari bona bae si dagu, enai vada e kau dikadia iboudiai daidiai.
\v 18 Iehova na e tomu: Sodoma bona Gomora bona edia hetabira hanuadia e heḡiḡi dobi heḡereḡerena ai, tau ta ese basine noholaia; tau ta na ia lalonai basine taruha.
\v 19 A itaia, leona na Ioridane isena udana amo mamoe maḡuna aukana ihadikana totona e maimu heḡereḡerena ai, lau ese iena amo baina haheaudia karoho, bona egu abi-hidi tauna baina duanaia, ia ese baine biagua. Badina be daika na lau heḡereḡeregu? Daika ese baine boirigu? Mamoe ireḡudia tauna be daika lau vairagu ai baine gini diba?
\v 20 Taunabunai, Iehova ese Edom ihadikana dalana vada e haerolaia herevana na ba kamonai, bona Teman inoholaina taudia ihadikadia dalana e uralaiamu danu. Mamoe-mamoe na seri bogaragina amo bae dabuidia oho; edia seri mamoedia na bae gari taku, ediai baine vara ḡauna dainai.
\v 21 Edia moru reḡena dainai tanobada na baine heude-heude; edia tai reḡena na Davara Kakakakana isena ai bae kamonai.
\v 22 A itaia, ta baine roho isi, baine roho haraḡa-haraga, ugava na heto; hanina baine toi roro, Bosra ihadikana totona; bena Edom ena tuari taudia lalodia na e hekamonaimu hahinena lalona heḡereḡerena ai baela.
\b
\s1 Peroveta herevana Damasko latanai
\q1 
\v 23 Damasko herevana.
\q1 Hamat bona Arapada vada e baia;
\q2 badina be hari dikadia vada e kamonai.
\q1 Gari ese e gugubadiamu;
\q2 e hekwarahimu, davara na heto,
\q2 asi vea dibana davarana na heto.
\q1 
\v 24 Damasko vada e manoka-manoka,
\q2 e raka muri, baine heau eto,
\q2 lagaga ese e butua tao;
\q1 hisi-ani bona lalo-hisihisi ese vada e gugubaia,
\q2 e hekamonaimu hahinena na heto.
\q1 
\v 25 Hanua mai harina, hanua mai moalena, madi ihabaina!
\q2 Vada e rakatania.
\q1 
\v 26 Taunabunai, ena eregabe taudia na ena ariara ai bae hekida diho,
\q2 bona ena tuari taudia iboudiai na bae habuadia tari una dina ai.
\q2 Iehova Sabaota na e herevamu.
\q1 
\v 27 Damasko maḡuna ai lahi ta baina ha-araia,
\q2 ia ese Damasko maguna ai lahi ta baina ha-araia,
\q2 ia ese Ben-Hadad ena gabu aukadia baine aradia ore.
\s1 Peroveta herevana Kedara
\s1 bona Hasoro latadiai
\p 
\v 28 Kedara bona Hasoro basileiadia, Nebukadresara, Babulono pavapavana, ese e hadareredia basileiadia, herevadia. Iehova ini e gwau tomamu:
\q1 A tore isi, Kedara ihadikana baola;
\q2 mairiveina kahana taudia ba habuadia tari.
\q1 
\v 29 Edia dabua kalagadia bona edia mamoe seridia bae heabi oho,
\q2 edia seseahu dabuadia bona edia kohu iboudiai danu;
\q1 edia kamelo na edia amo bae hakaudia oho,
\q2 bona taunimanima ese bae boi henidia, baeto
\q2 “Kaha iboudiai hahegari mo”.
\q1 
\v 30 Hasoro inoholaina taumui e!
\q2 A heau, dauha baola, dobu gabudia ai ba noho.
\q2 Iehova na e herevamu.
\q1 Badina be Nebukadresara, Babulono pavapavana, ese
\q2 oi ihadikamu dalana vada e haeroa,
\q2 oi ihadikamu karana vada e uralaia.
\b
\q1 
\v 31 Iehova na e tomu: A tore isi!
\q2 E laḡa-animu besena, e noho namonamomu besena,
\q2 ihadikana totona baola;
\q1 ia na asi ena ikoukou, bona asi ena auri,
\q2 ia na sibona e noho edeamu.
\q1 
\v 32 Iehova na e tomu:
\q2 Edia kamelo na bae dadidia,
\q2 edia boromakau seridia bae abidia oho.
\q1 Bagudia huidia e abimu taudia na
\q2 baina hakarohodia, kaha iboudiai baela;
\q1 bona ihahisidia ḡaudia na
\q2 kaha iboudiai amo baina mailaidia.
\q1 
\v 33 Hasoro na uda sisiadia edia noho gabuna ai bainela,
\q2 baine vahu hanaihanai;
\q1 tau ta ese basine noholaia,
\q2 tau ta ia lalonai basine taruha.
\s1 Peroveta herevana Elam latanai
\p 
\v 34 Iehova ena hereva peroveta tauna Ieremia enai e kau Elam dainai, Sedekia, Iuda pavapavana, e lohia matama negana ai.
\p 
\v 35 Iehova Sabaota ini e gwau tomamu: A itaia, lau ese Elam ena peva, edia goada badina, baina hakwaidua;
\v 36 bona lai haniosi, guba kahana haniosi amo, na Elam latanai baina mailaidia, bona baina hakarohodia roho- roho, unu lai kahadia iboudiai baela; bona Elam amo bae luludia lasi taudia na bese iboudiai bogaragidiai bae kau.
\v 37 Iehova na e tomu, Lau ese Elam baina hagaria inaidia vairadiai, bona edia mauri iabi-ohona dalana e tahuamu taudia vairadiai danu; dika na idia latadiai baina hadihoa, bona egu badu ḡaraḡara danu. Dare baina siaia, baine ḡavadia, ela bona baina ha-oredia;
\v 38 egu terono baina haginia Elam ai, bona edia pavapava bona edia lohia baina habuadia tari. Iehova na e herevamu.
\p 
\v 39 Iehova na e tomu: A dina gabedia ai Elam ena noho-namo baina havaraia lou.
\c 50
\s1 Peroveta herevana Babulono latanai
\p 
\v 1 Ina na Iehova ena hereva, peroveta tauna Ieremia uduna amo e gwauraia, Babulono latanai, Kaldea taudia edia tano latanai.
\q1 
\v 2 Bese bogaragidiai ba gwauraia bona ba herevalaia hedinarai;
\q2 pepe ta ba duduia isi, ba herevalaia hedinarai.
\q1 Basio hunia, baoto:
\q2 Babulono vada e abia,
\q1 Bel vada e hahemaraia,
\q2 Merodak\f + \fr 50:2 \ft Bel bona Merodak na Babulono taudia edia dirava.\f* vada e baia.
\q1 Ena dirava laulaudia vada e hahemaraidia,
\q2 ena kaivakuku vada e baia.
\p 
\v 3 Badina be mirigini kahana amo bese ta vada ema, ia ihadikana; una bese ese ena tano baine havahua, tau ta ese basine noholaia; taunimanima bona ubu-ubu ḡaudia na bae heau karoho.
\p 
\v 4 Iehova na e tomu, Unu dinadia ai bona una nega ai, Israel bona Iuda taudia bae hegogo, mai taidia ida baema, Iehova, edia Dirava, bae tahua.
\v 5 Siona dalana bae henanadailaia, bae vaira henia, baeto, Aoma, Iehova ida baita hegwauhamata heheni, baine hesiriu hanaihanai gwauhamatana, ta ese basine laloa boio ḡaina.
\p 
\v 6 Egu bese taudia na boio mamoedia; ireḡudia taudia ese vada hakaudia kerere, ororo ai vada e harakadia siri; ororo badana amo ela bona ororo maraḡina vada ela, edia maḡu vada e reaia.
\v 7 E davaridia taudia iboudiai ese e ha-oredia; inaidia eto, Ai na asi emai kerere, badina be idia ese Iehova, edia noho gabuna korikorina, Iehova, senedia edia helaro, vada e kara dika helua.
\p 
\v 8 Babulono bogaragina amo ba heau lao, Kaldea taudia edia tano ba rakatania, nani mamaruanedia na edia seri matana ai e rakamu na heto.
\v 9 Badina be lau ese bese badadia mirigini kahana amo na hatoredia isimu, Babulono ihadikana totona na hakaudia laomu. Idia ese bae tuari henia, bena unu amo ia na baine hahedarere. Edia hakore na tuari mai dibana tauna na heto, dia imana kavakava se lou maimu.
\v 10 Kaldea tanona bae dadihaia; enai bae dadidadi taudia iboudiai ese kohu bae abi doroka-doroka. Iehova na e herevamu.
\b
\q1 
\v 11 Lau ahugu idadina taumui e!
\q2 Ena be ba moale, ena be ba heaḡi,
\q1 ena be ba lebulebu boromakau hahinena matamatana rei gabuna ai na heto,
\q2 eiava ba tubebe hosi mamaruanedia na heheto,
\q1 
\v 12 to sinamui na bae hahemaraia vaitani,
\q2 e havaramui hahinena sivaraina baine dika.
\q1 A itaia, ia na bese gini-gabena ai bainela,
\q2 bese idau-idau bogaragidiai;
\q1 tano ḡaḡaena ai bainela,
\q2 kaukauna bona deḡedeḡena rahu.
\q1 
\v 13 Iehova ena badu dainai ta ese basine noholaia,
\q2 ia na baine vahu vaitani;
\q1 Babulono bae rakaia hanai taudia na bae hoa mai garidia ida,
\q2 bona bae si dagu, ia berona iboudiai daidiai.
\q1 
\v 14 Emui peva o maremu taumui iboumui ai,
\q2 Babulono ba tuari henia, ba ginia heḡeḡe;
\q1 ba tarakia, emui diba bae ore na basio laloa,
\q2 badina be ia ese Iehova vada e kara dika henia.
\q1 
\v 15 Ba loloa heḡeḡe,
\q2 ia na vada e baia;
\q1 ena gabu aukadia vada e makohi,
\q2 ena maḡu vada eme heḡiḡi dobi.
\q1 Badina be Iehova ena dava-heni binai:
\q2 ena dika davana ba henia;
\q2 ia e karava heḡereḡerena ai ba kara henia.
\q1 
\v 16 Hadohado tauna na Babulono amo ba negea daure,
\q2 bona taboro negana ai uit e utuamu tauna danu;
\q1 hahehisi tauna ena dare dainai
\q2 iboudiai ese edia bese korikori taudia bae lou henidia
\q2 bona iboudiai na edia tano korikori bae heau lao.
\p 
\v 17 Israel na leona ese vada e luludia karoho mamoena ta. Guna Asuria pavapavana ese e ania, ma harihari, ina nega dokona ai, Nebukadresara, Babulono pavapavana, ese ia turiana e kwarurudia.
\v 18 Taunabunai, Iehova Sabaota, Israel Diravana, na ini e gwau tomamu: A itaia, Babulono pava- ! pavana bona ena tano na edia dika davadia ba henidiamu, Asuria pavapavana ena dika davana na henia heḡereḡerena.
\v 19 Israel na ena rei gabuna baina henia lou; ia na Karamele ai bona Basan ai baine aniani, bona Efraim ororodia ai bona Gilead ai bogana baine kunu.
\v 20 Iehova na e tomu: Unu dinadia ai bona una nega ai, kara havara bae tahua Israel ai, to asi ḡauna; bona kara dika bae tahua Iuda ai, to basie davaria; badina be kwabukwabudia, baina rakatanidia taudia, na edia dika baina gwau tao.
\q1 
\v 21 Merataimi tanona ba tuari henia,
\q2 bona Pekodo inoholaina taudia danu.
\q1 Iehova na e tomu: Bavala-ala,
\q2 ba habuadia tari vaitani,
\q2 vada na haganilaimui karadia iboudiai na ba kara.
\q1 
\v 22 Tuari reḡedia na tano ai e reḡemu,
\q2 bona hahebua-tari badana danu.
\q1 
\v 23 Tanobada idoinai ibotalaina lavuna,
\q2 madi, vada e utua gari, vada e hamakohia.
\q1 Babulono madi ihabaina!
\q2 Ia na hahegari ḡauna ai vada ela,
\q2 bese idau-idau bogaragidiai.
\q1 
\v 24 Babulono e! Idoa na otoa, oi iabimu totona;
\q2 bena na idoamu, to asi dibamu.
\q1 E davarimu bona e abimu,
\q2 badina be Iehova o tuari henia.
\q1 
\v 25 Iehova ese ena tuari ḡaudia ihaboudia rumana vada e kehoa,
\q2 ena badu tuari ḡaudia vada e abidia lasi;
\q1 badina be Ḡaubada Iehova Sabaota na mai ena ḡaukara ta,
\q2 Kaldea taudia edia tano ai baine karaia.
\q1 
\v 26 Kaha iboudiai amo ba tuari henia;
\q2 ena roge ba kehodia;
\q1 ba hasenua, uit senudia na heheto,
\q2 ba habuaia tari vaitani,
\q2 ienai sisisisina taina basine mia.
\q1 
\v 27 Ena boromakau mamaruanedia iboudiai na bavaladia mase,
\q2 iala-masedia gabuna ai do bae diho.
\q1 Madi, ihabaidia! Badina be edia dina vada e kau,
\q2 edia dika davana iabina negana vada e kau.
\p 
\v 28 A hakala, idia na e heaumu, Babulono tanona amo e roho maurimu; Siona ai Iehova, eda Dirava, ena dava-heni, ena dubu idavalaina, na bae gwauraia hedinarai.
\p 
\v 29 Peva taudia a boiridia, peva e maremu taudia iboudiai, Babulono ihadikana totona. Ba taruhaia hegeḡe; tau ta basine roho mauri. Ena kara davadia ba henia, ena kara iboudiai heḡereḡeredia ai ba kara henia; badina be mai heagina ida Iehova, Israel ena Helaḡa Diravana, na vada e hare henia.
\v 30 Taunabunai, ena eregabe taudia na ena ariara ai bae hekida diho, bona ena tuari taudia iboudiai na bae habuadia tari una dina ai. Iehova na e herevamu.
\b
\q1 
\v 31 Ḡaubada Iehova Sabaota na e tomu:
\q2 Heaḡi taumu e! A itaia, lau na oi inaimu;
\q1 badina be emu dina vada e kau,
\q2 emu dika davana baina henimu negana vada e gini dae.
\q1 
\v 32 Heaḡi tauna na baine hetutuhi, baine hekida diho,
\q2 asi tauna ta ese baine hatorea isi.
\q1 Lau ese lahi ta baina ha-araia ena hanua iboudiai lalodiai;
\q2 ia e ḡeḡea madaimu ḡaudia iboudiai na baine aradia ore.
\b
\p 
\v 33 Iehova Sabaota ini e gwau tomamu: Israel taudia na e hahisidiamu, bona Iuda taudia danu idia ida; e abidia mauri taudia iboudiai ese vada e dogodia tao tarika-tarika, ikahu-riegedia asie uramu.
\v 34 Ihamauridia Diravana na mai goadana; ia ladana na Iehova Sabaota. Ia ese edia gini-kau gabuna baine herevalaia, bena tanobada na laḡani baine henia, a Babulono inoholaina taudia na hekwarahi baine henidia.
\b
\q1 
\v 35 Iehova na e tomu:
\q2 Dare ta Kaldea taudia latadiai,
\q1 bona Babulono inoholaina taudia latadiai,
\q2 bona ena lohia bona ena aonega taudia latadiai baine kau.
\q1 
\v 36 Dare ta bagu-haoro taudia latadiai baine kau,
\q2 kavakava taudia ai bae hahelao helaoreana.
\q1 Dare ta ena tuari taudia latadiai baine kau,
\q2 baine habuadia tari helaoreana.
\q1 
\v 37 Dare ta ena hosi bona ena kariota latadiai,
\q2 bona bese idaudia edia tuari taudia iboudiai
\q2 ia lalonai e nohomu na latadiai baine kau,
\q2 hahine ai bae hahelao helaoreana.
\q1 Dare ta ena taḡa idoinai latanai baine kau,
\q2 bae dadihaia helaoreana.
\q1 
\v 38 Medu na ena ranu gabudia ai basine diho,
\q2 bena bae kororo.
\q1 Badina be ia na dirava idau-idau laulaudia tanona,
\q2 bona kaivakuku na e lalodia badamu.
\p 
\v 39 Taunabunai, uda boromadia bona uda sisiadia na Babulono ai bae noho hebou, bona kokokoko danu ia lalonai bae noho; tau ta ese basine noholaia ela bona hanaihanai, uru iboudiai lalodiai tau ta ese basine noho henia.
\v 40 Dirava ese Sodoma bona Gomora bona edia hetabira hanuadia na e habuadia tari negana heḡereḡerena ai, unuheto tau ta na unuseni ai basine noho, bona taunimanima natuna ta ese basine noho henia. Iehova na e herevamu.
\b
\q1 
\v 41 A itaia, bese ta mirigini kahana amo e maimu,
\q2 basileia badana ta bona pavapava hutuma na
\q2 tanobada dokodia amo e tore isimu.
\q1 
\v 42 Idia ese peva bona io e abi kaumu;
\q2 idia na mai daḡedagedia, asi hebogahisidia.
\q1 Idia reḡedia na davara guruna na heto;
\q2 idia na hosi ai e guimu;
\q1 edia tuari ḡaudia na e abi kaumu,
\q2 oi Babulono kekenimu, ihadikamu totona.
\b
\q1 
\v 43 Babulono pavapavana ese haridia e kamonai,
\q2 bena imana e hedabarai;
\q1 hisi ese e gugubaia,
\q2 hahine ena hekamonai hisina na heto.
\b
\p 
\v 44 A itaia, leona na mamoe maḡuna aukana ihadikana totona Ioridane udana amo e daemu na heto, lau ese iena amo baina haheaudia oho; bona baina abia hidi tauna na ia ikwarana tauna ai baina halaoa. Badina be daika na lau heḡereḡeregu? Daika ese baine boirigu? Edena mamoe ireḡudia tauna na lau vairagu ai baine gini diba?
\v 45 Taunabunai, Iehova ena lalo-hadai, Babulono ihadikana totona vada e haeroa, bona ena ura, Kaldea taudia edia tano ihadikana totona vada e laloa, na ba kamonai. Momokani, mamoe maraḡidia na edia mamoe serina amo bae dabuidia lao; momokani, edia magu mamoedia na bae gari taku, ediai vada e vara ḡauna dainai.
\v 46 Babulono iabina reḡena dainai tanobada baine heude-heude, bona ena taitai na bese iboudiai bogaragidiai bae kamonai.
\c 51
\s1 Iehova ese Babulono e revaia
\p 
\v 1 Iehova ini e gwau tomamu:
\q1 A itaia, hahebua-tari tauna baina rohea,
\q2 Babulono ihadikana totona,
\q2 Kaldea inoholaina taudia ihadikadia totona;
\q1 
\v 2 bona itapona taudia na Babulono baina siaidia lao,
\q2 idia ese bae tapoa;
\q1 bona kaha iboudiai amo bae tuari henia negana ai,
\q2 idia ese ena tano anina bae ha-orea,
\q2 hisihisi dinana ai.
\q1 
\v 3 Peva tauna ese ena peva basine marea,
\q2 ena tuari dabuana ai basine gini tore.
\q1 Ena eregabe taudia basio bogadia hisi;
\q2 ena tuari oreana idoinai ba habuaia tari.
\q1 
\v 4 Kaldea taudia edia tano ai na masedia ai bae hekida diho,
\q2 bona edia ariara ai danu bae hekida diho mai berodia ida.
\q1 
\v 5 Badina be Israel bona Iuda edia Dirava,
\q2 Iehova Sabaota, ese asine rakatanidia;
\q1 a Kaldea taudia edia tano na kerere ai e honu honu daemu,
\q2 Israel ena Helaḡa Diravana enai.
\b
\q1 
\v 6 Babulono bogaragina amo ba heau;
\q2 iboumui ai maurimui ba tahua.
\q1 Iena dika davana iabina ai basio hedai uru;
\q2 badina be ina na Iehova ena dava-heni negana,
\q2 ahuna binai ia ese e heniamu.
\q1 
\v 7 Babulono na \it gold\it* keherena ta Iehova imana ai,
\q2 tanobada idoinai ihakekerona;
\q1 bese idau-idau ese iena vine ranuna e inua,
\q2 una dainai unu bese na e kavadia.
\q1 
\v 8 Asi vanahana Babulono na vada e darere, vada e makohi;
\q2 ia taina ba tai.
\q1 Ena hisihisi muramurana ba laohaia,
\q2 reana baine namo Iou.
\q1 
\v 9 Ita ese Babulono na ena hisihisi amo baitama hamauria,
\q2 to ena hisihisi amo se mauri,
\q1 A rakatania, aitala,
\q2 ta ta ena tano ena tano baita lou heni;
\q1 badina be ihahemaoro-henina vada e dae guba ai,
\q2 vada e heabi isi atai ai.
\q1 
\v 10 Iehova ese igwaurai-maoroda vada e hahedinaraia;
\q2 aoma, Iehova, eda Dirava, ena kara na
\q2 Siona ai baita gwaurai hedinarai.
\q1 
\v 11 Diba matadia a nau!
\q2 Kesi avabi isi!
\b
\p Iehova ese Media pavapavadia vada e rohedia, badina be ena ura Babulono enai na baine habuaia tari e tomu; badina be una na Iehova ena dava-heni, ena dubu idavalaina.
\b
\q1 
\v 12 Pepe ta ba haginia Babulono maḡudia vairadiai,
\q2 hegima oreana ba ha-aukaia;
\q1 hegima taudia ba duanaidia,
\q2 ibani-henina daladia ba hegaeḡaelai;
\q1 badina be Babulono taudia e herevalaidia ḡaudia na
\q2 Iehova ese vada e haero bona vada e kara.
\q1 
\v 13 Umui, sinavai momo badibadidiai o nohomu taumui e!
\q2 Taga taumui e, dokomui vada e kau,
\q2 emu mauri varona vada e utua.
\q1 
\v 14 Iehova Sabaota na ia sibona ladana ai vada e gwau hamata, eto:
\q2 Momokani, taunimanima ai baina hahonumu,
\q2 bae hoho, kwadi na heheto;
\q1 bena kwalimu honena bae lololaia,
\q2 oi latamu ai.
\b
\q1 
\v 15 Ia ese ena siahu amo tanobada e karaia
\q2 bona ena aonega amo tanobada idoinai e haginia,
\q2 bona ena lalo-parara amo guba e idia roro.
\q1 
\v 16 Ia e herevamu negadia ai, ranu e heguruamu guba ai;
\q2 ia ese ninoa e hadaeamu, tanobada dokodia amo.
\q1 Ia ese medu kevarudia e halasidiamu,
\q2 bona lai na ena habou-habou rumadia amo e hakaudia lasimu.
\q1 
\v 17 Taunimanima iboudiai na kakavakava bona asi aonegadia,
\q2 bona \it gold\it* iḡaukaralaina taudia iboudiai na edia kaivakuku ese e hahemaraidiamu;
\q1 badina be edia kaivakuku na koikoi ḡaudia,
\q2 bona asi laḡadia.
\q1 
\v 18 Idia na asi anidia, haero-kerere ese e havaradia;
\q2 edia dava-abi negana ai bae mase.
\q1 
\v 19 Iakob ahuna na dia unuheto;
\q2 badina be ia ese ḡau iboudiai vada e karadia.
\q1 Ia dihina na Israel besena;
\q2 ia ladana na Iehova Sabaota.
\b
\q1 
\v 20 Oi na egu gahi bona egu tuari ḡauna;
\q2 oiemu amo bese idau-idau baina huaridia,
\q2 oiemu amo basileia idau-idau baina habuadia tari;
\q1 
\v 21 oiemu amo hosi mai iḡuina tauna ida baina huaridia patapata,
\q2 oiemu amo kariota bona kariota tauna baina huaridia patapata;
\q1 
\v 22 oiemu amo tau bona hahine baina huaridia patapata,
\q2 oiemu amo iahu bona eregabe baina huaridia patapata;
\q1 oiemu amo tauhau bona hane-ulato baina huaridia patapata,
\q2 
\v 23 oiemu amo mamoe ireḡudia tauna mai ena mamoe serina ida baina huaridia patapata;
\q1 oiemu amo ruarua tauna mai ena boromakau mamaruanedia ida baina huaridia patapata,
\q2 oiemu amo bese ikwaradia taudia bona tuari lohiadia baina huaridia patapata.
\b
\p 
\v 24 Iehova na e tomu: Mata dogadoḡamu ai Babulono bona Kaldea inoholaina taudia edia dika davadia do baina henidia, kara dikadia Siona ai vada e kara iboudiai daidiai.
\b
\q1 
\v 25 Iehova na e tomu: Hahebua-tari ororona e!
\q2 Tanobada idoinai o habuaia tarimu;
\q2 lau ese na inai henimumu.
\q1 Lau imagu baina toia roro, oi ihadikamu totona,
\q2 bona haga nadidia amo baina keimu dobi,
\q2 vada e heara ororona ai baina halaomu.
\q1 
\v 26 Daiguni nadina ta eiava badi nadina ta na oiemu amo basie abia;
\q2 a oi na ba vahu hanaihanai.
\q2 Iehova na e herevamu.
\b
\q1 
\v 27 Pepe ba duduia isi tanobada ai,
\q2 bese idau-idau bogaragidiai kibi ba hiriria;
\q1 bese idau-idau ba hahegaegaedia, bae tuari henia totona,
\q2 basileia idau-idau ba boiridia, ia ihadikana totona,
\q2 Ararat bona Mini bona Asakena.
\q1 tuari lohiana ba duanaia, ia ihadikana;
\q2 hosi ba hakaudia lasi, kwadi na heheto.
\q1 
\v 28 Bese idau-idau ba hahegaegaedia, bae tuari henia totona,
\q2 Media pavapavadia, bona edia hekwara taudia mai ibolodia taudia ida,
\q2 bona idia ese e lohiadia tanodia iboudiai.
\q1 
\v 29 Tano na e heude-heudemu, hisihisi ai e hekoe-hekoemu,
\q2 badina be Iehova ena ura Babulono enai vada e ginimu.
\q1 Babulono tanona baine havahua,
\q2 asi inoholaina tauna ta baine noho.
\q1 
\v 30 Babulono ena tuari taudia ese tuari vada e hadokoa,
\q2 edia gabu aukadia ai e nohomu;
\q1 edia goada vada e ore,
\q2 hahine ai ela;
\q1 rumana vada e aramu,
\q2 aurina vada e kwaidu.
\q1 
\v 31 Heau tauna ta ese lava baine heaulaia, ma heau tauna ta baine davaria;
\q2 bona gwaukau tauna ta ese lava baine laohaia, ma gwaukau tauna ta baine davaria;
\q1 Babulono pavapavana na bae hamaoroa,
\q2 ena hanua na kahadia iboudiai vada e abia;
\q1 
\v 32 turu-hanai gabudia vada e abidia,
\q2 gabu aukadia vada e doudia,
\q2 tuari taudia na e gari lalo-dikamu.
\q1 
\v 33 Badina be Iehova Sabaota, Israel Diravana, na
\q2 ini e gwau tomamu:
\q1 Babulono natuna hahinena na uit ikwadilaina gabuna na heto,
\q2 e moia tao matama ḡauna;
\q1 nega taina bainela,
\q2 bena itaborona negana baine kau.
\b
\q1 
\v 34 Nebukadresara, Babulono pavapavana, ese vada e ha-oregu,
\q2 vada e moigu tao;
\q1 ia ese tohe asi anina heḡereḡerena ai vada e halaogu;
\q2 ia ese vada e hadonogu, huala badana na heto;
\q1 ia ese agu aniani ḡaudia namodia amo bogana vada e hakunua,
\q2 vada e lorigu lasi.
\q1 
\v 35 Siona inoholaina taudia na baeto:
\q2 “Dagedage karadia lauegu ai bona varavaragu ediai e kara na
\q2 Babulono latanai bae mia”.
\q1 Ierusalem baineto:
\q2 “Lau raragu na Kaldea inoholaina taudia latadiai”.
\q1 
\v 36 Taunabunai, Iehova na e tomu;
\q2 A itaia, emu gini-kau gabuna baina herevalaia,
\q2 bona oi ihadikamu davana baina heni.
\q1 Ena davara baina hakaukaua,
\q2 bona ena ranu lohilohi gabudia baina hakororo;
\q1 
\v 37 Babulono na e heḡiḡi dobi hanuana ai bainela,
\q2 uda sisiadia edia noho gabuna,
\q1 gari bona si-dagu ihavaradia ḡauna,
\q2 asi inoholaina tauna ta.
\q1 
\v 38 Idia na bae ḡou hebou, leona na heheto;
\q2 bae gigi, leona natudia na heheto.
\q1 
\v 39 Lalodia doini e garaḡaramu negana ai,
\q2 aria ta baina heḡaeḡaelaia adia;
\q1 baina hakekerodia ela bona bae mase rea,
\q2 bae mahuta hanaihanai, basie noga.
\q2 Iehova na e herevamu.
\q1 
\v 40 Iala-masedia totona baina hakaudia hekei, mamoe natudia na heheto,
\q2 mamoe mamaruanedia bona nani mamaruanedia na heheto.
\q1 
\v 41 Babulono madi vada e abia,
\q2 tanobada idoinai ese e imodaiamu ḡauna na vada e dadia.
\q1 Babulono madi, gari ihavarana ḡauna ai vada ela,
\q2 bese idau-idau bogaragidiai.
\q1 
\v 42 Davara ese Babulono vada e ha-utua dae;
\q2 ena hurehure badadia ese vada e habubunia.
\q1 
\v 43 Ena hanua badadia na gari ihavarana ḡaudia ai vada ela,
\q2 tano kaukauna, deḡedeḡena rahu tanona,
\q1 tau ta ese se noholaiamu tanona,
\q2 taunimanima natuna ta ese se rakaia hanaimu tanona.
\q1 
\v 44 Lau ese Bel davana baina henia Babulono\f + \fr 51:44 \ft Bel na Babulono taudia edia dirava ta.\f* ai;
\q2 vada e hadonoa ḡauna na uduna amo baina abia lasi.
\q1 Bese idau-idau basie aru henia lou;
\q2 Babulono maguna vada e heḡiḡi dobi.
\b
\q1 
\v 45 Egu bese taumui e, ia bogaragina amo a raka lasi!
\q2 Iboumui ai ta ta ena mauri ena mauri daladia ba tahu,
\q2 Iehova ena badu ḡaraḡara amo ba roho mauri.
\q1 
\v 46 Laḡani ta ai hari ta e maimu,
\q2 ma laḡani ta ai hari ta,
\q1 bona daḡedaḡe karadia na tano ai e karamu,
\q2 bona lohia ta lohia ta ida e heiri-heirimu,
\q1 negadia ai na kudoumui basie hetaha bona basio gari,
\q2 tano ai hari o kamonaimu dainai.
\b
\q1 
\v 47 Taunabunai, a itaia, negana na e maimu,
\q2 lau ese Babulono ena dirava laulaudia davadia do baina heni;
\q1 ena tano idoinai do bae hahemaraia,
\q2 bona ena mase taudia iboudiai na ia bogaraginai bae hehda diho.
\q1 
\v 48 Bena guba bona tanobada bona lalodia ḡaudia iboudiai ese
\q2 baḡo anedia bae abi, Babulono latanai;
\q2 badina be mirigini kahana amo
\q1 hahebua-tari taudia na baema, ia ihadikana.
\q2 Iehova na e herevamu.
\q1 
\v 49 Babulono na baine moru, Israel ena mase taudia daidiai,
\q2 tanobada idoinai ena mase taudia na Babulono dainai vada e hehda diho heḡereḡerena.
\b
\q1 
\v 50 Umui dare amo vada o roho mauri taumui e,
\q2 aola, basio gini kava!
\q1 Gabu daudau ai Iehova ba laloa tao,
\q2 Ierusalem na ba laloa une, baoto:
\q1 
\v 51 Ai na vada e hahemaraimai, badina be gwaugvvau herevadia vada a kamonai,
\q2 bona e dadaraimai dainai a igo dihomu;
\q1 badina be idau bese taudia na Iehova ena dubu ai,
\q2 ena gabu helagadia lalodiai vada e vareai.
\b
\q1 
\v 52 Iehova na e tomu:
\q2 Taunabunai, a itaia, negana be maimu,
\q1 lau ese ena dirava laulaudia baina hahemaoro henidia,
\q2 bona ena tano idoinai lalonai mai berodia taudia na bae ḡanaḡana.
\q1 
\v 53 Ena be Babulono bema dae guba ai,
\q2 ena be ena atai gabudia bema ha-aukadia,
\q1 to hahebua-tari taudia lauegu amo na ia latanai bae kau.
\q2 Iehova na e herevamu.
\b
\q1 
\v 54 A kamonai! Taitai ta Babulono amo;
\q2 hahebua-tari badana reḡena Kaldea taudia edia tano amo.
\q1 
\v 55 Badina be Iehova ese Babulono e havahuanu,
\q2 ia gadona bada-hereana e tuiamu.
\q1 Edia hurehure na e regemu, sinavai momo na heheto;
\q2 gurudia na e bada e laomu;
\q1 
\v 56 badina be hahebua-tari tauna na Babulono enai vada e kau,
\q2 ena luari taudia vada e abidia,
\q2 edia peva vada e hakwaidudia rohoroho;
\q1 badina be Iehova na dava-heni Diravana,
\q2 momokani ia ese dava baine heni.
\q1 
\v 57 Ena lohia taudia bona ena aonega taudia baina hakekerodia,
\q2 ena hekwara taudia, ena tuari lohiadia,
\q2 bona ena tuari taudia danu;
\q1 idia na bae mahuta hanaihanai, basie noga.
\q2 Pavapava badana, ladana Iehova Sabaota, na e herevamu.
\q1 
\v 58 Iehova Sabaota ini e gwau tomamu:
\q2 Babulono maḡuna, lababa-bada ḡauna, na tano ai baine helaha tari;
\q2 bona ikoukoudia, atai-herea ḡaudia, na lahi ai bae doudia.
\q1 Bese idau-idau edia hekwarahi na asi anina;
\q2 basileia idau-idau e ḡaukara lalo-dikamu, lahi mo ana.
\b
\p 
\v 59 Ina na peroveta tauna Ieremia ena hereva, ia ese Seraia, Neria Mahaseia natuna, e haḡanilaia ḡauna, Sedekia, Iuda pavapavana, ida Babulono ela negana ai, hari Sedekia ena lohia laḡanina ihahanina lalonai. Seraia na kohu ireḡuna tauna.
\v 60 Ieremia ese dika idoinai Babulono latanai baine kau herevadia na buka ta ai e tore.
\v 61 Bena Ieremia ese Seraia e hamaoroa, eto, Babulono ai ba kau negana ai, mi hereva iboudiai do ba duahidia;
\v 62 ma baoto, Iehova e, oi na vada o hereva, ina gabu ba negea daure, bena ḡau ta ia lalonai basine noho, taunimanima ta eiava ubu-ubu ḡauna ta; ia na baine vahu hanaihanai.
\v 63 Bena ina buka ba duahia vaitani murinai, nadi ta ai ba mataia kau, bena Eufrate sinavaina lalonai ba negea dobi.
\v 64 Bena baoto, Babulono na unu baine mutu toma, basine keni lou, dika na ia latanai ba hadihoamu dainai. Ieremia ena hereva dokona binai.
\c 52
\s1 Ierusalem e darere
\p 
\v 1 Sedekia e lohia matama negana ai, ena mauri laḡanidia na ruahui-ta; ena lohia laḡanidia Ierusalem ai na gwauta-ta. Sinana ladana na Hamutala, Ieremia, tau Libna, natuna.
\v 2 Ia na Iehova vairanai e kara havara, Iehoiakim ena kara iboudiai heḡereḡeredia ma e kara.
\v 3 Momokani, Iehova ena badu dainai Ierusalem bona Iuda edia dika na e bada e laova ela bona ia vairana amo e negedia daure.
\p Bena Sedekia ese Babulono pavapavana e gwau edeede henia.
\v 4 Ena lohia laḡanina ihataurahani-tana ai, hua ihagwautana dinana ihagwautana lalonai, Nebukadresara, Babulono pavapavana, na ena tuari oreana idoinai ida Ierusalem ihadikana ema, e koua hegeḡe bona tano e larebaia heḡeḡe.
\v 5 Taunabunai, hanua e koua heḡeḡe ela bona King Sedekia ena lohia laḡanina ihagwauta-tana.
\v 6 Bena hua ihahanina dinana ihataurahani-tana ai, hanua lalonai doe vada e bada herea, bona tano idoinai taunimanima na asi adia.
\v 7 Una negana ai, hanua maguna e hamaurua. Ena be Kaldea taudia na hanua vada e koua heḡeḡe, to tuari taudia iboudiai na hanuaboi ai e heau, magu ruaosi padadia ikoukouna amo, hanua pavapavana ena uma-uma badibadinai; bena Araba kahana ela.
\v 8 A Kaldea taudia edia tuari oreana ese hanua pavapavana na e gavaia, ela bona Ieriko taorana ai Sedekia e lasia tao; bena ena tuari oreana idoinai na iena amo e karoho rohoroho.
\v 9 Bena idia ese hanua pavapavana e abia mauri, Babulono pavapavana dekena e laohaia, Ribla ai, Hamat tanona ai. Ia ese e revaia.
\v 10 Bena Sedekia natuna mamaruanedia na ia vairanai e aladia mase; bona Iuda lohiadia iboudiai danu Ribla ai e aladia mase.
\v 11 Ia ese danu Sedekia matana e hakepuludia, auri gadeadia amo e ḡuia. Bena Babulono pavapavana ese Babulono e laohaia, unuseni ai dibura rumana ai e koua ela bona ena mase dinana.
\s1 luda e abia mauri
\p 
\v 12 Hua iha-imana dinana ihahituna ai (una na King Nebukadresara, Babulono pavapavana, ena lohia laḡanina ihagwauta-taurahani-tana ai), Nebusaradana, hegima oreana biaguna, Babulono pavapavana ena hesiai tauna ta, na Ierusalem ai e raka vareai.
\v 13 Bena ia ese Iehova ena dubu bona pavapava ena ruma bona Ierusalem rumadia iboudiai e doudia; ruma badadia iboudiai e doudia vaitani.
\v 14 Bena Kaldea tuari oreana taudia iboudiai, hegima oreana biaguna ida ema taudia, ese Ierusalem heḡeḡemadai maḡudia iboudiai e hahegigidia dobi.
\v 15 Bena ogoḡami dikadika taudia haida, bona hanua taudia kwabukwabudia dounu hanua ai e nohova, bona Babulono pavapavana enai e heau hanai taudia, bona ima karakara dibaka taudia oredia, na Nebusaradana, hegima oreana biaguna, ese e ḡuidia, bena dauha e laohaidia.
\v 16 A Nebusaradana, hegima oreana biaguna, ese ogoḡami dikadika taudia haida e rakatanidia, vine imeadia ireḡudia bona tano iruana taudia ai baela.
\p 
\v 17 Auri labora-labora au-tubuadia Iehova ena dubu ai, bona rerue bona auri labora-labora nauna badana Iehova ena dubu ai, na Kaldea taudia ese e hamakohidia, bena auri labora-laborana idoinai na e laohaia Babulono.
\v 18 Bona uro bona gaga bona lamepa ihaḡoevadia ḡaudia, bona nau, bona muramura mai bonadia urodia, bona auri labora-labora ḡaudia, kara helagadia ai e ḡaukaralaiva ḡaudia, na iboudiai e laohai;
\v 19 bona bia bona gida keberedia bona dihu bona uro, bona lamepa patadia, bona muramura mai bonadia urodia, bona udu-ahudia keheredia. \it Gold\it* ḡaudia bona \it silver\it* ḡaudia na hari hegima oreana biaguna ese e laohai.
\v 20 Hari au-tubua ruaosi, bona nau badana, bona boromakau mamaruanedia laulaudia gwauta-ruaosi, auri labora-labora amo e kara bona nau badana henunai e ato ḡaudia, bona rerue, hanua pavapavana Solomon ese e kara Iehova ena dubu ena, auri labora-labora idia lalodiai metauna na asi ihahetohona.
\v 21 Hari au-tubuadia ta ena lata na kiubit gwauta-taurahani; ena kuboro-heḡeḡe na kiubit gwauta-rua; kopina udunana na ima-kwakikwaki hani e haheboudia udunana heḡereḡerena; ia na auri kuborona lalona kohua.
\v 22 Ia latanai na kwarana ikorona, auri labora-labora ḡauna; hari kwarana ikorona ta ena lata na kiubit ima; bona reke-hetomana bona rimono huahuadia laulaudia, iboudiai na auri laboralabora amo e kara, na auri au-tubua kwarana ikorona ḡauna e gegelaia. Au-tubua iharuana danu unuheto, mai ena rimono huahuadia laulaudia.
\v 23 Rimono huahuadia laulaudia na taurahanita-ahui tauratoi ohena ohena ai; rimono huahuadia laulaudia reke-hetomana e geḡelaia iboudiai na sinahu-ta.
\p 
\v 24 Bena hari hegima oreana biaguna ese hahelaḡa tauna badana Seraia, bona hahelaḡa tauna iharuana Sefania, bona dubu iduarana inaridia taudia tatoiosi, e abidia.
\v 25 Hanua amo danu tuari oreana biaguna ta bona hanua pavapavana ena kaunsil taudia hahitu hanua lalonai e davaridia na e abidia; bona tuari biaguna ena toretore tauna, ena ḡaukara be tano taudia ihagaudia, bona tano taudia tauratoi-ahui hanua lalonai e davaridia danu,
\v 26 Nebusaradana, hegima oreana biaguna, ese e abidia, Babulono pavapavana dekena e laohaidia Ribla ai.
\v 27 Bena Babulono pavapavana ese e rahudia mamase, Ribla ai, Hamat tanona ai, e aladia mase. Taunabunai, Iuda taudia na e ḡuidia, edia tano amo e abidia oho, dauha e laohaidia.
\p 
\v 28 Nebukadresara ese iḡuidia ai e laohaidia taudia ihagaudia bini: laḡani ihahituna ai, Iuda taudia daha-toi ruahui-toi;
\v 29 Nebukadresara ena lohia laḡanina ihagwauta-taurahanina a ai, ia ese taunimanima sinahu-taurahani toi-ahui rua Ierusalem amo iḡuidia ai e laohaidia;
\v 30 bona Nebukadresara ena lohia laḡanina iharuahui-toina ai, Nebusaradana, hegima oreana biaguna, ese Iuda taudia sinahu-hitu hari-ahui ima na iḡuidia ai e laohaidia; e laohaidia taudia iboudiai na daha-hani sinahu-tauratoi.
\s1 Iehoiakini e ruhaia nege
\p 
\v 31 Iehoiakini, Iuda pavapavana, ena iḡui ai e nohova laḡanina ihatoiahuihituna ai, hua ihagwauta-ruana dinana iharuahui-imana ai, Evil-merodak, Babulono pavapavana, e lohia matama. Bena ena lohia laḡanina gini-gunana ai ia ese Iehoiakini, Iuda pavapavana, e hagagaia isi, dibura rumana amo e hakaua lasi;
\v 32 ia ese e hereva namo henia, bona helai ḡauna hereana e henia, pavapava iboudiai ia ida Babulono ai e nohova daediai.
\v 33 Taunabunai, Iehoiakini na ena dibura ruma dabuadia e doki oho. Una murinai ena mauri dinadia iboudiai lalodiai ia na hanua pavapavana ena pata ai e aniani hanaihanaiava;
\v 34 bona hanua pavapavana ese ahuna e henia, dina ta ta amo, ena mauri dinadia iboudiai lalodiai, ela bona ena mase dinana. mi dikadika taudia haida, bona hanua taudia kwabukwabudia dounu hanua ai e nohova, bona Babulono pavapavana enai e heau hanai taudia, bona ima karakara dibaka taudia o 
