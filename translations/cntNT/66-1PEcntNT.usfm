\id 1PE  
\h PRIMERA PEDRO 
\toc1 Si₂ carta le₂'uɨg₅₄ a₂ca₂jmo₃ SAN PEDRO 
\toc2 PRIMERA PEDRO 
\toc3 1 P. 
\mt2 Si₂ carta le₂'uɨg₅₄ a₂ca₂jmo₃ 
\mt1 SAN PEDRO 
\c 1  
\s1 Jmo₅ Pe₄ si₂ a₂chein₃ ne₄ dsa₂ 'én₂ i₂tián'₅ tsɨ₁rë₂jan₅₄ uɨ́ng₂ 
\p  
\v 1 Jniá₂ Pe₄, lɨ́ng₅ dsa₂ i₂chen₄ quián₅ Jesucristo jmo₂₃ si₂ la₂ tsɨ́ng₂ ne₄ ca₂le₃jɨ́n₃ dsa₂ i₂tsɨ₁rë₂jan₅₄ i₂ma₂lɨ́n₅ co₂'nió'₄ dsɨ₂nau₂ i₂tián'₅ uɨ́ng₂, le₂tan₅₄ 'uë₃ Ponto, quian'₅₄ Galacia, Capadocia, Asia, Bitinia në́₃,  
\v 2 ne₄ ca₂le₃jɨ́n₃ dsa₂ i₂ma₂quion'₅₄ quián₅ Diú₄ Jmei₂ jniog₄ lia'₂ con'₂ lë́₅ ma₂i₃jiog₅ dsɨ́₅ ca₂le₂jŋiá₅. Ca₂quió'₂ Diú₄ të₂le₃ quian'₅₄ ta₁ quió'₅ Jme₂dsí₂ quiáin₅ ia₁jaun₂ ma₂lë́₅ 'í₁ 'nia'₂, ia₁jaun₂ le₃chang'₂ jme₁ti'₄ ne₅₄, chan'₂ 'nia'₂ qui₂le₁jë́₃ jme₂dsí₂ quiáng'₂ në́₃, rë₂jŋióg'₄ le₁séng'₅ jmɨ₂ 'an₅₄ Jesucristo. Jaun₂ juá'₅ jniá₂, juɨ₁chan'₂ bá₄ 'nia'₂ dse₃ ne₄ ca₂le₃jë́₃ ne₅₄ a₂dse₃ jme₂gu'₅₄ Diú₄, 'ei₅ tei₄ ja₁con'₂ 'nia'₂ ca₂le₃jɨ́ng'₃. 
\s1 'A₂ lia'₂ chan₂ dsa₂ caun₂ bá₄ a₂le₁'ág₄ dsɨ́₅ a₂ma₂rë₂'én₄ dsáu₁, tɨ́in'₄ guei'₅₄ i₂juɨ́g₃ 
\p  
\v 3 Juɨ₁le₂juɨn'₂ bá₄ Diú₄ Jmei₂ Te₁gui'₅₄ Jesucristo quián₂, ia₁ ca₂dsia₃ ŋéi₂ dsɨ́₅ 'ŋio₅ lɨn₃ jniog₄, ca₂cuë₃ jme₂dsí₂ 'mɨ́₂, ma₂jmo₃ bá₄ a₂ma₂ca₂rë₃chóng₃ táng₃ jniog₄ të₂le₃ quian'₅₄ juɨ₅bí₂ a₂ca₂jen'₅₄ táng₃ Jesucristo jɨn₄ 'lag₄. 'Uɨg₅₄ në₅ bá₄ a₂chong₂ jniog₄ caun₂ bá₄ qui₂le₁'ág₄ dsɨ₅ a₂dsi₁no₃ tág'₄ guei'₅₄ i₂juɨ́g₃.  
\v 4 Ton'₂ jmo₃ a₂guéi'₁ 'nia'₂ a₂ma₂lë́₅ jág₁ a₂tɨng'₅₄ cuë₃ Diú₄, a₂lë́₅ caun₂ a₂tsá₃ ton₅ jmɨg₄ dsɨ₃'én₂, on₃ guë'₂ lé₂ le₃'lɨg'₅₄, on₃ guë'₂ ton₅ jmɨg₄ le₃juɨng₅ në́₃. Ca₂le₃jë́₃ a₂në₅ ma₂lë́₅ co₂jŋia₅₄ rë₂'ma₄ guei'₅₄ i₂juɨ́g₃ quián'₂ 'nia'₂.  
\v 5 Të₂le₃ ia₁ a₂'én'₂ 'nia'₂ ma₂jmo₂₃ 'í₁ quian'₅₄ juɨ₅bí₂ quió'₅ a₂dsi₁no'₃ 'nia'₂ tɨ́ng'₄ a₂le₃jniá₂ jmɨg₄ jë₁ca₂tó'₂ i₁lión'₂ 'nia'₂. 
\p  
\v 6 'Uɨg₅₄ në₅ bá₄ në́₃ juɨ₁chan'₂ 'nia'₂ qui₂le₁'ág₄ dse₃ 'au'₂, 'io'₂ jéng'₂, tsá₃ a₂léi₂ juɨ₁la₂ 'lióng₂ táu₂ a₂qui₂dsɨ₃ŋɨ́'₂ 'nia'₂ co₂'na₂.  
\v 7 Ia₁ lia'₂ lë́₅ cu₄nióg₄ bá₄ lë́₅ 'én'₂ 'nia'₂: jaun₂ tion₅₄ 'nió'₅ cáu₃, ŋag₅ si₂, jióg'₂ 'í₁ le₃léi₄ chi₂jua'₂ të₃dsón'₂ bá₄ dse₃. Juɨ₁lia'₂ jau'₂ 'í₁ cu₄nióg₄ të₂le₃ quian'₅₄ si₂, ján₃ bá₄ le₂në₅ jióg'₂ 'í₁ a₂'én'₂ 'nia'₂ të₂le₃ quian'₅₄ uɨg₅ a₂niog₅ qui₂dsɨ₂ŋɨ́g'₂. Ia₁ a₂'én'₂ 'nia'₂ në₅, quen₅ guë́₄ 'ŋio₅ lɨn₃ lia'₂ con'₂ guë́₄ cu₄nióg₄, ia₁ cu₄nióg₄ në́₃, a₂dsɨ₂'én₂ bá₄ jaun₂. Jaun₂ në́₃ jë₁ma₂ca₂o₃'ág₃ jág₁ a₂'én'₂ 'nia'₂ të₃dsón'₂, jaun₂ guë́₄ 'ag₃ Diú₄, 'én'₂ bá₄ 'nia'₂ dse₃ lɨn₃, ton'₂ qui₂jme₃go₃ bá₄ dsa₂, jaun₂ guéin'₂ bá₄ 'nia'₂ guei'₅₄ i₂juɨ́g₃ jë₁ma₂ca₂rë₃jniá₂ Jesucristo. 
\p  
\v 8 'Nió'₃ bá₄ 'nia'₂ Cristo juɨ₁la₂ tsá₃ ma₂ca₂të́₂ ne'₅₄ 'nia'₂. Caun₂ bá₄ qui₂le₁'ág₄ 'au'₂ 'nia'₂ le₃quió'₅ 'éi₂, jŋia'₅₄ la₂ tsá₃ ma₂ca₂jɨin'₅₄ 'nia'₂ dsón'₂ dsi₁ne₁ la₁ 'ŋio₅ lɨn₃ bá₄ 'io'₂ jén'₂ 'nia'₂ ca₂lia'₂ tsá₃ ne₄ 'a₂ lia'₂ le₃jua'₅₄,  
\v 9 ia₁ le₂në₅ bá₄ ma₂lɨn'₂ 'nia'₂ juɨ₅ ja₁ma₂lón₂ jme₂dsí₂ quiáng'₂; ia₁ ja₁jaun₂ dsi₁no'₃ dsón'₂ bá₄ 'nia'₂ lia'₂ con'₂ lë́₅ 'éng'₂. 
\p  
\v 10 Juɨ₁lia'₂ jág₁ a₂lió₂ Diú₄ në₅, lia'₂ con'₂ lë́₅ jme₁'ë́₂ dsa₂ quián₅ Diú₄ jág₁ ma₂lɨ́g'₂, ca₂juá'₂ të₃jŋiá₅ 'a₂ lia'₂ jmo₃ 'ua₁ dsɨ́₅ jme₃goin'₅₄ 'nia'₂, jaun₂ dsa₂ 'éi₂ në́₃ ca₂'náu'₃ jág₁ dsau₅ ca₂cáun₃ 'í₁ rë₂ lɨn₃,  
\v 11 'ein₂ dsón'₂ 'éi₂, o₃ 'e₂ 'ió'₄ a₂ŋág₃ uɨg₅, a₂le₃juɨin'₂ táng₃ cang₂ jaun₂. Ca₂jmo₃ bá₄ dsa₂ 'éi₂ në́₃ lia'₂ con'₂ lë́₅ ca₂'ë₃ Jme₂dsí₂ quián₅ Cristo juɨ₅ të₂dsɨ́₅.  
\v 12 Ca₂jme₃jnia₅ Diú₄ jág₁ a₂qui₂ca₂ŋɨ́'₂ dsɨ́₅ dsa₂ 'éi₂, la₁ on₃jua'₅₄ a₂dse₃ ja₁coin₂ guioin₅₄, a₂dse₃ të₂le₃ ja₁con'₂ 'nia'₂ bá₄ a₂ca₂jme₃ti₃ 'éi₂ lia'₂ con'₂ jme₁ca₂'ë́₂ jág₁, co₂rë₂ bá₄ lia'₂ con'₂ lë́₅ jág₁ a₂ma₂ca₂rë₃'ë́₂ ja₁con'₂ 'nia'₂ të₂le₃ quian'₅₄ Jme₂dsí₂ Jŋió₅ i₂chen₄ já₅ guei'₅₄ i₂juɨ́g₃. Ca₂le₂jiog₅ ángeles në́₃, jme₁'ɨ́n₅ dsɨ́₅ të₃ ne₅₄ ca₂le₃jë́₃ a₂në₅. 
\s1 Diú₄ ma₂ca₂të₃ jniog₄ a₂le₃chong₂ le₁jë́₃ jme₂dsí₂ quián₂ 
\p  
\v 13 Jaun₂, rë₂ján'₁ 'nia'₂ jmo₄, a₂le₃ŋɨ́'₂ dsei'₂ a₂le₃'en₅₄ 'au'₂ 'nia'₂. Caun₂ bá₄ le₁'ág₄ 'au'₂ 'nia'₂ jmo₄ a₂le₁jan'₄ a₂jme₃gu'₅₄ Diú₄ jmɨg₄ jë₁ma₂të́₂ rë₁jme₃jnia₅ Jesucristo.  
\v 14 La₁ juɨ₁len'₅₄ 'nia'₂ chi'₂-guein₂ dsen₃ quián₅ Diú₄ i₂qui₂rë₂ti'₅₄. Tsá₃ ma₃tián'₂ 'nia'₂ jua'₅₄ a₂qui₂dsɨ₂jŋia₅ guë́₄ 'lɨg'₅₄ 'au'₂, lia'₂ jme₁lɨ́ng'₄ le₂jŋiá₅ lia'₂ con'₂ tsá₃ 'e₂ jme₁ma₂ŋi'₅₄ 'nia'₂ le₃quió'₅ Diú₄.  
\v 15 Të₂le₃ juɨ₁le₂chan'₂ bá₄ 'nia'₂ qui₂le₁jë́₃ të₂'au'₂ qui₂rë₂jŋió₄ co₂ŋei'₅₄ jme₂dsí₂ quiáng'₂ quian'₅₄ ca₂le₃jë́₃ guë́₄ a₂jmo'₂ 'nia'₂. Ia₁ i₂jŋió₅ lɨn₃ bá₄ Diú₄ i₂ma₂ca₂të₃ 'nia'₂.  
\v 16 Ia₁ juá'₂ ne₄ Si₂: “Juɨ₁le₂jŋió'₄ bá₄ 'nia'₂, ia₁ i₂jŋió₅ bá₄ jniá₂ 'ŋió₃.”\f + \fr 1:16 \ft Levítico 11:14,45; 19:2; 20:7.\f* 
\p  
\v 17 Chi₂jua'₂ të'₂ 'nia'₂ “Tia₅₄” i₂qui₂con₂ 'í₁ quió'₅ le₂jan₂ le₂jan₂ dsa₂ lia'₂ con'₂ lë́₅ ma₂jmo₃, la₁ tsá₃ jma₃quén₅ jɨ́in₂ ca₂le₃jɨ́n₃, jaun₂ ca₂tɨ́n'₂ 'nia'₂ jme₁gain'₃ ca₂le₃jë́₃ jmɨg₄ të₁lia'₂ chan'₂ 'nia'₂ lɨ́ng'₅ në₂jag₄ bá₄ dsɨ₂nau₂ ne₄ gua'₅₄ 'uë₃ la₂.  
\v 18 Ia₁ ma₂ŋi'₅₄ bá₄ 'nia'₂, on₃jua'₅₄ a₂ca₂quɨin₃ quian'₅₄ cosa a₂tsá₃ uë́₂ jiog₅, quian'₅₄ juɨ₁lia'₂ cu₄nióg₄ cu₄tiog₂ a₂ca₂lióin₂ 'nia'₂ ne₄ juɨ₅ a₂tsá₃ ta₁ tí₄ a₂jme₁le₁quian'₄ 'nia'₂, a₂ca₂rë₂tɨ́ng'₃ ca₂ŋág₃ dsa₂ can'₅₄ quiáng'₂.  
\v 19 Ca₂quɨ́n'₂ 'nia'₂ të₂le₃ quian'₅₄ jmɨ₂ 'an₅₄ Cristo a₂quen₅ guë́₄ lɨn₃, a₂ca₂ŋó₃ qui₂rë₂jein'₅₄ ne₄ Diú₄ në₂jag₄ bá₄ já'₂ cha'₂ i₂tsá₃ 'e₂ 'lɨg'₅₄ lɨ́n₅ 'i₁caun₂.  
\v 20 Ia₁ lia'₂ con'₂ né'₃ a₂nio₃ mɨ₂güɨ́g₃, jme₁ma₂rë₂'ɨ́in₁ bá₄ a₂lióin₂ dsa₂ mɨ₂güɨ́g₃. Ia₁ ma₂ca₂rë₃jniái₂ jmɨg₄ jë₁ca₂tó'₂ rë₂në́₃, a₂dse₃ o₄quián'₂ 'nia'₂.  
\v 21 Ia₁ të₂le₃ quian'₅₄ 'éi₂ bá₄ 'én'₂ 'nia'₂ le₃quió'₅ Diú₄ i₂ca₂jme₃jen'₅₄ Cristo ja₁jme₁rë₂'lɨin₅₄, jaun₂ ca₂jme₃jláu'₁ në́₃. 'Uɨg₅₄ jaun₂, juɨ₁le₁'ág₄ 'au'₂ 'nia'₂ 'éng'₂ të₂le₃ quió'₅ Diú₄. 
\p  
\v 22 Në₃ në́₃ ma₂le₁jɨ́n'₃ bá₄ 'nia'₂ ia₁ ma₂jme₂tí'₁ 'nia'₂ jág₁ tí₅, ia₁ të₃dsón'₂ bá₄ ma₂'nió'₃ 'nia'₂ rɨ́ng'₂, jme₁'nió₄ 'nia'₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂ jaun₂ në́₃ ca₂le₃jë́₃ 'au'₂.\f + \fr 1:22 \ft A₂lɨn₅₄ chog₅₄ si₂: “a₂le₁jë́₃ 'au'₂.” \f* 
\v 23 Ia₁ ma₂ca₂rë₃chán'₃ 'nia'₂ táng₃, la₁ on₃jua'₅₄ lia'₂ lë́₅ rë₃chan₂ jaun₅ dsa₂ i₂dsan₂. A₂ca₂lɨng'₃ jaun₅ Diú₄ bá₄ i₂tsá₃ lɨ́g'₂ jmɨg₄ dsián₃. Ca₂rë₃cháng'₃ të₂le₃ quian'₅₄ jág₁ jén'₃ quió'₅ Diú₄ bá₄ a₂jiog₅ co₂tan₅₄.  
\v 24 Ia₁ ne₄ Si₂ juá'₂: 
\q1 Ca₂le₃jɨ́n₃ dsa₂ mɨ₂güɨ́g₃ 
\q2 lɨ́in₅ juɨ₁lia'₂ lë́₅ nɨ₁nau₂, 
\q1 ca₂le₃jë́₃ 'a₂ lia'₂ jláin'₁ 
\q2 lë́₅ lia'₂ lë́₅ lí₁ jlá'₁ quió'₅ nɨ₁nau₂. 
\q1 Jë₁ma₂ca₂rë₃quéin₃ nɨ₁nau₂, 
\q2 ca₂tá'₂ bá₄ lí₁ ján₃. 
\q1  
\v 25 La₁ jág₁ quió'₅ Te₁gui'₅₄ jiog₅ co₂tan₅₄ bá₄.\f + \fr 1:25 \ft Isaías 40:6-8.\f* 
\p Jaun₂ jág₁ dse₃ a₂lión₂ dsa₂ në₅ ma₂ca₂rë₃'ë́₂ jɨn'₄ 'nia'₂. 
\c 2  
\p  
\v 1 Jaun₂ në́₃, co₂dsia₅ tí₃ 'nia'₂ ca₂le₃jë́₃ ne₅₄ a₂'lɨg'₅₄, quian'₅₄ 'a₂ lia'₂ lë́₅ jme₁chan'₂ 'nia'₂ jmo'₂ o₁ne'₄, o₁gang'₂, jme₁chan'₂ 'nia'₂ jmo'₂ uɨg₅ 'au'₂, ca₂le₃jë́₃ guë́₄ a₂lë₁chi₂dsia'₂ 'nia'₂ 'ɨ́ng'₅ rɨ́ng'₂.  
\v 2 Jmo₄ 'nia'₂ në₂jag₄ bá₄ guein₂ pí'₁ i₂'ɨ́n₅ dsɨ́₅ 'ɨ́n'₂ dsi'₅₄ jmá'₅ a₂gu₂dsí₂, jaun₂ të₂le₃ quian'₅₄ a₂jaun₂ qui₂dsɨ₃can'₅₄ 'nia'₂ ca₂lia'₂ ca₂'ŋia₅ i₁lión'₂ 'nia'₂,  
\v 3 chi₂jua'₂ të₃dsón'₂ bá₄ ma₂ca₂rë₃len'₄ 'nia'₂ jmá₂ a₂dse₃ dsɨ́₅ Te₁gui'₅₄.\f + \fr 2:3 \ft Salmo 34:8.\f* 
\s1 Cristo bá₄ i₂lɨ́n₅ nɨ₁'lau₂ jén'₃ 
\p  
\v 4 Jme₁quián₄ 'nia'₂ ja₁con₂ Te₁gui'₅₄ i₂lɨ́n₅ nɨ₁cang₁ jén'₃. Dsa₂ mɨ₂güɨ́g₃ në́₃ tsá₃ ca₂rë₃jei₅₄, la₁ të₂le₃ quió'₅ Diú₄ në́₃ lë́₅ nɨ₁cang₁ rë₂quio'₅₄ a₂jlá'₁ a₂quen₅ guë́₄ lɨn₃.  
\v 5 Le₂në₅ bá₄ 'nia'₂ ján₃, jmo₄ 'nia'₂ 'au'₂ a₂lɨ́ng'₅ co₂'nió'₄ nɨ₁cang₁ jén'₃ a₂jmó'₂ Diú₄ ta₁ a₂juɨ₂₃ jmóg'₅ caun₂ 'né₅ a₂gu₂dsí₂, ia₁jaun₂ dsi₁nó'₅ 'nia'₂ léng'₂ co₂'nió'₄ jme₂dsa₂ i₂lë́₅ 'í₁ quiáin₅ i₂qui₂jén'₅ 'e₂ qui₂jén'₅ ne₄ Diú₄ a₂gu₂dsí₂ a₂lë́₅ a₂'ŋio₂ dsɨ́₅ 'éi₂ gue₂₃ të₂le₃ quian'₅₄ Jesucristo.  
\v 6 Ia₁ ne₄ Si₂ juá'₂ ján₃: 
\q1 la₂ dsián₄ jniá₂ ciudad Sión i₂lɨ́n₅ nɨ₁cang₁ 
\q2 quió'₅ qui'₅₄ 'uɨg₅₄ 'ia'₂. 
\q1 Ca₂le₃jɨ́n₃ i₂'én₂ le₃quió'₅, 
\q2 o₁lɨ́g'₂ tsá₃ 'ag₃ caun₂-tɨn₃ dsɨ́₅.\f + \fr 2:6 \ft Isaías 28:16.\f* 
\p  
\v 7 Të₂le₃ quián'₂ 'nia'₂ i₂'éng'₂, nɨ₁'lau₂ jaun₂ lë́₅ a₂quen₅ 'ŋio₅ lɨn₃. La₁ të₂le₃ quió'₅ i₂tsá₃ 'én₂ në́₃, rë₂ti₃ juɨ₁lia'₂ juá'₂ ne₄ Si₂: 
\q1 Nɨ₁cang₁ a₂tsá₃ ca₂rë₃ji'₅₄ dsa₂ i₂jme₁jmóg'₅ 'né₅, 
\q2 ca₂lë₃ nɨ₁cang₁ a₂dsen₅₄ guë́₄ quió'₅ qui'₅₄ 'ia'₂.\f + \fr 2:7 \ft Salmo 118:22.\f* 
\m  
\v 8 Rë₂ti₃ ján₃ ja₁juá'₂ ne₄ Si₂: 
\q1 nɨ₁cang₁ a₂qui₂nió₅ dsa₂, 
\q1 nɨ₁'lau₂ a₂jmo₅ a₂dsɨ₂gan'₅₄ dsa₂.\f + \fr 2:8 \ft Isaías 8:14.\f* 
\m 'Uɨg₅₄ ia₁ a₂tsá₃ 'nio₃ jme₃ti₃ jág₁ dse₃, qui₂niói₅ juɨ₁lia'₂ ma₂'i₄ 'éi'₃ dsɨ₃ŋɨ́i₂. 
\s1 Dsa₂ i₂tén₅ le₃quió'₅ Diú₄ 
\p  
\v 9 Ma₂lɨ́n'₅ bá₄ 'nia'₂ në́₃, jon₂ dsa₂ i₂rë₂quion'₅₄ quián₅ Diú₄. Lɨ́ng'₅ co₂nió'₃ jme₂dsa₂ i₂jme₂ti₃ ta₁ ne₄ Rag₅₄, caun₂ juɨg₂ jŋió₅, dsa₂ juɨg₂ quián₅ Diú₄ 'ŋiog₅. Ca₂le₃jë́₃ a₂në₅ lɨ́n'₅ 'nia'₂, ia₁jaun₂ qui₂jme₁jnia'₅ 'nia'₂, ca₂le₃jë́₃ a₂jlá'₁ a₂ma₂jmo₃ Diú₄. Ia₁ 'éi₂ bá₄ ma₂ca₂'uíin'₂ 'nia'₂ jë₄ qui₁né'₃, ca₂tág₃ të₂le₃ ja₁jniá₂ si₂ jlá'₁ quió'₅.  
\v 10 Le₂jŋiá₅ në́₃, tsá₃ dsa₂ juɨg₂ jme₁lɨ́n'₄ 'nia'₂; la₁ rë₂në́₃ në́₃ ma₂ca₂dsi₃nó'₅ 'nia'₂ ma₂lɨ́ng'₅ dsa₂ juɨg₂ quián₅ Diú₄. Ca₂le₂jŋiá₅, 'i₁jan₂ tsá₃ 'ein₂ jme₁ŋéi₂ dsɨ́₅ 'nia'₂; la₁ rë₂në́₃, Diú₄ ma₂ca₂tá'₂ ŋéi₂ dsɨ́₅. 
\s1 Tián'₂ 'nia'₂ a₂jme₁ti'₄ ne₄ Diú₄ 
\p  
\v 11 'Nia'₂ rɨn'₅₄ jniog₄ i₂'nióg₃, 'nia'₂ i₂tiáng'₅ uɨ́ng₂ i₂ma₂lɨ́ng'₅ në₂jag₄ bá₄ dsɨ₂nau₂, chi₂len'₄ jniá₂ 'nia'₂ co₂dsia₅ tí₃ 'nia'₂ ca₂le₃jë́₃ a₂'lɨg'₅₄ a₂'ɨ́n₅ dsɨ́₅ nɨ₁ŋɨ'₁ a₂jmo₅ 'nei₂ ja₁con₂ jme₂dsí₂ quián'₂ 'nia'₂.  
\v 12 I₂nio₄ bá₄ 'nia'₂ con'₂ dsi₂ten₅₄ jɨn₄ dsɨ₂nau₂ juɨg₂ ja₁tiáng'₄, ia₁jaun₂ juɨ₁la₂ 'ag₂₃ 'ɨin₂₃ 'nia'₂ 'lɨg'₅₄ a₂jág₂ jɨ́in₂ 'nia'₂ në₂jag₄ bá₄ dsa₂ i₂le₁cán'₄ dso₄, la₁ jë₁ma₂ca₂të́₂ ne₅₄ a₂dse₃ jmo'₂ 'nia'₂, jme₃juɨin'₂ bá₄ Diú₄ jë₁ma₂të́₂ rë₁të₃dsɨ₅₄ 'éi'₃. 
\p  
\v 13 Ia₁ a₂gan'₃ 'nia'₂ Te₁gui'₅₄, tión'₂ 'nia'₂ ca₂le₃jë́₃ 'éi'₃ quí'₅ juɨ₁'ein₂ guë́₃ dsɨ₂tan₅₄ i₂dsián₁ quián₅ dsa₂ ne₄ gua'₅₄ 'uë₃ la₂; tión'₂ 'nia'₂ 'éi'₃ quí'₅ juɨ₁lia'₂ gui'₅₄ dsɨ₂tan₅₄ emperador  
\v 14 lia'₂ 'éi'₃ quió'₅ i₂lɨ́n₅ dsi₄má'₂ i₂dsián₁ quiáin₅, a₂cuë́'₃ uɨg₅ dsa₂ i₂jmo₅ 'lɨg'₅₄, la₁ dse₃ 'ɨin₃ dsa₂ i₂jmo₅ a₂dse₃.  
\v 15 Ia₁ a₂në₅ bá₄ a₂'nio₃ Diú₄: a₂jmó'₂ 'nia'₂ ca₂ne₅₄ a₂dse₃, ia₁jaun₂ dsɨ₃lén₂ tei₄ dsa₂ co₄ i₂'ɨn₅ 'lɨg'₅₄ 'nia'₂ ia₁ a₂tsá₃ ŋi₅. 
\p  
\v 16 I₂nio'₄ bá₄ 'nia'₂ jaun₂, lia'₂ jë₁i₂nio₄ dsa₂ i₂ma₂ca₂lón₂ i₂ma₂ca₂niá₃ juɨ₅ quió'₅, la₁ tsá₃ o₁leng'₅₄ jua'₅₄ a₂ma₂rë₂na₄ juɨ₅ ia₁jaun₂ 'náu'₁ dso₄. Juɨ₁le₂chan'₂ 'nia'₂ a₂lɨ́ng'₅ dsa₂ i₂jme₂ti₃ ta₁ ne₄ Diú₄.  
\v 17 Jme₁gan₃ 'nia'₂ ca₂le₃jɨ́n₃ dsa₂; jme₁'nió₄ 'nia'₂ rɨ́ng'₂ në́₃. Jme₁gan₃ 'nia'₂ Diú₄, ton'₂ jme₁gan₃ 'nia'₂ dsɨ₂tan₅₄ dsa₂ juɨn'₂.\f + \fr 2:17 \ft lit. “jme₁gan₃ 'nia'₂ rag₅₄.” \f* 
\s1 Caun₂ jág₁ dsau₅ 'a₂ lia'₂ lë́₅ jmɨ₁uɨg₅ a₂ca₂i₃ŋɨ́₂ Cristo 
\p  
\v 18 'Nia'₂ guë'₂ dsa₂ i₂jme₂ti₃ ta₁ ne₄ dsa₂, tión'₂ 'nia'₂ 'ei₅ gau₂ ca₂le₃jë́₃ 'e₂ te₂néi'₂ juɨg'₂ 'nia'₂. Ca₂tɨ́n'₂ 'nia'₂ jme₁ti'₄, on₃jua'₅₄ jmá'₃ ne₄ dsa₂ dsen₃ i₂juɨn'₂ dsɨ́₅; ca₂tɨ́n'₂ bá₄ 'nia'₂ jme₁ti'₄ le₂jiog₅ ne₄ dsa₂ i₂tsau₂ dsɨ́₅ në́₃.  
\v 19 Ia₁ ja₂lɨn₃ guë́₄ dse₃ të₂tsɨn'₅₄ dsa₂ ne₄ Diú₄ jme₁jmo₂₃ tió'₃ dsɨ́₅ ŋág₅ uɨg₅ on₃jua'₅₄ a₂cha₂ rɨin₂, ne₄ ia₁ a₂lí'₄ dsɨ́₅ a₂'ŋio₂ dsɨ́₅ Diú₄ bá₄.  
\v 20 Ia₁ në₁jua'₂ jmo'₂ 'nia'₂ tió'₃ 'au'₂ jme₁qui₂dsɨ₂bang'₅₄ ne₄ 'uɨg₅₄ dsáu'₂ 'nia'₂ guiong'₅₄, ¿'e₂ a₂dse₃ a₂lé₂ le₃guéi'₁ 'nia'₂ në₁jua'₂ le₂jaun₂? La₁ në₁jua'₂ ŋag'₅₄ 'nia'₂ uɨg₅ ne₄ 'uɨg₅₄ a₂dse₃ a₂jmo'₂, ton'₂ jmo'₂ 'nia'₂ tió'₃ 'au'₂, ia₁ le₂në₅ bá₄ dsióg₄ të₃tsɨn'₅₄ 'nia'₂ dse₃ ne₄ Diú₄.  
\v 21 Ia₁ ta₁ jaun₂ ma₂ca₂rë₃të́₄ 'nia'₂, ia₁ ján₃ bá₄ ca₂ŋág₃ Cristo uɨg₅ o₄quián'₂ 'nia'₂, a₂ca₂quiog₂ caun₂ juɨ₅ ia₁jaun₂ le₂në₅ i₁nio'₄ 'nia'₂ juɨ₁lia'₂ ca₂ŋɨ₃ 'ŋiog₅. 
\q1  
\v 22 'I₁caun₂ dso₄ tsá₃ 'e₂ ca₂'náu₂, 
\q2 on₃ guë'₂ 'i₁ca₂mɨ́g₂ jág₁ a₂juɨ₁gain₂ ca₂o₃'ág₃ mɨ₂'o₅₄;\f + \fr 2:22 \ft Isaías 53:9.\f* 
\m  
\v 23 jme₁qui₂ca₂jnáu'₂ dsa₂ jág₁ uɨg₅, tsá₃ le₂jaun₂ ca₂jéin₃ jág₁ jua'₅₄ a₂ca₂quiain₃ dsa₂ juë́'₅. Të₂le₃ caun₂ bá₄ ca₂'ág₂ dsɨ́₅ ca₂dsiain₃ o₄gú₃ i₂qui₃dsɨ₅ 'éi'₃ lia'₂ tí₅.  
\v 24 Le₂në₅ bá₄ ca₂cáun₃ Cristo juɨ₅ nɨ₁ŋɨ₁₂ 'ŋiog₅ dsáu₁ jniog₄ jme₁ca₂ŋó₃ ne₄ cróg₄ ia₁jaun₂ dsióg₃ jniog₄ ne₄ dso₄, a₂le₃chong₂ táng₃, quián₁ caun₂ juɨ₅ co₂dsau₅; ne₄ a₂qui₂ca₂cuɨ́n'₂ Cristo ca₂'lón'₂ bá₄ 'nia'₂.  
\v 25 Ia₁ le₂jŋiá₅ jme₁i₂nio'₄ 'nia'₂ lia'₂ ja₁i₂nio₄ já'₂ cha'₂ i₂ma₂i₂cón'₅,\f + \fr 2:25 \ft 'Nio'₂ ja₁ton₅ Isaías 53:5,6.\f* la₁ rë₂në́₃ ma₂ca₂jén'₃ bá₄ táng₃ 'nia'₂ le₃quió'₅ Cristo. 'Éi₂ bá₄ i₂jiog₅, niog₅ gu₂, jmo₅ 'í₁\f + \fr 2:25 \ft griego: epískopos.\f* jme₂dsí₂ quián'₂ 'nia'₂. 
\c 3  
\s1 'A₂ lia'₂ dsi₂ten₅₄ le₃chan₂ dsa₂ i₂le₁jen'₂ gu₂ 
\p  
\v 1 Le₂në₅ bá₄ ján₃, 'nia'₂ dsa₂ mɨ́₂ i₂le₁jen'₂ gu₂, tión'₂ 'nia'₂ 'éi'₃ quió'₅ dsɨ₂i₂gog'₂, ia₁jaun₂ në₁jua'₂ chan₂ i₂tsá₃ 'én₂, lé₂ le₃join'₅₄ ia₁jaun₂ le₃'éin₂ ján₃, on₃jua'₅₄ a₂'nió'₅ juɨg'₅₄ 'nia'₂ jág₁ 'lióng₂, të₂le₃ quian'₅₄ juɨ₅ 'a₂ lia'₂ lë́₅ i₂nio'₄ bá₄ 'nia'₂,  
\v 2 ia₁ të₃ ne₅₄ a₂ma₂lɨ́n'₂ 'nia'₂ dsa₂ i₂le₁jë́₃ dsɨ́₅, i₂ŋi₅ 'a₂ lia'₂ jme₃go₃.  
\v 3 Tsá₃ juɨ₁le₅₄ jua'₅₄ a₂jŋia'₅₄ tión'₂ 'nia'₂ jlá'₁ jmá'₃ lia'₂ le₃co'₅₄, quian'₅₄ juɨ₁lia'₂ a₂ŋɨ́₄ jlá'₁ qui₂rë₂lag₄ dsei'₂, o₃ a₂qui₂le₁lɨn'₄ 'nia'₂ juɨ₁lia'₂ quian'₅₄ mɨ́g₂ cu₄nióg₄, tsɨ́n'₂ jlá'₁ në́₃.  
\v 4 Qui₁jmo'₅₄ bá₄ 'nia'₂ jláng'₁ të₂le₃ quian'₅₄ a₂rë₃'ma₄ të₂'au'₂ 'nia'₂, a₂rë₂lag₄ quian'₅₄ caun₂ jme₂dsí₂ a₂jmo'₂ 'nia'₂ meg'₂. A₂rë₃lɨn₄ dsa₂ le₂në₅ bá₄ lë́₅ caun₂ a₂jlá'₁ a₂tsá₃ lɨ́g'₂ jmɨg₄ dsɨ₃'én₂, ton'₂ quen₅ 'ŋio₅ lɨn₃ të₂le₃ ja₁con₂ Diú₄.  
\v 5 Ia₁ le₂në₅ bá₄ jme₁qui₂le₁lɨn₄ dsa₂ mɨ́₂ i₂jme₁lë́₄ 'í₁ quián₅ Diú₄ ma₂lɨ́g'₂: jme₁i₂nioi₅₄ caun₂ bá₄ jme₁le₁'ág₄ dsɨ́₅ le₃quió'₅ Diú₄, ton'₂ tioin'₅₄ 'éi'₃ quió'₅ dsɨ₂i₂gu₂.  
\v 6 Ján₃ bá₄ le₂në₅ jme₁lɨ́n₄ Sara, ca₂nág₂ gau₂ jág₁ quió'₅ Abraham, jaun₂ ca₂të₃ “Gui'₅₄ quiáng₃”. Le₂në₅ bá₄ dsi₁nó'₅ 'nia'₂ léng'₂ juɨ₁lia'₂ jme₁lɨ́n₄ 'éi₂, në₂jag₄ bá₄ chi'₂ quiáin₅ bá₄ ján₃, në₁jua'₂ ca₂jmo'₅₄ con'₂ dsi₂ten₅₄, tsá₃ ma₃'e₂ gau₂ jiá₃ 'au'₂ 'nia'₂. 
\p  
\v 7 Le₂në₅ bá₄ ján₃, 'nia'₂ dsa₂ ŋe'₂, jmo₄ 'nia'₂ 'en₅₄ 'au'₂ 'a₂ lia'₂ tiáng'₄ quian'₅₄ dsa₂ mɨ́₂ quiáng'₂, juɨ₁ŋei₂ bá₄ a₂ca₂tɨ́in₂ jme₁gain'₃ 'nia'₂, ia₁ lɨ́in₅ i₂'uan₅₄ guë́₄ lia'₂ con'₂ guë́₄ guiong'₅₄, lɨ́in₅ co₂'nió'₄ caun₂ nɨ₁vaso a₂go'₂ guë́₄; ia₁ co₂rë₂ bá₄ lɨ́n'₅ 'nia'₂ dsa₂ i₂rë₂gon'₅₄ i₂ca₂tɨ́n₂ le₃chan₂ dse₃. Le₂në₅ jmo₄ 'nia'₂ ia₁jaun₂ 'i₁caun₂ tsá₃ 'e₂ jnág₅ cha₂ jë₁ma₂të́₂ rë₁chi₁len'₄ 'nia'₂ Diú₄. 
\s1 Dsa₂ i₂ŋág₅ uɨg₅ ne₄ ia₁ a₂jmo₂₃ a₂dse₃ 
\p  
\v 8 Jë₁ca₂tó'₂ rɨn'₅₄ jniog₄, juɨ₁chan'₂ bá₄ 'nia'₂ ca₂le₃jɨ́ng'₃ 'ei₅ caun₂ jág₁, jeng'₂ quian'₅₄ rɨ́ng'₂; 'ua₁ 'au'₂ 'nia'₂ jmo₄; jme₁'nió₄ 'nia'₂ rɨ́ng'₂; juɨ₁chan'₂ 'nia'₂ ŋéi₂ 'au'₂; jmo₄ 'nia'₂ meg'₂ në́₃.  
\v 9 Tsá₃ lë₁jein'₅₄ 'nia'₂ 'lɨg'₅₄ quian'₅₄ a₂'lɨg'₅₄; tsá₃ të₁'óng'₁ dsa₂ i₂të₂'o'₂. Të₂le₃ jein'₅₄ jág₁ dse₃ a₂jme₃gu'₅₄ Diú₄ quió'₅ dsa₂ le₂'éi₂. Ia₁ ta₁ në₅ bá₄ a₂'nio₃ Diú₄ jmó'₂ 'nia'₂ a₂ma₂ca₂të₃, ia₁jaun₂ bá₄ tɨn'₃ 'nia'₂ jme₃gu'₅₄ Diú₄.  
\v 10 Ia₁: 
\q1 Ca₂le₃jɨ́n₃ dsa₂ i₂'nio₃ le₃chan₂ dse₃ 
\q2 ca₂tɨ́in₂ jmo₃ 'í₁ le₁tsɨ'₂ 
\q1 jaun₂ tsá₃ 'ŋiái₃ jág₁ 'lɨg'₅₄, 
\q2 on₃ guë'₂ 'nió'₅ 'uë́'₃ jág₁ të₂jág₁ mɨ₂'o₅₄. 
\q1  
\v 11 Co₂dsia₅ 'nió'₅ quiá'₂ dsa₂ cau₅ 
\q2 juɨ₁lia'₂ juɨ₅ 'lɨg'₅₄, jmo₃ ca₂ne₅₄ a₂dse₃; 
\q1 'nió'₅ 'no'₂ dsa₂ juɨ₅ ja₁'ei₅ tei₄, 
\q2 jaun₂ juɨ₅ jaun₂ 'en₃. 
\q1  
\v 12 Ia₁ jme₁ne₁ Te₁gui'₅₄ tsá₃ 'na₂ jɨ́in₂ dsa₂ dsen₃, 
\q2 ton'₂ rë₂jáin₁ nag₂₃ 'e₂ chi₂léi'₂ dsa₂ quiáin₅, 
\q1 la₁ të₂le₃ quió'₅ i₂jmo₅ a₂'lɨg'₅₄, 
\q2 le₂cau₅ bá₄ jéin'₅ ne₅₄.\f + \fr 3:12 \ft Salmo 34:12-16.\f* 
\p  
\v 13 ¿I₂'ein₂ bá₄ lé₂ le₃jmóg'₂ në₁jua'₂ dsen₅₄ 'au'₂ 'nia'₂ ca₂jmo'₅₄ a₂dse₃?  
\v 14 La₁ juɨ₁'a₂ guë́₃ la₂ ŋag'₅₄ 'nia'₂ uɨg₅ ne₄ ia₁ a₂jmo'₂ 'nia'₂ a₂dse₃, la₁ia₁ 'e₂ guë́₄ dsen'₃ 'nia'₂ chang'₂ jua'₅₄ le₂jaun₂. Tsá₃ jmo₂ 'nia'₂ gang'₃ 'e₂ a₂gó'₅ dsa₂ 'éi₂ chain₂, on₃ guë'₂ cán'₁ 'nia'₂ juë́'₅.\f + \fr 3:14 \ft Isaías 8:12.\f* 
\v 15 Të₂le₃ jmo₄ bá₄ 'nia'₂ 'au'₂ a₂lɨ́n₅ Cristo juɨg'₂ 'nia'₂ i₂jŋió₅, a₂lë́₅ 'í₁ të₂'au'₂ 'nia'₂. Chan'₂ 'nia'₂ rë₂jáng'₁, a₂jein'₅₄ jág₁ quió'₅ dsa₂ i₂'nio₃ le₃ŋi₅ 'a₂ lia'₂ lë́₅ a₂'ɨ́n₂ 'au'₂ 'nia'₂. Jŋia'₅₄ lia'₂ jmo₄ a₂në₅ jmá'₃ lia'₂ quian'₅₄ a₂'ua₁ 'au'₂, a₂jme₁gan'₃ 'nia'₂ dsa₂ në́₃, a₂qui₂le₁jë́₃ a₂qui₂dsɨ₂jŋi₅ 'au'₂,  
\v 16 ia₁jaun₂ le₃gui'₅₄ dsa₂ i₂chi₂'ag₅ 'lɨg'₅₄ o₄quió'₄ juɨ₅ dse₃ a₂i₂nio'₄ 'nia'₂ le₃quió'₅ Cristo.  
\v 17 Në₁jua'₂ le₂jaun₂ 'nio₃ Diú₄, ja₂lɨn₃ guë́₄ dse₃ a₂ŋág₅ dsa₂ uɨg₅ ne₄ ia₁ a₂jmo₂₃ a₂dse₃, lia'₂ con'₂ guë́₄ ne₄ a₂jmo₂₃ a₂'lɨg'₅₄. 
\p  
\v 18 Ia₁ le₂në₅ bá₄ ján₃, co₂ráun₂ bá₄ ca₂jon₃ Cristo\f + \fr 3:18 \ft A₂lɨn₅₄ chog₅₄ si₂: “ca₂ŋág₃ Cristo uɨg₅.” \f* jme₁ca₂join₃ ne₄ 'uɨg₅₄ dsáu₁ jniog₄. I₂jme₁lɨ́n₄ jan₂ dsa₂ dsen₃ co₂ŋɨ́₂ bá₄ 'éi₂, ca₂join₃ o₄quió'₄ dsa₂ cha₂ dsáu₁, ia₁jaun₂ të₂ ja₁con₂ Diú₄. Ca₂join₃ juɨ₅ nɨ₁ŋɨ₁₂, ton'₂ ca₂jein'₅₄ bá₄ táng₃ të₂le₃ quian'₅₄ Jme₂dsí₂.  
\v 19 Jaun₂ le₂në₅, ca₂ŋei₅₄ ca₂i₁'ë́₄ jág₁ ja₁con₂ jme₂dsí₂ i₂jme₁tion'₅₄ le₁jnɨ́₅  
\v 20 i₂tsá₃ ca₂nág₂ gau₂ jmɨg₄ ma₂lɨ́g'₂ jaun₂ lia'₂ con'₂ jme₁chan₂ Noé. Uë́₂ bá₄ ca₂jmo₃ Diú₄ juɨn'₂ dsɨ́₅ ca₂jŋia₃ të₁lia'₂ lë́₂ nɨ₁barco.\f + \fr 3:20 \ft Noé: 'Í₂ Génesis 6 - 9.\f* Jŋia₃ tan₅₄ dsa₂ bá₄ lë́₂ i₂ca₂lón₂ quian'₅₄ a₂jaun₂ jme₁ca₂'a₃ jmɨg₂ mɨ₂güɨ́g₃.  
\v 21 A₂jaun₂ jáng'₅ caun₂ léi₄ jme₁chó₅ jniog₄ jmɨg₂ jmɨg₄ rë₂në́₃, a₂ma₂ca₂lag₃ jniog₄ dsa₂ i₂ma₂ca₂lón₂; on₃jua'₅₄ a₂jŋia'₃ a₂'lian₅₄ dsa₂, të₂le₃ a₂jang'₂ jniog₄ caun₂ léi₄ a₂quián₁ jniog₄ caun₂ juɨ₅ a₂le₁jë́₃ jme₂dsí₂ quián₂ të₂le₃ ne₄ Diú₄ bá₄, ton'₂ ca₂ló₂ jniog₄ të₂le₃ quian'₅₄ juɨ₅bí₂ a₂ca₂jen'₅₄ Jesucristo.  
\v 22 Ca₂uɨ́g₂ táng₃ ŋái'₃ guei'₅₄ i₂juɨ́g₃; ja₁jaun₂ guá₅ të₂le₃ gu₂ ne₁ Diú₄; 'éi'₃ quió'₅ 'éi₂ bá₄ tion'₅₄ ca₂le₃jɨ́n₃ ángeles quian'₅₄ ca₂le₃jɨ́n₃ i₂lɨ́n₅ ta₁, ca₂le₃jɨ́n₃ guë́₄ i₂'io₅ juɨ₅bí₂ në́₃. 
\c 4  
\s1 A₂jme₂ti₃ dsa₂ lia'₂ con'₂ lë́₅ juɨ₅bí₂ a₂ma₂cuë₃ Diú₄ 
\p  
\v 1 Jaun₂ lë₃, ia₁ ca₂ŋág₃ Cristo uɨg₅ juɨ₅ nɨ₁ŋɨ₁₂, le₂në₅ bá₄ 'nia'₂ ján₃ chan'₂ 'nia'₂ rë₂lɨng'₅₄ caun₂ 'éi₂ 'nia'₂ 'au'₂ a₂cán'₁ jmɨ₁uɨg₅. Ia₁ juɨ₁lia'₂ dsa₂ i₂ma₂ca₂ŋág₃ uɨg₅ juɨ₅ nɨ₁ŋɨ₁₂, co₂dsia₅ ma₂tí₂ bá₄ juɨ₅ jë₁jme₁'no₂₃ dso₄.  
\v 2 A₂le₃chain₂ táng₃ të₂le₃ ne₄ juɨ₅ ja₁ŋó₄, a₂jme₃ti₃ a₂'nio₃ Diú₄ bá₄, tsá₃ ma₃le₃chain₂ jua'₅₄ a₂cuë́'₃ guë́₄ o₂'ŋió₃ o₂jŋia₃ dsɨ₅ con'₂ niog₅ mɨ₅ nɨ₁ŋɨ₁₂.  
\v 3 Tió'₅, a₂ma₂ca₂ŋɨ́₂ juɨn₅₄ qui₂ma₂jmo'₅₄ 'nia'₂ ja₁ma₂ja₂nóg'₅, lia'₂ con'₂ lë́₅ jmo₅-dsáu₅ ca₂le₃jɨ́n₃ dsa₂ i₂tsá₃ cuɨn₅ Diú₄. Ia₁ jme₁chan'₂ 'nia'₂ tsá₃ caun₂ a₂jme₁'ɨ́n₅ 'au'₂; tsá₃ caun₂ a₂'lɨg'₅₄ a₂jme₁qui₂lë́₂ 'au'₂ 'nia'₂ në́₃; jme₁qui₂i₂niog'₅₄ qui₂le₁'eng'₅; jme₁qui₂quë́'₂ 'nia'₂ tóng'₂ chí'₅ co₂mɨ'₅₄ niog₅ jmɨg₄. Jme₁'ág'₂ 'nia'₂ ca₂lia'₂ tsá₃ cuente niog₅; jme₁jme₂juɨ́n'₂ 'nia'₂ diú₄ lag₄, caun₂ a₂'io'₅₄ Diú₄.  
\v 4 Dsɨ₂gó'₃ dsɨ́₅ dsa₂ 'éi₂ a₂tsá₃ jme₂quiain'₅₄ 'nia'₂ jë₄ ca₂le₃jë́₃ a₂i₂juɨn₅₄ a₂'lɨg'₅₄ a₂jmo₅-dsáu₅, jaun₂ 'lɨg'₅₄ bá₄ 'ag₂₃.  
\v 5 La₁ já₅ bá₄ jmɨg₄ ja₁jáng'₃ cuenta quió'₅ ne₄ i₂ma₂lë́₅ co₂jŋia₅₄ con₂ 'í₁ lia'₂ quió'₅ i₂chan₂ lia'₂ quió'₅ i₂ma₂dsan₃ në́₃.  
\v 6 'Uɨg₅₄ në₅, ca₂rë₃'ë́₂ jág₁ dse₃ ca₂lia'₂ ja₁con₂ dsa₂ i₂ma₂dsan₃: ia₁jaun₂ të₃dsɨ₅₄ 'éi'₃ le₃quió'₅ nɨ₁ŋɨ₁₂, lia'₂ con'₂ lë́₅ dsɨ₂jiog₅ dsɨ́₅ dsa₂ mɨ₂güɨ́g₃, ia₁jaun₂ guë́₄ le₃chain₂ juɨ₅ jme₂dsí₂ në́₃, lia'₂ con'₂ lë́₅ dsɨ₂jiog₅ dsɨ́₅ Diú₄. 
\p  
\v 7 La₁ ja₂quián₃ bá₄ jmɨg₄ jë₁dsian₅ ca₂le₃jë́₃. Jaun₂ në́₃ len'₅₄ 'nia'₂ chang'₂, 'en₅₄ 'au'₂, ia₁jaun₂ lé₂ chi₁léng'₄ Diú₄.  
\v 8 La₁ a₂dsen₅₄ guë́₄ 'ŋio₅ lɨn₃, 'nió'₅ a₂jme₁'nió'₄ 'nia'₂ rɨ́ng'₂ 'ŋio₅ lɨn₃ le₂jang'₂ le₂jang'₂. Ia₁ ja₁'nio₃ dsa₂ rɨin'₅₄, 'lióng₂ o₂'én₂ dso₄ cha₂ ja₁con₂ rɨn'₅₄ dsa₂.\f + \fr 4:8 \ft 'Nio'₂ ja₁ton₅ Proverbios 10:12.\f* 
\v 9 Guen₅₄ 'nia'₂ rɨ́ng'₂ i₂qui₂dsɨ₂jag₅₄ dsi₂néi₂ quiáng'₂, on₃jua'₅₄ a₂qui₂dsɨ₂mé'₂ 'au'₂ quiain'₅₄.  
\v 10 Le₂jan'₂ le₂jan'₂ 'nia'₂ ca₂tɨ́ng'₂ jme₁'ong'₁ rɨ́ng'₂ lia'₂ con'₂ lë́₅ ma₂ca₂rë₃tɨ́ng'₃ a₂'lióng₂ ne₅₄ a₂ma₂ca₂jme₃gu'₅₄ Diú₄, a₂niog₅ gog'₂ 'nia'₂ jmó'₂.  
\v 11 Në₁jua'₂ 'ein₂ 'nio₃ te₂néi'₂ jág₁, juɨ₁te₂néi'₂ bá₄ quian'₅₄ jág₁ quió'₅ Diú₄. Në₁jua'₂ chan₂ guë'₂ 'ein₂ 'nio₃ jme₃'o₅₄ juɨ₁jme₂'o₅₄ bá₄ lia'₂ con'₂ lë́₅ juɨ₅bí₂ a₂ma₂cuë₅ Diú₄, ia₁jaun₂ le₂në₅ bá₄ le₃juɨn'₂ Diú₄ ne₄ ca₂le₃jë́₃ të₂le₃ quian'₅₄ Jesucristo. 'Éi₂ bá₄ ca₂tɨ́n₂ ŋe₂ ca₂le₃jë́₃ ti₁'mag'₄, ca₂le₃jë́₃ juɨ₅bí₂, ca₂le₃jë́₃ jmɨg₄ co₂tan₅₄. ¡A₂méi₃! 
\s1 A₂ŋág₅ dsa₂ uɨg₅ ne₄ 'uɨg₅₄ ia₁ a₂'éin₂ 
\p  
\v 12 'Nia'₂ rɨn'₅₄ jniog₄ i₂'nióg₃, tsá₃ lë₁jmo₂ 'nia'₂ go₂'i₃ jme₁dsɨ₂ŋɨ́g'₂ táu₂ a₂lë́₅ lia'₂ lë́₅ si₂ dséi₂ ja₁con'₂ 'nia'₂, jua'₅₄ a₂le₃jmó'₂ 'nia'₂ 'au'₂ jua'₅₄ a₂tsá₃ ma₂cuɨn'₂ 'nia'₂, 'a₂ lia'₂ lë́₅ dsɨ₂ŋɨ́g'₂.  
\v 13 Të₂le₃ jmo₄ 'nia'₂ 'io'₂, ia₁ le₂në₅ bá₄ can'₂ 'nia'₂ ján₃ jmɨ₁uɨg₅ juɨ₁lia'₂ a₂ca₂i₃ŋɨ́₂ Cristo, ia₁jaun₂ bá₄ cán'₁ 'nia'₂ ján₃ o₂'ŋió₃ 'au'₂ 'ŋio₅ lɨn₃ jë₁ma₂të́₂ rë₁jme₃jniai₂₃ 'a₂ lia'₂ jláin'₁.  
\v 14 'E₂ guë́₄ dsen'₃ 'nia'₂ jme₁të₂'o'₂ 'ein₂ të₂'o'₂ o₄quió'₄ Cristo, ia₁ le₂në₅ bá₄ të₂'ŋiá₄ Jme₂dsí₂ quián₅ Diú₄ i₂tág₅ co₂'né'₅ ne₄ quián'₂ 'nia'₂.  
\v 15 Chi₂jua'₂ 'ein₂ 'nia'₂ dsɨ₂ŋɨ́₂ uɨg₅, la₁ lag₃ në₁jua'₂ tsá₃ lë́₅ dso₄ 'ang₂, o₃ a₂ca₂jŋɨi'₃ dsa₂, o₃ chan₂ i₂ca₂cuë́'₃ dsa₂ mɨ₂güɨ́g₃ rɨin'₅₄, o₃ a₂qui₂tiáin₂ caun₂ ja₁tsá₃ ca₂tɨ́in₂.  
\v 16 La₁ në₁jua'₂ ŋag'₅₄ 'nia'₂ uɨg₅ ca₂ne₅₄ ia₁ a₂lɨ́ng'₅ dsa₂ “cristianos”, tsá₃ 'nió'₅ jmó'₂ 'nia'₂ gueng'₅₄. Diú₄ bá₄ 'nió'₅ jme₁juɨn'₂ 'nia'₂ ia₁ a₂quiong₅ dsa₂ le₂jaun₂. 
\p  
\v 17 Ia₁ ma₂të́₂ jmɨg₄ a₂të₂dsɨ₅₄ 'éi'₃ le₂'uɨg₅₄ de'₂ ja₁con₂ dsa₂ dsi₂néi₂ quió'₅ Diú₄. Chi₂jua'₂ le₂'uɨg₅₄ jme₂lióg₃ quian'₅₄ jniog₄, ¿'a₂ bá₄ lia'₂ dsióg₄ dsi₁ŋɨ́₂ ca₂le₃jɨ́n₃ i₂tsá₃ jme₂ti₃ jág₁ dse₃ quió'₅ Diú₄?  
\v 18 Chi₂jua'₂ quian₅ ta₁ lɨn₃ a₂tɨ́n'₅ dsa₂ dsen₃, “¿'ë₂ guë́₄ bá₄ dsióg₄ dsi₁ŋɨ́₂ dsa₂ i₂tsá₃ Diú₄ cuɨn₅, i₂le₁cán'₄ dso₄?”\f + \fr 4:18 \ft Proverbios 11:31.\f* 
\v 19 Jaun₂ në́₃, i₂ŋág₅ uɨg₅ lia'₂ con'₂ lë́₅ 'ŋio₂ dsɨ́₅ Diú₄, ca₂tɨ́in₂ caun₂ jmo₃ a₂dse₃ bá₄, dsia₃ o₄gú₃ Diú₄ jme₂dsí₂ quió'₅, ia₁ Diú₄ bá₄ i₂ca₂jmó'₂ 'éi₂, i₂rë₂ti'₅₄ në́₃. 
\c 5  
\s1 Toin'₂ jág₁ dse₃ dsa₂ 'én₂ 
\p  
\v 1 Jaun₂ në́₃, jág₁ la₂ cuë́₅ jniá₂ ca₂le₃jɨ́n₃ dsa₂ can'₅₄ i₂quian₅ ne₄ juɨ₅\f + \fr 5:1 \ft griego: presbúteros. \f* quián'₂ 'nia'₂, ia₁ le₂në₅ bá₄ jniá₂ 'ŋió₃ ján₃ lɨ́ng₅ jan₂ dsa₂ juɨn'₂ i₂niog₅ ne₄ guá'₅, ton'₂ lɨ́ng₅ jan₂ i₂ca₂të́₂ ne₄ 'a₂ lia'₂ lë́₅ jmɨ₁uɨg₅ a₂ca₂i₃ŋɨ́₂ Cristo. Jaun₂ le₂në₅ bá₄ ján₃, lɨ́ng₅ jan₂ i₂jme₃quiain'₅₄ jë₁ma₂të́₂ rë₁jme₃jniai₂₃ a₂jláin'₁. Jág₁ la₂ juɨ́g₂ jniá₂ 'nia'₂:  
\v 2 Dse₃ jmo₄ 'nia'₂ 'í₁ guá'₅ quián₅ Diú₄ i₂lɨ́n₅ co₂nió'₃ já'₂ cha'₂ i₂niog₅ gog'₂. Jmo₄ 'nia'₂ ta₁ në₅ a₂'ŋio₂ 'au'₂, lia'₂ con'₂ lë́₅ 'nio₃ Diú₄. Tsá₃ jmo₂ 'nia'₂ 'au'₂ jua'₅₄ a₂chan₂ i₂chi₂quióng₂ jmɨg₄, on₃ guë'₂ jmo₂ 'nia'₂ 'au'₂ jua'₅₄ a₂ŋɨ́₄ 'ɨ́n₅ 'au'₂ cu₄ në́₃. Jmo₄ 'nia'₂ ta₁ quió'₅ Diú₄ a₂dsen₅₄ 'au'₂.  
\v 3 Tsá₃ jmo₂ 'nia'₂ jua'₅₄ guion'₅₄ 'nia'₂ ca₂tɨ́ng'₂ jmó'₂ gong'₂ ne₄ quió'₅ guá'₅ i₂niog₅ gog'₂, të₂le₃ ca₂tɨ́n'₂ bá₄ 'nia'₂ cuë'₅₄ caun₂ juɨ₅ dse₃ já'₂ cha'₂ quián₅ Diú₄.  
\v 4 Jaun₂ bá₄ jë₁ma₂të́₂ jmɨg₄ i₁jme₃jnia₅ i₂lɨ́n₅ juɨg₅₄ dsen₅₄ i₂quián₅ juɨg₅₄ já'₂ cha'₂, ŋe'₂ 'nia'₂ jma₃cáun₃ corona a₂tsá₃ lɨ́g'₂ jmɨg₄ le₃juɨng₅. 
\p  
\v 5 Le₂në₅ bá₄ 'nia'₂ dsa₂ chi'₂ ján₃, tión'₂ 'nia'₂ 'éi'₃ quió'₅ dsa₂ can'₅₄ quián'₂ 'nia'₂. Ton'₂ juɨ₁qui₂rë₂lɨng'₅₄ quian'₅₄ a₂meg'₂ ja₁con₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂, ia₁: 
\q1 Tsá₃ jen₅₄ Diú₄ juɨ₁lia'₂ dsa₂ i₂jmo₅ rón₂, 
\q2 la₁ jme₂'oin₅₄ a₂'ua₁ dsɨ́₅ dsa₂ i₂jmo₅ me'₂.\f + \fr 5:5 \ft Proverbios 3:34.\f* 
\m  
\v 6 Jaun₂ në́₃, le₂në₅ jmo₄ 'nia'₂ meg'₂ o₄gú₃ bén₂ quió'₅ Diú₄ ia₁jaun₂ bá₄ chó'₂ 'éi₂ jmɨg₄ jaun₂ quió'₅.  
\v 7 O₄gú₃ 'éi₂ dsia₄ 'nia'₂ ca₂le₃jë́₃ 'e₂ o₂i₁ dsɨ₅ a₂chan'₂ 'nia'₂, ia₁ dsan₂ bá₄ dsɨ́₅ 'éi₂ 'nia'₂ ján₃. 
\p  
\v 8 'En₅₄ 'au'₂ 'nia'₂ jmo₄, chang'₂ rë₂jáng'₁, ia₁ i₂së₃dsen₃ i₂'ŋia₅₄ 'nia'₂ ŋɨ₂₃ lɨ́in₅ lia'₂ lɨ́n₅ 'ia'₂ i₂ŋɨ₅ i₂jme₂'ne₅₄ 'ŋióg₂ a₂'nai'₂ 'ein₂ i₂'nio₃ quɨin'₂.  
\v 9 Quian'₅₄ a₂'én'₂ 'nia'₂, nau₂ tiá₂ queng'₂ ne₅₄, ia₁ ŋi'₅₄ bá₄ 'nia'₂ ta₁caun₂ mɨ₂güɨ́g₃ bá₄ qui₂dsɨ₂ŋɨ́₂ rɨ́ng'₂ jmɨ₁uɨg₅ le₂në₅ ján₃.  
\v 10 Ia₁ jë₁ma₂ca₂ŋɨ'₂ 'nia'₂ co₂'na₂ uɨg₅ le₂në₅, 'ŋiog₅ bá₄ Diú₄ i₂'ua₁ dsɨ́₅ lɨn₃ chei'₃ táng₃ rë₂ a₂jme₃'ŋiai₂₃ a₂'nió'₅ guë́₄ quián'₂ 'nia'₂, cuë₃ bí₂ náu'₁ 'nia'₂ tiá₂. Jme₃gu'₅₄ bá₄ 'éi₂ jniog₄ ne₄ ca₂le₃jë́₃ ne₅₄ a₂dse₃. Ia₁ ma₂ca₂të₃ jniog₄ le₃quió'₅ Cristo Jesús, a₂jme₁quiain'₄ jniog₄ co₂tan₅₄ ja₁co₂tág₅ co₂'né'₅ quió'₅.  
\v 11 'Éi₂ bá₄ ca₂tɨ́n₂ juɨ₅bí₂ ca₂le₃jë́₃ jmɨg₄ co₂tan₅₄. A₂méi₃. 
\s1 Cuag₂₃ Diú₄ jë₁ca₂tó'₂ jë₁'ág'₅ jág₁ 
\p  
\v 12 Të₂le₃ quian'₅₄ Silvano\f + \fr 5:12 \ft Co₂'nió'₄ lia'₂ chen₂ Silas.\f* i₂jɨng₅₄ lia'₂ ja₁jɨng₁₂ jan₂ rɨ́ng'₃ i₂rë₂ti'₅₄, ma₂jmo₃ si₂ la₂ ja₁juá'₅ tɨn₃-'nɨ₅ jon₂ jág₁ a₂cuë́₃ bí₂ 'nia'₂. Jág₁ a₂ma₂në₂juá'₃ jniá₂ në₅, jáng'₅ léi₄ 'a₂ lia'₂ dsón'₂ 'ua₁ dsɨ́₅ Diú₄. Jaun₂ nau₂ 'nia'₂ tiá₂ juɨ₅ në₅.  
\v 13 Guá'₅ i₂chan₂ ja₁të́'₂ dsa₂ juɨg₂ “Babilonia” la₂, dsa₂ i₂ma₂ca₂quión'₂ Diú₄ juɨ₁lia'₂ ma₂ca₂quióin'₂ 'nia'₂, dsiáin'₂ jág₁ a₂cuɨin₂₃ Diú₄ 'nia'₂, le₂jaun₂ bá₄ Marcos jón₃ quiáng₃ në́₃.  
\v 14 Cuɨn₅₄ 'nia'₂ Diú₄ rɨ́ng'₂ le₂jang'₂ le₂jang'₂, chen'₅₄\f + \fr 5:14 \ft Caun₂ tag₄ a₂jme₁chí'₄ lia'₂ con'₂ ca₂jmo₃ Pe₄ si₂ la₂.\f* 'nia'₂ jú'₅ rɨ́ng'₂ ia₁ a₂'nióg'₃ rɨ́ng'₂. 
\p Tián'₂ bá₄ 'nia'₂ 'ei₅ tei₄ ca₂le₃jɨ́n'₃ 'nia'₂ i₂tén₅ le₃quió'₅ Cristo. 
\p Co₂në₅.