\v 5 \w Joram|strong="H3088"\w* tenía 32 \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* \w ocho|strong="H8083"\w* \w años|strong="H8141"\w* en Jerusalén.  
\v 6 \w Anduvo|strong="H3212"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w reyes|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w como|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Acab, \w pues|strong="H3588"\w* una \w hija|strong="H1323"\w* \w de|strong="H3588"\w* Acab \w fue|strong="H1961"\w* \w su|strong="H3588"\w* esposa. \w Hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 7 Pero \nd \+w Yavé|strong="H3068"\+w*\nd* \w no|strong="H3808"\w* quiso \w destruir|strong="H7843"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w* \w a|strong="H3068"\w* causa del \w Pacto|strong="H1285"\w* \w que|strong="H3808"\w* \w hizo|strong="H3772"\w* con \w él|strong="H3605"\w* según su promesa, según \w la|strong="H3605"\w* cual le \w daría|strong="H5414"\w* una \w lámpara|strong="H5216"\w* \w a|strong="H3068"\w* \w él|strong="H3605"\w* y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w para|strong="H4616"\w* \w siempre|strong="H3605"\w*.   
\p
\v 8 \w En|strong="H5921"\w* su \w tiempo|strong="H3117"\w* Edom \w se|strong="H5921"\w* rebeló \w contra|strong="H5921"\w* \w el|strong="H5921"\w* dominio \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* proclamaron un \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w ellos|strong="H3027"\w*.  
\v 9 Entonces \w Joram|strong="H3088"\w* \w fue|strong="H1961"\w* \w con|strong="H5973"\w* sus oficiales y \w todos|strong="H3605"\w* sus carruajes. Al \w levantarse|strong="H6965"\w* \w de|strong="H5973"\w* \w noche|strong="H3915"\w*, derrotó \w a|strong="H3068"\w* \w los|strong="H3605"\w* edomitas, quienes \w lo|strong="H3605"\w* \w habían|strong="H1961"\w* sitiado \w a|strong="H3068"\w* \w él|strong="H5973"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* comandantes \w de|strong="H5973"\w* sus carruajes.  
\v 10 Sin embargo, Edom siguió \w en|strong="H5704"\w* rebeldía contra \w el|strong="H1931"\w* dominio \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.  
\p \w En|strong="H5704"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w Libna|strong="H3841"\w* \w también|strong="H2088"\w* \w se|strong="H1931"\w* rebeló contra \w su|strong="H1931"\w* dominio, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* abandonó \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H3588"\w* \w sus|strong="H1931"\w* antepasados.  
\v 11 \w Además|strong="H1571"\w* construyó lugares \w altos|strong="H1116"\w* en \w la|strong="H1931"\w* región montañosa de \w Judá|strong="H3063"\w*, \w y|strong="H1571"\w* fomentó \w la|strong="H1931"\w* prostitución entre \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Jerusalén \w y|strong="H1571"\w* \w Judá|strong="H3063"\w*.   
\p
\v 12 Entonces le llegó una carta del \w profeta|strong="H5030"\w* Elías \w que|strong="H3808"\w* decía: \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H8478"\w* \w David|strong="H1732"\w*, tu antepasado, dice: \wj \+w Por|strong="H8478"\+w* \+w cuanto|strong="H8478"\+w* \+w no|strong="H3808"\+w* andas \+w en|strong="H8478"\+w* los \+w caminos|strong="H1870"\+w* \+w de|strong="H8478"\+w* tu padre Josafat, \+w ni|strong="H3808"\+w* \+w en|strong="H8478"\+w* los \+w caminos|strong="H1870"\+w* \+w de|strong="H8478"\+w* Asa, \+w rey|strong="H4428"\+w* \+w de|strong="H8478"\+w* \+w Judá|strong="H3063"\+w*,\wj*  
\v 13 \wj \+w sino|strong="H2896"\+w* \+w en|strong="H4480"\+w* \+w el|strong="H3427"\+w* \+w camino|strong="H1870"\+w* \+w de|strong="H4480"\+w* \+w los|strong="H3427"\+w* \+w reyes|strong="H4428"\+w* \+w de|strong="H4480"\+w* \+w Israel|strong="H3478"\+w*, causaste \+w que|strong="H4480"\+w* \+w Judá|strong="H3063"\+w* \+w y|strong="H1571"\+w* \+w los|strong="H3427"\+w* \+w habitantes|strong="H3427"\+w* \+w de|strong="H4480"\+w* Jerusalén forniquen según \+w la|strong="H1571"\+w* fornicación \+w de|strong="H4480"\+w* \+w la|strong="H1571"\+w* \+w casa|strong="H1004"\+w* \+w de|strong="H4480"\+w* Acab.\wj*  
\p \wj \+w Por|strong="H4480"\+w* cuanto asesinaste \+w a|strong="H3068"\+w* tus hermanos, \+w a|strong="H3068"\+w* \+w la|strong="H1571"\+w* \+w familia|strong="H1004"\+w* \+w de|strong="H4480"\+w* tu padre, \+w que|strong="H4480"\+w* eran \+w mejores|strong="H2896"\+w* \+w que|strong="H4480"\+w* tú,\wj*  
\v 14 \wj \+w ciertamente|strong="H2009"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w va|strong="H3068"\+w* \+w a|strong="H3068"\+w* golpear con una \+w gran|strong="H1419"\+w* calamidad \+w a|strong="H3068"\+w* tu \+w pueblo|strong="H5971"\+w*, tus \+w hijos|strong="H1121"\+w*, tus mujeres, \+w todas|strong="H3605"\+w* tus posesiones\wj*  
\v 15 \wj \+w y|strong="H5921"\+w* \+w a|strong="H3068"\+w* \+w ti|strong="H4480"\+w* \+w con|strong="H5921"\+w* \+w muchas|strong="H7227"\+w* \+w enfermedades|strong="H2483"\+w*, \+w con|strong="H5921"\+w* dolencia \+w de|strong="H4480"\+w* tus intestinos, \+w hasta|strong="H5704"\+w* \+w que|strong="H4480"\+w* \+w salgan|strong="H3318"\+w* tus intestinos \+w por|strong="H5921"\+w* causa \+w de|strong="H4480"\+w* \+w la|strong="H5921"\+w* \+w enfermedad|strong="H2483"\+w* \+w día|strong="H3117"\+w* tras \+w día|strong="H3117"\+w*.\wj*   
\p
\v 16 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* incitó \w la|strong="H5921"\w* ira \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* árabes \w que|strong="H5921"\w* estaban \w con|strong="H5921"\w* \w los|strong="H5921"\w* etíopes \w contra|strong="H5921"\w* \w Joram|strong="H3088"\w*.  
\v 17 \w Estos|strong="H3605"\w* \w subieron|strong="H5927"\w* contra \w Judá|strong="H3063"\w* \w y|strong="H1571"\w* \w la|strong="H1571"\w* invadieron. \w Se|strong="H3808"\w* llevaron \w todo|strong="H3605"\w* \w que|strong="H3588"\w* \w hallaron|strong="H4672"\w* \w en|strong="H3588"\w* \w la|strong="H1571"\w* \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w*, \w los|strong="H1121"\w* bienes, sus \w hijos|strong="H1121"\w* \w y|strong="H1571"\w* sus mujeres. \w No|strong="H3808"\w* le \w quedó|strong="H7604"\w* algún \w hijo|strong="H1121"\w*, excepto Joacaz, \w el|strong="H3588"\w* \w menor|strong="H6996"\w* \w de|strong="H3588"\w* sus \w hijos|strong="H1121"\w*.   
\p
\v 18 Después de \w todo|strong="H3605"\w* \w esto|strong="H2063"\w*, \nd \+w Yavé|strong="H3068"\+w*\nd* \w lo|strong="H3605"\w* \w hirió|strong="H5062"\w* con una \w enfermedad|strong="H2483"\w* incurable en \w los|strong="H3605"\w* intestinos.  
\v 19 \w Aconteció|strong="H1961"\w* \w que|strong="H3808"\w* \w en|strong="H5973"\w* \w el|strong="H5973"\w* transcurso \w del|strong="H5973"\w* \w tiempo|strong="H6256"\w*, \w después|strong="H1961"\w* \w de|strong="H5973"\w* \w dos|strong="H8147"\w* \w años|strong="H3117"\w*, \w se|strong="H1961"\w* \w le|strong="H5973"\w* \w salieron|strong="H3318"\w* \w los|strong="H5973"\w* intestinos \w a|strong="H3068"\w* causa \w de|strong="H5973"\w* la \w enfermedad|strong="H2483"\w* y \w murió|strong="H4191"\w* \w con|strong="H5973"\w* gran dolor. Su \w pueblo|strong="H5971"\w* \w no|strong="H3808"\w* encendió una hoguera \w para|strong="H1961"\w* \w él|strong="H5973"\w*, \w como|strong="H5973"\w* la hoguera \w que|strong="H3808"\w* encendieron \w para|strong="H1961"\w* sus antepasados.   
\p
\v 20 \w Tenía|strong="H1961"\w* 32 \w años|strong="H8141"\w* \w cuando|strong="H1961"\w* comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* \w en|strong="H6912"\w* Jerusalén \w ocho|strong="H8083"\w* \w años|strong="H8141"\w*. Desapareció \w sin|strong="H3808"\w* \w que|strong="H3808"\w* \w nadie|strong="H3808"\w* \w lo|strong="H3808"\w* lamentara, y \w lo|strong="H3808"\w* \w sepultaron|strong="H6912"\w* \w en|strong="H6912"\w* la \w Ciudad|strong="H5892"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, pero \w no|strong="H3808"\w* \w en|strong="H6912"\w* \w los|strong="H1121"\w* \w sepulcros|strong="H6913"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w*.   
\c 22  
\s1 Reinado de Ocozías en Judá  
\p
\v 1 \w Los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H3588"\w* Jerusalén proclamaron \w a|strong="H3068"\w* Ocozías, \w el|strong="H3588"\w* \w menor|strong="H6996"\w* \w de|strong="H3588"\w* sus \w hijos|strong="H1121"\w*, \w como|strong="H3588"\w* \w rey|strong="H4428"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w lugar|strong="H8478"\w*, \w porque|strong="H3588"\w* unas bandas \w que|strong="H3588"\w* llegaron \w con|strong="H3588"\w* \w los|strong="H3427"\w* árabes \w al|strong="H4428"\w* \w campamento|strong="H4264"\w* \w mataron|strong="H2026"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* mayores. \w Por|strong="H3588"\w* tanto Ocozías, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Joram|strong="H3088"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*, \w reinó|strong="H4427"\w*.   
\p
\v 2 Ocozías tenía 22 \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* un \w año|strong="H8141"\w* en Jerusalén. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* su madre \w era|strong="H8141"\w* \w Atalía|strong="H6271"\w*, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* \w Omri|strong="H6018"\w*.   
\p
\v 3 \w También|strong="H1571"\w* \w él|strong="H1931"\w* \w anduvo|strong="H1980"\w* \w en|strong="H3588"\w* \w los|strong="H1931"\w* \w caminos|strong="H1870"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Acab. \w Su|strong="H1931"\w* propia madre \w fue|strong="H1961"\w* \w su|strong="H1931"\w* consejera \w para|strong="H3588"\w* \w que|strong="H3588"\w* obrara \w impíamente|strong="H7561"\w*.  
\v 4 \w Hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante \nd \+w Yavé|strong="H3068"\+w*\nd*, \w como|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Acab, \w porque|strong="H3588"\w* \w después|strong="H1961"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w* \w de|strong="H3588"\w* \w su|strong="H1992"\w* padre, \w ellos|strong="H1992"\w* \w lo|strong="H6213"\w* aconsejaban \w para|strong="H3588"\w* perdición \w de|strong="H3588"\w* \w él|strong="H3588"\w*.  
\v 5 \w Porque|strong="H5921"\w* \w al|strong="H5921"\w* \w andar|strong="H1980"\w* \w según|strong="H5921"\w* \w el|strong="H5921"\w* \w consejo|strong="H6098"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w fue|strong="H3212"\w* \w con|strong="H5921"\w* \w Joram|strong="H3088"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Acab, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w* \w contra|strong="H5921"\w* \w Hazael|strong="H2371"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria, \w en|strong="H5921"\w* Ramot \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w*.  
\p \w Los|strong="H1121"\w* sirios \w hirieron|strong="H5221"\w* \w a|strong="H3068"\w* \w Joram|strong="H3088"\w*,  
\v 6 \w quien|strong="H1931"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* \w Jezreel|strong="H3157"\w* \w para|strong="H3588"\w* ser curado \w de|strong="H3588"\w* las \w heridas|strong="H4347"\w* \w que|strong="H3588"\w* \w le|strong="H1931"\w* \w hicieron|strong="H5221"\w* \w en|strong="H3588"\w* Ramot \w de|strong="H3588"\w* Galaad \w cuando|strong="H3588"\w* combatía contra \w Hazael|strong="H2371"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Siria. \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Joram|strong="H3088"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*, bajó \w a|strong="H3068"\w* \w ver|strong="H7200"\w* \w a|strong="H3068"\w* \w Joram|strong="H3088"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Acab, \w en|strong="H3588"\w* \w Jezreel|strong="H3157"\w*, \w pues|strong="H3588"\w* estaba \w enfermo|strong="H2470"\w*.   
\p
\v 7 Pero la derrota \w de|strong="H5973"\w* Ocozías \w era|strong="H1961"\w* designio \w de|strong="H5973"\w* \nd ʼElohim\nd*, porque \w fue|strong="H1961"\w* \w a|strong="H3068"\w* ver \w a|strong="H3068"\w* \w Joram|strong="H3088"\w*. Al llegar allí, \w salió|strong="H3318"\w* \w con|strong="H5973"\w* \w Joram|strong="H3088"\w* \w contra|strong="H5973"\w* \w Jehú|strong="H3058"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Nimsi, \w a|strong="H3068"\w* quien \nd \+w Yavé|strong="H3068"\+w*\nd* \w ungió|strong="H4886"\w* \w para|strong="H1961"\w* exterminar la \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Acab.   
\p
\v 8 \w Cuando|strong="H1961"\w* \w Jehú|strong="H3058"\w* hacía justicia \w con|strong="H5973"\w* la \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Acab, encontró \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w los|strong="H1121"\w* hermanos \w de|strong="H5973"\w* Ocozías quienes \w estaban|strong="H1961"\w* al servicio \w de|strong="H5973"\w* Ocozías, y \w los|strong="H1121"\w* \w mató|strong="H2026"\w*.  
\v 9 También \w buscó|strong="H1875"\w* \w a|strong="H3068"\w* Ocozías, \w a|strong="H3068"\w* \w quien|strong="H3605"\w* detuvieron \w cuando|strong="H3588"\w* \w estaba|strong="H1004"\w* \w escondido|strong="H2244"\w* \w en|strong="H3588"\w* \w Samaria|strong="H8111"\w*. \w Lo|strong="H1931"\w* llevaron ante \w Jehú|strong="H3058"\w*, \w y|strong="H3588"\w* \w lo|strong="H1931"\w* \w mataron|strong="H4191"\w*. \w Pero|strong="H3588"\w* \w lo|strong="H1931"\w* \w sepultaron|strong="H6912"\w*, \w porque|strong="H3588"\w* dijeron: \w Es|strong="H1931"\w* \w el|strong="H1931"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Josafat, \w quien|strong="H3605"\w* \w buscó|strong="H1875"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w con|strong="H3588"\w* \w todo|strong="H3605"\w* \w su|strong="H1931"\w* \w corazón|strong="H3824"\w*. \w Y|strong="H3068"\w* \w no|strong="H3588"\w* quedó \w ninguno|strong="H3605"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Ocozías \w que|strong="H3588"\w* fuera capaz \w de|strong="H3588"\w* \w retener|strong="H6113"\w* \w el|strong="H1931"\w* \w reino|strong="H4467"\w*.   
\s1 Usurpación del reino por Atalía  
\p
\v 10 \w Cuando|strong="H3588"\w* \w Atalía|strong="H6271"\w*, madre \w de|strong="H3588"\w* Ocozías, \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w* \w murió|strong="H4191"\w*, se \w levantó|strong="H6965"\w* \w para|strong="H3588"\w* exterminar \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w descendencia|strong="H2233"\w* \w real|strong="H4467"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*.   
\p
\v 11 \w Pero|strong="H3588"\w* Josabet, \w hija|strong="H1323"\w* del \w rey|strong="H4428"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Joás|strong="H3101"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Ocozías, \w y|strong="H3588"\w* \w se|strong="H1961"\w* \w lo|strong="H1931"\w* \w llevó|strong="H3947"\w* furtivamente \w de|strong="H3588"\w* \w entre|strong="H8432"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del \w rey|strong="H4428"\w* \w que|strong="H3588"\w* \w eran|strong="H1961"\w* asesinados. \w Lo|strong="H1931"\w* \w escondió|strong="H5641"\w* juntamente \w con|strong="H3588"\w* \w su|strong="H1931"\w* madre \w de|strong="H3588"\w* crianza \w en|strong="H8432"\w* uno \w de|strong="H3588"\w* \w los|strong="H1121"\w* aposentos. \w Así|strong="H3588"\w* Josabet, \w hija|strong="H1323"\w* del \w rey|strong="H4428"\w* \w Joram|strong="H3088"\w*, esposa del \w sacerdote|strong="H3548"\w* \w Joiada|strong="H3077"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w era|strong="H1961"\w* hermana \w de|strong="H3588"\w* Ocozías, \w lo|strong="H1931"\w* \w escondió|strong="H5641"\w* \w de|strong="H3588"\w* \w Atalía|strong="H6271"\w*, \w y|strong="H3588"\w* \w ella|strong="H1931"\w* \w no|strong="H3808"\w* pudo \w matarlo|strong="H4191"\w*.  
\v 12 \w Estuvo|strong="H1961"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w escondido|strong="H2244"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* \w seis|strong="H8337"\w* \w años|strong="H8141"\w*, mientras \w Atalía|strong="H6271"\w* \w reinaba|strong="H4427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra.   
\c 23  
\s1 Gran obra del sumo sacerdote Joiada  
\p
\v 1 \w El|strong="H5973"\w* \w año|strong="H8141"\w* \w séptimo|strong="H7637"\w* \w Joiada|strong="H3077"\w* se fortaleció. Hizo un \w pacto|strong="H1285"\w* \w con|strong="H5973"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H5973"\w* centenas: \w con|strong="H5973"\w* \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Jeroham|strong="H3395"\w*, \w Ismael|strong="H3458"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Johanán|strong="H3076"\w*, \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Obed|strong="H5744"\w*, \w Maasías|strong="H4641"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Adaía, y Elisafat, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Zicri.  
\v 2 Recorrieron \w Judá|strong="H3063"\w* para convocar \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* de \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w* y \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w jefes|strong="H7218"\w* de las casas paternas de \w Israel|strong="H3478"\w*. Fueron \w a|strong="H3068"\w* Jerusalén.   
\p
\v 3 Entonces \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w congregación|strong="H6951"\w* \w hizo|strong="H3772"\w* un \w pacto|strong="H1285"\w* \w con|strong="H5973"\w* respecto \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd*.  
\p Joiada \w les|strong="H1992"\w* \w dijo|strong="H1696"\w*: \w Aquí|strong="H2009"\w* \w está|strong="H1992"\w* \w el|strong="H5921"\w* \w hijo|strong="H1121"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w quien|strong="H3605"\w* \w reinará|strong="H4427"\w*, tal \w como|strong="H5973"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H1992"\w* descendientes \w de|strong="H5921"\w* \w David|strong="H1732"\w*.   
\p
\v 4 \w Esto|strong="H2088"\w* \w es|strong="H2088"\w* \w lo|strong="H1697"\w* \w que|strong="H4480"\w* \w harán|strong="H6213"\w*: la \w tercera|strong="H7992"\w* parte \w de|strong="H4480"\w* ustedes, los \w sacerdotes|strong="H3548"\w* y los \w levitas|strong="H3881"\w* \w que|strong="H4480"\w* entran \w el|strong="H6213"\w* \w sábado|strong="H7676"\w*, estarán \w de|strong="H4480"\w* \w porteros|strong="H7778"\w* \w en|strong="H4480"\w* las puertas.  
\v 5 Otra \w tercera|strong="H7992"\w* parte \w estará|strong="H3605"\w* en \w el|strong="H3605"\w* palacio \w real|strong="H4428"\w*. Otra \w tercera|strong="H7992"\w* parte, en \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* del \w Fundamento|strong="H3247"\w*. \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w estará|strong="H3605"\w* en \w los|strong="H3605"\w* \w patios|strong="H2691"\w* \w de|strong="H5971"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H5971"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
