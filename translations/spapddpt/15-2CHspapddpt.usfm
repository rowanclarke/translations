\c 1  
\s1 Reinado de Salomón en Israel  
\p
\v 1 \w Salomón|strong="H8010"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*, \w se|strong="H5921"\w* estableció firmemente \w en|strong="H5921"\w* su \w reino|strong="H4438"\w*, pues \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd* estaba \w con|strong="H5973"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* exaltó muchísimo.   
\p
\v 2 \w Salomón|strong="H8010"\w* habló \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*: \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* millares y centenas, \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w jueces|strong="H8199"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* sus casas paternas.   
\p
\v 3 \w Salomón|strong="H8010"\w* \w y|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w congregación|strong="H6951"\w* \w fueron|strong="H1961"\w* al lugar alto \w que|strong="H3588"\w* \w estaba|strong="H1961"\w* \w en|strong="H5973"\w* \w Gabaón|strong="H1391"\w*, \w porque|strong="H3588"\w* \w allí|strong="H8033"\w* \w estaba|strong="H1961"\w* \w el|strong="H5973"\w* Tabernáculo \w de|strong="H3588"\w* \w Reunión|strong="H6951"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd*, \w que|strong="H3588"\w* \w Moisés|strong="H4872"\w*, esclavo \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w hizo|strong="H6213"\w* \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w desierto|strong="H4057"\w*.  
\v 4 \w Pues|strong="H3588"\w* \w David|strong="H1732"\w* \w subió|strong="H5927"\w* \w el|strong="H3588"\w* Arca \w de|strong="H3588"\w* \nd ʼElohim\nd* \w de|strong="H3588"\w* Quiriat-jearim al lugar \w que|strong="H3588"\w* le \w preparó|strong="H3559"\w*, \w porque|strong="H3588"\w* le levantó una tienda \w en|strong="H3588"\w* Jerusalén.  
\v 5 \w El|strong="H1121"\w* \w altar|strong="H4196"\w* \w de|strong="H6440"\w* bronce \w que|strong="H1121"\w* \w hizo|strong="H6213"\w* \w Bezaleel|strong="H1212"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Uri, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Hur|strong="H2354"\w*, \w estaba|strong="H7760"\w* allí \w delante|strong="H6440"\w* \w del|strong="H4196"\w* \w Tabernáculo|strong="H4908"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\p \w Salomón|strong="H8010"\w* y la \w congregación|strong="H6951"\w* fueron \w a|strong="H3068"\w* consultarle.  
\v 6 \w Salomón|strong="H8010"\w* \w subió|strong="H5927"\w* \w allá|strong="H8033"\w* \w ante|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w de|strong="H5921"\w* bronce \w que|strong="H5921"\w* estaba \w en|strong="H5921"\w* \w el|strong="H5921"\w* Tabernáculo \w de|strong="H5921"\w* Reunión, \w y|strong="H5921"\w* \w ofreció|strong="H5927"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* 1.000 \w holocaustos|strong="H5930"\w*.   
\p
\v 7 \w Aquella|strong="H1931"\w* \w noche|strong="H3915"\w* \nd ʼElohim\nd* \w se|strong="H1931"\w* \w apareció|strong="H7200"\w* \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* y \w le|strong="H1931"\w* dijo: \wj \+w Pide|strong="H7592"\+w* \+w lo|strong="H1931"\+w* \+w que|strong="H4100"\+w* quieras \+w que|strong="H4100"\+w* Yo te \+w dé|strong="H5414"\+w*.\wj*   
\p
\v 8 \w Salomón|strong="H8010"\w* respondió \w a|strong="H3068"\w* \nd ʼElohim\nd*: \w Tú|strong="H6213"\w* mostraste \w gran|strong="H1419"\w* \w misericordia|strong="H2617"\w* \w a|strong="H3068"\w* mi padre \w David|strong="H1732"\w* y \w me|strong="H5973"\w* constituiste \w rey|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w*.  
\v 9 \w Ahora|strong="H6258"\w*, oh \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd*, sea confirmada tu \w Palabra|strong="H1697"\w* \w que|strong="H3588"\w* diste \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w mi|strong="H5921"\w* padre, \w pues|strong="H3588"\w* Tú \w me|strong="H5921"\w* designaste \w rey|strong="H4427"\w* \w de|strong="H5921"\w* un \w pueblo|strong="H5971"\w* tan \w numeroso|strong="H7227"\w* \w como|strong="H3588"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w tierra|strong="H6083"\w*.  
\v 10 \w Dame|strong="H5414"\w* \w sabiduría|strong="H2451"\w* \w y|strong="H3588"\w* \w conocimiento|strong="H4093"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w salga|strong="H3318"\w* \w y|strong="H3588"\w* \w entre|strong="H3588"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, \w porque|strong="H3588"\w* ¿\w quién|strong="H4310"\w* puede juzgar \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w* \w tuyo|strong="H6258"\w* tan \w grande|strong="H1419"\w*?   
\p
\v 11 \nd ʼElohim\nd* respondió \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w*: \wj \+w Porque|strong="H5921"\+w* tuviste \+w esto|strong="H2063"\+w* \+w en|strong="H5921"\+w* mente, \+w y|strong="H1571"\+w* \+w no|strong="H3808"\+w* \+w pediste|strong="H7592"\+w* \+w riquezas|strong="H6239"\+w*, \+w ni|strong="H3808"\+w* posesiones, \+w ni|strong="H3808"\+w* honor, \+w ni|strong="H3808"\+w* \+w la|strong="H5921"\+w* \+w vida|strong="H5315"\+w* \+w de|strong="H5921"\+w* \+w los|strong="H5921"\+w* \+w que|strong="H3808"\+w* \+w te|strong="H5921"\+w* \+w aborrecen|strong="H8130"\+w*, \+w ni|strong="H3808"\+w* siquiera \+w pediste|strong="H7592"\+w* larga \+w vida|strong="H5315"\+w*, \+w sino|strong="H3808"\+w* \+w pediste|strong="H7592"\+w* \+w para|strong="H5921"\+w* \+w ti|strong="H5921"\+w* \+w sabiduría|strong="H2451"\+w* \+w y|strong="H1571"\+w* \+w conocimiento|strong="H4093"\+w* \+w para|strong="H5921"\+w* juzgar \+w a|strong="H3068"\+w* \+w mi|strong="H5921"\+w* \+w pueblo|strong="H5971"\+w* \+w sobre|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w cual|strong="H5315"\+w* \+w te|strong="H5921"\+w* designé \+w rey|strong="H4427"\+w*,\wj*  
\v 12 \wj \+w se|strong="H1961"\+w* te \+w dan|strong="H5414"\+w* \+w sabiduría|strong="H2451"\+w* \+w y|strong="H3519"\+w* \+w conocimiento|strong="H4093"\+w*. Te \+w daré|strong="H5414"\+w* \+w riquezas|strong="H6239"\+w*, posesiones \+w y|strong="H3519"\+w* honor, \+w tales|strong="H3651"\+w* \+w como|strong="H1961"\+w* \+w ningún|strong="H3808"\+w* \+w rey|strong="H4428"\+w* \+w los|strong="H1961"\+w* \+w tuvo|strong="H1961"\+w* hasta ahora, \+w ni|strong="H3808"\+w* \+w los|strong="H1961"\+w* \+w tendrá|strong="H1961"\+w* \+w después|strong="H1961"\+w* \+w de|strong="H6440"\+w* ti.\wj*   
\p
\v 13 \w Salomón|strong="H8010"\w* regresó \w a|strong="H3068"\w* Jerusalén \w después|strong="H5921"\w* \w de|strong="H5921"\w* estar \w en|strong="H5921"\w* \w el|strong="H5921"\w* Tabernáculo \w de|strong="H5921"\w* Reunión \w en|strong="H5921"\w* \w el|strong="H5921"\w* lugar alto \w de|strong="H5921"\w* \w Gabaón|strong="H1391"\w* \w y|strong="H5921"\w* comenzó \w a|strong="H3068"\w* reinar \w en|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\p
\v 14 \w Salomón|strong="H8010"\w* reunió carruajes \w de|strong="H5973"\w* guerra y \w jinetes|strong="H6571"\w*. \w Tuvo|strong="H1961"\w* 1.400 carruajes \w de|strong="H5973"\w* guerra y 12.000 \w jinetes|strong="H6571"\w* \w que|strong="H1961"\w* situó \w en|strong="H5973"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5973"\w* \w los|strong="H5973"\w* carruajes y \w en|strong="H5973"\w* Jerusalén \w cerca|strong="H5973"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w*.   
\p
\v 15 El \w rey|strong="H4428"\w* logró que la \w plata|strong="H3701"\w* y el \w oro|strong="H2091"\w* fueran como las piedras en Jerusalén, y que el cedro fuera tan abundante como los sicómoros \w de|strong="H5414"\w* la Sefela.\f + \fr 1:15 \ft Sefela. Territorio que va descendiendo de la región montañosa de Judea y llega hasta la tierra baja costera del Jordán.\f*  
\v 16 Los \w caballos|strong="H5483"\w* de \w Salomón|strong="H8010"\w* eran de \w Egipto|strong="H4714"\w*. Los \w mercaderes|strong="H5503"\w* del \w rey|strong="H4428"\w* los compraban \w por|strong="H4428"\w* manadas.  
\v 17 Llevaban de \w Egipto|strong="H4714"\w* un carruaje \w por|strong="H3027"\w* 600 piezas de \w plata|strong="H3701"\w*, y un \w caballo|strong="H5483"\w* \w por|strong="H3027"\w* 150. \w Por|strong="H3027"\w* \w medio|strong="H3027"\w* de \w ellos|strong="H3027"\w* \w también|strong="H3651"\w* \w los|strong="H3605"\w* adquirían \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de \w los|strong="H3605"\w* hititas y \w los|strong="H3605"\w* \w reyes|strong="H4428"\w* de Siria.   
\c 2  
\s1 Preparativos para la Casa de \nd ʼElohim\nd*  
\p
\v 1 \w Salomón|strong="H8010"\w* \w se|strong="H5921"\w* propuso edificar una Casa \w al|strong="H5921"\w* Nombre \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H5921"\w* un palacio real \w para|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 2 \w Salomón|strong="H8010"\w* designó 70.000 cargadores y 80.000 canteros \w para|strong="H5973"\w* labrar piedras \w en|strong="H5973"\w* la región montañosa, y 3.600 supervisores.   
\p
\v 3 Salomón envió \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* Hiram, rey \w de|strong="H5921"\w* Tiro: Haz conmigo \w como|strong="H5921"\w* hiciste \w con|strong="H5921"\w* \w mi|strong="H5921"\w* padre David, \w al|strong="H5921"\w* enviarle cedros \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w edificara|strong="H1129"\w* una \w casa|strong="H1004"\w* \w para|strong="H5921"\w* vivir.   
\p
\v 4 \w Ciertamente|strong="H3588"\w* \w yo|strong="H3588"\w* voy \w a|strong="H3068"\w* \w edificar|strong="H1129"\w* una \w Casa|strong="H1004"\w* al Nombre \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* mi \nd ʼElohim\nd* \w para|strong="H3588"\w* consagrarla \w a|strong="H3068"\w* \w Él|strong="H3588"\w* \w y|strong="H3588"\w* quemar incienso aromático ante \w Él|strong="H3588"\w* \w para|strong="H3588"\w* \w la|strong="H3588"\w* presentación continua \w de|strong="H3588"\w* \w los|strong="H3605"\w* panes, \w para|strong="H3588"\w* \w los|strong="H3605"\w* holocaustos \w de|strong="H3588"\w* \w la|strong="H3588"\w* mañana, \w la|strong="H3588"\w* llegada \w de|strong="H3588"\w* \w la|strong="H3588"\w* noche, \w los|strong="H3605"\w* holocaustos \w de|strong="H3588"\w* \w los|strong="H3605"\w* sábados, las lunas nuevas \w y|strong="H3588"\w* las fiestas solemnes \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd*, \w lo|strong="H3605"\w* \w cual|strong="H3588"\w* se hará \w perpetuamente|strong="H3605"\w* \w en|strong="H3588"\w* Israel.   
\p
\v 5 \w La|strong="H3588"\w* \w Casa|strong="H1004"\w* \w que|strong="H3588"\w* voy \w a|strong="H3068"\w* \w edificar|strong="H1129"\w* \w es|strong="H3588"\w* grande, \w pues|strong="H3588"\w* nuestro \nd ʼElohim\nd* \w es|strong="H3588"\w* \w más|strong="H3588"\w* grande \w que|strong="H3588"\w* todos \w los|strong="H3588"\w* \tl ʼelohim\tl*.  
\v 6 Pero ¿\w quién|strong="H6213"\w* \w será|strong="H6213"\w* capaz \w de|strong="H5973"\w* edificarle Casa, cuando \w el|strong="H5973"\w* cielo y \w el|strong="H5973"\w* \w más|strong="H6258"\w* alto cielo \w no|strong="H6213"\w* \w lo|strong="H6213"\w* pueden contener? ¿\w Quién|strong="H6213"\w* soy \w yo|strong="H6213"\w* \w para|strong="H5973"\w* \w que|strong="H6258"\w* \w le|strong="H5973"\w* edifique Casa, sino solo \w para|strong="H5973"\w* quemar incienso ante \w Él|strong="H5973"\w*?   
\p
\v 7 \w Ahora|strong="H2009"\w* \w pues|strong="H3588"\w*, \w envíame|strong="H7971"\w* un hombre hábil \w para|strong="H3588"\w* trabajar \w en|strong="H5973"\w* oro, plata, bronce, hierro, \add tela de\add* púrpura, carmesí \w y|strong="H3588"\w* azul, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w sepa|strong="H3045"\w* \w cómo|strong="H3588"\w* \w hacer|strong="H3772"\w* grabados \w para|strong="H3588"\w* \w que|strong="H3588"\w* trabaje \w con|strong="H5973"\w* \w los|strong="H5973"\w* expertos \w que|strong="H3588"\w* \w están|strong="H2009"\w* \w conmigo|strong="H5973"\w* \w en|strong="H5973"\w* Judá \w y|strong="H3588"\w* Jerusalén, \w a|strong="H3068"\w* quienes \w mi|strong="H2009"\w* padre David contrató.   
\p
\v 8 Envíame también cedros, cipreses \w y|strong="H3588"\w* sándalos del Líbano. \w Ciertamente|strong="H3588"\w* mis esclavos irán \w con|strong="H3588"\w* \w los|strong="H3588"\w* \w tuyos|strong="H1004"\w* \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* sé \w que|strong="H3588"\w* tus esclavos saben talar \w los|strong="H3588"\w* \w árboles|strong="H6086"\w* del Líbano  
\v 9 \w a|strong="H3068"\w* fin \w de|strong="H5414"\w* preparar \w madera|strong="H6086"\w* en abundancia, \w porque|strong="H2009"\w* la Casa que tengo que edificar \w será|strong="H5414"\w* grande y portentosa.   
\p
\v 10 Mira, \w para|strong="H5921"\w* \w el|strong="H5921"\w* sustento \w de|strong="H5921"\w* tus esclavos \w que|strong="H5921"\w* cortan \w y|strong="H5921"\w* labran \w la|strong="H5921"\w* madera \w doy|strong="H5414"\w* 4.400.000 litros \w de|strong="H5921"\w* trigo, 4.400.000 litros \w de|strong="H5921"\w* cebada, 440.000 litros \w de|strong="H5921"\w* vino \w y|strong="H5921"\w* 440.000 litros \w de|strong="H5921"\w* aceite.   
\p
\v 11 \w Hiram|strong="H2361"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Tiro, respondió en una carta \w que|strong="H3045"\w* envió \w a|strong="H3068"\w* \w Salomón|strong="H4428"\w*: \w A|strong="H3068"\w* causa del amor \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w por|strong="H5414"\w* su pueblo, te designó \w rey|strong="H4428"\w*.   
\p
\v 12 \w Y|strong="H3068"\w* \w Hiram|strong="H2361"\w* añadió: ¡Bendito sea \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* de Israel, Quien hizo el cielo y la tierra, Quien dio al rey David un hijo \w sabio|strong="H2450"\w*, dotado de discreción y entendimiento, quien edificará una Casa \w para|strong="H6258"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* y un palacio real \w para|strong="H6258"\w* él!   
\p
\v 13 \w Yo|strong="H4480"\w*, \w pues|strong="H4480"\w*, \w te|strong="H4480"\w* envío \w a|strong="H3068"\w* Hiram-abí, \w hombre|strong="H1121"\w* \w hábil|strong="H2450"\w* dotado \w de|strong="H4480"\w* entendimiento,  
\v 14 hijo de una mujer de las hijas de Dan, y su padre es de Tiro. Él sabe trabajar en oro, plata, bronce, hierro, piedra, madera, y \add tela de\add* púrpura, azul, carmesí y lino fino. Puede hacer toda clase de grabados y ejecutar cualquier proyecto \w que|strong="H6258"\w* le sea encomendado, quien se podrá colocar entre tus peritos y los peritos de mi \tl ʼadón\tl* David, tu padre.   
\p
\v 15 \w En|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w al|strong="H5921"\w* trigo, \w la|strong="H5921"\w* cebada, \w el|strong="H5921"\w* aceite \w y|strong="H5921"\w* \w el|strong="H5921"\w* vino \w de|strong="H4480"\w* \w los|strong="H5921"\w* cuales \w mi|strong="H5921"\w* \tl ʼadón\tl* habló, entréguelos \w a|strong="H3068"\w* sus esclavos,  
\v 16 y \w nosotros|strong="H3605"\w* mismos talaremos árboles del Líbano de acuerdo con \w todas|strong="H3605"\w* tus necesidades. Te \w los|strong="H3605"\w* llevaremos en balsas por mar \w a|strong="H3068"\w* Jope, y tú \w los|strong="H3605"\w* subirás \w a|strong="H3068"\w* Jerusalén.   
\p
\v 17 Salomón contó todos \w los|strong="H1992"\w* extranjeros \w que|strong="H5971"\w* \w estaban|strong="H5971"\w* en la tierra \w de|strong="H5971"\w* Israel, según \w el|strong="H6213"\w* censo \w que|strong="H5971"\w* \w hizo|strong="H6213"\w* \w su|strong="H1992"\w* padre David. \w Se|strong="H1992"\w* halló \w que|strong="H5971"\w* \w había|strong="H6213"\w* 153.600.  
\v 18 Designó \w a|strong="H3068"\w* 70.000 de ellos como cargadores, \w a|strong="H3068"\w* 80.000 para tallar piedras en la región montañosa y \w a|strong="H3068"\w* 3.600 supervisores para vigilar la labor de la gente.   
\c 3  
\s1 Construcción de la Casa de \nd Yavé\nd*  
\p
\v 1 \w Salomón|strong="H8010"\w* \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* \w edificar|strong="H1129"\w* la \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* en Jerusalén, en la montaña Moriah, \w donde|strong="H4725"\w* \add Él\add* se \w apareció|strong="H7200"\w* \w a|strong="H3068"\w* su padre \w David|strong="H1732"\w* en el \w lugar|strong="H4725"\w* que \w David|strong="H1732"\w* \w preparó|strong="H3559"\w* en la era de Ornán \w jebuseo|strong="H2983"\w*.  
\v 2 \w A|strong="H3068"\w* los \w dos|strong="H8141"\w* días del \w mes|strong="H2320"\w* \w segundo|strong="H8145"\w*, el \w año|strong="H8141"\w* cuarto de su \w reinado|strong="H4438"\w*, \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* \w edificar|strong="H1129"\w*.   
\p
\v 3 Estas son las medidas prescritas \w a|strong="H3068"\w* \w Salomón|strong="H8010"\w* para los \w cimientos|strong="H3245"\w* de la \w Casa|strong="H1004"\w* de \nd ʼElohim\nd*: La longitud en codos,\f + \fr 3:3 \ft Codo: 45 centímetros.\f* según la \w medida|strong="H4060"\w* \w antigua|strong="H7223"\w*, era de 27 metros, y la \w anchura|strong="H7341"\w*, de nueve metros.  
\v 4 \w El|strong="H5921"\w* patio \w que|strong="H5921"\w* \w estaba|strong="H1004"\w* adelante tenía \w la|strong="H5921"\w* longitud \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w anchura|strong="H7341"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w*, nueve metros, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w altura|strong="H1363"\w*, nueve metros. \w Lo|strong="H5921"\w* recubrió \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w puro|strong="H2889"\w* \w por|strong="H5921"\w* \w dentro|strong="H6440"\w*.   
\p
\v 5 \w La|strong="H5921"\w* sala \w principal|strong="H1419"\w* \w la|strong="H5921"\w* \w cubrió|strong="H2645"\w* \w con|strong="H5921"\w* \w madera|strong="H6086"\w* \w de|strong="H5921"\w* ciprés \w y|strong="H5921"\w* \w la|strong="H5921"\w* recubrió \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w de|strong="H5921"\w* \w buena|strong="H2896"\w* calidad. \w La|strong="H5921"\w* realzó \w con|strong="H5921"\w* palmeras \w y|strong="H5921"\w* cadenas.  
\v 6 Para adornarla, \w cubrió|strong="H6823"\w* la \w Casa|strong="H1004"\w* de piedras \w preciosas|strong="H3368"\w*. El \w oro|strong="H2091"\w* era de Parvaim.  
\v 7 Recubrió \w con|strong="H5921"\w* \w oro|strong="H2091"\w* \w las|strong="H5921"\w* vigas, \w las|strong="H5921"\w* entradas, \w las|strong="H5921"\w* paredes \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w puertas|strong="H1817"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w*. Talló \w querubines|strong="H3742"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* paredes.   
\p
\v 8 Construyó \w el|strong="H5921"\w* Lugar \w Santísimo|strong="H6944"\w* cuya longitud era \w de|strong="H5921"\w* nueve metros, \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w anchura|strong="H7341"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w*. \w Lo|strong="H5921"\w* recubrió \w con|strong="H5921"\w* 19,8 toneladas \w de|strong="H5921"\w* \w oro|strong="H2091"\w* fino.  
\v 9 El \w peso|strong="H4948"\w* de los clavos fue 550 gramos de \w oro|strong="H2091"\w*. También recubrió de \w oro|strong="H2091"\w* los aposentos.   
\p
\v 10 Dentro del Lugar \w Santísimo|strong="H6944"\w* \w hizo|strong="H6213"\w* \w dos|strong="H8147"\w* \w querubines|strong="H3742"\w* de madera y los recubrió de \w oro|strong="H2091"\w*.  
\v 11 Las \w alas|strong="H3671"\w* \w de|strong="H2568"\w* los \w querubines|strong="H3742"\w* tenían nueve metros \w de|strong="H2568"\w* longitud. Cada \w ala|strong="H3671"\w* tenía 2,25 metros \w de|strong="H2568"\w* longitud. Cada \w querubín|strong="H3742"\w* \w tocaba|strong="H5060"\w* la \w pared|strong="H7023"\w* \w de|strong="H2568"\w* la \w Casa|strong="H1004"\w* \w con|strong="H5060"\w* un \w ala|strong="H3671"\w*, y \w con|strong="H5060"\w* la otra al otro \w querubín|strong="H3742"\w*.  
\v 12 El otro \w querubín|strong="H3742"\w* tenía la misma posición por el otro lado.  
\v 13 \w Las|strong="H1992"\w* \w alas|strong="H3671"\w* \w de|strong="H5921"\w* \w estos|strong="H1992"\w* \w querubines|strong="H3742"\w* \w se|strong="H1992"\w* \w extendían|strong="H6566"\w* nueve metros. \w Ellos|strong="H1992"\w* \w estaban|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H7272"\w*, \w con|strong="H5921"\w* \w sus|strong="H1992"\w* \w rostros|strong="H6440"\w* vueltos \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* Lugar Santísimo.   
\p
\v 14 \w Hizo|strong="H6213"\w* también \w el|strong="H5921"\w* velo \add de tela\add* azul, púrpura, \w carmesí|strong="H3758"\w* \w y|strong="H5921"\w* lino fino. Bordó \w querubines|strong="H3742"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*.   
\p
\v 15 \w Delante|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w hizo|strong="H6213"\w* también \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w columnas|strong="H5982"\w* \w de|strong="H5921"\w* 15,75 metros \w de|strong="H5921"\w* altura, \w las|strong="H5921"\w* cuales tenían \w arriba|strong="H7218"\w* capiteles \w de|strong="H5921"\w* 2,25 metros.  
\v 16 \w Hizo|strong="H6213"\w* \w cadenillas|strong="H8333"\w* \w como|strong="H5921"\w* collares \w y|strong="H5921"\w* \w las|strong="H5921"\w* colocó \w en|strong="H5921"\w* \w la|strong="H5921"\w* parte superior \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*. \w Hizo|strong="H6213"\w* 100 \w granadas|strong="H7416"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* colocó \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w cadenillas|strong="H8333"\w*.  
\v 17 Puso \w las|strong="H5921"\w* \w columnas|strong="H5982"\w* \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w Templo|strong="H1964"\w*, una \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w* \w y|strong="H5921"\w* otra \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w izquierda|strong="H8040"\w*. \w Llamó|strong="H7121"\w* \w la|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w* Jaquín \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w izquierda|strong="H8040"\w* \w Boaz|strong="H1162"\w*.   
\c 4  
\s1 Mobiliario de la Casa  
\p
\v 1 \w Hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w altar|strong="H4196"\w* de bronce de nueve metros de longitud y de \w anchura|strong="H7341"\w*, y 4,5 metros de \w altura|strong="H6967"\w*.  
\v 2 \w Hizo|strong="H6213"\w* también \w el|strong="H6213"\w* \w mar|strong="H3220"\w* circular \w de|strong="H2568"\w* fundición \w de|strong="H2568"\w* 4,5 metros \w de|strong="H2568"\w* borde \w a|strong="H3068"\w* borde, 2,25 metros \w de|strong="H2568"\w* alto y 13,5 metros \w de|strong="H2568"\w* circunferencia.  
\v 3 \w Debajo|strong="H8478"\w* del \w mar|strong="H3220"\w* había figuras \w de|strong="H8478"\w* calabazas, \w diez|strong="H6235"\w* \w por|strong="H8478"\w* \w cada|strong="H6235"\w* 45 centímetros \w alrededor|strong="H5439"\w*. Eran \w dos|strong="H8147"\w* hileras \w de|strong="H8478"\w* calabazas fundidas juntamente con el \w mar|strong="H3220"\w*.   
\p
\v 4 \w Estaba|strong="H5975"\w* asentado \w sobre|strong="H5921"\w* 12 \w bueyes|strong="H1241"\w*: \w tres|strong="H7969"\w* \w miraban|strong="H6437"\w* \w al|strong="H5921"\w* \w norte|strong="H6828"\w*, \w tres|strong="H7969"\w* \w al|strong="H5921"\w* occidente, \w tres|strong="H7969"\w* \w al|strong="H5921"\w* sur, \w y|strong="H5921"\w* \w tres|strong="H7969"\w* \w al|strong="H5921"\w* \w oriente|strong="H4217"\w*. \w El|strong="H5921"\w* \w mar|strong="H3220"\w* \w estaba|strong="H5975"\w* asentado \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w y|strong="H5921"\w* \w todas|strong="H3605"\w* sus ancas \w estaban|strong="H5975"\w* \w hacia|strong="H5921"\w* \w adentro|strong="H1004"\w*.  
\v 5 El mar tenía 7,5 centímetros de espesor. Su borde tenía la forma como el borde de una copa, como una \w flor|strong="H6525"\w* de lirio. Su capacidad era de 66.000 litros.   
\p
\v 6 También \w hizo|strong="H6213"\w* \w diez|strong="H6235"\w* piletas, \w cinco|strong="H2568"\w* \w al|strong="H5930"\w* sur y \w cinco|strong="H2568"\w* \w al|strong="H5930"\w* norte, \w para|strong="H5414"\w* lavar y limpiar en ellas \w lo|strong="H6213"\w* que se ofrecía en \w holocausto|strong="H5930"\w*. Pero \w el|strong="H6213"\w* \w mar|strong="H3220"\w* era \w para|strong="H5414"\w* que los \w sacerdotes|strong="H3548"\w* se \w lavaran|strong="H7364"\w* en \w él|strong="H6213"\w*.   
\p
\v 7 \w Hizo|strong="H6213"\w* los \w diez|strong="H6235"\w* candelabros \w de|strong="H2568"\w* \w oro|strong="H2091"\w*, según \w lo|strong="H6213"\w* prescrito con respecto \w a|strong="H3068"\w* ellos. Los \w puso|strong="H5414"\w* en \w el|strong="H6213"\w* Santuario, \w cinco|strong="H2568"\w* \w a|strong="H3068"\w* la \w derecha|strong="H3225"\w* y \w cinco|strong="H2568"\w* \w a|strong="H3068"\w* la \w izquierda|strong="H8040"\w*.   
\p
\v 8 \w Hizo|strong="H6213"\w* \w diez|strong="H6235"\w* \w mesas|strong="H7979"\w* y las \w puso|strong="H3240"\w* en \w el|strong="H6213"\w* \w Templo|strong="H1964"\w*, \w cinco|strong="H2568"\w* \w a|strong="H3068"\w* la \w derecha|strong="H3225"\w* y \w cinco|strong="H2568"\w* \w a|strong="H3068"\w* la \w izquierda|strong="H8040"\w*. \w También|strong="H7979"\w* \w hizo|strong="H6213"\w* 100 \w tazones|strong="H4219"\w* \w de|strong="H2568"\w* \w oro|strong="H2091"\w*.   
\p
\v 9 Además \w hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w patio|strong="H2691"\w* de los \w sacerdotes|strong="H3548"\w* y \w el|strong="H6213"\w* \w gran|strong="H1419"\w* \w patio|strong="H2691"\w* con sus \w puertas|strong="H1817"\w*. Recubrió las \w puertas|strong="H1817"\w* de ambos de bronce.  
\v 10 \w Puso|strong="H5414"\w* el \w mar|strong="H3220"\w* en la esquina sureste \w de|strong="H5414"\w* la Casa.   
\p
\v 11 También \w hizo|strong="H6213"\w* los \w calderos|strong="H5518"\w*, las palas y los \w tazones|strong="H4219"\w*.  
\p \w Hiram|strong="H2438"\w* terminó de realizar la \w obra|strong="H4399"\w* que \w hizo|strong="H6213"\w* para \w el|strong="H6213"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* en la \w Casa|strong="H1004"\w* de \nd ʼElohim\nd*:  
\v 12 \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w columnas|strong="H5982"\w*, \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* parte superior \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*, \w los|strong="H5921"\w* collares \w para|strong="H5921"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w capiteles|strong="H3805"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w redes|strong="H3805"\w* \w que|strong="H5921"\w* \w cubrían|strong="H3680"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* \w capiteles|strong="H3805"\w*,  
\v 13 \w y|strong="H5921"\w* \w las|strong="H5921"\w* 400 \w granadas|strong="H7416"\w* \w para|strong="H5921"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w redes|strong="H3805"\w*: \w dos|strong="H8147"\w* hileras \w de|strong="H5921"\w* \w granadas|strong="H7416"\w* \w por|strong="H5921"\w* cada red \w para|strong="H5921"\w* \w cubrir|strong="H3680"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* esferas \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w capiteles|strong="H3805"\w* \w que|strong="H5921"\w* estaban \w en|strong="H5921"\w* \w la|strong="H5921"\w* parte superior \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w columnas|strong="H5982"\w*.   
\p
\v 14 \w Hizo|strong="H6213"\w* también \w las|strong="H5921"\w* \w basas|strong="H4350"\w* \w y|strong="H5921"\w* puso \w las|strong="H5921"\w* piletas \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w*,  
\v 15 el \w mar|strong="H3220"\w* con los 12 \w bueyes|strong="H1241"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* él,  
\v 16 \w los|strong="H3605"\w* \w calderos|strong="H5518"\w*, las palas y \w los|strong="H3605"\w* tenedores.  
\p \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* utensilios destinados \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H3605"\w* Hiram-abí \w hizo|strong="H6213"\w* para \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* eran de bronce abrillantado.  
\v 17 El \w rey|strong="H4428"\w* los fundió en tierra arcillosa en la llanura del \w Jordán|strong="H3383"\w*, entre Sucot y Seredata.  
\v 18 \w Salomón|strong="H8010"\w* \w hizo|strong="H6213"\w* \w tan|strong="H3966"\w* \w gran|strong="H3966"\w* cantidad \w de|strong="H3588"\w* \w estos|strong="H3605"\w* utensilios \w que|strong="H3588"\w* \w nunca|strong="H3808"\w* pudo ser averiguado \w el|strong="H3588"\w* \w peso|strong="H4948"\w* del bronce.   
\p
\v 19 \w El|strong="H5921"\w* \w rey|strong="H6213"\w* \w hizo|strong="H6213"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* utensilios \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd*, \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w*, \w las|strong="H5921"\w* \w mesas|strong="H7979"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* cuales \w se|strong="H5921"\w* ponían \w los|strong="H5921"\w* \w Panes|strong="H3899"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Presencia|strong="H6440"\w*,  
\v 20 \w y|strong="H1197"\w* los candelabros con sus \w lámparas|strong="H5216"\w* \w de|strong="H6440"\w* \w oro|strong="H2091"\w* \w puro|strong="H5462"\w* para que las encendieran \w delante|strong="H6440"\w* del Lugar Santísimo \w de|strong="H6440"\w* \w la|strong="H1197"\w* manera prescrita.   
\p
\v 21 Las \w flores|strong="H6525"\w*, las \w lámparas|strong="H5216"\w* y las tenazas \w se|strong="H1931"\w* hicieron de \w oro|strong="H2091"\w* purísimo.  
\v 22 Las despabiladeras, los \w tazones|strong="H4219"\w* para lavar, las \w cucharas|strong="H3709"\w* y los \w incensarios|strong="H4289"\w* eran de \w oro|strong="H2091"\w* \w puro|strong="H5462"\w*. La entrada de la \w Casa|strong="H1004"\w*, las \w puertas|strong="H1817"\w* \w interiores|strong="H6442"\w* de acceso al Lugar \w Santísimo|strong="H6944"\w* y las \w puertas|strong="H1817"\w* de entrada al salón principal del \w Templo|strong="H1964"\w* \add también\add* eran de \w oro|strong="H2091"\w*.   
\c 5  
\s1 Traslado del Arca  
\p
\v 1 Así se terminó \w la|strong="H3605"\w* \w obra|strong="H4399"\w* \w que|strong="H3605"\w* \w Salomón|strong="H8010"\w* \w hizo|strong="H6213"\w* \w para|strong="H5414"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H5414"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Salomón|strong="H8010"\w* introdujo \w los|strong="H3605"\w* objetos \w que|strong="H3605"\w* su padre \w David|strong="H1732"\w* consagró: \w la|strong="H3605"\w* \w plata|strong="H3701"\w*, \w el|strong="H3605"\w* \w oro|strong="H2091"\w* y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios. \w Los|strong="H3605"\w* depositó en \w el|strong="H3605"\w* tesoro \w de|strong="H5414"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H5414"\w* \nd ʼElohim\nd*.   
\p
\v 2 Después \w Salomón|strong="H8010"\w* reunió en Jerusalén \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w ancianos|strong="H2205"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* las \w tribus|strong="H4294"\w* y \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* casas paternas \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* para \w subir|strong="H5927"\w* \w el|strong="H1931"\w* Arca del \w Pacto|strong="H1285"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* desde \w la|strong="H1931"\w* \w Ciudad|strong="H5892"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* \w Sion|strong="H6726"\w*.  
\v 3 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres de \w Israel|strong="H3478"\w* \w se|strong="H1931"\w* congregaron ante \w el|strong="H1931"\w* \w rey|strong="H4428"\w* en \w la|strong="H1931"\w* \w solemnidad|strong="H2282"\w* del \w mes|strong="H2320"\w* \w séptimo|strong="H7637"\w*.   
\p
\v 4 Cuando \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* de \w Israel|strong="H3478"\w* llegaron, \w los|strong="H3605"\w* \w levitas|strong="H3881"\w* \w alzaron|strong="H5375"\w* \w el|strong="H3605"\w* Arca.  
\v 5 \w Los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w levitas|strong="H3881"\w* \w subieron|strong="H5927"\w* \w el|strong="H3605"\w* Arca, \w el|strong="H3605"\w* Tabernáculo de Reunión y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios \w sagrados|strong="H6944"\w* \w que|strong="H3605"\w* había dentro del Tabernáculo.  
\v 6 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w que|strong="H3808"\w* \w se|strong="H5921"\w* reunió \w con|strong="H5921"\w* \w él|strong="H5921"\w* \w delante|strong="H6440"\w* \w del|strong="H5921"\w* Arca \w sacrificaron|strong="H2076"\w* \w ovejas|strong="H6629"\w* \w y|strong="H5921"\w* becerros, \w los|strong="H5921"\w* cuales, \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* su gran cantidad \w no|strong="H3808"\w* \w se|strong="H5921"\w* pudieron \w contar|strong="H5608"\w* \w ni|strong="H3808"\w* calcular.   
\p
