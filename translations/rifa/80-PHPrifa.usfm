\id PHP
\h إِفِيلِيبِّيينْ
\toc1 إِفِيلِيبِّيينْ
\toc2 إِفِيلِيبِّيينْ
\toc3 فِيل.
\mt1 إِفِيلِيبِّيينْ
\c 1
\s1 أَسدْجمْ غَارْ ؤُمزْوَارُو ذ ثْژَادْجِيثْ أَكْ-ذ ؤُقَاذِي
\m 
\v 1 بُولُوسْ ذ ثِيمُوثِييُو، إِمْسخَّارنْ ن يَاسُوع لْمَاسِيحْ، إِ مَارَّا إِمْقدَّاسنْ ذِي يَاسُوع لْمَاسِيحْ إِنِّي إِدْجَانْ ذِي فِيلِيبِّي، أَكْ-ذ إِمْغَارنْ ذ إِمْسخَّارنْ \add ذِي ثْمسْمُونْثْ\add*:
\v 2 أَرْضَا أَذْ كِيومْ يِيڒِي، ؤُڒَا ذ ڒهْنَا زِي أَربِّي بَابَاثْنغْ، ؤُ زِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏2 \xt رُوم. 1‏:‏7؛ 1 بُط. 1‏:‏2. \x*
\b
\m 
\v 3 تّْقَاذِيغْ أَربِّي إِنُو ڒَامِي ذَايْومْ تّْفكَّارغْ ڒبْذَا، \x ◘ \xo 1:‏3 \xt أَفا. 1‏:‏15؛ كُول. 1‏:‏3؛ 1 تس. 1‏:‏2؛ 2 تس. 1‏:‏3. \x*
\v 4 مَاغَارْ ذِي كُوڒْ ثِيژَادْجِيثِينْ إِنُو خَاومْ، أَقَا كْسِيغْ س ڒْمعْرُوفْ س ڒفْرَاحثْ
\v 5 ذِي سِّيبّثْ ن ثْمُونْثْ نْومْ أَكْ-ذ لْ-إِنْجِيلْ، زڭْ وَاسّْ أَمزْوَارُو أَڒْ إِضَا.
\v 6 أَقَا تِّيقّغْ بلِّي ونِّي ذَايْومْ إِبْذَانْ ڒخْذَايمْ إِصبْحنْ، أَذْ ثنْثْ إِكمّڒْ أَڒْ أَسّْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏6 \xt يُوح. 6‏:‏29؛ 1 تس. 1‏:‏3. \x*
\v 7 إِشْنَا أَيِي أَذْ فكَّارغْ ذَايْومْ مَارَّا أَمُّو، مِينْزِي أَقَا كنِّيوْ غَارِي ذڭْ وُوڒْ إِنُو، خْمِي دْجِيغْ ذِي سّْنَاسڒْ ؤُڒَا خْمِي غَا أَوْثغْ خْ ثِيذتّْ ن لْ-إِنْجِيلْ، \add مِينْزِي\add* كنِّيوْ ثْشَارْشمْ أَكِيذِي ذِي أَرْضَا. \x ◘ \xo 1:‏7 \xt أَفا. 3‏:‏1؛ 4‏:‏1؛ كُول. 4‏:‏3، 18؛ 2 تِيم. 1‏:‏8. \x*
\v 8 مِينْزِي أَربِّي ذ أَشهَّاذْ إِنُو مشْحَاڒْ كنِّيوْ تّخْسغْ س ڒحْنُونشْثْ يُودْجْغنْ ن يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏8 \xt رُوم. 1‏:‏9؛ 9‏:‏1؛ 2 كُور. 1‏:‏23؛ 11‏:‏31؛ ڭال. 1‏:‏20؛ 1 تس. 2‏:‏5؛ 1 تِيم. 5‏:‏21؛ 2 تِيم. 4‏:‏1. \x*
\m 
\v 9 مَانْ أَيَا إِ تّْژَادْجِيغْ، أَقَا ثَايْرِي نْومْ أَذْ ثْفيّضْ أَطَّاسْ س وَاطَّاسْ ذِي ثُوسّْنَا ذ قَاعْ ڒفْهَامثْ ثَارُوحَانشْثْ،
\v 10 مَاحنْذْ أَذْ ثْفَارْزمْ مِينْ إِتّْڒِيقنْ، ؤُ مَاحنْذْ أَذْ ثِيڒِيمْ ثقُّورمْ ؤُ بْڒَا ڒْعِيبْ ذڭْ وَاسّْ ن لْمَاسِيحْ،
\v 11 ثشُّورمْ س ڒْغِيدْجثْ ن ثْسڭْذَا إِ يدْجَانْ ذِي يَاسُوع لْمَاسِيحْ إِ ؤُعُودْجِي ذ ؤُسمْغَارْ ن أَربِّي.
\b
\s1 پُولُوسْ ذِي ڒحْبسْ
\m 
\v 12 \add أَ\add* أَيْثْمَا، نشّْ خْسغْ أَذْ ثسّْنمْ بلِّي ثِيمسْڒَايِينْ إِ ذ أَيِي إِمْسَارنْ أَرْنِينْثْ عَاذْ ذِي ثُوزّڭَّارْثْ \add ن ثْبَارّحْثْ\add* ن لْ-إِنْجِيلْ،
\v 13 مِينْزِي ثتّْوَاسّنْ ثْمحْبَاسْثْ إِنُو زِي سِّيبّثْ ن لْمَاسِيحْ إِ قَاعْ إِنِّي إِدْجَانْ ذِي ڒقْصَارْ ن قَايْصَارْ ؤُ إِ قَاعْ مِينْ إِقِّيمنْ.
\v 14 أَزْينْ أَمقّْرَانْ ن وَاوْمَاثنْ ذِي سِيذِيثْنغْ، ؤُمِي دْجِيغْ ذِي ثْمحْبَاسْثْ، إِذْوڒْ غَارْسنْ تِّيقّثْ كْثَارْ ؤُشَا ذوْڒنْ زعّْمنْ سَّاوَاڒنْ أَوَاڒْ ن أَربِّي س ثرْيَاسْثْ كْثَارْ، بْڒَا ثِيڭّْوُوذِي. \x ◘ \xo 1:‏14 \xt أَفا. 3‏:‏13؛ 1 تس. 3‏:‏3. \x*
\v 15 شَا \add زَّايْسنْ\add* تّْبَارّْحنْ لْمَاسِيحْ زِي ڒحْسذْ ذ ؤُمْعَانذْ، مَاشَا شَا نّغْنِي عَاوذْ زِي نّيّثْ ثشْنَا ؤُ س ثَايْرِي،
\v 16 مِينْزِي نِيثْنِي سّْننْ أَقَا تّْوَاڭّغْ مَاحنْذْ أَذْ وْثغْ خْ لْ-إِنْجِيلْ.
\v 17 مَاشَا إِنِّي إِتّْبَارّْحنْ س لْمَاسِيحْ س ؤُمْعَانذْ، وَارْ ث تّڭّنْ س نّيّثْ ثشْنَا، مَاشَا تّخْسنْ أَذْ خَافِي أَرْنِينْ ڒْمحْنثْ إِ سّْنَاسڒْ إِنُو.
\m 
\v 18 س مَانْ أَيَا فَارّْهغْ، \add وَاهْ،\add* أَذْ فَارْحغْ: أَقَا إِتّْوَابَارّحْ لْمَاسِيحْ س إِبْرِيذنْ إِفَارْزنْ، مَا س إِجّْ ن لْغَارَاضْ نّغْنِي، نِيغْ س ثِيذتّْ.
\v 19 مِينْزِي سّْنغْ أَقَا ثِيمسْڒَايِينْ-أَ أَذْ إِڒِينْثْ إِ ثُوذَارْثْ إِ نشّْ س ثْژَادْجِيثْ نْومْ ؤُ س ثوْهِيبْثْ ن أَرُّوحْ ن يَاسُوع لْمَاسِيحْ، \x ◘ \xo 1:‏19 \xt ڒخ. 16‏:‏7؛ 2 كُور. 1‏:‏11. \x*
\v 20 مَاحنْذْ نشّْ، أَمْ سِيثِيمغْ ؤُ تّْرَاجِيغْ، وَارْ تّْسضْحِيغْ شَا خْ وَالُو، مَاشَا أَمْ ڒبْذَا، ؤُڒَا ذ ڒخُّو أَذْ إِتّْوَاسّمْغَارْ لْمَاسِيحْ س بْطَايْطَايْ ذِي أَرِّيمثْ إِنُو، مَا س ثُوذَارْثْ \add إِنُو\add* نِيغْ س ڒْموْثْ \add إِنُو\add*. \x ◘ \xo 1:‏20 \xt رُوم. 5‏:‏5. \x*
\v 21 مِينْزِي ثُوذَارْثْ إِنُو ذ لْمَاسِيحْ ؤُشَا ڒْموْثْ ذ أَرْبحْ إِ نشّْ.
\v 22 مَاشَا مَاڒَا ذِينْ ڒْغِيدْجثْ ذِي ثُوذَارْثْ-أَ ذِي أَرِّيمثْ زِي جِّيهثْ ن ڒْخذْمثْ إِنُو، \add خنِّي\add* وَارْ سِّينغْ مِينْ غَا خْضَارغْ.
\v 23 مَاغَارْ أَقَا أَيِي جَارْ ثْنَاينْ ن إِغزْذِيسنْ: ذَايِي مژْرِي مَاحنْذْ أَذْ رَاحغْ أَذْ إِڒِيغْ أَكْ-ذ لْمَاسِيحْ، مِينْزِي مَانْ أَيَا قَاعْ حْسنْ،
\v 24 مَاشَا أَغِيمِي ذِي أَرِّيمثْ إِتّْخصَّا عَاذْ كْثَارْ ذِي طّْوعْ نْومْ.
\v 25 ذ مَانْ أَيَا سّْنغْ نِيشَانْ، أَقَا أَذْ قِّيمغْ، \add وَاهْ،\add* أَذْ قِّيمغْ ذِي طّْوعْ ن ڒفْرَاحثْ نْومْ ؤُ مَاحنْذْ أَذْ إِڭْمَا لْ-إِيمَانْ نْومْ،
\v 26 حِيمَا، خْمِي د غَا يَاسغْ غَارْومْ عَاوذْ، أَقَا أَسمْغَارْ نْومْ ذِي لْمَاسِيحْ وَاهَا أَذْ إِفيّضْ، ؤُمِي نشّْ \add قِّيمغْ\add*.
\m 
\v 27 ؤُيُورمْ س ؤُوقَّارْ إِ ڒخْبَارْ أَصبْحَانْ ن لْمَاسِيحْ، حِيمَا، خْمِي د غَا يَاسغْ ؤُشَا أَذْ كنِّيوْ ژَترغْ ؤُڒَا خْمِي غَا غَابغْ، أَذْ زَّايْومْ سْڒغْ، أَقَا ثْبدّمْ نِيشَانْ ذڭْ إِجّْ ن أَرُّوحْ ؤُ س إِجّْ ن ڒعْمَارْ، ؤُشَا ثتّْغلّْبمْ س لْ-إِيمَانْ ذِي لْ-إِنْجِيلْ. \x ◘ \xo 1:‏27 \xt أَمز. 17‏:‏1؛ 1 كُور. 7‏:‏20؛ أَفا. 4‏:‏1؛ كُول. 1‏:‏10؛ 1 تس. 2‏:‏12؛ 4‏:‏1. \x*
\v 28 وَارْ تّڭّْوْذمْ شَاعمَّارْصْ زڭْ إِنِّي خَاومْ د-إِكَّارنْ. مَانْ أَيَا ذ أَعدْجمْ إِ نِيثْنِي غَارْ ؤُهلّكْ، مَاشَا إِ كنِّيوْ غَارْ ؤُسنْجمْ.
\v 29 مِينْزِي أَقَا إِمّوْشْ أَومْ زِي أَربِّي، وَارْ إِدْجِي أَذْ ثَامْنمْ ذِي لْمَاسِيحْ وَاهَا، مَاشَا عَاوذْ مَاحنْذْ أَذْ ثْمَارّْثمْ ذِي طّْوعْ نّسْ،
\v 30 ؤُ أَذْ ثكْسِيمْ أَمنْغِي، أَمْ مَامّشْ إِ ذ أَيِي ث ثژْرِيمْ ؤُشَا ڒخُّو أَقَا خَافِي ثسْڒِيمْ.
\b
\b
\c 2
\s1 أَوَاضعْ ن يَاسُوع لْمَاسِيحْ
\m 
\v 1 مَاڒَا خنِّي غَارْومْ شَا ن ؤُفوّجْ ذِي لْمَاسِيحْ، أَوَاڒنْ س ثَايْرِي إِ وُوڒْ، نِيغْ ثَامُونْثْ ن أَرُّوحْ، نِيغْ ڒحْنُونشْثْ ذِي ذَاخڒْ ذ أَرّحْمثْ،
\v 2 كمّْڒمْ ڒفْرَاحثْ إِنُو ؤُمِي غَا إِمُونْ أَرَّايْ نْومْ، أَذْ غَارْومْ ثِيڒِي ثَايْرِي ذ إِشْثنْ، ذ ڒعْمَارْ ذ إِجّنْ ؤُڒَا ذ ؤُخَارَّاصْ ذ إِجّنْ. \x ◘ \xo 2:‏2 \xt رُوم. 12‏:‏16؛ 15‏:‏5؛ 1 كُور. 1‏:‏10؛ فِيل. 3‏:‏16؛ 1 بُط. 3‏:‏8. \x*
\v 3 وَارْ تّڭّمْ شَا ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ س ؤُمْعَانذْ نِيغْ زِي ثُوفّثْ إِخْوَانْ، مَاشَا أجّْ كُوڒْ إِجّْ أَذْ إِوقَّارْ ونّغْنِي كْثَارْ زڭْ إِخفْ نّسْ س ؤُوَاضعْ. \x ◘ \xo 2:‏3 \xt رُوم. 12‏:‏10؛ 1 بُط. 5‏:‏5. \x*
\v 4 وَارْ إِخزَّارْ ؤُڒَا ذ إِجّْ غَارْ إِخفْ نّسْ وَاهَا، مَاشَا أجّْ كُوڒْ إِجّْ أَذْ إِخْزَارْ عَاوذْ غَارْ ونِّي ذ أَسْ يُوذْسنْ. \x ◘ \xo 2:‏4 \xt 1 كُور. 10‏:‏24؛ 13‏:‏5. \x*
\v 5 أجّْ أَذْ ذَايْومْ ثِيڒِي نّيّثْ إِ ثُوغَا عَاوذْ ذِي يَاسُوع لْمَاسِيحْ، \x ◘ \xo 2:‏5 \xt مت. 11‏:‏29؛ يُوح. 13‏:‏15؛ 1 بُط. 2‏:‏21؛ 1 يُوح. 2‏:‏6. \x*
\v 6 ونِّي، أَمْ إِدْجَا ذڭْ وَارْوَاسْ ن أَربِّي، وَارْ إِحْسِيبْ شَا ذ ثَاكشَّاضْثْ ؤُمِي إِمْقُودَّا أَكْ-ذ أَربِّي، \x ◘ \xo 2:‏6 \xt 2 كُور. 4‏:‏4؛ كُول. 1‏:‏15؛ عبر. 1‏:‏3. \x*
\v 7 مَاشَا إِسّخْوَا إِخفْ نّسْ، إِكْسِي صِّيفثْ ن ؤُمْسخَّارْ. نتَّا إِذْوڒْ ذڭْ وَارْوَاسْ ن بْنَاذمْ، ؤُشَا إِتّْوَافْ ذِي فُورْمَا ن بْنَاذمْ. \x ◘ \xo 2:‏7 \xt إِزهد. 8‏:‏6؛ مت. 20‏:‏28؛ يُوح. 13‏:‏14. \x*
\v 8 نتَّا إِسّْوَاضعْ إِخفْ نّسْ ؤُشَا إِذْوڒْ إِطَّاعْ أَڒْ ڒْموْثْ، \add وَاهْ،\add* أَڒْ ڒْموْثْ ن صَّالِيبْ. \x ◘ \xo 2:‏8 \xt عبر. 2‏:‏9، 14، 17؛ 4‏:‏15؛ 12‏:‏2. \x*
\v 9 س ؤُيَا إِسُّوعْڒَا إِ-ث أَربِّي قَاعْ سنّجْ ؤُشَا إِوْشَا أَسْ إِسمْ سنّجْ إِ كُوڒْ إِسمْ، \x ◘ \xo 2:‏9 \xt ڒخ. 2‏:‏33؛ عبر. 1‏:‏4. \x*
\v 10 حِيمَا ذڭْ يِيسمْ ن يَاسُوع أَذْ أَضَارنْ مَارَّا إِفَادّنْ نِّي إِدْجَانْ ذڭْ ؤُجنَّا ؤُ خْ ثمُّورْثْ ؤُ سَاذُو ثمُّورْثْ، \x ◘ \xo 2:‏10 \xt إِشا. 45‏:‏23؛ رُوم. 14‏:‏11. \x*
\v 11 ؤُ \add حِيمَا\add* أَذْ إِشْهذْ كُوڒْ إِڒسْ بلِّي يَاسُوع لْمَاسِيحْ ذ سِيذِي إِ ؤُعُودْجِي ن أَربِّي، بَابَاسْ. \x ◘ \xo 2:‏11 \xt يُوح. 13‏:‏13؛ 1 كُور. 8‏:‏6؛ 12‏:‏3. \x*
\b
\s1 ثِيفَاوِينْ ذِي دُّونشْثْ
\m 
\v 12 س ؤُينِّي، \add أَ\add* إِمْعِيزّنْ إِنُو، أَمْ مَامّشْ ثُوغَا ثطَّاعمْ ڒبْذَا، وَارْ إِدْجِي خْمِي أَكِيذْومْ دْجِيغْ وَاهَا، ڒخُّو عَاذْ كْثَارْ خْمِي خَاومْ إِ غَا أَڭّْوْجغْ، خذْممْ س ؤُفيّضْ إِ ثُوذَارْثْ نْومْ س ثِيڭّْوُوذِي ذ ثَارْجِيجَاثْ،
\v 13 مِينْزِي أَربِّي ذ ونِّي ذَايْومْ إِخدّْمنْ أَڒْ غَا ثخْسمْ ؤُ أَذْ ثڭّمْ مِينْ ذِي ثمّژْڒمْ كنِّيوْ. \x ◘ \xo 2:‏13 \xt 2 كُور. 3‏:‏5. \x*
\v 14 ڭّمْ مَارَّا بْڒَا ڒعْكَاسثْ ؤُ بْڒَا أَمْشُوبّشْ، \x ◘ \xo 2:‏14 \xt رُوم. 12‏:‏17؛ 1 بُط. 2‏:‏12؛ 4‏:‏9. \x*
\v 15 حِيمَا أَذْ ثِيڒِيمْ بْڒَا ڒْعِيبْ، أَمْ ثَارْوَا إِمزْذَاڭنْ ن أَربِّي إِنِّي إِزدّْغنْ ذِي ڒْوسْطْ ن جِّيڒْ إِعوّْجنْ ذ إِفَارْغنْ، ؤُ \add حِيمَا\add* أَذْ ثْبَانمْ جَارْ أَسنْ أَمْ ثْفَاوِينْ ذِي دُّونشْثْ، \x ◘ \xo 2:‏15 \xt أَوڒن. 4‏:‏18؛ مت. 5‏:‏14. \x*
\v 16 مَاحنْذْ أَذْ ثِيڒِيمْ ذِي طّْوعْ نْسنْ ذڭْ ومْشَانْ ن ثُوذَارْثْ، حِيمَا أَذْ غَارِي يِيڒِي ؤُسمْغَارْ ذڭْ وَاسّْ ن لْمَاسِيحْ، وَارْ ؤُيُورغْ بَاطڒْ نِيغْ خذْمغْ س وَالُو. \x ◘ \xo 2:‏16 \xt 2 كُور. 1‏:‏14؛ 1 تس. 2‏:‏19. \x*
\v 17 مَاشَا مَاڒَا تّتّْوَارُوشّغْ أَمْ يِيشْثْ ن ثوْهِيبْثْ \add ن ؤُسيّبْ\add* خْ ثْغَارْصْثْ ؤُ خْ ثْسخَّارْثْ ذِي طّْوعْ ن لْ-إِيمَانْ نْومْ، أَذْ فَارْحغْ عَاوذْ ؤُشَا أَذْ أَرشْقغْ أَكِيذْومْ مَارَّا. \x ◘ \xo 2:‏17 \xt 2 كُور. 7‏:‏4. \x*
\v 18 \add خنِّي ؤُڒَا ذ كنِّيوْ،\add* فَارْحمْ ؤُشَا فَارْحمْ عَاوذْ أَكِيذِي.
\b
\s1 ثِيمُوثِييُو ذ إِبَافْرُوذِيثُوسْ
\m 
\v 19 مَاشَا نشّْ سِّيثِيمغْ ذِي سِيذِيثْنغْ يَاسُوع أَذْ أَومْ د-سّكّغْ ثِيمُوثِييُو ذغْيَا، حِيمَا أَذْ إِڒِيغْ خْ ڒْخَاضَارْ إِنُو خْمِي غَا سّْنغْ أَمدُّورْ نْومْ. \x ◘ \xo 2:‏19 \xt ڒخ. 16‏:‏1؛ رُوم. 16‏:‏21؛ 1 تس. 3‏:‏2. \x*
\v 20 مِينْزِي وَارْ غَارِي ذَانِيثَا ؤُڒَا ذ إِجّنْ أَمْ نشّْ، ونِّي إِكسِّينْ س ومْنُوسْ خْ مَامّشْ إِفّغْ ؤُمدُّورْ نْومْ س شْضَارثْ.
\v 21 مِينْزِي مَارَّا يَارزُّونْ ذِي مِينْ نْسنْ، وَارْ إِدْجِي ذِي مِينْ إِدْجَانْ ن يَاسُوع لْمَاسِيحْ. \x ◘ \xo 2:‏21 \xt 1 كُور. 10‏:‏24؛ 13‏:‏5. \x*
\v 22 مَاشَا كنِّيوْ ثسّْنمْ ثَاقدْجبْثْ نّسْ، بلِّي ثُوغَا إِخدّمْ أَكِيذِي ذِي \add ثْبَارّحْثْ ن\add* ڒخْبَارْ أَصبْحَانْ أَمْ يِيجّْ ن مِّيسْ غَارْ بَابَاسْ.
\v 23 نشّْ سِّيثِيمغْ أَذْ غَارْومْ ث-إِ-د-سّكّغْ ذغْيَا، خْمِي غَا ژَترغْ مَامّشْ غَا إِفّغْ ؤُمدُّورْ إِنُو.
\v 24 مَاشَا تِّيقّغْ ذِي سِيذِي إِنُو، بلِّي عَاوذْ نشّْ أَذْ غَارْومْ د-أَسغْ ذغْيَا.
\m 
\v 25 مَاشَا إِتّْغِيڒْ أَيِي بلِّي ثُوغَا إِتّْخصَّا أَذْ د-أَومْ سّكّغْ ؤُمَا إِبَافْرُوذِيثُوسْ، ونِّي ذ أَمْعَاونْ إِنُو ذ أَمْسخَّارْ أَكِيذِي، مَاشَا نتَّا \add عَاوذْ\add* ذ رَّاسُولْ نْومْ ذ أَمْسخَّارْ نْومْ ذِي مِينْ حْذَاجغْ. \f ◼ \fr 2:‏25 \ft \bd ’رَّاسُولْ‘\bd* - نِيغْ ’أَمَازَانْ‘.\f*
\v 26 مِينْزِي ثُوغَا إِوحّشْ أَطَّاسْ أَذْ كنِّيوْ إِژَارْ مَارَّا، ؤُشَا ثُوغَا إِكْسِي س ومْنُوسْ مِينْزِي كنِّيوْ ثسْڒِيمْ بلِّي ثُوغَا إِهْڒشْ.
\v 27 س ثِيذتّْ، ثُوغَا إِهْڒشْ أَڒْ ڒْموْثْ، مَاشَا أَربِّي ثُوغَا يَارْحمْ إِ-ث، وَارْ إِدْجِي نتَّا وَاهَا، أَحقَّا ؤُڒَا ذ نشّْ، حِيمَا وَارْ غَارِي إِتِّيڒِي ؤُفقُّوصْ خْ ؤُفقُّوصْ.
\v 28 س ؤُينِّي سّكّغْ ث س ثَازْڒَا أَطَّاسْ، حِيمَا، خْمِي ث غَا ثْژَارمْ عَاوذْ، أَذْ ثْفَارْحمْ ؤُشَا أَذْ ذَايِي يِيڒِي ذْرُوسْ ن ومْنُوسْ.
\v 29 س ؤُينِّي قبْڒمْ ث ذِي سِيذِي، س مَارَّا ڒفْرَاحثْ، وقَّارمْ إِنِّي إِدْجَانْ أَمْ وَانِيثَا، \x ◘ \xo 2:‏29 \xt 1 كُور. 9‏:‏14؛ ڭال. 6‏:‏6؛ 1 تس. 5‏:‏12؛ 1 تِيم. 5‏:‏17؛ عبر. 13‏:‏17. \x*
\v 30 مِينْزِي خْ سِّيبّثْ ن ڒْخذْمثْ ن لْمَاسِيحْ، ثُوغَا إِقَارّبْ غَارْ ڒْموْثْ أَمْ إِسبّڒْ ثُوذَارْثْ ن يِيخفْ نّسْ، مَاحنْذْ أَذْ إِكمّڒْ مِينْ إِنقْصنْ ذِي ثْسخَّارْثْ نْومْ إِ نشّْ.
\b
\b
\c 3
\s1 أَضْفَارْ ن ؤُڒَاغِي ن أَربِّي
\m 
\v 1 س ؤُينِّي، \add أَ\add* أَيْثْمَا، فَارْحمْ ذِي سِيذِيثْنغْ. وَارْ خَافِي يوْعَارْ أَذْ أَومْ أَرِيغْ ثِيمسْڒَايِينْ-أَ ثْوَاڒَا نّغْنِيثْ، مِينْزِي أَذْ زَّايْسنْثْ ثتّْوَاحْضَامْ. \x ◘ \xo 3:‏1 \xt فِيل. 4‏:‏4؛ يَاع. 1‏:‏2؛ 1 بُط. 4‏:‏13. \x*
\m 
\v 2 حْضَامْ إِخفْ نْومْ زڭْ يِيطَانْ، حْضَامْ زڭْ إِخدَّامنْ إِعفَّاننْ، حْضَامْ زڭْ إِنِّي إِقطّْعنْ أَيْسُومْ. \x ◘ \xo 3:‏2 \xt إِشا. 56‏:‏10. \x*
\v 3 مِينْزِي نشِّينْ ذ أَخْثَانْ، \add نشِّينْ\add* إِنِّي إِتّْسخَّارنْ إِ أَربِّي س أَرُّوحْ، إِنِّي إِسّمْغَارَانْ ذِي يَاسُوع لْمَاسِيحْ، ؤُشَا وَارْ تِّيقّنْ شَا ذڭْ \add وخْثَانْ ن\add* ويْسُومْ \add ن بْنَاذمْ\add*. \x ◘ \xo 3:‏3 \xt أَعَوذ. 10‏:‏16؛ 30‏:‏6؛ إِرْم. 4‏:‏4؛ يُوح. 4‏:‏24؛ رُوم. 2‏:‏29؛ كُول. 2‏:‏11. \x*
\m 
\v 4 نشّْ زمَّارغْ أَذْ تِّيقّغْ ذڭْ ويْسُومْ \add إِنُو\add*، مِينْزِي مَاڒَا إِتّْغِيڒْ إِ حذْ أَذْ إِتِّيقّْ ذڭْ ويْسُومْ \add نّسْ\add*، نشّْ كْثَارْ: \x ◘ \xo 3:‏4 \xt 2 كُور. 11‏:‏21. \x*
\v 5 أَقَا أَيِي ذ أَمخْثَانْ زڭْ وَامِي غَارِي ثْمنْيَا ن وُوسَّانْ، زِي ڒْڭنْسْ ن إِسْرَائِيل، زڭْ أَيْثْ ن بِينْيَامِينْ، نشّْ ذ أَعِيبْرَانِي زڭْ إِعِيبْرَانِييّنْ، زِي جِّيهثْ ن شَّارِيعَا نشّْ ذ أَفَارِيسِي، \x ◘ \xo 3:‏5 \xt أَمز. 49‏:‏27؛ لَاوِي 12‏:‏3؛ ڒخ. 23‏:‏6؛ 2 كُور. 11‏:‏22. \x*
\v 6 زڭْ ؤُغزْذِيسْ ن شْضَارثْ ثُوغَا ذَارّْشغْ خْ ثْمسْمُونْثْ \add ن لْمَاسِيحْ\add*، زڭْ ؤُغزْذِيسْ ن ثْسڭْذَا ثنِّي ذِي شَّارِيعَا أَقَا أَيِي بْڒَا ڒْعِيبْ. \x ◘ \xo 3:‏6 \xt ڒخ. 8‏:‏3؛ 9‏:‏1؛ 22‏:‏3، 4؛ ڭال. 1‏:‏13؛ 1 تِيم. 1‏:‏13. \x*
\v 7 مَاشَا مِينْ ثُوغَا غَارِي أَرْبحْ، أَقَا ڭِّيغْ ث ذ ثَاخسَّارْثْ خْ سِّيبّثْ ن لْمَاسِيحْ. \x ◘ \xo 3:‏7 \xt مت. 13‏:‏44. \x*
\v 8 نشّْ ڭِّيغْ مَارَّا مَانْ أَيَا ذ ثَاخسَّارْثْ زِي سِّيبّثْ ن ثُوسّْنَا ن سِيذِي يَاسُوع لْمَاسِيحْ، ونِّي ذِي طّْوعْ نّسْ خْسَارغْ كُوڒْشِي، ڭِّيغْ ث أَمشْنَاوْ وفْرَاضْ يُورْصُوضنْ حِيمَا أَذْ أَربْحغْ لْمَاسِيحْ، \x ◘ \xo 3:‏8 \xt إِشا. 53‏:‏11؛ إِرْم. 9‏:‏22؛ يُوح. 17‏:‏3؛ كُول. 2‏:‏2. \x*
\v 9 مَاحنْذْ أَذْ تّْوَافغْ ذَايسْ، وَارْ إِدْجِي س ثْسڭْذَا ن إِخفْ إِنُو ثنِّي زِي شَّارِيعَا - مَاشَا أَكْ-ذ ثنِّي د-إِتّفّْغنْ زِي لْ-إِيمَانْ ن لْمَاسِيحْ، أَقَا-ت ذ ثَاسڭْذَا ثنِّي زِي أَربِّي - \x ◘ \xo 3:‏9 \xt رُوم. 1‏:‏17؛ 3‏:‏21. \x*
\v 10 حِيمَا أَمُّو إِ غَا سّْنغْ يَاسُوع ذ جّهْذْ ن ثْنُوكْرَا نّسْ، ؤُ \add مَاحنْذْ\add* أَذْ شَارْشغْ ذڭْ ؤُودّبْ نّسْ، أَذْ ذوْڒغْ ذڭْ وَارْوَاسْ ن ڒْموْثْ نّسْ، \x ◘ \xo 3:‏10 \xt رُوم. 8‏:‏17؛ 2 كُور. 4‏:‏10؛ 2 تِيم. 2‏:‏11، 12؛ 1 بُط. 4‏:‏13. \x*
\v 11 حِيمَا س شَا ن وبْرِيذْ أَذْ أَوْضغْ غَارْ ثْنُوكْرَا زِي ثَادَّارْثْ ن إِمتِّيننْ.
\m 
\v 12 نشّْ وَارْ تِّيوِيضغْ نِيغْ تّْوَاكمّْڒغْ عَاذْ، مَاشَا يمَّارغْ إِ مَانْ أَيَا، حِيمَا، مَاڒَا إِعدّڒْ، أَذْ طّْفغْ مِينْ خفْ إِ ذ أَيِي إِطّفْ يَاسُوع لْمَاسِيحْ.
\v 13 \add أَ\add* أَيْثْمَا، وَارْ ذ أَيِي إِتّْغِيڒْ أَقَا طّْفغْ ث، مَاشَا تّڭّغْ إِشْثْ ن ڒْحَاجّثْ: تُّوغْ مِينْ أَوَارْنِي أَيِي ؤُشَا أَذْ سّْوِيژّْضغْ إِخفْ إِنُو غَارْ مِينْ ذِينْ زَّاثِي.
\v 14 تِّيزَّارغْ غَارْ لْغَارَاضْ حِيمَا أَذْ طّْفغْ \add تَّاجْ ن\add* ؤُغلّبْ ن ثْڒَاغِيثْ يُوعْڒَانْ ن أَربِّي ثنِّي إِدْجَانْ ذِي يَاسُوع لْمَاسِيحْ. \x ◘ \xo 3:‏14 \xt 1 كُور. 9‏:‏24؛ 2 تِيم. 4‏:‏7. \x*
\m 
\v 15 أجّْ إِنِّي إِوْضنْ غَارْ ڒكْمَارثْ، أَذْ ركّْزنْ خنِّي ذِي ثْمسْڒَايِينْ-أَ. ؤُشَا مَاڒَا غَارْومْ نّيّثْ نّغْنِي ذِي شَا، أَقَا أَربِّي أَذْ أَومْ إِسّْشنْ مَانْ أَيَا عَاوذْ.
\v 16 مَاشَا أجّْ أَنغْ، حِيمَا أَذْ نَاوضْ غَارْ مَانْ أَيَا، أَذْ نُويُورْ ذڭْ وبْرِيذْ ذ إِجّنْ س إِخَارِيصّنْ نّغْ ذ إِجّنْ. \x ◘ \xo 3:‏16 \xt رُوم. 12‏:‏16؛ 15‏:‏5؛ 1 كُور. 1‏:‏10؛ ڭال. 6‏:‏16؛ فِيل. 2‏:‏2؛ 1 بُط. 3‏:‏8. \x*
\v 17 ضْفَارمْ أَيِي-د، \add أَ\add* أَيْثْمَا، كْسِيمْ ثِيوصَّافْ إِ إِنِّي يُويُورنْ عْلَاحْسَابْ أَمذْيَا إِ زَّايْنغْ ثژْرِيمْ. \x ◘ \xo 3:‏17 \xt 1 كُور. 4‏:‏16؛ 11‏:‏1؛ 1 تس. 1‏:‏6. \x*
\v 18 مِينْزِي أَقَا ذِينْ أَطَّاسْ إِنِّي يُويُورنْ وَارْ إِدْجِي أَمنِّي، نِّيغْ أَومْ ت أَطَّاسْ ن إِمُورنْ - ؤُشَا ڒخُّو أَذْ ت إِنِيغْ س إِمطَّاونْ - أَقَا أَثنْ ذ ڒْعذْيَانْ ن صَّالِيبْ ن لْمَاسِيحْ. \x ◘ \xo 3:‏18 \xt رُوم. 16‏:‏17. \x*
\v 19 أَنڭَّارُو نْسنْ ذ أَهلّكْ، أَربِّي نْسنْ ذ أَعذِّيسْ نْسنْ ؤُشَا أَعُودْجِي نْسنْ ذ أَبهْذڒْ نْسنْ، ؤُ نّيّثْ نْسنْ ذِي ثْمسْڒَايِينْ ن دُّونشْثْ.
\v 20 مَاشَا نشِّينْ نتّْسخَّارْ ذڭْ إِجنْوَانْ إِ زَّايسْ نتّْرَاجَا عَاوذْ ونِّي ذ أَنغْ إِتِّيشنْ ثُوذَارْثْ، سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، \x ◘ \xo 3:‏20 \xt 1 كُور. 1‏:‏7؛ 1 تس. 1‏:‏10؛ ثِيث. 2‏:‏13؛ عبر. 13‏:‏14. \x*
\v 21 ونِّي إِ غَا إِبدّْڒنْ أَرِّيمثْ نّغْ إِحبْضنْ، حِيمَا أَذْ ثذْوڒْ ذِي صِّيفثْ ن أَرِّيمثْ نّسْ إِعُودْجنْ، عْلَاحْسَابْ جّهْذْ نّسْ ثَامقّْرَانْثْ إِ زِي إِ غَا إِتّْوَاڭّْ مَارَّا مِينْ إِدْجَانْ سْوَادَّايْ نّسْ. \x ◘ \xo 3:‏21 \xt 1 كُور. 15‏:‏51؛ كُول. 3‏:‏4؛ 1 يُوح. 3‏:‏2. \x*
\b
\b
\c 4
\s1 أَوَاڒْ ذ ؤُسدْجمْ أَنڭَّارُو
\m 
\v 1 س ؤُيَا، \add أَ\add* أَيْثْمَا إِعِيزّنْ ذ إِغْڒَانْ، أَقَا كنِّيوْ ذ ڒفْرَاحثْ إِنُو ذ تَّاجْ إِنُو، بدّمْ خنِّي أَمُّو نِيشَانْ ذِي سِيذِيثْنغْ، \add أَ\add* إِمْعِيزّنْ إِنُو! \x ◘ \xo 4:‏1 \xt 1 تس. 2‏:‏19. \x*
\m 
\v 2 نشّْ تّْزَاوَاڭغْ زڭْ ؤُوُوذِييَا ذ سِينْثِيشِي، مَاحنْذْ أَذْ إِمُونْ أَرَّايْ نْسنْثْ ذِي سِيذِيثْنغْ.
\m 
\v 3 تّْزَاوَاڭغْ عَاوذْ زَّايكْ، \add أَ\add* أَمْعَاشَارْ أَمْثِيقِّي إِنُو، مَاحنْذْ أَذْ ثوْشذْ أَفُوسْ إِ ثِينِّي إِ إِخدّْمنْ أَكِيذِي خْ سِّيبّثْ ن \add ثْبَارّحْثْ ن\add* لْ-إِنْجِيلْ، ؤُڒَا أَكْ-ذ كْلِيمِينْسْ ذ إِمْسخَّارنْ إِنُو نّغْنِي، إِنِّي إِسْمَاونْ نْسنْ يُورَانْ ذڭْ وذْلِيسْ \add إِتّْوَانْضنْ\add* ن ثُوذَارْثْ. \x ◘ \xo 4:‏3 \xt ؤُف. 32‏:‏32؛ إِزهد. 69‏:‏29؛ أَسَا. 3‏:‏5؛ 20‏:‏12؛ 21‏:‏27. \x*
\m 
\v 4 فَارْحمْ ڒبْذَا ذِي سِيذِيثْنغْ، نشّْ قَّارغْ عَاوذْ: فَارْحمْ! \x ◘ \xo 4:‏4 \xt 1 تس. 5‏:‏16. \x*
\v 5 أَذْ يِيڒِي ؤُوَاضعْ نْومْ إِتّْوَاسّنْ غَارْ إِوْذَانْ مَارَّا. سِيذِيثْنغْ أَقَا يُوذسْ. \x ◘ \xo 4:‏5 \xt 1 كُور. 10‏:‏11؛ عبر. 10‏:‏25. \x*
\v 6 وَارْ كسِّيمْ شَا س ومْنُوسْ خْ وَالُو، مَاشَا أَذْ يِيڒِي مَارَّا مِينْ ثتَّارمْ ڒبْذَا إِتّْوَاسّنْ غَارْ أَربِّي س ثْژَادْجِيثْ ذ ثْكسِّيثْ ن ڒْمعْرُوفْ أَكْ-ذ ؤُقَاذِي. \x ◘ \xo 4:‏6 \xt إِزهد. 55‏:‏23؛ مت. 6‏:‏25؛ 1 تِيم. 6‏:‏8، 17؛ 1 بُط. 5‏:‏7. \x*
\v 7 ؤُشَا ڒهْنَا ن أَربِّي إِ إِعْذُونْ مَارَّا ڒفْهَامثْ أَذْ إِحْضَا ؤُڒَاونْ ذ إِخَارِّيصنْ نْومْ ذِي يَاسُوع لْمَاسِيحْ. \x ◘ \xo 4:‏7 \xt يُوح. 14‏:‏27؛ رُوم. 5‏:‏1؛ أَفا. 2‏:‏14. \x*
\m 
\v 8 غَارْ ؤُنڭَّارْ، \add أَ\add* أَيْثْمَا، مَارَّا مِينْ إِدْجَانْ ذ ثِيذتّْ، مَارَّا مِينْ إِقُّورنْ، مَارَّا مِينْ إِسڭّْذنْ، مَارَّا مِينْ إِزْذِيڭنْ، مَارَّا مِينْ إِعِيزّنْ، مَارَّا مِينْ غَارْ إِدْجَا ڒْحسّْ أَصبْحَانْ، ؤُ مَارَّا مِينْ غَا إِسْذَاهدْجنْ شَّانْ ذ ؤُسمْغَارْ، خَارْصمْ ذَايسْ. \x ◘ \xo 4:‏8 \xt رُوم. 13‏:‏13؛ 1 تس. 4‏:‏3، 4، 5. \x*
\v 9 مِينْ ثغْرِيمْ ؤُ ثْقبْڒمْ، مِينْ ثسْڒِيمْ ؤُ ثژْرِيمْ زَّايِي، ڭّمْ ث، ؤُشَا أَربِّي ن ڒهْنَا أَذْ كِيومْ يِيڒِي!
\b
\m 
\v 10 أَقَا فَارْحغْ أَطَّاسْ ذِي سِيذِيثْنغْ ؤُمِي ذَايْومْ إِدْجَا ومْنُوسْ مَاحنْذْ أَذْ أَيِي ثثْهِيلَّامْ، أَمْ مَامّشْ ذَايْومْ ث ثُوغَا \add قْبڒْ\add*، مَاشَا وَارْ ذ أَسْ ثُوفِيمْ مَامّشْ \add أَذْ ثڭّمْ\add*. \x ◘ \xo 4:‏10 \xt 2 كُور. 11‏:‏9. \x*
\v 11 وَارْ ت نِّيغْ، مِينْزِي نشّْ حْوَاجغْ شَا، مِينْزِي ڒمْذغْ أَذْ قنْعغْ مَامّشْ مَا د-ثُوسَا. \x ◘ \xo 4:‏11 \xt 1 تِيم. 6‏:‏6. \x*
\v 12 نشّْ أَقَا سّْنغْ ؤُمِي قَّارنْ دّدْجْ، ؤُشَا أَقَا سّْنغْ ؤُمِي قَّارنْ أَفيّضْ. مَانِي مَا ؤُ ذِي مَارَّا أَقَا ڒمْذغْ، أَمْ ذِي ثْيَاوَانْثْ، أَمْ ذِي ڒَاژْ أَمْ ذڭْ ؤُفيّضْ ؤُڒَا ذِي ڒغْبنْ. \x ◘ \xo 4:‏12 \xt 1 كُور. 4‏:‏11؛ 2 كُور. 11‏:‏27. \x*
\v 13 قدّغْ قَاعْ زِي لْمَاسِيحْ ونِّي ذ أَيِي إِوْشِينْ جّهْذْ.
\v 14 وَاخَّا أَمنِّي مْلِيحْ ڒَامِي ذ أَيِي ثوْشِيمْ أَفُوسْ ذِي ڒمْحَايمْ إِنُو.
\v 15 ثسّْنمْ عَاوذْ سِيمَانْثْ نْومْ، \add أَ\add* إِفِيلِيبِّييّنْ، بلِّي غَارْ ؤُمزْوَارُو ن \add ثْبَارّحْثْ ن\add* ڒخْبَارْ أَصبْحَانْ، ؤُمِي د-فّْغغْ زِي مَاكِيذُونِييَا، ؤُڒَا ذ إِشْثْ ن ثْمسْمُونْثْ وَارْ ثڭِّي أَكِيذِي ڒحْسَابْ خْ مِينْ وْشِينْ ذ مِينْ كْسِينْ، مْغِيرْ ثنِّي نْومْ وَاهَا. \x ◘ \xo 4:‏15 \xt 2 كُور. 11‏:‏9. \x*
\v 16 مِينْزِي عَاوذْ ذِي ثِيسَّالُونِيكَا ثسّكّمْ أَيِي-د مِينْ ذ أَيِي إِتّْخصَّانْ، إِجّْ ن ؤُمُورْ ؤُ إِجّْ ن ؤُمُورْ نّغْنِي.
\v 17 وَارْ أَرزُّوغْ أَذْ ذَايِي ثوْشمْ شَا، مَاشَا أَرزُّوغْ أَذْ ثْوسّعْ ڒْغِيدْجثْ نْومْ.
\v 18 نشّْ طّْفغْ كُوڒْشِي ؤُ غَارِي كُوڒْشِي س زّْيَاذَا، أَقَا جِّيوْنغْ. نشّْ كْسِيغْ مَارَّا مِينْ ذ أَيِي د-ثسّكّمْ س ؤُفُوسْ ن إِبَافْرُوذِيثُوسْ: إِشْثْ ن ڒفْوَاحثْ إِتّْفُوحنْ ذ إِشْثْ ن ثْغَارْصْثْ يَارْضَانْ قِيبَاتْشْ إِ أَربِّي. \x ◘ \xo 4:‏18 \xt عبر. 13‏:‏16. \x*
\b
\m 
\v 19 مَاشَا أَربِّي إِنُو أَذْ إِسّْيِيونْ مَارَّا مِينْ ثحْذَاجمْ عْلَاحْسَابْ أَڭْڒَا نّسْ ذڭْ ؤُعُودْجِي إِ إِدْجَانْ ن يَاسُوع لْمَاسِيحْ.
\v 20 أَقَا إِ أَربِّي، بَابَاثْنغْ، أَذْ غَارسْ يِيڒِي ؤُعُودْجِي ذ شَّانْ إِ ڒبْذَا قَاعْ. أَمِينْ.
\b
\m 
\v 21 سدْجْممْ خْ كُوڒْ إِمْقدَّاسنْ ذِي يَاسُوع لْمَاسِيحْ س ڒهْنَا.
\m أَوْمَاثنْ إِنِّي أَكِيذِي، تّْسدْجَامنْ خَاومْ س ڒهْنَا.
\m 
\v 22 أَقَا مَارَّا إِمْقدَّاسنْ تّْسدْجَامنْ خَاومْ س ڒهْنَا، أَمزْوَارُو إِنِّي إِدْجَانْ زِي ثَادَّارْثْ ن قَايْصَارْ.
\m 
\v 23 أَرْضَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَذْ يِيڒِي أَكِيذْومْ مَارَّا. أَمِينْ. 
