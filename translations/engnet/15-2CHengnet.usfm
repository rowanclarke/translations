\v 11 \w God|strong="H3808"\w* said \w to|strong="H1961"\w* \w Solomon|strong="H8010"\w*, “\w Because|strong="H5921"\w* \w you|strong="H5921"\w* \w desire|strong="H5315"\w* \w this|strong="H2063"\w*, \w and|strong="H3117"\w* \w did|strong="H5971"\w* \w not|strong="H3808"\w* \w ask|strong="H7592"\w* \w for|strong="H5921"\w* \w riches|strong="H6239"\w*, \w wealth|strong="H6239"\w*, \w and|strong="H3117"\w* \w honor|strong="H3519"\w*, \w or|strong="H3808"\w* \w for|strong="H5921"\w* \w vengeance|strong="H7592"\w* \w on|strong="H5921"\w* \w your|strong="H5921"\w* \w enemies|strong="H8130"\w*, \w and|strong="H3117"\w* \w because|strong="H5921"\w* \w you|strong="H5921"\w* \w did|strong="H5971"\w* \w not|strong="H3808"\w* \w ask|strong="H7592"\w* \w for|strong="H5921"\w* \w long|strong="H3117"\w* \w life|strong="H5315"\w*, \w but|strong="H3808"\w* \w requested|strong="H7592"\w* \w wisdom|strong="H2451"\w* \w and|strong="H3117"\w* discernment \w so|strong="H1961"\w* \w you|strong="H5921"\w* \w can|strong="H3808"\w* \w make|strong="H4427"\w* judicial decisions \w for|strong="H5921"\w* \w my|strong="H5921"\w* \w people|strong="H5971"\w* \w over|strong="H5921"\w* \w whom|strong="H5971"\w* \w I|strong="H3117"\w* \w have|strong="H1961"\w* \w made|strong="H4427"\w* \w you|strong="H5921"\w* \w king|strong="H4427"\w*,
