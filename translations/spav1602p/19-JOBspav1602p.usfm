\v 4 \w Sea|strong="H1961"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w sombrío|strong="H2822"\w*, \w y|strong="H5921"\w* Dios \w no|strong="H1961"\w* \w cuide|strong="H1875"\w* \w de|strong="H5921"\w* \w él|strong="H1931"\w* \w desde|strong="H5921"\w* \w arriba|strong="H4605"\w*, ni \w claridad|strong="H5105"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w* \w resplandezca|strong="H3313"\w*.
