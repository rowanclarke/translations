\v 7 \w Then|strong="H2009"\w* \w he|strong="H2088"\w* led \w me|strong="H7725"\w* \w to|strong="H7725"\w* \w the|strong="H7725"\w* \w bank|strong="H8193"\w* \w of|strong="H6086"\w* \w that|strong="H2088"\w* \w river|strong="H5158"\w*. \w There|strong="H2009"\w* \w I|strong="H2009"\w* \w saw|strong="H2009"\w* \w many|strong="H7227"\w* \w trees|strong="H6086"\w* growing \w on|strong="H7725"\w* \w each|strong="H2088"\w* \w side|strong="H2088"\w* \w of|strong="H6086"\w* \w the|strong="H7725"\w* \w river|strong="H5158"\w*.  
