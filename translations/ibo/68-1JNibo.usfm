\id 1JN - Biblica® Open Igbo Contemporary Bible 2020 
\h 1 Jọn 
\toc1 1 Jọn 
\toc2 1 Jọn 
\toc3 1Jọn 
\mt1 1 Jọn 
\c 1  
\s1 Okwu nke ndụ 
\p  
\v 1 Ihe anyị na-edere unu banyere ya bụ ihe ahụ na-adịrị site na mmalite, nke anyị nụrụ, nke anyị jikwa anya anyị hụ, nke anyị lekwasịrị anya, na nke aka anyị metụrụ. Anyị na-ekwu ihe banyere Okwu nke ndụ ahụ.  
\v 2 Ndụ ahụ pụtara ihe. Anyị ahụla ya ma gbaakwa ama banyere ya. Ya mere, ihe anyị na-ekwu okwu ya, na ihe anyị na-akọrọ unu bụ banyere ndụ ebighị ebi ahụ nke ya na Nna nọ na mbụ; nke e mere ka ọ pụta ìhè nye anyị.  
\v 3 Anyị na-ekwusara unu ihe anyị hụrụ na nke anyị nụrụ, ka unu soro anyị nwee nnwekọ. Nʼezie nnwekọ anyị bụ nke anyị na Nna na nke Ọkpara ya bụ Jisọs Kraịst, na-enwekọ.  
\v 4 Anyị na-edere unu ihe ndị a nʼihi ime ka ọṅụ anyị zuo oke. 
\s1 Ìhè na Ọchịchịrị 
\p  
\v 5 Nke a bụ ozi ahụ anyị nụrụ site nʼaka ya, nke anyị na-ekwusakwara unu. Chineke bụ ìhè, ọchịchịrị ọbụla adịghịkwa nʼime ya.  
\v 6 Ya mere ọ bụrụ na anyị asị na anyị na ya nọ nʼezi nnwekọ ma na-ebi nʼime ọchịchịrị, ọ bụ okwu ụgha ka anyị na-ekwu. Eziokwu ahụ adịghịkwa nʼime anyị.  
\v 7 Ma ọ bụrụ na anyị na-ebi ndụ anyị nʼìhè, dị ka ya onwe ya si nọọ nʼìhè, mgbe ahụ anyị na ibe anyị na-enwe ezi nnwekọ. Ọbara Jisọs bụ Ọkpara ya na-asachapụkwa anyị mmehie anyị niile. 
\p  
\v 8 Ma ọ bụrụ na anyị asị na anyị adịghị eme mmehie, anyị na-eduhie onwe anyị, na-ajụkwa ịnabata eziokwu ahụ nʼime anyị.  
\v 9 Ma ọ bụrụ na anyị ekwupụta mmehie anyị, onye ahụ kwesiri ntụkwasị obi na onye ezi omume, ọ ga-agbaghara anyị mmehie anyị niile, sachapụkwa anyị site nʼajọ omume anyị niile.  
\v 10 Ọ bụrụ na anyị asị na anyị emeghị mmehie ọbụla, anyị na-akpọ ya onye na-ekwu okwu ụgha, okwu ya enwekwaghị ọnọdụ nʼime anyị. 
\c 2  
\p  
\v 1 Ezi ụmụntakịrị m, ana m edere unu ihe ndị a ka unu ghara imehie. Ma ọ bụrụ na onye ọbụla emehie, anyị nwere onye na-ekwuchite ọnụ anyị nʼihu Nna ahụ. Ọ bụ Jisọs Kraịst, Onye ezi omume ahụ.  
\v 2 Ọ bụ onye jiri onwe ya chụọ aja nʼihi ikpuchiri anyị mmehie anyị, ma ọ bụghị naanị nʼihi mmehie anyị, ọ bụkwa nʼihi mmehie ụwa niile. 
\s1 Ịhụnanya na Ịkpọ asị 
\p  
\v 3 Otu a ka anyị si amata na anyị maara onye ọ bụ, ma ọ bụrụ na anyị erube isi nye iwu ya niile.  
\v 4 Onye ahụ na-ekwu sị, “Amaara m ya,” ma ọ dịghị eme ihe o nyere nʼiwu bụ onye okwu ụgha, eziokwu ahụ adịghịkwa nʼime ya.  
\v 5 Ma ọ bụrụ na onye ọbụla na-erube isi nʼokwu ya, nʼezie, ịhụnanya Chineke bụ ihe emere ka o zuo oke nʼime ya. Ọ bụ otu a ka anyị si amata na anyị nọ nʼime ya.  
\v 6 Onye ọbụla na-ekwu na ya bi nʼime ya kwesiri ibi ndụ dịka ya. 
\p  
\v 7 Ndị enyi m hụrụ nʼanya, anaghị m edere unu ihe gbasara iwu ọhụrụ, kama ọ bụ otu iwu ochie ahụ, nke na-adị site na mbụ. Iwu ochie a bụ nke e ziri unu ozi banyere ya.  
\v 8 Ma otu ọ dị, ana m edere unu iwu ọhụrụ, nke bụ eziokwu nʼime ya na nʼime unu. Nʼihi na ọchịchịrị na-agafe, ezi ìhè ebidola ịchawapụta. 
\p  
\v 9 Onye ọbụla na-asị na ya nọ nʼìhè ma na-akpọ nwanna ya asị, na-anọ nʼọchịchịrị ruo ugbu a.  
\v 10 Onye ọbụla na-ahụ nwanna ya nʼanya na-ebi nʼime ihe ahụ ọ dịkwaghị ìhè dị nʼime onye dị otu a bụ nke ga-eme ya ka ọ sụọ ngọngọ.  
\v 11 Ma onye ọbụla na-akpọ nwanna ya asị nọ nʼọchịchịrị, na-ejegharịkwa nʼime ọchịchịrị; ọ maghị ebe ọ na-aga nʼihi na ọchịchịrị ahụ emeela ka o kpuo ìsì. 
\s1 Ihe mere e jiri dee ihe ndị a 
\q1  
\v 12 Ana m edere unu ihe ndị a ụmụntakịrị m 
\q2 nʼihi na a gbagharala unu mmehie niile site nʼaha ya. 
\q1  
\v 13 Ana m edere unu ndị bụ nna ihe ndị a, 
\q2 nʼihi na unu maara onye ahụ na-adị site na mbụ. 
\q1 Ana m edere unu ụmụ okorobịa, 
\q2 nʼihi na unu emeriela ajọ onye ahụ. 
\b  
\q1  
\v 14 Ana m edere unu ụmụntakịrị, 
\q2 nʼihi na unu maara nna ahụ. 
\q1 Ana m edere unu ndị nna, 
\q2 nʼihi na unu maara onye ahụ na-adị site na mbụ. 
\q1 Ana m edere unu ụmụ okorobịa, 
\q2 nʼihi na unu siri ike, 
\q2 okwu Chineke na-ebikwa nʼime unu, 
\q2 unu emeriekwala ajọ onye ahụ. 
\s1 Unu ahụla ụwa nʼanya 
\p  
\v 15 Kwụsịnụ ịhụ ụwa nʼanya, ya na ihe niile dị nʼụwa. Ọ bụrụ na onye ọbụla ahụ ụwa nʼanya ịhụnanya nke Nna adịghị nʼime ya.  
\v 16 Nʼihi na ihe niile dị nʼụwa, ihe ndị ahụ niile anụ ahụ anyị, na anya anyị na-achọ, ya na ịnya isi mmadụ banyere ihe ọ bụ na ihe o nwere, esiteghị nʼebe Nna nọ, kama ha sitere nʼụwa.  
\v 17 Ụwa na ọchịchọ ọjọọ ya niile na-agafe agafe, ma onye ahụ na-eme uche Chineke ga-adị ndụ ruo mgbe ebighị ebi. 
\s1 Onye iro Kraịst 
\p  
\v 18 Ụmụ m, nke a bụ oge awa nke ikpeazụ. Dịka unu nụrụ na otu onye na-emegide Kraịst na-abịa, ọ bụladị ugbu a, ọtụtụ ndị na-emegide Kraịst abịala. Otu a ka anyị si amata na ọ bụ oge awa nke ikpeazụ.  
\v 19 Ha si nʼetiti anyị pụọ, ma ha abụghị ndị nke anyị nʼezie. Nʼihi na a sị na anyị na ha bụ otu, ha gaara aga nʼihu soro anyị nọdụ. Ma ọpụpụ ha pụrụ na-egosi na ọ dịghị onye nʼime ha sonyere anyị. 
\p  
\v 20 Ma unu nwere otite mmanụ sitere nʼOnye Nsọ ahụ, unu niile matakwara ihe niile.  
\v 21 Ya mere, anaghị m edegara unu akwụkwọ a dịka ndị na-amaghị eziokwu kama nʼihi na unu maara ya na nʼihi na ọ dịghị okwu ụgha ọbụla na-esi nʼeziokwu ahụ apụta.  
\v 22 Onye bụ onye okwu ụgha? Ọ bụ onye ahụ na-asị na Jisọs abụghị Kraịst ahụ. Onye dị otu a bụ onye na-emegide Kraịst, nʼihi na ọ nabataghị Nna ahụ na Ọkpara ya.  
\v 23 Onye ọbụla jụrụ Ọkpara ahụ enwekwaghị Nna ahụ; ma onye ọbụla nabatara Ọkpara ahụ nwekwara Nna ahụ. 
\p  
\v 24 Hụnụ na ihe unu nụrụ site na mmalite na-anọgide nʼime unu. Ọ bụrụ na ihe unu nụrụ na mbido ebiri nʼime unu, unu ga-anọgide nʼime Ọkpara ahụ na nʼime Nna ahụ.  
\v 25 Ihe o kwere anyị na nkwa bụ nke a, ndụ ebighị ebi. 
\p  
\v 26 Ana m edere unu ihe ndị a banyere ndị ahụ na-agbalị iduhie unu.  
\v 27 Ma unu onwe unu, otite mmanụ ahụ unu natara nʼaka ya na-anọgide nʼime unu, nʼihi nke a, onye ozizi ọzọ adịghị unu mkpa. Dịka otite mmanụ ya na-ezi unu ihe banyere ihe niile, bụrụkwa eziokwu, ọ bụghị okwu ụgha. Ya mere, dịka o zikwara unu, na-anọgidenụ nʼime ya. 
\s1 Ụmụ Chineke 
\p  
\v 28 Ugbu a ụmụntakịrị m, nọgidesienụ ike nʼime ya, ka ọ ga-abụ mgbe e mere ka ọ pụta ìhè, anyị ga-abụ ndị obi siri ike, ndị ihere na-agaghị eme, nʼihu ya mgbe ọ bịara. 
\p  
\v 29 Ọ bụrụ na unu matara na ọ bụ onye ezi omume, unu maara na onye ọbụla nke na-eme ihe ziri ezi bụ onye a mụrụ site na ya. 
\c 3  
\s1 Ibi ndụ dị ka ụmụ Kraịst 
\p  
\v 1 Lee ụdị oke ịhụnanya nke Nna ahụ nwere nʼebe anyị nọ, na-aga akpọ anyị ụmụ Chineke. Nʼezie, nke a bụ ihe anyị bụ. Ihe mere na ụwa amaghị anyị bụ nʼihi na ọ maghị ya.  
\v 2 Ndị hụrụ nʼanya, ugbu a anyị abụrụla ụmụ Chineke. Ọ bụ ezie na anyị enweghị ike ịghọta ihe ọnọdụ anyị ga-abụ nʼoge dị nʼihu, ma anyị maara nke ọma na mgbe a ga-eme ka ọ pụta ìhè, a ga-emekwa ka anyị bụrụ ndị yiri ya, nʼihi na anyị ga-ahụ ya dịka ọ dị.  
\v 3 Onye ọbụla nwere olileanya dị otu a kwesiri idebe onwe ya ọcha, dị ka ya onwe ya dị ọcha. 
\p  
\v 4 Onye ọbụla na-eme mmehie na-emebi iwu. Nʼezie mmehie bụ mmebi iwu.  
\v 5 Unu maara na e mere ka ọ pụta ìhè iwepụ mmehie. Ọ dịkwaghị mmehie ọbụla dị nʼime ya.  
\v 6 Onye ọbụla na-anọgide nʼime ya adịghị ebi ndụ ime mmehie, onye ọbụla nke na-ebi ndụ mmehie ahụbeghị ya anya mgbe ọbụla, ọ matabekwaghị ya. 
\p  
\v 7 Ezigbo ụmụ m, unu ekwela ka onye ọbụla duhie unu, onye ọbụla na-eme ezi ihe bụ onye ezi omume dị ka ya onwe ya bụ onye ezi omume.  
\v 8 Onye ọbụla na-eme mmehie bụ nwa ekwensu, nʼihi na ekwensu bụ onye mmehie site na mmalite. Ihe mere Ọkpara Chineke jiri pụta ìhè bụ ka ọ laa ọrụ niile nke ekwensu nʼiyi.  
\v 9 Onye a mụrụ site na Chineke adịghị anọgide na-eme mmehie, nʼihi na mkpụrụ Chineke na-anọgide nʼime ya, ha enweghị ike ịnọgide na-eme mmehie, nʼihi na a mụrụ ha site na Chineke.  
\v 10 Otu a ka anyị si amata ndị bụ ụmụ Chineke, na ndị bụ ụmụ ekwensu: Onye ọbụla na-adịghị eme ihe ziri ezi abụghị nwa Chineke, otu a ka ọ dịkwa onye na-adịghị ahụ ụmụnna ha nʼanya. 
\s1 Hụ mmadụ ibe gị nʼanya 
\p  
\v 11 Nʼihi na nke a bụ ozi ahụ unu nụrụ site na mmalite, ka anyị hụrịta onwe anyị nʼanya.  
\v 12 Ka anyị hapụ ịdị ka Ken, onye bụ nke ajọ onye ahụ, na onye gburu nwanne ya. Gịnị mere o ji gbuo ya? Ọ bụ nʼihi na ọrụ ya jọrọ njọ, ma nke nwanne ya ziri ezi.  
\v 13 Ka ọ gharakwa iju unu anya ụmụnna m, na ụwa kpọrọ unu asị.  
\v 14 Anyị matara na anyị esitela nʼọnwụ baa na ndụ nʼihi na anyị na-ahụ ụmụnna\f + \fr 3:14 \ft Maọbụ, \fqa anyị na-ahụrịta onwe anyị nʼanya\f* anyị nʼanya. Onye ọbụla na-adịghị ahụ ibe ya nʼanya na-anọgide nʼọnwụ.  
\v 15 Onye ọbụla na-akpọ nwanna ya asị bụ ogbu mmadụ, unu matakwara na o nweghị onye ọbụla bụ ogbu mmadụ nwere ndụ ebighị ebi nʼime ya. 
\p  
\v 16 Ọ bụ otu a ka anyị sị mata ihe bụ ịhụnanya, na Jisọs tọgbọrọ ndụ ya nʼihi anyị. Anyị kwesikwara ịtọgbọ ndụ anyị nʼihi ụmụnna anyị.  
\v 17 Ọ bụrụ na onye ọbụla nwere akụ nke ụwa, ahụ nwanna ya ka ọ nọ na mkpa ma o nweghị obi ebere nʼebe ọ nọ, olee otu ịhụnanya Chineke si dịrị nʼime ya?  
\v 18 Ụmụntakịrị m, ka ịhụnanya anyị ghara ịbụ naanị nʼegbugbere ọnụ maọbụ nke okwu efu, kama ka ọ bụrụ nke sitere nʼeziokwu nakwa nʼomume anyị. 
\p  
\v 19 Anyị ga-esitekwa na nke a mata na anyị bụ ndị nke eziokwu ahụ ma matakwa otu anyị ga-esi mee ka obi anyị kwenye nʼihu ya.  
\v 20 Nʼihi na ọ bụrụ na obi anyị amaa anyị ikpe, Chineke dị ukwuu karịa obi anyị, ọ mazukwara ihe niile.  
\v 21 Ndị m hụrụ nʼanya, ọ bụrụ na obi anyị amaghị anyị ikpe, anyị nwere nkwuwa okwu nʼihu Chineke  
\v 22 na-anatakwa ya ihe ọbụla anyị rịọrọ nʼihi na anyị na-erube isi nʼiwu ya, na-emekwa ihe na-atọ ya ụtọ.  
\v 23 Nke a bụkwa iwu ya: ka anyị kwere nʼaha Ọkpara ya Jisọs Kraịst, ya na ịhụrịta ibe anyị nʼanya dịka o nyere anyị nʼiwu.  
\v 24 Ndị niile na-erube isi nye iwu ya na-anọgidesikwa ike nʼime ya, ya onwe ya na-anọgidesikwa ike nʼime ndị ahụ! Otu a ka anyị si mara na ọ na-anọgidesike nʼime anyị: Ọ bụ site na Mmụọ nke o nyere anyị. 
\c 4  
\s1 Nwapụta mmụọ niile 
\p  
\v 1 Ndị enyi m hụrụ nʼanya, unu ekwenyela okwu mmụọ niile, kama nwaleenụ mmụọ niile ahụ i mata ma ha si na Chineke, nʼihi na ọtụtụ ndị amụma ụgha apụọla baa nʼime ụwa.  
\v 2 Otu a ka unu ga-esi mata Mmụọ nke Chineke: Mmụọ ọbụla nke na-ekwupụta na Jisọs Kraịst abịala nʼanụ ahụ sitere na Chineke.  
\v 3 Ma mmụọ ọbụla nke na-adịghị ekwupụta Jisọs esiteghị na Chineke, mmụọ dị otu a bụ nke onye ahụ na-emegide Kraịst nke unu nụrụ na ọ ga-abịa, ma ugbu a ọ bịala nʼụwa. 
\p  
\v 4 Ụmụntakịrị m, unu bụ ndị sitere na Chineke, unu emeriekwala ha nʼihi na onye ahụ nke bi nʼime unu dị ukwuu karịa onye ahụ nọ nʼime ụwa.  
\v 5 Nʼihi na ndị a si nʼime ụwa pụta. Ya mere, ihe ha na-ekwu okwu ya bụ naanị ihe banyere ụwa. Ụwa na-aṅakwa ha ntị.  
\v 6 Anyị sitere na Chineke, onye ọbụla maara Chineke na-ege anyị ntị, ma onye ọbụla na-esiteghị na Chineke anaghị ege anyị ntị. Ọ bụ otu a ka anyị si amata mmụọ eziokwu na mmụọ nke okwu ụgha. 
\s1 Chineke bụ ịhụnanya 
\p  
\v 7 Ndị m hụrụ nʼanya, o kwesiri ka anyị hụrịtaa onwe anyị nʼanya, nʼihi na ịhụnanya na-esi nʼebe Chineke nọ abịa. Onye ọbụla nwere ịhụnanya bụ onye amụrụ site na Chineke, ọ makwara Chineke.  
\v 8 Onye na-enweghị ịhụnanya amaghị Chineke, nʼihi na Chineke bụ ịhụnanya.  
\v 9 E siri otu a mee ka ịhụnanya Chineke nʼebe anyị nọ pụta ìhè: Chineke zitere naanị otu Ọkpara ya nʼụwa ka anyị nwee ndụ site na ya.  
\v 10 Nke a bụ ihe a na-akpọ ịhụnanya, ọ bụghị na anyị hụrụ Chineke nʼanya kama na ọ hụrụ anyị nʼanya ma zite Ọkpara ya dịka aja nke juru ya obi maka mmehie niile anyị.  
\v 11 Ndị m hụrụ nʼanya, ebe ọ bụ na Chineke si otu a hụ anyị nʼanya, anyị kwesiri ịhụrịta onwe anyị nʼanya.  
\v 12 O nwebeghị mgbe ọbụla anyị ji anya anyị hụ Chineke anya, ma ọ bụrụ na anyị ahụ ibe anyị nʼanya, Chineke na-ebi nʼime anyị. A na-emekwa ka ịhụnanya ya zuo oke nʼime anyị. 
\p  
\v 13 O tinyekwala Mmụọ Nsọ ya nʼime anyị igosi anyị na o bi nʼime anyị, na anyị bikwa nʼime ya.  
\v 14 Ma anyị onwe anyị ahụla ma na-agbakwa ama na Nna ahụ zitere Ọkpara ya ka ọ bụrụ Onye nzọpụta nke ụwa.  
\v 15 Chineke bi nʼime onye ọbụla nke na-ekwupụta na Jisọs bụ Ọkpara Chineke. Onye dị otu a bikwa nʼime Chineke.  
\v 16 Anyị maara ma kwerekwa nʼịhụnanya Chineke nwere nʼebe anyị nọ. 
\p Chineke bụ ịhụnanya. Onye ọ bụlakwa na-ebi ndụ ịhụnanya na-anọgide nʼime Chineke. Chineke nʼonwe ya na-ebinyekwara onye dị otu a.  
\v 17 Nʼụzọ dị otu a, a na-eme ka ịhụnanya zuo oke nʼetiti anyị, ka anyị nwee ike inwe nkwuwa okwu nʼụbọchị ikpe ahụ, nʼihi na dịka ya onwe ya dị, otu a ka anyị onwe anyị dịkwa nʼụwa nke a.  
\v 18 Ịtụ egwu adịghị nʼebe ịhụnanya dị, kama ịhụnanya zuruoke na-achụpụ egwu nʼihi na egwu na ntaramahụhụ na-arụkọ ọrụ, onye ọbụla nke na-atụ egwu bụ onye na-ezubeghị oke nʼịhụnanya. 
\p  
\v 19 Anyị hụrụ ya nʼanya nʼihi na o buru ụzọ hụ anyị nʼanya.  
\v 20 Onye ọbụla na-asị, “Ahụrụ m Chineke nʼanya,” ma nọgide na-akpọ nwanna ya asị, onye ahụ bụ onye ụgha. Nʼihi na ọ bụrụ na ọ hụghị nwanna ya nʼanya, bụ onye ọ na-ahụ anya kwa ụbọchị, ọ pụghị ịhụ Chineke nʼanya bụ onye ọ na-ahụbeghị anya.  
\v 21 Iwu o nyere anyị bụ, “Onye ọbụla hụrụ Chineke nʼanya aghakwaghị ịhụ nwanna ya nʼanya.” 
\c 5  
\s1 Okwukwe nʼime Ọkpara Chineke 
\p  
\v 1 Onye ọbụla kweere na Jisọs bụ Kraịst bụ onye amụrụ site na Chineke. Onye ọbụla nke hụkwara Nna nʼanya na-ahụkwa Ọkpara ya nʼanya.  
\v 2 Ọ bụ otu a ka anyị si amata na anyị hụrụ ụmụ Chineke nʼanya, mgbe anyị na-ahụ Chineke nʼanya, na-erubekwa isi nʼiwu ya niile.  
\v 3 Nke a bụ ịhụnanya Chineke, na anyị ga-edebe iwu ya. Iwu ya adịghịkwa arọ.  
\v 4 Nʼihi na onye ọbụla amụrụ site na Chineke na-emeri ụwa. Nke a bụkwa mmeri ahụ na-emeri ụwa, ọ bụladị okwukwe anyị.  
\v 5 Onye pụrụ imeri ụwa, ma ọ bụghị naanị onye ahụ kweere na Jisọs bụ Ọkpara Chineke? 
\p  
\v 6 Ọ bụ onye ahụ bịara site na mmiri na ọbara, ya bụ Jisọs Kraịst. O siteghị naanị na mmiri bịa, kama o sitere na mmiri na ọbara. Ọ bụkwa Mmụọ Nsọ na-agba ama maka ya, nʼihi na Mmụọ Nsọ bụ eziokwu.  
\v 7 Nʼihi na ha dị atọ gbara akaebe:  
\v 8 Mmụọ Nsọ,\f + \fr 5:8 \ft Nʼakwụkwọ ndị ọhụrụ nke Vụlget \fqa na-agba akaebe nʼeluigwe: Nna, Okwu ahụ na Mmụọ Nsọ, ha atọ bụ otu. \fv 8 \fv*\fqa Ha dịkwa atọ na-agba akaebe nʼụwa: \ft (nke a adịghị nʼakwụkwọ Griik ọbụla tupu senchuri nke iri na anọ)\f* na mmiri na ọbara, ha atọ kwekọrịtara.  
\v 9 Ọ bụrụ na anyị nabata akaebe nke mmadụ gbara, akaebe nke Chineke gbara dị ukwuu karịa, nʼihi na ọ bụ akaebe Chineke gbara banyere Ọkpara ya.  
\v 10 Onye ọbụla kweere nʼỌkpara Chineke nwere ọgbụgba ama a nʼobi ya. Ma onye ọbụla na-ekwereghị na Chineke emeela ya ka ọ bụrụ onye ụgha, nʼihi na o kwereghị nʼama ahụ Chineke gbara banyere Ọkpara ya.  
\v 11 Ama ahụ bụkwa nke a, na Chineke enyela anyị ndụ ebighị ebi, ndụ a dịkwa nʼime Ọkpara ya.  
\v 12 Onye ọbụla nwere Ọkpara ahụ nwere ndụ ma onye ọbụla na-enweghị Ọkpara Chineke enweghị ndụ. 
\s1 Ime okwu ka o wee anya 
\p  
\v 13 Ana m edere unu ihe ndị a unu ndị kweere nʼaha Ọkpara Chineke, ime ka unu mata na unu nwere ndụ ebighị ebi.  
\v 14 Nkwuwa okwu anyị nwere na ya bụ, na ọ bụrụ na anyị arịọ ihe ọbụla dịka ọchịchọ obi ya siri dị, ọ na-anụ olu anyị.  
\v 15 Ọ bụrụkwanụ na anyị matara na ọ na-anụ olu anyị mgbe ọbụla anyị rịọrọ ya ihe, anyị na-amatakwa na anyị anatala ihe ọbụla anyị rịọrọ ya. 
\p  
\v 16 Ọ bụrụ na onye ọbụla ahụ ka nwanna ya na-eme mmehie nke na-adịghị eduba nʼọnwụ, ya kpee ekpere, Chineke ga-enyekwa onye ahụ ndụ. Nke a bụ maka ndị ahụ mmehie ha na-abụghị nke na-eduba nʼọnwụ. E nwere mmehie na-eduba nʼọnwụ. Asịghị m unu kpee ekpere maka nke ahụ.  
\v 17 Ajọ omume niile bụ mmehie, ma ọ dị mmehie nke na-adịghị eduba nʼọnwụ. 
\p  
\v 18 Anyị matara na onye ọbụla amụrụ site na Chineke anaghị aga nʼihu na-eme mmehie, kama onye ahụ nke amụrụ site na Chineke na-echekwa ha, ajọ onye ahụ adịghị emetụkwa ha aka.  
\v 19 Anyị maara na anyị bụ ụmụ Chineke, ụwa niile nọkwa nʼokpuru ike ajọ onye ahụ.  
\v 20 Anyị matakwara na Ọkpara Chineke abịala, nyekwa anyị nghọta ka anyị mara ya, onye bụ eziokwu. Anyị nọ nʼime onye ahụ bụ eziokwu, ọ bụladị nʼime Ọkpara ya, bụ Jisọs Kraịst. Ya onwe ya bụ ezi Chineke bụrụkwa ndụ ebighị ebi. 
\b  
\b  
\p  
\v 21 Ụmụ m, wezuganụ onwe unu site nʼarụsị niile.