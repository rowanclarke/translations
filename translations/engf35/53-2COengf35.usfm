\v 1 \w And|strong="G1161"\w* \w now|strong="G1161"\w*, brothers, \w we|strong="G1161"\w* want \w you|strong="G5210"\w* \w to|strong="G1722"\w* \w know|strong="G1722"\w* \w about|strong="G1722"\w* \w the|strong="G1722"\w* \w grace|strong="G5485"\w* \w of|strong="G2316"\w* \w God|strong="G2316"\w* \w that|strong="G3588"\w* \w has|strong="G2316"\w* \w been|strong="G1325"\w* \w bestowed|strong="G1325"\w* \w upon|strong="G1722"\w* \w the|strong="G1722"\w* congregations \w of|strong="G2316"\w* \w Macedonia|strong="G3109"\w*,
