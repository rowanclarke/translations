\v 22 \w And|strong="G2532"\w* \w he|strong="G2532"\w* \w who|strong="G3588"\w* \w swears|strong="G3660"\w* \w by|strong="G1722"\w* \w heaven|strong="G3772"\w* \w swears|strong="G3660"\w* \w by|strong="G1722"\w* \w the|strong="G1722"\w* \w throne|strong="G2362"\w* \w of|strong="G2316"\w* \w God|strong="G2316"\w* \w and|strong="G2532"\w* \w by|strong="G1722"\w* \w Him|strong="G3588"\w* \w who|strong="G3588"\w* \w sits|strong="G2521"\w* \w on|strong="G1722"\w* \w it|strong="G2532"\w*.   
\p
