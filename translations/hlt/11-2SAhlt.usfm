\v 31 \w A|strong="H9907"\w* \w khuikah|strong="H9996"\w* \w pilnam|strong="H5971"\w* \w te|strong="H0853"\w* a \w khuen|strong="H3318"\w* \w tih|strong="H9999"\w* \w hlawh|strong="H4050"\w* \w taengah|strong="H9996"\w*, \w thi|strong="H1270"\w* \w tlang|strong="H2757"\w* \w taengah|strong="H9996"\w*, \w thi|strong="H1270"\w* \w yoeng|strong="H4037"\w* \w taengah|strong="H9996"\w* a \w khueh|strong="H7760"\w*. \w Amih|strong="H9908"\w* \w te|strong="H0853"\w* \w taptlang|strong="H4404"\w* \w dongah|strong="H9996"\w* a \w tueih|strong="H5674"\w*. \w Te|strong="H3651"\w* tlam te \w Ammon|strong="H5983"\w* \w koca|strong="H1121"\w* rhoek kah \w khopuei|strong="H5892"\w* \w tom|strong="H3605"\w* \w te|strong="H9997"\w* a \w saii|strong="H6213"\w* \w daengah|strong="H9999"\w* \w David|strong="H1732"\w* \w neh|strong="H9999"\w* \w pilnam|strong="H5971"\w* \w pum|strong="H3605"\w* loh \w Jerusalem|strong="H3389"\w* la \w mael|strong="H7725"\w* pueng.
