\id 2TI Mazatec of Jalapa de Díaz
\h Xu̱ju̱n xi ma joho xi kin'ekjíhi̱ Timoteo̱
\toc1 Xu̱ju̱n xi ma joho xi kits'ínkjihi̱ nda̱ postru̱ Pablo̱ Timoteo̱
\toc2 Xu̱ju̱n xi ma joho xi kin'ekjíhi̱ Timoteo̱
\toc3 2 Ti.
\mt1 Xu̱ju̱n xi ma joho xi kits'ínkjihi̱ nda̱ postru̱ Pablo̱ Timoteo̱
\c 1
\s1 B'i̱ ts'ín kikjaniñaha̱ Pablo̱ Timoteo̱
\p 
\v 1 An Pablo̱, an xi kama nku nda̱ postru̱hu̱ Jesucristo̱ a̱t'aha̱ Nti̱a̱ná b'a̱ ts'ín kama mjehe̱. Tíbitjusun ni xi kitsúya títjun nga ts'i̱ínk'íéntu tík'un xu̱ta̱ xi s'ejihi̱n Cristo̱ Jesu.
\v 2 Tífaniñaha Timoteo̱, ji xi nkúhu tsa ntína̱ ko̱ tjo ṉkjúnna ji.
\p Katsjáhi kju̱a̱nda ko̱ kju̱a̱jyu Nti̱a̱ Na̱'miná ko̱ Nda̱ Nti̱a̱ná Cristo̱ Jesu ko̱ nda katasehi.
\s1 B'i̱ ts'ín kitsjá nga'yúhu̱n Pablo Timoteo̱
\p 
\v 3 Ni̱stjin ni̱stje̱n nchjantjáíhi nginku̱n Nti̱a̱ná ko̱ tsjaha̱ máb'achjíhi̱ nga̱t'a ts'e̱ ni xi tín'ei. Kui xi títs'inxát'aha̱ xi nkú nga ta̱ kits'ín ntje̱ chána̱ ko̱ je tjíya kju̱a̱nkjintak'unna̱ nga b'a̱ títs'ian.
\v 4 F'áítsjenna nga kich'í ko̱ mjena skue ngáha ra tu̱ xi b'a̱ ts'ín tséjihinna kju̱a̱tsjo.
\v 5 Ts'inkj'áítsjen xi nkú ts'ín ngayjehe ani̱ma̱hi̱ s'ejihin Nti̱aná. Tjun Loi̱da̱, na̱cháhi̱, b'a̱ ta̱ ts'ín kis'ejihi̱n, ko̱ Eunice̱, náhi̱. Nd'a̱i̱ be sisihi̱n k'an nga ko̱ ji b'a̱ ta̱ ts'ín s'ejihin.
\p 
\v 6 Kui b'a̱ maha, títs'inkj'áítsjehen ra nga n'e̱'yúnyai kju̱a̱nda xi kitsjáhi Nti̱a̱ná nk'ie nga kingjennéhe ntsa̱.
\v 7 A̱t'aha̱ najmi kju̱a̱binkjun tsjáná Espiri̱tu̱ xi kits'ín nibáná Nti̱a̱ná. Nga'yún ní tsjáná ko̱ kju̱a̱tjo, ko̱ ta̱ tsjáná nga na̱xu̱ s'e̱yaná.
\p 
\v 8 Kui nga najmi tu̱ n'e subaha̱ ri̱ yjohi̱ nga k'úéni̱jmí Nda̱ Nti̱a̱ná ko̱ ta̱ ndaha nga kjíi̱ya'yán nga̱t'aha̱ nga tíb'eni̱jmíá. Nga'yúhu̱n Nti̱a̱ná katasinko̱hi nga ku̱i̱tjájin kju̱a̱ni̱ma̱ nga̱t'aha̱ én nda tsuhu̱ Nti̱a̱ná xi nkúhu an.
\v 9 Nti̱a̱ná kits'ínk'ankiná ko̱ j'ájinná nga ka̱maá xu̱ta̱ xi ts'e̱. Tu̱nga najmi nga̱t'aha̱ ní ni xi kin'eé j'ájihinná. B'a̱ ní kits'ín a̱t'aha̱ b'a̱ ts'ín y'énda títjun ko̱ b'a̱ ts'ín nibá kju̱a̱ndaha̱. Kintehe̱ ni nga kamanda a̱sunntei̱, a̱jihi̱n Cristo̱ Jesu kits'ín nga ñá tsuhuná kju̱a̱nda xu'bi̱.
\v 10 Nd'a̱i̱ ni̱ ma ja y'éjña chji kju̱a̱ndoo̱ nk'ie nga ja j'ai Cristo̱ Jesu xi kits'ínk'ankiná nga j'ai kjexín nga'yúhu̱n ngabayoo̱ ko̱ ts'asje chji nga ka̱ma ku̱i̱ntsu̱ba̱ tík'un síán tu̱ ngat'aha̱ én nda tsuhu̱ Nti̱a̱ná.
\p 
\v 11 Nti̱a̱ná kits'ín mana nku xi b'éni̱jmí éhe̱n, nku nda̱ postru̱ ko̱ nku nda̱ maestru̱.
\v 12 Kui kju̱a̱ha nga tíf'a̱jihinna kju̱a̱ni̱ma̱. Tu̱nga najmi subahá mana, a̱t'aha̱ be yá xi kits'in s'ejian ko̱ behe̱ k'an nga tjíhi̱n nga'yún nga kj'u̱átjo ni xi kits'ínkjas'enna. B'a̱ ts'i̱ín santaha nkúhu nga ku̱i̱chú ni̱stjin nga cha̱se̱he̱ mí nihi xi kits'ín nga nkúnkú xu̱ta̱.
\p 
\v 13 Ndjá n'e̱ s'ejin Cristo̱ Jesu ko̱ ti̱nchinjín kju̱a̱tjoho̱. Xi nkú kits'inko̱ho nga tsakuyáha, ni nda xi tsakuyáha, b'a̱ n'e̱i.
\v 14 Nga'yúhu̱n Espiri̱tu̱ Santo̱ xi tíjñajinná chúnko̱ho̱ ri̱ én nda tsu xi kin'ekjas'ehin.
\p 
\v 15 Ja yai nga ja i̱ncha kits'ín nga mana ngayjee̱ xu̱ta̱ xi tjín nga ngúsuhu̱n a̱nte Asi̱a̱. Santaha ko̱ nda̱ Figelo̱ ko̱ nda̱ Hermoge̱ne̱ b'a̱ kits'ínko̱na.
\p 
\v 16 Nti̱a̱ná katase ni̱ma̱ha̱ xu̱ta̱ xinkjín nda̱ Onesifo̱ro̱. Nkjin ni̱yá kitsjá nga'yúnna ndo̱ ko̱ najmi kama subaha̱ nga̱t'aha̱ nga kjíi̱ya'yán.
\v 17 Ni xi kits'ín ní, nk'ie nga j'ai nanki Roma̱ tsangisjaina santaha nkúhu nga kisakúhu̱ an.
\v 18 Nda̱ Nti̱a̱ná katase ni̱ma̱ha̱ ni̱stjin nga cha̱se̱he̱ mí nihi xi kits'ín nga nkúnkú xu̱ta̱. Ko̱ ji ja ya sisin xi nkú ts'ín tsasinko̱ná ndo̱ nanki Efe̱so̱.
\c 2
\s1 B'i̱ ts'ín y'éjña chu̱ba̱ya Pablo̱ nk'ie nga tsakúyaha̱ Timoteo̱
\p 
\v 1 Kui b'a̱ maha, ji ntína̱, n'e̱jahani nga'yún xi sakújinná kju̱a̱ndaha̱ Cristo̱ Jesu.
\v 2 Ko̱ ni xi kinu'yáí nga kixian nginku̱n nkjin xu̱ta̱, kui xi n'e̱kjas'eihi̱n já xi ma 'yún tak'aán, já xi ka̱ma ku̱a̱kúya ngáha̱ ra̱ kj'a̱í.
\p 
\v 3 N'e̱ chúkju̱a̱i̱ kju̱a̱ni̱ma̱ xi ku̱i̱tjájin, a̱t'aha̱ ji xi nkú joya nda̱ juhu̱n Cristo̱ Jesu ji, nda̱ jun xi nda ts'ín xáha̱.
\v 4 Yaá nga ndaha nku nda̱ jun xi tíkján najmi tsungijin yjoho̱ ni xi tjín a̱sunntei̱. B'a̱ ts'ín a̱t'aha̱ mjehe̱ nga nda sku̱e̱he̱ xi kitsjá xáha̱.
\v 5 Ko̱ ta̱ máha nku nda̱tsuton, najmi ka̱ma ts'i̱ín ngana̱ tsa najmi tsúton xi nkú ts'ín tíjña nga nuton.
\v 6 Ko̱ ta̱ máha nku xi títs'ín kju̱a̱ni̱ma̱ nga títs'ínxá, bichú ni̱stjin nga sakúhu̱ ni tjun xi b'éntje̱.
\v 7 N'e̱chu̱ba̱yahi̱ yjohi̱ ni xi tíxihin ko̱ b'a̱ ta̱ ts'ín Nda̱ Nti̱a̱ná ts'i̱ín nga ka̱mankjihin ngayjee̱ nii̱.
\p 
\v 8 N'e̱kj'áítsjein Jesucristo̱ xi j'áíya ngáha̱ ra̱ ngabayoo̱, xi ntje̱he̱ David y'aha̱ ra̱. B'i̱ tsu én xi tíb'eni̱jmíá.
\v 9 Ko̱ kui nga̱t'aha̱ ée̱n un tíbehena ko̱ santaha kjíi̱ya'yán xi nkúhu tsa an xi nda̱ ch'on k'an. Tu̱nga máha éhe̱n Nti̱a̱ná, najmi kjiya'yún.
\v 10 Kui nga ngandaha̱ xu̱ta̱ xi Nti̱a̱ná j'ájin títs'in chúkju̱a̱hana ngayjee̱ ni xi tímat'an, tu̱ xi ko̱ kui i̱ncha sa̱kúhu̱ ra̱ nga Cristo̱ Jesu ts'i̱ínk'anki ko̱ tsjáha̱ kju̱a̱chánka xi najmi maha̱ feya.
\p 
\v 11 Ma n'e s'ejin én xi tsu:
\q1 Tsa tsayaka̱á Cristo̱,
\q1 ta̱ ku̱i̱ntsu̱ba̱ tík'unko̱ ngáhaná.
\q1 
\v 12 Tsa tín'e chúkju̱á nga un tíbená,
\q1 ta̱ ku̱a̱texumaka̱á.
\q1 Tsa najmi n'e̱kié yjoná nga yaá,
\q1 ko̱ kui najmi ts'i̱ínkie yjoho̱ nga bená.
\q1 
\v 13 Tsa najmi ch'a s'ejihi̱n ñá,
\q1 tu̱nga kui ma ma 'yún tak'aán,
\q1 a̱t'aha̱ kui najmi maha̱ ts'ínjo éhe̱n.
\s1 B'i̱ ts'ín tsakúyaha̱ Pablo̱ Timoteo̱ xi nkú ts'ín ts'i̱ínxát'aha̱ Cristo̱
\p 
\v 14 N'e̱kj'áítsjeihi̱n xu̱ta̱ ni̱nku̱, nginku̱n Nti̱a̱ná tu̱ xí b'a̱há t'ihi̱n, nga najmi tu̱ mí éhen ni i̱ncha k'u̱ésiyáha, a̱t'aha̱ kui ni xu'bi̱ xi najmi chumi ni chjíhi̱ ra̱. Tu̱ sa ní ts'ínndyjajihi̱n xu̱ta̱ xi mjéñjuhu̱ kui niu̱.
\v 15 Ngayjehe k'uin n'e̱i ni xi nda nginku̱n Nti̱a̱ná tu̱ xi nda sku̱e̱he ni xi tín'ei. N'e̱i xi nkúhu nku nda̱ musu̱ xi najmi ma subaha̱ ni xi títs'ín ko̱ xi nda ts'ín bakúya én xi na̱xu̱ tjín.
\p 
\v 16 Najmi tu̱ nungijin yjohi̱ én tiya xi tjín a̱sunntei̱, a̱t'aha̱ xi b'a̱ ts'ín nchja̱, kui xi tu̱ nku fi t'axíhín ra̱ Nti̱a̱ná.
\v 17 Ko̱ kui éhe̱n xi nkú joyaha tsé xi fina̱nka̱. Najmi maha̱ manda. B'a̱ ts'ín tsatsun nda̱ Himeneo̱ ko̱ nda̱ Fileto̱.
\v 18 Kui xi ja ngji t'axíhi̱n ni xi na̱xu̱ tjín. B'a̱ tíi̱ncha tsu nga ja j'a ni̱stjin nga kj'u̱a̱íya ngáha̱ ra̱ xu̱ta̱ ngabayoo̱. B'a̱ ts'ín títs'ínndyjajihi̱n ra̱ k'u̱a̱ xu̱ta̱ xi s'ejihi̱n Nti̱a̱ná.
\v 19 Tu̱nga tu̱ nkú ndjáhá síjña éhe̱n Nti̱a̱ná. Síjña xi nkúhu nku xjó xi: “Nda̱ Nti̱a̱ná be xu̱ta̱ xi ts'e̱”, tsu ntu xi tjít'aha̱. Ko̱ b'a̱ ta̱ ts'ín tjít'a yaha̱: “Ngayjee̱ xi tsu nga s'ejihi̱n Cristo̱ kats'ín t'axíhi̱n yjoho̱ ni xi najmi na̱xu̱ nginku̱n Nti̱a̱ná.”
\p 
\v 20 Xi nkúhu nku ni'ya chánka, najmi tu̱ suba ni to̱onsine ko̱ to̱ontaba tjíhi̱n. Ta̱ tjín níhi̱ ni xi kamandako̱ho yá ko̱ ninte. K'u̱a̱ xi n'echjén nk'ie nga tjín s'í ko̱ k'u̱a̱ xi n'echjén tehe̱nte.
\v 21 Ko̱ b'a̱ ta̱ ts'ín tíjña a̱jinná. Tsa tjín xi ja kits'ín je yjoho̱, kui xi nkú joyaha ni xi ma n'echjén nk'ie nga tjín s'í. Ja je ko̱ Nti̱a̱ná ka̱ma ts'i̱ínchjéhe̱n, a̱t'aha̱ ja tjíndaha̱ yjoho̱ nga ka̱ma ts'i̱ín ngayjee̱ ni xi nda.
\p 
\v 22 Chíhi̱n yjohi̱ ni xi nchja̱ha̱ ani̱ma̱ha̱ já i̱stiu̱. N'e̱i ni xi na̱xu̱ nginku̱n Nti̱a̱ná, tu̱ nku n'e̱ s'ejinní Nti̱a̱ná, ko̱ kas'ehi kju̱a̱tjo ko̱ kju̱a̱jyu. Nkuhú n'e̱ mako̱i̱ yjohi̱ xu̱ta̱ xi je tjíntuyá ani̱ma̱ha̱ ko̱ nchja̱ha̱ Nda̱ Nti̱a̱ná.
\v 23 Najmi tu̱ n'esihi̱n én tsujnu tsut'a ko̱ én xi najmi tjíhi̱n sin xi nchja̱ xu̱ta̱, a̱t'aha̱ ja yai nga yo̱ nibáha̱ ra̱ kju̱a̱chán.
\v 24 Xi títs'ínxát'aha̱ Nda̱ Nti̱a̱ná najmi tjíhin nga kju̱a̱chán kju̱ájin yjoho̱. Nda ní ts'ín kats'ínsihi̱n ngayjee̱ xu̱ta̱. Ko̱ tjíhin nga ka̱maha̱ ku̱a̱kúyaha̱ xu̱ta̱. Kats'ín chúkju̱a̱ ni xi ka̱mat'ain.
\p 
\v 25 Ni̱ma̱kju̱a̱ kat'asje yjoho̱ nk'ie nga tsjáni̱yáha̱ xi tífi kontra̱ha̱. Kutsa Nti̱a̱náhá tsjáha̱ xu̱ta̱ xu'bo̱ nga ts'i̱ínk'óntjaiya ani̱ma̱ha̱ nga sku̱e̱ ni xi na̱xu̱ tjín
\v 26 ko̱ nga ku̱a̱nkaha̱ ni xi ts'ana̱cha̱ko̱ho̱ ra̱ nda̱nindoo̱. A̱t'aha̱ i̱ncha kjintuyá'yún ko̱ ni xi mjehe̱ nda̱nindoo̱ títs'ínko̱ho̱.
\c 3
\s1 B'i̱ ts'ín tsakúya Pablo̱ xi nkú ka̱ma kintehe̱ ni nga kj'u̱a̱í ngáha Nda̱ Nti̱a̱ná
\p 
\v 1 Katumankjihin ni xu'bi̱. Ni̱stjin xi fekuhu s'e̱ ni̱stjin kju̱a̱'un.
\v 2 A̱t'aha̱ ka̱maxkín xu̱ta̱ ko̱ 'yún ts'i̱ín mje to̱on. Ngak'un ka̱ma ko̱ nk'a k'u̱a̱sje yjoho̱. Ch'on ts'ín ku̱i̱nchja̱ne Nti̱a̱ná ko̱ najmi ku̱i̱nt'é'éhe̱n xi cháha̱. Ndjá s'e̱yaha̱ ko̱ najmi sku̱e̱nkjún Nti̱a̱ná.
\v 3 Najmi s'e̱he̱ kju̱a̱tjo ko̱ najmi ka̱ma ni̱ma̱ha̱ xu̱ta̱. Ku̱i̱nchja̱yane xu̱ta̱ ko̱ najmi k'u̱éch'oho̱ yjoho̱ ni xi ku̱i̱nchja̱ha̱ ani̱ma̱ha̱. Kjan ka̱ma ko̱ ngju̱a̱i̱ kontra̱ha̱ ngayjee̱ ni xi nda.
\v 4 Tsank'á ka̱ma, najmi ka̱ma nusihi̱n ni xi i̱ncha ts'i̱ín, ko̱ tséjihi̱n ra̱ kju̱a̱ngak'un. Najmi ku̱a̱ngisjai Nti̱a̱ná. Ni xi ku̱i̱nchja̱ níhi̱ ani̱ma̱ha̱ ku̱a̱ngisjai.
\v 5 B'a̱ i̱ncha ts'i̱ín xi benkjún Nti̱a̱ná ts'i̱ín, tu̱nga xi nkú ts'ín tjíntu kui niu̱ xi ku̱a̱kúchji nga najmi tíjñajihi̱n nga'yún xi Nti̱a̱ná tsjáha̱ xu̱ta̱ xi benkjúhu̱n.
\p N'e̱ t'axíhi̱n yjohi̱ xu̱ta̱ xu'bi̱.
\v 6 A̱t'aha̱ xi b'a̱ k'un, kui xi xki̱ ni'ya i̱ncha fi ko̱ b'ana̱cha̱ha̱ jminchjín xi najmi ndjá tjíntuyáha̱, xi kitsejíhi̱n ra̱ ngatitsun ko̱ nt'é'éhe̱n tu̱ mí nihí ni xi nchja̱ha̱ ani̱ma̱ha̱.
\v 7 Kui jminchjíu̱n xi tehe̱nte bangiya tu̱nga ndahá i̱chí najmi ma bichú mankjin sisihi̱n ni xi na̱xu̱ tjín.
\v 8 Xi nkú ts'ín játj'e Jane̱ ko̱ Jambre̱ ngji kontra̱ha̱ Moise ni̱stjin nk'ie, b'a̱ ta̱ ts'ín ko̱ kui já xu'bi̱ tífi kontra̱ha̱ ni xi na̱xu̱ tjín. Najmi nda kju̱a̱nkjintak'uhu̱n ko̱ yaha̱ nga najmi Nti̱a̱ná s'ejihi̱n.
\v 9 Tu̱nga najmi ngju̱a̱i̱ndjuko̱hó ni xi i̱ncha y'a, a̱t'aha̱ ngayjee̱ xu̱ta̱ sku̱e̱ kju̱a̱nchi̱nihi̱. B'a̱ ka̱mat'ain xi nkú nga ta̱ kamat'ain Jane̱ ko̱ Jambre̱.
\s1 B'i̱ ts'ín kitsjáni̱yáha̱ Pablo̱ Timoteo̱
\p 
\v 10 Ji Timoteo̱, ja yai sisin ni xi tsakuyá ko̱ xi nkú ts'ian. Ta̱ yai ni xi mjena ts'ian, xi nkú ts'ín s'ejinna, kju̱a̱tsentana̱, kju̱a̱tjona̱, ko̱ xi nkú ts'ín títs'in chúkju̱a̱ ni xi tímat'an.
\v 11 Yai xi nkú ts'ín kitsjennkí unkiena xu̱ta̱, ko̱ kju̱a̱'un xi kikie, ko̱ ni xi kamat'an nanki Antiokia̱, nanki Ikoni̱o̱ ko̱ nanki Listra̱. Kitsjennkí unkiena xu̱ta̱ tu̱nga Nda̱ Nti̱a̱náhá tsasinko̱na a̱jihi̱n ngayjee̱ ni xu'bi̱.
\p 
\v 12 Kju̱axi̱ nga ngayjee̱ xi mjehe̱ sku̱e̱nkjún Nti̱a̱ná ko̱ Cristo̱ Jesu, kui xi tsjénnki unkiehe̱ xu̱ta̱.
\v 13 Tu̱nga máha xu̱ta̱ ch'onk'uu̱n ko̱ xi tsank'óo̱, 'yún ch'onk'un ka̱ma sa. K'u̱a̱na̱cha̱ ko̱ ta̱ ch'a̱na̱cha̱ha̱.
\p 
\v 14 Tu̱nga máha ji, ndjá ti̱si̱njñajin ni xi tsinchiyáí, ni xi tsichu mankjihin. A̱t'aha̱ yai yá xi tsakúyahi niu̱.
\v 15 N'e̱kj'áítsjein nga santa nkúhu nga ndyjahi yai nkú títsu xu̱ju̱n éhe̱n Nti̱a̱ná. Kui xi tsje. Kui xi tjíhi̱n nga'yún nga tsjáhi kju̱a̱nkjintak'un, a̱t'aha̱ s'ejihin Cristo̱ Jesu ko̱ tíb'anki.
\v 16 Espiri̱tu̱hu̱ Nti̱a̱ná kits'ínxájihi̱n xi y'ét'a ngayjee̱ xu̱ju̱n éhe̱n Nti̱a̱ná ko̱ kui xu̱ju̱n basinko̱ná nga bakuyáha̱á xu̱ta̱, nga n'ek'a ni̱yáha̱á, nga bixínyaha̱á má nihi xi najmi nda tjín títs'ín, ko̱ nga 'ba̱i̱ ni̱yáha̱á xi nkú ts'ín na̱xu̱ ngju̱a̱i̱ko̱ yjoho̱.
\v 17 B'a̱ ts'ín xu̱ju̱n tu̱ xi nda̱ xi ts'ínxát'aha̱ ra̱ Nti̱a̱ná sku̱e̱ sisihin ni xi tjíhin nga ts'i̱ín nga ts'i̱ín xá xi nda.
\c 4
\p 
\v 1 Nginku̱n Nti̱a̱ná ko̱ nginku̱n Cristo̱ Jesu, kui xi ku̱a̱se̱he̱ ni xi kits'ín xu̱ta̱ xi tjíntu tík'un ko̱ xi ja k'ien nk'ie nga kj'u̱a̱íkúchji yjoho̱ nga kj'u̱a̱ítéxuma, tu̱ xí tíbankihí ra nga
\v 2 t'eni̱jmí éhe̱n Nti̱a̱ná. Tu̱ nkú b'a̱há n'e̱i̱ tu̱ mí ni̱stjihín ni ko̱ tu̱ mí chu̱ba̱há ni. T'inyaihi̱ xu̱ta̱ tsa najmi nda tjín ni xi títs'ín, ko̱ n'e̱k'a ni̱yáí, ko̱ tjennni̱yáíhi̱. Kas'e tehe̱ntehi kju̱a̱tsenta nk'ie nga ku̱a̱kúyai éhe̱n Nti̱a̱ná.
\p 
\v 3 A̱t'aha̱ ku̱i̱chú ni̱stjin nga najmi ta̱ ts'i̱ínsihi̱n ra̱ xu̱ta̱ én nda xi bakuyáá, xi nda ts'ínko̱ná. Tu̱ sa ní i̱ncha ku̱a̱ngisjai nga nkjin ṉkjún já maestru̱ xi ku̱a̱kúyaha̱ ni xi tsjoho̱ nga ku̱i̱nt'é, a̱t'aha̱ kui niu̱ xi nchja̱ha̱ ani̱ma̱ha̱.
\v 4 Ngju̱a̱i̱ t'axíhi̱n ko̱ najmi ta̱ ku̱a̱sínñjuhu̱ ra̱ én xi na̱xu̱ tjín. Énchá xi nchja̱ xu̱ta̱ i̱ncha ts'i̱ínsihi̱n.
\v 5 Tu̱nga máha ji, tu̱ nkú cha̱se̱ sisinní ni xi n'e̱i. N'e̱ chúkju̱a̱i kju̱a̱'uu̱n. N'e̱kjas'eihi̱n yjohi̱ nga t'eni̱jmí éhe̱n Nti̱a̱ná. Nda n'e̱tjusuin xáhi̱.
\p 
\v 6 An bi, ja ma ka̱maná nku chje̱ xi ku̱i̱chúsehe̱ Nti̱a̱ná. Ja tíbichú tiña chu̱ba̱ nga k'uejñá a̱sunntei̱.
\v 7 Ja tsási̱nchjaha̱ xi fi kontra̱ha̱ éhe̱n Nti̱a̱ná. Ja tsichu kjet'a ni̱yána̱. Tu̱ nkú kis'ejihínna Nti̱a̱ná.
\v 8 Ja tíkuyána nd'a̱i̱ chjí xi ts'i̱ínkjáíhi̱n xu̱ta̱ xi ja na̱xu̱ nginku̱n Nti̱a̱ná. Nda̱ Nti̱a̱ná tsjána niu̱, a̱t'aha̱ na̱xu̱ ts'i̱ínko̱ xu̱ta̱ ni̱stjin nga ku̱a̱se̱ mí nihi xi kits'ín nga nkúnkú. Ko̱ najmi tu̱ nku an tsjána chjí xu'bo̱. Ta̱ tsjáha̱ ngayjee̱ xu̱ta̱ xi tjoho̱ ko̱ xi tíi̱ncha kuyá nga kj'u̱a̱í ngáha.
\s1 B'i̱ ts'ín kitsúya̱ha̱ Pablo̱ Timoteo̱ ni xi mjehe̱ nga ts'i̱ín
\p 
\v 9 N'e̱ ki̱tsa̱ xáíhi̱ yjohi̱ nga nibáa̱se̱ xatíní.
\v 10 A̱t'aha̱ nda̱ Dema̱ 'yún tjo saha̱ ni xi tjín a̱sunntei̱. Ja kits'ín nga mana. Nanki Tesaloni̱ka̱ ngji. Nda̱ Krescente̱ ngá a̱nte Galaci̱a̱ ngji, ko̱ nda̱ Tito̱ ja ngji a̱nte Dalmaci̱a̱.
\v 11 Tu̱ nkuhú nda̱ Luko̱ tíjñako̱ sana e̱i̱. Ti̱nchísjai nda̱ Marko̱ ko̱ nibáko̱i̱, a̱t'aha̱ kui xi ka̱ma ku̱a̱si̱nko̱na a̱jihi̱n xána̱.
\v 12 Nda̱ Tiki̱ko̱ bi, nanki Efe̱so̱ kits'inkjíá.
\v 13 Nk'ie nga ni̱bai, nibáko̱ní najyunna̱ xi ts'inchjén ni̱stjin chu̱nch'óo̱n. Kui xi y'ejñá nanki Troa̱, ni'yaha̱ nda̱ Karpo̱. Ko̱ ta̱ nibáko̱ní xu̱ju̱nna̱. Tu̱ xí najmi tu̱ n'echayaní i̱chí xi tja̱ba̱xín kamandako̱ho.
\p 
\v 14 Tse ṉkjún kju̱a̱sti kitsjáná nda̱ Alejandro̱, nda̱ xi ts'ínnda ni ki̱cha̱. Nda̱ Nti̱a̱ná k'u̱échjí ngajoya ngáha̱ ra̱ ni xi kits'ín.
\v 15 Ko̱ ji, chíhi̱n yjohi̱ ndo̱, a̱t'aha̱ tu̱ xí 'yúhún ngji kontra̱ha̱ én xi tíb'eni̱jmíaá.
\p 
\v 16 Nk'ie nga tjun kinchjantjá yjona̱ nginku̱n já tjíxóo̱, najmi ch'a tsasinko̱na. Ngayjee̱ y'éntu masenna. Najmi tu̱ kat'axki̱hi̱ ra̱ Nti̱a̱ná ni xi i̱ncha kits'ín.
\v 17 Tu̱nga Nda̱ Nti̱a̱náhá tsasinko̱na ko̱ kitsjána nga'yún tu̱ xi kama y'eni̱jmíyjehena éhe̱n. B'a̱ ts'ín kint'éhe ngayjee̱ xu̱ta̱ xi najmi ntje̱ judio̱ tje̱he̱n ra̱. Ts'asje'ana Nda̱ Nti̱a̱ná ngabayoo̱.
\v 18 Ko̱ ta̱ k'u̱a̱sjejinna a̱jihi̱n ngayjee̱ ni ch'onk'un xi tjín ko̱ ngju̱a̱i̱ko̱na má batéxuma ndji̱o̱jmi ján. ¡N'e̱kié yjoná nga tjíhi̱n kju̱a̱chánka santaha tu̱ nkjéhé ni! B'a̱ kat'e.
\s1 B'i̱ ts'ín kits'ínkje Pablo̱ xu̱ju̱i̱n
\p 
\v 19 Tjeihi̱n kju̱a̱suniñana̱ na Priska̱ ko̱ nda̱ Akila̱ ko̱ xu̱ta̱ xinkjín nda̱ Onesifo̱ro̱.
\v 20 Nanki Corinto̱ y'ejña nda̱ Erasto̱. Nanki Mileto̱ kisatéch'in nda̱ Trofi̱mo̱ ko̱ yo̱ y'ejñá.
\v 21 N'e̱'ahi̱ yjohi̱ nga nibáa̱se̱ní kintehe̱ ni nga kj'u̱a̱í ni̱stjin chu̱nch'óo̱n. Títs'ínkjihi kju̱a̱suniña nda̱ Eubu̱lo̱ ko̱ nda̱ Pudente̱ ko̱ nda̱ Lino̱ ko̱ na Claudi̱a̱ ko̱ ngayjee̱ já nts'eé xi tjín e̱i̱.
\p 
\v 22 Nda̱ Nti̱a̱ná Jesucristo̱ kat'ejñako̱hi. Ngatentoo̱ kas'enu̱u kju̱a̱ndaha̱ Nti̱a̱ná.
