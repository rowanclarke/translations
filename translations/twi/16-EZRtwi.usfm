\tr 
\tc1 Akub, Hatita ne Sobai asefo
\tcr2 139
\b
\li4 
\v 43 Saa as…îredan mu asomfo asefo yi na wofi nnommum mu bae:
\tr 
\tc1 Siha, Hasufa, Tabaot,
\tr 
\tc1 
\v 44 Keros, Siaha, Padon,
\tr 
