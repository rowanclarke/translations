\p
\v 63 Pero \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* \w echar|strong="H3201"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w jebuseos|strong="H2983"\w* \w que|strong="H3808"\w* \w habitaban|strong="H3427"\w* \w en|strong="H5704"\w* Jerusalén. \w Así|strong="H2088"\w* \w que|strong="H3808"\w* \w los|strong="H3427"\w* \w jebuseos|strong="H2983"\w* viven \w con|strong="H5704"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* \w en|strong="H5704"\w* Jerusalén \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\c 16  
\s1 Territorio de los hijos de José  
\p
\v 1 Tocó \w en|strong="H3318"\w* \w suerte|strong="H1486"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w* la parte \w que|strong="H4325"\w* comenzaba por \w el|strong="H1008"\w* \w oriente|strong="H4217"\w* \w en|strong="H3318"\w* \w el|strong="H1008"\w* \w Jordán|strong="H3383"\w*, \w a|strong="H3068"\w* nivel \w de|strong="H1121"\w* \w Jericó|strong="H3405"\w* (las \w aguas|strong="H4325"\w* \w de|strong="H1121"\w* \w Jericó|strong="H3405"\w*), hacia \w el|strong="H1008"\w* \w desierto|strong="H4057"\w*, \w que|strong="H4325"\w* \w subía|strong="H5927"\w* desde \w Jericó|strong="H3405"\w* por la región montañosa \w hasta|strong="H3405"\w* Bet-ʼEl.  
\v 2 De Bet-ʼEl subía \w a|strong="H3068"\w* \w Luz|strong="H3870"\w*, y \w pasaba|strong="H5674"\w* al límite de los arquitas \w en|strong="H3318"\w* Atarot.  
\v 3 \w De|strong="H5704"\w* allí bajaba \w hacia|strong="H1366"\w* el oeste, \w hasta|strong="H5704"\w* el límite \w de|strong="H5704"\w* \w los|strong="H1961"\w* jafletitas, \w hasta|strong="H5704"\w* el lindero \w de|strong="H5704"\w* Bet-horón (\w la|strong="H1366"\w* \w de|strong="H5704"\w* abajo), \w y|strong="H5704"\w* \w hasta|strong="H5704"\w* \w Gezer|strong="H1507"\w*, \w y|strong="H5704"\w* terminaba \w en|strong="H5704"\w* el \w mar|strong="H3220"\w*.   
\p
\v 4 Así recibieron su heredad \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*: \w Manasés|strong="H4519"\w* y Efraín.   
\p
\v 5 \w Este|strong="H1961"\w* \w fue|strong="H1961"\w* \w el|strong="H1121"\w* territorio \w de|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* Efraín según sus \w familias|strong="H4940"\w*. \w Por|strong="H5704"\w* \w el|strong="H1121"\w* \w este|strong="H1961"\w*, \w el|strong="H1121"\w* límite \w de|strong="H5704"\w* su \w herencia|strong="H5159"\w* \w era|strong="H1961"\w* \w desde|strong="H5704"\w* Atarot-adar \w hasta|strong="H5704"\w* Bet-horón, \w la|strong="H1366"\w* \w de|strong="H5704"\w* arriba.  
\v 6 \w Este|strong="H4217"\w* límite \w salía|strong="H3318"\w* al occidente \w en|strong="H3318"\w* Micmetat al \w norte|strong="H6828"\w*. \w El|strong="H5674"\w* lindero daba \w vuelta|strong="H5437"\w* \w hacia|strong="H1366"\w* \w el|strong="H5674"\w* \w este|strong="H4217"\w* hasta Tanat-silo, y continuaba hasta \w el|strong="H5674"\w* \w este|strong="H4217"\w* de Janoa.  
\v 7 De Janoa bajaba \w a|strong="H3068"\w* Atarot y \w a|strong="H3068"\w* Naarat, tocaba \w en|strong="H3318"\w* \w Jericó|strong="H3405"\w* y \w salía|strong="H3318"\w* al \w Jordán|strong="H3383"\w*,  
\v 8 \w de|strong="H1121"\w* Tapúa. \w El|strong="H1121"\w* límite \w iba|strong="H3212"\w* al oeste \w hacia|strong="H1366"\w* \w el|strong="H1121"\w* \w arroyo|strong="H5158"\w* \w de|strong="H1121"\w* Caná y terminaba \w en|strong="H3212"\w* \w el|strong="H1121"\w* \w mar|strong="H3220"\w*. \w Esta|strong="H2063"\w* \w es|strong="H1961"\w* \w la|strong="H1366"\w* \w herencia|strong="H5159"\w* \w de|strong="H1121"\w* \w la|strong="H1366"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Efraín según sus \w familias|strong="H4940"\w*.  
\v 9 Hubo también \w ciudades|strong="H5892"\w* \w que|strong="H1121"\w* se apartaron para \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Efraín \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w heredad|strong="H5159"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.   
\p
\v 10 Pero ellos \w no|strong="H3808"\w* \w echaron|strong="H3423"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* \w que|strong="H3808"\w* \w vivían|strong="H3427"\w* \w en|strong="H5704"\w* \w Gezer|strong="H1507"\w*, \w así|strong="H2088"\w* \w que|strong="H3808"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* viven \w en|strong="H5704"\w* \w medio|strong="H7130"\w* \w de|strong="H5704"\w* Efraín \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*, \w y|strong="H5704"\w* \w fueron|strong="H1961"\w* sometidos \w a|strong="H3068"\w* trabajos forzados.   
\c 17  
\s1 Territorio de Manasés  
\p
\v 1 \w Este|strong="H1931"\w* \w fue|strong="H1961"\w* \w el|strong="H1931"\w* sorteo \w para|strong="H3588"\w* \w la|strong="H1931"\w* \w tribu|strong="H4294"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w*, \w por|strong="H3588"\w* ser \w el|strong="H1931"\w* \w primogénito|strong="H1060"\w* \w de|strong="H3588"\w* \w José|strong="H3130"\w*. \w A|strong="H3068"\w* Maquir, \w el|strong="H1931"\w* \w primogénito|strong="H1060"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w* \w y|strong="H3588"\w* padre \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w*, \w le|strong="H1931"\w* tocó \w en|strong="H3588"\w* \w suerte|strong="H1486"\w* \w Galaad|strong="H1568"\w* \w y|strong="H3588"\w* \w Basán|strong="H1316"\w*, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w era|strong="H1961"\w* un varón \w de|strong="H3588"\w* \w guerra|strong="H4421"\w*.  
\v 2 También \w se|strong="H1961"\w* echaron suertes \w para|strong="H1961"\w* \w los|strong="H1121"\w* otros \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w* según sus \w familias|strong="H4940"\w*: \w para|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Abiezer, \w de|strong="H1121"\w* Helec, \w de|strong="H1121"\w* Asriel, \w de|strong="H1121"\w* Siquem, \w de|strong="H1121"\w* Hefer y \w de|strong="H1121"\w* Semida. Estos \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w varones|strong="H2145"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*, según sus \w familias|strong="H4940"\w*.   
\p
\v 3 \w Pero|strong="H3588"\w* Zelofehad, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Hefer, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w*, \w no|strong="H3808"\w* \w tuvo|strong="H1961"\w* \w hijos|strong="H1121"\w*, \w sino|strong="H3588"\w* \w hijas|strong="H1323"\w*, cuyos \w nombres|strong="H8034"\w* \w son|strong="H1961"\w* \w Maala|strong="H4244"\w*, \w Noa|strong="H5270"\w*, \w Hogla|strong="H2295"\w*, \w Milca|strong="H4435"\w*, \w y|strong="H3588"\w* Tirsa.  
\v 4 Éstas se \w presentaron|strong="H5414"\w* \w delante|strong="H6440"\w* del \w sacerdote|strong="H3548"\w* Eleazar, \w de|strong="H6440"\w* \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Nun|strong="H5126"\w*, y \w de|strong="H6440"\w* \w los|strong="H1121"\w* jefes, y dijeron: \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w que|strong="H1121"\w* nos \w diera|strong="H5414"\w* \w herencia|strong="H5159"\w* \w entre|strong="H8432"\w* nuestros hermanos. Así fue como \w él|strong="H1121"\w* nos \w dio|strong="H5414"\w* una \w heredad|strong="H5159"\w* \w entre|strong="H8432"\w* \w los|strong="H1121"\w* hermanos del padre \w de|strong="H6440"\w* ellas, \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* la \w Palabra|strong="H6310"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 5 \w A|strong="H3068"\w* \w Manasés|strong="H4519"\w* le tocaron en \w suerte|strong="H2256"\w* \w diez|strong="H6235"\w* \w partes|strong="H2256"\w*, además de la tierra de \w Galaad|strong="H1568"\w* y de \w Basán|strong="H1316"\w*, que está al otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*.  
\v 6 \w Porque|strong="H3588"\w* las \w hijas|strong="H1323"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w* obtuvieron \w herencia|strong="H5159"\w* \w entre|strong="H8432"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w él|strong="H3588"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w* correspondió al resto \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w*.  
\v 7 \w El|strong="H5921"\w* límite \w de|strong="H5921"\w* \w Manasés|strong="H4519"\w* \w iba|strong="H1980"\w* \w desde|strong="H5921"\w* Aser \w hasta|strong="H5921"\w* Micmetat, \w que|strong="H5921"\w* \w estaba|strong="H1961"\w* \w al|strong="H5921"\w* \w este|strong="H1961"\w* \w de|strong="H5921"\w* Siquem. Luego \w el|strong="H5921"\w* límite \w iba|strong="H1980"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* sur, \w hasta|strong="H5921"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* En-tapúa.  
\v 8 \w La|strong="H1366"\w* tierra \w de|strong="H1121"\w* Tapúa \w fue|strong="H1961"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, pero Tapúa, \w que|strong="H1121"\w* \w estaba|strong="H1961"\w* en \w el|strong="H1121"\w* límite \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w fue|strong="H1961"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Efraín.  
\v 9 El límite bajaba por el \w arroyo|strong="H5158"\w* de Caná, \w hacia|strong="H5045"\w* el sur del \w arroyo|strong="H5158"\w*. Estas \w ciudades|strong="H5892"\w* de Efraín \w están|strong="H1961"\w* \w entre|strong="H8432"\w* las \w ciudades|strong="H5892"\w* de \w Manasés|strong="H4519"\w*. El límite de \w Manasés|strong="H4519"\w* \w estaba|strong="H1961"\w* \w en|strong="H8432"\w* el lado \w norte|strong="H6828"\w* del \w arroyo|strong="H5158"\w*, y terminaba \w en|strong="H8432"\w* el \w mar|strong="H3220"\w*.  
\v 10 El lado sur \w era|strong="H1961"\w* de Efraín y el lado \w norte|strong="H6828"\w* de \w Manasés|strong="H4519"\w*, y el \w mar|strong="H3220"\w* \w era|strong="H1961"\w* su límite. Por el \w norte|strong="H6828"\w* \w se|strong="H1961"\w* encontraba con Aser, y por el \w este|strong="H1961"\w*, con Isacar.  
\v 11 En Isacar y en Aser, \w Manasés|strong="H4519"\w* \w tenía|strong="H1961"\w* Bet-seán y sus \w aldeas|strong="H1323"\w*, Ibleam y sus \w aldeas|strong="H1323"\w*, \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de \w Dor|strong="H1756"\w* y sus \w aldeas|strong="H1323"\w*, \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Endor y sus \w aldeas|strong="H1323"\w*, \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Taanac y sus \w aldeas|strong="H1323"\w*, y \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Megido y sus \w aldeas|strong="H1323"\w*, \w tres|strong="H7969"\w* regiones montañosas.   
\p
\v 12 Pero \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w* \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* \w echar|strong="H3201"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H1121"\w* aquellas \w ciudades|strong="H5892"\w*, por \w lo|strong="H3808"\w* cual \w el|strong="H1121"\w* \w cananeo|strong="H3669"\w* persistió en vivir en \w aquella|strong="H2063"\w* tierra.  
\v 13 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w fueron|strong="H1961"\w* \w fuertes|strong="H1121"\w*, sometieron \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w cananeos|strong="H3669"\w* \w a|strong="H3068"\w* trabajo forzado, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H1121"\w* \w echaron|strong="H3423"\w* completamente.   
\p
\v 14 Entonces \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w José|strong="H3130"\w* \w hablaron|strong="H1696"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: ¿\w Por|strong="H4069"\w* \w qué|strong="H5704"\w* nos \w diste|strong="H5414"\w* \w como|strong="H4069"\w* \w herencia|strong="H5159"\w* una sola \w suerte|strong="H1486"\w* \w y|strong="H5704"\w* una sola parte, \w aunque|strong="H5704"\w* somos un \w pueblo|strong="H5971"\w* \w numeroso|strong="H7227"\w*, \w al|strong="H5704"\w* cual \nd \+w Yavé|strong="H3068"\+w*\nd* \w bendijo|strong="H1288"\w* \w de|strong="H5704"\w* este modo?   
\p
\v 15 \w Josué|strong="H3091"\w* les respondió: \w Si|strong="H3588"\w* ustedes \w son|strong="H3588"\w* un \w pueblo|strong="H5971"\w* \w numeroso|strong="H7227"\w*, suban al \w bosque|strong="H3293"\w* \w y|strong="H3588"\w* desmonten \w allí|strong="H8033"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w los|strong="H3588"\w* ferezeos \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* refaítas, ya \w que|strong="H3588"\w* \w la|strong="H3588"\w* región montañosa \w de|strong="H3588"\w* Efraín \w es|strong="H3588"\w* estrecha \w para|strong="H3588"\w* ustedes.   
\p
\v 16 Pero \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w* le respondieron: \w No|strong="H3808"\w* nos bastará esa región montañosa. \w Todos|strong="H3605"\w* \w los|strong="H3427"\w* \w cananeos|strong="H3669"\w* \w que|strong="H3808"\w* viven en \w la|strong="H3605"\w* tierra del \w valle|strong="H6010"\w* tienen carruajes \w de|strong="H1121"\w* \w hierro|strong="H1270"\w*, tanto \w los|strong="H3427"\w* \w que|strong="H3808"\w* \w están|strong="H3427"\w* en Bet-seán y en sus \w aldeas|strong="H1323"\w*, como \w los|strong="H3427"\w* \w que|strong="H3808"\w* \w están|strong="H3427"\w* en \w el|strong="H3605"\w* \w valle|strong="H6010"\w* \w de|strong="H1121"\w* \w Jezreel|strong="H3157"\w*.   
\p
\v 17 Entonces \w Josué|strong="H3091"\w* respondió \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H5971"\w* \w José|strong="H3130"\w*, Efraín y \w Manasés|strong="H4519"\w*: Ustedes \w son|strong="H1961"\w* un \w pueblo|strong="H5971"\w* \w numeroso|strong="H7227"\w* y \w tienen|strong="H1961"\w* \w gran|strong="H1419"\w* \w fuerza|strong="H3581"\w*. \w No|strong="H3808"\w* \w tendrán|strong="H1961"\w* una sola parte,  
\v 18 \w sino|strong="H3588"\w* \w que|strong="H3588"\w* \w la|strong="H1931"\w* región montañosa \w será|strong="H1961"\w* \w de|strong="H3588"\w* ustedes, \w porque|strong="H3588"\w* \w aunque|strong="H3588"\w* \w es|strong="H1931"\w* \w bosque|strong="H3293"\w*, ustedes \w lo|strong="H1931"\w* talarán \w y|strong="H3588"\w* \w la|strong="H1931"\w* \w poseerán|strong="H3423"\w* \w hasta|strong="H1931"\w* \w sus|strong="H1931"\w* límites, \w porque|strong="H3588"\w* desposeerán al \w cananeo|strong="H3669"\w*, \w aunque|strong="H3588"\w* \w tenga|strong="H1961"\w* carruajes \w de|strong="H3588"\w* \w hierro|strong="H1270"\w* \w y|strong="H3588"\w* \w sea|strong="H1961"\w* \w fuerte|strong="H2389"\w*.   
\c 18  
\s1 La herencia de Benjamín  
\p
\v 1 \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* congregación \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* se reunió en \w Silo|strong="H7887"\w* y levantaron \w allí|strong="H8033"\w* \w el|strong="H3605"\w* Tabernáculo \w de|strong="H6440"\w* Reunión. \w La|strong="H3605"\w* tierra \w estaba|strong="H7931"\w* sometida \w a|strong="H3068"\w* \w ellos|strong="H3605"\w*.  
\v 2 \w Sin|strong="H3808"\w* embargo, \w entre|strong="H3808"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* quedaban \w siete|strong="H7651"\w* \w tribus|strong="H7626"\w* \w que|strong="H3808"\w* \w aún|strong="H3808"\w* \w no|strong="H3808"\w* habían recibido su \w herencia|strong="H5159"\w*.   
\p
\v 3 Entonces \w Josué|strong="H3091"\w* dijo \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*: ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* serán ustedes negligentes \w para|strong="H5704"\w* ir \w a|strong="H3068"\w* poseer la tierra \w que|strong="H5704"\w* les \w dio|strong="H5414"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H1121"\w* \nd ʼElohim\nd* \w de|strong="H5704"\w* sus antepasados?   
\p
\v 4 Designen \w tres|strong="H7969"\w* varones de cada \w tribu|strong="H7626"\w* para \w que|strong="H6310"\w* yo los \w envíe|strong="H7971"\w*, \w que|strong="H6310"\w* se levanten, recorran la tierra, hagan una descripción \w escrita|strong="H3789"\w* de ella \w según|strong="H6310"\w* sus \w heredades|strong="H5159"\w* y vuelvan \w a|strong="H3068"\w* mí.  
\v 5 \w La|strong="H5921"\w* dividirán \w en|strong="H5921"\w* \w siete|strong="H7651"\w* \w partes|strong="H2505"\w*. \w Judá|strong="H3063"\w* \w permanecerá|strong="H5975"\w* \w en|strong="H5921"\w* su territorio \w en|strong="H5921"\w* \w el|strong="H5921"\w* sur, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w* permanecerán \w en|strong="H5921"\w* su territorio \w del|strong="H5921"\w* \w norte|strong="H6828"\w*.   
\p
\v 6 Ustedes harán una descripción \w de|strong="H6440"\w* la tierra en \w siete|strong="H7651"\w* partes y me la traerán \w aquí|strong="H6311"\w*. Yo echaré \w suertes|strong="H1486"\w* \w por|strong="H6440"\w* ustedes \w aquí|strong="H6311"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, nuestro \nd ʼElohim\nd*.  
\v 7 \w Pero|strong="H3588"\w* \w los|strong="H3588"\w* \w levitas|strong="H3881"\w* \w no|strong="H3588"\w* tienen \w parte|strong="H2677"\w* \w entre|strong="H7130"\w* ustedes, \w pues|strong="H3588"\w* \w su|strong="H3588"\w* \w herencia|strong="H5159"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* \w sacerdocio|strong="H3550"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Gad|strong="H1410"\w* \w y|strong="H3588"\w* \w Rubén|strong="H7205"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* media \w tribu|strong="H7626"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w* ya \w recibieron|strong="H3947"\w* \w su|strong="H3588"\w* \w herencia|strong="H5159"\w* \w al|strong="H7130"\w* otro \w lado|strong="H5676"\w* \w del|strong="H2677"\w* \w Jordán|strong="H3383"\w*, \w al|strong="H7130"\w* \w oriente|strong="H4217"\w*, \w la|strong="H3588"\w* \w cual|strong="H3588"\w* \w Moisés|strong="H4872"\w*, esclavo \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*,\nd* les \w dio|strong="H5414"\w*.   
\p
\v 8 Aquellos hombres se \w levantaron|strong="H6965"\w* y \w fueron|strong="H3212"\w*. \w Josué|strong="H3091"\w* \w mandó|strong="H6680"\w* \w a|strong="H3068"\w* los que \w iban|strong="H1980"\w* \w a|strong="H3068"\w* describir la tierra: \w Vayan|strong="H3212"\w*, recorran la tierra, descríbanla y \w vuelvan|strong="H7725"\w* \w a|strong="H3068"\w* mí para que \w yo|strong="H6680"\w* \w eche|strong="H7993"\w* \w suertes|strong="H1486"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w aquí|strong="H6311"\w* \w en|strong="H3212"\w* \w Silo|strong="H7887"\w*.   
\p
\v 9 Aquellos hombres \w fueron|strong="H3212"\w* \w y|strong="H5921"\w* recorrieron \w la|strong="H5921"\w* tierra, hicieron una descripción \w por|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w en|strong="H5921"\w* \w siete|strong="H7651"\w* partes \w en|strong="H5921"\w* un rollo \w y|strong="H5921"\w* volvieron \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w al|strong="H5921"\w* \w campamento|strong="H4264"\w* \w en|strong="H5921"\w* \w Silo|strong="H7887"\w*.  
\v 10 \w Josué|strong="H3091"\w* les \w echó|strong="H7993"\w* \w suertes|strong="H1486"\w* en \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, en \w Silo|strong="H7887"\w*. \w Allí|strong="H8033"\w* \w repartió|strong="H2505"\w* \w Josué|strong="H3091"\w* la tierra \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* según sus divisiones.   
\p
\v 11 Echó \w la|strong="H1366"\w* \w suerte|strong="H1486"\w* \w de|strong="H1121"\w* \w la|strong="H1366"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w* según sus \w familias|strong="H4940"\w*, y les \w salió|strong="H3318"\w* \w el|strong="H1121"\w* territorio entre \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*.  
\v 12 \w Por|strong="H4480"\w* el \w norte|strong="H6828"\w* su límite partía \w del|strong="H4480"\w* \w Jordán|strong="H3383"\w*, \w luego|strong="H5927"\w* \w subía|strong="H5927"\w* \w por|strong="H4480"\w* el \w lado|strong="H3802"\w* \w norte|strong="H6828"\w* \w de|strong="H4480"\w* \w Jericó|strong="H3405"\w*, \w después|strong="H1961"\w* \w subía|strong="H5927"\w* \w por|strong="H4480"\w* \w la|strong="H1366"\w* región montañosa \w hacia|strong="H4480"\w* el oeste y llegaban \w al|strong="H4480"\w* \w desierto|strong="H4057"\w* \w de|strong="H4480"\w* Bet-avén.  
\v 13 \w Desde|strong="H5921"\w* \w allí|strong="H8033"\w* \w el|strong="H1931"\w* límite \w pasaba|strong="H5674"\w* \w a|strong="H3068"\w* \w Luz|strong="H3870"\w*, \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w lado|strong="H3802"\w* sur \w de|strong="H5921"\w* \w Luz|strong="H3870"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* Bet-ʼEl, \w y|strong="H5921"\w* bajaba \w hacia|strong="H5921"\w* Atarot-adar \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* montaña \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w al|strong="H5921"\w* sur \w de|strong="H5921"\w* Bet-horón \w de|strong="H5921"\w* Abajo.  
\v 14 \w Luego|strong="H1931"\w* \w el|strong="H1931"\w* límite doblaba \w hacia|strong="H5921"\w* \w el|strong="H1931"\w* oeste \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w lado|strong="H6285"\w* sur \w de|strong="H4480"\w* \w la|strong="H1931"\w* región montañosa \w que|strong="H4480"\w* \w está|strong="H2063"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* Bet-horón, \w al|strong="H5921"\w* sur, \w y|strong="H5921"\w* volvía \w a|strong="H3068"\w* \w salir|strong="H8444"\w* \w a|strong="H3068"\w* Quiriat-baal, \w que|strong="H4480"\w* \w es|strong="H1931"\w* Quiriat-jearim, \w ciudad|strong="H5892"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*. \w Este|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w lado|strong="H6285"\w* \w del|strong="H4480"\w* oeste.   
\p
\v 15 El \w lado|strong="H6285"\w* sur partía desde el \w extremo|strong="H7097"\w* \w de|strong="H4325"\w* Quiriat-jearim, y el \w límite|strong="H7097"\w* \w salía|strong="H3318"\w* al oeste, seguía hasta \w la|strong="H1366"\w* \w fuente|strong="H4599"\w* \w de|strong="H4325"\w* \w aguas|strong="H4325"\w* \w de|strong="H4325"\w* Neftoa.  
\v 16 Este \w límite|strong="H7097"\w* bajaba \w al|strong="H5921"\w* \w extremo|strong="H7097"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* región montañosa \w que|strong="H5921"\w* \w está|strong="H5921"\w* frente \w al|strong="H5921"\w* \w valle|strong="H1516"\w* \w del|strong="H5921"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Hinom, \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w al|strong="H5921"\w* \w norte|strong="H6828"\w* \w del|strong="H5921"\w* \w valle|strong="H1516"\w* \w de|strong="H5921"\w* Refaim, luego bajaba \w al|strong="H5921"\w* \w valle|strong="H1516"\w* \w de|strong="H5921"\w* Hinom, \w al|strong="H5921"\w* \w lado|strong="H3802"\w* sur \w del|strong="H5921"\w* \w jebuseo|strong="H2983"\w*, \w y|strong="H5921"\w* \w de|strong="H5921"\w* allí bajaba \w a|strong="H3068"\w* En-rogel.  
\v 17 \w Luego|strong="H3318"\w* doblaba hacia \w el|strong="H1121"\w* \w norte|strong="H6828"\w* y seguía \w a|strong="H3068"\w* En-semes, y \w de|strong="H1121"\w* allí seguía \w a|strong="H3068"\w* Gelilot, \w que|strong="H1121"\w* está frente \w a|strong="H3068"\w* la subida \w de|strong="H1121"\w* Adumim, y bajaba \w a|strong="H3068"\w* la piedra \w de|strong="H1121"\w* Bohán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w*.  
\v 18 \w Pasaba|strong="H5674"\w* por la ladera \w enfrente|strong="H4136"\w* del Arabá, por \w el|strong="H5674"\w* \w norte|strong="H6828"\w*, y bajaba al Arabá.  
\v 19 \w Después|strong="H1961"\w* \w el|strong="H5674"\w* \w límite|strong="H7097"\w* \w pasaba|strong="H5674"\w* \w por|strong="H2088"\w* \w el|strong="H5674"\w* \w lado|strong="H3802"\w* \w norte|strong="H6828"\w* de Bet-hogla y terminaba en \w la|strong="H1366"\w* bahía del \w norte|strong="H6828"\w* del \w mar|strong="H3220"\w* \w Salado|strong="H4417"\w*, al sur de \w la|strong="H1366"\w* desembocadura del \w Jordán|strong="H3383"\w*. \w Este|strong="H2088"\w* \w es|strong="H1961"\w* \w el|strong="H5674"\w* \w límite|strong="H7097"\w* del sur.   
\p
\v 20 \w El|strong="H1121"\w* \w Jordán|strong="H3383"\w* \w era|strong="H1121"\w* \w el|strong="H1121"\w* límite por \w el|strong="H1121"\w* \w este|strong="H2063"\w*. \w Esta|strong="H2063"\w* \w era|strong="H1121"\w* \w la|strong="H2063"\w* \w herencia|strong="H5159"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w*, por sus límites \w alrededor|strong="H5439"\w*, según sus \w familias|strong="H4940"\w*.  
\v 21 Las \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w*, por sus \w familias|strong="H4940"\w*, \w fueron|strong="H1961"\w*: \w Jericó|strong="H3405"\w*, Bet-hogla, Emec-casis,  
\v 22 Bet-arabá, \w Samaraim|strong="H6787"\w*, Bet-ʼEl,  
\v 23 Avim, Pará, Ofra,  
\v 24 Quefar-hamoni, Ofni y Gaba: 12 \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.  
\v 25 \w Gabaón|strong="H1391"\w*, \w Ramá|strong="H7414"\w*, Beerot,  
\v 26 Mizpa, Quefirá, Moza,  
\v 27 Requem, Irpel, Taralá,  
\v 28 Sela, Elef, \w Jebús|strong="H2983"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* Jerusalén, Gaba y Quiriat: 14 \w ciudades|strong="H5892"\w* con \w sus|strong="H1931"\w* \w aldeas|strong="H2691"\w*. \w Esta|strong="H2063"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w herencia|strong="H5159"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w* según \w sus|strong="H1931"\w* \w familias|strong="H4940"\w*.   
\c 19  
\s1 Sorteo de los territorios restantes  
\p
\v 1 La \w segunda|strong="H8145"\w* \w suerte|strong="H1486"\w* tocó \w a|strong="H3068"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Simeón|strong="H8095"\w* según sus \w familias|strong="H4940"\w*. Su \w herencia|strong="H5159"\w* \w estaba|strong="H1961"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* la \w heredad|strong="H5159"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.  
\v 2 En \w su|strong="H1992"\w* \w heredad|strong="H5159"\w* \w tenían|strong="H1961"\w* Beerseba, \w Seba|strong="H7652"\w*, Molada,  
\v 3 \w Hasar-sual|strong="H2705"\w*, \w Bala|strong="H1088"\w*, Esem,  
\v 4 Heltolad, \w Betul|strong="H1329"\w*, \w Horma|strong="H2767"\w*,  
\v 5 \w Siclag|strong="H6860"\w*, Bet-marcabot, Hasar-susa,  
\v 6 Bet-lebaot y Saruhén: 13 \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.  
\v 7 \w Y|strong="H3068"\w* \w Aín|strong="H5871"\w*, Rimón, \w Eter|strong="H6281"\w* y Asán: cuatro \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.  
\v 8 \w Todas|strong="H3605"\w* las \w aldeas|strong="H2691"\w* \w que|strong="H5704"\w* estaban \w alrededor|strong="H5439"\w* \w de|strong="H5704"\w* \w estas|strong="H2063"\w* \w ciudades|strong="H5892"\w* \w hasta|strong="H5704"\w* Balat-beer, \w que|strong="H5704"\w* \w es|strong="H2063"\w* \w Ramat|strong="H7414"\w* del Neguev. \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H3605"\w* \w heredad|strong="H5159"\w* \w de|strong="H5704"\w* \w la|strong="H3605"\w* \w tribu|strong="H4294"\w* \w de|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Simeón|strong="H8095"\w*, según sus \w familias|strong="H4940"\w*.  
\v 9 \w De|strong="H3588"\w* \w la|strong="H3588"\w* porción \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w se|strong="H1961"\w* tomó \w la|strong="H3588"\w* \w heredad|strong="H5159"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Simeón|strong="H8095"\w*, ya \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w parte|strong="H2506"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w era|strong="H1961"\w* muy \w grande|strong="H7227"\w* \w para|strong="H3588"\w* \w ellos|strong="H1992"\w*. \w Así|strong="H3588"\w* \w que|strong="H3588"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Simeón|strong="H8095"\w* \w tuvieron|strong="H1961"\w* \w su|strong="H1992"\w* \w heredad|strong="H5159"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w herencia|strong="H5159"\w* \w de|strong="H3588"\w* \w aquéllos|strong="H1992"\w*.   
\p
\v 10 \w La|strong="H1366"\w* \w tercera|strong="H7992"\w* \w suerte|strong="H1486"\w* tocó \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Zabulón|strong="H2074"\w*, según sus \w familias|strong="H4940"\w*, \w y|strong="H5704"\w* \w el|strong="H1121"\w* límite \w de|strong="H5704"\w* su \w heredad|strong="H5159"\w* llegaba \w hasta|strong="H5704"\w* \w Sarid|strong="H8301"\w*.  
\v 11 \w Por|strong="H5921"\w* \w el|strong="H5921"\w* oeste su límite \w subía|strong="H5927"\w* \w hasta|strong="H5921"\w* Marala \w y|strong="H5921"\w* llegaba \w hasta|strong="H5921"\w* Dabeset, \w y|strong="H5921"\w* \w de|strong="H5921"\w* allí \w hasta|strong="H5921"\w* \w el|strong="H5921"\w* \w arroyo|strong="H5158"\w* \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Jocneam,  
\v 12 \w de|strong="H5921"\w* \w Sarid|strong="H8301"\w* \w volvía|strong="H7725"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w este|strong="H4217"\w*, \w hacia|strong="H5921"\w* \w donde|strong="H5921"\w* \w sale|strong="H3318"\w* \w el|strong="H5921"\w* \w sol|strong="H8121"\w*, \w hasta|strong="H5921"\w* \w el|strong="H5921"\w* lindero \w de|strong="H5921"\w* Quislot-tabor, \w salía|strong="H3318"\w* \w a|strong="H3068"\w* Daberat \w y|strong="H5921"\w* \w subía|strong="H5927"\w* \w a|strong="H3068"\w* Jafía.  
\v 13 De \w allí|strong="H8033"\w* \w pasaba|strong="H5674"\w* al \w este|strong="H4217"\w*, \w a|strong="H3068"\w* Gat-jefer, hasta Et-cazín, y se extendía hasta Rimón, la cual limita con Nea.  
\v 14 \w Después|strong="H1961"\w* el límite giraba al \w norte|strong="H6828"\w*, \w hacia|strong="H1366"\w* Hanatón, \w e|strong="H3068"\w* iba \w a|strong="H3068"\w* \w salir|strong="H8444"\w* al \w valle|strong="H1516"\w* de Jefte-el,  
\v 15 donde están Catat, Nahalal, Simrón, Ideala y Belén: 12 \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.   
\p
\v 16 \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w heredad|strong="H5159"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Zabulón|strong="H2074"\w* según sus \w familias|strong="H4940"\w*. \w Estas|strong="H2063"\w* \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.   
\p
\v 17 La cuarta \w suerte|strong="H1486"\w* \w salió|strong="H3318"\w* para Isacar, para \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Isacar según sus \w familias|strong="H4940"\w*.  
\v 18 Su territorio \w fue|strong="H1961"\w* \w Jezreel|strong="H3157"\w*, Quesulot, \w Sunem|strong="H7766"\w*,  
\v 19 Hafaráim, Sihón, Anaharat,  
\v 20 Rabit, Quisión, Ebes,  
\v 21 Remet, En-ganim, En-hada y Bet-pases.  
\v 22 El límite llegaba hasta \w Tabor|strong="H8396"\w*, Sahasima y Bet-semes, y su lindero terminaba en el \w Jordán|strong="H3383"\w*: 16 \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.   
\p
\v 23 \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w herencia|strong="H5159"\w* \w de|strong="H1121"\w* \w la|strong="H2063"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Isacar según sus \w familias|strong="H4940"\w*. Esas \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.   
\p
\v 24 La quinta \w suerte|strong="H1486"\w* \w salió|strong="H3318"\w* para la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aser, según sus \w familias|strong="H4940"\w*.  
\v 25 Su territorio \w fue|strong="H1961"\w*: Helcat, Halí, Betén, Acsaf,  
\v 26 Alamelec, Amad y Miseal, y llegaba hasta el oeste de la montaña Carmelo y \w a|strong="H3068"\w* Sihor-libnat.  
\v 27 Después \w volvía|strong="H7725"\w* hacia donde \w sale|strong="H3318"\w* el \w sol|strong="H8121"\w* hasta Bet-dagón, llegaba hasta \w Zabulón|strong="H2074"\w* y al \w valle|strong="H1516"\w* de Jefte-el, hacia el \w norte|strong="H6828"\w* de Bet-emec y \w a|strong="H3068"\w* Neiel, y \w salía|strong="H3318"\w* por el \w norte|strong="H6828"\w* \w a|strong="H3068"\w* Cabul,  
\v 28 \w a|strong="H3068"\w* Hebrón, \w a|strong="H3068"\w* \w Rehob|strong="H7340"\w*, \w a|strong="H3068"\w* Hamón \w y|strong="H5704"\w* \w a|strong="H3068"\w* Caná, \w hasta|strong="H5704"\w* la \w gran|strong="H7227"\w* \w Sidón|strong="H6721"\w*.  
\v 29 \w De|strong="H5704"\w* allí el límite \w volvía|strong="H7725"\w* \w hacia|strong="H1366"\w* \w Ramá|strong="H7414"\w* \w y|strong="H5704"\w* \w hacia|strong="H1366"\w* \w la|strong="H1366"\w* \w ciudad|strong="H5892"\w* fortificada \w de|strong="H5704"\w* \w Tiro|strong="H6865"\w*, regresaba \w hacia|strong="H1366"\w* Hosa, \w y|strong="H5704"\w* salía \w al|strong="H5704"\w* \w mar|strong="H3220"\w* \w por|strong="H5704"\w* el territorio \w de|strong="H5704"\w* Aczib,  
\v 30 Uma, Afec y \w Rehob|strong="H7340"\w*: 22 \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.   
\p
\v 31 \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w herencia|strong="H5159"\w* \w de|strong="H1121"\w* \w la|strong="H2063"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aser según sus \w familias|strong="H4940"\w*. Esas \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.   
\p
\v 32 La sexta \w suerte|strong="H1486"\w* tocó \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Neftalí según sus \w familias|strong="H4940"\w*.  
\v 33 Su lindero iba \w desde|strong="H5704"\w* Hélef, Alón-saananim, Adami-néqueb \w y|strong="H5704"\w* Jabneel, \w hasta|strong="H5704"\w* \w Lacum|strong="H3946"\w*, \w y|strong="H5704"\w* salía \w al|strong="H5704"\w* \w Jordán|strong="H3383"\w*.  
\v 34 Desde \w allí|strong="H8033"\w* el límite \w volvía|strong="H7725"\w* \w hacia|strong="H5045"\w* el oeste hasta Aznot-tabor, y de \w allí|strong="H8033"\w* \w a|strong="H3068"\w* Hucoc, y llegaba hasta \w Zabulón|strong="H2074"\w* por el sur, y por el oeste limitaba con Aser y con \w Judá|strong="H3063"\w* \w en|strong="H3318"\w* el \w Jordán|strong="H3383"\w*, \w hacia|strong="H5045"\w* \w donde|strong="H8033"\w* \w sale|strong="H3318"\w* \w sol|strong="H8121"\w*.  
\v 35 \w Y|strong="H3068"\w* las \w ciudades|strong="H5892"\w* fortificadas eran: Sidim, \w Ser|strong="H6863"\w*, Hamat, Racat, Cineret,  
\v 36 Adama, \w Ramá|strong="H7414"\w*, Hazor,  
\v 37 Cedes, Edrei, En-hazor,  
\v 38 Irón, Migdal-el, Horem, Bet-anat y Bet-semes: 19 \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.   
\p
\v 39 \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w heredad|strong="H5159"\w* \w de|strong="H1121"\w* \w la|strong="H2063"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Neftalí según sus \w familias|strong="H4940"\w*. Esas \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.   
\p
\v 40 La séptima \w suerte|strong="H1486"\w* \w salió|strong="H3318"\w* para la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Dan|strong="H1835"\w* por sus \w familias|strong="H4940"\w*.  
\v 41 El territorio de su \w herencia|strong="H5159"\w* \w fue|strong="H1961"\w* Zora, Estaol, Ir-semes,  
\v 42 Saalabín, Ajalón, Jetla,  
\v 43 Elón, Timnat, \w Ecrón|strong="H6138"\w*,  
\v 44 Elteque, Gibetón, Baalat,  
\v 45 Jehúd, Bene-berac, Gat-rimón,  
\v 46 Me-harcón, y Racón, \w con|strong="H5973"\w* \w el|strong="H5973"\w* territorio que está frente \w a|strong="H3068"\w* Jope.   
\p
\v 47 \w El|strong="H5973"\w* territorio \w de|strong="H5973"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w Dan|strong="H1835"\w* \w se|strong="H1992"\w* amplió, pues \w subieron|strong="H5927"\w* y atacaron \w a|strong="H3068"\w* Lesem. \w La|strong="H1366"\w* capturaron, \w la|strong="H1366"\w* \w pasaron|strong="H3427"\w* \w a|strong="H3068"\w* filo \w de|strong="H5973"\w* \w espada|strong="H2719"\w*, \w la|strong="H1366"\w* \w poseyeron|strong="H3423"\w* y \w se|strong="H1992"\w* establecieron \w en|strong="H5973"\w* ella. \w A|strong="H3068"\w* Lesem \w la|strong="H1366"\w* \w llamaron|strong="H7121"\w* \w Dan|strong="H1835"\w*, por \w el|strong="H5973"\w* \w nombre|strong="H8034"\w* \w de|strong="H5973"\w* \w su|strong="H1992"\w* antepasado \w Dan|strong="H1835"\w*.   
\p
\v 48 \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w heredad|strong="H5159"\w* \w de|strong="H1121"\w* \w la|strong="H2063"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Dan|strong="H1835"\w* según sus \w familias|strong="H4940"\w*, esas \w ciudades|strong="H5892"\w* con sus \w aldeas|strong="H2691"\w*.   
\p
\v 49 Cuando \w acabaron|strong="H3615"\w* \w de|strong="H1121"\w* distribuir la tierra según sus límites, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w dieron|strong="H5414"\w* \w heredad|strong="H5159"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*, \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1121"\w* ellos.  
\v 50 \w Según|strong="H5921"\w* \w el|strong="H5921"\w* \w mandamiento|strong="H6310"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w le|strong="H5921"\w* \w dieron|strong="H5414"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w que|strong="H5921"\w* \w él|strong="H5921"\w* \w pidió|strong="H7592"\w*: Timnat-sera, \w en|strong="H5921"\w* \w la|strong="H5921"\w* región montañosa \w de|strong="H5921"\w* Efraín. \w Él|strong="H5921"\w* \w reedificó|strong="H1129"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w y|strong="H5921"\w* vivió \w en|strong="H5921"\w* \w ella|strong="H5921"\w*.   
\p
\v 51 Estas son las \w heredades|strong="H5159"\w* \w que|strong="H1121"\w* \w el|strong="H1121"\w* \w sacerdote|strong="H3548"\w* Eleazar y \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Nun|strong="H5126"\w*, y \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H6440"\w* las casas paternas repartieron \w por|strong="H6440"\w* sorteo entre las \w tribus|strong="H4294"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* en \w Silo|strong="H7887"\w*, en \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, en la entrada del Tabernáculo \w de|strong="H6440"\w* Reunión. Así \w acabaron|strong="H3615"\w* \w de|strong="H6440"\w* repartir la tierra.   
\c 20  
\s1 Ciudades de refugio  
\p
\v 1 \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*:  
\v 2 \wj \+w Habla|strong="H1696"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*: Designen las \+w ciudades|strong="H5892"\+w* \+w de|strong="H1121"\+w* refugio, \+w de|strong="H1121"\+w* las cuales les \+w hablé|strong="H1696"\+w* \+w por|strong="H3027"\+w* \+w medio|strong="H3027"\+w* \+w de|strong="H1121"\+w* \+w Moisés|strong="H4872"\+w*,\wj*  
\v 3 \wj \+w para|strong="H1961"\+w* \+w que|strong="H1961"\+w* huya \+w allí|strong="H8033"\+w* el \+w homicida|strong="H7523"\+w* \+w que|strong="H1961"\+w* mate \+w a|strong="H3068"\+w* alguien \+w sin|strong="H1097"\+w* intención, \+w sin|strong="H1097"\+w* premeditación, y les sirvan \+w de|strong="H1818"\+w* refugio del vengador \+w de|strong="H1818"\+w* la \+w sangre|strong="H1818"\+w*.\wj*   
\p
\v 4 \wj \+w El|strong="H1931"\+w* \+w que|strong="H1931"\+w* huya \+w a|strong="H3068"\+w* alguna \+w de|strong="H5973"\+w* esas \+w ciudades|strong="H5892"\+w*, \+w se|strong="H1931"\+w* \+w presentará|strong="H5975"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H1931"\+w* \+w puerta|strong="H6607"\+w* \+w de|strong="H5973"\+w* \+w la|strong="H1931"\+w* \+w ciudad|strong="H5892"\+w* y expondrá \+w sus|strong="H1931"\+w* \+w razones|strong="H1697"\+w* \+w a|strong="H3068"\+w* oídos \+w de|strong="H5973"\+w* \+w los|strong="H3427"\+w* \+w ancianos|strong="H2205"\+w* \+w de|strong="H5973"\+w* \+w aquella|strong="H1931"\+w* \+w ciudad|strong="H5892"\+w*. \+w Ellos|strong="H1931"\+w* \+w lo|strong="H1931"\+w* recibirán \+w consigo|strong="H5973"\+w* \+w en|strong="H5973"\+w* \+w la|strong="H1931"\+w* \+w ciudad|strong="H5892"\+w* y \+w le|strong="H1931"\+w* \+w darán|strong="H5414"\+w* \+w lugar|strong="H4725"\+w* \+w para|strong="H5414"\+w* \+w que|strong="H1931"\+w* viva \+w con|strong="H5973"\+w* \+w ellos|strong="H1931"\+w*.\wj*   
\p
\v 5 \wj \+w Si|strong="H3588"\+w* \+w el|strong="H1931"\+w* vengador \+w de|strong="H3588"\+w* \+w la|strong="H1931"\+w* \+w sangre|strong="H1818"\+w* \+w lo|strong="H1931"\+w* \+w persigue|strong="H7291"\+w*, \+w no|strong="H3808"\+w* \+w entregarán|strong="H5462"\+w* \+w en|strong="H3588"\+w* \+w su|strong="H1931"\+w* \+w mano|strong="H3027"\+w* al \+w homicida|strong="H7523"\+w*, \+w porque|strong="H3588"\+w* \+w mató|strong="H5221"\+w* \+w a|strong="H3068"\+w* \+w su|strong="H1931"\+w* \+w prójimo|strong="H7453"\+w* \+w sin|strong="H3808"\+w* premeditación, \+w sin|strong="H3808"\+w* aborrecerlo \+w antes|strong="H3588"\+w*.\wj*   
\p
