\id MAL - Biblica® Open Igbo Contemporary Bible 2020
\h Malakaị
\toc1 Malakaị
\toc2 Malakaị
\toc3 Mal
\mt1 Malakaị
\c 1
\p 
\v 1 Okwu amụma: Nke a bụ okwu \nd Onyenwe anyị\nd* gwara Izrel site nʼọnụ Malakaị onye amụma.
\s1 Izrel ekwenyeghị na Chineke hụrụ ha nʼanya
\p 
\v 2 “Ahụla m unu nʼanya,” ka \nd Onyenwe anyị\nd* na-ekwu.
\p “Ma unu na-asị, ‘Olee ụzọ i si hụ anyị nʼanya?’
\p “Ịsọ, ọ bụghị nwanne Jekọb?” ka \nd Onyenwe anyị\nd* kwupụtara. “Ma otu ọ dị, ahụrụ m Jekọb nʼanya,
\v 3 ma Ịsọ ka m kpọrọ asị, mee ugwu ya niile ka ha ghọọ ebe tọgbọrọ nʼefu, werekwa ihe nketa ya nye nkịta ọhịa niile nke ọzara.”
\p 
\v 4 Ndị Edọm nwere ike sị, “Ọ bụ ezie na e tikpọọla anyị, ma anyị ga-ewugharị nkpọnkpọ ebe niile.”
\p Ma otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, na-ekwu, “Ha nwere ike wugharịa ya, ma aga m akwadakwa ha ọzọ. Nʼihi na a ga-akpọ ha Obodo ihe ọjọọ, ndị \nd Onyenwe anyị\nd* na-eweso iwe ruo mgbe ebighị ebi.
\v 5 Anya unu ga-ahụ nke a ma unu ga-ekwukwa, ‘\nd Onyenwe anyị\nd* dị ukwuu, ọ bụladị ruo nʼofe oke ala Izrel!’ ”
\s1 Imebi ọgbụgba ndụ site nʼaja nwere ntụpọ
\p 
\v 6 “Nwa na-asọpụrụ nna ya, ohu na asọpụrụkwa onyenwe ya. A sị na m bụ nna, ebee ka egwu m dị. A sị na m bụ onyenwe mmadụ, ebee ka nsọpụrụ m dị?” Ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu.
\p “Ọ bụ unu ndị nchụaja na-eleda aha m anya.
\p “Ma unu na-ajụ, ‘Olee ụzọ anyị si eleda aha gị anya?’
\p 
\v 7 “Unu na-eji anụ rụrụ arụ na-achụrụ m aja nʼelu ebe ịchụ aja m.
\p “Ma unu na-ajụ, ‘Olee ụzọ anyị si merụọ ya?’
\p “Ọ bụ mgbe unu na-asị na tebul \nd Onyenwe anyị\nd* bụ ihe e kwesiri ileda anya.
\v 8 Mgbe unu ji anụ ndị kpuru ìsì achụrụ m aja, ọ bụghị ihe na-ezighị ezi ka unu na-eme? Mgbe unu na-ejikwa ndị dara ngwụrọ, na anụ na-arịa ọrịa, ọ bụghị ihe ọjọọ ka unu na-eme? Werenụ anụ ndị a bugara onye na-achị obodo unu dịka onyinye. Ọ ga-atọ ya ụtọ ịnabata onyinye dị otu a? Ọ ga-anabata unu?” Ka Onyenwe anyị, Onye pụrụ ime ihe niile na-ekwu.
\p 
\v 9 “Ma ugbu a, rịọọnụ Chineke ka o gosi anyị amara ya. Ọ bụrụ na unu ji onyinye ndị dị otu a nʼaka unu, ọ ga-egosi unu afọ ọma ya?” Ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu.
\p 
\v 10 “Ọ gaara adị m nnọọ mma ma a sị na otu onye nʼime unu ga-emechi ọnụ ụzọ ụlọnsọ ukwu ahụ, ka unu gharakwa ịkwanye ọkụ na-enweghị isi nʼelu ebe ịchụ aja m. Ihe banyere unu adịghị atọ m ụtọ. Ọ bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru. Agaghị m anabatakwa onyinye ọbụla si unu nʼaka.
\v 11 Nʼihi na site nʼọwụwa anyanwụ ruo ọdịda ya, aha m ga-adị ukwuu nʼetiti mba niile. A ga-ewebatara m ihe nsure ọkụ na-esi isi ụtọ na onyinye dị ọcha nʼaha m, nʼebe niile, nʼihi na aha m ga-adị ukwuu nʼetiti mba niile.” Ọ bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru.
\p 
\v 12 “Ma unu na-eme ka ọ ghara ịdị nsọ mgbe unu na-asị na, Tebul Onyenwe anyị bụ ihe e merụrụ emerụ, ebe ihe oriri ya bụkwa ihe nlelị.
\v 13 Unu na-ekwukwa, ‘Nke a bụ ihe ike ọgwụgwụ,’ si otu a na-eduli imi unu elu nʼebe m nọ nʼọnọdụ oke nlelị.” Ọ bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru.
\p “Mgbe unu na-ewebata ihe a natara nʼike, na nke dara ngwụrọ, na nke na-arịa ọrịa, jiri ha chụọrọ m aja, o kwesiri ka m nabata ya?” Ka \nd Onyenwe anyị\nd* na-ekwu.
\v 14 “Onye a na-abụ ọnụ ka onye aghụghọ ahụ bụ nke nwere oke nʼigwe ewu na atụrụ ya, kwee nkwa inye ya, ma mesịa were anụ nwere ntụpọ chụọrọ Onyenwe anyị aja. Nʼihi na mụ onwe m bụ Eze ukwu ahụ,” ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, “aha m bụkwa ihe a ga-atụ egwu nʼetiti mba dị iche iche.
\c 2
\s1 Ndụmọdụ ndị ọzọ nye ndị nchụaja
\p 
\v 1 “Ma ugbu a, unu ndị nchụaja, ịdọ aka na ntị a dịrị unu.
\v 2 Ọ bụrụ na unu ajụ ige ntị, ọ bụrụkwa na unu ekpebighị nʼobi unu inye aha m otuto,” ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, na-ekwu, “Aga m ezite ọbụbụ ọnụ nʼahụ unu, aga m abụkwa ngọzị unu niile ọnụ. E, abụọlarị unu ọnụ, nʼihi na unu ekpebighị nʼobi unu ịsọpụrụ m.
\p 
\v 3 “Nʼihi unu, aga m abara ụmụ ụmụ unu mba.\f + \fr 2:3 \ft Maọbụ, \fqa kpọnwụsịa mkpụrụ ọghịgha unu\f* Agaghị m anabata onyinye unu, aga m efesakwa nsị anụ nʼihu unu, bụ nsị nke ihe onyinye unu, aga m ewezugakwa unu site nʼihu m.
\v 4 Otu a ka unu ga-esi mara na ọ bụ mụ zitere unu ịdọ aka na ntị a, ka ọgbụgba ndụ mụ na Livayị gbara dịgide,” Ọ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, na-ekwu.
\v 5 “Ọgbụgba ndụ mụ na ya bụ nke ndụ na udo, ọ bụ m nyere ha ya, nke a bụ nʼihi nsọpụrụ. O nyere m nsọpụrụ nʼezie, tụkwaa aha m egwu.
\v 6 Iwu nke eziokwu dị ya nʼọnụ, ọ dịkwaghị okwu ụgha ọbụla a chọpụtara nʼegbugbere ọnụ ya. O soro m jee ije nʼudo, na nʼịkwụba aka ọtọ. O mekwara ka ọtụtụ si nʼajọ omume ha chigharịa.
\p 
\v 7 “Nʼihi na egbugbere ọnụ onye nchụaja kwesiri ijupụta nʼihe ọmụma; e kwesikwara isi nʼọnụ ya mụta ihe, nʼihi na ọ bụ onyeozi nke \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile.
\v 8 Ma unu esitela nʼụzọ ahụ wezuga onwe unu, sitekwa nʼozizi unu mee ka ọtụtụ mmadụ sụọ ngọngọ. Unu emerụọla ọgbụgba ndụ nke Livayị.” Ọ bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru.
\v 9 “Nʼihi nke a, emeela m ka unu bụrụ ndị a na-elelị anya, na ndị e wedara nʼala nʼihu ndị mmadụ niile, nʼihi na unu agbasoghị ụzọ m, kama unu na-ele mmadụ anya nʼihu, nʼihe metụtara iwu.”
\s1 Imebi ọgbụgba ndụ site nʼịgba alụkwaghị m
\p 
\v 10 Ọ bụghị otu Nna ka anyị niile nwere? Ọ bụghị otu Chineke ahụ kere anyị? Gịnị mere anyị ji na-emerụ ọgbụgba ndụ nna anyị ha site na-enweghị ntụkwasị obi na mmekọrịta anyị na ibe anyị?
\p 
\v 11 Juda ekwesighị ntụkwasị obi. E meela ihe arụ nʼIzrel na nʼime Jerusalem: Juda emerụọla ụlọnsọ ukwu \nd Onyenwe anyị\nd* hụrụ nʼanya, lụọkwa ada chi ndị mba ọzọ.
\v 12 Ka \nd Onyenwe anyị\nd* kewapụ onye mere ihe dị otu a nʼụlọ ikwu Jekọb, ka ọ ghara inwe onye akaebe, ka ọ ghara inwe onye ga-aza ya mgbe ọ kpọrọ oku maọbụ butere \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile onyinye.
\p 
\v 13 Ihe ọzọ unu na-emekwa bụ ndị a: unu na-eme ka anya mmiri unu jupụta nʼebe ịchụ aja \nd Onyenwe anyị\nd*. Unu na-akwa akwa, na-eti mkpu akwa nʼihi na ọ naghị elenye anya nʼonyinye unu, maọbụ jiri obi ụtọ nabata ha.
\v 14 Unu na-asị “Nke a ọ bụ nʼihi gịnị?” Ọ bụ nʼihi na \nd Onyenwe anyị\nd* bụ onyeama nʼetiti gị na nwunye ị lụrụ nʼokorobịa gị, nʼihi na ị kwesighị ntụkwasị obi, ọ bụ ezie na ọ bụ nwanyị e jikọtara gị na ya, bụrụkwa nwunye ọgbụgba ndụ gị.
\p 
\v 15 Ọ bụ na ọ bụghị otu Chineke ahụ kere gị? Nʼanụ ahụ na nʼime mmụọ, unu bụ nke ya. Ma gịnị ka otu Chineke a chọrọ? Ka unu bụrụ ụmụ na-atụ ya egwu. Ya mere, jie mmụọ gị aka, ka ị gharakwa ịbụ onye na-ekwesighị ntụkwasị obi nʼebe nwunye ị lụtara nʼokorobịa nọ.
\p 
\v 16 “Akpọrọ m ịgba alụkwaghị m asị,” ka \nd Onyenwe anyị\nd* Chineke nke Izrel sịrị, “a kpọkwara nwoke na-emeso nwunye ya mmeso nʼụzọ ihe ike asị.” Ọ bụ \nd Onyenwe\nd* Onye pụrụ ime ihe niile na-ekwu.
\p Ya mere, kpachapụrụnụ onwe unu anya, unu abụkwala ndị na-ekwesighị ntụkwasị obi.
\s1 Imebi ọgbụgba ndụ site nʼikpe mmegide
\p 
\v 17 Unu esitela nʼoke okwu unu mee ka ike gwụ \nd Onyenwe anyị\nd*.
\p Ma unu na-ajụ, “Olee ụzọ anyị si mee ka ike gwụ ya?”
\p Mgbe unu na-asị, “Ndị niile na-eme ihe ọjọọ dị mma nʼanya \nd Onyenwe anyị\nd*. Ihe ha na-atọkwa ya ụtọ,” maọbụ na-asịkwa, “Ebee ka Chineke ahụ na-ekpe ikpe ziri ezi nọ?”
\c 3
\p 
\v 1 “Lee, aga m ezipu onyeozi m, onye ga-edozi ụzọ nʼihu m. Mgbe ahụ, Onyenwe anyị ahụ unu na-ele anya ya ga-abịa na mberede nʼụlọnsọ ukwu ya. Onyeozi nke ọgbụgba ndụ ahụ, onye ihe ya na-agụsị unu agụụ ike, ga-abịa,” ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru.
\p 
\v 2 “Ma onye ga-anagide ụbọchị ọbịbịa ya ma guzokwa mgbe ọ pụtara ihe? Nʼihi na ọ ga-adị ka ọkụ na-anụcha anụcha, dịkwa ka ncha e ji asụ akwa.
\v 3 Ọ na-anọdụ ala dịka ndị na-anụcha ọlaọcha ime ka ọ dị ọcha. Ọ ga-anụcha ndị Livayị, ime ka ha dị ọcha, dịka ọlaedo na ọlaọcha a nụchara anụcha tutu ruo mgbe ha ga-ewetara \nd Onyenwe anyị\nd* onyinye nʼezi omume.
\v 4 Mgbe ahụ, onyinye Juda na Jerusalem ga-abụ onyinye \nd Onyenwe anyị\nd* ga-anabata, dịka o si anabata ha nʼụbọchị ndị ahụ gara aga, na mgbe ochie gara aga.
\p 
\v 5 “Mgbe ahụ, aga m abịa unu nso ikpe unu ikpe. Aga m abịakwa ngwangwa ịgbagide ha ama bụ ndị mgbaasị, na ndị na-akwa iko, na ndị na-aṅụ iyi ụgha, na ndị na-emegbu ndị inyom di ha nwụrụ, na ndị na-emegbu ndị na-enweghị nna, na ndị na-anapụ ndị ọbịa ikpe ziri ezi, ndị ahụ niile na-adịghị atụ egwu m.” Ọ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru.
\s1 Imebi ọgbụgba ndụ site nʼakwụghị otu ụzọ nʼime ụzọ iri
\p 
\v 6 “Nʼihi na mụ onwe m bụ \nd Onyenwe anyị\nd* adịghị agbanwe agbanwe. Ya mere, unu bụ ụmụ Jekọb ji dịgide.
\v 7 Site nʼoge nna nna unu ha, unu esitela nʼidebe iwu na ụkpụrụ m wezuga onwe unu. Unu adịghịkwa edebe ha. Ya mere, lọghachikwutenụ m, mụ onwe m ga-alọghachikwute unu.” Ọ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu.
\p “Ma unu na-asị, ‘Anyị ga-esi aṅaa lọghachi?’
\p 
\v 8 “Mmadụ ọ na-ezu ihe bụ nke Chineke nʼohi? Ma unu apụnarịla m ihe bụ nke m.
\p “Ma unu na-ajụ: ‘Anyị si aṅaa na-ezu gị ohi?’
\p “Ọ bụ site nʼotu ụzọ nʼime ụzọ iri unu, onyinye na aja niile.
\v 9 Nʼihi ya, ọbụbụ ọnụ dịịrị unu, ka mba niile unu ha, nʼihi na ọ bụ mụ onwe m ka unu na-ezu ohi.
\v 10 Webatanụ otu ụzọ nʼụzọ iri nke ihe niile unu nʼime ụlọakụ m, ka nri jupụta nʼime ụlọ m. Jirinụ nke a nwalee m,” ka unu hụ ma mụ onwe m agaghị emeghe ọnụ ụzọ eluigwe, site na ya wụdatara unu ngọzị dị ukwuu, nke ga-ejubiga oke na ọnọdụ agaghị adị ichebe ha. Ọ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu.
\v 11 “Aga m egbochi ihe nripịa ndị ahụ niile ka ha ghara iripịa mkpụrụ ubi unu. Osisi vaịnị unu agakwaghị atụpụsị mkpụrụ ya nʼala tutu ruo mgbe ha chara.” Ọ bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu.
\v 12 “Mgbe ahụ, mba niile dị iche iche ga-akpọ unu ndị a gọziri agọzi, nʼihi na ala unu ga-abụ nke na-enye ndị nwe ya obi ụtọ.” Ọ bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru.
\s1 Okwu mpako ndị Izrel megide Chineke
\p 
\v 13 \nd Onyenwe anyị\nd* na-ekwu, sị, “Unu ekwuola ọtụtụ okwu dị ike megide m.”
\p “Ma unu na-ajụ, ‘Gịnị ka anyị kwuru megide gị?’
\p 
\v 14 “Unu ekwuola sị, ‘Ọ bụ ihe nzuzu ife Chineke ofufe, na ịtụ ya egwu. Gịnị bụ uru anyị na-erite site nʼidebe iwu ya, na ijegharị dịka ndị na-eru ụjụ nʼihu \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile?
\v 15 Ma site ugbu a gaa nʼihu, ndị nganga ka anyị ga-akpọ ndị ihe na-agara nke ọma. Nʼezie, ndị na-eme ihe ọjọọ ka ihe na-agara nke ọma. Ndị ahụ jikwa ihe ọjọọ ha na-anwa Chineke na-agbanarị ntaramahụhụ ya.’ ”
\s1 Ụfọdụ ndị kwesiri ntụkwasị obi
\p 
\v 16 Mgbe ahụ, ndị niile na-atụ egwu \nd Onyenwe anyị\nd* gwarịtara ibe ha okwu, \nd Onyenwe anyị\nd* ṅara ntị, nụkwa ihe ha na-ekwu. Nʼihu ya, e nwere akwụkwọ ncheta dị ya, ebe e dere aha ndị niile na-atụ egwu \nd Onyenwe anyị\nd*, ma na-echekwa echiche banyere aha ya.
\p 
\v 17 “Nʼụbọchị ahụ m ga-eme ihe,” ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu, “ha ga-abụ ihe oke ọnụahịa nke aka m. Aga m echebe ha, dịka nna na-enwe ọmịiko ma chebekwa nwa ya nwoke na-efe ya.
\v 18 Unu ga-ahụ ihe dị iche nʼetiti ndị ezi omume na ndị ajọ omume, hụkwa ihe dị iche nʼetiti ndị na-efe Chineke na ndị na-adịghị efe ya.
\c 4
\s1 Ikpe ọmụma na ime ka ọgbụgba ndụ sie ike
\p \f + \fr 4:0 \ft Nʼakwụkwọ ndị Hibru, isi nke Anọ, site nʼamaokwu nke mbụ ruo na nke isii, bụ nke edepụtara dịka isi nke Atọ, amaokwu nke iri na itoolu ruo nke iri abụọ na anọ.\f*
\v 1 “Nʼezie, ụbọchị ahụ na-abịa, ọ ga-erekwa ọkụ dịka ebe a funyere ọkụ buru ibu. Mgbe ndị nganga, ndị na-eme ihe ọjọọ, ga-abụ igbugbo ọka, ụbọchị ahụ na-abịa ga-erechapụ ha,” otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru. “Ọ dịkwaghị mgbọrọgwụ maọbụ alaka ọbụla ga-afọdụrụ ha.
\v 2 Ma unu bụ ndị na-atụ egwu aha m ka anyanwụ nke ezi omume ga-achawapụta wetakwara unu ọgwụgwọ nke si nʼime nku ya. Unu ga-apụkwa, na-awụgharị dịka ụmụ ehi eji nri zujuo afọ.
\v 3 Mgbe ahụ, unu ga-azọpịakwa ndị ajọ omume. Ha ga-aghọkwa ntụ nʼokpuru ọbụ ụkwụ unu, nʼụbọchị ahụ m ga-eme ihe ndị a,” otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru.
\p 
\v 4 “Chetanụ iwu Mosis, bụ odibo m, ya bụ iwu na ụkpụrụ ndị ahụ dị iche iche m nyere ya na Horeb, maka Izrel niile.
\p 
\v 5 “Lee, aga m ezitere unu Ịlaịja onye amụma, tupu ụbọchị ukwu ahụ dị oke egwu bụ ụbọchị \nd Onyenwe anyị\nd* abịa.
\v 6 Ọ ga-eme ka obi ndị bụ nna chigharịkwute ụmụ ha, meekwa ka obi ndị bụ ụmụ chigharịkwutekwa nna ha; ka m ghara ịbịa ma jiri ịbụ ọnụ laa ala ahụ nʼiyi.”
