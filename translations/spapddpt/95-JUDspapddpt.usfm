\s1 Alabanza a Dios  
\p
\v 24 \w Al|strong="G3588"\w* \w que|strong="G3588"\w* es poderoso \w para|strong="G1722"\w* guardarlos \w sin|strong="G2532"\w* caída \w y|strong="G2532"\w* colocarlos \w en|strong="G1722"\w* \w pie|strong="G2476"\w* \w sin|strong="G2532"\w* mancha \w en|strong="G1722"\w* presencia \w de|strong="G1722"\w* \w su|strong="G3588"\w* \w gloria|strong="G1391"\w* \w con|strong="G1722"\w* gran gozo,  
\v 25 \w al|strong="G3588"\w* único \w Dios|strong="G2316"\w*, \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*, \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1519"\w* \w Jesucristo|strong="G2424"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w*, \w sea|strong="G3588"\w* \w gloria|strong="G1391"\w*, \w majestad|strong="G1391"\w*, soberanía \w y|strong="G2532"\w* \w autoridad|strong="G1849"\w*, \w tanto|strong="G1223"\w* \w antes|strong="G4253"\w* \w de|strong="G1519"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* siglos, \w como|strong="G2532"\w* \w ahora|strong="G3568"\w* \w y|strong="G2532"\w* \w por|strong="G1223"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* siglos. Amén.   