\c 18
\s1 Reinado de Ezequías en Judá
\p 
\v 1 \w El|strong="H1121"\w* \w año|strong="H8141"\w* \w tercero|strong="H7969"\w* \w de|strong="H1121"\w* \w Oseas|strong="H1954"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ela, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, comenzó \w a|strong="H3068"\w* reinar Ezequías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Acaz, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.
