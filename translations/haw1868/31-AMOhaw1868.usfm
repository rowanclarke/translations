\id AMO  
\h Amosa 
\toc1 Amosa 
\toc2 Amosa 
\toc3 Amosa 
\mt1 Amosa  
\c 1  
\s1 AMOSA.  
\q1
\v 1 O NA olelo a Amosa, ka mea iwaena o na kahu bipi o Tekoa, na mea ana i ike ai no ka Iseraela, i na la o Uzia, ke alii o ka Iuda, a i na la o Ieroboama, ke keiki a Ioasa, ke alii o ka Iseraela, elua makahiki mamua o ke olai.   
\q1
\v 2 A i aku la ia, E uwo mai o Iehova mai Ziona mai, A e hoopuka mai i kona leo mai Ierusalema mai; E uwe no na wahi noho o na kahuhipa, A e maloo ka piko o Karemela.   
\b  
\q1
\v 3 Penei ka Iehova i olelo ai; No na hala ekolu o Damaseko, a me ka ha, aole au e hoololi ae i kona hoopaiia, No ka mea, ua hehi lakou i ko Gileada me ka mea hao e hehi palaoa ai:   
\q1
\v 4 A e hoouna'ku ai i ke ahi iloko o ka hale o Hazaela, Ka mea e hoopau ai i na hale alii o Benehadada.   
\q1
\v 5 A e haki no ia'u ke kaola o Damaseko, A e hooki aku au i na kanaka mai ke awawa o Avena aku, A me ka mea e hoopaa ana i ke kookoo alii, mai ka hale o Edena aku: A e hele pio aku la na kanaka o Suria i Kira, wahi a Iehova.   
\b  
\q1
\v 6 Ke olelo mai nei o Iehova, penei; No na hala ekolu o Gaza, a me ka ha, aole au e hoololi ae i kona hoopaiia; No ko lakou lawe pio ana i ka poe pio a pau, A haawi aku ia lakou i ka Edoma;   
\q1
\v 7 Aka, e hoolei aku au i ke ahi maloko o ka papohaku o Gaza, A e hoopau aku ia i kona mau halealii;   
\q1
\v 8 A e hooki aku au i kanaka mai Asedoda aku, A me ka mea e hoopaa ana i ka hoailona moi mai Asekelona aku; A e hooku e aku au i kuu lima i Ekerona; A e make ke koena o ko Pilisetia, wahi a Iehova ka Haku.   
\b  
\q1
\v 9 Ke olelo mai nei o Iehova, peneia; No na hala ekolu, o Turo, a me ka ha, aole au e hoololi ae i kona hoopaiia: No ka mea, ua hoolilo lakou i ka poe pio a pau i ko Edoma, Aole hoi i hoomanao i ka berita o na hoahanau:   
\q1
\v 10 Aka, e hoolei aku au i ke ahi iloko o ka papohaku o Turo, Ka mea e hoopau ai i kona mau halealii.   
\b  
\q1
\v 11 Ke olelo mai nei o Iehova, penei; No na hala ekolu o ka Edoma, a me ka ha, aole au e hoololi ae i kona hoopaiia: No ka mea, ua hahai aku ia i kona hoahanau me ka pahikaua, A ua haalele aku i kona aloha, A ua haehae mau loa kona inaina, A ua hoomau loa ia i kona huhu.   
\q1
\v 12 A e hoolei aku au i ke ahi iloko o Temana, A e hoopau aku ia i na halealii o Bozera.   
\b  
\q1
\v 13 Ke olelo mai nei o Iehova, penei; No na hala ekolu o na mamo a Amona, a me ka ha, aole au e hoololi ae i kona hoopaiia; No ka mea, ua kaha aku lakou i na wahine hapai o Gileada, I hoopalahalaha aku ai lakou i ko lakou palena:   
\q1
\v 14 Aka, e hoa aku au i ke ahi iloko o ka papohaku o Raba, A e hoopau aku ia i na halealii ona, Me ka hooho i ka la o ke kaua, Me ka ino i ka la o ka puahiohio:   
\q1
\v 15 A e hele aku no ko lakou alii iloko o ke pio, Oia a me kana mau kaukaualii kekahi, wahi a Iehova.   
\c 2  
\b  
\q1
\v 1 OLELO mai o Iehova, penei; No na hala ekolu o ka Moaba, a me ka ha, Aole au e hoololi ae i kona hoopaiia; No ka mea, ua puhi aku ia i na iwi o ke alii o Edoma i puna.   
\q1
\v 2 Aka, e hoolei aku au i ke ahi iloko o Moaba; A e hoopau aku ia i na halealii o Kiriota: A e make ana ka Moaba, me ka haunaele, Me ka hooho, a me ke kani ana o ka pu.   
\q1
\v 3 A e hooki aku au i ka lunakanawai mai waena mai ona, A e pepehi aku au i kona mau luna a pau me ia, wahi a Iehova.   
\b  
\q1
\v 4 Ke olelo mai nei o Iehova, peneia; No na hala ekolu o ka Iuda, a me ka ha, aole au e hoololi ae i kona hoopaiia; No ka mea, ua hoowahawaha lakou i ke kanawai o Iehova, A ua malama ole i kana mau kauoha, A ua hoauwana aku la ko lakou mau mea wahahee ia lakou, Mamuli o na mea a ko lakou mau makua i hele ai:   
\q1
\v 5 Aka, e hoouna aku au i ke ahi maluna o Iuda, A e hoopau aku ia i na halealii o Ierusalema.   
\b  
\q1
\v 6 Ke olelo mai nei o Iehova penei; No na hala ekolu o ka Iseraela, a me ka ha, aole au e hoololi ae i kona hoopaiia; No ka mea, ua kuai aku lakou i ka poe pono no ke kala, A i ka mea ilihune no ka paa kamaa;   
\q1
\v 7 E kuko ana i ka lepo o ka honua maluna o ke poo o na ilihune, A hoololi ae i ka hoaponoia o ka poe popilikia: A komo aku ke kanaka, a me kona makuakane iloko i ke kaikamahine hookahi, I mea e hoohaumia'i i ko'u inoa hoano;   
\q1
\v 8 A moe iho lakou maluna o na kapa i laweia i ukupanai, ma kela kuahu keia kuahu, A inu no lakou i ka waina o ka poe i hoopaiia ma ka hale o ko lakou mau akua.   
\b  
\q1
\v 9 A ua luku aku au i ka Amora imua o lakou, O kona kiekie, ua like me ke kiekie o na laau kedara, A o kona ikaika, ua like me na laau oka; Aka, ua luku aku au i kona hua maluna, A me kona aa malalo.   
\q1
\v 10 A ua lawe mai hoi au ia oukou mai ka aina o Aigupita mai, A alakai ia oukou ma ka waonahele i na makahiki he kanaha, E komo ai i ka aina o ka Amora.   
\q1
\v 11 A ua hoolilo au i kekahi o ka oukou poe keiki, i poe kaula, A o ka poe kanaka opiopio o oukou, i poe Nazarite. Aole anei pela, e na mamo a Iseraela? wahi a Iehova.   
\q1
\v 12 Aka, hooinu oukou i ka poe Nazarite i ka waina, A papa aku oukou i na kaula, i aku la, Mai wanana oukou.   
\q1
\v 13 Aia hoi, e kaomi iho au ia oukou, E like me ke kaomi ana o ke kaa i piha i na pua.   
\q1
\v 14 A e nalowale ka mama mai ka mea mama aku, A o ka mea ikaika, aole ia e hookupaa i kona ikaika, Aole hoi e hoopakele ka mea mana ia ia iho.   
\q1
\v 15 Aole hoi e kupaa ka mea e lawe ana i ke kakaka; A o ka mea wawae mama, aole ia e pakele: Aole hoi ka mea holo maluna o ka lio e hoopakele i kona ola.   
\q1
\v 16 A o ka mea ikaika ma kona naau iwaena o ka poe ikaika, E holo kohana aku ia ia la, wahi a Iehova.   
\c 3  
\b  
\q1
\v 1 E HOOLOHE i keia olelo a Iehova i olelo mai ai no oukou, e na mamo a Iseraela, No ka ohana a pau, a'u i lawe mai ai mai ka aina o Aigupita mai, i mai la,   
\q1
\v 2 O oukou wale no ka'u i ike ai, mamua o na ohana a pau o ka honua: No ia mea, e hoopai aku ai au ia oukou no ko oukou hewa a pau.   
\q1
\v 3 E hiki anei i na mea elua ke hele pu, ke kuikahi pu ole laua?   
\q1
\v 4 E uwo anei ka liona ma ka ululaau ke loaa ole ia ia ke pio? E hoopuka anei ka liona opio i kona leo mai kona lua aku, ke loaa ole ia ia kekahi mea?   
\q1
\v 5 E haule anei ka manu iloko o ka pahele ma ka honua ke ole ka pahele nona? E lawe anei kekahi i ka pahele mai ka honua ae ke loaa ole ia ia kekahi mea iki?   
\q1
\v 6 E puhiia anei ka pu ma ke kulanakauhale, a pihoihoi ole na kanaka? He ino anei maloko o ke kulanakauhale, aole na Iehova ia i hana?   
\q1
\v 7 No ka mea, aole e hana mai o Iehova ka Haku i kekahi mea, Ke hoike ole mai ia i kona mea huna i kana mau kauwa, i na kaula.   
\q1
\v 8 Ua uwo mai ka liona, owai la ka mea makau ole? Ua olelo mai o Iehova ka Haku, owai la ka mea wanana ole?   
\b  
\q1
\v 9 E hai aku ma na halealii i Asedoda, A ma na halealii i ka aina o Aigupita, a e i aku, E hoakoakoaia oukou maluna o na mauna o Samaria, A e nana i ka haunaele nui iwaenakonu ona, A i na hookaumaha ana iloko ona.   
\q1
\v 10 Aole lakou e ike e hana i ka pono, wahi a Iehova, Hoiliili lakou i ka waiwai alunu, A i ka mea kaili wale, iloko o ko lakou mau halealii.   
\b  
\q1
\v 11 No ia mea, ke olelo mai nei o Iehova ka Haku, peneia; E hele mai auanei ka enemi, a puni ka aina; A e lawe aku ia i kou ikaika mai ou aku la, A e haoia kou mau halealii.   
\q1
\v 12 Ke olelo mai nei o Iehova, peneia; E like me ke kahuhipa i hoopakele mailoko mai o ka waha o ka liona, i na wawae elua a me kekahi apana o ka pepeiao; Pela e hoopakeleia na mamo a Iseraela, ka poe e noho ana ma Samaria ma ke kihi o kahi moe, a ma Damaseko ma kahi hikiee.   
\q1
\v 13 E hoolohe oukou, a e hoike aku i ko ka hale o Iakoba, wahi a Iehova ka Haku, ke Akua o na kaua;   
\q1
\v 14 A i ka la a'u e hoopai aku ai i ka hewa o ka Iseraela iluna ona, A e hoopai hoi au i na kuahu o Betela: A e okiia na pepeiaohao o ke kuahu, a haule iho la ia ilalo i ka honua.   
\q1
\v 15 A e wahi aku au i ka hale hooilo me ka hale kau. A e wawahiia na hale niho elepani, A hoopauia hoi na hale nui, wahi a Iehova.   
\c 4  
\b  
\q1
\v 1 E HOOLOHE oukou i keia olelo, e na bipi wahine o Basana, Na mea ma na mauna o Samaria, Na mea e hookaumaha ana i ka poe ilihune, Na mea e hooluhi ana i ka poe nele, Na mea e olelo ana i ko lakou mau haku, E lawe mai, a e inu kakou.   
\q1
\v 2 Ua hoohiki o Iehova ka Haku, ma kona hemolele, Aia hoi, e hiki mai ana na la maluna o oukou, E lawe aku ai oia ia oukou me na kilou, A i ka poe mahope o oukou i na makau lawaia.   
\q1
\v 3 A e puka aku oukou, ma ua wahi hiolo, o kela mea keia mea ma kona alo, A e hooleiia'ku iwaho o ka pakaua, wahi a Iehova.   
\b  
\q1
\v 4 E hele mai oukou i Betela, a e hana hewa; E hoonui i ka hana hewa ma Gilegala; A lawe mai oukou i ka oukou mau mohai no ke kakahiaka, A i na hapaumi o oukou no ke kolu o na makahiki:   
\q1
\v 5 A e puhi i ka berena hu i mohai aloha, A e hoike aku i na mohai aloha i lohe: No ka mea, o ka oukou makemake no ia, e na mamo a Iseraela, wahi a Iehova ka Haku.   
\b  
\q1
\v 6 A ua haawi aku hoi au ia oukou i ka maemae o na niho ma ko oukou mau kulanakauhale a pau, A i ka nele i ka berena ma ko oukou mau wahi a pau: Aka, aole oukou i hoi hou mai ia'u, wahi a Iehova.   
\q1
\v 7 A paa ia'u ka ua, mai o oukou aku, i ka manawa ekolu malama i koe a hiki i ka ohi ana: A hooua iho au maluna o kekahi kulanakauhale, A hooua ole au maluna o kekahi kulanakauhale: Ua hoouaia kau wahi, A o kahi i hooua ole ia, ua maloo.   
\q1
\v 8 A hele aku elua ekolu paha na kulanakauhale i kekahi kulanakauhale e inu i ka wai, aole nae i kena: Aka, aole oukou i hoi hou mai ia'u, wahi a Iehova.   
\q1
\v 9 Ua hahau aku au ia oukou i ka hua ai maalili, a me ka punahelu: He nui ko oukou kihapai, ko oukou mau pawaina, a me ko oukou mau laau fiku, a me ko oukou mau laau oliva, ua aiia hoi e ka uhini opiopio hulu ole; Aka, aole oukou i hoi hou mai ia'u, wahi a Iehova.   
\q1
\v 10 A ua hoouna aku au iwaena o oukou i ke ahulau, e like me ia ma Aigupita; Ua luku aku au i ko oukou poe kanaka opio i ka pahikaua, Me ko oukou poe lio i pioia; A ua hoopii ae au i ka pilau o ko oukou hoomoana ana, a hiki i ko oukou mau ihu; Aka, aole oukou i hoi hou mai ia'u, wahi a Iehova.   
\q1
\v 11 Ua luku aku au iwaena o oukou, E like me ka luku ana o ke Akua ia Sodoma a me Gomora; Ua like hoi oukou me ka momokuahi i kailiia mai loko mai o ke ahi: Aka, aole oukou i hoi hou mai ia'u, wahi a Iehova.   
\q1
\v 12 No ia mea, pela au e hana aku ai ia oe, e ka Iseraela: A no ka'u hana ana aku i keia ia oe, E hoomakaukau oe e halawai me kou Akua, e ka Iseraela.   
\q1
\v 13 No ka mea, aia hoi, o ka mea nana i hana na mauna, A o ka mea i hana i ka makani, A hai aku i ke kanaka i kona manao, A o ka mea i hoolilo i ka wanaao i pouli, O ka mea e hehi ana maluna o na wahi kiekie o ka honua, O Iehova, ke Akua o na kaua, kona inoa.   
\c 5  
\b  
\q1
\v 1 E HOOLOHE oukou i keia olelo, a'u e hapai aku nei no oukou, Oia hoi, he kanikau, e ka hale o ka Iseraela.   
\q1
\v 2 Ua haule, aole e ala hou ae, ke kaikamahine puupaa o ka Iseraela: Ua kulaina oia maluna o kona aina iho: Aohe mea nana ia e hoala.   
\q1
\v 3 No ka mea, ke olelo mai nei o Iehova ka Haku, peneia: O ko ke kulanakauhale i hele patausani aku, e koe mai no he haneri; A o ka mea i hele pahaneri aku, e koe mai no he umi, no ka hale o ka Iseraela.   
\b  
\q1
\v 4 No ka mea, ke olelo mai nei o Iehova peneia i ka hale o ka Iseraela, E imi oukou ia'u, a e ola oukou.   
\q1
\v 5 Aka, mai imi oukou i Betela, Aole hoi e komo i Gilegala, Aole e hele aku i Beereseba; No ka mea, he oiaio, e hele pio aku ko Gilegala, A e lilo o Betela i mea ole.   
\q1
\v 6 E imi oukou ia Iehova, a e ola oukou; O lele mai ia, me he ahi la, ma ka hale o Iosepa, A e hoopau aku ia, Aohe mea nana ia e kinai ma Betela.   
\q1
\v 7 E ka poe i hoolilo i ka olelo hoopono i mea awaawa, A hoolei i ka pono ma ka honua,   
\b  
\q1
\v 8 E imi i ka mea nana i hana ia Peleiade a me Oriona, A hoolilo i ka malu o ka make i malamalama, A hoopouli i ke ao a lilo i po: Ka mea e hoopii ana i na wai o ka moana, A ninini iho ia lakou maluna o ka ili o ka honua: O Iehova kona inoa:   
\q1
\v 9 O ka mea e lawe mai i ka make maluna o ka poe ikaika, A e hoohiki mai i ka luku maluna o kahi paa.   
\b  
\q1
\v 10 Ke inaina nei lakou i ka mea e ao ana ma ka pukapa, A hoowahawaha lakou i ka mea e olelo pono ana.   
\q1
\v 11 No ia mea, no ko oukou hehi ana maluna o ka ilihune, A ke lawe nei oukou i ka ai makana mai ona aku la: Ua hana oukou i na hale pohaku i kalaiia, Aka, aole oukou e noho iloko o lakou; Ua kanu oukou i na pawaina maikai, Aka, aole oukou e inu i ka waina o lakou.   
\q1
\v 12 No ka mea, ua ike au, he nui wale ko oukou lawehala ana, A me ko oukou mau hewa nui: E hoopilikia ana i ka poe hoopono, e lawe ana i ka uku kipe, A e hookahuli ana i ka pono o ka poe ilihune ma ka pukapa.   
\q1
\v 13 No ia mea, e noho malie ka mea naauao i kela manawa; No ka mea, he manawa ino ia.   
\b  
\q1
\v 14 E imi oukou i ka maikai, aole i ka hewa, i ola oukou; A pela e mau ai o Iehova, ke Akua o na kaua me oukou, e like me ka oukou i olelo ai.   
\q1
\v 15 E inaina i ka hewa, a e aloha i ka maikai, A e hookupaa oukou i ka hoopono ma ka pukapa: Malia paha e aloha mai o Iehova, ke Akua o na kaua, i ke koena o ka Iosepa.   
\b  
\q1
\v 16 No ia hoi, ke olelo mai nei o Iehova, ke Akua o na kaua, ka Haku, peneia; Ma na alanui a pau he auwe ana; A ma na wahi iwaho a pau, e olelo lakou, Auwe! auwe! A e kahea aku lakou i ka mea mahiai i ka u ana, A i ka poe ike e kanikau i ka uwe ana.   
\q1
\v 17 A ma na pawaina a pau ka uwe ana: No ka mea, e hele auanei au iwaena ou, wahi a Iehova.   
\b  
\q1
\v 18 Auwe ka poe iini i ka la o Iehova! No ke aha la keia ia oukou? O ka la o Iehova, he pouli ia, aole he malamalama.   
\q1
\v 19 E like me ke kanaka i holo mai ke alo aku o ka liona, a halawai ka bea me ia: A i komo paha iloko o ka hale, a hilinai kona lima ma ka paia, a nahu mai ka nahesa ia ia.   
\q1
\v 20 Aole anei he pouli ka la o Iehova, me ka malamalama ole? A he pouli loa, aohe ona malamalama.   
\b  
\q1
\v 21 Ke inaina nei au, ke hoowahawaha nei au i ko oukou mau ahaaina, Aole wau e oluolu i ko oukou mau halawai ana.   
\q1
\v 22 Ina e kaumaha mai oukou no'u i ka oukou mau mohai kuni, a me ka oukou mau mohai makana, aole au e oluolu ia mea: Aole hoi au e manao i ka mohai aloha o ko oukou mau mea momona.   
\q1
\v 23 E lawe ae oe mai o'u aku nei i ke oli ana o ka oukou mau mele; Aole au e hoolohe i ke kani ana o ko oukou mau viola.   
\q1
\v 24 Aka, e hookaheia ka hoopono ana e like me ka wai, A o ka pono e like me ka waikahe ikaika.   
\b  
\q1
\v 25 Ua kaumaha mai anei oukou na'u i na mohai, a me na makana ma ka waonahele i na makahiki he kanaha, e ka hale o ka Iseraela?   
\q1
\v 26 Ua hali oukou i ka halelewa o ko oukou Moloka, A me ka hale o ko oukou mau kii, Ka hoku o ko oukou akua, ka mea a oukou i hana'i no oukou.   
\q1
\v 27 Nolaila, e lawe pio aku au ia oukou ma o aku o Damaseko, wahi a Iehova, ke Akua o na kaua, kona inoa.   
\c 6  
\b  
\q1
\v 1 A UWE ka poe palaka ma Ziona, A hilinai hoi ma ka mauna o Samaria: Ka poe i oleloia, o na pookela o na lahuikanaka, Io lakou la i hele mai ka Iseraela!   
\q1
\v 2 E hele aku oukou i Kalene, a e nana; A mai laila aku e hele ai oukou i Hamata nui; Alaila, e iho aku i Gata o ko Pilisetia: Ua oi anei ko lakou maikai mamua o ko keia mau aupuni? Ua oi anei ka palahalaha o ko lakou mokuna mamua o ko oukou mokuna?   
\q1
\v 3 Auwe ka poe i hooloihi aku i ka la ino, A hookokoke i ka noho hookaumaha wale;   
\b  
\q1
\v 4 Ka poe e moe ana maluna o na wahi moe niho elepani, A moe hoolei loa maluna o ko lakou wahi moe, A ai iho i na keikihipa o ka poe hipa, A me na keiki bipi i kupeleia;   
\q1
\v 5 Ka poe mele mamuli o ka viola, A hana lakou no lakou iho i na mea kani e like me Davida;   
\q1
\v 6 Ka poe inu waina maloko o na kiaha, A kahinu ia lakou iho i ka hinu maikai: Aka, aole i kaumaha lakou no ka eha ana o ka Iosepa!   
\b  
\q1
\v 7 No ia mea, ano e hele pio aku ai lakou iwaena o ka poe pio mua, A e laweia'ku ka olioli o ka poe moe hoolei loa.   
\b  
\q1
\v 8 Ua hoohiki o Iehova ka Haku, ma kona ola, wahi a Iehova, ke Akua o na kaua, Ke hoopailua nei au i ka haaheo o Iakoba, A ke hoowahawaha nei hoi i kona mau halealii; Nolaila, e hoolilo aku ai au i ke kulanakauhale, a me kona mea i piha ai.   
\q1
\v 9 A ina e waihoia na kanaka he umi ma ka hale hookahi, e make no lakou.   
\q1
\v 10 A o ka hoahanau o kona makuakane e lawe aku ia ia, A o ka mea i puhi ia ia, e lawe aku iwaho i na iwi mailoko mai o ka hale, A e olelo aku i ka mea maloko loa o ka hale, Aole anei he mea i koe me oe? e i mai kela, Aole. Alaila, e i aku ia, Hamau; no ka mea, aole e olelo ma ka inoa o Iehova.   
\q1
\v 11 No ka mea, aia hoi, ke kauoha mai nei o Iehova, A e hahau aku ia i ka hale nui me ka nahaha, A i ka hale uuku me ka wawahi.   
\b  
\q1
\v 12 E holo anei na lio maluna o na pohaku? E mahi oopalau ia anei malaila me na bipi kauo? No ka mea, ua hoolilo oukou i ka hoopono ana i laau make, A i ka hua o ka pono, i laau awaawa:   
\q1
\v 13 E oukou, ka poe e olioli ana i ka mea ole, Ka poe e olelo, Aole anei kakou i lawe no kakou i na pepeiaohao ma ko kakou ikaika?   
\q1
\v 14 Aka, aia hoi, e hoala ku e auanei au i lahuikanaka ia oukou, e ko ka hale o Iseraela, wahi a Iehova, ke Akua o na kaua; A e hookaumaha lakou ia oukou mai ke komo ana o Hamata a hiki i ke kahawai o ka papu.   
\c 7  
\b  
\q1
\v 1 PENEIA i hoike mai ai o Iehova ka Haku ia'u: Aia hoi, hana iho la ia i na uhini i ka ulu mua ana o ka weuweu hope; aia hoi, o ka weuweu lua ia mahope o ka ke alii oki ana. A i ka wa i hoopau ai lakou i ka ai ana i ka weuweu o ka aina, alaila i aku la au,   
\q1
\v 2 E Iehova ka Haku, ke noi aku nei au, e kala mai oe. Pehea la e ku mai ai o Iakoba? No ka mea, ua uuku ia.   
\q1
\v 3 Huli ae la o Iehova no keia mea: aole ia e hiki mai, wahi a Iehova.   
\b  
\q1
\v 4 Peneia i hoike mai ai o Iehova ka Haku ia'u; Aia hoi, kahea mai o Iehova ka Haku, e hakaka me ke ahi, a ai iho la ia i ka hohonunui, a hoopau iho la i kauwahi. Alaila, i aku la au,   
\q1
\v 5 E ka Haku, e Iehova, ke noi aku nei au, e oki: Pehea e ku mai ai o Iakoba? No ka mea, ua uuku ia.   
\q1
\v 6 Huli ae la o Iehova no keia mea: aole e hiki mai keia, wahi a Iehova ka Haku.   
\b  
\q1
\v 7 Peneia i hoike mai ai oia ia'u: Aia hoi, ku mai la ka Haku maluna o ka papohaku kupono, me ka mea hookupono ma kona lima.   
\q1
\v 8 A i mai la o Iehova ia'u, E Amosa, heaha la kau e ike nei? A i aku la au, He mea hookupono. Alaila, i mai la o Iehova. Aia hoi, e hoonoho aku au i na mea hookupono iwaena o kuu poe kanaka o ka Iseraela: Aole au i hele hou ae mai o lakou aku.   
\q1
\v 9 A e hooneoneoia na wahi kiekie o Isaaka, A e wawahiia na wahi hoano o ka Iseraela: A e ku e aku au i ka hale o Ieroboama me ka pahikaua.   
\b  
\q1
\v 10 Alaila, hoouna aku la o Amazia, ke kahuna o Betela. Io Ieroboama la, ke alii o ka Iseraela, i aku la, Ua ku e mai o Amosa ia oe iwaena o ko ka hale o Iseraela: aole e hiki i ka aina ke hoomanawanui i kana mau olelo a pau.   
\q1
\v 11 No ka mea, ke olelo mai nei o Amosa penei, E make auanei o Ieroboama i ka pahikaua, a e lawe pio ia'ku ka Iseraela mai ko lakou aina aku.   
\q1
\v 12 Olelo aku la hoi o Amazia ia Amosa, E ke kaula ike, o hele, e holo aku oe i ka aina o Iuda, a malaila e ai ai i ka berena, a e wanana malaila:   
\q1
\v 13 A mai wanana hou ma Betela: no ka mea, he heiau keia no ke alii, a o ko ke alii hale noho keia.   
\b  
\q1
\v 14 Alaila, olelo aku la o Amosa, a i aku la ia Amazia, Aole wau he kaula mamua. aole hoi he keiki a ke kaula; aka, he hanai bipi wau, a he mea hoiliili hua sukamore:   
\q1
\v 15 A lawe o Iehova ia'u mai ka hahai ana i na holoholona, a olelo mai o Iehova ia'u, E hele, e wanana aku i kuu poe kanaka i ka Iseraela.   
\b  
\q1
\v 16 Ano hoi, e hoolohe oe i ka olelo a Iehova; Ke olelo nei oe, Mai wanana ku e aku i ka Iseraela, a mai hapai ku e oe i kau olelo i ko ka hale o Isaaka.   
\q1
\v 17 No ia mea, ke olelo mai nei o Iehova, penei: E moe kolohe kau wahine ma ke kulanakauhale, a o kau mau keikikane, a me kau mau kaikamahine, e haule lakou i ka pahikaua, A e puunaueia kou aina me ke kaula-ana: a e make oe ma ka aina haumia; A e hele pio aku ka Iseraela mai ko lakou aina aku.   
\c 8  
\b  
\q1
\v 1 PENEIA i hoike mai ai o Iehova ka Haku ia'u: aia hoi, he hinai hua oo.   
\q1
\v 2 A i mai la ia, Heaha kau e ike nei, e Amosa? I aku la au, He hinai hua oo. Alaila, i mai la o Iehova ia'u, Ua hiki mai ka hope maluna o kuu poe kanaka o ka Iseraela; Aole au e hele hou ae mai o lakou aku.   
\q1
\v 3 A e lilo na mele o ka halealii i auwe ana ia la, wahi a Iehova ka Haku: A he nui auanei na kupapau ma na wahi a pau: a e hoolei malu aku ia lakou.   
\b  
\q1
\v 4 E hoolohe i keia, e oukou ka mea e moni i ka poe ilihune, a hoopau i ka poe nele o ka aina,   
\q1
\v 5 I ka i ana ae, Ahea la e pau ai ka mahina hou, i kuai aku ai kakou i ka ai? A me ka Sabati, i wehe ae ai kakou i ka hua ai, e houuku ana i ka epa, A e hoomahuahua ana i ke sekela, a e hoololi ana i na mea kaupaona hoopunipuni?   
\q1
\v 6 I kuai aku ai kakou i ka poe ilihune no ke kala, A i ka poe nele no ka paa kamaa; a i kuai aku ai i ka hua palaoa ino?   
\b  
\q1
\v 7 Ua hoohiki o Iehova ma ka nani o Iakoba, Aole loa au e hoopoina i ka lakou mau hana a pau.   
\q1
\v 8 Aole anei e haalulu ka aina no keia mea, a e auwe na mea a pau e noho ana iloko ona? A e pii ae ia me he muliwai la a puni ona; A e laweia'ku ia, a e halana ae ia e like me ka muliwai o Aigupita.   
\q1
\v 9 A i kela la, wahi a Iehova ka Haku, E hoonapoo iho au i ka la i ke awakea, a e hoopouli iho au i ka aina i ka la laelae.   
\q1
\v 10 A e hoolilo au i ka oukou mau ahaaina i auwe ana, A i ko oukou mau mele i kanikau ana; A e lawe mai au i ke kapa ino maluna o na puhaka a pau, A me ka ohule maluna o na poo a pau; A e hoohalike au ia mea me ka auwe ana no ke keiki kamakahi, A i ka hope o ia mea e like me ka la awaawa.   
\b  
\q1
\v 11 Aia hoi, e hiki mai ana na la, wahi a Iehova ka Haku, E lawe mai ai au i ka wi maluna o ka aina, aole o ka wi i ka ai, aole o ka make inu i ka wai, Aka, o ka lohe i ka olelo a Iehova.   
\q1
\v 12 A e auwana lakou mai ke kai a hiki i ke kai, a mai ke kukulu akau, a ka hikina, E holo lakou ma o a ma o, e imi ana i ka olelo a Iehova, aole e loaa.   
\q1
\v 13 I kela la. e maule na wahine puupaa maikai, a me na kanaka opio no ka makewai.   
\q1
\v 14 O ka poe e hoohiki ma ka hewa o Samaria, a i iho, E ola ana kou Akua, e Dana; a e ola ana ka aoao o Beereseba; E haule no hoi lakou, aole loa e ala hou ae.   
\c 9  
\b  
\q1
\v 1 I KE aku la au ia Iehova e ku ana maluna o ke kuahu: a i mai la ia, E hahau i ke poo o ke kia, i haalulu ai na kumu kia; A e oki ia lakou ma ke poo, ia lakou a pau; A e pepehi aku au i ke koena o lakou me ka pahikaua: O ka mea o lakou e holo ana, aole ia e malu; A o ka mea e pakele ana, aole e pakele io.   
\q1
\v 2 Ina e eli iho lakou i ka po, e lawe ko'u lima ia lakou mailaila mai; Ina e pii lakou i ka lani, e lawe au ia lakou mailaila mai;   
\q1
\v 3 A ina e pee lakou maluna o ka piko o Karemela, e imi aku au, a e lawe ia lakou mailaila mai; A ina e pee lakou mai kuu maka aku ma ka mole o ke kai, Malaila e kena aku au i ka nahesa, a e nahu aku ia ia lakou.   
\q1
\v 4 A ina e hele pio aku lakou imua o ko lakou poe enemi, Malaila e kena aku au i ka pahikaua, a e luku aku ia ia lakou; A e kau aku kuu mau maka maluna o lakou no ka ino, aole no ka maikai.   
\b  
\q1
\v 5 A o Iehova, ka Haku o na kaua, oia ka mea e hoopa i ka aina, a e hehee iho no ia; A e auwe iho ka poe a pau e noho ana iloko ona: A e ea ae ia me he muliwai la a puni ona; A e halana ae e like me ka muliwai o Aigupita.   
\q1
\v 6 Oia ka i hana i na papaluna iloko o ka lani, a i hookumu i kona poai maluna o ka honua; O ka mea i hoopii ae i na wai o ka moana, a ninini iho ia lakou maluna o ka ili o ka aina; O Iehova kona inoa:   
\b  
\q1
\v 7 E na mamo a Iseraela, aole anei oukou i like ia'u me na mamo a Kusa? wahi a Iehova. Aole anei au i lawe mai i ka Iseraela mai ka aina o Aigupita mai? A i ko Pilisetia mai Kapetora mai, a me ko Suria mai Kira mai?   
\q1
\v 8 Aia hoi, o na maka o Iehova ka Haku maluna o ke aupuni hewa; A e hokai aku au ia mai ka honua aku; Aka hoi, aole au e luku loa aku i ko ka hale o Iakoba, wahi a Iehova.   
\q1
\v 9 No ka mea, aia hoi, e kauoha aku au, a e kanana iho ai i ko ka hale o Iseraela iwaena o na lahuikanaka a pau; E like me ka hua palaoa i kananaia iloko o ke kanana, Aole e haule kekahi hua ma ka honaa.   
\q1
\v 10 E make ka poe hewa a pau o kuu poe kanaka i ka pahikaua, Ka poe e olelo ana, Aole e hiki mai ka hewa mahope, aole hoi mamua o kakou.   
\b  
\q1
\v 11 I kela la e kukulu au i ka halelewa o Davida i wawahiia, A e hoopaa i kona wahi hiolo; A e hooku hou au i kona mau mea i heleleiia, A hana aku ia e like me na la mamua;   
\q1
\v 12 I lilo no lakou ke koena o ka Edoma, a me na lahuikanaka a pau, Ka poe i kaheaia ka inoa o Iehova maluna o lakou, wahi a Iehova, nana keia i hana.   
\b  
\q1
\v 13 Aia hoi, e hiki mai na la, wahi a Iehova, E halawai ai ka mea e mahiai ana, me ka mea e oki ana, A o ka mea e hehi i na huawaina, me ka mea e lulu i ka hua; A e hookulukulu iho na mauna i ka waina hou, A e hehee iho na puu a pau.   
\q1
\v 14 A e hoihoi mai au i ka poe pio o kuu poe kanaka o ka Iseraela, A e kukulu lakou i na kulanakauhale neoneo, a noho lakou iloko; A e kanu lakou i na pawaina, a e inu lakou i ko lakou waina; A e hana lakou i na kihapai, a e ai hoi i ko lakou hua.   
\q1
\v 15 A e kanu iho au ia lakou ma ko lakou aina iho, Aole e uhuki hou ia ae lakou mai ko lakou aina ae, Ka mea a'u i haawi aku ai ia lakou, wahi a Iehova kou Akua.   