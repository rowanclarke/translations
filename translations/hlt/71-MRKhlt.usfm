\v 29 \x - \xo 4.29 \xt Joe 3. 13.\x*\wj \+w Tedae|strong="G1161"\+w* \+w cangvuei|strong="G2590"\+w* \+w loh|strong="G3588"\+w* \+w hmin|strong="G3860"\+w* \+w tih|strong="G3752"\+w* \+w cangah|strong="G2326"\+w* a \+w pha|strong="G3936"\+w* \+w atah|strong="G3754"\+w* \+w vin|strong="G1407"\+w* \+w tlek|strong="G2117"\+w* a \+w pom|strong="G0649"\+w*,” \wj* a \w ti|strong="G3004"\w* nah.   
\s1 Mukang Tii Thuinuetnah  
\p
\v 30 Te phoeiah Jesuh loh, \wj “ \+w Pathen|strong="G2316"\+w* \+w ram|strong="G0932"\+w* \+w he|strong="G3588"\+w* \+w metlam|strong="G4459"\+w* \+w n'thuidoek|strong="G3666"\+w* \+w vetih|strong="G2228"\+w* \+w mebang|strong="G5101"\+w* \+w nuettahnah|strong="G3850"\+w* \+w nen|strong="G1722"\+w* \+w n'nueh|strong="G5087"\+w* lah ve?\wj*  
\v 31 \wj \+w Pathen|strong="G2316"\+w* \+w ram|strong="G0932"\+w*\+w tah|strong="G3588"\+w* \+w mukang|strong="G4615"\+w* \+w mu|strong="G2848"\+w* \+w bangla|strong="G5613"\+w* om. \+w Te|strong="G3739"\+w* te \+w diklai|strong="G1093"\+w* \+w dongah|strong="G1909"\+w* a \+w haeh|strong="G4687"\+w* \+w vaengah|strong="G3752"\+w* tah \+w diklai|strong="G1093"\+w* \+w hmankah|strong="G1909"\+w* a \+w tii|strong="G4690"\+w* \+w boeih|strong="G3956"\+w* lakah a \+w yit|strong="G3398"\+w* koek la \+w om|strong="G5607"\+w*\wj*.  
\v 32 \wj A \+w haeh|strong="G4687"\+w* \+w phoeiah|strong="G3752"\+w* \+w rhoeng|strong="G0305"\+w* \+w tih|strong="G2532"\+w* \+w toian|strong="G3001"\+w* \+w boeih|strong="G3956"\+w* lakah a \+w tanglue|strong="G3187"\+w* la \+w coeng|strong="G1096"\+w*, a \+w hlaeng|strong="G2798"\+w* \+w khaw|strong="G2532"\+w* a \+w len|strong="G3173"\+w* la \+w cawn|strong="G4160"\+w*. Te \+w dongah|strong="G5620"\+w* \+w vaan|strong="G3772"\+w* kah \+w vaa|strong="G4071"\+w* khaw \+w a|strong="G0846"\+w* \+w hlipkhup|strong="G4639"\+w* \+w ah|strong="G5259"\+w* bu a \+w tuk|strong="G2681"\+w* \+w thai|strong="G1410"\+w*,” \wj* a \w ti|strong="G3004"\w* nah.   
\p
\v 33 A \w yaak|strong="G0191"\w* \w thai|strong="G1410"\w* \w la|strong="G2531"\w* \w hebang|strong="G5108"\w* \w nuettahnah|strong="G3850"\w* neh \w amih|strong="G0846"\w* taengah \w ol|strong="G3056"\w* \w muep|strong="G4183"\w* a \w thui|strong="G2980"\w* pah.  
\v 34 \w Nuettahnah|strong="G3850"\w* \w pawt|strong="G5565"\w* \w atah|strong="G1161"\w* \w amih|strong="G0846"\w* taengah a \w thui|strong="G2980"\w* \w moenih|strong="G3756"\w*. \w Tedae|strong="G1161"\w* \w a|strong="G2398"\w* \w hnukbang|strong="G3101"\w* rhoek ham \w bueng|strong="G2596,G2398"\w* ni \w boeih|strong="G3956"\w* a \w thuicaih|strong="G1956"\w* pah.   
\s1 Hlipuei Loh Duem Coeng  
\p
\v 35 \w Te|strong="G1565"\w* \w khohnin|strong="G2250"\w* \w hlaem|strong="G3798"\w* a \w pha|strong="G1096"\w* \w vaengah|strong="G2532"\w* \w amih|strong="G0846"\w* te, \wj “ \+w Rhlavangan|strong="G4008"\+w* \+w la|strong="G1519"\+w* \+w lan|strong="G1330"\+w* uh sih,” \wj* a \w ti|strong="G3004"\w* nah.   
\p
\v 36 Te \w phoeiah|strong="G2532"\w* \w hlangping|strong="G3793"\w* \w te|strong="G3588"\w* a \w hlah|strong="G0863"\w* uh tih \w lawng|strong="G4143"\w* \w khuiah|strong="G1722"\w* aka \w om|strong="G2258"\w* \w Jesuh|strong="G2424"\w* te \w pahoi|strong="G5613"\w* a \w khuen|strong="G3880"\w* uh. \w Lawng|strong="G4143"\w* \w tloe|strong="G0243"\w* rhoek \w khaw|strong="G2532"\w* \w Jesuh|strong="G2424"\w* \w taengah|strong="G3326"\w* \w om|strong="G2258"\w* uh.  
\v 37 Te \w vaengah|strong="G2532"\w* \w khohli|strong="G0417"\w* aka \w tlo|strong="G3173"\w* \w hlipuei|strong="G2978"\w* te \w hli|strong="G1096"\w*. Te \w dongah|strong="G2532"\w* \w tuiphu|strong="G2949"\w* \w loh|strong="G3588"\w* \w lawng|strong="G4143"\w* \w te|strong="G1519"\w* a \w boh|strong="G1911"\w* \w dongah|strong="G5620"\w* \w lawng|strong="G4143"\w* \w dalh|strong="G2235"\w* \w buek|strong="G1072"\w*.  
