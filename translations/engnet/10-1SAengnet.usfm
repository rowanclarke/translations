\v 9 “\w But|strong="H7911"\w* \w they|strong="H3068"\w* \w forgot|strong="H7911"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w their|strong="H3068"\w* \w God|strong="H3068"\w*, \w so|strong="H3027"\w* \w he|strong="H3068"\w* gave \w them|strong="H3027"\w* \w into|strong="H3027"\w* \w the|strong="H3068"\w* \w hand|strong="H3027"\w* \w of|strong="H4428"\w* \w Sisera|strong="H5516"\w*, \w the|strong="H3068"\w* \w general|strong="H8269"\w* \w in|strong="H3068"\w* \w command|strong="H3027"\w* \w of|strong="H4428"\w* \w Hazor|strong="H2674"\w*’s \w army|strong="H6635"\w*, \w and|strong="H3068"\w* \w into|strong="H3027"\w* \w the|strong="H3068"\w* \w hand|strong="H3027"\w* \w of|strong="H4428"\w* \w the|strong="H3068"\w* \w Philistines|strong="H6430"\w* \w and|strong="H3068"\w* \w into|strong="H3027"\w* \w the|strong="H3068"\w* \w hand|strong="H3027"\w* \w of|strong="H4428"\w* \w the|strong="H3068"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* \w Moab|strong="H4124"\w*, \w and|strong="H3068"\w* \w they|strong="H3068"\w* \w fought|strong="H3898"\w* \w against|strong="H3898"\w* \w them|strong="H3027"\w*.  
\v 10  \w Then|strong="H6258"\w* \w they|strong="H3588"\w* \w cried|strong="H2199"\w* \w out|strong="H2199"\w* \w to|strong="H3068"\w* \w the|strong="H3588"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w and|strong="H3068"\w* admitted, ‘\w We|strong="H3588"\w* \w have|strong="H3068"\w* \w sinned|strong="H2398"\w*, \w for|strong="H3588"\w* \w we|strong="H3068"\w* \w have|strong="H3068"\w* \w forsaken|strong="H5800"\w* \w the|strong="H3588"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w and|strong="H3068"\w* \w have|strong="H3068"\w* \w served|strong="H5647"\w* \w the|strong="H3588"\w* \w Baals|strong="H1168"\w* \w and|strong="H3068"\w* \w the|strong="H3588"\w* images \w of|strong="H3068"\w* \w Ashtoreth|strong="H6252"\w*. \w Now|strong="H6258"\w* \w deliver|strong="H5337"\w* \w us|strong="H3588"\w* \w from|strong="H3027"\w* \w the|strong="H3588"\w* \w hand|strong="H3027"\w* \w of|strong="H3068"\w* \w our|strong="H3068"\w* \w enemies|strong="H3027"\w* \w so|strong="H6258"\w* \w that|strong="H3588"\w* \w we|strong="H3068"\w* \w may|strong="H3068"\w* \w serve|strong="H5647"\w* \w you|strong="H3588"\w*.’  
