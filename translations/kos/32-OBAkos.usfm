\id OBA  
\ide UTF8
\h OBADIAH 
\toc1 Obadiah 
\toc2 Obadiah 
\toc3 Oba 
\mt1 OBADIAH  
\is1 Tukakinyen Book Lal OBADIAH  
\ip Book fototo se inge orekla tukun kunausyukla acn Jerusalem in yac 586 B. C. Mwet Babylonia pa utyak kunausla acn we, ac mwet Edom, su nuna mwet lokoalok lun Judah in pacl loes, elos engankin musalla lun acn Judah, ac elos kasru mwet Babylonia in sruokya mwet ma kaingelik, ac wi pac eis ma wap in acn Judah. Obadiah el palye mu Edom ac fah kalyeiyuk ac kutangyukla, oapana mutunfacl saya ma lain Israel.  
\is1 Takla Lun Koanon Book Se Inge  
\io1 Kalyeiyuk Edom 1–14  
\io1 Len in nununku lun Leum 15–21  
\c 1  
\p
\v 1 Pa inge kas in palu lal Obadiah — ma \nd LEUM GOD\nd* Fulatlana El fahk ke acn Edom.\x - \xo 1:1 \xt 1–14; Isa 34:5–17; 63:1–6; Jer 49:7–22; Ezk 25:12–14; 35:1–15; Amo 1:11–12; Mal 1:2–5\x*  
\s1 \nd LEUM GOD\nd* El Fah Kalyei Acn Edom  
\q1 \nd LEUM GOD\nd* El supwala mwet roso lal nu sin mutunfacl uh  
\q2 Ac kut lohng kas lal:  
\q2 “Akola! Kut som mweun acn Edom!”   
\q1
\v 2 \nd LEUM GOD\nd* El fahk nu sin Edom,  
\q2 “Nga fah oru tuh kom in munas inmasrlon mutunfacl uh.  
\q2 Mwet nukewa ac fah kwase kom.   
\q1
\v 3 Inse fulat lom kiapwekomla.  
\q1 Siti fulat sum kalkalyak ke eot ku.  
\q2 Acn in muta lom oan yen fulat fineol uh,  
\q1 Ouinge kom nunku sum sifacna,  
\q2 ‘Su ac ku in amakinyuwi nu ten?’   
\q1
\v 4 Kom finne oakiya acn sum in oan fin acn fulat  
\q2 Oana ahng lun eagle uh,  
\q2 Ac lumweyuk mu oan inmasrlon itu uh,  
\q1 Nga ac fah amakinkomi nu ten.   
\q1
\v 5 “Pacl se mwet pisrapasr uh tuku ke fong,  
\q2 Eltal eis na ma eltal lungse mukena.  
\q1 Pacl se mwet uh kosrani grape uh,  
\q2 Elos ac filiya kutu in oanna.  
\q1 A funu mwet lokoalok lowos uh, elos ac sikikowosla nufon!   
\q1
\v 6 Kowos fwil natul Esau, ma saok lowos ayukla suwos.   
\q1
\v 7 Mwet ma asruoki nu suwos, elos kiapwekowosla,  
\q2 Elos liskowosla liki facl suwos.  
\q1 Elos misla yuruwos meet, a inge elos kutangkowosla.  
\q2 Elos su wi kowos na mongo meet, inge elos oakiya mwe kwasrip nu suwos.  
\q2 Elos aksruksruk keiwos ac fahk, ‘Pia sruk usrnguk lalos an?’   
\b  
\q1
\v 8 “Ke len se nga ac kalyei Edom,  
\q2 Nga ac kunausla mwet usrnguk lalos,  
\q2 Ac eisla lalmwetmet lalos.   
\q1
\v 9 Mwet watwen in acn Teman ac arulana tuninfongla,  
\q2 Ac mwet mweun nukewa in Edom ac fah anwukla.   
\s1 Sripen Kalyeiyuk Acn Edom  
\q1
\v 10 “Mweyen kowos onela ac pisre  
\q2 Ma lun sou lowos,\f + \fr 1:10 \fk sou lowos: \ft Mwet Israel elos fwilin tulik natul Jacob, ac mwet Edom elos fwilin tulik natul Esau, su tamulel matu lal Jacob.\f* su tulik natul Jacob,  
\q2 Kowos ac fah kunausyukla ac aklusrongtenyeyuk nwe tok.\x - \xo 1:10 \xt Jol 3:19\x*   
\q1
\v 11 Kowos tu na ngetang ke len se ma  
\q2 Mwet lokoalok uh kunausla mutunpot lalos.  
\q1 Lupan koluk lowos an oana koluk lun mwetsac  
\q2 Su usla mwe kasrup in acn Jerusalem  
\q2 Ac kitalik inmasrlolos.   
\q1
\v 12 Tiana wo ke kowos tuh pwarkin  
\q2 Ongoiya ma sikyak nu sin mwet Judah wiowos.  
\q1 Tiana wo ke kowos tuh engan  
\q2 Ke len in musalla lalos.  
\q1 Tia pac wo ke kowos tuh isrunulos  
\q2 Ke elos muta in keok.   
\q1
\v 13 Tiana wo ke kowos tuh utyak nu in siti lun mwet luk  
\q2 In pwarkin keok lalos,  
\q2 Ac in eisla mwe kasrup lalos  
\q2 Ke len in ongoiya lalos.   
\q1
\v 14 Tiana wo ke kowos tuh ke inkanek sengelik  
\q2 In sruokolos su srike in kaing.  
\q1 Tiana wo ke kowos tuh eisalosyang nu inpoun mwet lokoalok lalos  
\q2 Ke len in ongoiya lalos.   
\s1 God El Fah Nununku Mutunfacl Nukewa  
\q1
\v 15 “Len se apkuranme ke nga, \nd LEUM GOD\nd*,  
\q2 Fah nununku mutunfacl nukewa.  
\q1 Edom, ma kom orala tari  
\q2 Ac fah orek nu sum.  
\q2 Orekma sufal lom nukewa ac fah folokot pacna nu sum.   
\q1
\v 16 Mwet luk elos numla sie cup in kalya arulana mwen  
\q2 Fineol mutal\f + \fr 1:16 \fk Fineol mutal: \ft pa Fineol Zion.\f* sik,  
\q1 Tusruktu, mutunfacl nukewa raunela ac fah nim pac  
\q2 Sie cup in kalya su mwen liki na.  
\q2 Elos fah numla nufon, na elos wanginla.   
\s1 Israel Kutangla  
\q1
\v 17 “Tusruktu kutu ac fah tia sruh\f + \fr 1:17 \fk kutu ac fah tia sruh: \ft Liye verse 14.\f* Fineol Zion,  
\q2 Na acn we ac fah sie acn mutal.  
\q1 Ac fah ma lun mwet lal Jacob  
\q2 Acn se su nuna ma lalos meet.   
\q1
\v 18 Mwet lal Jacob ac mwet lal Joseph ac fah oana firir in e;  
\q2 Elos ac fah sukela mwet lal Esau  
\q2 Oana e uh esukla sroan mah.  
\q2 Wangin mwet in fwil natul Esau fah moul.  
\q1 Nga, \nd LEUM GOD\nd*, pa fahk.   
\b  
\q1
\v 19 “Mwet in acn eir in Judah fah muta fin acn Edom.  
\q2 Elos su muta ke eol srisrik layen nu roto, fah sruokya acn Philistia.  
\q1 Mwet Israel fah eis acn lun Ephraim ac Samaria.  
\q2 Mwet Benjamin fah eis acn Gilead.   
\q1
\v 20 Mwet epang in Israel su muta in sruoh elos fah orala sie un mwet mweun  
\q2 Su fah foloko ac sruokya acn Phoenicia, fahla nwe Zarephath su oan epang.  
\q1 Mwet sruoh lun Jerusalem su muta Sardis\f + \fr 1:20 \fk Sardis: \ft Siti se inge pangpang pac Sepharad.\f*  
\q2 Fah sruokya siti srisrik layen eir in Judah.   
\q1
\v 21 Tukun mwet Jerusalem elos kutangla acn inge nukewa  
\q2 Elos fah utyak mweuni acn Edom ac leumi acn we.  
\q1 Ac \nd LEUM GOD\nd* El fah leum fin tokosrai sac nufon.”   