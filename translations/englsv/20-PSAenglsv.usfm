\v 5 \w There|strong="H3045"\w* \w they|strong="H3808"\w* feared \w a|strong="H3068"\w* fear—\w there|strong="H3045"\w* \w was|strong="H3808"\w* \w no|strong="H3808"\w* fear, || \w For|strong="H7121"\w* \w God|strong="H3808"\w* \w has|strong="H3045"\w* \w scattered|strong="H5971"\w* \w the|strong="H3045"\w* bones \w of|strong="H5971"\w* \w him|strong="H7121"\w* || \w Who|strong="H5971"\w* \w is|strong="H3899"\w* encamping against \w you|strong="H3045"\w*, || \w You|strong="H3045"\w* \w have|strong="H5971"\w* put \w to|strong="H7121"\w* shame, || \w For|strong="H7121"\w* \w God|strong="H3808"\w* \w has|strong="H3045"\w* despised \w them|strong="H7121"\w*.
