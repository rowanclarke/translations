\id 2TI Ika New Testament 2009 
\h 2 Timoti 
\toc1 Ẹkụkwọ-Ozi Nke Ẹbụọ Pọlụ Dejẹnni Timoti Timoti, Nke Ẹbụọ 
\toc2 Timoti, Nke Ẹbụọ 
\toc3 2Tim 
\mt2 Ẹkụkwọ-Ozi Nke Ẹbụọ Pọlụ Dejẹnni 
\mt2 Timoti 
\mt1 Timoti, Nke Ẹbụọ 
\c 1  
\cl Isi Nke Ohu 
\p  
\v 1 Mmẹ wụ Pọlụ de ẹkụkwọ-ozini. M wụ onyẹ-ozi pụ-ichẹn Kraịstị wụ Jizọsị makẹni uche Osolobuẹ rọ. Wẹ tumẹ m onyẹ-ozi pụ-ichẹn d'a rụn ọrụn w'e gi mẹ nkwa Osolobuẹ gha—nkwa ahụn o kwe n'o k'e ye ndụn imẹ Kraịstị wụ Jizọsị.  
\v 2 M rị e dejẹnni ezi nwa m wụ Timoti: ẹfọma, omikẹn lẹ udọn, hụn gha ẹka Chuku Nẹdi lẹ Kraịstị wụ Jizọsị Di-nwọnni-ẹnyi bịa ya rịnị ị. 
\s1 Pọlụ E Kele Osolobuẹ, Ọ Gba Timoti Umẹ 
\p  
\v 3 M rị a kpanmịn Osolobuẹ, hụn m gi obi rị ọchan e fe nọkẹ kẹ ndị nẹdi m kanị dọn gi obi rị ụchan fe ẹ. M'a kpanmịn a m gha a nyanhan ị ogẹn ile imẹ ekpere m—kẹ uhinhin kẹ efinnaị. 
\p  
\v 4 M gha a nyanhan ẹnya-mirin i, ọ hụ a rị m nị m hụn ị, kẹni ịghọghọ jun m obi.  
\v 5 M rị a nyanhan okukwe i hụn gha akpakalị obi i pụha; okukwe ohu hụ hụn bu ụzọ rị imẹ nnẹ-i-kanị wụ Lọịsị lẹ nnẹ i wụ Yunisi, hụn m marịn n'ọ rịzịkwọ nwan imẹ i.  
\v 6 Ufiri ẹ, m rị a nyanhan n'ị n'ị fụnwun oyiye Osolobuẹ hụn rị imẹ i, hụn Osolobuẹ ye i ogẹn m gi bu ẹka kwasị ị.  
\v 7 Makẹni, Osolobuẹ eyeni ẹnyi mmọn egun, kama, mmọn ikẹn lẹ ihiẹn-ọsụsụọ lẹ ikwọndọn-enwẹn-ịhịan k'o ye ẹnyi.  
\v 8 Ya wụ, emẹkwọlẹ nwan ifẹnrẹn iku oku Onyẹ-nwọnni-ẹnyi, emẹzịkwọlẹ ifẹnrẹn mmẹ nwẹn hụn gi ifiri ẹ rị imẹ ngan. Kama, gi ikẹn Osolobuẹ ye i tarị afụnfụn nke i hụn oziọma e gi gha ihun. 
\p  
\v 9 Osolobuẹ wụ onyẹ zụọpụha nị ẹnyi, kpọ ẹnyi oku rị nsọ. Ẹlẹ ọrụn-ọma ẹnyi rụn haịn o gi kpọ ẹnyi, kanị makẹni ẹrịra k'ọ chọ n'o mẹ ẹ lẹzi makẹ ifiri ẹfọma a hụn o mẹ ni ẹnyi imẹ Kraịstị wụ Jizọs' nị ụwa d'e bidọn—  
\v 10 ọ nọ nwan mẹ ẹ n'ọ pụha ifọn ogẹnni ghahanị ọbịbịa Onyẹ-nzụọfụha ẹnyi wụ Kraịst' Jizọsị bịa imẹ ụwa. Kraịstị wụ Jizọsị e mẹrigụọ ọnwụn, napụ a ikẹn. O gigụọ Oziọma wepụha ndụn lẹ ibi-jẹnrin-ejẹn ifọn. 
\p  
\v 11 Ufiri oziọmanị k'o gi tumẹ m onyẹ e zisọnmẹ ozi, onyẹ-ozi pụ-ichẹn lẹ onyẹ-nkuzi, kẹni m d'e zisọnmẹ ẹ, a rụn ọrụn rịn'a;  
\v 12 ifiri ẹ kẹ m gizikwọ rị a ta afụnfụn ẹnịna. Kanị ifẹnrẹn arị e mẹ m, makẹni a marịnghọ m onyẹ m gi dọn ẹnya; a maringhọzị m n'o k'a saẹka chedọn ihiẹn hụn m buche ẹ ẹka, d'e ru Ụhụọhịn hụ. 
\p  
\v 13 Sọnmẹ ụdị nkuzi ahụn zu oke ị nụ ọnụ m; e gi okukwe lẹ ihiẹn-ọsụsụọ hụn rị imẹ Jesu Kristi e sọn ẹ.  
\v 14 Chedọn ihiẹn-ọma ahụn wẹ buche i ẹka; mẹ ẹ ghahanị eyemẹka Mmọn-nsọ hụn bi imẹ ẹnyi. 
\p  
\v 15 Y'a marịnghọ nị ndị ile rị Azụụn Eshịa a gbakịtọgụọ m azụụn; Figelọsị lẹ Homojinisi a gbagụọzịdẹ m tọ. 
\p  
\v 16 Osolobuẹ ya mẹ ni ezi-lẹ-ụlọ Ọnẹsifọrọs' omikẹn, makẹni Ọnẹsifọrọs' a gbaka m umẹ! Ifẹnrẹn ẹgan m e mẹdẹn'ẹ.  
\v 17 Kama, o ruhụ Rom, ọ nọ chọsọnmẹdẹ m d'e ru n'ọ hụn m.  
\v 18 Di-nwọnni-ẹnyi ya mẹ ni Ọnẹsifọrọsị nwẹhẹn omikẹn ẹka a Ụhụọhịn hụ! Ịyụ lẹ enwẹn i a marịnghọ ẹka ile o yeni m imẹ Ẹfẹsọsị. 
\c 2  
\cl Isi Nke Ẹbụọ 
\s1 Onyẹ-agha Kraịstị Furuni 
\p  
\v 1 O mẹ nke i nwa m, gi ẹfọma hụ Osolobuẹ mẹni ẹnyi imẹ Kraịstị wụ Jizọsị e zekẹnmẹ.  
\v 2 Weri ihiẹn ndị hụ ị nụ ọnụ m id'ẹnya ndị bu ọda kuzi ndị furu wẹ gi e dọn ẹnya, hụn jẹnkọ d'a saẹka kuzizi ndị ọzọ ya. 
\p  
\v 3 Tarị afụnfụn nọkẹ ezigbo onyẹ-agha Jesu Kristi.  
\v 4 O nwọnni onyẹ-agha hụn e kọn ẹka e ye oku-elu; makẹni onyẹ-agha k'e mẹrịrị ihiẹn a sụọ onyẹ-isi agha ọ rị okpuru ẹ ụsụọ ẹfọ.  
\v 5 O nwọnni onyẹ a dọ-ọnụ egumegu e mẹrini mmanị o sọnghọ iwu rịn'a.  
\v 6 Onyẹ-ugbo hụn a rụnshi ọrụn ikẹn ịya e bu'zọ e ri erere ihiẹn ọ rụnpụha.  
\v 7 Romi ihiẹn m rị e ku; Di-nwọnni-ẹnyi k'e mẹ i ghọta ihiẹn ile. 
\p  
\v 8 Nyanhan Jizọsị wụ Kraịstị hụn Osolobuẹ gha imẹ ọnwụn weli, hụn wẹ mụye ikpun-ụlọ Defidi—ọhụn wụ oziọma m rị e zi.  
\v 9 Ufiri ẹ kẹ m gi a ta afụnfụn d'e ru nwan ebe wẹ nọ kpọma m ẹgan nọkẹ onyẹ-ohin—kanị oku Osolobuẹ arị ẹgan. 
\p  
\v 10 Ya wụ, m'e gi ufiri ndị Osolobuẹ họrị e dingbuchanrịn ihiẹn ile, kẹni wẹ sazịkwọ ẹka nwọnhẹn nzụọpụha hụn rị imẹ Kraịstị wụ Jizọsị lẹ ọghọ itẹbitẹ rịn'a.  
\v 11 Ihiẹnni w'e ku wụ ezioku: 
\q1 “Omẹni ẹnyi e sọngụọ a nwụnhụn, 
\q2 ẹnyi k'e sọnzikwọ a rị ndụn; 
\q1  
\v 12 omẹni ẹnyi e din ndidi, 
\q2 ẹnyi k'e sọnzikwọ a kị; 
\q1 omẹni ẹnyi a jụ a, 
\q2 ọ k'a jụzịkwọ ẹnyi; 
\q1  
\v 13 ẹnyi wụbehi ndị wẹ gi e dọn-ẹnya, 
\q2 ya lẹ enwẹn ẹ k'a wụsọnmẹ onyẹ wẹ gi e dọn-ẹnya, 
\q2 makẹni ọ sakọ ẹka jụ enwẹn ẹ.” 
\p  
\v 14 Nyanhan nị wẹ ihiẹnni; gi ẹfan Osolobuẹ gbakẹnmẹ wẹ mkpịnsịn-ẹka. Sị wẹ adọzịlẹ akpụrụ-oku, nị ara ye ẹka, kama, o wiwihụ ndị a nụn'a. 
\s1 Onyẹ-ọrụn Hụn A Sụọ Osolobuẹ 
\p  
\v 15 A lịlịma n'ị y'a ghọsị n'ị wụ onyẹ Osolobuẹ kwadọn; onyẹ-ọrụn nwẹlẹni ihiẹn ọwụlẹ ifẹnrẹn e gi mẹ ẹ, hụn marịn ẹnya oku-Osolobuẹ, oku ahụn hụn wụ ezioku, a kuzi ẹ ọhụnma.  
\v 16 Latọ oku nwọnlẹni-isi hụn ghalẹni e yeni ịhịan ẹka fe Osolobuẹ, makẹni o mẹ ịhịan a latọkẹnmẹ ihiẹn Osolobuẹ.  
\v 17 Ihiẹn ndị rị imẹ ẹ rị a kuzi a bagbama nọkẹ ẹtẹ rị a banị. Himẹnọsị lẹ Filetọsị rị imẹ ndị nọ ẹrịra.  
\v 18 Madụ ẹbụọnị a ghagụọ imẹ ezioku pụ, makẹni wẹ rị e ku nị Osolobuẹ e weligụọlẹ ndị nwụnnị. O nwẹ ndị wẹ gi ihiẹnni e wiwi okukwe wẹ.  
\v 19 Kanị iyetọ Osolobuẹ tụrụkwọ ebe ọ rị; ihiẹn wẹ deye ẹ wụ: “Di-nwọnni-ẹnyi a marịngụọ ndị wụ nke ẹ” lẹ “Onyẹ ọwụlẹ hụn a kpọku ẹfan Di-nwọnni-ẹnyi ya la njọ tọ.” 
\p  
\v 20 Imẹ ụlọ hi-ogbe, w'a hụn ụdị arịa ichẹn-ichẹn—ẹlẹ arịa wẹ gi goru lẹ hụn wẹ gi ọla kpụ sụọ, kanị kẹ hụn wẹ gi osisi tụ lẹ hụn wẹ gi ụrụa kpụ rịzịkwọ arị. O nwẹ arịa wẹ gi e mẹ ihiẹn ọghọ, nwẹzikwọ ndị wẹ gi e mẹ ihiẹn-mmaka.  
\v 21 Ẹrịrazịkwọ, kẹ wẹ hanlẹ chanchanpụ eje-ihiẹn ndịnị m rụtụ ẹka imẹ obibi wẹ k'a wụrụ arịa nwẹ ọghọ; wụrụ arịa wẹ dọnmẹ ichẹn, hụn onyẹ nwẹ ụnọ gi e mẹ ihiẹn, arịa w'e gi mẹ ihiẹn ile rị mma. 
\p  
\v 22 La ihiẹn ndị ahụn a nasọnmẹ ikorọbịa ẹnya tọ; y'a chụsọnmẹ ezi-omumẹ, okukwe, ihiẹn-ọsụsụọ lẹ udọn, yụ lẹ ndị hụn gi obi rị-ọchan a kpọku Di-nwọnni-ẹnyi.  
\v 23 Adọlẹ ndọndọ nwọnlẹni isi hụn ndị marịnlẹni ihiẹn wẹ rị e ku a dọ—y'a marịnghọ ni ikpe k'o buhẹ—  
\v 24 bụ odibo Di-nwọnni-ẹnyi awụkọ onyẹ-ikpe; kama, ọ sikọ d'e girịrị ẹfọma e sọn onyẹ ọwụlẹ, wụrụ onyẹ a saẹka a kuzi, e nwọn ndidi,  
\v 25 e gi nwayọ a kọwa nị ndị ghalẹni e kweye n'ẹ ebe wẹ nọ ghọtafie. Osolobuẹ nwọn ikẹn mẹ wẹ gbehutọ, bịa d'a marịn ezioku,  
\v 26 [mẹmẹ uche Osolobuẹ;] wanahịn ọnya Ekwensụ te gi kwọndọn wẹ, hụn wẹ gi e mẹ uche Ekwensụ. 
\c 3  
\cl Isi Nke Ẹtọ 
\s1 Ogẹn Ịkpazụụn, Ọ K'a Fụ Ọrụn Ife Osolobuẹ 
\p  
\v 1 Kanị, ghọta ọnwan ọhụnma-ọhụnma, nị ogẹn ịkpazụụn, ogẹn ihiẹn gi e zekẹnmẹ k'a bịa.  
\v 2 Makẹni ịhịan k'a wụ ndị enwẹn wẹ ka wẹ a sụọ, ndị egho a sụọ, ndị a nyan isi, ndị mpache, ndị-mkpari, ndị e nufụ isi okpuru ndị mụ nị wẹ, ndị ọhụnma-ogodan, ndị e mẹ ihiẹn rụnị.  
\v 3 Wẹ k'a wụ ndị ẹfọ-njọ, ndị oku ghalẹni a gụụ ẹfọ, ndị-nkutọ, ndị ghalẹni e kwọndọn enwẹn wẹ, ndị obi wẹ rị azụụn, ndị ihiẹn rị mma ghalẹni a sụọ;  
\v 4 Wẹ k'a wụ ndị hụn e bu ịhịan mbu-azụụn, ndị a sị “ihiẹn chọ n'o mẹ ya mẹ”, ndị e ro enwẹn wẹ karị ihiẹn wẹ wụ, ndị ihiẹn a sụọ ụsụọ ka mkpa karị Osolobuẹ.  
\v 5 Wẹ k'a wụ ndị e mẹzuchanrịn omẹnalị rị imẹ ofufe Osolobuẹ, kanị ikẹn w'e gi bi obibi rịn'a a rị imẹ ndụn wẹ. La ndị nọ ẹrịra tọ.  
\v 6 Ndị hụ imẹ wẹ wụ ndị e gi ẹro a rụbansọnmẹ ikpun-ụlọ d'e dufie ikpoho obi wẹ zelẹni, ikpoho obi rị e gbu mgbu makẹ njọ ndị wẹ mẹ, ikpoho ẹgụn ihiẹn rị ichẹn-ichẹn rị e buhunmẹ,  
\v 7 Ikpoho w'a tọ a kuzi, kanị w'a ra saẹka mụnrụn ezioku.  
\v 8 Kẹ Janesi lẹ Jambresi dọn papụ oku Mozizi, ẹrịra kẹ ndịnị uche wẹ rilẹni mma, danpụgụụ imẹ okukwe-Kraịstị, dọn a papụ ezioku.  
\v 9 Kanị, o biekọ a kụsị wẹ wẹ, makẹni nzuzu wẹ k'a pụha ihun ịhịan ile nọkẹ nke madụ ẹbụọ hụ wụ Janesi lẹ Jambresi. 
\s1 Ndụnmọdụn Ịkpazụụn 
\p  
\v 10 Nke i, ya hụngụọ nwan nkuzi m, obibi m, ihiẹn m rị a chụ, okukwe m, ndidi m, ihiẹn-ọsụsụọ m, kẹ m dọn wuzo,  
\v 11 ukpokpo ile wẹ gi ifiri okukwe m kpokpo m lẹ afụnfụn ile m rị a ta. Ya marịnghọ ihiẹn ile m hụn imẹ Antịọkụ, imẹ Ikoniọm lẹ imẹ alị Listra. Y'a marịnghọ okẹn ukpokpo hụn m din; kanị Di-nwọnni-ẹnyi nọ gbapụhachanrịn m imẹ wẹ ile.  
\v 12 Eziẹ, wẹ k'e kpokporịrị kẹ wẹ han chọ nị wẹ bi obibi ndị e fe Osolobuẹ imẹ Kraịstị wụ Jizọsị.  
\v 13 Kanị ndị eje-ịhịan lẹ ndị ndufie jẹnkọ d'a gha a jọwaye njọ; wẹ k'a gha e dufie ndị ọzọ, ndị ọzọ hụ e dufie wẹ. 
\p  
\v 14 Kanị ịyụ nwẹn, mẹsọnmẹ ihiẹn hụn ị mụ, hụn i kwerikẹnmẹ, makẹni y'a marịnghọ onyẹ ị mụnarịn a;  
\v 15 y'a marịngụọzị Ẹkụkwọ-nsọ—gha ẹhụ nwa-ndu i lala, Ẹkụkwọ-nsọ hụn k'a saẹka kuzi i ihiẹn y'e gi nwọn nzụọpụha ghahanị ikwerini Kraịstị wụ Jizọsị.  
\v 16 Ihiẹn ile rị imẹ Ẹkụkwọ-nsọ gha ọnụ Osolobuẹ pụha; wẹ e gi ẹ a kuzi, a jụgbọ, e wekinhẹn ịhịan ebe ọ nọ fie ụzọ, a zụn ịhịan ọzụnzụn wẹ gi e mẹ ihiẹn Osolobuẹ chọ,  
\v 17 kẹni onyẹ nke Osolobuẹ wụrụ onyẹ wẹ zụn ọhụnma, hụn wẹ kwademẹ tọ nị ọrụn-ọma ile. 
\c 4  
\cl Isi Nke Ẹnọ 
\p  
\v 1 M rị a gbakẹnmẹ i mkpịnsịn-ẹka idẹnya Osolobuẹ lẹ Kraịstị wụ Jizọsị hụn jẹnkọ d'e kin ndị rị ndụn lẹ ndị nwụnnị ikpe; m rịzị a gba ị ya makẹ ifiri ọbịbịa Kraịstị lẹ Alị-eze ẹ, a sị ị,  
\v 2 e ku oku-Chuku; e kusọnmẹ ẹ ogẹn ile—kẹ ọnọdị rị mma kẹ ọnọdị jọ-njọ; a gwapụ ịhịan eje-ihiẹn wẹ mẹ, a jụgbọ, a kasị obi, e gichanrịn ndidi lẹ nkuzi e mẹ ẹ.  
\v 3 Makẹni ogẹn lala hụn ịhịan jẹnkọzilẹni d'e gi kweri din ndidi nụsọnmẹ ezigbo nkuzi. Ebe ntịn wẹ n'a chọsọnmẹ n'ọ nụ ihiẹn a sụọnị wẹ, wẹ k'a chọrịsọnmẹ ndị nkuzi k'a kuzi wẹ ihiẹn wẹ chọ nị wẹ nụ.  
\v 4 Wẹ k'a gbakịtọ ezioku azụụn, sọnmẹ ilu.  
\v 5 Kanị, ịyụ nwẹn, dọnrin ẹnya e leban ihiẹn ile ẹnya; e dingbu afụnfụn; a rụn ọrụn onyẹ e zisọnmẹ oziọma. Mẹchanrịn ihiẹn ile ọrụn ị chọ. 
\p  
\v 6 O mẹ nke m, wẹ rị nwan e hupụ m nọkẹ manya wẹ gi a chụ ẹjan; ogẹn m'e gi lama e rugụọ.  
\v 7 A lụgụọ m ezigbo ọgụn hụ! A gbagụọ m ọsọ hụ! E sọngụọ m ụzọ okukwe hụ!  
\v 8 Gha kikẹnni jẹnmẹ, ihiẹn họdụnị nwan wụ okpu onyẹ mẹ ihiẹn Chuku chọ hụn rị e che ni m, hụn Onyẹ-nwọnni-ẹnyi, Ọka-Ikpe ahụn ghalẹni a tụ ntụ, jẹnkọ d'e ye m Ụhụọhịn hụ, gi tu m ugọn. Ẹlẹ mmẹ sụọ k'o k'e ye ẹ, kanị ndị ile buchanrịn obi wẹ che ọbịbịa a. 
\s1 Pọlụ E Ku Oku Enwẹn Ẹ 
\p  
\v 9 Nwankẹnmẹ n'ị bịa d'e kunrun m ẹgwa,  
\v 10 nị Dẹmas' a lagụọ m tọ shi Tẹsalonika—makẹni ihiẹn ụwanị rị a sụọ a; Krẹsẹns' e shigụọ Galeshịa; Taịtọs' e jẹnmẹgụọ Damashịa.  
\v 11 Luku sụọ sọn m nọdị. Chọ Makị n'i wẹhẹ ẹ ị lalanị, makẹni ọ wụ onyẹ e yekẹnmẹ ni m ẹka ọda. 
\p  
\v 12 E zigụọ m Taịkikọs' shi Ẹfẹsọsị.  
\v 13 Ị lalanị, wẹhẹ ẹwuru hụ w'e yiye elu ẹ hụn m latọ ẹka Kapọsị imẹ Trasị; wẹhẹzi ẹkụkwọ ndị hụ, tụmadụ ndị hụn wẹ gi akpụkpọ-anụ mẹmẹ. 
\p  
\v 14 Alẹzanda hụn a kpụ ụzụn kọpa mẹkẹnmẹ m eje-ihiẹn. Nna ẹnyi jẹnkọ d'a kụ a ụgwọ ihiẹn o mẹ.  
\v 15 Ịyụ lẹ enwẹn i k'a kpachanpụkwọ n'a ẹnya makẹ ọgụn ile hụn ọ lụsọn ozi ẹnyi. 
\p  
\v 16 Ogẹn wẹ gi kpọ m ikpe ibuzọ, o nwọnni onyẹ pụha d'e kuye ni m, ịhịan ile la m tọ. W'e gilẹ ẹ ma wẹ ikpe!  
\v 17 Kanị Di-nwọnni-ẹnyi nọyeni m anọyeni; ọ nọ ye m ikẹn, kẹni m hụn ụzọ ziru oziọma alị, zi ẹ n'o ruchanrịn ndị anị ndị ọzọ ile wụlẹni ndị Ju ntịn; m nọ hụn isi wanahịn ọnụ ẹwọrọ.  
\v 18 Di-nwọnni-ẹnyi jẹnkọ d'a gbafụha m makẹ eje-ihiẹn ọwụlẹ gha a rụ m ẹhụ, ọ zụọ m, kẹni m hụn ụzọ banye Alị-eze ẹ hụn rị elu-igwee. Ọghọ ya rịn'a jẹnrin ejẹn! Isẹẹ. 
\s1 Ekele Ịkpazụụn 
\p  
\v 19 Kele Priska lẹ Akwila lẹ ikpun-ụlọ Onẹsifọrọsị.  
\v 20 Ẹrastọsị esọnni ndị ọzọ, ọ nọdị Kọrẹntị; m la Trofimọsị tọ imẹ Miletusu makẹni emu rị a kụ a.  
\v 21 Nwankẹnmẹ n'ị bịa ogẹn oyi gini d'e ru. Yubulọsị lẹ Pudẹnsi lẹ Laịnọsị lẹ Klọdiọsị lẹ umunẹ ẹnyi ile e zighọ ekele. 
\p  
\v 22 Di-nwọnni-ẹnyi ya nọyeni mmọn ị. Ẹfọma Osolobuẹ ya nọyeni ọnụ.