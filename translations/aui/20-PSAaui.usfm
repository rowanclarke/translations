\id PSA - Anuki 
\h Psam 
\toc1 Psam 
\toc2 Psam 
\mt1 Psam  
\is1 Wonawiiakowa  
\ip Raghani iguri kamone, wawaya bogaebogae korotodi ayi da pari mmko bukana kamone sigiruma. Isrel damdi sivituwiitaghoma da toudima sikabepepa. Mma na ayi da pari bogaebogae: mududi na God kabikuwayenina da kabepepina kiiravine bi wiikiikiivenina da wiimiiseyana kiiravine. Mududi na wiiwiita da wiitarababarana kiiravidiye sibaba, bo noghotataveyana kiiravine. Ayi mududi kamodiye na wawaya yadi kiiwawo kiiravidiye sarupari, bi God sibabiini da kadi aviya aro inaveredi. Bi mududi kamodiye na giruma wawayina yana piropiro da nuwapoya kiiravidiye yagwinigwini God biidi.  
\ip Yesu touna wosina raghani viya na sisiya mmkodi paridima ivisisiya, bi keresiyana dagudagunama, na God yana wawaya mmkodi ayi da parima siyakabekabepepa.  
\iot Psam Vinevineyidi  
\io1 Psam: \ior 1, 23, 27, 34, 51, 67, 90, 95:1-11, 100, 103, 110, 119:9-16, 139\ior*  
\c 1  
\s1 Nuwamiise wiisuwonina  
\q1
\v 1 Wawaya iiyawogha berabero wawayidi geyawata siyapeepewa  
\q2 bi yadi sisiya gesiyakivikivina,  
\q2 da bada gewiigeruwana damdi yadi sisiya siyawaiwaiyana raghanina God sinamayenina,  
\q3 toudi nuwamiise wawayidi.   
\q1
\v 2 Bi gegha da Yawe God yana wiiyeveveyana sivinuwayuyuneni,  
\q2 na raghani nonowa gabudara da nubabasu na yana gwara sinuwanoghonoghoteni.   
\q1
\v 3  \x - \xo 1:3 \xt Jer 17:8\x*Toudi ware kii rarima kawabarane siwawa na naboni,  
\q2 kadi iri vinevineyina nunune suwagha  
\q2 bi rugurugudi gesiyaraborabobo da siyariirighana.  
\q1 Wawaya nokodi naboni, na awaki sabera na berana kamna yatubugha.   
\q1
\v 4 Bi berabero wawayidi na genaboni.  
\q2 Toudi na ware rugurugu pokina naboni,  
\q2 yanunu yatapitaveni.   
\q1
\v 5 Na God matane na toudi gewasina  
\q2 raghanina wawaya initupawamiwamiredina gabudarine,  
\q2 toudi kate gegha God yana wawaya yawata sinikapudina.   
\b  
\q1
\v 6 Yawe God kana kivikivina yinaghovedi bi yakoyayidi,  
\q2 bi berabero wawayidi na rabobo kedane sapeepewa.   
\c 23  
\s1 Bada na kada Bodaboda  
\d Ayina Deivid igirumi  
\b  
\q1
\v 1 Yawe God yakoyakoyayigu  
\q2 ware sip bodaboda yana sip yakoyakoyayidina naboni  
\q3 na getana awaki ayadadina. \fig |alt="1/2 page" src="bk00004c.tif" size="span" ref="23:1" \fig*   
\q1
\v 2 Bi yaberagu da idu miisediye akenayowogha,  
\q2 bi rarima nighorovidi riridiye yinaghovegu.   
\q1
\v 3 Touna yawa wouna yavereveregu,  
\q2 bi keda rotomanidiye yinaghovegu  
\q2 basuna yana keda waghata na nonowa rotomanidi.   
\q1
\v 4 Raghani viya na anagha wiididibaridiye apeepewa,  
\q2 bi gegha ayanaghanagharana,  
\q1 basuna tam kwabaabaregu da kwiiwiitegu,  
\q2 ware sip bodaboda yana kiima  
\q1 sip yitarababaranedi bi yakoyakoyayidina naboni.   
\b  
\q1
\v 5 Kagu aviya matadiye bi  
\q2 tam kepo kiiraviguve kwakabunayi.  
\q1 Tam oil gayamiguve kwiiwayi  
\q2 da wiiyeveveyana tam kwakabikabi karawayegu.  
\q1 Yagu niniuna reduna kwiibonuvi yakamiviwayi   
\q1
\v 6 Akovi da tam kuninuwayuyunegu  
\q2 bi miisena kunabera tagu biidi  
\q1 patana da anarabobo  
\q2 da Yawe God yana bareye anamake waghata.   
\c 27  
\s1 Kabepepa Parina  
\d Ayina Deivid igirumi  
\b  
\q1
\v 1 Yagu yeghana na Yawe God gwabinama yapiipiika,  
\q2 bi yiyawiigu na geananagharana.  
\q1 Touna piropiro gwabidima yamiiri babaregu  
\q2 na kate geiiyabo ananagharenina.   
\q1
\v 2 Raghanina kagu aviya, iiyawogha na wawaya beroberodi  
\q2 sinagogona tagu biidi bi sinimatipo da kasunuyigu,  
\q2 na toudi wosina sinataguredi da sinabeku.   
\q1
\v 3 Meboda aviya peyaridi sinapiika sinituwiikapudi da sinagogona tagu biidi,  
\q2 bi gegha da geananagharedina.  
\q1 Raghanina sinagogona tagu biidi,  
\q2 na tagu Yawe God kawagha anitumaghaneni.   
\b  
\q1
\v 4 Tagu sawara tanagha kiiravine Yawe God avibabiini,  
\q2 sawara tanagha kawagha akayoveni:  
\q2 Yagu wiina kirakii da yagu yawa tupana kamone na yana bare kamone anamakae,  
\q2 bi anakita da touna imiise da awaki patana  
\q2 bi yana Bare Kabikabikuwayine anarupari touna biidi.   
\q1
\v 5 Raghanina piropiro anabanani na yana gawara nighorovine inikowoyigu,  
\q2 bi yana bare kamone inababaregu,  
\q2 touna akima kiidamo kirakiine inatoregeeyegu  
\q2 meme kagu aviya gerubana sinakabiguna.   
\q1
\v 6 Kagu aviya sinagwagwara wiikenaviviregu,  
\q2 bi gegha da animaragata kirakii da anageiwayidi.  
\q1 Yawe God yana bare kabikabikuwayina kamone tagu suwara anagibu,  
\q2 bi nuwamiiseye anarukwatu da anatawora  
\q2 bi inawa anarouwa da ayima anakabepepi.   
\b  
\q1
\v 7 Yawe God, raghanina arupari tam biidi na kwawaiyanegu,  
\q2 kinuwanuwaghanegu bi yagu sisiya kuwonabodegu!   
\q1
\v 8 Tam kuwonegu bo, Piika kunisisiya tagu biidi,  
\q2 na kata apiipiika tam biidi.   
\q1
\v 9 Tagu yam wiitamariyana,  
\q2 genuwanuwam inapughu da kunamiiri kubuteguna,  
\q2 gegwabiguma kunakowoghana!  
\q1 Tam kuviyawiigu bi nonowa kwiiwiitegu,  
\q2 na kata gekunakuyoveguna!   
\q1
\v 10 Meboda tamagunaki da sinagunaki sinamiiri kubutegu,  
\q2 bi gegha, Yawe God na nonowa inakoyakoyayigu.   
\q1
\v 11 Yawe God, kagu aviya sikoyakoyagha da sinaburavigu,  
\q2 na kiyevevegu da anakivinim,  
\q2 bi keda rotomanidiye kinaghovegu.   
\q1
\v 12 Nokodi aviyidi kiiraviguve sisiya wiiyaba saberabera,  
\q2 yadi wiina da siniberogu,  
\q2 na gekuniwaghasinedi da sinaburaviguna!   
\b  
\q1
\v 13 Bi gegha da iitumaghana da Yawe God miisena inabera tagu biidi,  
\q2 raghanina mmko kuburina debane patana yawayawiiguve amakamakena  
\q2 bi anakitani da noko inabera.   
\q1
\v 14 Na tam Yawe God kitumaghaneni,  
\q2 kimaragata bi nuwanuwam inatora,  
\q2 na Yawe God kitumaghaneni.   
\c 34  
\s1 God yana Miisena kiiravine Kabepepina  
\d Raghani tana Abimelek naghone bi Deivid ibera da ware iyaneghanegha na iviporataveni inagho. Muriye na God metagha Deivid iviwiiteni na kiiravine noko raghanine mmko ayina igirumi.  
\b  
\q1
\v 1 Tagu raghani nonowa Yawe God anakabepepi  
\q2 bi yana miisena kiiravine anisisiya.   
\q1
\v 2 Tagu kana waghawagha iragata kirakii na anakabepepi,  
\q2 tami moyamoyakimi yagu sisiya koyawaiyana bi koyinuwamiise.   
\q1
\v 3 Kobera da tupada Yawe God tana kabepepi,  
\q2 kobera da tupada kana waghawagha tana kabikarawayeni!   
\b  
\q1
\v 4 Tagu arupari Yawe God biidi na iwonabodegu,  
\q2 nokodi wawaya ayanaghanagharedi, na gwabidima iviyawiigu.   
\q1
\v 5 Wawaya iiyawogha wiiwiita kiiravine samiiri wamira Yawe God biidi,  
\q2 na toudi parapa sinuwamiise,  
\q2 bi nonowa iniwiitedi.   
\q1
\v 6 Tagu piropiro kamone bi arupari na Yawe God iwaiyanegu,  
\q2 touna yagu nuwapoya tupadi kamodima iviyawiigu.   
\q1
\v 7 Bi wawaya iiyawogha Yawe God sakabi karawayeni,  
\q2 na yana aneya inakoyayidi,  
\q2 bi riiridiye yamake da yitarababaranedi.   
\b  
\q1
\v 8 Na Yawe God biidi komiiriwamira  
\q2 bi tami bada konakabibanani da yana miisena metagha.  
\q1 Memeda wiiwiita kiiravine konanagho touna biidi,  
\q2 na tami parapa koninuwamiise.   
\q1
\v 9 Tami wiiwiigeruwana dammi,  
\q2 Yawe God kokabikarawayeni.  
\q1 Wawaya iiyawogha sakabikarawayeni na  
\q2 getana awaki siyadadiyenina.   
\q1
\v 10 Raghani viya, na laiyon kadi kam sarukwamra na vitonana sarabobo,  
\q2 bi gegha da Yawe God yana wiiwiigeruwana damdi na  
\q2 sawara miisedi bogaebogae gesinadiyanana.   
\b  
\q1
\v 11 Natunatugu, kopiika yagu sisiya konawaiyana.  
\q2 Tagu aniyevevemi da metagha Yawe God konakabikuwayeni.   
\q1
\v 12 Memeda makewiiguri konakayoveni  
\q2 bi yawa miisena kabina,   
\q1
\v 13 na gewawaya konisisiya berovedi  
\q2 da gekoniyabana.   
\q1
\v 14 Berabero beradima komiiriwamira,  
\q2 bi miisena konabera,  
\q1 kovi matipo kirakii bi wawaya koniwiitedi  
\q2 da nuwaruririye sinamakae.   
\b  
\q1
\v 15 Yawe God na rotomana berabera wawayidi yakighukighudi,  
\q2 raghanina wiiwiita kiiravine sakwatu touna biidi na yawaiyanedi.   
\q1
\v 16 Bi bera bero wawayidi na yamiiri kubutedi da yiaviyedi,  
\q2 toudi sinarabobo da getana iiyabo inanoghota mayedina.   
\b  
\q1
\v 17 Raghanina Yawe God yana wawaya wiiwiita kiiravine sarukwatu,  
\q2 na yawaiyanedi,  
\q2 da yadi piropiroma yiyawiidi.   
\q1
\v 18 Yawe God na noghota kawakawa wawayidi yagwabigwabiyedi,  
\q2 bi raghanina wawaya yadi noghota parapa sabeku na yiwiitedi.   
\b  
\q1
\v 19 Rotomana berabera wawayidi na nuwapoya peyaridi sabanana,  
\q2 bi gegha da Yawe God yiwiitena nonovedi.   
\q1
\v 20 Touna irikedi tupadi yabaabarena wiimasiyedi  
\q2 da irikedi getana inipokina.   
\b  
\q1
\v 21 Bi wawaya berodi kiiravidiye,  
\q2 na toudi wosina yadi berona sinageghomiiri da sinirabobodi,  
\q1 bi rotomana berabera wawayidi  
\q2 kadi aviya na aro sinakabi.   
\q1
\v 22 Bi gegha, Yawe God yana wiitamariyana yiyawiidi.  
\q2 Wawaya iiyawogha wiiwiita kiiravine samiiri karona  
\q2 touna biidi na aro gesinabananina.   
\c 51  
\s1 Noghotataveyana kana Pari  
\d Raghani tana kiiwawo Deivid madawara ibera, tomogha kana waghawagha Uraiya wavinena kana waghawagha Betsiba yawata. Na God yana peroveta Neitan noko berana kiiravine ikini na Deivid yanabera kiiravine ivinuwapoya na God biidi mmko parina igirumi.  
\b  
\q1
\v 1 O God, yam nuwayuyuna geiyakovikovina  
\q2 na miisena kubera tagu biidi.  
\q1 Tam nonowa wawaya kwiinuwapoyedi,  
\q2 na berona ayaberabera na kunoghotataveni;   
\q1
\v 2 yagu berona koghataveni,  
\q2 bi yagu tamumu kugigirataveni ware wawaya gara dadabuna sakoghatavenina naboni.   
\b  
\q1
\v 3 Berona ayaberabera na akovi,  
\q2 raghani nonowa na iinuwanoghonoghoteni.   
\q1
\v 4 Tagu berona tam biidi abera, tam kawagha;  
\q2 yagu kabikwayo matam kamone ibero.  
\q1 Na raghanina kuwonegu bo, “Tam bera berona kubera!”  
\q2 Na tam wonawaghata kwiisisiya.  
\q1 Raghanina aro kunavereguna,  
\q2 tam bera rotomanina kwaberabera.   
\q1
\v 5 Yagu tubugha raghanine da kata na tagu tamumu wawayigu,  
\q2 raghanina tagu patana sinagunaki kamokamone na tagu naboni abero.   
\q1
\v 6 Bi gegha da kukayoveni da nuwanuwagu kamone wiisuwona iyibonuvigu  
\q2 na noghota miisena nama kuviyevevegu.   
\b  
\q1
\v 7 Yagu berona ayaberabera na kukoghataveni da anamiise magha;  
\q2 da parapa anapoe wamira.   
\q1
\v 8 Kuwonegu da tam kunoghotatavegu na  
\q2 wiisuwona aninuwamiise!  
\q1 Naghove, tam irikegu kugawowora,  
\q2 katana kubera da aninuwamiise magha.   
\q1
\v 9 Geyagu berona kunakita kirakiiyedina  
\q2 bi kabitavena tuwanonoyidi.   
\b  
\q1
\v 10 O God, nuwanuwa miisena, bi wouna kuveregu  
\q2 da tam wiisuwone anakivinim.   
\q1
\v 11 Gegha gwabimma kunaporataveguna!  
\q2 Gegha Kanumim Kabikabikuwayina gwabiguma kunakabitavenina!   
\q1
\v 12 Kuberagu da aninuwamiise magha,  
\q2 ware dagudagune kuviyawiiguna raghanine naboni;  
\q1 kuberagu da yam sisiya kabisisirenina nuwanuwagu inasisira.   
\b  
\q1
\v 13 Wasina bi bero berabera wawayidi biiyadi yam keda aniyeveveyana  
\q2 da sinamiiri karona magha tam biidi.   
\q1
\v 14 O God tam kuviyawiigu, na kata yagu yawa kitara babaraneni  
\q2 bi yam keda rotomanidi kiiravine nuwamiiseye anataworedi.   
\q1
\v 15 O Bada, kiwiitegu da anisisiya  
\q2 da tam anakabepepim.   
\q1
\v 16 Tagu ribiribi anagibu da tam biidi anasuwara, bi gegha, noko geyam kayowana,  
\q2 tam suwara noko naboni na gekiiravidiye kuyibabana.\f + \fr 51:16 \ft Mmko geiyawonawona da God yana kayowana da wawaya suwara beradi sinakabiturana. Mmko yana basuna na God yanoghonoghota da parapa suwara miisena na raghanina yada berona kiiravine tani nuwapoya bi tani babiini da inanoghota taveda.\f*   
\q1
\v 17 Raghanina atoreyowoyena mayegu  
\q2 bi iibabiim da yagu tamumu kunanoghotataveni,  
\q1 na nokodi suwara naboni na tam yam kayowana.  
\q2 O God, gekuyamiimiiri kubutegu  
\q1 raghanina yagu tamumu kiiravine iinuwapoya  
\q2 bi arupari tam biidina.   
\q1
\v 18 O God yam nuwasisirama na Zaiyon biidi miisena kunabera;  
\q2 bi Jerusalem papana kunayoghana mayeni.   
\q1
\v 19 Wasina bi wawaya nuwanuwadi miisenama tam biidi suwara sinabera, na tam kuninuwamiise toudi biiyadi.  
\q2 Toudi suwara bogaebogae sinagabuna tam biidi.  
\q2 Bi suwara gabugabunidi kiiravine na kau makidi yam suwara gabugabuna debane sinagabuna.   
\c 67  
\s1 Ayi wiikiikiiwa kiiravine  
\d Kabepepa ayidi badana kiiravine. Inawa ere uravidima. Psam, bo Ayi.  
\b  
\q1
\v 1 O God, kinuwanuwaghanemii, da kimiiseyemii  
\q2 bi mayiyim kubera da inarukarata toumii biiyadi.   
\q1
\v 2 Wasina bi wawaya tupadi kubura debane  
\q2 sinakovi da tam awaki kwakayokayoveni da toudi sinabera,  
\q2 dam bi dam tupadi sinakovi da tam rubana kuniyawiidi.   
\b  
\q1
\v 3 Na dam bi dam tupadi tam sinakabepepim,  
\q2 O God, wawaya tupadi na tam sinakabepepim!   
\q1
\v 4 Dam tupadi kubura debane na nuwamiiseye sinatawora  
\q2 basuna tam keda rotomanidiye wawaya kwiibadedi,  
\q2 bi dam tupadi kubura debane kwiinaghovedi.   
\q1
\v 5 Na dam bi dam tupadi tam sinakabepepim,  
\q2 O God, wawaya tupadi na tam sinakabepepim!   
\b  
\q1
\v 6 Na kwabu kabipura miisena inavereyana,  
\q2 bi yada God parapa miisena inabera touda biiyadi.   
\q1
\v 7 Wonawaghata, God wiimiiseyana inavereda  
\q2 bi meghamegha mmko kuburina debane,  
\q2 na wawaya God sinakabikarawayeni.   
\c 90  
\s1 God da Wawaya kiiravidiye  
\d God yana bagibagi tomoyina Mosis, touna mmko parina igirumi.  
\b  
\q1
\v 1 Yawe God, kimta bi kimta nunudigha na  
\q2 tam na ware yama bare.   
\q1
\v 2 Tam rorowainagha na God waghata  
\q2 bi muriye da koya kuyaberadi  
\q2 da muriye na kubura kuyabera.   
\b  
\q1
\v 3 Wawaya kwawonedi bo, “Koveramagha konidobodobo magha!”  
\q2 Na kwawamiridi da saveramagha sidobodobo, mema sipiikana.   
\q1
\v 4 Mata kamomve, na bodu 1,000 na ware gabudara tanagha naboni,  
\q2 toudi ware raghani tupona nubabasu kamone.   
\q1
\v 5 Wawaya yadi yawa kwabori yaininagha  
\q2 ware raghanina mimeu yakovina naboni.  
\q2 Touda ware rei didibare yagogo yageena naboni.   
\q1
\v 6 Didibare na reina matayina da yagogo yapora  
\q2 bi ravidiye na yivivi da yarabobo.   
\b  
\q1
\v 7 Noko naboni da yam nuwapughu ghamana yiberomii.  
\q2 Raghanina nuwanuwam yapughu toumii biiyadi,  
\q2 na parapa kanagharena kirakiiyem.   
\q1
\v 8 Bi yama bera berodi tupadi kwakitakita  
\q2 bi kiimatipo da yama berona kayikowoyidi,  
\q2 bi gegha da tupadi kwakitadi.   
\q1
\v 9 Raghanina yawayawiimii kamakamake na nuwanuwam yapughu toumii biiyadi,  
\q2 da yama yawa kwabori yaiyainedi,  
\q2 mayimayiyina raghanina wawaya yiyawiigurina naboni.   
\q1
\v 10 Toumii kamake da bodu 70 naboni  
\q2 bi meboda wawaya viya maragasidi na  
\q1 samake da bodu 80 naboni,  
\q2 bi gegha da nuwapoya peyaridi kabanana,  
\q1 na raghani yanagho yaininagha da karabobo.   
\b  
\q1
\v 11 Getana iiyabo parapa iyakakovi da yam nuwapughu maragasina metagha;  
\q2 meboda yam nuwapughu kayakowa yapori,  
\q2 na parapa kayakumararayem.   
\q1
\v 12 Kiyevevemii da yama yawa makena gabudarina yana guri kanakovi,  
\q2 da toumii noghota miisena tam gwabimma kanakabi.   
\b  
\q1
\v 13 Yawe God kuveramagha da kuninuwanuwaghanemii!  
\q2 Genuwanuwam inapughumake toumii biiyadina!   
\q1
\v 14 Yam nuwamonikama didibara patepatena kibonuvimii,  
\q2 da yama make yawana kamone nuwamiimiiseye kanatawora.   
\q1
\v 15 Bodu peyaridi nuwapoya kuveremii kiiravine,  
\q2 na kata raghani gurina nuwamiise kuveremii!  
\q1 Yama kabikwarakwara kabitavetaveyana,  
\q2 bi bodu miisedi kuveremii!   
\q1
\v 16 Toumii yam wiitamariyana, yam bagibagi yana maragata kiyevevemii.  
\q2 Yam badobado da maragata metagha na natunatumii kiyevevedi!   
\b  
\q1
\v 17 Yawe tamna yama God, kinuwanuwaghanemii  
\q2 bi awaki bagibagidi kaberabera na  
\q1 kubera da sinuwagha wiimasi,  
\q2 bi awaki bagibagidi kaberabera na  
\q2 kubera da sinuwagha wiimasi.   
\c 95  
\s1 Kabepepa ayina  
\q1
\v 1 Kopiika, Yawe God tanakabepepi!  
\q2 Kobera da nuwamiise kiiravine God biidi tanatawora,  
\q2 iiyabo yitarababaranedana.   
\q1
\v 2 Kobera da wiikiikiiwama tanapiika naghone  
\q2 bi kabepepa ayidi nuwakayowanidi tanatawora da tanakabepepi.   
\b  
\q1
\v 3 Kiiravine Yawe na God kiidamo kirakiina,  
\q2 touna kiiwawo maragata kirakiina,  
\q2 da god tupadi igeetawanidi.   
\q1
\v 4 Bi kubura tupana yibadeni,  
\q2 epamana bonayidi didibaridiye da inagho igae koya gekirakiidiye.   
\q1
\v 5 Yegii tupana yibadeni, meko iberana;  
\q2 bi bada tanawa, meko touna wosina ikabiwiipakipakina.   
\b  
\q1
\v 6 Kopiika, kobera da tanapepeta bi tana kabikuwayeni;  
\q2 kobera da Yawe God naghone tanituwapore oghogheyana,  
\q2 kada berabera tomoyina!   
\q1
\v 7 Touna na yada God;  
\q2 bi touda na yana wawaya, na yakoyakoyayida,  
\q2 ware sip bodaboda yana sip yakoyakoyayidina naboni.  
\b  
\q1 Kata kowaiyana Yawe God awaki yawonewoneni:   
\q1
\v 8  \x - \xo 95:8 \xt Exo 17:1-7; Num 20:2-13\x*Genuwanuwami sinakotakii,  
\q2 ware nosinosiminakimi Meriba kubure siberana naboni,  
\q2 ware toudi noko gabudarine Massa mayabine siberana naboni.   
\q1
\v 9 Name siruyaghagu da sivitupawamiwamiregu,  
\q2 bagune sikita da awaki abera kiiravidiye  
\q2 raghanina Ijiptma akabikanibuvedina gabudarine.   
\q1
\v 10 Bi bodu 40 kamodiye nuwanuwagu ipughu nokodi damdi biiyadi.  
\q2 Awona bo, Toudi nuwanuwadiye tagu simiiri kubutegu,  
\q2 da yagu gwara gesiyakabisisiredina.   
\q1
\v 11 Na nuwanuwagu ipughu na wiisuwona maragasina mma naboni abera, awona bo,  
\q2 “Tagu gawara kiiravidiye akabununayi da siyiyawiitaveyana,  
\q2 bi gegha da kata geaniwaghasinedi da sinarughu kamonena.”   
\c 100  
\s1 Kabepepa ayina  
\d Mmko ayina kamone na God yana miisena kiiravine yana wawaya sikiikiiveni.  
\b  
\q1
\v 1 Wawaya tupami kubura debane,  
\q2 kabepepa ayidma kotawora gwaru Yawe God biidi!   
\q1
\v 2 Nuwamiimiiseye touna kokabepepi,  
\q2 kopiika naghone bi konatawora touna biidi.   
\q1
\v 3 Bi konakovi da, “Yawe na God!”  
\q2 Touna iberada, touda na yana wawaya,  
\q2 bi yakoyakoyayida ware sip bodaboda yana sip yakoyakoyayidina naboni.   
\b  
\q1
\v 4 Ere wiikiikiivimi yana Bare Kabikabikuwayine korughu,  
\q2 korughu garina kamone bi konakabepepa.  
\q2 Touna kovikiikiiveni da kana waghawagha kovimiiseyeni.   
\q1
\v 5 Basuna Yawe God na wiinuwanuwaghaneyanina;  
\q2 yana nuwamonika na makewaghawaghasina  
\q2 bi yana nuwamiise na inanowiikarukaru kimta bi kimta biiyadi.   
\c 103  
\s1 Yawe God yana nuwayuyuna  
\d Ayina Deivid igirumi  
\b  
\q1
\v 1 Tagu nuwanuwagu tupanama Yawe God anakabepepi!  
\q1 Kana waghawagha kabikabikuwayina anakabepepi!   
\q1
\v 2 Tagu nuwanuwagu tupanama Yawe God anakabepepi,  
\q2 bi bera miisedi tupadi ibera na gemeyani aninuwawapidina.   
\q1
\v 3 Touna yagu tamumu tupadi yanoghotatavedi,  
\q2 bi gubaga tupadima yiyawiigu.   
\q1
\v 4 Touna karawagama yiyawiigu,  
\q2 bi yinuwanuwaghanegu da nuwamonika yaveregu  
\q2 bi miisena yaberabera tagu biidi.   
\q1
\v 5 Patana amakamakena,  
\q2 touna sawara miisedi yiwiitegu,  
\q2 da tubuyigu na ware kakaka wouna maragasina naboni.   
\b  
\q1
\v 6 Yawe God yana wiiwiita na yayowogha wawaya biiyadi  
\q2 basuna yana keda na nonowa rotomanidi;  
\q2 bi raghanina wawaya berona sabera na Yawe God toudi wawayidi wiitupawamiwamira yaveredi.   
\b  
\q1
\v 7 Touna yana noghota iyanoghonoghosi da iyabera na Mosis biidi ividebeni,  
\q2 bi Isrel damdi biiyadi parapa yana maragata ghamana iviyevevedi.   
\q1
\v 8 Yawe God na wiiwiinuwaghaneyanina da wiinuwayuyunina,  
\q2 touna genuwanuwana iyapughupughu yaininagha,  
\q2 bi yana nuwayuyuna kiiravidae na gegha damonana.   
\q1
\v 9 Touna genonowa yada berona inatupakoghatedina,  
\q2 bi kate yana nuwapughu inanuwatawana waghawaghasina.   
\q1
\v 10 Bagune touna rubarubana da aro ghamana iyavereda,  
\q2 bi yada bera beroberodi kiiravine yanuwatotoveda na gegha iyiimiisanena mayedana.   
\q1
\v 11 Yana nuwayuyuna touda kiiravidae, iiyawogha sakabikabikarawayeni na gegha damonana;  
\q2 nuwayuyunina na iragata kirakii,  
\q2 gegha abama yana ragata naboni.   
\q1
\v 12 Ware raghani matanama metagha na yana rabaraba mayimayiyina raghani didinama naboni,  
\q2 yada bera berodi gwabidama yayounataveyana da yana rabaraba noko patana.   
\q1
\v 13 Ware tamada natunatuna yanuwatotovedi na naboni,  
\q2 bi Yawe God iiyawogha sakumakumararayeni na yanuwatotovedi;   
\q1
\v 14 touna yanoghosi da touda dobodoboma kawagha iberada,  
\q2 na iyakovi da touda na noganogada.   
\q1
\v 15 Bi yada make yawana kubura debane na ware rei naboni.  
\q2 Ware garagara sarudi naboni, tiisaru bi tarabobo.   
\q1
\v 16 Yanunu yatapidi, na toudi sasiwana  
\q2 getana iiyabo iyakitakita mayedina.   
\q1
\v 17 Bi gegha da iiyawogha Yawe God sakumakumararayeni,  
\q2 na yana nuwayuyuna da bera rotomanidi beradi gwabidiye inamake nonowa,  
\q2 kimta da kimta kiiravidiye   
\q1
\v 18 da nokodi iiyawogha yana wiiwaghasina maragasina sakabikabitawani  
\q2 bi yana gwara sakabikabisisiredina biiyadi.   
\b  
\q1
\v 19 Yawe God ibera da abama na yana wiibada abamakamakena,  
\q2 bi nama sawara tupadi yibadedi.   
\b  
\q1
\v 20 Yawe God kokabepepi, tami aneyaneya tupami badobadomi da maragasimi,  
\q2 iiyawogha yana sisiya kowaiyana da koberadina  
\q2 tami Yawe God kokabepepi.   
\q1
\v 21 Yawe God kokabepepi  
\q2 abama kana iyo wawayimi  
\q1 iiyawogha kobagibagiyeni  
\q2 da yana noghota koberaberana.   
\q1
\v 22 Sawara tupadi touna iberadina,  
\q2 sawara tupadi yana wiibadana kamone,  
\q2 na tami Yawe God kokabepepi.  
\q1 Tagu nuwanuwagu tupanama Yawe God anakabepepi.   
\c 110  
\s1 Yawe God da yana Wiivinevinegha Kiiwawona  
\d Mmko Psamna Deivid igirumi.  
\sp Dima wawayina-wawaya biiyadi  
\m
\v 1  \x - \xo 110:1 \xt Mrk 12:36; Acts 2:34,35\x*Yawe God yagu Bada\f + \fr 110:1 \ft Akowa damdi sawona da mmko God yana Wiivinevinegha Kiiwawona, Keriso kiiravine yisisiya (Matiu 22:44 kokita).\f* iwoneni bo,  
\q1 “Mma ririguve kumakekira gawara kabikabikarawayine  
\q2 bi Tagu kam aviya anageiwayidi da yam wiibadana rogune anatoredi.”   
\sp Dima wawayina-kiiwawo biidi  
\q1
\v 2 Yawe God inabera da yam wiibadana inaragata  
\q2 da Jerusalemma yam kanibutaveyana kamone  
\q2 na tam kam aviya kunibadedi.   
\q1
\v 3 Noko gabudarine kunanagho aviye yam maragatama wiirouwa biiyadi,  
\q2 na yam wawaya nuwasisire sinaveremayedi sinanagho.  
\q1 Tam na gara kabikabikuwayidi kunikote,  
\q2 bi gabudara nununaghana yam maragata aniiwuwamiri,  
\q2 ware youra didibara nununagha naboni.   
\sp Dima wawayina-kiiwawo biidi  
\q1
\v 4 Tagu, Yawe God wiisuwona abera na  
\q2 gegha yagu noghota anawamirina, awona bo,  
\q1 “Tam na kuni \k prist\k* waghata  
\q2 Melkisidek\f + \fr 110:4 \ft Melkisidek na yana kayena getayakovina bi touna God yana prist kiikiiwawona tana ware Isu naboni Abraham yana raghaniye.\f* yana kayenama.”   
\sp Dima wawayina-Yawe God biidi  
\q1
\v 5 O Yawe God, kiiwawo na katiiyamma yamiimiiri  
\q2 da babarem kiiravine.  
\q1 Bi kiikiiwawo korotodi inikasunughana  
\q2 raghanina nuwanuwana inapughuna.   
\q1
\v 6 Touna dam tupadi aro inaveredi  
\q2 bi yadi kubura na wawaya sirabobona tubuyidima inibonuvi.  
\q1 Bi kiikiiwawo tupadi inageiwayidi, kubura tupane.   
\q1
\v 7 Touna kedae wusire rarima inaniuna  
\q2 da gayamina inarukabepi bi iniyeveveyana da touna kana aviya igeeiwayidi.   
\c 119  
\s1 Yawe God yana Gwara  
\q1
\v 9 O Yawe God metagha tomogha yaragina keda rotomanine inamake?  
\q2 Nokona wonam kabisisirenina.   
\q1
\v 10 Nuwanuwagu tupanama iimatipo da anabagibagiyem;  
\q2 na kiwiitegu da yam gwara kabisisiredi geanasinighiiyedina.   
\q1
\v 11 Bi wonam agirumeyana da nuwanuwaguve atourarughuwana,  
\q2 na getam biidi tamumu anaberana.   
\q1
\v 12 Yawe God akabekabepepim,  
\q2 yam gwara kiyevevegu.   
\q1
\v 13 Kawaguma gwara tupadi yam wawaya kuveredi  
\q2 na anakabiyawa gwaruvedi.   
\q1
\v 14 Tam wonam akivikivini na nuwamiisena parapa iragata kirakii,  
\q2 genaboni moura peyaridi wiirapeneyanana.   
\q1
\v 15 Bi yam keda ananoghonoghosi;  
\q2 yam gwara kiiravidiye na yagu wiinuwanoghonoghota kamone  
\q2 nonowa ananoghonoghosidi.   
\q1
\v 16 Tagu yam gwara kiiravidiye na aninuwamiise,  
\q2 bi wonam geaninuwawapidina.   
\c 139  
\s1 God yana nuwagiura tupana da koyagha  
\d Mmko Psamna Deivid igirumi.  
\b  
\q1
\v 1 Yawe God, tam nuwanuwagu kamona kwaginigini  
\q2 bi kwakowa kirakiiyegu.   
\q1
\v 2 Tam kwakovi da awaki raghanine amakeyowogha  
\q2 bo ageghomiiri amiiri.  
\q1 Bagune tam rabarabae,  
\q2 nonowa na yagu noghota kwakakovi.   
\q1
\v 3 Tam apeepewana raghanine na kwakitakitagu  
\q2 bo raghanina yagu bare kamone iiyawiitaveyanana.  
\q1 Tagu sawara tupana aberabera na tam kwakakovi.   
\q1
\v 4 Yawe God, muriyeda ayisisiya na,  
\q2 tam nada kwakovi da awaki anisisiyeni.   
\b  
\q1
\v 5 Tamna ware gari naboni kuvitumpipinegu,  
\q2 bi imam debaguve kutore da yam maragatama kwabababaregu.   
\q1
\v 6 Tam akovigu kabina mma naboni na parapa iragata kirakii  
\q2 da gerubana anakovina.   
\b  
\q1
\v 7 Tagu gerubana mebo anaverairem ananagho da gekunakitaguna?  
\q2 Getana kubura noko naboni meme.  
\q2 Meghamegha ananono na tam nonowa na nama!   
\q1
\v 8 Meboda anagae abame, na tam nama;  
\q2 Bo meboda anarabobo bi sinadogugu,  
\q2 na tam nama.   
\q1
\v 9 Meboda anarowoghataveyana ananagho raghani matene gabudara yageegeena kuburidiye,  
\q2 bo meboda ananagho raghani didine gabudara yayoyona kuburidiye make biidi   
\q1
\v 10 na tam imam maragasina ininaghovegu,  
\q2 bi katiiyam inababaregu.   
\b  
\q1
\v 11 Tagu meboda wiididibara ayawoneni da iyikowoyigu  
\q2 bo yeghana ivitumpipinegu na iyididibara magha   
\q1
\v 12 Bi gegha da bagune wiididibara kamone,  
\q2 tagu gerubana anakowoyemna.  
\q1 Tam biidi wiididibara na parapa yeghanina ware gabudara.  
\q2 Wiididibara da yeghana tam biidi na mayimayiyidi.   
\b  
\q1
\v 13 Tam tubuyigu kamona torerereyidi, nuwanuwa da gayama kubera  
\q2 bi sinagunaki raparapane kuvikiikiigu.   
\q1
\v 14 Bi kubera wiimasiyegu kiiravine na iikiikiivem;  
\q2 bagibagi tupadi kwaberabera na waratetedi.  
\q2 Tagu nuwanuwagu tupanama akovi.   
\q1
\v 15 Raghanina irikegu kubera, bi sinagunaki raparapane kutoura yapoyapora,  
\q2 bi name wiikowoye ayaragaragata na tam kwakovi da tagu nama.   
\q1
\v 16 Muriye da ayatubugha na tam kukitagu.  
\q1 Na yagu make yawana gabudaridi kuveregu da anamake,  
\q2 na yam buka kamone kugiruma.  
\q2 Muriye da gabudara dagudaguna iyadagu,   
\b  
\q1
\v 17 O God ipiropiro kirakii da tagu yam noghota parapa anakovidi  
\q2 basuna toudi sipeyara kirakii!   
\q1
\v 18 Tagu gerubagu da anakabiyavidina  
\q2 basuna toudi parapa sipeyara,  
\q2 gekikira eghana naboni!  
\q1 Bi tupadi kabiyawa kovidina na,  
\q2 augunai da ayamakewaghata tam naboni!   
\b  
\q1
\v 19 God, tagu parapa akayokayoveni da berabero wawayidi kunikasunughana!  
\q2 Kasukasunugha wawayidi gwabiguma kurukwavina tavetaveyana.   
\q1
\v 20 Toudi sisiya berodima sigiboyim;  
\q2 bi kam waghawagha gesiyakabikabi karawayenina.   
\q1
\v 21 O Yawe God, tagu iiyawogha sasinighiiyem na asinighiiyedi,  
\q2 da iiyawogha gesiyakabikabi sisiremna.   
\q1
\v 22 Getana awaki, da nuwapughuma iisinighiighiiyedi,  
\q2 na toudi kagu aviya.   
\b  
\q1
\v 23 O God, kita rughuwona da nuwanuwagu kunakita  
\q2 bi kuruyaghagu da yagu noghota kunakovi.   
\q1
\v 24 Bi meboda berabero wawayidi yadi kedagha ananono na kiyevevegu,  
\q2 bi yawa makewaghawaghasina kedane kinaghovegu anapiika tam biidi.   