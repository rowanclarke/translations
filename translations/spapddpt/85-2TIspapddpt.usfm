\p
\v 9 Haz todo esfuerzo \w para|strong="G4314"\w* \w venir|strong="G2064"\w* \w pronto|strong="G5030"\w* \w a|strong="G4314"\w* mí,  
\v 10 \w porque|strong="G1063"\w* \w Demas|strong="G1214"\w*, \w al|strong="G3588"\w* amar \w al|strong="G3588"\w* mundo \w de|strong="G1519"\w* \w ahora|strong="G3568"\w*, \w me|strong="G1473"\w* desamparó \w y|strong="G2532"\w* \w fue|strong="G4198"\w* \w a|strong="G1519"\w* Tesalónica, \w Crescente|strong="G2913"\w*, \w a|strong="G1519"\w* \w Galacia|strong="G1053"\w* \w y|strong="G2532"\w* \w Tito|strong="G5103"\w*, \w a|strong="G1519"\w* \w Dalmacia|strong="G1149"\w*.  
