\id SNG - Guji Bible 
\h Kitaaba Faaruu Solomoonii 
\toc1 Kitaaba Faaruu Solomoonii 
\toc2 Kitaaba Faaruu Solomoonii 
\toc3 Far. Sol. 
\mt1 Kitaaba Faaruu Solomoonii 
\imt1 Seensa 
\ip Kitaab faaruu Solomoonii irra caalaa wolaloo jaalalaa faaruu dhiirti dubartii, dubartiin dhiira faarfattu. Hiikkaa garii keessatti kitaab kun, «Faaruu faaruu caaltu» yookiin, «Faaruu keessaa faaruu guddoo bareeddu» jedhamee beekkama. Woraabbii afaan Ibrootaa keessatti kitaab kun ka Solomoonii te'uun isaa waan beekkameef, kitaaba Solomoonii jedhama. 
\ip Faaruu tana worri Yihudootaa yennaa hedduu jaalala Waaqaa fi kolbaa isaa wodhakkaa jiruun wol fakkeessan; worri Kiristaanaa jaalala Kiristoosii fi Wolde'a Kiristaanaa wodhakkaa jiruun wol fakkeessan. 
\iot Haadhoo Dubbi'ii 
\io1 Faaruu Qaraa\ior 1:1—2:7\ior* 
\io1 Faaruu Lammeesso'oo\ior 2:8—3:5\ior* 
\io1 Faaruu Sadeesso'oo\ior 3:6—5:1\ior* 
\io1 Faaruu Arfeesso'oo\ior 5:2—6:3\ior* 
\io1 Faaruu Shaneesso'oo\ior 6:4—8:4\ior* 
\io1 Faaruu Jayeesso'oo\ior 8:5-14\ior* 
\c 1  
\p  
\v 1 Faaruu Solomoonii ta faaruu mara caaltu. 
\s1 Faaruu Qaraa 
\sp Waajibittiin 
\q1  
\v 2 «Jaalalli keeti daadhii woyni'ii waan caaluuf, 
\q2 afaan kiyya keessa na sunqadhu. 
\q1  
\v 3 Fooleen fiqiree teetii hin uddootti; 
\q2 maqaan keeti akka fiqiree dhangalaatuu ti; 
\q2 tanaaf durri marti si jaalatti. 
\q1  
\v 4 Na fudhadhuu deemi! Ariifannuu ti; 
\q2 ee, mooticha gara kolloo teetii na geessi. 
\sp Jaaloti 
\q1 Nuuti si'iin firinxiindhee hin gammanna; 
\q2 daadhii woyni'ii caalaa jaalala keeti leellinna; 
\q2 dubartooti marti dhuguma si jaalatan. 
\sp Waajibittii 
\q1  
\v 5 Ee, durra Yerusaalemii! 
\q2 Ani gurraattii te'ulle, 
\q2 akka dunkaanii Qedaarii, 
\q2 akka gollaa mana mootummaa Solomoonii miidhaga. 
\q1  
\v 6 Ani gurraattii waan te'eef, 
\q2 aduun waan na gurraachessiteef, 
\q2 na hin daaw'atina'a! 
\q1 Obboleeyyan tiyya natti aaranee, 
\q2 oorruu muka woyni'ii akka eegu na godhane; 
\q2 muka woyni'ii kiyya ani hin eeganne. 
\q1  
\v 7 Jaala kiyya ka lubbu'uu! 
\q2 Hoolee teeti eessa akka tiffattu, 
\q2 Waareelle eessatti akka boqachiifattu natti himi. 
\q1 Ani maaniif hoolee jaalota teetii bira 
\q2 akka dubartii fuula hagooggattee joonja?» jette. 
\sp Waajibichi 
\q1  
\v 8 Ati ta dubartii mara caalaa miidhaddu! 
\q2 Yoo hin beenne teete, 
\q2 hoolee gula ideemi! 
\q2 Ilmoolee re'e'ee teeti 
\q2 dunkaanii tissitootaa bira dheechifadhu. 
\q1  
\v 9 Obboleettii tiyya! 
\q2 Ati fardoo garreettaa fardaan harkifamu harkisanu 
\q2 ka Fara'oonii keessaa 
\q2 akka farda tokkoo ti. 
\q1  
\v 10 Mallaan teeti seesaan, 
\q2 mormi keetille dooqaan miidhageera. 
\q1  
\v 11 Ani\f + \fr 1:11 \fqa Ani: \fqa Afaan Ibrootaatiin «Nuuti» \ft Jedha. Nuuti jechuun isaa akka mootichi ifi himu.\f* worqii gurraa, 
\q2 ta meeti'iin seefante hujisiisa. 
\sp Waajibittii 
\q1  
\v 12 Mootiin areerratiisatti jiruun, 
\q2 fiqireen tiyya uddaa ifii fiqqitte. 
\q1  
\v 13 Jaalalleen kiyya akka subba qumbi'ii ti; 
\q2 inni odduu harma kiyyaa boqata. 
\q1  
\v 14 Jaalalleen kiyya naaf akka daraaraa uddowu, 
\q2 ka addee muka woyni'ii 
\q2 ka madda En-Gedii keessaa ti. 
\sp Waajibichi 
\q1  
\v 15 Ee, jaalallee tiyya, ati attam attam miidhadda! 
\q2 Ee, attam attam miidhadda! 
\q2 Ilti teeti akka ila saphaliisaa ti. 
\sp Waajibittii 
\q1  
\v 16 Jaalallee kiyya, ati attam attam miidhadda! 
\q2 Ati attam attam nama gammachiitta! 
\q2 Taqeen teenna akka marra bisile'ee ti. 
\sp Waajibichi 
\q1  
\v 17 Utubaan mana keennaa muka hindheensaa ti; 
\q2 dagaleen isaalle muka birbirsaa ti. 
\c 2  
\sp Waajibittii 
\q1  
\v 1 Ani akka daraaraa lafa Sharoniitii fi 
\q2 akka daraaraa dhooqa keessaa ti. 
\sp Waajibichi 
\q1  
\v 2 Jaalalleen tiyya dubartoota oddu'utti 
\q2 akka daraaraa qoree odduu jiruu ti. 
\sp Waajibittii 
\q1  
\v 3 Jaalalleen kiyya dargaggoota oddu'utti, 
\q2 akka muka appili'ii ka baddaa keessa jiruu ti. 
\q1 Ani gaaddisa isaa jala tee'iisatti hin gammada; 
\q2 midhaan isaalle afaan kiyyatti hin mi'owa. 
\q1  
\v 4 Inni gara mana gammadaa na geesse; 
\q2 beessisi jaalala isaa na irra jira. 
\q1  
\v 5 Ani jaalala isaatiin qabame waan gaggabeef, 
\q2 midhaan woyni'ii nyaachisa'aatii na jabeessa'a; 
\q2 midhaan muka appili'iitiin na gammachiisa'a. 
\q1  
\v 6 Harki isaa bitaachi mataa kiyya jala adoo jiraataa; 
\q2 harki isaa middichi adoo na hanqafataa. 
\q1  
\v 7 Ee dubartoota Yerusaalemii, 
\q2 haga inni fedhuma ifiitiin ka'utti, 
\q2 jaalallee kiyya tirtirsitanee akka hin dammassine, 
\q2 ani maqaa jilibaa yookiin gadansa badda'aatiin, 
\q2 isin magannifadha. 
\s1 Faaruu Lammeesso'oo 
\sp Waajibittii 
\q1  
\v 8 Kunoo, jaalalleen kiyya, 
\q2 gaarota irra u'utaalaa, 
\q2 koobota irra burraaqaa dhufuun qoonqoo dhage'a. 
\q1  
\v 9 Jaalalleen kiyya jilibaa yookiin 
\q2 ilmoolee gadansaa fakkaata. 
\q1 Kunoo inni dalleya mana keennaa duuba dhaabbata; 
\q2 qowa dalleyaatiin, 
\q2 fodda'aan gara keessaa ilaaliisatti jira. 
\q1  
\v 10 Jaalalleen kiyya natti dubbatee, 
\q2 «Jaalallee tiyya, dansittii tiyya! 
\q2 Koy, woliin ideenna. 
\q1  
\v 11 Kunoo, ganni dabareera; 
\q2 bokkeenni roobuu lakkisee caameera. 
\q1  
\v 12 Daraaraan baquu jalqabeera; 
\q2 yennaan faaruu faarfatanu geetteerti; 
\q2 qoonqoon saphaliisaa lafa teenna keessatti 
\q2 dhage'anteerti. 
\q1  
\v 13 Harruun midhaanotteerti; 
\q2 woyniille daraartee uddootteerti. 
\q1 Jaalallee tiyya, dansittii tiyya! 
\q2 Ka'i, woliin ideenna» naan jedhe. 
\sp Waajibichi 
\q1  
\v 14 Ee, saphaliisa tiyya, 
\q2 ta holla dhakaa keessaa, 
\q2 ta addee dhokata gaara keessaa, 
\q2 fuula keeti natti mudhisi; 
\q2 qoonqoo teeti na dhageessis; 
\q2 qoonqoon teeti natti tolti; 
\q2 fuulli keeti natti miidhaga. 
\b  
\q1  
\v 15 Jeedalootaa fi ilmoolee jeedalootaa 
\q2 worra woynii teenna ta daraariisatti jirtu 
\q2 nu duraa balleessu, nuu qaba'a. 
\sp Waajibittii 
\q1  
\v 16 Jaalalleen kiyya, kiyyuma; 
\q2 anille ta isaa ti; 
\q2 inni daraaraa dansaa keessa horii tissa. 
\q1  
\v 17 Ee jaalallee kiyya! Adoo boruun hin dayya'in, 
\q2 aduun adoo hin bayin, 
\q2 akka jiliba'aa yookiin 
\q2 akka ilmoolee gadansaa, 
\q2 gaara bu'aa bayii qabu irra 
\q2 utaalaa gara kiyya koy. 
\c 3  
\q1  
\v 1 Ani halkan guutuu taqee tiyya irratti 
\q2 jaala kiyya ka lubbu'uu barbaade; 
\q2 ani isa barbaade ammoo hin dhaggine. 
\q1  
\v 2 Ani amma ka'ee qachaa keessa, 
\q2 karaa irra, woldeennaa kara'aa irra deddeemee, 
\q2 jaala kiyya ka lubbu'uu hin barbaada; 
\q2 ani barbaade ammoo isa hin dhaggine. 
\q1  
\v 3 Worri qachaa eegu adoo asii fi achi deemanuu, 
\q2 na dhaggane; 
\q2 anille, «Jaala kiyya ka lubbu'uu 
\q2 dhaggitaneertanii?» jedhee gaafadhe. 
\q1  
\v 4 Isaan irra akkuma dabareen, 
\q2 jaala kiyya ka lubbu'uu san dhaggee, 
\q2 isa qabadhe; 
\q2 gara mana haadha tiyyaa, 
\q2 gara kolloo haadha na deetteetitti 
\q2 haga isa geeffadhutti gad isa hin lakkinne. 
\b  
\q1  
\v 5 Ee dubartoota Yerusaalemii, 
\q2 haga inni fedhuma ifiitiin ka'utti, 
\q2 jaalallee kiyya tirtirsitanee akka hin dammassine, 
\q2 ani maqaa jilibaa yookiin gadansa badda'aatiin, 
\q2 isin magannifadha. 
\s1 Faaruu Sadeesso'oo 
\sp Waajibittii 
\q1  
\v 6 Ka lafa goomole'ee keessaa 
\q2 akka duumensa aaraa 
\q2 ol bayiisatti jiru, 
\q2 ka akka fiqiree qumbi'ii fi hixaanaan 
\q2 daldaltooti uddowaa mara irraa hujattee kun eennu? 
\q1  
\v 7 Kunoo, barcumaan mootumma'aa\f + \fr 3:7 \fqa Barcumaa mootumma'aa: \ft Barcumaan mootumma'aa kun ka kolbaan Solomoon ittiin ba'attee asii fi achi ideentu.\f* ka Solomoonii, 
\q2 loltoota hunnaameyyii Israa'elii 
\q2 keessaa ta filatante jaatamaan marfameera. 
\q1  
\v 8 Marti isaaniituu shallaagaa hidhatan; 
\q2 martinuu muuxannoo lolaa qaban; 
\q2 bidhaa halkaniitiif 
\q2 tokko tokkoon isaanii shallaagaa hidhataneeran. 
\q1  
\v 9 Mootichi Solomoon muka Libaanonii irraa, 
\q2 barcumaa mootumma'aa ka ifii hujisiifate. 
\q1  
\v 10 Miilli barcumaa mootumma'aa sanii meetii irraa, 
\q2 irkoon isaa worqii irraa, 
\q2 addeen tee'iisaa woyaa dhiille'een gonfameera; 
\q2 keessa isaa dubartoota Yerusaalemiititti seesee huje. 
\q1  
\v 11 Ee Dubartoota Yerusaalemii, 
\q2 dhaqa'aatii kallacha Solomoonii mootichaa, 
\q2 ka haati isaa guyyaa fuudha isaa, 
\q2 guyyaa gadhaan isaa gammadetti 
\q2 itti keette ilaala'a. 
\c 4  
\sp Waajibichi 
\q1  
\v 1 Jaalallee tiyya, ati attam attam dansitti'i! 
\q2 Ee, ati attam attam dansitti'i! 
\q1 Ilti teeti shaashii ati hagooggattu keessaa, 
\q2 akka ila saphaliisaa kuulle'e; 
\q2 rifeensi mataa keetii 
\q2 re'oota gaara Giil'aadii irraa 
\q2 gad yaa'anu fakkaata. 
\q1  
\v 2 Ilkaan keeti akka hoolota adii 
\q2 yennaa rifeensi isaanii muramu 
\q2 nafi isaanii dhiqamee bisaan keessaa bayanuu ti; 
\q2 hooloti tun martinuu lakkuu dhalti; 
\q2 maseenti takkaalle isaan keessa hin jirtu. 
\q1  
\v 3 Hidhiin teeti haarrii diintuu fakkaatti; 
\q2 haasonni keeti namatti tola. 
\q1 Mallaan teeti shaashii ati hagooggattu keessaa, 
\q2 midhaan rumaanii ka gargar baqaqe fakkaata. 
\q1  
\v 4 Mormi keeti xelleephoo Daawitii, 
\q2 ta wonteen gugurdoon kum tokko, 
\q2 wonteen goototaa martinuu 
\q2 itti fannifamanu fakkaata. 
\q1  
\v 5 Harmi keeti lamaanuu jilibaa ilmoolee, 
\q2 lakkuu jilibaa ilmoole'ee, 
\q2 ta daraaraa keessa dheeddu fakkaata. 
\q1  
\v 6 Adoo boruun hin dayya'in, 
\q2 aduun adoo hin bayin, 
\q2 ani gara gaara qumbi'iitii fi 
\q2 gara kooba hixaanaa hin dhaqa. 
\q1  
\v 7 Jaalallee tiyya, ati attam attam dansitti'i! 
\q2 Womaa dhidhinna hin qaddu. 
\b  
\q1  
\v 8 Waajibittii tiyya, Libaanon irraa gara kiyya koy! 
\q2 Libaanon irraa gara kiyya koy! 
\q1 Qaccee gaara Amaanaa irraa, 
\q2 qaccee gaara Siinaariitii fi Hermoonii, 
\q2 goda neenqaa, 
\q2 koobota qeeransaa irralle gad bu'i. 
\q1  
\v 9 Obboleettii tiyya, waajibittii tiyya! 
\q2 Ati midhuu teeti takkatti'iin, 
\q2 dirata morma keetiitiin 
\q2 qalbii tiyya boojite. 
\q1  
\v 10 Obboleettii tiyya, waajibittii tiyya! 
\q2 Jaalalli keeti attam attam nama gammachiisa! 
\q2 daadhii woyni'ii caalaa 
\q2 attam attam gabbi nama godha! 
\q1 Fooleen fiqiree teetii uddowaa mara caalti. 
\q1  
\v 11 Waajibittii tiyya! 
\q2 Hidhiin teeti akka dhaaba dammaa 
\q2 nadhii coccossiti; 
\q2 aananii fi dammi arraba keeti jala jiran; 
\q2 fooleen woyaa teetii akka foolee 
\q2 hindheensa Libaanonii ti. 
\q1  
\v 12 Obboleettii tiyya, waajibittii tiyya! 
\q2 Ati akka oorruu itti ijaaramee ti; 
\q2 akka madda dalleyaan marfameetii fi 
\q2 akka burqaa cuqqaalamee ti. 
\q1  
\v 13 Ati akka oorruu muka rumaanii, 
\q2 ka midhaan dansaa buusu, 
\q2 ka daraaraan uddowuu fi 
\q2 biqiltuun naardoosii achi keessa jiranuu ti. 
\q1  
\v 14 Muki Naardoosii, biqiltuun uddoottu, 
\q2 marri uddowu, qarafaan, 
\q2 muki hixaanaa, muki qumbi'ii, 
\q2 daraaraan hargiisaatii fi 
\q2 uddowaan dansaan adda addaa marti 
\q2 achi keessa jiran. 
\q1  
\v 15 Ati akka burqaa bisaan addee oorru'uu, 
\q2 ka boolla keessaa yaa'u, 
\q2 bisaan gaara Libaanoniitii gad yaa'uu ti. 
\sp Waajibittii 
\q1  
\v 16 Ee, qilleensa kaabaa dammaqi! 
\q1 Ee, qilleensa kibbaa koy! 
\q1 Oorruu tiyyatti qilleensi; 
\q2 fooleen isi'ii uddoottuun fiqittuu ti. 
\q1 Jaalalleen kiyya gara oorruu ifii dhufee 
\q2 midhaan oorruu ifii dansaa nyaatuu ti. 
\c 5  
\sp Waajibichi 
\q1  
\v 1 Obboleettii tiyya, waajibittii tiyya! 
\q2 Ani gara oorruu tiyyaa dhufeera; 
\q2 qumbii tiyyaa fi uddowaa kiyya wolitti qabadheera; 
\q2 nadhii dhaaba damma kiyyaa nyaadheera; 
\q2 daadhii woyni'ii tiyyaa fi aanan kiyya uneera. 
\sp Jaaloti 
\q1 Nyaadha'a, jaalota, una'a, jaalalaan machowa'a! 
\s1 Faaruu Arfeesso'oo 
\sp Waajibittii 
\q1  
\v 2 Ani rafeera; yaadi kiyya ammoo rafee hin jiru; 
\q2 jaalalleen kiyya balbala dhodhowaa, 
\q2 «Obboleettii tiyya, jaalallee tiyya! 
\q2 Saphaliisa tiyya, ta dhidhinna hin qanne, naa bani! 
\q1 Mataan kiyya fixeensaan, 
\q2 rifeensi mataa kiyyaalle 
\q2 dabana halkaniitiin jiidheera» jedhuun dhage'e. 
\q1  
\v 3 Ani ammoo, «Woyaa tiyya baafadheeraa, 
\q2 attam deebisee uffadha ree? 
\q1 Ani miila kiyya dhiqadheera, 
\q2 attam deebisee xureessa ree?» jedheen. 
\b  
\q1  
\v 4 Jaalalleen kiyya karaa qowaatiin 
\q2 harka ifii gara keessaa keye; 
\q2 gadhaan kiyya isaaf na raafame. 
\q1  
\v 5 Ani jaalallee kiyyaaf balbala baniisaaf ka'ee, 
\q2 harka kiyyaan qabannoo cufana'aa yennaa qabadhe, 
\q2 fiqireen qumbi'ii harka kiyya irraa coccoxxee, 
\q2 qabannoo san irratti dhangalaate. 
\q1  
\v 6 Ani jaalallee kiyyaaf balbala bane; 
\q2 inni ammoo deebi'ee deemeera. 
\q1 Yennaa inni dubbate san, 
\q2 gadhaan na rifate. 
\q1 Ani isa barbaade; 
\q2 ammoo hin dhaggine. 
\q1 Ani isa waame; 
\q2 inni na jalaa hin owwaanne. 
\b  
\q1  
\v 7 Namooti asii fi achi deemaa qachaa eeganu 
\q2 na dhaggane; 
\q2 isaan dikanee na madeessane; 
\q2 eeddoti dalleya qacha'aa 
\q2 woyaa tiyya na irraa mulqane. 
\q1  
\v 8 Ee, dubartoota Yerusaalemii, 
\q2 jaalallee kiyya yennaa dhaggitane, 
\q2 maan isatti hintan seetan? 
\q1 Ani jaalala isaatiin akka dhibameeru, 
\q2 itti naa hima'a. 
\sp Dubartooti Jaaloti Waajibitti'ii 
\q1  
\v 9 Ati ta dubartoota mara caalaa dansittii teete! 
\p Jaalalleen keeti worra kaan ka attam caalu inni? 
\q2 Ati akkas ka nu magannifattu, 
\q2 jaalalleen keeti worra kaan ka attam caalu inni? 
\sp Waajibittii 
\q1  
\v 10 Jaalalleen kiyya diimaa hargiisa; 
\q2 inni nama kuma kudhan keessalle'etti hin mudhata. 
\q1  
\v 11 Buqqiin mataa isaa worqii qulluu fakkaatti; 
\q2 rifeensi mataa isaa luuccaa, 
\q2 gurraacha akka harraaqessaa ti. 
\q1  
\v 12 Ilti isaa akka saphaliisa adii 
\q2 madda bisaanii bira tee'uu, 
\q2 ka akka waan aananiin dhiqatee 
\q2 addaatuu, 
\q2 akka dooqaa jirti. 
\q1  
\v 13 Mallaan isaa akka oorruu uddowa'aa ti; 
\q2 hidhiin isaa akka daraaraa 
\q2 fiqiree qumbi'ii dhangalaasuu ti. 
\q1  
\v 14 Harki isaa ulee worqi'ii 
\q2 ta dooqaan seefante fakkaata; 
\q2 nafi isaa ilka arbaa 
\q2 ka dhakaa, «Safiiros» jedhamuun 
\q2 seefame fakkaata. 
\q1  
\v 15 Miilli isaa utubaa cabbii cululuxxu'uu, 
\q2 ka worqii qulluu irra dhaabbatu fakkaata. 
\q1 Inni gaara Libaanonii fakkaata; 
\q2 akka hindheensa Libaanonii 
\q2 ka mara caalaa filatame. 
\q1  
\v 16 Haasonni isaa guddoo mi'owa; 
\q2 inni guddoo jaalatama'a. 
\q1 Ee, dubartoota Yerusaalemii, 
\q2 jaalalleen kiyya, jaalli kiyya isa. 
\c 6  
\s1 Dubartooti Jaaloti Waajibitti'ii 
\q1  
\v 1 Ati ta dubartoota caalaa dansittii teete! 
\q2 Jaalalleen keeti eessa dhaqe? 
\q1 Akka si woliin barbaannu, 
\q2 karaa kam gore? 
\sp Waajibittii 
\q1  
\v 2 Jaalalleen kiyya horii tiffatiisaaf, 
\q2 daraaraalle guuratiisaaf, 
\q2 gara oorruu uddowaa ifii gad dhaqeera. 
\q1  
\v 3 Ani ta jaalallee kiyyaa ti; innille kiyya; 
\q2 inni odduu daraara'aa horii tissa. 
\s1 Faaruu Shaneesso'oo 
\sp Waajibichi 
\q1  
\v 4 Ee, jaalallee tiyya, 
\q2 ati akka qachaa Tiiza'aa miidhadda; 
\q2 akka qachaa Yerusaalemii tolta; 
\q2 akka loltoota baandiraa qabatanee deemanuu 
\q2 arnya qadda. 
\q1  
\v 5 Ilti teeti waan na boojiteef, 
\q2 na irraa deebifadhu! 
\q1 Rifeensi mataa keetii re'oota 
\q2 gaara Giil'aadii irraa gad yaatu fakkaata. 
\q1  
\v 6 Ilkaan keeti akka hoolota adii 
\q2 dhiqamanee bisaan keessaa bayanuu addaata; 
\q2 hooloti tun martinuu lakkuu dhalti malee 
\q2 isaan keessa maseenti hin jirtu. 
\q1  
\v 7 Mallaan teeti lamaan 
\q2 shaashii ati hagooggattu keessaa, 
\q2 midhaan rumaanii ka gargar baqaqe fakkaatti. 
\q1  
\v 8 Giittoti jaatamaa fi gursumeeyyiin saddeettami, 
\q2 durri laakkossi isaanii haga hin qanne, 
\q2 jiraachuu dande'an. 
\q1  
\v 9 Saphaliisi tiyya 
\q2 ta anaaf dhidhinna hin qanne isii qofa; 
\q2 isiin haadha ifiitiif takkatti'i; 
\q2 ta isii deette isii jaalatti. 
\q1 Ijoolleen durraa isii dhagganee 
\q2 «Ati ta leellifante» jedhaneen; 
\q2 giittotii fi gursumeeyyiille isii leellisane. 
\sp Dubartooti Jaaloti Waajibitti'ii 
\q1  
\v 10 Ta akka boruu dayya'uu mudhattu, 
\q2 ta akka ji'aa miidhaddu, 
\q2 ta akka adu'uu issitu, 
\q2 ta akka loltoota baandiraa qabatanuu 
\q2 arnya qaddu tun eennu? 
\sp Waajibichi 
\q1  
\v 11 Ani muki woyni'ii akka quunxe, 
\q2 muki rumaaniille akka guntute ilaaliisaaf, 
\q2 gara dhooqa oorruu muka, «Almond» jedhamuu 
\q2 gad dhaqe. 
\q1  
\v 12 Adoo ani hin beekin halchaan tiyya na buttee, 
\q2 garreettaa fardaan harkifamu 
\q2 ka qondaaltota kolbaa tiyyaa keessa na keette. 
\sp Dubartooti Jaaloti Waajibitti'ii 
\q1  
\v 13 Ee, Shulaamitti'i! Deebi'i, deebi'i! 
\q2 Akka nuuti si ilaalluuf, deebi'i, deebi'i! 
\sp Waajibichi 
\q1 Akka nama sirba darabaa lamaa ilaaluu, 
\q2 Shulaamittii tana isin maaf ilaaltan? 
\c 7  
\sp Waajibichi 
\q1  
\v 1 Ee, intala qondaalaa! 
\q2 Miilli keeti kophee bexxellicha keessaa, 
\q2 attam attam dansa'a! 
\q1 Baarreen tafa keetii dooqa 
\q2 harki nama hujii harkaa beeku huje fakkaata. 
\q1  
\v 2 Handhurti teeti kuruurruu 
\q2 akka qorii daadhiin woyni'ii keessaa hin dhabannee fakkaatti. 
\q1 Uffaan keeti tuulaa qamadi'ii 
\q2 ta daraaraan itti naanneffame fakkaata. 
\q1  
\v 3 Harmi keeti lamaanuu 
\q2 lakkuu ilmoolee jiliba'aa fakkaata. 
\q1  
\v 4 Mormi keeti xelleephoo 
\q2 ilka arbaa irraa hujante fakkaata. 
\q1 Ilti teeti lamaanuu baleessa Heshiboonii 
\q2 ka karra Batraabiimii biraa fakkaatan. 
\q1 Funnaan keeti xelleephoo Libaanonii 
\q2 ta gara Damaasqo'oo fuula galteertu fakkaata. 
\q1  
\v 5 Mataan keeti gaara Qarmelosii fakkaata; 
\q2 rifeensi mataa keetiille 
\q2 maraa haarrii dhiille'ee fakkaata; 
\q2 mootichille shurrubbaa kanaan booji'ameera. 
\q1  
\v 6 Ee, jaalallee tiyya! 
\q2 Ati attam attam miidhadda! 
\q2 Ati attam attam tolta! 
\q2 Attam attam nama gammachiitta! 
\q1  
\v 7 Hojjaan teeti muka meexxi'ii, 
\q2 harmi keeti unkuruura isi'ii fakkaata. 
\q1  
\v 8 Ani, «Muka meexxi'ii san hin yaaba; 
\q2 damee isaa hin qabadha» jedhe. 
\q1 Harmi keeti akka unkuruura woyni'ii, 
\q2 fooleen hafuura keetii 
\q2 akka foolee muka appili'ii teetuu ti. 
\q2  
\v 9 Fooleen afaan keetiille 
\q2 akka foolee daadhii woyni'ii dansa'aa teetuu ti. 
\sp Waajibittii 
\q1 Daadhiin woyni'ii sun 
\q2 hidhi'ii fi ilkaan jaalallee kiyyaa keessa dabartee, 
\q2 laana gad buutuu ti. 
\q1  
\v 10 Ani ta jaalallee kiyyaa ti; 
\q2 inni na halcha. 
\q1  
\v 11 Jaalallee kiyya, koy! 
\q2 Baadiyyaa dhandhee, 
\q2 ollaa keessa bullaa ti. 
\q1  
\v 12 Barii ganamaan kaanee, 
\q2 gara addee muka woyni'ii dhandhee, 
\q2 muki woyni'ii guntutee akka baqe, 
\q2 muki rumaaniille akka daraare ilaalla! 
\q1 Ani achitti jaalala kiyya si'iif hin kenna. 
\q1  
\v 13 Midhaan muka fedhii jaalalaa kakkaasu 
\q2 hin uddowa; 
\q2 ee, jaalallee kiyya, 
\q2 midhaan dadansaan marti, 
\q2 ka amma guuramee fi ka bilchaate, 
\q2 ka ani si'iif lafa keyeeru 
\q2 balbala teenna dura jiran. 
\c 8  
\q1  
\v 1 Ati adoo obboleessa kiyya 
\q2 ka harma haadha tiyyaa hodhe, naaf teetee, 
\q2 ani karaa irratti si dhaggee, 
\q2 adoo si sunqadhee jiraadhe, 
\q2 silaa eennulle na hin tuffatuuyyu. 
\q1  
\v 2 Ani silaa gara mana haadha tiyyaa, 
\q2 ta na barsiittee si geessee, 
\q2 daadhii woyni'ii dansaa sii kennee, 
\q2 cunfaa midhaan muka rumaaniille 
\q2 si obaasaayyu. 
\q1  
\v 3 Harki isaa bitaachi 
\q2 mataa kiyya jala adoo jiraataa; 
\q2 harki isaa middichi adoo na hanqafata. 
\q1  
\v 4 Ee, dubartoota Yerusaalemii, 
\q2 jaalalleen kiyya haga inni fedhuma ifiitiin ka'utti, 
\q2 akka isa hin dammassine, 
\q2 ani isin kadhadha. 
\s1 Faaruu Jayeesso'oo 
\sp Dubartooti Jaaloti Waajibitti'ii 
\q1  
\v 5 Ta jaalallee ifii qabattee, 
\q2 goomolee keessaa ol bayiisatti jirtu tun eennu? 
\sp Waajibittii 
\q1 Ani muka appili'ii jalaa si kaase; 
\q2 haati teeti achitti ulfoottee, 
\q2 isiin achitti ciniinsifattee si deette. 
\q1  
\v 6 Akka chaappa'aatitti gadhaa keeti keessatti, 
\q2 irree teeti irralle'etti na mallatteeffadhu. 
\q1 Jaalalli akka du'aa jabaata; 
\q2 hinaaffaalle akka boolla awwaalaa jabaatti. 
\q1 Bobeenni isi'ii akka bobe'a ibiddaa, 
\q2 ka tallisuu ti. 
\q1  
\v 7 Bisaan guddaan 
\q2 ibidda jaalalaa dhaanfuu hin dande'u; 
\q2 lolaan haree hin dande'u. 
\q1 Nami tokko qabeenna mana ifii mara 
\q2 jaalalaaf yoo kenne, 
\q2 ijjumaa hin tuffatama. 
\sp Obboleeyyan Waajibitti'ii 
\q1  
\v 8 Nuuti obboleettii diqqittii, 
\q2 guntuta hin baasin takka qanna. 
\q1 Guyyaa isii kadhatane, 
\q2 nuuti maan goona laati? 
\q1  
\v 9 Adoo isiin dalleyaa dhaka'aa teetee, 
\q2 xelleephoo meeti'ii isii irratti hin ijaarra; 
\q2 adoo isiin balbala teetee, 
\q2 saanqaa hindheensaatiin hin cunna. 
\sp Waajibittii 
\q1  
\v 10 Ani dalleya dhaka'aa ti; 
\q2 harmi kiyya xelleephoo fakkaata; 
\q2 ani ila isaa duratti nama nageya isaaf fidu te'e. 
\q1  
\v 11 Solomoon Ba'aal-Hamoon keessaa 
\q2 oorruu muka woyni'ii qabaayyu. 
\q1 Oorruu muka woyni'ii san worra eegutti kireesse; 
\q2 tokko tokkoon isaanii 
\q2 gatii midhaan woyni'iitiif, 
\q2 meetii kuma tokko tokko fidaniiyyu. 
\q1  
\v 12 Oorruun muka woyni'ii tiyya, tiyyuma; 
\q2 ee Solomoon, ati kuma fudhadhu; 
\q2 worri oorruu muka woyni'ii eegulle 
\q2 dhibba lama fudhatuu ti. 
\sp Waajibichi 
\q1  
\v 13 Ee, ati ta oorruu keessa leetu, 
\q2 jaaloti tiyya qoonqoo teeti caqasiisatti jiran; 
\q2 anille qoonqoo teeti dhage'uu ti. 
\sp Waajibittii 
\q1  
\v 14 Jaalallee kiyya, dafii koy! 
\q2 Akka jiliba'aa yookiin akka ilmoolee gadansaa 
\q2 gaara uddowaan itti latu irraa utaalii koy!