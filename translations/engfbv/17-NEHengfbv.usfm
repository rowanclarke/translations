\p 
\v 15 \w When|strong="H3318"\w* \w our|strong="H3318"\w* enemies discovered \w that|strong="H6213"\w* \w we|strong="H3068"\w* knew \w about|strong="H6213"\w* \w their|strong="H2388"\w* \w plan|strong="H5927"\w*, \w and|strong="H2388"\w* \w that|strong="H6213"\w* God \w had|strong="H6213"\w* foiled \w it|strong="H6213"\w*, \w we|strong="H3068"\w* \w all|strong="H6213"\w* \w went|strong="H3318"\w* \w back|strong="H5927"\w* \w to|strong="H5704"\w* \w our|strong="H3318"\w* \w work|strong="H4399"\w* \w on|strong="H4399"\w* \w the|strong="H6213"\w* wall.
