\v 43 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* decaído \w e|strong="H3068"\w* irritado, \w y|strong="H5921"\w* \w llegó|strong="H3212"\w* \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w*.
\c 21
\s1 El crimen de Jezabel por el viñedo de Nabot
\p 
\v 1 \w Después|strong="H1961"\w* \w de|strong="H1697"\w* estas \w cosas|strong="H1697"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H1697"\w* Nabot \w jezreelita|strong="H3158"\w* \w tenía|strong="H1961"\w* un viñedo en \w Jezreel|strong="H3157"\w*, junto \w al|strong="H4428"\w* palacio \w de|strong="H1697"\w* Acab, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Samaria|strong="H8111"\w*.
\v 2 \w Y|strong="H3068"\w* Acab \w habló|strong="H1696"\w* \w a|strong="H3068"\w* Nabot: \w Dame|strong="H5414"\w* tu viñedo \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H4480"\w* sirva \w como|strong="H3588"\w* \w huerto|strong="H1588"\w*, \w porque|strong="H3588"\w* \w está|strong="H2088"\w* junto \w a|strong="H3068"\w* \w mi|strong="H1961"\w* \w casa|strong="H1004"\w*. \w Te|strong="H5869"\w* \w daré|strong="H5414"\w* un viñedo \w mejor|strong="H2896"\w* \w que|strong="H3588"\w* \w éste|strong="H2088"\w* \w por|strong="H3588"\w* \w él|strong="H1931"\w*, \w o|strong="H3068"\w* \w si|strong="H3588"\w* \w te|strong="H5869"\w* parece \w mejor|strong="H2896"\w*, \w te|strong="H5869"\w* \w lo|strong="H1931"\w* compraré.
\p 
\v 3 Pero Nabot dijo \w a|strong="H3068"\w* Acab: ¡\w Guárdeme|strong="H2486"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5414"\w* darte la \w herencia|strong="H5159"\w* \w de|strong="H5414"\w* \w mis|strong="H5414"\w* antepasados!
\p 
\v 4 Acab \w fue|strong="H3808"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* decaído \w y|strong="H5921"\w* enfadado \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w que|strong="H3808"\w* Nabot \w jezreelita|strong="H3158"\w* \w le|strong="H5921"\w* \w habló|strong="H1696"\w*, pues \w él|strong="H5921"\w* \w le|strong="H5921"\w* \w dijo|strong="H1696"\w*: ¡\w No|strong="H3808"\w* \w te|strong="H5921"\w* \w daré|strong="H5414"\w* \w la|strong="H5921"\w* \w herencia|strong="H5159"\w* \w de|strong="H5921"\w* \w mis|strong="H5414"\w* antepasados! \w Y|strong="H3068"\w* \w se|strong="H5921"\w* acostó \w en|strong="H5921"\w* su \w cama|strong="H4296"\w*, \w volvió|strong="H5414"\w* su \w rostro|strong="H6440"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* quiso comer \w pan|strong="H3899"\w*.
\p 
\v 5 Su esposa Jezabel fue \w a|strong="H3068"\w* él y le preguntó: ¿\w Por|strong="H2088"\w* \w qué|strong="H4100"\w* \w está|strong="H2088"\w* tan decaído tu \w espíritu|strong="H7307"\w* y \w no|strong="H4100"\w* comes \w pan|strong="H3899"\w*?
\p 
\v 6 \w Y|strong="H3068"\w* \w él|strong="H3588"\w* le respondió: \w Porque|strong="H3588"\w* \w hablé|strong="H1696"\w* \w con|strong="H3588"\w* Nabot \w jezreelita|strong="H3158"\w*, \w y|strong="H3588"\w* le \w dije|strong="H1696"\w*: Véndeme tu viñedo, \w o|strong="H3068"\w* \w si|strong="H3588"\w* \w te|strong="H3588"\w* parece mejor, \w te|strong="H3588"\w* \w daré|strong="H5414"\w* otro viñedo \w por|strong="H3588"\w* \w él|strong="H3588"\w*. \w Y|strong="H3068"\w* \w me|strong="H3588"\w* contestó: \w No|strong="H3808"\w* \w te|strong="H3588"\w* venderé mi viñedo.
\p 
\v 7 \w Y|strong="H3068"\w* su esposa Jezabel \w le|strong="H5921"\w* preguntó: ¿Eres \w tú|strong="H6213"\w* \w ahora|strong="H6258"\w* \w rey|strong="H6213"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*? ¡\w Levántate|strong="H6965"\w*, come \w pan|strong="H3899"\w* \w y|strong="H5921"\w* alégrese \w tu|strong="H6213"\w* \w corazón|strong="H3820"\w*! ¡\w Yo|strong="H6213"\w* \w te|strong="H5921"\w* \w daré|strong="H5414"\w* \w el|strong="H5921"\w* viñedo \w de|strong="H5921"\w* Nabot \w jezreelita|strong="H3158"\w*!
\p 
\v 8 Entonces ella \w escribió|strong="H3789"\w* \w cartas|strong="H5612"\w* en \w nombre|strong="H8034"\w* de Acab, las selló con \w el|strong="H3427"\w* anillo de \w él|strong="H3427"\w* y las \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* y nobles que \w vivían|strong="H3427"\w* con Nabot en su \w ciudad|strong="H5892"\w*.
\v 9 \w Y|strong="H3068"\w* en las \w cartas|strong="H5612"\w* dijo: Proclamen \w ayuno|strong="H6685"\w* y busquen \w que|strong="H5971"\w* Nabot \w se|strong="H5971"\w* siente frente al \w pueblo|strong="H5971"\w*,
