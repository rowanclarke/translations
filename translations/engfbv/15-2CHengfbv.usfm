\p
\v 3 \w The|strong="H1129"\w* \w size|strong="H4060"\w* \w of|strong="H1004"\w* \w the|strong="H1129"\w* \w foundation|strong="H3245"\w* \w Solomon|strong="H8010"\w* \w laid|strong="H3245"\w* \w for|strong="H1004"\w* \w the|strong="H1129"\w* \w Temple|strong="H1004"\w* \w of|strong="H1004"\w* God \w was|strong="H1004"\w* \w sixty|strong="H8346"\w* cubits long \w and|strong="H6242"\w* \w twenty|strong="H6242"\w* cubits \w wide|strong="H7341"\w* (according \w to|strong="H1004"\w* \w the|strong="H1129"\w* \w old|strong="H7223"\w* cubit \w measurement|strong="H4060"\w*).  
\v 4 \w The|strong="H6440"\w* \w front|strong="H6440"\w* porch \w that|strong="H1004"\w* ran \w across|strong="H5921"\w* \w the|strong="H6440"\w* \w width|strong="H7341"\w* \w of|strong="H1004"\w* \w the|strong="H6440"\w* \w Temple|strong="H1004"\w* \w was|strong="H1004"\w* \w twenty|strong="H6242"\w* cubits \w long|strong="H6440"\w* \w and|strong="H3967"\w* \w twenty|strong="H6242"\w*\f + \fr 3:4 \ft The Hebrew reads “one hundred and twenty” but this is surely a scribal error, since the height of the main Temple according to \xt 1 Kings 6:2\ft  was 30 cubits.\f* cubits \w high|strong="H1363"\w*. \w He|strong="H1004"\w* \w covered|strong="H6823"\w* \w the|strong="H6440"\w* \w inside|strong="H1004"\w* \w of|strong="H1004"\w* \w the|strong="H6440"\w* porch \w with|strong="H1004"\w* \w pure|strong="H2889"\w* \w gold|strong="H2091"\w*.  
\v 5 \w He|strong="H1004"\w* paneled \w the|strong="H5921"\w* \w main|strong="H1419"\w* \w room|strong="H1004"\w* \w with|strong="H1004"\w* \w cypress|strong="H1265"\w* \w overlaid|strong="H2645"\w* \w with|strong="H1004"\w* \w fine|strong="H2896"\w* \w gold|strong="H2091"\w*, \w with|strong="H1004"\w* images \w of|strong="H1004"\w* \w palm|strong="H8561"\w* \w trees|strong="H6086"\w* \w and|strong="H1419"\w* \w chains|strong="H8333"\w*.  
\v 6 \w He|strong="H1004"\w* decorated \w the|strong="H6823"\w* \w Temple|strong="H1004"\w* \w with|strong="H1004"\w* \w beautiful|strong="H8597"\w* gems, \w and|strong="H1004"\w* \w with|strong="H1004"\w* \w gold|strong="H2091"\w* \w he|strong="H1004"\w* imported \w from|strong="H2091"\w* \w Parvaim|strong="H6516"\w*.  
\v 7 \w He|strong="H1004"\w* \w covered|strong="H2645"\w* \w the|strong="H5921"\w* \w beams|strong="H6982"\w*, \w thresholds|strong="H5592"\w*, \w walls|strong="H7023"\w*, \w and|strong="H1004"\w* \w doors|strong="H1817"\w* \w of|strong="H1004"\w* \w the|strong="H5921"\w* \w Temple|strong="H1004"\w* \w with|strong="H1004"\w* \w gold|strong="H2091"\w*, \w and|strong="H1004"\w* \w he|strong="H1004"\w* \w carved|strong="H6605"\w* \w cherubim|strong="H3742"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w walls|strong="H7023"\w*.   
\p
