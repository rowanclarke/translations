\v 2 \w Los|strong="G3588"\w* \w principales|strong="G4413"\w* sacerdotes \w y|strong="G2532"\w* \w los|strong="G3588"\w* \w judíos|strong="G2453"\w* \w más|strong="G2532"\w* importantes \w le|strong="G2596"\w* presentaron demanda \w contra|strong="G2596"\w* \w Pablo|strong="G3972"\w*. \w Le|strong="G2596"\w* \w rogaban|strong="G3870"\w*  
\v 3 \w un|strong="G3588"\w* favor \w contra|strong="G2596"\w* \w él|strong="G3588"\w*: \w que|strong="G3588"\w* \w lo|strong="G3588"\w* trasladara \w a|strong="G1519"\w* Jerusalén. \w Le|strong="G2596"\w* estaban preparando \w una|strong="G3588"\w* emboscada \w para|strong="G1519"\w* matarlo \w en|strong="G1519"\w* \w el|strong="G3588"\w* \w camino|strong="G3598"\w*.   
