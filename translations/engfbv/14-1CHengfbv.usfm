\v 24 Tahath \w his|strong="H5921"\w* \w son|strong="H1121"\w*, Uriel \w his|strong="H5921"\w* \w son|strong="H1121"\w*, Uzziah \w his|strong="H5921"\w* \w son|strong="H1121"\w* \w and|strong="H1121"\w* Shaul \w his|strong="H5921"\w* \w son|strong="H1121"\w*.
\p 
\v 25 \w The|strong="H1121"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* Elkanah: Amasai, Ahimoth,
\v 26 Elkanah \w his|strong="H2226"\w* \w son|strong="H1121"\w*, Zophai \w his|strong="H2226"\w* \w son|strong="H1121"\w*, Nahath \w his|strong="H2226"\w* \w son|strong="H1121"\w*,
