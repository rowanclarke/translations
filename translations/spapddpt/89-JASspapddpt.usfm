\s1 Un Dios compasivo y misericordioso  
\p
\v 7 \w Por|strong="G1909"\w* \w tanto|strong="G2193"\w*, hermanos, tengan \w paciencia|strong="G3114"\w* \w hasta|strong="G2193"\w* \w la|strong="G3588"\w* \w venida|strong="G3952"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*. Observen \w cómo|strong="G2532"\w* \w el|strong="G3588"\w* \w labrador|strong="G1092"\w* \w espera|strong="G1551"\w* \w con|strong="G1909"\w* \w paciencia|strong="G3114"\w* \w el|strong="G3588"\w* \w precioso|strong="G5093"\w* \w fruto|strong="G2590"\w* \w de|strong="G1909"\w* \w la|strong="G3588"\w* \w tierra|strong="G1093"\w* \w hasta|strong="G2193"\w* \w que|strong="G3588"\w* llegue \w la|strong="G3588"\w* lluvia \w temprana|strong="G4406"\w* \w y|strong="G2532"\w* \w tardía|strong="G3797"\w*.  
\v 8 Sean pacientes. Fortalezcan \w sus|strong="G3588"\w* \w corazones|strong="G2588"\w*, \w porque|strong="G3754"\w* \w la|strong="G3588"\w* \w venida|strong="G3952"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w está|strong="G3588"\w* \w cerca|strong="G1448"\w*.   
