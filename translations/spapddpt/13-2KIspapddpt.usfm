\v 18 \w Anduvo|strong="H3212"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w reyes|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w como|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* Acab, \w pues|strong="H3588"\w* \w su|strong="H3588"\w* esposa \w fue|strong="H1961"\w* una \w hija|strong="H1323"\w* \w de|strong="H3588"\w* Acab, \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*.
\v 19 Pero \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* quiso \w destruir|strong="H7843"\w* \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* causa \w de|strong="H1121"\w* su esclavo \w David|strong="H1732"\w*, pues prometió \w darle|strong="H5414"\w* \w a|strong="H3068"\w* \w él|strong="H3605"\w* y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* una \w lámpara|strong="H5216"\w* \w para|strong="H4616"\w* \w siempre|strong="H3605"\w*.
