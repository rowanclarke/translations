\v 8  \w He|strong="H5414"\w* \w also|strong="H4428"\w* \w gave|strong="H5414"\w* \w him|strong="H5414"\w* \w a|strong="H3068"\w* written \w copy|strong="H6572"\w* \w of|strong="H4428"\w* \w the|strong="H6440"\w* \w law|strong="H1881"\w* \w that|strong="H5971"\w* \w had|strong="H4428"\w* \w been|strong="H5046"\w* disseminated \w in|strong="H5921"\w* \w Susa|strong="H7800"\w* \w for|strong="H5921"\w* \w their|strong="H5414"\w* \w destruction|strong="H8045"\w* \w so|strong="H5414"\w* \w that|strong="H5971"\w* \w he|strong="H5414"\w* \w could|strong="H5971"\w* \w show|strong="H7200"\w* \w it|strong="H5414"\w* \w to|strong="H5921"\w* Esther \w and|strong="H4428"\w* \w talk|strong="H5046"\w* \w to|strong="H5921"\w* \w her|strong="H5414"\w* \w about|strong="H5921"\w* \w it|strong="H5414"\w*. \w He|strong="H5414"\w* \w also|strong="H4428"\w* \w gave|strong="H5414"\w* \w instructions|strong="H6680"\w* \w that|strong="H5971"\w* \w she|strong="H5921"\w* \w should|strong="H4428"\w* \w go|strong="H5971"\w* \w to|strong="H5921"\w* \w the|strong="H6440"\w* \w king|strong="H4428"\w* \w to|strong="H5921"\w* \w implore|strong="H2603"\w* \w him|strong="H5414"\w* \w and|strong="H4428"\w* petition \w him|strong="H5414"\w* \w on|strong="H5921"\w* \w behalf|strong="H5921"\w* \w of|strong="H4428"\w* \w her|strong="H5414"\w* \w people|strong="H5971"\w*.  
\v 9  \w So|strong="H1697"\w* \w Hathach|strong="H2047"\w* returned \w and|strong="H1697"\w* \w related|strong="H5046"\w* \w Mordecai|strong="H4782"\w*’s \w instructions|strong="H1697"\w* \w to|strong="H1697"\w* Esther.   
\p
\v 10  \w Then|strong="H6680"\w* Esther replied \w to|strong="H6680"\w* \w Hathach|strong="H2047"\w* with \w instructions|strong="H6680"\w* \w for|strong="H4782"\w* \w Mordecai|strong="H4782"\w*:  
\v 11 “\w All|strong="H3605"\w* \w the|strong="H3605"\w* \w servants|strong="H5650"\w* \w of|strong="H4428"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w and|strong="H4428"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w of|strong="H4428"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*’s \w provinces|strong="H4082"\w* \w know|strong="H3045"\w* \w that|strong="H3045"\w* \w there|strong="H2088"\w* \w is|strong="H2088"\w* \w only|strong="H3605"\w* \w one|strong="H2088"\w* \w law|strong="H1881"\w* \w applicable|strong="H4191"\w* \w to|strong="H4191"\w* \w any|strong="H3605"\w* \w man|strong="H4191"\w* \w or|strong="H3808"\w* \w woman|strong="H2088"\w* \w who|strong="H3605"\w* \w comes|strong="H3117"\w* \w uninvited|strong="H3447"\w* \w to|strong="H4191"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w in|strong="H4428"\w* \w the|strong="H3605"\w* \w inner|strong="H6442"\w* \w court|strong="H2691"\w* – \w that|strong="H3045"\w* \w person|strong="H3045"\w* \w will|strong="H4428"\w* \w be|strong="H4191"\w* \w put|strong="H4191"\w* \w to|strong="H4191"\w* \w death|strong="H4191"\w*, \w unless|strong="H3808"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* extends \w to|strong="H4191"\w* \w him|strong="H7121"\w* \w the|strong="H3605"\w* \w gold|strong="H2091"\w* \w scepter|strong="H8275"\w*, permitting \w him|strong="H7121"\w* \w to|strong="H4191"\w* \w be|strong="H4191"\w* \w spared|strong="H2421"\w*. \w Now|strong="H3117"\w* \w I|strong="H3117"\w* \w have|strong="H5971"\w* \w not|strong="H3808"\w* \w been|strong="H5971"\w* \w invited|strong="H7121"\w* \w to|strong="H4191"\w* \w come|strong="H2421"\w* \w to|strong="H4191"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w for|strong="H7121"\w* \w some|strong="H3117"\w* \w thirty|strong="H7970"\w* \w days|strong="H3117"\w*!”   
\p
\v 12  When Esther’s \w reply|strong="H1697"\w* \w was|strong="H1697"\w* \w conveyed|strong="H1697"\w* \w to|strong="H1697"\w* \w Mordecai|strong="H4782"\w*,  
\v 13  \w he|strong="H3605"\w* said \w to|strong="H7725"\w* \w take|strong="H7725"\w* \w back|strong="H7725"\w* \w this|strong="H7725"\w* \w answer|strong="H7725"\w* \w to|strong="H7725"\w* Esther:  
\v 14 “Don’t \w imagine|strong="H2790"\w* \w that|strong="H3588"\w* \w because|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H4310"\w* part \w of|strong="H1004"\w* \w the|strong="H3588"\w* king’s \w household|strong="H1004"\w* \w you|strong="H3588"\w* \w will|strong="H4310"\w* \w be|strong="H1004"\w* \w the|strong="H3588"\w* \w one|strong="H3588"\w* \w Jew|strong="H3064"\w* \w who|strong="H4310"\w* \w will|strong="H4310"\w* escape. \w If|strong="H3588"\w* \w you|strong="H3588"\w* \w keep|strong="H2790"\w* \w quiet|strong="H2790"\w* \w at|strong="H1004"\w* \w this|strong="H2063"\w* \w time|strong="H6256"\w*, \w liberation|strong="H7305"\w* \w and|strong="H1004"\w* protection \w for|strong="H3588"\w* \w the|strong="H3588"\w* \w Jews|strong="H3064"\w* \w will|strong="H4310"\w* appear \w from|strong="H3064"\w* another \w source|strong="H4725"\w*, \w while|strong="H3588"\w* \w you|strong="H3588"\w* \w and|strong="H1004"\w* \w your|strong="H3045"\w* father’s \w household|strong="H1004"\w* perish. \w It|strong="H3588"\w* \w may|strong="H4310"\w* \w very|strong="H3045"\w* \w well|strong="H3045"\w* \w be|strong="H1004"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w have|strong="H3045"\w* achieved \w royal|strong="H4438"\w* \w status|strong="H6256"\w* \w for|strong="H3588"\w* \w such|strong="H2063"\w* \w a|strong="H3068"\w* \w time|strong="H6256"\w* \w as|strong="H3588"\w* \w this|strong="H2063"\w*!”   
\p
\v 15  \w Then|strong="H7725"\w* Esther \w sent|strong="H7725"\w* \w this|strong="H7725"\w* \w reply|strong="H7725"\w* \w to|strong="H7725"\w* \w Mordecai|strong="H4782"\w*:  
\v 16 “\w Go|strong="H3212"\w*, \w assemble|strong="H3664"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w Jews|strong="H3064"\w* \w who|strong="H3605"\w* \w are|strong="H3117"\w* \w found|strong="H4672"\w* \w in|strong="H5921"\w* \w Susa|strong="H7800"\w* \w and|strong="H4428"\w* \w fast|strong="H6684"\w* \w in|strong="H5921"\w* \w my|strong="H3605"\w* \w behalf|strong="H5921"\w*. Don’t eat \w and|strong="H4428"\w* don’t \w drink|strong="H8354"\w* \w for|strong="H5921"\w* \w three|strong="H7969"\w* \w days|strong="H3117"\w*, \w night|strong="H3915"\w* \w or|strong="H3808"\w* \w day|strong="H3117"\w*. \w My|strong="H3605"\w* \w female|strong="H5291"\w* attendants \w and|strong="H4428"\w* \w I|strong="H3117"\w* \w will|strong="H4428"\w* \w also|strong="H1571"\w* \w fast|strong="H6684"\w* \w in|strong="H5921"\w* \w the|strong="H3605"\w* \w same|strong="H3651"\w* \w way|strong="H3212"\w*. Afterward \w I|strong="H3117"\w* \w will|strong="H4428"\w* \w go|strong="H3212"\w* \w to|strong="H3212"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*, \w even|strong="H1571"\w* \w though|strong="H1571"\w* \w it|strong="H5921"\w* violates \w the|strong="H3605"\w* \w law|strong="H1881"\w*. \w If|strong="H3651"\w* \w I|strong="H3117"\w* perish, \w I|strong="H3117"\w* perish!”   
\p
\v 17  \w So|strong="H6213"\w* \w Mordecai|strong="H4782"\w* \w set|strong="H6213"\w* \w out|strong="H5921"\w* \w to|strong="H6213"\w* \w do|strong="H6213"\w* \w everything|strong="H3605"\w* \w that|strong="H3605"\w* Esther \w had|strong="H4782"\w* \w instructed|strong="H6680"\w* \w him|strong="H5921"\w*.   
\c 5  
\p
\v 1  \w It|strong="H5921"\w* \w so|strong="H1961"\w* \w happened|strong="H1961"\w* \w that|strong="H3117"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w third|strong="H7992"\w* \w day|strong="H3117"\w* Esther \w put|strong="H3847"\w* \w on|strong="H5921"\w* \w her|strong="H5921"\w* \w royal|strong="H4438"\w* attire \w and|strong="H4428"\w* \w stood|strong="H5975"\w* \w in|strong="H3427"\w* \w the|strong="H5921"\w* \w inner|strong="H6442"\w* \w court|strong="H2691"\w* \w of|strong="H4428"\w* \w the|strong="H5921"\w* \w palace|strong="H1004"\w*, \w opposite|strong="H5227"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w*’s \w quarters|strong="H1004"\w*. \w The|strong="H5921"\w* \w king|strong="H4428"\w* \w was|strong="H1961"\w* \w sitting|strong="H3427"\w* \w on|strong="H5921"\w* \w his|strong="H5921"\w* \w royal|strong="H4438"\w* \w throne|strong="H3678"\w* \w in|strong="H3427"\w* \w the|strong="H5921"\w* \w palace|strong="H1004"\w*, \w opposite|strong="H5227"\w* \w the|strong="H5921"\w* \w entrance|strong="H6607"\w*.  
\v 2  \w When|strong="H1961"\w* \w the|strong="H7200"\w* \w king|strong="H4428"\w* \w saw|strong="H7200"\w* \w Queen|strong="H4436"\w* Esther \w standing|strong="H5975"\w* \w in|strong="H4428"\w* \w the|strong="H7200"\w* \w court|strong="H2691"\w*, she \w met|strong="H5375"\w* \w with|strong="H3027"\w* \w his|strong="H5375"\w* approval. \w The|strong="H7200"\w* \w king|strong="H4428"\w* \w extended|strong="H1961"\w* \w to|strong="H1961"\w* Esther \w the|strong="H7200"\w* \w gold|strong="H2091"\w* \w scepter|strong="H8275"\w* \w that|strong="H7200"\w* \w was|strong="H1961"\w* \w in|strong="H4428"\w* \w his|strong="H5375"\w* \w hand|strong="H3027"\w*, \w and|strong="H4428"\w* Esther \w approached|strong="H7126"\w* \w and|strong="H4428"\w* \w touched|strong="H5060"\w* \w the|strong="H7200"\w* end \w of|strong="H4428"\w* \w the|strong="H7200"\w* \w scepter|strong="H8275"\w*.   
\p
\v 3  \w The|strong="H5414"\w* \w king|strong="H4428"\w* said \w to|strong="H5704"\w* \w her|strong="H5414"\w*, “\w What|strong="H4100"\w* \w is|strong="H4100"\w* \w on|strong="H5414"\w* \w your|strong="H5414"\w* mind, \w Queen|strong="H4436"\w* Esther? \w What|strong="H4100"\w* \w is|strong="H4100"\w* \w your|strong="H5414"\w* \w request|strong="H1246"\w*? \w Even|strong="H5704"\w* \w as|strong="H5704"\w* \w much|strong="H4100"\w* \w as|strong="H5704"\w* \w half|strong="H2677"\w* \w the|strong="H5414"\w* \w kingdom|strong="H4438"\w* \w will|strong="H4428"\w* \w be|strong="H5414"\w* \w given|strong="H5414"\w* \w to|strong="H5704"\w* \w you|strong="H5414"\w*!”   
\p
\v 4  Esther replied, “If \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w is|strong="H3117"\w* \w so|strong="H6213"\w* inclined, let \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w and|strong="H4428"\w* \w Haman|strong="H2001"\w* come \w today|strong="H3117"\w* \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w banquet|strong="H4960"\w* \w that|strong="H3117"\w* \w I|strong="H3117"\w* \w have|strong="H3117"\w* \w prepared|strong="H6213"\w* \w for|strong="H5921"\w* \w him|strong="H5921"\w*.”  
\v 5  \w The|strong="H6213"\w* \w king|strong="H4428"\w* replied, “Find \w Haman|strong="H2001"\w* \w quickly|strong="H4116"\w* \w so|strong="H6213"\w* \w that|strong="H1697"\w* \w we|strong="H3068"\w* \w can|strong="H6213"\w* \w do|strong="H6213"\w* \w as|strong="H1697"\w* Esther \w requests|strong="H1697"\w*.”  
\p \w So|strong="H6213"\w* \w the|strong="H6213"\w* \w king|strong="H4428"\w* \w and|strong="H4428"\w* \w Haman|strong="H2001"\w* \w went|strong="H4428"\w* \w to|strong="H6213"\w* \w the|strong="H6213"\w* \w banquet|strong="H4960"\w* \w that|strong="H1697"\w* Esther \w had|strong="H4428"\w* \w prepared|strong="H6213"\w*.  
\v 6  \w While|strong="H5704"\w* \w at|strong="H4428"\w* \w the|strong="H5414"\w* \w banquet|strong="H4960"\w* \w of|strong="H4428"\w* \w wine|strong="H3196"\w*, \w the|strong="H5414"\w* \w king|strong="H4428"\w* said \w to|strong="H5704"\w* Esther, “\w What|strong="H4100"\w* \w is|strong="H4100"\w* \w your|strong="H5414"\w* \w request|strong="H1246"\w*? \w It|strong="H5414"\w* \w shall|strong="H4428"\w* \w be|strong="H5414"\w* \w given|strong="H5414"\w* \w to|strong="H5704"\w* \w you|strong="H5414"\w*. \w What|strong="H4100"\w* \w is|strong="H4100"\w* \w your|strong="H5414"\w* \w petition|strong="H7596"\w*? \w Ask|strong="H4428"\w* \w for|strong="H5704"\w* \w as|strong="H5704"\w* \w much|strong="H4100"\w* \w as|strong="H5704"\w* \w half|strong="H2677"\w* \w the|strong="H5414"\w* \w kingdom|strong="H4438"\w*, \w and|strong="H4428"\w* \w it|strong="H5414"\w* \w shall|strong="H4428"\w* \w be|strong="H5414"\w* \w done|strong="H6213"\w*!”   
\p
\v 7  Esther \w responded|strong="H6030"\w*, “\w My|strong="H6030"\w* \w request|strong="H1246"\w* \w and|strong="H6030"\w* \w my|strong="H6030"\w* \w petition|strong="H7596"\w* is this:  
