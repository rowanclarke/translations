\v 16 \w De|strong="H5921"\w* \w la|strong="H5921"\w* manera \w que|strong="H3588"\w* vosotros \w bebisteis|strong="H8354"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w santo|strong="H6944"\w* \w monte|strong="H2022"\w*, \w beberán|strong="H8354"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w gentes|strong="H1471"\w* \w de|strong="H5921"\w* \w con|strong="H5921"\w*­tinuo: \w beberán|strong="H8354"\w*, \w y|strong="H3588"\w* engullirán, \w y|strong="H3588"\w* \w serán|strong="H1961"\w* \w como|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w* hubieran \w sido|strong="H1961"\w*.   
