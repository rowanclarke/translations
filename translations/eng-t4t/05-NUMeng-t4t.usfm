\p 
\v 13 \w So|strong="H4872"\w* \w Moses|strong="H4872"\w*/\w I|strong="H3068"\w* \w cried|strong="H6817"\w* \w out|strong="H6817"\w* \w to|strong="H3068"\w* \w Yahweh|strong="H3068"\w*, saying, “\w God|strong="H3068"\w*, \w I|strong="H3068"\w* plead \w with|strong="H3068"\w* \w you|strong="H4994"\w* \w to|strong="H3068"\w* \w heal|strong="H7495"\w* her!”
\p 
\v 14 \w But|strong="H3808"\w* \w Yahweh|strong="H3068"\w* replied, “If \w her|strong="H5462"\w* father \w had|strong="H3068"\w* \add rebuked her for doing something wrong by\add* spitting \w in|strong="H3068"\w* \w her|strong="H5462"\w* \w face|strong="H6440"\w*, \w she|strong="H6440"\w* \w would|strong="H3068"\w* \w have|strong="H3068"\w* \w been|strong="H3068"\w* \w ashamed|strong="H3637"\w* \w for|strong="H6440"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*. \add She should be ashamed because of what she has done\add*. \w So|strong="H3808"\w* send \w her|strong="H5462"\w* \w outside|strong="H2351"\w* \w the|strong="H6440"\w* \w camp|strong="H4264"\w* \w for|strong="H6440"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*. \w Then|strong="H4872"\w* \add she will not have leprosy any more, and\add* \w she|strong="H6440"\w* \w may|strong="H3068"\w* return \w to|strong="H3068"\w* \w the|strong="H6440"\w* \w camp|strong="H4264"\w*.”
\v 15 \w So|strong="H3808"\w* \w they|strong="H3117"\w* sent \w her|strong="H5462"\w* \w outside|strong="H2351"\w* \w the|strong="H3117"\w* \w camp|strong="H4264"\w* \w for|strong="H5704"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*. ◄\w The|strong="H3117"\w* \w people|strong="H5971"\w*/\w We|strong="H3117"\w*► \w did|strong="H5971"\w* \w not|strong="H3808"\w* \w move|strong="H5265"\w* \add to another location\add* \w until|strong="H5704"\w* \w she|strong="H3808"\w* returned.
\p 
\v 16 \w But|strong="H5971"\w* after \add she returned\add*, \w they|strong="H5971"\w*/\w we|strong="H3068"\w* \w left|strong="H5265"\w* \w Hazeroth|strong="H2698"\w* \w and|strong="H5971"\w* \w moved|strong="H5265"\w* \add north\add* \w in|strong="H2583"\w* \w the|strong="H5971"\w* \w Paran|strong="H6290"\w* \w Desert|strong="H4057"\w* \w and|strong="H5971"\w* \w set|strong="H5265"\w* up \w their|strong="H5265"\w*/\w our|strong="H5971"\w* \w tents|strong="H2583"\w* there.
\c 13
\s1 Twelve Israeli men explored Canaan
\p 
\v 1 \w Yahweh|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*,
\v 2 “\w Send|strong="H7971"\w* \w some|strong="H3605"\w* \w men|strong="H1121"\w* \w to|strong="H3478"\w* \w Canaan|strong="H3667"\w* \add land\add* \w to|strong="H3478"\w* \w explore|strong="H8446"\w* \w it|strong="H5414"\w*. \w That|strong="H3605"\w* \w is|strong="H3478"\w* \w the|strong="H3605"\w* land \w that|strong="H3605"\w* \w I|strong="H5414"\w* \w will|strong="H3478"\w* \w give|strong="H5414"\w* \w to|strong="H3478"\w* \w you|strong="H5414"\w* Israelis. \w Send|strong="H7971"\w* \w men|strong="H1121"\w* \w who|strong="H3605"\w* \w are|strong="H1121"\w* \w leaders|strong="H5387"\w* \w in|strong="H3478"\w* \w their|strong="H3605"\w* \w tribes|strong="H4294"\w*.”
\p 
\v 3 \w So|strong="H7971"\w* \w Moses|strong="H4872"\w*/\w I|strong="H5921"\w* \w did|strong="H3478"\w* \w what|strong="H6310"\w* \w Yahweh|strong="H3068"\w* \w commanded|strong="H6310"\w* \w him|strong="H5921"\w*/\w me|strong="H7971"\w*. \w He|strong="H3068"\w*/\w I|strong="H5921"\w* \w sent|strong="H7971"\w* \w out|strong="H7971"\w* twelve Israeli \w men|strong="H1121"\w* \w who|strong="H3605"\w* \w were|strong="H3478"\w* \w all|strong="H3605"\w* \w leaders|strong="H7218"\w* \w of|strong="H1121"\w* \w their|strong="H3605"\w* tribes. \w He|strong="H3068"\w*/\w I|strong="H5921"\w* \w sent|strong="H7971"\w* \w them|strong="H1992"\w* \w from|strong="H5921"\w* \w their|strong="H3605"\w*/\w our|strong="H3068"\w* camp \w at|strong="H5921"\w* \w Paran|strong="H6290"\w* \w in|strong="H5921"\w* \w the|strong="H3605"\w* \w desert|strong="H4057"\w*.
