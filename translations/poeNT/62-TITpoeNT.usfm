\id TIT
\h TITO
\toc1 Tí xroon ikjin chꞌín Pablo chrꞌénhen chꞌán tí chꞌín Tito
\toc2 TITO
\toc3 Tit.
\mt1 Tí xroon ikjin chꞌín Pablo chrꞌénhen chꞌán tí chꞌín Tito
\c 1
\s1 Chꞌín Pablo nixje̱he̱ tí chꞌín Tito
\p 
\v 1 Janhan Pablo mé tꞌa̱ha̱ xra̱ Dios la ko tsíkjeyána Jesucristo kíxin tsjáko̱ha̱ tí í so sín tsíkjeyá Dios kja̱xin kíxin tsꞌitja sín tso̱nohe sín kíxin nkexrí chrókuinkáchónki sín tí nkehe chaxín.
\v 2 Ntá tsꞌejóchónhen sín tsochónta sín kjuachón jnkochríxín. Dios la xitjahya sichꞌia la kaín tí nkehe tsíchrónka chꞌán ósé tí na̱xa̱ kꞌónahya chjasintajni la mé xi̱kaha tso̱nhen.
\v 3 Ntá tí ya̱on tsíntáchro Dios la mé jie ó xiteyá la ntá kónoxín tí tan kuènte chꞌán. A̱ ntá Dios tí nkexro tsaáxinni mé kꞌue̱to̱an kíxin si̱tꞌaha̱ chꞌán xra̱ tsjàkua itén chꞌán.
\v 4 Ikjian tí xroon i chrꞌanhan jaha Tito. Tꞌíkua̱n éxí chaxín xja̱nna tí jaha kíxin yóíni tinkáchónkini Jesús. Kjuasáyé Itꞌéni Dios la ko Jesucristo tí nkexro tsaáxinni, chrókjuintayavan la ko chrókui̱konóa̱ha chꞌán la ko chrótjáha chꞌán kjuaxróxin.
\s1 Tí xra̱ sichꞌe tí chꞌín Tito chjasin Creta
\p 
\v 5 Kui̱to̱ha jaha tí isla Creta kíxin jaha chrókuétue̱nhén tí sín siín ntiha kíxin nkexrí chrókꞌuejó sín la ko chrókónoxín nkexro tsꞌe̱to̱an kuènte jnkojnko ni̱nko jnkojnko chjasin éxí tí kuétua̱nhan jaha.
\v 6 Tꞌichjánxi̱n kíxin tí nkexro tsꞌe̱to̱an xra̱ kuènte ni̱nko la jína chrókjuakꞌe kíxin kohya nkexro chrókꞌueka jie̱, la ko chróchónta jnkoko̱á ichjién la ko tí xje̱en sín chrókuinkáchónki Ìnchéni kíxin tso̱kohya nkexro chrókjuanchia jie̱ kíxin jehya tí jína tjejóchꞌe sín, la ko kja̱xin chrókójie̱hya sín.
\v 7 Mé xi̱kaha tí nkexro tsꞌáyéhe̱ tí xra̱ tsꞌe̱to̱an xra̱ kuènte ni̱nko mé tsꞌe̱to̱an nkexrí tso̱nhen xra̱ kuènte Dios la ntá tꞌichjánxi̱n ijnko nkexro tsjenka̱yáxin jína, chrókjuasinhya jie̱. La chrókjuinchehnkehya la ko chrókóninkakonhya tjoka. La ko kja̱xin jehya ijnko nkexro tókoan la ko jehya ijnko nkexro tjeyá kjuanínkaon la ko chrókóxrjíe̱nhya sín chrókjuichꞌia sín ntá chrókjuacha sín chichaon.
\v 8 Kja̱xin jína chrókjuakꞌe chꞌán kíxin tí tsjiji ijnko nkexro nto̱e chꞌán chrókjuanjon chꞌán kjuachaxin chrókjuakꞌe tí nkexro a. La ko jína chrókjuakꞌe chꞌán la ko jína chrókjuenka̱yáxin chꞌán kíxin ijnko nkexro ó tsíkjinchetjóá Dios la ko chróchónta chꞌán kjuasáyé chꞌán.
\v 9 Kja̱xin tꞌichjánxi̱n chrókuíto̱ehya chꞌán tí tan jína xráko̱he̱ chꞌán kíxin ntá jína tsja̱ko̱he̱ chꞌán í so chojni tí nkehe ntoá la kjónté nkexro tjinkakonhya tsinhin la jína chróchenka chꞌán chrókuinhin.
\p 
\v 10 Siín itsjé tí sín nínkaon mé tí sín a la mé tí sín judío la mé nixja sín éxí lo̱nti̱ sín mé xi̱kaha chꞌiyehe sín chojni.
\v 11 Tí sín a la chrókꞌuíkjehe̱ni irꞌva sín kíxin tjachròe sín nchónhya chojni kíxin tjako sín tí nkehe jehya jína kíxin chrókjuichꞌia sín chrókjuacha sín nchónhya chichaon.
\p 
\v 12 Ijnko chꞌín kuènte chjasin Creta la mé tsíchrónka chꞌán nkexrí tjejó tí sín chjasén chꞌán. Ntáchro chꞌán kíxin: “Kaín tí chojni chjasénni mé imá chꞌia sín la ko imá jie̱he sín la ko imá kóchjinka sín la ko séhe sín”, mé xi̱kaha chrónka chꞌán.
\v 13 Tí nkehé tsíchrónka chꞌán mé chaxín ntoá. Méxra̱ a̱ntsí fuerte chrókjuéntuéhé sín kíxin ntá jína chrókꞌuejó sín chróxraxinkaon sín Dios.
\v 14 Nixje̱hé sín kíxin chrókuahya sín kuenté kaín tí nkehe tsíkꞌaxrjeníxin kja tí sín judío tjako la ko chrókuitekakonhya sín tí nkehe tꞌe̱to̱an tí sín nínkakonhen tí nkehe chaxín.
\p 
\v 15 Tí sín chaxín tjóá kjuaxrexinkaon kuènte sín ntá kaín nkehe chꞌe sín la jína. A̱ ntá tí nkexro titekakonhya la tjuáhya kjuaxrexinkaon kuènte la kohya ninkehó nkehe jína tí kjuaxrexinkaon kuènte sín la kaín nkehe tjenka̱yáxin sín mé tjuáhya.
\v 16 Ntáchro sín kíxin chóxin sín Dios a̱ ntá tí tꞌikonni nkexrí chꞌe sín ó noexínni kíxin chaxínhya tíha la chꞌia sín. Jehe sín mé ntoáhya tjenka̱yáxin sín la ko jie̱he sín la ko titekakonhya sín. A̱ ntá tí xi̱kaha chꞌe sín la, ¿nkexrí chrókjuichꞌe sín tí xra̱ jína?
\c 2
\s1 Chrókjuako chꞌín Tito tí tan chaxín
\p 
\v 1 A ntá jaha chrókjuàkua éxí tí chrónka tí tan jína chaxín.
\v 2 Tjákohé tí sín ó táda kíxin chrókókoanhya sín la ko jína chrókꞌuejó sín la ko chróchónta sín kjuasáyé sín la ko chróchónta sín ijnko kjuaxrexinkaon jína la ko jína chrókuinkáchónki sín tí nkehe chaxín la ko chrótjuèhe sín kíchó sín la ko chrókónínkakonhya sín kjónté tsjasóte sín.
\v 3 A̱ ntá kja̱xin xi̱kaha tí sín ó nána la kja̱xin jína chrókꞌuejó sín la kja̱xin chrókjuinchekuáxinhya sín chrókuinkáchónki sín kjuachꞌia la ko kja̱xin chrókókoanhya sín. Chrókjua̱ko̱xi̱n sín ijnko kjuaxrexinkaon jína
\v 4 kíxin xi̱kaha chrókjua̱kue̱xi̱n sín tí chojni chjin tjarisoá a kíxin chrótjuèhe sín xìi sín la ko chrótjuèhe sín xje̱en sín
\v 5 la ko chrókjuichꞌe sín xra̱ jína la ko ntoá chrókjuenka̱yáxin sín la ko jína chrókꞌuàyakonhen sín nchia nto̱é sín la ko chrókójína sín la ko chrókuitekakonhen sín xìi sín. Tí xi̱kaha chrókjuichꞌe sín chrókjuinchexiteyá sín la kohya nkexro chrókꞌuántaxínhi̱n tí itén Dios tinkáchónkini.
\p 
\v 6 Kja̱xin xi̱kaha chrókjui̱nchexraxinkávan tí sín ntasoá kíxin jína chrókꞌuejó sín chróchónta sín kjuasáyé sín.
\v 7 Jaha mé chrókjuákoéxian sín kaín nkehe jína la ko chrókjuákohé sín kíxin ntoá chrókꞌuejó sín.
\v 8 Jaha la chrónixja tí nkehe jína kíxin kohya nkexró chrókꞌuántaxín la ntá xi̱kaha chrókósuèhe̱ tí sín nínkaon la ntá kohya nkehe jínahya chróntáchro sín kuènte tí jeheni.
\p 
\v 9 Tétue̱nhén tí sín xrichꞌexón xra̱ kíxin chrókjuinchexiteyéhe̱ sín tí lamo kuènte sín la ko chrókójína sín la ko chrónixja̱nki̱ehya sín tí nkexro chꞌehe sín xra̱
\v 10 la ko kja̱xin chrókueéhya sín kíxin jehya ijnko chojni che̱e tí jehe sín. Ntá kaín chojni chrókꞌuikon sín kíxin tja̱ko̱xi̱n sín kíxin náxrjón tí itén Dios chrókuaáxinni.
\p 
\v 11 Kíxin Dios mé kjua̱ko̱xi̱n chꞌán kíxin nkexrí tjuèheni chꞌán kíxin jehe chꞌán mé tsaáxin kaín chojni.
\v 12 Kjuasáyé Dios mé tja̱ko̱he̱ni chꞌán kíxin chrókuíto̱heni kaín nkehe jie̱ la ko kaín tí nkehe jínahya tjenka̱yáxinni. La ko jína chrókꞌuejóni chjasintajni la ko ntoá chrókꞌuejóni la ko chrókuinkáchónkini Dios.
\v 13 Kja̱xin chrókꞌuejóni jína kíxin chrókóchéhe̱ni chrókꞌuejóchónhenni tí ya̱on kjua̱cha̱xién Dios jié itsi Dios la ko Jesucristo tí nkexro tsaáxinni.
\v 14 A̱ ntá jehe chꞌán mé kꞌuenyákonhe̱nni chꞌán kíxin tjinkaon chꞌán tsaáxinni chꞌán kíxin tso̱tjuáxin kaín jie̱ chóntani kíxin ntá jeheni mé tsꞌónani ijnko chojni sichꞌehe chꞌán xra̱ la ko tso̱xrjínhi̱nni sichꞌeni kaín xra̱ jína tjinkaon chꞌán.
\p 
\v 15 Tíhi mé chrókjuàkua la ko chrókjui̱nchexraxinkávan sín la ko chrókuétue̱nhén sín kjua̱cha̱xién Dios. Chrókui̱to̱éhya kíxin ninkexró chrókókjo̱nie̱hya tí nkehe tjàkua jaha.﻿
\c 3
\s1 Jína chrókꞌuejó tí sín tinkáchónki Cristo
\p 
\v 1 Chrókjui̱nchexraxinkávan sín kíxin sinchexiteyéhe̱ sín tí gobierno la ko tsitekaon sín ichrén xra̱ tsꞌe̱to̱an tí síxre̱é kíxin chrókjuichꞌe sín kaín xra̱ jína tsꞌe̱to̱an tí sín a.
\v 2 La ko chrókꞌuántaxíe̱nhya sín ninkexró la ko kjuaxróxin chrókꞌuejó sín la ko chrókꞌóna sín ijnko chojni jína la ko chrókjua̱ko̱xi̱n sín kíxin jehya ijnko chojni nchehnke la chrókjuikosáyehe sín kaín chojni.
\p 
\v 3 Jeheni kja̱xin ósé kꞌuélo̱nti̱ni la ko kꞌuékitekakonhyani Dios. Chji̱ni kꞌuékꞌajini la kꞌuékóxrjínhi̱nni kaín nkehe jínahya. La ko jehya jína kꞌuékꞌejóni la ko kꞌuéchóntani kjuachji̱no̱xínhin la ko kꞌuéchji̱noxíenhenni í so chojni.
\v 4 A̱ ntá tí Dios tsaáxinni mé kjua̱kue̱xi̱nni chꞌán kixin jína chꞌán la ko tjuèhe chꞌán kaín chojni.
\v 5 Jehe chꞌán kuaáxinni chꞌán la jehya kíxin ichrén xra̱ jína chrókjuichꞌeheni chꞌán. Náhí, ó jehí kui̱konóe̱he̱ni chꞌán la ntá kjuínchekaáni chꞌán la ko kjuínchetjóáni chꞌán. Ntá kokjíhini ni̱xin kíxin tí Ncha̱kuen chꞌán la mé kꞌuáyèxinni kjuachón ni̱xin.
\v 6 Kjuasáyé Jesucristo tí nkexro tsaáxinni ntá kjuíncheki̱to̱nhe̱nni Dios Ncha̱kuen chꞌán kíxin tsochóntani kjuachaxin kuènté chꞌán.
\v 7 A̱ ntá xi̱kaha kjuasáyé chꞌán kjuínchetjóáni chꞌán kíxin ntá tjejóchónhenni tí kjuachón jnkochríxín tsjanjon chꞌán.
\p 
\v 8 Kaín tíha mé chaxín. Tjínka̱van kíxin jaha chrókuéto̱an kaín tíha kíxin ntá kaín tí sín tinkáchónki Dios mé chrókuitekaon sín chrókjuichꞌe sín kaín nkehe jína. Kaín tí nkehe la mé jína la ko tsjinki̱tsa kaín chojni.
\v 9 A̱ ntá jaha mé ti̱to̱hé tí sín tja̱cha̱xi̱n kíchó sín lo̱nti̱ sín la ko ti̱to̱hé tí nkehe tinkáchónki sín kuènte tí sín tsíkꞌaxrjeníxin sín la ko ti̱to̱hé tí sín tjanjo̱nxi̱n tí ley kuènte Moisés. Kaín tíha la ó chónkó la ninkehó kjuaxrexinkaon chóntahya.
\p 
\v 10 Jnkojín nkexro tjinkaon tsjixrónkáxin tí tójnkotsé ni̱nko ntiha la nixje̱hé chꞌán jnkojína senó la ko yóxin ínaá ntá tí titekakonhya chꞌán ntá ti̱to̱hé sátsji chꞌán
\v 11 kíxin ó noha kíxin tí chojni xi̱kaha a mé ntoáhya tjenka̱yáxin sín kíxin jehó sín nchekꞌánkí sín iji̱é sín.
\s1 Tí nkehe kꞌue̱to̱an chꞌín Pablo
\p 
\v 12 Tí tsétua̱nha̱n chꞌín Artemas la ko chꞌín Tíquico kíxin tsjiji sín tí tjen jaha la ntá tjoka chrókꞌuinkatsjehé tí janhan chjasin Nicópolis kíxin ntiha tsjakꞌé tsꞌatsínkajia tí ncha̱kuen kin.
\v 13 Jína chrókjuínki̱tsa jaha tí chꞌín Zenas tí chꞌín nixjayákonhe̱n í jnko chojni la ko tí chꞌín Apolos la ko chróchje̱hé sín kaín tí nkehe tꞌichjánxi̱nhin sín tió sátsji sín kíxin ninkehó nkehe chrókꞌuitjáyanhya tí tꞌichjánxi̱nhin sín.
\v 14 Ntá tí sín í so chrókꞌuitja sín nkexrí sichꞌe sín tí xra̱ jína la ko chrókjuinki̱tsa sín kíchó sín ichrén nkehe tꞌichjánxi̱nhin sín kíxin chrókjua̱ko̱xi̱n sín kíxin jína tjejó sín.
\s1 Ó kjuixixín nixja chꞌín Pablo
\p 
\v 15 Kaín tí nkexro tjéki̱an janhan ntihi nixja̱ha̱ sín jnkojína. Jaha mé nixje̱hé kaín tí sín tinkáchónki Ìnchéni ntiha mé kaín tí sín imá tjuèheni sín. Dios mé chrókjuincheyaonrá chꞌán kaín rá. Amén. Ó tjen.
