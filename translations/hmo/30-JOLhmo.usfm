\id JOL JOEL, Hiri Motu Bible, PNG, 1989, 6/90, 5/93 
\h IOELA 
\toc1 IOELA 
\toc2 IOELA 
\mt1 IOELA  
\c 1  
\s1 Taunimanima idia taitai, edia uma anina be kwadi ese idia hadikaia dainai  
\p
\v 1 Inai hereva be Lohiabada ese Ioela, Petuela ena natuna dekenai ia henia.   
\b  
\q1
\v 2 Umui buruka taudia e, kamonai!  
\q1 Iuda dekenai noho taudia e, umui kamonai!  
\q1 Umui emui nega lalonai,  
\q1 o emui tamana edia nega lalonai,  
\q1 inai bamona kara ia vara, a?   
\q1
\v 3 Emui natudia do umui hamaorolaia,  
\q1 vadaeni idia ese edia natudia do idia hamaorolaia,  
\q1 vadaeni gabeai nega idia vara bese taudia,  
\q1 be do idia hamaorolaia.   
\b  
\q1
\v 4 Kwadi orea 4 be idia toreisi,  
\q1 uma ena anina ibounai idia ania ore.  
\q1 Orea ginigunana ese idia rakatania gaudia,  
\q1 be orea iharuana ese idia ania.  
\q1 Bona orea namba 3 bona namba 4,  
\q1 ese unai bamona idia karaia,  
\q1 ela bona uma aniani ibounai idia haorea momokani.   
\b  
\q1
\v 5 Inua kekero taudia e,  
\q1 umui noga, umui taitai.  
\q1 Uaina umui inua taudia e,  
\q1 mai boiboi danu do umui tai.  
\q1 Badina be uaina matamata idia karaia diba lasi,  
\q1 kwadi ese vain huahua ibounai idia ania ore dainai.   
\b  
\q1
\v 6 Kwadi orea badana ese,  
\q1 iseda tano idia hadikaia bada herea.  
\q1 Idia be goada herea momokani,  
\q1 bona idia be momo herea.  
\q1 Idia edia isena be mai matana,  
\q1 laiona ena isena bamona.   
\q1
\v 7 Idia ese iseda vain audia idia hadikaia ore,  
\q1 bona iseda fig audia idia ania ore.  
\q1 Au edia kopina idia kokia,  
\q1 ela bona rigi ibounai idia kurokuro vadaeni.   
\b  
\q1
\v 8 Umui ibounai do umui taitai,  
\q1 kekeni ia tai bamona,  
\q1 badina ia adavaia gwauraia tauna,  
\q1 be ia mase vadaeni.   
\b  
\q1
\v 9 Paraoa ena boubou bona uaina boubou,  
\q1 be Dubu helaga dekenai idia henia diba lasi.  
\q1 Hahelagaia taudia be idia tai noho,  
\q1 badina idia be mai edia boubou gaudia lasi,  
\q1 Lohiabada dekenai do idia henia totona.   
\q1
\v 10 Uma gabu ibounai be idia noho kava,  
\q1 aniani ta idia havaraia lasi.  
\q1 Tano danu ia tai noho,  
\q1 badina be uma ena anina ia dika ore.  
\q1 Vain huahua idia kaukau vadaeni,  
\q1 bona olive audia danu idia kakoro.   
\b  
\q1
\v 11 Umui biru taudia e, do umui lalohisihisi.  
\q1 Vain umui naria taudia e,  
\q1 do umui tai bada,  
\q1 badina uiti bona bali bona tano ena anina,  
\q1 ibounai be idia dika vadaeni.   
\q1
\v 12 Vain audia bona fig audia danu idia kakoro vadaeni,  
\q1 bona au huahua idia atoa audia ibounai,  
\q1 be kaukau dainai idia mase.  
\q1 Taunimanima edia moale ia ore momokani.   
\s1 Lalona giroa totona ia boiridia  
\q1
\v 13 Hahelagaia taudia e,  
\q1 puse dabua, emui lalohisihisi ena toana,  
\q1 do umui karaia, do umui tai.  
\q1 Boubou patana umui naria noho taudia,  
\q1 do umui tai bada.  
\q1 Dubu Helaga do umui raka vareai,  
\q1 bona hanuaboi ena hora ibounai do umui tai!  
\q1 Badina be paraoa ena boubou bona uaina ena boubou,  
\q1 be emui Dirava dekenai do umui henia diba lasi.   
\q1
\v 14 Aniani ania lasi taravatu do umui gwauraia.  
\q1 Hebou helagana do umui boiria!  
\q1 Tau badadia do umui haboua,  
\q1 Iuda taudia ibounai danu.  
\q1 Lohiabada emui Dirava ena Dubu Helaga lalonai,  
\q1 do umui raka vareai,  
\q1 bona Lohiabada dekenai do umui tai henia.   
\q1
\v 15 Lohiabada ena dina be kahirakahira.  
\q1 Unai dina dekenai ia ese ita do ia hadikaia bada.  
\q1 Unai dina ese gari bada do ia havaraia.   
\b  
\q1
\v 16 Iseda uma gabudia edia aniani gaudia be do idia dika lao,  
\q1 bona ita be do ita gini kava,  
\q1 do ita hanamodia diba lasi.  
\q1 Vadaeni Dirava ena Dubu Helaga do ita vareai,  
\q1 to do ita moale diba lasi.   
\q1
\v 17 Tano be ranu lasi dainai,  
\q1 uhe be idia mase noho.  
\q1 Uiti ena anina be ia tubu lasi dainai,  
\q1 haboua rumadia be idia noho kava,  
\q1 bona idia be makohia danu.   
\q1
\v 18 Boromakau be idia hitolo bada,  
\q1 unai dainai idia boiboi noho.  
\q1 Idia raka kava, raka kava noho,  
\q1 rei be lasi dainai.  
\q1 Mamoe orea danu be madi idia hisihisi bada noho.   
\b  
\q1
\v 19 Lohiabada e, oi dekenai lau taitai inai,  
\q1 badina be uma bona rei gabudia idia kakoro vadaeni,  
\q1 lahi ese ia gabudia ore vadaeni bamona.   
\q1
\v 20 Uda boroma idauidau ese danu,  
\q1 be oi dekenai idia boiboi noho,  
\q1 badina be sinavai maragidia ibounai idia kaukau vadaeni.   
\c 2  
\s1 Kwadi be toa ta, Lohiabada ena Dina ia mai noho ena toana  
\q1
\v 1 Kibi do umui hiriria,  
\q1 gaba do umui botaia, Siona,  
\q1 Dirava ena ororo helagana dekenai.  
\q1 Iuda dekenai noho taudia e,  
\q1 mai gari danu do umui heudeheude,  
\q1 badina be Lohiabada ena dina be kahirakahira ia ginidae.   
\q1
\v 2 Inai dina be do ia dibura momokani,  
\q1 bona ori korema momokani ese guba do idia koua.  
\q1 Inai be kwadi orea bada herea,  
\q1 tuari orea badana bamona idia mai noho.  
\q1 Edia toana be, dibura ese ororo ia koua noho bamona.  
\q1 Guna be inai bamona kara nega ta ia vara lasi,  
\q1 bona gabeai danu inai bamona kara,  
\q1 be do ia vara lou lasi.   
\b  
\q1
\v 3 Ava ibounai idia ania ore,  
\q1 lahi ese ia gabua ore noho bamona.  
\q1 Idia edia vairana dekenai be uma namona, Eden hegeregerena ia noho,  
\q1 to idia edia murinai dekenai,  
\q1 idia ania ore gabuna,  
\q1 be tano kaukau bamona.  
\q1 Gau ta lasi idia dekena amo ia heau mauri diba.   
\q1
\v 4 Idia edia toana be hosi bamona.  
\q1 Idia heau noho,  
\q1 tuari hosi idia heau bamona.   
\q1
\v 5 Idia be ororo edia ataiai dekenai,  
\q1 idia roho noho neganai,  
\q1 edia regena be kariota edia regena bamona,  
\q1 bona lahi ese rei kakoro ia gabua neganai bamona.  
\q1 Idia be tuari orea goadana,  
\q1 tuari totona ia gini hegaegae noho bamona.   
\b  
\q1
\v 6 Idia mai noho neganai,  
\q1 taunimanima ibounai idia gari bada noho.  
\q1 Taunimanima ibounai edia vairana,  
\q1 edia toana be idia labora lao.   
\q1
\v 7 Tuari taudia bamona idia heau mai noho.  
\q1 Tuari taudia bamona magu idia daekau lao noho.  
\q1 Idia raka hebou maoromaoro,  
\q1 tuari taudia idia raka bamona.  
\q1 Idia edia dala dekena amo idia raka siri lasi.   
\q1
\v 8 Idia raka hebou noho,  
\q1 to ta ese ma ta ena dala ia koua lasi.  
\q1 Idia be tuari magu ibounai idia makohia diho noho,  
\q1 bona gau ta ese edia raka ia hadokoa diba lasi.   
\q1
\v 9 Hanua ena latanai idia roho lao noho.  
\q1 Hanua ena magu idia heau hanaia noho.  
\q1 Ruma ena haba dekenai idia daekau lao,  
\q1 bona uindo dekenai idia vareai,  
\q1 henaoa taudia edia kara bamona.   
\b  
\q1
\v 10 Idia raka mai noho neganai,  
\q1 tano ia mareremarere noho,  
\q1 bona guba ia heudeheude noho.  
\q1 Dina bona hua idia dibura noho.  
\q1 Hisiu be idia diaridiari lasi.   
\q1
\v 11 Lohiabada ese iena gadona ia habadaia noho.  
\q1 Iena tuari taudia ese ia idia kamonai henia,  
\q1 bona idia be momo momo herea,  
\q1 bona mai edia goada.  
\q1 Badina be Lohiabada ena dina be dina badana,  
\q1 bona mai ena gari bada.  
\q1 Inai dina dekenai be daika ese ia mauri diba?   
\s1 Dirava be taunimanima dekenai ia boiboi, edia lalona do idia giroa  
\q1
\v 12 Lohiabada ia hereva, ia gwau,  
\q1 “Momokani inai nega dika be do ia vara,  
\q1 to namona be harihari,  
\q1 emui lalona do umui giroa momokani,  
\q1 bona lau dekenai do umui giroa mai lou.  
\q1 Bona umui ese aniani lasi taravatu do umui karaia,  
\q1 bona mai lalohisihisi momokani do umui tai,  
\q1 lau dekenai do umui giroa mai totona.   
\q1
\v 13 Emui lalohisihisi hedinaraia totona,  
\q1 dabua umui darea be hegeregere lasi momokani!  
\q1 Emui kudouna do umui makohia,  
\q1 emui lalohisihisi toana hedinaraia totona!”  
\b  
\q1 Lohiabada, emui Dirava dekenai do umui giroa mai.  
\q1 Ia be mai ena bogahisihisi bada,  
\q1 bona ia be mai ena hariharibada.  
\q1 Ia be badu haraga lasi,  
\q1 bona ia ese iena gwauhamata,  
\q1 be nega ibounai ia badinaia noho.  
\q1 Ia be nega ibounai ia noho hegaegae,  
\q1 emui dika do ia gwauatao totona.  
\q1 Ia ura lasi emui dika ena davana,  
\q1 be umui dekenai do ia henia.   
\q1
\v 14 Bema Lohiabada emui Dirava dekenai umui giroa lou neganai,  
\q1 sedira ia ese iena lalona do ia haidaua,  
\q1 bona ia ese aniani momo,  
\q1 be umui dekenai do ia henia.  
\q1 Unai neganai umui ese paraoa ena boubou,  
\q1 bona uaina ena boubou do umui henia diba.   
\b  
\q1
\v 15 Siona Ororo dekenai kibi do umui hiriria.  
\q1 Aniani ania lasi taravatu do umui atoa,  
\q1 bona hebou helagana do umui boiria!   
\q1
\v 16 Taunimanima ibounai do umui haboua mai.  
\q1 Hebou helagana totona do idia noho hegaegae neganai,  
\q1 idia do umui boiria mai.  
\q1 Hanua tau badadia do umui haboua.  
\q1 Memero bona kekeni danu do umui gogoa mai,  
\q1 rata idia inua natudia danu.  
\q1 Headava matamata taudia danu,  
\q1 tau bona hahine ese,  
\q1 edia ruma ena daiutu do idia rakatania,  
\q1 hebou dekenai do idia vareai.   
\q1
\v 17 Hahelagaia taudia ese,  
\q1 Lohiabada ena gaukara Dubu Helaga lalonai idia karaia noho,  
\q1 Dubu ena iduara bona boubou patana edia huanai,  
\q1 be inai bamona do idia guriguri namo,  
\q1 do idia gwau,  
\q1 “Lohiabada e, oiemu bese,  
\q1 be mani do oi bogahisihisi henia.  
\q1 Bema ai dekenai oi bogahisihisi lasi neganai,  
\q1 bese idauidau taudia ese,  
\q1 ai dekenai do idia kirikiri, do idia gwau,  
\q1 ‘Umui emui Dirava be edeseni ia noho?’ ”   
\s1 Lohiabada ese tano dekenai aniani ia havaraia lou  
\q1
\v 18 Vadaeni Lohiabada ese iena lalona do ia giroa,  
\q1 bona iena tano dekenai do ia laloa momo,  
\q1 bona ia ese iena bese taudia dekenai do ia bogahisihisi henia.   
\b  
\q1
\v 19 Lohiabada ese idia dekenai do ia haere, do ia gwau:  
\q1 “Harihari lau ese uiti bona uaina,  
\q1 bona olive auna ena dehoro umui dekenai do lau henia,  
\q1 bona emui bogana be do idia kunu.  
\q1 Vadaeni bese idauidau ese,  
\q1 umui do idia hemarai henia lou lasi.   
\q1
\v 20 Mirigini kahana dekena amo idia mai,  
\q1 ena kwadi orea be do lau lulua lao,  
\q1 bona idia momo be tano kaukau,  
\q1 dekenai do lau siaia ore.  
\q1 Edia vairana kahana gaudia be,  
\q1 dina daekau kahana davara lalonai do idia moru,  
\q1 bona edia murinai kahana gaudia,  
\q1 be dina diho kahana davara lalonai do idia moru.  
\q1 Bona edia mase tauanidia edia bonana be bada.  
\q1 Idia ese umui idia kara dika henia dainai,  
\q1 lau ese idia do lau hadikaia ore.   
\b  
\q1
\v 21 “Tano e, do umui gari lasi.  
\q1 Do umui moale bada,  
\q1 badina lau Lohiabada ese kara badadia,  
\q1 be umui totona lau karaia vadaeni.   
\q1
\v 22 Uda boroma idauidau e,  
\q1 do umui gari lasi,  
\q1 badina be rei namona ia tubu lou.  
\q1 Au ese edia huahua ma idia atoa,  
\q1 bona fig bona vain huahua momo idia noho.   
\b  
\q1
\v 23 “Siona taudia e, do umui moale.  
\q1 Lau Lohiabada, emui Dirava ese,  
\q1 umui totona lau karaia gaudia dainai do umui moale.  
\q1 Lau ese umui dekenai,  
\q1 medu hegeregerena lau henia vadaeni,  
\q1 uhe do umui hadoa totona.  
\q1 Bona lau ese medu momo umui dekenai lau siaia vadaeni,  
\q1 guna lau siaia hegeregerena.   
\q1
\v 24 Uiti idia botaia gabudia dekenai,  
\q1 be uiti dekena amo do idia honu.  
\q1 Uaina bona olive dehoro idia moia guridia be idia honu,  
\q1 unai dainai do idia bubua kava.   
\b  
\q1
\v 25 “Lau ese unai kwadi orea umui dekenai lau siaia,  
\q1 tuari orea bamona.  
\q1 Idia ese emui aniani idia ania.  
\q1 To harihari lau ese unai lagani gunadia,  
\q1 umui dekena amo idia boio gaudia, be do lau henia lou.   
\q1
\v 26 Harihari aniani momo do umui abia,  
\q1 bona do umui boga kunu.  
\q1 Umui ese lau Lohiabada, emui Dirava do umui hanamoa henia,  
\q1 badina lau ese hoa karadia,  
\q1 be umui totona lau karaia vadaeni.  
\q1 Lauegu bese be bese haida ese,  
\q1 hemarai do idia henidia lou lasi.   
\q1
\v 27 Unai neganai, Israela e,  
\q1 umui be do umui diba,  
\q1 lau be umui emui huanai lau noho,  
\q1 bona do umui diba,  
\q1 lau Lohiabada be emui Dirava,  
\q1 dirava ma ta be lasi.  
\q1 Lauegu bese be bese haida ese,  
\q1 hemarai do idia henidia lou lasi.”   
\s1 Dirava ese iena Lauma taunimanima ibounai dekenai do ia bubua diho  
\q1
\v 28 Ma Lohiabada ia hereva lou, ia gwau,  
\q1 “Nega gabeai lau ese egu Lauma,  
\q1 be taunimanima ibounai dekenai do lau bubua diho.  
\q1 Bona emui natuna tau bona natuna hahine ese,  
\q1 egu peroveta hereva do idia gwauraia hedinarai.  
\q1 Emui tau buruka be do idia nihi,  
\q1 bona emui eregabe taudia ese,  
\q1 mata hanai do idia itaia.   
\q1
\v 29 Unai neganai danu egu Lauma,  
\q1 be hesiai taudia bona hesiai hahinedia danu,  
\q1 edia latanai do lau bubua diho.”   
\s1 Lohiabada ena Dina do ia ginidae ena toana  
\q1
\v 30 Lohiabada ma ia hereva lou, ia gwau,  
\q1 “Lau ese unai dina do ia mai ena toadia,  
\q1 be guba bona tanobada dekenai do lau atoa.  
\q1 Tanobada dekenai be tuari do idia vara,  
\q1 bona taunimanima momo edia rarana do ia bubua.  
\q1 Lahi bona kwalahu bada danu,  
\q1 be tanobada dekenai do idia vara.   
\q1
\v 31 Dina be do ia dibura,  
\q1 bona hua be do ia kakakaka lao,  
\q1 rara ena toana bamona.  
\q1 Bema inai bamona toa umui itaia neganai,  
\q1 do umui diba Lohiabada ena dina be kahirakahira.  
\q1 Unai dina badana dekenai,  
\q1 taunimanima ibounai do idia gari bada herea.   
\q1
\v 32 To durua totona Lohiabada idia noia taudia ibounai,  
\q1 ese mauri do idia davaria.  
\q1 Lau Lohiabada lau herevalaia guna vadaeni, lau gwau,  
\q1 ‘Ierusalema dekenai noho taudia haida,  
\q1 be do idia heau mauri.  
\q1 Lau ese lau abia hidi taudia ibounai,  
\q1 be do idia mauri.’ ”   
\c 3  
\s1 Dirava ese bese ibounai do ia kota henia  
\q1
\v 1 Lohiabada ia gwau,  
\q1 “Unai neganai lau ese Iuda taudia,  
\q1 bona Ierusalema taudia,  
\q1 edia noho bona edia tano do lau hanamoa lou.   
\q1
\v 2 Lau ese bese idauidau ibounai do lau haboua,  
\q1 bona koura ta, ladana be ‘Dirava be Kota Biaguna’,  
\q1 dekenai do lau hakaudia mai.  
\q1 Unuseni lau ese idia do lau kota henia,  
\q1 idia ese egu bese taudia idia dagedage henidia dainai.  
\q1 Idia ese Israela taudia idia luludia lao bese idauidau edia huanai,  
\q1 bona egu tano Israela be idia haria lao.   
\q1
\v 3 Inai bese idauidau ese laki idia gadara,  
\q1 do idia diba daika ese,  
\q1 Israela guia taudia ta ta do idia abia totona.  
\q1 Idia ese Israela memero bona kekeni,  
\q1 be guia totona idia hoia lao,  
\q1 bona moni idia davaria.  
\q1 Inai moni dekena amo,  
\q1 sihari kava hahine edia davana idia karaia,  
\q1 bona uaina idia hoia.   
\b  
\p
\v 4 “Umui Turo bona Sidono bona Pilistia kahana ibounai taudia e, umui be dahaka umui karaia gwauraia lau dekenai? Umui laloa umui dekenai lau kara dika vadaeni, bona umui ura davana lau dekenai umui henia, a? Bema inai bamona umui karaia gwauraia neganai, lau ese emui dika ena davana do lau henia haraga!   
\p
\v 5 “Umui ese lauegu siliva bona golo, bona egu kohu namodia idauidau umui abia vadaeni, bona emui dirava koikoi ena dubu helaga lalonai umui atoa vadaeni.  
\v 6 Umui ese Ierusalema taudia bona Iuda taudia umui guia, bona gabu daudau dekenai umui hakaudia lao, Helene taudia dekenai umui hoidia lao.   
\p
\v 7 “To harihari lau ese idia do lau abidia lou. Lau ese idia do lau durua, vadaeni idia ese umui hoidia lao gabudia do idia rakatania. Bona umui ese idia dekenai umui karaia karadia, be lau ese umui dekenai do lau karaia.  
\v 8 Umui emui natudia tau bona hahine be do lau hoidia lao Iuda taudia dekenai. Iuda taudia ese inai emui natudia do idia hoidia lao Sabea taudia dekenai, daudau gabuna dekenai. Lau Lohiabada ese, lau hereva vadaeni.”   
\p
\v 9 Dirava ese Ioela ia hamaoroa, bese idauidau edia huanai inai bamona do ia gwauraia:  
\b  
\q1 “Tuari totona do umui hegaegae noho.  
\q1 Emui tuari taudia do umui boiria hebou.  
\q1 Do idia raka mai,  
\q1 bona tuari hamatamaia.   
\q1
\v 10 Emui tano geia auridia edia matana,  
\q1 be do umui botaia palaka,  
\q1 tuari kaia gaudia do idia lao.  
\q1 Bona emui uma kaia badadia dekena amo,  
\q1 io do umui karaia.  
\q1 Unai neganai manoka tauna be do ia gwau,  
\q1 ‘Lau be tuari tauna.’   
\q1
\v 11 Do umui mai haraga,  
\q1 umui bese idauidau taudia.  
\q1 Kahana ibounai dekenai noho besedia e,  
\q1 koura dekenai do umui haboua mai.”  
\b  
\q1 Lohiabada e, oiemu tuari taudia do oi siaia diho,  
\q1 idia ese unai bese idauidau taudia do idia tuari henia.   
\b  
\q1
\v 12 Dirava ia hereva, ia gwau,  
\q1 “Bese idauidau taudia be,  
\q1 kota totona idia noho hegaegae namo,  
\q1 bona koura, ena ladana be ‘Dirava be Kota Biaguna’,  
\q1 dekenai do idia haboua mai.  
\q1 Unuseni lau Lohiabada be do lau helai,  
\q1 bona bese idauidau taudia ibounai,  
\q1 be do lau kota henia.   
\q1
\v 13 Idia be kara dika taudia momokani.  
\q1 Unai dainai idia do umui utua diho,  
\q1 hegeregere biru taudia ese,  
\q1 tano ena uiti magena idia utua bamona.  
\q1 Bona umui ese idia do umui moia,  
\q1 hegeregere vain huahua guri dekenai idia moia bamona,  
\q1 moia ela bona uaina ia bubua kava.”   
\b  
\q1
\v 14 Taunimanima momo momo herea,  
\q1 be “Dirava ia Kota Biaguna” ena koura dekenai do idia haboua,  
\q1 bona unuseni Lohiabada ena dina do ia ginidae.  
\q1 Unai dina be ia kahirakahira momokani.   
\q1
\v 15 Dina bona hua be do idia dibura,  
\q1 bona hisiu be do idia diaridiari lou lasi.   
\s1 Dirava ese iena bese Iuda taudia do ia hanamoa  
\q1
\v 16 Lohiabada be Siona dekena amo ia boiboi,  
\q1 Ierusalema dekena amo ia hereva noho.  
\q1 Vadaeni guba bona tanobada do idia mareremarere.  
\q1 To Lohiabada ese iena bese taudia do ia naria namonamo,  
\q1 dika do idia davaria lasi.   
\b  
\q1
\v 17 Lohiabada ia gwau,  
\q1 “Unai neganai Israela taudia e, do umui diba,  
\q1 lau sibona be Lohiabada, emui Dirava.  
\q1 Lau be Siona dekenai lau noho,  
\q1 egu ororo helagana be unai.  
\q1 Ierusalema be do ia helaga,  
\q1 bona idau bese taudia ese,  
\q1 ia do idia raka hanaia lou lasi.   
\b  
\q1
\v 18 “Unai neganai, ororo badadia dekenai,  
\q1 vain uma momo herea do idia vara noho,  
\q1 bona boromakau momo herea be,  
\q1 ororo maragidia ibounai dekenai rei do idia ania noho.  
\q1 Iuda ena sinavai bona sinavai maragidia ibounai,  
\q1 be mai edia ranu momo.  
\q1 Dubu Helaga dekena amo be ranu do ia heau mai,  
\q1 bona Akasia ena Koura dekenai ranu do ia henia.   
\b  
\q1
\v 19 “To Aigupito be tano kaukau do ia lao,  
\q1 bona Edoma ena tano be anina lasi tano do ia lao,  
\q1 taunimanima noho lasi gabuna.  
\q1 Badina inai bese ruaosi ese,  
\q1 Iuda taudia idia tuari henia,  
\q1 bona idia ese Iuda ena kerere lasi taudia idia alaia mase.   
\q1
\v 20 Lau ese unai Iuda taudia idia alaia taudia,  
\q1 edia kerere davana do lau henia.  
\q1 Lau ese unai kerere taudia,  
\q1 be do lau bogahisihisi henia lasi.   
\q1
\v 21 To Iuda bona Ierusalema dekenai,  
\q1 be taunimanima do idia noho hanaihanai,  
\q1 bona lau Lohiabada,  
\q1 be Siona Ororo dekenai do lau noho.”   