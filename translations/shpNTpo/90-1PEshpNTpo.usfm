\id 1PE - Shipibo NT with OT portions -Peru 2011 (DBL -2013)
\h 1 PEDRO
\toc1 Joi akaibo janbisaboki peokin jato Pedron kirika bomaa
\toc2 1 Pedro
\toc3 1 Ped.
\mt1 1 PEDRO
\mt2 Joi akaibo janbisaboki peokin jato Pedron kirika bomaa
\c 1
\s1 Jato saludana
\p 
\v 1 Ea riki Pedro, Jesucriston raana, enra saludo bomai ja Diossen katotabo jatíbiain jaton mainmabi janbisax, ja Ponto main, Galaciain, Capadociain, Asiain, jainoax ja Bitiniain jakanabo.
\p 
\v 2 Ja non Papa Diossen moabi mato jaskáati shinanna ixon katotabo. Jawen Shinan meranxonra jawenabo itiakin mato imaa iki; mato Jesucristoki yoitibo inon ixon, itan jawen jimin chokitabo maton ikanon ixon. Bikanwe jawen jakon shinan itan jawen xabá shinan.
\s1 Jaon manáxon Dios rabiti
\p 
\v 3 Ja non Ibo Jesucriston Papa Dios rabinon akanwe, janra ani akinmisti shinanya ixon, Jesucristo mawámaxon jirimataanan noa bená jonibo imaa iki, jaskatira noa jaon manati jenéyamai.
\p 
\v 4 Jainxonra jaskara meninoxon mato Diossen yoia jawékibo maton binoxiki, ja jawetianbi keyóyosma jawékibo, tishiosma, itan jawetianbi ramíosmabo.
\p 
\v 5 Jaskáakin ja Dios ikonhaax jaki koshiabo mato ikenra, jaskatax kishpinmeekanon ixon, jawen atipana koshin mato jan koirannai; moa nete senenketian jaskáati jan shinanna keskáakin.
\p 
\v 6 Neskara kopíra mato raroshaman ikanti jake; icha tanakaati jawékibo winotibi, basima winotaibores iketian.
\p 
\v 7 Ja Dios ikonhaax mato jaki koshia riki oro keska; ja orora akanai jabiresshaman onannoxon chiikan tanakin. Jaskáribiira ja Dios ikonhaax jaki koshitaanan ja tanakaati jawékibo teneax, ja maton ikonhaa jawéki ja oro winoa jakon itiki. Jaskáakinra Dios ikonhaa ixon, ja tanakaati jawékibo winoa iken, Jesucristo joxon jakoinra mato iká iketian mato rabinoxiki, jainxon kikin joniboakinribi mato oinnoxiki.
\p 
\v 8 Jaskarabo kopíra já oinnama ixonbi akonbireskin maton Jesucristo noike, jainxon oinnama ixonbi ikonhaabo ikaxa rama mato kikini raroi, jaskáshamani ja raroi yoyo iti joibobi yamake.
\p 
\v 9 Jaskáakin ja ikonhaax jaki koshiabo mato ikenra, moa mato Diossen kishpinmai iitai.
\p 
\v 10 Profetabaonra meskóakinbo tanaxon shinanman kikinhakin onanbokana iki ja kishpinmeeti joi, ja joira akana iki ja Diossen jawen jakon shinanman noa yoikin.
\p 
\v 11 Moatianbira jawen Shinanmanbi ja *profetabo jato onanmabea iki, ja Cristo onitsapiti mawatax jiria pekáo, ani ratéti jawékibo winóti; jatianra jabo kikinbiresi onankaskana iki, tsoa jonishaman yoii itan jawetianshaman jaskati yoikinmein jato meran iká Diossen Shinanman jato akai ixon.
\p 
\v 12 Ikaxbi Diossenra jato onanmaa iki, ja jabaon jato yoikatitai joibo, jabo jaskámati yoii ikáma, mato imanoxon yoii iká. Ja joiribi riki naikanmeax joxon, ja Diossen Shinanman atipana koshin jato amaaton, ja bena joi yoiaibaon mato onanmaa. Neskara jawékibora akanai ja ángelbaonribi kikinhakin onankaskin.
\s1 Yoiti bakebo iti
\p 
\v 13 Jaskara iken maton ati jawékibo jaketian, akonkin shinankanwe. Jaskáaxon jakon jawékibores maton anon. Ja Jesucristo jakiribi joketian, Diossen jawen jakon shinanman mato meniti jawékinin manákanwe.
\p 
\v 14 Jainoax jawen bakebo ixon jan yoiai joibo senenhaxonaibo ikaxkaya, ja Dios onanamatian jakonma jawékibores akíbiribi mato jaa ikátiai keskatibo jaai moa jenékanwe.
\p 
\v 15 Jaskáyamaikaya jan mato katota Dios ochaoma iken, moa ochaoma keskati jakanabo ikanwe.
\p 
\v 16 Wishá meranra ikai: “Eara ochaoma iki, jaskara iken matoribi ochaomabo ikanwe”, iki.\f + \fr 1:16 \ft Lv. 11.45; 19.2\f*
\p 
\v 17 Ja non Papa akin maton akai Diossenra, senenbires jaton aká jawékibo jato yoixonai, jaskara kopí ja nato neten mato winotai keskábores jaai kaman, jan yoiai keskatibores mato ikanti jake.
\p 
\v 18 Diossenra ja maton rekenbaon jakonma axébo chibani jakanabo mato ikanainbi, mato tsekaa iki; jaskákinra kikinhakin maton onanke ja mato kishpinmakin oro jawékinin, iamaxon koríkinin kopíaxon mato imaama, jabo iki keyotai jawékibores.
\p 
\v 19 Jaskáyamakinra ja Jesucriston jakonhira jimin mato kopía iki; ja westíora waka bake jawen yoranko jawe jakonmabi yama retekanai keská imataanan.\f + \fr 1:19 \ft Ja Moiséssen esé meranra Diossen yoia iki; jaton ocha soakaati kopí, yoina retea jimi meniti.\f*
\p 
\v 20 Ja Cristo jaskámatira nete joniamatianbi Diossen shinanna iká iki; jaskatira moa nato nete senenaitian, mato akinti kopí joá iki.
\p 
\v 21 Jaskáakinra ja Cristo kopíres maton Dios ikonhai, janbi jirimataanan jatíbibo xewina imaa iketian; jaskatira ja Dios ikonhaabo ikax, jaon manatabo mato ikanai.
\p 
\v 22 Jainoax ramaribi ja ikon join yoiai keskatibo jaax, maton shinan meran moa jakonabo mato ikanai, jaskáaxon mato betan joi akaiboribi ikonkon maton noiti kopí, jaskara kopíra jakon shinanyanix, maton koshianixbi wetsabo betan mato noianankanti jake.
\p 
\v 23 Jaskatira ja Diossen join imaa ikax, moa benati pikotabo mato ikanai, ja nekeabi maton anibo meranoax ikama, jabo iki joni ikax mawataiboribi, ja Diossen joi riki jato jamai ikax jawetianbi keyoyosma.
\p 
\v 24 Wishá meranra ikai:
\q1 “jatíbi jonibo riki basi jayamaibo ikax xobi
\q1 keskábores,
\q1 jainxon jatíbi jaton metsábo iki, xobi joa keskábores,
\q1 ja xobi choshiketian ikai, jawen joaboribi moa maanni,
\q1 
\v 25 Ikaxbi ja non Ibon joira jawetianbi keyóyamai”, iki.\f + \fr 1:25 \ft Is. 40.6-8\f* Jatian ja nato bená joi riki, ja mato onanmakana.
\c 2
\p 
\v 1 Jaskara kopíra jatíbi meskó jakonma shinanbo moa maton jeneti jake: jatíbi paranmisti shinanbo; beparanmisti shinanbo, notsiresti shinanbo jainoax ja meskó joibo ninkatax keshati shinanboribi.
\p 
\v 2 Ja pikó benashoko bake kikini jawen titan xoma akasai keskatikaya, kikinhakin ja Diossen jakon joi onanti shinanyabo ikanwe, jaskáakin ja joi onanax, shinan meran beboni koshitaanan mato kishpinmeekanon.
\p 
\v 3 Ja non Ibora jakon shinanya iki ixon moa onanax.
\s1 Cristonra bená jonibo jato imai
\p 
\v 4 Jaskara iken jaki koshikanwe, Cristo riki ja jonibaon rotokana jiria makan keska, ikaxbi Diossenbi ja kikin chorish makan iken, janbi katota keská.
\p 
\v 5 Neskáxonra Diossen maton shinan meran, jakon chorish makan xoboa keskábo mato imati iki, jawen *sacerdotebobiribi, jainoax ja Jesucristo kopíres, Dios keenai keskatishaman menikaataiboribi mato imati iki.
\p 
\v 6 Wishá meranra ikai já yoii neskati:
\q1 “Enra ja *Sión jeman westíora koshi makan akai, jara en katota iki, jara kikin kopí iki,
\q1 jaki koshiabora, paranmeetabo ikantima iki”, iki.\f + \fr 2:6 \ft Is. 28.16\f*
\q1 
\v 7 Jaskara ikenra ja ikonhabo ixon maton onanke, ja wetsabo xewina kikin jakonhira shanka keska, ikaxbi ja ikonhayamaibaon shinannai yoiira ikai Wishá meran neskati:
\q1 “Ja xoboaibaon rotokana makanra,
\q1 jan xobo koshiaka makan banéke”, iki.\f + \fr 2:7 \ft Sal. 118.22\f*
\p 
\v 8 Jainoax iribai:
\q1 “Westíora jaki tatí iti makan, jainoax westíora jan jato pakémai makan keska”, iki.\f + \fr 2:8 \ft Is. 8.14\f*
\m Jabora jaki tatí ikanai, jawen joiki yoitimati; jaskátibiribi imaabo ikax.
\p 
\v 9 Ikaxbi mato riki, Diossenbi katota rarebobo, ja Apon tee axonai *sacerdotebo, Dioski menikaata jonibo, jawen jonibo itiakin Diossenbi biabo. Neskarabora mato imaa iki, ja jakonhira tee Diossen akábo maton jato yoinon ixon. Janra ja ocha akí yamé keska meran mato iikanainbi, ja jakonhira joé keska meran ikanon ixon mato kenaa iki.
\p 
\v 10 Moatianra Diossen katota jonimabobi mato ikana iki, ikaxbi ramara mato Diossen jonibo iki, moatianra Diossen mato onísayamabobia iki, ikaxbi ramara mato Diossen kikinhakin noibai.\f + \fr 2:10 \ft Os. 1.6, 9; 2.23\f*
\s1 Diossen tee axoni jati
\p 
\v 11 Nokon noi wetsabo nato neten basi iamai ikax, winotai jonibo keskábores ikenra, en mato yoikin jeneyamai; ja maton jakonma shinanbo jenekanwe, jaskara shinanbaonra maton jati jakonmaakai.
\p 
\v 12 Ja Dios ikonhayamaibo xarameax mato ikainkobo jakonires ikanwe. Jatianra jabaon, jakonma jawéki akai joniboakin mato rama yoia ixonbi, jakon jawékibo maton aká oinxon, jabaonribi Dios rabikanti iki já joketian.
\s1 Joni koshibaon ati yoiaibo senenhati
\p 
\v 13 Ja non Ibo ikonhabo ixon jatíbi joni koshibaon yoiai joibo senenhaxonkanwe, jainxon ja icha mai iboaa apon yoiai joiboribi maton senenhaxonti iki, jara jatíbibaon koshi iki.
\p 
\v 14 Jainxon ja jakonma akaibo jato castiganon ixon itan jakon akaiboribi jato jakonhakanon ixon, ja apon jato koshi imaabo iken.
\p 
\v 15 Ikaxbi Diosra keenai maton jakon jawékibores atin, jaskatax ja onanmabo, itan shinan maxkata jonibo matoki jakonmaibo yoyo ikantima kopí.
\p 
\v 16 Moa xabakaata jonibo keskatikaya ikanwe. Jatian moa jaskati xabakaatabo ixonra, jakonma jawékibo non ati jawemabi iki ixon shinanyamakanwe. Jaskáyamaikaya Diossen yonoti jonibo keskatires ikanwe.
\p 
\v 17 Jatíbibo jato jakonhakin akanwe, non wetsabo jato noikanwe, kikin aniakin Dios shinankanwe, ja icha mai iboaa apo jakonhakanwe.
\s1 Yonokaataibaon ati jawékibo
\p 
\v 18 Iboakanabo ikax, jan mato iboabaon yoikanai keskatires ikanwe, jakonshaman shinanyanix; ja mato jakonhakin akaibo, itan maton yoiai joibo mato ninkáxonaibaon yoiai keskatibichoresma, ja jakonmaboribi jaton yoiai joibo jato senenhaxonkanwe.\fig Jakonmaakanabi jakonres akin jenetima.|src="CO00798b.TIF" size="span" loc="1 Pedro 2.18" ref="1 Pedro 2:18"\fig*
\p 
\v 19 Jakon jawéki riki, ja Dios keenai keskáakin jawéki senenhakin, westíora jonin jakonma jawéki akáma ixonbi, masá tenemakanaitian, jawe iamakin teneti.
\p 
\v 20 Ikaxbi ¿Jawekeskaxonmein jakonma aketian mato ramiakana tenexon, maton jakon jawéki biti iki? Ikaxbi jakon jawékibo akín maton masá teneaira, Dios bebon kikin jakon iki.
\p 
\v 21 Neskarabo winóti kopíra mato Diossen katota iki, Cristora mato kopi onitsapita iki, já iní keskatiribi mato ikanon ikax.
\p 
\v 22 Jára jawetianbi ochayamaa iki, itan jawen yoyo ikainkoboribi tsoabi jato paranyamaa iki.\f + \fr 2:22 \ft Is. 53.9\f*
\p 
\v 23 Ichabokanabira jawetianbi jan jato kopikin icháyamaa iki, masábo tenemakanabira, ramara en mato ashokoai akinbo jato ayamakin, Dioskires jato jenea iki, jan jaton akábo atibi keskáakin ponté jato yoixonai iketian.
\p 
\v 24 Jara jawen yoranbi non ochabo bibaini korosen akana mawata iki, jaskatax kikinhakin ja ochabo akin moa jeneax, jakon jawékibores akí noa jakanon ixon. Ja rishkikin xateyonkana kopíra mato benxoa iki.
\p 
\v 25 Moatianra mato ikana iki ja oveja manota keskábo, ikaxbi ramara moa Cristo ikonhabo iken, jan oveja koirannai jakon *pastor keska ixon, koiraanan mato jan akinnai.
\c 3
\s1 Wanoya itan benoyabaon senenhatibo
\p 
\v 1 Jatian mato benoyabora en mato yoiai, ja maton benen yoiai keskatibo ikanwe. Jaskáxon ja joi ikonhayamaibaonbi, maton joi yoiamabi maton ikábo oinxonres, ikonhakanon ixon.
\p 
\v 2 Ja maton ikainkobo jawe jakonma iamai, itan ikoni mato Dioski raketaibo ointaanan.
\p 
\v 3 Ja mato raokaataibo ibanon nekebima jabo iki; meskóakinhorabo boo atima, ja oro akana joyabo, itan ja kopí chopairaboribi sawetima.
\p 
\v 4 Jaskáyamaikaya maton shinan meran, jawetianbi keyóyosma xabá shinanman, itan noimisti shinanmanres, kikini raokaata ikanwe. Jaskaraton metsatakayara Diossen oinna kikinbires jakonshaman iki.
\p 
\v 5 Neskatiribi raokaatabora ikana iki, ja moatian Dioski menikaata ainbobo; jabora ikoni Dioski koshikanabo ikax, jaton benen yoiai keskati ikai ainbobo ikana iki.
\p 
\v 6 Jaskarara iká iki Sara, janra jawen bene Abrahamman yoia yoiti ikai ainbo ixon, nokon ibó akin janepaonike. Jatian matobora jawen bake ainbobo iki; ja ikonkon jawékibores akí tsokibi rakéyamai ikax.
\p 
\v 7 Jatian mato wanoyabora en yoiai, jakonax maton awin betan ninkakanankanwe. Jakonshamanxonreskaya ikinkanwe, ja ainbobora non kikinhakin méketi iki ixon shinannai kopíbichoma; jabora mato aká keskaribiakin, jakon shinanya ixon Diossen jabé jamanoxon yoiaboribi iki. Jaskáakanwe ja maton oracion jan tsokásatibo yamati kopí.
\s1 Joi akaibaon ati jawékibo
\p 
\v 8 Jatikaxbi jakonanani jakanwe; westíora shinanyabicho itaanan shinannanani, jainoax joi akaibo ikax noiananax. Jakonhakin shinannaibo ikanwe, jato xewinaton shinanmeetaimabo.
\p 
\v 9 Mato ramiakanabi kopikin jato ramiayamakanwe, mato ichaakanabi kopikin jato ichayamakanwe jaskáyamakinkaya jato jakonhareskanwe, Diossenra jakonhanoxon mato kenaa iki.
\p 
\v 10 Wishá meranra ikai neskati:
\q1 “Tsoaki ikoni jakoni jaax, raroires jatin keenai,
\q1 jara jakonmaibo yoyo iki jenetax, moa
\q1 jansoibo yoyo iki jeneta iti jake.
\q1 
\v 11 Jainoax jakonma jawékibo akin jenetaanan
\q1 jakon jawékiboresibi ati jake.
\q1 Jatíbibo betan jakonax jatiakin shinannires jawé.
\q1 
\v 12 Non Ibonra ja jakon jawéki akai jonibo jato
\q1 koirannai.
\q1 Jainxon jaton oranaiboribi jato ninkáxonai
\q1 Ikaxbi ja non Ibora ja jakonma jawéki akaiboki,
\q1 jakonmaatai”, iki.\f + \fr 3:12 \ft Sal. 34.12-16\f*
\p 
\v 13 Jatian ¿Maton jakon jawékibores akaitianmein tson mato jakonmaati iki?
\p 
\v 14 Ikaxbi ja jakoni jakanabo ixonbi masábo teneira mato raroreskanti jake, jaskatira tsokibi mato rakéti itan ratéti yamake.
\p 
\v 15 Jaskáyamakinkaya maton Ibo keskáakin maton shinan meran Cristo rabikanwe, jainxon jawe kopí Criston manataboki ikanai ixon mato yokákanaitian, moa jato yoitiresbo ikanwe.
\p 
\v 16 Ikaxbi jaskáakinbo jato yoikin, rabí shinanhomaxon jakonhaxonres jato yoikanwe, maton shinan meran jakonma aká shinan yamashaman itaanan. Jaskatax ja Cristo ikonhaax mato jakoni jakanabo oinnax, mato jakonmaakin yoiaibo, jato yoyo ika joinbi ikonbiresi rabinkanti kopí.
\p 
\v 17 Jaskara Diossen shinanna iketian jakon akai kopí onitsapitikayara jakon iki, ja jakonma jawékibo axon masá tenetitianbi.
\p 
\v 18 Cristobira onitsapitax non ochabo kopí westíoraibicho mawata iki, jara jakon joni ikaxbi jakonma jonibo kopí mawata iki, jaskáaxon noa Dios betan jakonbires imanox. Jara nekebi jawen yora mawákenbi, Diossen Shinanmanbi jakiribi jirimaa iki.
\p 
\v 19 Jatian moa jaskara ixonra, kaxon ja xepó meran ikana kayabo jawen joi jato yoia iki.
\p 
\v 20 Ja kayabora ikana iki, ja moatian Noé inontian yoitima ikana jonibo, ja jonibora aká iki Diossen ja ani wapóro Noekan akai kaman, jaweayamakin jato manakin. Jatian ja wapóroninmeax kishpinmeetabora ikana iki posaka jonibichores.
\p 
\v 21 Ja jenen ewara iká iki, rama ja bautismo yoii iká. Jameranoax noa rama kishpinkanabo. Ja bautismora non yora chókiti noa ikaima iki; jara Dios bebon jakonma aká shinan meran yamaa onanti inox noa ikai iki. Janra noa kishpinmaa iki, ja Jesucristo mawataxbi jiria kopíres.
\p 
\v 22 Jara naikan kaax, Diossen mekayao yakata iki. Jaskara kopíra ja ángelbo itan jatíbi koshi shinanya koshibo, jaki koshikana baneta iki.
\c 4
\s1 Cristo iní keskati jati
\p 
\v 1 Jaskara iken, Criston jawen yora onitsapimani keskatiribi onitsapiti shinanya ikanwe. Jaweratoboki onitsapiti jawemabi iki, jabaonra moa ocha jeneke.
\p 
\v 2 Jaskatax ja Diossen shinannai keskatires jaax, ja nekeabi non yora keenai jakonma jawékibo akí, moa mato jayamati kopí.
\p 
\v 3 Basibiresa ja Dios ikonhayamaibaon akai jawékiboribi maton aká iki, jakonmanin kikini cheatabo mato ikana iki, jakonmabo atin keenaibores; jawékiananbi paeni, itan ayorakin pae xeaibo; jainoax ja kikin jakonmabires jatonbi aká jawékibo rabii.
\p 
\v 4 Ikaxbi ramara, ja bebonbires jakonma akanainkobo mato jato betan yamaa oinnax, jabobiribi matoki jakonmaibo yoyo ikanai.
\p 
\v 5 Ikaxbi jabaonra ja mawataboyabi ja jiriabo, jaton akábobiribi jato yoixonai iti imaa bebonxonbiribi, jaton aká jawékibo yoinoxikanai.
\p 
\v 6 Neskara kopíra ja mawataboribi ja jakon joi jato yoia iki, jaskatax Dios betan jaton shinan meran jakanon ixon; nato netemeax castiganmetaanan, joni ikai keskati mawákanabo ikenbi.
\p 
\v 7 Moara jatíbi jawékibo senenti ochóma iki; jaskara iken akonkin shinankanwe, itan akonkin Dios orankanwe.
\p 
\v 8 Maton wetsabo betan ikoni noianankanwe, ja noimisti shinanmanra icha ocha akanabobi moa jato shinanxontimaakin noa imai.
\p 
\v 9 Ja matoiba merataibokiribi jakonmaibo yoyo iamakin, jakonhaxonres jato bikanwe.
\p 
\v 10 Ja meskó onan shinanyabo mato Diossen imaa iken, jakonhakin ja onan shinanman jato akinnai ixon, jaskara onan shinanya mia Diossen imaatonin, wetsaboribi jato akinwe.
\p 
\v 11 Jaweratoki joi yoiai iki, janra Diossen joishamanbiribi yoiti jake; jaweratonki jato jawéki akinnai, janra ja Diossen menia koshiaxon jato akinti jake. Jatíbi maton akai jawékibo akanwe, ja Jesucristo kopíres Dios rabikanon ixon; ja riki jatíbitian rabiti itan jawena riki jatíbi atipana koshi. Jaskarashaman ibanon.
\s1 Cristo ikonha ikax onitsapiti
\p 
\v 12 En noia nokon wetsabo, atikoma jawékibo nokoax ratéyamakanwe; jawekeskatiki noa neskara jawékibo winotai ixon shinannax, jara bená jawékima iki.
\p 
\v 13 Jaskáyamaikaya ja Cristo iní keskatiribi onitsapitibi raroreskanwe, jaskatax Cristo jakiribi jawen koshi shinanyabi joketian, mato kikin raroshamanbo ikanon.
\p 
\v 14 Ja Cristo kopí wetsabo mato jakomaibo yoyo ikanainbira mato Diossen raroshaman imati iki, ja Diossen kikin ani Shinan mato meran ikí jenéyamai kopí.
\p 
\v 15 Matora ja retemis iken, yometso iken, jakonmaamis joni iken, iamaxon ja wetsabo winota jawékiainbo niakaaketian onitsapimakanaibo ikanti yamake.
\p 
\v 16 Ikaxbi ja joi ikonhai iken mato masá tenemakanara, mato rabinti yamake, jaskáyamakinra maton Dios rabiresti iki, ja ikonhaibo iken mato jaskákanaitian.
\p 
\v 17 Moara ja joi ikonhaibopari jaton akábo jato Diossen yoixontibo peokooke, jatian noibakeaxpari jaskara jawékibo peokootaitianki, ¿Ja Diossen jakon joiki yoitimaibo jawekeskara winónoxiki?
\p 
\v 18 Ja joi akai jonira atikonmabires meranbi kishpinmeetai, jatian ¿Ja jakonma itan ja ochaya jonimein, jawekeskara winónoxiki?
\p 
\v 19 Jaskara ikenra ja Dios keenaton onitsapitaibaon, jakon jawékibores akin jenetima iki, jainxon jan noa jonia Dioskiribi menikaakanti jake, janra noa jawetianbi jeneyamai.
\c 5
\s1 Joi akaibo ikinai koshibo jato esea
\p 
\v 1 Ramara earibi jato keska *anciano ixon, ja mato ikinai ancianobo en eseai; enribi ja Cristo onitsapitaibo oinni ixon. Jainoax earibi iki, jabaon akai keskáakinribi Cristo joketian jawen kikin jakon jawékibo biti.
\p 
\v 2 Ja maton ikinnon ixon matoki jenekana Diossen joi ikonhaibo jakonhaxon jato ikinkanwe. Keenshamanxon Dios keenai keskáakin; ja oveja koirannaibaon jato ikinai keskáakin. Jato ikinti yoikana senenhakinresma, kopíakanti keenkinresmaribi, keenshamantaanankaya jawen tee axonkanwe.
\p 
\v 3 Ja maton ikinai joi akaibo, iboaxon jato yonoai keskáakin jato ayamakanwe, jaskáyamaikaya jakoni mato ikaibores jato oinmakanwe.
\p 
\v 4 Jatianra ja *pastorbaon koshi joketian, jawetianbi keyóyosma kikin jakonhira jan ratéti jawéki maton biti iki, ja maitira jawetianbi payóyamai.
\s1 Jatíbi joi akaibo jato esea
\p 
\v 5 Jaskáribiakinra mato ranonboyabi xontakobo en mato yoiai, ja mato ikinai ancianobaon yoiai keskatibokaya ikanwe. Jatikaxbira rabíti shinanhomabo ikax mato joi ninkakananti jake. Wishá meranra ikai neskati:
\q1 “Ja rabitai jonibokira Dios jakonmaatai,
\q1 ikaxbi ja rabiamaibora jawen jakon shinanman jato akinnai”, iki.\f + \fr 5:5 \ft Pr. 3.34\f*
\p 
\v 6 Ja Dios atipana koshia iketiankaya, rabíti shinanhomabo itaanan jaki jenekaakanwe. Jaskáxon mato jan jaskara imatitianbiribi, kikin joniakin mato imanon.
\p 
\v 7 Jaskara iken jatíbi ja maton meskó shinannaibo Dioski jenekanwe, janra matoakin shinankin jeneyamai.
\p 
\v 8 Jatíbitian shinanyares ikax koiranmeekanwe, non rawí yoshinra ja pinoxon benai león keo keokawanai keská iki.
\p 
\v 9 Já ninkáxonyamakanwe; Dioskireskaya kikini koshikanwe; mato ikai keskatiribi, jatíbiainoa mato betan joi akaibo onitsapitai onantaanan.
\p 
\v 10 Ikaxbi jaskatibo basima mato onitsapita pekaora, Diossenbi jakiribi jakonhati iki, jainxonra ponté shinanya itan koshi shinanya mato imati iki; jainxonra moa jakibi kikini koshia mato imati iki. Ja Diosbi riki jawen ani noimisti shinanman noa kenaa, ja Jesucristo betanbi jawen keyóyosma jakon netenko jaai noa bokanon ixon.
\p 
\v 11 Jawena riki jatíbitian ja atipana koshi, ibanon jaskarashaman.
\s1 Senentiainbi jato saludana
\p 
\v 12 Ja non Iboki koshii jenéyamai non wetsa Silvanon akinnatonra, nato ichama joi en mato wishaxonke, mato ésenoxon; jainxon ja jakon jawékibo maton biabo riki, akonkin noixon mato Diossen meniabo iki ixon mato onanmati kopí. Ja jaskáakin mato Diossen noia, jawetianbi shinanbenoyamakanwe.
\p 
\v 13 Ja mato aká keskákinribi Diossen katota Babiloniainoa Cristo ikonhaibaonra, mato saludo bomai, jainxon ja nokon bake keskáakin en shinannai Marcosninribira mato saludo bomai.
\p 
\v 14 Joi akaibobires ikax, noiananax wetsabo betan saludanani, betsó iananankanwe. Jatikaxbi jakonshaman jakanwe moa Cristonabo ikax.
