\li2 
\v 21 आतेर के संतान (हिजकियाह के बंस म ले) 98;
\li2 
\v 22 हासूम के संतान 328;
\li2 
\v 23 बेसै के संतान 324;
\li2 
\v 24 हारीफ के संतान 112;
\li2 
\v 25 गिबोन के संतान 95।
\li1 
\v 26 आदमीमन—
\li2 बैतलहम अऊ नतोपा के आदमीमन 188;
\li2 
\v 27 अनातोत के आदमीमन 128;
\li2 
\v 28 बेत-अजमावेत के आदमीमन 42;
\li2 
