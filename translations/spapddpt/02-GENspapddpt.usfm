\p
\v 26 Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Disón|strong="H1789"\w*: \w Hemdán|strong="H2533"\w*, Esbán, Itrán y Querán.   
\p
\v 27 Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Ezer: \w Bilhán|strong="H1092"\w*, \w Zaaván|strong="H2190"\w* y Acán.   
\p
\v 28 Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Disán: \w Huz|strong="H5780"\w* y Arán.   
\p
\v 29 Estos son los jeques de los hurritas: los jeques \w Lotán|strong="H3877"\w*, \w Sobal|strong="H7732"\w*, \w Zibeón|strong="H6649"\w*, \w Aná|strong="H6034"\w*,  
\v 30 \w Disón|strong="H1789"\w*, Ezer y Disán. Estos fueron los jeques de los hurritas por sus familias en la tierra de \w Seír|strong="H8165"\w*.   
\p
\v 31 \w Antes|strong="H6440"\w* \w que|strong="H1121"\w* un \w rey|strong="H4428"\w* \w reinara|strong="H4427"\w* sobre \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, estos fueron \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w que|strong="H1121"\w* \w reinaron|strong="H4428"\w* en la tierra \w de|strong="H6440"\w* Edom:   
\p
\v 32 \w Bela|strong="H1106"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Beor, \w reinó|strong="H4427"\w* en Edom, y \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* su \w ciudad|strong="H5892"\w* fue Dinaba.   
\p
\v 33 \w Murió|strong="H4191"\w* \w Bela|strong="H1106"\w* y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Jobab|strong="H3103"\w*, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* \w Zera|strong="H2226"\w*, \w de|strong="H8478"\w* \w Bosra|strong="H1224"\w*.   
\p
\v 34 \w Jobab|strong="H3103"\w* \w murió|strong="H4191"\w* y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Husam|strong="H2367"\w*, \w de|strong="H8478"\w* la tierra \w de|strong="H8478"\w* Temán.   
\p
\v 35 \w Husam|strong="H2367"\w* \w murió|strong="H4191"\w* y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Adad|strong="H1908"\w*, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Badad, \w el|strong="H1121"\w* \w que|strong="H1121"\w* derrotó \w a|strong="H3068"\w* \w Madián|strong="H4080"\w* \w en|strong="H8478"\w* \w el|strong="H1121"\w* \w campo|strong="H7704"\w* \w de|strong="H8478"\w* \w Moab|strong="H4124"\w*, y \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H8478"\w* su \w ciudad|strong="H5892"\w*, Avit.   
\p
\v 36 \w Adad|strong="H1908"\w* \w murió|strong="H4191"\w* y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Samla|strong="H8072"\w*, \w de|strong="H8478"\w* Masreca.   
\p
\v 37 \w Samla|strong="H8072"\w* \w murió|strong="H4191"\w* y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Saúl|strong="H7586"\w*, \w de|strong="H8478"\w* Rehobot del \w Río|strong="H5104"\w*.   
\p
\v 38 \w Saúl|strong="H7586"\w* \w murió|strong="H4191"\w* y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Baal-hanán|strong="H1177"\w*, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Acbor.   
\p
\v 39 \w Baal-hanán|strong="H1177"\w*, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* Acbor, \w murió|strong="H4191"\w* y \w reinó|strong="H4427"\w* \w en|strong="H8478"\w* su \w lugar|strong="H8478"\w* \w Adar|strong="H1924"\w*. Su \w ciudad|strong="H5892"\w* se \w llamaba|strong="H8034"\w* Pau y su esposa Mehetabel, \w hija|strong="H1323"\w* \w de|strong="H8478"\w* Matred, \w hija|strong="H1323"\w* \w de|strong="H8478"\w* Mezahav.   
\p
\v 40 Estos son los \w nombres|strong="H8034"\w* de los jeques de \w Esaú|strong="H6215"\w* por sus \w familias|strong="H4940"\w*, localidades y \w nombres|strong="H8034"\w*: los jeques \w Timná|strong="H8555"\w*, Alva, Jetet,  
\v 41 Oholibama, Ela, Pinón,  
\v 42 Cenaz, \w Temán|strong="H8487"\w*, Mibzar,  
\v 43 \w Magdiel|strong="H4025"\w* \w e|strong="H3068"\w* Hiram.  
\p Tales fueron \w los|strong="H1931"\w* jeques de Edom, \w conforme|strong="H1931"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* viviendas en \w la|strong="H1931"\w* tierra de \w su|strong="H1931"\w* posesión. \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w Esaú|strong="H6215"\w*, padre de Edom.   
\c 37  
\s1 José y sus hermanos  
\p
\v 1 \w Jacob|strong="H3290"\w* \w habitó|strong="H3427"\w* en la tierra de \w Canaán|strong="H3667"\w*, la tierra de las peregrinaciones de su padre.   
\p
\v 2 \w Esta|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* historia \w de|strong="H1121"\w* \w la|strong="H1931"\w* familia \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w*: \w José|strong="H3130"\w* \w tenía|strong="H1961"\w* 17 \w años|strong="H8141"\w* \w de|strong="H1121"\w* \w edad|strong="H8141"\w* y \w apacentaba|strong="H7462"\w* las \w ovejas|strong="H6629"\w* con \w sus|strong="H1931"\w* hermanos. \w El|strong="H1931"\w* joven \w estaba|strong="H1961"\w* con \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Bilha|strong="H1090"\w* y \w de|strong="H1121"\w* \w Zilpa|strong="H2153"\w*, concubinas \w de|strong="H1121"\w* \w su|strong="H1931"\w* padre. \w José|strong="H3130"\w* informaba \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre \w la|strong="H1931"\w* \w mala|strong="H7451"\w* \w fama|strong="H1681"\w* \w de|strong="H1121"\w* \w ellos|strong="H1931"\w*.   
\p
\v 3 \w Israel|strong="H3478"\w* amaba \w a|strong="H3068"\w* \w José|strong="H3130"\w* \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w*, \w porque|strong="H3588"\w* \w era|strong="H1931"\w* \w el|strong="H1931"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* vejez. \w Le|strong="H1931"\w* \w hizo|strong="H6213"\w* una túnica \w con|strong="H3588"\w* rayas \w de|strong="H3588"\w* colores.  
\v 4 Sus hermanos, al \w ver|strong="H7200"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* padre \w lo|strong="H3808"\w* prefería sobre \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w*, \w lo|strong="H3808"\w* \w aborrecían|strong="H8130"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w podían|strong="H3201"\w* \w hablarle|strong="H1696"\w* \w pacíficamente|strong="H7965"\w*.   
\p
\v 5 \w José|strong="H3130"\w* \w tuvo|strong="H2492"\w* un \w sueño|strong="H2472"\w* y lo \w contó|strong="H5046"\w* \w a|strong="H3068"\w* sus hermanos, con lo cual aumentaron \w más|strong="H5750"\w* su odio contra él  
\v 6 \w pues|strong="H4994"\w* él les dijo: \w Escuchen|strong="H8085"\w* \w ahora|strong="H4994"\w* \w este|strong="H2088"\w* sueño \w que|strong="H4994"\w* tuve.  
\v 7 Estábamos ahí \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del \w campo|strong="H7704"\w* \w y|strong="H1571"\w* atábamos gavillas. Miré \w que|strong="H1571"\w* \w mi|strong="H2009"\w* gavilla se levantaba \w y|strong="H1571"\w* seguía erguida. \w Y|strong="H3068"\w* las gavillas de ustedes \w la|strong="H1571"\w* rodeaban \w y|strong="H1571"\w* se inclinaban ante \w la|strong="H1571"\w* mía.   
\p
\v 8 \w Le|strong="H5921"\w* respondieron sus hermanos: ¿Vas \w a|strong="H3068"\w* reinar \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w y|strong="H5921"\w* \w nos|strong="H5921"\w* dominarás? \w Y|strong="H3068"\w* \w lo|strong="H1697"\w* odiaron \w aun|strong="H5750"\w* \w más|strong="H5750"\w* \w a|strong="H3068"\w* \w causa|strong="H1697"\w* \w de|strong="H5921"\w* sus \w sueños|strong="H2472"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* sus \w palabras|strong="H1697"\w*.   
\p
\v 9 \w Tuvo|strong="H2492"\w* \w otro|strong="H5750"\w* \w sueño|strong="H2472"\w* y lo \w contó|strong="H5608"\w* \w a|strong="H3068"\w* sus hermanos: Miren, me vino \w otro|strong="H5750"\w* \w sueño|strong="H2472"\w*: que el \w sol|strong="H8121"\w*, la \w luna|strong="H3394"\w* y once \w estrellas|strong="H3556"\w* se inclinaban ante \w mí|strong="H2009"\w*.   
\p
\v 10 \w Lo|strong="H4100"\w* relató \w a|strong="H3068"\w* su padre y \w a|strong="H3068"\w* sus hermanos. Pero su padre \w lo|strong="H4100"\w* reprendió y le dijo: ¿\w Qué|strong="H4100"\w* fue \w esto|strong="H2088"\w* \w que|strong="H4100"\w* \w soñaste|strong="H2492"\w*? ¿Yo, tu madre y tus hermanos \w nos|strong="H4100"\w* postraremos en tierra ante ti?  
\v 11 Sus hermanos le \w tenían|strong="H8104"\w* \w envidia|strong="H7065"\w*, pero su padre meditaba en \w esto|strong="H1697"\w*.   
\s1 José vendido por sus hermanos  
\p
\v 12 Cuando sus hermanos apacentaban el \w rebaño|strong="H6629"\w* de su padre \w en|strong="H3212"\w* Siquem,  
\v 13 \w Israel|strong="H3478"\w* dijo \w a|strong="H3068"\w* \w José|strong="H3130"\w*: ¿\w No|strong="H3808"\w* \w están|strong="H2009"\w* tus hermanos \w pastoreando|strong="H7462"\w* \w en|strong="H3212"\w* Siquem? \w Ven|strong="H3212"\w*, te \w enviaré|strong="H7971"\w* \w a|strong="H3068"\w* ellos.  
\p \w Y|strong="H3068"\w* él respondió: \w Aquí|strong="H2009"\w* estoy dispuesto.   
\p
\v 14 \w E|strong="H3068"\w* \w Israel|strong="H4994"\w* le dijo: \w Vé|strong="H3212"\w* \w ahora|strong="H4994"\w*. \w Mira|strong="H7200"\w* cómo están tus hermanos, cómo se encuentra el \w rebaño|strong="H6629"\w* y tráeme un informe. Así \w lo|strong="H1697"\w* \w envió|strong="H7971"\w* desde el \w valle|strong="H6010"\w* \w de|strong="H1697"\w* \w Hebrón|strong="H2275"\w*, y \w llegó|strong="H3212"\w* \w a|strong="H3068"\w* Siquem.  
\v 15 Un hombre \w lo|strong="H4100"\w* \w halló|strong="H4672"\w* \w cuando|strong="H4100"\w* deambulaba \w por|strong="H4100"\w* el \w campo|strong="H7704"\w* y le \w preguntó|strong="H7592"\w*: ¿\w Qué|strong="H4100"\w* \w buscas|strong="H1245"\w*?   
\p
\v 16 \w Y|strong="H3068"\w* \w dijo|strong="H5046"\w*: \w Busco|strong="H1245"\w* \w a|strong="H3068"\w* mis hermanos. Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* me digas dónde pastorean \w ellos|strong="H1992"\w*.   
\p
\v 17 \w El|strong="H3588"\w* hombre respondió: \w Salieron|strong="H5265"\w* \w de|strong="H3588"\w* \w aquí|strong="H2088"\w*. \w Los|strong="H3588"\w* \w oí|strong="H8085"\w* \w decir|strong="H8085"\w*: \w Vamos|strong="H3212"\w* \w a|strong="H3068"\w* Dotán.  
\p \w José|strong="H3130"\w* \w fue|strong="H3212"\w* tras sus hermanos \w y|strong="H3588"\w* \w los|strong="H3588"\w* \w halló|strong="H4672"\w* \w en|strong="H3588"\w* Dotán.  
\v 18 Cuando \w lo|strong="H7350"\w* \w vieron|strong="H7200"\w* de \w lejos|strong="H7350"\w*, \w antes|strong="H2962"\w* que se acercara, se confabularon para \w matarlo|strong="H4191"\w*.   
\p
\v 19 \w Y|strong="H3068"\w* se dijeron el uno al otro: ¡\w Aquí|strong="H2009"\w* viene el soñador!  
\v 20 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w vamos|strong="H3212"\w*, matémoslo y echémoslo \w en|strong="H3212"\w* una cisterna, y diremos \w que|strong="H4100"\w* una \w mala|strong="H7451"\w* \w bestia|strong="H2416"\w* \w lo|strong="H4100"\w* devoró. Entonces \w veremos|strong="H7200"\w* \w en|strong="H3212"\w* \w qué|strong="H4100"\w* pararán sus \w sueños|strong="H2472"\w*.   
\p
\v 21 Cuando \w Rubén|strong="H7205"\w* \w oyó|strong="H8085"\w* esto, al intentar librarlo de \w mano|strong="H3027"\w* de \w ellos|strong="H3027"\w*, dijo: ¡\w No|strong="H3808"\w* le quitemos la \w vida|strong="H5315"\w*!  
\v 22 \w Y|strong="H3068"\w* \w Rubén|strong="H7205"\w* añadió: \w No|strong="H3808"\w* derramen \w sangre|strong="H1818"\w*. Échenlo en \w esta|strong="H2088"\w* cisterna \w que|strong="H3808"\w* \w está|strong="H2088"\w* en el \w desierto|strong="H4057"\w*, pero \w no|strong="H3808"\w* \w extiendan|strong="H7971"\w* la \w mano|strong="H3027"\w* contra él. \w Esto|strong="H2088"\w* dijo \w a|strong="H3068"\w* fin \w de|strong="H1818"\w* librarlo \w de|strong="H1818"\w* sus \w manos|strong="H3027"\w* \w para|strong="H4616"\w* hacerlo \w volver|strong="H7725"\w* \w a|strong="H3068"\w* su padre.   
\p
\v 23 \w Sucedió|strong="H1961"\w* \w que|strong="H5921"\w* \w cuando|strong="H1961"\w* \w José|strong="H3130"\w* llegó \w hasta|strong="H5921"\w* sus hermanos, \w lo|strong="H5921"\w* despojaron \w de|strong="H5921"\w* su túnica, \w la|strong="H5921"\w* túnica \w de|strong="H5921"\w* rayas \w de|strong="H5921"\w* colores \w que|strong="H5921"\w* \w llevaba|strong="H1961"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*.  
\v 24 Lo \w tomaron|strong="H3947"\w* y lo echaron en la cisterna, pero la cisterna estaba \w vacía|strong="H7386"\w*. No había \w agua|strong="H4325"\w* en ella.   
\p
\v 25 Luego se \w sentaron|strong="H3427"\w* \w a|strong="H3068"\w* comer \w pan|strong="H3899"\w*. Al levantar sus \w ojos|strong="H5869"\w* \w vieron|strong="H7200"\w* una caravana \w de|strong="H5869"\w* ismaelitas que \w iba|strong="H1980"\w* \w de|strong="H5869"\w* \w Galaad|strong="H1568"\w*, y \w llevaba|strong="H5375"\w* en sus \w camellos|strong="H1581"\w* especias, \w bálsamo|strong="H6875"\w* y mirra para llevarlos \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 26 \w Entonces|strong="H3588"\w* \w Judá|strong="H3063"\w* preguntó \w a|strong="H3068"\w* sus hermanos: ¿\w Qué|strong="H3588"\w* \w provecho|strong="H1215"\w* hay \w que|strong="H3588"\w* \w matemos|strong="H2026"\w* \w a|strong="H3068"\w* nuestro hermano \w y|strong="H3588"\w* ocultemos \w su|strong="H3588"\w* \w sangre|strong="H1818"\w*?  
\v 27 Vendámoslo \w a|strong="H3068"\w* \w los|strong="H1931"\w* ismaelitas \w y|strong="H3588"\w* \w no|strong="H3588"\w* levantemos nuestra \w mano|strong="H3027"\w* \w contra|strong="H1961"\w* \w él|strong="H1931"\w*, \w pues|strong="H3588"\w* \w es|strong="H1931"\w* nuestro hermano, nuestra \w carne|strong="H1320"\w*. \w Y|strong="H3068"\w* \w sus|strong="H1931"\w* hermanos \add le\add* \w obedecieron|strong="H8085"\w*.   
\p
\v 28 Cuando \w pasaron|strong="H5674"\w* los \w mercaderes|strong="H5503"\w* madianitas, \w sacaron|strong="H4900"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w* \w de|strong="H4480"\w* la cisterna, y lo \w vendieron|strong="H4376"\w* \w a|strong="H3068"\w* los ismaelitas \w por|strong="H4480"\w* 20 piezas \w de|strong="H4480"\w* \w plata|strong="H3701"\w*. \w Y|strong="H3068"\w* \w ellos|strong="H4480"\w* llevaron \w a|strong="H3068"\w* \w José|strong="H3130"\w* \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 29 Cuando \w Rubén|strong="H7205"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* la cisterna, no halló \w a|strong="H3068"\w* \w José|strong="H3130"\w* allí. \w Entonces|strong="H7725"\w* \w rasgó|strong="H7167"\w* sus ropas,  
\v 30 se \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* sus hermanos y les exclamó: ¡El muchacho no está allí! ¿\w Y|strong="H3068"\w* yo, \w a|strong="H3068"\w* dónde iré?   
\p
\v 31 Entonces \w tomaron|strong="H3947"\w* la túnica \w de|strong="H1818"\w* \w José|strong="H3130"\w*, degollaron un cabrito y empaparon la túnica con la \w sangre|strong="H1818"\w*.  
\v 32 \w Luego|strong="H4994"\w* \w enviaron|strong="H7971"\w* \w la|strong="H1931"\w* túnica \w de|strong="H1121"\w* rayas \w de|strong="H1121"\w* colores \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre y dijeron: \w Hallamos|strong="H4672"\w* \w esto|strong="H2063"\w*. \w Reconoce|strong="H5234"\w* y \w mira|strong="H4994"\w* \w si|strong="H3808"\w* \w es|strong="H1931"\w* \w o|strong="H3068"\w* \w no|strong="H3808"\w* \w la|strong="H1931"\w* túnica \w de|strong="H1121"\w* tu \w hijo|strong="H1121"\w*.   
\p
\v 33 \w Él|strong="H1121"\w* la reconoció y exclamó: ¡Es la túnica \w de|strong="H1121"\w* mi \w hijo|strong="H1121"\w*! Alguna \w mala|strong="H7451"\w* \w bestia|strong="H2416"\w* lo devoró. ¡Sin duda \w José|strong="H3130"\w* fue destrozado!   
\p
\v 34 \w Entonces|strong="H3117"\w* \w Jacob|strong="H3290"\w* \w rasgó|strong="H7167"\w* sus \w ropas|strong="H8071"\w*, \w se|strong="H5921"\w* cubrió \w con|strong="H5921"\w* tela áspera \w e|strong="H3068"\w* hizo duelo \w por|strong="H5921"\w* su \w hijo|strong="H1121"\w* durante \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*.  
\v 35 \w Todos|strong="H3605"\w* sus \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w* se \w levantaron|strong="H6965"\w* \w para|strong="H3588"\w* consolarlo, \w pero|strong="H3588"\w* \w él|strong="H3588"\w* rehusó ser consolado \w y|strong="H3588"\w* decía: ¡\w Descenderé|strong="H3381"\w* enlutado hasta mi \w hijo|strong="H1121"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* Seol! \w Y|strong="H3068"\w* \w su|strong="H3588"\w* padre \w lloraba|strong="H1058"\w* \w por|strong="H3588"\w* \w él|strong="H3588"\w*.   
\p
\v 36 Entre tanto, los madianitas lo \w vendieron|strong="H4376"\w* en \w Egipto|strong="H4714"\w* \w a|strong="H3068"\w* Potifar, funcionario \w de|strong="H8269"\w* \w Faraón|strong="H6547"\w*, \w capitán|strong="H8269"\w* \w de|strong="H8269"\w* la guardia.   
\c 38  
\s1 Judá y Tamar  
\p
\v 1 \w Aconteció|strong="H1961"\w* \w en|strong="H5704"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w que|strong="H1931"\w* \w Judá|strong="H3063"\w* \w se|strong="H1961"\w* apartó \w de|strong="H5704"\w* \w sus|strong="H1931"\w* hermanos \w para|strong="H5704"\w* establecerse \w con|strong="H5704"\w* un adulamita \w llamado|strong="H8034"\w* \w Hira|strong="H2437"\w*.  
\v 2 \w Judá|strong="H3063"\w* \w vio|strong="H7200"\w* \w allí|strong="H8033"\w* \w a|strong="H3068"\w* la \w hija|strong="H1323"\w* de cierto \w cananeo|strong="H3669"\w*, cuyo \w nombre|strong="H8034"\w* era \w Súa|strong="H7770"\w*, la \w tomó|strong="H3947"\w*, y se unió con \w ella|strong="H8033"\w*.  
\v 3 \w Concibió|strong="H2029"\w* y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*. \w Y|strong="H3068"\w* \w él|strong="H1121"\w* lo \w llamó|strong="H7121"\w* \w Er|strong="H6147"\w*.  
\v 4 \w Concibió|strong="H2029"\w* \w otra|strong="H5750"\w* vez y dio \w a|strong="H3068"\w* luz \w otro|strong="H5750"\w* \w hijo|strong="H1121"\w*, y lo \w llamó|strong="H7121"\w* Onán.  
\v 5 \w Volvió|strong="H3254"\w* \w a|strong="H3068"\w* concebir y dio \w a|strong="H3068"\w* luz \w otro|strong="H5750"\w* \w hijo|strong="H1121"\w*, y lo \w llamó|strong="H7121"\w* \w Sela|strong="H7956"\w*. \w Él|strong="H1121"\w* \w estaba|strong="H1961"\w* \w en|strong="H5750"\w* Kezib \w cuando|strong="H1961"\w* ella lo dio \w a|strong="H3068"\w* luz.   
\p
\v 6 Entonces \w Judá|strong="H3063"\w* \w tomó|strong="H3947"\w* esposa para \w Er|strong="H6147"\w* su \w primogénito|strong="H1060"\w*, y el \w nombre|strong="H8034"\w* de ella era Tamar.  
