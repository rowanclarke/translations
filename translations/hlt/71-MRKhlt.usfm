\c 4  
\s1 Cangti Tuh Nuettahnah  
\p
\v 1 \x - \xo 4.1 \xt Luk 5. 1-3.\x* \w Tuili|strong="G2281"\w* \w kaengah|strong="G3844"\w* \w khaw|strong="G2532"\w* \w thuituen|strong="G1321"\w* ham \w koep|strong="G3825"\w* a \w tong|strong="G0756"\w* \w tih|strong="G2532"\w* \w hlangping|strong="G3793"\w* loh \w a|strong="G0846"\w* \w taengah|strong="G4314"\w* a \w kumngai|strong="G4118"\w* a \w tingtun|strong="G4863"\w* pah. Te \w dongah|strong="G5620"\w* \w amah|strong="G0846"\w* te \w tuili|strong="G2281"\w* \w kah|strong="G1722"\w* \w lawng|strong="G4143"\w* \w khuiah|strong="G1519"\w* \w ngol|strong="G2521"\w* hamla \w kun|strong="G1684"\w*. Te \w vaengah|strong="G2532"\w* \w hlangping|strong="G3793"\w* \w tah|strong="G3588"\w* \w tuili|strong="G2281"\w* \w taengkah|strong="G4314"\w* \w lan|strong="G1093"\w* \w soah|strong="G1909"\w* \w boeih|strong="G3956"\w* \w om|strong="G2258"\w* uh.  
\v 2 Te \w vaengah|strong="G2532"\w* \w amih|strong="G0848"\w* te \w nuettahnah|strong="G3850"\w* \w neh|strong="G1722"\w* \w muep|strong="G4183"\w* a \w thuituen|strong="G1321"\w* \w tih|strong="G2532"\w* \w a|strong="G0846"\w* \w thuituennah|strong="G1322"\w* \w dongah|strong="G1722"\w* \w amih|strong="G0846"\w* te,  
\v 3 “\wj \+w Hnatun|strong="G0191"\+w* uh lah, cangti aka \+w tuh|strong="G4687"\+w* \+w tah|strong="G3588"\+w* cangti \+w tuh|strong="G4687"\+w* ham \+w cet|strong="G1831"\+w* \+w ne|strong="G2400"\+w*\wj*.  
\v 4 \wj A \+w tuh|strong="G4687"\+w* la a \+w om|strong="G1096"\+w* \+w vaengah|strong="G1722"\+w* a \+w ngen|strong="G3303"\+w* \+w tah|strong="G3739"\+w* \+w long|strong="G3598"\+w* \+w ah|strong="G3844"\+w* \+w tla|strong="G4098"\+w*. Te \+w dongah|strong="G2532"\+w* \+w vaa|strong="G4071"\+w* \+w loh|strong="G3588"\+w* a \+w paan|strong="G2064"\+w* \+w tih|strong="G2532"\+w* a \+w kueh|strong="G2719"\+w*\wj*.  
\v 5 \wj Te \+w phoeiah|strong="G2532"\+w* a \+w tloe|strong="G0243"\+w* tah \+w laimen|strong="G1093"\+w* \+w muep|strong="G4183"\+w* aka \+w om|strong="G2192"\+w* \+w pawh|strong="G3756"\+w* \+w lungrhong|strong="G4075"\+w* \+w soah|strong="G1909"\+w* \+w tla|strong="G4098"\+w* \+w tih|strong="G2532"\+w* \+w laimen|strong="G1093"\+w* a \+w dung|strong="G0899"\+w* la a \+w om|strong="G2192"\+w* \+w pawt|strong="G3361"\+w* \+w dongah|strong="G1223"\+w* \+w tlek|strong="G2117"\+w* \+w poe|strong="G1816"\+w*\wj*.  
\v 6 \wj \+w Tedae|strong="G2532"\+w* \+w khomik|strong="G2246"\+w* a \+w thoeng|strong="G0393"\+w* \+w vaengah|strong="G3753"\+w* a \+w kaeng|strong="G2739"\+w* \+w atah|strong="G2532"\+w* a \+w yung|strong="G4491"\+w* a \+w om|strong="G2192"\+w* \+w pawt|strong="G3361"\+w* \+w dongah|strong="G1223"\+w* \+w koh|strong="G3583"\+w*\wj*  
\v 7 \wj Te \+w phoeiah|strong="G2532"\+w* a \+w tloe|strong="G0243"\+w* tah \+w hling|strong="G0173"\+w* \+w khuiah|strong="G1519"\+w* \+w tla|strong="G4098"\+w*. \+w Hling|strong="G0173"\+w* \+w te|strong="G3588"\+w* \+w a rhoeng|strong="G0305"\+w* \+w vaengah|strong="G2532"\+w* \+w cangti|strong="G0846"\+w* te a \+w thing|strong="G4846"\+w* \+w tih|strong="G2532"\+w* a \+w thaih|strong="G2590"\+w* \+w thaii|strong="G1325"\+w* \+w pawh|strong="G3756"\+w*\wj*.  
