\c 24  
\s1 Good figs and bad figs  
\p
\v 1  \add The army of\add* \w King|strong="H4428"\w* \w Nebuchadnezzar|strong="H5019"\w* \w of|strong="H1121"\w* Babylon captured \w Jehoiachin|strong="H3204"\w*, \w the|strong="H6440"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*, \w and|strong="H1121"\w* \w his|strong="H3068"\w* \w officials|strong="H8269"\w*, \w and|strong="H1121"\w* \w all|strong="H7200"\w* \w his|strong="H3068"\w* \w skilled|strong="H2796"\w* \w workers|strong="H2796"\w* [DOU] \w and|strong="H1121"\w* \w took|strong="H4428"\w* \w them|strong="H6440"\w* \w to|strong="H3068"\w* Babylon. \w After|strong="H7200"\w* \w that|strong="H7200"\w* happened, \w Yahweh|strong="H3068"\w* gave \w me|strong="H6440"\w* \w a|strong="H3068"\w* \w vision|strong="H7200"\w*. \add In the vision\add* \w I|strong="H2009"\w* \w saw|strong="H7200"\w* \w two|strong="H8147"\w* \w baskets|strong="H1736"\w* \w of|strong="H1121"\w* \w figs|strong="H8384"\w* \w that|strong="H7200"\w* \w had|strong="H3068"\w* \w been|strong="H3068"\w* placed \w in|strong="H3068"\w* \w front|strong="H6440"\w* \w of|strong="H1121"\w* \w the|strong="H6440"\w* \w temple|strong="H1964"\w*.  
\v 2 \w One|strong="H3808"\w* \w basket|strong="H1731"\w* \w was|strong="H7451"\w* full \w of|strong="H7451"\w* \w good|strong="H2896"\w* \w figs|strong="H8384"\w*, \w like|strong="H3808"\w* \w the|strong="H3808"\w* \w kind|strong="H2896"\w* \w that|strong="H7451"\w* ripen first. \w The|strong="H3808"\w* other \w basket|strong="H1731"\w* \w was|strong="H7451"\w* filled \w with|strong="H2896"\w* \w figs|strong="H8384"\w* \w that|strong="H7451"\w* \w were|strong="H7451"\w* \w bad|strong="H7451"\w*/rotten, \w with|strong="H2896"\w* \w the|strong="H3808"\w* result \w that|strong="H7451"\w* \w they|strong="H3808"\w* could \w not|strong="H3808"\w* \w be|strong="H3808"\w* eaten.   
\p
