\v 20 \w No|strong="H3808"\w* \w habrá|strong="H1961"\w* \w más|strong="H5750"\w* \w allí|strong="H8033"\w* \w niño|strong="H5288"\w* \w de|strong="H3588"\w* \w días|strong="H3117"\w*, \w ni|strong="H3808"\w* \w viejo|strong="H2205"\w* \w que|strong="H3588"\w* sus \w días|strong="H3117"\w* \w no|strong="H3808"\w* \w cumpla|strong="H4390"\w*: \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w niño|strong="H5288"\w* \w morirá|strong="H4191"\w* \w de|strong="H3588"\w* \w cien|strong="H3967"\w* \w años|strong="H8141"\w*, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w pecador|strong="H2398"\w* \w de|strong="H3588"\w* \w cien|strong="H3967"\w* \w años|strong="H8141"\w*, \w será|strong="H1961"\w* maldito.   
