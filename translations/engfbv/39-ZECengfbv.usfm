\p 
\v 5 “Don't \w you|strong="H3045"\w* \w know|strong="H3045"\w* \w what|strong="H4100"\w* \w these|strong="H1992"\w* \w are|strong="H1992"\w*?” \w the|strong="H3045"\w* \w angel|strong="H4397"\w* \w replied|strong="H6030"\w*.
