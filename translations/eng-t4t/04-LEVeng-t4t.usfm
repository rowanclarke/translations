\c 27
\s1 Making promises about gifts to Yahweh
\p 
\v 1 \w Yahweh|strong="H3068"\w* \w also|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*,
\v 2 “\w Tell|strong="H1696"\w* \w the|strong="H3588"\w* Israeli \w people|strong="H1121"\w* \add that this is what I am saying to them\add*: \w If|strong="H3588"\w* \w anyone|strong="H5315"\w* solemnly promises \w to|strong="H1696"\w* dedicate another \w person|strong="H5315"\w* \w to|strong="H1696"\w* \add work solely\add* \w for|strong="H3588"\w* \w me|strong="H5315"\w*, \w the|strong="H3588"\w* \w person|strong="H5315"\w* \w who|strong="H3068"\w* \w is|strong="H3068"\w* dedicated \w to|strong="H1696"\w* \w me|strong="H5315"\w* \w is|strong="H3068"\w* \w allowed|strong="H3068"\w* \w to|strong="H1696"\w* \w be|strong="H3068"\w* free \w from|strong="H5315"\w* \w having|strong="H3588"\w* \w to|strong="H1696"\w* \w do|strong="H3068"\w* \w that|strong="H3588"\w* \w by|strong="H3068"\w* \w someone|strong="H5315"\w* paying \add to the priest\add* \w a|strong="H3068"\w* fixed amount \w of|strong="H1121"\w* money. \w The|strong="H3588"\w* money \w that|strong="H3588"\w* \w is|strong="H3068"\w* given \w must|strong="H1121"\w* \w be|strong="H3068"\w* calculated \w by|strong="H3068"\w* comparing \w it|strong="H3588"\w* \w with|strong="H3068"\w* \w the|strong="H3588"\w* official pieces \w of|strong="H1121"\w* silver \w in|strong="H3478"\w* \w the|strong="H3588"\w* Sacred Tent.
\v 3 \add These are the amounts that must be paid\add*:
\li2 50 pieces of silver for men who are between 20 and 60 years old,
\li2 
\v 4 30 pieces of silver for adult women \add who are between 20 and 60 years old\add*,
\li2 
\v 5 20 pieces of silver for young men who are between five and 20 years old,
\li2 ten pieces of silver for young women who are between five and 20 years old,
\li2 
\v 6 five pieces of silver for boys who are between one month and five years old,
\li2 three pieces of silver for girls who are between one month and five years old,
\li2 
\v 7 15 pieces of silver for men who are more than 60 years old,
\li2 ten pieces of silver for women who are more than 60 years old.
\p 
