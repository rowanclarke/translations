\id MRK - Okphela
\h iMaki
\toc1 iMaki
\toc2 iMaki
\toc3 iMak
\mt2 Usomhi Onete oyi iJesu iKirisiti ni
\mt1 IMaki
\mt2 Ọ kẹkẹ
\c 1
\s1 Itsabọ oyi iJọni Ọni ọọ batazi ẹgbọ
\r (iMat 3.1-12; iLuk 3.1-18; iJọn 1.19-28)
\p 
\v 1 Ona o khi igbaekẹle oyi usomhi onete oyi iJesu iKirisiti Omi Ẹshinẹgba.
\v 2 A kẹkẹ ọli shi Ebe-no-pfuasẹ ni ọmekẹguele ọyọli ni a lu Azaya ọ kẹkẹ. Ni Ẹshinẹgba ọ la liẹ,
\q1 “Mhi ya ghie aghiusomhi
\q2 ọyẹmhẹ ralo nẹ.
\q1 Ọni ọ ya bẹ odẹ
\q2 shi ekẹ khẹ.”\f + \fr 1:2 \ft Li zẹ \fq iMala 3.1\f*
\q1 
\v 3 “Ọgbọ ọ la ọdagbe
\q2 ẹ pfie okokokhuẹ. Ọọ liẹ,
\q1 ‘A riẹlẹ odẹ
\q2 shi ekẹ khẹ Ọnọmhuẹ,
\q2 ni ọ́ọ́ bhale.
\q1 Riẹlẹ oni odẹ sheshe
\q2 ni ọ rọte.’ ”\f + \fr 1:3 \ft Li zẹ \fq Aza 40.3\f*
\m 
\v 4 Ighọ IJọni ọ li bhale, ọọ batazi ẹgbọ obini ọdagbe ifufu, ọọ tse abọ, ọọ liẹ, “A mu pfi lase olamhẹ eyẹ ẹ le bhale deba Ẹshinẹgba ini a ri olamhẹ topfa ẹ.”
\v 5 Ighọ ẹgbọ e rọte ekẹ iJudia ali ẹoli iJerusalẹmu lẹ deba IJọni. Ee zọnọ olamhẹ eyẹwẹ yẹ ọli. Ọ la okẹ iJọdani batazi ẹgbọ.
\v 6 Ode ni a ri iriria eyi alakumi do, iJọni ọ rọ fia itsua sọ. Ọ ri ẹkuẹ riẹlẹ ọgbẹnẹ mu oku. Initso ali oribo e khi eminale eyọli.\f + \fr 1:6 \ft Li zẹ \fq 2 Ighie 1.8\f*
\v 7 Abọ ni ọọ tse gueyẹ agbọ khi: “Ọmọse ni ọ ke ya bhale ẹlẹlese odẹ ukhokho oyẹmhẹ, ọ fu dọsẹ mhẹ, ọ mhọli ekpabọ dọsẹ mhẹ. Mhi aa fu ramhi ọni ọọ taghiẹ uli ni o la ekuẹ ni ọ sọ-a.
\v 8 Amẹ mhi rọ batazi ẹ memena, ama Ayẹmhẹ-nọ-pfuasẹ ọ ke rọ ya batazi ẹ.”
\s1 Ibatazi ali imufẹ oyi iJesu
\r (iMat 3.13--4.11; iLuk 3.21-22; 4.1-13)
\p 
\v 9 Ọa te aghọ tẹsẹ ne, ni iJesu ọ rọ rọte iNazarẹti ni o la ekẹ iGalili bhale ni iJọni ọ la okẹ iJọdani batazi ọli.
\v 10 Abi iJesu ọ rọ lẹsẹ rọte elemhi okẹ ji egbe ngale te, ọ mẹ khi idane ọ khueghie. Ayẹmhẹ oyi Ẹshinẹgba ọ li abi anekhukhu rọte idane tiemhile ya ma li egbe.
\v 11 A suọ khi uruli o rọte idane ngme tiemhile, ọọ, “Omimhẹ ni mhi nono ingme oyọli u khi. U ma ri egbe ẹ mu mhẹ gba.”\f + \fr 1:11 \ft Li zẹ \fq Igbae 22.2; Iwolo 2.7; Aza 42.1; iMat 3.17; 12.18; iMak 9.7; iLuk 3.22\f*
\p 
\v 12 Utoghuokpe, Ayẹmhẹ oyi Ẹshinẹgba o rue iJesu je ọdagbe.
\v 13 Ogbẹlẹ egbhuẹva ọ la oobọ. Ọkphaghiẹ, ni ọ khi oghie ayẹmhẹ ebe, ọ mu ọli fẹ. IJesu ọ nu elamhakọ la oobọ, ama igẹni eyi Ẹshinẹgba e ri ukpẹloe e khu ọli.
\s1 Eniyẹ odukhokho eni ododẹ ni iJesu ọ zẹ
\r (iMat 4.12-22; iLuk 4.14-15; 5.1-11)
\p 
\v 14 Abi a rọ mu iJọni shi owa ighumha se, iJesu ọ je iGalili ya tse abọ usomhi onete oyi Ẹshinẹgba.
\v 15 Ọọ liẹ, “Oni ẹghẹghẹ o she bhale, Eghiele oyi Ẹshinẹgba o she ti mama awa. A mu pfi lase olamhẹ eyẹ ẹ le, ni a mie oni usomhi onete suọ.”\f + \fr 1:15 \ft Li zẹ \fq iMat 3.2\f*
\p 
\v 16 Abi iJesu ọ rọte epfepfẹ okẹ oniẹmhi oni o khi shi, na lui iGalili kia lẹ, ọ mẹ iSamọ ali inyọghuo ọli Aduru. Egbifẹlẹ e khi. E pfi aga lo elemhi oni okẹ, ee gbe ifẹlẹ.
\v 17 IJesu ọọ wẹ, “A deba mhẹ, mhi ya sẹsẹ e abi a ke liẹ ke ti ẹgbọ gbili.”
\v 18 Aghọaghọ e ku iga eyẹwẹ shi ekẹ, ẹ deba li.
\p 
\v 19 Ọ̀ ke te aghọ je odalo dẹnẹ, ọ gbo mẹ inyọghuo etuava, iJemhisi ali iJọni imi iZebedi e la elemhi ọkọ-okẹ oniẹmhi, e zu iga eyẹwẹ.
\v 20 Abi iJesu ọ rọ lẹsẹ mẹ wẹ, o lu wẹ e deba luẹ, aghọaghọ e pfi itawẹ ali ẹgbọ ni e nu wẹ ye shi elemhi ọkọ-okẹ oniẹmhi, e deba li vu.
\s1 IJesu ọ khu ọmọse ayẹmhẹ ebe egbe-a
\r (iLuk 4.31-37)
\p 
\v 21 IJesu ali eniyẹ odukhokho eyọli e bhale ẹoli iKapanọmu. Ogbẹlẹ iyẹmhẹa ni o ke deba li, iJesu ọ dọsẹ lo elemhi owa ugamhi, ọ la aghọ sẹsẹ.
\v 22 O ri abọ sha ẹgbọ ni e ri esọ kpe abi ọ li sẹsẹ, itobọ khi eri ọ sẹsẹ ẹgbọ abi ọgbọ ni ọ lẹsẹ emini ọọ sẹsẹ, osẹsẹ oyọli o kiọda shi oyi eni e sẹsẹ Ishi eyi iMosisi.\f + \fr 1:22 \ft Li zẹ \fq iMat 7.28-29\f*
\p 
\v 23 Utoghuo kpe ọmọse ni ayẹmhẹ ebe o la egbe, ọ lo elemhi oni owa ugamhi le. Ọ́ tsẹsẹ gbaa! Ọọ,
\v 24 “Elọ wa nono anye egbe, iJesu na iNazarẹti? Eri u bhale ya pfuse anye-a? Mhi ga lẹsẹ ọni u khi. Ọni Ọ pfuasẹ ọyi Ẹshinẹgba u khi.”
\p 
\v 25 IJesu ọ́ dese oni ayẹmhẹ obe, ọọ li, “Guese unu pia, te ọli egbe lase le.”
\v 26 Oni ayẹmhẹ obe o nighise ọni ọmọse, o mu ọli pfi gbe. Ọ pfie okokokhuẹ, o rọte ọni ọmọse egbe ya lase.
\p 
\v 27 O ga ri abọ sha ẹgbọ nya. E mhila egbe wẹ, “Onoghuo na? Osẹsẹ onogbọ ni o mhọli ekpabọ! Eri ọ ga nu ayẹmhẹ ebe ẹ ngme, e ga suọ esọ na li.”
\v 28 Aghọaghọ ingme oyi iJesu o gbe ekẹ-a asha kpa ekẹ iGalili.
\s1 IJesu ọ ri ebubu ẹgbọ ze
\r (iMat 8.14-17; iLuk 4.38-41)
\p 
\v 29 IJesu ali eniyẹ odukhokho eyọli, ghe iJemhisi ali iJọni, e ga rọte owa ugamhi fiẹ lasele, e ya je apfẹ oyi iSamọ ali Aduru
\v 30 Ọgọ iSamọ ọni ọkpotso, ọ yẹshi ghua ughuamhi iba. IJesu ọ lẹsẹ ramhi aghọ, a gue ingme oyọli yẹ iJesu.
\v 31 Ighọ ọ lo deba li, ọ mu ọli obọ, ọ mu ọli ukpho vule. Ighọ eni iba e lase ọli egbe le. Ọ fẹli wẹ epfẹse.
\p 
\v 32 Ẹlogbọmhi ẹlẹghọ khi ovọ ọọ tiemhi eko, ẹgbọ e tsua eni ẹa ze, ali eni iyẹmhẹ ọkphaghiẹ e yẹsẹ ngme bhale ghi iJesu.
\v 33 Ẹgbọ nya ni e la oni ẹoli e le gba odalo oni owa.
\v 34 IJesu ọ ri eni ẹ ghua, ighuamhi khi ighuamhi, ze. Ọ khu ayẹmhẹ ebe ebubu ẹgbọ egbe a, ama ọa zẹ ni eni ayẹmhẹ ebe eghọ e ngme emhikhọghuo unu lasele, itobọ khi e lẹsẹ ọni ọ khi.
\s1 IJesu ọ la iGalili tse abọ usomhi onete
\r (iLuk 4.42-44)
\p 
\v 35 Ogbiẹ-fiefie ogbeakọlọ khi obili ọa pfo ogbe ne, iJesu ọ fiẹ lase je ashini o da-ya, ọ ya sọ iromhi.
\v 36 ISamọ ali apfọli ni e kpọle, e vu ya nono ọli.
\v 37 Abi e rọ mẹ ọli, ẹẹ ọli, “Ẹgbọ kpa ẹẹ nono ẹ.”
\p 
\v 38 IJesu ọọ wẹ, “Awa mema ya je ẹoli oboese, ikhi apfẹ eni e timama akana, ni mhi li la oobọ tsẹ abọ, irari khi ona o zẹ ni mhi rọ bhale.”
\v 39 Ighọ ọ kia gasẹ ekẹ iGalili nya tse abọ. Ọ la owa ugamhi eyẹwẹ tse abọ. Ọ khu ẹgbọ ayẹmhẹ ebe egbe ku-a.\f + \fr 1:39 \ft Li zẹ \fq iMat 4.23; 9.35\f*
\s1 IJesu ọ ri ọni efafe e mu ze
\r (iMat 8.1-4; iLuk 5.12-16)
\p 
\v 40 Ọmọse ni efafe e mu ọ bhale deba iJesu. Ọ wugha li odalo, ọọ lema li, ọọ, “Ini o ghọle ẹ, u dobẹ ya rẹmhẹ ze, u rẹmhẹ khi ọni ọ pfuasẹ.”
\p 
\v 41 Ighọ elemhi ọli, ee ala iJesu, ọ nise obọ-a ti ọni ọmọse, ọọ li, “O ghọle mhẹ, khi ọni ọ pfuasẹ.”
\v 42 Aghọaghọ eni efafe e lase ọli egbe le, ọ ze, ọ khi ọni ọ pfuasẹ.
\p 
\v 43 IJesu ọ́ gueyẹ ọli, ọ ke vu. Ọ lolo tse agua ye ọli,
\v 44 ọọ li, “Khi gue ingme ona yẹ ọgbọkhọghuo, ama lẹ ya ri egbe ẹ khasẹ ekpodalo-ugamhi eyi Ẹshinẹgba, ni e tẹ ọkpẹ ne, ni u luasẹ obo ni iMosisi ọọ a ke luasẹ, ini a ri ọgbọ lina ze. Isheghọ, ni o khi ọtsẹlẹ na wẹ khi u she ze.”\f + \fr 1:44 \ft Li zẹ \fq iLẹv 14.1-32\f*
\p 
\v 45 Eri ọni ọmọse ọ ri ochoghọ ngme ọli kiakiala gboo, ọ miatsẹ oni ingme onete ku asha kpa. Itobọ ona, iJesu ọa ke dobẹ lo ẹoli okhọghuo le gboo. Eri ọ ke la ọdagbe obini o da-ya. Abi o riẹ khi ighọ, eri ẹgbọ nya e kie rọte asha kpa ẹ bhale deba li.
\c 2
\s1 IJesu ọ ri ọmọse ni ọ guọghọ-a ze
\r (iMat 9.1-8; iLuk 5.17-26)
\p 
\v 1 Ikuku ogbẹlẹ e dọsẹ, iJesu ọ gbo lo elemhi iKapanọmu, eni ẹgbọ e suọ khi ọ she bhale apfẹ.
\v 2 Ebubu ẹgbọ e le gba ramhi ni ọgbọ a ke mẹ ashikhọghuo ni o kpọle, ya ramhi olase unu-odẹ. IJesu ọ tse abọ oni usomhi yẹ wẹ.
\v 3 Ighọ emọse aane e tsua ọmọse ni ọ guọghọ-a adigege shi iya bhale ghi iJesu.
\v 4 Abi eni emọse ẹa rọ mẹ asha tsua li lole ashini iJesu ọ la, itobọ ẹgbọ ni e ghọ bu dọsẹ, e nga ukhomhi oni owa rọte ashini iJesu ọ la gbese ekpha-a. Abi e rọ gbese ọlia se, e ri ili ri ọni ọmọse tiemhile, abi ọ́ kie li yẹshi iya.\fig Ọmọsẹ ni a gbese ekpha-a rọ tiemhile deba iJesu|src="DN00444b.tif" size="col" loc="MRK 2.4" copy="Dunham" ref="2.4"\fig*
\v 5 Abi iJesu ọ rọ mẹ irudunga oyẹwẹ, ọọ ọni ọmọse ni ọ guọghọ-a, “Omimhẹ, a she ri olamhẹ topfa ẹ.”
\p 
\v 6 Ama eni ẹ sẹsẹ Ishi eyi iMosisi ni e shitọ akaghọ, e sa ọ udu oyẹwẹ, e liẹ,
\v 7 “Elọ o zẹ ni ọni ọgbọ ọna ọ rọ ngme ungmemhi onana unu. Eri ọ pfi unu-a! A li mẹ ọni ọ dobẹ ya gbe olamhẹ kua na ọgbọ? Ọa khi Ẹshinẹgba luẹghuo?”
\p 
\v 8 Aghọaghọ iJesu ọ she lẹsẹ elemhi ayẹmhẹ oyọli emini e sa shi elemhi udu oyẹwẹ, ọọ wẹ, “Elọ o zẹ ni a rọ sa usamhi onana.
\v 9 Onoghuo o kẹlẹ nẹ, ni a rọ liẹ ọni ọmọse ni ọ guọghọ-a, ‘A ri olamhẹ topfa ẹ,’ abi khi ‘Vule, rue iya oyẹ ni u ke kia’?
\v 10 Mhi ya rọ li khasẹ ẹ khi Omi Ọgbọ ọ mhọli ekpabọ elemhi agbọ ona ni ọ rọ gbe olamhẹ kua na ọgbọ.” Ighọ ọ gueyẹ ọni ọmọse ni ọ guọghọ-a eghọ,
\v 11 “Mhiẹ yẹ u vule, u rue iya oyẹ, u ke je apfẹ.”
\p 
\v 12 Ọni ọmọse ọ vule, ọ rue iya oyọli, ọ la akpẹwẹ nya kia vu. O ri abọ sha ẹgbọ kpa. Ee kuẹghiẹ Ẹshinẹgba, e liẹ, “Anye ẹa kpẹ mẹ onana ghue oo!”
\s1 IJesu ọ lu iLẹvi
\r (iMat 9.9-13; iLuk 5.27-32)
\p 
\v 13 IJesu ọ gbo je epfẹ okẹ oniẹmhi ni o khishi. Ebubu ẹgbọ e bhale deba li, ọ sẹsẹ wẹ.
\v 14 Abi ọ kia lẹ, ọ mẹ ọmionoga iLiva omi Afeusi khi ọ shitọ okholo eyi eni ẹ mie oga. IJesu ọọ li, “Deba mhẹ.” Ighọ ọ vule deba li.
\p 
\v 15 Abi iJesu ọ la ayi iLẹvi le eminale ẹlogbọmhi, emionoga ni e bu ali ẹgbọ ena olamhẹ e li nu ọli ali eniyẹ odukhokho eyọli le emhi, irari khi ẹgbọ ni e bu e deba li.
\v 16 Abi ẹgbọ eni ẹẹ sẹsẹ ishi na lui iFarisi e rọ mẹ khi iJesu ọ nu egbushia ali emionoga ẹ le eminale, e mhila eniyẹ odukhokho eyọli, “Elọ o zẹ ni ọ rọ nu emionoga ali egbushia ẹ le eminale?”
\p 
\v 17 IJesu ọ suọ onana, ọọ wẹ, “Ẹgbọ ni e ze ẹa mhuẹ emini e ri ọbo ẹ li. Ọni ọọ to, ọ́ ye apfẹ ọbo. Ọa khi eni e pfuasẹ ne mhi bhale ya lu, ama egbushia.”
\s1 Omhila ingme azumhi
\r (iMat 9.14-17; iLuk 5.33-39)
\p 
\v 18 Ẹghẹghẹ oghuo eniyẹ odukhokho eyi iJọni Ọni ọọ batazi ẹgbọ ali ẹgbọ iFarisi ee pfi azumhi. Ẹgbọ eghuo e bhale ya mhila iJesu, ẹ ọli, “Elọ o zẹ ni eniyẹ odukhokho eyi iJọni ali enayi ẹgbọ iFarisi e rọ pfi azumhi ni eyẹ ẹa rọ́ pfi?”
\p 
\v 19 IJesu ọ sọ wẹ ọ, ọọ wẹ, “Sẹ epfẹse eyi ọmọse ni ọ rue ọmueshi ọnọgbọ e liẹ ke pfi azumhi ini oni ọmọse ọ kie nu wẹ shitọ? Ẹa mẹ asha pfi azumhi ini ọ kie nu wẹ shitọ.
\v 20 Ama ẹghẹghẹ o ya bhale ni a rọ rue ọni ọdọ ọni ọmueshi vu. Ẹghẹghẹ aghọ, e rọ tigbe ya ke pfi azumhi.
\p 
\v 21 “Ọgbọ a ya khi ode onogbọ gbẹla ma ode onodiọ. Ini u lighọ, eri oni ode onogbọ o ya nyanọ oni ode onodiọ-a. O ke nyanọ-a dọsẹ abi o kpẹ li.
\v 22 Ali khi ọgbọ ọa ya ku onyọ onogbọ shi akpaba onodiọ. [Ikhi akpaba ni ẹgbọ iJu e ku onyọ shi.] Ini u lighọ, eri oni onyọ o ya vẹsẹ oni akpaba-a. Oni onyọ ali oni akpaba e ga li opfu-a. Akpaba onogbọ a ku onyọ onogbọ ẹ lo.”
\s1 Ọnọmhuẹ ọyi ogbẹlẹ iyẹmhẹa
\r (iMat 12.1-8; iLuk 6.1-5)
\p 
\v 23 Ogbẹlẹghuo ẹlẹ iyẹmhẹa oyi ẹgbọ iJu, iJesu ọ rọte ifui ishemhi iakpa kia dọsẹ. Eniyẹ odukhokho eyọli e li nu ọli kia. Ighọ e li bẹ eni iakpa.\f + \fr 2:23 \ft Li zẹ \fq iDẹut 23.25\f*
\v 24 Ighọ iFarisi e mhila iJesu, “Elọ o zẹ khi eniyẹ odukhokho eyẹ ẹẹ riẹlẹ emini a ghuẹ ẹlẹ iyẹmhẹa?”
\p 
\v 25 IJesu ọ sọ wẹ ọ, ọọ, “Aa kpẹ mẹ ọli zẹ Ebe-no-pfuasẹ emini Oghie iDefidi ọ riẹlẹ abi okiamhi o rọ gbe ọli ali eni e nu ọli kia?
\v 26 Ẹghẹghẹ ni Abiata ọ rọ khi Ọkpeda na ekpodalo-ugamhi eyi Ẹshinẹgba, ni Oghie iDefidi ọ rọ lo Owa oyi Ẹshinẹgba ya rue ibulẹdi ni a rọọ ga Ẹshinẹgba le, ọ kholo na eni e nu ọli kia le. Ibulẹdi ona ighie eyi ekpodalo-ugamhi tsẹ, ushi o lama e ke le wẹ.”\f + \fr 2:26 \ft Li zẹ \fq iLẹv 24.9\f*\f + \fr 2:26 \ft Li zẹ \fq 1 iSam 21.1-6\f*
\p 
\v 27 Ighọ ọọ wẹ, “Eri a ma ogbẹlẹ iyẹmhẹa na ọgbọ, aa ma ọgbọ na ogbẹlẹ iyẹmhẹa.
\v 28 Itobọ ighọ, Omi Ọgbọ ọ khi Ọnọmhuẹ, li shi ọyi ogbẹlẹ iyẹmhẹa.”
\c 3
\s1 Ọmọse ni ọ ghu obọ oghuo-a
\r (iMat 12.9-14; iLuk 6.6-11)
\p 
\v 1 Ẹlẹlese khi iJesu ọ gbo je owa ugamhi, ọmọse ni obọ oyọli oghuo o ghua, ọ la akaghọ.
\v 2 Ẹgbọ eghuo e nono ashini e te ya mẹ asha gue ingme shi iJesu egbe. E ri ukpẹloe shi ọli egbe ini ọ ya ri ọgbọ ze ẹlẹ iyẹmhẹa.
\v 3 IJesu ọọ ọni ọmọse ni ọ ghu obọ-a, “Vule migha odalo oyi ẹgbọ kpa.”
\p 
\v 4 IJesu ọ mhila wẹ, “Onoghuo o gbe akanya elemhi ushi oyawa nẹ ẹlẹ Iyẹmhẹa? Ni a rọ riẹlẹ onete abi ni a rọ riẹlẹ onobe? Ni a rọ tsumhi agbọ oyi ọgbọ abi ni a rọ pfuse ọlia?” Ama e tsaghiẹ a.
\p 
\v 5 Ighọ iJesu ọ ri elemhi ibibi bino wẹ gasẹ, udu oyọli o yese-a shi udu obe ni e mhuẹ. Ọọ, “Nọmọse nise obọ-a.” Ọ nise ọli-a. Ighọ obọ oyọli o gbo li abi o kpẹ te ekẹ li
\v 6 Ighọ ẹgbọ iFarisi e fiẹ deba eniyẹ odukhokho eyi Erọdu, e ya gba ugbamhi abi e li ya gbe iJesu-a.
\s1 Ebubu ẹgbọ e deba iJesu
\p 
\v 7 Ighọ iJesu ali eniyẹ odukhokho eyọli e lase wẹ iteva le ya je okẹ na iGalili. Ebubu ẹgbọ e rọte iGalili deba iJesu.
\v 8 Abi e rọ suọ emini ọ riẹlẹ, ebubu ẹgbọ e bhale deba li, rọte ekẹ iJudia ali iJerusalẹmu, ali Idumia ali ekẹ ni o kpe obọ na iJọdani ali epfepfẹ iTirẹ ali iSidọni.
\v 9 Itobọ khi eni ẹgbọ e bu dọsẹ, iJesu ọ gueyẹ eniyẹ odukhokho eyọli e nono ọkọ-okẹ oni ikeke ni lọli lo ọ ini ẹgbọ e khi sha mu luẹ.
\v 10 Itobọ khi ọ she kpẹ ri ebubu ẹgbọ ze, ẹgbọ eni ẹa ze, e mise egbe ini e mẹ asha ramhi ọli egbe ri obọ ti ọli.\f + \fr 3:10 \ft Li zẹ \fq iMak 4.1; iLuk 5.1-3\f*
\v 11 Ẹghẹghẹ kpa ni ẹgbọ ni ayẹmhẹ ebe e yẹsẹ ẹ ngme e rọ da mẹ iJesu ne, e de ya yẹshi ekẹ odalo oyọli. Ẹẹ tsẹsẹ, ẹẹ liẹ, “Omi Ẹshinẹgba u khi.”
\p 
\v 12 Ama, ọ tse agua yẹ eni ayẹmhẹ ebe eghọ e khi gue ọni lọli khi le.
\s1 IJesu ọ zẹ ighiusomhi na kẹ ogbava
\r (iMat 10.1-4; iLuk 6.12-16)
\p 
\v 13 IJesu ọ nga ukhomhi ute, ọ lu emọse ni e ghọle ọli. E bhale deba li.
\v 14 Ọ ya zẹ ẹgbọ ogbava kẹ, ọ lu wẹ ighiusomhi na kẹẹ. Ọ zẹ wẹ ni e nu luẹ ke kia, ali ni luẹ mẹ wẹ ke ghie usomhi fiẹ ke tse abọ usomhi onete,
\v 15 ali ni e gbo mhuẹ ekpabọ ni e rọ ke khu ẹgbọ ayẹmhẹ ebe egbe kua.
\v 16 Ena e khi otuogbava ni ọ zẹ. ISamọ, ọni iJesu ọ lu iPita.
\v 17 IJemhisi ali inyọghuo-ọli iJọni imi iZebedi (eni iJesu ọ ri akiseva iBonajisi na. Ni o migha shi Imi Akphala),
\v 18 Ali Aduru, iFilipu, iBatolomiu, iTọmọsi, iJemhisi omi Afeusi, ali iTadiusi, iSamọ [ọni ije-odalo oyi ẹdẹli iJu oo ghọ mu egbe.]
\p 
\v 19 Ali iJudasi Isikarọti ọni ọ ri iJesu dẹ.
\s1 IJesu ali iBezebọ
\r (iMat 12.22-32; iLuk 11.14-23; 12.10)
\p 
\v 20 IJesu ọ nyenẹ egbe je apfẹ. Ighọ ebubu ẹgbọ e gbo tigbili ramhi khi iJesu ali eniyẹ odukhokho eyọli ẹa mẹ asha, wẹ khi eminale e ya le.
\v 21 Abi apfẹ ọ e rọ suọ ona, E nono khi wẹwẹ e ya mu ọli je apfẹ. Irari khi eri e liẹ, “Ujili o she ẹ kpha li.”
\p 
\v 22 Eni ẹẹ sẹsẹ ishi ni e rọte iJerusalẹmu tiemhie, e liẹ, “Ayẹmhẹ iBezebọ ni ọ khi Ọkphaghiẹ o la li egbe yẹsẹ ọli ẹ ngme! Lọli ọ khi oghie ọyi iyẹmhẹ ebe ni ọ ri ekpabọ na li ni ọ rọ ke khu ẹgbọ iyẹmhẹ ebe egbe kua.”\f + \fr 3:22 \ft Li zẹ \fq iMat 9.34; 10.25\f*
\p 
\v 23 Ighọ iJesu ọ lu wẹ, ọ ri okhẹ irọkhọkhọ nu wẹ ngme, Ọọ wẹ, “Sẹ ọkphaghiẹ ọ liẹ ke khu ọkphaghiẹ?
\v 24 Ini ushishi e kemhi egbe wẹ shi ikui-iku ni e rọ nu egbe wẹ ẹ khọli, eri oni ushishi ọọ de.
\v 25 Ini ọmhuẹ-apfẹ o kemhi shi ikui-iku ni e rọ nu egbewẹ ẹ khọli, eri oni ọmhuẹ-apfẹ o ya de.
\v 26 Ini ọkphaghiẹ ọ mu okhọli vule shi egbọli ọ, ọa ya tọ, eri ọ ya de, ukpẹsẹ oyọli o she ramhi.
\p 
\v 27 “Ọgbọ ọkhọghuo ọa la ọ ni ọ dobẹ ya lo owa oyi ọmọse-akama ya ti ọli itsua ekẹ-a ini ọa kpẹ mu ọni ọmọse-akama gẹ shi ekẹ. Ẹghẹghẹ aghọ, ọ tigbe dobẹ ti ọli itsua ekẹ-a.
\p 
\v 28 “Egbegbi ingme mhi gueyẹ ẹ, khi, aa mẹ olamhẹ ni ọgbọ ọ lamhẹ ali ungmemhi ipfiunu-a ni ọgbọ ya ngme, ni aa dobẹ rọ ya gbekua na li.
\v 29 Ama ọnini ọ da ngme ungmemhi ipfiunu-a deba Ayẹmhẹ-nọ-pfuasẹ ne, aa ya rọ topfa li, irari khi olamhẹ ona agbọagbọ ọ pfi obọ lo.”\f + \fr 3:29 \ft Li zẹ \fq iLuk 12.10\f*
\p 
\v 30 Itobọ khi ẹ ọli khi, “Ọ mhọli ayẹmhẹ ebe,” ọ rọ ngme ona.
\s1 Inyọ iJesu ali inyọghuo ọli eni emọse
\r (iMat 12.46-50; iLuk 8.19-21)
\p 
\v 31 Ighọ inyọ iJesu ali inyọghuo ọli ee bhale. E migha oolase. E ghie ọgbọ ọ ka lu iJesu ghi ẹwẹ.
\v 32 Ebubu ẹgbọ e shitọ gasẹ ọli. E bhale ya gueyẹ ọli khi inyọli ali inyọghuo ọli e la oolase, khi ẹẹ nono ni wẹwẹ e mẹ ọli.
\p 
\v 33 Ọ mhila wẹ, “Eghuo e khi inyẹmhẹ ali Inyọghuo-mhẹ?”
\p 
\v 34 Ighọ ọ bino eni e shitọ gasẹ ọli, ọọ, “Enana e khi inyẹmhẹ ali Inyọghuo-mhẹ!
\v 35 Ọnini ọ́ da riẹlẹ emini e ghọle Ẹshinẹgba, ọ khi Inyọghuo-mhẹ ọnọmọse ali ọnọkpotso ali inyẹmhẹ.”
\c 4
\s1 Okhẹ irọkhọkhọ oyi ọni ọ kọ ikpamhi emhi
\r (iMat 13.1-9; iLuk 8.4-8)
\p 
\v 1 IJesu ọ ke gbo la epfẹ okẹ ni o khi shi na iGalili sẹsẹ. Ẹgbọ ni e le gasẹ ọli e bu dọsẹ ramhi ni ọ rọ ya lo elemhi ọkọ-okẹ shitọ. Oni ọkọ-okẹ o la elemhi oni okẹ. Eni ẹgbọ e ke migha egele esesọ oni okẹ.\f + \fr 4:1 \ft Li zẹ \fq iLuk 5.1-3\f*
\v 2 Emhi ebubu ọ ri okhẹ irọkhọkhọ ọ sẹsẹ wẹ. Ọọ wẹ.
\v 3 “A ghe i! Ọghiale ọ́ ya la ọ. Ọ fiẹ yá kọ iakpa.
\v 4 Abi ọ li kia miatsẹ eni iakpa, ikpamhi eghuo ọ e de kua odẹ, ighọ ipfeli e bhale ya sanọ wẹ le.
\v 5 Eghuo ọ, e de kushi ekẹ ni o khi ọkpegbhẹ, ni ekẹ ẹa lolo la. Ighọ e nyanya zẹ, e fu, ama oni ekẹ ọa limhi.
\v 6 Ama abi ovọ o rọ to, o tosẹ wẹ a, e khakha, itobọ khi ẹa mẹ ekẹ ni o limhi pfi imhili lo.
\v 7 Ikpamhi emhi elese e de kulo ifui igba. Ighọ igba e zẹ lasele tono eni iakpa abi e rọ fu vule. Itobọ ighọ, ẹa ke dobẹ ni e fu nyanọ ekhẹ lasele.
\v 8 Ama ikpamhi eghuo, e de shi ekẹ onete. Eni ikpamhemhi e zẹ, e fu, e nyanọ ekhẹ lasele. Eghuo ọ, e mhuẹ ikpamhi uye ali igbe, eghuo ọ, e mhuẹ ikpamhi egbhuẹsẹ, elese e mhuẹ egbhuẹshe.”
\p 
\v 9 Ighọ iJesu, ọọ, “Ọni ọ mhọli esọ, ọ suọ.”
\s1 Emini o zẹ ni a rọ zẹ oni okhẹ irọkhọkhọ
\r (iMat 13.10-17; iLuk 8.9-10)
\p 
\v 10 Abi iJesu lọlighuo ọ rọ shitọ, eniyẹ odukhokho ogbava eyọli ali ẹgbọẹse ni e li suọ abi ọ rọ ngme, e bhale deba li, ọ gueyẹ wẹ emini ọ ri oni okhẹ irọkhọkhọ ngme.
\v 11 Ọọ wẹ, “A she ri osheli oyi Eghiele oyi Ẹshinẹgba na ẹ. Ama okhẹ irọkhọkhọ a rọ gue ungmemhi nya yẹ ẹgbọẹse.
\v 12 Ni a bhale ya ẹ khi,
\q1 “ ‘E kha riẹ nya alo-a shi ekẹ
\q2 ẹa tigbe ya mẹ emhikhọghuo,
\q1 ali e kha riẹ ku esọ a shi ekẹ,
\q2 ọa ya lo wẹ esọ.
\q1 Irari khi ini ọa khi ighọ,
\q2 e dobẹ mẹ ekẹ, e suọ esọ,
\q1 e mu pfi deba Ẹshinẹgba,
\q2 ọ rọ topfa wẹ.’ ”\f + \fr 4:12 \ft Li zẹ \fq Aza 6.9,10\f*
\s1 IJesu ọ guele emini oni okhẹ irọkhọkhọ o ngme
\r (iMat 13.18-23; iLuk 8.11-15)
\p 
\v 13 IJesu ọ mhila wẹ, ọọ wẹ, “Aa lẹsẹ emini a ri okhẹ irọkhọkhọ ona ngme? Sẹ a li tigbe ya lẹsẹ emini a ri okhẹ irọkhọkhọ okhọghuo ngme shọ?
\v 14 Eni iakpa ni ọni ọghiale ọ miatsẹ ẹ ku, e migha shi ungmemhi oyi Ẹshinẹgba.
\v 15 Eri ikpamhi iakpa ni e de shi odẹ e li abi ẹgbọ eghuo ni e kha da lẹsẹ suọ oni ungmemhi ne, Ọkphaghiẹ ọ bhale ya rue wẹ luẹ udu le.
\v 16 Ikpamhi emhi ni e de shi ekẹ ni o li echechẹ, e li abi ẹgbọ ni e kha da lẹsẹ suọ oni ungmemhi ne, e ri udu oghẹlẹ mie ọli.
\v 17 Ama, ọa ya tiemhi wẹ ekẹ elemhi. Ẹa dobẹ migha tẹsẹ, itobọ khi ọa pfi imhili lo ekẹ. Itobọ ighọ, ini ọmunu o bhale ali ni a rọ mu okhọli vule shi wẹ ọ rọte oni ungmemhi ni e suọ, e kẹlẹ de odẹ-a.
\v 18 Ikpamhi emhi ni e de pfilo ifui igba eri e li abi ẹgbọ ni e kha suọ oni ungmemhi,
\v 19 isamhi ingme agbọ ona, ali ọghuẹmhẹ ẹpfue, ali ọghuẹmhẹ khi ọghuẹmhẹ e lu guese oni ungmemhi-a, ẹẹ tono ọli igba, itobọ ighọ ọa mọ imọmhi.
\v 20 Ama ikpamhi emhi ni e de shi ekẹ onete, e li abi ẹgbọ ni e suọ ungmemhi, e mie ọli suọ, e mọ imọmhi enete. Eghuo e mhuẹ ikpamhi uye ali igbe, eghuo e mhuẹ egbhuẹsẹ. Eghuo, e mhuẹ egbhuẹshe.”
\s1 Ákpá ni a rọ nga ukhomhi asha
\r (iLuk 8.16-18)
\p 
\v 21 IJesu ọ gbolo ẹ wẹ “Ọgbọkhọghuo ọ̀ọ́ ya ri ákpá ru lasele, ọ ya rue atalabi guese ọli mu ekẹ, wẹkhi eri ọ ke ya rue ọli ya sheli ufui ukpho?\f + \fr 4:21 \ft Li zẹ \fq iMat 5.15; iLuk 11.33\f*
\v 22 Emiemini a rọ sheli, o ya lasele gbo alo gbugbugbu. Aa mẹ emhi osheli ni aa ya khueghie a.\f + \fr 4:22 \ft Li zẹ \fq iMat 10.26; iLuk 12.2\f*
\v 23 Ọnini ọ mhọli esọ, ọ ri esọ shi ekẹ ni ọ suọ.”
\p 
\v 24 Ọ gbolo ẹ wẹ, “Emiemini u da suọ kpa, sa ọ bie! Emiemini u da rọ shi ushi rọ gue ẹgbọẹse ẹzọ, Ẹshinẹgba ọ li ya rọli gue ẹ ẹzọ. Oyẹ o gbo ya ze nẹ.
\v 25 Ọni ọ kpẹ mhọli ne, a ya gbo rọ ma ọ na li, ama ọni ọa mhọli a ya mie ọli ukukuọ ni ọ gbo mhọli.”\f + \fr 4:25 \ft Li zẹ \fq iMat 13.12; 25.29; iLuk 19.26\f*
\s1 Okhẹ irọkhọkhọ oyi ikpamhi emhi ni ọọ zẹ
\p 
\v 26 IJesu ọ gbolo ẹ, “Abi Eghiele oyi Ẹshinẹgba o li na. Eri o li abi ini ọmọse ọ miatsẹ ikpamhi iakpa kia ku shi ekẹ.
\v 27 Obili o kha bi, ọ ya lesẹ a, ogbe o kha gbe ọ guale, ama eni ikpamhi emhi ẹẹ zẹ lasele, ẹẹ fu vule. Ama ọa ya lẹsẹ abi o li kia.
\v 28 Ekẹ lọlighuo ọ lẹsẹ abi o li ri emhi ẹkọmhi ẹẹ bie. Oni ododẹ, o kha zẹ ukhuli, o ke fu vule, o nyanọ ifẹlẹ, o ya ri umọmhi lasele.
\v 29 Eni iakpa e kha da bie ne, ọni ọ gua wẹ ọ rue agaga ya gbe wẹ, itobọ khi ẹghẹghẹ ikhiẹsẹ o ramhi.”\f + \fr 4:29 \ft Li zẹ \fq iJọẹ 3.13\f*
\s1 Okhẹ irọkhọkhọ oyi ukpamhi ọọra imọsitadi
\r (iMat 13.31-32,34; iLuk 13.18-19)
\p 
\v 30 IJesu ọ gbolo ẹ wẹ, “Elọ awa mema ri Eghiele oyi Ẹshinẹgba ya khọkhọ? Okhẹ irọkhọkhọ onoghuo awa mema ya zẹ rọli lo ẹgbọ esọ eghọ o?
\v 31 Eri o li abi ukpamhi ọara imọsitadi ni ukpamhi ọli o shẹ nẹ nya agbọ ona, ni ọgbọ ọ rọ kọ ekẹ.
\v 32 Ini a rọli kọ, o zẹ, o fu vule, o mele unyanọ ni o funẹ a shi ishemhi, ni o mhọli iguabọ eniẹmhi, ni ipfeli ẹ bhale ya ku eko shi.”
\p 
\v 33 Okhẹ irọkhọkhọ enana iJesu ọ rọ nu wẹ ngme oni ungmemhi, ramhi ashini o lo wẹ esọ ramhi.
\v 34 Aa mẹ ungmemhi ni ọ nu wẹ ngme, ni ọa ri okhẹ irọkhọkhọ nu wẹ ngme. Ama ini o de tẹ ọli ali eniyẹ odukhokho eyọli, ọ rọ ri emini ọ nu wẹ ngme nya a lo wẹ esọ.
\s1 IJesu ọ́ pfọmhise akpekpeli
\r (iMat 8.23-27; iLuk 8.22-25)
\p 
\v 35 Ẹlẹ ogbọmhi ẹlẹghọ, iJesu ọọ eniyẹ odukhokho eyọli, “Awa da je ukiẹkiẹ okẹ obini o kpọle.”
\v 36 Ighọ e zẹ ẹgbọ ni e legba obọ shi aghọ, eni eniyẹ odukhokho e ya lo elemhi ọkọ-okẹ oni ikeke ni iJesu ọ she lo shitọ. E gua li vu. Ọkọ-okẹ elese e li deba wẹ vu.
\p 
\v 37 Utoghuokpe, akpekpeli oniẹmhi oo li, oo zughuse oni okẹ, ni amẹ e fiase kulo elemhi oni ọkọ-okẹ, ramhi ni o rọ vọ amẹ. Ukukuọ o kpọle ni ọa rọ kuluẹ.
\v 38 IJesu ọ la ukhokho oni ọkọ-okẹ oniẹmhi, ọ́ lesẹ-a ri ukhomhi nga akpẹsukhomhi. Ighọ eniyẹ odukhokho eyọli e guise ọli le. Ẹ ọli, “Ọsẹsẹ, wa bie ga liẹ ini awa ghọ ghua?”
\p 
\v 39 Ighọ iJesu ọ ti vule, ọ dese oni akpekpeli, ọọ li, “Li tsukẹ.” Ighọ oni akpekpeli ó pfọmhẹ te. Asha kpa o pfọmhẹ tsukẹ.
\p 
\v 40 Ighọ iJesu ọọ eniyẹ odukhokho eyọli, “Elọ o zẹ ni a rọ́ lighọ́ ọ́ na ulishi. Eri aa kie mhọli irudunga?”
\p 
\v 41 Ulishi oo mu wẹ, e mhila egbe wẹ, “Ọghuo ọna ọ khi? Ghe akpekpeli ali izughuse okẹ e ga suọ esọ a na li.”
\c 5
\s1 IJesu ọ ri ọmọse ni ayẹmhẹ ebe o la egbe ze
\r (iMat 8.28-34; iLuk 8.26-39)
\p 
\v 1 IJesu ali eniyẹ odukhokho eyọli e da okẹ iGalili je ukiẹkiẹ ekẹ iGẹrasẹnẹsi.
\v 2 Abi iJesu ọ lẹsẹ rọte elemhi ọkọ-okẹ lasele, ọmọse ni ọ mhọli ayẹmhẹ ebe, ọ rọte atalimhi ni o la aghọ bhale deba iJesu.
\v 3 Ifui atalimhi ọni ọmọse ọọ la. Ọgbọkhọghuo ọa ke dobẹ ri iwẹghẹ gẹ ọli.
\v 4 Ẹghẹghẹ kpa, a rọ́ ri iwẹghẹ gẹ ọli abọ ali awẹ, ama eri ọọ kphuru wẹ a, ọ taghiẹ wẹ a, ọ shashe wẹ a. Ọgbọkhọghuo ọa dobẹ mu ọli.
\v 5 Nobi-nogbe ọ́ rọ la ifui atalimhi ali ikhomhi ite dudu gasẹ. Ọọ pfi okokokhuẹ. Ọ ri echẹ fianọ egbeọli.
\p 
\v 6 Abi ọ lẹsẹ ta pfia mẹ iJesu te, ọ na bhale ya wugha li odalo.
\v 7 Ọ tsẹsẹ leghe, ọ́ọ́, “IJesu Omi Ẹshinẹgba ni ọ Yagha Ne Nyaa, elọ wa nono mhẹ egbe? Mhi ri Ẹshinẹgba lema ẹ khi na mhẹ osoli!”
\v 8 Itobọ emini ọ rọ ngme na khi, iJesu ọ she kpẹ gueyẹ ọli, “Yẹyẹ ayẹmhẹ obe, lase ọni ọmọse ọna egbe le.”
\p 
\v 9 Ighọ iJesu ọ mhila li, “Sẹ a lui eva oyẹ?” Ọọ, “Eva oyẹmhẹ o khi Olele ẹgbọ, itobọ khi anye bu gba.”
\v 10 Ọ gbo lema iJesu ọ kpẹkpẹ, ọ khi khu ẹwẹ oni ekẹ ya lase.
\p 
\v 11 Igulu ni e bububu e la epfẹ ute ni o la aghọ le eminale.
\v 12 Eni ayẹmhẹ e lema iJesu, “Khu anye ya lo igulu eghọ, zẹ ni anye ya lo wẹ egbe.”
\v 13 IJesu ọ ri ẹghẹghẹ na wẹ, e ka lo eni igulu egbe. Ighọ e rọte ọni ọmọse egbe lasele e ya lo eni igulu egbe. Eni igulu ni e ramhi agbẹlẹ eva, e rọte egele na ya kulo oni okẹ, e ghuloa nya.
\p 
\v 14 Eni e ri ukpẹloe ẹ khu eni igulu e na je ifui apfẹ ali ẹoli nya ni e la oni ekẹ ya guele emini a mẹ. Ighọ ẹgbọ e bhale ya bino emini a mẹ.
\v 15 Abi eni ẹgbọ e rọ bhale deba iJesu, e mẹ ọni ọmọse ni ayẹmhẹ ebe ni e bu e kpẹ la egbe, khi ọ shitọ aghọ, ọ ri itsua sọ, ẹgbhali eyọli e she gba na li. Ulishi oo mu wẹ.
\v 16 Eni e mẹ emini a mẹ e gueyẹ ẹgbọ emini ọni ọmọse ni ayẹmhẹ obe e la egbe ọ mẹ egbe ali emini e li eni igulu.
\v 17 Ighọ, e gueyẹ iJesu ọ lase wẹwẹ ekẹ le.
\p 
\v 18 Abi iJesu ọ lo elemhi ọkọ-okẹ oniẹmhi khi ọọ ke vu, ọni ọmọse ni ayẹmhẹ ebe e kpẹ la egbe, ọ lema iJesu ọ zẹ ni lọli deba li vu.
\v 19 Ama iJesu ọa lama na li. Ọ ri ochoghọ liẹ ọli, “Ke je apfẹ ni u ya gueyẹ ẹgbọ ena unuẹkpẹ oyẹ emini Ọnọmhuẹ ọ riẹlẹ nẹ, ali abi ọ li lẹ elemhi ẹ.”
\v 20 Ighọ ọni ọmọse ọ lui ifui ẹoli igbe ọdọda ena ekẹ iDikapolisi. Ọ kia gueyẹ ẹgbọ abi iJesu ọ li riẹlẹ na luẹ. O ri abọ sha ẹgbọ nya.
\s1 Ọmueshi ni ọ ghu-a ali ọkpotso ni ọlia ee ku egbe
\r (iMat 9.18-26; iLuk 8.40-56)
\p 
\v 21 Abi iJesu ọ rọ gbo nyenẹ egbe da je ukiẹkiẹ okẹ obini o kpọle, ẹgbọ e le gasẹ ọli.
\v 22 Ọmọse ọghuo ni a lu iJarọsi, ni ọ khi ọtuọghuo eni ẹ mhẹsẹ shi owa ugamhi, ọ bhale akaghọ. Abi ọọ mẹ iJesu te, ọ de ya wugha li odalo.
\v 23 Ọ mema lolo lema li, ọ́ọ́ li, “Omimhẹ ọni ọmueshi ọ ma ghua gba memena, kpẹkpẹ bhale ya ri obọ ti ọ li egbe ni ọ ze, ini ọ khi ghua.”
\v 24 Ighọ iJesu ọ deba li vu.
\p Ighọ ebubu ẹgbọ e deba li e vẹ mu ọli.
\v 25 Ọkpotso ọghuo ọ la aghọ ni ọ she ku ọlia ishitọ egbe ramhi ikpe igbẹva.
\v 26 Ọ̀ she mẹ osoli obọ oyi ebubu ẹgbọ abi ọ rọ kia dua oni ughuamhi. Ọ́ she ri ẹpfue eyọli nya dua ọ, ama ọa pfo, oo ga khọlọ ọli egbe.
\v 27 Abi ọ rọ suọ ingme oyi iJesu, ighọ ọ te ifuabọ oyi ẹgbọ ri obọ ti ọli awulu ni ọ sọ.
\v 28 Ọ rọ li shi udu khi, “Ini mhi da mẹ asha ri obọ ti ọli awulu ne, mhi ya ze.”
\p 
\v 29 Abi ọ ri obọ ti ọli awulu te, eni ọlia ni e ku ọli egbe, e khakha utoghuo kpe. Aghọaghọ ọ lẹsẹ khi emini o yẹsẹ luẹ ẹ ngme, khi o pfo.
\p 
\v 30 Aghọaghọ, iJesu ọ lẹsẹ khi itoto o she rọte luẹ egbe ya lase. Ighọ ọ migha, ọ mu egbe pfi iteva ẹgbọ ni e sha mu ọ. Ọ mhila wẹ, ọ́ọ́. “Ọghuo ọ ri obọ ti mhẹ awulu?”
\p 
\v 31 Eniyẹ odukhokho eyọli ẹẹ ọli, u ga mẹ abi ẹgbọ e liẹ vẹ mu ẹ, u kiele ẹ mhila, “Ọghuo ọ ri obọ ti mhẹ?”
\p 
\v 32 Ama, iJesu ọ kie bino gasẹ ini ọ mẹ ọni ọ ri obọ ti ọ.
\v 33 Abi ọni ọkpotso ọ rọ mẹ abi o ke li ọli egbe, ọ bhale odalo oyi iJesu ya wugha, ulishi o mema mu ọli, ọ gue igẹsikia le abi o ga li kia nya.
\v 34 IJesu ọ́ọ́ ọni ọkpotso, “Omi mhẹ, irudunga oyẹ o she mie ẹ pfuese. Ri opfọmhẹ ke je, anasẹmhẹ oyẹ o she pfo.”
\p 
\v 35 Abi iJesu ọ kie li ngme, emọse eghuo, e rọte owa oyi iJarọsi bhale. Ẹẹ iJarọsi, “Omiẹ ọ she ghua, khi ke yẹsẹ Ọsẹsẹ ngme.”
\p 
\v 36 IJesu ọa fẹ ri esọ shi emini e ngme, ọ́ọ́ ọni ọmọse “Khi zẹ ni ulishi o mu ẹ, ama lẹsẹ mhọli irudunga.”
\p 
\v 37 Ọa zẹ ni ọgbọkhọghuo ọ deba li sẹ ni iPita, ali iJemhisi ali iJọni inyọghuo iJemhisi.
\v 38 Abi e rọ bhale owa oyi iJarọsi, iJesu ọ mẹ abi ẹgbọ e li i kpe okeke, ni e li i viẹ gbii.
\v 39 Ighọ, ọ lo elemhi oni owa, ọ́ọ́, “Elọ o pfi onyaghu onana? Elọ o rẹ ẹ viẹ? Ọni ọmọ ọa ghu, eri ọ lesẹ a.”
\p 
\v 40 Ama eni ẹgbọ e gia li. Abi ọ rọ khu wẹ fiẹ se, ọ rue ita ali inyọ ọni ọmueshi ali eniyẹ odukhokho otuasẹ eghọ mhuẹ obọ je ashini ọni ọmọ ọ yẹshi.
\p 
\v 41 IJesu ọ mu ọli obọ, ọọ ọni ọmueshi, “Talita kumi.” Emini a ri ona ngme khi, “Ọnọmueshi, mhiẹ yẹ u vule.”
\p 
\v 42 Utoghuo kpe, ọni ọmueshi ọ vule, ọ́ kia gasẹ. [Ọmọ ikpe igbẹva ọ khi.] Abi a rọ mẹ ona, o ri abọ sha wẹ.
\v 43 Ama iJesu ọ lolo tsẹ agua yẹ wẹ e khi gueyẹ ọgbọkhọghuo. Ọọ wẹ, “A ri emhi na li le.”
\c 6
\s1 A ri ukpẹloe gbe iJesu obini iNazarẹti
\r (iMat 13.53-58; iLuk 4.16-30)
\p 
\v 1 IJesu ọ rọte aghọ vu je ẹoli oyọli, eniyẹ odukhokho eyọli e deba li.
\v 2 Ogbẹlẹ iyẹmhẹa oyi ẹgbọ iJu o ramhi, ọ́ọ́ sẹsẹ elemhi owa ugamhi. O ri abọ sha ebubu ẹgbọ eni e ri esọ shi ọli ọ.
\p E mhila egbe, “Obo ọni ọmọse ọna ọ rọte mẹ eni emhi enana? Ilẹsingme nabi onoghuo na ni a rọ na li, ni ọ gbo rọ gbe ikanya ọnyaloa?
\v 3 Ọna ọa she khi ikapita, omi iMeli, ni ọ gbo khi inyọghuo iJemhisi ali iJosisi ali iJudasi ali iSamọ? Ena ẹa khi inyọghuo ọli eni imueshi, ni e ga li nu awa la akana enana?” O ri elemhi bi wẹ.
\p 
\v 4 Ama iJesu ọ́ọ́, “Ashakpa a la mu ekpẹ na ọmekẹguele, sẹ ni apfẹ oyọli ali unuẹkpẹ oyọli aa la mu ekpẹ na li.”\f + \fr 6:4 \ft Li zẹ \fq iJọn 4.44\f*
\p 
\v 5 Ọa dobẹ la akaghọ gbe akanya ọnyaloa okhọghuo, sẹ ni ikuku ẹgbọ ni ẹa ze ni ọ́ rọ ze abi ọ rọ ri obọ ti wẹ.
\v 6 Umha-mhọli irudunga oyẹwẹ o ri abọ sha iJesu.
\p Ighọ iJesu ọ kia rọte ẹoli je ẹoli sẹsẹ eni ẹgbọ.
\s1 IJesu ọ ghie eniyẹ odukhokho otuogbava fiẹ
\r (iMat 10.5-15; iLuk 9.1-6)
\p 
\v 7 Ọ lu eniyẹ odukhokho etuogbava eyọli tigbili, ọ ghie wẹ ava-ava fiẹ, ọ ri ekpabọ na wẹ ni e rọ́ mhuẹ itoto rọ khu ayẹmhẹ ebe.
\p 
\v 8 Ọ gueyẹ wẹ, “Ini a lẹ, a lẹsẹ rue orọkpọ mhuẹ obọ, a khi tsua eminale, wẹkhi akpaba ni a pfi ẹ sọ, wẹkhi ukpaghọ.
\v 9 A sọ ekuẹ, ama a khi tsua awulu olese ma oni a rọ sọ.
\v 10 Ọ gbolo ẹ wẹ, a kha da lo apfẹ okhọghuo le ni e rọ da mie ẹ, a la akaghọ ramhi ni a rọ ya rọte oni ẹoli vu.
\v 11 Ini o khia khi a bhale ẹoli okhọghuo khi eni ẹgbọ ẹa mie ẹ, ni ẹa rọ gbo ri esọ shi emini a ngme, a rọte aghọ vu. A kpe abọ ọ-a na wẹ, a rọte aghọ vu. Eri ona o ya khi ọtsẹlẹ shi wẹ egbe.”\f + \fr 6:11 \ft Li zẹ \fq Ika 13.51\f*\f + \fr 6:11 \ft Li zẹ \fq iLuk 10.4-11\f*
\p 
\v 12 Ighọ e fiẹ ya tsẹ abọ gasẹ, e liẹ ẹgbọ e rọte olamhẹ oyẹwẹ mu pfi.
\v 13 E khu ebubu ẹgbọ ayẹmhẹ ebe egbe-a, e ri oili to eni ẹẹ ghua ebubu egbe, e rẹwẹ ze.\f + \fr 6:13 \ft Li zẹ \fq iJem 5.14\f*
\s1 Eghuli oyi iJọni Ọni ọọ batazi
\r (iMat 14.1-12; iLuk 9.7-9)
\p 
\v 14 Ẹghẹghẹ ana, oghie Erọdu ọ li suọ eko eni ingme ena nya, itobọ khi eva oyi iJesu o she gasẹ asha kpa. Ẹgbọ eghuo e liẹ khi iJọni Ọni ọọ batazi lọ ni ọ nyenẹ egbe bhale agbọ, lọli o zẹ ni ọ rọ lighọ mhọli ekpabọ rọ gbe ikanya ọnyaloa.
\p 
\v 15 Ẹgbọ eghuo e liẹ khi, “Elaja Ọmekẹguele ọ khi.” Elese ẹ khi, “Ọmekẹguele nabi emekẹguele ena ẹlẹlẹ ọ khi.”\f + \fr 6:15 \ft Li zẹ \fq iMat 16.14; iMak 8.28; iLuk 9.19\f*
\p 
\v 16 Ama abi Erọdu ọ rọ suọ ona, ọ kẹ, “IJọni, ni mhi khi ukhomhi ọ, a rọte eghuli guise le!”
\p 
\v 17 Itobọ khi Erọdu ọọ ke mhẹsẹ a mu iJọni gẹ pfilo owa ighumha. Ini egbe e ba mu Ẹrodiasi. Eri Erọdu ọ mie iFilipu inyọghuo ọli Ẹrodiasi.
\v 18 Ẹghẹghẹ kpa IJọni ọ rọ gueyẹ Erọdu khi, ọa ti ni ọ rue ughuẹ inyọghuo ọli shi.\f + \fr 6:18 \ft Li zẹ \fq iLuk 3.19-20\f*
\p 
\v 19 Itobọ ona, ọni Ẹrodiasi ọ̀ọ́ biselemhi iJọni, ọ̀ọ́ nono odẹ ni ọ te ya gbe ọli-a, ama ọa dobẹ.
\v 20 A gbo bhale ya ẹ khi Erọdu ọ̀ọ́ na ulishi iJọni itobọ khi ọ lẹsẹ khi iJọni khi ọgbọ onete ali ọgbọ ọ ni ọ pfuasẹ ọ khi. Ọ ri irarighọ ri ukpẹloe ẹ khu ọli. Ọ̀ ma nono ni lọli ri esọ ke shi ungmemhi oyi iJọni, ini o ri riẹ khia khi ingmemhi eyọli e ma yese ọli udu-a ẹghẹghẹ kpa ni ọ rọ suọ li.
\p 
\v 21 Ikpukhokho ọ, Ẹrodiasi ọ mẹ ashini ni ọ te ya mu ota sọ iJọni. Ighọ ẹlẹghuo ni o ikhi ogbẹlẹ ni Erọdu ọ rọ mhọli ukue ni ọ rọ yelele ogbẹlẹ ni a rọ bia li le. Ọ ya luno idenọmọ eyọli ali ẹgbọ eni mu ẹloe ali ẹgbọ igọmẹti ali eni ẹẹ gbe ikanya igọmẹti ni e la ekẹ iJudia shi oni ukue.
\v 22 Abi ọmọ ọmueshi omi Ẹrodiasi ọ rọ fiẹ lasele gbe ishimhi, o mema ti Erọdu ali ẹgbọ eni e bhale ya bino ọli ẹloe.
\p Ighọ ọni oghie ọọ ọni ọmueshi, “Mhila mhẹ emiemini o ga ghọle ẹ, mhi ya rọli nẹ.”
\v 23 Ọ romhi isheli khasẹ ọni ọmueshi, “Emiemini u mhila, mhi ya rọli ne, o kha riẹ khi agbekhi-eva eghiele oyẹmhẹ.”
\p 
\v 24 Ighọ ọni ọmueshi ọ fiẹ ya mhila inyọ li, “Elọ mhi ya mhila?”
\p Inyọli ọọ li, “Ukhomhi oyi iJọni Ọni ọọ batazi ẹgbọ wa mhila.”
\p 
\v 25 Aghọaghọ ọni ọmueshi ọ nyanya na ya lo deba oghie, ọ mhila li, “Ukhomhi oyi iJọni Ọni ọọ batazi ẹgbọ mhia nono ni u khi shi ukpẹko na mhẹ memena.”
\p 
\v 26 Udu o todẹ yese oghie a. Ama itobọ ekha ni ọ tse ukpẹloe oyi epfẹse ni ọ lu shi oni ukue, ọa ke dobẹ ti da oni ekha.
\v 27 Aghọaghọ ọ ghie eni ẹẹ gbolo ẹgbọ-a e ka pfa iJọni ukhomhi ọ bhale. Eni emọse e je owa ighumha ya khi iJọni ukhomhi ọ.
\v 28 E rue ọli shi ukpẹko bhẹ. Ighọ oghie ọ kpha li na ọni ọmueshi. Ọni ọmueshi ọ kpha li na inyọ li.
\v 29 Abi eniyẹ odukhokho eyi iJọni e rọ suọ ona, e bhale ya tsua etuli oyọli ya rọ tọ.
\s1 IJesu ọ ri eminale na ẹgbọ agbẹlẹ ishe le
\r (iMat 14.13-21; iLuk 9.10-17; iJọn 6.1-14)
\p 
\v 30 Eni ighiusomhi na kẹẹ e jele, e le gasẹ ọli, e gueyẹ ọli emini e riẹlẹ ali emini e sẹsẹ nya.
\v 31 Ighọ, itobọ ebubu ẹgbọ, ni ee bhale ni ee vu, iJesu ali eniyẹ odukhokho eyọli ẹa mẹ asha le eminale. IJesu ọọ wẹ, “A bhale ni awa je ashini awa-eghuo tsẹ awa ya la, ni a yẹmhẹ-a ukuku ọ.”
\p 
\v 32 Ighọ wẹwẹghuo tsẹ ee lo ọkọ-okẹ oniẹmhi ya je ashini o da-ya.
\v 33 Ama ebubu ẹgbọ ni e mẹ wẹ abi e rọ vu, e lẹsẹ khi wẹwẹ lọ. Ighọ eni ẹgbọ e rọte ẹoli nya ri awẹ na ya ralo ashini iJesu ali eniyẹ odukhokho eyọli e je.
\v 34 Abi iJesu ọ rọ ramhi aghọ, ọ mẹ abi eni ẹgbọ e bu, elemhi wẹ e lala li. Itobọ khi eri e li abi isumha ni ẹa mhọli ọni ọ rẹ wẹ ẹ kia. Ighọ ọ li sẹsẹ wẹ emhi ebubu.\f + \fr 6:34 \ft Li zẹ \fq iNọba 27.17; 1 Ighie 22.17; 2 Okhẹ 18.16; Ezik 34.5; iMat 9.36\f*
\p 
\v 35 Ẹghẹghẹ ana, ogbe o she vu. Ighọ eniyẹ odukhokho eyi iJesu e bhale deba li, e kẹ ọli, “Aborọkhia khi oola óó nuata shi apfẹ ena, ni ẹghẹghẹ o rọ she vu dọsẹ ena,
\v 36 waa ke gueyẹ eni ẹgbọ ena e kia je ifui apfẹ ya nono emhi dẹ le.”
\p 
\v 37 Ama, iJesu ọ́ọ́ wẹ, “A ri emhi na wẹ le.”
\p E mhila li, “Ifata eyi ogbẹlẹ elele eyi ọgbọ e ya lo ni a rọ dẹ ibulẹdi ghi wẹ le?”
\p 
\v 38 Ighọ iJesu ọ mhila wẹ, “Iruli ibulẹdi ingmẹ a mhọli shi aghọ? A ka bino ghue.”
\p Abi e rọ bino se, e ọli, “Iruli wẹ ishe ali ifẹlẹ aava.”
\p 
\v 39 Ighọ iJesu ọ́ọ́ wẹ e riẹlẹ eni ẹgbọ shitọ ikui-iku, ukhomhi ebuli.
\v 40 E shitọ ikui-iku, ẹgbọ egbhuẹshi-she ali egbhuẹ-eveva ali ogbogbe.
\v 41 Ighọ iJesu ọ́ọ́ rue eni ibulẹdi ishe ali ifẹlẹ aava eghọ, ọ bino idane, ọ tsẹ Ẹshinẹgba uwegbe. Ọ gbe eni ibulẹdi khia, ọ rọ na eniyẹ odukhokho eyọli e ke kemhi na ẹgbọ. Ọ gbo kemhi eni ifẹlẹ aava na wẹ nya.
\v 42 Ọgbọkpa ọ le, ọ khue.
\v 43 Iku wẹ ni eniyẹ odukhokho eyọli e sanọ ekẹ, e vọ ighughu igbẹva.
\v 44 Emọse agbẹlẹ ishe, e le eni eminale.
\s1 IJesu ọ kia ukhomhi okẹ
\r (iMat 14.22-23; iJọn 6.15-21)
\p 
\v 45 Aghọaghọ ọ ri ọmọ odukhokho eyọli lo ọkọ-okẹ oniẹmhi, e ka ralo iBẹtisaida ya migha khẹ luẹ ukiẹkiẹ obinokpọle. Ighọ ọ gueyẹ oni ukpokpomhi ebubu ẹgbọ e ke je apfẹ.
\v 46 Abi ọ rọ tsẹ wẹ okhila se nya, ọ nga ukhomhi ute ya sọ iromhi.
\p 
\v 47 Ogbọmhi ò mu ekẹ, oni ọkọ-okẹ oniẹmhi o kia ramhi iteva oni okẹ, o ke kpe iJesu lọlighuo tsẹ le shi ekẹ.
\v 48 Ọ́ mẹ́ khi akpekpeli óó nasẹ eniyẹ odukhokho eyọli. O ramhi itsotso ogbiẹ, iteteva elemhi agogo esẹ ali agogo esesa, ọ̀ọ́ kia ukhomhi oni okẹ lẹ deba wẹ. Ọ́ she kia ya dọsẹ wẹ.
\v 49 Ama abi e mẹ iJesu khi ọ́ọ́ kia ukhomhi amẹ, e dabi khi ayẹmhẹ olimhi lọ, e tsẹsẹ leghe.
\v 50 Itobọ khi eri wẹwẹ nya e yila abi e rọ mẹ ọli.
\p Aghọaghọ ọ nu wẹ ngme, ọọ wẹ, “A mhọli udu! Mhẹmhẹ lọ! A khi ke na ulishi.”
\v 51 Ọ lo elemhi ọkọ-okẹ oniẹmhi deba wẹ, oni akpekpeli o pfọmhẹ. O ri abọ sha eni eniyẹ odukhokho,
\v 52 itobọ khi ẹa kie dobẹ lẹsẹ udi ingme eminale ni ọ kpẹ rọ na ẹgbọ agbẹlẹ ishe le; a toto wẹ udu.
\s1 IJesu ọ la iGẹnẹsarẹti ri ẹgbọ ze
\r (iMat 14.34-36)
\p 
\v 53 Abi e rọ da oni okẹ se, e lasele shi iGẹnẹsarẹti, e mu oni ọkọ-okẹ oniẹmhi zu aghọ.
\v 54 Abi e lẹsẹ rọte ọkọ-okẹ oniẹmhi tiemhie, ẹgbọ e she lẹsẹ khi iJesu lọ.
\v 55 Ighọ eni ẹgbọ e nyanya kia gasẹ oni ekẹ nya, ashiashini e da suọ khi ọ da la ne, e tsua eni ẹẹ ghua shi iya bhale aghọ.
\v 56 Obiobini iJesu ọ da je ne, o ke khi ẹoli ni e gbẹdi, o ke khi enikeke o, ghe ifui ishemhi o, eri ee tsua eni ẹẹ ghua bhale agbagbajighana atuoki. E lema iJesu ọ lẹsẹ zẹ ni eni ẹẹ ghua e ri obọ ti ọ esọ awulu ni ọ rọ sọ tsẹ. Eni e da ri obọ ti ọli nya e ze.
\c 7
\s1 Osẹsẹ oyi ipfuasẹ ni o te ekelemhi lasele
\r (iMat 15.1-9)
\p 
\v 1 IFarisi ali esẹsẹ Ishi eyi iMosisi eghuo ni e rọte iJerusalẹmu bhale, e le gasẹ iJesu.
\v 2 E mẹ khi eniyẹ odukhokho eyọli eghuo e ri abọ ni ẹa pfuasẹ ni aa kpe-a a le eminale. [Emini a ri ona ngme khi ẹa kpe abọ-a abi ẹgbọ iFarisi ẹẹ a ke li.]
\p 
\v 3 Irari khi iFarisi ali ẹgbọ iJu eni e kpọle nya ẹa ya le eminale ini ẹa li kpe abọ-a. Abi ititawẹ e sẹsẹ wẹ na, ni e rọ gbe akanya.
\v 4 Ini e rọte oki jele khi ẹa li kpe egbe a, ẹa ya le eminale. E gbo mhọli ighuighuẹ ebubu elese ni e gbolo ẹ ghuẹ, Ighuighuẹ abi a liẹ kpe iko, ekhe, itasa ali igege-a.
\p 
\v 5 Irarighọ, eni iFarisi ali esẹsẹ Ishi eyi iMosisi e mhila iJesu, “Elọ o zẹ khi eniyẹ odukhokho eyẹ ẹa ri ishi ni itita awa e rọ shi ekẹ gbe akanya, ni e rọ ri abọ eni ẹa pfuasẹ ẹ le eminale?”
\p 
\v 6 IJesu ọ́ọ́ wẹ, “Igẹsikia Azaya ọ ngme abi ọ rọ ngme ungmemhi oyi Ẹshinẹgba ni o gọ lu ẹẹ ni a di egbe ẹ. Oni a kẹkẹ shi ekẹ khi,
\q1 “ ‘Ungmemhi unu
\q1 ẹgbọ ena e rọ ri ekpẹ ẹ na mhẹ,
\q2 ama udu oyẹwẹ
\q2 o nuata shi mhẹ ọ.
\q1 
\v 7 Ugamhi afuẹ ẹẹ ga mhẹ,
\q2 ushi eni ẹgbọ e rọ shi ekẹ,
\q2 ẹẹ sẹsẹ ẹgbọ.’\f + \fr 7:7 \ft Li zẹ \fq Aza 29.13\f*
\m 
\v 8 A she pfi ishi eyi Ẹshinẹgba shi ekẹ, a ri osẹsẹ eyi ẹgbọ ẹ gbe akanya.”
\v 9 Ọ gbolo ẹ wẹ, “A ga lẹsẹ odẹ ni a te ri ishi eyi Ẹshinẹgba shi ukhokho obọ, ini a ba mẹ asha ri osẹsẹ eyẹ ẹ gbe akanya.
\v 10 Itobọ khi iMosisi ọọ liẹ, ‘Mu ekpẹ na itẹ ali inyẹ.’ Ọ gbolo ẹ, ‘Ọnini ọ da ku itsẹ ni itali okekhi inyọli ne, a gbe ọlia.’\f + \fr 7:10 \ft Li zẹ \fq Okiali 20.12; iDẹut 5.16; Okiali 21.17; iLẹv 20.9\f*
\v 11-12 Ama ẹẹ a sẹsẹ ẹgbọ khi ini ọgbọ ọ gueyẹ itali okekhi inyọli, khi emini lọli kha kpẹ rọ kpaghiẹ itali ali inyọli obọ khi Ikobani o ke khi, khi ọa mhuẹ abi o ngme. Khi ushi ọa mu ọli ini ọa ke ririẹ ri emhikhọghuo na itali ali inyọ li. (Emini a rọ somhi Ẹshinẹgba opfa se, áá lui Ikobani).
\v 13 Eri a ri osẹsẹ ona a shishi ungmemhi oyi Ẹshinẹgba ekẹ a. A gbo mhọli emhi elese eghọghọ ebubu ni a gbolo ẹ riẹlẹ.”
\s1 Emini e ri ọgbọ khi ọni ọa pfuasẹ
\r (iMat 15.10-20)
\p 
\v 14 IJesu ọ gbo lu eni ebubu ẹgbọ gbili, ọ́ọ́ wẹ, “A ku esọ a shi mhẹ ọ, ni ona o lo ẹ esọ.
\v 15 Emhikhọghuo ọa la ọ ni ọgbọ le, ni o ri ọgbọ khi ọna umha pfuasẹ. Sẹ ni emini o rọte ọgbọ ekelemhi lasele, o ri ọgbọ ọ khi oni ọa pfuasẹ odalo oyi Ẹshinẹgba.”
\v 16 [Ọni ọ mhọli esọ, ọ rọ suọ.]
\p 
\v 17 Abi iJesu ọ rọ pfi eni ebubu ẹgbọ shi aghọ ni ọ rọ ya lo owa se, eniyẹ odukhokho eyọli e bhale deba li, e mhila li emini oni ungmemhi o ngme.
\v 18 Ọ mhila wẹ, “Aa kie lẹsẹ udi emini mhia ngme? Ọa kie lo ẹ esọ khi emhikhọghuo ni o rọte odato lo ọgbọ elemhi khi ọa ya ri ọli khi ọni ọa pfuasẹ odalo oyi Ẹshinẹgba?
\v 19 Irari khi oni emhi ọa ya je ọli udu, ama ekẹ elemhi ọọ tiemhi, o gbo rọte idiegbe ya fiẹ lase.” Eri iJesu ọ ri ona guele khi eminale ni a le nya, khi e ti.
\p 
\v 20 IJesu ọ gbo liẹ. “Emini o rọte ọgbọ ekelemhi udu lasele, o ri ọgbọ ọ khi ọna umha-pfuasẹ.
\v 21 Itobọ khi rọte ekelemhi udu oyi ọgbọ, isamhi ebe e rọte ẹ lasele, enabi, itsẹbọ, ighiatọ, ọgbọ ugbeli, okia,
\v 22 emhi ituegbe, ọbe imumu, ikpamhika, efiala, ubọgbọ, iyese-egbe eva a, umha-mhọli ekpẹ, iditsẹa.
\v 23 Ekelemhi udu eni ingeli ena nya e rọte ẹ lasele ni e ri ọgbọ ọ khi ọna umha-pfuasẹ odalo oyi Ẹshinẹgba.”
\s1 Imiesuọ oyi ọkpotso ọghuo
\r (iMat 15.21-28)
\p 
\v 24 Ighọ iJesu ọ rọte aghọ vu, ọ je ukiẹkiẹ ekẹ iTai. Ọ lo owa oghuo, ọa nono ni ọgbọkhọghuo ọ lẹsẹ khi lọli la akaghọ. Ama ọa dobẹ ri egbe ọli sheli.
\v 25 Abi ọkpotso ọghuo ni ayẹmhẹ ebe o la omi ọli ọni ọmueshi egbe, ọ rọ suọ eko iJesu, ọ nyanya bhale ya de wugha li odalo.
\v 26 Ọngi iJẹta ọni ọkpotso ọ khi, a bia li shi ekẹ iFonisha ni o la iSiria. Ọ lema iJesu ọ khu oni ayẹmhẹ ebe omi ọli egbe a.
\p 
\v 27 IJesu ọ́ọ́ li, “Zẹ ni eniyẹ e kpẹ le eminale ne, ọa ti ni eminale ni a kha rọ na eniyẹ le, ni a pfi ọli ghi ewa.”
\p 
\v 28 Ọni ọkpotso ọ́ọ́, “Guẹguẹguẹ Ọnọmhuẹ! Ama ewa e kiele la ifui itebu ẹ sanọ eminale ni eniyẹ kẹsẹ le le.”
\p 
\v 29 IJesu ọọ ọli, “Itobọ oni ungmemhi ni u rọ sọ mhẹ ọ ena, ke je, u ya bhale ya ẹ khi oni ayẹmhẹ ebe, o she rọte omi ẹ egbe ya lase.”
\p 
\v 30 Ighọ, ọli je apfẹ, ọ ya ẹ khi omi ọli o yẹshi ukpho khi oni ayẹmhẹ ebe o she rọte ọli egbe vu.
\s1 IJesu ọ ri ungmenu ni ọ gbo lesọ ze
\p 
\v 31 Ighọ iJesu ọ rọte ukiẹkiẹ obini iTai vu, ọ rọte iSidọni ya tiemhi okẹ iGalili, ọ je ekẹ iDikapolisi
\v 32 Oobọ ẹgbọ eghuo e la tsua ọmọse oghuo ni ọ khi ọlesọ, ni ọ gbo khi ungmenu, bhale ghi iJesu. E lema li ọ kpẹkpẹ ọ lẹsẹ ri obọ nga li egbe.
\p 
\v 33 Ighọ iJesu ọ rue lọlighuo fiẹ iteva oyi eni ebubu ẹgbọ, ọ ri imiesabọ shi ọni ọmọse esọ, ọ to etẹ, ọ ri obọ ti ọni ọmọse ẹlẹmhi.
\v 34 Ighọ iJesu ọ bino idane, ọ tu ekperumhẹ-a, ọ́ọ́ ọni ọmọse “Efata!” Emini a ri ona ngme khi, “Khueghie-a!”
\v 35 Utoghuo kpe esọ eyi ọni ọmọse e khueghie a, ẹlẹmhi oyọli o taghiẹ-a, ọ ngme lasele gboo.
\p 
\v 36 Ighọ iJesu ọ tse agua yẹ wẹ e khi gueyẹ ọgbọkhọghuo. Ama abi ọ dobẹ tse agua yẹ wẹ kpa, ighọ e dobẹ ngme oni ingme.
\v 37 O ri abọ sha ẹgbọ eni e suọ nya. E liẹ, “Ọ ma guẹ riẹlẹ emhikpa,” e gbo liẹ, “Ọ ri eni e le esọ ọ suọ esọ, ọ khueghie ingmenu unu a, ẹẹ ngme.”
\c 8
\s1 IJesu ọ ri eminale na ẹgbọ agbẹlẹ asha ene le
\r (iMat 15.32-39)
\p 
\v 1 Ọa rọte aghọ tẹsẹ ni ebubu ẹgbọ elese e rọ legba. Abi eni ẹgbọ ẹa rọ mẹ emhi le, iJesu ọ lu eniyẹ odukhokho eyọli, ọ́ọ́ wẹ,
\v 2 “Elemhi ẹgbọ ena ẹẹ ala mhẹ, ò she gba ẹlẹ esẹ ni e te nu mhẹ la ana ni ẹa te mẹ emhikhọghuo le.
\v 3 Ini mhiẹ e ri okiamhi ke je apfẹ mena, ubi o ya rue wẹ shi odẹ, itobọ khi eghuo ọ, e rọte odonuẹ bhale.”
\p 
\v 4 Eniyẹ odukhokho eyọli e mhila li, “Obo u sa khi a te ya mẹ eminale ni e bu ifu ọdagbe ona, ni e ya khuese ẹgbọ ena nya?”
\p 
\v 5 IJesu ọ mhila wẹ, “Ibulẹdi ingmẹ a mhọli?”
\p Ẹ ọli “Ishilua.”
\p 
\v 6 Ọ gueyẹ eni ebubu ẹgbọ e shitọ ekẹ. Ighọ ọ rue eni ibulẹdi ishilua eghọ, ọ kphẹmhi na Ẹshinẹgba, ọ khi wẹ-a, ọ rue wẹ na eniyẹ odukhokho eyọli e ke kemhi wẹ na eni ẹgbọ. Ighọ eniyẹ odukhokho eyọli e li kemhi na wẹ.
\v 7 E gbo mhọli ikuku imi ifẹlẹ shi aghọ. Ọ gbo kphẹmhi na Ẹshinẹgba shi ọ. Ọ rẹwẹ na eniyẹ odukhokho eyọli e gbo li kemhi wẹ.
\v 8 Eni ẹgbọ e le, e khue. E le se, eni eniyẹ odukhokho e sanọ iku wẹ ni e le kpọle vọ ighughu ishilua.
\v 9 Ẹgbọ agbẹlẹ asha ene e khi. IJesu ọọ eni ẹgbọ e ke je.
\v 10 Lọli ali eniyẹ odukhokho eyọli e lo ọkọ-okẹ oniẹmhi e je ukiẹkiẹ obini iDalamanuta.
\s1 Ẹgbọ iFarisi e mhila irọkhasẹ
\r (iMat 12.38-42; 16.1-4)
\p 
\v 11 Ẹgbọ iFarisi e bhale, e mhila iJesu ogbọ ni e rọ mu ọli fẹ. Ẹẹ ọli ọ ri irọkhasẹ ni o rọte iloghie bhale khasẹ ẹwẹ ni wẹwẹ e lẹsẹ khi Ẹshinẹgba ọ ghie ọli.\f + \fr 8:11 \ft Li zẹ \fq iMat 12.38; iLuk 11.16\f*
\v 12 IJesu ọ tu ekperumhẹ-a, ọ́ọ́, “Elọ o zẹ ni ẹẹ ẹgbọ a rọ́ mhila irọkhasẹ ọnyaloa? Abi o li mhi li gue ọli ẹ yẹ ẹ khi, aa ya mẹ irọkhasẹ ọnyaloa okhọghuo.”\f + \fr 8:12 \ft Li zẹ \fq iMat 12.39; iLuk 11.29\f*
\v 13 Ighọ ọ pfi wẹ shi aghọ vu, ọ nyenẹ egbe ukhokho gbo ya lo ọkọ-okẹ oniẹmhi, ọ da je ukiẹkiẹ obinuzeva.
\s1 Oyese oyi iFarisi ali Erọdu ni o li abi ifuma
\r (iMat 16.5-12)
\p 
\v 14 Eniyẹ odukhokho eyọli ẹa sato tsua ibulẹdi ni e bu, sẹ ni uruli oghuo ni e mhuẹ shi oni ọkọ-okẹ oniẹmhi.
\v 15 IJesu ọ tse agua yẹ wẹ, ọ́ọ́ wẹ, “A mhuẹ ẹgbhẹ shi ifuma eyi iFarisi ali Erọdu.”\f + \fr 8:15 \ft Li zẹ \fq iLuk 12.1\f*
\p 
\v 16 Eniyẹ odukhokho eyọli e nu egbewẹ ngme, e liẹ, “Itobọ khi awa a mhuẹ ibulẹdi ọ rọ ngme ona.”
\v 17 IJesu ọ lẹsẹ emini e ngme. Ọ mhila wẹ, “Elọ o zẹ ni a rọ gue ẹzọ khi aa mhọli ibulẹdi? Eri aa ya mẹ ekẹ abi khi eri ọa kie lo ẹ esọ? Eri udu oyẹẹ o na khukhu?
\v 18 A mhọli alo, aa rẹwẹ a mẹ ekẹ? A gbo mhuẹ esọ aa rẹwẹ ẹ suọ? Aa sato?\f + \fr 8:18 \ft Li zẹ \fq iJere 5.21; Ezik 12.2; iMak 4.12\f*
\v 19 Abi mhi rọ kholo ibulẹdi ishe-a na ẹgbọ agbẹlẹ asha ishe, ighughu ingmẹ a sanọ iku wẹ ekẹ vọ?” Ẹẹ ọli, “Igbẹva!”
\v 20 “Abi mhi rọ gbo kemhi ibulẹdi ishilua na ẹgbọ agbẹlẹ asha ene, ighughu ingmẹ a sanọ iku wẹ vọ?”
\p Ẹ ọli “Ishilua.”
\p 
\v 21 Ọọ, “Eri emini mhia ngme ọa kie lo ẹ esọ?”
\s1 IJesu ọ la obini iBẹtisaida khueghie ọzalo alo a
\p 
\v 22 E bhale iBẹtisaida. Ẹgbọ eghuo e tsua ọmọse ọzalo bhale ghi iJesu, Ẹ ọli ọ kpẹkpẹ ọ ri obọ ti ọli.
\v 23 Ighọ iJesu ọ mu ọni ọmọse ọzalo obọ-obọ ya fiẹ ifui oni apfẹ. Ọ̀ to etẹ shi obọ rọ shishi ọli alo-a. IJesu ọ mhila li ini ọ mẹ emhikhọghuo.
\p 
\v 24 Ọni ọmọse ọ bino idane, ọọ “Mhia mẹ ẹgbọ khi e li abi ẹẹra a kia gasẹ.”
\v 25 Ighọ iJesu ọ gbo ri abọ shi ọni ọmọse alo. Alo eyọli e tigbe khueghie-a, ọ mẹ ekẹ gboo.
\v 26 IJesu ọọ ke je, ọ ọli, “Khi gbo je elemhi ifui ẹoli.”
\s1 IPita ọ guele ọni iJesu ọ khi
\r (iMat 16.13-20; iLuk 9.18-21)
\p 
\v 27 Ighọ iJesu ali eniyẹ odukhokho eyọli e vu je ikuku ẹoli ni e la gasẹ iSizeria iFilipi. Abi e li lẹ, ọ mhila wẹ, “Ọghuo ẹgbọ e famhi ẹ liẹ khi mhi khi?”
\p 
\v 28 Ẹ ọli, “Eri eghuo ẹ khi iJọni ni ọọ batazi ẹgbọ u khi; eghuo ẹ khi Elaja u khi; elese ẹ khi ọtuọghuo emekẹguele na ẹlẹ u khi.”\f + \fr 8:28 \ft Li zẹ \fq iMak 6.14-15; iLuk 9.7-8\f*
\p 
\v 29 Ọ ke mhila wẹ, “Ama, ọghuo ẹẹ oyẹẹ a liẹ khi mhi khi?”\f + \fr 8:29 \ft Li zẹ \fq iJọn 6.68-69\f*
\p IPita ọ sọ li ọ, ọọ li, “Yẹyẹ u khi iKirisiti ni ọ khi Ọmiepfuese?”
\p 
\v 30 IJesu ọ tse agua yẹ wẹ e khi gueyẹ ọgbọkhọghuo ọni lọli khi.
\s1 IJesu ọ guele shi ekẹ khi lọli ya ghua
\r (iMat 16.21-28; iLuk 9.22-27)
\p 
\v 31 Ighọ ọ sẹsẹ eniyẹ odukhokho eyọli khi Omi Ọgbọ ọ mema ya mẹ osoli egbegbọ. Eni egbhali, ali ighie eyi ekpodalo-ugamhi ali eni ẹ sẹsẹ ishi, e ya kie ọli. A ya gbe lọli-a, ama ẹlẹ onuzi-esẹ, ọ gbo ya guale.
\v 32 Ọ ngme ona lasele gboo. Ighọ iPita ọ lu ọli ochi, ọọ li ọ khi ke ngme ungmemhi onana ghue.
\p 
\v 33 Ama abi iJesu ọ rọ nyenẹ alo ukhokho bino eniyẹ odukhokho eyọli, ọ dese iPita. Ọọ li, “Vu mhẹ odalo le yẹyẹ Ọkphaghiẹ. Wa mhọli ingme Ẹshinẹgba shi udu, ama emhi agbọ.”
\p 
\v 34 Ighọ ọ lu eni ebubu ẹgbọ ali eniyẹ odukhokho eyọli, ọọ wẹ, “Ini ọgbọkhọghuo ọọ nono ni lọli bhale deba mhẹ, ọ mema ya kie egbọli, ọ rue apfida oyọli, ọọ deba mhẹ.\f + \fr 8:34 \ft Li zẹ \fq iMat 10.38; iLuk 14.27\f*
\v 35 Itobọ khi ọnini ọ da dua ni lọli tsumhi agbọ oyọli ne, o ya de ọli obọ a, ama ọni ọ da ri irari oyẹmhẹ ali irari oyi usomhi onete oyi Ẹshinẹgba rue agbọ oyọli pfia, ọ ya tsumhi ọli.\f + \fr 8:35 \ft Li zẹ \fq iMat 10.39; iLuk 17.33; iJọn 12.25\f*
\v 36 Eleli onoghuo ọgbọ ọ ya mẹ ini ọ mhọli agbọ nya khi ayẹmhẹ oyọli o li opfu-a?
\v 37 Elọ ọgbọ ọ ya rọ ọọghiẹ ayẹmhẹ oyọli?
\v 38 Ini omama oyẹmhẹ ali omama oyi ingme oyẹmhẹ o da mu ọgbọkhọghuo elemhi agbọ ichimhi ali agbọ ọkhọlọ ona ne, omama oyi ọnọgbọ o ya li mu Omi Ọgbọ ẹlẹghọ ini ọ bhale elemhi ufumhi oyi Itali ali oyi igẹni ni e pfuasẹ.”
\c 9
\p 
\v 1 Ọ gbolo ẹ wẹ, “Mhi gue igẹsikia yẹ ẹ khi, ẹgbọ eghuo e migha ana, ni ẹa ya ghu ne, ni e rọ mẹ khi Eghiele oyi Ẹshinẹgba o bhale, elemhi ekpabọ.”
\s1 Imamachi oyi iJesu
\r (iMat 17.1-13; iLuk 9.28-36)
\p 
\v 2 Abi ẹlẹ-esesa e rọ dọsẹ, iJesu ọ rue iPita, ali iJemhisi ali iJọni, ya nga ute oniẹmhi ni o yagha, asha ni wẹwẹghuo kpe e la. Ighọ e mẹ khi iJesu ọ mu melaa.
\v 3 Itsua ni ọ rọ sọ, e pfuasẹ-a, e gẹ pẹ̀pẹ̀pẹ̀. E todẹ pfuasẹ dọsẹ utsakolo, e dọsẹ abi ọgbọkhọghuo ọa tigbe dobẹ ya li pfuẹ wẹ-a pfuasẹ ramhi agbọ ona.
\v 4 Ighọ eni eniyẹ odukhokho aasẹ eyọli e mẹ khi Elaja ali iMosisi e lasele nu iJesu ghẹta.
\p 
\v 5 IPita ọọ iJesu, “Ọsẹsẹ, o guẹ ti khi awa la akana. Zobẹ ni anye tọ ikholo esẹ shi ana. Ọghuo ọ o kha khi oyẹ, oghuo o khi oyi iMosisi, onokpọle o khi oyi Elaja.”
\v 6 Ọa ke lẹsẹ emini ọ ke ya ngme, itobọ khi eri lọli ali enekpọle e yila dọsẹ.
\p 
\v 7 Ighọ otughunu o lasele ya guese wẹ-a, Ẹshinẹgba ọ rọte elemhi oni otughunu ngme, ọ́ọ́, “Omimhẹ ni Ọmọse na, ni mhi nono ingme oyọli egbegbọ. A ke suọ esọ na li.”\f + \fr 9:7 \ft Li zẹ \fq iMat 3.17; iMak 1.11; iLuk 3.22\f*\f + \fr 9:7 \ft Li zẹ \fq 2 iPit 1.17-18\f*
\p 
\v 8 Utoghuokpe khi e ke pfi alo bino, ẹa ke mẹ ọgbọkhọghuo sẹ ni iJesu lọlighuo.
\p 
\v 9 Abi e li rọte oni ukhomhi ute e tiemhi le, iJesu ọ gueyẹ wẹ e khi gueyẹ ọgbọkhọghuo emini e mẹ ini Omi Ọgbọ ọa li rọte eghuli guale.
\v 10 E ri oni ungmemhi gbe akanya, ama e nu egbewẹ ghẹta emini irọte eghuli guale o ngme.
\p 
\v 11 Ighọ e mhila iJesu, “Elọ o zẹ ni eni ẹ sẹsẹ e rọ liẹ khi Elaja ọ kpẹ ya bhale?”\f + \fr 9:11 \ft Li zẹ \fq iMala 4.5; iMat 11.14\f*
\p 
\v 12 IJesu ọọ, “Egbegbọ lọ khi Elaja ọ kpẹ ya bhale, ọ ya bhale ya mu egbe emhi nya shi ekẹ. Elọ o mema zẹ ni Ebe-no-pfuasẹ o rọọ khi Omi Ọgbọ ọ mema mẹ osue egbegbọ, a gbo kie ọli?”
\v 13 Ama a ghe i, Elaja ọ she bhale, e riẹlẹ emini o ghọle wẹ deba li ẹzẹzẹ abi a li kẹkẹ ingme oyọli shi Ebe-no-pfuasẹ.
\s1 Irọze oyi ọzẹo nọ mhuẹ ayẹmhẹ obe
\r (iMat 17.14-21; iLuk 9.37-43)
\p 
\v 14 Abi e ke rọ ya kugbe eniyẹ odukhokho ni e kpọle ọ, e mẹ khi ebubu ẹgbọ o le gasẹ wẹ, esẹsẹ Ishi eyi iMosisi e nu wẹ la akaghọ khakọ.
\v 15 Abi eni ẹgbọ e lẹsẹ mẹ iJesu te, abọ e sha wẹ egbegbọ. E na ya tsẹ ọli.
\p 
\v 16 Ọ mhila wẹ, “Elọ o khi ni a nu wẹ khakọ ọ shi?”
\p 
\v 17 Ọmọse ọghuo ọ rọte elemhi eni ebubu ẹgbọ ya rue unu, ọ́ọ́, “Ọsẹsẹ, omimhẹ ọni ọmọse mhi rọ bhale ghi ẹ, ayẹmhẹ obe ọ nasẹ ọli, ni ọa ke zẹ ọli ẹ ngme.
\v 18 Ini oni ughuamhi o da tsua rughu ọli ne, eri o pfi ọli ẹ gbe, ọọ chi ofulu unu, ọọ le akọ unu, ọ zese a. Mhi gueyẹ eniyẹ odukhokho eyẹ e khu ọli oni ayẹmhẹ egbe-a, ama ẹa dobẹ.”
\p 
\v 19 IJesu ọọ, “Ẹẹ ẹgbọ ni ẹa mhọli irudunga ena, ẹlẹ-ingmẹ mhi ke mhọli rọ nu ẹ ya la akana, ẹlẹ-ingmẹ mhi bẹshi ya la onana ramhi, Mu ọni ọmọ ghi mhẹ!”
\p 
\v 20 Ighọ e mu ọni ọmọ bhale. Abi oni ayẹmhẹ o rọ mẹ iJesu tee, o de rughu ọni ọmọ, o pfi ọni ọmọ gbe, ọọ kpi abọ ali awẹ-a, oo wu ọli ekẹ, ọọ chi ofulu unu.
\p 
\v 21 IJesu ọ mhila ita ọni ọmọ, “Aẹlẹ ọ te lina?”
\p Ọọ, “Abi ọ te khi ọmọ.”
\v 22 “O she lina mu ọli pfi lo elemhi erali ali elemhi okẹ itingmingmẹ abi o kha gbe ọli-a. Ini u mhọli emini u dobẹ ya riẹlẹ, kpẹkpẹ lẹ elemhi anye ni u kpaghiẹ anye obọ.”
\p 
\v 23 IJesu ọ́ọ́, “Eri u wẹ ini mhi dobẹ? Emhikpa ọọ tsẹ na ọni ọ da mhọli irudunga.”
\p 
\v 24 Aghọaghọ ita ọni ọmọ ọ nyanya liẹ, “Mhi miesuọ ukukuọ, kpaghiẹ mhẹ obọ ni mhi gbo miesuọ shi ọ egbegbọ.”
\p 
\v 25 Abi iJesu ọ rọ mẹ khi eni ebubu ẹgbọ e na bhale ashini oni ingme o de shi, ọ tsẹsẹ ku oni ayẹmhẹ obe. “Yẹyẹ ayẹmhẹ ungmenu ali ilesọ, rọte ọli egbe ya lasele, khi gbo nyenẹ egbe bhale ọ ghue.”
\p 
\v 26 Oni ayẹmhẹ o tsẹsẹ, ri itoto nighise ọni ọmọ, ọ rọte ọli egbe ya fiẹ. Ọni ọmọ ọ ke li abi ọni ghua. Ẹgbọ e liẹ, “Ọ she ghua.”
\v 27 Ama, iJesu ọ mu ọni ọmọ obọ vule migha. Ọ migha.
\p 
\v 28 Abi iJesu ọ rọ lo elemhi owa se, eniyẹ odukhokho eyọli e bẹna mhila li, “Elọ o zẹ ni anye aa rọ dobẹ khu ọli oni ayẹmhẹ egbe-a?”
\p 
\v 29 IJesu ọ sọ wẹ ọ, ọọ wẹ, “Iromhi isọsọ ali azumhi tsẹ o dobẹ a khu onana.”
\s1 IJesu ọ gbo ngme ingme eghuli oyọli
\r (iMat 17.22-23; iLuk 9.43-45)
\p 
\v 30 IJesu ali eniyẹ odukhokho eyọli e rọte aghọ vu, e rọte iGalili dọsẹ, ọa nono ni ọgbọkhọghuo ọ lẹsẹ ashini wẹwẹ e la,
\v 31 Itobọ khi ọ sẹsẹ eniyẹ odukhokho eyọli, ọọ yẹ, “A ya ri Omi Ọgbọ na ẹgbọ de. E gbe ọli-a. Ẹlẹ nuzi-esẹ ọ gbo guale.”
\v 32 Ama emini ọ ngme ọa lo wẹ esọ, ulishi o mu wẹ abi e li ya mhila li emini ọ rọli ngme.
\s1 Ọni ọ fu nẹ nya
\r (iMat 18.1-5; iLuk 9.46-48)
\p 
\v 33 E bhale ẹoli iKapanọmu. Abi ọ rọ la elemhi owa, ọ mhila wẹ, “Elọ a khakọ shi amo abi a rọ la odẹ?”
\p 
\v 34 Ama e tsaghiẹ-a, itobọ khi ọni ọ kpeda nya elemhi wẹ e la odẹ khakọ shi.\f + \fr 9:34 \ft Li zẹ \fq iLuk 22.24\f*
\p 
\v 35 IJesu ọ shitọ, ọ lu eniyẹ odukhokho ogbava eyọli, ọ́ọ́ wẹ, “Ini ọgbọkhọghuo ọọ nono ni lọli khi ọni ododẹ, ọ kpe ya ri egbọli khi ọni ọ kpukhokho nya, ali ọni ọ ga ẹgbọ nya.”\f + \fr 9:35 \ft Li zẹ \fq iMat 20.26-27; 23.11; iMak 10.43-44; iLuk 22.26\f*
\p 
\v 36 Ọ mu ukuku ọmọ vule migha wẹ iteva. Ọ mu ọli shi abọ, ọ́ọ́ wẹ,
\v 37 “Ọnini ọ ri itobọ oyẹmhẹ mie ọtuọghuo ikuku eniyẹ enana ne, mhẹmhẹ ọ mie. Ọnini ọ da mie mhẹ ne, ọni ọ ghie mhẹ ọ mie, ọa khi mhẹmhẹ.”\f + \fr 9:37 \ft Li zẹ \fq iMat 10.40; iLuk 10.16; iJọn 13.20\f*
\s1 Ọni ọa da khi ọbe awa ne ọyi awa ọ khi
\r (iLuk 9.49-50)
\p 
\v 38 IJọni ọ́ọ́, “Ọsẹsẹ, anye mẹ ọmọse ọghuo ni ọ́ ri eva oyẹ khu ayẹmhẹ ebe kua. Ama anye gueyẹ ọli ọ khi gbo lighọ, itobọ khi ọa khi ọghuo elemhi awa.”
\p 
\v 39 IJesu ọ́ wẹ, “A khi ke khu ọli ọ, itobọ khi ọni ọ ri eva oyẹmhẹ gbe akanya ọnyaloa, ọa tigbe ẹ vule ke ngme onobe oyẹmhẹ.
\v 40 Itobọ khi ọni ọa khi obe awa, ọyawa ọ khi.”\f + \fr 9:40 \ft Li zẹ \fq iMat 12.30; iLuk 11.23\f*
\v 41 Abi o li mhi li gue ọli ẹ yẹ ẹ khi, ọnini ọ da diẹ uko amẹ na ẹ da irari eva oyẹmhẹ ne, ali irari khi ọnayi iKirisiti a khi, ọ ya mẹ eleli ọ.\f + \fr 9:41 \ft Li zẹ \fq iMat 10.42\f*
\s1 A mu egbe ẹ shi emini e yẹsẹ ọgbọ ọ lamhẹ
\r (iMat 18.6-9; iLuk 17.1-2)
\p 
\v 42 “Ini ọgbọkhọghuo ọ yẹsẹ ikuku eniyẹ enana ni e mie mhẹ suọ lamhẹ, o bie tinẹ ni a gẹ ẹchẹ iko oniẹmhi shi ọgbọ ọghọghọ uruli tsua pfilo elemhi okẹ oniẹmhi.
\v 43 Ini obọ oyẹ o rẹ ya lamhẹ, khi ọli pfia. O ti ẹ egbe nẹ ini u waa mhọli obọ ya lo iloghie na agbọagbọ, ni u rọ tsua abọ eve-eva eyẹ ya lo ilimhi iriẹriẹ, ashini erali ẹa tigbe ẹ pfọ-a ghue.\f + \fr 9:43 \ft Li zẹ \fq iMat 5.30\f*
\v 44 [Akaghọ ikpatsọ ni ẹ le wẹ ni ẹa tigbe ẹ ghu e la, ali ashini erali ni ẹ tosẹ wẹ-a, ẹa tigbe ẹ pfu ghue.]
\v 45 Ini owẹ oyẹ o rẹ ya lamhẹ, khi ọli pfia, o ti ẹ egbe nẹ ini u waa mhọli awẹ rọ lo iloghie na agbọagbọ ni u rọ mhọli awẹ eve-eva, ni u rọ ya lo ilimhi iriẹriẹ.
\v 46 Akaghọ ikpatsọ ni ẹ le wẹ ni ẹa tigbe ẹ ghu e la, ali ashini erali ni ẹ tosẹ wẹ-a, ẹa tigbe ẹ pfu ghue.
\v 47 Ini ukpẹloe oyẹ o rẹ ẹ lamhẹ, vuọnyọ li pfia, o ti ẹ egbe nẹ ini u ri ukpẹloe oghuo lo Eghiele oyi Ẹshinẹgba, ocho ni u rọ ya mhọli ikpamhi alo eva, a pfi ẹ ya lo ilimhi iriẹriẹ.\f + \fr 9:47 \ft Li zẹ \fq iMat 5.29\f*
\v 48 Akaghọ,
\q1 “ ‘Ikpatsọ ni ẹ le wẹ
\q2 ni ẹa tigbe ẹ ghu e la,
\q1 ali ashini erali ni ẹ tosẹ wẹ-a,
\q2 ẹa tigbe ẹ pfu ghue.’\f + \fr 9:48 \ft Li zẹ \fq Aza 66.24\f*
\p 
\v 49 “Erali a rọ nye ọgbọgbọ-a, a rọli khi ọni ọ pfuasẹ abi a li ri ugbheli ẹ ri iluasobo khi pfuasẹ.
\p 
\v 50 “Ugbheli o ma ti, ama ini oviọlọ oyọli o kala, sẹ o ke li zẹ gbolo rọ ya mele ugbheli-a?
\p “A zẹ ni a mhọli ugbheli shi agbọ oyẹ ẹ. A nu egbe ke ngeli angeli opfọmhẹ.”\f + \fr 9:50 \ft Li zẹ \fq iMat 5.13; iLuk 14.34-35\f*
\c 10
\s1 IJesu ọ ngme shi ingme ipfughuẹ-a
\r (iMat 19.1-12; iLuk 16.18)
\p 
\v 1 IJesu ọ rọte aghọ vu je ekẹ iJudia, ini a da iJọdani. Ighọ ẹgbọ ni e bu e gbo vẹ ngale deba li, ọ sẹsẹ wẹ abi ọ kpẹ̀ li.
\p 
\v 2 Ẹgbọ iFarisi eghuo e bhale ya mu ọli fẹ, e mhila li, “Ushi oyawa o lama, ọmọse ọ khu ughuẹ ọyọli?”
\p 
\v 3 Ọọ, “Elọ iMosisi ọ gueyẹ ẹ a ke li?”
\p 
\v 4 E kẹ, “Eri iMosisi ọ lama ọmọse ọ kẹkẹ ebe ni a rọ pfa ughuẹ-a mhọli ughuẹ ọli obọ, ọ khu ọli.”\f + \fr 10:4 \ft Li zẹ \fq iDẹut 24.1-4; iMat 5.31\f*
\p 
\v 5 IJesu ọọ wẹ, “Itobọ khi udu oyẹẹ ọọ gbe, iMosisi ọ rọ lighọ kẹkẹ oni ushi na ẹ.
\v 6 ‘Ama ọmọse ali ọkpotso, Ẹshinẹgba ọ rọte igbaekẹle agbọ ma wẹ.’\f + \fr 10:6 \ft Li zẹ \fq Igbae 1.27; 5.2\f*
\v 7 ‘Onana o zẹ ni ọmọse ọ rọ ọ pfi itali ali inyọli shi ekẹ, ọ ya toma ughuẹ ọli ọ.
\v 8 Wẹwẹ aava e mele idiegbe ọghuo a.’ Ẹghẹghẹ aghọ ẹa ke khi etuava, ama ọghuo.\f + \fr 10:8 \ft Li zẹ \fq Igbae 2.24\f*
\v 9 Irarighọ, emini Ẹshinẹgba ọ da toma ne, ọgbọkhọghuo ọ khi vasẹ wẹ a.”
\p 
\v 10 Abi e rọ gbo la elemhi owa, eniyẹ odukhokho eyi iJesu e mhila li ogbọ ona.
\v 11 IJesu ọọ wẹ, “Ọnini ọ da khu ughuẹ ọli ni ọ ya rue ọkpotso ọlese ne, eri ọ kia okia shi oni ughuẹ ọli ọ.
\v 12 Ini ọni ọkpotso ọ lase ayi ọdọli le khi ọ ya ngeli na ọmọse ọlese, eri ọ kia okia.”\f + \fr 10:12 \ft Li zẹ \fq iMat 5.32; 1 iKọri 7.10-11\f*
\s1 IJesu ali eniyẹ enikeke
\r (iMat 19.13-15; iLuk 18.15-17)
\p 
\v 13 Ẹgbọ eghuo e mu eniyẹ bhale deba iJesu ni ọ ri obọ ti wẹ, ama eniyẹ odukhokho eyọli ee khu wẹ.
\p 
\v 14 Abi iJesu ọ rọ mẹ ghọ, o ri elemhi bi ọli. Ọ́ọ́ wẹ, “A zẹ ni ikuku eniyẹ e bhale deba mhẹ. A khi ke khu wẹ, itobọ khi enabi wẹwẹ e li mhọli obọ shi Eghiele oyi Ẹshinẹgba.
\v 15 Zẹ mhẹ gue igẹsikia yẹ ẹ khi ọni ọa da rue Eghiele oyi Ẹshinẹgba abi eniyẹ enikeke ne, ọa tigbe ya lo iloghie.”\f + \fr 10:15 \ft Li zẹ \fq iMat 18.3\f*
\v 16 Ọ muno eniyẹ shi egbe, ọ ri obọ nga wẹ ukhomhi, ọ sọ iromhi na wẹ.
\s1 Ozele-ọmọse ni ọ lolo pfue
\r (iMat 19.16-30; iLuk 18.18-30)
\p 
\v 17 Abi iJesu ọ ke rue okiali ekẹ khi ọ vu, ọmọse ọghuo ọ na bhale ya wugha li odalo, ọọ li, “Ọsẹsẹ nete! Elọ mhi ya riẹlẹ ni mhi rọ ya mhuẹ agbọ na agbọagbọ?”
\p 
\v 18 IJesu ọ li, “Elọ e zẹ ni u rọ ọ lu mhẹ ọnọti. Ọgbọkhọghuo ọa laọ ni ọ ti, sẹ ni Ẹshinẹgba.
\v 19 Ni mhi rọ sọ ẹ ogbọ ni u mhila mhẹ, u lẹsẹ ushi ni Ẹshinẹgba ọ rọ shi ekẹ. Ni ọ lẹ, ‘A khi gbe ugbeli, a khi kia okia, a khi do ughiatọ, a khi pfi ọtsẹlẹ ẹgbhọli mu ọgbọ, a khi li ọgbọ le, mu ekpẹ na ita ẹ ali inyẹ ẹ.’ ”\f + \fr 10:19 \ft Li zẹ \fq Okiali 20.12-16; iDẹut 5.16-20\f*
\p 
\v 20 Ọni ọzẹo ọọ, “Ọsẹsẹ, abi a te bia mhẹ mhi te ri ena nya a gbe akanya.”
\p 
\v 21 IJesu ọ ri ẹloe inono bino ọli, ọọ li, “Emhi oghuo tsẹ o kpe ẹ le ni waa riẹlẹ ne. Je ya ri emini u mhọli nya dẹ ni u kemhi wẹ na eni ẹa mhọli emhi, ẹghẹghẹ aghọ ni u mhọli ẹpfue shi obini iloghie, u tigbe bhale ya deba mhẹ ke kia.”
\p 
\v 22 Abi ọni ọmọse ọ rọ suọ ona, alo eyọli e yese a, ọ ri iyeseudu-a ya vu, itobọ khi ọ mhọli ẹpfue eniẹmhi.
\p 
\v 23 IJesu ọ bino gasẹ kpa, ọọ eniyẹ odukhokho eyọli, “O ma mu ọgbọ ni ọ pfue unu ni ọ rọ lo Eghiele oyi Ẹshinẹgba.”
\p 
\v 24 Ingmemhi eyọli e ri abọ sha eniyẹ odukhokho eyọli. Ama iJesu ọ gbolo ẹ, “Eniyẹ eyẹmhẹ, o ma mu eni e ri egbe da ẹpfue oyẹwẹ unu ni e rọ lo Eghiele oyi Ẹshinẹgba.
\v 25 Ni ọgbọ ni ọ pfue ọ rọ lo Eghiele oyi Ẹshinẹgba, o ya munu dọsẹ, ni ọgbọ ke dua ni lọli ri alakumi rọte esẹ asugẹ ya fiẹ.”
\p 
\v 26 Ona o ke ri abọ sha eniyẹ odukhokho eyọli nẹ, e rọ mhila egbe, “Ọghuo ọ dobẹ ya lo ọ shọ?”
\p 
\v 27 IJesu ọ pfi ukpẹloe bino wẹ, ọ́ọ̀, “Ona ọa zẹ ọgbọ ya li ama emhikpa o zẹ Ẹshinẹgba a li.”
\p 
\v 28 IPita ọ́ọ̀ iJesu, “Emhinya anye tsua kua bhale deba ẹ.”
\p 
\v 29 IJesu ọ́ọ̀ wẹ, egbegbi-ingme mhi gue ẹ yẹ ẹ khi ọnini ọ da pfi apfẹ ọli shi ekẹ, ali inyọghuo ọli eni emọse ali eni ikpotso, ali ita ali inyọ, ni ọ pfi eniyẹ ali ishemhi, ghe ọwolọ shi ekẹ irari oyẹmhẹ ali usomhi onete oyi Ẹshinẹgba,
\v 30 a ya somhi ọli opfa. Elemhi agbọ ona, a ya khivọsẹ na li asha egbhuẹshe, ikhivọsẹ owa ali ikhivọsẹ inyọghuo, ali inyọ ali eniyẹ ali ishemhi, ali anasẹmhẹ. Ọ ya mhuẹ agbọ na agbọagbọ, elemhi agbọ ni o kẹ ẹ bhale.
\v 31 Ama ẹgbọ eghuo ni e ralo, e ya kpẹ ukhokho. Eni e kpẹ ukhokho amo, e ya khi eni ododẹ.\f + \fr 10:31 \ft Li zẹ \fq iMat 20.16; iLuk 13.30\f*
\s1 IJesu ọ gbo ngme ingme eghuli oyọli utonuzi-esẹ
\r (iMat 20.17-19; iLuk 18.31-34)
\p 
\v 32 Abi iJesu ọ rọ tsua wẹ lẹ iJerusalẹmu, ni ọ rọ ralo na wẹ, eni ingme e pfuse ghagha a shi eniyẹ odukhokho eyi iJesu udu. Ulishi o mu ẹgbọ ni e deba wẹ. Ighọ iJesu ọ gbo li rue eniyẹ odukhokho ogbava eyọli ye ochi, ọ gueyẹ wẹ emini lọli ya mẹ ini wẹwẹ e ramhi iJerusalẹmu.
\v 33 Ọọ, “IJerusalẹmu awa je ena, a ya la oobọ rue Omi ọgbọ na ighie eyi ekpodalo-ugamhi ali eni ẹ sẹsẹ ishi dẹ, a ri ọli na wẹ mu. E pfa ẹzọ igbe-a mu ọli, e ghi ọli abọ ghi ẹgbọ iJẹta.
\v 34 E ya rọli ke li egia, e tono etẹ ku ọli, e gbe ọli itẹ, e tigbe gbe ọli-a. Ama ẹlẹ nuzi-esẹ, ọ ya rọte eghuli guale.”
\s1 Emini iJemhisi ali iJọni e mhila iJesu ọ riẹlẹ na ẹwẹ
\r (iMat 20.20-28)
\p 
\v 35 Ighọ iJemhisi ali iJọni imi iZebedi e bhale deba iJesu, ẹ ọli, “Ọsẹsẹ, anye ẹ nono ni u riẹlẹ emini anye ya mhilẹ ena na anye.”
\p 
\v 36 IJesu ọọ wẹ, “Elọ a nono ni mhi riẹlẹ na ẹ?”
\p 
\v 37 E kẹ, anye ẹ nono, ini u da shitọ ukpẹkhomhi oyẹ obini Eghiele oniẹmhi oyẹ ne, ni u zẹ ni ọtuọghuo anye ọ kha shitọ ẹ ukiẹkiẹ obita, ọnọkpọle ọ shitọ ẹ obọgobọ.
\p 
\v 38 IJesu ọọ wẹ, “Aa lẹsẹ emini aa mhila. Uko ni mhi rọte da, a dobẹ ya rọte ọ da, abi khi eri a dobẹ ya mie ibatizi onabi mhi mie?”\f + \fr 10:38 \ft Li zẹ \fq iLuk 12.50\f*
\p 
\v 39 E kẹ, “Anye ya dobẹ.” IJesu ọọ wẹ, “A dobẹ ri uko ni mhi rọ da ya da, a gbo dobẹ mie ibatizi onabi mhi mie,
\v 40 ama mhia mhọli afu ni a rọ ri ọgbọ ọ shitọ mama mhẹ ukiẹkiẹ obita ali obọgobọ ukpẹkhomhi oghie obini iloghie. Ẹshinẹgba ọ ri asha eghọghọ ya na ẹgbọ ni ọ rẹ wẹ shi aghọ khẹ.”
\p 
\v 41 Abi eniyẹ odukhokho etuogbe enekpọle e rọ suọ ingmemhi ena, e nu iJemhisi ali iJọni i wola shi ọ.
\v 42 Ighọ iJesu ọ lu wẹ tigbili, ọọ wẹ, “A lẹsẹ khi eni ẹ lu egbewẹ ighie eyi ẹgbọ eni ẹa ya ga Ẹshinẹgba, khi eri ẹ li wẹ abi o ghọle wẹ, ighọ eni e kpeda omhẹsẹ e li ẹ mhẹsẹ na wẹ.
\v 43 Ama, a khi li abi wẹwẹ. Ama ọnini ọ nono ni lọli khi ọniẹmhi elemhi ẹ, ọ khi ọni ọ ga ẹẹ nya.\f + \fr 10:43 \ft Li zẹ \fq iLuk 22.25-26\f*
\v 44 Ọnini ọ nono ni lọli khi ọnododẹ, ọọ mema kpẹ ri egbọli khi oghumha ọyi ẹgbọ kpa.\f + \fr 10:44 \ft Li zẹ \fq iMat 23.11; iMak 9.35; iLuk 22.26\f*
\v 45 Itobọ khi Omi Ọgbọ ọa bhale ni a ke ga li, ama eri ọ bhale ya ga ali ni ọ gbo ri agbọ oyọli bhale ni a rọ luasẹ obo na ebubu ẹgbọ.”
\s1 IJesu ọ ri iBatimeusi ọtasẹ-alo-a ze
\r (iMat 20.29-34; iLuk 18.35-43)
\p 
\v 46 Ighọ e bhale iJẹriko. Abi iJesu ali eniyẹ odukhokho eyọli ali ebubu ẹgbọ ni e deba li, e rọ rọte oni ẹoli vu, ọmọse ọghuo ni ọ tasẹ alo-a na lui iBatimeusi (omi iTimeusi a ri iBatimeusi ngme) ọ shitọ epfẹ odẹ mhila omhila.
\v 47 Abi ọ rọ suọ khi iJesu ọna iNazarẹti lọ, ọ́ọ́ tsẹsẹ leghe, ọọ liẹ, “IJesu omi iDefidi, kpẹkpẹ, lẹ elemhi mhẹ.”
\p 
\v 48 Ebubu ẹgbọ e tsẹsẹ ku ọli, ẹẹ ọli ọ zẹ ni a suọ esọ. Ama eena ọ mema lolo pfi okokokhuẹ lu ọli nẹ, “Omi iDefidi lẹ elemhi mhẹ!”
\p 
\v 49 IJesu ọ migha, ọ́ọ́, “A lu ọli na mhẹ.” Ighọ e lu ọni ọtasalo-a, ẹ ọli, “Ke ghẹlẹ, vule, khi ọọ lu ẹ.”
\v 50 Ọ rue awulu nọ ọ sọ pfi a, ọ ti vule pia bhale deba iJesu.
\p 
\v 51 IJesu ọ mhila li, “Elọ wa nono ni mhi riẹlẹ nẹ?”
\p Ọni ọmọse ni ọ tasẹ alo-a, ọ́ọ́, “Ọsẹsẹ, mhia nono ni mhi gbo ke mẹ ekẹ.”
\p 
\v 52 IJesu ọ́ọ́, “Ke lẹ, khi irudunga oyẹ o she rẹ ze.” Aghọaghọ, ọọ mẹ ekẹ, ọ deba iJesu rọte odẹ vu.
\c 11
\s1 Ẹgbọ e ri ufumhi na iJesu abi ọ́ rọ́ lo iJerusalẹmu
\r (iMat 21.1-11; iLuk 19.28-40; iJọn 12.12-19)
\p 
\v 1 Abi e rọ ti ramhi iJerusalẹmu ni e rọ bhale iBẹtifagi ali iBẹtani Udi Ute Olivu, iJesu ọ ghie etuava elemhi eniyẹ odukhokho eyọli,
\v 2 Ọọ wẹ, “A je ẹoli ni o la odalo oobọ eghọ. A kha lẹsẹ lo oni ẹoli le, a ya mẹ omi akphẹrẹ ni a muzu, ni ọgbọkhọghuo ọa nga shitọ ghue. A taghiẹ ọli bhale ana.
\v 3 Ini ọgbọkhọghuo ọ mhila ẹ, ‘Elọ o ze ni a rọ taghiẹ ọli? A gueyẹ ọli khi, Ọnọmhuẹ ọ́ọ́ nono ni lọli ri ọli riẹlẹ emhi, ali khi ọ gbo rọli bhale ya shi ekẹ lẹna.’ ”
\p 
\v 4 Ighọ ee bhale ya ẹ ọni ozele akphẹrẹ ni a muzu shi ifui apfẹ epfẹ odẹ. Abi e li taghiẹ ọli-a,
\v 5 ẹgbọ eghuo ni e migha akaghọ e mhila wẹ, “Elọ a la akaghọ a riẹlẹ ni a rọ taghiẹ ọni omi akphẹrẹ ọghọ-a?”
\v 6 E sọ wẹ ọ abi iJesu ọ́ọ́ e li sọ wẹ ọ. Ighọ eni ẹgbọ e zẹ wẹ vu.
\v 7 Abi e rọ mu ọni ozele akphẹrẹ bhale ghi iJesu se, e banọ ide egbe-a pfino nga ọni ozele akphẹrẹ ukhokho. Ighọ, iJesu ọ nga li shitọ.
\v 8 Ebubu ẹgbọ elese e li ba ide rọ ku odẹ, eghuo, e nyanọ eyamhi ku odẹ.
\v 9 Ẹgbọ ni e ralo ali eni e deba li e gbe ukua, e tsẹsẹ, e liẹ,
\q1 “Okuekhoogo! Oolo!”
\q1 Ẹshinẹgba ọ ka khivọsẹ
\q2 na ọni ọ ri eva oyi
\q2 Ọnọmhuẹ bhale!\f + \fr 11:9 \ft Li zẹ \fq Iwolo 118.25-26\f*
\q1 
\v 10 “Ẹshinẹgba ọ ka khivọsẹ
\q2 shi Eghiele oyi oghie iDefidi
\q2 ita awa ni ọọ bhale.”
\q1 “Ikuẹghiẹ o khi oyi Ẹshinẹgba!”
\p 
\v 11 Abi iJesu ọ rọ ramhi iJerusalẹmu, ọ dọsẹ ya lo elemhi Owa oyi Ẹshinẹgba. Ọ bino emhi nya gasẹ, ama aborọkhia khi obili o she bi dọsẹ, lọli ali eniyẹ odukhokho ogbava eyọli e je iBẹtani.
\s1 IJesu ọ pfi unu na ọọra ọkhua-eni
\r (iMat 21.18-19)
\p 
\v 12 Ogbeakọlọ abi e li rọte ẹoli iBẹtani fiẹ, okiamhi oo gbe iJesu.
\v 13 Ighọ ọ̀ tapfia mẹ ọara ọkhua-eni ni o guẹ ta ebe. Ọ lẹ ya bino ini o she mọ udumhi. Abi ọ rọ ramhi aghọ ọa mẹ emhikhọghuo ọ, sẹ ni ebe, itobọ khi ọa ramhi ẹghẹghẹ ni ọkhua-eni e rọ mọ ne.
\v 14 Ighọ ọọ oni ọkhua-eni, “Ọgbọkhọghuo ọa ke gbo rọte ẹ ukhomhi ya pfa udumhi ghue.”
\p Eniyẹ odukhokho eyọli e suọ khi ọ ngme na.
\s1 IJesu ọ je Owa oyi Ẹshinẹgba
\r (iMat 21.12-17; iLuk 19.45-48; iJọn 2.13-22)
\p 
\v 15 Abi e ke rọ ramhi iJerusalẹmu, iJesu ọ lo Owa oyi Ẹshinẹgba, ọ vẹsẹ eni e la akaghọ du oki kua. Ọ kpha okphẹ oyi eni e pfa ikpaghọ ali eni e ri inekhukhu dẹ kua.
\v 16 Ọa zẹ ni ọgbọkhọghuo ọ tsua itsua-oki rọte elemhi apfẹ oni Owa oyi Ẹshinẹgba dọsẹ.
\v 17 Abi ọ́ ke rọ́ sẹsẹ ẹgbọ, ọ́ rọ́ liẹ, “A she kpẹ kẹkẹ ọli shi Ebe-no-pfuasẹ khi,
\q1 “ ‘Owa iromhi oyi ishishi nya,
\q2 a ya ke lu Owa oyẹmhẹ,’
\m Ama ẹẹ, a she rọli mele owa ighiatọ a.”\f + \fr 11:17 \ft Li zẹ \fq Aza 56.7; iJere 7.11\f*
\p 
\v 18 Abi ighie eyi ekpodalo-ugamhi ali eni ẹ sẹsẹ ishi e rọ suọ ona, ee dua odẹ ni e te mẹ asha ya gbe iJesu a. Ama ulishi oyi iJesu óó mu wẹ, itobọ khi eri osẹsẹ oyọli o ri abọ sha ẹgbọ kpa.
\p 
\v 19 Ogbọmhi o mu ekẹ, iJesu ali eniyẹ odukhokho eyọli e rọte oni ẹoli ya fiẹ.
\s1 Ilẹsingme ni a rọte ọkhua-eni ni o ku ebe a rue
\r (iMat 21.20-22)
\p 
\v 20 Ẹluzogbe oogbeakọlọ khi e rọte oni odẹ dọsẹ, e mẹ khi oni ọara ọkhua-eni o khakha ya ramhi imhili.
\v 21 IPita ọ sato, ọọ iJesu, “Ọsẹsẹ, bino khẹ! Ọara ọkhua-eni ni u pfi unu na o she khakha-a.”
\p 
\v 22 IJesu ọ sọ li ọ, ọọ, “Mhọli irudunga na Ẹshinẹgba.”
\v 23 “Egbegbi-ingme mhi gue ẹ yẹ ẹ khi ọnini ọ gueyẹ oni ute ona, ‘Rọ te akana lasele ya je elemhi okẹ oniẹmhi,’ ni ọa rọ da mhọli akhọkhọmhẹ shi udu shi emini ọ ngme ne, ni ọ rọ mhọli miesuọ khi emini lọli ngme o ya bhale ya tsẹ, oo ya lighọ na li.\f + \fr 11:23 \ft Li zẹ \fq iMat 17.20; 1 iKọri 13.2\f*
\v 24 Irarighọ, emiemini u sọ iromhi mhila, miesuọ khi u she mhọli ọli, oyẹ o kẹ khi.
\v 25 U kha da migha a lema, ni u rọ ri ingme oyi ọgbọ shi elemhi, nyanya rọ topfa li. Ini itẹ ni ọ la iloghie ọ ri olamhẹ eyẹ li topfa ẹ.”
\v 26 “Ama ini u waa da rọ topfa ọgbọẹse ne, itẹ na iloghie ọa ya li ri olamhẹ eyẹ topfa ẹ.”\f + \fr 11:26 \ft Li zẹ \fq iMat 6.14-15\f*
\s1 A mhila iJesu ọni ọ ri afu na li
\r (iMat 21.23-27; iLuk 20.1-8)
\p 
\v 27 Ighọ ee gbo lo iJerusalẹmu le. Abi iJesu ọ li kia elemhi apfẹ Owa oyi Ẹshinẹgba gasẹ, ighie eyi ekpodalo-ugamhi ali eni ẹ sẹsẹ ishi ali egbhali e bhale deba li.
\v 28 E mhila li, “Ọghuo ọ ri afu nẹ ni u rọ riẹlẹ eni emhi enana nya, ọghuo ọ ri unu nẹ u ke riẹlẹ ena.”
\p 
\v 29 IJesu ọ sọ wẹ ọ, Ọ́ọ́, “Mhi ya mhila ẹ ogbọ oghuo. A sọ mhẹ ọ, ni mhi tigbe gueyẹ ẹ ọni ọ ri afu na mhẹ mhi ke riẹlẹ emhi ena.
\v 30 Ọghuo ọ fẹ ri itoto na iJọni ọ ke batazi ẹgbọ abi ẹgbọ?”
\p 
\v 31 Ighọ, e ya ye egbe ochi, e nu egbe wẹ ngme ọli khi, “Awa khẹ ‘Rọte iloghie’ lọ, ọ ya mhila awa, ‘Elọ o zẹ ni aa rọ mie ọli suọ?’
\v 32 Ama ini awa kẹ, ‘Obọ oyi ẹgbọ.’ ” Ulishi oyi ẹgbọ o mu wẹ, itobọ khi ọgbọkpa ọ lẹsẹ khi ọmekẹguele iJọni ọ khi.
\p 
\v 33 Ighọ ẹẹ iJesu, “Anye ẹa lẹsẹ.” Ighọ iJesu ọọ wẹ, “Mhi aa ya li gueyẹ ẹ ọni ọ ri afu na mhẹ mhi rọ ke riẹlẹ eni emhi ena.”
\c 12
\s1 Okhẹ irọkhọkhọ oyi eni e ngmomhi shi ogba ẹẹra ipfonu
\r (iMat 21.33-46; iLuk 20.9-19)
\p 
\v 1 Ighọ iJesu ọ ke ri okhẹ irọkhọkhọ sẹsẹ wẹ. Ọọ, “Ọmọse ọghuo ọ ke ya gua ogba ẹẹra ipfonu. Ọ ma ugbe gasẹ oni ogba. Ọ tọ esẹ shi ọ, ni a mino amẹ ikpamhi eni ẹẹra kulo. Ọ gbo tọ owa ni o yagha ni a la khẹ-ekhẹ shi ọ. Ighọ ọ ya ri oni ogba nga eghiale eghuo obọ e nu lọli ri ukpẹloe ke khu. Ọ vu asha obini odonuẹ.\f + \fr 12:1 \ft Li zẹ \fq Aza 5.1-2\f*
\v 2 Ẹghẹghẹ ikhiẹsẹ o ramhi, ọni ọmọse ọ ghie oghumha ọyọli ghi eni ọ ri ogba nga obọ, ọ lẹ ya mie wẹ idumhi emhi ni a kọ shi oni ogba bhale ghi luẹ.
\v 3 Ama e mu ọli, e gbe ọli, e khu ọli. Ọ pfino abọ efuẹ ya je.
\v 4 Ọ gbo ghie oghumha ọyọli ọlese ghi wẹ, E pfi emhi shi ọli ukhomhi, e yẹghẹ ọli-a
\v 5 Ọ gbo ghie ọlese, e gbe onana-a. Ọ ghie elese ni e bu, e gbe eghuo itali, e gbolo eghuo-a.
\p 
\v 6 “O kpọli ọghuo le ni ọa ghie ne, ikhi omi ọli ni ọ lolo nono ingme oyọli. Lọli ọ kpukhokho ghie. Ọ sa, ọọ, ‘E ya mu ekpẹ na omi mhẹ.’
\p 
\v 7 “Ama eni e la oni ogba, ẹẹ egbewẹ. ‘Ọna ọ ya le ugu oni ogba ona, a bhale ni awa gbe ọli-a. Ẹghẹghẹ aghọ ni oni ugu o mele oyawa-a.’
\v 8 Ighọ e mu ọli, e gbe ọli-a, e pfi ọli rọte oni ogba ya lase.
\p 
\v 9 “Sẹ ọni ọ mhọli oni ogba ona ọ fẹ ya li? Eri ọ bhale ya gbolo eni ẹgbọ ni ọ ri oni ogba nga obọ-a, ọ rue oni ogba na ẹgbọẹse.
\v 10 Aa she zẹ ọli Ebe-no-pfuasẹ khi.
\q1 “ ‘Ẹchẹ ni itsọna e kie pfia,
\q2 lọli o ke ya mele egbegbi ẹchẹ
\q2 ni o kẹ mu ẹloe nẹ nya-a.
\q1 
\v 11 Ọnọmhuẹ ọ lighọ riẹlẹ ona,
\q2 óó ti anye ẹloe gba’ ”\f + \fr 12:11 \ft Li zẹ \fq Iwolo 118.22-23\f*
\p 
\v 12 Ighọ egbhali eyi ẹgbọ iJu, e nono odẹ ni e te ya mu iJesu, itobọ khi e lẹsẹ khi wẹwẹ ọ ri oni okhẹ irọkhọkhọ ona nu ngme. Ama e na ulishi oyi ebubu ẹgbọ ni e la aghọ, e zẹ ọli obọ, e vu.
\s1 Ingme izẹ oga na iSiza
\r (iMat 22.15-22; iLuk 20.20-26)
\p 
\v 13 Ighọ e tigbe ya nyenẹ egbe ya ghie iFarisi eghuo ali eniyẹ odukhokho eyi Erọdu ghi iJesu, ni e mẹ asha rọte emini ọ ya ngme ri ingme de ọli.
\v 14 Ighọ e bhale deba iJesu, ẹẹ ọli, “Ọsẹsẹ, anye lẹsẹ khi u ma ngme igẹsikia, khi emiemini ẹgbọ ẹẹ ngme ali emiemini ọgbọ ọ khi ọa ya mu ẹ ẹloe, ama odẹ oyi Ẹshinẹgba wa sẹsẹ ni o te odẹ igẹsikia. Mhiẹ i, o famhi ti abi khi ọa ti elemhi ushi, ni a rọ zẹ oga na oghie iSiza?
\v 15 Anye ke zẹ, abi anye khi zẹ?”
\p Ama iJesu ọ she mẹ ikpamhika oyẹwẹ. Ọ́ọ́ wẹ, “Elọ o zẹ ni a rọ nono ni a di mhẹ mu? A rue ukpamhi anini bhale ghue ni mhi bino.”
\v 16 E rue oghuo bhale ghi ọli, ọọ wẹ, “Alo ali eva eyi ọghuo na ni a mu shi ọ ena?” Ẹẹ ọli, “Eyi iSiza lọ.”
\p 
\v 17 IJesu ọ́ọ́ wẹ, “A ri emini o khi oyi iSiza na iSiza, a ri emini o khi oyi Ẹshinẹgba na Ẹshinẹgba.”
\p Ighọ ingme oyi iJesu o sha wẹ abọ.
\s1 Ingme iteghuli-guale
\r (iMat 22.23-33; iLuk 20.27-40)
\p 
\v 18 Ighọ ẹgbọ ena otu na lui iSadusi ni ẹẹ sẹsẹ khi ite-eghuli-guale ọa ya la ikpukhokho agbọ, e bhale deba iJesu ya mhila li ogbọ.\f + \fr 12:18 \ft Li zẹ \fq Ika 23.8\f*
\v 19 Ẹẹ ọli, “Ọsẹsẹ, iMosisi ọ kẹkẹ ọli shi ebe ushi na awa khi, ‘Ini ọmọse ọ ghu-a pfi ughuẹ ọli shi agbọ, ni ọa rọ bia ọmọ na li, inyọghuo ọni ọmọse ọ́ mema rue ọni ọsamhi-olimhi ughuẹ ni ọ bia eniyẹ na ọni ọkpotso na inyọghuo ọli ni ọ ghu-a ọghọ’\f + \fr 12:19 \ft Li zẹ \fq iDẹut 25.5\f*
\v 20 Ẹghẹghẹ oghuo ó ya la ọ, a mẹ emọse oshilua ni e khi inyọghuo. Ọni ọgbhali ọ rue ọkpotso. Ọni ọmọse ya ghua, ọa bia ọmọ na ọni ọkpotso.
\v 21 Inyọghuo ọli ni ọọ deba li ọ ke rue ọni ọkpotso, ọ gbo ghua, ọa bia ọmọ. Ighọ o gbo li inyọghuo ọli ọnuzasẹ.
\v 22 Ighọ o gbo li khi eni inyọghuo ọni ọmọse ni e kpọle nya. Eni inyọghuo oshilua nya e ga rue ọni ọkpotso ughuẹ ni ẹa bia ọmọ ọkhọghuo na li. Ikpukhokho ọ, ọni ọkpotso ọ li ghua.
\v 23 Ini ogbẹlẹ iguale o ramhi, ni eni e ghu-a nya e rọ guale, ọghuo ọ famhi ya khi ughuẹ ọni ọkpotso? Aborọkhia khi wẹwẹ oshilua nya e ga rue ọli ughuẹ eghọ.”
\p 
\v 24 IJesu ọ sọ wẹ ọ, Ọ́ọ́, “Wa a mẹ khi eri a da odẹ khi aa lẹsẹ emhikhọghuo elemhi Ebe-no-pfuasẹ, wẹkhi eri a lẹsẹ emhikhọghuo elemhi ekpabọ oyi Ẹshinẹgba.
\v 25 Ini eni e ghu-a e guale, ẹa kẹ ke rue ughuẹ wẹkhi eri a ke rẹ wẹ kẹ yẹ ughuẹ. Eri e kẹ li abi igẹni ena iloghie.
\v 26 Ama ingme iguale oyi eni e ghua, aa she kpẹ zẹ ọli ebe ni iMosisi ọ kẹkẹ ni ọ ngme ingme ebuli ni oo to shi? Abi Ẹshinẹgba ọ gueyẹ iMosisi khi, ‘Mhẹmhẹ mhi khi Ẹshinẹgba ọyi Aburaamu ali Ẹshinẹgba ọyi Aziki, ali Ẹshinẹgba ọyi iGiekọpu.’\f + \fr 12:26 \ft Li zẹ \fq Okiali 3.6\f*
\v 27 Ẹshinẹgba oyi eni e la agbọ ọ khi, ọa khi ọyi eni e ghua. Eri a ga da odẹ pfo nya.” Emini a ri ona ngme khi, ẹgbọ eni ghu-a eghuo e kie mhọli agbọ.
\s1 Ushi ni o funẹ nya
\r (iMat 22.34-40; iLuk 10.25-28)
\p 
\v 28 Ọtuọghuo eni ẹ sẹsẹ ishi, ọ la aghọ suọ abi e rọ khakọ, ọ mẹ khi iJesu ọ ga guẹ sọ ẹgbọ iSadusi ogbọ ni e mhila li, ọ mhila li, “Elemhi ishi nya, onoghuo o ga funẹ nya?”
\p 
\v 29 IJesu ọ sọ li ọ, ọ́ọ́, “Oni o mu ẹloe ne nya na, ‘Ku esọ-a yẹyẹ iZirẹni, Ọnọmhuẹ Ẹshinẹgba ọyawa, lọlighuo kpe ọ khi Ọnọmhuẹ.
\v 30 Nono ingme oyi Ẹshinẹgba Ọnọmhuẹ ọyẹ, ri udu oyẹ nya ali agbọ oyẹ nya, ghe isamhi ali ekpabọ eyẹ nya nono ingme oyi Ẹshinẹgba.’\f + \fr 12:30 \ft Li zẹ \fq iDẹut 6.4-5\f*
\v 31 Onuzi-eva ni o gbo lolo mu ẹloe khi, ‘Nono ingme oyi ọnuzava ọyẹ abi u li nono ingme egbe ẹ.’ Ushi olese okhọghuo ọa ke la ọ ni o gbo mu ẹloe dọsẹ ena.”\f + \fr 12:31 \ft Li zẹ \fq iLẹv 19.18\f*
\p 
\v 32 Ọni ọmọse ọ́ọ́, “U ga guẹ ngme, Ọsẹsẹ. Igẹsikia u ngme ni u wẹ khi Ẹshinẹgba ọghuo ọ khi, ali khi ọlese ọa ke la ọ, sẹ ni lọlighuo.\f + \fr 12:32 \ft Li zẹ \fq iDẹut 4.35\f*
\v 33 Ali khi awa ri udu oyi awa nya, ali isamhi eyi awa ali ekpabọ eyi awa nono ingme oyi Ẹshinẹgba. Ali awa nono ingme oyi ọnuzava ọyawa abi awa li nono ingme egbe awa. Ni awa rọ ri ishi eva ena gbe akanya, o ghọle Ẹshinẹgba dọsẹ ni awa ya ri iluasobo ali isomhopfa ọdọda bhale ghi ọli.”\f + \fr 12:33 \ft Li zẹ \fq Osia 6.6\f*
\p 
\v 34 Abi iJesu ọ rọ mẹ ilẹsingme ni ọ rọ sọ luẹ ọ, iJesu ọọ li, “Wa a ga nuata shi Eghiele oyi Ẹshinẹgba.”
\p Rọte aghọ vu ọgbọ okhọghuo ọa ke gbolo mhila li ogbọ okhọghuo.\f + \fr 12:34 \ft Li zẹ \fq iLuk 10.25-28\f*
\s1 Omi ọni Ọmiepfuese ọ khi
\r (iMat 22.41-46; iLuk 20.41-44)
\p 
\v 35 Abi iJesu ọ rọ la elemhi apfẹ ni o la Owa oyi Ẹshinẹgba sẹsẹ ẹgbọ, ọ mhila wẹ ogbọ. Ọ́ọ́, Elọ o zẹ ni esẹsẹ Ishi eyi iMosisi e rọ liẹ khi omi iDefidi Ọmiepfuese ọ khi?
\v 36 Abi Ayẹmhẹ-nọ-pfuasẹ o rọ kpha iDefidi sọ, ọ rọ rọte unu oyọli liẹ.
\q1 “ ‘Ẹshinẹgba ọ́ọ́, Ọnọmhuẹ oyẹmhẹ.
\q2 Shitọ mama mhẹ
\q1 ramhi ẹghẹghẹ
\q1 ni mhi rọ ya ri ebe ẹ
\q2 shi ẹ ufui ẹkoawẹ.’ ”\f + \fr 12:36 \ft Li zẹ \fq Iwolo 110.1\f*
\m 
\v 37 Ini iDefidi ọ rọte unu oyi lọlighuo lu ọli Ọnọmhuẹ, sẹ ọni Ọnọmhuẹ ọyọli ọ ke gbo liẹ khi omi ọli?
\p Ebubu ẹgbọ e ku esọ a shi ekẹ shi emini ọ ngme, ni o ri egbe mu wẹ.
\s1 IJesu ọ tse agua yẹ eniyẹ odukhokho eyọli shi esẹsẹ Ishi eyi iMosisi egbe
\r (iMat 23.1-36; iLuk 20.45-47)
\p 
\v 38 IJesu ọ sẹsẹ wẹ, Ọ́ọ́ wẹ, “A mu egbe ẹ shi esẹsẹ Ishi eyi iMosisi egbe. Itsua na dọlọdọlọ e ma ghọle wẹ e isọ ke kia ifui oki, ni ẹgbọ e ke tsẹ wẹ otsẹ ekpẹ.
\v 39 E ma nono ni wẹwẹ e shitọ ukpẹkhomhi ni ọ mu ẹloe elemhi owa ugamhi oyi awa ali ashini o mu ẹloe elemhi ilegba, ni a la le, ni a la da.
\v 40 Itoto e rọ li esamhi-olimhi ẹ le. Iromhi ni e nuẹ, eyi abamẹmhẹ, ẹ sọ. Ẹshinẹgba, ọ ya na wẹ osoli oniẹmhi to ọ.”
\s1 Irọna ni ọsamhi-olimhi ọ rọ na Ẹshinẹgba
\r (iLuk 21.1-4)
\p 
\v 41 Abi iJesu ọ rọ shitọ ti mama oni akpati ni a pfi ukpaghọlọ irọna a lo elemhi Owa oyi Ẹshinẹgba, ọọ bino ẹgbọ abi e li pfi ikpaghọ lo ọ. Ẹgbọ ni e pfue ebubu e pfi ikpokpomhi ikpaghọ lo.
\v 42 Ighọ ọsamhi-olimhi ni ọa mhuẹ emhikhọghuo, ọ li ya pfi anini eva lo.
\p 
\v 43 Ighọ iJesu ọ lu eniyẹ odukhokho eyọli, Ọ́ọ́ wẹ, “Igẹsikia mhi gue ẹ yẹ ẹ, khi ọni ọsamhi-olimhi ni ọa mhọli emhikhọghuo ọna, lọli ọ ri irọna ni o funẹ nya bhale dọsẹ ẹgbọ enekpọle nya
\v 44 Itobọ khi eri eni e pfue e rọte ẹpfue ni e mhuẹ mu ẹpfiẹ rọ riẹlẹ irọna. Ama ọni ọsamhi-olimhi ọna, rọte elemhi umhamẹ oyọli, ọ kie rue emini ọ mhọli nya ni ọ kha rọ ke le, riẹlẹ irọna.”
\c 13
\s1 IJesu ọ guele emini a ya ke mẹ ikpukhokho agbọ
\r (iMat 24.1-2; iLuk 21.5-6)
\p 
\v 1 Abi iJesu ọ rọte elemhi Owa oyi Ẹshinẹgba fiẹ lasele tee, ọmọ odukhokho ọyọli ọghuo, ọ́ọ́ li, “Bino ghue, Ọsẹsẹ! Ghe abi ukpokpomhi owa ona ali echẹ ni a rọ ma li e li somhi otse khẹ!”
\p 
\v 2 IJesu ọ sọ li ọ, ọ́ọ́, “Wa mẹ ukpokpomhi owa ona. Ẹghẹghẹ o ya bhale ni ẹchẹli okhọghuo ọa ke rọ ya migha ukhomhi okhọghuo. Wẹwẹ nya e ya de kua.”
\s1 Ozughu ali Imu-okhọli vule
\r (iMat 24.3-14; iLuk 21.7-19)
\p 
\v 3 Abi iJesu ọ li shitọ ukhomhi Ute ẹẹra Olivu, ni o sọ alo ghue oni Owa oyi Ẹshinẹgba, iPita ali iJemhisi ali iJọni ali Aduru e bẹna bhale ya mhila li,
\v 4 Ẹ ọli, “Gueyẹ anye, ẹghẹghẹ ni a rọ ya ke mẹ eni ingme enana. Elọ a ya ke mẹ ni a rọ ya lẹsẹ khi oni ẹghẹghẹ ni eni emhi ena e rọ ya tsẹ khi o she ramhi?”
\v 5 Ighọ iJesu ọọ wẹ, “A kuegbe-a ke tọkpẹ, ini ọgbọkhọghuo ọ khi di ẹ.
\v 6 Ebubu ẹgbọ e ya ri eva oyẹmhẹ bhale deba ẹ, ẹ liẹ khi, ‘Mhẹmhẹ mhi khi lọli,’ ẹẹ di ebubu ẹgbọ.
\v 7 Ini a suọ khi a khọli, o ke khi eri a suọ eko ingme okhọli obini odonuẹ, a khi ze ni o nighise ẹ udu. Emhi eghọghọ e mema bhale ya tsẹ, ama ukpẹsẹ agbọ ọa kie ramhi.
\v 8 Ishishi ali ishishi e ya mu okhọli vule shi egbe ọ, eghiele ali eghiele e ya li mu okhọli vule shi egbe wẹ ọ. Ekẹ o ya la asha kpa ke nighise, ẹẹ kuluẹ. Okiamhi oniẹmhi ọ́ọ̀ pfi. Igbaekẹle osoli na abi ọọ li ọkpotso ni oku o lẹsẹ bẹlẹ ẹ to egbe.
\p 
\v 9 “A ri ukpẹloe shi ekẹ lolo ke tọkpẹ. A ya mu ẹ je owa ni a la guẹ ẹzọ. A la elemhi Owa ugamhi gbe ẹ. A ya ri itobọ oyẹmhẹ mu ẹ bhale odalo oyi enighie ali eni ẹ mhẹsẹ ni a rọ gue usomhi onete oyi Ẹshinẹgba yẹ wẹ.
\v 10 Ama neni ukpẹsẹ agbọ o ya ramhi, a mema she ya tse abọ oni usomhi onete oyi Ẹshinẹgba yẹ ẹgbọ na ishishi nya.
\v 11 Ini a da mu e bhale khi a rẹ ẹ gue ẹzọ, khi zẹ ni udu o nasẹ ẹ shi emini u ya ngme. Ama lẹsẹ ngme emiemini Ẹshinẹgba o ya rọ nẹ oni ẹghẹghẹ aghọ, itobọ khi ọa khi yẹyẹ wa ngme, ama Ayẹmhẹ-nọ-pfuasẹ.\f + \fr 13:11 \ft Li zẹ \fq iMat 10.17-20; iLuk 12.11-12\f*
\p 
\v 12 “Ẹgbọ e ya ri inyọghuo wẹ bhale na gbolo-a, ita e li ri imi wẹ li bhale ni a li gbolo-a. Ẹghẹghẹ aghọ, eniyẹ e ya ke sọ alo okhọli ghue eni e bia wẹ ọ, e gbolo wẹ-a.
\v 13 Ẹgbọ nya e ya ri itobọ oyẹmhẹ ke biselemhi ẹ, ama ọni ọ ri egbe mie ya ramhi ukpẹsẹ, a ya mie pfuese.\f + \fr 13:13 \ft Li zẹ \fq iMat 10.22\f*
\s1 Emhi obe ni ọọ vẹsẹ ẹgbọ kua
\r (iMat 24.15-28; iLuk 21.20-24)
\p 
\v 14 “Ama, a kha da mẹ emini ẹ pfi oyese, ashini aa kha mẹ ọli, ikhi oni ọ vẹsẹ ẹgbọ kua, ẹghẹghẹ aghọ ọni ọ zẹ ebe ọ lẹsẹ abi a ri emini ọ zẹ ngme. Eni e la ekẹ iJudia e na nga ikhomhi ite.\f + \fr 13:14 \ft Li zẹ \fq iDan 9.27; 11.31; 12.11\f*
\v 15 Ọni ọ la ukhomhi owa ne ọ khi tiemhile elemhi owa ya rue emhikhọghuo.
\v 16 Ọni ọ la ifui ishemhi ọ khi na bhale apfẹ ya rue awulu oyọli.\f + \fr 13:16 \ft Li zẹ \fq iLuk 17.31\f*
\v 17 O ma ze mu ikpotso ni ẹ mẹ ali eni e mhọli eniyẹ ni ẹ nye ẹnyeli shi egbe ẹghẹghẹ aghọ.
\v 18 Lema Ẹshinẹgba ọ khi bie zẹ ni o de shi ẹghẹghẹ ni ulili oniẹmhi o la gbe ẹgbọ elemhi ukpe.
\v 19 Itobọ khi onana o ya khi osoli ni o khọlọ ne nya rọte ẹghẹghẹ ni Ẹshinẹgba ọ te ma agbọ. Ọgbọ a ke gbo ya mẹ osoli uza onana ghue ekẹ agbọ.\f + \fr 13:19 \ft Li zẹ \fq iDan 12.1; Irọ 7.14\f*
\v 20 Ini Ẹshinẹgba ọa li rọte ogbẹlẹ osoli ni a ngme ena khi-a, ọgbọkhọghuo ọa ya dobẹ ji ukhomhi ọ le. Ama irari oyi ẹgbọ eyọli ni ọ zẹ ọda kẹ, ọ rọ rọte eni ogbẹlẹ osoli ena khi-a.
\v 21 Ẹghẹghẹ aghọ ini ọgbọkhọghuo ọ gueyẹ, ‘Ghekhẹ, ghe Ọmiepfuese!’ Okekhia khi eri ọ́ yẹ, ‘Ghe ọli oobọ khẹ!’ Khi mie ọli suọ.
\v 22 Itobọ khi iromhi emiepfuese ali emekẹguele e ya lasele. E ya ke riẹlẹ ọlẹlẹ ali ikanya ọnyaloa ọdọda rọ ke di ẹgbọ. Ni o khia khi ini ọa gue kia, e ga li ya di egbegbi eni Ẹshinẹgba ọ zẹ ọda kẹ.
\v 23 Irarighọ, a ga lolo kuegbe-a ke tọ ẹloe ekẹ. Mhi she gue emhi nya yẹ ẹ shi ekẹ se neni oni ẹghẹghẹ o ya ramhi.
\s1 Inyenegbe bhale oyi Omi Ọgbọ
\r (iMat 24.29-31; iLuk 21.25-28)
\p 
\v 24 “Ini ẹghẹghẹ osoli ona o ga dọsẹ se nya,
\q1 “ ‘Ovọ o ya bishi alo-a,
\q2 uki ọa ke dobẹ gẹ,\f + \fr 13:24 \ft Li zẹ \fq Aza 13.10; Ezik 32.7; iJọẹ 2.10,31; 3.15; Irọ 6.12\f*
\q1 
\v 25 Ikpẹtata e deno ukhuli kule,
\q2 ukhuli ali ekpabọ
\q2 ni e la irarogbe ẹ mhẹsẹ
\q2 e ya ke nighise.’\f + \fr 13:25 \ft Li zẹ \fq Aza 34.4; iJọẹ 2.10; Irọ 6.13\f*
\p 
\v 26 “Ẹghẹghẹ aghọ, ẹgbọ nya e ya mẹ khi Omi Ọgbọ ọ kia elemhi otughunu ẹ bhale, elemhi ekpabọ ali ufumhi ni ọ gẹ nyanyanya.\f + \fr 13:26 \ft Li zẹ \fq iDan 7.13; Irọ 1.7\f*
\v 27 Ẹghẹghẹ aghọ, ọ ya ghie igẹni eyọli e te asha kpa, ikhi ukpẹsẹ agbọ nya, ti ẹgbọ eyọli ni ọ zẹ ọda kẹ gbili.
\s1 Osẹsẹ oyi oni ọọra ọkhua-eni
\r (iMat 24.32-35; iLuk 21.29-33)
\p 
\v 28 “Bino abi ọkhua-eni o li ẹ te. O kha da kpẹsẹ ukhuli, ni o rọ ke ta ebe ne, lẹsẹ khi okasẹ o kẹlẹ ya le.
\v 29 A kha da gbo li lighọ mẹ khi eni emhi ena khi a da mẹ wẹ ne, lẹsẹ khi ẹghẹghẹ o she ramhi.
\v 30 Abi o li mhi li gue ọli ẹ yẹ ẹ khi, ẹgbọ eghuo ni e la agbọ memena ẹa ya ghu ne, ni eni emhi ena nya e rọ bhale ya tsẹ.
\v 31 Ekẹ ali ukhuli e ya dọsẹ, ama ingmemhi eyẹmhẹ ẹa ya tigbe dọsẹ ghue.
\s1 Ọgbọkhọghuo ọa lẹsẹ oni ogbẹlẹ wẹẹ oni ẹghẹghẹ
\r (iMat 24.36-44)
\p 
\v 32 “Ọgbọkhọghuo ọa lẹsẹ oni ogbẹlẹ wẹkhi oni ẹghẹghẹ. Ghe egbegbi igẹni ena iloghie ali mhẹmhẹ Omi ọli, sẹ ni Itamhẹ lọlighuo.\f + \fr 13:32 \ft Li zẹ \fq iMat 24.36\f*
\v 33 A ri ukpẹloe shi ekẹ ke tọkpẹ, itobọ khi waa lẹsẹ ẹghẹghẹ ni ọ la ya bhale.
\v 34 Eri ona o li abi ọmọse ni ọ vu asha obini odonuẹ, ni ọ ri ighumha eyọli shi apfẹ e ri ukpẹloe khu shi na luẹ. Ọ gueyẹ ọgbọgbọ akanya ni ọ ya gbe. Ọ gueyẹ ọni ọ khẹ ekhẹ ọ ke khẹ ekhẹ apfẹ.\f + \fr 13:34 \ft Li zẹ \fq iLuk 12.36-38\f*
\p 
\v 35 “Irarighọ, ke khẹ ekhẹ, itobọ khi waa lẹsẹ ẹghẹghẹ ni ọga ọ rọ ya jele. Ini ẹlogbọmhi lọ o, okekhi itsotso ogbiẹ lọ o, okekhi ẹghẹghẹ obili-atso lọ o, abi khi ogbiẹ-fiefie lo.
\v 36 Ini ọ bhale guo, khi zẹ ni ọ bhale ya ẹ khi u wa lesẹ a.
\v 37 Abi mhi li gue ọli yẹ ẹ ena mhi li gbo gueyẹ ọgbọkpa. ‘A ke khẹ ekhẹ!’ ”
\c 14
\s1 Ugbamhi ni a gba khẹ iJesu
\r (iMat 26.1-5; iLuk 22.1-2; iJọn 11.45-53)
\p 
\v 1 O ke kpe ogbẹlẹ eva le ni a rọ ya li ukpe iPasova ali ukpe ni a la le ibulẹdi ni aa ri ifuma shi nye, ighie eyi ekpodalo-ugamhi ali esẹsẹ Ishi eyi iMosisi, ee nono odẹ ni e te ya bẹna mu iJesu gbe-a.\f + \fr 14:1 \ft Li zẹ \fq Okiali 12.1-27\f*
\v 2 Ẹ egbe, “Awa khi riẹlẹ ọli ini a li imu, onyaghu ọa ya lasele shi ọ.”
\s1 A la iBẹtani ku oili shi iJesu egbe
\r (iMat 26.6-13; iJọn 12.1-8)
\p 
\v 3 Abi iJesu ọ rọ la ẹoli iBẹtani, owa oyi iSamọ ni efafe e kpẹ mu shitọ le eminale, ọkpotso ọghuo ọ rue ukoko ituale ni o lolo ghalẹ, ni o pfie lasele. Ọ gbe oni ukoko a, ọ ku oni ituale shi iJesu ukhomhi.\f + \fr 14:3 \ft Li zẹ \fq iLuk 7.37-38\f*
\v 4 Ẹgbọ eghuo ni e la aghọ, e ri elemhi ibibi liẹ egbe, “Elọ o zẹ ni a rọ na pfuẹchẹ oni ituale kua shi afuẹ?”
\v 5 A kha ri ọli dẹ ramhi ifata ukpe ali emhi, a kemhi eni ikpaghọ na eni ẹa mhuẹ. E shi ọni ọkpotso unu egbegbọ.
\p 
\v 6 Ama iJesu ọ́ọ́ wẹ, “A zẹ ọli obọ. Elọ a yẹsẹ ọli ẹ ngme shi? Egbegbi emini o ti ni o somhi otse ọ riẹlẹ na mhẹ.
\v 7 Ẹghẹghẹ kpa eni ẹa mhuẹ e rọ nu ẹ la ana, ẹghẹghẹ ni o ghọle ẹ kpa a kpaghiẹ wẹ obọ. Ama aa ya mẹ mhẹ ẹghẹghẹ kpa.\f + \fr 14:7 \ft Li zẹ \fq iDẹut 15.11\f*
\v 8 Emini ọ dobẹ ya riẹlẹ ọ riẹlẹ eghọ. Eri ọ ku ituale ku mhẹ egbe shi ekẹ khẹ ẹghẹghẹ irọtọ oyẹmhẹ.
\v 9 Igẹsikia mhi gue ẹ yẹ ẹ khi, ashashini a da la tse abọ usomhi onete ekẹ agbọ ona nya ne, a ya yele emini ọkpotso ọna ọ riẹlẹ le.”
\s1 IJudasi ọ lama khi lọli ya ri iJesu dẹ
\r (iMat 26.14-16; iLuk 22.3-6)
\p 
\v 10 Ẹghẹghẹ aghọ iJudasi Isikarọti, ni ọ khi ọtuọghuo eniyẹ odukhokho ogbava, ọ lẹ deba ighie eyi ekpodalo-ugamhi, ni ọ ya ri iJesu na wẹ dẹ.
\v 11 Onana ni ọ gueyẹ wẹ, o ga ghọle wẹ. E shobọ khi wẹwẹ e ya ri ikpaghọ na li. Ighọ iJudasi ọ li nono ẹghẹghẹ ni ọ ti ni ọ rọ ya mẹ asha ri iJesu na wẹ.
\s1 IJesu ọ nu eniyẹ odukhokho eyọli le Eminale iPasova
\r (iMat 26.17-25; iLuk 22.7-14,21-23; iJọn 13.21-30)
\p 
\v 12 Ogbẹlẹ ni ododẹ ni a li oni ukpe ni a la le ibulẹdi ni aa ri ifuma shi nye o ramhi, ni o khi ogbẹlẹ ni a rọ gbe ozele Osumha ọyi oni iPasova-a, eniyẹ odukhokho eyi iJesu e mhila li “Ashi o ghọle ẹ ni anye mu egbe shi ekẹ nẹ, ni u la le eminale iPasova?”
\p 
\v 13 Ighọ, ọ ghie eniyẹ odukhokho etuava eyọli, ọ́ọ́ wẹ, “A lo ifuapfẹ, ọmọse ni ọ tsua ubene amẹ, ọ ya lona ẹ odẹ. A deba li je apfẹ.
\v 14 A gueyẹ ọni ọ mhọli apfẹ ni ọ ya lo, khi, ‘Ọsẹsẹ ọọ, anye mhilẹ u ri anye khasẹ elemhi owa ni lọli ali eniyẹ odukhokho eyẹluẹ wẹwẹ e la ya le eminale iPasova?’
\v 15 Ọ ya rẹ ẹ khasẹ agbala ni emhi nya e gba shi ukhomhi owa atọnga, a muno egbe shi akaghọ na awa.”
\p 
\v 16 Eni eniyẹ odukhokho e vu, e lo ifui apfẹ, e ya mẹ eni emhi tee abi iJesu ọ gue ọli yẹ wẹ. Ighọ e mu egbe oni eminale iPasova.
\p 
\v 17 Ogbọmhi o mu ekẹ, iJesu ali eni eniyẹ odukhokho ogbava e bhale.
\v 18 Abi e li shitọ gasẹ itebu le eminale, iJesu ọ́ọ́ wẹ, “Egbegbi-ingme mhi gue ẹ yẹ ẹ khi ọtuọghuo elemhi ẹ ọ ya rẹ mhẹ dẹ. Ọni ọ nu mhẹ le emhi memena.”\f + \fr 14:18 \ft Li zẹ \fq Iwolo 41.9\f*
\p 
\v 19 Udu o yese wẹ-a, ọtuọghuo-ọghuo ọọ mhila li, “She khi ọa khi mhẹmhẹ o khi?”
\p 
\v 20 Ọ sọ wẹ ọ, ọ́ọ́ wẹ, “Ọtuọghuo elemhi ẹẹ ogbava ọ ya khi, ọni ọ ga ri ibulẹdi nu mhẹ ẹ sọmhi elemhi utasa memena.
\v 21 Eri Omi Ọgbọ ọ ya ghu-a abi a li kẹkẹ ọli shi ekẹ na li. Eri-tsẹ khi, o maa khọlọ ọni ọ ya rọli dẹ egbe! O kha ga ti nẹ, ini ọgbọ ọa bie bia li lọ!”
\s1 Eminale oyi Ọnọmhuẹ
\r (iMat 26.26-30; iLuk 22.14-20; 1 iKọri 11.23-25)
\p 
\v 22 Abi e li le eminale eghọ, iJesu ọ rue ibulẹdi, ọ kphẹmhi, ọ khi ọli a, ọ rọ na eniyẹ odukhokho eyọli, ọ́ọ́, “A mọ le; Idiegbe oyẹmhẹ na.”
\p 
\v 23 Ighọ ọ gbo sọ onyọ shi uko, ọ kphẹmhi, ọ rọli na wẹ, wẹwẹ nya e ga te ọ da.
\p 
\v 24 IJesu ọ́ọ́ wẹ, “Ọlia eyẹmhẹ na ni e migha shi ishiobọ onogbọ, ni a ku kua na ebubu ẹgbọ.\f + \fr 14:24 \ft Li zẹ \fq Okiali 24.8; iJere 31.31-34\f*
\v 25 Mhi gue igẹsikia yẹ ẹ khi mhi aa ke gbo ya rọte onyọ upfonu ona da, sẹ ni obini Eghiele oyi Ẹshinẹgba, ni mhi la da onyọ onogbọ.”
\v 26 Abi e rọ to uwolo se, e fiẹ lasele, e je Ute Ẹẹra olivu.
\s1 IJesu ọ guele shi ekẹ khi iPita ọ ya kie luẹ
\r (iMat 26.31-35; iLuk 22.31-34; iJọn 13.36-38)
\p 
\v 27 IJesu ọ́ọ́ wẹ, “Ẹẹ nya, a ya na kua, a zẹ mhẹmhẹ-ghuo obọ, irari khi a she kẹkẹ ọli shi Ebe-no-pfuasẹ khi.
\q1 “ ‘Mhi ya ri emhi li
\q2 ọrisumhakia,
\q2 isumha e ya vẹ kua.’\f + \fr 14:27 \ft Li zẹ \fq iZaka 13.7\f*
\p 
\v 28 “Ama ini a guise mhẹ le se, mhi ya ralo khẹ ẹ iGalili.”\f + \fr 14:28 \ft Li zẹ \fq iMat 28.16\f*
\p 
\v 29 IPita ọọ li, “Ini ẹgbọ nya e ririẹ kie ẹ, mhi aa ya kie ẹ.”
\p 
\v 30 IJesu ọ́ọ́ iPita, “Mhi gueyẹ khi, neni ọkpa ọọ gbiẹghẹ iteva amiọsẹ, u ya kie mhẹ itesẹ.”
\v 31 IPita ọ kie gẹma ọ gue gagaga, ọ liẹ, “Ini o ri riẹ khia khi oni mhi la nu ẹ ghu-a lọ, mhi aa ya tigbe kie-ẹ.” Enekpọle nya e li ngme ghọ.
\s1 IJesu ọ la iGẹtisẹmani sọ iromhi
\r (iMat 26.36-46; iLuk 22.39-46)
\p 
\v 32 E je ashini a lu iGẹtisẹmani, iJesu ọọ eniyẹ odukhokho eyọli, “A shitọ ana ni mhi ya sọ iromhi bhale.”
\v 33 Ọ rue iPita ali iJọni ali iJemhisi ma egbe vu. Iyesudu-a ali anasẹmhẹ e bhale na li.
\v 34 Ọ wẹ, “Oya ni o la mhẹ udu memena o gba a. O ga nono ni luẹ gbe mhẹ. A migha akana khẹ mhẹ, a ke tọkpẹ.”
\p 
\v 35 Ọ ti je odalo dẹnẹ, ọ de ya yẹshi ekẹ, ọọ sọ iromhi ini o ya zẹ riẹlẹ ni oni ẹghẹghẹ ona o dọsẹ luẹ.
\v 36 Ọ́ọ́, “Itamhẹ, Itamhẹ, emhikpa o zẹ ẹ riẹlẹ. Rue mhẹ oni uko osoli ona odalo le. Eri-tsẹ khi, ọa khi abi o ghọle mhẹ, sẹẹ ni abi o li ghọle ẹ.”
\p 
\v 37 Abi ọ nyenẹ egbe bhale, ọ mẹ khi eni eniyẹ odukhokho e lesẹ-a. Ọọ iPita, “ISamọ, eri u lesẹ-a? Aa dobẹ nu mhẹ tọkpẹ ukuku ẹghẹghẹ tsẹ?
\v 38 Ri ukpẹloe shi ekẹ gboo ke sọ iromhi ini u khi de ini u mhọli imufẹ. Ayẹmhẹ oyẹ o mu egbe ni o rọ riẹlẹ, eri-tsẹ khi, idiegbe oyẹ ọa dobẹ.”
\p 
\v 39 Ighọ ọ gbo vu ya sọ iromhi enabi ọ kpẹ sọ.
\v 40 Abi ọ rọ nyenẹ egbe bhale, ọ gbo bhale ya ẹ wẹ khi e lesẹ-a, irari khi olesẹ o la wẹ alo, ẹa lẹsẹ abi e ke ya ngme ọli.
\p 
\v 41 Abi ọ rọ nyenẹ egbe bhale utonuzesẹ, ọ́ọ́ wẹ, “Olesẹ a kie la, ni a yẹmhẹ-a? Olesẹ oghọ o she bu ẹ! Oni ẹghẹghẹ o she ramhi. A bino khẹ khi, a ri Omi Ọgbọ na ena olamhẹ dẹ.
\v 42 A vule ni awa vu! Ọni ọ́ rẹmhẹ dẹ ọ́ọ́ bhale ena!”
\s1 A mu iJesu
\r (iMat 26.47-56; iLuk 22.47-53; iJọn 18.3-12)
\p 
\v 43 Abi ọ li ngme, iJudasi, ni ọ khi ọtuọghuo elemhi eni eniyẹ odukhokho ogbava ọ bhale. Ẹgbọ ni e tsua itsua okhọli ali itakobi ali ikpokpo, ni ighie eyi ekpodalo-ugamhi, ali esẹsẹ Ishi eyi iMosisi ali egbhali e ghie, e nu ọli bhale.
\p 
\v 44 Ọni ọ rọli dẹ ọ she kpẹ gueyẹ eni e nu ọli kia, ọọ wẹ, “Ọni mhi da pfipfi ekphamhi ne, lọli ọ khi ọni a nono. A mu ọli, a khẹ ọli ekhẹ rue vu.”
\v 45 Abi e rọ lẹsẹ lole, iJudasi ọ lẹ deba iJesu, ọ́ọ́, “Ọsẹsẹ.” Ọ pfipfi ọli ekphamhi.
\v 46 Eni emọse e mu iJesu.
\v 47 Ighọ ọtuọghuo eni e migha epfẹ-aghọ ọ ji itakobi oyọli emhi lasele, ọ bẹ oghumha ọyi Ọga ọyi ekpodalo ugamhi esọ-a.
\p 
\v 48 IJesu ọ́ọ́ wẹ, “Okhọli mhi tsua, ni a rọ lina tsua itsua okhọli ali itakobi ali ikpokpo bhale ya mu mhẹ?
\v 49 Ogbẹlẹ kpa mhi rọ nu ẹ la, mhi la Owa oyi Ẹshinẹgba ẹ sẹsẹ. Aa mu mhẹ. Eri a mẹ emhi ena ni emini a kẹkẹ shi Ebe-no-pfuasẹ o bhale ya tsẹ.”\f + \fr 14:49 \ft Li zẹ \fq iLuk 19.47; 21.37\f*
\v 50 Ighọ eniyẹ odukhokho eyọli nya ni e deba li e vẹ kua, o kpe lọlighuo le.
\p 
\v 51 Ọzẹo ọghuo ni ọ sọ awulu ona yẹyẹyẹ, ọọ deba iJesu. Abi e rọ tọ obọ sọ li, khi wẹwẹ e ya mu ọli,
\v 52 ọ nyanọ awulu-a mhuẹ wẹ abọ, ọ ri irumheba na vu.
\s1 Otu iSaẹdiri e ri iJesu gue ẹzọ
\r (iMat 26.57-68; iLuk 22.54-55,63-71; iJọn 18.13-14,19-24)
\p 
\v 53 E mu iJesu bhale owa oyi Ọga ọyi ekpodalo ugamhi, ighie eyi ekpodalo-ugamhi nya, ali egbhali ali ekẹkebe ali esẹsẹ Ishi eyi iMosisi nya e le gba.
\v 54 IPita ọ tapfia deba li ukhu-khokho, ya ramhi elemhi apfẹ oyi Ọga ọyi ekpodalo ugamhi. Ọ nu eni ẹ khẹ ekhẹ shitọ khasẹ erali.
\p 
\v 55 Eni ighie eyi ekpodalo-ugamhi ali oni igbaa oyi iSaẹdiri nya, e nono emhi ushi ni e ya mu mhọli iJesu obọ, ni e ba mẹ asha gbe ọli-a. Ẹa mẹ emhikhọghuo.
\v 56 Ebubu ẹgbọ e pfi ọtsẹlẹ eyi ẹgbhọli mu ọli, eni ọtsẹlẹ nya, ẹa de shi oghuo.
\p 
\v 57 Ikpukhokho, ẹgbọ eghuo e vule pfi ọtsẹlẹ ẹgbhọli ona mu iJesu. Ẹẹ,
\v 58 “Anye suọ khi ọọ liẹ khi, ‘Mhi ya guọghọ Owa oyi Ẹshinẹgba onana ni ẹgbọ e ri abọ ma-a, ẹlẹ-esẹ mhi tọ olese ni ẹgbọ ẹa ri abọ ma.’ ”\f + \fr 14:58 \ft Li zẹ \fq iJọn 2.19\f*
\v 59 Abi e riẹ kie ngme ona, ọtsẹlẹ eyẹwẹ ẹa kie de shi oghuo.
\p 
\v 60 Ighọ Ọga ọyi ekpodalo ugamhi ọ vule migha odalo oyẹwẹ nya, ọ mhila iJesu. “Waa bie ya sọ wẹ ọ? Ẹzọ elọ na ni ẹgbọ ena ẹẹ gue shi ẹ egbe?”
\v 61 Ama iJesu ọ tsaghiẹ a, ọa sọ wẹ ọ. Ọga ọyi ekpodalo ugamhi, ọ gbo mhila li, “Yẹyẹ u khi Ọmiepfuese, Omi Ẹshinẹgba ọna Kuẹghiẹ?”
\p 
\v 62 IJesu ọ́ọ́ li, “Lọli mhi khi. Ẹẹ nya a ya mẹ khi Omi Ọgbọ ọ shitọ obita oyi Ẹshinẹgba ni ọ funẹ, ali khi ọ la otughunu rọte irarogbe ẹ tiemhie.”\f + \fr 14:62 \ft Li zẹ \fq iDan 7.13\f*
\p 
\v 63 Ọga ọyi ekpodalo ugamhi ọ nyanọ itsua shi egbọli uruli abi ọ li yila. Ọ́ọ́, “Awa ke gbo nono ọtsẹlẹ olese.
\v 64 Ẹẹ nya a she suọ abi ọ pfi unu-a deba Ẹshinẹgba. Sẹ a sọ shi ọ?”
\p Wẹwẹ nya e pfa ẹzọ mu ọli khi ọni a gbe-a ọ khi.\f + \fr 14:64 \ft Li zẹ \fq iLẹv 24.16\f*
\v 65 Ẹgbọ eghuo ọ, e tono etẹ ku ọli. E ri emhi gẹnọ ọli alo. E pfi ọli emhi, ẹ ọli, “Mẹ ekẹ guele, gueyẹ anye ọni ọ pfi ẹ emhi?” Eni ẹ khẹ ekhẹ e mu ọli, e lase ọli esọ.
\s1 IPita ọ khi lọli ẹa lẹsẹ iJesu
\r (iMat 26.69-75; iLuk 22.56-62; iJọn 18.15-18,25-27)
\p 
\v 66 Abi iPita ọ kie shitọ elemhi apfẹ eghọ, ọmueshi ọghuo ni ọ khi ọni ọọ ga ọyi Ọga ọyi ekpodalo ugamhi ọ bhale.
\v 67 Ọ mẹ iPita abi ọ rọkhasẹ erali, ọ tọli ọkpẹ tsukẹ.
\p Ọọ li, “Yẹyẹ u li nu iJesu na iNazarẹti i kia.”
\p 
\v 68 Ama iPita ọ tia. Ọ́ọ́, “Mhi a lẹsẹ emini wa ngme.” Ọ lase aghọ le je odẹ ni a tẹ ẹ lo elemhi apfẹ. [Ighọ ọkpa ọ gbiẹghẹ.]
\p 
\v 69 Abi ọni ọmueshi ni ọ ga ọgbọ ọghọ ọ rọ gbo mẹ iPita aghọ, ọ gbo riẹlẹ eni ingmemhi ngme khasẹ eni e migha epfẹ aghọ. Ọọ, “Ọtuọghuo elemhi wẹ, ọni ọmọse ọna ọ khi.”
\v 70 IPita ọ gbo tia.
\p Oo li dẹnẹ, eni e migha epfẹ aghọ e kẹ iPita, “Igẹsikia lọ khi ọtuọghuo elemhi wẹ u khi, irari khi ọnge iGalili u khi.”
\p 
\v 71 Ighọ ọ li sẹ egbọli isheli, ọ romhi eni isheli. Ọ liẹ, “Mhi aa ga lẹsẹ ọmọse ọna ni a ngme ena.”
\p 
\v 72 Utoghuokpe, ọkpa ọ gbiẹghẹ utonuzi-eva. IPita ọ sato emini iJesu ọ gueyẹ ọli khi, “Neni ọkpa ọ ya gbiẹghẹ utonuzi-eva, u ya kie mhẹ itesẹ.” Ighọ ọ gbe akhe eviẹ a.
\c 15
\s1 A rue iJesu bhale odalo oyi iPaleti
\r (iMat 27.1-2,11-14; iLuk 23.1-5; iJọn 18.28-38)
\p 
\v 1 Ẹluzogbe fiefie, ighie eyi ekpodalo-ugamhi, ali egbhali ali esẹsẹ Ishi eyi iMosisi ali igbaa eyi iSaẹdiri nya, e ye ugbamhi. E gẹ iJesu rue vu ghi iPaleti.
\p 
\v 2 Ọni iPaleti ọ mhila iJesu ogbọ, ọọ li, “Oghie ọyi ẹgbọ iJu u khi?”
\p IJesu ọ́ọ́, “Eee! Ighọ lọ abi u ngme ọli.”
\p 
\v 3 Eni ighie eyi ekpodalo-ugamhi eyi Ẹshinẹgba e ga gue ẹzọ emhi ebubu shi iJesu egbe.
\v 4 Ighọ iPaleti ọ gbo mhila li ogbọ, ọ́ọ́, “Wa ya pfunu, u suọ iwali ẹzọ ni e gue ẹ shi ẹ egbe?”
\p 
\v 5 Ama iJesu ọa sọ li ọ. O ri abọ sha iPaleti.
\s1 A pfa ẹzọ mu iJesu a ka gbe ọli a
\r (iMat 27.15-26; iLuk 23.13-25; iJọn 18.39--19.16)
\p 
\v 6 Abi áá li ini o lina ramhi ẹghẹghẹ ukpe iPasova, eri iPaleti ọ rue ọgbọ ọghuo owa ighumha lasele na wẹ abi o ghọle wẹ shi.
\v 7 Ẹghẹghẹ aghọ ọmọse ọghuo ni a lu iBarabasi ọ la owa ighumha, ni ọ khi ọghuo ẹgbọ ni a mu. Eri a mu ọli shi ugbeli ni ọ gbe ẹghẹghẹ ni a rọ mẹ onyaghu.
\v 8 Abi eni ẹgbọ e rọ bhale gbii ya mhila iPaleti ọ riẹlẹ emini ọ kie kpẹ riẹlẹ na wẹ,
\v 9 IPaleti ọ mhila wẹ, ọọ, “A nono ni mhi rue oghie iJu abọ a na ẹ?”
\v 10 Ọ́ ga lẹsẹ gboo khi itobọ ibiselemhi, ighie eyi ekpodalo-ugamhi e rọ mu iJesu ghi luẹ.
\v 11 Ama ighie eyi ekpodalo-ugamhi e sẹsẹ ẹgbọ e gueyẹ iPaleti ọ ri ochoghọ wolọ iBarabasi obọ a na ẹwẹ.
\p 
\v 12 IPaleti ọ mhila wẹ, ọ́ọ́, “Elọ mhi kẹ li ọni a lu oghie iJu shọ?”
\p 
\v 13 E tsẹsẹ leghe, “A ta li ma ọara apfida.”
\p 
\v 14 IPaleti ọ mhila wẹ, ọ́ọ́, “Elọ o zẹ, umha-guẹkia onoghuo ọ riẹlẹ?” Ama eena e tsẹsẹ nẹ, “A ta li ma ọara apfida!”
\p 
\v 15 Ni ọ rọ riẹlẹ emini oo ghọle eni ẹgbọ, ọ wolọ iBarabasi abọ-a na wẹ. Ọ́ọ́ e gbe iJesu itẹ, ọ rue ọli na wẹ e ka ta li ma ọara apfida.
\s1 Ekhọli-okhuẹ e ri iJesu li egia
\r (iMat 27.27-31; iJọn 19.2-3)
\p 
\v 16 Eni ekhọli-okhuẹ e rue iJesu lo elemhi apfẹ agbala oyi igọvunọ. E lu ekhọli-okhuẹ apfẹwẹ eni e kpọle.
\v 17 E ri awulu ichẹ ni o khi ẹgholi ibulu, sọ li, e ri igba do arula rughu ọli ukhomhi.
\v 18 E liẹ ọli, “A da abọ na oghie ọyi ẹgbọ iJu!”
\v 19 E pfino ọli ukpokpo ukhomhi iti ingmi-ingmẹ, e tono etẹ ku ọli. E de ya wugha li odalo, e nyẹsẹ ukhomhi na li.
\v 20 Abi e rọ lighọ ri iJesu li egia se nya, e gueghie ọli oni awulu ichẹ ni o khi ẹgholi ibulu oghọ, e nyenẹ egbe ri itsua eyọli sọ li. Ighọ e rue ọli vu ya tama ọara apfida.
\s1 A ta iJesu ma apfida
\r (iMat 27.32-44; iLuk 23.26-43; iJọn 19.17-27)
\p 
\v 21 Abi e rọ lẹ, e ya ẹ ọmọse ọghuo ni a lu iSamọ ni ọ rọte odẹ oyọli dọsẹ, ni ọ rọte asha jele. Ighọ eni ekhọli-okhuẹ e ri itoto mu ọli ọ tsua ọara apfida oyi iJesu. ISamọ ọngi iZirẹni ọ khi, ọ gbo khi ita Alẹzada ali iRufọsi.\f + \fr 15:21 \ft Li zẹ \fq iRom 16.13\f*
\v 22 E rue iJesu bhale ashini a lu iGọgọta. [Ugua ukhomhi olimhi a ri iGọgọta ngme]
\v 23 A ri onyọ ni a ku ikhumhi na lui Imari shi na li ọ rọ da, ama ọa lama da li.
\v 24 E ta li ma ọara apfida. E kemhi itsua ni ọ sọ mhọli egbe abọ. E ti ebe rọ kemhi eni ide eyọli, ni e lẹsẹ oni o ya tẹ ọgbọgbọ.\f + \fr 15:24 \ft Li zẹ \fq Iwolo 22.18\f*
\p 
\v 25 Ẹghẹghẹ agogo itili ẹluzogbe a rọ ta li ma ọara apfida.
\v 26 Emini e kẹkẹ rọ kphase oni ọara apfida kpeda na li khi. Oghie Ọyi Ẹgbọ iJu.
\v 27 E li gbo ta ighiatọ etuava ma ọara apfida mama li, ọtuọghuo ọ la li obọ-ita, ọnọkpọle ọ la li obọgobọ.
\v 28 Ona o ri emini a kẹkẹ shi Ebe-no-pfuasẹ bhale ya tsẹ, ni ọ́ọ́, “A leli ọli ma ighiatọ.”\f + \fr 15:28 \ft Li zẹ \fq Aza 53.12\f*
\v 29 Ẹgbọ eni e te epfẹ aghọ dọsẹ, e pfi itsue manya iJesu, ee nighise ukhomhi, e liẹ, “Ebanẹkẹ! Yẹyẹ ni u ya guọghọ Owa oyi Ẹshinẹgba-a, u gbo riẹlẹ ọ tọ ogbẹlẹ esẹ.\f + \fr 15:29 \ft Li zẹ \fq Iwolo 22.7; 109.25; iMak 14.58; iJọn 2.19\f*
\v 30 Rọ te ọara apfida tiemhie shọ ya mie egbe ẹ pfuese.”
\p 
\v 31 Ighọ ighie eyi ekpodalo-ugamhi, ali esẹsẹ Ishi eyi iMosisi e li ri iJesu li egia, e liẹ egbe wẹ. “Ọ mie ẹgbọẹse pfuese, ama ọa dobẹ mie egbọli pfuese.
\v 32 A zẹ ni ọni Ọmiepfuese ọna, ikhi oghie iZirẹni, ni ọ rọte ọara apfida tiemhie ni awa mẹ, ni awa mie ọli suọ.” Eni a li ta ma ọara apfida mama li, e ga li nu wẹ tsue ọli.
\s1 Eghuli oyi iJesu
\r (iMat 27.45-56; iLuk 23.44-49; iJọn 19.28-30)
\p 
\v 33 Agogo igbẹva ọguota, obili o bi oni ekẹ a nya. Elemhi iwakati esẹ oni obili o la ogbe ramhi.
\v 34 Agogo esẹ o ramhi, iJesu ọ tsẹsẹ leghe, ọ ri unu ẹoli oyẹwẹ liẹ, “Eloi, Eloi, Lama Sabachi tani?” Emini a ri ona ngme khi, “Ẹshinẹgba ọyẹmhẹ, Ẹshinẹgba ọyẹmhẹ, elọ o zẹ ni u rọ tsua mhẹ pfia.”\f + \fr 15:34 \ft Li zẹ \fq Iwolo 22.1\f*
\p 
\v 35 Abi ẹgbọ eghuo ni e migha epfẹ aghọ e rọ suọ khi ọ ngme na, e kẹ, “Ri esọ shi ekẹ khi ọ lui Elaja.”
\p 
\v 36 Ọmọse ọghuo elemhi eni ẹgbọ ọ na ya rue isoso sọ li onyọ ni okhẹ a, ọ gẹ ọli shi ukpokpo rọli kpẹ iJesu unu ọ rọ da. Ọni ọmọse ọ kẹ. “A zẹ ọli obọ, ni awa mẹ ini Elaja ọ ya bhale ya rue ọli ukhomhi ọara apfida tiemhie.”\f + \fr 15:36 \ft Li zẹ \fq Iwolo 69.21\f*
\p 
\v 37 IJesu ọ tsẹsẹ leghe, ọ ghua.
\p 
\v 38 Ukpokpomhi ode ugbakpi ni a rọ pfa odẹ-a shi elemhi Owa Oyi Ẹshinẹgba, o rọte idane kiẹsẹ-a asha eva ya to ekẹ.\f + \fr 15:38 \ft Li zẹ \fq Okiali 26.31-33\f*
\v 39 Abi ọkhọli-okhuẹ ọniẹmhi ni ọ migha odalo oni ọara apfida ọ rọ suọ abi iJesu ọ́ tsẹsẹ leghe, ni ọ rọ mẹ abi ọ li ghua, ọ́ọ́, “Egbegbọ lọ khi, Omi Ẹshinẹgba ọmọse ọna ọ khi.”
\p 
\v 40 Ikpotso eghuo e ta pfia bino, iMeli ọnge iMagidaleni, ali iMeli inyi iJemhisi ọni ọ kpọkẹ, ni ọ gbo khi inyi iJosisi ali iSalomẹ.
\v 41 Ikpotso ena e mema deba iJesu ni e ri ukpẹloe khu ọli obini iGalili. Ikpotso elese ni e deba iJesu bhale iJerusalẹmu e li ga migha aghọ.\f + \fr 15:41 \ft Li zẹ \fq iLuk 8.2-3\f*
\s1 Irọtọ oyi iJesu
\r (iMat 27.57-61; iLuk 23.50-56; iJọn 19.38-42)
\p 
\v 42 Ogbọmhi o she mu ekẹ ẹlẹghọ ni o khi ẹlẹ ni a rọ mu egbe khẹ ẹlẹ iyẹmhẹa ọyi ẹgbọ iJu.
\v 43 IJosẹfu ọnge Arimatia, ni ọ khi ọghuo eni ẹ mhẹsẹ, ni ọ khi ọgbọ ni ọ li mu ẹloe. Eri ọ bie kpẹ ri ẹloe shi ekẹ khẹ Eghiele oyi Ẹshinẹgba. Ọ gbe udu lẹ ya gueyẹ iPaleti o rue olimhi oyi iJesu na luẹ ya tọ.
\v 44 O ga sha iPaleti abọ khi iJesu ọ she gbhẹ ghọ kẹlẹ ghua. Ọ lui ọni ọkhọli-okhuẹ ọniẹmhi ọghọ mhila ini iJesu ọ she gbhẹ ghua.
\v 45 Abi iPaleti ọ rọ rọte unu oyi ọni ọkhọli-okhuẹ ọniẹmhi ọghọ suọ khi ighọ o khi egbegbọ, ọ tsua olimhi ọyi iJesu na iJosẹfu.
\v 46 Ighọ iJosẹfu ọ dẹ ide, ọ rue ọni olimhi tiemhile ọara, ọ khuli ọli, ọ ri ọli tọ uji ni a tọ shi echẹ. Ọ gheghele ẹchẹ oniẹmhi guese oni uji.
\v 47 IMeli ọnge iMagidaleni, ali iMeli inyọ iJosisi e mẹ ashini a ri ọli tọ.
\c 16
\s1 Irọte eghuli guale oyi iJesu
\r (iMat 28.1-8; iLuk 24.1-12; iJọn 20.1-10)
\p 
\v 1 Abi ẹlẹ iyẹmhẹa o rọ dọsẹ se, iMeli ọnge iMagidaleni, ali iSalomẹ, ali iMeli inyi iJemhisi, e dẹ afu ituale ni ẹẹ pfie mhuẹ obọ ni wẹwẹ e ya khakha li shi idiegbe olimhi oyi iJesu.
\v 2 Ogbiẹ-fiefie ni o khi uka, khi ovọ o lẹsẹ ngale, e je atalimhi ni a rọli tọ.
\v 3 Ighọ e mhila egbe wẹ́, “Ọghuo ọ ya gheghele ẹchẹ unu oni atalimhi-a na awa?”
\p 
\v 4 Ama abi e ke rọ yasẹ alo ekẹ bino, e mẹ khi a she gheghele oni ẹchẹ ni o ghọ gbẹdi unu oni atalimhi-a a.
\v 5 Abi e rọ lo oni uji, e mẹ ọzẹo ni ọ sọ itsua epfopfo na dogo, khi ọ shitọ epfẹ obita. O sha wẹ abọ.
\p 
\v 6 Ọ́ọ́ wẹ, “Abọ e khi sha ẹ.” “IJesu ọnge iNazarẹti ọni a ta ma ọara apfida a nono? Ọ she te eghuli guale. Ọa la akana. Ghe ashini a rọli tọ.
\v 7 Ama a ke vu, a ka gueyẹ eniyẹ odukhokho eyọli ali iPita khi, ‘Ọ she ralo iGalili ẹ khẹ ẹ. A ya bhale ya ẹ ọli shi aghọ abi ọ kie kpẹ gueyẹ ẹ.’ ”\f + \fr 16:7 \ft Li zẹ \fq iMat 26.32; iMak 14.28\f*
\p 
\v 8 Eni ikpotso e lasele, e na ya je apfẹ. Abọ e sha wẹ, ulishi oo mu wẹ, ẹa nu ọgbọkhọghuo ngme irari khi ulishi ó mu wẹ.
\p [Ebe eni ododẹ eghuo eni a rọte kẹkẹ oni Usomhi Onete ona, ẹa mhọli ọdada 9-20 oyi ukhomhi 16 ona.]
\s1 IJesu ọ ri egbọli khasẹ iMeli ọngi iMagidaleni
\r (iMat 28.9-10; iJọn 20.11-18)
\p 
\v 9 Abi iJesu ọ rọ rọte eghuli guale ẹlẹ uka se, ọ ri egbe ọli kpẹ khasẹ iMeli ọnge iMagidaleni, ọni iJesu ọ khu ayẹmhẹ ebe ishilua rọte egbe ya fiẹ.
\v 10 Ọ vu ya gueyẹ apfẹ iJesu ni ee viẹ.
\v 11 Abi e rọ suọ khi iJesu ọ she guale khi ọ la agbọ ali khi iMeli ọngi IMagidaleni ọ mẹ ọli, ẹa mie shi ọli ọ.
\s1 IJesu ọ ri egbọli khasẹ eniyẹ odukhokho aava
\r (iLuk 24.13-35)
\p 
\v 12 Abi a rọ mẹ ona se, iJesu ọ rọte odẹ ọdọda ri egbọli khasẹ ẹwẹ aava abi e li lo elemhi oni ẹoli.
\v 13 E nyenẹ egbe jele, e gbo gueyẹ eniyẹ odukhokho ni e kpọle, ama, ẹa gbo li mie shi wẹ ọ.
\s1 IJesu ọ ri egbọli khasẹ eni eniyẹ odukhokho ogbaghuo
\r (iMat 28.16-20; iLuk 24.36-49; iJọn 20.19-23; Ika 1.6-8)
\p 
\v 14 Ikpukhokho, iJesu ọ ri egbọli khasẹ eni eniyẹ odukhokho ogbaghuo abi e rọ le eminale. Ọ dese wẹ shi umha-mhọli irudunga oyẹwẹ, ali umha-nono ni e mie shi emini eni e mẹ luẹ e ngme abi ọ rọ guale se.
\p 
\v 15 Ọọ wẹ, “A lo elemhi ekẹ agbọ nya, a ke gue usomhi onete oyẹmhẹ yẹ ọgbọkpa.\f + \fr 16:15 \ft Li zẹ \fq Ika 1.8\f*
\v 16 Ọnini ọ da mie ẹ suọ, ni a da batazi ne, ọ ya mhọli imiepfuese, ama ọni ọa da miesuọ, a she pfa ẹzọ mu ọli.
\v 17 Ọlẹlẹ ona o ya ke deba eni e miesuọ, e ya ri eva oyẹmhẹ khu ayẹmhẹ ebe kua, e ya ngme ẹmuẹ onogbọ unu.
\v 18 E ya ri abọ eyẹwẹ mu enyẹ ekẹ, ini e riẹ rue ikhumhi ni ọọ gbe ọgbọ da, ọa ya li wẹ abikhọghuo. E kha ri abọ nga eni ẹ ghua egbe, e ya toto.”
\s1 A rue iJesu nga obini iloghie
\r (iLuk 24.50-53; Ika 1.9-11)
\p 
\v 19 Abi iJesu Ọnọmhuẹ ọ rọ nu wẹ ngme se, a rue ọli nga idane iloghie. Ọ shitọ ukiẹkiẹ obita oyi Ẹshinẹgba.\f + \fr 16:19 \ft Li zẹ \fq Ika 1.9-11\f*
\v 20 Ighọ eniyẹ odukhokho eyi iJesu e li fiẹ ya tse abọ oni usomhi onete gasẹ asha kpa. Ighọ Ọnọmhuẹ ọ rẹ wẹ gbe ikanya, ọ ri ikanya ọnyaloa ni e gbe ri ungmemhi oyọli tsẹ.
