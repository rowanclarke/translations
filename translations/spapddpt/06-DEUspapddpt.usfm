\p 
\v 14 \w Ciertamente|strong="H2005"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* pertenecen \w el|strong="H3605"\w* \w cielo|strong="H8064"\w* y \w los|strong="H3605"\w* más altos \w cielos|strong="H8064"\w*, y \w la|strong="H3605"\w* tierra y \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* hay en \w ella|strong="H3605"\w*.
\v 15 Pero \nd \w Yavé|strong="H3068"\w*\nd* \w solo|strong="H7535"\w* \w se|strong="H5971"\w* agradó \w de|strong="H5971"\w* tus antepasados \w para|strong="H7535"\w* amarlos, y escogió \w de|strong="H5971"\w* entre \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w* \w a|strong="H3068"\w* su \w descendencia|strong="H2233"\w*, \w a|strong="H3068"\w* ustedes, como ven \w hoy|strong="H3117"\w*.
\v 16 Circunciden, \w pues|strong="H5750"\w*, el \w prepucio|strong="H6190"\w* \w de|strong="H5750"\w* su \w corazón|strong="H3824"\w* y \w no|strong="H3808"\w* sean indómitos.
\p 
\v 17 \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w su|strong="H1931"\w* \nd ʼElohim\nd* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \nd ʼElohim\nd* \w de|strong="H3588"\w* \tl ʼelohim\tl*\f + \fr 10:17 \ft \nd ʼElohim\nd* es un nombre plural.\f* \w y|strong="H3588"\w* \nd ʼAdón\nd* \w de|strong="H3588"\w* \tl ʼadón\tl*, \nd \w ʼEL|strong="H1931"\w*\nd* \w grande|strong="H1419"\w*, \w poderoso|strong="H1368"\w* \w y|strong="H3588"\w* temible, \w Quien|strong="H1931"\w* \w no|strong="H3808"\w* muestra parcialidad \w ni|strong="H3808"\w* admite \w soborno|strong="H7810"\w*,
\v 18 \w que|strong="H1616"\w* \w hace|strong="H6213"\w* \w justicia|strong="H4941"\w* al \w huérfano|strong="H3490"\w* y \w a|strong="H3068"\w* la viuda, y ama al \w extranjero|strong="H1616"\w* y le \w da|strong="H5414"\w* \w pan|strong="H3899"\w* y \w ropa|strong="H8071"\w*.
\v 19 \w Por|strong="H3588"\w* tanto, amarán al \w extranjero|strong="H1616"\w*, \w porque|strong="H3588"\w* ustedes \w fueron|strong="H1961"\w* \w extranjeros|strong="H1616"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.
\p 
\v 20 \w Temerás|strong="H3372"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*. \w A|strong="H3068"\w* Él \w servirás|strong="H5647"\w*, \w a|strong="H3068"\w* Él te aferrarás y por su \w Nombre|strong="H8034"\w* \w jurarás|strong="H7650"\w*.
\v 21 \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w tu|strong="H6213"\w* \w alabanza|strong="H8416"\w*. \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w tu|strong="H6213"\w* \nd ʼElohim\nd*, \w Quien|strong="H6213"\w* \w hizo|strong="H6213"\w* para ti \w estas|strong="H6213"\w* cosas \w grandes|strong="H1419"\w* y portentosas \w que|strong="H1931"\w* \w vieron|strong="H7200"\w* tus \w ojos|strong="H5869"\w*.
\v 22 Con 70 \w personas|strong="H5315"\w* \w descendieron|strong="H3381"\w* tus antepasados \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*, y \w ahora|strong="H6258"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H5315"\w* hizo tan \w numeroso|strong="H7230"\w* como las \w estrellas|strong="H3556"\w* del \w cielo|strong="H8064"\w*.
\c 11
\s1 Beneficios de amar a Yavé
\p 
\v 1 Amarás \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* y \w guardarás|strong="H8104"\w* \w siempre|strong="H3605"\w* sus Preceptos, \w Estatutos|strong="H2708"\w*, \w Ordenanzas|strong="H4941"\w* y \w Mandamientos|strong="H4687"\w*.
\v 2 Consideren \w hoy|strong="H3117"\w* (\w no|strong="H3808"\w* \add hablo\add* \w con|strong="H3588"\w* sus \w hijos|strong="H1121"\w*, quienes \w no|strong="H3808"\w* \w conocieron|strong="H3045"\w* \w ni|strong="H3808"\w* \w vieron|strong="H7200"\w*) \w la|strong="H3588"\w* disciplina \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w su|strong="H3588"\w* \nd ʼElohim\nd*: \w su|strong="H3588"\w* \w grandeza|strong="H1433"\w*, \w su|strong="H3588"\w* \w mano|strong="H3027"\w* \w fuerte|strong="H2389"\w* \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w brazo|strong="H2220"\w* \w extendido|strong="H5186"\w*,
\v 3 sus señales y sus hazañas \w que|strong="H3605"\w* \w hizo|strong="H6213"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w Egipto|strong="H4714"\w* con respecto \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*, \w rey|strong="H4428"\w* de \w Egipto|strong="H4714"\w*, y \w a|strong="H3068"\w* \w toda|strong="H3605"\w* su tierra;
\v 4 \w lo|strong="H2088"\w* \w que|strong="H5921"\w* \w hizo|strong="H6213"\w* \w al|strong="H5921"\w* \w ejército|strong="H2428"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w a|strong="H3068"\w* sus \w caballos|strong="H5483"\w* \w y|strong="H5921"\w* carruajes, \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* cuales precipitó \w las|strong="H5921"\w* \w aguas|strong="H4325"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w* Rojo \w mientras|strong="H5704"\w* \w ellos|strong="H5921"\w* \w los|strong="H5921"\w* perseguían, \w y|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w los|strong="H5921"\w* destruyó \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*;
\v 5 \w lo|strong="H2088"\w* \w que|strong="H5704"\w* \w hizo|strong="H6213"\w* \w con|strong="H5704"\w* ustedes \w en|strong="H5704"\w* \w el|strong="H6213"\w* \w desierto|strong="H4057"\w*, \w hasta|strong="H5704"\w* \w cuando|strong="H5704"\w* llegaron \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*;
\v 6 y \w lo|strong="H6213"\w* \w que|strong="H1121"\w* \w hizo|strong="H6213"\w* con Datán y Abiram, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Eliab, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w*, \w cómo|strong="H7272"\w*, en \w medio|strong="H7130"\w* \w de|strong="H1121"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w la|strong="H3605"\w* tierra \w abrió|strong="H6475"\w* su \w boca|strong="H6310"\w* y \w los|strong="H1121"\w* tragó \w a|strong="H3068"\w* \w ellos|strong="H3605"\w*, sus \w familias|strong="H1004"\w*, sus tiendas y \w todo|strong="H3605"\w* su \w ganado|strong="H1121"\w*,
\v 7 \w pero|strong="H3588"\w* sus \w ojos|strong="H5869"\w* \w vieron|strong="H7200"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w gran|strong="H1419"\w* \w obra|strong="H4639"\w* \w que|strong="H3588"\w* \w hizo|strong="H6213"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 8 \w Por|strong="H4616"\w* tanto, \w guarden|strong="H8104"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w Mandamientos|strong="H4687"\w* \w que|strong="H3117"\w* \w yo|strong="H6680"\w* \w les|strong="H6680"\w* \w ordeno|strong="H6680"\w* \w hoy|strong="H3117"\w* \w para|strong="H4616"\w* \w que|strong="H3117"\w* sean fuertes, y entren y ocupen \w la|strong="H8104"\w* tierra \w a|strong="H3068"\w* \w la|strong="H8104"\w* cual \w pasan|strong="H5674"\w* \w para|strong="H4616"\w* poseerla,
\v 9 \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* \w que|strong="H5921"\w* prolonguen sus \w días|strong="H3117"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w juró|strong="H7650"\w* \w a|strong="H3068"\w* sus antepasados \w que|strong="H5921"\w* \w les|strong="H5921"\w* \w daría|strong="H5414"\w* \w a|strong="H3068"\w* \w ellos|strong="H5921"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* su \w descendencia|strong="H2233"\w*, tierra \w que|strong="H5921"\w* \w fluye|strong="H2100"\w* \w leche|strong="H2461"\w* \w y|strong="H5921"\w* \w miel|strong="H1706"\w*.
\v 10 \w La|strong="H1931"\w* tierra \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w cual|strong="H1931"\w* entras \w para|strong="H3588"\w* tomarla \w no|strong="H3808"\w* \w es|strong="H1931"\w* \w como|strong="H3588"\w* \w la|strong="H1931"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w* \w de|strong="H3588"\w* \w donde|strong="H8033"\w* \w salieron|strong="H3318"\w*, \w donde|strong="H8033"\w* \w sembrabas|strong="H2233"\w* tu semilla \w y|strong="H3588"\w* regabas \w con|strong="H3588"\w* tu \w pie|strong="H7272"\w*, \w como|strong="H3588"\w* un \w huerto|strong="H1588"\w* \w de|strong="H3588"\w* hortaliza.
\v 11 Pero la tierra \w a|strong="H3068"\w* la cual están \w a|strong="H3068"\w* punto \w de|strong="H4325"\w* pasar para poseerla es una tierra \w de|strong="H4325"\w* montañas y valles, \w que|strong="H4325"\w* \w bebe|strong="H8354"\w* el \w agua|strong="H4325"\w* \w de|strong="H4325"\w* la \w lluvia|strong="H4306"\w* \w del|strong="H8354"\w* \w cielo|strong="H8064"\w*.
\v 12 Es una tierra \w que|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w cuida|strong="H1875"\w*. Los \w ojos|strong="H5869"\w* \w de|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* están \w siempre|strong="H8548"\w* sobre ella \w desde|strong="H5704"\w* el \w principio|strong="H7225"\w* \w hasta|strong="H5704"\w* el fin del \w año|strong="H8141"\w*.
\p 
\v 13 \w Sucederá|strong="H1961"\w* \w que|strong="H3117"\w*, \w si|strong="H1961"\w* \w obedecen|strong="H8085"\w* sinceramente mis \w Mandamientos|strong="H4687"\w* \w que|strong="H3117"\w* \w les|strong="H6680"\w* \w ordeno|strong="H6680"\w* \w hoy|strong="H3117"\w*, aman \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*, y le \w sirven|strong="H5647"\w* con \w todo|strong="H3605"\w* su \w corazón|strong="H3824"\w* y con \w toda|strong="H3605"\w* su \w alma|strong="H5315"\w*,
\v 14 Él también \w dará|strong="H5414"\w* la \w lluvia|strong="H4306"\w* \w a|strong="H3068"\w* su tierra en su \w tiempo|strong="H6256"\w*, la temprana y la \w tardía|strong="H4456"\w*, y recogerás tu \w grano|strong="H1715"\w*, tu \w mosto|strong="H8492"\w* y tu \w aceite|strong="H3323"\w*.
\v 15 \w Dará|strong="H5414"\w* también \w hierba|strong="H6212"\w* en tu \w campo|strong="H7704"\w* \w para|strong="H5414"\w* tu ganado. Comerás y quedarás satisfecho.
\p 
\v 16 Guárdense \w para|strong="H5493"\w* \w que|strong="H6435"\w* sus \w corazones|strong="H3824"\w* \w no|strong="H6435"\w* sean engañados, y \w que|strong="H6435"\w* ustedes \w no|strong="H6435"\w* \w se|strong="H6435"\w* aparten, sirvan \w a|strong="H3068"\w* otros \tl ʼelohim\tl* y los adoren,
\v 17 \w porque|strong="H5921"\w* entonces \w la|strong="H5921"\w* ira \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w se|strong="H1961"\w* encenderá \w contra|strong="H5921"\w* ustedes. Cerrará \w el|strong="H5921"\w* \w cielo|strong="H8064"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w habrá|strong="H1961"\w* \w lluvia|strong="H4306"\w*. \w La|strong="H5921"\w* tierra \w no|strong="H3808"\w* \w dará|strong="H5414"\w* su fruto, \w y|strong="H5921"\w* \w pronto|strong="H4120"\w* perecerán \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w buena|strong="H2896"\w* tierra \w que|strong="H3808"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w les|strong="H5921"\w* \w da|strong="H5414"\w*.
\v 18 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w pondrán|strong="H7760"\w* estas \w palabras|strong="H1697"\w* mías \w en|strong="H5921"\w* su \w corazón|strong="H3824"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* su \w alma|strong="H5315"\w*. \w Las|strong="H5921"\w* atarán \w como|strong="H1961"\w* señal \w en|strong="H5921"\w* su \w mano|strong="H3027"\w*, \w y|strong="H5921"\w* \w serán|strong="H1961"\w* \w como|strong="H1961"\w* frontales \w entre|strong="H5921"\w* sus \w ojos|strong="H5869"\w*.
\v 19 Las \w enseñarán|strong="H3925"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*, \w hablarán|strong="H1696"\w* \w de|strong="H1121"\w* ellas cuando se sienten \w en|strong="H3212"\w* su \w casa|strong="H1004"\w*, cuando \w anden|strong="H3212"\w* \w por|strong="H1870"\w* \w el|strong="H1121"\w* \w camino|strong="H1870"\w*, cuando se acuesten y cuando se levanten.
\v 20 \w Las|strong="H5921"\w* escribirán \w en|strong="H5921"\w* \w las|strong="H5921"\w* jambas \w de|strong="H5921"\w* tu \w casa|strong="H1004"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* sus \w puertas|strong="H8179"\w*,
\v 21 \w para|strong="H4616"\w* \w que|strong="H5921"\w* sus \w días|strong="H3117"\w* \w y|strong="H5921"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* sus \w hijos|strong="H1121"\w* \w se|strong="H5921"\w* multipliquen \w como|strong="H5921"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w cielos|strong="H8064"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w juró|strong="H7650"\w* \w a|strong="H3068"\w* sus antepasados \w que|strong="H5921"\w* \w les|strong="H5921"\w* \w daría|strong="H5414"\w*.
\p 
\v 22 \w Porque|strong="H3588"\w* \w si|strong="H3588"\w* \w guardan|strong="H6213"\w* diligentemente \w todos|strong="H3605"\w* \w estos|strong="H2063"\w* \w Mandamientos|strong="H4687"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w les|strong="H6680"\w* \w ordeno|strong="H6680"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w los|strong="H3605"\w* cumplan, \w si|strong="H3588"\w* aman \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w su|strong="H3588"\w* \nd ʼElohim,\nd* andan \w en|strong="H3588"\w* \w todos|strong="H3605"\w* sus \w caminos|strong="H1870"\w* \w y|strong="H3588"\w* se aferran \w a|strong="H3068"\w* \w Él|strong="H3588"\w*,
\v 23 \nd \w Yavé|strong="H3068"\w*\nd* expulsará \w a|strong="H3068"\w* \w todas|strong="H3605"\w* estas \w naciones|strong="H1471"\w* \w de|strong="H4480"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* ustedes, y desposeerán \w a|strong="H3068"\w* \w naciones|strong="H1471"\w* \w más|strong="H4480"\w* \w grandes|strong="H1419"\w* y \w más|strong="H4480"\w* \w fuertes|strong="H6099"\w* \w que|strong="H4480"\w* ustedes.
\v 24 \w Todo|strong="H3605"\w* \w lugar|strong="H4725"\w* \w que|strong="H4480"\w* pise \w la|strong="H3605"\w* planta \w de|strong="H4480"\w* su \w pie|strong="H7272"\w* \w será|strong="H1961"\w* suyo \w desde|strong="H4480"\w* \w el|strong="H3605"\w* \w desierto|strong="H4057"\w* \w y|strong="H5704"\w* \w el|strong="H3605"\w* \w Líbano|strong="H3844"\w*, \w y|strong="H5704"\w* \w desde|strong="H4480"\w* \w el|strong="H3605"\w* \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w mar|strong="H3220"\w* \w Occidental|strong="H3220"\w*.
\v 25 \w Nadie|strong="H3808"\w* prevalecerá \w delante|strong="H6440"\w* \w de|strong="H5921"\w* ustedes. \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd* \w pondrá|strong="H5414"\w* \w el|strong="H5921"\w* \w temor|strong="H6343"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* pavor \w delante|strong="H6440"\w* \w de|strong="H5921"\w* ustedes \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w que|strong="H3808"\w* pisen, \w como|strong="H5921"\w* \w Él|strong="H5921"\w* \w les|strong="H5921"\w* \w habló|strong="H1696"\w*.
\p 
\v 26 Miren, \w hoy|strong="H3117"\w* \w pongo|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ustedes la \w bendición|strong="H1293"\w* y la \w maldición|strong="H7045"\w*:
\v 27 La \w bendición|strong="H1293"\w*, si \w escuchan|strong="H8085"\w* los \w Mandamientos|strong="H4687"\w* de \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd* \w que|strong="H3117"\w* \w yo|strong="H6680"\w* \w les|strong="H6680"\w* \w ordeno|strong="H6680"\w* \w hoy|strong="H3117"\w*,
\v 28 y la \w maldición|strong="H7045"\w*, \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w escuchan|strong="H8085"\w* los \w Mandamientos|strong="H4687"\w* \w de|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*, \w sino|strong="H3808"\w* \w se|strong="H3045"\w* apartan \w del|strong="H4480"\w* \w camino|strong="H1870"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w* \w les|strong="H6680"\w* \w ordeno|strong="H6680"\w* \w hoy|strong="H3117"\w* \w para|strong="H4480"\w* seguir \w a|strong="H3068"\w* otros \tl ʼelohim\tl* \w que|strong="H4480"\w* \w no|strong="H3808"\w* \w conocieron|strong="H3045"\w*.
\p 
\v 29 \w Acontecerá|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H5921"\w* introduzca \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w cual|strong="H3588"\w* entras \w para|strong="H5921"\w* poseerla, \w pondrás|strong="H5414"\w* \w la|strong="H5921"\w* \w bendición|strong="H1293"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* montaña \w Gerizim|strong="H1630"\w*, \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w maldición|strong="H7045"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* montaña \w Ebal|strong="H5858"\w*.
\v 30 ¿\w No|strong="H3808"\w* \w están|strong="H3427"\w* \w éstas|strong="H1992"\w* al otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*, al occidente, en la tierra del \w cananeo|strong="H3669"\w* \w que|strong="H3808"\w* \w habita|strong="H3427"\w* en \w el|strong="H3427"\w* Arabá, junto al robledal de \w Moré|strong="H3427"\w* frente \w a|strong="H3068"\w* \w Gilgal|strong="H1537"\w*?
