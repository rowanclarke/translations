\v 43 “\w We|strong="H3588"\w*'ve got ten shares \w in|strong="H5921"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*,”\f + \fr 19:43 \ft Referring to the ten northern tribes.\f* \w the|strong="H3605"\w* \w men|strong="H3605"\w* \w of|strong="H4428"\w* \w Israel|strong="H3478"\w* \w replied|strong="H6030"\w*, “\w so|strong="H4480"\w* \w we|strong="H3068"\w* \w have|strong="H3478"\w* \w a|strong="H3068"\w* greater claim \w on|strong="H5921"\w* David \w than|strong="H4480"\w* \w you|strong="H3588"\w* \w do|strong="H4100"\w*. \w Why|strong="H4100"\w* \w do|strong="H4100"\w* \w you|strong="H3588"\w* \w look|strong="H5375"\w* \w down|strong="H5921"\w* \w on|strong="H5921"\w* \w us|strong="H5921"\w*? Weren't \w we|strong="H3068"\w* \w the|strong="H3605"\w* \w first|strong="H2088"\w* \w ones|strong="H7138"\w* \w to|strong="H3478"\w* \w talk|strong="H1697"\w* \w about|strong="H5921"\w* \w bringing|strong="H5375"\w* back \w our|strong="H3605"\w* \w king|strong="H4428"\w*?” \w But|strong="H3588"\w* \w the|strong="H3605"\w* \w men|strong="H3605"\w* \w of|strong="H4428"\w* \w Judah|strong="H3063"\w* argued \w even|strong="H3588"\w* \w more|strong="H4480"\w* strongly \w than|strong="H4480"\w* \w the|strong="H3605"\w* \w men|strong="H3605"\w* \w of|strong="H4428"\w* \w Israel|strong="H3478"\w*.
\b
\c 20
\p 
\v 1 \w A|strong="H3068"\w* rabble-rouser \w called|strong="H8034"\w* \w Sheba|strong="H7652"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Bichri|strong="H1075"\w*, \w from|strong="H3478"\w* \w the|strong="H8628"\w* tribe \w of|strong="H1121"\w* Benjamin, \w happened|strong="H7122"\w* \w to|strong="H3478"\w* \w be|strong="H3808"\w* \w there|strong="H8033"\w*. \w He|strong="H8033"\w* \w blew|strong="H8628"\w* \w the|strong="H8628"\w* ram's \w horn|strong="H7782"\w* \w and|strong="H1121"\w* shouted: “\w We|strong="H8033"\w* \w have|strong="H1121"\w* \w no|strong="H3808"\w* interest \w in|strong="H3478"\w* \w David|strong="H1732"\w*, \w no|strong="H3808"\w* commitment \w to|strong="H3478"\w* \w Jesse|strong="H3448"\w*'s \w son|strong="H1121"\w*. \w Israelites|strong="H3478"\w*, \w let|strong="H3808"\w*'s all \w go|strong="H3478"\w* \w home|strong="H8034"\w*!”
\p 
\v 2 \w So|strong="H4480"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w men|strong="H1121"\w* \w of|strong="H1121"\w* \w Israel|strong="H3478"\w* abandoned \w David|strong="H1732"\w* \w to|strong="H5704"\w* \w follow|strong="H1692"\w* \w Sheba|strong="H7652"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Bichri|strong="H1075"\w*. \w But|strong="H3605"\w* \w the|strong="H3605"\w* \w men|strong="H1121"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w* accompanied \w their|strong="H3605"\w* \w king|strong="H4428"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w way|strong="H5704"\w* \w from|strong="H4480"\w* \w the|strong="H3605"\w* \w Jordan|strong="H3383"\w* \w to|strong="H5704"\w* \w Jerusalem|strong="H3389"\w*.
\v 3 \w When|strong="H1961"\w* \w David|strong="H1732"\w* returned \w to|strong="H5704"\w* \w his|strong="H5414"\w* \w palace|strong="H1004"\w* \w in|strong="H1004"\w* \w Jerusalem|strong="H3389"\w*, \w he|strong="H3117"\w* \w took|strong="H3947"\w* \w the|strong="H5414"\w* \w ten|strong="H6235"\w* \w concubines|strong="H6370"\w* \w he|strong="H3117"\w* \w had|strong="H1961"\w* \w left|strong="H3240"\w* \w to|strong="H5704"\w* look \w after|strong="H1961"\w* \w the|strong="H5414"\w* \w palace|strong="H1004"\w*\f + \fr 20:3 \ft See \xt 15:16\xt*\ft .\f* \w and|strong="H4428"\w* \w put|strong="H5414"\w* \w them|strong="H5414"\w* \w in|strong="H1004"\w* \w a|strong="H3068"\w* \w house|strong="H1004"\w* \w under|strong="H5414"\w* \w guard|strong="H8104"\w*. \w He|strong="H3117"\w* \w took|strong="H3947"\w* \w care|strong="H4931"\w* \w of|strong="H4428"\w* \w their|strong="H5414"\w* \w needs|strong="H1961"\w* \w but|strong="H3808"\w* \w he|strong="H3117"\w* didn't sleep \w with|strong="H1004"\w* \w them|strong="H5414"\w*. \w They|strong="H3117"\w* \w were|strong="H1961"\w* imprisoned \w until|strong="H5704"\w* \w they|strong="H3117"\w* \w died|strong="H4194"\w*, \w living|strong="H2424"\w* \w like|strong="H1961"\w* widows.
\p 
\v 4 \w Then|strong="H4428"\w* \w the|strong="H3117"\w* \w king|strong="H4428"\w* \w ordered|strong="H2199"\w* \w Amasa|strong="H6021"\w*, “\w Call|strong="H2199"\w* \w up|strong="H5975"\w* \w the|strong="H3117"\w* army \w of|strong="H4428"\w* \w Judah|strong="H3063"\w*. \w Have|strong="H3063"\w* \w them|strong="H5975"\w* \w come|strong="H3063"\w* \w to|strong="H3117"\w* \w me|strong="H5975"\w* \w within|strong="H3063"\w* \w three|strong="H7969"\w* \w days|strong="H3117"\w*, \w and|strong="H3063"\w* \w you|strong="H3117"\w* \w come|strong="H3063"\w* too.”
