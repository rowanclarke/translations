\v 9 \w Entonces|strong="H6256"\w*, \w a|strong="H3068"\w* \w los|strong="H3605"\w* 23 días del \w mes|strong="H2320"\w* \w tercero|strong="H7992"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* Siván, \w los|strong="H3605"\w* secretarios del \w rey|strong="H4428"\w* fueron \w llamados|strong="H7121"\w*. \w Todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* Mardoqueo \w mandó|strong="H6680"\w* \w en|strong="H5704"\w* relación \w con|strong="H5704"\w* \w los|strong="H3605"\w* \w judíos|strong="H3064"\w* \w se|strong="H1931"\w* \w les|strong="H6680"\w* \w escribió|strong="H3789"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \tl sátrapas\tl*, \w los|strong="H3605"\w* \w gobernadores|strong="H6346"\w* \w y|strong="H5704"\w* \w jefes|strong="H8269"\w* \w de|strong="H5704"\w* las 127 \w provincias|strong="H4082"\w* \w que|strong="H1931"\w* están \w desde|strong="H5704"\w* India \w hasta|strong="H5704"\w* \w Etiopía|strong="H3568"\w*, \w cada|strong="H3605"\w* \w provincia|strong="H4082"\w* según \w su|strong="H1931"\w* \w escritura|strong="H3789"\w* \w y|strong="H5704"\w* \w cada|strong="H3605"\w* \w pueblo|strong="H5971"\w* según \w su|strong="H1931"\w* \w lengua|strong="H3956"\w*. También \w se|strong="H1931"\w* \w escribió|strong="H3789"\w* \w esto|strong="H1931"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w judíos|strong="H3064"\w* según \w su|strong="H1931"\w* \w escritura|strong="H3789"\w* \w y|strong="H5704"\w* \w su|strong="H1931"\w* \w lengua|strong="H3956"\w*.
\p 
\v 10 \w Y|strong="H3068"\w* \w él|strong="H1121"\w* \w escribió|strong="H3789"\w* \w cartas|strong="H5612"\w* en \w nombre|strong="H8034"\w* del \w rey|strong="H4428"\w* Asuero y las selló con \w el|strong="H1121"\w* sello del \w rey|strong="H4428"\w*. Las \w envió|strong="H7971"\w* \w por|strong="H3027"\w* \w medio|strong="H3027"\w* \w de|strong="H1121"\w* mensajeros \w a|strong="H3068"\w* \w caballo|strong="H5483"\w* en veloces corceles, mulas y \w dromedarios|strong="H7409"\w* jóvenes \w de|strong="H1121"\w* las caballerías \w reales|strong="H4428"\w*.
