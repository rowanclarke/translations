\id MAT
\h SAN MATEO
\toc1 Jág₁ Dse₃ quió'₅ Diú₄ a₂ca₂tó'₂ San Mateo ne₄ Si₂
\toc2 SAN MATEO
\toc3 Mt.
\mt1 Jág₁ Dse₃ quió'₅ Diú₄ a₂ca₂tó'₂ San Mateo ne₄ Si₂
\c 1
\s1 Dsa₂ can'₅₄ quián₅ Jesucristo i₂jme₁chan₂ ma₂lɨ́g'₂
\r (Lucas 3:23-38)
\p 
\v 1 A₂la₂ bá₄ caun₂ lista ja₁le₁ton₅ dsa₂ can'₅₄ quián₅ Jesucristo i₂jme₁lɨ́n₄ tsɨ₁jon₂ quián₅ David\f + \fr 1:1 \ft Rag₅₄ David i₂ca₂rë₃chán₃ con'₂ co₂mei₅ ŋi₂ né'₃ a₂ca₂rë₃chán₃ Jesús.\f* quian'₅₄ Abraham.
\p 
\v 2 Abraham ca₂lɨn₃ jmei₂ Isaac,
\q1 Isaac guë'₂ ca₂lɨn₃ jmei₂ Jacob;
\q1 Jacob guë'₂ ca₂lɨn₃ jmei₂ Judá quian'₅₄ rɨin'₅₄.
\q1 
\v 3 Judá guë'₂ në́₃ ca₂lɨn₃ jmei₂ Fares quian'₅₄ Zara
\q2 të₂le₃ quian'₅₄ Tamar.
\q1 Fares guë'₂ ca₂lɨn₃ jmei₂ Esrom;
\q1 Esrom guë'₂ ca₂lɨn₃ jmei₂ Aram.
\q1 
\v 4 Aram guë'₂ ca₂lɨn₃ jmei₂ Aminadab;
\q1 Aminadab guë'₂ ca₂lɨn₃ jmei₂ Na'asón;
\q1 Na'asón guë'₂ ca₂lɨn₃ jmei₂ Salmón;
\q1 
\v 5 Salmón guë'₂ ca₂lɨn₃ jmei₂ Bo'oz
\q2 të₂le₃ quian'₅₄ Rahab.
\q1 Bo'oz guë'₂ ca₂lɨn₃ jmei₂ Obed
\q2 të₂le₃ quian'₅₄ Ruth.
\q1 Obed guë'₂ ca₂lɨn₃ jmei₂ Isaí;
\q1 
\v 6 Isaí guë'₂ ca₂lɨn₃ jmei₂ Rag₅₄ David.
\p Rag₅₄ David guë'₂ në́₃ ca₂lɨn₃ jmei₂ Salomón,
\q2 (të₂le₃ quian'₅₄ i₂jme₁lɨ́n₄ dsa₂ mɨ́₂
\q2 quián₅ Urías le₂jŋiá₅).
\q1 
\v 7 Salomón guë'₂ ca₂lɨn₃ jmei₂ Roboam;
\q1 Roboam guë'₂ ca₂lɨn₃ jmei₂ Abías;
\q1 Abías guë'₂ ca₂lɨn₃ jmei₂ Asa;
\q1 
\v 8 Asa guë'₂ ca₂lɨn₃ jmei₂ Josafat;
\q1 Josafat guë'₂ ca₂lɨn₃ jmei₂ Joram;
\q1 Joram guë'₂ ca₂lɨn₃ jmei₂ Usías;
\q1 
\v 9 Usías guë'₂ ca₂lɨn₃ jmei₂ Jotam;
\q1 Jotam guë'₂ ca₂lɨn₃ jmei₂ Acaz;
\q1 Acaz guë'₂ ca₂lɨn₃ jmei₂ Ezequías;
\q1 
\v 10 Ezequías guë'₂ ca₂lɨn₃ jmei₂ Manasés;
\q1 Manasés guë'₂ ca₂lɨn₃ jmei₂ Amón;
\q1 Amón guë'₂ ca₂lɨn₃ jmei₂ Josías;
\q1 
\v 11 Josías guë'₂ ca₂lɨn₃ jmei₂ Jeconías quian'₅₄ rɨin'₅₄,
\q2 (lia'₂ con'₂ jmɨg₄ jme₁ca₂i₃lén₂ dsa₂ israelitas
\q2 a₂ca₂tág₃ dsa₂ juɨ₅ 'uë₃ Babilonia).
\p 
\v 12 Cang₂ jme₁ma₂tág₃ dsa₂ 'uë₃ Babilonia jaun₂,
\q1 ca₂lɨn₃ Jeconías jmei₂ Salatiel;
\q2 i₂ca₂lɨn₃ jmei₂ Zorobabel;
\q1 
\v 13 Zorobabel në́₃ ca₂lɨn₃ jmei₂ Abiud;
\q1 Abiud guë'₂ ca₂lɨn₃ jmei₂ Eliaquim;
\q1 Eliaquim guë'₂ ca₂lɨn₃ jmei₂ Azor;
\q1 
\v 14 Azor në́₃ ca₂lɨn₃ jmei₂ Sadoc;
\q1 Sadoc guë'₂ ca₂lɨn₃ jmei₂ Aquim;
\q1 Aquim guë'₂ ca₂lɨn₃ jmei₂ Eliud;
\q1 
\v 15 Eliud guë'₂ ca₂lɨn₃ jmei₂ Eleazar,
\q2 i₂ca₂lɨn₃ jmei₂ Matán;
\q1 Matán guë'₂ ca₂lɨn₃ jmei₂ Jacob;
\q1 
\v 16 Jacob në́₃ ca₂lɨn₃ jmei₂ José, dsɨ₂i₂gu₂ María;
\q1 María guë'₂ në́₃ ca₂lɨn₃ chog₅₄ Jesús
\q2 i₂të́'₂ dsa₂ Cristo*.\f + \fr 1:16 \ft Co₂rë₂ bá₄ jein₅ jág₁ “Cristo” quian'₅₄ “I₂rë₂'ɨ́n₁ quián₅ Diú₄.” Quian'₅₄ jág₁ jmei₅ hebreo guë'₂ táng₃ juá'₂ dsa₂ Meshíaj: “Mesías” quian'₅₄ jág₁ ŋi'₅₄.\f*
\p 
\v 17 Jaun₂ në́₃, con'₂ guia₃-quén₂ tsɨ₁jon₂ dsa₂ ca₂ŋɨ́₂ ca₂le₃ jme₁chan₂ Abraham ca₂të₂ jmɨg₄ jme₁ca₂rë₃chán₃ David, ján₃ bá₄ le₂jaun₂ guia₃-quén₂ tsɨ₁jon₂ dsa₂ ca₂ŋɨ́₂ ca₂le₃ jme₁chan₂ David, ca₂të₂ jmɨg₄ jme₁ca₂tág₃ dsa₂ dsa₂ israelitas juɨ₅ 'uë₃ Babilonia; cang₂ jaun₂ guë́₄ në́₃, con'₂ guia₃-quén₂ tsɨ₁jon₂ dsa₂ ca₂ŋɨ́₂ ca₂le₃ ca₂tág₃ dsa₂, ca₂të₂ jmɨg₄ jme₁ca₂rë₃chán₃ dsa₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄.\f + \fr 1:17 \ft Co₂rë₂ bá₄ jein₅ jág₁ “Cristo” quian'₅₄ “I₂rë₂'ɨ́n₁ quián₅ Diú₄.” Quian'₅₄ jág₁ jmei₅ hebreo guë'₂ táng₃ juá'₂ dsa₂ Meshíaj: “Mesías” quian'₅₄ jág₁ ŋi'₅₄.\f*
\s1 'A₂ lia'₂ ca₂lë₃ a₂ca₂rë₃chán₃ Jesús
\r (Lucas 2:1-7)
\p 
\v 18 Le₂la₂ bá₄ ca₂lë₃ a₂ca₂rë₃chán₃ Jesús: chog₅₄ jme₁chen₂ María jme₁ma₂lɨ'₅₄ jág₁ a₂jéin'₂ gu₂ quian'₅₄ José; la₁ né'₃ guë́₄ a₂tiain'₃, María në́₃ ca₂can₃ guein₂ të₂le₃ quian'₅₄ juɨ₅bí₂ quió'₅ Jme₂dsí₂ Jŋió₅.
\v 19 José dsa₂ ŋe'₂ quiáin₅ në́₃ jme₁lɨ́in₄ jan₂ dsa₂ dsen₃, jaun₂ tsá₃ jme₁'nio₃ chein'₃ o₂guí'₃ María jua'₅₄ le₃ŋi₅ dsa₂ juɨn₅; jŋia'₅₄ lia'₂ a₂jaun₂ bá₄ jme₁dsɨ₂jiog₅ dsɨ́₅ a₂jme₁téi₂ bá₄ con'₂ tsá₃ 'ein₂ ŋi₅.
\v 20 Le₂jaun₂ bá₄ jme₁ma₂ca₂'náu'₃ dsɨ́₅ jmo₃, jme₁ca₂quɨ₃ a₂ca₂jme₃jnia₅ jan₂ ángel quián₅ Te₁gui'₅₄ ne₅₄ ca₂juá'₂:
\p ―Së́₄, tsɨ₁jon₂ David, tsá₃ lë₁jmo₂ gang'₃ jua'₅₄ cán'₁ o₂guí'₃ a₂guéng'₄ María a₂léin₂ dsɨ₂i₂gog'₂, ia₁ guein₂ i₂le₃chan₂ quiáin₅ já₅ ja₁con₂ Jme₂dsí₂ Jŋió₅.
\v 21 Jaun₂ le₃chan₂ jan₂ guein₂ dsa₂ ŋe'₂ quiáin₅, jaun₂ quiain'₅₄ 'ne₂ JESÚS.\f + \fr 1:21 \ft Lia'₂ chen₂ Jesús (hebreo: Yeshua) jein₅ jág₁: Lió₂ bá₄ Te₁gui'₅₄.\f* Le₃chein₂ le₂në₅ ia₁ a₂lióin₂ dsa₂ juɨg₂ quiáin₅ 'uɨg₅₄ dsáu₁.
\p 
\v 22 Ca₂lë₃ ca₂le₃jë́₃ a₂në₅ ia₁jaun₂ le₃ti₃ juɨ₁lia'₂ ca₂juá'₂ Te₁gui'₅₄ të₂le₃ quian'₅₄ dsa₂ i₂jme₁'ë́₂ jág₁ quiáin₅, jme₁ca₂juá'₂:
\q1 
\v 23 Cán₂ jan₂ dsa₂ mɨ₄ guein₂,
\q2 jaun₂ le₃chan₂ jan₂ guein₂ dsa₂ ŋe'₂ quiáin₅,
\q1 jaun₂ le₃chein₂ Emanuel,\f + \fr 1:23 \ft Isaías 7:14.\f*
\q2 co₂'nió'₄ a₂juá'₂: Quiong'₅₄ Diú₄ jniog₄.
\p 
\v 24 Jaun₂ jme₁ca₂ŋé₃ Së́₄ a₂jme₁rë₂güɨ́in₃ jaun₂, le₂jaun₂ bá₄ ca₂jmo₃ lia'₂ con'₂ lë́₅ ca₂juá'₂ ángel quián₅ Te₁gui'₅₄, jaun₂ ca₂guein₃ bá₄ María a₂lén₂ 'éi₂ dsɨ₂i₂gu₂.
\v 25 La₁ia₁ tsá₃ ca₂tiáin'₂ dsɨ₂juɨ₅ jme₁né₄, jua'₅₄ a₂ca₂rë₃cuɨin₂₃ rɨin'₅₄, ca₂lia'₂ jme₁ca₂rë₃chán₃ guein₂ i₂le₂'uɨg₅₄ 'éi₂ quián₅ bá₄ María; jaun₂ ca₂quiain₃ guein₂ Jesús.
\c 2
\s1 Ca₂o₃lén₂ dsa₂ can'₅₄ i₂dsi₂ jág₁
\p 
\v 1 Ca₂rë₃chán₃ Jesús jë₄ juɨg₂ Belén, ja₁tén₄ 'uë₃ Judea, jmɨg₄ lia'₂ con'₂ jme₁lɨ́n₄ Herodes rag₅₄ 'uë₃ jaun₂. Jaun₂ ca₂o₃lén₂ co₂nió'₃ dsa₂ i₂chan₂ uɨ́ng₂ të₂le₃ ja₁'ia₂\f + \fr 2:1 \ft Co₂'nió'₄ le₃jua'₅₄, caun₂ cosa a₂tsá₃ 'i₄ jme₂dsí₂, a₂ca₂jmo₃ Diú₄. 'Nio'₂ ja₁ton₅ Salmo 8:3; Romanos 1:25.\f* 'iog₂, jaun₂ ca₂dsi₃léin₂ juɨg₂ Jerusalén.
\v 2 Jaun₂ ca₂ŋag₃:
\p ―¿Na₅ Rag₅₄ quián₅ dsa₂ judíos i₂ca₂rë₃chán₃? Ia₁ 'uë₃ të₂le₃ ja₁'ŋia₂ 'iog₂, ma₂në₂jɨn₄ jnia'₅₄ nei₅ quiáin₅, jaun₂ ja₂náu₅ jnia'₅₄ a₂jme₁juɨin'₂.
\p 
\v 3 Jme₁ca₂rë₃ŋi₅ Rag₅₄ Herodes jág₁ në₅, 'ŋio₅ lɨn₃ tsá₃ ma₃tei₄ ca₂'ág₂ dsɨ́₅, ján₃ bá₄ le₂jaun₂ ca₂le₃jɨ́n₃ dsa₂ juɨg₂ Jerusalén.
\v 4 Jaun₂ në́₃ ca₂të́'₃ rag₅₄ ca₂le₃jɨ́n₃ juɨg₅₄ jme₂dsa₂ quian'₅₄ ca₂le₃jɨ́n₃ të₅juá'₅ quián₅ dsa₂, jaun₂ ca₂ŋag₃ a₂já'₄ dsón'₂ lë́₅ jág₁ le₃chan₂ dsa₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄.
\v 5 Jaun₂ ca₂juá'₂ dsa₂ 'éi₂:
\p ―Juɨg₂ Belén, ja₁tén₄ 'uë₃ Judea. Ia₁ le₂la₂ ca₂tó'₂ ne₄ si₂ dsa₂ i₂jme₁'ë́₂ jág₁ o₄quió'₄ Diú₄:
\q1 
\v 6 Jaun₂ 'ne₂, Belén, juɨg₂ tén₅ 'uë₃ Judá,
\q1 on₃jua'₅₄ 'ne₂ lɨ́ng'₅ juɨg₂ i₂me'₂ guë́₄
\q2 të₂le₃ ne₄ juɨ₁lia'₂ dsa₂ i₂qui₂dsɨ₅ 'éi'₃ 'uë₃ në₅;
\q1 ia₁ ja₁con'₂ 'ne₂ bá₄ o₃'ɨn₅ jan₂
\q2 i₂gon₂, cán₂ ne₄ juɨ₅,
\q1 jmo₃ 'í₁ dsa₂ juɨg₂ Israel quiáng₃.\f + \fr 2:6 \ft Miqueas 5:2.\f*
\p 
\v 7 Jaun₂ Herodes në́₃ ca₂të́'₃ dsa₂ can'₅₄ 'éi₂ con'₂ jë₄ të₃co'₅₄, jaun₂ ca₂ŋag₃ lɨ́g'₂ 'e₂ jmɨg₄ të₃dsón'₂ ca₂rë₃jniá₂ nei₅ jaun₂.\f + \fr 2:7 \ft Co₂'nió'₄ le₃jua'₅₄, caun₂ cosa a₂tsá₃ 'i₄ jme₂dsí₂, a₂ca₂jmo₃ Diú₄. 'Nio'₂ ja₁ton₅ Salmo 8:3; Romanos 1:25.\f*
\v 8 Jme₁ma₂në₂ŋag₃ dsa₂ 'éi₂ jaun₂ guë́₄ ca₂chei₃ juɨ₅ juɨg₂ Belén, jaun₂ ca₂tsɨ́'₃ dsa₂:
\p ―O₂nó'₅ 'nia'₂ ja₁jaun₂, o₂quion₂ de'₂ 'nia'₂ 'í₁ rë₂ të₂le₃ quió'₅ chi'₂ bë'₅₄ i₂'ɨ́n'₅ 'nia'₂ në₅; jaun₂ jë₁ma₂ca₂dsáin'₂ 'nia'₂, i₂con'₄ 'nia'₂ jág₁ ia₁jaun₂ nei₅₄ jniá₂ ján₃ i₂jme₁juɨin'₂.
\p 
\v 9 Jme₁ma₂në₂néi₂ dsa₂ 'éi₂ jág₁ quió'₅ rag₅₄, jaun₂ ca₂i₃léin₂. Jaun₂ në́₃, nei₅ a₂ma₂ca₂jág₃a të₂le₃ 'uë₃ ja₁'ia₂a 'iog₂, ca₂ŋó₃ ne₄ juɨ₅ quió'₅, ca₂lia'₂ ca₂'ág₂ tei₄ ne₄ ja₁jme₁'en₅₄ guein₂.
\v 10 Jme₁ca₂jág₃ jaun₂,\f + \fr 2:10 \ft Co₂'nió'₄ le₃jua'₅₄, caun₂ cosa a₂tsá₃ 'i₄ jme₂dsí₂, a₂ca₂jmo₃ Diú₄. 'Nio'₂ ja₁ton₅ Salmo 8:3; Romanos 1:25.\f* ca₂jmo₃ 'io'₂ 'ŋio₅ lɨn₃;
\v 11 jaun₂ jme₁ca₂i₃toin'₅₄ dsi₂néi₂, ca₂jɨ́in₂ guein₂ bë'₅₄ quiain'₅₄ chog₅₄ i₂chen₂ María. Jaun₂ në́₃, ca₂chi₃jné₃ ca₂jme₃juɨin'₂ guein₂. Jaun₂ dsɨ₂juɨ₅ le₂jaun₂ qui₂ca₂niá₃ tsɨ₁gu₅ quió'₅, ca₂cuë₃ cu₄nióg₄, chen₂, no'₅₄ mirra në́₃.
\v 12 Cang₂ guë́₄ jaun₂ ca₂quɨ₃ dsa₂ 'éi₂ a₂ca₂jmo₃ Diú₄ jág₁ a₂tsá₃ ma₃dsɨ₃lein₃ juɨ₅ ja₁con₂ Rag₅₄ Herodes, jaun₂ juɨ₅ siá'₂ bá₄ ca₂i₃lein₃ juɨ₅ go₅₄.
\s1 Ca₂cuɨng₃ Së́₄ quiain'₅₄ María juɨ₅ 'uë₃ Egipto
\p 
\v 13 Cang₂ guë́₄ jaun₂, jme₁ma₂i₂len₃ dsa₂ can'₅₄ 'éi₂, ca₂quɨ₃ Së́₄ a₂ca₂jme₃jnia₅ jan₂ ángel quián₅ Te₁gui'₅₄ ja₁coin₂, a₂ca₂juá'₂:
\p ―Nau₂, jŋia₅ i₂bë'₅₄ quiáng'₂, chog₅₄ në́₃, cuɨng₅ 'nia'₂ juɨ₅ 'uë₃ Egipto. Ja₁jaun₂ o₂'ú₅ ca₂lia'₂ ca₂juá'₃ jniá₂. Ia₁ 'nau'₂ Herodes 'nai'₂ guein₂ a₂jŋag'₃.
\p 
\v 14 A₂ca₂nau₂ jaun₂ Së́₄, ca₂tág₃ guein₂ quian'₅₄ chog₅₄ a₂'uë₂ jaun₂, ca₂i₃léin₂ juɨ₅ Egipto.
\v 15 Ja₁jaun₂ ca₂tóin'₂ ca₂lia'₂ ca₂jon₃ Herodes. Ca₂lë₃ le₂në₅ ia₁jaun₂ le₃ti₃ jág₁ a₂ca₂juá'₂ Te₁gui'₅₄ të₂le₃ quian'₅₄ dsa₂ i₂jme₁'ë́₂ jág₁ o₄quió'₄, jme₁ca₂juá'₂: “Të₂ Egipto bá₄ ca₂të₃ jniá₂ jón₃ quiáng₃.”\f + \fr 2:15 \ft Oseas 11:1.\f*
\s1 Jmo₅ Herodes 'éi'₃ a₂jme₃dsiain₂₃ guein₂
\p 
\v 16 Jme₁ca₂rë₃lí'₄ Herodes ca₂jme₃gau₅ dsa₂ can'₅₄ 'éi₂ quió'₅, ca₂rë₃'néi₃ 'ŋio₅ lɨn₃. Jaun₂ ca₂chein₃ dsa₂ a₂jme₃dsiain₂₃ ca₂le₃jɨ́n₃ guein₂ i₂con'₂ ma₂tion'₅₄ tɨn₃ ŋi₂, guein₂ i₂pí'₁ guë́₄ në́₃ i₂chan₂ ma₂quián₅ Belén, lia'₂ con'₂ tí₅ ma₂ne₁ŋó₄ jmɨg₄ a₂ca₂juá'₂ dsa₂ can'₅₄ 'éi₂.
\v 17 Jaun₂ le₂në₅ ca₂rë₃ti₃ jág₁ a₂ca₂tó'₂ ne₄ si₂ Jeremías i₂jme₁'ë́₂ jág₁ o₄quió'₄ Diú₄:
\q1 
\v 18 Ca₂né'₂ të₁tsɨ'₅₄ co₂mɨ'₅₄ jë₄ juɨg₂ Ramá,
\q2 a₂'o₅ dsa₂ a₂quɨ'₂ dsɨ́₅ guë́₄ lɨn₃;
\q1 Raquel bá₄ 'éi₂ ca₂'o₃\f + \fr 2:18 \ft Raquel: 'io₅₄ quián₅ Jacob, Génesis 29.\f*
\q2 o₄quió'₄ chi'₂-guein₂ quiáin₅,
\q1 jaun₂ tsá₃ ca₂gue₃ jua'₅₄ 'ein₂ guë́₃ jmo₃ lián'₂ dsɨ́₅,
\q2 ia₁ ma₂ca₂dsan₃ bá₄ guein₂.\f + \fr 2:18 \ft Jeremías 31:15.\f*
\p 
\v 19 La₁ cang₂ guë́₄ jaun₂, jme₁ma₂ca₂jon₃ Herodes, ca₂quɨ₃ Së́₄ a₂ca₂jme₃jnia₅ táng₃ jan₂ ángel quián₅ Te₁gui'₅₄ ja₁coin₂ 'ein₅₄ Egipto,
\v 20 Ca₂juá'₂ ángel:
\p ―Nau₂, jŋia₅ táng₃ i₂bë'₅₄ quiáng'₂, chog₅₄ në́₃, jaun₂ o₂nó'₅ táng₃ 'nia'₂ juɨ₅ 'uë₃ Israel, ia₁ ma₂ca₂dsan₃ bá₄ i₂jme₁'nio₃ jme₁jŋɨ'₃ guein₂.
\p 
\v 21 A₂ca₂nau₂ jaun₂ táng₃ Së́₄, ca₂tág₃ chi'₂ quiáin₅, quian'₅₄ chog₅₄, juɨ₅ 'uë₃ Israel.
\v 22 La₁ jme₁ca₂rë₃ŋi₅ Së́₄ a₂ma₂lɨ́n₅ ta₁ Arquelao 'uë₃ Judea, ta₁ a₂jme₁lɨ́n₄ Herodes jmei₂, jaun₂ ca₂rë₃gó'₅ dsó₃ ja₁jaun₂. Ia₁ ca₂'ë́₂ táng₃ Diú₄ jág₁ jë₄ quɨ₂₃, jaun₂ juɨ₅ 'uë₃ Galilea bá₄ ca₂ŋó₃.
\v 23 Jme₁ca₂dsióg₃ ja₁jaun₂, ca₂ŋó₃ ca₂i₁gua₂ juɨg₂ ja₁chei₂ Nazaret. Le₂në₅ bá₄ ca₂rë₃ti₃ jág₁ quió'₅ dsa₂ i₂ca₂'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂: “A₂quiong₃ dsa₂ nazareno.”
\c 3
\s1 'Ë́₂ Juan₅₄ jág₁ caun₂ 'uë₃ quein₂ ja₁co₂'ŋiog₅
\r (Marcos 1:1-8; Lucas 3:1-18; Juan 1:19-28)
\p 
\v 1 Jmɨg₄ jaun₂ guan₃ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂, caun₂ 'uë₃ quein₂ co₂'ŋiog₅ ja₁tén₄ 'uë₃ Judea, a₂'ë́₂ jág₁,
\v 2 a₂juá'₂:
\p ―Jein'₅₄ 'nia'₂ 'au'₂, ia₁ ma₂ja₂quián₃ jmɨg₄ jë₁gon₃ Diú₄.
\p 
\v 3 Juan₅₄ la₂ bá₄ 'éi₂ i₂ca₂'ɨn₃ Isaías i₂jme₁juá'₂ o₄quió'₄ Diú₄ jme₁ca₂tó'₂ ne₄ si₂ a₂juá'₂ le₂la₂:
\q1 Né'₂ a₂táun₂ dsa₂ tiá₂ jág₁
\q2 caun₂ 'uë₃ quein₂ ja₁co₂'ŋiog₅, a₂juá'₂:
\q1 “Jmo₄ 'nia'₂ co₂jŋia₅₄ juɨ₅ quió'₅ Te₁gui'₅₄;
\q2 nia₄ 'nia'₂ caun₂ juɨ₅ co₂dsau₅.”\f + \fr 3:3 \ft Isaías 40:3.\f*
\p 
\v 4 Nɨ₁tsɨn'₅₄ Juan₅₄ 'éi₂ jme₁lë́₄ 'mɨ'₂ a₂rë₂ta₄ quian'₅₄ jŋi₄ já'₂ camello; a₂jme₁jén'₅ tú'₅ guë'₂ quian'₅₄ lo₄ já'₂; má₃ a₂jme₁guë́'₅ guë'₂, jmá'₃ i₁nɨ'₂ tia₄ quian'₅₄ jmɨ₁tá'₄ cha₂ ja₁nau₂.
\v 5 Jme₁ja₂lén₂ dsa₂ chan₂ Jerusalén, quian'₅₄ dsa₂ i₂tián'₅ 'uë₃ Judea quian'₅₄ dsa₂ i₂tián'₅ cau₅ Cuá₃ Jordán në́₃, jme₁qui₂ja₂néi₃ jág₁ a₂cuë₅ 'éi₂.
\v 6 Jme₁ma₂ca₂lë₃ jmo₂₃ qui₂ŋí₃ quió'₅ ne₄ Diú₄ ca₂le₃jë́₃ dso₄ a₂qui₂rë₂cáin'₄, jaun₂ guë́₄ ca₂cho₃ Juan₅₄ jmɨg₂\f + \fr 3:6 \ft lit. “ca₂tióg₃ Juan₅₄ jmɨg₂.” \f* Cuá₃ Jordán.
\p 
\v 7 La₁ jme₁ca₂jág₃ Juan₅₄ juɨn₅ lɨn₃ dsa₂ fariseos ja₂lén₂ quian'₅₄ dsa₂ saduceos në́₃, a₂mɨ₂₃ cho₃ Juan₅₄ jmɨg₂,\f + \fr 3:7 \ft lit. “tióg₂ Juan₅₄ jmɨg₂.” \f* jaun₂ ca₂juá'₂ Juan₅₄:
\p ―¡'Nia'₂ tsɨ₁jon₂ dsɨ₂mɨ'₂! ¿'Ein₂ bá₄ në₂chí'₃ 'nia'₂ a₂cuɨng'₂ long'₅₄ a₂'i₄ 'nei₂ dsɨ́₅ Diú₄ a₂ja₂quián₃?
\v 8 Jmo₄ 'nia'₂ jaun₂ juɨ₁le₂jniá₂ a₂léi₄ të₃dsón'₂ a₂ma₂ca₂jein'₅₄ 'nia'₂ 'au'₂.
\v 9 Tsá₃ o₁len'₂ 'nia'₂ jua'₅₄ lé₂ le₃jua'₅₄ 'nia'₂: “Lág₅ jnia'₅₄ tsɨ₁jon₂ Abraham”; ia₁ jniá₂ juá'₅, ca₂të₂ nɨ₁cang₁ tio'₅₄ la₂, lé₂ le₃jmo₃ Diú₄ jmói'₂ tsɨ₁jon₂ Abraham.
\v 10 Ia₁ ma₂lë́₅ co₂jŋia₅₄ ŋi₁dsi₁ a₂qui₂uɨ́n'₂ 'ma₂. Ca₂le₃jë́₃ 'ma₂ a₂tsá₃ dse₃ mɨ́g₂ 'ag₅, uɨ́n'₂ bá₄, dsɨ₂to'₅₄ si₂.
\v 11 Jniá₂ në́₃, dsau₅ bá₄ në₂tiáng₃ 'nia'₂ jmɨg₂ co₂'nió'₄ a₂jáng'₅ léi₄ a₂jein'₅₄ 'nia'₂ 'au'₂; la₁ i₂já₅ chi₁co'₅₄ quió₃ në́₃, 'éi₂ bá₄ i₂'uan'₂ guë́₄ lia'₂ con'₂ guë́₄ jniá₂, ca₂lia'₂ jŋia'₅₄ lau₂ ton₅ tag₅₄ bá₄ tsá₃ ca₂tɨ́ng₂ i₁quian₃. 'Éi₂ guë́₄ në́₃, tióg₂ Jme₂dsí₂ Jŋió₅, dsi₂si₂ në́₃.
\v 12 Në₂jag₄ bá₄ a₂ma₂chi₁chan'₂ ŋí₁ a₂quió'₅ mɨ́g₂ trigo, dsia₃ jma₃quén₅ quian'₅₄ jme₁qui₅. Jmá'₃ mɨ́g₂ bá₄ cág'₃, 'ma₃ dsi₂néi₂, la₁ qui₂dsɨ́'₂ bá₄ jme₁qui₅ dsi₂si₂ ja₁tsá₃ ma₃o₁lɨ́g'₂ jmɨg₄ éi₃.\f + \fr 3:12 \ft 'Nio'₂ ja₁ton₅ Mateo 13:30.\f*
\s1 Ca₂jŋó₂ Jesús jmɨg₂
\r (Marcos 1:9-11; Lucas 3:21-22)
\p 
\v 13 Jaun₂ në́₃, Jesús, o₂'ɨ́in₃ 'uë₃ Galilea, ca₂dsióg₃ të₂ Cuá₃ Jordán ia₁jaun₂ cho₃ Juan₅₄ jmɨg₂.\f + \fr 3:13 \ft lit. “ia₁jaun₂ tióg₂ Juan₅₄ jmɨg₂.” \f*
\v 14 Tsá₃ jme₁gue₅ Juan₅₄ le₂'uɨg₅₄, jaun₂ ca₂juá'₂ tsɨ́'₅ Jesús:
\p ―Jniá₂ bá₄ i₂'nió'₅ quió₃ tsón'₄ 'ne₂ jmɨg₂.\f + \fr 3:14 \ft lit. “tián'₄ 'ne₂ jmɨg₂.” \f* ¿'A₂ bá₄ lia'₂ 'ne₂ ŋe'₃ ja₁con₂ jniá₂?
\p 
\v 15 La₁ ca₂juá'₂ Jesús:
\p ―Juɨ₁le₅₄ bá₄ le₂në₅ të₂në₃, ia₁ dsi₂ten₅₄ de'₂ jmó₁ jniog₄ le₂në₅ ia₁jaun₂ jme₁ti₁ ca₂le₃jë́₃ a₂dse₃.
\p Jaun₂ bá₄ ca₂gue₃ Juan₅₄.
\p 
\v 16 Jme₁ma₂lë₅ cho₅ Juan₅₄ jmɨg₂,\f + \fr 3:16 \ft lit. “tióg₂ Juan₅₄ jmɨg₂.” \f* jaun₂ ca₂o₃'ɨ́n₃ Jesús dsi₂jmɨg₂. Jaun₂ dsɨ₂juɨ₅ le₂jaun₂ ca₂niá₃ dsɨ₄ mɨ₂güɨ́g₃ ca₂lë₃, jaun₂ ca₂jɨ́n₂ Jesús Jme₂dsí₂ quián₅ Diú₄ ca₂sión₃ ne₄ quió'₅, i₂lɨ́n₅ lia'₂ lɨ́n₅ jan₂ i₁ju₂.
\v 17 Jaun₂ ca₂né'₂ jág₁ guei'₅₄ a₂ca₂juá'₂:
\p ―I₂la₂ bá₄ jón₃ quiáng₃ i₂ŋɨ́₄ lë₃ 'nióg₃ guë́₄ lɨn₃. 'E₂ bá₄ 'ŋio₂ dsɨ₃ quiain'₅₄.
\c 4
\s1 Ca₂caun₃ i₂së₃dsen₃ táu₂ quió'₅ Jesús
\r (Marcos 1:12-13; Lucas 4:1-13)
\p 
\v 1 Dsɨ₂juɨ₅ jaun₂ ca₂të₃ Jme₂dsí₂ quián₅ Diú₄ ca₂të́'₃ Jesús caun₂ 'uë₃ quein₂ co₂'ŋiog₅ ia₁jaun₂ ja₁jaun₂ cáun₂ táu₂ i₂së₃dsen₃.
\p 
\v 2 Të₂láu₃ jmɨg₄ të₂láu₃ nei₅, ca₂jme₃'ɨn₅₄ Jesús; cang₂ guë́₄ jaun₂ ca₂lë₃ i₁cón'₅ 'ŋio₅ lɨn₃.
\v 3 Jaun₂ ca₂jme₃quián₃ i₂së₃dsen₃ ja₁coin₂, a₂cáun₂ táu₂, jaun₂ ca₂juá'₂ tsɨ́'₅ Jesús:
\p ―Chi₂jua'₂ dsón'₂ lɨ́ng'₅ Ja₁ŋi'₅₄ Diú₄, jmo₄ juɨ₁le₅₄ i₁ŋí'₄ nɨ₁cang₁ tio'₅₄ në₅.
\p 
\v 4 La₁ ca₂ŋag₃ Jesús:
\p ―Chi₁ton₅ ne₄ Si₂: “On₃jua'₅₄ jmá'₃ quian'₅₄ i₁ŋí'₄ le₃tan₅₄ dsa₂ mɨ₂güɨ́g₃ le₃chain₂, ján₃ bá₄ 'nió'₅ jme₃tan₅₄ dsa₂ quian'₅₄ ca₂le₃jë́₃ jág₁ a₂'uë'₂ mɨ₂'o₄ Diú₄.”\f + \fr 4:4 \ft Deuteronomio 8:3.\f*
\p 
\v 5 Ŋó₃ jaun₂, ca₂jiog₃ táng₃ i₂së₃dsen₃ të₂ juɨg₂ Jerusalén ciudad jŋió₅, jaun₂ ca₂jiog₃ të₂ guei'₅₄ guá'₅ templo ja₁ŋei₅ 'ŋio₅ lɨn₃.
\v 6 Jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ Jesús:
\p ―Chi₂jua'₂ 'ne₂ lɨ́ng'₅ Ja₁ŋi'₅₄ Diú₄, tian'₅₄ ja₁në₅; ia₁ juá'₂ ne₄ Si₂:
\q1 Chen₃ Diú₄ ángeles quiáin₅
\q2 ia₁jaun₂ jmo₃ 'í₁;
\q1 chó'₂ quian'₅₄ gu₂
\q2 ia₁jaun₂ tsá₃ jéng'₂ uɨg₅ nióg'₃ quian'₅₄ cang₄.\f + \fr 4:6 \ft Salmo 91:11-12.\f*
\p 
\v 7 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Ján₃ bá₄ juá'₂ ne₄ Si₂: “Tsá₃ tang'₅₄ Te₁gui'₅₄ Diú₄ quiáng'₂.”\f + \fr 4:7 \ft Deuteronomio 6:16.\f*
\p 
\v 8 Con'₂ guë́₄ siá'₂ táng₃ ca₂jiog₃ i₂së₃dsen₃ juɨ₅ caun₂ má'₂ ja₁ŋei₅ 'ŋio₅ lɨn₃. Jaun₂ ca₂'ë₃ le₃jë́₃ juɨg₂ a₂cha₂ mɨ₂güɨ́g₃ quian'₅₄ ca₂le₃jë́₃ a₂jlá'₁ cha₂.
\v 9 Jaun₂ ca₂tsɨ́'₃ Jesús:
\p ―Dsia₅₄ jniá₂ gog'₂ 'ne₂ ca₂le₃jë́₃ a₂në₅, në₁jua'₂ ca₂chi₁jne'₄ ne₃ a₂jme₁juag'₂.
\p 
\v 10 Jaun₂ në́₃ ca₂ŋag₃ Jesús:
\p Guan'₂ Satanás, ia₁ ne₄ Si₂ juá'₂: “Jme₁juɨn'₂ Te₁gui'₅₄ Diú₄ quiáng'₂, jŋia'₅₄ lia'₂ ne₄ 'éi₂ bá₄ jme₁ti₁.”\f + \fr 4:10 \ft Deuteronomio 6:13.\f*
\p 
\v 11 Jaun₂ në́₃ ca₂ŋá'₃ i₂së₃dsen₃, jaun₂ ca₂o₃lén₂ ángeles ca₂jme₃ti₃ ta₁ ne₄ Jesús.
\s1 Ca₂jme₃lióg₃ Jesús ta₁ quió'₅, 'uë₃ Galilea
\r (Marcos 1:14-15; Lucas 4:14-15)
\p 
\v 12 Jme₁ca₂rë₃ŋi₅ Jesús a₂'en₅₄ Juan₅₄ né'₃ 'má₃, jaun₂ ŋó₃ juɨ₅ 'uë₃ Galilea.
\v 13 Tsá₃ ca₂jŋia₃ jë₄ juɨg₂ Nazaret, ŋó₃ bá₄ ca₂i₁'i₅ të₂ Capernaum, caun₂ juɨg₂ a₂niog₅ chei'₅₄ jmɨ₁ŋí'₄ 'uë₃ ja₁tén₄ Zabulón quian'₅₄ Neftalí.
\v 14 Jaun₂ le₂në₅ ca₂rë₃ti₃ jág₁ a₂ca₂tó'₂ ne₄ si₂ Isaías i₂jme₁'ë́₂ jág₁ o₄quió'₄ Diú₄:
\q1 
\v 15 'Uë₃ ja₁tén₄ Zabulón quian'₅₄ Neftalí
\q2 a₂niog₅ le₃quióng₄ Cuá₃ Jordán, chei'₅₄ jmɨ₁ŋí'₄,
\q2 'uë₃ Galilea le₃quió'₅ dsɨ₂nau₂:
\q1 
\v 16 dsa₂ i₂jme₁tián'₄ jë₄ qui₁né'₃
\q2 ma₂ca₂jág₃ caun₂ si₂ juë'₂;
\q1 dsa₂ i₂jme₁tián'₄ 'uë₃ ja₁'ei₅ 'én'₁ 'mú₃,
\q2 ne₄ quió'₅ ma₂ca₂'ág₂ si₂.\f + \fr 4:16 \ft Isaías 9:1-2.\f*
\p 
\v 17 Të₂le₃ ne₄ juɨ₅ jaun₂ ca₂jme₃lióg₃ Jesús ca₂'ë́₂ jág₁, ca₂juá'₂:
\p ―Jein'₅₄ 'nia'₂ 'au'₂, ia₁ ma₂ja₂quián₃ guá₂ 'éi'₃ quió'₅ Diú₄.
\s1 Ca₂të́'₃ Jesús quén₂ dsa₂ i₂tsán'₂ ju₄
\r (Marcos 1:16-20; Lucas 5:1-11)
\p 
\v 18 Co₂ráun₂ ŋó₃ Jesús i₁ŋɨ₂ chei'₅₄ jmɨ₁ŋí'₄ Galilea. Ja₁jaun₂, ca₂jɨ́in₂ Si₂mu₅₄ i₂të́'₂ dsa₂ Pe₄, quiain'₅₄ dsó₂ rɨin'₅₄ i₂chen₂ Drë́₄. Dsa₂ i₂tsán'₂ ju₄ bá₄ 'éi₂, jaun₂ hora jaun₂ dé₄ në́₃ jme₁tioin'₅₄ táun₂ 'má₅ dsi₂jmɨg₂.
\v 19 Jaun₂ ca₂juá'₂ Jesús:
\p ―'Éin₃ jniá₂, jaun₂ cuë₅₄ ta₁ a₂chi₁liang'₂ dsa₂ mɨ₂güɨ́g₃, juɨ₁lia'₂ chi₂liáng'₁ ju₄ në₅.
\p 
\v 20 Dsɨ₂juɨ₅ le₂jaun₂ bá₄ ca₂dsia₃ cau₅ 'má₅ quió'₅, jaun₂ i₃léin₂ quiong'₅₄.
\p 
\v 21 Me'₂ guë́₄ ne₄ juɨ₅ ja₁i₃léin₂ jaun₂, ca₂jɨ́in₂ con'₂ guë́₄ on₃ dsó₂: Jacobo quian'₅₄ Juan₅₄ rɨin'₅₄, ja₁ŋi'₅₄ Zebedeo. Jme₁tioin'₅₄ 'ŋió'₃ tsɨ₁mu₅ qui₂'méi₅ 'má₅ quió'₅, quiain'₅₄ jmei₂. Jaun₂ ca₂të₃ Jesús,
\v 22 jaun₂ dsɨ₂juɨ₅ le₂jaun₂ bá₄ ca₂tí₂ tsɨ₁mu₅ quió'₅ ca₂téin₂ jmei₂, jaun₂ ca₂i₃léin₂ ca₂jme₃quiain'₅₄ Jesús.
\s1 Ca₂jme₃tɨn₅ Jesús juɨn₅ lɨn₃ dsa₂
\r (Lucas 6:17-19)
\p 
\v 23 I₂ŋɨ₅₄ Jesús le₂tan₅₄ 'uë₃ Galilea, qui₂jme₂tɨin₂₃ dsa₂ dsi₂néi₂ guá'₅ sinagogas lia'₂ caun₂ ja₁qui₂ŋɨ́i₅. Qui₂'ë́₂ jág₁ dse₃ juɨ₁lia'₂ ja₁gon₂ Diú₄, ján₃ bá₄ qui₂jme₂'lióin₂ dsa₂ ca₂le₃jë́₃ ne₅₄ dso₄ 'e₂ niog₅ lɨ́n₅ dsa₂.
\v 24 Le₂tan₅₄ 'uë₃ Siria ca₂i₃'ág₃ jág₁ 'a₂ lia'₂ lë́₅ jmo₅ Jesús ŋɨ₂₃, jaun₂ ca₂o₃jŋia₃ dsa₂ ca₂le₃jɨ́n₃ dsa₂ i₂le₁quian₅ ca₂le₃jë́₃ ne₅₄ jmɨ₁uɨg₅, quian'₅₄ juɨ₁'ein₂ guë́₃ i₂quɨ'₂ uɨg₅ quió'₅. Ca₂i₁quiain₅₄ ca₂le₃jɨ́n₃ dsa₂ i₂tion'₅₄ jme₂dsí₂ je₂na'₅₄, dsa₂ i₂lɨ́n₅ dso₄ 'ei₂, quian'₅₄ dsa₂ 'lian'₂ në́₃. Ja₁jaun₂ ca₂jme₃'lión₂ Jesús ca₂le₃jɨ́n₃ dsa₂ 'éi₂.
\p 
\v 25 Juɨn₅ lɨn₃ dsa₂ i₂chan₂ Galilea, dsa₂ i₂chan₂ ta₁guia₃ juɨg₂ ja₁të́'₂ dsa₂ Decápolis, quian'₅₄ dsa₂ i₂chan₂ Jerusalén, dsa₂ i₂tián'₅ 'uë₃ Judea quian'₅₄ dsa₂ i₂tián'₅ le₂'ŋo'₅₄ Cuá₃ Jordán në́₃, ca₂jme₃quiong'₅₄ ca₂jme₃quiain'₅₄ Jesús.
\c 5
\s1 Jág₁ a₂ca₂cuë₃ Jesús má'₂
\r (Lucas 6:20-23)
\p 
\v 1 Jɨ́n₂ Jesús dsa₂ juɨn₅ 'éi₂, jaun₂ ca₂uɨ́g₂ caun₂ dsɨ₂con'₂ ja₁ŋei₅ guë́₄, jaun₂ ca₂guá₂. Jaun₂ ca₂ŋɨ'₂ dsa₂ i₂quiain'₅₄ le₃lág'₃ quió'₅.
\v 2 Jaun₂ ca₂jme₃lióg₃ ca₂jme₃tɨin₂₃ dsa₂, ca₂juá'₂ le₂la₂:
\s1 ¿'Ein₂ dsa₂ 'éi₂ i₂jmo₅ 'io'₂?
\p 
\v 3 ―'E₂ guë́₄ dsen₃ juɨ₁lia'₂ dsa₂ i₂rë₂lí'₄ qui₂chi₁quiain₁₂ jmɨg₄ o₄quió'₄ jme₂dsí₂ quió'₅, ia₁ i₂le₂'éi₂ bá₄ ca₂tɨ́n₂ ja₁gon₂ Diú₄.
\p 
\v 4 ’'E₂ guë́₄ dsen₃ juɨ₁lia'₂ dsa₂ i₂ta'₂ 'lia'₂ dsɨ́₅, ia₁ cuë₃ bá₄ Diú₄ lián'₂ dsɨ́₅.
\p 
\v 5 ’'E₂ guë́₄ dsen₃ juɨ₁lia'₂ dsa₂ i₂jmo₅ me'₂, ia₁ gua'₅₄ 'uë₃ bá₄ tɨin₅₄, cuë₃ Diú₄.
\p 
\v 6 ’'E₂ guë́₄ dsen₃ juɨ₁lia'₂ dsa₂ i₂ŋɨ́₄ lë₃ 'ɨ́n₅ dsɨ́₅ jmo₃ a₂'ŋio₂ dsɨ́₅ Diú₄, ia₁ lë́₂ dsɨ́₅ në₂jag₄ bá₄ a₂i₁cón'₅, a₂rë₂quein₂ dsɨ́₅ në́₃; ia₁ 'ág'₄ bá₄ dsɨ́₅, jmo₃ Diú₄.
\p 
\v 7 ’'E₂ guë́₄ dsen₃ juɨ₁lia'₂ dsa₂ i₂ŋéi₂ dsɨ́₅ dsa₂ sián'₂, ia₁ dsia₃ bá₄ Diú₄ ŋéi₂ dsɨ́₅ guioin₅₄.
\p 
\v 8 ’'E₂ guë́₄ dsen₃ juɨ₁lia'₂ dsa₂ i₂qui₂le₁jë́₃ dsɨ́₅, ia₁ jɨ́in₂ bá₄ Diú₄.
\p 
\v 9 ’'E₂ guë́₄ dsen₃ juɨ₁lia'₂ dsa₂ i₂quɨ́n'₅ bí₂ 'no'₂ juɨ₅ 'a₂ lia'₂ 'ag₃ tei₄, ia₁ quiong₃ Diú₄ chi'₂-guein₂ quiáin₅.
\p 
\v 10 ’'E₂ guë́₄ dsen₃ juɨ₁lia'₂ dsa₂ i₂qui₂co₂'ein₅ dsa₂ 'uɨg₅₄ ia₁ a₂jmo₂₃ a₂'ŋio₂ dsɨ́₅ Diú₄, ia₁ ja₁gon₂ Diú₄ bá₄ ca₂tɨ́in₂.
\p 
\v 11 ’'E₂ guë́₄ dsen'₃ 'nia'₂, jë₁ma₂të́₂ rë₁qui₃jnáu'₂ dsa₂ jág₁, qui₂co₂jmóg'₂, a₂juá'₂ ca₂le₃jë́₃ ne₅₄ jág₁ a₂tsá₃ tí₅ ja₁con'₂ 'nia'₂ o₄quió₃ jniá₂;
\v 12 jmo₄ 'nia'₂ 'io'₂, juɨ₁le₁'ág₄ bá₄ dse₃ 'au'₂, ia₁ guéi'₁ 'nia'₂ 'liang'₅₄ jó₄ guei'₅₄ i₂juɨ́g₃. Ia₁ le₂në₅ bá₄ ján₃ qui₂ca₂co₃'ein₃ dsa₂ quió'₅ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄, i₂ma₂ca₂rë₃chán₃ le₂jŋiá₅ con'₂ guë́₄ 'nia'₂.
\s1 Jág₁ a₂jáng'₅ léi₄ juɨ₁lia'₂ tsɨ₁ŋi₁ quian'₅₄ si₂ a₂tág₅ jɨn₄ dsa₂ mɨ₂güɨ́g₃
\r (Marcos 9:50: Lucas 14:34-35)
\p 
\v 13 ’Tén'₅ 'nia'₂ ta₁ ne₄ gua'₅₄ 'uë₃ juɨ₁lia'₂ jmo₅ tsɨ₁ŋi₁ jë₄ má₃. La₁ në₁jua'₂ ma₂ca₂'en₃ ŋi'₅₄ tsɨ₁ŋi₁, ¿'a₂ bá₄ lia'₂ lé₂ le₃lei₂ táng₃? Tsá₃ ma₃'e₂ ta₁ jmo₃, a₂jŋia'₅₄ lia'₂ a₂dsɨ₃ga'₅₄ bá₄ jaun₂, qui₃tsó'₃ dsa₂.
\p 
\v 14 ’Ján₃ bá₄ rë₂jniá'₁ 'nia'₂ co₂'nió'₄ a₂lɨ́ng'₅ si₂ quió'₅ dsa₂ mɨ₂güɨ́g₃. Juɨ₁lia'₂ caun₂ juɨg₂ a₂niog₅ dsɨ₂con'₂ tsá₃ lé₂ le₃dsɨ₃'ma₄,
\v 15 ján₃ bá₄ tsá₃ guí'₅ dsa₂ si₂ caun₂ nɨ₁tsɨ́₅ a₂chi'₃ né'₃ tsɨ₁gu₅; guei'₅₄ bá₄ chi'₂ dsa₂ ia₁jaun₂ tág'₅ si₂ ja₁con₂ ca₂le₃jɨ́n₃ i₂tion'₅₄ dsi₂néi₂.
\v 16 Le₂në₅ bá₄ 'nia'₂ në́₃, jmo₄ tág₅ si₂ quiáng'₂ jɨn₄ dsa₂ mɨ₂güɨ́g₃, ia₁jaun₂ të₅₄ ne₄ dsa₂ a₂dse₃ a₂jmo'₂ 'nia'₂, jaun₂ jme₃juɨin'₂ Ŋéi'₅ 'nia'₂ i₂guá₅ guei'₅₄ i₂juɨ́g₃.
\s1 Jme₂tag₅ Jesús juɨ₁lia'₂ 'Éi'₃
\p 
\v 17 'Tsá₃ o₁len'₂ 'nia'₂ jua'₅₄ a₂guio₃ jniá₂ a₂jŋiá'₄ Si₂ 'Éi'₃ quió'₅ Moisés, on₃ guë'₂ jág₁ a₂jme₁jme₂tag₅ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄. On₃jua'₅₄ ta₁ jaun₂ guio₃ jniá₂ a₂jŋiá'₄, të₂le₃ a₂jme₁'ŋia₅ bá₄ jniá₂ guio₃.
\v 18 Ia₁ a₂dsɨ₂jó'₃ juá'₅ jniá₂, të₁lia'₂ niog₅ mɨ₂güɨ́g₃, të₁lia'₂ jniá₂ dsɨ₄ guei'₅₄ në₅, 'i₁caun₂ punto, on₃ guë'₂ 'i₁caun₂ letra pí'₁ quió'₅ Si₂ 'Éi'₃ tsá₃ dsɨ₃'én₂ ca₂lia'₂ ca₂rë₃ti₃ ca₂le₃jë́₃ a₂niog₅ lé₂.
\v 19 'Uɨg₅₄ jaun₂, juɨ₁lia'₂ i₂jmo₅ cau₅ caun₂ 'Éi'₃ Juá'₅ ne₄ Si₂ 'Éi'₃, o₁jŋia'₅₄ lɨ́in₂ caun₂ 'éi'₃ tsá₃ lɨn₄ quen₅, në₁jua'₂ le₂jaun₂ jme₁tɨin₂₃ dsa₂ rɨin'₅₄, le₂jaun₂ bá₄ lén₂ dsa₂ 'éi₂ jan₂ dsa₂ i₂tsá₃ lɨn₄ quen₅ ja₁gon₂ Diú₄. La₁ juɨ₁lia'₂ dsa₂ i₂nag₅ gau₂, jme₂ti₃, le₂jaun₂ jme₂tɨin₂₃ i₂sián'₂ në́₃, le₂jaun₂ bá₄ lén₂ dsa₂ 'éi₂ juɨin'₂ ja₁gon₂ Diú₄.
\v 20 Ia₁ a₂dsɨ₂jó'₃ juá'₅ jniá₂ juɨ́g₂ 'nia'₂, në₁jua'₂ tsá₃ ca₂jmo'₅₄ 'nia'₂ a₂dse₃ guë́₄ con'₂ guë́₄ të₅juá'₅ quian'₅₄ dsa₂ fariseos, lia'₂ o₁lɨ́g'₂ jmɨg₄ tsá₃ lé₂ dsi₁no'₃ 'nia'₂ ja₁gon₂ Diú₄.
\s1 Jme₂tag₅ Jesús juɨ₁lia'₂ a₂rë₂'ne₂ dsa₂
\r (Lucas 12:57-59)
\p 
\v 21 ’Ma₂ŋi'₅₄ bá₄ 'nia'₂ 'a₂ lia'₂ lë́₅ ma₂nág₂ dsa₂ can'₅₄ quián'₂ 'nia'₂: “Tsá₃ jŋɨ́g'₄ dsa₂,\f + \fr 5:21 \ft Éxodo 20:13.\f* ia₁ në₁jua'₂ 'ein₂ ca₂jŋɨ'₃ rɨn'₅₄, tion₅₄ të₃dsɨ₅₄ bá₄ 'éi'₃ ja₁coin₂.”
\v 22 La₁ jniá₂ juá'₅ juɨ́g₂ 'nia'₂, chi₂jua'₂ 'ein₂ ca₂rë₃'né₃ quian'₅₄ rɨn'₅₄,\f + \fr 5:22 \ft A₂lɨn'₅₄ chog₅₄ si₂ juá'₂ ján₃: “on₃jua'₅₄ cha₂ 'uɨg₅₄.” \f* ján₃ bá₄ le₂jaun₂ jióg'₂ 'í₁ ja₁coin₂, të₃dsɨ₅₄ 'éi'₃. Ján₃ bá₄ le₂jaun₂ juɨ₁lia'₂ i₂të₂'on'₂ rɨn'₅₄, ne₄ dsɨ₂tan₅₄ quián₅ guá'₅ bá₄ dsi₁léin₂, la₁ juɨ₁lia'₂ i₂quian₅ tonto\f + \fr 5:22 \ft griego: raca; caun₂ jág₁ të₂'o'₅₄ arameo co₂'nió'₄ a₂juá'₂: “Tsá₃ 'e₂ tio'₅₄ mɨ₂dsei'₂.” \f* rɨn'₅₄, go'₂ 'liáin'₃ quióin'₄ dsi₂si₂ ja₁'lɨg'₅₄.
\p 
\v 23 ’Uɨg₅₄ jaun₂ në́₃, në₁jua'₂ dsi₂can'₅₄ 'e₂ dsi₂can'₅₄ ne₄chei₂, a₂jen'₅₄ ne₄ Diú₄, në₁ca₂dsáu'₃ 'au'₂ tsá₃ 'ei₅ caun₂ jág₁ quian'₅₄ rɨ́ng'₂,
\v 24 ja₁jaun₂ de'₂ dsia₄ a₂jaun₂ cau₅ ne₄chei₂, jaun₂ guë́₄ guan'₂ jme₁dsian₅ mɨ'₅₄ o₂'éi₂ caun₂ jág₁ quian'₅₄ rɨ́ng'₂. Jaun₂ guë́₄ ŋe'₅₄ táng₃ i₂dsia₄ a₂cuë'₅₄ Diú₄.
\p 
\v 25 ’Chi₂jua'₂ 'ein₂ 'nio₃ 'nag₃ ne₄ dsɨ₂tan₅₄, ŋi'₅₄ ta₁ 'nio'₂ juɨ₅ 'éi₂ caun₂ jág₁ quiain'₅₄ né'₃ a₂jmo₃ le₂jaun₂, ia₁jaun₂ tsá₃ jáng'₂ ne₄ dsɨ₂tan₅₄ i₂qui₂dsɨ₅ 'éi'₃; ia₁ dsɨ₂tan₅₄ në́₃, con'₂ tsá₃ ŋó₅ në₁ca₂jáng'₂ o₄gú₃ chi'₂ 'ɨ'₅₄; i₂'éi₂ guë́₄ në́₃ 'liog'₃ né'₃ 'má₃.
\v 26 A₂dsɨ₂jó'₃ juá'₅ jniá₂, tsá₃ a₁jaun₂ o₃'ɨng'₂ ja₁jaun₂ ca₂lia'₂ ca₂qui'₅₄ ca₂le₃jë́₃ 'a₂ con'₂ mɨ₅ dsa₂ quiáng'₂.
\s1 Jme₂tag₅ Jesús a₂tsá₃ nió'₃ dsa₂ jág₁ quian'₅₄ dsa₂ on₃jua'₅₄ dsɨ₂i₂gu₂
\p 
\v 27 ’Ma₂ŋi'₅₄ bá₄ 'nia'₂ ján₃ 'a₂ lia'₂ lë́₅ ma₂juá'₂ dsa₂ le₂jŋiá₅: “Tsá₃ nióg'₄ jág₁ quian'₅₄ dsa₂ on₃jua'₅₄ dsɨ₂i₂gog'₂.”\f + \fr 5:27 \ft Éxodo 20:14.\f*
\v 28 La₁ jniá₂ guë'₂ juá'₅ juɨ́g₂ 'nia'₂, chi₂jua'₂ 'ein₂ dsɨ₂jiog₅ dsɨ́₅ 'lɨg'₅₄ qui₂jɨ́in₂ jan₂ dsa₂ mɨ́₂, co₂'nió'₄ ma₂në₂'nióg₂ dso₄ quiong'₅₄ juɨ₅ të₂dsɨ́₅.
\p 
\v 29 ’Në₁jua'₂ mɨ₂ne'₅₄ jmo₅ a₂tang'₂ dso₄, co₂dsia₅ dsi₄, tiong₂ uɨ́ng₂; ia₁ dse₃ guë́₄ a₂dsɨ₃'én₂ ca₂jne₄ quiáng'₂, con'₂ guë́₄ jme₁o₁'ú'₃ ta₁jang'₂ ja₁'lɨg'₅₄.
\v 30 Ján₃ bá₄ le₂në₅ në₁jua'₂ mɨ₂gog'₂ jmo₅ a₂tang'₂ dso₄, co₂dsia₅ ti₄, tiong₂ uɨ́ng₂; ia₁ dse₃ guë́₄ a₂dsɨ₃'én₂ ca₂jne₄ nɨ₁ŋɨ'₁ con'₂ guë́₄ jme₁o₁'ú'₃ ta₁jang'₂ ja₁'lɨg'₅₄.
\s1 Jme₂tag₅ Jesús juɨ₁lia'₂ dso₄ a₂tén₂ dsa₂ dsɨ₂i₂gu₂
\r (Mateo 19:9; Marcos 10:11-12; Lucas 16:18)
\p 
\v 31 ’Ján₃ bá₄ ma₂juá'₂ dsa₂ le₂jŋiá₅: “Chi₂jua'₂ 'ein₂ ca₂tén₂ dsa₂ mɨ́₂ quián₅, ca₂tɨ́in₂ cho₃ caun₂ si₂ a₂jáng'₅ léi₄ a₂ma₂ca₂téin₂ dsón'₂ rɨin'₅₄.”\f + \fr 5:31 \ft Deuteronomio 24:1.\f*
\v 32 La₁ jniá₂ juá'₅ juɨ́g₂ 'nia'₂, chi₂jua'₂ 'ein₂ ca₂tén₂ dsa₂ mɨ́₂ quián₅, on₃jua'₅₄ cha₂ 'uɨg₅₄, jua'₅₄ a₂ma₂nió'₅ jág₁ quian'₅₄ i₂sián'₂, jmo₂₃ a₂'no₃ 'io₅₄ quiáin₅ dso₄. Ján₃ bá₄ le₂jaun₂ juɨ₁lia'₂ dsa₂ ŋe'₂ i₂cán₂ 'io₅₄ i₂ma₂téi₂ dsa₂, ján₃ bá₄ le₂jaun₂ 'no₂₃ dso₄.
\s1 Jme₂tag₅ Jesús juɨ₁lia'₂ jág₁ a₂'ɨn₅ dsa₂ Diú₄
\p 
\v 33 ’Ma₂nei'₂ bá₄ 'nia'₂ ján₃, 'a₂ lia'₂ lë́₅ ca₂nág₂ dsa₂ can'₅₄ ma₂lɨ́g'₂: “Tsá₃ jmó'₂ jua'₅₄ a₂tsá₃ jme₁ti'₄ jág₁ quiáng'₂ a₂ma₂cuë'₅₄ a₂'ɨ́ng'₅ Te₁gui'₅₄.”
\v 34 La₁ jniá₂ juá'₅ juɨ́g₂ 'nia'₂ tsá₃ 'e₂ 'uɨg₅₄ cha₂ jua'₅₄ a₂'ɨ́ng'₄ Diú₄; tsá₃ 'ë́'₁ guei'₅₄ i₂juɨ́g₃, ia₁ ne₄ta₁ quió'₅ Diú₄ bá₄ jaun₂;
\v 35 on₃ guë'₂ 'ë́'₁ gua'₅₄ 'uë₃, ia₁ co₂'nió'₄ ja₁tióng₂ tag₄ bá₄ Diú₄; on₃ guë'₂ 'nió'₅ 'ë́'₁ 'nia'₂ Jerusalén, ia₁ juɨg₂ quió'₅ Rag₅₄ Juɨn'₂ bá₄ jaun₂.
\v 36 Tsá₃ lë₁'ë₂ 'nia'₂ mɨ₂dsei'₂ guiong'₅₄ në́₃, ia₁ 'i₁ca₂mɨ'₂ nɨ₁jŋi₂ dsei'₂ 'nia'₂ tsá₃ lé₂ le₃jmó'₂ tiog₂, on₃ guë́₄ a₂lia'₂ në́₃.
\v 37 Jua'₅₄ bá₄ 'nia'₂ quian'₅₄ ca₂jon₄ jág₁, “ján₅”, o₃ “jan₂'ón₄” 'e₂, ia₁ në₁jua'₂ 'ein₂ ca₂juá'₂ ŋag₅₄ guë́₄ con'₂ lë́₅ në₅, já₅ ja₁con₂ i₂së₃dsen₃ bá₄ jaun₂.
\s1 Jme₂tag₅ Jesús jág₁ juɨ₁lia'₂ a₂con₂ dsa₂ 'ma'₅₄ ja₁con₂ rɨin'₅₄
\r (Lucas 6:29-30)
\p 
\v 38 ’Ma₂nei'₂ bá₄ 'nia'₂ a₂ma₂juá'₂ dsa₂ le₂jŋiá₅: “Në₁jua'₂ 'ein₂ ca₂'én₂ ca₂mɨ́g₂ mɨ₂ne₄ rɨn'₅₄, le₂jaun₂ bá₄ lé₂ 'éi'₃ dsɨ₃'én₂ ca₂mɨ́g₂ mɨ₂ne₄ juɨ₁lia'₂ i₂ca₂jmo₃ ján₃; o₃ në₁jua'₂ 'ein₂ ca₂tia'₃ ca₂mɨ́g₂ mɨ₂jan₄ rɨn'₅₄ në́₃, le₂jaun₂ bá₄ lé₂ táng₃ 'éi'₃, tiá'₃ ca₂mɨ́g₂ quió'₅.”\f + \fr 5:38 \ft Éxodo 21:24; Levítico 24:20; Deuteronomio 19:21.\f*
\v 39 La₁ jniá₂ guë'₂ juá'₅ juɨ́g₂ 'nia'₂, tsá₃ lë₁nau₂ 'nia'₂ queng'₂ quian'₅₄ dsa₂ 'lɨn'₅₄. Në₁jua'₂ 'ein₂ ca₂quein₃ rë₂jog'₂, jein'₅₄ të₂le₃ ca₂ton₂, juɨ₁quein₂₃ ta₁tɨn₃ ton₂.
\v 40 Chi₂jua'₂ 'ein₂ 'nag₅ quiáng'₂, a₂'nio₃ jŋiá'₂ nɨ₁tsɨ́n'₂, le₂jiog₅ tsɨ₁'mɨ'₂ dsiog₂ qui'₅₄ cuë'₅₄ juɨ₁quion₂.
\v 41 Në₁jua'₂ 'ein₂ ca₂chi₃quióng₂ jmɨg₄ a₂caun'₅₄ lio₅₄ caun₂ kilómetro, o₂con₄ tɨn₃ kilómetros.
\v 42 Juɨ₁'ein₂ guë́₃ mɨ₅ 'e₂ mɨ₅ quiáng'₂ a₂dsi₂, cuë'₅₄; 'a₃ lë₁jein'₅₄ le₃mɨ₂ca'₅₄ quió'₅.
\s1 Jme₁'nió₄ bá₄ 'nia'₂ juɨ₁lia'₂ dsa₂ i₂'iog₅₄ quián'₂ 'nia'₂
\r (Lucas 6:27-28, 32―36)
\p 
\v 43 ’Ján₃ bá₄ ma₂nei'₂ 'nia'₂ a₂ma₂juá'₂ dsa₂ le₂jŋiá₅: “Jme₁'nió₄ a₂mei₅₄ quiáng'₂, jme₁'ŋia₅₄ juɨ₁lia'₂ dsa₂ i₂'iog₅₄.”
\v 44 La₁ jniá₂ guë'₂ juá'₅ juɨ́g₂ 'nia'₂: Jme₁'nió₄ bá₄ 'nia'₂ juɨ₁lia'₂ dsa₂ i₂'iog₅₄, mɨ₄ ne₄ Diú₄ o₄quió'₄ juɨ₁lia'₂ dsa₂ i₂co₂'ein₅.\f + \fr 5:44 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “Jua'₅₄ a₂dse₃ ja₁con₂ juɨ₁lia'₂ dsa₂ i₂juá'₂ uɨg₅, jmo₄ a₂dse₃ ja₁con₂ juɨ₁lia'₂ dsa₂ i₂'iog₅₄.” \f*
\v 45 Jaun₂ le₂në₅ bá₄ a₂rë₂jniá'₁ 'nia'₂ a₂lɨ́ng'₅ chi'₂-guein₂ quián₅ Ŋéi'₅ i₂guá₅ guei'₅₄ i₂juɨ́g₃; ia₁ 'éi₂ bá₄ cuë₅ 'iog₂ cuë́'₅ lia'₂ dsa₂ 'lɨn'₅₄ lia'₂ dsa₂ dsen₃; ján₃ bá₄ chein₁₂ jmɨ́₅ cuë́'₅ lia'₂ dsa₂ i₂cuɨn₅ Diú₄ lia'₂ dsa₂ i₂tsá₃ Diú₄ cuɨn₅ në́₃.
\v 46 Ia₁ në₁jua'₂ 'nió'₃ 'nia'₂ jmá'₃ lia'₂ dsa₂ i₂'nio₃ 'nia'₂, ¿'e₂ 'lian'₅₄ 'nia'₂ guéi'₁ le₂jaun₂? Le₂jiog₅ dsa₂ i₂cán₂ 'lia'₅₄ quián₅ dsɨ₂tan₅₄ tɨn₂ le₂jaun₂.
\v 47 Chi₂jua'₂ cuɨ́n'₅ 'nia'₂ Diú₄ jmá'₃ lia'₂ dsa₂ rɨ́ng'₂, ¿'e₂ a₂ŋag₅₄ guë́₄ a₂dse₃ jmo'₂ 'nia'₂ në₁jua'₂ le₂jaun₂? Ia₁ le₂në₅ bá₄ jmo₅ dsa₂ i₂tsá₃ Diú₄ cuɨn₅ ján₃.
\v 48 Juɨ₁dsi₂can'₅₄ bá₄ 'nia'₂ a₂dsi₁nóg'₅ léng'₂ dsa₂ dsen₃ juɨ₁lia'₂ dsen₃ Ŋéi'₅ 'nia'₂ i₂guá₅ guei'₅₄ i₂juɨ́g₃.
\c 6
\s1 Jme₂tag₅ Jesús jág₁ juɨ₁lia'₂ a₂jmo₅ dsa₂ dse₃
\p 
\v 1 ’Jmo₄ 'nia'₂ 'í₁ tsá₃ lë₁jmo₂ 'nia'₂ a₂lɨ́ng'₅ dsa₂ dsen₃ jŋia'₅₄ lia'₂ jmá'₃ jë₄ jág₃ dsa₂. Në₁jua'₂ le₂në₅ jmo'₂ 'nia'₂, Ŋéi'₅ 'nia'₂ i₂guá₅ guei'₅₄ i₂juɨ́g₃ tsá₃ 'e₂ 'lian'₅₄ 'nia'₂ cuë₃ 'i₁caun₂.
\p 
\v 2 ’'Uɨg₅₄ jaun₂, jë₁ma₂të́₂ rë₁jme₁'on'₁ 'nia'₂ 'ein₂ jme₁'ong'₁ juɨ₁lia'₂ i₂'nió'₅ quió'₅, tsá₃ jmó'₂ jua'₅₄ uɨ́ng₂ ma₂dsɨ₂'ag₅ jág₁ juɨ₁lia'₂ jmo₅ dsa₂ i₂lë₁jmo₅ o₁ne₁ dsi₂néi₂ guá'₅ sinagogas juɨ₁lia'₂ jë₄ calles në́₃. Jmo₂₃ le₂jaun₂ a₂chein'₂ dse₃ guioin₅₄ ia₁jaun₂ 'ag₃ dsa₂ dse₃; la₁ia₁ a₂të₃dsón'₂ juá'₅ jniá₂ i₂ma₂gue₃ 'lian'₅₄ bá₄ i₂le₂'éi₂.
\v 3 La₁ 'ne₂ në́₃, jë₁ma₂të́₂ rë₁jme₁'ong'₁ juɨ₁lia'₂ 'ein₂ jme₁'ong'₁, jmo₄ ca₂lia'₂ jŋia'₅₄ a₂mei₅₄ dsen₃ quiáng'₂ tsá₃ ŋi₅.
\v 4 Ja₂lɨn₃ guë́₄ dse₃ jmó'₂ jë₄ të₃co'₅₄. Jaun₂ Ŋéi'₅ i₂jág₅ a₂dse₃ jmo'₂ jë₄ të₃co'₅₄ jaun₂, cuë₃ 'liang'₅₄.\f + \fr 6:4 \ft Juá'₂ a₂lɨn₅₄ chog₅₄ si₂ le₂la₂ ján₃: “të₃ jɨn₄ juɨn₅ dsa₂.” \f*
\s1 Jme₂tag₅ Jesús 'a₂ lia'₂ chi₃lén'₂ dsa₂ Diú₄
\r (Lucas 11:2-4)
\p 
\v 5 ’Jë₁ma₂të́₂ rë₁chi₁len'₄ 'nia'₂ Diú₄, tsá₃ lë₁jmo₂ 'nia'₂ juɨ₁lia'₂ jmo₅ dsa₂ i₂lë₁jmo₅-dsáu₅ o₁ne₁, a₂të₅ dsɨ́₅ chi₂léin'₂ Diú₄ të₃ tióin₂ dsi₂néi₂ guá'₅ sinagogas jë₄ calles në́₃, ia₁jaun₂ jág₃ dsa₂. A₂dsɨ₂jó'₃ juá'₅ jniá₂, i₂ma₂gue₃ 'lian'₅₄ bá₄ i₂le₂'éi₂.
\v 6 La₁ jë₁ma₂të́₂ rë₁mɨ́'₁ 'ne₂ ne₄ Diú₄, jne₅₄ dsi₂néi₂ quiáng'₂. Ja₁jaun₂ chi₁len'₄ 'ne₂ Diú₄ Ŋéi'₅ i₂tsá₃ jniá₂. Jaun₂ në́₃ Ŋéi'₅ i₂ŋi₅ 'e₂ a₂jmo'₂ jë₄ të₃co'₅₄, cuë₃ 'liang'₅₄.
\p 
\v 7 ’Jë₁ma₂të́₂ rë₁juɨg'₅₄ Diú₄, tsá₃ jmó'₂ 'nia'₂ jua'₅₄ a₂lë₁të₁'ɨ́'₁ jág₁ a₂tsá₃ ta₁ tí₄, juɨ₁lia'₂ jmo₅ dsɨ₂nau₂ i₂tsá₃ 'én₂, ia₁ lɨ́in₂ nag₃ Diú₄ të₂le₃ ia₁ a₂'lióng₂ jág₁ juá'₂.
\v 8 Tsá₃ lë₁o₁len'₅₄ 'nia'₂ juɨ₁lia'₂ lɨ́n₅ dsa₂ le₂'éi₂. Ia₁ i₂ma₂ŋi₅ bá₄ Ŋéi'₅ 'nia'₂ 'e₂ a₂'nió'₅ quián'₂ 'nia'₂ né'₃ guë́₄ a₂mɨ́'₁.
\v 9 Jaun₂ në́₃, le₂la₂ bá₄ juɨg'₅₄ 'nia'₂ Diú₄:
\q1 Tia₅₄ quián₂ jniog₄, 'ne₂ i₂ŋéi'₂ guei'₅₄ i₂juɨ́g₃,
\q2 juɨ₁jme₂go₃ bá₄ dsa₂ a₂rë₂jŋió₄ a₂cheng'₂.
\q1 
\v 10 Juɨ₁le₅₄ bá₄ 'éi'₃ quiáng'₂,
\q1 juɨ₁le₅₄ bá₄ a₂'ŋio₂ 'au'₂ 'ne₂ ne₄ gua'₅₄ 'uë₃,
\q2 juɨ₁lia'₂ lë́₅ guei'₅₄ i₂juɨ́g₃.
\q1 
\v 11 Cuë₄ a₂'nió'₅ que₅₄ jnia'₅₄ jmɨg₄ në₃.
\q1 
\v 12 'Én₃ dso₄ quián₂ jnia'₅₄,
\q2 juɨ₁lia'₂ 'én₅ jnia'₅₄ dsáu₁ rɨn'₅₄.
\q1 
\v 13 'A₃ cuë₂ jmɨg₄ jiá₃ juɨ₅bí₂ a₂cáun₂ táu₂,
\q2 të₂le₃ lio₄ bá₄ o₄gú₃ i₂së₃dsen₃.\f + \fr 6:13 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “lio₄ bá₄ jnia'₅₄ ne₄ a₂'lɨg'₅₄;” a₂siá'₂ juá'₂ bá₄ ján₃: “ia₁ 'ne₂ bá₄ ca₂tɨ́ng'₂ gong'₂, qui₁dsɨ'₂ 'éi'₃, a₂jme₃juag'₂ dsa₂ në́₃, co₂tan₅₄.” \f*
\p 
\v 14 ’Ia₁ në₁jua'₂ 'én'₅ 'nia'₂ dsáu₁ rɨ́ng'₂ jë₁ma₂'náu₂ dso₄ ja₁cong'₂, ján₃ bá₄ le₂jaun₂ Ŋéi'₅ 'nia'₂ i₂guá₅ guei'₅₄ i₂juɨ́g₃ 'éin₂ dsáu'₂ 'nia'₂ guiong'₅₄.
\v 15 La₁ në₁jua'₂ tsá₃ 'éng'₅ dsáu₁ rɨ́ng'₂, ján₃ bá₄ le₂jaun₂ tsá₃ 'én₂ Ŋéi'₅ dsáu'₂ 'nia'₂.
\s1 Jme₂tag₅ Jesús jág₁ juɨ₁lia'₂ a₂jme₂'ɨn₅₄ dsa₂
\p 
\v 16 ’Jë₁ma₂të́₂ rë₁jme₁'ɨn'₄ 'nia'₂, tsá₃ jme₁tsɨ́n₄ 'nia'₂ o₄-ne'₅₄ jua'₅₄ a₂jmó'₂ lë₁'ág₄ 'lia'₂ 'au'₂ juɨ₁lia'₂ jmo₅ dsa₂ i₂lë₁jmo₅-dsáu₅ o₁ne₁. Jmo₅ dsa₂ le₂'éi₂ le₂jaun₂ ia₁jaun₂ jág₃ dsa₂ a₂dsón'₂ bá₄ jme₂'ɨin₅₄. A₂dsɨ₂jó'₃ juá'₅ jniá₂, i₂ma₂gue₃ 'lian'₅₄ bá₄ 'éi₂.
\v 17 La₁ 'ne₂ në́₃, jë₁ma₂të́₂ rë₁jme₁'ɨng'₄, sio₅ rë₂ dsei'₂, rang₂ ne'₅₄ në́₃,
\v 18 ia₁jaun₂ tsá₃ 'ein₂ le₃lí'₄ a₂jme₂'ɨng'₄. Jŋia'₅₄ lia'₂ Ŋéi'₅ i₂tsá₃ jniá₂ bá₄ ŋi₅. Jaun₂ Ŋéi'₅ i₂jág₅ ca₂le₃jë́₃ a₂jmo'₂ jë₄ të₃co'₅₄ jaun₂, 'éi₂ bá₄ cuë₃ 'liang'₅₄.
\s1 Juɨ₁lia'₂ a₂quen₅ lɨn₃ a₂rë₂'ma₄ guei'₅₄ i₂juɨ́g₃
\r (Lucas 12:33-34)
\p 
\v 19 ’Tsá₃ lë₁dsia₂ 'nia'₂ lo'₂ le₁má'₂ a₂jmo'₂ 'nia'₂ a₂quen₅ lɨn₃ quiáng'₂ ne₄ gua'₅₄ 'uë₃ la₂, ia₁ ja₁lá₃ ja₁lë₁qui₂rë₂juɨ₁ tón'₅ i₁cá₁ qui₂'éin₂, ján₃ bá₄ ja₁lá₃ ja₁qui₂dsɨ₂'én₂ qui₂rë₃'áu₁ cosas në́₃; ja₁lá₃ bá₄ chan₂ dsa₂ qui₂juɨin₂₃ 'e₂ qui₂juɨin₂₃ a₂tóin'₅ 'ang₂₃.
\v 20 Guei'₅₄ i₂juɨ́g₃ bá₄ 'nió'₅ dsiá'₁ 'nia'₂ lo'₂ quiáng'₂, ja₁tsá₃ 'e₂ lé₂ jua'₅₄ a₂qui₃'én₂ cá₁, on₃ guë'₂ 'e₂ rë₂'áu₁, on₃ guë́₄ lé₂ dsɨ₃ton'₅₄ 'ang₂.
\v 21 Ia₁ juɨ₁lia'₂ jë₁tio'₅₄ a₂quen₅ quiáng'₂, ja₁jaun₂ bá₄ 'i₄ a₂'ɨ₅ 'au'₂.
\s1 Juɨ₁lia'₂ jme₁ne₁ dsa₂
\r (Lucas 11:34-36)
\p 
\v 22 ’Lë́₅ jme₁ne₁ dsa₂ juɨ₁lia'₂ lë́₅ caun₂ si₂ nɨ₁tsɨ́₅ quió'₅ nɨ₁ŋɨ₁ dsa₂; 'uɨg₅₄ jaun₂ në́₃, në₁jua'₂ dse₃ jme₁ne'₁, ján₃ bá₄ le₂jaun₂ co₂'nió'₄ tág₅ bá₄ si₂ ta₁jang'₂;
\v 23 la₁ në₁jua'₂ tsá₃ dse₃ jme₁ne'₁, ta₁jang'₂ bá₄ lë́₅ qui₁né'₃. Në₁jua'₂ si₂ quiáng'₂ në́₃, chí'₅ chi₁liá'₃, ¡'e₂ guë́₄ 'ŋio₅ juë'₂ lë́₅ qui₁né'₃ në₁jua'₂ le₂jaun₂!
\s1 Juɨ₁lia'₂ a₂'nio₃ dsa₂ Diú₄, a₂'ɨ́n₅ guë'₂ dsɨ́₅ cu₄ në́₃
\r (Lucas 16:13)
\p 
\v 24 ’'I₁jan₂ tsá₃ 'ein₂ lé₂ jme₃ti₃ ta₁ ne₄ on₃ juɨg₅₄; ia₁ jme₃'ŋiai₅₄ jan₂, i₂jan₂ guë'₂ jme₃'nioi₃. O₃ náu₃ tiá₂ quian'₅₄ jan₂, i₂jan₂ guë'₂ tsá₃ le₃jein₅₄. Tsá₃ 'ein₂ lé₂ jme₃ti₃ ne₄ Diú₄, le₂jiog₅ ne₄ a₂'ɨ́n₅ dsɨ́₅ cu₄ në́₃.
\s1 Jmo₅ Diú₄ 'í₁ chi'₂-guein₂ quiáin₅
\r (Lucas 12:22-31)
\p 
\v 25 ’Jaun₂ në́₃ juɨ́g₂ jniá₂ 'nia'₂: Tsá₃ lë₁can₂ 'nia'₂ o₂i₁ dsɨ₅ jua'₅₄ a₂ŋɨ́₄ 'ɨ₅ 'au'₂ 'e₂ quë'₅₄, o₃ 'e₂ 'ag'₅₄ të₁lia'₂ chang'₂, on₃ guë'₂ o₄quió'₄ nɨ₁ŋɨ'₁ 'nia'₂, 'e₂ 'mɨ'₂ a₂quɨ'₅₄. ¿Tsa₁ quen₅ guë́₄ jme₂dsí₂ a₂chan₂ dsa₂ lia'₂ con'₂ guë́₄ má₃?
\v 26 Jɨn₄ de'₂ 'nia'₂ juɨ₁lia'₂ i₁tan₅ i₂i₂nio₄ guei'₅₄: tsá₃ 'e₂ jne₂₃, on₃ guë'₂ 'e₂ cág'₅, jua'₅₄ a₂dsia₂₃ lo'₂; la₁ Ŋéi'₅ 'nia'₂ i₂guá₅ guei'₅₄ i₂juɨ́g₃ qui₂jme₂tau₅₄. Jaun₂ në́₃, ¿Tsa₁ quen'₅ guë́₄ 'nia'₂ lia'₂ con'₂ guë́₄ já'₂ 'éi₂?
\v 27 ¿'Ein₂ 'nia'₂, të₂le₃ ia₁ a₂ŋɨ́₄ 'ɨ₅ 'au'₂, lé₂ le₃jmó'₂ 'nia'₂ a₂lé₂ le₃chang'₂ caun₂ hora ŋag₅₄ guë́₄?\f + \fr 6:27 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “a₂lé₂ le₃i₃con'₅₄ 'nia'₂ caun₂ lë₂.” \f*
\p 
\v 28 ’¿'E₂ 'uɨg₅₄ a₂ŋɨ́₄ lë₃ 'ɨ₅ 'au'₂ 'nia'₂ juɨ₁lia'₂ o₄quió'₄ 'mɨ'₂ a₂quɨ'₅₄? Jag₄ de'₂ 'nia'₂ juɨ₁lia'₂ 'a₂ lia'₂ dsɨ₂cón₃ lí₁ a₂cha₂ ja₁nau₂; on₃jua'₅₄ i₂jmo₅ ta₁ 'ua'₂, on₃ guë'₂ 'me₂₃;
\v 29 la₁ juɨ́g₂ jniá₂ 'nia'₂, ca₂lia'₂ jŋia'₅₄ Rag₅₄ Salomón lia'₂ con'₂ jme₁quɨ́'₅ tsɨn'₅₄ a₂jlá'₁ guë́₄, tsá₃ ca₂rë₃jláin'₁ juɨ₁lia'₂ jlá'₁ lí₁.
\v 30 Jaun₂ në́₃, chi₂jua'₂ Diú₄ le₂në₅ jmo₂₃ jlá'₁ nau₂ a₂cha₂ jmɨg₄ në₃, la₁ 'ióg₃ guë'₂ dsɨ₃'én₂ dsi₂si₂, ¡'ë₂ guë́₄ bá₄ 'nia'₂ dsa₂ tsá₃ lɨn₄ 'én₂ jmo₃ 'í₁ qui₃chein'₃ 'nia'₂ dse₃!
\v 31 Jaun₂ le₂në₅, tsá₃ lë₁can₂ 'nia'₂ o₂i₁ dsɨ₅, jua'₅₄ a₂qui₁ŋag'₅₄ 'nia'₂: “¿'E₂ que₅₄ jniog₄?” o₃ “¿'E₂ 'ne'₅₄ jniog₄?” o₃ “¿'E₂ 'mɨ'₂ qui'₅₄ jniog₄?”
\v 32 Ia₁ dsa₂ mɨ₂güɨ́g₃ bá₄ i₂nio₄ qui₂'en₅ 'ɨ́n₅ dsɨ́₅ ca₂le₃jë́₃ a₂në₅. I₂ŋi₅ bá₄ Ŋéi'₅ 'nia'₂ i₂guá₅ guei'₅₄, a₂'nió'₅ quián'₂ 'nia'₂ le₃jë́₃ a₂në₅.
\v 33 La₁ jmo₄ de'₂ jŋiá₅ 'nia'₂ 'ɨ́n₅ 'au'₂ a₂jiá₃ 'éi'₃ quió'₅ Diú₄ ja₁cong'₂, quian'₅₄ a₂jmó'₂ 'nia'₂ ca₂le₃jë́₃ a₂dse₃ a₂të₅ dsɨ́₅ 'éi₂, jaun₂ guë́₄ guéi'₁ 'nia'₂ le₃jë́₃ a₂në₅ a₂ŋag₅₄ guë́₄.
\v 34 Tsá₃ lë₁can₂ 'nia'₂ o₂i₁ dsɨ₅ jaun₂, o₄quió'₄ jmɨg₄ 'ióg₃, ia₁ jma₃quén₅ o₂i₁ dsɨ₅ cha₂ bá₄ lia'₂ co₂jmɨg₄ lia'₂ co₂jmɨg₄.
\c 7
\s1 Tsá₃ lë₁cáun₂ 'nia'₂ 'í₁ quió'₅ i₂sián'₂
\r (Lucas 6:37-38, 41―42)
\p 
\v 1 ’Tsá₃ lë₁cáun₂ 'nia'₂ 'í₁ quió'₅ rɨ́ng'₂, ia₁jaun₂ tsá₃ con₂ Diú₄ 'í₁ ja₁con'₂ 'nia'₂ guiong'₅₄.
\v 2 Ia₁ le₂në₅ bá₄ con₂ Diú₄ 'í₁ ja₁con'₂ 'nia'₂ guiong'₅₄ juɨ₁lia'₂ cáun'₂ 'nia'₂ 'í₁ ja₁con₂ rɨ́ng'₂. Quian'₅₄ 'éi'₃ a₂dsia'₂ 'nia'₂, 'éi'₃ jaun₂ bá₄ dsiog₃ Diú₄ quián'₂ 'nia'₂ guiong'₅₄.
\p 
\v 3 ’¿'A₂ lia'₂ jniag'₃ 'ne₂ jag'₅₄ jme₁qui₅ pí'₁ a₂'i₄ jme₁ne₁ rɨ́ng'₂, ton'₂ tsá₃ leng'₅₄ guë'₂ a₂'i₄ ca₂'nau₅₄ nɨ₁chá₅ pa₁ jme₁ne'₁ 'ŋiag'₂?
\v 4 ¿O₃ 'a₂ lia'₂ lé₂ le₃juɨg'₅₄ rɨ́ng'₂: “Cuë₄ jmɨg₄ dsi₄ jniá₂ jme₁qui₅ pí'₁ a₂'i₄ jme₁ne'₁,” ton'₂ në₅ bá₄ chi₁'i₁ ca₂'nau₅₄ nɨ₁'ma₂ chá₅ jme₁ne'₁ 'ŋiag'₂?
\v 5 ¡'Ne₂ dsa₂ i₂lë₁jmo₅ o₁ne₁! Dsi₄ de'₂ jŋiá₅ nɨ₁'ma₂ chá₅ mɨ₂ne'₅₄ 'ŋiag'₂, jaun₂ guë́₄ lé₂ le₃jag'₅₄ rë₂, jaun₂ guë́₄ lé₂ dsí'₁ qui₅ pí'₁ jme₁ne₁ rɨ́ng'₂.
\p 
\v 6 ’Tsá₃ cuë'₂ 'nia'₂ juɨ₁lia'₂ dsɨ₂jɨ'₅₄ a₂lë́₅ a₂jŋió₅ quió'₅ jme₂dsí₂, ia₁ con'₂ tsá₃ ŋó₅ në₁jua'₂ ja₂dsɨ́in₂ a₂jmo₃ le₁juɨg₁ quiáng'₂. Ján₃ bá₄ tsá₃ dsia₂ 'nia'₂ juɨ₁lia'₂ mɨ́g₂ jlá'₁ a₂quen₅ quiáng'₂ ne₄ i₁ŋí₅, con'₂ tsá₃ ŋó₅ në₁jua'₂ qui₂ca₂tsó'₃, jme₃'ióg₃.
\s1 Juɨ₁lia'₂ dsa₂ i₂mɨ₅, i₂'no'₂, i₂të́₂ në́₃.
\r (Lucas 11:9-13; 6:31)
\p 
\v 7 ’Mɨ₄ 'nia'₂ ne₄ Diú₄, jaun₂ guéi'₁ 'nia'₂; 'nio'₂ 'nia'₂, jaun₂ bá₄ dsiang'₂; té₃ 'nia'₂ o₄'né₄, jaun₂ bá₄ niá₂.
\v 8 Ia₁ juɨ₁lia'₂ i₂mɨ₅, gue₃ bá₄; juɨ₁lia'₂ i₂'no'₂, dsio'₂ bá₄ ján₃; ján₃ bá₄ le₂jaun₂, quió'₅ juɨ₁lia'₂ i₂të́₂ o₄'né₄, niá₂ bá₄.
\p 
\v 9 ’¿O₃ chan₂ juɨ₁lia'₂ 'ein₂ 'nia'₂, jme₁mɨ₅ chi'₂ quiáng'₂ i₁ŋí'₄, cuë'₂ 'nia'₂ ca₂mɨ́g₂ nɨ₁cang₁?
\v 10 ¿O₃ chan'₂ 'nia'₂ jë₁ma₂ca₂mɨ₃ chi'₂ quiáng'₂ quió'₅ ju₄, cuɨ́in'₄ 'nia'₂ dsɨ₂mɨ'₂?
\v 11 Jaun₂ në́₃, chi₂jua'₂ 'nia'₂ dsa₂ i₂rë₂cán'₄ dso₄ tɨng'₂ cuë'₂ cosa dse₃ chi'₂-guein₂ quiáng'₂, ¡'ë₂ guë́₄ bá₄ Ŋéi'₅ 'nia'₂ i₂guá₅ guei'₅₄ cuë₃ a₂dse₃ cuë́'₃ juɨ₁lia'₂ i₂mɨ₅ ja₁coin₂!
\p 
\v 12 ’'Uɨg₅₄ jaun₂ në́₃, jmo₄ bá₄ 'nia'₂ quian'₅₄ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂ juɨ₁lia'₂ 'e₂ a₂'niog'₂ 'nia'₂ jmo₃ 'éi₂ quian'₅₄ 'nia'₂; ia₁ a₂në₅ bá₄ ta₁ quí'₅ ca₂le₃jë́₃ Si₂ 'Éi'₃, quian'₅₄ guë́₄ Si₂ a₂qui₂ca₂jmo₃ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄.
\s1 O₄juɨ₅ dsag₂
\r (Lucas 13:24)
\p 
\v 13 ’Tión'₂ 'nia'₂ të₂le₃ o₄juɨ₅ dsag₂. Ia₁ a₂'ɨ́₂ juë'₂ bá₄ ja₁dsɨ₂ton'₅₄ dsa₂ juɨ₅ a₂jiog₅ ja₁dsɨ₃'éin₂. Ja₂lɨn₃ guë́₄ juɨn₅ dsa₂ i₂dsɨ₂ton'₅₄ juɨ₅ jaun₂;
\v 14 ia₁ caun₂ o₄juɨ₅ dsag₂ rë₂quɨ́'₅ bá₄ ja₁i₂nio₄ dsa₂ a₂dsi₁lein₅ ja₁le₃chan₂ jme₂dsí₂, jaun₂ tsá₃ lɨn₄ juɨn₅ i₂dso'₂ juɨ₅ jaun₂.
\s1 Të₂le₃ quian'₅₄ mɨ́g₂ a₂'ag₅ bá₄ nɨ₁'ma₂, jáng'₅ léi₄
\r (Lucas 6:43-44)
\p 
\v 15 ’Jmo₄ 'nia'₂ 'í₁ jaun₂ tsá₃ jme₃gau₅ dsa₂ i₂i₂nio₄ 'ë́₂ jág₁ a₂juɨ₁gain₂, i₂ja₂lén₂ ja₁con'₂ 'nia'₂ qui₂rë₂lɨin₅₄ a₂lɨ́in₅ já'₂ cha'₂, la₁ të₂le₃ né'₃ të₂dsɨ́₅ lɨ́in₅ juɨ₁lia'₂ lɨ́n₅ dsɨ₂jɨ'₅₄ náu₂ tsau₂ dsɨ́₅.
\v 16 La₁ të₂le₃ 'a₂ lia'₂ jmo₅-dsáu₅ bá₄ le₃cuɨin'₂ 'nia'₂; ia₁ tsá₃ guei'₅₄ chi₁uɨ́ng₃ taun₅ quɨn₅ dsa₂ juɨ₁lia'₂ mɨ́g₂ uvas. On₃ guë'₂ lé₂ le₃quɨn₃ dsa₂ mɨ́g₂ higos guei'₅₄ 'ma₂ taun₅ jmɨ'₅₄.
\v 17 Jaun₂ në́₃, ca₂le₃jë́₃ 'ma₂ dse₃, mɨ́g₂ dse₃ bá₄ 'ag₅; ján₃ bá₄ le₂jaun₂ juɨ₁lia'₂ nɨ₁'ma₂ 'lɨg'₅₄, mɨ́g₂ 'lɨg'₅₄ bá₄ 'ag₅.
\v 18 Juɨ₁lia'₂ nɨ₁'ma₂ dse₃, tsá₃ lé₂ le₃'ag₃ mɨ́g₂ 'lɨg'₅₄; ján₃ guë'₂ le₂jaun₂ tsá₃ lé₂ le₃'ag₃ mɨ́g₂ dse₃ juɨ₁lia'₂ nɨ₁'ma₂ 'lɨg'₅₄.
\v 19 Ca₂le₃jë́₃ nɨ₁'ma₂ a₂tsá₃ 'ag₅ mɨ́g₂ dse₃, jŋia'₅₄ lia'₂ a₂uɨ́n'₂ bá₄, dsɨ'₂ dsi₂si₂.
\v 20 Jaun₂ le₂në₅ bá₄ le₃cuɨin'₂ 'nia'₂: të₂le₃ 'a₂ lia'₂ lë́₅ jmo₂₃.
\s1 Tsá₃ ca₂le₃jɨ́n₃ tɨ́n'₄ ja₁gon₂ Diú₄.
\r (Lucas 13:25-27)
\p 
\v 21 ’Tsá₃ ca₂le₃jɨ́n₃ i₂të́₂ jniá₂: “Te₁gui'₅₄, Te₁gui'₅₄,” dsi₁lein₅ guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄; jŋia'₅₄ lia'₂ jmá'₃ i₂jmo₅ a₂'ŋio₂ dsɨ́₅ Ŋe'₃ i₂guá₅ guei'₅₄ bá₄ dsi₁len₅.
\v 22 Juɨn₅ dsa₂ lé₂ jmɨg₄ jaun₂ i₂juá'₂ tság₃ jniá₂: “Te₁gui'₅₄, Te₁gui'₅₄, ma₂qui₂ca₂'ë́₄ jnia'₅₄ jág₁ o₄quián'₂ 'ne₂. Quian'₅₄ bí₂ 'éi'₃ quiáng'₂ në́₃, ma₂qui₂ma₂'uɨn'₅₄ jnia'₅₄ je₂na'₅₄, ma₂qui₂ma₂jmó₁ jnia'₅₄ 'lióng₂ léi₄ juë'₂ në́₃.”
\v 23 La₁ jaun₂ guë́₄ në́₃ juɨg₅₄ jniá₂: “O₁lɨ́g'₂ tsá₃ 'nia'₂ ca₂rë₃cuɨ́ng₅. Cau₅ jŋia'₃ 'nia'₂ i₂jmo'₂ a₂'lɨg'₅₄.”
\s1 Ta₁tɨn₃ ne₅₄ 'uɨg₅₄
\r (Marcos 1:22; Lucas 6:47-49)
\p 
\v 24 ’Jaun₂ në́₃, ca₂le₃jɨ́n₃ juɨ₁lia'₂ dsa₂ i₂nag₅ jág₁ quió₃, jmo₂₃ a₂juɨ́g₂ jniá₂, lɨ́in₅ juɨ₁lia'₂ lɨ́n₅ jan₂ dsa₂ i₂ŋɨ́'₂ dsɨ́₅ i₂ca₂jmóg'₃ 'ne₄ ne₄ 'lau₂.
\v 25 Ca₂já₃ jmɨ́₅, qui₂ca₂juë'₂ jmɨg₂ cuá₃, ca₂'ág₂ dsí₂ tiá₂ lɨn₃ ca₂jnáu₃ 'né₅ jaun₂; la₁ tsá₃ ca₂quɨ'₃, ia₁ jme₁chí'₄ bá₄ 'uɨg₅₄ ne₄ 'lau₂.
\v 26 La₁ ca₂le₃jɨ́n₃ juɨ₁lia'₂ dsa₂ i₂nag₅ jág₁ quió₃, tsá₃ jmo₂₃ guë'₂ a₂juɨ́g₂ jniá₂, lɨ́in₅ juɨ₁lia'₂ lɨ́n₅ jan₂ dsa₂ co₄ i₂tsá₃ 'en₅₄ dsɨ́₅, ca₂chi'₃ 'né₅ quió'₅ ne₄ ti₁tsag₁.
\v 27 Jme₁ca₂já₃ jmɨ́₅, ca₂juë'₂ jmɨg₂ cuá₃, ca₂'ág₂ dsí₂ tiá₂ ca₂jnáu₃ dso'₂ tsɨ₁'né₅ jaun₂; jaun₂ ca₂quɨ'₃ ca₂gon₃ gau₂ lɨn₃.
\p 
\v 28 Jme₁ca₂lë₃ juá'₂ Jesús jág₁ le₂në₅, 'ŋio₅ lɨn₃ qui₂dsɨ₂gó'₃ dsɨ́₅ dsa₂ 'a₂ lia'₂ lë́₅ jág₁ a₂jme₂tag₂₃,
\v 29 ia₁ jme₂tag₂₃ juɨ₁lia'₂ jan₂ i₂quian₅ 'éi'₃ dsón'₂, on₃jua'₅₄ rë'₂ lia'₂ të₅juá'₅ quiáin₅.
\c 8
\s1 Ca₂jme₃'lión₂ Jesús jan₂ dsa₂ i₂lɨ́n₅ 'mé'₅ 'iog₅
\r (Marcos 1:40; Lucas 5:12-16)
\p 
\v 1 Jme₁ca₂sión₃ Jesús má'₂, juɨn₅ lɨn₃ dsa₂ jme₂quiong'₅₄.
\v 2 Jaun₂ ca₂jme₃quián₃ jan₂ dsa₂ dso'₅₄ i₂lɨ́n₅ 'mé'₅ 'iog₅, ca₂chi₃jné₃ ne₄ Jesús, jaun₂ ca₂juá'₂:
\p ―Chi₂jua'₂ 'niog'₂ 'ne₂, Te₁gui'₅₄, lé₂ bá₄ jme₁'lio'₅₄ jniá₂.
\p 
\v 3 Jaun₂ Jesús në́₃ ca₂néi'₃ gu₂, ca₂jŋa'₃ quió'₅ dsa₂ 'éi₂, jaun₂ ca₂juá'₂:
\p ―'Nio₃ bá₄ jniá₂. Jme₁'liong₅₄ 'ne₂.
\p Dsɨ₂juɨ₅ jme₁ca₂juá'₂ le₂në₅, ca₂'lón₂ dsa₂ 'éi₂ 'mé'₅ 'iog₅ a₂jme₁lɨ́in₄.
\v 4 Jaun₂ ca₂juá'₂ Jesús:
\p ―Në₃ jaun₂, tsá₃ lë₁'ein₂ juɨg'₂ 'i₁jan₂; jŋia'₅₄ lia'₂ guan'₂ o₂jme₁jnia₅ ne₄ jme₂dsa₂, jaun₂ o₂jen'₅₄ a₂'nió'₅ jme₁ti'₄ con'₂ lë́₅ 'Éi'₃ quió'₅ Moisés, ia₁jaun₂ le₃ŋi₅ dsa₂ a₂ma₂le₁jɨ́ng'₃.\f + \fr 8:4 \ft 'Í₂ Levítico 14.\f*
\s1 'A₂ lia'₂ jme₁'én₂ jan₂ juɨg₅₄ 'lióg₂ romano
\r (Lucas 7:1-10)
\p 
\v 5 Jme₁ca₂'í₃ Jesús jë₄ juɨg₂ Capernaum, ca₂jme₃quián₃ jan₂ juɨg₅₄ 'lióg₂ romano coin₂, jaun₂ ca₂mɨ₃ a₂jme₃'o₅₄ 'éi₂, ca₂juá'₂:
\p 
\v 6 ―Te₁gui'₅₄, jan₂ dsó₂ i₂jme₂ti₃ ta₁ ne₃, ron₅ dso'₅₄ ŋág₅ uɨg₅ ja₁quió₃; a₂'ua'₂ quió'₅, tsá₃ lé₂ jë́'₂ gu₂-tag₅₄.
\v 7 Jaun₂ ca₂juá'₂ Jesús:
\p ―Nei₅₄ bá₄ jniá₂ i₁jme₁'lioin₁₂.
\p 
\v 8 Jaun₂ ca₂ŋag₃ juɨg₅₄ 'lióg₂:
\p ―Te₁gui'₅₄, tsá₃ ca₂tɨ́n₂ jniá₂ jua'₅₄ o₁'ú'₃ 'ne₂ dsi₂néi₂ quió₃; jŋia'₅₄ lia'₂ a₂jme₁jmó'₂ 'éi'₃ bá₄, jaun₂ 'lión₂ dsa₂ 'éi₂ quiáng₃.
\v 9 Ia₁ le₂në₅ bá₄ jniá₂ 'ŋió₃, chéng'₅ a₂jme₂ti₅₄ 'éi'₃ quió'₅ juɨg₃, ján₃ bá₄ le₂në₅ te₁neg'₅₄ 'lióg₂ i₂niog₅ gu₃, 'e₂ caun₂ 'nio₃ jniá₂ lé₂. Në₁jua'₂ ca₂juɨ́g₂ jniá₂: “Gua₂ jó₄”, ja₁jaun₂ dsó₃ bá₄; në₁jua'₂ ca₂juɨ́g₂ jniá₂ i₂sián'₂ guë'₂ táng₃: “Ŋia₅”, jiá₃ bá₄. Në₁jua'₂ ca₂juɨ́g₂ jniá₂ dsa₂ sián'₂ quiáng₃: “O₂jmo₄ a₂la₂ a₂ó₃”, a₂jaun₂ dsɨ₃jmó₂ bá₄.
\p 
\v 10 Jme₁ca₂nág₂ Jesús a₂juá'₂ dsa₂ 'éi₂, ca₂i₃gó'₃ dsɨ́₅, jaun₂ ca₂tsɨ́'₃ dsa₂ i₂jme₁quiain'₅₄:
\p ―A₂dsɨ₂jó'₃ juá'₅ jniá₂ juɨ́g₂ 'nia'₂, ca₂lia'₂ 'i₁jan₂ dsa₂ juɨg₂ Israel, tsá₃ i₂ma₂jɨn₄ jniá₂ i₂'én₂ guë́₄ lɨn₃ lia'₂ 'én₂ dsa₂ la₂.
\v 11 Jniá₂ juɨ́g₂ 'nia'₂, juɨn₅ dsa₂ i₂qui₂ja₃lén₂ ca₂le₂con₂ gua'₅₄ 'uë₃, a₂tiain'₃ co₂lë₅ guë́'₃ quian'₅₄ Abraham, quian'₅₄ Isaac, Jacob në́₃ ja₁gon₂ Diú₄ guei'₅₄ i₂juɨ́g₃;
\v 12 la₁ dsa₂ i₂jme₁ca₂tɨ́n₂ tón'₃ ja₁gon₂ Diú₄, dsɨ₃toin'₅₄ jë₄ qui₁né'₃ uɨ́ng₂, qui₂dsɨ₃'áu₃, quɨ́g'₃ jan₅₄.
\p 
\v 13 Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ juɨg₅₄ 'lióg₂:
\p ―Guan'₂ dsi₂néi₂ quiáng'₂. Lé₂ bá₄ con'₂ lë́₅ 'éng'₂.
\p Dsón'₂ rë'₂ hora jaun₂ ca₂'lón₂ dsó₂ mozo quián₅ dsa₂ 'éi₂.
\s1 Ca₂jme₃'lión₂ Jesús ma₂chog₅₄ Pe₄.
\r (Marcos 1:29-31; Lucas 4:38-39)
\p 
\v 14 Co₂ráun₂ ŋó₃ Jesús ja₁quió'₄ Pe₄. Ja₁jaun₂ jme₁rë₂quian₅ ma₂chog₅₄ Pe₄ a₂dso'₅₄ 'i₄ dséi₂.
\v 15 Jaun₂ ca₂jŋa'₃ Jesús gu₂ dsa₂ dso'₅₄, jaun₂ dsɨ₂juɨ₅ le₂jaun₂ bá₄ ca₂o₃'ág₃ dséi₂. Jaun₂ ca₂nau₂ ma₂chog₅₄ Pe₄ ca₂jme₃lióg₃ ca₂jme₃ti₃ ta₁ ne₄ mesa, a₂ag'₃.
\s1 Ca₂jme₃'lión₂ Jesús juɨn₅ lɨn₃ dsa₂ dso'₅₄
\r (Marcos 1:32-34; Lucas 4:40-41)
\p 
\v 16 Le₃ca₂nei₂ jaun₂, juɨn₅ lɨn₃ dsa₂ i₂jiog₅ jme₂dsí₂ je₂na'₅₄, ca₂o₃jŋia₃ dsa₂ ne₄ Jesús; jaun₂ quian'₅₄ ca₂jon₄ jág₁ bá₄ ca₂'uɨ́in'₂ jme₂dsí₂ 'lɨn'₅₄. Jaun₂ ca₂jme₃'lióin₂ ján₃ ca₂le₃jɨ́n₃ dsa₂ dso'₅₄.
\v 17 Le₂në₅ bá₄ ca₂rë₃ti₃ jág₁ quió'₅ Isaías i₂jme₁'ë́₂ jág₁ o₄quió'₄ Diú₄ jme₁ca₂juá'₂:
\q1 'Éi₂ bá₄ ca₂jŋiá'₂ a₂jme₁'uau₅₄ jniog₄,
\q2 'éi₂ bá₄ ca₂can₃ guei₂ jmɨ₁uɨg₅ quián₂ jniog₄.\f + \fr 8:17 \ft Isaías 53:4.\f*
\s1 Dsa₂ i₂jme₁'nio₃ jme₃quian'₅₄ Jesús
\r (Lucas 9:57-62)
\p 
\v 18 Jme₁ca₂jág₃ Jesús juɨn₅ lɨn₃ dsa₂ le₁lio₃, jaun₂ ca₂jmo₃ 'éi'₃ a₂ŋɨ́₃ dsa₂ quiáin₅ të₂le₃ 'ŋo'₅₄ jmɨ₁ŋí'₄.
\v 19 Jaun₂ ca₂jme₃quián₃ jan₂ të₅juá'₅ coin₂, jaun₂ ca₂juá'₂:
\p ―Të₅, nei₅₄ jniá₂ quian'₅₄ 'ne₂ ca₂le₂con₂ ja₁gog'₅₄.
\p 
\v 20 Jaun₂ ca₂ŋag₃ Jesús:
\p ―I₂cha₂ të₂'lau₂ quió'₅ bá₄ juɨ₁lia'₂ i₁güɨ₅, ján₃ bá₄ le₂jaun₂ juɨ₁lia'₂ i₁tan₅ i₂'ɨn₅ guei'₅₄, i₂tio'₅₄ tsag₄ bá₄ 'éi₂. La₁ Jaun₅ dsa₂ mɨ₂güɨ́g₃ në́₃, tsá₃ ja₁cha₂ jua'₅₄ ja₁quióg₃ ca₂tiá₂.
\p 
\v 21 Jan₂ guë'₂ i₂sián'₂ i₂jme₁ma₂ŋó₅ quiong'₅₄ ca₂juá'₂:
\p ―Te₁gui'₅₄, ¿tsa₁ cuë́'₁ jmɨg₄ a₂nég'₄ i₁'ong₃ de'₂ jŋiá₅ ŋe'₃?
\p 
\v 22 La₁ ca₂ŋag₃ Jesús:
\p ―'Éin₃ 'ne₂ jniá₂, juɨ₁dsi₂'ón₃ bá₄ 'lag₄, 'lag₄ rɨin'₅₄.
\s1 Ca₂jmo₃ Jesús ca₂'ág₂ tei₄ jmɨ₁ŋí'₄, ca₂jŋia'₃ dsí₂ në́₃
\r (Marcos 4:35-41; Lucas 8:22-25)
\p 
\v 23 Jaun₂ në́₃, ca₂'í₃ Jesús 'ŋió'₃ tsɨ₁mu₅, quian'₅₄ dsa₂ i₂ma₂quiain'₅₄.
\v 24 Jme₁ma₂tioin'₅₄ ne₄ jmɨg₂, ca₂'ág₂ dsí₂ tiá₂ lɨn₃ con'₂ tsá₃ jáin₅. Ca₂lia'₂ ma₂dsɨ₂jein₃ jmɨg₂ 'ŋió'₃ tsɨ₁mu₅. La₁ jme₁rë₂güɨ́n₃ bá₄ Jesús ŋó₅.
\v 25 Jaun₂ ca₂i₁ŋei₅₄ bá₄ dsa₂ quiáin₅, jaun₂ ca₂juá'₂:
\p ―¡Te₁gui'₅₄, lio₄! ¡Ia₁ dsɨ₃'éin₂ jnia'₅₄\f + \fr 8:25 \ft o₃, “jniog₄.” \f* ja₁lá₃!
\p 
\v 26 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿'E₂ lë₃ ŋɨ́₄ lë₃ gan'₃ 'nia'₂ dsa₂ i₂tsá₃ lɨn₄ 'én₂?
\p Jaun₂ ca₂nau₂ ca₂jéin₂ dsí₂, jmɨ₁ŋí'₄ në́₃, jaun₂ co₂ŋei'₅₄ ca₂të₁tsɨ'₅₄ táng₃ tei₄.
\v 27 Jaun₂ ca₂i₃gó'₃ dsɨ́₅ dsa₂, qui₂ca₂ŋɨ́i'₃ rɨin'₅₄:
\p ―¿I₂'ein₂ bá₄ dsa₂ në₅, le₂jiog₅ dsí₂ le₂jiog₅ jmɨ₁ŋí'₄ nag₅ gau₂ jág₁ quió'₅?
\s1 Dsa₂ i₂chan₂ Gadara i₂jme₁tion'₅₄ je₂na'₅₄ të₂dsɨ́₅
\r (Marcos 5:1-20; Lucas 8:26-39)
\p 
\v 28 Jme₂ca₂dsióg₃ Jesús le₃ca₂ton₂ jmɨ₁ŋí'₄, të₂le₃ 'uë₃ Gadara,\f + \fr 8:28 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “Gerasa”; a₂siá'₂ guë'₂ në́₃, juá'₂: “Gergesa.” \f* jaun₂ ca₂'uɨn₂ on₃ dsa₂ jë₄ le₁'on₅ 'lag₄, jaun₂ ca₂jme₃quiáin₃ con₂ Jesús. Le₃on₃ dsa₂ 'éi₂ jme₁jiog₅ je₂na'₅₄, jaun₂ 'ŋio₅ lɨn₃ jme₁tsau₂ dsɨ́₅, 'i₁jan₂ dsa₂ tsá₃ 'ein₂ lé₂ le₃ŋɨ́₃ juɨ₅ jaun₂.
\v 29 Jaun₂ ca₂tóin'₂ co₂mɨ'₅₄ ca₂juá'₂ tiá₂:
\p ―¿'E₂ 'uɨg₅₄ tián'₅ 'ne₂ jë₄ quian'₅₄ jnia'₅₄, Jesús Ja₁ŋi'₅₄ Diú₄? ¿A₂ŋe'₃ 'ne₂ ja₁lá₃ a₂jmog'₅₄ jnia'₅₄ të₃jŋiá₅?
\p 
\v 30 Me'₂ cau₅ jaun₂, jme₁tion'₅₄ juɨn₅ i₁ŋí₅ guë́'₅;
\v 31 jaun₂ qui₂ca₂mɨ₃ je₂na'₅₄ ne₄ Jesús, ca₂juá'₂:
\p ―Chi₂jua'₂ 'uag'₅₄ jnia'₅₄ ja₁lá₃, chei₅ jnia'₅₄ dsi₁tió'₄ quió'₅ i₁ŋí₅ 'o₃.
\p 
\v 32 Jaun₂ ca₂juá'₂ Jesús:
\p ―O₂nó'₅ 'nia'₂.
\p Jaun₂ ca₂'uɨn₂ jme₂dsí₂ 'lɨn'₅₄ të₂dsɨ́₅ dsa₂ 'éi₂, jaun₂ ca₂i₃toin'₅₄ të₂dsɨ́₅ i₁ŋí₅. Dsɨ₂juɨ₅ le₂jaun₂ bá₄ ca₂i₁nio₁ co₂chi'₅₄ i₁ŋí₅ cuɨng₂₃ juɨ₅ siá₅, jaun₂ ca₂i₁sein'₃ të₂ jmɨ₁ŋí'₄. Ja₁jaun₂ ca₂dsain₃ ca₂'ɨn'₃ jmɨg₂.
\p 
\v 33 Dsa₂ i₂jme₁jmo₅ 'í₁ i₁ŋí₅ në́₃ ca₂cuɨng₃. Jme₁dsi₃lein₃ jë₄ juɨg₂ ca₂dsia₃ a₂ca₂lë₃ jaun₂, quian'₅₄ a₂ca₂lë₃ quian'₅₄ dsa₂ i₂jme₁tion'₅₄ je₂na'₅₄ në́₃.
\v 34 Ca₂le₃jɨ́n₃ dsa₂ chan₂ juɨg₂ jaun₂ në́₃ ca₂'uɨin₂ i₃léin₂ ja₁'en₅₄ Jesús. Jaun₂ jme₁ca₂jɨ́in₂ Jesús në́₃, ca₂chi₃quióng₂ jmɨg₄ a₂o₃'ɨin₅ le₂con₂ jaun₂.
\c 9
\s1 Ca₂jme₃'lión₂ Jesús jan₂ dsa₂ 'lian'₂
\r (Marcos 2:1-12; Lucas 5:17-26)
\p 
\v 1 Jaun₂ ca₂'í₃ Jesús 'ŋió'₃ tsɨ₁mu₅, ca₂ŋɨ́i₃ le₃'ŋo'₅₄ jmɨ₁ŋí'₄, jaun₂ ca₂dsiáin'₃ juɨg₂ ja₁jme₁guá₄.
\v 2 Jaun₂ ca₂o₃jŋia₃ dsa₂ jan₂ dsa₂ 'lian'₂, dsɨ́in₂ ne₄ tsɨ₁jein₁. Jme₁ca₂jág₃ Jesús a₂'én₂ dsa₂ 'éi₂ 'ŋio₅ lɨn₃, ca₂tsɨ́'₃ dsa₂ dso'₅₄:
\p ―Jmo₄ lían'₂ 'au'₂, jón₃; ma₂rë₂'én₄ bá₄ dsáu'₂.
\p 
\v 3 Jaun₂ ca₂i₃jiog₅ dsɨ́₅ i₂lɨn₅₄ të₅juá'₅: “A₂'ɨn₅ 'lɨg'₅₄ Diú₄ bá₄ i₂në₅ a₂juá'₂ le₂në₅.”
\p 
\v 4 La₁ i₂ŋi₅ rë₂ bá₄ Jesús a₂dsɨ₂jiog₅ dsɨ́₅ dsa₂ 'éi₂, jaun₂ ca₂juá'₂:
\p ―¿'E₂ lë₃ dsɨ₂jiog₅ 'au'₂ 'nia'₂ 'lɨg'₅₄ le₂në₅?
\v 5 ¿Na₂ a₂'ua₁ guë́₄ ta₁ jua'₅₄ a₂jme₁juɨg₅₄ jniá₂ dsa₂ la₂: “Ma₂rë₂'én₄ bá₄ dsáu'₂”, o₃ a₂jme₁juɨg₅₄ 'e₂ jniá₂: “Nau₂, ŋɨ₄?”
\v 6 Dse₃ jaun₂. La₂ jmo₅₄ jniá₂ jaun₂ le₃ŋi'₅₄ 'nia'₂ a₂'io₅ 'éi'₃ Jaun₅ dsa₂ mɨ₂güɨ́g₃ ne₄ gua'₅₄ 'uë₃ a₂qui₃'éin₂ dsáu₁ dsa₂.
\p Jaun₂ guë́₄ ca₂juá'₂ ca₂tsɨ́'₃ dsa₂ 'lian'₂:
\p ―Nau₂, quion₂ tsɨ₁jein₁ quiáng'₂, guan'₂ ja₁quiáng'₂.
\p 
\v 7 Jaun₂ ca₂nau₂ bá₄ dsa₂ 'éi₂, ca₂ŋái'₃ ja₁quió'₄.
\v 8 Jme₁ca₂jág₃ dsa₂ a₂ca₂lë₃ jaun₂, ca₂i₃gó'₃ dsɨ́₅, jaun₂ ca₂jme₃juɨin'₂ Diú₄ ne₄ 'uɨg₅₄ ia₁ a₂ma₂cuë₃ bí₂ jaun₂ ma₂cuë́'₃ jan₂ dsa₂ mɨ₂güɨ́g₃.
\s1 Ca₂të́'₃ Jesús Mateo
\r (Marcos 2:13-17; Lucas 5:27-32)
\p 
\v 9 Ca₂o₃'ɨ́n₃ bá₄ Jesús ja₁jme₁'ein₅₄ jaun₂. Ja₁ŋó₄ jaun₂, ca₂jɨ́in₂ jan₂ dsa₂ i₂chen₂ Mateo, guá₅ caun₂ dsi₂néi₂ cán₂ 'lia'₅₄ o₄quió'₄ dsɨ₂tan₅₄. Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ 'éi₂:
\p ―'Éin₃ jniá₂.
\p Jaun₂ ca₂nau₂ bá₄ Të₅₄, ca₂jme₃quiong'₅₄.
\p 
\v 10 Ca₂lë₃ jme₁ma₂'en₅₄ Jesús guë́'₅ dsi₂néi₂ quió'₅ Të₅₄, ca₂dsi₃lén₂ juɨn₅ guë́₄ dsa₂ i₂cán₂ cu₄ rɨin'₅₄, dsa₂ “i₂le₁cán'₄ dso₄” sián'₂ guë́₄ në́₃, ca₂i₃toin'₅₄ i₁guë'₂ quiain'₅₄ Jesús, quiain'₅₄ dsa₂ i₂ma₂quiain'₅₄ në́₃.
\v 11 Dsa₂ fariseos në́₃, jme₁ca₂jág₃ a₂në₅, jaun₂ ca₂ŋɨ́i'₃ dsa₂ quián₅ Jesús:
\p ―¿'A₂ lia'₂ guë́'₅ të₅ quián'₂ 'nia'₂ co₂lë₅ quian'₅₄ dsa₂ i₂cán₂ 'lia'₅₄ quián₅ dsɨ₂tan₅₄, dsa₂ i₂le₁cán'₄ dso₄ në́₃?
\p 
\v 12 Ca₂nág₂ Jesús jág₁ jaun₂, jaun₂ ca₂juá'₂:
\p ―On₃jua'₅₄ dsa₂ i₂qui₂le₁'ág₄ dse₃ dsɨ́₅ i₂'nió'₅ të₅mɨ́₅ quió'₅; të₂le₃ ja₁con₂ dsa₂ i₂le₁dso'₅₄ bá₄ 'nió'₅ quió'₅.
\v 13 O₂nó'₅ 'nia'₂ o₂jme₁tɨn₅ 'e₂ jein₅ jág₁ la₂ tio'₅₄ ne₄ Si₂: “A₂'nio₃ jniá₂ dsiá'₁ 'nia'₂ ŋéi₂ 'au'₂ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂, on₃jua'₅₄ rë'₂ a₂jŋia'₅₄ qui₁jen'₄ 'nia'₂ 'e₂ qui₁jen'₄ ne₃.”\f + \fr 9:13 \ft Oseas 6:6.\f* Ia₁ tsá₃ ta₁ jaun₂ guio₃ jniá₂ jua'₅₄ a₂të́₄ dsa₂ dsen₃; a₂të́₄ dsa₂ i₂le₁cán'₄ dso₄ bá₄ jniá₂ guio₃.
\s1 Ca₂ŋɨ́'₃ dsa₂ Jesús juɨ₁lia'₂ jág₁ a₂jme₂'ɨn₅₄ dsa₂
\r (Marcos 2:18-22; Lucas 5:33-39)
\p 
\v 14 Jaun₂ ca₂dsi₃lén₂ dsa₂ i₂jme₁i₂nio₄ quian'₅₄ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂ ca₂jme₃quiáin₃ ne₄ Jesús, jaun₂ ca₂ŋag₃:
\p ―¿'A₂ lia'₂ jme₂'ɨn₅₄ bá₄ dsa₂ fariseos, le₂jaun₂ guë'₂ jnia'₅₄ në́₃, la₁ dsa₂ i₂quian'₅₄ 'ne₂ guë'₂ tsá₃ jme₂'ɨin₅₄?
\p 
\v 15 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿Lé₂ le₃tón'₃ 'lia'₂ dsɨ́₅ juɨ₁lia'₂ dsa₂ i₂té₁ ja₁niog₅ jmɨg₄ ja₁jen'₂ gu₂ dsa₂, chi₂jua'₂ jaun₂ bá₄ guá₅ guë'₂ dsa₂ ŋe'₂ i₂jen'₂ gu₂? Já₅ jmɨg₄ jë₁tsá₃ ma₃dsa₂ i₂jen'₂ gu₂ 'éi₂ chan₂ lé₂; jaun₂ guë́₄ tóin'₃ jme₃'ɨin₅₄.
\p 
\v 16 ’Ma₁ tsá₃ 'ein₂ tɨn₂ tióng₅ tsɨ₁'mɨ'₂ gui'₅₄ quian'₅₄ 'nau₅₄ tsɨ₁'mɨ'₂ 'mɨ́₂. Ia₁ dsán'₅ tsɨ₁'mɨ'₂ 'mɨ́₂, jaun₂ juë'₂ guë́₄ ja₁gag₂ lë́₂.
\v 17 Ján₃ bá₄ le₂jaun₂ tsá₃ tia'₂ dsa₂ vino 'mɨ́₂ 'ŋió'₃ nɨ₁lau₂ gui'₅₄, ia₁ ne'₂. Në₅ bá₄ téin₃ vino, ton'₂ dsɨ₃'én₂ nɨ₁lau₂ në́₃ në₁jua'₂ ca₂jmo₃ dsa₂ le₂jaun₂. Jaun₂ lë₃, 'ŋió'₃ lau₂ 'mɨ́₂ bá₄ 'nió'₅ tia'₃ dsa₂ vino 'mɨ́₂, ia₁jaun₂ le₃tɨn₃ bá₄ lé₂ 'í₁.
\s1 Ja₁mɨ́g₄ Jairo, quian'₅₄ 'io₅₄ i₂ca₂nɨ́'₃ tsɨn'₅₄ Jesús
\r (Marcos 5:21-43; Lucas 8:40-56)
\p 
\v 18 Të₃ 'en₅₄ Jesús dsia₂₃ jág₁, jme₁ca₂dsióg₃ jan₂ i₂niog₅ gu₂ guá'₅ sinagoga. Ca₂chi₃jné₃ ne₄ Jesús, jaun₂ ca₂juá'₂:
\p ―Lia'₂ ca₂jon₃\f + \fr 9:18 \ft o₃, “ma₂i₁jón₂”, lé₂ le₃jein₃ jág₁.\f* jan₂ chi'₂ dsa₂ mɨ́₂ quiáng₃. La₁ në₁jua'₂ gog'₅₄ 'ne₂ quian'₅₄ jniá₂ o₁quiog'₂ gog'₂ ne₄ quió'₅, le₃chain₂ bá₄ táng₃.
\p 
\v 19 Jaun₂ ca₂nau₂ Jesús, jaun₂ ca₂ŋó₃ quiain'₅₄ dsa₂ 'éi₂, lia'₂ jma₃quiain'₅₄ dsa₂ i₂ma₂ja₂lén₂ quiong'₅₄.
\v 20 Të₃jë₄ jaun₂, ŋó₃ jan₂ dsa₂ mɨ́₂ i₂dso'₅₄ ma₂guia₃-tɨ́n₂ ŋi₂ a₂tɨin₂. Ca₂jme₃quiáin₃ të₂le₃ chi₁co'₅₄ quió'₅ Jesús, jaun₂ ca₂nɨ́i'₂ chei'₅₄ tsɨn'₅₄ 'éi₂.
\v 21 Ia₁ lɨ́in₂: “Tsá₃ nag₅₄ në₁jua'₂ jŋia'₅₄ nɨ́g'₄ ca₂juɨg₄ tsɨn'₅₄, jŋia₃ quió₃.”
\v 22 Jaun₂ ca₂jén'₃ Jesús, ca₂jɨ́in₂ 'io₅₄, jaun₂ ca₂juá'₂:
\p ―Jmo₄ lián'₂ 'au'₂, jón₃. Ma₂'lóng'₂ bá₄, ia₁ 'éng'₂.
\p Dsɨ₂juɨ₅ le₂jaun₂ bá₄ ca₂jŋia₃ co₂ŋei'₅₄ quió'₅.
\p 
\v 23 Jme₁ca₂dsióg₃ Jesús ja₁quió'₄ dsa₂ juɨg₅₄ sinagoga 'éi₂, jaun₂ ca₂jág₃ ma₂tion'₅₄ dsa₂ i₂jmo₅ son₅₄, ma₂tion'₅₄ dsa₂ juɨn₅ go₂'i₃ në́₃, quɨ'₂-'o₂₃.
\v 24 Jaun₂ ca₂juá'₂:
\p ―'Uɨ́n'₂ 'nia'₂ ja₁lá₃; tsá₃ rë₂jon₅₄ i₂bë'₅₄ në₅. Jŋia'₅₄ lia'₂ a₂rë₂güɨ́in₃ bá₄.
\p La₁ jŋia'₅₄ ca₂ŋág₂ bá₄ dsa₂.
\v 25 Jme₁ma₂'uɨn'₂ dsa₂, jaun₂ ca₂'í₃ Jesús dsi₂néi₂, ca₂jŋa'₃ mɨ₂gu₂ i₂bë'₅₄, jaun₂ ca₂nau₂ bá₄ 'éi₂.
\v 26 Ca₂le₂con₂ juɨg₂ tio'₅₄ 'uë₃ jaun₂, ca₂i₃'ág₃ jág₁ a₂ca₂lë₃ jaun₂.
\s1 Ca₂jme₃'lión₂ Jesús on₃ dsa₂ ten₄
\p 
\v 27 Jme₁o₂'ɨ́n₃ Jesús ja₁jaun₂, ca₂'ein₃ on₃ dsa₂ ten₄, ja₂léin₂ të́₂ tiá₂:
\p ―¡Dsia₄ ŋéi₂ 'au'₂ jnia'₅₄, 'ne₂ tsɨ₁jon₂ David!
\p 
\v 28 Jme₁ca₂'í₃ Jesús dsi₂néi₂, ca₂jme₃quián₃ dsa₂ ten₄ 'éi₂ cau₅ quió'₅. Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿'Én'₂ 'nia'₂ a₂lé₂ le₃jme₁'lio₅₄ jniá₂?
\p Jaun₂ ca₂ŋag₃:
\p ―'Éin₂ bá₄ jnia'₅₄, Te₁gui'₅₄.
\p 
\v 29 Jaun₂ ca₂nɨ́'₃ Jesús gu₂ jme₁ne₁₂ jaun₂ ca₂juá'₂:
\p ―Juɨ₁le₅₄ bá₄ con'₂ lë́₅ 'én'₂ 'nia'₂.
\p 
\v 30 Jaun₂ ca₂lág₃ bá₄ mɨ₂ne₄ dsa₂ 'éi₂. Jaun₂ ca₂jmo₃ Jesús 'éi'₃ ca₂juá'₂:
\p ―Të₃ŋi'₅₄ 'nia'₂ jnag₅₄ tsá₃ 'ein₂ juɨ₁le₂ŋi₅ a₂në₅.
\p 
\v 31 La₁ 'éi₂ në́₃, jme₁ca₂'uɨin₂ jaun₂, ca₂dsia₃ ca₂le₂con₂ ja₁tén₄ 'uë₃ jaun₂ 'e₂ a₂ca₂jmo₃ Jesús.
\s1 Ca₂jme₃'lión₂ Jesús jan₂ dsa₂ con₄
\p 
\v 32 Jme₁ma₂'uɨn₂ dsa₂ i₂jme₁ten₄ 'éi₂, ca₂o₃lén₂ i₂sián'₂ táng₃ jŋiai₂₃ jan₂ dsa₂ con₄ i₂'en₅₄ jme₂dsí₂ je₂na'₅₄.
\v 33 Dsɨ₂juɨ₅ jme₁ca₂dsen₅ Jesús je₂na'₅₄, jaun₂ ca₂jme₃lióg₃ dsa₂ con₄ 'éi₂ ca₂dsia₃ jág₁. Dsa₂ juɨn₅ i₂jme₁tion'₅₄ ca₂të́₂ ne₅₄, ca₂i₃gó'₃ dsɨ́₅, jaun₂ ca₂dsia₃:
\p ―Ca₂le₂con₂ 'uë₃ Israel la₂, tsá₃ 'ein₂ ma₂ca₂jág₃ a₂le₂në₅.
\p 
\v 34 La₁ dsa₂ fariseos guë'₂ në́₃, ca₂juá'₂:
\p ―Të₂le₃ quian'₅₄ juɨ₅bí₂ quió'₅ 'ŋiog₅ juɨg₅₄ je₂na'₅₄ bá₄, jmo₅ i₂në₅ 'uɨ́in'₂ je₂na'₅₄.
\s1 Dsia₅ Jesús ŋéi₂ dsɨ́₅ dsa₂
\p 
\v 35 Ca₂ŋɨ₃ Jesús ca₂le₂con₂ juɨg₂ ca'₅₄, ca₂le₂con₂ juɨg₂ pí'₁ në́₃, jme₂tɨin₂₃ dsa₂ dsi₂néi₂ guá'₅ sinagogas. Jme₁'ë́₂ jág₁ dse₃ juɨ₁lia'₂ ja₁gon₂ Diú₄. Jme₁jme₂'lióin₂ dsa₂ ca₂le₃jë́₃ ne₅₄ dso₄, quian'₅₄ ca₂le₃jë́₃ jmɨ₁uɨg₅ a₂jme₁le₁quian₅ dsa₂.
\v 36 Jme₁ca₂jɨ́in₂ dsa₂, ca₂tá'₂ ŋéi₂ dsɨ́₅, ia₁ jme₁chain₂ o₂i₁ dsɨ₅ ca₂lia'₂ ma₂ja₂'ú'₃ dsɨ́₅ chain₂, në₂jag₄ bá₄ já'₂ cha'₂ i₂tsá₃ chan₂ jmo₃ 'í₁.
\v 37 Jaun₂ në́₃ ca₂tsɨ́'₃ dsa₂ i₂jme₁quiain'₅₄:
\p ―Dsón'₂ bá₄ dsau₅ 'lióng₂ a₂ca₂rau₂, la₁ tsá₃ juɨn₅ dsa₂ i₂jmo₅ ta₁ ja₁nau₂.
\v 38 Jaun₂ lë₃, mɨ₄ 'nia'₂ ne₄ juɨg₅₄ ja₁nau₂ a₂chein₃ guë́₄ juɨn₅ dsa₂ i₂jmo₃ ta₁ ja₁nau₂ quió'₅.
\c 10
\s1 Ca₂quión'₂ Jesús guia₃-tɨ́n₂ dsa₂ jë₄ quió'₅ dsa₂ quiáin₅
\r (Marcos 3:13-19; Lucas 6:12-16)
\p 
\v 1 Jaun₂ ca₂të́'₃ Jesús chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ ca₂cuë₃ bí₂ 'éi'₃ a₂'uɨ́in'₂ jme₂dsí₂ 'lɨn'₅₄, a₂qui₂jme₃'lióin₂ ca₂le₃jë́₃ ne₅₄ dso₄ a₂niog₅ lɨ́n₅ dsa₂, ca₂le₃jë́₃ jmɨ₁uɨg₅ në́₃.
\p 
\v 2 Le₂la₂ bá₄ chen₂ ta₁guia₃-tɨ́n₂ dsa₂ i₂ca₂quión'₂ Jesús 'éi₂ quiáin₅: Si₂mu₅₄, i₁të́'₂ dsa₂ Pe₄; quiain'₅₄ Drë́₄ rɨin'₅₄; Jacobo\f + \fr 10:2 \ft Jacobo: ján₃ bá₄ chein₂ Santiago.\f* quian'₅₄ Juan₅₄ rɨin'₅₄, ja₁ŋí'₄ Zebedeo;
\v 3 Fe₂li₄ quian'₅₄ Bartolomé; To₁má₄ në́₃ quian'₅₄ Të₅₄ i₂jme₁cán₂ 'lia'₅₄ a₂ca₂tɨ́n₂ dsɨ₂tan₅₄; Jacobo i₂lɨ́n₅ ja₁ŋí'₄ Alfeo; Tadeo në́₃;
\v 4 Si₂mu₅₄ në́₃ i₂të́'₂ dsa₂ cananista;\f + \fr 10:4 \ft cananista: partido quió'₅ dsa₂ i₂'nio₃ táun₂ 'uë₃ 'éi'₃ quió'₅ Roma. Jma₃quén₅ ca₂quioin₃ le₃on₃ Si₂mu₅₄ 'éi₂, ia₁ ŋɨ́₄ lë₃ mei'₂ tsá₃ ca₂ne₅₄ a₂chein₂.\f* Judas Iscariote në́₃, i₂ca₂jɨ́n'₂ Jesús.
\s1 Ca₂chen₃ Jesús dsa₂ guia₃-tɨ́n₂ quiáin₅ a₂ca₂i₁'ë́₄ jág₁ dse₃
\r (Marcos 6:7-13; Lucas 9:1-6)
\p 
\v 5 Dsa₂ guia₃-tɨ́n₂ në₅ bá₄ ca₂chen₃ Jesús jme₁ma₂në₂cuë₃ jág₁ la₂:
\p ―Tsá₃ o₁nó'₅ 'nia'₂ juɨ₅ 'uë₃ go₄ dsɨ₂nau₂, on₃ guë'₂ o₂ton'₅₄ 'nia'₂ 'i₁caun₂ juɨg₂ a₂tén₅ 'uë₃ Samaria.
\v 6 Ja₁jaun₂ bá₄ o₂nó'₅ 'nia'₂ ja₁tion'₅₄ dsa₂ i₂lɨ́n₅ co₂'nió'₄ já'₂ cha'₂ i₂ma₂i₂cón'₅ i₂chan₂ juɨg₂ Israel.
\v 7 O₂nó'₅ 'nia'₂ qui₂o₂'ë́₃ jág₁ dse₃ la₂ chei'₅₄ 'nia'₂ dsa₂, ma₂ja₂quián₃ 'éi'₃ quió'₅ Diú₄.
\v 8 O₂jmo₄ 'nia'₂ le₁jɨ́n₃ dsa₂ i₂lɨ́n₅ 'mé'₅ 'iog₅; ca₂le₃jɨ́n₃ guë'₂ i₂lɨ́n₅ dso₄ siá'₂ në́₃, o₂jme₁'lioin₅₄; o₂jme₁jen'₅₄ 'nia'₂ 'lag₄; o₂'uɨn'₅₄ 'nia'₂ je₂na'₅₄ quió'₅ dsa₂ në́₃. Jaun₂ le₂në₅ juɨ₁lia'₂ në₂gue'₅₄ 'nia'₂ bí₂ la₂ on₃jua'₅₄ a₂cha₂ 'lia'₅₄, le₂në₅ o₂jmo₄ 'nia'₂ ján₃, o₂cuë'₅₄ dsa₂ bí₂ tsá₃ 'lia'₅₄ cán'₁.
\v 9 Tsá₃ 'e₂ cán'₁ 'nia'₂, juɨ₁lia'₂ a₂'nió'₅ le₂'i₄ juɨ₅, on₃ guë'₂ cu₄nióg₄, on₃ guë'₂ cu₄tiog₂, on₃ guë'₂ ŋí₁ guéin₂ të₂lau₂ quiáng'₂,
\v 10 on₃ guë'₂ të₂'mɨ'₂ jua'₅₄ a₂to'₅₄ lio₅₄ cán'₁. Jmá'₃ co₂dsán'₃ tsɨ́n'₂ bá₄ 'nia'₂ cán'₁, tsá₃ cán'₁ 'nia'₂ lau₂ ton₂ tag'₅₄ a₂ŋag₅₄ guë́₄ con'₂ a₂ma₂le₁ton₅ tag'₅₄, on₃ guë'₂ 'ma₂'ɨ₅₄; ia₁ juɨ₁lia'₂ dsa₂ i₂jmo₅ ta₁, ca₂tɨ́in₂ bá₄ gue₃ má₃ quió'₅.
\p 
\v 11 ’Jë₁ma₂ca₂dsi₃nó'₅ 'nia'₂ lia'₂ caun₂ juɨg₂ ca'₅₄ o₃ juɨg₂ pí'₁ 'e₂, ja₁jaun₂ jŋia₄ 'nia'₂ ja₁quió'₄ dsa₂ i₂léi₄ dsen₃ 'ua₁ dsɨ́₅, quió'₅ 'éi₂ tión'₂ 'nia'₂ ca₂lia'₂ ca₂të́₂ jmɨg₄ i₁'uɨ́ng'₃ táng₃.
\v 12 Jë₁ma₂të́₂ rë₁tóng'₁ dsi₂néi₂ quió'₅, cuɨin₅₄ 'nia'₂ Diú₄ jua'₅₄ 'nia'₂: “Juɨ₁'ei₅ bá₄ tei₄ dsi₂néi₂ la₂.”
\v 13 Në₁jua'₂ dsa₂ dsi₂néi₂ jaun₂ léi₄ gue₂₃ bá₄ lia'₂ i₁rë₂ jág₁, jág₁ quián'₂ 'nia'₂ a₂cuɨ́in'₅ Diú₄, juɨ₁të₂'ŋiá₄ bá₄ 'ei₅ tei₄ ja₁con₂ dsa₂ 'éi₂ dsi₂néi₂ jaun₂. La₁ në₁jua'₂ léi₄ tsá₃ dse₃ le₁'ág₄ dsɨ́₅ dsa₂ gue₂₃ jág₁ quián'₂ 'nia'₂, juɨ₁të₂'ŋiá₄ bá₄ jág₁ 'ei₅ tei₄ jaun₂ ja₁con'₂ 'nia'₂ guiong'₅₄.
\v 14 Në₁jua'₂ cha₂ ja₁lɨn₅₄ tsá₃ 'nio₃ dsa₂ guein₃ 'nia'₂, on₃ guë'₂ 'nio₃ nag₃ jág₁ quián'₂ 'nia'₂ në́₃, co₂ŋei'₅₄ 'uɨ́n'₂ 'nia'₂ dsi₂néi₂ jaun₂, o₃ juɨg₂ jaun₂, séi'₃ 'nia'₂ 'liog₂ tag'₅₄.
\v 15 Ia₁ a₂dsɨ₂jó'₃ juá'₅ jniá₂, jë₁ma₂të́₂ rë₁qui₃dsɨ₅ Diú₄ 'éi'₃, 'ŋio₅ guë́₄ uɨg₅ gue₃ dsa₂ juɨg₂ jaun₂ con'₂ guë́₄ dsa₂ i₂jme₁chan₂ Sodoma quian'₅₄ Gomorra.\f + \fr 10:15 \ft Sodoma quian'₅₄ Gomorra: 'Í₂ Génesis 18 - 19.\f*
\s1 Qui₂co₃'ein₃ dsa₂
\r (Marcos 13:9-13; Lucas 21:12-17)
\p 
\v 16 ’Tsɨ́n₂ jniá₂ 'nia'₂ jaun₂, a₂lɨ́ng'₅ në₂jag₄ bá₄ já'₂ cha'₂ jɨn₄ co₂'nió'₄ já'₂ tsau₂ dsɨ́₅. Jmo₄ 'nia'₂ jaun₂ a₂lɨ́ng'₅ dsa₂ i₂'io₅ mai₅₄ juɨ₁lia'₂ dsɨ₂mɨ'₂, ton'₂ 'ua₁ 'au'₂ 'nia'₂ juɨ₁lia'₂ lɨ́n₅ i₁ju₂.
\v 17 Rë₂ján'₁ 'nia'₂ jaun₂ ia₁ qui₃jáng'₂ dsa₂ ne₄ dsɨ₂tan₅₄, qui₃bóg₂ dsa₂ në́₃ dsi₂néi₂ guá'₅ sinagogas.
\v 18 Lia'₂ ne₄ dsi₄má'₂ lia'₂ ne₄ rag₅₄ në́₃, dsi₁jŋia₃ dsa₂ 'nia'₂ 'uɨg₅₄ quió₃ jniá₂; jaun₂ le₂në₅ bá₄ lé₂ le₃o₁jang'₄ 'nia'₂ jág₁ dsau₅ ne₄ 'éi₂, quian'₅₄ ja₁con₂ dsɨ₂nau₂ sián'₂ në́₃.
\v 19 La₁ jë₁ma₂të́₂ rë₁qui₃jáng'₂ dsa₂ ne₄ta₁, tsá₃ lë₁jmo₂ 'nia'₂ 'ɨ₅ 'au'₂ 'e₂ jua'₅₄ o₃ 'a₂ lia'₂ ŋag'₅₄; ia₁ jë₁ma₂të́₂ rë₁jua'₅₄ 'nia'₂ jág₁, Diú₄ bá₄ cuë₃ jág₁ a₂ŋi'₅₄ 'nia'₂ 'a₂ lia'₂ ŋag'₅₄ juɨg'₅₄ dsa₂.
\v 20 Ia₁ on₃jua'₅₄ guion'₅₄ 'nia'₂ jua'₅₄ jág₁; 'ŋiog₅ bá₄ Jme₂dsí₂ quián₅ Ŋéi'₅ 'nia'₂ juá'₂ juɨ₅ të₂'au'₂.
\p 
\v 21 ’Ia₁ lé₂ táng₃, juɨ₁lia'₂ rɨn'₅₄ dsa₂ qui₃jɨ́in'₂ rɨin'₅₄ jaun₂ jŋag'₃ dsa₂, juɨ₁lia'₂ jmei₂ guë'₂ dsa₂ qui₃jɨ́in'₂ chi'₂ quiáin₅; chi'₂ guë'₂ në́₃ qui₃náu₃ 'nei₂ jmái'₃ chog₅₄-jmei₂, qui₃jáng'₂ a₂jme₃dsiog₅ dsa₂.
\v 22 Ca₂le₃jɨ́n₃ juɨ₁lia'₂ dsa₂ mɨ₂güɨ́g₃ jme₃'ŋiai₅₄ 'nia'₂ 'uɨg₅₄ quió₃ jniá₂; la₁ia₁ juɨ₁lia'₂ i₂tión₂ tiá₂ ca₂të₂ jë₁ca₂tó'₂, i₂'éi₂ bá₄ i₂lión₂.
\v 23 Jë₁ma₂qui₂co₃'ein₃ dsa₂ juɨ₁lia'₂ caun₂ juɨg₂, cuɨng₅ 'nia'₂ juɨ₅ juɨg₂ siá'₂ táng₃; a₂dsɨ₂jó'₃ juá'₅ jniá₂, të₃ tsá₃ ma₂lë₅ quen'₄ 'nia'₂ i₁niog'₄ ca₂le₃jë́₃ juɨg₂ ja₁tén₄ 'uë₃ Israel, a₂guan'₂ táng₃ Jaun₅ dsa₂ mɨ₂güɨ́g₃.
\p 
\v 24 ’Juɨ₁lia'₂ jan₂ i₂jme₂tɨn₅, tsá₃ juɨin'₂ con'₂ guë́₄ të₅ quiáin₅; ján₃ bá₄ le₂jaun₂ juɨ₁lia'₂ jan₂ dsa₂ i₂jme₂ti₃, tsá₃ juɨin'₂ con'₂ guë́₄ juɨg₅₄.
\v 25 Tió'₅ juɨ₁lia'₂ i₂jme₂tɨn₅ léin₂ juɨ₁lia'₂ lɨ́n₅ të₅ quiáin₅; juɨ₁lia'₂ dsa₂ i₂jme₂ti₃ guë'₂ në́₃, dsi₁léin₂ juɨ₁lia'₂ lɨ́n₅ juɨg₅₄. Chi₂jua'₂ 'ŋiog₅ dsa₂ juɨn'₂ caun₂ dsi₂néi₂ ma₂quion₅ dsa₂ Be'elzebú, ¡'ë₂ guë́₄ bá₄ 'ɨn₃ dsa₂, juɨ₁lia'₂ i₂tion'₅₄ dsi₂néi₂ quió'₅!
\s1 'Ein₂ 'nió'₅ jme₃gan₃ dsa₂
\r (Lucas 12:2-7)
\p 
\v 26 ’'Uɨg₅₄ jaun₂, tsá₃ lë₁jmo₂ 'nia'₂ gang'₃ dsa₂ mɨ₂güɨ́g₃. Ia₁ 'i₁caun₂ juɨ₁lia'₂ a₂rë₂jlë₅ tsá₃ cha₂ jua'₅₄ a₂tsá₃ le₃jniá₂, ján₃ bá₄ le₂jaun₂ juɨ₁lia'₂ a₂rë₂'ma₄ tsá₃ cha₂ jua'₅₄ a₂tsá₃ le₃ŋi₅ dsa₂.
\v 27 Juɨ₁lia'₂ a₂juɨ́g₂ jniá₂ 'nia'₂ la₂ jë₄ të₃co'₅₄, jua'₅₄ 'nia'₂ të₃jɨn₄ dsa₂ juɨn₅; ján₃ bá₄ le₂jaun₂ juɨ₁lia'₂ a₂juɨ́g₂ jniá₂ 'nia'₂ con'₂ tei₄, jua'₅₄ 'nia'₂ co₂mɨ'₅₄ juɨ₁lia'₂ ja₁ŋei₅.
\v 28 Tsá₃ lë₁jmo₂ 'nia'₂ gang'₃ quian'₅₄ i₂jŋɨ'₃ nɨ₁ŋɨ́₅, la₁ të₂'au'₂ 'nia'₂ tsá₃ 'e₂ lé₂ le₃jmo₃; i₂'éi₂ bá₄ ca₂tɨ́n'₂ 'nia'₂ jme₁gang'₃ juɨ₁lia'₂ i₂lé₂ le₃jŋɨ'₃ nɨ₁ŋɨ́₅ quian'₅₄ guë'₂ të₂'au'₂ 'nia'₂ a₂jeng'₃ ja₁'lɨg'₅₄.
\p 
\v 29 ’¿Tsa₁ 'nɨ₅ dsa₂ on₃ i₁tan₅ pí'₁ quian'₅₄ caun₂ ŋí₁ guéin₂? La₁ 'i₁jan₂ i₁tan₅ tsá₃ tián'₃ 'uë₃ jua'₅₄ tsá₃ ŋi₅ Ŋéi'₅ 'nia'₂.
\v 30 Ia₁ le₂jiog₅ nɨ₁jŋi₂ dsei'₂ 'nia'₂ le₁'í₁ je₂liá'₂ mɨ'₂ tí₅ ján₃.
\v 31 Tsá₃ lë₁jmo₂ 'nia'₂ gang'₃, ia₁ 'ŋio₅ lɨn₃ guë́₄ quen'₄ 'nia'₂ lia'₂ con'₂ guë́₄ juɨn₅ lɨn₃ i₁tan₅.
\s1 Juɨ₁lia'₂ i₂jme₂jnia₅ a₂cuɨin₂₃ Jesucristo jɨn₄ dsa₂ mɨ₂güɨ́g₃
\r (Lucas 12:8-9)
\p 
\v 32 ’Juɨ₁lia'₂ i₂jme₂jnia₅ të₂le₃ quió₃ jniá₂ jɨn₄ dsa₂ mɨ₂güɨ́g₃, ján₃ bá₄ le₂jaun₂ jniá₂ në́₃ jme₁jniag₅ të₂le₃ quió'₅ 'éi₂ ne₄ Ŋe'₃ i₂guá₅ guei'₅₄ i₂juɨ́g₃;
\v 33 la₁ juɨ₁lia'₂ i₂jme₂jnia₅ a₂tsá₃ cuɨg₂₃ jniá₂ jɨn₄ dsa₂ mɨ₂güɨ́g₃, ján₃ bá₄ le₂jaun₂ jme₁jnia₅ jniá₂ a₂tsá₃ cuɨ́in₅ ne₄ Ŋe'₃ i₂guá₅ guei'₅₄ i₂juɨ́g₃.
\s1 Jesús bá₄ i₂'uɨn₄ a₂lë́₂ le₁dson'₅₄ dsa₂
\r (Lucas 12:51-53; 14:26-27)
\p 
\v 34 ’Tsá₃ o₁len'₂ 'nia'₂ jua'₅₄ a₂guio₃ jniá₂ a₂i₃'ei₃ tei₄ mɨ₂güɨ́g₃; ia₁ tsá₃ ta₁ jaun₂ guio₃ jniá₂ a₂i₃'ei₃ tei₄. Mɨ'₅₄ 'nei₂ bá₄ a₂quian₄ jniá₂.
\v 35 A₂jaun₂ bá₄ guio₃ jniá₂ a₂i₃dsia₃ mɨ'₅₄ dsi₂néi₂:
\q1 Chi'₂ jme₃'ŋiai₅₄ jmei₂,
\q1 chi'₂ ja₁mɨ́g₄ dsa₂ në́₃
\q2 jme₃'ŋiai₅₄ chog₅₄;
\q1 i₂lɨ́n₅ mɨ₂lo₅₄ në́₃
\q2 tóin'₃ mɨ'₅₄ quian'₅₄ ma₂chog₅₄.
\q1 
\v 36 Dsa₂ i₂lɨ́n₅ jmei₂ dsi₂néi₂
\q2 qui₂jme₃'iog₅₄ chi'₂ quiáin₅.\f + \fr 10:36 \ft Miqueas 7:6.\f*
\p 
\v 37 ’Juɨ₁lia'₂ i₂'nio₃ guë́₄ 'ŋio₅ lɨn₃ chog₅₄-jmei₂ lia'₂ con'₂ guë́₄ jniá₂, tsá₃ ca₂tɨ́in₂ léin₂ dsa₂ quiáng₃; le₂në₅ bá₄ ján₃, juɨ₁lia'₂ i₂'nio₃ 'ŋio₅ lɨn₃ guë́₄ ja₁ŋi'₅₄ o₃ ja₁mɨ́g₄ 'e₂, lia'₂ con'₂ guë́₄ jniá₂, tsá₃ ca₂tɨ́in₂ léin₂ dsa₂ quiáng₃;
\v 38 juɨ₁lia'₂ i₂tsá₃ ca₂'ág₂ caun₂ dsɨ́₅ ca₂join₃ chi₂jua'₂ ca₂join₃,\f + \fr 10:38 \ft lit. “i₂tsá₃ cán₂ cróg₄ quió'₅.” \f* a₂jiá₃ chi₁co'₅₄ quió₃, tsá₃ ca₂tɨ́in₂ léin₂ dsa₂ quiáng₃.
\v 39 Juɨ₁lia'₂ i₂ŋɨ́₄ lë₃ 'nio₃ lí'₂ le₃chain₂ dse₃, dsɨ₃'én₂ quió'₅; ján₃ bá₄ le₂në₅, juɨ₁lia'₂ i₂ca₂guen₃ 'mú₃ o₄quió₃ jniá₂, lí'₂ bá₄.
\s1 Co₂'nió'₄ 'lian'₅₄ dsa₂
\r (Marcos 9:41)
\p 
\v 40 ’Juɨ₁lia'₂ i₂guen₅ 'nia'₂, guei₂₃ jniá₂; juɨ₁lia'₂ i₂guei₅ jniá₂ guein₂₃ i₂ca₂chei₃ jniá₂ në́₃.
\v 41 I₂guen₅ juɨ₁lia'₂ jan₂ dsa₂ i₂'ë́₂ jág₁ o₄quió'₄ Diú₄ ia₁ a₂lɨ́in₅ i₂chen₄ quián₅ Diú₄, co₂jaun₂ bá₄ 'lia'₅₄ gue₃ ján₃ juɨ₁lia'₂ 'lian'₅₄ jan₂ i₂'ë́₂ jág₁ quián₅ Diú₄. Le₂në₅ bá₄ ján₃, juɨ₁lia'₂ i₂guen₅ jan₂ dsa₂ dsen₃ ia₁ lɨ́in₅ dsa₂ dsen₃, gue₃ 'liain'₅₄ ján₃ con'₂ 'lia'₅₄ a₂ca₂tɨ́n₂ jan₂ dsa₂ dsen₃.
\v 42 Juɨ₁'ein₂ guë́₃ dsa₂ i₂cuë₅ caun₂ vaso jmɨg₂ güɨ́g'₂, cuë́'₅ jan₂ dsa₂ me'₂ le₂në₅ quiáng₃ 'uɨg₅₄ ia₁ a₂'ein₂₃ jniá₂, a₂dsɨ₂jó'₃ juá'₅, tion₅₄ bá₄ gue₃ 'liain'₅₄.
\c 11
\s1 Dsa₂ i₂chen₄ quián₅ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂
\r (Lucas 7:18-35)
\p 
\v 1 Jme₁ca₂dsan₃ cuë₅ Jesús jág₁ në₅ cuë́'₅ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, ca₂o₃'ɨ́in₃ táng₃ ja₁jaun₂, ca₂'í₃ juɨ₅ ca₂i₁'ë́₄ jág₁, i₂jme₁tɨin₂₃ dsa₂ juɨg₂ tio'₅₄ con'₂ ma₂quián₅ jaun₂.
\p 
\v 2 Juan₅₄ në́₃, të₃ 'ein₅₄ né'₃ 'má₃, ca₂rë₃ŋi₅ 'a₂ lia'₂ lë́₅ jmo₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄. Jaun₂ ca₂chein₃ i₂lɨn₅₄ dsa₂ i₂jme₁quiain'₅₄
\v 3 a₂ca₂i₁ŋag₁₂:
\p ―¿'Ne₂ líng'₅ dsa₂ i₂lë́₅ jág₁ jiá₃, o₃ jŋia₄ jnia'₅₄ i₂sián'₂ 'e₂?
\p 
\v 4 Jaun₂ ca₂ŋag₃ Jesús:
\p ―O₂nó'₅ 'nia'₂ o₂chei'₅₄ Juan₅₄ 'e₂ a₂të₅ ne'₅₄ 'nia'₂ la₂, 'e₂ a₂nag'₂ 'nia'₂ në́₃.
\v 5 O₂dsia₄ 'nia'₂ 'a₂ lia'₂ lë́₅ qui₂jág₅ dsa₂ ten₄; dsa₂ i₂jme₁guian'₅₄ guë'₂ në́₃, ma₂i₂nioi₅₄ rë'₂ táng₃; dsa₂ i₂jme₁lɨ́n₄ 'mé'₅ 'iog₅ ma₂le₁jɨ́in₃ táng₃ dso₄ a₂jme₁lɨ́in₄; dsa₂ i₂jme₁guɨn₄ guë'₂ në́₃ ma₂nag₂₃; dsa₂ i₂ma₂dsan₃, jein'₅₄ táng₃; ja₁con₂ dsa₂ te₂ŋé₂ në́₃ dsɨ₂'ag₅ jág₁ dse₃ la₂ a₂lión₂ dsa₂.
\v 6 'E₂ guë́₄ dsen₃ dsa₂ i₂tsá₃ 'ag₅ caun₂-tɨn₃ dsɨ́₅ ja₁con₂ jniá₂.
\p 
\v 7 Jme₁ma₂i₂len₃ dsa₂ 'éi₂, jaun₂ ca₂jme₃lióg₃ Jesús ca₂tsɨ́'₃ dsa₂ a₂'ɨin₂₃ Juan₅₄:
\p ―¿'E₂ jme₁lɨ́n'₂ 'nia'₂ jme₁të₃ ne'₅₄ lia'₂ con'₂ jme₁i₁nóg'₄ 'uë₃ quein₂ co₂'ŋiog₅ jaun₂? ¿O₃ bá₄ jme₁lɨ́n'₂ 'nia'₂ a₂jme₁jɨng'₄ jan₂ dsa₂ i₂lɨ́n₅ juɨ₁lia'₂ lë́₅ ca₂'nau₂ nɨ₁'ma₂ ta₅ a₂lë₁qui₂bí₂ dsí₂ juɨ₅ la₂ juɨ₅ në₅?
\v 8 Chi₂jua'₂ tsá₃ le₂jaun₂ në́₃, ¿'e₂ guë'₂ ca₂i₁jag'₄ 'nia'₂? ¿O₃ bá₄ a₂jme₁lɨ́n'₂ 'nia'₂ a₂jme₁jɨng'₄ jan₂ dsa₂ i₂qui'₂ tsɨn'₅₄ jlá'₁? La₁ on₃jua'₅₄ le₂jaun₂. Ia₁ juɨ₁lia'₂ dsa₂ i₂quɨ́'₅ tsɨn'₅₄ jlá'₁, i₂tón'₅ dsi₂néi₂ quió'₅ rag₅₄ bá₄ i₂le₂'éi₂.
\v 9 ¿'E₂ guë'₂ ca₂i₁jag'₄ 'nia'₂ jaun₂ në́₃? ¿O₃ bá₄ jan₂ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄ 'e₂? Dsón'₂ bá₄ jaun₂ juá'₅ jniá₂. I₂lɨ́n₅ tson₂ guë́₄ jan₂ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄ bá₄ 'éi₂.
\v 10 Juan₅₄ 'éi₂ bá₄ i₂'ɨn₅ Si₂ quió'₅ Diú₄ ja₁juá'₂:
\q1 Tsɨng₅₄ jan₂ dsa₂ quiáng₃ ne₄ juɨ₅ quiáng'₂, jón₃,
\q2 a₂dsɨ₃can₅ jág₁, jmo₃ co₂jŋia₅₄ juɨ₅.\f + \fr 11:10 \ft Malaquías 3:1.\f*
\m 
\v 11 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, 'i₁jan₂ dsa₂ i₂ma₂can₅ dsa₂ mɨ́₂ i₂chan₂ mɨ₂güɨ́g₃, tsá₃ 'ein₂ ma₂lɨn₅ i₂juɨn'₂ guë́₄ i₂'ë́₂ jág₁ o₄quió'₄ Diú₄, lia'₂ con'₂ guë́₄ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂. La₁ia₁, i₂lɨ́n₅ i₂me'₂ guë́₄ ja₁gon₂ Diú₄, i₂'éi₂ bá₄ lɨ́n₅ i₂juɨn'₂ guë́₄ lia'₂ con'₂ guë́₄ Juan₅₄ 'éi₂.
\v 12 Ca₂le₃ ca₂guan₃ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂, ca₂të₂ jmɨg₄ në₃, con'₂ 'i₄ juɨ₅ bá₄ ma₂já₅ tiá₂ ja₁gon₂ Diú₄. Jaun₂ dsa₂ con'₂ i₂tiá₂ dsɨ́₅ bá₄ chan'₂ tiá₂ juɨ₅ jaun₂.\f + \fr 11:12 \ft o₃, “ca₂të₃ jmɨg₄ në₃, ma₂já'₅ ja₁gon₂ Diú₄ në₂jag₄ bá₄ a₂lë́₂ 'nei₂. Jaun₂ dsa₂ i₂con'₂ qui₂jmo₂₃ 'nei₂ në́₃, 'nio₃ join₅₄ juɨ₁lia'₂ dsa₂ i₂i₂nio₄ juɨ₅ jaun₂.” \f*
\v 13 Ca₂le₃jɨ́n₃ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄, quian'₅₄ 'Éi'₃ quió'₅ Moisés në́₃, a₂jŋia'₅₄ con'₂ ca₂'ë́₂ jág₁ ja₁gon₂ Diú₄ bá₄ jaun₂, ca₂lia'₂ ca₂të́₂ jmɨg₄ jme₁ca₂guan₃ Juan₅₄.
\v 14 Ján₃ bá₄ chi₂jua'₂ 'niog'₂ 'nia'₂ guéi'₁ jág₁ la₂, Juan₅₄ 'éi₂ bá₄ i₂ca₂jme₃ti₃ jág₁ a₂lë́₅ a₂jme₁jiá₃ Elías.
\v 15 Juɨ₁lia'₂ i₂le₁dsɨ₅₄ rë₂gua₄, juɨ₁nei₅₄.
\p 
\v 16 ’¿'E₂ quian'₅₄ lé₂ le₃quɨ́ng₄ a₂lɨ́n₅ dsa₂ i₂chan₂ jmɨg₄ në₃? Lɨ́in₅ juɨ₁lia'₂ lɨ́n₅ i₂bë'₅₄ i₂tion'₅₄ co₅ jë₄ 'ma'₅₄, tioin'₅₄ co₂mɨ'₅₄ qui₂guió'₅ tsɨ́'₅ rɨin'₅₄:
\q1 
\v 17 Në₂jéi₄ jnia'₅₄ te₁fi₁ o₄quián'₂ 'nia'₂,
\q2 la₁ tsá₃ në₂dsián'₃ guë'₂ 'nia'₂;
\q1 ján₃ guë'₂ në₂jmó₁ jnia'₅₄ son₅₄ quió'₅ 'lag₄
\q2 a₂ta'₂ 'lia'₂ dsɨ́₅ dsa₂,
\q1 la₁ tsá₃ ca₂tá'₂ guë'₂ quɨ'₂ 'au'₂ 'nia'₂.
\m 
\v 18 Ia₁ ca₂guan₃ Juan₅₄, i₂tsá₃ 'e₂ 'lióng₂ jme₁guë́'₅ on₃ guë'₂ 'e₂ jme₁'ɨ́n'₂ në́₃, jaun₂ ca₂'ag₃ dsa₂ a₂'ein₅₄ je₂na'₅₄.
\v 19 Ca₂guan₃ guë'₂ táng₃ Jaun₅ dsa₂ mɨ₂güɨ́g₃ i₂guë́'₅ i₂'ɨ́n'₂, 'ag₅ táng₃ dsa₂ a₂lɨ́in₅ jlé₂ 'í₅ quian'₅₄ má₄ jmɨ́g₃, a₂lɨ́in₅ a₂mei₅₄ quián₅ dsa₂ cha₂ dsáu₁, quian'₅₄ dsa₂ i₂cán₂ 'lia'₅₄ quián₅ dsɨ₂tan₅₄ në́₃. La₁ tion₅₄ bá₄ le₃lí'₄ dsa₂ a₂dsau₅ jág₁ a₂ŋɨ́'₂ dsɨ́₅ Diú₄, 'uɨg₅₄ ia₁ ŋɨ́'₂ bá₄ dsɨ́₅ dsa₂ i₂gue₅ jág₁ në₅.
\s1 Juɨg₂ jë₁tsá₃ ne'₅₄ dsa₂
\r (Lucas 10:13-15)
\p 
\v 20 Jaun₂ në́₃, ca₂jme₃lióg₃ Jesús qui₂ca₂jéin₂ dsa₂ ja₁'lióng₂ guë́₄ léi₄ juë'₂ ma₂qui₂ma₂jmo₃, ia₁ tsá₃ ma₂jéin'₃ dsa₂ dsɨ́₅. Jaun₂ ca₂juá'₂:
\p 
\v 21 ―¡'E₂ guë́₄ juɨ́g'₂ 'nia'₂ dsa₂ juɨg₂ Corazín! ¡'E₂ guë́₄ juɨ́g'₂ 'nia'₂ i₂chan₂ Betsaida! Ia₁ jua'₅₄ mei'₂ guë́₃ jniá₂ ma₂jmo₃ léi₄ juë'₂ në₅ jë₄ juɨg₂ Tiro quian'₅₄ juɨg₂ Sidón juɨ₁lia'₂ a₂ma₂jmo₃ jniá₂ jë₄ quián'₂ 'nia'₂, lɨ́g'₂ bá₄ tsá₃ ma₂ca₂jéin'₃ dsa₂ 'éi₂ dsɨ́₅, jme₁cuë₃ léi₄ a₂quɨ'₂ dsɨ́₅ jme₁i₃nioi₅₄ le₁qui'₂ 'mɨ'₂ taun₅ qui₂le₁séin₅ ti₁juá₃ në́₃.
\v 22 La₁ juɨ́g₂ jniá₂ 'nia'₂, jmɨg₄ i₁qui₃dsɨ₅ Diú₄ 'éi'₃, ja₂lɨn₃ guë́₄ tson₂ uɨg₅ a₂guéi'₁ 'nia'₂ con'₂ guë́₄ dsa₂ i₂jme₁chan₂ Tiro quian'₅₄ Sidón.
\v 23 'Nia'₂ guë'₂ dsa₂ i₂chan₂ juɨg₂ Capernaum, ¿lɨ́n'₂ 'nia'₂ a₂uɨg'₅₄ guei'₅₄ lɨn₃? On₃jua'₅₄ le₂jaun₂. Të₂ ja₁jɨ'₂ lɨn₃ ja₁tion'₅₄ 'lag₄\f + \fr 11:23 \ft griego: hades, co₂'nió'₄ a₂juá'₂, ja₁quió'₄ 'lag₄.\f* bá₄ sén'₂ 'nia'₂. Ia₁ jua'₂ mei'₂ guë́₃ jniá₂ ca₂jmo₃ léi₄ juë'₂ jë₄ juɨg₂ Sodoma juɨ₁lia'₂ a₂ma₂ca₂jmo₃ jniá₂ jë₄ quián'₂ 'nia'₂, a₂niog₅ bá₄ juɨg₂ jaun₂ ca₂të₂ jmɨg₄ në́₃.
\v 24 Jaun₂ juá'₅ jniá₂, jmɨg₄ jë₁ma₂të́₂ rë₁qui₃dsɨ₅ Diú₄ 'éi'₃, 'ŋio₅ guë́₄ uɨg₅ guéi'₁ 'nia'₂ con'₂ guë́₄ dsa₂ i₂jme₁chan₂ juɨg₂ Sodoma.
\s1 Ja₁jŋia₅ dsa₂ i₂ma₂'ú'₃
\r (Lucas 10:21-22)
\p 
\v 25 Jmɨg₄ jaun₂ ca₂juá'₂ Jesús:
\p ―Jme₁juɨ́n'₁ jniá₂ 'ne₂, Tia₅₄, i₂lɨ́ng'₅ juɨg₅₄ gua'₅₄ 'uë₃ quian'₅₄ guei'₅₄ i₂juɨ́g₃, ia₁ ca₂'ma'₅₄ a₂në₅ ja₁con₂ dsa₂ i₂tɨn₂ si₂, i₂ŋɨ́'₂ dsɨ́₅, a₂ma₂ca₂jme₁jniag'₂ ja₁con₂ dsa₂ i₂lɨ́n₅ lia'₂ lɨ́n₅ guein₂, i₂tsá₃ 'e₂ cuɨ́'₅.
\v 26 Dsón'₂ bá₄ jaun₂, Tia₅₄, ia₁ le₂në₅ ca₂rë₃'ŋió₃ 'au'₂.
\p 
\v 27 Jaun₂ ca₂tsɨ́'₃ dsa₂:
\p ―O₄gu₃ jniá₂ ma₂ca₂dsia₃ Ŋe'₃ ca₂le₃jë́₃. 'I₁jan₂ tsá₃ 'ein₂ cuɨn₅ Ja₁ŋi'₅₄ Diú₄ 'a₂ lia'₂ të₃dsón'₂ lɨ́in₅, jŋia'₅₄ lia'₂ 'ŋiog₅ bá₄ Jmei₂; ján₃ bá₄ 'i₁jan₂ tsá₃ 'ein₂ cuɨn₅ Jmei₂ 'a₂ lia'₂ të₃dsón'₂ lɨ́in₅, jŋia'₅₄ lia'₂ 'ŋiog₅ bá₄ Ja₁ŋi'₅₄ táng₃, ján₃ bá₄ jme₃jniai₂₃ ja₁con₂ i₂'nio₃ le₃ŋi₅.
\v 28 I₂nó'₅ 'nia'₂ ja₁con₂ jniá₂, ca₂le₃jɨ́n'₃ 'nia'₂ i₂qui₂ma₂'ú'₃ dsɨ́₅, i₂qui₂le₁quian₅ guei₂, jaun₂ cuë₅₄ jniá₂ ja₁jan'₄ 'nia'₂.
\v 29 Gue₄ 'nia'₂ ta₁ quió₃ a₂cuë́₅ jniá₂ 'nia'₂, jme₁tɨn₅ 'nia'₂ jmó'₂ ján₃, 'a₂ lia'₂ lɨ́n₅ jniá₂, ia₁ juɨn'₂ dsɨ₃ lɨ́ng₅, meg'₂ bá₄ lë́₅ dsɨ₃; jaun₂ le₂në₅ bá₄ dsi₁nó'₅ 'nia'₂ dsiang'₂ ja₁jŋia₃ të₂'au'₂.
\v 30 Ia₁ ta₁ a₂cuë́₅ jniá₂ 'nia'₂, on₃jua'₅₄ a₂'ua'₂ ta₁; ján₃ bá₄ le₂jaun₂ on₃jua'₅₄ a₂guei₂ cán'₁ 'nia'₂ a₂cuë́₅ jniá₂ 'nia'₂.
\c 12
\s1 Jesús bá₄ i₂quian₅ 'éi'₃ ne₄ quió'₅ jmɨg₄ sa₅₄
\r (Marcos 2:23-28; Lucas 6:1-5)
\p 
\v 1 Jmɨg₄ jaun₂ ca₂ŋɨ₃ Jesús ja₁lë́₄ ja₁nau₂ quió'₅ dsa₂ caun₂ jmɨg₄ sa₅₄. Dsa₂ i₂quiain'₅₄ në́₃ ca₂tá'₂ i₁cón'₅, jaun₂ qui₂ca₂gág₃ mɨ́'₂ trigo, jaun₂ ca₂guë́'₃.
\v 2 Jme₁ca₂jág₂ dsa₂ fairseos, jaun₂ ca₂o₃léin₂ ca₂tsɨ́'₃ Jesús:
\p ―Jag₄ 'a₂ lia'₂ tion'₅₄ dsa₂ quiáng'₂ jmo₂₃ ta₁ a₂tsá₃ 'i₄ 'éi'₃ jmo₃ dsa₂ jmɨg₄ sa₅₄.
\p 
\v 3 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿Tsa₁ ma₂ca₂'í'₂ 'nia'₂ ne₄ Si₂ 'a₂ lia'₂ lë́₅ ca₂jmo₃ David co₂ráun₂ jme₁ca₂lë₃ i₁cón'₅ quiain'₅₄ rɨin'₅₄?
\v 4 Ca₂'í₃ dsi₂néi₂ quió'₅ Diú₄, ca₂guë́'₃ i₁ŋí'₄ jŋió₅, a₂tsá₃ jme₁'i₄ 'éi'₃ guë́'₃, a₂'i₄ 'éi'₃ guë́'₃ jmá'₃ jme₂dsa₂.
\v 5 ¿O₃ tsa₁ ma₂ca₂'í'₂ 'nia'₂ ne₄ Si₂ 'Éi'₃ quió'₅ Moisés, juɨ₁lia'₂ jme₂dsa₂ tsá₃ jme₂gó'₃ jmɨg₄ sa₅₄? La₁ tsá₃ 'ein₂ bón'₂ guë'₂ dso₄ 'éi₂ në́₃.
\v 6 Juɨ́g₂ jniá₂ 'nia'₂, ja₁lá₃ chén'₅ jan₂ i₂juɨn'₂ guë́₄ con'₂ guë́₄ guá'₅ templo.
\v 7 Jua'₅₄ mei'₂ guë́₃ ma₂ŋɨ́'₂ 'nia'₂ 'e₂ jein₅ jág₁ la₂: “A₂'nio₃ jniá₂ a₂dsiá'₁ 'nia'₂ ŋéi₂ 'au'₂, on₃jua'₅₄ rë'₂ a₂jŋia'₅₄ qui₁jen'₅₄ 'nia'₂ 'e₂ qui₁jen'₅₄ ne₃”,\f + \fr 12:7 \ft Oseas 6:6.\f* tsá₃ jua'₅₄ jme₁bong'₅₄ dso₄ dsa₂ i₂tsá₃ 'e₂ dso₄ rɨn₂.
\v 8 Ia₁ le₂në₅ jaun₂, jniá₂, Jaun₅ dsa₂ mɨ₂güɨ́g₃, jmo₂₃ 'éi'₃ juɨ₁lia'₂ jmɨg₄ sa₅₄.
\s1 Jan₂ dsa₂ jle₅ caun₂ gu₂
\r (Marcos 3:1-6; Lucas 6:6-11)
\p 
\v 9 Ca₂o₃'ɨ́n₃ bá₄ Jesús ja₁jaun₂, jaun₂ ca₂'í₃ táng₃ dsi₂néi₂ guá'₅ sinagoga.
\v 10 Ja₁jaun₂ jme₁'en₅₄ jan₂ dsa₂ i₂jle₅ caun₂ mɨ₂gu₂. Dsa₂ fariseos në́₃ jme₁'nio₃ 'no'₂ juɨ₅ bóin'₂ dso₄ Jesús, jaun₂ ca₂ŋag₃:
\p ―¿'I₄ 'éi'₃ jme₃'lión₂ dsa₂ jan₂ dsa₂ dso'₅₄ jme₁jmɨg₄ sa₅₄?
\p 
\v 11 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿'Ein₂ 'nia'₂, i₂'ŋio₅ jan₂ já'₂ cha'₂, në₁jua'₂ ca₂bain₃ siá₅ juɨ₁lia'₂ caun₂ jmɨg₄ sa₅₄, tsa₁ dsó₅ dsɨ₃dsein₂₃ já'₂ quiáin₅?
\v 12 ¡'Ë₂ guë́₄ bá₄ quen₅ jan₂ dsa₂ con'₂ guë́₄ jan₂ já'₂ cha'₂! Jaun₂ lë₃, 'i₄ bá₄ 'éi'₃ jmo₃ dsa₂ a₂dse₃ juɨ₁lia'₂ jmig₄ sa₅₄.
\p 
\v 13 Jaun₂ guë́₄ ca₂tsɨ́'₃ dsa₂ dso'₅₄ 'éi₂:
\p ―Nei'₅₄ gog'₂.
\p Jaun₂ ca₂néi'₃ 'éi₂ gu₂, ca₂jŋia₃ quió'₅, jaun₂ ca₂lë₃ co₂rë₂ quian'₅₄ a₂caun₂.
\v 14 Ca₂'uɨn₂ bá₄ dsa₂ fariseos 'éi₂ në́₃, jaun₂ ca₂jmo₃ jág₁ a₂jŋɨi'₃ Jesús.
\s1 Juɨ₁lia'₂ dsa₂ i₂ca₂quión'₂ Diú₄ a₂jme₃ti₃ ta₁ ne₅₄, jág₁ a₂ca₂'ë́₂ dsa₂ i₂ca₂juá'₂ o₄quió'₄ Diú₄
\p 
\v 15 Jme₁ca₂rë₃ŋi₅ Jesús jág₁ jaun₂, ca₂o₃'ɨ́in₃ bá₄. Jaun₂ juɨn₅ lɨn₃ dsa₂ i₃lén₂ chi₁co'₅₄ quió'₅ 'ein₂₃. Jme₁jme₂'lión₂ Jesús ca₂le₃jɨ́n₃ dsa₂ i₂le₁dso'₅₄,
\v 16 jaun₂ ca₂juá'₂ a₂tsá₃ 'e₂ dsia₃ dsa₂ jua'₅₄ a₂'ag₃ 'ein₂ lɨ́in₅.
\v 17 Le₂në₅ bá₄ ca₂lë₃ ia₁jaun₂ le₃ti₃ jág₁ a₂ca₂'ë́₂ Isaías, dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄, jme₁ca₂juá'₂ le₂la₂:
\q1 
\v 18 I₂la₂ bá₄ dsa₂ i₂jme₃ti₃ ta₁ ne₃,
\q2 i₂ma₂ca₂quiong'₅₄, i₂'nióg₃ guë́₄ lɨn₃,
\q2 jaun₂ 'io'₂ jéin₅ jniá₂ quiain'₅₄.
\q1 Tón'₁ jniá₂ Jme₂dsí₂ quiáng₃ të₂dsɨ́₅,
\q1 jaun₂ jme₃jniai₂₃ ca₂le₃jë́₃ juɨg₂
\q2 jɨn₄ dsɨ₂nau₂ 'ë₃ juɨ₅ dsau₅ të₃dsón'₂.
\q1 
\v 19 Tsá₃ quein₅ náu₃, on₃ guë'₂ guió'₃,
\q2 on₃ guë'₂ né'₂ jág₁ quió'₅ jë₄ calle,
\q1 
\v 20 Lia'₂ 'i₁ca₂tag₄ nɨ₁'ma₂ ta₅ tsá₃ jio₃,
\q2 on₃ guë'₂ ei₃ nɨ₁mecha a₂ca₂juɨg₄ 'ia₂ guë́₄ jme₁ŋi₁.
\q1 Jmo₃ le₂në₅ ca₂lia'₂ ca₂tió'₃
\q2 a₂lí'₂ a₂dsi₂ten₅₄ dsón'₂.
\q1 
\v 21 Jaun₂ caun₂ ja₁con₂ 'éi₂ bá₄
\q2 'ag₃ dsa₂ caun₂ dsɨ́₅
\q2 ca₂le₃jɨ́n₃ dsa₂ i₂chan₂ ca₂le₃jë́₃ juɨg₂.\f + \fr 12:21 \ft Isaías 42:1-4.\f*
\s1 Juá'₂ dsa₂ a₂'io₅ Jesús juɨ₅bí₂ quió'₅ Be'elzebú
\r (Marcos 3:19-30; Lucas 11:14-23, 12:10)
\p 
\v 22 Jaun₂ ca₂o₃jŋia₃ dsa₂ ja₁coin₂ jan₂ dsa₂ ten₄ i₂con₄ në́₃ i₂jme₁'en₅₄ jan₂ jme₂dsí₂ je₂na'₅₄. Jesús në́₃ ca₂jme₃'lió₂, ca₂jág₃ táng₃ dse₃, ca₂dsia₃ dse₃ jág₁ në́₃.
\v 23 Ca₂i₃gó'₃ dsɨ́₅ ca₂le₃jɨ́n₃ dsa₂, jaun₂ ca₂juá'₂:
\p ―¿On₁jua'₅₄ i₂në₅ lɨ́n₅ tsɨ₁jon₂ David?
\p 
\v 24 La₁ jme₁ca₂nág₂ dsa₂ fariseos jág₁ jaun₂, ca₂dsia₃ jág₁ quian'₅₄ rɨin'₅₄:
\p ―A₂'uɨn'₂ i₂në₅ je₂na'₅₄ quió'₅ dsa₂ të₂le₃ quian'₅₄ juɨ₅bí₂ quió'₅ Be'elzebú, juɨg₅₄ je₂na'₅₄ bá₄.
\p 
\v 25 La₁ i₂ŋi₅ rë₂ bá₄ Jesús 'e₂ dsɨ₂jiog₅ dsɨ́₅ dsa₂ 'éi₂, jaun₂ ca₂juá'₂:
\p ―Juɨ₁lia'₂ dsɨ₂tan₅₄ tion'₅₄ le₁dsoin'₅₄, nió'₅ mɨ'₅₄, tsá₃ uë́₂ tió'₅ jua'₅₄ tsá₃ dsɨ₃'én₂ 'éi'₃ quió'₅. Le₂në₅ bá₄ ján₃ juɨ₁lia'₂ dsa₂ caun₂ dsi₂néi₂, në₁jua'₂ lë́₅ le₁dsoin'₅₄, niog₅ mɨ'₅₄, ján₃ bá₄ tsá₃ uë́₂ tió'₅.
\v 26 Ján₃ bá₄ le₂në₅, në₁jua'₂ ca₂jmo₃ Satanás mɨ'₅₄ dsein₂₃ jan₂ i₂quiáin₅ 'ŋiog₅, co₂'nió'₄ 'ŋiog₅ bá₄ jmo₂₃ le₁dsoin'₅₄. ¿'A₂ lia'₂ lé₂ le₃'io₃ guë́₄ bí₂ 'éi'₃ quió'₅, chi₂jua'₂ le₂jaun₂?
\v 27 Chi₂jua'₂ jniá₂ 'uɨng'₅₄ je₂na'₅₄ quian'₅₄ bí₂ quió'₅ Be'elzebú juɨ₁lia'₂ juá'₂ 'nia'₂, ¿'ein₂ bá₄ guë'₂ cuë₅ bí₂ cuë́'₅ dsa₂ quián'₂ 'nia'₂ a₂'uɨ́in'₂ je₂na'₅₄ jaun₂ në́₃? 'Uɨg₅₄ jaun₂, guion₅₄ bá₄ dsa₂ quiáng'₂ jme₃li₅₄ a₂lɨ́n'₅ 'nia'₂ guiong'₅₄.
\v 28 La₁ jniá₂ në́₃ në₂'uɨng'₅₄ je₂na'₅₄ të₂le₃ quian'₅₄ bí₂ quió'₅ Jme₂dsí₂ quián₅ Diú₄. Jaun₂ në́₃ le₂në₅ bá₄ cuë₅ jniá₂ léi₄ a₂ma₂gua₅ 'éi'₃ quió'₅ Diú₄ ja₁con'₂ 'nia'₂.
\p 
\v 29 ’Jaun₂ në́₃, ¿'a₂ lia'₂ lé₂ le₃'í₂ jan₂ dsa₂ dsi₂néi₂ quió'₅ juɨ₁lia'₂ jan₂ dsa₂ i₂'uan'₂, a₂jŋiá'₃ a₂te₁'i₁ quió'₅, chi₂jua'₂ le₂'uɨg₅₄ tsá₃ ma₂në₂'nei'₂ de'₂ dsa₂? Jŋia'₅₄ lia'₂ le₂jaun₂ bá₄ lé₂ le₃jŋiá'₃ a₂cha₂ quió'₅.
\p 
\v 30 ’I₂tsá₃ tión₂ le₃quió₃ jniá₂, dsa₂ i₂'iog₅₄ jniá₂ bá₄ 'éi₂; le₂jaun₂ guë'₂ i₂tsá₃ quian'₅₄ jniá₂ cág'₅, jŋia'₅₄ jmo₂₃ tsɨ₁rë₂ja₅₄ bá₄.
\v 31 Juɨ́g₂ jniá₂ 'nia'₂ jaun₂ në́₃, a₂lé₂ le₃'én₂ bá₄ ca₂le₃jë́₃ dsáu₁ dsa₂, ca₂le₃jë́₃ 'e₂ a₂'lɨg'₅₄ juá'₂ në́₃. La₁ në₁jua'₂ ca₂'ɨin₃ 'lɨg'₅₄ Jme₂dsí₂ quián₅ Diú₄, a₂në₅ guë́₄ tsá₃ ma₃o₂'én₂ dso₄ cha₂.
\v 32 La₁ në₁jua'₂ chan₂ i₂ca₂'ɨn₃ 'lɨg'₅₄ Jaun₅ dsa₂ mɨ₂güɨ́g₃, lé₂ bá₄ le₂'én₂ dsáu₁; la₁ juɨ₁lia'₂ i₂'ɨn₅ 'lɨg'₅₄ Jme₂dsí₂ Jŋió₅, tsá₃ ma₃o₂'én₂ dso₄ cha₂ quió'₅, mɨ₂güɨ́g₃ la₂, on₃ guë'₂ mɨ₂güɨ́g₃ caun₂ në́₃.
\s1 Të₂le₃ 'a₂ lia'₂ lë́₅ mɨ́g₂ a₂'ag₅ bá₄ nɨ₁'ma₂, jáng'₅ léi₄
\r (Lucas 6:43-45)
\p 
\v 33 ’Chi₂jua'₂ jmo'₂ 'nia'₂ a₂le₃dse₃ nɨ₁'ma₂, mɨ́g₂ dse₃ bá₄ 'ag₃; la₁ chi₂jua'₂ jmo'₂ 'nia'₂ a₂le₃'lɨg'₅₄ nɨ₁'ma₂, mɨ́g₂ 'lɨg'₅₄ bá₄ 'ag₃ ján₃. 'Uɨg₅₄ jaun₂, të₂le₃ quian'₅₄ mɨ́g₂ a₂'ag₅ bá₄ nɨ₁'ma₂, jáng'₅ léi₄ chi₂jua'₂ dse₃ o₃ a₂'lɨg'₅₄ 'e₂.
\v 34 ¡'Nia'₂ tsɨ₁jon₂ dsɨ₂mɨ'₂! ¿'A₂ bá₄ lia'₂ lé₂ le₃dsiá'₁ 'nia'₂ jág₁ dse₃, ton'₂ 'lɨn'₅₄ bá₄ guë'₂ 'nia'₂ guiong'₅₄? Ia₁ lia'₂ con'₂ lë́₅ a₂'lióng₂ ŋag₅₄ cha₂ të₂dsɨ́₅ dsa₂, a₂jaun₂ bá₄ 'uë₂ mɨ₂'o₅₄.
\v 35 Juɨ₁lia'₂ dsa₂ dsen₃, jág₁ dse₃ bá₄ dsia₂₃, ia₁ jmá'₃ lia'₂ a₂dse₃ bá₄ rë₂'ma₄ të₂dsɨ́₅; le₂në₅ bá₄ juɨ₁lia'₂ dsa₂ 'lɨn'₅₄, jág₁ 'lɨg'₅₄ bá₄ dsia₂₃, ia₁ jmá'₃ lia'₂ a₂'lɨg'₅₄ bá₄ rë₂'ma₄ të₂dsɨ́₅.
\v 36 Jaun₂ juá'₅ jniá₂, jáng'₃ bá₄ dsa₂ mɨ₂güɨ́g₃ cuenta quió'₅ jë₁ma₂të́₂ jmɨg₄ i₁con₂ Diú₄ 'í₁, qui₃dsɨ₂₃ 'éi'₃ ne₄ ca₂le₃jë́₃ jág₁ a₂tsá₃ ta₁ tí₄.
\v 37 Ia₁ të₂le₃ 'a₂ lia'₂ lë́₅ jág₁ quián'₂ bá₄ 'nia'₂, jióg'₂ 'í₁, rɨng'₂ o₃ tsá₃ rɨng'₂.
\s1 Mɨ₅ dsa₂ fariseos a₂jmo₃ Jesús caun₂ léi₄ juë'₂
\r (Marcos 8:12; Lucas 11:29-32)
\p 
\v 38 Jaun₂ në́₃ i₂lɨn₅₄ dsa₂ fariseos quian'₅₄ të₅juá'₅ ca₂tsɨ́'₃ Jesús:
\p ―Të₅, 'niog₂ jnia'₅₄ jag₅₄ caun₂ léi₄ juë'₂ a₂jmó'₂ 'ne₂.
\p 
\v 39 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Tsɨ₁jon₂ dsa₂ 'lɨn'₅₄ i₂tsá₃ nag₃ la₂ mɨ₂₃ a₂jmo₅₄ jniá₂ caun₂ léi₄ juë'₂. La₁ tsá₃ ma₃'e₂ léi₄ lé₂ le₃cuë₅₄ jniá₂ ja₁con'₂ 'nia'₂, jŋia'₅₄ lia'₂ con'₂ léi₄ juɨ₁lia'₂ a₂ca₂i₃ŋɨ́₂ Jonás i₂jme₁'ë́₂ jág₁ o₄quió'₄ Diú₄ bá₄.
\v 40 Ia₁ juɨ₁lia'₂ ca₂'í₃ Jonás 'nɨ₅ jmɨg₄, 'nɨ₅ nei₅ të₂dsɨ́₅ já'₂ jmɨg₂ pan₅₄ 'éi₂, le₂jaun₂ bá₄ 'í₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ né'₃ 'uë₃ 'nɨ₅ jmɨg₄, 'nɨ₅ nei₅.
\v 41 Jmɨg₄ jë₁ma₂të́₂ rë₁con₂ Diú₄ 'í₁, dsa₂ i₂jme₁chan₂ juɨg₂ ciudad Nínive, dsa₂ 'éi₂ bá₄ náu₃ qui₃dsɨ₂₃ 'éi'₃ ján₃ ja₁con'₂ 'nia'₂ dsa₂ chang'₂ jmɨg₄ në₃. Ia₁ dsa₂ 'éi₂ ca₂jéin'₃ dsɨ́₅ lia'₂ con'₂ jme₁ca₂'ë́₂ Jonás jág₁ quió'₅ Diú₄. La₁ në₃ në́₃ la₂ chén'₅ jan₂ i₂juɨn'₂ guë́₄ lia'₂ con'₂ guë́₄ Jonás 'éi₂.
\v 42 'Io₅₄ rag₅₄ i₂jme₁gon₂ 'uë₃ të₂le₃ sur, ján₃ bá₄ náu₃ 'éi₂ jmɨg₄ i₁qui₃dsɨ₅ Diú₄ 'éi'₃, ján₃ guë'₂ 'liog'₃ 'éi₂ 'liain'₃ 'nia'₂ i₂chang'₂ jmɨg₄ në₃. Ia₁ 'éi₂ në́₃ ca₂já₃ uɨ́ng₂ lɨn₃ ca₂'í₃ juɨ₅ a₂ca₂o₃néi₃ jág₁ quió'₅ Salomón 'a₂ lia'₂ jme₁ŋɨ́'₂ dsɨ́₅ 'éi₂ a₂ŋɨ́₄ lë₃ jme₁tɨin₂;\f + \fr 12:42 \ft 'Í₂ 1 Reyes 10; 2 Crónicas 9:1-12.\f* la₁ në₃ në́₃, la₂ chén'₅ jan₂ i₂juɨn'₂ guë́₄ con'₂ guë́₄ Salomón 'éi₂.
\s1 Jme₂dsí₂ 'lɨn'₅₄ i₂jón'₂ táng₃
\r (Lucas 11:24-26)
\p 
\v 43 ’Jë₁ma₂o₂'ɨ́n₃ jan₂ jme₂dsí₂ 'lɨn'₅₄ quió'₅ jan₂ dsa₂, jaun₂ dsɨ₂ŋɨ́₃ le₂tan₅₄ ja₁quein₂ 'no'₂ ja₁jŋia₃. Në₁jua'₂ tsá₃ ca₂dsó'₂ ja₁jŋia₃ në́₃, jaun₂ 'no'₂ táng₃ dsɨ́₅:
\v 44 “Nég'₄ táng₃ dsi₂néi₂ quió₃ ja₁ca₂o₃'ɨ́ng₃.” Jë₁ma₂ca₂dsiáin'₃ jaun₂, dsain'₂ táng₃ dsa₂ 'éi₂ lɨ́in₅ co₂'nió'₄ bá₄ caun₂ dsi₂néi₂ a₂rë₂jë₄, rë₂'ia'₅₄, rë₂ chí'₅.
\v 45 Jaun₂ në́₃ o₂'ɨin₅₄ táng₃ dsó₅ chi₂liain'₂ con'₂ guë́₄ guion₃ jme₂dsí₂ 'lɨn'₅₄ rɨin'₅₄ i₂lë₁'ŋio₅ guë́₄ con'₂ guë́₄ 'ŋiog₅. Dsɨ₂lein₅ dsɨ₂tiain'₂ të₂dsɨ́₅ dsa₂ 'éi₂. Jaun₂ dsa₂ 'éi₂ në́₃, dsióg₄ léin₂ le₃'lɨin'₅₄ guë́₄ lɨn₃ guë́₄ con'₂ guë́₄ jme₁lɨ́in₄ le₂'uɨg₅₄.\f + \fr 12:45 \ft 'Nio'₂ ja₁ton₅ 2 Pedro 2:20.\f* Le₂në₅ bá₄ dsɨ₃ŋɨ́₂ tsɨ₁jon₂ 'lɨn'₅₄ i₂chan₂ rë₂në́₃.
\s1 Chi'₂ rɨn'₅₄ Jesús quian'₅₄ chog₅₄
\r (Marcos 3:31-35; Lucas 8:19-21)
\p 
\v 46 Të₃ 'en₅₄ Jesús dsia₂₃ jág₁ tsɨ́'₅ dsa₂, jme₁ca₂dsi₃lén₂ chi'₂ rɨin'₅₄ quiain'₅₄ chog₅₄ në́₃. Ca₁'né₄ bá₄ ca₂tiáin'₂ a₂'nio₃ dsia₃ jág₁ quiain'₅₄ Jesús.
\v 47 Jaun₂ ca₂i₁con₂ jan₂ jág₁, ca₂juá'₂:
\p ―Chog'₂ quian'₅₄ chi'₂ rɨ́ng'₂ tiáin'₅ ca₁'né₄, a₂'nio₃ dsia₃ jág₁ quian'₅₄ 'ne₂.\f + \fr 12:47 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ chi₁ton₅ \f*
\p 
\v 48 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿'Ein₂ 'éi₂ cha₃ jniá₂, 'ein₂ 'éi₂ rɨ́n'₃ jniá₂ në́₃?
\p 
\v 49 Jaun₂ në́₃ ca₂'ɨin₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ ca₂juá'₂:
\p ―I₂la₂ bá₄ lɨ́n₅ co₂'nió'₄ cha₃ jniá₂, quian'₅₄ rɨ́ng'₃ në́₃.
\v 50 Ia₁ juɨ₁'ein₂ guë́₃ i₂jmo₅ a₂'ŋio₂ dsɨ́₅ Ŋe'₃ jniá₂ i₂guá₅ guei'₅₄ i₂juɨ́g₃, i₂'éi₂ bá₄ lɨ́n₅ juɨ₁lia'₂ dsó₂ rɨ́ng'₃, 'io₅₄ rɨ́ng'₃, cha₃ në́₃.
\c 13
\s1 Jág₁ a₂jáng'₅ léi₄ juɨ₁lia'₂ dsa₂ i₂séi₂ mɨ́g₂ jon₂
\r (Marcos 4:1-9; Lucas 8:4-8)
\p 
\v 1 Jmɨg₄ jaun₂ ca₂o₃'ɨ́n₃ Jesús dsi₂néi₂ ja₁jme₁'ein₅₄, ca₂ŋó₃ ca₂i₁gua₂ chei'₅₄ jmɨ₁'ŋí'₄.
\v 2 Ia₁ ca₂ŋɨ'₂ táng₃ juɨn₅ lɨn₃ dsa₂ le₃lág'₃ quió'₅ ja₁guá₄, jaun₂ ca₂'í₃ 'ŋió'₃ tsɨ₁mu₅, jaun₂ ca₂guá₂. Jaun₂ dsa₂ guë'₂ në́₃ ca₂tóin'₂ ca₂le₃jɨ́in₃ chei'₅₄ jmɨg₂.
\v 3 Jaun₂ në́₃ ca₂jme₃tɨin₂₃ dsa₂ 'lióng₂ lɨn₃ jág₁ të₂le₃ quian'₅₄ jág₁ a₂jáng'₅ léi₄.
\p Ca₂juá'₂:
\p ―Jan₂ dsa₂ ca₂ŋe₄ ja₁nau₂ ca₂i₁séi₄ mɨ́g₂ jon₂;
\v 4 jme₁ma₂'ein₅₄ séi₂ në́₃, a₂lɨn₅₄ mɨ́g₂ jon₂ ca₂i₃ga'₅₄ le₂'i₄ juɨ₅, jaun₂ në́₃ i₁tan₅ bá₄ ca₂o₃lén₂ ca₂cág'₃.
\v 5 A₂lɨn₅₄ guë'₂ mɨ́g₂ jon₂ ca₂i₃to'₅₄ jë₄ nɨ₁cang₁, ja₁tsá₃ lɨn₄ gua'₅₄ lë́₅. A₂jaun₂ në́₃ tsá₃ uë́₂ ca₂rë₃'ag₄ ca₂'ia₂, ia₁ tsá₃ jɨ'₂ gua'₅₄ ja₁i₃to'₅₄.
\v 6 La₁ jme₁ca₂të́₂ 'iog₂, ca₂rë₃juɨng₅, ca₂cáu₂ bá₄ a₂jaun₂, ia₁ tsá₃ jmú₄ 'lióng₂ jme₁ma₂cha₂.
\v 7 A₂lɨn₅₄ guë'₂ i₃ga'₅₄ ja₁lë́₄ nɨ₁taun₅. Jme₁ca₂i₃cón₃ nɨ₁taun₅ në́₃, ca₂jlë₃ bá₄ jon₂ jaun₂ táng₃.
\v 8 La₁ a₂lɨn₅₄ guë'₂ në́₃ ca₂tɨ́n₂ ja₁'o'₅₄ 'uë₃; a₂jaun₂ ca₂rau₂ dse₃; a₂lɨn₅₄ mɨ́g₂ jon₂ ca₂'ág₂ jma₃cáun₃ 'ŋiá₂-láu₂ mɨ́g₂ lia'₂ ca₂mɨ́g₂ jon₂ a₂i₃jnia₄; a₂lɨn₅₄ guë'₂ jma₃'nag'₂ ne₂guióg₂ mɨ́g₂, a₂lɨn₅₄ guë'₂ jma₃guióg₂-guiá₂ mɨ́g₂.
\v 9 Chi₂jua'₂ 'ein₂ 'nia'₂ i₂dsi₅₄ rë₂gua₄, nei₂ 'nia'₂.
\s1 Ta₁ quí'₅ jág₁ a₂jáng'₅ léi₄
\r (Marcos 4:10-12; Lucas 8:9-10)
\p 
\v 10 Jaun₂ ca₂jme₃quián₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ con₂ Jesús, jaun₂ ca₂ŋag₃:
\p ―¿'E₂ lë₃ jme₂tɨ́ng'₁ dsa₂ jmá'₃ lia'₂ quian'₅₄ jág₁ a₂jáng'₅ léi₄?
\p 
\v 11 Jaun₂ në́₃ ca₂ŋag₃ Jesús:
\p ―Diú₄ bá₄ jmo₅ a₂rë₃ŋɨ́'₂ 'au'₂ 'nia'₂ jág₁ rë₂'ma₄ juɨ₁lia'₂ 'a₂ lia'₂ lë́₅ ja₁goin₂ guei'₅₄ i₂juɨ́g₃. La₁ ja₁con₂ dsa₂ në₅ në́₃, tsá₃ le₂jaun₂.
\v 12 Ia₁ juɨ₁lia'₂ dsa₂ i₂ŋɨ́'₂ dse₃, Diú₄ bá₄ jmo₃ le₃ŋɨ́i'₂ guë́₄ 'lióng₂, jaun₂ dsi₁léin₂ léin₂ dsa₂ i₂niog₅ dsi₄. La₁ juɨ₁lia'₂ i₂tsá₃ 'nio₃ le₃ŋɨ́'₂ në́₃, Diú₄ bá₄ jmo₃ co₂dsia₅ tsá₃ le₃ŋɨ́i'₂ co₂ŋei'₅₄.
\v 13 'Uɨg₅₄ jaun₂ bá₄ a₂jme₂tɨ́n₂ jniá₂ dsa₂ të₂le₃ quian'₅₄ jág₁ a₂jáng'₅ léi₄:
\q1 Ia₁jaun₂ i₂jág₃,
\q2 la₁ tsá₃ le₃lí'₄ 'e₂ a₂në₂jág₃;
\q1 i₂në₂néi₂ guë'₂ në́₃,
\q2 la₁ tsá₃ ca₂rë₃lí'₄ 'e₂ a₂në₂néi₂,
\q2 on₃ guë́₄ ca₂ŋɨ́i'₂.
\m 
\v 14 Jaun₂ le₂në₅ rë₂ti₃ të₂le₃ quió'₅ dsa₂ në₅ juɨ₁lia'₂ ca₂juá'₂ Isaías i₂ca₂'ë́₂ jág₁ quián₅ Diú₄:
\q1 Dsón'₂ bá₄ nág'₁ 'nia'₂,
\q2 la₁ tsá₃ le₃ŋɨ́g'₂ 'e₂ a₂nág'₁;
\q1 Caun₂ qui₁jag'₅₄ 'nia'₂ në́₃,
\q2 la₁ tsá₃ le₃len'₅₄ 'nia'₂.
\q1 
\v 15 Ia₁ a₂ma₂'ua'₂ dsi₄ bá₄ dsa₂ la₂,
\q2 ja₂lag₃ bá₄ nag₂₃,
\q1 në₂jag₄ bá₄ i₂ma₂rë₂jnɨ₅ rë₂gua₄;
\q1 ján₃ bá₄ le₂në₅, në₂jag₄ bá₄ a₂tsá₃ jniá₂ mɨ₂ne₅₄,
\q2 ia₁jaun₂ tsá₃ jág₃ quian'₅₄ mɨ₂ne₅₄,
\q2 on₃ guë'₂ nag₃ quian'₅₄ rë₂gua₅₄,
\q2 on₃ guë́₄ le₃ŋɨ́'₂ dsɨ́₅,
\q1 ia₁jaun₂ tsá₃ jéin'₃ dsɨ́₅ ja₁con₂ jniá₂
\q1 ia₁jaun₂ jme₁'lioin₁₂ jniá₂.\f + \fr 13:15 \ft Isaías 6:9-10.\f*
\p 
\v 16 ’La₁ 'e₂ guë́₄ dsen'₃ 'nia'₂ ia₁ jniá₂ mɨ₂ne'₅₄, nag'₂ bá₄ 'nia'₂ në́₃ quian'₅₄ rë₂guá'₂.
\v 17 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, juɨn₅ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂, juɨn₅ dsa₂ dsen₃, jme₁'nio₃ të₃ ne₅₄ a₂jág'₂ 'nia'₂ rë₂në́₃, la₁ tsá₃ ca₂jág₃; jme₁'nio₃ nag₃ në́₃ juɨ₁lia'₂ a₂nag'₂ 'nia'₂ rë₂në́₃, la₁ tsá₃ ca₂nág₂.
\s1 Juá'₂ Jesús tsɨ́'₅ dsa₂ lia'₂ tí₅ jág₁ 'e₂ jág₁ dsau₅ jáng'₅ juɨ₁lia'₂ jág₁ quió'₅ dsa₂ i₂séi₂ mɨ₂jon₂
\r (Marcos 4:13-20; Lucas 8:11-15)
\p 
\v 18 'Nei₂ 'nia'₂ jaun₂, 'e₂ jág₁ dsau₅ jáng'₅ juɨ₁lia'₂ jág₁ quió'₅ dsa₂ i₂séi₂ mɨ́g₂ jon₂.
\v 19 Juɨ₁lia'₂ dsa₂ i₂nag₅ jág₁ dse₃ a₂já₅ guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄, në₁jua'₂ tsá₃ ŋɨ́i'₂, lɨ́in₅ juɨ₁lia'₂ mɨ́g₂ jon₂ a₂ca₂séi'₂ dsi₂juɨ₅. I₂së₃dsen₃ bá₄ ja₂ ja₁coin₂, jaun₂ jŋiá'₂ táng₃ jág₁ dse₃ a₂jme₁ma₂jnia₄ të₂dsɨ́₅.
\v 20 Mɨ́g₂ jon₂ a₂ca₂séi'₂ guë'₂ jë₄ nɨ₁cang₁, lë́₅ juɨ₁lia'₂ lɨ́n₅ dsa₂ i₂gue₅ 'ŋio₂ dsɨ́₅ jág₁ dse₃ a₂nag₂₃,
\v 21 la₁ia₁ tsá₃ cha₂ guë'₂ jë₁dsɨ₃'má₂ jmú₄ né'₃ 'uë₃, tsá₃ uë́₂ tió'₅; jaun₂ jë₁ma₂já₅ o₂i₁ dsɨ₅ a₂dsɨ₂ŋɨ́i₂ 'e₂ dsɨ₂ŋɨ́i₂, o₃ qui₂co₂'ein₅ dsa₂ o₄quió'₄ jág₁ quió'₅ Diú₄, guein₂₃ tí₂ bá₄ táng₃ jág₁.
\v 22 Juɨ₁lia'₂ mɨ́g₂ jon₂ a₂i₃ga'₅₄ jë₄ nɨ₁taun₅ guë'₂ táng₃, jáng'₅ jág₁ dsau₅ juɨ₁lia'₂ dsa₂ i₂nag₅ jág₁ dse₃, la₁ia₁ 'ŋio₅ lɨn₃ guë́₄ 'ɨ₅ dsɨ́₅ o₂me'₅₄ dsɨ₅ a₂cha₂ mɨ₂güɨ́g₃ la₂, a₂'ɨ́n₅ dsɨ́₅ a₂le₃cha₂ cu₄ a₂le₃chain₂ dse₃ në́₃, a₂në₅ bá₄ a₂jme₂gau₅ táng₃ quió'₅. Ca₂le₃jë́₃ a₂në₅ jlë́₂ bá₄ táng₃ jág₁ dse₃ a₂jme₁ma₂nág₂, jaun₂ tsá₃ ma₂'e₂ a₂dse₃ ráu₃ ja₁con₂ dsa₂ 'éi₂.
\v 23 La₁ juɨ₁lia'₂ mɨ́g₂ jon₂ a₂ca₂séi'₂ ja₁dse₃ gua'₅₄, jáng'₅ táng₃ jág₁ dsau₅ të₂le₃ ja₁con₂ dsa₂ i₂nag₅ jág₁, ton'₂ ŋɨ́i'₂ në́₃; jaun₂ jmá'₃ lia'₂ ca₂ne₅₄ a₂dse₃ bá₄ rau₂ ja₁coin₂. I₂lɨn₅₄ guë'₂ dsa₂ 'éi₂ të₂le₃ quian'₅₄ a₂dse₃ rë₂jniá₂ a₂jmo₂₃, lɨ́in₅ juɨ₁lia'₂ lë́₅ lia'₂ ca₂cho'₅₄ mɨ́g₂ a₂ca₂i₃jnia₄, rau₂ caun₂ 'ŋiá₂-láu₂ mɨ́g₂ lia'₂ ca₂mɨ́g₂; i₂lɨn₅₄ guë'₂ jma₃'nag'₂ co₂ne₂guióg₂; i₂lɨn₅₄ guë'₂ jma₃guióg₂-guiá₂ mɨ́g₂.
\s1 Jág₁ a₂jáng'₅ léi₄ juɨ₁lia'₂ nɨ₁nau₂ 'lɨg'₅₄ a₂ca₂'ia₂ jë₄ trigo
\p 
\v 24 Ca₂juá'₂ Jesús táng₃ ca₂tsɨ́'₃ dsa₂ caun₂ jág₁ a₂jáng'₅ léi₄ siá'₂:
\p ―A₂lë́₅ guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄ lia'₂ lɨ́n₅ jan₂ dsa₂ i₂ca₂séi₂ ca₂ne₅₄ mɨ́g₂ jon₂ dse₃ 'uë₃ quió'₅;
\v 25 la₁ caun₂ 'uë₂ jme₁ma₂le₁güɨ́n₃ dsa₂ le₃jɨ́in₃, ca₂guan₃ jan₂ dsa₂ 'lɨn'₅₄ i₂'iog₅₄ ca₂jmo₃ uɨg₅ dsɨ́₅ ca₂guia'₃ jon₂ nɨ₁nau₂ 'lɨg'₅₄ jë₄ trigo, jaun₂ ca₂ŋái'₃ táng₃.
\v 26 Jme₁ca₂i₃cón₃ trigo, jme₁ma₂tio'₅₄ mɨ́'₂ në́₃, jë₄ jaun₂ ca₂'ia₂ nɨ₁nau₂ 'lɨg'₅₄ ján₃.
\v 27 Jaun₂ në́₃, dsa₂ i₂jme₂ti₃ ta₁ ne₄ juɨg₅₄ ja₁nau₂, ca₂i₁con₂ jág₁ ne₄ juɨg₅₄, ca₂juá'₂: “Gui'₅₄, ¿on₁jua'₅₄ jmá'₃ ca₂ne₅₄ mɨ́g₂ jon₃ dse₃ ca₂jŋí'₂ ja₁nau₂ quiáng'₂ jme₁ca₂jŋí'₂? ¿'A₂ guë'₂ lia'₂ ca₂lë₃ a₂ca₂'ia₂ nɨ₁nau₂ 'lɨg'₅₄ jaun₂ në́₃?”
\v 28 Jaun₂ ca₂ŋag₃ dsa₂ juɨg₅₄: “'An₁ jan₂ dsa₂ 'lɨn'₅₄ i₂'iog₅₄ bá₄ ca₂jmo₃ a₂në₅.” Jaun₂ ca₂ŋag₃ dsa₂ i₂jme₂ti₃ ta₁ ne₅₄: “¿Tsa₁ 'niog'₂ jua'₅₄ co₂dsia₅ dsɨ₁guéi₁ jnia'₅₄ nɨ₁nau₂ 'lɨg'₅₄ jaun₂?”
\v 29 Jaun₂ ca₂ŋag₃ táng₃ 'éi₂, ca₂juá'₂: “Jan₂'ón₄. Tió'₅ bá₄. Ia₁ con'₂ tsá₃ ŋó₅ në₁jua'₂ le₂jiog₅ tag₄ trigo dse₃ bá₄ ca₂cang₅.
\v 30 Ja₂lɨn₃ guë́₄ dse₃ juɨ₁le₁dsi₅₄ me'₂ jaun₂, juɨ₁dsi₂cón₃ bá₄ co₂lë₅, ca₂lia'₂ ca₂të́₂ jmɨg₄ i₁ráu₃; jaun₂ guë́₄ tsɨng₅₄ dsa₂ a₂dsɨ₃cang₅₄ de'₂ le₂'uɨg₅₄ nɨ₁nau₂ 'lɨg'₅₄, jaun₂ cág'₃ jmá'₃ co₂dsong'₅₄ ia₁jaun₂ 'nei₃, dsɨ'₂, jaun₂ guë́₄ cág'₃ trigo tó'₃ caun₂ ja₁tó'₃ dsi₂néi₂ quió₃.”
\s1 Jág₁ a₂jáng'₅ léi₄ juɨ₁lia'₂ mɨ́g₂ jon₂ quió'₅ nɨ₁'ma₂ mostaza
\r (Marcos 4:30-32; Lucas 13:18-19)
\p 
\v 31 Ca₂dsia₃ Jesús ján₃ caun₂ jág₁ a₂jáng'₅ léi₄ le₂la₂:
\p ―Ja₁gon₂ Diú₄ guei'₅₄ i₂juɨ́g₃, lë́₅ juɨ₁lia'₂ lë́₅ mɨ́g₂ jon₂ quió'₅ nɨ₁'ma₂ mostaza\f + \fr 13:31 \ft mostaza: On₃jua'₅₄ mɨ₁ján'₅ a₂cuɨ́'₅ dsa₂ go₄ jniog₄; caun₂ nɨ₁'ma₂ dsón'₂ jaun₂ a₂të́'₂ të₅sí₃ Brassica nigra.\f* a₂ca₂jné₂ jan₂ dsa₂ ja₁nau₂ quió'₅.
\v 32 Dsón'₂ mɨ́g₂ jon₂ jaun₂ lë́₅ mɨ́g₂ a₂pí'₁ tei₄ guë́₄ 'ŋio₅ lɨn₃ lia'₂ con'₂ guë́₄ mɨ́g₂ jon₂ siá'₂; la₁ia₁ jë₁ma₂ca₂i₃cón₃ në́₃, lë́₂ caun₂ nɨ₁'ma₂ pa₁ guë́₄ lia'₂ con'₂ guë́₄ rɨn'₅₄ a₂cha₂ ja₁nau₂ quió'₅, ca₂të₂ i₁tan₅ lé₂ le₃tiain'₃ gu'₂ nei'₅₄.
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ 'a₂ lia'₂ rón'₂ i₁ŋí'₄
\r (Lucas 13:20-21)
\p 
\v 33 Ca₂dsia₃ Jesús jág₁ a₂jáng'₅ léi₄ le₂la₂ táng₃:
\p ―Lë́₅ guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄, juɨ₁lia'₂ lë́₅ levadura a₂co₂güɨ́n'₂ jan₂ 'io₅₄ quian'₅₄ 'nɨ₅ tio'₅₄ ŋí₁ ca'₅₄\f + \fr 13:33 \ft griego: “'nɨ₅ tio'₅₄ ŋí₁ sata”, a₂tio'₅₄ con'₂ 22 litros le₂caun₂ ŋí₁.\f* ti₁juɨ₁ harina, ia₁jaun₂ ron'₂ dse₃ ca₂le₃jë́₃ ti₁can₁.
\s1 Ta₁ a₂quí'₅ jág₁ a₂jáng'₅ léi₄ a₂ca₂jme₃tag₅ Jesús
\r (Marcos 4:33-34)
\p 
\v 34 Ca₂le₃jë́₃ jág₁ la₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂ të₂le₃ quian'₅₄ jág₁ a₂jáng'₅ léi₄; 'i₁co₂ráun₂ tsá₃ jme₁jme₂tag₂₃ jua'₅₄ tsá₃ të₂le₃ quian'₅₄ jág₁ a₂jáng'₅ léi₄.
\v 35 Le₂në₅ ca₂jmo₃ ia₁jaun₂ le₃ti₃ jág₁ a₂jme₁ma₂rë₂'ë́₂ quió'₅ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂ jme₁ca₂juá'₂:
\q1 'Uë'₅₄ jniá₂ jág₁ 'o₃
\q2 të₂le₃ quian'₅₄ jág₁ a₂jáng'₅ léi₄;
\q1 dsia₅₄ jniá₂ jág₁ a₂tsá₃ ma₂ca₂rë₃jniá₂
\q2 ca₂le₃ ca₂jmo₃ Diú₄ mɨ₂güɨ́g₃.\f + \fr 13:35 \ft Salmo 78:2.\f*
\s1 Dsia₅ Jesús lia'₂ tí₅ jág₁ 'e₂ jág₁ dsau₅ jáng'₅ juɨ₁lia'₂ nɨ₁nau₂ 'lɨg'₅₄ a₂ca₂'ia₂ jë₄ trigo
\p 
\v 36 Jaun₂ në́₃, ca₂o₃'ɨ́n₃ Jesús jɨn₄ dsa₂ juɨn₅ ja₁jme₁'ein₅₄ jaun₂ ca₂'í₃ táng₃ caun₂ dsi₂néi₂. Jaun₂ ca₂o₃lén₂ táng₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ ja₁coin₂, ca₂juá'₂:
\p ―Dsia₄ lia'₂ tí₅ jág₁ 'e₂ jág₁ dsau₅ jáng'₅ juɨ₁lia'₂ jág₁ quió'₅ nɨ₁nau₂ 'lɨg'₅₄ a₂ca₂'ia₂ jë₄ trigo.
\p 
\v 37 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Dsa₂ i₂ŋɨ₅ séi₂ mɨ́g₂ jon₂ dse₃, Jaun₅ dsa₂ mɨ₂güɨ́g₃ bá₄ 'éi₂;
\v 38 ja₁nau₂ guë'₂ lë́₅ co₂'nió'₄ mɨ₂güɨ́g₃ la₂. Jon₂ dse₃ guë'₂ në́₃, co₂'nió'₄ lɨ́n₅ chi'₂-guein₂ i₂tion'₅₄ 'éi'₃ quió'₅ Diú₄. Nɨ₁nau₂ 'lɨg'₅₄ guë'₂ në́₃, co₂'nió'₄ dsa₂ i₂tion'₅₄ juɨ₅ 'éi'₃ quió'₅ i₂së₃dsen₃.
\v 39 Dsa₂ 'lɨn'₅₄ i₂'iog₅₄ i₂ca₂jné₂ jon₂ nɨ₁nau₂ 'lɨg'₅₄, i₂së₃dsen₃ bá₄ 'éi₂. I₁ráu₃ guë'₂ në́₃, lë́₅ jmɨg₄ jë₁ca₂tó'₂; i₂ja₃lén₂ ja₃cag'₅₄ guë́₄ në́₃, ángeles quián₅ bá₄ Diú₄.
\v 40 Jaun₂, juɨ₁lia'₂ cág'₅ dsa₂ nɨ₁nau₂ 'lɨg'₅₄, a₂tó'₅ dsi₂si₂, le₂në₅ bá₄ lé₂ ján₃ jmɨg₄ jë₁ca₂tó'₂ mɨ₂güɨ́g₃ la₂.
\v 41 Chen₃ Jaun₅ dsa₂ mɨ₂güɨ́g₃ ángeles quiáin₅ ia₁jaun₂ 'uɨ́in'₂ jë₄ quió'₅ dsa₂ quiáin₅ ca₂le₃jɨ́n₃ i₂jmo₅ qui₂sén'₂ rɨn'₅₄ a₂'no₂₃ dso₄, ca₂le₃jɨ́n₃ guë́₄ i₂ca₂rë₃chán₃ i₂tsá₃ ca₂tí₂ juɨ₅ 'lɨg'₅₄.
\v 42 Jaun₂ to'₂ ja₁néi'₅ tsɨ'₄ si₂, ja₁tóin'₃ quɨ'₂-'o₂₃, qui₃quɨ́g'₃ jan₅₄ në́₃.
\v 43 Jaun₂, dsa₂ dsen₃ quián₅ Diú₄ guë'₂ dsɨ₃lein₅ dsɨ₃tiain'₂ ja₁jniai₅₄ tág₅ juɨ₁lia'₂ jniá₂ 'iog₂ ja₁jmo₅ Diú₄ Jmei₂ 'éi'₃. Chi₂jua'₂ 'ein₂ 'nia'₂ i₂dsi₅₄ rë₂gua₄, rë₂ nei₂ 'nia'₂.
\s1 Jág₁ a₂jáng'₅ léi₄ juɨ₁lia'₂ caun₂ a₂quen₅ guë́₄ 'ŋio₅ lɨn₃ a₂rë₂'ma₄
\p 
\v 44 ’Guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄ ján₃ bá₄ lë́₅ juɨ₁lia'₂ caun₂ a₂quen₅ 'ŋio₅ lɨn₃ a₂rë₂'ma₄ rë₂'o₅ né'₃ 'uë₃. La₁ juɨ₁lia'₂ jan₂ dsa₂ i₂dso'₂ në́₃, ja₁jaun₂ bá₄ 'ma₂₃ táng₃; ia₁ a₂ŋɨ́₄ lë₃ 'io'₂ jén'₅, jaun₂ dsáin'₅ dsɨ₂'nág₂ ca₂le₃jë́₃ 'e₂ a₂cha₂ quió'₅, jaun₂ lá₅ 'uë₃ jaun₂.
\s1 Jág₁ a₂jáng'₅ léi₄ juɨ₁lia'₂ mɨ́g₂ perla a₂quen₅ lɨn₃
\p 
\v 45 ’Ján₃ bá₄ lë́₅ guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄ juɨ₁lia'₂ lɨ́n₅ jan₂ dsa₂ i₂ŋɨ₅ 'no'₂ perlas jlá'₁ ia₁jaun₂ jmo₃ 'ma'₅₄.
\v 46 Jë₁ma₂ca₂dsó'₂ ca₂mɨ́g₂ a₂quen₅ lɨn₃, dsáin'₅ dsɨ₂'nág₂ ca₂le₃jë́₃ 'e₂ a₂cha₂ quió'₅, jaun₂ lá₅ mɨ́g₂ jlá'₁ jaun₂.
\s1 Jág₁ a₂jáng'₅ léi₄ juɨ₁lia'₂ tsɨ₁'má₅
\p 
\v 47 ’Ján₃ bá₄ le₂jaun₂ lë́₅ guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄ juɨ₁lia'₂ lë́₅ caun₂ tsɨ₁'má₅ a₂táun₂ dsa₂ ne₄ jmɨ₁ŋí'₄ jaun₂ 'uɨ́in'₂ ca₂le₃jɨ́n₃ ne₅₄ já'₂.
\v 48 Jë₁ma₂ca₂rɨn₅ tsɨ₁'má₅, dsa₂ në́₃ 'ɨ́in₅ të₂le₃ chei'₅₄ jmɨ₁ŋí'₄; jaun₂ quióin'₂ jmá'₃ lia'₂ ju₄ dsen₃ caun₂ ja₁to'₂, jaun₂ guiain'₂ bá₄ juɨ₁lia'₂ já'₂ i₂tsá₃ dsen₃.
\v 49 Ján₃ bá₄ le₂jaun₂ lé₂ jmɨg₄ jë₁ca₂tó'₂ mɨ₂güɨ́g₃ la₂: 'uɨ́n₃ ángeles ja₃jmó₂ jma₃quén₅ dsa₂ 'lɨn'₅₄ jë₄ quió'₅ dsa₂ dsen₃
\v 50 jaun₂ toin'₂ i₂'lɨn'₅₄ ja₁néi'₅ tsɨ'₄ si₂ ja₁dsɨ₃toin'₅₄ quɨ'₂-'o₂₃ qui₃quɨ́g'₃ jan₅₄ në́₃.”
\s1 Juɨ₁lia'₂ cu₄nióg₄ 'mɨ́₂ quian'₅₄ cu₄nióg₄ gui'₅₄
\p 
\v 51 Jaun₂ ca₂ŋɨ́'₃ Jesús chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅:
\p ―¿Ŋɨ́g'₂ 'nia'₂ ca₂le₃jë́₃ jág₁ a₂juá'₅ jniá₂ në₅?
\p Jaun₂ ca₂ŋag₃:
\p ―Ŋág'₂ bá₄ jnia'₅₄.
\p 
\v 52 Jaun₂ ca₂juá'₂ Jesús në́₃:
\p ―Juɨ₁lia'₂ jan₂ të₅juá'₅ i₂ma₂ca₂jme₃tɨn₅ 'a₂ lia'₂ lë́₅ guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄, lɨ́in₅ juɨ₁lia'₂ lɨ́n₅ jan₂ juɨg₅₄ tsɨ₁'né₅ i₂'uë́'₅ a₂quen₅ a₂te₁'i₁ le₁'ma₁ dsi₂néi₂ quió'₅, lia'₂ cosas 'mɨ́₂ lia'₂ cosas gui'₅₄ në́₃.
\s1 'En₅₄ Jesús jë₄ juɨg₂ Nazaret
\r (Marcos 6:1-6; Lucas 4:16-30)
\p 
\v 53 Jme₁ca₂dsan₃ jme₂tɨn₅ Jesús dsa₂ jág₁ a₂jáng'₅ léi₄ në₅, ca₂o₃'ɨ́in₃ bá₄ ja₁jaun₂, ŋái'₃ juɨg₂ go₅₄.
\v 54 Jme₁ca₂dsiáin'₃ jaun₂ në́₃, ca₂jme₃lióg₃ ca₂jme₃tɨin₂₃ dsa₂ jág₁ dse₃ quió'₅ Diú₄ dsi₂néi₂ guá'₅ sinagoga quió'₅ dsa₂ ja₁jaun₂, jaun₂ dsa₂ në́₃, ca₂i₃gó'₃ dsɨ́₅ jág₁ a₂ca₂nág₂, jaun₂ ca₂dsia₃:
\p ―¿A₂já'₄ ca₂i₁jme₁tɨn₅ i₂në₅ jág₁ a₂ŋɨ́₄ lë₃ tɨin₂₃ në₅? ¿'A₂ bá₄ lia'₂ 'io₂₃ bí₂ a₂tɨin₂ jmo₃ o₂dsain₂ në́₃?
\v 55 ¿On₁jua'₅₄ i₂në₅ ja₁ŋi'₅₄ të₅'má₃? ¿On₁jua'₅₄ chog₅₄ i₂chen₂ María? ¿On₁jua'₅₄ i₂në₅ i₂lɨ́n₅ rɨn'₅₄ Santiago\f + \fr 13:55 \ft Santiago: ján₃ bá₄ chein₂ Jacobo.\f* quian'₅₄ Së́₄, Si₂mu₅₄, Judas në́₃?
\v 56 ¿On₁jua'₅₄ jë₄ quián₂ jniog₄ la₂ tián'₅ 'io₅₄ rɨin'₅₄ në́₃? ¿'A₂ bá₄ já'₄ já₅ a₂ŋɨ́₄ lë₃ cuɨ́'₅ i₂në₅ ca₂le₃jë́₃ jág₁ a₂tɨin₂ në₅?
\p 
\v 57 Jaun₂ tsá₃ dse₃ ca₂tɨ́n₂ dsa₂ jág₁ jaun₂ quió'₅, tsá₃ juɨ₅ ca₂tón'₃ dsa₂. La₁ ca₂juá'₂ Jesús:
\p ―Ca₂le₂con₂ bá₄ juɨg₂ siá'₂ jme₂gan₃ dsa₂ juɨ₁lia'₂ jan₂ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄; jŋia'₅₄ lia'₂ dsa₂ go₅₄ bá₄, tsá₃ jei₅₄, quian'₅₄ dsa₂ dsi₂néi₂ quió'₅ 'ŋiog₅ në́₃.
\p 
\v 58 Jaun₂ tsá₃ ma₃léi₄ juë'₂ lɨn₅₄ ca₂jmo₃ ja₁jaun₂, ia₁ tsá₃ guë'₂ 'én₂ dsa₂.
\c 14
\s1 Ca₂jon₃ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂
\r (Marcos 6:14-29; Lucas 9:7-9)
\p 
\v 1 Jmɨg₄ jaun₂ Herodes, i₂jme₁lɨ́n₄ dsi₄má'₂ 'uë₃ Galilea, ca₂rë₃ŋi₅ jág₁ a₂ŋɨ₅ Jesús le₂con₂ jaun₂.
\v 2 Jaun₂ dsia₂₃ tsɨ́'₅ dsa₂ i₂jme₂ti₃ ta₁ ne₅₄:
\p ―Juan₅₄ i₂chon₅ dsa₂ jmɨg₂ bá₄ në₅ ŋɨ₅; ma₂ca₂jein'₅₄ táng₃. 'Uɨg₅₄ jaun₂ 'io₂₃ juɨ₅bí₂ a₂jmo₂₃ léi₄ juë'₂.
\p 
\v 3 Ia₁ le₂jŋiá₅ ma₂ca₂jŋa'₃ dsa₂ Juan₅₄ 'éi'₃ quió'₅ Herodes, ca₂'nei'₂, ca₂to'₂ dsa₂ né'₃ 'má₃ në́₃. Ca₂jmo₃ le₂në₅ 'uɨg₅₄ quió'₄ 'io₅₄ Herodías i₂jme₁lë́₄ dsa₂ mɨ́₂ quián₅ Fe₂li₄ rɨin'₅₄.
\v 4 Ia₁ 'lióng₂ ráun₂ ma₂qui₂ma₂juá'₂ Juan₅₄ ma₂qui₂ma₂tsɨ́'₃ Herodes: “Tsá₃ 'i₄ 'éi'₃ cáng'₄ 'io₅₄ në₅.”
\p 
\v 5 'Uɨg₅₄ jág₁ jaun₂, jme₁'nio₃ Herodes jŋɨi'₃ Juan₅₄, la₁ tsá₃ tiá₂ dsɨ́₅, ia₁ jme₁gain₃ dsa₂; ia₁ ca₂le₃jɨ́n₃ bá₄ dsa₂ jme₁'éin₂ a₂lɨ́n₅ Juan₅₄ jan₂ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄.
\v 6 La₁ caun₂ jmɨg₄ në́₃, jme₁ca₂dsɨ́'₃ Herodes ŋi₂, ca₂o₃'ɨ́n₃ ja₁mɨ́g₄ 'io₅₄ Herodías, ca₂dsáin₂ jɨn₄ dsa₂ i₂té₁ jmɨg₄. A₂në₅ në́₃ ca₂të́₂ dsɨ́₅ 'ŋio₅ lɨn₃ Herodes,
\v 7 ca₂lia'₂ ca₂cuë₃ jág₁ quió'₅, ca₂le₃jë́₃ 'ɨin₂₃ Diú₄ a₂cuë₃ 'e₂ caun₂ a₂mɨ₃ 'io₅₄ bë'₅₄ 'éi₂.
\v 8 Jaun₂ në́₃, jme₁ma₂në₂tio'₂ chog₅₄ jág₁, ŋó₃, ca₂juá'₂:
\p ―Cuë₄ mɨ₂dsi₄ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂, të₂në₃, 'i₄ 'ŋió'₃ uɨng₅.\f + \fr 14:8 \ft lit. “rë₂dsɨ́₂ ne₄ caun₂ nɨ₁ŋí₁ charola.” \f*
\p 
\v 9 Jaun₂ ca₂tá'₂ 'lia'₂ dsɨ́₅ rag₅₄ jme₁ca₂nág₂ le₂në₅, la₁ tsá₃ ma₃'e₂ ŋi₅ jmo₃, ia₁ ma₂në₂cuë₃ jág₁ quió'₅ a₂'ɨin₂₃ Diú₄, të₃nag₅ dsa₂ i₂tion'₅₄ dsi₂néi₂ ja₁niog₅ jmɨg₄.
\v 10 Jaun₂ lë₃, ca₂jmo₃ 'éi'₃ a₂ca₂i₁qui'₂ dsa₂ mɨ₂dsi₄ Juan₅₄ dsi₂néi₂ tsɨ₁'né₅ 'má₃.
\v 11 Dsɨ₂juɨ₅ jaun₂ bá₄ ca₂o₃can₅ dsa₂ mɨ₂dsi₄ Juan₅₄ rë₂'i₄ 'ŋió'₃ uɨng₅,\f + \fr 14:11 \ft lit. “rë₂dsɨ́₂ ne₄ caun₂ nɨ₁ŋí₁ charola.” \f* jaun₂ ca₂cuë́'₃ 'io₅₄ bë'₅₄ 'éi₂, jaun₂ 'éi₂ në́₃ ca₂i₁con₂ ne₄ chog₅₄.
\p 
\v 12 Jme₁co₂lág₂ jaun₂ në́₃, ca₂o₃lén₂ dsa₂ i₂jme₁quian'₅₄ Juan₅₄, jaun₂ ca₂tág₃ 'lag₄ 'éi₂ ca₂i₁'ó₄. Jaun₂ guë́₄ ca₂i₁lein₅₄ ca₂i₁chi'₄ Jesús.
\s1 Ca₂jme₃tan₅₄ Jesús 'ŋiá₂ mei₅ dsa₂
\r (Marcos 6:30-44; Lucas 9:10-17; Juan 6:1-14)
\p 
\v 13 Jme₁ca₂rë₃ŋi₅ Jesús jág₁ në₅, ca₂o₃'ɨ́in₃ ja₁jme₁'ein₅₄, ca₂'í₃ 'ŋió'₃ caun₂ tsɨ₁mu₅, a₂jme₁i₂'i₅ caun₂ ja₁co₂'ŋiog₅. La₁ juɨn₅ dsa₂ juɨg₂ te₁'i₁ con'₂ ma₂quián₅ jaun₂ ca₂rë₃ŋi₅, jaun₂ ca₂'uɨin₂, ca₂i₁lein₅₄ ca₂i₁'ein₂₃ Jesús juɨ₅ tag₅₄.
\v 14 Jme₁ca₂dsióg₃ Jesús le₂'ŋo'₅₄ jmɨg₂, ca₂jág₃ juɨn₅ lɨn₃ dsa₂ ma₂tión₂ le₁jŋiog₅. Jaun₂ ca₂dsia₃ ŋéi₂ dsɨ́₅ dsa₂ 'éi₂, ca₂jme₃'lióin₂ dsa₂ i₂jme₁qui₂le₁dso'₅₄ quián₅ dsa₂.
\v 15 Të₂le₃ ca₂'láu₂ jaun₂, ca₂o₃lén₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ ca₂juá'₂ ca₂tsɨ́'₃ Jesús:
\p ―Ca₂'láu₂ bá₄ la₂, ton'₂ caun₂ ja₁co₂'ŋiog₅ bá₄ la₂ ja₁tsá₃ 'ein₂ tián'₅. 'Ei'₂ jág₁ dsa₂ ia₁jaun₂ dsɨ₃léin₂ le₂con₂ juɨg₂ ma₂quián₅ në₅, qui₂dsɨ₃lia₅ ca₂la₂ a₂guë́'₃.
\p 
\v 16 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Tsá₃ tion₅₄; cuë'₅₄ 'nia'₂ dsa₂ guiong'₅₄ a₂guë́'₃.
\p 
\v 17 Jaun₂ ca₂ŋag₃ chi'₂ dsɨ₂guia₃-tɨ́n₂:
\p ―Tsá₃ 'e₂ a₂siá'₂ cha₂ ja₁lá₃, jŋia'₅₄ lia'₂ 'ŋiá₂ i₁ŋí'₄ bá₄, quian'₅₄ on₃ i₁ju₁.
\p 
\v 18 Jaun₂ ca₂juá'₂ táng₃ Jesús:
\p ―O₂quian₂ 'nia'₂ ja₁lá₃.
\p 
\v 19 Jaun₂ në́₃, ca₂tsɨ́'₃ dsa₂ a₂tiain'₃ ne₄ 'uë₃. Jaun₂ ca₂jŋa'₃ ta₁'ŋiá₂ i₁ŋí'₄ quian'₅₄ le₃on₃ i₁ju₁, jaun₂ ca₂chóg'₃ ne₅₄ guei'₅₄ i₂juɨ́g₃, ca₂cuë́'₃ ti₁'mag'₄ Diú₄. Jaun₂ ca₂dsioin₃ le₂caun₂ le₂caun₂ i₁ŋí'₄, ca₂cuë́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂. Jaun₂ 'éi₂ guë́₄ në́₃ ca₂dsió'₃ jɨn₄ dsa₂.
\v 20 Ca₂le₃jɨ́n₃ bá₄ dsa₂ ca₂guë́'₃ ca₂lia'₂ ca₂'ág'₃ dsɨ́₅. Jme₁ca₂lë₃ guë́'₅, jaun₂ ca₂cág'₃ bá₄ guë́₄ guia₃-tɨ́n₂ tsɨ₁mɨ'₂ 'nau₅₄ a₂ca₂chóng₃.
\v 21 Dsa₂ i₂ca₂guë́'₃ 'éi₂ jme₁tén₄ 'ŋiá₂ mei₅ jmá'₃ lia'₂ dsa₂ ŋe'₂, i₂sián'₂ bá₄ dsa₂ mɨ́₂, chi'₂ në́₃.
\s1 Ca₂ŋɨ₃ Jesús ne₄ jmɨ₁ŋí'₄
\r (Marcos 6:45-52; Juan 6:16-21)
\p 
\v 22 Dsɨ₂juɨ₅ jme₁ca₂lë₃ jaun₂, ca₂jmo₃ Jesús 'éi'₃ a₂tón'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ 'ŋió'₃ tsɨ₁mu₅, a₂ŋɨ́₃ de'₂ 'éi₂ jmɨg₂ le₁jŋiái₄ lia'₂ con'₂ guë́₄ 'ŋiog₅ a₂dsɨ₃lein₃, të₁lia'₂ 'í₂ 'ŋiog₅ 'ág'₅ jág₁ dsa₂.
\v 23 Jme₁ca₂lë₃ 'ág'₅ jág₁ dsa₂, ca₂ŋó₃ juɨ₅ má'₂ i₁chi₂i₁lein'₄ Diú₄. Ca₂tó'₂ nei₂ jme₁ca₂tó'₂, jaun₂ bá₄ 'ein₅₄ 'ŋiog₅.
\v 24 Tsɨ₁mu₅ a₂tion'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ në́₃, jme₁ma₂dsióg'₃ dsi₂jo₂ jmɨ₁ŋí'₄. Jmɨg₂ në́₃, qui₂jná'₅ tiá₂ lɨn₃ dso'₂ tsɨ₁mu₅, ia₁ 'ei₅ tiá₂ dsí₂ 'liog'₂ le₃ca'₃.
\v 25 Le₁né₃ të₂le₃ ca₂jnia₃ jaun₂, ca₂jme₃quián₃ Jesús ja₁ŋáu'₄ tsɨ₁mu₅ tioin'₅₄.
\v 26 Jaun₂ në́₃ jme₁ca₂jág₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ jóin'₅ ŋɨ₂₃ ne₄ jmɨ₁ŋí'₄, ca₂juɨin'₂ ca₂tóin'₂ co₂mɨ'₅₄ ca₂guió'₃ ca₂juá'₂:
\p ―¡Jme₂dsí₂ 'lɨn'₅₄\f + \fr 14:26 \ft griego: fantasma.\f* bá₄ ó₃!
\p 
\v 27 La₁ dsɨ₂juɨ₅ bá₄ ca₂juá'₂ Jesús në́₃:
\p ―¡Dsia₄ 'nia'₂ tiá₂ 'au'₂! ¡Jniá₂ bá₄ la₂; tsá₃ lë₁juɨ́n'₂ 'nia'₂!
\p 
\v 28 Jaun₂ Pe₄ në́₃ ca₂ŋag₃:
\p ―Te₁gui'₅₄, chi₂jua'₂ 'ne₂ në₅, jmo₄ 'éi'₃ a₂nei₅₄ ŋɨ₅₄ ne₄ jmɨg₂ a₂dsióg₄ të₂ ja₁chéng'₄ në₅.
\p 
\v 29 ―Ŋia₅ jaun₂ ―ca₂juá'₂.
\p Jaun₂ ca₂sión₃ Pe₄ 'ŋió'₃ tsɨ₁mu₅, ca₂ŋɨ₃ ne₄ jmɨg₂ jme₁ŋó₄ ja₁chén'₄ Jesús.
\v 30 La₁ jme₁ca₂tón'₃ juɨ₅ ca₂jág₃ 'a₂ lia'₂ 'ei₅ tiá₂ dsí₂, ca₂ja₃gó'₃ dsɨ́₅, jaun₂ guë́₄ ca₂rë₃lióg₃ ca₂i₃'óin'₅ jmɨg₂. Ca₂guió'₃ tiá₂, ca₂juá'₂:
\p ―¡Lio₄ jniá₂, Te₁gui'₅₄!
\p 
\v 31 Dsɨ₂juɨ₅ jaun₂ ca₂néi'₃ Jesús gu₂, ca₂tɨ́in₂ quió'₅ Pe₄, jaun₂ juá'₂:
\p ―¡'E₂ guë́₄ ca₂juɨg₄ 'én'₂ 'ne₂! ¿'E₂ lë₃ në₂'éi'₂ caun₂-tɨn₃ 'au'₂?
\p 
\v 32 Jme₁ca₂i₃toin'₅₄ 'ŋió'₃ tsɨ₁mu₅, ca₂'ág₂ táng₃ tei₄ dsí₂.
\v 33 Jaun₂ i₂jme₁tion'₅₄ 'ŋió'₃ tsɨ₁mu₅ ca₂jmo₃ i₁'áin₃ ne₄ Jesús, ca₂jme₃juag'₂. Jaun₂ ca₂juá'₂:
\p ―Dsón'₂ bá₄ lɨ́ng'₅ Ja₁ŋi'₅₄ Diú₄.
\s1 Ca₂jme₃'lión₂ Jesús dsa₂ dso'₅₄ 'uë₃ Genesaret
\r (Marcos 6:53-56)
\p 
\v 34 A₂ca₂'ain₂ jmɨg₂ jaun₂, ca₂dsi₃lein₃ 'uë₃ Genesaret.
\v 35 Dsa₂ chan₂ ja₁jaun₂ në́₃, jme₁ca₂rë₃cuɨin₂₃ Jesús, jaun₂ ca₂i₁nioi₁₂ ca₂i₁can₅ jág₁ ca₂le₃jë́₃ juɨg₂ te₁'i₁ le₃lág'₃ jaun₂, jaun₂ ca₂o₃jŋia₃ dsa₂ ca₂le₃jɨ́n₃ dsa₂ i₂jme₁le₁dso'₅₄ ja₁'en₅₄ Jesús.
\v 36 Jaun₂ ca₂mɨ₃ tsá₃ a₂nag₅₄ o₁jŋia'₅₄ 'ág₃ tag₄ tsɨn'₅₄ bá₄ cuë₃ jmɨg₄ nɨ́'₃ dsa₂ i₂le₁dso'₅₄; jaun₂ në́₃, ca₂le₃jɨ́n₃ dsa₂ dso'₅₄ i₂qui₂ca₂nɨ́'₃ tsɨn'₅₄ Jesús, ca₂'lóin₂ co₂ŋei'₅₄ dso₄ a₂jme₁lɨ́in₄.
\c 15
\s1 Jme₂tag₅ Jesús juɨ₁lia'₂ 'e₂ jaun₂ a₂jmo₅ a₂rë₂'ŋio₅ dsa₂
\r (Marcos 7:1-23)
\p 
\v 1 Jaun₂ në́₃ ca₂o₃lén₂ i₂lɨn₅₄ dsa₂ fariseos quian'₅₄ të₅juá'₅ i₂ja₂lén₂ Jerusalén, ca₂jme₃quiáin₃ ja₁con₂ Jesús, jaun₂ ca₂ŋag₃:
\p 
\v 2 ―¿'E₂ lë₃ tsá₃ jme₂ti₃ dsa₂ i₂quiang'₅₄ tag₄ 'éi'₃ a₂chí'₅ quió'₅ dsa₂ can'₅₄? Tsá₃ rang₂₃ gu₂ né'₃ guë́₄ a₂guë́'₃.
\p 
\v 3 Jaun₂ ca₂ŋag₃ Jesús:
\p ―'Nia'₂ guë'₂ në́₃, ¿'E₂ lë₃ qui₂tsó'₂ 'nia'₂ 'éi'₃ quió'₅ Diú₄ a₂jme₂tí'₁ 'nia'₂ jmá'₃ lia'₂ tag₄ quián'₂ 'nia'₂ guiong'₅₄?
\v 4 Ia₁ ca₂juá'₂ Diú₄: “Jme₁gan₃ 'nia'₂ chog'₂-ŋéi'₅.”\f + \fr 15:4 \ft Éxodo 20:12; Deuteronomio 5:16.\f* Ján₃ bá₄ ca₂juá'₂: “I₂të₂'on'₂ jmei₂, o₃ i₂të₃'on'₂ chog₅₄, ca₂tɨ́in₂ jóin₂.”\f + \fr 15:4 \ft Éxodo 21:17; Levítico 20:9.\f*
\v 5 La₁ 'nia'₂ në́₃ jme₂tɨ́ng'₁ dsa₂, në₁'ein₂ cha₂ quió'₅ a₂lé₂ le₃jme₃'oin₅₄ chog₅₄-jmei₂, la₁ lag₃ në₁ca₂tsɨ́'₃ dsa₂ chog₅₄-jmei₂: “A₂ma₂rë₂jen'₅₄ ne₄ Diú₄ bá₄ a₂jaun₂”,
\v 6 jaun₂ në́₃, jme₂tɨ́n'₂ 'nia'₂ dsa₂ 'éi'₃ a₂tsá₃ ma₃tion₅₄ 'nió'₅ jme₃'on₅₄ dsa₂ chog₅₄-jmei₂. O₄quió'₄ tag₄ quián'₂ 'nia'₂ guiong'₅₄ bá₄ ma₂ja₂nó'₅ 'nia'₂ jmo'₂ tsá₃ ma₃'e₂ quen₅ 'éi'₃ quió'₅ Diú₄.
\v 7 ¡'Nia'₂ dsa₂ i₂lë₁jmo₅-dsáu₅ o₁ne₁ a₂jmo'₂ 'nia'₂ a₂jme₂juɨ́ng'₁ Diú₄ quian'₅₄ tag₄ quiáng'₂ ja₂nóg'₅! Dsón'₂ bá₄ dsau₅ a₂ca₂juá'₂ Isaías i₂jme₁'ë́₂ jág₁ quián₅ Diú₄, jme₁ca₂tióng₃ ne₄ si₂, 'ɨin₂₃ 'nia'₂, jme₁ca₂juá'₂:
\q1 
\v 8 Dsa₂ juɨg₂ la₂ jme₂juag'₂ jniá₂
\q2 jmá'₃ lia'₂ quian'₅₄ mɨ₂'o₅₄ bá₄,
\q1 la₁ia₁ uɨ́ng₂ bá₄ 'i₄ dsɨ́₅
\q2 ja₁con₂ jniá₂.
\q1 
\v 9 La₁ tsá₃ 'e₂ ta₁ tí₄ a₂jme₂juag'₂,
\q2 ia₁ jág₁ a₂jme₂tag₂₃
\q1 jmá'₃ 'éi'₃ quió'₅ dsa₂ mɨ₂güɨ́g₃ bá₄ jaun₂.\f + \fr 15:9 \ft Isaías 29:13.\f*
\p 
\v 10 Jaun₂ ca₂të́'₃ Jesús dsa₂ juɨn₅ i₂ma₂quiain'₅₄ a₂jme₃quián₃ 'éi₂ ja₁coin₂, jaun₂ ca₂juá'₂:
\p ―Rë₂ nei₂ 'nia'₂ a₂la₂; juɨ₁le₂ŋɨ́'₂ 'nia'₂:
\v 11 Juɨ₁lia'₂ a₂dsɨ₂to'₅₄ juɨ₅ mɨ₂'o₄ dsa₂, on₃jua'₅₄ a₂jaun₂ jmo₅ a₂rë₃'iog₅ jme₂dsí₂ quió'₅ dsa₂. Ca₂le₃jë́₃ a₂'uë₂ juɨ₅ mɨ₂'o₄ dsa₂, a₂jaun₂ bá₄ jmo₅ a₂rë₂'iog₅ jme₂dsí₂ quió'₅ dsa₂.
\p 
\v 12 Jaun₂ ca₂jme₃quián₃ chi'₂ dsɨ₂guia₃-tɨ́n₂, jaun₂ ca₂juá'₂:
\p ―¿Tsa₁ ŋi'₅₄, 'ŋio₅ lɨn₃ tsá₃ dse₃ ca₂tɨ́n₂ dsa₂ fariseos jág₁ a₂në₂chei'₅₄?
\p 
\v 13 La₁ ca₂ŋag₃ Jesús:
\p ―Ca₂le₃jë́₃ nɨ₁'ma₂ a₂tsá₃ ca₂chéin'₃ Ŋe'₃ jniá₂ i₂guá₅ guei'₅₄ i₂juɨ́g₃, guéi₃ le₂jiog₅ jmú₄.
\v 14 O₁lë́₄ me'₂; ia₁ dsa₂ ten₄ bá₄ në₅ quian₅ ne₄ juɨ₅.\f + \fr 15:14 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “ia₁ i₂jŋia₅ dsa₂ ten₄ bá₄ në₅.” \f* Ia₁ në₁jua'₂ jan₂ dsa₂ ten₄ jŋiai₂₃ dsa₂ ten₄ rɨin'₅₄, le₃oin₃ bá₄ tsɨ₃séin'₂ siá₅.
\p 
\v 15 Jaun₂ ca₂juá'₂ Pe₄ ca₂tsɨ́'₃ Jesús:
\p ―Jua'₅₄ 'e₂ jág₁ dsau₅ jáng'₅ jág₁ në₅.
\p 
\v 16 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿Ján₃ bá₄ tsá₃ ŋɨ́'₂ 'au'₂ 'nia'₂?
\v 17 Ia₁, ¿tsa₁ ŋɨ́'₂ 'nia'₂, juɨ₁lia'₂ ca₂le₃jë́₃ a₂dsɨ₂to'₅₄ juɨ₅ rë₂'o₄ dsa₂, dsɨ₂lé₂ rë₂tú'₅ bá₄ dsa₂, cang₂ jaun₂ 'uë₂ táng₃?
\v 18 La₁ juɨ₁lia'₂ a₂'uë₂ juɨ₅ mɨ₂'o₄ dsa₂, a₂jaun₂ a₂já₅ të₂dsɨ́₅ bá₄ dsa₂. A₂jaun₂ bá₄ jmo₅ a₂rë₂'iog₅ jme₂dsí₂ quió'₅ dsa₂.
\v 19 Ia₁ të₂dsɨ́₅ bá₄ dsa₂ já₅ ca₂le₃jë́₃ a₂'lɨg'₅₄ a₂dsɨ₂jiog₅ dsɨ́₅: juɨ₁lia'₂ a₂jme₂dsian₅ dsa₂ dsa₂ mɨ₂güɨ́g₃ rɨin'₅₄: juɨ₁lia'₂ a₂nió'₅ dsa₂ jág₁ quian'₅₄ dsa₂ i₂tsá₃ lɨ́n₅ dsɨ₂i₂gu₂, juɨ₁lia'₂ a₂lë₁i₂nio₄ dsa₂ tiáin'₅, tsá₃ gu₂ le₁jen'₂; juɨ₁lia'₂ a₂'ang₅ dsa₂; juɨ₁lia'₂ a₂nau₂ dsa₂ a₂jáng'₅ jág₁ dsau₅ a₂jmo₂₃ të₂jɨ́in₁; juɨ₁lia'₂ a₂jmo₅ dsa₂ a₂lë₁bóin'₂ dso₄ rɨin'₅₄ në́₃.
\v 20 Ca₂le₃jë́₃ a₂në₅ bá₄ jmo₅ a₂rë₂'iog₅ jme₂dsí₂ quió'₅ dsa₂; la₁ a₂guë́'₅ dsa₂ të₃ tsá₃ ma₂në₂jme₃ti₃ 'éi'₃ tag₄ a₂chí'₅ a₂rang₂₃ gu₂, on₃jua'₅₄ a₂jaun₂ jmo₅ a₂rë₂'ŋio₅ dsa₂.
\s1 Jan₂ i₁náu₃ i₂ca₂rë₃'én₂ të₂le₃ quió'₅ Jesús
\r (Marcos 7:24-30)
\p 
\v 21 O₂'ɨ́n₃ bá₄ Jesús ja₁jaun₂, ca₂ŋó₃ táng₃ juɨ₅ juɨg₂ Tiro quian'₅₄ Sidón.
\v 22 Ja₁jaun₂ jan₂ 'io₅₄ cananea i₂guá₅ jë₄ juɨg₂ jaun₂, ca₂guain₃ con₂ Jesús 'o₂₃ co₂mɨ'₅₄, juá'₂ tiá₂:
\p ―¡Te₁gui'₅₄, jaun₅ David, dsia₄ ŋéi₂ 'au'₂ jniá₂! Jan₂ chi'₂ ja₁mɨ́g₄ jniá₂ 'en₅₄ jan₂ jme₂dsí₂ je₂na'₅₄ të₂dsɨ́₅, 'ŋio₅ lɨn₃ ŋág₅ uɨg₅.
\p 
\v 23 La₁ tsá₃ 'e₂ ca₂ŋag₃ Jesús 'i₁caun₂. Jaun₂ o₃lén₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ ca₂juá'₂:
\p ―Chei'₅₄ i₂në₅ juɨ₁dsiain'₅₄, ia₁ já₅ guió'₅ co₂mɨ'₅₄ chi₁co'₅₄ quián₂ jniog₄.
\p 
\v 24 Jaun₂ ca₂ŋag₃ Jesús ca₂tsɨ́'₃ 'io₅₄ 'éi₂:
\p ―Ca₂chei₃ Diú₄ jniá₂ a₂guio₃ jmá'₃ lia'₂ ca₂ne₅₄ o₄quió'₄ já'₂ cha'₂ i₂ma₂i₂cón'₅ chan₂ juɨg₂ Israel.
\p 
\v 25 La₁ caun₂ já₅ bá₄ 'io₅₄ 'éi₂, ca₂chi₃jné₃ ne₄ Jesús, ca₂juá'₂:
\p ―¡Te₁gui'₅₄, jme₁'o₄ jniá₂!
\p 
\v 26 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Tsá₃ dsi₂ten₅₄ jua'₅₄ a₂jŋiá'₄ jniá₂ i₁ŋí'₄ quió'₅ chi'₂-guein₂ a₂cuë́₄ dsɨ₂jɨ'₅₄.
\p 
\v 27 Jaun₂ ca₂ŋag₃ táng₃ 'io₅₄:
\p ―Dsón'₂ bá₄ dsau₅, Te₁gui'₅₄; la₁ cág'₅ bá₄ dsɨ₂jɨ'₅₄ nɨ₁jne₁ a₂tsɨ₂séi'₂ ne₄ mesa ja₁guë́'₅ juɨg₅₄.
\p 
\v 28 Jaun₂ ca₂ŋag₃ táng₃ Jesús:
\p ―¡'E₂ guë́₄ tson₂ 'én'₂ 'ne₂, dsa₂ mɨ́₂! Juɨ₁le₅₄ bá₄ lia'₂ con'₂ lë́₅ a₂mɨ'₂ në₅.
\p Dsɨ₂juɨ₅ le₂jaun₂ bá₄ ca₂'lón₂ chi'₂ ja₁mɨ́g₄ 'io₅₄ 'éi₂.
\s1 Ca₂jme₃'lión₂ Jesús juɨn₅ dsa₂ dso'₅₄
\p 
\v 29 O₂'ɨ́n₃ bá₄ táng₃ Jesús ja₁jaun₂, jaun₂ ca₂ŋɨ́i₃ juɨ₅ chei'₅₄ jmɨ₁ŋí'₄ Galilea; jaun₂ ca₂uɨ́g₂ juɨ₅ ne₄ má'₂, jaun₂ ca₂guá₂ jme₁dsióg₃.
\v 30 Juɨn₅ dsa₂ ca₂dsi₃lén₂ táng₃ cau₅ quió'₅ ja₁jaun₂, le₁jŋiai₂₃ dsa₂ guian'₅₄, dsa₂ i₂le₁já'₂ gu₂-tag₄, dsa₂ ten₄, dsa₂ con₄, juɨn₅ guë́₄ dsa₂ sián'₂ i₂jme₁le₁dso'₅₄ në́₃. Qui₂ca₂dsiog₃ ja₁chén'₄ Jesús, jaun₂ ca₂jme₃'lió₂ 'éi₂.
\v 31 Jaun₂ guë́₄ ca₂i₃gó'₃ dsɨ́₅ dsa₂ jme₁ca₂të́₂ ne₅₄ ma₂dsia₅ jág₁ dsa₂ i₂jme₁con₄, ma₂i₂nio₄ dsa₂ i₂jme₁qui₂le₁já'₂ quió'₅, quian'₅₄ dsa₂ guian'₅₄ në́₃; dsa₂ ten₄ në́₃ qui₂ca₂jág₃. Jaun₂ ca₂tón'₂ dsa₂ ca₂jme₃juɨin'₂ Diú₄ quián₅ dsa₂ Israel.
\s1 Ca₂jme₃tan₅₄ Jesús quén₂ mei₅ dsa₂
\r (Marcos 8:1-10)
\p 
\v 32 Jaun₂ ca₂të́'₃ Jesús chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ ca₂juá'₂:
\p ―'Ŋio₅ ŋéi₂ dsɨ₃ jɨng₅₄ dsa₂ në₅, ia₁ ma₂'nɨ₅ jmɨg₄ tioin'₅₄ ja₁lá₃ quian'₅₄ jniá₂, 'i₁ca₂juɨg₄ tsá₃ 'e₂ cha₂ a₂guë́'₃ ja₁lá₃. Jaun₂ në́₃, tsá₃ 'nio₃ jniá₂ dsiain'₅₄ të₃ tsá₃ ma₂në₂guë́'₃, ia₁ con'₂ tsá₃ ŋó₅ në₁ca₂'uáin₂ le₂'i₄ juɨ₅.
\p 
\v 33 Jaun₂ ca₂juá'₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅:
\p ―¿A₂já'₄ lé₂ dsɨ₁liá₄ i₁ŋí'₄ ja₁co₂'ŋiog₅ la₂ a₂guë́'₃ dsa₂ juɨn₅ në₅?
\p 
\v 34 Jaun₂ ca₂ŋag₃ Jesús ca₂ŋɨ́i'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂:
\p ―¿Je₂liá'₂ i₁ŋí'₄ 'i₄ guë́₄ quián'₂ 'nia'₂?
\p Jaun₂ ca₂ŋag₃ 'éi₂:
\p ―Guio₃ i₁ŋí'₄ bá₄ 'i₄, quian'₅₄ guë'₂ on₃-ún₂ ju₄ pí'₁.
\p 
\v 35 Jaun₂ ca₂jmo₃ 'éi'₃ a₂tian'₃ dsa₂ 'uë₃,
\v 36 jaun₂ ca₂jŋa'₃ ta₁guio₃ i₁ŋí'₄ quian'₅₄ i₁ju₁ në́₃, ca₂cuë́'₃ ti₁'mag'₄ Diú₄. Jaun₂ ca₂dsioin₃ le₂caun₂ le₂caun₂ i₁ŋí'₄, ca₂cuë́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ 'éi₂ guë́₄ në́₃ ca₂dsió'₃ jɨn₄ dsa₂.
\v 37 Ca₂le₃jɨ́n₃ bá₄ dsa₂ 'éi₂ ca₂guë́'₃ ca₂lia'₂ ca₂'ág'₃ dsɨ́₅. Jaun₂ ca₂cág'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ guio₃ tsɨ₁mɨ'₂ jmá'₃ nɨ₁jne₁ a₂ca₂chóng₃.
\v 38 Dsa₂ i₂ca₂guë́'₃ 'éi₂ jme₁lë́₂ quén₂ mei₅ jmá'₃ dsa₂ ŋe'₂, i₂sián'₂ bá₄ dsa₂ mɨ́₂ quian'₅₄ chi'₂ në́₃.
\v 39 Jme₁ca₂lë₃ jaun₂, ca₂'ág'₃ Jesús jág₁ dsa₂, jaun₂ ca₂'í₃ 'ŋió'₃ tsɨ₁mu₅ a₂ŋó₃ juɨ₅ jë₄ juɨg₂ Magadán.\f + \fr 15:39 \ft o₃, Magdala, ja₁chan₂ María Magdalena.\f*
\c 16
\s1 Dsa₂ fariseos quian'₅₄ dsa₂ saduceos mɨ₂₃ ne₄ Jesús a₂jmo₃ 'éi₂ caun₂ léi₄ juë'₂
\r (Marcos 8:11-13; Lucas 12:54-56)
\p 
\v 1 Dsa₂ fariseos quian'₅₄ dsa₂ saduceos i₁lein₅₄ i₁jɨin₅₄ Jesús, ia₁ a₂'no'₂ juɨ₅ 'a₂ lia'₂ tiain'₃ Jesús quian'₅₄ jág₁; jaun₂ ca₂mɨ₃ a₂jmo₃ 'éi₂ caun₂ léi₄ a₂já₅ guei'₅₄ i₂juɨ́g₃.
\p 
\v 2 La₁ ca₂ŋag₃ Jesús:
\p ―['Nia'₂ tɨng'₂ jág'₁ të₂le₃ ca₂'láu₂ jme₁lɨn₅₄, juá'₂ 'nia'₂: “Dse₃ bá₄ 'ei₅ táng₃ 'ióg₃, ia₁ guéin₂ bá₄ jniá₂ guei'₅₄ mɨ₂güɨ́g₃.”
\v 3 Ján₃ bá₄ juá'₂ 'nia'₂ jme₁lɨn₅₄ juɨ₁lia'₂ të₃ o₃'iog₂, “Tiá'₃ jmɨ́₅ në₃, ia₁ guéin₂ jniá₂ jnei₅ tio'₅₄ guei'₅₄.” Ŋi'₅₄ bá₄ 'nia'₂ 'a₂ lia'₂ jua'₅₄ 'e₂ jein₅ jág₁ 'a₂ lia'₂ jniá₂ guei'₅₄, jŋia'₅₄ lia'₂ 'e₂ a₂të₅ ne'₅₄ 'nia'₂ jmɨg₄ në₃ bá₄, tsá₃ ŋi'₅₄ 'nia'₂ 'e₂ jein₅ jág₁.]\f + \fr 16:3 \ft A₂lɨn₅₄ chog₅₄ si₂ gui'₅₄ guë́₄ tsá₃ chi₁ton₅ jág₁ a₂tio'₅₄ 'ŋió'₃ corchetes [le₂la₂].\f*
\v 4 Tsɨ₁jon₂ dsa₂ 'lɨn'₅₄ i₂tsá₃ nag₃ la₂, mɨ₂₃ a₂jmo₅₄ jniá₂ caun₂ léi₄ a₂o₂dsang₂. La₁ 'i₁caun₂ léi₄ siá'₂ tsá₃ 'e₂ ŋe'₂ 'nia'₂, jŋia'₅₄ lia'₂ caun₂ léi₄ juɨ₁lia'₂ a₂ca₂i₃ŋɨ́₂ Jonás bá₄.
\p Jaun₂ ca₂tén₂ bá₄ Jesús dsa₂ 'éi₂, ca₂ŋái'₃.
\s1 Levadura quió'₅ dsa₂ fariseos
\r (Marcos 8:14-21)
\p 
\v 5 Jme₁ca₂'an₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ jmɨ₁ŋí'₄, ca₂dsáu'₃ dsɨ́₅ tsá₃ 'e₂ i₁ŋí'₄ le₁quian₅ guë́'₃.
\v 6 Jaun₂ ca₂juá'₂ Jesús:
\p ―Jmo₄ 'nia'₂ 'í₁ jaun₂ tsá₃ le₃tɨn'₂ 'nia'₂ juá'₅ a₂jme₂tag₅ dsa₂ fariseos, dsa₂ saduceos në́₃. Ia₁ juá'₅ quió'₅ lë́₅ lia'₂ lë́₅ juɨ₁ levadura.
\p 
\v 7 Jaun₂ ca₂dsia₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ jág₁ tsɨ́'₅ rɨin'₅₄:
\p ―Ia₁ tsá₃ i₁ŋí'₄ le₁quian₁ bá₄ jniog₄, jaun₂ bá₄ juá'₂ le₂në₅.
\p 
\v 8 La₁ ca₂rë₃lí'₄ bá₄ Jesús 'e₂ jág₁ dsia₂₃, jaun₂ ca₂juá'₂:
\p ―¿'E₂ lë₃ juá'₂ 'nia'₂ tsá₃ le₁quian'₄ i₁ŋí'₄? ¡'E₂ guë́₄ ca₂juɨg₄ 'én'₂ 'nia'₂!
\v 9 ¿'E₂? ¿Tsa₁ ma₂ca₂rë₃ŋɨ́'₂ 'nia'₂? ¿Tsa₁ ma₃dsá₂ 'au'₂ 'nia'₂ lia'₂ con'₂ ca₂dsio'₄ jniá₂ 'ŋiá₂ i₁ŋí'₄ ca₂lɨn₅ quió'₅ 'ŋiá₂ mei₅ dsa₂, on₃ guë'₂ dsá₂ 'au'₂ 'nia'₂ je₂liá'₂ tsɨ₁mɨ'₂ 'nau₅₄ a₂ca₂cag'₅₄ táng₃ 'nia'₂?
\v 10 ¿On₃ guë'₂ dsá₂ 'au'₂ 'nia'₂ lia'₂ con'₂ ca₂dsio'₄ jniá₂ guio₃ i₁ŋí'₄ ca₂lɨn₅ quió'₅ quén₂ mei₅ dsa₂, on₃ guë'₂ dsá₂ 'au'₂ 'nia'₂ je₂liá'₂ tsɨ₁mɨ'₂ 'nau₅₄ a₂ca₂chóng₂ a₂ca₂cag'₅₄ 'nia'₂ në́₃?
\v 11 ¿'A₂ bá₄ lia'₂ ŋɨ́₄ tsá₃ rë₂len'₅₄ 'nia'₂? On₃jua'₅₄ i₁ŋí'₄ 'ë₅ jniá₂ jme₁në₂juá'₃ jmo₄ 'nia'₂ 'í₁ quian'₅₄ levadura quió'₅ dsa₂ fariseos quian'₅₄ dsa₂ saduceos.
\p 
\v 12 Jaun₂ guë́₄ ca₂ŋɨ́'₂ dsɨ́₅ 'éi₂ a₂'ë₅ Jesús jaun₂, on₃jua'₅₄ a₂ca₂tɨ́in₂ jmo₃ 'í₁ juɨ₁lia'₂ juɨ₁ levadura a₂cón'₂ dsa₂ i₁ŋí'₄, a₂ca₂tɨ́in₂ jmo₃ 'í₁ 'a₂ lia'₂ lë́₅ juá'₅ a₂jme₂tag₅ dsa₂ fariseos quian'₅₄ dsa₂ saduceos bá₄.
\s1 Ca₂juá'₂ Pe₄ lia'₂ tí₅ jág₁ dsau₅ a₂lɨ́n₅ Jesús dsa₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄
\r (Marcos 8:27-30; Lucas 9:18-21)
\p 
\v 13 Jme₁ca₂dsióg₃ Jesús ma₂quián₅ juɨg₂ Cesarea ja₁tén₄ Filipo, jaun₂ ca₂ŋɨ́i'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅:
\p ―¿'Ein₂ lɨ́n₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃, juá'₂ dsa₂?
\p 
\v 14 Jaun₂ ca₂ŋag₃ 'éi₂:
\p ―I₂lɨn₅₄ dsa₂ juá'₂ a₂lɨ́ng'₅ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂; i₂sián'₂ guë'₂ juá'₂ a₂lɨ́ng'₅ Elías; i₂lɨn₅₄ guë'₂ juá'₂ táng₃ a₂lɨ́ng'₅ Jeremías, o₃ jan₂ i₂sián'₂ i₂já₅ 'ë́₂ jág₁ quió'₅ Diú₄.
\p 
\v 15 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿'Nia'₂ guë'₂ në́₃? ¿'E₂ juá'₂ 'nia'₂ 'ein₂ lɨ́n₅ jniá₂?
\p 
\v 16 Jaun₂ ca₂ŋag₃ Si₂mu₅₄ Pe₄:
\p ―'Ne₂ lɨ́ng'₅ dsa₂ I₂rë₂'ɨ́n₁, Ja₁ŋi'₅₄ Diú₄ jén'₃.
\p 
\v 17 Jaun₂ ca₂ŋag₃ Jesús:
\p ―'E₂ guë́₄ dsen'₃ 'ne₂, Si₂mu₅₄, ja₁ŋi'₅₄ Jonás, ia₁ 'i₁jan₂ dsa₂ mɨ₂güɨ́g₃ tsá₃ në₂jme₃jnia₅ ne'₅₄ a₂në₅, jŋia'₅₄ lia'₂ Ŋe'₃ jniá₂ i₂guá₅ i₂juɨ́g₃ bá₄.
\v 18 Jaun₂ juá'₅ jniá₂ juɨ́g₂ 'ne₂, a₂ma₂cheng'₂ Pedro,\f + \fr 16:18 \ft griego: Petros, co₂'nió'₄ le₃jua'₅₄ nɨ₁cang₁.\f* jaun₂ ne₄ nɨ₁'lau₂ la₂\f + \fr 16:18 \ft 'Nio'₂ ja₁ton₅ 1 Pedro 2:7.\f* jmóg'₄ jniá₂ guá'₅ quió₃, jaun₂ ca₂lia'₂ jŋia'₅₄ i₂'io₅ bí₂ 'mú₃ tsá₃ le₃quɨ'₅₄ jmɨg₄ jua'₅₄ a₂tió'₃ quiong'₅₄ quian'₅₄ mai₅₄ quió'₅.
\v 19 Jaun₂ o₄gog'₂ 'ne₂ dsia₅₄ jniá₂ jág₁ dse₃ quió₃ a₂lë́₅ co₂'nió'₄ ŋí₁ llave a₂niá₃ ja₁dsɨ₃tion'₅₄ dsa₂ ja₁gon₂ Diú₄. Ca₂le₃jë́₃ 'e₂ a₂tsá₃ cuë́'₂ 'ne₂ jmɨg₄ ne₄ gua'₅₄ 'uë₃ la₂ lia'₂ con'₂ lë́₅ jág₁ quió₃, ján₃ bá₄ le₂jaun₂ tsá₃ lé₂ guei'₅₄ i₂juɨ́g₃; ján₃ bá₄ le₂jaun₂ juɨ₁lia'₂ a₂cuë́'₂ 'ne₂ jmɨg₄ gua'₅₄ 'uë₃ la₂ lia'₂ con'₂ lë́₅ jág₁ quió₃, a₂jaun₂ bá₄ lé₂ guei'₅₄ i₂juɨ́g₃ ján₃.
\p 
\v 20 Jaun₂ ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ a₂tsá₃ 'ein₂ tsɨ́'₃ 'i₁jan₂ a₂lɨ́in₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄.
\s1 Ca₂'ë́₂ Jesús jág₁ a₂jóin₂
\r (Marcos 8:31--9:1; Lucas 9:22-27)
\p 
\v 21 Të₂le₃ ne₄ juɨ₅ ja₁ŋó₄ jaun₂, ca₂jme₃lióg₃ Jesús ca₂'ë́₂ jág₁ ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, a₂tion₅₄ dsó₃ juɨ₅ Jerusalén, ja₁dsɨ₃ŋɨ́i₂ 'lióng₂ ne₅₄ jmɨ₁uɨg₅ a₂jmóg'₂ dsa₂ can'₅₄ quián₅ guá'₅, quian'₅₄ juɨg₅₄ jme₂dsa₂, të₅juá'₅ në́₃. Jaun₂ ca₂juá'₂ a₂jŋag'₃ dsa₂, la₁ a₂'nɨ₅ jmɨg₄ jaun₂, jein'₅₄ bá₄ táng₃.
\p 
\v 22 Jaun₂ Pe₄ në́₃ ca₂jiog₃ le₃cau₅, jaun₂ ca₂jme₃lióg₃ a₂të₂néi'₂ a₂jme₁jnéi₂ juɨ₅, ca₂juá'₂:
\p ―¡Tsá₃ o₁le₅₄ le₂në₅, Te₁gui'₅₄! ¡O₁lɨ́g'₂ bá₄ tsá₃ juɨ₁dsi₂ŋɨ́'₂ 'ne₂ le₂në₅!
\p 
\v 23 La₁ Jesús në́₃, ca₂jéin'₃ le₂ca'₃, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ Pe₄:
\p ―¡Jŋiag'₃ cau₅ quió₃, Satanás! Jŋia'₅₄ jnɨ'₂ bá₄ 'ne₂ juɨ₅ quió₃, ia₁ tsá₃ le₂jaun₂ dsɨ₂jiog₅ 'au'₂ juɨ₁lia'₂ dsɨ₂jiog₅ dsɨ́₅ Diú₄. Ia₁ lia'₂ dsɨ₂jiog₅ dsɨ́₅ dsa₂ mɨ₂güɨ́g₃ bá₄ dsɨ₂jiog₅ 'au'₂.
\p 
\v 24 Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ ca₂le₃jɨ́n₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅:
\p ―Chi₂jua'₂ 'ein₂ 'nio₃ 'éin₃ jniá₂, co₂dsia₅ juɨ₁dsi₂'én₂ dsɨ́₅ guioin₅₄, juɨ₁jmo₁₂ co₂jŋiai₅₄ a₂jóin₂,\f + \fr 16:24 \ft lit. “juɨ₁quian₅₄ cróg₄ quió'₅.” \f* juɨ₁jia₂ chi₁co'₅₄ quió₃.
\v 25 Ia₁ juɨ₁'ein₂ guë́₃ i₂tsá₃ 'nio₃ jón₂ ia₁ a₂'ɨ́n₅ dsɨ́₅ le₃chain₂ dse₃ mɨ₂güɨ́g₃ la₂, dsɨ₂'én₂ quió'₅. La₁ juɨ₁'ein₂ guë́₃ i₂tén'₂ dsɨ́₅ gue₃ 'mú₃ 'uɨg₅₄ quió₃ jniá₂, le₃chain₂ dse₃ mɨ₂güɨ́g₃ caun₂.
\v 26 Ia₁, ¿'e₂ bá₄ ta₁ jmo₃ a₂lí'₂ dsa₂ 'ŋio₅ lɨn₃ ne₄ gua'₅₄ 'uë₃ la₂, në₁jua'₂ dsɨ₃'én₂ bá₄ guë'₂ jme₂dsí₂ quió'₅ mɨ₂güɨ́g₃ caun₂? ¿O₃ je₂liá'₂ lé₂ le₃quí₃ dsa₂ 'lia'₅₄ ia₁jaun₂ tɨ́n'₄ jme₂dsí₂ quió'₅?
\v 27 Ia₁ Jaun₅ dsa₂ mɨ₂güɨ́g₃ jŋiói'₂ quian'₅₄ juɨ₅bí₂ jlá'₁ quió'₅ Jmei₂, quian'₅₄ ángeles quiáin₅, ja₃qui₅ 'lian'₅₄ dsa₂ 'a₂ con'₂ jŋia'₅₄ niog₅ ca₂jmo₃.
\v 28 A₂dsɨ₂jó'₃ juá'₅ jniá₂ juɨ́g₂ 'nia'₂, chan₂ i₂lɨn₅₄ juɨ₁lia'₂ i₂tion'₅₄ ja₁lá₃ tsá₃ dsián₃ ca₂lia'₂ ca₂të́₂ ne₅₄ jɨ́in₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ a₂jŋiói'₂ lɨ́in₅ rag₅₄ a₂qui₃dsɨ₂₃ 'éi'₃.
\c 17
\s1 Ca₂rë₃tsɨ́n₃ 'a₂ lia'₂ jniá₂ Jesús
\r (Marcos 9:2-13; Lucas 9:28-36)
\p 
\v 1 Jŋéi₂ jmɨg₄ cang₂ jaun₂, ca₂jŋia₃ Jesús Pe₄, Jacobo,\f + \fr 17:1 \ft ján₃ bá₄ chein₂ Santiago.\f* quian'₅₄ Juan₅₄ rɨn'₅₄ Jacobo në́₃, ca₂i₃léin₂ con'₂ guioin₅₄ caun₂ má'₂ ŋei₅.
\v 2 Ja₁jaun₂ ca₂rë₃tsɨ́n₃ 'a₂ lia'₂ jniá₂ Jesús të₃ jág₅ 'éi₂. Ne₄ Jesús ca₂jnia₃ tág₅ juɨ₁lia'₂ jniá₂ 'iog₂; tsɨn'₅₄ guë'₂ në́₃ ca₂jnia₃ tiog₂ jau₂ ca₂lia'₂ tág₅ lɨn₃.
\v 3 Jaun₂ dsɨ₂juɨ₅ jaun₂ ca₂jnia₃ Moisés quian'₅₄ Elías, tióin₂ dsia₂₃ jág₁ quiain'₅₄ Jesús.
\v 4 Jaun₂ ca₂juá'₂ Pe₄ ca₂tsɨ́'₃ Jesús:
\p ―Te₁gui'₅₄, ¡'e₂ guë́₄ dse₃ lia'₂ tio'₅₄ jniog₄ ja₁lá₃! Chi₂jua'₂ niog'₂, jmo₅₄ jniá₂ 'nɨ₅ tsɨ₁'io₅ láu₃: caun₂ quiáng'₂, caun₂ quió'₅ Moisés, caun₂ guë'₂ quió'₅ Elías në́₃.
\p 
\v 5 Të₃jë₄ dsia₅ Pe₄ jág₁ jaun₂, ca₂lioin₂ caun₂ jnei₅ tág₅; jaun₂ jë₄ jnei₅ jaun₂ ca₂né'₂ jág₁ a₂juá'₂:
\p ―I₂la₂ bá₄ jón₃ quiáng₃, i₂ŋɨ́₄ lë₃ 'nióg₃ guë́₄ lɨn₃. 'E₂ bá₄ 'ŋio₂ dsɨ₃ quiain'₅₄. Nei₂ 'nia'₂ jág₁ quió'₅.
\p 
\v 6 Jme₁ca₂nág₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ jág₁ jaun₂, ca₂rë₃gó'₅ ca₂le₃jë́₃ ca₂i₃gain'₅₄ 'uë₃ le₁'éin₂,
\v 7 Jaun₂ ca₂guán'₃ táng₃ Jesús cau₅ quió'₅, ca₂jŋau'₃, jaun₂ ca₂juá'₂:
\p ―Nau₂ 'nia'₂; Tsá₃ lë₁jmo₂ 'nia'₂ gang'₃.
\p 
\v 8 Jaun₂ jme₁ca₂jág₃ táng₃, tsá₃ ma₂'ein₂ i₂sián'₂ ca₂jɨ́in₂; jŋia'₅₄ lia'₂ 'ŋiog₅ bá₄ Jesús ma₂chéin'₅.
\p 
\v 9 Jme₁ja₂lein₃ sióin₅ táng₃ má'₂ jaun₂, ca₂jmo₃ Jesús 'éi'₃, ca₂juá'₂:
\p ―Tsá₃ 'ein₂ juɨg'₅₄ 'nia'₂ a₂në₂jag'₅₄ 'nia'₂ në₅, ca₂lia'₂ ca₂të́₂ jmɨg₄ jë₁ma₂ca₂jen'₅₄ táng₃ Jaun₅ dsa₂ mɨ₂güɨ́g₃ ne₄ 'mú₃.
\p 
\v 10 Jaun₂ ca₂ŋag₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ ca₂ŋɨ́i'₃ Jesús:
\p ―Chi₂jua'₂ le₂në₅, ¿'E₂ lë₃ juá'₂ të₅juá'₅, Elías bá₄ i₂jiá₃ le₂'uɨg₅₄?
\p 
\v 11 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Dsón'₂ Elías bá₄ jiá₃ le₂'uɨg₅₄, jaun₂ 'éi₂ bá₄ jme₃rë́₃ ca₂le₃jë́₃.
\v 12 La₁ juá'₅ jniá₂, i₂ma₂guan₅ bá₄ Elías, la₁ tsá₃ 'ein₂ ca₂rë₃cuɨg₅. Jaun₂ qui₂ca₂jmóg'₂ dsa₂ lia'₂ lë́₂ dsɨ́₅ ca₂le₃jë́₃ guë́₄ 'a₂ lia'₂ 'nio₃ jmóg'₂. Ján₃ bá₄ le₂në₅, Jaun₅ dsa₂ mɨ₂güɨ́g₃ dsɨ₃ŋɨ́i₂ uɨg₅ o₄gú₃ dsa₂ 'éi₂.
\p 
\v 13 Jaun₂ guë́₄ ca₂rë₃lí'₄ chi'₂ dsɨ₂guia₃-tɨ́n₂, Juan₅₄ i₂ca₂chon₃ dsa₂ jmɨg₂ bá₄ 'ɨn₅ Jesús, a₂juá'₂ le₂jaun₂.
\s1 Ca₂jme₃'lión₂ Jesús jan₂ chi'₂ i₂'en₅₄ jme₂dsí₂ 'lɨn'₅₄ dsɨ́₅
\r (Marcos 9:14-29; Lucas 9:37-43)
\p 
\v 14 Jme₁ca₂dsi₃lein₃ ja₁tion'₅₄ dsa₂ juɨn₅, jaun₂ ca₂jme₃quián₃ jan₂ dsa₂ ja₁chén'₄ Jesús, jaun₂ ca₂chi₃jné₃ ne₅₄, jaun₂ ca₂juá'₂:
\p 
\v 15 ―Te₁gui'₅₄, dsia₄ ŋéi₂ 'au'₂ chi'₂ quiáng₃, 'ŋio₅ lɨn₃ ŋág₅ uɨg₅ lɨ́in₅ dso₄ 'ei₂; 'lióng₂ ráun₂ ma₂ca₂táin'₂ dsi₂si₂, dsi₂jmɨg₂ në́₃.
\v 16 Ma₂i₁jŋiai₅₄ jniá₂ ne₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáng'₂, la₁ tsá₃ ca₂tió'₃ jme₃'lió₂.
\p 
\v 17 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¡'En₁ jmá'₃ tsá₃ 'e₂ 'én'₂ 'nia'₂! ¿Je₂liá'₂ jmɨg₄ jmá'₃ 'nió'₅ 'ú₄ quian'₅₄ 'nia'₂? ¿Je₂liá'₂ jmɨg₄ jmá'₃ 'nió'₅ jmo₅₄ tió'₅ dsɨ₃ quian'₅₄ 'nia'₂? I₂jŋia₅ chi'₂ ja₁lá₃.
\p 
\v 18 Jaun₂ ca₂jí₂ Jesús ca₂jéin₂ je₂na'₅₄. Jaun₂ ca₂o₃'ɨ́in₃ të₂dsɨ́₅ chi'₂ 'éi₂, jaun₂ guë́₄ në́₃ ca₂'lóin₂ dsɨ₂juɨ₅ le₂jaun₂.
\p 
\v 19 Jme₁co₂lág₂ jaun₂ ca₂dsia₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ jág₁ quian'₅₄ Jesús jë₄ con'₂ guioin₅₄, jaun₂ ca₂ŋɨ́i'₃ 'éi₂:
\p ―¿'E₂ 'uɨg₅₄ tsá₃ ca₂tián₃ jnia'₅₄ dsén₄ i₂'lɨn'₅₄?
\p 
\v 20 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Ne₄ ia₁ a₂ŋɨ́₄ lë₃ ca₂juɨg₄ 'én'₂ bá₄ 'nia'₂. A₂dsɨ₂jó'₃ juá'₅ jniá₂, jua'₅₄ mei'₂ guë́₃ 'én'₂ 'nia'₂, tsá₃ a₂nag₅₄ o₁jŋia'₅₄ con'₂ tí₅ ca₂mɨ́g₂ mɨ₂jon₂ mostaza,\f + \fr 17:20 \ft mostaza: On₃jua'₅₄ mɨ₁ján'₅ a₂cuɨ́'₅ dsa₂ go₄ jniog₄; caun₂ nɨ₁'ma₂ dsón'₂ bá₄ jaun₂ a₂të́'₂ të₅sí₃ Brassica nigra.\f* lé₂ le₃jme₁juɨg'₅₄ 'nia'₂ juɨ₁lia'₂ má'₂ ó₃: “Jŋiag'₃ ja₁në₅, gua₂ të₂le₃ ca₂taun₂”; má'₂ jaun₂ në́₃ jŋióg'₃ ja₁'ë'₂ 'nia'₂. 'I₁caun₂ tsá₃ 'e₂ cha₂ jua'₅₄ a₂tsá₃ lé₂ le₃jmó'₂ 'nia'₂ jua'₅₄ mei'₂ guë́₃ le₂jaun₂.\f + \fr 17:20 \ft A₂lɨn₅₄ chog₅₄ si₂ chi₁ton₅ versículo 21 bá₄ ján₃, a₂juá'₂ le₂la₂: “La₁ juɨ₁lia'₂ i₂'lɨn'₅₄ le₂në₅, tsá₃ o₂'ɨin₅ në₁jua'₂ tsá₃ chi₂lén'₂ dsa₂ Diú₄ a₂jme₂'ɨin₅₄.” \f*
\s1 Ca₂'ë́₂ táng₃ Jesús jág₁ a₂jóin₂
\r (Marcos 9:30-32; Lucas 9:43-45)
\p 
\v 22 Të₁lia'₂ i₂nioi₅₄ co₂lë₅ le₂con₂ ja₁tén₄ 'uë₃ Galilea, jaun₂ ca₂juá'₂ táng₃ Jesús a₂jáng'₂ dsa₂ jɨ́in'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ o₄gú₃ dsa₂ mɨ₂güɨ́g₃.
\v 23 Jaun₂ jŋag'₃ dsa₂, la₁ a₂'nɨ₅ jmɨg₄ jaun₂, jein'₅₄ bá₄ táng₃. Ca₂tá'₂ 'lia'₂ bá₄ dsɨ́₅ chi'₂ dsɨ₂guia₃-tɨ́n₂ jme₁ca₂nág₂ jág₁ jaun₂.
\s1 Ca₂quí₃ 'lia'₅₄ ja₁con₂ dsɨ₂tan₅₄ quián₅ guá'₅
\p 
\v 24 Jme₁ca₂dsióg₃ Jesús juɨg₂ Capernaum quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂, jaun₂ ca₂o₃lén₂ dsa₂ i₂cág'₅ jma₃tɨn₃ 'éi'₃ cu₄ dracma a₂'nió'₅ quió'₅ guá'₅ templo, jaun₂ dsa₂ 'éi₂ ca₂jme₃quiáin₃ con₂ Pe₄, ca₂ŋag₃:
\p ―¿Tsa₁ quí₅ të₅ quián'₂ 'nia'₂ 'lia'₅₄ quió'₅ guá'₅?
\p 
\v 25 Jaun₂ ca₂ŋag₃ Pe₄:
\p ―Ján₅. Quí₅ bá₄.
\p Jme₁ca₂'i₃ Pe₄ dsi₂néi₂, jaun₂ 'ŋiog₅ Jesús de'₂ jŋiá₅ ca₂juá'₂ ca₂tsɨ́'₃ Pe₄:
\p ―¿'A₂ lia'₂ lɨ́n'₂ 'ne₂, Si₂mu₅₄? Juɨ₁lia'₂ jan₂ rag₅₄ dsa₂ mɨ₂güɨ́g₃, ¿'Ein₂ quió'₅ mɨ₂₃ 'lia'₅₄? ¿Quió'₅ dsa₂ go₅₄, o₃ quió'₅ jmá'₃ dsɨ₂nau₂ 'e₂?
\p 
\v 26 Jaun₂ ca₂ŋag₃ Pe₄:
\p ―Quió'₅ dsɨ₂nau₂ bá₄.
\p Jaun₂ ca₂juá'₂ táng₃ Jesús ca₂tsɨ́'₃ 'éi₂:
\p ―Tsá₃ ca₂tɨ́n₂ dsa₂ go₅₄ quí₃ jaun₂ në́₃.
\v 27 La₁, jaun₂ tsá₃ tɨin₃ 'lɨg'₅₄, gua₂ o₂'éi₂ mɨ₂cu₄ dsi₂jmɨg₂, O₂dsen₅₄ i₁ju₁ i₂nág'₃ le₂'uɨg₅₄ mɨ₂cu₄. Mɨ₂'o₄ i₁ju₁ 'éi₂, dsiang'₂ caun₂ cu₄ 'ua'₂. A₂jaun₂ quɨ'₅₄ quián₂ jniog₄ le₃ó₃.
\c 18
\s1 'Ein₂ lɨ́n₅ i₂dsen₅₄ guë́₄ ja₁gon₂ Diú₄
\r (Marcos 9:33-37; Lucas 9:46-48)
\p 
\v 1 Ján₃ bá₄ jmɨg₄ jaun₂ táng₃ ca₂jme₃quián₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ con₂ Jesús jaun₂ ca₂ŋag₃:
\p ―¿'Ein₂ lɨ́n₅ i₂dsen₅₄ guë́₄ guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄?
\p 
\v 2 Jaun₂ ca₂të́'₃ Jesús jan₂ i₂bë'₅₄, jaun₂ ca₂chei'₃ dsi₂jo₂ ja₁tiáin'₄,
\v 3 jaun₂ ca₂juá'₂:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, në₁jua'₂ tsá₃ ca₂jme₁tsɨ́n'₄ 'nia'₂ 'au'₂, a₂léng'₂ lia'₂ lɨ́n₅ jan₂ i₂bë'₅₄, o₁lɨ́g'₂ jmɨg₄ tsá₃ lé₂ le₃dsi₁no'₃ 'nia'₂ guei'₅₄ i₂juɨ́g₃.
\v 4 Jaun₂ në́₃, i₂'éi₂ bá₄ i₂lén₂ i₂dsen₅₄ guë́₄ guei'₅₄ i₂juɨ́g₃ juɨ₁lia'₂ i₂jmo₅ me'₂ lia'₂ lɨ́n₅ chi'₂ bë'₅₄ la₂.
\v 5 Con'₂ siá'₂ táng₃, juɨ₁lia'₂ dsa₂ i₂guen₅ jan₂ guein₂ o₄quió₃ jniá₂ juɨ₁lia'₂ i₂la₂, jniá₂ bá₄ guei₂₃.
\s1 A₂go'₂ tsɨ₃sén'₂ dsa₂ dso₄
\r (Marcos 9:42-48; Lucas 17:1-2)
\p 
\v 6 ’Juɨ₁'ein₂ guë́₃ i₂jmo₅ tsɨ₂sén'₂ juɨ₁lia'₂ chi'₂ bë'₅₄ i₂le₂la₂ i₂'én₂ të₂le₃ quió₃ jniá₂, ja₂lɨn₃ guë́₄ co₂ŋei'₅₄ dse₃ tón₂ dsa₂ ne₄ jmɨ₁ŋí'₄ rë₂quein₅ ca₂mɨ́g₂ nɨ₁to₂ dsɨ₂lag₅₄.
\v 7 ¡'E₂ guë́₄ juɨ́g₂ dsa₂ mɨ₂güɨ́g₃ ia₁ tsá₃ caun₂ a₂ja₂lé₂ ja₁coin₂ a₂jmo₅ a₂tsɨ₂séin'₂! La₁ le₂jaun₂ dsón'₂ dsɨ₃ŋɨ́i₂ bá₄, la₁ 'e₂ guë́₄ juɨ́g₂ juɨ₁lia'₂ dsa₂ i₂ton'₂ jág₁ rɨn'₅₄ jaun₂ jén'₃ dsɨ́₅ 'éi₂ a₂'no₃ dso₄.
\p 
\v 8 ’'Uɨg₅₄ jaun₂, chi₂jua'₂ mɨ₂gog'₂ o₃ mɨ₂tag'₅₄ 'e₂, jmo₅ a₂tang'₂ dso₄, co₂dsia₅ dse₃ 'nia₄, tiong₂ uɨ́ng₂; ia₁ ja₂lɨn₃ guë́₄ dse₃ a₂dsiáng'₄ ja₁le₃chang'₂ co₂tan₅₄ a₂rë₂'liáng'₃, con'₂ guë́₄ a₂jme₁o₁'ú'₃ a₂rë₂'ŋia₅ gog'₂-tag'₅₄ dsi₂si₂ ja₁tsá₃ ton₅ jmɨg₄ éi₃.
\v 9 Në₁jua'₂ mɨ₂ne'₅₄ jmo₅ a₂tang'₂ dso₄, dsi₄ ján₃, tiong₂ uɨ́ng₂: ia₁ ja₂lɨn₃ guë́₄ dse₃ a₂dsiáng'₄ ja₁le₃chang'₂ co₂tan₅₄ a₂teng'₅₄ ca₂mɨ́g₂ mɨ₂ne'₅₄, lia'₂ con'₂ guë́₄ a₂jme₁gog'₅₄ a₂rë₂'ŋia₅ ta₁tɨn₃ mɨ́g₂ mɨ₂ne'₅₄ dsi₂si₂ guio₃-juɨ́g₃.
\s1 Jág₁ a₂jáng'₅ léi₄ juɨ₁lia'₂ jan₂ já'₂ cha'₂ i₂ca₂i₃cón'₅
\r (Lucas 15:3-7)
\p 
\v 10 ’Tsá₃ jmo₂ 'nia'₂ jua'₅₄ a₂tsá₃ jen'₅₄ juɨ₁lia'₂ jan₂ chi'₂ bë'₅₄ le₂la₂. Ia₁ juɨ́g₂ jniá₂ 'nia'₂, ia₁ ángeles i₂jmo₅ 'í₁ quiáin₅ co₂tan₅₄ bá₄ jɨ́in₂ Ŋe'₃ i₂guá₅ guei'₅₄ i₂juɨ́g₃.\f + \fr 18:10 \ft A₂lɨn₅₄ chog₅₄ si₂ chi₁ton₅ versículo 11 a₂juá'₂ le₂la₂: “Ta₁ jaun₂ bá₄ já₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃, a₂ja₂'niai'₂ dsa₂ i₂ma₂i₂cón'₅.” \f*
\p 
\v 12 ’¿'A₂ lia'₂ lɨ́n'₂ 'nia'₂? Jua'₅₄ mei'₂ guë́₃ jan₂ dsa₂ 'ŋio₅ caun₂ 'ŋiá₂-lón₂ já'₂ cha'₂, në₁jua'₂ ca₂i₃cón'₅ jan₂, ¿tsa₁ ja₁jaun₂ chein'₂ ne₄ dsɨ₂con'₂ i₂quéin'₂ co₂ne₂guión₂ rë₂dsɨ́₂ guia₃-né₂ (99) con'₂ i₂te₂ 'éi₂, jaun₂ dsó₅ táng₃ dsɨ₂'niai'₂ i₂tsá₃ chan₂ 'éi₂?
\v 13 Jë₁ma₂ca₂dsáu'₂ në́₃, a₂dsɨ₂jó'₃ juá'₅ jniá₂, 'ŋio₅ lɨn₃ guë́₄ 'io'₂ jmo₂₃ o₄quió'₄ i₂jan₂ 'éi₂ con'₂ guë́₄ i₂quéin'₂ co₂ne₂guióg₂ rë₂dsɨ́₂ guia₃-né₂ i₂tsá₃ i₂cón'₅.
\v 14 Le₂në₅ bá₄ ján₃, Ŋéi'₅ 'nia'₂ i₂guá₅ guei'₅₄ i₂juɨ́g₃ tsá₃ 'nio₃ jua'₅₄ dsɨ₃cón'₅ ca₂lia'₂ 'i₁jan₂ i₂lɨ́n₅ guein₂ bë'₅₄ juɨ₁lia'₂ i₂la₂.
\s1 'A₂ lia'₂ 'nió'₅ 'én₂ dsa₂ dsáu₁ rɨin'₅₄
\r (Lucas 17:3)
\p 
\v 15 ’Chi₂jua'₂ 'e₂ caun₂ a₂ca₂jmóg'₂ jan₂ rɨ́ng'₂, dsia₄ de'₂ 'nia'₂ jág₁ ja₁con'₂ guiong'₅₄, ja₁jaun₂ jme₁jniag'₂ ne₅₄ 'e₂ a₂ca₂jmóg'₂. Në₁jua'₂ ca₂tón'₃ juɨ₅ jág₁ quiáng'₂, ja₁jaun₂ ca₂dsan₃ bá₄ mɨ'₅₄, ca₂lë₃ bá₄ táng₃ rɨ́ng'₂ quiain'₅₄.
\v 16 La₁ në₁jua'₂ tsá₃ ca₂tón'₃ juɨ₅ jág₁ quiáng'₂ në́₃, te'₂ on₃-ún₂ dsa₂ sián'₂ ia₁jaun₂ “ca₂le₃jë́₃ 'e₂ niog₅ lé₂ jióg'₂ 'í₁ quian'₅₄ on₃-ún₂ dsa₂ i₂jáng'₃ jág₁ dsau₅, në₁jua'₂ tí₅ jág₁ jaun₂.”\f + \fr 18:16 \ft Deuteronomio 19:15.\f*
\v 17 Në₁jua'₂ tsá₃ ca₂tón'₃ juɨ₅ jág₁ quió'₅ dsa₂ 'éi₂, chei'₅₄ guá'₅; në₁jua'₂ tsá₃ ca₂tón'₃ juɨ₅ on₃ guë'₂ jág₁ quió'₅ guá'₅ në́₃, të₂le₃ ja₁ŋó₄ jaun₂, jmo₄ 'au'₂ jɨin'₅₄ lia'₂ ja₁jɨng'₄ jan₂ dsɨ₂nau₂, o₃ juɨ₁lia'₂ jan₂ i₂cág'₅ cu₄ a₂ca₂tɨ́n₂ dsɨ₂tan₅₄ 'e₂.
\p 
\v 18 ’A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, ca₂le₃jë́₃ 'e₂ a₂tsá₃ cuë'₂ 'nia'₂ jmɨg₄ ne₄ gua'₅₄ 'uë₃ la₂, lia'₂ con'₂ lë́₅ jág₁ quió₃, ján₃ bá₄ tsá₃ lé₂ guei'₅₄ i₂juɨ́g₃; ján₃ bá₄ le₂jaun₂ juɨ₁lia'₂ a₂cuë'₂ 'nia'₂ jmɨg₄ ne₄ gua'₅₄ 'uë₃ la₂, lia'₂ con'₂ lë́₅ jág₁ quió₃, a₂jaun₂ bá₄ lé₂ guei'₅₄ i₂juɨ́g₃.
\p 
\v 19 ’Ján₃ bá₄ juá'₅ jniá₂, në₁jua'₂ on'₃ 'nia'₂ jmo'₂ caun₂ jág₁ ne₄ gua'₅₄ 'uë₃ la₂, a₂mɨ́'₁ 'nia'₂ 'e₂ a₂'niog'₂ mɨ́'₁, cuë₃ bá₄ Ŋe'₃ jniá₂ i₂guá₅ guei'₅₄ i₂juɨ́g₃.
\v 20 Ia₁ jë₁le₁ŋɨ'₂ on₃-ún₂ o₄quió₃ jniá₂, jë₄ jaun₂ bá₄ 'eng₅₄.
\p 
\v 21 Jaun₂ Pe₄ në́₃ ca₂ŋag₃:
\p ―Te₁gui'₅₄, ¿con'₂ je₂liá'₂ ráun₂ 'nió'₅ 'én₄ jniá₂ dsáu₁ rɨ́ng'₃ në₁jua'₂ 'e₂ caun₂ a₂ca₂jmóg'₂? ¿'A₂ lia'₂? ¿Guio₃ ráun₂?
\p 
\v 22 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Ma₁ tsá₃ juá'₅ jniá₂ jŋia'₅₄ guio₃ ráun₂. Ta₁'nag'₂ co₂ne₂guióg₂ rë₂dsɨ́₂ guia₃ ráun₂ a₂jma₃guio₃ (70 X 7 = 490)\f + \fr 18:22 \ft o₃, “ta₁'nag'₂ co₂ne₂guióg₂ rë₂dsɨ́₂ guia₃-guio₃ (77) ráun₂”.\f* bá₄ juá'₅ jniá₂.
\s1 Jág₁ a₂jáng'₅ léi₄ juɨ₁lia'₂ jan₂ dsa₂ i₂tsá₃ ca₂'én₂ dsáu₁ rɨn'₅₄
\p 
\v 23 ’Uɨg₅₄ jaun₂, lë́₅ guei'₅₄ i₂juɨ́g₃ juɨ₁lia'₂ lɨ́n₅ jan₂ rag₅₄ i₂ca₂mág₃ cuentas quió'₅ ca₂le₃jɨ́n₃ dsa₂ i₂jme₂ti₃ ta₁ ne₅₄.
\v 24 Jaun₂ jme₁ma₂jme₂lióg₃ chein'₂ cuentas, jme₁ca₂dsi₃lén₂ dsa₂ le₁jŋiai₂₃ jan₂ dsa₂ i₂rɨn₅ guia₃ mei₅ talentos.
\v 25 La₁, ia₁ tsá₃ 'e₂ cha₂ quian'₅₄ a₂quí₃, jaun₂ ca₂jmo₃ rag₅₄ 'éi'₃ a₂dsɨ₃'nɨ₄ dsa₂ 'éi₂ lia'₂ jma₃quian'₅₄ 'io₅₄ quiáin₅, chi'₂ quiáin₅ në́₃, ca₂le₃jë́₃ 'e₂ a₂jme₁cha₂ quió'₅ në́₃, ia₁jaun₂ le₂jaun₂ jme₁dsian₅ a₂rɨin₂.
\v 26 La₁ dsa₂ 'éi₂ në́₃, ca₂já₃ ca₂chi₃jné₃ ne₄ rag₅₄ juɨg₅₄, jaun₂ ca₂mɨ₃ tion₅₄ ca₂juá'₂: “Gui'₅₄ quiáng₃, jmo₄ juɨn'₂ 'au'₂ quian'₅₄ jniá₂, a₂quɨ́₄ bá₄ jniá₂ quiáng'₂, ca₂le₃jë́₃.”
\v 27 Jaun₂ juɨg₅₄ në́₃ ca₂dsia₃ bá₄ ŋéi₂ dsɨ́₅ ja₁coin₂, jaun₂ ca₂'éin₂ bá₄ ca₂le₃jë́₃ a₂jme₁rɨin₂, jaun₂ ca₂lió₂ bá₄.
\p 
\v 28 'La₁ dsɨ₂juɨ₅ jme₁o₂'ɨ́in₃ jaun₂ në́₃, ca₂jein'₂ jan₂ dsa₂ i₂jme₂ti₃ rɨin'₅₄ i₂rɨn₂ caun₂ 'ŋiá₂-láu₂ cu₄ denarios quió'₅. Jaun₂ ca₂tɨ́in₂ dsɨ₂lag₄ rɨin'₅₄, ca₂güɨ'₃ tiá₂, ca₂juá'₂: “¡Qui₄ a₂rɨng'₂ quió₃!”
\v 29 Jaun₂ rɨin'₅₄ 'éi₂ në́₃ ca₂chi₃jné₃ ne₅₄, jaun₂ ca₂mɨ₃ tion₅₄ ca₂juá'₂: “Jmo₄ juɨn'₂ 'au'₂ quian'₅₄ jniá₂, a₂quɨ́₄ bá₄ jniá₂ quiáng'₂, ca₂le₃jë́₃.”
\v 30 La₁ i₂jan₂ në́₃ tsá₃ ca₂gue₃, jaun₂ juɨ₅ 'né₅ 'má₃ bá₄ ca₂i₁tio'₂. Ca₂lia'₂ jaun₂ ca₂'mag'₂ dsɨ́₅ ca₂lia'₂ ca₂quí₃ rɨin'₅₄ ca₂le₃jë́₃.
\v 31 Jaun₂ jme₁ca₂jág₃ rɨin'₅₄ i₂jme₂ti₃ ta₁ sián'₂, ca₂tá'₂ 'lia'₂ dsɨ́₅, jaun₂ ca₂i₁con₂ jág₁ ne₄ juɨg₅₄ ca₂i₁jua'₄ ca₂le₃jë́₃ a₂ca₂lë₃ jaun₂.
\v 32 Jaun₂ ca₂jmo₃ juɨg₅₄ 'éi'₃ ca₂i₁quiong₅₄ táng₃ dsa₂, jaun₂ ca₂të₃ juɨg₅₄ dsi₂néi₂ quió'₅, jaun₂ ca₂juá'₂: “'Ne₂ i₂jme₂ti₃ ta₁ ne₃, ¡'e₂ guë́₄ 'ŋio₅ 'lɨn'₅₄ 'ne₂ ca₂'uɨ́ng'₂! Jua'₂ në₂'én₃ bá₄ jniá₂ ca₂le₃jë́₃ a₂jme₁rɨng'₂ quió₃, ia₁ në₂mɨ'₅₄ tion₅₄-jan₃.
\v 33 ¿Tsa₁ dse₃ jua'₅₄ le₂jaun₂ bá₄ në₂dsia'₅₄ ŋéi₂ 'au'₂ rɨ́ng'₂, juɨ₁lia'₂ në₂dsia₃ jniá₂ ŋéi₂ dsɨ₃ 'ŋiag'₂?”
\v 34 Të₃ ma₂'ne₂ jaun₂ juɨg₅₄, ca₂jɨ́in'₂ dsa₂ 'éi₂ o₄gú₃ dsa₂ i₂niog₅ ne₄ 'né₅ 'má₃, ca₂jmo₃ ca₂lia'₂ ca₂quí₃ jë₂ a₂jme₁rɨin₂.
\p 
\v 35 Jaun₂ ca₂juá'₂ Jesús guë́₄ në́₃:
\p ―Ján₃ bá₄ le₂në₅ jmo₃ Ŋe'₃ jniá₂ i₂guá₅ guei'₅₄ i₂juɨ́g₃ quian'₅₄ 'nia'₂ le₂jang'₂ le₂jang'₂ në₁jua'₂ tsá₃ ca₂'én'₃ 'nia'₂ ca₂le₃jë́₃ 'au'₂ dsáu₁ rɨ́ng'₂.
\c 19
\s1 Jme₂tag₅ Jesús juɨ₁lia'₂ 'a₂ lia'₂ lë́₅ a₂tén₂ dsa₂ dsɨ₂i₂gu₂
\r (Marcos 10:1-12; Lucas 16:18)
\p 
\v 1 Jme₁ca₂dsan₃ juá'₂ Jesús jág₁ në₅, jaun₂ ca₂o₃'ɨ́in₃ 'uë₃ Galilea, jaun₂ ca₂dsióg₃ të₂le₃ quióng₄ Cuá₃ Jordán.
\v 2 Juɨn₅ lɨn₃ dsa₂ ca₂jme₃quiong'₅₄, jaun₂ ca₂jme₃'lióin₂ dsa₂ i₂qui₂le₁dso'₅₄.
\p 
\v 3 Jaun₂ në́₃, i₂lɨn₅₄ dsa₂ fariseos ca₂jme₃quiáin₃ con₂ Jesús a₂jŋia'₅₄ con'₂ cáun₂ táu₂. Jaun₂ ca₂ŋag₃:
\p ―¿'I₄ 'éi'₃ a₂tén₂ dsa₂ dsɨ₂i₂gu₂ ne₄ 'uɨg₅₄ në₁'e₂ caun₂ a₂lë₃?
\p 
\v 4 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿Tsa₁ ma₂ca₂'í'₂ 'nia'₂ ne₄ Si₂, ja₁juá'₂ i₂ca₂jmó'₂ dsa₂ mɨ₂güɨ́g₃ le₂ne₁: “Ca₂jmói'₂ dsa₂ ŋe'₂ dsa₂ mɨ́₂ në́₃”?\f + \fr 19:4 \ft Génesis 1:27; 5:2.\f*
\v 5 Ca₂juá'₂ në́₃: “'Uɨg₅₄ jaun₂ ca₂tɨ́n₂ dsa₂ ŋe'₂ téin₂ chog₅₄-jmei₂ jaun₂ con'₂ tiain'₃ quiain'₅₄ dsɨ₂i₂gu₂, jaun₂ jë₁le₃oin₃ léin₂ caun₂ bá₄ nɨ₁ŋɨ́₅.”\f + \fr 19:5 \ft Génesis 2:24.\f*
\v 6 Jaun₂ dsióg₄ léin₂ jan₂ bá₄, tsá₃ ma₃lë́₂ oin₃. Jaun₂ tsá₃ 'i₄ 'éi'₃ jua'₅₄ jmo₃ dsa₂ mɨ₂güɨ́g₃ jma₃quén₅ a₂ma₂ca₂dsia₃ Diú₄ rë₂.
\p 
\v 7 Jaun₂ ca₂ŋag₃ táng₃ dsa₂ fariseos:
\p ―¿'E₂ guë'₂ lë₃ në́₃ ca₂jmo₃ Moisés 'éi'₃ a₂lé₂ le₃jmo₃ dsa₂ ŋe'₂ caun₂ si₂ të₃ron₅₄ cuë́'₃ 'io₅₄ ja₁juá'₂ a₂téin₂ rɨin'₅₄, jaun₂ guë́₄ ma₂lé₂ dsei₂₃?
\p 
\v 8 Jaun₂ ca₂juá'₂ Jesús:
\p ―'Uɨg₅₄ ia₁ a₂ŋɨ́₄ tsá₃ nág'₁ 'nia'₂ guiong'₅₄ bá₄ jaun₂ ca₂cuë₃ 'éi₂ jmɨg₄ a₂tén₂ dsa₂ dsɨ₂i₂gu₂; la₁ lia'₂ con'₂ le₂'uɨg₅₄ tsá₃ le₂në₅ jme₁lë́₄.
\v 9 La₁ jniá₂ juá'₅, juɨ₁'ein₂ guë́₃ i₂lë₁tén₂ dsɨ₂i₂gu₂, on₃jua'₅₄ a₂cha₂ lë₃, në₁jua'₂ on₃ guë'₂ jua'₅₄ ia₁ a₂nió'₅ jág₁ quian'₅₄ i₂sián'₂; në₁jua'₂ jë₁ma₂ca₂lë₃ jaun₂, cáin₂ táng₃ 'io₅₄ sián'₂, 'no₂₃ dso₄ ne₄ Diú₄; ján₃ bá₄ le₂në₅ quian'₅₄ dsa₂ ŋe'₂ i₂jén'₂ gu₂ quian'₅₄ jan₂ 'io₅₄ i₂ma₂téi₂ dsa₂ në́₃, ján₃ bá₄ le₂jaun₂ 'no₂₃ dso₄ ne₄ Diú₄.
\p 
\v 10 Jaun₂ lë₃, ca₂juá'₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅:
\p ―Në₁jua'₂ le₂në₅ cha₂ o₂me'₅₄ dsɨ₅ quió'₅ dsa₂ ŋe'₂ dsa₂ mɨ́₂, ¿tsa₁ dse₃ jua'₅₄ a₂tsá₃ jéin'₂ co₂ŋei'₅₄ gu₂?
\p 
\v 11 Jaun₂ ca₂juá'₂ táng₃ Jesús:
\p ―Tsá₃ ca₂le₃jɨ́n₃ lé₂ le₃ŋɨ́'₂ dsɨ́₅ jua'₅₄ lé₂ le₃jmo₃ le₂në₅; jŋia'₅₄ lia'₂ i₂ma₂cuë₃ Diú₄ bí₂ a₂le₃ŋɨ́i'₂.
\v 12 'Lióng₂ bá₄ 'uɨg₅₄ cha₂ a₂tsá₃ le₃jén'₂ dsa₂ ŋe'₂ i₂lɨn₅₄ gu₂; ia₁ i₂lɨn₅₄ le₂jaun₂ ma₂lɨ́in₅ lia'₂ con'₂ jme₁ca₂rë₃cháin₃ a₂tsá₃ lé₂ le₃jéin'₂ gu₂; i₂lɨn₅₄ guë'₂ në́₃, ia₁ a₂ma₂ca₂jmóg'₂ dsa₂ mɨ₂güɨ́g₃ rɨin'₅₄ té'₃; i₂lɨn₅₄ guë'₂ në́₃, ia₁ a₂co₂ŋei'₅₄ ma₂quí'₃ dsɨ́₅ a₂tsá₃ jéin'₂ gu₂ ne₄ o₄quió'₄ ja₁gon₂ Diú₄. Juɨ₁lia'₂ i₂tió'₅ jme₃ti₃ jág₁ la₂, juɨ₁jmo₁₂.
\s1 Ca₂jme₃gon'₅₄ Jesús chi'₂-guein₂
\r (Marcos 10:13-16; Lucas 18:15-17)
\p 
\v 13 Jaun₂ ca₂o₃jŋia₃ i₂lɨn₅₄ dsa₂ ca₂o₃jŋiai₃ guein₂ quiáin₅ ne₄ Jesús ia₁jaun₂ qui₃nɨ́i'₂ gu₂, tsɨ́'₃ Diú₄ o₄quió'₄ në́₃. La₁ chi'₂ dsɨ₂guia₃-tɨ́n₂ në́₃ ca₂jéin₂ dsa₂.
\v 14 La₁ Jesús në́₃, ca₂juá'₂:
\p ―Cuë₄ 'nia'₂ jmɨg₄ juɨ₁ja₂lén₂ chi'₂-guein₂ cong₂; tsá₃ lë₁jmo₂ 'nia'₂ le₂në₅ jua'₅₄ jnɨg'₅₄, ia₁ juɨ₁lia'₂ i₂le₂në₅ bá₄ guë'₂ i₂ca₂tɨ́n₂ ja₁gon₂ Diú₄.
\p 
\v 15 Jme₁ca₂lë₃ chi₂láin'₂ le₂jan₂ le₂jan₂ guein₂ a₂jme₂gu'₅₄, ca₂ŋái'₃ bá₄ jaun₂.
\s1 Jan₂ dsó₂ chi'₂ cha₂ cu₄ ca₂dsia₃ jág₁ quiain'₅₄ Jesús
\r (Marcos 10:17-31; Lucas 18:18-30)
\p 
\v 16 Jan₂ dsó₂ chi'₂ ca₂jme₃quián₃ con₂ Jesús, jaun₂ ca₂ŋag₃:
\p ―Të₅ dsen₃, ¿'e₂ jmo₅₄ jniá₂\f + \fr 19:16 \ft o₃, “Të₅, ¿'e₂ a₂dse₃ a₂jmo₅₄ jniá₂…” \f* ia₁jaun₂ léi₂ ja₁le₃chang₂ co₂tan₅₄?
\p 
\v 17 Jaun₂ ca₂juá'₂ Jesús:
\p ―¿'E₂ lë₃ të́'₅ jniá₂ dsen₃?\f + \fr 19:17 \ft o₃, “¿'E₂ lë₃ ŋag'₅₄ jniá₂ juɨ₁lia'₂ a₂dse₃?\f* Jŋia'₅₄ lia'₂ jan₂ bá₄ i₂chan₂ i₂lɨ́n₅ i₂dsen₃, i₂'éi₂ lɨ́n₅ Diú₄. La₁ në₁jua'₂ 'niog'₂ 'ú'₄ ja₁le₃chang'₂ co₂tan₅₄, jme₁ti₁ 'éi'₃ quió'₅ Diú₄.
\p 
\v 18 Jaun₂ ca₂ŋag₃ táng₃ dsó₂ 'éi₂:
\p ―¿'E₂ 'éi'₃?
\p Jaun₂ ca₂ŋag₃ táng₃ Jesús:
\p ―Tsá₃ jŋɨ́g'₄ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂; tsá₃ nióg'₄ jág₁ quian'₅₄ dsa₂ i₂tsá₃ lɨ́n₅ dsɨ₂i₂gog'₂; tsá₃ 'áng'₁ a₂cha₂ quió'₅ rɨ́ng'₂; tsá₃ jmó'₂ jua'₅₄ jang'₅₄ jág₁ të₂jág₁ a₂jmag'₅₄ rɨ́ng'₂;
\v 19 a₂jme₁gang'₃ chog'₂-ŋéi'₅;\f + \fr 19:19 \ft Éxodo 20:12-16; Deuteronomio 5:16-20.\f* a₂jme₁'nióg'₄ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂ juɨ₁lia'₂ 'nióg'₃ 'ŋiag'₂ në́₃.\f + \fr 19:19 \ft Levítico 19:18.\f*
\p 
\v 20 Jaun₂ ca₂ŋag₃ táng₃ dsó₂ 'éi₂ ca₂tsɨ́'₃ Jesús:
\p ―Ca₂le₃jë́₃ a₂në₅ ma₂guio₃ jme₂tí₂. ¿'E₂ guë́₄ a₂siá'₂ 'nió'₅ jmo₅₄?
\p 
\v 21 Jaun₂ ca₂ŋag₃ táng₃ Jesús:
\p ―Në₁jua'₂ 'niog'₂ léng'₂ jan₂ dsa₂ i₂rë₂'ŋia₅ të₂le₃ quió'₅ jme₂dsí₂, guan'₂ o₂'nag₄ ca₂le₃jë́₃ a₂cha₂ quiáng'₂, jaun₂ o₂dsio'₅₄ ja₁con₂ dsa₂ te₂ŋé₂, jaun₂ le₂në₅ le₃cha₂ a₂jlá'₁ quiáng'₂ guei'₅₄ i₂juɨ́g₃; jaun₂ guë́₄ ŋe'₅₄ quian'₅₄ jniá₂.
\p 
\v 22 La₁ jme₁ca₂nág₂ dsó₂ jág₁ në₅, ca₂ŋái'₃ 'lia'₂ dsɨ́₅, ia₁ 'ŋio₅ lɨn₃ jme₁cha₂ cu₄.
\p 
\v 23 Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, 'e₂ guë́₄ quian₅ ta₁ quió'₅ jan₂ dsa₂ cha₂ cu₄ a₂'í₂ guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄.
\v 24 Juá'₅ jniá₂, tsá₃ guë́₄ 'e₂ ta₁ quian₅ a₂lé₂ le₃ŋɨ́₃ jan₂ já'₂ camello juɨ₅ tau₂ mɨ₂cu₄, lia'₂ con'₂ guë́₄ jan₂ dsa₂ cha₂ cu₄ a₂'í₂ ja₁gon₂ Diú₄.
\p 
\v 25 Jme₁ca₂nág₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ jág₁ në₅, 'ŋio₅ lɨn₃ ca₂i₃gó'₃ dsɨ́₅, jaun₂ qui₂ca₂ŋɨ́i'₃ rɨin'₅₄ con'₂ guioin₅₄:
\p ―¿I₂'ein₂ bá₄ guë'₂ jaun₂ në́₃ i₂lé₂ le₃tɨ́n'₄?
\p 
\v 26 Jaun₂ ca₂jág₃ Jesús ca₂jɨ́in₂ 'éi₂, jaun₂ ca₂juá'₂:
\p ―Dsón'₂ bá₄ jaun₂, të₂le₃ quió'₅ dsa₂ mɨ₂güɨ́g₃ o₁lɨ́g'₂ tsá₃ lé₂ le₃lé₂. La₁ të₂le₃ quió'₅ Diú₄, ca₂le₃jë́₃ bá₄ lé₂ le₃lé₂.
\p 
\v 27 Jaun₂ ca₂juá'₂ Pe₄ në́₃:
\p ―Te₁gui'₅₄, ca₂le₃jë́₃ 'e₂ a₂jme₁cha₂ quián₂ jnia'₅₄ ma₂ca₂tén'₃ dsɨ₅ jnia'₅₄ ma₂qui₂ca₂tí₄ ia₁ a₂'én₅ jnia'₅₄ 'ne₂. ¿'E₂ a₂tag₃ jnia'₅₄ në́₃?
\p 
\v 28 Jaun₂ ca₂ŋag₃ Jesús ca₂juá'₂:
\p ―A₂dsɨ₂jó'₃ juá'₅ jniá₂ juɨ́g₂ 'nia'₂, jë₁ma₂ca₂të́₂ jmɨg₄ i₁le₃'mag'₂ ca₂le₃jë́₃ 'a₂ lia'₂ niog₅ lë́₅ mɨ₂güɨ́g₃, jë₁ma₂ca₂të́₂ rë₁guá₃ Jaun₅ dsa₂ mɨ₂güɨ́g₃ ne₄ta₁ jlá'₁ quió'₅, jaun₂ 'nia'₂ në́₃ i₂ma₂ja₂nóg'₅ quiong'₅₄ jniá₂, nio₃ gog'₂ 'nia'₂ jma₃cáun₃ ta₁ a₂tiáng'₄ jmó'₂ gong'₂ qui₁dsɨ́'₂ 'éi'₃ ta₁guia₃-tɨ́n₂ nió'₃ dsa₂ juɨg₂ tsɨ₁jon₂ Israel.
\v 29 Ján₃ bá₄ le₂jaun₂ ján₃, ca₂le₃jɨ́n₃ i₂ma₂ca₂tén'₃ dsɨ́₅ dsi₂néi₂ quió'₅, i₂ma₂ca₂tén'₃ dsɨ́₅ chi'₂ rɨn'₅₄, o₃ chog₅₄-jmei₂, o₃ dsa₂ mɨ́₂ quiáin₅, o₃ chi'₂ quiáin₅, i₂ca₂tén'₃ dsɨ́₅ ca₂tí₂ ja₁nau₂ quió'₅ në́₃, 'uɨg₅₄ quió₃ jniá₂, ia₁ gue₃ caun₂ 'ŋiá₂-láu₂ ŋag₅₄ guë́₄ lia'₂ con'₂ guë́₄ a₂ma₂ca₂tí₂, ton'₂ gue₃ ján₃ a₂le₃chain₂ co₂tan₅₄.
\v 30 La₁ rë₂në́₃ juɨn₅ lɨn₃ i₂lɨ́n₅ i₂quen₅, la₁ jmɨg₄ jaun₂ léin₂ dsa₂ të₂le₃ jë₁ca₂tó'₂; le₂jaun₂ bá₄ ján₃ juɨ₁lia'₂ i₂tsá₃ 'e₂ quen₅ rë₂në́₃ lia'₂ con'₂ niog₅ lɨ́n₂ dsa₂ mɨ₂güɨ́g₃, léin₂ i₂le₂'uɨg₅₄.
\c 20
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ dsa₂ i₂jmo₅ ta₁ caun₂ ja₁nau₂
\p 
\v 1 ’Lë́₅ guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄ juɨ₁lia'₂ jan₂ dsa₂ juɨg₅₄ ja₁nau₂ i₂o₂'ɨn₅ të₃ o₃'iog₂, ca₂i₁tioin₁₂ dsa₂ i₂jmo₃ ta₁ ja₁nau₂ quió'₅ ja₁jnia₄ cho'₅₄ uɨng₂ uvas.
\v 2 Ca₂lɨ́'₃ bá₄ jág₁ quian'₅₄ dsa₂ i₂jmo₃ ta₁ a₂'liain'₅₄ jma₃ca₂'éi'₃ cu₄ denario lia'₂ co₂jmɨg₄, jaun₂ ca₂chein₃ dsa₂ 'éi₂ juɨ₅ ja₁nau₂ quió'₅.
\v 3 Jme₁co₂lág₂ jaun₂ o₂'ɨ́in₃ táng₃ con'₂ hora ŋí₁ ŋi₃ të₂le₃ o₃'iog₂,\f + \fr 20:3 \ft lit. “hora 'nɨ₅.” \f* jaun₂ ca₂jɨ́in₂ dsa₂ sián'₂ i₂tión₂ jɨn₅₄ jë₄ 'ma'₅₄.
\v 4 Jaun₂ ca₂tsɨ́'₃ dsa₂ 'éi₂: “O₂nó'₅ 'nia'₂ ján₃ o₂jmo₄ ta₁ ja₁nau₂ quió₃, quɨ́₄ bá₄ jniá₂ 'liang'₅₄ 'nia'₂ con'₂ dsi₂ten₅₄.” Jaun₂ i₃lén₂ bá₄ dsa₂ 'éi₂.
\v 5 Jaun₂ o₂'ɨ́in₃ táng₃ con'₂ dsi₂ŋí'₃,\f + \fr 20:5 \ft lit. “hora jŋéi₂.” \f* con'₂ siá'₂ hora ŋí₁ 'nɨ₅ të₂le₃ ca₂'láu₂ në́₃;\f + \fr 20:5 \ft lit. “hora ŋi₃.” \f* le₂jaun₂ bá₄ ca₂jmo₃ ján₃.
\v 6 Con'₂ siá'₂ o₂'ɨ́in₃ bá₄ guë́₄ con'₂ hora ŋí₁ 'ŋiá₂ të₂le₃ ca₂'láu₂,\f + \fr 20:6 \ft lit. “hora guia₃-cáun₃.” \f* ŋó₃ juɨ₅ jë₄ 'ma'₅₄, jaun₂ ca₂dsáin'₂ táng₃ dsa₂ i₂jɨn₅₄ tión₂. Jaun₂ ca₂tsɨ́'₃ 'éi₂: “¿'E₂ lë₃ tión'₂ 'nia'₂ ja₁lá₃ ta₁ne₁jmɨg₄ tsá₃ 'e₂ ta₁ jmo'₂?”
\v 7 Jaun₂ ca₂ŋag₃ dsa₂ 'éi₂ ca₂juá'₂: “Ia₁ 'i₁jan₂ tsá₃ 'ein₂ tio₅.” Jaun₂ ca₂ŋag₃ dsa₂ juɨg₅₄ ja₁nau₂ ca₂juá'₂: “O₂nó'₅ 'nia'₂ ján₃, o₂jmo₄ ta₁ ja₁nau₂ quió₃; quɨ́₄ bá₄ jniá₂ 'lian'₅₄ 'nia'₂ con'₂ dsi₂ten₅₄.”
\p 
\v 8 'Jme₁ca₂nei₂ jmɨg₄ jaun₂, ca₂juá'₂ juɨg₅₄ ja₁nau₂ ca₂tsɨ́'₃ dsa₂ i₂niog₅ ne₄ i₂te₂né'₂ dsa₂ ta₁: “Te'₂ dsa₂ i₂ma₂në₂jmo₃ ta₁, jaun₂ quɨ'₅₄ 'liain'₅₄. Jme₁lióg₄ de'₂ jŋiá₅ quian'₅₄ dsa₂ i₂në₂tión'₂ jë₁ca₂tó'₂, jaun₂ dsian₅ quian'₅₄ i₂në₂tión'₂ le₂'uɨg₅₄.”
\v 9 Jaun₂ dsi₃lén₂ dsa₂ i₂ca₂tón'₂ ca₂jmo₃ ta₁ hora ŋí₁ 'ŋiá₂ të₂le₃ ca₂'láu₂, jaun₂ le₂jain₂ le₂jain₂ ca₂gue₃ 'liain'₅₄ jma₃ca₂'éi'₃ cu₄ denario.
\v 10 Jme₁co₂lág₂ jaun₂, ca₂tɨ́n₂ dsa₂ i₂ca₂i₃ton'₅₄ le₂'uɨg₅₄, i₃jiog₅ dsɨ́₅ a₂jme₁gue₃ guë́₄ ŋag₅₄ 'liain'₅₄; la₁ co₂rë₂ bá₄ 'liain'₅₄ ca₂gue₃ jma₃ca₂'éi'₃ cu₄ denario le₂jain₂ le₂jain₂.
\v 11 La₁ jme₁ma₂në₂gue₃ 'liain'₅₄, i₃léin₂ i₃chog'₄ dso₄ ne₄ juɨg₅₄,
\v 12 jaun₂ ca₂juá'₂: “Dsa₂ i₂o₃lén₂ jë₁ca₂tó'₂, caun₂ hora bá₄ në₂tióin'₂ në₂jmo₃ ta₁; co₂jaun₂ bá₄ 'liain'₅₄ në₂gue₃ ján₃ con'₂ 'liog'₅₄ jnia'₅₄ i₂në₂tió'₄ në₂jmó₁ ta₁ ta₁ne₁jmɨg₄ në₂ŋag₅₄ 'iog₂ dséi₂ 'ŋio₅ lɨn₃.”
\v 13 La₁ ca₂ŋag₃ juɨg₅₄ ca₂tsɨ́'₃ jan₂: “A₂mei₅₄ quiáng₃, tsá₃ 'e₂ jua'₅₄ a₂tsá₃ dsi₂ten₅₄ jmo₅ jniá₂ ja₁cong'₂. ¿Tsa₁ ca₂lë₃ jág₁ a₂'liang'₅₄ ca₂'éi'₃ cu₄ denario guë'₂?
\v 14 Juɨ₁le₂'ŋio₂ 'au'₂ con'₂ ma₂'liang'₅₄ në₅, guan'₂ quiáng'₂. Në₁jua'₂ jniá₂ le₂në₅ ca₂lë₃ dsɨ₃ quɨ́₄ 'lian'₅₄ dsa₂ i₂në₂tong₅₄ jë₁ca₂tó'₂ con'₂ 'lian'₅₄ 'ne₂,
\v 15 ¿o₃ tsa₁ ca₂tɨ́n₂ jniá₂ jmo₅₄ quian'₅₄ cu₄ quió₃ 'a₂ lia'₂ jŋia'₅₄ 'nio₃ jmo₅₄? ¿O₃ ja₂ uɨg₅ 'au'₂ 'e₂, ia₁ a₂'ua₁ dsɨ₃?”
\p 
\v 16 'Jaun₂ në́₃ juɨ₁lia'₂ dsa₂ i₂lɨ́n₅ të₂le₃ jë₁ca₂tó'₂ rë₂në́₃, léin₂ i₂le₂'uɨg₅₄ jmɨg₄ jaun₂; le₂në₅ bá₄ ján₃, juɨ₁lia'₂ i₂lɨ́n₅ i₂le₂'uɨg₅₄ rë₂në́₃, léin₂ dsa₂ të₂le₃ jë₁ca₂tó'₂.
\s1 Con'₂ siá'₂ táng₃ ca₂'ë́₂ Jesús jág₁ a₂jóin₂
\r (Marcos 10:32-34; Lucas 18:31-34)
\p 
\v 17 Jme₁ma₂'en₅₄ Jesús juɨ₅ uɨ́g₂ tso₄ a₂dsióg₄ Jerusalén, jaun₂ ca₂të́'₃ cau₅ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ ca₂juá'₂:
\p 
\v 18 ―Juɨ₁lia'₂ jág'₂ 'nia'₂, tio'₅₄ jniog₄ juɨ₅ tso₄ la₂ a₂dsi₁náu₅ Jerusalén. Ja₁jaun₂ jáng'₂ dsa₂ jɨ́in'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ o₄gú₃ juɨg₅₄ jme₂dsa₂, ne₄ të₅juá'₅ në́₃; 'éi₂ guë́₄ në́₃ cuë₃ 'éi'₃ a₂jŋag'₃ dsa₂.
\v 19 Jáng'₂ dsa₂ në́₃ o₄gú₃ dsɨ₂nau₂ ia₁jaun₂ jmóg'₂ burlas, qui₃bóg₂ dsa₂, jaun₂ guë́₄ tioin₃ cróg₄ jŋag'₃; la₁ a₂'nɨ₅ jmɨg₄ jaun₂, jein'₅₄ le₃chain₂ bá₄ táng₃.
\s1 Juɨ₁lia'₂ a₂ca₂mɨ₃ chog₅₄ Jacobo quian'₅₄ Juan₅₄
\r (Marcos 10:35-45)
\p 
\v 20 Jaun₂ ca₂jme₃quián₃ chog₅₄ Jacobo quian'₅₄ Juan₅₄, ja₁ŋi'₅₄ Zebedeo, ja₁'en₅₄ Jesús. Jaun₂ ca₂chi₃jné₃ ca₂mɨ₃ a₂jmo₃ 'éi₂ dse₃ dsɨ́₅.
\v 21 Jaun₂ ca₂ŋag₃ Jesús:
\p ―¿'E₂ 'niog'₂ 'ne₂?
\p Jaun₂ ca₂ŋag₃ chog₅₄ chi'₂ 'éi₂:
\p ―¿Tsa₁ cuë́'₁ jmɨg₄ a₂tian'₃ jma₃jan₂ chi'₂ quiáng₃ cong'₂, jë₁ma₂të́₂ rë₁ne'₅₄ gong'₂ ne₄ta₁ quiáng'₂, jan₂ të₂le₃ gog'₂ ne₁, jan₂ guë'₂ të₂le₃ gog'₂ jen₅?
\p 
\v 22 La₁ Jesús në́₃ ca₂ŋag₃:
\p ―Tsá₃ ŋi'₅₄ 'nia'₂ 'e₂ a₂mɨ'₂. ¿Tian'₃ 'nia'₂ dsɨ₃ŋɨ́g'₂ ca₂le₃jë́₃ juɨ₁lia'₂ a₂dsɨ₃ŋɨ́₂ jniá₂ guë'₂?\f + \fr 20:22 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ le₂la₂ ján₃: “¿Tian'₃ 'nia'₂ cán'₁ o₂i₁ dsɨ₅ juɨ₁lia'₂ o₂i₁ dsɨ₅ a₂can₅₄ jniá₂?” \f*
\p Jaun₂ ca₂ŋag₃ 'éi₂:
\p ―Tián₂ bá₄ jnia'₅₄.
\p 
\v 23 Jaun₂ ca₂juá'₂ táng₃ Jesús:
\p ―Dsón'₂ bá₄ jaun₂ dsɨ₃ŋɨ́'₂ 'nia'₂ juɨ₁lia'₂ 'a₂ lia'₂ niog₅ dsɨ₃ŋɨ́₂ jniá₂,\f + \fr 20:23 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ le₂la₂ ján₃: “ján₃ bá₄ cán'₁ 'nia'₂ o₂i₁ dsɨ₅ juɨ₁lia'₂ o₂i₁ dsɨ₅ can₅₄ jniá₂.” \f* la₁ juɨ₁lia'₂ a₂juá'₂ 'nia'₂ në₅ a₂tiáng'₄ jma₃ca₂ton₂ cau₅ quió₃, on₃jua'₅₄ jniá₂ ca₂tɨ́ng₂ cuë₅₄ a₂jaun₂. Ja₁jaun₂ ma₂jmo₃ Ŋe'₃ jniá₂ co₂jŋia₅₄ a₂tian'₃ con'₂ i₂ca₂tɨ́n₂ bá₄.
\p 
\v 24 Rɨin'₅₄ i₂guian₃ guë́₄ 'éi₂ në́₃ ca₂rë₃'néi₃ quian'₅₄ i₂on₃ 'éi₂ jme₁ca₂nág₂ jág₁ jaun₂.
\v 25 La₁ ca₂të₃ Jesús, jaun₂ ca₂juá'₂:
\p ―Ŋi'₅₄ bá₄ 'nia'₂, juɨ₁lia'₂ dsɨ₂tan₅₄ dsa₂ can'₅₄ i₂tián'₅ gon₂ ca₂le₃jë́₃ juɨg₂,\f + \fr 20:25 \ft o₃, “i₂tián'₅ gon₂ jɨn₄ dsɨ₂nau₂.” \f* qui₂toin'₂ dsa₂ 'éi'₃ bén₂. Le₂jaun₂ bá₄ jmo₅ juɨ₁lia'₂ dsɨ₂tan₅₄ i₂sion₅ guë́₄, tiáin'₅ goin₂ jmo₂₃ 'éi'₃.
\v 26 La₁ jɨn'₄ 'nia'₂, tsá₃ le₂jaun₂ lé₂. Chi₂jua'₂ 'ein₂ 'nio₃ jmo₃ juɨn'₂, ca₂tɨ́in₂ jme₃ti₃ ta₁ ne₄ rɨin'₅₄;
\v 27 chi₂jua'₂ 'ein₂ 'nia'₂ 'nio₃ cán₂ ne₄ juɨ₅, 'nió'₅ jme₃ti₃ ne₄ ca₂le₃jɨ́n₃ dsa₂.
\v 28 Ia₁ le₂në₅ bá₄ Jaun₅ dsa₂ mɨ₂güɨ́g₃, tsá₃ ta₁ jaun₂ já₅ jua'₅₄ a₂jme₃ti₃ dsa₂ ne₅₄; a₂jme₃ti₃ ta₁ ne₄ dsa₂ bá₄ já₅, a₂quí₃ quian'₅₄ 'mú₃ co₂'nió'₄ 'lia'₅₄ ia₁jaun₂ tɨ́n'₄ juɨn₅.
\s1 Ca₂jme₃'lión₂ Jesús on₃ dsa₂ ten₄
\r (Marcos 10:46-52; Lucas 18:35-43)
\p 
\v 29 Jme₁ma₂tioin'₅₄ juɨ₅ 'uɨin₂ juɨg₂ Jericó, juɨn₅ dsa₂ ja₁jaun₂ ca₂jme₃quiain'₅₄ Jesús.
\v 30 Juɨ₅ ja₁ŋó₄ jaun₂, jme₁tián'₄ on₃ dsa₂ ten₄ cau₅ juɨ₅. Dsa₂ 'éi₂ në́₃ jme₁ca₂nág₂ a₂ŋó₅ Jesús cau₅ jaun₂, ca₂juá'₂ tiá₂:
\p ―¡Te₁gui'₅₄, tsɨ₁jon₂ David, dsia₄ ŋéi₂ 'au'₂ jnia'₅₄!
\p 
\v 31 Jaun₂ ca₂jí₂ bá₄ dsa₂ ia₁jaun₂ dsɨ₃léin₂ tei₄. La₁ të₂le₃ i₂juɨ'₂ guë́₄ co₂mɨ'₅₄ ca₂tóin'₂ bá₄, ca₂juá'₂:
\p ―¡Te₁gui'₅₄, tsɨ₁jon₂ David, dsia₄ ŋéi₂ 'au'₂ jnia'₅₄!
\p 
\v 32 Jme₁ca₂nág₂ Jesús, jaun₂ ca₂nau₂, jaun₂ ca₂të́'₃ le₃on₃ dsa₂ 'éi₂, jaun₂ ca₂ŋag₃:
\p ―¿'E₂ 'niog'₂ 'nia'₂ jmo₅₄ jniá₂ o₄quián'₂ 'nia'₂?
\p 
\v 33 Jaun₂ ca₂ŋag₃ dsa₂ 'éi₂:
\p ―Te₁gui'₅₄, a₂jnia₅₄ mɨ₂ne₄ bá₄ jnia'₅₄ 'niog₂.
\p 
\v 34 Jaun₂ ca₂dsia₃ bá₄ Jesús ŋéi₂ dsɨ́₅, jaun₂ ca₂tí₂ gu₂ jme₁ne₁ dsa₂ 'éi₂. Jaun₂ dsɨ₂juɨ₅ le₂jaun₂ ca₂jnia₃ jme₁ne₁ dsa₂, jaun₂ i₃léin₂ bá₄ jaun₂ ca₂jme₃quiain'₅₄ Jesús.
\c 21
\s1 Ca₂'í₃ Jesús jë₄ juɨg₂ Jerusalén
\r (Marcos 11:1-11; Lucas 19:28-40; Juan 12:12-19)
\p 
\v 1 Jme₁ma₂quián₅ dsi₁léin₂ Jerusalén, dsi₃léin₂ quián₅ juɨg₂ Betfagé a₂niog₅ cau₅ Má'₂ Olivos, ja₁jaun₂ ca₂chen₃ Jesús on₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅,
\v 2 ca₂juá'₂:
\p ―O₂nó'₅ 'nia'₂ juɨg₂ pí'₁ niog₅ të₂le₃ ne₄ juɨ₅ ja₁dsau₅₄ në₅. Ja₁jaun₂ dsian'₂ 'nia'₂ jan₂ i₂bú'₄ mɨ́₂ rë₂'ŋe'₅₄, chéin'₅ quian'₅₄ guein₂ quiáin₅. O₂chein'₅₄ 'nia'₂ jaun₂ të'₅₄ ja₁lá₃.
\v 3 Në₁jua'₂ 'ein₂ ŋag₅ 'e₂ lë₃ tsɨin'₅₄, jaun₂ juɨg'₅₄ 'nia'₂: “Te₁gui'₅₄ bá₄ 'nio₃ ca₂tiá₂.” Jaun₂ në₃ cón'₅ bá₄ cuag₃.
\p 
\v 4 Ca₂lë₃ le₂në₅ ia₁jaun₂ le₃ti₃ jág₁ a₂ca₂tó'₂ ne₄ si₂ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂, jme₁ca₂juá'₂:
\q1 
\v 5 Chei'₅₄ dsa₂ juɨg₂ i₂tián'₅ Sión:
\q1 “Jag₄, në₅ jón'₅ Rag₅₄ quián'₂ 'nia'₂ ja₁cong'₂,
\q2 a₂lɨ́in₅ jan₂ dsa₂ me'₂, tsá₃ jláin'₁,
\q1 jóin'₅ co₂dsɨin₅₄ jan₂ bú'₄,
\q2 jóin'₅ quian'₅₄ jaun₅ já'₂ i₂cán₂ lio₅₄ bá₄”.\f + \fr 21:5 \ft Zacarías 9:9.\f*
\p 
\v 6 Jaun₂ ca₂i₃lén₂ bá₄ i₂on₃ 'éi₂, ca₂jmo₃ bá₄ con'₂ lë́₅ jág₁ a₂ca₂cuë₃ Jesús.
\v 7 Jaun₂ ca₂i₁te₂ bú'₄ lia'₂ jma₃quian'₅₄ guein₂ quiáin₅, ca₂i₁jiog₃ ja₁'en₅₄ Jesús. Jaun₂ ca₂jlág₂ nɨ₁tsɨn'₅₄ mɨ₂ca'₄ já'₂, jaun₂ guë́₄ ca₂co₃dsag₅₄ Jesús.
\v 8 Jaun₂ dsa₂ juɨn₅ i₂quiain'₅₄ në́₃ i₂jŋiá₅ le₃ne₄ juɨ₅ qui₂ca₂néi'₃ 'mɨ'₂ le₂'i₄ juɨ₅ ja₁ŋɨ́₃ Jesús; i₂lɨn₅₄ guë'₂ qui₂ca₂'nia₃ mog'₅₄ 'ma₂tsɨ́n₅, qui₂ca₂jó₃ dsi₂juɨ₅.
\v 9 Dsa₂ i₂i₃lén₂ le₃ne₄ juɨ₅, quian'₅₄ i₂ja₂lén₂ le₃chi₁co'₅₄ në́₃, qui₂ca₂tóin'₂ co₂mɨ'₅₄ ca₂juá'₂:
\q1 ¡Juɨ₁le₂juɨn'₂\f + \fr 21:9 \ft lit. “Hosana”, a₂jein₅ jág₁ quian'₅₄ jág₁ jmei₅ arameo: “Lio₄ jnia'₅₄”, co₂'nió'₄ a₂qui₂mɨ₅ dsa₂ ne₄ Diú₄ a₂jiá₃ I₂rë₂'ɨ́n₁ quiáin₅; la₁ cang₂ jaun₂ táng₃ ca₂jein₃ jág₁ a₂jme₂juɨn'₂ dsa₂ jan₂ dsa₂. Ján₃ bá₄ le₂në₅ \f* bá₄ tsɨ₁jon₂ David!
\q2 ¡Juɨ₁le₂jŋió₃ bá₄ i₂në₅ i₂já₅ o₄quió'₄ Te₁gui'₅₄!\f + \fr 21:9 \ft Salmo 118:26.\f*
\q2 ¡Juɨ₁le₂juɨn'₂ bá₄ i₂guá₅ guei'₅₄ i₂juɨ́g₃!
\p 
\v 10 Jme₁ca₂'í₃ Jesús jë₄ juɨg₂ Jerusalén, jaun₂ qui₂ca₂tón'₂ go₂'i₃ dsa₂ juɨg₂, juɨn₅ i₂qui₂ca₂ŋag₃:
\p ―¿'Ein₂ bá₄ në₅?
\p 
\v 11 Jaun₂ qui₂ca₂ŋag₃ dsa₂ juɨn₅ i₂quian'₅₄ Jesús, ca₂juá'₂:
\p ―Jesús bá₄ la₂, dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄, i₂chan₂ juɨg₂ Nazaret ja₁tén₄ Galilea.
\s1 Ca₂'uɨ́n'₂ Jesús dsa₂ i₂jme₁tion'₅₄ dsia₅ 'ma'₅₄ i₁dsi₅ guá'₅
\r (Marcos 11:15-19; Lucas 19:45-48; Juan 2:13-22)
\p 
\v 12 Ca₂dsióg₃ Jesús jme₁ca₂dsióg₃ i₁dsi₅ guá'₅ templo, jaun₂ qui₂ca₂'uɨ́in'₂ ca₂le₃jɨ́n₃ dsa₂ i₂jme₁ma₂tion'₅₄ dsia₅ 'ma'₅₄ i₁dsi₅ guá'₅, dsa₂ i₂'nag₅, i₂qui₂lá₅ në́₃, qui₂ca₂jéin'₃ nɨ₁mesa ja₁jme₁jmó'₂ dsa₂ ta₁ jme₂tsɨ́in₃ cu₄, qui₂ca₂quɨ́'₂ 'ma₂sɨ₅₄ ja₁jme₁tián'₄ dsa₂ i₂'nɨ₅ i₁ju₂;
\v 13 jaun₂ ca₂juá'₂:
\p ―Ne₄ Si₂ juá'₂: “'Né₅ quió₃ lë́₅ ca₂ne₅₄ 'né₅ ja₁të₁ja₂lén₂ dsa₂ ja₂chi'₅₄ Diú₄”;\f + \fr 21:13 \ft Isaías 56:7.\f* la₁ 'nia'₂ në́₃ ma₂jmo'₅₄ në₂jag₄ bá₄ të₂'lau₂ quió'₅ dsa₂ 'ang₂.\f + \fr 21:13 \ft Jeremías 7:11.\f*
\p 
\v 14 Jaun₂ ca₂jme₃quián₃ i₂lɨn₅₄ dsa₂ ten₄ quian'₅₄ dsa₂ guian'₅₄ në́₃ con₂ Jesús i₁dsi₅ guá'₅, jaun₂ ca₂jme₃'lióin₂ bá₄ dsa₂ 'éi₂.
\v 15 La₁ jme₁ca₂jág₃ juɨg₅₄ jme₂dsa₂ quian'₅₄ të₅juá'₅ léi₄ jlá'₁ a₂ca₂jmo₃ Jesús jaun₂, ton'₂ ia₁ ca₂nág₂ në́₃ tion'₅₄ chi'₂ co₂mɨ'₅₄ qui₂guió'₅ i₁dsi₅ guá'₅, a₂juá'₂: “¡Juɨ₁le₂juɨn'₂ tsɨ₁jon₂ David!”, jaun₂ ca₂rë₃'néi₃.
\v 16 Jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ Jesús:
\p ―¿Tsa₁ nag'₂ 'e₂ juá'₂ chi'₂?
\p Jaun₂ ca₂ŋag₃ Jesús:
\p ―Ján₅, nag₅ bá₄ jniá₂. Ia₁, ¿tsa₁ ma₂'í'₂ 'nia'₂ ne₄ Si₂ ja₁juá'₂:
\q1 Te₁gui'₅₄, 'ne₂ bá₄ ma₂ca₂jmo'₅₄
\q2 'e₂ a₂'uë₂ mɨ₂'o₄ chi'₂ bë'₅₄
\q1 quian'₅₄ mɨ₂'o₄ guein₂ tei₄ i₂guén'₅ dsi'₅₄,
\q2 'uë₂ jág₁ a₂jme₂juɨin'₂ 'ne₂?\f + \fr 21:16 \ft Salmo 8:2.\f*
\p 
\v 17 Jaun₂ ca₂o₃'ɨ́in₃ bá₄ ja₁tion'₅₄ 'éi₂, jaun₂ ca₂ŋái'₃ táng₃ juɨg₂ Betania. Ja₁jaun₂ ca₂jŋia₂ caun₂ nei₅.
\s1 Ca₂juá'₂ Jesús caun₂ jág₁ a₂ca₂cuë́'₃ uɨg₅ caun₂ nɨ₁'ma₂ higuera a₂tsá₃ mɨ́g₂ cha₂
\r (Marcos 11:12-14, 20―26)
\p 
\v 18 Jme₁jnia₃ jaun₂, jme₁ma₂tioin'₅₄ juɨ₅ a₂i₂lein₃ táng₃ juɨ₅ jë₄ juɨg₂ Jerusalén. Jesús në́₃ ca₂tá'₂ i₁cón'₅.
\v 19 Jaun₂ ca₂jág₃ caun₂ nɨ₁'ma₂ higuera a₂dsi₅₄ cau₅ juɨ₅, jaun₂ ca₂jme₃quiáin₃ 'uɨg₅₄, la₁ tsá₃ 'e₂ mɨ́g₂ ca₂dsó'₂ guë'₂ guei'₅₄ nɨ₁'ma₂; jŋia'₅₄ lia'₂ jmá'₃ mog'₅₄ bá₄ cha₂. Jaun₂ në́₃ ca₂juá'₂ Jesús ca₂tsɨ́'₃ nɨ₁'ma₂:
\p ―¡Lia'₂ o₁lɨ́g'₂ jmɨg₄, tsá₃ ma₃juɨ₁'ag₅₄ mɨ́g₂ quiáng'₂!
\p Dsɨ₂juɨ₅ jaun₂ bá₄ ca₂rë₃quéin₃ nɨ₁'ma₂ jaun₂.
\v 20 Jme₁ca₂të́₂ ne₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ a₂ca₂lë₃ jaun₂, ca₂i₃gó'₃ dsɨ́₅, jaun₂ ca₂ŋɨ́i'₃ Jesús:
\p ―¿'A₂ bá₄ lia'₂ con'₂ tan₅₄ lia'₂ dsɨ₂juɨ₅ ca₂rë₃quéin₃ nɨ₁'ma₂ në₅?
\p 
\v 21 Jaun₂ ca₂ŋag₃ Jesús:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, në₁jua'₂ tsá₃ ca₂'éi'₂ 'nia'₂ caun₂-tɨn₃ 'au'₂ lia'₂ 'éng'₂, on₃jua'₅₄ jmá'₃ juɨ₁lia'₂ a₂në₂jmo₃ jniá₂ quian'₅₄ nɨ₁'ma₂ higuera në₅, lé₂ le₃jmó'₂ 'nia'₂, ia₁ lé₂ le₃jua'₅₄ 'nia'₂ ján₃ juɨg'₅₄ nɨ₁má'₂ ó₃: “Jŋiag'₃ ja₁në₅, o₃ o₂'ú₅ jmɨ₁ŋí'₄”, le₂jaun₂ dsón'₂ lé₂ bá₄.
\v 22 Le₂jaun₂ bá₄ ján₃ ca₂le₃jë́₃ 'e₂ a₂mɨ'₂ 'nia'₂ jme₁mɨ'₂ ne₄ Diú₄, në₁jua'₂ 'én'₂ të₃dsón'₂ 'nia'₂, guéi'₁ bá₄ 'nia'₂.
\s1 Jesús bá₄ i₂'io₅ 'éi'₃
\r (Marcos 11:27-33; Lucas 20:1-8)
\p 
\v 23 Jaun₂ ca₂'í₃ táng₃ Jesús i₁dsi₅ guá'₅ templo, jaun₂ të₁lia'₂ 'ein₅₄ jme₂tɨin₂₃ dsa₂, jaun₂ ca₂jme₃quián₃ juɨg₅₄ jme₂dsa₂ quian'₅₄ i₂lɨ́n₅ dsa₂ can'₅₄ quián₅ dsa₂ juɨg₂, con₂ Jesús, jaun₂ ca₂ŋag₃:
\p ―¿'E₂ ta₁ lɨ́n'₅ 'ne₂, 'e₂ lë₃ jmo'₂ ca₂le₃jë́₃ 'e₂ a₂jmo'₂ ŋɨ'₂? ¿'Ein₂ ca₂cuë₃ bí₂ 'éi'₃ në₅?
\p 
\v 24 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Ján₃ bá₄ ŋag₄ jniá₂ caun₂ 'nia'₂: në₁jua'₂ ca₂ŋag'₅₄ 'nia'₂ lia'₂ tí₅, jaun₂ guë́₄ juá'₄ jniá₂ 'ein₂ cuë₅ bí₂ 'éi'₃ a₂jmo₂₃ ca₂le₃jë́₃ a₂jmo₂₃.
\v 25 Juɨ₁lia'₂ a₂ca₂chon₃ Juan₅₄ jmɨg₂ dsa₂, ¿'ein₂ quió'₅ 'éi'₃ jaun₂? ¿Quió'₅ Diú₄, o₃ quió'₅ dsa₂ mɨ₂güɨ́g₃ 'e₂?
\p Jaun₂ ca₂dsia₃ dsa₂ can'₅₄ jág₁ con'₂ guioin₅₄, ca₂juá'₂:
\p ―Në₁jua'₂ ca₂chei₅₄ jniog₄ 'éi'₃ quió'₅ Diú₄ bá₄ jaun₂, në₃ cón'₅ bá₄ ŋag₃: “¿'E₂ lë₃ tsá₃ ca₂rë₃'én'₂ 'nia'₂ jág₁ quió'₅ 'éi₂?”
\v 26 La₁ në₁jua'₂ ca₂ŋag₄ guë'₂ jniog₄ 'éi'₃ quió'₅ dsa₂ mɨ₂güɨ́g₃ në́₃, le₃'ne₂ dsa₂ juɨg₂ quian'₅₄ jniog₄, ia₁ ca₂le₃jɨ́n₃ bá₄ dsa₂ jmo₂₃ dsɨ́₅ a₂jme₁lɨ́n₄ Juan₅₄ jan₂ dsa₂ i₂ca₂'ë́₂ jág₁ quián₅ Diú₄.
\v 27 Jaun₂ në́₃, ca₂ŋag₃ dsa₂ can'₅₄ 'éi₂ ca₂tsɨ́'₃ Jesús:
\p ―Tsá₃ a₂jaun₂ ne₄ jnia'₅₄ 'ein₂ ca₂chen₃ 'éi₂.
\p Jaun₂ në́₃, ca₂ŋag₃ Jesús:
\p ―Ján₃ bá₄ le₂në₅ tsá₃ juá'₄ jniá₂ 'ein₂ cuë₅ bí₂ a₂jmo₂₃ ca₂le₃jë́₃ a₂jmo₂₃ ŋɨ₂₃.
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ on₃ ja₁ŋi'₅₄ jan₂ dsa₂
\p 
\v 28 Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂ 'éi₂:
\p ―¿'A₂ lia'₂ lɨ́n'₂ 'nia'₂ juɨ₁lia'₂ jág₁ la₂? Jan₂ dsa₂ jme₁chan₂ on₃ ja₁ŋi'₅₄. Jaun₂ ca₂tsɨ́'₃ chi'₂ quiáin₅ i₂lɨ́n₅ i₂juɨn'₂ guë́₄: “Jón₃, gua₂ o₂jmo₄ ta₁ ja₁nau₂ quián₂ jmɨg₄ në₃.”
\v 29 Jaun₂ ca₂ŋag₃ chi'₂ quiáin₅: “¡Tsá₃ nei₅₄!” La₁ jme₁co₂lág₂ jaun₂ ca₂jme₃tsɨ́in₃ 'a₂ lia'₂ dsɨ₂jiog₅ dsɨ́₅, jaun₂ ŋó₃ bá₄ i₁jmo₅₄ ta₁.
\v 30 Jaun₂ ca₂ŋe₄ táng₃ jmei₂ i₁chi'₄ chi'₂ jan₂ quiáin₅. Ján₃ bá₄ le₂jaun₂ ca₂tsɨ́'₃ 'éi₂. I₂'éi₂ në́₃ ca₂ŋag₃: “Nei₅₄ bá₄ jniá₂, tia₅₄, i₁jmo₃ ta₁.” La₁ tsá₃ ŋei₅₄ guë'₂ jaun₂ në́₃.
\v 31 Jë₄ le₃oin₃ le₂jaun₂, ¿'ein₂ ca₂jmo₃ a₂'ŋio₂ dsɨ́₅ jmei₂?
\p Jaun₂ ca₂ŋag₃:
\p ―Chi'₂ i₂le₂'uɨg₅₄ bá₄.
\p Jaun₂ ca₂juá'₂ Jesús:
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, dsa₂ i₂cán₂ 'lia'₅₄ quián₅ dsɨ₂tan₅₄, o₃ juɨ₁lia'₂ 'io₅₄ i₂'nag₅ quió'₅ në́₃, i₂le₂'éi₂ bá₄ tiá₂ le₂'uɨg₅₄ dsɨ₃ton'₅₄ ja₁gon₂ Diú₄ lia'₂ con'₂ guë́₄ 'nia'₂.
\v 32 Ia₁ lia'₂ con'₂ jme₁guan₃ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂, ca₂jme₃jniai₂₃ ja₁con'₂ 'nia'₂ 'a₂ lia'₂ dsón'₂ ca₂tɨ́ng'₂ 'nia'₂ tiáng'₄. La₁ tsá₃ a₂jaun₂ ca₂rë₃'én'₂ 'nia'₂. Ia₁ a₂dsau₅ bá₄ juɨ₁lia'₂ dsa₂ i₂cán₂ 'lia'₅₄ quián₅ dsɨ₂tan₅₄, quian'₅₄ 'io₅₄ i₂'nag₅ quió'₅ në́₃, ca₂rë₃'éin₂ jág₁ quió'₅ Juan₅₄. La₁ a₂dsau₅ bá₄ o₁jŋia'₅₄ a₂ca₂të́₂ ne'₅₄ 'nia'₂ jaun₂, tsá₃ ca₂tá'₂ jén₂ 'au'₂ 'nia'₂, on₃ guë'₂ ca₂rë₃'éng'₂.
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ co₂nió'₃ dsa₂ 'lɨn'₅₄ i₂jmó'₂ ta₁ ja₁nau₂
\r (Marcos 12:1-12; Lucas 20:9-19)
\p 
\v 33 ’Nei₂ 'nia'₂ jág₁ a₂jáng'₅ léi₄ siá'₂ la₂: Jan₂ dsa₂ ca₂chéin'₃ cho'₅₄ uɨng₂ uvas ja₁nau₂ quió'₅. Jaun₂ ca₂jmo₃ jnɨ́₁ le₃lág'₃; ca₂jmo₃ co₂jŋia₅₄ ja₁jlein'₃ mɨ́g₂ në́₃; caun₂ guë'₂ tsɨ₁'né₅ ŋei₅ ca₂chi'₃ ja₁guá₃ jmo₃ 'í₁. Jaun₂ ca₂lɨ́'₃ jág₁ quian'₅₄ dsa₂ sián'₂ i₂nio₃ ne₄ ja₁nau₂, jaun₂ ca₂ŋó₃ bá₄ 'ŋiog₅ i₁ŋɨ₂ juɨg₂ siá'₂.
\v 34 Jme₁ca₂të́₂ jein₂ a₂ca₂rau₂ mɨ́g₂, jaun₂ dsa₂ juɨg₅₄ ja₁nau₂ ca₂chein₃ co₂nió'₃ dsa₂ mozo quiáin₅, a₂jme₁i₂mɨ́₃ a₂jáng'₃ dsa₂ i₂niog₅ gu₂ ja₁nau₂ ca₂dsio₄ mɨ́g₂ con'₂ a₂ca₂tɨ́n₂ juɨg₅₄.
\v 35 La₁ dsa₂ i₂tion'₅₄ jmó'₂ ta₁ ja₁nau₂ në́₃, ca₂jŋai'₃ bá₄ dsa₂ mozo i₂chen₄ quián₅ juɨg₅₄. Ca₂cuë́'₃ bá₄ jan₂ tioin'₅₄; jan₂ guë'₂ ca₂jŋɨi'₃; jan₂ guë'₂ ca₂cuë́'₃ quian'₅₄ nɨ₁cang₁.
\v 36 La₁ juɨg₅₄ ja₁nau₂ në́₃, juɨn₅ guë́₄ i₂ca₂chein₃ cang₂ jaun₂ con'₂ guë́₄ le₂'uɨg₅₄; la₁ dsa₂ 'lɨn'₅₄ i₂tion'₅₄ jmo₅ ta₁ ja₁nau₂ në́₃, le₂jaun₂ bá₄ qui₂ca₂jmái'₂ ca₂le₃jɨ́n₃ dsa₂ mozo i₂chen₄ 'éi₂.
\p 
\v 37 ’La₁ jë₁ca₂tó'₂ në́₃, dsa₂ juɨg₅₄ ja₁nau₂ ca₂chein₃ ja₁ŋi'₅₄, ia₁ lɨ́in₂: “Jme₃go₃ dsa₂ jme₃gain₃ chi'₂ quiáng₃.”
\v 38 La₁ jme₁ca₂jág₃ dsa₂ i₂jmo₅ ta₁ ja₁nau₂ ca₂jɨ́in₂ ja₁ŋi'₅₄ dsa₂ juɨg₅₄ ca₂dsióg₃, jaun₂ ca₂dsia₃ jág₁ tioin'₅₄: “I₂në₅ bá₄ tɨn₃ ja₁nau₂ la₂ cang₂; në₃ o₁jŋɨ́i'₄ jniog₄ ia₁jaun₂ jniog₄ bá₄ lé₂ quián₂.”
\v 39 Le₂jaun₂ bá₄ ca₂jmo₃. Ca₂jŋai'₃ bá₄ 'éi₂ tioin'₅₄, jaun₂ ca₂dsei₂₃ le₃co'₅₄ jnɨ́₁; ja₁jaun₂ ca₂jŋag'₃.
\p 
\v 40 ’Jaun₂ në́₃, jë₁ma₂të́₂ jmɨg₄ rë₁jŋió'₂ dsa₂ juɨg₅₄ ja₁nau₂, ¿'e₂ lɨ́n'₂ 'nia'₂ jmo₃ quian'₅₄ dsa₂ i₂jmó'₂ ta₁ ja₁nau₂ 'éi₂?
\p 
\v 41 Jaun₂ ca₂ŋag₃ dsa₂ 'éi₂:
\p ―A₂jme₃dsiain₂₃ dsa₂ 'lɨn'₅₄ 'éi₂ ca₂lia'₂ tsá₃ ŋéi₂ dsɨ́₅, jaun₂ cuë́'₃ dsa₂ sián'₂ ja₁nau₂ con'₂ i₂léi₄ jáng'₃ ca₂dsio₄ con'₂ ca₂tɨ́in₂ jë₁ma₂të́₂ jein₂ a₂ráu₃.
\p 
\v 42 Jaun₂ në́₃, ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂:
\p ―¿Tsa₁ ma₂'í'₂ 'nia'₂ ne₄ Si₂ ja₁juá'₂:
\q1 Nɨ₁cang₁ a₂tsá₃ ca₂rë₃ji'₅₄ të₅'ia'₂,
\q2 ca₂dsióg₃ ca₂lë₃ nɨ₁cang₁ a₂dsen₅₄ guë́₄
\q2 të₁ron₅₄ qui'₅₄ 'ia'₂;
\q1 a₂ca₂jmo₃ Te₁gui'₅₄ bá₄ jaun₂,
\q2 jaun₂ 'ŋio₅ lɨn₃ bá₄ jlá'₁, lág₂ jniog₄?\f + \fr 21:42 \ft Salmo 118:22-23.\f*
\p 
\v 43 ’'Uɨg₅₄ jaun₂ juɨ́g₂ jniá₂ 'nia'₂, co₂dsia₅ jŋiá'₂ Diú₄ o₄gog'₂ 'nia'₂ 'éi'₃ quió'₅, o₄gú₃ i₂sián'₂ bá₄ dsia₃ con'₂ i₂léi₄ jáng'₃ a₂ráu₃.
\v 44 La₁ juɨ₁lia'₂ nɨ₁cang₁ la₂ në́₃, juɨ₁'ein₂ guë́₃ i₂ca₂tán'₂ ne₄, lé₂ le₁juɨg₁ le₁dsog'₅₄ quió'₅; o₃ në₁jua'₂ ca₂jlɨ́in₃, lé₂ ti₁'liog₂ quió'₅.\f + \fr 21:44 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ rë₂ton₅ versículo 44.\f*
\p 
\v 45 Jme₁ca₂nág₂ juɨg₅₄ jme₂dsa₂ quian'₅₄ dsa₂ fariseos jág₁ a₂jáng'₅ léi₄ në₅, ca₂rë₃lí'₄ bá₄ guioin₅₄ a₂'ɨn₅ 'éi₂ bá₄ Jesús.
\v 46 Jaun₂ jme₁'nio₃ jme₁tsáun'₂, la₁ ca₂rë₃gain₃ bá₄ dsa₂ juɨn₅ i₂quian'₅₄ Jesús, ia₁ ca₂le₃jɨ́n₃ bá₄ dsa₂ jmo₂₃ dsɨ́₅ a₂lɨ́n₅ 'éi₂ jan₂ i₂'ë́₂ jág₁ quián₅ Diú₄ bá₄.
\c 22
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ ja₁niog₅ jmɨg₄ a₂ca₂jen'₂ gu₂ dsa₂
\r (Lucas 14:15-24)
\p 
\v 1 Ca₂jme₃lióg₃ táng₃ Jesús ca₂tsɨ́'₃ dsa₂ të₂le₃ quian'₅₄ jág₁ a₂jáng'₅ léi₄, le₂la₂:
\p 
\v 2 ―Lë́₅ guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄ juɨ₁lia'₂ jan₂ rag₅₄ i₂ca₂jmo₃ co₂jŋia₅₄ caun₂ má₃ a₂ca₂jmo₃ jmɨg₄ ja₁jen'₂ gu₂ chi'₂ ja₁ŋi'₅₄.
\v 3 Jaun₂ ca₂chein₃ dsa₂ i₂jme₂ti₃ ta₁ ne₅₄ a₂dsɨ₃quiáin₂ dsa₂ i₂ma₂lë́₅ jág₁ ja₃lén₂ ja₃guë́'₃. La₁ dsa₂ 'éi₂ në́₃ tsá₃ ma₃ca₂gue₃ ja₃léin₂.
\v 4 Jaun₂ ca₂chein₃ táng₃ i₂sián'₂, jaun₂ ca₂tsɨ́'₃ 'éi₂: “Chei'₅₄ 'nia'₂ dsa₂ i₂ma₂lë́₅ jág₁ ja₃lén₂ jmɨg₄, ma₂lë́₅ bá₄ co₂jŋia₅₄ má₃. Ca₂jme₁dsiang₂₃ bá₄ ca₁juɨ₅ 'on'₅₄ quiáng₃; ma₂lë₅ bá₄ co₂jŋia₅₄ ca₂le₃jë́₃. Jaun₂ juɨ₁ja₂léin₂ bá₄ jmɨg₄ quió'₅ chi'₂ quiáng₃.”
\v 5 La₁ tsá₃ juɨ₅ ca₂tón'₃ dsa₂ i₂jme₁ma₂lë́₅ jág₁ rë₂té₄ 'éi₂. Juɨ₅ siá'₂ bá₄ i₃léin₂: jan₂ ŋó₃ juɨ₅ ja₁nau₂ quió'₅ bá₄; jan₂ guë'₂ ŋó₃ i₃dsiá₃ 'ma'₅₄.
\v 6 Rɨn'₅₄ dsa₂ 'éi₂ në́₃, ca₂jŋai'₃ bá₄ dsa₂ i₂jme₂ti₃ ta₁ ne₄ rag₅₄ 'éi₂, ca₂cuë₃, ca₂jme₃dsiog₂₃ bá₄.
\v 7 Jaun₂ në́₃, ca₂rë₃'né₃ rag₅₄ 'ŋio₅ lɨn₃, jaun₂ ca₂chein₃ 'lióg₂ quiáin₅ ca₂i₁jme₁dsiain₂₃ dsa₂ 'éi₂ qui₂ca₂i₁dsɨ́'₄ 'lióg₂ 'né₅, co₂dsia₅ ca₂'éin₂ go₄ dsa₂ 'éi₂.
\v 8 Jaun₂ ca₂juá'₂ rag₅₄ ca₂tsɨ́'₃ dsa₂ i₂jme₂ti₃ ne₅₄: “Ca₂le₃jë́₃ ma₂lë́₅ co₂jŋia₅₄ a₂jen'₂ gu₂ chi'₂ quiáng₃ a₂nio₃ jmɨg₄, la₁ dsa₂ i₂jme₁lë́₄ jág₁ rë₂té₄ 'éi₂, tsá₃ ma₃ca₂tɨ́in₂ ja₃léin₂.
\v 9 O₂nó'₅ 'nia'₂ në́₃, o₂nau₂ jë₄ calle juë'₂ ja₁i₂nio₄ guë́₄ dsa₂ juɨn₅, o₂chei'₅₄ ca₂le₃jɨ́n₃ dsa₂ i₂jeng'₂ juɨ₁ja₂léin₂ jmɨg₄ jë₁jen'₂ gu₂ chi'₂ quiáng₃.”
\v 10 Jaun₂ ca₂'uɨn₂ bá₄ dsa₂ 'éi₂ në́₃ ca₂i₁lein₅₄ jë₄ calle, jaun₂ chi₂ca₂liain'₃ ca₂le₃jɨ́n₃ dsa₂ i₂ca₂jein'₂ lia'₂ dsa₂ dsen₃ lia'₂ dsa₂ 'lɨn'₅₄ në́₃; jaun₂ ca₂can'₂ bá₄ dsi₂néi₂ ca₂lë₃, quian'₅₄ dsa₂ 'éi₂.
\p 
\v 11 ’Jaun₂ guë́₄ ca₂'í₃ rag₅₄ dsi₂néi₂ ca₂i₁jɨin₁₂ dsa₂ i₂tion'₅₄ 'éi₂, jaun₂ ca₂jɨ́in₂ jan₂ i₂'en₅₄ jë₄ jaun₂, tsá₃ jme₁rë₂lɨin₅₄ jua'₅₄ a₂qui'₂ 'mɨ'₂ a₂quɨ́'₅ dsa₂ dsɨ₂léin₂ ja₁niog₅ jmɨg₄ jen'₂ gu₂ dsa₂.
\v 12 Jaun₂ ca₂tsɨ́'₃ dsa₂ 'éi₂, ca₂juá'₂: “A₂mei₅₄, ¿'a₂ bá₄ lia'₂ në₂'ú'₃ 'ne₂ ja₁lá₃ të₃ tsá₃ rë₂lɨng'₅₄ con'₂ dsi₂ten₅₄ a₂gog'₅₄ ja₁niog₅ jmɨg₄ jen'₂ gu₂ dsa₂?” Jaun₂ tei₄ bá₄ ca₂nau₂ dsa₂ 'éi₂, tsá₃ 'e₂ ŋi₅ ŋag₃.
\v 13 Jaun₂ bá₄ ca₂juá'₂ rag₅₄ ca₂tsɨ́'₃ dsa₂ i₂tion'₅₄ jme₂ti₃ ne₄ mesa: “Quéin₂ 'nia'₂ gu₂-tag₄ i₂në₅, dsein₅₄ ca₁'né₄, qui₂dsɨin₅ 'nia'₂ güɨg₂, 'liain'₅₄ jë₄ qui₁né'₃ ja₁quɨ'₂-'o₃, qui₃quɨ́g'₃ jan₅₄.”
\v 14 Ia₁ juɨn₅ lɨn₃ dsa₂ i₂rë₂té₄, la₁ me'₂ bá₄ i₂rë₂quion'₅₄.
\s1 Jág₁ juɨ₁lia'₂ 'lia'₅₄ a₂ca₂tɨ́n₂ dsɨ₂tan₅₄
\r (Marcos 12:13-17; Lucas 20:20-26)
\p 
\v 15 Jme₁co₂lág₂ jaun₂ ca₂i₃len₃ dsa₂ fariseos ca₂i₁jmo₅₄ jág₁ 'a₂ lia'₂ join₅₄ Jesús juɨ₁lia'₂ bá₄ 'ŋiái₃ ca₂jon₄ jág₁ 'lia'₂, ia₁jaun₂ cuɨn₃ jmɨg₄ a₂bóg'₂ dso₄.
\v 16 Jaun₂ ca₂chein₃ táng₃ i₂lɨn₅₄ dsa₂ quiáin₅ quian'₅₄ i₂lɨn₅₄ dsa₂ i₂quian'₅₄ Herodes, a₂ca₂i₁chi'₄ Jesús:
\p ―Të₅, ne₄ bá₄ jnia'₅₄, a₂dsón'₂ bá₄ juá'₂ 'ne₂ lia'₂ tí₅ jág₁, qui₂jme₂tɨ́ng'₁ dsa₂ juɨ₅ dse₃ quió'₅ Diú₄, jaun₂ tsá₃ can'₂ 'ne₂ jág₁ jua'₅₄ a₂quian'₅₄ o₂i₁ dsɨ₅ 'e₂ a₂'ag₅ dsa₂, ia₁ tsá₃ gang'₃ jmag'₅₄ juɨ₁lia'₂ dsa₂ dsen₅₄ në́₃.
\v 17 Jaun₂ 'niog₂ jnia'₅₄ jua'₅₄ 'ne₂ 'a₂ lia'₂ dsɨ₂jiog₅ 'au'₂: ¿Dsióg₅ guë'₂ jua'₅₄ a₂caun₂ qui₅₄ 'lia'₅₄ a₂ca₂tɨ́n₂ dsɨ₂tan₅₄ César? ¿'Nió'₅ qui₅₄, o₃ tsá₃ qui₅₄ 'e₂?
\p 
\v 18 La₁ ca₂rë₃lí'₄ bá₄ Jesús a₂dsɨ₂jiog₅ dsɨ́₅ dsa₂ 'éi₂ 'lɨg'₅₄, jaun₂ ca₂juá'₂:
\p ―¡'Nia'₂ dsa₂ i₂lë₁co₂jmo₅ o₁ne₁! ¿'E₂ lë₃ 'niog'₂ 'nia'₂ jo'₅₄ jniá₂ juɨ₁lia'₂ tsán'₂ dsa₂ jan₂ já'₂ quian'₅₄ liá₂?
\v 19 'Ë₄ de'₂ 'nia'₂ caun₂ cu₄ 'ua'₂ juɨ₁lia'₂ a₂quí₅ dsa₂ 'lia'₅₄ a₂ca₂tɨ́n₂ dsɨ₂tan₅₄.
\p Jaun₂ ca₂o₃can₅ dsa₂ caun₂ cu₄ denario.
\v 20 Jme₁ma₂në₂jág₃ Jesús, jaun₂ ca₂ŋɨ́i'₃ dsa₂ 'éi₂:
\p ―¿'Ein₂ dsɨ₂ne₄ chi₁ton₅ ja₁lá₃? ¿'Ein₂ guë'₂ quió'₅ letra në́₃?
\p 
\v 21 Jaun₂ ca₂ŋag₃:
\p ―Quió'₅ gui'₅₄ emperador César.
\p Jaun₂ ca₂juá'₂ táng₃ Jesús:
\p ―Jang'₅₄ guë'₂ 'nia'₂ jaun₂ ne₄ César con'₂ a₂ca₂tɨ́n₂ César; ne₄ Diú₄ në́₃ jang'₅₄ 'nia'₂ con'₂ a₂ca₂tɨ́n₂ Diú₄.
\p 
\v 22 Dsa₂ 'éi₂ në́₃, jme₁ca₂nág₂ jág₁ në₅, ca₂i₃gó'₃ dsɨ́₅. Ca₂téin₂ bá₄ ca₂juë'₂ Jesús, ca₂i₃lein₃ bá₄.
\s1 Ca₂ŋag₃ dsa₂ saduceos juɨ₁lia'₂ a₂jen'₅₄ 'lag₄
\r (Marcos 12:18-27; Lucas 20:27-40)
\p 
\v 23 Jmɨg₄ jaun₂ ca₂o₃lén₂ i₂lɨn₅₄ dsa₂ saduceos ca₂o₃jɨin₅₄ Jesús. Ia₁ tsá₃ 'én₂ dsa₂ 'éi₂ a₂jen'₅₄ táng₃ dsa₂ jë₁ma₂dsain₃. Jaun₂ jág₁ në₅ ca₂ŋɨ́i'₃ Jesús ca₂juá'₂:
\p 
\v 24 ―Të₅, le₂la₂ ca₂juá'₂ Moisés: në₁jua'₂ ca₂jon₃ jan₂ dsa₂ ŋe'₂ të₃ tsá₃ ca₂can₃ 'io₅₄ quiáin₅ guein₂, tion₅₄ 'nió'₅ jén'₂ gu₂ dsó₂ rɨn'₅₄ dsa₂ ŋe'₂ i₂ca₂jon₃ quian'₅₄ 'io₅₄ 'nág₂ 'éi₂, ia₁jaun₂ guein₂ i₂le₃chan₂ quiáin₅, lé₂ co₂'nió'₄ tsɨ₁jon₂ 'lag₄ rɨin'₅₄.
\v 25 Dse₃ jaun₂. Jë₄ quián₂ jnia'₅₄ la₂, jme₁chan₂ guion₃ dsa₂ ŋe'₂ i₂lɨ́n₅ rɨn'₅₄. Ca₂jen'₂ gu₂ i₂le₂'uɨg₅₄, la₁ ca₂join₃ bá₄, të₃ tsá₃ guein₂ ca₂can₃ 'io₅₄ quiáin₅. Jaun₂ ca₂të₁'ŋiá₄ bá₄ 'io₅₄ 'nág₂ 'éi₂ o₄gú₃ dsó₂ rɨin'₅₄ i₂jë₁ca₂të́₂ on₃.
\v 26 La₁ ján₃ bá₄ le₂jaun₂ ca₂i₃ŋɨ́i₂, ca₂join₃ bá₄ ján₃. Jaun₂ ca₂guá₂ táng₃ 'io₅₄ 'éi₂ quian'₅₄ i₂jë₁ca₂të́₂ ún₂ dsó₂; ján₃ bá₄ le₂jaun₂ ca₂lë₃ quian'₅₄ 'éi₂. Jaun₂ le₂në₅ bá₄ ca₂lë₃ quian'₅₄ ta₁guion₃ dsó₂ 'éi₂ con'₂ i₂jme₁lë́₄ rɨn'₅₄, ca₂dsain₃ bá₄ të₃ tsá₃ guein₂ ca₂can₃ 'io₅₄.
\v 27 Jaun₂ ca₂jon₃ bá₄ 'io₅₄ jme₁ca₂jon₃ në́₃.
\p 
\v 28 Jaun₂ në́₃, jmɨg₄ jë₁ma₂të́₂ rë₁jen'₅₄ 'lag₄, ¿'ein₂ bá₄ quián₅ lé₂ 'io₅₄ 'éi₂? Ia₁ ta₁guion₃ bá₄ guë'₂ dsa₂ ŋe'₂ ca₂guá₂ quiain'₅₄.
\p 
\v 29 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Tsá₃ le₂jaun₂ lia'₂ ŋɨ́'₂ 'au'₂ 'nia'₂, ia₁ tsá₃ cuɨn'₂ 'nia'₂ 'a₂ lia'₂ juá'₂ Si₂, on₃ guë'₂ cuɨn'₂ 'nia'₂ 'a₂ lia'₂ lë́₅ juɨ₅bí₂ quió'₅ Diú₄ në́₃.
\v 30 Jë₁ma₂të́₂ jmɨg₄ a₂jen'₅₄ 'lag₄, on₃jua'₅₄ a₂le₃chain₂ jua'₅₄ a₂qui₃jéin'₂ guë́₄ gu₂, on₃ guë'₂ në₅ tóin'₃ guë́₄ jua'₅₄ a₂qui₃cuɨin₃ chi'₂ quiáin₅ a₂jéin'₂ gu₂, ia₁ i₂lén₂ juɨ₁lia'₂ lɨ́n₅ ángeles i₂tion'₅₄ guei'₅₄ i₂juɨ́g₃ bá₄ 'éi₂ jmɨg₄ jaun₂.
\v 31 La₁ juɨ₁lia'₂ a₂jen'₅₄ táng₃ 'lag₄, ¿tsa₁ ma₂'í'₂ 'nia'₂ ne₄ Si₂ juɨ₁lia'₂ a₂ca₂juá'₂ 'ŋiog₅ Diú₄ jme₁ca₂juá'₂:
\v 32 “Jniá₂ bá₄ lɨ́ng₅ Diú₄ quián₅ Abraham, quián₅ Isaac, quián₅ Jacob në́₃?”\f + \fr 22:32 \ft Éxodo 3:6.\f* A₂lɨ́in₅ Diú₄ quián₅ dsa₂ jén'₃ bá₄, on₃jua'₅₄ rë'₂ Diú₄ quián₅ 'lag₄.
\p 
\v 33 Jme₁ca₂nág₂ dsa₂ jág₁ në₅, ca₂i₃gó'₃ dsɨ́₅ 'a₂ lia'₂ jme₂tag₅ Jesús.
\s1 'Éi'₃ Juá'₅ a₂dsen₅₄ guë́₄ quió'₅ Diú₄
\r (Marcos 12:28-34; Lucas 10:25-28)
\p 
\v 34 Jme₁ca₂rë₃ŋi₅ dsa₂ fariseos ca₂lɨ́'₃ bá₄ táng₃ Jesús jág₁ a₂ca₂tsɨ́in₂ quian'₅₄ dsa₂ saduceos, jaun₂ ca₂ŋɨi'₂ ca₂jmo₃ jág₁.
\v 35 Jaun₂ jan₂ rɨin'₅₄ i₂lɨ́n₅ të₅juá'₅, jme₁'nio₃ jme₁jo₅₄ quian'₅₄ jág₁, jaun₂ ca₂ŋɨ́i'₃ Jesús:
\p 
\v 36 ―Të₅, ¿'e₂ 'Éi'₃ Juá'₅ a₂dsen₅₄ guë́₄ con'₂ guë́₄ ca₂le₃jë́₃ Si₂ 'Éi'₃ quió'₅ Diú₄?
\p 
\v 37 Jaun₂ ca₂ŋag₃ Jesús:
\p ―“Jme₁'nió₄ Te₁gui'₅₄ Diú₄ quiáng'₂, ca₂le₃jë́₃ 'au'₂, ca₂le₃jë́₃ jme₂dsí₂ quiáng'₂, ca₂le₃jë́₃ 'a₂ lia'₂ niog₅ ŋɨ́'₂ dsei'₂.”\f + \fr 22:37 \ft Deuteronomio 6:5.\f*
\v 38 A₂në₅ bá₄ 'Éi'₃ Juá'₅ a₂le₂'uɨg₅₄ a₂dsen₅₄ guë́₄ con'₂ guë́₄ ca₂le₃jë́₃.
\v 39 Jë₁ca₂të́₂ tɨn₃ 'Éi'₃ në́₃, mei'₂ tsá₃ co₂rë₂ quian'₅₄ a₂le₂'uɨg₅₄: “Jme₁'nió₄ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂ juɨ₁lia'₂ 'nióg'₃ 'ŋiag'₂.”\f + \fr 22:39 \ft Levítico 19:18.\f*
\v 40 Tɨn₃ 'éi'₃ në₅ bá₄ lë́₅ 'uɨg₅₄ cho'₅₄ ca₂le₃jë́₃ 'Éi'₃ quió'₅ Moisés quian'₅₄ ca₂le₃jë́₃ jág₁ a₂ca₂'ë́₂ dsa₂ i₂chen₄ quián₅ Diú₄ ma₂lɨ́g'₂.
\s1 ¿'Ein₂ tsɨ₁jon₂ quián₅ lɨ́n₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄?
\r (Marcos 12:35-37; Lucas 20:41-44)
\p 
\v 41 Të₃ tion'₅₄ dsa₂ fariseos le₁ŋɨi'₂,
\v 42 jaun₂ ca₂ŋag₃ Jesús ca₂juá'₂:
\p ―¿'A₂ lia'₂ lɨ́n'₂ 'nia'₂? ¿'Ein₂ tsɨ₁jon₂ quián₅ lɨ́n₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄?
\p ―Tsɨ₁jon₂ David ―ca₂ŋag₃ dsa₂ 'éi₂.
\p 
\v 43 Jaun₂ ca₂juá'₂ táng₃ Jesús:
\p ―¿'A₂ lia'₂ jaun₂? Ia₁ 'ŋiog₅ bá₄ guë'₂ David ca₂juá'₂ lia'₂ con'₂ jme₁ca₂'í₃ Jme₂dsí₂ Jŋió₅ të₂dsɨ́₅, ca₂të₃ “Te₁gui'₅₄.” ¿'A₂ lia'₂ lë́₅ jaun₂? Ia₁ 'ŋiog₅ bá₄ guë'₂ David ca₂juá'₂:
\q1 
\v 44 Ca₂juá'₂ Diú₄ ca₂tsɨ́'₃ Te₁gui'₅₄ quiáng₃:
\q1 “Né₂ con₂ jniá₂ të₂le₃ gu₃ ne₁,
\q2 ca₂lia'₂ ca₂të́₂ jmɨg₄
\q2 a₂tón'₁ jniá₂ dsa₂ i₂'iog₅₄ o₄tag'₄.”\f + \fr 22:44 \ft Salmo 110:1.\f*
\m 
\v 45 ¿'A₂ bá₄ lia'₂ lë́₅ a₂lɨ́in₅ tsɨ₁jon₂ David, ton'₂ 'ŋiog₅ bá₄ guë'₂ David ca₂të₃ “Te₁gui'₅₄ quiáng₃?”
\p 
\v 46 Jaun₂ të₂le₃ ne₄ juɨ₅ guë́₄ jaun₂, tsá₃ ma₃'ein₂ ca₂tiá₂ dsɨ́₅ jua'₅₄ a₂ŋag₃ guë́₄ 'e₂ ŋag₃.
\c 23
\s1 Chóg'₅ Jesús dso₄ juá'₂ 'a₂ lia'₂ niog₅ lɨ́n₅ dsa₂ fariseos quian'₅₄ të₅juá'₅ në́₃
\r (Marcos 12:38-40; Lucas 11:37-54; 20:45-47)
\p 
\v 1 Jaun₂ në́₃ ca₂ton₃ Jesús jág₁ ca₂tsɨ́'₃ dsa₂ juɨn₅ i₂quiain'₅₄, ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ në́₃, ca₂juá'₂:
\p 
\v 2 ―Dsa₂ fariseos quian'₅₄ të₅juá'₅ në́₃, tiáin'₅ ta₁ a₂jme₁lɨ́n₄ Moisés.
\v 3 Jaun₂ lë₃ ca₂tɨ́n'₂ 'nia'₂ nág'₁ gau₂ jág₁ quió'₅, jme₁ti'₄ 'nia'₂ 'e₂ a₂te₂néi'₂. La₁ tsá₃ can₂ 'nia'₂ juɨ₅ jua'₅₄ a₂jmó'₂ juɨ₁lia'₂ a₂jmo₂₃ guioin₅₄, ia₁ juɨ₁lia'₂ jme₂tag₂₃, tsá₃ jme₂ti₃ guioin₅₄; të₂le₃ siá'₂ bá₄ jmo₂₃ dsó₅.
\v 4 Qui₂'nei₂₃ lio₅₄ guei₂ 'ŋio₅ lɨn₃ qui₂dsɨ₂₃ mɨ₂ca'₄ dsa₂, la₁ guioin₅₄ në́₃ ca₂lia'₂ jŋia'₅₄ caun₂ chi₁gú₃ bá₄ tsá₃ 'nio₃ tí₂ jua'₅₄ a₂jme₃'o₅₄ cán₂.
\v 5 Ca₂le₃jë́₃ 'e₂ a₂jmo₂₃, jmo₂₃ a₂jŋia'₅₄ con'₂ 'nio₃ jág₂ dsa₂ bá₄. Ia₁ tɨn₂ dsɨ́₅ i₃quian₅₄ le₁ton₅ jma₃ca₂tsɨ́n'₅ tsɨ₁'mɨ'₂ 'ɨ́₂ le₂con₂ chi₁quí₃ quian'₅₄ mɨ₂cu₅ në́₃ qui₂le₁ton₅ 'éi'₃ quió'₅ Diú₄;\f + \fr 23:5 \ft 'Nio'₂ ja₁ton₅ Deuteronomio 6:4-9.\f* a₂ta₁ dsɨ́₅ i₂nioi₅₄ le₁qui'₂ tsɨ₁'mɨ'₂ chen'₅₄ jang₄ qui₂le₁'ág₄ a₂lë́₅ lí₁ ca'₅₄ a₃tag₄.
\v 6 'Ŋio₅ të₅ dsɨ́₅ qui₂dsɨ₂toin'₅₄ jmá'₃ lia'₂ ja₁jlá'₁ bá₄ ja₁qui₂dsɨ₂guë́'₃, qui₂dsɨ₂tiain'₂ ja₁dsen₅₄ guë́₄ juɨ₁lia'₂ dsi₂néi₂ guá'₅ sinagoga në́₃.
\v 7 Ton'₂ 'ŋio₅ të₅ dsɨ́₅ qui₃cuag₃ dsa₂ Diú₄ jë₄ 'ma'₅₄, qui₃të́₂ dsa₂ “të₅”\f + \fr 23:7 \ft o₃, Rabbí.\f* në́₃.
\p 
\v 8 ’La₁ 'nia'₂ në́₃, tsá₃ ca₂tɨ́ng'₂ jua'₅₄ të́₂ dsa₂ “të₅”, ia₁ ca₂le₃jɨ́n'₃ bá₄ 'nia'₂ lë́₅ rɨ́ng'₂; ia₁ jan₂ bá₄ Të₅ quián'₂ 'nia'₂ chan₂.
\v 9 Tsá₃ të'₅₄ 'nia'₂ “tia₅₄” 'i₁jan₂ dsa₂ mɨ₂güɨ́g₃, ia₁ jan₂ bá₄ Ŋéi'₅ 'nia'₂ i₂chan₂, i₂guá₅ guei'₅₄ i₂juɨ́g₃.
\v 10 Tsá₃ cuë́'₁ 'nia'₂ jmɨg₄ a₂të́₂ dsa₂ 'nia'₂ guiong'₅₄ a₂lɨ́ng'₅ juɨg₅₄ dsa₂, ia₁ jan₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄ bá₄ i₂lɨ́n₅ juɨg'₂ 'nia'₂.
\v 11 Juɨ₁lia'₂ i₂jme₃ti₃ ta₁ ne₄ rɨn'₅₄, i₂'éi₂ bá₄ i₂juɨn'₂ guë́₄.
\v 12 Ia₁ juɨ₁lia'₂ i₂jme₂can'₅₄ guion₅₄ jɨn₄ rɨn'₅₄, të₂le₃ sióin₂, lé₂ mei'₂; la₁ juɨ₁lia'₂ i₂jmo₅ me'₂ jɨn₄ rɨn'₅₄, i₂'éi₂ bá₄ lén₂ i₂juɨn'₂ guë́₄ con'₂ guë́₄ ca₂le₃jɨ́n₃.
\p 
\v 13 ’¡'E₂ guë́₄ juɨ́g'₂ 'nia'₂ të₅juá'₅, 'nia'₂ dsa₂ fariseos në́₃, i₂lë₁jmo₅-dsáu₅ o₁ne₁! Ia₁ jnág'₂ 'nia'₂ o₄'né₄ guei'₅₄ i₂juɨ́g₃ ja₁gon₂ Diú₄, tsá₃ cuë'₂ 'nia'₂ jmɨg₄ tón'₃ i₂sián'₂. Ia₁ on₃ guë'₂ tón'₂ 'nia'₂ guiong'₅₄, on₃ guë'₂ cuë'₂ 'nia'₂ juɨ₅ tón'₃ juɨ₁lia'₂ i₂'nio₃ tón'₃.\f + \fr 23:13 \ft A₂lɨn₅₄ chog₅₄ si₂ chi₁ton₅ versículo 14 ján₃, a₂juá'₂ le₂la₂: “¡'E₂ guë́₄ juɨ́g'₂ 'nia'₂ të₅juá'₅, 'nia'₂ dsa₂ fariseos në́₃, i₂lë₁jmo₅-dsáu₅ o₁ne₁! Ia₁ ja₂nó'₅ 'nia'₂ qui₂jŋiá'₂ 'ne₄ 'io₅₄ 'nág₂, jaun₂ jmo'₂ 'nia'₂ chi₂leng'₅₄ Diú₄ uë́₂ lɨn₃, ia₁jaun₂ tsá₃ 'ein₂ le₃lí'₄. 'Uɨg₅₄ jaun₂ ja₂lɨn₃ guë́₄ 'ŋio₅ uɨg₅ guéi'₁ 'nia'₂.\f*
\p 
\v 15 ’¡'E₂ guë́₄ juɨ́g'₂ 'nia'₂ të₅juá'₅, 'nia'₂ dsa₂ fariseos në́₃, i₂lë₁jmo₅-dsáu₅ o₁ne₁! Ia₁ qui₂i₂nio'₄ 'nia'₂ ca₂le₂con₂ mɨ₂güɨ́g₃ qui₁'ang'₄ jmɨ₁ŋí'₄, a₂qui₂jme₂tɨ́ng'₁ dsa₂ lia'₂ lë́₅ 'én'₂ 'nia'₂ guiong'₅₄. Jë₁ma₂ca₂jon'₃ 'nia'₂ dsa₂ a₂dsɨ₃léin₂ juɨ₅ quiáng'₂, qui₂jme₂tɨ́in'₁ 'nia'₂ a₂jŋia'₅₄ con'₂ a₂jme₃'lɨin'₅₄ guë́₄ lia'₂ con'₂ guë́₄ guion'₅₄ 'nia'₂.
\p 
\v 16 ’¡'E₂ guë́₄ juɨ́g'₂ 'nia'₂, dsa₂ ten₄ i₂quian₅ ne₄ juɨ₅! Ia₁ juá'₂ 'nia'₂ jme₂tɨ́ng'₁ dsa₂: “Në₁jua'₂ 'ein₂ ca₂cuë₃ jág₁ quió'₅ 'ë₂₃ guá'₅, tsá₃ 'e₂ quen₅ jág₁ jaun₂; la₁ në₁jua'₂ ca₂'ë₃ cu₄nióg₄ a₂te₁'i₁ guá'₅, a₂jaun₂ guë́₄ dsón'₂ quen₅ jág₁ quió'₅”, tion₅₄ 'nió'₅ jme₃ti₃ jág₁ a₂në₂cuë₃.
\v 17 ¡'Nia'₂ dsa₂ ten₄, dsa₂ co₄! ¿'E₂ a₂quen₅ guë́₄ 'ŋio₅ lɨn₃? ¿Cu₄nióg₄, o₃ guá'₅ ja₁rë₂jŋió₃ cu₄nióg₄ jaun₂ 'e₂?
\v 18 Juá'₂ 'nia'₂ ján₃: “Në₁jua'₂ 'ein₂ cuë₅ jág₁ quió'₅ a₂'ë₂₃ ne₄chei₂, ján₃ bá₄ tsá₃ 'e₂ quen₅ jág₁ jaun₂; la₁ në₁jua'₂ ca₂'ɨin₃ já'₂ i₂rë₂jen'₅₄ ne₄ ne₄chei₂, jaun₂ guë́₄ dsón'₂ tion₅₄ 'nió'₅ jme₃ti₃ jág₁ quió'₅.”
\v 19 ¡'Nia'₂ dsa₂ ten₄! ¿'E₂ jaun₂ a₂lë́₅ a₂dsen₅₄ guë́₄? ¿Já'₂ i₂rë₂jen'₅₄ ne₄ Diú₄, o₃ ne₄chei₂ a₂rë₂jŋió₃ já'₂ 'éi₂ 'e₂?
\v 20 Jaun₂ lë₃, juɨ₁lia'₂ jme₁cuë₅ dsa₂ jág₁ quió'₅ a₂'ë₂₃ ne₄chei₂, on₃jua'₅₄ jmá'₃ ne₄chei₂ 'ë₂₃; a₂'ë₂₃ ca₂le₃jë́₃ 'e₂ a₂te₁'i₁ ne₄chei₂ bá₄ jaun₂.
\v 21 Le₂në₅ bá₄ ján₃, juɨ₁lia'₂ i₂'ë₅ guá'₅, on₃jua'₅₄ jmá'₃ ca₂ne₅₄ guá'₅ 'ë₂₃, a₂'ɨin₂₃ le₂jiog₅ Diú₄ i₂guá₅ dsi₂néi₂ jaun₂ bá₄.
\v 22 Ján₃ bá₄ le₂në₅ juɨ₁lia'₂ i₂'ë₅ guei'₅₄ i₂juɨ́g₃, a₂ma₂në₂'ë₃ le₂jiog₅ ne₄ta₁ quió'₅ Diú₄, ton'₂ a₂ma₂në₂'ɨin₃ le₂jiog₅ 'ŋiog₅ Diú₄ i₂guá₅ ne₄ta₁ jaun₂ bá₄ ján₃.
\p 
\v 23 ’¡'E₂ guë́₄ juɨ́g'₂ 'nia'₂ të₅juá'₅, 'nia'₂ dsa₂ fariseos në́₃, i₂lë₁jmo₅-dsáu₅ o₁ne₁! Ia₁ qui₂jáng'₂ 'nia'₂ caun₂ qui'₅₄ a₂guia₃ quió'₅ mɨ₁'au₂ mɨ₂juɨg₂, juɨ₁lia'₂ menta, anís, quian'₅₄ qui₂má₃ në́₃. La₁ tsá₃ tón'₂ guë'₂ 'nia'₂ juɨ₅ 'Éi'₃ Juá'₅ a₂dsen₅₄ guë́₄ quió'₅ Diú₄ ron₅, juɨ₁lia'₂ ja₁juá'₂ a₂'nió'₅ jmo₃ dsa₂ a₂dse₃, a₂dsia₃ dsa₂ ŋéi₂ dsɨ́₅ dsa₂ mɨ₂güɨ́g₃ rɨin'₅₄, a₂jmo₃ dsa₂ tí₅ jág₁ quió'₅ quian'₅₄ rɨin'₅₄. A₂në₅ bá₄ a₂dsen₅₄ guë́₄ a₂ca₂tɨ́n'₂ 'nia'₂ jmó'₂, la₁ on₃jua'₅₄ a₂tsá₃ ma₃jme₁ti'₄ 'nia'₂ 'Éi'₃.
\v 24 ¡'Nia'₂ dsa₂ ten₄ i₂quian₅ ne₄ juɨ₅! Qui₁ŋɨ'₄ 'nia'₂ quió'₅ i₁lu₂ pí'₁, la₁ nɨ́'₅ bá₄ guë'₂ 'nia'₂ guiong'₅₄ juɨ₁lia'₂ já'₂ camello.
\p 
\v 25 ’¡'E₂ guë́₄ juɨ́g'₂ 'nia'₂ të₅juá'₅, 'nia'₂ dsa₂ fariseos në́₃, i₂lë₁jmo₅-dsáu₅ o₁ne₁! Ia₁ lɨ́n'₅ 'nia'₂ juɨ₁lia'₂ lë́₅ nɨ₁vaso, nɨ₁uɨng₅ në́₃, qui₁rɨn'₄ 'nia'₂ jmá'₃ lia'₂ le₃co'₅₄. La₁ të₂le₃ juɨ₅ të₂'au'₂ 'nia'₂, qui₂rë₂can'₂ ca₂le₃jë́₃ ne₅₄ a₂'lɨg'₅₄ a₂qui₂dsɨ₂jŋia₅ 'au'₂ 'nia'₂, 'niog'₂ 'nia'₂ jua'₅₄ jmá'₃ lia'₂ guiong'₅₄ bá₄ qui₂le₃cha₂ quiáng'₂; qui₂ja₂nó'₅ 'nia'₂ 'ang'₂ quió'₅ dsa₂.
\v 26 ¡'Nia'₂ dsa₂ fariseos ten₄! Rang₂ 'nia'₂ de'₂ jŋiá₅ le₃'ŋió'₂ nɨ₁vaso quian'₅₄ nɨ₁uɨng₅, jaun₂ guë́₄ lé₂ le₁jë́₃ le₂tan₅₄ le₃co'₅₄ në́₃.
\p 
\v 27 ’¡'E₂ guë́₄ juɨ́g'₂ 'nia'₂ të₅juá'₅, 'nia'₂ dsa₂ fariseos në́₃, i₂lë₁jmo₅-dsáu₅ o₁ne₁! Ia₁ lɨ́n'₅ 'nia'₂ juɨ₁lia'₂ lë́₅ tau₂ 'ŋio₅ a₂jŋia'₅₄ con'₂ jniá₂ tiog₂, jniá₂ jlá'₁ jmá'₃ lia'₂ le₃co'₅₄ bá₄, la₁ le₃'ŋió'₂ qui₂rë₂can'₂ nɨ₁mu₅, chí'₅ ma₂'lɨg'₅₄.
\v 28 Le₂në₅ bá₄ lɨ́n'₅ 'nia'₂; 'e₂ guë́₄ dsen'₃ 'nia'₂ jniág'₂ jmá'₃ lia'₂ le₃co'₅₄ të₃jë₄ jág₅ dsa₂, la₁ të₂'au'₂ guë'₂ 'nia'₂ qui₂rë₂can'₂ ca₂le₃jë́₃ ne₅₄ a₂'lɨg'₅₄, a₂jmo'₂ dsáu'₂ 'nia'₂ o₁ne₁ 'e₂ a₂jmo'₂.
\p 
\v 29 ’¡'E₂ guë́₄ juɨ́g'₂ 'nia'₂ të₅juá'₅, 'nia'₂ dsa₂ fariseos në́₃, i₂lë₁jmo₅-dsáu₅ o₁ne₁! Ia₁ qui₂jmóg'₂ 'nia'₂ tau₂ 'ŋio₅ quió'₅ dsa₂ i₂ca₂'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂, qui₂jmóg'₂ 'nia'₂ jlá'₁ qui₂rë₂lag₄ juɨ₁lia'₂ ja₁le₁'on₅ dsa₂ dsen₃ i₂ma₂dsan₃.
\v 30 Jaun₂ jag'₅₄ 'nia'₂: “Jua'₅₄ mei'₂ bá₄ ca₂rë₃chóng₃ jniog₄ jmɨg₄ jaun₂ lia'₂ con'₂ jme₁chan₂ dsa₂ can'₅₄ quián₂ ma₂lɨ́g'₂, tsá₃ jme₁jme₁quiain'₅₄ jniog₄ lia'₂ con'₂ jme₁ca₂jmo₃ a₂ca₂i₃'o₅₄ jmɨ₂ 'an₅₄ dsa₂ i₂chen₄ 'éi₂ quián₅ Diú₄.”
\v 31 Jaun₂ le₂në₅, quian'₅₄ jág₁ quián'₂ 'nia'₂ guiong'₅₄, jáng'₂ 'nia'₂ jág₁ dsau₅ a₂lɨ́ng'₅ tsɨ₁jon₂ dsa₂ i₂ca₂jme₃dsian₅ dsa₂ i₂ma₂chen₃ Diú₄.
\v 32 Jaun₂ në́₃, jme₁'ŋia₅ 'nia'₂ dso₄ a₂ca₂jme₃lióg₃ dsa₂ can'₅₄ quián'₂ 'nia'₂.
\p 
\v 33 ’¡Já'₂ 'lɨn'₅₄! ¡Tsɨ₁jon₂ dsɨ₂mɨ'₂! ¿'A₂ bá₄ lia'₂ le₃lon'₅₄ 'nia'₂ 'éi'₃ uɨg₅ a₂já₅ ja₁con'₂ 'nia'₂ a₂dsi₁nog'₃ guio₃-juɨ́g₃?
\v 34 'Uɨg₅₄ jaun₂, tsɨn₅₄ jniá₂ ja₁con'₂ 'nia'₂ dsa₂ i₂'ë́₂ jág₁ o₄quió₃, dsa₂ i₂ŋɨ́'₂ niog₅ dsi₄, i₂lɨ́n₅ të₅ në́₃. I₂lɨn₅₄ 'éi₂ jme₁dsiain'₂ bá₄ 'nia'₂, i₂lɨn₅₄ guë'₂ qui₁tóin'₄ 'nia'₂ cróg₄. I₂sián'₂ guë'₂ në́₃ qui₁cuë'₅₄ 'nia'₂ dsi₂néi₂ guá'₅ sinagogas quiáng'₂, qui₂co₁'éin'₄ 'nia'₂ në́₃ le₂'í₁ juɨg₂.
\v 35 Jaun₂ lë₃, 'nia'₂ bá₄ le₁cáng'₄ jmɨ₄ ca₂le₃jɨ́n₃ dsa₂ dsen₃ i₂qui₂ma₂dsan₃ mɨ₂güɨ́g₃, ca₂të₂ jmɨ₄ Abel i₂jme₁lɨ́n₄ dsa₂ dsen₃, ca₂të₂ jmɨ₄ Zacarías ja₁ŋi'₅₄ Berequías, i₂ca₂jŋɨ́'₃ 'nia'₂ i₁dsi₅ guá'₅ jë₄ ja₁lë́₄ ja₁jŋió₅ quian'₅₄ ja₁chí'₄ ne₄chei₂.
\v 36 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, dsa₂ chan₂ jmɨg₄ në₃ bá₄ rë₂cán'₄ ca₂le₃jë́₃ dso₄ jaun₂.
\s1 'O₅ Jesús o₄quió'₄ juɨg₂ Jerusalén
\r (Lucas 13:34-35)
\p 
\v 37 ’¡'Nia'₂ dsa₂ juɨg₂ Jerusalén! ¡'Nia'₂ dsa₂ juɨg₂ Jerusalén, 'nia'₂ i₂jme₂dsiáng'₁ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄, 'nia'₂ i₂qui₂jnag'₅₄ cang₄ dsa₂ i₂chen₅ Diú₄ jɨn'₄ 'nia'₂! ¡'Lióng₂ ráun₂ jme₁'ɨ́n₅ dsɨ₃ jme₁chi₁liang'₂ guein₂ dsa₂ juɨg₂ quiáng'₂, juɨ₁lia'₂ jmo₅ i₁tsɨ́n'₃ a₂chi₂lain'₂ guein₂ quiáin₅ to'₂ né'₃ tsɨ₁rë₂cu₅, la₁ guion'₅₄ 'nia'₂ tsá₃ ca₂gue'₅₄!
\v 38 Jag₄ jaun₂, dsi₂néi₂ quiáng'₂ në́₃ të₃'ŋiá₄, të₃tsɨ'₅₄ tei₄, tsá₃ 'ein₂ chan₂ lé₂.
\v 39 Ia₁ juá'₅ jniá₂, tsá₃ ma₃la₂ jag'₅₄ 'nia'₂ jniá₂, ca₂lia'₂ ca₂të́₂ jmɨg₄ jë₁ma₂të́₂ rë₁jua'₅₄ 'nia'₂: “Juɨ₁le₂jŋió₃ bá₄ i₂në₅ i₂jón'₅ o₄quió'₄ Te₁gui'₅₄.”\f + \fr 23:39 \ft Salmo 118:26.\f*
\c 24
\s1 Ca₂'ë́₂ Jesús jág₁ a₂dsɨ₃'én₂ bá₄ guá'₅ templo
\r (Marcos 13:1-2; Lucas 21:5-6)
\p 
\v 1 Jaun₂ ca₂o₃'ɨ́n₃ Jesús i₁dsi₅ guá'₅ templo ja₁jme₁'ein₅₄. Jme₁ma₂'ein₅₄ juɨ₅ ŋái'₅, ca₂jme₃quián₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ të́₂, ca₂juá'₂:
\p ―Jag₄ 'a₂ lia'₂ lë́₅ guá'₅.
\p 
\v 2 La₁ jaun₂ ca₂ŋag₃ Jesús:
\p ―¿Jág'₂ 'nia'₂ ca₂le₃jë́₃ a₂në₅? A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, já₅ jmɨg₄ lia'₂ 'i₁ca₂mɨ́g₂ nɨ₁cang₁ tsá₃ ma₃'e₂ jua'₅₄ a₂le₁juɨ́₄ guë́₄ lé₂ quian'₅₄ rɨn'₅₄. Ca₂le₃jë́₃ bá₄ 'én₂.
\s1 Léi₄ a₂lé₂ jmɨg₄ jë₁ca₂tó'₂
\r (Marcos 13:3-23; Lucas 21:7-24; 17:22-24)
\p 
\v 3 Jme₁ca₂dsióg₃ Jesús Má'₂ Olivos; ja₁jaun₂ ca₂guá₂. Jaun₂ ca₂i₁len₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ con'₂ jë₄ jmá'₃ guioin₅₄, ca₂nɨ́i'₃ Jesús:
\p ―'Niog₂ jnia'₅₄ le₃ne₄ lɨ́g'₂ lé₂ a₂juá'₂ 'ne₂ në₅. ¿'E₂ léi₄ lé₂ jë₁ma₂të́₂ rë₁ŋeg'₅₄ táng₃? ¿'E₂ bá₄ léi₄ lé₂ jë₁ma₂të́₂ rë₁të₅₄ jmɨg₄ jaun₂?
\p 
\v 4 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Jmo₄ 'nia'₂ 'í₁ ia₁jaun₂ tsá₃ 'ein₂ jme₃gau₅.
\v 5 Ia₁ juɨn₅ i₂të₁i₃nio₄ a₂juá'₂ i₂nioi₅₄ o₄quió₃ jniá₂, juá'₂: “Jniá₂ bá₄ lɨ́ng₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄”; jaun₂ juɨn₅ dsa₂ i₂qui₂jme₃gain₂₃.
\v 6 Jë₁ma₂nei'₂ 'nia'₂ 'ei₅ jág₁ a₂nio₃ 'nei₂ a₂quɨ́n'₂ dsa₂ ja₁lá₃ ja₁ó₃, la₁ tsá₃ jmó'₂ 'nia'₂ gang'₃, ia₁ le₂jaun₂ dsón'₂ lé₂ bá₄. La₁ 'nió'₅ bá₄ guë́₄ a₂ŋɨ́₂ jein₂ jaun₂.
\v 7 Ia₁ nio₃ 'nei₂, qui₃quɨ́n'₂ dsa₂ le₂caun₂ le₂caun₂ juɨg₂ nación; dsɨ₂tan₅₄ guë'₂ në́₃ qui₃tóin'₃ mɨ'₅₄ quɨ́in'₂ quian'₅₄ dsɨ₂tan₅₄ rɨin'₅₄ i₂chan₂ juɨg₂ siá'₂. Jaun₂ guë́₄ në́₃ 'lióng₂ ja₁qui₂i₂nio₄ dsa₂ 'oin₅₄ lé₂, ton'₂ 'lióng₂ ja₁qui₂dsɨ₃bi₅₄ 'uë₃ në́₃.
\v 8 Ca₂le₃jë́₃ a₂në₅ lé₂ a₂le₂'uɨg₅₄ jmɨ₁uɨg₅ juɨ₁lia'₂ jan₂ 'io₅₄ i₂rë₂chan₂ guein₂ quián₅.
\p 
\v 9 ’Jaun₂ guë́₄ në́₃, qui₃jɨ́n'₂ dsa₂ 'nia'₂ ne₄ dsɨ₂tan₅₄ ia₁jaun₂ cuë₃ dsa₂ uɨg₅, jaun₂ guë́₄ jme₃dsian₅ dsa₂ 'nia'₂. Le₂con₂ mɨ₂güɨ́g₃ bá₄ jme₃'ŋia₅₄ dsa₂ 'nia'₂ 'uɨg₅₄ quió₃ jniá₂.
\v 10 Jmɨg₄ jaun₂, juɨn₅ dsa₂ i₂tí₂ juɨ₅ quió'₅ Diú₄ a₂jme₁'éin₂, qui₂jme₃'ŋiai₅₄ bá₄ rɨin'₅₄, qui₃jáng'₂ në́₃.
\v 11 Juɨn₅ dsa₂ le₃chan₂ i₂'ë́₂ jág₁ i₂juɨ₁gan₂, jaun₂ juɨn₅ dsa₂ i₂jme₃gain₂₃.
\v 12 'Uɨg₅₄ ia₁ a₂ŋɨ́₄ lë₃ juɨ₁si ŋag₅₄ le₃'lɨn'₅₄ dsa₂, co₂dsia₅ le₃güɨ́g'₂ bá₄ 'a₂ lia'₂ jme₁'nio₃ dsa₂ rɨin'₅₄ le₂jain₂ le₂jain₂.
\v 13 La₁ juɨ₁lia'₂ i₂náu₃ tiá₂ të₂ jë₁ca₂tó'₂, 'éi₂ bá₄ lión₂.
\v 14 Jág₁ dse₃ la₂ juɨ₁lia'₂ 'a₂ lia'₂ lë́₅ ja₁gon₂ Diú₄ qui₂dsɨ₃'ag₅ ta₁caun₂ mɨ₂güɨ́g₃, ia₁jaun₂ le₃ŋi₅ ca₂le₃jë́₃ juɨg₂ te₁'i₁ gua'₅₄ 'uë₃ jág₁ dse₃ jaun₂; jaun₂ guë́₄ në́₃ të₅₄ jmɨg₄ jë₁ca₂tó'₂.
\p 
\v 15 ’Jaun₂ në́₃, já₅ jmɨg₄ a₂të₅₄ ne'₅₄ 'nia'₂ a₂náu₃ jan₂ dsa₂ i₂'lɨn'₅₄ guë́₄ lɨn₃, a₂jme₃'ióg₃ ja₁jŋió₅, a₂le₃ti₃ jág₁ a₂ca₂'ë́₂ Daniel i₂jme₁'ë́₂ jág₁ quián₅ Diú₄,\f + \fr 24:15 \ft 'Í₂ Daniel 9:27; 11:31; 12:11.\f* (jaun₂ juɨ₁le₂ŋɨ́'₂ bá₄ i₂'ɨ₅ si₂ la₂),
\v 16 jaun₂ në́₃, dsa₂ i₂tián'₅ le₂tan₅₄ 'uë₃ Judea, juɨ₁cuɨng₁₂ juɨ₅ má'₂.
\v 17 Juɨ₁lia'₂ i₂'en₅₄ guei'₅₄ 'ne₄, tsá₃ ma₃juɨ₁sióin₄ jua'₅₄ a₂'uë́'₃ 'e₂ 'uë́'₃ dsi₂néi₂ quió'₅;
\v 18 juɨ₁lia'₂ i₂'en₅₄ ja₁nau₂ quió'₅ táng₃, tsá₃ ma₃juɨ₁jŋioi'₅₄ jua'₅₄ a₂ja₃quián₂ tsɨ₁'mɨ'₂ dsiog₂ quió'₅.
\v 19 ¡Juɨ́g₂ bá₄ juɨ₁lia'₂ dsa₂ mɨ́₂ i₂le₁quian₅ guein₂, juɨ₁lia'₂ i₂le₁jŋia₅ guein₂ i₂'ɨ́n'₂ dsi'₅₄ në́₃, jmɨg₄ jaun₂!
\v 20 Mɨ₄ 'nia'₂ ne₄ Diú₄ ia₁jaun₂ tsá₃ o₁le₅₄ jua'₅₄ a₂cuɨ́ng'₂ 'nia'₂ jein₂ güɨ́g₂, on₃ guë'₂ jmɨg₄ sa₅₄ në́₃.
\v 21 Ia₁ juá'₅ jniá₂, caun₂ o₂i₁ dsɨ₅ lɨn₃ a₂le₃chan₂ dsa₂ jmɨg₄ jaun₂, caun₂ jmɨ₁uɨg₅ a₂tsá₃ ma₂ca₂rë₃chá₃ ca₂le₃ ca₂nio₃ mɨ₂güɨ́g₃, on₃ guë'₂ ma₃niog₅ jmɨg₄ jua'₅₄ a₂le₃cha₂ guë́₄ cang₂.
\v 22 Jua'₅₄ mei'₂ guë́₃ Diú₄ tsá₃ ma₂ca₂jme₃të́₃ jmɨg₄ jaun₂, 'i₁jan₂ tsá₃ 'ein₂ jme₁lión₂ jua'₅₄ mei'₂ guë́₃ tsá₃ le₂jaun₂. La₁ o₄quió'₄ i₂rë₂quion'₅₄ quiáin₅, jme₃të́₃ bá₄ jmɨg₄ jaun₂.
\p 
\v 23 ’Në₁jua'₂ chan₂ i₂ca₂juá'₂ tsɨ́'₅ 'nia'₂ jmɨg₄ jaun₂: “¡Jag₄ 'nia'₂! ¡La₂ bá₄ chén'₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄!” o₃ në₁jua'₂ 'ein₂ ca₂juá'₂: “Jó₄ 'ein₅₄”, tsá₃ o₁'en'₅₄ 'nia'₂ jág₁ jaun₂.
\v 24 Ia₁ juɨn₅ dsa₂ i₂juɨ₁gan₂ ja₃lén₂ a₂juá'₂ a₂lɨ́in₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄, a₂juá'₂ në́₃ a₂lɨ́in₅ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄; 'lióng₂ léi₄ juë'₂ a₂o₂dsain₂ jmo₃ a₂jme₃gain₂₃ dsa₂. Jua'₅₄ mei'₂ guë́₃ lé₂, ca₂të₂ dsa₂ i₂quion'₅₄ quián₅ Diú₄ jme₃gain₂₃.
\v 25 Jaun₂ në₅ ma₂në₂juɨ́g₂ jniá₂ 'nia'₂ të₃jŋiá₅.
\v 26 Jaun₂ në́₃, në₁jua'₂ 'ein₂ ca₂tsɨ́'₃ 'nia'₂: “Ŋí₂ 'nia'₂, jó₄ 'ein₅₄ ja₁lë́₄ 'uë₃ quein₂ co₂'ŋiog₅”, tsá₃ lë₁o₂nó'₅ 'nia'₂ ja₁jaun₂; o₃ në₁jua'₂ 'ein₂ ca₂juá'₂: “Ŋí₂ 'nia'₂, ja₁lá₃ rë₂'mai₅₄ dsi₂néi₂”, tsá₃ juɨ₁le₂'én'₂ 'nia'₂.
\v 27 Ia₁ juɨ₁lia'₂ jme₁lë́₂ si₁ŋí'₃ ca₂taun₂ ca₂taun₂, le₂jaun₂ bá₄ lé₂ jë₁ma₂të́₂ rë₁guan'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃.
\v 28 Ia₁ juɨ₁lia'₂ ja₁ron₅ 'lag₄, ja₁jaun₂ bá₄ ŋɨ'₂ i₁tú₃ tsɨn'₅₄.
\s1 'A₂ lia'₂ guan'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃
\r (Marcos 13:24-37; Lucas 21:25-33; 17:26-30, 34―36)
\p 
\v 29 ’Dsɨ₂juɨ₅ jë₁ma₂ca₂ŋag₅ jmɨg₄ o₂i₁ dsɨ₅ jaun₂,
\q1 'iog₂ në́₃ co₂dsia₅ le₃lia'₂,
\q2 tsɨ'₂ në́₃ tsá₃ ma₃tág₅ jnia₅₄;
\q2 nei₅ guë'₂ në́₃ qui₂tsɨ₃séi'₂,
\q1 ca₂le₃jë́₃ guë́₄ 'e₂ bí₂ cha₂ guei'₅₄ mɨ₂güɨ́g₃
\q2 qui₃guian'₃.\f + \fr 24:29 \ft Isaías 13:10; 34:4.\f*
\p 
\v 30 ’Të₃jë₄ jaun₂ guë́₄ në́₃, le₃jniá₂ guei'₅₄ dsi₂güɨg₂ léi₄ quió'₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃, ca₂le₃jë́₃ juɨg₂ te₁'i₁ le₂con₂ mɨ₂güɨ́g₃ tóin'₃ quɨ'₃-'o₃. Jɨ́in₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃, guain'₂ guei'₅₄ jë₄ jnei₅ quian'₅₄ ca₂le₃jë́₃ juɨ₅bí₂ a₂'io₂₃ jláin'₁.
\v 31 Jaun₂ qui₃chein₃ ángeles quiáin₅ jéi₂ ŋí₂ trompeta tiá₂ lɨn₃ a₂të₂ dsa₂ i₂quion'₅₄ quiáin₅ i₂chan₂ ca₂le₃jë́₃ juɨg₂ te₁'i₁ ta₁caun₂ mɨ₂güɨ́g₃.
\p 
\v 32 ’Jme₁tɨn₅ 'nia'₂, juɨ₁le₂ŋɨ́'₂ 'au'₂ jág₁ a₂jáng'₅ léi₄ juɨ₁lia'₂ nɨ₁'ma₂ a₂'ag₅ mɨ́g₂ higos: jme₁chéi'₂ gu'₂ nei'₅₄, a₂ja₂'ŋio₃ mog'₅₄, ŋi'₅₄ 'nia'₂ a₂ma₂ja₂quián₃ jein₂ 'iog₂ bá₄ jaun₂.
\v 33 Le₂në₅ bá₄ 'nia'₂ jaun₂ në́₃, jë₁ma₂të₅ ne'₅₄ a₂lë́₂ ca₂le₃jë́₃ a₂në₅, juɨ₁le₂ŋi'₅₄ bá₄ 'nia'₂ a₂ma₂ja₂quiáin₃, në₂jag₄ bá₄ i₂ma₂chén'₅ o₄'né₄ bá₄ 'éi₂.
\v 34 A₂dsɨ₂jó'₃ juá'₅ jniá₂ juɨ́g₂ 'nia'₂, tsá₃ dsɨ₃ŋɨ́₂ tsɨ₁jon₂ la₂,\f + \fr 24:34 \ft o₃, “né'₃ a₂dsián₃ dsa₂ i₂lɨ́n₅ raza la₂.” \f* ca₂lia'₂ ca₂lë₃ ca₂le₃jë́₃ a₂në₅.
\v 35 Já₅ jmɨg₄, guei'₅₄ dsi₂güɨg₂ quian'₅₄ mɨ₂güɨ́g₃ la₂ ŋag₅, la₁ jág₁ quió₃ o₁lɨ́g'₂ tsá₃ ŋag₅ jua'₅₄ a₂tsá₃ le₃ti₃.
\p 
\v 36 ’La₁ 'i₁jan₂ tsá₃ 'ein₂ ŋi₅ 'e₂ 'ió'₄, 'e₂ hora lé₂ a₂jaun₂, on₃ guë'₂ ángeles i₂tion'₅₄ guei'₅₄ i₂juɨ́g₃, on₃ guë'₂ 'ŋiog₅ Ja₁ŋi'₅₄ Diú₄.\f + \fr 24:36 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ chi₁ton₅ “on₃ guë'₂ 'ŋiog₅ Ja₁ŋi'₅₄ Diú₄.” \f* Jŋia'₅₄ lia'₂ 'ŋiog₅ bá₄ Diú₄ Jmei₂ ŋi₅.
\p 
\v 37 ’Ia₁ juɨ₁lia'₂ ca₂lë₃ jmɨg₄ lia'₂ con'₂ jme₁chan₂ Noé, le₂jaun₂ bá₄ lé₂ ján₃ jë₁ma₂të́₂ rë₁guan'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃.
\v 38 Ia₁ jmɨg₄ jaun₂, né'₃ a₂can'₂ mɨ₂güɨ́g₃ quian'₅₄ jmɨg₂, jme₁chan₂ dsa₂ qui₂guë́'₅, qui₂'ɨ́n'₂, qui₂jéin'₂ gu₂, qui₂cuɨin₂₃ ja₁mɨ́g₄ jme₁jéin'₂ gu₂ në́₃, ca₂lia'₂ ca₂të́₂ jmɨg₄ jme₁ca₂'í₃ Noé 'ŋió'₃ nɨ₁barco;
\v 39 la₁ con'₂ tsá₃ 'ein₂ rë₁ján₁ jme₁ca₂dság'₃ jmɨg₂ ca₂jiog₃ quió'₅ ca₂le₃jɨ́in₃. Le₂jaun₂ bá₄ lé₂ táng₃ jë₁ma₂të́₂ rë₁guan'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃.
\v 40 Jmɨg₄ jaun₂, on₃ dsa₂ ŋe'₂ tion'₅₄ ja₁nau₂; jan₂ i₂dsán'₃, jan₂ guë'₂ i₂të₃'ŋiá₄.
\v 41 On₃ guë'₂ dsa₂ mɨ́₂ tioin'₅₄ éi'₅ ne₄ nɨ₁to₂; jan₂ i₂dsán'₃, jan₂ guë'₂ i₂të₃'ŋiá₄.
\p 
\v 42 ’Jme₁jnio₂ 'nia'₂ ne'₅₄ jaun₂, ia₁ tsá₃ ŋi'₅₄ 'nia'₂ 'e₂ hora jŋió'₂ juɨg'₂.
\v 43 La₁ juɨ₁le₂ŋɨ́'₂ 'au'₂ 'nia'₂ a₂la₂: jua'₅₄ mei'₂ guë́₃ ŋi₅ dsa₂ juɨg₅₄ caun₂ dsi₂néi₂ 'e₂ hora jiá₃ dsa₂ 'ang₂ të₂le₃ ca₂nei₂, jme₃jnio₅₄ ne₅₄, tsá₃ cuë₃ jmɨg₄ a₂'í₂ dsa₂, 'ang₃ dsi₂néi₂ quió'₅.
\v 44 Le₂në₅ bá₄ 'nia'₂, rë₂ján'₁ 'nia'₂ chang'₂; ia₁ con'₂ tsá₃ ŋi'₅₄ bá₄ 'nia'₂ guan'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃.
\s1 Dsa₂ dsen₃ i₂jme₂ti₃, quian'₅₄ dsa₂ i₂tsá₃ jme₂ti₃
\r (Lucas 12:41-48)
\p 
\v 45 ’¿'Ein₂ dsa₂ i₂ŋɨ́'₂ dsɨ́₅ jme₂ti₃ con'₂ dsi₂ten₅₄ ne₄ juɨg₅₄? Juɨg₅₄ në́₃ ca₂dsia₃ o₄gú₃ 'éi₂ dsi₂néi₂ quió'₅ lia'₂ jma₃quian'₅₄ ca₂le₃jɨ́n₃ rɨin'₅₄ i₂jme₂ti₃, a₂ŋɨi'₃ rɨin'₅₄ jë₁ma₂të́₂ hora a₂guë́'₃.
\v 46 'E₂ guë́₄ dsen₃ 'éi₂ jë₁ma₂të́₂ rë₁jo₅₄ juɨg₅₄ jë₁ma₂guáin'₅ jme₂ti₃ bá₄ ta₁ a₂chéin'₅.
\v 47 A₂dsɨ₂jó'₃ juá'₅ jniá₂, cuë₃ juɨg₅₄ ta₁ a₂nio₃ ne₅₄ ca₂le₃jë́₃ 'e₂ a₂cha₂ quió'₅.
\v 48 La₁ jua'₅₄ mei'₂ guë́₃ dsa₂ i₂jme₂ti₃ lɨ́in₅ jan₂ dsa₂ 'lɨn'₅₄ i₂tsá₃ tón'₂ juɨ₅ ta₁ a₂chéin'₅, ia₁ lɨ́in₂, “i₂le₃'ɨn₄ bá₄ juɨg₃”,
\v 49 jaun₂ jme₂lióg₃ qui₂cuë́'₅ bá₄ rɨin'₅₄, dsó₂ qui₂dsɨ₂guë́'₃ qui₂dsɨ₂'én'₃ quian'₅₄ dsa₂ 'en₅ në́₃.
\v 50 La₁ caun₂ jmɨg₄ con'₂ tsá₃ rë₂jáin₁, caun₂ hora con'₂ tsá₃ lí'₄ bá₄, dsián'₄ juɨg₅₄.
\v 51 Juɨg₅₄ në́₃ cuë₃ uɨg₅,\f + \fr 24:51 \ft lit. “dsia₃ juɨg₅₄ le₁juɨg₁ le₁dsog'₅₄ quió'₅.” \f* 'liog'₃ ja₁jaun₂ bá₄ ján₃, ja₁ca₂tɨ́n₂ dsi₁len₅ i₂lë₁jmo₅-dsáu₅ o₁ne₁, ja₁quɨ'₂-'o₃, qui₃quɨ́g'₃ jan₅₄.
\c 25
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ guian₃ chi'₂ dsa₂ mɨ₄
\p 
\v 1 'Jmɨg₄ jaun₂ juɨ₁lia'₂ ja₁gon₂ Diú₄, lé₂ juɨ₁lia'₂ ca₂jmo₃ guian₃ chi'₂ dsa₂ mɨ₄ jme₁ca₂can₃ nɨ₁tsɨ́₅ le₁guí'₂ si₂ quió'₅. Ca₂i₃léin₂ ca₂i₁jme₁jein'₂ dsa₂ ŋe'₂ i₂jen'₂ gu₂.
\v 2 'Ŋiá₂ chi'₂ dsa₂ mɨ₄ 'éi₂ jme₁coin₅₄; 'ŋiá₂ guë'₂ i₂'ŋio₄, i₂dse₃ niog₅ dsi₄.
\v 3 Dsa₂ mɨ₄ i₂co₄ 'éi₂ në́₃, jmá'₃ nɨ₁tsɨ́₅ chi₁guí'₂ si₂ bá₄ ca₂can₃; tsá₃ ca₂can₃ guë'₂ nɨ₁dsɨg₁ a₂'a₄ aceite.
\v 4 La₁ dsa₂ mɨ₄ i₂niog₅ dse₃ dsi₄ në́₃ ca₂jmo₃ co₂jŋia₅₄ quió'₅, jme₁le₁quian₅ nɨ₁tsɨ́₅ le₁guí'₂ si₂, ton'₂ jme₁le₁quian₅ rë₂tsón₂ aceite 'a₄ nɨ₁dsɨg₁.
\v 5 La₁ ca₂rë₃'ɨn₄ bá₄ guë'₂ dsa₂ ŋe'₂ i₂lë₅ jág₁ jen'₂ gu₂, jaun₂ le₃jɨ́n₃ bá₄ dsa₂ mɨ́₂ 'éi₂ në́₃ ca₂tá'₂ i₁güɨ́in₃, jaun₂ ca₂güɨin₂ bá₄.
\v 6 Jaun₂ jme₁ca₂të́₂ dsi₃nei₅, ca₂né'₂ tiá₂ i₁juá'₄ dsa₂: “¡Në₅ jón'₅ dsa₂ ŋe'₂ i₂jen'₂ gu₂! ¡'Uɨn'₂ 'nia'₂ o₂jme₁jein'₂!”
\v 7 Jaun₂ qui₂ca₂nau₂ ca₂le₃jɨ́in₃, ca₂jmo₃ dse₃ mecha tsɨ́₅ quió'₅.
\v 8 Jaun₂ ca₂juá'₂ dsa₂ mɨ́₂ i₂'ŋiá₂ i₂co₄ 'éi₂ ca₂tsɨ́'₃ rɨin'₅₄ i₂'ŋio₄: “Cuë́'₁ 'nia'₂ ca₂juɨg₄ aceite quiáng'₂, ia₁ ma₂i₁ei₃ si₂ tsɨ́₅ quián₂ jnia'₅₄.”
\v 9 La₁ ca₂ŋag₃ dsa₂ mɨ́₂ i₂'ŋio₄: “Jan₂'ón₄. Ia₁ con'₂ tsá₃ ŋó₅ në₁jua'₂ tsá₃ ca₂tɨ́n'₂ quián₂ jnia'₅₄ guio₅₄, on₃ guë'₂ quián'₂ 'nia'₂ tɨ́n'₂ në́₃. Co₂ŋei'₅₄ guë́₄ dse₃ o₂nó'₅ 'nia'₂ guiong'₅₄ o₂liá₃ quiáng'₂ ja₁'nag₅ dsa₂.”
\v 10 La₁ të₁lia'₂ i₂lén₂ 'éi₂ i₂lia₅ aceite, të₃jë₄ jaun₂ ca₂guán'₃ dsa₂ ŋe'₂ i₂lë₅ jág₁ jen'₂ gu₂. Dsa₂ mɨ́₂ i₂tián'₅ lë́₅ co₂jŋia₅₄ ca₂i₃toin'₅₄ bá₄ co₂lë₅ quiong'₅₄ i₁guë'₂ ja₁niog₅ jmɨg₄ a₂jen'₂ gu₂ dsa₂. Jaun₂ ca₂jnág₃ o₄'né₄ jme₁ca₂jnág₃.
\v 11 Jme₁co₂lág₂ jaun₂, o₃len₅ i₂'ŋiá₂ 'éi₂, jaun₂ ca₂tóin'₂ ca₂të₃, ca₂juá'₂: “¡Te₁gui'₅₄, Te₁gui'₅₄! ¡Nia₄ o₄'né₄ jaun₂ tió'₄ jnia'₅₄!”
\v 12 La₁ jaun₂ ca₂ŋag₃ dsa₂ ŋe'₂: “A₂dsɨ₂jó'₃ juá'₅, tsá₃ cuɨ́ng₅ 'ein₂ 'nia'₂.”
\p 
\v 13 'Jaun₂ le₂në₅, chan'₂ 'nia'₂ co₂jŋiag'₅₄, ia₁ tsá₃ ŋi'₅₄ 'nia'₂ 'e₂ 'ió'₄, 'e₂ hora guan'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃.
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ 'a₂ lia'₂ lë́₅ ca₂jmo₃ ún₂ dsa₂ quian'₅₄ a₂ca₂dsia₃ juɨg₅₄ o₄gú₃
\r (Lucas 19:11-27)
\p 
\v 14 ’Con'₂ siá'₂ lë́₅ ja₁gon₂ Diú₄ juɨ₁lia'₂ jan₂ dsa₂ i₂'en₅₄ juɨ₅ dsó₃ dsɨ₃ŋɨ́₃ uɨ́ng₂ juɨg₂ siá'₂. Jaun₂ ca₂të́'₃ dsa₂ i₂jme₁jme₂ti₃ ta₁ ne₅₄, jaun₂ o₄gú₃ 'éi₂ ca₂dsia₃ cu₄.
\v 15 Jan₂ i₂ca₂cuë́'₃ 'ŋiá₂ mei₅ 'éi'₃ cu₄ talentos; jan₂ guë'₂ i₂ca₂cuë́'₃ tɨn₃ mei₅, jan₂ guë'₂ caun₂ mei₅. Ca₂cuë́'₃ le₂jan₂ dsa₂ 'éi₂ 'a₂ con'₂ jŋia'₅₄ quɨ'₅₄ jmɨg₄. Jaun₂ guë́₄ ŋó₃ i₁ŋɨ́₃.
\v 16 Dsa₂ i₂ca₂gue₃ 'ŋiá₂ mei₅ 'éi'₃ cu₄ në́₃, ca₂jmói'₂ ta₁ cu₄ jaun₂, jaun₂ ca₂lɨ́'₃ con'₂ guë́₄ 'ŋiá₂ mei₅ jmá'₃ a₂dsɨ́₂.
\v 17 Ján₃ bá₄ le₂jaun₂ ca₂jmo₃ i₂ca₂gue₃ tɨn₃ mei₅, ca₂lɨ́'₃ con'₂ guë́₄ tɨn₃ mei₅ táng₃ a₂të₁dsɨ₅₄.
\v 18 La₁ dsa₂ i₂ca₂gue₃ caun₂ mei₅ në́₃, ca₂'ma₃ bá₄ a₂caun₂ mei₅ a₂ca₂cuë₃ juɨg₅₄, ca₂i₁'ó₄ né'₃ 'uë₃.
\p 
\v 19 ’Uë́₂ lɨn₃ bá₄ i₁ŋɨ₂ juɨg₅₄ në́₃; la₁ ca₂guáin'₃ jme₁ca₂guáin'₃ cang₂. Jaun₂ ca₂cáun₃ 'í₁ ca₂chein'₃ cuentas quió'₅ dsa₂ i₂jme₂ti₃ i₂ca₂cuë́'₃ cu₄.
\v 20 Jaun₂ ca₂dsióg₃ i₂le₂'uɨg₅₄ i₂ca₂gue₃ 'ŋiá₂ mei₅, jaun₂ ca₂jɨ́in'₂ juɨg₅₄ con'₂ guë́₄ 'ŋiá₂ mei₅ a₂të₁dsɨ₅₄ a₂ca₂lɨ́'₃, jaun₂ juá'₂ tsɨ́'₃ juɨg₅₄: “Te₁gui'₅₄, ca₂cuë'₅₄ 'ne₂ 'ŋiá₂ mei₅; jag₄, la₂ ron₅ con'₂ guë́₄ 'ŋiá₂ mei₅ táng₃ a₂ca₂lág₃.”
\v 21 Jaun₂ ca₂juá'₂ juɨg₅₄: “'Ŋio₅ dse₃ ca₂jmo'₅₄. Lɨ́ng'₅ bá₄ jan₂ dsa₂ dsen₃ i₂ca₂rë₃ti'₅₄; ca₂rë₃teng'₅₄ bá₄ quian'₅₄ a₂ca₂juɨg₄ a₂ca₂dsia₃ jniá₂ gog'₂, në₃ në́₃ 'lióng₂ guë́₄ a₂dsia₅₄ jniá₂ gog'₂. 'Ú₅ dsi₂néi₂, o₁quián₁ o₂'ŋió₃ dsɨ₅ co₂dsia₅.”
\v 22 Jme₁co₂lág₂ jaun₂ ca₂dsióg₃ i₂ca₂gue₃ tɨn₃ mei₅, jaun₂ ca₂juá'₂: “Te₁gui'₅₄, ca₂cuë'₅₄ 'ne₂ tɨn₃ mei₅; jag₄, la₂ ron₅ con'₂ guë́₄ tɨn₃ mei₅ táng₃ a₂ca₂lág₃.”
\v 23 Jaun₂ ca₂juá'₂ juɨg₅₄, “'Ŋio₅ dse₃ ca₂jmo'₅₄. Lɨ́ng'₅ bá₄ jan₂ dsa₂ dsen₃ i₂ca₂rë₃ti'₅₄; ca₂rë₃teng'₅₄ bá₄ quian'₅₄ a₂ca₂juɨg₄ a₂ca₂dsia₃ jniá₂ gog'₂, në₃ në́₃ 'lióng₂ guë́₄ a₂dsia₅₄ jniá₂ gog'₂. 'Ú₅ dsi₂néi₂, o₁quián₁ o₂'ŋió₃ dsɨ₅ co₂dsia₅.”
\p 
\v 24 'La₁ jme₁ca₂dsióg₃ i₂ca₂gue₃ caun₂ mei₅, ca₂juá'₂ tsɨ́'₅ juɨg₅₄: “Te₁gui'₅₄, guion₄ jniá₂ a₂lɨ́ng'₅ jan₂ dsa₂ i₂tsá₃ 'e₂ ŋéi₂ dsɨ́₅, 'aun'₂ ja₁tsá₃ 'e₂ ca₂jŋí'₂, ton'₂ cag'₅₄ ja₁tsá₃ 'e₂ ca₂séi'₃.
\v 25 'Uɨg₅₄ jaun₂ ca₂rë₃gó₅ jniá₂, ca₂i₁'ó₄ bá₄ jniá₂ cu₄ quiáng'₂ né'₃ 'uë₃. La₁, la₂ bá₄ ron₅ quiáng'₂.”
\v 26 Jaun₂ ca₂ŋag₃ juɨg₅₄: “¡Dsa₂ 'lɨn'₅₄ juɨ́'₅! 'An₁, ŋi'₅₄ bá₄ jaun₂ në́₃ a₂'on₂₃ ja₁tsá₃ 'e₂ ca₂jan₃, ton'₂ cag'₅₄ ja₁tsá₃ 'e₂ ca₂séi₃.
\v 27 'Uɨg₅₄ jaun₂, jua'₅₄ banco bá₄ co₂ŋei'₅₄ ca₂i₁tio'₂ cu₄ quió₃, ia₁jaun₂ jme₁guéi'₄ cu₄ quió₃ jë₁ma₂guáng'₃ lia'₂ jma₃quian'₅₄ a₂të₁dsɨ₅₄.
\v 28 Jŋiá'₃ 'nia'₂ a₂caun₂ mei₅ chan'₂ i₂në₅ jaun₂ në́₃, o₂cuë'₅₄ i₂chan'₂ guia₃ mei₅.
\v 29 Ia₁ juɨ₁lia'₂ i₂ma₂le₁'io₅ 'lióng₂, të₂le₃ 'lióng₂ guë́₄ ŋei₂ bá₄, ia₁jaun₂ le₃cha₂ quió'₅ lia'₂ qui₂rë₂tsón₂; la₁ juɨ₁lia'₂ i₂tsá₃ 'e₂ le₁'io₅, le₂jiog₅ a₂ca₂juɨg₄ a₂ma₂le₁'io₂₃, co₂dsia₅ jŋia'₃ bá₄.
\v 30 Jaun₂ dsa₂ i₂tsá₃ ta₁ tén₄ la₂, dsein₅₄ ca₁'né₄ tioin'₂ 'nia'₂ jë₄ qui₁né'₃, ja₁quɨ'₂-'o₃ quɨ́g'₃ jan₅₄ në́₃.”
\s1 Jë₁ma₂të́₂ rë₁të₃dsɨ₅₄ 'éi'₃ ja₁con₂ dsa₂ mɨ₂güɨ́g₃.
\p 
\v 31 ’Jë₁ma₂të́₂ rë₁guan'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ a₂lɨ́in₅ rag₅₄ jlán'₁ lɨn₃, a₂qui₂le₁lio₃ ángeles quiáin₅, jaun₂ guë́₄ guá₃ ne₄ta₁ quió'₅ a₂'uain'₂ lɨn₃,
\v 32 jaun₂ ŋɨ'₂ ne₅₄ ca₂le₃jɨ́n₃ dsa₂ chan₂ juɨg₂ ca₂le₂con₂ mɨ₂güɨ́g₃. Jaun₂ guë́₄ në́₃ jmo₃ jma₃quén₅ con'₂ ca₂tɨ́n₂ le₂jan₂ le₂jan₂ dsa₂ quian'₅₄ rɨin'₅₄, juɨ₁lia'₂ jmo₅ dsa₂ i₂jmo₅ 'í₁ já'₂ cha'₂, jmo₂₃ jma₃quén₅ já'₂ cha'₂ quian'₅₄ chein₄ lau₂.
\v 33 Të₂le₃ gu₂ ne₁ quió'₅, chein'₃ já'₂ cha'₂; chein₄ lau₂ guë'₂ të₂le₃ gu₂ jen₅.
\v 34 Jaun₂ në́₃, juá'₂ Rag₅₄ tsɨ́'₅ i₂tión₂ të₂le₃ gu₂ ne₁: “I₂no'₄ 'nia'₂ i₂ma₂rë₂gon'₅₄ quián₅ Ŋe'₃; gue₄ 'nia'₂ a₂ca₂tɨ́ng'₂ ja₁gon₂ Diú₄, ja₁ma₂lë́₅ co₂jŋia₅₄ quián'₂ 'nia'₂ ca₂le₃ ca₂nio₃ mɨ₂güɨ́g₃.
\v 35 Ia₁ ca₂ŋɨ₃ jniá₂ 'ong₅₄, 'nia'₂ bá₄ i₂ca₂cuë'₅₄ a₂ca₂guë'₃; ca₂ŋɨ₃ a₂rë₂quein₂ dsɨ₃ i₁guɨ'₄ jmɨg₂, 'nia'₂ bá₄ i₂ca₂cuë'₅₄ jmɨg₂ ca₂guɨ'₃; ca₂ŋɨ₃ jniá₂ 'no₂₃ ja₁jan₁₂, 'nia'₂ bá₄ i₂ca₂cuë'₅₄ dsi₂néi₂ quiáng'₂ ca₂jan₅₄.
\v 36 Ca₂ŋɨ₃ jniá₂ 'ɨn₂ tsɨ́n'₅, 'nia'₂ bá₄ i₂ca₂cuë'₅₄ tsɨ́n'₅ ca₂quɨ́'₃; ca₂tsán₂ dsong₅₄, 'nia'₂ bá₄ i₂ca₂jmo'₅₄ 'í₁; ca₂i₁'ú₄ né'₃ 'má₃, ca₂i₁jag'₄ bá₄ 'nia'₂.”
\v 37 Jaun₂ në́₃, ŋag₃ dsa₂ dsen₃ 'éi₂: “Te₁gui'₅₄, ¿lɨ́g'₂ bá₄ jaun₂ ca₂né₄ jnia'₅₄ 'ne₂ a₂ŋɨ'₂ i₁cuang'₃ jaun₂ ca₂cuë́₁ jnia'₅₄ a₂ca₂qué'₂? ¿O₃ lɨ́g'₂ jaun₂ ca₂né₄ jnia'₅₄ 'ne₂ a₂ŋɨ'₂ rë₂quein₂ 'au'₂, jaun₂ ca₂cuë́₁ jnia'₅₄ jmɨg₂ ca₂'én'₂?
\v 38 ¿O₃ lɨ́g'₂ jaun₂ ca₂né₄ jnia'₅₄ 'ne₂ a₂ŋɨ'₂ 'náu'₂ ja₁jan'₄, jaun₂ jnia'₅₄ bá₄ ca₂cuë́₁ dsi₂néi₂ ca₂jŋia'₅₄, o₃ ca₂ŋɨ'₅₄ 'ɨn₂ tsɨ́n'₂, jaun₂ jnia'₅₄ bá₄ ca₂cuë́₁?
\v 39 ¿O₃ lɨ́g'₂ jaun₂ ca₂né₄ jnia'₅₄ 'ne₂ a₂rong'₂ dsong'₅₄ o₃ lia'₂ con'₂ ca₂'ú'₃ né'₃ 'má₃, jaun₂ ca₂i₁jag₅₄ jnia'₅₄?”
\v 40 Jaun₂ në́₃, ŋag₃ Rag₅₄: “A₂dsɨ₂jó'₃ juá'₅ jniá₂, ca₂le₃jë́₃ a₂dse₃ a₂'ua₁ 'au'₂ 'nia'₂ ca₂jmo'₅₄ ja₁con₂ le₂jan₂ le₂jan₂ rɨ́ng'₃ la₂ i₂jɨ́n₂ dsa₂ mɨ₂güɨ́g₃ 'uɨn₃, o₄quió₃ jniá₂ bá₄ a₂ca₂jmo'₅₄ 'nia'₂.”
\p 
\v 41 ’Jaun₂ juá'₂ táng₃ Rag₅₄ tsɨ́'₃ i₂tión₂ të₂le₃ gu₂ jen₅: “Jŋia'₃ 'nia'₂ ja₁con₂ jniá₂, 'nia'₂ i₂tiong'₅₄ 'éi'₃ o₁nóg'₅ dsi₂si₂ ja₁tsá₃ ton₅ jmɨg₄ éi₃, ja₁lë́₄ co₂jŋia₅₄ quió'₅ i₂së₃dsen₃ quian'₅₄ ángeles quiáin₅.
\v 42 Ia₁ ca₂ŋɨ₃ jniá₂ i₁cón₅, 'nia'₂ në́₃ tsá₃ 'e₂ ca₂cuë'₅₄ a₂guë'₅₄; ca₂ŋɨ₃ rë₂quein₂ dsɨ₃ i₁guɨ'₄ jmɨg₂, tsá₃ 'e₂ jmɨg₂ ca₂cuë'₅₄ 'nia'₂.
\v 43 Ca₂ŋɨ₃ jniá₂ 'no₂₃ ja₁jan₁₂, tsá₃ ja₁ca₂cuë'₅₄ 'nia'₂ jan₅₄. Ca₂ŋɨ₃ 'ɨn₂ tsɨ́n'₅, tsá₃ 'e₂ tsɨ́n'₅ ca₂cuë'₅₄ 'nia'₂. Ca₂tsán₂ dsong₅₄, jme₁ca₂'ú₃ né'₃ 'má₃ në́₃, tsá₃ ca₂i₁jag'₄ 'nia'₂.”
\v 44 Jaun₂ në́₃, ŋag₃ dsa₂ 'éi₂: “Te₁gui'₅₄, ¿lɨ́g'₂ bá₄ jaun₂ ca₂né₄ jnia'₅₄ 'ne₂ a₂ŋɨ'₂ i₁cuang'₃, o₃ rë₂quein₂ 'au'₂ o₃ ca₂ŋɨ'₅₄ 'náu'₂ ja₁jan'₄, o₃ ca₂ŋɨ'₅₄ tsá₃ tsɨ́n'₂ cha₂ quɨ'₅₄, o₃ jme₁ca₂rë₃dsong'₅₄, o₃ lia'₂ con'₂ ca₂'ú'₃ né'₃ 'má₃, tsá₃ ca₂jme₁'o₁ jnia'₅₄?”
\v 45 Jaun₂ ŋag₃ Rag₅₄: “A₂dsɨ₂jó'₃ juá'₅ jniá₂, ca₂le₃jë́₃ a₂dse₃ a₂tsá₃ ca₂jmo'₅₄ 'nia'₂ ja₁con₂ le₂jan₂ le₂jan₂ rɨ́ng'₃ la₂ i₂jɨ́n₂ dsa₂ mɨ₂güɨ́g₃ 'uɨn₃, o₄quió₃ jniá₂ bá₄ tsá₃ 'e₂ ca₂jmo'₅₄ 'nia'₂.”
\v 46 Jaun₂ dsa₂ 'éi₂ dsɨ₃léin₂ ja₁dsɨ₃ŋag₅₄ uɨg₅ co₂tan₅₄, la₁ dsa₂ dsen₃ në́₃, dsɨ₃lein₅ ja₁le₃chain₂ co₂tan₅₄.
\c 26
\s1 Ca₂quɨn'₃ dsa₂ jág₁ a₂tsáin'₂ Jesús
\r (Marcos 14:1-2; Lucas 22:1-2; Juan 11:45-53)
\p 
\v 1 Jme₁ca₂dsan₃ juá'₂ Jesús ca₂le₃jë́₃ jág₁ në₅, jaun₂ ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂:
\p 
\v 2 ―Ma₂ŋi'₅₄ 'nia'₂ jaun₂, a₂tɨn₃ jmɨg₄ në₃ te₅₄ Jmɨg₄ Të₂'ɨn₅₄, ja₁jáng'₂ dsa₂ jɨ́in'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ a₂tion₃ ne₄ cróg₄.
\p 
\v 3 Jaun₂ në́₃, juɨg₅₄ jme₂dsa₂, quian'₅₄ të₅juá'₅, dsa₂ can'₅₄ quián₅ dsa₂ judíos në́₃, ca₂ŋɨi'₂ i₁dsi₅ ne₄ta₁ quió'₅ i₂lɨ́n₅ jme₂dsa₂ dsen₅₄, i₂chen₂ Caifás.
\v 4 Ja₁jaun₂ ca₂quɨin₃ jág₁ quió'₅ a₂jmo₃ të₂le₃ quian'₅₄ caun₂ mai₅₄ ia₁jaun₂ cuɨn₃ jmɨg₄ tsáun'₂, jaun₂ jŋang'₃.
\v 5 Jaun₂ tioin'₅₄ ca₂dsia₃ jág₁ ca₂juá'₂:
\p ―La₁ tsá₃ 'nió'₅ jmó₁ jniog₄ të₃ niog₅ jmɨg₄, jme₁né₄, ia₁ con'₂ tsá₃ ŋó₅ në₁jua'₂ ca₂tó'₂ dsa₂ juɨg₂ mɨ'₅₄.
\s1 Jan₂ 'io₅₄ ca₂tsɨ́in₂ Jesús no'₅₄ mɨ₂juɨg₂
\r (Marcos 14:3-9; Juan 12:1-8)
\p 
\v 6 Lia'₂ con'₂ 'en₅₄ guë́₄ Jesús juɨg₂ Betania ja₁quió'₄ i₂të́'₂ dsa₂ Si₂mu₅₄ 'mé'₅ 'iog₅,
\v 7 jaun₂ ca₂dsióg₃ jan₂ 'io₅₄ quian₅ caun₂ tsɨ́₅ no'₅₄ mɨ₂juɨg₂ a₂'mu'₅₄. Jme₁ma₂guá₅ Jesús ne₄ mesa guë́'₅, jaun₂ ca₂'ág₂ 'io₅₄ 'éi₂ no'₅₄ mɨ₂juɨg₂ mɨ₂dsi₄ Jesús.
\v 8 Jme₁ca₂jág₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ a₂jaun₂, tsá₃ dse₃ ca₂tɨ́in₂, jaun₂ ca₂tsɨ́'₃ rɨin'₅₄ tioin'₅₄:
\p ―Tsá₃ ne₄ 'e₂ lë₃ në₂'éin₂ a₂në₅.
\v 9 Jua'₅₄ co₂ŋei'₅₄ bá₄ në₂'nag₃ ia₁jaun₂ jme₁jme₂'oin₅₄ dsa₂ te₂ŋé₂.
\p 
\v 10 Jme₁ca₂nág₂ Jesús jág₁ a₂dsia₂₃ tioin'₅₄, jaun₂ ca₂juá'₂:
\p ―¿'E₂ lë₃ cuë'₂ 'nia'₂ o₂me'₅₄ dsɨ₅ 'io₅₄ la₂? A₂në₂jmóg'₂ la₂ caun₂ a₂dse₃ bá₄.
\v 11 Ca₂le₃jë́₃ jmɨg₄ bá₄ i₂nio₄ dsa₂ te₂ŋé₂ jɨn'₄ 'nia'₂, la₁ jniá₂ në́₃ tsá₃ ma₃uë́₂ 'en₅₄ jniá₂ quian'₅₄ 'nia'₂.
\v 12 Juɨ₁lia'₂ no'₅₄ mɨ₂juɨg₂ a₂në₂tsáng₂ nɨ₁ŋɨ₃, jua'₂ a₂ma₂në₂jmóg'₂ co₂jŋia₅₄ jë₁ma₂të́₂ rë₁'ong₃ bá₄.
\v 13 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, ca₂le₂con₂ mɨ₂güɨ́g₃ ja₁'ë́₂ dsa₂ jág₁ dse₃ quió₃, ján₃ bá₄ le₂jaun₂ dsiog'₂ dsɨ́₅ dsa₂ 'ɨin₃ 'io₅₄ në₅.
\s1 Jmo₅ Judas caun₂ jág₁ a₂'nɨi₂₃ Jesús
\r (Marcos 14:10-11; Lucas 22:3-6)
\p 
\v 14 Jaun₂ në́₃, jan₂ i₂lɨ́n₅ dsa₂ guia₃-tɨ́n₂, i₂chen₂ Judas Iscariote, ŋei₅₄ i₁dsia₂ jág₁ quian'₅₄ juɨg₅₄ jme₂dsa₂,
\v 15 jaun₂ ca₂i₁jua'₄:
\p ―¿Je₂liá'₂ cuë́'₁ 'nia'₂ në₁jua'₂ jɨn'₄ jniá₂ Jesús o₄gog'₂?
\p Jaun₂ në́₃, ca₂quí₃ juɨg₅₄ jme₂dsa₂ guióg₂-guiá₂ 'éi'₃ cu₄tiog₂.
\v 16 Jaun₂ në́₃ të₃ne₄ juɨ₅ ja₁ŋó₄ jaun₂, ca₂'náu'₃ Judas dsɨ́₅ 'a₂ lia'₂ cuɨn₃ jmɨg₄ jɨ́in'₂ Jesús.
\s1 Má₃ jë₁ca₂tó'₂ quió'₅ Te₁gui'₅₄
\r (Marcos 14:12-25; Lucas 22:7-23; Juan 13:21-30; 1 Corintios 11:23―26)
\p 
\v 17 Jmɨg₄ le₂'uɨg₅₄ a₂niog₅ Jmɨg₄ Të₂'ɨn₅₄ a₂guë́'₅ dsa₂ i₁ŋí'₄ a₂tsá₃ quian'₅₄ levadura, chi'₂ dsɨ₂guia₃-tɨ́n₂ në́₃ ca₂jme₃quiáin₃ ja₁con₂ Jesús ca₂ŋag₃:
\p ―¿A₂já'₄ 'niog'₂ dsɨ₁jmó₁ jnia'₅₄ co₂jŋia₅₄ má₃ Jmɨg₄ Të₂'ɨn₅₄ quiáng'₂?
\p 
\v 18 Jaun₂ ca₂juá'₂ Jesús:
\p ―O₂nó'₅ 'nia'₂ jë₄ juɨg₂, ja₁quió'₄ jan₂ dsa₂, jaun₂ juɨg'₅₄ 'nia'₂: “Le₂la₂ juá'₂ të₅: Ma₂ja₂quián₃ hora quió₃, jaun₂ ja₁quiáng'₂ i₁guë'₃ Jmɨg₄ Të₂'ɨn₅₄ co₂lë₅ quian'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáng₃.”
\p 
\v 19 Jaun₂ në́₃ i₃lén₂ bá₄ chi'₂ dsɨ₂guia₃-tɨ́n₂, jaun₂ ca₂jmo₃ con'₂ lë́₅ jág₁ ca₂juá'₂ Jesús. Jaun₂ ca₂tóin'₂ ca₂jmo₃ co₂jŋia₅₄ a₂guë́'₃ Jmɨg₄ Të₂'ɨn₅₄ ja₁jaun₂.
\p 
\v 20 Jme₁ca₂nei₂ jaun₂, jme₁ma₂guá₅ Jesús ne₄ mesa co₂lë₅ quiain'₅₄ ta₁guia₃-tɨ́n₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅.
\v 21 Të₃jë₄ tiáin'₄ guë́'₅ jaun₂, ca₂juá'₂ Jesús:
\p ―A₂dsɨ₂jó'₃ juá'₅ jniá₂, jan'₂ 'nia'₂ i₂'en₅₄ jë₄ la₂ bá₄ i₂jáng'₂ jniá₂.
\p 
\v 22 Jaun₂ në́₃ ca₂tá'₂ 'lia'₂ dsɨ́₅ 'ŋio₅ lɨn₃ bá₄ tiáin'₅, jaun₂ ca₂jme₃lióg₃ ca₂ŋɨ́i'₃ Jesús le₂jain₂ le₂jain₂ ca₂juá'₂:
\p ―Te₁gui'₅₄, ¿On₁jua'₅₄ jniá₂ 'ág'₅?
\p 
\v 23 Jaun₂ ca₂ŋag₃ Jesús:
\p ―I₂tiá₂ gu₂ co₂lë₅ 'ŋió'₃ uɨng₅ quian'₅₄ jniá₂, i₂'éi₂ bá₄ i₂jáng'₂.
\v 24 Dsón'₂ bá₄ dsau₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃ 'ein₅₄ juɨ₅ lia'₂ con'₂ lë́₅ juá'₂ ne₄ Si₂; la₁ ¡'e₂ guë́₄ juɨ́g₂ dsa₂ i₂jáng'₂! Dse₃ quió'₅ jua'₅₄ co₂ŋei'₅₄ bá₄ tsá₃ ca₂rë₃cháin₃.
\p 
\v 25 Jaun₂ në́₃ Judas, dsa₂ i₂ma₂lë́₂ dsɨ́₅ jáng'₂, ca₂juá'₂:
\p ―Të₅, ¿On₁ jniá₂ bá₄ 'ág'₅ 'ne₂?
\p Jaun₂ ca₂ŋag₃ Jesús:
\p ―'Ŋiag'₂ bá₄ ma₂në₂jua'₅₄.
\p 
\v 26 Të₁lia'₂ tiáin'₅ guë́'₅, ca₂jŋa'₃ Jesús i₁ŋí'₄, ca₂cuë́'₃ ti₁'mag'₄ Diú₄, jaun₂ guë́₄ ca₂dsioin₃, ca₂cuë́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ ca₂juá'₂:
\p ―Qué'₂ 'nia'₂, ia₁ ŋɨ₃ bá₄ jniá₂ i₁ŋí'₄ la₂.
\p 
\v 27 Jaun₂ ca₂can₃ táng₃ copa 'a₄ vino, ján₃ bá₄ le₂jaun₂ ca₂cuë́'₃ ti₁'mag'₄ Diú₄, jaun₂ guë́₄ ca₂cuë́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂, jaun₂ ca₂juá'₂:
\p ―'Én'₂ 'nia'₂ ca₂le₃jɨ́ng'₃ a₂la₂,
\v 28 ia₁ jmɨ₃ bá₄ jniá₂ la₂, a₂lɨ'₅₄ jág₁ 'mɨ́₂ a₂të₃ron₅₄,\f + \fr 26:28 \ft 'Nio'₂ ja₁ton₅ Éxodo 24:8; Hebreos 10:29; 13:20.\f* a₂niog₅ dsɨ₃'o₅₄ o₄quió'₄ juɨn₅ dsa₂, ia₁jaun₂ 'én₂ dsáu₁.
\v 29 Dsón'₂ juá'₅ jniá₂, tsá₃ ma₃lɨ́g'₂ jmɨg₄ jua'₅₄ a₂guɨ'₅₄ guë́₄ táng₃ vino ca₂lia'₂ ca₂të́₂ jmɨg₄ i₁guɨ'₄ táng₃ caun₂ vino 'mɨ́₂ co₂lë₅ quian'₅₄ 'nia'₂ ja₁gon₂ Ŋe'₃.
\s1 Ca₂juá'₂ Jesús a₂tsá₃ tion₃ Pe₄ a₂cuɨg₂₃
\r (Marcos 14:26-31; Lucas 22:31-34; Juan 13:36-38)
\p 
\v 30 Jme₁ca₂lë₃ 'ë₂₃ jme₂juɨin'₂ Diú₄, jaun₂ guë́₄ i₃léin₂ juɨ₅ Má'₂ Olivos.
\v 31 Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂:
\p ―Ca₂le₃jɨ́n'₃ bá₄ 'nia'₂ tiá'₃ jén₂ 'au'₂ o₄quió₃ jniá₂ a₂'uë₂ në₃, 'ág'₁ 'nia'₂ caun₂-tɨn₃ 'au'₂; ia₁ rë₂ton₅ ne₄ Si₂, juá'₂: “Jŋɨ́'₄ jniá₂ dsa₂ i₂jŋia₅ já'₂ cha'₂, jaun₂ já'₂ cha'₂ në́₃ dsɨ₃léin₂ tsɨ₁rë₂jain₅₄.”\f + \fr 26:31 \ft Zacarías 13:7.\f*
\v 32 La₁ cang₂ jë₁ma₂ca₂jeng'₅₄ táng₃, nei₅₄ jniá₂ jŋiág₅ juɨ₅ Galilea lia'₂ con'₂ guë́₄ 'nia'₂.
\p 
\v 33 Jaun₂ në́₃ ca₂ŋag₃ Pe₄:
\p ―O₁jŋia'₅₄ la₂ ca₂'ág₂ caun₂-tɨn₃ dsɨ́₅ ca₂le₃jɨ́n₃ rɨ́ng'₃, la₁ jniá₂, o₁lɨ́g'₂ jmɨg₄ tsá₃ 'ag₅₄ caun₂-tɨn₃ dsɨ₃.
\p 
\v 34 Jaun₂ ca₂juá'₂ Jesús:
\p ―A₂dsɨ₂jó'₃ juá'₅ jniá₂, a₂'uë₂ në₃, né'₃ a₂'o₃ të₁guí₄ dsó₂, hora jaun₂ dé₄ dsón'₂ chéng'₅ tsá₃ tóng'₄ ta₁'nɨ₅ ráun₂ a₂cuɨg'₂ jniá₂.
\p 
\v 35 Jaun₂ ca₂ŋag₃ táng₃ Pe₄:
\p ―O₁jŋia'₅₄ la₂ ca₂dsau₃ jniog₄ co₂lë₅, o₁lɨ́g'₂ jmɨg₄ jua'₅₄ a₂tsá₃ 'ɨ́n₄ jniá₂ 'ne₂.
\p Le₂jaun₂ bá₄ ca₂juá'₂ ca₂le₃jɨ́n₃ rɨin'₅₄ ján₃.
\s1 Ca₂chi₃lén'₂ Jesús Diú₄ caun₂ ja₁chei₂ Getsemaní
\r (Marcos 14:32-42; Lucas 22:39-46)
\p 
\v 36 Jaun₂ ca₂dsióg₃ Jesús jme₁ca₂dsióg₃ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ caun₂ ja₁chei₂ Getsemaní, jaun₂ ca₂juá'₂:
\p ―Ja₁lá₃ tián'₂ 'nia'₂ të₁lia'₂ nei₅₄ jó₄ i₁chi₁leng'₄ Diú₄.
\p 
\v 37 Jaun₂ ca₂jŋiai₃ Pe₄, quian'₅₄ le₃on₃ ja₁ŋi'₅₄ Zebedeo, jaun₂ Jesús në́₃ ca₂tá'₂ quian₅ o₂i₁ dsɨ₅ 'ŋio₅ lɨn₃.
\v 38 Jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ i₂ún₂ i₂quiain'₅₄:
\p ―'Ŋio₅ lɨn₃ quian₅₄ o₂i₁ dsɨ₅, ca₂lia'₂ jmá'₃ le₃jóng₂ të₂në₃. Ja₁lá₃ tián'₂ 'nia'₂, jme₁jnio₂ 'nia'₂ ne'₅₄, jme₁quiong'₅₄ jniá₂.
\p 
\v 39 Ca₂juɨg₄ bá₄ ca₂ŋó₃ guë́₄ ne₄ juɨ₅. Ja₁jaun₂ ca₂lia'₂ ca₂i₃'ɨ́in₃ chi₁'ɨn₅ ne₅₄ ca₂të₂ 'uë₃, ca₂mɨ₃ ca₂tsɨ́'₃ Diú₄, ca₂juá'₂:
\p ―Tia₅₄ quiáng₃, jua'₅₄ mei'₂ bá₄ lé₂ le₃lé₂, lio₄ jniá₂ jmɨ₁uɨg₅ la₂. La₁ tsá₃ juɨ₁le₅₄ con'₂ 'nio₃ jniá₂, juɨ₁le₅₄ bá₄ a₂'ŋio₂ 'au'₂ 'ne₂.
\p 
\v 40 Jaun₂ në́₃, ca₂nau₂ Jesús, jaun₂ ca₂ŋái'₃ ja₁tián'₄ i₂ún₂ i₂quiain'₅₄, la₁ ma₂le₁güɨ́n₃ bá₄ guë'₂ 'éi₂ tiáin'₅; jaun₂ ca₂të́'₃ Pe₄, ca₂juá'₂:
\p ―¿Tsa₁ ma₃tian'₃ guë́₄ 'nia'₂ jua'₅₄ caun₂ hora bá₄ jme₁jnio'₂ guë́₄ 'nia'₂ ne'₅₄ quian'₅₄ jniá₂?
\v 41 Jme₁jnio₂ 'nia'₂ ne'₅₄, chi₁len'₄ 'nia'₂ Diú₄, ia₁jaun₂ tsá₃ tsɨ₃sén'₂ 'nia'₂. Dsón'₂ bá₄ jaun₂ 'ŋio₂ bá₄ dsɨ́₅ jme₂dsí₂ quián'₂ 'nia'₂, la₁ nɨ₁ŋɨ'₁ guion'₅₄ bá₄ 'nia'₂ 'uan₅₄.
\p 
\v 42 A₂ca₂të́₂ tɨn₃ ráun₂ ŋó₃ táng₃ i₁chi'₄ Diú₄ le₂la₂:
\p ―Tia₅₄ quiáng₃, chi₂jua'₂ tsá₃ lé₂ jua'₅₄ a₂tsá₃ jme₁ŋag₅₄ jniá₂ uɨg₅ la₂, juɨ₁le₅₄ bá₄ a₂'ŋio₂ 'au'₂ 'ne₂.
\p 
\v 43 Jaun₂ ca₂guáin'₃ táng₃ ja₁tián'₄ chi'₂ dsɨ₂guia₃-tɨ́n₂, la₁ le₁güɨ́n₃ bá₄ táng₃ 'éi₂ tiáin'₅, ia₁ a₂ŋɨ́₄ lë₃ ma₂i₁güɨ́in₃.
\v 44 Jaun₂ ŋó₃ bá₄ táng₃ jë₁ca₂të́₂ 'nɨ₅ ráun₂, a₂chi₂i₁lein'₄ Diú₄; ján₃ bá₄ le₂jaun₂ ca₂juá'₂ tsɨ́'₅ Diú₄.
\v 45 Jaun₂ guáin'₃ në́₃ ja₁tián'₄ chi'₂ dsɨ₂guia₃-tɨ́n₂, jaun₂ ca₂juá'₂:
\p ―¿'E₂? ¿Lia'₂ ma₂tián'₅ jaun₂ bá₄ 'nia'₂ le₁güɨ́ng'₃? Ŋí₂ 'nia'₂, ca₂të́₂ bá₄ hora në́₃. Ma₂rë₂jɨn'₅₄ bá₄ Jaun₅ dsa₂ mɨ₂güɨ́g₃ o₄gú₃ dsa₂ i₂le₁cán'₄ dso₄.
\v 46 Nau₂ 'nia'₂ në́₃, ma₃; ia₁ në₅ ma₂já₅ i₂jáng'₂.
\s1 Ma₂le₁te₂ dsa₂ Jesús
\r (Marcos 14:43-50; Lucas 22:47-53; Juan 18:2-11)
\p 
\v 47 Të₃jë₄ dsia₂₃ jág₁ jaun₂, jme₁ca₂dsióg₃ Judas, i₂lɨ́n₅ jan₂ dsa₂ i₂guia₃-tɨ́n₂. Juɨn₅ lɨn₃ dsa₂ i₂ja₂lén₂ quiong'₅₄ qui₂le₁quian₅ ŋi₁tág₂, i₂le₁quian₅ nɨ₁'ma₂ në́₃, i₂chen₄ quián₅ juɨg₅₄ jme₂dsa₂ quian'₅₄ dsɨ₂gui'₅₄ can'₅₄ quián₅ dsa₂ juɨg₂.
\v 48 Jaun₂ Judas në́₃, ia₁ ma₂ca₂jmo₃ bá₄ jág₁ le₂jŋiá₅ 'e₂ léi₄ jmo₃ jë₁ma₂të́₂ rë₁jáng'₂, jme₁ma₂juá'₂:
\p ―I₂chen'₄ jniá₂ quió'₅, i₂'éi₂ bá₄ jma'₅₄ 'nia'₂.
\p 
\v 49 Jaun₂ dsɨ₂juɨ₅ jme₁dsióg₃ Judas, ca₂jme₃quiáin₃ con₂ Jesús, jaun₂ ca₂juá'₂:
\p ―¡Siang'₃, të₅!
\p Jaun₂ ca₂chen'₃ rë₂jú'₅ Jesús.
\p 
\v 50 Jaun₂ ca₂jéin'₃ Jesús jág₁ quió'₅, ca₂juá'₂:
\p ―A₂mei₅₄, ¿'E₂ ta₁ ŋɨ'₂?
\p Jaun₂ guë́₄ ca₂jme₃quián₃ ca₂le₃jɨ́n₃ dsa₂ ca₂jŋai'₃ Jesús, jaun₂ ca₂tág₃.
\p 
\v 51 Të₃jë₄ jaun₂, jan₂ dsa₂ i₂jme₁quian'₅₄ Jesús ca₂dsi₂ ŋi₁tág₂, ca₂ti₃ caun₂ rë₂gua₄ dsa₂ i₂jme₂ti₃ quián₅ jme₂dsa₂ dsen₅₄.
\v 52 Jaun₂ ca₂juá'₂ Jesús:
\p ―Tiá₃ táng₃ ŋi₁tág₂ quiáng'₂ ja₁jme₁'i₄. Ia₁ ca₂le₃jɨ́n₃ i₂quɨ́n'₂ quian'₅₄ ŋi₁tág₂, ján₃ bá₄ quian'₅₄ ŋi₁tág₂ dsiáin₃.
\v 53 ¿'E₂ lɨ́ng'₂? ¿A₁tsá₃ lé₂ le₃jme₁mɨ₁₂ ne₄ Ŋe'₃, a₂chein₃ ja₁cong₂ guia₃-tɨ́n₂ mei₅ ángeles quiáin₅?
\v 54 La₁ jua'₅₄ mei'₂ guë́₃ le₂jaun₂, ¿'A₂ bá₄ lia'₂ le₃ti₃ jág₁ a₂tio'₅₄ ne₄ Si₂ ja₁juá'₂ a₂dsɨ₃ŋɨ́g₂ le₂la₂?
\p 
\v 55 Jaun₂ juá'₂ Jesús tsɨ́'₅ dsa₂:
\p ―¿'E₂? ¿Ja₁nó'₅ 'nia'₂ le₁quian'₅₄ ŋi₁tág₂, nɨ₁'ma₂, ja₂chong'₂ jniá₂, në₂jag₄ bá₄ lɨ́ng₅ dsa₂ 'ang₂? Jua'₂ ca₂le₃jë́₃ jmɨg₄ bá₄ 'eng₅₄ jme₁tɨ́ng₂ dsa₂ jɨn'₄ 'nia'₂ i₁dsi₅ guá'₅ templo, tsá₃ ma₂chong'₂ guë'₂ 'nia'₂ ja₁jaun₂.
\v 56 La₁ ca₂le₃jë́₃ a₂lë́₂ la₂ rë₂ti₃ jág₁ quió'₅ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂.
\p Jaun₂ guë́₄ qui₂ca₂cuɨng₃ ca₂le₃jɨ́n₃ chi'₂ dsɨ₂guia₃-tɨ́n₂, ca₂téin₂ bá₄ Jesús.
\s1 Dsián'₃ Jesús ne₄ dsɨ₂tan₅₄ quián₅ guá'₅
\r (Marcos 14:53-65; Lucas 22:54-71; Juan 18:12-24)
\p 
\v 57 Jaun₂ dsa₂ i₂ca₂i₁chan'₅₄ Jesús ca₂i₁jo₅₄ ne₄ Caifás, i₂lɨ́n₅ jme₂dsa₂ dsen₅₄. Ja₁jaun₂ ma₂le₁ŋɨ'₂ të₅juá'₅ quian'₅₄ guë́₄ dsa₂ can'₅₄.
\v 58 Pe₄ në́₃ ca₂ŋó₃ uɨ́ng₂ të₂quɨ́in₃ 'ein₂₃ Jesús ca₂të₂ i₁dsi₅ quió'₅ jme₂dsa₂ dsen₅₄. Ja₁jaun₂ ca₂'í₃ ca₂guá₂ quiain'₅₄ 'lióg₂, ia₁ 'nio₃ të₅ ne₅₄ 'a₂ lia'₂ jŋia'₅₄ dsióg₄ quian'₅₄ Jesús.
\p 
\v 59 Jaun₂ juɨg₅₄ jme₂dsa₂, quian'₅₄ ca₂le₃jɨ́n₃ dsɨ₂tan₅₄ quián₅ guá'₅ në́₃, qui₂ca₂'náu'₃ juɨ₅ 'a₂ lia'₂ jme₃cáin'₂ Jesús dso₄ quian'₅₄ jág₁ të₂jág₁ ia₁jaun₂ jŋag'₃.
\v 60 La₁ tsá₃ dso'₂ guë'₂ 'a₂ lia'₂ jme₃cáu'₂, o₁jŋia'₅₄ juɨn₅ i₂qui₂ca₂nau₂ jmo₂₃ jág₁ të₂jág₁. Dsi₃lén₂ jme₁dsi₃lén₂ on₃ dsa₂,
\v 61 jaun₂ ca₂juá'₂:
\p ―I₂në₅ ma₂ca₂juá'₂, “Quɨ'₅₄ jniá₂ jmɨg₄ lé₂ le₃'éng₄ guá'₅ templo quió'₅ Diú₄, quian'₅₄ 'nɨ₅ jmɨg₄ bá₄ lé₂ le₃jmóg'₄ táng₃.”
\p 
\v 62 Jaun₂ ca₂nau₂ jme₂dsa₂ dsen₅₄, jaun₂ ca₂tsɨ́'₃ Jesús:
\p ―¿Tsa₁ 'e₂ ŋag'₅₄ 'i₁caun₂? ¿I₂'e₂ bá₄ jág₁ në₅ a₂jáng'₅ dsa₂ a₂rë₂cáng'₄?
\p 
\v 63 La₁ tei₄ bá₄ ca₂nau₂ Jesús. Jaun₂ ca₂ŋag₃ táng₃ jme₂dsa₂ dsen₅₄, ca₂juá'₂:
\p ―Dsi₅₄ jniá₂ 'éi'₃ a₂jua'₅₄ 'ɨ́ng'₅ Diú₄ jén'₃ ne₄ jnia'₅₄, chi₂jua'₂ të₃dsón'₂ lɨ́ng'₅ Ja₁ŋi'₅₄ Diú₄, I₂rë₂'ɨ́n₁ quiáin₅.
\p 
\v 64 Jaun₂ ca₂ŋag₃ Jesús:
\p ―Ján₅, jniá₂ bá₄ 'éi₂, juɨ₁lia'₂ i₁juá'₂ 'ne₂ në₅. La₁ juá'₅ jniá₂ juɨ́g₂ 'nia'₂ ján₃, ca₂le₃jɨ́ng'₃, a₂já₅ jmɨg₄ a₂jag'₅₄ 'nia'₂ jɨng'₅₄ Jaun₅ dsa₂ mɨ₂güɨ́g₃ guá₃ të₂le₃ gu₂ ne₁ Diú₄ i₂'uan'₂ guë́₄ lɨn₃, a₂jŋiói'₂ jë₄ jnei₅ guei'₅₄ dsi₂güɨg₂ në́₃.
\p 
\v 65 Jme₂dsa₂ dsen₅₄ në́₃, jme₁ca₂nág₂ jág₁ jaun₂, ca₂chein₃ nɨ₁tsɨn'₅₄ 'ŋiog₅,\f + \fr 26:65 \ft Jme₁chí'₄ tag₄ quió'₅ dsa₂ judíos jmɨg₄ jaun₂ a₂gág₅ dsa₂ nɨ₁tsɨn'₅₄ cuë₂₃ léi₄ jë₁ma₂'í₅ 'nei₂ dsɨ́₅, o₃ jme₁'i₄ quɨ'₂ dsɨ́₅.\f* jaun₂ ca₂juá'₂:
\p ―¡'E₂ guë́₄ 'ŋio₅ 'lɨg'₅₄ juá'₂ i₂në₅ 'ɨin₂₃ Diú₄ quian'₅₄ jág₁ në₅ quió'₅! ¿'E₂ guë́₄ jmá'₃ jág₁ 'lióng₂ 'niog₂ jniog₄ jua'₅₄ a₂jáng'₅ guë́₄ dsa₂ sián'₂ jág₁ dsau₅? Ma₂në₂nei'₂ bá₄ 'nia'₂ guiong'₅₄ jág₁ 'lɨg'₅₄ a₂ma₂në₂juá'₂ i₂në₅ 'ɨin₂₃ Diú₄.
\v 66 ¿'A₂ lia'₂ lɨ́n'₂ 'nia'₂?
\p Jaun₂ ca₂juá'₂ ca₂le₃jɨ́in₃ tioin'₅₄:
\p ―I₂ca₂tɨ́n₂ jón₂ bá₄ në₅.
\p 
\v 67 Jaun₂ qui₂ca₂'ŋéi₃ dsa₂ dsɨ₂ne₄ Jesús tioin'₅₄, tsá₃ caun₂ a₂qui₂ca₂jmóg'₂. I₂lɨn₅₄ guë'₂ qui₂ca₂quein₃ tioin'₅₄,
\v 68 jaun₂ ca₂juá'₂:
\p ―'Ne₂ guë'₂ i₂juá'₂ lɨ́ng'₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄: ¡Dsi₄ jág₁ jua'₅₄ 'ein₂ në₂quein₃ quiáng'₂!
\s1 Tsá₃ ca₂tion₃ Pe₄ a₂cuɨin₂₃ Jesús
\r (Marcos 14:66-72; Lucas 22:56-62; Juan 18:15-27)
\p 
\v 69 Të₃jë₄ jaun₂ jme₁guá₄ Pe₄ i₁dsi₅; jaun₂ ca₂dsióg₃ jan₂ 'io₅₄ i₂jme₂ti₃ ta₁ ja₁jaun₂, jaun₂ ca₂tsɨ́'₃ Pe₄:
\p ―¿Ján₃ guë'₂ jme₁quian'₄ 'ne₂ Jesús i₂chan₂ Galilea?
\p 
\v 70 La₁ jɨn₄ dsa₂ ja₁guá₄ jaun₂ tsá₃ ca₂tioin₃, jaun₂ ca₂juá'₂:
\p ―Tsá₃ guion₅₄ 'e₂ a₂juá'₂ 'ne₂ në₅.
\p 
\v 71 Ca₂nau₂ Pe₄ ŋó₅ të₂le₃ o₄'né₄, jaun₂ ca₂jág₂ táng₃ jan₂ 'io₅₄ sián'₂. 'Éi₂ në́₃ ca₂tsɨ́'₃ dsa₂ i₂tion'₅₄:
\p ―I₂jme₁quian'₅₄ Jesús Nazareno bá₄ në₅.
\p 
\v 72 La₁ jme₁ca₂nág₂ Pe₄, tsá₃ ca₂tioin₃ táng₃ jë́₃ 'ɨin₂₃ Diú₄, ca₂juá'₂:
\p ―¡Tsá₃ dsa₂ 'éi₂ cuɨ́n₅ jniá₂!
\p 
\v 73 Jme₁co₂lág₂ jaun₂, ca₂jme₃quián₃ dsa₂ i₂tion'₅₄ con₂ Pe₄, jaun₂ ca₂juá'₂:
\p ―Të₃dsón'₂ bá₄ lɨ́ng'₅ jan₂ rɨn'₅₄ 'éi₂, ia₁ në₅ rë₂jniág'₂ 'a₂ lia'₂ né'₂ jag'₅₄.
\p 
\v 74 Jaun₂ në́₃, Pe₄ ca₂'ɨin₃ Diú₄ ca₂mɨ₃ a₂dsɨ₃ŋɨ́i₂ 'e₂ dsɨ₃ŋɨ́i₂, ca₂juá'₂:
\p ―¡Tsá₃ dsa₂ 'éi₂ cuɨ́n₅ jniá₂!
\p Të₃jë₄ jaun₂ ca₂'o₃ jan₂ të₁guí₄ dsó₂.
\v 75 Jaun₂ guë́₄ në́₃ ca₂dsáu'₃ dsɨ́₅ Pe₄ a₂ca₂juá'₂ Jesús le₂jŋiá₅: “Né'₃ a₂'o₃ të₁guí₄ dsó₂; hora jaun₂ dé₄ dsón'₂ chéng'₅ tsá₃ tóng'₄ ta₁'nɨ₅ ráun₂ a₂cuɨg'₂ jniá₂.” Jaun₂ guë́₄ o₂'ɨ́n₃ Pe₄ të₂le₃ ca₁'né₄, ca₂tá'₂ quɨ'₂ dsɨ́₅, ca₂'o₃ 'ŋio₅ lɨn₃.
\c 27
\s1 Ca₂jɨ́n'₂ dsa₂ Jesús o₄gú₃ Pilato
\r (Marcos 15:1; Lucas 23:1-2; Juan 18:28-32)
\p 
\v 1 Jme₁jnia₃ jaun₂, ca₂le₃jɨ́n₃ juɨg₅₄ jme₂dsa₂ quian'₅₄ gui'₅₄ can'₅₄ quián₅ dsa₂ juɨg₂ ca₂jmo₃ caun₂ jág₁ a₂jŋɨi'₃ Jesús.
\v 2 Qui₂ca₂'néi₂ tioin'₅₄, jaun₂ ca₂tág₃ ca₂i₁jang'₂ ne₄ Dsi₄má'₂ Poncio Pilato.
\s1 Ca₂jon₃ Judas
\r (Hechos 1:18-19)
\p 
\v 3 Jme₁ma₂të₅ ne₄ Judas i₂ca₂'nag₃, a₂ma₂në₂dsí₃ dsa₂ 'éi'₃ a₂jŋɨi'₃ Jesús, jaun₂ ca₂tá'₂ quɨ'₂ dsɨ́₅. Jaun₂ ca₂i₁con₂ táng₃ ta₁guiog₃-guiá₂ 'éi'₃ cu₄tiog₂ jaun₂, ca₂jɨ́in'₃ juɨg₅₄ jme₂dsa₂ quian'₅₄ gui'₅₄ can'₅₄.
\v 4 Jaun₂ ca₂juá'₂:
\p ―Ma₂në₂'no₃ jniá₂ dso₄, ia₁ në₂jɨng'₅₄ ne₄ 'mú₃ jan₂ i₂tsá₃ dso₄ rɨn₂.
\p La₁ ca₂ŋag₃ dsa₂ 'éi₂:
\p ―Tsá₃ 'e₂ a₂jaun₂ dsan₂ dsɨ₅ jnia'₅₄. A₂ca₂tɨ́n'₂ 'ne₂ bá₄ jaun₂.
\p 
\v 5 Con'₂ ca₂i₁guia'₂ jaun₂ bá₄ Judas cu₄ jaun₂ dsi₂néi₂ ja₁jŋió₅ guá'₅ templo, jaun₂ ca₂o₃'ɨ́in₃ ca₂i₁tiá₄ ché₂ dsɨ₂lag₅₄ ca₂jŋɨi'₃ 'ŋiog₅.
\v 6 Juɨg₅₄ jme₂dsa₂ në́₃ ca₂i₁cag'₂ cu₄ jaun₂, jaun₂ ca₂juá'₂:
\p ―Tsá₃ 'i₄ 'éi'₃ dsɨ₃to'₅₄ cu₄ la₂ 'ŋió'₃ gu₅ ja₁tio'₅₄ cu₄ quió'₅ guá'₅, ia₁ cu₄ a₂ca₂quɨ́n₂ jmɨ₂ bá₄ la₂.
\p 
\v 7 Jaun₂ ca₂jmo₃ caun₂ jág₁ a₂lá₃ caun₂ 'uë₃ quian'₅₄ cu₄ jaun₂ quió'₅ jan₂ dsa₂ i₂jme₁jmo₅ nɨ₁dsɨg₁ gua'₅₄, ja₁jmo₃ 'uë₃ ja₁'óin₂ jmá'₃ lia'₂ dsɨ₂nau₂.
\v 8 'Uɨg₅₄ jaun₂ chei₂ ja₁jaun₂ ca₂të₂ jmɨg₄ në₃, 'Uë₃ Jmɨ₂.
\v 9 Le₂në₅ ca₂rë₃ti₃ jág₁ a₂ca₂juá'₂ Jeremías, dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂, jme₁ca₂juá'₂: “Ca₂can₃ dsa₂ guióg₂-guiá₂ cu₄tiog₂, con'₂ 'ma'₅₄ a₂ca₂dsi₂ dsa₂ juɨg₂ Israel quió'₅ 'éi₂.
\v 10 Quian'₅₄ cu₄ jaun₂ ca₂lá₃ caun₂ 'uë₃ quió'₅ dsa₂ i₂jmo₅ nɨ₁dsɨg₁, lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ Te₁gui'₅₄.”\f + \fr 27:10 \ft Jeremías 32:6-9; Zacarías 11:12-13.\f*
\s1 Chén'₅ Jesús ne₄ Pilato
\r (Marcos 15:2-5; Lucas 23:3-5; Juan 18:33-38)
\p 
\v 11 Të₁lia'₂ jaun₂, chén'₅ Jesús ne₄ dsi₄má'₂, jaun₂ 'éi₂ në́₃ ca₂ŋag₃:
\p ―¿Dsón'₂ lɨ́ng'₅ Rag₅₄ quián₅ dsa₂ judíos?
\p Jaun₂ ca₂ŋag₃ Jesús:
\p ―Le₂në₅ bá₄, juɨ₁lia'₂ juá'₂ 'ne₂ në₅.
\p 
\v 12 Jaun₂ caun₂ qui₂ca₂'nag₃ bá₄ juɨg₅₄ jme₂dsa₂ quian'₅₄ gui'₅₄ can'₅₄ tioin'₅₄. La₁ tsá₃ ma₃'e₂ ca₂ŋag₃ Jesús.
\v 13 Jaun₂ ca₂juá'₂ Pilato:
\p ―¿Tsa₁ nag'₂ ca₂le₃jë́₃ 'e₂ i₁juá'₄ dsa₂ në₅ 'nɨi₂₃ 'ne₂?
\p 
\v 14 La₁ tsá₃ ma₃'e₂ ca₂ŋag₃ Jesús 'i₁caun₂; jaun₂ ca₂i₃gó'₃ dsɨ́₅ Pilato.
\s1 Ca₂o₃'ág₃ 'éi'₃ a₂jón₂ Jesús
\r (Marcos 15:6-20; Lucas 23:13-25; Juan 18:38 ― 19:16)
\p 
\v 15 Jmɨg₄ jaun₂ jme₁chí'₄ tag₄ quió'₅ dsi₄má'₂ a₂lióin₂ ca₂le₃jë́₃ ŋi₂, jan₂ dsa₂ i₂'en₅₄ né'₃ 'má₃, jme₁të₅ Jmɨg₄ Të₂'ɨn₅₄, 'ein₂ ca₂'ɨn₃ dsa₂ juɨg₂ i₂lión₂.
\v 16 Jmɨg₄ jaun₂ jme₁rë₂jnɨ́₅ jan₂ dsa₂ i₂chen₂ Barrabás, ca₂le₂con₂ bá₄ 'ei₅ jág₁ quió'₅ a₂'lɨin'₅₄.
\v 17 Të₃jë₄ le₁ŋɨ'₂ dsa₂ jaun₂, ca₂ŋag₃ Pilato ca₂ŋɨ́i'₃ dsa₂ juɨg₂:
\p ―¿I₂'ein₂ 'niog'₂ 'nia'₂ lon₄ jniá₂ quián'₂ 'nia'₂? ¿Barrabás, o₃ Jesús i₂të́'₂ dsa₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄ 'e₂?
\p 
\v 18 Ia₁ ca₂rë₃lí'₄ bá₄ Pilato 'ŋiog₅, a₂'iog₅₄ uɨg₅ dsɨ́₅ bá₄ dsa₂ ca₂jɨ́in'₂ Jesús ne₅₄.
\p 
\v 19 Të₁lia'₂ guá₅ Pilato ne₄ta₁ quió'₅, ja₁qui₂dsɨ₂₃ 'éi'₃, të₃jë₄ jaun₂ ca₂chen₃ 'io₅₄ quiáin₅ jág₁ ne₅₄ a₂ca₂juá'₂: “Tsá₃ lë₁tián₅ 'ne₂ cuente quió'₅ dsa₂ i₂tsá₃ 'e₂ rɨn₂ në₅. Ia₁ 'ŋio₅ gau₂ qui₂chóg₂ i₃ŋɨ́g₂ ca₂néi₃ o₄quió'₄.”
\p 
\v 20 La₁ juɨg₅₄ jme₂dsa₂ quian'₅₄ gui'₅₄ can'₅₄ në́₃, ca₂toin'₂ jág₁ dsa₂ juɨg₂ ia₁jaun₂ mɨ₃ dsa₂ tsɨ́'₃ Pilato a₂lióin₂ Barrabás bá₄, jaun₂ jŋɨi'₃ bá₄ Jesús.
\v 21 Jaun₂ ca₂juá'₂ Pilato ca₂tsɨ́'₃ dsa₂:
\p ―¿I₂'ein₂ dsa₂ on₃ la₂ 'niog'₂ 'nia'₂ lon₄ jniá₂?
\p Jaun₂ ca₂ŋag₃ dsa₂ juɨg₂ tioin'₅₄:
\p ―Barrabás bá₄.
\p 
\v 22 Jaun₂ ca₂ŋag₃ táng₃ Pilato ca₂ŋɨ́i'₃ dsa₂ juɨg₂:
\p ―¿'E₂ guë'₂ 'niog'₂ 'nia'₂ jmo₅₄ jniá₂ quian'₅₄ Jesús i₂të́'₂ dsa₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄?
\p Jaun₂ ca₂ŋag₃ co₂dsia₅ ca₂le₃jɨ́in₃ tioin'₅₄:
\p ―¡Tióin₃ cróg₄!
\p 
\v 23 Jaun₂ ca₂ŋag₃ táng₃ Pilato:
\p ―¿'E₂ 'uɨg₅₄ në́₃? ¿'E₂ guë'₂ dso₄ ma₂'náu₂?
\p La₁ të₂le₃ i₂juɨ'₂ guë́₄ co₂mɨ'₅₄ ca₂tóin'₂, ca₂juá'₂:
\p ―¡Tióin₃ cróg₄!
\p 
\v 24 La₁ ca₂rë₃lí'₄ bá₄ Pilato tsá₃ 'e₂ ta₁ jmo₃ jág₁ quió'₅, ia₁ të₂le₃ 'ŋio₅ lɨn₃ guë́₄ juɨ₁si co₂mɨ'₅₄ ca₂tóin'₂. Jaun₂ lë₃, ca₂chein₃ jan₂ dsa₂ i₁quian₅₄ jmɨg₂, jaun₂ ca₂rang₃ gu₂ të₃ne₄ dsa₂ juɨg₂, jaun₂ ca₂juá'₂:
\p ―Tsá₃ 'e₂ rë₃cán'₄ jniá₂ jmɨ₄ dsa₂ në₅; guion'₅₄ bá₄ 'nia'₂ rë₂cáng'₄ në₁'e₂ ca₂jmai'₅₄.
\p 
\v 25 Jaun₂ ca₂ŋag₃ ca₂le₃jɨ́n₃ dsa₂ juɨg₂ tioin'₅₄:
\p ―¡Jmɨ₄ 'mú₃ quió'₅ i₂në₅, juɨ₁dsi₂ŋag₂ jnia'₅₄ 'e₂ dsɨ₃ŋág₂, quian'₅₄ tsɨ₁jon₂ quián₂ jnia'₅₄ i₂në₃ guë́₄ të₁ja₃lén₂!
\p 
\v 26 Jaun₂ ca₂lión₂ bá₄ Pilato Barrabás i₂mɨ₅ dsa₂ lión₂; jaun₂ ca₂jmo₃ 'éi'₃ a₂bán₂ dsa₂ Jesús, jaun₂ guë́₄ ca₂jáng'₂ o₄gú₃ dsa₂ juɨg₂ jaun₂ tion₃ cróg₄.
\p 
\v 27 Jme₁co₂lág₂ jaun₂, 'lióg₂ quián₅ dsi₄má'₂ ca₂jŋiai₃ Jesús juɨ₅ i₁dsi₅ ne₄ta₁ jaun₂. Jaun₂ ca₂ŋɨ'₂ ca₂le₃jɨ́n₃ 'lióg₂ le₃lág'₃ quió'₅ Jesús.
\v 28 Jaun₂ guë́₄ ca₂dsi₂ tsɨn'₅₄ Jesús, ca₂quei'₃ caun₂ tsɨ₁'mɨ'₂ guéin₂ 'uɨ'₃,\f + \fr 27:28 \ft Guéin₂ 'uɨ'₃ jme₁jniá₂ tsɨn'₅₄ rag₅₄ jme₁quɨ́'₅ jmɨg₄ jaun₂.\f*
\v 29 jaun₂ ca₂jmo₃ caun₂ corona quian'₅₄ chi₁uɨ́ng₃ taun₅, ca₂tó'₂ mɨ₂dsi₄ Jesús. Ca₂chong'₂ ca₂'nau₅₄ guë'₂ nɨ₁'ma₂ ta₅ gu₂ ne₁. Jaun₂ guë́₄ ca₂chi₃jné₃ ne₄ Jesús tioin'₅₄, a₂lë₁qui₂co₂jmóg'₂, ca₂juá'₂:
\p ―¡Sian'₃ 'ne₂, Rag₅₄ quián₅ dsa₂ judíos!
\p 
\v 30 Ján₃ qui₂ca₂'ŋéi₂ dsa₂, qui₂ca₂bá₂ dsa₂ mɨ₂dsi₅₄ quian'₅₄ nɨ₁'ma₂ a₂ca₂chong'₃ jaun₂.
\v 31 Jme₁ca₂lë₃ a₂lë₁co₂jmóg'₂ jaun₂, ca₂dsei₂₃ táng₃ tsɨ₁'mɨ'₂ 'uɨ'₃ a₂jme₁ca₂quei'₃, jaun₂ ca₂quei'₃ táng₃ nɨ₁tsɨn'₅₄ a₂jme₁qui'₂. Jaun₂ guë́₄ ca₂jiog₃ ca₂të₂ ja₁të₃toin₅₄ cróg₄.
\s1 Ca₂tion₃ dsa₂ cróg₄ Jesús
\r (Marcos 15:21-32; Lucas 23:26-43; Juan 19:17-27)
\p 
\v 32 A₂ca₂'uɨin₂ jaun₂, ca₂jein'₂ jan₂ dsa₂ i₂chan₂ Cirene, i₂chen₂ Si₂mu₅₄. Jaun₂ ca₂chi₃quiáin₂ jmɨg₄ 'éi₂ a₂cán₂ cróg₄.
\p 
\v 33 Jaun₂ ca₂dsi₃léin₂ jme₁dsi₃léin₂ caun₂ ja₁chei₂ Gólgota, co₂'nió'₄ ja₁të́'₂ dsa₂ Dsɨ₂con'₂ Nɨ₁mu₅ Mɨ₂dsi₄ 'Lag₄.
\v 34 Ja₁jaun₂ ca₂jén'₃ dsa₂ ne₄ Jesús vino a₂rë₃cón'₅ quian'₅₄ dsɨ́'₁ já'₂;\f + \fr 27:34 \ft co₂'nió'₄ caun₂ mɨ́₅ a₂jŋia'₃ uɨg₅ quió'₅ dsa₂.\f* la₁ dsɨ₂juɨ₅ jme₁ca₂tí₂ Jesús 'o₅₄, tsá₃ ma₃ca₂'ɨn'₃.
\p 
\v 35 Jme₁ca₂lë₃ tion₂₃ cróg₄, 'lióg₂ në́₃ ca₂jmo₃ dsióg₁ tsɨn'₅₄ Jesús, ca₂co₃ o₁ne₄ 'ein₂ lí'₂.\f + \fr 27:35 \ft A₂lɨn₅₄ chog₅₄ si₂ a₂ca₂lë₃ guë́₄ cang₂ juá'₂ le₂la₂ ján₃: “Le₂në₅ ca₂lë₃ ca₂rë₃ti₃ jág₁ a₂ca₂juá'₂ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂, ja₁juá'₂: ‘Ca₂dsión'₂ dsa₂ nɨ₁tsɨ́n'₅; ca₂co₃ dsa₂ o₁ne₄ 'ein₂ lí'₂ 'mɨ'₂ quió₃’.” Salmo 22:18.\f*
\v 36 Ja₁jaun₂ ca₂tiáin'₂ jmo₂₃ 'í₁.
\v 37 Dsi₄ cróg₄ ca₂tióng₃ dsa₂ letra ja₁juá'₂ 'e₂ dso₄ a₂bóin'₂ Jesús, a₂juá'₂ le₂la₂: “I₂LA₂ BÁ₄ JESÚS, I₂LƗ́N₅ RAG₅₄ QUIÁN₅ DSA₂ JUDÍOS”.
\p 
\v 38 Ján₃ bá₄ ca₂tioin₃ guë́₄ on₃ dsa₂ 'ang₂ co₂lë₅ quiong'₅₄, jan₂ të₂le₃ gu₂ ne₁, jan₂ guë'₂ të₂le₃ gu₂ jen₅.
\v 39 Jaun₂ ca₂le₃jɨ́n₃ dsa₂ i₂qui₂ca₂ŋɨ́₃ juɨ₅ jaun₂ qui₂ca₂jnáu'₂ jág₁ uɨg₅, qui₂bí₂ dsi₅₄,
\v 40 ca₂juá'₂:
\p ―'Ne₂ guë'₂ i₂juá'₂ a₂'éng'₄ guá'₅, con'₂ siá'₂ tɨng'₂ jmog'₅₄ táng₃ quian'₅₄ 'nɨ₅ jmɨg₄, në₃ në́₃, lion₄ 'ŋiag'₂. Sión₅ ja₁tong'₂ në₅, chi₂jua'₂ dsón'₂ 'ne₂ lɨ́ng'₅ Ja₁ŋi'₅₄ Diú₄.
\p 
\v 41 Ján₃ bá₄ le₂jaun₂ a₂lë₁qui₂co₂jmóg'₂ juɨg₅₄ jme₂dsa₂ quian'₅₄ të₅juá'₅, gui'₅₄ can'₅₄ në́₃, dsia₂₃ jág₁ qui₂tsɨ́'₅ rɨin'₅₄, juá'₂:
\p 
\v 42 ―Ca₂lióin₂ bá₄ i₂sián'₂, la₁ 'ŋiog₅ bá₄ tsá₃ lé₂ le₃lióin₂. Chi₂jua'₂ i₂në₅ lɨ́n₅ Rag₅₄ quián₅ dsa₂ juɨg₂ Israel, juɨ₁sióin₄ cróg₄ ia₁jaun₂ bá₄ le₃'éin₂ jniog₄ le₃quió'₅.
\v 43 I₂në₅ guë'₂ juá'₂ 'ei₅ caun₂ dsɨ́₅ ne₄ Diú₄; në₃ në́₃ 'éi₂ juɨ₁lio₅₄ chi₂jua'₂ të₃dsón'₂ bá₄ 'nioi₃ i₂në₅; ia₁ 'ŋiog₅ guë'₂ ma₂juá'₂ lɨ́in₅ Ja₁ŋi'₅₄ Diú₄.
\p 
\v 44 Le₂jiog₅ dsa₂ 'ang₂ i₂le₁ton₅ quian'₅₄ Jesús qui₂ca₂juá'₂ uɨg₅.
\s1 Ca₂jon₃ Jesús
\r (Marcos 15:33-41; Lucas 23:44-49; Juan 19:28-30)
\p 
\v 45 Jme₁ca₂të́₂ dsi₂ŋí'₃,\f + \fr 27:45 \ft lit. “hora jŋéi₂.” \f* ca₂'ág₂ nei₂ le₂tan₅₄ le₂con₂ 'uë₃ jaun₂ ca₂lia'₂ ca₂të́₂ hora ŋí₁ 'nɨ₅\f + \fr 27:45 \ft lit. “hora ŋi₃.” \f* të₂le₃ ca₂'láu₂.
\v 46 Hora jaun₂, ca₂'ŋia₂ guë́₄ Jesús, jág₁ ca₂juá'₂ tiá₂:
\p ―Elí, Elí, ¿lama sabactani? ―co₂'nió'₄ a₂juá'₂: Diú₄ quiáng₃, Diú₄ quiáng₃, ¿'e₂ lë₃ ma₂në₂téi'₃ jniá₂?\f + \fr 27:46 \ft Salmo 22:1.\f*
\p 
\v 47 I₂lɨn₅₄ dsa₂ i₂jme₁tión₂ cau₅ jaun₂ ca₂nág₂, jaun₂ ca₂dsia₃ jág₁ tsɨ́'₅ rɨin'₅₄:
\p ―Nei₂ 'nia'₂. Elías, i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂, të́'₂.
\p 
\v 48 Jaun₂ dsɨ₂juɨ₅ le₂jaun₂ ŋó₃ jan₂ co₂chi'₅₄ i₁quian₅₄ caun₂ nɨ₁jau₂ guion₅ jmɨg₂. Jaun₂ ca₂guioin₃ vino dsi'₃, jaun₂ ca₂chi₃dsí₂ nei'₅₄ caun₂ nɨ₁'ma₂ ta₅, jaun₂ ca₂jén'₃ ne₄ Jesús ia₁jaun₂ jme₁'ɨ́n'₂.
\v 49 La₁ ca₂juá'₂ rɨin'₅₄:
\p ―Tsá₃ lein'₅₄; o₁ne₄ chi₂jua'₂ jiá₃ Elías ja₃lio₅₄ quió'₅.
\p 
\v 50 Con'₂ bá₄ ca₂'ŋióg₂ guë́₄ Jesús tiá₂ lɨn₃, jaun₂ guë́₄ ca₂jáng'₃ jme₂dsí₂ quió'₅.
\v 51 Hora jaun₂ dé₄ dsón'₂ co₂dsia₅ ca₂chen₃ ca₂të₂ guei'₅₄ ca₂të₂ 'uë₃ ca₂lë₃ tɨn₃ tsɨ́n'₅ tsɨ₁'mɨ'₂ pa₁ a₂jme₁'ei₅ dsi₂néi₂ guá'₅ templo. 'Uë₃ guë'₂ në́₃ ca₂i₁bi₅₄, nɨ₁'lau₂ a₂te₁'i₁ ja₁jaun₂ qui₂ca₂dsón₂;
\v 52 tau₂ 'ŋio₅ në́₃ qui₂ca₂niá₃ ca₂lë₃; ján₃ bá₄ qui₂ca₂jen'₅₄ juɨn₅ 'lag₄ jŋió₅ quián₅ Diú₄ i₂ma₂dsan₃ le₂jŋiá₅.
\v 53 Qui₂ca₂'uɨin₂ tau₂ 'ŋio₅; ca₂i₃toin'₅₄ Jerusalén ciudad jŋió₅ jme₁ca₂jen'₅₄ Jesús, ton'₂ ca₂jme₃jniai₂₃ në́₃ ne₄ juɨn₅ dsa₂.
\p 
\v 54 Jaun₂ juɨg₅₄ 'lióg₂ quian'₅₄ guë́₄ dsa₂ i₂jme₁quiain'₅₄ jmo₂₃ 'í₁ Jesús, jme₁ma₂të₅ ne₅₄ dsɨ₂bi₅₄ 'uë₃ ma₂lë́₂ ca₂le₃jë́₃ guë́₄ 'e₂ a₂ca₂lë₃ jaun₂, jaun₂ guë́₄ ca₂rë₃gó'₅ 'ŋio₅ lɨn₃; jaun₂ guë́₄ ca₂juá'₂:
\p ―Të₃dsón'₂ bá₄ jme₁lɨ́n₄ i₂në₅ Ja₁ŋi'₅₄ Diú₄.
\p 
\v 55 Jme₁tion'₅₄ juɨn₅ 'io₅₄ ja₁jaun₂ jág₅, tióin₂ uɨ́ng₂. 'Éi₂ ma₂ja₂léin₂ jme₂ti₃ ne₄ Jesús le₂tan₅₄ 'uë₃ Galilea.
\v 56 Jɨn₄ 'io₅₄ 'éi₂ jme₁'en₅₄ María i₂chan₂ Magdala, quiain'₅₄ María chog₅₄ Jacobo quian'₅₄ Së́₄; quian'₅₄ chog₅₄ chi'₂ quián₅ Zebedeo.
\s1 Ca₂'on₃ Jesús
\r (Marcos 15:42-47; Lucas 23:50-56; Juan 19:38-42)
\p 
\v 57 Jme₁ca₂tó'₂ nei₂ jmɨg₄ jaun₂, guan₃ jan₂ dsa₂ cha₂ cu₄ i₂chen₂ José, i₂chan₂ juɨg₂ Arimatea, ia₁ ján₃ bá₄ ca₂rë₃'éin₂ le₃quió'₅ Jesús.
\v 58 'Éi₂ në́₃, ŋei₅₄ i₂jɨin₁₂ Pilato, ca₂i₁mɨi'₄ 'lag₄ Jesús. Jaun₂ ca₂jmo₃ Pilato 'éi'₃ a₂jáng'₂ dsa₂.
\v 59 Jaun₂ në́₃ ca₂tág₃ Së́₄, ca₂lio₃ rë₂ quian'₅₄ caun₂ tsɨ₁'mɨ'₂ le₁jë́₃.
\v 60 Jaun₂ ca₂i₁tio'₂ 'ŋió'₃ caun₂ tau₂ 'ŋio₅ 'mɨ́₂ quió'₅ 'ŋiog₅, a₂jme₁ma₂guéi₃ dso'₂ nɨ₁'lau₂. Jaun₂ ca₂jŋiói'₃ ca₂mɨ́g₂ nɨ₁cang₁ lɨ'₂ pa₁, ca₂jlë́₂ 'o₄ tau₂ 'ŋio₅, jaun₂ guë́₄ ca₂ŋái'₃.
\v 61 La₁ María i₂chan₂ Magdala quiain'₅₄ María jan₂ 'éi₂, jaun₂ bá₄ jme₁tiáin'₄ të₂le₃ ja₁jniá₂ o₄'né₄ tau₂ 'ŋio₅.
\s1 Jmo₅ 'lióg₂ 'í₁ tau₂ 'ŋio₅
\p 
\v 62 Jme₁jnia₃ táng₃ jaun₂, co₂'nió'₄ jme₁ca₂dsan₃ tion'₅₄ dsa₂ jmo₂₃ co₂jŋia₅₄ a₂'nió'₅ quió'₅ jmɨg₄, jaun₂ ca₂i₁len₅₄ juɨg₅₄ jme₂dsa₂ quian'₅₄ dsa₂ fariseos në́₃ ca₂ŋɨi'₂ ne₄ Pilato,
\v 63 ca₂i₁jua'₄:
\p ―Gui'₅₄, dsáu'₅ dsɨ₅ jnia'₅₄, a₂ca₂juá'₂ të₂jág₁ 'éi₂ lia'₂ con'₂ jme₁chain₂ guë́₄, a₂jein'₅₄ táng₃ a₂'nɨ₅ jmɨg₄.
\v 64 'Uɨg₅₄ jaun₂, chen₅ 'lióg₂ juɨ₁dsi₂jmó₂ 'í₁ tau₂ 'ŋio₅ ca₂lia'₂ ca₂të́₂ jmɨg₄ 'nɨ₅, ia₁ con'₂ tsá₃ ŋó₅ në₁jua'₂ ja₂lén₂ dsa₂ i₂jme₁quiain'₅₄ të₂, jaun₂ táun₂ jág₁ cang₂, lé₂ le₃juá'₂: “Ma₂ca₂jein'₅₄ bá₄ táng₃.” Ia₁ në₁jua'₂ ca₂lë₃ le₂jaun₂, ja₂lɨn₃ guë́₄ juë'₂ lé₂ jág₁ të₂jág₁ jë₁ca₂tó'₂ në₅, con'₂ guë́₄ jág₁ të₂jág₁ le₂'uɨg₅₄.
\p 
\v 65 Jaun₂ ca₂juá'₂ Pilato:
\p ―Në₅ tión₂ co₂nió'₃ i₂në₅. O₂nó'₅ 'nia'₂ quiain'₅₄, o₂jmo₄ 'nia'₂ 'í₁ 'a₂ con'₂ jŋia'₅₄ tian'₃ 'nia'₂ jmó'₂.
\p 
\v 66 Jaun₂ ca₂i₃léin₂ jaun₂ në́₃, i₁jmo₅₄ 'í₁ dse₃ lɨn₃ tau₂ 'ŋio₅, ca₂tióng₃ caun₂ sello dso'₂ nɨ₁cang₁ a₂chi₁jnɨ₅, jaun₂ ca₂chein'₃ co₂nió'₃ 'lióg₂ i₂jmo₃ 'í₁.
\c 28
\s1 Jmɨg₄ a₂ca₂jen'₅₄ Jesús
\r (Marcos 16:1-8; Lucas 24:1-12; Juan 20:1-10)
\p 
\v 1 Ca₂ŋɨ́₂ bá₄ jmɨg₄ sa₅₄. Jaun₂ në́₃, të₂le₃ ca₂jnia₃ jmɨg₄ le₂'uɨg₅₄ semana, ca₂ŋe₄ María i₂chan₂ Magdala quiain'₅₄ María jan₂; ca₂i₁lein₅₄ i₁jag₅₄ tau₂ 'ŋio₅ quió'₅ Jesús.
\v 2 Con'₂ tsá₃ rë₂jáin₁ dsɨ₂juɨ₅ le₂jaun₂ ca₂i₁bi₅₄ 'uë₃ tiá₂ lɨn₃ ia₁ a₂ca₂sión₃ guei'₅₄ i₂juɨ́g₃ jan₂ ángel quián₅ Te₁gui'₅₄. Ca₂të₁tsɨin'₅₄ o₄'né₄ tau₂ 'ŋio₅, ca₂mói₂ nɨ₁cang₁ a₂jme₁chi₁jnɨ₅, jaun₂ ca₂guá₂ ne₄ jaun₂.
\v 3 Ca₂lia'₂ tág₅ 'ŋio₅ lɨn₃ jniái₂ juɨ₁lia'₂ tág₅ si₁ŋí'₃. Tsɨn'₅₄ a₂qui'₂ guë'₂ tiog₂ jau₂ lɨn₃.
\v 4 Jme₁ca₂jág₂ 'lióg₂ i₂tion'₅₄ jmo₅ 'í₁, ca₂rë₃gó'₅ 'ŋio₅ lɨn₃ ca₂jlein₃ në₂jag₄ bá₄ tsá₃ dsɨ́₅ chan₂ ca₂jén'₃.
\v 5 Jaun₂ ca₂juá'₂ ángel ca₂tsɨ́'₃ 'io₅₄:
\p ―Tsá₃ jmo₂ 'nia'₂ gang'₃. Ia₁ guion₄ jniá₂ a₂'na'₂ Jesús i₂ca₂tion₃ dsa₂ cróg₄ bá₄ 'nia'₂ i₂niog'₅₄.
\v 6 Tsá₃ 'éi₂ ma₃chan₂ ja₁lá₃; ma₂ca₂jein'₅₄ bá₄ táng₃ juɨ₁lia'₂ lë́₅ ca₂juá'₂ 'ŋiog₅. La₂ i₂jag₄ de'₂ 'nia'₂ ja₁jme₁rë₂quiain₂₃.
\v 7 O₂nó'₅ 'nia'₂ i₂ŋáu'₂ o₂chei'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ a₂ma₂ca₂jein'₅₄ táng₃ ne₄ 'mú₃; ma₂'ein₅₄ juɨ₅ ŋó₅ jŋiái₅ lia'₂ con'₂ guë́₄ 'nia'₂ juɨ₅ Galilea. Ja₁jaun₂ o₁jɨin'₄ 'nia'₂. Jág₁ në₅ ma₂në₂juɨ́g₂ 'nia'₂.
\p 
\v 8 Jaun₂ në́₃ ca₂'uɨn₂ 'io₅₄ i₂ŋáu'₂, të₃ ma₂gó'₅, ton'₂ jén'₅ rë'₂ 'io'₂ ján₃. Jaun₂ ca₂i₃lein₃ co₂chi'₅₄ i₁con₂ jág₁ ne₄ dsa₂ guia₃-tɨ́n₂.
\v 9 Të₃jë₄ i₂lein₃ jaun₂, con'₂ tsá₃ jáin₅ ca₂jme₃jnia₅ Jesús ne₅₄, ca₂juá'₂:
\p ―¡Siang'₃!
\p Jaun₂ në́₃ ca₂jme₃quiáin₃ con₂ Jesús, ca₂chi₃jné₃ ca₂jmo₃ i₁'áin₃ ca₂të₂ 'uë₃, ca₂quɨ́'₃ cu₅ tag₄ Jesús.
\v 10 Jesús në́₃ ca₂juá'₂:
\p ―Tsá₃ lë₁jmo₂ 'nia'₂ gang'₃. O₂nó'₅ 'nia'₂ o₂con₄ jág₁ ne₄ rɨ́ng'₃ o₂chei'₅₄ 'nia'₂ juɨ₁dsi₂lein₅ juɨ₅ Galilea, jaun₂ ja₁jaun₂ jág₂ jniá₂.
\s1 Jág₁ a₂ca₂dsia₃ 'lióg₂
\p 
\v 11 Të₁lia'₂ i₃len₃ 'io₅₄ 'éi₂ i₂con₃ jág₁, i₂lɨn₅₄ 'lióg₂ i₂jme₁jmo₅ 'í₁ i₃lein₃ jë₄ juɨg₂ i₁con₂ jág₁ ne₄ juɨg₅₄ jme₂dsa₂ ca₂i₁jua'₄ ca₂le₃jë́₃ 'a₂ lia'₂ niog₅ ca₂lë₃.
\v 12 Juɨg₅₄ jme₂dsa₂ në́₃ ca₂ŋɨi'₂ quian'₅₄ gui'₅₄ can'₅₄ ca₂jmo₃ jág₁, jaun₂ ca₂cuë́'₃ 'lióng₂ cu₄ 'lióg₂ 'éi₂,
\v 13 ca₂juá'₂:
\p ―Le₂la₂ dsiá'₁ 'nia'₂ juɨg'₅₄ dsa₂: të₁lia'₂ jme₁rë₂güɨ́n'₃ 'nia'₂ a₂'uë₂ ca₂dsi₃lén₂ dsa₂ i₂jme₁quiain'₅₄, jaun₂ ca₂tág₃ 'lag₄.
\v 14 Në₁jua'₂ ca₂rë₃ŋi₅ dsi₄má'₂ jág₁ në₅, la₂ bá₄ ne₄ jnia'₅₄ 'a₂ lia'₂ jme₁'uan₅₄ dsɨ́₅ ia₁jaun₂ tsá₃ cán'₁ 'nia'₂ o₂i₁ dsɨ₅.
\v 15 Jaun₂ ca₂gue₃ bá₄ 'lióg₂ cu₄, jaun₂ le₂jaun₂ bá₄ ca₂jmo₃ con'₂ lë́₅ jág₁ ca₂to'₂ dsa₂ 'éi₂. Jaun₂ le₂në₅ bá₄ jág₁ 'ei₅ ca₂le₂con₂ le₁ŋi₅ dsa₂ judíos ca₂të₂ jmɨg₄ në₃.
\s1 Ca₂chen₃ Jesús chi'₂ dsɨ₂guia₃-tɨ́n₂ a₂dsɨ₃'ë́₃ jág₁
\r (Marcos 16:14-18; Lucas 24:36-49; Juan 20:19-23; Hechos 1:6-8)
\p 
\v 16 Jaun₂ në́₃ i₃len₃ bá₄ ta₁guia₃-ján₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ juɨ₅ Galilea, ca₂i₃léin₂ ja₁lë́₄ caun₂ má'₂, lia'₂ con'₂ lë́₅ ma₂ca₂juá'₂ Jesús le₂jŋiá₅.
\v 17 Jaun₂ dsɨ₂juɨ₅ jme₁ca₂jɨ́in₂ Jesús, ca₂chi₃jné₃ ca₂jmo₃ i₁'áin₃, la₁ i₂lɨn₅₄ në́₃ tsá₃ caun₂ jme₁ma₂le₁'ág₄ dsɨ́₅.
\v 18 Jaun₂ ca₂jme₃quián₂ Jesús ja₁tióin₂, jaun₂ ca₂juá'₂:
\p ―Ca₂le₃jë́₃ bí₂ 'éi'₃ lia'₂ guei'₅₄ i₂juɨ́g₃ lia'₂ ne₄ gua'₅₄ 'uë₃ në́₃ ma₂ca₂ŋɨg₂.
\v 19 Jaun₂ lë₃, o₂nó'₅ 'nia'₂ në́₃ ca₂le₂con₂ mɨ₂güɨ́g₃, o₂jme₁tɨn₅ 'nia'₂ dsa₂ a₂léin₂ dsa₂ quiáng₃, o₂qui₂o₂chon₄ 'nia'₂ dsa₂ jmɨg₂, lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ Ŋe'₃, quian'₅₄ lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ Ja₁ŋi'₅₄,\f + \fr 28:19 \ft 'Nio'₂ ja₁ton₅ Romanos 6:3; 1 Corintios 1:13; Gálatas 3:27.\f* quian'₅₄ lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ Jme₂dsí₂ Jŋió₅,
\v 20 o₂jme₁tɨin₅ 'nia'₂ a₂nag₃ gau₂ ca₂le₃jë́₃ 'éi'₃ a₂ma₂cuë́₃ jniá₂ 'nia'₂. Jaun₂ ŋi'₅₄ 'nia'₂ në́₃, la₂ bá₄ 'eng₅₄ quian'₅₄ 'nia'₂ ca₂le₃jë́₃ jmɨg₄, ca₂lia'₂ ca₂'ŋia₅ jmɨg₄ jë₁ca₂tó'₂.
\p Co₂në₅.
