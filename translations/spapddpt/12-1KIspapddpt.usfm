\v 15 \w Así|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* \w no|strong="H3808"\w* hizo caso \w al|strong="H4428"\w* \w pueblo|strong="H5971"\w*, \w porque|strong="H3588"\w* \w esto|strong="H1697"\w* \w estaba|strong="H1961"\w* dispuesto \w de|strong="H3588"\w* parte \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* cumpliera \w la|strong="H3588"\w* \w Palabra|strong="H1697"\w* \w que|strong="H3588"\w* \w habló|strong="H1696"\w* \w por|strong="H3588"\w* \w medio|strong="H3027"\w* \w de|strong="H3588"\w* \w Ahías|strong="H3379"\w* \w silonita|strong="H7888"\w* \w a|strong="H3068"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Nabat|strong="H5028"\w*.
\p 
\v 16 \w Cuando|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w no|strong="H3808"\w* \w los|strong="H1121"\w* \w escuchó|strong="H8085"\w*, \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* le \w respondió|strong="H7725"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ¿\w Qué|strong="H3588"\w* \w parte|strong="H2506"\w* tenemos \w nosotros|strong="H3605"\w* \w con|strong="H3588"\w* \w David|strong="H1732"\w*? ¡\w No|strong="H3808"\w* tenemos \w heredad|strong="H5159"\w* \w con|strong="H3588"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Isaí|strong="H3448"\w*! ¡\w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* tus tiendas! ¡\w Ahora|strong="H6258"\w* ten cuidado \w de|strong="H3588"\w* tu propia \w casa|strong="H1004"\w*, \w David|strong="H1732"\w*! \w E|strong="H3068"\w* \w Israel|strong="H3478"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* sus tiendas.
\p 
\v 17 Pero \w en|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w que|strong="H5921"\w* \w vivían|strong="H3427"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w Roboam|strong="H7346"\w* siguió reinando \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.
