\v 22 \wj Estableceré con \+w ellos|strong="H3605"\+w* una sola \+w nación|strong="H1471"\+w* \+w en|strong="H5750"\+w* \+w la|strong="H3605"\+w* tierra, \+w en|strong="H5750"\+w* las montañas \+w de|strong="H5750"\+w* \+w Israel|strong="H3478"\+w*. \+w Habrá|strong="H1961"\+w* un \+w rey|strong="H4428"\+w* \+w para|strong="H1961"\+w* \+w todos|strong="H3605"\+w* \+w ellos|strong="H3605"\+w*. \+w Ya|strong="H3068"\+w* \+w no|strong="H3808"\+w* \+w serán|strong="H1961"\+w* \+w dos|strong="H8147"\+w* \+w naciones|strong="H1471"\+w*, \+w ni|strong="H3808"\+w* \+w estarán|strong="H1961"\+w* divididos \+w en|strong="H5750"\+w* \+w dos|strong="H8147"\+w* \+w reinos|strong="H4467"\+w*.\wj*  
\v 23 \wj \+w Ya|strong="H3068"\+w* \+w no|strong="H3808"\+w* \+w se|strong="H1961"\+w* contaminarán con sus \+w ídolos|strong="H1544"\+w*, sus repugnancias, \+w ni|strong="H3808"\+w* \+w cualquiera|strong="H3605"\+w* \+w de|strong="H5750"\+w* sus transgresiones. \+w Los|strong="H3605"\+w* \+w salvaré|strong="H3467"\+w* \+w de|strong="H5750"\+w* \+w todas|strong="H3605"\+w* sus transgresiones con las cuales \+w pecaron|strong="H2398"\+w*. Yo \+w los|strong="H3605"\+w* purificaré. \+w Serán|strong="H1961"\+w* \+w mi|strong="H1961"\+w* \+w pueblo|strong="H5971"\+w*, y Yo \+w seré|strong="H1961"\+w* su \+nd ʼElohim\+nd*.\wj*   
\p
\v 24 \wj \+w Mi|strong="H5921"\+w* esclavo \+w David|strong="H1732"\+w* \+w será|strong="H1961"\+w* su \+w rey|strong="H4428"\+w*, \+w y|strong="H5921"\+w* \+w todos|strong="H3605"\+w* \+w ellos|strong="H5921"\+w* \+w tendrán|strong="H1961"\+w* un solo \+w pastor|strong="H7462"\+w*. Vivirán \+w según|strong="H5921"\+w* mis Preceptos, observarán mis \+w Estatutos|strong="H2708"\+w* \+w y|strong="H5921"\+w* \+w los|strong="H5921"\+w* practicarán.\wj*  
