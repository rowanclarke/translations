\id NAM
\h عَننَبِ نَشُمُ
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ نَشُمُ بّ
\toc2 عَننَبِ نَشُمُ
\toc3 نَش
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ نَشُمُ بّ
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip عَسِرِيَ شَ مَنفّيَ نُ بَرَ سّنبّ سْتْ حّ كّمّ سٌلٌمَسَشَن بٍينُ عَننَبِ عِسَ شَ بَرِ عِسِرَيِلَ بْشِ مَ تّمُي نَشّ. نَ وَشَتِ حَمَنّ بِرِن نُ نَ عَ شَ يَامَرِ شْرْشْي بُن مَ. نِنٍوٍ نُ قِندِشِ عَ شَ مَنفَتَا نَن نَ. عَسِرِيَكَيٍ مُ نُ بِرَ مَ عَلَتَلَ شَ سّرِيّ قْشْ رَ قٍقٍ مَ.
\ip نَ كُي عَننَبِ نَشُمُ عِسِرَيِلَكَ نَشَ يِ مَسٍنيِ تِ عٍ شَ قٍ رَ. مَسٍنيِ نَ عَ رَ نَشَن شْرْشْ، بَرِ مَ عٍ شَ قٍ مُ نُ رَقَنشِ عَلَ مَ. عَننَبِ نَشُمُ تٌ فّ عَلَ شَ سّنبّ مَفَاشُشِ مَسٍندٍ عَسِرِيَكَيٍ بّ، عَ نَشَ عَ قَلَ عٍ بّ عٍ قَمَ فبَلٌي حَاشِ سْتْدٍ عٍ شَ يُنُبِيٍ شَ قٍ رَ. نَ كِيتِ نُ قَتَنشِ عَلَ نَن نَ. عَلَ نَشَ بَبِلْنكَيٍ شّي نِنٍوٍ كَنَدٍ حّ كّمّ سٍننِ بٍينُ عَننَبِ عِسَ شَ وَشَتِ.
\ip نَ مَسٍنيِ نُ شْرْشْ عَسِرِيَكَيٍ بّ، كْنْ عَ نُ قِندِشِ قٍ قَنيِ نَن نَ عِسِرَيِلَكَيٍ بّ، نَشٍيٍ نُ تْورْ مَ عٍ يَشُييٍ شَ يَامَرِ بُن مَ. عَننَبِ نَشُمُ نَشَ عَ مَسٍن عٍ بّ عَ يُنُبِتْييٍ قَمَ عٍ شَ كٌبِحَ سَرٍ سْتْدٍ عَلَتَلَ يِ رَ. عَلَ شَ كِيتِ شْرْشْي عَسِرِيَكَيٍ بّ، عَ نُ لِمَنِيَ قِمَ عِسِرَيِلَكَيٍ مَ.
\ip هَلِ تٌ، عَلَ شَ حَمَ نْمَ سّيوَدٍ نَ شَ قٍ رَ. عٍ شَ عَ كٌلٌن عَلَتَلَ قَمَ مِشِ حَاشِيٍ مَكِيتِدٍ، عَ قَ عٍ سَرٍ رَفبِلٍن عٍ مَ. وٌن بِرِن عَ كٌلٌن تِنشِنيِ قَن، كْنْ عَ نْمَ لُدٍ وٌن بّ عَلْ تِنشِنتَرٍيَ نَ سْونّيَقٍ يِ دُنِحَ كُي، بَرِ مَ قٍ حَاشِ فبٌ، تِنشِنتْييٍ قَن نَ تْورْقٍ. يِ كِتَابُي عَ مَسٍنمَ وٌن بّ تِنشِنتَرٍ مُ فٍينِمَ، عَلَتَلَ شَ تِنشِنيِ نَن مِشِ فٍينِمَ دُنِحَ بّندّ قُحِ قَرِ نُن عَلِفِيَمَ. عَلَ شَ مِشِ بِرِن مَكِيتِ عَ شَ سّرِيّ رَ. عَمِنَ.
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ نَشُمُ بّ
\c 1
\s1 عَلَ شَ شْنّ نِنٍوٍ شِلِ مَ
\p 
\v 1 مَسٍنيِ شْرْشْي نَن يَ نِنٍوٍ شَ قٍ رَ، عَلَ نَشَن مَسٍن عَننَبِ نَشُمُ عٍلٍكٌسِكَ بّ.
\q1 عَلَتَلَ مَفَاشُ، عَ فبٍحْشْقٍ مُ كَنَمَ.
\q1 
\v 2 عَلَتَلَ عَ فبٍحْشْمَ نّ،
\q1 عَ شَ شْنّ سّنبّ فبٌ عَ يَشُييٍ مَبِرِ،
\q1 عَ مُ دِحّمَ عٍ مَ مَقُرٍن مَقُرٍن.
\b
\q1 
\v 3 كْنْ عَلَتَلَ مُ شْنْمَ مَقُرٍن مَقُرٍن،
\q1 عَ سّنبّ فبٌ هَن.
\q1 عَلَتَلَ مِشِ حَاشِ سَرٍ رَفبِلٍنمَ نّ قٍ حَاشِ رَبَيٍ مَ.
\q1 عَ شَ حّرّ لُمَ نّ عَلْ تُرُننَادّ نَشَن شُبٍ رَتٍمَ،
\q1 عَ تِشِ نُشُييٍ قَرِ.
\q1 
\v 4 عَ نَ شَاحّ بَا مَ، عَ شْرِ مَ نّ،
\q1 عَ شُرٍ بِرِن نَشَرَ،
\q1 عَ بَسَن نُن كَرٍ مٍلٍ قِندِ فبٍنفبٍرٍنيِ رَ،
\q1 عَ لِبَن سَنسِيٍ لِسِمَ نّ.
\q1 
\v 5 عَ فٍيَيٍ رَ سّرّنمَ نّ، عٍ شُنُ عَلْ كُمِ تُرٍ.
\q1 بْشِ سّرّنمَ نّ عَ يَ عِ،
\q1 دُنِحَ مِشِيٍ بْحّ مِنِمَ نّ.
\q1 
\v 6 ندٍ نْمَ تِدٍ عَ شَ شْنّ يَ رَ؟
\q1 ندٍ نْمَ تِدٍ عَ شَ بْحّتٍ يَ عِ؟
\q1 عَ شَ شْنّ لُمَ نّ عَلْ تّ، نَشَن فّمّيٍ بُلَمَ.
\q1 
\v 7 عَلَتَلَ قَن، عَ كَنتَرِ قِمَ نّ تْورْ مِشِيٍ مَ،
\q1 عَ مّينِمَ نّ مِشِيٍ مَ نَشٍيٍ عٍ يّتّ تَشُمَ عَ رَ.
\q1 
\v 8 كْنْ عَ نِنٍوٍ شُن نَكَنَمَ نّ،
\q1 عَ عَ يَشُييٍ كٍرِ مَ دِ مِ نَن كُي.
\b
\q1 
\v 9 نِنٍوٍ، وٌ قّيرّ مُندُن قٍنقٍ عَلَتَلَ شِلِ مَ؟
\q1 عَ تَن نَن سْنتْي تِمَ كٍرٍنيِ رَ.
\q1 
\v 10 عٍ قَمَ نّ لُدٍ عَلْ عٍ كَنكَنشِ تُنبٍ كُنسِيٍ نَن نَ،
\q1 عَلْ عٍ سِيسِشِ بٍيرٍ نَن نَ،
\q1 عَلْ سّشّ شَرَشِ نَشَن فَنشِ قٍوٌ.
\q1 
\v 11 نِنٍوٍكَ ندٍ بَرَ قٍ حَاشِ رَبَ عَلَتَلَ رَ،
\q1 عَ مِشِيٍ رَ سِشِ قٍ كٌبِ نَن مَ.
\b
\q1 
\v 12 عَلَ شَ مَسٍنيِ نَن يَ عٍ شَ قٍ رَ؛
\q1 «هَلِ وٌ يَشُييٍ وُيَ، عٍ شُن قَمَ نّ رَكَنَدٍ، عٍ حْن.
\q1 ﭑ بَرَ وٌ تَن يُدَيَكَيٍ تْورْ،
\q1 كْنْ ﭑ مُ نَ رَبَمَ سْنْن.
\q1 
\v 13 يَكْسِ ﭑ وٌ بَمَ نّ وٌ يَشُييٍ شَ نْي بُن مَ،
\q1 ﭑ لُوتِيٍ بٌلٌن وٌ شِرِشِ نَشٍيٍ رَ.»
\b
\q1 
\v 14 عَلَتَلَ شَ مَسٍنيِ نَن يَ وٌ تَن نِنٍوٍكَيٍ شَ قٍ رَ؛
\q1 «وٌ بْنسْي قَمَ نّ حْندٍ.
\q1 ﭑ وٌ شَ كُيٍ مَسٌلِشِيٍ نُن وٌ شَ كُيٍ نَشٍيٍ يَءِلَنشِ وُرٍ رَ،
\q1 نَشٍيٍ نَ وٌ شَ عَلَيٍ شَ بَنشِيٍ كُي،
\q1 ﭑ نٍيٍ بِرِن كَنَمَ نّ.
\q1 ﭑ وٌ سْنتْمَ نّ، بَرِ مَ وٌ حَاشُ.»
\c 2
\s1 نِنٍوٍ شَ حَشَنكَتّ
\q1 
\v 1 شّيرَ نَ قَقٍ فٍيَيٍ قَرِ،
\q1 عَ قَقٍ شِبَارُي قَنيِ رَ وٌ بّ،
\q1 عَ بْحّسَ مَسٍنيِ نَن تِمَ وٌ بّ.
\q1 يُدَيَكَيٍ، وٌ شَ وٌ شَ سَلِيٍ رَبَ،
\q1 وٌ شَ وٌ شَ لَايِدِيٍ رَكَمَلِ عَلَ بّ،
\q1 بَرِ مَ مِشِ حَاشِيٍ مُ قَمَ وٌ سْنتْدٍ سْنْن.
\b
\q1 
\v 2 نِنٍوٍكَيٍ، وٌ يَشُييٍ نَ قَقٍ وٌ شِلِ مَ.
\q1 وٌ وٌ شَ تّتّ مَكَنتَ،
\q1 وٌ مّينِ وٌ شَ كِرَ مَ،
\q1 وٌ وٌ تَفِ عِشِرِ،
\q1 وٌ شَ لِمَنِيَ، وٌ شَ سّنبّ سْتْ،
\q1 
\v 3 بَرِ مَ عَلَتَلَ قَمَ نّ يَشُبَ شُن نَكٍلِدٍ،
\q1 عَ قَمَ نّ عِسِرَيِلَ عِتٍدٍ،
\q1 هَلِ كَسَرّ تٌ تِ عٍ شَ بْشِ مَ، عٍ شَ سَنسِيٍ نَشَ تُشُنسَن.
\b
\q1 
\v 4 وٌ يَشُييٍ شَ سْورِيٍ نَ وُرٍ لٍقَيٍ فبٍيلِشِ شَنِنقٍ،
\q1 دٌنمَ فبٍيلِ رَفٌرٌشِ عٍ مَ.
\q1 عٍ شَ سْورِ رَفِسٍيٍ يَنبَمَ عَ قَنيِ رَ،
\q1 عٍ شَ تَنبّيٍ شَاحّشِ فٍرٍ شِلِ مَ.
\q1 
\v 5 نَ فِسٍيٍ عٍ فِمَ كِرَيٍ رَ،
\q1 عٍ فبَتَشِ سٌقٍ رَ فٍرٍ كُي.
\q1 عٍ لُشِ عَلْ سٍيَمَكْنيِ نَشَن دَنفِمَ كٌورٍ رَ.
\b
\q1 
\v 6 سْورِ سُفَندِشِيٍ شّيمَ نَا،
\q1 عٍ شُلُن سِفَقٍ رَ تَا تّتّ يِرٍ، عٍ سَ فٍرٍ سٌ.
\q1 
\v 7 عٍ مَنفّ شَ بَنشِ نَادّ رَبِ، عٍ بِرِن سٌ نَ كُي.
\q1 
\v 8 يَامَرِ قِشِ تَاكَيٍ شَ شَنِن كٌنيِيَ كُي.
\q1 عَ شَ فِنّيٍ سِفَمَ نّ وَ رَ سُننُنيِ كُي.
\q1 
\v 9 نِنٍوٍ بَرَ لُ عَلْ يٍ رَفَتَدٍ عِبْوشِ،
\q1 عَ يٍ قَ مِنِ بْشِ مَ.
\q1 ندٍ عَ قَلَمَ، «وٌ بَ نَ رَبَقٍ، وٌ كٍلِ نَا.»
\q1 كْنْ مِشِ يٌ مُ فبِلٍنمَ نَ قْشْ رَ.
\q1 
\v 10 بٌورٍيٍ عَ قَلَمَ، «وٌ فبٍتِ نُن شّيمَ تٌنفٌ.
\q1 نَاقُلِ فبٍفبٍ نَ عٍ يِ رَ.»
\q1 
\v 11 كَسَرّ، تُشُنسَنيِ، نُن فبَلٌي!
\q1 لِمَنِيَ بَرَ بَ عٍ يِ رَ،
\q1 عٍ سَنيِيٍ مُ شَنقٍ عٍ بُن مَ،
\q1 عٍ بْحّ نَ تْورْقٍ،
\q1 عٍ لَهَلّ بَرَ مَسَرَ.
\b
\q1 
\v 12 تَا سّنبّمَ نَشَن نُ لُشِ عَلْ يّتّ لُدٍ،
\q1 يّتّ يْرّيٍ نُن عٍ نفَ نُ مَلَبُشِ شَشِلِسَ كُي دّننَشّ،
\q1 نَ تَا مُنسٍ سْتْشِ يِ كِ؟
\q1 
\v 13 نَ يّتّ سّنبّمَ نُ سُبٍ قَشَمَ عَ شَ فِنّ نُن عَ شَ دِيٍ بّ،
\q1 عَ نُ عَ شْنيِ رَقٍمَ سُبٍ عِبْوشِ رَ.
\b
\q1 
\v 14 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن يَ؛
\q1 «ﭑ كٍلِمَ نّ وٌ شِلِ مَ،
\q1 ﭑ وٌ شَ سْورِ رَفِسٍيٍ فَنمَ نّ،
\q1 ﭑ وٌ شَ يّتّ يْرّيٍ قَشَمَ نّ سَنتِدّفّمَ رَ،
\q1 ﭑ سُبٍ بِرِن بَمَ نّ وٌ يِ رَ دُنِحَ.
\q1 وٌ شَ شّيرَيٍ شُي مُ مّمَ سْنْن.»
\c 3
\s1 نِنٍوٍ شَ حْنيِ
\q1 
\v 1 حَشَنكَتّ نَ يِ تَا قَشّتِ بّ،
\q1 نَشَن نَقٍشِ يَنقَنتٍيَ، سٍ مُحَشِيٍ، نُن تْورْ مِشِيٍ رَ.
\q1 
\v 2 لُشُسِنيِ شُي مِنِمَ نَا،
\q1 سْورِ رَفِسٍ سَنيِيٍ شُي مِنِمَ،
\q1 سٌييٍ عٍ فِمَ، سْورِ رَفِسٍ عٍ عِمَشَمَ.
\q1 
\v 3 سٌي رَفِيٍ فٍرٍ سٌمَ،
\q1 سَنتِدّفّمَ لِنتَنمَ عَلْ تّ لُوتِيٍ،
\q1 تَنبّ وٌلِمَ عَلْ سٍيَمَكْنيِيٍ،
\q1 مِشِ قَشَشِيٍ رَلَنتَنشِ يِرٍ بِرِن مَ،
\q1 قُرٍ سَشِيٍ مُ حْنمَ،
\q1 مِشِيٍ عٍ سَنيِ رَدِنمَ قُرٍيٍ رَ.
\q1 
\v 4 نَ بِرِن قَتَنشِ عَ شَ سّنِيّنتَرٍحَ نَن مَ.
\q1 عَ سِيٍ مَبّندُنمَ عَ شَ لَنفٌيحَ رَ،
\q1 عَ حَمَنّيٍ مَدَشُمَ عَ دُورٍيَ رَ.
\b
\q1 
\v 5 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن يَ؛
\q1 «ﭑ كٍلِمَ نّ وٌ شِلِ مَ،
\q1 ﭑ وٌ رَيَافِمَ نّ سِ بِرِن يَ شْرِ،
\q1 ﭑ وٌ مَفٍلِ تِ حَمَنّيٍ بِرِن يَ عِ.
\q1 
\v 6 ﭑ وٌ مَكٌتٌمَ نّ نْشْي رَ، ﭑ وٌ رَيَافِ.
\q1 
\v 7 نَ كُي، مِشِ يٌ نَ وٌ تٌ، عَ عَ فِمَ نّ وٌ مَ،
\q1 عَ قَ عَ قَلَ، ‹نِنٍوٍ بَرَ كَنَ.
\q1 ندٍ كِنِكِنِمَ عَ مَ؟
\q1 ندٍ عَ مَدُندُ مَ؟›»
\b
\q1 
\v 8 نِنٍوٍ، وٌ قِسَ تٍبٍسٍ بّ،
\q1 تَا نَشَن دْشْشِ نِلِ شُرٍ سَلٌنيِيٍ تَفِ،
\q1 يٍ فبٌ دّننَشّ؟
\q1 بَا نُ قِندِشِ عَ شَ تّتّ مَكَنتَشِ نَن نَ.
\q1 
\v 9 كُسِ نُن مِسِرَ نُ سّنبّ قِمَ نّ عَ مَ،
\q1 ثُتِ نُن لِبِيَ نُ عَ مَلِمَ.
\q1 
\v 10 كْنْ تٍبٍسٍ قَن بَرَ شَنِن كٌنيِيَ كُي حَمَنّ مَ،
\q1 عَ شَ دِيٍ بَرَ قَشَ كِرَ شُنيِيٍ رَ،
\q1 عَ شَ كُنتِفِيٍ بَرَ مَيٍفٍتِ سِفَقٍ رَ كٌنيِيَ كُي.
\q1 
\v 11 وٌ تَن دَفَلَنمَ نّ عَلْ سِيسِلَيٍ،
\q1 وٌ وٌ نْشُنمَ نّ وٌ يَشُييٍ يَ رَ.
\b
\q1 
\v 12 وٌ شَ بَنشِ مَكَنتَشِيٍ لُشِ نّ عَلْ شْرّ بِلِيٍ،
\q1 قٌيٍ نَشٍيٍ بٌفِ رَيٌلٌنمَ مِشِيٍ شَ دٍبٍ كُي نَشٍيٍ وَ مَ عٍ دٌنقٍ.
\q1 
\v 13 فِنّ دٌرٌ نَن قَ لُشِ وٌ شَ بْشِ مَ،
\q1 سْورِيٍ مُ نَ سْنْن نَشٍيٍ وٌ مَكَنتَمَ،
\q1 وٌ شَ نَادّيٍ رَبِشِ وٌ يَشُييٍ يَ رَ،
\q1 تّ بَرَ نَ بَلَنسٍيٍ فَن.
\b
\q1 
\v 14 وٌ يٍ بَ، بَرِ مَ فٍرٍ نَ قَقٍ،
\q1 وٌ ندٍ سَ وٌ شَ تّتّ قَرِ.
\q1 وٌ بٌورَ رَقَلَ، وٌ بِرِكِ بْنبْ.
\q1 
\v 15 مّننِ، تّ قَمَ نّ وٌ شَ تَا فَندٍ عَلْ تُفُمِيٍ،
\q1 سَنتِدّفّمَ قَمَ نّ وٌ سْنتْدٍ.
\q1 وٌ وٌ مَلَن عَلْ تُفُمِيٍ،
\q1 وٌ وٌ مَلَن عَلْ كَتٌي.
\q1 
\v 16 وٌ بَرَ يُلّيٍ رَوُيَ وٌ شْنيِ دَنفِقٍ تُنبُييٍ رَ كٌورٍ مَ.
\q1 وٌ بَرَ لُ عَلْ تُفُمِيٍ نَشٍيٍ تُفَنمَ، عٍ سِفَ.
\q1 
\v 17 وٌ شَ سْورِيٍ لُشِ نّ عَلْ تُفُمِ نَشٍيٍ نَ تّتّ قَرِ فّيسّفّ،
\q1 كْنْ سٌفٍ نَ تٍ، عٍ تُفَن،
\q1 عٍ سِفَ يِرٍ مِشِ مُ دّننَشّ كٌلٌن.
\b
\q1 
\v 18 عَسِرِيَ مَنفّ، عِ شَ يَرٍرَتِيٍ نَ شِقٍ،
\q1 عِ شَ كُنتِفِيٍ سَشِ،
\q1 عِ شَ حَمَ بَرَ يٍنسٍن يّ فٍيَيٍ قَرِ،
\q1 مِشِ يٌ مُ نْمَ عٍ شُنلَندٍ.
\q1 
\v 19 عِ شَ فبَلٌي فبٌ، عِ شَ قِ مُ يَلَنمَ.
\q1 مِشِ نَشٍيٍ بِرِن عِ شَ تْورّ شَ قٍ مّمَ،
\q1 عٍ عٍ بّلّشّ بْنبْمَ نّ حّلّشِنيِ مَ،
\q1 بَرِ مَ مِشِ يٌ مُ نَ وٌ مُ كٌبِحَ رَبَشِ نَشَن نَ.
