\id 1TH
\h PRIMERA TESALONICENSES
\toc1 Si₂ carta le₂'uɨg₅₄ a₂ca₂jmo₃ San Pablo ne₄ dsa₂ TESALONICENSES
\toc2 PRIMERA TESALONICENSES
\toc3 1 Ts.
\mt2 Si₂ carta le₂'uɨg₅₄ a₂ca₂jmo₃ San Pablo ne₄ dsa₂
\mt1 TESALONICENSES
\c 1
\s1 Pablo quiain'₅₄ rɨin'₅₄ jmo₂₃ si₂ a₂chein₃ ne₄ Guá'₅ i₂chan₂ juɨg₂ Tesalónica
\p 
\v 1 Jniá₂ Pa₄, quian'₅₄ Silvano,\f + \fr 1:1 \ft Lia'₂ chen₂ Silvano, co₂rë₂ quian'₅₄ Silas.\f* Timoteo në́₃, jmo₂₃ si₂ la₂ a₂dsiang'₅₄ ne₄ dsa₂ i₂ma₂'én₂ le₃quió'₅ Jesús, i₂chan₂ juɨg₂ Tesalónica, dsa₂ i₂'ei₅ caun₂ jág₁ quian'₅₄ Diú₄, quian'₅₄ Te₁gui'₅₄ Jesucristo në́₃. Juɨ₁jme₂gu'₅₄ Diú₄ 'nia'₂. Juɨ₁'ei₅ bá₄ tei₄ tion'₅₄ 'nia'₂ quian'₅₄ 'éi'₃ quió'₅ Diú₄ Jmei₂ jniog₄, quian'₅₄ 'éi'₃ quió'₅ Te₁gui'₅₄ Jesucristo në́₃.
\s1 Cha₂ léi₄ ja₁con₂ dsa₂ chan₂ Tesalónica ia₁ a₂'éin₂
\p 
\v 2 Ca₂le₃jë́₃ jmɨg₄ bá₄ cuë₂ jnia'₅₄ ti₁'mag'₄ Diú₄ o₄quián'₂ 'nia'₂ ca₂le₃jɨ́ng'₃. Jë₁ma₂të́₂ rë₁chi₁len'₄ jnia'₅₄ Diú₄, dsau'₂ bá₄ dsɨ₅ jnia'₅₄ 'nia'₂.
\v 3 Dsau'₂ bá₄ dsɨ₅ jnia'₅₄ 'nia'₂ ne₄ Diú₄ Jmei₂ jniog₄, ia₁ 'ŋio₅ lɨn₃ ma₂jmo'₅₄ 'nia'₂ ta₁ cha₂ léi₄ ja₁con'₂ 'nia'₂ ia₁ 'éng'₂, ia₁ 'ŋio₅ lɨn₃ jme₂ti'₅₄ 'nia'₂ ta₁ ne₄ Te₁gui'₅₄ 'uɨg₅₄ ia₁ a₂'niói'₃ 'nia'₂. Jaun₂ caun₂ bá₄ le₁'ág₄ 'au'₂ 'nia'₂ a₂'ɨ́n₂ 'au'₂ le₃quió'₅ Te₁gui'₅₄ Jesucristo quián₂ jniog₄.
\v 4 Rɨn'₅₄ jniog₄, 'nio₃ bá₄ Diú₄ 'nia'₂, ne₄ bá₄ jnia'₅₄ a₂ma₂quióin'₂ 'nia'₂.
\v 5 Lia'₂ con'₂ jme₁ca₂jme₁tɨn₅ jnia'₅₄ 'nia'₂ jág₁ dse₃, on₃jua'₅₄ jmá'₃ quian'₅₄ jág₁ jaun₂ jme₁né₄. Ia₁ jme₁quian'₅₄ bá₄ juɨ₅bí₂ quió'₅ Jme₂dsí₂ Jŋió₅ ján₃, ca₂'ë́₄ jág₁ dse₃ la₂ jɨn'₄ 'nia'₂. Jaun₂ caun₂ bá₄ 'ei₅ dsɨ₅ jnia'₅₄ ia₁ Jme₂dsí₂ Jŋió₅ bá₄ jmo₃ jme₃'uá₂ 'au'₂ 'nia'₂ a₂le₃'éng'₂. Ŋi'₅₄ bá₄ 'nia'₂ dse₃ 'a₂ lia'₂ ca₂tió'₄ jnia'₅₄ jɨn'₄ 'nia'₂ a₂dse₃ quián'₂ bá₄ 'nia'₂ jaun₂.
\p 
\v 6 'Nia'₂ në́₃, ca₂quian'₂ 'nia'₂ juɨ₅ a₂ca₂quián₁ jnia'₅₄, a₂ca₂can₃ Te₁gui'₅₄ në́₃. Ca₂gue'₅₄ bá₄ 'nia'₂ a₂'ŋio₂ 'au'₂ jág₁ dse₃. Chan'₂ bá₄ 'nia'₂ o₂'ŋió₃ o₂jŋia₃ 'au'₂ a₂jmo₅ Jme₂dsí₂ quián₅ Diú₄, tsá₃ a₂nag₅₄ jaun₂ ca₂quɨ́n₂ a₂ca₂i₃ŋɨ́'₂ 'nia'₂ uɨg₅ 'ŋio₅ lɨn₃ 'uɨg₅₄ jág₁ dse₃.
\v 7 Jaun₂ le₂në₅ bá₄ ca₂dsi₃nó'₅ 'nia'₂ ca₂cuë'₅₄ 'nia'₂ caun₂ juɨ₅ dse₃ jaun₂ ca₂cáun₃ 'í₁ ca₂le₃jɨ́n₃ dsa₂ i₂'én₂ le₂tan₅₄ juɨg₂ te₁'i₁ 'uë₃ Macedonia quian'₅₄ le₂tan₅₄ 'uë₃ Acaya në́₃.
\v 8 Jaun₂ le₂në₅ ma₂ca₂'ë'₅₄ 'nia'₂ dsa₂ jág₁ dse₃ quió'₅ Te₁gui'₅₄, on₃jua'₅₄ jmá'₃ dsa₂ chan₂ Macedonia quian'₅₄ Acaya ma₂qui₂ma₂'ë'₅₄ 'nia'₂ jág₁, ia₁ ca₂le₂con₂ ja₁siá'₂ bá₄ ján₃ le₁ŋi₅ dsa₂ a₂lɨ́n'₂ 'nia'₂ dsa₂ i₂'én₂ quián₅ Diú₄. Jaun₂ tsá₃ ma₃'e₂ jua'₅₄ 'nió'₅ guë́₄ chei₅₄ jnia'₅₄ 'i₁caun₂ 'nia'₂.
\v 9 Të₂le₃ dsia₅ bá₄ 'éi₂ guioin₅₄ a₂ca₂guei'₅₄ 'nia'₂ dse₃ jnia'₅₄, dsia₂₃ 'a₂ lia'₂ ca₂tí'₃ a₂jme₁'éng'₂ të₂le₃ quió'₅ diú₄ lag₄, a₂ca₂rë₃'én'₂ 'nia'₂ të₂le₃ quió'₅ Te₁gui'₅₄, ca₂jme₁ti'₄ ne₄ Diú₄ jén'₃ dsón'₂ i₂chan₂.
\v 10 Dsia₂₃ bá₄ ján₃ 'a₂ lia'₂ tion'₅₄ 'nia'₂ le₁jan'₄ a₂jŋió'₂ táng₃ juɨ₅ guei'₅₄ i₂juɨ́g₃ Jesús Ja₁ŋi'₅₄ Diú₄ i₂ca₂jme₃jein'₅₄ jɨn₄ 'lag₄. I₂'éi₂ bá₄ lió₂ jniog₄ ne₄ a₂'i₄ 'nei₂ dsɨ́₅ Diú₄.
\c 2
\s1 Ta₁ a₂ca₂jmo₃ Pablo juɨg₂ Tesalónica
\p 
\v 1 Ia₁ ŋi'₅₄ bá₄ 'nia'₂ guiong'₅₄, rɨn'₅₄ jniog₄, tsá₃ jua'₅₄ a₂lë₁ca₂i₁náu₄ jnia'₅₄ ca₂i₁jɨn₁ 'nia'₂.
\v 2 Ia₁ ma₂ŋi'₅₄ bá₄ 'nia'₂, të₂le₃ ca₂jme₃'o₅₄ bá₄ Diú₄ ca₂nio₃ tiá₂ dsɨ₅, ca₂'ë́₄ jnia'₅₄ ja₁con'₂ 'nia'₂ jág₁ dse₃ a₂lión₂ dsa₂, o₁jŋia'₅₄ ca₂jmóg'₂ dsa₂ ca₂të₂ca₂'o'₂ juɨg₂ Filipos le₂jŋiá₅.
\v 3 Ia₁ jág₁ a₂ca₂tion'₅₄ jnia'₅₄ 'nia'₂, on₃jua'₅₄ a₂já₃ 'uɨg₅₄ ia₁ a₂i₂gon₂ jnia'₅₄, on₃ guë'₂ o₄quió'₄ ia₁ a₂dsɨ₂jŋia₅ dsɨ₅ a₂'lɨg'₅₄, on₃ guë'₂ jua'₅₄ ia₁ a₂jme₂gán₁ jnia'₅₄ 'nia'₂.
\v 4 Të₂le₃ ia₁ Diú₄ bá₄ ca₂cáun₃ 'í₁ a₂jmo₂ jnia'₅₄, ca₂dsia₃ gu₂ jnia'₅₄ a₂qui₁'ë́₄ jág₁ dse₃. Jaun₂ le₂në₅ juɨ₁lia'₂ jág₁ a₂jua'₂ jnia'₅₄, on₃jua'₅₄ a₂jua'₂ ia₁jaun₂ 'ŋio₂ dsɨ́₅ dsa₂ mɨ₂güɨ́g₃, të₂le₃ ia₁jaun₂ 'ŋio₂ dsɨ́₅ Diú₄ bá₄ i₂con₂ 'í₁ të₂dsɨ₅ jniog₄.
\v 5 Ŋi'₅₄ bá₄ 'nia'₂, 'i₁cón'₂ tsá₃ jua'₅₄ ca₂dsiá₁ jnia'₅₄ jág₁ rau₂, on₃ guë'₂ jua'₅₄ ca₂'má₂ jnia'₅₄ jág₁ a₂tsá₃ dsi₂ten₅₄ 'má₂ ia₁jaun₂ léi₂ cu₄. Jág₅ bá₄ Diú₄ ca₂le₃jë́₃ a₂ca₂jmó₁.
\v 6 Tsá₃ a₂jaun₂ 'niog₂ jnia'₅₄ jua'₅₄ a₂jme₃juag'₂ dsa₂ 'ŋio₅ lɨn₃, on₃ guë'₂ 'nia'₂, on₃ guë'₂ dsa₂ sián'₂ në́₃, o₁jŋia'₅₄ jme₁ca₂tág₂ rë'₂ jnia'₅₄ jmó₁ 'éi'₃ jaun₂ ia₁ a₂lág₅ dsa₂ i₂chen₄ quián₅ Cristo.
\v 7 Të₂le₃ ca₂jmó₁ bá₄ jnia'₅₄ 'ua₁ dsɨ₅ ja₁con'₂ 'nia'₂, juɨ₁lia'₂ lɨ́n₅ jan₂ chog₅₄ chi'₂, a₂jme₂cain'₅₄ chi'₂ quiáin₅ qui₂jmo₂₃ 'í₁.
\v 8 Jaun₂ lë₃ 'ŋio₅ lɨn₃ ca₂rë₃'nio₃ jnia'₅₄ 'nia'₂, ca₂lia'₂ jŋia'₅₄ on₃jua'₅₄ jmá'₃ jág₁ dse₃ quió'₅ Diú₄ në₅ ca₂tág₂ jnia'₅₄ cuë́₁, le₂jiog₅ jme₂dsí₂ quián₂ jnia'₅₄ 'ŋio₂ dsɨ₅ cuë₁ ján₃. Ia₁ ma₂dsi₂nó'₅ 'nia'₂ léng'₂ dsa₂ i₂'nió₄ lɨn₃ quián₂ jnia'₅₄.
\v 9 Jua'₂ jnia'₅₄ le₂në₅, rɨn'₅₄ jniog₄, ia₁jaun₂ dsá₂ bá₄ 'au'₂ 'nia'₂ 'a₂ lia'₂ ca₂jmó₁ jnia'₅₄ ta₁ a₂ca₂lag₃ a₂que₅₄. Lia'₂ 'uë₂-jmɨ₂ bá₄ qui₂ca₂jmó₁ jnia'₅₄ ta₁, ia₁jaun₂ 'i₁jan'₂ 'nia'₂ tsá₃ jua'₅₄ 'ein₂ 'ŋio₅ guei₂ ca₂can₃ quian'₅₄ jnia'₅₄, të₁lia'₂ ca₂tió'₄ ca₂'ë́₄ jág₁ dse₃ quió'₅ Diú₄.
\p 
\v 10 Ca₂të́₂ bá₄ ne'₅₄ 'nia'₂, jág₅ bá₄ Diú₄ ján₃, ca₂tió'₄ jnia'₅₄ quian'₅₄ 'nia'₂ dsa₂ i₂'én₂, a₂lág₅ jnia'₅₄ dsa₂ jŋió₅, dsa₂ dsen₃, i₂tsá₃ 'ein₂ lé₂ le₃bóg'₂ dso₄.
\v 11 Ŋi'₅₄ bá₄ 'nia'₂ ján₃, ca₂jmó₁ jnia'₅₄ jɨn'₄ 'nia'₂ juɨ₁lia'₂ jmo₅ jan₂ jmei₂ dsa₂ jmái'₂ chi'₂ quiáin₅, qui₂ca₂cuë₅₄ jnia'₅₄ bí₂ 'nia'₂, ca₂tion'₅₄ jnia'₅₄ jág₁ 'nia'₂ jaun₂ náu'₁ tiá₂ juɨ₅ dse₃.
\v 12 Jaun₂ qui₂ma₂chei₅₄ bá₄ jnia'₅₄ 'nia'₂ a₂i₁niog'₄ lia'₂ con'₂ dsi₂ten₅₄ i₂nio₄ dsa₂ quián₅ Diú₄ i₂të́₂ a₂jme₁quiain'₄ 'nia'₂ ja₁jmo₂₃ 'éi'₃ guei'₅₄ i₂juɨ́g₃ ja₁lë́₄ co₂tág₅ co₂'né'₅ quió'₅.
\p 
\v 13 Jaun₂ lë₃, ca₂le₃jë́₃ jmɨg₄ bá₄ cuë₂ jnia'₅₄ ti₁'mag'₄ Diú₄. Ia₁ le₂'uɨg₅₄ jme₁ca₂nei'₂ 'nia'₂ jág₁ dse₃ quió'₅ Diú₄ a₂ca₂jua'₅₄ jnia'₅₄, ca₂gue'₅₄ bá₄ 'nia'₂ con'₂ lë́₅ jág₁ dse₃ quió'₅ Diú₄, on₃jua'₅₄ con'₂ lë́₅ jág₁ quió'₅ dsa₂ mɨ₂güɨ́g₃. Ia₁ dsón'₂ bá₄ jág₁ dse₃ quió'₅ Diú₄ në₅, a₂jmo₃ léi₄ të₂'au'₂ 'nia'₂ dsa₂ i₂'én₂.
\v 14 Rɨn'₅₄ jniog₄, lia'₂ con'₂ ca₂ŋag'₅₄ 'nia'₂ uɨg₅ qui₂ca₂'ein₃ dsa₂ go'₄ 'nia'₂, ca₂i₃ŋɨ́'₂ 'nia'₂ juɨ₁lia'₂ ca₂jmá'₂ dsa₂ guá'₅ quián₅ Diú₄ i₂tián'₅ Judea i₂ma₂lɨ́n₅ quián₅ Cristo Jesús. Le₂jaun₂ bá₄ ca₂qui₂co₂'ein₃ dsa₂ judíos dsa₂ go₅₄.
\v 15 Dsa₂ judíos 'éi₂ bá₄ i₂ca₂jŋɨ'₃ Te₁gui'₅₄ Jesús, i₂ca₂jme₃dsian₅ dsa₂ i₂chen₄ quián₅ Diú₄ në́₃. Jaun₂ ca₂'uág'₂ bá₄ jnia'₅₄. Tsá₃ 'nioi₃ Diú₄. 'Ŋiai₅₄ bá₄ ca₂le₃jɨ́n₃ dsa₂.
\v 16 Cha₂ jme₁lɨn₅₄ 'niog₂ jnia'₅₄ chei₅₄ jág₁ dsɨ₂nau₂, ia₁jaun₂ lión₂ 'éi₂ ján₃. La₁ 'éi₂ bá₄ jné₅ juɨ₅. Jaun₂ le₂në₅ caun₂ dsɨ₂juë'₂ bá₄ dsáu₁. Co₂ŋei'₅₄ ma₂já₅ a₂'i₄ 'nei₂ dsɨ́₅ Diú₄ ja₁coin₂.
\s1 Dsɨ₂jiog₅ dsɨ́₅ Pablo dsó₃ táng₃ juɨ₅ Tesalónica
\p 
\v 17 Rɨn'₅₄ jniog₄, lia'₂ con'₂ jme₁ca₂tén₄ co₂'na₂ rɨn'₅₄, o₁jŋia'₅₄ tsá₃ né₅ jnia'₅₄ 'nia'₂, la₁ tion₅₄ bá₄ jme₁dsau'₂ dsɨ₅ jnia'₅₄, 'ŋio₅ lɨn₃ jme₁'niog₂ jnia'₅₄ dsau₅₄ táng₃ dsɨ₁né₄ 'nia'₂.
\v 18 Jaun₂ dsón'₂ bá₄ jme₁'niog₂ jnia'₅₄ dsau₅₄ dsɨ₁jɨn₁ 'nia'₂. Jniá₂ Pa₄ 'lióng₂ ráun₂ jme₁ca₂quɨ́n'₃ bí₂ a₂nei₅₄. La₁ i₂së₃dsen₃ bá₄ ca₂jné₃ juɨ₅.
\v 19 Jaun₂ ¿'e₂ jaun₂ a₂'ɨ́n₂ dsɨ₅ jnia'₅₄ chong₂, a₂jmo₅ jnia'₅₄ 'io'₂, o₃ premio o₄quió'₄ a₂jmó₁ jnia'₅₄ táu'₅ jë₁ma₂të́₂ rë₁guan'₂ Jesús Te₁gui'₅₄ quián₂? ¿On₁jua'₅₄ o₄quián'₂ 'nia'₂ bá₄?
\v 20 'Uɨg₅₄ quián'₂ 'nia'₂ bá₄ ŋɨ́₄ 'io'₂ jein₅ jnia'₅₄; o₄quián'₂ 'nia'₂ bá₄ jme₂go₃ dsa₂ sián'₂ në́₃
\c 3
\p 
\v 1 Jaun₂ në́₃, ia₁ tsá₃ ma₃tián₂ jnia'₅₄, ca₂rë₃'ŋió₃ bá₄ dsɨ₅ jŋia₁ guio₅₄ juɨg₂ Atenas.
\v 2 Jaun₂ ca₂chen₅₄ jnia'₅₄ Timoteo rɨn'₅₄ ca₂i₁jɨin₁₂ 'nia'₂, ia₁ i₂ma₂lɨ́n₅ quián₅ Diú₄ bá₄ 'éi₂, ia₁ jmo₂₃ ta₁ co₂lë₅ quian'₅₄ jnia'₅₄ a₂jme₂tɨin₂₃ dsa₂ jág₁ dse₃ quió'₅ Cristo. Lé₂ le₃juá'₂ 'éi₂ lia'₂ tí₅ jág₁ cuë́'₃ bí₂ 'nia'₂ a₂le₃'én'₂ guë́₄ 'nia'₂,
\v 3 ia₁jaun₂ 'i₁jan'₂ 'nia'₂ tsá₃ dsɨ₃lén₂ cau₅ 'uɨg₅₄ a₂co₂'ein₅ dsa₂. Ia₁ ŋi'₅₄ bá₄ 'nia'₂ guiong'₅₄, 'éi'₃ në₅ tio'₅₄.
\v 4 Lia'₂ con'₂ jme₁tio'₅₄ jnia'₅₄ quian'₅₄ 'nia'₂ le₂jŋiá₅, ca₂jua'₅₄ jnia'₅₄ a₂tion₅₄ niog₅ ŋag₅₄ 'uɨg₅₄, jaun₂ le₂jaun₂ ca₂lë₃ në́₃, jaun₂ ma₂ŋi'₅₄ bá₄ 'nia'₂.
\v 5 Jaun₂ lë₃, ia₁ tsá₃ ma₃tió₅ 'ɨ₅ dsɨ₃, ca₂tsɨ́ng₂ dsa₂ ca₂i₁ŋag₁₂ 'a₂ lia'₂ lë́₅ ma₂'én'₂ 'nia'₂ tiong'₅₄, ia₁ con'₂ tsá₃ ŋó₅ në₁ca₂'liog'₃ i₂së₃dsen₃ a₂jmó'₂ 'nia'₂ cosa 'lɨg'₅₄. Tsá₃ ma₃ta₁ tí₄ ta₁ quián₂ jnia'₅₄, jua'₅₄ mei'₂ guë́₃ le₂jaun₂.
\p 
\v 6 La₁ ma₂guán'₅ bá₄ táng₃ Timoteo juɨg₂ Tesalónica, quion₂ jág₁ dse₃ 'én'₂ bá₄ 'nia'₂ jág₁ quió'₅ Diú₄, 'nió'₃ bá₄ 'nia'₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂. Juá'₂ bá₄ ján₃, jmo'₂ 'nia'₂ 'io'₂ a₂dsau'₂ 'au'₂ 'nia'₂ jnia'₅₄ ca₂le₃jë́₃ jmɨg₄, a₂'ɨ́n₅ 'au'₂ 'nia'₂ 'ŋio₅ lɨn₃ jag'₅₄ jnia'₅₄, le₂jaun₂ bá₄ jnia'₅₄ ján₃ juɨ₁lia'₂ 'nia'₂ 'ɨ́n₅ dsɨ₅ jɨn₄ 'nia'₂.
\v 7 Jaun₂ le₂në₅, rɨn'₅₄ jniog₄, të₃jë₄ uɨg₅ chong₂ 'ɨ₅ dsɨ₅ jnia'₅₄, la₁ ca₂'ág₂ lián'₂ dsɨ₅ jnia'₅₄ jme₁ca₂rë₃ne₄ 'a₂ lia'₂ lë́₅ a₂'én'₂ 'nia'₂.
\v 8 'Io'₂ jein₅ jnia'₅₄ chong₂ jme₁ca₂rë₃ne₄ tión'₂ bá₄ 'nia'₂ tiá₂ të₂le₃ quió'₅ Te₁gui'₅₄.
\v 9 Ca₂lia'₂ tsá₃ ne₄ jnia'₅₄ 'a₂ lia'₂ cuë₅₄ ti₁'mag'₄ Diú₄ con'₂ dsi₂ten₅₄ o₄quió'₄ a₂'io'₂ jmo₂ jnia'₅₄ le₃ne₄ Diú₄ quián₂ o₄quián'₂ 'nia'₂.
\v 10 Ca₂le₃jë́₃ dsɨ₅ bá₄ jnia'₅₄ mɨ₂ lia'₂ 'uë₂-jmɨ₂ ne₄ Diú₄ a₂cuë₃ jmɨg₄ dsɨ₁jɨn₁ 'nia'₂, jaun₂ jme₁'ŋia₅ guë́₄ jnia'₅₄ a₂'nió'₅ le₃tɨn'₂ guë́₄ 'nia'₂ a₂le₃'éng'₂.
\p 
\v 11 'Niog₂ jnia'₅₄, Diú₄ Jmei₂ 'ŋiog₅ quian'₅₄ Te₁gui'₅₄ Jesucristo, jme₃'o₅₄ cuë₃ jmɨg₄ dsi₁náu₅ dsi₁jɨng₅₄ 'nia'₂.
\v 12 Juɨ₁jmo₅₄ bá₄ Te₁gui'₅₄ juɨ₁dsi₂cón₃ a₂jme₁'nió'₄ guë́₄ 'nia'₂ rɨ́ng'₂ le₂jan'₂ le₂jan'₂ 'nia'₂ quian'₅₄ ca₂le₃jɨ́n₃ guë́₄ juɨ₁'ein₂ guë́₃ dsa₂ juɨ₁lia'₂ 'nio₃ jnia'₅₄ 'nia'₂.
\v 13 Juɨ₁jmo₅₄ bá₄ Diú₄ 'ag₃ tiá₂ 'au'₂ 'nia'₂, lén'₂ 'nia'₂ dsa₂ i₂ma₂lë́₅ 'í₁ quiáin₅ i₂tsá₃ ma₃'e₂ dsáu₁ cha₂ ne₄ Diú₄ Jmei₂ jniog₄ jë₁ma₂të́₂ rë₁jŋió'₂ Te₁gui'₅₄ Jesús quian'₅₄ ca₂le₃jɨ́n₃ i₂quiáin₅.\f + \fr 3:13 \ft lit. “dsa₂ jŋió₅ quiáin₅.” \f*
\c 4
\s1 'A₂ lia'₂ dsi₂ten₅₄ le₃chan₂ dsa₂ con'₂ 'ŋio₂ dsɨ́₅ Diú₄
\p 
\v 1 Në₃ në́₃ rɨn'₅₄ jniog₄, mɨ₂ jnia'₅₄ ne'₅₄ 'nia'₂ të₂le₃ o₄quió'₄ Te₁gui'₅₄ Jesús, a₂i₁nio'₄ 'nia'₂ lia'₂ con'₂ 'ŋio₂ dsɨ́₅ Diú₄, juɨ₁lia'₂ ca₂jme₁tag₅ jnia'₅₄. Le₂jaun₂ caun₂ jmo₄ 'nia'₂ ca₂le₃jë́₃ jmɨg₄.
\p 
\v 2 Ŋi'₅₄ bá₄ 'nia'₂ 'a₂ lia'₂ lë́₅ jág₁ ca₂jme₁tag₅ jnia'₅₄, 'éi'₃ ca₂cuë₃ Te₁gui'₅₄ Jesús.
\v 3 A₂'nio₃ Diú₄ a₂i₁nio'₄ 'nia'₂ lɨ́ng'₅ dsa₂ i₂ma₂lë́₅ 'í₁ ca₂ne₅₄ i₂ma₂quiáin₅ 'ŋiog₅; 'i₁jan₂ tsá₃ 'ein₂ juɨ₁nió'₄ jág₁ a₂tsá₃ dsi₂ten₅₄ nió'₃.
\v 4 Juɨ₁le₂ŋi'₅₄ 'nia'₂ le₂jang'₂ le₂jang'₂ 'a₂ lia'₂ tiáng'₄ quiang'₅₄ dsa₂ mɨ́₂ quiáng'₂, lë́₅ 'í₁, jme₁gain'₃ 'nia'₂.\f + \fr 4:4 \ft o₃, “Juɨ₁le₂ŋi'₅₄ 'nia'₂ le₂jang'₂ le₂jang'₂ 'a₂ lia'₂ jme₁'uang'₅₄ nɨ₁ŋɨ'₁ guiong'₅₄, lë́₅ 'í₁, con'₂ dsi₂ten₅₄.” \f*
\v 5 On₃jua'₅₄ a₂lë₁qui₂dsɨ₂jein₅ 'au'₂ 'nia'₂ 'lɨg'₅₄ juɨ₁lia'₂ jmo₅ dsɨ₂nau₂ i₂tsá₃ Diú₄ cuɨn₅.
\v 6 Jaun₂ 'i₁jan₂ tsá₃ 'ein₂ juɨ₁qui₂dsɨ₂juɨn₅₄ jua'₅₄ jme₃gain₂₃ rɨin'₅₄, quian'₅₄ 'i₁caun₂. Ia₁ Te₁gui'₅₄ bá₄ jéin'₃ uɨg₅ ca₂le₃jë́₃ a₂le₂në₅, juɨ₁lia'₂ ma₂chei₅₄ jnia'₅₄ 'nia'₂ le₂jŋiá₅.
\v 7 Ia₁ on₃jua'₅₄ jaun₂ ma₂të₅ Diú₄ a₂qui₂dsɨ₂jiog₅ dsɨ₅ 'lɨg'₅₄; a₂jaun₂ bá₄ ca₂të₃ a₂le₃chong₂ jniog₄ jŋió₅.
\v 8 Jaun₂ le₂në₅, juɨ₁lia'₂ i₂tsá₃ gue₅ jág₁ a₂jme₂tág₁ jnia'₅₄ la₂, on₃jua'₅₄ dsa₂ tsá₃ guein₂₃; Diú₄ bá₄ tsá₃ guein₂₃, i₂ma₂cuɨn₃ Jme₂dsí₂ Jŋió₅ quiáin₅.
\p 
\v 9 Tsá₃ 'e₂ tion₅₄ 'nió'₅ jua'₅₄ a₂juá'₄ jniá₂ tó'₄ ne₄ si₂ la₂, jua'₅₄ a₂juá'₄ jniá₂ 'a₂ lia'₂ dsi₂ten₅₄ jme₁'nió'₄ 'nia'₂ dsa₂ i₂'én₂ rɨ́ng'₂. Ia₁ ma₂ca₂jme₃tag₅ bá₄ Diú₄ 'ŋiog₅ 'a₂ lia'₂ jme₁'nió'₃ 'nia'₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂.
\v 10 Jaun₂ le₂në₅ bá₄ jmo'₂ 'nia'₂ ja₁con₂ rɨ́n'₂ 'nia'₂ i₂'én₂ i₂tián'₅ 'uë₃ Macedonia. La₁ mɨ₂ jnia'₅₄ ja₁con'₂ 'nia'₂, rɨn'₅₄ jniog₄, caun₂ juɨ₁dsi₂tsón₃ bá₄ a₂'nióg'₃ 'nia'₂ rɨ́ng'₂.
\v 11 Quen'₂ 'nia'₂ bí₂ tián'₂ 'nia'₂ 'ei₅ tei₄, jmo₄ 'nia'₂ jmá'₃ con'₂ a₂ca₂tɨ́n'₂ 'nia'₂ jmó'₂ guiong'₅₄, jmo₄ 'nia'₂ ta₁ quiáng'₂ quian'₅₄ gog'₂-tag'₅₄, juɨ₁lia'₂ qui₂ma₂jua'₅₄ jnia'₅₄ le₂jŋiá₅,
\v 12 ia₁jaun₂ i₁nio'₄ 'nia'₂ caun₂ juɨ₅ a₂jme₃go₃ dsa₂ sián'₂ i₂tsá₃ 'én₂, ia₁jaun₂ tsá₃ lë́₅ jua'₅₄ cha₂ a₂'nió'₅ quián'₂ 'nia'₂.
\s1 A₂jŋió'₂ Te₁gui'₅₄
\p 
\v 13 Rɨn'₅₄ jniog₄, tsá₃ 'niog₂ jnia'₅₄ jua'₅₄ tsá₃ ŋi'₅₄ 'nia'₂ 'e₂ lé₂ quian'₅₄ dsa₂ 'én₂ i₂ma₂dsan₃, ia₁jaun₂ tsá₃ jmó'₂ 'nia'₂ 'lia'₂ 'au'₂ juɨ₁lia'₂ 'lia'₂ dsɨ́₅ dsa₂ i₂tsá₃ jmɨg₄ cha₂ quió'₅ jua'₅₄ tɨ́in'₄.
\v 14 Jaun₂ le₂në₅, juɨ₁lia'₂ 'éin₂ jniog₄ a₂ca₂jon₃ Jesús, a₂ca₂jein'₅₄ táng₃ në́₃, le₂jaun₂ bá₄ 'éin₂ jniog₄ ján₃ a₂jme₃jen'₅₄ Diú₄ co₂lë₅ quian'₅₄ Jesús dsa₂ i₂ca₂dsan₃ i₂'én₂ le₃quió'₅.
\p 
\v 15 Jaun₂ lë₃ chei₂ jnia'₅₄ 'nia'₂ juɨ₁lia'₂ ca₂jme₃tag₅ Te₁gui'₅₄, con'₂ jniog₄ i₂chong₂ ca₂lia'₂ ca₂të́₂ jmɨg₄ a₂guan'₂ Te₁gui'₅₄, 'i₁jan₂ tsá₃ 'ein₂ jua'₅₄ i₂dsɨ₃jŋiá₄ con'₂ guë́₄ dsa₂ i₂ma₂dsan₃.
\v 16 Ia₁ 'ŋiog₅ bá₄ Te₁gui'₅₄ sióin₃ guei'₅₄ i₂juɨ́g₃ guió'₃ tiá₂ jmo₃ 'éi'₃, quian'₅₄ jág₁ quió'₅ ángel i₂'uan'₂ guë́₄, dsɨ₃'ein₅₄ ŋí₁ trompeta quió'₅ Diú₄ në́₃. Jaun₂ guë́₄ ca₂le₃jɨ́n₃ dsa₂ i₂'én₂ le₃quió'₅ Cristo i₂ma₂dsan₃, qui₃jein'₅₄ le₂'uɨg₅₄.
\v 17 Jaun₂ jniog₄ i₂chong₂ guë́₄, i₂të₁'ŋiá₄ guë́₄ në́₃, chó'₂ co₂lë₅ jë₄ jnei₅ quian'₅₄ dsa₂ i₂ma₂dsan₃ 'éi₂, a₂dsɨ₂jme₁jen'₂ Te₁gui'₅₄ guei'₅₄ dsi₁guɨg₂. Jaun₂ le₂në₅ dsɨ₁tió'₄ co₂tan₅₄ quian'₅₄ Te₁gui'₅₄.
\v 18 Jaun₂ lë₃, cuë₅₄ 'nia'₂ lián'₂ rɨ́ng'₂ quian'₅₄ jág₁ la₂.
\c 5
\p 
\v 1 La₁ tsá₃ tion₅₄ jua'₅₄ a₂juá'₄ jniá₂ tó'₄ ne₄ si₂ 'e₂ 'ió'₄ 'e₂ jmɨg₄ a₂lé₂ jaun₂.
\v 2 Jaun₂ ma₂le₁ŋi'₅₄ bá₄ 'nia'₂ dse₃ guiong'₅₄, jmɨg₄ a₂jŋió'₂ Te₁gui'₅₄ con'₂ tsá₃ ján₅ bá₄ dsa₂, juɨ₁lia'₂ ja₁já₄ jan₂ dsa₂ 'ang₂ caun₂ 'uë₂.
\v 3 Jë₁ma₂të́₂ rë₁juá'₂ dsa₂: “Ca₂le₃jë́₃ lë́₅ 'í₁, tei₄ bá₄ 'ei₅”, të₃jë₄ jaun₂ 'én₂ con'₂ tiá₂ ne₄ quió'₅ dsa₂ 'éi₂. Lé₂ juɨ₁lia'₂ ja₁jén'₅ 'io₅₄ i₂quian₅ guein₂. Con'₂ tsá₃ rë₂jáin₁ jë₁ma₂tá'₂ quɨ'₂ uɨg₅ quió'₅, tsá₃ a₁jaun₂ a₂lióin₂ jua'₅₄ a₂tsá₃ ŋág₃ jmɨ₁uɨg₅ jaun₂.
\v 4 La₁ 'nia'₂ rɨn'₅₄ jniog₄, tsá₃ tion'₅₄ 'nia'₂ jë₄ qui₁né'₃, jaun₂ tsá₃ lë́₅ jua'₅₄ jo₅₄ jmɨg₄ jaun₂ quián'₂ 'nia'₂, juɨ₁lia'₂ ja₁jo₅ jan₂ 'ang₂.
\v 5 Ia₁ ca₂le₃jɨ́n'₃ bá₄ 'nia'₂ lɨ́ng'₅ jaun₅ quián₅ ja₁tág₅ si₂, quian'₅₄ a₂jmɨ₂ në́₃. Tsá₃ téi₅ jniog₄ a₂'uë₂, on₃ guë'₂ jë₄ qui₁né'₃.
\v 6 Jaun₂ tsá₃ 'nió'₅ guág₃ jniog₄ juɨ₁lia'₂ güɨn₂ i₂lɨn₅₄. Le₁jnio₂ ne₄ bá₄ jniog₄ 'nió'₅ jmó₁, lei₅₄, 'en₅₄ dsɨ₅.
\v 7 A₂'uë₂ bá₄ güɨn₂ dsa₂, ján₃ guë'₂ a₂'uë₂ bá₄ 'ɨ́n'₂ dsa₂ 'en₅.
\v 8 La₁ jniog₄ në́₃, i₂téi₅ a₂jmɨ₂, 'nió'₅ lei₅₄, 'en₅₄ dsɨ₅. 'Nió'₅ qui₁jmó₁ 'í₁ quian'₅₄ a₂'éin₂ quian'₅₄ a₂jme₁'nió₄ rɨn'₅₄ në́₃, në₂jag₄ bá₄ qui₂rë₂lióg₃ ŋí₁ le₁dsɨ₅, lë́₅ 'í₁; a₂'ɨ́n₂ dsɨ₅ jniog₄ a₂tág'₄ në́₃, lë́₅ co₂'nió'₄ ŋí₁ a₂'i₄ mɨ₂dsi₄ 'lióg₂, lë́₅ 'í₁.
\v 9 Ia₁ on₃jua'₅₄ jaun₂ ca₂'ag₃ Diú₄ a₂guéi₁ jniog₄ 'nei₂ a₂'i₄ dsɨ́₅; a₂jaun₂ bá₄ ca₂'ag₃ a₂lió₂ jniog₄ të₂le₃ quian'₅₄ Te₁gui'₅₄ Jesucristo quián₂.
\v 10 O₄quián₂ jniog₄ ca₂join₃ ia₁jaun₂ dsɨ₁'io₁ co₂lë₅ quiain'₅₄, të₁lia'₂ chong₂, o₃ jë₁ma₂dsau₃ 'e₂.\f + \fr 5:10 \ft lit. “chi₂jua'₂ le₁jnio₂ ne₄ jniog₄, o₃ le₁guág₃ 'e₂.” \f*
\v 11 Jaun₂ caun₂ dsia₄ 'nia'₂ tiá₂ 'au'₂, cuë'₅₄ bí₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂, juɨ₁lia'₂ ma₂jmo'₂ në₅.
\s1 Ton'₂ Pablo jág₁ dsa₂ rɨin'₅₄
\p 
\v 12 Rɨn'₅₄ jniog₄, mɨ₂ jnia'₅₄ a₂jme₁gang'₃ dsa₂ i₂jmo₅ ta₁ jë₄ quián'₂ 'nia'₂, i₂jiog₅ ne₄ juɨ₅ le₃quió'₅ Te₁gui'₅₄, i₂to'₂ jág₁ dse₃ në́₃.
\v 13 Ca₂tɨ́n'₂ 'nia'₂ jme₁gain'₃ 'ŋio₅ lɨn₃, a₂jme₁'niói₄ në́₃, o₄quió'₄ ta₁ a₂jmo₂₃. Juɨ₁'ei₅ bá₄ tei₄ tion'₅₄ 'nia'₂ le₂jang'₂ le₂jang'₂.
\p 
\v 14 Ján₃ guë'₂ le₂jaun₂ rɨn'₅₄ jniog₄, jén₃ 'nia'₂ dsa₂ i₂tsá₃ ta₁ 'nio₃ jmo₃. Cuë'₅₄ 'nia'₂ bí₂ dsa₂ i₂tsá₃ lɨn₄ niog₅ tiá₂ dsɨ́₅, jme₁'on₁ 'nia'₂ dsa₂ 'uan₅₄, jme₁juɨn'₂ 'nia'₂ 'au'₂ quian'₅₄ ca₂le₃jɨ́n₃ rɨ́ng'₂.
\p 
\v 15 Jmo₄ 'nia'₂ 'í₁, ia₁jaun₂ 'i₁jan₂ tsá₃ jéin'₃ 'lɨg'₅₄ quió'₅ i₂jmóg'₂ 'lɨg'₅₄. Të₂le₃ caun₂ o₂nó'₅ bá₄ 'nia'₂ jmo₄ a₂dse₃ co₂tan₅₄ quian'₅₄ rɨ́n'₂ 'nia'₂ le₂jang'₂ le₂jang'₂ quian'₅₄ guë́₄ ca₂le₃jɨ́n₃ dsa₂.
\p 
\v 16 Tián'₂ bá₄ 'nia'₂ 'io'₂ jéng'₂ co₂tan₅₄.
\v 17 Chi₂len'₅₄ 'nia'₂ Diú₄ lia'₂ tsá₃ 'na₂.
\v 18 Cuë'₅₄ 'nia'₂ ti₁'mag'₄ Diú₄ ne₄ ca₂le₃jë́₃, ia₁ a₂në₅ bá₄ 'ŋio₂ dsɨ́₅ Diú₄ të₂le₃ quián'₂ 'nia'₂ o₄quió'₄ Cristo Jesús.
\p 
\v 19 Tsá₃ lë₁ag₂ 'nia'₂ si₂ quió'₅ Jme₂dsí₂ Jŋió₅.
\v 20 Në₁jua'₂ 'ein₂ 'ë́₂ jág₁ a₂guéi'₅ quió'₅ Diú₄, tsá₃ lë₁jmo₂ 'nia'₂ jua'₅₄ a₂tsá₃ jeng'₅₄.
\v 21 Quion₂ de'₂ 'nia'₂ 'í₁ ca₂le₃jë́₃ a₂në₅, jaun₂ chan'₂ bá₄ 'nia'₂ jmá'₃ a₂dse₃.
\v 22 Co₂dsia₅ jmo₄ 'nia'₂ cau₅ ca₂le₃jë́₃ ne₅₄ a₂'lɨg'₅₄.
\p 
\v 23 'Ŋiog₅ Diú₄ i₂jmo₅ 'ei₅ tei₄, juɨ₁jmo₁₂ a₂lén'₂ 'nia'₂ dsa₂ jŋió₅ co₂ŋei'₅₄; juɨ₁le₅₄ bá₄ 'í₁ 'nia'₂, ta₁jang'₂: lia'₂ jme₂dsí₂, lia'₂ 'au'₂, lia'₂ ŋɨ'₄ 'nia'₂; ia₁jaun₂ tsá₃ 'ein₂ lé₂ le₃bóg'₂ dso₄ jë₁ma₂të́₂ rë₁guan'₂ Te₁gui'₅₄ Jesucristo quián₂.
\v 24 I₂ma₂të₃ quián'₂ 'nia'₂ tí₅ bá₄ jág₁ quió'₅, jaun₂ jme₃ti₃ bá₄ ca₂le₃jë́₃ a₂në₅.
\s1 'Ág'₅ jág₁ jë₁ca₂tó'₂
\p 
\v 25 Rɨn'₅₄ jniog₄, chi₁len'₄ 'nia'₂ Diú₄ o₄quián₂ jnia'₅₄.
\p 
\v 26 Cuɨn₅₄ Diú₄ ca₂le₃jɨ́n₃ rɨn'₅₄ a₂qui₁chén'₁\f + \fr 5:26 \ft Caun₂ tag₄ a₂jme₁chí'₄ lia'₂ con'₂ ca₂jmo₃ Pa₄ si₂ la₂.\f* 'nia'₂ quió'₅ rɨ́ng'₂, a₂lë́₅ léi₄ a₂ma₂'ei₅ caun₂ jág₁ a₂le₁jë́₃ 'au'₂ quian'₅₄ rɨ́ng'₂.
\p 
\v 27 Mɨ₅ jniá₂, lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ Te₁gui'₅₄, 'í₂ 'nia'₂ si₂ carta la₂ jɨn₄ ca₂le₃jɨ́n₃ rɨn'₅₄.
\p 
\v 28 Juɨ₁jme₂gu'₅₄ Te₁gui'₅₄ Jesucristo quián₂ jniog₄ ca₂le₃jɨ́n'₃ 'nia'₂.
\p Co₂në₅.
