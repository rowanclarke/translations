\toc1 Primera carta de Pablo a Timoteo
\mt1 1 Timoteo
\c 1
\s1 Saludo
\p 
\v 1 \w Pablo|strong="G3972"\w*, \w un|strong="G3588"\w* apóstol \w de|strong="G2596"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w* \w por|strong="G2596"\w* mandato \w de|strong="G2596"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*, \w y|strong="G2532"\w* \w de|strong="G2596"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w* \w nuestra|strong="G3588"\w* \w esperanza|strong="G1680"\w*,
\v 2 \w a|strong="G1722"\w* \w Timoteo|strong="G5095"\w*, legítimo \w hijo|strong="G5043"\w* \w en|strong="G1722"\w* \add la \add*\w fe|strong="G4102"\w*. \w Gracia|strong="G5485"\w*, \w misericordia|strong="G1656"\w*, \w paz|strong="G1515"\w* \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w Padre|strong="G3962"\w* \w y|strong="G2532"\w* \w de|strong="G1722"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w*.
\s1 Falsos maestros
\p 
\v 3 \w Cuando|strong="G1722"\w* pasé \w a|strong="G1519"\w* \w Macedonia|strong="G3109"\w* \w te|strong="G4771"\w* \w rogué|strong="G3870"\w* permanecer \w en|strong="G1722"\w* Éfeso \w para|strong="G1519"\w* \w que|strong="G2443"\w* mandaras \w a|strong="G1519"\w* \w algunos|strong="G5100"\w* \w que|strong="G2443"\w* \w no|strong="G3361"\w* ofrecieran instrucción diferente,
\v 4 \w ni|strong="G3366"\w* pusieran atención \w a|strong="G1722"\w* \w fábulas|strong="G3454"\w* \w y|strong="G2532"\w* \w genealogías|strong="G1076"\w* interminables, \w las|strong="G3588"\w* \w cuales|strong="G3748"\w* \w más|strong="G2532"\w* \w bien|strong="G3123"\w* promueven especulaciones inútiles \w y|strong="G2532"\w* \w no|strong="G3366"\w* \w la|strong="G3588"\w* administración \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w que|strong="G3588"\w* es \w por|strong="G1722"\w* \w fe|strong="G4102"\w*.
\p 
\v 5 \w Pues|strong="G1161"\w* \w el|strong="G3588"\w* propósito \w de|strong="G1537"\w* \w esta|strong="G3588"\w* instrucción es \add el\add* amor \w de|strong="G1537"\w* \w corazón|strong="G2588"\w* \w puro|strong="G2513"\w*, buena \w conciencia|strong="G4893"\w* \w y|strong="G2532"\w* \w fe|strong="G4102"\w* sincera,
\v 6 \w de|strong="G1519"\w* \w las|strong="G3739"\w* \w cuales|strong="G3739"\w*, \w algunos|strong="G5100"\w* perdieron \w el|strong="G3739"\w* camino y fueron desviados \w hacia|strong="G1519"\w* vacía palabrería.
\v 7 Deseaban ser maestros \w de|strong="G4012"\w* la Ley \w sin|strong="G3361"\w* \w entender|strong="G3539"\w* \w lo|strong="G5101"\w* \w que|strong="G3739"\w* \w dicen|strong="G3004"\w*, \w ni|strong="G3383"\w* \w las|strong="G3739"\w* \w cosas|strong="G3739"\w* \w que|strong="G3739"\w* \w hablan|strong="G3004"\w* \w de|strong="G4012"\w* \w manera|strong="G3361"\w* absoluta.
\s1 Propósito de la Ley
\p 
\v 8 \w Pero|strong="G1161"\w* \w sabemos|strong="G1492"\w* \w que|strong="G3754"\w* \add la\add* \w Ley|strong="G3551"\w* es \w buena|strong="G2570"\w* \w cuando|strong="G1492"\w* \w alguno|strong="G5100"\w* habla \w legítimamente|strong="G3545"\w*.
\v 9 Reconocemos \w que|strong="G3754"\w* \add la\add* \w Ley|strong="G3551"\w* \w no|strong="G3756"\w* \w se|strong="G1492"\w* instituyó para \add el\add* \w justo|strong="G1342"\w*, \w sino|strong="G1161"\w* para inicuos \w y|strong="G2532"\w* desobedientes, ateos \w y|strong="G2532"\w* pecadores, perversos \w y|strong="G2532"\w* profanos, patricidas \w y|strong="G2532"\w* \w matricidas|strong="G3389"\w*, homicidas,
\v 10 inmorales sexuales, homosexuales, secuestradores, \w mentirosos|strong="G5583"\w*, perjuros \w y|strong="G2532"\w* \w si|strong="G1487"\w* \w hay|strong="G3588"\w* \w algún|strong="G5100"\w* \w otro|strong="G2087"\w* \w que|strong="G3588"\w* \w se|strong="G2532"\w* opone a \add la \add*\w sana|strong="G5198"\w* \w doctrina|strong="G1319"\w*,
\v 11 \w según|strong="G2596"\w* \w las|strong="G3588"\w* Buenas Noticias \w de|strong="G2596"\w* \w la|strong="G3588"\w* \w gloria|strong="G1391"\w* \w del|strong="G3588"\w* \w bendito|strong="G3107"\w* \w Dios|strong="G2316"\w*, \w las|strong="G3588"\w* \w cuales|strong="G3739"\w* se \w me|strong="G1473"\w* encomendaron.
\s1 Vocación de Pablo
\p 
\v 12 \w Estoy|strong="G2192"\w* agradecido \w al|strong="G3588"\w* \w que|strong="G3754"\w* \w me|strong="G1473"\w* fortaleció, \w a|strong="G1519"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w*, \w porque|strong="G3754"\w* \w al|strong="G3588"\w* ponerme \w en|strong="G1519"\w* \w el|strong="G3588"\w* \w ministerio|strong="G1248"\w*, \w me|strong="G1473"\w* consideró \w fiel|strong="G4103"\w*.
\v 13 \w Había|strong="G4160"\w* sido \w un|strong="G3588"\w* blasfemo, perseguidor \w e|strong="G2532"\w* insolente. \w Pero|strong="G2532"\w* \w me|strong="G1722"\w* fue otorgada misericordia \w porque|strong="G3754"\w* procedí \w por|strong="G1722"\w* ignorancia \w en|strong="G1722"\w* incredulidad.
\v 14 \w Pero|strong="G1161"\w* \w la|strong="G3588"\w* \w gracia|strong="G5485"\w* \w de|strong="G1722"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* estuvo presente \w en|strong="G1722"\w* gran abundancia \w con|strong="G3326"\w* \w fe|strong="G4102"\w* \w y|strong="G2532"\w* amor \w en|strong="G1722"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w*.
\p 
\v 15 \w La|strong="G3588"\w* \w Palabra|strong="G3056"\w* \w es|strong="G3739"\w* \w fiel|strong="G4103"\w* \w y|strong="G2532"\w* digna \w de|strong="G1519"\w* \w toda|strong="G3956"\w* aceptación: \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w* \w vino|strong="G2064"\w* \w al|strong="G3588"\w* \w mundo|strong="G2889"\w* \w a|strong="G1519"\w* \w salvar|strong="G4982"\w* pecadores, \w de|strong="G1519"\w* \w los|strong="G3588"\w* \w cuales|strong="G3739"\w* \w yo|strong="G1473"\w* \w soy|strong="G1510"\w* \add el \add*\w primero|strong="G4413"\w*.
\v 16 Pero \w por|strong="G1223"\w* \w esto|strong="G3778"\w* \add me \add*fue otorgada misericordia, \w a|strong="G1519"\w* fin \w de|strong="G1722"\w* \w que|strong="G3588"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w* demuestre \w toda|strong="G1223"\w* \w longanimidad|strong="G3115"\w* \w primero|strong="G4413"\w* \w en|strong="G1722"\w* \w mí|strong="G3588"\w* \w como|strong="G1722"\w* \w ejemplo|strong="G5296"\w* \w de|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* creerían \w en|strong="G1722"\w* \w Él|strong="G3588"\w* \w para|strong="G1519"\w* \w vida|strong="G2222"\w* eterna.
\p 
\v 17 \w Por|strong="G1519"\w* tanto, \w al|strong="G3588"\w* Rey \w de|strong="G1519"\w* \w los|strong="G3588"\w* siglos, inmortal, invisible, \w al|strong="G3588"\w* único \w Dios|strong="G2316"\w*, sean \add el \add*\w honor|strong="G5092"\w* \w y|strong="G2532"\w* \add la \add*\w gloria|strong="G1391"\w* \w por|strong="G1519"\w* \w los|strong="G3588"\w* siglos \w de|strong="G1519"\w* \w los|strong="G3588"\w* siglos. Amén.
\p 
\v 18 \w Este|strong="G3778"\w* mandato \w te|strong="G4771"\w* \w encargo|strong="G3908"\w*, \w hijo|strong="G5043"\w* \w Timoteo|strong="G5095"\w*, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w conforme|strong="G2596"\w* \w a|strong="G1909"\w* \w las|strong="G3588"\w* \w profecías|strong="G4394"\w* \w que|strong="G3588"\w* preceden \w sobre|strong="G1909"\w* ti, \w te|strong="G4771"\w* sirvas \w de|strong="G1722"\w* \w ellas|strong="G3588"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* noble combate,
\v 19 \w y|strong="G2532"\w* mantengas \add la \add*\w fe|strong="G4102"\w* \w y|strong="G2532"\w* \w la|strong="G3588"\w* buena \w conciencia|strong="G4893"\w*.
\p \w Algunos|strong="G5100"\w* naufragaron \w respecto|strong="G4012"\w* a \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w al|strong="G3588"\w* rechazarlas,
\v 20 \w de|strong="G3588"\w* \w los|strong="G3588"\w* \w cuales|strong="G3739"\w* \w son|strong="G1510"\w* \w Himeneo|strong="G5211"\w* \w y|strong="G2532"\w* Alejandro, \w a|strong="G2443"\w* \w quienes|strong="G3739"\w* \w entregué|strong="G3860"\w* \w a|strong="G2443"\w* \w Satanás|strong="G4567"\w* \w para|strong="G2443"\w* \w que|strong="G3588"\w* aprendieran \w a|strong="G2443"\w* \w no|strong="G3361"\w* blasfemar.
\c 2
\s1 Respaldo a la conversación con Dios
\p 
\v 1 \w Exhorto|strong="G3870"\w* \w ante|strong="G4412"\w* \w todo|strong="G3956"\w*, \w que|strong="G3767"\w* sean hechas \w peticiones|strong="G1783"\w*, conversaciones con Dios, súplicas \w y|strong="G3767"\w* acciones \w de|strong="G5228"\w* gracias \w por|strong="G5228"\w* \w todos|strong="G3956"\w* los hombres,
\v 2 \w por|strong="G1722"\w* \add los\add* reyes \w y|strong="G2532"\w* \w por|strong="G1722"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* están \w en|strong="G1722"\w* posición \w de|strong="G1722"\w* autoridad, \w a|strong="G1722"\w* fin \w de|strong="G1722"\w* \w que|strong="G3588"\w* pasemos \w una|strong="G3588"\w* vida diaria tranquila \w y|strong="G2532"\w* \w quieta|strong="G2263"\w*, \w con|strong="G1722"\w* \w toda|strong="G3956"\w* \w piedad|strong="G2150"\w* \w y|strong="G2532"\w* dignidad.
\p 
\v 3 \w Esto|strong="G3778"\w* \w es|strong="G3778"\w* \w bueno|strong="G2570"\w* \w y|strong="G2532"\w* agradable \w delante|strong="G1799"\w* \w de|strong="G3588"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*,
\v 4 \w el|strong="G3739"\w* \w cual|strong="G3739"\w* desea \w que|strong="G3739"\w* \w todos|strong="G3956"\w* \w los|strong="G2532"\w* hombres sean \w salvos|strong="G4982"\w* \w y|strong="G2532"\w* acudan \w al|strong="G1519"\w* \w conocimiento|strong="G1922"\w* \w de|strong="G1519"\w* la verdad.
\p 
\v 5 \w Porque|strong="G1063"\w* hay \w un|strong="G1520"\w* \w solo|strong="G1520"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w un|strong="G1520"\w* \w solo|strong="G1520"\w* \w Mediador|strong="G3316"\w* entre \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* hombres: \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w*, Hombre,
\v 6 \w Quien|strong="G3588"\w* \w se|strong="G1438"\w* \w dio|strong="G1325"\w* a \w sí|strong="G1438"\w* mismo como rescate \w por|strong="G5228"\w* \w todos|strong="G3956"\w*. \w El|strong="G3588"\w* \w testimonio|strong="G3142"\w* \add fue dado\add* \w en|strong="G3588"\w* \w tiempos|strong="G2540"\w* apropiados,
\v 7 \w para|strong="G1519"\w* \w lo|strong="G3739"\w* \w cual|strong="G3739"\w* \w yo|strong="G1473"\w* fui constituido \w predicador|strong="G2783"\w* \w y|strong="G2532"\w* apóstol (\w digo|strong="G3004"\w* \w verdad|strong="G4102"\w*, \w no|strong="G3756"\w* \w miento|strong="G5574"\w*), \w maestro|strong="G1320"\w* \w de|strong="G1722"\w* \add los\add* gentiles \w en|strong="G1722"\w* \w fe|strong="G4102"\w* \w y|strong="G2532"\w* \w verdad|strong="G4102"\w*.
\p 
\v 8 \w Quiero|strong="G1014"\w*, \w pues|strong="G3767"\w*, \w que|strong="G3588"\w* \w los|strong="G3588"\w* hombres hablen \w con|strong="G1722"\w* Dios \w en|strong="G1722"\w* \w todo|strong="G3956"\w* \w lugar|strong="G5117"\w* \w y|strong="G2532"\w* levanten \w manos|strong="G5495"\w* santas, \w sin|strong="G5565"\w* \w ira|strong="G3709"\w* \w ni|strong="G2532"\w* discusión.
\s1 Comportamiento de las mujeres
\p 
\v 9 \w Asimismo|strong="G2532"\w*, \w que|strong="G2228"\w* las \w mujeres|strong="G1135"\w* \w se|strong="G1438"\w* \w adornen|strong="G2885"\w* \w con|strong="G3326"\w* \w ropa|strong="G2441"\w* decorosa, \w con|strong="G3326"\w* \w modestia|strong="G4997"\w* \w y|strong="G2532"\w* decencia, \w no|strong="G3361"\w* \w con|strong="G3326"\w* peinados ostentosos, \w ni|strong="G2532"\w* \w oro|strong="G5557"\w*, \w ni|strong="G2532"\w* \w perlas|strong="G3135"\w*, \w ni|strong="G2532"\w* \w ropa|strong="G2441"\w* costosa,
\v 10 sino \w con|strong="G1223"\w* buenas \w obras|strong="G2041"\w*, \w lo|strong="G3739"\w* \w cual|strong="G3739"\w* \w conviene|strong="G4241"\w* \w a|strong="G1223"\w* \w mujeres|strong="G1135"\w* \w que|strong="G3739"\w* profesan reverencia \w a|strong="G1223"\w* Dios.
\p 
\v 11 \w Que|strong="G1722"\w* una \w mujer|strong="G1135"\w* \w aprenda|strong="G3129"\w* \w en|strong="G1722"\w* quietud, \w con|strong="G1722"\w* \w toda|strong="G3956"\w* sumisión,
\v 12 \w pues|strong="G1161"\w* \w no|strong="G3756"\w* \w permito|strong="G2010"\w* \w a|strong="G1722"\w* una \w mujer|strong="G1135"\w* \w enseñar|strong="G1321"\w* \w ni|strong="G3761"\w* dominar \w a|strong="G1722"\w* \w un|strong="G1722"\w* varón, \w sino|strong="G1161"\w* estar \w en|strong="G1722"\w* quietud.
\p 
\v 13 \w Porque|strong="G1063"\w* Adán fue formado \w primero|strong="G4413"\w*, \w luego|strong="G1534"\w* \w Eva|strong="G2096"\w*.
\v 14 Adán \w no|strong="G3756"\w* \w fue|strong="G1096"\w* engañado, \w sino|strong="G1161"\w* \w la|strong="G3588"\w* \w esposa|strong="G1135"\w*. \w Cuando|strong="G1722"\w* \w fue|strong="G1096"\w* engañada, cayó \w en|strong="G1722"\w* \w transgresión|strong="G3847"\w*.
\v 15 \w Pero|strong="G1161"\w* será preservada \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1722"\w* \w la|strong="G3588"\w* procreación, \w cuando|strong="G1722"\w* \w permanezca|strong="G3306"\w* \w en|strong="G1722"\w* \add la\add* \w fe|strong="G4102"\w*, \add el \add*amor, \w y|strong="G2532"\w* \add la \add*santificación \w con|strong="G3326"\w* \w modestia|strong="G4997"\w*.
\c 3
\s1 Para los que anhelan ministerio
\p 
\v 1 \w Fiel|strong="G4103"\w* \w es|strong="G1487"\w* \w la|strong="G3588"\w* \w Palabra|strong="G3056"\w*: \w Si|strong="G1487"\w* \w alguno|strong="G5100"\w* anhela oficio \w de|strong="G3588"\w* supervisor, \w desea|strong="G1937"\w* \w buena|strong="G2570"\w* \w obra|strong="G2041"\w*.
\v 2 Es \w necesario|strong="G1163"\w* \w que|strong="G3588"\w* \w el|strong="G3588"\w* supervisor \w sea|strong="G3588"\w* irreprochable, esposo \w de|strong="G3588"\w* \w una|strong="G1520"\w* sola \w esposa|strong="G1135"\w*, sobrio, prudente, honorable, \w hospedador|strong="G5382"\w*, apto para enseñar,
\v 3 \w no|strong="G3361"\w* adicto al vino, \w ni|strong="G3361"\w* pendenciero, \w sino|strong="G3361"\w* amable, apacible, \w no|strong="G3361"\w* avaro,
\v 4 \w que|strong="G3588"\w* gobierne \w bien|strong="G2573"\w* \w su|strong="G3588"\w* \w propia|strong="G2398"\w* \w familia|strong="G3624"\w*, \w que|strong="G3588"\w* \w tenga|strong="G2192"\w* \w hijos|strong="G5043"\w* \w en|strong="G1722"\w* \w sujeción|strong="G5292"\w* \w con|strong="G3326"\w* \w toda|strong="G3956"\w* dignidad,
\v 5 (\w pues|strong="G1161"\w* \w si|strong="G1487"\w* \w alguno|strong="G5100"\w* \w no|strong="G3756"\w* \w sabe|strong="G1492"\w* dirigir \w a|strong="G1161"\w* \w su|strong="G3588"\w* \w propia|strong="G2398"\w* \w familia|strong="G3624"\w*, ¿\w cómo|strong="G4459"\w* \w cuidará|strong="G1959"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w iglesia|strong="G1577"\w* \w de|strong="G3588"\w* \w Dios|strong="G2316"\w*?),
\v 6 \w no|strong="G3361"\w* \w un|strong="G3588"\w* recién convertido, \w no|strong="G3361"\w* \w sea|strong="G3588"\w* \w que|strong="G3588"\w*, \w después|strong="G1519"\w* \w de|strong="G1519"\w* envanecerse \w caiga|strong="G1706"\w* \w en|strong="G1519"\w* \w juicio|strong="G2917"\w* \w del|strong="G3588"\w* \w diablo|strong="G1228"\w*.
\p 
\v 7 \w Debe|strong="G1163"\w* \w tener|strong="G2192"\w* \w también|strong="G2532"\w* \w buen|strong="G2570"\w* \w testimonio|strong="G3141"\w* \w de|strong="G1519"\w* \w los|strong="G3588"\w* \w de|strong="G1519"\w* afuera, \w para|strong="G1519"\w* \w que|strong="G3588"\w* \w no|strong="G3361"\w* \w caiga|strong="G1706"\w* \w en|strong="G1519"\w* reproche \w y|strong="G2532"\w* trampa \w del|strong="G3588"\w* \w diablo|strong="G1228"\w*.
\s1 Para los diáconos
\p 
\v 8 \w Asimismo|strong="G5615"\w*, \add los \add*\w diáconos|strong="G1249"\w*, sean serios, \w sin|strong="G3361"\w* doblez de lengua, dignos de respeto, \w no|strong="G3361"\w* de doble palabra, \w no|strong="G3361"\w* adictos a \w mucho|strong="G4183"\w* \w vino|strong="G3631"\w*, \w no|strong="G3361"\w* codiciosos de ganancia deshonesta,
\v 9 \w que|strong="G3588"\w* guarden \w el|strong="G3588"\w* \w misterio|strong="G3466"\w* \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w con|strong="G1722"\w* \w limpia|strong="G2513"\w* \w conciencia|strong="G4893"\w*.
\v 10 \w Éstos|strong="G3778"\w* \w también|strong="G2532"\w* sean probados \w primero|strong="G4413"\w*, \w y|strong="G2532"\w* \w entonces|strong="G1161"\w*, \w si|strong="G2532"\w* \w son|strong="G1510"\w* irreprochables, sirvan \w como|strong="G2532"\w* diáconos.
\p 
