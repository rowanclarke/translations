\id PHP
\h הפיליפינים
\toc1 אִגֶּרֶת פּוֹלוֹס הַשָּׁלִיחַ אֶל־הַפִּילִפִּיִּים
\toc2 אִגֶּרֶת פּוֹלוֹס הַשָּׁלִיחַ אֶל־הַפִּילִפִּיִּים
\toc3 הפיליפינים
\mt1 אִגֶּרֶת פּוֹלוֹס הַשָּׁלִיחַ אֶל־הַפִּילִפִּיִּים
\c 1
\cp א
\cl פרק א
\p 
\v 1 \vp א\vp* פּוֹלוֹס וְטִימוֹתִיּוֹס עַבְדֵי יֵשׁוּעַ הַמָּשִׁיחַ אֶל־כָּל־הַקְּדוֹשִׁים בְּיֵשׁוּעַ הַמָּשִׁיחַ הַיֹּשְׁבִים בְּפִלִפִּי עִם־זִקְנֵיהֶם וּמְשָׁרְתֵיהֶם׃
\v 2 \vp ב\vp* חֶסֶד וְשָׁלוֹם יִתֵּן לָכֶם אֱלֹהִים אָבִינוּ וְיֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ׃
\v 3 \vp ג\vp* אֲבָרְכָה אֶת־אֱלֹהָי בְּכָל־עֵת אֲשֶׁר אֱזְכֹּר אֶתְכֶם׃
\v 4 \vp ד\vp* וְאֶעֶלְצָה תָּמִיד בְּכָל־תְּפִלּוֹתָי כַּאֲשֶׁר אֶתְפַּלֵּל בְּעַד כֻּלְּכֶם׃
\v 5 \vp ה\vp* אַתֶּם הַנִּלְוִים אֶל־הַבְּשׂרָה לְמִן־הַיּוֹם הָרִאשׁוֹן וְעַד־עָתָּה׃
\v 6 \vp ו\vp* וּבָזֹאת אֲנִי בֹטֵחַ כִּי הוּא אֲשֶׁר הֵחֵל לִפְעֹל דָּבָר טוֹב בָּכֶם גַּם־הוּא יְכַלֶּנּוּ עַד־יוֹם יֵשׁוּעַ הַמָּשִׁיחַ׃
\v 7 \vp ז\vp* כֵּן חָשְׁבָה נַפְשִׁי עֲלֵיכֶם בְּמֵישָׁרִים כִּי בְקֶרֶב לְבָבִי אֶשָּׂא אֶתְכֶם אִם בְּשִׁבְתִּי בְּבֵית הָאֲסוּרִים אוֹ מִדֵּי דַבְּרִי לְהַצְדִּיק אֶת־הַבְּשׂרָה ולְהַאֲדִירָהּ כִּי דְבֵקִים אַתֶּם בִּי כֻלְּכֶם בַּחֲבָלִים נָפְלוּ לִי בֶּחָסֶד׃
\v 8 \vp ח\vp* הֵן אֱלֹהִים לִי לְעֵד כַּמָּה אֶרְחָמְכֶם בְּרַחֲמֵי יֵשׁוּעַ הַמָּשִׁיחַ׃
\v 9 \vp ט\vp* וְעַל־זֹאת אֶתְפַּלֵּל כִּי־תִרְבֶּה אַהֲבַתְכֶם הָלוֹךְ וָרָב בְּכָל־דֵּעָה וְהַשְׂכֵּל׃
\v 10 \vp י\vp* לְהָכִּיר וּלְהַבְדִּיל בֵּין טוֹב לָרָע לִהְיוֹת בָּרֵי לֵב וְלֹא לְמוֹקֵשׁ עַד־יוֹם הַמָּשִׁיחַ׃
\v 11 \vp יא\vp* מְלֵאִים פְּרִי צֶדֶק עַל־יְדֵי יֵשׁוּעַ הַמָּשִׁיחַ לִכְבוֹד אֱלֹהִים וְתִפְאַרְתּוֹ׃
\v 12 \vp יב\vp* וַאֲנִי חָפֵץ כִּי תֵדְעוּן אֶחָי זֹאת אֲשֶׁר בָּאַתְנִי בָּאָה רַק לְהוֹעִיל לַהֲלִיכוֹת הַבְּשׂרָה׃
\v 13 \vp יג\vp* עַד אֲשֶׁר נִשְׁמַע בְּשַׁעַר הַבִּירָה וּבְכָל־שְׁאָר הַמְּקֹמוֹת כִּי אָסִיר אֲנִי לְמַעַן הַמָּשִׁיחַ׃
\v 14 \vp יד\vp* וְאַחִים רַבִּים הַדְּבֵקִים בַּאֲדֹנֵינוּ לָבְשׁוּ אֹמֶץ רָב לְנֹכַח מוּסָרִי וַיַּשְׁמִיעוּ בְיֶתֶר עֹז אֶת־דְּבַר הָאֱלֹהִים בִּבְלִי־פָחַד׃
\v 15 \vp טו\vp* אָמְנָם יֵשׁ מַגִּידִים עֵדוּת הַמָּשִׁיחַ מִקִּנְאָה וּמְרִיבָה וְיֵשׁ מַגִּידִים מֵרוּחַ נְדִיבָה׃
\v 16 \vp טז\vp* וְאֵלֶּה הַמַּגִּידִים עֵדוּת הַמָּשִׁיחַ מִמְּרִיבָה וְלֹא בְּתָם־לֵב יַחְשְׁבוּ לְהוֹסִיף לַחַץ לְמוּסָרִי׃
\v 17 \vp יז\vp* אֵלֶּה הַמַּגִּידִים מֵאַהֲבָה יֹדְעִים כִּי לְהוֹצִיא צִדְקַת הַבְּשׂרָה לְאוֹר אָנֹכִי עֹמֵד פֹּה׃
\v 18 \vp יח\vp* אַךְ מָה אֵפוֹא עַתָּה אִם־בִּלְשׁוֹן רְמִיָּה אוֹ בִּשְׂפַת אֱמֶת הֲלֹא מִכָּל־עֵבֶר הֻגַּד הַמָּשִׁיחַ עַל־פִּיהֶם וְעַל־זֶה עָלֵז אֲנִי וְגִיל תָּגִיל נַפְשִׁי׃
\v 19 \vp יט\vp* כִּי בִתְפִלַּתְכֶם וּבְרוּחַ יֵשׁוּעַ מְשִׁיחֵנוּ הַנָּתוּן לִי יָדַעְתִּי כִּי גַּם־זֹאת תִּהְיֶה־לִּי לִישׁוּעָה׃
\v 20 \vp כ\vp* כַּאֲשֶׁר הוֹחַלְתִּי כִּי בְכָל־דְּרָכַי לֹא אֵבוֹשׁ מִשִּׁבְרִי וְכָל־מִבְטָחִי כְּאָז כֵּן עַתָּה כִּי יָרוּם הַמָּשִׁיחַ בְּמוֹ־נַפְשִׁי אִם־בַּחַיִּים אִם־בַּמָּוֶת׃
\v 21 \vp כא\vp* כִּי חַיָּתִי הוּא הַמָּשִׁיחַ וְהַמָּוֶת הוּא לְרַוְחָתִי׃
\v 22 \vp כב\vp* אָכֵן אִם יִנָּתְנוּ לִי חַיֵּי בְשָׂרִי לְהָבִיא עוֹד פְּרִי עֲמָלִי אָז לֹא אֵדַע מָה אֶבְחָר׃
\v 23 \vp כג\vp* כִּי נִלְחָץ אֲנִי בֵּין שְׁתָּיִם נַפְשִׁי כָלְתָה לְהִפָּרֵד לִהְיוֹת עִם־הַמָּשִׁיחַ אֲשֶׁר הוּא טוֹב לִי מִכֹּל׃
\v 24 \vp כד\vp* אֶפֶס לְהַאֲרִיךְ חַיֵּי בְשָׂרִי יֹתֵר טוֹב הוּא לָכֶם׃
\v 25 \vp כה\vp* וּבָזֹאת אֲנִי בֹטֵחַ וְיוֹדֵעַ כִּי אִוָּתֵר פֹּה וְיָשַׁבְתִּי עִם־כֻּלְּכֶם לְמַרְבֶּה הָאֱמוּנָה וְהַשִּׂמְחָה לָכֶם׃
\v 26 \vp כו\vp* וְתִפְאַרְתְּכֶם לִפְנֵי יֵשׁוּעַ הַמָּשִׁיחַ תִּגְדַּל בִּי כַּאֲשֶׁר אָשׁוּבָה אֲלֵיכֶם׃
\v 27 \vp כז\vp* רַק שִׂימוּ דַרְכְּכֶם כַּאֲשֶׁר יָאֲתָה לִבְשׂרַת הַמָּשִׁיחַ וְכִי אָבוֹא לִרְאֹתְכֶם אוֹ לְשֵׁמַע אֹזֶן מֵרָחוֹק אָז אֶמְצָא כִּי רוּחַ אֶחָד בָּכֶם וְנֶפֶשׁ אַחַת לְהִלָּחֵם יַחְדָּו מִלְחֲמוֹת אֱמוּנַת הַבְּשׂרָה׃
\v 28 \vp כח\vp* וְאַל־תִּירָאוּ וְאַל־תַּעַרְצוּ מִפְּנֵי הַקָּמִים עֲלֵיכֶם זֶה הוּא לָהֶם לְאוֹת כִּלָּיוֹן וְלָכֶם לִתְשׁוּעָה וְגַם־זֹאת יָצְאָה מֵעִם הָאֱלֹהִים׃
\v 29 \vp כט\vp* אֲשֶׁר נָתַן לָכֶם גַּם־לְהַאֲמִין בַּמָּשִׁיחַ וְגַם־לְהִתְעַנּוֹת בִּגְלָלוֹ׃
\v 30 \vp ל\vp* וְנַפְתּוּלֵי אֱלֹהִים נִפְתַּלְתֶּם כָּמֹנִי כַּאֲשֶׁר רְאִיתֶם אֹתִי וְכַאֲשֶׁר הִנְּכֶם שֹׁמְעִים עָלַי כַּיּוֹם הַזֶּה׃
\c 2
\cp ב
\cl פרק ב
\p 
\v 1 \vp א\vp* לָכֵן אִם־יֵשׁ נֹחַם מָה בַּמָּשִׁיחַ אִם־יֵשׁ אַהֲבָה מְשִׁיבַת נָפֶשׁ אִם־יֵשׁ חִבּוּר הָרוּחַ אִם־יֵשׁ רַחֲמִים וַחֲסָדִים׃
\v 2 \vp ב\vp* הַשְׁלִימוּ־נָא שְׂשׂוֹן לְבָבִי וְהִתְאַחֲדוּ בְדֵעָה אַחַת אַהֲבָה אַחַת נֶפֶשׁ אַחַת וְלֵב אֶחָד׃
\v 3 \vp ג\vp* אַל־תַּעֲשׂוּ דָבָר בִּמְרִיבָה אוֹ בִּכְבוֹד שָׁוְא כִּי אִם־בְּעַנְוַתְכֶם תַּחְשְׁבוּ אִישׁ אֶת־אָחִיו לְגָדוֹל מִמֶּנּוּ׃
\v 4 \vp ד\vp* אַל־יָחוּשׁ אִישׁ לְטוֹבַת נַפְשׁוֹ לְבַדּוֹ כִּי אִם־גַּם לְטוֹבַת רֵעֵהוּ׃
\v 5 \vp ה\vp* וִיהִי כֵן לִבְּכֶם כִּלְבַב יֵשׁוּעַ הַמָּשִׁיחַ׃
\v 6 \vp ו\vp* הוּא אֲשֶׁר בְּמוֹצָאֹתָיו נִמְצָא בִדְמוּת אֱלֹהִים וּבְכָל־זֹאת לֹא חָשַׁב הֱיוֹתוֹ שָׁוֶה לֵאלֹהִים כְּשָׁלָל לוֹ׃
\v 7 \vp ז\vp* כִּי אִם־הִתְנַצֵּל אֶת־כְּבוֹדוֹ וַיִּלְבַּשׁ דְּמוּת עָבֶד וַיְהִי כְּתַבְנִית אַחַד הָאָדָם׃
\v 8 \vp ח\vp* וְאַחֲרֵי אֲשֶׁר נִמְצָא כְאָדָם לַתֹּאַר הִשְׁפִּיל נַפְשׁוֹ וַיִּכָּנַע עַד־מָוֶת עַד־מוּת עַל־הָעֵץ׃
\v 9 \vp ט\vp* עַל־כֵּן גַּם־הָאֱלֹהִים הֵרִימוֹ עָל וַיִּתֶּן־לוֹ שֵׁם נַעֲלֶה מִכָּל־שֵׁם׃
\v 10 \vp י\vp* כִּי לְשֵׁם יֵשׁוּעַ תִּכְרַע כָּל־בֶּרֶךְ אֲשֶׁר בַּשָּׁמַיִם וַאֲשֶׁר בָּאָרֶץ וַאֲשֶׁר מִתַּחַת לָאָרֶץ׃
\v 11 \vp יא\vp* וְכָל־לָשׁוֹן תִּשָּׁבַע כִּי יֵשׁוּעַ הַמָּשִׁיחַ הוּא הָאָדוֹן לִכְבוֹד אֱלֹהִים הָאָב׃
\v 12 \vp יב\vp* עַל־כֵּן אֲהוּבֵי נַפְשִׁי כַּאֲשֶׁר שְׁמַעְתֶּם אֵלַי תָּמִיד בִּהְיוֹתִי לִפְנֵיכֶם וְגַם־עוֹד יֶתֶר הַרְבֵּה כַּיּוֹם בִּהְיוֹתִי מֵרָחוֹק עִבְדוּ בְיִרְאָה וּבִרְעָדָה לְיֵשַׁע נַפְשְׁכֶם׃
\v 13 \vp יג\vp* כִּי אֱלֹהִים הוּא הַנֹּתֵן לָכֶם כֹּחַ לַחְפֹּץ וְגַם־לַעֲשׂוֹת כְּחֶפְצוֹ׃
\v 14 \vp יד\vp* וְכֹל אֲשֶׁר תַּעֲשׂוּ עֲשׂוּ בִּבְלִי תְלוּנָּה וּבִבְלִי מָדוֹן׃
\v 15 \vp טו\vp* לְבַעֲבוּר תִּהְיוּ זַכִּים וּתְמִימִים כִּבְנֵי אֱלֹהִים בִּבְלִי־מוּם בְּתוֹךְ דּוֹר עִקֵּשׁ ופְתַלְתֹּל אֲשֶׁר־תָּאִירוּ בֵינֵיהֶם כִּמְאֹרֹת עֲלֵי־הָאָרֶץ׃
\v 16 \vp טז\vp* כִּי תֹאחֲזוּן בִּדְבַר הַחַיִּים לִהְיוֹת לִי לְתִפְאֶרֶת בְּיוֹם הַמָּשִׁיחַ כִּי לֹא חַשְׁתִּי לָרִיק וְלֹא יָגַעְתִּי לַתֹּהוּ׃
\v 17 \vp יז\vp* וְגַם לוּ יִשָּׁפֵךְ דָּמִי עֲלֵי־זֶבַח וַעֲבֹדָה לֶאֱמוּנַתְכֶם אָשִׂישׂ עַל־כֻּלְּכֶם וְאָגִילָה׃
\v 18 \vp יח\vp* וְכֵן שִׂישׂוּ גַם־אַתֶּם וְגִילוּ עִמָּדִי׃
\v 19 \vp יט\vp* וַאֲנִי תוֹחַלְתִּי בְיֵשׁוּעַ אֲדֹנֵינוּ לִשְׁלֹחַ לָכֶם מְהֵרָה אֶת־טִימוֹתִיּוֹס לְהָשִׁיב נַפְשִׁי גַּם־אֲנִי כַּאֲשֶׁר אֵדַע מָה עִמָּכֶם׃
\v 20 \vp כ\vp* כִּי זוּלָתוֹ אֵין־אִתִּי אִישׁ כִּלְבָבִי הַדֹּאֵג לָכֶם מִמּקוֹר נַפְשׁוֹ׃
\v 21 \vp כא\vp* כִּי כֻלָּם חֶפְצֵי נַפְשָׁם יִדְרֹשׁוּן וְלֹא חֶפְצֵי יֵשׁוּעַ הַמָשִׁיחַ׃
\v 22 \vp כב\vp* וְרַק אֹתוֹ יְדַעְתֶּם כִּי צָרוּף הוּא בַּעֲלִיל וּכְבֵן לִפְנֵי אָבִיו עָבַד עִמִּי בְּמַלְאֲכוּת הַבְּשׂרָה׃
\v 23 \vp כג\vp* אַקֲוֶּה כִּי אֶשְׁלָחֶנּוּ לָכֶם בְּקֶרֶב הַיָמִים אַחֲרֵי אֲשֶׁר אֶרְאֶה מַה־יֵּעָשֶׂה בִּי׃
\v 24 \vp כד\vp* אַךְ בַּאֲדֹנֵינוּ בָטַחְתִּי כִּי גַם־אָנֹכִי אָבוֹא אֲלֵיכֶם מְהֵרָה׃
\v 25 \vp כה\vp* וְרָאִיתִי כִּי נָכוֹן הַדָּבָר לִשְׁלֹחַ לָכֶם אֶת־אֶפַּפְרוֹדִיטוֹס אָחִי סוֹמֵךְ יָדִי בַּעֲבֹדָתִי וְגֶבֶר עֲמִיתִי בְּמִלְחַמְתִּי הֲלֹא הוּא הַשָּׁלוּחַ מִכֶּם וְהַנֹּתֵן לִי מַחְסֹרָי׃
\v 26 \vp כו\vp* כִּי נִכְסְפָה נַפְשׁוֹ לְכֻלְּכֶם וְיִתְעַצֵּב אֶל־לִבּוֹ בַּעֲבוּר אֲשֶׁר שְׁמַעְתֶּם כִּי חָלָה׃
\v 27 \vp כז\vp* כִּי אָמֵן חָלֹה חָלָה וְנָטָה לָמוּת אַךְ הָאֱלֹהִים הִטָּה אֵלָיו חָסֶד וְלֹא אֵלָיו לְבַדּוֹ כִּי אִם־גַּם אֵלַי לְבִלְתִּי הוֹסִיף לִי יָגוֹן עַל־יָגוֹן׃
\v 28 \vp כח\vp* עַל־כֵּן חַשְׁתִּי לְשָׁלְחוֹ לְמַעַן תִּרְאֻהוּ וְתָשִׂישׂוּ בוֹ וְנִגְרַע יָגוֹן מִמֶּנִּי׃
\v 29 \vp כט\vp* אֲשֶׁר לָזֹאת קַדְּמוּ פָנָיו בַּאֲדֹנֵינוּ בְּשָׂשׂוֹן רָב וְהָבוּ כָבוֹד לַאֲנָשִׁים כָּמֹהוּ׃
\v 30 \vp ל\vp* כִּי הִגִּיעָ עַד־שַׁעֲרֵי מָוֶת בַּעֲבוּר עֲבֹדַת הַמָּשִׁיחַ וַיַּשְׁלֵךְ נַפְשׁוֹ מִנֶּגֶד לְמַעַן הִמָּנוֹת הַחֶסְרוֹן אֲשֶׁר קָצְרָה יֶדְכֶם לְסָמְכֵנִי׃
\c 3
\cp ג
\cl פרק ג
\p 
\v 1 \vp א\vp* וְיֶתֶר הַדְּבָרִים אַחַי הִנְנִי אֹמֵר שִׂמְחוּ בַאֲדֹנֵינוּ הֵן לִכְתֹּב אֲלֵיכֶם מִשְׁנֶה דָבָר לֹא לְטֹרַח עָלַי וְטוֹב לָכֶם כִּי אֲשַׁנֵּן דְּבָרָי׃
\v 2 \vp ב\vp* הִשָּׁמְרוּ מִפְּנֵי הַכְּלָבִים הִשָּׁמְרוּ מִפְּנֵי פֹעֲלֵי אָוֶן הִשָּׁמְרוּ מִפְּנֵי קְצוּצֵי עָרְלָה׃
\v 3 \vp ג\vp* כִּי אֲנַחְנוּ בְּנֵי בְרִית הַמּוּלוֹת אֲנָחְנוּ אֲשֶׁר נַעֲבֹד אֶת־אֱלֹהִים בָּרוּחַ וַאֲשֶׁר בְּיֵשׁוּעַ הַמָּשִׁיחַ נִתְהַלֵּל וְלֹא נָשִׂים בְּבָשָׂר מִבְטָחֵנוּ׃
\v 4 \vp ד\vp* אַף כִּי יֶשׁ־לִי לִבְטֹחַ גַּם־בְּבָשָׂר וְאִם־יָשִׂים אִישׁ בַּבָּשָׂר מִבְטַחוֹ הֲלֹא רַב לִי מִמֶּנּוּ׃
\v 5 \vp ה\vp* נִמּוֹל בֶּן־שְׁמֹנַת יָמִים מִגֶּזַע יִשְׂרָאֵל מִשֵּׁבֶט בִּנְיָמִין עִבְרִי בֶּן־עִבְרִי וּבְדַת הַתּוֹרָה פָּרוּשׁ׃
\v 6 \vp ו\vp* מִצַּד הַקִּנְאָה רָדַפְתִּי אֶת־עֲדַת הַמָּשִׁיחַ וּמִצַּד צִדְקַת הַתּוֹרָה לֹא נִמְצָא בִי שֶׁמֶץ דָּבָר׃
\v 7 \vp ז\vp* אַךְ־מוֹתַר כָּל־אֵלֶּה חָשַׁבְתִּי לִי לְמַחְסוֹר בַּעֲבוּר הַמָּשִׁיחַ׃
\v 8 \vp ח\vp* כִּי אָמֵן הֲלֹא אֶת־כֹּל אֲחַשְּׁבָה לְחֶסְרוֹן מִפְּנֵי יִתְרוֹן דַּעַת יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנִי אֲשֶׁר הִתְנַצַּלְתִּי בַעֲבוּרוֹ אֶת־כֹּל אֲשֶׁר לִי וּלְדֹמֶן חֲשַׁבְתִּים לְמַעַן יִהְיֶה לִּי הַמָּשִׁיחַ שְׂכָרִי׃
\v 9 \vp ט\vp* לְהִמָּצֵא דָבֵק בּוֹ אָנֹכִי אֲשֶׁר צִדְקָתִי אֵינֶנָּה מִן־הַתּוֹרָה כִּי אִם־מִמְּקוֹר אֱמוּנַת הַמָּשִׁיחַ הִיא הַצְּדָקָה מִמְּקוֹר אֱלֹהִים בָּאֱמוּנָה׃
\v 10 \vp י\vp* כִּי אֹתוֹ אֲבַקֵּשׁ לָדַעַת עִם־עֹז תְּקוּמָתוֹ לָקַחַת חֵלֶק בְּמַכְאֹבָיו וְלִהְיוֹת כְּמַתְכֻּנְתּוֹ בְּמוֹתוֹ׃
\v 11 \vp יא\vp* אוּלַי אוּכַל לַעֲמֹד לְגוֹרָלִי לִתְקוּמָה מִן־הַמֵּתִים׃
\v 12 \vp יב\vp* לֹא כְמוֹ אִם־כְּבָר הִשַּׂגְתִּי חֶפְצִי אוֹ הִגַּעְתִּי עַד־תַּכְלִית אֲבָל אָרוּץ אַחֲרָיו אוּלַי אֲשִׂיגֶנּוּ כַּאֲשֶׁר בַּעֲבוּר זֶה נֶאֱחַזְתִּי בְיַד יֵשׁוּעַ הַמָּשִׁיחַ גַּם־אֲנִי׃
\v 13 \vp יג\vp* אַחַי לֹא אָמַרְתִּי בְלִבִּי כִּי הִשַּׂגְתִּי חֶפְצִי אַךְ־אַחַת אָמַרְתִּי לִשְׁכֹּחַ אֶת־אֲשֶׁר מֵאַחֲרַי וְלִנְטוֹת בְּכָל־מְאֹדִי אֶל־אֲשֶׁר לְפָנָי׃
\v 14 \vp יד\vp* וְרָץ אֲנִי אֶל־הַמַּטָּרָה אֶל־שְׂכַר הַמְּרוּצָה כַּאֲשֶׁר קְרָאַנִי אֱלֹהִים וַיְרוֹמְמֵנִי בְּיֵשׁוּעַ הַמָּשִׁיחַ׃
\v 15 \vp טו\vp* וְעַתָּה כָּל־הַשְּׁלֵמִים מֵאִתָּנוּ כְּמוֹ כֵן יַחְשֹׁבוּ וְאִם־יֵשׁ בֵּינֵיכֶם הַחֹשְׁבִים לֹא־כֵן גַּם־זֹאת יְגַלֶּה לָכֶם אֱלֹהִים׃
\v 16 \vp טז\vp* רַק אֶל־אֲשֶׁר הִגָּעְנוּ בַּמְּסִלָּה הַזֹּאת נִתְהַלֵּכָה בְּמַעְגָּל אֶחָד וּבְלֵב אֶחָד׃
\v 17 \vp יז\vp* לְכוּ אַחַי בְּעִקְּבוֹתַי וְהִתְבּוֹנְנוּ אֶל־הַהֹלְכִים כֵּן כַּאֲשֶׁר הָיִינוּ לָכֶם לְמוֹפֵת׃
\v 18 \vp יח\vp* כִּי רַבִּים הֵם הַהֹלְכִים אֲשֶׁר אָמַרְתִּי לָכֶם עַל־אֹדוֹתָם וְעַתּה גַם־בִּבְכִי אֲנִי אֹמֵר כִּי־אֹרְבֵי צְלִיב הַמָּשִׁיחַ הֵם׃
\v 19 \vp יט\vp* אֲשֶׁר אֲחֲרִיתָם אֲבדּוֹן וֵאלֹהֵיהֶם הוּא הַבֶּטֶן וּכְבוֹדָם בְּבָשְׁתָּם וְאַף־הֶגְיוֹנָם הַבְלֵי חָלֶד׃
\v 20 \vp כ\vp* כִּי הֶגְיוֹנֵנוּ הֶגְיוֹן אֶזְרָחִים בַּשָּׁמָיִם אֲשֶׁר מִשָּׁם נְחַכֶּה לְמוֹשִׁיעֵנוּ הוּא יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ׃
\v 21 \vp כא\vp* אֲשֶׁר יְשַׁנֶּה אֶת־גּוּפֵנוּ הַשָּׁפֵל וִישַׁוֵּהוּ בְתֹאַר גּוּף כְּבוֹדוֹ כְּפִי־פְעֻלַּת כֹּחוֹ אֲשֶׁר בְּיָדוֹ לָשִׁית כֹּל תַּחַת־רַגְלָיו׃
\c 4
\cp ד
\cl פרק ד
\p 
\v 1 \vp א\vp* עַל־כֵּן אַחִים אֲהוּבִים מַחֲמַדֵּי נַפְשִׁי מְשׂוֹשׂ לִבִּי וַעֲטֶרֶת רֹאשִׁי עִמְדוּ הָכֵן לִפְנֵי אֲדֹנֵינוּ יְדִידִים׃
\v 2 \vp ב\vp* הִנְנִי דֹרֵשׁ מִן־אַבְהוֹדִיָּה וְגַם כֵּן מִן־סוּנְטִיכִי לְהִתְהַלֵּךְ בְּלֵב אֶחָד לִפְנֵי אֲדֹנֵינוּ׃
\v 3 \vp ג\vp* וְאֵלֶיךָ חָבֵר נֶאֱמָן הַנִּצְמָד־לִי בַּעֲבֹדָה אֶקְרָא־נָא לַעֲזֹר לָהֶן אֲשֶׁר עָבְדוּ עִמִּי יַחְדָּו בְּמַלְאֲכוּת הַבְּשׂרָה עִם־קְלִימִיס וְעִם־יֶתֶר סֹמְכֵי יָדִי אֲשֶׁר שְׁמוֹתָם בְּסֵפֶר הַחַיִּים׃
\v 4 \vp ד\vp* שִׂישׂוּ בַאֲדֹנֵינוּ תָּמִיד וְעוֹד אֶשְׁנֶה לֵאמֹר שִׂישׂוּ בוֹ מָשׂוֹשׂ׃
\v 5 \vp ה\vp* עַנְוַת רוּחֲכֶם תִּוָּדַע לְכָל־בְּנֵי אָדָם קָרוֹב הוּא אֲדֹנֵינוּ׃
\v 6 \vp ו\vp* הַרְחִיקוּ כָל־דְּאָגָה מִכֶּם אַךְ הוֹדִיעוּ כָל־מִשְׁאֲלוֹתֵיכֶם בִּתְפִלָּה בִּתְחִנָּה וּבְתוֹדָה לֵאלֹהֵינוּ׃
\v 7 \vp ז\vp* וְהָאֱלֹהִים יְצַו אֶת־שְׁלוֹמוֹ אֲשֶׁר לֹא יְכִילֶנּוּ כָל־שֵׂכֶל לִנְצֹר אֶת־לִבְּכֶם וְאֶת־הֶגְיוֹן רוּחֲכֶם בְּיֵשׁוּעַ הַמָּשִׁיחַ׃
\v 8 \vp ח\vp* סוֹף דָּבָר אַחַי שִׂימוּ לִבְּכֶם אֵיזֶה דָבָר אֱמֶת הוּא אֵיזֶה נִכְבָּדוֹת בּוֹ וְאֵיזֶה מְכוֹנוֹ ישֶׁר אֵיזֶה הוּא זָךְ אֵיזֶה הוּא נֶחְמָד וְאֵיזֶה לוֹ שֵׁם טוֹב אִם־יֵשׁ מַעֲשֵׂה צְדָקָה אוֹ דָבָר לוֹ נָאוָה תְהִלָּה שִׂימוּ לִבְּכֶם לְכָל־אֵלֶּה׃
\v 9 \vp ט\vp* וְכֹל אֲשֶׁר לְמַדְתֶּם וְקִבַּלְתֶּם וּכְמַעֲשַׂי אֲשֶׁר שְׁמַעְתֶּם אוֹ רְאִיתֶם כֵּן תַּעֲשׂוּ גַּם־אַתֶּם וֵאלֹהֵי הַשָּׁלוֹם יְהִי עִמָּכֶם׃
\v 10 \vp י\vp* וַאֲנִי שָׂמַחְתִּי בַאֲדֹנֵינוּ עַד־מְאֹד כִּי עוֹד יָנוּב חֵילְכֶם וְתָשִׂימוּ עַיִן לָחוּשׁ לִי אַף כִּי־עֵינֵיכֶם שַׂמְתֶּם לָחוּשׁ לִי תָמִיד אֲבָל לֹא הָיוּ לָכֶם יָדָיִם׃
\v 11 \vp יא\vp* וְלֹא בַעֲבוּר מַחְסֹרַי אֲנִי דֹבֵר כֵּן כִּי לָמַדְתְּי לִהְיוֹת שָׂמֵחַ בְּחֶלְקִי׃
\v 12 \vp יב\vp* יֹדֵעַ אֲנִי לַעֲמֹד בִּשְׁפַל הַמַּדְרֵגָה וְלַעֲמֹד בִּהְיוֹת לִי דַּי וְהוֹתֵר בְּכָל־מָקוֹם וּבְכָל־עֵת הִסְכַּנְתִּי לִשְׂבֹּעַ וְגַם־לִרְעָב לִחְיוֹת בְּמוֹתָר וְגַם־בְּמַחְסוֹר׃
\v 13 \vp יג\vp* אֶת־כֹּל אוּכַל בְּיַד הַמָּשִׁיחַ הַמְאַזְּרֵנִי חָיִל׃
\v 14 \vp יד\vp* אֲבָל אַתֶּם הֵיטַבְתֶּם עֲשׂוֹ כִּי הִתְחַבַּרְתֶּם עִמִּי בְּצָרָתִי׃
\v 15 \vp טו\vp* גַּם־דְּעוּ־נָא בְּנֵי פִילִפִּי כְּצֵאתִי מִן־מַקְדּוֹנְיָא בִּתְחִלַּת הַבְּשׂרָה לֹא הָיְתָה עֵדָה אֲשֶׁר־בָּאָה בְדִבְרֵי מַשָּׂא וּמַתָּן עִמָּדִי זוּלָתִי אַתֶּם לְבַדְּכֶם׃
\v 16 \vp טז\vp* כִּי גַּם־לְתַסְלוֹנִיקִי שְׁלַחְתֶּם לִי פַּעַם וּשְׁתַּיִם דֵּי מַחְסֹרָי׃
\v 17 \vp יז\vp* וְלֹא מַתָּן אֲנִי מְבַקֵּשׁ כִּי אִם־פֶּרְיְכֶם מְבַקֵּשׁ אֲנִי כִּי יִשְׂגֶּה לָכֶם לָרֹב׃
\v 18 \vp יח\vp* אַךְ עַתָּה יֶשׁ־לִי כֹל דַּי וְהוֹתֵר וַאֲנִי מָלֵאתִי כִּי לָקַחְתִּי מִיַּד אֶפַּפְרוֹדִיטוֹס אֶת־אֲשֶׁר שְׁלַחְתֶּם לִי לְרֵיחַ נִיחֹחַ מִנְחָה עֲרֵבָה לְרָצוֹן לֵאלֹהִים׃
\v 19 \vp יט\vp* וֵאלֹהַי יְמַלֵּא כָל־מַחְסֹרְכֶם בְּעָשְׁרוֹ וּבִכְבוֹדוֹ בְּיֵשׁוּעַ הַמָּשִׁיחַ׃
\v 20 \vp כ\vp* וְלֵאלֹהֵינוּ אָבִינוּ הַכָּבוֹד לְעוֹלָם וָעֶד אָמֵן׃
\v 21 \vp כא\vp* שַׁאֲלוּ לִשְׁלוֹם כָּל־הַקְּדוֹשִׁים בְּיֵשׁוּעַ הַמָּשִׁיחַ הָאַחִים אֲשֶׁר עִמָּדִי שֹׁאֲלִים לִשְׁלוֹמְכֶם׃
\v 22 \vp כב\vp* כָּל־הַקְּדוֹשִׁים שֹׁאֲלִים לִשְׁלוֹמְכֶם וּבְרֹאשָׁם אֵלֶּה אֲשֶׁר מִבֵּית קֵיסָר׃
\v 23 \vp כג\vp* חֶסֶד יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ עִם־כֻּלְכֶם אָמֵן׃ 
