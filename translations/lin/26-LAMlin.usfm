\id LAM Biblica® Open Lingala Contemporary Bible 2020
\h Bileli
\toc1 Bileli
\toc2 Bileli
\toc3 Bi
\mt1 Bileli
\c 1
\ms1 Nzembo ya liboso ya mawa : Yelusalemi esundolami na maboko ya banguna na yango
\s1 Yelusalemi ezali na matanga
\q1 
\v 1 Tala ndenge nini engumba oyo, na kala,
\q2 ezalaki na bato ebele penza,
\q1 etikali lisusu na bato te !
\q2 Tala ndenge nini engumba
\q1 oyo ezalaki na lokumu kati na bikolo
\q2 ekomi lelo lokola mwasi akufisa mobali ;
\q1 oyo ezalaki engumba mokonzi
\q2 ekomi lelo na bowumbu !
\b
\q1 
\v 2 Butu mobimba, azali kolela se kolela,
\q2 mpinzoli etondi na matama na ye.
\q1 Kati na bamakangu na ye nyonso,
\q2 moko te ayei kobondisa ye ;
\q1 baninga na ye nyonso bakosi ye,
\q2 bakomi banguna na ye.
\b
\q1 
\v 3 Yuda akei na bowumbu,
\q2 akomi konyokwama mpe kosala misala makasi ;
\q1 azali kovanda kati na bikolo,
\q2 azali lisusu na esika ya kopema te.
\q1 Bato nyonso oyo bazali kolanda ye,
\q2 bakangi ye kati na pasi makasi.
\b
\q1 
\v 4 Nzela oyo ekenda kino na Siona ezali na matanga,
\q2 pamba te bato bazali koya lisusu na bafeti te.
\q1 Bikuke na ye nyonso etikali lisusu na bato te,
\q2 Banganga-Nzambe na ye bazali kolela,
\q1 bana na ye ya basi oyo bayebi nanu nzoto ya mibali te
\q2 bazali na mawa ;
\q2 bongo ye moko akomi na pasi makasi kati na motema.
\b
\q1 
\v 5 Banguna na ye bakomi bakonzi na ye,
\q2 bayini na ye bazali na esengo ;
\q1 pamba te Yawe atindeli Siona pasi
\q2 likolo ya ebele ya masumu na ye.
\q1 Bana na ye ya mibali bakei na bowumbu,
\q2 bakangi bango mpe bazali kotambola
\q2 liboso ya monguna na ye.
\q1 
\v 6 Lokumu nyonso ya Siona, mboka kitoko, esili ;
\q2 bakambi na ye bakomi lokola mboloko
\q1 oyo ezangi matiti ya kolia,
\q2 mpe bazali kokima, makasi na bango esili
\q2 liboso ya moto oyo azali kolanda bango.
\b
\q1 
\v 7 Na mikolo na ye ya pasi mpe ya koyengayenga,
\q2 tango bato na ye bazali kokweya na maboko ya banguna
\q1 mpe moto akosunga ye azali te,
\q2 Yelusalemi azali kokanisa bomengo na ye nyonso ya kala ;
\q1 bayini na ye batali ye na pamba
\q2 mpe basepeli na kobebisama na ye.
\b
\q1 
\v 8 Yelusalemi asali masumu mingi penza,
\q2 yango wana akomi mbindo.
\q1 Bato nyonso oyo bazalaki kopesa ye lokumu
\q2 bakomi kotiola ye,
\q1 pamba te bamoni bolumbu na ye ;
\q2 ye moko mpe azali komilela
\q2 mpe abaluki mpo na kobomba elongi.
\b
\q1 
\v 9 Mbindo na ye ekangami ye na elamba,
\q2 ayebaki te makambo nini ekokomela ye na sima.
\q1 Tala ye wana akweyi,
\q2 bongo kokweya na ye ezali kokamwisa ;
\q1 moto oyo akolendisa ye azali te !
\q2 « Oh Yawe, tala pasi na ngai,
\q2 pamba te monguna alongi ngai ! »
\b
\q1 
\v 10 Monguna asemboli loboko na ye
\q2 likolo ya bomengo nyonso ya Yelusalemi,
\q1 bongo azali komona bikolo ya bapaya
\q2 kokota na esika na ye ya bule,
\q2 bikolo oyo Yo opekisaki kokota kati na lisanga na Yo.
\b
\q1 
\v 11 Bato na ye nyonso bazali kolela
\q2 lokola bato bazali koluka bilei ;
\q1 bapesaki bomengo na bango mpo na kozwa bilei,
\q2 mpo ete bawumela na bomoi.
\q2 Oh Yawe, tala mpe mona ndenge natiolami !
\b
\q1 
\v 12 Bino bato nyonso oyo bolekelaka wana ;
\q2 boni, ezali kosala bino eloko moko te ?
\q1 Botala malamu zingazinga na bino,
\q2 ezali na pasi lokola pasi oyo ekomeli ngai ?
\q1 Yawe atindeli ngai yango
\q2 na mokolo ya kanda makasi na Ye.
\q1 
\v 13 Wuta na likolo, atindeli ngai moto,
\q2 akitiseli ngai yango kino na mikuwa ;
\q1 atieli ngai motambo na makolo
\q2 mpe akweyisi ngai ;
\q1 akomisi ngai eloko ya pamba,
\q2 akotisi ngai na mawa ya mokolo na mokolo.
\b
\q1 
\v 14 Maboko na Ye ekangi masumu na ngai
\q2 ndenge bakangaka ekangiseli ;
\q1 masumu yango emati ngai kino na kingo,
\q2 mpe Nkolo asilisi makasi na ngai,
\q1 akabi ngai na maboko ya bato
\q2 oyo nazali na makoki ya kotelemela te.
\b
\q1 
\v 15 Yawe asundoli bilombe nyonso ya bitumba
\q2 oyo bazalaki na milongo na ngai ;
\q1 abengi mampinga ya bapaya
\q2 mpo ete baya koboma bilenge mibali na ngai.
\q1 Nkolo akamoli Yuda, mboka kitoko,
\q2 na ekamolelo na Ye ya vino.
\b
\q1 
\v 16 Tala tina nini nazali kolela
\q2 mpe miso na ngai etondi na mpinzoli ;
\q1 moto moko te ayei pene na ngai
\q2 mpo na kobondisa ngai,
\q1 moto moko te ayei kolendisa molimo na ngai.
\q2 Bana na ngai bazali na pasi,
\q2 mpo ete monguna aleki ngai na makasi.
\b
\q1 
\v 17 Siona atomboli maboko na ye,
\q2 kasi moto oyo akobondisa ye azali te.
\q1 Yawe azwi mokano mpo na Jakobi
\q2 ete bazalani na ye bakokoma banguna na ye,
\q1 mpe ete Yelusalemi akokoma
\q2 eloko ya mbindo na miso na bango.
\b
\q1 
\v 18 Yawe azali sembo ;
\q2 nzokande, ezali ngai nde natombokelaki mitindo na Ye.
\q1 Boyoka, bino bikolo nyonso,
\q2 mpe botala pasi na ngai !
\q1 Bana na ngai ya basi mpe ya mibali
\q2 bakei na bowumbu.
\b
\q1 
\v 19 Nabengisaki baninga na ngai,
\q2 kasi bakosaki ngai.
\q1 Banganga-Nzambe mpe bakambi na ngai
\q2 bakufaki kati na engumba
\q1 tango bazalaki koluka bilei
\q2 mpo ete bawumela na bomoi.
\q1 
\v 20 Oh Yawe, tala ndenge nazali na pasi :
\q2 libumu na ngai ezali kotungisama,
\q1 mpe motema na ngai ezali kosala pasi,
\q2 pamba te nazalaki motomboki penza.
\q1 Na libanda, mopanga ezali koboma bana na ngai ;
\q2 mpe na kati, ezali kaka kufa.
\b
\q1 
\v 21 Bato bayokaki na bango kolela na ngai,
\q2 kasi moto akobondisa ngai azali te ;
\q1 banguna na ngai nyonso bayokaki sango ya pasi na ngai
\q2 mpe basepelaki na makambo oyo osalaki.
\q1 Tika ete okokisa solo mokolo oyo olakaki,
\q2 mpo ete bango mpe bakoma lokola ngai !
\b
\q1 
\v 22 Tika ete mabe na bango nyonso eya liboso na Yo ;
\q2 sala bango ndenge osalaki ngai
\q2 mpo na masumu nyonso oyo nasalaki !
\q1 Kolela na ngai ezali mingi
\q2 mpe motema na ngai etondi na pasi !
\c 2
\ms1 Nzembo ya mibale ya mawa : kanda ya Yawe
\s1 Yawe apesi Yelusalemi etumbu
\q1 
\v 1 Tala ndenge nini Nkolo azipi Siona, mboka kitoko,
\q2 na lipata ya kanda na Ye :
\q1 akweyisi lokumu ya Isalaele,
\q2 wuta na likolo kino na se ;
\q1 na mokolo ya kanda na Ye,
\q2 abosanaki enyatelo makolo na Ye !
\b
\q1 
\v 2 Na kozanga mawa, Nkolo abebisi bandako nyonso
\q2 ya Jakobi ;
\q1 na kanda na Ye, akweyisi bandako batonga makasi
\q2 ya Yuda, mwasi kitoko,
\q2 mpe asambwisi bokonzi mpe bakambi na yango.
\b
\q1 
\v 3 Na kanda makasi na Ye,
\q2 abukaki Isalaele maseke nyonso,
\q1 alongolaki loboko na Ye ya mobali
\q2 na likolo na yango
\q1 tango monguna na bango azalaki kopusana ;
\q2 apelisaki moto kati na mokili ya Jakobi
\q1 lokola moto makasi oyo etumbaka biloko nyonso
\q2 na bangambo na yango nyonso.
\b
\q1 
\v 4 Lokola moyini, abendi tolotolo na Ye ;
\q2 lokola monguna, asemboli loboko na Ye
\q1 mpe abomi nyonso oyo ezalaki kosepelisa miso ;
\q2 mpe asopi kanda makasi na Ye lokola moto
\q2 na likolo ya bandako ya kapo ya Siona, mboka kitoko.
\b
\q1 
\v 5 Yawe akomi lokola monguna :
\q2 abebisi mokili ya Isalaele,
\q1 abebisi bandako nyonso ya mokonzi ya Isalaele,
\q2 abuki bandako na yango batonga makasi,
\q1 atondisi matanga mpe kolela
\q2 kati na Yuda, mboka kitoko.
\b
\q1 
\v 6 Abebisi lopango na ye
\q2 ndenge babebisaka lopango ya elanga,
\q2 abebisi esika na bango ya mayangani.
\q1 Na kanda makasi na Ye,
\q2 Yawe asali ete Siona abosana
\q1 bafeti oyo ekatama mpe mikolo ya Saba ;
\q2 mpe apameli mokonzi mpe Nganga-Nzambe.
\b
\q1 
\v 7 Yawe abwaki etumbelo na ye,
\q2 asundoli esika na ye ya bule
\q1 mpe akabi na maboko ya monguna
\q2 bamir mpe bandako ya mokonzi na yango.
\q1 Bato bagangi makasi kati na Tempelo ya Yawe
\q2 ndenge bagangaka na mokolo ya feti oyo ekatama.
\b
\q1 
\v 8 Yawe akani kobuka bamir
\q2 oyo ezingeli Siona, mboka kitoko ;
\q1 atandi singa ya komekela molayi
\q2 mpe azongisi loboko na Ye na sima te
\q1 mpo na kobebisa ;
\q2 abebisi bamir oyo ebatelaka engumba mpe bamir mosusu ;
\q2 bongo akweyisi yango nyonso.
\b
\q1 
\v 9 Bikuke na yango ezindi na mabele ;
\q2 abuki-buki mpe abebisi banzete oyo
\q2 bakangelaka bikuke yango.
\q1 Mokonzi mpe bakambi na ye bakei
\q2 na bowumbu kati na bikolo,
\q1 Mobeko ezali lisusu te,
\q2 mpe basakoli na ye bazali kozwa lisusu te
\q2 bimoniseli kowuta na Yawe.
\b
\q1 
\v 10 Bampaka ya Siona, mboka kitoko,
\q2 bavandi kimia na mabele,
\q1 bamisopeli putulu na mito na bango mpe balati basaki ;
\q2 bongo bilenge basi ya Yelusalemi bafukami,
\q2 bilongi na bango kino na se.
\b
\q1 
\v 11 Miso na ngai elembi kobimisa mpinzoli,
\q2 nazali komitungisa,
\q1 libumu na ngai ezali kobaluka,
\q2 motema na ngai ezali kotungisama
\q1 mpo ete bato na ngai babebisami,
\q2 mpo ete bana mpe bana oyo bazali komela mabele
\q2 balembi-lembi banzoto na balabala ya engumba.
\b
\q1 
\v 12 Bazalaki koloba na bamama na bango :
\q2 « Epai wapi tokoki kozwa ble mpe masanga ya vino ? »
\q1 Ndenge bazalaki kokweya-kweya
\q2 lokola bato oyo bazoki bapota minene
\q1 na babalabala ya engumba,
\q2 ndenge wana mpe bazalaki kokufa
\q2 na maboko ya bamama na bango.
\b
\q1 
\v 13 Naloba lisusu nini mpo na yo ?
\q2 Nakokanisa yo na nani,
\q1 Yelusalemi, mboka kitoko ?
\q2 Nakokanisa yo na nani
\q1 mpo ete nakoka kobondisa yo,
\q2 Siona, mboka kitoko ?
\q1 Pota na yo ezali monene lokola ebale monene ;
\q2 nani akoki kobikisa yo ?
\b
\q1 
\v 14 Bimoniseli ya basakoli na yo ezalaki
\q2 ya lokuta mpe ya pamba ;
\q1 balakisaki yo masumu na yo te
\q2 mpo ete okende na bowumbu te :
\q1 masakoli oyo bazwelaki yo
\q2 ezalaki ya mabe mpe ya lokuta !
\b
\q1 
\v 15 Bato nyonso oyo bolekelaka na nzela na yo
\q2 bazali kobeta maboko na kokamwa,
\q1 bazali kobeta piololo mpe koningisa mito
\q2 mpo na Yelusalemi, mboka kitoko :
\q1 « Boni, ezali solo engumba oyo bazalaki kobenga
\q2 kitoko ekoka mpe esengo ya mokili mobimba ? »
\b
\q1 
\v 16 Banguna na yo nyonso bafungoli minoko na bango
\q2 mpo na kotiola yo,
\q1 bazali koseka yo mpe kolia minu na bango ;
\q2 bongo bazali koloba :
\q1 « Tomeli ye ! Tala mokolo oyo tozalaki kozela !
\q2 Tokomi penza na mokolo yango mpe tomoni yango ! »
\b
\q1 
\v 17 Yawe asali makambo oyo abongisaki,
\q2 akokisi liloba na Ye,
\q1 nyonso oyo aloba wuta kala :
\q2 akweyisi yo na mawa te,
\q1 apesi nzela na banguna na yo ete balonga yo,
\q2 atomboli liseke ya banguna na yo.
\b
\q1 
\v 18 Mitema ya bato ezali koganga epai na Nkolo.
\q2 Oh mir ya Siona, mboka kitoko,
\q1 tika ete mpinzoli na yo ebima lokola ebale,
\q2 butu mpe moyi,
\q2 mpe miso na yo ekangama te !
\b
\q1 
\v 19 Telema, ganga na butu
\q2 ndenge bakengeli basalaka na butu ;
\q1 sopa motema na yo lokola mayi, na miso ya Nkolo,
\q2 tombola maboko na yo epai na Ye
\q1 mpo na bomoi ya bana na yo,
\q2 oyo bazali kokufa nzala na babalabala nyonso.
\b
\q1 
\v 20 Oh Yawe, tala mpe mona !
\q2 Nani oyo osalela makambo ya boye ?
\q1 Boni, basi basengelaki solo kolia
\q2 mbuma ya mabumu na bango
\q1 to bana oyo bango moko babokoli ?
\q2 Boni, basengelaki solo koboma mosakoli mpe Nganga-Nzambe
\q2 kati na Esika ya bule ya Nkolo ?
\b
\q1 
\v 21 Bibembe ya bilenge mpe ya mikolo
\q2 elali-lali na babalabala ;
\q1 basali na ngai ya mibali mpe ya basi bakufi na mopanga !
\q2 Obomi bango na mokolo ya kanda na Yo ;
\q2 obomi bango na mawa te !
\b
\q1 
\v 22 Ndenge obengisaka bato na mokolo ya feti,
\q2 ndenge wana mpe obengisaki pasi
\q1 wuta na bangambo nyonso mpo na kosala ngai mabe.
\q2 Na mokolo ya kanda ya Yawe,
\q1 moto moko te abikaki to atikalaki na bomoi.
\q2 Monguna na ngai abebisi bato
\q2 oyo nazalaki kobokola mpe kobatela.
\c 3
\ms1 Nzembo ya misato ya mawa : elikya atako pasi
\s1 Pasi ya mosakoli
\q2 
\v 1 Nazali moto oyo amona pasi
\q2 na nzela ya fimbu ya kanda na Ye.
\q1 
\v 2 Amemaki ngai mpe atambolisaki ngai
\q2 kati na molili, kasi na pole te.
\q1 
\v 3 Solo, mokolo mobimba,
\q2 azalaki kobalola loboko na Ye
\q2 mpo na kotelemela ngai tango nyonso.
\b
\q1 
\v 4 Abebisaki nzoto na ngai mpe poso na yango,
\q2 abukaki mikuwa na ngai.
\q1 
\v 5 Mpo na kotelemela ngai,
\q2 atongaki zingazinga na ngai
\q2 mir ya ngenge mpe ya pasi.
\q1 
\v 6 Atongelaki ngai ndako ya kovanda kati na molili,
\q2 lokola bato ya tango ya kala oyo bakufa.
\b
\q1 
\v 7 Azingelaki ngai na bamir mpo ete nakima te ;
\q2 akangaki ngai na minyololo ya kilo.
\q1 
\v 8 Ezala soki nabeleli mpo na kosenga lisungi,
\q2 azali koyoka libondeli na ngai te.
\q1 
\v 9 Akangaki nzela na ngai na mabanga minene
\q2 mpe abebisaki banzela na ngai ya mike.
\b
\q1 
\v 10 Azalaki mpo na ngai lokola ngombolo oyo ebongami,
\q2 lokola nkosi oyo ebombameli ngai ;
\q1 
\v 11 apengwisaki ngai nzela,
\q2 apasolaki ngai mpe akomisaki ngai eloko ya pamba.
\q1 
\v 12 Abendaki tolotolo na Ye
\q2 mpe akomisaki ngai esika na Ye ya kobamba makonga.
\b
\q1 
\v 13 Atobolaki motema na ngai,
\q2 na makonga oyo ewutaki na libenga na Ye.
\q1 
\v 14 Nakomaki eloko ya liseki
\q2 na miso ya bato na ngai nyonso ;
\q2 bazalaki tango nyonso kotiola ngai na banzembo.
\q1 
\v 15 Atondisaki ngai na matiti ya bololo
\q2 mpe alangwisaki ngai na masanga ya bololo.
\b
\q1 
\v 16 Abukaki minu na ngai na mabanga,
\q2 azindisaki ngai na putulu.
\q1 
\v 17 Nazangaki kimia,
\q2 nayebaki lisusu te nini yango bolamu.
\q1 
\v 18 Boye nalobaki : « Lokumu mpe makambo nyonso
\q2 oyo natielaki elikya na Yawe esili ! »
\s1 Yawe, elikya na ngai
\q1 
\v 19 Nakanisi pasi mpe minyoko na ngai,
\q2 ezali lokola ngenge mpe masanga ya bololo.
\q1 
\v 20 Tango nyonso nakanisaka yango,
\q2 motema na ngai ebukanaka.
\q1 
\v 21 Nzokande, tala makambo oyo nakanisaka ;
\q2 oyo mpo na yango, nazalaka na elikya :
\q1 
\v 22 Bolamu ya Yawe esili te,
\q2 mawa na Ye ekomi nanu na suka te ;
\q1 
\v 23 ekomaka ya sika tongo nyonso.
\q2 Solo, boyengebene na Yo ezali monene !
\q1 
\v 24 Namilobeli : « Yawe azali elikya na ngai ;
\q2 yango wana nakotia motema epai na Ye. »
\b
\q1 
\v 25 Yawe azali malamu
\q2 mpo na bato oyo batielaka Ye elikya,
\q2 mpo na bato oyo balukaka Ye !
\q1 
\v 26 Ezali malamu kozela na kimia
\q2 lobiko kowuta na Yawe !
\q1 
\v 27 Ezali malamu mpo na moto
\q2 komema ekangiseli na ye
\q2 wana azali nanu elenge.
\b
\q1 
\v 28 Tika ete avanda kimia mpe avanda ye moko,
\q2 pamba te Yawe nde alingi bongo mpo na ye.
\q1 
\v 29 Tika ete atia elongi na ye na mabele :
\q2 tango mosusu elikya ekoki kozala.
\q1 
\v 30 Tika ete apesa litama
\q2 mpo ete babeta ye mbata,
\q2 mpe tika ete atonda na soni !
\b
\q1 
\v 31 Pamba te Nkolo abwakaka moto te
\q2 mpo na libela.
\q1 
\v 32 Ezala soki apesi etumbu, ayokaka kaka mawa
\q2 mpo na bolingo monene na Ye.
\q1 
\v 33 Ezalaka na esengo te
\q2 nde Yawe ayokisaka bato soni
\q2 to atindelaka bato pasi.
\b
\q1 
\v 34 Tango banyataka na makolo
\q2 bakangami nyonso ya mokili,
\q1 
\v 35 tango babebisaka lokumu ya moto
\q2 na miso ya Ye-Oyo-Aleki-Likolo,
\q1 
\v 36 tango banyokolaka moto kati na kosambisama,
\q2 boni, Nkolo amonaka yango te ?
\b
\q1 
\v 37 Nani akoki kaka kobimisa liloba
\q2 mpo ete likambo esalema
\q2 soki Nkolo apesi yango nzela te ?
\q1 
\v 38 Boni, ezali te wuta na monoko ya Ye-Oyo-Aleki-Likolo
\q2 nde pasi mpe bolamu ekomelaka bato ?
\q1 
\v 39 Mpo na nini moto na bomoi amilela-lela
\q2 tango bapesi ye etumbu likolo ya masumu na ye ?
\b
\q1 
\v 40 Tokota na mozindo ya kososola banzela na biso
\q2 mpe totala malamu etamboli na biso,
\q2 bongo tozonga epai na Yawe ;
\q1 
\v 41 totombola mitema mpe maboko na biso
\q2 epai ya Nzambe oyo azali na Lola mpe toloba :
\q1 
\v 42 « Tosalaki masumu mpe totombokelaki Yo,
\q2 yango wana olimbisaki te.
\q1 
\v 43 Omizipaki na kanda ndenge bamizipaka liputa,
\q2 onyokolaki biso mpe obomaki na mawa te.
\q1 
\v 44 Omizipaki lipata
\q2 mpo ete mabondeli edusola te.
\q1 
\v 45 Okomisaki biso lokola eloko ya nkele
\q2 mpe ya tina te na miso ya bikolo.
\b
\q1 
\v 46 Banguna na biso nyonso bafungolaki minoko
\q2 mpo na kotiola biso ;
\q1 
\v 47 libula na biso ekomi :
\q2 somo, mabulu, kobebisama mpe kufa. »
\q1 
\v 48 Miso na ngai ezali kosopa miluka ya mpinzoli
\q2 mpo ete bato na ngai babebisami.
\b
\q1 
\v 49 Miso na ngai ezali kobimisa mpinzoli tango nyonso
\q2 mpe ezali kolemba te,
\q1 
\v 50 kino tango Yawe akotala mpe akomona
\q2 wuta kuna na Lola.
\q1 
\v 51 Makambo oyo miso na ngai ezali komona
\q2 ezali koyokisa motema na ngai pasi
\q2 likolo na bana basi nyonso ya engumba na ngai.
\b
\q1 
\v 52 Bato oyo bayinaka ngai na pamba
\q2 balukaki kokanga ngai lokola ndeke ;
\q1 
\v 53 balukaki koboma ngai kati na libulu,
\q2 babwakelaki ngai mabanga ;
\q1 
\v 54 mayi etondaki kino kozipa moto na ngai
\q2 mpe nakanisaki ete nakomi pene ya kokufa.
\b
\q1 
\v 55 Nabelelaki Kombo na Yo, Yawe,
\q2 wuta na mozindo ya libulu.
\q1 
\v 56 Oyokaki ngai libondeli na ngai :
\q2 « Kokanga matoyi na Yo te
\q1 wana nazali kobelela Yo
\q2 mpo ete oyoka kolela na ngai
\q2 mpe nazwa lisungi kowuta na Yo ! »
\q1 
\v 57 Tango nabelelaki Yo,
\q2 opusanaki pene na ngai
\q2 mpe olobaki : « Kobanga te ! »
\b
\q1 
\v 58 Nkolo, obundelaki ngai solo,
\q2 osikolaki bomoi na ngai !
\q1 
\v 59 Yawe, omonaki mabe oyo basalaki ngai :
\q2 longisa ngai !
\q1 
\v 60 Omonaki solo posa na bango
\q2 ya kozongisa mabe na mabe
\q2 mpe mabongisi na bango ya kosala ngai mabe.
\b
\q1 
\v 61 Yawe, oyokaki mafinga na bango,
\q2 mabongisi na bango ya kosala ngai mabe,
\q1 
\v 62 maloba ya bayini na ngai
\q2 mpe makanisi na bango ya kosala ngai mabe.
\q1 
\v 63 Tala mpe mona bango ! Ezala bavandi to batelemi,
\q2 mosala na bango : kotiola ngai na banzembo na bango.
\b
\q1 
\v 64 Yawe, pesa bango lifuti oyo ekoki na bango
\q2 kolanda misala na bango ;
\q1 
\v 65 yeisa mitema na bango makasi,
\q2 kweyisela bango bilakeli mabe na Yo ;
\q1 
\v 66 nyokola bango na kanda makasi na Yo
\q2 mpe bebisa bango na se ya Lola na Yo, Yawe !
\c 4
\s1 Nzembo ya minei : kokakolama ya Siona
\q1 
\v 1 Ndenge nini wolo ebungisi kongenga na yango,
\q2 wolo ya peto enzuluki !
\q1 Mabanga ya talo oyo ya bule epanzani
\q2 na basonge ya babalabala nyonso.
\q1 
\v 2 Ndenge nini bana mibali ya motuya ya Siona,
\q2 oyo, na kala, bazalaki kozwa bango lokola wolo ya peto,
\q1 kasi bakomi lelo komona bango lokola mbeki ya mabele,
\q2 oyo mosali mbeki basili kosala !
\q1 
\v 3 Ata mbwa ya zamba ezalaka na posa
\q2 ya komelisa bana na yango mabele ;
\q1 kasi bato na ngai bakomi mitema makasi
\q2 lokola maligbanga kati na esobe.
\b
\q1 
\v 4 Likolo ya nzala, lolemo ya mwana ekangami
\q2 na likolo ya kati ya monoko na ye ;
\q1 bana mike bazali kosenga bilei
\q2 kasi moto moko te azali kopesa bango yango.
\b
\q1 
\v 5 Bato oyo na kala bazalaki kolia bilei ya kitoko
\q2 bakomi kokufakufa na babalabala ;
\q1 ba-oyo bakolaki na molato ya motane
\q2 bakomi sik’oyo kolalela matiti ya kopola.
\b
\q1 
\v 6 Lisumu oyo bato na ngai basali
\q2 ezali monene koleka lisumu ya Sodome,
\q1 engumba oyo ebebisamaki na mbala moko
\q2 wana moto moko te asembolaki loboko na ye
\q2 mpo na kotelemela yango.
\b
\q1 
\v 7 Bana ya bakonzi na bango bazalaki
\q2 kongala koleka mvula ya pembe,
\q1 pembe koleka miliki ;
\q2 banzoto na bango ezalaki motane
\q1 koleka langi ya motane penza,
\q2 mpe lolenge na bango ezalaki
\q2 lokola libanga na safiri.
\b
\q1 
\v 8 Bilongi na bango ekomi mwindo koleka makala,
\q2 bazali koyeba bango lisusu te na babalabala ;
\q1 poso na bango ya nzoto ekangami na mikuwa,
\q2 ekawuki lokola koni.
\b
\q1 
\v 9 Bato oyo bakufi na mopanga bazali malamu
\q2 koleka ba-oyo bakufi na nzala :
\q1 banzulukaka mpe bakondaka makasi mpo na nzala,
\q2 mpo na kozanga bilei kowuta na bilanga.
\b
\q1 
\v 10 Basi ya mitema malamu balambi,
\q2 na maboko na bango, bana na bango moko ;
\q1 bana na bango bakomi bilei na bango
\q2 kati na pasi oyo ekomeli bato na ngai.
\b
\q1 
\v 11 Yawe asilikaki makasi koleka ;
\q2 asopaki kanda na Ye
\q1 mpe apelisaki moto kati na Siona,
\q2 moto oyo ezikisaki miboko na yango.
\b
\q1 
\v 12 Bakonzi ya mabele mpe bikolo mosusu ya mokili
\q2 bandimaki te ete banguna mpe bayini
\q2 bakokaki kokota na bikuke ya Yelusalemi.
\b
\q1 
\v 13 Kasi makambo wana esalemaki
\q2 mpo na masumu ya basakoli ya Yelusalemi
\q1 mpe mabe ya Banganga-Nzambe na yango,
\q2 oyo basopaki kati na yango makila ya bato ya sembo.
\b
\q1 
\v 14 Bakomaki sik’oyo koyengayenga
\q2 na babalabala lokola bakufi miso,
\q1 bakomaki mbindo na makila
\q2 mpe moto moko te akokaki kosimba bilamba na bango.
\b
\q1 
\v 15 Bato bazali koganga mpe koloba na bango :
\q2 « Bolongwa awa, bato ya mbindo !
\q1 Bolongwa awa, bolongwa awa, bosimba biso te ! »
\q2 Wana bazalaki kokima mpe kotelengana,
\q1 bato ya bikolo mosusu bazalaki koloba :
\q2 « Bavanda na esika oyo te ! »
\b
\q1 
\v 16 Yawe, Ye moko, apanzi bango,
\q2 azali kotala bango lisusu te.
\q1 Bapesaki Banganga-Nzambe lokumu te
\q2 mpe bayokelaki mibange mawa te.
\b
\q1 
\v 17 Miso na biso elembaki lisusu
\q2 mpo na kozela na pamba lisungi ;
\q1 wuta na bandako milayi na biso ya kotalela na mosika,
\q2 tozalaki kotala wana tozalaki kozela lisungi
\q1 kowuta na ekolo songolo mpe pakala,
\q2 kasi ebikisaki biso te.
\b
\q1 
\v 18 Banguna na biso bazalaki kolanda matambe na biso ;
\q2 boye tokokaki lisusu te kotambola na babalabala na biso.
\q1 Suka na biso ekomaki pene,
\q2 mikolo na biso ekomaki ya kotanga,
\q2 mpo ete tokomaki na suka.
\b
\q1 
\v 19 Bato oyo bazalaki kolanda biso
\q2 bazalaki mbangu koleka mpongo, na likolo ;
\q1 bazalaki kolanda biso na likolo ya bangomba
\q2 mpe kotiela biso mitambo kati na esobe.
\b
\q1 
\v 20 Mopakolami na Yawe, oyo totielaki motema
\q2 akangami na mitambo na bango ;
\q1 nzokande tozalaki kokanisa boye na tina na ye :
\q2 « Tokobika bomoi malamu
\q1 na se ya bobatelami na ye
\q2 kati na bikolo. »
\b
\q1 
\v 21 Edomi, mboka kitoko,
\q2 movandi ya mokili ya Utsi,
\q1 sepela, zala na esengo !
\q2 Kasi yo mpe, bakopesa yo kopo ;
\q2 okomela, okolangwa mpe okotikala bolumbu.
\b
\q1 
\v 22 Siona, mboka kitoko, etumbu na yo ekosila ;
\q2 Nzambe akomema yo lisusu na bowumbu te.
\q1 Kasi yo Edomi, mboka kitoko,
\q2 Nzambe akopesa yo etumbu mpo na mabe na yo,
\q2 mpe akobimisa masumu na yo na polele.
\b
\c 5
\ms1 Nzembo ya mitano : Libondeli
\s1 Kanisa
\q1 
\v 1 Oh Yawe,
\q2 kanisa makambo oyo ekomeli biso !
\q2 Tala mpe mona soni na biso !
\q1 
\v 2 Libula na biso ekeyi na maboko ya bapaya,
\q2 bandako na biso ekeyi na maboko ya bato mosusu.
\q1 
\v 3 Tokomi lokola bana bitike, tozangi tata ;
\q2 bamama na biso bakomi lokola basi bakufisa mibali !
\q1 
\v 4 Tosengeli kofuta mbongo ata mpo na mayi na biso ya komela
\q2 to mpe mpo na bakoni na biso !
\q1 
\v 5 Banguna na biso bazali kolanda biso,
\q2 bakomi na sima ya mokongo ;
\q2 bongo biso tolembi nzoto, tozangi kimia.
\q1 
\v 6 Tokomi ata kobondela bato ya Ejipito mpe ya Asiri
\q2 mpo ete bapesa biso bilei.
\q1 
\v 7 Solo batata na biso basalaki masumu,
\q2 kasi bazali lisusu te,
\q1 bongo biso tokomi komema
\q2 mokumba ya etumbu na bango.
\q1 
\v 8 Bawumbu bakomi kokonza biso,
\q2 mpe moto ata moko te amonani
\q2 mpo na kokangola biso na maboko na bango.
\q1 
\v 9 Tozali kozwa bilei na biso na motuya ya bomoi na biso,
\q2 likolo na mopanga ya babomi kuna na esobe.
\q1 
\v 10 Poso ya nzoto na biso ekomi moto
\q2 lokola nde balekisi yango na mbabola,
\q2 pamba te nzala ezali kotumba biso makasi.
\q1 
\v 11 Basambwisi basi kati na Siona,
\q2 mpe bilenge basi oyo bayebi nanu nzoto ya mibali te
\q2 kati na bingumba ya Yuda.
\q1 
\v 12 Badiembiki bakalaka, na maboko na bango ;
\q2 mpe bapesi bakambi lokumu te.
\q1 
\v 13 Bilenge mibali bazali komema libanga oyo banikelaka ble ;
\q2 bongo bana mike bazali kotepatepa na se ya kilo ya bakoni.
\q1 
\v 14 Bakambi batika kokende na ekuke ya engumba,
\q2 mpe bilenge batika kobeta mindule.
\q1 
\v 15 Esengo ezalaka lisusu te kati na mitema na biso,
\q2 mabina na biso ebongwana matanga.
\q1 
\v 16 Mitole ekweyi wuta na mito na biso.
\q2 Mawa na biso, mpo ete tosali masumu !
\q1 
\v 17 Soki mitema na biso ezali komona pasi
\q2 mpe soki miso na biso ekomi komona molili,
\q1 
\v 18 ezali mpo ete ngomba Siona ebebisami,
\q2 mpe mbwa ya zamba ekomi kovanda kuna.
\s1 Zongisa biso epai na Yo
\q1 
\v 19 Oh Yawe, ozali Mokonzi seko na seko ;
\q2 Kiti ya Bokonzi na Yo ekowumela libela na libela.
\q1 
\v 20 Mpo na nini obosana biso mpo na tango nyonso ?
\q2 Mpo na nini osundola biso tango molayi ?
\q1 
\v 21 Oh Yawe, zongisa biso epai na Yo ;
\q2 mpe tokozonga penza !
\q1 Yeisa mikolo na biso sika
\q2 ndenge ezalaki na tango ya kala !
\q1 
\v 22 Boni, osundoli biso solo mpo na libela
\q2 mpe otombokeli biso na kanda eleka ndelo ?
