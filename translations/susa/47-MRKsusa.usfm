\id MRK - Revised Susu Gospels
\h مَرَكِ
\toc1 عِنيِلَ عِسَ عَننَبِ مَرَكِ نَشَن سّبّشِ
\toc2 مَرَكِ
\mt1 عِنيِلَ عِسَ
\mt1 عَننَبِ مَرَكِ نَشَن سّبّشِ
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip كِتَابُي نَشَن شِلِ «عِنيِلَ عِسَ،» عَ دْشْ نَانِ نَ عَ رَ. نَمِحْنمّ نَانِ نَن عِنيِلَ عِسَ شَ تَرُشُي سّبّ عَلَ شَشِلِ سّنِيّنشِ سَابُي رَ. عٍ شِلِ نّ مَتِيُ، مَرَكِ، لُكِ، نُن يَيَ.
\ip عَننَبِ مَرَكِ يِ كِتَابُي سّبّ نّ حّ تٌنفٌ سَشَن حْندْن عِسَ قَشَ شَنبِ. عَ نَشَ عِسَ شَ دُنِحّءِفِرِ بِرِن مَسٍن عَلَكٌ مِشِيٍ شَ عَ كٌلٌن، عَ عِسَ قِندِشِ عَلَ شَ مِشِ سُفَندِشِ نَن نَ. عَ عَ سّبّ فِرّكِ شُي نّ، كْنْ مُشُ بَرَ عَ مَدَنفِ سٌسٌ شُي رَ عَلَكٌ سٌسٌي قَن نْمَ عَ قَهَامُدٍ عَ قَنيِ رَ.
\ip عِسَ شَ كَابَنَكٌ فبٍفبٍ سّبّشِ يِ كِتَابُي كُي عَلَكٌ مِشِ شَ عَ سّنبّ كٌلٌن، عَلَ نَشَن قِشِ عَ مَ. عَ قُرٍ مَيٍ رَيَلَن نّ، عَ حِننّ رَفبِلٍن مِشِيٍ قْشْ رَ. عَننَبِ مَرَكِ بَرَ وَ مِشِيٍ شَ عِسَ شَ شَرَنيِ قَن كٌلٌن. عِسَ تٌ مِشِيٍ شَرَن عَلَ شَ مَسٍنيِ رَ، عٍ نَشَ عَ كٌلٌن، عَ عَ نْندِ يَتِ يَتِ نَن كَوَندِ مَ. عَ دْنشْي رَ، يِ كِتَابُي دّنتّفّ سَمَ عِسَ قَشَ كِ نَشّ، عَ مَن كٍلِشِ قَشّ مَ كِ نَشّ.
\ip نَ بِرِن نْمَ قَهَامُي قِدٍ وٌن مَ، وٌن شَ عَ كٌلٌن ندٍ نَ عِسَ رَ. عَ لْننِ نَشَن قِشِ وٌن مَ يِ كِتَابُي كُي، عَ نْمَ وٌن مَلِدٍ وٌن مَ دُنِحّءِفِرِ كُي، عَ مَن نْمَ وٌن مَلِدٍ عَلِفِيَمَ. عَلَ شَ عَ رَ سٌ وٌن شَشِلِ مَ. عَمِنَ.
\mt1 عِنيِلَ عِسَ
\mt1 عَننَبِ مَرَكِ نَشَن سّبّشِ
\cl سٌرَ
\c 1
\s1 عَننَبِ يَيَ كَوَندِ تِقٍ
\r مَتِيُ ٣‏؛١ ٬ ١٢، لُكِ ٣‏؛١ ٬ ٢٢
\p 
\v 1 عِنيِلَ عِسَ قْلّ نَن يَ، نَشَن عَلَ شَ مِشِ سُفَندِشِ عِسَ شَ قٍ مَسٍنمَ، نَشَن قِندِشِ عَلَ شَ دِ رَ.
\v 2 عَ سّبّشِ عَننَبِ عٍسَيِ شَ كِتَابُي كُي،
\q1 «ﭑ قَمَ ﭑ مَ شّيرَ رَ سَنبَدٍ عِ يَ رَ،
\q1 عَ شَ كِرَ رَبْو عِ بّ.
\q1 
\v 3 عَ عَ شُي عِتٍمَ فبٍنفبٍرٍن يِرٍ،
\q1 ‹وٌ كِرَ يَءِلَن مَرِفِ بّ،
\q1 وٌ سَنكِرَيٍ مَتِنشِن عَ يَ رَ.›»
\m 
\v 4 نَ كُي، يَيَ شُنشَ نَشَ تٌ فبٍنفبٍرٍنيِ مَ. عَ نُ كَوَندِ تِمَ مِشِيٍ بّ، عٍ شَ عٍ شُنشَ يٍ شْورَ تُوبِ رَ، عَلَكٌ عَلَ شَ عٍ شَ يُنُبِيٍ شَقَرِ.
\v 5 يُدَيَكَيٍ نُن دَرِ سَلَمُكَ بِرِن نُ سِفَمَ عَ يِرٍ. عٍ نُ عٍ شَ يُنُبِيٍ مَسٍنمَ كّنّ مَ، يَيَ قَن نُ عٍ شُنشَمَ يُرُدّن شُرٍ شْورَ.
\v 6 حْشْمّ شَبٍ دٌنمَ نَن نُ رَفٌرٌشِ يَيَ مَ، بّلّتِ كِرِ دَاشِ نُ شِرِشِ عَ تَفِ. عَ نُ بَلٌمَ كَتٌي نُن وُلَ كُمِ نَن نَ.
\v 7 عَ نُ كَوَندِ تِمَ، عَ نُ عَ قَلَ، «نَشَن قَمَ قَدٍ ﭑ شَنبِ رَ، نَ سّنبّ فبٌ ﭑ تَن بّ. نَ بِنيّ مُ نَ ﭑ تَن يِ رَ، ﭑ حَن شَ ﭑ قٍلٍن عَ شَ سَنكِرِ لُوتِ يَتِ قُلُندٍ.
\v 8 ﭑ تَن بَرَ وٌ شُنشَ يٍ شْورَ، كْنْ عَ تَن عَلَ شَشِلِ سّنِيّنشِ نَن نَفٌرٌ مَ وٌ مَ.»
\s1 عِسَ شُنشَقٍ
\r مَتِيُ ٣‏؛١٣ ٬ ١٧، لُكِ ٣‏؛٢١ ٬ ٢٢، يَيَ ١‏؛٣٢ ٬ ٣٤
\p 
\v 9 نَ وَشَتِ مَ، عِسَ نَشَ قَ كٍلِ نَسَرّتِ، فَلِلٍ بْشِ مَ، يَيَ نَشَ عَ شُنشَ يُرُدّن شُرٍ شْورَ.
\v 10 عَ قّقّ تٍ يٍ شْورَ تّمُي نَشّ، عَ نَشَ كٌورٍ تٌ رَبِ رَ، عَلَ شَشِلِ سّنِيّنشِ نَشَ فٌرٌ عَ مَ عَلْ فَنبّ.
\v 11 شُي ندٍ نَشَ مّ كٍلِ كٌورٍ مَ، عَ عَ مَسٍن، «ﭑ مَ دِ مَشَنُشِ نَن نَ عِ رَ. عِ ﭑ كّنّنشِ كِ قَنيِ رَ.»
\s1 سٍنتَنّ كَتَقٍ عَ شَ عِسَ رَتَنتَن
\r مَتِيُ ٤‏؛١ ٬ ١١، لُكِ ٤‏؛١ ٬ ١٣
\p 
\v 12 نَ شَنبِ عَلَ شَشِلِ نَشَ عِسَ شَنِن فبٍنفبٍرٍنيِ مَ.
\v 13 شِ تٌنفٌ نَانِ بُن مَ، عَ نُ نَ فبٍنفبٍرٍن يِرٍ، سٍنتَنّ نُ كَتَقٍ عَ رَتَنتَندٍ. وُلَ سُبٍيٍ نُ نَ نَا. مَلٍكّيٍ نَشَ عَ بُن تِ.
\s1 عِسَ شَ وَلِ قْلّ نُن عَ قْشِرَبِرّ سِنفٍيٍ
\r مَتِيُ ٤‏؛١٢ ٬ ٢٢، لُكِ ٤‏؛١٤ ٬ ٥‏؛١١
\p 
\v 14 يَيَ سَ شَنبِ فٍيلِ، عِسَ نَشَ سِفَ فَلِلٍ بْشِ مَ عَلَ شَ شِبَارُ قَنيِ كَوَندِ رَ.
\v 15 عَ نُ عَ مَسٍنمَ، «وَشَتِ سُفَندِشِ بَرَ عَ لِ، عَلَ شَ مَنفّيَ نِينِ بَرَ مَكْرّ. وٌ تُوبِ، وٌ لَ عَلَ شَ شِبَارُ قَنيِ رَ.»
\p 
\v 16 عَ تٌ نُ دَنفِقٍ فَلِلٍ بَا دّ رَ، عَ نَشَ سِمْن نُن عَ شُنيَ عَندِرٍ تٌ، عٍ يّلّ وٌلِقٍ، بَرِ مَ يّشّسُشُييٍ نَن نُ عٍ رَ.
\v 17 عِسَ نَشَ عَ قَلَ عٍ بّ، «وٌ بِرَ ﭑ قْشْ رَ. تّمُي دَنفِشِ، وٌ نُ يّشّ نَن سْتْمَ، كْنْ يَكْسِ ﭑ عَ نِيَمَ وٌ شَ نُ مِشِيٍ نَن سْتْ ﭑ بّ.»
\v 18 عٍ نَشَ عٍ شَ يّلّيٍ لُ نَ كٍرٍن نَ، عٍ بِرَ عِسَ قْشْ رَ.
\v 19 عٍ تٌ دَنفِ نَ رَ دٌندٌرٌنتِ، عَ نَشَ سٍبٍدٍ شَ دِ يَكِ نُن عَ شُنيَ يَيَ تٌ، عٍ نُ نَ يّلّيٍ مَدّفّقٍ عٍ شَ كُنكُي كُي.
\v 20 عِسَ نَشَ عٍ شِلِ كٍرٍن نَ، عٍ قَن نَشَ عٍ بَبَ سٍبٍدٍ نُن وَلِكّيٍ لُ كُنكُي كُي، عٍ بِرَ عِسَ قْشْ رَ.
\s1 عِسَ حِننّ كٍرِقٍ
\r لُكِ ٤‏؛٣١ ٬ ٣٧
\p 
\v 21 عِسَ نُن عَ قْشِرَبِرّيٍ نَشَ سٌ كَثّرّنَمُ. مَلَبُ لْشْي مَ، عِسَ نَشَ سٌ سَلِدٍ كُي، عَ كَوَندِ تِ قْلْ.
\v 22 مِشِيٍ نَشَ كَابَ عَ شَ شَرَنيِ مَ، بَرِ مَ عَ مُ نُ لُشِ عَلْ عٍ شَ سّرِيّ كَرَ مْشْيٍ. عَ تَن نُ وْيّنمَ مَنفّ سّنبّ نَن نَ.
\v 23 نَ وَشَتِ يَتِ، شّمّ ندٍ حِننّ نُ نَشَن قْشْ رَ، عَ نَشَ سْنشْي رَتٍ قْلْ عٍ شَ سَلِدٍ بَنشِ كُي،
\v 24 «عِسَ نَسَرّتِكَ، عِ وَشِ مُنسٍ شْن مَ مُشُ بّ؟ عِ قَشِ مُشُ سْنتْدٍ نّ؟ ﭑ عَ كٌلٌن مِشِ نَشَن لَنشِ عِ مَ. عَلَ شَ سّنِيّنتْي نَن نَ عِ رَ.»
\v 25 عِسَ نَشَ وْيّن عَ مَ عَ شْرْشْي رَ، «عِ سَبَرِ. فبِلٍن يِ شّمّ قْشْ رَ.»
\v 26 حِننّ نَشَ شّمّ رَكٍتُن عَ رَ، عَ سْنشْ، عَ قَ فبِلٍن عَ قْشْ رَ.
\v 27 بِرِن دّ نَشَ عِشَرَ، عٍ نُ قَ عٍ بٌرٍ مَشْرِن، «مُنسٍ يِ كِ؟ شَرَنيِ نّينّ عَ نُن سّنبّ! هَلِ حِننّيٍ، عَ عٍ يَمَرِ مَ، عٍ عَ شُي رَبَتُ.»
\v 28 عَ مُ بُ، عَ شِلِ نَشَ دِن فَلِلٍ بْشِ يِرٍ بِرِن نَ.
\s1 عِسَ سِمْن بِتَنيِ نُن قُرٍ مَ فبٍفبٍ رَيَلَنقٍ
\r مَتِيُ ٨‏؛١٤ ٬ ١٧، لُكِ ٤‏؛٣٨ ٬ ٤١
\p 
\v 29 عٍ تٌ مِنِ سَلِدٍ كُي، عِسَ نُن يَكِ نُن يَيَ نَشَ سِفَ سِمْن نُن عَندِرٍ شْنيِ.
\v 30 سِمْن بِتَنيِ فِنّمَ نُ سَشِ، عَ قَتٍ وٌلٍنشِ. عٍ نَشَ عَ شَ قٍ قَلَ عِسَ بّ كٍرٍن نَ.
\v 31 عِسَ نَشَ عَ مَسٌ فِنّ رَ، عَ عَ بّلّشّ سُشُ، عَ عَ رَكٍلِ. قُرٍ نَشَ عَ بّحِن، عَ نَشَ عٍ بُن تِ قْلْ.
\p 
\v 32 نُنمَرٍ تٌ سٌ، سٌفٍ نَشَ دُلَ، مِشِيٍ نَشَ قَ قُرٍ مَيٍ بِرِن نَ عَ شْن، عَ نُن حِننّيٍ بِرَشِ نَشٍيٍ قْشْ رَ.
\v 33 تَا بِرِن نَشَ عٍ مَلَن نَادّ رَ.
\v 34 عَ نَشَ قُرٍ مَ فبٍفبٍ رَيَلَن، قُرٍ مْولِ وُيَشِ نُ نَشٍيٍ مَ. عَ نَشَ حِننّ فبٍفبٍ قَن كٍرِ مِشِيٍ قْشْ رَ، كْنْ عَ مُ تِن حِننّيٍ شَ وْيّن، بَرِ مَ عٍ نُ عَ كٌلٌن.
\s1 عِسَ كَوَندِ تِقٍ فَلِلٍ بْشِ مَ
\r مَتِيُ ٤‏؛٢٣، لُكِ ٤‏؛٤٢ ٬ ٤٤
\p 
\v 35 سُبَشّ مَ، عِسَ نَشَ كٍلِ، عَ نَشَ مِنِ وُلَ عِ عَلَ مَشَندِدٍ.
\v 36 سِمْن نُن عَ بٌورٍيٍ يَ كٌتٌ نَشَ مْ عِسَ قٍندٍ.
\v 37 عٍ تٌ عَ تٌ، عٍ نَشَ عَ قَلَ عَ بّ، «بِرِن نَ عِ قٍنقٍ.»
\v 38 عِسَ نَشَ عٍ يَابِ، «وٌن شّي تَا فبّتّيٍ نَشٍيٍ نَ بٍ رَبِلِنيِ عَلَكٌ ﭑ شَ كَوَندِ رَبَ مّننِ قَن، بَرِ مَ ﭑ قَشِ نَ نَن مَ.»
\v 39 عَ نَشَ سِفَ فَلِلٍ بْشِ بِرِن مَ، عَ نُ كَوَندِ تِ عٍ شَ سَلِدٍ بَنشِيٍ كُي، عَ نُ حِننّيٍ قَن كٍرِ مِشِيٍ قْشْ رَ.
\s1 كُنّ كَنيِ رَيَلَنقٍ
\r مَتِيُ ٨‏؛١ ٬ ٤، لُكِ ٥‏؛١٢ ٬ ١٤
\p 
\v 40 كُنّ كَنيِ ندٍ نَشَ قَ عِسَ يِرٍ، عَ عَ شِنبِ سِن عَ بُن مَ، عَ عَ مَيَندِ، «شَ عِ تِن، عِ نْمَ ﭑ نَسّنِيّندٍ.»
\v 41 عِسَ نَشَ كِنِكِنِ عَ مَ. عَ نَشَ عَ بّلّشّ عِتَلَ، عَ عَ سَ كُنّ كَنيِ مَ، عَ عَ قَلَ عَ بّ، «ﭑ تِنشِ. عِ شَ سّنِيّن.»
\v 42 كُنّ قُرٍ نَشَ بَ شّمّ مَ كٍرٍن نَ، عَ نَشَ سّنِيّن.
\v 43 عِسَ تٌ عَ رَفبِلٍن، عَ نَشَ عَ مَتِنتِن عَ رَ
\v 44 يِ مَسٍنيِ رَ، «عِ نَشَ يِ قٍ قَلَ مِشِ يٌ بّ. سِفَ عِ سَ عِ يّتّ دّنتّفّ سّرّشّدُبّ بّ، عِ سّرّشّ بَ عِ شَ سّنِيّنيِ شَ قٍ رَ، عَلْ عَننَبِ مُنسَ عَ يَمَرِشِ كِ نَشّ. نَ قِندِ مَ سٍيدٍحْشْيَ نَن نَ عٍ بّ.»
\v 45 كْنْ شّمّ تٌ سِفَ، عَ نَشَ سٌ يِ قٍ تَفِ رَبَقٍ بِرِن بّ، عَ نُ عَ شِبَارُ رَيٍنسٍن يّ. نَ نَشَ عَ نِيَ عِسَ مُ نْ سٌدٍ تَا كُي سْنْن كّنّ مَ. قٌ عَ تٌ نُ سَ لُمَ تَا قَرِ مَ مِشِ يٌ مُ سَبَتِشِ دّننَشّ. مِشِيٍ قَن نُ كٍلِمَ يِرٍ بِرِن قَقٍ رَ عَ يِرٍ.
\c 2
\s1 نَمَتّ رَيَلَنقٍ
\r مَتِيُ ٩‏؛١ ٬ ٨، لُكِ ٥‏؛١٧ ٬ ٢٦
\p 
\v 1 شِ ندٍيٍ تٌ دَنفِ، عِسَ مَن نَشَ فبِلٍن كَثّرّنَمُ، مِشِيٍ قَ عَ مّ عَ عَ نَ بَنشِ.
\v 2 حَمَ فبٍفبٍ نَشَ قَ عَ يِرٍ، بَنشِ كُي نَشَ رَقٍ، تِدٍ نَشَ حْن تَندٍ بِرِن مَ. عِسَ نَشَ عٍ كَوَندِ عَلَ شَ مَسٍنيِ رَ.
\v 3 مِشِ ندٍيٍ نَشَ قَ نَمَتّ رَ عِسَ شْن. شّمّ نَانِ نَن نُ عَ شَنِنقٍ.
\v 4 كْنْ حَمَ تٌ نُ فبٌ، عٍ مُ نُ نْمَ عٍ مَكْرّدٍ عِسَ رَ. نَ كُي، عٍ نَشَ بَنشِ قَرِ يِرٍ ندٍ مَبَ عِسَ يَءِلَنيِ. عٍ نَشَ نَمَتّ رَفٌرٌ مّننِ رَ عَ شَ سَدٍ قَرِ.
\v 5 عِسَ تٌ عٍ شَ دَنشَنِيَ تٌ، عَ نَشَ عَ قَلَ نَمَتّ بّ، «ﭑ مَ دِ، عِ شَ يُنُبِيٍ بَرَ شَقَرِ.»
\v 6 سّرِيّ كَرَ مْشْ ندٍيٍ نُ دْشْشِ نَا، عٍ نَشَ عٍ شَشِلِ رَحّرّ،
\v 7 «يِ وْيّنمَ يِ مْولِ رَ مُنقٍ رَ؟ عَ نَ عَلَ رَ سْتْقٍ نّ يِ كِ! ندٍ نْمَ يُنُبِيٍ شَقَرِدٍ، بَقٍ عَلَ كٍرٍن نَ؟»
\v 8 عِسَ نَشَ عٍ شَ مَحْشُنيِ كٌلٌن عَ شَشِلِ مَ كٍرٍن نَ. عَ نَشَ عَ قَلَ عٍ بّ، «مُنقٍ رَ يِ مَحْشُنيِ مْولِ نَ وٌ بْحّ مَ؟
\v 9 وْيّنيِ مُندُن سْونّيَ، عَ قَلَقٍ يِ نَمَتّ بّ، ‹عِ شَ يُنُبِيٍ بَرَ شَقَرِ،› كَ عَ قَلَقٍ عَ بّ، ‹كٍلِ، عِ شَ سَدٍ تٌنفٌ، عِ حّرّ›؟
\v 10 ﭑ شَ عَ مَسٍن وٌ بّ عَ عَدَ مَ شَ دِ نْمَ يُنُبِ شَقَرِدٍ دُنِحَ مَ.» عِسَ نَشَ عَ مَسٍن نَمَتّ بّ،
\v 11 «ﭑ نَشّ عِ بّ، كٍلِ، عِ عِ شَ سَدٍ تٌنفٌ، عِ سِفَ عِ شْنيِ.»
\v 12 عَ نَشَ كٍلِ كٍرٍن نَ، عَ عَ شَ سَدٍ تٌنفٌ، عَ مِنِ بِرِن يَ شْرِ. حَمَ بِرِن دّ نَشَ عِشَرَ، عٍ نُ قَ عَلَ مَتْشْ، «هَن تٌ مُشُ سِنفٍ مُ نُ يِ حْندْن تٌ.»
\s1 لٍوِ بِرَقٍ عِسَ قْشْ رَ
\r مَتِيُ ٩‏؛٩ ٬ ١٣، لُكِ ٥‏؛٢٧ ٬ ٣٢
\p 
\v 13 عِسَ مَن نَشَ فٌرٌ بَا دّ رَ. حَمَ بِرِن نَشَ قَ عَ يِرٍ، عَ نُ عٍ كَوَندِ.
\v 14 عَ تٌ نُ دَنفِقٍ، عَ نَشَ عَلِقَ شَ دِ لٍوِ تٌ، عَ دْشْشِ دُوتِ مَشِلِدٍ. عَ نَشَ عَ قَلَ عَ بّ، «بِرَ ﭑ قْشْ رَ.» لٍوِ نَشَ كٍلِ، عَ بِرَ عَ قْشْ رَ.
\p 
\v 15 لْشْ ندٍ عِسَ نُن عَ قْشِرَبِرّيٍ نُ نَ عٍ دّفٍقٍ لٍوِ شْنيِ. دُوتِ مَشِلِيٍ نُن يُنُبِتْي فبٍفبٍ قَن نُ نَ، عٍ بِرِن نُ عٍ دّفٍقٍ يِرٍ كٍرٍن، بَرِ مَ نَ مِشِ مْولِ وُيَشِ نُ بَرَ بِرَ عِسَ قْشْ رَ.
\v 16 سّرِيّ كَرَ مْشْ نَشٍيٍ نُ نَ قَرِ سّنِيٍ يَ مَ، عٍ تٌ عِسَ تٌ عَ دّفٍ رَ عٍ نُن دُوتِ مَشِلِيٍ نُن يُنُبِتْييٍ، عٍ نَشَ عَ قْشِرَبِرّيٍ مَشْرِن، «مُنقٍ رَ عِسَ نُن دُوتِ مَشِلِيٍ نُن يُنُبِتْييٍ عٍ دّفٍمَ يِرٍ كٍرٍن؟»
\v 17 عِسَ تٌ نَ مّ، عَ نَشَ عٍ يَابِ، «مِشِ يَلَنشِ هَيِ مُ نَ سٍرِبَ مَ. قُرٍ مَ نَن هَيِ نَ عَ مَ. ﭑ مُ قَشِ تِنشِنتْييٍ شَ شِلِدٍ. ﭑ قَشِ يُنُبِتْييٍ نَن شِلِدٍ.»
\s1 عِسَ مَشْرِنقٍ سُنيِ مَ
\r مَتِيُ ٩‏؛١٤ ٬ ١٧، لُكِ ٥‏؛٣٣ ٬ ٣٩
\p 
\v 18 عَننَبِ يَيَ قْشِرَبِرّيٍ نُن قَرِ سّنِيٍ تٌ نُ نَ سُنيِ، مِشِيٍ نَشَ قَ عِسَ مَشْرِندٍ، «مُنقٍ رَ يَيَ قْشِرَبِرّيٍ نُن قَرِ سّنِيٍ قْشِرَبِرّيٍ سُنيِ سُشُمَ، كْنْ عِ فبٍيٍ تَن مُ سُنمَ؟»
\v 19 عِسَ نَشَ عٍ يَابِ، «فِنّقٍنيِ شَ قُتِشِرِ شُلُنيِ، عَ بٌورٍيٍ نْمَ سُنيِ سُشُدٍ عَ نَ عٍ قّ مَ تّمُي نَشّ؟ شَ عٍ نُن فِنّقٍنيِ نَ عَ رَ، عٍ مُ نْمَ سُندٍ.
\v 20 لْشْي قَمَ، فِنّقٍنيِ بَمَ نّ عٍ يَ مَ. نَ وَشَتِ تَن، عٍ سُنيِ سُشُمَ نّ.
\v 21 مِشِ يٌ مُ دُفِ قٌرِ لٌنثٌمَ دُفِ نّينّ رَ، شَ نَ مُ عَ رَ نَ دُفِ نّينّ شُنتُنيِ دُفِ قٌرِ عِبّندُنمَ، دُفِ عِبْو دَنفِ عَ سِنفٍ رَ.
\v 22 مِشِ يٌ مَن مُ وّنِ نّينّ سَمَ لّبّ قٌرِ كُي، شَ نَ مُ عَ رَ نَ وّنِ نّينّ نَ قُنتُ، وّنِ لّبّ قٌرِ بُلَمَ نّ. نَ كُي، وّنِ يٌ، لّبّ يٌ، عَ كَنيِ فَنمَ نّ عٍ بِرِن نَ. عَ لَن نّ وّنِ نّينّ شَ سَ لّبّ نّينّ نَن كُي.»
\s1 مَلَبُ لْشْي شَ سّرِيّ
\r مَتِيُ ١٢‏؛١ ٬ ٢١، لُكِ ٦‏؛١ ٬ ١١
\p 
\v 23 مَلَبُ لْشْ ندٍ، عِسَ نُن عَ قْشِرَبِرّيٍ نُ حّرّقٍ سَنكِرَ مَ شّيٍ تَفِ. عٍ تٌ نُ دَنفِقٍ، عَ قْشِرَبِرّيٍ نَشَ مّنفِ تْنسْي ندٍ بَ قْلْ.
\v 24 نَ كُي، قَرِ سّنِيٍ نَشَ وْيّن عِسَ بّ، «مُنقٍ رَ عٍ نَ مَلَبُ لْشْي سّرِيّ مَتَندِقٍ؟»
\v 25 عِسَ نَشَ عٍ يَابِ، «وٌ مُ نُ عَ شَرَن دَوُدَ نَشَن نَبَ كَامّ تٌ عَ سُشُ، عَ تَن نُن نَشٍيٍ نُ نَ عَ قْشْ رَ؟
\v 26 عَ سٌ نّ عَلَ شَ بَنشِ كُي، عَبِيَتَرِ نُ قِندِشِ سّرّشّدُبّ كُنتِفِ رَ تّمُي نَشّ، عَ تَامِ دٌن نَشَن قِشِ عَلَ مَ، عَ ندٍ سٌ عَ قْشِرَبِرّيٍ قَن يِ رَ، هَلِ عَ تٌ مُ نُ دَشَ مِشِ يٌ شَ نَ دٌن، قٌ سّرّشّدُبّيٍ.»
\v 27 عِسَ مَن نَشَ عَ مَسٍن عٍ بّ، «مَلَبُ لْشْي نَ مِشِ نَن بّ، مِشِ شَ مُ دَاشِ مَلَبُ لْشْي بّ.
\v 28 نَ كُي، عَدَ مَ شَ دِ قِندِشِ مَرِفِ نَن نَ هَلِ مَلَبُ لْشْي شُن مَ.»
\c 3
\s1 قٍ قَنيِ رَبَقٍ مَلَبُ لْشْي مَ
\r مَتِيُ ١٢‏؛٩ ٬ ٢١، لُكِ ٦‏؛٦ ٬ ١١
\p 
\v 1 عِسَ مَن نَشَ سٌ سَلِدٍ كُي. عَ نَشَ شّمّ ندٍ لِ نَا، نَشَن بّلّشّ تُوشِ عَ مَ.
\v 2 قَرِ سّنِيٍ نُ عٍ يَ تِشِ عِسَ رَ عٍ شَ عَ مَتٌ شَ عَ عَ رَيَلَنمَ مَلَبُ لْشْي مَ، عَلَكٌ عٍ شَ نْ عَ كَلَمُدٍ قٍ ندٍ مَ.
\v 3 عِسَ نَشَ عَ قَلَ شّمّ بّ نَشَن بّلّشّ تُوشِ عَ مَ، «كٍلِ، عِ قَ تِ بٍ، حَمَ تَفِ.»
\v 4 عَ نَشَ عٍ مَشْرِن، «عَ دَشَ قٍ قَنيِ نَن شَ رَبَ مَلَبُ لْشْي، كَ قٍ حَاشِ؟ نِي رَكِسِقٍ نَن دَشَ كَ نِي سْنتْقٍ؟» كْنْ مِشِ يٌ مُ عَ يَابِ.
\v 5 عِسَ شْنْشِ نَشَ عٍ مَتٌ، عَ بْحّ تْورْشِ كِ قَنيِ بَرِ مَ كِنِكِنِتَرٍ نَن نُ عٍ رَ. عَ نَشَ عَ قَلَ شّمّ بّ نَشَن بّلّشّ تُوشِ عَ مَ، «عِ بّلّشّ عِتَلَ.» عَ نَشَ عَ عِتَلَ، عَ بّلّشّ نَشَ يَلَن.
\v 6 قَرِ سّنِيٍ نَشَ مِنِ كٍرٍن نَ، عٍ تَن نُن هٍرٌدٍ قْشِرَبِرّيٍ نَشَ سَ مَلَنيِ رَبَ عِسَ شِلِ مَ. عٍ نَشَ كِرَ قٍن قْلْ عِسَ قَشَقٍ مَ.
\s1 حَمَ مَلَنقٍ عِسَ يِرٍ
\r مَتِيُ ٤‏؛٢٣ ٬ ٢٥، ١٢‏؛١٥ ٬ ١٦، لُكِ ٦‏؛١٧ ٬ ١٩
\p 
\v 7 عِسَ نَشَ كٍلِ نَا عٍ نُن عَ قْشِرَبِرّيٍ، عٍ نَشَ سِفَ بَا دّ رَ. حَمَ فبٍفبٍ نَشَ بِرَ عٍ قْشْ رَ كٍلِقٍ فَلِلٍ، يُدَيَ،
\v 8 دَرِ سَلَمُ، عِدُ مٍيَ، يُرُدّن نَاكِرِ، عَ نُن تِرٍ نُن سِدْن نَبِلِنيِيٍ. حَمَ نُ بَرَ عَ مّ عِسَ نُ نَ قٍيٍ نَشٍيٍ رَبَقٍ. نَ نَن عَ تٌ عٍ فبٍفبٍ نَشَ قَ عَ يِرٍ.
\v 9 عِسَ نَشَ عَ قَلَ عَ قْشِرَبِرّيٍ بّ، عٍ شَ كُنكُي ندٍ شِرِ عَ بّ بَا دّ رَ، عَلَكٌ حَمَ نَشَ قَ عَ شّتّن.
\v 10 بَرِ مَ عَ تٌ نُ بَرَ مِشِ فبٍفبٍ رَيَلَن، قُرٍ مَيٍ بِرِن نُ كَتَمَ عٍ شَ عٍ بّلّشّ دِن عَ رَ.
\v 11 حِننّيٍ نّقّ عِسَ تٌ، عٍ نُ بِرَ مَ عَ بُن مَ، عٍ نُ فبٍلٍفبٍلٍ، «عَلَ شَ دِ نَن نَ عِ رَ.»
\v 12 كْنْ عِسَ نَشَ تْنيِ دْشْ عٍ مَ عٍ نَشَ مِشِيٍ رَكٌلٌن عَ شَ قٍ مَ.
\s1 عِسَ قْشِرَبِرّ قُ نُن قِرِن سُفَندِقٍ
\r مَتِيُ ١٠‏؛١ ٬ ٤، لُكِ ٦‏؛١٢ ٬ ١٦
\p 
\v 13 نَ شَنبِ، عِسَ نَشَ تٍ فٍيَ قَرِ. عَ نَشَ مِشِيٍ شِلِ عَ وَشِ نَشٍيٍ شْن، عٍ قَن نَشَ قَ عَ قّ مَ.
\v 14 عَ نَشَ قْشِرَبِرّ قُ نُن قِرِن سُفَندِ، عَلَكٌ عٍ شَ لُ عَ سّيتِ مَ، عَ مَن شَ عٍ شّي كَوَندِ رَبَدٍ،
\v 15 عَ مَن شَ سّنبّ قِ عٍ مَ حِننّ كٍرِقٍ رَ مِشِيٍ قْشْ رَ.
\v 16 عَ مِشِ قُ نُن قِرِن نَن سُفَندِ؛ سِمْن، عَ نَشَن شِلِ سَ ثِيّرِ،
\v 17 يَكِ، سٍبٍدٍ شَ دِ، نُن يَيَ، يَكِ شُنيَ، عَ نَشَ يِ قِرِنيِيٍ قَن شِلِ سَ بٌوَنٍرِفٍ، نَ نَن قَلَشِ «سٍسَرِنيِ شَ دِيٍ»،
\v 18 عَندِرٍ، قِلِثُ، بَرٌتٌلٌمٍ، مَتِيُ، تٌمَسِ، عَلِقَ شَ دِ يَكِ، تَدَيٌ، سِمْن كَنَانكَ،
\v 19 نُن يُدَ سِ عِسِكَرِيٌتِ نَشَن عِسَ يَنقَ، عَ عَ سَ مِشِ كٌبِيٍ بّلّشّ.
\s1 شَشِلِ سّنِيّنشِ رَ سْتْقٍ
\r مَتِيُ ١٢‏؛٢٢ ٬ ٣٣، لُكِ ١١‏؛١٤ ٬ ٢٣، ١٢‏؛١٠
\p 
\v 20 نَ شَنبِ، عٍ نَشَ فبِلٍن بَنشِ، كْنْ حَمَ مَن نَشَ عٍ مَلَن عٍ يِرٍ. عٍ حَن مُ نْ عٍ دّفٍدٍ.
\v 21 عِسَ شَ مِشِيٍ تٌ عَ مّ، عٍ نَشَ سِفَ عَ قْشْ رَ، بَرِ مَ عٍ نُ عَ قَلَقٍ، «عَ بَرَ دَشُ.»
\p 
\v 22 سّرِيّ كَرَ مْشْ نَشٍيٍ كٍلِ دَرِ سَلَمُ، نٍيٍ قَن نُ عَ قَلَقٍ، «عَ حِننّيٍ كٍرِ مَ حِننّ مَنفّ بّلّسّبُلُ نَن سَابُي رَ.»
\v 23 عِسَ نَشَ عٍ شِلِ، عَ تَالِ سَ عٍ بّ، «سٍنتَنّ نْمَ سٍنتَنّ كٍرِدٍ؟
\v 24 شَ حَمَنّ عَ يّتّ فٍرٍ لَنتَرٍيَ كُي، نَ حَمَنّ مُ شَنمَ.
\v 25 شَ دٍنبَيَ قَن عَ يّتّ فٍرٍ لَنتَرٍيَ كُي، نَ دٍنبَيَ مُ شَنمَ.
\v 26 سٍنتَنّ قَن، شَ عَ عَ يّتّ فٍرٍ لَنتَرٍيَ كُي، عَ شَ قٍ بَرَ حْن، عَ عَ يّتّ كَنَمَ نّ.
\v 27 وٌ شَ عَ كٌلٌن، مِشِ يٌ مُ نْمَ سٌدٍ سّنبّمَ شَ بَنشِ كُي، عَ عَ هَرِفٍ بَ عَ يِ رَ، شَ عَ مُ عَ شِرِ سِندٍن. نَ تّمُي، عَ نْمَ نّ عَ هَرِفٍ بِرِن مُحَدٍ.»
\p 
\v 28 «ﭑ شَ نْندِ قَلَ وٌ بّ، عَلَ دِحّمَ نّ عَدَ مَدِيٍ شَ يُنُبِ نُن مَرَ سْتْي بِرِن مَ،
\v 29 كْنْ مِشِ نَشَن عَلَ شَشِلِ سّنِيّنشِ رَ سْتْمَ، نَ يُنُبِ تَن مُ نْمَ شَقَرِدٍ نَ كَنيِ بّ عَبَدَن.»
\v 30 عِسَ يِ قٍ بِرِن مَسٍن نّ عٍ بّ، بَرِ مَ عٍ نُ عَ قَلَقٍ نّ، «حِننّ كَنيِ نَ عَ رَ.»
\s1 عِسَ شَ دٍنبَيَ
\r مَتِيُ ١٢‏؛٤٦ ٬ ٥٠، لُكِ ٨‏؛١٩ ٬ ٢١
\p 
\v 31 عِسَ نفَ نُن عَ شُنيَ شّمّمَيٍ نَشَ قَ، عٍ تِ تَندٍ، عٍ مِشِ شّي عِسَ شِلِدٍ.
\v 32 حَمَ نُ دْشْشِ عِسَ رَبِلِنيِ. عٍ نَشَ عَ قَلَ عَ بّ، «عِ نفَ نُن عِ شُنيَيٍ نَ تَندٍ، عٍ وَ مَ وٌ شَ دّ مَسَرَ.»
\v 33 عِسَ نَشَ عٍ يَابِ، «ندٍ قِندِشِ ﭑ نفَ نُن ﭑ شُنيَيٍ رَ؟»
\v 34 عَ نَشَ عَ يَ رَفٍ مِشِيٍ تَفِ نَشٍيٍ نُ دْشْشِ عَ رَبِلِنيِ، عَ قَ عَ مَسٍن، «عَ مَتٌ، ﭑ نفَ نُن ﭑ شُنيَيٍ نَن يَ.
\v 35 مِشِ يٌ نَشَن عَلَ وَشْنقٍ رَبَمَ، نَ كَنيِ نَن قِندِشِ ﭑ شُنيَ شّمّمَ، ﭑ مَافِنّ، نُن ﭑ نفَ رَ.»
\c 4
\s1 شّ رَوَلِ شَ تَالِ
\r مَتِيُ ١٣‏؛١ ٬ ٢٣، لُكِ ٨‏؛٤ ٬ ١٥
\p 
\v 1 عِسَ مَن نَشَ كَوَندِ تِ قْلْ بَا دّ رَ. حَمَ فبٍفبٍ تٌ عٍ مَلَن، عَ نَشَ سَ دْشْ كُنكُي كُي، حَمَ نَشَ لُ بَا دّ رَ.
\v 2 عَ نَشَ قٍ وُيَشِ مَسٍن عٍ بّ تَالِيٍ رَ. عَ شَ كَوَندِ كُي، عَ نَشَ عَ مَسٍن عٍ بّ،
\v 3 «وٌ وٌ تُلِ مَتِ. شّ رَوَلِ ندٍ نَن مِنِ سَنسِ شْرِ فَرَنسَندٍ.
\v 4 عَ تٌ نُ سَنسِ شْرِ فَرَنسَنمَ، شْرِ ندٍيٍ نَشَ بِرَ سَنكِرَ شْن، شْنِيٍ نَشَ قَ، عٍ عٍ دٌن فبِكِ.
\v 5 شْرِ ندٍيٍ قَن نَشَ بِرَ فّمّ يِرٍ، بّندّ مُ فبٌ دّننَشّ. نٍيٍ نَشَ بُلَ مَقُرٍن نَ، بَرِ مَ نَ بّندّ مُ تِلِن.
\v 6 كْنْ سٌفٍ تٌ شْنْ، نَ سَنسِيٍ نَشَ رَفَن، عٍ شَرَ فبٍن، بَرِ مَ سَنكٍ مُ نُ نَ عٍ بّ.
\v 7 سَنسِ شْرِ ندٍيٍ قَن نَشَ بِرَ تُنبٍ كُنسِيٍ تَفِ. تُنبٍ كُنسِيٍ نَشَ فبٌ، عٍ سَنسِيٍ عِشّتّن، عٍ عٍ كَنَ، عٍ مُ بٌفِ يٌ رَ مِنِ.
\v 8 سَنسِ شْرِ ندٍيٍ قَن نَشَ بِرَ بّندّ قَنيِ مَ. نَ شْرِيٍ تَن، عٍ كٍرٍن كٍرٍن بِرِن سَنسِيٍ نَشَ تْنسْي رَ مِنِ، ندٍيٍ نَشَ شْرِ تٌنفٌ سَشَن نَمِنِ، ندٍيٍ شْرِ تٌنفٌ سٍننِ، ندٍيٍ شْرِ كّمّ.»
\v 9 نَ شَنبِ، عَ نَشَ عَ مَسٍن، «شَ وٌ تُلِ قٍ مّمَ، وٌ وٌ تُلِ مَتِ يِ مَسٍنيِ رَ.»
\p 
\v 10 عِسَ تٌ لُ عَ شَتِ مَ، عَ قْشِرَبِرّ قُ نُن قِرِنيِيٍ عَ نُن نَشٍيٍ نُ نَ عَ رَبِلِنيِ، عٍ نَشَ عَ مَشْرِن عَ شَ تَالِيٍ مَ.
\v 11 عَ نَشَ عَ مَسٍن عٍ بّ، «عَلَ بَرَ قَهَامُي قِ وٌ مَ وٌ شَ عَ شَ مَنفّيَ نِينِ فُندٌ كٌلٌن، كْنْ مِشِ فبّتّيٍ تَن قٍ بِرِن مّمَ تَالِ وْيّنيِيٍ نَن نَ،
\v 12 عَلَكٌ
\q1 ‹عٍ شَ قٍ تٌ عَ قَنيِ رَ، كْنْ عٍ نَشَ عَ عِفبّ.
\q1 عٍ شَ قٍ مّ عَ قَنيِ رَ، كْنْ عٍ نَشَ عَ قَهَامُ.
\q1 نَ رَبَشِ نّ عَلَكٌ عٍ نَشَ قَ عٍ يَ رَقِندِ عَلَ مَ، عَلَ قَ دِحّ عٍ مَ.›»
\p 
\v 13 عَ نَشَ عٍ مَشْرِن، «وٌ تٌ مُ قَ يِ تَالِ كُي كٌلٌنشِ، وٌ تَالِ فبّتّيٍ كٌلٌنمَ دِ؟
\v 14 شّ رَوَلِ نَشَن سَنسِ شْرِ فَرَنسَنمَ، عَ مَنِيَ مِشِ رَ نَشَن عَلَ شَ مَسٍنيِ كَوَندِ مَ.
\v 15 مِشِ ندٍيٍ مَنِيَشِ نَ سَنسِ شْرِيٍ رَ نَشٍيٍ بِرَ كِرَ شْن. عٍ نّقّ عَلَ شَ مَسٍنيِ مّ، سٍنتَنّ عَ بَ عٍ شَشِلِ مَ.
\v 16 سَنسِ شْرِ نَشٍيٍ بِرَ فّمّ يِرٍ، نٍيٍ مِسَالِشِ مِشِيٍ نَن نَ نَشٍيٍ عَلَ شَ مَسٍنيِ مّمَ، عٍ عَ سُشُ مَقُرٍن سّيوّ رَ.
\v 17 كْنْ سَنكٍ تٌ مُ نَ عٍ بّ، عٍ شَ دَنشَنِيَ مُ بُمَ. تْورّ نُن حَشَنكَتّ نَ عٍ لِ عَلَ شَ مَسٍنيِ شَ قٍ رَ، عٍ فبِلٍنمَ نّ عَلَ شَ قٍ قْشْ رَ كٍرٍن نَ.
\v 18 سَنسِ شْرِ نَشٍيٍ بِرَ تُنبٍ كُنسِيٍ تَفِ، نٍيٍ مِسَالِشِ مِشِيٍ نَن نَ نَشٍيٍ عَلَ شَ مَسٍنيِ مّمَ،
\v 19 كْنْ يِ دُنِحَ كْنتْقِلِ، نُن نَاقُلِ شْلِ، نُن قٍ فبّتّيٍ شْلِ نَن عٍ سُشُمَ هَن عٍ عَلَ شَ مَسٍنيِ بّحِن. نَ كُي، عَلَ شَ مَسٍنيِ مُ نْمَ عٍ بْحّ مَسَرَدٍ.
\v 20 سَنسِ شْرِ نَشٍيٍ بِرَ بّندّ قَنيِ تَن مَ، نٍيٍ مِسَالِشِ مِشِيٍ نَن نَ نَشٍيٍ عَلَ شَ مَسٍنيِ مّمَ، عٍ مَن عَ سُشُ، عَ عٍ بْحّ مَسَرَ. شْرِ كٍرٍن بٌفِ تٌنفٌ سَشَن نَمِنِمَ، ندٍيٍ بٌفِ تٌنفٌ سٍننِ، فبّتّيٍ قَن بٌفِ كّمّ.»
\s1 لَنثُي شَ تَالِ
\r لُكِ ٨‏؛١٦ ٬ ١٨
\p 
\v 21 عِسَ مَن نَشَ عَ مَسٍن عٍ بّ، «لَنثُي نْمَ دْشْدٍ دٍبٍ بُن مَ، شَ نَ مُ سَدٍ بُن مَ؟ عَ مُ دْشْمَ لَنثُي دْشْسٍ شَ قَرِ؟
\v 22 بَرِ مَ سٍ نَشَن بِرِن نْشُنشِ، قٌ عَ بِرِن شَ مَكّنّن. سٍ نَشَن بِرِن قِندِشِ فُندٌ رَ، قٌ عَ بِرِن شَ سَ كّنّ مَ.
\v 23 شَ وٌ تُلِ قٍ مّمَ، وٌ وٌ تُلِ مَتِ يِ مَسٍنيِ رَ.»
\p 
\v 24 عِسَ مَن نَشَ عَ مَسٍن عٍ بّ، «وٌ وٌ حْشْ سَ ﭑ مَ مَسٍنيِ شْن. وٌ مَنِيَسٍ نَشَن نَوَلِمَ بٌورٍيٍ بّ، نَ نَن نَوَلِمَ وٌ قَن بّ، عَلَ مَن ندٍ سَ عَ شُن.
\v 25 قَهَامُي كَنيِ شَ قَهَامُي شُن مَسَمَ، كْنْ قَهَامُتَرٍ، هَلِ عَ نَشَن دِ مَحْشُنشِ عَ فبٍ رَ، نَ قَمَ بَدٍ عَ يِ رَ.»
\s1 سَنسِ شْرِ شَ تَالِ
\p 
\v 26 عِسَ مَن نَشَ عَ مَسٍن، «عَلَ شَ مَنفّيَ مَنِيَشِ شّمّ نَن نَ نَشَن سَنسِ شْرِ فَرَنسَنمَ شّ مَ.
\v 27 شَ عَ شِقٍ، شَ عَ مُ شِقٍ، كْي نُن يَنيِ، سَنسِ بُلَمَ نّ، عَ تٍ، كْنْ عَ تَن مُ عَ كٌلٌن نَ رَبَمَ كِيٌكِ.
\v 28 بْشِ نَن سَنسِ رَ مْمَ عَ يّتّ مَ. عَ بُلَمَ نّ سِندٍن، عَ تٍ، عَ تْنسْي مِنِ، عَ شْرِ قَ رَقٍ.
\v 29 عَ نّقّ مْ، عَ كَنيِ عَ شَبَمَ نّ، بَرِ مَ عَ شَبَ تّمُي بَرَ عَ لِ.»
\s1 كٌندٍ شْرِ شَ تَالِ
\r مَتِيُ ١٣‏؛٣١ ٬ ٣٥، لُكِ ١٣‏؛١٨ ٬ ١٩
\p 
\v 30 عِسَ مَن نَشَ عَ مَسٍن، «وٌن نْمَ عَلَ شَ مَنفّيَ مِسَالِدٍ مُنسٍ رَ؟ وٌن نْمَ عَ شَ قٍ مَسٍندٍ تَالِ وْيّنيِ مُندُن نَ؟
\v 31 عَ مَنِيَشِ كٌندٍ شْرِ نَن نَ. عَ نّ سِمَ بْشِ تّمُي نَشّ، عَ شْرِ شُرُن بْشِ سَنسِ بِرِن بّ،
\v 32 كْنْ شَ عَ بَرَ بُلَ، عَ قِندِ عَ رَ، عَ بِلِ نُن عَ سَلٌنيِيٍ فبٌمَ دَنفِقٍ سَنسِ بِرِن نَ، شْنِيٍ نُ قَ عٍ تّي سَ عَ كْن نَ، نِينِ بُن مَ.»
\p 
\v 33 عَ نُ مِشِيٍ كَوَندِ مَ يِ تَالِ وْيّنيِ مْولِ فبٍفبٍ نَن نَ عٍ شَشِلِ بّرّ رَ.
\v 34 عَ حَن مُ نُ مَسٍنيِ يٌ تِمَ عٍ بّ شَ تَالِ دَاشِ شَ مَ رَ. كْنْ شَ عٍ نُن عَ قْشِرَبِرّيٍ دٌرٌ بَرَ لُ عَ رَ، عَ نُ عَ بِرِن تَفِ رَبَمَ نّ عٍ بّ.
\s1 عِسَ قٌيٍ بٍلٍبٍلٍ رَشَرَقٍ
\r مَتِيُ ٨‏؛٢٣ ٬ ٢٧، لُكِ ٨‏؛٢٢ ٬ ٢٥
\p 
\v 35 نُنمَرٍ تٌ سٌ نَ لْشْي كٍرٍنيِ، عِسَ نَشَ عَ قَلَ عَ قْشِرَبِرّيٍ بّ، «وٌن شّي نَاكِرِ مَ.»
\v 36 عَ قْشِرَبِرّيٍ نَشَ كٍلِ حَمَ شُن، عٍ عِسَ شَنِن كُنكُي كُي عَ نُ نَشَن كُي. عٍ نَشَ كُنكُي فبّتّيٍ قَن شَنِن.
\v 37 قٌيٍ بٍلٍبٍلٍ نَشَ كٍلِ بَا مَ، مْرْنيِ نُ قَ سَ كُنكُي كُي.
\v 38 كْنْ عِسَ تَن نُ نَ شِقٍ كُنكُي شْرّ رَ، عَ شُنيِ سَشِ شُنسَسٍ مَ. عَ قْشِرَبِرّيٍ نَشَ قَ عَ رَشُنُ، عٍ عَ قَلَ عَ بّ، «كَرَ مْشْ، عِ مُ كْنتْقِلِشِ وٌن قَشَقٍ رَ؟»
\v 39 عِسَ تٌ شُنُ، عَ نَشَ شَاحّ قٌيٍ مَ، عَ قَ بَا يَمَرِ، «دُندُ! عِ رَشَرَ!» قٌيٍ نَشَ عِتِ، بَا نَشَ رَشَرَ يٍن!
\v 40 عِسَ قَ عٍ مَشْرِن، «وٌ فَاشُشِ مُنقٍ رَ؟ هَن يَ دَنشَنِيَ مُ نَ وٌ بّ؟»
\v 41 عٍ قَن نَشَ فَاشُ كِ قَنيِ، عٍ نُ عَ قَلَ عٍ بٌرٍ بّ، «ندٍ لَنشِ يِ مَ؟ هَلِ قٌيٍ نُن بَا، عٍ عَ شُي رَبَتُمَ.»
\c 5
\s1 عِسَ حِننّيٍ كٍرِقٍ فَدَرَكَ قْشْ رَ
\r مَتِيُ ٨‏؛٢٨ ٬ ٣٤، لُكِ ٨‏؛٢٦ ٬ ٣٩
\p 
\v 1 عِسَ نُن عَ قْشِرَبِرّيٍ نَشَ قَ نَاكِرِ مَ، فَدَرَ بْشِ مَ.
\v 2 عِسَ تٌ فٌرٌ كُنكُي كُي، شّمّ ندٍ نَشَ قَ عَ رَلَندٍ، حِننّ نُ نَشَن قْشْ رَ. عَ نُ كٍلِشِ فَبُرِيٍ يِرٍ،
\v 3 بَرِ مَ عَ نُ سَبَتِشِ مّننِ نّ. مِشِ يٌ مُ نُ نْمَ عَ شِرِدٍ سْنْن، هَلِ يْلْنشْنيِ رَ.
\v 4 سَنيَ وُيَشِ، عٍ نُ بَرَ وُرٍ بَلَن عَ سَنيِيٍ مَ، عٍ يْلْنشْنيِ بَلَن عَ بّلّشّيٍ قَن مَ. كْنْ عَ نُ يْلْنشْنيِيٍ بٌلٌنمَ نّ، عَ وُرٍيٍ قَن بِرِن عِفِرَ. مِشِ يٌ مُ نُ نَ نَا نَشَن نْمَ عَ رَ.
\v 5 كْي نُن يَنيِ عَ نُ نَ فَبُرِيٍ يِرٍ نّ، عَ نُن فٍيَيٍ قَرِ. عَ نُ فبٍلٍفبٍلٍمَ، عَ نُ عَ يّتّ مَشْنْ فّمّ رَ.
\p 
\v 6 عَ تٌ عِسَ تٌ كٍلِ يِرٍ مَكُيٍ، عَ نَشَ عَ فِ، عَ سَ سُيِدِ عَ بّ.
\v 7 عَ نَشَ فبٍلٍفبٍلٍ، «عِسَ، عِ تَن عَلَ شِلِ شُنفبٍ كَنيِ شَ دِ، عِ وَ مَ مُنسٍ شْن مَ ﭑ بّ؟ ﭑ بَرَ عِ مَيَندِ عَلَ شَ قٍ رَ، عِ نَشَ ﭑ حَشَنكَتَ.»
\v 8 عِسَ نُ بَرَ عَ يَمَرِ، «عِ تَن حِننّ، فبِلٍن يِ شّمّ قْشْ رَ.»
\v 9 عِسَ مَن نَشَ عَ مَشْرِن، «عِ شِلِ دِ؟» عَ نَشَ عَ يَابِ، «ﭑ شِلِ نّ فَلِ، بَرِ مَ مُشُ فَلِ نَن عَ رَ.»
\v 10 عَ نَشَ عِسَ مَيَندِ كِ قَنيِ، عَ عَ نَشَ عٍ كٍرِ نَ بْشِ مَ.
\p 
\v 11 شْسّ فَلِ نُ نَ عٍ دّ مَدٌنقٍ فٍيَ ندٍ مَ.
\v 12 حِننّيٍ نَشَ عِسَ مَيَندِ، «مُشُ رَ سٌ يِ شْسّيٍ عَلَكٌ مُشُ شَ لُ عٍ قَتٍ.»
\v 13 عِسَ نَشَ تِن. حِننّيٍ نَشَ فبِلٍن نَ شّمّ قْشْ رَ، عٍ سٌ شْسّيٍ. شْسّيٍ نَشَ فٌرٌ عٍ فِ رَ تٍنتٍنيِ رَ، عٍ سِن بَا مَ. عٍ وُلُ قِرِن نَن نُ عَ رَ. عٍ بِرِن نَشَ مَدُلَ، عٍ قَشَ.
\p 
\v 14 نَشٍيٍ نُ نَ شْسّيٍ دّ مَدٌنقٍ، عٍ نَشَ عٍ فِ. عٍ نَشَ سَ نَ قٍ قَلَ تَاكَيٍ نُن دَاشَكَيٍ بّ، مِشِيٍ قَن نَشَ سِفَ نَ قٍ مَتٌدٍ.
\v 15 عٍ تٌ عِسَ يِرٍ لِ، عٍ نَشَ نَ شّمّ تٌ حِننّ فَلِ نُ نَشَن قْشْ رَ، عَ دْشْشِ، سٌسٍ رَفٌرٌشِ عَ مَ، عَ بَرَ شَشِلِ سْتْ. نَ نَشَ عٍ فَاشُ.
\v 16 نَشٍيٍ نُ بَرَ عَ تٌ عِسَ حِننّيٍ كٍرِشِ شّمّ قْشْ رَ كِ نَشّ، عَ نُن نَشَن نَبَ شْسّيٍ رَ، عٍ نَشَ عَ تَفِ رَبَ عٍ بِرِن بّ.
\v 17 نَ شَنبِ، نَاكَيٍ نَشَ سٌ عِسَ مَيَندِقٍ عَلَكٌ عَ شَ كٍلِ عٍ شَ بْشِ مَ.
\p 
\v 18 عِسَ تٌ نُ بَكِقٍ كُنكُي كُي، حِننّيٍ نُ شّمّ نَشَن قْشْ رَ، عَ نَشَ عِسَ مَيَندِ عَ عٍ بِرِن شَ لُ عَ رَ.
\v 19 كْنْ عِسَ مُ تِن، عَ عَ قَلَ عَ بّ، «فبِلٍن عِ شْنيِ، عِ شَ مِشِيٍ يِرٍ. سَ دّنتّفّ سَ عٍ بّ، مَرِفِ قٍ نَشَن بِرِن نَبَشِ عِ بّ، عَ نُن عَ كِنِكِنِشِ عِ مَ كِ نَشّ.»
\v 20 شّمّ نَشَ سِفَ، عَ سَ نَ بْشِ عِسَ قْلْ، نَشَن شِلِ تَا قُ. عِسَ نَشَن بِرِن نَبَشِ عَ بّ، عَ نَشَ عَ تَفِ رَبَ نَاكَيٍ بّ، بِرِن نَشَ كَابَ.
\s1 فِنّدِ مّدِ رَكٍلِقٍ قَشّ مَ
\s1 نُن فِنّ فبّتّ رَيَلَنقٍ
\r مَتِيُ ٩‏؛١٨ ٬ ٢٦، لُكِ ٨‏؛٤٠ ٬ ٥٦
\p 
\v 21 عِسَ مَن تٌ فِرِ نَاكِرِ مَ كُنكُي كُي، حَمَ فبٍفبٍ نَشَ عٍ مَلَن عَ يِرٍ بَا دّ رَ.
\v 22 سَلِدٍ يَرٍرَتِ ندٍ نَشَ قَ عَ شْن نَشَن شِلِ يَيِرُ. عَ تٌ عِسَ تٌ، عَ نَشَ سُيِدِ عَ بّ.
\v 23 عَ نَشَ عَ مَيَندِ كِ قَنيِ، «ﭑ مَ دِ فِنّ نَ عَ نِي مَفَفَقٍ! يَندِ، قَ عِ قَ عِ بّلّشّ سَ عَ مَ عَلَكٌ عَ شَ يَلَن، عَ شَ كِسِ.»
\v 24 عِسَ نَشَ سِفَ عَ قْشْ رَ. حَمَ فبٍفبٍ قَن نَشَ بِرَ عِسَ قْشْ رَ، عٍ نُ قَ عَ شّتّن.
\p 
\v 25 فِنّ ندٍ نُ نَ عٍ يَ مَ نَشَن شَ كِكٍ وَلِ مُ نُ عَ عِتِمَ حّ قُ نُن قِرِن بُن مَ.
\v 26 عَ نُ بَرَ تْورْ سٍرِبَ وُيَشِ يِ، عَ عَ هَرِفٍ بِرِن سٌ عٍ يِ رَ، كْنْ عَ مُ قِسَ. عَ شَ قُرٍ شُن نُ مَسَمَ نَن تُي.
\v 27 عَ تٌ نُ بَرَ عِسَ شَ قٍ مّ، عَ نَشَ سٌ حَمَ تَفِ، عَ قَ عِسَ شَنبِ رَ، عَ عَ بّلّشّ دِن عَ شَ دٌنمَ رَ.
\v 28 بَرِ مَ عَ نُ بَرَ عَ قَلَ عَ يّتّ بّ، «شَ ﭑ نْ ﭑ بّلّشّ دِندٍ عِسَ شَ دٌنمَ رَ فبَنسَن، ﭑ يَلَنمَ نّ.»
\v 29 عَ شَ كِكٍ وَلِ نَشَ دَن كٍرٍن نَ، عَ نَشَ عَ كٌلٌن عَ قَتٍ مَ عَ عَ بَرَ يَلَن.
\v 30 عِسَ نَشَ عَ كٌلٌن كٍرٍن نَ عَ سّنبّ ندٍ بَرَ مِنِ عَ قَتٍ يِ كَابَنَكٌ رَبَقٍ رَ. عَ نَشَ عَ يَ رَقِندِ حَمَ مَ، عَ مَشْرِنيِ تِ، «ندٍ عَ بّلّشّ دِنشِ ﭑ مَ دٌنمَ رَ؟»
\v 31 عَ قْشِرَبِرّيٍ نَشَ عَ قَلَ عَ بّ، «عِ مُ حَمَ تٌشِ عٍ عِ شّتّنقٍ كِ نَشّ؟ عِ مَن نُ قَ مَشْرِنيِ تِ، ‹ندٍ دِنشِ ﭑ نَ؟›»
\v 32 كْنْ عِسَ نَشَ عَ يَ رَفٍ عَ شَ عَ كَنيِ كٌلٌن.
\p 
\v 33 فِنّ تٌ عَ كٌلٌن قٍ نَشَن عَ سْتْشِ، عَ نَشَ فَاشُ هَن عَ سّرّن. عَ نَشَ سُيِدِ عِسَ بّ، عَ نْندِ بِرِن قَلَ عَ بّ.
\v 34 عِسَ نَشَ عَ قَلَ فِنّ بّ، «ﭑ مَ دِ، عِ شَ دَنشَنِيَ بَرَ عِ رَيَلَن. سِفَ بْحّسَ كُي، عِ شَ تْورّ بَرَ بَ عِ مَ.»
\p 
\v 35 عِسَ تٌ نُ وْيّنقٍ، مِشِ ندٍيٍ نَشَ قَ كٍلِقٍ سَلِدٍ يَرٍرَتِ شْنيِ، عٍ عَ قَلَ عَ بّ، «عِ شَ دِ فِنّ بَرَ قَشَ. هَلِ عِ مُ كَرَ مْشْ تْورْ سْنْن.»
\v 36 كْنْ عِسَ مُ عٍ شُي دَنشُن. عَ نَشَ عَ قَلَ سَلِدٍ يَرٍرَتِ بّ، «عِ نَشَ فَاشُ. عِ تَن شَ لَ عَلَ رَ تُن.»
\v 37 عِسَ مُ تِن مِشِ يٌ شَ بِرَ عَ قْشْ رَ، قٌ ثِيّرِ، يَكِ، نُن يَيَ، يَكِ شُنيَ.
\v 38 عٍ تٌ سَلِدٍ يَرٍرَتِ شْنيِ لِ، عِسَ نَشَ مِشِيٍ لِ، عٍ وَقٍ، عٍ فبٍلٍفبٍلٍقٍ.
\v 39 عَ تٌ سٌ بَنشِ كُي، عَ نَشَ عٍ مَشْرِن، «وٌ وَقٍ مُنقٍ رَ؟ وٌ فبٍلٍفبٍلٍمَ مُن مَ؟ يِ دِ مّدِ مُ قَشَشِ. عَ نَ شِقٍ نّ.»
\v 40 كْنْ عٍ تَن نَشَ سٌ عَ مَيٍلٍقٍ.
\p عِسَ تٌ عٍ بِرِن نَمِنِ، عَ نَشَ سٌ دِ مّدِ سَشِ دّننَشّ، عَ تَن نُن عَ قْشِرَبِرّيٍ، عَ نُن دِ بَبَ، نُن عَ نفَ.
\v 41 عِسَ نَشَ عَ سُشُ عَ بّلّشّ مَ، عَ عَ قَلَ عَ بّ، «تَلِتَ كُمِ». نَ نَن قَلَشِ عٍ شَ شُي، «فِنّدِ مّدِ، ﭑ نَشّ عِ بّ، كٍلِ!»
\v 42 فِنّدِ مّدِ نَشَ كٍلِ كٍرٍن نَ، عَ عَ حّرّ. عَ حّ قُ نُن قِرِن نَن نُ عَ رَ. نَشٍيٍ نُ نَ، عٍ نَشَ كَابَ كِ قَنيِ، عٍ بِرِن دّ نَشَ عِشَرَ.
\v 43 عِسَ نَشَ عَ مَتِنتِن عٍ رَ، عَ عٍ نَشَ يِ قٍ تَفِ رَبَ مِشِ يٌ بّ. عَ نَشَ عَ قَلَ عٍ بّ عٍ شَ دٌنسٍ قِ تّمّدِ مَ.
\c 6
\s1 نَسَرّتِكَيٍ تٌندِقٍ لَدٍ عِسَ رَ
\r مَتِيُ ١٣‏؛٥٣ ٬ ٥٨، لُكِ ٤‏؛١٦ ٬ ٣٠
\p 
\v 1 عِسَ نَشَ كٍلِ مّننِ، عَ سِفَ عَ شْنيِ، عَ مْشِ دّننَشّ. عَ قْشِرَبِرّيٍ نَشَ بِرَ عَ قْشْ رَ.
\v 2 مَلَبُ لْشْي، عَ نَشَ مِشِيٍ كَوَندِ قْلْ سَلِدٍ كُي. مِشِ فبٍفبٍ نَشَ عَ شُي مّ. عٍ دّ نَشَ عِشَرَ، عٍ عٍ بٌرٍ مَشْرِن، «ندٍ يِ مَسٍنشِ يِ بّ؟ عَ لْننِ مُندُن سْتْشِ يِ كِ؟ عَ نْشِ يِ كَابَنَكٌ قٍيٍ رَبَدٍ دِ؟
\v 3 كَمُدّرِ شَ مُ عَ رَ، مَرِيَمَ شَ دِ؟ يَكِ، يُسُقُ، يُدَ، نُن سِمْن تَارَ شَ مُ عَ رَ؟ عَ شُنيَ فِنّمَيٍ قَن مُ نَ وٌن يَ مَ بٍ؟» نَ كُي، عٍ مُ لَ عَ رَ، عٍ شْنْ عَ مَ.
\p 
\v 4 عِسَ قَن نَشَ عَ مَسٍن عٍ بّ، «نَمِحْنمّ بِنيَشِ يِرٍ بِرِن، قٌ عَ شْنيِ، عَ بَرِبٌورٍيٍ، نُن عَ نفَشَكٍرٍنيِيٍ تَفِ.»
\v 5 عِسَ مُ نْ كَابَنَكٌ يٌ رَبَدٍ نَا، قٌ عَ تٌ عَ بّلّشّ سَ قُرٍ مَ كٍرٍن كٍرٍن مَ، عَ عٍ رَيَلَن.
\v 6 عِسَ نَشَ كَابَ عٍ شَ دَنشَنِيَتَرٍحَ مَ.
\s1 عِسَ عَ قْشِرَبِرّ قُ نُن قِرِنيِيٍ شّيقٍ
\r مَتِيُ ١٠‏؛٥ ٬ ٤٢، لُكِ ٩‏؛١ ٬ ٦
\p 
\v 7 عِسَ نَشَ عَ قْشِرَبِرّ قُ نُن قِرِنيِيٍ شِلِ، عَ عٍ شّي قِرِن قِرِن نَ. عَ نَشَ نْي قِ عٍ مَ عٍ شَ نْ حِننّيٍ كٍرِدٍ مِشِيٍ قْشْ رَ.
\v 8 عَ نَشَ عَ قَلَ عٍ بّ، «وٌ نَشَ سٍسٍ شَنِن وٌ شُن مَ، هَلِ تَامِ، فبْنقْي، نُن كْبِرِ. وٌ شُلِ فبَنسَن نَن شَنِن.
\v 9 وٌ سَنكِرِيٍ سٌ، كْنْ وٌ نَشَ دٌنمَ قِرِن شَنِن وٌ شُن.»
\v 10 عَ نَشَ عَ قَلَ عٍ بّ، «وٌ نَ سٌ بَنشِ نَشَن كُي، وٌ شَ يِفِيَ مّننِ نّ هَن وٌ سِفَمَ يِرٍ فبّتّ تّمُي نَشّ.
\v 11 شَ مِشِ ندٍيٍ تٌندِ وٌ رَ سّنّدٍ، عٍ مُ عٍ تُلِ مَتِ وٌ رَ، وٌ نّ كٍلِمَ نَا، وٌ شَ مّننِ بّندّ رَكْنكْن وٌ سَنيِيٍ رَ، عَ شَ قِندِ سٍيدٍحْشْيَ رَ عٍ بّ، وٌ بَرَ عٍ رَبٌلٌ.»
\p 
\v 12 نَ كُي، عِسَ قْشِرَبِرّيٍ نَشَ سِفَ كَوَندِ تِدٍ مِشِيٍ بّ عَلَكٌ عٍ شَ تُوبِ.
\v 13 عٍ نَشَ حِننّيٍ كٍرِ مِشِ فبٍفبٍ قْشْ رَ. عٍ نَشَ تُرٍ سَ قُرٍ مَ فبٍفبٍ مَ، عٍ عٍ رَيَلَن.
\s1 عَننَبِ يَيَ شَ قَشّ
\r مَتِيُ ١٤‏؛١ ٬ ١٢، لُكِ ٩‏؛٧ ٬ ٩
\p 
\v 14 فَلِلٍ مَنفّ هٍرٌدٍ نَشَ يِ قٍ مّ، بَرِ مَ عِسَ شِلِ نُ بَرَ تٍ، عَ دِن يِرٍ بِرِن نَ. ندٍيٍ نُ عَ قَلَمَ، «يَيَ شُنشَ نَن كٍلِشِ قَشّ مَ. نَ نَن عَ تٌشِ نْي نَ عَ يِ عَ شَ كَابَنَكٌي رَبَ.»
\v 15 فبّتّيٍ قَن نُ عَ قَلَمَ، «عَننَبِ عٍلِيَ نَ عَ رَ.» ندٍيٍ قَن نُ عَ قَلَمَ، «نَمِحْنمّ نَن عَ رَ نَشَن لُشِ عَلْ نَمِحْنمّ دَنفِشِيٍ.»
\v 16 كْنْ هٍرٌدٍ تٌ عِسَ شَ قٍ مّ، عَ نَشَ عَ قَلَ، «ﭑ يَيَ نَشَن شُنيِ بٌلٌن، نَ نَن كٍلِشِ قَشّ مَ.»
\p 
\v 17 عَ نَ قَلَ نّ، بَرِ مَ عَ تَن هٍرٌدٍ يَتِ نَن مِشِيٍ شّي يَيَ سُشُدٍ، يْلْنشْنيِ شَ سَ عَ مَ، عَ شَ سَ فٍيلِ هٍرٌدِيَسِ شَ قٍ رَ، عَ تَارَ قِلِثُ شَ فِنّ، هٍرٌدٍ نَشَن دْشْ.
\v 18 يَيَ نُ عَ قَلَمَ هٍرٌدٍ بّ، «عَ مُ دَشَ عِ شَ عِ تَارَ شَ فِنّ تٌنفٌ.»
\v 19 نَ نَشَ عَ نِيَ يَيَ نَشَ رَحَاشُ هٍرٌدِيَسِ مَ، عَ نَشَ وَ عَ شَ قَشّ شْن. كْنْ عَ قَشَ قّيرّ مُ نُ نَ عَ بّ،
\v 20 بَرِ مَ هٍرٌدٍ مُ نُ سُو سَمَ يَيَ رَ. عَ نُ عَ كٌلٌن مِشِ نَ عَ رَ، نَشَن تِنشِن، عَ مَن سّنِيّن. نَ نَ عَ تٌشِ، عَ نُ عَ مَكَنتَمَ. هٍرٌدٍ نُ عَ تُلِ تِمَ يَيَ رَ تّمُي نَشّ، عَ نُ كْنتْقِلِمَ عَ شَ وْيّنيِ رَ، كْنْ عَ مَن نُ رَقَن عَ مَ عَ شَ نُ عَ تُلِ مَتِ عَ رَ.
\p 
\v 21 لْشْ ندٍ، هٍرٌدِيَسِ نَشَ قّيرّ سْتْ يَيَ قَشَقٍ مَ. هٍرٌدٍ نَشَ حّلّشِن شُلُنيِ تِ عَ بَرِ لْشْي عِفبِلٍنيِ شَ قٍ رَ. عَ نَشَ مِشِ بِنيٍيٍ شِلِ، عَ شَ سْورِيٍ شَ مَنفّيٍ، عَ نُن فَلِلٍ بْشِ مِشِ شُنفبٍيٍ.
\v 22 هٍرٌدِيَسِ شَ دِ فِنّ تٌ سٌ مّننِ، عَ قَرٍ بٌرٌن مِشِيٍ بّ، عَ نَشَ رَقَن هٍرٌدٍ نُن عَ شَ شْحّيٍ مَ. مَنفّ نَشَ عَ قَلَ يِ فِنّدِ مّدِ بّ، «عِ وَ مَ نَشَن يٌ شْن، عَ قَلَ ﭑ بّ ﭑ شَ عَ قِ عِ مَ.»
\v 23 عَ نَشَ عَ كَلِ، عَ عَ قَلَ عَ بّ، «عِ نَ نَشَن يٌ مَشْرِن ﭑ مَ، ﭑ نَ سٌمَ نّ عِ يِ رَ، هَلِ عَ قِندِ ﭑ مَ مَنفّيَ سّيتِ رَ.»
\v 24 فِنّدِ مّدِ نَشَ مِنِ عَ سَ عَ نفَ مَشْرِن، «عَ لَن ﭑ شَ مُنسٍ مَشْرِن عَ مَ؟» عَ نفَ نَشَ عَ يَابِ، «يَيَ شُنيِ.»
\v 25 فِنّدِ مّدِ نَشَ عَ شُلُن مَقُرٍن سِفَقٍ مَنفّ يِرٍ، عَ عَ قَلَ عَ بّ، «ﭑ وَ مَ عَ شْن مَ نّ، عِ شَ يَيَ شُنيِ سٌ ﭑ يِ رَ ثِلٍتِ مَ كٍرٍن نَ.»
\v 26 مَنفّ نَشَ نِمِسَ نَ مَ كِ قَنيِ، كْنْ عَ شَ مَرَكَلِ نُن عَ شَ شْحّيٍ شَ قٍ رَ، عَ مُ نْ تٌندِدٍ عَ بّ.
\v 27 عَ نَشَ سْورِ شّي كٍرٍن نَ، عَ شَ سَ قَ يَيَ شُنيِ رَ. سْورِ نَشَ سِفَ فٍيلِ كُي، عَ سَ يَيَ شُنيِ بٌلٌن عَ دّ عِ.
\v 28 عَ نَشَ قَ عَ شُنيِ رَ ثِلٍتِ مَ، عَ نَ سٌ فِنّدِ مّدِ يِ رَ. فِنّدِ مّدِ قَن نَشَ عَ شَنِن عَ نفَ شْن مَ.
\v 29 يَيَ قْشِرَبِرّيٍ تٌ يِ قٍ مّ، عٍ نَشَ سَ عَ قُرٍ تٌنفٌ، عٍ عَ رَفَتَ.
\s1 عِسَ دٌنسٍ قِقٍ شّمّ مِشِ وُلُ سُولِ مَ
\r مَتِيُ ١٤‏؛١٣ ٬ ٢١، لُكِ ٩‏؛١٠ ٬ ١٧
\p 
\v 30 شّيرَيٍ مَن نَشَ نَرَلَن عِسَ يِرٍ. عٍ قٍ نَشٍيٍ رَبَ، عٍ كَوَندِ نَشٍيٍ تِ، عٍ نَشَ عَ بِرِن دّنتّفّ سَ عَ بّ.
\v 31 عِسَ نَشَ عَ قَلَ عٍ بّ، «وٌن شّي يِرٍ مَدُندُشِ عَلَكٌ وٌن دٌرٌ شَ لُ يِرٍ كٍرٍن، وٌ شَ وٌ مَلَبُ.» عَ نَ قَلَ نّ، بَرِ مَ مِشِيٍ شَ قَ نُن سِفّ فبٌ عٍ يِرٍ. عٍ حَن مُ نُ نْمَ عٍ يّتّ سْتْدٍ، عٍ شَ عٍ دّفٍ.
\v 32 نَ كُي، عٍ نَشَ بَكِ كُنكُي كُي، عٍ دٌرٌ شَ سِفَ وُلَ عِ.
\p 
\v 33 مِشِ وُيَشِ نَشَ عٍ تٌ سِفَ رَ، عٍ نَشَ عٍ كٌلٌن. عٍ فبٍفبٍ نَشَ كٍلِ نَ تَايٍ، عٍ عٍ فِ عٍ سَنيِ رَ هَن عٍ تَن سِنفٍ سَ سٌ عِسَ نُن عَ قْشِرَبِرّيٍ نُ سِفَقٍ دّننَشّ.
\v 34 عِسَ تٌ فٌرٌ كُنكُي كُي، عَ نَشَ حَمَ فبٍفبٍ تٌ نَا. عَ نَشَ كِنِكِنِ عٍ مَ، بَرِ مَ عٍ نُ لُشِ نّ عَلْ يّشّي نَشٍيٍ مَكَنتَمَ مُ نَ. عَ نَشَ عٍ كَوَندِ قْلْ قٍ فبٍفبٍ رَ.
\p 
\v 35 نُنمَرٍ تٌ سٌ قْلْ، عِسَ قْشِرَبِرّيٍ نَشَ عٍ مَسٌ عِسَ رَ، عٍ عَ قَلَ عَ بّ، «وٌن نَ وُلَ نّ يِ كِ، كْي قَن بَرَ سٌ.
\v 36 حَمَ رَيٍنسٍن عَلَكٌ عٍ شَ سِفَ تَايٍ نُن دَاشَيٍ نَشٍيٍ نَ بٍ رَبِلِنيِ، عٍ شَ سَ دٌنسٍيٍ سَرَ.»
\v 37 كْنْ عِسَ نَشَ عٍ يَابِ، «وٌ تَن شَ دٌنسٍ سٌ عٍ يِ.» عٍ تَن نَشَ عَ قَلَ عَ بّ، «شَ مُشُ سَ تَامِ سَرَ يِ حَمَ بِرِن بّ، نَ كْبِرِ سِفَمَ هَن وَلِكّ شَ كِكٍ سٌلٌمَسَشَن سَرٍ!»
\v 38 عَ نَشَ عٍ مَشْرِن، «تَامِ يٍرِ نَ وٌ يِ رَ؟ وٌ سَ نَ مَتٌ.» عٍ تٌ عَ مَتٌ، عٍ نَشَ عَ يَابِ، «تَامِ سُولِ، عَ نُن يّشّ قِرِن.»
\p 
\v 39 عَ نَشَ يَامَرِ قِ مِشِ بِرِن مَ، عٍ شَ عٍ مَفٌرٌ عٍ شُندّ شُندّ مَ حٌوفٍ شِندٍ قَرِ.
\v 40 نَ كُي، مِشِيٍ نَشَ سِفَ دْشْ رَ عٍ كّمّ كّمّ نُن عٍ تٌنفٌ سُولِ سُولِ مَ.
\v 41 عِسَ نَشَ نَ تَامِ سُولِ نُن نَ يّشّ قِرِن تٌنفٌ، عَ عَ يَ رَتٍ كٌورٍ مَ، عَ قَ عَلَ نُوَلِ سَ. عَ نَشَ تَامِيٍ عِفِرَ، عَ قَ عَ سٌ عَ قْشِرَبِرّيٍ يِ رَ، عٍ شَ عٍ عِتَشُن حَمَ مَ. عَ نَشَ نَ يّشّ قِرِنيِيٍ قَن عِتَشُن بِرِن مَ.
\v 42 حَمَ بِرِن نَشَ عٍ دّفٍ هَن عٍ وَ سَ.
\v 43 تَامِ نُن يّشّ دْنشْي تٌ مَتٌنفٌ، دٍبٍ قُ نُن قِرِن نَن نَقٍ.
\v 44 مِشِ نَشٍيٍ تَامِ دٌن، شّمّ وُلُ سُولِ نَن نُ عٍ رَ.
\s1 عِسَ حّرّقٍ يٍ قَرِ
\r مَتِيُ ١٤‏؛٢٢ ٬ ٣٣
\p 
\v 45 نَ شَنبِ، عِسَ نَشَ عَ قَلَ عَ قْشِرَبِرّيٍ بّ، عٍ شَ بَكِ كُنكُي كُي، عٍ فِرِ نَاكِرِ مَ. عٍ شَ سِفَ عَ يَ رَ بٍتٍسَيِدَ، عَ تَن شَ نُ حَمَ رَفبِلٍن.
\v 46 عَ تٌ فّ عَ حُنفُدٍ حَمَ مَ، عَ نَشَ تٍ عَلَ مَشَندِدٍ فٍيَ قَرِ.
\p 
\v 47 كْي تٌ سٌ، كُنكُي نُ نَ بَا تَفِ. عِسَ كٍرٍن نَن نُ نَ شَرٍ مَ.
\v 48 عَ نَشَ عَ قْشِرَبِرّيٍ تٌ عٍ نَ تْورْقٍ عَ حَاشِ رَ لَالَ بَدٍ، بَرِ مَ قٌيٍ يَ نُ رَقِندِشِ عٍ مَ. سُبَشّ، عِسَ نَشَ قَ عَ قْشِرَبِرّيٍ مَ، عَ حّرّقٍ بَا قَرِ. عَ فبٍ مُ نُ لُشِ عَ شَ دَنفِ عٍ رَ،
\v 49 عٍ قَ عَ تٌ حّرّ رَ يٍ قَرِ. عٍ نَشَ عَ مَحْشُن تُبَرِ رَ، عٍ سْنشْي رَتٍ،
\v 50 بَرِ مَ عٍ بِرِن نُ عِسَ تٌشِ، عٍ بِرِن فَاشُشِ. كْنْ عِسَ نَشَ عَ مَسٍن عٍ بّ كٍرٍن نَ، «وٌ نَشَ كْنتْقِلِ، ﭑ تَن نَن عَ رَ. وٌ نَشَ فَاشُ.»
\v 51 عِسَ نَشَ تٍ عٍ شَ كُنكُي كُي، قٌيٍ قَن نَشَ عَ رَشَرَ. عٍ بِرِن نَشَ كَابَ، عٍ دّ عِشَرَ.
\v 52 عٍ مُ نُ تَامِيٍ شَ كَابَنَكٌ قٍ قَهَامُشِ، بَرِ مَ عٍ شَشِلِ مُ نُ رَبِشِ.
\s1 عِسَ قُرٍ مَ فبٍفبٍ رَيَلَنقٍ فٍنٍسَرٍتِ
\r مَتِيُ ١٤‏؛٣٤ ٬ ٣٦
\p 
\v 53 عٍ تٌ فّ بَا عِفِرِدٍ، عٍ نَشَ سٌ فٍنٍسَرٍتِ بْشِ، عٍ كُنكُي شِرِ نَا.
\v 54 عٍ تٌ فٌرٌ كُنكُي كُي، مِشِيٍ نَشَ عِسَ كٌلٌن كٍرٍن نَ،
\v 55 عٍ نَشَ نَ بْشِ بِرِن عِسَ. عٍ نُ عِسَ شِلِ مّمَ دّدّ، عٍ نُ قَمَ عٍ فِ رَ قُرٍ مَيٍ رَ عَ شْن، عٍ سَشِ عٍ شَ سَدٍيٍ مَ.
\v 56 عِسَ نُ سٌمَ دَاشَ نُن تَا يٌ كُي، مِشِيٍ نُ قُرٍ مَيٍ سَمَ عَ يَ رَ يِرٍ مَكّنّنشِيٍ، عٍ عَ مَيَندِ عٍ شَ عٍ بّلّشّ دِن عَ شَ دٌنمَ سَنبُنيِ فبَنسَن نَ. قُرٍ مَ بِرِن نَشٍيٍ نَ رَبَ، عٍ بِرِن نَشَ يَلَن.
\c 7
\s1 عَلَ شَ سّرِيّ نُن عَدَ مَ شَ نَامُنيِ
\r مَتِيُ ١٥‏؛١ ٬ ٢٠
\p 
\v 1 قَرِ سّنِيٍ نَشَ عٍ مَلَن عِسَ يِرٍ، عٍ نُن سّرِيّ كَرَ مْشْ ندٍيٍ نَشٍيٍ نُ بَرَ قَ كٍلِقٍ دَرِ سَلَمُ.
\v 2 عٍ نَشَ عَ تٌ، عَ قْشِرَبِرّ ندٍيٍ عٍ دّفٍمَ عٍ بّلّشّ سّنِيّنتَرٍيٍ رَ، عٍ مُ عٍ رَشَشِ نَامُنيِ كِ مَ.
\p 
\v 3 قَرِ سّنِيٍ نُن يُوِقِ بِرِن نّ عٍ دّفٍمَ قٌ عٍ عٍ بّلّشّ رَشَ سِندٍن عٍ شَ نَامُنيِ كِ مَ نَشَن قَتَنشِ عٍ بٍنبَيٍ رَ.
\v 4 شَ عٍ كٍلِ حَمَ يِرٍ، عٍ مُ عٍ دّفٍمَ سِندٍن، قٌ عٍ فّ عٍ مَشَدٍ عَ دِينّ كِ مَ. نَامُنيِ وُيَشِ مَن نَ عٍ يِ رَ، عَلْ تْنبِلِ، تُندٍ، نُن ثَانِ مَشَ كِ.
\p 
\v 5 نَ كُي، قَرِ سّنِيٍ نُن سّرِيّ كَرَ مْشْيٍ نَشَ عِسَ مَشْرِن، «مُنقٍ رَ عِ قْشِرَبِرّيٍ مُ بِرَشِ قٌرِيٍ شَ نَامُنيِيٍ قْشْ رَ، عٍ نُ عٍ دّفٍ عٍ بّلّشّ سّنِيّنتَرٍيٍ رَ؟»
\v 6 عِسَ نَشَ عٍ يَابِ، «وٌ تَن قِلَنكَقُييٍ، عَننَبِ عٍسَيِ نْندِ يَتِ نَن مَسٍن وٌ شَ قٍ رَ عَ شَ كِتَابُي كُي،
\q1 ‹يِ حَمَ ﭑ بِنيَمَ عٍ دّ نّ،
\q1 كْنْ عٍ بْحّ مَكُيَ ﭑ نَ ثٌن!
\q1 
\v 7 عٍ شَ سَلِ قُقَقُ نَ عَ رَ،
\q1 بَرِ مَ عٍ مِشِ شَرَنمَ عَدَ مَدِيٍ شَ مَحْشُنيِيٍ نَن نَ
\q1 عَلْ نَ نَامُنيِيٍ نَن قِندِشِ ﭑ تَن مَ سّرِيّ نَن نَ.›»
\m 
\v 8 «وٌ بَرَ عَلَ شَ سّرِيّ بّحِن، وٌ بِرَ مِشِيٍ شَ نَامُنيِ قْشْ رَ.»
\p 
\v 9 عِسَ مَن نَشَ عَ مَسٍن عٍ بّ، «وٌ قَتَشِ دٍ! وٌ فبِلٍنشِ عَلَ شَ سّرِيّ نَن قْشْ رَ عَلَكٌ وٌ شَ بِرَ وٌ فبٍ نَامُنيِ قْشْ رَ!
\v 10 عَننَبِ مُنسَ بَرَ عَ مَسٍن، ‹وٌ شَ وٌ بَبَ نُن وٌ نفَ بِنيَ.› عَ مَن بَرَ عَ مَسٍن، ‹مِشِ يٌ نَشَن عَ بَبَ نُن عَ نفَ كٌنبِ، عَ لَن نّ نَ كَنيِ شَ قَشَ.›
\v 11 كْنْ وٌ تَن نَشّ، شَ مِشِ ندٍ عَ قَلَ عَ بَبَ شَ نَ مُ عَ نفَ بّ، ‹عِ نُ لَنمَ عِ شَ نَشَن سْتْ ﭑ نَ عِ مَلِسٍ رَ، ﭑ بَرَ عَ قِ عَلَ مَ،›
\v 12 هَلِ نَ كَنيِ مُ قٍقٍ رَبَ عَ بَبَ نُن عَ نفَ بّ.
\v 13 نَ كُي، وٌ عَلَ شَ سّرِيّ مَتَندِ مَ وٌ شَ نَامُنيِيٍ سَابُي رَ، وٌ مَن قَ نٍيٍ نَن مَسٍنمَ وٌ شَ دِيٍ بّ. وٌ نَ قٍ مْولِ فبٍفبٍ نَن نَبَمَ، بَقٍ يِ رَ.»
\p 
\v 14 عِسَ مَن نَشَ حَمَ شِلِ، عَ عَ مَسٍن عٍ بّ، «وٌ بِرِن شَ وٌ تُلِ مَتِ ﭑ نَ، وٌ شَ قَهَامُي سْتْ.
\v 15‏-16 دٌنسٍ نَشَن كٍلِ عَ قَرِ مَ، عَ سٌ مِشِ قَتٍ عِ، عَ سٍسٍ مُ نَ نَشَن نْمَ عَ كَنيِ قِندِدٍ مِشِ سّنِيّنتَرٍ رَ. قٍ كٌبِ نَشٍيٍ كٍلِمَ مِشِ بْحّ مَ، نٍيٍ نَن عَ كَنيِ قِندِ مَ مِشِ سّنِيّنتَرٍ رَ.»
\p 
\v 17 عِسَ تٌ بَرَ كٍلِ حَمَ شُن، عَ سٌ بَنشِ، عَ قْشِرَبِرّيٍ نَشَ عَ مَشْرِن يِ تَالِ وْيّنيِ مَ.
\v 18 عَ نَشَ عَ مَسٍن عٍ بّ، «يَشَ وٌ قَن مُ قَهَامُي سْتْ؟ وٌ مُ عَ كٌلٌن، عَ دٌنسٍ يٌ كٍلِ عَ قَرِ مَ، عَ سٌ مِشِ قَتٍ عِ، نَ مُ نْمَ عَ كَنيِ قِندِدٍ مِشِ سّنِيّنتَرٍ رَ؟
\v 19 بَرِ مَ نَ مُ سٌمَ بْحّ شَ كُي، عَ فٌرٌ مَ قُرِ نّ، عَ قَ مِنِ مِشِ قَتٍ عِ.» نَ كُي، عِسَ عَ مَسٍن نّ، عَ دٌنسٍ بِرِن سّنِيّن.
\v 20 عَ مَن نَشَ عَ مَسٍن، «قٍ كٌبِ نَشَن كٍلِمَ مِشِ بْحّ مَ، نَ نَن عَ كَنيِ قِندِ مَ مِشِ سّنِيّنتَرٍ رَ.
\v 21 بَرِ مَ شَشِلِ كٌبِ قَتَنمَ مِشِ بْحّ نَن نَ، عَلْ لَنفٌيحَ، مُحّ، قَشّ تِقٍ،
\v 22 يّنّ، وَ سَتَرٍيَ، حَاشُي، يَنقَنتٍيَ، حّنفّيَ، تْونّ، كٌنبِ، يّتّ عِفبٌي، نُن دَشُحَ.
\v 23 نَ قٍ كٌبِيٍ بِرِن كٍلِمَ مِشِ بْحّ نَن مَ، عٍ عَ كَنيِ قِندِ مِشِ سّنِيّنتَرٍ رَ.»
\s1 سِرِيَ قٍنِسِيَ فِنّ شَ دَنشَنِيَ
\r مَتِيُ ١٥‏؛٢١ ٬ ٢٨
\p 
\v 24 عِسَ نَشَ كٍلِ مّننِ، عَ سِفَ تِرٍ بْشِ مَ. عَ نَشَ سٌ عَ يِفِيَدٍ. عَ مُ نُ وَ مَ مِشِ يٌ شَ عَ يِرٍ كٌلٌن، كْنْ عَ مُ نْ عَ نْشُندٍ.
\v 25 فِنّ ندٍ نُ نَ، حِننّ نُ نَشَن شَ دِ فِنّ قْشْ رَ. عَ تٌ عِسَ شَ قٍ مّ، عَ نَشَ قَ عَ يِرٍ، عَ سُيِدِ عَ بّ.
\v 26 يُوِقِ شَ مُ نُ يِ فِنّ رَ، عَ نُ بَرِشِ سِرِيَ قٍنِسِيَ نّ. عَ نَشَ عِسَ مَيَندِ، عَ شَ حِننّ كٍرِ عَ شَ دِ فِنّ قْشْ رَ.
\v 27 عِسَ نَشَ عَ يَابِ، «عَ لُ دِ مّيٍ نَن سِنفٍ شَ عٍ دّفٍ، بَرِ مَ عَ مُ لَن تَامِ شَ بَ دِ مّدِيٍ يِ رَ، عَ سَ بَرٍيٍ بُن.»
\v 28 فِنّ قَن نَشَ عَ يَابِ، «مَرِفِ، عِ نْندِ، كْنْ بَرٍدِ نَشٍيٍ نَ تٍيبِلِ بُن مَ، عٍ قَن دِ مّيٍ شَ دٌنسٍ دٌنمَ نَشَن بِرَ مَ بْشِ.»
\v 29 عِسَ نَشَ عَ قَلَ عَ بّ، «عِ شَ يَابِ شَ قٍ رَ، سِفَ، حِننّ بَرَ فبِلٍن عِ شَ دِ فِنّ قْشْ رَ.»
\v 30 فِنّ تٌ فبِلٍن عَ شْنيِ، عَ نَشَ عَ شَ دِ لِ عَ سَشِ سَدٍ مَ، حِننّ بَرَ فبِلٍن عَ قْشْ رَ.
\s1 عِسَ تُلِشْرِ بٌبٌشِ رَيَلَنقٍ
\p 
\v 31 عِسَ نَشَ كٍلِ تِرٍ بْشِ، عَ دَنفِ سِدْن، عَ فبِلٍن فَلِلٍ بَا مَبِرِ، تَا قُ بْشِ مَ.
\v 32 عٍ نَشَ قَ تُلِشْرِ ندٍ رَ عَ شْن مَ، وْيّنقٍ شْرْشْشِ نَشَن مَ، عٍ عِسَ مَيَندِ عَ شَ عَ بّلّشّ سَ عَ مَ.
\v 33 عِسَ نَشَ تُلِشْرِ تٌنفٌ حَمَ يِرٍ، عٍ سَ تِ عٍ شَتِ مَ. عِسَ نَشَ عَ بّلّشّسٌلٍيٍ رَ سٌ تُلِشْرِ تُلِيٍ كُي، عَ عَ يّتّ كَن دّيٍ سَ عَ نّنيِ مَ.
\v 34 عَ نَشَ عَ يَ رَتٍ كٌورٍ، عَ عَ حّنفِ رَتٍ عَ بٍلٍبٍلٍ رَ. عَ قَ عَ قَلَ تُلِشْرِ بّ، «عٍقَقَتَ!» نَ نَن قَلَشِ عٍ شَ شُي، «عِ شَ رَبِ!»
\v 35 عَ تُلِيٍ نَشَ قٍ مّ كٍرٍن نَ، عَ نّنيِ قَن نَشَ كٍلِ، عَ نَشَ وْيّن قْلْ عَ قَنيِ رَ.
\p 
\v 36 عِسَ نَشَ عٍ يَمَرِ، عَ عٍ نَشَ يِ قٍ قَلَ مِشِ يٌ بّ. كْنْ هَلِ عِسَ تٌ نُ تْنيِ دْشْمَ عٍ مَ كِيٌكِ، عٍ تَن نُ سِفَمَ عَ شَ شِبَارُ قَلَ رَ نَن تُي.
\v 37 عٍ نُ بَرَ كَابَ كِ قَنيِ، عٍ نُ عَ قَلَ، «عَ قٍ قَنيِ مْولِ بِرِن نَبَمَ! عَ عَ نِيَمَ تُلِشْرِ شَ قٍ مّ، بٌبٌي قَن شَ وْيّن!»
\c 8
\s1 عِسَ دٌنسٍ قِقٍ شّمّ مِشِ وُلُ نَانِ مَ
\r مَتِيُ ١٥‏؛٣٢ ٬ ٣٩
\p 
\v 1 نَ سَشَنيِ، حَمَ فبٍفبٍ مَن نُ بَرَ عٍ مَلَن. دٌنسٍ تٌ مُ نُ عٍ يِ رَ، عِسَ نَشَ عَ قْشِرَبِرّيٍ شِلِ، عَ عَ مَسٍن عٍ بّ،
\v 2 «ﭑ بَرَ كِنِكِنِ يِ حَمَ مَ، بَرِ مَ عَ شِ سَشَن نَن يِ كِ، عٍ نَ ﭑ يِرٍ. دٌنسٍ يٌ مُ عٍ بّ يِ كِ.
\v 3 ﭑ نَ عَ قَلَ يَ، عٍ شَ سِفَ عٍ شْنيِ كَامّ رَ عٍ مَ، عٍ تْورْ مَ نّ كِرَ شْن كِ قَنيِ. ندٍيٍ نَ عٍ يَ مَ، عٍ كٍلِدٍ مَكُيَ.»
\v 4 عِسَ قْشِرَبِرّيٍ نَشَ عَ يَابِ، «تَامِ سْتْمَ دِ يِ وُلَ كُي نَشَن يِ حَمَ وَ سَمَ؟»
\v 5 عِسَ نَشَ عٍ مَشْرِن، «تَامِ فُندِ يٍرِ نَ وٌ يِ؟» عٍ نَشَ عَ يَابِ، «سٌلٌقٍرٍ.»
\p 
\v 6 عِسَ نَشَ عَ قَلَ حَمَ بّ عٍ شَ دْشْ بْشِ. عَ نَشَ نَ تَامِ فُندِ سٌلٌقٍرٍ تٌنفٌ، عَ عَلَ نُوَلِ سَ. عَ تٌ عٍ عِفِرَ، عَ نَشَ عٍ سٌ عَ قْشِرَبِرّيٍ يِ رَ، عٍ شَ عٍ عِتَشُن حَمَ مَ. عٍ قَن نَشَ عَ رَبَ نَ كِ.
\v 7 يّشّ لَنمَ ندٍيٍ قَن نُ نَ عٍ يِ رَ. عِسَ تٌ عَلَ نُوَلِ سَ عٍ شَ قٍ رَ، عَ نَشَ عَ قَلَ، عَ عٍ قَن شَ عِتَشُن.
\v 8 حَمَ نَشَ عَ دّفٍ هَن عٍ وَ سَ. دٌنسٍ دْنشْي قَن نَشَ مَتٌنفٌ هَن دٍبٍ سٌلٌقٍرٍ نَشَ رَقٍ.
\v 9 مِشِ وُلُ نَانِ حْندْن نَن نُ نَ نَا. عِسَ تٌ عٍ رَفبِلٍن،
\v 10 عَ نَشَ تٍ كُنكُي كُي كٍرٍن نَ، عٍ نُن عَ قْشِرَبِرّيٍ نَشَ سِفَ دَلَمَنُتَ بْشِ مَ.
\s1 قَرِ سّنِيٍ نُن سَدُ سٍنِيٍ شَ دَنشَنِيَتَرٍحَ
\r مَتِيُ ١٦‏؛١ ٬ ١٢
\p 
\v 11 قَرِ سّنِيٍ نَشَ قَ، عٍ نُن عِسَ نَشَ وْيّن قْلْ. عٍ تٌ نُ وَ مَ عَ مَتٌقٍ، عٍ نَشَ عَ مَشْرِن عَ شَ تْنشُمَ مَكَابَشِ ندٍ مَسٍن عٍ بّ كٍلِقٍ كٌورٍ مَ.
\v 12 نَ نَشَ عِسَ بْحّ تْورْ كِ قَنيِ. عَ نَشَ عَ مَسٍن، «مُنقٍ رَ يِ وَشَتِ مِشِيٍ ﭑ مَشْرِنمَ تْنشُمَ مَكَابَشِ مَ؟ ﭑ شَ نْندِ قَلَ وٌ بّ، تْنشُمَ يٌ مُ قِمَ يِ وَشَتِ مِشِيٍ مَ.»
\v 13 نَ شَنبِ عَ نَشَ كٍلِ عٍ شُن مَ، عَ مَن بَكِ كُنكُي كُي فِرِقٍ رَ نَاكِرِ مَ.
\p 
\v 14 عَ قْشِرَبِرّيٍ نُ بَرَ نّيمُ قَدٍ تَامِ ندٍ رَ عٍ شُن. تَامِ فُندِ كٍرٍن ثٍتِ نَن نُ نَ عٍ يِ رَ كُنكُي كُي.
\v 15 عِسَ نَشَ يِ مَتِنتِن عٍ رَ، «وٌ وٌ يّتّ رَتَنفَ قَرِ سّنِيٍ نُن هٍرٌدٍ شَ لّبِنِ مَ.»
\v 16 عٍ نَشَ سٌ وْيّنقٍ عٍ بٌرٍ بّ نَ قٍ مَ، عَ عَ نَ قَلَشِ نّ بَرِ مَ تَامِ مُ نَ عٍ يِ رَ.
\v 17 عِسَ تٌ عٍ شَ وْيّنيِ كٌلٌن، عَ نَشَ عَ مَسٍن عٍ بّ، «وٌ تَامِ قٍ قَلَمَ وٌ بٌرٍ بّ مُنقٍ رَ؟ هَن يَ وٌ مُ شَشِلِ سْتْ، وٌ مُ قٍ قَهَامُ؟ وٌ شَشِلِ مُ رَبِشِ؟
\v 18 يَ نَ وٌ بّ، كْنْ وٌ مُ سٍ تٌمَ. تُلِ نَ وٌ بّ، كْنْ وٌ مُ قٍ مّمَ. وٌ نّيمُشِ نّ؟
\v 19 ﭑ تَامِ فُندِ سُولِ عِتَشُن مِشِ وُلُ سُولِ مَ دّننَشّ، وٌ دٍبٍ يٍرِ رَقٍ تَامِ دْنشْي رَ؟» عٍ نَشَ عَ يَابِ، «قُ نُن قِرِن.»
\v 20 «ﭑ مَن تٌ تَامِ فُندِ سٌلٌقٍرٍ عِتَشُن شّمّ وُلُ نَانِ مَ، وٌ دٍبٍ يٍرِ رَقٍ تَامِ دْنشْي رَ؟» عٍ نَشَ عَ يَابِ، «سٌلٌقٍرٍ.»
\v 21 عَ قَ عٍ مَشْرِن، «هَن يَ وٌ مُ قَهَامُي سْتْ؟»
\s1 دْنشُي رَيَلَنقٍ
\p 
\v 22 عٍ تٌ سٌ بٍتٍسَيِدَ، مِشِيٍ نَشَ قَ دْنشُي ندٍ رَ عِسَ شْن، عٍ عَ مَيَندِ عَ شَ عَ بّلّشّ سَ عَ مَ.
\v 23 عِسَ نَشَ دْنشُي بّلّشّ سُشُ، عَ مِنِ عَ رَ تَا قَرِ مَ. عَ نَشَ عَ دّيٍ سَ عَ يَ مَ، عَ عَ بّلّشّ سَ عَ مَ، عَ قَ عَ مَشْرِن، «عِ سٍ ندٍ تٌمَ؟»
\v 24 دْنشُي نَشَ عَ يَ رَبِ، عَ قَ عَ قَلَ، «ﭑ بَرَ مِشِيٍ تٌ حّرّ رَ، كْنْ عٍ لُشِ عَلْ وُرِ بِلِيٍ.»
\v 25 عِسَ مَن نَشَ عَ بّلّشّ سَ عَ يَ مَ. دْنشُي تٌ عَ يَ رَبِ سْنْن، عَ نُ بَرَ يَلَن، عَ سٍ بِرِن عِفبّمَ عَ قَنيِ رَ.
\v 26 نَ تّمُي، عِسَ نَشَ عَ قَلَ عَ بّ، «فبِلٍن عِ شْنيِ كٍرٍن نَ، هَلِ عِ مُ سٌ تَا كُي.»
\s1 ثِيّرِ عِسَ كٌلٌنقٍ عَلَ شَ مِشِ سُفَندِشِ رَ
\r مَتِيُ ١٦‏؛١٣ ٬ ٢٠، لُكِ ٩‏؛١٨ ٬ ٢١
\p 
\v 27 عِسَ نُن عَ قْشِرَبِرّيٍ مَن نَشَ مِنِ سِفَقٍ رَ تَا نَشٍيٍ نَ سٍسَرٍيَ قِلِثِ رَبِلِنيِ. كِرَ شْن، عِسَ نَشَ عَ قْشِرَبِرّيٍ مَشْرِن، «مِشِيٍ مُنسٍ قَلَمَ ﭑ مَ قٍ رَ؟ ندٍ لَنشِ ﭑ مَ؟»
\v 28 عٍ نَشَ عَ يَابِ، «ندٍيٍ عَ قَلَمَ، عَننَبِ يَيَ شُنشَ. ندٍيٍ عَ قَلَمَ، عَننَبِ عٍلِيَ، شَ نَ مُ عَ رَ نَمِحْنمّ فبّتّ.»
\v 29 عِسَ مَن نَشَ عٍ مَشْرِن، «كْنْ وٌ تَن نَشّ دِ؟ ندٍ ﭑ نَ؟» ثِيّرِ نَشَ عَ يَابِ، «عَلَ شَ مِشِ سُفَندِشِ نَن نَ عِ رَ.»
\v 30 عِسَ نَشَ عَ مَتِنتِن عٍ رَ، عَ عٍ نَشَ عَ شَ قٍ قَلَ مِشِ يٌ بّ.
\s1 عِسَ عَ شَ قَشّ نُن مَرَكٍلِ شَ قٍ مَسٍنقٍ
\r مَتِيُ ١٦‏؛٢١ ٬ ٢٨، لُكِ ٩‏؛٢٢
\p 
\v 31 عِسَ نَشَ عَ مَسٍن قْلْ عٍ بّ، عَ قٌ عَدَ مَ شَ دِ شَ تْورّ فبٍفبٍ سْتْ. يُوِقِيٍ شَ قٌرِيٍ، سّرّشّدُبّ كُنتِفِيٍ، نُن سّرِيّ كَرَ مْشْيٍ مُ لَمَ عَ رَ، عٍ عَ قَشَ، كْنْ شِ سَشَن دَنفِ شَنبِ، عَ مَن كٍلِمَ نّ قَشّ مَ.
\v 32 عَ نَشَ يِ وْيّنيِ بِرِن مَسٍن عٍ بّ عَ قِيشّ رَ. ثِيّرِ تٌ عَ بّندُن، عٍ سَ تِ عٍ شَتِ مَ، عَ نَشَ سٌ وْيّنقٍ عِسَ مَ، عَ شَ بَ نَ مْولِ قَلَقٍ.
\v 33 كْنْ عِسَ نَشَ عَ يَ رَقِندِ عَ قْشِرَبِرّيٍ مَ، عَ قَ عَ قَلَ ثِيّرِ بّ، «كٍلِ ﭑ يَ عِ، عِ تَن سٍنتَنّ! عِ شَشِلِ مُ تِشِ عَلَ قٍيٍ شَ رَ، عَ تِشِ عَدَ مَ قٍيٍ نَن نَ.»
\p 
\v 34 نَ شَنبِ، عِسَ نَشَ حَمَ شِلِ عَ نُن عَ قْشِرَبِرّيٍ، عَ عَ مَسٍن عٍ بّ، «شَ مِشِ وَ بِرَقٍ ﭑ قْشْ رَ، عَ شَ تٌندِ عَ يّتّ مَ، عَ تِن تْورّ نُن قَشّ رَ، عَ بِرَ ﭑ قْشْ رَ.
\v 35 مِشِ نَشَن وَ مَ عَ يّتّ رَكِسِقٍ، نَ كَنيِ لْيمَ نّ. نَشَن عَ يّتّ رَلْيمَ ﭑ تَن مَ قٍ رَ عَ نُن ﭑ مَ شِبَارُ قَنيِ شَ قٍ رَ، نَ كَنيِ كِسِمَ نّ.
\v 36 دُنِحَ بِرِن سْتْي مُنسٍ قَنمَ مِشِ مَ، شَ عَ سِفَمَ يَهَننَمَ؟
\v 37 قٍ مُندُن نَ، مِشِ نْمَ عَ شَ عَرِيَننَ مَسَرَدٍ نَشَن نَ؟
\v 38 نَشَن يٌ يَافِمَ ﭑ تَن نُن ﭑ مَ وْيّنيِ شَ قٍ رَ يِ وَشَتِ مِشِ كٌبِيٍ نُن يُنُبِتْييٍ تَفِ، ﭑ تَن عَدَ مَ شَ دِ قَمَ ﭑ بَبَ شَ نْرّ كُي تّمُي نَشّ ﭑ نُن مَلٍكّ سّنِيّنشِيٍ، ﭑ قَن يَافِمَ نّ نَ كَنيِ شَ قٍ رَ.»
\c 9
\p 
\v 1 عِسَ مَن نَشَ عَ مَسٍن عٍ بّ، «ﭑ شَ نْندِ قَلَ وٌ بّ، مِشِ ندٍيٍ تِشِ وٌ يَ مَ بٍ، نَشٍيٍ مُ قَشَمَ قٌ عٍ عَلَ شَ مَنفّيَ نِينِ تٌ قَ رَ سّنبّ كُي.»
\s1 عِسَ نْرْقٍ
\r مَتِيُ ١٧‏؛١ ٬ ١٣، لُكِ ٩‏؛٢٨ ٬ ٣٦
\p 
\v 2 شِ سٍننِ دَنفِ شَنبِ، عِسَ نَشَ ثِيّرِ، يَكِ، نُن يَيَ شَنِن عٍ دٌرٌ مَ فٍيَ عِتٍشِ ندٍ قَرِ. مّننِ عِسَ نَشَ مَسَرَ، عَ نْرْ عٍ يَ شْرِ.
\v 3 عَ شَ سٌسٍيٍ نَشَ قِيشّ عَ مْولِ ندٍ رَ نَشَن مُ تٌمَ دُنِحَ مَ.
\v 4 عَننَبِ عٍلِيَ نُن عَننَبِ مُنسَ نَشَ مِنِ قْشِرَبِرّيٍ يَ شْرِ، عٍ نَشَ عٍ تٌ نَا عٍ نُن عِسَ وْيّنقٍ.
\p 
\v 5 ثِيّرِ نَشَ عَ قَلَ عِسَ بّ، «كَرَ مْشْ، قٍ قَنيِ نَ عَ رَ مُشُ تٌ نَ بٍ يِ كِ. مُشُ شَ لِنفِرَ سَشَن يَءِلَن، كٍرٍن عِ فبٍ، كٍرٍن عَننَبِ مُنسَ فبٍ، كٍرٍن عَننَبِ عٍلِيَ فبٍ.»
\v 6 ثِيّرِ نَ قَلَ نّ عَ تٌ مُ نُ سٍسٍ كٌلٌن عَ نَشَن قَلَمَ، بَرِ مَ عَ تَن نُن عَ بٌورٍيٍ نُ بَرَ فَاشُ كِ قَنيِ رَ.
\v 7 نَ شَنبِ، نُشُي نَشَ فٌرٌ عٍ شُن مَ، شُي ندٍ نَشَ مِنِ نُشُي كُي، عَ عَ مَسٍن، «ﭑ مَ دِ مَشَنُشِ نَن يِ كِ. وٌ وٌ تُلِ مَتِ عَ رَ.»
\v 8 نَ عِكْرْشِ رَ، عِسَ قْشِرَبِرّيٍ تٌ عٍ يَ رَفٍ، عٍ مُ مِشِ يٌ تٌ عٍ يِرٍ قٌ عِسَ.
\p 
\v 9 عٍ تٌ نُ نَ فٌرٌقٍ فٍيَ قَرِ، عِسَ نَشَ عَ مَتِنتِن عٍ رَ، عٍ قٍ نَشَن تٌشِ عٍ يَ رَ، عٍ نَشَ عَ قَلَ مِشِ يٌ بّ، هَن بٍيمَنُن عَدَ مَ شَ دِ شَ كٍلِ قَشّ مَ.
\v 10 عٍ نَشَ نَ رَفَتَ عٍ شَشِلِ مَ، عٍ نُ عٍ بٌرٍ مَشْرِن، «عَ تٌ عَ قَلَ عَ عَ كٍلِمَ قَشّ مَ، نَ مُنسٍ مَسٍنشِ؟»
\p 
\v 11 عٍ نَشَ عِسَ مَشْرِن، «مُنقٍ رَ سّرِيّ كَرَ مْشْيٍ عَ قَلَمَ عَ قٌ عَننَبِ عٍلِيَ نَن سِنفٍ شَ قَ؟»
\v 12 عَ نَشَ عَ مَسٍن عٍ بّ، «نْندِ نَ عَ رَ. عَننَبِ عٍلِيَ نَن سِنفٍ قَمَ يَتِ، عَ قٍ بِرِن يَءِلَن. عَ مَن سّبّشِ مُنقٍ رَ، عَ قٌ عَدَ مَ شَ دِ شَ تْورّ فبٍفبٍ سْتْ، مِشِيٍ عَ مَبٍرٍ؟
\v 13 كْنْ ﭑ شَ عَ قَلَ وٌ بّ، عَننَبِ عٍلِيَ حَن بَرَ قَ، كْنْ عٍ بَرَ عٍ وَشْنقٍ بِرِن نِيَ عَ رَ، عَلْ عَ شَ قٍ سّبّشِ كِ نَشّ.»
\s1 عِسَ حِننّ كٍرِقٍ دِ مّدِ قْشْ رَ
\r مَتِيُ ١٧‏؛١٤ ٬ ٢٣، لُكِ ٩‏؛٣٧ ٬ ٤٥
\p 
\v 14 نَ شَنبِ، عٍ نَشَ سَ قْشِرَبِرّ بٌورٍيٍ لِ، عٍ نُن سّرِيّ كَرَ مْشْيٍ نُ نَ شْرْشْقٍ عٍ شَ وْيّنيِيٍ كُي، حَمَ فبٍفبٍ قَن نُ نَ عٍ رَبِلِنيِ.
\v 15 حَمَ قّقّ عِسَ تٌ، عٍ نَشَ كَابَ، عٍ عٍ فِ، عٍ شَ سَ عَ شّيبُ.
\v 16 عِسَ نَشَ عٍ مَشْرِن، «وٌ نُن يٍيٍ نَ وْيّنقٍ يِ مْولِ رَ مُنقٍ مَ؟»
\v 17 شّمّ ندٍ نَشَ عَ يَابِ حَمَ تَفِ، «كَرَ مْشْ، ﭑ قَشِ ﭑ مَ دِ شّمّ نَن نَ عِ شْن، بَرِ مَ حِننّ نَ عَ قْشْ رَ نَشَن بَرَ عَ دّ بٌبٌ.
\v 18 عَ نَ كٍلِ عَ رَ دّدّ، عَ عَ رَبِرَ مَ نّ بْشِ، عَ دّ شُنقّ نُ قَ مِنِ، عَ نُ عَ حِنيِ رَشِن، عَ قَتٍ بِرِن شْرْشْ عَ رَ. ﭑ بَرَ عِ قْشِرَبِرّيٍ مَيَندِ عٍ شَ يِ حِننّ كٍرِ عَ قْشْ رَ، كْنْ عٍ مُ نْ.»
\p 
\v 19 عِسَ نَشَ عٍ يَابِ، «وٌ تَن دَنشَنِيَتَرٍ بْنسْي، ﭑ شَ لُ وٌ سّيتِ مَ هَن مُن تّمُي؟ ﭑ شَ تِ وٌ بُن مَ هَن مُن لْشْي؟ وٌ قَ نَ دِ رَ ﭑ شْن.»
\v 20 عٍ نَشَ قَ عَ رَ عَ شْن. حِننّ تٌ عِسَ تٌ، عَ نَشَ دِ رَبِرَ كٍرٍن نَ، عَ نُ قَ عَ مَحِندِفِلِن بْشِ، عَ دّ شُنقّ نُ مِنِ.
\v 21 عِسَ نَشَ عَ بَبَ مَشْرِن، «يِ رَبَمَ عَ رَ كَبِ مُن تّمُي؟» عَ نَشَ عَ يَابِ، «كَبِ عَ دِ مّدِ تّمُي.
\v 22 سَنمَيَ وُيَشِ يِ حِننّ عَ رَبِرَ مَ تّ شْورَ، شَ نَ مُ يٍ، عَلَكٌ عَ شَ عَ قَشَ. كْنْ شَ عِ نْمَ قٍ ندٍ رَ، مُشُ مَلِ. كِنِكِنِ مُشُ مَ!»
\v 23 عِسَ نَشَ عَ مَسٍن عَ بّ، «عِ نَشّ، شَ ﭑ نْمَ. قٍقٍ مُ نَ نَشَن مُ نْمَ رَبَدٍ مِشِ بّ شَ دَنشَنِيَ نَ عَ بّ.»
\v 24 دِ بَبَ قَن نَشَ عَ شُي عِتٍ كٍرٍن نَ عِسَ مَيَندِقٍ رَ، «دَنشَنِيَ نَ ﭑ بّ، كْنْ ﭑ مَلِ ﭑ مَ دَنشَنِيَتَرٍحَ شَ قٍ رَ!»
\p 
\v 25 عِسَ تٌ حَمَ تٌ، عٍ قَقٍ عٍ فِ رَ، عَ نَشَ وْيّن حِننّ رَ، «عِ تَن حِننّ نَشَن بَرَ يِ دِ دّ بٌبٌ، عِ عَ تُلِ شْرِ، ﭑ بَرَ عِ يَامَرِ، فبِلٍن عَ قْشْ رَ، عِ مَن نَشَ عَ تْورْ سْنْن!»
\v 26 حِننّ نَشَ سْنشْ، عَ دِ رَكٍتُن عَ رَ عَ حَاشِ رَ، عَ قَ فبِلٍن عَ قْشْ رَ. دِ نَشَ لُ عَلْ عَ قَشَشِ نّ. مِشِ فبٍفبٍ نَشَ عَ قَلَ، «عَ بَرَ قَشَ.»
\v 27 كْنْ عِسَ نَشَ عَ سُشُ عَ بّلّشّ مَ، عَ عَ رَكٍلِ، دِ قَن نَشَ تِ.
\p 
\v 28 عِسَ تٌ سٌ بَنشِ، عَ قْشِرَبِرّيٍ نَشَ عَ مَشْرِن عٍ دٌرٌ مَ، «مُنقٍ رَ مُشُ تَن مُ نْ نَ حِننّ كٍرِدٍ؟»
\v 29 عِسَ نَشَ عَ مَسٍن عٍ بّ، «يِ حِننّ مْولِ تَن كٍرِ مَ مِشِ قْشْ رَ عَلَ مَشَندِ نَن تُن نَ.»
\s1 عِسَ عَ شَ قَشّ نُن مَرَكٍلِ شَ قٍ مَسٍنقٍ سَنمَيَ قِرِن ندٍ
\r مَتِيُ ١٧‏؛٢٢ ٬ ٢٣، لُكِ ٩‏؛٤٣ ٬ ٤٦
\p 
\v 30 عٍ نَشَ كٍلِ مّننِ، عٍ فَلِلٍ بْشِ عِفِرِ. عِسَ مُ نُ وَ مَ مِشِيٍ شَ عَ يِرٍ كٌلٌن،
\v 31 بَرِ مَ عَ نُ نَ عَ قْشِرَبِرّيٍ شَرَنقٍ نّ. عَ نَشَ عَ مَسٍن عٍ بّ، «عَدَ مَ شَ دِ سَمَ نّ مِشِيٍ بّلّشّ، عٍ عَ قَشَ. عَ شَ قَشّ شِ سَشَن دَنفِ شَنبِ، عَ مَن كٍلِمَ نّ قَشّ مَ.»
\v 32 كْنْ عَ قْشِرَبِرّيٍ مُ عَ شَ وْيّنيِ قَهَامُ، عٍ مَن مُ سُو سَ عَ مَشْرِندٍ.
\s1 مِشِ نَشَن تِدٍ فبٌ
\r مَتِيُ ١٨‏؛١ ٬ ٥، لُكِ ٩‏؛٤٦ ٬ ٤٨
\p 
\v 33 عٍ نَشَ سٌ كَثّرّنَمُ. عٍ مَن تٌ سٌ بَنشِ كُي، عِسَ نَشَ عٍ مَشْرِن، «وٌ نُ نَ وْيّنيِ مُندُن كِرَ شْن؟»
\v 34 كْنْ عٍ مُ سٍسٍ قَلَ، بَرِ مَ عٍ تٌ نُ وْيّنمَ عٍ بٌرٍ بّ كِرَ شْن، عٍ نُ وَ مَ عَ كٌلٌنقٍ نّ نَشَن تِدٍ فبٌ عٍ يَ مَ.
\v 35 نَ كُي، عِسَ تٌ عَ مَفٌرٌ، عَ نَشَ يِ مِشِ قُ نُن قِرِن شِلِ، عَ عَ مَسٍن عٍ بّ، «شَ مِشِ يٌ وَ قِندِقٍ يَرٍرَتِ رَ، قٌ نَ كَنيِ شَ قِندِ بِرِن شَ شَنبِرَتِ رَ، عَ قِندِ بِرِن هَيِ قَنمَ رَ.»
\p 
\v 36 عِسَ نَشَ دِ مّدِ ندٍ تٌنفٌ، عَ عَ تِ عٍ تَفِ. عَ نَشَ دِ مّدِ دْشْ عَ سَن مَ، عَ قَ عَ مَسٍن عَ قْشِرَبِرّيٍ بّ،
\v 37 «مِشِ يٌ نَشَن يِ دِ مّدِ مْولِ رَ سّنّمَ ﭑ شِلِ رَ، نَ كَنيِ بَرَ ﭑ تَن يّتّ يَتِ رَ سّنّ. مِشِ يٌ ﭑ نَسّنّ، نَ كَنيِ مُ ﭑ تَن فبَنسَن شَ رَ سّنّشِ. عَ بَرَ ﭑ شّيمَ قَن نَسّنّ.»
\s1 قِندِقٍ عِسَ قْشِرَبِرّ رَ
\r لُكِ ٩‏؛٤٩ ٬ ٥٠
\p 
\v 38 يَيَ نَشَ عَ قَلَ عَ بّ، «كَرَ مْشْ، مُشُ بَرَ شّمّ ندٍ تٌ عَ حِننّ كٍرِ مَ مِشِ قْشْ رَ عِ شِلِ سَابُي رَ. مُشُ بَرَ كَتَ عَ شَ بَ نَ مَ، بَرِ مَ عَ مُ بِرَشِ وٌن قْشْ رَ.»
\v 39 عِسَ نَشَ عَ مَسٍن، «وٌ نَشَ عَ رَتْن، بَرِ مَ مِشِ يٌ كَابَنَكٌ رَبَ ﭑ شِلِ سَابُي رَ، نَ كَنيِ مُ نْمَ قٍ حَاشِ قَلَدٍ ﭑ مَ قٍ رَ مَقُرٍن.
\v 40 نَ كُي، مِشِ نَشَن مُ عَ عِكٍلِشِ وٌن شِلِ مَ، عَ كَنيِ نَ وٌن بّ نّ.
\v 41 مِشِ يٌ وٌ كِ يٍ ﭑ شِلِ رَ وٌ تٌ بِرَشِ عَلَ شَ مِشِ سُفَندِشِ قْشْ رَ، ﭑ شَ نْندِ قَلَ وٌ بّ، نَ كَنيِ مُ فَنمَ عَ بَرَايِ رَ مُكُ.»
\s1 مَرَتَنتَنيِ سَابُي
\r مَتِيُ ١٨‏؛٦ ٬ ٩، لُكِ ١٧‏؛١ ٬ ٢
\p 
\v 42 «مِشِ يٌ يِ مِشِ شُرِ كٍرٍن نَتَنتَن، نَشَن دَنشَنِيَشِ ﭑ مَ، عَ قِسَ نَ كَنيِ بّ فّمّ بِنيٍ شَ شِرِ عَ كْنيِ رَ، عَ رَ سِن بَا مَ.
\v 43‏-44 شَ عِ بّلّشّ قِندِ عِ رَتَنتَنسٍ رَ، عَ بٌلٌن. عِ سٌقٍ عَرِيَننَ عِ بّلّشّ كٍرٍن بٌلٌنشِ، نَ قِسَ عِ بّ دِنّ عِ بّلّشّ قِرِن لُشِ نَ، عِ قَ سِفَ يَهَننَمَ، تّ مُ شُبٍنمَ دّننَشّ.
\v 45‏-46 شَ عِ سَنيِ قِندِ عِ رَتَنتَنسٍ رَ، عَ بٌلٌن. عِ سٌقٍ عَرِيَننَ عِ سَنيِ كٍرٍن بٌلٌنشِ، نَ قِسَ عِ بّ دِنّ عِ سَنيِ قِرِن لُشِ نَ، عِ قَ وٌلِ يَهَننَمَ.
\v 47 شَ عِ يَ قِندِ عِ رَتَنتَنسٍ رَ، عَ بَ نَ. عِ سٌقٍ عَرِيَننَ عِ يَ كٍرٍن كَنَشِ، نَ قِسَ عِ بّ دِنّ عِ يَ قِرِن لُشِ نَ، عِ قَ وٌلِ يَهَننَمَ،
\v 48 كُلِ مُ قَشَمَ دّننَشّ، تّ قَن مُ شُبٍنمَ.»
\r مَتِيُ ٥‏؛١٣، لُكِ ١٤‏؛٣٤ ٬ ٣٥
\p 
\v 49 «تّ سَمَ نّ مِشِ بِرِن مَ، عَلْ قْشّ سَمَ دٌنسٍ مَ كِ نَشّ.
\v 50 قْشّ قِندِشِ قٍ قَنيِ نَن نَ، كْنْ شَ قْشّ مّشّمّشّنيِ بَرَ بَ، عَ قَ مّشّمّشّنمَ دِ؟ قْشّ شَ لُ وٌ عِ، وٌ شَ لُ بْحّسَ كُي وٌ بٌرٍ تَفِ.»
\c 10
\s1 قُتِ نُن قَتَنيِ
\r مَتِيُ ١٩‏؛١ ٬ ٩، لُكِ ١٦‏؛١٨
\p 
\v 1 عِسَ نَشَ كٍلِ مّننِ، عَ سِفَ يُدَيَ بْشِ عَ نُن يُرُدّن نَاكِرِ مَ. حَمَ فبٍفبٍ مَن نَشَ عٍ مَلَن عَ يِرٍ، عَ قَن نَشَ عٍ كَوَندِ قْلْ، عَلْ عَ نُ دَرِشِ عَ رَ كِ نَشّ.
\p 
\v 2 قَرِ سّنِيٍ نَشَ قَ عِسَ يِرٍ عَلَكٌ عٍ شَ فَنتَنيِ تٍ عَ بّ. عٍ نَشَ عَ مَشْرِن، «عَ دَشَ شّمّ شَ مّي عَ شَ فِنّ رَ؟»
\v 3 عِسَ نَشَ عٍ يَابِ، «عَننَبِ مُنسَ وٌ يَمَرِ مُنسٍ رَ؟»
\v 4 عٍ قَن نَشَ عَ يَابِ، «عَننَبِ مُنسَ عَ قَلَ نّ، عَ شَ شّمّ وَ مّيقٍ عَ شَ فِنّ رَ، عَ شَ قَتَن كّيدِ نَن نَقَلَ، عَ قَ مّي فِنّ رَ.»
\p 
\v 5 عِسَ نَشَ عَ مَسٍن عٍ بّ، «عَننَبِ مُنسَ يِ يَامَرِ سّبّشِ نّ وٌ بّ وٌ شَشِلِ تٌ شْرْشْ.
\v 6 كْنْ دُنِحَ قْلْ قْلّ رَ، عَلَ نَشَ شّمّ نُن فِنّ دَا.
\v 7 ‹نَ كُي، شّمّ كٍلِمَ عَ بَبَ نُن عَ نفَ شُن مَ، عَ عَ شَ فِنّ شَ قُتِ شِرِ،
\v 8 عٍ قِرِن قِندِ كٍرٍن نَ.› نَ نَن عَ تٌشِ، مِشِ قِرِن شَ مُ عٍ رَ سْنْن، عٍ قِرِن بَرَ قِندِ كٍرٍن نَ.
\v 9 عَلَ بَرَ نَشٍيٍ شِرِ عٍ بٌورٍ رَ، عَدَ مَ نَشَ عٍ رَقَتَن.»
\p 
\v 10 عٍ تٌ سٌ بَنشِ، عِسَ قْشِرَبِرّيٍ مَن نَشَ عَ مَشْرِن نَ مَسٍنيِ مَ.
\v 11 عِسَ نَشَ عَ مَسٍن عٍ بّ، «مِشِ يٌ مّي عَ شَ فِنّ رَ، عَ سَ فبّتّ دْشْ، عَ كَنيِ بَرَ يّنّ رَبَ.
\v 12 شَ فِنّ قَن مّي عَ شَ شّمّ رَ، عَ سَ دْشْ شّمّ فبّتّ شْن، عَ قَن بَرَ يّنّ رَبَ.»
\s1 عِسَ نُن دِ مّدِيٍ
\r مَتِيُ ١٩‏؛١٣ ٬ ١٥، لُكِ ١٨‏؛١٥ ٬ ١٧
\p 
\v 13 مِشِيٍ نُ قَقٍ دِ مّدِيٍ رَ عِسَ شْن، عَلَكٌ عَ شَ عَ بّلّشّ سَ عٍ مَ، كْنْ عَ قْشِرَبِرّيٍ نَشَ وْيّن نَ مِشِيٍ مَ.
\v 14 عِسَ تٌ نَ قٍ تٌ، عَ نَشَ شْنْ، عَ قَ عَ مَسٍن عَ قْشِرَبِرّيٍ بّ، «وٌ عَ لُ دِ مّدِيٍ شَ قَ ﭑ يِرٍ. وٌ نَشَ تْنيِ دْشْ عٍ مَ، بَرِ مَ نَشٍيٍ مَنِيَشِ عٍ رَ، نٍيٍ نَن سٌمَ عَلَ شَ مَنفّيَ نِينِ بُن مَ.
\v 15 ﭑ شَ نْندِ قَلَ وٌ بّ، مِشِ نَشَن مُ تِنمَ عَلَ شَ مَنفّيَ نِينِ رَ عَلْ دِ مّدِ، نَ كَنيِ مُ سٌمَ عَلَ شَ مَنفّيَ نِينِ بُن مَ قٍوٌ!»
\v 16 عَ نَشَ دِ مّدِيٍ دْشْ عَ سَن مَ، عَ عَ بّلّشّ سَ عٍ مَ، عَ دُبَ عٍ بّ.
\s1 سّفّتَلَ بَننَشِ
\r مَتِيُ ١٩‏؛١٦ ٬ ٣٠، لُكِ ١٨‏؛١٨ ٬ ٣٠
\p 
\v 17 عِسَ تٌ نُ بَرَ كِرَ سُشُ، شّمّ ندٍ نَشَ قَ عَ فِ رَ عَ قْشْ رَ، عَ عَ شِنبِ سِن عَ بُن مَ. عَ نَشَ عِسَ مَشْرِن، «كَرَ مْشْ قَنيِ، عَ لَن ﭑ شَ مُنسٍ رَبَ عَلَكٌ ﭑ شَ عَبَدَن كِسِ سْتْ كّ رَ؟»
\v 18 عِسَ نَشَ عَ مَسٍن عَ بّ، «مُنقٍ رَ عِ ﭑ شِلِمَ كَرَ مْشْ قَنيِ؟ مِشِ يٌ مُ قَن. عَلَ كٍرٍن ثٍتِ نَن قَن.
\v 19 عِ سّرِيّ كٌلٌن؛ ‹عِ نَشَ قَشّ تِ. عِ نَشَ يّنّ رَبَ. عِ نَشَ مُحّ تِ. عِ نَشَ مِشِ تْوحّفّ. عِ نَشَ قُ مِشِ مَ. عِ بَبَ نُن عِ نفَ بِنيَ.›»
\p 
\v 20 شّمّ نَشَ عِسَ يَابِ، «كَرَ مْشْ، ﭑ بَرَ نَ بِرِن نَبَتُ كَقِ ﭑ دِ مّدِ تّمُي.»
\v 21 عِسَ نَشَ شّمّ مَتٌ، عَ نَشَ عَ شَنُ. عَ نَشَ عَ مَسٍن عَ بّ، «قٍ كٍرٍن نَن قَ لُشِ عِ بّ. سِفَ، سٍ نَشَن بِرِن نَ عِ يِ رَ، عِ سَ عَ مَتِ، عِ عَ كْبِرِ قِ سٍتَرٍيٍ مَ. نَ كُي، عِ قَمَ بَننَيَ سْتْدٍ عَرِيَننَ. عِ نَ نَ رَبَ، قَ، عِ بِرَ ﭑ قْشْ رَ.»
\v 22 شّمّ تٌ نَ وْيّنيِ مّ، عَ نَشَ سِفَ سُننُنيِ كُي، بَرِ مَ هَرِفٍ فبٍفبٍ نُ نَ عَ يِ رَ.
\p 
\v 23 عِسَ نَشَ عَ يَ رَفٍ عَ رَبِلِنيِ، عَ قَ عَ مَسٍن عَ قْشِرَبِرّيٍ بّ، «سٌقٍ عَلَ شَ مَنفّيَ نِينِ بُن مَ، عَ شْرْشْ نَاقُلِ كَنيِيٍ بّ كِ قَنيِ!»
\v 24 عَ قْشِرَبِرّيٍ نَشَ كَابَ عَ شَ وْيّنيِ مَ، كْنْ عِسَ مَن نَشَ عَ مَسٍن عٍ بّ، «ﭑ مَ دِيٍ، سٌقٍ عَلَ شَ مَنفّيَ نِينِ بُن مَ، عَ شْرْشْ كِ قَنيِ!
\v 25 حْشْمّ سٌ حْشُن سّنبّ يَلٍ رَ، دِنّ بَننَمِشِ سٌقٍ رَ عَلَ شَ مَنفّيَ نِينِ بُن مَ.»
\v 26 عِسَ قْشِرَبِرّيٍ دّ نَشَ عِشَرَ كِ قَنيِ رَ، عٍ نُ عٍ بٌرٍ مَشْرِن، «ندٍ قَ نْمَ كِسِدٍ قَ؟»
\v 27 عِسَ نَشَ عٍ مَتٌ، عَ قَ عَ مَسٍن عٍ بّ، «عَدَ مَ مُ نْمَ عَ يّتّ رَكِسِدٍ، كْنْ عَلَ تَن نْمَ قٍ بِرِن نَ.»
\p 
\v 28 ثِيّرِ نَشَ وْيّن قْلْ عِسَ بّ، «عَ مَتٌ، مُشُ بَرَ كٍلِ سٍ بِرِن شُن مَ، مُشُ بِرَ عِ قْشْ رَ.»
\v 29 عِسَ نَشَ عَ مَسٍن، «ﭑ شَ نْندِ قَلَ وٌ بّ، مِشِ يٌ نَشَن نَ كٍلِ عَ شَ سٍ ندٍ شُن مَ ﭑ تَن نُن ﭑ مَ شِبَارُ قَنيِ شَ قٍ رَ، عَ قِندِ بَنشِ رَ بَ، شُنيَيٍ بَ، تَارَيٍ بَ، بَبَ بَ، نفَ بَ، دِيٍ بَ، بْشِيٍ بَ،
\v 30 نَ كَنيِ قَمَ نَ بِرِن حْشْي كّمّ كّمّ نَن سْتْدٍ. قْشْييٍ يٌ، شُنيَيٍ يٌ، تَارَيٍ يٌ، بَبَيٍ يٌ، نفَيٍ يٌ، بْشِيٍ يٌ، عَ عٍ سْتْمَ يِ دُنِحَ مَ عَ نُن حَشَنكَتّ رَ، عَ مَن قَ عَبَدَن كِسِ سْتْ عَلِفِيَمَ.
\v 31 يَرٍرَتِ وُيَشِ قَمَ قِندِدٍ شَنبِرَتِيٍ رَ، شَنبِرَتِيٍ قَن قِندِ يَرٍرَتِيٍ رَ.»
\s1 عِسَ عَ شَ قَشّ نُن مَرَكٍلِ شَ قٍ مَسٍنقٍ سَنمَيَ سَشَن ندٍ
\r مَتِيُ ٢٠‏؛١٧ ٬ ١٩، لُكِ ١٨‏؛٣١ ٬ ٣٤
\p 
\v 32 عِسَ نُن عَ قْشِرَبِرّيٍ نَشَ كِرَ سُشُ تٍقٍ دَرِ سَلَمُ، عِسَ تِشِ عٍ يَ رَ. عَ قْشِرَبِرّيٍ نُ كْنتْقِلِشِ، نَشٍيٍ قَن نُ بِرَشِ عٍ قْشْ رَ، نٍيٍ قَن نُ فَاشُشِ. عِسَ مَن نَشَ عَ قْشِرَبِرّ قُ نُن قِرِن شُن لَن، عَ سٌ قٍ تَفِ رَبَقٍ عٍ بّ نَشَن قَمَ عَ تَن لِدٍ.
\v 33 عَ نَشَ عَ مَسٍن، «وٌ عَ مَتٌ، وٌن نَ تٍقٍ دَرِ سَلَمُ نّ يِ كِ. عَدَ مَ شَ دِ سَمَ نّ سّرّشّدُبّ كُنتِفِيٍ، نُن سّرِيّ كَرَ مْشْيٍ بّلّشّ، عٍ عَ مَكِيتِ قَشّ كِيتِ رَ، عٍ عَ سٌ كَاقِرِيٍ يِ رَ.
\v 34 عٍ عَ مَيٍلٍمَ نّ، عٍ دّيٍ بْشُن عَ مَ، عٍ عَ بْنبْ سّبّرّ رَ، عٍ مَن قَ عَ قَشَ. كْنْ عَ شَ قَشّ شِ سَشَن دَنفِ شَنبِ، عَ مَن كٍلِمَ نّ قَشّ مَ.»
\s1 سٍبٍدٍ شَ دِيٍ شَ مَشْرِنيِ
\r مَتِيُ ٢٠‏؛٢٠ ٬ ٢٨، لُكِ ٢٢‏؛٢٤ ٬ ٤٧
\p 
\v 35 نَ شَنبِ، سٍبٍدٍ شَ دِيٍ، يَكِ نُن يَيَ، عٍ نَشَ عٍ مَسٌ عِسَ رَ، عٍ عَ قَلَ عَ بّ، «كَرَ مْشْ، مُشُ وَ مَ عَ شْن مَ نّ، مُشُ نَ قٍ نَشَن يٌ مَشْرِن عِ مَ، عِ شَ نَ رَبَ مُشُ بّ.»
\v 36 عِسَ نَشَ عٍ مَشْرِن، «وٌ وَ مَ ﭑ شَ مُنسٍ رَبَ وٌ بّ؟»
\v 37 عٍ نَشَ عَ يَابِ، «تِن مُشُ بّ، كٍرٍن شَ دْشْ عِ يِرٍقَنيِ مَ، بٌورٍ قَن شَ دْشْ عِ كْولَ مَ عِ شَ نْرّ كُي.»
\v 38 عِسَ نَشَ عَ مَسٍن عٍ بّ، «وٌ مُ عَ كٌلٌن وٌ قٍ نَشَن مَشْرِنقٍ. وٌ نْمَ تِندٍ تْورّ رَ، عَلْ ﭑ تَن تِنمَ عَ رَ كِ نَشّ؟ وٌ نْمَ تِدٍ تْورّ يَ عِ نَشَن قَقٍ ﭑ لِدٍ؟»
\v 39 عٍ نَشَ عَ يَابِ، «مُشُ نْمَ.» عِسَ قَن نَشَ عَ قَلَ عٍ بّ، «وٌ قَن يَتِ قَمَ حَشَنكَتّ سْتْدٍ عَلْ ﭑ تَن. وٌ قَن قَمَ تِدٍ ﭑ مَ تْورّ بُن مَ نَشَن قَقٍ ﭑ لِدٍ.
\v 40 كْنْ دْشْقٍ ﭑ يِرٍقَنيِ نُن ﭑ كْولَ مَ، نَ مُ قَتَنمَ ﭑ تَن شَ رَ. نَ نَ مِشِيٍ نَن بّ، عَ رَفَتَشِ نَشٍيٍ بّ.»
\p 
\v 41 قْشِرَبِرّ قُ دْنشْي تٌ نَ قٍ مّ، عٍ بْحّ نَشَ تٍ قْلْ يَكِ نُن يَيَ مَ.
\v 42 عِسَ نَشَ عٍ شِلِ عَ يِرٍ، عَ عَ مَسٍن عٍ بّ، «وٌ عَ كٌلٌن، نَشٍيٍ كٌلٌنشِ حَمَنّ مَنفّيٍ رَ، عٍ مِشِيٍ يَمَرِ مَ عَ شْرْشْي رَ، عٍ عٍ سّنبّ رَ مِنِمَ عٍ مَ عَلَكٌ عٍ شَ مَنفّيَ شَ كٌلٌن.
\v 43 كْنْ عَ نَشَ لُ نَ كِ وٌ تَن تَفِ. مِشِ نَشَن وَ مَ عَ تِدٍ شَ فبٌ وٌ يَ مَ، عَ شَ قِندِ وٌ مَلِمَ نَن نَ.
\v 44 مِشِ نَشَن وَ مَ قِندِقٍ وٌ شَ يَرٍرَتِ رَ، عَ كَنيِ شَ قِندِ بِرِن شَ كٌنيِ نَن نَ.
\v 45 هَلِ عَدَ مَ شَ دِ عَ قَشِ نَ نَن مَ. عَ مُ قَشِ شّ مِشِيٍ شَ وَلِ عَ تَن بّ. عَ قَشِ نّ عَلَكٌ عَ تَن نَن شَ وَلِ مِشِيٍ بّ، عَ شَ مِشِ فبٍفبٍ شُنسَرَ عَ شَ قَشّ سَابُي رَ.»
\s1 عِسَ يٍرِكٌ دْنشُي رَيَلَنقٍ
\r مَتِيُ ٢٠‏؛٢٩ ٬ ٣٤، لُكِ ١٨‏؛٣٥ ٬ ٤٣
\p 
\v 46 عٍ نَشَ سٌ يٍرِكٌ. عِسَ نُن عَ قْشِرَبِرّيٍ مَن تٌ نُ كٍلِقٍ نَا، عٍ نُن حَمَ فبٍفبٍ، تِمٍيٌ شَ دِ شّمّ بَرِتِمٍيٌ نُ دْشْشِ كِرَ دّ رَ كُلّ مَتِدٍ. دْنشُي نَن نُ عَ رَ.
\v 47 عَ تٌ عَ مّ عَ عِسَ نَسَرّتِكَ نَن نُ دَنفِقٍ نَا، عَ نَشَ سٌ عَ شِلِقٍ عَ شُي عِتٍشِ رَ، «عِسَ، دَوُدَ شَ دِ، كِنِكِنِ ﭑ مَ.»
\v 48 حَمَ نَشَ وْيّن دْنشُي مَ عَ عَ شَ عَ سَبَرِ، كْنْ عَ حَن نَشَ عَ شُي عِتٍ دَنفِ عَ سِنفٍ رَ، عَ نُ شِلِ تِ، «دَوُدَ شَ دِ، كِنِكِنِ ﭑ مَ.»
\v 49 عِسَ نَشَ تِ، عَ عَ قَلَ، «وٌ عَ شِلِ.» عٍ نَشَ دْنشُي شِلِ، عٍ عَ قَلَ عَ بّ، «لِمَنِيَ! كٍلِ، عِسَ نَ عِ شِلِقٍ!»
\v 50 دْنشُي نَشَ عَ شَ دٌنمَ بِنيٍ وْلّ كٍرٍن نَ، عَ كٍلِ، عَ تُفَن، عَ سِفَ عِسَ يِرٍ.
\v 51 عِسَ نَشَ عَ مَشْرِن، «عِ وَ مَ ﭑ شَ مُنسٍ رَبَ عِ بّ؟» دْنشُي نَشَ عَ يَابِ، «كَرَ مْشْ، ﭑ وَ مَ نّ ﭑ يَ شَ سٍ تٌ.»
\v 52 عِسَ نَشَ عَ مَسٍن عَ بّ، «سِفَ، عِ شَ دَنشَنِيَ بَرَ عِ رَكِسِ.» عَ يَ نَشَ سٍ تٌ كٍرٍن نَ، عَ قَ بِرَ عِسَ قْشْ رَ كِرَ شْن.
\c 11
\s1 عِسَ سٌقٍ دَرِ سَلَمُ
\r مَتِيُ ٢١‏؛١ ٬ ١١، لُكِ ١٩‏؛٢٨ ٬ ٤٤، يَيَ ١٢‏؛١٢ ٬ ١٦
\p 
\v 1 عٍ تٌ مَكْرّ دَرِ سَلَمُ رَ، عٍ نَ بٍتِقَفٍ نُن بٍتَنِ يِرٍ لِ، عٌلِوِ فٍيَ مَبِرِ، عِسَ نَشَ عَ قْشِرَبِرّ مِشِ قِرِن شّي،
\v 2 عَ عَ قَلَ عٍ بّ، «وٌ شَ سٌ تَا كُي نَشَن نَ يَرٍ. وٌ نّقّ سٌ نَا، وٌ سٌقَلٍ لَنمَ لِمَ عَ شِرِشِ نَ، مِشِ سِنفٍ مُ نُ دْشْ نَشَن قَرِ. وٌ شَ عَ قُلُن، وٌ قَ عَ رَ ﭑ شْن مَ.
\v 3 شَ مِشِ ندٍ قَ سَ وٌ مَشْرِن، ‹وٌ عَ قُلُنقٍ مُنقٍ رَ،› وٌ شَ عَ يَابِ، ‹مَرِفِ نَن هَيِ نَ عَ مَ. عَ عَ رَفبِلٍنمَ يَ.›»
\p 
\v 4 عٍ تٌ سِفَ، عٍ نَشَ عَ لِ سٌقَلٍ لَنمَ شِرِشِ نَادّ ندٍ سّيتِ مَ كِرَ دّ رَ. عٍ تٌ عَ قُلُن،
\v 5 مِشِ نَشٍيٍ نُ تِشِ نَا، عٍ نَشَ عٍ مَشْرِن، «وٌ مُنسٍ رَبَقٍ، وٌ تٌ يِ سٌقَلٍ لَنمَ قُلُنشِ؟»
\v 6 عٍ نَشَ عٍ يَابِ عَلْ عِسَ عَ مَسٍن عٍ بّ كِ نَشّ. نٍيٍ قَن نَشَ عٍ لُ عٍ شَ سِفَ.
\v 7 عٍ تٌ قَ سٌقَلٍ لَنمَ رَ عِسَ شْن، عٍ نَشَ عٍ شَ دٌنمَيٍ سَ عَ قَرِ، عِسَ قَ عَ مَفٌرٌ عَ مَ.
\p 
\v 8 مِشِ فبٍفبٍ نَشَ عٍ شَ دٌنمَيٍ عِتَلَ كِرَ شْن مَ، ندٍيٍ قَن نَشَ قّنسّ سّفّ، عٍ نٍيٍ قَن سَ كِرَ شْن مَ عِسَ بِنيَقٍ رَ.
\v 9 حَمَ نَشٍيٍ نُ حّرّقٍ عِسَ يَ رَ، عَ نُن نَشٍيٍ نُ حّرّقٍ عَ شَنبِ رَ، عٍ بِرِن نُ عٍ شُي عِتٍقٍ، عٍ عَ قَلَ،
\q1 «تَنتُي نَ وٌن نَكِسِمَ بّ!
\q1 بَرَكَ نَ عَ بّ نَشَن قَقٍ مَرِفِ شِلِ رَ!
\q1 
\v 10 بَرَكَ نَ وٌن بَبَ دَوُدَ شَ مَنفّيَ بّ نَشَن نَ قَقٍ!
\q1 تَنتُي نَ وٌن نَكِسِمَ بّ نَشَن نَ كٌورٍ مَ!»
\p 
\v 11 عِسَ تٌ سٌ دَرِ سَلَمُ، عَ نَشَ سِفَ هْرْ مْبَنشِ كُي. عَ تٌ فّ نَا رَبِلِنيِ بِرِن مَتٌدٍ، عٍ نُن عَ قْشِرَبِرّ مِشِ قُ نُن قِرِنيِيٍ نَشَ سِفَ بٍتَنِ، بَرِ مَ كْي نُ بَرَ سٌ.
\s1 عِسَ شْرّ بِلِ دَنكَقٍ
\r مَتِيُ ٢١‏؛١٨ ٬ ٢٢
\p 
\v 12 نَ كُيٍ عِبَ، عٍ تٌ نُ كٍلِقٍ بٍتَنِ، كَامّ نَشَ عِسَ سُشُ.
\v 13 عَ تٌ شْرّ بِلِ ندٍ تٌ، عَ ندٍدِ مَكُيَشِ عٍ رَ، عَ بُرّشّ نَ عَ كْن نَ، عَ نَشَ سَ نَ مَتٌ، شَ عَ نْمَ عَ بٌفِ ندٍ مَسْتْدٍ. كْنْ عَ تٌ مَكْرّ شْرّ بِلِ رَ، عَ مُ سٍسٍ لِ عَ كْن نَ قٌ عَ بُرّشّ، بَرِ مَ شْرّ بٌفِ تّمُي مُ نُ عَ لِشِ.
\v 14 عِسَ نَشَ عَ قَلَ شْرّ بِلِ بّ، «مِشِ يٌ نَشَ عِ تَن بٌفِ دٌن سْنْن!» عَ قْشِرَبِرّيٍ قَن نَشَ عَ شُي مّ.
\s1 عِسَ سَرٍ مَتِيٍ كٍرِقٍ هْرْ مْبَنشِ كُي
\r مَتِيُ ٢١‏؛١٢ ٬ ١٧، لُكِ ١٩‏؛٤٥ ٬ ٤٨، يَيَ ٢‏؛١٣ ٬ ١٦
\p 
\v 15 عٍ تٌ سِفَ دَرِ سَلَمُ، عِسَ نَشَ سٌ هْرْ مْبَنشِ كُي، عَ سَرٍ مَتِيٍ نُن سَرٍ سٌي كٍرِ قْلْ، نَشٍيٍ نُ نَ نَا. عَ نَشَ كْبِرِ مَسَرّيٍ شَ تٍيبِلِيٍ نُن فَنبّ مَتِيٍ شَ دْشْسٍيٍ رَبِرَ.
\v 16 عَ مَن مُ تِن مِشِ يٌ شَ دَنفِ هْرْ مْبَنشِ سَنسَنيِ كُي، عٍ نَ قِندِ عٍ شَ كٌتٍ مَشَنِن كِرَ رَ.
\v 17 عَ نَشَ عٍ كَوَندِ، عَ عَ مَسٍن، «عَ مُ سّبّشِ شّ، ‹ﭑ مَ بَنشِ شِلِ قَلَمَ نّ، سِ بِرِن مَ سَلِدٍ بَنشِ›؟ كْنْ وٌ تَن بَرَ عَ قِندِ مُحّتِيٍ دْشْدٍ رَ.»
\v 18 سّرّشّدُبّ كُنتِفِيٍ نُن سّرِيّ كَرَ مْشْيٍ تٌ يِ قٍ مّ، عٍ نَشَ قّيرّ قٍن قْلْ عٍ نْمَ عِسَ قَشَدٍ كِ نَشّ. عٍ نُ فَاشُشِ عَ يَ رَ، بَرِ مَ عَ نُ حَمَ بِرِن دّ عِشَرَ مَ عَ شَ كَوَندِ رَ.
\v 19 نُنمَرٍ تٌ سٌ، عِسَ نُن عَ قْشِرَبِرّيٍ مَن نَشَ كٍلِ تَا كُي.
\s1 شْرّ بِلِ شَرٍ نُن عَلَ مَشَندِقٍ
\r مَتِيُ ٢١‏؛٢٠ ٬ ٢٢
\p 
\v 20 نَ كُيٍ عِبَ، عٍ تٌ نُ دَنفِقٍ، عَ قْشِرَبِرّيٍ نَشَ شْرّ بِلِ تٌ عَ بَرَ شَرَ هَن عَ سَنكٍ.
\v 21 ثِيّرِ تٌ رَتُ، عَ نَشَ عَ قَلَ عِسَ بّ، «كَرَ مْشْ، عَ مَتٌ، عِ شْرّ بِلِ نَشَن دَنكَ، عَ بَرَ شَرَ فبٍن.»
\p 
\v 22 عِسَ نَشَ عَ مَسٍن عٍ بّ، «وٌ شَ دَنشَنِيَ عَلَ مَ.
\v 23 ﭑ شَ نْندِ قَلَ وٌ بّ، شَ وٌ عَ قَلَ يِ فٍيَ بّ، ‹كٍلِ بٍ، عِ سَ سِن بَا مَ،› شَ نَ كَنيِ مُ سِيكّ عَ بْحّ مَ، عَ لَ عَ رَ، عَ نَشَن قَلَشِ عَ رَبَمَ نّ، نَ قٍ رَبَمَ نّ نَ كَنيِ بّ.
\v 24 نَ نَن عَ رَ، ﭑ شَ عَ قَلَ وٌ بّ، وٌ نَ عَلَ مَشَندِ قٍقٍ رَ، شَ وٌ لَ عَ رَ عَ وٌ بَرَ عَ سْتْ، وٌ عَ سْتْمَ نّ.
\v 25‏-26 وٌ نَ تِ عَلَ مَشَندِدٍ تّمُي نَشّ، شَ قٍ ندٍ نَ وٌ نُن مِشِ ندٍ تَفِ، وٌ شَ دِحّ عَ مَ، عَلَكٌ وٌ بَبَ نَشَن نَ عَرِيَننَ، عَ قَن شَ دِحّ وٌ شَ يُنُبِيٍ مَ.»
\s1 عِسَ وَلِمَ ندٍ شَ يَامَرِ مَ؟
\r مَتِيُ ٢١‏؛٢٣ ٬ ٢٧، لُكِ ٢٠‏؛١ ٬ ٨
\p 
\v 27 عٍ مَن نَشَ سٌ دَرِ سَلَمُ. عِسَ تٌ نُ عَ حّرّقٍ هْرْ مْبَنشِ كُي، سّرّشّدُبّ كُنتِفِيٍ، سّرِيّ كَرَ مْشْيٍ، نُن يُوِقِيٍ شَ قٌرِيٍ نَشَ قَ عَ يِرٍ،
\v 28 عٍ عَ مَشْرِن، «عِ يِ قٍيٍ رَبَمَ ندٍ شَ يَامَرِ مَ؟ ندٍ يِ سّنبّ قِشِ عِ مَ، عِ شَ يِ قٍيٍ رَبَ؟»
\v 29 عِسَ نَشَ عٍ يَابِ، «ﭑ قَن شَ وٌ مَشْرِن قٍ كٍرٍن مَ. شَ وٌ ﭑ يَابِ، ﭑ عَ قَلَمَ نّ وٌ بّ ﭑ يِ قٍيٍ رَبَمَ نَشَن مَ يَامَرِ مَ.
\v 30 يَيَ تٌ نُ مِشِيٍ شُنشَمَ يٍ شْورَ، عَلَ نَن عَ شّيشِ بَ، كَ عَدَ مَ؟ وٌ ﭑ يَابِ.»
\p 
\v 31 نَ كُي عٍ نَشَ سٌ وْيّنقٍ عٍ بٌرٍ تَفِ، «شَ وٌن نَ عَ يَابِ، وٌن نَشّ، ‹عَلَ،› عَ عَ قَلَمَ نّ وٌن بّ، ‹مُنقٍ رَ وٌ مُ قَ لَ عَ رَ؟›
\v 32 كْنْ وٌن نَ عَ يَابِ، ‹عَدَ مَ،› نَ قَن قِندِ مَ قٍ نَن نَ وٌن بّ.» عٍ نُ فَاشُشِ حَمَ نَن يَ رَ، بَرِ مَ بِرِن يَيَ مَحْشُنشِ نَمِحْنمّ يَتِ نَن نَ.
\v 33 نَ كُي، عٍ نَشَ عِسَ يَابِ، «مُشُ مُ عَ كٌلٌن.» عِسَ قَن نَشَ عَ مَسٍن عٍ بّ، «ﭑ قَن مُ عَ قَلَمَ وٌ بّ ﭑ يِ قٍيٍ رَبَمَ نَشَن مَ يَامَرِ مَ.»
\c 12
\s1 بْشِ رَوَلِ حَاشِيٍ شَ تَالِ
\r مَتِيُ ٢١‏؛٣٣ ٬ ٤٦، لُكِ ٢٠‏؛٩ ٬ ١٩
\p 
\v 1 عِسَ مَن نَشَ سٌ تَالِ وْيّنيِيٍ قَلَقٍ عٍ بّ، عَ عَ مَسٍن، «شّمّ ندٍ نَشَ وّنِ بِلِيٍ سِ. عَ نَشَ تّتّ رَبِلِن بْشِ رَ، عَ بَيٍ تِ، عَ يِلِ فٍ وّنِ بٌفِ بُندُ مَ دّننَشّ. نَ شَنبِ، عَ نَشَ نَ هّرِ بْشِ رَوَلِيٍ مَ، عَ قَ بِيَاسِ.»
\p 
\v 2 «وّنِ بٌفِ بَ تّمُي تٌ عَ لِ، بْشِ كَنيِ نَشَ كٌنيِ ندٍ شّي بْشِ رَوَلِيٍ شْن مَ، عٍ شَ وّنِ بٌفِ ندٍ سٌ عَ يِ رَ.
\v 3 كْنْ، بْشِ رَوَلِيٍ نَشَ نَ كٌنيِ سُشُ، عٍ عَ بْنبْ، عٍ عَ رَفبِلٍن عَ بّلّشّ عِفٍلِ رَ.»
\p 
\v 4 «بْشِ كَنيِ مَن نَشَ كٌنيِ فبّتّ شّي عٍ شْن مَ. عٍ نَشَ نَ قَن بْنبْ عَ شُنيِ مَ، عٍ عَ كٌنبِ عَ مَيَافِشِ رَ.
\v 5 بْشِ كَنيِ مَن تٌ مِشِ فبّتّ شّي، عٍ نَشَ نَ تَن قَشَ. بْشِ كَنيِ مِشِ وُيَشِ فبّتّيٍ شّي نّ عٍ شْن مَ نَ كِ. عٍ نَشَ ندٍيٍ بْنبْ، عٍ ندٍيٍ قَشَ.»
\p 
\v 6 «بْشِ كَنيِ شَ دِ شَنُشِ كٍرٍنيِ نَن نُ قَ لُشِ. عَ دْنشْي رَ، عَ نَشَ نَ شّي عٍ شْن مَ، بَرِ مَ عَ نُ بَرَ عَ قَلَ، ‹عٍ ﭑ مَ دِ تَن بِنيَمَ نّ.›
\v 7 كْنْ يِ بْشِ رَوَلِيٍ نَشَ عَ قَلَ عٍ بٌرٍ بّ، ‹يِ نَن نَ كّ تٌنفٌمَ رَ، وٌ قَ، وٌن شَ عَ قَشَ عَلَكٌ كّ شَ قِندِ وٌن فبٍ رَ.›
\v 8 عٍ نَشَ عَ سُشُ، عٍ عَ قَشَ، عٍ قَ عَ وٌلِ تّتّ شَنبِ رَ.»
\p 
\v 9 «نَ كُي، بْشِ كَنيِ مُنسٍ رَبَمَ قَ؟ عَ سِفَمَ نّ نَا، عَ بْشِ رَوَلِيٍ قَشَ، عَ عَ شَ بْشِ سٌ مِشِ فبّتّيٍ يِ.
\v 10 وٌ مُ نُ يِ مَسٍنيِ شَرَن كِتَابُي كُي؟
\q1 ‹بَنشِتِيٍ مّي فّمّ نَشَن نَ،
\q1 عَ بَرَ قِندِ تُشُي فّمّ هَفِفّ رَ.
\q1 
\v 11 مَرِفِ قْشِ نَن عَ رَ.
\q1 قٍ مَكَابَشِ نَن يَ وٌن بّ.›»
\p 
\v 12 عَ نُ وْيّنقٍ نَشٍيٍ بّ، عٍ نَشَ عَ كٌلٌن عَ عِسَ يِ تَالِ وْيّنيِ مَسٍنشِ عٍ تَن نَن بّ. عٍ نُ كَتَقٍ عٍ شَ عَ سُشُ، كْنْ عٍ نُ فَاشُشِ حَمَ نَن يَ رَ. نَ كُي، عٍ نَشَ كٍلِ عَ شُن، عٍ سِفَ.
\s1 فَنتَنيِ تٍقٍ عِسَ بّ دُوتِ شَ قٍ رَ
\r مَتِيُ ٢٢‏؛١٥ ٬ ٢٢، لُكِ ٢٠‏؛٢٠ ٬ ٢٦
\p 
\v 13 عٍ نَشَ قَرِ سّنِ نُن هٍرٌدٍ قْشِرَبِرّ ندٍيٍ شّي عِسَ شْن عَلَكٌ عٍ شَ فَنتَنيِ تٍ عَ بّ، عٍ شَ عَ مَسْتْ وْيّنيِ كُي.
\v 14 عٍ تٌ سِفَ عَ يِرٍ، عٍ نَشَ عَ قَلَ عَ بّ، «كَرَ مْشْ، مُشُ عَ كٌلٌن نْندِ قَلّ نَن عِ رَ. عِ مُ فَاشُمَ مِشِ يٌ شْن، بَرِ مَ عِ مُ مِشِ رَقِسَمَ عٍ بٌورٍيٍ بّ. عِ مِشِيٍ شَرَنمَ عَلَ شَ كِرَ نَن نَ عَ نْندِ كِ مَ. عَ لَنمَ كَ عَ مُ لَنمَ مُشُ شَ دُوتِ قِ رْ مَ مَنفّ مَ؟ مُشُ شَ عَ قِ، كَ مُشُ نَشَ عَ قِ؟»
\p 
\v 15 عِسَ تٌ عٍ شَ قِلَنكَقُيحَ كٌلٌن، عَ نَشَ عٍ يَابِ، «وٌ كَتَقٍ ﭑ مَسْتْدٍ مُنقٍ رَ؟ وٌ قَ فبٍتِ كْبِرِ كٌلٍ كٍرٍن نَ ﭑ شْن مَ، ﭑ شَ عَ مَتٌ.»
\v 16 عٍ تٌ قَ كٍرٍن نَ، عَ نَشَ عٍ مَشْرِن، «ندٍ شِلِ نُن مِسَالِ نَ يِ كْبِرِ كٌلٍ مَ يِ كِ؟» عٍ نَشَ عَ يَابِ، «رْ مَ مَنفّ فبٍ.»
\v 17 عِسَ نَشَ عَ قَلَ عٍ بّ، «وٌ مَنفّ فبٍ رَفبِلٍن مَنفّ مَ، وٌ عَلَ قَن فبٍ رَفبِلٍن عَلَ مَ.» عٍ قَن نَشَ كَابَ عِسَ شَ قٍ مَ.
\s1 سَدُ سٍنِيٍ عِسَ مَشْرِنقٍ قَشَمِشِيٍ شَ مَرَكٍلِ مَ
\r مَتِيُ ٢٢‏؛٢٣ ٬ ٣٣، لُكِ ٢٠‏؛٢٧ ٬ ٤٠
\p 
\v 18 سَدُ سٍنِيٍ، نَشٍيٍ عَ قَلَمَ عَ قَشَمِشِيٍ مُ كٍلِمَ قَشّ مَ، عٍ نَشَ قَ يِ مَشْرِنيِ رَ عِسَ شْن مَ،
\v 19 «كَرَ مْشْ، عَننَبِ مُنسَ يِ نَن سّبّ مُشُ بّ كِتَابُي كُي، ‹شَ شّمّ ندٍ تَارَ قَشَ، عَ نَشَ عَ شَ فِنّ لُ عَ مُ دِ يٌ بَرِ، عَ نَ شُنيَ نَن نَ فِنّ دْشْمَ، عَلَكٌ عَ شَ بْنسْي قِ عَ تَارَ مَ.›
\v 20 نَ كُي، شّمّ ندٍ نَشَ دِ شّمّ سٌلٌقٍرٍ سْتْ. عَ شَ دِ سِنفٍ نَشَ فِنّ دْشْ، عَ قَشَ، عَ مُ بْنسْي يٌ لُ.
\v 21 عَ شَنبِرَتٌي نَشَ نَ كَاحّ فِنّ تٌنفٌ، كْنْ عَ قَن نَشَ قَشَ، عَ مُ بْنسْي يٌ لُ. نَ نَن مَن نَبَ نَ قَن شَنبِرَتٌي رَ.
\v 22 يِ مِشِ سٌلٌقٍرٍ بِرِن، عٍ سٍسٍ مُ بْنسْي لُ. عَ دْنشْي رَ، فِنّ قَن نَشَ قَشَ.
\v 23 نَ كُي، مَرَكٍلِ لْشْي، نَ فِنّ تٌ دْشْشِ يِ مِشِ سٌلٌقٍرٍ بِرِن شْن مَ، عَ سَ قِندِ مَ ندٍ فبٍ رَ؟»
\p 
\v 24 عِسَ نَشَ عَ مَسٍن عٍ بّ، «وٌ مُ عَلَ شَ كِتَابُي كٌلٌن، وٌ مُ عَلَ سّنبّ قَن كٌلٌن. وٌ شَ تَنتَنيِ كٍلِدٍ شَ مُ نَ كِ؟
\v 25 مِشِيٍ نَ كٍلِ قَشّ مَ مَرَكٍلِ لْشْي، شّمّ مُ فِنّ دْشْمَ، فِنّ قَن مُ دْشْمَ شّمّ شْن. عٍ لُمَ نّ عَلْ مَلٍكّيٍ نَ عَرِيَننَ كِ نَشّ.
\v 26 عَ قَلَقٍ تَن، عَ قَشَمِشِيٍ مُ كٍلِمَ قَشّ مَ، وٌ مُ نُ عَننَبِ مُنسَ شَ كِتَابُي شَرَن، وُرِ بِلِ شَ قٍ قَلَشِ دّننَشّ؟ عَلَ عَ مَسٍن نّ عَ بّ، ‹ﭑ تَن نَن نَ مَرِفِ عَلَتَلَ رَ، عِبُرَهِمَ، عِسِيَفَ، نُن يَشُبَ نَشَن بَتُمَ.›
\v 27 قَشَمِشِيٍ شَ مُ عَلَ بَتُمَ، قٌ نَشٍيٍ بَلٌشِ. نَ تَن قِندِشِ وٌ بّ تَنتَنيِ نَن نَ.»
\s1 يَامَرِ نَشَن تِدٍ فبٌ عَ بِرِن بّ
\r مَتِيُ ٢٢‏؛٣٤ ٬ ٤٠، لُكِ ١٠‏؛٢٥ ٬ ٣٧
\p 
\v 28 سّرِيّ كَرَ مْشْ ندٍ نَشَ عَ مَسٌ عٍ رَ، عَ عَ تُلِ مَتِ عٍ شَ وْيّنيِ رَ. عَ تٌ عَ تٌ عَ عِسَ بَرَ يَابِ قَنيِ قِ، عَ نَشَ عَ مَشْرِن، «سّرِيّ مُندُن تِدٍ فبٌ سّرِيّ بِرِن يَ مَ؟»
\v 29 عِسَ نَشَ عَ يَابِ، «عَ سِنفٍ نَن يِ كِ، ‹عِسِرَيِلَ، عِ تُلِ مَتِ، وٌن مَرِفِ عَلَ، مَرِفِ كٍرٍن ثٍتِ نَ عَ رَ.
\v 30 عِ شَ عِ مَرِفِ عَلَ شَنُ عِ بْحّ بِرِن نَ، عِ نِي بِرِن نَ، عِ شَشِلِ بِرِن نَ، عَ نُن عِ سّنبّ بِرِن نَ.›
\v 31 عَ قِرِن ندٍ نَن يِ كِ، ‹عِ شَ عِ نفَشَكٍرٍنيِ شَنُ عَلْ عِ عِ يّتّ شَنُشِ كِ نَشّ.› سّرِيّ فبّتّ يٌ مُ نَ نَشَن دَنفِ نٍيٍ رَ.»
\p 
\v 32 سّرِيّ كَرَ مْشْ نَشَ عَ قَلَ عِسَ بّ، «عِ نْندِ، كَرَ مْشْ. عِ بَرَ نْندِ مَسٍن عَ عَلَ كٍرٍن ثٍتِ نَن عَ رَ، عَ بٌورٍ مُ نَ، قٌ عَ كٍرٍن.
\v 33 مِشِ شَ عَ شَنُ عَ بْحّ بِرِن نَ، عَ شَشِلِ بِرِن نَ، عَ نُن عَ سّنبّ بِرِن نَ. مِشِ مَن شَ عَ نفَشَكٍرٍنيِ شَنُ عَلْ عَ عَ يّتّ شَنُشِ كِ نَشّ. نٍيٍ رَبَتُقٍ دَنفِ سّرّشّ فَن دَاشِ نُن سّرّشّ بِرِن نَ.»
\v 34 عِسَ تٌ عَ تٌ، عَ عَ بَرَ شَشِلِمَيَ يَابِ قِ، عَ نَشَ عَ مَسٍن عَ بّ، «عَ فبٍ مُ لُشِ عِ شَ سٌ عَلَ شَ مَنفّيَ نِينِ بُن مَ.» نَ شَنبِ، مِشِ يٌ مُ سُو سَ عِسَ مَشْرِندٍ سْنْن.
\s1 دَوُدَ نُن عَلَ شَ مِشِ سُفَندِشِ
\r مَتِيُ ٢٢‏؛٤١ ٬ ٤٦، لُكِ ٢٠‏؛٤١ ٬ ٤٤
\p 
\v 35 عِسَ نَشَ كَوَندِ تِ قْلْ هْرْ مْبَنشِ كُي. «مُنقٍ رَ سّرِيّ كَرَ مْشْيٍ عَ قَلَمَ، عَ عَلَ شَ مِشِ سُفَندِشِ قِندِشِ دَوُدَ شَ دِ نَن نَ؟
\v 36 عَلَ شَشِلِ سّنِيّنشِ سَابُي رَ، دَوُدَ يّتّ عَ مَسٍن نّ،
\q1 ‹مَرِفِ بَرَ عَ مَسٍن ﭑ مَرِفِ بّ،
\q1 “ِ مَفٌرٌ ﭑ يِرٍقَنيِ مَ،
\q1 هَن بٍيمَنُن ﭑ شَ عِ يَشُييٍ رَفٌرٌ عِ سَنيِ بُن.”›»
\m 
\v 37 «دَوُدَ يّتّ يَتِ عَ قَلَمَ عَ بّ، ‹ﭑ مَرِفِ›. دَوُدَ قَ نْمَ قِندِدٍ عَ بَبَ رَ دِ؟»
\p حَمَ فبٍفبٍ نُ عٍ تُلِ مَتِمَ عَ رَ، عَ شَ كَوَندِ نُ رَقَن عٍ مَ.
\s1 دِينّلَ كٌبِيٍ
\r مَتِيُ ٢٣‏؛١ ٬ ٣٩، لُكِ ١١‏؛٣٧ ٬ ٥٢، ٢٠‏؛٤٥ ٬ ٤٧
\p 
\v 38 عِسَ نَشَ عَ مَسٍن عٍ بّ عَ شَ كَوَندِ كُي، «وٌ وٌ يّتّ رَتَنفَ سّرِيّ كَرَ مْشْيٍ مَ. عَ رَقَن عٍ مَ عٍ شَ عٍ مَحّرّ فُبَ شُنفبٍ رَفٌرٌشِ عٍ مَ، مِشِيٍ شَ نُ عٍ شّيبُ تَا كُي بِنيّ شّيبُييٍ رَ.
\v 39 عٍ وَ مَ دْشْقٍ سَلِدٍ سَقّ سِنفٍيٍ، عٍ مَن شَ بِنيّ سْتْ شُلُنيِ.
\v 40 عٍ كَاحّ فِنّيٍ هَرِفٍ مُحَمَ. عٍ سَلِمَ عَ شْنكُيٍ رَ، عَلَكٌ مِشِيٍ شَ عٍ تٌ. فبَلٌي نَشَن نَفَتَشِ عٍ بّ، عَ فبٌ كِ قَنيِ.»
\s1 كَاحّ فِنّ شَ هَدِيَ
\r لُكِ ٢١‏؛١ ٬ ٤
\p 
\v 41 عِسَ نَشَ دْشْ سَلِدٍ كُي، عَ يَ رَقِندِشِ كْبِرِ كَنكِرَ مَ، عَ نُ مِشِيٍ مَتٌ عٍ كْبِرِ سَمَ عَ كُي كِ نَشّ. بَننَمِشِ وُيَشِ نُ كْبِرِ فبٍفبٍ سَقٍ.
\v 42 كَاحّ فِنّ مِسِكِينّ قَن تٌ قَ، عَ تَن نَشَ كْبِرِ كٌلٍ قِرِن سَ نَشٍيٍ يُسِ مُ فبٌ.
\v 43 نَ كُي، عِسَ نَشَ عَ قْشِرَبِرّيٍ شِلِ، عَ عَ مَسٍن عٍ بّ، «ﭑ شَ نْندِ قَلَ وٌ بّ، يِ كَاحّ فِنّ مِسِكِينّ شَ كْبِرِ سَشِ فبٌ دَنفِ بِرِن فبٍ رَ نَشٍيٍ بَرَ كْبِرِ سَ كَنكِرَ كُي.
\v 44 عٍ تَن شَ هَدِيَ كٍلِشِ عٍ شَ نَاقُلِ نَن كُي، كْنْ يِ كَاحّ فِنّ تَن شَ هَدِيَ كٍلِشِ عَ شَ بَلٌي نَن كُي.»
\c 13
\s1 هْرْ مْبَنشِ شَ مِسَالِ
\r مَتِيُ ٢٤‏؛١ ٬ ٢، لُكِ ٢١‏؛٥ ٬ ٦
\p 
\v 1 عِسَ تٌ مِنِ هْرْ مْبَنشِ، عَ قْشِرَبِرّ كٍرٍن نَشَ عَ قَلَ عَ بّ، «كَرَ مْشْ، يِ بَنشِيٍ مَتٌ، عٍ تِشِ فّمّ شُنفبٍ نَشٍيٍ رَ، عٍ تِ كِ مَن تٌقَنشِ كِ نَشّ!»
\v 2 عِسَ نَشَ عَ يَابِ، «عِ يِ بَنشِ بٍلٍبٍلٍيٍ تٌشِ؟ يِ فّمّ كٍرٍن مُ لُمَ عَ بٌورٍ قَرِ بٍ، عَ بِرِن نَبِرَ مَ نّ.»
\s1 مَرَتَنتَنيِ، تْورّ، نُن حَشَنكَتّ
\r مَتِيُ ٢٤‏؛٣ ٬ ١٤، لُكِ ٢١‏؛٧ ٬ ١٩
\p 
\v 3 عِسَ تٌ نُ مَفٌرٌشِ عٌلِوِ فٍيَ قَرِ، عَ يَ رَقِندِشِ هْرْ مْبَنشِ مَ، ثِيّرِ، يَكِ، يَيَ، نُن عَندِرٍ نَشَ عَ مَشْرِن عٍ دٌرٌ مَ،
\v 4 «نَ قٍ سَ رَبَمَ مُن تّمُي؟ عَ مَن سَ كٌلٌنمَ تْنشُمَ مُندُن مَ عَ عَ قَقٍ رَبَدٍ؟»
\p 
\v 5 عِسَ نَشَ سٌ وْيّنقٍ عٍ بّ، «وٌ وٌ مّينِ.
\v 6 مِشِ وُيَشِ قَمَ ﭑ تَن شِلِ قَلَدٍ عٍ يّتّ شُن مَ عَ قَلَقٍ رَ، ‹ﭑ تَن نَن نَ عَلَ شَ مِشِ سُفَندِشِ رَ!› نَ كُي، عٍ قَمَ مِشِ فبٍفبٍ رَتَنتَندٍ.
\v 7 وٌ نَ فٍرٍ قٍ مّ، وٌ نَ فٍرٍ ندٍ شِلِ مّ، وٌ نَشَ كْنتْقِلِ، بَرِ مَ قٌ نَ قٍ مْولِيٍ شَ رَبَ. نَ شَ مُ قِندِ مَ دُنِحَ رَحْنيِ رَ سِندٍن.
\v 8 سِيٍ كٍلِمَ نّ عٍ بٌورٍ شِلِ مَ، حَمَنّيٍ عٍ بٌورٍ فٍرٍ. بْشِ قَمَ نّ سّرّندٍ يِرٍ وُيَشِ، كَامّ قَن سِن بْشِ مَ. نَ بِرِن قِندِ مَ مَنتْورْلِ قْلّ نَن نَ.»
\p 
\v 9 «وٌ شَ مّينِ وٌ يّتّ مَ، بَرِ مَ عٍ وٌ سٌمَ نّ كِيتِسَيٍ يِ رَ، عٍ وٌ بْنبْ سَلِدٍ بَنشِيٍ كُي. وٌ تِمَ نّ فٌمِنَيٍ نُن مَنفّيٍ يَ عِ ﭑ تَن مَ قٍ رَ، وٌ قِندِ مَ نّ ﭑ مَ سٍيدٍيٍ رَ عٍ تَن بّ.
\v 10 قٌ شِبَارُ قَنيِ شَ كَوَندِ سِ بِرِن بّ سِندٍن.
\v 11 عٍ نَ وٌ شَنِن وٌ مَكِيتِدٍ تّمُي نَشّ، وٌ نَشَ كْنتْقِلِ وٌ شَ مَسٍنيِ شَ قٍ رَ بٍينُن وٌ شَ عَ تِ. عَلَ نَ وْيّنيِ نَشَن يٌ قِ وٌ مَ نَ وَشَتِ مَ، وٌ شَ نَ نَن قَلَ، بَرِ مَ وٌ تَن شَ مُ وْيّنمَ، عَلَ شَشِلِ سّنِيّنشِ نَن قَمَ وْيّندٍ.»
\p 
\v 12 «مِشِ قَمَ عَ نفَشَكٍرٍنيِ يَنقَدٍ، عَ عَ سَ مِشِيٍ بّلّشّ، عٍ شَ عَ قَشَ. بَبّ قَن نَ مْولِ نِيَمَ عَ شَ دِ رَ، دِيٍ قَن كٍلِمَ نّ عٍ بَرِ مَيٍ شِلِ مَ، عٍ شَ عٍ قَشَ.
\v 13 مِشِ بِرِن قَمَ وٌ شْندٍ ﭑ تَن مَ قٍ رَ، كْنْ نَشَن نَ عَ تُننَبّشِ هَن عَ رَحْنيِ، نَ كَنيِ كِسِمَ نّ.»
\s1 سٍ هَرَ مُشِ حَاشِ
\r مَتِيُ ٢٤‏؛١٥ ٬ ٢٨، لُكِ ٢١‏؛٢٠ ٬ ٢٤
\p 
\v 14 «وٌ تَن نَشٍيٍ نَ يِ شَرَنقٍ، وٌ وٌ تُلِ مَتِ دٍ! وٌ نَ سٍ هَرَ مُشِ حَاشِ تٌ كَسَرّ نَ نَشَن شَنبِ رَ، عَ تِشِ يِرٍ عَ مُ لَن عَ شَ تِ دّننَشّ، وٌ تَن نَشٍيٍ نَ يُدَيَ نَ تّمُي، وٌ شَ وٌ فِ فٍيَيٍ قَرِ.
\v 15 نَشَن نَ تَندٍ، عَ نَشَ سٌ سٍسٍ تٌنفٌدٍ عَ شَ بَنشِ كُي.
\v 16 نَشَن نَ شّ مَ، عَ نَشَ فبِلٍن عَ شَ شِنبٍلِ دٌنمَ تٌنفٌدٍ.
\v 17 نَ وَشَتِ قِندِ مَ فبَلٌي نَن نَ قُرُفِنّيٍ نُن دِنفّيٍ بّ!
\v 18 وٌ عَلَ مَشَندِ نَ نَشَ وٌ لِ حّمّ تّمُي!
\v 19 بَرِ مَ تْورّ عَ لِمَ نَ وَشَتِ مَ، نَشَن مَنِيّ سِنفٍ مُ نُ تٌ كَبِ عَلَ نَشَ دُنِحَ دَا، عَ مَن مُ فبِلٍنمَ تٌ رَ عَبَدَن.
\v 20 شَ مَرِفِ مُ عَ رَفِرِشِ نُ ندٍ شَ بَ نَ شِ كْنتِ رَ، عَدَ مَ يٌ مُ كِسِمَ نُ. كْنْ عَ ندٍ بَشِ عَ كْنتِ رَ مِشِ سُفَندِشِيٍ نَن شَ قٍ رَ.»
\p 
\v 21 «شَ مِشِ ندٍ سَ عَ قَلَ وٌ بّ، ‹عَ مَتٌ، عَلَ شَ مِشِ سُفَندِشِ نَ بٍ›، شَ نَ مُ عَ رَ، ‹عَلَ شَ مِشِ سُفَندِشِ نَ مّننِ،› وٌ نَشَ لَ عَ رَ.
\v 22 بَرِ مَ وُلٍ قَلّيٍ قَمَ عَلَ شَ مِشِ سُفَندِشِ شِلِ قَلَدٍ عٍ يّتّ شُن، شَ نَ مُ عٍ عٍ يّتّ قِندِ نَمِحْنمّيٍ رَ. عٍ قَمَ تْنشُمَ مَكَابَشِيٍ نُن كَابَنَكٌي رَبَدٍ عَلَكٌ عٍ شَ عَلَ شَ مِشِ سُفَندِشِيٍ رَتَنتَن، شَ عٍ سَ نْمَ.
\v 23 وٌ مّينِ وٌ يّتّ مَ. ﭑ بَرَ قٍ بِرِن مَسٍن وٌ بّ بٍينُن عَ وَشَتِ شَ عَ لِ.»
\s1 عَدَ مَ شَ دِ فبِلٍنقٍ
\r مَتِيُ ٢٤‏؛٢٩ ٬ ٣١، لُكِ ٢١‏؛٢٥ ٬ ٢٨
\p 
\v 24 «نَ حَشَنكَتّ وَشَتِ دَنفِ شَنبِ،
\q1 ‹سٌفٍ عِقْورْ مَ نّ،
\q1 كِكٍ يَنبّ بَمَ نّ،
\q1 
\v 25 تُنبُييٍ بِرَ مَ نّ بْشِ،
\q1 سٍ نَشَن بِرِن نَ كٌورٍ مَ عَ سّرّنمَ نّ.›»
\m 
\v 26 «نَ تّمُي عَدَ مَ شَ دِ تٌمَ نّ قَ رَ نُشُي كُي، سّنبّ نُن نْرّ رَ.
\v 27 عَ عَ شَ مَلٍكّيٍ شّيمَ نّ دُنِحَ تُنشُن نَانِ بِرِن نَ، عٍ شَ سَ عَ شَ مِشِ سُفَندِشِيٍ مَلَن كٍلِ سّيتِ هَن سّيتِ.»
\s1 شْرّ بِلِ شَ مِسَالِ
\r مَتِيُ ٢٤‏؛٣٢ ٬ ٣٥، لُكِ ٢١‏؛٢٩ ٬ ٣٣
\p 
\v 28 «وٌ شْرّ بِلِ مَتٌ مِسَالِ رَ، وٌ شَ شَشِلِ سْتْ. عَ سَلٌنيِ نَ حِنفِ، عَ بُرّشّ نّينّ نَشَ مِنِ، وٌ عَ كٌلٌنمَ نّ حّمّ بَرَ مَكْرّ.
\v 29 عَدَ مَ شَ دِ قَقٍ قَن نَ نَ كِ نّ. وٌ نَ يِ قٍ بِرِن تٌ رَبَ رَ، وٌ شَ عَ كٌلٌن عَدَ مَ شَ دِ بَرَ مَكْرّ، عَ حَن تِشِ نَادّ رَ.
\v 30 ﭑ شَ نْندِ قَلَ وٌ بّ، تٌ مِشِيٍ مُ دَنفِمَ قٌ نَ قٍ بِرِن نَبَ.
\v 31 كٌورٍ نُن بْشِ دَنفِمَ نّ، كْنْ ﭑ مَ مَسٍنيِ تَن مُ دَنفِمَ عَبَدَن.»
\s1 دُنِحَ رَحْنيِ وَشَتِ كٌلٌنقٍ
\r مَتِيُ ٢٤‏؛٣٦ ٬ ٤٤
\p 
\v 32 «مِشِ يٌ مُ عَ كٌلٌن يِ قٍيٍ سَ رَبَمَ لْشْي نُن وَشَتِ يٌ مَ. هَلِ مَلٍكّ نَشٍيٍ نَ عَرِيَننَ، عٍ مُ عَ كٌلٌن، عَلَ شَ دِ قَن مُ عَ كٌلٌن، قٌ بَبَ عَلَ كٍرٍن ثٍتِ.
\v 33 وٌ مّينِ وٌ يّتّ مَ، وٌ نَشَ يَنقَ، بَرِ مَ وٌ قَن مُ عَ كٌلٌن يِ قٍيٍ سَ كَمَلِمَ تّمُي نَشّ.»
\p 
\v 34 «عَ مَنِيَشِ شّمّ نَن نَ، نَشَن نَ سِفَقٍ بِيَاسِ. عَ نَ كٍلِ عَ شَ قْشْي شُن، عَ نَ بِرِن تَشُمَ عَ شَ كٌنيِيٍ رَ، عَ كَنكَن تِ عَ شَ وَلِ دّ، عَ مَن عَ قَلَ نَادّ كَنتّ بّ، عَ عَ نَشَ يَنقَ.
\v 35 نَ كُي، وٌ نَشَ يَنقَ. شَ قْشْي كَنيِ فبِلٍنمَ نُنمَرٍ نَن نَ بَ، شَ نَ مُ كْي تَفِ، شَ نَ مُ كٌنكٌرٍ دّيَ سِنفٍ، شَ نَ مُ فّيسّفّ، وٌ مُ عَ وَشَتِ يٌ كٌلٌن.
\v 36 شَ عَ قَ وٌ تّرّننَ، عَ نَشَ عَ لِ دٍ وٌ شِقٍ!
\v 37 ﭑ نَشَن قَلَمَ وٌ بّ، ﭑ نَ نَن عَ قَلَمَ بِرِن بّ؛ وٌ نَشَ يَنقَ!»
\c 14
\s1 يَنقَنتٍيَ عِسَ بّ
\r مَتِيُ ٢٦‏؛١ ٬ ٥، لُكِ ٢٢‏؛١ ٬ ٦
\p 
\v 1 شِ قِرِن نَن نُ لُشِ بٍينُن سَيَمَلٍكّ دَنفِ سَلِ شَ عَ لِ، نَشَن مَن شِلِ قَلَمَ تَامِ لّبِنِتَرٍ سَلِ. سّرّشّدُبّ كُنتِفِيٍ نُن سّرِيّ كَرَ مْشْيٍ نُ نَ قّيرّ قٍنقٍ عٍ شَ عِسَ سُشُ يَنقَنتٍيَ سَابُي رَ، عٍ شَ عَ قَشَ.
\v 2 عٍ نَشَ لَن عَ مَ، «وٌن نَشَ عَ سُشُ سَلِ لْشْي، شَ نَ مُ عَ رَ حَمَ عَ شُنيِ كٍلِمَ نّ.»
\s1 فِنّ ندٍ لَبُندّ تُرٍ سَقٍ عِسَ مَ
\r مَتِيُ ٢٦‏؛٦ ٬ ١٣
\p 
\v 3 عِسَ تٌ نُ نَ بٍتَنِ، سِمْن كُنّ كَنيِ شْنيِ، عَ عَ دّفٍقٍ تٍيبِلِ رَ، فِنّ ندٍ نَشَ قَ. نَرَدَ لَبُندّ تُرٍ نُ نَ عَ يِ رَ، نَشَن سَرٍ شْرْشْ كِ قَنيِ. عَ نُ سَشِ عَ بِتِرّ تٌقَنيِ كُي نَشَن نُ رَقَلَشِ عَلَبَتِرَ فّمّ رَ. فِنّ تٌ بِتِرّ دّ رَبِ، عَ نَشَ لَبُندّ تُرٍ سَ عِسَ شُنيِ.
\v 4 كْنْ مِشِ ندٍيٍ نُ نَ نَا، عٍ نَشَ شْنْ، عٍ عَ قَلَ عٍ بٌرٍ بّ، «يِ لَبُندّ تُرٍ مَكَنَشِ يِ مْولِ رَ مُنقٍ رَ؟
\v 5 شَ عَ سَ مَتِ نّ نُ، عَ سَرٍ نْمَ دَنفِدٍ وَلِكّ شَ حّ كٍرٍن وَلِ سَرٍ رَ، نَ كْبِرِ قَن نْ قِدٍ سٍتَرٍيٍ مَ.» عٍ بْحّ نَشَ تٍ فِنّ شِلِ مَ.
\p 
\v 6 كْنْ عِسَ نَشَ عَ مَسٍن، «وٌ يِ فِنّ لُ نَ. وٌ نَ عَ تْورْقٍ مُنقٍ رَ؟ كّوَلِ قَنيِ نَن يِ كِ، عَ نَشَن نَبَشِ ﭑ بّ.
\v 7 سٍتَرٍيٍ لُمَ نّ وٌ يَ مَ تّمُي بِرِن. وٌ نَ وَ عَ شْن مَ تّمُي يٌ، وٌ نْمَ قٍ قَنيِ رَبَدٍ عٍ بّ، كْنْ ﭑ تَن مُ لُمَ وٌ يِ رَ بٍ عَبَدَن شّ.
\v 8 يِ فِنّ نْشِ نَشَن نَ، عَ نَ نَن نَبَشِ. عَ لَبُندّ سَشِ ﭑ مَ ﭑ مَ مَرَفَتّ لْشْي نَن مَ قٍ رَ.
\v 9 ﭑ شَ نْندِ قَلَ وٌ بّ، عَلَ شَ شِبَارُ قَنيِ سَ كَوَندِ مَ دّدّ دُنِحَ بِرِن كُي، يِ فِنّ شَ كّوَلِ شَ قٍ قَن قَلَمَ نّ، مِشِيٍ شَ عٍ رَتُ عَ شَ قٍ مَ.»
\s1 يُدَ سِ شَ يَنقَنتٍيَ
\r مَتِيُ ٢٦‏؛١٤ ٬ ١٦، لُكِ ٢٢‏؛١ ٬ ٦
\p 
\v 10 نَ تّمُي، يُدَ سِ عِسِكَرِيٌتِ، نَشَن نُ نَ عِسَ قْشِرَبِرّ قُ نُن قِرِنيِيٍ يَ مَ، عَ نَشَ سِفَ سّرّشّدُبّ كُنتِفِيٍ يِرٍ، عٍ شَ وْيّن عَلَكٌ عَ شَ عِسَ سَ عٍ بّلّشّ.
\v 11 عٍ تٌ عَ مّ، عٍ نَشَ حّلّشِن كِ قَنيِ رَ، عٍ كْبِرِ لَايِدِ تٌنفٌ عَ بّ. نَ كُي، يُدَ سِ نَشَ سٌ وَشَتِ قٍنقٍ عَ نْمَ عِسَ سَدٍ عٍ بّلّشّ تّمُي نَشّ.
\s1 سَيَمَلٍكّ دَنفِ سَلِ
\r مَتِيُ ٢٦‏؛١٧ ٬ ٢٥، لُكِ ٢٢‏؛٧ ٬ ٣٤
\p 
\v 12 تَامِ لّبِنِتَرٍ سَلِ تٌ عَ لِ، عَ لْشْي سِنفٍ، يّشّييْرّ بَمَ سّرّشّ رَ لْشْ نَشّ، عِسَ قْشِرَبِرّيٍ نَشَ عَ مَشْرِن، «عِ وَ مَ مُشُ شَ سَ سَيَمَلٍكّ دَنفِ سَلِ دٌنيِ رَقَلَ عِ بّ مِندٍن؟»
\v 13 عَ نَشَ عَ قْشِرَبِرّ مِشِ قِرِن شّي، عَ عَ قَلَ عٍ بّ، «وٌ سِفَ تَا كُي. وٌ نَرَلَنمَ شّمّ ندٍ رَ، يٍ قّحّ دْشْشِ عَ شُن. وٌ شَ بِرَ عَ قْشْ رَ.
\v 14 عَ نَ سٌ دّننَشّ، وٌ شَ عَ قَلَ نَ بَنشِ كَنيِ بّ، ‹كَرَ مْشْ وَ مَ عَ كٌلٌنقٍ عَ نْمَ سَيَمَلٍكّ دَنفِ سَلِ دٌنيِ دٌندٍ دّننَشّ، عَ تَن نُن عَ قْشِرَبِرّيٍ.›
\v 15 عَ قَمَ بَنشِ كُي شُنفبٍ مَسٍندٍ وٌ بّ كٌورٍ رَ، سٍ بِرِن يَءِلَنشِ نَا عَ قَنيِ رَ. وٌ شَ سَيَمَلٍكّ دَنفِ سَلِ دٌنيِ رَقَلَ مّننِ.»
\v 16 عَ قْشِرَبِرّيٍ نَشَ سِفَ، عٍ سٌ تَا كُي، عٍ قٍ بِرِن لِ عَلْ عِسَ عَ مَسٍن عٍ بّ كِ نَشّ. عٍ نَشَ سَيَمَلٍكّ دَنفِ سَلِ دٌنيِ رَقَلَ.
\p 
\v 17 نُنمَرٍ تٌ سٌ، عِسَ نُن عَ قْشِرَبِرّ قُ نُن قِرِنيِيٍ نَشَ قَ.
\v 18 عٍ نُ نَ عٍ دّفٍقٍ تٍيبِلِ رَ تّمُي نَشّ، عِسَ نَشَ عَ مَسٍن، «ﭑ شَ نْندِ قَلَ وٌ بّ، وٌ تَن نَشٍيٍ نَ وٌ دّفٍقٍ ﭑ قّ مَ يِ كِ، مِشِ كٍرٍن نَ وٌ يَ مَ نَشَن قَقٍ ﭑ يَنقَدٍ.»
\v 19 عَ قْشِرَبِرّيٍ نَشَ سُننُن قْلْ، كَنكَن نُ قَ عِسَ مَشْرِن، «ﭑ تَن مُ عَ رَ؟»
\v 20 عِسَ نَشَ عٍ يَابِ، «عَ كَنيِ نَ وٌ تَن مِشِ قُ نُن قِرِنيِيٍ يَ مَ، ﭑ نُن نَشَن بّلّشّ رَفٌرٌ مَ ثَانِ كٍرٍن كُي.
\v 21 عَدَ مَ شَ دِ سِفَمَ نّ عَلْ عَ شَ قٍ سّبّشِ كِ نَشّ، كْنْ فبَلٌي نَن نَ عَدَ مَ شَ دِ يَنقَمَ بّ. عَ قِسَ نَ كَنيِ بّ هَلِ عَ مُ بَرِ نُ.»
\s1 مَرِفِ شَ سّرّشّ تْنشُمَ
\r مَتِيُ ٢٦‏؛٢٦ ٬ ٣٠، لُكِ ٢٢‏؛١٤ ٬ ٢٠، كٌرِنتِ عِ ١١‏؛٢٣ ٬ ٢٥
\p 
\v 22 عٍ تٌ نُ عٍ دّفٍقٍ، عِسَ نَشَ تَامِ تٌنفٌ. عَ تٌ تَنتُي رَ سِفَ عَلَ مَ، عَ نَشَ تَامِ عِفِرَ، عَ عَ سٌ عَ قْشِرَبِرّيٍ يِ رَ، عَ عَ قَلَ عٍ بّ، «وٌ ﭑ كٌ، وٌ عَ دٌن. يِ قِندِشِ ﭑ قَتٍ نَن نَ.»
\v 23 نَ دَنفِ شَنبِ، عِسَ نَشَ تْنبِلِ قَن تٌنفٌ. عَ مَن تٌ تَنتُي رَ سِفَ عَلَ مَ، عَ نَشَ تْنبِلِ سٌ عٍ يِ رَ، عٍ بِرِن نَشَ عَ مِن.
\v 24 عِسَ نَشَ عَ مَسٍن عٍ بّ، «يِ قِندِشِ ﭑ وُلِ نَن نَ، سَاتّ وُلِ نَشَن بَشِ مِشِ فبٍفبٍ بّ.
\v 25 ﭑ شَ نْندِ قَلَ وٌ بّ، ﭑ تٌ يِ وّنِ مِنقٍ يِ كِ، ﭑ مُ يِ مِنمَ سْنْن، هَن وٌن بِرِن مَن سَ عَ مِنمَ لْشْ نَشّ عَلَ شَ مَنفّيَ نِينِ بُن مَ.»
\p 
\v 26 عٍ تٌ فّ بّيتِ بَدٍ، عٍ نَشَ تٍ عٌلِوِ فٍيَ قَرِ.
\s1 عِسَ عَ قَلَقٍ ثِيّرِ بّ عَ عَ يّتّ رَ سَنمَ نّ عَ مَ
\r مَتِيُ ٢٦‏؛٣١ ٬ ٣٥، لُكِ ٢٢‏؛٣١ ٬ ٣٤، يَيَ ١٣‏؛٣٦ ٬ ٣٨
\p 
\v 27 عِسَ نَشَ عَ مَسٍن عَ قْشِرَبِرّيٍ بّ، «وٌ بِرِن فبِلٍنمَ نّ ﭑ قْشْ رَ، بَرِ مَ عَ سّبّشِ، ‹ﭑ شُرُ سٍ دّ مَدٌنيِ قَشَمَ نّ، يّشّييٍ قَن يٍنسٍن.›
\v 28 كْنْ ﭑ نَ كٍلِ قَشّ مَ، ﭑ سِفَمَ وٌ يَ رَ فَلِلٍ.»
\p 
\v 29 ثِيّرِ نَشَ عَ قَلَ عَ بّ، «هَلِ بِرِن فبِلٍن عِ قْشْ رَ، ﭑ تَن مُ فبِلٍنمَ عِ قْشْ رَ!»
\v 30 عِسَ نَشَ ثِيّرِ يَابِ، «ﭑ شَ نْندِ قَلَ عِ بّ، تٌ كْي يَتِ، بٍينُن كٌنكٌرٍ شَ عَ رَتٍ دّيَ قِرِن، عِ عِ يّتّ رَ سَنمَ نّ ﭑ مَ سَنمَيَ سَشَن.»
\v 31 كْنْ ثِيّرِ نَشَ عَ قَلَ سّنبّ رَ، «هَلِ وٌن بِرِن نَن سَ قَشَمَ، ﭑ مُ ﭑ يّتّ رَ سَنمَ عِ مَ!» عِسَ قْشِرَبِرّ بِرِن نَشَ فبِلٍن نَ وْيّن كٍرٍن قَلَ رَ.
\s1 عِسَ عَلَ مَشَندِقٍ فٍتٍسٍمَنِ
\r مَتِيُ ٢٦‏؛٣٦ ٬ ٤٦، لُكِ ٢٢‏؛٣٩ ٬ ٤٦
\p 
\v 32 نَ دَنفِ شَنبِ عِسَ نُن عَ قْشِرَبِرّيٍ نَشَ سِفَ يِرٍ ندٍ، دّننَشّ شِلِ فٍتٍسٍمَنِ. عِسَ نَشَ عَ قَلَ عٍ بّ، «وٌ دْشْ بٍ. ﭑ تَن شَ سَ عَلَ مَشَندِ.»
\v 33 عَ نَشَ ثِيّرِ، يَكِ، نُن يَيَ شَنِن عَ شُن مَ. حَشَنكَتّ نُن كْنتْقِلِ نَشَ عِسَ بْحّ سُشُ.
\v 34 عَ نَشَ عَ مَسٍن عٍ بّ، «سُننُنيِ بَرَ نْ ﭑ بْحّ رَ عَلْ عَ شَ ﭑ قَشَ. وٌ لُ بٍ، كْنْ وٌ نَشَ شِ.»
\p 
\v 35 عِسَ نَشَ عَ مَسِفَ دٌندٌرٌنتِ، عَ عَ يَتَفِ رَقٍلٍن بْشِ مَ، عَ عَلَ مَشَندِ نَ وَشَتِ شَ مَكُيَ عَ رَ، شَ نَ سَ نْمَ رَبَدٍ.
\v 36 عَ نَشَ عَلَ مَشَندِ، «ﭑ بَبَ، عِ نْمَ قٍ بِرِن نَ. عِ شَ ﭑ نَتَنفَ يِ حَشَنكَتّ مَ. كْنْ ﭑ سَفٌ نَشَ رَبَ، عِ تَن نَن سَفٌ شَ رَبَ.»
\v 37 عَ تٌ فبِلٍن عَ قْشِرَبِرّيٍ يِرٍ، عَ نَشَ عٍ لِ عٍ نَ شِقٍ. عَ نَشَ عَ قَلَ ثِيّرِ بّ، «سِمْن، عِ شِقٍ نّ يِ كِ؟ عِ مُ نْشِ وَشَتِ كٍرٍن شِ شْلِ كَنَدٍ ﭑ مَ قٍ رَ؟
\v 38 وٌ نَشَ شِ. وٌ عَلَ مَشَندِ نّ عَلَكٌ وٌ نَشَ بِرَ تَنتَنيِ كُي. مَحْشُن قَنيِ نَ عَدَ مَ بّ، كْنْ عَ قَتٍ بّندّ تَن سّنبّ مُ نَ.»
\p 
\v 39 عِسَ مَن تٌ عَ مَسِفَ عٍ رَ، عَ مَن نَشَ عَلَ مَشَندِ نَ مَشَندِ كٍرٍنيِ رَ.
\v 40 عَ تٌ فبِلٍن عَ قْشِرَبِرّيٍ يِرٍ، عَ مَن نَشَ عٍ لِ عٍ شِقٍ، بَرِ مَ شِ شْلِ نُ بَرَ نْ عٍ رَ. يَابِ يٌ مُ نُ عٍ يِ عِسَ بّ.
\p 
\v 41 عِسَ مَن تٌ فبِلٍن عٍ يِرٍ عَ سَنمَيَ سَشَن ندٍ، عَ نَشَ عَ قَلَ عٍ بّ، «وٌ شِقٍ نّ؟ وٌ نَ وٌ مَلَبُقٍ هَن يَ؟ عَ تَن نَن نَ كِ، وَشَتِ بَرَ عَ لِ. عَدَ مَ شَ دِ قَقٍ سَدٍ يُنُبِتْييٍ بّلّشّ.
\v 42 وٌ كٍلِ، وٌن شّي. وٌ عَ مَتٌ، ﭑ يَنقَمَ بَرَ قَ.»
\s1 عِسَ سُشُقٍ
\r مَتِيُ ٢٦‏؛٤٧ ٬ ٥٦، لُكِ ٢٢‏؛٤٧ ٬ ٥٣، يَيَ ١٨‏؛٣ ٬ ١١
\p 
\v 43 عِسَ حَن مُ نُ فّشِ وْيّندٍ، يُدَ سِ، نَشَن نُ نَ عَ قْشِرَبِرّ قُ نُن قِرِنيِيٍ يَ مَ، عَ نَشَ قَ كٍرٍن نَ عٍ نُن حَمَ، سَنتِدّفّمَ نُن فبٍنفبٍتَ سُشُشِ عٍ يِ رَ. سّرّشّدُبّ كُنتِفِيٍ، سّرِيّ كَرَ مْشْيٍ، نُن يُوِقِيٍ شَ قٌرِيٍ نَن نُ عٍ شّيشِ.
\v 44 عِسَ يَنقَمَ نُن نَ حَمَ نُ بَرَ لَن عَ مَ، عَ شَ عِسَ مَتْنشُمَ عٍ بّ. عَ نُ بَرَ عَ قَلَ عٍ بّ، «ﭑ نَ مِشِ نَشَن سُنبُ، عَ تَن نَن نَ كِ. وٌ عَ سُشُ، وٌ عَ شَنِن، وٌ عَ كَنتَ.»
\v 45 يُدَ سِ قّقّ قَ، عَ نَشَ عَ مَسٌ عِسَ رَ، عَ عَ قَلَ عَ بّ، «كَرَ مْشْ،» عَ قَ عَ سُنبُ.
\v 46 نَ كُي، حَمَ نَشَ عِسَ سُشُ.
\p 
\v 47 مِشِ ندٍ نُ تِشِ نَا، عَ نَشَ عَ شَ سَنتِدّفّمَ رَ مِنِ، عَ سّرّشّدُبّ كُنتِفِ شَ كٌنيِ تُلِ بٌلٌن.
\v 48 عِسَ نَشَ عَ مَسٍن عٍ بّ، «وٌ تٌ مِنِشِ ﭑ شِلِ مَ سَنتِدّفّمَ نُن فبٍنفبٍتَ سُشُشِ وٌ يِ رَ، سُوتٍ نَن نَ ﭑ نَ؟
\v 49 لْشْ يٌ لْشْ، ﭑ نُ نَ وٌ يَ مَ، ﭑ نُ كَوَندِ تِ هْرْ مْبَنشِ كُي، وٌ مُ ﭑ سُشُ. كْنْ نَشَن سّبّشِ كِتَابُي كُي، قٌ عَ شَ كَمَلِ.»
\v 50 نَ شَنبِ، عِسَ قْشِرَبِرّيٍ بِرِن نَشَ عٍ فِ عَ شُن مَ.
\p 
\v 51 سّفّتَلَ ندٍ قَن نُ نَ نَشَن نُ بِرَشِ عِسَ قْشْ رَ، دُفِ نَن فبَنسَن نُ قٍلٍنشِ عَ مَ. عٍ نَشَ عَ سُشُ،
\v 52 كْنْ عَ نَشَ مِنِ عَ شَ دُفِ كُي، عَ عَ فِ عَ مَفٍلِ رَ.
\s1 يُوِقِيٍ عِسَ مَكِيتِقٍ
\r مَتِيُ ٢٦‏؛٥٧ ٬ ٦٨، لُكِ ٢٢‏؛٦٣ ٬ ٦٥، يَيَ ١٨‏؛١٢ ٬ ٢٤
\p 
\v 53 عٍ نَشَ عِسَ شَنِن سّرّشّدُبّ كُنتِفِيٍ شُنيِ شْن. سّرّشّدُبّيٍ كُنتِفِيٍ، يُوِقِيٍ شَ قٌرِيٍ، نُن سّرِيّ كَرَ مْشْ بِرِن نُ مَلَنشِ نَا.
\v 54 ثِيّرِ نُ بَرَ بِرَ عِسَ قْشْ رَ، كْنْ عَ مُ نُ عَ مَكْرّ مَ عَ فبٍ رَ. عَ نَشَ بِرَ عَ قْشْ رَ هَن عَ سٌ سّرّشّدُبّ كُنتِفِيٍ شُنيِ شَ تّتّ كُي. عٍ نُن هْرْ مْبَنشِ كَنتَمَيٍ نَشَ دْشْ تّ رَ، عٍ نُ قَ عٍ مَشَرَ.
\v 55 سّرّشّدُبّ كُنتِفِيٍ نُن يُوِقِيٍ شَ كِيتِسَ دْنشْي بِرِن، عٍ نُ سٍيدٍ قٍنقٍ عِسَ شِلِ مَ، عَلَكٌ عٍ شَ عَ قَشَ، كْنْ عٍ مُ سٍ تٌ.
\v 56 مِشِ فبٍفبٍ نَشَ قَ عِسَ تْوحّفّدٍ، كْنْ عٍ شَ وُلٍيٍ مُ نُ لَنمَ عٍ بٌورٍ مَ.
\v 57 مِشِ ندٍيٍ تٌ كٍلِ وُلٍ سٍيدٍ بَدٍ عَ شِلِ مَ، عٍ نَشَ عَ قَلَ،
\v 58 «مُشُ عَ شُي مّشِ نّ، عَ عَ قَلَمَ، ‹ﭑ يِ هْرْ مْبَنشِ رَبِرَ مَ نّ، عَدَ مَ بّلّشّ نَشَن تِشِ، ﭑ فبّتّ تِ شِ سَشَن بُن مَ، نَشَن مُ تِشِ عَدَ مَ بّلّشّ رَ.›»
\v 59 كْنْ هَلِ نَ وْيّنيِ كُي، عٍ شَ سٍيدٍحْشْيَ مُ نُ لَنشِ عَ بٌورٍ مَ.
\p 
\v 60 نَ كُي، سّرّشّدُبّ كُنتِفِيٍ شُنيِ نَشَ كٍلِ حَمَ تَفِ، عَ عِسَ مَشْرِن، «ثٍ، عِ مُ عٍ يَابِمَ؟ يِ شّمّيٍ مُنسٍ سَقٍ عِ شُن مَ يِ كِ؟»
\v 61 كْنْ عِسَ مُ يَابِ يٌ قِ، عَ مُ سٍسٍ قَلَ. سّرّشّدُبّ كُنتِفِ شُنيِ مَن نَشَ عَ مَشْرِن، «عِ تَن نَن نَ عَلَ شَ مِشِ سُفَندِشِ رَ، بَتُ مَنفّ شَ دِ؟»
\v 62 عِسَ نَشَ عَ مَسٍن، «ﭑ تَن نَن نَ عَ رَ. وٌ قَمَ عَدَ مَ شَ دِ تٌدٍ، عَ دْشْشِ عَلَ سّنبّمَ يِرٍقَنيِ مَ، وٌ عَ تٌ قَقٍ رَ نُشُييٍ كُي.»
\p 
\v 63 نَ كُي، سّرّشّدُبّ كُنتِفِ نَشَ عَ يّتّ شَ دٌنمَ سُشُ، عَ عِبْو شْنّ رَ، عَ عَ قَلَ، «وٌن هَيِ نَ سٍيدٍ فبّتّيٍ مَ يِرٍ؟
\v 64 وٌ بَرَ عَ مّ عَ عَلَ مَبّشُشِ كِ نَشّ! وٌ كِيتِ تٌشِ دِ؟» عٍ بِرِن نَشَ عَ قَلَ عَ لَنمَ عَ شَ قَشَ نّ.
\v 65 ندٍيٍ نَشَ دّيٍ بْشُن قْلْ عَ مَ. عٍ نَشَ عَ يَ مَشِرِ، عٍ نُ عَ مَدِن، عٍ نُ قَ عَ قَلَ عَ بّ، «نَمِحْنمّحَ رَبَ! عَ قَلَ بَ، نَشَن عِ بْنبْشِ!» عَ تٌ سَ كْسِبِلِيٍ بّلّشّ، نٍيٍ قَن نَشَ عَ بْنبْ.
\s1 ثِيّرِ عَ يّتّ رَ سَنقٍ عِسَ مَ
\r مَتِيُ ٢٦‏؛٦٩ ٬ ٧٥، لُكِ ٢٢‏؛٥٥ ٬ ٦٢، يَيَ ١٨‏؛١٥ ٬ ٢٥
\p 
\v 66 ثِيّرِ نُ نَ تّتّ كُي تّمُي نَشّ لَنبَنيِ، سّرّشّدُبّ كُنتِفِيٍ شُنيِ شَ كٌنيِ فِنّ كٍرٍن نَشَ قَ.
\v 67 عَ تٌ ثِيّرِ تٌ، عَ عَ مَشَرَقٍ تّ رَ، عَ نَشَ عَ عِفبّ، عَ عَ قَلَ، «عِ تَن، وٌ نُن عِسَ نَسَرّتِكَ بِرِن نَن نُ عَ رَ.»
\v 68 ثِيّرِ نَشَ عَ مَتَندِ، عَ عَ قَلَ، «ﭑ مُ عَ كٌلٌن عِ نَ قٍقٍ قَلَقٍ!» عَ نَشَ مِنِ تّتّ كُي.
\v 69 كْنْ كٌنيِ فِنّ مَن تٌ عَ تٌ، عَ مَن نَشَ وْيّن قْلْ مِشِيٍ بّ نَشٍيٍ نُ نَ نَا، «عَ شَ مِشِ ندٍ نَن يَ.»
\v 70 ثِيّرِ مَن نَشَ عَ مَتَندِ. عَ مُ بُ، نَشٍيٍ نُ نَ نَا، عٍ مَن نَشَ عَ قَلَ ثِيّرِ بّ، «نْندِ نَ عَ رَ، عَ تَن مِشِ ندٍ نَن يَتِ عِ رَ، بَرِ مَ فَلِلٍكَ نَن عِ رَ.»
\v 71 كْنْ ثِيّرِ نَشَ سٌ عَ كَلِقٍ، عَ عَ قَلَ «عَلَ شَ ﭑ دَنكَ! وٌ يِ شّمّ نَشَن مَ قٍ قَلَقٍ، ﭑ تَن مُ عَ كٌلٌن قٍوٌ!»
\v 72 كٌنكٌرٍ نَشَ عَ رَتٍ كٍرٍن نَ عَ دّيَ قِرِن ندٍ. ثِيّرِ نَشَ رَتُ قَ عِسَ شَ وْيّنيِ مَ عَ بّ، «بٍيمَنُن كٌنكٌرٍ شَ عَ رَتٍ دّيَ قِرِن، عِ عِ يّتّ رَ سَنمَ نّ ﭑ مَ سَنمَيَ سَشَن.» نَ كُي، عَ نَشَ سٌ وَقٍ.
\c 15
\s1 عِسَ شَنِنقٍ ثِلَتِ شْن
\r مَتِيُ ٢٧‏؛١ ٬ ٢‏،١١ ٬ ٢٦، لُكِ ٢٣‏؛١ ٬ ٧‏،١٣ ٬ ٢٥، يَيَ ١٨‏؛٢٨ ٬ ١٩‏؛١٦
\p 
\v 1 كُيٍ تٌ عِبَ، سّرّشّدُبّ كُنتِفِيٍ، يُوِقِيٍ شَ قٌرِيٍ، سّرِيّ كَرَ مْشْيٍ، نُن يُوِقِيٍ شَ كِيتِسَ دْنشْي بِرِن، عٍ تٌ نُ بَرَ فّ عٍ شَ مَلَنيِ رَ، عٍ نَشَ عِسَ شِرِ، عٍ عَ شَنِن ثِلَتِ شْن.
\p 
\v 2 ثِلَتِ نَشَ عِسَ مَشْرِن، «عِ تَن نَن قِندِشِ يُوِقِيٍ شَ مَنفّ رَ؟» عِسَ نَشَ عَ يَابِ، «عِ تَن نَن عَ قَلَشِ.»
\v 3 سّرّشّدُبّ كُنتِفِيٍ نَشَ قَ عِسَ تْوحّفّ قٍ فبٍفبٍ مَ.
\v 4 ثِلَتِ مَن نَشَ عَ مَشْرِن، «عِ مُ عٍ يَابِمَ؟ عِ مُ عَ مّشِ عٍ قٍ نَشَن بِرِن سَقٍ عِ شُن مَ؟»
\v 5 كْنْ عِسَ مُ يَابِ فبّتّ يٌ قِ سْنْن. ثِلَتِ قَن نَشَ كَابَ نَ مَ.
\p 
\v 6 حّ يٌ حّ، سَلِ نَ عَ لِ، ثِلَتِ دَرِ قٍ نَن نُ عَ رَ، عَ شَ فٍيلِمَنِ كٍرٍن نَبّحِن حَمَ بّ، عٍ نَ وَ نَشَن يٌ شْن.
\v 7 نَ وَشَتِ، فٍرٍ سٌي ندٍيٍ نُ نَ فٍيلِ نَشٍيٍ نُ بَرَ كٍلِ مَنفَسَنيِ شِلِ مَ. حَشَسِ تٌ بِرَ، عٍ نُ بَرَ قَشّ تِ. شّمّ ندٍ نُ نَ عٍ يَ مَ نَشَن نُ شِلِ بَرَبَسِ.
\v 8 عَوَ حَمَ نَشَ قَ ثِلَتِ شْن، عٍ عَ مَشْرِن، عَ شَ عَ رَبَ عٍ بّ، عَلْ عَ دَرِشِ عَ رَ كِ نَشّ.
\v 9 ثِلَتِ نَشَ عٍ مَشْرِن، «وٌ وَ مَ ﭑ شَ يُوِقِيٍ شَ مَنفّ بّحِن وٌ بّ؟»
\v 10 ثِلَتِ نُ عَ كٌلٌن عَ سّرّشّدُبّ كُنتِفِيٍ نُ عِسَ سَشِ عَ بّلّشّ تْونّ نَن مَ.
\p 
\v 11 كْنْ سّرّشّدُبّ كُنتِفِيٍ نَشَ حَمَ كُي عِسٌ، عَلَكٌ ثِلَتِ شَ بَرَبَسِ نَن بّحِن عٍ بّ.
\v 12 ثِلَتِ مَن نَشَ عٍ مَشْرِن، «وٌ قَ وَ مَ عَ شْن مَ ﭑ شَ مُنسٍ رَبَ يِ شّمّ رَ، وٌ نَشَن مَ، عَ يُوِقِيٍ شَ مَنفّ؟»
\v 13 حَمَ مَن نَشَ سْنشْ، «عَ بَنبَن وُرِ مَفَلَنبُشِ مَ!»
\v 14 كْنْ ثِلَتِ نَشَ عٍ مَشْرِن، «مُنقٍ مَ؟ عَ قٍ حَاشِ مُندُن نَبَشِ؟» كْنْ عٍ تَن سْنشْي نَن تُن شُن مَسَمَ، عٍ نُ عَ قَلَ، «عَ بَنبَن وُرِ مَفَلَنبُشِ مَ!»
\v 15 نَ كُي، ثِلَتِ تٌ وَ حَمَ بْحّ رَقَنقٍ عٍ مَ، عَ نَشَ بَرَبَسِ رَبّحِن عٍ بّ. عَ نَشَ يَامَرِ قِ سْورِيٍ شَ عِسَ بْنبْ سّبّرّ رَ. نَ شَنبِ، عَ نَشَ عِسَ سٌ عٍ يِ عٍ شَ سَ عَ بَنبَن وُرِ مَفَلَنبُشِ مَ.
\s1 سْورِيٍ عِسَ مَيٍلٍقٍ
\r مَتِيُ ٢٧‏؛٢٧ ٬ ٣١، يَيَ ١٩‏؛٢ ٬ ٣
\p 
\v 16 سْورِيٍ نَشَ عِسَ شَنِن فٌمِنَ شْنيِ، نَ تّتّ كُي، عٍ عٍ بٌورٍ سْورِيٍ بِرِن شِلِ.
\v 17 عٍ نَشَ مَنفّ فُبَ فبٍيلِ رَفٌرٌ عِسَ مَ، عٍ قَ تُنبٍيٍ مَقِلِن، عٍ عٍ يَءِلَن مَنفّ كَتَنيِ مَنِيّ رَ. عٍ نَشَ نَ سَ عَ شُن مَ،
\v 18 عٍ نُ عَ شّيبُ، «عِ كّنَ، يُوِقِيٍ شَ مَنفّ.»
\v 19 عٍ نُ عَ شُنيِ بْنبْمَ وُرِ رَ، عٍ دّيٍ بْشُن عَ مَ، عٍ عٍ شِنبِ سِن، عٍ سُيِدِ عَ بّ.
\v 20 عٍ تٌ فّ عِسَ مَيٍلٍدٍ، عٍ نَشَ مَنفّ فُبَ رَتٍ عَ مَ، عٍ عَ فبٍ دُفِ رَفٌرٌ عَ مَ، عٍ قَ عَ رَ مِنِ عٍ شَ سَ عَ بَنبَن وُرِ مَفَلَنبُشِ مَ.
\s1 عِسَ بَنبَنقٍ وُرِ مَفَلَنبُشِ مَ
\r مَتِيُ ٢٧‏؛٣٢ ٬ ٤٤، لُكِ ٢٣‏؛٢٦ ٬ ٤٩، يَيَ ١٩‏؛١٦ ٬ ٢٤
\p 
\v 21 سِرٍنِكَ شّمّ ندٍ نُ نَ دَنفِقٍ كِرَ رَ، عَ كٍلِشِ دَاشَ. عَ نُ شِلِ سِمْن، عَلٍسَندِرٍ نُن رُقُ بَبَ. سْورِيٍ نَشَ عَ يَمَرِ، عَ شَ عِسَ شَ وُرِ مَفَلَنبُشِ شَنِن.
\v 22 عٍ نَشَ عِسَ شَنِن يِرٍ دّننَشَن شِلِ قَلَمَ فٌلٌفٌتَ، نَ نَن قَلَشِ عٍ شَ شُي، «شُنكٌنكٌتَ يِرٍ».
\v 23 عٍ نَشَ وّنِ سٌ عَ يِ، مِرِ سٍرِ سَشِ عَ شُن، كْنْ عَ مُ تِن عَ مِندٍ.
\v 24 عٍ نَشَ عَ مَبَنبَن وُرِ مَفَلَنبُشِ مَ، عٍ كَندَ بُن عَ شَ دُفِيٍ شَ قٍ رَ، عَلَكٌ عٍ شَ عَ كٌلٌن كَنكَن نَشَن سْتْمَ.
\v 25 عٍ نُ عَ بَنبَنقٍ تّمُي نَشّ، فّيسّفّ تَفِ نَن نُ عَ رَ.
\v 26 عٍ تٌ نُ وَ مَ بِرِن شَ عَ كٌلٌن عٍ عَ بَنبَنشِ قٍ نَشَن مَ، عٍ يِ سّبّلِ نَن فبَكُ عَ شُن مَ، «يُوِقِيٍ شَ مَنفّ.»
\p 
\v 27‏-28 عٍ نَشَ سُوتٍ مِشِ قِرِن قَن بَنبَن وُرِ مَفَلَنبُشِيٍ مَ عِسَ قّ مَ، كٍرٍن عَ يِرٍقَنيِ مَ، بٌورٍ عَ كْولَ مَ.
\v 29 مِشِيٍ نُ دَنفِمَ عِسَ كٌنبِ رَ، عٍ نُ عٍ شُنيِ لِنتَن عَ مَ، عٍ عَ قَلَ، «عٍٍ، عِ تَن نَشَن هْرْ مْبَنشِ رَبِرَ مَ، عِ مَن قَ عَ تِ شِ سَشَن بُن مَ،
\v 30 عِ يّتّ رَكِسِ! فٌرٌ وُرِ مَفَلَنبُشِ كْن نَ!»
\v 31 سّرّشّدُبّ كُنتِفِيٍ نُن سّرِيّ كَرَ مْشْيٍ قَن نُ عَ مَيٍلٍقٍ، عٍ نُ عَ قَلَ، «عَ بَرَ مِشِ فبّتّيٍ رَكِسِ، كْنْ عَ مُ نْمَ عَ يّتّ تَن نَكِسِدٍ.
\v 32 عِسِرَيِلَ مَنفّ شَ مُ عَ رَ، عَلَ شَ مِشِ سُفَندِشِ؟ عَ شَ فٌرٌ وُرِ مَفَلَنبُشِ كْن بٍ يَ، مُشُ شَ عَ تٌ، مُشُ شَ لَ عَ رَ.» نَشٍيٍ نُ بَنبَنشِ عَ قّ مَ، نٍيٍ قَن نُ عِسَ كٌنبِقٍ نّ.
\s1 عِسَ شَ قَشّ
\r مَتِيُ ٢٧‏؛٤٥ ٬ ٥٦، لُكِ ٢٣‏؛٤٤ ٬ ٤٩، يَيَ ١٩‏؛٢٨ ٬ ٣٠
\p 
\v 33 يَنيِ تَفِ تٌ عَ لِ، يَنيِ شَرٍ رَ، دِ مِ نَشَ سِن بْشِ بِرِن مَ لّيرِ سَشَن بُن مَ.
\v 34 نَ وَشَتِ مَ، عِسَ نَشَ فبٍلٍفبٍلٍ سّنبّ رَ، «عٍلٌيِ، عٍلٌيِ، لّمَ سَبَشَتَنِ؟» نَ نَن قَلَشِ عٍ شَ شُي، «ﭑ مَرِفِ عَلَ، ﭑ مَرِفِ عَلَ، عِ ﭑ نَبّحِنشِ مُنقٍ رَ؟»
\v 35 مِشِ نَشٍيٍ نُ نَ نَا، عٍ تٌ عَ شُي مّ، عٍ نَشَ عَ قَلَ، «وٌ عَ مَتٌ، عَ نَ عَننَبِ عٍلِيَ نَن شِلِقٍ!»
\v 36 مِشِ ندٍ نَشَ عَ فِ، عَ سَ دُنكٌبِ رَ سِن وّنِ شْنّ شْورَ، عَ عَ سٌ وُرِ دّ عِ، عَ قَ عَ تِ عِسَ بّ عَلَكٌ عَ شَ عَ مِن. عَ نَشَ عَ قَلَ، «وٌ عَ لُ، وٌن شَ عَ مَتٌ شَ عَننَبِ عٍلِيَ قَمَ عَ رَفٌرٌدٍ.»
\v 37 عِسَ نَشَ عَ شُي عِتٍ سّنبّ رَ، عَ قَ لَاشِرَ.
\p 
\v 38 نَ وَشَتِ، دُفِ شُنفبٍ نَشَن سِنفَنشِ هْرْ مْبَنشِ كُي، عَ نَشَ عِبْو قِرِن نَ، كٍلِ عَ قُفٍ هَن عَ لَابٍ.
\v 39 سْورِ مَنفّ نَشَن نُ تِشِ عِسَ يَ عِ، عَ تٌ عِسَ لَاشِرَ كِ تٌ، عَ نَشَ عَ قَلَ، «نْندِ نَن عَ رَ يَتِ، عَلَ شَ دِ نَن نُ يِ شّمّ رَ!»
\v 40 فِنّ ندٍيٍ قَن نُ نَ نَا، عٍ ندٍدِ مَكُيَشِ عِسَ يِرٍ رَ، عٍ يِ قٍ بِرِن مَتٌمَ. مَرِيَمَ مَفِدَلَكَ نُ نَ عٍ يَ مَ، عَ نُن سَلٌمٍ، عَ نُن مَرِيَمَ، يَكِ لَنمَدِ نُن يُسُقُ نفَ.
\v 41 عِسَ نُ نَ فَلِلٍ تّمُي نَشّ، يِ فِنّيٍ نَن نُ بِرَ مَ عَ قْشْ رَ، عٍ نُ وَلِيٍ رَبَ عَ بّ. فِنّ فبّتّ فبٍفبٍ قَن نُ نَ نَا نَشٍيٍ نُ بَرَ عِسَ مَتِ هَن دَرِ سَلَمُ.
\s1 عِسَ شَ مَرَفَتّ
\r مَتِيُ ٢٧‏؛٥٧ ٬ ٦١، لُكِ ٢٣‏؛٥٠ ٬ ٥٦، يَيَ ١٩‏؛٣٨ ٬ ٤٢
\p 
\v 42 نُنمَرٍ تٌ سٌ، بٍينُن مَلَبُ لْشْي شَ قْلْ،
\v 43 يُسُقُ عَرِ مَتٍكَ نَشَ سِفَ ثِلَتِ شْن. يُوِقِيٍ شَ كِيتِسَ بِنيٍ ندٍ نَن نُ عَ رَ نَشَن نُ عَلَ شَ مَنفّيَ نِينِ مَمّقٍ. لِمَنِيَ كُي، عَ نَشَ سَ ثِلَتِ مَشَندِ عِسَ قُرٍ مَ.
\v 44 ثِلَتِ نَشَ تّرّننَ عَ كٌلٌنقٍ رَ عَ عِسَ حَن بَرَ قَشَ. عَ نَشَ سْورِ مَنفّ شِلِ، عَ عَ مَشْرِن نَ قٍ مَ.
\v 45 سْورِ مَنفّ قَن تٌ عَ رَكٌلٌن عَ عِسَ بَرَ قَشَ، ثِلَتِ نَشَ عِسَ قُرٍ سٌ يُسُقُ يِ رَ.
\v 46 يُسُقُ تٌ كَسَنفٍ سَرَ، عَ نَشَ عِسَ قُرٍ رَفٌرٌ وُرِ مَفَلَنبُشِ كْن، عَ عَ كَسَنفٍ، عَ قَ عَ بّلّ فَبُرِ كُي، نَشَن نُ فٍشِ فّمّ كُي. نَ شَنبِ، عَ نَشَ فّمّ شُنفبٍ مَحِندِفِلِن، عَ عَ دْشْ فَبُرِ دّ مَ.
\v 47 مَرِيَمَ مَفِدَلَكَ نُن مَرِيَمَ يُسُقُ نفَ، عٍ نَشَ عَ تٌ عٍ عِسَ رَفَتَقٍ دّننَشّ.
\c 16
\s1 عِسَ كٍلِقٍ قَشّ مَ
\r مَتِيُ ٢٨‏؛١ ٬ ١٥، لُكِ ٢٤‏؛١ ٬ ١٢، يَيَ ٢٠‏؛١ ٬ ٢٠
\p 
\v 1 مَلَبُ لْشْي تٌ بَ عَ رَ، مَرِيَمَ مَفِدَلَكَ، مَرِيَمَ يَكِ نفَ، نُن سَلٌمٍ، عٍ نَشَ لَبُندّ تُرٍ سَرَ عَلَكٌ عٍ شَ عَ سَ عِسَ قُرٍ مَ.
\v 2 سَندٍ لْشْي، كُيٍ بَشِ عِبَدٍ، عٍ نَشَ كُرُن فَبُرِ يِرٍ رَ.
\v 3 كِرَ رَ، عٍ نَشَ عٍ بٌرٍ مَشْرِن، «ندٍ فّمّ بَمَ وٌن بّ فَبُرِ دّ مَ؟»
\p 
\v 4 فّمّ نَشَن نُ دْشْشِ فَبُرِ دّ مَ، عَ نُ شُنفبٌ كِ قَنيِ. كْنْ عٍ تٌ عٍ يَ رَ سِفَ، عٍ نَشَ عَ تٌ فّمّ بَرَ بَ نَا.
\v 5 عٍ تٌ سٌ فَبُرِ كُي، عٍ نَشَ سّفّتَلَ ندٍ تٌ عَ دْشْشِ يِرٍقَنيِ مَ، فُبَ قِيشّ رَفٌرٌشِ عَ مَ. عٍ نَشَ فَاشُ.
\v 6 عَ نَشَ عَ قَلَ عٍ بّ، «وٌ نَشَ فَاشُ. وٌ نَ عِسَ نَسَرّتِكَ نَن قٍنقٍ، عٍ نَشَن بَنبَن وُرِ مَفَلَنبُشِ مَ. عَ مُ بٍ، عَ بَرَ كٍلِ قَشّ مَ. وٌ عَ مَتٌ، عٍ نُ عَ سَشِ مّننِ نّ.
\v 7 كْنْ وٌ سِفَ، وٌ سَ عَ قَلَ عَ قْشِرَبِرّيٍ بّ، عَ نُن ثِيّرِ، عَ عِسَ نَ سِفَقٍ وٌ يَ رَ فَلِلٍ. وٌ عَ تٌمَ مّننِ نّ عَلْ عَ عَ مَسٍن وٌ بّ كِ نَشّ.»
\v 8 فِنّيٍ نَشَ مِنِ فَبُرِ كُي، عٍ سِفَ عٍ فِ رَ، عٍ كَابَشِ قٌ عٍ سّرّنمَ. عٍ مُ سٍسٍ قَلَ مِشِ يٌ بّ، بَرِ مَ عٍ نُ بَرَ فّ فَاشُدٍ.
\s1 عِسَ مِنِقٍ مِشِيٍ مَ عَ نُن عَ شَ تٍ كٌورٍ
\r مَتِيُ ٢٨‏؛٩ ٬ ١٠، يَيَ ٢٠‏؛١١ ٬ ١٨
\p 
\v 9 عِسَ تٌ كٍلِ قَشّ مَ سَندٍ لْشْي كُيٍ عِبَ، عَ مِنِ مَرِيَمَ مَفِدَلَكَ نَن سِنفٍ مَ، عَ حِننّ سٌلٌقٍرٍ كٍرِ نَشَن قْشْ رَ.
\v 10 مَرِيَمَ نَشَ سِفَ عِسَ شِبَارُ قَلَدٍ مِشِيٍ بّ عٍ نُن نَشٍيٍ نُ عَ رَ. عٍ بِرِن نُ سُننُنشِ، عٍ مَن نُ وَقٍ عِسَ شَ حْنقٍ مَ.
\v 11 عٍ تٌ عَ مّ عَ عَ عِسَ حِحّ تٌ نّ، عٍ مُ لَ عَ رَ.
\r لُكِ ٢٤‏؛١٣ ٬ ٣٥
\p 
\v 12 نَ قٍيٍ دَنفِ شَنبِ، عِسَ نَشَ مِنِ كّحَ فبّتّ رَ عَ قْشِرَبِرّ مِشِ قِرِن مَ، عٍ تٌ نُ نَ دَاشَ ندٍ كِرَ شْن.
\v 13 نٍيٍ قَن نَشَ فبِلٍن يِ قٍ تَفِ رَبَ رَ بٌورٍيٍ بّ، كْنْ عٍ مُ لَ نٍيٍ قَن شُي رَ.
\v 14 نَ شَنبِ، عِسَ نَشَ مِنِ عَ قْشِرَبِرّ قُ نُن كٍرٍن مَ، عٍ نُ عٍ دّفٍقٍ تٍيبِلِ رَ تّمُي نَشّ. عِسَ نَشَ وْيّن عٍ مَ عٍ شَ دَنشَنِيَتَرٍحَ نُن شَشِلِ شْرْشْيَ شَ قٍ رَ، بَرِ مَ عٍ مُ نُ لَشِ مِشِيٍ رَ نَشٍيٍ عِسَ تٌ، عَ تٌ نُ بَرَ كٍلِ قَشّ مَ.
\r مَتِيُ ٢٨‏؛١٦ ٬ ٢٠، لُكِ ٢٤‏؛٤٤ ٬ ٥٣
\p 
\v 15 عِسَ نَشَ عَ مَسٍن عٍ بّ، «وٌ سِفَ دُنِحَ بِرِن كُي، وٌ دَالِ بِرِن كَوَندِ شِبَارُ قَنيِ رَ.
\v 16 نَشَن نَ دَنشَنِيَ ﭑ مَ، عَ شُنشَ يٍ شْورَ، نَ كَنيِ كِسِمَ نّ. كْنْ شَ نَشَن مُ دَنشَنِيَ ﭑ مَ، نَ كَنيِ بْنْمَ نّ.
\v 17 نَشٍيٍ نَ دَنشَنِيَ ﭑ مَ عٍ يِ كَابَنَكٌ قٍيٍ رَبَمَ نّ ﭑ شِلِ رَ. عٍ قَمَ نّ حِننّيٍ كٍرِدٍ مِشِيٍ قْشْ رَ، عٍ شُي نّينّيٍ قَلَمَ نّ،
\v 18 عٍ بْشِمَسٍيٍ سُشُمَ نّ عٍ بّلّشّ رَ عٍ مُ عٍ شِن، عٍ سٍقِ مِنمَ نّ سٍ مُ عٍ تٌ، عٍ عٍ بّلّشّ سَمَ نّ قُرٍ مَيٍ مَ، قُرٍ مَيٍ يَلَن.»
\p 
\v 19 نَ كُي، مَرِفِ عِسَ تٌ فّ وْيّندٍ عٍ بّ، عَ نَشَ تٍ كٌورٍ مَ. عَ نَشَ سَ عَ مَفٌرٌ عَلَ يِرٍقَنيِ مَ.
\v 20 عٍ تَن نَشَ سِفَ كَوَندِ تِدٍ يِرٍ بِرِن، عٍ نُن مَرِفِ نَشَ وَلِ. مَرِفِ نَشَ قّيرّ قِ عٍ مَ، عٍ شَ تْنشُمَ مَكَابَشِيٍ رَبَ، مِشِيٍ شَ لَ عٍ شَ كَوَندِ رَ.
