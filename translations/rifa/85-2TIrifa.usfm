\id 2TI
\h 2 ثِيمُوثِييُو 
\toc1 2 ثِيمُوثِييُو 
\toc2 2 ثِيمُوثِييُو 
\toc3 2 تِيم. 
\mt1 2 ثِيمُوثِييُو  
\c 1
\s1 أَسدْجمْ غَارْ ؤُمزْوَارُو ذ ؤُسجّعْ  
\m
\v 1 بُولُوسْ، رَّاسُولْ ن يَاسُوع لْمَاسِيحْ عْلَاحْسَابْ ڒْخَاضَارْ ن أَربِّي، عْلَاحْسَابْ لْوَاعْذْ ن ثُوذَارْثْ إِ \add ذِينْ\add* إِدْجَانْ ذِي يَاسُوع لْمَاسِيحْ. \f ◼ \fr 1:‏1 \ft \+bd ’رَّاسُولْ‘\+bd* - نِيغْ ’أَمَازَانْ‘.\f*   
\m
\v 2 إِ ثِيمُوثِييُو، مِّي إِعِيزّنْ: أَرْضَا ذ أَرّحْمثْ ذ ڒهْنَا زِي أَربِّي، بَابَاثْنغْ، ؤُ زِي يَاسُوع لْمَاسِيحْ، سِيذِيثْنغْ. \x ◘ \xo 1:‏2 \xt ڭال. 1‏:‏3؛ 1 تِيم. 1‏:‏2؛ 1 بُط. 1‏:‏2. \x*   
\b  
\m  
\s1 أَشجّعْ إِ ثِيمُوثِييُو  
\m
\v 3 نشّْ تّْقَاذِيغْ أَربِّي ونِّي ؤُمِيعبْذغْ أَمْ ڒجْذُوذْ إِنُو س ثْنفْسشْثْ ثزْذڭْ، \add أَمْ\add* تِّيذَارغْ شكْ بْڒَا قطُّو ذِي ثْژَادْجِيثِينْ إِنُو أَسّْ ذ دْجِيڒثْ. \x ◘ \xo 1:‏3 \xt ڒخ. 22‏:‏3؛ رُوم. 1‏:‏9؛ 1 تس. 1‏:‏2؛ 3‏:‏10. \x*  
\v 4 وحّْشغْ أَذْ شكْ ژَترغْ، خْمِي تّْفكَّارغْ ذڭْ إِمطَّاونْ نّشْ ؤُ تّْوَاشُّورغْ س ڒفْرَاحثْ،  
\v 5 ؤُمِي تِّيذَارغْ ذِي لْ-إِيمَانْ نّشْ بْڒَا نِّيفَاقْ، \add لْ-إِيمَانْ\add* نِّي ثُوغَا إِزدّْغنْ أَمزْوَارْ ذِي حنَّاشْ لُووِيسْ ؤُ ذڭْ يمَّاشْ ؤُنِيكِي، ؤُشَا، أَقَا سّْنغْ نِيشَانْ بلِّي إِزْذغْ ذَايكْ عَاوذْ.  
\v 6 س ؤُينِّي سّْعقْڒغْ شكْ أَذْ ثسّكَّارذْ ثَاوْهِيبْثْ ن أَربِّي ثنِّي ذَايكْ س \add وبْرِيذْ ن\add* وسْرُوسِي ن إِفَاسّنْ إِنُو \add خَاكْ\add*. \x ◘ \xo 1:‏6 \xt ڒخ. 6‏:‏6؛ 8‏:‏17؛ 13‏:‏3؛ 19‏:‏6، 7؛ 1 تِيم. 4‏:‏14؛ 5‏:‏22. \x*   
\m
\v 7 مِينْزِي أَربِّي وَارْ ذ أَنغْ إِوْشِي أَرُّوحْ ن ڒْعُورّثْ، مَاشَا \add أَرُّوحْ\add* ن جّهْذْ ذ ثَايْرِي ذ ؤُثبّثْ. \x ◘ \xo 1:‏7 \xt رُوم. 8‏:‏15. \x*  
\v 8 س ؤُيَا وَارْ تّْسضْحِي شَا حِيمَا أَذْ ثوْشذْ شّْهَاذثْ خْ سِيذِيثْنغْ، ؤُ وَارْ تّْسضْحِي زَّايِي نشّْ، ونِّي ذ أَمحْبُوسْ نّسْ، مَاشَا كْسِيمْ \add مَارَّا\add* ڒْغَارْ ذِي طّْوعْ ن لْ-إِنْجِيلْ س جّهْذْ ن أَربِّي، \x ◘ \xo 1:‏8 \xt ڒخ. 21‏:‏33؛ رُوم.1‏:‏16؛ أَفا. 3‏:‏1؛ 4‏:‏1؛ كُول. 4‏:‏18؛ فلمن. 1، 9، 13. \x*  
\v 9 ونِّي أَقَا إِوْشَا أَنغْ ثُوذَارْثْ ؤُشَا إِڒَاغَا أَنغْ-د س ثْڒَاغِيثْ إِقدّْسنْ، وَارْ إِدْجِي عْلَاحْسَابْ ڒخْذَايمْ نّغْ، مَاشَا عْلَاحْسَابْ ڒْخَاضَارْ نّسْ ذ أَرْضَا نِّي إِ ذ أَنغْ إِمّوْشنْ ذِي يَاسُوع لْمَاسِيحْ قْبڒْ ڒْوقْثْ ن زّْمَانَاثْ. \x ◘ \xo 1:‏9 \xt أَفا. 1‏:‏3؛ ثِيث. 3‏:‏4، 5، 6. \x*  
\v 10 \add أَقَا أَرْضَا-يَا\add* إِتّْوَاسّضْهَارْ ڒخُّو س ؤُخشِّي ن ونِّي ذ أَنغْ إِتِّيشنْ ثُوذَارْثْ، يَاسُوع لْمَاسِيحْ، ونِّي ثُوغَا إِبضْڒنْ ڒْموْثْ ؤُشَا إِسّضْهَارْ ثُوذَارْثْ وَارْ إِفنِّينْ س لْ-إِنْجِيلْ. \x ◘ \xo 1:‏10 \xt إِشا. 25‏:‏8؛ رُوم. 16‏:‏25؛ أَفا. 1‏:‏9؛ 3‏:‏9؛ كُول. 1‏:‏26؛ ثِيث. 1‏:‏2؛ عبر. 2‏:‏14؛ 1 بُط. 1‏:‏20. \x*  
\v 11 زَّايسْ تّْوَاسّْڭعّْذغْ نشّْ ذ أَمْبَارّحْ ذ رَّاسُولْ ذ ؤُمْسڒْمَاذْ ن ڒڭْنُوسْ. \x ◘ \xo 1:‏11 \xt ڒخ. 9‏:‏15؛ 13‏:‏2؛ 22‏:‏21؛ ڭال. 1‏:‏15؛ 2‏:‏8؛ أَفا. 3‏:‏8؛ 1 تِيم. 2‏:‏7. \x*  
\v 12 خْ سِّيبّثْ-أَ عَاوذْ كْسِيغْ أَرْمحْ ؤُ وَارْ تّْسضْحِيغْ شَا، مِينْزِي سّْنغْ مَانْ ونْ إِ زِي تَّامْنغْ ؤُشَا أَقَا تّْوَاسّْقنْعغْ بلِّي نتَّا أَقَا غَارسْ صُّولْطَا، مَاحنْذْ أَذْ إِحْضَا إِ نشّْ أَضْمَانْ إِنُو أَڒْ أَسّْ نِّي.  
\v 13 أجّْ أَذْ غَاركْ إِقِّيمْ لْمِيثَالْ ن وَاوَاڒنْ إِصحّنْ إِ زَّايِي ثسْڒِيذْ س لْ-إِيمَانْ ذ ثَايْرِي إِ إِدْجَانْ ذِي يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏13 \xt 2 تِيم. 3‏:‏14. \x*  
\v 14 حْضَا أَضْمَانْ أَصبْحَانْ \add إِ ذ أَشْ إِتّْوَاوكّْڒنْ\add* س أَرُّوحْ إِقدّْسنْ نِّي ذَايْنغْ إِزدّْغنْ.   
\m
\v 15 أَقَا ثسّْنذْ بلِّي مَارَّا إِنِّي إِدْجَانْ ذِي أَسِييَا جِّينْ أَيِي، زَّايْسنْ فِيخِيلُوسْ ذ هِيرْمُوخِينِيسْ. \x ◘ \xo 1:‏15 \xt ڒخ. 19‏:‏10. \x*  
\v 16 أَذْ يَارْزفْ سِيذِيثْنغْ س أَرّحْمثْ ذِي ثَادَّارْثْ ن ؤُنِيسِيفُورُوسْ، مِينْزِي ثُوغَا إِسَّاريّحْ أَيِي أَطَّاسْ ن ثْوَاڒَاوِينْ ؤُشَا وَارْ إِسضْحِي شَا زِي سّْنَاسڒْ ن ثْمحْبَاسْثْ إِنُو. \x ◘ \xo 1:‏16 \xt 2 تِيم. 4‏:‏19. \x*  
\v 17 مَاغَارْ ڒَامِي د-يُوسَا غَارْ رُومَا، ثُوغَا يَارزُّو خَافِي س شْضَارثْ أَطَّاسْ ؤُشَا يُوفَا أَيِي.  
\v 18 أَذْ أَسْ إِوْشْ سِيذِيثْنغْ، أَقَا أَذْ يَافْ أَرّحْمثْ غَارْ سِيذِيثْنغْ ذڭْ وَاسّْ نِّي. ؤُشَا مشْحَاڒْ إِسخَّارْ أَيِي ذِي أَفَاسُوسْ، شكْ ثسّْنذْ كْثَارْ.   
\b  
\b  
\m  
\c 2
\s1 أَعسْكَارِي إِشْنَانْ ن يَاسُوع لْمَاسِيحْ  
\m
\v 1 شكْ خنِّي، \add أَ\add* مِّي، إِڒِي ثْمحّْضذْ ذِي أَرْضَا نِّي إِدْجَانْ ذِي يَاسُوع لْمَاسِيحْ،  
\v 2 ؤُ مِينْ زَّايِي ثسْڒِيذْ زَّاثْ إِ وَاطَّاسْ ن ڒشْهُوذْ، وكّڒْ إِ-ث إِ إِوْذَانْ إِمْثِيقَّانْ، إِنِّي إِزمَّارنْ أَذْ سّْڒمْذنْ عَاوذْ إِنّغْنِي. \x ◘ \xo 2:‏2 \xt ثِيث. 1‏:‏5. \x*   
\m
\v 3 أَرْبُو ڒْغَارْ أَكْ-ذ إِنّغْنِي أَمْ يِيجّْ ن ؤُعسْكَارِي إِشْنَانْ ن يَاسُوع لْمَاسِيحْ.  
\v 4 وَارْ ذِينْ ؤُڒَا ذ إِجّْ ن ؤُعسْكَارِي إِڒهَّا أَكْ-ذ ڒسْوَاقْ ن ثُوذَارْثْ. إِتّْخصَّا أَسْ أَذْ يَارْضَا ونِّي ث إِڭِّينْ ذ أَعسْكَارِي \add وَاهَا\add*. \x ◘ \xo 2:‏4 \xt 1 كُور. 9‏:‏25. \x*  
\v 5 ؤُشَا \add عَاوذْ\add* ونِّي إِتّمْحِيزْوَارنْ أَمْ بُو-ؤُمْحِيزْوَارْ، وَارْ ذ أَسْ تِّيشنْ تَّاجْ مَاڒَا وَارْ إِمّْنِيغْ عْلَاحْسَابْ ڒْقَانُونْ.  
\v 6 أَفدْجَاحْ إِ إِتّڭّنْ ڒْخذْمثْ إِقسْحنْ، إِتّْخصَّا أَسْ أَذْ إِكْسِي ذ أَمزْوَارْ زِي ڒْغِيدْجثْ. \x ◘ \xo 2:‏6 \xt 1 كُور. 9‏:‏10. \x*   
\m
\v 7 خَارّصْ ذِي مِينْ ذ أَشْ قَّارغْ. أَذْ أَشْ إِوْشْ سِيذِيثْنغْ ڒفْهَامثْ ذِي كُوڒْشِي.  
\v 8 عْقڒْ \add ڒبْذَا\add* بلِّي يَاسُوع لْمَاسِيحْ، ونِّي د-إِتّْوَاسّْنكَّارنْ زِي ثَادَّارْثْ ن إِمتِّيننْ، أَقَا-ث زِي زَّارِيعثْ ن ذَاوُوذْ عْلَاحْسَابْ لْ-إِنْجِيلْ إِنُو،  
\v 9 \add ڒخْبَارْ أَصبْحَانْ\add* نِّي خفْ كْسِيغْ ثُوعفّْنَا، عَاذْ سّْنَاسڒْ أَخْمِي \add دْجِيغْ نشّْ ذ\add* إِجّْ ن ؤُعفَّانْ! مَاشَا أَوَاڒْ ن أَربِّي وَارْ إِزمَّارْ أَذْ إِتّْوَاقّنْ س سّْنَاسڒْ. \x ◘ \xo 2:‏9 \xt أَفا. 3‏:‏1، 13؛ 4‏:‏1؛ فِيل. 1‏:‏7؛ كُول. 1‏:‏24؛ 4‏:‏3، 18؛ 2 تِيم. 1‏:‏8. \x*  
\v 10 س ؤُينِّي تّْحمْڒغْ مَارَّا ذِي طّْوعْ ن يِينِّي إِتّْوَافَارْزنْ، حِيمَا أَذْ أَفنْ ؤُڒَا ذ نِيثْنِي ثُوذَارْثْ ذِي يَاسُوع لْمَاسِيحْ أَكْ-ذ ؤُعُودْجِي إِتّْذُومَانْ.  
\v 11 وَا ذ أَوَاڒْ ذَايسْ ڒَامَانْ، مِينْزِي مَاڒَا نمُّوثْ أَكِيذسْ، أَذْ كِيسْ ندَّارْ عَاوذْ، \x ◘ \xo 2:‏11 \xt رُوم. 6‏:‏8. \x*  
\v 12 ؤُ مَاڒَا نْصبَّارْ، أَذْ كِيسْ نحْكمْ عَاوذْ \add أَمْ إِجدْجِيذنْ\add*، مَاشَا مَاڒَا ننْكَارْ إِ-ث، نتَّا أَذْ أَنغْ إِنْكَارْ عَاوذْ. \x ◘ \xo 2:‏12 \xt مت. 10‏:‏33؛ مك. 8‏:‏38؛ لك. 9‏:‏26؛ 12‏:‏9؛ رُوم. 8‏:‏17؛ 2 كُور. 4‏:‏10؛ فِيل. 3‏:‏10؛ 1 بُط. 4‏:‏13. \x*  
\v 13 مَاڒَا وَارْ ذَايسْ نتِّيقّْ، أَقَا نتَّا إِتّْغِيمَا ذ أَمْثِيقِّي، مِينْزِي وَارْ إِزمَّارْ أَذْ إِنْكَارْ إِخفْ نّسْ. \x ◘ \xo 2:‏13 \xt ڒخْڒ. 23‏:‏19؛ رُوم. 3‏:‏3؛ 9‏:‏6. \x*   
\b  
\m
\v 14 سعْقڒْ أَسنْ مَانْ أَيَا، عْڒمْ أَسنْ زَّاثْ إِ سِيذِيثْنغْ مَاحنْذْ وَارْ تّْمنْغِينْ شَا س وَاوَاڒنْ وَارْ إِنفّْعنْ، إِنِّي د غَا يَاوْينْ أَردّدْجْ خْ يِينِّي إِتّْصنَّاثنْ.  
\v 15 حْضَا إِخفْ نّشْ، مَاحنْذْ أَذْ ثَارّذْ إِخفْ نّشْ أَمْ ثْكمْڒذْ زَّاثْ إِ أَربِّي، أَمْ ؤُخدَّامْ نِّي وَارْ غَارسْ مِينْ زِي غَا إِسضْحَا، ونِّي إِتّْبَارّْحنْ نِيشَانْ أَوَاڒْ ن ثِيذتّْ.   
\m
\v 16 أَڭّْوجْ خْ وَاوَاڒنْ إِخْوَانْ إِ وَارْ إِنفّْعنْ، مِينْزِي \add نِيثْنِي\add* أَذْ أَرْنِينْ أَطَّاسْ ذِي ڒقْجَاحثْ ن يِينِّي إِشغْڒنْ إِخفْ نْسنْ أَكْ-ذ مَانْ أَيَا. \x ◘ \xo 2:‏16 \xt 1 تِيم. 1‏:‏4؛ 4‏:‏7؛ 6‏:‏20؛ ثِيث. 1‏:‏14؛ 3‏:‏9. \x*  
\v 17 أَوَاڒْ نْسنْ أَذْ إِتّْوَاغِييّزْ أَمْ ؤُخْسَاسْ. أَقَا هِيمِينِييُوسْ ذ إِجّنْ زَّايْسنْ ؤُ فِيلِيثُوسْ ذ إِجّنْ نّغْنِي.  
\v 18 نِيثْنِي فّْغنْ زڭْ وبْرِيذْ ن ثِيذتّْ، قَّارنْ بلِّي ثَانُوكْرَا أَقَا ثمْسَارْ، ؤُشَا قڒْبنْ لْ-إِيمَانْ ن شَا.   
\m
\v 19 مَاشَا ذْسَاسْ ن أَربِّي إِبدّْ نِيشَانْ ؤُشَا وَا ذ أَشمِّيعْ نّسْ: ”سِيذِي إِسّنْ إِنِّي إِدْجَانْ نّسْ!“، ؤُشَا“ ’أجّْ مَارَّا إِنِّي إِتّْڒَاغَانْ خْ سِيذِي أَذْ أَڭّْوجنْ خْ ڒْمُوعْصِييّثْ.“ \x ◘ \xo 2:‏19 \xt ڒخْڒ. 16‏:‏5؛ إِشا. 52‏:‏11؛ يُوح. 10‏:‏14. \x*   
\m
\v 20 مَاشَا ذِي ثَادَّارْثْ ثَامقّْرَانْثْ وَارْ ذَايسْ ڒقْشُوعْ ن وُورغْ ذ نُّوقَارْثْ وَاهَا، مَاشَا عَاوذْ ن ؤُكشُّوضْ ذ ثْڒَاخْثْ، شَا \add زَّايْسنْ\add* ن شَّانْ ؤُ شَا ن ؤُبهْذڒْ. \x ◘ \xo 2:‏20 \xt رُوم. 9‏:‏21. \x*  
\v 21 خنِّي مَاڒَا إِسِّيزْذڭْ حذْ إِخفْ نّسْ زِي دّڭَّا، أَذْ يِيڒِي ذ إِشْثْ ن ڒْقشْعثْ ن شَّانْ، ثتّْوَاقدّسْ إِ ثدْجَا ؤُشَا ثذْوڒْ ثْنفّعْ إِ سِيذسْ، أَقَا ثتّْوَاسّوْجذْ إِ مَارَّا ڒخْذَايمْ إِصبْحنْ.   
\m
\v 22 أَرْوڒْ زِي مَارَّا نّشْوَاثْ ن ثمْژِي ؤُشَا أَرْذفْ ثَاسڭْذَا ذ لْ-إِيمَانْ ذ ثَايْرِي ذ ڒهْنَا أَكْ-ذ يِينِّي إِتّْڒَاغَانْ خْ سِيذِيثْنغْ زڭْ وُوڒْ إِزْذِيڭْ. \x ◘ \xo 2:‏22 \xt 1 تِيم. 6‏:‏11. \x*  
\v 23 بعّذْ خْ إِمْحَارْوَاضنْ إِبُوهَاڒِييّنْ إِ وَارْ إِدْجِينْ إِ ڒبْنِي، مَاغَارْ ثسّْنذْ أَقَا ندّْهنْ غَارْ إِمْشُوبَّاشْ. \x ◘ \xo 2:‏23 \xt 1 تِيم. 1‏:‏4؛ 6‏:‏4؛ ثِيث. 3‏:‏9. \x*  
\v 24 وَارْ إِشُووَّارْ إِ ؤُمْسخَّارْ ن سِيذِيثْنغْ أَذْ إِمْشُوبّشْ، مَاشَا إِشُووَّارْ أَسْ أَذْ يُويُورْ س ثمْهِينْثْ أَكْ-ذ مَارَّا، إِسّنْ أَذْ إِسّڒْمذْ، أَقَا غَارسْ تَّاسِيعْ ن ڒْخَاضَارْ، \x ◘ \xo 2:‏24 \xt 1 تِيم. 3‏:‏2. \x*  
\v 25 مَاحنْذْ أَذْ إِسّڒْمذْ س ثمْهِينْثْ إِنِّي ث إِتّْعكَّاسنْ. أَذْ ثَاغْ أَربِّي أَذْ أَسنْ إِوْشْ أَذْ ثُوبنْ أَذْ سّْننْ ثِيذتّْ، \x ◘ \xo 2:‏25 \xt ڭال. 6‏:‏1. \x*  
\v 26 ؤُشَا أَذْ د أَسنْ-يَارّْ ڒْبَاڒْ، أَذْ نْفكّنْ زِي ڒْفخْ ن شِّيطَانْ، ونِّي إِ-ثنْ إِحبّْسنْ إِ ثِيزِي نّسْ.   
\b  
\b  
\m  
\c 3
\s1 ؤُسَّانْ إِنڭُّورَا  
\m
\v 1 مَاشَا سّنْ دّڭَّا، أَقَا ذڭْ وُوسَّانْ إِنڭُّورَا أَذْ ذِينْ إِڒِينْ ڒْمِيجَاڒَاثْ ن ڒْوقْثْ إِوْعَارنْ. \x ◘ \xo 3:‏1 \xt 1 تِيم. 4‏:‏1؛ 2 بُط. 2‏:‏3؛ يَاه. 18. \x*  
\v 2 مِينْزِي إِوْذَانْ أَذْ خْسنْ إِخفْ نْسنْ، أَذْ إِڒِينْ ذ إِشطَّارنْ، ذ أَيْثْ ن بُو-نّْفَاخثْ ذ إِمْعفَّارنْ ذ إِمْشقَّافنْ، وَارْ تّطِّيعِينْ شَا إِ إِوْذَانْ \add نْسنْ\add*، أَذْ نْضَارنْ أَرْضَا، أَذْ إِڒِينْ ذ إِعفَّاننْ،  
\v 3 أَذْ شقّْفنْ، أَذْ مژْڒنْ ڒبْذَا ذِي \add عْڒَامْ كُوڒْ\add* نّشْوَاثْ، أَذْ إِڒِينْ قسْحنْ، شَارّْهنْ مِينْ إِصبْحنْ،  
\v 4 أَذْ إِڒِينْ ذ إِغدَّارنْ ذ إِفنْثْرُوسنْ، ذَايْسنْ نّْفَاخثْ، أَذْ خْسنْ نّشْوَاثْ كْثَارْ زِي أَربِّي.  
\v 5 نِيثْنِي غَارْسنْ ؤُذمْ ن ثِيڭّْوُوذِي زِي أَربِّي، \add مَاشَا\add* بدّنْ أَڭّْوجنْ خْ جّهْذْ نّسْ. إِنِّي إِدْجَانْ أَمنِّي، إِتّْخصَّا أَذْ ثنْ ثسِّيڭّْوجذْ خَاكْ. \x ◘ \xo 3:‏5 \xt مت. 18‏:‏17؛ رُوم. 16‏:‏17؛ 2 تس. 3‏:‏6؛ ثِيث. 3‏:‏10؛ 2 يُوح. 10. \x*   
\m
\v 6 زَّايْسنْ إِنِّي إِتّْحَامَانْ ثُوذْرِينْ ؤُشَا نِيثْنِي سُّوسُومنْ ثِيمْغَارِينْ ثِينِّي يَاربُّونْ دّْنُوبْ، تّْوَاعَارّنْثْ س ؤُبَارُّو ن نّشْوَاثْ، \x ◘ \xo 3:‏6 \xt مت. 23‏:‏14؛ ثِيث. 1‏:‏11. \x*  
\v 7 ثِينِّي خْسنْثْ أَذْ ڒمْذنْثْ ڒبْذَا.عمَّارْصْ أَذْ أَوْضنْ \add دَّابْ ن يرْيَازنْ نِّي\add* غَارْ ثُوسّْنَا ن ثِيذتّْ، \x ◘ \xo 3:‏7 \xt 1 تِيم. 5‏:‏11‏-‏13\x*  
\v 8 مَاشَا أَمْ مَامّشْ ثُوغَا يَانِّيسْ ذ يَامْبْرِيسْ تّمْعَاڒَانْ أَكْ-ذ مُوسَا، أَمُّو عَاوذْ إِنَا تّمْعَاڒَانْ أَكْ-ذ ثِيذتّْ: أَقَا-ثنْ ذ إِوْذَانْ، إِنِّي إِتّْوَاغشّْ ڒعْقڒْ نْسنْ، نِيثْنِي تّْوَامّنْضَارنْ زِي لْ-إِيمَانْ. \x ◘ \xo 3:‏8 \xt ؤُف. 7‏:‏11. \x*  
\v 9 مَاشَا وَارْ تّْرِيحنْ شَا كْثَارْ غَارْ زَّاثْ، مِينْزِي أَفْغُوڒْ نْسنْ إِبَانْ-د إِ مَارَّا، أَمْ مَامّشْ ثُوغَا إِتّْوَاسّنْ ؤُڒَا ذ \add أَفْغُوڒْ\add* ن يِينِّي \add س ثْنَاينْ\add*.   
\b  
\m  
\s1 أَمذْيَا ن بُولُوسْ ذ وَاوَاڒْ ن أَربِّي  
\m
\v 10 مَاشَا شكْ ثْسِيغِيذْ أَكِيذِي ذڭْ ؤُسڒْمذْ إِنُو، أَمْ مَامّشْ ڭُّورغْ، ثْسِيغِيذْ أَكِيذِي ذِي لْغَارَاضْ \add إِنُو\add*، لْ-إِيمَانْ إِنُو، تَّاسِيعْ ن ڒْخَاضَارْ إِنُو، ثَايْرِي إِنُو ذ صّْبَارْ إِنُو،  
\v 11 ذِي ڒحْصَارَاثْ ذ ؤُودّبْ إِنُو. ثسّْنذْ ثِيمسْڒَايِينْ إِ خَافِي إِكِّينْ ذِي أَنْثِييُوخِييَا ذ إِكُونِييَا ذ لِيسْثْرَا، مَانْ مَارْكَاثْ ن ؤُذَارّشْ إِ كْسِيغْ، ؤُشَا أَقَا سِيذِي إِسّنْجمْ أَيِي زَّايْسنْثْ مَارَّا. \x ◘ \xo 3:‏11 \xt إِزهد. 34‏:‏20؛ ڒخ. 13‏:‏50؛ 14‏:‏19؛ 2 كُور. 1‏:‏10. \x*  
\v 12 مَارَّا إِنِّي إِخْسنْ أَذْ دَّارنْ س ثِيڭّْوُوذِي زِي أَربِّي ذِي يَاسُوع لْمَاسِيحْ، أَذْ تّْوَاذَارّْشنْ. \x ◘ \xo 3:‏12 \xt مت. 16‏:‏24؛ لك. 24‏:‏26؛ يُوح. 17‏:‏14؛ ڒخ. 14‏:‏22؛ 1 تس. 3‏:‏3. \x*  
\v 13 مَاشَا إِوْذَانْ إِعفَّاننْ ذ إِشمَّاثنْ أَذْ أَرْنِينْ ذِي ثُوعفّْنَا نْسنْ، أَذْ غْوَانْ ؤُشَا أَذْ تّْوَاغْوَانْ.   
\m
\v 14 مَاشَا شكْ، قِّيمْ ذِي مِينْ ثُوغَا ثْڒمْذذْ ؤُ ذِي مِينْ ثتّْوَاسّْقنْعذْ، مَاغَارْ ثسّْنذْ مَانْ ونْ إِ زِي ث ثْڒمْذذْ،  
\v 15 ؤُ أَقَا زِي ثمْژِي نّشْ ثتّْوَاسّْڒمْذذْ ذِي ثِيرَا إِقدّْسنْ، ثِينِّي زمَّارنْثْ أَذْ شكْ أَرّنْثْ ذ أَمِيغِيسْ أَڒْ \add غَا ثطّْفذْ\add* ثُوذَارْثْ س لْ-إِيمَانْ ن يَاسُوع لْمَاسِيحْ.  
\v 16 كُوڒْ ثِيرَا إِ يُورَانْ س أَرُّوحْ \add إِقدّْسنْ\add*، أَقَا إِنفّعْ عَاوذْ إِ ؤُسڒْمذْ، إِ ؤُصحِّي، إِ وعْذَاڒْ ؤُشَا إِ تَّارْبِييّثْ ذِي ثْسڭْذَا، \x ◘ \xo 3:‏16 \xt 2 بُط. 1‏:‏20، 21. \x*  
\v 17 حِيمَا بْنَاذمْ ن أَربِّي أَذْ يِيڒِي إِعسّْ، إِحزّمْ إِ مَارَّا ڒْخذْمثْ إِصبْحنْ.   
\b  
\b  
\m  
\c 4
\s1 ڒْخذْمثْ ن ؤُمْبشَّارْ  
\m
\v 1 \add ذ مَانْ أَيَا إِ\add* تّْعوّْڒغْ خَاكْ زَّاثْ إِ أَربِّي ذ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، ونِّي إِ غَا إِحكْمنْ خْ يِينِّي إِدَّارنْ ؤُ خْ يِينِّي إِمُّوثنْ غَارْ ؤُخشِّي ن ثْڭلْذِيثْ نّسْ: \x ◘ \xo 4:‏1 \xt رُوم. 1‏:‏9؛ 9‏:‏1؛ 2 كُور. 1‏:‏23؛ 11‏:‏31؛ ڭال. 1‏:‏20؛ فِيل. 1‏:‏8؛ 1 تس. 2‏:‏5؛ 1 تِيم. 5‏:‏21؛ 6‏:‏13. \x*  
\v 2 بَارّحْ س وَاوَاڒْ، إِڒِي ثْفَاقذْ ذِي مَانْ أَيَا ذِي ڒْوقْثْ نِيغْ بَارَّا إِ ڒْوقْثْ، صحّْ، عَاقبْ، عْڒمْ س مَارَّا تَّاسِيعْ ن ڒْخَاضَارْ ؤُ س ؤُسڒْمذْ.  
\v 3 مِينْزِي أَذْ د-ثَاسْ إِشْثْ ن ڒْوقْثْ خْمِي إِوْذَانْ وَارْ قبِّيڒنْ عَاذْ ثَاغُورِي إِصحّنْ، مَاشَا أَذْ سّْمُوننْ إِ إِخفْ نْسنْ أَطَّاسْ ن إِمسْغَارنْ عْلَاحْسَابْ ثِيزِي نْسنْ، إِنِّي إِسَّاريّْحنْ إِمزُّوغنْ نْسنْ.  
\v 4 أَذْ جمْذنْ ثِيذتّْ خْ إِمجَّانْ نْسنْ ؤُشَا أَذْ فّْغنْ زڭْ وبْرِيذْ غَارْ ثْحُوجَا إِخْوَانْ.  
\v 5 مَاشَا شكْ، فَاقْ ذِي كُوڒْشِي، كْسِي أَرْمحْ، أڭّْ ڒْخذْمثْ ن ؤُمْبشَّارْ ؤُشَا كمّڒْ ڒْخذْمثْ ن ثْسخَّارْثْ نّشْ.   
\b  
\m  
\s1 أَوَاڒْ ذ ؤُسدْجمْ أَنڭَّارُو  
\m
\v 6 مِينْزِي نشّْ أَقَا تّْوَازدْجْعغْ أَمْ ثوْهِيبْثْ \add ن ؤُسيّبْ\add* ؤُ ڒْمِيجَاڒْ ن ثْوَاحِيثْ إِنُو يِيوضْ-د. \x ◘ \xo 4:‏6 \xt 2 بُط. 1‏:‏14. \x*  
\v 7 نشّْ منْغغْ أَمنْغِي أَصبْحَانْ، أَقَا كمّْڒغْ ثَازّْڒَا إِنُو، حْضِيغْ لْ-إِيمَانْ.  
\v 8 خنِّي ڒخُّو، تَّاجْ ن ثْسڭْذَا، ثنِّي إِ ذ أَيِي غَا إِوْشْ سِيذِي ذڭْ وَاسّْ نِّي، خْمِي غَا إِحْكمْ إِمْسڭَّاذنْ، أَقَا إِوْجذْ. مَاشَا وَارْ إِدْجِي إِ نشّْ وَاهَا، مَاشَا عَاوذْ إِ \add مَارَّا\add* إِنِّي إِتّخْسنْ أَخشِّي نّسْ. \x ◘ \xo 4:‏8 \xt 1 كُور. 9‏:‏25؛ 1 بُط. 5‏:‏4. \x*   
\b  
\m
\v 9 شْضَارثْ حِيمَا أَذْ غَارِي د-ثَاسذْ ذغْيَا.  
\v 10 مِينْزِي ذِيمَاسْ إِسْمحْ ذَايِي، \add مَاغَارْ\add* نتَّا إِتّخْسْ دُّونشْثْ \add ن يِيضَا\add* ؤُشَا إِرُوحْ غَارْ ثِيسَّالُونِيكَا، ؤُ كْرِيسْكِيسْ إِرُوحْ غَارْ ڭَالَاطِييَا ؤُ ثِيثُوسْ غَارْ ذَالْمَاثِييَا. \x ◘ \xo 4:‏10 \xt كُول. 4‏:‏14؛ فلمن. 24. \x*  
\v 11 مْغِيرْ لُوكَا إِ كِيذِي إِقِّيمنْ. أَوِي-د مَارْكُوسْ ؤُشَا ڭوّذْ إِ-ث أَكِيذكْ، مِينْزِي إِنفّعْ أَيِي ذِي ڒْخذْمثْ ن ثْسخَّارْثْ. \x ◘ \xo 4:‏11 \xt ڒخ. 15‏:‏37؛ كُول. 4‏:‏10، 14؛ فلمن. 24. \x*  
\v 12 سكّغْ-د ثِيشِيكُوسْ غَارْ أَفَاسُوسْ. \x ◘ \xo 4:‏12 \xt ڒخ. 20‏:‏4؛ كُول. 4‏:‏7. \x*   
\m
\v 13 خْمِي د غَا ثَاسذْ، أَوِي-د أَكِيذكْ أَقْرَابْ إِ إِذْلِيسنْ إِتّْوَانْضنْ نِّي جِّيغْ ذِي ثْرُووَاسْ غَارْ كَارْپُوسْ ؤُڒَا ذ إِذْلِيسنْ، ذ أَمزْوَارُو ڒمْصَاحفْ ن شَّارْكْ.   
\m
\v 14 أَلِيكْسَانْذِيرْ، أَمْزِيڒْ \add ن نّْحَاسْ\add*، ثُوغَا إِڭَّا ذَايِي أَطَّاسْ ن ثُوعفّْنَا. سِيذِيثْنغْ أَذْ ث إِخدْجصْ عْلَاحْسَابْ ڒخْذَايمْ نّسْ. \x ◘ \xo 4:‏14 \xt 1 تِيم. 1‏:‏20. \x*  
\v 15 حْضَا إِخفْ نّشْ زَّايسْ، مِينْزِي نتَّا ثُوغَا إِتّْعكَّاسْ أَوَاڒنْ نّغْ أَطَّاسْ.   
\m
\v 16 ؤُمِي كَّارغْ أَذْ وْثغْ خْ إِخفْ إِنُو ثْوَاڒَا ثَامزْوَارُوثْ، ؤُڒَا ذ إِجّْ وَارْ كِيذِي د-يُوسِي، مَاشَا مَارَّا سمْحنْ ذ أَيِي. أجّْ وَارْ إِتِّيڒِي ذ أَخدْجصْ نْسنْ.  
\v 17 مَاشَا سِيذِي ثُوغَا-ث غَارْ ؤُغزْذِيسْ إِنُو ؤُشَا إِوْشَا أَيِي جّهْذْ، حِيمَا خنِّي زَّايِي إِ غَا ثْكمّڒْ ثْبَارّحْثْ، ؤُ مَارَّا ڒڭْنُوسْ أَذْ سْڒنْ، أَقَا نشّْ تّْوَافكّغْ-د زڭْ ؤُخنْفُوشْ ن وَايْرَاذْ.  
\v 18 سِيذِي أَذْ أَيِي إِفكّْ زِي مَارَّا \add ثَامعْمُوتْشْ\add* ثَاعفَّانْثْ، أَذْ أَيِي إِوْشْ ثُوذَارْثْ ذِي ثْڭلْذِيثْ نّسْ ذڭْ إِجنْوَانْ، مَاغَارْ إِ نتَّا إِ غَا يِيڒِي ؤُعُودْجِي إِ ڒبْذَا قَاعْ. أَمِينْ.   
\b  
\m
\v 19 سدْجمْ خْ بْرِيسْكِيلَّا ذ أَكْوِيلَا ؤُ خْ \add أَيْثْبَابْ ن\add* ثَادَّارْثْ ن ؤُنِيسِيفُورُوسْ س ڒهْنَا. \x ◘ \xo 4:‏19 \xt ڒخ. 18‏:‏2؛ رُوم. 16‏:‏3. \x*   
\m
\v 20 إِرَاسْثُوسْ إِقِّيمْ ذِي كُورِينْثُوسْ ؤُ ثْرُوفِيمُوسْ جِّيغْ ث ذِي مِيلِيثُوسْ إِهْڒشْ.   
\m
\v 21 شْضَارثْ أَذْ د-ثَاسذْ قْبڒْ ثَاڭْرِيسْثْ.  
\m إِوْپُولُوسْ ذ بُوذِينْسْ ذ لِينُوسْ ذ كْلُوذِييَا ذ مَارَّا أَوْمَاثنْ تّْسدْجَامنْ خَاكْ س ڒهْنَا.   
\m
\v 22 أَذْ يِيڒِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَكْ-ذ أَرُّوحْ نّشْ. أَرْضَا أَذْ كِيذكْ يِيڒِي. أَمِينْ.   