\id JHN
\h يُوحَانَّا 
\toc1 يُوحَانَّا 
\toc2 يُوحَانَّا 
\toc3 يُوح. 
\mt1 يُوحَانَّا  
\c 1
\s1 أَوَاڒْ ن أَربِّي ذ ثَافَاوْثْ ذ ثُوذَارْثْ  
\m
\v 1 ذڭْ ؤُمزْوَارُو ثُوغَا إِدْجَا وَاوَاڒْ، أَوَاڒْ ثُوغَا-ث غَارْ أَربِّي ؤُ أَربِّي ثُوغَا-ث ذ أَوَاڒْ. \x ◘ \xo 1:‏1 \xt أَوڒن. 8‏:‏22؛ يُوح. 1‏:‏1، 2. \x*  
\v 2 وَانِيثَا ذ ونِّي إِدْجَانْ غَارْ أَربِّي ذڭْ ؤُمزْوَارُو. \x ◘ \xo 1:‏2 \xt يُوح. 17‏:‏5. \x*  
\v 3 زَّايسْ نتَّا إِدْجَا كُوڒْشِي ؤُ بْڒَا نتَّا وَارْ ثدْجِي ؤُڒَا ذ إِشْثْ ن ثْمسْڒَاشْثْ زِي \add مَارَّا\add* مِينْ إِدْجَانْ. \x ◘ \xo 1:‏3 \xt أَمز. 1‏:‏3؛ إِزهد. 33‏:‏6؛ أَفا. 3‏:‏9؛ كُول. 1‏:‏16؛ عبر. 1‏:‏2. \x*  
\v 4 ذَايسْ إِ ثدْجَا ثُوذَارْثْ ؤُ ثُوذَارْثْ ثدْجَا ثَافَاوْثْ ن إِوْذَانْ. \x ◘ \xo 1:‏4 \xt يُوح. 5‏:‏26؛ 1 يُوح. 5‏:‏11؛ 8‏:‏12؛ 9‏:‏5؛ 12‏:‏46. \x*  
\v 5 ثَافَاوْثْ ثَارقّْ ذِي ثَادْجسْثْ، ثَادْجسْثْ وَارْ ت ثطِّيفْ. \x ◘ \xo 1:‏5 \xt يُوح. 3‏:‏19. \x*   
\b  
\m
\v 6 ثُوغَا \add ذِينْ\add* إِجّْ ن بْنَاذمْ إِسّكّْ إِ-ث-إِ-د أَربِّي، قَّارنْ أَسْ يُوحَانَّا. \x ◘ \xo 1:‏6 \xt مـَال. 3‏:‏1؛ مت. 3‏:‏1؛ مك. 1‏:‏2، 4؛ لك. 3‏:‏3؛ 7‏:‏27؛ يُوح. 1‏:‏33. \x*  
\v 7 نتَّا يُوسَا-د أَمْ شَّاهذْ حِيمَا أَذْ إِشْهذْ إِ ثْفَاوْثْ، حِيمَا أَذْ زَّايسْ أَمْننْ مَارَّا.  
\v 8 نتَّا وَارْ إِدْجِي شَا ذ ثَافَاوْثْ، مَاشَا \add ثُوغَا-ث\add* حِيمَا أَذْ إِشْهذْ إِ ثْفَاوْثْ.   
\b  
\m
\v 9 مَاغَارْ \add ثَافَاوْثْ\add* نِّي، ثُوغَا ذ ثَافَاوْثْ ن ثِيذتّْ إِ إِتِّيشنْ ثَافَاوْثْ إِ كُوڒْ بْنَاذمْ إِ د-إِتَّاسنْ غَارْ دُّونشْثْ. \x ◘ \xo 1:‏9 \xt يُوح. 8‏:‏12؛ 9‏:‏5؛ 12‏:‏46. \x*  
\v 10 نتَّا ثُوغَا-ث ذِي دُّونشْثْ ؤُ زَّايسْ ثتّْوَاڭّْ دُّونشْثْ، \add مَاشَا\add* دُّونشْثْ وَارْ ث ثسِّينْ شَا. \x ◘ \xo 1:‏10 \xt عبر. 1‏:‏2؛ 11‏:‏3. \x*  
\v 11 يُوسَا-د غَارْ وِي إِدْجَانْ نّسْ، \add مَاشَا\add* وِي إِدْجَانْ نّسْ وَارْ ث قْبِيڒنْ.  
\v 12 مَاشَا مَارَّا إِنِّي ث إِقبْڒنْ، إِوْشَا أَسنْ صُّولْطَا، حِيمَا أَذْ ذوْڒنْ ذ ثَارْوَا ن أَربِّي، إِ يِينِّي إِتَّامْننْ ذڭْ يِيسمْ نّسْ، \x ◘ \xo 1:‏12 \xt إِشا. 56‏:‏5؛ رُوم. 8‏:‏15؛ ڭال. 3‏:‏26؛ 2 بُط. 1‏:‏4؛ 1 يُوح. 3‏:‏1. \x*  
\v 13 إِنِّي وَارْ د-إِخْڒِيقنْ ؤُڒَا زڭْ إِذَامّنْ، ؤُڒَا زِي مِينْ إِخْسْ دَّاثْ \add ن بْنَاذمْ\add*، ؤُڒَا زِي مِينْ إِخْسْ ورْيَازْ، مَاشَا زِي أَربِّي د-إِتّْوَاخڒْقنْ.   
\b  
\m
\v 14 أَوَاڒْ إِذْوڒْ ذ دَّاثْ، إِزْذغْ جَارْ أَنغْ، نشِّينْ نژْرَا أَعُودْجِي نّسْ، أَعُودْجِي ن ؤُينِّي \add ن مِّيسْ\add* زِي غَارْ بَابَاسْ إِ إِشُّورنْ س أَرْضَا ذ ثِيذتّْ. \x ◘ \xo 1:‏14 \xt إِشا. 7‏:‏14؛ مت. 1‏:‏16؛ 17‏:‏2؛ لك. 1‏:‏31؛ 2‏:‏7؛ كُول. 1‏:‏19؛ 2‏:‏9؛ 2 بُط. 1‏:‏17؛ 1 يُوح. 4‏:‏2، 3؛ 2 يُوح. 1‏:‏7. \x*  
\v 15 إِشْهذْ خَاسْ يُوحَانَّا، إِڒَاغَا، إِنَّا: ”ذ وَا مِينْ خفْ نِّيغْ، أَقَا نتَّا أَذْ د-يَاسْ أَوَارْنِي أَيِي، وَاخَّا نتَّا إِذْوڒْ زَّاثِي، مِينْزِي نتَّا ثُوغَا-ث قْبڒْ إِنُو.“ \x ◘ \xo 1:‏15 \xt مت. 3‏:‏11؛ مك. 1‏:‏7؛ لك. 3‏:‏16؛ يُوح. 1‏:‏26، 30. \x*   
\m
\v 16 زِي ڒكْمَاڒثْ نّسْ نِيوِي-د مَارَّا، أَرْضَا خْ أَرْضَا. \x ◘ \xo 1:‏16 \xt كُول. 2‏:‏10. \x*  
\v 17 شَّارِيعَا ثمّوْشْ خْ ؤُفُوسْ ن مُوسَا، مَاشَا أَرْضَا ذ ثِيذتّْ ؤُسِينْ-د زِي يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏17 \xt ؤُف. 20‏:‏1. \x*  
\v 18 ؤُڒَا ذ إِجّْ وَارْ إِژْرِي أَربِّي. أَينِّي ن أَربِّي إِ إِدْجَانْ ذڭْ وحْسِينْ ن بَابَاسْ، ذ نتَّا إِ \add زَّايسْ\add* إِسّْخبَّارنْ. \x ◘ \xo 1:‏18 \xt ؤُف. 33‏:‏20؛ أَعَوذ. 4‏:‏12؛ مت. 11‏:‏27؛ يُوح. 6‏:‏46؛ 1 تِيم. 6‏:‏16؛ 1 يُوح. 4‏:‏12. \x*   
\b  
\m  
\s1 شّْهَاذثْ ثَامزْوَارُوثْ ن يُوحَانَّا أَمْسغْضَاصْ  
\m
\v 19 ثَا ذ شّْهَاذثْ ن يُوحَانَّا ڒَامِي د-سّكّنْ وُوذَاينْ إِكهَّاننْ ذ إِلَاوِييّنْ زِي ؤُرْشَالِيمْ حِيمَا أَذْ ث سّقْسَانْ: ”مِينْ ثعْنِيذْ شكْ؟“ \x ◘ \xo 1:‏19 \xt [مت. 3‏:‏1‏-‏12؛ مك. 1‏:‏2‏-‏8؛ لك. 3‏:‏15‏-‏17] — يُوح. 5‏:‏33. \x*  
\v 20 ثُوغَا إِشْهذْ، وَارْ إِسّْنُوفَّارْ شَا، إِشْهذْ: ”نشّْ وَارْ دْجِيغْ شَا ذ لْمَاسِيحْ.“ \x ◘ \xo 1:‏20 \xt يُوح. 3‏:‏28؛ ڒخ. 13‏:‏25. \x*  
\v 21 سّقْسَانْ ث: ”إِ مِينْ ثعْنِيذْ شكْ خنِّي؟ مَا ذ شكْ ذ \add أَنَابِي\add* إِلِييَا؟“ إِنَّا: ”لَّ، وَارْ دْجِيغْ ذ نشّْ!“ ”مَا ذ شكْ ذ أَنَابِي؟“ يَارَّا-د: ”لَّ!“  
\v 22 \add خَاسْ ؤُشَا\add* نَّانْ أَسْ: ”مِينْ ثعْنِيذْ شكْ؟ إِتّْخصَّا أَنغْ أَذْ نَارّْ إِ يِينِّي ذ أَنغْ د-إِسّكّنْ. مِينْ ثقَّارذْ خْ يِيخفْ نّشْ؟“  
\v 23 إِنَّا: ”نشّْ ذ ثْمِيجَّا إِ إِتّْڒَاغَانْ ذِي ڒخْڒَا: ’سڭّْممْ أَبْرِيذْ ن سِيذِي نِيشَانْ!‘، أَمْ مَامّشْ إِنَّا ؤُنَابِي إِشَاعْيَا.“ \x ◘ \xo 1:‏23 \xt إِشا. 40‏:‏3؛ مت. 3‏:‏3؛ مك. 1‏:‏3؛ لك. 3‏:‏4. \x*   
\m
\v 24 إِنِّي د-إِتّْوَاسّكّنْ، ثُوغَا أَثنْ زڭْ إِفَارِيسِييّنْ.  
\v 25 نِيثْنِي سّقْسَانْ ث، نَّانْ أَسْ: ”مَاڒَا وَارْ ثدْجِيذْ شَا ذ لْمَاسِيحْ ؤُڒَا ذ إِلِييَا ؤُڒَا ذ أَنَابِي، إِ خنِّي مَايمِّي ثسّغْضَاصذْ؟“ \x ◘ \xo 1:‏25 \xt أَعَوذ. 18‏:‏18. \x*  
\v 26 يُوحَانَّا يَارَّا-د، إِنَّا أَسنْ: ”نشّْ سّغْضَاصغْ ذڭْ وَامَانْ، مَاشَا أَقَا ذِينْ ذِي ڒْوسْطْ نْومْ ونِّي وَارْ ثسِّينمْ شَا. \x ◘ \xo 1:‏26 \xt مت. 3‏:‏11؛ مك. 1‏:‏7؛ لك. 3‏:‏16؛ ڒخ. 1‏:‏5؛ 11‏:‏16؛ 19‏:‏4. \x*  
\v 27 نتَّا ذ ونِّي إِ د غَا يَاسنْ أَوَارْنِي أَيِي، نتَّا إِدْجَا قْبڒْ إِنُو، نشّْ وَارْ سْذِيهدْجغْ أَذْ أَسْ فسْيغْ إِفِيڒَانْ ن سَانْذَالِييَاثْ نّسْ.“   
\m
\v 28 مَانْ أَيَا إِمْسَارْ ذِي بَايْثْعَانْيَا خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، مَانِي ثُوغَا يُوحَانَّا إِسّغْضَاصْ.   
\b  
\m
\v 29 ثِيوشَّا نّسْ إِژْرَا يُوحَانَّا يَاسُوع إِڭُّورْ-د غَارسْ، إِنَّا: \bd ”خْزَارمْ، أَقَا-ث ذ إِزْمَارْ ن أَربِّي إِ إِتّكّْسنْ دّْنُوبْ خْ دُّونشْثْ!\bd* \x ◘ \xo 1:‏29 \xt أَمز. 22‏:‏7، 8؛ إِشا. 53‏:‏5، 7؛ يُوح. 1‏:‏36. \x*  
\v 30 ذ وَا مِينْ خفْ نِّيغْ: ’أَذْ د-يَاسْ أَوَارْنِي أَيِي إِجّْ ن ورْيَازْ نِّي إِدْجَانْ زَّاثِي، مِينْزِي نتَّا ثُوغَا-ث قْبڒْ إِنُو.‘  
\v 31 نشّْ وَارْ ث سِّينغْ شَا، مَاشَا حِيمَا أَذْ إِتّْوَاسَّارْڭبْ غَارْ إِسْرَائِيل، خْ ؤُينِّي ؤُسِيغْ-د حِيمَا أَذْ سّْغضْصغْ ذڭْ وَامَانْ.“   
\m
\v 32 يُوحَانَّا إِشْهذْ، إِنَّا: ”ژْرِيغْ أَرُّوحْ إِهْوَا-د أَمْ يِيشْثْ ن ثذْبِيرْثْ زڭْ ؤُجنَّا، ثَارْسَا خَاسْ. \x ◘ \xo 1:‏32 \xt مت. 3‏:‏16؛ مك. 1‏:‏10؛ لك. 3‏:‏22. \x*  
\v 33 نشّْ وَارْ ث سِّينغْ شَا، مَاشَا ونِّي ذ أَيِي د-إِسّكّنْ حِيمَا أَذْ سّْغضْصغْ ذڭْ وَامَانْ، نتَّا إِنَّا أَيِي: ’ونِّي ثژْرِيذْ إِهْوَا-د خَاسْ أَرُّوحْ ؤُشَا يَارْسَا خَاسْ، ذ وَا ذ ونِّي إِسّغْضَاصنْ ذِي أَرُّوحْ إِقدّْسنْ.‘  
\v 34 ؤُ نشّْ ژْرِيغْ، شهْذغْ بلِّي وَانِيثَا ذ مِّيسْ ن أَربِّي.“   
\b  
\m  
\s1 إِمحْضَارنْ إِمزْوُورَا ن يَاسُوع  
\m
\v 35 ثِيوشَّا نّسْ ثُوغَا يُوحَانَّا إِبدّْ أَكْ-ذ ثْنَاينْ ن إِمحْضَارنْ نّسْ.  
\v 36 أَمْ ثُوغَا إِخزَّارْ غَارْ يَاسُوع إِ \add ذِينْ\add* إِڭُّورنْ، إِنَّا: ”خْزَارمْ، \add ذ وَا ذ\add* إِزْمَارْ ن أَربِّي!“ \x ◘ \xo 1:‏36 \xt إِشا. 53‏:‏7؛ يُوح. 1‏:‏29؛ ڒخ. 8‏:‏32\x*  
\v 37 ثْنَاينْ ن إِمحْضَارنْ نّسْ سْڒِينْ أَسْ أَمْ ت إِقَّارْ ؤُشَا ضْفَارنْ يَاسُوع.  
\v 38 إِنّقْڒبْ-د يَاسُوع، إِژْرَا إِ-ثنْ ضفَّارنْ ث-إِ-د، إِسّقْسَا ثنْ: ”مِينْ خفْ ثَارزُّومْ؟“ نِيثْنِي نَّانْ أَسْ: ”\add أَ\add* أَمْسڒْمَاذْ نّغْ، مَانِي ثْزدّْغذْ؟“  
\v 39 إِنَّا أَسنْ: ”أَرَاحمْ-د، أَذْ ثْژَارمْ!“ رُوحنْ أَكِيذسْ، ژْرِينْ مَانِي إِزْذغْ، قِّيمنْ أَكِيذسْ أَسّْ نِّي. ثَاسَاعّثْ ثُوغَا-ت عْڒَاحَاڒْ ذعشْرَا، \add إِخْسْ أَذْ يِينِي عْڒَاحَاڒْ ثَاسَاعّثْ وِيسّْ أَربْعَا ن ثْمذِّيثْ\add*.   
\m
\v 40 أَنْذْرَاوُوسْ، ؤُمَاسْ ن شِيمْعُونْ، ثُوغَا-ث ذ إِجّنْ زڭْ يِينِّي إِسْڒِينْ أَيَا زِي يُوحَانَّا ؤُشَا ضفَّارنْ يَاسُوع.  
\v 41 ذ وَا إِ إِژْرِينْ أَمزْوَارُو ؤُمَاسْ شِيمْعُونْ، إِنَّا أَسْ: ”أَقَا نُوفَا لْمَاسِيحْ!“  
\v 42 إِسِّيوضْ إِ-ث-إِ-د غَارْ يَاسُوع. إِخْزَارْ ذَايسْ يَاسُوع، إِنَّا: ”شكْ ذ شِيمْعُونْ، مِّيسْ ن يُونَا، أَذْ أَشْ ڒَاغَانْ: ’كِيفَا‘، \add إِخْسْ أَذْ يِينِي ’أَژْرُو‘\add* “\f ◼ \fr 1:‏42 \ft \+bd ’كِيفَا‘\+bd* - إِسمْ وَانِيثَا ذ إِسمْ نّسْ س ثْرَامِيثْ، ؤُ ’بُوطْرُوسْ‘ ذ إِسمْ نّسْ س ثْيُونَانِيثْ، مِينْزِي إِوْذَانْ ذِي ثمُّورْثْ ذِي ڒْوقْثْ نِّي، ثُوغَا سِّيوْڒنْ س ثْرَامِيثْ، مَاشَا ثْيُونَانِيثْ ذ إِڒسْ ن إِيُونَانِييّنْ إِنِّي ثُوغَا صّلْطنْ ذِي ثمُّورْثْ غَارْ إِجّْ ن ڒْوقْثْ قْبڒْ د-يُوسِينْ إِرُومَانِييّنْ.\f*  \x ◘ \xo 1:‏42 \xt مت. 16‏:‏18. \x*   
\m
\v 43 ثِيوشَّا نّسْ ثُوغَا إِخْسْ يَاسُوع أَذْ إِرَاحْ غَارْ لْجَالِيلْ. إِمّڒْقَا أَكْ-ذ فِيلِيبُّوسْ، إِنَّا أَسْ: ”ضْفَارْ أَيِي-د!“  
\v 44 فِيلِيبُّوسْ س يِيخفْ نّسْ ثُوغَا زِي بَايْثْ-صَايْذَا زِي ثَانْذِينْثْ ن أَنْذْرَاوُوسْ ذ شِيمْعُونْ. \x ◘ \xo 1:‏44 \xt يُوح. 12‏:‏21. \x*  
\v 45 فِيلِيبُّوسْ يُوفَا نَاثَانَايِيلْ، إِنَّا أَسْ: ”نُوفَا ونِّي خفْ يُورَا مُوسَا ذِي شَّارِيعَا ؤُڒَا ذ إِنَابِييّنْ، أَقَا-ث ذ يَاسُوع، مِّيسْ ن يُوسُوفْ زِي نَّاصِيرَا.“ \x ◘ \xo 1:‏45 \xt أَمز. 3‏:‏15؛ 22‏:‏18؛ 26‏:‏4؛ 49‏:‏10؛ أَعَوذ. 18‏:‏18؛ 2 صم. 7‏:‏12؛ إِشا. 4‏:‏2؛ 7‏:‏14؛ 9‏:‏5؛ 40‏:‏10، 11؛ 53‏:‏1‏-‏12؛ إِرْم. 23‏:‏5؛ 33‏:‏14؛ حِز. 34‏:‏23؛ دَان. 9‏:‏24؛ زَاك. 6‏:‏12؛ 9‏:‏9. \x*  
\v 46 نَاثَانَايِيلْ إِنَّا أَسْ: ”مَا أَذْ ثَاغْ إِزمَّارْ أَذْ د-ثفّغْ زِي نَّاصِيرَا شَا ن ثْشُونِي؟“ فِيلِيبُّوسْ إِنَّا أَسْ: ”أَرَاحْ-د، ثخْزَارذْ!“  
\v 47 يَاسُوع إِژْرَا نَاثَانَايِيلْ إِڭُّورْ-د غَارسْ، إِنَّا خَاسْ: ”خْزَارْ، وَا ذ إِجّْ ن مِّيسْ ذ ثِيذتّْ ن إِسْرَائِيل نِّي وَارْ ذَايسْ بُو ڒْغشّْ!“  
\v 48 نَاثَانَايِيلْ إِنَّا أَسْ: ”مَانِيسْ ذ أَيِي ثسّْنذْ؟“ يَاسُوع إِنَّا أَسْ: ”ژْرِيغْ شكْ سْوَادَّايْ إِ وَارْثُو قْبڒْ مَا أَذْ أَشْ د-إِڒَاغَا فِيلِيبُّوسْ.“  
\v 49 نَاثَانَايِيلْ يَارَّا-د خَاسْ: ”\add أَ\add* أَمْسڒْمَاذْ إِنُو، شكْ ذ مِّيسْ ن أَربِّي، شكْ ذ أَجدْجِيذْ ن إِسْرَائِيل.“  
\v 50 يَاسُوع إِنَّا أَسْ: ”مَا ثُومْنذْ س مِينْزِي ذ أَشْ نِّيغْ: ’أَقَا ژْرِيغْ شكْ سْوَادَّايْ إِ وَارْثُو‘؟ أَذْ ثْژَارذْ مِينْ إِدْجَانْ كْثَارْ زِي مَانْ أَيَا.“  
\v 51 إِنَّا أَسْ: ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، زِي سَّا ذ ثْسَاونْثْ أَذْ ثْژَارمْ أَجنَّا إِنُّورْزمْ ؤُ لْمَالَاكَاثْ ن أَربِّي تَّاڒْينْثْ هكّْوَانْثْ غَارْ مِّيسْ ن بْنَاذمْ!“ \x ◘ \xo 1:‏51 \xt أَمز. 28‏:‏12. \x*   
\b  
\b  
\m  
\c 2
\s1 لْمُوعْجِيزَا ثَامزْوَارُوثْ ذِي قَانَا  
\m
\v 1 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا ثمْسَارْ إِشْثْ ن ثْمغْرَا ذِي قَانَا، إِشْثْ ن ثنْذِينْثْ ذِي لْجَالِيلْ. ثُوغَا ذِينْ يمَّاسْ ن يَاسُوع.  
\v 2 ؤُڒَا ذ يَاسُوع ذ إِمحْضَارنْ نّسْ تّْوَاعَارْضنْ-د غَارْ ثْمغْرَا.  
\v 3 ڒَامِي إِقْضَا بِينُو، ثنَّا أَسْ يمَّاسْ إِ يَاسُوع: ”وَارْ غَارْسنْ بُو بِينُو!“  
\v 4 يَاسُوع إِنَّا أَسْ: ”مِينْ ذِينْ جَارْ أَيِي أَكِيذمْ، \add أَ\add* ثَامْغَارْثْ؟ ثَاسَاعّثْ إِنُو وَارْ د-ثِيوِيضْ عَاذْ!“  
\v 5 يمَّاسْ ثنَّا إِ إِمْسخَّارنْ: ”مِينْ ذ أَومْ إِ غَا يِينِي، ڭّمْ ث.“   
\m
\v 6 ثُوغَا ذِينْ ستَّا ن إِقدّْوَاحْ ن وژْرُو ذَايْسنْ أَمَانْ، مَّارْسنْ ذِينِّي أَمْ مَامّشْ نُّومنْ تّڭّنْ وُوذَاينْ ڒُوضُو، كُوڒْ إِجّنْ \add زَّايْسنْ\add* غَارسْ ڒْقدّْ ن ثْنَاينْ أَڒْ ثْڒَاثَا ن ’إِرِيبَاعنْ‘. \f ◼ \fr 2:‏6 \ft \+bd ’إِرِيبَاعنْ‘\+bd* - نِيغْ ’إِمِيثْرِيثنْ‘ ذِي ثُوثْلَايْثْ ن ثْيُونَانِيثْ. إِجّْ ن زَّايْسنْ ذَايسْ عْڒَاحَاڒْ ثْمَانْيِينْ أَڒْ مْيَا ؤُ-عِيشْرِينْ لِيثْرُو.\f*  
\v 7 يَاسُوع إِنَّا أَسنْ: ”شُّورمْ إِقدّْوَاحْ س وَامَانْ!“ ؤُشَا شُّورنْ ثنْ س وَامَانْ أَڒْ أَقمُّومْ.  
\v 8 \add خَاسْ ؤُشَا\add* إِنَّا أَسنْ: ”ڒخُّو سّْفَارّْغمْ \add شْوَايْثْ\add* زَّايْسنْ، وْشمْ ث إِ بَابْ ن وُورَارْ.“ ؤُشَا سِّيوْضنْ ث.  
\v 9 ؤُمِي بَابْ ن وُورَارْ إِقدْجبْ أَمَانْ إِ إِذوْڒنْ ذ بِينُو - \add مَاشَا\add* نتَّا وَارْ إِسِّينْ مَانِيسْ د-إِكَّا، مَاشَا إِمْسخَّارنْ نِّي ذ أَسْ د-يُويْمنْ أَمَانْ، سّْننْ - إِڒَاغَا-د بَابْ ن ثْمغْرَا خْ وسْڒِي.  
\v 10 إِنَّا أَسْ: ”كُوڒْ بْنَاذمْ إِتّْقدَّامْ بِينُو أَصبْحَانْ ذ أَمزْوَارُو. مَاڒَا إِنوْجِيونْ سْوِينْ أَطَّاسْ، أَذْ أَسنْ إِوْشْ بِينُو وَارْ إِحْڒِينْ، مَاشَا شكْ ثْخمّْڒذْ بِينُو إِصبْحنْ أَڒْ إِ ڒخُّو.“   
\m
\v 11 ذ ثَا ذ ڒعْڒَامثْ ثَامزْوَارُوثْ إِ إِڭَّا يَاسُوع، ذِي قَانَا ذِي لْجَالِيلْ. إِسّضْهَارْ-د أَعُودْجِي نّسْ ؤُشَا ؤُمْننْ زَّايسْ إِمحْضَارنْ نّسْ.  
\v 12 أَوَارْنِي مَانْ أَيَا إِهْوَا-د غَارْ كَافَارْنَاحُومْ، نتَّا ذ يمَّاسْ، ذ أَيْثْمَاسْ، ذ إِمحْضَارنْ نّسْ، ؤُشَا قِّيمنْ ذِينْ شَا ن وُوسَّانْ.   
\b  
\m  
\s1 يَاسُوع ذِي زَّاوشْثْ ثَامقّْرَانْثْ  
\m
\v 13 ڒَامِي د-يِيوضْ \add ڒْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو، ڒْعِيذْ ن وُوذَاينْ، إِڭعّذْ يَاسُوع غَارْ ؤُرْشَالِيمْ. \x ◘ \xo 2:‏13 \xt [مت. 21‏:‏12‏-‏13؛ مك. 11‏:‏15‏-‏17؛ لك. 19‏:‏45‏-‏46]\x*  
\v 14 يُوفَا ذِي زَّاوشْثْ ثَامقّْرَانْثْ إِنِّي ذِينْ إِزّْنُوزَانْ إِينْذُوزنْ ذ وُودْجِي ذ إِذْبِيرنْ، ؤُڒَا ذ إِصَارَّافنْ ن ثنْعَاشِينْ إِ ذِينْ إِقِّيمنْ. \x ◘ \xo 2:‏14 \xt مت. 21‏:‏12؛ مك. 11‏:‏15؛ لك. 19‏:‏45. \x*  
\v 15 إِڭَّا إِجّْ ن ؤُركُّوضْ زڭْ إِسغْوَانْ إِ يِيخفْ نّسْ، ؤُشَا يُوژّڒْ خَاسنْ مَارَّا زِي زَّاوشْثْ ثَامقّْرَانْثْ، ؤُڒَا ذ ؤُدْجِي ذ إِينْذُوزنْ ذ إِصَارَّافنْ، ؤُشَا إِزدْجعْ إِصُولْذِييّنْ نْسنْ ذِي ثمُّورْثْ، إِنّقْڒبْ طّْوَابڒْ نْسنْ.  
\v 16 إِنَّا إِ يِينِّي إِزّْنُوزَانْ إِذْبِيرنْ: ”كّْسمْ مَانْ أَيَا سَّا! وَارْ تَّارِّيمْ شَا ثَادَّارْثْ ن بَابَا ذ ثَادَّارْثْ ن سُّوقْ!“  
\v 17 \add خنِّي\add*عقْڒنْ إِمحْضَارنْ نّسْ بلِّي ثُورَا: ”شْضَارثْ إِ ثَادَّارْثْ نّشْ إِشَّا أَيِي.“ \x ◘ \xo 2:‏17 \xt إِزهد. 69‏:‏10. \x*   
\m
\v 18 \add مَاشَا\add* ؤُذَاينْ أَرِّينْ-د، نَّانْ أَسْ: ”مَانْ ڒعْڒَامثْ إِ ذ أَنغْ غَا ثمْڒذْ، بلِّي \add أَقَا غَاركْ ڒْحقّْ حِيمَا\add* أَذْ ثڭّذْ مَانْ أَيَا؟“ \x ◘ \xo 2:‏18 \xt مت. 12‏:‏38؛ 16‏:‏1؛ مك. 8‏:‏11؛ لك. 11‏:‏29؛ يُوح. 6‏:‏30. \x*  
\v 19 يَاسُوع يَارَّا-د، إِنَّا أَسنْ: ”هذْممْ زَّاوشْثْ ثَامقّْرَانْثْ ثَانِيثَا ؤُشَا ذِي ثْڒَاثَا ن وُوسَّانْ أَذْ ت سّْبدّغْ.“ \x ◘ \xo 2:‏19 \xt مت. 26‏:‏61؛ 27‏:‏40؛ مك. 14‏:‏58؛ 15‏:‏29. \x*  
\v 20 نَّانْ أَسْ وُوذَاينْ: ”زَّاوشْثْ ثَامقّْرَانْثْ ثَانِيثَا ثبْنَا ذِي ستَّا ؤُ-ربْعِينْ ن إِسڭّْوُوسَا، مَا شكْ ثخْسذْ أَذْ ت-إِ-د-ثسّْبدّذْ ذِي ثْڒَاثَا ن وُوسَّانْ؟“  
\v 21 مَاشَا نتَّا ثُوغَا إِسَّاوَاڒْ خْ زَّاوشْثْ ثَامقّْرَانْثْ ن أَرِّيمثْ نّسْ.   
\m
\v 22 أَوَارْنِي ڒَامِي د-إِكَّارْ يَاسُوع زِي ثَادَّارْثْ ن إِمتِّيننْ،عقْڒنْ إِمحْضَارنْ نّسْ مِينْ ذ أَسنْ إِنَّا، ؤُشَا ؤُمْننْ ذِي ثِيرَا \add إِقدّْسنْ\add* ؤُ ذڭْ وَاوَاڒْ إِ إِنَّا يَاسُوع. \x ◘ \xo 2:‏22 \xt لك. 24‏:‏8. \x*   
\m
\v 23 ؤُمِي يَاسُوع ثُوغَا ذِي ؤُرْشَالِيمْ، ذِي ڒْعِيذْ ن \add ثْغَارْصْثْ ن\add* ؤُسعْذُو، ؤُمْننْ وَاطَّاسْ ذَايسْ ڒَامِي ژْرِينْ ڒعْڒَامَاثْ إِ إِڭَّا.  
\v 24 مَاشَا يَاسُوع وَارْ إِسّْشنْ شَا إِخفْ نّسْ غَارْسنْ، مِينْزِي نتَّا إِسّنْ مَارَّا إِوْذَانْ،  
\v 25 وَارْ إِحْذِيجْ شَا أَذْ أَسْ إِشْهذْ حذْ خْ بْنَاذمْ، مِينْزِي نتَّا س يِيخفْ نّسْ إِسّنْ مِينْ إِدْجَانْ ذِي بْنَاذمْ. \x ◘ \xo 2:‏25 \xt 1 صم. 16‏:‏7؛ 1 إِم. 28‏:‏9؛ إِزهد. 7‏:‏10؛ 103‏:‏14؛ إِرْم. 11‏:‏20؛ 17‏:‏10؛ 20‏:‏12؛ يُوح. 6‏:‏64. \x*   
\b  
\b  
\m  
\c 3
\s1 يَاسُوع ذ نِيكُوذِيمُوسْ  
\m
\v 1 ثُوغَا ذِينْ إِجّْ ن بْنَاذمْ زڭْ إِفَارِيسِييّنْ قَّارنْ أَسْ نِيكُوذِيمُوسْ، نتَّا ذ إِجّْ ن ؤُمقّْرَانْ ن وُوذَاينْ.  
\v 2 يُوسَا-د غَارْ يَاسُوع س دْجِيڒثْ، إِنَّا أَسْ: ”\add أَ\add* أَمْسڒْمَاذْ إِنُو، نشِّينْ نسّنْ بلِّي شكْ ذ أَمْسغَّارْ إِ د-يُوسِينْ زِي غَارْ أَربِّي، مِينْزِي وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ إِڭّْ ڒعْڒَامَاثْ-أَ إِ ثڭِّيذْ شكْ، مْغِيرْ مَاڒَا أَكِيذسْ أَربِّي.“ \x ◘ \xo 3:‏2 \xt يُوح. 7‏:‏50؛ 9‏:‏16، 33؛ 19‏:‏39؛ ڒخ. 10‏:‏38. \x*  
\v 3 يَارَّا-د يَاسُوع، إِنَّا أَسْ: ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَشْ إِنِيغْ، ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ إِژَارْ ثَاڭلْذِيثْ ن أَربِّي مْغِيرْ مَاڒَا إِتّْوَاخْڒقْ-د زِي جْذِيذْ.“  
\v 4 نِيكُوذِيمُوسْ إِنَّا أَسْ: ”مَامّشْ إِزمَّارْ إِجّْ ن ؤُوسَّارْ أَذْ د-إِتّْوَاخْڒقْ \add عَاذْ\add*؟ وَارْ إِزمَّارْ أَذْ يَاذفْ عَاوذْ ذڭْ ؤُعذِّيسْ ن يمَّاسْ، مَاحنْذْ أَذْ د-إِتّْوَاخْڒقْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ؟“  
\v 5 يَاسُوع يَارَّا-د، إِنَّا أَسْ: ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَشْ إِنِيغْ: مَاڒَا شَا ن يِيجّنْ وَارْ د-إِخْڒِيقْ شَا زڭْ وَامَانْ ؤُ زڭْ أَرُّوحْ، وَارْ إِزمَّارْ أَذْ يَاذفْ غَارْ ثْڭلْذِيثْ ن أَربِّي. \x ◘ \xo 3:‏5 \xt ثِيث. 3‏:‏5. \x*  
\v 6 مِينْ د-إِتّْوَاخڒْقنْ زِي دَّاثْ، نتَّا ذ دَّاثْ، ؤُ مِينْ د-إِتّْوَاخڒْقنْ زِي أَرُّوحْ، نتَّا ذ أَرُّوحْ. \x ◘ \xo 3:‏6 \xt رُوم. 8‏:‏5. \x*  
\v 7 وَارْ ثْبهْثمْ شَا مَاڒَا نِّيغْ أَشْ، إِتّْخصَّا كنِّيوْ أَذْ د-ثتّْوَاخڒْقمْ زِي جْذِيذْ.  
\v 8 أَسمِّيضْ إِتّْسُوضْ مَانِيسْ إِخْسْ، ثتّسْڒِيذْ إِ ؤُسُوضِي نّسْ، وَارْ ثسِّينذْ شَا مَانِيسْ د-إِتَّاسْ ؤُڒَا مَانِي إِتّْرَاحْ. أَمُّو إِ إِدْجَا عَاوذْ مَارَّا ونِّي د-إِتّْوَاخڒْقنْ زِي أَرُّوحْ.“   
\m
\v 9 نِيكُوذِيمُوسْ يَارَّا-د، إِنَّا أَسْ: ”مَامّشْ إِ غَا يڭّْ أَذْ يِيڒِي مَانْ أَيَا؟“  
\v 10 يَاسُوع يَارَّا-د، إِنَّا أَسْ: ”مَا شكْ ذ أَمْسغَّارْ ن إِسْرَائِيل ؤُ وَارْ ثسِّينذْ شَا مَانْ أَيَا؟  
\v 11 س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَشْ إِنِيغْ: نشِّينْ نسَّاوَاڒْ خْ مِينْ نسّنْ، نشْهذْ خْ مِينْ نژْرَا، وَاخَّا أَمنِّي كنِّيوْ وَارْ ثقْبِيڒمْ شَا شّْهَاذثْ نّغْ. \x ◘ \xo 3:‏11 \xt يُوح. 3‏:‏32؛ 7‏:‏16؛ 8‏:‏28؛ 12‏:‏49؛ 14‏:‏24. \x*  
\v 12 مَاڒَا سِّيوْڒغْ أَومْ خْ مِينْ إِدْجَانْ خْ ثمُّورْثْ، كنِّيوْ وَارْ ثِيمْنمْ، مَامّشْ غَا ثڭّمْ أَذْ ثَامْنمْ مَاڒَا سِّيوْڒغْ أَومْ خْ مِينْ إِدْجَانْ ذڭْ ؤُجنَّا؟  
\v 13 ؤُڒَا ذ إِجّْ وَارْ يُوڒِي غَارْ ؤُجنَّا مْغِيرْ ونِّي د-إِهْوَانْ زڭْ ؤُجنَّا، أَقَا-ث ذ مِّيسْ ن بْنَاذمْ، ذ ونِّي إِدْجَانْ ذڭْ ؤُجنَّا. \x ◘ \xo 3:‏13 \xt دَان. 7‏:‏13؛ يُوح. 6‏:‏62؛ أَفا. 4‏:‏9. \x*   
\m
\v 14 أَمْ مَامّشْ إِسّْڭعّذْ مُوسَا أَفِيغَارْ ذِي ڒفْيَافِي، أَمُّو إِتّْخصَّا أَذْ إِتّْوَاسّْڭعّذْ مِّيسْ ن بْنَاذمْ \add عَاوذْ\add*، \x ◘ \xo 3:‏14 \xt ڒخْڒ. 21‏:‏4‏-‏9؛ 2 إِج. 18‏:‏4؛ يُوح. 8‏:‏28؛ 12‏:‏32. \x*  
\v 15 حِيمَا مَارَّا ونِّي زَّايسْ إِ غَا يَامْننْ، وَارْ إِتّْهلِّيكْ شَا، مَاشَا أَذْ غَارسْ ثِيڒِي ثُوذَارْثْ إِتّْذُومَانْ. \x ◘ \xo 3:‏15 \xt يُوح. 3‏:‏15. \x*  
\v 16 أَمُّو إِ يخْسْ أَربِّي دُّونشْثْ أَڒْ مَانِي إِوْشَا أَينِّي ن مِّيسْ، حِيمَا كُوڒْ إِجّنْ ونِّي زَّايسْ إِ غَا يَامْننْ، وَارْ إِهلِّيكْ شَا، مَاشَا أَذْ غَارسْ ثِيڒِي ثُوذَارْثْ إِتّْذُومَانْ. \x ◘ \xo 3:‏16 \xt يُوح. 3‏:‏36؛ لك. 19‏:‏10؛ رُوم. 5‏:‏8؛ 8‏:‏31؛ 1 يُوح. 4‏:‏9؛ 5‏:‏10. \x*  
\v 17 مِينْزِي أَربِّي وَارْ د-إِسّكّْ شَا مِّيسْ غَارْ دُّونشْثْ، حِيمَا أَذْ إِحَاسبْ دُّونشْثْ، مَاشَا إِسّكّْ إِ-ث-إِ-د حِيمَا أَذْ زَّايسْ ثدَّارْ دُّونشْثْ. \x ◘ \xo 3:‏17 \xt لك. 9‏:‏56؛ يُوح. 9‏:‏39؛ 12‏:‏47؛ 1 يُوح. 4‏:‏14. \x*  
\v 18 ونِّي زَّايسْ إِ غَا يَامْننْ، وَارْ إِتّْوَاحَاسَابْ شَا. ونِّي وَارْ إِتِّيمْننْ شَا، أَقَا إِتّْوَاحَاسبْ زِي ڒخُّو، مِينْزِي نتَّا وَارْ يُومِينْ شَا ذڭْ يِيسمْ ن ؤُينِّي ن مِّيسْ ن أَربِّي. \x ◘ \xo 3:‏18 \xt يُوح. 5‏:‏24؛ 6‏:‏40،47؛ 20‏:‏31. \x*  
\v 19 ذ وَا ذ ڒحْكَامْ، أَقَا ثَافَاوْثْ ثُوسَا-د غَارْ دُّونشْثْ، \add مَاشَا\add* إِوْذَانْ خْسنْ ثَادْجسْثْ خْ ثْفَاوْثْ، مِينْزِي ثِيمڭَّا نْسنْ ثُوغَا أَثنْثْ ذ ثِيعفَّانِينْ. \x ◘ \xo 3:‏19 \xt يُوح. 1‏:‏5. \x*  
\v 20 مَارَّا ونِّي إِتّڭّنْ ثُوعفّْنَا، إِشَارّهْ ثَافَاوْثْ، وَارْ د-إِتِّيسْ شَا غَارْ ثْفَاوْثْ، حِيمَا وَارْ تّْوَاوبّْخنْثْ شَا ثِيمڭَّا نّسْ.  
\v 21 مَاشَا ونِّي إِتّڭّنْ ثِيذتّْ أَذْ د-يَاسْ غَارْ ثْفَاوْثْ، حِيمَا أَذْ بَاننْثْ ثِيمڭَّا نّسْ، أَقَا تّْوَاڭّنْثْ ذِي أَربِّي.“ \x ◘ \xo 3:‏21 \xt أَفا. 5‏:‏8، 13. \x*   
\b  
\m  
\s1 شّْهَاذثْ وِيسّْ ثْنَاينْ ن يُوحَانَّا أَمْسغْضَاصْ  
\m
\v 22 أَوَارْنِي مَانْ أَيَا يُوسَا-د يَاسُوع ذ إِمحْضَارنْ نّسْ غَارْ ثمُّورْثْ ن يَاهُوذِييَّا، إِسّعْذُو ذِينْ شَا ن ڒْوقْثْ أَكِيذْسنْ ؤُشَا ثُوغَا إِسّغْضَاصْ. \x ◘ \xo 3:‏22 \xt يُوح. 4‏:‏1. \x*  
\v 23 ؤُڒَا ذ يُوحَانَّا ثُوغَا إِسّغْضَاصْ ذِي عَايْنُونْ إِ د-يُوسِينْ طَّارْفْ إِ سَالِيمْ، مِينْزِي ذِينِّي أَمَانْ أَطَّاسْ. ؤُسِينْ-د \add إِوْذَانْ\add* ذِينِّي ؤُشَا تّْوَاسّْغضْصنْ، \x ◘ \xo 3:‏23 \xt مت. 3‏:‏6؛ مك. 1‏:‏5؛ لك. 3‏:‏7. \x*  
\v 24 مِينْزِي يُوحَانَّا ثُوغَا عَاذْ وَارْ إِمّنْضَارْ شَا ذِي ڒحْبسْ. \x ◘ \xo 3:‏24 \xt مت. 14‏:‏3. \x*   
\m
\v 25 إِمْسَارْ إِجّْ ن ؤُمْحَارْوضْ جَارْ إِجّنْ زڭْ إِمحْضَارنْ ن يُوحَانَّا ذ إِجّْ ن وُوذَايْ خْ مَامّشْ غَا يِيڒِي ڒُوضُو.  
\v 26 نِيثْنِي ؤُسِينْ-د غَارْ يُوحَانَّا، نَّانْ أَسْ: ”\add أَ\add* أَمْسڒْمَاذْ نّغْ، خْزَارْ، ونِّي أَكِيذكْ إِدْجَانْ خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، ونِّي مِينْ خفْ ثْشهْذذْ، أَقَا ؤُڒَا ذ نتَّا إِسّغْضَاصْ ؤُ مَارَّا تَّاسنْ-د غَارسْ.“ \x ◘ \xo 3:‏26 \xt مت. 3‏:‏11؛ مك. 1‏:‏7؛ لك. 3‏:‏16؛ يُوح. 1‏:‏15، 26، 34. \x*  
\v 27 يَارَّا-د يُوحَانَّا، إِنَّا أَسنْ: ”بْنَاذمْ وَارْ إِزمَّارْ أَذْ إِقْبڒْ ؤُڒَا ذ إِشْثْ ن ثْمسْڒَاشْثْ مَاڒَا وَارْ ذ أَسْ ثمّوْشْ زڭْ ؤُجنَّا.  
\v 28 كنِّيوْ سِيمَانْثْ نْومْ ثْشهّْذمْ بلِّي نشّْ نِّيغْ: ’نشّْ وَارْ دْجِيغْ شَا ذ لْمَاسِيحْ!‘، مَاشَا أَقَا نشّْ تّْوَاسّكّغْ-د زَّاثسْ. \x ◘ \xo 3:‏28 \xt مـَال. 3‏:‏1؛ مت. 11‏:‏10؛ مك. 1‏:‏2؛ لك. 1‏:‏17؛ 7‏:‏27؛ يُوح. 1‏:‏20، 21، 23. \x*  
\v 29 ونِّي غَارْ ثدْجَا ثسْڒِيثْ، نتَّا ذ أَسْڒِي. أَمدُّوكّڒْ ن وسْڒِي ونِّي إِتّْبدَّانْ \add زَّاثسْ\add*، إِتّسْڒَا غَارسْ، إِفَارّحْ س ڒفْرَاحثْ ثَامقّْرَانْثْ س ثْمِيجَّا ن وسْڒِي. س ؤُينِّي، خْزَارْ، أَقَا ثتّْوَاكمّڒْ ڒفْرَاحثْ إِنُو ثَانِيثَا.  
\v 30 إِتّْخصَّا أَذْ إِڭْمَا نتَّا ؤُ نشّْ أَذْ نقْصغْ.  
\v 31 مَاغَارْ ونِّي د-يُوسِينْ زِي سنّجْ، نتَّا سنّجْ إِ مَارَّا. ونِّي إِدْجَانْ زِي ثمُّورْثْ، زِي ثمُّورْثْ إِسَّاوَاڒْ. ونِّي د-يُوسِينْ زڭْ ؤُجنَّا، نتَّا سنّجْ إِ مَارَّا، \x ◘ \xo 3:‏31 \xt يُوح. 8‏:‏23. \x*  
\v 32 ؤُ نتَّا إِشهّذْ زِي مِينْ إِژْرَا ذ زِي مِينْ إِسْڒَا، \add مَاشَا\add* شّْهَاذثْ نّسْ وَارْ ت إِقبِّيڒْ ؤُڒَا ذ إِجّنْ. \x ◘ \xo 3:‏32 \xt يُوح. 5‏:‏30؛ 8‏:‏26؛ 12‏:‏49؛ 14‏:‏10؛ 1 يُوح. 5‏:‏10. \x*  
\v 33 ونِّي إِقبّْڒنْ شّْهَاذثْ نّسْ ذ ونِّي إِسَّارْسنْ طَّابعْ نّسْ ن ؤُشمِّيعْ بلِّي أَقَا أَربِّي ذ ثِيذتّْ. \x ◘ \xo 3:‏33 \xt أَيُوبْ رُوم. 3‏:‏4. \x*  
\v 34 مِينْزِي ونِّي د-إِسّكّْ أَربِّي، إِسَّاوَاڒْ س وَاوَاڒنْ ن أَربِّي، مِينْزِي أَربِّي وَارْ إِتِّيشْ شَا أَرُّوحْ س ڒْمِيزَانْ. \x ◘ \xo 3:‏34 \xt أَفا. 4‏:‏7. \x*  
\v 35 بَابَاسْ إِتّخْسْ مِّيسْ ؤُشَا إِڭَّا أَسْ كُوڒْشِي ذڭْ إِفَاسّنْ نّسْ. \x ◘ \xo 3:‏35 \xt مت. 11‏:‏27؛ 28‏:‏18؛ لك. 10‏:‏22؛ يُوح. 5‏:‏22؛ 17‏:‏2؛ عبر. 2‏:‏8. \x*  
\v 36 ونِّي إِتَّامْننْ ذِي مِّيسْ غَارسْ ثُوذَارْثْ إِتّْذُومَانْ، مَاشَا ونِّي وَارْ إِطِّيعْ شَا مِّيسْ، وَارْ إِژَارّْ ثُوذَارْثْ، \add مَاغَارْ\add* أَغْضَابْ ن أَربِّي أَذْ خَاسْ إِقِّيمْ.“ \x ◘ \xo 3:‏36 \xt يُوح. 3‏:‏36؛ 6‏:‏47؛ 1 يُوح. 5‏:‏10. \x*   
\b  
\b  
\m  
\c 4
\s1 يَاسُوع أَكْ-ذ ثمْغَارْثْ زِي سَامَارِييَا  
\m
\v 1 \add ؤُمِي\add* إِسّنْ يَاسُوع، أَقَا إِفَارِيسِييّنْ سْڒِينْ بلِّي نتَّا إِتّڭّْ ؤُ إِسّْغطَّاصْ إِمحْضَارنْ كْثَارْ زِي يُوحَانَّا \x ◘ \xo 4:‏1 \xt يُوح. 3‏:‏26. \x*  
\v 2 - وَاخَّا يَاسُوع سِيمَانْثْ نّسْ وَارْ إِسّغْضِيصْ شَا، مَاشَا إِمحْضَارنْ نّسْ -  
\v 3 إِفّغْ-د زِي يَاهُوذِييَّا، إِرُوحْ عَاوذْ غَارْ لْجَالِيلْ.  
\v 4 مَاشَا ثُوغَا إِتّْخصَّا أَذْ إِشُوقْ ذِي سَامَارْيَا.  
\v 5 نتَّا يُوسَا-د غَارْ إِشْثْ ن ثنْذِينْثْ ن إِسَامَارِييّنْ، قَّارنْ أَسْ سُوخَارْ، ثنِّي غَارْ طَّارْفْ ن إِيَّارْ إِ إِوْشَا يَاعْقُوبْ إِ مِّيسْ يُوسُوفْ. \x ◘ \xo 4:‏5 \xt أَمز. 33‏:‏19؛ 48‏:‏22؛ ياش. 24‏:‏32. \x*  
\v 6 ثُوغَا ذِينْ أَنُو ن يَاعْقُوبْ. يُوحڒْ يَاسُوع زڭْ إِبْرِيذنْ ؤُشَا إِرُوحْ إِقِّيمْ أَمنِّي غَارْ وَانُو، ثُوغَا ثَاسَاعّثْ ذ ستَّا، \add إِخْسْ أَذْ يِينِي أَزْينْ ن وَاسّْ\add*. \f ◼ \fr 4:‏6 \ft \+bd ’ثُوغَا ثَاسَاعّثْ ذ ستَّا‘\+bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي: ثُوغَا أَزْينْ ن وَاسّْ (ضُّوهْرْ).\f*   
\m
\v 7 ثُوسَا-د إِشْثْ ن ثمْغَارْثْ زِي سَامَارْيَا حِيمَا أَذْ ثَاڭمْ أَمَانْ. يَاسُوع إِنَّا أَسْ: ”أوْشْ أَيِي أَمَانْ، أَذْ سْوغْ!“،  
\v 8 مِينْزِي إِمحْضَارنْ نّسْ ثُوغَا رُوحنْ غَارْ ثنْذِينْثْ مَاحنْذْ أَذْ سْغنْ مَاشَّا إِ يِيخفْ نْسنْ.  
\v 9 ثَامْغَارْثْ ن سَامَارْيَا ثنَّا أَسْ: ”مَامّشْ ثڭِّيذْ ثتَّارذْ زَّايِي أَذْ ثسْوذْ، أَقَا شكْ ذ ؤُذَايْ ؤُ نشّْ ذ ثَامْغَارْثْ زِي سَامَارْيَا؟“ مِينْزِي ؤُذَاينْ وَارْ نُّومنْ تّمْصُورُوفنْ أَكْ-ذ إِمزْذَاغْ ن سَامَارْيَا. \x ◘ \xo 4:‏9 \xt لك. 9‏:‏52، 53؛ يُوح. 8‏:‏48. \x*  
\v 10 يَاسُوع يَارَّا-د، إِنَّا أَسْ: ”مَاعْلِيكْ ثسّْنذْ ثِيموْشَا ن أَربِّي ذ ونِّي ذ أَمْ إِقَّارنْ: ’أوْشْ أَيِي أَذْ سْوغْ!‘، إِڒِي شمْ ثتَّارْ ت زَّايسْ، ؤُشَا نتَّا أَذْ يِيڒِي إِوْشْ أَمْ أَمَانْ إِدَّارنْ.“  
\v 11 ثنَّا أَسْ ثمْغَارْثْ: ”\add أَ\add* سِيذِي، وَارْ غَاركْ إِ زِي غَا ثَاڭْمذْ ؤُشَا أَنُو يُودْجغْ، مَانِيسْ إِ ذ غَا ثَاوْيذْ أَمَانْ إِدَّارنْ؟ \x ◘ \xo 4:‏11 \xt إِرْم. 2‏:‏13. \x*  
\v 12 مَا شكْ ذ أَمقّْرَانْ زِي جذِّيثْنغْ يَاعْقُوبْ ونِّي ذ أَنغْ إِوْشِينْ أَنُو وَانِيثَا، إِسْوَا زَّايسْ، نتَّا ذ ثَارْوَا نّسْ ذ ڒبْهَايمْ نّسْ؟“  
\v 13 يَاسُوع يَارَّا-د، إِنَّا أَسْ: ”مَارَّا ونِّي إِ غَا إِسْونْ زڭْ وَامَانْ-أَ، أَذْ إِفُوذْ عَاوذْ،  
\v 14 مَاشَا ونِّي إِ غَا إِسْونْ زڭْ وَامَانْ إِ ذ أَسْ غَا وْشغْ نشّْ، نتَّا وَارْ إِتّْفَاذِيعمَّارْصْ. مِينْزِي أَمَانْ إِ ذ أَسْ غَا وْشغْ نشّْ، أَذْ ذَايسْ ذوْڒنْ ذ ڒْعُونْصَارْ ن وَامَانْ إِ د إِتّفّْغنْ غَارْ ثُوذَارْثْ إِتّْذُومَانْ.“ \x ◘ \xo 4:‏14 \xt يُوح. 3‏:‏16؛ 6‏:‏27، 35، 54؛ 7‏:‏38. \x*  
\v 15 ثَامْغَارْثْ ثنَّا أَسْ: ”\add أَ\add* سِيذِي، أوْشْ أَيِي أَمَانْ-أَ حِيمَا وَارْ تّْفِيذغْ، وَارْ د-تِّيسغْ عَاذْ ذَا، حِيمَا أَذْ أَڭْمغْ.“   
\m
\v 16 إِنَّا أَسْ يَاسُوع: ”رُوحْ، ڒَاغَا-د إِ ورْيَازْ نّمْ ؤُشَا ذْوڒْ-د ذَانِيثَا.“  
\v 17 نتَّاثْ ثنَّا أَسْ: ”وَارْ غَارِي بُو ورْيَازْ!“ يَاسُوع إِنَّا أَسْ: ”ثسِّيوْڒذْ نِيشَانْ ؤُمِي ثنِّيذْ: ’وَارْ غَارِي بُو ورْيَازْ!‘،  
\v 18 مِينْزِي ثُوغَا غَارمْ خمْسَا ن يرْيَازنْ ذ ونِّي غَارمْ ڒخُّو، وَارْ إِدْجِي بُو ذ أَرْيَازْ نّمْ. مَانْ أَيَا إِ ثنِّيذْ ذ ثِيذتّْ.“   
\m
\v 19 ثَامْغَارْثْ ثنَّا أَسْ: ”\add أَ\add* سِيذِي، تّْوَاڒِيغْ بلِّي شكْ ذ أَنَابِي. \x ◘ \xo 4:‏19 \xt لك. 7‏:‏16؛ 24‏:‏19؛ يُوح. 6‏:‏14. \x*  
\v 20 ڒجْذُوذْ نّغْ سجْذنْ ذڭْ وذْرَارْ-أَ، مَاشَا كنِّيوْ ثقَّارمْ بلِّي ذِي ؤُرْشَالِيمْ مَانِي إِدْجَا ومْشَانْ إِ ذِي إِشُووَّارْ أَذْ نسْجذْ.“ \x ◘ \xo 4:‏20 \xt أَعَوذ. 12‏:‏5، 11؛ 1 إِج. 9‏:‏3؛ 2 إِم. 7‏:‏12. \x*  
\v 21 يَاسُوع إِنَّا أَسْ: ”تِّيقّْ أَيِي، \add أَ\add* ثَامطُّوثْ، أَقَا ثَاسَاعّثْ أَذْ د-ثَاسْ إِ ذِي وَارْ ثْعبّْذمْ بَابَا ؤُڒَا ذڭْ وذْرَارْ-أَ ؤُڒَا ذِي ؤُرْشَالِيمْ.  
\v 22 كنِّيوْ ثْعبّْذمْ مِينْ وَارْ ثسِّينمْ، \add مَاشَا\add* نشِّينْ نْعبّذْ مِينْ نسّنْ، مِينْزِي ثُوذَارْثْ زڭْ وُوذَاينْ. \x ◘ \xo 4:‏22 \xt أَمز. 12‏:‏3؛ 18‏:‏18؛ 22‏:‏18؛ 26‏:‏4؛ 2 إِج. 17‏:‏29؛ عبر. 7‏:‏14. \x*  
\v 23 مَاشَا أَذْ د-ثَاوضْ ثْسَاعّثْ، نتَّاثْ أَقَا-ت ڒخُّو، بلِّي إِنِّي إِعبّْذنْ نِيشَانْ، أَذْعبْذنْ بَابَا ذِي أَرُّوحْ ؤُ ذِي ثِيذتّْ، مِينْزِي بَابَا يَارزُّو إِنِّي ث إِ غَا إِعبْذنْ أَمُّو.  
\v 24 أَربِّي ذ أَرُّوحْ ؤُ إِنِّي ث إِعبّْذنْ، إِتّْخصَّا أَسنْ أَذْعبْذنْ س أَرُّوحْ ذ ثِيذتّْ.“ \x ◘ \xo 4:‏24 \xt 2 كُور. 3‏:‏17. \x*   
\m
\v 25 ثَامْغَارْثْ ثنَّا أَسْ: ”نشّْ سّْنغْ بلِّي أَذْ د-يَاسْ لْمَاسِيحْ. خْمِي د غَا يَاسْ نتَّا، أَذْ أَنغْ إِسّڒْمذْ كُوڒْشِي.“  
\v 26 يَاسُوع إِنَّا أَسْ: ”أَقَا ذ نشّْ، ونِّي كِيمْ إِسَّاوَاڒنْ.“ \x ◘ \xo 4:‏26 \xt يُوح. 9‏:‏37. \x*   
\m
\v 27 أَمْ ثُوغَا إِسَّاوَاڒْ، ؤُسِينْ-د إِمحْضَارنْ نّسْ، تّْعجْبنْ ڒَامِي ث ؤُفِينْ إِسَّاوَاڒْ أَكْ-ذ إِشْثْ ن ثمْغَارْثْ. وَاخَّا أَمنِّي ؤُڒَا ذ إِجّْ وَارْ إِنِي: ”مِينْ ثَارزُّوذْ؟“ نِيغْ: ”مَايمِّي أَكِيذسْ ثسَّاوَاڒذْ؟“  
\v 28 \add خَاسْ ؤُشَا\add* ثجَّا ثمْغَارْثْ أَقدُّوحْ نّسْ س وَامَانْ، ثُويُورْ غَارْ ثنْذِينْثْ، ثنَّا إِ إِوْذَانْ:  
\v 29 ”أَرَاحمْ-د، أَذْ ثْژَارمْ أَرْيَازْ إِ ذ أَيِي إِنَّا مَارَّا مِينْ ڭِّيغْ. مَا \add أَذْ ثَاغْ\add* نتَّا ذ لْمَاسِيحْ؟“  
\v 30 إِوْذَانْ فّْغنْ-د زِي ثنْذِينْثْ، ؤُسِينْ-د غَارسْ.   
\m
\v 31 جَارْ ؤُ جَارْ تَّارنْ \add زَّايسْ\add* إِمحْضَارنْ نّسْ، نَّانْ: ”\add أَ\add* أَمْسڒْمَاذْ نّغْ، أشّْ!“  
\v 32 مَاشَا نتَّا إِنَّا أَسنْ: ”نشّْ أَقَا غَارِي إِجّْ ن مَاشَّا حِيمَا أَذْ زَّايسْ إِتّْوَاشّْ، وَارْ ت ثسِّينمْ شَا كنِّيوْ.“  
\v 33 إِمحْضَارنْ مّْسقْسَانْ جَارْ أَسنْ: ”مَا يِيوْيِي أَسْ-د حذْ شَا ن مَاشَّا؟“  
\v 34 يَاسُوع إِنَّا أَسنْ: ”مَاشَّا إِنُو أَقَا أَذْ ڭّغْ مِينْ إِخْسْ ونِّي ذ أَيِي د-إِسّكّنْ ؤُ أَذْ كمّْڒغْ ڒْخذْمثْ نّسْ.  
\v 35 مَا وَارْ ثقَّارمْ: ’إِقِّيمْ عَاذْ أَربْعَا ن إِيُورنْ ؤُشَا أَذْ د-ثَاسْ صَّابثْ‘؟‘ خْزَارمْ، نشّْ أَذْ أَومْ إِنِيغْ، سْڭعّْذمْ ثِيطَّاوِينْ نْومْ، خْزَارمْ ذڭْ إِيَّارنْ، أَقَا وَارْغنْ، وجْذنْ إِ صَّابثْ. \x ◘ \xo 4:‏35 \xt مت. 9‏:‏37؛ لك. 10‏:‏2. \x*  
\v 36 ونِّي إِمجَّارنْ أَذْ إِكْسِي ڒْمُونثْ نّسْ، إِيْرُو ڒْغِيدْجثْ إِ ثُوذَارْثْ إِتّْذُومَانْ، حِيمَا أَذْ فَارْحنْ جْمِيعْ ونِّي إِزَارّْعنْ ذ ونِّي إِمجَّارنْ.  
\v 37 مِينْزِي ذِي مَانْ أَيَا أَقَا أَوَاڒْ-أَ ذ ثِيذتّْ: ’إِجّنْ أَذْ إِزَارْعْ ؤُ ونّغْنِي أَذْ إِمْجَارْ.‘  
\v 38 نشّْ سّكّغْ-د كنِّيوْ حِيمَا أَذْ ثمْجَارمْ مِينْ ؤُمِي وَارْ ثخْذِيممْ كنِّيوْ. إِنّغْنِي ثُوغَا خدّْمنْ، كنِّيوْ ثُوذْفمْ غَارْ ڒْخذْمثْ نْسنْ.“   
\m
\v 39 أَطَّاسْ ن إِسَامَارِييّنْ زِي ثنْذِينْثْ نِّي ؤُمْننْ زَّايسْ خْ وَاوَاڒْ ن ثمْغَارْثْ إِ ثُوغَا إِشهّْذنْ: ”نتَّا إِنَّا أَيِي مَارَّا مِينْ ڭِّيغْ.“  
\v 40 ڒَامِي غَارسْ د-ؤُسِينْ إِسَامَارِييّنْ نِّي، سّقْسَانْ ث حِيمَا أَكِيذْسنْ إِقِّيمْ، ؤُشَا إِقِّيمْ أَكِيذْسنْ ثْنَاينْ ن وُوسَّانْ ذِينِّي.  
\v 41 ؤُشَا أَطَّاسْ ؤُمْننْ زَّايسْ زِي سِّيبّثْ ن وَاوَاڒْ نّسْ،  
\v 42 نَّانْ إِ ثمْغَارْثْ نِّي: ”نشِّينْ وَارْ نتِّيمنْ شَا عَاذْ زِي مِينْ ذ أَنغْ ثنِّيذْ، مِينْزِي نشِّينْ نسْڒَا إِ-ث س يِيخفْ نّغْ، نسّنْ بلِّي وَا س ثِيذتّْ ذ لْمَاسِيحْ، ونِّي إِتِّيشنْ ثُوذَارْثْ إِ دُّونشْثْ.“   
\b  
\m  
\s1 أَسْڭنْفِي ن مِّيسْ ن ؤُمْسخَّارْ ن ؤُجدْجِيذْ  
\m
\v 43 أَوَارْنِي ثْنَاينْ ن وُوسَّانْ إِفّغْ-د يَاسُوع سّنِّي، إِرُوحْ غَارْ لْجَالِيلْ. \x ◘ \xo 4:‏43 \xt [مت. 8‏:‏5‏-‏13؛ لك. 7‏:‏1‏-‏10]\x*  
\v 44 مِينْزِي يَاسُوع سِيمَانْثْ نّسْ أَقَا إِشْهذْ بلِّي أَنَابِي وَارْ غَارسْ بُو شَّانْ ذِي ثمُّورْثْ نّسْ. \x ◘ \xo 4:‏44 \xt مت. 13‏:‏57؛ مك. 6‏:‏4؛ لك. 4‏:‏24. \x*  
\v 45 ؤُمِي د-يُوسَا غَارْ لْجَالِيلْ، أَرحّْبنْ ث-إِ-د إِجَالِيلِييّنْ، مِينْزِي نِيثْنِي ژْرِينْ مَارَّا مِينْ إِڭَّا ذِي ڒْعِيذْ ذِي ؤُرْشَالِيمْ، مِينْزِي ؤُڒَا ذ نِيثْنِي ؤُسِينْ-د غَارْ ڒْعِيذْ.   
\m
\v 46 يُوسَا-د يَاسُوع عَاوذْ غَارْ \add ثنْذِينْثْ ن\add* قَانَا ذِي لْجَالِيلْ مَانِي يَارَّا أَمَانْ ذ بِينُو. ثُوغَا ذِينْ إِجّْ ن ؤُمْسخَّارْ ن ؤُجدْجِيذْ ذِي كَافَارْنَاحُومْ غَارسْ مِّيسْ إِهْڒشْ. \x ◘ \xo 4:‏46 \xt يُوح. 2‏:‏1، 11. \x*  
\v 47 ڒَامِي إِسْڒَا بلِّي يَاسُوع يُوسَا-د زِي يَاهُوذِييَّا غَارْ لْجَالِيلْ، إِرُوحْ غَارسْ، إِسّقْسَا ث حِيمَا أَذْ د-إِهْوَا مَاحنْذْ أَذْ إِسّْڭنْفَا مِّيسْ، ونِّي ثُوغَا إِڭُّورنْ أَذْ إِمّثْ.  
\v 48 يَاسُوع إِنَّا أَسْ: ”كنِّيوْ وَارْ تِّيمْنمْ شَا مَاڒَا وَارْ ثژْرِيمْ ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ.“ \x ◘ \xo 4:‏48 \xt 1 كُور. 1‏:‏22. \x*  
\v 49 إِنَّا أَسْ ؤُخدَّامْ ن ؤُجدْجِيذْ: ”\add أَ\add* سِيذِي، هْوَا-د قْبڒْ إِ غَا إِمّثْ ؤُحنْجِيرْ إِنُو.“  
\v 50 يَاسُوع إِنَّا أَسْ: ”رُوحْ أَقَا مِّيشْ إِدَّارْ!“ أَرْيَازْ نِّي إِتِّيقّْ ذڭْ وَاوَاڒْ إِ ذ أَسْ إِنَّا يَاسُوع ؤُشَا إِرُوحْ.   
\m
\v 51 ڒَامِي د-إِهْوَا، مّڒْقَانْ أَكِيذسْ إِمْسخَّارنْ نّسْ، خبَّارنْ ث، نَّانْ أَسْ: ”أَقَا مِّيشْ إِدَّارْ“.  
\v 52 إِسّقْسَا ثنْ خْ ثْسَاعّثْ مِينْ ذِي إِڭّنْفَا. نَّانْ أَسْ: ”إِضنَّاضْ غَارْ ثْسَاعّثْ وِيسّْ سبْعَا، \add إِخْسْ أَذْ يِينِي غَارْ ثْسَاعّثْ ثَامزْوَارُوثْ ن ؤُزِيڒْ،\add* ثجَّا خَاسْ ثْمسِّي.“  
\v 53 خنِّي إِسّنْ بَابَاسْ بلِّي أَقَا إِمْسَارْ غَارْ ثْسَاعّثْ إِ ذ أَسْ إِنَّا يَاسُوع: ”أَقَا مِّيشْ إِدَّارْ!“ يُومنْ نتَّا ذ مَارَّا أَيْثْبَابْ ن ثَادَّارْثْ نّسْ.   
\m
\v 54 ثَا ثُوغَا عَاوذْ ذ ڒعْڒَامثْ وِيسّْ ثْنَاينْ إِ إِڭَّا يَاسُوع زڭْ وَامِي د-إِفّغْ زِي يَاهُوذِييَّا غَارْ لْجَالِيلْ.   
\b  
\b  
\m  
\c 5
\s1 أَسْڭنْفِي ن إِجّْ ن ؤُمهْڒُوشْ ذِي بَايْثْ-خِيسْذَا  
\m
\v 1 أَوَارْنِي مَانْ أَيَا يِيوضْ-د ڒْعِيذْ ن وُوذَاينْ ؤُشَا إِڭعّذْ يَاسُوع غَارْ ؤُرْشَالِيمْ. \x ◘ \xo 5:‏1 \xt لَاوِي 23‏:‏2؛ أَعَوذ. 16‏:‏1. \x*  
\v 2 \add غَارْ ثوَّارْثْ ن وُودْجِي\add* ذِي ؤُرْشَالِيمْ ثُوغَا ذِينْ إِشْثْ ن ثْيڒْمَامْثْ ن ؤُسغْضصْ ؤُمِي قَّارنْ س ثْعِيبْرَانِيثْ ’بَايْثْ-خِيسْذَا‘، ثُوغَا غَارسْ خمْسَا ن إِسقِّيفنْ أَكْ-ذ إِكُولْوَارنْ ذ إِپِيلَارنْ.  
\v 3 ذَايْسنْ ثُوغَا إِقِّيمْ إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ ن إِمهْڒَاشْ ذ إِذَارْغَاڒنْ ذ إِقجْذَاحنْ ذ إِنعْضَابنْ، تّْرَاجَانْ أَنْهزِّي ن وَامَانْ.  
\v 4 مِينْزِي زِي ڒْوقْثْ غَارْ ڒْوقْثْ إِهكّْوَا-د إِجّْ ن لْمَالَاكْ غَارْ ثْيڒْمَامْثْ-أَ ن ؤُسغْضصْ، إِسّنْهزَّا أَمَانْ، ؤُ ونِّي إِ د غَا إِهْوَانْ ذ أَمزْوَارُو أَوَارْنِي أَنْهزِّي ن وَامَانْ، أَذْ إِتّْوَاسّْڭنْفَا، مَامّشْ مَا إِدْجَا ڒهْڒَاشْ نّسْ.   
\m
\v 5 ثُوغَا ذِينْ إِجّْ ن بْنَاذمْ ذَايسْ ڒهْڒَاشْ إِ يِيجّْ ن ڒْمِيجَاڒْ ن ثْمنْيَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا.  
\v 6 إِژْرَا يَاسُوع أَرْيَازْ-أَ إِسنّذْ ذِينِّي، إِسّنْ بلِّي ثُوغَا \add إِحْڒشْ أَمُّو\add* أَطَّاسْ زڭْ وَامِي. إِنَّا أَسْ: ”مَا ثخْسذْ أَذْ ثڭّنْفِيذْ؟“  
\v 7 يَارَّا-د خَاسْ ؤُمهْڒُوشْ، إِنَّا: ”وَاهْ، \add أَ\add* سِيذِي، مَاشَا وَارْ غَارِي إِجّنْ ونِّي ذ أَيِي غَا يِيوْينْ غَارْ ثُويڒْمَامْثْ ن ؤُسغْضصْ خْمِي غَا تّْوَاسّنْهزّنْ وَامَانْ. خْمِي تّْرَاحغْ نشّْ، إِهكّْوَا-د ونّغْنِي زَّاثِي.“  
\v 8 يَاسُوع إِنَّا أَسْ: ”كَّارْ، ثكْسِيذْ ثَاسُّوثْ نّشْ، ثُويُورذْ!“ \x ◘ \xo 5:‏8 \xt مت. 9‏:‏6؛ مك. 2‏:‏11؛ لك. 5‏:‏24. \x*  
\v 9 ذغْيَا إِڭّنْفَا بْنَاذمْ نِّي ؤُشَا إِكْسِي ثَاسُّوثْ نّسْ، يُويُورْ. مَانْ أَيَا ثُوغَا ذڭْ وَاسّْ ن سّبْثْ. \x ◘ \xo 5:‏9 \xt يُوح. 9‏:‏14. \x*   
\m
\v 10 نَّانْ وُوذَاينْ إِ ونِّي ثُوغَا إِتّْوَاسّْڭنْفَانْ: ”وَا ذ سّبْثْ، وَارْ غَاركْ بُو تّسْرِيحْ مَاحنْذْ أَذْ ثكْسِيذْ ثَاسُّوثْ نّشْ!“ \x ◘ \xo 5:‏10 \xt ؤُف. 20‏:‏10؛ أَعَوذ. 5‏:‏13؛ إِرْم. 17‏:‏21؛ مت. 12‏:‏2؛ مك. 2‏:‏24؛ لك. 6‏:‏2. \x*  
\v 11 يَارَّا-د، إِنَّا أَسنْ: ”ونِّي ذ أَيِي إِسّْڭنْفَانْ، إِنَّا: ’كْسِي ثَاسُّوثْ نّشْ، ثْرَاحذْ!‘ “  
\v 12 \add خنِّي\add* سّقْسَانْ ث: ”مِينْ إِعْنَا بْنَاذمْ-أَ إِ ذ أَشْ إِنَّانْ: ’كْسِي ثَاسُّوثْ نّشْ، ثْرَاحذْ‘؟“  
\v 13 ونِّي إِتّْوَاسّْڭنْفَانْ وَارْ إِسِّينْ مِينْ إِعْنَا يَاسُوع، مِينْزِي إِنّجْرَا مِينْزِي أَقَا ذِينْ أَطَّاسْ ن ڒْغَاشِي ذڭْ ومْشَانْ نِّي.   
\m
\v 14 أَوَارْنِي مَانْ أَيَا يُوفَا إِ-ث يَاسُوع ذِي زَّاوشْثْ ثَامقّْرَانْثْ، إِنَّا أَسْ: ”خْزَارْ، أَقَا ثڭّنْفِيذْ، وَارْ تّڭّْ بُو دّْنُوبْ عَاذْ، حِيمَا وَارْ ذ أَشْ إِتّمْسَارْ مِينْ إِدْجَانْ ذ أَعفَّانْ زِي مِينْ إِدْجَانْ قْبڒْ.“ \x ◘ \xo 5:‏14 \xt مت. 12‏:‏45؛ يُوح. 8‏:‏11. \x*   
\m
\v 15 أَرْيَازْ إِرُوحْ، إِخبَّارْ ؤُذَاينْ بلِّي ذ يَاسُوع إِ-ث إِسّْڭنْفَانْ.   
\m
\v 16 س ؤُينِّي ذَارّْشنْ وُوذَاينْ خْ يَاسُوع، أَرزُّونْ أَذْ ث نْغنْ، مِينْزِي إِڭَّا مَانْ أَيَا ذِي سّبْثْ.  
\v 17 مَاشَا يَاسُوع يَارَّا-د، إِنَّا أَسنْ: ”أَقَا بَابَا إِخدّمْ أَڒْ يِيضَا ؤُ \add خنِّي\add* نشّْ عَاوذْ أَقَا خدّْمغْ.“ \x ◘ \xo 5:‏17 \xt يُوح. 14‏:‏10. \x*  
\v 18 ذِي سِّيبّثْ-أَ أَرزُّونْ وُوذَاينْ عَاذْ كْثَارْ حِيمَا أَذْ ث نْغنْ، وَارْ إِدْجِي وَاهَا مِينْزِي إِخَاڒفْ سّبْثْ، مَاشَا ؤُڒَا مِينْزِي نتَّا إِنَّا أَقَا أَربِّي ذ بَابَاسْ، إِسّْقُودَّا إِخفْ نّسْ أَكْ-ذ أَربِّي. \x ◘ \xo 5:‏18 \xt يُوح. 7‏:‏19. \x*  
\v 19 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، مِّيسْ وَارْ إِزمَّارْ أَذْ إِڭّْ ؤُڒَا ذ إِشْثْ ن ثْمسْڒَاشْثْ س يِيخفْ نّسْ، مْغِيرْ مَاڒَا إِژْرَا بَابَاسْ إِتّڭّْ إِ-ت. مِينْ مَا إِتّڭّْ بَابَاسْ ؤُڒَا ذ مِّيسْ إِتّڭّْ أَمنِّي. \x ◘ \xo 5:‏19 \xt إِشا. 54‏:‏5؛ يُوح. 3‏:‏30؛ 8‏:‏38؛ 9‏:‏4؛ 10‏:‏30؛ 14‏:‏9؛ 17‏:‏5. \x*  
\v 20 بَابَاسْ إِتّخْسْ مِّيسْ، إِسّْشنْ أَسْ مَارَّا مِينْ إِتّڭّْ، ؤُشَا أَذْ أَسْ إِسّْشنْ ڒخْذَايمْ ثِيمقّْرَانِينْ خْ ثِينَا، حِيمَا أَذْ ثْذهْشمْ. \x ◘ \xo 5:‏20 \xt يُوح. 1‏:‏2؛ 3‏:‏35؛ 7‏:‏16؛ 8‏:‏28؛ 14‏:‏24. \x*  
\v 21 أَمْ مَامّشْ ذ إِسّْنكَّارْ بَابَاسْ إِمتِّيننْ ؤُشَا إِتِّيشْ ثُوذَارْثْ، أَمنِّي ؤُڒَا ذ مِّيسْ إِتِّيشْ ثُوذَارْثْ إِ ونِّي إِخْسْ.  
\v 22 بَابَاسْ وَارْ إِتّْحَاسَابْ ؤُڒَا ذ إِجّْ، مَاشَا إِوْشَا لْحِيسَابْ مَارَّا إِ مِّيسْ \x ◘ \xo 5:‏22 \xt مت. 11‏:‏27؛ يُوح. 3‏:‏35. \x*  
\v 23 حِيمَا أَذْ وقَّارنْ مَارَّا مِّيسْ أَمْ تّْوقَّارنْ بَابَاسْ. ونِّي وَارْ إِتّْوقَّارنْ مِّيسْ وَارْ إِتّْوقَّارْ شَا ؤُڒَا ذ بَابَا ونِّي إِ-ث-إِ-د-إِسّكّنْ. \x ◘ \xo 5:‏23 \xt يُوح. 2‏:‏23. \x*   
\m
\v 24 س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: ونِّي إِتّسْڒَانْ إِ وَاوَاڒْ إِنُو ؤُشَا يُومنْ ذڭْ ونِّي ذ أَيِي د-إِسّكّنْ، غَارسْ ثُوذَارْثْ إِتّْذُومَانْ، وَارْ د-إِتِّيسْ شَا غَارْ لْحِيسَابْ، مَاشَا نتَّا أَقَا إِمُّوطِّي زِي ڒْموْثْ غَارْ ثُوذَارْثْ. \x ◘ \xo 5:‏24 \xt لك. 23‏:‏43؛ يُوح. 3‏:‏18؛ 6‏:‏40، 47؛ 8‏:‏51. \x*  
\v 25 س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: أَذْ د-ثَاسْ ثْسَاعّثْ، أَقَا-ت ڒخُّو، إِ ذِي إِمتِّيننْ أَذْ سْڒنْ ثْمِيجَّا ن مِّيسْ ن أَربِّي ؤُ إِنِّي إِ \add ت\add* غَا إِسْڒنْ، أَذْ دَّارنْ. \x ◘ \xo 5:‏25 \xt أَفا. 2‏:‏1، 5؛ 1 تِيم. 5‏:‏6. \x*  
\v 26 مَاغَارْ أَمْ مَامّشْ بَابَاسْ غَارسْ ثُوذَارْثْ ذِي طّْبِيعثْ ن يِيخفْ نّسْ، أَمُّو إِ إِوْشَا ؤُڒَا إِ مِّيسْ حِيمَا أَذْ غَارسْ ثِيڒِي ثُوذَارْثْ ذِي طّْبِيعثْ ن يِيخفْ نّسْ،  
\v 27 ؤُشَا إِوْشَا أَسْ صُّولْطَا حِيمَا أَذْ إِحَاسبْ، مِينْزِي نتَّا ذ مِّيسْ ن بْنَاذمْ.  
\v 28 وَارْ تّْعجِيبمْ شَا س مَانْ أَيَا، أَقَا أَذْ د-ثَاسْ ثْسَاعّثْ إِ ذِي مَارَّا إِنِّي إِدْجَانْ ذڭْ إِمضْڒَانْ أَذْ سْڒنْ ثْمِيجَّا نّسْ، \x ◘ \xo 5:‏28 \xt 1 تس. 4‏:‏16. \x*  
\v 29 ؤُشَا أَذْ د-فّْغنْ \add زڭْ إِمضْڒَانْ\add*: إِنِّي إِڭِّينْ ثَاصبْحَانْثْ أَذْ كَّارنْ أَذْ رَاحنْ غَارْ ثْنُوكْرَا إِ ثُوذَارْثْ، ؤُ إِنِّي إِڭِّينْ ثُوعفّْنَا أَذْ كَّارنْ، أَذْ رَاحنْ غَارْ ثْنُوكْرَا إِ لْحِيسَابْ. \x ◘ \xo 5:‏29 \xt دَان. 12‏:‏2؛ مت. 25‏:‏34،46. \x*   
\m
\v 30 نشّْ وَارْ زمَّارغْ أَذْ ڭّغْ شَا زڭْ إِخفْ إِنُو، مَاشَا أَمْ مَامّشْ تّسْڒِيغْ، أَذْ حَاسْبغْ ؤُ لْحِيسَابْ إِنُو ذ ڒْحقّْ، مِينْزِي نشّْ وَارْ أَرزُّوغْ مِينْ خْسغْ، مَاشَا مِينْ إِخْسْ ونِّي ذ أَيِي د-إِسّكّنْ. \x ◘ \xo 5:‏30 \xt يُوح. 6‏:‏38. \x*  
\v 31 معْلِيكْ شهّْذغْ إِ إِخفْ إِنُو، إِڒِي أَقَا شّْهَاذثْ إِنُو وَارْ ثدْجِي شَا نِيشَانْ. \x ◘ \xo 5:‏31 \xt يُوح. 8‏:‏14. \x*  
\v 32 أَقَا ذِينْ إِجّنْ نّغْنِي وِي خَافِي إِشهّْذنْ، ؤُ نشّْ سّْنغْ بلِّي شّْهَاذثْ إِ خَافِي إِشهّذْ، أَقَا ذ ثِيذتّْ إِ ثدْجَا. \x ◘ \xo 5:‏32 \xt إِشا. 42‏:‏1؛ مت. 3‏:‏17؛ 17‏:‏5. \x*  
\v 33 كنِّيوْ ثسّكّمْ-د \add شَا ن إِرقَّاسنْ\add* غَارْ يُوحَانَّا ؤُشَا نتَّا إِشْهذْ إِ ثِيذتّْ. \x ◘ \xo 5:‏33 \xt يُوح. 1‏:‏15، 19، 27. \x*  
\v 34 مَاشَا نشّْ وَارْ قبّْڒغْ شَا شّْهَاذثْ ن بْنَاذمْ، مَاشَا نشّْ قَّارغْ \add مَارَّا\add* مَانْ أَيَا حِيمَا أَذْ ثدَّارمْ.  
\v 35 ثُوغَا نتَّا ذ ڒفْنَارْ يَارقّنْ، إِتّْلِيلِّيشنْ، ؤُ كنِّيوْ ثخْسمْ أَذْ ثْفَارْحمْ س ثْفَاوْثْ نّسْ غَارْ إِشْثْ ن ثْسَاعّثْ.  
\v 36 مَاشَا نشّْ غَارِي إِشْثْ ن شّْهَاذثْ ذ ثَامقّْرَانْثْ خْ ثنِّي ن يُوحَانَّا، مِينْزِي ڒخْذَايمْ إِ ذ أَيِي إِوْشَا بَابَا، حِيمَا أَذْ ثنْثْ كمّْڒغْ، ڒخْذَايمْ نِّي إِ تّڭّغْ شهّْذنْثْ سِيمَانْثْ نْسنْثْ أَقَا ذ بَابَا ذ نتَّا إِ ذ أَيِي د-إِسّكّنْ. \x ◘ \xo 5:‏36 \xt يُوح. 10‏:‏25؛ 1 يُوح. 5‏:‏9. \x*  
\v 37 بَابَا، ونِّي ذ أَيِي-د إِسّكّنْ، ذ نتَّا إِ خَافِي إِشهّْذنْ. كنِّيوْعمَّارْصْ وَارْ ثسْڒِيمْ ثْمِيجَّا نّسْ ؤُشَا وَارْ ثژْرِيمْ شَا ؤُذمْ نّسْ، \x ◘ \xo 5:‏37 \xt ؤُف. 33‏:‏20؛ أَعَوذ. 4‏:‏12؛ مت. 3‏:‏17؛ 17‏:‏5؛ مك. 1‏:‏11؛ 9‏:‏7؛ لك. 3‏:‏22؛ 9‏:‏35؛ يُوح. 1‏:‏33؛ 6‏:‏27؛ 8‏:‏18؛ 1 تِيم. 6‏:‏16؛ 2 بُط. 1‏:‏17؛ 1 يُوح. 4‏:‏12. \x*  
\v 38 ؤُشَا أَوَاڒْ نّسْ وَارْ ذَايْومْ إِتّْغِيمِي شَا ڒبْذَا، مِينْزِي كنِّيوْ وَارْ ثتِّيمْننْ شَا ذڭْ ونِّي إِ-ث-إِ-د-إِسّكّنْ.  
\v 39 أَرْزُومْ ذِي ثِيرَا \add إِقدّْسنْ\add*، مِينْزِي إِتّْغِيڒْ أَومْ أَقَا ذَايْسنْثْ ثُوذَارْثْ إِتّْذُومَانْ، ؤُ أَقَا أَثنْثْ ذ إِنِّي إِ خَافِي إِشهّْذنْ. \x ◘ \xo 5:‏39 \xt أَعَوذ. 18‏:‏18؛ إِشا. 34‏:‏16؛ لك. 16‏:‏29؛ 24‏:‏27؛ يُوح. 1‏:‏46؛ ڒخ. 17‏:‏11. \x*  
\v 40 \add وَاخَّا أَمنِّي\add* كنِّيوْ وَارْ ثتّخْسمْ أَذْ غَارِي د-ثَاسمْ حِيمَا أَذْ غَارْومْ ثِيڒِي ثُوذَارْثْ إِتّْذُومَانْ.   
\m
\v 41 وَارْ قبّْڒغْ شَا أَعُودْجِي ن إِوْذَانْ،  
\v 42 مَاشَا سّْنغْ كنِّيوْ، أَقَا كنِّيوْ وَارْ غَارْومْ بُو ثَايْرِي ن أَربِّي ذڭْ إِخفْ نْومْ.  
\v 43 نشّْ ؤُسِيغْ-د س يِيسمْ ن بَابَا، كنِّيوْ وَارْ ذ أَيِي ثْقبّْڒمْ شَا. مَاڒَا يُوسَا-د شَا ن يِيجّنْ س يِيسمْ نّسْ، أَذْ ث ثْقبْڒمْ.  
\v 44 مَامّشْ ثْزمَّارمْ أَذْ ثَامْنمْ، مَاڒَا كنِّيوْ ثتّخْسمْ أَعُودْجِي ن وَايَاوْيَا، مَاشَا وَارْ ثَارزُّومْ شَا خْ ؤُعُودْجِي ن ؤُينِّي ن أَربِّي ذ إِجّنْ؟ \x ◘ \xo 5:‏44 \xt يُوح. 12‏:‏43. \x*  
\v 45 مَا إِتّْغِيڒْ أَومْ أَذْ زَّايْومْ شثْشِيغْ غَارْ بَابَا؟ ونِّي زَّايْومْ إِ غَا إِشثْشَانْ ذ مُوسَا خْ ونِّي ثسّْرُوسَامْ أَسِيثمْ نْومْ.  
\v 46 مِينْزِي معْلِيكْ ثُومْنمْ زِي مُوسَا، إِڒِي ثُومْنمْ ذَايِي عَاوذْ، مِينْزِي نتَّا يُورَا خَافِي. \x ◘ \xo 5:‏46 \xt أَمز. 3‏:‏15؛ 22‏:‏18؛ 26‏:‏4؛ 28‏:‏14؛ أَعَوذ. 18‏:‏18. \x*  
\v 47 مَاڒَا كنِّيوْ وَارْ ثُومِينمْ شَا ذڭْ إِذْلِيسنْ نّسْ، مَامّشْ غَا ثڭّمْ أَذْ ثَامْنمْ ذڭْ وَاوَاڒنْ إِنُو؟“   
\b  
\b  
\m  
\c 6
\s1 لْمُوعْجِيزَا ن ؤُسشِّي ن خمْسَا أَڒَافْ  
\m
\v 1 أَوَارْنِي مَانْ أَيَا إِرُوحْ يَاسُوع غَارْ ؤُجمَّاضْ ن ڒبْحَارْ ن لْجَالِيلْ، ونِّي ؤُمِي قَّارنْ عَاوذْ \add ڒبْحَارْ ن\add* ثِيبِيرِييَاسْ. \x ◘ \xo 6:‏1 \xt [مت. 14‏:‏13‏-‏21؛ مك. 6‏:‏30‏-‏44؛ لك. 9‏:‏10‏-‏17]\x*  
\v 2 إِضْفَارْ إِ-ث-إِ-د إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ، مِينْزِي ژْرِينْ ڒعْڒَامَاثْ إِ إِڭَّا إِ إِمهْڒَاشْ.  
\v 3 ڒخْذنِّي إِڭعّذْ يَاسُوع غَارْ وذْرَارْ ؤُشَا إِقِّيمْ ذِينِّي أَكْ-ذ إِمحْضَارنْ نّسْ.  
\v 4 إِقَارّبْ-د ڒْعِيذْ ن ثْغَارْصْثْ ن ؤُسعْذُو ن وُوذَاينْ. \x ◘ \xo 6:‏4 \xt ؤُف. 12‏:‏18؛ لَاوِي 23‏:‏5، 7؛ ڒخْڒ. 28‏:‏16؛ أَعَوذ. 16‏:‏1. \x*   
\m
\v 5 ڒخْذنِّي إِسّْڭعّذْ يَاسُوع ثِيطَّاوِينْ نّسْ ؤُشَا، ؤُمِي إِژْرَا إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ يُوسَا-د غَارسْ، إِنَّا إِ فِيلِيبُّوسْ: ”مَانِيسْ إِ غَا نْسغْ أَغْرُومْ، حِيمَا أَذْ شّنْ إِنَا؟“ \x ◘ \xo 6:‏5 \xt مت. 14‏:‏14؛ مك. 6‏:‏34؛ لك. 9‏:‏13. \x*  
\v 6 إِنَّا أَمُّو حِيمَا أَذْ ث إِجَارّبْ، مِينْزِي نتَّا إِسّنْ مِينْ غَا يڭّْ.  
\v 7 يَارَّا-د خَاسْ فِيلِيبُّوسْ: ”أَغْرُومْ س مِيثَاينْ ذِينَارْ وَارْ ثنْ إِتّْقذِّي، \add عَاذْ\add* مَاڒَا كُوڒْ إِجّنْ زَّايْسنْ أَذْ إِكْسِي \add مْغِيرْ\add* ذْرُوسْ \add وَاهَا\add*.“  
\v 8 إِجّنْ زڭْ إِمحْضَارنْ نّسْ، نتَّا ذ أَنْذْرَاوُوسْ، ؤُمَاسْ ن شِيمْعُونْ بُوطْرُوسْ، إِنَّا أَسْ:  
\v 9 ”أَقَا ذَا إِجّْ ن ؤُحنْجِيرْ غَارسْ خمْسَا ن ثشْنِيفِينْ ن إِمنْذِي ذ ثْنَاينْ ن إِسڒْمَانْ، مَاشَا مَانْ أَيَا وَارْ إِتّْقذِّي إِ مَارَّا إِنَا!“   
\m
\v 10 يَاسُوع إِنَّا أَسنْ: ”سْغِيممْ إِوْذَانْ.“ ثُوغَا ذِينْ أَطَّاسْ ن أَرْبِيعْ ذڭْ ومْشَانْ نِّي. س ؤُينِّي قِّيمنْ يرْيَازنْ، أَقَا أَثنْ ذِي خمْسَا-أَڒَافْ إِذْسنْ.  
\v 11 يَاسُوع إِكْسِي ثِيشْنِيفِينْ، ؤُ أَوَارْنِي ڒَامِي إِبَاركْ إِ ثنْثْ، إِبْضَا إِ-ثنْثْ خْ يِينِّي \add ذِينْ\add* إِقِّيمنْ. \add إِبْضَا نتَّا\add* أَمنِّي عَاوذْ إِسڒْمَانْ، عْلَاحْسَابْ أَنشْثْ إِخْسنْ \add أَذْ شّنْ\add*. \x ◘ \xo 6:‏11 \xt 1 صم. 9‏:‏13. \x*  
\v 12 ڒَامِي جِّيوْننْ، إِنَّا إِ إِمحْضَارنْ نّسْ: ”يْرُوممْ إِڒقّْوَازْ إِشطّنْ، حِيمَا ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ وَارْ ثتّْضيِّيعْ!“  
\v 13 يْرُونْ ثنْ ؤُشَاعمَّارنْ ثنْعَاشْ ن ثْسُودْجَاثِينْ س إِڒقّْوَازْ نِّي إِشطّنْ غَارْ يِينِّي إِشِّينْ زِي خمْسَا ن ثشْنِيفِينْ ن إِمنْذِي.   
\m
\v 14 ڒَامِي ژْرِينْ إِوْذَانْ ڒعْڒَامثْ إِ إِڭَّا يَاسُوع، نَّانْ: ”وَا ذ ثِيذتّْ ذ أَنَابِي إِ إِڭُّورنْ أَذْ د-يَاسْ غَارْ دُّونشْثْ.“ \x ◘ \xo 6:‏14 \xt أَعَوذ. 18‏:‏15، 18؛ أَعَوذ. 34‏:‏10؛ لك. 7‏:‏16؛ 24‏:‏19؛ يُوح. 4‏:‏19. \x*  
\v 15 ؤُمِي إِسّنْ يَاسُوع، بلِّي أَذْ د-أَسنْ نِيثْنِي، أَذْ ث طّْفنْ حِيمَا أَذْ ث ڭّنْ ذ أَجدْجِيذْ، خنِّي إِنّجْرَا غَارْ وذْرَارْ، حَاشَا نتَّا وحّْذسْ.   
\b  
\m  
\s1 يَاسُوع إِڭُّورْ خْ وَامَانْ ن ڒبْحَارْ  
\m
\v 16 ڒَامِي د-ثوْضَا ثْمذِّيثْ، هْوَانْ-د إِمحْضَارنْ نّسْ غَارْ ڒبْحَارْ، \x ◘ \xo 6:‏16 \xt [مت. 14‏:‏22‏-‏27؛ مك. 6‏:‏45‏-‏52] — مت. 14‏:‏23؛ مك. 6‏:‏47. \x*  
\v 17 ؤُ \add أَوَارْنِي ڒَامِي\add* نْيِينْ ذِي ثْغَارَّابُوثْ، قضْعنْ \add ڒبْحَارْ\add* غَارْ كَافَارْنَاحُومْ. ثْقَارّبْ-د ثَادْجسْثْ ؤُ يَاسُوع ثُوغَا عَاذْ وَارْ غَارْسنْ د-يُوسِي.  
\v 18 ڒبْحَارْ إِنّهْوڒْ خَاسنْ، مِينْزِي أَسمِّيضْ ثُوغَا إِتّْسُوضْ أَطَّاسْ.  
\v 19 أَڒَامِي ثُوغَا قدّْفنْ ڒْقدّْ ن عْڒَاحَاڒْ خمْسَا ؤُ-عِيشْرِينْ أَڒْ ثْڒَاثِينْ ’إِسْثَاذِييّنْ‘، \add عْڒَاحَاڒْ خمْسَا كِيلُومِيثْرْ\add*، ژْرِينْ يَاسُوع إِڭُّورْ خْ ڒبْحَارْ، إِتّْقَارَّابْ-د غَارْ ثْغَارَّابُوثْ نْسنْ، ؤُشَا ڭّْوذنْ. \f ◼ \fr 6:‏19 \ft \+bd ’إِسْثَاذِييّنْ‘\+bd* 
\fp  إِجّْ ن ڒْمڒْعبْ ذِي ڒْوقْثْ ن إِيُونَانِييّنْ ثُوغَا غَارسْ إِشْثْ ثُوزُّوڭَارْثْ ن 185 مِيثْرْ، إِخْسْ أَذْ يِينِي ’إِجّْ ن ؤُسْثَاذِييْ‘.\f*  
\v 20 \add مَاشَا\add* نتَّا إِنَّا أَسنْ: ”أَقَا ذ نشّْ، وَارْ تّڭّْوذمْ شَا.“  
\v 21 نِيثْنِي خْسنْ أَذْ ث سّْقبْڒنْ ذِي ثْغَارَّابُوثْ، ؤُشَا خنِّي ثِيوضْ-د ثْغَارَّابُوثْ ذغْيَا غَارْ ڒْبَارّْ إِ غَارْ إِدْجَا تّْرَاحنْ.   
\m
\v 22 ثِيوشَّا نّسْ إِژْرَا ڒْغَاشِي نِّي إِبدّْ خْ ؤُجمَّاضْ ن ڒبْحَارْ، بلِّي وَارْ ذِينْ ثُوغِي ؤُڒَا ذ إِشْثْ ن ثْغَارَّابُوثْ نّغْنِيثْ مْغِيرْ إِشْثنْ، ثنِّي مَانِي ذَايسْ ؤُذْفنْ إِمحْضَارنْ نّسْ، ؤُ يَاسُوع وَارْ يُوذِيفْ شَا ذِي ثْغَارَّابُوثْ أَكْ-ذ إِمحْضَارنْ نّسْ.  
\v 23 \add مَاشَا\add* ؤُسِينْثْ-إِ-د إِغَارُّوبَا نّغْنِي زِي ثِيبِيرِييَاسْ زَّاثْ إِ ومْشَانْ مَانِي شِّينْ أَغْرُومْ نِّي إِبَاركْ يَاسُوع.  
\v 24 ڒَامِي إِژْرَا ڒْغَاشِي بلِّي يَاسُوع وَارْ ذِينْ إِدْجِي \add عَاذْ\add* ؤُڒَا ذ إِمحْضَارنْ نّسْ، نْيِينْ ؤُڒَا ذ نِيثْنِي ذڭْ إِغَارُّوبَا-يَا ؤُشَا ؤُسِينْ-د غَارْ كَافَارْنَاحُومْ، أَرزُّونْ خْ يَاسُوع.   
\b  
\m  
\s1 يَاسُوع نتَّا ذ أَغْرُومْ إِدَّارنْ  
\m
\v 25 ڒَامِي ث ؤُفِينْ خْ ؤُجمَّاضْ ن ڒبْحَارْ، نَّانْ أَسْ: ”\add أَ\add* أَمْسڒْمَاذْ نّغْ، مڒْمِي د-ثُوسِيذْ ذَا؟“  
\v 26 يَاسُوع يَارَّا-د خَاسنْ، إِنَّا: ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: كنِّيوْ ثَارزُّومْ خَافِي، وَارْ إِدْجِي ؤُمِي ثژْرِيمْ ڒعْڒَامَاثْ، مَاشَا ؤُمِي ثشِّيمْ أَغْرُومْ ؤُشَا ثجِّيوْنمْ.  
\v 27 وَارْ تّْخذْممْ إِ مَاشَّا إِخسَّارنْ، مَاشَا إِ مَاشَّا إِتّْغِيمَانْ إِ ثُوذَارْثْ إِتّْذُومَانْ، ثنِّي ذ أَومْ إِ غَا إِوْشْ مِّيسْ ن بْنَاذمْ، مِينْزِي أَربِّي، بَابَاسْ، إِسَّارْسْ طَّابعْ نّسْ خَاسْ.“ \x ◘ \xo 6:‏27 \xt مت. 3‏:‏17؛ 17‏:‏5؛ مك. 1‏:‏11؛ 9‏:‏7؛ لك. 3‏:‏22؛ 9‏:‏35؛ يُوح. 1‏:‏33؛ 3‏:‏16؛ 4‏:‏14؛ 5‏:‏37؛ 6‏:‏40، 54؛ 8‏:‏18؛ 2 بُط. 1‏:‏17؛ أَسَا. 7‏:‏2؛ 9‏:‏4.\x*  
\v 28 نَّانْ أَسْ: ”مِينْ غَا نڭّْ، حِيمَا أَذْ نڭّْ ڒخْذَايمْ ن أَربِّي؟“  
\v 29 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”ثَا ذ ڒْخذْمثْ ن أَربِّي، أَقَا أَذْ ثَامْنمْ ذڭْ ونِّي د-إِسّكّْ نتَّا.“ \x ◘ \xo 6:‏29 \xt 1 يُوح. 3‏:‏23. \x*  
\v 30 \add خَاسْ ؤُشَا\add* نَّانْ أَسْ: ”مَانْ ڒعْڒَامثْ إِ غَا ثڭّذْ خنِّي حِيمَا أَذْ \add ث\add* نْژَارْ ؤُشَا أَذْ زَّايكْ نَامنْ؟ مَانْ \add ڒْْخذْمثْ\add* إِ غَا ثڭّذْ؟ \x ◘ \xo 6:‏30 \xt مت. 12‏:‏38؛ 16‏:‏1؛ مك. 8‏:‏11؛ لك. 11‏:‏29؛ 1 كُور. 1‏:‏22. \x*  
\v 31 ڒجْذُوذْ نّغْ شِّينْ ’مَانَّا‘ ذِي ڒخْڒَا أَمْ مَامّشْ ثُورَا: ’نتَّا إِوْشَا أَسنْ-د أَغْرُومْ زڭْ ؤُجنَّا، حِيمَا أَذْ ث شّنْ‘.“ \x ◘ \xo 6:‏31 \xt ؤُف. 16‏:‏4، 14؛ ڒخْڒ. 11‏:‏7؛ نَاح. 9‏:‏15؛ إِزهد. 78‏:‏24، 25؛ 1 كُور. 10‏:‏3. \x*   
\m
\v 32 إِنَّا أَسنْ يَاسُوع: ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: وَارْ إِدْجِي ذ مُوسَا إِ ذ أَومْ إِوْشِينْ أَغْرُومْ زڭْ ؤُجنَّا، مَاشَا بَابَا إِتِّيشْ أَومْ أَغْرُومْ ن ثِيذتّْ زڭْ ؤُجنَّا.  
\v 33 مِينْزِي أَغْرُومْ ن أَربِّي ذ نتَّا ونِّي د-إِهْوَانْ زڭْ ؤُجنَّا ؤُشَا إِتِّيشْ ثُوذَارْثْ إِ دُّونشْثْ.“  
\v 34 نَّانْ أَسْ: ”\add أَ\add* سِيذِيثْنغْ، أوْشْ أَنغْ-د ڒبْذَا أَغْرُومْ-أَ.“  
\v 35 يَاسُوع إِنَّا أَسنْ: ”نشّْ ذ أَغْرُومْ إِدَّارنْ. ونِّي غَارِي د غَا يَاسنْ، وَارْ إِتّْڒِيژْعمَّارْصْ، ؤُ ونِّي ذَايِي إِ غَا يَامْننْ، وَارْ إِتّْفِيذِي \add عَاذْ\add*عمَّارْصْ. \x ◘ \xo 6:‏35 \xt إِشا. 55‏:‏1؛ يُوح. 4‏:‏14؛ 7‏:‏37. \x*  
\v 36 مَاشَا نشّْ نِّيغْ أَومْ، \add وَاخَّا\add* كنِّيوْ ثژْرِيمْ أَيِي، وَارْ ثُومِينمْ شَا.  
\v 37 كُوڒْ إِجّْ إِ ذ أَيِي غَا إِوْشْ بَابَا، أَذْ غَارِي د-يَاسْ ؤُ ونِّي غَارِي د غَا يَاسنْ، وَارْ ث سُّوفُّوغغْ شَا غَارْ بَارَّا.  
\v 38 مِينْزِي نشّْ هْوِيغْ-د زڭْ ؤُجنَّا، وَارْ إِدْجِي شَا حِيمَا أَذْ ڭّغْ مِينْ خْسغْ نشّْ، مَاشَا \add حِيمَا أَذْ ڭّغْ\add* مِينْ إِخْسْ ونِّي ذ أَيِي د-إِسّكّنْ. \x ◘ \xo 6:‏38 \xt مت. 26‏:‏39؛ مك. 14‏:‏36؛ لك. 22‏:‏42؛ يُوح. 5‏:‏30. \x*  
\v 39 ذ مَانْ أَيَا مِينْ إِخْسْ ونِّي ذ أَيِي د-إِسّكّنْ، أَقَا نشّْ وَارْ سّْودَّارغْ ؤُڒَا ذ إِجّنْ زڭْ يِينِّي ذ أَيِي إِوْشَا، مَاشَا أَذْ ث-إِ-د-سّْنكَّارغْ ذڭْ وَاسّْ أَنڭَّارُو. \x ◘ \xo 6:‏39 \xt يُوح. 10‏:‏28؛ 17‏:‏12؛ 18‏:‏9. \x*  
\v 40 ذ مَانْ أَيَا مِينْ إِخْسْ بَابَا ونِّي ذ أَيِي د-إِسّكّنْ، أَقَا كُوڒْ إِجّْ ونِّي إِ غَا إِژَارنْ مِّيسْ ؤُشَا أَذْ ذَايسْ يَامنْ، أَذْ غَارسْ ثِيڒِي ثُوذَارْثْ إِتّْذُومَانْ، ؤُشَا نشّْ أَذْ ث-إِ-د-سّْنكَّارغْ ذڭْ وَاسّْ أَنڭَّارُو.“ \x ◘ \xo 6:‏40 \xt يُوح. 3‏:‏16؛ 4‏:‏14؛ 6‏:‏27، 54. \x*   
\m
\v 41 ؤُذَاينْ شثْشَانْ زَّايسْ، مِينْزِي إِنَّا: ”نشّْ ذ أَغْرُومْ إِ د-إِهْوَانْ زڭْ ؤُجنَّا.“  
\v 42 نَّانْ: ”مَا ذ وَانِيثَا وَارْ إِدْجِي بُو ذ يَاسُوع، مِّيسْ ن يُوسُوفْ؟ نشِّينْ نسّنْ بَابَاسْ ذ يمَّاسْ! مَامّشْ إِ غَا يِينِي ورْيَازْ-أَ: ’نشّْ هْوِيغْ-د زڭْ ؤُجنَّا؟‘ “ \x ◘ \xo 6:‏42 \xt مت. 13‏:‏55؛ مك. 6‏:‏3. \x*  
\v 43 يَاسُوع يَارَّا-د خَاسنْ، إِنَّا: ”وَارْ تّْشثْشَامْ شَا جَارْ أَومْ.  
\v 44 وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ غَارِي د-يَاسْ، مْغِيرْ مَاڒَا إِجبْذْ إِ-ث-إِ-د بَابَا ونِّي ذ أَيِي د-إِسّكّنْ ؤُشَا نشّْ أَذْ ث-إِ-د-سّْنكَّارغْ ذڭْ وَاسّْ أَنڭَّارُو. \x ◘ \xo 6:‏44 \xt إِزْڒِي 1‏:‏4؛ يُوح. 6‏:‏65. \x*  
\v 45 أَقَا ثُورَا ذڭْ \add إِذْلِيسنْ ن\add* إِنَابِييّنْ: ’نِيثْنِي مَارَّا أَذْ تّْوَاسّْڒمْذنْ زِي أَربِّي!‘ س ؤُينِّي كُوڒْ إِجّْ ونِّي ذ أَسْ إِسْڒِينْ زِي بَابَا ؤُ إِڒْمذْ إِ-ث زَّايسْ، أَذْ غَارِي د-يَاسْ. \x ◘ \xo 6:‏45 \xt إِشا. 54‏:‏13؛ إِرْم. 31‏:‏33؛ عبر. 8‏:‏10؛ 10‏:‏16. \x*  
\v 46 ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ إِژَارْ بَابَا، مْغِيرْ ونِّي إِدْجَانْ زِي أَربِّي، ذ نتَّا إِ إِتّْوَاڒِينْ بَابَا. \x ◘ \xo 6:‏46 \xt مت. 11‏:‏27؛ لك. 10‏:‏22؛ يُوح. 1‏:‏18؛ 7‏:‏29؛ 8‏:‏19. \x*  
\v 47 س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: ونِّي ذَايِي إِتَّامْننْ، أَذْ غَارسْ ثِيڒِي ثُوذَارْثْ إِتّْذُومَانْ. \x ◘ \xo 6:‏47 \xt يُوح. 3‏:‏16، 36. \x*  
\v 48 نشّْ ذ أَغْرُومْ إِدَّارنْ.  
\v 49 ڒجْذُوذْ نْومْ شِّينْ ’مَانَّا‘ ذِي ڒخْڒَا ؤُشَا مُّوثنْ، \x ◘ \xo 6:‏49 \xt ؤُف. 16‏:‏4؛ ڒخْڒ. 11‏:‏7؛ إِزهد. 78‏:‏24. \x*  
\v 50 \add مَاشَا\add* مَانْ أَيَا ذ أَغْرُومْ إِ د-إِهْوَانْ زڭْ ؤُجنَّا، حِيمَا بْنَاذمْ أَذْ زَّايسْ يشّْ، وَارْ إِتّْمتِّي شَا:  
\v 51 نشّْ ذ أَغْرُومْ إِدَّارنْ إِ د-إِهْوَانْ زڭْ ؤُجنَّا. مَاڒَا إِجّنْ إِشَّا زڭْ وغْرُومْ-أَ، أَذْ إِدَّارْ إِ ڒبْذَا. أَغْرُومْ نِّي إِ غَا وْشغْ نشّْ، نتَّا ذ أَرِّيمثْ إِنُو إِ غَا وْشغْ إِ ثُوذَارْثْ ن دُّونشْثْ.“ \x ◘ \xo 6:‏51 \xt يُوح. 11‏:‏26؛ عبر. 10‏:‏5، 10. \x*   
\m
\v 52 ؤُذَاينْ مّنْغنْ جَارْ أَسنْ، نَّانْ: ”مَامّشْ إِ غَا يڭّْ وَانِيثَا أَذْ أَنغْ إِوْشْ أَرِّيمثْ نّسْ حِيمَا أَذْ \add ت\add* نشّْ؟“ \x ◘ \xo 6:‏52 \xt يُوح. 3‏:‏9. \x*  
\v 53 إِنَّا أَسنْ يَاسُوع: ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: مَاڒَا وَارْ ثتّتّمْ أَرِّيمثْ ن مِّيسْ ن بْنَاذمْ ؤُ وَارْ ثسّسمْ إِذَامّنْ نّسْ، وَارْ غَارْومْ بُو ثُوذَارْثْ ذڭْ إِخفْ نْومْ.  
\v 54 ونِّي إِ غَا إِشّنْ أَرِّيمثْ إِنُو ؤُشَا أَذْ إِسُووْ إِذَامّنْ إِنُو، أَذْ غَارسْ ثِيڒِي ثُوذَارْثْ إِتّْذُومَانْ ؤُ نشّْ أَذْ ث-إِ-د-سّْنكَّارغْ ذڭْ وَاسّْ أَنڭَّارُو. \x ◘ \xo 6:‏54 \xt يُوح. 3‏:‏16؛ 4‏:‏14؛ 6‏:‏27،40. \x*  
\v 55 مِينْزِي أَرِّيمثْ إِنُو ذ مَاشَّا ذ ثِيذتّْ ؤُشَا إِذَامّنْ إِنُو ذ ثِيسِّيثْ ذ ثِيذتّْ.  
\v 56 ونِّي إِ غَا إِشّنْ أَرِّيمثْ إِنُو ؤُشَا أَذْ إِسُو إِذَامّنْ إِنُو، أَذْ ذَايِي إِقِّيمْ ؤُ نشّْ ذَايسْ.  
\v 57 أَمْ مَامّشْ ذ أَيِي د-إِسّكّْ بَابَا إِدَّارنْ ؤُشَا نشّْ دَّارغْ زِي بَابَا، أَمُّو عَاوذْ ونِّي زَّايِي إِ غَا إِشّنْ، أَذْ زَّايِي إِدَّارْ.  
\v 58 وَا ذ أَغْرُومْ إِ د-إِهْوَانْ زڭْ ؤُجنَّا. وَارْ إِدْجِي شَا أَمْ مَامّشْ شِّينْ ڒجْذُوذْ نْومْ ’مَانَّا‘ ؤُشَا مُّوثنْ، ونِّي إِ غَا إِشّنْ أَغْرُومْ-أَ، أَذْ إِدَّارْ إِ ڒبْذَا.“ \x ◘ \xo 6:‏58 \xt يُوح. 3‏:‏13. \x*  
\v 59 إِنَّا مَانْ أَيَا ذِي ثمْزِيذَا، أَمْ ثُوغَا إِسّڒْمَاذْ ذِي كَافَارْنَاحُومْ.   
\b  
\m  
\s1 أَطَّاسْ ن إِمحْضَارنْ بْذَانْ تّڭّْوجّنْ خْ يَاسُوع  
\m
\v 60 أَطَّاسْ ن إِمحْضَارنْ نّسْ، ؤُمِي سْڒِينْ مَانْ أَيَا، نَّانْ: ”أَوَاڒْ-أَ إِقْسحْ. وِي إِزمَّارنْ أَذْ أَسْ إِسڒْ؟“  
\v 61 مَاشَا يَاسُوع إِسّنْ ذڭْ إِخفْ نّسْ، أَقَا إِمحْضَارنْ نّسْ شثْشَانْ خْ مَانْ أَيَا، ؤُشَا إِنَّا أَسنْ: ”مَا أَذْ ثنْقَارْضمْ ذِي مَانْ أَيَا؟  
\v 62 إِ مَامّشْ مَاڒَا ثژْرِيمْ مِّيسْ ن بْنَاذمْ إِتّْڭعَّاذْ غَارْ مَانِي إِڒَا إِدْجَا قْبڒْ؟ \x ◘ \xo 6:‏62 \xt مك. 16‏:‏19؛ لك. 24‏:‏50؛ يُوح. 3‏:‏13؛ ڒخ. 1‏:‏9؛ أَفا. 4‏:‏8. \x*  
\v 63 أَرُّوحْ ذ نتَّا إِسّدَّارنْ، أَرِّيمثْ وَارْ ثْنفّعْ إِ وَالُو. أَوَاڒنْ إِ ذ أَومْ نِّيغْ، أَقَا أَثنْ ذ أَرُّوحْ ذ ثُوذَارْثْ. \x ◘ \xo 6:‏63 \xt 2 كُور. 3‏:‏6. \x*  
\v 64 مَاشَا أَقَا ذِينْ شَا جَارْ أَومْ إِنِّي وَارْ يُومِيننْ.“ مِينْزِي يَاسُوع إِسّنْ زڭْ ؤُمزْوَارُو مَانْ ينْ إِدْجَانْ إِنِّي وَارْ يُومِيننْ ؤُ مَانْ ونْ ث إِ غَا إِغْذَارنْ. \x ◘ \xo 6:‏64 \xt يُوح. 2‏:‏25؛ 13‏:‏11. \x*  
\v 65 إِنَّا أَسنْ: ”س ؤُينِّي نِّيغْ أَومْ: وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ غَارِي د-يَاسْ، مْغِيرْ مَاڒَا ثمّوْشْ أَسْ زِي بَابَا.“ \x ◘ \xo 6:‏65 \xt يُوح. 6‏:‏44. \x*  
\v 66 زِي ڒْوقْثْ نِّي ذوْڒنْ أَطَّاسْ زڭْ إِمحْضَارنْ نّسْ غَارْ ضفَّارْ، وَارْ قِّيمنْ شَا ڭُّورنْ أَكِيذسْ.   
\m
\v 67 إِنَّا يَاسُوع إِ ثنْعَاشْ: ”مَا ؤُڒَا ذ كنِّيوْ ثخْسمْ أَذْ ثُويُورمْ؟“  
\v 68 شِيمْعُونْ بُوطْرُوسْ يَارَّا-د خَاسْ، إِنَّا: ”\add أَ\add* سِيذِي، وِي غَارْ إِ غَا نْرَاحْ؟ شكْ غَاركْ أَوَاڒنْ ن ثُوذَارْثْ إِتّْذُومَانْ، \x ◘ \xo 6:‏68 \xt ڒخ. 5‏:‏20. \x*  
\v 69 ؤُ نشِّينْ نُومنْ ؤُ نسّنْ أَقَا شكْ ذ لْمَاسِيحْ، مِّيسْ ن أَربِّي إِدَّارنْ.“ \x ◘ \xo 6:‏69 \xt مت. 16‏:‏16؛ مك. 8‏:‏29؛ لك. 9‏:‏20؛ يُوح. 11‏:‏27. \x*  
\v 70 يَاسُوع إِنَّا أَسنْ: ”مَا وَارْ إِدْجِي ذ نشّْ إِ كنِّيوْ د-إِخْضَارنْ ذ ثنْعَاشْ؟ ؤُشَا إِجّنْ زَّايْومْ ذ شِّيطَانْ.“ \x ◘ \xo 6:‏70 \xt لك. 6‏:‏13. \x*  
\v 71 إِنَّا مَانْ أَيَا خْ يَاهُوذَا، مِّيسْ ن شِيمْعُونْ إِسْخَارِييُوطِي، مِينْزِي وَانِيثَا ثُوغَا إِخْسْ أَذْ ث إِسلّمْ. نتَّا ذ إِجّنْ زِي ثنْعَاشْ.   
\b  
\b  
\m  
\c 7
\s1 أَيْثْمَاسْ ن يَاسُوع وَارْ ذَايسْ ؤُمِيننْ  
\m
\v 1 أَوَارْنِي مَانْ أَيَا ثُوغَا يَاسُوع إِڭُّورْ ذِي لْجَالِيلْ، وَارْ إِخْسْ أَذْ يُويُورْ ذِي يَاهُوذِييَّا، مِينْزِي ؤُذَاينْ ثُوغَا أَرزُّونْ أَذْ ث نْغنْ.  
\v 2 إِقَارّبْ-د ڒْعِيذْ ن إِعُوشُّوثنْ ن وُوذَاينْ. \x ◘ \xo 7:‏2 \xt لَاوِي 23‏:‏34. \x*  
\v 3 نَّانْ أَسْ أَيْثْمَاسْ: ”فّغْ سَّانِيثَا، رُوحْ غَارْ \add ثمُّورْثْ ن\add* يَاهُوذِييَّا حِيمَا ؤُڒَا ذ إِمحْضَارنْ نّشْ أَذْ ژَترنْ ڒخْذَايمْ نِّي ثتّڭّذْ.  
\v 4 ؤُڒَا ذ إِجّْ وَارْ إِتّڭّْ شَا ن ثْمسْڒَاشْثْ س ثْنُوفّْرَا، مَاڒَا يَارزُّو أَذْ إِسّضْهَارْ إِخفْ نّسْ س بْطَايْطَايْ. مَاڒَا ثڭِّيذْ ثِيمسْڒَايِينْ-أَ، سْشنْ إِخفْ نّشْ إِ دُّونشْثْ.“  
\v 5 مِينْزِي ؤُڒَا ذ أَيْثْمَاسْ وَارْ ذَايسْ ؤُمِيننْ شَا. \x ◘ \xo 7:‏5 \xt مك. 3‏:‏21. \x*  
\v 6 إِنَّا أَسنْ يَاسُوع: ”ڒْوقْثْ إِنُو عَاذْ وَارْ د-ثِيوِيضْ، مَاشَا ڒْوقْثْ نْومْ أَقَا-ت ڒبْذَا أَكِيذْومْ.  
\v 7 دُّونِّيثْ وَارْ ثْزمَّارْ أَذْ كنِّيوْ ثْشَارْهْ، مَاشَا نتَّاثْ ثْشَارْهْ أَيِي، مِينْزِي نشّْ شهّْذغْ خَاسْ بلِّي ڒخْذَايمْ نّسْ ذ ثِيعفَّانِينْ. \x ◘ \xo 7:‏7 \xt يُوح. 3‏:‏19؛ 14‏:‏17؛ 15‏:‏18. \x*  
\v 8 رُوحمْ كنِّيوْ غَارْ ڒْعِيذْ-أَ. نشّْ وَارْ تّْرِيحغْ شَا غَارْ ڒْعِيذْ-أَ، مِينْزِي ڒْوقْثْ إِنُو عَاذْ وَارْ ثْكمّڒْ.“ \x ◘ \xo 7:‏8 \xt يُوح. 8‏:‏20. \x*  
\v 9 أَوَارْنِي ڒَامِي إِنَّا أَمُّو، إِقِّيمْ ذِي لْجَالِيلْ.   
\b  
\m  
\s1 يَاسُوع إِڭُّورْ غَارْ ڒْعِيذْ ن إِعُوشُّوثنْ  
\m
\v 10 مَاشَا ؤُمِي ڭعّْذنْ أَيْثْمَاسْ غَارْ ڒْعِيذْ، إِرُوحْ ؤُڒَا ذ نتَّا غَارْ ڒْعِيذْ، وَارْ إِدْجِي س بْطَايْطَايْ، مَاشَا إِڭَّا أَخْمِي إِنُّوفَارْ.  
\v 11 ؤُذَاينْ أَرزُّونْ خَاسْ ذِي ڒْعِيذْ، نَّانْ: ”مَانِي إِدْجَا وَانِيثَا؟“ \x ◘ \xo 7:‏11 \xt يُوح. 11‏:‏56. \x*  
\v 12 أَطَّاسْ زِي ڒْغَاشِي ثمْثُومنْ خَاسْ. شَا \add زَّايْسنْ\add* نَّانْ: ”نتَّا ذ أَصبْحَانْ“ مَاشَا إِنّغْنِي نَّانْ: ”لَّ، مَاغَارْ إِسّْخَارِّيقْ خْ ڒْغَاشِي!“ \x ◘ \xo 7:‏12 \xt مت. 21‏:‏46؛ لك. 7‏:‏16؛ يُوح. 6‏:‏14؛ 9‏:‏16؛ 10‏:‏19. \x*  
\v 13 مَاشَا ؤُڒَا ذ إِجّْ وَارْ خَاسْ إِسِّيوڒْ س بْطَايْطَايْ زِي سِّيبّثْ ن ثِيڭّْوُوذِي زڭْ وُوذَاينْ. \x ◘ \xo 7:‏13 \xt يُوح. 9‏:‏22؛ 12‏:‏42؛ 19‏:‏38. \x*   
\m
\v 14 مَاشَا أَڒَامِي إِعْذُو وزْينْ ن ڒْعِيذْ، إِڭعّذْ يَاسُوع غَارْ زَّاوشْثْ ثَامقّْرَانْثْ، إِسّڒْمَاذْ \add ذِينْ\add*.  
\v 15 ؤُذَاينْ ذهْشنْ، نَّانْ: ”مَامّشْ إِڭَّا ورْيَازْ-أَ إِسّنْ إِذْلِيسنْ أَمْ وَارْ إِغْرِي شَا؟“  
\v 16 يَاسُوع يَارَّا-د، إِنَّا: ”ثَاغُورِي إِنُو وَارْ ثدْجِي شَا إِنُو، مَاشَا ن ونِّي ذ أَيِي د-إِسّكّنْ. \x ◘ \xo 7:‏16 \xt يُوح. 3‏:‏11؛ 8‏:‏28؛ 12‏:‏49؛ 14‏:‏10، 24. \x*  
\v 17 مَاڒَا إِجّنْ إِخْسْ أَذْ إِڭّْ مِينْ إِخْسْ نتَّا، أَذْ إِسّنْ مَا أَقَا ثَاغُورِي-يَا زِي أَربِّي نِيغْ أَقَا سَّاوَاڒغْ عْلَاحْسَابْ ڒْخَاضَارْ إِنُو.  
\v 18 ونِّي إِسَّاوَاڒنْ زڭْ ؤُخَارّصْ ن ڒْخَاضَارْ ن يِيخفْ نّسْ، يَارزُّو أَعُودْجِي نّسْ، مَاشَا ونِّي يَارزُّونْ أَعُودْجِي ن ونِّي ث-إِ-د إِسّكّنْ، أَقَا نتَّا ذ ثِيذتّْ، وَارْ ذَايسْ بُو ڒْغشّْ.  
\v 19 مَا وَارْ إِدْجِي ذ مُوسَا إِ ذ أَومْ إِوْشِينْ شَّارِيعَا؟ مَاشَا ؤُڒَا ذ إِجّْ زَّايْومْ وَارْ إِتّڭّْ شَّارِيعَا؟ إِ مَايمِّي \add خنِّي\add* ثَارزُّومْ أَذْ أَيِي ثنْغمْ؟“ \x ◘ \xo 7:‏19 \xt ؤُف. 20‏:‏1؛ 24‏:‏3؛ مت. 12‏:‏14؛ مك. 3‏:‏6؛ يُوح. 5‏:‏18؛ 10‏:‏39؛ 11‏:‏53؛ ڒخ. 7‏:‏53. \x*   
\m
\v 20 ڒْغَاشِي يَارَّا-د، نِيثْنِي نَّانْ: ”ذَايكْ إِجّْ ن شِّيطَانْ، وِي يَارزُّونْ أَذْ شكْ نْغنْ؟“ \x ◘ \xo 7:‏20 \xt يُوح. 8‏:‏48، 52؛ 10‏:‏20. \x*  
\v 21 يَاسُوع يَارَّا-د، إِنَّا أَسنْ: ”ڭِّيغْ إِشْثْ ن ڒْخذْمثْ ؤُشَا كنِّيوْ ثتّْبهْثمْ مَارَّا.  
\v 22 إِ ؤُيَا مُوسَا إِوْشَا أَومْ-د أَخْثَانْ، وَارْ إِدْجِي مِينْزِي أَخْثَانْ زِي مُوسَا إِ يدْجَا، مَاشَا \add مِينْزِي أَخْثَانْ إِدْجَا\add* زِي ڒجْذُوذْ نْومْ، ؤُ \add خنِّي\add* ثْختّْنمْ إِ بْنَاذمْ ذِي سّبْثْ. \x ◘ \xo 7:‏22 \xt لَاوِي 12‏:‏3؛ أَمز. 17‏:‏10. \x*  
\v 23 مَاڒَا إِقْبڒْ بْنَاذمْ أَذْ إِتّْوَاخْثنْ ذڭْ وَاسّْ ن سّبْثْ، حِيمَا وَارْ ثتّْوَارژِّي شَّارِيعَا ن مُوسَا، مَامّشْ إِ خَافِي إِ غَا ثْشثْشَامْ ڒَامِي سّْڭنْفِيغْ بْنَاذمْ إِكْمڒْ ذڭْ وَاسّْ ن سّبْثْ؟  
\v 24 وَارْ حكّْممْ خْ ثقْشُورْثْ \add ن بْنَاذمْ\add*، مَاشَا حكْممْ س يِيجّْ ن ڒْحُوكْمْ إِسڭّْذنْ.“ \x ◘ \xo 7:‏24 \xt أَعَوذ. 1‏:‏16، 17؛ أَوڒن. 24‏:‏23؛ يَاع. 2‏:‏1. \x*   
\b  
\m  
\s1 مَا يَاسُوع نتَّا ذ لْمَاسِيحْ؟  
\m
\v 25 نَّانْ إِرْيَازنْ زِي ؤُرْشَالِيمْ: ”مَا وَارْ إِدْجِي ذ وَا إِ يَارزُّونْ أَذْ ث نْغنْ؟  
\v 26 مَاشَا خْزَارْ، إِسَّاوَاڒْ س بْطَايْطَايْ، وَارْ ذ أَسْ قَّارنْ وَالُو. أَذْ ثَاغْ أَقَا سّْننْ إِمْغَارنْ \add ن ڒْڭنْسْ\add* نِيشَانْ بلِّي س ثِيذتّْ وَانِيثَا ذ لْمَاسِيحْ؟  
\v 27 مَاشَا نسّنْ وَا، مَانِيسْ نتَّا، مَاشَا خْمِي د غَا يَاسْ لْمَاسِيحْ، ؤُڒَا ذ إِجّْ وَارْ إِسِّينْ مَانِيسْ نتَّا.“ \x ◘ \xo 7:‏27 \xt مت. 13‏:‏55؛ مك. 6‏:‏3؛ لك. 4‏:‏22. \x*  
\v 28 ڒَامِي ثُوغَا إِسّڒْمَاذْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، إِسّْڭعّذْ يَاسُوع ثْمِيجَّا نّسْ س جّهْذْ، إِنَّا: ”كنِّيوْ ثسّْنمْ أَيِي ؤُ ثسّْنمْ مَانِيسْ نشّْ. نشّْ وَارْ د-ؤُسِيغْ س ڒْخَاضَارْ ن يِيخفْ إِنُو، مَاشَا ونِّي ذ أَيِي د-إِسّكّنْ أَقَا-ث ذ ثِيذتّْ، كنِّيوْ وَارْ ث ثسِّينمْ شَا. \x ◘ \xo 7:‏28 \xt يُوح. 5‏:‏43؛ 8‏:‏26، 42؛ رُوم. 3‏:‏4. \x*  
\v 29 مَاشَا نشّْ سّْنغْ ث، مِينْزِي نشّْ زَّايسْ ؤُ نتَّا ذ ونِّي ذ أَيِي-د إِسّكّنْ.“ \x ◘ \xo 7:‏29 \xt يُوح. 10‏:‏15. \x*   
\m
\v 30 خنِّي أَرزُّونْ أَذْ ث طّْفنْ، مَاشَا ؤُڒَا ذ إِجّْ وَارْ خَاسْ إِسَّارْسْ أَفُوسْ، مِينْزِي ثَاسَاعّثْ نّسْ وَارْ د-ثِيوضْ عَاذْ. \x ◘ \xo 7:‏30 \xt مك. 11‏:‏18؛ لك. 19‏:‏47؛ 20‏:‏19؛ يُوح. 7‏:‏19؛ 8‏:‏20، 37. \x*   
\m
\v 31 أَطَّاسْ زِي ڒْغَاشِي ؤُمْننْ زَّايسْ، نَّانْ: ”خْمِي د غَا يَاسْ لْمَاسِيحْ، مَا أَذْ إِڭّْ ڒعْڒَامَاثْ كْثَارْ زِي ثِينَا إِ إِڭَّا وَا؟“ \x ◘ \xo 7:‏31 \xt يُوح. 8‏:‏30. \x*   
\b  
\m
\v 32 سْڒِينْ إِفَارِيسِييّنْ مَارَّا مِينْ خَاسْ إِثمْثنْ ڒْغَاشِي. ؤُشَا نِيثْنِي ذ إِمقّْرَاننْ ن إِكهَّاننْ سّكّنْ-د إِعسَّاسنْ حِيمَا أَذْ ث طّْفنْ.  
\v 33 يَاسُوع إِنَّا: ”نشّْ أَذْ كِيذْومْ قِّيمغْ ذْرُوسْ ن ڒْوقْثْ عَاذْ، \add خنِّي\add* أَذْ رَاحغْ غَارْ ونِّي ذ أَيِي د-إِسّكّنْ. \x ◘ \xo 7:‏33 \xt يُوح. 16‏:‏16. \x*  
\v 34 أَذْ خَافِي ثَارْزُومْ، وَارْ ذَايِي ثتِّيفمْ، ؤُ مَانِي غَا إِڒِيغْ نشّْ، وَارْ ثْزمَّارمْ أَذْ د-ثَاذْفمْ.“ \x ◘ \xo 7:‏34 \xt يُوح. 8‏:‏21؛ 13‏:‏33. \x*  
\v 35 نَّانْ وُوذَاينْ جَارْ أَسنْ: ”مَانِي غَا إِرَاحْ نتَّا أَڒَامِي وَارْ نْزمَّارْ أَذْ ث نَافْ. مَا خنِّي إِخْسْ أَذْ إِرَاحْ غَارْ ثمُّورَا ن ڒڭْنُوسْ؟ مَا إِخْسْ أَذْ إِسّڒْمذْ إِ لْكُوفَّارْ؟  
\v 36 مِينْ إِعْنَا وَاوَاڒْ-أَ إِ إِنَّا: ’أَذْ خَافِي ثَارْزُومْ، وَارْ ذَايِي ثتّطِّيفمْ!‘، ؤُ ’مَانِي غَا إِڒِيغْ نشّْ، وَارْ ثْزمَّارمْ أَذْ د-ثَاذْفمْ‘؟“   
\b  
\m  
\s1 يَاسُوع ذ ڒْعُونْصَارْ ن وَامَانْ إِدَّارنْ  
\m
\v 37 ذڭْ وَاسّْ أَمقّْرَانْ، أَسّْ أَنڭَّارُو ن ڒْعِيذْ، \add إِكَّارْ\add* إِبدّْ-د يَاسُوع، إِڒَاغَا، إِنَّا: ”مَاڒَا إِفُوذْ حذْ، أجّْ إِ-ث أَذْ غَارِي د-يَاسْ، أَذْ إِسُو. \x ◘ \xo 7:‏37 \xt لَاوِي 23‏:‏36؛ إِشا. 55‏:‏1؛ يُوح. 6‏:‏35؛ أَسَا. 22‏:‏17. \x*  
\v 38 ونِّي ذَايِي إِ غَا يَامْننْ، أَمْ مَامّشْ نَّانْثْ ثِيرَا \add إِقدّْسنْ\add*: أَذْ زَّايسْ أَزّْڒنْ إِغزْرَانْ ن وَامَانْ إِدَّارنْ!“ \x ◘ \xo 7:‏38 \xt إِشا. 12‏:‏3. \x*  
\v 39 إِنَّا مَانْ أَيَا خْ أَرُّوحْ إِ غَا قبْڒنْ إِنِّي ذَايسْ إِتَّامْننْ. مِينْزِي أَرُّوحْ \add إِقدّْسنْ\add* وَارْ ذ أَسنْ إِمّوْشْ \add عَاذْ\add*، مِينْزِي يَاسُوع وَارْ إِتّْوَاسّْعُودْجِي عَاذْ. \x ◘ \xo 7:‏39 \xt إِشا. 44‏:‏3؛ يُووِ. 3‏:‏1؛ ڒخ. 2‏:‏17. \x*   
\m
\v 40 أَطَّاسْ زِي ڒْغَاشِي، ؤُمِي سْڒِينْ أَوَاڒْ-أَ، نَّانْ: ”ذ وَا ذ أَنَابِي س ثِيذتّْ!“ \x ◘ \xo 7:‏40 \xt مت. 21‏:‏46؛ لك. 7‏:‏16؛ يُوح. 6‏:‏14. \x*  
\v 41 إِنّغْنِي نَّانْ: ”وَا ذ لْمَاسِيحْ!“، مَاشَا شَا نّغْنِي \add زَّايْسنْ\add* نَّانْ: ”مَا أَذْ د-يَاسْ لْمَاسِيحْ زِي لْجَالِيلْ؟ \x ◘ \xo 7:‏41 \xt يُوح. 1‏:‏47؛ 4‏:‏42. \x*  
\v 42 مَا وَارْ قَّارنْثْ ثِيرَا \add إِقدّْسنْ\add*، أَقَا لْمَاسِيحْ أَذْ د-يَاسْ زِي زَّارِيعثْ ن ذَاوُوذْ، زِي بَايْثْ-لَاحْمْ، زِي ذْشَارْ ن ذَاوُوذْ؟“ \x ◘ \xo 7:‏42 \xt إِزهد. 132‏:‏11؛ مِيخَا 5‏:‏1؛ مت. 2‏:‏6. \x*  
\v 43 ؤُشَا إِمْسَارْ ؤُمْسبْضِي ن ڒْغَاشِي ذِي سِّيبّثْ نّسْ.  
\v 44 شَا زَّايْسنْ خْسنْ أَذْ ث طّْفنْ، مَاشَا ؤُڒَا ذ إِجّْ وَارْ خَاسْ إِسَّارْسْ إِفَاسّنْ.   
\m
\v 45 خنِّي ذوْڒنْ-د إِعسَّاسنْ نِّي غَارْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِفَارِيسِييّنْ. إِكهَّاننْ نَّانْ أَسنْ: ”مَايمِّي وَارْ ث-إِ-د-ثِيوْيمْ؟“  
\v 46 أَرِّينْ-د خَاسنْ إِعسَّاسنْ: ”عمَّارْصْ وَارْ إِسِّيوڒْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ أَمْ مَامّشْ \add إِسَّاوَاڒْ\add* ورْيَازْ-أَ!“  
\v 47 نَّانْ أَسنْ إِفَارِيسِييّنْ: ”مَا ؤُڒَا ذ كنِّيوْ تّْوَاخذْعمْ \add زَّايسْ\add*؟  
\v 48 مَا خنِّي ذِينْ شَا ن إِجّنْ زڭْ إِمقّْرَاننْ \add ن ڒْڭنْسْ\add* نِيغْ زڭْ إِفَارِيسِييّنْ يُومنْ زَّايسْ؟ \x ◘ \xo 7:‏48 \xt إِشا. 33‏:‏18؛ يُوح. 12‏:‏42؛ 1 كُور. 1‏:‏20؛ 2‏:‏8. \x*  
\v 49 مَاشَا ڒْغَاشِي-يَا إِ وَارْ إِسِّيننْ شَا شَّارِيعَا، أَقَا إِتّْوَانْعڒْ.“  
\v 50 نِيكُوذِيمُوسْ، ونِّي ثُوغَا ذ إِجّنْ زَّايْسنْ ؤُ ونِّي د-يُوسِينْ غَارْ يَاسُوع س دْجِيڒثْ، إِنَّا أَسنْ: \x ◘ \xo 7:‏50 \xt يُوح. 3‏:‏2؛ 19‏:‏39. \x*  
\v 51 ”مَا أَذْ ثحْكمْ شَّارِيعَا نّغْ خْ إِجّْ ن بْنَاذمْ، بْڒَا مَا أَذْ زَّايسْ سْڒنْ، أَذْ سّْننْ مِينْ إِڭَّا؟“ \x ◘ \xo 7:‏51 \xt ؤُف. 23‏:‏1؛ لَاوِي 19‏:‏15؛ أَعَوذ. 1‏:‏17؛ 17‏:‏8؛ 19‏:‏15. \x*  
\v 52 أَرِّينْ-د، نَّانْ أَسْ: ”مَا ؤُڒَا ذ شكْ \add أَذْ ثَاغْ\add* زِي لْجَالِيلْ؟ أَرْزُو، خْزَارْ، ؤُڒَا ذ إِجّْ ن ؤُنَابِي وَارْ د-إِتّكّْ شَا زِي لْجَالِيلْ.“  
\v 53 \add خَاسْ ؤُشَا\add* إِرُوحْ كُوڒْ إِجّنْ غَارْ ثَادَّارْثْ نّسْ. مَاشَا يَاسُوع إِرُوحْ غَارْ وذْرَارْ ن زِّيثُونْ.   
\b  
\b  
\m  
\c 8
\s1 ثَامْغَارْثْ ثتّْوَاطّفْ ثتّڭّْ زِّينَا  
\m
\v 1 ...  
\v 2 ذِي صّْبحْ يُوسَا-د عَاوذْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ، ؤُسِينْ-د غَارسْ إِوْذَانْ مَارَّا. \add خنِّي\add* أَمْ إِقِّيمْ، إِبْذَا إِسّڒْمَاذْ إِ-ثنْ.  
\v 3 إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ إِوْينْ أَسْ-د إِشْثْ ن ثمْغَارْثْ، ثتّْوَاطّفْ ثتّڭّْ زِّينَا. سّْبدّنْ ت ذِي ڒْوسْطْ،  
\v 4 نَّانْ أَسْ: ”\add أَ\add* أَمْسغَّارْ، ثَامْغَارْثْ-أَ ثتّْوَاطّفْ س بْطَايْطَايْ، ثتّڭّْ زِّينَا.  
\v 5 إِوصَّا مُوسَا ذِي شَّارِيعَا أَذْ نَارْجمْ \add ثِيمْغَارِينْ\add* أَمْ ثَانِيثَا. مِينْ غَا ثِينِيذْ شكْ؟“ \x ◘ \xo 8:‏5 \xt لَاوِي 20‏:‏10؛ أَعَوذ. 22‏:‏22. \x*  
\v 6 نَّانْ أَسْ أَيَا حِيمَا أَذْ ث جَارّْبنْ، حِيمَا أَذْ غَارْسنْ ثِيڒِي مِينْزِي خَاسْ إِ غَا شثْشَانْ. مَاشَا يَاسُوع يُوضَارْ سْوَادَّايْ، يُورَا \add س ؤُضَاضْ نّسْ\add* ذِي ثمُّورْثْ.   
\m
\v 7 ڒَامِي قِّيمنْ أَمُّو ث تّسّقْسَانْ، إِبدّْ، إِنَّا أَسنْ: ”وِي زَّايْومْ إِدْجَانْ بْڒَا دّْنُوبْ، أَذْ خَاسْ إِنْضَارْ أَژْرُو أَمزْوَارُو.“ \x ◘ \xo 8:‏7 \xt أَعَوذ. 17‏:‏7. \x*  
\v 8 خنِّي يُوضَارْ عَاوذْ سْوَادَّايْ ؤُشَا يُورَا ذِي ثمُّورْثْ. \x ◘ \xo 8:‏8 \xt إِرْم. 17‏:‏13\x*  
\v 9 ڒَامِي سْڒِينْ مَانْ أَيَا، فّْغنْ إِجّنْ أَوَارْنِي ونّغْنِي، إِمقّْرَاننْ ذ أَمزْوَارُو. ثَامْغَارْثْ نِّي إِبدّنْ ذِي ڒْوسْطْ جِّينْ ت وحّْذسْ.  
\v 10 ڒخْذنِّي يَاسُوع إِكَّارْ، إِنَّا إِ ثمْغَارْثْ: ”مَانِي دْجَانْ نِيثْنِي؟ مَا وَارْ شمْ إِحَاكمْ ؤُڒَا ذ إِجّنْ؟“  
\v 11 نتَّاثْ ثنَّا: ”ؤُڒَا ذ إِجّْ، \add أَ\add* سِيذِي!“ يَاسُوع إِنَّا أَسْ: ”ؤُڒَا ذ نشّْ وَارْ شمْ تّْحَاكَامغْ شَا. رُوحْ، وَارْ تّْعَاوَاذْ أَذْ ثڭّذْ دّْنُوبْ زِي سَّا ثْسَاونْثْ!“ \x ◘ \xo 8:‏11 \xt يُوح. 5‏:‏14. \x*   
\b  
\m  
\s1 يَاسُوع ذ ثَافَاوْثْ ن دُّونشْثْ  
\m
\v 12 إِسِّيوڒْ يَاسُوع عَاوذْ أَكِيذْسنْ، إِنَّا: ”نشّْ ذ ثَافَاوْثْ ن دُّونشْثْ. ونِّي ذ أَيِي غَا إِضْفَارنْ، وَارْ إِڭُّورْعمَّارْصْ ذِي ثَادْجسْثْ، مَاشَا أَذْ يَافْ ثْفَاوْثْ ن ثُوذَارْثْ.“ \x ◘ \xo 8:‏12 \xt إِشا. 42‏:‏6، 16؛ يُوح. 1‏:‏9؛ 9‏:‏5؛ 12‏:‏35، 36. \x*   
\m
\v 13 نَّانْ أَسْ إِفَارِيسِييّنْ: ”شكْ ثْشهّْذذْ خْ يِيخفْ نّشْ، شّْهَاذثْ نّشْ وَارْ ثدْجِي شَا ذ ثِيذتّْ.“  
\v 14 يَاسُوع يَارَّا-د، إِنَّا أَسنْ: ”عَاذْ مَاڒَا نشّْ شهّْذغْ خْ يِيخفْ إِنُو، شّْهَاذثْ إِنُو أَقَا ذ ثِيذتّْ، مِينْزِي نشّْ سّْنغْ مَانِيسْ د-ؤُسِيغْ ؤُ مَانِي غَا رَاحغْ، مَاشَا كنِّيوْ وَارْ ثسِّينمْ شَا مَانِيسْ د-ؤُسِيغْ ؤُڒَا مَانِي غَا رَاحغْ. \x ◘ \xo 8:‏14 \xt يُوح. 5‏:‏31. \x*  
\v 15 كنِّيوْ ثتّْحَاكَاممْ عْلَاحْسَابْ دَّاثْ، نشّْ وَارْ تّْحَاكَامغْ ؤُڒَا خْ إِجّنْ.  
\v 16 ؤُ نشّْ، مَاڒَا حَاكْمغْ، أَذْ يِيڒِي ڒحْكَامْ إِنُو ذ ثِيذتّْ، مِينْزِي نشّْ وَارْ دْجِيغْ بُو وحّْذِي، مَاشَا نشّْ ذ بَابَا ونِّي ذ أَيِي د-إِسّكّنْ.  
\v 17 ثُورَا عَاوذْ ذِي شَّارِيعَا نْومْ، بلِّي شّْهَاذثْ ن ثْنَاينْ ن إِوْذَانْ ذ ثِيذتّْ. \x ◘ \xo 8:‏17 \xt ڒخْڒ. 35‏:‏30؛ أَعَوذ. 17‏:‏6؛ 19‏:‏15؛ مت. 18‏:‏16؛ 2 كُور. 13‏:‏1؛ عبر. 10‏:‏28. \x*  
\v 18 نشّْ ذ ونِّي إِشهّْذنْ خْ يِيخفْ إِنُو، ؤُشَا ؤُڒَا ذ بَابَا ونِّي ذ أَيِي-د إِسّكّنْ، إِشْهذْ خَافِي.“ \x ◘ \xo 8:‏18 \xt مت. 3‏:‏17؛ 17‏:‏5؛ مك. 1‏:‏11؛ 9‏:‏7؛ لك. 3‏:‏22؛ 9‏:‏35؛ يُوح. 1‏:‏33؛ 5‏:‏37؛ 6‏:‏27. \x*  
\v 19 نِيثْنِي نَّانْ أَسْ: ”مَانِي إِدْجَا بَابَاشْ؟“ يَاسُوع يَارَّا-د، إِنَّا أَسنْ: ”كنِّيوْ وَارْ ذ أَيِي ثسِّينمْ شَا ؤُ وَارْ ثسِّينمْ بَابَا. معْلِيكْ كنِّيوْ ذ أَيِي ثسّْنمْ، أَذْ ثِيڒِي ثسّْنمْ ؤُڒَا ذ بَابَا.“ \x ◘ \xo 8:‏19 \xt يُوح. 14‏:‏9؛ 16‏:‏3. \x*   
\m
\v 20 إِنَّا أَوَاڒنْ-أَ ذِي مَانِي ثُوغَا ڒخْزنْ ن صّذْقثْ، أَمْ ثُوغَا إِسّڒْمَاذْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ. وَارْ ث إِطِّيفْ ؤُڒَا ذ إِجّْ، مِينْزِي ثَاسَاعّثْ نّسْ ثُوغَا عَاذْ وَارْ د-ثِيوِيضْ. \x ◘ \xo 8:‏20 \xt يُوح. 7‏:‏30. \x*   
\m
\v 21 يَاسُوع إِنَّا أَسنْ عَاوذْ: ”نشّْ أَذْ رَاحغْ، كنِّيوْ أَذْ خَافِي ثَارْزُومْ، أَذْ ثمّْثمْ ذِي دّْنُوبْ نْومْ. مَانِي غَا رَاحغْ نشّْ، وَارْ ثْزمَّارمْ كنِّيوْ أَذْ د-ثَاسمْ.“ \x ◘ \xo 8:‏21 \xt يُوح. 7‏:‏34؛ 13‏:‏33. \x*  
\v 22 ؤُذَاينْ نَّانْ: ”مَا أَذْ إِنغْ إِخفْ نّسْ \add ڒخُّو\add*، مِينْزِي نتَّا إِنَّا: ’مَانِي غَا رَاحغْ نشّْ، وَارْ ثْزمَّارمْ كنِّيوْ أَذْ د-ثَاسمْ‘؟“  
\v 23 نتَّا إِنَّا أَسنْ: ”كنِّيوْ زِي سْوَادَّايْ، نشّْ زِي سنّجْ، كنِّيوْ زِي دُّونشْثْ-أَ، مَاشَا نشّْ وَارْ دْجِيغْ شَا زِي دُّونشْثْ-أَ. \x ◘ \xo 8:‏23 \xt يُوح. 3‏:‏31. \x*  
\v 24 نشّْ نِّيغْ أَومْ، أَذْ ثمّْثمْ ذِي دّْنُوبْ نْومْ، مَاغَارْ مَاڒَا وَارْ ثُومِينمْ شَا أَقَا ذ نشّْ، أَذْ ثمّْثمْ ذِي دّْنُوبْ نْومْ.“ \x ◘ \xo 8:‏24 \xt يُوح. 8‏:‏21. \x*  
\v 25 ؤُذَاينْ نَّانْ: ”مِينْ ثعْنِيذْ شكْ؟“ يَاسُوع إِنَّا أَسنْ: ”وَاخَّا نشّْ بْذِيغْ أَذْ كِيذْومْ سِّيوْڒغْ -  
\v 26 \add ؤُشَا\add* نشّْ غَارِي أَطَّاسْ ن ثْمسْڒَايِينْ إِ خفْ زمَّارغْ أَذْ خَاومْ سِّيوْڒغْ ؤُشَا أَذْ خَاومْ حكْمغْ - \add إِتّْخصَّا عَاذْ أَذْ ثسّْنمْ،\add* أَقَا ونِّي ذ أَيِي د-إِسّكّنْ أَقَا-ث ذ ثِيذتّْ، ؤُشَا مِينْ زَّايسْ سْڒِيغْ، أَذْ ث إِنِيغْ إِ دُّونشْثْ.“ \x ◘ \xo 8:‏26 \xt يُوح. 7‏:‏28؛ 15‏:‏15؛ رُوم. 3‏:‏4. \x*  
\v 27 نِيثْنِي وَارْ فْهِيمنْ شَا، بلِّي ثُوغَا إِسَّاوَاڒْ أَكِيذْسنْ خْ بَابَاسْ.  
\v 28 يَاسُوع إِنَّا أَسنْ عَاوذْ: ”خْمِي غَا ثسّْڭعّْذمْ مِّيسْ ن بْنَاذمْ، أَذْ ثْفهْممْ بلِّي أَقَا ذ نشّْ، ؤُ بلِّي وَارْ تّڭّغْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ زڭْ إِخفْ إِنُو، مَاشَا سَّاوَاڒغْ أَمْ مَامّشْ ذ أَيِي إِسّڒْمذْ بَابَا. \x ◘ \xo 8:‏28 \xt ڒخْڒ. 21‏:‏9؛ 2 إِج. 18‏:‏4؛ يُوح. 3‏:‏11، 14؛ 7‏:‏16؛ 12‏:‏32، 49؛ 14‏:‏10. \x*  
\v 29 ونِّي ذ أَيِي د-إِسّكّنْ أَقَا-ث أَكِيذِي. بَابَا وَارْ ذ أَيِي إِجِّي شَا وحّْذِي، مِينْزِي تّڭّغْ ڒبْذَا مِينْ ث يَارْضَانْ.“ \x ◘ \xo 8:‏29 \xt يُوح. 14‏:‏10؛ 16‏:‏32. \x*  
\v 30 ؤُمِي ثُوغَا إِسَّاوَاڒْ خْ ثْمسْڒَايِينْ-أَ، ؤُمْننْ ذَايسْ أَطَّاسْ. \x ◘ \xo 8:‏30 \xt يُوح. 7‏:‏31. \x*   
\b  
\m  
\s1 أَيْثْ ن إِبْرَاهِيمْ  
\m
\v 31 خنِّي إِنَّا يَاسُوع إِ وُوذَاينْ نِّي ذَايسْ يُومْننْ: ”مَاڒَا ثقِّيممْ ثطّْفمْ ذڭْ وَاوَاڒْ إِنُو، أَذْ ثِيڒِيمْ س ثِيذتّْ ذ إِمحْضَارنْ إِنُو،  
\v 32 ؤُشَا أَذْ ثسّْنمْ ثِيذتّْ ؤُشَا ثِيذتّْ أَذْ كنِّيوْ ثْحَارّْ.“ \x ◘ \xo 8:‏32 \xt رُوم. 6‏:‏18؛ ڭال. 5‏:‏1؛ 1 بُط. 2‏:‏16. \x*  
\v 33 نَّانْ أَسْ: ”نشِّينْ ذ زَّارِيعثْ ن إِبْرَاهِيمْ،عمَّارْصْ وَارْ نعْبِيذْ حذْ س ثسْمُوغِي. مَامّشْ ثْزمَّارذْ أَذْ ثِينِيذْ: ’كنِّيوْ أَذْ ثتّْوَاحَارّمْ‘؟“ \x ◘ \xo 8:‏33 \xt مت. 3‏:‏9. \x*  
\v 34 يَاسُوع يَارَّا-د خَاسنْ: ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، مَارَّا ونِّي إِتّڭّنْ دّْنُوبْ نتَّا ذ أَمْسخَّارْ ن دّْنُوبْ. \x ◘ \xo 8:‏34 \xt رُوم. 6‏:‏20؛ 2 بُط. 2‏:‏1. \x*  
\v 35 أَمْسخَّارْ وَارْ إِتّْغِيمِي شَا ذِي ثَادَّارْثْ ڒبْذَا، مَاشَا مِّيسْ أَذْ ذِينْ إِقِّيمْ إِ ڒبْذَا.  
\v 36 خْمِي كنِّيوْ إِ غَا إِحَارّْ مِّيسْ، أَذْ ثِيڒِيمْ س ثِيذتّْ ذ إِحُورِّييّنْ. \x ◘ \xo 8:‏36 \xt رُوم. 8‏:‏2. \x*   
\m
\v 37 نشّْ سّْنغْ، أَقَا كنِّيوْ ذ ثَارْوَا ن إِبْرَاهِيمْ، مَاشَا كنِّيوْ ثَارزُّومْ أَذْ أَيِي ثنْغمْ، مِينْزِي أَوَاڒْ إِنُو وَارْ ثْزمَّارمْ أَذْ ث ثْفهْممْ.  
\v 38 نشّْ سَّاوَاڒغْ س مِينْ ژْرِيغْ زِي بَابَا. ؤُڒَا ذ كنِّيوْ ثتّڭّمْ زِي مِينْ ثژْرِيمْ زِي بَابَاثْومْ.“ \x ◘ \xo 8:‏38 \xt يُوح. 3‏:‏11؛ 7‏:‏16؛ 12‏:‏49؛ 14‏:‏10، 24. \x*  
\v 39 أَرِّينْ-د، نَّانْ أَسْ: ”بَابَاثْنغْ ذ إِبْرَاهِيمْ.“ إِنَّا أَسنْ يَاسُوع: ”مَاعْلِيكْ كنِّيوْ ثدْجِيمْ ذ ثَارْوَا ن إِبْرَاهِيمْ، أَذْ يِيڒِي أَقَا ثتّڭّمْ ڒخْذَايمْ ن إِبْرَاهِيمْ. \x ◘ \xo 8:‏39 \xt رُوم. 2‏:‏28؛ 9‏:‏7. \x*  
\v 40 مَاشَا ڒخُّو ثَارزُّومْ أَذْ أَيِي ثنْغمْ، نشّْ ذ إِجّْ ن بْنَاذمْ إِ ثُوغَا أَكِيذْومْ إِسَّاوَاڒنْ س ثِيذتّْ إِ سْڒِيغْ زِي أَربِّي. مَانْ أَيَا وَارْ ث إِڭِّي شَا إِبْرَاهِيمْ. \x ◘ \xo 8:‏40 \xt يُوح. 17‏:‏17. \x*  
\v 41 كنِّيوْ ثتّڭّمْ ڒخْذَايمْ ن بَابَاثْومْ.“ نِيثْنِي نَّانْ أَسْ: ”نشِّينْ وَارْ د-نخْڒِيقْ شَا زِي فَارْقْ-شّْغڒْ، أَقَا غَارْنغْ إِجّنْ ونِّي ذ بَابَاثْنغْ، أَقَا-ث ذ أَربِّي.“   
\b  
\m  
\s1 أَيْثْ ن إِبْڒِيسْ  
\m
\v 42 إِنَّا أَسنْ يَاسُوع: ”مَاعْلِيكْ أَربِّي ذ بَابَاثْومْ، إِڒِي أَقَا ثخْسمْ أَيِي، مِينْزِي نشّْ فّْغغْ-د زِي أَربِّي. نشّْ وَارْ د-ؤُسِيغْ شَا زڭْ إِخفْ إِنُو، مَاشَا نتَّا إِسّكّْ أَيِي-د. \x ◘ \xo 8:‏42 \xt يُوح. 5‏:‏43؛ 7‏:‏29. \x*  
\v 43 مَايمِّي وَارْ ثفْهِيممْ إِ وَاوَاڒنْ إِنُو؟ مِينْزِي كنِّيوْ وَارْ ثْزمَّارمْ أَذْ ثسْڒمْ إِ وَاوَاڒْ\add أنْ\add* إِنُو!  
\v 44 أَقَا كنِّيوْ \add ثفّْغمْ\add* زِي بَابَاثْومْ، إِبْڒِيسْ، ؤُشَا ثخْسمْ أَذْ ثڭّمْ إِمژْرَانْ ن بَابَاثْومْ. نتَّا ثُوغَا إِنقّْ إِوْذَانْ زڭْ ؤُمزْوَارُو ؤُ وَارْ إِبدّْ ذِي ثِيذتّْ، مِينْزِي وَارْ ذَايسْ بُو ثِيذتّْ. مڒْمِي مَا إِسَّاوَاڒْ س ؤُخَارِّيقْ، إِسَّاوَاڒْ س مِينْ ذَايسْ، مِينْزِي نتَّا ذ بُو-إِخَارِّيقنْ ؤُڒَا ذ بَابَاسْ ن ؤُخَارِّيقْ. \x ◘ \xo 8:‏44 \xt أَمز. 3‏:‏1؛ 2 كُور. 11‏:‏3؛ 1 يُوح. 3‏:‏8. \x*  
\v 45 مَاشَا ؤُمِي نشّْ قَّارغْ أَومْ ثِيذتّْ، كنِّيوْ وَارْ ذَايِي ثتِّيمْنمْ شَا.  
\v 46 وِي زَّايْومْ أَذْ أَيِي إِسّقْنعْ خْ دّْنُوبْ؟ ؤُمِي قَّارغْ ثِيذتّْ، مَايمِّي وَارْ ذَايِي ثتِّيمْنمْ شَا؟  
\v 47 ونِّي إِدْجَانْ زِي أَربِّي، إِتّسْڒَا إِ وَاوَاڒنْ ن أَربِّي. مِينْزِي كنِّيوْ وَارْ ثدْجِيمْ شَا زِي أَربِّي، س ؤُينِّي كنِّيوْ وَارْ ثتّسْڒِيمْ شَا.“ \x ◘ \xo 8:‏47 \xt يُوح. 6‏:‏37؛ 10‏:‏26، 27؛ 1 يُوح. 4‏:‏6. \x*   
\b  
\m  
\s1 يَاسُوع ثُوغَا-ث ذِينْ قْبڒْ إِبْرَاهِيمْ  
\m
\v 48 ؤُذَاينْ أَرِّينْ-د، نَّانْ أَسْ: ”مَا وَارْ إِدْجِي نِيشَانْ ؤُمِي ننَّا، أَقَا شكْ زِي سَامَارْيَا ؤُ ذَايكْ إِجّْ ن شِّيطَانْ؟“ \x ◘ \xo 8:‏48 \xt يُوح. 7‏:‏20؛ 10‏:‏20. \x*  
\v 49 يَاسُوع يَارَّا-د، إِنَّا: ”نشّْ وَارْ ذَايِي ؤُڒَا ذ إِجّْ ن شِّيطَانْ، مَاشَا نشّْ تّْوقَّارغْ بَابَا، ؤُشَا كنِّيوْ ثسّحْقَارَامْ أَيِي. \x ◘ \xo 8:‏49 \xt يُوح. 7‏:‏18. \x*  
\v 50 نشّْ وَارْ أَرزُّوغْ شَا أَعُودْجِي إِنُو. أَقَا ذِينْ إِجّنْ إِ خَاسْ يَارزُّونْ ذ ونِّي إِ غَا إِحكْمنْ.  
\v 51 س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: مَاڒَا شَا ن يِيجّنْ إِطّفْ ذڭْ وَاوَاڒْ إِنُو،عمَّارْصْ وَارْ إِتّْوِيڒِي ڒْموْثْ إِ ڒبْذَا.“ \x ◘ \xo 8:‏51 \xt يُوح. 5‏:‏24؛ 11‏:‏25. \x*  
\v 52 نَّانْ أَسْ وُوذَاينْ: ”ڒخُّو نسّنْ بلِّي ذَايكْ إِجّْ ن شِّيطَانْ. أَقَا إِبْرَاهِيمْ ذ إِنَابِييّنْ مُّوثنْ. شكْ ثقَّارذْ: ’مَاڒَا شَا ن يِيجّنْ إِطّفْ ذڭْ وَاوَاڒْ إِنُو،عمَّارْصْ أَذْ إِقَّاسْ ڒْموْثْ إِ ڒبْذَا!‘  
\v 53 مَا شكْ ثمْغَارذْ خْ جذِّيثْنغْ إِبْرَاهِيمْ ونِّي إِمُّوثنْ، ؤُڒَا خْ إِنَابِييّنْ نِّي إِمُّوثنْ؟ مِينْ ثْحسْبذْ إِخفْ نّشْ؟“ \x ◘ \xo 8:‏53 \xt عبر. 11‏:‏13. \x*  
\v 54 إِنَّا أَسنْ يَاسُوع: ”مَاڒَا نشّْ سّْعُودْجِيغْ إِخفْ إِنُو، أَعُودْجِي إِنُو وَارْ إِدْجِي ذ وَالُو. بَابَا، أَقَا إِسّْعُودْجْ أَيِي، ونِّي خفْ ثقَّارمْ: ’نتَّا ذ أَربِّي نّغْ!‘  
\v 55 كنِّيوْ وَارْ ث ثسِّينمْ، مَاشَا نشّْ أَقَا سّْنغْ ث. مَاڒَا نِّيغْ: ’وَارْ ث سِّينغْ!‘، أَذْ إِڒِيغْ نشّْ ذ بُو-إِخَارِّيقنْ أَمْ كنِّيوْ. مَاشَا نشّْ سّْنغْ ث ؤُ تّطّْفغْ ذڭْ وَاوَاڒْ نّسْ.  
\v 56 جذِّيثْومْ إِبْرَاهِيمْ ثُوغَا إِتّْرَاجَا س ڒفْرَاحثْ حِيمَا أَذْ إِژَارْ أَسّْ إِنُو، ؤُشَا إِژْرَا إِ-ث، إِفَارْحْ.“ \x ◘ \xo 8:‏56 \xt أَمز. 17‏:‏17؛ لك. 10‏:‏24؛ عبر. 11‏:‏13. \x*  
\v 57 نَّانْ أَسْ وُوذَاينْ: ”عَاذْ وَارْ غَاركْ بُو خمْسِينْ ن إِسڭّْوُوسَا، مَامّشْ ثڭِّيذْ ثژْرِيذْ إِبْرَاهِيمْ؟“  
\v 58 إِنَّا أَسنْ يَاسُوع: ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، قْبڒْ مَا ثُوغَا إِبْرَاهِيمْ، ثُوغَا نشّْ دْجِيغْ.“  
\v 59 \add خنِّي\add* كْسِينْ إِژْرَا حِيمَا أَذْ ث أَرجْمنْ. مَاشَا يَاسُوع إِسّْنُوفَّارْ إِخفْ نّسْ ؤُشَا إِفّغْ زِي زَّاوشْثْ ثَامقّْرَانْثْ \add أَمْ\add* إِشُوقْ ذِي ڒْوسْطْ نْسنْ، ؤُشَا \add أَمُّو إِ\add* إِرُوحْ. \x ◘ \xo 8:‏59 \xt لك. 4‏:‏29؛ يُوح. 10‏:‏31، 39؛ 11‏:‏8. \x*   
\b  
\b  
\m  
\c 9
\s1 أَسْڭنْفِي ن إِجّنْ ونِّي ذ أَذَارْغَاڒْ زڭْ وَامِي د-إِخْڒقْ  
\m
\v 1 ؤُمِي خَاسنْ د-إِكَّا، إِژْرَا إِجّْ ن ورْيَازْ ثُوغَا ذ أَذَارْغَاڒْ زڭْ وَامِي د-إِخْڒقْ.  
\v 2 إِمحْضَارنْ نّسْ سّقْسَانْ ث، نَّانْ: ”\add أَ\add* أَمْسڒْمَاذْ نّغْ، وِي إِخْضَانْ، مَا ذ وَا نِيغْ لْوَالِيذِينْ نّسْ، أَڒَامِي د-إِخْڒقْ ذ أَذَارْغَاڒْ؟“  
\v 3 يَاسُوع إِنَّا أَسنْ: ”ؤُڒَا ذ نتَّا وَارْ إِخْضِي ؤُڒَا ذ لْوَالِيذِينْ نّسْ، مَاشَا \add مَانْ أَيَا أَقَا إِمْسَارْ\add*، حِيمَا أَذْ ذَايسْ ضْهَارنْثْ ڒخْذَايمْ ن أَربِّي.  
\v 4 إِشُووَّارْ أَذْ خذْمغْ ڒخْذَايمْ ن ونِّي ذ أَيِي د-إِسّكّنْ مَاحنْذْ عَاذْ ذ أَزِيڒْ. أَذْ د-ثَاسْ ثَادْجسْثْ مَانِي وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ إِخْذمْ.  
\v 5 مِينْثْرَا نشّْ أَقَا أَيِي ذِي دُّونشْثْ، نشّْ ذ ثَافَاوْثْ ن دُّونشْثْ.“ \x ◘ \xo 9:‏5 \xt إِشا. 42‏:‏6؛ لك. 2‏:‏32؛ يُوح. 1‏:‏9؛ 8‏:‏12؛ 12‏:‏35،46؛ ڒخ. 13‏:‏47. \x*  
\v 6 أَوَارْنِي ڒَامِي إِنَّا أَمُّو، إِسُّوسفْ ذِي ثمُّورْثْ، إِڭَّا أَبدْجَاعْ زڭْ إِكُوفَّانْ نِّي ؤُشَا إِحنّشْ زَّايسْ ثِيطَّاوِينْ ن ؤُذَارْغَاڒْ س ؤُبدْجَاعْ. \x ◘ \xo 9:‏6 \xt مك. 8‏:‏23. \x*  
\v 7 \add خَاسْ ؤُشَا\add* إِنَّا أَسْ: ”رُوحْ، ثسِّيرْذذْ ذِي ثُويڒْمَامْثْ ن ؤُسغْضصْ ن سِيلُووَامْ!“ إِرُوحْ، إِسِّيرْذْ، إِذْوڒْ إِتّْوَاڒَا. \f ◼ \fr 9:‏7 \ft \+bd ’سِيلُووَامْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’إِتّْوَاسّكّنْ‘.\f*   
\m
\v 8 جِّيرَانْ ذ يِينِّي ثُوغَا ث إِژْرِينْ قْبڒْ إِتّتَّارْ، نَّانْ: ”مَا وَارْ إِدْجِي ذ وَا ذ ونِّي ثُوغَا إِتّْغِيمَانْ إِتّتَّارْ؟“ \x ◘ \xo 9:‏8 \xt ڒخ. 3‏:‏2. \x*  
\v 9 شَا زَّايْسنْ نَّانْ: ”أَقَا ذ نتَّا!“ نَّانْ إِنّغْنِي: ”لَّ، مَاشَا إِتَّاوِي-د ذَايسْ!“ مَاشَا نتَّا \add س يِيخفْ نّسْ\add* إِنَّا: ”أَقَا ذ نشّْ!“  
\v 10 نَّانْ أَسْ: ”مَامّشْ \add ثمْسَارْ\add* تّْوَارزْمنْثْ ثِيطَّاوِينْ نّشْ؟“  
\v 11 يَارَّا-د، إِنَّا أَسنْ: ”بْنَاذمْ ؤُمِي قَّارنْ يَاسُوع، إِڭَّا أَبدْجَاعْ، إِحنّشْ ثِيطَّاوِينْ إِنُو ؤُشَا إِنَّا أَيِي: ’رُوحْ غَارْ ثُويڒْمَامْثْ ن سِيلُووَامْ، ثسِّيرْذذْ!‘ خنِّي رُوحغْ، سِّيرْذغْ ؤُشَا ذوْڒغْ تّْوَاڒِيغْ.“  
\v 12 نَّانْ أَسْ: ”مَانِي إِدْجَا نتَّا؟“ إِنَّا: ”وَارْ سِّينغْ.“   
\m
\v 13 أَوْينْ-د ونِّي ثُوغَا إِدْجَا قْبڒْ ذ أَذَارْغَاڒْ، غَارْ إِفَارِيسِييّنْ.  
\v 14 ثُوغَا ذ سّبْثْ ڒَامِي إِڭَّا يَاسُوع أَبدْجَاعْ ؤُ يَارْزمْ أَسْ ثِيطَّاوِينْ نّسْ. \x ◘ \xo 9:‏14 \xt مت. 12‏:‏1؛ مك. 2‏:‏23؛ لك. 6‏:‏1؛ يُوح. 5‏:‏9. \x*  
\v 15 سّقْسَانْ ث إِفَارِيسِييّنْ عَاوذْ: ”مَامّشْ ثْذوْڒذْ ثتّْوَاڒِيذْ؟“ يَارَّا-د خَاسنْ: ”إِڭَّا أَبدْجَاعْ خْ ثِيطَّاوِينْ إِنُو، خنِّي سِّيرْذغْ ؤُشَا ذوْڒغْ تّْوَاڒِيغْ.“  
\v 16 شَا زڭْ إِفَارِيسِييّنْ نَّانْ: ”بْنَاذمْ-أَ وَارْ إِدْجِي شَا زِي أَربِّي، مِينْزِي نتَّا وَارْ إِتّْوقَّارْ شَا سّبْثْ.“ شَا نّغْنِي نَّانْ: ”مَامّشْ إِزمَّارْ إِجّْ ن بْنَاذمْ ذ أَعفَّانْ أَذْ إِڭّْ ڒعْڒَامَاثْ أَمْ ثِينَا؟“ ؤُشَا إِمْسَارْ ؤُبطُّو جَارْ أَسنْ. \x ◘ \xo 9:‏16 \xt يُوح. 3‏:‏2؛ 7‏:‏12؛ 9‏:‏33؛ 10‏:‏19. \x*  
\v 17 نَّانْ عَاوذْ إِ ؤُذَارْغَاڒْ: ”مِينْ خَاسْ ثقَّارذْ شكْ، أَڒَامِي يَارْزمْ ثِيطَّاوِينْ نّشْ؟“ نتَّا إِنَّا أَسنْ: ”أَقَا-ث ذ أَنَابِي!“ \x ◘ \xo 9:‏17 \xt لك. 7‏:‏16؛ 24‏:‏19؛ يُوح. 4‏:‏19؛ 6‏:‏14. \x*   
\m
\v 18 مَاشَا ؤُذَاينْ وَارْ زَّايسْ ؤُمِيننْ شَا بلِّي نتَّا ثُوغَا ذ أَذَارْغَاڒْ ؤُشَا إِذْوڒْ إِتّْوَاڒَا، أَڒَامِي ذ ڒَاغَانْ خْ لْوَالِيذِينْ ن ونِّي إِذوْڒنْ إِتّْوَاڒَا.  
\v 19 سّقْسَانْ ثنْ: ”مَا وَا ذ مِّيثْومْ مِينْ خفْ ثقَّارمْ أَقَا إِتّْوَاخْڒقْ-د ذ أَذَارْغَاڒْ؟ إِ مَامّشْ إِڭَّا إِتّْوَاڒَا ڒخُّو؟“  
\v 20 أَرِّينْ-د لْوَالِيذِينْ نّسْ، نَّانْ: ”نشِّينْ نسّنْ بلِّي وَا ذ مِّيثْنغْ، أَقَا إِتّْوَاخْڒقْ-د ذ أَذَارْغَاڒْ،  
\v 21 مَاشَا مَامّشْ إِڭَّا إِتّْوَاڒَا ڒخُّو، وَارْ نسِّينْ، ؤُ وِي ذ أَسْ يَارزْمنْ ثِيطَّاوِينْ نّسْ وَارْ ث نسِّينْ شَا \add عَاوذْ\add*. سقْسَامْ ث سِيمَانْثْ نّسْ، نتَّا أَقَا ذ أَبْڒِيغْ، أَذْ إِسِّيوڒْ خْ يِيخفْ نّسْ.“  
\v 22 نَّانْ لْوَالِيذِينْ نّسْ أَمُّو مِينْزِي ڭّْوذنْ زڭْ وُوذَاينْ، مِينْزِي ؤُذَاينْ مْعَاهَاذنْ بلِّي ونِّي إِ غَا إِشهْذنْ أَقَا نتَّا ذ لْمَاسِيحْ، أَذْ ث مّنْضَارنْ زِي ثمْزِيذَا. \x ◘ \xo 9:‏22 \xt يُوح. 7‏:‏13؛ 12‏:‏42. \x*  
\v 23 س ؤُينِّي نَّانْ لْوَالِيذِينْ نّسْ: ”نتَّا أَقَا-ث ذ أَبْڒِيغْ، سقْسَامْ ث سِيمَانْثْ نّسْ.“   
\m
\v 24 \add خَاسْ ؤُشَا\add* ڒَاغَانْ-د وِيسّْ مَارْثَاينْ خْ ورْيَازْ ونِّي ثُوغَا ذ أَذَارْغَاڒْ، نَّانْ أَسْ: ”سْعُودْجْ أَربِّي! أَقَا نسّنْ بلِّي أَرْيَازْ-أَ ذ إِجّْ ن ؤُمذْنُوبْ.“ \x ◘ \xo 9:‏24 \xt ياش. 7‏:‏19. \x*  
\v 25 نتَّا يَارَّا-د، إِنَّا أَسنْ: ”مَا نتَّا ذ أَمذْنُوبْ وَارْ سِّينغْ. نشّْ سّْنغْ إِشْثْ ن ثْمسْڒَاشْثْ، أَقَا ثُوغَا أَيِي ذ أَذَارْغَاڒْ، ڒخُّو تّْوَاڒِيغْ!“  
\v 26 نَّانْ أَسْ عَاوذْ: ”مِينْ زَّايكْ إِڭَّا؟ مَامّشْ ذ أَشْ إِڭَّا يَارْزمْ ثِيطَّاوِينْ نّشْ؟“  
\v 27 إِنَّا أَسنْ: ”أَقَا نِّيغْ أَومْ ث، \add مَاشَا\add* كنِّيوْ وَارْ ثسْڒِيمْ. مَايمِّي ثخْسمْ أَذْ ث ثسْڒمْ إِ ثْوَاڒَا نّغْنِي؟ مَا ثخْسمْ ؤُڒَا ذ كنِّيوْ أَذْ ثْذوْڒمْ ذ إِمحْضَارنْ نّسْ؟“  
\v 28 كّْوَارنْ ث، نَّانْ: ”شكْ ذ أَمحْضَارْ نّسْ! مَاشَا نشِّينْ أَقَا ذ إِمحْضَارنْ ن مُوسَا.  
\v 29 نشِّينْ نسّنْ أَقَا أَربِّي إِسِّيوڒْ أَكْ-ذ مُوسَا، مَاشَا أَرْيَازْ-أَ وَانِيثَا وَارْ نسِّينْ شَا مَانِيسْ نتَّا.“  
\v 30 يَارَّا-د ورْيَازْ، إِنَّا أَسنْ: ”أَقَا ذِي مَانْ أَيَا ڒعْجبْ، كنِّيوْ وَارْ ثسِّينمْ شَا مَانِيسْ نتَّا، وَاخَّا نتَّا يَارْزمْ أَيِي ثِيطَّاوِينْ إِنُو.  
\v 31 نشِّينْ نسّنْ، أَقَا أَربِّي وَارْ إِتّسْڒِي شَا غَارْ إِمذْنَابْ، مَاشَا مَاڒَا شَا ن إِجّنْ إِتّْوقَّارْ إِ-ث ؤُشَا إِتّڭّْ مِينْ إِخْسْ نتَّا، أَقَا نتَّا أَذْ غَارسْ إِسڒْ. \x ◘ \xo 9:‏31 \xt إِزهد. 66‏:‏18؛ أَوڒن. 15‏:‏29؛ 28‏:‏9؛ إِشا. 1‏:‏15؛ مِيخَا 3‏:‏4. \x*  
\v 32 عمَّارْصْ وَارْ إِتّْوَاسْڒِي قَاعْ، أَقَا شَا ن إِجّنْ يَارْزمْ ثِيطَّاوِينْ ن إِجّنْ إِخْڒقْ-د ذ أَذَارْغَاڒْ.  
\v 33 معْلِيكْ وَا وَارْ إِدْجِي شَا زِي أَربِّي، وَارْ إِزمَّارْ أَذْ إِڭّْ مَانْ أَيَا!“  
\v 34 أَرِّينْ-د، نَّانْ أَسْ: ”شكْ ثْخڒْقذْ-د ثْكمّْڒذْ ذِي دّْنُوبْ، مَا خنِّي ثخْسذْ أَذْ أَنغْ ثسّڒْمَاذذْ؟“ \add خنِّي\add* نْضَارنْ ث غَارْ بَارَّا.   
\m
\v 35 إِسْڒَا يَاسُوع بلِّي نْضَارنْ ث غَارْ بَارَّا، ؤُشَا ؤُمِي ث يُوفَا، إِنَّا أَسْ: ”مَا ثُومْنذْ ذِي مِّيسْ ن أَربِّي؟“  
\v 36 يَارَّا-د، إِنَّا: ”مِينْ إِعْنَا نتَّا، \add أَ\add* سِيذِي، حِيمَا أَذْ ذَايسْ أَمْنغْ؟“  
\v 37 إِنَّا أَسْ يَاسُوع: ”أَقَا شكْ ثژْرِيذْ ث ؤُڒَا ذ ونِّي أَكِيكْ إِسَّاوَاڒنْ أَقَا-ث ذ نتَّا.“  
\v 38 نتَّا إِنَّا: ”ؤُمْنغْ، أَ سِيذِي!“. ؤُشَا إِعبْذْ أَسْ.  
\v 39 يَاسُوع إِنَّا: ”إِ ڒْحُوكْمْ إِ د-ؤُسِيغْ غَارْ دُّونشْثْ-أَ، حِيمَا أَذْ ژَترنْ إِنِّي وَارْ إِتّْوِيڒِينْ، ؤُ \add حِيمَا\add* إِنِّي إِتّْوَاڒَانْ أَذْ ذَارْغْڒنْ.“ \x ◘ \xo 9:‏39 \xt يُوح. 3‏:‏17؛ 12‏:‏47. \x*   
\m
\v 40 سْڒِينْ شَا ن إِفَارِيسِييّنْ إِ كِيذسْ إِدْجَانْ مَانْ أَيَا، نَّانْ أَسْ: ”مَا أَقَا ذ نشِّينْ عَاوذْ ذ إِذَارْغَاڒنْ؟“  
\v 41 إِنَّا أَسنْ يَاسُوع: ”مَاعْلِيكْ ثدْجَامْ ذ إِذَارْغَاڒنْ وَارْ غَارْومْ إِتِّيڒِي بُو دّْنُوبْ، مَاشَا ڒخُّو ثقَّارمْ: ’أَقَا نتّْوَاڒَا!‘ س ؤُينِّي أَذْ إِقِّيمْ دّْنُوبْ نْومْ إِبدّْ.“   
\b  
\b  
\m  
\c 10
\s1 يَاسُوع ذ أَمكْسَا ذ أَصبْحَانْ  
\m
\v 1 ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: ونِّي وَارْ إِتِّيذْفنْ زِي ثوَّارْثْ غَارْ ڒْكُورِي ن وُودْجِي، مَاشَا أَذْ إِڭعّذْ مَانِيسْ نّغْنِي، أَقَا-ث ذ أَشفَّارْ ذ أَخوَّانْ.  
\v 2 مَاشَا ونِّي إِ غَا يَاذْفنْ زِي ثوَّارْثْ، نتَّا ذ أَمكْسَاوْ ن ثْحِيمَارْثْ.  
\v 3 أَعسَّاسْ ن ثوَّارْثْ أَذْ أَسْ يَارْزمْ إِ وَانِيثَا ؤُشَا أَذْ ثْسڒْ ثْحِيمَارْثْ إِ ثْمِيجَّا نّسْ. نتَّا أَذْ إِڒَاغَا إِ وُودْجِي نّسْ س إِسْمَاونْ نْسنْ ؤُشَا أَذْ ثنْ إِسُّوفّغْ غَارْ بَارَّا.  
\v 4 أَوَارْنِي ڒَامِي إِسُّوفّغْ مَارَّا ثَاحِيمَارْثْ نّسْ، أَذْ يُويُورْ زَّاثسْ، ؤُشَا أَذْ ث-إِ-د-ضْفَارنْ وُودْجِي نّسْ، مِينْزِي سّْننْ ثْمِيجَّا نّسْ.  
\v 5 مَاشَا أَبَارَّانِي وَارْ ث ثْضفَّارْ ثْحِيمَارْثْعمَّارْصْ، مَاشَا أَذْ زَّايسْ ثَارْوڒْ، مِينْزِي وَارْ ثسِّينْ ثْمِيجَّا ن ؤُبَارَّانِي.“   
\m
\v 6 إِنَّا أَسنْ يَاسُوع أَمتِّيڒْ-أَ، مَاشَا نِيثْنِي وَارْ فْهِيمنْ شَا إِ ثْمسْڒَايِينْ مِينْ خفْ ثُوغَا أَكِيذْسنْ إِسَّاوَاڒْ.   
\m
\v 7 يَاسُوع إِنَّا أَسنْ عَاوذْ: ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: نشّْ ذ ثَاوَّارْثْ ن ثْحِيمَارْثْ.  
\v 8 مَارَّا إِنِّي د-يُوسِينْ \add قْبڒْ إِنُو\add* أَقَا أَثنْ ذ إِشفَّارنْ ذ إِخوَّاننْ. مَاشَا ثَاحِيمَارْثْ وَارْ ذ أَسنْ ثسْڒِي شَا.  
\v 9 نشّْ ذ ثَاوَّارْثْ. ونِّي زَّايِي إِ غَا يَاذْفنْ، أَذْ إِدَّارْ. نتَّا أَذْ يَاذفْ، أَذْ إِفّغْ ؤُشَا أَذْ يَافْ مَانِي غَا يَارْوسْ. \x ◘ \xo 10:‏9 \xt يُوح. 14‏:‏6. \x*  
\v 10 أَشفَّارْ وَارْ د-إِتِّيسْ مْغِيرْ حِيمَا أَذْ يَاشَارْ، أَذْ إِنغْ ؤُ أَذْ إِسّْهلّكْ. نشّْ \add مَاشَا\add* ؤُسِيغْ-د حِيمَا أَذْ غَارْسنْ ثِيڒِي ثُوذَارْثْ ذ ؤُفيّضْ.   
\m
\v 11 نشّْ ذ أَمكْسَاوْ أَصبْحَانْ. أَمكْسَاوْ أَصبْحَانْ إِسّْرُوسَا ثُوذَارْثْ نّسْ إِ ثْحِيمَارْثْ نّسْ. \x ◘ \xo 10:‏11 \xt إِشا. 40‏:‏11؛ حِز. 34‏:‏11، 12، 15، 22، 23؛ مِيخَا 1‏:‏14؛ عبر. 13‏:‏20؛ 1 بُط. 5‏:‏4. \x*  
\v 12 مَاشَا أَمْشَارَايْ، ونِّي وَارْ إِدْجِي شَا ذ أَمكْسَاوْ، وَارْ إِدْجِي شَا ذ بَابْ ن وُودْجِي، خْ مِينِّي إِ غَا إِژَارْ ؤُشّنْ يُوسَا-د، أَذْ يجّْ ثَاحِيمَارْثْ ؤُشَا أَذْ يَارْوڒْ. خنِّي أَذْ د-يَاسْ وُوشّنْ، أَذْ إِخْضفْ ثَاحِيمَارْثْ ؤُشَا أَذْ ت إِزُّوزَارْ. \x ◘ \xo 10:‏12 \xt زَاك. 11‏:‏16. \x*  
\v 13 أَمْشَارَايْ يَارْوڒْ، مِينْزِي نتَّا ذ أَمْشَارَايْ، وَارْ ث إِشْقِي ثَاحِيمَارْثْ.  
\v 14 نشّْ ذ أَمكْسَاوْ أَصبْحَانْ. سّْنغْ ؤُدْجِي إِنُو ؤُشَا ؤُدْجِي إِنُو سّْننْ أَيِي، \x ◘ \xo 10:‏14 \xt 2 تِيم. 2‏:‏19. \x*  
\v 15 أَمْ مَامّشْ إِ ذ أَيِي إِسّنْ بَابَا، أَمُّو إِ سّْنغْ نشّْ بَابَا. نشّْ أَذْ وْشغْ ثُوذَارْثْ إِنُو إِ ثْحِيمَارْثْ. \x ◘ \xo 10:‏15 \xt مت. 11‏:‏27؛ لك. 10‏:‏22؛ يُوح. 6‏:‏46؛ 7‏:‏29. \x*  
\v 16 غَارِي عَاذْ ؤُدْجِي نّغْنِي، إِنِّي وَارْ إِدْجِينْ شَا زِي ڒْكُوڒِي-يَا. إِشُووَّارْ أَيِي أَذْ ثنْ د-سّْمُونغْ عَاوذْ ؤُشَا أَذْ سْڒنْ إِ ثْمِيجَّا إِنُو، ؤُشَا أَذْ ذوْڒنْ مَارَّا ذ إِشْثْ ن ثْحِيمَارْثْ \add سَاذُو ؤُفُوسْ ن\add* إِجّْ ن ؤُمكْسَاوْ. \x ◘ \xo 10:‏16 \xt حِز. 37‏:‏22. \x*  
\v 17 س مَانْ أَيَا إِتّخْسْ أَيِي بَابَا، مِينْزِي نشّْ وْشِيغْ ثُوذَارْثْ إِنُو حِيمَا أَذْ ت-إِ-د-كْسِيغْ عَاوذْ. \x ◘ \xo 10:‏17 \xt إِشا. 53‏:‏12. \x*  
\v 18 ؤُڒَا ذ إِجّْ وَارْ زَّايِي ت إِكْسِي، مَاشَا نشّْ وْشِيغْ ت س ڒْخَاضَارْ إِنُو. غَارِي صُّولْطَا حِيمَا أَذْ ت وْشغْ ؤُ غَارِي صُّولْطَا حِيمَا أَذْ ت-إِ-د-كْسِيغْ عَاوذْ. ثَاوْصيّثْ-أَ طّْفغْ ت زِي بَابَا.“ \x ◘ \xo 10:‏18 \xt يُوح. 2‏:‏19. \x*   
\m
\v 19 خنِّي إِمْسَارْ عَاوذْ ؤُبطُّو جَارْ وُوذَاينْ س سِّيبّثْ ن وَاوَاڒنْ-أَ. \x ◘ \xo 10:‏19 \xt يُوح. 7‏:‏12؛ 9‏:‏16. \x*  
\v 20 أَطَّاسْ زَّايْسنْ نَّانْ: ”أَقَا ذَايسْ إِجّْ ن شِّيطَانْ، نتَّا ذ أَطمّسْ أَمقّْرَانْ. مَايمِّي غَارسْ ثتّسْڒَامْ؟“ \x ◘ \xo 10:‏20 \xt يُوح. 7‏:‏20؛ 8‏:‏48، 52. \x*  
\v 21 إِنّغْنِي نَّانْ: ”أَوَاڒنْ-أَ وَارْ دْجِينْ شَا ن إِجّْ ن ؤُمَارْيَاحْ. مَا إِزمَّارْ إِجّْ ن شِّيطَانْ أَذْ يَارْزمْ ثِيطَّاوِينْ ن إِذَارْغَاڒنْ؟“ \x ◘ \xo 10:‏21 \xt ؤُف. 4‏:‏11؛ إِزهد. 94‏:‏9؛ 146‏:‏8. \x*   
\b  
\m  
\s1 ڒْعِيذْ ن ؤُذشّنْ ن زَّاوشْثْ ثَامقّْرَانْثْ  
\m
\v 22 يِيوضْ-د ڒْعِيذْ ن ؤُذشّنْ \add ن زَّاوشْثْ ثَامقّْرَانْثْ\add* ذِي ؤُرْشَالِيمْ. ثُوغَا ذ ڒْمشْثَا.  
\v 23 يَاسُوع إِڭُّورْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ ذڭْ ؤُسقِّيفْ أَكْ-ذ ؤُكُولْوَارْ ذ إِپِيلَارنْ ن سُولِيمَانْ. \x ◘ \xo 10:‏23 \xt 1 إِج. 6‏:‏3؛ ڒخ. 3‏:‏11؛ 5‏:‏12. \x*  
\v 24 نّْضنْ أَسْ-د وُوذَاينْ، نَّانْ أَسْ: ”أَڒْ مڒْمِي ذ أَنغْ إِ غَا ثجّذْ نُويڒْ \add عَاذْ\add*؟ مَاڒَا شكْ ذ لْمَاسِيحْ، إِنِي أَنغْ ث س بْطَايْطَايْ.“  
\v 25 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”نِّيغْ أَومْ ث ؤُشَا كنِّيوْ وَارْ ثُومِينمْ. ڒخْذَايمْ إِ ڭِّيغْ س يِيسمْ ن بَابَا، شهّْذنْثْ خَافِي. \x ◘ \xo 10:‏25 \xt يُوح. 5‏:‏36. \x*  
\v 26 مَاشَا كنِّيوْ وَارْ ثُومِينمْ، مِينْزِي كنِّيوْ وَارْ ثدْجِيمْ شَا ذ ؤُدْجِي إِنُو، أَمْ مَامّشْ ثُوغَا ذ أَومْ نِّيغْ.  
\v 27 ؤُدْجِي إِنُو إِسْڒَا غَارْ ثْمِيجَّا إِنُو ؤُ نشّْ سّْنغْ أَسنْ ؤُشَا نِيثْنِي أَذْ أَيِي-د ضْفَارنْ. \x ◘ \xo 10:‏27 \xt يُوح. 8‏:‏47. \x*  
\v 28 أَذْ أَسنْ وْشغْ ثُوذَارْثْ إِتّْذُومَانْ ؤُشَا وَارْ تّْوَاهلّْكنْعمَّارْصْ قَاعْ ؤُشَا ؤُڒَا ذ إِجّْ وَارْ ثنْ إِخطّفْ زڭْ ؤُفُوسْ إِنُو. \x ◘ \xo 10:‏28 \xt يُوح. 6‏:‏39؛ 17‏:‏12؛ 18‏:‏9. \x*  
\v 29 بَابَا ونِّي ذ أَيِي ثنْ إِوْشِينْ، أَقَا-ث ذ أَمقّْرَانْ خْ كُوڒْشِي. ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ \add ثنْ\add* إِخْضفْ زڭْ ؤُفُوسْ ن بَابَا.  
\v 30 نشّْ ذ بَابَا ذ إِجّنْ.“ \x ◘ \xo 10:‏30 \xt إِشا. 54‏:‏5؛ يُوح. 5‏:‏19؛ 14‏:‏9؛ 17‏:‏5. \x*   
\b  
\m  
\s1 ؤُذَاينْ أَرزُّونْ أَذْ أَرجْمنْ يَاسُوع  
\m
\v 31 خنِّي كْسِينْ وُوذَاينْ عَاوذْ إِژْرَا حِيمَا أَذْ ث أَرجْمنْ. \x ◘ \xo 10:‏31 \xt يُوح. 8‏:‏59؛ 11‏:‏8. \x*  
\v 32 يَاسُوع إِنَّا أَسنْ: ”أَقَا سّشْنغْ أَومْ أَطَّاسْ ن ڒخْذَايمْ ثِيصبْحَانِينْ زِي بَابَا. إِ مَانْ ڒْخذْمثْ زَّايْسنْثْ \add إِ ثخْسمْ\add* أَذْ أَيِي ثَارجْممْ؟“  
\v 33 نَّانْ أَسْ وُوذَاينْ: ”وَارْ شكْ نَارجّمْ خْ إِشْثْ ن ڒْخذْمثْ ثَاصبْحَانْثْ، مَاشَا ؤُمِي ثكْفَارذْ ؤُ ثَارِّيذْ إِخفْ نّشْ ذ أَربِّي، وَاخَّا شكْ ذ بْنَاذمْ إِ ثدْجِيذْ.“ \x ◘ \xo 10:‏33 \xt يُوح. 5‏:‏18. \x*  
\v 34 إِنَّا أَسنْ يَاسُوع: ”مَا وَارْ ثُورِي ذِي شَّارِيعَا نْومْ: ’نشّْ نِّيغْ، أَقَا كنِّيوْ ذ إِربِّيثنْ‘؟ \x ◘ \xo 10:‏34 \xt إِزهد. 82‏:‏6. \x*  
\v 35 مَاڒَا نتَّا إِسمَّا ثنْ ’إِربِّيثنْ‘، يِينِّي ؤُمِي د-يُوسَا وَاوَاڒْ ن أَربِّي، ؤُشَا وَارْ إِزمَّارْ أَذْ تّْوَارْژنْثْ ثِيرَا \add إِقدّْسنْ\add*،  
\v 36 مَامّشْ ثقَّارمْ كنِّيوْ خْ ونِّي إِتّْوَاقدّْسنْ زِي بَابَا ؤُ \add خْ ونِّي\add* إِسّكّْ إِ-ث-إِ-د غَارْ دُّونشْثْ: ’أَقَا شكْ ثكْفَارذْ!‘، مِينْزِي نشّْ نِّيغْ: ’أَقَا نشّْ ذ مِّيسْ ن أَربِّي‘؟ \x ◘ \xo 10:‏36 \xt يُوح. 5‏:‏1؛ 6‏:‏27. \x*  
\v 37 مَاڒَا نشّْ وَارْ خدّْمغْ شَا ڒخْذَايمْ ن بَابَا، \add خنِّي\add* وَارْ ذَايِي تِّيمْنمْ شَا. \x ◘ \xo 10:‏37 \xt يُوح. 15‏:‏24. \x*  
\v 38 مَاشَا مَاڒَا خذْمغْ ثنْثْ، أَمْنمْ خنِّي ذِي ڒخْذَايمْ، وَاخَّا كنِّيوْ عَاذْ وَارْ ذَايِي ثُومِينمْ، حِيمَا أَذْ ثسّْنمْ أَقَا بَابَا ذَايِي ؤُ نشّْ أَقَا أَيِي ذِي بَابَا.“ \x ◘ \xo 10:‏38 \xt يُوح. 14‏:‏11؛ 17‏:‏21. \x*   
\m
\v 39 أَرزُّونْ أَذْ ث طّْفنْ عَاوذْ، \add مَاشَا\add* إِخْثُوتّڒْ أَسنْ جَارْ إِفَاسّنْ نْسنْ. \x ◘ \xo 10:‏39 \xt لك. 4‏:‏29؛ يُوح. 8‏:‏59. \x*  
\v 40 إِرُوحْ غَارْ ؤُجمَّاضْ \add ن إِغْزَارْ\add* ن لْ-ؤُرْذُونْ، غَارْ ومْشَانْ مَانِي ثُوغَا إِسّْغطَّاصْ يُوحَانَّا ذڭْ ؤُمزْوَارُو، ؤُشَا إِقِّيمْ ذِينِّي. \x ◘ \xo 10:‏40 \xt يُوح. 1‏:‏28؛ 3‏:‏23. \x*  
\v 41 ؤُسِينْ-د غَارسْ وَاطَّاسْ \add ن إِوْذَانْ\add*، نَّانْ: ”يُوحَانَّا وَارْ إِڭِّي ؤُڒَا ذ إِشْثْ ن ڒعْڒَامثْ، مَاشَا مَارَّا مِينْ إِنَّا خْ ورْيَازْ-أَ ذ ثِيذتّْ!“  
\v 42 ؤُشَا ؤُمْننْ ذَايسْ أَطَّاسْ \add ذِيهَا\add*.   
\b  
\b  
\m  
\c 11
\s1 أَسْنكَّارْ ن أَلِيعَازَارْ زِي ڒْموْثْ  
\m
\v 1 ثُوغَا ذِينْ إِجّْ ن بْنَاذمْ إِهْڒشْ، \add قَّارنْ أَسْ\add* أَلِيعَازَارْ، زِي ذْشَارْ ن بَايْثْ-عَانْيَا. نتَّا ثُوغَا ذ ؤُمَاسْ ن مَارْيَامْ ذ مَارْثَا.  
\v 2 مَارْيَامْ ثَانِيثَا نتَّاثْ ذ ثنِّي إِ ثُوغَا إِذهْننْ يَاسُوع س ڒفْوَاحثْ ن مِيرُّو ؤُ ثمْسحْ إِضَارنْ نّسْ س ؤُشُووَّافْ نّسْ، ؤُ ؤُمَاسْ أَلِيعَازَارْ ثُوغَا إِهْڒشْ. \x ◘ \xo 11:‏2 \xt مت. 26‏:‏6؛ مك. 14‏:‏3؛ لك. 7‏:‏37؛ يُوح. 12‏:‏3. \x*  
\v 3 سّكّنْثْ-إِ-د ثْنَاينْ ن سُويثْمَاسْ \add إِجّنْ\add* غَارْ يَاسُوع، نَّانْثْ: ”\add أَ\add* سِيذِيثْنغْ، خْزَارْ، ونِّي ثخْسذْ، أَقَا إِهْڒشْ.“   
\m
\v 4 مَاشَا يَاسُوع إِنَّا: ”ڒهْڒَاشْ-أَ وَارْ إِدْجِي شَا إِ ڒْموْثْ، مَاشَا إِ ؤُعُودْجِي ن أَربِّي، حِيمَا أَذْ زَّايسْ إِتّْوَاسّْعُودْجْ مِّيسْ ن أَربِّي.“ \x ◘ \xo 11:‏4 \xt يُوح. 9‏:‏3؛ 11‏:‏40. \x*  
\v 5 ثُوغَا يَاسُوع إِتّخْسْ مَارْثَا ذ مَارْيَامْ ذ أَلِيعَازَارْ.   
\m
\v 6 أَڒَامِي إِسْڒَا أَقَا \add أَلِيعَازَارْ\add* إِهْڒشْ، ڒخْذنِّي إِقِّيمْ عَاذْ ثْنَاينْ ن وُوسَّانْ ذڭْ ومْشَانْ مَانِي ث ثُوغَا.  
\v 7 أَوَارْنِي مَانْ أَيَا إِنَّا إِ إِمحْضَارنْ نّسْ: ”أجّْ أَنغْ أَذْ نْرَاحْ عَاوذْ غَارْ \add ثمُّورْثْ ن\add* يَاهُوذِييَّا!“  
\v 8 إِمحْضَارنْ نَّانْ أَسْ: ”\add أَ\add* أَمْسڒْمَاذْ نّغْ، ذْرُوسْ زڭْ وَامِي ثُوغَا ؤُذَاينْ أَرزُّونْ أَذْ شكْ أَرجْمنْ، مَامّشْ شكْ أَذْ ثْرَاحذْ ذِينِّي عَاوذْ؟“ \x ◘ \xo 11:‏8 \xt يُوح. 8‏:‏59؛ 10‏:‏31. \x*  
\v 9 يَارَّا-د يَاسُوع: ”مَا وَارْ ذِينْ ثنْعَاشْ ن ثْسَاعّثِينْ ذڭْ ؤُزِيڒْ؟ مَاڒَا شَا ن يِيجّنْ يُويُورْ س ؤُزِيڒْ، وَارْ إِتّْنقْرِيضْ شَا، مِينْزِي إِتّْوَاڒَا ثَافَاوْثْ ن دُّونشْثْ-أَ.  
\v 10 مَاشَا مَاڒَا شَا ن يِيجّنْ أَذْ يُويُورْ س دْجِيڒثْ، أَذْ إِنْقَارضْ، مِينْزِي وَارْ ذَايسْ بُو ثْفَاوْثْ.“  
\v 11 أَوَارْنِي ڒَامِي إِنَّا مَانْ أَيَا، إِنَّا أَسنْ: ”أَلِيعَازَارْ، أَمدُّوكّڒْ نّغْ أَقَا إِطّصْ، مَاشَا أَذْ رَاحغْ حِيمَا أَذْ ث-إِ-د-سّْنكَّارغْ.“ \x ◘ \xo 11:‏11 \xt مت. 9‏:‏24؛ مك. 5‏:‏39؛ لك. 8‏:‏52. \x*  
\v 12 نَّانْ أَسْ إِمحْضَارنْ: ”\add أَ\add* سِيذِيثْنغْ، مَاڒَا نتَّا إِطّصْ، \add خنِّي\add* أَذْ إِڭّنْفَا!“  
\v 13 \add مَاشَا\add* يَاسُوع ؤُغَا إِسَّاوَاڒْ خْ ڒْموْثْ نّسْ، مَاشَا إِتّْغِيڒْ أَسنْ بلِّي نتَّا إِسَّاوَاڒْ خْ أَرَّاحثْ ن يِيضصْ.  
\v 14 خنِّي إِنَّا أَسنْ يَاسُوع س بْطَايْطَايْ: ”أَقَا أَلِيعَازَارْ إِمُّوثْ.  
\v 15 ؤُ نشّْ فَارْحغْ أَومْ ؤُمِي نشّْ وَارْ ذِينْ دْجِيغْ، حِيمَا أَذْ ثَامْنمْ. مَاشَا إِتّْخصَّا كنِّيوْ أَذْ ثْرَاحمْ ذِينِّي.“  
\v 16 إِنَّا ثُومَا، ونِّي ؤُمِي قَّارنْ ’أَشْنِيوْ‘، إِ إِمحْضَارنْ إِمْعَاشَارنْ نّسْ: ”أجّْ أَنغْ أَذْ نْرَاحْ ؤُڒَا ذ نشِّينْ، حِيمَا أَذْ نمّثْ أَكِيذسْ.“   
\m
\v 17 ڒَامِي د-يِيوضْ يَاسُوع غَارْ بَايْثْ-عَانْيَا، يُوفَا أَقَا عْذُونْ أَربْعَا ن وُوسَّانْ زڭْ وَامِي ثُوغَا-ث ذڭْ ونْضڒْ.  
\v 18 بَايْثْ-عَانْيَا ثُوغَا ثُوذسْ ؤُرْشَالِيمْ، عْڒَاحَاڒْ خمّسْطَاشْ ’إِسْثَاذِييّنْ‘، \add عْڒَاحَاڒْ ثْڒَاثَا كِيلُومِيثْرْ\add*. \f ◼ \fr 11:‏18 \ft \+bd ’إِسْثَاذِييّنْ‘\+bd* 
\fp  إِجّْ ن ڒْمڒْعبْ ذِي ڒْوقْثْ ن إِيُونَانِييّنْ ثُوغَا غَارسْ إِشْثْ ثُوزُّوڭَارْثْ ن 185 مِيثْرْ، إِخْسْ أَذْ يِينِي ’إِجّْ ن ؤُسْثَاذِييْ‘.\f*  
\v 19 أَطَّاسْ ن وُوذَاينْ ؤُسِينْ-د غَارْ مَارْثَا ذ مَارْيَامْ حِيمَا أَذْ ثنْثْعزَّانْ خْ ؤُمَاثْسنْثْ.  
\v 20 ڒَامِي ثسْڒَا مَارْثَا، أَقَا يَاسُوع يِيوضْ-د، ثفّغْ حِيمَا أَذْ ث ثڒْقَا، مَاشَا مَارْيَامْ ثقِّيمْ ذِي ثَادَّارْثْ.  
\v 21 ثنَّا مَارْثَا إِ يَاسُوع: ”\add أَ\add* سِيذِي، معْلِيكْ شكْ ثُوغَا ذَا، إِڒِي وَارْ إِتّْمتِّي شَا ؤُمَا.  
\v 22 مَاشَا ڒخُّو عَاذْ سّْنغْ عَاوذْ بلِّي مَارَّا مِينْ غَا ثتَّارذْ زِي أَربِّي، نتَّا أَذْ أَشْ ث إِوْشْ.“  
\v 23 يَاسُوع إِنَّا أَسْ: ”أَذْ د-إِكَّارْ ؤُمَامْ.“  
\v 24 ثنَّا أَسْ مَارْثَا: ”سّْنغْ بلِّي أَذْ د-إِكَّارْ ذِي ثْنُوكْرَا ذڭْ وَاسّْ أَنڭَّارُو.“ \x ◘ \xo 11:‏24 \xt دَان. 12‏:‏2؛ لك. 14‏:‏14؛ يُوح. 5‏:‏29. \x*  
\v 25 يَاسُوع إِنَّا أَسْ: ”نشّْ ذ ثَانُوكْرَا ذ ثُوذَارْثْ. ونِّي زَّايِي إِ غَا يَامْننْ، أَذْ إِدَّارْ، وَاخَّا إِمُّوثْ. \x ◘ \xo 11:‏25 \xt يُوح. 1‏:‏4؛ 3‏:‏16، 36؛ 5‏:‏24؛ 6‏:‏47؛ 14‏:‏6؛ 1 يُوح. 5‏:‏10. \x*  
\v 26 مَارَّا ونِّي إِدَّارنْ ؤُشَا يُومنْ زَّايِي، وَارْ إِتّْمتِّي إِ ڒبْذَا. مَا ثُومْنذْ ذِي مَانْ أَيَا؟“ \x ◘ \xo 11:‏26 \xt يُوح. 6‏:‏51. \x*  
\v 27 ثنَّا أَسْ: ”وَاهْ، \add أَ\add* سِيذِي إِنُو، ؤُمْنغْ أَقَا شكْ ذ لْمَاسِيحْ، مِّيسْ ن أَربِّي ونِّي ثُوغَا إِ ذ تَّاسنْ غَارْ دُّونشْثْ.“ \x ◘ \xo 11:‏27 \xt مت. 16‏:‏16؛ مك. 8‏:‏29؛ لك. 9‏:‏20؛ يُوح. 6‏:‏69. \x*   
\m
\v 28 أَوَارْنِي ڒَامِي ثنَّا أَيَا، ثْرُوحْ ثْڒَاغَا إِ ؤُتْشْمَاسْ مَارْيَامْ س ڒْحسّْ، ثنَّا أَسْ: ”أَمْسڒْمَاذْ نّغْ يُوسَا-د، إِتّْڒَاغَا-د خَامْ.“  
\v 29 ڒَامِي ثسْڒَا مَارْيَامْ أَيَا، ثكَّارْ س ثَازْڒَا، ثْرُوحْ غَارسْ.  
\v 30 ثُوغَا يَاسُوع وَارْ د-يُوسِي شَا عَاذْ غَارْ ذْشَارْ، مَاشَا ثُوغَا-ث \add عَاذْ\add* ذڭْ ومْشَانْ مَانِي ث ثڒْقَا مَارْثَا.  
\v 31 ؤُڒَا ذ ؤُذَاينْ، إِنِّي إِدْجَانْ أَكِيذسْ ذِي ثَادَّارْثْ، ثُوغَا تّْعزَّانْ ت، ضفَّارنْ ت ڒَامِي ژْرِينْ أَقَا مَارْيَامْ ثكَّارْ س ثَازْڒَا، ثفّغْ، مِينْزِي إِتّْغِيڒْ أَسنْ أَقَا ثْرُوحْ غَارْ ونْضڒْ حِيمَا أَذْ ثْرُو ذِينِّي.  
\v 32 ڒَامِي د-ثُوسَا مَارْيَامْ غَارْ مَانِي ثُوغَا يَاسُوع، ؤُشَا ثژْرَا إِ-ث، ثوْضَا غَارْ إِضَارنْ نّسْ، ثنَّا أَسْ: ”أَ سِيذِي، معْلِيكْ ثُوغَا شكْ ذَانِيثَا، إِڒِي ؤُمَا وَارْ إِتّْمتِّي شَا!“   
\m
\v 33 ڒَامِي ت إِژْرَا يَاسُوع ثتّْرُو، ؤُڒَا ذ وُوذَاينْ إِنِّي د-يُوسِينْ أَكِيذسْ تّْرُونْ، إِنّهْوڒْ أَرُّوحْ نّسْ، إِنْهزّْ ذِي ڒعْمَارْ نّسْ.  
\v 34 إِنَّا: ”مَانِي ث ثسَّارْسمْ؟“ نَّانْ أَسْ: ”أَرَاحْ-د، \add أَ\add* سِيذِيثْنغْ، أَذْ ثخْزَارذْ!“  
\v 35 \add خنِّي\add* فّْغنْثْ أَسْ-د إِ يَاسُوع إِمطَّاونْ. \x ◘ \xo 11:‏35 \xt لك. 19‏:‏41. \x*  
\v 36 ؤُذَاينْ نَّانْ: ”خْزَارمْ، مشْحَاڒْ ث إِتّخْسْ.“  
\v 37 \add مَاشَا\add* شَا زَّايْسنْ نَّانْ: ”مَا وَارْ إِزمَّارْ وَا، ونِّي يَارزْمنْ ثِيطَّاوِينْ إِ ؤُذَارْغَاڒْ، أَذْ إِڭّْ شَا مَاحنْذْ ؤُڒَا ذ وَانِيثَا وَارْ إِتّْمتِّي شَا؟“   
\m
\v 38 ؤُمِي د-يُوسَا غَارْ وَاخَّامْ ن ونْضڒْ، إِنّهْوڒْ يَاسُوع أَطَّاسْ ذڭْ إِخفْ نّسْ. أَخَّامْ ن ونْضڒْ أَقَا-ث ذ إِجّْ ن إِفْرِي ؤُشَا إِشْثْ ن ثصْضَارْثْ ثُوغَا ثمَّارْسْ خْ وَاذَافْ نّسْ.  
\v 39 يَاسُوع إِنَّا: ”كْسِيمْ ثَاصْضَارْثْ-أَ.“ ثنَّا أَسْ مَارْثَا، ؤُتْشْمَاسْ ن ونِّي إِمُّوثنْ: ”\add أَ\add* سِيذِي، أَقَا يَارْصُوضْ، مِينْزِي ثعْذُو خَاسْ أَربْعَا ن وُوسَّانْ.“  
\v 40 إِنَّا أَسْ يَاسُوع: ”مَا وَارْ ذ أَمْ نِّيغْ، مَاڒَا ثُومْنذْ، أَذْ ثْژَارذْ أَعُودْجِي ن أَربِّي؟“  
\v 41 كّْسِينْ ثَاصْضَارْثْ. خنِّي إِسّْڭعّذْ يَاسُوع ثِيطَّاوِينْ نّسْ غَارْ سنّجْ، إِنَّا: ”\add أَ\add* بَابَا، عَافَاكْ ڒَامِي ذ أَيِي ثسْڒِيذْ.  
\v 42 نشّْ سّْنغْ أَقَا ڒبْذَا ثتّسْڒِيذْ غَارِي، مَاشَا ذِي طّْوعْ ن ڒْغَاشِي إِ ذ أَيِي د-إِنّْضنْ، نِّيغْ ث، حِيمَا أَذْ أَمْننْ بلِّي شكْ ثسّكّذْ أَيِي-د.“ \x ◘ \xo 11:‏42 \xt يُوح. 12‏:‏30. \x*  
\v 43 ڒَامِي إِنَّا أَيَا، إِڒَاغَا س جّهْذْ: ”أَلِيعَازَارْ، فّغْ-د!“  
\v 44 ڒخْذنِّي إِفّغْ-د ؤُمتِّينْ، ثُوغَا إِفَاسّنْ ذ إِضَارنْ نّسْ شَارْفنْ س ڒشْفنْ \add نْ ڒقْطنْ\add* ؤُ ثُوغَا إِجّْ ؤُمنْذِيڒْ \add نْ ڒقْطنْ\add* إِتّْوَاشَارْفْ خْ ؤُغمْبُوبْ نّسْ. إِنَّا أَسنْ يَاسُوع: ”فسْيمْ أَسْ-د. جّمْ ث أَذْ إِرَاحْ.“ \x ◘ \xo 11:‏44 \xt يُوح. 20‏:‏7. \x*   
\b  
\m  
\s1 إِمْغَارنْ ن وُوذَاينْ أَرزُّونْ أَذْ نْغنْ يَاسُوع  
\m
\v 45 أَطَّاسْ ن وُوذَاينْ إِنِّي د-يُوسِينْ غَارْ مَارْيَامْ، ؤُشَا ژْرِينْ مِينْ إِڭَّا يَاسُوع، ؤُمْننْ زَّايسْ. \x ◘ \xo 11:‏45 \xt [مت. 26‏:‏1‏-‏5؛ مك. 14‏:‏1‏-‏2؛ لك. 22‏:‏1‏-‏2]\x*  
\v 46 مَاشَا شَا زَّايْسنْ رُوحنْ غَارْ إِفَارِيسِييّنْ، نَّانْ أَسنْ مِينْ إِڭَّا يَاسُوع.  
\v 47 ؤُشَا ڭِّينْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِفَارِيسِييّنْ إِجّْ ن ؤُمُونِي، نَّانْ: ”مِينْ غَا نڭّْ، مِينْزِي أَرْيَازْ-أَ إِتّڭّْ أَطَّاسْ ن ڒعْڒَامَاثْ. \x ◘ \xo 11:‏47 \xt إِزهد. 2‏:‏2؛ مت. 26‏:‏3؛ مك. 14‏:‏1؛ لك. 22‏:‏2؛ ڒخ. 4‏:‏27. \x*  
\v 48 مَاڒَا نجَّا إِ-ث أَمْيَا، مَارَّا أَذْ زَّايسْ أَمْننْ. \add خنِّي\add* أَذْ د-أَسنْ إِرُومَانِييّنْ، أَذْ زَّايْنغْ كّْسنْ أَمْشَانْ نّغْ \add إِقدّْسنْ\add* ؤُڒَا ذ \add إِوْذَانْ ن\add* ڒْڭنْسْ نّغْ.“  
\v 49 إِنَّا أَسنْ إِجّنْ زَّايْسنْ، أَقَا-ث ذ قَايَافَا، نتَّا ذ أَرَّايْسْ ن إِكهَّاننْ ذڭْ ؤُسڭّْوَاسْ نِّي: ”كنِّيوْ وَارْ ثسِّينمْ وَالُو،  
\v 50 ؤُشَا وَارْ ثفْهِيممْ شَا بلِّي إِنفّعْ إِ نشِّينْ خْ مِينِّي إِ غَا إِمّثْ إِجّْ ن بْنَاذمْ ذِي طّْوعْ ن ڒْڭنْسْ، ؤُشَا وَارْ إِتّْمتِّي شَا ڒْڭنْسْ نّغْ مَارَّا.“ \x ◘ \xo 11:‏50 \xt يُوح. 18‏:‏14. \x*  
\v 51 وَارْ إِنِي شَا مَانْ أَيَا زڭْ إِخفْ نّسْ، مَاشَا، ؤُمِي ثُوغَا ذ أَرَّايْسْ ن إِكهَّاننْ ذڭْ ؤُسڭّْوَاسْ نِّي، ثُوغَا إِتّْنبَّا بلِّي يَاسُوع أَذْ إِمّثْ ذِي طّْوعْ ن ڒْڭنْسْ.  
\v 52 وَارْ إِدْجِي حَاشَا ذِي طّْوعْ ن ڒْڭنْسْ، مَاشَا ؤُڒَا حِيمَا أَذْ إِسّْمُونْ إِحنْجِيرنْ إِتّْوَازُوزَّارنْ ن أَربِّي غَارْ إِجّنْ. \x ◘ \xo 11:‏52 \xt أَفا. 2‏:‏14، 15، 16. \x*  
\v 53 زڭْ وَاسّْ نِّي نْوَانْ أَذْ ث نْغنْ.   
\m
\v 54 مَاشَا يَاسُوع وَارْ إِقِّيمْ إِڭُّورْ جَارْ وُوذَاينْ س بْطَايْطَايْ، مَاشَا إِرُوحْ سّنِّي غَارْ إِشْثْ ن ثمُّورْثْ ثُوذسْ ڒخْڒَا، غَارْ إِشْثْ ن ثنْذِينْثْ قَّارنْ أَسْ إِفْرَايِيمْ، ؤُشَا إِقِّيمْ ذِينِّي أَكْ-ذ إِمحْضَارنْ نّسْ.   
\m
\v 55 ثُوغَا \add ڒْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو ن وُوذَاينْ عْڒَاينْ يِيوضْ-د. أَطَّاسْ زِي ذْشُورَاثْ ؤُسِينْ-د غَارْ ؤُرْشَالِيمْ حِيمَا أَذْ طهَّارنْ إِخفْ نْسنْ قْبڒْ ڒْعِيذْ. \x ◘ \xo 11:‏55 \xt أَمز. 35‏:‏2، ؤُف. 19‏:‏10‏-‏11، لَاوِي 22‏:‏1‏-‏4، ڒخْڒ. 9‏:‏10، 2 إِم. 30‏:‏17‏-‏18، يُوح. 18‏:‏28، ڒخ. 21‏:‏18، 24، 26\x*  
\v 56 نِيثْنِي ثُوغَا أَرزُّونْ خْ يَاسُوع، نَّانْ جَارْ أَسنْ ؤُمِي نِيثْنِي بدّنْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ: ”مِينْ ثتّْوَاڒَامْ؟ مَا زعْمَا وَارْ د-إِتِّيسْ غَارْ ڒْعِيذْ؟“ \x ◘ \xo 11:‏56 \xt يُوح. 7‏:‏11. \x*  
\v 57 \add مَاشَا\add* إِمقّْرَاننْ ن إِكهَّاننْ ذ إِفَارِيسِييّنْ وصَّانْ بلِّي، مَاڒَا شَا ن يِيجّنْ إِسّنْ مَانِي إِدْجَا، أَذْ ث إِنِي، حِيمَا أَذْ ث طّْفنْ.   
\b  
\b  
\m  
\c 12
\s1 أَذْهَانْ س ڒعْطُورْ إِغْڒَانْ ذِي بَايْثْ-عَانْيَا  
\m
\v 1 ستَّا ن وُوسَّانْ قْبڒْ \add ڒْْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو، يُوسَا-د يَاسُوع غَارْ بَايْثْ-عَانْيَا، مَانِي ثُوغَا إِدْجَا أَلِيعَازَارْ، ونِّي د-إِسّْنكَّارْ يَاسُوع زِي ثَادَّارْثْ ن إِمتِّيننْ. \x ◘ \xo 12:‏1 \xt [مت. 26‏:‏6‏-‏13؛ مك. 14‏:‏3‏-‏9] — مت. 26‏:‏6؛ مك. 14‏:‏3؛ لك. 7‏:‏37؛ يُوح. 11‏:‏2. \x*  
\v 2 ڭِّينْ أَسْ ذِينْ إِجّْ ن ؤُمنْسِي. مَارْثَا ثُوغَا ثْسخَّارْ، ؤُ أَلِيعَازَارْ ثُوغَا ذ إِجّنْ زڭْ إِنِّي أَكِيذسْ إِقِّيمنْ \add غَارْ طَّابْڒَا\add*.  
\v 3 ثكْسِي-د مَارْيَامْ إِجّْ ن ؤُغَارَّافْ نْ زّشْثْ إِ وذْهَانْ زِي ڒعْطُورْ نْ صّنْبلْ ثصْفَا ثِيغْڒَا، ثذْهنْ إِضَارنْ ن يَاسُوع، خنِّي ثمْسحْ إِضَارنْ نّسْ س ؤُشُووَّافْ نّسْ. ثَادَّارْثْ ثشُّورْ س ڒفْوَاحثْ ن \add زّشْثْ ن\add* وذْهَانْ.  
\v 4 إِجّنْ زڭْ إِمحْضَارنْ نّسْ ونِّي ؤُمِي قَّارنْ يَاهُوذَا إِسْخَارِييُوطِي ونِّي ث إِ غَا إِغْذَارنْ، إِنَّا:  
\v 5 ”مَايمِّي وَارْ ثمّنْزْ شَا ڒفْوَاحثْ-أَ ن صّنْبلْ س ثڒْثْ مْيَا ن ذِينَارْ، حِيمَا أَذْ ثمّوْشْ إِ إِمزْڒَاضْ؟“ \x ◘ \xo 12:‏5 \xt مك. 14‏:‏5. \x*  
\v 6 نتَّا إِنَّا أَيَا، وَارْ إِدْجِي مِينْزِي شْقَانْ ث إِمزْڒَاضْ، مَاشَا مِينْزِي نتَّا ذ أَشفَّارْ، ثُوغَا غَارسْ سّنْذُوقْ، ؤُشَا يَارْبُو مِينْ ذَايسْ إِمَّارْسنْ. \x ◘ \xo 12:‏6 \xt يُوح. 13‏:‏29. \x*  
\v 7 يَاسُوع إِنَّا: ”جّمْ ت، أَقَا ثْخمّڒْ إِ-ت إِ وَاسّْ ن ونْضڒْ إِنُو. \x ◘ \xo 12:‏7 \xt مك. 14‏:‏8. \x*  
\v 8 مِينْزِي إِمزْڒَاضْ أَقَا أَثنْ ڒبْذَا أَكِيذْومْ، مَاشَا نشّْ وَارْ كِيذْومْ دْجِيغْ إِ ڒبْذَا.“ \x ◘ \xo 12:‏8 \xt أَعَوذ. 15‏:‏11؛ مت. 26‏:‏11؛ مك. 14‏:‏7. \x*   
\m
\v 9 أَطَّاسْ ن ڒْغَاشِي زڭْ وُوذَاينْ سْڒِينْ بلِّي يَاسُوع أَقَا-ث ذِينِّي. ؤُسِينْ-د نِيثْنِي، وَارْ إِدْجِي حَاشَا زِي سِّيبّثْ ن يَاسُوع، مَاشَا عَاوذْ حِيمَا أَذْ ژَترنْ أَلِيعَازَارْ، ونِّي د-إِسّْنكَّارْ زِي ثَادَّارْثْ ن إِمتِّيننْ. \x ◘ \xo 12:‏9 \xt يُوح. 11‏:‏44. \x*  
\v 10 مْشَاوَارنْ إِمقّْرَاننْ ن إِكهَّاننْ، حِيمَا أَذْ نْغنْ ؤُڒَا ذ أَلِيعَازَارْ،  
\v 11 مِينْزِي أَطَّاسْ ن وُوذَاينْ فّْغنْ-د زِي سِّيبّثْ نّسْ ؤُشَا ؤُمْننْ ذِي يَاسُوع.   
\b  
\m  
\s1 أَذَافْ ن يَاسُوع غَارْ ؤُرْشَالِيمْ  
\m
\v 12 ثِيوشَّا نّسْ، ؤُمِي سْڒِينْ أَطَّاسْ ن ڒْغَاشِي إِنِّي د يُوسِينْ غَارْ ڒْعِيذْ بلِّي يَاسُوع يُوسَا-د غَارْ ؤُرْشَالِيمْ، \x ◘ \xo 12:‏12 \xt [مت. 21‏:‏1‏-‏11؛ مك. 11‏:‏1‏-‏11؛ لك. 19‏:‏28‏-‏40] — مت. 21‏:‏8؛ مك. 11‏:‏8؛ لك. 19‏:‏36. \x*  
\v 13 كْسِينْ إِفثْوَانْ ن ثِينِي ؤُشَا فّْغنْ، حِيمَا أَذْ ث ڒْقَانْ، ڒَاغَانْ:  
\b  
\m \qt ”ؤُصَانَّا!\qt*  
\m \qt سّعْذْ ن ونِّي د-يُوسِينْ\qt*  
\m \qt س يِيسمْ ن سِيذِي،\qt*  
\m \qt أَجدْجِيذْ ن إِسْرَائِيل!“\qt* \x ◘ \xo 12:‏13 \xt إِزهد. 118‏:‏25، 26؛ مت. 21‏:‏9؛ مك. 11‏:‏9، 10\x*   
\b  
\m
\v 14 يُوفَا يَاسُوع إِجّْ ن وسْنُوسْ ؤُشَا إِنْيَا خَاسْ، أَمْ مَامّشْ ثُورَا:   
\b  
\m
\v 15 \qt ”وَارْ تّڭّْوذْ شَا، \+add أَ\+add* يدْجِيسْ ن صِيهْيُونْ،\qt*  
\m \qt خْزَارْ، أَجدْجِيذْ نّمْ أَذْ د-يَاسْ،\qt*  
\m \qt إِقِّيمْ خْ وسْنُوسْ، أَحنْجِيرْ ن ثغْيُوتْشْ.“\qt* \x ◘ \xo 12:‏15 \xt إِشا. 62‏:‏11؛ زَاك. 9‏:‏9؛ مت. 21‏:‏5. \x*   
\b  
\m
\v 16 إِمحْضَارنْ نّسْ وَارْ فْهِيمنْ شَا ثِيمسْڒَايِينْ-أَ ذِي ڒْوقْثْ نِّي. مَاشَا أَوَارْنِي ڒَامِي إِتّْوَاسُّوعْڒَا يَاسُوع، ڒخْذنِّيعقْڒنْ بلِّي مَانْ أَيَا ثُورَا خَاسْ ؤُشَا بلِّي نِيثْنِي ڭِّينْ زَّايسْ مَانْ أَيَا.  
\v 17 ڒْغَاشِي إِ ثُوغَا إِدْجَانْ أَكِيذسْ، ثُوغَا إِشْهذْ أَقَا نتَّا إِڒَاغَا-د خْ أَلِيعَازَارْ زڭْ ونْضڒْ ؤُشَا إِسّْنكَّارْ إِ-ث-إِ-د زِي ثَادَّارْثْ ن إِمتِّيننْ.  
\v 18 س مَانْ أَيَا إِفّغْ ڒْغَاشِي أَمقّْرَانْ مَاحنْذْ أَذْ ث مّڒْقَانْ، مِينْزِي نِيثْنِي سْڒِينْ بلِّي إِڭَّا ڒعْڒَامثْ-أَ.  
\v 19 إِفَارِيسِييّنْ نَّانْ جَارْ أَسنْ: ”ثتّْوَاڒَامْ مْلِيحْ بلِّي كنِّيوْ ثتَّاكّْوَاضمْ غَارْ وَالُو، خْزَارمْ، أَقَا قَاعْ دُّونشْثْ ثضْفَارْ إِ-ث-إِ-د.“ \x ◘ \xo 12:‏19 \xt يُوح. 11‏:‏47. \x*   
\b  
\m  
\s1 يَاسُوع إِسَّاوَاڒْ خْ ڒْموْثْ ذ ثْنُوكْرَا نّسْ  
\m
\v 20 ثُوغَا ذِينْ شَا ن إِوْذَانْ زِي ڒڭْنُوسْ جَارْ أَسنْ إِنِّي د-إِڭعّْذنْ \add غَارْ ؤُرْشَالِيمْ\add* حِيمَا أَذْعبْذنْ ذِي ڒْعِيذْ. \x ◘ \xo 12:‏20 \xt ڒخ. 8‏:‏27. \x*  
\v 21 إِنَا رُوحنْ غَارْ فِيلِيبُّوسْ، ونِّي زِي \add ثنْذِينْثْ ن\add* بَايْثْ-صَايْذَا ذِي لْجَالِيلْ. سّقْسَانْ ث، نَّانْ: ”أَ سِيذِي، نخْسْ أَذْ نْژَارْ يَاسُوع.“ \x ◘ \xo 12:‏21 \xt يُوح. 1‏:‏45. \x*  
\v 22 يُوسَا-د فِيلِيبُّوسْ، إِنَّا \add ت\add* إِ أَنْذْرَاوُوسْ، ؤُشَا أَنْذْرَاوُوسْ ذ فِيلِيبُّوسْ نَّانْ \add ت\add* إِ يَاسُوع.  
\v 23 يَاسُوع يَارَّا-د، إِنَّا أَسنْ: ”أَقَا ثِيوضْ-د ثْسَاعّثْ إِ ذِي إِ غَا إِتّْوَاسّْعُودْجْ مِّيسْ ن بْنَاذمْ. \x ◘ \xo 12:‏23 \xt يُوح. 13‏:‏32؛ 17‏:‏1. \x*  
\v 24 س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: مَاڒَا وَارْ د-إِوْضِي ڒْحبّْ ن يِيرْذنْ ذِي ثمُّورْثْ، أَذْ إِمّثْ، خنِّي أَذْ إِقِّيمْ وحّْذسْ، مَاشَا مَاڒَا إِمُّوثْ، خنِّي أَذْ د-يَاوِي ڒْغِيدْجثْ أَطَّاسْ. \x ◘ \xo 12:‏24 \xt 1 كُور. 15‏:‏36. \x*  
\v 25 ونِّي إِتّخْسنْ ثُوذَارْثْ نّسْ، أَذْ ت إِخْسَارْ، \add مَاشَا\add* ونِّي إِ غَا إِشَارْهنْ ثُوذَارْثْ نّسْ ذِي دُّونشْثْ-أَ، أَذْ ت إِخمّڒْ إِ ثُوذَارْثْ إِتّْذُومَانْ. \x ◘ \xo 12:‏25 \xt مت. 10‏:‏39؛ 16‏:‏25؛ مك. 8‏:‏35؛ لك. 9‏:‏24؛ 17‏:‏33. \x*  
\v 26 مَاڒَا شَا ن يِيجّنْ إِسخَّارْ أَيِي، أجّْ إِ-ث أَذْ أَيِي إِضْفَارْ. مَانِي غَا إِڒِيغْ نشّْ، ذِينِّي إِ غَا يِيڒِي عَاوذْ ؤُمْسخَّارْ إِنُو. مَاڒَا شَا ن إِجّنْ إِخْذمْ أَيِي، أَذْ ث إِشنّعْ بَابَا. \x ◘ \xo 12:‏26 \xt يُوح. 14‏:‏3؛ 17‏:‏24. \x*  
\v 27 ڒخُّو ؤُڒْ إِنُو إِنّهْوڒْ، مِينْ غَا إِنِيغْ؟ \add أَ\add* بَابَا، سنْجمْ أَيِي زِي ثْسَاعّثْ-أَ؟ مَاشَا خْ ؤُينِّي إِ د-ؤُسِيغْ غَارْ ثْسَاعّثْ-أَ. \x ◘ \xo 12:‏27 \xt مت. 26‏:‏37، 38، 39؛ مك. 14‏:‏34؛ لك. 22‏:‏44. \x*  
\v 28 \add أَ\add* بَابَا، سْعُودْجِي إِسمْ نّشْ.“ خنِّي ثُوسَا-د إِشْثْ ن ثْمِيجَّا زڭْ ؤُجنَّا، \add ثنَّا\add*: ”سْعُودْجغْ ث ؤُشَا أَذْ ث سْعُودْجغْ عَاوذْ!“  
\v 29 ڒْغَاشِي إِ ثُوغَا إِبدّنْ ذِينْ إِسْڒَا إِ-ت، نِيثْنِي نَّانْ: ”أَقَا إِمْسَارْ وَاجَّاجْ.“ إِنّغْنِي نَّانْ: ”أَقَا إِسِّيوڒْ-د إِجّْ ن لْمَالَاكْ أَكِيذسْ.“   
\m
\v 30 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”ثْمِيجَّا-يَا وَارْ ثدْجِي شَا ذِي طّْوعْ إِنُو مَاشَا ذِي طّْوعْ نْومْ. \x ◘ \xo 12:‏30 \xt يُوح. 11‏:‏42. \x*  
\v 31 ڒخُّو أَذْ يِيڒِي ڒْحُوكْمْ خْ دُّونشْثْ-أَ، ڒخُّو أَذْ إِمّنْضَارْ ؤُمقّْرَانْ ن دُّونشْثْ-أَ غَارْ بَارَّا. \x ◘ \xo 12:‏31 \xt يُوح. 14‏:‏30؛ 16‏:‏11؛ كُول. 2‏:‏15. \x*  
\v 32 ؤُ نشّْ، خْ مِينِّي إِ غَا تّْوَاسّْڭعّْذغْ زِي ثمُّورْثْ، أَذْ غَارِي د-جبْذغْ مَارَّا.“ \x ◘ \xo 12:‏32 \xt ڒخْڒ. 21‏:‏9؛ 2 إِج. 18‏:‏4؛ يُوح. 3‏:‏14؛ 8‏:‏28. \x*  
\v 33 إِنَّا مَانْ أَيَا حِيمَا أَذْ إِسّْشنْ غَارْ مَانْ ڒْموْثْ إِ غَا إِمّثْ.   
\m
\v 34 ڒْغَاشِي يَارَّا-د خَاسْ: ”نشِّينْ نسْڒَا زِي شَّارِيعَا أَقَا لْمَاسِيحْ أَذْ إِقِّيمْ إِ ڒبْذَا. إِ مَامّشْ ثقَّارذْ شكْ بلِّي إِتّْخصَّا إِ مِّيسْ ن بْنَاذمْ أَذْ إِتّْوَاسّْڭعّذْ؟ مِينْ إِعْنَا مِّيسْ-أَ ن بْنَاذمْ؟“ \x ◘ \xo 12:‏34 \xt 2 صم. 7‏:‏16؛ 1 إِم. 22‏:‏10؛ إِزهد. 45‏:‏7؛ 89‏:‏37؛ 110‏:‏4؛ إِشا. 9‏:‏5؛ إِرْم. 23‏:‏6؛ حِز. 37‏:‏26؛ دَان. 2‏:‏44؛ 7‏:‏14، 27؛ مِيخَا 4‏:‏7؛ عبر. 1‏:‏8. \x*  
\v 35 يَاسُوع إِنَّا أَسنْ: ”ثَافَاوْثْ أَذْ ثِيڒِي أَكِيذْومْ ذْرُوسْ ن ڒْوقْثْ عَاذْ. ؤُيُورمْ، ڒَامِي غَارْومْ ثَافَاوْثْ، حِيمَا وَارْ كنِّيوْ ثتّطّفْ ثَادْجسْثْ. ونِّي إِڭُّورنْ ذِي ثَادْجسْثْ، وَارْ إِسِّينْ مَانِي إِڭُّورْ. \x ◘ \xo 12:‏35 \xt إِرْم. 13‏:‏16؛ يُوح. 1‏:‏9؛ 8‏:‏12؛ 9‏:‏5؛ 12‏:‏46؛ أَفا. 5‏:‏8؛ 1 تس. 5‏:‏4\x*  
\v 36 أَمْنمْ ذِي ثْفَاوْثْ مَاحنْذْ ثَافَاوْثْ عَاذْ أَقَا-ت غَارْومْ، حِيمَا كنِّيوْ أَذْ ثِيڒِيمْ ثَارْوَا ن ثْفَاوْثْ.“ أَمُّو إِ ثُوغَا إِسَّاوَاڒْ يَاسُوع. \add ڒخْذنِّي\add* يُويُورْ ؤُشَا إِنُّوفَارْ زَّايْسنْ.   
\b  
\m  
\s1 بْڒَا لْ-إِيمَانْ ن وُوذَاينْ  
\m
\v 37 وَاخَّا ثُوغَا نتَّا إِتّڭّْ مَارَّا ڒعْڒَامَاثْ-أَ زَّاثْسنْ، نِيثْنِي وَارْ زَّايسْ ؤُمِيننْ شَا،  
\v 38 حِيمَا أَذْ إِتّْوَاكمّڒْ وَاوَاڒْ ن ؤُنَابِي إِشَاعْيَا إِ إِنَّانْ:  
\b  
\m \qt ”\+tl أَ\+tl* سِيذِي، وِي يُومْننْ س ڒخْبَارْ نّغْ\qt*  
\m \qt ؤُ إِ ؤُمِي إِتّْوَاسَّارْڭبْ ؤُفُوسْ ن سِيذِي؟“\qt* \x ◘ \xo 12:‏38 \xt إِشا. 53‏:‏1؛ رُوم. 10‏:‏16. \x*   
\b  
\m
\v 39 س ؤُينِّي وَارْ زمَّارنْ أَذْ أَمْننْ، مِينْزِي إِشَاعْيَا إِنَّا عَاوذْ:   
\b  
\m
\v 40 \qt ”نِيثْنِي سّْذَارْغْڒنْ ثِيطَّاوِينْ \+tl ن يِيخفْ\+tl* نْسنْ،\qt*  
\m \qt سّقْسحنْ ؤُڒَاونْ نْسنْ،\qt*  
\m \qt حِيمَا وَارْ تّثْوِيڒِينْ س ثِيطَّاوِينْ نْسنْ،\qt*  
\m \qt وَارْ فهّْمنْ س وُوڒْ نْسنْ،\qt*  
\m \qt أَذْ ثُوبنْ ؤُشَا نشّْ أَذْ ثنْ سّْڭنْفِيغْ.“\qt* \x ◘ \xo 12:‏40 \xt إِشا. 6‏:‏9‏-‏10؛ حِز. 12‏:‏2؛ مت. 13‏:‏14؛ مك. 4‏:‏12؛ لك. 8‏:‏10؛ ڒخ. 28‏:‏26؛ رُوم. 11‏:‏8 \x*   
\b  
\m
\v 41 إِنَّا إِشَاعْيَا أَمُّو، ؤُمِي إِژْرَا أَعُودْجِي نّسْ ؤُشَا ثُوغَا إِسَّاوَاڒْ خَاسْ. \x ◘ \xo 12:‏41 \xt إِشا. 6‏:‏1. \x*  
\v 42 ؤُمْننْ زَّايسْ عَاوذْ أَطَّاسْ ن إِمقّْرَاننْ \add ن ڒْڭنْسْ\add*، مَاشَا س سِّيبّثْ ن إِفَارِيسِييّنْ وَارْ زَّايسْ شهْذنْ شَا \add س بْطَايْطَايْ\add*، حِيمَا وَارْ ثنْ سُّوفُّوغنْ زِي ثمْزِيذَا. \x ◘ \xo 12:‏42 \xt يُوح. 7‏:‏13؛ 9‏:‏22. \x*  
\v 43 مِينْزِي نِيثْنِي ثُوغَا خْسنْ أَعُودْجِي زڭْ إِوْذَانْ خْ ؤُعُودْجِي زِي أَربِّي. \x ◘ \xo 12:‏43 \xt يُوح. 5‏:‏44. \x*   
\m
\v 44 مَاشَا يَاسُوع إِڒَاغَا، إِنَّا: ”ونِّي ذَايِي إِتَّامْننْ، وَارْ ذَايِي إِتِّيمنْ شَا، مَاشَا ذڭْ ونِّي ذ أَيِي د-إِسّكّنْ.  
\v 45 ونِّي ذ أَيِي إِژْرِينْ، إِژْرَا ونِّي ذ أَيِي د-إِسّكّنْ. \x ◘ \xo 12:‏45 \xt يُوح. 10‏:‏30؛ 14‏:‏9. \x*  
\v 46 نشّْ ذ ثَافَاوْثْ إِ د-يُوسِينْ غَارْ دُّونشْثْ، حِيمَا كُوڒْ إِجّنْ ونِّي ذَايِي إِتَّامْننْ، وَارْ إِتّْغِيمِي شَا ذِي ثَادْجسْثْ. \x ◘ \xo 12:‏46 \xt إِشا. 42‏:‏6؛ 49‏:‏6؛ يُوح. 1‏:‏9؛ 8‏:‏12؛ 9‏:‏5؛ 12‏:‏46؛ ڒخ. 13‏:‏47. \x*  
\v 47 مَاڒَا شَا ن يِيجّنْ إِسْڒَا إِ وَاوَاڒنْ إِنُو، \add مَاشَا\add* وَارْ ذَايْسنْ إِتّطّفْ، نشّْ وَارْ خَاسْ حكّْمغْ شَا. نشّْ وَارْ د-ؤُسِيغْ شَا، حِيمَا أَذْ حكْمغْ خْ دُّونشْثْ، مَاشَا حِيمَا أَذْ وْشغْ ثُوذَارْثْ إِ دُّونشْثْ. \x ◘ \xo 12:‏47 \xt يُوح. 3‏:‏17؛ 9‏:‏39. \x*  
\v 48 ونِّي ذ أَيِي إِسّحْقَارنْ ؤُشَا وَارْ إِقْبِيڒْ أَوَاڒنْ إِنُو، غَارسْ ونِّي خَاسْ إِ غَا إِحكْمنْ: أَوَاڒْ إِ نِّيغْ، أَذْ خَاسْ إِحْكمْ ذڭْ وَاسّْ أَنڭَّارُو. \x ◘ \xo 12:‏48 \xt مك. 16‏:‏16؛ يُوح. 3‏:‏18؛ 8‏:‏24. \x*  
\v 49 مِينْزِي نشّْ وَارْ سِّيوْڒغْ شَا زِي غَارِي، مَاشَا بَابَا ونِّي ذ أَيِي-د-إِسّكّنْ إِوْشَا أَيِي إِشْثْ ن ثوْصيّثْ خْ مِينْ غَا إِنِيغْ ذ مِينْ خفْ غَا سِّيوْڒغْ،\x ◘ \xo 12:‏49 \xt أَعَوذ. 18‏:‏18؛ يُوح. 3‏:‏11؛ 5‏:‏20؛ 7‏:‏16؛ 8‏:‏28؛ 14‏:‏10، 24؛ 16‏:‏13. \x*  
\v 50 ؤُ نشّْ سّْنغْ ثِيوصَّا نّسْ، أَقَا أَثنْثْ ذ ثُوذَارْثْ إِتّْذُومَانْ. س ؤُيَا، مِينْ سَّاوَاڒغْ، سَّاوَاڒغْ ث أَمْ مَامّشْ ذ أَيِي إِنَّا بَابَا.“   
\b  
\b  
\m  
\c 13
\s1 أَسِيرْذْ ن إِضَارنْ ن إِمحْضَارنْ  
\m
\v 1 قْبڒْ إِ ڒْعِيذْ ن \add ثْغَارْصْثْ ن\add* ؤُسعْذُو، ؤُمِي إِسّنْ يَاسُوع أَقَا ثَاسَاعّثْ نّسْ ثِيوضْ-د بلِّي أَذْ إِفّغْ زِي دُّونشْثْ-أَ غَارْ بَابَاسْ، ثُوغَا إِتّخْسْ إِنِّي إِدْجَانْ نّسْ، إِنِّي إِدْجَانْ ذِي دُّونشْثْ، ؤُشَا نتَّا إِتّخْسْ إِ-ثنْ أَڒْ أَنڭَّارُو. \x ◘ \xo 13:‏1 \xt مت. 26‏:‏2؛ مك. 14‏:‏1؛ لك. 22‏:‏1. \x*   
\m
\v 2 غَارْ ؤُمنْسِي، ؤُمِي إِعَارْنْ شِّيطَانْ ؤُڒْ ن يَاهُوذَا، مِّيسْ ن شِيمْعُونْ إِسْخَارِييُوطِي، مَاحنْذْ أَذْ ث إِسلّمْ، \x ◘ \xo 13:‏2 \xt لك. 22‏:‏3؛ يُوح. 13‏:‏2. \x*  
\v 3 إِكَّارْ-د يَاسُوع خْ ؤُمنْسِي، مِينْزِي ثُوغَا إِسّنْ بلِّي بَابَاسْ إِوْشَا أَسْ كُوڒْشِي ذڭْ إِفَاسّنْ نّسْ ؤُ بلِّي إِفّغْ-د زِي غَارْ أَربِّي ؤُ غَارْ أَربِّي إِ غَا إِرَاحْ، \x ◘ \xo 13:‏3 \xt مت. 11‏:‏27؛ يُوح. 3‏:‏35؛ 16؛28. \x*  
\v 4 ؤُشَا إِكّسْ أَرُّوضْ نّسْ، إِكْسِي إِجّْ ن ؤُمنْذِيڒْ ؤُشَا إِبْيسْ إِ-ث إِ يِيخفْ نّسْ.  
\v 5 إِفَارّغْ أَمَانْ ذِي ثْبَانْيُوثْ ؤُشَا إِبْذَا إِسِّيرِيذْ إِضَارنْ ن إِمحْضَارنْ، إِمسّحْ أَسنْ س ؤُمنْذِيڒْ إِ زِي ثُوغَا إِبْيسْ.   
\m
\v 6 ڒَامِي د-يُوسَا غَارْ شِيمْعُونْ بُوطْرُوسْ، إِنَّا أَسْ شِيمْعُونْ: ”\add أَ\add* سِيذِي، مَا أَذْ ثسِّيرْذذْ إِضَارنْ إِنُو؟“ \x ◘ \xo 13:‏6 \xt مت. 3‏:‏14. \x*  
\v 7 يَارَّا-د يَاسُوع، إِنَّا أَسْ: ”شكْ وَارْ ثفْهِيمذْ شَا ڒخُّو مِينْ تّڭّغْ، مَاشَا أَذْ ثْفهْمذْ مَانْ أَيَا أَوَارْنِي مَانَاونِّي.“  
\v 8 إِنَّا أَسْ شِيمْعُونْ بُوطْرُوسْ: ”قَاعْعمَّارْصْ أَذْ ثسِّيرْذذْ إِضَارنْ إِنُو.“ يَارَّا-د خَاسْ يَاسُوع: ”مَاڒَا وَارْ ذ أَشْ سِّيرْذغْ، وَارْ غَاركْ ثتِّيڒِي بُو ثَاسْغَارْثْ أَكِيذِي.“  
\v 9 إِنَّا أَسْ شِيمْعُونْ بُوطْرُوسْ: ”\add أَ\add* سِيذِي، \add خنِّي\add* وَارْ ثسِّيرِيذْ إِضَارنْ إِنُو وَاهَا، مَاشَا ؤُڒَا ذ إِفَاسّنْ إِنُو ذ ؤُزدْجِيفْ إِنُو.“  
\v 10 يَاسُوع إِنَّا أَسْ: ”ونِّي إِتّْوَاسِيرْذنْ قَاعْ \add ذِي ثْبَانْيُوثْ\add*، وَارْ إِحْذِيجْ مْغِيرْ أَذْ تّْوَاسِيرْذنْ إِضَارنْ نّسْ وَاهَا، مِينْزِي عَاذْ نتَّا ذ أَمزْذَاڭْ. ؤُڒَا ذ كنِّيوْ ثِيزْذِيڭمْ، مَاشَا وَارْ إِدْجِي مَارَّا.“ \x ◘ \xo 13:‏10 \xt يُوح. 15‏:‏3. \x*  
\v 11 يَاسُوع ثُوغَا إِسّنْ وِي ث غَا إِغْذَارنْ، س ؤُينِّي إِنَّا: ”كنِّيوْ وَارْ ثدْجِيمْ شَا مَارَّا ذ إِمزْذَاڭْ.“ \x ◘ \xo 13:‏11 \xt يُوح. 6‏:‏64. \x*   
\m
\v 12 أَوَارْنِي ڒَامِي إِسِّيرْذْ إِضَارنْ نْسنْ، يَارْضْ أَرُّوضْ نّسْ \add عَاوذْ\add*، خنِّي إِقِّيمْ، إِنَّا أَسنْ: ”مَا ثْفهْممْ مِينْ ذَايْومْ ڭِّيغْ؟  
\v 13 كنِّيوْ ثتّْڒَاغَامْ أَيِي ’أَمْسڒْمَاذْ نّغْ!‘ ذ ’سِيذِيثْنغْ!‘، ؤُشَا ثِيذتّْ إِ ثنَّامْ، مِينْزِي وَا ذ نشّْ. \x ◘ \xo 13:‏13 \xt مت. 23‏:‏8، 10؛ 1 كُور. 8‏:‏6؛ 12‏:‏3؛ فِيل. 2‏:‏11. \x*  
\v 14 مَاڒَا نشّْ ذ سِيذِي نْومْ ذ أَمْسڒْمَاذْ نْومْ، ؤُشَا سِّيرْذغْ إِضَارنْ نْومْ، مَاهُو إِتّْخصَّا ؤُڒَا إِ كنِّيوْ أَذْ ثسِّيرْذمْ إِضَارنْ إِجّنْ إِ ونّغْنِي! \x ◘ \xo 13:‏14 \xt ڭال. 6‏:‏1، 2. \x*  
\v 15 مِينْزِي نشّْ زعْمَا وْشِيغْ أَومْ أَمذْيَا-يَا، حِيمَا، أَمْ مَامّشْ ڭِّيغْ نشّْ أَكِيذْومْ، أَذْ ثڭّمْ كنِّيوْ عَاوذْ \add أَكْ-ذ وَايَاوْيَا\add*. \x ◘ \xo 13:‏15 \xt 1 بُط. 2‏:‏21؛ 1 يُوح. 2‏:‏6. \x*  
\v 16 س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: وَارْ ذِينْ إِدْجِي ؤُمْسخَّارْ ونِّي يُوعْڒَانْ خْ سِيذسْ، ؤُڒَا ذ أَرقَّاسْ يُوعْڒَانْ خْ ونِّي إِ-ث-إِ-د-إِسّكّنْ. \x ◘ \xo 13:‏16 \xt مت. 10‏:‏24؛ لك. 6‏:‏40؛ يُوح. 15‏:‏20. \x*  
\v 17 مَاڒَا ثسّْنمْ ثِيمسْڒَايِينْ-أَ، أَذْ ثِيڒِيمْ ثتّْوَابَارْكمْ مَاڒَا ثڭِّيمْ زَّايْسنْثْ.   
\b  
\m  
\s1 يَاسُوع إِسّنْ ونِّي ث إِ غَا إِسلّْمنْ  
\m
\v 18 وَارْ ث قَّارغْ شَا خَاومْ مَارَّا، مَاغَارْ سّْنغْ إِنِّي إِ خْضَارغْ، مَاشَا حِيمَا أَذْ إِتّْوَاكمّڒْ مِينْ يُورَانْ ذڭْ وذْلِيسْ \add إِ إِقَّارنْ\add*: ’ونِّي إِ غَا إِشّنْ زڭْ وغْرُومْ أَكِيذِي، أَقَا إِسّْڭعّذْ خَافِي أَنِيرْزْ نّسْ.‘ \x ◘ \xo 13:‏18 \xt [مت. 26‏:‏20‏-‏25؛ مك. 14‏:‏17‏-‏21؛ لك. 22‏:‏21‏-‏23] — إِزهد. 41‏:‏10؛ مت. 26‏:‏23؛ 1 يُوح. 2‏:‏19. \x*  
\v 19 ڒخُّو أَذْ أَومْ ث إِنِيغْ قْبڒْ مَا أَذْ إِمْسَارْ، حِيمَا، خْ مِينِّي إِ غَا إِمْسَارْ، أَذْ ثَامْنمْ بلِّي أَقَا ذ نشّْ. \x ◘ \xo 13:‏19 \xt يُوح. 14‏:‏29؛ 16‏:‏4. \x*  
\v 20 س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: ونِّي إِ غَا إِقبْڒنْ ونِّي د غَا سّكّغْ، أَذْ أَيِي إِقْبڒْ، ؤُ ونِّي ذ أَيِي غَا إِقبْڒنْ، أَذْ إِقْبڒْ ؤُڒَا ذ ونِّي ذ أَيِي د-إِسّكّنْ.“ \x ◘ \xo 13:‏20 \xt مت. 10‏:‏40؛ لك. 10‏:‏16. \x*  
\v 21 ڒَامِي إِنَّا يَاسُوع مَانْ أَيَا، إِنّهْوڒْ أَرُّوحْ نّسْ أَطَّاسْ، ؤُشَا إِشْهذْ، إِنَّا: ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: إِجّنْ زَّايْومْ أَذْ ذَايِي إِغْذرْ!“ \x ◘ \xo 13:‏21 \xt مت. 26‏:‏21؛ مك. 14‏:‏18؛ لك. 22‏:‏21؛ ڒخ. 1‏:‏17؛ 1 يُوح. 2‏:‏19. \x*  
\v 22 إِمحْضَارنْ خْزَارنْ غَارْ وَايَاوْيَا، مِينْزِي وَارْ سِّيننْ ذِي مِينْ خفْ ثُوغَا إِسَّاوَاڒْ.  
\v 23 ثُوغَا ذِينْ إِجّنْ زڭْ إِمحْضَارنْ نّسْ إِ ثُوغَا إِتّخْسْ يَاسُوع، ثُوغَا إِسنّذْ غَارْ وحْسِينْ ن يَاسُوع. \x ◘ \xo 13:‏23 \xt يُوح. 20‏:‏2؛ 21‏:‏7، 20. \x*  
\v 24 إِسّْشنْ شِيمْعُونْ بُوطْرُوسْ غَارسْ، حِيمَا نتَّا أَذْ ث إِسّقْسَا مِينْ إِعْنَا ونِّي مِينْ خفْ ثُوغَا إِسَّاوَاڒْ \add أَمُّو\add*.  
\v 25 أَمحْضَارْ نِّي يَارَّا إِخفْ نّسْ إِتّْميّڒْ غَارْ إِذْمَارنْ ن يَاسُوع، إِنَّا أَسْ: ”\add أَ\add* سِيذِي، مِينْ إِعْنَا؟“  
\v 26 يَارَّا-د يَاسُوع، إِنَّا: ”ذ ونِّي ؤُمِي غَا سِّيسْنغْ \add أَڒقِّيمْ ن\add* وغْرُومْ، أَذْ أَسْ \add ث\add* وْشغْ.“ ڒخْذنِّي إِسِّيسنْ \add أَڒقِّيمْ ن\add* وغْرُومْ، إِوْشَا أَسْ \add ث-إِ\add*-د إِ يَاهُوذَا، مِّيسْ ن شِيمْعُونْ إِسْخَارِييُوطِي.   
\m
\v 27 أَوَارْنِي \add إِطّفْ ؤُڒقِّيمْ ن\add* وغْرُومْ، يُوذفْ إِ-ث شِّيطَانْ. إِنَّا أَسْ يَاسُوع: ”مِينْ \add ثخْسذْ\add* أَذْ ث ثڭّذْ، أڭّْ إِ-ث ذغْيَا.“  
\v 28 ؤُڒَا ذ إِجّْ زڭْ إِنِّي ثُوغَا إِقِّيمنْ \add غَارْ ؤُمنْسِي\add* وَارْ إِسِّينْ مَايمِّي نتَّا إِ ذ أَسْ إِنَّا مَانْ أَيَا.  
\v 29 مَاغَارْ إِتّْغِيڒْ أَسنْ إِ شَا \add زَّايْسنْ\add*، ؤُمِي يَاهُوذَا أَقَا-ث خْ سّنْذُوقْ، أَقَا يَاسُوع يُومُورْ إِ-ث حِيمَا أَذْ إِسغْ شَا مِينْ حْذَاجنْ نِيثْنِي إِ ڒْعِيذْ، نِيغْ حِيمَا أَذْ إِوْشْ شَا إِ إِمزْڒَاضْ. \x ◘ \xo 13:‏29 \xt يُوح. 12‏:‏6. \x*  
\v 30 وَانِيثَا، أَوَارْنِي ڒَامِي إِطّفْ \add أَڒقِّيمْ ن\add* وغْرُومْ، إِفّغْ ذغْيَا. ثُوغَا ذ دْجِيڒثْ ؤُمِي إِفّغْ.   
\b  
\m  
\s1 أَسْعُودْجِي ن يَاسُوع - خْ ثَايْرِي جَارْ وَاوْمَاثنْ  
\m
\v 31 إِنَّا يَاسُوع: ”أَقَا ڒخُّو إِتّْوَاسّْعُودْجْ مِّيسْ ن بْنَاذمْ ؤُشَا إِتّْوَاسّْعُودْجْ أَربِّي ذَايسْ.  
\v 32 مَاڒَا أَربِّي أَقَا إِتّْوَاسّْعُودْجْ ذَايسْ، ڒخْذنِّي أَربِّي أَذْ إِسّْعُودْجْ إِخفْ نّسْ ذَايسْ، \add وَاهْ،\add* أَذْ ث إِسّْعُودْجْ ذغْيَا. \x ◘ \xo 13:‏32 \xt يُوح. 12‏:‏23؛ 17‏:‏1. \x*  
\v 33 \add أَ\add* إِحنْجِيرنْ إِنُو إِمژْيَاننْ، نشّْ أَقَا أَيِي أَكِيذْومْ ذْرُوسْ ن ڒْوقْثْ عَاذْ. كنِّيوْ أَذْ خَافِي ثَارْزُومْ، ؤُشَا أَمْ مَامّشْ نِّيغْ إِ وُوذَاينْ: ’مَانِي غَا رَاحغْ نشّْ، وَارْ ثْزمَّارمْ أَذْ د-ثَاسمْ!‘، أَمُّو إِ ذ أَومْ غَا إِنِيغْ عَاوذْ ڒخُّو. \x ◘ \xo 13:‏33 \xt يُوح. 7‏:‏34؛ 8‏:‏21. \x*   
\m
\v 34 ثَاوْصيّثْ ن جْذِيذْ إِ ذ أَومْ غَا وْشغْ حِيمَا أَذْ ثخْسمْ إِجّنْ ونّغْنِي. أَمْ مَامّشْ نشّْ تّخْسغْ كنِّيوْ، إِتّْخصَّا ؤُڒَا ذ كنِّيوْ أَذْ ثخْسمْ أَيَاوْيَا. \x ◘ \xo 13:‏34 \xt لَاوِي 19‏:‏18؛ مت. 22‏:‏39؛ يُوح. 15‏:‏12؛ أَفا. 5‏:‏2؛ 1 تس. 4‏:‏9؛ 1 بُط. 4‏:‏8؛ 1 يُوح. 2‏:‏23، 3‏:‏23؛ 4‏:‏21.\x*  
\v 35 س مَانْ أَيَا أَذْ سّْننْ مَارَّا، أَقَا كنِّيوْ ذ إِمحْضَارنْ إِنُو، مَاڒَا ذِينْ غَارْومْ ثَايْرِي جَارْ أَومْ.“ \x ◘ \xo 13:‏35 \xt 1 يُوح. 2‏:‏5؛ 4‏:‏20. \x*   
\b  
\m  
\s1 يَاسُوع إِزْوَارْ إِسِّيوِيڒْ خْ ونْكَارْ ن بُوطْرُوسْ  
\m
\v 36 شِيمْعُونْ بُوطْرُوسْ إِنَّا أَسْ: ”\add أَ\add* سِيذِيثْنغْ، مَانِي غَا ثْرَاحذْ؟“ يَارَّا-د يَاسُوع، إِنَّا أَسْ: ”مَانِي غَا رَاحغْ نشّْ، وَارْ ثْزمَّارذْ ڒخُّو أَذْ أَيِي ثضْفَارذْ، مَاشَا غَارْ ؤُنڭَّارُو أَذْ ثَاسذْ.“ \x ◘ \xo 13:‏36 \xt [مت. 26‏:‏31‏-‏35؛ مك. 14‏:‏27‏-‏31؛ لك. 22‏:‏31‏-‏34] — يُوح. 21‏:‏18؛ 2 بُط. 1‏:‏14. \x*  
\v 37 شِيمْعُونْ بُوطْرُوسْ إِنَّا أَسْ: ”\add أَ\add* سِيذِي، مَايمِّي وَارْ زمَّارغْ أَذْ أَسغْ أَوَارْنِي أَشْ ڒخُّو؟ نشّْ أَذْ وْشغْ ثُوذَارْثْ إِنُو إِ شكْ.“ \x ◘ \xo 13:‏37 \xt مت. 26‏:‏33؛ مك. 14‏:‏29؛ لك. 22‏:‏33. \x*  
\v 38 إِنَّا أَسْ يَاسُوع: ”مَا ثخْسذْ أَذْ ثسَّارْسذْ ثُوذَارْثْ نّشْ ذِي طّْوعْ إِنُو؟ س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَشْ إِنِيغْ: وَارْ إِسْقُوقُوعْ ؤُيَاژِيضْ، قْبڒْ مَا أَذْ أَيِي ثنْكَارذْ ثْڒَاثَا ن ثْوَاڒَاوِينْ.“ \x ◘ \xo 13:‏38 \xt مت. 26‏:‏34؛ مك. 14‏:‏30؛ لك. 22‏:‏34. \x*   
\b  
\b  
\m  
\c 14
\s1 يَاسُوع نتَّا ذ أَبْرِيذْ ذ ثِيذتّْ ذ ثُوذَارْثْ  
\m
\v 1 ”وَارْ تّجِّيمْ أَذْ إِنّهْوڒْ ؤُڒْ نْومْ. كنِّيوْ ثُومْنمْ ذِي أَربِّي، أَمْنمْ عَاوذْ ذَايِي.  
\v 2 ذِي ثَادَّارْثْ ن بَابَا ذَايسْ أَطَّاسْ ن ثْزذِّيغِينْ. معْلِيكْ وَارْ إِدْجِي أَمنِّي، إِڒِي نِّيغْ أَومْ ث، مِينْزِي نشّْ أَذْ رَاحغْ، حِيمَا أَذْ أَومْ سّْوجْذغْ أَمْشَانْ.  
\v 3 أَوَارْنِي ڒَامِي رُوحغْ ؤُشَا سّْوجْذغْ أَومْ أَمْشَانْ، خنِّي أَذْعقْبغْ، أَذْ كنِّيوْ د-أَوْيغْ غَارِي، حِيمَا، مَانِي دْجِيغْ نشّْ، أَذْ ذِينْ ثِيڒِيمْ ؤُڒَا ذ كنِّيوْ. \x ◘ \xo 14:‏3 \xt يُوح. 12‏:‏26؛ 17‏:‏24. \x*  
\v 4 أَقَا ثسّْنمْ مَانِي غَا رَاحغْ ؤُشَا ثسّْنمْ أَبْرِيذْ.“   
\m
\v 5 إِنَّا أَسْ ثُومَا: ”\add أَ\add* سِيذِيثْنغْ، وَارْ نسِّينْ مَانِي غَا ثْرَاحذْ إِ مَامّشْ نْزمَّارْ أَذْ نسّنْ أَبْرِيذْ؟“  
\v 6 يَاسُوع إِنَّا أَسْ: ”نشّْ ذ أَبْرِيذْ ذ ثِيذتّْ ذ ثُوذَارْثْ، وَارْ د-إِتِّيسْ ؤُڒَا ذ إِجّْ غَارْ بَابَا مْغِيرْ زَّايِي. \x ◘ \xo 14:‏6 \xt يُوح. 1‏:‏4، 17؛ 10‏:‏9؛ 11‏:‏25؛ عبر. 9‏:‏8. \x*  
\v 7 مَاڒَا ثُوغَا ثسّْنمْ أَيِي، أَذْ ثِيڒِي أَقَا ثسّْنمْ ؤُڒَا ذ بَابَا. زِي ڒخُّو أَقَا ثسّْنمْ ث، ثژْرِيمْ ث.“   
\m
\v 8 فِيلِيبُّوسْ إِنَّا أَسْ: ”\add أَ\add* سِيذِيثْنغْ، سْشنْ أَنغْ بَابَاشْ، ؤُشَا إِكْفَا.“  
\v 9 يَاسُوع إِنَّا أَسْ: ”أَنشْثْ ؤُيَا ن ڒْوقْثْ قَاعْ نشّْ أَكِيذْومْ، مَا وَارْ ذ أَيِي ثسِّينذْ \add عَاذْ\add*، \add أَ\add* فِيلِيبُّوسْ؟ ونِّي ذ أَيِي إِژْرِينْ، إِژْرَا بَابَا. مَامّشْ ثقَّارذْ: ’سْشنْ أَنغْ بَابَاشْ‘؟ \x ◘ \xo 14:‏9 \xt يُوح. 10‏:‏30. \x*  
\v 10 مَا وَارْ ثُومِينذْ شَا أَقَا نشّْ أَقَا أَيِي ذِي بَابَا ذ بَابَا أَقَا-ث ذَايِي؟ أَوَاڒنْ إِ قَّارغْ، وَارْ ثنْ قَّارغْ شَا زِي غَارِي، مَاشَا بَابَا ونِّي ذَايِي إِزدّْغنْ، نتَّا إِتّڭّْ ڒخْذَايمْ-أَ. \x ◘ \xo 14:‏10 \xt يُوح. 5‏:‏17؛ 7‏:‏16؛ 8‏:‏28؛ 10‏:‏38؛ 12‏:‏49؛ 16‏:‏13؛ 17‏:‏21. \x*  
\v 11 أَمْنمْ أَيِي، أَقَا نشّْ أَقَا أَيِي ذِي بَابَا ؤُ بَابَا أَقَا-ث ذَايِي، ؤُ مَاڒَا لَّا، أَمْنمْ أَيِي خْ سِّيبّثْ ن ڒخْذَايمْ سِيمَانْثْ نْسنْثْ.  
\v 12 س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: ونِّي ذَايِي يُومْننْ، أَقَا ڒخْذَايمْ إِ تّڭّغْ، أَذْ زَّايْسنْثْ إِڭّْ ؤُڒَا ذ نتَّا، ؤُشَا أَذْ إِڭّْ ثِينِّي إِدْجَانْ ذ ثِيمقّْرَانِينْ خْ مَانْ أَيَا، مِينْزِي نشّْ أَذْ رَاحغْ غَارْ بَابَا. \x ◘ \xo 14:‏12 \xt مت. 21‏:‏21؛ لك. 17‏:‏6؛ ڒخ. 5‏:‏12؛ 19‏:‏11. \x*  
\v 13 ؤُشَا مَارَّا مِينْ غَا ثتَّارمْ س يِيسمْ إِنُو، أَذْ ث ڭّغْ إِ كنِّيوْ، حِيمَا أَذْ إِتّْوَاسّْعُودْجْ بَابَا ذِي مِّيسْ. \x ◘ \xo 14:‏13 \xt إِرْم. 29‏:‏12؛ مت. 7‏:‏7؛ 21‏:‏22؛ مك. 11‏:‏24؛ لك. 11‏:‏9؛ يُوح. 15‏:‏7؛ 16‏:‏24؛ يَاع. 1‏:‏5؛ 1 يُوح. 3‏:‏22. \x*  
\v 14 مَاڒَا ذ أَيِي غَا ثتَّارمْ س يِيسمْ إِنُو، أَذْ ث ڭّغْ.   
\b  
\m  
\s1 لْوَاعْذْ ن أَرُّوحْ إِقدّْسنْ  
\m
\v 15 مَاڒَا ثخْسمْ أَيِي، طّْفمْ ذِي ثْوصَّا إِنُو، \x ◘ \xo 14:‏15 \xt يُوح. 14‏:‏21، 23؛ 15‏:‏10؛ 1 يُوح. 5‏:‏3. \x*  
\v 16 ؤُشَا نشّْ أَذْ ژَّادْجغْ إِ بَابَا ؤُ نتَّا أَذْ أَومْ إِوْشْ إِجّْ ن ؤُمْسصْڒَاحْ \bd نّغْنِي\bd*، حِيمَا أَذْ كِيومْ إِقِّيمْ إِ ڒبْذَا:  
\v 17 أَرُّوحْ ن ثِيذتّْ ثنِّي وَارْ ثْزمَّارْ دُّونشْثْ أَذْ ث ثقْبڒْ، مِينْزِي وَارْ ث ثتّْوِيڒِي، وَارْ ث ثسِّينْ. مَاشَا كنِّيوْ ثسّْنمْ ث، مِينْزِي نتَّا إِتّْغِيمَا أَكِيذْومْ ؤُ نتَّا أَقَا-ث ذَايْومْ.“   
\m
\v 18 ”وَارْ كنِّيوْ تّجِّيغْ شَا ذ إِيُوجِيڒنْ، مَاغَارْ أَوَارْنِي ذْرُوسْ نْ ڒْوقْثْ نشّْ أَذْ غَارْومْ د-أَسغْ \add عَاوذْ\add*. \x ◘ \xo 14:‏18 \xt مت. 28‏:‏20. \x*  
\v 19 دُّونشْثْ وَارْ ذ أَيِي ثْژَارّْ، مَاشَا كنِّيوْ أَذْ أَيِي ثْوَاڒَامْ. مِينْزِي نشّْ دَّارغْ، أَذْ ثدَّارمْ ؤُڒَا ذ كنِّيوْ.  
\v 20 ذڭْ وَاسّْ نِّي أَذْ ثسّْنمْ، أَقَا نشّْ أَقَا أَيِي ذِي بَابَا، كنِّيوْ ذَايِي ؤُ نشّْ ذَايْومْ.   
\m
\v 21 ونِّي غَارْ إِدْجَا ثِيوصَّا إِنُو ؤُشَا أَذْ ذَايْسنْثْ إِطّفْ، ذ ونِّي ذ أَيِي إِتّخْسنْ، ؤُ ونِّي ذ أَيِي إِتّخْسنْ، ؤُڒَا ذ بَابَا أَذْ ث إِخْسْ ؤُ نشّْ أَذْ ث خْسغْ \add عَاوذْ\add* ؤُشَا أَذْ أَسْ سّشْنغْ إِخفْ إِنُو.“  
\v 22 إِنَّا أَسْ يَاهُوذَا، وَارْ إِدْجِي ذ إِسْخَارِييُوطِي: ”\add أَ\add* سِيذِي، مَامّشْ ذ أَنغْ إِ غَا ثسّشْنذْ إِخفْ نّشْ، وَارْ إِدْجِي شَا إِ دُّونشْثْ؟“  
\v 23 يَاسُوع يَارَّا-د، إِنَّا أَسْ: ”مَاڒَا شَا ن يِيجّنْ إِخْسْ أَيِي، خنِّي أَذْ إِطّفْ ذڭْ وَاوَاڒْ إِنُو ؤُشَا بَابَا أَذْ ث إِخْسْ، ؤُشَا غَارسْ إِ د غَا نَاسْ ؤُ غَارسْ إِ غَا نڭّْ ثَازذِّيغْثْ نّغْ.  
\v 24 ونِّي وَارْ ذ أَيِي إِتّخْسنْ، وَارْ إِتّطِّيفْ شَا ذڭْ وَاوَاڒْ إِنُو، ؤُشَا أَوَاڒْ-أَ إِ ثسْڒِيمْ، وَارْ إِدْجِي شَا زِي غَارِي، مَاشَا زِي بَابَا، ونِّي ذ أَيِي د-إِسّكّنْ. \x ◘ \xo 14:‏24 \xt يُوح. 7‏:‏16؛ 8‏:‏28؛ 12‏:‏49؛ 14‏:‏10؛ 16‏:‏13. \x*   
\m
\v 25 سِّيوْڒغْ أَكِيذْومْ مَانْ أَيَا ؤُمِي نشّْ \add عَاذْ\add* أَكِيذْومْ.  
\v 26 مَاشَا ؤُمْسصْڒَاحْ، أَرُّوحْ إِقدّْسنْ، ونِّي إِ د غَا إِسّكّْ بَابَا س يِيسمْ إِنُو، أَذْ أَومْ إِسّڒْمذْ كُوڒْشِي، أَذْ أَومْ إِسّْفكَّارْ مَارَّا مِينْ ذ أَومْ نِّيغْ. \x ◘ \xo 14:‏26 \xt لك. 24‏:‏49؛ يُوح. 15‏:‏26؛ 16‏:‏7، 13؛ ڒخ. 2‏:‏4. \x*   
\m
\v 27 ڒهْنَا أَذْ أَومْ ث جّغْ، نشّْ أَذْ أَومْ وْشغْ ڒهْنَا إِنُو. نشّْ أَذْ أَومْ \add ث\add* وْشغْ، وَارْ إِدْجِي شَا أَمْ مَامّشْ \add ث\add* ثتِّيشْ دُّونشْثْ. وَارْ ثجِّيمْ أَذْ إِنّهْوڒْ ؤُڒْ نْومْ، وَارْ تّڭّْوذمْ شَا. \x ◘ \xo 14:‏27 \xt فِيل. 4‏:‏7. \x*  
\v 28 أَقَا ثسْڒِيمْ نشّْ نِّيغْ أَومْ: ’نشّْ أَذْ ؤُيُورغْ ؤُشَا أَذْ غَارْومْ د-أَسغْ عَاوذْ‘. مَاڒَا ثخْسمْ أَيِي، أَذْ ثْفَارْحمْ، مِينْزِي أَقَا أَذْ رَاحغْ غَارْ بَابَا، مِينْزِي بَابَا إِمْغَارْ خَافِي! \x ◘ \xo 14:‏28 \xt يُوح. 14‏:‏3. \x*  
\v 29 ؤُشَا ڒخُّو، خْزَارْ، نشّْ نِّيغْ أَومْ ت قْبڒْ مَا أَذْ يِيڒِي، حِيمَا كنِّيوْ، خْ مِينِّي إِ غَا يِيڒِي ؤُيَا، أَذْ ثَامْنمْ. \x ◘ \xo 14:‏29 \xt يُوح. 13‏:‏19؛ 16‏:‏4. \x*  
\v 30 أَوَارْنِي مَانْ أَيَا وَارْ كِيومْ سِّيوِيڒغْ \add عَاذْ\add* أَطَّاسْ كْثَارْ، مَاغَارْ أَذْ د-يَاسْ ؤُمقّْرَانْ ن دُّونشْثْ-أَ، وَارْ غَارسْ إِتِّيڒِي وَالُو ذَايِي، \x ◘ \xo 14:‏30 \xt يُوح. 12‏:‏31؛ 16‏:‏11؛ أَفا. 2‏:‏2. \x*  
\v 31 مَاشَا إِتّْخصَّا أَذْ ثسّنْ دُّونشْثْ أَقَا نشّْ تّخْسغْ بَابَا ؤُشَا تّڭّغْ مِينْ ذ أَيِي إِوصَّا بَابَا. كَّارمْ، أَذْ نُويُورْ سَّانِيثَا.“ \x ◘ \xo 14:‏31 \xt يُوح. 10‏:‏18؛ عبر. 10‏:‏5. \x*   
\b  
\b  
\m  
\c 15
\s1 ثَازَايَارْثْ ذ ثِيصذْوِينْ نّسْ  
\m
\v 1 ”نشّْ ذ ثَازَايَارْثْ ن ثِيذتّْ، بَابَا ذ بَابْ ن وحْوِيشْ ن ثْزَايَارْثْ.  
\v 2 كُوڒْ ثَاسطَّا ذَايِي إِ وَارْ إِتِّيشنْ ڒْغِيدْجثْ، أَذْ ت إِكّسْ، ؤُشَا كُوڒْ \add ثَاسطَّا\add* إِ د-إِتَّاوْينْ ڒْغِيدْجثْ، أَذْ ت إِسِّيزْذڭْ، حِيمَا أَذْ ثَارْنِي ذِي ڒْغِيدْجثْ. \x ◘ \xo 15:‏2 \xt مت. 15‏:‏13. \x*  
\v 3 كنِّيوْ أَقَا ثتّْوَاسِّيزذْڭمْ زِي سِّيبّثْ ن وَاوَاڒْ إِ ذ أَومْ نِّيغْ. \x ◘ \xo 15:‏3 \xt يُوح. 13‏:‏10. \x*  
\v 4 قِّيممْ ذَايِي، \add أَمْ مَامّشْ\add* نشّْ أَقَا أَيِي ذَايْومْ. أَمْ ثْسطَّا إِ وَارْ إِزمَّارنْ أَذْ د-ثَاوْيِي ڒْغِيدْجثْ زڭْ إِخفْ نّسْ مَاڒَا وَارْ ثقِّيمْ ذِي ثْزَايَارْثْ، أَمْيَا ؤُڒَا ذ كنِّيوْ، مْغِيرْ مَاڒَا ثقِّيممْ ذَايِي.  
\v 5 نشّْ ذ ثَازَايَارْثْ، كنِّيوْ ذ ثِيسضْوِينْ. ونِّي ذَايِي إِ غَا إِقِّيمنْ ؤُ نشّْ ذَايسْ، نتَّا أَذْ د-يَاوِي ڒْغِيدْجثْ أَطَّاسْ، مِينْزِي بْڒَا زَّايِي وَارْ ثْزمَّارمْ أَذْ ثڭّمْ وَالُو.  
\v 6 مَاڒَا شَا ن يِيجّنْ وَارْ ذَايِي إِقِّيمْ، أَذْ إِمّنْضَارْ غَارْ بَارَّا أَمْ ثْسطَّا ثُوژغْ، خنِّي أَذْ ت يَارْونْ، أَذْ ت نْضَارنْ ذِي ثْمسِّي، أَذْ يَارغْ. \x ◘ \xo 15:‏6 \xt حِز. 15‏:‏2‏-‏8؛ مت. 3‏:‏10؛ 7‏:‏19؛ كُول. 1‏:‏23. \x*  
\v 7 مَاشَا مَاڒَا ثقِّيممْ ذَايِي ؤُشَا أَوَاڒنْ إِنُو أَذْ ذَايْومْ قِّيمنْ، تَّارمْ مِينْ ثخْسمْ ؤُشَا أَذْ غَارْومْ يِيڒِي. \x ◘ \xo 15:‏7 \xt إِرْم. 29‏:‏12؛ مت. 7‏:‏7؛ 21‏:‏22؛ مك. 11‏:‏24؛ لك. 11‏:‏9؛ يُوح. 14‏:‏13؛ 16‏:‏24؛ يَاع. 1‏:‏5؛ 1 يُوح. 3‏:‏22؛ 5‏:‏14. \x*  
\v 8 زِي مَانْ أَيَا أَذْ إِتّْوَاسّْعُودْجْ بَابَا، خْمِي إِ د غَا ثَاوْيمْ أَطَّاسْ ن ڒْغِيدْجثْ ؤُشَا أَذْ ثِيڒِيمْ ذ إِمحْضَارنْ إِنُو.   
\m
\v 9 أَمْ مَامّشْ بَابَا ثُوغَا إِتّخْسْ أَيِي، أَمُّو ؤُڒَا ذ نشّْ ثُوغَا تّخْسغْ كنِّيوْ. قِّيممْ ذِي ثَايْرِي إِنُو.  
\v 10 مَاڒَا ثطّْفمْ ذِي ثْوصَّا إِنُو، أَذْ ثقِّيممْ ذِي ثَايْرِي إِنُو، أَمْ مَامّشْ نشّْ ثُوغَا تّطّْفغْ ذِي ثْوصَّا ن بَابَا ؤُشَا تّْغِيمغْ ذِي ثَايْرِي نّسْ. \x ◘ \xo 15:‏10 \xt يُوح. 14‏:‏15، 21، 23؛ 1 يُوح. 5‏:‏3. \x*   
\m
\v 11 نِّيغْ أَومْ مَانْ أَيَا، حِيمَا أَذْ ذَايْومْ ثِيڒِي ڒفْرَاحثْ إِنُو ؤُشَا حِيمَا أَذْ ثتّْوَاكمّڒْ ڒفْرَاحثْ نْومْ.  
\v 12 ثَاوْصيّثْ إِنُو ذ ثَانِيثَا: أَقَا أَذْ ثخْسمْ إِجّنْ ونّغْنِي أَمْ مَامّشْ نشّْ ثُوغَا خْسغْ كنِّيوْ. \x ◘ \xo 15:‏12 \xt لَاوِي 19‏:‏18؛ مت. 22‏:‏39؛ يُوح. 13‏:‏34؛ أَفا. 5‏:‏2؛ 1 تس. 4‏:‏9؛ 1 بُط. 4‏:‏8؛ 1 يُوح. 3‏:‏23؛ 4‏:‏21. \x*  
\v 13 ؤُڒَا ذ إِجّْ وَارْ غَارسْ بُو ثَايْرِي ثَامقّْرَانْثْ خْ ثَانِيثَا: بلِّي شَا ن يِيجّنْ أَذْ إِوْشْ ثُوذَارْثْ نّسْ إِ إِمدُّوكَّاڒْ نّسْ. \x ◘ \xo 15:‏13 \xt رُوم. 5‏:‏7؛ أَفا. 5‏:‏2؛ 1 يُوح. 3‏:‏16. \x*  
\v 14 كنِّيوْ ذ إِمدُّوكَّاڒْ إِنُو، مَاڒَا ثڭِّيمْ مَارَّا مِينْ كنِّيوْ وصِّيغْ. \x ◘ \xo 15:‏14 \xt مت. 12‏:‏50؛ 2 كُور. 5‏:‏16؛ ڭال. 5‏:‏6؛ 6‏:‏15؛ كُول. 3‏:‏11. \x*  
\v 15 وَارْ تّْعِيوِيذغْ أَذْ أَومْ سمِّيغْ ’إِمْسخَّارنْ‘، مِينْزِي أَمْسخَّارْ وَارْ إِسِّينْ مِينْ إِتّڭّْ سِيذِيسْ. مَاشَا نشّْ ثُوغَا تّْڒَاغِيغْ أَومْ ذ ’إِمدُّوكَّاڒْ إِنُو!‘، مِينْزِي نشّْ سّشْنغْ كنِّيوْ مَارَّا مِينْ سْڒِيغْ زِي بَابَا. \x ◘ \xo 15:‏15 \xt يُوح. 8‏:‏26. \x*  
\v 16 وَارْ إِدْجِي ذ كنِّيوْ إِ ذ أَيِي إِخْضَارنْ، مَاشَا ذ نشّْ إِ كنِّيوْ إِخْضَارنْ ؤُشَا نشّْ ڭِّيغْ كنِّيوْ حِيمَا أَذْ ثْرَاحمْ، أَذْ د-ثَاوْيمْ ڒْغِيدْجثْ ؤُ حِيمَا أَذْ ثقِّيمْ ڒْغِيدْجثْ نْومْ، حِيمَا مَارَّا مِينْ غَا ثتَّارمْ زِي بَابَا س يِيسمْ إِنُو، أَذْ أَومْ \add ث\add* إِوْشْ نتَّا. \x ◘ \xo 15:‏16 \xt مت. 28‏:‏19؛ مك. 16‏:‏15؛ يُوح. 13‏:‏18؛ أَفا. 1‏:‏4؛ كُول. 1‏:‏6. \x*  
\v 17 ذ مَانْ أَيَا إِ زِي كنِّيوْ ؤُمُورغْ، حِيمَا أَذْ ثخْسمْ إِجّنْ ونّغْنِي.“   
\b  
\m  
\s1 دُّونشْثْ ثْشَارّهْ يَاسُوع  
\m
\v 18 ”مَاڒَا دُّونشْثْ أَذْ كنِّيوْ ثْشَارْهْ، سْنمْ أَقَا ثْشَارْهْ أَيِي قْبڒْ كنِّيوْ. \x ◘ \xo 15:‏18 \xt 1 يُوح. 3‏:‏13. \x*  
\v 19 مَاڒَا أَقَا كنِّيوْ زِي دُّونشْثْ، إِڒِي أَقَا دُّونشْثْ ثُوغَا ثتّخْسْ إِنِّي زَّايسْ. مَاشَا مِينْزِي كنِّيوْ وَارْ ثدْجِيمْ شَا زِي دُّونشْثْ، مَاشَا نشّْ إِخْضَارغْ كنِّيوْ زِي دُّونشْثْ، س ؤُينِّي ثْشَارّهْ دُّونشْثْ كنِّيوْ. \x ◘ \xo 15:‏19 \xt يُوح. 17‏:‏14؛ ڭال. 1‏:‏10. \x*  
\v 20 عقْڒمْ أَوَاڒْ إِ ذ أَومْ نِّيغْ: ’أَمْسخَّارْ وَارْ يُوعْڒِي خْ سِيذِيسْ!‘ مَاڒَا ذَارَّاشنْ أَيِي، أَذْ كنِّيوْ ذَارّْشنْ عَاوذْ. مَاڒَا طّْفنْ ذڭْ وَاوَاڒْ إِنُو، أَذْ طّْفنْ عَاوذْ ذڭْ وَاوَاڒْ نْومْ. \x ◘ \xo 15:‏20 \xt مت. 10‏:‏24؛ 24‏:‏9؛ لك. 6‏:‏40؛ يُوح. 13‏:‏16؛ 16‏:‏2. \x*  
\v 21 مَاشَا أَذْ زَّايْومْ ڭّنْ مَانْ أَيَا مَارَّا ذِي سِّيبّثْ ن يِيسمْ إِنُو، مِينْزِي نِيثْنِي وَارْ سِّيننْ شَا ونِّي ذ أَيِي د-إِسّكّنْ. \x ◘ \xo 15:‏21 \xt مت. 10‏:‏22؛ يُوح. 16‏:‏3. \x*  
\v 22 مَاڒَا وَارْ د-ؤُسِيغْ ؤُ وَارْ كِيسنْ سِّيوْڒغْ، أَذْ يِيڒِي وَارْ غَارْسنْ بُو دّْنُوبْ. مَاشَا ڒخُّو وَارْ غَارْسنْ بُو سْمَاحثْ خْ دّْنُوبْ نْسنْ. \x ◘ \xo 15:‏22 \xt رُوم. 4‏:‏15؛ 5‏:‏20. \x*  
\v 23 ونِّي ذ أَيِي إِشَارّْهنْ، أَذْ إِشَارْهْ ؤُڒَا ذ بَابَا.  
\v 24 مَاڒَا وَارْ ڭِّيغْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ ڒخْذَايمْ إِ وَارْ ثنْثْ يڭِّي ؤُڒَا ذ إِجّْ بْنَاذمْ نّغْنِي، أَذْ يِيڒِي وَارْ غَارْسنْ بُو دّْنُوبْ. مَاشَا ڒخُّو ژْرِينْ \add ثنْثْ\add*، شَارْهنْ أَيِي نشّْ ؤُڒَا ذ بَابَا. \x ◘ \xo 15:‏24 \xt يُوح. 10‏:‏37. \x*  
\v 25 س ؤُيَا أَذْ إِتّْوَاكمّڒْ وَاوَاڒْ إِ يُورَانْ ذِي شَّارِيعَا نْسنْ: ’شَارْهنْ أَيِي خْ وَالُو‘. \x ◘ \xo 15:‏25 \xt إِزهد. 35‏:‏19؛ 69‏:‏5. \x*   
\m
\v 26 خْمِي د غَا يَاسْ ؤُمْسصْڒَاحْ، ونِّي غَارْومْ د غَا سّكّغْ زِي بَابَا، أَرُّوحْ ن ثِيذتّْ إِ د-يُوسِينْ زِي غَارْ بَابَا، خنِّي وَانِيثَا أَذْ أَيِي إِشْهذْ. \x ◘ \xo 15:‏26 \xt لك. 24‏:‏49؛ يُوح. 14‏:‏26؛ 16‏:‏7؛ ڒخ. 5‏:‏32. \x*  
\v 27 ؤُشَا أَذْ ثْشهْذمْ ؤُڒَا ذ كنِّيوْ، مِينْزِي ثُوغَا كنِّيوْ أَكِيذِي زڭْ ؤُمزْوَارُو.“ \x ◘ \xo 15:‏27 \xt ڒخ. 1‏:‏8، 21؛ 5‏:‏32. \x*   
\b  
\b  
\m  
\c 16
\s1 أَرُّوحْ إِقدّْسنْ ذ أَمفْذِي نّغْنِي  
\m
\v 1 ”أَقَا سِّيوْڒغْ أَكِيذْومْ أَيَا، حِيمَا وَارْ تّنْقَارْضمْ.  
\v 2 أَذْ كنِّيوْ سُّوفّْغنْ زِي ثمْزِيذَاوِينْ نْسنْ. إِوَا، ثَاسَاعّثْ أَذْ د-ثَاسْ ؤُمِي كُوڒْ إِجّنْ ونِّي كنِّيوْ إِ غَا إِنْغنْ، أَذْ أَسْ إِتّْغِيڒْ أَقَا إِوْشَا إِشْثْ ن ثوْهِيبْثْ إِ أَربِّي. \x ◘ \xo 16:‏2 \xt يُوح. 9‏:‏22، 34؛ 12‏:‏42. \x*  
\v 3 أَذْ زَّايْومْ ڭّنْ مَانْ أَيَا، مِينْزِي نِيثْنِي وَارْ سِّيننْ بَابَا ؤُڒَا ذ نشّْ. \x ◘ \xo 16:‏3 \xt يُوح. 15‏:‏21؛ 1 كُور. 2‏:‏8. \x*  
\v 4 مَاشَا أَقَا نِّيغْ أَومْ مَانْ أَيَا، حِيمَا، خْمِي إِ د غَا ثَاسْ ثْسَاعّثْ، خنِّي أَذْ ثْعقْڒمْ خْ مَانْ أَيَا. نشّْ وَارْ ذَايْومْ نِّيغْ شَا مَانْ أَيَا قْبڒْ، مِينْزِي نشّْ ثُوغَا أَيِي \add عَاذْ\add* أَكِيذْومْ. \x ◘ \xo 16:‏4 \xt يُوح. 13‏:‏19؛ 14‏:‏29. \x*  
\v 5 مَاشَا ڒخُّو أَذْ رَاحغْ غَارْ ونِّي ذ أَيِي د-إِسّكّنْ، \add مَاشَا\add* ؤُڒَا ذ إِجّْ زَّايْومْ وَارْ ذ أَيِي إِسّقْسِي: ’مَانِي غَا ثْرَاحذْ؟‘  
\v 6 مَاغَارْ مِينْزِي نِّيغْ أَومْ مَانْ أَيَا، أَقَا أَشْضَانْ إِشُّورْ ؤُڒَاونْ نْومْ.  
\v 7 مَاشَا نشّْ أَذْ أَومْ إِنِيغْ ثِيذتّْ: حْسنْ أَومْ أَذْ رَاحغْ، مَاغَارْ مَاڒَا وَارْ رُوحغْ شَا، وَارْ غَارْومْ د-إِتِّيسْ ؤُمْسصْڒَاحْ. مَاڒَا رُوحغْ، أَذْ أَومْ ث-إِ-د-سّكّغْ. \x ◘ \xo 16:‏7 \xt لك. 24‏:‏49؛ يُوح. 14‏:‏26؛ 15‏:‏26. \x*  
\v 8 ڒَامِي د-يُوسَا وَانِيثَا، أَذْ إِسّقْنعْ دُّونشْثْ خْ دّْنُوبْ، خْ ثْسڭْذَا ؤُ خْ ڒْحُوكْمْ.  
\v 9 خْ دّْنُوبْ مِينْزِي نِيثْنِي وَارْ زَّايِي ؤُمِيننْ،  
\v 10 خْ ثْسڭْذَا، مِينْزِي نشّْ أَذْ رَاحغْ غَارْ بَابَا ؤُشَا وَارْ ذ أَيِي ثْژَارّمْ عَاذْ،  
\v 11 ؤُشَا خْ ڒْحُوكْمْ، مِينْزِي أَمقّْرَانْ ن دُّونشْثْ-أَ أَقَا إِتّْوَاحَاسبْ. \x ◘ \xo 16:‏11 \xt يُوح. 12‏:‏31؛ 14‏:‏30؛ أَفا. 2‏:‏2؛ كُول. 2‏:‏15. \x*   
\m
\v 12 غَارِي أَطَّاسْ مِينْ ذَايْومْ إِ غَا إِنِيغْ، مَاشَا ڒخُّو وَارْ ثْزمَّارمْ أَذْ ث ثكْسِيمْ.  
\v 13 مَاشَا ڒَامِي د-يُوسَا أَرُّوحْ ن ثِيذتّْ، أَذْ كنِّيوْ إِنْذهْ ذِي مَارَّا ثِيذتّْ، مِينْزِي نتَّا وَارْ إِسِّيوِيڒْ شَا زڭْ إِخفْ نّسْ، مَاشَا مَارَّا مِينْ غَا إِسْڒَا، أَذْ زَّايسْ إِسِّيوڒْ، ؤُشَا أَذْ أَومْ إِسّْشنْ ثِيمسْڒَايِينْ إِ د غَا يَاسنْ. \x ◘ \xo 16:‏13 \xt يُوح. 12‏:‏49؛ 14‏:‏26\x*  
\v 14 نتَّا أَذْ أَيِي إِسّْعُودْجْ، مِينْزِي أَذْ إِكْسِي زِي مِينْ غَارِي ؤُشَا أَذْ كنِّيوْ إِسَّارْڭبْ زَّايسْ.  
\v 15 مَارَّا مِينْ إِدْجَانْ غَارْ بَابَا، أَقَا-ث إِنُو. س ؤُينِّي نِّيغْ، بلِّي نتَّا أَذْ إِكْسِي زِي مِينْ غَارِي ؤُشَا أَذْ كنِّيوْ ت إِسَّارْڭبْ.“ \x ◘ \xo 16:‏15 \xt يُوح. 17‏:‏10. \x*   
\b  
\m  
\s1 ڒْوقْثْ ن وشْضَانْ أَذْ ثذْوڒْ ذ ڒفْرَاحثْ  
\m
\v 16 ”وَارْ إِتّْغِيمِي شَا ؤُشَا وَارْ ذ أَيِي ثْژَارّمْ \add عَاذْ\add*، ؤُ خنِّي \add عَاوذْ\add* وَارْ إِتّْغِيمِي شَا ؤُشَا أَذْ أَيِي ثْژَارمْ، مِينْزِي نشّْ أَذْ رَاحغْ غَارْ بَابَا.“ \x ◘ \xo 16:‏16 \xt يُوح. 7‏:‏33. \x*   
\m
\v 17 إِمحْضَارنْ نّسْ نَّانْ جَارْ أَسنْ: ”مَانَاوْيَا مِينْ ذ أَنغْ إِنَّا: ’وَارْ إِتّْغِيمِي شَا ؤُشَا وَارْ ذ أَيِي ثْژَارّمْ \add عَاذْ\add* ؤُ خنِّي عَاوذْ وَارْ إِتّْغِيمِي شَا ؤُشَا أَذْ أَيِي ثْژَارمْ!‘ ؤُ: ’نشّْ أَذْ رَاحغْ غَارْ بَابَا‘؟“  
\v 18 ؤُشَا نِيثْنِي نَّانْ: ”مَانَاوْيَا مِينْ إِقَّارْ: ’وَارْ إِتّْغِيمِي شَا‘؟ وَارْ نسِّينْ شَا مِينْ خفْ إِسَّاوَاڒْ.“  
\v 19 إِسّنْ يَاسُوع مِينْ خْسنْ أَذْ ث سّقْسَانْ، إِنَّا أَسنْ: ”مَا ثمّْسقْسَامْ مِينْزِي نِّيغْ: ’وَارْ إِتّْغِيمِي شَا ؤُشَا وَارْ ذ أَيِي ثْژَارّمْ \add عَاذْ\add* ؤُ خنِّي عَاوذْ وَارْ إِتّْغِيمِي شَا ؤُشَا أَذْ أَيِي ثْژَارمْ‘؟“   
\m
\v 20 ”س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: كنِّيوْ أَذْ ثْرُومْ، أَذْ ثْعبّْسمْ، مَاشَا دُّونشْثْ أَذْ ثْفَارْحْ. كنِّيوْ أَذْ ثْشضْنمْ، مَاشَا أَشْضَانْ نْومْ أَذْ إِذْوڒْ ذ ڒفْرَاحثْ.  
\v 21 ثَامْغَارْثْ، خْمِي غَا ثَارُووْ، أَذْ ذَايسْ يِيڒِي ڒحْرِيقْ، مِينْزِي ثَاسَاعّثْ نّسْ أَقَا ثِيوضْ-د. مَاشَا خْمِي د غَا ثَارُووْ مِّيسْ، وَارْ ثْفكَّارْ شَا عَاذْ ذِي ڒْمحْنثْ نّسْ س ڒفْرَاحثْ، مِينْزِي ثَارْنِي-د إِجّْ ن بْنَاذمْ غَارْ دُّونشْثْ. \x ◘ \xo 16:‏21 \xt إِشا. 26‏:‏17. \x*  
\v 22 ؤُڒَا ذ كنِّيوْ أَقَا ذَايْومْ أَشْضَانْ ڒخُّو، مَاشَا أَذْ كنِّيوْ ژَترغْ عَاوذْ، ؤُشَا أَذْ فَارْحنْ وُوڒَاونْ نْومْ ؤُشَا ؤُڒَا ذ إِجّْ وَارْ زَّايْومْ إِتّكّسْ ڒفْرَاحثْ نْومْ.   
\m
\v 23 ذڭْ وَاسّْ نِّي وَارْ ذ أَيِي ثتَّارمْ شَا. س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: مَارَّا مِينْ غَا ثتَّارمْ زِي بَابَا س يِيسمْ إِنُو، أَذْ أَومْ ث إِوْشْ. \x ◘ \xo 16:‏23 \xt إِرْم. 29‏:‏12؛ مت. 7‏:‏7؛ 21‏:‏22؛ مك. 11‏:‏24؛ لك. 11‏:‏9؛ يُوح. 14‏:‏13؛ 15‏:‏7؛ يَاع. 1‏:‏5؛ 1 يُوح. 3‏:‏22؛ 5‏:‏14. \x*  
\v 24 أَڒْ إِ ڒخُّو وَارْ ثتَّارمْ شَا س يِيسمْ إِنُو. تَّارمْ، أَذْ ثكْسِيمْ، حِيمَا أَذْ ثِيڒِي ڒفْرَاحثْ نْومْ ثكْمڒْ.   
\m
\v 25 سِّيوْڒغْ أَومْ خْ مَانْ أَيَا س إِمذْيَا، مَاشَا أَذْ د-ثَاوضْ ثْسَاعّثْ إِ ذِي وَارْ غَارْومْ إِ غَا سِّيوِيڒغْ عَاذْ س إِمتِّيڒنْ، مَاشَا أَذْ أَومْ بَارّْحغْ خْ بَابَا س بْطَايْطَايْ.  
\v 26 ذڭْ وَاسّْ نِّي أَذْ ثتَّارمْ س يِيسمْ إِنُو. نشّْ وَارْ ذ أَومْ قَّارغْ شَا بلِّي أَذْ تَّارغْ \add شَا\add* زِي بَابَا ذِي طّْوعْ نْومْ،  
\v 27 مِينْزِي بَابَا سِيمَانْثْ نّسْ إِتّخْسْ كنِّيوْ، مِينْزِي كنِّيوْ ثُوغَا ثتّخْسمْ أَيِي ؤُشَا أَقَا ثُومْنمْ أَقَا نشّْ زِي غَارْ أَربِّي إِ د-فّْغغْ. \x ◘ \xo 16:‏27 \xt يُوح. 17‏:‏8. \x*  
\v 28 فّْغغْ-د زِي بَابَا، ؤُسِيغْ-د غَارْ دُّونشْثْ. أَذْ جّغْ عَاوذْ دُّونشْثْ ؤُشَا أَذْ رَاحغْ غَارْ بَابَا.“ \x ◘ \xo 16:‏28 \xt يُوح. 13‏:‏3. \x*   
\m
\v 29 نَّانْ أَسْ إِمحْضَارنْ نّسْ: ”أَقَا ڒخُّو ثسَّاوَاڒذْ س بْطَايْطَايْ، وَارْ ثسِّيوِيڒذْ شَا س ؤُڒَا ذ إِجّْ ن ؤُمذْيَا.  
\v 30 ڒخُّو نسّنْ أَقَا ثسّْنذْ كُوڒْشِي، وَارْ ثحْذِيجذْ أَذْ شكْ إِسّقْسَا حذْ. زِي مَانَاونِّي نُومنْ أَقَا شكْ ثفّْغذْ-د زِي أَربِّي.“ \x ◘ \xo 16:‏30 \xt يُوح. 21‏:‏17. \x*  
\v 31 يَاسُوع يَارَّا-د خَاسنْ: ”مَا ڒخُّو ثُومْنمْ؟  
\v 32 أَذْ د-ثَاوضْ ثْسَاعّثْ، أَقَا ثِيوضْ-د، إِ ذِي إِ غَا ثتّْوَازُوزَّارمْ، كُوڒْ إِجّْ أَذْ إِطّفْ غَارْ ومْشَانْ نّسْ، أَذْ أَيِي ثجّمْ وحّْذِي، \add مَاشَا\add* نشّْ وَارْ دْجِيغْ بُو وحّْذِي، مِينْزِي بَابَا أَقَا-ث أَكِيذِي. \x ◘ \xo 16:‏32 \xt زَاك. 13‏:‏7؛ مت. 26‏:‏31؛ مك. 14‏:‏27؛ يُوح. 8‏:‏29؛ 14‏:‏10. \x*  
\v 33 أَقَا سِّيوْڒغْ أَكِيذْومْ س مَانْ أَيَا، حِيمَا أَذْ غَارْومْ يِيڒِي ڒهْنَا ذَايِي. ذِي دُّونشْثْ أَذْ غَارْومْ ثِيڒِي ڒْمحْنثْ، مَاشَا ڭّمْ ؤُڒْ، نشّْ أَقَاغلّْبغْ خْ دُّونشْثْ.“ \x ◘ \xo 16:‏33 \xt 2 إِج. 6‏:‏16؛ 2 إِم. 32‏:‏7؛ إِشا. 9‏:‏5؛ يُوح. 14‏:‏27؛ 16‏:‏33؛ رُوم. 5‏:‏1؛ أَفا. 2‏:‏13؛ كُول. 1‏:‏20؛ 1 يُوح. 4‏:‏4 \x*   
\b  
\b  
\m  
\c 17
\s1 ثَاژَادْجِيثْ ن يَاسُوع أَمْ ؤُكهَّانْ أَمقّْرَانْ  
\m
\v 1 ثُوغَا يَاسُوع إِسَّاوَاڒْ س مَانْ أَيَا ؤُشَا إِسّْڭعّذْ ثِيطَّاوِينْ نّسْ غَارْ ؤُجنَّا، إِنَّا: ”\add أَ\add* بَابَا، أَقَا ثَاسَاعّثْ ثِيوضْ-د. سُوعْڒَا مِّيشْ، حِيمَا ؤُڒَا ذ مِّيشْ أَذْ شكْ إِسُّوعْڒَا، \x ◘ \xo 17:‏1 \xt يُوح. 12‏:‏23؛ 13‏:‏32. \x*  
\v 2 أَڒَامِي ذ أَسْ ثوْشِيذْ صُّولْطَا خْ مَارَّا دَّاثْ، حِيمَا خنِّي نتَّا أَذْ إِوْشْ ثُوذَارْثْ إِتّْذُومَانْ إِ كُوڒْ إِجّنْ إِ ذ أَسْ ثوْشِيذْ. \x ◘ \xo 17:‏2 \xt إِزهد. 8‏:‏7؛ مت. 11‏:‏27؛ 28‏:‏18؛ لك. 10‏:‏22؛ يُوح. 3‏:‏35؛ 5‏:‏27؛ 1 كُور. 15‏:‏25؛ فِيل. 2‏:‏10؛ عبر. 2‏:‏8. \x*  
\v 3 ذ ثَانِيثَا ذ ثُوذَارْثْ إِتّْذُومَانْ، أَقَا نِيثْنِي أَذْ شكْ سّْننْ، مَاغَارْ شكْ وحّْذكْ ذ أَربِّي ذ ثِيذتّْ، ذ يَاسُوع لْمَاسِيحْ ونِّي د-ثسّكّذْ. \x ◘ \xo 17:‏3 \xt إِشا. 53‏:‏11؛ إِرْم. 9‏:‏22\x*  
\v 4 نشّْ سُّوعْڒِيغْ شكْ خْ ثمُّورْثْ. نشّْ كمّْڒغْ ڒْخذْمثْ إِ ذ أَيِي ثوْشِيذْ حِيمَا أَذْ ت ڭّغْ. \x ◘ \xo 17:‏4 \xt يُوح. 4‏:‏34؛ 13‏:‏32؛ 14‏:‏13؛ 19‏:‏30. \x*  
\v 5 ڒخُّو، سْعُودْجِي أَيِي، \add أَ\add* بَابَا، غَارْ إِخفْ نّشْ س ؤُعُودْجِي إِ ثُوغَا غَارِي قْبڒْ مَا أَذْ ثِيڒِي دُّونشْثْ. \x ◘ \xo 17:‏5 \xt يُوح. 1‏:‏1، 2؛ 10‏:‏30؛ 14‏:‏9. \x*   
\m
\v 6 سشْنغْ إِسمْ نّشْ إِ إِوْذَانْ إِنِّي ذ أَيِي ثوْشِيذْ زِي دُّونشْثْ. نِيثْنِي ثُوغَا أَثنْ نّشْ، ثوْشِيذْ ثنْ إِ نشّْ، أَقَا طّْفنْ ذڭْ وَاوَاڒْ نّشْ.  
\v 7 ڒخُّو سّْنغْ بلِّي مَارَّا مِينْ ذ أَيِي ثوْشِيذْ، أَقَا-ث زَّايكْ د-يُوسَا.  
\v 8 مِينْزِي نشّْ وْشِيغْ أَسنْ أَوَاڒنْ إِ ذ أَيِي ثوْشِيذْ ؤُشَا نِيثْنِي قبْڒنْ زَّايْسنْ، سّْننْ س ثِيذتّْ بلِّي نشّْ فّْغغْ-د زَّايكْ، ؤُمْننْ أَقَا شكْ ثسّكّذْ أَيِي-د. \x ◘ \xo 17:‏8 \xt يُوح. 16‏:‏27. \x*  
\v 9 نشّْ تَّارغْ ذِي طّْوعْ نْسنْ، وَارْ تّتَّارغْ ذِي طّْوعْ ن دُّونشْثْ، مَاشَا ذِي طّْوعْ ن يِينِّي ذ أَيِي ثوْشِيذْ، مِينْزِي أَقَا أَثنْ نّشْ.  
\v 10 مَارَّا مِينْ إِدْجَانْ إِنُو أَقَا-ث نّشْ ؤُ مِينْ إِدْجَانْ نّشْ أَقَا-ث إِنُو، ؤُ نشّْ تّْوَاسّْعُودْجغْ ذَايْسنْ. \x ◘ \xo 17:‏10 \xt يُوح. 16‏:‏15. \x*   
\m
\v 11 زِي ڒخُّو نشّْ وَارْ دْجِيغْ عَاذْ ذِي دُّونشْثْ، مَاشَا نِيثْنِي أَقَا أَثنْ ذِي دُّونشْثْ، ؤُشَا نشّْ أَذْ غَاركْ د-أَسغْ. \add أَ\add* بَابَا إِقدّْسنْ، حْضَا ثنْ ذڭْ يِيسمْ نّشْ، \add إِسمْ\add* نِّي ذ أَيِي ثوْشِيذْ، حِيمَا نِيثْنِي أَذْ إِڒِينْ ذ إِجّنْ أَمْ نشِّينْ.  
\v 12 ڒَامِي ذ أَيِي ثُوغَا أَكِيذْسنْ، حْضِيغْ ثنْ ذڭْ يِيسمْ نّشْ. نشّْعسّغْ خْ يِينِّي ذ أَيِي ثوْشِيذْ. ؤُڒَا ذ إِجّْ زَّايْسنْ وَارْ إِتّْوَاهلّكْ، مْغِيرْ مِّيسْ ن ثهْلِيكثْ، حِيمَا أَذْ إِتّْوَاكمّڒْ \add مِينْ يُورَانْ\add* ذِي ثِيرَا \add إِقدّْسنْ\add*. \x ◘ \xo 17:‏12 \xt إِشا. 8‏:‏18؛ يُوح. 6‏:‏39؛ 10‏:‏28؛ 18‏:‏9؛ عبر. 2‏:‏13. \x*   
\m
\v 13 مَاشَا ڒخُّو أَذْ غَاركْ د-أَسغْ ؤُ سَّاوَاڒغْ خْ مَانْ أَيَا ذِي دُّونشْثْ، حِيمَا أَذْ ثِيڒِي ڒفْرَاحثْ إِنُو ثكْمڒْ ذَايْسنْ.  
\v 14 وْشِيغْ أَسنْ أَوَاڒْ نّشْ ؤُشَا دُّونشْثْ ثُوغَا ثْشَارّهْ إِ-ثنْ، مِينْزِي وَارْ دْجِينْ شَا زِي دُّونشْثْ، أَمْ نشّْ وَارْ دْجِيغْ شَا زِي دُّونشْثْ. \x ◘ \xo 17:‏14 \xt يُوح. 15‏:‏19. \x*  
\v 15 نشّْ وَارْ تَّارغْ حِيمَا أَذْ ثنْ ثكْسِيذْ زِي دُّونشْثْ، مَاشَا حِيمَا أَذْ ثنْ ثحْضِيذْ زڭْ ؤُمْعفَّانْ.  
\v 16 نِيثْنِي وَارْ دْجِينْ شَا زِي دُّونشْثْ أَمْ نشّْ وَارْ دْجِيغْ شَا زِي دُّونشْثْ.  
\v 17 \add أَ\add* بَابَا، سْقدّسْ إِ-ثنْ ذِي ثِيذتّْ، أَوَاڒْ نّشْ ذ ثِيذتّْ. \x ◘ \xo 17:‏17 \xt إِزهد. 119‏:‏142؛ يُوح. 8‏:‏4. \x*  
\v 18 أَمْ مَامّشْ إِ ذ أَيِي د-ثسّكّذْ غَارْ دُّونشْثْ، \add أَمُّو إِ\add* ثنْ سّكّغْ عَاوذْ غَارْ دُّونشْثْ. \x ◘ \xo 17:‏18 \xt يُوح. 20‏:‏21. \x*  
\v 19 سّْقدَّاسغْ إِخفْ إِنُو ذِي طّْوعْ نْسنْ، حِيمَا أَذْ تّْوَاقدّْسنْ ؤُڒَا ذ نِيثْنِي ذِي ثِيذتّْ. \x ◘ \xo 17:‏19 \xt 1 كُور. 1‏:‏2، 30؛ 1 تس. 4‏:‏7. \x*   
\m
\v 20 وَارْ تَّارغْ ذِي طّْوعْ ن يِينَا وَاهَا، مَاشَا عَاوذْ ذِي طّْوعْ ن يِينِّي ذَايِي يُومْننْ س وَاوَاڒْ نْسنْ.  
\v 21 حِيمَا أَذْ إِڒِينْ مَارَّا ذ إِجّنْ، \add أَ\add* بَابَا، أَمْ شكْ ذَايِي ؤُ نشّْ ذَايكْ، حِيمَا ؤُڒَا ذ نِيثْنِي أَذْ إِڒِينْ ذ إِجّنْ ذَايْنغْ، حِيمَا أَذْ ثَامنْ دُّونشْثْ بلِّي أَقَا ذ شكْ إِ ذ أَيِي د-إِسّكّنْ. \x ◘ \xo 17:‏21 \xt يُوح. 10‏:‏38؛ 14‏:‏11؛ ڭال. 3‏:‏28. \x*  
\v 22 نشّْ وْشِيغْ أَسنْ أَعُودْجِي إِ ذ أَيِي ثوْشِيذْ، حِيمَا أَذْ إِڒِينْ ذ إِجّنْ أَمْ مَامّشْ نشِّينْ ندْجْ ذ إِجّنْ.  
\v 23 نشّْ ذَايْسنْ، شكْ ذَايِي، حِيمَا أَذْ إِڒِينْ تّْوَاكمّْڒنْ غَارْ إِجّنْ، حِيمَا أَذْ ثسّنْ دُّونشْثْ أَقَا شكْ ثسّكّذْ أَيِي-د ؤُ ثخْسذْ ثنْ أَمْ مَامّشْ إِ ذ أَيِي ثخْسذْ.   
\m
\v 24 \add أَ\add* بَابَا، خْسغْ إِ يِينِّي ذ أَيِي ثوْشِيذْ أَذْ إِڒِينْ أَكِيذِي مَانِي مَا دْجِيغْ نشّْ، ؤُشَا أَذْ ژَترنْ أَعُودْجِي إِنُو إِ ذ أَيِي ثوْشِيذْ، مِينْزِي شكْ ثخْسذْ أَيِي قْبڒْ مَا أَذْ ثتّْوَاڭّْ دُّونشْثْ. \x ◘ \xo 17:‏24 \xt يُوح. 12‏:‏26؛ 14‏:‏3. \x*  
\v 25 \add أَ\add* بَابَا إِنُو إِسڭّْذنْ، أَقَا دُّونشْثْ وَارْ شكْ ثسِّينْ، مَاشَا نشّْ أَقَا سّْنغْ شكْ ؤُ إِنَا سّْننْ أَقَا شكْ ثسّكّذْ أَيِي-د. \x ◘ \xo 17:‏25 \xt يُوح. 15‏:‏21؛ 16‏:‏3، 27؛ 17‏:‏8. \x*  
\v 26 نشّْ سّشْنغْ أَسنْ إِسمْ نّشْ ؤُ أَذْ ث سّشْنغْ، حِيمَا ثَايْرِي إِ زِي ثُوغَا ذ أَيِي ثتّخْسذْ أَذْ ثِيڒِي ذَايْسنْ ؤُ نشّْ ذَايْسنْ.“   
\b  
\b  
\m  
\c 18
\s1 ؤُضُوفْ ن يَاسُوع  
\m
\v 1 أَوَارْنِي ڒَامِي إِنَّا يَاسُوع أَيَا، إِفّغْ أَكْ-ذ إِمحْضَارنْ نّسْ، ژْوَانْ خْ يغْزَارْ ن قِيذْرُونْ. ثُوغَا ذِينْ إِجّْ ن وحْوِيشْ، يُوذفْ غَارسْ أَكْ-ذ إِمحْضَارنْ نّسْ. \x ◘ \xo 18:‏1 \xt [مت. 26‏:‏47‏-‏56؛ مك. 14‏:‏43‏-‏50؛ لك. 22‏:‏47‏-‏53] — 2 صم. 15‏:‏23؛ مت. 26‏:‏36؛ مك. 14‏:‏32؛ لك. 22‏:‏39. \x*  
\v 2 مَاشَا ؤُڒَا ذ يَاهُوذَا، أَغدَّارْ، إِسّنْ أَمْشَانْ نِّي عَاوذْ، مِينْزِي يَاسُوع ثُوغَا إِسّْمُونَا ذَايسْ أَطَّاسْ أَكْ-ذ إِمحْضَارنْ نّسْ.  
\v 3 يِيوِي-د يَاهُوذَا أَكِيذسْ إِشْثْ ن ثرْبِيعْثْ ن ڒْعسْكَارْ ؤُڒَا ذ إِعسَّاسنْ زڭْ وُوذمْ ن إِمقّْرَاننْ ن إِكهَّاننْ ذ إِفَارِيسِييّنْ، ؤُشَا يُوسَا-د ذِيهَا س إِصفْضَاونْ ذ ڒقْنَاذڒْ ذ ڒسْنَاحْ. \x ◘ \xo 18:‏3 \xt مت. 26‏:‏47؛ مك. 14‏:‏43؛ لك. 22‏:‏47. \x*   
\m
\v 4 يَاسُوع، ونِّي إِسّنْ مَارَّا مِينْ ذ أَسْ غَا إِمْسَارنْ، إِفّغْ-د \add غَارْسنْ\add*، إِنَّا أَسنْ: ”مِينْ خفْ ثَارزُّومْ؟“  
\v 5 أَرِّينْ-د خَاسْ: ”يَاسُوع نَّاصِيرِي!“ يَاسُوع إِنَّا أَسنْ: ”ذ نشّْ!“ ثُوغَا يَاهُوذَا، أَغدَّارْ، إِبدّْ عَاوذْ أَكِيذْسنْ.  
\v 6 ڒَامِي ذ أَسنْ إِنَّا يَاسُوع: ”ذ نشّْ!“، ذوْڒنْ نِيثْنِي غَارْ ضفَّارْ ؤُشَا وْضَانْ غَارْ ثمُّورْثْ.   
\m
\v 7 إِسّقْسَا ثنْ يَاسُوع عَاوذْ: ”مِينْ خفْ ثَارزُّومْ؟“ نَّانْ: ”يَاسُوع نَّاصِيرِي!“  
\v 8 يَاسُوع يَارَّا-د: ”أَقَا نِّيغْ أَومْ، أَقَا ذ نشّْ. مَاڒَا ثَارزُّومْ خَافِي، جّمْ إِنَا أَذْ رَاحنْ!“،  
\v 9 حِيمَا أَذْ إِتّْوَاكمّڒْ وَاوَاڒْ إِ ثُوغَا إِنَّا: ”إِنِّي ذ أَيِي ثوْشِيذْ، وَارْ زَّايْسنْ ودَّارغْ ؤُڒَا ذ إِجّْ.“ \x ◘ \xo 18:‏9 \xt يُوح. 6‏:‏39؛ 10‏:‏28؛ 17‏:‏12. \x*   
\m
\v 10 شِيمْعُونْ بُوطْرُوسْ ونِّي ثُوغَا غَارسْ سِّيفْ، إِجْبذْ إِ-ث-إِ-د، إِوْثَا زَّايسْ أَمْسخَّارْ ن أَرَّايْسْ ن إِكهَّاننْ، إِقسّْ أَسْ أَمزُّوغْ نّسْ أَفُوسِي. ثُوغَا أَمْسخَّارْ \add نِّي\add* قَّارنْ أَسْ مَالْخِيسْ. \x ◘ \xo 18:‏10 \xt مت. 26‏:‏51؛ مك. 14‏:‏47؛ لك. 22‏:‏50. \x*  
\v 11 \add خَاسْ ؤُشَا\add* إِنَّا يَاسُوع إِ بُوطْرُوسْ: ”أَرّْ سِّيفْ غَارْ وغْڒَافْ نّسْ، ڒْكَاسْ نِّي ذ أَيِي إِوْشَا بَابَا، مَا وَارْ ث سسّغْ؟“ \x ◘ \xo 18:‏11 \xt مت. 20‏:‏22؛ 26‏:‏39. \x*   
\b  
\m  
\s1 يَاسُوع زَّاثْ إِ حَانَّانْ، أَزدْجِيفْ ن إِكهَّاننْ  
\m
\v 12 ثَارْبِيعْثْ ن ڒْعسْكَارْ ذ إِمقّْرَاننْ خْ وَاڒفْ \add ن إِعسْكَارِييّنْ\add* ؤُڒَا ذ إِعسَّاسنْ ن وُوذَاينْ طّْفنْ يَاسُوع، شَارْفنْ ث. \x ◘ \xo 18:‏12 \xt [مت. 26‏:‏57، 58؛ مك. 14‏:‏53، 54؛ لك. 22‏:‏54]\x*  
\v 13 نذْهنْ ث أَمزْوَارُو غَارْ حَانَّانْ، مِينْزِي نتَّا ذ أَضڭّْوَاڒْ ن قَايَافَا، ونِّي ثُوغَا ذ أَرَّايْسْ ن إِكهَّاننْ ذڭْ ؤُسڭّْوَاسْ نِّي. \x ◘ \xo 18:‏13 \xt مت. 26‏:‏57؛ مك. 14‏:‏53؛ لك. 3‏:‏2؛ 22‏:‏54. \x*  
\v 14 قَايَافَا ذ نتَّا ثُوغَا إِوصَّا إِ وُوذَاينْ، أَقَا حْسنْ أَذْ إِمّثْ إِجّْ ن بْنَاذمْ ذِي طّْوعْ ن ڒْڭنْسْ. \x ◘ \xo 18:‏14 \xt يُوح. 11‏:‏50. \x*   
\b  
\m  
\s1 أَنْكَارْ ن بُوطْرُوسْ  
\m
\v 15 شِيمْعُونْ بُوطْرُوسْ إِضْفَارْ يَاسُوع أَكْ-ذ إِجّنْ زڭْ إِمحْضَارنْ إِنّغْنِي. أَمحْضَارْ نِّي ثُوغَا إِتّْوَاسّْننْ غَارْ أَرَّايْسْ ن إِكهَّاننْ ؤُشَا يُوذفْ أَكْ-ذ يَاسُوع غَارْ ڒمْرَاحْ ن ثَادَّارْثْ \add ن أَرَّايْسْ ن إِكهَّاننْ\add*. \x ◘ \xo 18:‏15 \xt [مت. 26‏:‏69‏-‏70؛ مك. 14‏:‏66‏-‏68؛ لك. 22‏:‏55‏-‏57] — مت. 26‏:‏58؛ مك. 14‏:‏54؛ لك. 22‏:‏54. \x*  
\v 16 شِيمْعُونْ إِبدّْ-د بَارَّا غَارْ ثوَّارْثْ. إِفّغْ-د ؤُمحْضَارْ إِ ثُوغَا إِتّْوَاسّْننْ غَارْ أَرَّايْسْ ن إِكهَّاننْ، إِسِّيوڒْ أَكْ-ذ ثْعسَّاسْثْ ثنِّي إِحطَّانْ ثَاوَّارْثْ ؤُشَا إِسِّيذفْ-د شِيمْعُونْ غَارْ ذَاخڒْ.  
\v 17 ثَابْڒِيغْثْ ثنِّي إِحطَّانْ ثَاوَّارْثْ، ثنَّا إِ شِيمْعُونْ: ”مَا وَارْ ثدْجِيذْ ؤُڒَا ذ شكْ زڭْ إِمحْضَارنْ ن بْنَاذمْ-أَ؟“ إِنَّا: ”لَّ!“  
\v 18 ثُوغَا إِمْسخَّارنْ ذ إِعسَّاسنْ بدّنْ \add ذِينْ\add*، سَّارْغنْ ثِيمسِّي س ڒفْحمْ، مِينْزِي ثُوغَا ثسْمضْ، ؤُشَا ثُوغَا تّْوقَّاحنْ. ؤُڒَا ذ شِيمْعُونْ إِبدّْ أَكِيذْسنْ، إِتّْوقَّاحْ. \x ◘ \xo 18:‏18 \xt مت. 26‏:‏69؛ مك. 14‏:‏67؛ لك. 22‏:‏55. \x*   
\b  
\m  
\s1 إِسقْسِيثنْ ن أَرَّايْسْ ن إِكهَّاننْ إِ يَاسُوع  
\m
\v 19 إِسّقْسَا أَرَّايْسْ ن إِكهَّاننْ يَاسُوع خْ إِمحْضَارنْ نّسْ ؤُ خْ ثْغُورِي نّسْ. \x ◘ \xo 18:‏19 \xt [مت. 26‏:‏59‏-‏66؛ مك. 14‏:‏55‏-‏64؛ لك. 22‏:‏66‏-‏71]\x*  
\v 20 يَارَّا-د خَاسْ يَاسُوع: ”نشّْ ثُوغَا سَّاوَاڒغْ إِ ڒْڭنْسْ س بْطَايْطَايْ، سّْغَارغْ ڒبْذَا ذِي ثمْزِيذَا ؤُ ذِي زَّاوشْثْ ثَامقّْرَانْثْ مَانِي تّْمُونَانْ وُوذَاينْ ڒبْذَا. ذِي ثْنُوفّْرَا وَارْ سِّيوْڒغْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ. \x ◘ \xo 18:‏20 \xt يُوح. 7‏:‏26. \x*  
\v 21 مَايمِّي ذ أَيِي ثسّقْسِيذْ؟ سقْسَا إِنِّي إِسْڒَانْ مِينْ ذ أَسنْ نِّيغْ. خْزَارْ، نِيثْنِي سّْننْ مِينْ نِّيغْ!“  
\v 22 ڒَامِي إِنَّا أَمُّو، خنِّي إِجّنْ زڭْ إِعسَّاسنْ إِ ثُوغَا ذِينْ إِبدّنْ، إِوْثَا يَاسُوع خْ ؤُمڭِّيزْ نّسْ، إِنَّا أَسْ: ”مَا أَمُّو إِ د غَا ثَارّذْ خْ أَرَّايْسْ ن إِكهَّاننْ؟“ \x ◘ \xo 18:‏22 \xt إِرْم. 20‏:‏2؛ ڒخ. 23‏:‏2. \x*  
\v 23 يَارَّا-د خَاسْ يَاسُوع، إِنَّا: ”مَاڒَا سِّيوْڒغْ مِينْ وَارْ إِحْڒِينْ، شْهذْ خْ مِينْ وَارْ إِحْڒِينْ، مَاشَا مَاڒَا سِّيوْڒغْ مْلِيحْ، مَايمِّي ذ أَيِي ثشَّاثذْ \add خنِّي\add*؟“  
\v 24 \add خَاسْ ؤُشَا\add* حَانَّانْ إِسّكّْ إِ-ث إِتّْوَاشَارْفْ غَارْ قَايَافَا، أَرَّايْسْ ن إِكهَّاننْ. \x ◘ \xo 18:‏24 \xt مت. 26‏:‏57؛ مك. 14‏:‏53؛ لك. 22‏:‏54. \x*   
\b  
\m  
\s1 شِيمْعُونْ بُوطْرُوسْ إِنْكَارْ عَاوذْ أَقَا نتَّا إِسّنْ يَاسُوع  
\m
\v 25 ثُوغَا شِيمْعُونْ بُوطْرُوسْ إِبدّْ ذِينِّي إِتّْوقَّاحْ. نَّانْ أَسْ: ”مَا وَارْ ثدْجِيذْ ؤُڒَا ذ شكْ زڭْ إِمحْضَارنْ نّسْ؟“ نتَّا إِنْكَارْ، إِنَّا: ”وَارْ دْجِيغْ شَا ذ نشّْ!“ \x ◘ \xo 18:‏25 \xt [مت. 26‏:‏71‏-‏75؛ مك. 14‏:‏69‏-‏72؛ لك. 22‏:‏58‏-‏62] — مت. 26‏:‏71؛ مك. 14‏:‏69؛ لك. 22‏:‏58. \x*  
\v 26 إِجّنْ زڭْ إِمْسخَّارنْ ن أَرَّايْسْ ن إِكهَّاننْ إِ ثُوغَا إِتّعْنَانْ إِ ونِّي ؤُمِي إِقسّْ شِيمْعُونْ أَمزُّوغْ، إِنَّا: ”مَا وَارْ شكْ ژْرِيغْ أَكِيذسْ ذڭْ وحْوِيشْ؟“  
\v 27 ڒخْذنِّي إِنْكَارْ شِيمْعُونْ عَاوذْ ؤُشَا ذغْيَا إِسّْقُوقعْ ؤُيَاژِيضْ. \x ◘ \xo 18:‏27 \xt يُوح. 13‏:‏38. \x*   
\b  
\m  
\s1 يَاسُوع زَّاثْ إِ بِيلَاطُوسْ  
\m
\v 28 خنِّي إِوْينْ-د يَاسُوع زِي قَايَافَا غَارْ ثَادَّارْثْ ن شّْرعْ، \add ؤُمِي قَّارنْ ’بْرِيثُورِييُومْ‘\add*. ثُوغَا ذ زِيشْ ذِي صّْبحْ. نِيثْنِي وَارْ ؤُذِيفنْ شَا غَارْ ثَادَّارْثْ ن شّْرعْ، حِيمَا وَارْ تّْوسِّيخنْ قْبڒْ مَا إِ غَا شّنْ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو. \x ◘ \xo 18:‏28 \xt [مت. 27‏:‏1‏-‏2، 11‏-‏31؛ مك. 15‏:‏1‏-‏20؛ لك. 23‏:‏1‏-‏25] — مت. 27‏:‏1؛ مك. 15‏:‏1؛ لك. 22‏:‏66؛ 23‏:‏1. \x*  
\v 29 \add س ؤُينِّي\add* إِفّغْ-د غَارْسنْ بِيلَاطُوسْ، إِنَّا أَسنْ: ”مَانْ أَشثْشِي إِ غَارْومْ خْ ورْيَازْ-أَ؟“  
\v 30 أَرِّينْ-د، نَّانْ أَسْ: ”مَاڒَا وَانِيثَا وَارْ ثُوغِي ذ مِّيسْ ن ڒْمُوعْصِييّثْ، أَذْ ثِيڒِي وَارْ ذ أَشْ ث-إِ-د-نتِّيوِي.“  
\v 31 إِنَّا أَسنْ بِيلَاطُوسْ: ”\add خنِّي\add* أَوْيمْ ث-إِ-د كنِّيوْ، ثْحكْممْ خَاسْ عْلَاحْسَابْ شَّارِيعَا نْومْ.“ خنِّي نَّانْ أَسْ وُوذَاينْ: ”وَارْ غَارْنغْ بُو تّسْرِيحْ مَاحنْذْ أَذْ ننغْ ؤُڒَا ذ إِجّْ!“،  
\v 32 حِيمَا أَذْ إِتّْوَاكمّڒْ وَاوَاڒْ ن يَاسُوع إِ ثُوغَا إِقَّارْ، أَمْ ثُوغَا إِسّْشَاننْ إِ مَانْ ڒْموْثْ إِ غَا إِمّثْ. \x ◘ \xo 18:‏32 \xt مت. 20‏:‏19؛ يُوح. 12‏:‏32. \x*   
\m
\v 33 خنِّي يُوذفْ-د بِيلَاطُوسْ عَاوذْ غَارْ ثَادَّارْثْ ن شّْرَاعْ، \add ؤُمِي قَّارنْ بْرِيثُورِييُومْ\add*، إِڒَاغَا-د خْ يَاسُوع، إِنَّا أَسْ: ”مَا شكْ ذ أَجدْجِيذْ ن وُوذَاينْ؟“ \x ◘ \xo 18:‏33 \xt مت. 27‏:‏11؛ مك. 15‏:‏2؛ لك. 23‏:‏3. \x*  
\v 34 يَارَّا-د خَاسْ يَاسُوع: ”مَا ثقَّارذْ أَيَا زِي غَاركْ نِيغْ ثُوغَا إِنّغْنِي قَّارنْ أَشْ ث خَافِي؟“  
\v 35 إِنَّا أَسْ بِيلَاطُوسْ: ”مَا نشّْ ذ ؤُذَايْ؟ أَقَا ڒْڭنْسْ نّشْ ذ إِمقّْرَاننْ ن إِكهَّاننْ إِوْينْ-د شكْ غَارِي. مِينْ ثُوغَا ثڭِّيذْ؟“  
\v 36 يَارَّا-د خَاسْ يَاسُوع: ”ثَاڭلْذِيثْ إِنُو وَارْ ثدْجِي شَا زِي دُّونشْثْ-أَ. مَاڒَا ثدْجَا ثْڭلْذِيثْ إِنُو زِي دُّونشْثْ-أَ، أَذْ يِيڒِي أَقَا إِمْسخَّارنْ إِنُو أَذْ مّنْغنْ، حِيمَا وَارْ تّْوَاسلَّامغْ إِ وُوذَاينْ، مَاشَا ڒخُّو ثَاڭلْذِيثْ إِنُو وَارْ ثدْجِي شَا سَّانِيثَا.“ \x ◘ \xo 18:‏36 \xt يُوح. 6‏:‏15؛ 1 تِيم. 6‏:‏13. \x*  
\v 37 إِنَّا أَسْ بِيلَاطُوسْ: ”خنِّي أَقَا شكْ ذ أَجدْجِيذْ نِيشَانْ!“ يَارَّا-د يَاسُوع: ”شكْ ثقَّارذْ، أَقَا نشّْ ذ أَجدْجِيذْ. إِ مَانْ أَيَا إِ د-خڒْقغْ ؤُ إِ ؤُيَا إِ د-ؤُسِيغْ غَارْ دُّونشْثْ، حِيمَا أَذْ شهْذغْ إِ ثِيذتّْ. مَارَّا ونِّي إِدْجَانْ زِي ثِيذتّْ، أَذْ إِسڒْ إِ ثْمِيجَّا إِنُو.“   
\m
\v 38 إِنَّا أَسْ بِيلَاطُوسْ: ”ؤُمِي قَّارنْ ذ ثِيذتّْ؟“ ڒَامِي إِنَّا أَمُّو، إِفّغْ-د عَاوذْ غَارْ وُوذَاينْ، إِنَّا أَسنْ: ”وَارْ ذَايسْ ؤُفِيغْ ؤُڒَا ذ إِجّْ ن ؤُخطُّو. \x ◘ \xo 18:‏38 \xt مت. 27‏:‏24؛ لك. 23‏:‏4. \x*  
\v 39 مَاشَا أَقَا ثنُّوممْ أَذْ أَومْ سَارّْحغْ إِجّْ ن بْنَاذمْ ذِي \add ڒْْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو. مَا ثخْسمْ خنِّي أَذْ أَومْ سَارّْحغْ بْنَاذمْ-أَ، أَجدْجِيذْ ن وُوذَاينْ؟“ \x ◘ \xo 18:‏39 \xt مت. 27‏:‏15؛ مك. 15‏:‏6؛ لك. 23‏:‏17. \x*  
\v 40 سْغُويّنْ عَاوذْ مَارَّا، نَّانْ: ”وَارْ إِدْجِي شَا وَانِيثَا، حَاشَا بَارْ-أَبَّاسْ!“ ثُوغَا بَارْ-أَبَّاسْ ذ أَقْطَاطْعِييْ. \x ◘ \xo 18:‏40 \xt مت. 27‏:‏16؛ مك. 15‏:‏7؛ لك. 23‏:‏19؛ ڒخ. 3‏:‏1. \x*   
\b  
\b  
\m  
\c 19
\s1 ڒْحُوكْمْ خْ يَاسُوع  
\m
\v 1 خنِّي \add إِجَّا\add* بِيلَاطُوسْ أَذْ هتّْكنْ يَاسُوع س ؤُركُّوضْ. \x ◘ \xo 19:‏1 \xt مت. 27‏:‏26؛ مك. 15‏:‏15. \x*  
\v 2 أَوَارْنِي ڒَامِي مُوذنْ إِعسْكَارِييّنْ إِجّْ ن تَّاجْ س إِسنَّاننْ، سَّارْسنْ أَسْ ت خْ ؤُزدْجِيفْ نّسْ ؤُشَا يَارْضنْ أَسْ إِجّْ ن ؤُسڒْهَامْ ذ أَرْجُووَانِي،  
\v 3 نَّانْ: ”سْڒَامْ خَاكْ، \add أَ\add* أَجدْجِيذْ ن وُوذَاينْ!“، ؤُشَا وْثِينْ ث خْ إِڭمِّيزنْ نّسْ.   
\m
\v 4 إِفّغْ-د عَاوذْ بِيلَاطُوسْ، إِنَّا أَسنْ: ”أَذْ أَومْ ث-إِ-د-سُّوفّْغغْ، حِيمَا أَذْ ثسّْنمْ بلِّي نشّْ وَارْ ذَايسْ ؤُفِيغْ سِّيبّثْ إِ ؤُشثْشِي، ؤُڒَا ذ إِشْثْ.“  
\v 5 \add خنِّي\add* إِفّغْ-د يَاسُوع س تَّاجْ ن إِسنَّاننْ ذ ؤُجدْجَابْ أَجُورْوَانِي. إِنَّا أَسنْ بِيلَاطُوسْ: ”خْزَارمْ، بْنَاذمْ!“   
\m
\v 6 ڒَامِي ث ژْرِينْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِعسَّاسنْ، سْغُوينْ، نَّانْ: ”صلّْبْ إِ-ث، صلّْبْ إِ-ث“ إِنَّا أَسنْ بِيلَاطُوسْ: ”أَوْيمْ ث-إِ-د كنِّيوْ، صلّْبمْ ث، مِينْزِي نشّْ وَارْ ذَايسْ ؤُفِيغْ ؤُڒَا ذ إِجّْ ن ڒْعِيبْ.“  
\v 7 أَرِّينْ-د خَاسْ وُوذَاينْ: ”غَارْنغْ شَّارِيعَا، ؤُ عْلَاحْسَابْ شَّارِيعَا نّغْ إِتّْخصَّا أَذْ إِمّثْ، مِينْزِي نتَّا إِتَّارَّا إِخفْ نّسْ ذ مِّيسْ ن أَربِّي.“ \x ◘ \xo 19:‏7 \xt لَاوِي 24‏:‏16؛ يُوح. 5‏:‏18؛ 10‏:‏3. \x*   
\m
\v 8 ڒَامِي إِسْڒَا بِيلَاطُوسْ أَوَاڒْ-أَ، يَارْنِي ذِي ثِيڭّْوُوذِي.  
\v 9 يُوذفْ عَاوذْ غَارْ ثَادَّارْثْ ن شّْرعْ، إِنَّا إِ يَاسُوع: ”مَانِيسْ شكْ؟“ مَاشَا يَاسُوع وَارْ خَاسْ د-يَارِّي شَا.  
\v 10 إِنَّا أَسْ بِيلَاطُوسْ: ”مَا وَارْ \add ثخْسذْ أَذْ\add* كِيذِي ثسِّيوِيڒذْ؟ مَا وَارْ ثسِّينذْ شَا أَقَا غَارِي صُّولْطَا حِيمَا أَذْ أَشْ سَّارّْحغْ ؤُ غَارِي صُّولْطَا حِيمَا أَذْ شكْ صلّْبغْ؟“  
\v 11 يَارَّا-د خَاسْ يَاسُوع: ”وَارْ غَاركْ ثتِّيڒِي بُو صُّولْطَا خَافِي، مَاڒَا وَارْ ذ أَشْ د-ثمّوْشْ زِي سنّجْ. س ؤُيَا، ونِّي ذ أَيِي إِسلّْمنْ إِ شكْ، أَقَا خَاسْ دّنْبْ إِمْغَارْ زڭْ ونِّي \add إِ إِدْجَانْ\add* خَاكْ.“  
\v 12 زِي ڒخْذنِّي ثُوغَا بِيلَاطُوسْ يَارزُّو أَذْ أَسْ إِسَارّحْ، مَاشَا ؤُذَاينْ سْغُوينْ، نَّانْ: ”مَاڒَا ثْسَارّْحذْ إِ ورْيَازْ-أَ، وَارْ ثدْجِيذْ شَا ذ أَمدُّوكّڒْ ن قَايْصَارْ. كُوڒْ إِجّنْ ونِّي إِتَّارَّانْ إِخفْ نّسْ ذ أَجدْجِيذْ، إِتّْعكَّاسْ قَايْصَارْ.“ \x ◘ \xo 19:‏12 \xt ڒخ. 17‏:‏7. \x*   
\m
\v 13 ڒَامِي إِسْڒَا بِيلَاطُوسْ إِ وَاوَاڒْ-أَ، إِسُّوفّغْ يَاسُوع، إِقِّيمْ خْ ڒْكُورْسِي ن شّْرعْ ذڭْ ومْشَانْ ؤُمِي قَّارنْ ’أَزَّايْ ن لُوصَا‘، مَاشَا قَّارنْ أَسْ س ثْعِيبْرَانِيثْ ’ڭْبِيبْثَا‘. \f ◼ \fr 19:‏13 \ft \+bd ’ثِيعِيبْرَانِيثْ‘\+bd* - أَذْ ثَاغْ ’ثِيعِيبْرَانِيثْ‘ إِجّْ ن إِسمْ نِّي إِسّْمُوننْ ذڭْ إِخفْ نّسْ أَمْ إِڒسْ ن ثْعِيبْرَانِيثْ، أَمْ إِرسْ ن ثْرَامِيثْ.\f*  
\v 14 ثُوغَا ذ \add أَسّْ ن\add* ؤُسوْجذْ إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو. ثُوغَا عْڒَاحَاڒْ ذ ثْسَاعّثْ وِيسّْ ستَّا \add غَارْ ثُوفُّوثْ\add*، ڒَامِي إِنَّا إِ وُوذَاينْ: ”خْزَارمْ، أَجدْجِيذْ نْومْ!“  
\v 15 مَاشَا نِيثْنِي سْغُوينْ: ”كْسِي ث، كْسِي ث، صلّْبْ إِ-ث!“ إِنَّا أَسنْ بِيلَاطُوسْ: ”مَا أَذْ صلّْبغْ \add خنِّي\add* أَجدْجِيذْ نْومْ؟“ أَرِّينْ-د خَاسْ إِمقّْرَاننْ ن إِكهَّاننْ: ”وَارْ غَارْنغْ بُو ؤُجدْجِيذْ مْغِيرْ قَايْصَارْ!“ \x ◘ \xo 19:‏15 \xt أَمز. 49‏:‏10. \x*  
\v 16 خنِّي إِسلّمْ أَسنْ ث حِيمَا أَذْ ث صلّْبنْ. ؤُشَا نِيثْنِي كْسِينْ يَاسُوع، إِوْينْ ث سّنِّي. \x ◘ \xo 19:‏16 \xt مت. 27‏:‏26؛ مك. 15‏:‏22؛ لك. 23‏:‏24، 25. \x*   
\b  
\m  
\s1 يَاسُوع يَاربُّو صَّالِيبْ  
\m
\v 17 يَارْبُو صَّالِيبْ نّسْ غَارْ ومْشَانْ ؤُمِي قَّارنْ ’ثَاشقُّوفْثْ‘، مَاشَا س ثْعِيبْرَانِيثْ قَّارنْ أَسْ ’جُولْجُوثَا‘. \f ◼ \fr 19:‏17 \ft \+bd ’ثِيعِيبْرَانِيثْ‘\+bd* - أَذْ ثَاغْ ’ثِيعِيبْرَانِيثْ‘ إِجّْ ن إِسمْ نِّي إِسّْمُوننْ ذڭْ إِخفْ نّسْ أَمْ إِڒسْ ن ثْعِيبْرَانِيثْ، أَمْ إِرسْ ن ثْرَامِيثْ.\f*  \x ◘ \xo 19:‏17 \xt [مت. 27‏:‏32‏-‏44؛ مك. 15‏:‏21‏-‏32؛ لك. 23‏:‏26‏-‏39] — مت. 27‏:‏31، 33؛ مك. 15‏:‏22؛ لك. 23‏:‏26، 33. \x*  
\v 18 صلّْبنْ ث ذِينِّي، ؤُشَا صلّْبنْ أَكِيذسْ ثْنَاينْ نّغْنِي، إِجّنْ غَارْ إِجّْ ن ؤُغزْذِيسْ ؤُ ونّغْنِي غَارْ ؤُغزْذِيسْ نّغْنِي، ؤُ يَاسُوع ذِي ڒْوسْطْ.  
\v 19 يُورَا بِيلَاطُوسْ عَاوذْ ذڭْ إِشْثْ ثڒْوِيحْثْ، إِسَّارْسْ إِ-ت خْ صَّالِيبْ. أَمُّو إِ إِتّْوَارِي \add ذَايسْ\add*: ’وَانِيثَا ذ يَاسُوع نَّاصِيرِي، أَجدْجِيذْ ن وُوذَاينْ‘. \x ◘ \xo 19:‏19 \xt مت. 27‏:‏37؛ مك. 15‏:‏26؛ لك. 23‏:‏38. \x*  
\v 20 ثِيرَا-يَا غْرِينْ ثنْثْ أَطَّاسْ ن وُوذَاينْ، مِينْزِي أَمْشَانْ مَانِي ثُوغَا صلّْبنْ يَاسُوع يُوذسْ-د إِ ثنْذِينْثْ. \add ثِيرَا-يَا\add* تّْوَارِينْثْ س ثْعِيبْرَانِيثْ ذ ثْلَاثِينِيثْ ذ ثْيُونَانِيثْ.  
\v 21 نَّانْ إِمقّْرَاننْ ن إِكهَّاننْ إِ بِيلَاطُوسْ: ”وَارْ تَّارِي شَا: ’أَجدْجِيذْ ن وُوذَاينْ‘، مَاشَا أَقَا إِنَّا: ’نشّْ ذ أَجدْجِيذْ ن وُوذَاينْ!‘ “  
\v 22 يَارَّا-د بِيلَاطُوسْ: ”مِينْ ؤُرِيغْ، أَقَا ؤُرِيغْ ث.“   
\m
\v 23 ڒَامِي صلّْبنْ إِعسْكَارِييّنْ يَاسُوع، كْسِينْ أَرُّوضْ نّسْ، بْضَانْ ث خْ أَربْعَا ن ثْسقَّارْ، إِ كُوڒْ أَعسْكَارِي إِشْثْ ن ثسْغَارْثْ. مَاشَا ثْشَامِيرْ نّسْ ثُوغَا بْڒَا ثَاخيَّاضْثْ، ثتّْوَاخيّضْ قَاعْ زِي سنّجْ. \x ◘ \xo 19:‏23 \xt مت. 27‏:‏35؛ مك. 15‏:‏24؛ لك. 23‏:‏34. \x*  
\v 24 نَّانْ إِ وَايَاوْيَا: ”وَارْ ث نتّْشَارِّيڭْ شَا، أَذْ خَاسْ نڭّْ أَكشُّوضْ، أَذْ نْژَارْ وِي ث غَا يَاوْينْ!“ أَمُّو إِ إِتّْوَاكمّڒْ أَوَاڒْ ن ثِيرَا \add إِقدّْسنْ\add* إِ إِقَّارنْ: ”بْضَانْ أَرُّوضْ إِنُو جَارْ أَسنْ ؤُ خْ ثْشَامِيرْ إِنُو ڭِّينْ أَكشُّوضْ.“ مَانْ أَيَا إِ إِڭِّينْ إِعسْكَارِييّنْ. \x ◘ \xo 19:‏24 \xt إِزهد. 22‏:‏19. \x*   
\m
\v 25 غَارْ صَّالِيبْ ن يَاسُوع ثْبدّْ يمَّاسْ، ذ ؤُتْشْمَاسْ ن يمَّاسْ، ذ مَارْيَامْ \add ثَامْغَارْثْ\add* ن كْلِييُوبَاسْ، ذ مَارْيَامْ ن مَاجْذَالَا. \x ◘ \xo 19:‏25 \xt مت. 27‏:‏55؛ مك. 15‏:‏40؛ لك. 23‏:‏49. \x*  
\v 26 ڒَامِي إِژْرَا يَاسُوع يمَّاسْ ذ ؤُمحْضَارْ ونِّي ثُوغَا إِتّخْسْ، إِبدّْ ذِينْ، إِنَّا إِ يمَّاسْ: ”\add أَ\add* ثَامْغَارْثْ، خْزَارْ، مِّيمْ!“  
\v 27 ڒخْذنِّي إِنَّا إِ ؤُمحْضَارْ نِّي: ”أَقَا-شْ يمَّاشْ!“ زِي ثْسَاعّثْ نِّي إِكْسِي ت ؤُمحْضَارْ \add غَارْ ثَادَّارْثْ نّسْ\add*.   
\b  
\m  
\s1 ڒْموْثْ ن يَاسُوع خْ صَّالِيبْ  
\m
\v 28 أَوَارْنِي مَانْ أَيَا إِسّنْ يَاسُوع أَقَا كُوڒْشِي إِتّْوَاكمّڒْ، ڒخْذنِّي إِنَّا، حِيمَا أَذْ يِيڒِي \add مِينْ يُورَانْ\add* ذِي ثِيرَا \add إِقدّْسنْ\add*: ”نشّْ فُّوذغْ!“ \x ◘ \xo 19:‏28 \xt [مت. 27‏:‏45‏-‏56؛ مك. 15‏:‏33‏-‏41؛ لك. 23‏:‏44‏-‏49] — إِزهد. 22‏:‏15؛ 69‏:‏21. \x*  
\v 29 إِتّْوَامَارْسْ ذِينْ إِجّْ ن ؤُغَارَّافْ إِشُّورْ س ڒْخدْجْ. سّْغضْصنْ إِشْثْ ن سْپُونْخَا \add ن هِيسُوبْ\add* س ڒْخدْجْ ؤُشَا ڭِّينْ ت خْ \add إِجّْ ن ؤُغَانِيمْ ن\add* ثْعلْدْجثْ، سِّيوْضنْ أَسْ ت غَارْ ؤُقمُّومْ نّسْ.  
\v 30 ڒَامِي إِقَّاسْ يَاسُوع ڒْخدْجْ، إِنَّا: ”أَقَا إِتّْوَاكمّڒْ!“ ؤُشَا إِسَّاضَارْ أَزدْجِيفْ نّسْ، إِسلّمْ أَرُّوحْ نّسْ.   
\m
\v 31 ؤُمِي ثُوغَا \add أَسّْ ن\add* ؤُسوْجذْ \add ن ثْغَارْصْثْ ن ؤُسعْذُو\add*، نَّانْ وُوذَاينْ: ”وَارْ إِعدّڒْ أَذْ قِّيمنْثْ أَرِّيمَاثْ \add نْسنْ\add* خْ صَّالِيبْ ذِي سّبْثْ، مِينْزِي سّبْثْ يُوذسْ-د!“، مِينْزِي أَسّْ نِّي ن سّبْثْ ثُوغَا ذ أَسّْ أَمقّْرَانْ. س ؤُيَا تَّارنْ وُوذَاينْ زِي بِيلَاطُوسْ، حِيمَا أَذْ أَرْژنْ إِضَارنْ ن يِينِّي إِتّْوَاصلّْبنْ، أَذْ ثنْ سِّيڭّْوجنْ سّنِّي.  
\v 32 \add خنِّي\add* ؤُسِينْ-د إِعسْكَارِييّنْ، أَرْژِينْ إِضَارنْ ن ؤُمزْوَارُو ؤُ ن ونّغْنِي إِ ثُوغَا إِتّْوَاصلّبْ أَكِيذسْ.  
\v 33 مَاشَا ڒَامِي د-ؤُسِينْ غَارْ يَاسُوع، وَارْ أَرْژِينْ شَا إِضَارنْ نّسْ ؤُمِي ژْرِينْ أَقَا إِمُّوثْ.  
\v 34 مَاشَا إِجّنْ زڭْ إِعسْكَارِييّنْ إِسّْنُوقّبْ إِ-ث س إِشْثْ ن لَانْسَا ذڭْ ؤُغزْذِيسْ نّسْ ؤُشَا فّْغنْ-د إِذَامّنْ ذ وَامَانْ ذغْيَا.  
\v 35 ونِّي إِژْرِينْ مَانْ أَيَا، ثُوغَا إِشْهذْ ؤُ شّْهَاذثْ نّسْ ذ ثِيذتّْ ؤُشَا نتَّا إِسّنْ، أَقَا إِنَّا ثِيذتّْ، حِيمَا أَذْ ثَامْنمْ ؤُڒَا ذ كنِّيوْ.  
\v 36 ثِيمسْڒَايِينْ-أَ مْسَارنْثْ، حِيمَا أَذْ تّْوَاكمّْڒنْثْ ثِيرَا \add إِقدّْسنْ\add* إِ إِقَّارنْ: ”وَارْ زَّايسْ إِتَّارژِّي يِيغسْ.“ \x ◘ \xo 19:‏36 \xt ؤُف. 12‏:‏46؛ ڒخْڒ. 9‏:‏12؛ إِزهد. 34‏:‏22. \x*  
\v 37 ؤُشَا إِجّْ ن وَاوَاڒْ نّغْنِي زِي ثِيرَا \add إِقدّْسنْ\add* إِقَّارْ: ”نِيثْنِي أَذْ ژَترنْ ونِّي ث إِسّْنُوقّْبنْ.“ \x ◘ \xo 19:‏37 \xt زَاك. 12‏:‏10. \x*   
\b  
\m  
\s1 أَنْضڒْ ن يَاسُوع  
\m
\v 38 أَوَارْنِي مَانْ أَيَا إِمْسَارْ أَقَا يُوسُوفْ زِي رَامْثَا، ونِّي ثُوغَا ذ إِجّْ ن ؤُمحْضَارْ ن يَاسُوع مَاشَا س ثْنُوفّْرَا زِي ثِيڭّْوُوذِي زڭْ وُوذَاينْ، إِتَّارْ أَسْ إِ بِيلَاطُوسْ تّسْرِيحْ حِيمَا أَذْ إِكْسِي أَرِّيمثْ ن يَاسُوع، ؤُشَا بِيلَاطُوسْ إِسَارّحْ أَسْ. خنِّي يُوسَا-د، إِكْسِي أَرِّيمثْ ن يَاسُوع. \x ◘ \xo 19:‏38 \xt [مت. 27‏:‏57‏-‏61؛ مك. 15‏:‏42‏-‏47؛ لك. 23‏:‏50‏-‏56] — مت. 27‏:‏57؛ مك. 15‏:‏42؛ لك. 23‏:‏50؛ يُوح. 12‏:‏42. \x*  
\v 39 يُوسَا-د عَاوذْ نِيكُوذِيمُوسْ ونِّي ثُوغَا د-يُوسِينْ قْبڒْ غَارْ يَاسُوع س دْجِيڒثْ، يِيوِي-د أَكِيذسْ أَخدْجضْ ن ڒفْوَاحثْ ن مِيرُّو ذ وشْفِيرْ عْڒَاحَاڒْ مْيَا لِيثْرُو. \f ◼ \fr 19:‏39 \ft \+bd ’قْبڒْ‘\+bd* - خْزَارْ يُوحْ. 3:1.\f*  \x ◘ \xo 19:‏39 \xt يُوح. 3‏:‏1؛ 7‏:‏50. \x*  
\v 40 كْسِينْ نِيثْنِي أَرِّيمثْ ن يَاسُوع، ڒحّْفنْ ت ذِي ڒشْفُونْ ن ڒقْطنْ \add أَزْذَاذْ\add* أَكْ-ذ ڒعْطُورْ، أَمْ مَامّشْ نُّومنْ تّڭّنْ ت وُوذَاينْ إِ ونْضڒْ.  
\v 41 ثُوغَا ذِينْ إِجّْ ن وحْوِيشْ ذڭْ ومْشَانْ مَانِي صلّْبنْ يَاسُوع، ؤُشَا ذڭْ وحْوِيشْ إِجّْ ن ونْضڒْ ن جْذِيذْ،عمَّارْصْ وَارْ ذَايسْ سَّارْسنْ ؤُڒَا ذ إِجّْ.  
\v 42 سَّارْسنْ يَاسُوع ذِينْ، مِينْزِي ثُوغَا يِيوضْ-د سّبْثْ ؤُ مِينْزِي أَنْضڒْ \add نِّي\add* ثُوغَا يُوذسْ.   
\b  
\b  
\m  
\c 20
\s1 أَنْضڒْ ن يَاسُوع إِخْوَا  
\m
\v 1 ذڭْ \add وَاسّْ\add* أَمزْوَارُو ن سِّيمَانَا ثُوسَا-د مَارْيَامْ ن مَاجْذَالَا ذِي صّْبحْ زِيشْ غَارْ ونْضڒْ، ثُوغَا عَاذْ ذ ثَادْجسْثْ. ثژْرَا ثَاصْضَارْثْ أَقَا ثمّكْسِي خْ ونْضڒْ. \x ◘ \xo 20:‏1 \xt [مت. 28‏:‏1‏-‏10؛ مك. 16‏:‏1‏-‏8؛ لك. 24‏:‏1‏-‏12] — مت. 28‏:‏1؛ مك. 16‏:‏1؛ لك. 24‏:‏1. \x*  
\v 2 ثُوزّڒْ-د، ثُوسَا-د غَارْ شِيمْعُونْ بُوطْرُوسْ ؤُ غَارْ ؤُمحْضَارْ نّغْنِي ونِّي ؤُمِي ثُوغَا إِتّخْسْ يَاسُوع، ثنَّا أَسنْ: ”كْسِينْ سِيذِيثْنغْ زڭْ ونْضڒْ، وَارْ سِّينغْ مَانِي ث ڭِّينْ.“ \x ◘ \xo 20:‏2 \xt يُوح. 13‏:‏23؛ 21‏:‏7، 20. \x*   
\m
\v 3 إِفّغْ-د شِيمْعُونْ ذ ؤُمحْضَارْ نّغْنِي ؤُشَا ؤُسِينْ-د غَارْ ونْضڒْ. \x ◘ \xo 20:‏3 \xt لك. 24‏:‏12. \x*  
\v 4 نِيثْنِي ؤُزّْڒنْ س ثْنَاينْ إِذْسنْ، \add مَاشَا\add* أَمحْضَارْ \add نّغْنِي\add* إِزْوَارْ إِ شِيمْعُونْ ؤُشَا يِيوضْ ذ أَمزْوَارُو غَارْ ونْضڒْ.  
\v 5 إِخْزَارْ، إِژْرَا ڒشْفُونْ نْ ڒقْطنْ \add أَزْذَاذْ\add* مَّارْسنْ \add ذِينْ\add*، مَاشَا وَارْ يُوذِيفْ شَا. \x ◘ \xo 20:‏5 \xt يُوح. 19‏:‏40. \x*  
\v 6 إِضْفَارْ إِ-ث شِيمْعُونْ، يُوذفْ غَارْ ونْضڒْ، إِژْرَا \add عَاوذْ\add* ڒشْفُونْ ن ڒقْطنْ \add أَزْذَاذْ\add* مَّارْسنْ \add ذِينْ\add*.  
\v 7 أَمنْذِيڒْ نِّي ثُوغَا خْ ؤُزدْجِيفْ نّسْ، وَارْ إِمَّارْسْ شَا أَكْ-ذ ڒشْفُونْ ن ڒقْطنْ \add أَزْذَاذْ\add*، مَاشَا ثُوغَا إِضْفصْ، إِتّْوَاڭّْ ذڭْ ومْشَانْ وحّْذسْ. \x ◘ \xo 20:‏7 \xt يُوح. 11‏:‏44. \x*  
\v 8 ڒخْذنِّي يُوذفْ-د ؤُڒَا ذ أَمحْضَارْ نّغْنِي نِّي د-يُوسِينْ ذ أَمزْوَارُو غَارْ ونْضڒْ، إِژْرَا ؤُشَا يُومنْ.  
\v 9 مِينْزِي نِيثْنِي ثُوغَا عَاذْ وَارْ سِّيننْ ثِيرَا \add إِقدّْسنْ\add*، بلِّي إِتّْخصَّا أَسْ أَذْ إِكَّارْ جَارْ إِمتِّيننْ. \x ◘ \xo 20:‏9 \xt إِزهد. 16‏:‏10؛ ڒخ. 2‏:‏25، 31؛ 13‏:‏35. \x*   
\m
\v 10 خنِّي ذوْڒنْ إِمحْضَارنْ نِّي غَارْ ثَادَّارْثْ نْسنْ.   
\b  
\m  
\s1 أَضْهَارْ ن يَاسُوع إِ مَارْيَامْ زِي مَاجْذَالَا  
\m
\v 11 مَارْيَامْ ثقِّيمْ ثْبدّْ غَارْ ونْضڒْ بَارَّا، ثتّْرُو. ڒَامِي ثُوغَا ثتّْرُو، ثسْوضْ ذڭْ ونْضڒْ، \x ◘ \xo 20:‏11 \xt [مك. 16‏:‏9‏-‏11] — مت. 28‏:‏1؛ مك. 16‏:‏5؛ لك. 24‏:‏4. \x*  
\v 12 ثژْرَا ثْنَاينْ ن لْمَالَاكَاثْ س وَارُّوضْ ذ أَشمْڒَاڒْ، قِّيمنْثْ مَانِي ثُوغَا ثمَّارْسْ أَرِّيمثْ ن يَاسُوع، إِجّنْ غَارْ ثْسُومّْثِينْ نّسْ ن ؤُزدْجِيفْ، إِجّنْ غَارْ إِضَارنْ نّسْ.  
\v 13 نَّانْ أَسْ: ”\add أَ\add* ثَامْغَارْثْ، مَايمِّي ثتّْرُوذْ؟“ ثنَّا أَسنْ: ”مَاغَارْ كّْسنْ سِيذِي إِنُو، وَارْ سِّينغْ مَانِي ث سَّارْسنْ.“  
\v 14 ؤُمِي ثنَّا أَيَا، ثنّقْڒبْ غَارْ ضفَّارْ، ثژْرَا يَاسُوع إِبدّْ، مَاشَا وَارْ ثسِّينْ شَا أَقَا-ث ذ يَاسُوع. \x ◘ \xo 20:‏14 \xt مت. 28‏:‏9؛ مك. 16‏:‏9. \x*  
\v 15 يَاسُوع إِنَّا أَسْ: ”\add أَ\add* ثَامْغَارْثْ، مَايمِّي ثتّْرُوذْ؟ مِينْ خفْ ثَارزُّوذْ؟“ ثتّْغِيڒْ أَسْ نتَّا ذ بَابْ ن ثحْوِيشْثْ، ثنَّا أَسْ: ”\add أَ\add* سِيذِي مَاڒَا شكْ إِ-ث إِكْسِينْ، إِنِي أَيِي مَانِي ث ثسَّارْسذْ، \add خنِّي\add* أَذْ ث كْسِيغْ.“  
\v 16 يَاسُوع إِنَّا أَسْ: ”\add أَ\add* مَارْيَامْ!“ نتَّاثْ ثنّقْڒبْ، ثنَّا أَسْ س ثْعِيبْرَانِيثْ: ”\add أَ\add* رَابُّولِي!“، إِخْسْ أَذْ يِينِي: ’\add أَ\add* أَمْسغَّارْ إِنُو‘.  
\v 17 يَاسُوع إِنَّا أَسْ: ”وَارْ ذ أَيِي ثتّْحِيذِي شَا، أَقَا نشّْ عَاذْ وَارْ ڭعّْذغْ شَا غَارْ بَابَا، مَاشَا رُوحْ غَارْ أَيْثْمَا، إِنِي أَسنْ: ’نشّْ أَقَا أَذْ ڭعّْذغْ غَارْ بَابَا ذ بَابَاثْومْ، غَارْ أَربِّي إِنُو ذ أَربِّي نْومْ.‘ “ \x ◘ \xo 20:‏17 \xt إِزهد. 22‏:‏23؛ مت. 28‏:‏10؛ يُوح. 16‏:‏2؛ عبر. 2‏:‏11. \x*  
\v 18 ثعْقبْ-د مَارْيَامْ ن مَاجْذَالَا ثْخبَّارْ إِمحْضَارنْ بلِّي نتَّاثْ ثژْرَا سِيذِيثْنغْ ؤُ بلِّي نتَّا إِنَّا أَسْ مَانْ أَيَا. \x ◘ \xo 20:‏18 \xt مت. 28‏:‏8؛ مك. 16‏:‏10؛ لك. 24‏:‏9. \x*   
\b  
\m  
\s1 أَضْهَارْ ن يَاسُوع إِ إِمحْضَارنْ نّسْ  
\m
\v 19 غَارْ ثْمذِّيثْ ن وَاسّْ نِّي، نتَّا ذ \add أَسّْ\add* أَمزْوَارُو ن سِّيمَانَا، ؤُمِي ثُوغَا ثِيوُّورَا مَانِي ثُوغَا \add قِّيمنْ\add* إِمحْضَارنْ قّْننْثْ س ثِيڭّْوُوذِي زڭْ وُوذَاينْ، يُوذفْ-د يَاسُوع، إِبدّْ ذِي ڒْوسْطْ نْسنْ، إِنَّا أَسنْ: ”سْڒَامْ خَاومْ.“ \x ◘ \xo 20:‏19 \xt [مت. 28‏:‏16‏-‏20؛ مك. 16‏:‏14‏-‏18؛ لك. 24‏:‏36‏-‏49] — مك. 16‏:‏14؛ لك. 24‏:‏36؛ 1 كُور. 15‏:‏5. \x*  
\v 20 أَوَارْنِي ڒَامِي إِنَّا أَيَا، إِمّڒْ أَسنْ إِفَاسّنْ نّسْ ذ ؤُغزْذِيسْ نّسْ. فَارْحنْ إِمحْضَارنْ ڒَامِي ژْرِينْ سِيذِيثْنغْ. \x ◘ \xo 20:‏20 \xt يُوح. 16‏:‏22. \x*  
\v 21 إِنَّا أَسنْ عَاوذْ يَاسُوع: ”سْڒَامْ خَاومْ، أَمْ مَامّشْ ذ أَيِي د-إِسّكّْ بَابَا، أَذْ كنِّيوْ د-سّكّغْ ؤُڒَا ذ نشّْ.“ \x ◘ \xo 20:‏21 \xt إِشا. 61‏:‏1؛ مت. 28‏:‏18؛ مك. 16‏:‏15؛ لك. 4‏:‏18؛ يُوح. 17‏:‏18. \x*  
\v 22 أَوَارْنِي ڒَامِي إِنَّا مَانْ أَيَا، إِسُوضْ ذَايْسنْ، إِنَّا أَسنْ: ”قبْڒمْ أَرُّوحْ إِقدّْسنْ.“  
\v 23 ونِّي ؤُمِي غَا ثغْفَارمْ دّْنُوبْ نّسْ، أَذْ أَسْ تّْوَاغْفَارنْ \add دّْنُوبْ نّسْ\add*. ونِّي ؤُمِي ذ أَسْ إِ غَا ثطّْفمْ ذِي دّْنُوبْ نّسْ، أَذْ أَسْ تّْوَاطّْفنْ \add دّْنُوبْ نّسْ\add*.“ \x ◘ \xo 20:‏23 \xt مت. 16‏:‏19؛ 18‏:‏18. \x*   
\b  
\m  
\s1 يَاسُوع إِسّْشنْ إِخفْ نّسْ إِ ثُومَا  
\m
\v 24 مَاشَا ثُومَا، إِجّنْ زِي ثنْعَاشْ، ونِّي ؤُمِي قَّارنْ ’أَشْنِيوْ‘، وَارْ ثُوغِي شَا أَكِيذْسنْ ڒَامِي د-يُوسَا يَاسُوع.  
\v 25 نَّانْ أَسْ إِمحْضَارنْ: ”أَقَا نژْرَا سِيذِيثْنغْ!“ مَاشَا نتَّا إِنَّا أَسنْ: ”مَاڒَا وَارْ ژْرِيغْ ڒِيمَاڒْثْ ن إِمسْمِيرنْ ذڭْ إِفَاسّنْ نّسْ، أَذْ سَّارْسغْ أَضَاضْ إِنُو ذڭْ ومْشَانْ ن إِمسْمِيرنْ ؤُشَا أَذْ سَّارْسغْ أَفُوسْ إِنُو ذڭْ ؤُغزْذِيسْ نّسْ، وَارْ تِّيمْنغْ.“   
\m
\v 26 أَوَارْنِي ثْمنْيَا ن وُوسَّانْ ثُوغَا إِمحْضَارنْ \add نّسْ\add* عَاوذْ غَارْ ذَاخڒْ ؤُ ثُومَا ثُوغَا أَكِيذْسنْ. يُوذفْ-د يَاسُوع، وَاخَّا ثِيوُّورَا ثُوغَا قّْننْثْ، ؤُشَا إِبدّْ-د ذِي ڒْوسْطْ نْسنْ، إِنَّا: ”سْڒَامْ خَاومْ!“  
\v 27 إِنَّا إِ ثُومَا: ”أَوِي-د أَضَاضْ نّشْ ؤُشَا خْزَارْ ذڭْ إِفَاسّنْ إِنُو، سَارْسْ أَفُوسْ نّشْ \add ذَانِيثَا\add* ؤُ سِيذفْ إِ-ث ذڭْ ؤُغزْذِيسْ إِنُو. وَارْ تِّيڒِي ذ أَكَافْرِيوْ، مَاشَا ذ ڒْمُومنْ.“ \x ◘ \xo 20:‏27 \xt 1 يُوح. 1‏:‏1. \x*  
\v 28 يَارَّا-د ثُومَا، إِنَّا أَسْ: ”أَ سِيذِي إِنُو ذ أَربِّي إِنُو!“  
\v 29 إِنَّا أَسْ يَاسُوع: ”ؤُمِي ثژْرِيذْ أَيِي ڒخُّو، أَقَا ثُومْنذْ، \add أَ\add* ثُومَا! سّعْذْ ن يِينِّي يُومْننْ، وَاخَّا نِيثْنِي وَارْ \add ذ أَيِي\add* ژْرِينْ.“ \x ◘ \xo 20:‏29 \xt 1 بُط. 1‏:‏8. \x*   
\m
\v 30 يَاسُوع إِڭَّا أَطَّاسْ ن ڒعْڒَامَاثْ نّغْنِي قِيبَاتْشْ إِ إِمحْضَارنْ نّسْ، ثِينِّي وَارْ يُورِينْثْ شَا ذڭْ وذْلِيسْ-أَ، \x ◘ \xo 20:‏30 \xt يُوح. 21‏:‏25. \x*  
\v 31 مَاشَا ثِينَا ؤُرَانْثْ حِيمَا أَذْ ثَامْنمْ بلِّي يَاسُوع نتَّا ذ لْمَاسِيحْ، مِّيسْ ن أَربِّي، ؤُشَا خْمِي غَا ثَامْنمْ، أَذْ غَارْومْ ثِيڒِي ثُوذَارْثْ س يِيسمْ نّسْ.   
\b  
\b  
\m  
\c 21
\s1 أَضْهَارْ ن يَاسُوع غَارْ ڒبْحَارْ ن ثِيبِيرِييَاسْ  
\m
\v 1 أَوَارْنِي ؤُيَا ثُوغَا يَاسُوع إِمّڒْ إِخفْ نّسْ عَاوذْ إِ إِمحْضَارنْ نّسْ غَارْ ڒبْحَارْ ن ثِيبِيرِييَاسْ، إِضْهَارْ-د أَمُّو.  
\v 2 ثُوغَا \add ذِينْ\add* جْمِيعْ شِيمْعُونْ بُوطْرُوسْ ذ ثُومَا، ونِّي ؤُمِي قَّارنْ ’أَشْنِيوْ‘، ذ نَاثَانَايِيلْ، ونِّي ثُوغَا زِي قَانَا ذِي ثمُّورْثْ ن لْجَالِيلْ، ذ ثَارْوَا ن زَابْذِي ؤُڒَا ذ ثْنَاينْ نّغْنِي زڭْ إِمحْضَارنْ \add نّسْ\add*. \x ◘ \xo 21:‏2 \xt مت. 4‏:‏21؛ مك. 1‏:‏19؛ يُوح. 1‏:‏46. \x*   
\m
\v 3 إِنَّا أَسنْ شِيمْعُونْ بُوطْرُوسْ: ”نشّْ أَذْ رَاحغْ أَذْ ڭْمَارغْ \add إِسڒْمَانْ\add*.“ نَّانْ أَسْ: ”أَذْ كِيكْ نْرَاحْ ؤُڒَا ذ نشِّينْ.“ فّْغنْ-د ؤُشَا نْيِينْ ذغْيَا ذِي ثْغَارَّابُوثْ. ذِي دْجِيڒثْ نِّي وَارْ طِّيفنْ وَالُو.  
\v 4 غَارْ ثُوفُّوثْ، إِبدّْ-د يَاسُوع خْ ثْمَا ن ڒبْحَارْ، مَاشَا إِمحْضَارنْ وَارْ سِّيننْ شَا أَقَا ذ يَاسُوع.  
\v 5 إِنَّا أَسنْ يَاسُوع: ”\add أَ\add* إِحنْجِيرنْ، مَا أَذْ ثَاغْ غَارْومْ شَا ن مَاشَّا؟“ أَرِّينْ-د خَاسْ ”لَّ!“  
\v 6 إِنَّا أَسنْ: ”نْضَارمْ ثْرَاشَّا نْومْ أَكْ-ذ ؤُغزْذِيسْ أَفُوسِي ن ثْغَارَّابُوثْ، أَذْ ثَافمْ.“ خنِّي نْضَارنْ \add ثْرَاشَّا\add* ؤُشَا وَارْ زمَّارنْ أَذْ ت-إِ-د-جبْذنْ زِي سِّيبّثْ ن ؤُبَارُّو ن إِسڒْمَانْ إِ ذَايسْ إِتّْوَاطّْفنْ. \x ◘ \xo 21:‏6 \xt لك. 5‏:‏4، 6، 7. \x*   
\m
\v 7 إِنَّا ؤُمحْضَارْ ونِّي ثُوغَا إِتّخْسْ يَاسُوع إِ بُوطْرُوسْ: ”أَقَا نتَّا ذ سِيذِيثْنغْ.“ ڒَامِي إِسْڒَا شِيمْعُونْ أَقَا نتَّا ذ سِيذِي، إِطّفْ ثْشَامِيرْ نّسْ مِينْزِي ثُوغَا ذ أَعَارْيَانْ، إِنْضَارْ إِخفْ نّسْ ذِي ڒبْحَارْ أَڒَامِي غَا د-إِقَارّبْ غَارْ يَاسُوع. \x ◘ \xo 21:‏7 \xt يُوح. 13‏:‏23؛ 20‏:‏2. \x*  
\v 8 مَاشَا إِمحْضَارنْ إِنّغْنِي ؤُسِينْ-د س ثْغَارَّابُوثْ مِينْزِي وَارْ إِڭّْوِيجنْ شَا خْ ڒْبَارّْ مْغِيرْ مِيثَاينْ ن إِغَادْجنْ، ؤُشَا جبْذنْ-د ثْرَاشَّا أَكْ-ذ إِسڒْمَانْ. \f ◼ \fr 21:‏8 \ft \+bd ’مِيثَاينْ ن إِغَادْجنْ‘\+bd* - إِخْسْ أَذْ يِينِي عْڒَاحَاڒْ 100 مِيثْرُو.\f*   
\m
\v 9 ڒَامِي د-فّْغنْ غَارْ ڒْبَارّْ، ژْرِينْ ذِيهَا أَقَا إِتّْوَاسّوْجذْ إِجّْ ن ؤُفنِّيشْ ن ڒفْحمْ مِيخفْ مَّارْسنْ إِسڒْمَانْ ذ وغْرُومْ.  
\v 10 إِنَّا أَسنْ يَاسُوع: ”أَوْيمْ-د زڭْ إِسڒْمَانْ إِ ثڭْمَارمْ ڒخُّو.“ \x ◘ \xo 21:‏10 \xt لك. 24‏:‏41. \x*  
\v 11 شِيمْعُونْ بُوطْرُوسْ يُويُورْ، إِجْبذْ ثْرَاشَّا ثشُّورْ س إِسڒْمَانْ إِمقّْرَاننْ غَارْ ڒْبَارّْ، أَقَا-ت ذَايسْ مْيَا ؤُ-ثْڒَاثَا ؤُ-خمْسِينْ. وَاخَّا ذَايسْ س وَانشْثْ ؤُيَا \add أَطَّاسْ\add*، وَارْ ثْشَارّڭْ شَا ثْرَاشَّا.  
\v 12 إِنَّا أَسنْ يَاسُوع: ”أَرَاحمْ-د ذَا، أَذْ ثَارِييّْقمْ!“ ؤُڒَا ذ إِجّْ زڭْ إِمحْضَارنْ وَارْ إِزْعِيمْ أَذْ ث إِسّقْسَا ’مِينْ ثعْنِيذْ شكْ؟‘، مِينْزِي سّْننْ أَقَا-ث ذ سِيذِيثْنغْ.  
\v 13 ڒخْذنِّي يُوسَا-د يَاسُوع، إِكْسِي أَغْرُومْ ذ إِسڒْمَانْ، إِوْشَا أَسنْ.  
\v 14 وَانِيثَا ذ ثْوَاڒَا وِيسّْ ثْڒَاثَا إِ د-إِضْهَارْ يَاسُوع إِ إِمحْضَارنْ نّسْ أَوَارْنِي ڒَامِي د-إِتّْوَاسّْنكَّارْ زِي ثَادَّارْثْ ن إِمتِّيننْ.   
\b  
\m  
\s1 أَسقْسِي ن يَاسُوع إِ بُوطْرُوسْ  
\m
\v 15 أَوَارْنِي ڒَامِي أَرِييّْقنْ، إِنَّا يَاسُوع إِ شِيمْعُونْ بُوطْرُوسْ: ”\add أَ\add* شِيمْعُونْ، مِّيسْ ن يُونَا، مَا ثتّخْسذْ أَيِي كْثَارْ زڭْ يِينَا؟“ إِنَّا أَسْ: ”وَاهْ، أَ سِيذِي، شكْ ثسّْنذْ أَقَا نشّْ تّخْسغْ شكْ.“ إِنَّا أَسْ: \bd ”أَرْوسْ إِزْمَارنْ إِنُو!“\bd*  
\v 16 إِنَّا أَسْ عَاوذْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ: ”\add أَ\add* شِيمْعُونْ، مِّيسْ ن يُونَا، مَا ثتّخْسذْ أَيِي؟“ إِنَّا أَسْ: ”وَاهْ \add أَ\add* سِيذِي، شكْ ثسّْنذْ أَقَا نشّْ تّخْسغْ شكْ.“ إِنَّا أَسْ: \bd ”أَرْوسْ إِشَارِّييّنْ إِنُو!“\bd*  
\v 17 إِنَّا أَسْ إِ ثْوَاڒَا وِيسّْ ثْڒَاثَا: ”\add أَ\add* شِيمْعُونْ، مِّيسْ ن يُونَا، مَا ثتّخْسذْ أَيِي؟“ إِشْضنْ بُوطْرُوسْ مِينْزِي إِنَّا أَسْ ث ثْوَاڒَا وِيسّْ ثْڒَاثَا: ’مَا ثتّخْسذْ أَيِي؟‘، ؤُشَا إِنَّا أَسْ: ”\add أَ\add* سِيذِي، شكْ ثسّْنذْ كُوڒْشِي، ثسّْنذْ أَقَا نشّْ تّخْسغْ شكْ.“ إِنَّا أَسْ يَاسُوع: \bd ”أَرْوسْ ثِيخْسِيوِينْ إِنُو!\bd* \x ◘ \xo 21:‏17 \xt يُوح. 16‏:‏30. \x*  
\v 18 س ثِيذتّْ، س ثِيذتّْ، نشّْ أَذْ أَشْ إِنِيغْ: ڒَامِي شكْ ثُوغَا ذ أَمژْيَانْ، ثْبيْسذْ إِ يِيخفْ نّشْ، ثْرُوحذْ مَانِي ثخْسذْ، مَاشَا خْ مِينِّي إِ غَا ثوْسَارذْ، أَذْ ثسّْوِيژّْضذْ إِفَاسّنْ نّشْ ؤُشَا ونّغْنِي أَذْ شكْ إِبْيسْ ؤُشَا أَذْ شكْ يَاوِي غَارْ مَانِي وَارْ ثتّخْسذْ.“ \x ◘ \xo 21:‏18 \xt يُوح. 13‏:‏36؛ ڒخ. 12‏:‏3؛ 2 بُط. 1‏:‏14. \x*  
\v 19 إِنَّا أَمُّو حِيمَا أَذْ إِسّْشنْ إِ مَانْ ڒْموْثْ إِ زِي غَا إِسّْعُودْجْ أَربِّي. أَوَارْنِي ڒَامِي \add ذ أَسْ\add* إِنَّا أَمُّو، إِنَّا أَسْ: ”ضْفَارْ أَيِي-د!“ \x ◘ \xo 21:‏19 \xt 2 بُط. 1‏:‏14. \x*   
\m
\v 20 إِنّقْڒبْ شِيمْعُونْ بُوطْرُوسْ، إِژْرَا أَمحْضَارْ نِّي ثُوغَا إِتّخْسْ يَاسُوع، إِضْفَارْ إِ-ث، نتَّا ذ ونِّي ثُوغَا يَارَّا إِخفْ نّسْ أَذْ إِميّڒْ غَارْ إِذْمَارنْ ن يَاسُوع غَارْ ؤُمنْسِي إِ إِنَّانْ: ”\add أَ\add* سِيذِي إِنُو، وِي شكْ إِ غَا إِغْذَارنْ؟“ \x ◘ \xo 21:‏20 \xt يُوح. 13‏:‏23؛ 20‏:‏2؛ 21‏:‏7. \x*  
\v 21 ڒَامِي إِژْرَا بُوطْرُوسْ وَا، إِنَّا إِ يَاسُوع: ”\add أَ\add* سِيذِي، إِ وَا، مِينْ ذ أَسْ غَا إِمْسَارنْ؟“  
\v 22 إِنَّا أَسْ يَاسُوع: ”مَاڒَا خْسغْ أَذْ إِقِّيمْ أَڒْ د غَاعقْبغْ، مِينْ ذ أَشْ إِرُوحنْ؟ شكْ ضْفَارْ أَيِي-د!“  
\v 23 ؤُشَا إِفّغْ-د وَاوَاڒْ-أَ جَارْ وَاوْمَاثنْ بلِّي أَمحْضَارْ نِّي وَارْ إِتّْمتِّي شَا، مَاشَا يَاسُوع وَارْ ذ أَسْ إِنِّي شَا بلِّي نتَّا وَارْ إِتّْمتِّي شَا، مَاشَا: ”مَاڒَا خْسغْ أَذْ إِقِّيمْ أَڒْ د غَاعقْبغْ، مِينْ ذ أَشْ إِرُوحنْ؟“   
\b  
\m  
\s1 ثَانڭَّارُوثْ  
\m
\v 24 ذ وَا ذ أَمحْضَارْ إِ إِشهّْذنْ س مَانْ أَيَا ؤُشَا نتَّا يُورَا مَانْ أَيَا، ؤُ نشِّينْ نسّنْ أَقَا شّْهَاذثْ نّسْ ذ ثِيذتّْ. \x ◘ \xo 21:‏24 \xt يُوح. 19‏:‏35. \x*  
\v 25 أَقَا ذِينْ عَاذْ أَطَّاسْ ن ثْمسْڒَايِينْ نّغْنِي إِ إِڭَّا يَاسُوع. مَاڒَا تّْوَارِينْثْ إِشْثْ أَوَارْنِي ثنّغْنِيثْ، إِتّْغِيڒْ أَيِي، أَذْ ثِيڒِي دُّونشْثْ سِيمَانْثْ نّسْ وَارْ ذَايسْ شَا تَّاسِيعْ حِيمَا أَذْ ثكْسِي إِذْلِيسنْ إِ غَا إِتّْوَارِينْ. أَمِينْ!  
\b  
\m أَنڭَّارْ ن لْ-إِنْجِيلْ إِقدّْسنْ أَمْ مَامّشْ ث إِبَارّحْ يُوحَانَّا.  
\b  
\m أَنڭَّارْ ن ثِيرَا ن إِذْلِيسنْ ن أَربْعَا ن \add إِذْلِيسنْ\add* ن لْ-إِنْجِيلْ.  
\b  
\m أَعُودْجِي إِ بَابَاسْ، إِ مِّيسْ ؤُ إِ أَرُّوحْ إِقدّْسنْ، ڒخُّو، ڒبْذَا ؤُ إِ ڒبْذَا ن ڒبْذَاثْ. \x ◘ \xo 21:‏25 \xt يُوح. 20‏:‏30. \x*   