\p \w Al|strong="G3588"\w* entender \w que|strong="G3754"\w* \w era|strong="G1510"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w*, \w ninguno|strong="G3762"\w* \w de|strong="G3588"\w* \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w* \w se|strong="G1492"\w* atrevía \w a|strong="G1161"\w* \w preguntarle|strong="G1833"\w*: ¿\w Quién|strong="G5101"\w* \w eres|strong="G1510"\w* \w Tú|strong="G4771"\w*?   
\p
\v 13 \w Entonces|strong="G2532"\w* \w Jesús|strong="G2424"\w* \w tomó|strong="G2983"\w* \w el|strong="G3588"\w* pan \w y|strong="G2532"\w* \w el|strong="G3588"\w* pescado \w y|strong="G2532"\w* les \w dio|strong="G1325"\w*.   
\p
