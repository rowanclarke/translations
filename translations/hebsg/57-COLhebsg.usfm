\id COL
\h קולוסים
\toc1 אִגֶּרֶת פּוֹלוֹס הַשָּׁלִיחַ אֶל־הַקּוֹלַסִּים
\toc2 אִגֶּרֶת פּוֹלוֹס הַשָּׁלִיחַ אֶל־הַקּוֹלַסִּים
\toc3 קולוסים
\mt1 אִגֶּרֶת פּוֹלוֹס הַשָּׁלִיחַ אֶל־הַקּוֹלַסִּים
\c 1
\cp א
\cl פרק א
\p 
\v 1 \vp א\vp* פּוֹלוֹס שְׁלִיחַ יֵשׁוּעַ הַמָּשִׁיחַ בִּרְצוֹן הָאֱלֹהִים אֲנִי וְטִימוֹתִיּוֹס אָחִינוּ׃
\v 2 \vp ב\vp* אֶל־הַקְּדוֹשִׁים וְהָאַחִים הַנֶּאֱמָנִים בַּמָּשִׁיחַ ישְׁבֵי קוֹלַסָּא חֶסֶד וְשָׁלוֹם יִתֵּן לָכֶם אֱלֹהִים אָבִינוּ וַאֲדוֹנֵינוּ יֵשׁוּעַ הַמָּשִׁיחַ׃
\v 3 \vp ג\vp* הִנֵּה אֲנַחְנוּ מוֹדִים לֵאלֹהִים אֲבִי יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ ומִתְפַּלְּלִים בַּעַדְכֶם תָּמִיד׃
\v 4 \vp ד\vp* אַחֲרֵי אֲשֶׁר שָׁמַעְנוּ אֱמוּנַתְכֶם בְּיֵשׁוּעַ הַמָּשִׁיחַ וְאַהֲבַתְכֶם לְכָל־הַקְּדוֹשִׁים׃
\v 5 \vp ה\vp* בַּעֲבוּר הַתִּקְוָה הַצְּפוּנָה לָכֶם בַּשָּׁמָיִם אֲשֶׁר שְׁמַעְתֶּם מֵאָז מִפִּי אִמְרֵי אֱמֶת בַּבְּשׂרָה׃
\v 6 \vp ו\vp* אֲשֶׁר הוּבְאָה אֲלֵיכֶם כְּמוֹ גַם בְּכָל־הָאָרֶץ וּפֹרִיָּה וַעֲנֵפָה בַּאֲשֶׁר הִיא שָׁם כְּמוֹ גַם־בְּתוֹכֲכֶם לְמִן־הַיּוֹם אֲשֶׁר שְׁמַעְתֶּם וְיָדֹעַ יְדַעְתֶּם חֶסֶד אֱלֹהִים בֶּאֱמֶת׃
\v 7 \vp ז\vp* וְכַאֲשֶׁר גַּם־כֵּן לְמַדְתֶּם מִפִּי אֶפַּפְרָס יְדִידֵנוּ הָעֹבֵד עִמָּנוּ יַחְדָּו הוּא מְשָׁרֵת הַמָּשִׁיחַ נֶאֱמָן לִפְנֵיכֶם׃
\v 8 \vp ח\vp* וְהוּא הִגִּיד לָנוּ אֶת־אַהֲבַתְכֶם לְפִי הָרוּחַ׃
\v 9 \vp ט\vp* בַּעֲבוּר זֹאת גַּם־אֲנַחְנוּ מִן־הַיּוֹם אֲשֶׁר שָׁמַעְנוּ כָזֹאת לֹא חָדַלְנוּ מֵהִתְפַּלֵּל וּמֵהִתְחַנֵּן בַּעַדְכֶם כִּי תִמָּלְאוּ דַעַת רְצוֹן אֵל בְּכָל־חָכְמַה וּתְבוּנָה הָעֶלְיוֹנָה׃
\v 10 \vp י\vp* לְהִתְהַלֵּךְ כַּטּוֹב בְּעֵינֵי הָאָדוֹן לְכָל־חֵפֶץ לִבּוֹ לַעֲשׂוֹת פְּרִי בְּכָל־מַעֲשֶׂה טּוֹב וּלְהוֹסִיף דַּעַת אֱלֹהִים׃
\v 11 \vp יא\vp* לְהִתְאַזֵּר בְּכָל־עֹז כְּעֹז כְּבוֹדוֹ לְכָל־תּוֹחֶלֶת וְאֹרֶךְ רוּחַ בְּלֵב שָׂמֵחַ׃
\v 12 \vp יב\vp* וּלְהוֹדוֹת לְאָבִינוּ אֲשֶׁר הֱכִינָנוּ לָקַחַת חֵלֶק בְּנַחֲלַת קְדשָׁיו בְּמוֹ־אוֹר׃
\v 13 \vp יג\vp* וַאֲשֶׁר הִצִּיל אֶת־נַפְשֵׁנוּ מִמֶּמְשֶׁלֶת הַחֹשֶׁךְ וַיִתֶּן־לָנוּ מָקוֹם בְּמַמְלֶכֶת בְּנוֹ אֲשֶׁר אָהֵב׃
\v 14 \vp יד\vp* וּבוֹ נִמְצָא פְדוּת בְּדָמוֹ וּסְלִיחָה לְחַטֹּאתֵינוּ׃
\v 15 \vp טו\vp* וְהוּא צֶלֶם אֱלֹהִים אֲשֶׁר פָּנָיו לֹא יֵרָאוּ וּבְכוֹר כָּל־נִבְרָא׃
\v 16 \vp טז\vp* כִּי־בוֹ נִבְרְאוּ כֹּל אֲשֶׁר בַּשָּׁמַיִם וַאֲשֶׁר בָּאָרֶץ הַנִּגְלוֹת וְהַנִּסְתָּרוֹת אִם כִּסְאוֹת וּמֶמְשָׁלוֹת אוֹ כָל־מִשְׂרָה וְשִׁלְטוֹן כֻּלָּם בּוֹ וּלְמַעֲנוֹ נִבְרָאוּ׃
\v 17 \vp יז\vp* וְהוּא קַדְמוֹן לְכָל־דָּבָר וְעַל־פִּיו הֵם עֹמְדִים כֻּלָּם׃
\v 18 \vp יח\vp* הוּא רֹאשׁ הָעֵדָה אֲשֶׁר הִיא גְוִיָּתוֹ וְגַם־רֹאשׁ וּבְכוֹר שֶׁקָּם מִן־הַמֵּתִים לִהְיוֹתוֹ רִאשׁוֹן לַכֹּל׃
\v 19 \vp יט\vp* כִּי־כֵן רָצָה אֱלֹהִים אֲשֶׁר בּוֹ יִשְׁכֹּן מְלֹא הַכֹּל׃
\v 20 \vp כ\vp* וְכֵן עַל־יָדוֹ יַהֲפֹךְ לֵב כֻּלָּם לְהִתְרַצּוֹת אֵלָיו אַחֲרֵי אֲשֶׁר עַל־יָדוֹ בְּדַם הַצְּלָב עָשָׂה שָׁלוֹם לְכֻלָּם לְכָל־אֲשֶׁר בָּאָרץ וּלְכָל־אֲשֶׁר בַּשָּׁמָיִם׃
\v 21 \vp כא\vp* וְגַם־אַתֶּם אֲשֶׁר מוּזָרִים הֱיִיתֶם לְפָנִים וְאֹיְבִים מִמְּקוֹר הַלֵּב עֵקֶב מַעֲשֵׂיכֶם הָרָעִים׃
\v 22 \vp כב\vp* הָפַךְ עַתָּה אֶת־לִבְּכֶם לְהִתְרַצּוֹת אֵלָיו בְּעַצְמוֹ וּבִבְשָׂרוֹ בְּמוֹתוֹ לַהֲקִימְכֶם קְדֹשִׁים לְפָנָיו זַכִּים מֵעָוֹן וּנְקִיִּים מִכָּל־שֶׁמֶץ דָּבָר׃
\v 23 \vp כג\vp* רַק אִם־תַּעַמְדוּ מְיֻסָּדִים וְהָכֵן בָּאֱמוּנָה וְלֹא תַרְפּוּ מִתּוֹחֶלֶת הַבְּשׂרָה אֲשֶׁר שְׁמַעְתֶּם בְּאָזְנֵיכֶם וַאֲשֶׁר שׂוּמָה בְאָזְנֵי כָל־יְצוּר תַּחַת הַשָּׁמַיִם וַאֲנִי פוֹלוֹס הָיִיִתִי לָהּ לִמָשָׁרֵת׃
\v 24 \vp כד\vp* וְעַתָּה הִנְנִי שָׂמֵחַ בְּעָנְיִי כִּי אֶתְעַנֶּה בִּגְלַלְכֶם וְחֵלֶק הַנֶּעְדָּר מִן־חֶבְלֵי הַמָּשִׁיחַ אַשְׁלִים אֲנִי בִּבְשָׂרִי בְּעַד גְּוִיָּתוֹ הֲלֹא הִיא עֲדָתוֹ׃
\v 25 \vp כה\vp* אֲשֶׁר הָיִיתִי לָהּ לִמְשָׁרֵת כְּפִי־פְקֻדַּת אֱלֹהִים הַנְּתוּנָה לִי בָּעֲבוּרְכֶם לְמַלֹּאת אֶת־דְּבַר אֱלֹהִים׃
\v 26 \vp כו\vp* הוּא הַסּוֹד אֲשֶׁר צָפוּן הָיָה מֵעוֹלָם וּמִדּוֹר דּוֹר וְעַתָּה נִגְלָה לִקְדֹשָׁיו׃
\v 27 \vp כז\vp* כִּי־חָפֵץ אֱלֹהִים לְהוֹדִיעָם מָה רַב עשֶׁר וְכָבוֹד בַּסּוֹד הַזֶּה לַגּוֹיִם הֲלֹא הוּא הַמָּשִׁיחַ בְּתוֹכֲכֶם צְבִי כָל־חֶמְדָּה׃
\v 28 \vp כח\vp* אֲשֶׁר בְּשׂרָתוֹ אֲנַחְנוּ מְבַשְּׂרִים לְהַזְהִיר אֶת־כָּל־אִישׁ וּלְלַמְּדוֹ בִּלְבַב חָכְמָה עַד־אֲשֶׁר נַצִּיגֶנּוּ כְּאָדָם שָׁלֵם בַּמָּשִׁיחַ יֵשׁוּעַ׃
\v 29 \vp כט\vp* זֶה הוּא אֲשֶׁר בּוֹ אֲנִי עָמֵל וְעֹדֵר בְּלֹא לֵב וְלֵב כְּכֹחַ יָדוֹ הַחֲזָקָה עָלָי׃
\c 2
\cp ב
\cl פרק ב
\p 
\v 1 \vp א\vp* וַאֲנִי חָפַצְתִּי כִּי תֵדְעוּן מָה־רַבּוּ הַקְּרָבוֹת אֲשֶׁר עָרַכְתִּי בַּעַדְכֶם וּבְעַד־אַנְשֵׁי לוּדְקְיָא וּבְעַד־כֹּל אֲשֶׁר לֹא־רָאוּ אֹתִי פָּנִים בְּפָנִים׃
\v 2 \vp ב\vp* לְמַעַן יִמְצְאוּ נֹחַם בְּלִבָּם לִהְיוֹת קְשׁוּרִים בְּאַהֲבָתָם וּבְכָל־חֹסֶן אוֹר שִׂכְלָם יַשְׂכִּילוּ אֶל־נָכוֹן סוֹד הָאֱלֹהִים אָבִינוּ וְסוֹד הַמָּשִׁיחַ׃
\v 3 \vp ג\vp* אֲשֶׁר בּוֹ צְפוּנִים כָּל־אֹצְרוֹת הַחָכְמָה וְהַדָּעַת׃
\v 4 \vp ד\vp* וְכָזֹאת אֲנִי אֹמֵר פֶּן־יַדִּיחַ אֶתְכֶם אִישׁ בְּשִׂפְתֵי חֲלָקוֹת׃
\v 5 \vp ה\vp* כִּי אַף־אִם בִּבְשָׂרִי רָחוֹק אֲנִי מִכֶּם בְּכָל־זֹאת בְּרוּחִי הִנְנִי אֶצְלְכֶם וְנַפְשִׁי שְׂמֵחָה לִרְאוֹת סֵדֶר הֲלִיכוֹתֵיכֶם וְתֹקֶף אֱמוּנַתְכֶם בַּמָּשִׁיחַ׃
\v 6 \vp ו\vp* עַל־כֵּן כַּאֲשֶׁר קִבַּלְתֶּם אֵת הַמָּשִׁיחַ אֶת־יֵשׁוּעַ אֲדֹנֵינוּ כֵּן־גַּם־תִּתְהַלְּכוּ לְפָנָיו׃
\v 7 \vp ז\vp* מַשְׁרִישִׁים וּבְנוּיִם בּוֹ לַעֲמֹד הָכֵן בָּאֱמוּנָה כַּאֲשֶׁר לֻמַּדְתֶּם וְלַעֲשׂוֹת חַיִל בְּאִמְרֵי תוֹדָה׃
\v 8 \vp ח\vp* הִשָּׁמְרוּ לָכֶם פֶּן־תִּהְיוּ לְשָׁלָל לְמֶחְקְרֵי אִישׁ בְּמַשְׂאוֹת שָׁוְא לְפִי מִצְוַת אֲנָשִׁים מְלֻמָּדָה כְּדֶרֶךְ הָעוֹלָם וְלֹא כְדֶרֶךְ הַמָּשִׁיחַ׃
\v 9 \vp ט\vp* כִּי כָל־מְלֹא אֱלֹהִים שָׁכֵן בְּתוֹכוֹ כְּמוֹ בְּתוֹךְ גְּוִיָּה׃
\v 10 \vp י\vp* וְאַתֶּם מְמֻלָּאִים בּוֹ אֲשֶׁר הוּא הָרֹאשׁ לְכָל־מִשְׂרָה וְשִׁלְטוֹן׃
\v 11 \vp יא\vp* וְגַם־בּוֹ נְמֻלתֶם לֹא בְמוּלַת מְלֶאכֶת יָד כִּי אִם־בַּהֲסִירְכֶם אֶת־גְּוִיַּת הַבָּשָׂר הַחוֹטֵא הֲלֹא הִיא בְרִית הַמּוּלוֹת לַמָּשִׁיחַ׃
\v 12 \vp יב\vp* אֲשֶׁר נִקְבַּרְתֶּם עִמּוֹ בַטְּבִילָה וְכֵן גַּם־עִמּוֹ קַמְתֶּם עַל־יְדֵי אֱמוּנַתְכֶם בִּגְבוּרַת אֱלֹהִים אֲשֶׁר הֲקִימוֹ מִן־הַמֵּתִים׃
\v 13 \vp יג\vp* וְאַתֶּם אֲשֶׁר מֵתִים הֱיִיתֶם בְּפִשְׁעֵיכֶם וּבְעָרְלַת בָּשָׂר הֶחֱיָה גַם־אֶתְכֶם עִמּוֹ כִּי סָלַח לְכֹל פְּשָׁעֵינוּ׃
\v 14 \vp יד\vp* וְאֶת־סֵפֶר חֹבֵנוּ הוּא סֵפֶר הַחֻקִּים אֲשֶׁר עָנָה בָנוּ מָחָה וְהָגוֹ מִן־הַמְּסִלָּה וַיִּתְקָעֵהוּ בַּצְּלָב׃
\v 15 \vp טו\vp* וַיַּפְשֵׁט שָׂרֵי צְבָאוֹת וְשַׁלִּיטֵי תֵבֵל וְנֶגֶד הַשֶּׁמֶשׁ נְתָנָם לְרַאֲוָה בָּם וְשָׁם גָּאֹה גָּאָה עֲלֵיהֶם׃
\v 16 \vp טז\vp* עַל־כֵּן אֵין לְאִישׁ לְהַרְשִׁיעַ אֶתְכֶם עוֹד עַל־דְּבַר מַאֲכָל וּמַשְׁקֶה אוֹ עַל־דְּבַר מוֹעֵד רֹאשׁ חֹדֶשׁ אוֹ שַׁבָּת׃
\v 17 \vp יז\vp* כִּי־הֵם רַק־צְלָלִים לַדְּבָרִים אֲשֶׁר הִתְעַתְּדוּ לָבוֹא וּמְקוֹרָם הוּא בַּמָּשִׁיחַ׃
\v 18 \vp יח\vp* אַל־יָעֹז אִישׁ לְהַחֲלִיף אֶת־מַשְׂכֻּרְתְּכֶם כִּי יִתְאַמֵּר בְּשִׁפְלוּת רוּחַ וְנָתוֹן כָּבוֹד לַמַּלְאָכִים וְעֹמֵד בִּדְבָרִים אֲשֶׁר לֹא רָאוּ עֵינָיו וּמִתְנַשֵּׂא לַשָּׁוְא בְּעֶשְׁתֹּנוֹת בָּשָׂר׃
\v 19 \vp יט\vp* וְאֵינֶנּוּ מַחֲזִיק בָּרֹאשׁ אֲשֶׁר מְקֻשָּׁר בּוֹ כָּל־הַגּוּף בִּפְרָקָיו וּמֵיתָרָיו וּמִמֶּנּוּ יִמְצָא אוֹן־לוֹ וְיִגְדַּל כַּאֲשֶׁר יְגַדְּלֶנּוּ אֱלֹהִים׃
\v 20 \vp כ\vp* לָכֵן אִם־מַתֶּם עִם־הַמָּשִׁיחַ בַּעֲזָבְכֶם יְסוֹדוֹת הָעוֹלָם לָמָּה־זֶּה בְּעוֹדְכֶם חַיִּים בָּעוֹלַם תּוֹאִילוּ לֶכֶת אַחֲרֵי־צָו לֵאמֹר׃
\v 21 \vp כא\vp* לֹא תִקְרַב הֲלֹם לֹא תִטְעַם לֹא תִגָּע׃
\v 22 \vp כב\vp* וְהֵם כֻּלָּם חֻקִּים עֹשֵׂיהֶם לֹא יִחְיוּ בָהֶם כְּמִצְוַת וְחֻקֵּיהֶם׃
\v 23 \vp כג\vp* אֲשֶׁר לָהֶם מַרְאֵה פְנֵי הַחָכְמָה מִחוּץ בְּיִרְאַת אֱלֹהִים וּבְשִׁפְלוּת רוּחַ וּלְעַנּוֹת אֶת־גּוּפָם כַּאֲשֶׁר בָּדְאוּ מִלִּבָּם וְכָל־אֵלֶּה לֹא לְכָבוֹד לָהֶם כִּי אִם־בְּשָׂרָם יִמְצָא חֵפֶץ בָּמוֹ׃
\c 3
\cp ג
\cl פרק ג
\p 
\v 1 \vp א\vp* וְעַתָּה אִם־קַמְתֶּם עִם־הַמָּשִׁיחַ בַּקְּשׁוּ אֵת אֲשֶׁר לְמָעְלָה אֲשֶׁר שָׁם הַמָּשִׁיחַ יֹשֵׁב לִימִין אֱלֹהִים׃
\v 2 \vp ב\vp* שִׂימוּ לִבְּכֶם לַאֲשֶׁר מֵעָל וְלֹא לַאֲשֶׁר בָּאָרֶץ׃
\v 3 \vp ג\vp* כִּי־מֵתִים אַתֶּם וְחַיֵּיכֶם צְפוּנִים עִם־הַמָּשִׁיחַ בֵּאלֹהִים׃
\v 4 \vp ד\vp* וְכַאֲשֶׁר יוֹפִיעַ הַמָּשִׁיחַ אֲשֶׁר הוּא חַיֵּינוּ אָז גַּם־אַתֶּם תּוֹפִיעוּ עִמּוֹ בִּכְבוֹדוֹ׃
\v 5 \vp ה\vp* עַל־כֵּן הַכְחִידוּ כְּלֵי תַאֲוַתְכֶם בָּאָרֶץ זְנוּנִים שִׁקּוּצִים וּתְשׁוּקוֹת זָרוֹת יֵצֶר רָע וְאַהֲבַת בֶּצַע אֲשֶׁר דָּמְתָה לַעֲבֹדַת אֱלִילִים׃
\v 6 \vp ו\vp* כִּי בִגְלַל אֵלֶּה שְׁפוּכָה חֲמַת אֱלֹהִים עַל־בְּנֵי הַמֶּרִי׃
\v 7 \vp ז\vp* וְגַם־אַתֶּם לְפָנִים כַּאֲשֶׁר יְשַׁבְתֶּם בְּתוֹכָם כֵּן הֲלַכְתֶּם בְּדַרְכֵיהֶם׃
\v 8 \vp ח\vp* אַךְ־עַתָּה הָסִירוּ כָל־אֵלֶּה מֵעֲלֵיכֶם גַּם־אַתֶּם זַעַף וְעֶבְרָה וְרִשְׁעָה וַחֲרָפוֹת וְדִבְרֵי נְבָלָה מִפִּיכֶם׃
\v 9 \vp ט\vp* אַל־תְּשַׁקְּרוּ אִישׁ בַּעֲמִיתוֹ אַחֲרֵי אֲשֶׁר פְּשַׁטְתֶּם אֶת־הָאָדָם הַקַּדְמֹנִי עִם־פְּעָלָיו׃
\v 10 \vp י\vp* וּלְבַשְׁתֶּם אֶת־הָאָדָם הֶחָדָשׁ הוּא אֲשֶׁר הִתְחַדֵּשׁ בְּדַעַת כְּצֶלֶם יֹצְרוֹ׃
\v 11 \vp יא\vp* אֲשֶׁר אֵין־בּוֹ יְוָנִי אוֹ יְהוּדִי נִמּוֹל אוֹ עָרֵל נִלְעַג לָשׁוֹן פֶּרֶא אָדָם עֶבֶד אוֹ בֶן־חוֹרִים כִּי הַכֹּל וּבַכֹּל הוּא הַמָּשִׁיחַ׃
\v 12 \vp יב\vp* וְאַתֶּם כִּבְחִירֵי הָאֱלֹהִים כִּקְדֹשָׁיו וִידִידָיו לִבְשׁוּ רַחֲמִים וַחֲסָדִים מִמְּקוֹר לִבְּכֶם רוּחַ שְׁפָלָה עֲנָוָה וְאֹרֶךְ אַפָּיִם׃
\v 13 \vp יג\vp* לָשֵׂאת אִישׁ אֶת־פְּנֵי רֵעֵהוּ וְלִסְלֹחַ לוֹ לִדְבַר רִיב כִּי־יִמָּצֵא בֵינֵיכֶם וּכְמוֹ אֲדֹנֵינוּ סָלַח לָכֶם כֵּן תִּסְלְחוּ גַּם־אַתֶּם׃
\v 14 \vp יד\vp* וְעַל־כָּל־אֵלֶּה לִבְשׁוּ אַהֲבָה אֲשֶׁר הִיא אֲגֻדַּת הַתְּמִימִים׃
\v 15 \vp טו\vp* וּשְׁלוֹם הָאֱלֹהִים אֲשֶׁר־נִבְחַרְתֶּם לוֹ בְּגוּף אֶחָד יִמְשֹׁל בְּקֶרֶב לִבְּכֶם וְאֶת־טוּבוֹ תַּכִּירוּ׃
\v 16 \vp טז\vp* וְתוֹרַת הַמָּשִׁיחַ תִּהְיֶה בְפִיכֶם תָּמִיד בְּכָל־חָכְמָה לְלַמֵּד וּלְעוֹרֵר אִישׁ אֶת־אָחִיהוּ בִּתְהִלּוֹת וְשִׁירוֹת וְזִמְרוֹת־יָהּ וּמִקֶּרֶב לִבְּכֶם תָּשִׁירוּ לֵאלֹהִים בְּתוֹדָה׃
\v 17 \vp יז\vp* וְכֹל אֲשֶׁר־תַּעֲשׂוּ גַּם־בִּדְבַר שְׂפָתַיִם גַּם־בְּמַעֲשֵׂה יָדָיִם עָשׂוּ כֹל בְּשֵׁם יֵשׁוּעַ אֲדֹנֵינוּ וּלְהֹדוֹת עַל־יָדוֹ לֵאלֹהִים אָבִינוּ׃
\v 18 \vp יח\vp* וְאַתֵּנָה נָשִׁים הִכָּנַעְנָה לְבַעֲלֵיכֶן כַּמִּשְׁפָּט לִפְנֵי אֲדֹנֵינוּ׃
\v 19 \vp יט\vp* בַּעֲלֵי אִשָּׁה אֶהֱבוּ אֶת־נְשֵׁיכֶם וְלֹא תִהְיוּ לָהֶן לְמֹרַת רוּחַ׃
\v 20 \vp כ\vp* שִׁמְעוּ בָנִים אֶל־יֹלְדֵיכֶם לְכֹל אֲשֶׁר יֹאמֵרוּן כִּי לְרָצוֹן הוּא לַאֲדֹנֵנוּ׃
\v 21 \vp כא\vp* אָבוֹת אַל־תַּכְעִיסוּ אֶת־בְּנֵיכֶם פֶּן־יֹאמְרוּ נוֹאָשׁ׃
\v 22 \vp כב\vp* וְאַתֶּם עֲבָדִים שִׁמְעוּ אֶל־אֲדֹנֵיכֶם אֲדֹנֵי הַבָּשָׂר לְכֹל אֲשֶׁר יֹאמֵרוּן וְלֹא בַעֲבֹדָה לְמַרְאֵה עֵינַיִם לְהָפִיק רָצוֹן מִבְּנֵי אָדָם כִּי אִם־בְּתָם־לֵב כְּיִרְאֵי יְהוָֹה׃
\v 23 \vp כג\vp* וְכֹל אֲשֶׁר תַּעֲשׂוּ עֲשׂוּ בְכָל־נַפְשְׁכֶם כְּמוֹ לַיהוָֹה וְלֹא לִבְנֵי־אָדָם׃
\v 24 \vp כד\vp* הֵן יְדַעְתֶּם כִּי מֵאֵת יְהוָֹה תִּקְחוּ שְׂכַרְכֶם וְנַחֲלַתְכֶם כִּי אֶת־אֲדֹנֵינוּ הַמָּשִׁיחַ אַתֶּם עֹבְדִים׃
\v 25 \vp כה\vp* כִּי הַמְעַוֵּל יִקְצָר־עָוֶל כַּאֲשֶׁר עָשָׂה וְאֵין מַשּׂוֹא פָנִים׃
\c 4
\cp ד
\cl פרק ד
\p 
\v 1 \vp א\vp* וְגַם־אַתֶּם אֲדֹנִים בְּצֶדֶק וּבְמִשְׁפָּט תַּעֲבִידוּן אֶת־עַבְדֵיכֶם הֲלֹא יְדַעְתֶּם כִּי גַם־לָכֶם אָדוֹן בַּשָּׁמָיִם׃
\v 2 \vp ב\vp* הִתְעוֹרְרוּ לִהִתְפַּלֵּל תָּמִיד וְשִׁקְדוּ לְהַעְתִּיר בְּתוֹדָה׃
\v 3 \vp ג\vp* וְחַלּוּ אֶת־פְּנֵי הָאֱלֹהִים גַּם־בַּעֲדֵנוּ לִפְתֹּחַ לָנוּ שַׁעַר לְנִיב שְׂפָתֵינוּ לְגַלּוֹת סוֹד הַמָּשִׁיחַ אֲשֶׁר בִּגְלָלוֹ אָסוּר אָנִי׃
\v 4 \vp ד\vp* לְמַעַן יִוָּדַע לַכֹּל כַּאֲשֶׁר אַבִּיעַ כַּמִּשְׁפָּט׃
\v 5 \vp ה\vp* הִתִהַלְּכוּ בִתְבוּנָה בְּקֶרֶב אֵלֶּה אֲשֶׁר מִחוּץ לַעֲדָתֵנוּ וּזְבַנוּ יַת־עִדָּנָא׃
\v 6 \vp ו\vp* יְהִי דְבַרְכֶם מָהוּל בְּחֵן כְּמוֹ מְמֻלָּח בַּמֶּלַח וְתֵדְעוּ לְהָשִׁיב נְכֹחוֹת לְכָל־אִישׁ וָאִישׁ׃
\v 7 \vp ז\vp* עַל־דְּבַר מַעֲמָדִי הֲלֹא טוּכִיקוֹס יַגִּיד לָכֶם הַכֹּל הוּא אָח אָהוּב וּמְשָׁרֵת נֶאֱמָן גֶּבֶר עֲמִיתִי וְעֶבֶד לַאֲדֹנֵינוּ׃
\v 8 \vp ח\vp* כִּי לַדָּבָר הַזֶּה שְׁלַחְתִּיו אֲלֵיכֶם לָדַעַת אֶת־שְׁלוֹמֵנוּ וּלְדַבֵּר נִחֻמִים עַל־לִבְּכֶם׃
\v 9 \vp ט\vp* וְעִמּוֹ גַּם־אוֹנִיסִימוֹס בֶּן־אַרְצְכֶם אָח נֶאֱמָן וְיַקִּיר לִי הֵמָּה יוֹדִיעוּ אֶתְכֶם כָּל־אֲשֶׁר נַעֲשָׂה פֹּה׃
\v 10 \vp י\vp* אֲרִיסְטַרְכוֹס אֲשֶׁר הוּא עָצוּר עִמָּדִי שֹׁאֵל לִשְׁלוֹמְכֶם גַּם־מַרְקוֹס בֶּן־אֲחוֹת בַּר־נַבָּא אֲשֶׁר נִדְרַשְׁתֶּם לְקַבֵּל פָּנָיו בְּבוֹאוֹ׃
\v 11 \vp יא\vp* וְגַם־יֵשׁוּעַ הַנִּקְרָא בְשֵׁם יוּסְטוֹס אֲשֶׁר הֵם מִן־הַנִּמּוֹלִים הֵם לְבַדָּם תָּמְכוּ בְיָדִי בְּמַלְכוּת הָאֱלֹהִים וַיָּשִׁיבוּ אֶת־נַפְשִׁי׃
\v 12 \vp יב\vp* אֶפַּפְרָס בֶּן־אַרְצְכֶם וְעֶבֶד יֵשׁוּעַ הַמָּשִׁיחַ שֹׁאֵל לִשְׁלוֹמְכֶם הוּא אֲשֶׁר גָּבַר בִּתְפִלּוֹתָיו בְּכָל־עֵת לְהַעֲמִידְכֶם לִפְנֵי הָאֱלֹהִים שְׁלֵמִים וּמְמֻלָּאִים בִּמְלֹא חֶפְצוֹ׃
\v 13 \vp יג\vp* כִּי עֵד אֲנִי לוֹ אֲשֶׁר קִנְאָתוֹ גָדְלָה לָכֶם וּלְיֹשְׁבֵי לוּדְקְיָא וּלְיֹשְׁבֵי הִירַפּוֹלִיס׃
\v 14 \vp יד\vp* יְדִידֵנוּ לוּקָס הָרֹפֵא וְדִימָס שֹׁאֲלִים לִשְׁלוֹמְכֶם׃
\v 15 \vp טו\vp* שַׁאֲלוּ לִשְׁלוֹם אַחֵינוּ אֲשֶׁר בְּלוּדְקְיָא וְלִשְׁלוֹם נוּמְפָס וְהַקָּהָל אֲשֶׁר בְּבֵיתָם׃
\v 16 \vp טז\vp* אַחֲרֵי קְרִיאַת הָאִגֶּרֶת הַזֹּאת בְּאָזְנֵיכֶם תְּנוּהָ לְהִקָּרֵא גַּם־בְּאָזְנֵי קְהַל לוּדְקְיָא וְהָאִגֶּרֶת אֲשֶׁר לְלוּדְקְיָא תִּקְרְאוּ בָהּ גַּם־אַתֶּם׃
\v 17 \vp יז\vp* וְאִמְרוּ אֶל־אַרְכִפּוֹס זָכוֹר אֶת־מִשְׁמֶרֶת הַכְּהֻנָּה אֲשֶׁר לָקַחְתָּ מִלִּפְנֵי הָאָדוֹן לְמַלֹּאתָהּ׃
\v 18 \vp יח\vp* זֹאת שְׁאֵלַת שָׁלוֹם בִּכְתָב יָדִי אֲנִי פוֹלוֹס זִכְרוּ לְמוֹסֵרָי וְחֶסֶד אֵל עִמָּכֶם אָמֵן׃ 
