\p
\v 1  \w So|strong="H3381"\w* \w David|strong="H1732"\w* \w left|strong="H8033"\w* \w there|strong="H8033"\w* \w and|strong="H3212"\w* \w escaped|strong="H4422"\w* \w to|strong="H3381"\w* \w the|strong="H3605"\w* \w cave|strong="H4631"\w* \w of|strong="H1004"\w* \w Adullam|strong="H5725"\w*. \w When|strong="H8085"\w* \w his|strong="H3605"\w* brothers \w and|strong="H3212"\w* \w the|strong="H3605"\w* rest \w of|strong="H1004"\w* \w his|strong="H3605"\w* father’s \w family|strong="H1004"\w* learned \w about|strong="H8085"\w* \w it|strong="H3381"\w*, \w they|strong="H8033"\w* \w went|strong="H3212"\w* \w down|strong="H3381"\w* \w there|strong="H8033"\w* \w to|strong="H3381"\w* \w him|strong="H3381"\w*.  
