\q1
\v 21 Tigua i̱hondo bi hongo howa ladagadaga bialu lalu,  
\q2 Heneneore í̠na ko birigo ina handarima, lalu haga ka.   
\q1
\v 22 Anduane Homogo-o tigua ani biyaruni í̠ de handarigo  
\q2 í̠na bi nale nahabe.  
\q1 Anduane Homogo í̠na i̱ helalu kaundiaha nahabe laro.   
\q1
\v 23 Anduane Homogo-o í̠ore abale heyalu  
\q2 i̱ biamogo bule ibabe.  
\q1 I̱naga Ngode Datagaliwabe-o í̠ heyalu  
\q2 i̱na bi lalu koru mo hongo halu lahabe.   
