\id SNG - Biblica® Open God’s Word in Contemporary Chichewa 2016 
\h NYIMBO YA SOLOMONI 
\toc1 Nyimbo ya Solomoni 
\toc2 Nyimbo ya Solomoni 
\toc3 Nyi 
\mt1 Nyimbo ya Solomoni 
\c 1  
\p  
\v 1 Nyimbo ya Solomoni, nyimbo yoposa nyimbo zonse. 
\b  
\sp Mkazi 
\q1  
\v 2 Undipsompsone ndi milomo yako 
\q2 chifukwa chikondi chako nʼchokoma kuposa vinyo. 
\q1  
\v 3 Mafuta ako odzola ndi onunkhira bwino; 
\q2 dzina lako lili ngati mafuta onunkhira otsanulidwa. 
\q2 Nʼchifukwa chake atsikana amakukonda! 
\q1  
\v 4 Nditenge ndipo ndizikutsata, tiye tifulumire! 
\q2 Mfumu indilowetse mʼchipinda chake. 
\sp Abwenzi 
\q1 Ife timasangalala ndi kukondwera nawe, 
\q2 tidzatamanda chikondi chako kupambana vinyo. 
\sp Mkazi 
\q1 Amachita bwinotu potamanda iwe! 
\b  
\q1  
\v 5 Ndine wakuda, komatu ndine wokongola, 
\q2 inu akazi a ku Yerusalemu, 
\q2 ine ndine wakuda ngati tenti ya ku Kedara, 
\q2 ngati makatani a tenti ya Solomoni. 
\q1  
\v 6 Musandiyangʼane monyoza chifukwa ndine wakuda, 
\q2 ndine wakuda chifukwa cha dzuwa. 
\q1 Alongo anga anandikwiyira 
\q2 ndipo anandigwiritsa ntchito mʼminda ya mpesa; 
\q2 munda wangawanga sindinawusamalire. 
\q1  
\v 7 Ndiwuze iwe, amene ndimakukonda, kumene umadyetsa ziweto zako 
\q2 ndi kumene umagoneka nkhosa zako nthawi yamasana. 
\q1 Ndikhalirenji ngati mkazi wachiwerewere 
\q2 pambali pa ziweto za abwenzi ako? 
\sp Abwenzi 
\q1  
\v 8 Ngati sukudziwa iwe wokongola kwambiri kuposa akazi ena, 
\q2 ngati sukudziwa, tsatira makwalala a nkhosa 
\q1 ndipo udyetse ana ambuzi 
\q2 pambali pa matenti a abusa. 
\sp Mwamuna 
\q1  
\v 9 Iwe bwenzi langa, 
\q2 uli ngati kavalo wamkazi ku magaleta a Farao. 
\q1  
\v 10 Masaya ako ndi okongola ndi ndolo zamʼmakutuzo, 
\q2 khosi lako likukongola ndi mikanda yamiyala yamtengowapatali. 
\q1  
\v 11 Tidzakupangira ndolo zagolide 
\q2 zokongoletsedwa ndi mikanda yasiliva. 
\sp Mkazi 
\q1  
\v 12 Pamene mfumu inali pa malo ake odyera, 
\q2 mafuta anga onunkhira anamveka fungo lake. 
\q1  
\v 13 Wokondedwa wanga ali ngati kathumba ka mure kwa ine, 
\q2 kamene kamakhala pakati pa mawere angawa. 
\q1  
\v 14 Wokondedwa wanga ali ngati mpukutu wa maluwa ofiira, 
\q2 ochokera ku minda ya mpesa ya ku Eni-Gedi. 
\sp Mwamuna 
\q1  
\v 15 Iwe wokondedwa wanga, ndiwe wokongoladi! 
\q2 Ndithu, ndiwe chiphadzuwa, 
\q2 maso ako ali ngati nkhunda. 
\sp Mkazi 
\q1  
\v 16 Iwe bwenzi langa, ndiwe wokongoladi! 
\q2 Ndithu, ndiwe wokongoladi kwambiri! 
\q2 Ndipo malo athu ogonapo ndi msipu wobiriwira. 
\sp Mwamuna 
\q1  
\v 17 Mitanda ya nyumba yathu ndi ya mkungudza, 
\q2 phaso lake ndi la mtengo wa payini. 
\c 2  
\sp Mkazi 
\q1  
\v 1 Ine ndine duwa la ku Saroni, 
\q2 duwa lokongola la ku zigwa. 
\sp Mwamuna 
\q1  
\v 2 Monga duwa lokongola pakati pa minga 
\q2 ndi momwe alili wokondedwa wanga pakati pa atsikana. 
\sp Mkazi 
\q1  
\v 3 Monga mtengo wa apulosi pakati pa mitengo ya mʼnkhalango 
\q2 ndi momwe alili bwenzi langa pakati pa anyamata. 
\q1 Ndimakondwera kukhala pansi pa mthunzi wako, 
\q2 ndipo chipatso chake ndi chokoma mʼkamwa mwanga. 
\q1  
\v 4 Iye wanditengera ku nyumba yaphwando, 
\q2 ndipo mbendera yake yozika pa ine ndi chikondi. 
\q1  
\v 5 Undidyetse keke ya mphesa zowuma, 
\q2 unditsitsimutse ndi ma apulosi, 
\q2 pakuti chikondi chandifowoketsa. 
\q1  
\v 6 Mutu wanga watsamira dzanja lake lamanzere, 
\q2 ndipo dzanja lake lamanja landikumbatira. 
\q1  
\v 7 Inu akazi a ku Yerusalemu, ndithu ndikukupemphani 
\q2 pali gwape ndi mbawala yayikazi zakuthengo: 
\q1 Musachigwedeze chikondi kapena kuchiutsa 
\q2 mpaka pamene chifunire ichocho. 
\b  
\q1  
\v 8 Tamverani bwenzi langa! 
\q2 Taonani! Uyu akubwera apayu, 
\q1 akulumphalumpha pa mapiri, 
\q2 akujowajowa pa zitunda. 
\q1  
\v 9 Bwenzi langa ali ngati gwape kapena mwana wa mbawala. 
\q2 Taonani! Uyo wayima kuseri kwa khoma lathulo, 
\q1 akusuzumira mʼmazenera, 
\q2 akuyangʼana pa mpata wa zenera. 
\q1  
\v 10 Bwenzi langa anayankha ndipo anati kwa ine, 
\q2 “Dzuka bwenzi langa, 
\q2 wokongola wanga, ndipo tiye tizipita. 
\q1  
\v 11 Ona, nyengo yozizira yatha; 
\q2 mvula yatha ndipo yapitiratu. 
\q1  
\v 12 Maluwa ayamba kuoneka pa dziko lapansi; 
\q2 nthawi yoyimba yafika, 
\q1 kulira kwa njiwa kukumveka 
\q2 mʼdziko lathu. 
\q1  
\v 13 Mtengo wankhuyu ukubereka zipatso zake zoyambirira; 
\q2 mitengo ya mpesa ya maluwa ikutulutsa fungo lake. 
\q1 Dzuka bwenzi langa, wokongola wanga 
\q2 tiye tizipita.” 
\sp Mwamuna 
\q1  
\v 14 Nkhunda yanga yokhala mʼmingʼalu ya thanthwe, 
\q2 mʼmalo obisala a mʼmbali mwa phiri, 
\q1 onetsa nkhope yako, 
\q2 nʼtamvako liwu lako; 
\q1 pakuti liwu lako ndi lokoma, 
\q2 ndipo nkhope yako ndi yokongola. 
\q1  
\v 15 Mutigwirire nkhandwe, 
\q2 nkhandwe zingʼonozingʼono 
\q1 zimene zikuwononga minda ya mpesa, 
\q2 minda yathu ya mpesa imene yayamba maluwa. 
\sp Mkazi 
\q1  
\v 16 Bwenzi langa ndi wangadi ndipo ine ndine wake; 
\q2 amadyetsa gulu lake la ziweto pakati pa maluwa okongola. 
\q1  
\v 17 Kamphepo kamadzulo kakayamba kuwuzira 
\q2 ndipo mithunzi ikayamba kuthawa, 
\q1 unyamuke bwenzi langa, 
\q2 ndipo ukhale ngati gwape 
\q1 kapena ngati mwana wa mbawala 
\q2 pakati pa mapiri azigwembezigwembe. 
\c 3  
\q1  
\v 1 Usiku wonse ndili pa bedi langa 
\q2 ndinafunafuna amene mtima wanga umamukonda; 
\q2 ndinamufunafuna koma osamupeza. 
\q1  
\v 2 Ndikudzuka tsopano ndipo ndidzayendayenda mu mzinda, 
\q2 mʼmisewu yake ndi mʼmabwalo ake; 
\q1 ndidzamufunafuna amene mtima wanga umamukonda. 
\q2 Kotero ine ndinamufunafuna iyeyo koma osamupeza. 
\q1  
\v 3 Alonda anandipeza 
\q2 pamene ankayendera mzinda. 
\q2 “Kodi mwamuonako amene mtima wanga umamukonda?” 
\q1  
\v 4 Nditawapitirira pangʼono 
\q2 ndinamupeza amene mtima wanga umamukonda. 
\q1 Ndinamugwira ndipo sindinamulole kuti achoke 
\q2 mpaka nditamulowetsa mʼnyumba ya amayi anga, 
\q2 mʼchipinda cha amene anandibereka. 
\q1  
\v 5 Inu akazi a ku Yerusalemu, ndithu ndikukupemphani 
\q2 pali gwape ndi mbawala yayikazi zakuthengo: 
\q1 Musachigwedeze chikondi kapena kuchiutsa 
\q2 mpaka pamene chifunire ichocho. 
\b  
\q1  
\v 6 Kodi ndani amene akubwera kuchokera ku chipululu 
\q2 ngati utsi watolotolo, 
\q1 wonunkhira mure ndi lubani, 
\q2 zopangidwa kuchokera ku zonunkhira zonse za anthu amalonda? 
\q1  
\v 7 Ona! Chimenecho ndi chonyamulira Solomoni, 
\q2 choperekezedwa ndi asilikali 60, 
\q2 anthu amphamvu a ku Israeli, 
\q1  
\v 8 onse atanyamula lupanga, 
\q2 onse odziwa bwino nkhondo, 
\q1 aliyense ali ndi lupanga pambali pake, 
\q2 kukonzekera zoopsa za usiku. 
\q1  
\v 9 Mfumu Solomoni anadzipangira chonyamulirachi; 
\q2 anachipanga ndi matabwa ochokera ku Lebanoni. 
\q1  
\v 10 Milongoti yake anayipanga yasiliva, 
\q2 kumbuyo kwake kwa golide. 
\q1 Mipando yake inakutidwa ndi nsalu yapepo, 
\q2 anakongoletsa mʼkati mwake ndi chikondi 
\q2 cha akazi a ku Yerusalemu. 
\q1  
\v 11 Tukulani inu akazi a ku Ziyoni 
\q2 ndipo mudzaone mfumu Solomoni atavala chipewa chaufumu, 
\q2 chipewa chaufumu chimene amayi ake anamuveka 
\q1 pa tsiku la ukwati wake, 
\q2 tsiku limene mtima wake unasangalala. 
\c 4  
\sp Mwamuna 
\q1  
\v 1 Ndiwe wokongoladi wokondedwa wanga! 
\q2 Ndithudi, ndiwe wokongola! 
\q2 Maso ako ali ngati nkhunda kumbuyo kwa nsalu yophimba kumutu. 
\q1 Tsitsi lako lili ngati gulu la mbuzi 
\q2 zikutsetsereka kuchokera ku Giliyadi. 
\q1  
\v 2 Mano ako ali ngati gulu la nkhosa zomwe zangometedwa kumene, 
\q2 zochokera kozisambitsa kumene. 
\q1 Iliyonse ili ndi ana amapasa; 
\q2 palibe imene ili yokha. 
\q1  
\v 3 Milomo yako ili ngati mbota yofiira; 
\q2 pakamwa pako ndi pokongola kwambiri. 
\q1 Kukhalira kumbuyo kwa nsalu yako yophimba 
\q2 kumutuyo, masaya ako akuoneka ngati mabandu a makangadza. 
\q1  
\v 4 Khosi lako lili ngati nsanja ya Davide, 
\q2 yomangidwa bwino ndi yosalala; 
\q1 pa nsanja imeneyo pali zishango 1,000, 
\q2 zishango zonsezo za anthu ankhondo. 
\q1  
\v 5 Mawere ako ali ngati tiana tiwiri ta nswala, 
\q2 ngati ana amapasa a nswala 
\q2 amene akudya pakati pa maluwa okongola. 
\q1  
\v 6 Kamphepo kamadzulo kakayamba kuwuzira 
\q2 ndipo mithunzi ikayamba kuthawa, 
\q1 ndidzapita ku phiri la mure 
\q2 ndi ku chitunda cha lubani. 
\q1  
\v 7 Ndiwe wokongola kwambiri wokondedwa wanga; 
\q2 palibe chilema pa iwe. 
\b  
\q1  
\v 8 Tiye tichoke ku Lebanoni iwe mkwatibwi wanga, 
\q2 tiye tichoke ku Lebanoni, 
\q1 utsikepo pa msonga ya Amana, 
\q2 kuchoka pa msonga ya phiri la Seniri, pamwamba penipeni pa Herimoni, 
\q1 kuchoka ku mapanga a mikango 
\q2 ndiponso kumapiri kumene akambuku amavutitsa. 
\q1  
\v 9 Iwe mlongo wanga, mkwatibwi wanga, wanditenga mtima, 
\q2 iwe wanditenga mtima 
\q1 ndi kapenyedwe ka maso ako, 
\q2 ndiponso ndi umodzi mwa mikanda ya mʼkhosi mwako. 
\q1  
\v 10 Iwe mlongo wanga, mkwatibwi wanga, chikondi chako nʼchosangalatsa! 
\q2 Chikondi chako nʼchosangalatsa kwambiri kupambana vinyo, 
\q2 ndiponso fungo la mafuta ako ndi lopambana zonunkhiritsa zonse! 
\q1  
\v 11 Iwe mkwatibwi wanga, milomo yako ikuchucha uchi ngati chisa cha njuchi; 
\q2 pansi pa lilime lako pali mkaka ndi uchi. 
\q2 Fungo lonunkhira la zovala zako likumveka ngati fungo la ku Lebanoni. 
\q1  
\v 12 Iwe mlongo wanga, mkwatibwi wanga, ndiwe munda wopiringidzidwa; 
\q2 ndiwe kasupe wotchingidwa, chitsime chotetezedwa. 
\q1  
\v 13 Zomera zako ndi munda wa zipatso za makangadza; 
\q2 muli zipatso zokoma kwambiri, 
\q2 muli hena ndi nadi, 
\q2  
\v 14 nadi ndi safiro, 
\q2 kalamusi ndi sinamoni, 
\q2 komanso mtengo uliwonse wonunkhira bwino. 
\q2 Mulinso mure ndi aloe 
\q2 ndi zonunkhiritsa zonse zabwino kwambiri. 
\q1  
\v 15 Iwe ndiwe kasupe wa mʼmunda, 
\q2 chitsime cha madzi oyenda, 
\q2 mtsinje wa madzi ochokera ku Lebanoni. 
\sp Mkazi 
\q1  
\v 16 Dzuka, iwe mphepo yakumpoto, 
\q2 ndipo bwera, iwe mphepo yakummwera! 
\q1 Uzira pa munda wanga, 
\q2 kuti fungo lake lonunkhira lifalikire ponseponse. 
\q1 Bwenzi langa alowe mʼmunda mwake 
\q2 ndi kudya zipatso zake zabwino kwambiri. 
\c 5  
\sp Mwamuna 
\q1  
\v 1 Ndalowa mʼmunda mwanga, iwe mlongo wanga, iwe mkwatibwi wanga; 
\q2 ndasonkhanitsa mure wanga ndi zokometsera zakudya zanga. 
\q1 Ndadya uchi wanga pamodzi ndi zisa zake zomwe; 
\q2 ndamwa vinyo wanga ndi mkaka wanga. 
\sp Abwenzi 
\q1 Idyani abwenzi anga, imwani; 
\q2 Inu okondana, imwani kwambiri. 
\sp Mkazi 
\q1  
\v 2 Ndinagona tulo koma mtima wanga unali maso. 
\q2 Tamverani, bwenzi langa akugogoda: 
\q1 “Nditsekulire, mlongo wanga, bwenzi langa, 
\q2 nkhunda yanga, wangwiro wanga. 
\q1 Mutu wanga wanyowa ndi mame, 
\q2 tsitsi langa lanyowa chifukwa cha nkhungu ya usiku.” 
\q1  
\v 3 Ndavula kale zovala zanga, 
\q2 kodi ndizivalenso? 
\q1 Ndasamba kale mapazi anga 
\q2 kodi ndiwadetsenso? 
\q1  
\v 4 Bwenzi langa anapisa dzanja lake pa chibowo cha pa chitseko; 
\q2 mtima wanga unagunda chifukwa cha iye. 
\q1  
\v 5 Ndinanyamuka kukamutsekulira wachikondi wangayo, 
\q2 ndipo manja anga anali noninoni ndi mure, 
\q1 zala zanga zinali mure chuchuchu, 
\q2 pa zogwirira za chotsekera. 
\q1  
\v 6 Ndinamutsekulira wachikondi wanga, 
\q2 koma nʼkuti wachikondi wangayo atachoka; iye anali atapita. 
\q2 Mtima wanga unafumuka chifukwa cha kuchoka kwake. 
\q1 Ndinamuyangʼanayangʼana koma sindinamupeze. 
\q2 Ndinamuyitana koma sanandiyankhe. 
\q1  
\v 7 Alonda anandipeza 
\q2 pamene ankayendera mzindawo. 
\q1 Anandimenya ndipo anandipweteka; 
\q2 iwo anandilanda mwinjiro wanga, 
\q2 alonda a pa khoma aja! 
\q1  
\v 8 Inu akazi a ku Yerusalemu ndithu ndikukupemphani, 
\q2 mukapeza wokondedwa wangayo, 
\q1 kodi mudzamuwuza chiyani? 
\q2 Muwuzeni kuti ine ndadwala nacho chikondi. 
\sp Abwenzi 
\q1  
\v 9 Iwe wokongola kuposa akazi onsewa, 
\q2 kodi wokondedwa wakoyo ndi wopambana wina aliyense bwanji? 
\q1 Kodi wokondedwa wakoyo ndi wopambana ena onse chotani 
\q2 kuti uzichita kutipempha motere? 
\sp Mkazi 
\q1  
\v 10 Wokondedwa wangayo ndi wowala kwambiri ndi wathanzi 
\q2 pakati pa anthu 1,000. 
\q1  
\v 11 Mutu wake ndi golide woyengeka bwino; 
\q2 tsitsi lake ndi lopotanapotana, 
\q2 ndiponso lakuda bwino ngati khwangwala. 
\q1  
\v 12 Maso ake ali ngati nkhunda 
\q2 mʼmbali mwa mitsinje ya madzi, 
\q1 ngati nkhunda zitasamba mu mkaka, 
\q2 zitayima ngati miyala yamtengowapatali. 
\q1  
\v 13 Masaya ake ali ngati timinda ta mbewu zokometsera zakudya 
\q2 zopatsa fungo lokoma. 
\q1 Milomo yake ili ngati maluwa okongola 
\q2 amene akuchucha mure. 
\q1  
\v 14 Manja ake ali ngati ndodo zagolide 
\q2 zokongoletsedwa ndi miyala yamtengowapatali. 
\q1 Thupi lake ndi losalala ngati mnyanga wanjovu 
\q2 woyikamo miyala ya safiro. 
\q1  
\v 15 Miyendo yake ili ngati mizati yamwala, 
\q2 yokhazikika pa maziko a golide. 
\q1 Maonekedwe ake ali ngati Lebanoni, 
\q2 abwino kwambiri ngati mkungudza. 
\q1  
\v 16 Milomo yake ndi yosangalatsa kwambiri; 
\q2 munthuyo ndi wokongola kwambiri! 
\q1 Uyu ndiye wachikondi wanga ndi bwenzi langa, 
\q2 inu akazi a ku Yerusalemu. 
\c 6  
\sp Abwenzi 
\q1  
\v 1 Iwe wokongola kuposa akazi onsewa, 
\q2 kodi wokondedwa wakoyo wapita kuti? 
\q1 Kodi wokondedwa wakoyo wakhotera njira iti 
\q2 kuti timufunefune pamodzi ndi iwe? 
\sp Mkazi 
\q1  
\v 2 Wachikondi wanga watsikira ku munda kwake, 
\q2 ku timinda ta zokometsera zakudya, 
\q1 akukadyetsa ziweto zake ku minda, 
\q2 ndiponso akuthyola maluwa okongola. 
\q1  
\v 3 Wokondedwa wangayo ndine wake ndipo iyeyo ndi wangawanga; 
\q2 amadyetsa ziweto zake pakati pa maluwa okongola. 
\sp Mwamuna 
\q1  
\v 4 Ndiwe wokongola, bwenzi langa, ngati Tiriza, 
\q2 wokongola kwambiri ngati Yerusalemu, 
\q2 ndiwe woopsa ngati gulu lankhondo lonyamula mbendera. 
\q1  
\v 5 Usandipenyetsetse; 
\q2 pakuti maso ako amanditenga mtima. 
\q1 Tsitsi lako lili ngati gulu la mbuzi 
\q2 zikutsetsereka kuchokera ku Giliyadi. 
\q1  
\v 6 Mano ako ali ngati gulu la nkhosa 
\q2 zimene zikubwera kuchokera kokazisambitsa, 
\q1 iliyonse ili ndi ana amapasa, 
\q2 palibe imene ili yokha. 
\q1  
\v 7 Kukhalira kumbuyo kwa nsalu yako yophimba kumutu, 
\q2 masaya ako ali ngati mabandu a makangadza. 
\q1  
\v 8 Ngakhale patakhala akazi a mfumu 60, 
\q2 ndi azikazi 80, 
\q2 ndi anamwali osawerengeka; 
\q1  
\v 9 koma nkhunda yanga, wangwiro wanga ndi wosiyana ndi wina aliyense; 
\q2 mwana wamkazi yekhayo wa amayi ake, 
\q2 mwana wapamtima wa amene anamubereka. 
\q1 Anamwali anamuona ndipo anamutcha wodala; 
\q2 akazi a mfumu ndi azikazi anamutamanda. 
\sp Abwenzi 
\q1  
\v 10 Ndani uyu akuoneka ngati mʼbandakucha, 
\q2 wokongola ngati mwezi, wowala ngati dzuwa, 
\q2 wochititsa mantha ngati gulu la ankhondo mbendera zili mʼmanja? 
\sp Mwamuna 
\q1  
\v 11 Ndinatsikira ku munda wa mitengo ya alimondi 
\q2 kukayangʼana zomera zatsopano ku chigwa, 
\q1 kukaona ngati mpesa waphukira 
\q2 kapena ngati makangadza ali ndi maluwa. 
\q1  
\v 12 Ndisanazindikire kanthu, 
\q2 ndinakhala ngati ndikulota kuti ndili mʼgaleta pambali pa mfumu yanga. 
\sp Abwenzi 
\q1  
\v 13 Bwerera, bwerera iwe namwali wa ku Sulami; 
\q2 bwerera, bwerera kuti ife tidzakupenyetsetse iwe! 
\sp Mwamuna 
\q1 Chifukwa chiyani mukufuna kudzapenyetsetsa ine mwana wamkazi wa ku Sulami, 
\q2 pamene ndikuvina pakati pa magulu awiri? 
\c 7  
\q1  
\v 1 Iwe namwali waufumu, mapazi ako ngokongola 
\q2 mu nsapato wavalazo! 
\q1 Ntchafu zako nʼzowumbika bwino ngati miyala yamtengowapatali, 
\q2 ntchito ya manja ya mmisiri waluso. 
\q1  
\v 2 Mchombo wako uli ngati chikho chowumbika bwino 
\q2 chimene nthawi zonse ndi chodzaza ndi vinyo. 
\q1 Chiwuno chako ndi choningʼa ngati mtolo wa tirigu 
\q2 utazunguliridwa ndi maluwa okongola. 
\q1  
\v 3 Mawere ako akuoneka ngati ana awiri a mbawala, 
\q2 ngati mphoyo zamapasa. 
\q1  
\v 4 Khosi lako lili see! ngati nsanja ya mnyanga wa njovu. 
\q1 Maso ako ali ngati mayiwe a ku Hesiboni, 
\q2 amene ali pafupi ndi chipata cha Bati Rabimu. 
\q1 Mphuno yako ili ngati nsanja ya ku Lebanoni, 
\q2 yoyangʼana ku Damasiko. 
\q1  
\v 5 Mutu wako uli bwinobwino nengʼaa ngati phiri la Karimeli. 
\q2 Tsitsi lako lili ngati nsalu yakuda yaufumu; 
\q2 mfumu yakopeka ndi maonekedwe ake okongola. 
\q1  
\v 6 Ndiwe wokongola kwambiri ndiponso wosangalatsa, 
\q2 iwe wokondedwa, namwali wokondweretsawe! 
\q1  
\v 7 Msinkhu wako uli ngati mtengo wa mgwalangwa, 
\q2 ndipo mawere ako ali ngati phava la zipatso. 
\q1  
\v 8 Ndinati, “Ndikwera mtengo wa mgwalangwa; 
\q2 ndidzathyola zipatso zake.” 
\q1 Mawere ako ali ngati maphava a mphesa, 
\q2 fungo la mpweya wako lili ngati ma apulosi, 
\q2  
\v 9 ndipo pakamwa pako pali ngati vinyo wokoma kwambiri. 
\sp Mkazi 
\q1 Tsono vinyo ameneyu amuthirire wachikondi wanga, 
\q2 ayenderere bwino pa milomo yake ndi mano ake. 
\q1  
\v 10 Wokondedwayo ine ndine wake, 
\q2 ndipo chilakolako chake chili pa ine. 
\q1  
\v 11 Bwera wachikondi wanga, tiye tipite ku madera a ku midzi, 
\q2 tikagone ku midzi. 
\q1  
\v 12 Tiye tilawirire mmamawa kupita ku minda ya mpesa, 
\q2 tikaone ngati mitengo ya mpesa yayamba kuphukira, 
\q1 ngati maluwa ake ayamba kuoneka, 
\q2 komanso ngati makangadza ayamba kuonetsa maluwa. 
\q2 Kumeneko ndidzakuonetsa chikondi changa. 
\q1  
\v 13 Mitengo ya mankhwala a chisulo ikupereka fungo lake labwino, 
\q2 ndipo pa khomo pathu pali zipatso zonse zokoma, 
\q1 zatsopano ndi zakale zomwe, 
\q2 zimene ndakusungira wokondedwa wanga. 
\c 8  
\q1  
\v 1 Ukanakhala kuti ndiwe mlongo wanga, 
\q2 amene anayamwa mawere a amayi anga! 
\q1 Ndikanakumana nawe pa njira, 
\q2 ndikanakupsompsona, 
\q2 ndipo palibe wina aliyense akanandinyoza. 
\q1  
\v 2 Ndikanakutenga 
\q2 ndi kukulowetsa mʼnyumba ya amayi anga, 
\q2 amayi amene anandiphunzitsa, 
\q1 ndikanakupatsa vinyo wotsekemera kuti umwe, 
\q2 zotsekemera za makangadza. 
\q1  
\v 3 Mutu wanga watsamira dzanja lake lamanzere 
\q2 ndipo dzanja lake lamanja landikumbatira. 
\q1  
\v 4 Inu akazi a ku Yerusalemu, ndithu ndikukupemphani: 
\q2 musachigwedeze chikondi kapena kuchiutsa 
\q2 mpaka pamene chifunire ichocho. 
\sp Abwenzi 
\q1  
\v 5 Kodi ndani uyo akutuluka ku chipululuyo, 
\q2 atatsamira wokondedwa wakeyo? 
\sp Mkazi 
\q1 Ndinakudzutsa pa tsinde pa mtengo wa apulosi, 
\q2 pamenepo ndi pamene amayi anachirira, 
\q2 pamenepo ndi pamene wokubereka anamva ululu pokubala iweyo. 
\q1  
\v 6 Undiyike pamtima pako ngati chidindo, 
\q2 ngati chidindo cha pa dzanja lako; 
\q1 pakuti chikondi nʼchamphamvu ngati imfa, 
\q2 nsanje ndiyaliwuma ngati manda. 
\q1 Chikondi chimachita kuti lawilawi 
\q2 ngati malawi a moto wamphamvu. 
\q1  
\v 7 Madzi ochuluka sangachizimitse chikondi, 
\q2 mitsinje singachikokolole chikondicho. 
\q1 Ngati wina apereka chuma chonse 
\q2 cha mʼnyumba mwake chifukwa cha chikondi, 
\q2 adzangonyozeka nazo kotheratu. 
\sp Abwenzi 
\q1  
\v 8 Ife tili naye mlongo wathu wamngʼono, 
\q2 koma alibe mawere, 
\q1 kodi tidzamuchitira chiyani mlongo wathuyu 
\q2 pa tsiku limene adzamufunsire? 
\q1  
\v 9 Ngati iye ndi khoma, 
\q2 tidzamumangira nsanja ya siliva. 
\q1 Ngati iye ndi chitseko, 
\q2 tidzamutchinga ndi matabwa a mkungudza. 
\sp Mkazi 
\q1  
\v 10 Ine ndili ngati khoma, 
\q2 ndipo mawere anga ndi nsanja zake. 
\q1 Tsono mʼmaso mwa bwenzi langa 
\q2 ndine wobweretsa mtendere. 
\q1  
\v 11 Solomoni anali ndi munda wampesa ku Baala-Hamoni; 
\q2 iyeyo anabwereketsa munda wamphesawo kwa alimi, 
\q1 aliyense mwa iwo ankayenera kupereka 
\q2 ndalama zasiliva 1,000 mʼmalo mwa zipatso zake. 
\q1  
\v 12 Koma munda wanga wampesa ndi wangawanga ndiponso wa ine ndekha. 
\q2 Iwe Solomoni, khala nazo ndalama zasiliva 1,000 
\q2 ndipo ndalama zasiliva 200 ndi za amene akusamalira mundawo. 
\sp Mwamuna 
\q1  
\v 13 Iwe amene umakhala mʼminda 
\q2 uli pamodzi ndi anzako, 
\q2 ndilole kuti ndimve liwu lako! 
\sp Mkazi 
\q1  
\v 14 Fulumira wokondedwa wanga, 
\q2 ndipo ukhale ngati gwape 
\q1 kapena mwana wa mbawala 
\q2 wothamanga mʼmapiri mʼmene mumamera mbewu zokometsera chakudya.