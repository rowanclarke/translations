\id LUK
\h لُوكَا 
\toc1 لُوكَا 
\toc2 لُوكَا 
\toc3 لك. 
\mt1 لُوكَا  
\c 1
\s1 ثَامزْوَارُوثْ  
\m
\v 1 ؤُمِي أَطَّاسْ إِذْسنْ ثُوغَا نْوَانْ أَذْ أَرِينْ إِمزْرُوينْ خْ ثْمسْڒَايِينْ إِ زِي نتّْوَاسّقْنعْ  
\v 2 - أَمْ مَامّشْ ثنْثْ إِ ذ أَنغْ خبَّارنْ نِيثْنِي، إِنِّي إِژْرِينْ أَوَاڒْ زڭْ ؤُمزْوَارُو ؤُ ثُوغَا أَثنْ ذ إِمْسخَّارنْ نّسْ -  
\v 3 إِبَانْ أَيِي-د ؤُڒَا إِ نشّْ، مِينْزِي ضْفَارغْ مَارَّا ثِيمسْڒَايِينْ مْلِيحْ زڭْ ؤُمزْوَارُو، حِيمَا أَذْ أَشْ د-أَرِيغْ كُوڒْشِي س ؤُستّفْ، \add أَ\add* ثِييُوفِيلِيسْ إِعِيزّنْ،  
\v 4 حِيمَا أَذْ ثسّْنذْ \add مْلِيحْ\add* ثِيذتّْ ن وَاوَاڒنْ نِّي زِي ثتّْوَاسّْڒمْذذْ.   
\b  
\m  
\s1 زَاكَارِييَّا ذ إِلِيصَابِيثْ  
\m
\v 5 ثُوغَا ذِينْ ذڭْ وُوسَّانْ ن هِيرُوذُوسْ، أَجدْجِيذْ ن يَاهُوذِييَّا، إِجّْ ن ؤُكهَّانْ، قَّارنْ أَسْ زَاكَارِييَّا. نتَّا زِي ثرْبِيعْثْ \add ن إِكهَّاننْ\add* ن ثَادَّارْثْ ن أَبِييَا ؤُشَا ثَامْغَارْثْ نّسْ ثُوغَا-ت زِي ثَارَّاوْثْ ن هَارُونْ، قَّارنْ أَسْ إِلِيصَابِيثْ. \x ◘ \xo 1:‏5 \xt 1 إِم. 24‏:‏10. \x*  
\v 6 ثُوغَا س ثْنَاينْ إِذْسنْ ذ إِمْسڭَّاذنْ غَارْ أَربِّي، ضْفَارنْ مَارَّا ثِيوصَّا ؤُ ؤُيُورنْ \add ذِي ڒَاثَارَاثْ ن\add* ثْسڭْذَا ن سِيذِي بْڒَا ڒْعِيبْ.  
\v 7 وَارْ ثُوغِي غَارْسنْ بُو ؤُحنْجِيرْ مِينْزِي إِلِيصَابِيثْ ثُوغَا وَارْ د-ثتِّيرُووْ شَا ؤُ ثُوغَا س ثْنَاينْ إِذْسنْ مْغَارنْ ذڭْ وُوسَّانْ.   
\m
\v 8 أَقَا إِمْسَارْ، ڒَامِي ثُوغَا \add زَاكَارِييَّا\add* إِتّڭّْ ڒْخذْمثْ ن ؤُكهَّانْ قِيبَاتْشْ إِ أَربِّي خْ نُّوبثْ ن ثرْبِيعْثْ نّسْ \add ن إِكهَّاننْ\add*، \x ◘ \xo 1:‏8 \xt 1 إِم. 24\x*  
\v 9 أَقَا يُوسَا-د ذَايسْ ؤُكشُّوضْ عْلَاحْسَابْ لْقَاعِيذَا ن ثُوكهَّانْثْ، حِيمَا أَذْ إِقدّمْ ثَاوْهِيبْثْ ن ڒبْخُورْ، ؤُشَا يُوذفْ نتَّا غَارْ زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي. \x ◘ \xo 1:‏9 \xt ؤُف. 30‏:‏7؛ لَاوِي 16‏:‏17. \x*  
\v 10 ثُوغَا قَاعْ أَبَارُّو ن ڒْڭنْسْ إِتّْژَادْجْ بَارَّا ذِي ثْسَاعّثْ ن ثوْهِيبْثْ ن ڒبْخُورْ.  
\v 11 \add ڒخْذنِّي\add* إِضْحَارْ أَسْ-د لْمَالَاكْ ن سِيذِي إِ زَاكَارِييَّا نِّي ثُوغَا إِبدّنْ خْ ؤُفُوسِي ن ؤُعَالْطَارْ ن ڒبْخُورْ.  
\v 12 ؤُمِي ث إِژْرَا زَاكَارِييَّا، إِنّخْڒعْ ؤُشَا إِڭّْوذْ.  
\v 13 إِنَّا أَسْ لْمَالَاكْ: ”وَارْ تّڭّْوذْ شَا، \add أَ\add* زَاكَارِييَّا، مِينْزِي ثتّْوَاقْبڒْ ثْژَادْجِيثْ نّشْ. أَقَا إِلِيصَابِيثْ، ثَامطُّوثْ نّشْ، أَذْ أَشْ د-ثَارُووْ أَحنْجِيرْ، أَذْ ث ثْسمِّيذْ يُوحَانَّا. \x ◘ \xo 1:‏13 \xt لك. 1‏:‏60. \x*  
\v 14 أَذْ ثْفَارْحذْ ؤُ أَذْ ثسْڒِيوْڒوذْ ؤُشَا أَطَّاسْ ن إِوْذَانْ أَذْ فَارْحنْ إِ وخْڒَاقْ نّسْ، \x ◘ \xo 1:‏14 \xt لك. 1‏:‏58. \x*  
\v 15 مِينْزِي أَذْ يِيڒِي ذ أَمقّْرَانْ غَارْ سِيذِي، وَارْ إِسسّْ بِينُو ؤُڒَا ذ شّْرَابْ. أَذْ إِتّْوَاشُّورْ س أَرُّوحْ إِقدّْسنْ ذڭْ ؤُعذِّيسْ ن يمَّاسْ، \x ◘ \xo 1:‏15 \xt ڒقض. 13‏:‏4. \x*  
\v 16 ؤُشَا أَذْ د-يَارّْ أَطَّاسْ ن إِحنْجِيرنْ ن إِسْرَائِيل غَارْ سِيذِي، أَربِّي نْسنْ. \x ◘ \xo 1:‏16 \xt مـَال. 3‏:‏24؛ مت. 11‏:‏14. \x*  
\v 17 نتَّا أَذْ يُويُورْ زَّاثسْ س أَرُّوحْ ذ جّهْذْ ن ؤُنَابِي إِلِييَا، حِيمَا أَذْ د-يَارّْ ؤُڒَاونْ ن إِبَابَاثنْ غَارْ ثَارَّاوْثْ نْسنْ ؤُ إِنِّي وَارْ يُومِيننْ غَارْ ثُوسّْنَا ن ؤُمْسڭّذْ، حِيمَا أَذْ إِسّوْجذْ إِجّْ ن ڒْڭنْسْ إِكْمڒْ إِ سِيذِي.“ \x ◘ \xo 1:‏17 \xt مـَال. 3‏:‏23‏-‏24؛ مت. 3‏:‏2؛ مك. 9‏:‏12. \x*  
\v 18 يَارَّا-د زَاكَارِييَّا خْ لْمَالَاكْ: ”مَامّشْ إِ غَا ڭّغْ أَذْ فهْمغْ أَيَا، مِينْزِي نشّْ ذ أَوسَّارْ ؤُڒَا ذ ثَامْغَارْثْ إِنُو ثمْغَارْ أَطَّاسْ!“ \x ◘ \xo 1:‏18 \xt أَمز. 17‏:‏17. \x*  
\v 19 يَارَّا-د لْمَالَاكْ، إِنَّا أَسْ: ”نشّْ ذ \bd جِيبْرِيلْ\bd*، ونِّي إِبدّنْ زَّاثْ إِ أَربِّي، تّْوَاسّكّغْ-د حِيمَا أَذْ كِيكْ سِّيوْڒغْ، أَذْ شكْ خبَّارغْ ڒخْبَارْ-أَ وَانِيثَا أَصبْحَانْ.  
\v 20 زِي ڒخُّو أَذْ ثڭْنُوذْ ؤُ وَارْ ثْزمَّارذْ أَذْ ثسِّيوْڒذْ أَڒْ أَسّْ مِينْ ذِي إِ غَا إِمْسَارْ ؤُيَا، مِينْزِي وَارْ ثُومِينذْ شَا س وَاوَاڒنْ إِنُو نِّي إِ غَا إِتّْوَاكمّْڒنْ ذِي ڒْوقْثْ نْسنْ.“  
\v 21 ثُوغَا ڒْڭنْسْ \add ذِي بَارَّا\add* إِتّْرَاجَا زَاكَارِييَّا ؤُشَا \add إِوْذَانْ\add* تّْبهْثنْ ؤُمِي إِعطَّاڒْ ذَاخڒْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ.  
\v 22 ؤُمِي د-إِفّغْ زَاكَارِييَّا، ثُوغَا وَارْ إِزمَّارْ أَذْ كِيسنْ إِسِّيوڒْ. خنِّي فهْمنْ بلِّي إِبَانْ أَسْ-د شَا ن ڒوْحِييْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ. ثُوغَا إِتّْشيَّارْ أَسنْ، \add مَاشَا\add* إِقِّيمْ إِڭْنُو.  
\v 23 ؤُمِي كمّْڒنْ وُوسَّانْ ن ڒْخذْمثْ \add ن ثُوكهَّانْثْ\add* نّسْ، إِعْقبْ-د غَارْ ثَادَّارْثْ نّسْ.   
\b  
\m
\v 24 أَوَارْنِي ؤُسَّانْ نِّي ثكْسِي ثَامْغَارْثْ نّسْ إِلِيصَابِيثْ س دّيْسثْ. ثفَّارْ إِخفْ نّسْ خمْسَا ن إِيُورنْ، ؤُشَا ثبْذَا ثقَّارْ:  
\v 25 ”أَمُّو إِ زَّايِي إِڭَّا سِيذِي ذڭْ وُوسَّانْ نِّي ؤُمِي غَارِي د-إِخْزَارْ، حِيمَا أَذْ خَافِي إِكّسْ أَسحْقَارْ ن إِوْذَانْ.“ \x ◘ \xo 1:‏25 \xt أَمز. 30‏:‏23؛ إِشا. 4‏:‏1. \x*   
\b  
\m  
\s1 أَضْهَارْ ن لْمَالَاكْ إِ مَارْيَامْ  
\m
\v 26 ذڭْ ؤُيُورْ وِيسّْ ستَّا إِسّكّْ-د أَربِّي لْمَالَاكْ جِيبْرِيلْ غَارْ إِشْثْ ن ثنْذِينْثْ ذِي لْجَالِيلْ، قَّارنْ أَسْ نَّاصِيرَا،  
\v 27 غَارْ إِشْثْ ن ثعْزَارشْثْ ذ ثَانخْضَابْثْ غَارْ ورْيَازْ زِي ثَادَّارْثْ ن \add ؤُجدْجِيذْ\add* ذَاوُوذْ، قَّارنْ أَسْ يُوسُوفْ. ثُوغَا إِسمْ ن ثعْزَارشْثْ نِّي مَارْيَامْ. \x ◘ \xo 1:‏27 \xt مت. 1‏:‏18. \x*  
\v 28 يُوذفْ-د غَارسْ لْمَالَاكْ، إِنَّا أَسْ: ”سْڒَامْ خَامْ، \add أَ\add* ثَامِيمُونْثْ! سِيذِيثْنغْ أَكِيذمْ! شمْ أَقَا ثتّْوَابَارْكذْ جَارْ ثمْغَارِينْ!“  
\v 29 ؤُمِي ث ثژْرَا، ثنّخْڒعْ زڭْ وَاوَاڒْ نّسْ ؤُشَا ثْخَارّصْ مِينْ إِخْسْ أَذْ يِينِي سْڒَامْ-أَ.  
\v 30 إِنَّا أَسْ لْمَالَاكْ: ”وَارْ تّڭّْوذْ شَا، \add أَ\add* مَارْيَامْ، مِينْزِي ثُوفِيذْ أَرْضَا غَارْ أَربِّي.  
\v 31 أَذْ ثكْسِيذْ دّيْسثْ ؤُشَا أَذْ ثَارْوذْ أَحنْجِيرْ، أَذْ ث ثْسمِّيذْ ’يشُّو‘. \x ◘ \xo 1:‏31 \xt إِشا. 7‏:‏14. \x*  
\v 32 وَانِيثَا أَذْ يِيڒِي ذ أَمقّْرَانْ، أَذْ خَاسْ تّْڒَاغَانْ مِّيسْ ن ؤُمْعُودْجِي خْ كُوڒْشِي، ؤُ أَذْ أَسْ إِوْشْ سِيذِي أَربِّي ڒْعَارْشْ ن جذِّيسْ ذَاوُوذْ. \x ◘ \xo 1:‏32 \xt 2 صم. 7‏:‏12؛ إِزهد. 132‏:‏11؛ إِشا. 9‏:‏6؛ 54‏:‏5. \x*  
\v 33 نتَّا أَذْ إِحْكمْ خْ ثَادَّارْثْ ن يَاعْقُوبْ إِ ڒبْذَا، وَارْ إِتِّيڒِي ؤُنڭَّارْ إِ ثْڭلْذِيثْ نّسْ.“ \x ◘ \xo 1:‏33 \xt 1 إِم. 22‏:‏10؛ إِزهد. 45‏:‏7؛ 89‏:‏37؛ إِرْم. 23‏:‏5؛ دَان. 7‏:‏14، 27؛ مِيخَا 4‏:‏7؛ عبر. 1‏:‏8. \x*  
\v 34 ثنَّا مَارْيَامْ إِ لْمَالَاكْ: ”مَامّشْ إِ غَا يِيڒِي ؤُيَا أَمْ وَارْ مْڒِيشغْ شَا أَكْ-ذ ورْيَازْ؟“  
\v 35 يَارَّا-د لْمَالَاكْ، إِنَّا أَسْ: ”أَرُّوحْ إِقدّْسنْ أَذْ د-يَاسْ ؤُشَا جّهْذْ ن ؤُمْعُودْجِي خْ كُوڒْشِي أَذْ خَامْ يَارْسَا. س ؤُينِّي أَذْ يِيڒِي ونِّي إِ د غَا إِخڒْقنْ زَّايمْ ذ أَمْقدَّاسْ ؤُ أَذْ ث سمَّانْ مِّيسْ ن أَربِّي.  
\v 36 خْزَارْ، إِلِيصَابِيثْ، ڒَادْجْ نّمْ، نتَّاثْ عَاوذْ أَقَا-ت س دّيْسثْ ذِي ثوْسَارْ نّسْ. أَقَا ذ أَيُورْ وِيسّْ ستَّا إِ نتَّاثْ ؤُمِي قَّارنْ ’وَارْ ثتِّيرُووْ!‘  
\v 37 مِينْزِي وَارْ ذِينْ مِينْ يوْعَارنْ إِ أَربِّي.“ \x ◘ \xo 1:‏37 \xt أَيُوبْ 42‏:‏2؛ إِرْم. 32‏:‏17؛ زَاك. 8‏:‏6؛ مت. 19‏:‏26؛ لك. 18‏:‏27. \x*  
\v 38 ثنَّا مَارْيَامْ: ”خْزَارْ، نشّْ ذ ثَايَّا ن سِيذِي، أَذْ أَيِي إِمْسَارْ عْلَاحْسَابْ أَوَاڒْ نّشْ.“ \add خَاسْ ؤُشَا\add* يُويُورْ خَاسْ لْمَالَاكْ.   
\b  
\m  
\s1 مَارْيَامْ ثْرُوحْ أَذْ ثَارْزفْ إِلِيصَابِيثْ  
\m
\v 39 ذڭْ وُوسَّانْ نِّي ثكَّارْ مَارْيَامْ، ثْرُوحْ ذغْيَا غَارْ إِذُورَارْ، غَارْ إِشْثْ ن ثنْذِينْثْ ن يَاهُوذِييَّا.  
\v 40 ثُوذفْ غَارْ ثَادَّارْثْ ن زَاكَارِييَّا، ثْسدْجمْ خْ إِلِيصَابِيثْ.  
\v 41 ؤُمِي ثسْڒَا إِلِيصَابِيثْ إِ سْڒَامْ ن مَارْيَامْ، إِمْسَارْ أَقَا إِنْهزّْ ؤُسيْمِي ذڭْ ؤُعذِّيسْ نّسْ، ؤُشَا ثذْوڒْ إِلِيصَابِيثْ ثشُّورْ س أَرُّوحْ إِقدّْسنْ.  
\v 42 نتَّاثْ ثسْغُويْ س جّهْذْ، ثنَّا إِ مَارْيَامْ: ”شمْ أَقَا ثتّْوَابَارْكذْ جَارْ ثمْغَارِينْ، ثتّْوَابَاركْ ڒْغِيدْجثْ ن ؤُعذِّيسْ نّمْ!  
\v 43 زِي مَانِيسْ غَارِي أَيَا، حِيمَا أَذْ غَارِي د-ثَاسْ يمَّاسْ ن سِيذِي إِنُو؟  
\v 44 مَاغَارْ ڒَامِي د-ثِيوضْ ثْمِيجَّا ن سْڒَامْ نّمْ غَارْ ؤُمزُّوغْ إِنُو، إِنْهزّْ ؤُسيْمِي ذڭْ ؤُعذِّيسْ إِنُو س ڒفْرَاحثْ ثَامقّْرَانْثْ.  
\v 45 سّعْذْ ن ثنِّي يُومْننْ أَقَا أَذْ إِتّْوَاكمّڒْ مِينْ ذ أَسْ إِتّْوَانَّا زِي سِيذِي.“ \x ◘ \xo 1:‏45 \xt لك. 11‏:‏28. \x*   
\b  
\m
\v 46 ثنَّا مَارْيَامْ:  
\b  
\m \qt ”ڒعْمَارْ إِنُو إِسّمْغَارَا ذِي سِيذِي،\qt*   
\m
\v 47 \qt إِفَارْحْ بُوحْبڒْ إِنُو س أَربِّي،\qt*  
\m \qt ونِّي ذ أَيِي إِتِّيشنْ ثُوذَارْثْ،\qt*   
\m
\v 48 \qt س مِينْزِي إِخْزَارْ\qt*  
\m \qt غَارْ ؤُمدُّورْ أَوَاضعْ ن ثَايَّا نّسْ.\qt*  
\m \qt خْزَارْ، زِي ڒخُّو مَارَّا أَرَّاونْ\qt*  
\m \qt أَذْ أَيِي سمَّانْ ’ذ ثَامِيمُونْثْ!‘\qt*   
\m
\v 49 \qt مِينْزِي ونِّي ذ أَمْزمَّارْ إِڭَّا ذَايِي\qt*  
\m \qt ثِيمسْڒَايِينْ مْغَارنْثْ،\qt*  
\m \qt أَقَا إِسمْ نّسْ إِقدّسْ.\qt*   
\m
\v 50 \qt أَرّحْمثْ نّسْ خْ ثَارْوَا ذ جِّيڒَاثْ،\qt*  
\m \qt خْ يِينِّي ث إِتّْوقَّارنْ.\qt* \x ◘ \xo 1:‏50 \xt ؤُف. 20‏:‏6. \x*   
\m
\v 51 \qt س ؤُغِيڒْ نّسْ أَقَا يِيوِي-د ڒغْڒبْ.\qt*  
\m \qt إِفَارْثكْ إِنِّي إِعفَّارنْ\qt*  
\m \qt ذڭْ إِخَارِّيصنْ ن وُوڒَاونْ نْسنْ.\qt* \x ◘ \xo 1:‏51 \xt إِزهد. 33‏:‏10؛ إِشا. 51‏:‏9؛ 52‏:‏10؛ 1 بُط. 5‏:‏5. \x*   
\m
\v 52 \qt إِنِّي غَارْ ثدْجَا صُّولْطَا إِغْضڒْ إِ-ثنْ\qt*  
\m \qt زِي ڒكْرَاسِي نْسنْ،\qt*  
\m \qt إِمْوَاضْعنْ إِسّْڭعّذْ إِ-ثنْ.\qt* \x ◘ \xo 1:‏52 \xt 1 صم. 2‏:‏8؛ إِزهد. 113‏:‏6. \x*   
\m
\v 53 \qt إِسّْجِيونْ س ڒْخَارْ إِنِّي إِدْجُوژنْ،\qt*  
\m \qt إِسْقَاذْ أَيْثْبَابْ ن وَاڭْڒَا س إِفَاسّنْ خْوَانْ.\qt* \x ◘ \xo 1:‏53 \xt إِزهد. 34‏:‏11. \x*   
\m
\v 54 \qt أَمْسخَّارْ نّسْ إِسْرَائِيل، إِعَاونْ إِ-ث،\qt*  
\m \qt أَقَا إِعْقڒْ خْ أَرّحْمثْ نّسْ،\qt* \x ◘ \xo 1:‏54 \xt إِشا. 30‏:‏18؛ 41‏:‏9؛ 54‏:‏5؛ إِرْم. 31‏:‏2، 20. \x*   
\m
\v 55 \qt أَمْ مَامّشْ إِسِّيوڒْ أَكْ-ذ ڒجْذُوذْ نّغْ،\qt*  
\m \qt أَكْ-ذ إِبْرَاهِيمْ ذ زَّارِيعثْ نّسْ،\qt*  
\m \qt إِ ڒبْذَا.“\qt* \x ◘ \xo 1:‏55 \xt أَمز. 17‏:‏19؛ 22‏:‏18؛ إِزهد. 132‏:‏11. \x*   
\b  
\m
\v 56 ثكَّا مَارْيَامْ عْڒَاحَاڒْ ثْڒَاثَا ن إِيُورنْ غَارْ إِلِيصَابِيثْ، \add خنِّي\add* ثعْقبْ غَارْ ثَادَّارْثْ نّسْ.   
\b  
\m  
\s1 أَخْڒَاقْ ن يُوحَانَّا أَمْسغْضَاصْ  
\m
\v 57 ڒَامِي د-ثِيوضْ ڒْوقْثْ ن إِلِيصَابِيثْ، حِيمَا أَذْ د-ثَارُووْ، ثجّْ-د أَحنْجِيرْ.  
\v 58 سْڒِينْ جِّيرَانْ ذ ڒَادْجْ نّسْ بلِّي أَربِّي إِسّْشنْ أَسْ أَرّحْمثْ نّسْ أَطَّاسْ، فَارْحنْ نِيثْنِي أَكِيذسْ. \x ◘ \xo 1:‏58 \xt لك. 1‏:‏14. \x*   
\m
\v 59 ذڭْ وَاسّْ وِيسّْ ثْمنْيَا ؤُسِينْ-د، حِيمَا أَذْ خثْننْ إِ ؤُحنْجِيرْ ؤُشَا سمَّانْ ث س يِيسمْ ن بَابَاسْ زَاكَارِييَّا. \x ◘ \xo 1:‏59 \xt أَمز. 17‏:‏12؛ لَاوِي 12‏:‏3. \x*  
\v 60 \add مَاشَا\add* ثطّفْ يمَّاسْ ذڭْ وَاوَاڒْ، ثنَّا: ”لَّ. وَارْ إِتّْوَاسمَّا أَمُّو، مَاشَا أَذْ إِتّْوَاسمَّا يُوحَانَّا.“ \x ◘ \xo 1:‏60 \xt لك. 1‏:‏13. \x*  
\v 61 نَّانْ أَسْ: ”وَارْ إِدْجِي حذْ زِي ڒَادْجْ نّمْ تّْڒَاغَانْ أَسْ-د س يِيسمْ-أَ.“  
\v 62 \add خنِّي\add* شِييَّارنْ غَارْ بَابَاسْ، مَامّشْ إِخْسْ أَذْ ث إِسمَّا.  
\v 63 إِتَّارْ ثَاڒْوِيحْثْ ؤُشَا يُورَا خَاسْ، إِنَّا: ”إِسمْ نّسْ يُوحَانَّا.“ ؤُشَا ثْبهْثنْ إِوْذَانْ مَارَّا.  
\v 64 ڒخْذنِّي يَارْزمْ أَقمُّومْ نّسْ ؤُشَا \add إِتّْوَاضْڒقْ\add* يِيڒسْ نّسْ ؤُشَا إِسِّيوڒْ \add عَاوذْ\add*، إِبَاركْ أَربِّي.   
\m
\v 65 ثهْوَا-د ثِيڭّْوُوذِي خْ مَارَّا جِّيرَانْ نْسنْ، سِّيوْڒنْ أَطَّاسْ خْ مَارَّا مَانْ أَيَا ذِي كُوڒْ إِذُورَارْ ن يَاهُوذِييَّا.  
\v 66 مَارَّا إِنِّي إِسْڒِينْ إِ مَانْ أَيَا، خمّْڒنْ ث ذڭْ وُوڒَاونْ نْسنْ، نَّانْ: ”أَقَا مِينْ غَا يِيڒِي ؤُحنْجِيرْ-أَ؟“ ثُوغَا أَفُوسْ ن سِيذِي أَكِيذسْ.   
\b  
\m
\v 67 إِتّْوَاشُّورْ بَابَاسْ زَاكَارِييَّا س أَرُّوحْ إِقدّْسنْ، إِنبَّا، إِنَّا:   
\b  
\m
\v 68 \qt ”أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي ن إِسْرَائِيل،\qt*  
\m \qt مِينْزِي إِفكَّارْ ذِي ڒْڭنْسْ نّسْ\qt*  
\m \qt ؤُشَا يِيوِي أَسنْ-د أَسنْجمْ.\qt*   
\m
\v 69 \qt إِسّْڭعّذْ أَنغْ-د إِجّْ ن يِيشّْ ن ؤُسنْجمْ\qt*  
\m \qt ذِي ثَادَّارْثْ ن ذَاوُوذْ، أَمْسخَّارْ نّسْ،\qt* \x ◘ \xo 1:‏69 \xt إِزهد. 132‏:‏17. \x*   
\m
\v 70 \qt - أَمْ مَامّشْ ثُوغَا ذ أَنغْ إِنَّا\qt*  
\m \qt س ؤُقمُّومْ ن إِنَابِييّنْ إِقدّْسنْ نّسْ،\qt*  
\m \qt إِنِّي ذِينْ ثُوغَا زڭْ وشْحَاڒْ ؤُيَا -\qt* \x ◘ \xo 1:‏70 \xt إِزهد. 72‏:‏12؛ إِشا. 40‏:‏10؛ إِرْم. 23‏:‏6؛ 30‏:‏10؛ دَان. 9‏:‏27. \x*   
\m
\v 71 \qt حِيمَا أَذْ أَنغْ إِفكّْ زِي ڒْعذْيَانْ نّغْ،\qt*  
\m \qt زڭْ إِفَاسّنْ ن يِينِّي إِ ذ أَنغْ إِشَارّْهنْ.\qt*   
\m
\v 72 \qt نتَّا إِڭَّا أَرّحْمثْ نّسْ إِ ڒجْذُوذْ نّغْ،\qt*  
\m \qt أَقَا إِعْقڒْ خْ ڒْعُوهُوذْ نّسْ إِقدّْسنْ،\qt*   
\m
\v 73 \qt خْ ثَاجَادْجِيثْ ثنِّي إِجُّودْجْ إِ إِبْرَاهِيمْ، جذِّيثْنغْ،\qt*  
\m \qt حِيمَا أَذْ ذ أَنغْ إِوْشْ،\qt* \x ◘ \xo 1:‏73 \xt أَمز. 22‏:‏16؛ إِزهد. 105‏:‏9؛ إِرْم. 31‏:‏33؛ عبر. 6‏:‏13، 17. \x*   
\m
\v 74 \qt مَاحنْذْ أَذْ نتّْوَافكّْ\qt*  
\m \qt زڭْ إِفَاسّنْ ن ڒْعذْيَانْ نّغْ،\qt*  
\m \qt أَذْ أَسْ نْسخَّارْ بْڒَا ثِيڭّْوُوذِي،\qt* \x ◘ \xo 1:‏74 \xt عبر. 9‏:‏14\x*   
\m
\v 75 \qt س ثْقدَّاسْثْ ذ ثْسڭْذَا،\qt*  
\m \qt مَارَّا ؤُسَّانْ \+tl ن ثُوذَارْثْ\+tl* نّغْ.\qt* \x ◘ \xo 1:‏75 \xt 1 بُط. 1‏:‏15. \x*   
\m
\v 76 \qt إِ شكْ، أَ أَحنْجِيرْ، أَذْ أَشْ تّْڒَاغَانْ\qt*  
\m \qt أَنَابِي ن ؤُمْعُودْجِي خْ كُوڒْشِي،\qt*  
\m \qt مِينْزِي أَذْ ثْرَاحذْ زَّاثْ إِ ؤُغمْبُوبْ ن سِيذِي،\qt*  
\m \qt حِيمَا أَذْ ثسّْوجْذذْ أَبْرِيذْ نّسْ،\qt* \x ◘ \xo 1:‏76 \xt لك. 1‏:‏17؛ مـَال. 3‏:‏23. \x*   
\m
\v 77 \qt حِيمَا أَذْ إِوْشْ إِ ڒْڭنْسْ نّسْ ثُوسّْنَا ن ثُوذَارْثْ،\qt*  
\m \qt \+tl إِ إِدْجَانْ\+tl* س وغْفَارْ ن دّْنُوبْ نْسنْ،\qt* \x ◘ \xo 1:‏77 \xt لك. 3‏:‏3. \x*   
\m
\v 78 \qt س ڒَادْجَاغْ ن أَرّحْمثْ ن أَربِّي نّغْ،\qt*  
\m \qt إِ زِي خَانغْ إِ غَا إِحِينّْ ڒفْجَارْ زِي ڒُوعْڒَا،\qt*   
\m
\v 79 \qt حِيمَا أَذْ إِسِّيرْغْ ثْفَاوْثْ إِ يِينِّي إِقِّيمنْ\qt*  
\m \qt ذِي ثَادْجسْثْ ذ ثِيڒِي ن ڒْموْثْ،\qt*  
\m \qt حِيمَا أَذْ إِڭوّذْ إِضَارنْ نّغْ\qt*  
\m \qt ذڭْ وبْرِيذْ ن ڒهْنَا.“\qt* \x ◘ \xo 1:‏79 \xt إِشا. 9‏:‏1؛ 42‏:‏7؛ 43‏:‏8؛ 49‏:‏9؛ 60‏:‏1. \x*   
\b  
\m
\v 80 أَمْ إِڭَّامْ ؤُحنْجِيرْ، يَارنِّي ذَايسْ أَرُّوحْ ؤُ ثُوغَا-ث ذِي ڒخْڒَا أَڒْ أَسّْ إِ ذِي د-إِضْهَارْ إِ إِسْرَائِيل. \x ◘ \xo 1:‏80 \xt لك. 2‏:‏40. \x*   
\b  
\b  
\m  
\c 2
\s1 أَخْڒَاقْ ن يَاسُوع  
\m
\v 1 ذڭْ وُوسَّانْ نِّي إِفّغْ-د إِجّْ ن ڒُومُورْ زِي قَايْصَارْ ؤُغُوسْثُوسْ حِيمَا أَذْ تّْوَازمّمنْ مَارَّا إِمزْذَاغْ ن ڒحْكَامثْ نّسْ. \x ◘ \xo 2:‏1 \xt [مت. 1‏:‏18‏-‏25] \x*  
\v 2 أَزمّمْ-أَ ثُوغَا-ث ذ أَمزْوَارُو ؤُمِي ثُوغَا قِيرِينِييُوسْ إِحكّمْ ذِي سُورِييَا.  
\v 3 كُوڒْ إِجّنْ إِڒُوحْ غَارْ ثنْذِينْثْ نّسْ، حِيمَا أَذْ إِتّْوَازمّمْ ذِينِّي.  
\v 4 إِڭعّذْ عَاوذْ يُوسُوفْ زِي نَّاصِيرَا، إِشْثْ ن ثنْذِينْثْ ذِي لْجَالِيلْ، غَارْ يَاهُوذِييَّا، غَارْ ثنْذِينْثْ ن ذَاوُوذْ ثنِّي ؤُمِي قَّارنْ بَايْثْ-لَاحْمْ ؤُمِي ث ثُوغَا زِي ثَادَّارْثْ ؤُ زِي جِّيڒْ ن ذَاوُوذْ، \x ◘ \xo 2:‏4 \xt 1 صم. 16؛ مِيخَا 5‏:‏1؛ مت. 1‏:‏1؛ يُوح. 7‏:‏42. \x*  
\v 5 أَكْ-ذ مَارْيَامْ، ثَانخْضَابْثْ نّسْ، ثنِّي ثُوغَا س دّيْسثْ، حِيمَا أَذْ إِتّْوَازمّمْ ذِينِّي.   
\m
\v 6 ؤُشَا إِمْسَارْ، أَڒَامِي ثنْ ثُوغَا ذِينِّي، قفْڒنْ وُوسَّانْ نّسْ حِيمَا أَذْ ثَارُو.  
\v 7 ثُورُووْ-د مِّيسْ أَمنْزُو، ثسّنّضْ إِ-ث ذِي ثحْڒُوشِينْ ؤُشَا ثسَّارْسْ إِ-ث ذِي ڒْكُورِي، مِينْزِي وَارْ غَارْسنْ بُو ومْشَانْ مَانِي \add زمَّارنْ\add* أَذْ قِّيمنْ. \x ◘ \xo 2:‏7 \xt مت. 1‏:‏25. \x*   
\b  
\m  
\s1 إِمكْسَاونْ ذڭْ إِيَّارنْ ن بَايْثْ-لَاحْمْ  
\m
\v 8 ذِي جّْوَايهْ نِّي ثُوغَا ذِينْ شَا ن إِمكْسَاونْ، حطَّانْ ثِيحِيمْرِيوِينْ نْسنْ ذِي دْجِيڒثْ.  
\v 9 ؤُ خْزَارْ، لْمَالَاكْ ن أَربِّي إِبدّْ-د غَارْسنْ ؤُشَا أَعُودْجِي ن سِيذِي إِسَّارْغْ خَاسنْ، إِنّضْ أَسنْ، ؤُشَا ثْڒحّفْ أَسنْ إِشْثْ ن ثِيڭّْوُوذِي ثمْغَارْ.  
\v 10 إِنَّا أَسنْ لْمَالَاكْ نِّي: ”وَارْ تّڭّْوذمْ شَا، أَذْ أَومْ بَارّْحغْ ڒخْبَارْ أَصبْحَانْ، أَذْ ثِيڒِي ڒفْرَاحثْ ثمْغَارْ إِ دُّونشْثْ مَارَّا.  
\v 11 أَقَا إِتّْوَاخْڒقْ أَومْ-د أَسّْ-أَ ؤُمْسنْجمْ، سِيذِي، لْمَاسِيحْ، ذِي ثنْذِينْثْ ن ذَاوُوذْ.  
\v 12 ذ وَا ذ أَومْ إِ غَا يِيڒِينْ ذ ڒعْڒَامثْ: أَذْ ثَافمْ أَسيْمِي إِتّْوَانّضْ ذِي ثحْڒُوشِينْ، إِمَّارْسْ ذِي ڒْكُورِي.“  
\v 13 ڒخْذنِّي إِبَانْ-د أَكْ-ذ لْمَالَاكْ إِجّْ ن ڒْغَاشِي أَمقّْرَانْ ن ڒْعسْكَارَاثْ ن ؤُجنَّا تّْصبَّاحنْ أَربِّي، قَّارنْ: \x ◘ \xo 2:‏13 \xt دَان. 7‏:‏10؛ أَسَا. 5‏:‏11. \x*   
\b  
\m
\v 14 \qt ”أَعُودْجِي إِ أَربِّي ذِي ڒُوعْڒَا،\qt*  
\m \qt ڒهْنَا خْ ثمُّورْثْ،\qt*  
\m \qt ؤُ أَسِيثمْ ذ أَصبْحَانْ إِ يوْذَانْ.“\qt* \x ◘ \xo 2:‏14 \xt إِشا. 57‏:‏19؛ أَفا. 2‏:‏17. \x*   
\b  
\m
\v 15 ؤُمِي خَاسنْ ؤُيُورنْثْ لْمَالَاكَاثْ غَارْ ؤُجنَّا، سِّيوْڒنْ إِمكْسَاونْ أَكْ-ذ وَايَاوْيَا، نَّانْ: ”أجّْ أَنغْ أَذْ نْرَاحْ غَارْ بَايْثْ-لَاحْمْ، حِيمَا أَذْ نْژَارْ مِينْ إِمْسَارنْ مِينْ خفْ ذ أَنغْ إِسَّارْڭبْ سِيذِي.“  
\v 16 ؤُسِينْ-د س ثَازْڒَا، ؤُفِينْ مَارْيَامْ ذ يُوسُوفْ ذ ؤُسيْمِي إِمَّارْسْ ذِي ڒْمذْوذْ.  
\v 17 ؤُمِي ث ژْرِينْ، عَاوْذنْ أَوَاڒْ إِ ذ أَسنْ إِتّْوَانَّانْ خْ ؤُحنْجِيرْ.  
\v 18 مَارَّا إِنِّي إِسْڒِينْ، ثْبهْثنْ س مِينْ ذ أَسنْ نَّانْ إِمكْسَاونْ.  
\v 19 مَاشَا مَارْيَامْ ثُوغَا ثْخمّڒْ مَارَّا أَوَاڒنْ-أَ، ثتّْخَارَّاصْ ذَايْسنْ ذڭْ وُوڒْ نّسْ.  
\v 20 خنِّيعقْبنْ-د إِمكْسَاونْ، تّْصبَّاحنْ ؤُ سّمْغَارَانْ ذِي أَربِّي خْ مَارَّا مِينْ سْڒِينْ ذ مَارَّا مِينْ ژْرِينْ، \add نِيشَانْ\add* أَمْ مَامّشْ ذ أَسنْ ثُوغَا إِتّْوَانَّا.   
\b  
\m  
\s1 أَخْثَانْ ن يَاسُوع  
\m
\v 21 ؤُمِي كمّْڒنْ ثْمنْيَا ن وُوسَّانْ، حِيمَا أَذْ إِتّْوَاخْثنْ ؤُسيْمِي، سمَّانْ ث ’يشُّو‘، أَمْ مَامّشْ ثُوغَا ث إِسمَّا لْمَالَاكْ قْبڒْ إِ غَا إِتّْوَاكْسِي ذڭْ ؤُعذِّيسْ. \x ◘ \xo 2:‏21 \xt أَمز. 17‏:‏12؛ لَاوِي 12‏:‏3؛ مت. 1‏:‏21؛ لك. 1‏:‏31؛ يُوح. 7‏:‏22. \x*  
\v 22 ؤُمِي كمّْڒنْ وُوسَّانْ ن ؤُسِيزْذڭْ نْسنْ عْلَاحْسَابْ شَّارِيعَا ن مُوسَا، إِوْينْ ث غَارْ ؤُرْشَالِيمْ، حِيمَا أَذْ ث قدّْمنْ زَّاثْ إِ سِيذِي \x ◘ \xo 2:‏22 \xt لَاوِي 12‏:‏6. \x*  
\v 23 - أَمْ مَامّشْ ثُورَا ذِي شَّارِيعَا ن سِيذِي: ’أَقَا كُوڒْ \add مِّيسْ\add* أَمنْزُو إِ د-إِتّْوَاخڒْقنْ زڭْ ؤُعذِّيسْ ن يمَّاسْ أَذْ إِتّْوَاسمَّا ذ أَمْقدَّاسْ إِ سِيذِي!‘ - \x ◘ \xo 2:‏23 \xt ؤُف. 13‏:‏2، 12؛ ڒخْڒ. 3‏:‏13؛ 8‏:‏16، 17. \x*  
\v 24 ؤُ حِيمَا أَذْ حْضَارنْ ثَاغَارْصْثْ أَمْ مَامّشْ ثتّْوَانَّا ذِي شَّارِيعَا ن سِيذِي: ثْنَاينْ ن إِذْبِيرنْ نِيغْ ثْيُويَا ن إِوَارُّوضنْ ن إِذْبِيرنْ. \x ◘ \xo 2:‏24 \xt لَاوِي 12‏:‏8. \x*   
\b  
\m  
\s1 ڒفْرَاحثْ ن شِيمْعُونْ ذ حَانَّا  
\m
\v 25 ثُوغَا ذِي ؤُرْشَالِيمْ إِجّْ ن ورْيَازْ قَّارنْ أَسْ شِيمْعُونْ. ثُوغَا أَرْيَازْ-أَ نِيشَانْ ذ أَمْسڭّذْ، إِتّْرَاجَا أَفوّجْ ن إِسْرَائِيل ؤُشَا ثُوغَا أَرُّوحْ إِقدّْسنْ خَاسْ.  
\v 26 ثُوغَا أَرُّوحْ إِقدّْسنْ إِوحَّا أَسْ-د أَقَا وَارْ إِتّْمتِّي شَا قْبڒْ إِ غَا إِژَارْ لْمَاسِيحْ ن سِيذِي.  
\v 27 يُوسَا-د غَارْ زَّاوشْثْ ثَامقّْرَانْثْ \add أَمْ ث إِعَارّنْ\add* أَرُّوحْ إِقدّْسنْ، ؤُمِي د-ؤُذْفنْ لْوَالِيذِينْ س ؤُحنْجِيرْ يَاسُوع، حِيمَا أَذْ أَسْ ڭّنْ عْلَاحْسَابْ لْقَاعِيذَا ن شَّارِيعَا.  
\v 28 إِكْسِي ث ذڭْ إِغَادْجنْ نّسْ ؤُشَا إِبَاركْ أَربِّي، إِنَّا:   
\b  
\m
\v 29 \qt ”\+tl أَ\+tl* سِيذِي إِنُو،\qt* \qt أجّْ أَمْسخَّارْ نّشْ\qt*  
\m \qt أَذْ إِرَاحْ ذِي ڒهْنَا ڒخُّو،\qt*  
\m \qt عْلَاحْسَابْ أَوَاڒْ نّشْ،\qt* \x ◘ \xo 2:‏29 \xt أَمز. 46‏:‏30. \x*   
\m
\v 30 \qt مِينْزِي ثِيطَّاوِينْ إِنُو ژْرِينْثْ أَرّحْمثْ نّشْ،\qt* \x ◘ \xo 2:‏30 \xt إِزهد. 98‏:‏2؛ إِشا. 52‏:‏10. \x*   
\m
\v 31 \qt إِ ثسّْوجْذذْ زَّاثْ إِ وُوذمْ ن مَارَّا ڒڭْنُوسْ:\qt* \x ◘ \xo 2:‏31 \xt ڒخ. 28‏:‏28. \x*   
\m
\v 32 \qt ثَافَاوْثْ إِ غَا ثتّْوَاسَارْڭبْ إِ ڒڭْنُوسْ\qt*  
\m \qt ذ ؤُعُودْجِي إِ ڒْڭنْسْ نّشْ إِسْرَائِيل!“\qt* \x ◘ \xo 2:‏32 \xt إِشا. 42‏:‏6؛ 49‏:‏6؛ ڒخ. 13‏:‏47. \x*   
\b  
\m
\v 33 إِثبْهثْ يُوسُوفْ ذ يمَّاسْ س مِينْ خَاسْ إِتّْوَانَّانْ.  
\v 34 \add خنِّي\add* إِبَارْكْ إِ-ثنْ شِيمْعُونْ، إِنَّا إِ مَارْيَامْ يمَّاسْ:  
\b  
\m \qt ”أَقَا وَا إِمَّارْسْ إِ ؤُوطُّو ذ ثْنُوكْرَا\qt*  
\m \qt ن وَاطَّاسْ ذِي إِسْرَائِيل\qt*  
\m \qt ؤُ إِ ڒعْڒَامثْ إِ غَا إِتّْوَاعكّْسنْ.\qt* \x ◘ \xo 2:‏34 \xt إِشا. 8‏:‏14؛ رُوم. 9‏:‏32؛ 1 بُط. 2‏:‏8. \x*   
\m
\v 35 \qt أَذْ إِشُوقْ سِّيفْ ذِي ڒعْمَارْ نّمْ،\qt*  
\m \qt حِيمَا أَذْ د-تّْوَاسّضْهَارنْ إِخَارِّيصنْ\qt*  
\m \qt زڭْ وَاطَّاسْ ن وُوڒَاونْ.“\qt*   
\b  
\m
\v 36 إِشْثْ ن ثْنَابِيثْ، \add قَّارنْ أَسْ\add* حَانَّا، يدْجِيسْ ن فَانْوِيلْ، زِي ثقْبِيتْشْ ن أَشِيرْ، ثُوغَا-ت ؤُڒَا ذ نتَّاثْ ثوْسَارْ أَطَّاسْ. ثدَّارْ أَكْ-ذ ورْيَازْ نّسْ سبْعَا ن إِسڭّْوُوسَا زڭْ وَامِي ت ثُوغَا \add عَاذْ\add* ذ ثَاعْزَارشْثْ.  
\v 37 ثُوغَا-ت ذ ثَاجَّاتْشْ إِ يِيجّْ ن ڒْمِيجَاڒْ ن أَربْعَا ؤُ-ثْمَانْيِينْ ن إِسڭّْوُوسَا، وَارْ ثتّْبعِّيذْ شَا خْ زَّاوشْثْ ثَامقّْرَانْثْ. ثُوغَا ثْعبّذْ \add أَربِّي\add* س ؤُژُومِّي ذ ثْژَادْجِيثْ دْجِيڒثْ ذ وَاسّْ. \x ◘ \xo 2:‏37 \xt 1 صم. 1‏:‏22. \x*  
\v 38 غَارْ ثْسَاعّثْ نِّي ثْبدّْ نتَّاثْ عَاوذْ، ثتّْصبَّاحْ إِ سِيذِي، ثسَّاوَاڒْ خَاسْ أَكْ-ذ مَارَّا إِنِّي إِتّْرَاجَانْ أَسنْجمْ ن ؤُرْشَالِيمْ. \f ◼ \fr 2:‏38 \ft \+bd ’أَسنْجمْ‘\+bd* - نِيغْ ’أَسلَّاكْ‘.\f*   
\m
\v 39 ؤُمِي كمّْڒنْ نِيثْنِي كُوڒْشِي عْلَاحْسَابْ شَّارِيعَا ن سِيذِي،عقْبنْ غَارْ ثنْذِينْثْ نْسنْ نَّاصِيرَا ذِي لْجَالِيلْ.  
\v 40 ثُوغَا أَحنْجِيرْ إِڭَّامْ، يَارنِّي ذَايسْ أَرُّوحْ، إِذْوڒْ إِشُّورْ س ثِيغِيثْ، ؤُ أَرْضَا ن أَربِّي أَقَا-ث خَاسْ. \x ◘ \xo 2:‏40 \xt لك. 1‏:‏80. \x*   
\b  
\m  
\s1 يَاسُوع ذِي زَّاوشْثْ ثَامقّْرَانْثْ ڒَامِي إِڭَّا ثنْعَاشْ ن إِسّڭّْوُوسَا  
\m
\v 41 ثُوغَا ڒَادْجْ نّسْ تّْرَاحنْ كُوڒْ أَسڭّْوَاسْ غَارْ ؤُرْشَالِيمْ ذِي ڒْعِيذْ ن \add ثْغَارْصْثْ ن\add* ؤُسعْذُو. \x ◘ \xo 2:‏41 \xt ؤُف. 23‏:‏15، 17؛ لَاوِي 23‏:‏5؛ أَعَوذ. 16‏:‏1. \x*  
\v 42 ؤُمِي غَارسْ يِيوضْ ثنْعَاشْ ن إِسڭّْوُوسَا، ڭعّْذنْ غَارْ ڒْعِيذْ أَمْ مَامّشْ نُّومنْ نِيثْنِي.  
\v 43 أَوَارْنِي ڒَامِي عْذُونْ وُوسَّانْ \add ن ڒْعِيذْ\add*،عقْبنْ-د، مَاشَا أَحنْجِيرْ، يَاسُوع، إِقِّيمْ أَوَارْنِي أَسنْ ذِي ؤُرْشَالِيمْ، ؤُمِي يُوسُوفْ ذ يمَّاسْ وَارْ أَرْڭِيبنْ شَا خْ مَانْ أَيَا.  
\v 44 إِتّْغِيڒْ أَسنْ أَقَا-ث جَارْ إِمْسبْرِيذنْ. أَوَارْنِي ڒَامِي ؤُيُورنْ إِشْثْ ن ثِيشْڒِي ن وَاسّْ، أَرزُّونْ خَاسْ جَارْ ڒَادْجْ نْسنْ ذ يِينِّي ثنْ إِسّْننْ.  
\v 45 ؤُمِي وَارْ ث ؤُفِينْ،عقْبنْ غَارْ ؤُرْشَالِيمْ، أَرزُّونْ خَاسْ.  
\v 46 أَوَارْنِي ثْڒَاثَا ن وُوسَّانْ ؤُفِينْ ث ذِي زَّاوشْثْ ثَامقّْرَانْثْ، ثُوغَا إِقِّيمْ ذِي ڒْوسْطْ ن إِمسْغَارنْ \add ن شَّارِيعَا\add*، إِتّسْڒَا غَارْسنْ، إِتّْسقْسَا ثنْ.  
\v 47 مَارَّا إِنِّي ذ أَسْ إِسْڒِينْ ثْبهْثنْ ذِي ڒفْهَامثْ ذ وَاوَاڒْ إِ د-إِتَّارَّا. \x ◘ \xo 2:‏47 \xt مت. 7‏:‏28؛ مك. 1‏:‏22؛ لك. 4‏:‏22، 32؛ يُوح. 7‏:‏15. \x*  
\v 48 ڒَامِي ث ژْرِينْ، ثْبهْثنْ. ثنَّا أَسْ يمَّاسْ: ”\add أَ\add* مِّي، مَايمِّي ذ أَنغْ ثڭِّيذْ أَمُّو؟ أَقَا، بَابَاشْ ذ نشّْ نذْعقْ س ثَارزُّوثْ خَاكْ.“  
\v 49 إِنَّا أَسنْ: ”مَايمِّي خَافِي ثَارْزُومْ؟ مَا وَارْ ثَارْڭِيبمْ شَا بلِّي \add إِتّْخصَّا أَيِي\add* أَذْ إِڒِيغْ ذِي ثَادَّارْثْ ن بَابَا؟“  
\v 50 مَاشَا وَارْ فْهِيمنْ أَوَاڒْ إِ ذ أَسنْ إِنَّا. \x ◘ \xo 2:‏50 \xt لك. 9‏:‏45؛ 18‏:‏34. \x*  
\v 51 ؤُشَا إِهْوَا-د أَكِيذْسنْ غَارْ نَّاصِيرَا، ثُوغَا إِتّڭّْ أَسنْ أَرَّايْ. مَاشَا يمَّاسْ ثْخمّڒْ مَارَّا أَوَاڒنْ-أَ ذڭْ وُوڒْ نّسْ.   
\m
\v 52 ؤُشَا ثُوغَا يَاسُوع يَارنِّي ذِي ثِيذِّي نّسْ ذ ثِيغِيثْ نّسْ ؤُ ذِي أَرْضَا غَارْ أَربِّي ذ يوْذَانْ. \x ◘ \xo 2:‏52 \xt 1 صم. 2‏:‏26؛ لك. 1‏:‏80. \x*   
\b  
\b  
\m  
\c 3
\s1 يُوحَانَّا أَمْسغْضَاصْ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ خمّسْطَاشْ زِي ڒحْكَامثْ ن قَايْصَارْ ثِيبَارْيُوسْ، ڒَامِي ثُوغَا بُونْطِييُوسْ بِيلَاطُوسْ ذ ڒْحَاكمْ خْ يَاهُوذِييَّا، ؤُ هِيرُوذُوسْ ذ ڒْحَاكمْ خْ لْجَالِيلْ، إِجّْ ن أَرْبعْ ن ثمُّورْثْ، ؤُ فِيلِيبُّوسْ، ؤُمَاسْ، ذ ڒْحَاكمْ خْ إِثُورِييَا ذ جِّيهثْ ن ثْرَاخُونِيثِيسْ، إِجّْ ن أَرْبعْ نّغْنِي ن ثمُّورْثْ، ؤُ لِيسَانْيُوسْ ذ ڒْحَاكمْ خْ جِّيهثْ ن أَبِيلِينِي، \add ثنِّي عَاوذْ\add* ذ إِجّْ ن أَرْبعْ نّغْنِي ن ثمُّورْثْ، \x ◘ \xo 3:‏1 \xt [مت. 3‏:‏1‏-‏12؛ مك. 1‏:‏1‏-‏8؛ يُوح. 1‏:‏19‏-‏28] \x*  *   
\b  
\m
\v 2 ؤُمِي ثُوغَا حَانَّانْ ذ قَايَافَا ذ أَرُّويَاسْ ن إِكهَّاننْ، أَقَا يُوسَا-د وَاوَاڒْ ن أَربِّي خْ يُوحَانَّا، مِّيسْ ن زَاكَارِييَّا، ذِي ڒخْڒَا. \x ◘ \xo 3:‏2 \xt ڒخ. 4‏:‏6. \x*  
\v 3 يِيوضْ-د غَارْ مَارَّا جّْوَايهْ إِ ذ أَسْ د-إِنّْضنْ إِ لْ-ؤُرْذُونْ، إِتّْبَارّحْ س ؤُسغْضصْ ن تُّوبثْ إِ وغْفَارْ ن دّْنُوبْ، \x ◘ \xo 3:‏3 \xt مت. 3‏:‏1؛ مك. 1‏:‏4. \x*  
\v 4 أَمْ مَامّشْ ثُورَا ذڭْ وذْلِيسْ ن وَاوَاڒنْ ن ؤُنَابِي إِشَاعْيَا إِ إِنَّانْ:  
\b  
\m \qt ”ثْمِيجَّا ن ونِّي إِسْغُويُّونْ ذِي ڒخْڒَا:\qt*  
\m \qt سْوجْذمْ أَبْرِيذْ ن سِيذِي،\qt*  
\m \qt سڭّْممْ أَمسْرَاقْ إِ أَربِّي نّغْ ذِي ڒوْضَا.\qt* \x ◘ \xo 3:‏4 \xt إِشا. 40‏:‏3‏-‏5؛ مت. 3‏:‏3؛ مك. 1‏:‏3؛ يُوح. 1‏:‏23. \x*   
\b  
\m
\v 5 \qt مَارَّا ثِيدَّاغِينْ أَذْ تّْوَاشُّورنْثْ،\qt*  
\m \qt مَارَّا إِذُورَارْ ذ ثوْرِيرِينْ\qt*  
\m \qt أَذْ د-تّْوَاسّهْوَانْ،\qt*  
\m \qt دّْمَانِي أَذْ تّْوَاسڭّْمنْثْ،\qt*  
\m \qt ؤُ إِمُوشَانْ إِوْعَارنْ أَذْ ذوْڒنْ ذ ڒوْضَا.\qt*   
\m
\v 6 \qt كُوڒْ دَّاثْ \+tl س إِذَامّنْ ذ ويْسُومْ\+tl*\qt*  
\m \qt أَذْ ثْژَارْ ثُوذَارْثْ ن أَربِّي.“\qt* \x ◘ \xo 3:‏6 \xt إِزهد. 98‏:‏2؛ إِشا. 40‏:‏3‏-‏5؛ 52‏:‏10. \x*   
\b  
\m
\v 7 ثُوغَا إِقَّارْ إِ ڒْغَاشِي إِ د-إِتّفّْغنْ حِيمَا أَذْ تّْوَاسّْغضْصنْ: ”\add أَ\add* ثَارْوَا ن إِڒفْسَاونْ، وِي ذ أَومْ إِمْڒنْ مَاحنْذْ \add أَذْ ثَارْزُومْ\add* أَذْ ثَاروْڒمْ زڭْ وغْضَابْ إِ د غَا يَاسنْ؟ \x ◘ \xo 3:‏7 \xt مت. 3‏:‏7؛ 23‏:‏33. \x*  
\v 8 س ؤُيَا ڭّمْ ڒْغِيدْجثْ إِ غَا إِڒِيقّنْ إِ تُّوبثْ. وَارْ تّْبدَّامْ أَذْ ثِينِيمْ ذڭْ إِخفْ نْومْ: ’أَقَا غَارْنغْ إِبْرَاهِيمْ ذ جذِّيثْنغْ!‘، مِينْزِي نشّْ أَذْ أَومْ إِنِيغْ، بلِّي أَربِّي إِزمَّارْ أَذْ إِسّْنكَّارْ زڭْ إِژْرَا-يَا ثَارْوَا إِ إِبْرَاهِيمْ. \x ◘ \xo 3:‏8 \xt مت. 3‏:‏9؛ يُوح. 8‏:‏39؛ ڒخ. 13‏:‏26. \x*  
\v 9 خْزَارْ، أَقَا ثتّْوَاسَّارْسْ ثْشَاقُورْثْ غَارْ إِژوْرَانْ ن ثْشجُّورَا. س ؤُيَا كُوڒْ ثَاشجَّارْثْ إِ وَارْ إِتِّيشنْ ڒْغِيدْجثْ ثشْنَا أَذْ ثتّْوَاقسّْ ؤُشَا أَذْ ثوْضَا ذِي ثْمسِّي.“ \f ◼ \fr 3:‏9 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  \x ◘ \xo 3:‏9 \xt مت. 3‏:‏10؛ 7‏:‏19. \x*   
\m
\v 10 إِسّقْسَا ث ڒْغَاشِي، إِنَّا: ”مِينْ غَا نڭّْ؟“ \x ◘ \xo 3:‏10 \xt ڒخ. 2‏:‏37. \x*  
\v 11 يَارَّا-د، إِنَّا أَسنْ: ”أجّْ ونِّي غَارْ إِدْجَا ثْيُويَا ن ثْشَامِيرَاثْ، أَذْ إِوْشْ إِ ونِّي وَارْ غَارْ إِدْجِي شَا، ؤُ أجّْ ونِّي غَارْ إِدْجَا مَاشَّا، أَذْ إِڭّْ أَمنِّي.“ \x ◘ \xo 3:‏11 \xt يَاع. 2‏:‏13، 15؛ 1 يُوح. 3‏:‏17. \x*  
\v 12 ؤُسِينْ-د عَاوذْ أَيْثْ ن ضَّارِيبَا، حِيمَا أَذْ تّْوَاسّْغضْصنْ، نَّانْ أَسْ: ”\add أَ\add* أَمْسغَّارْ، مِينْ غَا نڭّْ؟“  
\v 13 إِنَّا أَسنْ: ”وَارْ تّطّْفمْ ضَّارِيبَا كْثَارْ زِي مِينْ ذ أَومْ وصَّانْ مَاحنْذْ أَذْ ت ثطّْفمْ.“  
\v 14 سّقْسَانْ ث عَاوذْ إِعسْكَارِييّنْ، نَّانْ أَسْ: ”مِينْ غَا نڭّْ نشِّينْ؟“ إِنَّا أَسنْ: ”وَارْ تّڭّمْ ڒْغَارْ ؤُڒَا ذڭْ إِجّْ، وَارْ ذدْجْممْ حذْ، قنّْعمْ س ڒْمُونثْ نْومْ.“   
\m
\v 15 أَمْ إِبْذَا ڒْڭنْسْ أَذْ إِتّْشڒْ خْ يُوحَانَّا، ؤُ خَارّْصنْ ذڭْ وُوڒَاونْ نْسنْ مَا يُوحَانَّا نتَّا ذ لْمَاسِيحْ،  
\v 16 خنِّي إِطّفْ يُوحَانَّا ذڭْ وَاوَاڒْ، إِنَّا أَسنْ: ”نشّْ سّغْضَاصغْ كنِّيوْ ذڭْ وَامَانْ، مَاشَا أَوَارْنِي أَيِي أَذْ د-يَاسْ وِي إِجهْذنْ خَافِي، ونِّي ؤُمِي نشّْ وَارْ سْذِيهِيدْجغْ ؤُڒَا أَذْ أَسْ فسْيغْ إِفِيڒَانْ ن سَانْذَالِييَاثْ نّسْ. أَقَا نتَّا أَذْ كنِّيوْ إِسّغْضصْ ذِي أَرُّوحْ إِقدّْسنْ ؤُ ذِي ثْمسِّي. \x ◘ \xo 3:‏16 \xt إِشا. 44‏:‏3؛ يُووِ. 3‏:‏1؛ مت. 3‏:‏11؛ مك. 1‏:‏8؛ يُوح. 1‏:‏26؛ ڒخ. 1‏:‏5؛ 11‏:‏16؛ 2‏:‏4؛ 11‏:‏15؛ 19‏:‏4. \x*  
\v 17 نتَّا غَارسْ ثَازَّارْثْ ذڭْ ؤُفُوسْ نّسْ ؤُشَا أَذْ إِسِّيزْذڭْ أَنْذْرَارْ نّسْ. أَذْ إِسّْمُونْ إِرْذنْ غَارْ ڒْمَارْسِي نّسْ، مَاشَا إِشَارْفَا أَذْ ثنْ إِسّشْمضْ س ثْمسِّي وَارْ إِخْسِينْعمَّارْصْ.“ \x ◘ \xo 3:‏17 \xt مت. 3‏:‏12. \x*   
\m
\v 18 س ثْمسْڒَايِينْ نّغْنِي عَاذْ أَطَّاسْ ثُوغَا إِسّڒْمَاذْ \add إِوْذَانْ\add* ؤُشَا إِتّْبَارّحْ س ڒخْبَارْ أَصبْحَانْ إِ ڒْڭنْسْ.  
\v 19 مَاشَا ؤُمِي إِعَايَارْ يُوحَانَّا هِيرُوذُوسْ، ڒْحَاكمْ خْ إِجّْ ن أَرْبعْ ن ثمُّورْثْ، زِي سِّيبّثْ ن هِيرُوذِييَّا ثَامْغَارْثْ ن فِيلِيبُّوسْ ؤُمَاسْ، ؤُ زِي سِّيبّثْ ن مَارَّا ثُوعفّْنَا إِ إِڭَّا، \x ◘ \xo 3:‏19 \xt مت. 14‏:‏3؛ مك. 6‏:‏18. \x*  
\v 20 أَقَا يَارْنِي \add هِيرُوذُوسْ\add* عَاوذْ ذِي مَانْ أَيَا مَارَّا، ڒَامِي ثُوغَا إِحبّسْ يُوحَانَّا \add أَمْسغْضَاصْ\add*.   
\b  
\m  
\s1 أَسغْضصْ ن يَاسُوع س ؤُفُوسْ ن يُوحَانَّا أَمْسغْضَاصْ  
\m
\v 21 أَوَارْنِي ڒَامِي إِسّغْضصْ \add يُوحَانَّا\add* مَارَّا ڒْڭنْسْ، إِسّغْضصْ عَاوذْ يَاسُوع، ؤُشَا أَمْ ثُوغَا وَانِيثَا إِتّْژَادْجْ، إِنُّورْزمْ ؤُجنَّا، \x ◘ \xo 3:‏21 \xt [مت. 3‏:‏13‏-‏17؛ مك. 1‏:‏9‏-‏11] — مت. 3‏:‏13؛ مك. 1‏:‏9؛ يُوح. 1‏:‏32. \x*  
\v 22 ؤُشَا إِهْوَا-د خَاسْ أَرُّوحْ إِقدّْسنْ س صِّيفثْ ن دَّاثْ ن ثذْبِيرْثْ. ؤُشَا إِشْثْ ن ثْمِيجَّا زڭْ ؤُجنَّا ثُوغَا ثقَّارْ: ”شكْ ذ مِّي إِعِيزّنْ، ذَايكْ ؤُفِيغْ أَرْضَا إِنُو.“ \x ◘ \xo 3:‏22 \xt إِشا. 42‏:‏1؛ مت. 17‏:‏5؛ مك. 9‏:‏7؛ لك. 9‏:‏35؛ كُول. 1‏:‏13؛ 2 بُط. 1‏:‏17. \x*   
\b  
\m  
\s1 ثَاصِيڒثْ ن يَاسُوع لْمَاسِيحْ  
\m
\v 23 ثُوغَا يَاسُوع غَارسْ عْڒَاحَاڒْ ثْڒَاثِينْ ن إِسڭّْوُوسَا ؤُ إِتّْغِيڒْ أَسنْ أَقَا نتَّا ذ مِّيسْ ن يُوسُوفْ، مِّيسْ ن هَايْلِي، \x ◘ \xo 3:‏23 \xt [مت. 1‏:‏1‏-‏17] — مت. 13‏:‏55؛ يُوح. 6‏:‏42. \x*  
\v 24 مِّيسْ ن مَاتَّاثْ، مِّيسْ ن لَاوِي، مِّيسْ ن مَالْكِي، مِّيسْ ن يَانَّا، مِّيسْ ن يُوسُوفْ،  
\v 25 مِّيسْ ن مَاتَّاثَا، مِّيسْ ن عَامُوسْ، مِّيسْ ن نَاحُومْ، مِّيسْ ن حَاسْلِي، مِّيسْ ن نَاجَّايْ،  
\v 26 مِّيسْ ن مَاعَاثْ، مِّيسْ ن مَاتَّاثْ، مِّيسْ ن شِيمْعِي، مِّيسْ ن يُوسُوفْ، مِّيسْ ن يَاهُوذَا،  
\v 27 مِّيسْ ن يُوحَانَّا، مِّيسْ ن رِيسَا، مِّيسْ ن زَارُوبَّابِيلْ، مِّيسْ ن شَاعَالْثِييِيلْ، مِّيسْ ن نِيرِي،  
\v 28 مِّيسْ ن مَالْكِي، مِّيسْ ن أَذِّي، مِّيسْ ن قُوصَامْ، مِّيسْ ن أَلْمُوذَامْ، مِّيسْ ن عِيرْ،  
\v 29 مِّيسْ ن يُوسِي، مِّيسْ ن أَلِيعَازَارْ، مِّيسْ ن يُورَامْ، مِّيسْ ن مَاثِيثَا، مِّيسْ ن لَاوِي،  
\v 30 مِّيسْ ن شِيمْعُونْ، مِّيسْ ن يَاهُوذَا، مِّيسْ ن يُوسُوفْ، مِّيسْ ن يُونَامْ، مِّيسْ ن أَلْيَاقِيمْ،  
\v 31 مِّيسْ ن مَالِييَا، مِّيسْ ن مِييْنَانْ، مِّيسْ ن مَاتَّاثَا، مِّيسْ ن نَاثَانْ، مِّيسْ ن ذَاوُوذْ،  
\v 32 مِّيسْ ن يَاسَّا، مِّيسْ ن عُوبِيذْ، مِّيسْ ن بُوعَازْ، مِّيسْ ن سَالْمُونْ، مِّيسْ ن نَاحْشُونْ،  
\v 33 مِّيسْ ن عَامِّينَاذَابْ، مِّيسْ ن أَرَامْ، مِّيسْ ن حَاصْرُونْ، مِّيسْ ن فَارِيصْ، مِّيسْ ن يَاهُوذَا،  
\v 34 مِّيسْ ن يَاعْقُوبْ، مِّيسْ ن إِسْحَاقْ، مِّيسْ ن إِبْرَاهِيمْ، مِّيسْ ن ثَارَاحْ، مِّيسْ ن نَاحُورْ، \x ◘ \xo 3:‏34 \xt أَمز. 11‏:‏10. \x*  
\v 35 مِّيسْ ن سَارُوجْ، مِّيسْ ن رَاعُووْ، مِّيسْ ن فَالَاجْ، مِّيسْ ن عَابِيرْ، مِّيسْ ن شَالَاحْ،  
\v 36 مِّيسْ ن قِينَانْ، مِّيسْ ن أَرْفَاكْشَاذْ، مِّيسْ ن شَامْ، مِّيسْ ن نُوحْ، مِّيسْ ن لَامَاكْ،  
\v 37 مِّيسْ ن مَاثُوشَالَاحْ، مِّيسْ ن حَانُوخْ، مِّيسْ ن يَارَاذْ، مِّيسْ ن مَاهَالَالْ-إِلْ، مِّيسْ ن قِينَانْ،  
\v 38 مِّيسْ ن أَنُوشْ، مِّيسْ ن شِيثْ، مِّيسْ ن أَذَامْ، مِّيسْ ن أَربِّي. \x ◘ \xo 3:‏38 \xt أَمز. 5‏:‏3. \x*   
\b  
\b  
\m  
\c 4
\s1 أَجَارّبْ ن يَاسُوع ذِي ڒخْڒَا  
\m
\v 1 يَاسُوع إِعْقبْ-د زِي لْ-ؤُرْذُونْ أَمْ ثُوغَا إِشُّورْ س أَرُّوحْ إِقدّْسنْ ؤُشَا أَرُّوحْ إِنْذهْ إِ-ث غَارْ ڒخْڒَا، \x ◘ \xo 4:‏1 \xt [مت. 4‏:‏1‏-‏11؛ مك. 1‏:‏12‏-‏13] — مت. 4‏:‏1؛ مك. 1‏:‏12. \x*  
\v 2 حِيمَا أَذْ إِتّْوَاجَارّبْ زڭْ إِبْڒِيسْ أَربْعِينْ ن وُوسَّانْ. وَارْ إِشِّي وَالُو ذڭْ وُوسَّانْ نِّي ؤُشَا أَوَارْنِي ڒَامِي عْذُونْ \add وُوسَّانْ نِّي\add*، إِطّفْ إِ-ث ڒَاژْ غَارْ ؤُنڭَّارْ. \x ◘ \xo 4:‏2 \xt ؤُف. 34‏:‏28؛ 1 إِج. 19‏:‏8. \x*   
\m
\v 3 إِنَّا أَسْ إِبْڒِيسْ: ”مَاڒَا شكْ ذ مِّيسْ ن أَربِّي، إِنِي إِ وژْرُو-يَا أَذْ إِذْوڒْ ذ أَغْرُومْ.“  
\v 4 يَارَّا-د خَاسْ يَاسُوع، إِنَّا: ”أَقَا ثُورَا: ’بْنَاذمْ وَارْ إِدَّارْ س وغْرُومْ وَاهَا، مَاشَا س كُوڒْ أَوَاڒْ ن أَربِّي.‘ “ \x ◘ \xo 4:‏4 \xt أَعَوذ. 8‏:‏3؛ مت. 4‏:‏4. \x*   
\m
\v 5 \add خنِّي\add* إِسّْڭعّذْ إِ-ث شِّيطَانْ غَارْ إِجّْ ن وذْرَارْ يُوعْڒَانْ، إِسّْشنْ أَسْ مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ ذڭْ إِجّنْ ورْمَاشْ.  
\v 6 إِنَّا أَسْ إِبْڒِيسْ: ”أَذْ أَشْ وْشغْ صُّولْطَا-يَا مَارَّا ذ ؤُعُودْجِي نّسْ، مِينْزِي إِ نشّْ ؤُمِي ثمّوْشْ ؤُ تِّيشغْ \add ت\add* إِ ؤُمِي خْسغْ.  
\v 7 مَاڒَا ثْعبْذذْ أَيِي، أَذْ غَاركْ يِيڒِي مَارَّا أَيَا.“  
\v 8 يَارَّا-د خَاسْ يَاسُوع، إِنَّا أَسْ: ”أَقَا ثُورَا: ’سِيذِي، أَربِّي نّشْ، ؤُمِي غَا ثْسجْذذْ ؤُ إِ نتَّا وحّْذسْ ؤُمِي غَا ثْسخَّارذْ.‘ “ \x ◘ \xo 4:‏8 \xt أَعَوذ. 6‏:‏13؛ 10‏:‏20؛ 1 صم. 7‏:‏3. \x*   
\m
\v 9 يِيوْيِي ث غَارْ ؤُرْشَالِيمْ ؤُشَا إِسّْبدّْ إِ-ث غَارْ طَّارْفْ ن ثْزقَّا ن زَّاوشْثْ ثَامقّْرَانْثْ، إِنَّا أَسْ: ”مَاڒَا شكْ ذ مِّيسْ ن أَربِّي، نْضَارْ إِخفْ نّشْ سَّا غَارْ وَادَّايْ،  
\v 10 مِينْزِي ثُورَا: ’أَذْ يُومُورْ لْمَالَاكَاثْ نّسْ خَاكْ مَاحنْذْ أَذْ شكْ حْضَانْثْ،  
\v 11 أَقَا خْ إِفَاسّنْ نْسنْثْ أَذْ شكْ كْسِينْثْ، حِيمَا أَضَارْ نّشْ وَارْ إِنڭّحْ شَا أَژْرُو.‘ “ \x ◘ \xo 4:‏11 \xt إِزهد. 91‏:‏11، 12. \x*  
\v 12 يَارَّا-د خَاسْ يَاسُوع إِنَّا أَسْ: ”أَقَا إِتّْوَانَّا: ’وَارْ تّْجَارَّابْ سِيذِي، أَربِّي نّشْ.‘ “ \x ◘ \xo 4:‏12 \xt أَعَوذ. 6‏:‏16. \x*   
\m
\v 13 ؤُمِي إِكمّڒْ إِبْڒِيسْ مَارَّا أَجَارّبْ نّسْ، يُويُورْ خَاسْ شَا ن ڒْوقْثْ.   
\b  
\m  
\s1 أَنَابِي وَارْ إِدْجِي ذ أَمقْپُوڒْ ذِي ثنْذِينْثْ نّسْ  
\m
\v 14 إِعْقبْ-د يَاسُوع س جّهْذْ ن أَرُّوحْ غَارْ لْجَالِيلْ، ؤُشَا إِفّغْ ڒخْبَارْ خَاسْ ذِي مَارَّا جّْوَايهْ إِ ذ أَسنْ د-إِنّْضنْ. \x ◘ \xo 4:‏14 \xt [مت. 4‏:‏12‏-‏17؛ 13‏:‏53‏-‏58؛ مك. 1‏:‏14‏-‏15؛ 6‏:‏1‏-‏6] — مت. 4‏:‏12؛ مك. 1‏:‏14؛ يُوح. 4‏:‏43؛ ڒخ. 10‏:‏37. \x*  
\v 15 ثُوغَا إِسّڒْمَاذْ ذِي ثمْزِيذَاوِينْ نْسنْ، سّْعُودْجَانْ ث \add إِوْذَانْ\add* مَارَّا.   
\b  
\m
\v 16 يُوسَا-د غَارْ نَّاصِيرَا مَانِي ثُوغَا إِتّْوَاربَّا، ؤُشَا يُوذفْ غَارْ ثمْزِيذَا \add ن وُوذَاينْ\add* ذڭْ وَاسّْ ن سّبْثْ عْلَاحْسَابْ ثَانَامِيثْ نّسْ، ؤُشَا إِكَّارْ، حِيمَا أَذْ إِسّْغَارْ. \x ◘ \xo 4:‏16 \xt [نَاح. 8‏:‏4، 5؛ مت. 13‏:‏54؛ مك. 6‏:‏1؛ يُوح. 4‏:‏43] \x*  
\v 17 إِمّوْشْ أَسْ أَذْلِيسْ إِتّْوَانّْضنْ ن ؤُنَابِي إِشَاعْيَا، ؤُشَا يَارْزمْ يَاسُوع أَذْلِيسْ إِتّْوَانْضنْ، يُوفَا أَمْشَانْ مَانِي ثُورَا:   
\b  
\m
\v 18 \qt ”أَرُّوحْ ن سِيذِي خَافِي،\qt*  
\m \qt مِينْزِي نتَّا إِذْهنْ أَيِي\qt*  
\m \qt حِيمَا أَذْ بَارّْحغْ\qt*  
\m \qt س ڒخْبَارْ أَصبْحَانْ إِ إِمزْڒَاضْ،\qt*  
\m \qt إِسّكّْ أَيِي-د حِيمَا أَذْ سّْڭنْفِيغْ\qt*  
\m \qt إِنِّي ؤُمِي يَارْژْ وُوڒْ،\qt*  
\m \qt حِيمَا أَذْ بَارّْحغْ إِ إِمحْبَاسْ س ؤُسَارّحْ،\qt*  
\m \qt إِ إِذَارْغَاڒنْ س ڒْخژْرَاثْ،\qt*  
\m \qt ؤُ حِيمَا أَذْ سّْفوّْجغْ إِنِّي إِتّْوَارْژنْ\qt*  
\m \qt س وغْفَارْ \+tl ن دّْنُوبْ نْسنْ\+tl*،\qt*   
\m
\v 19 \qt حِيمَا أَذْ بَارّْحغْ س ؤُسڭّْوَاسْ ن أَرْضَا ن سِيذِي.“\qt* \x ◘ \xo 4:‏19 \xt إِشا. 42‏:‏7؛ 61‏:‏1، 2؛ مت. 11‏:‏5. \x*   
\b  
\m
\v 20 خنِّي ينّضْ أَذْلِيسْ، إِوْشَا إِ-ث إِ ؤُمْسخَّارْ، إِقِّيمْ، أَمْ ذَايسْ نْضَارنْ ثِيطَّاوِينْ نْسنْ مَارَّا إِنِّي ثُوغَا ذِي ثمْزِيذَا.  
\v 21 \add خنِّي\add* إِبْذَا إِقَّارْ أَسنْ: ”أَقَا أَسّْ-أَ تّْوَاكمّْڒنْثْ ثِيرَا-يَا \add إِقدّْسنْ\add* ذڭْ إِمزُّوغنْ نْومْ.“   
\m
\v 22 ثُوغَا مَارَّا شهّْذنْ خَاسْ، ثْبهْثنْ س وَاوَاڒنْ ن أَرْضَا إِ د-إِفّْغنْ زڭْ ؤُقمُّومْ نّسْ، ؤُشَا نَّانْ: ”مَا وَارْ إِدْجِي وَا ذ مِّيسْ ن يُوسُوفْ؟“ \x ◘ \xo 4:‏22 \xt إِشا. 50‏:‏4؛ مت. 13‏:‏54؛ مك. 6‏:‏2؛ لك. 2‏:‏47؛ يُوح. 6‏:‏42. \x*  
\v 23 إِنَّا أَسنْ يَاسُوع: ”نِيشَانْ أَذْ أَيِي ثِينِيمْ لْمَاثَالْ-أَ: ’\add أَ\add* أَضْبِيبْ، سْڭنْفَا يِيخفْ نّشْ! مشْحَاڒْ نسْڒَا بلِّي إِجْرَا ذِي كَافَارْنَاحُومْ، أڭّْ مَانْ أَيَا عَاوذْ ذِي ثنْذِينْثْ نّشْ.‘ “ \x ◘ \xo 4:‏23 \xt مت. 4‏:‏13. \x*  
\v 24 \add خنِّي\add* إِنَّا: ”س ثِيذتّْ، أَذْ أَومْ إِنِيغْ، وَارْ إِدْجِي ؤُنَابِي ذ أَمقْبُوڒْ ذِي ثمُّورْثْ نّسْ. \x ◘ \xo 4:‏24 \xt مت. 13‏:‏57؛ مك. 6‏:‏4؛ يُوح. 4‏:‏44. \x*  
\v 25 س ثِيذتّْ أَذْ أَومْ إِنِيغْ: ثُوغَا ذِينْ ثِيجَّاڒْ أَطَّاسْ ذِي ثَادَّارْثْ ن إِسْرَائِيل ذڭْ وُوسَّانْ ن إِلِييَا ؤُمِي إِتّْوَابلّعْ ؤُجنَّا ثْڒَاثَا ن إِسڭّْوُوسَا ذ ستَّا ن إِيُورنْ، أَڒَامِي ثُوغَا ڒَاژْ إِمْغَارْ ذِي ثمُّورْثْ مَارَّا.  
\v 26 وَارْ د-إِتّْوَاسّكّْ إِلِييَا ؤُڒَا غَارْ إِشْثنْ زَّايْسنْثْ، مْغِيرْ غَارْ صَارْفَاثْ \add إِ إِدْجَانْ ذِي جّْوَايهْ\add* ن صَايْذُونْ، غَارْ إِشْثْ ن ثَاجَّاتْشْ.  
\v 27 ثُوغَا ذِينْ ذِي إِسْرَائِيل ذِي ڒْوقْثْ ن ؤُنَابِي إِلِيشَاعْ أَطَّاسْ ن إِوْذَانْ إِ ذِي إِدْجَا ڒْبَارْصْ، ؤُشَا ؤُڒَا ذ إِجّْ زَّايْسنْ وَارْ إِتّْوَاسِّيزْذِيڭْ مْغِيرْ نَاعْمَانْ زِي أَرَامْ وَاهَا.“ \x ◘ \xo 4:‏27 \xt 2 إِج. 5‏:‏14. \x*   
\m
\v 28 ؤُمِي سْڒِينْ أَيَا، تّْوَاشُّورنْ مَارَّا \add إِنِّي إِدْجَانْ\add* ذِي ثمْزِيذَا، س ثفْقحْثْ.  
\v 29 كَّارنْ، سُّوفّْغنْ ث بَارَّا إِ ثنْذِينْثْ، إِوْينْ ث غَارْ ثْقِيشّثْ ن وذْرَارْ إِ خفْ ثُوغَا ثبْنَا ثنْذِينْثْ نْسنْ، حِيمَا أَذْ ث نْضَارنْ زِي جَّارْفْ يُوعْڒَانْ.  
\v 30 مَاشَا نتَّا إِشُوقْ ذِي ڒْوسْطْ نْسنْ، إِرُوحْ.   
\b  
\m  
\s1 أَسُوفُّوغْ ن إِجّْ ن ڒَارْيَاحْ أَمنْڭُوسْ  
\m
\v 31 إِهْوَا غَارْ كَافَارْنَاحُومْ، إِشْثْ ن ثنْذِينْثْ ذِي لْجَالِيلْ، ثُوغَا إِسّڒْمَاذْ إِ-ثنْ ذڭْ وُوسَّانْ ن سّبْثْ. \x ◘ \xo 4:‏31 \xt [مك. 1‏:‏21‏-‏28] — مت. 4‏:‏13؛ مك. 1‏:‏21. \x*  
\v 32 ثْبهْثنْ س ؤُسڒْمذْ نّسْ، مِينْزِي أَوَاڒْ نّسْ ثُوغَا ث س صُّولْطَا. \x ◘ \xo 4:‏32 \xt مت. 7‏:‏29؛ مك. 1‏:‏22. \x*  
\v 33 ثُوغَا ذِي ثمْزِيذَا إِجّْ ن ورْيَازْ ذَايسْ بُوحْبڒْ ن إِجّْ ن شِّيطَانْ أَمنْڭُوسْ. نتَّا إِسْغُويُّو س جّهْذْ أَطَّاسْ، \x ◘ \xo 4:‏33 \xt مك. 1‏:‏23. \x*  
\v 34 إِنَّا: ”ثوّجْ \add خَافِي\add*! مِينْ ذِينْ جَارْ أَنغْ أَكِيذكْ، \add أَ\add* يَاسُوع نَّاصِيرِي؟ مَا ثُوسِيذْ-د \add ذَا\add* حِيمَا أَذْ أَنغْ ثثحِّيذْ؟ نشّْ سّْنغْ مِينْ ثعْنِيذْ، أَقَا شكْ ذ أَمْقدَّاسْ ن أَربِّي.“  
\v 35 إِوبّخْ إِ-ث يَاسُوع، إِنَّا أَسْ: ”سْقَارْ، فّغْ-د زَّايسْ!“ إِنْضَارْ إِ-ث شِّيطَانْ ذِي ڒْوسْطْ، إِفّغْ زَّايسْ، بْڒَا مَا أَذْ أَسْ إِسّخْسَارْ شَا.  
\v 36 يَارْسَا ؤُثبْهثْ خْ مَارَّا، ؤُشَا بْذَانْ سَّاوَاڒنْ جَارْ أَسنْ، نَّانْ: ”مَانَا أَوَاڒْ-أَ؟ أَقَا س صُّولْطَا ذ جّهْذْ إِتَّامَارْ ڒَارْيَاحْ إِمنْڭَاسْ، ؤُشَا فّْغنْ!“  
\v 37 إِفّغْ-د خَاسْ ڒخْبَارْ غَارْ مَارَّا جّْوَايهْ إِ ذ أَسْ د-إِنّْضنْ.   
\b  
\m  
\s1 أَسْڭنْفِي ن ثْضكّْوَاتْشْ ن بُوطْرُوسْ  
\m
\v 38 ڒَامِي د-إِفّغْ يَاسُوع زِي ثمْزِيذَا، يُوذفْ غَارْ ثَادَّارْثْ ن شِيمْعُونْ. ثُوغَا ثَاضكّْوَاتْشْ ن شِيمْعُونْ ذَايسْ ثِيمسِّي أَطَّاسْ ؤُ تَّارنْ زَّايسْ ذِي طّْوعْ نّسْ. \x ◘ \xo 4:‏38 \xt [مت. 8‏:‏14‏-‏17؛ مك. 1‏:‏29‏-‏34] — مت. 8‏:‏14؛ مك. 1‏:‏29. \x*  
\v 39 إِغْنسْ خَاسْ ؤُشَا إِوبّخْ ثِيمسِّي ؤُشَا ثجَّا خَاسْ \add ثْمسِّي\add*. ڒخْذنِّي ثكَّارْ، ثذْوڒْ ثتّْسخَّارْ خَاسنْ.   
\m
\v 40 ڒَامِي ثغْڒِي ثْفُوشْثْ، إِوْينْ-د غَارسْ مَارَّا إِنِّي ثُوغَا غَارْ إِدْجَا إِمهْڒَاشْ إِ ذِي إِدْجَا عْڒَامْ كُوڒْ ڒهْڒَاشَاثْ. ؤُشَا نتَّا إِسَّارْسْ أَفُوسْ نّسْ خْ كُوڒْ إِجّنْ زَّايْسنْ، إِسّْڭنْفَا إِ-ثنْ. \x ◘ \xo 4:‏40 \xt مت. 8‏:‏16؛ مك. 1‏:‏32؛ 7‏:‏32؛ 8‏:‏23، 25. \x*  
\v 41 ثُوغَا شّْوَاطنْ تّفّْغنْ-د عَاوذْ زڭْ وَاطَّاسْ إِذْسنْ، ثُوغَا سْغُويُّونْ، قَّارنْ: ”شكْ ذ لْمَاسِيحْ مِّيسْ ن أَربِّي!“ \add مَاشَا\add* إِوبّخْ إِ-ثنْ، وَارْ ثنْ إِجِّي أَذْ سِّيوْڒنْ، مِينْزِي سّْننْ بلِّي نتَّا ذ لْمَاسِيحْ. \x ◘ \xo 4:‏41 \xt مك. 1‏:‏34؛ 3‏:‏11. \x*   
\b  
\m  
\s1 أَبَارّحْ ن يَاسُوع ذِي ثمْزِيذَاوِينْ ن لْجَالِيلْ  
\m
\v 42 ڒَامِي ثُوغَا ذ أَزِيڒْ، إِفّغْ-د، إِرُوحْ غَارْ إِجّْ ن ومْشَانْ إِخْڒَانْ، ثُوغَا ڒْغَاشِي يَارزُّو خَاسْ، ؤُسِينْ-د غَارسْ ؤُشَا أَرزُّونْ أَذْ ث منّْعنْ، حِيمَا وَارْ خَاسنْ إِتّْرِيحْ. \x ◘ \xo 4:‏42 \xt [مك. 1‏:‏35‏-‏39] — مك. 1‏:‏35. \x*  
\v 43 إِنَّا أَسنْ يَاسُوع: ”أَقَا إِتّْخصَّا أَيِي أَذْ بَارّْحغْ عَاوذْ إِ ثْندَّامْ نّغْنِي س ثْڭلْذِيثْ ن أَربِّي، مِينْزِي إِ مَانْ أَيَا ؤُمِي د-تّْوَاسّكّغْ.“  
\v 44 ؤُشَا إِتّْبَارّحْ ذِي ثمْزِيذَاوِينْ ن لْجَالِيلْ.   
\b  
\b  
\m  
\c 5
\s1 ثَاڒَاغِيثْ ن يَاسُوع خْ إِمحْضَارنْ إِمزْوُورَا  
\m
\v 1 أَڒَامِي خَاسْ إِمُونْ ڒْغَاشِي حِيمَا أَذْ سْڒنْ إِ وَاوَاڒْ ن أَربِّي، \add أَمْ\add* ثُوغَا نتَّا إِبدّْ خْ ثْمَا ن ڒبْحَارْ ن جِينِّيسَارثْ، \x ◘ \xo 5:‏1 \xt [مت. 4‏:‏18‏-‏22؛ مك. 1‏:‏16‏-‏20] — مت. 13‏:‏2؛ مك. 4‏:‏1. \x*  
\v 2 إِژْرَا ثْنَاينْ ن ثْغَارُّوبَا بدّنْثْ خْ ثْمَا ن ڒبْحَارْ. إِنيْمَارنْ ن إِسڒْمَانْ فّْغنْ-د زَّايسْ، ثُوغَا سِّيرْذنْ ثِيرَاشِّيوِينْ.  
\v 3 إِشْثنْ زِي ثْغَارُّوبَا نِّي ثُوغَا ن شِيمْعُونْ بُوطْرُوسْ. إِنْيَا يَاسُوع ذِي ثْغَارَّابُوثْ، إِسّقْسَا ثنْ أَذْ أَڭّْوجنْ شْوَايْثْ خْ ثْمَا ن ڒْبَاڒْ غَارْ ڒبْحَارْ. خنِّي إِقِّيمْ، إِسّڒْمَاذْ ڒْغَاشِي زِي ثْغَارَّابُوثْ.   
\m
\v 4 ؤُمِي إِكمّڒْ أَوَاڒْ، إِنَّا إِ شِيمْعُونْ: ”رُوحمْ غَارْ ڒَادْجَاغْ، نْضَارمْ ثِيرَاشِّيوِينْ نْومْ إِ ثْنيْمَارْثْ.“  
\v 5 يَارَّا-د شِيمْعُونْ، إِنَّا أَسْ: ”\add أَ\add* أَمْسڒْمَاذْ إِنُو، أَقَا نُوحڒْ دْجِيڒثْ ثكْمڒْ، وَارْ نيْمَارْ وَالُو، مَاشَا خْ وَاوَاڒْ نّشْ أَذْ نْضَارغْ ثْرَاشَّا.“  
\v 6 ؤُمِي ڭِّينْ مَانْ أَيَا، طّْفنْ أَطَّاسْ ن إِسڒْمَانْ أَڒَامِي ذوْڒنْثْ ثْرَاشِّيوِينْ نْسنْ تّْشَارَّاڭنْثْ.  
\v 7 أَقَا شِييَّارنْ غَارْ إِمدُّوكَّاڒْ نْسنْ إِنِّي ثُوغَا ذِي ثْغَارَّابُوثْ نّغْنِي، حِيمَا أَذْ د-أَسنْ أَذْ ثنْ عَاوْننْ. نِيثْنِي ؤُسِينْ-د، ؤُشَا شُّورنْ ثْنَاينْ ن ثْغَارُّوبَا أَڒَامِي عْڒَاينْ أَذْ غَارْقنْثْ.   
\m
\v 8 أَڒَامِي إِژْرَا شِيمْعُونْ بُوطْرُوسْ مَانْ أَيَا، إِوْضَا غَارْ إِضَارنْ ن يَاسُوع، إِنَّا أَسْ: ”تّْزَاوْڭغْ شكْ، أَ سِيذِي، أَڭّْوجْ خَافِي، أَقَا نشّْ ذ بْنَاذمْ ذ أَمذْنُوبْ.“  
\v 9 إِثبْهثْ نتَّا ذ مَارَّا إِنِّي إِدْجَانْ أَكِيذسْ خْ ثْنيْمَارْثْ ن إِسڒْمَانْ إِ طّْفنْ،  
\v 10 ؤُڒَا ذ يَاعْقُوبْ ذ يُوحَانَّا، ثَارْوَا ن زَابْذِي، إِنِّي ثُوغَا ذ إِشْرِيشنْ ن شِيمْعُونْ. \add مَاشَا\add* يَاسُوع إِنَّا إِ شِيمْعُونْ: ”وَارْ تّڭّْوذْ شَا، زِي سَّا ذ ثْسَاونْثْ أَذْ ثَافذْ ثْيمَّارذْ إِوْذَانْ إِ ؤُسنْجمْ.“ \x ◘ \xo 5:‏10 \xt إِرْم. 16‏:‏16؛ حِز. 47‏:‏9؛ مت. 4‏:‏19؛ مك. 1‏:‏17. \x*  
\v 11 نِيثْنِي إِوْينْ-د ثِيغَارُّوبَا غَارْ ڒْبَارّْ، جِّينْ كُوڒْشِي ؤُشَا ضْفَارنْ ث. \x ◘ \xo 5:‏11 \xt مت. 4‏:‏20؛ 19‏:‏27؛ مك. 10‏:‏28؛ لك. 18‏:‏28. \x*   
\b  
\m  
\s1 أَسْڭنْفِي ن إِجّْ ن ورْيَازْ إِ ذِي إِدْجَا ڒْبَارْصْ  
\m
\v 12 ؤُمِي ثُوغَا يَاسُوع ذڭْ إِشْثنْ زِي ثْندَّامْ \add نِّي\add*، يُوسَا-د \add غَارسْ\add* إِجّْ ن ورْيَازْ إِڒْقفْ إِ-ث مَارَّا ڒْبَارْصْ. ؤُمِي إِژْرَا نتَّا يَاسُوع، إِوْضَا خْ ؤُغمْبُوبْ نّسْ ؤُشَا إِزَاوڭْ إِ-ث، إِنَّا: ”أَ سِيذِي إِنُو، مَاڒَا ثخْسذْ، ثْزمَّارذْ أَذْ أَيِي ثسِّيزْذڭذْ!“ \x ◘ \xo 5:‏12 \xt [مت. 8‏:‏1‏-‏4؛ مك. 1‏:‏40‏-‏45] — مت. 8‏:‏2؛ مك. 1‏:‏40. \x*  
\v 13 إِسّْوِيژّضْ يَاسُوع س ؤُفُوسْ نّسْ غَارسْ، إِحَاذَا ث، إِنَّا: ”نشّْ خْسغْ، إِڒِي ثِيزْذِيڭذْ!“ ڒخْذنِّي إِرُوحْ خَاسْ ڒْبَارْصْ.  
\v 14 يُومُورْ إِ-ث: ”وَارْ ثقَّارْ إِ حذْ، مَاشَا رُوحْ، سْشنْ إِخفْ نّشْ إِ ؤُكهَّانْ، أوْشْ ثَاوْهِيبْثْ خْ ؤُسِيزْذڭْ نّشْ، أَمْ مَامّشْ \add ث\add* يُومُورْ مُوسَا، ذ شّْهَاذثْ إِ نِيثْنِي.“ \x ◘ \xo 5:‏14 \xt لَاوِي 13‏:‏2؛ 14‏:‏2؛ مت. 8‏:‏4. \x*  
\v 15 شّنْعثْ نّسْ ثُويُورْ مَانِي مَا كْثَارْ عَاذْ ؤُشَا إِنّيْرُو ڒْغَاشِي أَطَّاسْ، حِيمَا أَذْ أَسْ سْڒنْ ؤُ حِيمَا أَذْ زَّايسْ تّْوَاسّْڭنْفَانْ زِي ڒهْڒَاشَاثْ نْسنْ.  
\v 16 مَاشَا نتَّا إِفّغْ-د غَارْ ڒخْڒَا، إِتّْژَادْجْ ذِينْ.   
\b  
\m  
\s1 أَسْڭنْفِي ن إِجّْ ن ورْيَازْ ذ أَنعْضَابْ  
\m
\v 17 ذڭْ إِجّْ ن وَاسّْ زڭْ وُوسَّانْ نِّي أَمْ ثُوغَا يَاسُوع إِسّڒْمَاذْ، قِّيمنْ \add ذِينْ\add* إِفَارِيسِييّنْ ذ إِمْسڒْمَاذنْ ن شَّارِيعَا إِنِّي د-يُوسِينْ زِي مَارَّا ذْشُورَاثْ ن لْجَالِيلْ ذ يَاهُوذِييَّا ؤُ زِي ؤُرْشَالِيمْ. ثُوغَا ذِينْ جّهْذْ ن سِيذِي مَاحنْذْ أَذْ ثنْ إِڭّنْفَا. \x ◘ \xo 5:‏17 \xt [مت. 9‏:‏1‏-‏8؛ مك. 2‏:‏1‏-‏12] \x*  
\v 18 خنِّي إِوْينْ-د إِجّْ ن ؤُنعْضَابْ خْ ثَاسُّوثْ ثُوغَا أَرزُّونْ أَذْ ث سِّيذْفنْ غَارْ ذَاخڒْ، مَاحنْذْ أَذْ ث سَّارْسنْ زَّاثسْ. \x ◘ \xo 5:‏18 \xt مت. 9‏:‏1؛ مك. 2‏:‏3؛ ڒخ. 9‏:‏33. \x*  
\v 19 ؤُمِي وَارْ ؤُفِينْ مَانِيسْ ث إِ غَا سِّيذْفنْ زِي سِّيبّثْ ن ڒْغَاشِي، ڭعّْذنْ خْ ثْزقَّا ؤُشَا سيّْبنْ ث زڭْ ؤُقَارْمُوذْ غَارْ وَادَّايْ أَكْ-ذ ثَاسُّوثْ \add نِيشَانْ\add* غَارْ ڒْوسْطْ، زَّاثْ إِ يَاسُوع.  
\v 20 ؤُمِي إِژْرَا يَاسُوع لْ-إِيمَانْ نْسنْ، إِنَّا إِ ؤُنعْضَابْ نِّي: ”\add أَ\add* بْنَاذمْ، دّْنُوبْ نّشْ تّْوَاغْفَارنْ أَشْ.“   
\m
\v 21 بْذَانْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ تّْخَارَّاصنْ، نَّانْ: ”مِينْ إِعْنَا وَا، ڒَامِي نتَّا إِتّْشقَّافْ \add أَمُّو\add*. وِي إِزمَّارنْ أَذْ إِغْفَارْ دّْنُوبْ مْغِيرْ أَربِّي وحّْذسْ؟“ \x ◘ \xo 5:‏21 \xt إِزهد. 32‏:‏5؛ إِشا. 43‏:‏25. \x*  
\v 22 \add مَاشَا\add* يَارْڭبْ يَاسُوع خْ إِخَارِّيصنْ نْسنْ، ؤُشَا نتَّا إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا أَسنْ: ”مِينْ ثتّْخَارَّاصمْ ذڭْ وُوڒَاونْ نْومْ؟  
\v 23 مِينْ إِهوْننْ أَذْ إِنِيغْ: ’تّْوَاغْفَارنْ دّْنُوبْ نّشْ!‘ نِيغْ أَذْ إِنِيغْ: ’كَّارْ، ؤُيُورْ‘؟  
\v 24 مَاشَا حِيمَا أَذْ ثسّْنمْ بلِّي مِّيسْ ن بْنَاذمْ غَارسْ صُّولْطَا خْ ثمُّورْثْ، حِيمَا أَذْ إِغْفَارْ دّْنُوبْ - إِنَّا إِ ؤُنعْضَابْ - إِ شكْ ؤُمِي غَا إِنِيغْ، كَّارْ، كْسِي ثَاسُّوثْ نّشْ ؤُشَا رُوحْ غَارْ ثَادَّارْثْ نّشْ!“  
\v 25 ڒخْذنِّي إِكَّارْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ، إِكْسِي ثَاسُّوثْ نّسْ ؤُشَا إِرُوحْ غَارْ ثَادَّارْثْ نّسْ، إِسّمْغَارَا ذِي أَربِّي.  
\v 26 أَثبْهثْ إِهْوَا-د خْ مَارَّا إِوْذَانْ، سّمْغَارَانْ ذِي أَربِّي ؤُشَا ثُوذفْ إِ-ثنْ ثِيڭّْوُوذِي، نَّانْ: ”أَقَا أَسّْ-أَ نژْرَا ڒعْجَايبْ!“   
\b  
\m  
\s1 ثَاڒَاغِيثْ ن يَاسُوع خْ مَاتَّا لَاوِي  
\m
\v 27 أَوَارْنِي مَانْ أَيَا إِفّغْ يَاسُوع، إِژْرَا إِجّْ ن بُو-ضَّارِيبَا، قَّارنْ أَسْ لَاوِي، إِقِّيمْ ذڭْ ومْشَانْ ن ضَّارِيبَا، إِنَّا أَسْ: ”ضْفَارْ أَيِي-د!“ \x ◘ \xo 5:‏27 \xt [مت. 9‏:‏9‏-‏13؛ مك. 2‏:‏13‏-‏17] — مت. 9‏:‏9؛ مك. 2‏:‏14، 15. \x*  
\v 28 إِجَّا كُوڒْشِي، إِكَّارْ ؤُشَا إِضْفَارْ إِ-ث-إِ-د.   
\m
\v 29 إِسّْنوْجِي أَسْ لَاوِي إِجّْ ن ؤُسْنوْجِي ذ أَمقّْرَانْ ذِي ثَادَّارْثْ نّسْ، ؤُشَا إِنِّي أَكِيذسْ إِقِّيمنْ \add غَارْ طَّابْڒَا\add* ثُوغَا أَثنْ ذڭْ وَاطَّاسْ ن ڒْغَاشِي زڭْ أَيْثْ ن ضَّارِيبَا ذ إِنّغْنِي. \x ◘ \xo 5:‏29 \xt مت. 9‏:‏10؛ مك. 2‏:‏15؛ لك. 15‏:‏1. \x*  
\v 30 \add مَاشَا\add* إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ شثْشَانْ، نَّانْ إِ إِمحْضَارنْ نّسْ: ”مَايمِّي ثتّتّمْ، ثسّسّمْ أَكْ-ذ أَيْثْ ن ضَّارِيبَا ذ إِمذْنَابْ؟“  
\v 31 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”إِنِّي إِصحّنْ وَارْ حْذِيجنْ شَا أَضْبِيبْ، مَاشَا إِمهْڒَاشْ وَاهْ.  
\v 32 وَارْ د-ؤُسِيغْ أَذْ ڒَاغِيغْ خْ إِمْسڭَّاذنْ، مَاشَا خْ إِمذْنَابْ غَارْ تُّوبثْ.“ \x ◘ \xo 5:‏32 \xt مت. 9‏:‏13؛ لك. 19‏:‏10؛ 1 تِيم. 1‏:‏15. \x*   
\b  
\m  
\s1 أَسقْسِي خْ ؤُژُومِّي  
\m
\v 33 نَّانْ أَسْ: ”مَايمِّي ثْژُومَّانْ ؤُ تّْژَادْجَانْ إِمحْضَارنْ ن يُوحَانَّا أَطَّاسْ، ؤُڒَا ذ يِينِّي ن إِفَارِيسِييّنْ، مَاشَا إِنِّي نّشْ تّتّنْ، سسّنْ؟“ \x ◘ \xo 5:‏33 \xt [مت. 9‏:‏14‏-‏17؛ مك. 2‏:‏18‏-‏22] — مت. 9‏:‏14. \x*  
\v 34 إِنَّا أَسنْ: ”مَا ثخْسمْ أَذْ ثجّمْ أَيْثْ ن ؤُمُوڒَايْ أَذْ ژُومّنْ مَاڒَا أَمُوڒَايْ أَقَا-ث \add عَاذْ\add* أَكِيذْسنْ! \x ◘ \xo 5:‏34 \xt إِشا. 62‏:‏5؛ 2 كُور. 11‏:‏2. \x*  
\v 35 مَاشَا أَذْ د-أَوْضنْ وُوسَّانْ خْمِي خَاسنْ غَا إِتّْوَامّكْسِي ؤُمُوڒَايْ، ڒخْذنِّي أَذْ ژُومّنْ ذڭْ وُوسَّانْ نِّي.“   
\m
\v 36 إِنَّا أَسنْ عَاوذْ إِجّْ ن ؤُمذْيَا: ”وَارْ ذِينْ حذْ إِشَارّڭْ ثَانقِّيتْشْ زڭْ وَارُّوضْ ن جْذِيذْ، ؤُشَا إِتّڭّْ إِ-ت خْ وَارُّوضْ أَبُوڒَايْ، حِيمَا وَارْ ثتَّارِّي ثْنقِّيتْشْ ن جْذِيذْ أَذْ ثْشَارّڭْ أَبُوڒَايْ، مِينْزِي ثَانقِّيتْشْ ن جْذِيذْ وَارْ ثتّْڒِيقِي أَبُوڒَايْ.  
\v 37 ؤُشَا وَارْ إِدْجِي حذْ إِتّڭّْ بِينُو ن جْذِيذْ ذِي ثْخُونْشَايْ ثِيقْذِيمِينْ ن يِيڒمْ، حِيمَا بِينُو ن جْذِيذْ وَارْ إِتّْشَارِّيڭْ شَا ثِيخُونْشَايْ ؤُشَا أَذْ إِزدْجعْ بِينُو، أَذْ ضيّْعنْثْ ثْخُونْشَايْ. \x ◘ \xo 5:‏37 \xt مت. 9‏:‏17؛ مك. 2‏:‏22. \x*  
\v 38 مَاشَا تّڭّنْ بِينُو ن جْذِيذْ ذِي ثْخُونْشَايْ ن جْذِيذْ ؤُشَا أَذْ خمّْڒنْ س ثْيُويَا.  
\v 39 ؤُڒَا ذ إِجّْ، مَاڒَا إِسْوَا أَقْذِيمْ، وَارْ إِتّخْسْ عَاذْ ڒخْذنِّي جْذِيذْ، مِينْزِي نتَّا أَذْ يِينِي: ’أَقْذِيمْ إِتّْفُوحْ!‘ “   
\b  
\b  
\m  
\c 6
\s1 يَاسُوع ذ بَابْ ن سّبْثْ  
\m
\v 1 إِمْسَارْ ذِي سّبْثْ أَقَا يَاسُوع يُويُورْ ذڭْ إِيَّارنْ ن زَّارِيعثْ ن إِمنْذِي. ثُوغَا إِمحْضَارنْ نّسْ ڒقّْضنْ ثِيذْرِينْ، تّْحكَّانْ ثنْثْ س إِفَاسّنْ نْسنْ، تّتّنْ \add ثنْثْ\add*. \x ◘ \xo 6:‏1 \xt [مت. 12‏:‏1‏-‏8؛ مك. 2‏:‏23‏-‏28] — أَعَوذ. 23‏:‏24؛ مت. 12‏:‏1؛ مك. 2‏:‏23. \x*  
\v 2 شَا ن إِفَارِيسِييّنْ نَّانْ أَسنْ: ”مَايمِّي ثتّڭّمْ مِينْ وَارْ إِحدْجْڒنْ أَذْ إِتّْوَاڭّْ ذِي سّبْثْ؟“ \x ◘ \xo 6:‏2 \xt ؤُف. 20‏:‏10. \x*  
\v 3 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”مَا وَارْ ثغْرِيمْ مِينْ إِڭَّا ذَاوُوذْ ؤُمِي إِدْجُوژْ نتَّا ذ يِينِّي أَكِيذسْ؟ \x ◘ \xo 6:‏3 \xt 1 صم. 21‏:‏1‏-‏6\x*  
\v 4 مَامّشْ يُوذفْ غَارْ ثَادَّارْثْ ن أَربِّي، إِكْسِي أَغْرُومْ ن وسْشَانْ إِ إِدْجَانْ خْ ثْزوْضَا ن سِيذِي إِ وَارْ إِحدْجْڒنْ مَاشَّا نّسْ مْغِيرْ إِ إِكهَّاننْ وَاهَا، ؤُشَا إِشَّا \add زَّايسْ\add* ؤُ إِوْشَا عَاوذْ إِ يِينِّي ثُوغَا إِدْجَانْ أَكِيذسْ؟“  
\v 5 \add خنِّي\add* إِنَّا أَسنْ: ”أَقَا مِّيسْ ن بْنَاذمْ ذ بَابْ ن سّبْثْ.“ \x ◘ \xo 6:‏5 \xt مت. 12‏:‏8؛ مك. 2‏:‏28. \x*   
\b  
\m  
\s1 أَسْڭنْفِي ن إِجّْ ن ورْيَازْ ذڭْ وَاسّْ ن سّبْثْ  
\m
\v 6 ذڭْ إِجّْ ن \add وَاسّْ ن\add* سّبْثْ نّغْنِي يُوذفْ \add يشُّو\add* غَارْ ثمْزِيذَا، إِبْذَا إِسّْغَارَا. ثُوغَا ذِينْ إِجّْ ن بْنَاذمْ ونِّي ؤُمِي أَفُوسْ نّسْ إِقُوشّحْ. \x ◘ \xo 6:‏6 \xt [مت. 12‏:‏9‏-‏14؛ مك. 3‏:‏1‏-‏6] — مت. 12‏:‏9؛ مك. 3‏:‏1. \x*  
\v 7 حْضَانْ ث إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، مَا أَذْ إِسّْڭنْفَا ذِي سّبْثْ، حِيمَا أَذْ خَاسْ أَفنْ شَا ن تُّوهْمثْ.  
\v 8 مَاشَا نتَّا يَارْڭبْ خْ إِخَارِّيصنْ نْسنْ ؤُشَا إِنَّا إِ بْنَاذمْ ونِّي ؤُمِي إِقُوشّحْ ؤُفُوسْ نّسْ: ”كَّارْ، بدّْ ذِي ڒْوسْطْ ن ثمْزِيذَا.“ ؤُمِي إِكَّارْ ؤُ ثُوغَا إِبدّْ \add ذِينْ\add*،  
\v 9 إِنَّا أَسنْ يَاسُوع: ”أَذْ كنِّيوْ سّقْسِيغْ خْ مِينْ إِحدْجْڒنْ أَذْ إِتّْوَاڭّْ ذِي سّبْثْ. \add مَا إِحدْجڒْ إِ بْنَاذمْ مَاحنْذْ\add* أَذْ إِڭّْ ڒْخَارْ نِيغْ ڒْغَارْ، أَذْ إِسّنْجمْ إِجّْ ن ڒعْمَارْ نِيغْ أَذْ \add ث\add* يَاردّدْجْ؟“  
\v 10 ثُوغَا إِخزَّارْ غَارْ مَارَّا إِنِّي ذ أَسْ د-إِنّْضنْ، إِنَّا أَسْ \add إِ بْنَاذمْ نِّي\add*: ”سْوِيژّضْ أَفُوسْ نّشْ!“ إِسّْوِيژّضْ نتَّا أَفُوسْ نّسْ ؤُشَا إِذْوڒْ ؤُفُوسْ نّسْ إِصحّْ أَمْ ونّغْنِي. \x ◘ \xo 6:‏10 \xt 1 إِج. 13‏:‏6؛ مت. 12‏:‏13؛ مك. 3‏:‏5\x*  
\v 11 \add مَاشَا\add* نِيثْنِي ذوْڒنْ شُّورنْ س زّْعَافْ ؤُشَا سِّيوْڒنْ جَارْ أَسنْ خْ مِينْ غَا ڭّنْ إِ يَاسُوع.   
\b  
\m  
\s1 ڒِيخْضَارثْ ن ثنْعَاشْ ن رُّوسُولْ  
\m
\v 12 إِمْسَارْ ذڭْ وُوسَّانْ نِّي، أَقَا إِفّغْ يَاسُوع غَارْ إِجّْ ن وذْرَارْ، حِيمَا أَذْ إِژَّادْجْ ؤُشَا إِسّعْذُو ذِينْ دْجِيڒثْ ثكْمڒْ، إِتّْژَادْجْ إِ أَربِّي. \x ◘ \xo 6:‏12 \xt [مت. 10‏:‏1‏-‏4؛ مك. 3‏:‏13‏-‏19] \x*  
\v 13 ؤُمِي ثُوغَا ذ أَزِيڒْ، إِڒَاغَا-د إِ إِمحْضَارنْ نّسْ، ؤُشَا إِخْضَارْ زَّايْسنْ ثنْعَاشْ، إِسمَّا ثنْ رُّوسُولْ. \f ◼ \fr 6:‏13 \ft \+bd ’رُّوسُولْ‘\+bd* - نِيغْ ’إِمَازَاننْ‘.\f*  \x ◘ \xo 6:‏13 \xt مت. 10‏:‏1؛ مك. 3‏:‏13؛ 6‏:‏7؛ لك. 9‏:‏1. \x*  
\v 14 شِيمْعُونْ، ونِّي إِتّْكنَّانْ بُوطْرُوسْ، \add ’أَژْرُو‘\add*، ذ أَنْذْرَاوُوسْ ؤُمَاسْ، ذ يَاعْقُوبْ ذ يُوحَانَّا، ذ فِيلِيبُّوسْ ذ بَارْ-ثُولُومَاوُوسْ  
\v 15 ذ مَاتَّا ذ ثُومَا ذ يَاعْقُوبْ، مِّيسْ ن حَالْفَا، ذ شِيمْعُونْ ونِّي ؤُمِي تّْكنَّانْ ’أَمْعسَّابْ‘،  
\v 16 يَاهُوذَا، مِّيسْ ن يَاعْقُوبْ، ذ يَاهُوذَا إِسْخَارِييُوطِي ونِّي إِدْجَانْ ذ أَغدَّارْ.   
\b  
\m  
\s1 يَاسُوع إِسّڒْمَاذْ ؤُ إِسّْڭنْفَا  
\m
\v 17 إِهْوَا-د يَاسُوع أَكِيذْسنْ ؤُشَا إِبدّْ ذِي ڒوْضَا. ثُوغَا أَكِيذسْ إِجّْ ن ؤُبَارُّو ن إِمحْضَارنْ نّسْ ذ إِجّْ ن ؤُبَارُّو ن إِوْذَانْ زِي مَارَّا يَاهُوذِييَّا ذ ؤُرْشَالِيمْ ؤُ زِي ثْمَا ن ڒبْحَارْ غَارْ صُورْ ذ صَايْذُونْ. \x ◘ \xo 6:‏17 \xt [مت. 4‏:‏23‏-‏25؛ 5‏:‏1‏-‏12] — مت. 4‏:‏25؛ مك. 3‏:‏7. \x*  
\v 18 نِيثْنِي ؤُسِينْ-د حِيمَا أَذْ أَسْ سْڒنْ ؤُ أَذْ تّْوَاسّْڭنْفَانْ زِي ڒهْڒَاشْ نْسنْ، \add ثُوغَا أَكِيذْسنْ\add* ؤُڒَا ذ إِنِّي إِتّْوَاغزَّانْ زِي ڒَارْيَاحْ إِمنْڭَاسْ، ؤُشَا تّْوَاسّْڭنْفَانْ.  
\v 19 مَارَّا ڒْغَاشِي ثُوغَا إِتّخْسْ أَذْ ث إِحَاذَا، مِينْزِي ثُوغَا إِتّفّغْ-د زَّايسْ جّهْذْ نِّي إِسّْڭنْفَانْ كُوڒْشِي. \x ◘ \xo 6:‏19 \xt مك. 5‏:‏30. \x*   
\b  
\m  
\s1 لْبَارَاكَا ذ نّعْڒثْ  
\m
\v 20 إِسّْڭعّذْ ثِيطَّاوِينْ نّسْ غَارْ إِمحْضَارنْ نّسْ، إِنَّا:  
\b  
\m \qt ”سّعْذْ نْومْ، \+tl كنِّيوْ، أَ\+tl* إِمزْڒَاضْ،\qt*  
\m \qt مِينْزِي ثَاڭلْذِيثْ ن أَربِّي إِ كنِّيوْ.\qt* \x ◘ \xo 6:‏20 \xt مت. 5‏:‏2. \x*   
\m
\v 21 \qt سّعْذْ نْومْ، \+tl كنِّيوْ،\+tl* إِنِّي إِدْجُوژنْ ڒخُّو،\qt*  
\m \qt مِينْزِي كنِّيوْ أَذْ ثتّْوَاسّْجِيوْنمْ.\qt*  
\m \qt سّعْذْ نْومْ، \+tl كنِّيوْ،\+tl* إِنِّي إِتّْرُونْ ڒخُّو،\qt*  
\m \qt مِينْزِي كنِّيوْ أَذْ ثْضحْشمْ.\qt*\x ◘ \xo 6:‏21 \xt إِشا. 61‏:‏3؛ 65‏:‏13؛ 66‏:‏10. \x*   
\m
\v 22 \qt سّعْذْ نْومْ، ؤُمِي كنِّيوْ شَارّْهنْ إِوْذَانْ،\qt*  
\m \qt تَّاژّْڒنْ خَاومْ، تّكّْوَارنْ كنِّيوْ،\qt*  
\m \qt ؤُشَا سّْفطَّاحنْ زڭْ يِيسمْ نْومْ\qt*  
\m \qt خْ سِّيبّثْ ن مِّيسْ ن بْنَاذمْ.\qt*\x ◘ \xo 6:‏22 \xt مت. 5‏:‏11؛ 1 بُط. 2‏:‏19؛ 3‏:‏14؛ 4‏:‏14. \x*   
\m
\v 23 \qt فَارْحمْ ذڭْ وَاسّْ نِّي، نڭْزمْ س ڒفْرَاحثْ،\qt*  
\m \qt مِينْزِي، أَقَا ڒَاجَارْ نْومْ إِمْغَارْ ذڭْ ؤُجنَّا،\qt*  
\m \qt مِينْزِي أَمُّو ثُوغَا تّڭّنْ\qt*  
\m \qt ڒجْذُوذْ نْسنْ ذڭْ إِنَابِييّنْ.\qt* \x ◘ \xo 6:‏23 \xt ڒخ. 5‏:‏41؛ 7‏:‏51. \x*   
\m
\v 24 \qt مَاشَا ؤُشْثْ خَاومْ، \+tl كنِّيوْ،\+tl* أَيْثْبَابْ ن وَاڭْڒَا،\qt*  
\m \qt مِينْزِي أَقَا ثطّْفمْ أَفوّجْ نْومْ.\qt*\x ◘ \xo 6:‏24 \xt عَام. 6‏:‏1، 8. \x*   
\m
\v 25 \qt ؤُشْثْ خَاومْ، \+tl كنِّيوْ،\+tl* إِنِّي إِجِّيوْننْ،\qt*  
\m \qt مِينْزِي أَذْ ثْدْجَاژمْ.\qt*  
\m \qt ؤُشْثْ خَاومْ، \+tl كنِّيوْ\+tl* إِنِّي إِضحّْشنْ ڒخُّو،\qt*  
\m \qt مِينْزِي أَذْ ثْشضْنمْ، أَذْ ثْرُومْ.\qt* \x ◘ \xo 6:‏25 \xt إِشا. 65‏:‏13؛ يَاع. 4‏:‏9؛ 5‏:‏1. \x*   
\m
\v 26 \qt ؤُشْثْ خَاومْ ؤُمِي إِوْذَانْ أَذْ خَاومْ سِّيوْڒنْ مْلِيحْ،\qt*  
\m \qt مِينْزِي أَمُّو ثُوغَا تّڭّنْ ڒجْذُوذْ نْسنْ\qt*  
\m \qt أَكْ-ذ إِنَابِييّنْ إِسّْخَارِّيقنْ.“\qt*   
\b  
\m  
\s1 ثَايْرِي إِ ڒْعذْيَانْ  
\m
\v 27 ”مَاشَا نشّْ أَذْ أَومْ إِنِيغْ، إِ يِينِّي إِتّسْڒَانْ: خْسمْ ڒْعذْيَانْ نْومْ، ثْهِيلَّامْ ذڭْ إِنِّي كنِّيوْ إِشَارّْهنْ، \x ◘ \xo 6:‏27 \xt [مت. 5‏:‏38‏-‏48؛ 7‏:‏12] — ؤُف. 23‏:‏4؛ أَوڒن. 25‏:‏21؛ مت. 5‏:‏44؛ رُوم. 12‏:‏20؛ 1 كُور. 4‏:‏12. \x*  
\v 28 بَارْكمْ إِ يِينِّي كنِّيوْ إِنعّْڒنْ ؤُ ژَتدْجمْ خْ يِينِّي خَاومْ إِتّْعدَّانْ. \x ◘ \xo 6:‏28 \xt لك. 23‏:‏34؛ ڒخ. 7‏:‏60. \x*  
\v 29 إِ ونِّي شكْ إِوْثِينْ غَارْ ؤُمڭِّيزْ، أَرّْ أَسْ-د س ونّغْنِي، ؤُ ونِّي ذ أَشْ غَا إِكّْسنْ أَجدْجَابْ، وَارْ ث تّطّفْ أَذْ إِكْسِي ؤُڒَا ذ ثْشَامِيرْ نّشْ. \x ◘ \xo 6:‏29 \xt مت. 5‏:‏40؛ 1 كُور. 6‏:‏7. \x*  
\v 30 مَارَّا ونِّي ذ أَشْ غَا إِتَّارنْ، أوْشْ أَسْ ث، ؤُ ونِّي إِ غَا إِكْسِينْ مِينْ إِدْجَانْ نّشْ، وَارْ ذ أَسْ \add ث\add* تّتَّارْ. \x ◘ \xo 6:‏30 \xt أَعَوذ. 15‏:‏7؛ مت. 5‏:‏42. \x*  
\v 31 أَمْ مَامّشْ ثخْسذْ أَذْ أَومْ ڭّنْ إِوْذَانْ، ڭّمْ ؤُڒَا ذ كنِّيوْ ذَايْسنْ أَمنِّي. \x ◘ \xo 6:‏31 \xt مت. 7‏:‏12. \x*  
\v 32 مَاڒَا ثخْسمْ غَارْ يِينِّي كنِّيوْ إِتّخْسنْ، مَانْ ثْشُونِي إِ غَارْومْ. أَقَا ؤُڒَا ذ إِمذْنَابْ تّخْسنْ إِنِّي إِ ثنْ إِتّخْسنْ. \x ◘ \xo 6:‏32 \xt مت. 5‏:‏46. \x*  
\v 33 مَاڒَا ثڭّمْ ڒْخَارْ إِ يِينِّي ذ أَومْ إِتّڭّنْ ڒْخَارْ، مَانْ ثْشُونِي إِ غَارْومْ. أَقَا ؤُڒَا ذ إِمذْنَابْ تّڭّنْ أَمنِّي.  
\v 34 ؤُ مَاڒَا ثَارْضْڒمْ إِ إِوْذَانْ إِ زِي ثتّْرَاجَامْ أَذْ أَومْ د-أَرّنْ، مَانْ ثْشُونِي إِ غَارْومْ؟ أَقَا ؤُڒَا ذ إِمذْنَابْ أَرْضْڒنْ إِ إِمذْنَابْ، حِيمَا أَذْ أَسنْ د-إِذْوڒْ أَمنِّي عَاوذْ. \x ◘ \xo 6:‏34 \xt أَعَوذ. 15‏:‏8؛ مت. 5‏:‏42. \x*  
\v 35 مَاشَا خْسمْ ڒْعذْيَانْ نْومْ، ڭّمْ ذ أَسنْ ثْشُونِي، أَرْضْڒمْ، وَارْ ثْقطّْعمْ ڒَايَاسْ إِ شَا ن يِيجّنْ. خنِّي أَذْ يِيڒِي ڒَاجَارْ نْومْ إِمْغَارْ، أَذْ ثِيڒِيمْ ذ ثَارْوَا ن ؤُمْعُودْجِي خْ كُوڒْشِي، مِينْزِي أَقَا إِتّڭّْ س تَّاسِيعْ نْ ڒْخَاضَارْ أَكْ-ذ إِعفَّاننْ ذ يِينِّي وَارْ ث إِشكَّارنْ. \x ◘ \xo 6:‏35 \xt مت. 5‏:‏45. \x*   
\m
\v 36 أَرحْممْ أَمْ مَامّشْ إِدْجَا بَابَاثْومْ ذ أَرْحِيمْ.  
\v 37 وَارْ حكّمْ، وَارْ ثتّْوَاحَاكَاممْ. وَارْ تّْحَاسَابمْ، وَارْ ثتّْوَاحَاسْبمْ. غْفَارمْ، أَذْ أَومْ إِتّْوَاغْفَارْ. \x ◘ \xo 6:‏37 \xt مت. 7‏:‏1؛ رُوم. 2‏:‏1؛ 1 كُور. 4‏:‏5. \x*   
\m
\v 38 وْشمْ، أَذْ أَومْ إِمّوْشْ، أَذْ نْضَارنْ إِجّْ ن ڒْمُوذْ إِشْنَا، إِذقّسْ، إِتّْوَاسّنْهزّْ، إِفيّضْ ذڭْ وحْسِينْ نْومْ. مِينْزِي س ڒْمُوذْ إِ زِي غَا ثْوزْنمْ كنِّيوْ، أَذْ زَّايسْ ثتّْوَاوزْنمْ ؤُڒَا ذ كنِّيوْ.“ \x ◘ \xo 6:‏38 \xt أَوڒن. 10‏:‏22؛ 19‏:‏17؛ مت. 7‏:‏2؛ مك. 4‏:‏24. \x*   
\m  
\s1 أَمذْيَا ن ؤُخشِّيوْ ذ ثحْنَاشْثْ  
\m
\v 39 نتَّا إِنَّا أَسنْ إِجّْ ن ؤُمذْيَا: ”مَا إِزمَّارْ ؤُذَارْغَاڒْ أَذْ إِنْذهْ أَذَارْغَاڒْ؟ مَا وَارْ وطِّينْ س ثْنَاينْ إِذْسنْ ذڭْ وحْفُورْ؟ \x ◘ \xo 6:‏39 \xt [مت. 7‏:‏1‏-‏5] — إِشا. 42‏:‏19؛ مت. 15‏:‏14. \x*  
\v 40 أَمحْضَارْ وَارْ إِدْجِي شَا حْسنْ زڭْ ؤُمْسڒْمَاذْ نّسْ، مَاشَا كُوڒْ أَمحْضَارْ نِيشَانْ أَذْ يِيڒِي أَمْ ؤُمْسڒْمَاذْ نّسْ. \x ◘ \xo 6:‏40 \xt مت. 10‏:‏24؛ يُوح. 13‏:‏16؛ 15‏:‏20. \x*  
\v 41 مَايمِّي ثْخزَّارذْ غَارْ ؤُخشِّيوْ، ثنِّي ذِي ثِيطّْ ن ؤُمَاشْ، مَاشَا ثَاحْنَاشْثْ، ثنِّي ذِي ثِيطّْ نّشْ، وَارْ كِيسْ ثڒْهِيذْ؟ \x ◘ \xo 6:‏41 \xt مت. 7‏:‏3. \x*  
\v 42 مَامّشْ ثتّڭّذْ ثقَّارذْ إِ ؤُمَاشْ: ’ؤُمَا، أجّْ أَيِي أَذْ أَشْ د-سُّوفّْغغْ أَخشِّيوْ إِ ذَايكْ ذِي ثِيطّْ نّشْ!‘، ؤُ خْزَارْ، شكْ سِيمَانْثْ نّشْ وَارْ ثتّْوِيڒِيذْ شَا ثَاحْنَاشْثْ إِ غَاركْ ذِي ثِيطّْ نّشْ. \add شكْ، أَ\add* أَمْنَافقْ، سُوفّغْ-د أَمزْوَارُو ثَاحْنَاشْثْ نِّي غَاركْ ذِي ثِيطّْ نّشْ، خنِّي أَذْ ثتّْوَاڒِيذْ \add مْلِيحْ\add* مَاحنْذْ أَذْ ثسُّوفّْغذْ أَخشِّيوْ زِي ثِيطّْ ن ؤُمَاشْ.“   
\b  
\m  
\s1 ثَاشجَّارْثْ ذ ڒْغِيدْجثْ نّسْ  
\m
\v 43 ”وَارْ ذِينْ بُو ثْشجَّارْثْ ثَاصبْحَانْثْ إِ د-إِسّْغمَّاينْ ڒْغِيدْجثْ ثخْسَارْ، نِيغْ ثَاشجَّارْثْ إِخْسَارنْ إِ د-إِسّْغمَّاينْ ڒْغِيدْجثْ ثَاصبْحَانْثْ. \f ◼ \fr 6:‏43 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  \x ◘ \xo 6:‏43 \xt [مت. 7‏:‏17‏-‏20؛ 12‏:‏34‏-‏35] — مت. 7‏:‏17؛ 12‏:‏33. \x*  
\v 44 مِينْزِي كُوڒْ ثَاشجَّارْثْ ثتّْوَاسّنْ س ڒْغِيدْجثْ نّسْ، مِينْزِي وَارْ يْرُونْ زڭْ إِسنَّاننْ ڒْبَاشُورْ، ؤُ وَارْ ڒقّْضنْ أَضِيڒْ زِي شْبَارْقْ أَكْ-ذ إِسنَّاننْ. \x ◘ \xo 6:‏44 \xt مت. 7‏:‏16. \x*  
\v 45 بْنَاذمْ أَصبْحَانْ زِي ڒْكنْزْ ن وُوڒْ نّسْ ذ أَصبْحَانْ أَذْ إِسُّوفّغْ مِينْ إِصبْحنْ ؤُشَا بْنَاذمْ أَعفَّانْ زِي ڒْكنْزْ ن وُوڒْ نّسْ ذ أَعفَّانْ أَذْ د-إِسُّوفّغْ ثُوعفّْنَا. س مِينْ زِي إِشُّورْ وُوڒْ، زَّايسْ سَّاوَاڒنْ إِينْشِيشنْ.“ \x ◘ \xo 6:‏45 \xt مت. 12‏:‏35. \x*   
\b  
\m  
\s1 ثَادَّارْثْ خْ سّدْجَاحْ  
\m
\v 46 ”مَايمِّي ذ أَيِي ثتّْڒَاغَامْ: ’\add أَ\add* سِيذِي، \add أَ\add* سِيذِي!‘ ؤُشَا وَارْ ثتّڭّمْ شَا مِينْ قَّارغْ؟ \x ◘ \xo 6:‏46 \xt [مت. 7‏:‏24‏-‏27] — مـَال. 1‏:‏6؛ مت. 7‏:‏21؛ 25‏:‏11؛ لك. 13‏:‏25؛ رُوم. 2‏:‏13؛ يَاع. 1‏:‏22. \x*  
\v 47 مَارَّا ونِّي غَارِي إِ د غَا يَاسنْ، أَذْ إِسڒْ إِ وَاوَاڒنْ إِنُو ؤُشَا أَذْ زَّايْسنْ إِڭّْ، نشّْ أَذْ أَومْ سّشْنغْ مِينْ ذِي يَارْوسْ نتَّا. \x ◘ \xo 6:‏47 \xt مت. 7‏:‏24. \x*  
\v 48 نتَّا يَارْوسْ ذڭْ إِجّْ ن بْنَاذمْ إِ إِبْنَانْ إِشْثْ ن ثَادَّارْثْ. نتَّا إِغْزَا، إِحْفَارْ ؤُشَا إِسَّارْسْ ذْسَاسْ خْ سّدْجَاحْ. ؤُمِي د-ثُوسَا سّحْڒثْ، ثْقبّضْ ڒْحمْڒثْ ثَادَّارْثْ نِّي ؤُشَا وَارْ ثْزمَّارْ أَذْ ت ثسّنْهزّْ، مِينْزِي ثُوغَا ذْسَاسْ نّسْ خْ سّدْجَاحْ.  
\v 49 مَاشَا ونِّي إِتّسْڒَانْ وَارْ إِتّڭّْ، يَارْوسْ ذِي بْنَاذمْ إِ إِبْنَانْ ثَادَّارْثْ نّسْ خْ ثمُّورْثْ بْڒَا ذْسَاسْ. ؤُمِي ت-إِ-د-ثْقبّضْ ڒْحمْڒثْ، ڒخْذنِّي ثوْضَا. ثُوغَا أَفَارْثكْ ن ثَادَّارْثْ نِّي ذ أَمقّْرَانْ.“   
\b  
\b  
\m  
\c 7
\s1 لْ‘إِمَانْ ن ڒْقبْطَانْ أَرُومَانِي  
\m
\v 1 أَوَارْنِي ڒَامِي إِكمّڒْ مَارَّا أَوَاڒنْ نّسْ أَمْ ذ أَسْ سْڒَانْ إِوْذَانْ، يُوذفْ يَاسُوع غَارْ كَافَارْنَاحُومْ. \x ◘ \xo 7:‏1 \xt [مت. 8‏:‏5‏-‏13؛ يُوح. 4‏:‏43‏-‏54]\x*  
\v 2 أَمْسخَّارْ ن إِجّْ ن ڒْقبْطَانْ خْ مْيَا، ونِّي ثُوغَا إِسّْعِيزّْ أَطَّاسْ، ثُوغَا إِهْڒشْ، وَارْ ذ أَسْ إِقِّيمْ شَا أَذْ إِمّثْ.  
\v 3 ؤُمِي إِسْڒَا خْ يَاسُوع، إِسّكّْ غَارسْ شَا ن إِمْغَارنْ ن وُوذَاينْ، إِتَّارْ \add أَسْ\add* مَاحنْذْ أَذْ د-يَاسْ ؤُشَا أَذْ إِسّنْجمْ أَمْسخَّارْ نّسْ.  
\v 4 ڒَامِي د-إِوْضنْ غَارْ يَاسُوع، حشّْمنْ ث أَطَّاسْ، نَّانْ: ”أَقَا إِسْذَاهدْجْ أَذْ أَسْ ثڭّذْ أَيَا،  
\v 5 مِينْزِي نتَّا إِتّخْسْ ڒْڭنْسْ نّغْ ؤُ إِبْنَا أَنغْ ثَامْزِيذَا.“   
\m
\v 6 \add خَاسْ ؤُشَا\add* إِرُوحْ يَاسُوع أَكِيذْسنْ. أَڒَامِي ثُوغَا وَارْ إِڭّْوِيجْ عَاذْ خْ ثَادَّارْثْ، إِسّكّْ ڒْقبْطَانْ خْ مْيَا شَا ن إِمدُّوكَّاڒْ \add غَارسْ\add*، ؤُشَا نتَّا إِنَّا أَسْ: ”\add أَ\add* سِيذِي، وَارْ سِّيحِيڒْ إِخفْ نّشْ، مِينْزِي نشّْ وَارْ سْذِيهدْجغْ أَذْ ثَاذْفذْ سَاذُو ثَازقَّا إِنُو.  
\v 7 س ؤُينِّي نشّْ وَارْ حسْبغْ إِخفْ إِنُو سْذَاهدْجغْ حِيمَا أَذْ غَاركْ د-أَسغْ، مَاشَا إِنِي أَوَاڒْ \add وَاهَا\add* ؤُشَا أَذْ إِڭّنْفَا ؤُمْسخَّارْ أَمژْيَانْ إِنُو.  
\v 8 مِينْزِي ؤُڒَا ذ نشّْ عَاوذْ ذ إِجّْ ن بْنَاذمْ سَاذُو إِفَاسّنْ إِ دْجِيغْ ؤُ غَارِي \add عَاوذْ\add* إِعسْكَارِييّنْ سْوَادَّايْ إِ ؤُفُوسْ إِنُو. قَّارغْ إِ وَا: ’رُوحْ!‘، خنِّي إِتّْرَاحْ، إِ ونّغْنِي: ’أَسْ-د!‘، خنِّي إِتَّاسْ-د ؤُشَا إِ ؤُمْسخَّارْ إِنُو: ’أڭّْ أَيَا!‘، خنِّي إِتّڭّْ إِ-ث.“   
\m
\v 9 ؤُمِي إِسْڒَا يَاسُوع أَيَا، إِتّبْهثْ ذَايسْ. إِنّقْڒبْ ؤُشَا إِنَّا إِ ڒْغَاشِي ونِّي ثُوغَا إِ-ث-إِ-د-إِضفَّارنْ: ”نشّْ أَذْ أَومْ إِنِيغْ، وَارْ ؤُفِيغْ ؤُڒَا ذِي مَارَّا إِسْرَائِيل لْ-إِيمَانْ أَمقّْرَانْ أَمْ ڒْقدّْ ن وَا.“  
\v 10 أَڒَامِيعقْبنْ إِنِّي إِتّْوَاسّكّنْ غَارْ ثَادَّارْثْ، ؤُفِينْ أَمْسخَّارْ أَمهْڒُوشْ إِڭّنْفَا.   
\b  
\m  
\s1 مِّيسْ ن ثَاجَّاتْشْ زِي نَايِينْ  
\m
\v 11 ثِيوشَّا نّسْ إِرُوحْ غَارْ إِشْثْ ن ثنْذِينْثْ قَّارنْ أَسْ نَايِينْ. ثُوغَا ذِينْ أَكِيذسْ إِمحْضَارنْ نّسْ ذ إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ.  
\v 12 أَڒَامِي د-إِقَارّبْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ، خْزَارْ، كْسِينْ-د إِجّْ ن ؤُمتِّينْ \add خْ ڒْمحْمڒْ\add* غَارْ بَارَّا. نتَّا ذ أَينِّي ن مِّيسْ نِّي ثُوغَا غَارْ يمَّاسْ. يمَّاسْ ثُوغَا-ت ذ ثَاجَّاتْشْ ؤُ ثُوغَا أَكِيذسْ أَطَّاسْ ن ڒْغَاشِي زِي ثنْذِينْثْ.  
\v 13 ؤُمِي ت إِژْرَا يَاسُوع، ثزِّيدْجزْ أَسْ، إِنَّا أَسْ: ”وَارْ تّْرُو!“  
\v 14 خنِّي إِقَارّبْ-د، إِحَاذَا ڒْمحْمڒْ، ؤُشَا بدّنْ يِينِّي ث يَارْبُونْ، إِنَّا: ”\add أَ\add* أَبْڒِيغْ، إِ شكْ ؤُمِي غَا إِنِيغْ، كَّارْ-د!“ \x ◘ \xo 7:‏14 \xt ڒخ. 9‏:‏40. \x*  
\v 15 إِقِّيمْ ؤُمتِّينْ، إِبْذَا إِسَّاوَاڒْ، خنِّي يَارَّا أَسْ ث-إِ-د إِ يمَّاسْ.  
\v 16 ثُوذفْ ثِيڭّْوُوذِي ذِي مَارَّا ؤُشَا سّمْغَارنْ أَربِّي، نَّانْ: ”أَقَا إِكَّارْ-د ذَايْنغْ ؤُنَابِي إِمْغَارْ!“، ؤُشَا: ”أَقَا إِسِّيجّْ-د أَربِّي خْ ڒْڭنْسْ نّسْ.“ \x ◘ \xo 7:‏16 \xt لك. 1‏:‏68؛ 24‏:‏19؛ يُوح. 4‏:‏19؛ 6‏:‏14؛ 9‏:‏17. \x*  
\v 17 إِفّغْ ڒخْبَارْ-أَ خَاسْ غَارْ مَارَّا يَاهُوذِييَّا ؤُ غَارْ مَارَّا جّْوَايهْ إِ ذ أَسنْ د-إِنّْضنْ.   
\b  
\m  
\s1 أَسقْسِي ن يُوحَانَّا أَمْسغْضَاصْ  
\m
\v 18 إِمحْضَارنْ ن يُوحَانَّا عَاوْذنْ أَسْ مَانْ أَيَا مَارَّا. \x ◘ \xo 7:‏18 \xt [مت. 11‏:‏2‏-‏19] — مت. 11‏:‏2. \x*  
\v 19 إِڒَاغَا يُوحَانَّا إِ ثْنَاينْ زڭْ إِمحْضَارنْ نّسْ ؤُشَا إِسّكّْ إِ-ثنْ غَارْ يَاسُوع، إِقَّارْ \add س ؤُقمُّومْ نْسنْ\add*: ”مَا ذ شكْ ذ ونِّي د غَا يَاسنْ، نِيغْ أَذْ نْرَاجَا ونّغْنِي؟“  
\v 20 ؤُمِي رُوحنْ يرْيَازنْ غَارْ يَاسُوع، نَّانْ أَسْ: ”يُوحَانَّا أَمْسغْضَاصْ أَقَا إِسّكّْ أَنغْ-د غَاركْ، إِنَّا: ’مَا ذ شكْ ذ ونِّي إِ د غَا يَاسنْ نِيغْ أَذْ نْرَاجَا ونّغْنِي؟‘ “   
\m
\v 21 ذِي ثْسَاعّثْ نِّي ثُوغَا إِسّْڭنْفَا أَطَّاسْ \add ن إِوْذَانْ\add* زِي ڒهْڒَاشَاثْ ذ ؤُودّبْ \add نْسنْ\add* ؤُ زِي ڒَارْيَاحْ إِعفَّاننْ، ؤُشَا يَارَّا أَطَّاسْ ن إِذَارْغَاڒنْ تّْوَاڒَانْ.  
\v 22 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”رُوحمْ، عَاوْذمْ إِ يُوحَانَّا مِينْ ثژْرِيمْ ذ مِينْ ثسْڒِيمْ. أَقَا إِذَارْغَاڒنْ تّْوَاڒَانْ ؤُ إِنعْضَابنْ ڭُّورنْ ؤُ يِينِّي ذِي إِدْجَا ڒْبَارْصْ تّْوَاسِّيزْذڭنْ ؤُ إِذهْشَارْ تّسْڒَانْ ؤُ إِمتِّيننْ تّكَّارنْ ؤُشَا إِتّتّْوَابَارّحْ س ڒخْبَارْ أَصبْحَانْ إِ إِمزْڒَاضْ. \x ◘ \xo 7:‏22 \xt إِشا. 29‏:‏18؛ 35‏:‏5؛ 61‏:‏1. \x*  
\v 23 سّعْذْ ن ونِّي وَارْ ذ أَيِي إِتّنْذْرِيفنْ.“   
\m
\v 24 ؤُمِي فّْغنْ إِمحْضَارنْ ن يُوحَانَّا، إِبْذَا يَاسُوع إِقَّارْ إِ ڒْغَاشِي خْ يُوحَانَّا: ”مِينْ غَارْ إِ غَا د-ثفّْغمْ غَارْ ڒخْڒَا أَذْ ثْژَارمْ؟ مَا إِجّْ ن ؤُغَانِيمْ إِسّنْهزَّا ث ؤُسمِّيضْ؟ \x ◘ \xo 7:‏24 \xt مت. 11‏:‏7. \x*  
\v 25 مَاڒَا لَّا، مِينْ غَارْ ثُوغَا د-ثفّْغمْ أَذْ ثْژَارمْ؟ مَا إِجّْ ن بْنَاذمْ يَارْضْ أَرُّوضْ يَارْضبْ؟ خْزَارْ إِنِّي يَارْضنْ أَرُّوضْ إِغْڒَانْ يَارْضبْ ؤُ دَّارنْ ذڭْ ؤُفُوهَارْثْ، أَقَا أَثنْ ذِي ڒقْصُورْ ن إِجدْجِيذنْ.  
\v 26 مَاشَا مِينْ غَارْ ثُوغَا د-ثفّْغمْ أَذْ ثْژَارمْ؟ مَا إِجّْ ن ؤُنَابِي؟ وَاهْ، أَذْ أَومْ إِنِيغْ ذ أَمقّْرَانْ كْثَارْ زڭْ ؤُنَابِي.  
\v 27 أَقَا ذ وَا إِ خفْ إِتّْوَارِي: ’أَقَا نشّْ أَذْ سّكّغْ لْمَالَاكْ إِنُو زَّاثْ إِ ؤُغمْبُوبْ نّشْ، ونِّي إِ غَا إِسّْوجْذنْ أَبْرِيذْ نّشْ غَارْ زَّاثْ نّشْ.‘ \x ◘ \xo 7:‏27 \xt ؤُف. 23‏:‏20؛ مـَال. 3‏:‏1؛ مك. 1‏:‏2. \x*  
\v 28 نشّْ أَذْ أَومْ إِنِيغْ، جَارْ إِنِّي د-إِتّْوَاخڒْقنْ زِي ثمْغَارِينْ ؤُڒَا ذ إِجّْ وَارْ إِدْجِي ذ أَنَابِي أَمقّْرَانْ خْ يُوحَانَّا \add أَمْسغْضَاصْ\add*، مَاشَا \add وَاخَّا أَمنِّي\add* ذ أَمژْيَانْ قَاعْ ذِي ثْڭلْذِيثْ ن أَربِّي إِمْغَارْ خَاسْ.“  
\v 29 مَارَّا إِوْذَانْ نِّي ذ أَسْ إِسْڒِينْ، ؤُڒَا ذ أَيْثْ ن ضَّارِيبَا شهْذنْ إِ ثْسڭْذَا ن أَربِّي، مِينْزِي نِيثْنِي تّْوَاسّْغضْصنْ س ؤُسغْضصْ ن يُوحَانَّا.  
\v 30 مَاشَا إِفَارِيسِييّنْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ؤُڭِينْ خْ شّْوَارْ ن أَربِّي إِ يِيخفْ نْسنْ، مِينْزِي ؤُڭِينْ أَذْ زَّايسْ تّْوَاسّْغضْصنْ.   
\m
\v 31 \add إِنَّا نتَّا\add*: ”مِينْ زِي غَا شبّْهغْ إِوْذَانْ ن جِّيڒْ-أَ؟ وِي ذِي يَارْوسنْ؟ \x ◘ \xo 7:‏31 \xt مت. 11‏:‏16. \x*  
\v 32 نِيثْنِي أَمشْنَاوْ إِحنْجِيرنْ إِ إِقِّيمنْ ذِي سُّوقْ، تّْڒَاغَانْ إِجّنْ ونّغْنِي، قَّارنْ: ’نشِّينْ نوْثَا أَومْ ذِي ثمْجَا، كنِّيوْ وَارْ ثشْضِيحمْ، ؤُ نشِّينْ نْغنّجْ إِجّْ ن وژْرِي ن وشْضَانْ إِ كنِّيوْ، \add مَاشَا\add* كنِّيوْ وَارْ ثْرُومْ شَا.‘  
\v 33 مِينْزِي يُوسَا-د يُوحَانَّا أَمْسغْضَاصْ، وَارْ إِتّتّْ أَغْرُومْ، وَارْ إِسسّْ بِينُو ؤُشَا ثنَّامْ: ’أَقَا ذَايسْ شِّيطَانْ!‘ \x ◘ \xo 7:‏33 \xt مت. 3‏:‏4؛ مك. 1‏:‏6. \x*  
\v 34 يُوسَا-د مِّيسْ ن بْنَاذمْ إِتّتّْ، إِسسّْ، ثنَّامْ: ’خْزَارْ، بْنَاذمْ-أَ إِڒْهفْ خْ مَاشَّا ذ بِينُو، أَقَا-ث ذ أَمدُّوكّڒْ ن أَيْثْ ن ضَّارِيبَا ذ إِمذْنَابْ.‘  
\v 35 مَاشَا ثِيغِيثْ ثتّْوَاسڭّذْ زِي مَارَّا ثَارْوَا نّسْ.“   
\b  
\m  
\s1 أَذْهَانْ ن إِضَارنْ ن يَاسُوع  
\m
\v 36 إِعَارْضْ إِ-ث إِجّْ ن ؤُفَارِيسِي حِيمَا أَذْ كِيسْ إِشّْ. يُوذفْ نتَّا غَارْ ثَادَّارْثْ ن ؤُفَارِيسِي ؤُشَا إِقِّيمْ \add غَارْ طَّابْڒَا\add*.  
\v 37 ثُوغَا ثْزدّغْ إِشْثْ ن ثمْغَارْثْ ثَامذْنُوبْثْ ذِي ثنْذِينْثْ نِّي. ؤُمِي ثسّنْ أَقَا إِقِّيمْ \add غَارْ طَّابْڒَا\add* ذِي ثَادَّارْثْ ن ؤُفَارِيسِي، ثُوسَا-د س إِشْثْ ن ؤُغَارَّافْ ن أَلَابَاسْثرْ ذَايسْ \add زّشْثْ\add* إِ وذْهَانْ،  
\v 38 ؤُشَا ؤُمِي ثْبدّْ غَارْ إِضَارنْ نّسْ غَارْ ضفَّارْ نّسْ، ثْرُو ؤُشَا ثبْذَا ثسُّوفَّا إِضَارنْ نّسْ س إِمطَّاونْ نّسْ ؤُشَا ثبْذَا ثسَّاژَاغْ إِ-ثنْ س ؤُشُووَّافْ \add ن ؤُزدْجِيفْ\add* نّسْ، ثسُّوذمْ أَسْ إِضَارنْ ؤُشَا ثمْسحْ إِ-ثنْ س إِشْثْ ن زّشْثْ ن وذْهَانْ.  
\v 39 ؤُمِي إِژْرَا ؤُفَارِيسِي ونِّي إِ-ث-إِ-د-إِعَارْضنْ مَانْ أَيَا، إِخَارّصْ ذڭْ يِيخفْ نّشْ، إِنَّا: ”مَاڒَا وَا ذ أَنَابِي \add س ثِيذتّْ\add*، إِڒِي أَقَا إِسّنْ مِينْ ثعْنَا ثَانِيثَا ؤُ مَامّشْ ثتّْوَاسّنْ نتَّاثْ، مِينْزِي ثنِّي ث إِحَاذَانْ، أَقَا-ت ذ ثَامذْنُوبْثْ.“   
\m
\v 40 يَارَّا-د يَاسُوع، إِنَّا أَسْ: ”\add أَ\add* شِيمْعُونْ، غَارِي إِشْثْ ن ڒْحَاجّثْ أَذْ أَشْ ت إِنِيغْ.“ إِنَّا أَسْ: ”إِنِي ت، \add أَ\add* أَمْسڒْمَاذْ إِنُو!“  
\v 41 إِنَّا أَسْ يَاسُوع: ”إِجّْ ن بَابْ ن ؤُمَارْوَاسْ ثُوغَا غَارسْ ثْنَاينْ تُّورْسنْ أَسْ. إِجّنْ ثُوغَا إِتُّورْسْ أَسْ خمْسَا-مْيَا ذِينَارْ ؤُ ونّغْنِي خمْسِينْ.  
\v 42 أَمْ وَارْ ثُوغِي غَارْسنْ مِينْ زِي غَا أَرّنْ أَمَارْوَاسْ، إِسَامْحْ أَسنْ \add أَمَارْوَاسْ\add* س ثْنَاينْ إِذْسنْ. \add إِنِي أَيِي،\add* وِي زَّايْسنْ ث غَا إِخْسنْ كْثَارْ؟“  
\v 43 يَارَّا-د شِيمْعُونْ، إِنَّا: ”إِتّْغِيڒْ أَيِي ونِّي ؤُمِي إِسَامْحْ كْثَارْ.“ إِنَّا أَسْ: ”شكْ ثْحكْمذْ س صَّاحْ.“  
\v 44 \add خَاسْ ؤُشَا\add* إِنّقْڒبْ يَاسُوع غَارْ ثمْغَارْثْ نِّي، إِنَّا إِ شِيمْعُونْ: ”مَا ثتّْوَاڒِيذْ ثَامْغَارْثْ-أَ؟ أَقَا ؤُذْفغْ غَارْ ثَادَّارْثْ نّشْ. أَمَانْ إِ إِضَارنْ إِنُو وَارْ ذ أَيِي ثنْ ثوْشِيذْ. مَاشَا نتَّاثْ ثسُّوفّْ إِضَارنْ إِنُو س إِمطَّاونْ \add نّسْ\add* ؤُشَا ثسِّيژغْ إِ-ثنْ س ؤُشُووَّافْ \add ن ؤُزدْجِيفْ\add* نّسْ.  
\v 45 شكْ وَارْ ذ أَيِي ثسُّوذْمذْ، مَاشَا نتَّاثْ، زڭْ وَامِي د-ؤُذْفغْ، وَارْ ثْبدّْ زڭْ ؤُسُوذمْ ن إِضَارنْ إِنُو.  
\v 46 س زّشْثْ وَارْ ثْمسْحذْ شَا أَزدْجِيفْ إِنُو، مَاشَا نتَّاثْ ثمْسحْ إِضَارنْ إِنُو س زّشْثْ ن وذْهَانْ.  
\v 47 س ؤُينِّي أَذْ أَشْ إِنِيغْ: أَقَا إِتّْوَاغْفَارْ أَسْ أَطَّاسْ ن دّْنُوبْ نّسْ، مِينْزِي ثخْسْ أَطَّاسْ. ونِّي ؤُمِي إِتّْوَاغْفَارْ ذْرُوسْ، أَذْ غَارسْ يِيڒِي ذْرُوسْ ن ثَايْرِي.“  
\v 48 \add خنِّي\add* إِنَّا أَسْ: ”\add أَ\add* ثَامطُّوثْ، أَقَا تّْوَاغْفَارنْ دّْنُوبْ نّمْ.“ \x ◘ \xo 7:‏48 \xt مت. 9‏:‏2. \x*   
\m
\v 49 إِنِّي أَكِيذسْ إِقِّيمنْ \add غَارْ طَّابْڒَا\add* بْذَانْ قَّارنْ ذڭْ إِخفْ نْسنْ: ”مِينْ إِعْنَا وَانِيثَا مَاحنْذْ أَذْ إِغْفَارْ ؤُڒَا إِ دّْنُوبْ.“ \x ◘ \xo 7:‏49 \xt مت. 9‏:‏3. \x*  
\v 50 إِنَّا أَسْ يَاسُوع إِ ثْمطُّوثْ نِّي: ”لْ‘إِمَانْ نّمْ أَقَا إِوْشَا أَمْ ثُوذَارْثْ. رُوحْ ذِي ڒهْنَا.“   
\b  
\b  
\m  
\c 8
\s1 ثِيمْغَارِينْ إِ إِسخَّارنْ إِ يَاسُوع  
\m
\v 1 أَوَارْنِي ؤُيَا إِشُوقْ يَاسُوع ذِي ثْندَّامْ ذ ذْشُورَاثْ، إِتّْبَارّحْ س ثْڭلْذِيثْ ن أَربِّي. ثُوغَا أَكِيذسْ ثنْعَاشْ \add ن رُّوسُولْ\add* نّسْ، \x ◘ \xo 8:‏1 \xt [مت. 13‏:‏1‏-‏17؛ مك. 4‏:‏1‏-‏12] \x*  
\v 2 ؤُڒَا ذ ثمْغَارِينْ أَيَا نِّي ثُوغَا إِتّْوَاسّْڭنْفَانْ زِي ڒحْڒَاشَاثْ ؤُ زِي ڒَارْيَاحْ إِعفَّاننْ: \add أَقَا-ت\add* مَارْيَامْ، قَّارنْ أَسْ ’ثنِّي ن مَاجْذَالَا‘، إِ زِي تّْوَاسُّوفّْغنْ سبْعَا ن شّْوَاطنْ، \x ◘ \xo 8:‏2 \xt مت. 27‏:‏55، 56. \x*  
\v 3 ذ يُوحَانَّا، ثَامْغَارْثْ ن خُوزَا، أَوْكِيڒْ ن هِيرُوذُوسْ، ذ سُوسَانَّا، ذ ثِينّغْنِي أَطَّاسْ إِ ثُوغَا تّْسخَّارنْثْ خَاسنْ س وَاڭْڒَا نْسنْثْ.   
\b  
\m  
\s1 أَمذْيَا ن ؤُمْزَارّعْ  
\m
\v 4 ڒَامِي ذِينْ إِسّْمُونْ إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ، ؤُسِينْ-د غَارسْ زِي مَارَّا ثِيندَّامْ، إِنَّا س يِيجّْ ن ؤُمذْيَا: \x ◘ \xo 8:‏4 \xt [مت. 13‏:‏18‏-‏23؛ مك. 4‏:‏13‏-‏20] — مت. 13‏:‏3؛ مك. 4‏:‏2. \x*  
\v 5 ”إِفّغْ-د إِجّْ ن ؤُمْزَارَّاعْ، حِيمَا أَذْ إِزَارْعْ زَّارِيعثْ نّسْ. أَمْ إِزَارّعْ، ثوْضَا \add شْوَايْثْ ن زَّارِيعثْ\add* ذڭْ وبْرِيذْ، إِعْفسْ خَاسْ ؤُشَا نقْبنْ إِ-ت إِجْضَاضْ.  
\v 6 ثوْضَا \add شْوَايْثْ ن زَّارِيعثْ\add* نّغْنِي خْ وژْرُو، ؤُمِي د-ثغْمِي ذغْيَا، ثُوژغْ، مِينْزِي وَارْ غَارسْ ثُوغِي ثُوفّثْ.  
\v 7 ثوْضَا \add شْوَايْثْ ن زَّارِيعثْ\add* نّغْنِي ذِي ڒْوسْطْ ن إِسنَّاننْ ؤُشَا إِسنَّاننْغمْينْ-د أَكِيذسْ ؤُشَا جيّْفنْ ت.  
\v 8 ثوْضَا \add شْوَايْثْ ن زَّارِيعثْ\add* نّغْنِي ذِي ثمُّورْثْ يَارضْبنْ ذ لمْلِيحْ، ؤُشَا ؤُمِي د-ثغْمِي، ثڭَّا ڒْغِيدْجثْ ن مْيَا إِمُورنْ.“ أَوَارْنِي ڒَامِي ثُوغَا إِقَّارْ مَانْ أَيَا، إِڒَاغَا: ”ونِّي غَارْ إِدْجَا إِمزُّوغنْ إِ ؤُسدْجِي، أجّْ إِ-ث أَذْ إِسڒْ.“   
\b  
\m
\v 9 سّقْسَانْ ث إِمحْضَارنْ نّسْ: ”مِينْ إِخْسْ أَذْ يِينِي ؤُمذْيَا-أَ؟“ \x ◘ \xo 8:‏9 \xt [مت. 13‏:‏18‏-‏23؛ مك. 4‏:‏10‏-‏20] \x*  
\v 10 إِنَّا أَسنْ: ”إِ كنِّيوْ ؤُمِي إِمّوْشْ أَذْ ثسّْنمْ سِّيرّْ ن ثْڭلْذِيثْ ن أَربِّي، مَاشَا إِ إِنّغْنِي أَذْ د-يَاسْ وَاوَاڒْ س إِمذْيَا، أَڒَامِي نِيثْنِي تّْوَاڒَانْ مَاشَا وَارْ تّْوِيڒِينْ ؤُشَا تّسْڒَانْ وَارْ فهّْمنْ. \x ◘ \xo 8:‏10 \xt إِشا. 6‏:‏9‏-‏10؛ حِز. 12‏:‏2؛ مت. 11‏:‏25؛ 13‏:‏14؛ مك. 4‏:‏12؛ يُوح. 12‏:‏40؛ ڒخ. 28‏:‏26؛ رُوم. 11‏:‏8؛ 2 كُور. 3‏:‏5، 14. \x*  
\v 11 ذ وَا ذ \add ڒْْمعْنَا ن\add* ؤُمذْيَا: زَّارِيعثْ نتَّاثْ ذ أَوَاڒْ ن أَربِّي. \x ◘ \xo 8:‏11 \xt مت. 13‏:‏18؛ مك. 4‏:‏13. \x*  
\v 12 إِنَا خْ طَّارْفْ ن وبْرِيذْ، نِيثْنِي ذ إِنِّي إِتّسْڒَانْ أَوَاڒْ، مَاشَا \add خنِّي\add* إِتَّاسْ-د إِبْڒِيسْ، إِتّكّسْ أَوَاڒْ زڭْ وُوڒْ نْسنْ أَڒَامِي وَارْ تِّيمْننْ ؤُشَا أَذْ دَّارنْ.  
\v 13 إِنَا خْ وژْرُو، نِيثْنِي ذ إِنِّي خْمِي غَا سْڒنْ، أَذْ قبْڒنْ أَوَاڒْ س ڒفْرَاحثْ، \add مَاشَا\add* وَارْ غَارْسنْ بُو وژْوَارْ، تَّامْننْ غَارْ خنِّيثْ، ذِي ڒْوقْثْ ن ؤُجَارّبْ أَذْ نْقَارْضنْ. \x ◘ \xo 8:‏13 \xt مت. 13‏:‏20؛ مك. 4‏:‏16. \x*  
\v 14 إِنَا إِ إِوْضَانْ ذڭْ إِسنَّاننْ، نِيثْنِي ذ إِنِّي إِتّسْڒَانْ أَوَاڒْ، خنِّي تّْرَاحنْ، تّْبُوخْسُوينْ ذڭْ إِمْنُوسنْ ذ وَاڭْڒَا ذ طَّامُوعْ ن دُّونشْثْ، وَارْ سّنْذَاينْ شَا ڒْغِيدْجثْ. \x ◘ \xo 8:‏14 \xt مت. 19‏:‏23؛ مك. 10‏:‏23؛ لك. 18‏:‏24؛ 1 تِيم. 6‏:‏9. \x*  
\v 15 إِنَا ذِي ثمُّورْثْ يَارضْبنْ، نِيثْنِي ذ إِنِّي إِتّسْڒَانْ إِ وَاوَاڒْ، خمّْڒنْ ث ذڭْ وُوڒْ نِيشَانْ، إِصْبحْ، ؤُشَا سّنْذَاينْ ڒْغِيدْجثْ س صّْبَارْ.“   
\b  
\m  
\s1 أَمذْيَا ن ڒفْنَارْ ذ ڒْمرْفعْ  
\m
\v 16 ”ؤُڒَا ذ إِجّْ وَارْ إِسّْرُوغِي ڒفْنَارْ ؤُشَا إِقبَّارْ خَاسْ س يِيجّْ ن ؤُقدُّوحْ نِيغْ إِسّْرُوسَا ث سَاذُو قَامَا، مَاشَا \add س ڒمْقْڒُوبْ\add* إِسّْرُوسَا ث خْ ڒْمرْفعْ، حِيمَا إِنِّي د-إِتَّاذْفنْ أَذْ ژَترنْ ثَافَاوْثْ نّسْ. \x ◘ \xo 8:‏16 \xt [مك. 4‏:‏21‏-‏25] — مت. 5‏:‏15؛ مك. 4‏:‏21؛ لك. 11‏:‏33. \x*  
\v 17 مِينْزِي وَارْ ذِينْ مِينْ إِذْڒِينْ، وَارْ د-إِتّفِّيغْ غَارْ بَارَّا، ؤُ \add وَارْ ذِينْ\add* مِينْ إِنُّوفَّارنْ، وَارْ إِتّْوِيسِّينْ، وَارْ د-إِتّفِّيغْ غَارْ بَارَّا. \x ◘ \xo 8:‏17 \xt أَيُوبْ 12‏:‏22؛ مت. 10‏:‏26؛ مك. 4‏:‏22؛ لك. 12‏:‏2. \x*  
\v 18 حْضَامْ مَامّشْ ثتّسْڒَامْ، مِينْزِي ونِّي غَارْ إِدْجَا أَذْ أَسْ إِمَّارْنِي، ؤُ ونِّي وَارْ غَارْ إِدْجِي، مِينْ ذ أَسْ إِتّْغِيڒْ غَارسْ، أَذْ زَّايسْ إِتّْوَاكّسْ.“ \x ◘ \xo 8:‏18 \xt مت. 13‏:‏12؛ 25‏:‏29؛ مك. 4‏:‏25؛ لك. 19‏:‏26. \x*   
\b  
\m  
\s1 مَانْ ونْ إِدْجَانْ ذ يمَّاسْ ذ أَيْثْمَاسْ ن يَاسُوع  
\m
\v 19 يمَّاسْ ذ أَيْثْمَاسْ ؤُسِينْ-د غَارسْ، وَارْ زمَّارنْ أَذْ أَكِيذسْ سِّيوْڒنْ س سِّيبّثْ ن ڒْغَاشِي. \x ◘ \xo 8:‏19 \xt [مت. 12‏:‏46‏-‏50؛ مك. 3‏:‏31‏-‏35] — مت. 12‏:‏46؛ 13‏:‏55؛ مك. 3‏:‏31. \x*  
\v 20 نَّانْ أَسْ: ”يمَّاشْ ذ أَيْثْمَاشْ بدّنْ بَارَّا، خْسنْ أَذْ شكْ ژَترنْ.“  
\v 21 يَارَّا-د، إِنَّا أَسنْ: ”يمَّا ذ أَيْثْمَا، أَقَا ذ إِنِّي إِتّسْڒَانْ أَوَاڒْ ن أَربِّي ؤُ تّڭّنْ زَّايسْ.“ \x ◘ \xo 8:‏21 \xt يُوح. 15‏:‏14؛ 2 كُور. 5‏:‏16. \x*   
\b  
\m  
\s1 يَاسُوع ذ ثْحَارْيَاضْثْ  
\m
\v 22 ذڭْ إِجّنْ زڭْ وُوسَّانْ نِّي إِنْيَا ذڭْ إِشْثْ ن ثْغَارَّابُوثْ، نتَّا ذ إِمحْضَارنْ نّسْ. إِنَّا أَسنْ: ”أجّْ أَنغْ أَذْ نژْوَا غَارْ ؤُجمَّاضِينْ ن ڒبْحَارْ!“ \x ◘ \xo 8:‏22 \xt [مت. 8‏:‏23‏-‏27؛ مك. 4‏:‏35‏-‏41] — مت. 8‏:‏23؛ مك. 4‏:‏35، 36. \x*  
\v 23 أَمْ ثنْ ثُوغَا رُوحنْ ذِي ڒبْحَارْ، إِكَّا يِيضصْ خْ يَاسُوع. خنِّي ثهْوَا-د إِشْثْ ن ثْحَارْيَاضْثْ ن ؤُسمِّيضْ ذِي ڒبْحَارْ، ثبْذَا ثْغَارَّابُوثْ عْڒَاينْ أَذْ ثهْوَا.  
\v 24 قَارّْبنْ غَارسْ ؤُشَا سّْفَاقنْ ث، نَّانْ أَسْ: ”\add أَ\add* أَمْسڒْمَاذْ نّغْ، \add أَ\add* أَمْسڒْمَاذْ نّغْ، أَقَا نْغَارّقْ.“ نتَّا إِكَّارْ-د، إِوبّخْ أَسمِّيضْ ذ ڒمْوَاجْ ن وَامَانْ ؤُشَا سّْقَارنْ، يَارْسَا ڒْحَاڒْ.  
\v 25 خنِّي إِنَّا أَسنْ: ”مَانِي إِدْجَا لْ-إِيمَانْ نْومْ؟“ ڭّْوذنْ، ثْبهْثنْ، نَّانْ جَارْ أَسنْ: ”مِينْ إِعْنَا وَا، أَقَا إِتَّامَارْ ؤُڒَا ذ أَسمِّيضْ ذ وَامَانْ ؤُشَا تّطَّاعنْ أَسْ.“ \x ◘ \xo 8:‏25 \xt أَيُوبْ 26‏:‏12؛ إِزهد. 107‏:‏25. \x*   
\b  
\m  
\s1 أَسْڭنْفِي ن إِجّْ ن ؤُمرْيَاحْ  
\m
\v 26 ؤُيُورنْ س ثْغَارَّابُوثْ، ؤُسِينْ-د غَارْ ثمُّورْثْ ن ڭَاذَارِينُوسْ ثنِّي قِيبَاتْشْ إِ لْجَالِيلْ. \x ◘ \xo 8:‏26 \xt [مت. 8‏:‏28‏-‏34؛ مك. 5‏:‏1‏-‏20] — مت. 8‏:‏28؛ مك. 5‏:‏1. \x*  
\v 27 ؤُمِي د-إِفّغْ غَارْ ثمُّورْثْ، إِڒْقَا ث-إِ-د إِجّْ ن ورْيَازْ زِي ثنْذِينْثْ. أَطَّاسْ زڭْ وَامِي ثُوغَا ذَايسْ إِجّْ ن شِّيطَانْ ؤُ ثُوغَا وَارْ إِتِّيرْضْ أَرُّوضْ، وَارْ إِزدّغْ ذِي ثَادَّارْثْ مَاشَا ذڭْ إِمضْڒَانْ.  
\v 28 ؤُمِي إِژْرَا يَاسُوع، إِسْغُويْ، إِوْضَا غَارْ إِضَارنْ نّسْ، إِنَّا س جّهْذْ ”مِينْ ذِينْ جَارْ أَنغْ نشّْ ذ شكْ أَ يَاسُوع، مِّيسْ ن أَربِّي، أَمْعُودْجِي خْ كُوڒْشِي؟ تّْزَاوَاڭغْ شكْ، وَارْ ذ أَيِي ثْعذِّيبذْ؟“  
\v 29 مَاغَارْ نتَّا يُومُورْ إِ ڒَارْيَاحْ أَمنْڭُوسْ، حِيمَا أَذْ د-إِفّغْ زِي بْنَاذمْ نِّي، مِينْزِي ثُوغَا-ث ذَايسْ \add عَاذْ\add* إِجّْ ن ڒْمِيجَارْ ن ڒْوقْثْ ذ أَمقّْرَانْ. \add ثُوغَا أَرزُّونْ\add* أَذْ ث شَارْفنْ س سّْنَاسڒْ ذ إِشذِّييّنْ، مَاشَا نتَّا ثُوغَا إِتَّارژَّا إِشذِّييّنْ نّسْ ؤُشَا \add خنِّي\add* يُوژّڒْ خَاسْ إِجّْ ن شِّيطَانْ غَارْ ڒخْڒَا.  
\v 30 إِسّقْسَا ث يَاسُوع: ”مَامّشْ ذ أَشْ قَّارنْ؟“ إِنَّا أَسْ: ”لِيخْيُونْ “، مِينْزِي شّْوَاطنْ أَطَّاسْ ثُوغَا ؤُذْفنْ ذَايسْ.  
\v 31 نِيثْنِي تَّارنْ زَّايسْ، حِيمَا وَارْ ثنْ إِتَّامَارْ أَذْ رَاحنْ غَارْ وحْفُورْ.   
\m
\v 32 ثُوغَا ذِينْ إِشْثْ ن ثْحِيمَارْثْ ذ ثَامقّْرَانْثْ ن إِڒْفَانْ، ثُوغَا ثْهدَّا ذڭْ وذْرَارْ. تَّارنْ زَّايسْ حِيمَا أَذْ ثنْ إِجّْ أَذْ أَذْفنْ ذڭْ إِڒْفَانْ. ؤُشَا نتَّا إِسَامْحْ أَسنْ.  
\v 33 فّْغنْ شّْوَاطنْ زِي بْنَاذمْ \add نِّي\add*، ؤُذْفنْ ذڭْ إِڒْفَانْ. \add خنِّي\add* ثقْنُونِّي ثْحِيمَارْثْ زِي جَّارْفْ ذِي ڒبْحَارْ ؤُشَا ثْغَارْقْ. \x ◘ \xo 8:‏33 \xt مك. 5‏:‏13\x*   
\m
\v 34 ؤُمِي ژْرِينْ إِمكْسَاونْ مِينْ إِمْسَارنْ، أَروْڒنْ ؤُشَا عَاوْذنْ ث ذِي ثنْذِينْثْ ؤُ ذِي ذْشُورَاثْ.  
\v 35 فّْغنْ-د إِوْذَانْ حِيمَا أَذْ ژَترنْ مِينْ إِمْسَارنْ. نِيثْنِي ؤُسِينْ-د غَارْ يَاسُوع، ؤُفِينْ بْنَاذمْ نِّي زِي فّْغنْ شّْوَاطنْ، يَارْضْ، س ڒعْقڒْ، إِقِّيمْ غَارْ إِضَارنْ ن يَاسُوع، ؤُشَا ڭّْوذنْ.  
\v 36 إِنِّي إِژْرِينْ مَانْ أَيَا، عَاوْذنْ أَسنْ مَامّشْ إِتّْوَاسّْڭنْفَا ؤُمَارْيَاحْ.  
\v 37 ڒْغَاشِي ن إِجَاذَارِييّنْ زَاوْڭنْ ث، حِيمَا أَذْ خَاسنْ إِڭّْوجْ، مِينْزِي ثُوذفْ إِ-ثنْ ثِيڭّْوُوذِي ثمْغَارْ. \add خَاسْ ؤُشَا\add* ينْيَا يَاسُوع ذِي ثْغَارَّابُوثْ، إِڭّْوجْ خَاسنْ. \x ◘ \xo 8:‏37 \xt ڒخ. 16‏:‏39. \x*   
\m
\v 38 أَرْيَازْ إِ زِي فّْغنْ شّْوَاطنْ، إِتَّارْ زَّايسْ، مَا أَذْ ثَاغْ إِزمَّارْ أَذْ غَارسْ إِقِّيمْ، مَاشَا يَاسُوع إِسّكّْ إِ-ث، إِنَّا أَسْ: \x ◘ \xo 8:‏38 \xt مك. 5‏:‏18. \x*  
\v 39 ”عْقبْ غَارْ ثَادَّارْثْ نّشْ، عَاوذْ \add إِ أَيْثْ بَابْ ن ثَادَّارْثْ\add* مِينْ ذَايكْ إِڭَّا أَربِّي.“ \add خَاسْ ؤُشَا\add* إِرُوحْ، إِبَارّحْ ذِي قَاعْ ثَانْذِينْثْ س مَارَّا مِينْ ذَايسْ إِڭَّا يَاسُوع.   
\b  
\m  
\s1 يدْجِيسْ ن يَايْرُوسْ ذ إِشْثْ ن ثمْغَارْثْ ثحْڒشْ زڭْ ؤُسِيزّڒْ ن إِذَامّنْ  
\m
\v 40 أَڒَامِي د-إِعْقبْ يَاسُوع، يَارحّبْ زَّايسْ إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ، مِينْزِي مَارَّا تّْرَاجَانْ ث. \x ◘ \xo 8:‏40 \xt [مت. 9‏:‏18‏-‏26؛ مك. 5‏:‏21‏-‏43] \x*  
\v 41 ؤُ خْزَارْ، يُوسَا-د إِجّْ ن ورْيَازْ قَّارنْ أَسْ يَايْرُوسْ، ثُوغَا-ث ذ أَمقّْرَانْ ن ثمْزِيذَا، إِوْضَا غَارْ إِضَارنْ ن يَاسُوع ؤُشَا إِزَاوْڭْ إِ-ث أَذْ يَاذفْ غَارْ ثَادَّارْثْ نّسْ، \x ◘ \xo 8:‏41 \xt مت. 9‏:‏18؛ مك. 5‏:‏22. \x*  
\v 42 مِينْزِي أَينِّي ن يدْجِيسْ إِ غَارسْ ثنِّي غَارْ إِدْجَا ثنْعَاشْ ن إِسڭّْوُوسَا، ثُوغَا عْڒَاينْ أَذْ ثمّثْ. أَمْ كِيذسْ إِڭُّورْ يَاسُوع، إِسّْذحّسْ إِ-ث ڒْغَاشِي.   
\m
\v 43 إِشْثْ ن ثمْغَارْثْ، ثُوغَا تَّازّْڒنْ زَّايسْ إِذَامّنْ ڒْقدّْ ن ثنْعَاشْ ن إِسڭّْوُوسَا، ثْسيَّارْ مَارَّا ڒعْوتْشْ نّسْ خْ إِضْبِيبنْ، وَارْ إِزمَّارْ حذْ أَذْ ت إِسّْڭنْفَا، \x ◘ \xo 8:‏43 \xt لَاوِي 15‏:‏25؛ مت. 9‏:‏20؛ مك. 5‏:‏25. \x*  
\v 44 ثُوسَا-د غَارسْ زِي ضفَّارْ، ثْحَاذَا أَبحْڒُوڒْ ن وَارُّوضْ نّسْ، ؤُشَا ڒخْذنِّي إِبدّْ ؤُسِيزّڒْ ن إِذَامّنْ نّسْ.  
\v 45 \add خَاسْ ؤُشَا\add* إِنَّا يَاسُوع: ”وِي ذ أَيِي إِحَاذَانْ؟“ ؤُمِي نْكَارنْ مَارَّا، إِنَّا شِيمْعُونْ بُوطْرُوسْ ذ يِينِّي أَكِيذسْ: ”\add أَ\add* أَمْسڒْمَاذْ نّغْ، ڒْغَاشِي إِسّْذحّسْ إِ-شْ ؤُ شكْ ثقَّارذْ: ’وِي ذ أَيِي إِحَاذَانْ؟‘ “  
\v 46 \add مَاشَا\add* يَاسُوع إِنَّا: ”أَقَا إِجّنْ إِحَاذَا أَيِي، مِينْزِي نشّْ ؤُشِيغْ جّهْذْ إِفّغْ زَّايِي.“  
\v 47 ؤُمِي ثسّنْ ثمْغَارْثْ، بلِّي وَارْ ثقِّيمْ وَارْ ثمْژَارْ، ثُوسَا-د س ؤُقفْقفْ ؤُشَا ثوْضَا غَارْ إِضَارنْ ن يَاسُوع، إِسْجذْ أَسْ. قِيبَاتْشْ إِ مَارَّا إِوْذَانْ ثْخبَّارْ خْ مَانْ سِّيبّثْ إِ زِي ث ثْحَاذَا ذ مَامّشْ ثتّْوَاسّْڭنْفَا ذغْيَا.  
\v 48 إِنَّا أَسْ يَاسُوع: ”أڭّْ ؤُڒْ، أَ يدْجِي، أَقَا لْ-إِيمَانْ نّمْ إِوْشَا أَمْ ثُوذَارْثْ. رُوحْ ذِي ڒهْنَا.“   
\m
\v 49 أَمْ إِسَّاوَاڒْ \add عَاذْ\add*، يُوسَا-د إِجّْ ن ورْيَازْ زِي ثَادَّارْثْ ن ؤُمقّْرَانْ ن ثمْزِيذَا، إِنَّا أَسْ: ”أَقَا يدْجِيشْ ثمُّوثْ، وَارْ سَّاحَاڒْ عَاذْ أَمْسغَّارْ.“ \x ◘ \xo 8:‏49 \xt مك. 5‏:‏35. \x*  
\v 50 مَاشَا يَاسُوع إِسْڒَا مَانْ أَيَا، إِنَّا إِ بَابَاسْ ن ثْحنْجِيرْثْ: ”وَارْ ثڭّْوذْ شَا! أَمنْ وَاهَا، نتَّاثْ أَذْ ثدَّارْ!“  
\v 51 ؤُمِي د-يُوسَا يَاسُوع غَارْ ثَادَّارْثْ، وَارْ إِجِّي ؤُڒَا ذ إِجّنْ أَذْ يَاذفْ مْغِيرْ شِيمْعُونْ ذ يَاعْقُوبْ ذ يُوحَانَّا ذ بَابَاسْ ن ثْحنْجِيرْثْ ذ يمَّاسْ.  
\v 52 ثُوغَا مَارَّا إِتّْرُو، وْثِينْ خَاسْ أَڭجْذُورْ. نتَّا إِنَّا: ”وَارْ تّْرُومْ، نتَّاثْ وَارْ ثمُّوثْ شَا، مَاشَا نتَّاثْ ثطّصْ.“ \x ◘ \xo 8:‏52 \xt يُوح. 11‏:‏11. \x*  
\v 53 نِيثْنِي ضحْشنْ ذَايسْ، سّْننْ بلِّي نتَّاثْ ثُوغَا ثمُّوثْ.   
\m
\v 54 مَاشَا أَوَارْنِي ڒَامِي إِسُّوفّغْ مَارَّا، إِطّفْ إِ-ت زڭْ ؤُفُوسْ نّسْ، إِڒَاغَا، إِنَّا أَسْ: ”\add أَ\add* ثَاحنْجِيرْثْ، كَّارْ!“  
\v 55 إِذْوڒْ-د ذَايسْ بُوحْبڒْ ؤُشَا ثكَّارْ ڒخْذنِّي. خنِّي يُومُورْ أَذْ أَسْ وْشنْ مِينْ غَا ثشّْ.  
\v 56 ثْبهْثنْ لْوَالِيذِينْ نّسْ، مَاشَا نتَّا إِوصَّا إِ-ثنْ، وَارْ قَّارنْ إِ حذْ مِينْ إِمْسَارنْ.   
\b  
\b  
\m  
\c 9
\s1 يَاسُوع إِسّكّْ ثنْعَاشْ ن رُّوسُولْ نّسْ  
\m
\v 1 يَاسُوع إِڒَاغَا-د \add غَارسْ\add* ثنْعَاشْ \add ن رُّوسُولْ\add* نّسْ، إِوْشَا أَسنْ جّهْذْ ذ صُّولْطَا خْ مَارَّا شّْوَاطنْ ؤُ \add خْ مَارَّا\add* ڒهْڒَاشَاثْ، حِيمَا أَذْ سّْڭنْفَانْ \add إِوْذَانْ\add*. \x ◘ \xo 9:‏1 \xt [مت. 10‏:‏5‏-‏15؛ مك. 6‏:‏7‏-‏13] — مت. 10‏:‏1؛ مك. 3‏:‏13؛ 6‏:‏7؛ لك. 6‏:‏13. \x*  
\v 2 إِسّكّْ إِ-ثنْ حِيمَا أَذْ بَارّْحنْ س ثْڭلْذِيثْ ن أَربِّي ؤُ حِيمَا أَذْ سّْڭنْفَانْ إِمهْڒَاشْ. \x ◘ \xo 9:‏2 \xt مت. 10‏:‏7. \x*  
\v 3 إِنَّا أَسنْ: ”وَارْ كسِّيمْ وَالُو ذڭْ وبْرِيذْ نِيغْ ثَاغَّارْشْثْ نِيغْ تّسْطِيمْ نِيغْ أَغْرُومْ ؤُڒَا ذ نُّوقَارْثْ، ؤُشَا وَارْ كسِّيمْ ؤُڒَا ذ ثْنَاينْ ن ثْشَامِيرَاثْ. \x ◘ \xo 9:‏3 \xt مت. 10‏:‏9؛ مك. 6‏:‏8؛ لك. 22‏:‏35. \x*  
\v 4 مَانْ ثَادَّارْثْ إِ غَا ثَاذْفمْ، قِّيممْ ذِينِّي ؤُشَا فّْغمْ سّنِّي.  
\v 5 مَاڒَا ثفّْغمْ زِي ثنْذِينْثْ، زرْزمْ \add خنِّي\add* ثَاعجَّاجْثْ زڭْ إِضَارنْ نْومْ قِيبَاتْشْ إِ يِينِّي وَارْ كنِّيوْ إِقبّْڒنْ، ذ شّْهَاذثْ خَاسنْ.“ \x ◘ \xo 9:‏5 \xt مت. 10‏:‏14؛ مك. 6‏:‏11؛ لك. 10‏:‏11؛ 21‏:‏13؛ 24‏:‏48؛ ڒخ. 13‏:‏51؛ 18‏:‏6. \x*  
\v 6 \add خَاسْ ؤُشَا\add* فّْغنْ رُّوسُولْ، ثُوغَا تّْشُوقَانْ ذِي ذْشُورَاثْ ذ ثْندَّامْ. نِيثْنِي تّْبَارّْحنْ س ڒخْبَارْ أَصبْحَانْ، سّْڭنْفَانْ \add إِمهْڒَاشْ\add* ذِي كُوڒْ أَمْشَانْ.   
\b  
\m  
\s1 هِيرُوذُوسْ يَارْجفْ ؤُمِي إِسْڒَا خْ مَارَّا مِينْ إِڭَّا يَاسُوع  
\m
\v 7 هِيرُوذُوسْ، ڒْحَاكمْ خْ إِجّْ ن أَرْبعْ ن ثمُّورْثْ إِسْڒَا خْ مَارَّا مِينْ إِتّْوَاڭّنْ زَّايسْ ؤُشَا يَارْجفْ، مِينْزِي شَا \add ن إِوْذَانْ\add* نَّانْ، أَقَا يُوحَانَّا إِكَّارْ-د زِي ثَادَّارْثْ ن إِمتِّيننْ. \x ◘ \xo 9:‏7 \xt [مت. 14‏:‏1‏-‏12؛ مك. 6‏:‏14‏-‏29] — مت. 14‏:‏1؛ مك. 6‏:‏14. \x*  
\v 8 شَا نّغْنِي نَّانْ أَقَا إِلِييَا إِضْهَارْ-د ؤُ شَا نّغْنِي \add عَاوذْ\add* أَقَا إِجّنْ زڭْ إِنَابِييّنْ ن وشْحَاڒْ ؤُيَا إِكَّارْ-د. \x ◘ \xo 9:‏8 \xt مت. 16‏:‏14؛ مك. 6‏:‏15؛ 8‏:‏28؛ لك. 9‏:‏19\x*  
\v 9 إِنَّا هِيرُوذُوسْ: ”أَقَا ذ نشّْ إِ إِقسّنْ أَزدْجِيفْ ن يُوحَانَّا، مَاشَا مَانِيسْ وَا إِ خفْ سْڒِيغْ \add مَارَّا\add* مَانْ أَيَا؟“ ؤُشَا ثُوغَا يَارزُّو أَذْ ث إِژَارْ.   
\b  
\m  
\s1 لْمُوعْجِيزَا ن ؤُسشِّي أَمزْوَارُو  
\m
\v 10 ؤُمِي د -عقْبنْ رُّوسُولْ، عَاوْذنْ إِ يَاسُوع مَارَّا مِينْ ڭِّينْ. خنِّي يِيوْيِي ثنْ أَكِيذسْ غَارْ إِجّْ ن ومْشَانْ إِخْڒَا غَارْ بَايْثْ-صَايْذَا، \add حِيمَا أَذْ إِڒِينْ\add* وحّذْسنْ أَكِيذسْ. \x ◘ \xo 9:‏10 \xt [مت. 14‏:‏13‏-‏21؛ مك. 6‏:‏30‏-‏44؛ يُوح. 6‏:‏1‏-‏14] — مت. 14‏:‏13؛ مك. 6‏:‏30، 31، 32. \x*  
\v 11 ؤُمِي يَارْڭبْ ڒْغَاشِي خْ مَانْ أَيَا، إِضْفَارْ إِ-ث. نتَّا ثُوغَا يَارحّبْ زَّايْسنْ، إِسِّيوڒْ أَكِيذْسنْ خْ ثْڭلْذِيثْ ن أَربِّي ؤُ إِنِّي حْذَاجنْ أَذْ تّْوَاسّْڭنْفَانْ، إِسّْڭنْفَا إِ-ثنْ.   
\m
\v 12 ڒَامِي إِبْذَا ڒْحَاڒْ إِسُّوثُومْ، قَارّْبنْ-د غَارسْ إِمحْضَارنْ نّسْ، نَّانْ أَسْ: ”سكّْ ڒْغَاشِي، حِيمَا أَذْ رَاحنْ غَارْ ڒذْشُورْ ذ إِيَّارنْ إِ ذ أَسنْ د-إِنّْضنْ، أَذْ ذِينِّي أَفنْ مَانِي غَا سّنْسنْ ذ مِينْ غَا شّنْ، مِينْزِي أَقَا أَنغْ ذَا ذڭْ إِجّْ ن ومْشَانْ إِخْڒَانْ.“ \x ◘ \xo 9:‏12 \xt مت. 14‏:‏15؛ مك. 6‏:‏35؛ يُوح. 6‏:‏5. \x*  
\v 13 مَاشَا يَاسُوع إِنَّا أَسنْ: ”وْشمْ أَسنْ كنِّيوْ حِيمَا أَذْ شّنْ.“ نَّانْ أَسْ: ”وَارْ غَارْنغْ مْغِيرْ خمْسَا ن ثشْنِيفِينْ ذ ثْنَاينْ ن إِسڒْمَانْ، نِيغْ إِتّْخصَّا أَذْ نْرَاحْ أَذْ نْسغْ مَاشَّا إِ مَارَّا إِوْذَانْ-أَ!“ \x ◘ \xo 9:‏13 \xt مت. 14‏:‏16؛ مك. 6‏:‏37؛ يُوح. 6‏:‏9. \x*  
\v 14 مِينْزِي ثُوغَا أَثنْ ذِي شَا ن خمْسَاڒَافْ ن يرْيَازنْ. \add مَاشَا\add* يَاسُوع إِنَّا أَسنْ: ”سْغِيممْ ثنْ ذِي ثْعُورِّيشِينْ ن خمْسِينْ.“  
\v 15 ؤُشَا ڭِّينْ إِمحْضَارنْ أَمنِّي ؤُشَا سّْغِيمنْ ثنْ مَارَّا.  
\v 16 إِكْسِي يَاسُوع ثِيشْنِيفِينْ س خمْسَا ؤُڒَا ذ ثْنَاينْ ن إِسڒْمَانْ \add نِّي\add*، إِسّْڭعّذْ ثَامُوغْڒِي نّسْ غَارْ ؤُجنَّا، ؤُشَا إِبَارْكْ \add إِ-ثنْثْ\add*، يَارْژَا ؤُشَا إِوْشَا \add زِي ثشْنِيفِينْ نِّي\add* إِ إِمحْضَارنْ نّسْ، حِيمَا أَذْ وْشنْ إِ ڒْغَاشِي. \x ◘ \xo 9:‏16 \xt 1 صم. 9‏:‏13؛ مك. 6‏:‏41\x*  
\v 17 شِّينْ، جِّيوْننْ مَارَّا. أَڒَامِي ذ جَارْونْ مِينْ إِقِّيمنْ زڭْ إِڒقّْوَازْ، ثُوغَا ذِينِّي ثنْعَاشْ ن ثْسُودْجَاثِينْ.   
\b  
\m  
\s1 شّْهَاذثْ ن شِيمْعُونْ بُوطْرُوسْ  
\m
\v 18 أَمْ ثُوغَا يَاسُوع إِتّْژَادْجْ وحّْذسْ، أَمْ ثُوغَا إِمحْضَارنْ أَكِيذسْ، إِسّقْسَا ثنْ، إِنَّا: ”مِينْ إِقَّارْ ڒْغَاشِي مِينْ عْنِيغْ؟“ \x ◘ \xo 9:‏18 \xt [مت. 16‏:‏13‏-‏19؛ مك. 8‏:‏27‏-‏29] — مت. 16‏:‏13؛ مك. 8‏:‏27. \x*  
\v 19 أَرِّينْ-د، نَّانْ أَسْ: ” ’يُوحَانَّا أَمْسغْضَاصْ!‘، ؤُ إِنّغْنِي: ’إِلِييَا!‘، ؤُ شَا إِنّغْنِي: ’أَقَا إِكَّارْ-د إِجّْ ن ؤُنَابِي، إِجّنْ زڭْ إِنَابِييّنْ ن وشْحَاڒْ ؤُيَا‘.“ \x ◘ \xo 9:‏19 \xt مت. 14‏:‏2؛ مت. 16‏:‏14؛ مك. 6‏:‏15؛ 8‏:‏28؛ لك. 9‏:‏8\x*  
\v 20 إِنَّا أَسنْ: ”إِ كنِّيوْ، مِينْ ثقَّارمْ مِينْ عْنِيغْ؟“ يَارَّا-د شِيمْعُونْ، إِنَّا: ”لْمَاسِيحْ ن أَربِّي.“  
\v 21 \add خنِّي\add* إِعْڒمْ أَسنْ س جّهْذْ ؤُشَا إِوصَّا ثنْ، وَارْ ث قَّارنْ إِ حذْ.   
\b  
\m  
\s1 يَاسُوع إِسَّاوَاڒْ خْ ڒْموْثْ ذ ثْنُوكْرَا نّسْ إِ ثْوَاڒَا ثَامزْوَارُوثْ  
\m
\v 22 إِنَّا أَسنْ: ”إِتّْخصَّا إِ مِّيسْ ن بْنَاذمْ أَذْ إِودّبْ أَطَّاسْ ؤُشَا أَذْ إِمّنْضَارْ زڭْ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ذ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ، أَذْ إِتّْوَانغْ ؤُشَا ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا أَذْ د-إِكَّارْ.“ \x ◘ \xo 9:‏22 \xt [مت. 16‏:‏21‏-‏28؛ مك. 8‏:‏30‏-‏9‏:‏1] — مت. 16‏:‏21؛ 17‏:‏22؛ مك. 8‏:‏31؛ 9‏:‏31؛ 10‏:‏33؛ لك. 18‏:‏31؛ 24‏:‏7. \x*  
\v 23 \add خَاسْ ؤُشَا\add* إِنَّا إِ مَارَّا: ”مَاڒَا إِخْسْ حذْ أَذْ د-يَاسْ أَوَارْنِي أَيِي، إِتّْخصَّا أَسْ أَذْ إِنْكَارْ إِخفْ نّسْ، أَذْ إِكْسِي صَّالِيبْ نّسْ كُوڒْ أَسّْ ؤُشَا أَذْ أَيِي د-إِضْفَارْ. \x ◘ \xo 9:‏23 \xt مت. 10‏:‏38؛ 16‏:‏24؛ مك. 8‏:‏34؛ لك. 14‏:‏27. \x*  
\v 24 مِينْزِي وِي إِخْسنْ أَذْ إِسّنْجمْ ثُوذَارْثْ نّسْ، أَذْ ت إِودَّارْ. مَاشَا وِي إِخْسنْ أَذْ إِودَّارْ ثُوذَارْثْ نّسْ ذِي طّْوعْ إِنُو، أَذْ ت إِسّنْجمْ. \x ◘ \xo 9:‏24 \xt مت. 10‏:‏39؛ 16‏:‏25؛ مك. 8‏:‏35؛ لك. 17‏:‏33؛ يُوح. 12‏:‏25. \x*  
\v 25 مِينْزِي مَانْ ڒفْضڒْ إِ بْنَاذمْ مَاڒَا يَارْبحْ دُّونشْثْ مَارَّا، مَاشَا أَذْ يَاردّدْجْ ڒعْمَارْ نّسْ نِيغْ أَذْ ث إِودَّارْ؟  
\v 26 مِينْزِي ونِّي إِ غَا إِسضْحَانْ زَّايِي ؤُ زڭْ وَاوَاڒنْ إِنُو، أَذْ زَّايسْ إِسضْحَا \add عَاوذْ\add* مِّيسْ ن بْنَاذمْ خْمِي د غَا يَاسْ ذڭْ ؤُعُودْجِي نّسْ ؤُ ذڭْ ؤُعُودْجِي ن بَابَاسْ أَكْ-ذ لْمَالَاكَاثْ نّسْ إِقدّْسنْ. \x ◘ \xo 9:‏26 \xt مت. 10‏:‏33؛ مك. 8‏:‏38؛ لك. 12‏:‏9؛ 2 تِيم. 2‏:‏12؛ 1 يُوح. 2‏:‏23. \x*  
\v 27 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، أَقَا شَا زڭْ إِنِّي ذَا إِحْضَارنْ، وَارْ تّْقِيسِينْ شَا ڒْموْثْ أَڒْ غَا ژَترنْ ثَاڭلْذِيثْ ن أَربِّي.“ \x ◘ \xo 9:‏27 \xt مت. 16‏:‏28؛ مك. 9‏:‏1. \x*   
\b  
\m  
\s1 أَسْعُودْجِي ن يَاسُوع خْ وذْرَارْ  
\m
\v 28 عْڒَاحَاڒْ ثْمنْيَا ن وُوسَّانْ أَوَارْنِي ڒَامِي \add إِنَّا\add* أَوَاڒنْ-أَ، إِوْيِي-د يَاسُوع أَكِيذسْ شِيمْعُونْ ذ يَاعْقُوبْ ذ يُوحَانَّا ؤُشَا إِڭعّذْ غَارْ وذْرَارْ، حِيمَا أَذْ إِژَّادْجْ. \x ◘ \xo 9:‏28 \xt [مت. 17‏:‏1‏-‏8؛ مك. 9‏:‏2‏-‏8] — مت. 17‏:‏1؛ مك. 9‏:‏2. \x*  
\v 29 أَمْ ثُوغَا إِتّْژَادْجْ، إِبدّڒْ وُوذمْ ن ؤُغمْبُوبْ نّسْ ؤُ أَرُّوضْ نّسْ إِذْوڒْ ذ أَشمْڒَاڒْ إِتِّيسِّيقنْ.  
\v 30 خْزَارْ، ثْنَاينْ ن يرْيَازنْ سِّيوْڒنْ أَكِيذسْ، ثُوغَا أَثنْ ذ مُوسَا ذ إِلِييَا،  
\v 31 إِنِّي د-إِضْهَارنْ س ؤُعُودْجِي، ثُوغَا سَّاوَاڒنْ خْ وُوفُّوغْ نّسْ إِ ثُوغَا إِ غَا إِتّْوَاكمّڒْ ذِي ؤُرْشَالِيمْ.  
\v 32 شِيمْعُونْ ذ يِينِّي أَكِيذسْ، ثُوغَا إِكَّا خَاسنْ يِيضصْ، أَڒَامِي عْڒَاينْ وَارْ زمَّارنْ أَذْ قِّيمنْ فَاقنْ. نِيثْنِي ژْرِينْ أَعُودْجِي نّسْ ذ ثْنَاينْ ن يرْيَازنْ بدّنْ أَكِيذسْ.  
\v 33 أَڒَامِي خَاسْ فَارْقنْ إِنَا، إِنَّا شِيمْعُونْ إِ يَاسُوع: ”\add أَ\add* أَمْسڒْمَاذْ إِنُو، أَقَا مْلِيحْ ؤُمِي إِ ذَا ندْجْ. أجّْ أَنغْ أَذْ نوّثْ ثْڒَاثَا ن إِعُوشُّوثنْ ن ثْسطَّا، إِجّنْ إِ شكْ، إِجّنْ إِ مُوسَا ؤُ إِجّنْ إِ إِلِييَا.“ نتَّا \add مَاشَا\add* وَارْ إِسِّينْ مِينْ إِنَّا.  
\v 34 أَوَارْنِي ڒَامِي إِنَّا مَانْ أَيَا، إِكَّا-د خَاسنْ إِجّْ ن ؤُسيْنُو، إِسّْذُورِييْ إِ-ثنْ ؤُشَا نِيثْنِي ذوْڒنْ ڭّْوذنْ ؤُمِي ژْرِينْ مُوسَا ذ إِلِييَا ؤُذْفنْ غَارْ ؤُسيْنُو.  
\v 35 ثُوسَا-د إِشْثْ ن ثْمِيجَّا زڭْ ؤُجنَّا، ثقَّارْ: ”ذ وَا ذ مِّي إِعِيزّنْ، سْڒمْ غَارسْ!“ \x ◘ \xo 9:‏35 \xt أَعَوذ. 18‏:‏15؛ إِشا. 42‏:‏1؛ مت. 3‏:‏17؛ 17‏:‏5؛ مك. 1‏:‏11؛ 9‏:‏7؛ لك. 3‏:‏22؛ ڒخ. 3‏:‏22؛ كُول. 1‏:‏13؛ 2 بُط. 1‏:‏17. \x*  
\v 36 أَڒَامِي د-ثُوسَا ثْمِيجَّا، ؤُفِينْ يَاسُوع وحّْذسْ. نِيثْنِي سّْقَارنْ ؤُشَا وَارْ خبَّارنْ حذْ ذڭْ وُوسَّانْ نِّي س مِينْ ژْرِينْ.   
\b  
\m  
\s1 أَسْڭنْفِي ن إِجّْ ن ؤُحنْجِيرْ ذَايسْ ڒَارْيَاحْ ذ أَمنْڭُوسْ  
\m
\v 37 ثِيوشَّا نّسْ، أَڒَامِي ثُوغَا د-هكّْوَانْ زڭْ وذْرَارْ، إِڒْقَا ثنْ-إِ-د إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ. \x ◘ \xo 9:‏37 \xt [مت. 17‏:‏14‏-‏18؛ مك. 9‏:‏14‏-‏27] — مت. 17‏:‏14؛ مك. 9‏:‏17. \x*  
\v 38 ؤُ خْزَارْ، إِجّْ ن ورْيَازْ زِي ڒْغَاشِي إِسْغُويْ، إِنَّا: ”\add أَ\add* أَمْسغَّارْ، تّْزَاوْڭغْ شكْ، حِينّْ خَافِي، أَقَا-ث ذ أَينِّي ن مِّيسْ إِ غَارِي.  
\v 39 خْزَارْ، إِتّطّفْ إِ-ث إِجّْ ن ڒَارْيَاحْ، خنِّي إِسْغُويُّو ذغْيَا، إِتّْغژَّا ثِيغْمَاسْ ؤُ إِتّكّْ أَسْ-د كُوفُّو زڭْ ؤُقمُّومْ، عْڒَاحَارْ وَارْ ذ أَسْ يَارخُّو أَمْ ث إِيزّمْ \add أَمُّو\add*.  
\v 40 تَّارغْ زڭْ إِمحْضَارنْ نّشْ أَذْ ث سُّوفّْغنْ، مَاشَا وَارْ زمَّارنْ.“  
\v 41 يَارَّا-د يَاسُوع، إِنَّا: ”أَ جِّيڒْ إِ وَارْ يُومِيننْ إِمْعوّْجنْ، مشْحَاڒْ غَارْومْ إِ غَا كّغْ أَذْ كنِّيوْ كْسِيغْ؟ أَوِي-د مِّيشْ ذَا!“  
\v 42 أَڒَامِي غَارسْ ث-إِ-د-إِسّْقَارّبْ، إِنْضَارْ إِ-ث شِّيطَانْ \add ذِي ثمُّورْثْ\add*، إِمزّقْ إِ-ث. مَاشَا يَاسُوع إِوبّخْ ڒَارْيَاحْ أَمنْڭُوسْ، إِسّْڭنْفَا أَحنْجِيرْ ؤُشَا يَارَّا إِ-ث إِ بَابَاسْ.   
\b  
\m  
\s1 يَاسُوع إِسَّاوَاڒْ خْ ڒْموْثْ ذ ثْنُوكْرَا نّسْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ  
\m
\v 43 مَارَّا ثُوغَا تّْعجّْبنْ ذِي ڒمْغَارثْ ن أَربِّي. ؤُشَا ؤُمِي ثْبهْثنْ مَارَّا نِيثْنِي ذِي مَارَّا مِينْ إِڭَّا يَاسُوع، إِنَّا إِ إِمحْضَارنْ نّسْ: \x ◘ \xo 9:‏43 \xt [مت. 17‏:‏22‏-‏23؛ مك. 9‏:‏30‏-‏32]\x*  
\v 44 ”ڭّمْ أَوَاڒنْ-أَ ذڭْ إِمزُّوغنْ نْومْ، مِينْزِي مِّيسْ ن بْنَاذمْ أَذْ إِمّوْشْ ذڭْ إِفَاسّنْ ن إِوْذَانْ.“ \x ◘ \xo 9:‏44 \xt مت. 17‏:‏22؛ مك. 9‏:‏31. \x*  
\v 45 مَاشَا نِيثْنِي وَارْ فْهِيمنْ إِ وَاوَاڒْ-أَ، ثُوغَا إِتّْوَاسّْنُوفَّارْ خَاسنْ مَاحنْذْ وَارْ ث فهّْمنْ. ؤُشَا نِيثْنِي ڭّْوذنْ أَذْ ث سّقْسَانْ خْ وَاوَاڒْ-أَ. \x ◘ \xo 9:‏45 \xt لك. 2‏:‏50؛ 18‏:‏34. \x*   
\b  
\m  
\s1 مَانْ ونْ إِدْجَانْ ذ أَمقّْرَانْ؟  
\m
\v 46 يُوذفْ إِ-ثنْ إِجّْ ن ؤُمْشُوبّشْ خْ مَانْ ونْ زَّايْسنْ إِ غَا يِيڒِينْ ذ أَمقّْرَانْ قَاعْ. \x ◘ \xo 9:‏46 \xt [مت. 18‏:‏1‏-‏5؛ مك. 9‏:‏33‏-‏37] — مت. 18‏:‏1؛ مك. 9‏:‏33؛ لك. 22‏:‏24. \x*  
\v 47 مَاشَا إِسّنْ يَاسُوع أَخَارّصْ ن وُوڒَاونْ نْسنْ ؤُشَا إِكْسِي إِجّْ ن ؤُحنْجِيرْ إِسّْبدّْ إِ-ث غَارسْ.  
\v 48 إِنَّا أَسنْ: ”وِي غَا إِقبْڒنْ أَحنْجِيرْ-أَ س يِيسمْ إِنُو، إِقْبڒْ أَيِي نشّْ، ؤُ وِي ذ أَيِي غَا إِقبْڒنْ، إِقْبڒْ ونِّي ذ أَيِي د-إِسّكّنْ. مِينْزِي ونِّي ذ أَمژْيَانْ قَاعْ جَارْ أَومْ، نتَّا أَذْ يِيڒِي ذ أَمقّْرَانْ.“ \x ◘ \xo 9:‏48 \xt مت. 18‏:‏5؛ 23‏:‏11؛ مك. 9‏:‏37؛ لك. 10‏:‏16؛ 14‏:‏11؛ 18‏:‏14؛ يُوح. 13‏:‏20. \x*   
\b  
\m  
\s1 وِي وَارْ إِدْجِينْ ضِيدّْ نْومْ، نتَّا أَقَا-ث أَكِيذْومْ  
\m
\v 49 إِطّفْ يُوحَانَّا ذڭْ وَاوَاڒْ، إِنَّا: ”\add أَ\add* أَمْسڒْمَاذْ نّغْ، نژْرَا إِجّنْ إِسُّوفُّوغْ شّْوَاطنْ س يِيسمْ نّشْ ؤُشَا نسّْبدّْ إِ-ث، مِينْزِي نتَّا وَارْ شكْ إِضفَّارْ \add جْمِيعْ\add* أَكِيذْنغْ.“ \x ◘ \xo 9:‏49 \xt [مك. 9‏:‏38‏-‏40] — مك. 9‏:‏38. \x*  
\v 50 إِنَّا أَسْ يَاسُوع: ”وَارْ ث سْبدَّامْ، مِينْزِي وِي وَارْ إِدْجِينْ ضِيدّْ نْومْ، أَقَا-ث أَكِيذْومْ.“ \x ◘ \xo 9:‏50 \xt مت. 12‏:‏30؛ مك. 9‏:‏39؛ لك. 9‏:‏50؛ 11‏:‏23. \x*   
\b  
\m  
\s1 يَاسُوع ذڭْ إِجّْ ن ذْشَارْ ن إِسَامِيرِييّنْ  
\m
\v 51 ؤُمِي د-إِوْضنْ أَذْ كمّْڒنْ وُوسَّانْ ن ثْمكْسِيثْ نّسْ نّسْ \add غَارْ ؤُجنَّا\add*، يَارَّا أَغمْبُوبْ نّسْ غَارْ ؤُرْشَالِيمْ. \x ◘ \xo 9:‏51 \xt مك. 16‏:‏19؛ ڒخ. 1‏:‏2؛ 1 تِيم. 3‏:‏16. \x*  
\v 52 إِسّكّْ زَّاثسْ إِرقَّاسنْ، ؤُشَا إِنَا ؤُذْفنْ غَارْ إِجّْ ن ذْشَارْ ن إِسَامَارِييّنْ، حِيمَا أَذْ أَسْ وجْذنْ \add ذِينْ\add*.  
\v 53 نِيثْنِي \add مَاشَا\add* وَارْ ث قْبِيڒنْ، مِينْزِي يَارَّا أَغمْبُوبْ نّسْ، حِيمَا أَذْ إِرَاحْ غَارْ ؤُرْشَالِيمْ. \x ◘ \xo 9:‏53 \xt يُوح. 4‏:‏9. \x*  
\v 54 ؤُمِي ژْرِينْ يَاعْقُوبْ ذ يُوحَانَّا، إِمحْضَارنْ نّسْ، مَانْ أَيَا، نَّانْ: ”أَ سِيذِيثْنغْ، مَا ثخْسذْ أَذْ نُومُورْ، حِيمَا أَذْ د-ثهْوَا ثْمسِّي زڭْ ؤُجنَّا، مَاحنْذْ أَذْ ثنْ ثشّْ أَمْ مَامّشْ إِڭَّا عَاوذْ إِلِييَا؟“  
\v 55 \add مَاشَا\add* أَمْ د-إِنّقْڒبْ، إِوبّخْ إِ-ثنْ، إِنَّا: ”وَارْ ثسِّينمْ شَا مَانْ أَرُّوحْ إِ زِي ثدْجَامْ كنِّيوْ!  
\v 56 مِينْزِي مِّيسْ ن بْنَاذمْ وَارْ د-يُوسِي شَا حِيمَا أَذْ إِسّْهلّكْ ڒعْمُورْ ن إِوْذَانْ، مَاشَا حِيمَا أَذْ إِوْشْ ثُوذَارْثْ!“ خنِّي رُوحنْ غَارْ ذْشُورَاثْ نّغْنِي. \x ◘ \xo 9:‏56 \xt يُوح. 3‏:‏17؛ 12‏:‏47. \x*   
\b  
\m  
\s1 أَضْفَارْ ن يَاسُوع  
\m
\v 57 أَمْ ڭُّورنْ نِيثْنِي ذڭْ وبْرِيذْ، إِنَّا أَسْ إِجّْ ن ورْيَازْ: ”أَ سِيذِي إِنُو، أَذْ شكْ ضْفَارغْ مَانِي مَا إِ غَا ثْرَاحذْ.“ \x ◘ \xo 9:‏57 \xt [مت. 8‏:‏19‏-‏22] — مت. 8‏:‏19. \x*  
\v 58 إِنَّا أَسْ يَاسُوع: ”إِشعْبَاونْ غَارْسنْ إِفْرَانْ ذ إِجْضَاضْ ن ؤُجنَّا غَارْسنْ ڒعْوَاشّْ، مَاشَا مِّيسْ ن بْنَاذمْ وَارْ غَارسْ ؤُڒَا مَانِي غَا إِسنّذْ أَزدْجِيفْ نّسْ.“   
\m
\v 59 إِنَّا إِ ونّغْنِي: ”ضْفَارْ أَيِي-د!“ مَاشَا وَانِيثَا إِنَّا: ”\add أَ\add* سِيذِي إِنُو، أجّْ أَيِي أَمزْوَارْ أَذْ أَرڭّْوحغْ أَذْ نضْڒغْ بَابَا!“ \x ◘ \xo 9:‏59 \xt مت. 8‏:‏21. \x*  
\v 60 \add مَاشَا\add* إِنَّا أَسْ يَاسُوع: ”أجّْ إِمتِّيننْ أَذْ نضْڒنْ إِمتِّيننْ نْسنْ، مَاشَا شكْ رُوحْ، ثْبَارّْحذْ س ثْڭلْذِيثْ ن أَربِّي.“ \x ◘ \xo 9:‏60 \xt مت. 8‏:‏22. \x*   
\m
\v 61 إِنَّا أَسْ ونّغْنِي: ”أَذْ شكْ ضْفَارغْ، \add أَ\add* سِيذِي، مَاشَا أجّْ أَيِي أَمزْوَارْ أَذْ ڭّغْ أَلَّاهْ إِهنِّيكْ خْ يِينِّي غَارِي ذِي ثَادَّارْثْ إِنُو، \add خنِّي\add* أَذْ د-أَسغْ.“  
\v 62 إِنَّا أَسْ يَاسُوع: ”ؤُڒَا ذ إِجّْ، مَاڒَا إِسّْرُوسَا أَفُوسْ نّسْ خْ ؤُسْغَارْ، خنِّي أَذْ إِخْزَارْ غَارْ ضفَّارْ، أَذْ إِصْڒحْ إِ ثْڭلْذِيثْ ن أَربِّي.“ \x ◘ \xo 9:‏62 \xt أَوڒن. 26‏:‏11؛ فِيل. 3‏:‏14؛ عبر. 6‏:‏5؛ 2 بُط. 2‏:‏20. \x*   
\b  
\b  
\m  
\c 10
\s1 أَسكِّي ن سبْعِينْ ن إِمحْضَارنْ  
\m
\v 1 أَوَارْنِي مَانْ أَيَا إِڒقّمْ يَاسُوع عَاوذْ سبْعِينْ نّغْنِي زڭْ إِمحْضَارنْ نّسْ ؤُشَا إِسّكّْ إِ-ثنْ ثْيُويَا ثْيُويَا قِيبَاتْشْ إِ ؤُغمْبُوبْ نّسْ غَارْ مَارَّا ثِيندَّامْ ذ جّْوَايهْ مَانِي ثُوغَا نتَّا إِڭَّا أَذْ إِرَاحْ. \x ◘ \xo 10:‏1 \xt [مت. 11‏:‏20‏-‏27؛ 13‏:‏16‏-‏17] \x*  
\v 2 إِنَّا أَسنْ: ”ثَاميْرَا أَطَّاسْ، مَاشَا إِخدَّامنْ ذْرُوسْ، س ؤُينِّي تَّارمْ إِ بَابْ ن ثْميْرَا، حِيمَا أَذْ إِسّكّْ إِخدَّامنْ غَارْ ثْميْرَا نّسْ. \x ◘ \xo 10:‏2 \xt مت. 9‏:‏37؛ يُوح. 4‏:‏35؛ 2 تس. 3‏:‏1. \x*  
\v 3 رُوحمْ! أَقَا أَذْ كنِّيوْ سّكّغْ أَمْ وُودْجِي جَارْ وُوشَّاننْ. \x ◘ \xo 10:‏3 \xt مت. 10‏:‏16. \x*  
\v 4 وَارْ كِيومْ كسِّيمْ ثِيشْيَارِينْ ڒَا ذ تّسْطَايمْ ؤُڒَا ذ سَانْذَالِييَاثْ، وَارْ تّْسدْجَاممْ خْ حذْ ذڭْ وبْرِيذْ. \x ◘ \xo 10:‏4 \xt 2 إِج. 4‏:‏29؛ مت. 10‏:‏9؛ مك. 6‏:‏8؛ لك. 9‏:‏3؛ 22‏:‏35. \x*  
\v 5 مَانْ مَا ثَادَّارْثْ إِ غَا ثَاذْفمْ، إِنِيمْ ذ أَمزْوَارُو: ’ڒهْنَا خْ ثَادَّارْثْ-أَ.‘ \x ◘ \xo 10:‏5 \xt مت. 10‏:‏12؛ مك. 6‏:‏10. \x*  
\v 6 مَاڒَا ذِينْ مِّيسْ ن ڒهْنَا، ڒهْنَا نْومْ أَذْ خَاسْ يَارْسَا، مَاڒَا وَارْ إِدْجِي أَمنِّي، ڒهْنَا نْومْ أَذْ غَارْومْ د-إِعْقبْ.  
\v 7 قِّيممْ ذِي ثَادَّارْثْ نِّي، شّمْ، سْومْ زِي مِينْ غَارْسنْ، مِينْزِي أَخدَّامْ إِسْذَاهدْجْ ڒْمُونثْ نّسْ. \add س ؤُيَا\add* وَارْ ڭُّورمْ شَا زِي ثَادَّارْثْ غَارْ ثَادَّارْثْ نّغْنِي. \x ◘ \xo 10:‏7 \xt لَاوِي 19‏:‏13؛ أَعَوذ. 24‏:‏14؛ 25‏:‏4؛ مت. 10‏:‏10؛ 1 كُور. 9‏:‏4، 14؛ 10‏:‏27؛ 1 تِيم. 5‏:‏18. \x*  
\v 8 مَانْ ثَانْذِينْثْ إِ غَا ثَاذْفمْ ؤُشَا أَذْ كنِّيوْ قبْڒنْ، شّمْ \add ذِينْ\add* مِينْ ذ أَومْ غَا وْشنْ.  
\v 9 سْڭنْفَامْ إِمهْڒَاشْ إِ ذِينْ إِدْجَانْ، إِنِيمْ أَسنْ: ”أَقَا ثْقَارّبْ-د غَارْومْ ثْڭلْذِيثْ ن أَربِّي.“  
\v 10 مَانْ مَا ثَانْذِينْثْ إِ غَا ثَاذْفمْ، وَارْ كنِّيوْ قْبِيڒنْ، فّْغمْ غَارْ زّْنَاقِي نّسْ، إِنِيمْ: \x ◘ \xo 10:‏10 \xt مت. 10‏:‏14؛ مك. 6‏:‏11؛ لك. 9‏:‏5. \x*  
\v 11 ”عَاذْ ؤُڒَا ذ ثَاعجَّاجْثْ إِ ذَايْنغْ إِڒصْقنْ خْ \add إِضَارنْ\add* نّغْ ن ثنْذِينْثْ نْومْ، أَذْ ت نزّرْزْ خَاومْ. مَاشَا سْنمْ أَيَا، أَقَا ثْقَارّبْ-د غَارْومْ ثْڭلْذِيثْ ن أَربِّي! \x ◘ \xo 10:‏11 \xt ڒخ. 13‏:‏51؛ 18‏:‏6. \x*  
\v 12 أَذْ أَومْ إِنِيغْ بلِّي ذڭْ وَاسّْ نِّي أَذْ يِيڒِي ڒْحَاڒْ ن سَاذُومْ إِهْونْ زِي ثنْذِينْثْ نِّي.“   
\b  
\m
\v 13 \bd ؤُشْثْ خَامْ، \+add أَ\+add* خُورَازِينْ، ؤُشْثْ خَامْ، \+add أَ\+add* بَايْثْ-صَايْذَا!\bd* مْڒِي مْسَارنْثْ ذِي صُورْ ذ صَايْذُونْ ڒعْجَايبْ إِ إِتّْوَاڭّنْ ذَايْكنْثْ، أَذْ ثِيڒِي ثُوبنْثْ زِي زّْمَانْ أَمْ قِّيمنْثْ ذِي ثْخَانْشثْ ن وشْضَانْ ذ يِيغّضْ \add خْ إِزدْجِيفنْ نْسنْثْ\add*. \x ◘ \xo 10:‏13 \xt مت. 11‏:‏20‏-‏24\x*  
\v 14 مَاشَا أَذْ يِيڒِي ڒْحَاڒْ ن صُورْ ذ صَايْذُونْ إِهْونْ زِي ڒْحَاڒْ نْكنْثْ ذِي لْحِيسَابْ.  
\v 15 ؤُ شمْ، \add أَ\add* كَافَارْنَاحُومْ، ثنِّي ثُوغَا إِتّْوَاسّْڭعّْذنْ غَارْ ؤُجنَّا، أَقَا أَذْ ثتّْوَاسّهْوِيذْ غَارْ ڒَاخَارْثْ!   
\m
\v 16 وِي زَّايْومْ إِ غَا إِسْڒنْ، أَذْ زَّايِي إِسڒْ، وِي كنِّيوْ غَا يَاڭِينْ، أَذْ أَيِي يَاڭِي، ؤُ وِي ذ أَيِي غَا يَاڭِينْ، أَذْ يَاڭِي ونِّي ذ أَيِي د-إِسّكّنْ.“ \x ◘ \xo 10:‏16 \xt مت. 10‏:‏40؛ مك. 9‏:‏37؛ يُوح. 13‏:‏20. \x*   
\b  
\m
\v 17 \add خنِّي\add*عقْبنْ سبْعِينْ نِّي س ڒفْرَاحثْ أَطَّاسْ، نَّانْ أَسْ: ”\add أَ\add* سِيذِيثْنغْ، ؤُڒَا ذ شّْوَاطنْ طَّاعنْ أَنغْ س يِيسمْ نّشْ.“  
\v 18 \add خَاسْ ؤُشَا\add* إِنَّا أَسنْ: ”ژْرِيغْ شِّيطَانْ إِوْضَا-د أَمشْنَاوْ أَسَّامْ زڭْ ؤُجنَّا. \x ◘ \xo 10:‏18 \xt أَسَا. 12‏:‏8، 9. \x*  
\v 19 خْزَارْ، نشّْ أَذْ أَومْ وْشغْ صُّولْطَا حِيمَا أَذْ ثْعفْسمْ خْ إِفِيغْرَانْ ذ إِغَارْضْمِيونْ ؤُڒَا \add ذ صُّولْطَا\add* خْ مَارَّا جّهْذْ ن ڒعْذُو. ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ وَارْ كنِّيوْ ثْضَارِّي. \x ◘ \xo 10:‏19 \xt مك. 16‏:‏18؛ ڒخ. 28‏:‏5. \x*  
\v 20 مَاشَا وَارْ فَارّْحمْ شَا س ؤُيَا، بلِّي أَقَا شّْوَاطنْ أَذْ أَومْ طَّاعنْ، مَاشَا فَارْحمْ بلِّي أَقَا إِسْمَاونْ نْومْ تّْوَازمّمنْ ذڭْ إِجنْوَانْ.“ \x ◘ \xo 10:‏20 \xt ؤُف. 32‏:‏32؛ إِشا. 4‏:‏3؛ دَان. 12‏:‏1؛ فِيل. 4‏:‏3. \x*   
\b  
\m
\v 21 ذِي ثْسَاعّثْ نِّي إِفَارْحْ يَاسُوع ذِي أَرُّوحْ إِقدّْسنْ، إِنَّا: \bd ”نشّْ تّْقَاذِيغْ شكْ، أَ بَابَا، بَابْ ن ؤُجنَّا ذ ثمُّورْثْ\bd*، مِينْزِي ثسّْنُوفَّارذْ ثِيمسْڒَايِينْ-أَ خْ إِمِيغِيسنْ ؤُ خْ أَيْثْبَابْ ن ڒعْقڒْ ؤُشَا ثسَّارڭْبذْ ثنْثْ إِ إِحنْجِيرنْ. وَاهْ، أَ بَابَا، أَمُّو إِ ثُوغَا إِخْسْ ڒْخَاضَارْ نّشْ!“ \x ◘ \xo 10:‏21 \xt [مت. 11‏:‏25‏-‏27؛ 13‏:‏16‏-‏17] — أَيُوبْ 5‏:‏12؛ إِشا. 29‏:‏14؛ مت. 11‏:‏25؛ 1 كُور. 1‏:‏19؛ 2‏:‏7، 8؛ 2 كُور. 3‏:‏14. \x*  
\v 22 \add خَاسْ ؤُشَا\add* إِنّقْڒبْ غَارْ إِمحْضَارنْ نّسْ، إِنَّا: ”كُوڒْشِي إِمّوْشْ أَيِي زِي بَابَا ؤُشَا ؤُڒَا ذ إِجّْ وَارْ إِسِّينْ مَانْ ونْ ذ مِّيسْ مْغِيرْ بَابَاسْ ؤُشَا \add ؤُڒَا ذ إِجّْ وَارْ إِسِّينْ\add* مَانْ ونْ ذ بَابَاسْ مْغِيرْ مِّيسْ، ذ ونِّي ؤُمِي إِخْسْ مِّيسْ أَذْ \add ث\add* إِسَّارْڭبْ.“ \x ◘ \xo 10:‏22 \xt إِزهد. 8‏:‏7؛ يُوح. 1‏:‏18؛ 3‏:‏35؛ 6‏:‏44، 45؛ 17‏:‏2؛ 1 كُور. 15‏:‏27؛ فِيل. 2‏:‏10؛ عبر. 2‏:‏8. \x*   
\m
\v 23 \add خنِّي\add* إِنّقْڒبْ-د غَارْ إِمحْضَارنْ وحّذْسنْ، إِنَّا: ”سّعْذْ ن ثِيطَّاوِينْ إِ إِتّْوَاڒَانْ مِينْ ثتّْوَاڒَامْ كنِّيوْ. \x ◘ \xo 10:‏23 \xt مت. 13‏:‏16. \x*  
\v 24 مِينْزِي نشّْ أَذْ أَومْ إِنِيغْ، أَقَا أَطَّاسْ ن إِنَابِييّنْ ذ إِجدْجِيذنْ ثُوغَا خْسنْ أَذْ ژَترنْ مِينْ ثتّْوَاڒَامْ كنِّيوْ، \add مَاشَا\add* وَارْ ت تّْوِيڒِينْ، ؤُڒَا أَذْ سْڒنْ مِينْ ثتّسْڒَامْ، \add مَاشَا\add* وَارْ ت سْڒِينْ.“ \x ◘ \xo 10:‏24 \xt 1 بُط. 1‏:‏10. \x*   
\b  
\m  
\s1 أَمذْيَا ن ورْيَازْ ذ أَرْحِيمْ زِي سَامَارْيَا  
\m
\v 25 خْزَارْ، إِجّْ ن ؤُمْسڒْمَاذْ ن إِذْلِيسنْ إِكَّارْ حِيمَا أَذْ ث إِجَارّبْ، إِنَّا: ”\add أَ\add* أَمْسغَّارْ، مِينْ غَا ڭّغْ حِيمَا أَذْ وَارْثغْ ثُوذَارْثْ إِتّْذُومَانْ؟“  
\v 26 يَاسُوع إِنَّا أَسْ: ”مَامّشْ ث يُورِينْ ذِي شَّارِيعَا؟ مَامّشْ ثقَّارذْ؟“  
\v 27 يَارَّا-د، إِنَّا أَسْ: ”أَذْ ثخْسذْ سِيذِي، أَربِّي نّشْ س مَارَّا وُوڒْ نّشْ، س مَارَّا ڒعْمَارْ نّشْ، س مَارَّا جّهْذْ نّشْ، س مَارَّا ڒعْقڒْ نّشْ، ؤُشَا \add أَذْ ثخْسذْ\add* جَّارْ نّشْ أَمشْنَاوْ إِخفْ نّشْ.“ \x ◘ \xo 10:‏27 \xt لَاوِي 19‏:‏18؛ أَعَوذ. 6‏:‏5؛ 10‏:‏12؛ 30‏:‏6؛ مت. 22‏:‏37؛ مك. 12‏:‏30؛ رُوم. 13‏:‏9؛ ڭال. 5‏:‏14؛ يَاع. 2‏:‏8. \x*  
\v 28 إِنَّا أَسْ يَاسُوع: ”أَقَا ثَارِّيذْ نِيشَانْ. أڭّْ مَانْ أَيَا ؤُشَا أَذْ ثدَّارذْ.“  
\v 29 مَاشَا نتَّا إِخْسْ أَذْ إِسّڭّذْ إِخفْ نّسْ، إِنَّا أَسْ: ”مَانْ ونْ إِدْجَانْ ذ جَّارْ إِنُو؟“   
\m
\v 30 يَارَّا-د خَاسْ يَاسُوع، إِنَّا أَسْ: ”إِجّْ ن ورْيَازْ إِهْوَا-د زِي ؤُرْشَالِيمْ غَارْ أَرِيحَا ؤُشَا إِوْضَا ذڭْ إِفَاسّنْ ن إِشفَّارنْ، كّْسنْ أَسْ أَرُّوضْ، وْثِينْ ث س وعْمُوذْ، خنِّي رُوحنْ، جِّينْ ث جَارْ ڒْموْثْ ذ ثُوذَارْثْ.  
\v 31 خنِّي إِهْوَا-د إِجّْ ن ؤُكهَّانْ غَارْ وبْرِيذْ نِّي. نتَّا إِژْرَا إِ-ث، مَاشَا إِكَّا \add خَاسْ\add*.  
\v 32 أَمُّو عَاوذْ ؤُڒَا ذ إِجّْ ن ؤُلَاوِي إِعْذُو-د خْ ومْشَانْ نِّي، إِژْرَا إِ-ث، مَاشَا إِكَّا \add خَاسْ\add*.  
\v 33 مَاشَا إِجّْ ن ورْيَازْ أَسَامِيرِي، ثُوغَا-ث ذڭْ ؤُسَافَارْ، يِيوضْ-د غَارسْ، إِژْرَا إِ-ث ؤُشَا إِحِينّْ خَاسْ.  
\v 34 إِقَارّبْ-د غَارسْ، إِشدّْ أَسْ إِيزِّيمنْ نّسْ، إِسيّحْ خَاسنْ بِينُو ذ زّشْثْ. \add خنِّي\add* إِسّنْيَا إِ-ث خْ زَّايْڒثْ نّسْ، يِيوْيِي إِ-ث غَارْ ونْوَاڒْ، إِثْهلَّا ذَايسْ.  
\v 35 ثِيوشَّا نّسْ ڒَامِي إِرُوحْ، إِوْشَا ثْنَاينْ ذِينَارْ إِ بَابْ ن ونْوَاڒْ، إِنَّا أَسْ: ’ثْهِيلَّا ذَايسْ ؤُ مَاڒَا ثْخدْجْصذْ كْثَارْ زِي مَانْ أَيَا، أَذْ شكْ خدْجْصغْ خْمِي د غَاعقْبغْ.‘  
\v 36 مَانْ ونْ زِي ثْڒَاثَا نِّي ثتّْوَاڒِيذْ ذ جَّارْ ن ونِّي إِوْضَانْ ذڭْ \add إِفَاسّنْ ن\add* إِشفَّارنْ؟“  
\v 37 إِنَّا أَسْ: ”ونِّي خَاسْ إِحِينّنْ!“ إِنَّا أَسْ يَاسُوع: ”إِوَا ؤُيُورْ، ؤُڒَا ذ شكْ ثڭّذْ أَمنِّي!“   
\b  
\m  
\s1 يَاسُوع ذِي ثَادَّارْثْ ن مَارْيَامْ ذ مَارْثَا  
\m
\v 38 أَمْ ثُوغَا ڭُّورنْ نِيثْنِي، يُوذفْ غَارْ إِجّْ ن ذْشَارْ، ؤُشَا إِشْثْ ن ثمْغَارْثْ، قَّارنْ أَسْ مَارْثَا، ثَارحّبْ زَّايسْ ذِي ثَادَّارْثْ نّسْ.  
\v 39 ثُوغَا غَارْ ثَا إِشْثْ ن ؤُتْشْمَاسْ، قَّارنْ أَسْ مَارْيَامْ، ثنِّي ثُوغَا ثقِّيمْ غَارْ إِضَارنْ ن سِيذِيثْنغْ ؤُشَا ثُوغَا ثسّْحسَّا إِ وَاوَاڒْ نّسْ.  
\v 40 مَاشَا مَارْثَا ثُوغَا ثشْغڒْ أَطَّاسْ س ثْسخَّارْثْ. نتَّاثْ ثُوسَا-د \add غَارسْ\add*، ثنَّا أَسْ: ”\add أَ\add* سِيذِي، مَا وَارْ ذ أَشْ إِشْقِي بلِّي ؤُتْشْمَا ثجَّا أَيِي تّْسخَّارغْ وحّْذِي؟ إِنِي أَسْ حِيمَا أَذْ أَيِي ثْعَاونْ.“  
\v 41 مَاشَا يَاسُوع يَارَّا-د، إِنَّا أَسْ: ”مَارْثَا، مَارْثَا، شمْ ثْشغْڒذْ ؤُ ثْقدْجِيقذْ خْ وَاطَّاسْ ن ثْمسْڒَايِينْ،  
\v 42 مَاشَا إِتّْخصَّا إِشْثْ ن ڒْحَاجّثْ \add وَاهَا\add*! أَقَا مَارْيَامْ ثِيخْضَارْ ثَاسْغَارْثْ ثَاصبْحَانْثْ ثنِّي وَارْ زَّايسْ إِتّْوَاتّكّْسنْ.“   
\b  
\b  
\m  
\c 11
\s1 يَاسُوع إِسّڒْمَاذْ مَامّشْ إِشُووَّارْ أَذْ ژَتدْجنْ  
\m
\v 1 أَمْ ثُوغَا إِتّْژَادْجْ ذڭْ إِجّْ ن ومْشَانْ، إِمْسَارْ، ؤُمِي إِكمّڒْ نتَّا ثَاژَادْجِيثْ نّسْ، أَقَا إِجّنْ زڭْ إِمحْضَارنْ نّسْ إِنَّا أَسْ: ”\add أَ\add* سِيذِيثْنغْ، سڒْمذْ أَنغْ أَذْ نژَّادْجْ أَمْ مَامّشْ ثُوغَا يُوحَانَّا إِسّڒْمَاذْ عَاوذْ إِمحْضَارنْ نّسْ.“ \x ◘ \xo 11:‏1 \xt [مت. 6‏:‏9‏-‏15؛ 7‏:‏7‏-‏11]\x*  
\v 2 يَاسُوع إِنَّا أَسنْ: ”مڒْمِي مَا ثژُّودْجمْ، إِنِيمْ:  
\b  
\m ’\bdit بَابَاثْنغْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ\bdit*،  
\m \qt أَذْ إِتّْوَاقدّسْ إِسمْ نّشْ،\qt*  
\m \qt أَذْ د-ثَاسْ ثْڭلْذِيثْ نّشْ،\qt*  
\m \qt أَذْ ثتّْوَاڭّْ أَمْ مَامّشْ ثخْسذْ شكْ،\qt*  
\m \qt أَمْ ذڭْ ؤُجنَّا، \+tl أَمُّو\+tl* عَاوذْ ذِي ثمُّورْثْ.\qt*   
\m
\v 3 \qt أوْشْ أَنغْ كُوڒْ أَسّْ أَغْرُومْ نّغْ إِ كُوڒْ أَسّْ،\qt*   
\m
\v 4 \qt ؤُشَا غْفَارْ أَنغْ دّْنُوبْ نّغْ،\qt*  
\m \qt مِينْزِي ؤُڒَا ذ نشِّينْ نْسَامحْ إِ مَارَّا\qt*  
\m \qt إِنِّي ذَايْنغْ إِتُّورْسنْ.\qt*  
\m \qt وَارْ ذ أَنغْ سِّيذِيفْ شَا ذڭْ ؤُجَارّبْ،\qt*  
\m \qt مَاشَا سنْجمْ أَنغْ زڭْ ؤُمْعفَّانْ.‘ “\qt*   
\b  
\m
\v 5 خنِّي إِنَّا أَسنْ: ”مَانْ ونْ زَّايْومْ إِ غَارْ إِدْجَا إِجّْ ن ؤُمدُّوكّڒْ، أَذْ غَارسْ إِرَاحْ ذڭْ وزْينْ ن دْجِيڒثْ ؤُشَا أَذْ أَسْ إِنِي: ’\bd \+bdit أَ\+bdit* أَمدُّوكّڒْ، أَرْضڒْ أَيِي ثْڒَاثَا ن ثشْنِيفِينْ\bd*، \x ◘ \xo 11:‏5 \xt [مت. 7‏:‏7‏-‏11]\x*  
\v 6 مِينْزِي إِجّْ ن ؤُمدُّوكّڒْ إِنُو، إِخشّْ-د غَارِي زڭْ ؤُسَافَارْ، وَارْ غَارِي مِينْ ذ أَسْ غَا قدّْمغْ!‘،  
\v 7 ؤُشَا \add خنِّي\add* أَذْ خَاسْ د-يَارّْ ؤُمدُّوكّڒْ نّسْ زِي ذَاخڒْ، أَذْ أَسْ يِينِي: ’وَارْ د أَيِي تّْصدَّاعْ، ثَاوَّارْثْ ثْبلّعْ ؤُ ثَارْوَا أَقَا-ت أَكِيذِي ذِي ثَاسُّوثْ، وَارْ زمَّارغْ أَذْ د-كَّارغْ مَاحنْذْ أَذْ أَشْ وْشغْ \add أَغْرُومْ\add*.‘  
\v 8 أَذْ أَومْ إِنِيغْ، مَاڒَا وَارْ د-إِكَّارْ حِيمَا أَذْ أَسْ إِوْشْ ؤُمِي نتَّا ذ أَمدُّوكّڒْ نّسْ، إِوَا أَذْ د-إِكَّارْ أَذْ أَسْ إِوْشْ مشْحَاڒْ مَا إِحْذَاجْ خْ سِّيبّثْ ن ڒوْعَارثْ \add ن ؤُمدُّوكّڒْ\add* نّسْ.   
\m
\v 9 أَذْ أَومْ إِنِيغْ: \bd تَّارمْ، خنِّي أَذْ أَومْ إِمّوْشْ\bd*، أَرْزُومْ، خنِّي أَذْ ثَافمْ، سّْقَارْقْبمْ، خنِّي أَذْ أَومْ أَرزْمنْ. \x ◘ \xo 11:‏9 \xt مت. 7‏:‏7؛ 21‏:‏22؛ مك. 11‏:‏24؛ يُوح. 14‏:‏13؛ 15‏:‏7؛ 16‏:‏24؛ يَاع. 1‏:‏5، 6؛ 1 يُوح. 3‏:‏22؛ 5‏:‏14. \x*  
\v 10 مِينْزِي مَارَّا وِي غَا إِتَّارنْ أَذْ إِكْسِي، ؤُ وِي غَا يَارْزُونْ أَذْ يَافْ، ؤُ وِي غَا إِسّْقَارْقْبنْ أَذْ أَسْ إِتّْوَارْزمْ.  
\v 11 نِيغْ ذِينْ جَارْ أَومْ بَابَاسْ، ونِّي ؤُمِي ذ أَسْ إِ غَا إِتَّارْ مِّيسْ أَغْرُومْ، أَذْ أَسْ إِوْشْ أَژْرُو؟ نِيغْ ؤُمِي غَا إِتَّارْ أَسْڒمْ، أَذْ أَسْ إِوْشْ أَفِيغَارْ ذڭْ ومْشَانْ ن وسْڒمْ؟ \x ◘ \xo 11:‏11 \xt مت. 7‏:‏9. \x*  
\v 12 نِيغْ مَاڒَا إِتَّارْ زَّايسْ ثَامدْجَاتْشْ، أَذْ أَسْ إِوْشْ ثَاغَارْضنْثْ؟  
\v 13 مَاڒَا كنِّيوْ، إِنِّي إِدْجَانْ ذ إِعفَّاننْ، ثسّْنمْ أَذْ ثوْشمْ ثِيموْشَا ثِيصبْحَانِينْ إِ ثَارْوَا نْومْ، مشْحَاڒْ س وَاطَّاسْ أَذْ إِوْشْ بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ أَرُّوحْ إِقدّْسنْ إِ يِينِّي ذ أَسْ ث إِتَّارنْ!“   
\b  
\m  
\s1 يَاسُوع ذ بعَالْزَاپُوبْ  
\m
\v 14 ؤُمِي إِسُّوفّغْ نتَّا إِجّْ ن شِّيطَانْ أَڭْنَاوْ، إِمْسَارْ، أَوَارْنِي ڒَامِي إِسُّوفّغْ شِّيطَانْ نِّي، أَقَا أَڭْنَاوْ إِبْذَا إِسَّاوَاڒْ. \add ؤُشَا خنِّي\add* إِثبْهثْ ڒْغَاشِي \add مَارَّا\add*. \x ◘ \xo 11:‏14 \xt [مت. 12‏:‏22‏-‏30؛ مك. 3‏:‏20‏-‏27] — مت. 9‏:‏32؛ 12‏:‏22. \x*  
\v 15 مَاشَا شَا زَّايْسنْ نَّانْ: ”إِسُّوفُّوغْ شّْوَاطنْ س بعَالْزابُوبْ، أَمقّْرَانْ ن شّْوَاطنْ.“ \x ◘ \xo 11:‏15 \xt مت. 9‏:‏34؛ 12‏:‏24؛ مك. 3‏:‏22. \x*  
\v 16 إِنّغْنِي جَارّْبنْ ث، تَّارنْ زَّايسْ إِشْثْ ن ڒعْڒَامثْ زڭْ ؤُجنَّا.   
\m
\v 17 مَاشَا نتَّا يَارْڭبْ خْ إِخَارِّيصنْ نْسنْ، إِنَّا أَسنْ: ”كُوڒْ ثَاڭلْذِيثْ إِ إِبْضَانْ خْ يِيخفْ نّسْ أَذْ ثتّْوَاردّدْجْ ؤُ ثَادَّارْثْ إِ إِبْضَانْ خْ يِيخفْ نّسْ، أَذْ ثوْضَا. \x ◘ \xo 11:‏17 \xt مت. 12‏:‏25؛ مك. 3‏:‏24. \x*  
\v 18 مَاڒَا إِبْضَا شِّيطَانْ خْ يِيخفْ نّسْ، مَامّشْ غَا ثقِّيمْ ثْڭلْذِيثْ نّسْ؟ مِينْزِي كنِّيوْ ثقَّارمْ بلِّي نشّْ سُّوفُّوغغْ شّْوَاطنْ س بعَالْزابُوبْ.  
\v 19 مَاڒَا نشّْ سُّوفُّوغغْ شّْوَاطنْ س بعَالْزابُوبْ، س مِينْزِي إِ ثنْ سُّوفُّوغنْ ثَارْوَا نْومْ؟ س ؤُينِّي أَذْ إِڒِينْ نِيثْنِي ذ لْقُوضَاثْ خَاومْ.  
\v 20 مَاشَا مَاڒَا ثُوغَا س ؤُضَاضْ ن أَربِّي إِ زِي سُّوفُّوغغْ شّْوَاطنْ، خنِّي أَقَا ثْقَارّبْ-د غَارْومْ ثْڭلْذِيثْ ن أَربِّي.  
\v 21 مِينْ غَا يكّْ ورْيَازْ إِجهْذنْ إِحزّْمنْ س ڒسْنَاحْ إِتّْعسَّا خْ ڒمْرَاحْ نّسْ، أَذْ يِيڒِي وَاڭْڒَا نّسْ ذِي ڒَامَانْ.  
\v 22 مَاشَا مڒْمِي إِ د غَا يَاسْ ونِّي إِدْجَانْ ذ جِّيهڒْ خَاسْ، ؤُشَا أَذْ ث إِغْڒبْ، أَقَا نتَّا أَذْ أَسْ إِكّسْ ڒسْنَاحْ مِينْ خفْ ثُوغَا إِتّْشَاڒْ، ؤُشَا أَذْ إِبْضَا مِينْ ثُوغَا زَّايسْ إِكْسِي.   
\m
\v 23 ونِّي وَارْ إِدْجِينْ أَكِيذِي، أَقَا-ث ضِيدّْ إِنُو ؤُ ونِّي وَارْ كِيذِي إِسّْمُونِينْ، أَقَا نتَّا إِتّْزدْجَاعْ.“ \x ◘ \xo 11:‏23 \xt مت. 12‏:‏30؛ مك. 9‏:‏39؛ لك. 9‏:‏50؛ 11‏:‏23. \x*   
\b  
\m  
\s1 ڒَارْيَاحْ أَمنْڭُوسْ نِّي يَارزُّونْ أَذْ د-إِعْقبْ  
\m
\v 24 ”خْمِي غَا إِفّغْ ڒَارْيَاحْ أَمنْڭُوسْ زِي بْنَاذمْ، أَذْ إِشُوقْ ذڭْ إِمُوشَانْ وَارْ ذَايْسنْ بُو وَامَانْ، أَذْ يَارْزُو أَرَّاحثْ ؤُشَا خْمِي وَارْ ت إِتِّيفْ، أَذْ يِينِي: ’أَذْعقْبغْ غَارْ ثَادَّارْثْ إِنُو ثنِّي زِي د-فّْغغْ.‘ \x ◘ \xo 11:‏24 \xt [مت. 12‏:‏43‏-‏45] — مت. 12‏:‏43. \x*  
\v 25 خْمِي د غَا يَاسْ، أَذْ ت يَافْ، ثْفَارْضْ، ثعْذڒْ.  
\v 26 خنِّي أَذْ إِرَاحْ، أَذْ إِكْسِي سبْعَا ن ڒَارْيَاحْ نّغْنِي إِعفَّاننْ خَاسْ، أَذْ د-أَذْفنْ ؤُشَا أَذْ زذْغنْ ذِينِّي. خنِّي أَذْ إِذْوڒْ ؤُنڭَّارْ ن بْنَاذمْ نِّي ذ أَعفَّانْ مَاهُو خْ مَامّشْ ث ثُوغَا غَارْ ؤُمزْوَارْ.“ \x ◘ \xo 11:‏26 \xt يُوح. 5‏:‏14؛ عبر. 6‏:‏4، 5؛ 10‏:‏26؛ 2 بُط. 2‏:‏20. \x*   
\m
\v 27 أَمْ إِسَّاوَاڒْ س ؤُيَا، ثسّْڭعّذْ إِشْثْ ن ثمْغَارْثْ زِي ڒْغَاشِي ثْمِيجَّا نّسْ، ثنَّا أَسْ: ”سّعْذْ ن ؤُعذِّيسْ إِ شكْ إِكْسِينْ ؤُ ثَابُّوشْثْ إِ زِي ثطّْضذْ!“  
\v 28 نتَّا إِنَّا: ”سّعْذْ ن يِينِّي إِتّسْڒَانْ أَوَاڒْ ن أَربِّي ؤُشَا حفّْضنْ ث.“ \x ◘ \xo 11:‏28 \xt مت. 7‏:‏21؛ يُوح. 6‏:‏29؛ رُوم. 2‏:‏13. \x*   
\b  
\m  
\s1 ڒعْڒَامثْ ن يُونُوسْ  
\m
\v 29 أَمْ ثُوغَا إِمُونْ ڒْغَاشِي، إِبْذَا إِقَّارْ: ”تَّاصِيڒثْ-أَ ذ ثَاعفَّانْثْ ثتّتَّارْ ڒعْڒَامثْ، وَارْ ذ أَسْ ثتّْموْشِي ڒعْڒَامثْ مْغِيرْ ڒعْڒَامثْ ن يُونُوسْ أَنَابِي. \x ◘ \xo 11:‏29 \xt [مت. 12‏:‏38‏-‏42؛ مك. 8‏:‏12] — يُون. 2‏:‏1، 11. \x*  
\v 30 مِينْزِي أَمْ مَامّشْ ثُوغَا يُونُوسْ ذ ڒعْڒَامثْ إِ أَيْثْبَابْ ن نِينْوَا، أَمُّو إِ غَا يِيڒِي مِّيسْ ن بْنَاذمْ عَاوذْ \add ذ ڒعْڒَامثْ\add* إِ جِّيڒْ-أَ.  
\v 31 ثَاجدْجِيذْثْ ن لْجَانُوبْ أَذْ ثكَّارْ ذڭْ \add وَاسّْ ن\add* لْحِيسَابْ أَكْ-ذ يرْيَازنْ ن جِّيڒْ-أَ، أَذْ ثنْ ثْحَاسبْ. مِينْزِي ثُوسَا-د زِي ثْنڭَّارُوثْ ن ثمُّورْثْ، حِيمَا أَذْ ثْسڒْ إِ ثِيغِيثْ ن سُولِيمَانْ. خْزَارْ، أَقَا ذَا ونِّي إِمْغَارنْ خْ سُولِيمَانْ. \x ◘ \xo 11:‏31 \xt 1 إِج. 10‏:‏1؛ 2 إِم. 9‏:‏1؛ مت. 12‏:‏42. \x*  
\v 32 إِرْيَازنْ ن نِينْوَا أَذْ د-كَّارنْ ذڭْ \add وَاسّْ ن\add* لْحِيسَابْ أَكْ-ذ جِّيڒْ-أَ ؤُشَا أَذْ ث حَاسْبنْ، مِينْزِي نِيثْنِي ثُوبنْ أَوَارْنِي إِ ؤُبَارّحْ ن يُونُوسْ. خْزَارْ، أَقَا ذَا ونِّي إِمْغَارنْ خْ يُونُوسْ!“ \x ◘ \xo 11:‏32 \xt يُون. 3‏:‏5. \x*   
\b  
\m  
\s1 ڒْقنْذِيڒْ ن أَرِّيمثْ  
\m
\v 33 ؤُڒَا ذ إِجّْ وَارْ إِسّْرقِّي ڒْقنْذِيڒْ ؤُشَا إِسّْرُوسَا ث ذڭْ ومْشَانْ إِنُوفَّارنْ نِيغْ سَاذُو ڒْمُوذْ ن إِمنْذِي، مَاشَا \add إِسّْرُوسَا إِ-ث\add* خْ ڒْمرْفعْ، حِيمَا إِنِّي د غَا يَاذْفنْ أَذْ ژَترنْ ثْفَاوْثْ. \x ◘ \xo 11:‏33 \xt [مت. 5‏:‏15؛ 6‏:‏22‏-‏23] — مت. 5‏:‏15؛ مك. 4‏:‏24؛ لك. 8‏:‏16. \x*  
\v 34 ڒْقنْذِيڒْ ن أَرِّيمثْ نّشْ ذ ثِيطّْ نّشْ. مَاڒَا ثِيطّْ نّشْ ثصْفَا، أَذْ ثِيڒِي ثْفَاوْثْ ؤُڒَا ذِي مَارَّا أَرِّيمثْ نّشْ. مَاڒَا \add ثِيطّْ نّشْ\add* ذ ثَاعفَّانْثْ، ؤُڒَا ذ أَرِّيمثْ نّشْ أَذْ ثِيڒِي ذ ثَادْجسْثْ. \x ◘ \xo 11:‏34 \xt مت. 6‏:‏22. \x*  
\v 35 حْضَا خنِّي، حِيمَا ثَافَاوْثْ إِ ذَايكْ \add إِدْجَانْ\add*، وَارْ ثتِّيڒِي ذ ثَادْجسْثْ.  
\v 36 مَاڒَا مَارَّا أَرِّيمثْ نّشْ ثشُّورْ س ثْفَاوْثْ، وَارْ ذَايسْ ؤُڒَا ذ إِجّْ ن ؤُغزْذِيسْ إِبَارّْشنْ، خنِّي أَذْ ذَايسْ ثِيڒِي ثْفَاوْثْ كُوڒْشِي أَمْ مَامّشْ خْمِي يَارقّْ ڒْقنْذِيڒْ س ؤُشعَّاڒْ نّسْ.“   
\b  
\m  
\s1 ؤُشْثْ خْ إِفَارِيسِييّنْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ  
\m
\v 37 أَمْ ثُوغَا إِسَّاوَاڒْ س مَانْ أَيَا، إِعَارْضْ إِ-ث إِجّْ ن ؤُفَارِيسِي غَارْ ؤُمشْڒِي أَكِيذسْ. خنِّي يُوذفْ، إِقِّيمْ غَارْ طَّابْڒَا. \x ◘ \xo 11:‏37 \xt [مت. 23‏:‏1‏-‏36؛ مك. 12‏:‏38‏-‏40؛ لك. 20‏:‏45‏-‏47]\x*  
\v 38 ؤُمِي ث إِژْرَا ؤُفَارِيسِي، إِثبْهثْ مِينْزِي نتَّا وَارْ إِسِّيرْذْ شَا ذ أَمزْوَارْ قْبڒْ إِ ؤُمشْڒِي. \x ◘ \xo 11:‏38 \xt مك. 7‏:‏3، 4\x*   
\m
\v 39 مَاشَا يَاسُوع إِنَّا أَسْ: ”كنِّيوْ، \add أَ\add* إِفَارِيسِييّنْ، ثسِّيزْذَاڭمْ بَارَّا ن ڒْكَاسْ ذ طّبْصِي، مَاشَا ذِي ذَاخڒْ نْومْ ثْشُورّمْ س \add طّْمعْ ن\add* ثْكشَّاضْثْ ذ ڒْغَارْ. \x ◘ \xo 11:‏39 \xt مت. 23‏:‏25؛ ثِيث. 1‏:‏15. \x*  
\v 40 كنِّيوْ، \add أَ\add* إِفْغَاڒْ، مَا وَارْ إِدْجِي ونِّي إِڭِّينْ مِينْ إِدْجَانْ غَارْ بَارَّا، إِڭَّا ؤُڒَا ذ مِينْ إِدْجَانْ ذَاخڒْ؟  
\v 41 مَاشَا مَاڒَا أَذْ ثوْشمْ \add مَارَّا\add* مِينْ إِدْجَانْ ذَاخڒْ ذ صّذْقثْ، خْزَارْ، مَارَّا مِينْ ذَايْومْ أَذْ يِيڒِي ذ أَمزْذَاڭْ.“ \x ◘ \xo 11:‏41 \xt إِشا. 58‏:‏7؛ دَان. 4‏:‏24؛ لك. 12‏:‏33. \x*   
\m
\v 42 مَاشَا \bd ؤُشْثْ خَاومْ\bd*، \add أَ\add* إِفَارِيسِييّنْ مِينْزِي ثتّْعشَّارَامْ نّعْنَاعْ ذ وَازَارْ ذ مَارَّا ثِيبِّي، \add مَاشَا\add* ثجِّيمْ ڒْحُوكْمْ ذ ثَايْرِي ن أَربِّي غَارْ ؤُغزْذِيسْ. إِوَا إِتّْخصَّا أَومْ أَذْ ثڭّمْ ثِيمسْڒَايِينْ-أَ، نْهْڒَا مَا أَذْ ثتُّومْ إِنّغْنِي. \x ◘ \xo 11:‏42 \xt 1 صم. 15‏:‏22؛ حُوش. 6‏:‏6؛ مِيخَا 6‏:‏8؛ مت. 9‏:‏13؛ 12‏:‏7؛ 23‏:‏23. \x*   
\m
\v 43 \bd ؤُشْثْ خَاومْ\bd*، \add أَ\add* إِفَارِيسِييّنْ، مِينْزِي إِعْجبْ أَومْ أَذْ ثقِّيممْ خْ ڒكْرَاسِي ن زَّاثْ ذِي ثمْزِيذَاوِينْ ؤُ إِعْجبْ أَومْ أَذْ خَاومْ سدْجْمنْ \add إِوْذَانْ\add* ذِي ڒسْوَاقْ. \x ◘ \xo 11:‏43 \xt مت. 23‏:‏6؛ مك. 12‏:‏38؛ لك. 20‏:‏46. \x*   
\m
\v 44 \bd ؤُشْثْ خَاومْ\bd*، أَ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، \add كنِّيوْ، أَ\add* إِمْنَافْقنْ، مِينْزِي كنِّيوْ ثتّڭّمْ أَمْ يِيمضْڒَانْ إِدُّورْينْ مِينْ خفْ ڭُّورنْ إِوْذَانْ أَمْ وَارْ سِّيننْ.“ \x ◘ \xo 11:‏44 \xt مت. 23‏:‏27. \x*   
\m
\v 45 إِجّنْ زڭْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا أَسْ: ”\add أَ\add* أَمْسغَّارْ، أَقَا خْمِي ثقَّارذْ أَيَا، ثسّْفطَّاحذْ أَنغْ ؤُڒَا ذ نشِّينْ.“   
\m
\v 46 مَاشَا نتَّا إِنَّا: \bd ”ؤُشْثْ خَاومْ\bd*، \add أَ\add* إِمْسڒْمَاذنْ ن إِذْلِيسنْ، مِينْزِي ثسَّاربُّومْ ڒحْمُوڒْ إِضقْڒنْ إِ ثْكسِّيثْ خْ إِوْذَانْ، مَاشَا كنِّيوْ س يِيخفْ نْومْ وَارْ ثتّْحِيذِيمْ ڒحْمُوڒْ نِّي ؤُڒَا س إِجّنْ زڭْ إِضوْضَانْ نْومْ! \x ◘ \xo 11:‏46 \xt إِشا. 10‏:‏1؛ مت. 23‏:‏4؛ ڒخ. 15‏:‏10. \x*   
\m
\v 47 \bd ؤُشْثْ خَاومْ\bd*، مِينْزِي ثْبنَّامْ إِمضْڒَانْ ن إِنَابِييّنْ، أَمْ ڒجْذُوذْ نْومْ نْغِينْ ثنْ. \x ◘ \xo 11:‏47 \xt مت. 23‏:‏29. \x*  
\v 48 س مَانْ أَيَا ثْنعّْممْ، أَقَا كنِّيوْ ثَارطَّامْ س مِينْ ڭِّينْ ڒجْذُوذْ نْومْ، مِينْزِي نِيثْنِي نْغِينْ ثنْ ؤُشَا كنِّيوْ ثْبنَّامْ إِمضْڒَانْ نْسنْ.  
\v 49 س ؤُينِّي ثِيغِيثْ ن أَربِّي ثنَّا: ”أَقَا أَذْ أَسنْ د-سّكّغْ إِنَابِييّنْ ذ رُّوسُولْ. أَذْ أَژّْڒنْ نِيثْنِي خْ \add شَا\add* زَّايْسنْ ؤُشَا أَذْ ثنْ نْغنْ، \x ◘ \xo 11:‏49 \xt مت. 10‏:‏16؛ لك. 10‏:‏3؛ يُوح. 16‏:‏2؛ ڒخ. 7‏:‏51؛ عبر. 11‏:‏35. \x*  
\v 50 حِيمَا أَذْ تّْوَاتَّارنْ زِي جِّيڒْ-أَ إِذَامّنْ ن مَارَّا إِنَابِييّنْ إِ إِتّْوَاسِّيزّْڒنْ زڭْ وَامِي ثتّْوَاڭّْ دُّونشْثْ:  
\v 51 زڭْ إِذَامّنْ ن هَابِيلْ أَڒْ إِذَامّنْ ن زَاكَارِييَّا، ونِّي نْغِينْ جَارْ زَّاوشْثْ ثَامقّْرَانْثْ ذ ؤُعَالْطَارْ! وَاهْ، أَذْ أَومْ إِنِيغْ بلِّي ڭُّورْ أَذْ تّْوَاتَّارنْ \add إِذَامّنْ نْسنْ\add* زِي جِّيڒْ-أَ. \x ◘ \xo 11:‏51 \xt أَمز. 4‏:‏8؛ 2 إِم. 24‏:‏21؛ عبر. 11‏:‏4. \x*   
\m
\v 52 \bd ؤُشْثْ خَاومْ\bd*، \add أَ\add* إِمْسڒْمَاذنْ ن إِذْلِيسنْ، مِينْزِي ثْكسِّيمْ ثِيسَارُوثِينْ ن ثُوسّْنَا. كنِّيوْ س يِيخفْ نْومْ وَارْ ثتِّيذْفمْ ؤُ إِنِّي إِتَّاذْفنْ، ثطّْفمْ ثنْ.“ \x ◘ \xo 11:‏52 \xt مت. 23‏:‏13. \x*   
\m
\v 53 أَمْ ثُوغَا أَكِيذْسنْ إِسَّاوَاڒْ س ؤُيَا، بْذَانْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ تّْضَادَّانْ ث أَطَّاسْ. فُّوڭْمنْ، حشّنْ خْ وَاوَاڒنْ نّسْ،  
\v 54 ؤُشَا ڭِّينْ زَّايسْ س ثْحْرَايْمشْثْ أَطَّاسْ، أَرزُّونْ أَذْ ث طّْفنْ س شَا زڭْ ؤُقمُّومْ نّسْ، حِيمَا أَذْ ث ضڒْمنْ.   
\b  
\b  
\m  
\c 12
\s1 يَاسُوع إِسَّاوَاڒْ غَارْ إِمحْضَارنْ نّسْ ذ ڒْغَاشِي  
\m
\v 1 ؤُمِي مُوننْ إِبَارُّوثنْ ن ڒْغَاشِي س وَاطَّاسْ، أَڒَامِي بْذَانْ \add عْڒَاينْ\add*عفّْسنْ إِجّْ خْ ونّغْنِي، إِبْذَا إِقَّارْ إِ إِمحْضَارنْ نّسْ: ”\bd غَارْ ؤُمزْوَارْ حْضَامْ إِخفْ نْومْ زڭْ ونْثُونْ ن إِفَارِيسِييّنْ، أَقَا-ث ذ نِّيفَاقْ!\bd*\x ◘ \xo 12:‏1 \xt [مت. 10‏:‏28‏-‏33؛ 12‏:‏32؛ 10‏:‏19‏-‏20] — مت. 16‏:‏16؛ مك. 8‏:‏15. \x*  
\v 2 مِينْزِي وَارْ ذِينْ مِينْ إِذْڒِينْ، وَارْ إِتّتّْوَاسّضْهَارْ، ؤُ \add وَارْ ذِينْ\add* مِينْ إِنُوفَّارنْ، وَارْ إِتّتّْوِيسِّينْ. \x ◘ \xo 12:‏2 \xt أَيُوبْ 12‏:‏22؛ مت. 10‏:‏26؛ مك. 4‏:‏22؛ لك. 8‏:‏17. \x*  
\v 3 مِينْزِي مَارَّا مِينْ ثنَّامْ ذِي ثَادْجسْثْ، أَذْ إِتّْوَاسڒْ ذِي ثْفَاوْثْ، ؤُ مِينْ خفْ ثسِّيوْڒمْ ذڭْ ؤُمزُّوغْ ذڭْ وخَّامْ ن ذَاخڒْ، أَذْ إِتّْوَابَارّحْ زَّايسْ خْ ثْزغْوِينْ.“   
\b  
\m
\v 4 ”نشّْ أَذْ أَومْ إِنِيغْ، \add أَ\add* إِمدُّوكَّاڒْ إِنُو: \bd وَارْ ثڭّْوْذمْ شَا زڭْ إِنِّي إِنقّنْ أَرِّيمثْ\bd*، \add مَاشَا\add* أَوَارْنِي مَانْ أَيَا وَارْ زمَّارنْ أَذْ ڭّنْ كْثَارْ عَاذْ. \x ◘ \xo 12:‏4 \xt إِشا. 51‏:‏7؛ إِرْم. 1‏:‏8؛ مت. 10‏:‏28. \x*  
\v 5 مَاشَا نشّْ أَذْ أَومْ سّشْنغْ ونِّي زِي غَا ثڭّْوذمْ: ڭّْوذمْ زڭْ ونِّي غَارْ إِدْجَا صُّولْطَا، مَاحنْذْ أَذْ إِنْضَارْ ذِي جهنَّامَا أَوَارْنِي ڒَامِي إِنْغَا. وَاهْ، أَذْ أَومْ إِنِيغْ، زڭْ وَانِيثَا إِ غَا ثڭّْوذمْ!  
\v 6 مَا وَارْ تّْمنْزِينْ خمْسَا ن ژَّاوشْ س ثْنَاينْ ن إِصُولْذِييّنْ ن نّْحَاسْ؟ ؤُشَا ؤُڒَا ذ إِجّْ زَّايْسنْ وَارْ إِتّتّْوَاتُّو زَّاثْ إِ أَربِّي. \x ◘ \xo 12:‏6 \xt مت. 10‏:‏29. \x*  
\v 7 مَاشَا زَّايْومْ، عَاذْ إِژُوطَّانْ ن ؤُشُوَّافْ ن ؤُزدْجِيفْ نْومْ تّْوَاحسْبنْ. س ؤُينِّي وَارْ ثڭّْوْذمْ شَا، كنِّيوْ حْسنْ زِي ژَّاوشْ أَطَّاسْ!“ \f ◼ \fr 12:‏7 \ft \+bd ’ژَّاوشْ‘\+bd* - نِيغْ: ’إِژَّاوْجِيونْ‘.\f*  \x ◘ \xo 12:‏7 \xt 1 صم. 14‏:‏45؛ 2 صم. 14‏:‏11؛ 1 إِج. 1‏:‏52؛ لك. 21‏:‏18. \x*   
\m
\v 8 ”نشّْ أَذْ أَومْ إِنِيغْ، مَارَّا وِي زَّايِي إِ غَا إِشهْذنْ قِيبَاتْشْ إِ إِوْذَانْ، أَذْ زَّايسْ إِشْهذْ عَاوذْ مِّيسْ ن بْنَاذمْ زَّاثْ إِ لْمَالَاكَاثْ ن أَربِّي. \x ◘ \xo 12:‏8 \xt مت. 10‏:‏32. \x*  
\v 9 مَاشَا وِي ذ أَيِي غَا إِنْكَارنْ قِيبَاتْشْ إِ إِوْذَانْ، ؤُڒَا ذ نتَّا س يِيخفْ نّسْ أَذْ إِتّْوَانْكَارْ قِيبَاتْشْ إِ لْمَالَاكَاثْ ن أَربِّي. \x ◘ \xo 12:‏9 \xt مت. 10‏:‏33؛ مك. 8‏:‏38؛ لك. 9‏:‏26؛ 2 تِيم. 2‏:‏12؛ 1 يُوح. 2‏:‏23. \x*   
\m
\v 10 كُوڒْ إِجّْ ونِّي إِ غَا إِنِينْ أَوَاڒْ ضِيدّْ ن مِّيسْ ن بْنَاذمْ، أَقَا أَذْ أَسْ إِتّْوَاغْفَارْ مَانْ أَيَا. مَاشَا ونِّي إِ غَا إِشقّْفنْ ذِي أَرُّوحْ إِقدّْسنْ وَارْ ذ أَسْ إِتّتّْوَاغْفَارْ شَا مَانْ أَيَا!“ \x ◘ \xo 12:‏10 \xt 1 يُوح. 5‏:‏16. \x*   
\m
\v 11 ”خْمِي كنِّيوْ إِ غَا نذْهنْ غَارْ ثمْزِيذَاوِينْ، زَّاثْ إِ ڒْحُوكَّامْ ذ أَيْثْ ن بُو-صُّولْطَا، وَارْ كسِّيمْ شَا س ومْنُوسْ مِينْ زِي إِ د غَا ثَارّمْ نِيغْ مِينْ غَا ثِينِيمْ، \x ◘ \xo 12:‏11 \xt مت. 10‏:‏19؛ مك. 13‏:‏11؛ لك. 21‏:‏14. \x*  
\v 12 مِينْزِي أَرُّوحْ إِقدّْسنْ أَذْ أَومْ إِسّڒْمذْ ذِي ثْسَاعّثْ نِّي مِينْ إِتّْخصَّا أَذْ ثِينِيمْ.“   
\b  
\m  
\s1 أَمذْيَا ن بَابْ ن وَاڭْڒَا  
\m
\v 13 إِنَّا أَسْ إِجّنْ زِي ڒْغَاشِي: ”\add أَ\add* أَمْسغَّارْ، إِنِي أَسْ إِ ؤُمَا، حِيمَا أَذْ كِيذِي إِبْضَا ڒْوَارْثْ.“  
\v 14 \add مَاشَا\add* يَاسُوع إِنَّا أَسْ: ”\add أَ\add* بْنَاذمْ، وِي ذ أَيِي يَارِّينْ خَاومْ ذ ڒْقَاضِي نِيغْ ذ ڒْعَاذڒْ؟“  
\v 15 إِنَّا إِ إِمحْضَارنْ نّسْ: ”غَارْومْ، حْضَامْ إِخفْ نْومْ زِي طّْمعْ، مَاغَارْ ثُوذَارْثْ وَارْ ثدْجِي ذڭْ ؤُفيّضْ ن وَاڭْڒَا.“ \x ◘ \xo 12:‏15 \xt 1 تِيم. 6‏:‏7. \x*   
\m
\v 16 \add خَاسْ ؤُشَا\add* إِحَاجَا أَسنْ إِجّْ ن ؤُمذْيَا: ”ثَامُّورْثْ ن إِجّْ ن ورْيَازْ ذ بَابْ ن وَاڭْڒَا ثِيوْيِي أَسْ-د صَّابثْ أَطَّاسْ.  
\v 17 إِخَارّصْ ذڭْ إِخفْ نّسْ: ’مِينْ غَا ڭّغْ؟، مِينْزِي وَارْ غَارِي بُو ڒْمَارْسِي إِ ذِي إِ غَا يَارْوغْ \add مَارَّا\add* ڒْغِيدْجثْ إِنُو.‘  
\v 18 إِنَّا: ’أَمُّو إِ غَا ڭّغْ: أَذْ هذْمغْ ڒمْرَاسِي إِنُو، خنِّي أَذْ بْنِيغْ \add ڒمْرَاسِي\add* ذ إِمقّْرَاننْ خَاسنْ ؤُشَا أَذْ ذَايْسنْ خزْنغْ مَارَّا ڒْغِيدْجثْ ذ وَاڭْڒَا إِنُو.  
\v 19 أَذْ إِنِيغْ إِ يِيخفْ إِنُو: ’\add أَ\add* ڒعْمَارْ \add إِنُو\add*، غَاركْ أَطَّاسْ ن وَاڭْڒَا إِ إِتّْوَاخْزنْ ذِينْ إِ وَاطَّاسْ ن إِسڭّْوُوسَا. أَريّحْ، ثشّذْ، ثسْوذْ ؤُ ثْفَارْحذْ!‘ \x ◘ \xo 12:‏19 \xt أَمب. 11‏:‏9؛ 1 كُور. 15‏:‏32؛ يَاع. 5‏:‏5. \x*  
\v 20 مَاشَا إِنَّا أَسْ أَربِّي: ’\add أَ\add* أَفْغُوڒْ، أَقَا دْجِيڒثْ-أَ أَذْ زَّايكْ إِتّْوَاتَّارْ ڒعْمَارْ نّشْ. خنِّي إِ ؤُمِي غَا يِيڒِي مِينْ ثسّْوجْذذْ؟‘ \x ◘ \xo 12:‏20 \xt إِزهد. 39‏:‏7؛ إِزهد. 52‏:‏7؛ أَمب. 2‏:‏18، 19؛ إِرْم. 17‏:‏11. \x*  
\v 21 أَمُّو إِ غَا إِمْسَارْ إِ ونِّي إِيَارّْونْ ڒكْنُوزْ إِ يِيخفْ نّسْ، \add مَاشَا\add* وَارْ إِدْجِي ذ بَابْ ن وَاڭْڒَا ذِي أَربِّي.“   
\b  
\m  
\s1 ثَاڭلْذِيثْ ن أَربِّي ذ أَمزْوَارُو  
\m
\v 22 إِنَّا إِ إِمحْضَارنْ نّسْ: ”س ؤُينِّي نشّْ أَذْ أَومْ إِنِيغْ: وَارْ كسِّيمْ س ومْنُوسْ إِ ڒعْمَارْ نْومْ مِينْ غَا ثشّمْ، ؤُڒَا إِ أَرِّيمثْ نْومْ مِينْ غَا ثْيَارْضمْ. \x ◘ \xo 12:‏22 \xt [مت. 6‏:‏19‏-‏21، 25‏-‏34] — إِزهد. 55‏:‏23؛ مت. 6‏:‏25؛ فِيل. 4‏:‏6؛ 1 تِيم. 6‏:‏8؛ 1 بُط. 5‏:‏7. \x*  
\v 23 ڒعْمَارْ كْثَارْ زِي مَاشَّا ؤُ أَرِّيمثْ كْثَارْ زڭْ ورُّوضْ.  
\v 24 خْزَارمْ غَارْ إِبَاغْڒِيونْ! أَقَا وَارْ زَارّْعنْ، وَارْ مجَّارنْ، وَارْ غَارْسنْ ثِيسْرَافِينْ نِيغْ ذ ڒمْرَاسِي، \add مَاشَا\add* أَربِّي إِسّشَّا إِ-ثنْ. مشْحَاڒْ أَطَّاسْ ثْسكّْوِيمْ كنِّيوْ كْثَارْ خْ إِجْضَاضْ! \x ◘ \xo 12:‏24 \xt أَيُوبْ 38‏:‏41؛ إِزهد. 147‏:‏9. \x*  
\v 25 مَانْ ونْ زَّايْومْ إِزمَّارْ س ومْنُوسْ نّسْ أَذْ يَارْنِي ذِي ثُوزّڭَّارْثْ نّسْ إِجّْ ن ؤُغِيڒْ \add وَاهَا\add*؟ \x ◘ \xo 12:‏25 \xt مت. 6‏:‏27. \x*  
\v 26 مَاڒَا كنِّيوْ وَارْ ثْزمَّارمْ ؤُڒَا خْ مِينْ إِدْجَانْ ذ أَمژْيَانْ قَاعْ، مَايمِّي غَا ثكْسِيمْ س ومْنُوسْ خْ مِينْ إِقِّيمنْ؟“   
\b  
\m
\v 27 ”خْزَارمْ مَامّشْغمّْينْثْ ثْلِيلِّيشِينْ! وَارْ خدّْمنْثْ، وَارْ تّْقَارضْشنْثْ، \add مَاشَا\add* نشّْ أَذْ أَومْ إِنِيغْ، أَقَا ؤُڒَا ذ سُولِيمَانْ ذِي قَاعْ أَعُودْجِي نّسْ وَارْ يَارْضْ شَا أَمْ ؤُڒَا ذ إِشْثْ زَّايْسنْثْ. \f ◼ \fr 12:‏27 \ft \+bd ’ثِيلِيلِّيشِينْ‘\+bd* - إِجّْ ن مَارْكَا ن نُّووَارَاثْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*  
\v 28 مَاڒَا أَربِّي إِسّْيَارْضْ أَمُّو أَرْبِيعْ إِ إِدْجَانْ أَسّْ-أَ ذڭْ إِيَّارْ ؤُشَا ثِيوشَّا أَذْ إِمّنْضَارْ ذِي ثفْقُونْثْ، مشْحَاڒْ إِحْڒَا أَطَّاسْ أَذْ إِسّْيَارْضْ نتَّا كنِّيوْ إِ ذِي إِدْجَا ذْرُوسْ ن لْ-إِيمَانْ!“   
\b  
\m
\v 29 ”س ؤُينِّي وَارْ أَرزُّومْ شَا خْ مِينْ غَا ثشّمْ ؤُڒَا خْ مِينْ غَا ثسْومْ، وَارْ تّجِّيمْ إِخَارِّيصنْ نْومْ أَذْغفْڒمْ خْ مَانْ أَيَا.  
\v 30 مِينْزِي مَارَّا ثِيمسْڒَايِينْ-أَ أَرزُّونْ ذَايْسنْثْ ڒڭْنُوسْ ن دُّونشْثْ، مَاشَا بَابَاثْومْ إِسّنْ بلِّي ثحْذَاجمْ ثنْثْ.  
\v 31 مَاشَا أَرْزُومْ ثَاڭلْذِيثْ ن أَربِّي ؤُشَا ثِيمسْڒَايِينْ-أَ مَارَّا أَذْ أَومْ تّْوَامَّارْنِينْثْ.“ \x ◘ \xo 12:‏31 \xt 1 إِم. 3‏:‏13؛ إِزهد. 37‏:‏25. \x*   
\b  
\m
\v 32 ”وَارْ تّڭّْوذْ، \add شمْ،\add* \add أَ\add* ثَاحِيمَارْثْ ثَامژْيَانْثْ، مِينْزِي يَارْضَا بَابَاثْومْ أَذْ أَومْ إِوْشْ ثَاڭلْذِيثْ.  
\v 33 زنْزمْ مِينْ غَارْومْ، وْشمْ صّذْقثْ! ڭّمْ إِ يِيخفْ نْومْ ثِيشْيَارِينْ ن ثْمنْيَاثْ إِ وَارْ يَارشِّينْ، ؤُشَا \add خمّْڒمْ\add* إِجّْ ن ڒْكنْزْ إِ وَارْ إِقطِّينْ ذڭْ إِجنْوَانْ، مَانِي وَارْ إِتِّيذفْ ؤُشفَّارْ ؤُڒَا ذ ثْشِينْذَا وَارْ ثتّڭّْ سُّوسّْ. \x ◘ \xo 12:‏33 \xt مت. 6‏:‏20؛ 19‏:‏21؛ لك. 16‏:‏9؛ 1 تِيم. 6‏:‏19. \x*  
\v 34 مِينْزِي مَانِي غَا يِيڒِي ڒْكنْزْ نْومْ، ذِينِّي إِ غَا يِيڒِي عَاوذْ وُوڒْ نْومْ.“   
\b  
\m  
\s1 أَعْقَابْ ن بَابْ ن ثَادَّارْثْ  
\m
\v 35 ”أَذْ إِڒِينْثْ ثجْعِينَّاثِينْ نْومْ حزّْممْثْ س إِبُويَاسْ ؤُ ڒفْنَارَاثْ نْومْ أَرقّنْثْ. \x ◘ \xo 12:‏35 \xt [مت. 24‏:‏45‏-‏51] — أَفا. 6‏:‏14؛ 1 بُط. 1‏:‏13. \x*  
\v 36 إِڒِيمْ أَمْ إِوْذَانْ إِ إِتّْرَاجَانْ سِيذِي نْسنْ خْمِي د غَا يعْقبْ زڭْ وخَّامْ ن وُورَارْ، حِيمَا، خْمِي د غَا يَاسْ، أَذْ إِسّْقَارْقبْ، زمَّارنْ أَذْ أَسْ أَرْزْمنْ ذغْيَا.  
\v 37 سّعْذْ ن إِمْسخَّارنْ نِّي، خْمِي د غَا يَاسْ سِيذِيثْسنْ، أَذْ ثنْ يَافْ فَاقنْ. س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، أَقَا أَذْ إِحزّمْ إِخفْ نّسْ ؤُشَا أَذْ ثنْ إِسّْغِيمْ، خنِّي أَذْ د-يَاسْ أَذْ خَاسنْ إِسخَّارْ.  
\v 38 مَاڒَا يُوسَا-د غَارْ حطُّو وِيسّْ ثْنَاينْ ن دْجِيڒثْ نِيغْ غَارْ حطُّو وِيسّْ ثْڒَاثَا ؤُشَا يُوفَا إِ-ثنْ أَمُّو، سّعْذْ ن إِمْسخَّارنْ نِّي. \x ◘ \xo 12:‏38 \xt مت. 24‏:‏42. \x*  
\v 39 مَاشَا سّْنمْ أَيَا: مَاڒَا بَابْ ن ثَادَّارْثْ إِسّنْ ذِي مَانْ ثْسَاعّثْ إِ ذِي غَا إِخشّْ ؤُشفَّارْ، خنِّي أَذْ يِيڒِي إِفَاقْ، وَارْ إِتّجِّي ثَادَّارْثْ نّسْ أَذْ ت أَشَارنْ. \x ◘ \xo 12:‏39 \xt مت. 24‏:‏43؛ 1 تس. 5‏:‏2؛ 2 بُط. 3‏:‏10؛ أَسَا. 3‏:‏3؛ 16‏:‏15. \x*  
\v 40 إِڒِيمْ كنِّيوْ عَاوذْ ثْوجْذمْ، مِينْزِي مِّيسْ ن بْنَاذمْ أَذْ د-يَاسْ ذڭْ إِشْثْ ن ثْسَاعّثْ إِ وَارْ ثتّْرِيجِيمْ.“ \x ◘ \xo 12:‏40 \xt مت. 24‏:‏44؛ 25‏:‏13؛ مك. 13‏:‏33؛ لك. 21‏:‏34؛ 1 تس. 5‏:‏6. \x*   
\b  
\m  
\s1 أَمذْيَا ن ووْكِيڒْ أَمْثِيقِّي  
\m
\v 41 إِنَّا أَسْ شِيمْعُونْ بُوطْرُوسْ: ”\add أَ\add* سِيذِيثْنغْ، مَا إِ نشِّينْ إِ ثْعَاوْذذْ أَمذْيَا-يَا نِيغْ إِ مَارَّا؟“  
\v 42 إِنَّا أَسْ يَاسُوع: ”مَانْ ونْ إِدْجَانْ خنِّي ذ أَوْكِيڒْ أَمِيغِيسْ إِ ذِي إِدْجَا ڒَامَانْ، ذ ونِّي إِ غَا يڭّْ سِيذِيسْ خْ إِمْسخَّارنْ نّسْ حِيمَا أَذْ \add أَسنْ\add* إِوْشْ ڒعْوتْشْ \add نْسنْ\add* ذِي ڒْوقْثْ نّسْ؟ \x ◘ \xo 12:‏42 \xt مت. 24‏:‏45؛ 25‏:‏21؛ 1 كُور. 4‏:‏2. \x*  
\v 43 سّعْذْ ن ؤُمْسخَّارْ نِّي إِ غَا يَافْ سِيذِي نّسْ، خْمِي د غَا يَاسْ، إِتّڭّْ أَمُّو.  
\v 44 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، بلِّي أَذْ ث يڭّْ خْ مَارَّا أَڭْڒَا نّسْ.  
\v 45 مَاشَا مَاڒَا أَمْسخَّارْ نِّي أَذْ يِينِي ذڭْ وُوڒْ نّسْ: ’أَقَا سِيذِي إِنُو إِعطَّاڒْ خْ وعْقَابْ!‘، ؤُشَا إِبْذَا إِشَّاثْ إِمْسخَّارنْ ذ ثِييَّا، إِتّتّْ، إِسسّْ، إِسْشَارْ،  
\v 46 خنِّي أَذْ د-يَاسْ سِيذِي ن ؤُمْسخَّارْ نِّي ذڭْ إِجّْ ن وَاسّْ وَارْ إِتّْرِيجِي ؤُ ذڭْ إِشْثْ ن ثْسَاعّثْ إِ وَارْ إِسِّينْ. وَانِيثَا أَذْ ث إِقطّسْ ذ إِشدْجِيقنْ، أَذْ إِڭّْ ثَاسْغَارْثْ نّسْ أَكْ-ذ إِغدَّارنْ.  
\v 47 أَمْسخَّارْ نِّي إِسّْننْ ڒْخَاضَارْ ن سِيذِي نّسْ ؤُشَا وَارْ إِسّوْجذْ إِخفْ نّسْ ؤُڒَا وَارْ إِڭِّي عْلَاحْسَابْ ڒْخَاضَارْ ن سِيذسْ، أَذْ إِكْسِي ثِييِّيثَا أَطَّاسْ. \x ◘ \xo 12:‏47 \xt يَاع. 4‏:‏17. \x*  
\v 48 مَاشَا ونِّي وَارْ إِسِّيننْ \add ڒْْخَاضَارْ ن سِيذسْ\add* \add أَمْ\add* إِڭَّا شَا مِينْ إِسْذَاهدْجنْ ثِييِّيثَا، أَذْ إِتّْوَاوّثْ س ذْرُوسْ ن ثِييِّيثَا. زِي كُوڒْ إِجّنْ ؤُمِي إِمّوْشْ أَطَّاسْ، أَذْ زَّايسْ إِتّْوَاتَّارْ أَطَّاسْ، ؤُ وِي ؤُمِي إِتّْوَاكلّفْ أَطَّاسْ، أَذْ زَّايسْ إِتّْوَاتَّارْ كْثَارْ.“   
\b  
\m  
\s1 ثَاوَاسِيثْ ن يَاسُوع أَذْ ثَاوِي أَبطُّو  
\m
\v 49 ”ؤُسِيغْ-د حِيمَا أَذْ نْضَارغْ ثِيمسِّي خْ ثمُّورْثْ ؤُ معْلِيكْ ؤُفِيغْ أَذْ ثِيڒِي ثَارْغَا. \x ◘ \xo 12:‏49 \xt [مت. 10‏:‏34‏-‏36] \x*  
\v 50 \add مَاشَا\add* غَارِي إِجّْ ن ؤُسغْضصْ إِ زِي غَا تّْوَاسّْغضْصغْ، ؤُ تّْوَاحْصَارغْ أَطَّاسْ أَڒْ ذ غَا إِتّْوَاكمّڒْ. \x ◘ \xo 12:‏50 \xt مت. 20‏:‏22؛ مك. 10‏:‏38. \x*  
\v 51 مَا إِتّْغِيڒْ أَومْ بلِّي ؤُسِيغْ-د حِيمَا أَذْ سِّيوْضغْ ڒهْنَا خْ ثمُّورْثْ؟ لَّ، أَذْ أَومْ إِنِيغْ، ذ أَمزْوَارْ أَبطُّو. \x ◘ \xo 12:‏51 \xt مت. 10‏:‏34. \x*  
\v 52 مِينْزِي زِي ڒخُّو ذ ثْسَاونْثْ أَذْ مّْسبْضَانْ خمْسَا ذڭْ إِشْثْ ن ثَادَّارْثْ، ثْڒَاثَا ضِيدّْ ثْنَاينْ ؤُ ثْنَاينْ ضِيدّْ ثْڒَاثَا.  
\v 53 بَابَاسْ أَذْ إِمّْسبْضَا خْ مِّيسْ، ؤُ مِّيسْ خْ بَابَاسْ، ؤُ يمَّاسْ خْ يدْجِيسْ، ؤُ يدْجِيسْ خْ يمَّاسْ، ؤُ ڒَالَّاسْ خْ ثسْڒِيثْ، ؤُ ثَاسْڒِيثْ خْ ڒَالَّاسْ.“ \x ◘ \xo 12:‏53 \xt مِيخَا 7‏:‏6\x*   
\b  
\m  
\s1 إِتّْخصَّا أَذْ نْميّزْ زّْمَانَاثْ  
\m
\v 54 إِنَّا إِ ڒْغَاشِي: ”خْمِي غَا ثْژَارمْ إِجّْ ن ؤُسيْنُو إِڭعّذْ-د زِي ڒْغَارْبْ، ذغْيَا أَذْ ثِينِيمْ: ’أَذْ يِيڒِي ونْژَارْ!‘ ؤُشَا أَمُّو إِ غَا إِمْسَارْ! \x ◘ \xo 12:‏54 \xt [مت. 16‏:‏2‏-‏3]\x*  
\v 55 خْمِي غَا ثْژَارمْ أَسمِّيضْ ن لْجَانُوبْ إِتّْسُوضْ، خنِّي أَذْ ثِينِيمْ: ’أَذْ يِيڒِي ڒحْمُو!‘، ؤُشَا \add أَمُّو\add* إِ غَا إِمْسَارْ.  
\v 56 \add أَ\add* إِمْنَافْقنْ، أَقَا ثسّْنمْ أَذْ ثْميّْزمْ ؤُذمْ ن ثمُّورْثْ ذ ؤُجنَّا. مَا زّْمَانْ-أَ مَامّشْ وَارْ ثْزمَّارنْ أَذْ ث ثْميّْزمْ؟“   
\b  
\m  
\s1 ڭّمْ أَصْڒَاحْ أَكْ-ذ وغْرِيمْ نّكْ  
\m
\v 57 ”مَايمِّي وَارْ ثْحكّْممْ س يِيخفْ نْومْ مِينْ إِدْجَانْ ذ صَّاحْ؟ \x ◘ \xo 12:‏57 \xt [مت. 5‏:‏25‏-‏26]\x*  
\v 58 مِينْزِي، خْمِي غَا ثْرَاحذْ غَارْ ڒْحَاكمْ أَكْ-ذ وغْرِيمْ نّشْ، أڭّْ ثِيزمَّارْ أَمْ ثدْجِيذْ عَاذْ \add أَكِيسْ\add* ذڭْ وبْرِيذْ مَاحنْذْ أَذْ زَّايسْ ثتّْوَافكّذْ، حِيمَا وَارْ شكْ إِتّْجَارِّي غَارْ ڒْقَاضِي ؤُشَا ڒْقَاضِي أَذْ شكْ إِسلّمْ إِ ومْخَازْنِي، خنِّي أَذْ شكْ إِنْضَارْ ؤُمْخَازْنِي ذِي ڒحْبسْ.  
\v 59 أَذْ أَشْ إِنِيغْ، شكْ وَارْ د سّنِّي ثتّفّْغذْ أَڒْ غَا ثْخدْجْصذْ أَصُولْذِي أَنڭَّارُو!“   
\b  
\b  
\m  
\c 13
\s1 أَمذْيَا ن وَارْثُو إِ وَارْ إِتِّيشّنْ ڒْغِيدْجثْ  
\m
\v 1 ذِي ڒْوقْثْ نِّي ؤُسِينْ-د \add غَارسْ\add* شَا ن إِوْذَانْ، خبَّارنْ ث خْ إِجَالِيلِييّنْ إِنِّي إِخدْجضْ بِيلَاطُوسْ إِذَامّنْ نْسنْ أَكْ-ذ ثْغَارْصِينْ نْسنْ.  
\v 2 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”مَا إِتّْغِيڒْ أَومْ بلِّي إِجَالِيلِييّنْ-أَ ذ إِمذْنَابْ كْثَارْ زڭْ إِجَالِيلِييّنْ نّغْنِي ؤُمِي ذ أَسنْ إِمْسَارْ ؤُودّبْ-أَ؟  
\v 3 أَذْ أَومْ إِنِيغْ، لَّا! مَاشَا كنِّيوْ أَذْ ثتّْوَاهلّْكمْ مَارَّا أَمْ نِيثْنِي، مَاڒَا وَارْ ثتُّوبمْ.  
\v 4 ؤُ زِي جِّيهثْ ن ثْمنْطَاشْ \add ن إِوْذَانْ\add* إِ خفْ د-ثوْضَا صُّومْعثْ ذِي سِيلُووَامْ ؤُشَا مُّوثنْ زَّايسْ، مَا إِتّْغِيڒْ أَومْ أَقَا أَثنْ ذ إِمذْنَابْ كْثَارْ زڭْ إِوْذَانْ \add نّغْنِي\add* إِ إِزدّْغنْ ذِي ؤُرْشَالِيمْ؟  
\v 5 أَذْ أَومْ إِنِيغْ، لَّا! مَاشَا كنِّيوْ أَذْ ثتّْوَاهلّْكمْ مَارَّا أَمْ نِيثْنِي، مَاڒَا وَارْ ثتُّوبمْ!“   
\b  
\m
\v 6 إِنَّا أَسنْ أَمذْيَا-يَا: ”ثُوغَا غَارْ إِجّْ ن ورْيَازْ إِجّْ ن وَارْثُو إِ إِتّْوَاژُّونْ ذڭْ ؤُمَارْجعْ نّسْ ن ؤُضِيڒْ، ؤُشَا نتَّا يُوسَا-د، يَارزُّو ذَايسْ ثَازَارْثْ، \add مَاشَا\add* وَارْ ت يُوفِي.  
\v 7 إِنَّا إِ بَابْ ن ؤُمَارْجعْ ن ؤُضِيڒْ: ’أَقَا ثْڒَاثَا ن إِسڭّْوُوسَا تَّاسغْ-د، أَرزُّوغْ ثَازَارْثْ ذڭْ وَارْثُو-يَا، وَارْ ت ؤُفِيغْ. قسّْ إِ-ت \add خنِّي\add*، مَايمِّي ثسَّاحَاڒْ عَاذْ ثَامُّورْثْ؟‘  
\v 8 يَارَّا-د خَاسْ ؤُفدْجَاحْ: ’أَ سِيذِي، أجّْ إِ-ت \add أَذْ ثْبدّْ\add* عَاذْ أَسڭّْوَاسْ-أَ. أَذْ ت غْزِيغْ، ؤُ أَذْ أَسْ ڭّغْ ڒغْبَارْ.  
\v 9 أَذْ ثَاغْ أَذْ ثَارّْ ڒْغِيدْجثْ، مَاڒَا لَّا، خنِّي قسّْ إِ-ت ذڭْ ؤُسڭّْوَاسْ إِ د غَا يَاسنْ.‘ “   
\b  
\m  
\s1 أَسْڭنْفِي ن إِشْثْ ن ثمْغَارْثْ ذڭْ وَاسّْ ن سّبْثْ  
\m
\v 10 ڒَامِي ثُوغَا إِسّڒْمَاذْ يَاسُوع ذڭْ إِشْثنْ زِي ثمْزِيذَاوِينْ ذِي سّبْثْ،  
\v 11 ثُوغَا ذِينْ إِشْثْ ن ثمْغَارْثْ إِ إِضْعفْ بُوحْبڒْ نّسْ ڒْمِيجَاڒْ ن ثْمنْطَاشْ ن إِسڭّْوُوسَا. ثُوغَا ثقْوسْ، وَارْ ثْزمَّارْ أَذْ ثْسڭّمْ أَعْرُورْ.  
\v 12 ؤُمِي ت إِژْرَا يَاسُوع، إِڒَاغَا-د خَاسْ غَارسْ، إِنَّا أَسْ: ”\add أَ\add* ثَامْغَارْثْ، أَقَا شمْ ثنْفكّذْ زِي ثُوضْعفْثْ نّمْ!“  
\v 13 إِسَّارْسْ خَاسْ أَفُوسْ نّسْ ؤُشَا نتَّاثْ ثذْوڒْ ثْسڭّمْ ڒخْذنِّي، ثبْذَا ثسّمْغَارَا ذِي أَربِّي!  
\v 14 مَاشَا أَمقّْرَانْ ن ثمْزِيذَا، ؤُمِي إِخيّقْ، مِينْزِي يَاسُوع إِسّْڭنْفَا \add إِجّنْ\add* ذِي سّبْثْ، إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا إِ ڒْغَاشِي: ”أَقَا ذِي ستَّا ن وُوسَّانْ إِتّْخصَّا ڒْخذْمثْ، أَسمْ-د ذڭْ وُوسَّانْ نِّي مَاحنْذْ أَذْ ثتّْوَاسّْڭنْفَامْ، وَارْ إِدْجِي ذڭْ وَاسّْ ن سّبْثْ!“ \x ◘ \xo 13:‏14 \xt ؤُف. 20‏:‏9؛ أَعَوذ. 5‏:‏13؛ حِز. 20‏:‏12. \x*  
\v 15 \add مَاشَا\add* يَارَّا-د يَاسُوع، إِنَّا أَسْ: ”\add أَ شكْ،\add* أَمْنَافقْ! مَا وَارْ إِفسِّي كُوڒْ إِجّنْ زَّايْومْ ذِي سّبْثْ إِ ؤُفُونَاسْ نّسْ نِيغْ إِ وغْيُوڒْ نّسْ زِي ڒْمذْوذْ، خنِّي أَذْ ث إِنْذهْ مَاحنْذْ أَذْ ث إِوَارْذْ؟ \x ◘ \xo 13:‏15 \xt ؤُف. 23‏:‏5؛ أَعَوذ. 22‏:‏4؛ لك. 14‏:‏5. \x*  
\v 16 مَاشَا ثَامْغَارْثْ-أَ أَقَا-ت ذ يدْجِيسْ ن إِبْرَاهِيمْ، ثنِّي إِشدّْ إِبْڒِيسْ، خْزَارْ، \add عَاذْ\add* ڒْمِيجَاڒْ ن ثْمنْطَاشْ ن إِسڭّْوُوسَا، مَا وَارْ ذ أَسْ د-يُوسِي أَذْ ثتّْوَافكّْ زڭْ ؤُشذِّي-يَا ذڭْ وَاسّْ ن سّبْثْ؟“  
\v 17 أَمْ إِنَّا مَانْ أَيَا، سضْحَانْ مَارَّا إِنِّي ثُوغَا أَكِيذسْ إِتّمْعَاڒَانْ، \add مَاشَا\add* مَارَّا ڒْغَاشِي إِفَارْحْ زِي لْمُوعْجِيزَاثْ نِّي ثُوغَا إِتّْوَاڭّنْ س ؤُفُوسْ نّسْ.   
\b  
\m  
\s1 إِمذْيَا ن ثْحبُّوشْثْ ن زَّارِيعثْ ن ؤُخرْذلْ ؤُ ن ونْثُونْ  
\m
\v 18 يَاسُوع إِنَّا: ”مِينْ ذِي ثَارْوسْ ثْڭلْذِيثْ ن أَربِّي ؤُشَا مِينْ زِي ت غَا سّمْقُودّغْ؟ \x ◘ \xo 13:‏18 \xt [مت. 13‏:‏31‏-‏33؛ مك. 4‏:‏30‏-‏32] — مت. 13‏:‏31؛ مك. 4‏:‏30. \x*  
\v 19 أَقَا-ت أَمْ يِيشْثْ ن ثْحبُّوشْثْ ن زَّارِيعثْ ن ؤُخرْذلْ إِكْسِي ت إِجّْ ن ورْيَازْ، إِنْضَارْ إِ-ت ذِي ثحْوِيشْثْ نّسْ، ؤُشَا ثغْمِي-د، ثذْوڒْ ذ ثَاشجَّارْثْ ثمْغَارْ ؤُشَا ڭِّينْ إِجْضَاضْ ن ؤُجنَّا ڒعْوَاشّْ نْسنْ ذِي ڒفْرُوعْ نّسْ.“ \f ◼ \fr 13:‏19 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘). \+bd ’أَخرْذلْ‘\+bd* - س ثَافْرَانْسِيسْثْ: ’مُوثَارْذِي‘.\f*   
\m
\v 20 يَاسُوع إِنَّا عَاوذْ: ”س مِينْ زِي غَا سّمْقُودّغْ ثَاڭلْذِيثْ ن أَربِّي؟ \x ◘ \xo 13:‏20 \xt مت. 13‏:‏33. \x*  
\v 21 أَقَا-ت أَمْ ونْثُونْ، ثيْسِي ث ثمْغَارْثْ، ثفَّارْ إِ-ث ذِي ثْڒَاثَا ن ڒمْذُوذْ ن وَارنْ، أَڒَامِي إِسّْممّْ مَارَّا!“   
\b  
\m  
\s1 ثَاوَّارْثْ إِحْسَارنْ  
\m
\v 22 إِژْوَا ثِيندَّامْ ذ ذْشُورَاثْ، أَمْ ثُوغَا إِسّڒْمَاذْ، إِڭُّورْ غَارْ ؤُرْشَالِيمْ. \f ◼ \fr 13:‏22 \ft \+bd ’ذْشُورَاثْ‘\+bd* - نِيغْ ’ڒذْشُورْ‘ نِيغْ ’إِبِيلَاجنْ‘.\f*  \x ◘ \xo 13:‏22 \xt [مت. 7‏:‏13‏-‏14، 21‏-‏23] — مت. 9‏:‏35؛ مك. 6‏:‏6. \x*  
\v 23 إِجّنْ إِسّقْسَا إِ-ث، مَا أَقَا ذِينْ ذْرُوسْ ن يِينِّي إِ غَا طّْفنْ ثُوذَارْثْ.  
\v 24 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”ڭّمْ جّهْذْ نْومْ، حِيمَا أَذْ ثَاذْفمْ زِي ثوَّارْثْ إِحْصَارنْ، أَقَا نشّْ أَذْ أَومْ إِنِيغْ، أَطَّاسْ أَذْ أَرْزُونْ أَذْ د-أَذْفنْ، \add مَاشَا\add* وَارْ زمَّارنْ. \x ◘ \xo 13:‏24 \xt مت. 7‏:‏13. \x*  
\v 25 زڭْ وَامِي إِ غَا إِكَّارْ بَابْ ن ثَادَّارْثْ مَاحنْذْ أَذْ إِبلّعْ ثَاوَّارْثْ، خنِّي أَذْ ثْبدّمْ ذِي بَارَّا، أَذْ ثسّْقَارقْبمْ، أَذْ ثبْذَامْ أَذْ ثِينِيمْ: ’\add أَ\add* سِيذِيثْنغْ، \add أَ\add* سِيذِيثْنغْ، أَرْزمْ أَنغْ!‘ مَاشَا نتَّا أَذْ د-يَارّْ، أَذْ يِينِي: ’نشّْ وَارْ كنِّيوْ سِّينغْ، مَانِيسْ كنِّيوْ؟‘ \x ◘ \xo 13:‏25 \xt مت. 25‏:‏11، 12؛ لك. 6‏:‏46. \x*  
\v 26 أَذْ ثبْذَامْ أَذْ ثِينِيمْ: ’نشِّينْ أَحقَّا ثُوغَا نشَّا نسْوَا قِيبَاتْشْ نّشْ، ؤُشَا شكْ ثُوغَا ثسّڒْمَاذذْ ذڭْ إِمسْرَاقْ نّغْ!‘  
\v 27 \add مَاشَا\add* نتَّا أَذْ يِينِي: ’وَارْ كنِّيوْ سِّينغْ، \add وَارْ سِّينغْ\add* مَانِيسْ كنِّيوْ! أَڭّْوجمْ خَافِي، كنِّيوْ إِنِّي إِتّڭّنْ ڒْمُوعْصِييّثْ!‘ \x ◘ \xo 13:‏27 \xt إِزهد. 6‏:‏9؛ مت. 7‏:‏23؛ 25‏:‏12،41. \x*  
\v 28 أَذْ ذِينْ ثِيڒِي ثْغُويِّيثْ ذ ؤُغزِّي ن ثغْمَاسْ، خْمِي غَا ثْژَارمْ إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ ذ مَارَّا إِنَابِييّنْ ذِي ثْڭلْذِيثْ ن أَربِّي، مَاشَا كنِّيوْ أَذْ ثمّنْضَارمْ بَارَّا. \x ◘ \xo 13:‏28 \xt مت. 8‏:‏11، 12؛ 13‏:‏42؛ 24‏:‏51. \x*  
\v 29 أَذْ د-أَسنْ زِي مَانِيسْ ذ ثْنقَّارْ ثْفُوشْثْ ؤُ زِي مَانِي ثْغدْجِي ثْفُوشْثْ ؤُڒَا زِي شَّامَالْ ؤُڒَا زِي لْجَانُوبْ، أَذْ قِّيمنْ \add غَارْ طَّابْڒَا\add* ذِي ثْڭلْذِيثْ ن أَربِّي. \x ◘ \xo 13:‏29 \xt إِشا. 2‏:‏2؛ مـَال. 1‏:‏11؛ مت. 8‏:‏11. \x*  
\v 30 خْزَارْ، أَقَا ذِينْ إِنڭُّورَا إِنِّي إِ غَا يِيڒِينْ ذ إِمزْوُورَا، ؤُ أَقَا ذِينْ إِمزْوُورَا إِنِّي إِ غَا يِيڒِينْ ذ إِنڭُّورَا.“ \x ◘ \xo 13:‏30 \xt مت. 19‏:‏30؛ 20‏:‏16؛ مك. 10‏:‏31. \x*   
\b  
\m  
\s1 أَوَاڒنْ إِنڭُّورَا ن يَاسُوع خْ ؤُرْشَالِيمْ  
\m
\v 31 ذڭْ وَاسّْ نِّي قَارّْبنْ-د شَا ن إِفَارِيسِييّنْ، نَّانْ أَسْ: ”فّغْ، رُوحْ سَّا، مِينْزِي هِيرُوذُوسْ إِخْسْ أَذْ شكْ إِنغْ!“ \x ◘ \xo 13:‏31 \xt [مت. 23‏:‏37‏-‏39]\x*  
\v 32 يَاسُوع إِنَّا أَسنْ: ”رُوحمْ، إِنِيمْ أَسْ إِ وشْعبْ-أَ: ’خْژَارْ، أَقَا نشّْ سُّوفُّوغغْ شّْوَاطنْ، سّْڭنْفِيغْ أَسّْ-أَ ذ ثِيوشَّا، ؤُشَا ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا أَذْ إِوْضغْ غَارْ ڒكْمَارثْ.“ \f ◼ \fr 13:‏32 \ft \+bd ’أَذْ إِوْضغْ غَارْ ڒكْمَارثْ‘\+bd* - إِخْسْ أَذْ يِينِي ’أَذْ قْضِيغْ ڒْخذْمثْ إِنُو‘. خْزَارْ مَاثْ. 5:17.\f*  
\v 33 مَاشَا إِتّْخصَّا أَيِي أَذْ خذْمغْ أَسّْ-أَ ذ ثِيوشَّا، ؤُشَا ذڭْ وَاسّْ أَوَارْنِي أَسْ أَذْ رَاحغْ، مِينْزِي وَارْ إِزمَّارْ أَذْ إِتّْوَانغْ إِجّْ ن ؤُنَابِي بَارَّا إِ ؤُرْشَالِيمْ.  
\v 34 \add أَ\add* ؤُرْشَالِيمْ، \add أَ\add* ؤُرْشَالِيمْ، ثنِّي إِنقّنْ إِنَابِييّنْ ذ ثنِّي يَارجّْمنْ إِنِّي إِ غَارمْ د-إِتّْوَاسّكّنْ، مشْحَاڒْ ن ثْوَاڒَاوِينْ ثُوغَا خْسغْ أَذْ سّْمُونغْ ثَارْوَا نّمْ أَمْ مَامّشْ ثسّْمُونَا ثْيَاژِيضْثْ إِفِيدْجُوسنْ نّسْ سَاذُو وَافْرِيونْ نّسْ، \add مَاشَا\add* كنِّيوْ وَارْ ثخْسمْ. \x ◘ \xo 13:‏34 \xt إِزهد. 17‏:‏8؛ 91‏:‏4؛ مت. 23‏:‏37. \x*  
\v 35 خْزَارْ، ثَادَّارْثْ نْومْ أَذْ أَومْ ثقِّيمْ ذ ڒْخَارْبثْ. مَاغَارْ نشّْ أَذْ أَومْ إِنِيغْ، أَقَا وَارْ ذ أَيِي ثْژَارّمْ أَڒْ د غَا ثَاسْ ڒْوقْثْ إِ ذِي إِ غَا ثِينِيمْ: ’لْبَارَاكَا إِ ونِّي د غَا يَاسنْ س يِيسمْ ن سِيذِي‘.“ \x ◘ \xo 13:‏35 \xt إِزهد. 69‏:‏26؛ 118‏:‏26؛ إِشا. 1‏:‏7؛ إِرْم. 7‏:‏34؛ مِيخَا 3‏:‏12؛ مت. 23‏:‏38؛ ڒخ. 1‏:‏20. \x*   
\b  
\b  
\m  
\c 14
\s1 أَسْڭنْفِي ن إِجّْ ن ؤُمهْڒُوشْ س ثُوفّثْ ن وَامَانْ ذڭْ وَاسّْ ن سّبْثْ  
\m
\v 1 ڒَامِي يُوذفْ غَارْ ثَادَّارْثْ ن إِجّْ زڭْ إِمقّْرَاننْ ن إِفَارِيسِييّنْ حِيمَا أَذْ إِشّْ أَغْرُومْ ذڭْ وَاسّْ ن سّبْثْ، ثُوغَا حطَّانْ ث.  
\v 2 ؤُ خْزَارْ، إِبدّْ ذِينْ قِيبَاتْشْ نّسْ إِجّْ ن بْنَاذمْ إِهْڒشْ س ثُوفّثْ ن وَامَانْ \add ن أَرِّيمثْ نّسْ\add*.  
\v 3 إِطّفْ يَاسُوع ذڭْ وَاوَاڒْ، إِنَّا إِ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، إِنَّا: ”مَا إِحدْجڒْ ؤُسْڭنْفِي ذِي سّبْثْ؟“  
\v 4 نِيثْنِي سْقَارنْ وَاهَا. \add خنِّي\add* إِطّفْ إِ-ث، إِسّْڭنْفَا إِ-ث ؤُشَا إِجَّا إِ-ث أَذْ إِرَاحْ.  
\v 5 خنِّي يَارَّا-د خَاسنْ إِنَّا: ”مَانْ ونْ زَّايْومْ، مَاڒَا مِّيسْ نِيغْ أَفُونَاسْ نّسْ إِوْضَا أَسْ ذڭْ وَانُو، وَارْ ث-إِ-د-إِسُّوفُّوغْ زَّايسْ ذغْيَا ذڭْ وَاسّْ ن سّبْثْ؟“ \x ◘ \xo 14:‏5 \xt ؤُف. 23‏:‏5؛ أَعَوذ. 22‏:‏4؛ لك. 13‏:‏15. \x*  
\v 6 وَارْ ؤُفِينْ س مِينْ زِي خَاسْ د غَا يَارّنْ.   
\b  
\m  
\s1 أَمذْيَا خْ ؤُوَاضعْ  
\m
\v 7 إِعَاوذْ إِجّْ ن ؤُمذْيَا إِ إِنوْجِيونْ أَمْ ذ أَسنْ إِحكَّارْ إِخْضَارنْ إِمُوشَانْ إِمزْوُورَا. \add إِنَّا أَسنْ\add*:  
\v 8 ”مَاڒَا إِعَارْضْ حذْ إِ شكْ غَارْ إِجّْ ن وُورَارْ خنِّي وَارْ تّْغِيمِي ذڭْ ومْشَانْ أَمزْوَارُو، حِيمَا وَارْ إِتّْوَاعَارْضْ ونّغْنِي يُوعْڒَانْ \add خَاكْ\add*، مَاحنْذْ أَذْ إِقِّيمْ ذِينْ،  
\v 9 ؤُشَا \add خنِّي\add* أَذْ د-يَاسْ ونِّي خَاكْ إِعَارْضنْ، أَذْ أَشْ يِينِي: ’أڭّْ أَمْشَانْ إِ ورْيَازْ-أَ!‘، \add ؤُشَا خنِّي\add* أَذْ ثْسضْحِيذْ، أَذْ ثكَّارذْ حِيمَا أَذْ ثكْسِيذْ أَمْشَانْ أَنڭَّارُو.  
\v 10 مَاڒَا شكْ ثتّْوَاعَارْضذْ، رُوحْ، قِّيمْ ذڭْ ومْشَانْ أَنڭَّارُو، حِيمَا، خْمِي د غَا يَاذفْ ونِّي خَاكْ إِعَارْضنْ، أَذْ ثَاغْ أَذْ أَشْ يِينِي: ’\add أَ\add* أَمدُّوكّڒْ، ڭعّذْ، قِّيمْ!‘ خنِّي أَذْ أَشْ يِيڒِي شَّانْ زَّاثْ إِ يِينِّي أَكِيذكْ إِقِّيمنْ. \x ◘ \xo 14:‏10 \xt أَوڒن. 25‏:‏6، 7. \x*  
\v 11 مِينْزِي مَارَّا وِي غَا إِسُّوعْڒَانْ إِخفْ نّسْ أَذْ إِتّْوَاسّْوَاضعْ ؤُ وِي غَا إِسّْوَاضْعنْ إِخفْ نّسْ أَذْ إِتّْوَاسُّوعْڒَا.“ \x ◘ \xo 14:‏11 \xt أَيُوبْ 22‏:‏29؛ أَوڒن. 29‏:‏23؛ مت. 23‏:‏12؛ لك. 1‏:‏51؛ 18‏:‏14؛ يَاع. 4‏:‏6، 10؛ 1 بُط. 5‏:‏5. \x*   
\b  
\m  
\s1 أَمذْيَا ن يِينِّي إِتّْوَاعَارْضنْ إِ ؤُمنْسِي  
\m
\v 12 إِنَّا عَاوذْ إِ ونِّي ث إِعَارْضنْ: ”مَاڒَا شكْ ثڭِّيذْ إِجّْ ن ؤُمشْڒِي نِيغْ أَمنْسِي، وَارْ عَارّضْ إِمدُّوكَّاڒْ نّشْ نِيغْ أَيْثْمَاشْ، ؤُڒَا ذ ڒَادْجْ نّشْ نِيغْ جِّيرَانْ نّشْ إِ غَارْ إِدْجَا وَاڭْڒَا، نِيغْ أَقَا أَذْ شكْ عَارْضنْ ؤُڒَا ذ نِيثْنِي ؤُشَا أَذْ غَاركْ يِيڒِي ڒخْڒَاصْ. \x ◘ \xo 14:‏12 \xt [مت. 22‏:‏1‏-‏10] — نَاح. 8‏:‏10؛ أَوڒن. 3‏:‏28. \x*  
\v 13 مَاڒَا ثْعَارْضذْ \add خْ إِوْذَانْ\add*، خنِّي عَارْضْ خْ إِمزْڒَاضْ ذ إِقِييْذَارنْ ذ إِنعْضَابنْ ذ إِذَارْغَاڒنْ.  
\v 14 \add خنِّي\add* أَذْ ثِيڒِيذْ ذ أَمسْعُوذْ ؤُمِي وَارْ غَارْسنْ س مِينْزِي شكْ إِ غَا خدْجْصنْ، مِينْزِي أَذْ ثطّْفذْ ڒخْرَاصْ نّشْ ذِي ثْنُوكْرَا ن إِمْسڭَّاذنْ.“   
\m
\v 15 ؤُمِي إِسْڒَا أَيَا إِجّنْ زڭْ إِنِّي ذِينْ إِقِّيمنْ \add غَارْ طَّابْڒَا\add*، إِنَّا أَسْ وَانِيثَا: ”سّعْذْ ن ونِّي إِ غَا إِشّنْ أَغْرُومْ ذِي ثْڭلْذِيثْ ن أَربِّي!“  
\v 16 يَاسُوع إِنَّا أَسْ: ”إِجّْ ن ورْيَازْ إِڭَّا إِشْثْ ن زَّارْذثْ ثمْغَارْ ؤُشَا إِعَارْضْ أَطَّاسْ \add ن إِوْذَانْ\add*. \x ◘ \xo 14:‏16 \xt إِشا. 25‏:‏6؛ مت. 22‏:‏2؛ أَسَا. 19‏:‏7، 9. \x*  
\v 17 إِسّكّْ أَمْسخَّارْ نّسْ ذِي ثْسَاعّثْ ن زَّارْذثْ، حِيمَا أَذْ إِنِي إِ إِنوْجِيونْ: ’خْزَارْ، كُوڒْشِي أَقَا إِوْجذْ إِ كنِّيوْ. أَرَاحمْ-د!‘  
\v 18 \add خنِّي\add* إِبْذَا كُوڒْ إِجّنْ زَّايْسنْ أَذْ إِڭّْ سِّيبّثْ. إِنَّا أَسْ ؤُمزْوَارْ: ’سْغِيغْ إِجّْ ن إِيَّارْ، أَقَا إِتّْخصَّا أَيِي أَذْ رَاحغْ أَذْ ث ژَترغْ. تَّارغْ أَشْ أَذْ أَيِي ثْسَامْحذْ!‘  
\v 19 ونّغْنِي إِنَّا: ’سْغِيغْ خمْسَا ن ثْيُويَا ن إِينْذُوزنْ، أَقَا أَذْ رَاحغْ أَذْ ثنْ جَارّْبغْ، تَّارغْ أَشْ أَذْ أَيِي ثْسَامْحذْ!‘  
\v 20 ؤُ ونّغْنِي إِنَّا: ’أَقَا مَامّشْ مڒْشغْ ثَامْغَارْثْ، خْ ؤُينِّي وَارْ زمَّارغْ أَذْ د-أَسغْ!‘   
\m
\v 21 إِذْوڒْ-د ؤُمْسخَّارْ نِّي ؤُشَا إِخبَّارْ سِيذِي نّسْ س مَانْ أَيَا. خنِّي إِخيّقْ بَابْ ن ثَادَّارْثْ، إِنَّا إِ ؤُمْسخَّارْ نّسْ: ’رُوحْ ذغْيَا غَارْ وَازَّاينْ ذ زّْنَاقِي ن ثنْذِينْثْ، ؤُشَا نْذهْ-د إِمزْڒَاضْ ذ إِقِييْذَارنْ ذ إِنعْضَابنْ ذ إِذَارْغَاڒنْ!‘  
\v 22 إِنَّا ؤُمْسخَّارْ: ’\add أَ\add* سِيذِي، أَقَا إِمْسَارْ أَمْ مَامّشْ إِ ثُومُورذْ، ؤُشَا أَقَا ذِينْ عَاذْ أَمْشَانْ.‘  
\v 23 إِنَّا بَابْ إِ ؤُمْسخَّارْ نّسْ: ’فّغْ غَارْ إِبْرِيذنْ ذ زّْنَاقِي ؤُشَا حْصَارْ إِ-ثنْ أَذْ أَذْفنْ أَڒْ غَا ثشُّورْ ثَادَّارْثْ إِنُو،  
\v 24 مِينْزِي نشّْ أَذْ أَومْ إِنِيغْ، بلِّي ؤُڒَا ذ إِجّْ زڭْ يرْيَازنْ إِنِّي ثُوغَا إِتّْوَاعَارْضنْ، أَذْ يِيڒِي غَارْ زَّارْذثْ إِنُو‘ “   
\b  
\m  
\s1 أَضْفَارْ ن يَاسُوع  
\m
\v 25 أَمْ ثُوغَا إِجّْ ن ؤُبَارُّو ذ أَمقّْرَانْ ن ڒْغَاشِي إِڭُّورْ أَكِيذسْ، إِنّقْڒبْ-د، إِنَّا أَسنْ: \x ◘ \xo 14:‏25 \xt [مت. 10‏:‏37‏-‏38]\x*  
\v 26 ”مَاڒَا يُوسَا-د حذْ غَارِي ؤُشَا وَارْ إِشَارّهْ بَابَاسْ نِيغْ يمَّاسْ، أَيْثْمَاسْ نِيغْ سُويثْمَاسْ، ثَامْغَارْثْ نّسْ نِيغْ ثَارْوَا نّسْ، ؤُ عَاذْ ؤُڒَا ذ إِخفْ نّسْ، وَارْ إِزمَّارْ أَذْ يِيڒِي ذ أَمحْضَارْ إِنُو. \x ◘ \xo 14:‏26 \xt أَعَوذ. 13‏:‏7؛ 33‏:‏9؛ مت. 10‏:‏37. \x*  
\v 27 ونِّي وَارْ إِكْسِينْ صَّالِيبْ نّسْ، أَذْ أَيِي د-إِضْفَارْ، وَارْ إِزمَّارْ أَذْ يِيڒِي ذ أَمحْضَارْ إِنُو. \x ◘ \xo 14:‏27 \xt مت. 10‏:‏38؛ 16‏:‏24؛ مك. 8‏:‏34؛ لك. 9‏:‏23. \x*  
\v 28 ؤُ مَانْ ونْ زَّايْومْ إِ إِخْسنْ أَذْ إِبْنَا إِشْثْ ن صُّومْعثْ، وَارْ إِتّْغِيمِي أَمزْوَارْ حِيمَا أَذْ إِڭّْ ڒحْسَابْ، مَا غَارسْ مِينْ إِخصّنْ إِ ؤُكمّڒْ،  
\v 29 حِيمَا، مَاڒَا إِسَّارْسْ ذْسَاسْ، \add خنِّي\add* وَارْ إِزمَّارْ أَذْ أَسْ إِكمّڒْ، وَارْ خَاسْ ضحّْشنْ مَارَّا إِنِّي ث إِژْرِينْ،  
\v 30 أَذْ إِنِينْ: ’أَرْيَازْ-أَ إِبْذَا ڒبْنِي ؤُشَا وَارْ إِزمَّارْ أَذْ ث إِكمّڒْ.‘   
\m
\v 31 نِيغْ مَانْ أَجدْجِيذْ، مَاڒَا إِفّغْ غَارْ ؤُمنْغِي ضِيدّْ ن إِجّْ ن ؤُجدْجِيذْ نّغْنِي، وَارْ إِتّمْشَاوَارْ أَمزْوَارْ مَا إِزمَّارْ أَذْ إِمْقُودَّا سعشْرَا-أَڒَافْ أَكْ-ذ ونِّي غَارسْ إِ د غَا يَاسنْ س عِيشْرِينْ-أَڒفْ؟  
\v 32 مَاڒَا وَارْ إِدْجِي أَمنِّي، خنِّي أَذْ د-إِسّكّْ إِرقَّاسنْ أَمْ إِدْجَا \add ؤُجدْجِيذْ\add* نِّي عَاذْ غَارْ ڒَاڭّْوَاجْ، حِيمَا أَذْ \add زَّايسْ\add* إِتَّارْ أَصْڒَاحْ.   
\m
\v 33 س ؤُينِّي ؤُڒَا ذ إِجّْ زَّايْومْ ونِّي وَارْ إِتّجِّي مَارَّا أَڭْڒَا نّسْ، وَارْ إِزمَّارْ أَذْ يِيڒِي ذ أَمحْضَارْ إِنُو.“   
\b  
\m  
\s1 أَمذْيَا ن ثْمدْجَاحْثْ  
\m
\v 34 ”ثَامدْجَاحْثْ ثحْڒَا، مَاشَا مَاڒَا ثخْسَارْ ثْمدْجَاحْثْ أَڒذِّي نّسْ، س مِينْ زِي ت إِ غَا إِعذْڒنْ؟ \x ◘ \xo 14:‏34 \xt [مت. 5‏:‏13؛ مك. 9‏:‏50] \x*  
\v 35 وَارْ ثْصدْجحْ شَا إِ ثمُّورْثْ ؤُڒَا إِ ثْزُوبَاتْشْ، خنِّي أَذْ ت نْضَارنْ. ونِّي غَارْ إِدْجَا إِمزُّوغنْ إِ ؤُسدْجِي، أجّْ إِ-ث أَذْ إِسڒْ.“   
\b  
\b  
\m  
\c 15
\s1 أَمذْيَا ن ؤُحُوڒِي إِودَّارنْ  
\m
\v 1 خنِّي ثُوغَا أَيْثْ ن ضَّارِيبَا ذ إِمذْنَابْ تّْقَارَّابنْ غَارسْ حِيمَا أَذْ أَسْ سْڒنْ. \x ◘ \xo 15:‏1 \xt [مت. 18‏:‏12‏-‏14] — مت. 9‏:‏10؛ مك. 2‏:‏15؛ لك. 5‏:‏29. \x*  
\v 2 تّْمعْمِيعنْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، قَّارنْ: ”أَقَا وَا يَارحّبْ س إِمذْنَابْ ؤُشَا إِتّتّْ أَكِيذْسنْ.“  
\v 3 \add خنِّي\add* إِحَاجَا أَسنْ يَاسُوع أَمذْيَا-يَا:  
\v 4 ”مَانْ بْنَاذمْ زَّايْومْ إِ غَارْ إِدْجَا مْيَا ن إِحُوڒِييّنْ ؤُشَا إِودَّارْ أَسْ إِجّنْ زَّايْسنْ، مَا وَارْ إِتّجِّي ثسْعَا ؤُ ثسْعِينْ ذِي ڒخْڒَا ؤُشَا أَذْ يَارْزُو خْ ونِّي إِودَّارنْ أَڒْ ث غَا يَافْ؟  
\v 5 ؤُ خْمِي ث غَا يَافْ، أَذْ إِفْرَاحْ، أَذْ ث إِسَّارْسْ خْ ثْغَارْذِينْ نّسْ.  
\v 6 خْمِي د غَا يَاوضْ غَارْ ثَادَّارْثْ، أَذْ إِڒَاغَا خْ إِمدُّوكَّاڒْ نّسْ ذ جِّيرَانْ نّسْ، أَذْ أَسنْ يِينِي: ’فَارْحمْ أَكِيذِي، مِينْزِي ؤُفِيغْ أَهُوڒِي إِنُو إِودَّارنْ!‘  
\v 7 نشّْ أَذْ أَومْ إِنِيغْ، أَمُّو إِ غَا ثِيڒِي ڒفْرَاحثْ ذڭْ ؤُجنَّا خْ إِجّْ ن ؤُمذْنُوبْ إِ غَا إِثُوبنْ كْثَارْ خْ ثسْعَا ؤُ-ثسْعِينْ ن إِمْسڭَّاذنْ إِ وَارْ إِخْسنْ أَذْ ثُوبنْ!“ \x ◘ \xo 15:‏7 \xt لك. 5‏:‏32. \x*   
\b  
\m  
\s1 أَمذْيَا ن ؤُصُولْذِي إِودَّارنْ  
\m
\v 8 ”نِيغْ مَانْ ثَامْغَارْثْ إِ غَارْ إِدْجَا عشْرَا ن ثبْيِيسِينْ ن إِجّْ ن جُّوزْ، مَاڒَا إِودَّارْ إِشْثنْ زَّايْسنْثْ، مَا وَارْ ثسّْرُوغِي ڒْقنْذِيڒْ، أَذْ ثْفَارْضْ ثَادَّارْثْ ؤُشَا أَذْ ثَارْزُو مْلِيحْ أَڒْ ت غَا ثَافْ؟ \f ◼ \fr 15:‏8 \ft \+bd ’ذِيرْهَامْ‘\+bd* - س ثْيُونَانِيثْ: ’ذْرَاخْمَا‘، إِجّْ ن ؤُصُولْذِي ذِي ڒْوقْثْ ن إِرُومَانِييّنْ. س إِڒسْ ن ثْرَامِيثْ: ’زُوزَا‘.\f*  
\v 9 مَاڒَا ثُوفِي ت، أَذْ ثْڒَاغَا خْ ثْمدُّوكَاڒْ ذ ثِيجَّارِينْ، أَذْ أَسنْثْ ثِينِي: ’فَارْحنْثْ أَكِيذِي، مِينْزِي ؤُفِيغْ \add ثَابْيِيسْثْ ن\add* ’جُّوزْ‘ نِّي ثُوغَا ذ أَيِي إِودَّارنْ.‘  
\v 10 نشّْ أَذْ أَومْ إِنِيغْ، أَمُّو إِ غَا ثِيڒِي ڒفْرَاحثْ قِيبَاتْشْ إِ لْمَالَاكَاثْ ن أَربِّي س يِيجّْ ن ؤُمذْنُوبْ إِ غَا إِثُوبنْ.“   
\b  
\m  
\s1 أَمذْيَا ن مِّيسْ إِودَّارنْ  
\m
\v 11 يَاسُوع إِنَّا أَسنْ عَاوذْ: ”إِجّْ ن بْنَاذمْ ثُوغَا غَارسْ ثْنَاينْ ن إِحنْجِيرنْ.  
\v 12 إِنَّا ؤُمَاژُوژْ نْسنْ إِ بَابَاسْ: ’أَ بَابَا، أوْشْ أَيِي ثَاسْغَارْثْ ثنِّي ذ أَيِي د-يُوسِينْ زڭْ وَاڭْڒَا نّشْ!‘ \add خَاسْ ؤُشَا\add* إِبْضَا أَسنْ \add بَابَاسْ\add* أَڭْڒَا نّسْ.  
\v 13 أَوَارْنِي شَا ن وُوسَّانْ إِسّْمُونْ مِّيسْ أَمَاژُوژْ كُوڒْشِي مِينْ ذ أَسْ إِمّوْشنْ، خنِّي إِسَافَارْ غَارْ إِشْثْ ن ثمُّورْثْ ثِيڭّْوجْ. إِقَارْضْ مَارَّا أَڭْڒَا نّسْ أَمْ إِسّعْذُو ذِينِّي إِشْثْ ن ثُوذَارْثْ ن ؤُفشّحْ.   
\m
\v 14 أَوَارْنِي ڒَامِي إِقَارْضْ كُوڒْشِي، إِوْضَا-د إِجّْ ن ڒَاژْ إِوْعَارْ ذِي ثمُّورْثْ نِّي ؤُشَا إِبْذَا أَذْ إِحْوَاجْ.  
\v 15 إِرُوحْ ؤُشَا إِڒْصقْ ذڭْ إِجّنْ زڭْ إِمزْذَاغْ ن ثمُّورْثْ نِّي ؤُشَا وَانِيثَا إِسّكّْ إِ-ث غَارْ إِيَّارْ نّسْ حِيمَا أَذْ يَارْوسْ إِڒْفَانْ.  
\v 16 ثُوغَا إِمّژْرِي أَذْ إِشُّورْ أَعذِّيسْ نّسْ س ثسْرِيغْوَا، ثنِّي إِتّتّنْ إِڒْفَانْ، \add مَاشَا\add* ؤُڒَا ذ إِجّْ وَارْ ذ أَسْ إِوْشِي شَا.  
\v 17 إِذْوڒْ غَارْ ڒعْقڒْ نّسْ، إِنَّا: ’مشْحَاڒْ ن إِخمَّاسنْ ن بَابَا إِ غَارْ إِدْجَا أَغْرُومْ أَطَّاسْ ؤُ نشّْ ذَا تّْمتِّيغْ س ڒَاژْ!  
\v 18 أَذْ كَّارغْ، أَذْ رَاحغْ غَارْ بَابَا ؤُشَا أَذْ أَسْ إِنِيغْ: ’\add أَ\add* بَابَا، أَقَا خْضِيغْ أَكْ-ذ ؤُجنَّا ؤُ أَكِيذكْ!  
\v 19 وَارْ سْذِيهدْجغْ أَذْ أَيِي ثْڒَاغِيذْ ذ مِّيشْ. أڭّْ أَيِي أَمْ يِيجّنْ زڭْ إِشُووَّارنْ نّشْ.‘   
\m
\v 20 إِكَّارْ ؤُشَا إِعْقبْ غَارْ بَابَاسْ. أَمْ ث ثُوغَا عَاذْ غَارْ ڒَاڭّْوَاجْ، إِبَارْقْ إِ-ث بَابَاسْ، إِحِينّْ خَاسْ، ؤُشَا يُوزّڒْ غَارسْ، إِنْڭزْ أَسْ خْ يِيرِي، إِسُّوذمْ إِ-ث. \x ◘ \xo 15:‏20 \xt ڒخ. 2‏:‏39؛ أَفا. 2‏:‏12، 17. \x*  
\v 21 إِنَّا أَسْ مِّيسْ: ’\add أَ\add* بَابَا، خْضِيغْ أَكْ-ذ ؤُجنَّا ؤُ أَكِيذكْ. وَارْ سْذِيهدْجغْ أَذْ أَيِي ڒَاغَانْ مِّيشْ.‘  
\v 22 مَاشَا بَابَاسْ إِنَّا إِ إِمْسخَّارنْ نّسْ: ’سُوفّْغمْ-د أَرُّوضْ إِحْڒَانْ أَطَّاسْ، سْيَارْضمْ أَسْ ث، ڭّمْ ثْخَاذنْثْ ذڭْ ؤُفُوسْ نّسْ ؤُشَا قّْنمْ أَسْ سَانْذَالِييَاثْ \add إِ إِضَارنْ نّسْ\add*.  
\v 23 أَوْيمْ-د أَينْذُوزْ إِصحّنْ، ثْغَارْصمْ أَسْ، خنِّي أَذْ نشّْ، أَذْ نْفَارْحْ،  
\v 24 مِينْزِي مِّي وَانِيثَا ثُوغَا إِمُّوثْ، إِدَّارْ. ثُوغَا إِودَّارْ، \add مَاشَا\add* إِتّْوَافْ.‘ خنِّي بْذَانْ أَذْ فَارْحنْ!   
\m
\v 25 مَاشَا مِّيسْ أَمقّْرَانْ ثُوغَا ذڭْ إِيَّارْ. أَڒَامِي د-يَارڭّْوحْ، إِذْوڒْ إِقَارّبْ-د غَارْ ثَادَّارْثْ، خنِّي إِسْڒَا إِ دْجْغَا ذ ؤُغنّجْ ن وَاطَّاسْ ن إِوْذَانْ.  
\v 26 إِڒَاغَا إِ يِيجّنْ زڭْ إِمْسخَّارنْ إِمژْيَاننْ نّسْ، إِسّقْسَا ث: ’مَانْ أَيَا؟‘  
\v 27 وَانِيثَا إِنَّا أَسْ: ’ؤُمَاشْ يُوسَا-د، بَابَاشْ إِغَارْصْ إِ ؤُينْذُوزْ إِصحّنْ، مِينْزِي إِعْقبْ-د غَارسْ مْلِيحْ!‘  
\v 28 مَاشَا \add مِّيسْ أَمقّْرَانْ\add* إِخيّقْ، وَارْ إِخْسْ أَذْ يَاذفْ. خنِّي إِفّغْ بَابَاسْ غَارْ بَارَّا، إِحشّمْ إِ-ث.  
\v 29 مَاشَا نتَّا يَارَّا-د، إِنَّا أَسْ إِ بَابَاسْ: ’أَقَا نشّْ خذْمغْ غَاركْ ڒخُّو أَطَّاسْ ن إِسڭّْوُوسَا،عمَّارْصْ وَارْ جِّيغْ زِي ثوْصيّثْ نّشْ. \add مَاشَا\add* شكْ وَارْ ذ أَيِي ثوْشِيذْعمَّارْصْ ؤُڒَا ذ إِجّْ ن إِغَايْضْ، حِيمَا أَذْ فَارْحغْ أَكْ-ذ إِمدُّوكَّاڒْ إِنُو.  
\v 30 مَاشَا ؤُمِي د-يُوسَا مِّيشْ وَانِيثَا ونِّي إِشّنْ أَڭْڒَا نّشْ أَكْ-ذ ثمْغَارِينْ ن فَارْقْ-شّْغڒْ، ثْغَارْصذْ أَسْ إِ ؤُينْذُوزْ إِصحّنْ!‘  
\v 31 إِنَّا أَسْ بَابَاسْ: ’أَ مِّي، ثُوغَا شكْ أَكِيذِي ڒبْذَا، أَقَا مَارَّا مِينْ إِدْجَانْ إِنُو، أَقَا نّشْ.  
\v 32 أَقَا إِعدّڒْ إِ نشِّينْ أَذْ نْفَارْحْ أَذْ نزْهُو، مِينْزِي ؤُمَاشْ وَانِيثَا ثُوغَا إِمُّوثْ، \add مَاشَا\add* إِدَّارْ \add عَاوذْ\add*، ثُوغَا إِودَّارْ ؤُشَا إِتّْوَافْ!‘ “   
\b  
\b  
\m  
\c 16
\s1 أَمذْيَا ن ووْكِيڒْ ذ أَعفَّانْ  
\m
\v 1 إِنَّا عَاوذْ إِ إِمحْضَارنْ نّسْ: ”ثُوغَا ذِينْ إِجّْ ن بْنَاذمْ، أَقَا-ث ذ بَابْ ن وَاڭْڒَا، غَارسْ إِجّْ ن ووْكِيڒْ نِّي زِي شثْشَانْ \add إِوْذَانْ\add*، أَقَا زعْمَا ثُوغَا إِتّْزُوزَّارْ أَڭْڒَا ن سِيذسْ.  
\v 2 إِڒَاغَا أَسْ، إِنَّا أَسْ: ’مَانْ أَيَا إِ خَاكْ تّسْڒِيغْ؟ أوْشْ ڒحْسَابْ إِ ؤُوكّڒْ نّشْ، مِينْزِي وَارْ إِزمَّارْ أَذْ ثِيڒِيذْ عَاذْ ذ أَوْكِيڒْ!‘  
\v 3 إِنَّا ووْكِيڒْ أَكْ-ذ إِخفْ نّسْ: ’مِينْ غَا ڭّغْ ؤُمِي سِيذِي إِنُو أَذْ خَافِي إِكّسْ أَوكّڒْ-أَ؟ وَارْ زمَّارغْ إِ ؤُقَّازْ ن ثمُّورْثْ ؤُ تّْسضْحِيغْ ثُوثْرَا!  
\v 4 أَقَا سّْنغْ مِينْ غَا ڭّغْ حِيمَا، خْمِي غَا تّْوَاحُوزغْ خْ ؤُوكّڒْ، أَذْ أَيِي قبْڒنْ ذِي ثُوذْرِينْ نْسنْ.‘  
\v 5 ؤُشَا إِڒَاغَا-د إِ كُوڒْ إِجّنْ زڭْ أَيْثْبَابْ ن ؤُمَارْوَاسْ ن سِيذسْ. إِنَّا أَسْ إِ ؤُمزْوَارْ: ’مشْحَاڒْ ذ أَشْ إِتُّورْسْ سِيذِي؟‘  
\v 6 يَارَّا-د خَاسْ نتَّا: ’مْيَا ن إِبِيذَاونْ ن زّشْثْ!‘ إِنَّا أَسْ: ’كْسِي ڒْشِيغذْ ن ؤُمَارْوَاسْ نّشْ، قِّيمْ ذغْيَا، ثَارِيذْ: خمْسِينْ ن إِبِيذَاونْ.‘  
\v 7 \add خنِّي\add* إِنَّا إِ ونّغْنِي: ’إِ شكْ، مشْحَاڒْ ذ أَشْ إِتُّورْسْ سِيذِي؟‘ يَارَّا-د خَاسْ: ’مْيَا ن ثْخُونْشَايْ ثِيمقّْرَانِينْ ن يِيرْذنْ.‘ إِنَّا أَسْ: ’كْسِي ڒْشِيغذْ ن ؤُمَارْوَاسْ نّشْ، ثَارِيذْ: ثْمَانْيِينْ.‘  
\v 8 سِيذِيثْنغْ إِڭَّا ڒْفَادْجْ ذڭْ ووْكِيڒْ إِغشّْ، أَقَا ثُوغَا إِتّڭّْ س ثِيغِيثْ، مِينْزِي ثَارْوَا ن دُّونشْثْ-أَ ذ إِمِيغِيسنْ ذِي جِّيڒْ نْسنْ وَانِيثَا خْ ثَارْوَا ن ثْفَاوْثْ.  
\v 9 عَاوذْ نشّْ أَذْ أَومْ إِنِيغْ: ’ڭّمْ إِمدُّوكَّاڒْ إِ يِيخفْ نْومْ س وَاڭْڒَا-يَا ن ڒْغشّْ، حِيمَا، خْمِي غَا إِقْضَا، أَذْ كنِّيوْ قبْڒنْ ذڭْ إِقِيضَانْ نْسنْ ن ڒبْذَا.‘ “ \x ◘ \xo 16:‏9 \xt مت. 6‏:‏19؛ 19‏:‏21؛ 1 تِيم. 6‏:‏19. \x*   
\b  
\m  
\s1 ثَاسخَّارْثْ إِ أَربِّي ذ ثوْكِيڒْثْ ن ثنْعَاشِينْ  
\m
\v 10 ”ونِّي إِدْجَانْ ذ أَمْثِيقِّي ذِي ذْرُوسْ، أَقَا-ث ذ أَمْثِيقِّي ؤُڒَا ذڭْ وَاطَّاسْ، ؤُ ونِّي إِغشّنْ ذِي ذْرُوسْ، أَقَا إِغشّْ ؤُڒَا ذڭْ وَاطَّاسْ.  
\v 11 مَاڒَا وَارْ ثدْجِيمْ ذ إِمْثِيقَّانْ زِي جِّيهثْ ن وَاڭْڒَا ن ڒْغشّْ، وِي كنِّيوْ إِ غَا إِوكّْڒنْ خْ مِينْ إِدْجَانْ نِيشَانْ؟  
\v 12 مَاڒَا وَارْ ثدْجِيمْ ذ إِمْثِيقَّانْ ذِي مِينْ إِدْجَانْ ن ونّغْنِي، وِي ذ أَومْ إِ غَا إِوْشِينْ مِينْ إِدْجَانْ نْومْ؟   
\m
\v 13 ؤُڒَا ذ إِجّْ ن ؤُمْسخَّارْ وَارْ إِزمَّارْ أَذْ إِخْذمْ ثْنَاينْ ن إِسِيذِيثنْ، مِينْزِي نِيغْ أَذْ إِشَارْهْ إِجّنْ ؤُشَا أَذْ إِسّْعِيزّْ ونّغْنِي، نِيغْ أَذْ إِشبَّارْ ذڭْ إِجّنْ ؤُشَا أَذْ إِسّحْقَارْ ونّغْنِي. وَارْ ثْزمَّارمْ أَذْ ثْسخَّارمْ إِ أَربِّي ذ وَاڭْڒَا. \x ◘ \xo 16:‏13 \xt مت. 6‏:‏24. \x*   
\b  
\m  
\s1 شَّارِيعَا ن سِيذِي أَربِّي وَارْ تّْبطِّيڒْ شَا  
\m
\v 14 ڒَامِي سْڒِينْ إِفَارِيسِييّنْ مَارَّا مَانْ أَيَا، سّحْقَارنْ ث، مِينْزِي نِيثْنِي ثُوغَا تّخْسنْ ثْمنْيَاثْ. \x ◘ \xo 16:‏14 \xt [مت. 11‏:‏12‏-‏13] — مت. 23‏:‏14. \x*  
\v 15 يَاسُوع إِنَّا أَسنْ: ”كنِّيوْ ذ إِنِّي إِسّڭّْذنْ إِخفْ نْومْ زَّاثْ إِ إِوْذَانْ، مَاشَا أَربِّي يَارْڭبْ خْ وُوڒَاونْ نْومْ، مِينْزِي مِينْ يُوعْڒَانْ غَارْ إِوْذَانْ، أَقَا-ث ذ نّْعِي زَّاثْ إِ أَربِّي. \x ◘ \xo 16:‏15 \xt 1 صم. 16‏:‏7؛ إِزهد. 7‏:‏10. \x*  
\v 16 شَّارِيعَا ذ إِنَابِييّنْ أَقَا أَثنْ أَڒْ يُوحَانَّا. زِي ڒْوقْثْ نِّي إِتّْوَابَارّحْ س ثْڭلْذِيثْ ن أَربِّي ؤُشَا مَارَّا إِذْسنْ تّمْسذْحَاسنْ غَارسْ حِيمَا أَذْ ذِينْ أَذْفنْ. \x ◘ \xo 16:‏16 \xt مت. 11‏:‏12، 13. \x*  
\v 17 مَاشَا ثِيكّسْثْ ن ؤُجنَّا ذ ثمُّورْثْ ثهْونْ خْ ؤُوطُّو ن إِشْثْ ن ثْنقِّيطْ زِي شَّارِيعَا.“ \x ◘ \xo 16:‏17 \xt إِزهد. 102‏:‏27؛ إِشا. 40‏:‏8؛ 51‏:‏6؛ مت. 5‏:‏18. \x*   
\b  
\m
\v 18 ”مَارَّا وِي غَا إِدْجْفنْ إِ ثمْغَارْثْ نّسْ ؤُشَا أَذْ إِمْڒشْ أَكْ-ذ ثنّغْنِيثْ، أَقَا إِزْنَا، ؤُ مَارَّا وِي غَا إِمڒْشنْ ثَامْغَارْثْ ثنِّي ؤُمِي إِدْجْفنْ، أَقَا نتَّا إِزْنَا.“ \x ◘ \xo 16:‏18 \xt مت. 5‏:‏32؛ 19‏:‏9؛ مك. 10‏:‏11؛ 1 كُور. 7‏:‏10. \x*   
\b  
\m  
\s1 بَابْ ن وَاڭْڒَا ذ ؤُمژْڒُوضْ أَلِيعَازَارْ  
\m
\v 19 ”ثُوغَا ذِينْ إِجّْ ن بْنَاذمْ، أَقَا-ث ذ بَابْ ن وَاڭْڒَا، يَارْضْ ڒقْطنْ أَشمْڒَاڒْ أَزْذَاذْ ذ \add ڒحْرِيرْ ذ\add* أَزڭّْوَاغْ. إِتّْغبَّا زّْهُو كُوڒْ أَسّْ.  
\v 20 ثُوغَا ذِينْ عَاوذْ إِجّْ ن ؤُمزْڒُوضْ قَّارنْ أَسْ أَلِيعَازَارْ. ثُوغَا سّْبُوژّْڒنْ ث غَارْ ثوَّارْثْ ن بَابْ ن وَاڭْڒَا، إِشُّورْ س ڒْحبّْ.  
\v 21 ثُوغَا ذَايسْ مژْرِي أَذْ إِجِّيونْ س إِڒقّْوَازْ إِ د-إِوطَّانْ زِي طَّابْڒَا ن بَابْ ن وَاڭْڒَا. تَّاسنْ-د يِيطَانْ عَاوذْ، ڒسّْحنْ إِبُوعْرُوسنْ نّسْ.  
\v 22 إِمُّوثْ ؤُمزْڒُوضْ، كْسِينْثْ ث لْمَالَاكَاثْ غَارْ وحْسِينْ ن إِبْرَاهِيمْ. ؤُڒَا ذ بَابْ ن وَاڭْڒَا إِمُّوثْ، نضْڒنْ ث.   
\m
\v 23 أَمْ ثُوغَا إِتّْعدَّابْ ذِي ڒَاخَارْثْ، إِسّْڭعّذْ ثَامُوغْڒِي نّسْ، إِژْرَا إِبْرَاهِيمْ زِي ڒَاڭّْوَاجْ ؤُ أَلِيعَازَارْ ثُوغَا-ث ذڭْ وحْسِينْ نّسْ.  
\v 24 إِڒَاغَا س جّهْذْ: ’\add أَ\add* بَابَا إِبْرَاهِيمْ، أَرْحمْ أَيِي. سكّْ-د أَلِيعَازَارْ حِيمَا أَذْ إِسُّوفّْ إِخفْ ن ؤُضَاضْ نّسْ س وَامَانْ ؤُشَا أَذْ إِسّسْمضْ إِڒسْ إِنُو، مِينْزِي أَقَا تّْعدَّابغْ ذِي ثْمسِّي-يَا.‘   
\m
\v 25 إِنَّا أَسْ إِبْرَاهِيمْ: ’أَ مِّي، عْقڒْ أَقَا ثْكمّْڒذْ مَارَّا ڒْخَارْ نّشْ ذِي ثُوذَارْثْ نّشْ، ؤُشَا أَمُّو إِ إِكمّڒْ أَلِيعَازَارْ ڒْغَارْ. ڒخُّو نتَّا إِتّتّْوَافوّجْ ؤُ شكْ ثتّْوَاعدَّابذْ. \x ◘ \xo 16:‏25 \xt أَيُوبْ 21‏:‏13. \x*  
\v 26 سنّجْ إِ مَانْ أَيَا مَارَّا، أَقَا جَارْ أَنغْ نشِّينْ ذ كنِّيوْ إِجّْ ن تَّاسِيعْ إِمْغَارْ، أَڒَامِي إِنِّي إِخْسنْ أَذْ غَارْومْ د-ژْوَانْ سَّا، وَارْ زمَّارنْ ؤُشَا ؤُڒَا ذ إِنِّي ذِينْ إِدْجَانْ وَارْ زمَّارنْ أَذْ غَارْنغْ د-ژْوَانْ سّنِّي.‘  
\v 27 إِنَّا أَسْ: ’تّْزَاوْڭغْ شكْ خنِّي، أَ بَابَا، أَذْ ث ثسّكّذْ غَارْ ثَادَّارْثْ ن بَابَا،  
\v 28 مِينْزِي غَارِي خمْسَا ن أَيْثْمَا. أجّْ إِ-ث أَذْ أَسنْ إِعْڒمْ، حِيمَا وَارْ د-تِّيسنْ ؤُڒَا ذ نِيثْنِي غَارْ ومْشَانْ-أَ ن ؤُعدّبْ.‘  
\v 29 إِنَّا أَسْ إِبْرَاهِيمْ: ’أَقَا غَارْسنْ مُوسَا ذ إِنَابِييّنْ. أجّْ إِ-ثنْ أَذْ غَارْسنْ سْڒنْ!‘ \x ◘ \xo 16:‏29 \xt إِشا. 8‏:‏20؛ 34‏:‏16؛ يُوح. 5‏:‏39؛ ڒخ. 17‏:‏11. \x*  
\v 30 مَاشَا نتَّا إِنَّا أَسْ: ’لَّ، \add أَ\add* بَابَا إِبْرَاهِيمْ، مَاڒَا إِرُوحْ غَارْسنْ إِجّنْ زڭْ إِمتِّيننْ، خنِّي أَذْ ثُوبنْ!‘  
\v 31 إِنَّا أَسْ إِبْرَاهِيمْ: ’مَاڒَا نِيثْنِي وَارْ سْڒِينْ غَارْ مُوسَا ذ إِنَابِييّنْ، خنِّي وَارْ زَّايسْ تّْوَاسّْقنْعنْ عَاوذْ، \add عَاذْ\add* خْمِي د غَا إِكَّارْ إِجّنْ جَارْ إِمتِّيننْ!‘ “   
\b  
\b  
\m  
\c 17
\s1 خْ ؤُغكّْوِي غَارْ دّنْبْ ؤُ خْ سْمَاحثْ  
\m
\v 1 إِنَّا يَاسُوع إِ إِمحْضَارنْ نّسْ: ”وَارْ ثْعدّڒْ إِلَا أَذْ إِڒِينْثْ ثْعنْكْرِيفِينْ، مَاشَا ؤُشْثْ خْ ونِّي زِي إِ د غَا يَاسنْثْ! \x ◘ \xo 17:‏1 \xt [مت. 18‏:‏6‏-‏7، 21‏-‏22؛ مك. 9‏:‏42] — مت. 18‏:‏7؛ مك. 9‏:‏42. \x*  
\v 2 إِحْڒَا أَسْ أَذْ خَاسْ ثتّْوَاڭّْ إِشْثْ ن ثصْضَارْثْ ن ثْسِيرْثْ ثذْقڒْ غَارْ يِيرِي نّسْ ؤُشَا أَذْ إِمّنْضَارْ ذِي ڒبْحَارْ خْ مِينِّي غَا إِسّنْقَارْضْ إِجّنْ زڭْ إِمژْيَاننْ-أَ.  
\v 3 حْضَامْ إِخفْ نْومْ. مَاڒَا إِخْضَا ؤُمَاشْ، وبّخْ إِ-ث، ؤُ مَاڒَا إِثُوبْ، سَامْحْ أَسْ. \x ◘ \xo 17:‏3 \xt لَاوِي 19‏:‏17؛ أَوڒن. 17‏:‏10؛ مت. 18‏:‏15؛ يَاع. 5‏:‏19. \x*  
\v 4 مَاڒَا إِخْضَا أَكِيذكْ سبْعَا ن ثْوَاڒَاوِينْ ذڭْ إِجّْ ن وَاسّْ ؤُشَا إِذْوڒْ-د غَاركْ سبْعَا ن ثْوَاڒَاوِينْ، إِقَّارْ: ’أَقَا ثُوبغْ!‘، إِتّْخصَّا أَذْ أَسْ ثْسَامْحذْ.“ \x ◘ \xo 17:‏4 \xt مت. 18‏:‏21. \x*   
\b  
\m  
\s1 أَمذْيَا ن ثْحبُّوشْثْ ن زَّارِيعثْ ن ؤُخرْذلْ  
\m
\v 5 نَّانْ رُّوسُولْ: ”\add أَ\add* سِيذِيثْنغْ، أَرْنِي أَنغْ لْ-إِيمَانْ نّغْ!“  
\v 6 نتَّا إِنَّا أَسنْ: ”مْڒِي ثُوغَا ذَايْومْ لْ-إِيمَانْ أَمْ يِيشْثْ ن ثْحبُّوشْثْ ن زَّارِيعثْ ن ؤُخرْذلْ ؤُشَا أَذْ ثِينِيمْ إِ ثْشجَّارْثْ-أَ ن ثُوثْ: ’ثْوَاقْڒعْ زڭْ إِژوْرَانْ نّمْ، ثْوَاژُّو ذِي ڒبْحَارْ!‘، خنِّي أَذْ أَومْ ثطَّاعْ.“ \x ◘ \xo 17:‏6 \xt مت. 17‏:‏20؛ 21‏:‏21؛ مك. 11‏:‏23. \x*   
\b  
\m  
\s1 أَمذْيَا ن بَابْ ذ ؤُمْسخَّارْ نّسْ  
\m
\v 7 مَانْ ونْ زَّايْومْ إِ غَارْ إِدْجَا ؤُمْسخَّارْ إِشَارّزْ نِيغْ يَاركّْوسْ ؤُدْجِي، أَذْ أَسْ يِينِي ذغْيَا مَاڒَا إِعْقبْ-د زڭْ إِيَّارْ ؤُشَا يُوذفْ \add غَارْ ثَادَّارْثْ\add*: ’قَارّبْ-د، ثقِّيمذْ \add غَارْ طَّابْڒَا\add*‘؟  
\v 8 مَا وَارْ ذ أَسْ إِقَّارْ: ’سوْجذْ مِينْ غَا مُّونسْوغْ، ثْبيْسذْ، ثْسخَّارذْ خَافِي أَڒْ غَا شّغْ، سْوغْ. أَوَارْنِي مَانْ أَيَا أَذْ ثشّذْ، أَذْ ثسْوذْ ؤُڒَا ذ شكْ‘؟  
\v 9 مَا أَذْ إِكْسِي ؤُمْسخَّارْ نِّي أَقَاذِي، مِينْزِي نتَّا إِڭَّا مِينْ ذ أَسْ إِتّْوَانَّانْ أَذْ ث يڭّْ؟ إِتّْغِيڒْ أَيِي، لَّا!  
\v 10 أَمُّو ؤُڒَا ذ كنِّيوْ، خْمِي ثڭِّيمْ مَارَّا مِينْ ذ أَومْ يُومُورنْ، \add إِتّْخصَّا\add* أَذْ ثِينِيمْ: ’أَقَا نشِّينْ ذ إِمْسخَّارنْ وَارْ إِنفّْعنْ، مِينْزِي نڭَّا مِينْ ثُوغَا خَانغْ‘.“   
\b  
\m  
\s1 أَسْڭنْفِي نعشْرَا إِ ذِي إِدْجَا ڒْبَارْصْ  
\m
\v 11 رَامِي إِرُوحْ يَاسُوع غَارْ ؤُرْشَالِيمْ إِشُوقْ ذِي ڒْوسْطْ \add ن ثمُّورْثْ\add* ن إِسَامَارِييّنْ، ثنِّي إِدْجَانْ زَّاثْ ن لْجَالِيلْ.  
\v 12 أَڒَامِي ثُوغَا إِتَّاذفْ غَارْ إِجّْ ن ذْشَارْ، ڒْقَانْ ثعشْرَا ن يرْيَازنْ ذَايْسنْ ڒْبَارْصْ، قِّيمنْ بدّنْ غَارْ ڒَاڭّْوَاجْ.  
\v 13 سّْڭعّْذنْ ثْمِيجَّا نْسنْ، نَّانْ: ”\add أَ\add* أَمْسڒْمَاذْ نّغْ، يَاسُوع، أَرْحمْ أَنغْ!‘“  
\v 14 ؤُمِي ذَايْسنْ إِخْزَارْ، إِنَّا أَسنْ: ”رُوحمْ، سشْنمْ إِخفْ نْومْ إِ إِكهَّاننْ!“ خنِّي إِمْسَارْ، أَمْ ڭُّورنْ نِيثْنِي، أَقَا تّْوَاسِّيزذْڭنْ. \x ◘ \xo 17:‏14 \xt لَاوِي 13‏:‏2؛ 14‏:‏2؛ مت. 8‏:‏4؛ لك. 5‏:‏14. \x*   
\m
\v 15 إِجّنْ زَّايْسنْ إِعْقبْ، ؤُمِي إِژْرَا بلِّي إِڭّنْفَا، ؤُشَا إِسّمْغَارَا ذِي أَربِّي س ثْمِيجَّا ثجْهذْ.  
\v 16 إِوْضَا خْ ؤُغمْبُوبْ نّسْ غَارْ إِضَارنْ ن يَاسُوع، إِقَاذَا ث. وَا ثُوغَا ذ إِجّْ ن \add ورْيَازْ\add* أَسَامِيرِي.  
\v 17 إِطّفْ يَاسُوع ذڭْ وَاوَاڒْ، إِنَّا: ”مَا وَارْ تّْوَاسِّيزذْڭنْ مَارَّا سعشْرَا؟ مَانِي قِّيمنْ ثسْعَا؟  
\v 18 مَايمِّي جِّينْ نِيثْنِي أَذْ د-أَسنْ حِيمَا أَذْ سّْعُودْجنْ أَربِّي، مْغِيرْ وَانِيثَا وَاهَا، ونِّي إِدْجَانْ زڭْ إِجّْ نْ ڒْڭنْسْ ذ أَبَارَّانِي؟“ \x ◘ \xo 17:‏18 \xt لك. 4‏:‏25‏-‏27\x*  
\v 19 خنِّي إِنَّا أَسْ: ”كَّارْ، ثْرُوحذْ، أَقَا لْ-إِيمَانْ نّشْ إِسّنْجمْ إِ شكْ!“   
\b  
\m  
\s1 ثَاوَاسِيثْ ن ثْڭلْذِيثْ ن أَربِّي  
\m
\v 20 ؤُمِي إِفَارِيسِييّنْ سّقْسَانْ يَاسُوع: ”مڒْمِي إِ د غَا ثَاسْ ثْڭلْذِيثْ ن أَربِّي؟“، يَارَّا-د خَاسنْ، إِنَّا: ”وَارْ د-ثتِّيسْ ثْڭلْذِيثْ ن أَربِّي س يِيجّْ ن وُوذمْ إِتّْوَاسّْشَاننْ. \x ◘ \xo 17:‏20 \xt [مت. 24‏:‏23‏-‏28، 37‏-‏41] \x*  
\v 21 وَارْ قَّارنْ: ’أَقَا-ت ذَا!‘، نِيغْ: ’أَقَا-ت ذِيهَا!‘، مِينْزِي ثَاڭلْذِيثْ ن أَربِّي أَقَا-ت ذِي \add شَا\add* زَّايْومْ.“ \x ◘ \xo 17:‏21 \xt مت. 24‏:‏23؛ مك. 13‏:‏21؛ لك. 21‏:‏7، 8. \x*  
\v 22 إِنَّا إِ إِمحْضَارنْ نّسْ: ”أَذْ د-أَوْضنْ وُوسَّانْ إِ ذِي إِ غَا ثخْسمْ أَذْ ثْژَارمْ إِجّْ ن وَاسّْ وَاهَا زڭْ وُوسَّانْ ن مِّيسْ ن بْنَاذمْ، \add مَاشَا\add* كنِّيوْ وَارْ \add ث\add* ثْژَارّمْ.  
\v 23 مَاڒَا نَّانْ أَومْ: ’أَقَا-ث ذَا!‘ نِيغْ: ’أَقَا-ث ذِيهَا!‘، وَارْ ذِينْ تّْرِيحمْ. \x ◘ \xo 17:‏23 \xt مت. 24‏:‏23؛ مك. 13‏:‏21. \x*  
\v 24 مِينْزِي أَمْ مَامّشْ إِشَّاثْ وَاسَّامْ زِي طَّارْفْ سَاذُو ؤُجنَّا غَارْ طَّارْفْ نّغْنِي سَاذُو ؤُجنَّا، أَمُّو عَاوذْ أَذْ يِيڒِي مِّيسْ ن بْنَاذمْ ذڭْ وَاسّْ نّسْ.  
\v 25 مَاشَا إِتّْخصَّا أَسْ أَمزْوَارُو أَذْ إِودّبْ أَطَّاسْ ؤُشَا أَذْ إِتّْوَامّنْضَارْ زِي جِّيڒْ-أَ! \x ◘ \xo 17:‏25 \xt مت. 16‏:‏21؛ 17‏:‏22؛ 20‏:‏18؛ مك. 8‏:‏31؛ 9‏:‏31؛ 10‏:‏33؛ لك. 9‏:‏22؛ 18‏:‏31؛ 24‏:‏6، 7\x*   
\m
\v 26 أَمْ مَامّشْ ثُوغَا ذڭْ وُوسَّانْ ن نُوحْ، أَمُّو إِ غَا يِيڒِي \add عَاوذْ\add* ذڭْ وُوسَّانْ ن مِّيسْ ن بْنَاذمْ. \x ◘ \xo 17:‏26 \xt أَمز. 6‏:‏2؛ 7‏:‏7؛ مت. 24‏:‏37، 38؛ 1 بُط. 3‏:‏20. \x*  
\v 27 ثُوغَا تّتّنْ، سسّنْ، تَّاوْينْ ثِيمْغَارِينْ، سْمدْجَاشنْ \add ثِيمْغَارِينْ\add* إِ يرْيَازنْ أَڒْ أَسّْ إِ ذِي يُوذفْ نُوحْ غَارْ ؤُغَارَّابُو ؤُشَا يُوسَا-د طُّوفَانْ، إِسّْهلّكْ إِ-ثنْ مَارَّا.  
\v 28 أَمُّو ثُوغَا إِمْسَارْ عَاوذْ ذڭْ وُوسَّانْ ن لُوثْ. ثُوغَا تّتّنْ، سسّنْ، سَّاغنْ، زّْنُوزَانْ، تّژُّونْ، بنَّانْ.  
\v 29 مَاشَا ذڭْ وَاسّْ إِ ذِي د-إِفّغْ لُوثْ زِي سَاذُومْ، إِجَّا سِيذِي أَذْ د-ثوْضَا ثْمسِّي ذ ڒشْبَاريّثْ زڭْ ؤُجنَّا، إِثحَّا ثنْ مَارَّا. \x ◘ \xo 17:‏29 \xt أَمز. 19‏:‏24؛ أَعَوذ. 29‏:‏22؛ إِشا. 13‏:‏19؛ إِرْم. 50‏:‏40؛ حُوش. 11‏:‏8؛ عَام. 4‏:‏11؛ يَاه. 7. \x*   
\m
\v 30 أَمُّو إِ غَا يِيڒِي ذڭْ وَاسّْ إِ ذِي إِ غَا إِتّْوَاسَّارْڭبْ مِّيسْ ن بْنَاذمْ.  
\v 31 ونِّي إِدْجَانْ خْ ثْزقَّا ذڭْ وَاسّْ نِّي ؤُ ڒْقشّْ نّسْ أَقَا-ث ذِي ثَادَّارْثْ، وَارْ د-إِهكّْوِي شَا مَاحنْذْ أَذْ ث إِكْسِي. أَمُّو ؤُڒَا ذ ونِّي إِدْجَانْ ذڭْ إِيَّارْ، وَارْ د-إِتّْعِيقِيبْ شَا.  
\v 32 عقْڒمْ خْ ثمْغَارْثْ ن لُوثْ! \x ◘ \xo 17:‏32 \xt أَمز. 19‏:‏15‏-‏17، 26. \x*  
\v 33 ونِّي يَارزُّونْ أَذْ إِسّنْجمْ ثُوذَارْثْ نّسْ، أَذْ ت إِخْسَارْ، ؤُ ونِّي ت إِ غَا إِخْسَارنْ، أَذْ ت إِسّنْجمْ. \x ◘ \xo 17:‏33 \xt مت. 10‏:‏39؛ 16‏:‏25؛ مك. 8‏:‏35؛ لك. 9‏:‏24؛ يُوح. 12‏:‏25. \x*  
\v 34 أَذْ أَومْ إِنِيغْ، أَقَا ذِي دْجِيڒثْ نِّي أَذْ ذِينْ إِڒِينْ ثْنَاينْ خْ إِشْثْ ن ثَاسُّوثْ: إِجّنْ أَذْ إِتّْوَاكْسِي، ونّغْنِي أَذْ إِتّْوَاجّْ. \x ◘ \xo 17:‏34 \xt مت. 24‏:‏40،41؛ 1 تس. 4‏:‏17. \x*  
\v 35 أَذْ ذِينْ إِڒِينْثْ ثْنَاينْ ن ثمْغَارِينْ حَارّْينْثْ جْمِيعْ، إِشْثْ أَذْ ثتّْوَاكْسِي، ثنّغْنِي أَذْ ثتّْوَاجّْ.  
\v 36 أَذْ ذِينْ إِڒِينْ ثْنَاينْ ذڭْ إِيَّارْ: إِجّنْ أَذْ إِتّْوَاكْسِي، ونّغْنِي أَذْ إِتّْوَاجّْ.“   
\m
\v 37 أَرِّينْ-ذ، نَّانْ أَسْ: ”مَانِي، أَ سِيذِيثْنغْ؟“ نتَّا إِنَّا أَسنْ: ”مَانِي ثدْجَا أَرِّيمثْ ذِينْ إِتّْمُونَانْ عَاوذْ إِڭِيذَارنْ.“ \x ◘ \xo 17:‏37 \xt أَيُوبْ 39‏:‏30؛ مت. 24‏:‏28. \x*   
\b  
\b  
\m  
\c 18
\s1 أَمذْيَا ن ثَاجَّاتْشْ ذ ڒْقَاضِي  
\m
\v 1 إِنَّا أَسنْ عَاوذْ إِجّْ ن ؤُمذْيَا بلِّي أَقَا إِتّْخصَّا أَسنْ أَذْ ژَّادْجنْ ذِي كُوڒْ ڒْوقْثْ بْڒَا أَملِّي. \x ◘ \xo 18:‏1 \xt رُوم. 12‏:‏12؛ أَفا. 6‏:‏18؛ كُول. 4‏:‏2؛ 1 تس. 5‏:‏17. \x*   
\m
\v 2 ”ثُوغَا ذڭْ إِشْثْ ن ثنْذِينْثْ إِجّْ ن ڒْقَاضِي وَارْ إِتّڭّْوذْ شَا أَربِّي، وَارْ إِتّْوقَّارْ بْنَاذمْ.  
\v 3 إِشْثْ ن ثَاجَّاتْشْ ذِي ثنْذِينْثْ نِّي ثُوسَا-د غَارسْ، ثنَّا أَسْ: ’أوْشْ أَيِي ثَاسْغَارْثْ إِنُو خْ وغْرِيمْ إِنُو!‘  
\v 4 أَطَّاسْ إِ إِكَّا ثُوغَا يُوڭِي. خنِّي إِنَّا ذڭْ إِخفْ نّسْ: ’نشّْ زعْمَا وَارْ تّڭّْوذغْ شَا أَربِّي ؤُ وَارْ تّْوقِّيرغْ بْنَاذمْ،  
\v 5 قَاعْ أَمُّو، مِينْزِي ثَاجَّاتْشْ-أَ ثْهكّْوڒْ أَيِي \add بْڒَا قطُّو\add*، أَذْ أَسْ وْشغْ ثَاسْغَارْثْ نّسْ، حِيمَا وَارْ د-ثتّْعِيقِّيبْ ڒبْذَا ؤُشَا أَذْ أَيِي ثَارْژْ أَزدْجِيفْ.‘ “   
\m
\v 6 سِيذِيثْنغْ إِنَّا: ”سْڒمْ مِينْ إِقَّارْ ڒْقَاضِي أَغشَّاشْ!  
\v 7 مَا وَارْ إِتِّيشْ أَربِّي ثَاسْغَارْثْ كْثَارْ أَطَّاسْ إِ يِينِّي زَّايسْ إِتّْوَافَارْزنْ، إِنِّي غَارسْ د-إِسْغُويُّونْ أَسّْ ذ دْجِيڒثْ؟ مَا وَارْ إِتّڭّْ نتَّا \add كْثَارْ أَطَّاسْ\add* س تَّاسِيعْ ن ڒْخَاضَارْ خَاسنْ؟ \x ◘ \xo 18:‏7 \xt أَسَا. 6‏:‏10. \x*  
\v 8 أَذْ أَومْ إِنِيغْ، أَقَا أَذْ أَسنْ إِوْشْ ثَاسْغَارْثْ ذغْيَا. مَاشَا خْمِي د غَا إِعْقبْ مِّيسْ ن بْنَاذمْ، مَا أَذْ يَافْ لْ-إِيمَانْ ذِي ثمُّورْثْ؟“   
\b  
\m  
\s1 أَمذْيَا ن ؤُفَارِيسِي ذ إِجّْ ن بُو-ضَّارِيبَا  
\m
\v 9 إِنَّا أَمذْيَا-يَا إِ إِوْذَانْ نِّي غَارْ ثدْجَا تِّيقّثْ ذڭْ يِيخفْ نْسنْ أَقَا أَثنْ ذ إِمْسڭَّاذنْ ؤُ سّحْقَارَانْ إِنّغْنِي مَارَّا.  
\v 10 ”ڭَاعّْذنْ ثْنَاينْ ن إِوْذَانْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ، حِيمَا أَذْ ژَّادْجنْ، إِجّنْ ذ أَفَارِيسِي ؤُ ونّغْنِي ذ إِجّْ ن بُو-ضَّارِيبَا.  
\v 11 إِبدّْ ؤُفَارِيسِي، إِتّْژَادْجْ أَكْ-ذ يِيخفْ نّسْ: ’\add أَ\add* أَربِّي، تّْقَاذِيغْ شكْ ؤُمِي وَارْ دْجِيغْ شَا أَمْ إِوْذَانْ نّغْنِي: إِغشَّاشنْ ذ يِينِّي إِحصَّارنْ ذ يِينِّي إِزنَّانْ، ؤُڒَا أَمْ بُو-ضَّارِيبَا وَانِيثَا. \x ◘ \xo 18:‏11 \xt إِشا. 1‏:‏15؛ 58‏:‏2؛ أَسَا. 3‏:‏17، 18. \x*  
\v 12 نشّْ تّْژُومِّيغْ ثْنَاينْ ن إِمُورنْ ذِي سِّيمَانَا، تِّيشغْ ڒعْشُورْ زِي مَارَّا مِينْ غَارِي إِدْجَانْ ذ أَڭْڒَا.‘  
\v 13 مَاشَا بُو-ضَّارِيبَا ونِّي إِبدّنْ غَارْ ڒَاڭّْوَاجْ، وَارْ إِزْعِيمْ ؤُڒَا أَذْ إِسِّيڒِي ثِيطَّاوِينْ نّسْ غَارْ ؤُجنَّا، مَاشَا إِوْثَا إِخفْ نّسْ غَارْ إِذْمَارنْ، إِنَّا: ’\add أَ\add* أَربِّي، أَرْحمْ أَيِي، أَقَا نشّْ ذ أَمذْنُوبْ!‘  
\v 14 نشّْ أَذْ أَومْ إِنِيغْ، أَقَا وَانِيثَا أَذْ يِيڒِي إِتّْوَاسڭّذْ س وَاطَّاسْ خْ ؤُفَارِيسِي نِّي ؤُمِي د-إِهْوَا غَارْ ثَادَّارْثْ نّسْ. مِينْزِي مَارَّا ونِّي إِ غَا إِسُّوعْڒَانْ إِخفْ نّسْ أَذْ إِتّْوَاسّْوَاضعْ، ؤُ ونِّي إِ غَا إِسّْوَاضْعنْ إِخفْ نّسْ أَذْ إِتّْوَاسُّوعْڒَا.“ \x ◘ \xo 18:‏14 \xt أَيُوبْ 22‏:‏29؛ أَوڒن. 29‏:‏23؛ مت. 23‏:‏12؛ لك. 14‏:‏11؛ يَاع. 4‏:‏6، 10؛ 1 بُط. 5‏:‏5. \x*   
\b  
\m  
\s1 يَاسُوع ذ إِحنْجِيرنْ  
\m
\v 15 إِوْينْ أَسْ-د إِحنْجِيرنْ إِمژْيَاننْ حِيمَا أَذْ ثنْ إِسْڒُوفْ. ؤُمِي ثنْ ژْرِينْ إِمحْضَارنْ، وبّْخنْ ثنْ. \x ◘ \xo 18:‏15 \xt [مت. 19‏:‏13‏-‏15؛ مك. 10‏:‏13‏-‏16] — مت. 19‏:‏13؛ مك. 10‏:‏13. \x*  
\v 16 مَاشَا يَاسُوع إِڒَاغَا خَاسنْ، إِنَّا أَسنْ: ”جّمْ إِحنْجِيرنْ أَذْ غَارِي د-أَسنْ، وَارْ ثنْ تّطّْفمْ، مِينْزِي ثَاڭلْذِيثْ ن إِجنْوَانْ إِ يِينِّي أَمْ يِينَا. \x ◘ \xo 18:‏16 \xt مت. 18‏:‏3؛ 19‏:‏14؛ 1 كُور. 14‏:‏20؛ 1 بُط. 2‏:‏2. \x*  
\v 17 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: ونِّي وَارْ إِقْبِيڒنْ ثَاڭلْذِيثْ ن أَربِّي أَمْ ؤُحنْجِيرْ وَارْ ت إِتِّيذفْعمَّارْصْ!“   
\b  
\m  
\s1 أَسقْسِي ن إِجّْ ن بَابْ ن وَاڭْڒَا إِ يَاسُوع  
\m
\v 18 إِسّقْسَا ث إِجّْ ن ؤُمقّْرَانْ، إِنَّا أَسْ: ”\add أَ\add* أَمْسغَّارْ أَصبْحَانْ، مِينْ غَا ڭّغْ، حِيمَا أَذْ وَارْثغْ ثُوذَارْثْ إِتّْذُومَانْ؟“ \x ◘ \xo 18:‏18 \xt [مت. 19‏:‏16‏-‏30؛ مك. 10‏:‏17‏-‏31] — مت. 19‏:‏16؛ مك. 10‏:‏17. \x*  
\v 19 إِنَّا أَسْ يَاسُوع: ”مَايمِّي ذ أَيِي ثْڒَاغِيذْ س ’أَصبْحَانْ‘؟ ؤُڒَا ذ إِجّْ وَارْ إِدْجِي ذ أَصبْحَانْ مْغِيرْ إِجّنْ، أَقَا-ث ذ أَربِّي.  
\v 20 شكْ ثسّْنذْ ثِيوصَّا: وَارْ زنِّي، وَارْ نقّْ، وَارْ تِّيشَارْ، وَارْ شهّذْ س ژُورْ، وقَّارْ بَابَاشْ ذ يمَّاشْ!“ \x ◘ \xo 18:‏20 \xt ؤُف. 20‏:‏12‏-‏16؛ أَعَوذ. 5‏:‏17‏-‏20؛ رُوم. 13‏:‏9؛ أَفا. 6‏:‏2؛ كُول. 3‏:‏20. \x*  
\v 21 إِنَّا أَسْ: ”أَقَا مَارَّا ثِينَا حْضِيغْ ثنْثْ زِي ثمْژِي إِنُو.“  
\v 22 ؤُمِي إِسْڒَا يَاسُوع أَيَا، إِنَّا أَسْ: ”إِشْثْ ثقِّيمْ أَشْ. ؤُيُورْ، زنْزْ مَارَّا مِينْ غَاركْ، فَارْقْ إِ-ث خْ إِمزْڒَاضْ ؤُشَا أَذْ غَاركْ يِيڒِي ڒْكنْزْ ذڭْ إِجنْوَانْ، \add خنِّي\add* ضْفَارْ أَيِي-د.“ \x ◘ \xo 18:‏22 \xt مت. 6‏:‏19؛ 19‏:‏21؛ 1 تِيم. 6‏:‏19. \x*   
\m
\v 23 ؤُمِي إِسْڒَا مَانْ أَيَا، إِشْضنْ مِينْزِي ثُوغَا-ث ذ بَابْ ن وَاڭْڒَا أَمقّْرَانْ.  
\v 24 ؤُمِي إِژْرَا يَاسُوع بلِّي نتَّا إِشْضنْ، إِنَّا: ”مَامّشْ يوْعَارْ خْ أَيْثْبَابْ ن وَاڭْڒَا مَاحنْذْ أَذْ د-أَذْفنْ غَارْ ثْڭلْذِيثْ ن أَربِّي. \x ◘ \xo 18:‏24 \xt أَوڒن. 11‏:‏28؛ مت. 19‏:‏23؛ مك. 10‏:‏23. \x*  
\v 25 مِينْزِي أَذَافْ ن وڒْغمْ زِي ثِيطّْ ن ثْسِينفْثْ إِهْونْ خْ وَاذَافْ ن بَابْ ن وَاڭْڒَا غَارْ ثْڭلْذِيثْ ن أَربِّي.“  
\v 26 إِنِّي ثُوغَا إِتّسْڒَانْ أَيَا، نَّانْ: ”وِي إِزمَّارنْ \add خنِّي\add* أَذْ إِتّْوَاسّنْجمْ؟“  
\v 27 يَاسُوع إِنَّا: ”مِينْ وَارْ إِزمَّارنْ أَذْ يِيڒِي غَارْ إِوْذَانْ، غَارْ أَربِّي إِزمَّارْ أَذْ يِيڒِي.“ \x ◘ \xo 18:‏27 \xt أَيُوبْ 42‏:‏2؛ إِرْم. 32‏:‏17؛ زَاك. 8‏:‏6؛ لك. 1‏:‏37. \x*   
\b  
\m  
\s1 ڒْمُونثْ ن وضْفَارْ ن يَاسُوع  
\m
\v 28 إِنَّا أَسنْ بُوطْرُوسْ: ”أَقَا نشِّينْ نجَّا كُوڒْشِي ؤُشَا نضْفَارْ إِ شكْ.“ \x ◘ \xo 18:‏28 \xt مت. 4‏:‏20؛ 19‏:‏27؛ مك. 10‏:‏28؛ لك. 5‏:‏11. \x*  
\v 29 يَاسُوع إِنَّا أَسْ: ”س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، وَارْ ذِينْ ؤُڒَا ذ إِجّْ إِ إِتّجِّينْ ثَادَّارْثْ نِيغْ لْوَالِيذِينْ نِيغْ ثَاوْمَاثْ، نِيغْ ثَامْغَارْثْ نِيغْ ثَارَّاوْثْ ذِي طّْوعْ ن ثْڭلْذِيثْ ن أَربِّي، \x ◘ \xo 18:‏29 \xt أَعَوذ. 33‏:‏9. \x*  
\v 30 إِ وَارْ إِكْسِينْ أَضفُّوسْ خْ ؤُضفُّوسْ ن ثْسقَّارْ ذِي ڒْوقْثْ-أَ، ؤُشَا ذِي زّْمَانْ إِ د غَا يَاسنْ \add أَذْ إِكْسِي\add* ثُوذَارْثْ إِتّْذُومَانْ.“ \x ◘ \xo 18:‏30 \xt أَيُوبْ 42‏:‏12. \x*   
\b  
\m  
\s1 يَاسُوع إِسَّاوَاڒْ خْ ڒْموْثْ ذ ثْنُوكْرَا نّسْ إِ ثْوَاڒَا وِيسّْ ثْڒَاثَا  
\m
\v 31 يَاسُوع إِكْسِي ثنْعَاشْ \add ن رُّوسُولْ\add* نّسْ غَارسْ، إِنَّا أَسنْ: ”أَذْ نْڭعّذْ غَارْ ؤُرْشَالِيمْ ؤُشَا مَارَّا مِينْ يُورَانْ س ؤُفُوسْ ن إِنَابِييّنْ خْ مِّيسْ ن بْنَاذمْ أَذْ إِتّْوَاقْفڒْ. \x ◘ \xo 18:‏31 \xt [مت. 20‏:‏17‏-‏19؛ مك. 10‏:‏32‏-‏34] — إِزهد. 22‏:‏7؛ إِشا. 53‏:‏7؛ مت. 16‏:‏21؛ 17‏:‏22؛ 20‏:‏17؛ مك. 8‏:‏31؛ 9‏:‏31؛ 10‏:‏32؛ لك. 9‏:‏22؛ 24‏:‏7. \x*  
\v 32 مِينْزِي نتَّا أَذْ إِتّْوَاسلّمْ إِ ڒڭْنُوسْ، ؤُشَا أَذْ زَّايسْ سْثهْزَانْ، أَذْ خَاسْ سُّوسْفنْ خْ ؤُغمْبُوبْ نّسْ، \x ◘ \xo 18:‏32 \xt مت. 27‏:‏2؛ لك. 23‏:‏1؛ يُوح. 18‏:‏28؛ ڒخ. 3‏:‏13. \x*  
\v 33 أَذْ ث هتّْكنْ س ؤُركُّوضْ، أَذْ ث سّحْقَارنْ، أَذْ ث نْغنْ ؤُشَا ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا أَذْ د-إِكَّارْ.“  
\v 34 نِيثْنِي وَارْ فْهِيمنْ وَالُو زِي مَانْ أَيَا. ثُوغَا أَوَاڒْ-أَ إِوْعَارْ خَاسنْ، ؤُ نِيثْنِي وَارْ فْهِيمنْ مِينْ ذ أَسنْ إِتّْوَانَّانْ.   
\b  
\m  
\s1 أَسْڭنْفِي ن إِجّْ ن ؤُذَارْغَاڒْ  
\m
\v 35 أَڒَامِي د-قَارّْبنْ غَارْ أَرِيحَا ثُوغَا إِجّْ ن ؤُذَارْغَاڒْ إِقِّيمْ ذڭْ وبْرِيذْ، إِتّتَّارْ. \x ◘ \xo 18:‏35 \xt [مت. 20‏:‏29‏-‏34؛ مك. 10‏:‏46‏-‏52] — مت. 20‏:‏29؛ مك. 10‏:‏46. \x*  
\v 36 ڒَامِي إِسْڒَا إِ ڒْحسّْ ن ڒْغَاشِي إِعْذُو، إِسّقْسَا: ”مَانْ أَيَا؟“  
\v 37 نَّانْ أَسْ: ”يشُّو نَّاصِيرِي إِعدُّو.“  
\v 38 إِڒَاغَا، إِنَّا: ”\add أَ\add* يَاسُوع، \add أَ\add* مِّيسْ ن ذَاوُوذْ، أَرْحمْ أَيِي!“  
\v 39 إِنِّي ثُوغَا إِڭُّورنْ غَارْ زَّاثْ ن يَاسُوع، وبّْخنْ ث مَاحنْذْ أَذْ إِسْقَارْ، مَاشَا نتَّا إِبْذَا إِتّْڒَاغَا س جّهْذْ كْثَارْ: ”\add أَ\add* مِّيسْ ن ذَاوُوذْ، أَرْحمْ أَيِي!“  
\v 40 إِبدّْ يَاسُوع ؤُشَا يُومُورْ أَذْ ث-إِ-د-أَوْينْ غَارسْ. ؤُمِي د غَارسْ إِقَارّبْ، إِسّقْسَا ث،  
\v 41 إِنَّا أَسْ: ”مِينْ ثخْسذْ أَذْ أَشْ ث ڭّغْ؟“ إِنَّا: ”\add أَ\add* سِيذِي، خْسغْ أَذْ ذوْڒغْ تّْوَاڒِيغْ!“  
\v 42 إِنَّا أَسْ يَاسُوع: ”ثْوَاڒَا، أَقَا لْ-إِيمَانْ نّشْ إِسّْڭنْفَا شكْ.“  
\v 43 ڒخْذنِّي إِتّْوَاڒَا ؤُشَا إِضْفَارْ إِ-ث، إِسّمْغَارَا ذِي أَربِّي. مَارَّا إِوْذَانْ إِ إِژْرِينْ مَانْ أَيَا، سّْعُودْجنْ أَربِّي.   
\b  
\b  
\m  
\c 19
\s1 يَاسُوع ذ زَاكَّايُو  
\m
\v 1 ؤُمِي يُوذفْ يَاسُوع غَارْ أَرِيحَا، إِشُوقْ \add ثنْذِينْثْ نِّي\add*،  
\v 2 ثُوغَا ذِينْ إِجّْ ن ورْيَازْ قَّارنْ أَسْ زَاكَّايُو. وَانِيثَا ثُوغَا ذ بَابْ ن وَاڭْڒَا ؤُڒَا ذ أَمقّْرَانْ ن أَيْثْ ن ضَّارِيبَا.  
\v 3 نتَّا ثُوغَا يَارزُّو أَذْ إِژَارْ يَاسُوع ذ مِينْ إِعْنَا، \add مَاشَا\add* وَارْ إِزمَّارْ س سِّيبّثْ ن ڒْغَاشِي، مِينْزِي ثُوغَا زَاكَّايُو ذ أَقُوضَاضْ ن ثِيذِّي.  
\v 4 \add س ؤُينِّي\add* إِزْوَارْ إِ يَاسُوع ؤُشَا إِڭعّذْ خْ إِجّْ ن وَارْثُو نْ ڒخْڒَا، حِيمَا أَذْ ث إِژَارْ، مِينْزِي ثُوغَا نتَّا إِڭَّا أَذْ د-يكّْ سّنِّي.  
\v 5 ؤُمِي د-يُوسَا يَاسُوع غَارْ ومْشَانْ نِّي، إِخْزَارْ غَارْ ؤُجنَّا، إِبَارْقْ إِ-ث. إِنَّا أَسْ: ”\add أَ\add* زَاكَّايُو، قدْجقْ-د، هْوَا-د ذغْيَا، مِينْزِي أَسّْ-أَ إِتّْخصَّا أَيِي أَذْ قِّيمغْ ذِي ثَادَّارْثْ نّشْ!“   
\m
\v 6 إِقدْجقْ-د، إِهْوَا-د ذغْيَا ؤُشَا يَارحّبْ زَّايسْ س ڒفْرَاحثْ.  
\v 7 مَارَّا إِنِّي إِژْرِينْ مَانْ أَيَا، بْذَانْ تّْمعْمِيعنْ خَاسْ، نَّانْ: ”أَقَا يُوذفْ غَارْ إِجّْ ن ورْيَازْ ذ أَمذْنُوبْ، حِيمَا أَذْ غَارسْ إِقِّيمْ!“  
\v 8 إِكَّارْ زَاكَّايُو، إِنَّا إِ يَاسُوع: ”خْزَارْ، سِيذِي، أَذْ وْشغْ أَزْينْ ن وَاڭْڒَا إِنُو إِ إِمزْڒَاضْ ؤُ مَارَّا ونِّي زِي كّْسغْ شَا ن ڒْحَاجّثْ س ڒْغشّْ، أَذْ \add أَسْ ث\add* أَرّغْ أَربْعَا ن ثْسقَّارْ!“  
\v 9 إِنَّا أَسْ يَاسُوع: ”أَسّْ-أَ ثِيوضْ-د ثُوذَارْثْ إِ ثَادَّارْثْ-أَ، مِينْزِي ؤُڒَا ذ وَا ذ إِجّْ ن مِّيسْ ن إِبْرَاهِيمْ. \x ◘ \xo 19:‏9 \xt لك. 13‏:‏16. \x*  
\v 10 مِينْزِي مِّيسْ ن بْنَاذمْ يُوسَا-د حِيمَا أَذْ يَارْزُو ؤُ أَذْ إِسّنْجمْ مِينْ إِودَّارنْ.“ \x ◘ \xo 19:‏10 \xt مت. 10‏:‏6؛ 15‏:‏24؛ 18‏:‏11؛ ڒخ. 13‏:‏46. \x*   
\b  
\m  
\s1 أَمذْيَا نعشْرَا ن ڒْوُوزْنَاثْ  
\m
\v 11 ؤُمِي ثُوغَا تّسْڒَانْ أَيَا، يَارْنِي-د عَاوذْ إِجّْ ن ؤُمذْيَا، مِينْزِي إِتّْغِيڒْ أَسنْ، ؤُمِي ثُوغَا د-إِقَارّبْ غَارْ ؤُرْشَالِيمْ، أَقَا ثَاڭلْذِيثْ ن أَربِّي أَذْ د-ثضْهَارْ ذغْيَا. \x ◘ \xo 19:‏11 \xt [مت. 25‏:‏14‏-‏30]\x*  
\v 12 إِنَّا: ”إِجّْ ن بْنَاذمْ زِي ڒجْوَاذْ إِرُوحْ غَارْ إِشْثْ ن ثمُّورْثْ ثِيڭّْوجْ، حِيمَا أَذْ إِطّفْ ثَاڭلْذَا إِ يِيخفْ نّسْ، ؤُشَا \add خنِّي\add* أَذْ د-إِذْوڒْ \add أَوَارْنِي مَانْ أَيَا\add*. \x ◘ \xo 19:‏12 \xt مت. 25‏:‏14؛ مك. 13‏:‏34. \x*  
\v 13 إِڒَاغَا-د إِعشْرَا ن إِمْسخَّارنْ نّسْ ؤُشَا إِوْشَا أَسنْعشْرَا ن ڒْمِينَاثْ ؤُشَا إِنَّا أَسنْ: ’ڭّمْ تِّيجَارَا أَڒْ د غَاعقْبغْ‘.  
\v 14 مَاشَا إِمزْذَاغْ ن ثنْذِينْثْ ثُوغَا شَارّْهنْ ث ؤُشَا سّكّنْ أَوَارْنِي أَسْ إِرقَّاسنْ، نَّانْ: ’وَارْ نخْسْ وَانِيثَا أَذْ يِيڒِي ذ أَجدْجِيذْ خَانغْ!‘   
\m
\v 15 ؤُمِي د-إِعْقبْ أَوَارْنِي ڒَامِي ذ إِكْسِي ثَاڭلْذَا، يُومُورْ مَاحنْذْ أَذْ ڒَاغَانْ إِ إِمْسخَّارنْ نِّي ؤُمِي إِوْشَا نُّوقَارْثْ، حِيمَا أَذْ إِسّنْ أَرْبحْ إِ د-يِيوِي كُوڒْ إِجّنْ ذِي ثْسبَّابْثْ نّسْ.  
\v 16 يُوسَا-د ؤُمزْوَارْ، إِنَّا: ’\add أَ\add* سِيذِي، ڒْمِينَا نّشْ ثِيوِي-دعشْرَا ڒْمِينَاثْ‘.  
\v 17 إِنَّا أَسْ: ’مْلِيحْ شكْ، \add أَ\add* أَمْسخَّارْ أَصبْحَانْ، مِينْزِي ثُوغَا شكْ ذ أَمْثِيقِّي خْ ذْرُوسْ، أَذْ ثِيڒِيذْ ذ أَزدْجِيفْ خْعشْرَا ن ثْندَّامْ.‘  
\v 18 يُوسَا-د ونِّي وِيسّْ ثْنَاينْ، إِنَّا: ’\add أَ\add* سِيذِي، ڒْمِينَا نّشْ ثِيوِي-د خمْسَا ڒْمِينَاثْ.‘  
\v 19 إِنَّا إِ وَانِيثَا عَاوذْ: ’ؤُڒَا ذ شكْ أَذْ ثِيڒِيذْ ذ أَزدْجِيفْ خْ خمْسَا ن ثْندَّامْ!‘   
\m
\v 20 خنِّي يُوسَا-د ونّغْنِي، إِنَّا: ’أَ سِيذِي، خْزَارْ ڒْمِينَا نّشْ إِ ثُوغَا خمّْڒغْ ذڭْ \add إِجّْ ن زِّيفْ ن\add* ڒقْطنْ.  
\v 21 مِينْزِي ڭّْوذغْ زَّايكْ، مِينْزِي شكْ ذ إِجّْ ن بْنَاذمْ ثْقسْحذْ. شكْ ثْكسِّيذْ مِينْ وَارْ ثسّْرُوسِيذْ ؤُ ثْمجَّارذْ مِينْ وَارْ ثْزَارْعذْ!‘  
\v 22 إِنَّا أَسْ: ’س ؤُقمُّومْ نّشْ أَذْ خَاكْ شَارّْعغْ، \add أَ\add* أَمْسخَّارْ أَعفَّانْ! ثسّْنذْ بلِّي نشّْ ذ بْنَاذمْ إِقْسحْ، كسِّيغْ مِينْ وَارْ سّْرُوسِيغْ، مجَّارغْ مِينْ وَارْ زَارْعغْ. \x ◘ \xo 19:‏22 \xt  2 صم. 1‏:‏16؛ مت. 12‏:‏37. \x*  
\v 23 مَايمِّي وَارْ ثسَّارْسذْ \add تّْمنْيَاثْ ن\add* نُّوقَارْثْ إِنُو ذِي ڒْبَانْكُو؟ خنِّي خْمِي د غَا يَاسغْ، أَذْ ثنْثْ كْسِيغْ س لْفَايْذَا.‘  
\v 24 إِنَّا إِ يِينِّي ذِينْ إِبدّنْ أَكِيذسْ: ’كْسِيمْ خَاسْ ڒْمِينَا نّسْ، وْشمْ ت إِ ونِّي غَارْ إِدْجَاعشْرَا ن ڒْمِينَاثْ.‘ “   
\m
\v 25 نَّانْ أَسْ: ’\add أَ\add* سِيذِيثْنغْ، أَقَا غَارسْعشْرَا ن ڒْمِينَاثْ \add عَاذْ\add*؟“  
\v 26 ”نتَّا إِنَّا أَسنْ: ’أَذْ أَومْ إِنِيغْ، بلِّي مَارَّا ونِّي غَارْ إِدْجَا، أَذْ أَسْ إِمّوْشْ، مَاشَا ونِّي وَارْ غَارْ إِدْجِي، أَذْ أَسْ إِتّْوَاكّسْ عَاذْ ؤُڒَا ذ مِينْ غَارسْ. \x ◘ \xo 19:‏26 \xt مت. 13‏:‏12؛ 25‏:‏29؛ مك. 4‏:‏25؛ لك. 8‏:‏18. \x*  
\v 27 مَاشَا ڒْعذْيَانْ إِنُو إِنِّي وَارْ إِخْسنْ أَذْ خَاسنْ ذوْڒغْ ذ أَجدْجِيذْ، أَوْيمْ ثنْ-د ذَانِيثَا ؤُشَا غَارْصمْ أَسنْ زَّاثِي.‘ “   
\b  
\m  
\s1 أَذَافْ ن يَاسُوع غَارْ ؤُرْشَالِيمْ  
\m
\v 28 أَوَارْنِي ڒَامِي إِنَّا يَاسُوع مَانْ أَيَا، إِزْوَارْ أَسنْ ؤُشَا إِڭعّذْ غَارْ ؤُرْشَالِيمْ. \x ◘ \xo 19:‏28 \xt [مت. 21‏:‏1‏-‏11؛ مك. 11‏:‏1‏-‏11؛ يُوح. 12‏:‏12‏-‏19]\x*  
\v 29 أَڒَامِي د-إِقَارّبْ غَارْ بَايْثْ-فَاجِي ذ بَايْثْ-عَانْيَا غَارْ ؤُغزْذِيسْ ن وذْرَارْ ؤُمِي قَّارنْ ’ثَادَّارْثْ ن زِّيثُونْ‘، إِسّكّْ ثْنَاينْ ن إِمحْضَارنْ نّسْ، \x ◘ \xo 19:‏29 \xt مت. 21‏:‏1؛ مك. 11‏:‏1. \x*  
\v 30 إِنَّا أَسنْ: ”رُوحمْ غَارْ ذْشَارْ إِ إِدْجَانْ غَارْ زَّاثْ نْومْ. خْزَارْ، خْمِي ذِينْ إِ غَا ثَاذْفمْ، أَذْ ثَافمْ إِجّْ ن وسْنُوسْ إِقّنْ، وَارْ خَاسْ إِنْيِي ؤُڒَا ذ إِجّْ ن بْنَاذمْ عَاذْ. فسْيمْ أَسْ ؤُشَا أَوْيمْ ث-إِ-د \add ذَا\add*.  
\v 31 مَاڒَا إِسّقْسَا كنِّيوْ شَا ن إِجّنْ: ’مَايمِّي ذ أَسْ ثْفسْيمْ؟‘، أَذْ أَسْ ثِينِيمْ أَمُّو: ’أَقَا سِيذِيثْنغْ إِحْوَاجْ إِ-ث!‘ “   
\m
\v 32 إِنِّي د-إِتّْوَاسّكّنْ رُوحنْ ؤُشَا ؤُفِينْ \add ث\add* أَمْ مَامّشْ ذ أَسنْ إِنَّا.  
\v 33 أَڒَامِي ذ فسْينْ إِ وسْنُوسْ، سّقْسَانْ ثنْ أَيْثْبَابْ نّسْ: ”مَايمِّي ثْفسّْيمْ إِ وسْنُوسْ؟“  
\v 34 نَّانْ أَسنْ: ”أَقَا سِيذِيثْنغْ إِحْوَاجْ إِ-ث!“  
\v 35 ؤُسِينْ-د زَّايسْ غَارْ يَاسُوع، نْضَارنْ أَرُّوضْ نْسنْ خْ وسْنُوسْ، سّنْينْ يَاسُوع خَاسْ. \x ◘ \xo 19:‏35 \xt يُوح. 12‏:‏14. \x*  
\v 36 أَمْ ثُوغَا إِڭُّورْ، سُّونْ نِيثْنِي أَبْرِيذْ س وَارُّوضْ نْسنْ.  
\v 37 ؤُمِي د-إِقَارّبْ غَارْ ثيْسَارْثْ \add ن وذْرَارْ\add* ن ’ثَادَّارْثْ ن زِّيثُونْ‘، إِبْذَا ڒْغَاشِي ن إِمحْضَارنْ مَارَّا أَذْ فَارْحنْ، تّْسبَّاحنْ أَربِّي س إِشْثْ ن ثْمِيجَّا ثجْهذْ أَطَّاسْ خْ سِّيبّثْ ن لْمُوعْجِيزَاثْ ثِيمقّْرَانِينْ نِّي ثُوغَا ژْرِينْ.  
\v 38 نِيثْنِي نَّانْ:  
\b  
\m \qt ”لْبَارَاكَا إِ ؤُجدْجِيذْ إِ د-يُوسِينْ\qt*  
\m \qt س يِيسمْ ن سِيذِي!\qt*  
\m \qt ڒهْنَا ذڭْ ؤُجنَّا\qt*  
\m \qt ذ ؤُعُودْجِي ذِي ڒُوعْڒَا خْ ڒُوعْڒَا قَاعْ!“\qt* \x ◘ \xo 19:‏38 \xt إِزهد. 118‏:‏26؛ لك. 2‏:‏14؛ أَفا. 2‏:‏14. \x*   
\b  
\m
\v 39 مَاشَا شَا ن إِفَارِيسِييّنْ جَارْ ڒْغَاشِي نَّانْ أَسْ: ”\add أَ\add* أَمْسڒْمَاذْ إِنُو، وبّخْ إِمحْضَارنْ نّشْ!“  
\v 40 إِنَّا أَسنْ: ”أَذْ أَومْ إِنِيغْ، مَاڒَا سْقَارنْ إِنَا، خنِّي أَذْ ڒَاغَانْ يژْرَا.“ \x ◘ \xo 19:‏40 \xt حَاب. 2‏:‏11. \x*  
\v 41 أَڒَامِي د-إِقَارّبْ ؤُشَا إِژْرَا ثَانْذِينْثْ، إِرُو خَاسْ،  
\v 42 إِنَّا: ”مْڒِي ثْفهْمذْ مِينْ ذ أَمْ د غَا يَاوْينْ ڒهْنَا نّمْ، عَاذْ ذڭْ وَاسّْ-أَ نّمْ! مَاشَا ڒخُّو أَقَا مَانْ أَيَا إِنُوفَّارْ خْ ثِيطَّاوِينْ نّمْ.  
\v 43 أَقَا أَذْ غَارمْ د-أَسنْ وُوسَّانْ إِ ذ أَمْ د غَا قُووَّارنْ ڒْعذْيَانْ نّمْ ؤُ أَذْ شمْ حْصَارنْ زِي مَارَّا إِغزْذِيسنْ.  
\v 44 أَذْ شمْ أَردّْدْجنْ، شمْ ذ ثَارْوَا نّمْ أَكِيذمْ، وَارْ ذَايمْ تّجِّينْ أَژْرُو إِبدّْ خْ وژْرُو نّغْنِي، مِينْزِي وَارْ ثفْثِينذْ إِ ڒْوقْثْ ن وَارْزفْ \add ن أَربِّي\add* غَارمْ.“ \x ◘ \xo 19:‏44 \xt 1 إِج. 9‏:‏7، 8؛ مِيخَا 3‏:‏12؛ مت. 24‏:‏1، 2؛ مك. 13‏:‏2؛ لك. 21‏:‏6. \x*   
\b  
\m  
\s1 أَسِيزْذڭْ ن زَّاوشْثْ ثَامقّْرَانْثْ  
\m
\v 45 ؤُمِي يُوذفْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ، إِبْذَا إِسُّوفُّوغْ إِنِّي إِ ثُوغَا إِسَّاغنْ ؤُ إِزّْنُوزَانْ ذَايسْ. \x ◘ \xo 19:‏45 \xt [مت. 21‏:‏12‏-‏17؛ مك. 11‏:‏15‏-‏19؛ يُوح. 2‏:‏13‏-‏22]\x*  
\v 46 إِنَّا أَسنْ: ”أَقَا ثُورَا: ’ثَادَّارْثْ إِنُو ذ ثَادَّارْثْ ن ثْژَادْجِيثْ!‘، مَاشَا كنِّيوْ ثَارِّيمْ ت ذ إِجّْ ن إِفْرِي ن إِشفَّارنْ!“ \x ◘ \xo 19:‏46 \xt 1 إِج. 8‏:‏29؛ إِشا. 56‏:‏7؛ إِرْم. 7‏:‏11؛ مت. 21‏:‏13؛ مك. 11‏:‏17. \x*  
\v 47 ثُوغَا إِسّڒْمَاذْ مَارَّا ؤُسَّانْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، مَاشَا إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِمْغَارنْ ن ڒْڭنْسْ ثُوغَا أَرزُّونْ حِيمَا أَذْ ث نْغنْ. \x ◘ \xo 19:‏47 \xt مك. 11‏:‏18؛ يُوح. 7‏:‏19؛ 8‏:‏37. \x*  
\v 48 \add مَاشَا\add* وَارْ ؤُفِينْ مِينْ خَاسْ غَا ڭّنْ، مِينْزِي مَارَّا إِوْذَانْ ثُوغَا ڒصْقنْ ذَايسْ، تّسْڒَانْ غَارسْ.   
\b  
\b  
\m  
\c 20
\s1 أَسقْسِي خْ مَانْ تّسْرِيحْ إِ زِي إِتّڭّْ يَاسُوع ڒعْجَايبْ نّسْ  
\m
\v 1 ذڭْ إِجّْ زڭْ وُوسَّانْ نِّي، أَمْ ثُوغَا نتَّا إِسّڒْمَاذْ ڒْڭنْسْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، إِتّْبَارّحْ س ڒخْبَارْ أَصبْحَانْ، \add خنِّي\add*غوّْغنْ خَاسْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ أَكْ-ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add*. \x ◘ \xo 20:‏1 \xt [مت. 21‏:‏23‏-‏27؛ مك. 11‏:‏27‏-‏33] — مت. 21‏:‏23؛ مك. 11‏:‏27؛ ڒخ. 4‏:‏7؛ 7‏:‏27. \x*  
\v 2 سِّيوْڒنْ أَكِيذسْ، نَّانْ: ”إِنِي أَنغْ، س مَانْ تّسْرِيحْ إِ ثتّڭّذْ أَيَا، نِيغْ مَانْ ونْ إِ ذ أَشْ إِوْشِينْ تّسْرِيحْ-أَ؟“  
\v 3 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”ؤُڒَا ذ نشّْ أَذْ كنِّيوْ سّقْسِيغْ إِجّْ ن ؤُسقْسِي. إِنِيمْ أَيِي:  
\v 4 مَا أَسغْضصْ ن يُوحَانَّا زڭْ ؤُجنَّا نِيغْ زڭْ إِوْذَانْ؟“  
\v 5 مْشَاوَارنْ جَارْ أَسنْ، نَّانْ: ”مَاڒَا ننَّا: ’زڭْ ؤُجنَّا!‘، أَذْ يِينِي: ’مَايمِّي خنِّي وَارْ زَّايسْ ثُومِينمْ؟‘  
\v 6 مَاڒَا ننَّا: ’زڭْ إِوْذَانْ!‘، أَذْ أَنغْ يَارْجمْ مَارَّا ڒْڭنْسْ، مِينْزِي نِيثْنِي تّْوَاسّْقنْعنْ بلِّي يُوحَانَّا ذ أَنَابِي.“  
\v 7 نَّانْ أَسْ: ”نشِّينْ وَارْ نسِّينْ زِي مَانِيسْ!“  
\v 8 \add خنِّي\add* إِنَّا أَسنْ يَاسُوع: ”خنِّي ؤُڒَا ذ نشّْ وَارْ ذ أَومْ قَّارغْ س مَانْ تّسْرِيحْ إِ تّڭّغْ أَيَا!“   
\b  
\m  
\s1 أَمذْيَا ن ؤُمَارْجُوعْ ن ؤُضِيڒْ ذ إِخمَّاسنْ إِعفَّاننْ  
\m
\v 9 إِبْذَا إِتّْعَاوَاذْ إِ ڒْڭنْسْ أَمذْيَا-يَا: ”إِجّْ ن بْنَاذمْ إِڭَّا إِجّْ ن ؤُمَارْجعْ ن ؤُضِيڒْ، إِژُّو ذَايسْ ثِيزَايَارِينْ، إِشْرَا أَمَارْجعْ إِ إِخمَّاسنْ، ؤُشَا إِسَافَارْ إِجّْ ن ڒْمِيجَاڒْ ن ڒْوقْثْ ذ أَزِيرَارْ. \x ◘ \xo 20:‏9 \xt [مت. 21‏:‏33‏-‏46؛ مك. 12‏:‏1‏-‏12] — إِزهد. 80‏:‏9؛ إِشا. 5‏:‏1؛ إِرْم. 2‏:‏21؛ 12‏:‏10؛ مت. 21‏:‏33؛ مك. 12‏:‏1. \x*  
\v 10 أَڒَامِي د-يِيوضْ ڒْحَاڒْ، إِسّكّْ إِجّْ ن ؤُمْسخَّارْ غَارْ إِخمَّاسنْ حِيمَا أَذْ أَسْ وْشنْ زڭْ ؤُضِيڒْ ن ؤُمَارْجعْ. وْثِينْ ث إِخمَّاسنْ \add نِّي\add* ؤُشَا سّكّنْ ث-إِ-د إِخْوَا.  
\v 11 خنِّي إِسّكّْ عَاوذْ إِجّْ ن ؤُمْسخَّارْ نّغْنِي، وْثِينْ ث عَاوذْ، ذدْجنْ ث، خنِّي سكّنْ ث-إِ-د إِخْوَا.  
\v 12 إِسّكّْ عَاوذْ \add أَمْسخَّارْ\add* وِيسّْ ثْڒَاثَا، مَاشَا نِيثْنِي سّْيزْمنْ ث عَاوذْ ؤُشَا نْضَارنْ ث غَارْ بَارَّا.   
\m
\v 13 إِنَّا بَابْ ن ؤُمَارْجعْ ن ؤُضِيڒْ: ’مِينْ غَا ڭّغْ؟ أَذْ سّكّغْ مِّي إِعِيزّنْ. خْمِي ث غَا ژَترنْ، أَذْ ث وقَّارنْ نِيشَانْ.‘  
\v 14 ؤُمِي ث ژْرِينْ إِخمَّاسنْ، مْشَاوَارنْ جَارْ أَسنْ، نَّانْ: ’أَقَا ذ وَا ذ أَوْرِيثْ. زِيذْ أَذْ ث نّغْ، حِيمَا أَذْ غَارْنغْ د-إِذْوڒْ ڒْوَارْثْ.‘ \x ◘ \xo 20:‏14 \xt أَمز. 37‏:‏17؛ إِزهد. 2‏:‏1، 8؛ مت. 26‏:‏3؛ 27‏:‏1؛ يُوح. 11‏:‏53؛ عبر. 1‏:‏2. \x*  
\v 15 مّنْضَارنْ ث بَارَّا إِ ؤُمَارْجعْ ن ؤُضِيڒْ ؤُشَا نْغِينْ ث. مِينْ زَّايْسنْ إِ غَا يڭّْ خنِّي بَابْ ن ؤُمَارْجعْ ن ؤُضِيڒْ؟  
\v 16 أَذْ د-يَاسْ، أَذْ إِنغْ إِخمَّاسنْ نِّي، ؤُشَا أَذْ إِوْشْ أَمَارْجعْ ن ؤُضِيڒْ إِ إِنّغْنِي.“ ؤُمِي سْڒِينْ أَيَا، نَّانْ أَسْ: ”عمَّارْصْ!“  
\v 17 مَاشَا نتَّا إِخْزَارْ غَارْسنْ، إِنَّا: ”مِينْ إِخْسْ أَذْ يِينِي خنِّي \add وَاوَاڒْ-أَ\add* إِ يُورَانْ:  
\b  
\m \qt ’أَژْرُو إِ ثُوغَا إِعِيفّنْ إِبنَّاينْ،\qt*  
\m \qt أَقَا إِذْوڒْ ذ \+tl أَژْرُو ن\+tl* ؤُزدْجِيفْ ن ثغْمَارْثْ!\qt* \x ◘ \xo 20:‏17 \xt إِزهد. 118‏:‏22؛ إِشا. 8‏:‏14؛ 28‏:‏16؛ مت. 21‏:‏42؛ مك. 12‏:‏10؛ ڒخ. 4‏:‏11؛ رُوم. 9‏:‏33؛ 1 بُط. 2‏:‏4، 7. \x*   
\m
\v 18 \qt مَارَّا وِي غَا إِوْضَانْ خْ وژْرُو-يَا،\qt*  
\m \qt أَذْ إِفَارْثكْ،\qt*  
\m \qt ؤُ ونِّي خفْ إِ غَا إِوْضَا،\qt*  
\m \qt أَذْ ث إِڒْبزْ‘؟“\qt* \x ◘ \xo 20:‏18 \xt إِشا. 8‏:‏15؛ دَان. 2‏:‏34؛ زَاك. 12‏:‏3. \x*   
\b  
\m
\v 19 أَرزُّونْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِمقّْرَاننْ ن إِكهَّاننْ أَذْ خَاسْ سَّارْسنْ إِفَاسّنْ ذِي ثْسَاعّثْ نِّي، مَاشَا نِيثْنِي ڭّْوذنْ زڭْ إِوْذَانْ، مِينْزِي سّْننْ بلِّي نتَّا إِنَّا أَمذْيَا-يَا خَاسنْ.   
\b  
\m  
\s1 أَسقْسِي خْ ؤُخدْجصْ ن ضَّارِيبَا إِ قَايْصَارْ  
\m
\v 20 حْضَانْ ث ؤُشَا سّكّنْ إِبرْڭَاڭنْ إِنِّي إِڭِّينْ إِخفْ نْسنْ أَمشْنَاوْ إِمْسڭَّاذنْ، حِيمَا أَذْ أَسْ ڭّنْ إِجّْ ن ڒْفخْ ذِي سِّيبّثْ ن إِجّْ ن وَاوَاڒْ، مَاحنْذْ أَذْ ث سلّْمنْ إِ ڒْقَاضِي ذ جّهْذْ ن لْعَامِيلْ. \x ◘ \xo 20:‏20 \xt [مت. 22‏:‏15‏-‏22؛ مك. 12‏:‏13‏-‏17] — مت. 22‏:‏16؛ مك. 12‏:‏13. \x*  
\v 21 سّقْسَانْ ث، نَّانْ: ”\add أَ\add* أَمْسغَّارْ، نسّنْ بلِّي شكْ ثسَّاوَاڒذْ ؤُ ثسّڒْمَاذذْ نِيشَانْ، وَارْ ثتّڭّذْ شَا س وُوذْمَاونْ ؤُ ثسّڒْمَاذذْ أَبْرِيذْ ن أَربِّي س ثِيذتّْ.  
\v 22 مَا إِحدْجڒْ أَنغْ أَذْ نوْشْ ڒعْشُورْ إِ كُوڒْ  إِجّنْ ؤُزدْجِيفْ إِ قَايْصَارْ نِيغْ لَّا؟“  
\v 23 يُوشَا س ثحْرَايْمشْثْ نْسنْ ؤُشَا إِنَّا أَسنْ: ”مَايمِّي ذ أَيِي ثتّْجَارَّابمْ؟  
\v 24 سشْنمْ أَيِي-د ذِينَارْ. وِي يِيڒَانْ ثَاصْوِيرْثْ-أَ ذ ثِيرَا-يَا؟“ نَّانْ أَسْ: ”ن قَايْصَارْ!“  
\v 25 \add خَاسْ ؤُشَا\add* إِنَّا أَسنْ يَاسُوع: ”وْشمْ خنِّي إِ قَايْصَارْ مِينْ إِدْجَانْ إِ قَايْصَارْ ؤُ إِ أَربِّي مِينْ إِدْجَانْ إِ أَربِّي!“ \x ◘ \xo 20:‏25 \xt مت. 17‏:‏25؛ 22‏:‏21؛ رُوم. 13‏:‏7. \x*  
\v 26 وَارْ زمَّارنْ أَذْ ث طّْفنْ س وَاوَاڒْ نّسْ قِيبَاتْشْ إِ إِوْذَانْ، \add مَاشَا\add* قِّيمنْ تّْبهْثنْ س ثمْوَارِّيثْ نّسْ ؤُشَا سّغْذنْ.   
\b  
\m  
\s1 أَسقْسِي ن إِصَاذُوقِييّنْ خْ ثْنُوكْرَا  
\m
\v 27 ؤُسِينْ-د شَا زڭْ إِصَاذُوقِييّنْ إِنِّي إِقَّارنْ، وَارْ ذِينْ بُو ثْنُوكْرَا \add زِي ڒْموْثْ\add*. سّقْسَانْ ث، \x ◘ \xo 20:‏27 \xt [مت. 22‏:‏23‏-‏33؛ مك. 12‏:‏18‏-‏27] — مت. 22‏:‏23؛ مك. 12‏:‏18؛ ڒخ. 23‏:‏8. \x*  
\v 28 نَّانْ أَسْ: ”\add أَ\add* أَمْسغَّارْ، يُورَا أَنغْ مُوسَا، مَاڒَا إِمُّوثْ إِ ورْيَازْ ؤُمَاسْ إِ غَارْ إِدْجَا ثَامْغَارْثْ ؤُشَا إِمُّوثْ بْڒَا إِحنْجِيرنْ، خنِّي أَذْ يَاوِي ؤُمَاسْ ثَامْغَارْثْ نِّي، مَاحنْذْ أَذْ د-يجّْ أَحنْجِيرْ إِ ؤُمَاسْ. \x ◘ \xo 20:‏28 \xt أَعَوذ. 25‏:‏5‏-‏6. \x*  
\v 29 ثُوغَا ذِينْ سبْعَا ن وَاوْمَاثنْ. أَمزْوَارْ يِيوِي إِشْثْ ن ثمْغَارْثْ، \add مَاشَا\add* إِمُّوثْ بْڒَا إِحنْجِيرنْ.  
\v 30 يِيوِي ونِّي ذ وِيسّْ ثْنَاينْ ثَامْغَارْثْ نِّي ؤُشَا ؤُڒَا ذ نتَّا إِمُّوثْ بْڒَا إِحنْجِيرنْ.  
\v 31 خنِّي ونِّي ذ وِيسّْ ثْڒَاثَا يِيوِي ثَامْغَارْثْ نِّي ؤُشَا أَمُّو إِنّغْنِي أَڒْ وِيسّْ سبْعَا. مُّوثنْ نِيثْنِي \add مَارَّا إِذْسنْ\add*، وَارْ د-جِّينْ شَا إِحنْجِيرنْ.  
\v 32 غَارْ ؤُنڭَّارْ ثمُّوثْ ثمْغَارْثْ عَاوذْ.  
\v 33 ذِي ثْنُوكْرَا إِ مَانْ ونْ زَّايْسنْ إِ غَا ثِيڒِي ذ ثَامْغَارْثْ؟ مِينْزِي مَارَّا سبْعَا نِّي إِوْينْ ت \add ذ ثَامْغَارْثْ\add*!“   
\m
\v 34 إِنَّا أَسنْ يَاسُوع: ”أَيْثْ ن دُّونشْثْ-أَ إِوْينْ ثِيمْغَارِينْ، ؤُ ثِيمْغَارِينْ تّْوَاسّْمدْجَاشنْثْ إِ يرْيَازنْ.  
\v 35 مَاشَا إِنِّي إِتّْوَاحسْبنْ سْذَاهدْجنْ أَذْ أَوْضنْ غَارْ دُّونشْثْ نِّي ؤُ غَارْ ثْنُوكْرَا زِي ثَادَّارْثْ ن إِمتِّيننْ، وَارْ تِّيوْينْ ثِيمْغَارِينْ، ؤُ ثِيمْغَارِينْ وَارْ تِّيڒِينْثْ إِ يرْيَازنْ.  
\v 36 مَاغَارْ وَارْ زمَّارنْ عَاذْ أَذْ مّْثنْ، مِينْزِي نِيثْنِي أَمْ لْمَالَاكَاثْ ؤُ نِيثْنِي ذ ثَارْوَا ن أَربِّي، مِينْزِي نِيثْنِي ذوْڒنْ ذ ثَارْوَا ن ثْنُوكْرَا. \x ◘ \xo 20:‏36 \xt 1 يُوح. 3‏:‏2. \x*  
\v 37 مَاشَا زِي جِّيهثْ ن إِمتِّيننْ أَذْ تّْوَاسّْنكَّارنْ، ثُوغَا إِسّْبيَّانْ مُوسَا عَاوذْ ؤُمِي إِحَاجَا خْ شْبَارْقْ أَكْ-ذ إِسنَّاننْ، أَقَا سِيذِي إِنَّا: ’\add نشّْ\add* ذ أَربِّي ن إِبْرَاهِيمْ ذ أَربِّي ن إِسْحَاقْ ذ أَربِّي ن يَاعْقُوبْ.‘ \x ◘ \xo 20:‏37 \xt ؤُف. 3‏:‏6؛ ڒخ. 7‏:‏32؛ عبر. 11‏:‏16. \x*  
\v 38 نتَّا وَارْ إِدْجِي شَا ذ أَربِّي ن إِمتِّيننْ، مَاشَا ن يِينِّي إِدَّارنْ، مِينْزِي غَارسْ نتَّا نِيثْنِي مَارَّا دَّارنْ.“  
\v 39 أَرِّينْ-د شَا زڭْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ، نَّانْ: ”\add أَ\add* أَمْسغَّارْ، ثسِّيوْڒذْ مْلِيحْ أَطَّاسْ!“  
\v 40 ؤُشَا وَارْ زْعِيمنْ عَاذْ أَذْ ث سّقْسَانْ خْ شَا.   
\b  
\m  
\s1 مَانْ ونْ إِدْجَانْ ذ مِّيسْ ن ذَاوُوذْ؟  
\m
\v 41 إِنَّا أَسنْ: ”مَامّشْ زمَّارنْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ أَذْ إِنِينْ بلِّي لْمَاسِيحْ ذ مِّيسْ ن ذَاوُوذْ؟ \x ◘ \xo 20:‏41 \xt [مت. 22‏:‏41‏-‏46؛ مك. 12‏:‏35‏-‏37] — مت. 22‏:‏42؛ مك. 12‏:‏35. \x*  
\v 42 ذَاوُوذْ \add سِيمَانْثْ نّسْ\add* إِقَّارْ ذڭْ وذْلِيسْ ن إِزهِّيذنْ:  
\b  
\m \qt ’سِيذِي إِنَّا إِ سِيذِي إِنُو:\qt*  
\m \qt قِّيمْ خْ ؤُفُوسِي إِنُو،\qt* \x ◘ \xo 20:‏42 \xt إِزهد. 110‏:‏1؛ ڒخ. 2‏:‏34؛ 1 كُور. 15‏:‏25؛ عبر. 1‏:‏13؛ 10‏:‏13. \x*   
\m
\v 43 \qt أَڒْ ذ غَا سَّارْسغْ ڒْعذْيَانْ نّشْ\qt*  
\m \qt سَاذُو إِضَارنْ نّشْ.‘\qt* \x ◘ \xo 20:‏43 \xt إِزهد. 110‏:‏1. \x*   
\b  
\m
\v 44 مَاڒَا ذَاوُوذْ إِسمَّا ث ’سِيذِي‘، مَامّشْ غَا يِيڒِي نتَّا ذ مِّيسْ؟“   
\b  
\m  
\s1 يَاسُوع ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ  
\m
\v 45 أَمْ ثُوغَا مَارَّا إِوْذَانْ \add زمَّارنْ\add* أَذْ سْڒنْ، إِنَّا إِ إِمحْضَارنْ نّسْ: \x ◘ \xo 20:‏45 \xt [مت. 23‏:‏1‏-‏36؛ مك. 12‏:‏38‏-‏40؛ لك. 11‏:‏37‏-‏54]\x*  
\v 46 ”حْضَامْ إِخفْ نْومْ زڭْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ إِنِّي إِتّخْسنْ أَذْ ؤُيُورنْ س إِجدْجَابنْ إِزِيرَارنْ، إِنِّي ؤُمِي إِتّعْجِيبْ أَسنْ أَذْ خَاسنْ سدْجْمنْ إِوْذَانْ ذِي ڒسْوَاقْ ؤُ أَذْ قِّيمنْ خْ ڒكْرَاسِي إِصبْحنْ ذِي ثمْزِيذَاوِينْ ؤُ خْ إِمُوشَانْ إِمزْوُورَا غَارْ إِمنْسِيونْ. \x ◘ \xo 20:‏46 \xt مت. 23‏:‏5، 6؛ مك. 12‏:‏38، 39؛ لك. 11‏:‏43. \x*  
\v 47 نِيثْنِي تّتّنْ ثُوذْرِينْ ن ثِيجَّاڒْ أَمْ تّتَّارنْ ثِيوْهِيبِينْ ذِي طّْوعْ ن ثْژَادْجَاثِينْ نْسنْ ثِيزِيرَارِينْ. أَقَا إِنَا أَذْ كْسِينْ إِجّْ ن ڒْحُوكْمْ إِقْسحْ.“ \x ◘ \xo 20:‏47 \xt مت. 23‏:‏14؛ مك. 12‏:‏40؛ 2 تِيم. 3‏:‏6؛ ثِيث. 1‏:‏11. \x*   
\b  
\b  
\m  
\c 21
\s1 صّذْقثْ ن ثَاجَّاتْشْ  
\m
\v 1 خنِّي إِسْوضْ يَاسُوع غَارْ أَيْثْبَابْ ن وَاڭْڒَا سّْرُوسَانْ صّْذَاقِي نْسنْ ذِي سّنْذُوقْ. \x ◘ \xo 21:‏1 \xt [مك. 12‏:‏41‏-‏44] — 2 إِج. 12‏:‏10؛ مك. 12‏:‏41. \x*  
\v 2 إِژْرَا عَاوذْ إِشْثْ ن ثَاجَّاتْشْ ثَامزْڒُوضْثْ ثسَّارْسْ ذَايسْ ثْنَاينْ ن \add ؤُقِييَّاثْ، سمَّانْ ثنْثْ\add* ’شَامُونَاثْ‘.  
\v 3 إِنَّا أَسنْ: ”س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، أَقَا ثَاجَّاتْشْ-أَ ڒْمسْكِينَا ثنْضَارْ \add ذَايسْ\add* كْثَارْ زَّايْسنْ مَارَّا. \x ◘ \xo 21:‏3 \xt 2 كُور. 8‏:‏12. \x*  
\v 4 مِينْزِي مَارَّا نِيثْنِي نْضَارنْ زِي زِّييَاذَا ن وَاڭْڒَا نْسنْ \add إِشْثْ ن صّذْقثْ\add* ذڭْ وخَّامْ ن صّْذَاقِي ن أَربِّي، مَاشَا نتَّاثْ زِي ڒخْصصْ نّسْ أَقَا ثنْضَارْ ذَايسْ مَارَّا مِينْ غَارسْ.“   
\b  
\m  
\s1 أَوَاڒْ ن يَاسُوع خْ ڒْوقْثْ أَنڭَّارُو  
\m
\v 5 أَڒَامِي ثُوغَا شَا \add ن إِوْذَانْ\add* سَّاوَاڒنْ خْ زَّاوشْثْ ثَامقّْرَانْثْ، ثنِّي ثْزوّقْ س إِژْرَا إِصبْحنْ ذ صّْذَاقِي، إِنَّا أَسنْ يَاسُوع: \x ◘ \xo 21:‏5 \xt [مت. 24‏:‏1‏-‏14؛ مك. 13‏:‏1‏-‏13] — مت. 24‏:‏1؛ مك. 13‏:‏1. \x*  
\v 6 ”مَا ثتّْوَاڒَامْ ثِيمسْڒَايِينْ-أَ؟ أَذْ د-أَسنْ وُوسَّانْ وَارْ إِتّْغِيمِي ؤُڒَا ذ إِجّْ ن وژْرُو خْ وژْرُو نّغْنِي إِ وَارْ إِتَّاردّْدْجنْ.“ \x ◘ \xo 21:‏6 \xt 1 إِج. 9‏:‏7؛ مِيخَا 3‏:‏12؛ لك. 19‏:‏44. \x*  
\v 7 سّقْسَانْ ث، نَّانْ: ”\add أَ\add* أَمْسغَّارْ، مڒْمِي إِ غَا يِيڒِي ؤُيَا ذ مَانْ ڒعْڒَامثْ أَقَا ثِيمسْڒَايِينْ-أَ ؤُذْسنْثْ-إِ-د؟“  
\v 8 إِنَّا أَسنْ: ”عسّمْ، وَارْ ثتّْوَاغَارّمْ، مِينْزِي أَطَّاسْ أَذْ د-أَسنْ س يِيسمْ إِنُو، أَذْ إِنِينْ: ’أَقَا نشّْ ذ لْمَاسِيحْ!‘ ؤُ: ’ڒْْوقْثْ أَقَا ثِيوضْ-د!‘، مَاشَا وَارْ ڭُّورمْ أَوَارْنِي أَسنْ. \x ◘ \xo 21:‏8 \xt إِرْم. 29‏:‏8؛ مت. 24‏:‏4؛ أَفا. 5‏:‏6؛ كُول. 2‏:‏18؛ 2 تس. 2‏:‏2؛ 1 يُوح. 4‏:‏1. \x*  
\v 9 مَاڒَا ثسْڒِيمْ خْ ڒْبَارُوضْ ذ إِغوّْغنْ، وَارْ تّْنخْڒِيعمْ شَا، مِينْزِي س ؤُغِيڒْ أَذْ يِيڒِي ؤُيَا ذ أَمزْوَارْ، مَاشَا وَارْ إِتِّيڒِي عَاذْ ذغْيَا ؤُنڭَّارْ.   
\m
\v 10 مَاغَارْ إِجّْ ن ڒْڭنْسْ أَذْ د-إِڭعّذْ ضِيدّْ ن إِجّْ ن ڒْڭنْسْ \add نّغْنِي\add* ؤُ إِشْثْ ن ثْڭلْذِيثْ ضِيدّْ ن إِشْثْ ن ثْڭلْذِيثْ \add نّغْنِيثْ\add*. \x ◘ \xo 21:‏10 \xt إِشا. 19‏:‏2. \x*  
\v 11 أَذْ إِڒِينْ إِنْهزِّييّنْ ن ثمُّورْثْ مْغَارنْ ذِي عْڒَامْ كُوڒْ إِمُوشَانْ ذ ڒَاژْ ذ جّْرَايحْ ذ ثِيڭّْوُوذِي ذ ؤُسْنخْڒِيعْ. ؤُشَا أَذْ د-بَاننْثْ ڒعْڒَامَاثْ مْغَارنْثْ زڭْ ؤُجنَّا ؤُ أَذْ ذِينْ إِڒِينْثْ ثْحَارْيَاضِينْ إِجهْذنْ.  
\v 12 مَاشَا قْبڒْ مَانْ أَيَا مَارَّا أَذْ خَاومْ سَّارْسنْ إِفَاسّنْ، أَذْ كنِّيوْ سلّْمنْ غَارْ ثمْزِيذَاوِينْ ذ ڒحْبُوسَاثْ، ؤُشَا أَذْ كنِّيوْ نذْهنْ زَّاثْ إِ إِجدْجِيذنْ ذ ڒْحُوكَّامْ خْ سِّيبّثْ ن يِيسمْ إِنُو. \x ◘ \xo 21:‏12 \xt مت. 10‏:‏17؛ 24‏:‏9؛ مك. 13‏:‏9؛ يُوح. 16‏:‏2؛ ڒخ. 4‏:‏3؛ 5‏:‏18؛ 12‏:‏4؛ 16‏:‏24؛ أَسَا. 2‏:‏10. \x*  
\v 13 مَاشَا مَانْ أَيَا أَذْ يَارَّا كنِّيوْ أَذْ ثْشهْذمْ. \x ◘ \xo 21:‏13 \xt لك. 9‏:‏15؛ 21‏:‏13؛ 24‏:‏48\x*  
\v 14 ڭّمْ ذڭْ وُوڒَاونْ نْومْ مَاحنْذْ وَارْ \add ثَارزُّومْ\add* أَذْ ثْڒمْذمْ مَامّشْ إِ د غَا ثَارّمْ. \x ◘ \xo 21:‏14 \xt مت. 10‏:‏19؛ مك. 13‏:‏11. \x*  
\v 15 مِينْزِي نشّْ أَذْ أَومْ وْشغْ أَقمُّومْ ذ ثِيغِيثْ إِ وَارْ زمَّارنْ أَذْ ثنْ سّْبدّنْ مَارَّا ڒْعذْيَانْ نْومْ. \x ◘ \xo 21:‏15 \xt ؤُف. 4‏:‏12؛ إِشا. 54‏:‏17؛ مت. 10‏:‏19؛ ڒخ. 6‏:‏10. \x*  
\v 16 أَذْ كنِّيوْ سلّْممْ لْوَالِيذِينْ نْومْ ذ ثَاوْمَاثْ نْومْ ذ ڒَادْجْ نْومْ ذ إِمدُّوكَّاڒْ نْومْ ؤُشَا أَذْ نْغنْ شَا زَّايْومْ، \x ◘ \xo 21:‏16 \xt مِيخَا 7‏:‏6؛ ڒخ. 7‏:‏59؛ 12‏:‏2. \x*  
\v 17 ؤُ كنِّيوْ أَذْ ثتّْوَاشَارْهمْ زِي مَارَّا س سِّيبّثْ ن يِيسمْ إِنُو. \x ◘ \xo 21:‏17 \xt مت. 10‏:‏22؛ مك. 13‏:‏13. \x*  
\v 18 \add وَاخَّا أَمنِّي\add* ؤُڒَا ذ إِجّْ ن ؤُژطُّو \add ن ؤُشُووَّافْ\add* ن ؤُزدْجِيفْ نْومْ وَارْ إِتّْودَّارِي شَا، \x ◘ \xo 21:‏18 \xt 1 صم. 14‏:‏45؛ 2 صم. 14‏:‏11؛ 1 إِج. 1‏:‏52؛ مت. 10‏:‏30. \x*  
\v 19 مَاشَا س صّْبَارْ نْومْ أَذْ ثَاربْحمْ ڒعْمُورْ نْومْ.“   
\b  
\m  
\s1 أَردّدْجْ ن ؤُرْشَالِيمْ  
\m
\v 20 ”خْمِي غَا ثْژَارمْ ؤُرْشَالِيمْ أَقَا إِنّضْ أَسْ-د ڒْعسْكَارْ، خنِّي سْنمْ بلِّي أَقَا إِقَارّبْ-د وَاردّدْجْ نّسْ. \x ◘ \xo 21:‏20 \xt [مت. 24‏:‏15‏-‏21؛ 24‏:‏29‏-‏35؛ مك. 13‏:‏14‏-‏19؛ 13‏:‏24‏-‏32] — دَان. 9‏:‏27؛ زَاك. 14‏:‏1‏-‏3؛ مت. 24‏:‏15‏-‏35؛ مك. 13‏:‏14‏-‏31. \x*  
\v 21 خنِّي إِتّْخصَّا أَذْ أَروْڒنْ إِنِّي إِدْجَانْ ذِي يَاهُوذِييَّا غَارْ إِذُورَارْ، أجّْ إِنِّي إِدْجَانْ ذِي ڒْوسْطْ نّسْ أَذْ زَّايسْ فّْغنْ، أَذْ أَروْڒنْ، ذ يِينِّي إِدْجَانْ ذِي ذْشُورَاثْ، وَارْ ت تِّيذْفنْ،  
\v 22 مِينْزِي إِنَا ذ ؤُسَّانْ ن نّقْمثْ حِيمَا أَذْ إِتّْوَاكمّڒْ مَارَّا مِينْ يُورِينْ. \f ◼ \fr 21:‏22 \ft \+bd ’ؤُسَّانْ ن نّقْمثْ‘\+bd* - نِيغْ ’ؤُسَّانْ ن وعْمُوذْ‘.\f*  \x ◘ \xo 21:‏22 \xt دَان. 9‏:‏26، 27؛ مت. 24‏:‏15؛ مك. 13‏:‏14. \x*  
\v 23 ؤُشْثْ خْ ثمْغَارِينْ نِّي س دّيْسثْ ذ ثِينِّي إِسُّوطُّوضنْ ذڭْ وُوسَّانْ نِّي، مِينْزِي أَذْ ذِينْ ثِيڒِي ڒْمحْنثْ ذ ثَامقّْرَانْثْ خْ ثمُّورْثْ ذ وغْضَابْ خْ ڒْڭنْسْ-أَ.  
\v 24 نِيثْنِي أَذْ وْضَانْ س ڒقْضعْ ن سِّيفْ، أَذْ تّْوَاحبّْسنْ أَمْ تّْوَانذْهنْ جَارْ مَارَّا ڒڭْنُوسْ، ؤُشَا ؤُرْشَالِيمْ أَذْ خَاسْعفْسنْ ڒڭْنُوسْ أَڒْ غَا كمّْڒنْثْ زّْمَانَاثْ ن ڒڭْنُوسْ.“ \x ◘ \xo 21:‏24 \xt رُوم. 11‏:‏25. \x*   
\b  
\m  
\s1 ڒعْڒَامَاثْ ذڭْ ؤُجنَّا إِ خْ ثمُّورْثْ  
\m
\v 25 ”أَذْ ذِينْ إِڒِينْثْ ڒعْڒَامَاثْ ذِي ثْفُوشْثْ، ذِي ثْزِيرِي ؤُ ذڭْ إِثْرَانْ، ؤُشَا خْ ثمُّورْثْ \add أَذْ ذِينْ ثِيڒِي\add* ڒْمحْنثْ ذِي ڒڭْنُوسْ، أَڒْ ذ أَسنْ إِودَّارْ مِينْ غَا ڭّنْ زڭْ ؤُنخْڒِيعْ ن زّْهِيرْ أَمقّْرَانْ ن ڒبْحَارْ، \x ◘ \xo 21:‏25 \xt إِشا. 13‏:‏10؛ حِز. 32‏:‏7؛ يُووِ. 3‏:‏4؛ 3‏:‏15؛ مت. 24‏:‏29؛ مك. 13‏:‏24؛ أَسَا. 6‏:‏12. \x*  
\v 26 ؤُ \add زڭْ\add* ونْهزِّي ن ثمُّورْثْ ذ أَمقّْرَانْ أَذْ إِسّْنخْڒِيعْ ڒعْمَارْ ن إِوْذَانْ زِي ثِيڭّْوُوذِي زِي مِينْ إِ د غَا يَاسنْ خْ ثمُّورْثْ، ؤُ صُّولَاطَاثْ ن إِجنْوَانْ أَذْ تّْوَانْهزّنْثْ.  
\v 27 ڒخْذنِّي أَذْ ژَترنْ مِّيسْ ن بْنَاذمْ، خْمِي د غَا يَاسْ ذڭْ إِسيْنُوثنْ، س جّهْذْ ذ ؤُعُودْجِي أَطَّاسْ. \x ◘ \xo 21:‏27 \xt دَان. 7‏:‏10؛ مت. 16‏:‏27؛ 24‏:‏30؛ 25‏:‏31؛ 26‏:‏64؛ مك. 13‏:‏26؛ 14‏:‏62؛ ڒخ. 1‏:‏11؛ 2 تس. 1‏:‏10؛ أَسَا. 1‏:‏7. \x*  
\v 28 خْمِي غَا بْذَانْثْ ثْمسْڒَايِينْ-أَ، ڭّمْ ثَارْيَاسْثْ، سْڭعّْذمْ إِزدْجِيفنْ نْومْ مِينْزِي أَسنْجمْ نْومْ أَقَا يِيوضْ-د.“ \x ◘ \xo 21:‏28 \xt رُوم. 8‏:‏23. \x*   
\b  
\m  
\s1 حْضَامْ، ژَتدْجمْ!  
\m
\v 29 إِعَاوذْ أَسنْ إِجّْ ن ؤُمذْيَا: ”خْزَارمْ غَارْ وَارْثُو ن ثَازَارْثْ ؤُ غَارْ مَارَّا ثِيشجُّورَا. \x ◘ \xo 21:‏29 \xt مت. 24‏:‏32؛ مك. 13‏:‏28. \x*  
\v 30 خْمِي غَا سّْنضْينْثْ، أَذْ ثسّْنمْ س مَانْ أَيَا أَقَا أَنبْذُو يِيوضْ-د.  
\v 31 أَمُّو \add إِتّْخصَّا\add* عَاوذْ كنِّيوْ، خْمِي غَا ثتّْوَاڒَامْ ثِيمسْڒَايِينْ-أَ تّمْسَارَانْثْ، سْنمْ \add خنِّي\add* بلِّي ثَاڭلْذِيثْ ن أَربِّي ثُوذسْ-د.  
\v 32 س ثِيذتّْ أَذْ أَومْ إِنِيغْ، أَقَا وَارْ إِعدُّو جِّيڒْ-أَ أَڒْ غَا يِيڒِي ؤُيَا كُوڒْشِي.  
\v 33 أَجنَّا ذ ثمُّورْثْ أَذْعدُّونْ، \add مَاشَا\add* أَوَاڒنْ إِنُو وَارْعدُّونْعمَّارْصْ. \x ◘ \xo 21:‏33 \xt إِزهد. 102‏:‏27؛ إِشا. 51‏:‏6؛ مت. 24‏:‏35؛ عبر. 1‏:‏11. \x*   
\m
\v 34 حْضَامْ إِخفْ نْومْ حِيمَا وَارْ تّضْقِيڒنْ وُوڒَاونْ نْومْ زڭْ ؤُفُوشّحْ ذ وسْشَارْ ذ إِمُونَاسْ ن دُّونشْثْ-أَ، ؤُ وَارْ خَاومْ د-إِوْضِي وَاسّْ نِّي ذغْيَا. \x ◘ \xo 21:‏34 \xt رُوم. 13‏:‏13؛ 1 تس. 5‏:‏6؛ 1 بُط. 4‏:‏7. \x*  
\v 35 مِينْزِي أَذْ د-يَاسْ \add أَسّْ نِّي\add* أَمْ ڒْفخْ خْ مَارَّا إِنِّي إِقِّيمنْ خْ ؤُغمْبُوبْ ن ثمُّورْثْ. \x ◘ \xo 21:‏35 \xt 1 تس. 5‏:‏2؛ 2 بُط. 3‏:‏10؛ أَسَا. 3‏:‏3؛ 16‏:‏15. \x*  
\v 36 حْضَامْ خنِّي ڒبْذَا، ژَتدْجمْ حِيمَا أَذْ ثِيڒِيمْ ثسْذَاهدْجمْ مَاحنْذْ أَذْ ثْنجْممْ زِي مَارَّا مِينْ غَا إِمْسَارنْ، ؤُشَا أَذْ ثْبدّمْ زَّاثْ إِ مِّيسْ ن بْنَاذمْ.“ \x ◘ \xo 21:‏36 \xt مت. 24‏:‏42؛ 25‏:‏13؛ مك. 13‏:‏33؛ لك. 12‏:‏40؛ 1 تس. 5‏:‏6. \x*   
\b  
\m
\v 37 س ؤُزِيڒْ ثُوغَا إِسّڒْمَاذْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، \add مَاشَا\add* س دْجِيڒثْ ثُوغَا إِتّفّغْ، إِتّْغِيمَا إِتّْنُوسَا خْ وذْرَارْ ؤُمِي قَّارنْ: ’ثَادَّارْثْ ن زِّيثُونْ‘. \x ◘ \xo 21:‏37 \xt يُوح. 8‏:‏2. \x*  
\v 38 ذِي صّْبحْ زِيشْ ثُوغَا مَارَّا إِوْذَانْ تَّاسنْ-د غَارسْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ حِيمَا أَذْ سْڒنْ أَوَاڒْ نّسْ.   
\b  
\b  
\m  
\c 22
\s1 ڒْغذْرَانْ ن يَاهُوذَا إِسْخَارِييُوطِي  
\m
\v 1 إِقَارّبْ-د ڒْعِيذْ ن \add وغْرُومْ\add* بْڒَا أَنْثُونْ ؤُمِي قَّارنْ \add ڒْعِيذْ ن\add* \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو. \x ◘ \xo 22:‏1 \xt [مت. 26‏:‏1‏-‏5، 14‏-‏16؛ مك. 14‏:‏1‏-‏2، 10‏-‏11؛ يُوح. 11‏:‏45‏-‏53] — ؤُف. 12‏:‏15؛ إِرْم. 16‏:‏7 مت. 26‏:‏2؛ مك. 14‏:‏1. \x*  
\v 2 ثُوغَا إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ أَرزُّونْ إِشْثْ ن ثوَّارْثْ، حِيمَا أَذْ ث نْغنْ، مَاشَا نِيثْنِي ڭّْوذنْ زڭْ إِوْذَانْ. \x ◘ \xo 22:‏2 \xt إِزهد. 2‏:‏2؛ يُوح. 11‏:‏47؛ ڒخ. 4‏:‏27. \x*  
\v 3 \add خنِّي\add* يُوذفْ شِّيطَانْ ذِي يَاهُوذَا ونِّي ؤُمِي قَّارنْ إِسْخَارِييُوطِي. نتَّا ثُوغَا ذ إِجّنْ زِي ثنْعَاشْ \add ن إِمحْضَارنْ\add*. \x ◘ \xo 22:‏3 \xt مت. 26‏:‏14؛ مك. 14‏:‏10؛ يُوح. 13‏:‏27. \x*  
\v 4 إِرُوحْ، إِسِّيوڒْ أَكْ-ذ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِمْڭوَّاذنْ ن إِعسَّاسنْ ن زَّاوشْثْ ثَامقّْرَانْثْ مَامّشْ ث إِ غَا إِسلّمْ إِ نِيثْنِي.  
\v 5 فَارْحنْ ؤُشَا تَّافْقنْ أَذْ أَسْ وْشنْ \add ثِينْعَاشِينْ ن\add* نُّوقَارْثْ.  
\v 6 نتَّا إِوْشَا أَسنْ أَوَاڒْ ؤُشَا يَارْزُو إِشْثْ ن ثوَّارْثْ، حِيمَا أَذْ أَسنْ ث إِسلّمْ بَارَّا إِ ڒْغَاشِي.   
\b  
\m  
\s1 أَسوْجذْ ن ؤُمنْسِي ن ؤُسعْذُو  
\m
\v 7 يِيوضْ-د وَاسّْ ن \add وغْرُومْ\add* بْڒَا أَنْثُونْ إِ ذِي ثُوغَا إِتّْخصَّا أَذْ ثتّْوَاغَارْصْ إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو. \x ◘ \xo 22:‏7 \xt [مت. 26‏:‏17‏-‏25؛ مك. 14‏:‏12‏-‏21؛ يُوح. 13‏:‏21‏-‏30] — مت. 26‏:‏17؛ مك. 14‏:‏12، 13. \x*  
\v 8 يَاسُوع إِسّكّْ-د بُوطْرُوسْ ذ يُوحَانَّا، إِنَّا \add أَسنْ\add*: ”رُوحمْ، ثسّْوجْذمْ أَنغْ إِ \add ؤُمنْسِي ن\add* ؤُسعْذُو حِيمَا أَذْ نشّْ.“  
\v 9 نَّانْ أَسْ: ”مَانِي ثخْسذْ أَذْ نسّوْجذْ؟“  
\v 10 إِنَّا أَسنْ: ”خْزَارْ، خْمِي غَا ثَاذْفمْ غَارْ ثنْذِينْثْ أَذْ كنِّيوْ إِڒْقَا إِجّْ ن ورْيَازْ، يَارْبُو إِشْثْ ن ثقْبُوشْثْ ن وَامَانْ. ضْفَارمْ ث!  
\v 11 إِنِيمْ إِ بَابْ ن ثَادَّارْثْ: ’أَمْسڒْمَاذْ نّغْ إِسّقْسَا: مَانِي إِدْجَا وخَّامْ ن إِنوْجِيونْ إِ ذِي إِ غَا شّغْ \add ؤُمنْسِي ن\add* ؤُسعْذُو أَكْ-ذ إِمحْضَارنْ إِنُو؟‘  
\v 12 نتَّا أَذْ أَومْ إِسّْشنْ إِشْثْ ن ثْغُورْفثْ ثْمِيرِيوْثْ سنّجْ، يسُّو \add س إِبَايَاسنْ\add*. سْوجْذمْ ذِينْ \add كُوڒْشِي\add*!“  
\v 13 نِيثْنِي رُوحنْ، ؤُفِينْ \add مَارَّا\add* أَمْ مَامّشْ ثُوغَا ذ أَسنْ إِنَّا ؤُشَا سّْوجْذنْ إِ \add ؤُمنْسِي ن\add* ؤُسعْذُو.   
\b  
\m  
\s1 أَمنْسِي ن سِيذِيثْنغْ  
\m
\v 14 ؤُمِي د-ثِيوضْ ثْسَاعّثْ، يُوسَا-د يَاسُوع، إِقِّيمْ \add غَارْ طَّابْڒَا\add* ذ ثنْعَاشْ ن رُّوسُولْ أَكِيذسْ. \x ◘ \xo 22:‏14 \xt [مت. 26‏:‏26‏-‏30؛ مك. 14‏:‏22‏-‏26؛ 1 إِم. 11‏:‏23‏-‏25] — مت. 26‏:‏20؛ مك. 14‏:‏17. \x*  
\v 15 إِنَّا أَسنْ: ”نشّْ ثُوغَا وحّْشغْ أَطَّاسْ أَذْ شّغْ \add أَمنْسِي-يَا ن\add* ؤُسعْذُو أَكِيذْومْ قْبڒْ إِ غَا ودّْبغْ.  
\v 16 مِينْزِي أَذْ أَومْ إِنِيغْ، أَقَا وَارْ زَّايسْ تّتّغْ \add عَاذْ\add* أَڒْ غَا ثتّْوَاكمّڒْ ذِي ثْڭلْذِيثْ ن أَربِّي.“  
\v 17 \add خنِّي\add* إِطّفْ إِجّْ ن ڒْكَاسْ ؤُشَا إِقَاذَا، إِنَّا: ”كْسِيمْ وَا، بْضَامْ ث جَارْ أَومْ!  
\v 18 مِينْزِي نشّْ أَذْ أَومْ إِنِيغْ، وَارْ سسّغْ شَا زِي ڒْغِيدْجثْ ن ثْزَايَارْثْ أَڒْ د ثُوسَا ثْڭلْذِيثْ ن أَربِّي.“  
\v 19 إِكْسِي أَغْرُومْ، إِقَاذَا، يَارْژَا \add إِ-ث\add* ؤُشَا إِوْشَا أَسنْ ث، إِنَّا: ”ثَا ذ أَرِّيمثْ إِنُو ثنِّي خَاومْ إِمّوْشنْ. ڭّمْ أَيَا إِ ڒِيذَارثْ إِنُو.“ \x ◘ \xo 22:‏19 \xt مت. 26‏:‏26؛ مك. 14‏:‏22؛ 1 كُور. 11‏:‏24. \x*  
\v 20 أَمُّو \add إِ إِنَّا\add* عَاوذْ خْ ڒْكَاسْ أَوَارْنِي إِ ؤُمنْسِي: ”ڒْكَاسْ-أَ ذ ڒْعَاهْذْ ن جْذِيذْ س إِذَامّنْ إِنُو إِنِّي إِ خَاومْ إِ غَا إِتّْوَاسِّيزّْڒنْ. \x ◘ \xo 22:‏20 \xt إِرْم. 31‏:‏31؛ مت. 26‏:‏28، مك. 14‏:‏24، لك. 22‏:‏20، 1 كُور. 11‏:‏25، 2 كُور. 3‏:‏6، عبر. 8‏:‏6، 8، 13؛ 9‏:‏15؛ 12‏:‏24\x*   
\m
\v 21 مَاشَا أَقَا ذَا، أَفُوسْ ن ونِّي ذ أَيِي غَا إِغْذَارنْ أَقَا-ث أَكِيذِي غَارْ طَّابْڒَا. \x ◘ \xo 22:‏21 \xt مت. 26‏:‏23؛ مك. 14‏:‏18؛ يُوح. 13‏:‏21. \x*  
\v 22 مِّيسْ ن بْنَاذمْ أَذْ إِرَاحْ أَمْ مَامّشْ خَاسْ إِتّْوَاكّسْ، مَاشَا ؤُشْثْ خْ بْنَاذمْ نِّي إِ ث غَا إِغْذَارنْ!“ \x ◘ \xo 22:‏22 \xt إِزهد. 41‏:‏10؛ يُوح. 13‏:‏18؛ ڒخ. 1‏:‏6. \x*   
\m
\v 23 بْذَانْ تّمْسّقْسَانْ جَارْ أَسنْ، مَانْ ونْ زَّايْسنْ إِ غَا يڭّ مَانْ أَيَا.   
\m
\v 24 ثُوغَا جَارْ أَسنْ عَاوذْ أَمْشُوبّشْ خْ مَانْ ونْ زَّايْسنْ إِدْجَانْ ذ أَمقّْرَانْ قَاعْ.  
\v 25 خنِّي إِنَّا أَسنْ يَاسُوع: ”إِجدْجِيذنْ ن ڒڭْنُوسْ صلّْطنْ خَاسنْ، ؤُ إِنِّي خَاسنْ إِصلّْطنْ تّْوَاڒَاغَانْ ’ثَارْوَا ن رجْوَاذْ!‘ \f ◼ \fr 22:‏25 \ft \+bd ’ثَارْوَا ن ڒجْوَاذْ‘\+bd* - نِيغْ ’ڒْْمُوحْسِينِينْ‘.\f*  \x ◘ \xo 22:‏25 \xt مت. 20‏:‏25؛ مك. 10‏:‏42. \x*  
\v 26 كنِّيوْ مَاشَا وَارْ تّڭّمْ أَمُّو، مَاشَا أَمقّْرَانْ ذَايْومْ أَذْ يِيڒِي أَمْ ؤُمَاژُوژْ، ؤُ أَمزْوَارْ \add أَذْ يِيڒِي\add* أَمْ ؤُمْسخَّارْ. \x ◘ \xo 22:‏26 \xt لك. 9‏:‏48؛ 1 بُط. 5‏:‏3. \x*  
\v 27 مِينْزِي مَانْ ونْ إِدْجَانْ ذ أَمقّْرَانْ؟ مَا ذ ونِّي إِقِّيمنْ \add غَارْ طَّابْڒَا\add* نِيغْ ذ ونِّي إِتّْسخَّارنْ؟ مَاشَا نشّْ ذِي ڒْوسْطْ نْومْ أَمْ ونِّي إِتّْسخَّارنْ. \x ◘ \xo 22:‏27 \xt مت. 20‏:‏28؛ يُوح. 13‏:‏14؛ فِيل. 2‏:‏7. \x*   
\m
\v 28 أَقَا كنِّيوْ ذ إِنِّي أَكِيذِي إِقِّيمنْ ذڭْ إِجَارِّيبنْ إِنُو.  
\v 29 نشّْ أَذْ أَومْ وعْذغْ إِشْثْ ن ثَاڭلْذِيثْ أَمْ مَامّشْ إِ ذ أَيِي ت إِوَاعْذْ بَابَا، \x ◘ \xo 22:‏29 \xt لك. 12‏:‏32. \x*  
\v 30 حِيمَا أَذْ ثشّمْ أَذْ ثسْومْ خْ طَّابْڒَا إِنُو ذِي ثْڭلْذِيثْ إِنُو ؤُشَا أَذْ ثقِّيممْ خْ ڒكْرَاسِي ن ثْڭلْذِيثْ، أَذْ ثْحكْممْ خْ ثنْعَاشْ ن ثْقبَّاڒْ ن أَيْثْ ن إِسْرَائِيل.“ \x ◘ \xo 22:‏30 \xt مت. 19‏:‏28؛ أَسَا. 3‏:‏21. \x*   
\b  
\m  
\s1 قِّيممْ ثْشبَّارمْ ذِي لْ-إِيمَانْ  
\m
\v 31 إِنَّا يَاسُوع إِ شِيمْعُونْ: ”شِيمْعُونْ، شِيمْعُونْ، أَقَا شِّيطَانْ ثُوغَا يَارزُّو أَذْ كنِّيوْ إِزُّوزَارْ أَمْ يِيرْذنْ. \x ◘ \xo 22:‏31 \xt [مت. 26‏:‏31‏-‏35؛ مك. 14‏:‏27‏-‏31؛ يُوح. 13‏:‏36‏-‏38] — 1 بُط. 5‏:‏8. \x*  
\v 32 \add مَاشَا\add* نشّْ ژُودْجغْ خَاكْ حِيمَا وَارْ إِفنِّي لْ-إِيمَانْ نّشْ. ؤُڒَا ذ شكْ، ثُوبْ ذِي ڒْوقْثْ إِتّْوَاڭّنْ، سْثبّثْ أَيْثْمَاشْ.“  
\v 33 إِنَّا أَسْ شِيمْعُونْ: ”\add أَ\add* سِيذِي، نشّْ أَقَا وجْذغْ حِيمَا أَذْ كِيكْ رَاحغْ ؤُڒَا غَارْ ڒحْبسْ ذ ڒْموْثْ.“  
\v 34 \add مَاشَا\add* يَاسُوع إِنَّا أَسْ: ”نشّْ أَذْ أَشْ إِنِيغْ، \add أَ\add* شِيمْعُونْ، وَارْ إِسّْقُوقُوعْ ؤُيَاژِيضْ أَسّْ-أَ قْبڒْ مَا أَذْ أَيِي ثنْكَارذْ ثْڒَاثَا ن ثْوَاڒَاوِينْ بلِّي أَقَا ثسّْنذْ أَيِي.“ \x ◘ \xo 22:‏34 \xt مت. 26‏:‏34؛ مك. 14‏:‏30؛ يُوح. 13‏:‏38. \x*   
\m
\v 35 إِنَّا أَسنْ: ”ڒَْامِي كنِّيوْ سّكّغْ بْڒَا ثَاشْيَارْثْ، بْڒَا تّسْطِيمْ نِيغْ سَانْذَالِييَاثْ، مَا ثُوغَا إِتّْخصَّا أَومْ شَا؟“ نَّانْ أَسْ: ”وَالُو!“ \x ◘ \xo 22:‏35 \xt مت. 10‏:‏9؛ مك. 6‏:‏8؛ لك. 9‏:‏3. \x*  
\v 36 \add خَاسْ ؤُشَا\add* إِنَّا أَسنْ: ”مَاشَا ڒخُّو ونِّي غَارْ إِدْجَا ثشْيَارْثْ، أَذْ ت إِكْسِي، أَمُّو ؤُڒَا ذ تّسْطِيمْ، ؤُشَا ونِّي وَارْ غَارْ إِدْجِي سِّيفْ، أَذْ إِزّنْزْ أَرُّوضْ نّسْ ؤُشَا أَذْ \add زَّايسْ\add* إِسغْ سِّيفْ إِ يِيخفْ نّسْ.  
\v 37 مِينْزِي نشّْ أَذْ أَومْ إِنِيغْ، أَقَا إِتّْخصَّا أَذْ تّْوَاكمّْڒنْثْ ثِيرَا-يَا ذَايِي: ’أَقَا إِتّْوَاحْسبْ أَكْ-ذ إِنِّي وَارْ إِسڭّْذنْ!‘، مِينْزِي مَارَّا مِينْ خَافِي يُورَانْ، أَذْ إِتّْوَاكمّڒْ.“ \x ◘ \xo 22:‏37 \xt إِشا. 53‏:‏12؛ مك. 15‏:‏28. \x*  
\v 38 نَّانْ أَسنْ: ”\add أَ\add* سِيذِيثْنغْ، أَقَا ذَا ثْنَاينْ ن ڒسْيُوفْ!“ إِنَّا أَسنْ: ”إِكْفَا!“   
\b  
\m  
\s1 ثَاژَادْجِيثْ ن يَاسُوع خْ وذْرَارْ ن ثَادَّارْثْ ن زِّيثُونْ  
\m
\v 39 إِفّغْ، إِرُوحْ غَارْ وذْرَارْ ’ثَادَّارْثْ ن زِّيثُونْ‘ أَمْ مَامّشْ ثُوغَا إِنُّومْ، ؤُشَا ضْفَارنْ ث عَاوذْ إِمحْضَارنْ نّسْ. \x ◘ \xo 22:‏39 \xt [مت. 26‏:‏36‏-‏46؛ مك. 14‏:‏32‏-‏42] — مت. 26‏:‏36؛ مك. 14‏:‏32؛ يُوح. 8‏:‏1؛ 18‏:‏1. \x*  
\v 40 ؤُمِي إِخشّْ غَارْ ومْشَانْ نِّي، إِنَّا أَسنْ: ”ژَتدْجمْ حِيمَا وَارْ د-ثتِّيذْفمْ ذڭْ ؤُجَارّبْ.“  
\v 41 إِفكّْ إِخفْ نّسْ زَّايْسنْ عْڒَاحَاڒْ ثِيشْثِي ن إِجّْ ن ؤُحجَّارْ ن وژْرُو، يُوضَارْ خْ إِفَادّنْ نّسْ، إِژُّودْجْ،  
\v 42 إِنَّا: ”\add أَ\add* بَابَا، مَاڒَا ثخْسذْ، أجّْ ڒْكَاسْ-أَ أَذْ خَافِي إِعْذُو. مَاشَا وَارْ إِتِّيڒِي مِينْ خْسغْ نشّْ مَاشَا مِينْ ثخْسذْ شكْ.“ \x ◘ \xo 22:‏42 \xt مت. 26‏:‏39؛ مك. 14‏:‏35\x*  
\v 43 \add خنِّي\add* إِضْهَارْ أَسْ-د إِجّْ ن لْمَالَاكْ زڭْ ؤُجنَّا، إِوْشَا أَسْ جّهْذْ.  
\v 44 ثُوغَا نتَّا إِڭّْوذْ أَطَّاسْ، إِتّْژَادْجْ أَطَّاسْ ؤُشَا ثِيذِي نّسْ ثُوغَا ثتّڭّْ أَمْ ثْنقِّيضِينْ ن إِذَامّنْ وطَّانْثْ غَارْ ثمُّورْثْ. \x ◘ \xo 22:‏44 \xt يُوح. 12‏:‏27؛ عبر. 5‏:‏7. \x*  
\v 45 \add خنِّي\add* إِكَّارْ زِي ثْژَادْجِيثْ، يُوسَا-د غَارْ إِمحْضَارنْ نّسْ ؤُشَا يُوفَا إِ-ثنْ طّْصنْ س وشْضَانْ.  
\v 46 إِنَّا أَسنْ: ”مَايمِّي ثطّْصمْ؟ كَّارمْ، ثژَّادْجمْ حِيمَا وَارْ ثتِّيذْفمْ ذڭْ ؤُجَارّبْ.“   
\b  
\m  
\s1 ؤُضُوفْ ن يَاسُوع  
\m
\v 47 أَمْ ثُوغَا عَاذْ إِسَّاوَاڒْ، خْزَارْ، أَقَا يُوسَا-د إِجّْ ن ڒْغَاشِي أَكْ-ذ ونِّي إِ ذ أَسْ قَّارنْ يَاهُوذَا، ونِّي ذ إِجّنْ زِي ثنْعَاشْ، ؤُشَا نتَّا ثُوغَا إِزْوَارْ أَسنْ، إِقَارّبْ-د غَارْ يَاسُوع، إِسُّوذمْ إِ-ث، مَاغَارْ أَقَا إِوْشَا أَسنْ إِجّْ ن وسْشَانْ: ”ونِّي إِ غَا سُّوذْمغْ، ذ ونِّي نتَّا!“ \x ◘ \xo 22:‏47 \xt [مت. 26‏:‏47‏-‏56؛ مك. 14‏:‏43‏-‏50؛ يُوح. 18‏:‏3‏-‏11] — مت. 26‏:‏47؛ مك. 14‏:‏43؛ يُوح. 18‏:‏3. \x*  
\v 48 إِنَّا أَسْ يَاسُوع: ”\add أَ\add* يَاهُوذَا، مَا س ؤُسُوذمْ أَذْ ثغْذَارذْ مِّيسْ ن بْنَاذمْ؟“  
\v 49 ؤُمِي ژْرِينْ إِنِّي ذ أَسْ د-إِنّْضنْ مِينْ إِمْسَارنْ، نَّانْ أَسْ: ”أَ سِيذِيثْنغْ، مَا أَذْ ث نوّثْ س ڒسْيُوفْ؟“  
\v 50 إِجّنْ زَّايْسنْ ثُوغَا إِوْثَا أَمْسخَّارْ ن أَرَّايْسْ ن إِكهَّاننْ، إِقسّْ أَسْ أَمزُّوغْ أَفُوسِي. \x ◘ \xo 22:‏50 \xt مت. 26‏:‏51؛ مك. 14‏:‏47. \x*  
\v 51 إِطّفْ يَاسُوع ذڭْ وَاوَاڒْ، إِنَّا: ”صَافِي، بَارَاكَا!“ خنِّي إِحَاذَا أَسْ أَمزُّوغْ ؤُشَا إِسّْڭنْفَا إِ-ث.   
\m
\v 52 إِنَّا يَاسُوع إِ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ذ إِمْڭوَّاذنْ ن إِعسَّاسنْ ن زَّاوشْثْ ثَامقّْرَانْثْ، إِنِّي ثُوغَا غَارسْ د-يُوسِينْ: ”مَا ثفّْغمْ-د غَارِي أَخْمِي د-ثفّْغمْ غَارْ إِجّْ ن ؤُخوَّانْ، س ڒسْيُوفْ ذ إِعُومَاذْ، مَاحنْذْ أَذْ أَيِي ثتّْفمْ؟ \x ◘ \xo 22:‏52 \xt مت. 26‏:‏55؛ مك. 14‏:‏48. \x*  
\v 53 أَسّْ خْ وَاسّْ ثُوغَا أَيِي أَكِيذْومْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، كنِّيوْ وَارْ غَارِي ثسّْوِيژّْضمْ س إِفَاسّنْ، مَاشَا ثَا ذ ثَاسَاعّثْ نْومْ ذ صُّولْطَا ن ثَادْجسْثْ.“   
\b  
\m  
\s1 أَنْكَارْ ن بُوطْرُوسْ  
\m
\v 54 طّْفنْ ث، نذْهنْ ث ؤُشَا سِّيذْفنْ ث ذِي ثَادَّارْثْ ن أَرَّايْسْ ن إِكهَّاننْ. ؤُشَا إِضْفَارْ إِ-ث شِيمْعُونْ زِي ڒَاڭّْوَاجْ. \x ◘ \xo 22:‏54 \xt [مت. 26‏:‏57‏-‏58، 69‏-‏75؛ مك. 14‏:‏53‏-‏54، 66‏-‏72؛ يُوح. 18‏:‏12‏-‏18، 25‏-‏27] — مت. 26‏:‏57؛ مك. 14‏:‏53؛ يُوح. 18‏:‏12، 24. \x*  
\v 55 نِيثْنِي سَّارْغنْ ثِيمسِّي ذِي ڒْوسْطْ ن ڒمْرَاحْ، خنِّي قِّيمنْ ذڭْ ونّضْ نّسْ. ؤُشَا شِيمْعُونْ إِقِّيمْ جَارْ أَسنْ. \x ◘ \xo 22:‏55 \xt مت. 26‏:‏69؛ مك. 14‏:‏54، 66؛ يُوح. 18‏:‏16، 25. \x*  
\v 56 ثژْرَا إِ-ث إِشْثْ ن ثَايَّا أَمْ إِقِّيمْ غَارْ ثْمسِّي ؤُشَا ثخْزَارْ ذَايسْ مْلِيحْ، ثنَّا: ”ؤُڒَا ذ وَا ثُوغَا-ث أَكِيذسْ.“  
\v 57 مَاشَا نتَّا إِنْكَارْ ث، إِنَّا: ”\add أَ\add* ثَامْغَارْثْ، نشّْ وَارْ ث سِّينغْ!“  
\v 58 وَارْ ذِينْ مِينْ إِعْذُونْ إِژْرَا إِ-ث ونّغْنِي، إِنَّا: ”ؤُڒَا ذ شكْ ذ إِجّنْ زَّايْسنْ.“ مَاشَا بُوطْرُوسْ إِنَّا: ”وَارْ إِدْجِي بُو ذ نشّْ!“  
\v 59 ؤُمِي ثعْذُو عْڒَاحَاڒْ إِشْثْ ن ثْسَاعّثْ، إِبْذَا ونّغْنِي أَذْ إِقَاشحْ، إِنَّا: ”س ثِيذتّْ، ؤُڒَا ذ وَا ثُوغَا-ث أَكِيذسْ، مِينْزِي ؤُڒَا ذ نتَّا ذ أَجَالِيلِي.“  
\v 60 إِنَّا بُوطْرُوسْ: ”\add أَ\add* بْنَاذمْ، نشّْ وَارْ سِّينغْ مِينْ خفْ ثسَّاوَاڒذْ!“ ڒخْذنِّي، أَمْ ثُوغَا عَاذْ إِسَّاوَاڒْ، إِسّْقُوقعْ ؤُيَاژِيضْ.  
\v 61 إِنّقْڒبْ يَاسُوع ؤُشَا إِخْزَارْ غَارْ بُوطْرُوسْ. ؤُشَا إِعْقڒْ شِيمْعُونْ خْ وَاوَاڒْ إِ ذ أَسْ إِنَّا سِيذِيثْنغْ: ”قْبڒْ إِ غَا إِسّْقُوقعْ ؤُيَاژِيضْ، أَذْ أَيِي ثنْكَارذْ ثْڒَاثَا ن ثْوَاڒَاوِينْ!“ \x ◘ \xo 22:‏61 \xt مت. 26‏:‏34، 75؛ مك. 14‏:‏72؛ يُوح. 13‏:‏38؛ 18‏:‏27. \x*  
\v 62 ؤُشَا إِفّغْ-د شِيمْعُونْ بَارَّا، إِرُو إِمطَّاونْ إِمرْزَاڭنْ.   
\b  
\m  
\s1 أَسحْقَارْ ن يَاسُوع  
\m
\v 63 إِرْيَازنْ نِّي إِطّْفنْ يَاسُوع، ثُوغَا سْثْهزَّانْ زَّايسْ، \x ◘ \xo 22:‏63 \xt [مت. 26‏:‏67‏-‏68؛ مك. 14‏:‏65] — أَيُوبْ 16‏:‏10؛ إِشا. 50‏:‏6؛ مت. 26‏:‏67؛ مك. 14‏:‏6؛ يُوح. 19‏:‏3. \x*  
\v 64 ذْڒِينْ \add ثِيطَّاوِينْ نّسْ\add*، \add خنِّي\add* وْثِينْ ث غَارْ ؤُغمْبُوبْ، نَّانْ: ”نَابّْ، مَانْ ونْ إِ شكْ إِوْثِينْ؟“  
\v 65 س وَاطَّاسْ ن ثْمسْڒَايِينْ نّغْنِي ثُوغَا تّْشقَّافنْ ذَايسْ، سَّاوَاڒنْ ضِيدّْ نّسْ.   
\b  
\m  
\s1 يَاسُوع زَّاثْ إِ جْمَاعثْ ثَامقّْرَانْثْ ن وُوذَاينْ  
\m
\v 66 ؤُمِي د-يِيوضْ ؤُزِيڒْ، مُوننْ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ذ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ؤُشَا نذْهنْ ث غَارْ وخَّامْ ن جْمَاعثْ نْسنْ. \x ◘ \xo 22:‏66 \xt [مت. 26‏:‏59‏-‏66؛ مك. 14‏:‏55‏-‏64؛ يُوح. 18‏:‏19‏-‏24] — إِزهد. 2‏:‏2؛ مت. 27‏:‏1؛ مك. 15‏:‏1؛ يُوح. 18‏:‏28. \x*  
\v 67 نَّانْ أَسْ: ”مَاڒَا شكْ ذ لْمَاسِيحْ، \add خنِّي\add* إِنِي أَنغْ ث.“ إِنَّا أَسنْ: ”مَاڒَا نِّيغْ أَومْ ث، وَارْ ذَايِي ثتِّيمْنمْ،  
\v 68 ؤُ مَاڒَا سّقْسِيغْ كنِّيوْ، وَارْ خَافِي د-ثَارِّيمْ نِيغْ وَارْ ذ أَيِي ثَارخُّومْ.  
\v 69 زِي ڒخُّو ذ ثْسَاونْثْ أَذْ إِقِّيمْ مِّيسْ ن بْنَاذمْ خْ ؤُفُوسْ أَفُوسِي ن جّهْذْ ن أَربِّي.“ \x ◘ \xo 22:‏69 \xt دَان. 7‏:‏9؛ مت. 16‏:‏27؛ 24‏:‏30؛ 25‏:‏31؛ 26‏:‏64؛ مك. 14‏:‏62؛ ڒخ. 1‏:‏11؛ 1 تس. 1‏:‏10؛ أَسَا. 1‏:‏7. \x*  
\v 70 نَّانْ مَارَّا: ”مَا شكْ ذ مِّيسْ ن أَربِّي؟“ إِنَّا أَسنْ: ”كنِّيوْ \add س يِيخفْ نْومْ\add* ثقَّارمْ، أَقَا ذ نشّْ!“  
\v 71 نَّانْ: ”ؤُمِي نحْذَاجْ عَاذْ ڒشْهُوذْ؟ مِينْزِي أَقَا نشِّينْ \add س يِيخفْ نّغْ\add* نسْڒَا ث زڭْ ؤُقمُّومْ نّسْ.“   
\b  
\b  
\m  
\c 23
\s1 بِيلَاطُوسْ إِسّقْسَا يَاسُوع  
\m
\v 1 مَارَّا ثْمسْمُونْثْ نْسنْ ثكَّارْ ؤُشَا نِيثْنِي نذْهنْ ث غَارْ بِيلَاطُوسْ. \x ◘ \xo 23:‏1 \xt [مت. 27‏:‏1‏-‏2، 11‏-‏14؛ مك. 15‏:‏1‏-‏5؛ يُوح. 18‏:‏28‏-‏38] — مت. 27‏:‏2؛ مك. 15‏:‏1؛ يُوح. 18‏:‏28. \x*  
\v 2 بْذَانْ أَذْ ث ضڒْمنْ، نَّانْ: ”نشِّينْ نُوفَا أَقَا وَا إِسّفْسذْ ڒْڭنْسْ نّغْ أَمْ إِمنّعْ أَذْ وْشنْ ضَّارِيبَا إِ كُوڒْ أَزدْجِيفْ إِ قَايْصَارْ، إِقَّارْ بلِّي نتَّا ذ أَجدْجِيذْ، لْمَاسِيحْ!“ \x ◘ \xo 23:‏2 \xt مت. 17‏:‏25؛ 22‏:‏21؛ مك. 12‏:‏17؛ لك. 20‏:‏25؛ ڒخ. 17‏:‏7؛ رُوم. 13‏:‏7. \x*  
\v 3 إِسّقْسَا ث بِيلَاطُوسْ، إِنَّا: ”مَا شكْ ذ أَجدْجِيذْ ن وُوذَاينْ؟“ يَارَّا-د، إِنَّا: ”شكْ إِ ث إِقَّارنْ!“ \x ◘ \xo 23:‏3 \xt مت. 27‏:‏11؛ مك. 15‏:‏2؛ يُوح. 18‏:‏33. \x*   
\m
\v 4 إِنَّا بِيلَاطُوسْ إِ ڒْغَاشِي ؤُ إِ إِمقّْرَاننْ ن إِكهَّاننْ: ”أَقَا وَارْ ؤُفِيغْ بُو ؤُڒَا ذ إِجّْ ن ڒْعِيبْ ذِي بْنَاذمْ-أَ!“  
\v 5 \add مَاشَا\add* سْغُوينْ نِيثْنِي، نَّانْ: ”نتَّا إِسّْغوَّاغْ ڒْڭنْسْ، إِسّڒْمَاذْ ذِي مَارَّا يَاهُوذِييَّا، إِبْذَا زِي لْجَالِيلْ أَڒْ ذَا.“  
\v 6 ؤُمِي إِسْڒَا بِيلَاطُوسْ ’لْجَالِيلْ‘، إِسّقْسَا: ”مَا أَرْيَازْ-أَ ذ أَجَالِيلِي؟“  
\v 7 ؤُمِي إِفْهمْ بلِّي نتَّا ثُوغَا سَاذُو ؤُفُوسْ ن هِيرُوذُوسْ، إِسّكّْ إِ-ث غَارْ هِيرُوذُوسْ، مِينْزِي وَانِيثَا ثُوغَا-ث ذِي ؤُرْشَالِيمْ ذڭْ وُوسَّانْ نِّي. \x ◘ \xo 23:‏7 \xt لك. 3‏:‏1. \x*   
\b  
\m  
\s1 يَاسُوع زَّاثْ إِ هِيرُوذُوسْ  
\m
\v 8 أَڒَامِي إِژْرَا هِيرُوذُوسْ يَاسُوع، إِفَارْحْ أَطَّاسْ، مِينْزِي أَطَّاسْ زڭْ وَامِي ثُوغَا إِخْسْ أَذْ ث إِژَارْ، مِينْزِي إِسْڒَا خَاسْ أَطَّاسْ ن ثْمسْڒَايِينْ، ؤُ ثُوغَا إِسِّيثِيمْ أَذْ زَّايسْ إِژَارْ شَا ن ڒعْڒَامثْ. \x ◘ \xo 23:‏8 \xt لك. 9‏:‏7. \x*  
\v 9 إِسّقْسَا ث خْ وَاطَّاسْ ن ثْمسْڒَايِينْ، مَاشَا يَاسُوع وَارْ خَاسْ د-يَارِّي س شَا.  
\v 10 إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ كَّارنْ، ضڒْمنْ ث س ڒْحَارّثْ.  
\v 11 هِيرُوذُوسْ أَكْ-ذ ڒْعسْكَارْ نّسْ سّحْقَارنْ ث، ؤُ أَوَارْنِي ڒَامِي إِسْثهْزَا زَّايسْ، يَارْضْ أَسْ إِجّْ ن ؤُسڒْهَامْ أَذهْمَانِي، ؤُشَا إِسّكّْ إِ-ث غَارْ بِيلَاطُوسْ.  
\v 12 ذوْڒنْ بِيلَاطُوسْ ذ هِيرُوذُوسْ ذ إِمدُّوكَّاڒْ ذڭْ وَاسّْ نِّي، مِينْزِي قْبڒْ ثُوغَا ذِينْ ڒعْذَاوثْ جَارْ أَسنْ. \x ◘ \xo 23:‏12 \xt ڒخ. 4‏:‏27. \x*   
\b  
\m  
\s1 ڒْحُوكْمْ خْ يَاسُوع س ڒْموْثْ  
\m
\v 13 \add خَاسْ ؤُشَا\add* إِڒَاغَا بِيلَاطُوسْ خْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمقّْرَاننْ ن ڒْڭنْسْ، إِنَّا أَسنْ: \x ◘ \xo 23:‏13 \xt [مت. 27‏:‏15‏-‏26؛ مك. 15‏:‏6‏-‏15؛ يُوح. 18‏:‏39‏-‏40؛ 19‏:‏1‏-‏16] — مت. 27‏:‏23؛ مك. 15‏:‏14؛ يُوح. 18‏:‏38؛ 19‏:‏4. \x*  
\v 14 ”كنِّيوْ ثِيوْيمْ أَيِي-د بْنَاذمْ-أَ أَمْ يِيجّنْ ونِّي إِسّْعِيدْجنْ ڒْڭنْسْ نْومْ. خْزَارْ، نشّْ سّقْسِيغْ ث زَّاثْومْ، وَارْ ؤُفِيغْ ؤُڒَا ذ إِجّْ ن ڒْعِيبْ ذڭْ ورْيَازْ-أَ زِي جِّيهثْ مَارَّا إِ زَّايسْ ثتّْشثْشَامْ خَاسْ كنِّيوْ.  
\v 15 ؤُڒَا ذ هِيرُوذُوسْ \add وَارْ ذَايسْ يُوفِي شَا\add*، مِينْزِي نشّْ سّكّغْ ث غَارسْ. ؤُ خْزَارْ، وَارْ ذِينْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ إِ إِڭَّا ثسْذَاهدْجْ ڒْموْثْ.  
\v 16 نشّْ أَذْ ث هتّْكغْ س ؤُركُّوضْ ؤُشَا أَذْ أَسْ أَرْخُوغْ.“  
\v 17 مَاغَارْ ثُوغَا ذِينْ إِشْثْ ن ثْنَامِيثْ مَاحنْذْ أَذْ أَسنْ يَارْخُو إِ يِيجّنْ ذِي ڒْعِيذْ. \x ◘ \xo 23:‏17 \xt مت. 27‏:‏15؛ مك. 15‏:‏6؛ يُوح. 18‏:‏39. \x*  
\v 18 مَاشَا مَارَّا ڒْغَاشِي إِسْغُويْ ذڭْ إِجّْ ن ؤُمُورْ، إِنَّا: ”كّْسمْ وَا، أَرْخُو أَنغْ-د إِ بَارْ-أَبَّاسْ!“ \x ◘ \xo 23:‏18 \xt ڒخ. 3‏:‏14. \x*  
\v 19 وَا ثُوغَا إِتّْوَامّنْضَارْ ذِي ڒحْبسْ خْ سِّيبّثْ ن إِجّْ ن ؤُغُووّغْ إِ إِمْسَارنْ ذِي ثنْذِينْثْ ؤُ \add خْ سِّيبّثْ ن\add* ونْغَايْ.  
\v 20 إِسِّيوڒْ بِيلَاطُوسْ عَاوذْ أَكِيذْسنْ، مِينْزِي ثُوغَا إِخْسْ أَذْ يَارْخُو إِ يَاسُوع.  
\v 21 مَاشَا سْغُوينْ نِيثْنِي، نَّانْ: ”صلّْبْ إِ-ث! صلّْبْ إِ-ث!“  
\v 22 إِنَّا أَسنْ إِ ثْوَاڒَا وِيسّْ ثْڒَاثَا: ”مَانْ ثُوعفّْنَا إِڭَّا وَا \add خنِّي\add*؟ نشّْ وَارْ ذَايسْ ؤُفِيغْ بُو ؤُخطُّو إِ \add إِسْذَاهدْجنْ\add* ڒْموْثْ؟ س ؤُينِّي أَوَارْنِي ڒَامِي ث هتّْكغْ س ؤُركُّوضْ، أَذْ أَسْ أَرْخُوغْ!“  
\v 23 مَاشَا نِيثْنِي زِييَّارنْ خَاسْ س ثْمِيجَّاوِينْ جّهْذنْثْ، تَّارنْ \add مَاحنْذْ\add* أَذْ ث صلّْبنْ. ثِيمِيجَّاوِينْ نْسنْ ذ ثنِّي ن إِمقّْرَاننْ ن إِكهَّاننْ ثُوغَا أَرنّْينْثْ ذِي جّهْذْ.  
\v 24 \add خنِّي\add* إِحْكمْ بِيلَاطُوسْ أَذْ أَسنْ إِقْضَا شْغڒْ نْسنْ. \x ◘ \xo 23:‏24 \xt مت. 27‏:‏26؛ مك. 15‏:‏15؛ يُوح. 19‏:‏16. \x*  
\v 25 إِضْڒقْ أَسنْ إِ ونِّي إِمّنْضَارنْ ذِي ڒحْبسْ زِي سِّيبّثْ ن ؤُغُووّغْ ذ ونْغَايْ، ذ ونِّي تَّارنْ نِيثْنِي، مَاشَا إِسلّمْ يَاسُوع \add إِ نِيثْنِي\add* خْ ڒحْسَابْ ڒْخَاضَارْ نْسنْ.   
\b  
\m  
\s1 أَبْرِيذْ غَارْ صَّالِيبْ  
\m
\v 26 ؤُمِي ث ڭوّْذنْ سّنِّي، طّْفنْ شِيمْعُونْ زِي قَايْرَاوَانْ، ثُوغَا يُوسَا-د زِي ڒْكَامْپُو، ؤُشَا سَّارْسنْ خَاسْ صَّالِيبْ حِيمَا أَذْ \add ث\add* يَارْبُو أَوَارْنِي يَاسُوع. \x ◘ \xo 23:‏26 \xt [مت. 27‏:‏32‏-‏44؛ مك. 15‏:‏21‏-‏32؛ يُوح. 19‏:‏17‏-‏19]\x*  
\v 27 إِضْفَارْ إِ-ث-إِ-د إِجّْ ن ڒْغَاشِي ن إِوْذَانْ ذ ثمْغَارِينْ نِّي ثُوغَا إِوْثِينْ أَڭجْذُورْ، تّْرُونْثْ خَاسْ.  
\v 28 إِنّقْڒبْ-د غَارْسنْثْ يَاسُوع، إِنَّا: ”\add أَ\add* يسِّيسْ ن ؤُرْشَالِيمْ، وَارْ تّْرُونْثْ شَا خَافِي، مَاشَا رُونْثْ خْ إِخفْ نْكنْثْ ذ ثَارْوَا نْكنْثْ.  
\v 29 مِينْزِي أَذْ د-أَسنْ وُوسَّانْ إِ ذِي إِ غَا إِنِينْ: ’سّعْذْ ن ثمْغَارِينْ إِ وَارْ إِزمَّارنْ أَذْ ؤُرْونْثْ ؤُ \add سّعْذْ ن\add* إِعذِّيسنْ نِّي وَارْ يُورْونْ، ذ ثِيبَّاشْ ثِينِّي وَارْ إِسُّوطُّوضنْ!‘  
\v 30 خنِّي أَذْ إِنِينْ إِ إِذُورَارْ: ’وْضَامْ-د خَانغْ!‘، ؤُ إِ ثِيوْرِيرِينْ: ’ذْڒنْثْ أَنغْ!‘ \x ◘ \xo 23:‏30 \xt إِشا. 2‏:‏19؛ حُوش. 10‏:‏8؛ أَسَا. 6‏:‏16؛ 9‏:‏6. \x*  
\v 31 مِينْزِي مَاڒَا ڭِّينْ أَيَا س ؤُكشُّوضْ أَزِيزَا، مِينْ غَا إِمْسَارنْ خنِّي إِ \add ؤُكشُّوضْ\add* يُوژْغنْ؟“ \x ◘ \xo 23:‏31 \xt إِرْم. 25‏:‏29؛ 1 بُط. 4‏:‏17. \x*  
\v 32 نذْهنْ أَكِيذسْ عَاوذْ ثْنَاينْ نّغْنِي إِنِّي ثُوغَا إِقطّْعنْ أَبْرِيذْ، حِيمَا أَذْ ثنْ نْغنْ \add أَكِيذسْ\add*. \x ◘ \xo 23:‏32 \xt يُوح. 19‏:‏18. \x*   
\m
\v 33 ڒَامِي إِوْضنْ غَارْ ومْشَانْ ؤُمِي قَّارنْ ’ثَاشقُّوفْثْ‘، صلّْبنْ ث ذِينْ أَكْ-ذ يِينِّي ثُوغَا إِقطّْعنْ أَبْرِيذْ، إِجّنْ خْ يفُوسْ نّسْ ؤُ ونّغْنِي خْ ؤُزڒْمَاضْ نّسْ. \x ◘ \xo 23:‏33 \xt مت. 27‏:‏33، 38؛ مك. 15‏:‏22؛ يُوح. 19‏:‏18. \x*  
\v 34 مَاشَا يَاسُوع إِنَّا: ”\add أَ\add* بَابَا، غْفَارْ أَسنْ، مِينْزِي نِيثْنِي وَارْ سِّيننْ مِينْ تّڭّنْ!“ ؤُشَا بْضَانْ أَرُّوضْ نّسْ، نْضَارنْ خَاسْ أَكشُّوضْ. \x ◘ \xo 23:‏34 \xt إِزهد. 22‏:‏19؛ مت. 27‏:‏35؛ مك. 15‏:‏24؛ يُوح. 19‏:‏23؛ ڒخ. 7‏:‏60؛ 1 كُور. 4‏:‏12. \x*  
\v 35 ثُوغَا إِوْذَانْ بدّنْ ذِينْ، خزَّارنْ. ؤُڒَا ذ إِمقّْرَاننْ \add ن ڒْڭنْسْ\add* سْثْهزَّانْ زَّايسْ، نَّانْ: ”ثُوغَا إِسّنْجمْ إِنّغْنِي، ڒخُّو أجّْ إِ-ث أَذْ إِسّنْجمْ إِخفْ نّسْ مَاڒَا نتَّا ذ لْمَاسِيحْ، ذ ونِّي إِتّْوَافَارْزنْ زِي أَربِّي؟“  
\v 36 ؤُڒَا ذ إِعسْكَارِييّنْ سْثهْزَانْ زَّايسْ أَمْ غَارسْ د-قَارّْبنْ ؤُشَا وْشِينْ أَسْ ڒْخدْجْ.  
\v 37 نَّانْ أَسْ: ”مَاڒَا شكْ ذ أَجدْجِيذْ ن وُوذَاينْ، \add خنِّي\add* سنْجمْ إِخفْ نّشْ!“  
\v 38 ثُوغَا ذِينْ عَاوذْ إِشْثْ ن ثِيرَا سنّجْ نّسْ، ؤُرِينْ ت \add س لْحُورُوفْ\add* ن ثْيُونَانِيثْ ذ ثْلَاثِينِيثْ ذ ثْعِيبْرَانِيثْ: ’وَا ذ أَجدْجِيذْ ن وُوذَاينْ.‘ \x ◘ \xo 23:‏38 \xt مت. 27‏:‏37؛ مك. 15‏:‏26؛ يُوح. 19‏:‏19. \x*   
\m
\v 39 إِجّنْ زڭْ إِقْطَاطْعِييّنْ إِ يُويْڒنْ أَكِيذسْ، ثُوغَا إِتّْشقَّافْ ذَايسْ، إِقَّارْ: ”مَاڒَا شكْ ذ لْمَاسِيحْ، سنْجمْ إِخفْ نّشْ ؤُڒَا ذ نشِّينْ!“  
\v 40 مَاشَا ونّغْنِي إِوبّخْ إِ-ث، إِنَّا: ”مَا شكْ وَارْ ثڭّْوِيذذْ شَا عَاذْ زِي أَربِّي ؤُمِي شكْ إِڒْقفْ شّْرعْ ذ إِجّنْ؟  
\v 41 نشِّينْ س ڒْحقّْ مِينْزِي نطّفْ أَخدْجصْ ن مِينْ نڭَّا. مَاشَا وَا وَارْ إِڭِّي مِينْ وَارْ إِحْڒِينْ!“  
\v 42 \add خَاسْ ؤُشَا\add* إِنَّا إِ يَاسُوع: ”عْقڒْ خَافِي، \add أَ\add* سِيذِي إِنُو، خْمِي د غَا ثَاسذْ ذِي ثْڭلْذِيثْ نّشْ.“  
\v 43 إِنَّا أَسْ يَاسُوع: ”س ثِيذتّْ، نشّْ أَذْ أَشْ إِنِيغْ، أَقَا أَسّْ-أَ أَذْ ثِيڒِيذْ أَكِيذِي ذِي جّنّثْ.“   
\b  
\m  
\s1 ڒْموْثْ ن يَاسُوع  
\m
\v 44 ثُوغَا ثَاسَاعّثْ عْڒَاحَاڒْ ذ ستَّا، \add أَقَا-ت ذ ضّْهُورْ\add*، خنِّي ثوْضَا-د ثَادْجسْثْ خْ ثمُّورْثْ مَارَّا أَڒَامِي ذ ثسْعَا، \add أَقَا-ت ذ ثْڒَاثَا ن ؤُعشِّي\add*. \f ◼ \fr 23:‏44 \ft \+bd ’ستَّا‘\+bd* - إِخْسْ أَذْ يِينِي ’ثُوغَا ذ أَزْينْ ن وَاسّْ‘. \+bd ’ثسْعَا‘\+bd* - إِخْسْ أَذْ يِينِي ’ثَاسَاعّثْ ثُوغَا-ت ذ ثْڒَاثَا ن وزْينْ ن وَاسّْ‘.\f*  \x ◘ \xo 23:‏44 \xt [مت. 27‏:‏45‏-‏56؛ مك. 15‏:‏33‏-‏41؛ يُوح. 19‏:‏28‏-‏30] — مت. 27‏:‏45؛ مك. 15‏:‏33. \x*  
\v 45 \add خنِّي\add* ثبَّارْشنْ ثْفُوشْثْ ؤُشَا أَڒحَّافْ ن وَاذَافْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ إِتّْوَاشَارّڭْ ذڭْ وزْينْ. \x ◘ \xo 23:‏45 \xt مت. 27‏:‏51؛ مك. 15‏:‏38. \x*  
\v 46 يَاسُوع إِڒَاغَا س جّهْذْ، إِنَّا: ”\add أَ\add* بَابَا، ذڭْ إِفَاسّنْ نّشْ أَذْ سَّارْسغْ أَرُّوحْ إِنُو.“ ؤُمِي إِنَّا أَيَا، إِسلّمْ إِخفْ نّسْ \add غَارسْ\add*. \x ◘ \xo 23:‏46 \xt إِزهد. 31‏:‏6؛ مت. 27‏:‏50؛ مك. 15‏:‏37؛ يُوح. 19‏:‏30؛ ڒخ. 7‏:‏59. \x*  
\v 47 ؤُمِي إِژْرَا ڒْقبْطَانْ خْ مْيَا مِينْ ثُوغَا إِمْسَارنْ، إِبْذَا إِسّمْغَارَا ذِي أَربِّي، إِنَّا: ”س ثِيذتّْ ثُوغَا بْنَاذمْ-أَ ذ أَمْسڭَّاذْ!“ \x ◘ \xo 23:‏47 \xt مت. 27‏:‏54؛ مك. 15‏:‏39. \x*   
\m
\v 48 ؤُمِي مَارَّا ڒْغَاشِي إِ ذ إِمُوننْ حِيمَا أَذْ ژَترنْ أَفُورّجْ-أَ، ژْرِينْ مِينْ إِمْسَارنْ،عقْبنْ أَمْ وْثِينْ ذڭْ إِذْمَارنْ نْسنْ.  
\v 49 مَارَّا إِنِّي إِسّْننْ يَاسُوع ذ ثمْغَارِينْ إِ كِيذسْ د-يُوسِينْ زِي لْجَالِيلْ، بدّنْ غَارْ ڒَاڭّْوَاجْ، ژْرِينْ \add مَارَّا\add* أَيَا.   
\b  
\m  
\s1 أَنْضڒْ ن يَاسُوع  
\m
\v 50 إِجّْ ن ورْيَازْ، قَّارنْ أَسْ يُوسُوفْ، ثُوغَا-ث ذ أَمْشَاوَارْ ذِي جْمَاعثْ \add ثَامقّْرَانْثْ\add*. نتَّا زِي رَامْثَا، إِشْثْ ن ثنْذِينْثْ ذِي يَاهُوذَا، أَقَا-ث ذ إِجّْ ن ورْيَازْ ذ أَصبْحَانْ ذ أَمْسڭَّاذْ. \f ◼ \fr 23:‏50 \ft \+fk جْمَاعثْ \+bdit ثَامقّْرَانْثْ\+bdit*‘ - نِيغْ: ’جْمَاعثْ ن ڒْحُوكَّامْ إِمقّْرَاننْ ن وُوذَاينْ‘.\f*  \x ◘ \xo 23:‏50 \xt [مت. 27‏:‏57‏-‏61؛ مك. 15‏:‏42‏-‏47؛ يُوح. 19‏:‏38‏-‏42] — مت. 27‏:‏57؛ مك. 15‏:‏43؛ يُوح. 19‏:‏38. \x*  
\v 51 نتَّا وَارْ يَارْضِي شَا خْ شّْوَارْ نْسنْ ؤُ خْ مِينْ ڭِّينْ، ؤُ نتَّا ثُوغَا إِتّْرَاجَا ثَاڭلْذِيثْ ن أَربِّي.  
\v 52 وَانِيثَا يُويُورْ غَارْ بِيلَاطُوسْ ؤُشَا إِتَّارْ \add أَسْ\add* أَرِّيمثْ ن يَاسُوع.  
\v 53 إِسّهْوَا ت-إِ-د \add زِي صَّالِيبْ\add*، إِنّضْ إِ-ت ذڭْ إِشْثْ ن ثْخيَّاضْثْ ن ڒقْطنْ \add أَزْذَاذْ\add* ؤُشَا إِسَّارْسْ إِ-ت ذڭْ ونْضڒْ إِ إِغْزَا ذِي سّدْجَاحْ مَانِي وَارْ إِنْضِيڒْ حذْ عَاذْ. \x ◘ \xo 23:‏53 \xt مت. 12‏:‏40؛ 26‏:‏12؛ 27‏:‏59؛ مك. 15‏:‏46. \x*  
\v 54 ثُوغَا ذ أَسّْ ن ؤُسوْجذْ، أَقَا سّبْثْ ثْقَارّبْ-د.   
\m
\v 55 ثِيمْغَارِينْ إِ كِيذسْ د-يُوسِينْ زِي لْجَالِيلْ، قَارّْبنْثْ-إِ-د، ژْرِينْثْ أَنْضڒْ ذ مَامّشْ سَّارْسنْ أَرِّيمثْ نّسْ. \x ◘ \xo 23:‏55 \xt لك. 8‏:‏2. \x*  
\v 56 \add خَاسْ ؤُشَا\add*عقْبنْثْ، سّوْجْذنْثْ ڒعْطُورْ ذ زّشْثْ إِتّْفُوحنْ، \add مَاشَا\add* ذِي سّبْثْ أَريّْحنْثْ أَمْ مَامّشْ ثدْجَا ذِي ثوْصيّثْ. \x ◘ \xo 23:‏56 \xt مك. 15‏:‏47\x*   
\b  
\b  
\m  
\c 24
\s1 ثَانُوكْرَا  
\m
\v 1 ذڭْ \add وَاسّْ\add* أَمزْوَارْ \add ن سِّيمَانَا\add* غَارْ صّْبحْ، ڒَامِي ثُوغَا عَاذْ ذ ثَادْجسْثْ، رُوحنْثْ غَارْ ونْضڒْ، كْسِينْثْ ڒعْطُورْ إِ ثُوغَا سّوْجْذنْثْ، ؤُ ثُوغَا ذِينْ \add عَاذْ\add* ثِيمْغَارِينْ نّغْنِي أَكِيذْسنْثْ. \x ◘ \xo 24:‏1 \xt [مت. 28‏:‏1‏-‏10؛ مك. 16‏:‏1‏-‏8؛ يُوح. 20‏:‏1‏-‏10] — مت. 28‏:‏1؛ مك. 16‏:‏1؛ يُوح. 20‏:‏1. \x*  
\v 2 أَقَا ؤُفِينْثْ، ثَاصْضَارْثْ إِ ثُوغَا خْ ونْضڒْ، ثتّْوَاسّقْنُونِي زَّايسْ.  
\v 3 ؤُذْفنْثْ، \add مَاشَا\add* وَارْ ؤُفِينْثْ شَا أَرِّيمثْ ن يَاسُوع.   
\m
\v 4 أَمْ ثْبهْثنْثْ ذِي مَانْ أَيَا، خْزَارْ، أَقَا ذِينْ ثْنَاينْ ن يرْيَازنْ ذڭْ وَارُّوضْ إِتِّيسِّيقنْ، بدّنْ سنّجْ نْسنْثْ.  
\v 5 نِيثنْثِي ڭّْوذنْثْ أَطَّاسْ ؤُشَا قْبَاڒنْثْ أَزدْجِيفْ نْسنْثْ غَارْ ثمُّورْثْ. نِيثْنِي \add مَاشَا\add* نَّانْ أَسنْثْ: ”مَايمِّي ثَارزُّونْثْ خْ ونِّي إِدَّارنْ جَارْ إِمتِّيننْ؟  
\v 6 أَقَا وَارْ ذَا إِدْجِي، مِينْزِي أَقَا إِكَّارْ!عقْڒنْثْ خْ مِينْ ذ أَكنْثْ إِنَّا ؤُمِي ث ثُوغَا عَاذْ ذِي لْجَالِيلْ، \x ◘ \xo 24:‏6 \xt مت. 16‏:‏21؛ 17‏:‏22؛ 20‏:‏18؛ مك. 8‏:‏31؛ 9‏:‏31؛ 10‏:‏33؛ لك. 9‏:‏22؛ 18‏:‏31. \x*  
\v 7 إِنَّا: ’أَقَا ثُورَا بلِّي مِّيسْ ن بْنَاذمْ أَذْ إِمّوْشْ ذڭْ إِفَاسّنْ ن إِمذْنَابْ، أَذْ إِتّْوَاصلّبْ ؤُشَا ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا أَذْ د-إِكَّارْ.‘ “   
\m
\v 8 \add خنِّي\add*عقْڒنْثْ خْ وَاوَاڒنْ نّسْ. \x ◘ \xo 24:‏8 \xt يُوح. 2‏:‏22. \x*  
\v 9 عقْبنْثْ-إِ-د زڭْ ونْضڒْ ؤُشَا خبَّارنْثْ مَارَّا مَانْ أَيَا إِ حِيطَاشْ ؤُ إِ إِنّغْنِي. \x ◘ \xo 24:‏9 \xt مت. 28‏:‏8؛ مك. 16‏:‏10. \x*  
\v 10 إِنَا ثُوغَا ذ مَارْيَامْ ن مَاجْذَالَا ذ يُوحَانَّا ذ مَارْيَامْ، يمَّاسْ ن يَاعْقُوبْ، ذ مِينْ ثُوغَا إِقِّيمنْ \add ن ثمْغَارِينْ\add* إِ إِدْجَانْ أَكِيذْسنْثْ، حَاجَانْثْ نِيثنْثِي مَانْ أَيَا إِ رُّوسُولْ.  
\v 11 نِيثْنِي حسْبنْ أَوَاڒنْ-أَ ذ أَطمّسْ ؤُشَا وَارْ ثنْثْ تِّيقّنْ.   
\m
\v 12 مَاشَا شِيمْعُونْ إِكَّارْ-د، يُوزّڒْ ذغْيَا غَارْ ونْضڒْ، إِخزَّارْ ذَاخڒْ، إِژْرَا ثَاخيَّاضْثْ ن ڒقْطنْ \add أَزْذَاذْ\add* ثتّْوَامَارْسْ غَارْ ؤُغزْذِيسْ. \add خنِّي\add* إِرُوحْ، إِتّبْهثْ ذڭْ يِيخفْ نّسْ س مِينْ إِمْسَارنْ. \x ◘ \xo 24:‏12 \xt يُوح. 20‏:‏3، 6. \x*   
\b  
\m  
\s1 ذڭْ وبْرِيذْ غَارْ عِيمْوَاسْ  
\m
\v 13 ؤُ خْزَارْ، ذڭْ وَاسّْ نِّي ثُوغَا ثْنَاينْ زَّايْسنْ ذڭْ وبْرِيذْ غَارْ إِجّْ ن ذْشَارْ قَّارنْ أَسْ عِيمْوَاسْ، إِڭّْوجْ ستِّينْ ’إِسْثَاذِييّنْ‘ خْ ؤُرْشَالِيمْ، \add عْڒَاحَاڒْ حِيطَاشْ كِيلُومِيثْرْ\add*. \x ◘ \xo 24:‏13 \xt [مك. 16‏:‏12‏-‏13] — مك. 16‏:‏12. \x*  
\v 14 ثُوغَا سَّاوَاڒنْ أَكْ-ذ وَايَاوْيَا خْ مَارَّا مِينْ ثُوغَا إِمْسَارنْ.   
\m
\v 15 أَمْ سَّاوَاڒنْ نِيثْنِي، تّمْسَاوَاضنْ، إِقَارّبْ-د غَارْسنْ يَاسُوع، يُويُورْ أَكِيذْسنْ. \x ◘ \xo 24:‏15 \xt مت. 18‏:‏20؛ لك. 24‏:‏36. \x*  
\v 16 تّْوَاشبَّارنْثْ ثِيطَّاوِينْ نْسنْ أَڒَامِي وَارْ ث عْقِيڒنْ.  
\v 17 إِنَّا أَسنْ: ”مَانْ أَوَاڒنْ-أَ إِ خفْ ثسَّاوَاڒمْ أَكْ-ذ وَايَاوْيَا ذڭْ وبْرِيذْ، أَمْ ثڭُّورمْ ؤُ تّْبَاننْثْ ڒْخژْرَاثْ نْومْ شضْننْثْ؟“  
\v 18 إِجّنْ زَّايْسنْ ؤُمِي قَّارنْ كْلِييُوبَاسْ، إِنَّا أَسْ: ”مَا شكْ ذ أَينِّي ن ؤُبَارَّانِي ذِي ؤُرْشَالِيمْ إِ وَارْ إِسِّيننْ مِينْ ذِينْ إِمْسَارنْ ذڭْ وُوسَّانْ-أَ؟“  
\v 19 إِنَّا أَسنْ: ”مِينْ إِمْسَارنْ؟“ نَّانْ أَسْ: ”مِينْ إِمْسَارنْ إِ يَاسُوع زِي نَّاصِيرَا، ثُوغَا-ث ذ أَنَابِي، ثُوغَا غَارسْ جّهْذْ ذِي مِينْ إِتّڭّْ ؤُ ذِي مِينْ إِسَّاوَاڒْ قِيبَاتْشْ إِ أَربِّي ذ مَارَّا ڒْڭنْسْ. \x ◘ \xo 24:‏19 \xt لك. 7‏:‏16؛ يُوح. 4‏:‏19؛ 6‏:‏14. \x*  
\v 20 سلّْمنْ ث إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add* إِ ڒْحُوكْمْ س ڒْموْثْ ؤُشَا صلّْبنْ ث.  
\v 21 نشِّينْ ثُوغَا نسِّيثِيمْ، أَقَا ذ نتَّا إِ غَا إِسلّْكنْ إِسْرَائِيل، مَاشَا خْزَارْ، أَسّْ-أَ \add عْذُونْ عَاذْ\add* ثْڒَاثَا ن وُوسَّانْ زڭْ وَامِي إِمْسَارْ مَانْ أَيَا مَارَّا. \x ◘ \xo 24:‏21 \xt ڒخ. 1‏:‏6. \x*  
\v 22 مَاشَا شَا ن ثمْغَارِينْ زَّايْنغْ سّْحيَّارنْثْ أَنغْ عَاوذْ، مَاغَارْ نِيثنْثِي رُوحنْثْ زِيشْ غَارْ ونْضڒْ. \x ◘ \xo 24:‏22 \xt مت. 28‏:‏8؛ مك. 16‏:‏10؛ يُوح. 20‏:‏18. \x*  
\v 23 ڒَامِي وَارْ ذِينْ ؤُفِينْثْ أَرِّيمثْ نّسْ، ؤُسِينْثْ-إِ-د، نَّانْثْ: ”أَقَا نژْرَا ذِينْ لْمَالَاكَاثْ، ؤُ \add لْمَالَاكَاثْ\add* نَّانْثْ خَاسْ: ’أَقَا إِدَّارْ!‘ “  
\v 24 شَا زڭْ إِنِّي أَكِيذْنغْ إِدْجَانْ، رُوحنْ غَارْ ونْضڒْ، ؤُفِينْ ثِيمسْڒَايِينْ أَمْ مَامّشْ خَاسْ نَّانْثْ عَاوذْ ثمْغَارِينْ، مَاشَا نتَّا وَارْ ث ژْرِينْ شَا.“   
\m
\v 25 إِنَّا أَسنْ: ”مشْحَاڒْ ذ إِفْغَاڒْ ذ إِنضْقَاڒْ ن وُوڒْ إِ ثدْجَامْ مَاحنْذْ أَذْ ثَامْنمْ ذِي مَارَّا مِينْ سِّيوْڒنْ إِنَابِييّنْ!  
\v 26 مَا وَارْ إِتّْخصِّي أَذْ إِودّبْ لْمَاسِيحْ حِيمَا أَذْ يَاذفْ غَارْ ؤُعُودْجِي نّسْ؟“ \x ◘ \xo 24:‏26 \xt إِشا. 50‏:‏6؛ 53‏:‏5؛ فِيل. 2‏:‏7؛ عبر. 12‏:‏2؛ 1 بُط. 1‏:‏11. \x*  
\v 27 خنِّي إِبْذَا زِي مُوسَا ؤُ زِي مَارَّا إِنَابِييّنْ، إِتّْفسَّارْ أَسنْ خْ يِيخفْ نّسْ زِي مَارَّا ثِيرَا \add إِقدّْسنْ\add*. \x ◘ \xo 24:‏27 \xt أَمز. 3‏:‏15؛ 22‏:‏18؛ 26‏:‏4؛ 49‏:‏10؛ أَعَوذ. 18‏:‏15؛ إِزهد. 132‏:‏11؛ إِشا. 7‏:‏14؛ 9‏:‏5؛ 40‏:‏10؛ إِرْم. 23‏:‏5؛ 33‏:‏14؛ حِز. 34‏:‏23؛ 37‏:‏25؛ دَان. 9‏:‏24؛ مِيخَا 7‏:‏20. \x*   
\m
\v 28 \add ؤُمِي\add* د-قَارّْبنْ غَارْ ذْشَارْ إِ غَارْ ثُوغَا ڭُّورنْ، إِڭَّا نتَّا أَخْمِي ثُوغَا إِخْسْ أَذْ يَارْنِي ذڭْ وبْرِيذْ غَارْ إِجّْ ن ومْشَانْ إِڭّْوجنْ.  
\v 29 \add مَاشَا\add* نِيثْنِي ڭِّينْ خَاسْ بزّزْ، نَّانْ: ”قِّيمْ أَكِيذْنغْ، مِينْزِي ثَامذِّيثْ أَذْ ثوْضَا، أَقَا إِميّڒْ ؤُزِيڒْ.“ ؤُشَا يُوذفْ، إِقِّيمْ أَكِيذْسنْ. \x ◘ \xo 24:‏29 \xt أَمز. 19‏:‏3؛ ڒخ. 16‏:‏15؛ عبر. 13‏:‏2. \x*  
\v 30 إِمْسَارْ أَڒَامِي ثُوغَا أَكِيذْسنْ إِقِّيمْ \add غَارْ ؤُمنْسِي\add* إِكْسِي أَغْرُومْ، إِبَاركْ \add إِ-ث\add*، يَارْژَا \add إِ-ث\add*، خنِّي إِوْشَا أَسنْ \add ث\add*.  
\v 31 ذغْيَا نُّورْزْمنْثْ ثِيطَّاوِينْ نْسنْ،عقْڒنْ ث. \add خَاسْ ؤُشَا\add* إِتّْوَامّكْسِي زَّايْسنْ.   
\m
\v 32 نَّانْ إِجّنْ إِ ونّغْنِي: ”مَا وَارْ ثُوغِي إِذقّڒْ وُوڒْ نّغْ أَڒَامِي ثُوغَا أَكِيذْنغْ إِسَّاوَاڒْ ذڭْ وبْرِيذْ، إِسّفْهَامْ أَنغْ ثِيرَا \add إِقدّْسنْ\add*؟“  
\v 33 ذِي ثْسَاعّثْ نِّي كَّارنْ نِيثْنِي،عقْبنْ غَارْ ؤُرْشَالِيمْ، ؤُشَا ؤُفِينْ حِيطَاشْ \add ن رُّوسُولْ\add* مُوننْ، نِيثْنِي ذ يِينِّي أَكِيذْسنْ.  
\v 34 ؤُشَا نِيثْنِي نَّانْ: ”ذ ثِيذتّْ، أَقَا إِكَّارْ-د سِيذِيثْنغْ، إِبَانْ-د إِ شِيمْعُونْ.“  
\v 35 ؤُڒَا ذ نِيثْنِي خبَّارنْ عَاوذْ س مِينْ إِمْسَارنْ ذڭْ وبْرِيذْ ؤُ مَامّشْ ثعقْڒنْ أَڒَامِي يَارْژَا أَغْرُومْ.   
\b  
\m  
\s1 أَضْهَارْ ن يَاسُوع إِ إِمحْضَارنْ نّسْ  
\m
\v 36 أَمْ ثُوغَا سَّاوَاڒنْ نِيثْنِي خْ مَانْ أَيَا، إِبدّْ يَاسُوع سِيمَانْثْ نّسْ ذِي ڒْوسْطْ نْسنْ، إِنَّا أَسنْ: ”سْڒَامْ خَاومْ، أَقَا ذ نشّْ، وَارْ تّڭّْوذمْ شَا!“ \x ◘ \xo 24:‏36 \xt [مت. 28‏:‏16‏-‏20؛ مك. 16‏:‏14‏-‏18؛ يُوح. 20‏:‏19‏-‏23؛ ؤُف. 1‏:‏6‏-‏8] — مك. 16‏:‏14؛ يُوح. 20‏:‏19؛ 1 كُور. 15‏:‏5. \x*  
\v 37 \add مَاشَا\add* نِيثْنِي نّْخڒْعنْ ؤُشَا ڭّْوذنْ أَطَّاسْ، إِتّْغِيڒْ أَسنْ بلِّي تّْوَاڒَانْ إِجّْ ن ڒخْيَاڒْ.  
\v 38 إِنَّا أَسنْ يَاسُوع: ”مَايمِّي ثتّْنخْڒِيعمْ، مَايمِّي ثتّڭّمْ إِخَارِّيصنْ ذڭْ وُوڒَاونْ نْومْ؟  
\v 39 خْزَارمْ إِفَاسّنْ ذ إِضَارنْ إِنُو، أَقَا ذ \bd نشّْ نشّْ\bd*. حَاذَامْ أَيِي، ؤُ سْنمْ بلِّي إِجّْ ن ڒخْيَاڒْ وَارْ غَارسْ بُو ويْسُومْ ؤُڒَا ذ إِغْسَانْ أَمْ مَامّشْ ذ أَيِي ثتّْوَاڒَامْ.“  
\v 40 ؤُمِي إِنَّا أَيَا، إِسّْشنْ أَسنْ إِفَاسّنْ نّسْ ذ إِضَارنْ نّسْ.  
\v 41 وَارْ ؤُمِيننْ عَاذْ زِي سِّيبّثْ ن ڒفْرَاحثْ، قِّيمنْ تّْبهْثنْ. إِنَّا أَسنْ: ”مَا غَارْومْ ذَا شَا ن مَاشَّا؟“ \x ◘ \xo 24:‏41 \xt يُوح. 21‏:‏10. \x*  
\v 42 وْشِينْ أَسْ إِشْثْ ن ثشْوِيحْثْ ن وسْڒمْ إِشنّْفنْ ذ شَا ن ثزْڒفْثْ ن ثَامّنْثْ.  
\v 43 إِكْسِي ت ؤُشَا إِشَّا إِ-ت قِيبَاتْشْ نْسنْ.   
\b  
\m
\v 44 إِنَّا أَسنْ: ”إِنَا ذ أَوَاڒنْ إِ زِي كِيذْومْ سِّيوْڒغْ ؤُمِي ذ أَيِي ثُوغَا عَاذْ أَكِيذْومْ، أَقَا إِتّْخصَّا أَذْ إِتّْوَاكمّڒْ مَارَّا مِينْ خَافِي يُورَانْ ذِي شَّارِيعَا ن مُوسَا، ذڭْ إِنَابِييّنْ ؤُ ذڭْ إِزهِّيذنْ.“ \x ◘ \xo 24:‏44 \xt مت. 16‏:‏21؛ 17‏:‏22؛ 20‏:‏18؛ مك. 8‏:‏31؛ 9‏:‏31؛ 10‏:‏33؛ لك. 9‏:‏22؛ 18‏:‏31؛ 24‏:‏6. \x*  
\v 45 خنِّي يَارْزمْ أَسنْ ڒعْقڒْ نْسنْ، حِيمَا أَذْ فهْمنْ إِ ثِيرَا \add إِقدّْسنْ\add*.  
\v 46 إِنَّا أَسنْ: ”أَمُّو إِ ثُورَا ؤُ أَمُّو إِ ثُوغَا إِتّْخصَّا أَذْ إِمَارّثْ لْمَاسِيحْ ؤُ أَذْ د-إِكَّارْ زِي ثَادَّارْثْ ن إِمتِّيننْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا، \x ◘ \xo 24:‏46 \xt إِزهد. 22‏:‏7؛ ڒخ. 17‏:‏3. \x*  
\v 47 \add حِيمَا\add* أَذْ إِتّْوَابَارّحْ س تُّوبثْ إِ وغْفَارْ ن دّْنُوبْ إِ مَارَّا ڒڭْنُوسْ س يِيسمْ نّسْ، ذ أَمزْوَارُو ذِي ؤُرْشَالِيمْ. \x ◘ \xo 24:‏47 \xt ڒخ. 13‏:‏38؛ 1 يُوح. 2‏:‏12. \x*  
\v 48 كنِّيوْ ذ ڒشْهُوذْ خْ مَانْ أَيَا. \x ◘ \xo 24:‏48 \xt لك. 9‏:‏15؛ 21‏:‏13\x*  
\v 49 أَقَا نشّْ أَذْ أَومْ د-سّكّغْ لْوَاعْذْ ن بَابَا. قِّيممْ \add مَاشَا\add* ذِي ثنْذِينْثْ ن ؤُرْشَالِيمْ أَڒْ غَا ثتّْوَاسّْيَارْضمْ س جّهْذْ زِي ڒُوعْڒَا!“ \x ◘ \xo 24:‏49 \xt يُوح. 14‏:‏26؛ 15‏:‏26؛ 16‏:‏7؛ ڒخ. 1‏:‏4. \x*   
\b  
\m  
\s1 ثَامكْسِيثْ ن يَاسُوع غَارْ ؤُجنَّا  
\m
\v 50 خنِّي إِنْذهْ إِ-ثنْ غَارْ \add ثنْذِينْثْ ن\add* بَايْثْ-عَانْيَا، إِسّْڭعّذْ إِفَاسّنْ نّسْ ؤُشَا إِبَارْكْ إِ-ثنْ. \x ◘ \xo 24:‏50 \xt [مك. 16‏:‏19‏-‏20؛ ڒخ.1‏:‏9‏-‏11] — ڒخ. 1‏:‏12. \x*  
\v 51 أَوَارْنِي ڒَامِي ثنْ ثُوغَا إِتّْبَارَاكْ، إِمْسَارْ، أَقَا إِمّْسبْضَا خَاسنْ ؤُشَا إِڭّعّذْ غَارْ ؤُجنَّا. \x ◘ \xo 24:‏51 \xt مك. 16‏:‏19 ڒخ. 1‏:‏9. \x*  
\v 52 سجْذنْ أَسْ ؤُشَاعقْبنْ غَارْ ؤُرْشَالِيمْ س ڒفْرَاحثْ ثمْغَارْ.  
\v 53 ثُوغَا-ثنْ ڒبْذَا ذِي زَّاوشْثْ ثَامقّْرَانْثْ، سّمْغَارَانْ ؤُ تّْبَارَاكنْ أَربِّي. أَمِينْ.  
\b  
\m أَنڭَّارْ ن لْ-إِنْجِيلْ إِقدّْسنْ أَمْ مَامّشْ ث إِبَارّحْ لُوكَا.   