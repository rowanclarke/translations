\id REV - Fakai Translation 
\h Hyan-u Yohanna 
\toc1 Hyan-u Yohanna du̱gu̱-du̱ Ye̱so̱ Kiristi 
\toc2 Hyan-u 
\toc3 Hyan 
\mt1 Hyan-u Yohanna 
\mt2 du̱gu̱-du̱ Ye̱so̱ Kiristi 
\c 1  
\s1 Taku̱n-du̱ u̱s-rem 
\p  
\v 1 \f + \fr 1:1. \f*Uno̱ hyan-o̱ o̱o̱n du̱gu̱-du̱ Ye̱so̱ Kiristi, u̱ Ru̱-u̱ ya'u̱ Ye̱so̱ remu̱ Ru̱-u̱ o̱ u̱t-sa wa ko̱ste̱ to̱k-ne̱ wa no̱m-u̱ wa zo̱nge̱ u̱t-no̱m u-shu̱ za m-tumb. Tu̱msu̱ Kiristi no̱mo̱g remsu̱ hyan-u uno̱ u̱ wa to̱mto̱n wa-to̱m-u̱ u-Ru̱ u̱du̱ to̱k-u̱ wa Yohanna.  
\v 2 Yohanna wu̱r ko̱-uyan ho̱n-ho̱n u̱ wa hyane̱ tu̱msu̱ wa hog. Sin-se̱ o̱o̱ge̱ ogor-tu̱ remsu̱ u-Ru̱ tu̱msu̱ u̱t-nip ne̱ tu̱ Ye̱so̱ Kiristi upse̱.  
\v 3 Nu-u u-Ru̱ u̱du̱ wu̱ karu̱nte̱ rem-u̱s sin-se̱ su̱ no̱m-u̱ do̱'e̱ u̱t-no̱m u-shu̱, tu̱msu̱ kom-u̱ u-Ru̱ u̱du̱ wu̱ e̱re̱ tu̱msu̱ wa dor se̱. Rem u̱zu̱ no̱m-u̱t tun-to̱ do̱'e̱ u̱t-no̱m za m-tumb. 
\s1 Vu̱k-u̱s Yohanna m-ha u̱du̱ mo̱ro̱g-tu̱  //  a-doru̱ Ye̱so̱ ne̱ u̱t-ta'er 
\p  
\v 4 Uno̱ ran-o̱ o̱o̱n du̱gu̱-du̱ Yohanna, m-ha u̱du̱ mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱ u̱t-ta'er i o̱ me̱ gas-su̱ dak-u̱ Asiya. 
\p Yage̱ no̱ o̱nk u-nya u̱ ru̱s-du̱ jab ne̱ du̱gu̱-du̱ u-Ru̱, wu̱ o̱ da-o̱, tu̱msu̱ u̱ da-u̱ arke̱ ne̱, u̱ da-u̱ do̱'e̱ haan ne̱, tu̱msu̱ du̱gu̱-du̱ u̱t-yar u̱t-ta'er tu̱ o̱ u-shu̱ pora-du̱ u̱r-faru̱k du̱ u-Ru̱,  
\v 5 tu̱msu̱ du̱gu̱-du̱ Ye̱so̱ Kiristi. Wu̱na o̱ wa-warru̱ rem-su̱ u̱t-nip ho̱n-ho̱n wu̱ yu̱'e̱ zu̱n-mu̱ no̱m-u̱ wa nape̱. Wu̱na o̱ wu̱ yu̱ne̱ u̱r-taku̱n du̱gu̱ m-mar tu̱msu̱ faru̱k-u̱ faru̱k-tu̱ u-dak u̱t-be̱e̱t. 
\p Ye̱so̱ Kiristi cwan-u̱g in tu̱msu̱ wa u̱ku̱r in du̱gu̱ swadu̱ u̱r-ko̱b u̱du̱ agu̱z-du̱ hyu̱-m wa u̱ remu̱ ba'as-u̱t in.  
\v 6 Wa wa'ag in shu̱'u̱t no̱m-u̱ u̱r-faru̱k tu̱msu̱ a-to̱o̱g-ne̱ rem-u̱ in no̱m-te̱ Ru̱-u wa tu̱msu̱ u̱so-u wa ne̱ m-to̱k. M-sek tu̱msu̱ u̱r-be̱b ne̱ u̱du̱ wu̱n m-mo̱mmo̱! U̱ shu̱'u̱t iya. 
\q1  
\v 7 Gwatu̱n! Ye̱so̱ o̱ haan u̱ u̱t-ku̱'u̱t ne̱. 
\q2 Tu̱msu̱ kowan do̱'e̱ hyan-du̱ wa, 
\q1 u̱ dame̱ i jwaye̱ wu̱n ne̱. 
\q2 Tu̱msu̱ ne̱t-tu̱ u-dak u̱t-be̱e̱t 
\q2 e̱ do̱'e̱ no̱m-du̱ namu̱ jab u̱ remu̱ wu̱n. 
\q4 U̱! U̱ shu̱'u̱t iya. 
\p  
\v 8 Wa-Ko̱-uyan u-Ru̱ zu̱u̱g, <<Me̱ wa wu̱ o̱tte̱ u̱r-be̱b u̱r-be̱e̱t du̱gu̱ u̱r-taku̱n m-ha m-vaste̱, wu̱ o̱o̱ge̱ da-o̱, tu̱msu̱ wu̱ o̱o̱ge̱ da-u̱ arke̱, tu̱msu̱ wu̱ do̱'e̱ haan, me̱ o̱ Ru̱-u̱ zu̱ge̱ u̱r-be̱b.>> 
\s1 Waku̱n sha-mu̱ Wa'u̱ Ne̱t 
\p  
\v 9 Me̱, Yohanna, me̱ o̱ o̱ru̱ no̱ wa-doru̱ Kiristi tu̱msu̱ wu̱ no̱me̱ u̱r-kot u̱ no̱ ne̱ u̱-me̱ swadu̱ u̱r-ko̱b, u̱ faru̱k-du̱ u-Ru̱ ne̱, tu̱msu̱ u̱ gag-du̱ jab ne̱ u̱ka wa-doru̱ Ye̱so̱. Na gwu̱nu̱g me̱ u̱-me̱ dak-u̱ o̱o̱ge̱ m-gan m-sa ne̱ mu̱ Patamos remu̱ u̱zu̱ u̱m o̱o̱g warru̱ rem-su̱ u-Ru̱ tu̱msu̱ remsu̱ u̱t-nip su̱ mo̱t-u̱t Ye̱so̱ ne̱.  
\v 10 U̱ ho̱-du̱ a-doru̱ Ye̱so̱ ne̱ no̱m-u̱ Wa-ko̱-uyan u̱t-huuk, Yar-u̱ u-Ru̱ dor-u̱t me̱. Tu̱msu̱ u̱m hog u-cwar u̱ dim-u̱ ri yu̱ u̱t-wan u̱ka wan-tu̱ u-kar.  
\v 11 Ya zu̱ me̱, <<Pan u̱-me̱ ran-u̱ u̱s-pan no̱m-u̱ bo̱ hyane̱, tu̱msu̱ bo̱ tomot o̱ u̱du̱ mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱ u̱-me̱ bo̱-u̱t tun-to̱ u̱t-ta'er: Afisa, Simina, Pirigamu, Tayatira, Sardisu, Firadafiya u̱ Rawudikiya ne̱.>> 
\p  
\v 12 U̱m bir u-dim remu̱ u̱m hyan wana o̱ u̱s-rem u̱ me̱ ne̱. Tu̱msu̱ da-u̱ u̱m bire̱ u-dim, u̱m hyu̱n u̱s-kwam u̱s-ta'er su̱ kwam-tu̱ bu̱-mu̱ u̱t-ró su̱ shik su̱ na su̱kte̱ u̱s-hitirra.  
\v 13 U̱-me̱ te̱k-u̱ u̱s-kwam su̱ u̱r-ees su̱ na su̱kte̱ u̱s-hitirra, u̱m hyu̱n waku̱n ne̱t wa u̱ ees <<Sha-mu̱ Wa'u̱ Ne̱t,>> wa o̱ m-wa u̱ to̱ggo̱-yu̱ m-wu̱r ne̱ m-te̱ ba-tu̱ u̱s-na, tu̱msu̱ wa o̱ m-as u-zeng ne̱ yu̱ kwam-tu̱ bu̱-mu̱ u̱t-ró su̱ shik-u̱ so̱k-u wa.  
\v 14 Hi-u̱r wa u̱ hi-u̱s wa ne̱ o̱ pusse̱ u̱ka u̱t-randi, tu̱msu̱ pusse̱ u̱ka u̱t-tu̱ru̱m. Tu̱msu̱ is-u̱ wa o̱ u̱ka rem-tu̱ u-ra.  
\v 15 Tu̱msu̱ na-u̱s wu̱n o̱ u̱ka kwam-tu̱ bu̱-mu̱ u-dak tu̱ shik tu̱ na toke̱ u̱-me̱ u-ra. Tu̱msu̱ cwar-u wa o̱ u̱ka gwu̱z-u̱ m-bu̱ mu̱ o̱ m-ja u̱-me̱ u-gi.  
\v 16 Wu̱ o̱tte̱ sha-mu̱ Wa'u̱ Ne̱t wa o̱ m-shu̱p u̱ re̱ge̱r-ne̱ ta'er u̱ kom-u̱ u̱t-cwa wa, tu̱msu̱ u̱-me̱ nu-u wa van-u̱ m-wu̱r rwu̱u̱n yu̱ o̱tte̱ m-re̱ ko̱yu̱he̱ gas-ya. Shu̱-u wa o̱ u̱s-mo̱k u̱ka zu̱n-mu̱ u̱r-ho̱ sok. 
\p  
\v 17 Da-u̱ u̱m hyane̱ wu̱n u̱m he u-dak u̱t-jwu̱n u-shu̱ wu̱n u̱ka zu̱ u̱m maru̱g. Se̱ wa do̱ru̱ me̱ kom u̱t-cwa tu̱msu̱ wa zu̱ me̱: <<A-bo̱ ho̱g u-gye̱r da! Me̱ wa o̱ wu̱ o̱tte̱ u̱r-be̱b u̱r-be̱e̱t du̱gu̱ u̱r-taku̱n m-te m-vaste̱.  
\v 18 Me̱ wa wu̱ o̱o̱ge̱ wa-u̱r-fat. U̱m o̱o̱gu̱ maru̱g, tu̱msu̱ da-o̱ u̱m o̱ u̱r-fat m-mo̱mmo̱! U̱m o̱ m-shu̱p u̱ u-mabudi yu̱ m-mar ne̱ u̱ mabudi yu̱ be-du̱ andaka ne̱ o̱tte̱ ne̱. 
\p  
\v 19 <<Remu̱ iya pan no̱m-u̱ bo̱ hyane̱, u̱ no̱m-u̱ o da-o̱ ne̱, tu̱msu̱ no̱m-u̱ do̱'e̱ u̱t-shu̱'u̱t ne̱ da-u̱ no̱m-u̱t tun-to̱ arke̱.  
\v 20 Uno̱ o̱ zu̱n-mu̱ no̱m-tu̱ m-yasa tu̱ re̱ge̱r ta'er i bo̱ hyane̱ u̱ kom u̱t-cwa ri tu̱msu̱ u̱s-kwam ne̱ u̱s-ta'er su̱ bu̱-mu̱ u̱t-ró su̱ shik su̱ na su̱kte̱ u̱s-hitirra: U̱ re̱ge̱r ne̱ ta'er e̱ o̱ a-to̱m u-Ru̱ ne̱ e̱ i mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱ u̱t-ta'er, tu̱msu̱ kwam-su̱ u̱r-ees su̱ na su̱kte̱ u̱s-hitirra u̱s-ta'er se̱ o̱o̱ge̱ mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱ u̱t-ta'er. 
\c 2  
\s1 To̱m m-ha u̱du̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱  //  u̱-me̱ bo̱-u̱ Afisa 
\m  
\v 1 Pan ran-u uno̱ m-ha u̱du̱ wa-to̱m u-Ru̱ wu̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱ u̱-me̱ bo̱-u̱ Afisa: 
\pi1 Uno̱ ran-o̱ o̱o̱n du̱gu̱-du̱ wu̱ o̱ m-shu̱p u̱ re̱ge̱r ne̱ ta'er u̱ kom-u̱ u̱t-cwa u̱ wa, tu̱msu̱ wa o̱ m-da u̱ te̱k-u̱ u̱s-kwam u̱s-ta'er su̱ kwam-tu̱ bu̱-mu̱ u̱t-ró su̱ shik su̱ na su̱kte̱ u̱s-hitirra:  
\v 2 U̱m nak no̱m-tu̱ no̱ nome̱ u̱t-be̱e̱t. U̱m hyanu̱g pama-u̱ ank-m no̱ tu̱msu̱ gag-du̱ jab-u̱ no̱ ne̱. U̱m nak u̱zu̱ no̱ gu̱gu̱mte̱ ne̱t-u̱t yo̱-to̱. Tu̱msu̱ no̱ reg i o̱o̱ge̱ u̱t-war u̱zu̱ e̱ o̱ a-to̱mu̱ Ye̱so̱ ne̱ se̱di e̱ zaar a-to̱mu̱ Ye̱so̱ da. No̱ byu̱k-u̱t u̱n a-u̱s-bi ne̱.  
\v 3 No̱ no̱ng gag-du̱ jab, tu̱msu̱ no̱ gu̱g jab u̱ swadu̱ u̱r-ko̱b u̱ remu̱ dim-u̱r ri, tu̱msu̱ no̱ poog da. 
\pi1  
\v 4 Se̱di u̱m o̱tte̱ u-no̱m u-gan u̱ u̱m zaare̱ u̱t-sa da u̱ mo̱t-u̱t no̱ ne̱: No̱ zaar u̱ cwan-u̱t ri da ko̱ o̱r-u̱t no̱ ne̱ u̱ka no̱ nomte̱ u̱r-taku̱n.  
\v 5 Remu̱ iya, baksu̱n u̱ka no̱ o̱tte̱ m-no̱m u̱t-cwan u̱r-be̱b ne̱ kanda no̱ he̱'e̱. Yagu̱n u̱t-ba'as tu̱msu̱ no̱ no̱m u̱r-yu̱ u̱ka no̱ nomte̱ u̱r-taku̱n da-u̱ no̱ ya'e̱ jab u̱du̱ ri. A no̱ re u-shu̱ u̱t-ba'as ne̱, u̱m do̱'e̱ u̱t-haan u̱du̱ no̱ tu̱msu̱ u̱m do̱'e̱ ve̱n-du̱ no̱ u̱du̱ hast-du̱ kwam-su̱ u̱r-ees u̱ no̱ su̱ na su̱kte̱ u̱s-hitirra du̱gu̱ be-du̱ u̱r-shu̱'u̱t u̱ se̱.  
\v 6 Se̱di no̱ o̱tte̱ no̱m-u so̱-o̱ u̱ no̱ nome̱: No̱ gu̱gu̱mte̱ no̱m-u̱t yo̱-to̱ Nikorata, tu̱ ko̱me̱ u̱m gu̱gme̱. 
\pi1  
\v 7 Kowan wu̱ o̱tte̱ u̱t-to̱ yage̱ wa gan u̱t-to̱ u̱du̱ no̱m-u̱ Yar-u̱ u-Ru̱ o̱ u̱t-war u̱du̱ mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱. U̱du̱ ne̱t-tu̱ kere̱ re̱-du̱ u̱r-ko̱rro̱, me̱ ya'u̱ u̱n ke̱rru̱ re̱-du̱ ya-tu̱ u-te du̱gu̱ me̱ u-te yu̱ yu̱'e̱ u̱r-fat, su̱ rogme̱ u̱-me̱ u-faradisi u̱ u-Ru̱. 
\s1 To̱m m-ha u̱du̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱  //  u̱-me̱ bo̱-u̱ Simina 
\m  
\v 8 Pan uno̱ ran-o̱ m-ha u̱du̱ wa-to̱m u-Ru̱ wu̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱ u̱-me̱ bo̱-u̱ Simina: 
\pi1 Sin-se̱ rem-se̱ o̱o̱n du̱gu̱-du̱ wu̱ o̱o̱ge̱ u̱r-taku̱n u̱ m-vaste̱ ne̱, wu̱ mare̱ se̱di da-o̱ wa mu̱u̱gu̱n u̱r-fat.  
\v 9 U̱m nak u̱ mo̱t-tu̱ swadu̱ u̱r-ko̱b no̱ ne̱ tu̱msu̱ taag-u no̱ ne̱, m-ha iya ne̱ no̱ o̱tte̱ u̱t-kwu̱m. U̱m nak u̱ mo̱t-tu̱ ne̱t-tu̱ o̱ u̱t-war u̱zu̱ ne̱t-tu̱ Ru̱-u̱ dage̱ to̱, Yahuda-ne̱, se̱di e̱ zaar Yahuda-ne̱ da. U̱n o̱ warru̱ no̱m-u̱t yo̱-to̱ u̱ mo̱t-u̱t no̱ ne̱, se̱di u̱n o̱ me̱ ne̱t-tu̱ o̱ no̱mu̱ faru̱k-u̱ no̱m u̱s-te m-to̱k.  
\v 10 A-no̱ ho̱g gye̱r-u̱ ko̱b-du̱ no̱ do̱'e̱ u̱t-swa da. E̱r me̱! Faru̱k-u̱ no̱m u̱s-te o̱ mo̱t-tu̱ wadu̱ hu̱u̱b-u̱t yo̱-to̱ no̱ e̱ maas e̱ke̱n u̱-me̱ no̱ tu̱msu̱ e̱ wa' no̱ u̱-me̱ bu-u̱ m-to̱k remu̱ u̱zu̱ e̱ no̱m-tu̱ no̱ m-reg. No̱ do̱'e̱ swa-u̱ ko̱b-u̱r yat-de̱ m-roog u̱t-o̱p. Se̱di taas no̱ ku̱u̱su̱n u̱ yadu̱ jab u̱ me̱ ne̱ da ko̱ a-mu̱u̱ne̱ u̱zu̱ na do̱'e̱ ho̱-du̱ no̱. U̱m do̱'e̱ yadu̱ no̱ to̱p-du̱ u̱r-fat. 
\pi1  
\v 11 Kowan wu̱ o̱tte̱ u̱t-to̱ yage̱ wa gan u̱t-to̱ u̱du̱ no̱m-u̱ Yar-u̱ u-Ru̱ o̱ u̱t-war u̱du̱ mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱. Wu̱ kere̱ re̱-du̱ u̱r-ko̱rro̱, mar-mu̱ u-yu̱ru̱mse̱ zaar u̱ ho̱nse̱ wa da. 
\s1 To̱m m-ha u̱du̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱  //  u̱-me̱ bo̱-u̱ Pirgamu 
\m  
\v 12 Pan uno̱ ran-o̱ m-ha u̱du̱ wa-to̱m u-Ru̱ wu̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱ u̱-me̱ bo̱-u̱ Pirigamu: 
\pi1 Sin-se̱ remse̱ o̱o̱n du̱gu̱ wu̱ o̱ m-shu̱p u̱ van-u̱ m-wu̱r ne̱ yu̱ o̱tte̱ m-re̱ ko̱yu̱he̱ gas-ya:  
\v 13 U̱m nak be-du̱ no̱ o̱tte̱ u̱r-yu̱ u̱-me̱ be-du̱ faru̱k-u̱ no̱m u̱s-te o̱tte̱ u̱r-faru̱k. No̱ o̱ a-doru̱ ri a jab-u̱ so̱-o̱ ne̱, tu̱msu̱ no̱ yakke̱ do̱rru̱ me̱ da, ko̱ da-u̱ u̱n ho̱ye̱ Antipas wu̱ o̱o̱ge̱ wa jab-u̱ pus-o̱ u̱du̱ warru̱ rem-u̱s ri u̱ku̱n u̱ bo̱-u no̱ be-du̱ faru̱k-u̱ no̱m u̱s-te o̱tte̱ u̱r-faru̱k. 
\pi1  
\v 14 Se̱di no̱ nom to̱ku̱n no̱m-to̱ tu̱ u̱m zaare̱ u̱t-sa da: To̱ko̱n ne̱t-to̱ u̱-me̱ no̱ u̱n dor ko̱se̱-u̱t Bara'amu, wu̱ ko̱se̱ Barak u̱ka wadu̱ ne̱t-tu̱ Isra-ne̱ no̱m u̱t-ba'as. Bara'amu wu̱' u̱n re̱ no̱m-u̱ u̱t-re̱ u̱ na sake̱ ru̱-tu̱ za u̱r-fat. Tu̱msu̱ wa wu̱' e̱ no̱m u̱t-ba'as u̱du̱ re̱g-du̱ e̱ u̱zu̱ e̱ roog u̱ ne̱ta-tu̱ zaare̱ tu̱' e̱ da.  
\v 15 Iya-o̱, e̱ke̱n o̱ró u̱-me̱ no̱ i do̱rru̱ ko̱se̱-u̱t Nikorata.  
\v 16 Rem iya, se̱ no̱ yakke̱ u̱t-ba'as! Se̱di a no̱ gu̱gme̱ u̱t-yage̱, u̱m do̱'e̱ haan u̱du̱ no̱ za m-tumb u̱m no̱m m-dum u̱ u̱n ne̱ u̱ van-u̱ m-wu̱r u̱ rwu̱u̱ne̱ du̱gu̱ me̱ nu-u ri. 
\pi1  
\v 17 Kowan wu̱ o̱tte̱ u̱t-to̱ yage̱ wa gan u̱t-to̱ u̱du̱ no̱m-u̱ Yar-u̱ u-Ru̱ o̱ u̱t-war u̱du̱ mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱. Tu̱msu̱ ko̱wana wu̱ re u̱r-ko̱rro̱ me̱ u̱t-ya wa no̱m u̱t-re̱ u̱ m-yasa du̱gu̱ do̱m u-ru̱ u̱ na foge̱ manna. Me̱ u̱t-ya ko̱wan ta'ar-u̱r pus-de̱. Tu̱msu̱ u̱ do̱m-u̱ ta'ar-u̱r re̱ dim-du̱ o̱ró m-pan du̱ waku̱n nape̱ da se̱ wu̱ o̱nke̱ de̱. 
\s1 To̱m m-ha u̱du̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱  //  u̱-me̱ bo̱-u̱ Tayatira 
\m  
\v 18 Pan uno̱ ran-o̱ m-ha u̱du̱ wa-to̱m u-Ru̱ u̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱ u̱-me̱ bo̱-u̱ Tayatira: 
\pi1 Sin-se̱ remse̱ o̱o̱n du̱gu̱-du̱ Wa'u u-Ru̱ wu̱ is-u̱ wa o̱o̱ge̱ sha-mu̱ rem-tu̱ u-ra tu̱msu̱ wu̱ ba-tu̱ u̱s-na wa o̱o̱ge̱ u̱ka kwam-tu̱ bu̱-mu̱ u-dak tu̱ shik yu̱ na toke̱ u-ra tu̱msu̱ na jig.  
\v 19 U̱m nak no̱m-tu̱ no̱ nome̱ u̱t-be̱e̱t. U̱m nak u̱zu̱ no̱ o̱ cwan-tu̱ o̱r-u̱t no̱ ne̱ tu̱msu̱ no̱ o̱tte̱ yadu̱ jab-u̱ u̱du̱ ri. U̱m nak u̱ka no̱ o̱tte̱ no̱mu̱ o̱r-u̱t no̱ ne̱ u̱r-se̱ge̱, tu̱msu̱ u̱ka no̱ o̱tte̱ gag-du̱ jab-u̱ ne̱. U̱m nak u̱ da-o̱ u̱zu̱ no̱ u̱t-no̱m m-ze̱g da-u̱ no̱ o̱nk-u̱ me̱ u̱r-taku̱n. 
\pi1  
\v 20 Se̱di o̱ko̱n o̱ró u̱ no̱ no̱me̱ u̱ yu̱-u̱r no̱ u̱ u̱m zaare̱ u̱t-sa da: No̱ gu̱gu̱mte̱ egu̱sse̱ ne̱ta-u ya Jezebe̱r du̱gu̱ bu̱rgu̱sse̱ ko̱se̱-tu̱ u̱s-bi wa. Wa fog hi-u̱r wa wa-warru̱ rem-su̱ u-Ru̱ se̱di u̱du̱ ko̱se̱-u̱t wa, wa o̱ e̱ngu̱sse̱ ne̱t-u̱t ri du̱gu̱ u-fu̱n u̱du̱ no̱m-du̱ yu̱du̱ m-o̱ tu̱msu̱ u̱ re̱-du̱ no̱m-u̱ u̱t-re̱ u̱ na sake̱ ru̱-tu̱ za u̱r-fat.  
\v 21 U̱m yaag wa u-da u̱zu̱ wa byu̱ru̱n du̱gu̱ u̱t-ba'as, se̱di wa zaar u̱t-sa u̱t-byu̱ru̱n du̱gu̱ o̱o̱-m wa da.  
\v 22 Gwat! U̱m do̱'e̱ gwu̱n-du̱ wu̱n u̱ do̱m-u̱ u-yu̱n u̱ ko̱b-du̱ m-yar. Tu̱msu̱ u̱m do̱'e̱ wadu̱ i no̱me̱ m-o̱ u̱ wu̱n ne̱ e̱ swa u̱r-ko̱b u-tát, se̱ e̱ byu̱rgu̱n tu̱msu̱ e̱ yage̱ no̱m-du̱ no̱m-tu̱ wu̱n nome̱.  
\v 23 U̱m do̱'e̱ ho̱-du̱ i o̱ do̱rru̱ ko̱se̱-u̱t wu̱n. Se̱ mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱ be̱e̱t e̱ do̱'e̱ u̱t-nap u̱zu̱ me̱ o̱ wu̱ gote̱ u̱s-jab tu̱msu̱ dorog-su̱ u̱t-ne̱t u̱t-be̱e̱t. Tu̱msu̱ u̱m do̱'e̱ ve̱n-du̱ ko̱wan u̱-me̱ no̱ ho̱n-ho̱n u̱ka ba'as-u̱t tu̱ no̱ no̱me̱.  
\v 24 Se̱di tu̱msu̱ u̱m o̱tte̱ u̱s-rem u̱ remu̱ no̱ i kuse̱ u̱-me̱ Tayatira i gu̱gme̱ do̱rru̱ ko̱se̱-tu̱ u̱s-bi tun-to̱, i gu̱gme̱ u̱t-no̱m u̱r-kot u̱ no̱m-u̱ a-doru̱ wu̱n ne̱ foge̱ ko̱se̱-tu̱ u̱t-nip tu̱ u̱r-ra tu̱ faru̱k-u̱ no̱m u̱s-te upse̱. U̱m zaar u̱t-swu̱r m-sake̱ no̱ mo̱ko̱n no'-mo̱ da,  
\v 25 se̱di u̱zu̱ no̱ re̱ u-shu̱ do̱rru̱ me̱ ne̱ u̱ka no̱ o̱tte̱ do̱rru̱ me̱, kanda u̱m haan. 
\pi1  
\v 26 Se̱di u̱du̱ wu̱ re̱ye̱ u̱r-ko̱rro̱ tu̱msu̱ wa dor me̱ m-te m-vaste̱, u̱m do̱'e̱ ya-du̱ wa-u̱r-be̱b wa no̱m faru̱k-du̱ u̱t-dak u̱t-be̱e̱t. 
\qm1  
\v 27 Wa do̱'e̱ no̱m-du̱ faru̱k-u̱r u̱n u̱ ko̱m-yu̱ u-kwam; 
\qm2 tu̱msu̱ wa do̱'e̱ cakmu̱sse̱ u̱n u̱ka rwab-tu̱ ma-u̱ u̱t-tur, 
\mi u̱ka u̱m o̱nkte̱ u̱r-be̱b du̱gu̱-du̱ u̱so-u ri.  
\v 28 U̱m do̱'e̱ ya-du̱ wu̱n re̱ge̱r-yu̱ u̱r-wu̱n.  
\v 29 Kowan wu̱ o̱tte̱ u̱t-to̱ yage̱ wa gan u̱t-to̱ u̱du̱ no̱m-u̱ Yar-u̱ u-Ru̱ o̱ u̱t-war u̱du̱ mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱.>> 
\c 3  
\s1 To̱m m-ha u̱du̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱  //  u̱-me̱ bo̱-u̱ Sardisu 
\m  
\v 1 Pan uno̱ ran-o̱ m-ha u̱du̱ wa-to̱m u-Ru̱ wu̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱ u̱-me̱ bo̱-u̱ Sardisu. 
\pi1 Wu̱ o̱ faru̱k-du̱ u̱t-Yar u̱t-ta'er i no̱me̱ u-Ru̱ m-to̱k, tu̱msu̱ wu̱ o̱ m-shu̱p u̱ re̱ge̱r ne̱ ta'er, wa to̱mo̱tto̱n sin-se̱ remse̱: U̱m nak no̱m-tu̱ no̱ no̱me̱ u̱t-be̱e̱t. U̱m nak u̱zu̱ ne̱t-tu̱ o̱ u̱t-war u̱zu̱ no̱ o̱ u̱r-fat, se̱di no̱ maru̱g.  
\v 2 Zu̱tu̱n du̱gu̱ m-roog, tu̱msu̱ no̱ swu̱re̱ no̱m-u̱ kuse̱ me̱ no̱ cashi u̱r-be̱b kanda o̱ mu̱ru̱s u-be̱e̱t. Remu̱ u̱zu̱ u̱m byu̱k-u̱t u̱zu̱ no̱m-u̱ no̱ o̱ u̱t-no̱m o̱ shu̱u̱ste̱ no̱m-u̱ Ru̱-u ri o̱ u̱t-sa no̱ no̱m da.  
\v 3 Remu̱ iya, baksu̱n u̱ no̱m-u̱ no̱ o̱nke̱ tu̱msu̱ no̱ hog, tu̱msu̱ no̱ dor o̱, tu̱msu̱ no̱ byu̱ru̱n u̱du̱ ri. A no̱ gu̱gme̱ u̱t-zu̱te̱ du̱gu̱ m-roog, u̱m do̱'e̱ u̱t-haan u̱du̱ no̱ za m-tumb, za nap-u̱r no̱, u̱ka hyu̱-u. 
\pi1  
\v 4 M-ha iya ne̱, e̱ke̱n o̱ró i kuse̱ cashi u̱-me̱ no̱ u̱ bo̱-u̱ Sardisu i gu̱gme̱ naas-du̱ hi-u̱r e̱ u̱ u̱t-ba'as. U̱n do̱'e̱ no̱m-du̱ m-ha u̱ me̱ ne̱ u̱-me̱ cwu̱-u̱t pus-to̱ tu̱ u-he̱n remu̱ u̱zu̱ u̱n ko̱rge̱.  
\v 5 Ko̱wana re u̱r-ko̱rro̱ wa do̱'e̱ wadu̱ cwu̱-u̱t pus-to̱ u̱ka ne̱t-u̱t tun-to̱ nomte̱. U̱m zaar u̱ has-tu̱ dim-du̱ ne̱t-u̱ wa du̱gu̱ ran-u̱ u̱r-fat da. Da-u̱ u̱m eese̱ u̱-shu̱ U̱so-u ri u̱ a-to̱mu̱ u-Ru̱ ne̱, u̱m do̱'e̱ u̱t-war u̱zu̱ wa o̱ ne̱t-u̱ ri.  
\v 6 Kowan wu̱ o̱tte̱ u̱t-to̱ yage̱ wa gan u̱t-to̱ u̱du̱ no̱m-u̱ Yar-u̱ u-Ru̱ o̱ u̱t-war u̱du̱ mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱. 
\s1 To̱m m-ha u̱du̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱  //  u̱-me̱ bo̱-u̱ Firadafiya 
\m  
\v 7 Pan uno̱ ran-o̱ m-ha u̱du̱ wa-to̱m u-Ru̱ wu̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱ u̱-me̱ bo̱-u̱ Firadafiya. Wa-u-He̱n tu̱msu̱ wa-u̱t-nip o̱ to̱mto̱n sin-se̱ rem-se̱. 
\pi1 Wu̱na o̱ wu̱ o̱ m-shu̱p u̱ mabudi ne̱ yu̱ faru̱k-u̱r faru̱k Dawuda. A wa upse̱ u-is waku̱n za kerru̱ u̱t-tage̱ da, tu̱msu̱ a wa tage̱ u-is waku̱n za kerru̱ u̱t-upus da.  
\v 8 U̱m nak no̱m-tu̱ no̱ nome̱ u̱t-be̱e̱t, tu̱msu̱ u̱m upuste̱ u-is u̱ remu̱ no̱ yu̱ waku̱n zaaru̱ ke̱rru̱ u̱t-tage̱ da. No̱ o̱tte̱ u̱r-be̱b cashi, m-ha iya ne̱ no̱ dor rem-u̱s ri tu̱msu̱ no̱ no̱ng se-m ri u̱zu̱ no̱ o̱ wa-doru̱ ri da.  
\v 9 U̱t-nip! U̱m do̱'e̱ wadu̱ ne̱t-u̱t to̱ i o̱ ban-du̱ kirru̱ u̱t-ne̱t i o̱o̱ge̱ no̱mu̱ faru̱k-u̱ no̱m u̱s-te u̱t-huuk, i zu̱ye̱, It o̱ ne̱t-tu̱ Ru̱-u̱ dage̱, se̱di bise̱ u̱n o̱tte̱, u̱n haan tu̱msu̱ u̱n he̱ u̱t-jwu̱n u-shu̱ no̱ tu̱msu̱ u̱n war u̱zu̱ u̱m o̱ cwan-u̱t no̱.  
\v 10 Rem u̱zu̱ no̱ do̱ro̱g bo̱r-u ri u̱du̱ gag-du̱ jab ne̱, u̱m do̱'e̱ e̱'-du̱ no̱ du̱gu̱ da-u̱ reg-m yat-mo̱ mu̱ do̱'e̱ haan u̱-me̱ u-dak u-be̱e̱t remu̱ na reg-u̱t i o̱ m-yu̱ u̱-me̱ u-dak u-be̱e̱t. 
\pi1  
\v 11 U̱m o̱ haan za m-tumb. Ship yadu̱ jab u̱ bo̱ o̱tte̱, taas u̱ waku̱n haan wa kost to̱p-du̱ u̱r-faru̱k du̱ na do̱'e̱ yadu̱ bo̱ da.  
\v 12 Wu̱ kere̱ re̱-du̱ u̱r-ko̱rro̱ u̱m do̱'e̱ u̱t-wa wa shu̱'u̱t u̱r-kan u̱-me̱ be-du̱ u̱r-shu̱'u̱t du̱ Ru̱-u ri. Tu̱msu̱ wa zamu̱n u̱ yage̱ o̱ da. Tu̱msu̱ u̱m do̱'e̱ pan-du̱ dim-du̱ Ru̱-u ri u̱ dim-du̱ bo̱-u̱ Ru̱-u ri ne̱ u̱ do̱m-u̱ wu̱n. Bo̱-u o̱ o̱o̱ge̱ Urusharima u̱ po-o̱ u̱ o̱ cu̱zu̱n du̱gu̱ me̱ do̱m u-ru̱ du̱gu̱-du̱ Ru̱-u ri. Tu̱msu̱ u̱m do̱'e̱ pan-du̱ dim-u̱r po-de̱ ri u̱ do̱m-u̱ wu̱n.  
\v 13 Kowan wu̱ o̱tte̱ u̱t-to̱ yage̱ wa gan u̱t-to̱ u̱du̱ no̱m-u̱ Yar-u̱ u-Ru̱ o̱ u̱t-war u̱du̱ mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱. 
\s1 To̱m m-ha u̱du̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱  //  u̱-me̱ bo̱-u̱ Rawudikiya 
\m  
\v 14 Pan uno̱ ran-o̱ m-ha u̱du̱ wa-to̱m u-Ru̱ wu̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱ u̱-me̱ bo̱-u̱ Rawudikiya. 
\pi1 Wu̱ na foge̱, U̱ shu̱'u̱t iya o̱ to̱mto̱n no̱ sin-se̱ remse̱. Wa ware̱ u̱t-nip ho̱n-ho̱n u̱ mo̱t-tu̱ u-Ru̱ ne̱. Tu̱msu̱ du̱gu̱ wu̱n de̱ Ru̱-u̱ nomte̱ u̱t-no̱m u̱t-be̱e̱t.  
\v 15 U̱m nak ank-m ró. U̱m nak u̱zu̱ bo̱ zatte̱ m-du̱ng ko̱ m-tor da. U̱m cwan-u̱g u̱zu̱ no̱ o̱ m-tor ne̱ ko̱ m-du̱ng ne̱.  
\v 16 Se̱di ba shu̱'u̱te̱ no̱ zatte̱ m-du̱ng ko̱ m-tor da, u̱m do̱'e̱ top-su̱ no̱ du̱gu̱ me̱ nu-u ri.  
\v 17 Remu̱ zu̱ no̱ o̱ u̱t-war u̱-me̱ no̱, <<It o u̱t-kwu̱m ne̱. It o̱tte̱ ko̱-uyan u̱ it o̱ u̱t-sa.>> Se̱di no̱ nak da u̱zu̱ yu̱-u̱r no̱ u̱-me̱ Yar-u̱ u-Ru̱ de̱ shaktu̱sse̱, no̱m-tu̱ u̱r-o̱n, wa u̱r-ko̱b, po̱, tu̱msu̱ u̱r-so.  
\v 18 U̱m o̱ yadu̱ no̱ u̱s-rem u̱zu̱ no̱ haan u̱du̱ ri no̱ o̱ kwam-tu̱ bu̱-mu̱ u̱t-ró su̱ shik tu̱ na zo̱me̱ u̱ u-ra. U̱ da-u o̱ no̱ do̱'e̱ u̱t-shu̱'u̱t u̱t-kwu̱m ne̱. Tu̱msu̱ no̱ do̱'e̱ o̱o̱du̱ cwu̱-u̱t pus-to̱ du̱gu̱-du̱ ri remu̱ no̱ taku̱ste̱ so-u̱r no̱ du̱ shu̱'u̱te̱ no̱m-tu̱ m-e̱'. Tu̱msu̱ no̱ o̱ m-no̱o̱g remu̱ is-u̱ no̱ ko̱ no̱ u̱t-ker m-hyan. 
\pi1  
\v 19 Ne̱t-tu̱ u̱m o̱ u̱t-cwan e̱ o̱ ne̱t-tu̱ u̱m o̱ nak-du̱ u̱t-to̱ tu̱msu̱ u̱t-him ne̱. Rem iya wa'u̱n jab u̱ka no̱ do̱te̱ yage̱-du̱ u̱t-ba'as.  
\v 20 Me̱ ya ana! U̱m o̱ ees u̱ bo̱n-du̱ is tu̱msu̱ u̱m o̱ u̱t-ko̱o̱t. A waku̱n ho̱ge̱ cwar-u ri tu̱msu̱ wa upus u-is u̱m do̱'e̱ cwaan u̱-me̱ bu-u wa tu̱msu̱ u̱m do̱'e̱ re̱-du̱ no̱m u̱t-re̱ u̱r-kot u̱ wa ne̱, tu̱msu̱ wa do̱'e̱ u̱t-re̱ u̱ me̱ ne̱.  
\v 21 U̱du̱ wu̱ re̱ye̱ u̱r-ko̱rro̱ me̱ ya'u̱ wa u̱r-be u̱r-kot u̱-me̱ ne̱ u̱ do̱m-u̱ pora-du̱ u̱r-faru̱k-u̱ ri, u̱ka u̱m rete̱ u̱r-ko̱rro̱ tu̱msu̱ u̱m shu̱'u̱t u̱r-kot u̱ u̱so-u ri ne̱ u̱ do̱m-u̱ pora-du̱ u̱r-faru̱k-u̱ wa.  
\v 22 Kowan wu̱ o̱tte̱ u̱t-to̱ yage̱ wa gan u̱t-to̱ u̱du̱ no̱m-u̱ Yar-u̱ u-Ru̱ o̱ u̱t-war u̱du̱ mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱. 
\c 4  
\s1 Pora-du̱ u̱r-faru̱k u̱-me̱ do̱m-u u-ru̱ 
\p  
\v 1 Da-u̱ no̱m-u̱t to̱ arke̱ u̱m got, tu̱msu̱ is-yu̱ o̱ró u̱ku̱n u̱ ees u̱r-hu̱k u̱-me̱ do̱m-u u-ru̱! Tu̱msu̱ cwar-yu̱ u̱r-taku̱n yu̱ u̱m ho̱ge̱ ya o̱ u̱s-rem u̱ me̱ ne̱ sha-mu̱ fu̱rru̱ u-kar ya zu̱ me̱: <<Daane̱ do̱m u̱ ana remu̱ u̱m ko̱s-tu̱ bo̱ no̱m-u̱ do̱'e̱ u̱t-no̱m za u-sakna u̱ dim-u̱ no̱m-u̱t tun-to̱.>>  
\v 2 Za rem Yar-u̱ u-Ru̱ dor-u̱t me̱, tu̱msu̱ u̱m hyu̱n pora-du̱ u̱r-faru̱k u̱ku̱n u̱-me̱ do̱m u-ru̱ tu̱msu̱ waku̱n o̱ shu̱'u̱t u̱ do̱m-u̱ de̱.  
\v 3 Tu̱msu̱ wu̱ o̱ shu̱'u̱t u̱-do̱mu̱ pora-du̱ u̱r-faru̱k wa o̱ u̱s-baku̱t sha-mu̱ ta'ar-u̱t so̱-to̱ tu̱ shik tu̱ na foge̱ jaspa u̱ yakutu ne̱. Be-du̱ wa o̱tte̱ u̱ shu̱'u̱t ro̱to̱ro̱nd yu̱ gu̱nu̱s wa ya o̱ sha-mu̱ ta'ar-u̱t so̱-to̱ tu̱ shik tu̱ na foge̱ zumurrudu.  
\v 4 M-gan u̱ pora-du̱ u̱r-faru̱k ne̱ pora-tu̱ u̱t-faru̱k o̱ró u̱r-shik u̱t-nas (24), tu̱msu̱ i o̱ shu̱'u̱t u̱ do̱m-u̱ to̱ e̱ o̱ u̱t-ne̱nge̱n u̱r-shik u̱t-nas (24). U̱n kowan o̱ m-wa u̱ cwu̱-u̱t pus-to̱ ne̱ tu̱msu̱ u̱ to̱p-tu̱ u̱r-faru̱k ne̱ tu̱ kwam-tu̱ bu̱-mu̱ u̱t-ró tu̱ shik u̱-do̱m-u̱ hi-u̱t wa.  
\v 5 Du̱gu̱-du̱ me̱ pora-du̱ u̱r-faru̱k yaku̱t-su̱ o̱ rwu̱u̱n tu̱msu̱ u̱t-dum ne̱ u̱ gap-du̱ u̱s-kagagag ne̱. Tu̱msu̱ u̱-shu̱ pora-du̱ u̱r-faru̱k-u̱ de̱ hittirra su̱ o̱rò u̱ku̱n u̱s-ta'er se̱ o̱ m-re̱ u-ra. To̱ o̱o̱ge̱ Yar-tu̱ u-Ru̱ u̱t-ta'er.  
\v 6 Tu̱msu̱ u̱-shu̱ pora-du̱ u̱r-faru̱k-u̱ de̱ u̱ku̱n o̱ko̱n no̱m-o̱ o̱rò sha-mu̱ sa-mu̱ u̱r-madibi, du̱ o̱ u̱s-myak u̱ m-baku̱t ne̱. 
\p M-gan pora-du̱ u̱r-faru̱k de̱, no̱m-tu̱ u̱r-fat o̱ró u̱t-nas, tu̱msu̱ war-u u̱n o̱ u̱t-is ne̱ ko̱yu̱he̱ gas-ya, u-shu̱ u̱ u-dim ne̱.  
\v 7 No̱m-yu̱ u̱r-fat yu̱ u̱r-taku̱n o̱ u̱ka u-zur, yu̱ u-yu̱ru̱mse̱ o̱ u̱ka u-na, yu̱ u-tu̱tu̱rse̱ o̱ u̱ u-shu̱ ne̱ sha-mu̱ shu̱-u̱ ne̱t, yu̱ u-nasu̱rse̱ o̱ sha-mu̱ u-shu̱p u̱r-yu̱ne̱ u̱t-kap ne̱.  
\v 8 Ko̱yu̱he̱ u̱-me̱ no̱m-tu̱ u̱r-fat u̱t-nas ya o̱tte̱ u̱t-kap u̱t-shishin, tu̱msu̱ war-u̱t e̱ u-be̱e̱t is-tu̱ taku̱ste̱ u-shu̱ u̱ u-dim ne̱ m-ha ta-u̱ kap-u̱t e̱ ne̱. U-ho̱ u̱ m-gyu̱p ne̱ u̱n tamu̱g u̱t-yage̱ u̱t-zu̱: 
\qc <<U-he̱n, u-he̱n, u-he̱n, 
\qc u̱du̱ Wa-ko̱-uyan u-Ru̱ wu̱ o̱tte̱ be̱b-du̱ ko̱-uyan, 
\qc wu̱ o̱o̱ge̱ da-u̱ dim, u̱ wu̱ o̱ da-o̱ ne̱, 
\qc u̱ da-u̱ do̱'e̱ haan ne̱.>> 
\m  
\v 9 Da-u̱ no̱m-tu̱ u̱r-fat yu̱'e̱ m-sek, m-ze̱g ne̱ u̱ u̱t-vam ne̱ u̱du̱ wu̱ o̱ shu̱'u̱t u̱-do̱mu̱ pora-du̱ u̱r-faru̱k tu̱msu̱ wu̱ o̱ u̱r-fat m-mo̱mmo̱,  
\v 10 ne̱nge̱n-u̱t to̱ u̱r-shik u̱ u̱t-nas (24) u̱n he̱ u-dak tu̱msu̱ u̱n no̱mu̱ wu̱ o̱ shu̱'u̱t u̱-do̱mu̱ pora-du̱ u̱r-faru̱k u̱t-huuk wu̱ o̱ u̱r-fat m-mo̱mmo̱. Tu̱msu̱ u̱n ru̱st to̱p-tu̱ u̱r-faru̱k-u̱ u̱n u̱-shu̱ pora-du̱ u̱r-faru̱k tu̱msu̱ u̱n zu̱, 
\q1  
\v 11 <<Bo̱ wa ko̱re̱, Wa-ko̱-uyan it tu̱msu̱ Ru̱-u it ne̱, 
\q2 u̱ bo̱ o̱nk m-sek u̱ m-ze̱g ne̱ tu̱msu̱ u̱r-be̱b ne̱, 
\q1 remu̱ bo̱ wa no̱me̱ u̱t-no̱m u̱t-be̱e̱t, 
\q2 tu̱msu̱ u̱du̱ cite̱-m ró na nomte̱ to, 
\q2 tu̱msu̱ no̱m-u̱t to̱ shu̱'u̱t.>> 
\c 5  
\s1 Ran-u̱ u̱s-pan u̱ Kag-u̱r U̱r-ca ne̱ 
\p  
\v 1 Se̱ u̱m hyu̱n ran-u̱ u̱s-pan u̱ na huste̱ u̱ kom-u̱ u̱t-cwa u̱ wu̱ o̱ shu̱'u̱t u̱ do̱m-u̱ pora-du̱ u̱r-faru̱k. U̱-me̱ ran-u o̱ pan-su̱ o̱ró u̱-me̱ tu̱msu̱ u̱-do̱ ne̱, tu̱msu̱ na rake̱ ran-u u̱s-pan o̱ u̱t-be u̱t-ta'er.  
\v 2 Tu̱msu̱ u̱m hyu̱n wa-to̱m u-Ru̱ yu̱ o̱ u̱r-be̱b ne̱, wu̱ no̱me̱ u̱t-jar u̱ cwar-yu̱ m-yat u̱zu̱, <<Wana ko̱re̱ wa upus ran-u̱ u̱s-pan o̱ tu̱msu̱ wa hast u̱t-rake̱ tu̱ o̱ do̱m-u̱ ran-u̱ u̱s-pan o̱?>>  
\v 3 Se̱di waku̱n zaar u̱-me̱ do̱m u-ru̱ ko̱ dak-u uno̱ ko̱ ta-u̱ u-dak wu̱ ko̱re̱ wa upus ran-u o̱ ko̱ wa gwat no̱m-u̱ o̱ m-pan u̱-me̱ ran-u o̱ da.  
\v 4 Se̱ u̱m he̱e̱se̱ u̱s-kan m-yat rem u̱zu̱ waku̱n zaar wu̱ ko̱re̱ wa upus ko̱ wa karu̱nte̱ no̱m-u̱ o̱ m-pan u̱ ran-u o̱ da.  
\v 5 Se̱ waku̱n u̱ te̱k-u̱ u̱t-ne̱nge̱n wa zu̱ me̱, <<Yage̱ u̱s-kan! Gwat! Wu̱ na foge̱ zur-yu̱ ko̱-u̱r Yahuda, wu̱ o̱ du̱gu̱ ko̱-u̱r faru̱k Dawuda, wa re̱e̱g u̱r-ko̱rro̱. Wu̱na o̱ wu̱ na nomte̱ este̱du̱ u̱s-rem du̱gu̱ ko̱-u̱r Dawuda. Tu̱msu̱ wa ko̱rge̱ wa upus ran-u̱ u̱s-pan o̱ tu̱msu̱ wa hast rake̱-tu̱ o̱ u̱t-ta'er.>> 
\p  
\v 6 Se̱ u̱m hyu̱n Kag-u̱r u̱r-ca, u̱ka zu̱ na panu̱g ya, wu̱ o̱ ees u̱t-mo̱r u̱ pora-du̱ u̱r-faru̱k, tu̱msu̱ no̱m-tu̱ u̱r-fat u̱ to̱ u̱t-nas u̱ u̱t-ne̱nge̱n ne̱ to̱ gu̱nu̱ste̱ wa. Wa o̱tte̱ u̱s-kar u̱s-ta'er u̱ u̱t-is ne̱ u̱t-ta'er, tu̱ o̱ Yar-tu̱ u-Ru̱ u̱t-ta'er tu̱ wa to̱mne̱ u̱-me̱ u-dak u-be̱e̱t.  
\v 7 Se̱ wa do̱'e̱ tu̱msu̱ wa o̱nk ran-u o̱ du̱gu̱ kom u̱t-cwa u̱ wu̱ o̱ u̱ shu̱'u̱t u̱-do̱m pora-du̱ u̱r-faru̱k.  
\v 8 Da-u̱ wa kabe̱ ran-u o̱, se̱ no̱m-tu̱ u̱r-fat u̱ to̱ u̱t-nas u̱ u̱t-ne̱nge̱n ne̱ u̱r-shik u̱ u̱t-nas (24) to̱ he̱ u-dak u-shu̱ Kag-u̱r U̱r-ca. Kowan o̱ u-mo̱ro̱ ne̱, tu̱msu̱ e̱ o̱ m-shu̱p u̱ u̱t-kwano ne̱ tu̱ kwam-tu̱ bu̱-mu̱ u̱t-ró tu̱ shik to̱ shu̱u̱g u̱ no̱o̱g-mu̱ wu̱s u-haku̱n, tu̱ o̱o̱ge̱ to̱o̱g-su̱ ne̱t-tu̱ u-Ru̱.  
\v 9 Tu̱msu̱ e̱ fu se̱p-u po-o̱ e̱ o̱ u̱t-zu̱: 
\q1 <<Bo̱ wa ko̱re̱ bo̱ kab ran-u̱ u̱s-pan 
\q2 tu̱msu̱ bo̱ hast rake̱-u̱t wa, 
\q1 remu̱ u̱zu̱ na panu̱g bo̱, 
\q2 tu̱msu̱ bo̱ gwu̱u̱g ne̱t-tu̱ u-Ru̱ u̱ hyu̱-m ró 
\q1 du̱gu̱ ko̱du̱he̱ ko̱-de̱ tu̱msu̱ u̱t-rem ne̱ 
\q2 tu̱msu̱ u̱t-ne̱t ne̱ tu̱msu̱ u̱t-dak ne̱. 
\q1  
\v 10 Bo̱ muute̱ u̱n shu̱'u̱t u̱r-faru̱k tu̱msu̱ a-to̱o̱g-ne̱ remu̱ u̱n no̱m-te̱ Ru̱-u in m-to̱k, 
\q2 tu̱msu̱ u̱n do̱'e̱ no̱m-du̱ u̱r-faru̱k u̱ do̱m-u u-dak.>> 
\p  
\v 11 Se̱ u̱m got tu̱msu̱ u̱m hog cwar-su̱ a-to̱mu̱ u-Ru̱ u-tát, u̱t-zo̱ngu do̱m u̱t-zo̱ngu, tu̱msu̱ u̱t-zo̱ngu u̱t-o̱p u-so u̱t-zo̱ngu u-o̱p. E̱ gu̱nu̱ste̱ pora-du̱ u̱r-faru̱k u̱ no̱m-tu̱ u̱r-fat ne̱ tu̱msu̱ u̱t-ne̱nge̱n ne̱.  
\v 12 Tu̱msu̱ u̱n fu u̱t-se̱p u̱-me̱ do̱m-u̱ u-ru̱ u̱ cwar-yu̱ m-yat: 
\q1 <<Kag-u̱r U̱r-ca wu̱ na pane̱ wa ko̱re̱. 
\q2 Wa o̱nk u̱t-vam, m-shin ne̱, u̱t-kwu̱m ne̱, 
\q1 u̱s-ve̱r ne̱, tu̱msu̱ u̱r-be̱b ne̱, 
\q2 m-sek ne̱, m-ze̱g ne̱, tu̱msu̱ u̱t-vam ne̱.>> 
\p  
\v 13 Se̱ tu̱msu̱ u̱m hog ko̱tu̱he̱ no̱m-tu̱ u̱r-fat tu̱ me̱ do̱m u-ru̱ u̱ tu̱ do̱m-u u-dak ne̱ u̱ tu̱ ta-u u-dak ne̱ u̱ tu̱ me̱ m-sa ne̱, tu̱msu̱ u̱ ko̱-u̱-he̱ no̱m-u̱ u̱r-fat u̱ o̱ me̱ m-bu̱ u̱ u-dak ne̱, e̱ o̱ fu̱-du̱ u̱t-se̱p: 
\q1 <<U̱du̱ wu̱ o̱ shu̱'u̱t u̱ do̱m-u̱ pora-du̱ u̱r-faru̱k 
\q2 tu̱msu̱ u̱du̱ Kag-u̱r u̱r-ca ne̱, 
\q1 na ya' wa u̱t-vam, m-sek ne̱, m-ze̱g ne̱, tu̱msu̱ m-shin ne̱, 
\q2 m-mo̱mmo̱!>> 
\m  
\v 14 Tu̱msu̱ no̱m-tu̱ u̱r-fat u̱ to̱ u̱t-nas to̱ zu̱, <<U̱ shu̱'u̱t iya.>> Tu̱msu̱ ne̱nge̱n-u̱t to̱ u̱r-shik u̱t-nas he u-dak u̱n no̱mu̱ Kag-u̱r U̱r-ca u̱t-huuk. 
\c 6  
\s1 U̱t-rake̱ 
\p  
\v 1 U̱m o̱ u̱t-gwat u̱ka Kag-u̱r U̱r-ca haste̱ u̱r-taku̱n u-gan u̱ te̱k-u̱ u̱t-rake̱ u̱t-ta'er. Se̱ u̱m hog wagan u̱ te̱k-u̱ no̱m-tu̱ u̱r-fat u̱ to̱ o̱ u̱t-zu̱ u̱ cwar-yu̱ o̱ u̱ka u-kagagag, <<Haane̱!>>  
\v 2 U̱m got tu̱msu̱ u̱m hyu̱n jwaak-u pus-ya o̱ ees u̱ku̱n. Wu̱ o̱ m-sak u̱ do̱m-u̱ ya o̱ m-shu̱p u-ta ne̱, tu̱msu̱ na wa-u̱ wa to̱p-du̱ u̱r-faru̱k u̱ hi-u̱r wa. Wa aru̱k m-rwu̱ remu̱ wa reet m-gag tu̱msu̱ wa kum re̱-du̱ u̱r-ko̱rro̱. 
\p  
\v 3 Da-u̱ Kag-u̱r U̱r-ca upse̱ u̱t-rake̱ tu̱ u-yu̱ru̱mse̱, u̱m hog no̱m-yu̱ u̱r-fat yu̱ u-yu̱ru̱mse̱ ya o̱ u̱t-zu̱, <<Haane̱!>>  
\v 4 Se̱ yaku̱n jwaak ya rwu̱u̱n, yu̱ o̱ jaz-ya. Wu̱ o̱ m-sak u̱ do̱m-u u-jwaak na yase̱ wa van-u̱ m-wu̱r u̱ yat-o̱, tu̱msu̱ na yu̱' wa-u̱r-be̱b u̱zu̱ wa hast shu̱'u̱t-du̱ m-yar du̱gu̱ me̱ u-dak, tu̱msu̱ wa wu̱'u̱t u̱t-ne̱t e̱ pan o̱r-u̱t e̱ ne̱ ko̱he̱ne̱. 
\p  
\v 5 Da-u̱ Kag-u̱r U̱r-ca haste̱ u̱t-rake̱ tu̱ u-tu̱tu̱rse̱, se̱ u̱m hog no̱m-yu̱ u̱r-fat yu̱ u-tu̱tu̱rse̱ ya o̱ u̱t-zu̱, <<Haane̱!>> U̱m got, tu̱msu̱ ku̱n u̱ shu̱ ri u̱m hyu̱n jwaak-u rim-ya! Wu̱ o̱ m-sak u̱ do̱m-u̱ ya wa o̱ m-shu̱p u̱ no̱m-yu̱ u̱t-mu̱'u̱s ne̱ u̱ kom-u wa.  
\v 6 Se̱ u̱m hog o̱ko̱n no̱m-o̱ u̱ka u-cwar u̱ te̱k-u̱ no̱m-tu̱ u̱r-fat u̱ to̱ u̱t-nas ya o̱ u̱t-zu̱, <<Kwano du̱ u-mu̱'u̱g u̱r-gan du̱ fat de̱ o̱ to̱p-u̱ u̱r-hoot u̱r-gan, tu̱msu̱ kwano tu̱ u-mu̱'u̱g tu̱ bur u̱t-tu̱t to̱ o̱ to̱p-u̱ u̱r-hoot u̱r-gan. A-bo̱ naas m-no̱o̱g u̱ bu̱-mu̱ ke̱ ne̱ da.>> 
\p  
\v 7 Da-u̱ Kag-u̱r U̱r-ca haste̱ u̱t-rake̱ tu̱ u-nasu̱rse̱, u̱m hog cwar-yu̱ no̱m-yu̱ u̱r-fat yu̱ u-nasu̱rse̱ ya o̱ u̱t-zu̱, <<Haane̱!>>  
\v 8 U̱m got, tu̱msu̱ u̱ku̱n u̱-shu̱ ri u̱m hyu̱n u-jwaak yu̱ bu̱-mu̱ u̱t-ran! Wu̱ o̱ m-sak u̱-do̱m ya dim-u̱r wa na zu̱ye̱ m-mar. Tu̱msu̱ be-du̱ andaka ne̱ o̱tte̱, du̱ na foge̱ Hades o̱ do̱rru̱ dim-u̱ wa. Na yu̱' e̱ u̱r-be̱b u̱-do̱mu̱ u̱r-ho̱ u̱r-gan u̱-me̱ u̱t-nas u̱-me̱ ne̱t-tu̱ u-dak u̱t-be̱e̱t u̱zu̱ u̱n ho̱ u̱n u̱s-van su̱ m-wu̱r, u̱ u̱s-me̱r ne̱ u̱ u̱s-go̱m ne̱ tu̱msu̱ bisa-tu̱ u̱r-do̱g ne̱. 
\p  
\v 9 Da-u̱ Kag-u̱r U̱r-ca haste̱ u̱t-rake̱ tu̱ u-tanu̱rse̱, se̱ u̱m hyu̱n u̱-ta u̱r-sak andaka ne̱ i na ho̱ye̱ u̱ remu̱ rem-su̱ u-Ru̱ tu̱msu̱ u̱ remu̱ yadu̱ jab u̱ warru̱ rem-su̱ u̱t-nip su̱ mo̱t-u̱t Ye̱so̱  
\v 10 U̱n no̱m u̱s-kan u̱ cwar-u yat-ya, <<Wa-ko-uyan, bo̱ o̱ wa-u-he̱n tu̱msu̱ u̱t-nip ne̱! Mu̱ne̱ o̱ bo̱ do̱'e̱ kwu̱p-du̱ u̱s-rem tu̱msu̱ bo̱ to̱p-u̱ it mag-du̱ hyu̱-m it u̱-do̱mu̱ ne̱t-tu̱ dak-u uno̱ i ho̱ye̱ it?>>  
\v 11 Se̱ na yase̱ u̱n ko̱wan u-to̱ggo̱ yu̱ m-wu̱r yu̱ pus-ya, tu̱msu̱ na zu̱ u̱n e̱ste̱ u-da cashi, se̱ tat-u̱ hu̱u̱b-u̱t u̱n to̱k-ne̱ u̱ o̱r-u̱t u̱n ne̱ i na do̱'e̱ u̱t-ho̱ u̱ka na hote̱ u̱n o̱ shu̱u̱g. 
\p  
\v 12 U̱m got u̱ka Kag-u̱r U̱r-ca haste̱ u̱t-rake̱ tu̱ u-shishin. Se̱ na nom ru̱mu̱s-du̱ u-dak du̱ yat-de̱. Tu̱msu̱ ho̱-du̱ baru̱m u̱ rimde̱ u̱ka kus-u rim-o̱ u̱ na no̱me̱ u̱ can-tu̱ gwaar-u rim-ya, tu̱msu̱ pyaat-yu̱ baru̱m u̱ jaz-ya u̱ka m-hyu̱.  
\v 13 Tu̱msu̱ re̱ge̱r he̱e̱n du̱gu̱ do̱m u-ru̱ u̱ u-dak u̱ka gom-tu̱ ya-tu̱ u-rumba he̱e̱tu̱n da-u̱ mya-mu̱ u̱r-be̱b fu̱rne̱ tu̱msu̱ mo̱ zu̱gumse̱ ya.  
\v 14 Se̱ do̱m u-ru̱ hust u̱ka u̱r-wu̱ndi. Tu̱msu̱ u̱t-ro̱r u̱t-be̱e̱t u̱ dak-tu̱ o̱ m-gan m-sa ne̱ ko̱-u̱-he̱ na hast o̱ du̱gu̱ be-du̱ u̱r-shu̱'u̱t u̱ wa. 
\p  
\v 15 Se̱ faru̱k-tu̱ u-dak, tu̱msu̱ u̱ faru̱k-u̱t re̱k-to̱ ne̱, u̱ tu̱-shu̱ karma-ne̱, u̱ a no̱m-u̱ u̱t-kom ne̱, u̱ a u̱r-be̱b ne̱, tu̱msu̱ u̱ i o̱ m-to̱k ne̱ u̱ i zaare̱ m-to̱k ne̱ da, ko̱wan yase̱ hi-u̱r wa u̱-me̱ u̱t-so tu̱msu̱ u̱ te̱k-u̱ ta'ar-u̱r u̱ do̱m-u̱ u̱t-ro̱r.  
\v 16 Tu̱msu̱ u̱n zu̱ u̱t-ro̱r u̱ u̱t-ta'ar ne̱, <<He̱e̱nu̱n u̱ do̱m-u̱ it! No̱ yase̱ it du̱gu̱-du̱ wu̱ shu̱'u̱t u̱ do̱m-u̱ pora-du̱ u̱r-faru̱k! Yasu̱n it du̱gu̱-du̱ namu̱ jab-u̱ Kag-u̱r U̱r-ca!  
\v 17 Re̱mu̱ ho̱-u̱r yat-de̱ du̱ namu̱ jab-u̱ u̱n teegu̱n! Wana do̱'e̱ kerru̱ u̱r-ees?>> 
\c 7  
\s1 Ne̱t-ne̱ u̱r-zo̱ngu u-gan u̱ u̱t-shik u̱t-yu̱r  //  u̱t-nas (144,000) i na wa'e̱ u̱s-nap 
\p  
\v 1 Da-u̱ taase̱ u̱m hyu̱n a-to̱mu̱ u-Ru̱ ne̱ nas u̱ ees u̱ jwu̱n-tu̱ u-dak u̱t-nas. U̱n o̱ m-shu̱p u̱ mya-mu̱ u-dak ne̱ u̱t-nas remu̱ e̱ hooste̱ m-mya u̱t-fu̱ru̱n u-do̱m u-dak ko̱ u̱-me̱ m-sa ne̱, ko̱ u̱-do̱mu̱ yaku̱n te-ya.  
\v 2 Se̱ u̱m hyu̱n waku̱n wa-to̱m u-Ru̱ wa o̱o̱n du̱gu̱ gas-u̱ ho̱-du̱ rwu̱u̱tu̱n, wa o̱ m-shu̱p u̱ nap-su̱ Ru̱-u̱ u̱r-fat ne̱. Wa no̱mu̱ a-to̱mu̱ u-Ru̱ ne̱ nas i na ya'e̱ u̱r-ke̱r e̱ ho̱nse̱ u-dak u̱ m-sa ne̱ wa o̱ u̱t-jar u̱ cwar-u yat-ya.  
\v 3 Wa zu̱, <<A no̱ ho̱nse̱ u-dak ko̱ m-sa ko̱ u̱s-te se̱ it wa'ag u̱s-nap u̱ po̱ng-tu̱ to̱k-ne̱ u-Ru̱>>  
\v 4 Waku̱n waru̱ me̱ tat-u̱ u̱t-ne̱t i na wa'e̱ u̱s-nap du̱gu̱ me̱ ko̱-tu̱ Isra-ne̱ u̱t-be̱e̱t, u̱r-zo̱ngu u-gan u̱ u̱t-shik u̱t-yu̱r u̱t-nas (144,000). 
\li1  
\v 5 Du̱gu̱ me̱ ko̱-u̱r Yahuda 12,000, 
\li1 du̱gu̱ me̱ ko̱-u̱r Rube̱n 12,000, 
\li1 du̱gu̱ ko̱-u̱r Gad 12,000, 
\li1  
\v 6 du̱gu̱ ko̱-u̱r Ashu̱r 12,000, 
\li1 du̱gu̱ ko̱-u̱r Naptari 12,000, 
\li1 du̱gu̱ ko̱-u̱r Manase 12,000, 
\li1  
\v 7 du̱gu̱ ko̱-u̱r Simiyo̱n, 12,000, 
\li1 du̱gu̱ ko̱-u̱r Re̱wi 12,000, 
\li1 du̱gu̱ ko̱-u̱r Issakar 12,000, 
\li1  
\v 8 du̱gu̱ ko̱-u̱r Ze̱be̱run 12,000, 
\li1 du̱gu̱ ko̱-u̱r Yusuhu 12,000, 
\li1 du̱gu̱ ko̱-u̱r Banyamin 12,000. 
\s1 Mo̱ro̱g-u̱r yat-de̱ u̱ to̱ggo̱-su̱  //  m-wu̱r ne̱ su̱ pus-se̱ 
\p  
\v 9 Da-u̱ taase̱ u̱m hyu̱n mo̱ro̱g-du̱ u̱t-ne̱t u-tát tu̱ waku̱n zare̱ kerru̱ u̱t-ogor da, du̱gu̱ ko̱-u̱-he̱ dak-o̱, u̱t-ko̱ ne̱, u̱t-ne̱t ne̱ u̱ u̱r-rem ne̱. U̱n o̱ u̱ ees u-shu̱ pora-du̱ u̱r-faru̱k tu̱msu̱ u̱-shu̱ Kag-u̱r U̱r-ca ne̱. U̱n o̱ m-wa u̱ to̱ggo̱-su̱ m-wu̱r su̱ pus-se̱ ne̱ tu̱msu̱ m-shu̱p u̱ ran-u̱ u-dabino̱ ne̱ u̱ kom-u̱t u̱n.  
\v 10 Tu̱msu̱ u̱n o̱ u̱t-jar u̱ cwar-su̱ m-yat: 
\q1 <<U̱ku̱r-u̱ o̱o̱n du̱gu̱-du̱ Ru̱-u it 
\q1 wu̱ o̱ shu̱'u̱t u̱-do̱mu̱ pora-du̱ u̱r-faru̱k, 
\q1 tu̱msu̱ du̱gu̱-du̱ Kag-u̱r U̱r-ca!>> 
\m  
\v 11 Tu̱msu̱ a-to̱mu̱ u-Ru̱ ne̱ be̱e̱t e̱ o̱ ees m-gan u̱ pora-du̱ u̱r-faru̱k ne̱ tu̱msu̱ m-gan u̱t-ne̱nge̱n ne̱ tu̱msu̱ m-gan u̱ no̱m-tu̱ u̱r-fat u̱ to̱ ne̱ u̱t-nas. Tu̱msu̱ u̱n he u-dak u̱ u̱t-jwu̱n, shu̱u̱t u̱n u̱ u-dak u̱-shu̱ pora-du̱ u̱r-faru̱k, tu̱msu̱ u̱n no̱me̱ u-Ru̱ u̱t-huuk.  
\v 12 U̱n fu u̱t-se̱p, 
\q1 <<U̱ shu̱'u̱t iya! 
\q1 Nu-u so̱-o̱ u̱ m-sek ne̱ 
\q1 tu̱msu̱ u̱s-ve̱r ne̱ tu̱msu̱ u̱t-vam ne̱ tu̱msu̱ m-ze̱g ne̱ 
\q1 tu̱msu̱ m-shin ne̱ tu̱msu̱ u̱r-be̱b ne̱ 
\q1 u̱du̱ Ru̱-u it m-mo̱mmo̱. 
\q1 U̱ shu̱'u̱t iya!>> 
\p  
\v 13 Se̱ wagan u̱ te̱k-u̱ ne̱nge̱n-u̱t to̱ ne̱ u̱r-shik u̱t-nas (24) shit me̱, <<Wanne̱ e̱ ine̱ m-wa u̱ to̱ggo̱-su̱ m-wu̱r ne̱ su̱ pus-se̱? Tu̱msu̱ du̱gu̱ he̱ne̱ o̱ u̱n rwu̱u̱ne̱?>> 
\p  
\v 14 Tu̱msu̱ u̱m zu̱ wu̱n, <<U̱so-u̱ u-bu ri, bo̱ wa o̱ wu̱ nape̱.>> 
\p Se̱ wa zu̱ me̱, <<Ine̱ o̱o̱ge̱ ne̱t-tu̱ rwu̱u̱ne̱ du̱gu̱ da-u̱ swa-u̱ ko̱b-u̱r yat-de̱. E̱ jaaste̱ to̱ggo̱-su̱ m-wu̱r u̱n tu̱msu̱ mo̱ muut u̱n u̱ puse̱ u̱ hyu̱-mu̱ Kag-u̱r U̱r-ca.>>  
\v 15 O̱ wa'e̱ 
\q1 u̱n o̱tte̱ u̱ ees u̱-shu̱ pora-du̱ u̱r-faru̱k du̱ u-Ru̱ 
\q2 tu̱msu̱ u̱n o̱ no̱mu̱ wa u̱t-huuk u-ho̱ u̱ m-gye̱p ne̱ 
\q2 u̱-me̱ be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱. 
\q1 Tu̱msu̱ wu̱ o̱ shu̱'u̱t u̱-do̱mu̱ pora-du̱ u̱r-faru̱k 
\q2 wa do̱'e̱ yadu̱ u̱n be-du̱ u̱r-hure̱. 
\q1  
\v 16 U̱n zamu̱n u̱t-swu̱r m-ho̱g u̱s-me̱r 
\q2 ko̱ u-swaat m-bu̱ da. 
\q1 Ho̱-du̱ zamu̱n u̱t-swu̱r m-gap u̱n 
\q2 ko̱ mo̱ko̱n du̱ng-mo̱ gap u̱n da. 
\q1  
\v 17 Remu̱ Kag-u̱r U̱r-ca ya yu̱ o̱ shu̱'u̱t u̱-do̱mu̱ pora-du̱ u̱r-faru̱k 
\q2 wa do̱'e̱ u̱t-shu̱'u̱t wu̱ o̱ gwat-du̱ u̱n. 
\q1 Wa do̱'e̱ hu̱u̱tu̱ u̱n u̱ be-du̱ pe̱r-mu̱ m-bu̱ 
\q2 mu̱ yu̱'e̱ fat-du̱ m-mo̱mmo̱. 
\q1 Tu̱msu̱ Ru̱-u̱ do̱'e̱ ko̱ku̱ u̱n m-is m-be̱e̱t du̱gu̱ is-u̱ u̱n. 
\c 8  
\s1 U̱s-nap u̱s-ta'er u̱ u̱r-tanda ne̱  //  du̱ tok-du̱ no̱o̱g-mu̱ wu̱s u-haku̱n ne̱  //  u̱ du̱ kwam-tu̱ bu̱-mu̱ u̱t-ró ne̱ du̱ shik 
\p  
\v 1 Da-u̱ Kag-u̱r U̱r-ca haste̱ u̱t-rake̱ tu̱ u-ta'er, se̱ me̱ do̱m u-ru̱ no̱m te̱k m-te̱ u-u̱k u-kwam u-gan. 
\p  
\v 2 Se̱ u̱m hyu̱n a-to̱mu̱ u-Ru̱ ta'er i eese̱ u-shu̱ u-Ru̱, tu̱msu̱ na yasu̱ e̱ u̱s-kar u̱s-ta'er. 
\p  
\v 3 Waku̱n wa-to̱m u-Ru̱ wu̱ o̱tte̱ u̱r-tanda du̱ kwam-tu̱ bu̱-mu̱ u̱t-ró ne̱ du̱ shik, wa haan tu̱msu̱ wa ees u̱ u̱r-sak du̱ to̱o̱g. Na yasu̱ wa no̱o̱g-mu̱ wu̱s u-haku̱n u-tát remu̱ yadu̱ to̱o̱g u̱du̱ u-Ru̱, u̱ to̱o̱g-su̱ ne̱t-tu̱ u-Ru̱ ne̱, u̱ do̱m-u̱ u̱r-sak du̱ kwam-tu̱ bu̱-mu̱ u̱t-ró ne̱ du̱ shik u̱-shu̱ pora-du̱ u̱r-faru̱k.  
\v 4 Fu̱'u̱t-mu̱ no̱o̱g-mu̱ wu̱s u-haku̱n, mo̱ same̱ u̱ to̱o̱g-su̱ ne̱t-tu̱ u-Ru̱ ne̱, mo̱ yu̱ne̱ m-te̱ du̱ u-Ru̱ du̱gu̱-du̱ kom-u̱ wa-to̱m u-Ru̱.  
\v 5 Se̱ wa-to̱m u-Ru̱ shu̱u̱s u̱r-tanda du̱ no̱o̱g-mu̱ wu̱s u-haku̱n u-ra du̱gu̱ u̱r-sak, tu̱msu̱ wa gun de̱ u̱-do̱m-u̱ u-dak u-be̱e̱t. Tu̱msu̱ na nom gap-u̱ u̱s-kagagag, u̱t-dum ne̱, u̱ u̱s-yaku̱t ne̱ tu̱msu̱ ru̱mu̱s-du̱ u-dak ne̱. 
\s1 U̱s-kar 
\p  
\v 6 Se̱ a-to̱mu̱ u-Ru̱ ne̱ u-ta'er i o̱ m-shu̱p u̱s-kar ne̱ u̱s-ta'er e̱ zo̱ngte̱ remu̱ u̱n fu̱r-u̱t se̱. 
\p  
\v 7 Wa-to̱m u-Ru̱ yu̱ u̱r-taku̱n fur yu̱wa kar-ya, tu̱msu̱ na no̱m u̱t-tu̱ru̱m u̱ u-ra ne̱ u̱r-dame̱ u̱ m-hyu̱ ne̱ na gwu̱n to̱ u̱-do̱m u-dak. U̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t u̱ u-dak to tokos, tu̱msu̱ u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t tu̱ u̱s-te se̱ tokos, tu̱msu̱ u̱ gwa-u̱s yarse̱ ne̱ u̱s-be̱e̱t se̱ tokos. 
\p  
\v 8 Se̱ wa-to̱m u-Ru̱ yu̱ u-yu̱ru̱mse̱ wa fur yu̱wa kar-ya, tu̱msu̱ o̱ko̱n no̱m-o̱ u̱ka ta'ar-u yat-o̱ m-re̱ u-ra na gun o̱ u̱-me̱ m-sa. U̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t tu̱ m-sa to̱ baru̱m m-hyu̱,  
\v 9 tu̱msu̱ u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t tu̱ nom-tu̱ u̱r-fat tu̱ o̱ u̱-me̱ m-sa to̱ mu̱ru̱s, tu̱msu̱ u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t tu̱ u̱s-hat se̱ natu̱sse̱. 
\p  
\v 10 Se̱ wa-to̱m u-Ru̱ yu̱ tu̱tu̱rse̱ wa fur yu̱wa kar-ya, tu̱msu̱ re̱ge̱r-u yat-ya he̱e̱n du̱gu̱ do̱m u-ru̱, ya o̱ m-re̱ u-ra u̱ka u-hitirra yu̱ u̱t-kom. Ya he u̱-do̱mu̱ u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t su̱ u̱s-gi tu̱msu̱ u̱ do̱m-u̱ bu̱-mu̱ m-pe̱r.  
\v 11 Dim-du̱ re̱ge̱r-u ya na foge̱ U̱t-gag. Ya muut u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t tu̱ m-bu̱ u̱t-gag ne̱, tu̱msu̱ u̱t-ne̱t u-tát e̱ mu̱ru̱m remu̱ swadu̱ bu̱-mu̱ u̱t-gag. 
\p  
\v 12 Se̱ wa-to̱m u-Ru̱ yu̱ u-nasu̱rse̱ wa fur yu̱wa kar-ya, tu̱msu̱ u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t tu̱ u̱r-ho̱ to̱ baru̱m u-cwu̱m, tu̱msu̱ u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t tu̱ u-pyaat to̱ baru̱m u-cwu̱m, tu̱msu̱ u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t du̱ re̱ge̱r e̱ baru̱m u-cwu̱m. Tu̱msu̱ u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t tu̱ u̱r-hoot to̱ baru̱m u-cwu̱m, tu̱msu̱ u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t tu̱ m-gyu̱p to̱ baru̱m u-cwu̱m. 
\p  
\v 13 Se̱ u̱m got tu̱msu̱ u̱m hog u-shu̱p ya o̱ u̱r-yu̱ne̱ u̱ te̱k-u̱ do̱m u-ru̱ tu̱msu̱ u̱t-jar m-yat, ya o̱ u̱t-zu̱, <<No̱m-tu̱ u̱r-o̱n! No̱m-tu̱ u̱r-o̱n! No̱m-tu̱ u̱r-o̱n u̱du̱ i o̱ shu̱'u̱t u̱-me̱ u-dak u-be̱e̱t, u̱ remu̱ no̱mu̱ do̱'e̱ u̱t-no̱m da-u̱ a-to̱mu̱ u-Ru̱ ne̱ tu̱t i kuse̱ fure̱ kar-u̱s e̱!>> 
\c 9  
\p  
\v 1 Se̱ wa-to̱m u-Ru̱ yu̱ u-tanu̱rse̱ wa fur yu̱wa kar-ya, tu̱msu̱ u̱m hyu̱n u-re̱ge̱r yu̱ he̱e̱ne̱ du̱gu̱ do̱m u-ru̱ u-dak. Tu̱msu̱ na yase̱ wa u-mabudi yu̱ kub-u̱ za u̱r-ma.  
\v 2 Wa upus kub-u̱ za u̱r-ma, tu̱msu̱ fu̱'u̱t-mu̱ yu̱nne̱ du̱gu̱ me̱ u-kub u̱ka fu̱'u̱t-mu̱ ra-u yat-o̱. U̱r-ho̱ u̱ m-mya ne̱ to̱ baru̱m u-cwu̱m remu̱ m-fu̱'u̱t mu̱ rwu̱u̱ne̱ du̱gu̱ me̱ kub-u̱ za u̱r-ma.  
\v 3 Tu̱msu̱ du̱gu̱ me̱ m-fu̱'u̱t é cu̱zu̱n u̱-me̱ u-dak, tu̱msu̱ na yu̱' u̱n u̱r-be̱b u̱n no̱m m-tot u̱ka tot i u-dak u-be̱e̱t.  
\v 4 Na waru̱ e̱ u̱zu̱ a e̱ ho̱nse̱ gwa-su̱ u-dak ko̱ u̱r-ku̱wu̱t ko̱ u-te se̱di ne̱t-u̱t to̱ war-to̱ tu̱ zatte̱ nap-su̱ u-Ru̱ u̱ po̱ng-u̱t e̱ da.  
\v 5 Na waru̱ u̱n u̱zu̱ a u̱n ho̱ u̱n da, se̱di u̱n ya' u̱n u̱r-ko̱b m-te u̱s-pyaat u̱s-tan. Tu̱msu̱ toto-m u̱n o̱ u̱ka tot-mu̱ u-tot da-u̱ ya to̱-te̱ ne̱t.  
\v 6 U̱ ho̱-u̱t to̱ ne̱t-tu̱ do̱'e̱ goot-du̱ m-mar se̱di u̱n zaar u̱ kwu̱m-du̱ mo̱ da. U̱n do̱'e̱ u̱t-sa u̱n mar, se̱di mar-mu̱ do̱'e̱ so̱m-du̱ u̱n. 
\p  
\v 7 Sha-mu̱ é e̱ o̱ u̱ka jwaak i na zo̱nge̱ i m-gag. E̱ o̱tte̱ o̱ko̱n no̱m-o̱ u̱ka to̱p-tu̱ u̱r-faru̱k tu̱ bu̱-mu̱ u̱t-ró ne̱ du̱ shik u̱-do̱m-u̱ hi-u̱t e̱, tu̱msu̱ shu̱u̱t u̱n o̱ u̱ka sha-mu̱ shu̱u̱t-u̱ u̱t-ne̱t.  
\v 8 Hi-u̱s u̱n o̱ u̱ka hi-su̱ ne̱ta tu̱msu̱ nin-u̱ u̱n o̱ u̱ka nin u-zur.  
\v 9 U̱n o̱tte̱ u̱t-tum sha-mu̱ tum-tu̱ u̱t-kwam, tu̱msu̱ ram-su̱ kap-u̱t u̱n o̱ u̱ka ke̱ke̱-su̱ jwaak u-tát m-so̱m u̱du̱ m-gag.  
\v 10 U̱n o̱tte̱ u̱s-tor tu̱msu̱ u̱n nom m-tot u̱ka tot nomte̱. Tu̱msu̱ na yaag e̱ u̱r-be̱b e̱ ho̱nse̱ u̱t-ne̱t m-te u̱s-pyaat u̱s-tan u̱ tor-u̱s e̱.  
\v 11 Faru̱k-u̱ u̱n wa o̱ no̱m-yu̱ u̱s-te yu̱ kub-u̱ za u̱r-ma. Dim-u̱r wa u̱ rem-du̱ u̱t-Ibraniya na zu̱ wa Abadan tu̱msu̱ u̱ rem-du̱ u̱t-Girik na zu̱ wa Aporiyan, wata Wa-u̱r-ho̱. 
\p  
\v 12 Swa-u̱ u̱r-ko̱b du̱ u̱r-taku̱n aru̱kte̱, se̱di gwat, swa-u̱ u̱r-ko̱b u̱t-yu̱r o̱mo̱n.  
\v 13 Se̱ wa-to̱m u-Ru̱ wu̱ shi-shin fur yu̱wa kar-ya, tu̱msu̱ u̱m hog u-cwar ya o̱ rwu̱u̱n du̱gu̱ jwu̱n-tu̱ u̱r-sak u̱t-nas du̱ kwam-tu̱ bu̱-mu̱ u̱t-ró du̱ shik du̱ o̱o̱ge̱ u̱-shu̱ u-Ru̱.  
\v 14 Tu̱msu̱ ya zu̱ wa-to̱m u-Ru̱ yu̱ shishin wu̱ o̱ m-shu̱p u-kar ne̱, <<Uste̱ a-to̱m u-Ru̱ ne̱ e̱ nas i o̱ m-gag u̱ gi-u yat-ya yu̱ Yufiretis.>>  
\v 15 Tu̱msu̱ a-to̱m u-Ru̱ ne̱ e̱ nas i na zo̱nge̱ u̱ remu̱ da-u o̱ tu̱msu̱ ho̱-u̱r re ne̱ tu̱msu̱ pyaat-u ya ne̱ tu̱msu̱ hak-u ya ne̱ na ust u̱n remu̱ u̱n ho̱ru̱sse̱ u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t tu̱ ne̱t-tu̱ u-dak u̱t-be̱e̱t.  
\v 16 U̱m hog tat-u̱ karma-ne̱ u̱n teeg 200,000,000 karma-ne̱ u̱-do̱mu̱ jwaak. 
\p  
\v 17 Tu̱msu̱ u-me̱ hyan-u ri u̱m hyang jwaak u̱ i o m-sak ne̱ u̱-do̱mu̱ e̱. I o̱ m-sak u̱ do̱m-u̱ jwaak e̱ o̱ m-wa u̱t-tum ne̱ tu̱ bu̱-m jaz-mo̱ tu̱msu̱ rim-su̱ bu̱-mu̱ u̱t-ran ne̱ u̱ bu̱-mu̱ u̱t-ró ne̱. Jwaak-u̱ e̱ o̱tte̱ u̱t-hi u̱ka zur, tu̱msu̱ u-ra u̱ m-fu̱'u̱t ne̱ u̱ ta'ar-tu̱ bu̱-mu̱ u̱t-ró tu̱ o̱ m-tok o̱ rwu̱u̱n du̱gu̱ me̱ nu-u̱t e̱.  
\v 18 Remu̱ no̱m-u̱t tun-to̱ u̱t-tu̱t no̱m-tu̱ haatu̱n swadu̱ u̱r-ko̱b ne̱ du̱ u-ra, u̱ m-fu̱'u̱t ne̱, ta'ar-tu̱ bu̱-mu̱ u̱t-ró tu̱ o̱ m-tok tu̱ rwu̱u̱ne̱ du̱gu̱ nu-tu̱ jwaak, to̱ ho u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t tu̱ ne̱t-tu̱ u-dak.  
\v 19 Be̱b-du̱ jwaak-u̱ e̱ o̱ du̱gu̱ nu-u̱t e̱ u̱ tor-u̱s e̱ ne̱. Remu̱ u̱zu̱ tor-u̱s u̱n o̱ u̱ka fa, tor-u̱s se̱ o̱ u̱t-hi ne̱ tu̱ ho̱nse̱ u̱t-ne̱t. 
\p  
\v 20 Se̱di ne̱t-tu̱ kuse̱ i na ho̱ye̱ da u̱du̱ no̱m-tu̱ haatu̱n swadu̱ u̱r-ko̱b, u̱n gu̱gu̱m u̱t-byu̱ru̱n tu̱msu̱ u̱n yage̱ u̱t-ba'as. E̱ re u-shu̱ u̱ no̱me̱ no̱m u̱s-te u̱t-huuk u̱ ru̱-tu̱ za u̱r-fat ne̱ tu̱ kwam-tu̱ bu̱-mu̱ u̱t-ró ne̱ tu̱ shik tu̱msu̱ kwam-u̱t pus-to̱ ne̱ tu̱ shik tu̱msu̱ u̱ kwam-tu̱ bu̱-mu̱ u-dak ne̱ tu̱msu̱ u̱t-ta'ar ne̱ tu̱msu̱ u̱s-te ne̱ tu̱ zaare̱ m-hyan ko̱ m-ho̱g ko̱ m-ha da.  
\v 21 Tu̱msu̱ e̱ gu̱gu̱m yage̱-du̱ ho̱-du̱ u̱t-ne̱t ko̱ no̱m-du̱ m-bo̱n ko̱ m-o̱ ko̱ u-hiw ne̱. 
\c 10  
\s1 Wa-to̱m u-Ru̱ u̱ ran-u̱ u̱s-pan ne̱  //  u̱ re̱k-o̱ 
\p  
\v 1 Se̱ u̱m hyu̱n waku̱n wa-to̱m u-Ru̱ wu̱ o̱ u̱r-be̱b ne̱ wa o̱ cu̱zu̱n du̱gu̱ me̱ do̱m u-ru̱. Ku̱'u̱t-du̱ taku̱s wa, u̱ ro̱tu̱ro̱nd ne̱ do̱m-u̱ hi-u̱r wa. Shu̱-u wa o̱ u̱s-baku̱t u̱ka u̱r-ho̱, tu̱msu̱ na-u̱s wa o̱ u̱ka u-ra u̱ yu̱ne̱ m-kim m-da u-ru̱ u̱ka u̱r-kan.  
\v 2 Tu̱msu̱ wa o̱ m-shu̱p u̱ ran-u̱ u̱s-pan ne̱ u̱ re̱k-o̱ u̱ na upse̱ u̱ kom-u̱t wa. Tu̱msu̱ wa dor ba-tu̱ u̱s-na wa u̱ kom-u̱ u̱t-cwa wa u̱ do̱m-u̱ m-sa tu̱msu̱ na-u̱ kom-u̱ u̱r-beer wa u̱ do̱m-u̱ u-dak.  
\v 3 Se̱ wa nom u̱t-jar m-yat u̱ka jar-tu̱ u-zur. Tu̱msu̱ da-u̱ wa no̱me̱ u̱t-jar, se̱ u̱s-kagagag u̱s-ta'er se̱ shu̱s.  
\v 4 Da-u̱ kagagag-u̱s se̱ u̱s-ta'er no̱me̱ u̱s-rem, u̱m o̱ mo̱t-tu̱ u̱t-pan. Se̱di u̱m hog yaku̱n cwar-ya du̱gu̱ me̱ do̱m u-ru̱, ya o̱ u̱t-zu̱, <<Takse̱ no̱m-u̱ kagagag-u̱s se̱ u̱s-ta'er ware̱ tu̱msu̱ a-bo̱ o̱ m-pan da.>> 
\p  
\v 5 Se̱ wa-to̱m u-Ru̱ wa wu̱ u̱m hyane̱ ees u-do̱m m-sa tu̱msu̱ u-dak ne̱ wa jaku̱s kom u̱t-cwa wa m-gwat me̱ do̱m u-ru̱.  
\v 6 Wa no̱m u̱s-to̱nd u̱ dim-du̱ wu̱ o̱ u̱r-fat m-mo̱mmo̱, wu̱ no̱me̱ do̱m-u u-ru̱ u̱ no̱m-u̱ o̱o̱ge̱ u̱-me̱ o̱ ne̱, tu̱msu̱ u-dak ne̱ u̱ no̱m-u̱ o̱ u̱-me̱ o̱ ne̱, tu̱msu̱ m-sa ne̱ u̱ no̱m-u̱ o̱ u̱-me̱ o̱ ne̱. Wa zu̱, <<Naas u-da zamu̱n da!  
\v 7 Se̱di da-u̱ wa-to̱m u-Ru̱ wu̱ u-ta'er o̱ mo̱t-tu̱ fu̱rru̱ yu̱wa kar-ya, no̱m-tu̱ m-yasa tu̱ Ru̱-u̱ zo̱nge̱ u̱t-no̱m to̱ do̱'e̱ u̱t-shu̱, u̱ka wa war-tu̱ to̱k-ne̱ wa a-warru̱ rem-su̱ u-Ru̱ ne̱.>> 
\p  
\v 8 Se̱ cwar-yu̱ u̱m ho̱ge̱ du̱gu̱ me̱ do̱m u-ru̱, ya sur m-no̱m u̱s-rem u̱ me̱ ne̱: <<Do̱'e̱ bo̱ o̱nk ran-u̱ u̱s-pan u̱ na upse̱ du̱gu̱ kom-u̱ wa-to̱m u-Ru̱ wu̱ o̱o̱ge̱ u̱ ees u-do̱m m-sa tu̱msu̱ do̱m-u u-dak ne̱.>> 
\p  
\v 9 Se̱ u̱m do̱'e̱ u̱du̱ wa-to̱m u-Ru̱ tu̱msu̱ u̱m zu̱ wa <<Ya' me̱ ran-u u̱s-pan re̱k-o̱ u̱ o̱o̱ge̱ kom-u ró.>> Wa zu̱ me̱, <<Kab o̱ tu̱msu̱ bo̱ re̱ o̱. O̱ do̱'e̱ u̱t-shu̱'u̱t u̱t-gag u̱ me̱n-u̱t rò, se̱di u̱-me̱ nu-u rò o̱ do̱'e̱ u̱t-shu̱'u̱t m-re̱me̱r ne̱ u̱ka so̱.>>  
\v 10 Se̱ u̱m o̱nk ran-u̱ u̱s-pan re̱k-o̱ du̱gu̱ kom-u̱ wa-to̱m u-Ru̱ tu̱msu̱ u̱m tu̱'u̱s o̱. O̱ shu̱'u̱t m-re̱me̱r ne̱ u̱ka so̱ u̱ nu-u ri, se̱di da-u̱ u̱m tor-se̱ o̱, o̱ baru̱m u̱t-gag u̱ me̱n-u̱t ri.  
\v 11 Se̱ na waru̱ me̱, <<Se̱ bo̱ swu̱ru̱g m-war rem-su̱ u-Ru̱ u̱ mo̱t-tu̱ u̱t-ne̱t u-tát, u̱t-dak ne̱, u̱t-rem ne̱ tu̱msu̱ u̱t-faru̱k ne̱.>> 
\c 11  
\s1 U̱s-ees u̱s-yu̱r 
\p  
\v 1 Se̱ na yase̱ me̱ u-ryap yu̱ u-te yu̱ o̱ u̱ka u-ko̱m, tu̱msu̱ na zu̱ me̱, <<Do̱'e̱ bo̱ mu̱'u̱s be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱ u̱ sak-du̱ to̱o̱g ne̱, tu̱msu̱ bo̱ ogor tat-u̱ u̱t-ne̱t i no̱me̱ u̱t-huuk u̱ku̱n.  
\v 2 Se̱di a-bo̱ mu̱'u̱s kat-du̱ do̱-u̱ be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱ da. Remu̱ u̱zu̱ na ya'aste̱ o̱ u̱du̱ u̱t-dak, tu̱msu̱ u̱n do̱'e̱ jangu̱sse̱ bo̱-u u-he̱n m-te̱ u̱s-pyaat u̱t-shik u̱t-yu̱r u̱ u̱s-yu̱r (42).  
\v 3 Tu̱msu̱ u̱m do̱'e̱ yadu̱ a-warru̱ nip-u̱t ri ne̱ yu̱r u̱r-be̱b du̱ warru̱ rem-su̱ u-Ru̱ m-te u̱t-ho̱ 1,260 m-wa u̱ cwu̱-tu̱ namu̱ jab ne̱.>>  
\v 4 A-warru̱ u̱t-nip ne̱ ine̱ yu̱r e̱ o̱o̱ge̱ te-su̱ ze̱tun u̱s-yu̱r tu̱msu̱ kwam-su̱ u̱r-ees su̱ na su̱kte̱ u̱s-hitirra u̱s-yu̱r su̱ eese̱ u̱-shu̱ Wa-ko̱-uyan wu̱ o̱tte̱ u-dak u-be̱e̱t.  
\v 5 A waku̱n o̱ cwan-tu̱ wa ho̱nse̱ u̱n, ra-u̱ rwu̱u̱n du̱gu̱ nu-u̱t u̱n o̱ tokos hu̱u̱b-u̱t yo̱-to̱ u̱n. Iya-o̱ ko̱wana wu̱ o̱ u̱t-sa wa ho̱nsu̱ u̱n wa do̱'e̱ u̱t-mar.  
\v 6 Ne̱t-u̱t tun-to̱ u̱t-yu̱r u̱n o̱tte̱ be̱b-du̱ tage̱ du̱ do̱m u-ru̱ taas na no̱m u-yu̱ da da-u̱ e̱ o̱o̱ge̱ warru̱ rem-su̱ u-Ru̱. Tu̱msu̱ u̱n o̱tte̱ be̱b-du̱ muut-du̱ m-sa tu̱msu̱ u̱s-gi ne̱ m-hyu̱, tu̱msu̱ u̱n haatu̱n ko̱-uyan go̱-du̱ no̱m-tu̱ haatu̱n swadu̱ u̱r-ko̱b u̱-me̱ u-dak ko̱-uyan da-o̱ cite̱ u̱n. 
\p  
\v 7 Da-u̱ u̱n taase̱ warru̱ rem-su̱ u-Ru̱, bisa-u yo̱-o̱ yu̱ rwu̱u̱ne̱ du̱gu̱ kub-u̱ za u̱r-ma wa do̱'e̱ no̱m-du̱ m-gag u̱ u̱n ne̱ tu̱msu̱ wa do̱'e̱ zeg be̱b-u̱r u̱n wa ho̱ru̱sse̱ u̱n.  
\v 8 Tu̱msu̱ na do̱'e̱ u yagu̱ war-u̱t u̱n m-ru̱t u-dak u̱-do̱mu̱ fu̱n-u yat-ya u̱-me̱ bo̱-u yat-o̱ u̱ na foge̱ u̱ sha-mu̱ u̱s-rem Saduma u̱ Masar ne̱. Gandi bo̱-u o̱ o̱o̱ge̱ be-du̱ na su̱rgu̱sse̱ Wa-ko̱-uyan u̱n u-kan.  
\v 9 M-roog u̱t-tu̱t u̱ u-u̱k, u̱t-ne̱t u̱t-be̱e̱t, u̱t-ko̱ ne̱, u̱t-rem ne̱ tu̱msu̱ u̱t-dak ne̱ e̱ do̱'e̱ gwat-du̱ u-u̱t u̱n tu̱msu̱ e̱ za u̱t-yage̱ na jwak u̱n da.  
\v 10 Tu̱msu̱ I o̱ u̱r-yu̱ u̱ do̱m-u̱ u-dak e̱ do̱'e̱ no̱m-du̱ u̱r-so̱ do̱m-u̱ u̱n tu̱msu̱ e̱ no̱m mo̱ro̱g-du̱ u̱r-so̱, m-ha tom-tu̱ u-nya ne̱ u̱du̱ o̱r-u̱t u̱n ne̱. Remu̱ ine̱ a-warru̱ rem-su̱ u-Ru̱ ne̱ yu̱r e̱ yaag i o̱ u̱r-yu̱ u̱ do̱m-u̱ u-dak u̱r-ko̱b. 
\p  
\v 11 Se̱di ba roog-mu̱ u̱t-tu̱t u-u̱k arke̱ vu̱'e̱ su̱ u̱r-fat du̱gu̱-du̱ u-Ru̱ to u̱-me̱ u̱n, tu̱msu̱ u̱n yu̱ne̱ u̱ ba-tu̱ u̱s-na u̱n. Ne̱t-tu̱ hyane̱ u̱n gye̱r-u̱ yat-ya maas e̱.  
\v 12 Se̱ cwar-yu̱ m-yat du̱gu̱ me̱ do̱m u-ru̱ ya fog a-warru̱ rem-su̱ u-Ru̱ e̱ yu̱r, <<Daanu̱n u̱ ana!>> Tu̱msu̱ u̱n yu̱ne̱ m-da u̱-me̱ do̱m-u̱ u-ru̱ u̱-me̱ u̱r-ku̱'u̱t, da-u̱ hu̱u̱b-u̱t yo̱-to̱ u̱n o̱ madi-u̱r u̱n. 
\p  
\v 13 U̱ da-u o̱ za rem na no̱m ru̱mu̱s-du̱ u-dak du̱ yat-de̱ se̱ u̱r-kwu̱s u̱r-gan u̱-me̱ u̱t-o̱p tu̱ u-bo̱ o̱ hemu̱sse̱. Ne̱t-ne̱ 7,000 e̱ maru̱s u̱ remu̱ ru̱mu̱s-du̱ u-dak. Ko̱wan hog u-gye̱r so̱k tu̱msu̱ u̱n yu̱' Ru̱-u̱ me̱ do̱m u-ru̱ m-ze̱g. 
\p  
\v 14 Swa-u̱ u̱r-ko̱b du̱ u-yu̱ru̱mse̱ aru̱kte̱. Du̱ tu̱tu̱rse̱ o̱o̱n za rem. 
\s1 Kar-yu̱ u-ta'er 
\p  
\v 15 Wa-to̱m u-Ru̱ wu̱ u-ta'er wa fur yu̱wa kar-ya, tu̱msu̱ cwar-su̱ yu̱ne̱ u̱t-jar m-yat u̱-me̱ do̱m u-ru̱ se̱ o̱ u̱t-zu̱: 
\q1 <<Faru̱k-du̱ dak-u̱ u-be̱e̱t shu̱'u̱te̱ be-du̱ 
\q1 faru̱k-du̱ Wa-ko̱-uyan u̱ in tu̱msu̱ u̱ Kiristi wu̱n ne̱. 
\q2 Tu̱msu̱ Wa-ko̱-uyan do̱'e̱ u̱ no̱m-du̱ u̱r-faru̱k m-mo̱mmo̱.>> 
\m  
\v 16 Se̱ ne̱nge̱n-u̱t to̱ u̱r-shik u̱t-nas (24) i o̱ shu̱'u̱t u̱-do̱mu̱ pora-tu̱ u̱r-faru̱k u̱n u̱-shu̱ u-Ru̱, u̱n he do̱m-u̱ u̱t-jwu̱n u̱ shu̱u̱t u̱n ne̱ u-dak. Tu̱msu̱ u̱n no̱me̱ u-Ru̱ u̱t-huuk,  
\v 17 Tu̱msu̱ u̱n zu̱, 
\q1 <<It yaag u̱t-vam u̱du̱ ró, Wa-ko̱-uyan u-Ru̱ wu̱ ze̱ge̱ u̱r-be̱b, 
\q2 wu̱ o̱o̱ge̱ u̱ da-o̱ tu̱msu̱ wu̱ o̱o̱ge̱ u̱ da-u̱ arke̱, 
\q1 rem u̱zu̱ bo̱ kabu̱g be̱b-u̱r yat-de̱ ró 
\q2 tu̱msu̱ bo̱ he̱e̱se̱ u̱r-faru̱k. 
\q1  
\v 18 Dak-tu̱ hog u̱s-ryab, 
\q2 se̱di ryab-u̱s rò teegu̱n, 
\q1 tu̱msu̱ da-u̱ teegu̱n u̱ bo̱ do̱te̱ no̱mu̱ i mare̱ 
\q2 kwu̱p-du̱ u̱s-rem, 
\q2 tu̱msu̱ bo̱ ya' to̱k-ne̱ rò, a-warru̱ 
\q1 rem-su̱ u-Ru̱ ne̱, to̱p-u u̱n, 
\q1 tu̱msu̱ u̱ dame̱ ne̱t-tu̱ u-Ru̱ ne̱ u̱ i o̱ ho̱g-du̱ gye̱r-u̱ dim-u̱r ró ne̱, 
\q2 m-ha u̱ i-re̱k-e̱ u̱ i-yate̱ ne̱. 
\q1 Tu̱msu̱ da-u̱ teegu̱n u̱ bo̱ do̱'e̱ 
\q2 ho̱ru̱sse̱ ne̱t-tu̱ ho̱ru̱sse̱ u-dak u-be̱e̱t.>> 
\p  
\v 19 Se̱ na upus be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱ du̱ o̱ u̱-me̱ do̱m u-ru̱ tu̱msu̱ u̱-me̱ ku̱n na hyu̱n u̱r-tu̱ksu̱ra du̱ este̱du̱ u̱s-rem wa u̱-me̱ be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱. Tu̱msu̱ u̱ku̱n na nom u̱s-yaku̱t, u̱t-dum ne̱, u̱ gap-du̱ u̱s-kagagag ne̱, ru̱mu̱s-du̱ u-dak ne̱ tu̱msu̱ na nom u-yu̱ u̱ yat-o̱ u̱ u̱t-tu̱ru̱m ne̱ tu̱msu̱ m-mya ne̱. 
\c 12  
\s1 U-ne̱ta u̱ fa-u yat-ya ne̱ yu̱ yo̱-ya 
\p  
\v 1 Se̱ u̱m hyu̱n u-hyan u̱ ya'u̱ me̱ mu̱rimmo̱ o̱ rwu̱u̱gu̱n du̱gu̱ me̱ do̱m u-ru̱. U̱m hyu̱n u-ne̱ta ya na taku̱ste̱ wa u̱ u̱r-ho, tu̱msu̱ u-pyaat ne̱ u̱ ta-u̱ ba-tu̱ u̱s-na wa. Wa o̱ m-wa u̱ to̱p-du̱ u̱r-faru̱k ne̱ du̱ re̱ge̱r o̱p u̱ yu̱r (12) u̱ hi-u̱r wa.  
\v 2 Wa o̱ me̱n-tu̱ ub ne̱, tu̱msu̱ wa o̱ u̱s-eku̱s m-yat re̱mu̱ re̱-mu̱ u̱r-mat da-u̱ wa o̱ u̱ mo̱t-tu̱ u̱r-mat.  
\v 3 Se̱ u̱m hyu̱n se̱ku̱n nap-se̱ se̱ rwu̱u̱gu̱n du̱gu̱ me̱ do̱m u-ru̱. U̱m hyu̱n fa-u yat-ya yu̱ yo̱-ya u̱ jaz-ya yu̱ o̱tte̱ u̱t-hi u̱t-ta'er tu̱msu̱ u̱s-kar ne̱ u̱s-o̱p tu̱msu̱ to̱p-tu̱ u̱r-faru̱k ne̱ u̱t-ta'er u̱ do̱m-u̱ hi-u̱t wa.  
\v 4 Tor-u wa opos u̱r-kwu̱s u̱r-gan u̱ te̱k-u̱ u̱t-tu̱t tu̱ re̱ge̱r i do̱m u-ru̱ tu̱msu̱ wa gwu̱n e̱ u̱-me̱ u-dak. Se̱ fa-u yat-ya yu̱ yo̱-ya ya ees u-shu̱ ne̱ta-u ya yu̱ o̱ mo̱ttu̱ u̱r-mat, remu̱ wa toroste̱ u̱r-ya da-u̱ wa mate̱.  
\v 5 Ne̱ta-u ya mu̱t ya-du̱ u̱r-campa, wu̱ do̱'e̱ no̱m-du̱ faru̱k-du̱ u̱t-dak u̱ ko̱m-yu̱ yu̱ u-kwam. Tu̱msu̱ na rumus ya-u̱r wa m-da do̱m-u u-ru̱ tu̱msu̱ u̱du̱ pora-du̱ u̱r-faru̱k-u̱ wa.  
\v 6 Ne̱ta-u ya ku̱su̱m m-so̱m m-cwa u̱-me̱ u̱r-do̱g, m-ha be-du̱ Ru̱-u̱ zo̱ngte̱ u̱r-be remu̱ wa, du̱ wa do̱te̱ gwat-du̱ wa m-te m-roog 1,260. 
\p  
\v 7 Tu̱msu̱ gag-mu̱ yu̱ne̱ u̱-me̱ do̱m u-ru̱. Mika'iru u̱ a-to̱m wa ne̱ e̱ no̱m m-dum u̱ fa-u yat-ya ne̱ yu̱ yo̱-ya. Tu̱msu̱ fa-u yat-ya yu̱ yo̱-ya u̱ a-to̱mu̱ wa ne̱ e̱ top u̱r-mag.  
\v 8 Se̱di Mika'iru u̱ a-to̱mu̱ wa ne̱ u̱n zeg be̱b-du̱ fa-u yat-ya yu̱ yo̱-ya. Tu̱msu̱ fa-u yat-ya yu̱ yo̱-ya u̱ a-to̱mu̱ wa e̱ taag u̱ be-du̱ u̱r-shu̱'u̱t u̱-me̱ do̱m u-ru̱.  
\v 9 Se̱ na gwu̱n fa-u yat-ya yu̱ yo̱-ya u-dak, wata fa-u ya yu̱ du̱gu̱ da-u̱ dim yu̱ na foge̱ faru̱k-u̱ no̱m u̱s-te, wu̱ e̱ngu̱sse̱ u-dak u-be̱e̱t. Na gwu̱n wa u̱-do̱m u-dak u̱ a-to̱mu̱ wa ne̱ u̱r-kot u̱ wa ne̱. 
\p  
\v 10 Tu̱msu̱ u̱m hog cwar-yu̱ u̱r-be̱b du̱gu̱ me̱ do̱m u-ru̱ ya o̱ u̱t-zu̱, 
\q1 <<U̱ da-o̱ u̱ku̱r u̱ haagu̱n u̱ u̱r-be̱b ne̱ 
\q2 tu̱msu̱ u̱ faru̱k-du̱ Ru̱-u in ne̱, 
\q2 tu̱msu̱ be̱b-u̱r Kiristi wa ne̱. 
\q1 Remu̱ wu̱ ke̱te̱ o̱r-u̱t in u̱s-rem, campa-ne̱ u̱ u̱t-ne̱ta ne̱ 
\q2 wu̱ ke̱te̱ e̱ u̱s-rem u̱-shu̱ Ru̱-u̱ in u-ho̱ u̱ m-gyu̱p ne̱, 
\q2 na gwu̱n-gu̱n wa u-dak. 
\q1  
\v 11 Tu̱msu̱ u̱n re u̱r-ko̱rro̱ u̱ wa ne̱ 
\q2 remu̱ mar-mu̱ Kag-u̱r U̱r-ca do̱m u-kan 
\q2 tu̱msu̱ remu̱ rem-su̱ u-Ru̱ su̱ u̱n ware̱. 
\q1 U̱n cwang fat-u̱t u̱n sok da, 
\q2 har teet u̱n zaar u̱ ho̱g-du̱ gye̱r-u̱ m-mar da. 
\q1  
\v 12 Rem iya, no̱mo̱n u̱r-so̱, me̱ do̱m u-ru̱! 
\q2 Tu̱msu̱ u̱ no̱ ne̱ i o̱ u̱r-yu̱ u̱-me̱ do̱m u-ru̱, 
\q1 no̱mo̱n u̱r-so̱! Se̱di no̱m-tu̱ u̱r-o̱n u̱du̱ no̱ 
\q2 u-dak tu̱msu̱ m-sa ne̱. 
\q2 Remu̱ u̱zu̱ faru̱k-u̱ no̱m u̱s-te cu̱zgu̱n u̱du̱ no̱! 
\q1 Tu̱msu̱ wa shu̱u̱g u̱s-ryab ne̱, 
\q2 remu̱ wa nak u̱zu̱ da-u wa cashi o̱ kuse̱.>> 
\p  
\v 13 Da-u̱ fa-u yat-ya yu̱ yo̱-ya hyane̱ u̱zu̱ na gwu̱n-gu̱n wa u-dak, wa bu̱z ne̱ta-u ya yu̱ mate̱ ya-du̱ u̱r-campa.  
\v 14 Se̱di na yu̱' ne̱ta-u ya u̱t-kap u̱t-yu̱r u̱ka kap-tu̱ u-shu̱p, remu̱ wa yu̱nte̱ u̱t-kap m-ha be-du̱ na zo̱nge̱ wa u̱-me̱ u̱r-do̱g taas u̱ fa-u yo̱-ya maas wu̱n da. Ku̱na na do̱te̱ gwat-du̱ wa m-te, u-da u-gan, u̱t-da u̱t-yu̱r ne̱ tu̱msu̱ u̱k u-da ne̱.  
\v 15 Se̱ fa-u yat-ya yu̱ yo̱-ya ya agzu̱n m-bu̱ du̱gu̱ nu-u wa u̱ dim-u̱ ne̱ta-u ya u̱ka bu̱-mu̱ u-gi, remu̱ bu̱-mu̱ reet ne̱ta-u ya u̱ka bu̱-mu̱ re̱-du̱ u-dak.  
\v 16 Se̱di dak-u̱ se̱ge̱ ne̱ta-u ya u̱du̱ upus u-nu tu̱msu̱ o̱ toros gi-u ya yu̱ fa-u yat-ya yu̱ yo̱-ya agzu̱n du̱gu̱ nu-u wa.  
\v 17 Tu̱msu̱ fa-u yat-ya yu̱ yo̱-ya hog ryab-su̱ ne̱ta-u ya, tu̱msu̱ wa aru̱k remu̱ wa jum-ut m-gag u̱ ko̱-du̱ ne̱ta-u ya ne̱, i dore̱ no̱m-u̱ Ru̱-u̱ zu̱ u̱n no̱m tu̱msu̱ u̱n dor rem-u̱s Ye̱so̱.  
\v 18 Se̱ fa-u yat-ya yu̱ yo̱-ya yu̱ne̱ wa do̱'e̱ wa ees u̱-kit m-sa. 
\c 13  
\p  
\v 1 Se̱ u̱m hyu̱n bisa-u o̱ u̱ yo̱-o̱ u̱ rwu̱u̱n du̱gu̱ me̱ m-sa. 
\s1 Bisa-u yo̱-o̱ du̱gu̱ me̱ m-sa 
\p Wa o̱tte̱ u̱s-kar u̱s-o̱p u̱ u̱t-hi ne̱ u̱t-ta'er, u̱ to̱p-tu̱ u̱t-faru̱k ne̱ u̱t-o̱p u̱-do̱mu̱ kar-u̱s wa. Tu̱msu̱ m-pan u̱ do̱m-u̱ ko̱du̱he̱ hi-de̱ dim-tu̱ o̱rò du̱ pyap-su̱ u-Ru̱.  
\v 2 Bisa-u yo̱-o̱ ya o̱ u̱ka sha-mu̱ u-go. Se̱di na-u̱s wa o̱ u-cam tu̱msu̱ u̱t-can ne̱ u̱ karanku i o̱tte̱ m-re̱ tu̱msu̱ m-wu̱r sha-mu̱ su̱ bisa-yu̱ u̱r-do̱g yu̱ na foge̱ biye̱r tu̱msu̱ nu-u wa o̱ sha-mu̱ nu-u̱ u-zur. Fa-u yat-ya yu̱ yo̱-ya yase̱ bisa-u yo̱-o̱ ya be̱b-u̱r wa u̱ pora-du̱ u̱r-faru̱k-u̱ wa ne̱ u̱ faru̱k-u̱r yat-de̱ wa ne̱.  
\v 3 U̱m hyu̱n u̱r-gan u̱ te̱k-u̱ hi-tu̱ bisa-u yo̱-o̱ ya u̱ u̱r-ho̱nse̱ ne̱ du̱ yat-de̱ u̱ka du̱ do̱'e̱ ho̱-du̱ wa, se̱di ho̱nse̱-u̱r re̱ tu̱u̱s! U-dak u-be̱e̱t o̱ mu̱rimmo̱ tu̱msu̱ u̱n dor bisa-u yo̱-o̱ ya.  
\v 4 U̱n no̱me̱ fa-u yat-ya yu̱ yo̱-ya u̱t-huuk remu̱ zu̱ wa yaag bisa-u yo̱-o̱ ya u̱r-be̱b, tu̱msu̱ u̱n no̱me̱ bisa-u yo̱-o̱ ya u̱t-huuk. U̱n shit, <<Wana o̱tte̱ u̱r-be̱b u̱ka bisa-u yo̱-o̱ inya? Wana do̱'e̱ u̱t-kere̱ m-gag u̱ wa ne̱ tu̱msu̱ wa re̱ wa m-gag?>> 
\p  
\v 5 Na yu̱' bisa-u ya u̱r-ke̱r wa war gom-tu̱ hu̱k-mu̱ u̱r-hi tu̱msu̱ u̱ pyap-su̱ u-Ru̱ ne̱. Tu̱msu̱ na yu̱' wa-u̱r-be̱b u̱ wa no̱m no̱m-u̱ wa o̱ u̱t-sa u-be̱e̱t u̱s-pyaat u̱t-shik u̱t-yu̱r u̱ pyaat-su̱ u̱s-yu̱r (42).  
\v 6 Se̱ bisa-u yo̱-o̱ ya upus u-nu wa tu̱msu̱ wa o̱ pyap-su̱ u-Ru̱. Wa o̱ pyap-su̱ dim-du̱ u-Ru̱ u̱ be-du̱ u̱r-shu̱'u̱t wa ne̱, wata, i o̱ shu̱'u̱t u̱-me̱ do̱m u-ru̱.  
\v 7 Tu̱msu̱ na yu̱' bisa-u yo̱-o̱ ya u̱r-ke̱r wa no̱m m-gag u̱ ne̱t-tu̱ u-Ru̱ ne̱ tu̱msu̱ wa re̱ e̱ m-gag. Tu̱msu̱ na yu̱' wa-u̱r-be̱b u̱ wa no̱m u̱r-faru̱k du̱ ko̱du̱he̱ ko̱-de̱ u̱ u̱t-ne̱t ne̱ u̱ u̱r-rem ne̱ tu̱msu̱ u-dak ne̱.  
\v 8 Tu̱msu̱ ne̱t-tu̱ o̱ shu̱'u̱t u̱-me̱ u-dak u̱t-be̱e̱t e̱ do̱'e̱ no̱mu̱ bisa-u yo̱-o̱ ya u̱t-huuk. U̱na o̱o̱ge̱ ne̱t-tu̱ dim-u̱t e̱ zare̱ m-pan u̱-me̱ ran-u̱ u̱r-fat da du̱gu̱ na no̱m u-dak u-be̱e̱t, ran-u̱ u̱s-pan o̱ u̱ o̱o̱ge̱ u̱ Kag-u̱r U̱r-ca wu̱ na pane̱. 
\p  
\v 9 Kowan wu̱ o̱tte̱ u̱t-to̱ yage̱ wa gan u̱t-to̱. 
\q1  
\v 10 Ko̱wana na cine̱ u̱zu̱ se̱ wa no̱ng m-to̱k, 
\q2 to̱k-mo̱ wa do̱te̱ m-ha. 
\q1 Ko̱wana na cine̱ u̱zu̱ van-u̱ m-wu̱r o̱ do̱'e̱ ho̱-du̱ wa, 
\q2 tu̱msu̱ van-u̱ m-wu̱r o̱ na do̱te̱ ho̱-du̱ wa. 
\m Remu̱ iya ne̱t-tu̱ u-Ru̱ se̱ e̱ gak jab u̱ swadu̱ u̱r-ko̱b ne̱ tu̱msu̱ e̱ shu̱'u̱t u̱ yadu̱ jab ne̱. 
\s1 Bisa-u yo̱-o̱ rwu̱u̱gu̱n du̱gu̱ me̱ u-dak 
\p  
\v 11 Se̱ u̱m hyu̱n o̱ko̱n bisa-u yo̱-o̱ wu̱ o̱ rwu̱u̱n du̱gu̱ me̱ u-dak. Wa o̱tte̱ u̱s-kar u̱s-yu̱r u̱ka Kag-u̱r U̱r-ca, se̱di cwar-u wa o̱ u̱ka cwar-yu̱ fa-u yat-ya yu̱ yo̱-ya.  
\v 12 Wa o̱ no̱m-du̱ ko-uyan u̱ be̱b-du̱ bisa-u yo̱-o̱ ya yu̱ u̱r-taku̱n. Wa wa'ag u-dak u-be̱e̱t u̱ ne̱t-tu̱ o̱ u̱-me̱ o̱ ne̱ e̱ no̱mu̱ bisa-u yo̱-o̱ ya yu̱ u̱r-taku̱n u̱t-huuk, wu̱ ho̱nse̱-u̱r yat-de̱ wa tu̱u̱se̱.  
\v 13 Wa no̱m no̱m-tu̱ m-shin tu̱-yat-to̱, m-ha wa-du̱ u-ra ne̱ o̱ he̱e̱n du̱gu̱ do̱m u-ru̱ u-dak da-u̱ ko̱wan o̱ u̱t-gwat.  
\v 14 Tu̱msu̱ u̱ u̱s-nap ne̱ su̱ na ya'e̱ wa no̱m u̱ swas-mu̱ bisa-u yo̱-ya ya yu̱ u̱r-taku̱n, wa e̱ngu̱sse̱ u̱t-ne̱t u̱t-be̱e̱t tu̱ uno̱ dak-u u-be̱e̱t o̱. Wa wu̱' u̱t-ne̱t e̱ no̱m u-ma u̱ o̱o̱ge̱ sha-mu̱ bisa-u yo̱-ya ya yu̱ na ho̱nse̱ u̱ van-u̱ m-wu̱r tu̱msu̱ wa mu̱u̱n u̱r-fat remu̱ e̱ yu̱'u̱t wa m-ze̱g.  
\v 15 Na yu̱' bisa-u yo̱-ya ya yu̱ u-yu̱ru̱mse̱ u̱r-be̱b wa ya' u̱r-fat u̱du̱ ma-u̱ bisa-u yo̱-ya ya yu̱ u̱r-taku̱n, remu̱ wa nom-u̱t u̱s-rem tu̱msu̱ wa wa' i gu̱gme̱ no̱me̱-du̱ ma-u̱ bisa-u yo̱-ya u̱t-huuk be̱e̱t na ho̱ e̱.  
\v 16 Tu̱msu̱ wa wa'ag na wa'u̱ ko̱wan u̱s-nap u̱ kom u̱t-cwa ko̱ do̱m-u̱ po̱ng-u̱r wa, i-yate̱, i-re̱k-e̱, a-u̱t-kwu̱m ne̱, a-u̱r-ko̱b-ne̱, to̱k-ne̱, tu̱msu̱ wu̱ zare̱ m-to̱k da.  
\v 17 Tu̱msu̱ waku̱n zaar wu̱ do̱'e̱ ke̱rru̱ u̱t-o̱ ko̱ wa bab o̱ko̱n za nap-u̱s se̱ da, wata dim-du̱ bisa-u yo̱-ya ya, ko̱ u̱t-ogor ne̱ tu̱ o̱ ees-mu̱ dim-u̱r wa. 
\p  
\v 18 Uno̱ no̱m-o̱ o̱tte̱ sa-u̱ u̱s-ve̱r: Wu̱ o̱tte̱ m-nap, yage̱ wa nap ogor-tu̱ bisa-u yo̱-ya ya, remu̱ u̱zu̱ ogor-tu̱ dim-du̱ ne̱t-to̱. Ogor-u̱t to̱ o̱o̱ge̱ 666. 
\c 14  
\s1 Kag-u̱r U̱r-ca u̱ u̱t-ne̱t ne̱ u̱r-zo̱ngu u-gan  //  u̱ u̱t-shik u̱t-yu̱r u̱t-nas (144,000) 
\p  
\v 1 Se̱ u̱m got, tu̱msu̱ u̱ku̱n u̱-shu̱ ri u̱m hyu̱n Kag-u̱r U̱r-ca u̱ ees u̱-do̱mu̱ u̱r-ro̱r du̱ na foge̱ Sihiyona u̱-me̱ u-bo̱ u-he̱n u-Ru̱. Tu̱msu̱ u̱ Kag-u̱r U̱r-ca ne̱, u̱t-ne̱t ne̱ u̱r-zo̱ngu u-gan u̱ u̱t-shik u̱t-yu̱r u̱t-nas (144,000), i o̱tte̱ dim-u̱r wa u̱ dim-du̱ U̱so-u wa ne̱ m-pan u̱ po̱ng-u̱t e̱.  
\v 2 Tu̱msu̱ u̱m hog u̱s-ram se̱ o̱ rwu̱u̱n du̱gu̱ me̱ do̱m u-ru̱ sha-mu̱ ram-su̱ bu̱-mu̱ o̱ m-ja tu̱msu̱ sha-mu̱ dum-tu̱ u-kagagag m-yat. Wan-tu̱ u̱m ho̱ge̱ to̱ o̱ sha-mu̱ wan-tu̱ ya u̱t-o̱ni ne̱ e̱ o̱ o̱s-du̱ u̱s-mo̱ro̱.  
\v 3 Tu̱msu̱ e̱ fu se̱p-u po-o̱ u̱-shu̱ pora-du̱ u̱r-faru̱k du̱ u-Ru̱ tu̱msu̱ u̱-shu̱ no̱m-tu̱ u̱r-fat u̱t-nas u̱ ne̱nge̱n-u̱t to̱ ne̱. Waku̱n zaar wu̱ o̱ wu̱ kere̱ iis-u̱ se̱p-u o̱ da se̱ ne̱t-ne̱ e̱ u̱r-zo̱ngu u-gan u̱ u̱t-shik u̱t-yu̱r u̱t-nas (144,000) i na guye̱ du̱gu̱ me̱ u-dak u-be̱e̱t.  
\v 4 Tun-to̱ o̱ ne̱t-tu̱ naase̱ war-u̱t e̱ u̱ yu̱-du̱ m-o̱ da, remu̱ zu̱ u̱n shu̱pu̱k hi-u̱t u̱n u-he̱n ne̱. U̱n o̱ doru̱ Kag-u̱r U̱r-ca ko̱he̱ne̱ wa hu̱u̱te̱. Na o̱o̱g e̱ du̱gu̱ me̱ ne̱t-tu̱ u-dak u̱ka sha-mu̱ yadu̱ to̱o̱g-du̱ ket u̱r-taku̱n du̱ na yu̱'e̱ u̱du̱ u-Ru̱ u̱ Kag-u̱r u̱r-ca ne̱.  
\v 5 U̱n waru̱g u̱s-bi u̱ nu-u̱t u̱n da. U̱n zatte̱ u̱r-pyap da. 
\s1 A-to̱m u-Ru̱ ne̱ tu̱t 
\p  
\v 6 Se̱ u̱m hyu̱n waku̱n wa-to̱m u-Ru̱ u̱t-riig u̱t-kap m-mya u̱-do̱m u-ru̱. Wa zo̱ngte̱ re̱mu̱ wa nom-u̱t bu̱t-tu̱ rem-su̱ m-re̱me̱r su̱ m-mo̱mmo̱ u̱du̱ i o̱ u̱r-yu̱ u̱-me̱ u-dak u-be̱e̱t, u̱du̱ ko̱-u̱-he̱ dak-o̱, u̱r-ko̱ ne̱, u̱r-rem ne̱ tu̱msu̱ u̱t-ne̱t ne̱.  
\v 7 Se̱ wa zu̱ u̱ u-cwar yu̱ m-yat, <<Ho̱go̱n gye̱r-u̱ u-Ru̱ tu̱msu̱ no̱ ya' wa m-sek remu̱ ho̱-du̱ kwu̱p-du̱ u̱s-remu̱ wa teeg. No̱mo̱n wa u̱t-huuk wa yu̱ no̱mu̱ me̱ do̱m u-ru̱ u̱ u-dak ne̱, m-sa ne̱ tu̱msu̱ hu̱-su̱ bu̱-mu̱ m-pe̱r ne̱.>> 
\p  
\v 8 Se̱ wa-to̱m u-Ru̱ wu̱ u-yu̱ru̱mse̱ do̱ro̱n wu̱n, wa zu̱, <<Babira o̱ hemu̱sse̱! Babira bo̱-u yat-o̱ hemu̱sse̱! Bo̱-u uno̱ wa'ag u̱t-dak u̱t-be̱e̱t e̱ no̱m u̱r-kot u̱ wa ne̱ u̱ yu̱-du̱ m-o̱ u̱ wu̱n ne̱ u̱ka ne̱t wu̱ ke̱ ho̱ye̱.>> 
\p  
\v 9 Wa-to̱m u-Ru̱ wu̱ tu̱tu̱rse̱ dor u̱n, u̱t-jar m-yat, <<A-mu̱u̱ne̱ waku̱n no̱nge̱ bisa-u yo̱-ya ya u̱t-huuk tu̱msu̱ u̱ ma-u̱ o̱o̱ge̱ sha-mu̱ bisa-u yo̱-ya ya tu̱msu̱ wa o̱nk nap-u̱s u̱ wa do̱m-u̱ po̱ng-u̱r wa ko̱ do̱m-u̱ kom-u wa,  
\v 10 wa do̱'e̱ u̱t-goone̱ u̱ ryab-su̱ u-Ru̱ ne̱. Wa do̱'e̱ yadu̱ e̱ u̱r-ko̱b sok u̱ ryab-su̱ u-tát u̱ wa ne̱ u̱s-shu̱yi. Tu̱msu̱ e̱ do̱'e̱ swadu̱ u̱r-ko̱b u-tát u̱-me̱ u-ra u̱ do̱'e̱ u̱t-wa u̱ kwam-tu̱ u̱'e̱ u̱-shu̱ a-to̱m u-Ru̱ ne̱ i u-he̱n tu̱msu̱ u̱-shu̱ Kag-u̱r U̱r-ca.  
\v 11 Fu̱'u̱t-mu̱ u-ra mu̱ swadu̱ u̱r-ko̱b u̱ u̱n do̱'e u̱t-yu̱ne̱ u̱-do̱m u-ru̱ m-mo̱mmo̱. Tu̱msu̱ e̱ zaar kwu̱m-du̱ u̱r-hure̱ du̱gu̱ swa-u̱ u̱r-ko̱b u̱n da u-ho̱ u̱ m-gye̱p ne̱, remu̱ i no̱me̱ bisa-u yo̱-o̱ ya u̱t-huuk u̱ ma-u̱ o̱o̱ge̱ sha-mu̱ bisa-u yo̱-ya ne̱ ko̱ i o̱nke̱ nap-su̱ dim-u̱r wa.>>  
\v 12 Remu̱ iya, ne̱t-tu̱ u-Ru̱ se̱ e̱ gak jab-u̱ swa-u̱ u̱r-ko̱b ne̱, i do̱re̱ bo̱r-tu̱ u-Ru̱ tu̱msu̱ e̱ ship yadu̱ jab-u̱ e̱ u̱-me̱ Ye̱so̱. 
\p  
\v 13 Se̱ u̱m hog u-cwar du̱gu̱ me̱ do̱m u-ru̱ u̱zu̱, <<Pan no̱m-u̱t tun-to̱: Nu-u so̱-o̱ u̱du̱ i mare̱ u̱-me̱ yadu̱ jab u̱du̱ Wa-ko-uyan du̱gu̱ da-o̱ m-ha u-shu̱.>> 
\p <<U̱,>> no̱m-u̱ Yar-u̱ u-Ru̱ ware̱, <<u̱n do̱'e̱ kwu̱m-du̱ u̱r-hure̱ du̱gu̱ ank-m u̱n, remu̱ na do̱'e̱ no̱mu̱ u̱n u-to̱p u̱ remu̱ ank-m so̱mo̱ mu̱ u̱n no̱me̱ do̱'e̱ do̱rru̱ u̱n.>> 
\s1 Ket u-dak u-be̱e̱t 
\p  
\v 14 Se̱ u̱m got, tu̱msu̱ u̱ku̱n u̱-shu̱ ri u̱m hyu̱n ku̱'u̱t-u̱r pus-de̱, tu̱msu̱ wu̱ o̱ shu̱'u̱t u̱-do̱m ku̱'u̱t-u̱r re̱ wa o̱ sha-mu̱ Wa'u̱ Ne̱t. Wa o̱tte̱ to̱p-du̱ u̱r-faru̱k du̱ kwam-tu̱ bu̱-mu̱ u̱t-ró du̱ shik u̱-do̱mu̱ hi-u̱r wa tu̱msu̱ u-ro̱ji ne̱ yu̱ o̱tte̱ m-re̱ sok u̱ kom-u wa.  
\v 15 Se̱ waku̱n wa-to̱m u-Ru̱ rwu̱u̱n du̱gu̱ be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱. Tu̱msu̱ wa nom u̱t-jar m-yat u̱du̱ wu̱ o̱ shu̱'u̱t u̱-do̱m u̱r-ku̱'u̱t, <<Kab ro̱ji-u rò tu̱msu̱ bo̱ no̱m ket, rem u̱zu̱ da-u̱ ket teeg, remu̱ da-u̱ ket-u̱ no̱m-tu̱ na kawe̱ me̱ u-dak u-be̱e̱t teegu̱n.>>  
\v 16 Se̱ wu̱ o̱ shu̱'u̱t u̱-do̱m u̱r-ku̱'u̱t wa nu̱b ro̱ji-u wa u̱-me̱ u-dak u-be̱e̱t tu̱msu̱ na kest u-dak u-be̱e̱t. 
\p  
\v 17 Se̱ waku̱n wa-to̱m u-Ru̱ rwu̱u̱n du̱gu̱ be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱ u̱-me̱ do̱m u-ru̱, tu̱msu̱ ko̱wa wa o̱tte̱ u-ro̱ji yu̱ m-re̱ sok.  
\v 18 Waku̱n wa-to̱m u-Ru̱, wu̱ o̱ gwat-du̱ u-ra, wa rwu̱u̱n du̱gu̱ me̱ u̱r-sak wa no̱m u̱s-rem u̱ cwar-yu̱ u̱r-be̱b u̱du̱ wu̱ o̱ m-shu̱p u-ro̱ji ne̱ yu̱ o̱tte̱ m-re̱, <<Kab u-ro̱ji yu̱ m-re̱ ró bo̱ kargu̱sse̱ yatu̱ inabi tu̱ ne̱ne̱ du̱gu̱ u-dak, remu̱ u̱zu̱ ya-tu̱ inabi to̱ ne̱ng.>>  
\v 19 Se̱ wa-to̱m u-Ru̱ nu̱b ro̱ji-u wa u̱-me̱ u-dak, tu̱msu̱ wa gargu̱sse̱ inabi du̱gu̱ me̱ tak-u̱ inabi u̱ o̱ me̱ u-dak. Se̱ wa gun u̱n u̱-me̱ be-u̱r yat-de̱ be-du̱ na nomte̱ rew-mu̱ yatu̱ inabi. Ku̱na Ru̱-u̱ do̱te̱ u̱ yadu̱ u̱n u̱r-ko̱b u̱-me̱ ryab-u̱s wa.  
\v 20 Na ryawugu̱sse̱ e̱ u̱ be-du̱ na no̱m-te̱ ryu̱-u mu̱ yatu̱ inabi u̱-do̱ u-bo̱. Tu̱msu̱ hyu̱-mu̱ agzu̱n du̱gu̱ be-du̱ na no̱m-te̱ rew-mu̱ yatu̱ inabi mo̱ nom m-ja m-te ja-mu̱ nu-u̱ u-jwaak, m-te ra-mu̱ u̱s-kirome̱ta u̱t-ko̱k u̱t-tu̱t (300). 
\c 15  
\s1 A-to̱m u-Ru̱ ne̱ ta'er u̱ no̱m-tu̱ haatu̱n  //  swadu̱ u̱r-ko̱b ne̱ u̱t-ta'er 
\p  
\v 1 Se̱ u̱m hyu̱n u-hyan u̱ ya'u̱ me̱ mu̱rimmo̱ u̱ rwu̱u̱gu̱n du̱gu̱ me̱ do̱m u-ru̱: a-to̱m u-Ru̱ ne̱ ta'er e̱ o̱ m-shu̱p u̱ no̱m-tu̱ haatu̱n swadu̱ u̱r-ko̱b ne̱ u̱t-ta'er tu̱ m-vaste̱, tu̱ do̱'e̱ haatu̱n shu̱-du̱ ryab-su̱ u-Ru̱.  
\v 2 U̱m hyu̱n u̱-shu̱ ri o̱ko̱n no̱m-o̱ u̱ka m-sa u̱s-baku̱t u̱ka u̱r-madibi mo̱ samge̱ u-ra ne̱. Tu̱msu̱ u̱-do̱mu̱ de̱ ne̱t-tu̱ re̱ye̱ u̱r-ko̱rro̱ u̱ bisa-u yo̱-ya ya ne̱ u̱ ma-u̱ o̱o̱ge̱ sha-mu̱ bisa-u yo̱-ya tu̱msu̱ pan-yu̱ dim-u̱r wa ne̱. U̱n o̱ m-shu̱p u̱s-mo̱ro̱ ne̱ su̱ Ru̱-u̱ yase̱ u̱n.  
\v 3 U̱n fu se̱p-u Mosa to̱k-u u-Ru̱ tu̱msu̱ u̱ se̱p-u̱ Kag-u̱r U̱r-ca ne̱: 
\q1 <<No̱m-tu̱ bo̱ no̱me̱ to̱ o̱ u-tát tu̱msu̱ mu̱rimmo̱ ne̱, 
\q2 Wa-ko̱-uyan u-Ru̱, wu̱ zu̱ge̱ u̱r-be̱b u-be̱e̱t. 
\q1 Fu̱n-u̱s rò o̱ ho̱n-ho̱n tu̱msu̱ u̱t-nip ne̱, 
\q2 Faru̱k wu̱ u̱t-dak u̱t-be̱e̱t. 
\q1  
\v 4 Wana za ho̱g-du̱ gye̱r-u ró da, Wa-ko̱-uyan, 
\q2 tu̱msu̱ wa ya' m-sek u̱ dim-u̱r ró da? 
\q1 Remu̱ u̱zu̱ bo̱ wa o̱o̱ge̱ wa-u-he̱n u̱ war ró. 
\q1 U̱t-dak u̱t-be̱e̱t to̱ do̱'e̱ haan 
\q2 tu̱msu̱ e̱ no̱m u̱t-huuk u̱-shu̱ ró, 
\q1 remu̱ ank-mu̱ jab-u̱ so̱-o̱ ró rwu̱u̱gu̱n m-zu̱n.>> 
\p  
\v 5 Se̱ u̱m got u̱m hyu̱n be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱ (rimpa-du̱ este̱du̱ u̱s-rem su̱ u-Ru̱) u̱r-hu̱k u̱-me do̱m u-ru̱.  
\v 6 Se̱ a-to̱m u-Ru̱ ne̱ ta'er i o̱o̱ge̱ m-shu̱p u̱ no̱m-tu̱ haatu̱n swadu̱ u̱r-ko̱b ne̱ u̱t-ta'er e̱ rwu̱u̱n u̱-do̱ du̱gu̱ me̱ be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱. E̱ o̱ m-wa u̱ cwu̱-u̱t so̱-to̱ ne̱ tu̱msu̱ tu̱ m-bak-u̱t ne̱ u̱ hap-su̱ kwam-tu̱ bu̱-mu̱ u̱t-ró yu̱ shik-u̱ so̱k-u̱t u̱n.  
\v 7 Se̱ wagan u̱ te̱k-u̱ no̱m-tu̱ u̱r-fat u̱ to̱ u̱t-nas yase̱ a-to̱m u-Ru̱ ne̱ e̱ ta'er, u̱t-kwano ne̱ tu̱ kwam-tu̱ bu̱-mu̱ u̱t-ró tu̱ shik, to̱ shu̱u̱g u̱ ryab-su̱ u-Ru̱ ne̱, wu̱ o̱ u̱r-fat m-mo̱mmo̱.  
\v 8 Be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱ de̱ shi m-fu̱'u̱t du̱gu̱ sek-mu̱ u-Ru̱ u̱ be̱b-u̱r wa ne̱. Waku̱n zaar wu̱ o̱ kerru̱ cwadu̱ be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱ da se̱ a-to̱m u-Ru̱ ne̱ ta'er e̱ taaste̱ dasu̱ no̱m-tu̱ haatu̱n swadu̱ u̱r-ko̱b ne̱ u̱t-ta'er. 
\c 16  
\s1 U̱t-kwano u̱t-ta'er tu̱ ryab-su̱ u-Ru̱ 
\p  
\v 1 Se̱ u̱m hog u-cwar m-yat du̱gu̱ be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱ ya o̱ zu̱du̱ a-to̱m u-Ru̱ ne̱ ta'er, <<De̱e̱n tu̱msu̱ no̱ agu̱z kwano-u̱t yat-to̱ to̱ u̱t-ta'er tu̱ shiye̱ u̱ ryab-su̱ u-Ru̱ ne̱ u̱-me̱ u-dak u-be̱e̱t.>>  
\v 2 Se̱ wa-to̱m u-Ru̱ wu̱ u̱r-taku̱n do̱'e̱ wa da'as u̱-wa kwano o̱ u-me̱ u-dak u-be̱e̱t. Se̱ to̱ko̱n nat-u̱t yo̱-to̱ tu̱ o̱ m-re̱ ne̱ to̱ rwu̱u̱n u̱ war-tu̱ u̱t-ne̱t i o̱tte̱ nap-su̱ bisa-u yo̱-ya ya tu̱msu̱ u̱ i no̱me̱ ma-u̱ o̱o̱ge̱ sha-mu̱ bisa-u yo̱-ya ne̱ u̱t-huuk.  
\v 3 Se̱ wa-to̱m u-Ru̱ wu̱ u-yu̱ru̱mse̱ do̱'e̱ wa da'as u̱-wa kwano o̱ u̱-do̱mu̱ m-sa, tu̱msu̱ sa-mu̱ baru̱m u̱ka hyu̱-mu̱ u̱t-ne̱t tu̱ mare̱. Tu̱msu̱ ko̱-uyan u̱ o̱ u̱-me̱ m-sa o̱ mu̱ru̱s.  
\v 4 Se̱ wa-to̱m u-Ru̱ wu̱ u-tu̱tu̱rse̱ wa do̱'e̱ wa da'as u̱-wa kwano o̱ u̱-me̱ u̱s-gi u̱ be-tu̱ m-pe̱r ne̱, tu̱msu̱ to̱ baru̱m m-hyu̱.  
\v 5 Se̱ u̱m hog wa-to̱m u-Ru̱ wu̱ o̱tte̱ u̱r-be̱b u̱ do̱m-u̱ m-bu̱ o̱ u̱t-zu̱, 
\q1 <<Bo̱ wa u-ho̱n-ho̱n wa, 
\q2 Wa-u-He̱n, wu̱ o̱o̱ge̱ u̱ da-o̱ tu̱msu̱ wu̱ o̱o̱ge̱ u-da u-be̱e̱t, 
\q2 remu̱ u̱zu̱ bo̱ to̱mo̱tto̱n sin-se̱ kwu̱b-du̱ u̱s-rem se̱. 
\q1  
\v 6 Remu̱ u̱zu̱ u̱n agu̱zte̱ m-hyu̱ mu̱ ne̱t-tu̱ u-Ru̱ u̱ a-warru̱ rem-su̱ u-Ru̱ ne̱, 
\q2 tu̱msu̱ bo̱ yaag u̱n m-hyu̱ u̱n swa. O̱ o̱o̱ge̱ to̱p-u u̱n.>> 
\m  
\v 7 Tu̱msu̱ u̱m hog u-cwar du̱gu̱-du̱ u̱r-sak, u̱t-zu̱, 
\q1 <<U̱, Wa-ko̱-uyan u-Ru̱, wu̱ zu̱ge̱ u̱r-be̱b u-be̱e̱t, 
\q2 kwu̱p-du̱ u̱s-rem u̱ ró o̱ ho̱n-ho̱n tu̱msu̱ u̱t-nip ne̱.>> 
\p  
\v 8 Se̱ wa-to̱m u-Ru̱ wu̱ u-nasu̱rse̱ da'as u̱-wa kwano o̱ u̱-do̱m u̱r-ho̱, tu̱msu̱ na yu̱' u̱r-ho̱ u̱r-be̱b de̱ tok u̱t-ne̱t u̱ u-ra.  
\v 9 Se̱ du̱ng-mu̱ u-tát tokos u̱t-ne̱t har u̱n hu̱ pyap-su̱ dim-du̱ u-Ru̱, wu̱ wa'e̱ no̱m-u̱t to̱ u̱t-be̱e̱t to̱ no̱m. Se̱di u̱n gu̱gu̱m yage̱-du̱ u̱t-ba'as u̱n ya' u-Ru̱ m-sek. 
\p  
\v 10 Se̱ wa-to̱m u-Ru̱ wu̱ u-tanu̱rse̱ wa da'as u̱-wa kwano o̱ u̱-do̱mu̱ pora-du̱ u̱r-faru̱k du̱ bisa-u yo̱-ya ya, u̱ faru̱k-u̱r wa ne̱ to̱ baru̱m u-cwu̱m. Ne̱t-tu̱ hu̱ epu̱r-du̱ u̱t-go̱p u̱ remu̱ m-re̱.  
\v 11 Tu̱msu̱ u̱n hu̱ pyu̱pu̱r-ru̱ u-Ru̱ wu̱ do̱m u-ru̱ remu̱ m-re̱ u̱ nat-u̱t u̱n ne̱. Se̱di e̱ gu̱gu̱m yage̱-du̱ no̱m-du̱ no̱m-u̱t yo̱-to̱ tu̱msu̱ e̱ byu̱ru̱n u̱du̱ u-Ru̱. 
\p  
\v 12 Se̱ wa-to̱m u-Ru̱ wu̱ u-shishin da'as u̱-wa kwano o̱ u̱-me̱ gi-u yat-ya yu̱ Yufiretis. Tu̱msu̱ bu̱-m wa gu̱'u̱s remu̱ na mangte̱ faru̱k-tu̱ u-do̱m u-fu̱n.  
\v 13 Se̱ u̱m hyu̱n no̱m u̱s-te i rime̱ tu̱t i o̱ sha-mu̱ u̱t-ko e̱ rwu̱u̱gu̱n du̱gu̱ me̱ nu-u̱ fa-u yat-ya yu̱ yo̱-ya, du̱gu̱ me̱ nu-u̱ u̱ bisa-u yo̱-ya ya tu̱msu̱ du̱gu̱ me̱ nu-tu̱ wa-warru̱ rem-su̱ u-Ru̱ ne̱ wu̱ u̱s-bi.  
\v 14 U̱na o̱ yar-tu̱ no̱m u̱s-te i o̱ no̱m-du̱ no̱m-tu̱ m-shin u̱s-nap ne̱. Tu̱msu̱ u̱n ru u̱n do̱'e̱ u̱du̱ faru̱k-tu̱ u-dak u̱t-be̱e̱t, tu̱msu̱ u̱n kargu̱ssu̱n u̱n u̱ remu̱ gag-mu̱ m-vaste̱ mu̱ ho̱-u̱r yat-de̱ du̱ u-Ru̱ wu̱ zu̱ge̱ u̱r-be̱b.  
\v 15 <<Gwat, me̱ ya u̱m do̱'e̱ haan za nap-u̱r no̱ sha-mu̱ hyu̱-u! Nu-u so̱-o̱ u̱du̱ wu̱ shu̱'u̱te̱ u-ho̱g tu̱msu̱ wa cin kus-u̱t wa zo̱ngi zo̱ngi, taas wa no̱k u̱r-so da tu̱msu̱ wa ho̱g m-e̱' da.>> 
\p  
\v 16 Se̱ yar-tu̱ no̱m u̱s-te kargu̱sse̱ u̱t-faru̱k u̱ a-m-gagu̱ u̱n ne̱ u̱ de̱ku̱n be-de̱ du̱ na foge̱ Amagedon u̱ rem-du̱ Yahuda-ne̱. 
\p  
\v 17 Se̱ wa-to̱m u-Ru̱ wu̱ u-ta'er da'as u̱-wa kwano o̱ u̱-me̱ m-mya. Tu̱msu̱ jar-tu̱ m-yat rwu̱u̱n du̱gu̱ be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱, u̱zu̱, <<Na taaste̱!>>  
\v 18 Se̱ na nom gap-du̱ u̱s-kagagag, u̱t-dum ne̱, u̱ u̱s-yaku̱t ne̱ tu̱msu̱ ru̱mu̱s-du̱ u-dak. Na tamu̱g no̱m-du̱ go̱-du̱ ru̱mu̱s-du̱ u-dak iya da mu̱ na no̱m-te̱ ne̱t u-me̱ u-dak u-be̱e̱t, ru̱mu̱s-du̱ u-dak u̱ de̱ o̱ yat-de̱ sok.  
\v 19 Bo̱-u yat-o̱ o̱ mot u̱t-kwu̱s u̱t-tu̱t tu̱msu̱ bo̱-tu̱ u-dak u̱t-be̱e̱t to̱ hemu̱sse̱. Ru̱-u̱ baku̱s u̱ Babira ne̱ bo̱-u yat-o̱ tu̱msu̱ wa yu̱' wa ko̱k-du̱ m-bu̱ u̱r-shu̱yi shu̱yi u̱ ryab-su̱ u-Ru̱.  
\v 20 Tu̱msu̱ ko̱-u̱-he̱ dak-u̱ o̱o̱ge̱ m-gan m-sa o̱ e̱nk, tu̱msu̱ u̱t-ro̱r u̱t-be̱e̱t to̱ e̱nk.  
\v 21 Na no̱m u̱t-tu̱ru̱m tu̱-yat-to̱, tu̱ no'-mu̱ to̱ teye̱ tat-u̱ ne̱t. To̱ hu̱ hemu̱n du̱gu̱ do̱m u-ru̱ u̱ do̱m-u̱ u̱t-ne̱t, se̱di u̱n hu̱ pepu̱rru̱ u-Ru̱ u̱ remu̱ swa-u̱ u̱r-ko̱b du̱ u̱t-tu̱ru̱m ne̱, remu̱ u̱zu̱ swadu̱ u̱r-ko̱b u̱ de̱ o̱ u-tát. 
\c 17  
\s1 U-ne̱ta u̱ bisa-u yo̱-ya ne̱ 
\p  
\v 1 Wagan u̱ te̱k-u̱ a-to̱m u-Ru̱ ne̱ ta'er i o̱tte̱ u̱t-kwano u̱t-ta'er wa haan tu̱msu̱ wa zu̱ me̱, <<Do̱rnu̱ me̱, tu̱msu̱ u̱m do̱'e̱ ko̱su̱ bo̱ swadu̱ u̱r-ko̱b du̱ do̱'e̱ he̱e̱n u̱du̱ napi napi yu̱ u-kaar wu̱ o̱ shu̱'u̱t u̱ u̱-do̱m m-bu̱ u-tát.  
\v 2 Faru̱k-tu̱ u-dak no̱ng m-o̱ u̱ wu̱n ne̱. Tu̱msu̱ ne̱t-tu̱ u-dak u̱t-be̱e̱t ke̱ i m-o̱ wu̱n ho̱o̱g u̱n.>> 
\p  
\v 3 Se̱ wa-to̱m u-Ru̱ haan tu̱msu̱ wa ku̱b me̱ u̱-me̱ se̱ge̱-du̱ Yar-u̱ u-Ru̱ m-cwa u̱-me̱ u̱r-do̱g. Ku̱na u̱m bitte̱ u-ne̱ta u̱ shu̱'u̱t u̱-do̱mu̱ bisa-u yo̱-ya yu̱ jaz-ya tu̱msu̱ bisa-u yo̱-ya na taku̱ste̱ ya u̱ u̱t-gom tu̱ pyap-su̱ u-Ru̱ ne̱. Wa o̱tte̱ u̱t-hi u̱t-ta'er tu̱msu̱ u̱s-kar ne̱ u̱s-o̱p.  
\v 4 Ne̱ta-u ya o̱ m-wa kus-tu̱ bu̱-mu̱ u̱r-ge̱ ne̱ tu̱msu̱ tu̱ jas-to̱ ne̱, tu̱msu̱ wa no̱ng u̱t-u̱k u̱ ta'ar-tu̱ kwam-tu̱ bu̱-mu̱ u̱t-ró tu̱ shik, u̱ ta'ar-tu̱ shik ne̱ tu̱msu̱ uz-ne̱ i shik sok. Tu̱msu̱ wa o̱ m-shu̱p u̱ ko̱k-u̱ m-bu̱ ne̱ u̱ kwam-tu̱ bu̱-mu̱ u̱t-ró du̱ shik, de̱ shu̱u̱g u̱ bu̱-mu̱ ke̱ ne̱ mu̱ o̱ ees-mu̱ no̱m-tu̱ u̱s-gu̱r u̱t-go̱ u̱t-go̱ u̱ tu̱ o̱o̱-m wu̱n ne̱.  
\v 5 U̱ po̱ng-u̱r wa dim-du̱ o̱ró m-pan: 
\pc M-YASA 
\pc BABIRA U̱ YAT-O̱, 
\pc INO-U̱ KAAR NE̱ 
\pc TU̱MSU̱ INO-U̱ NO̱M-TU̱ U̱S-GU̱R TU̱ U-DAK U-BE̱E̱T. 
\m  
\v 6 U̱m hyu̱n ne̱ta-u ya swa-u̱ ho̱o̱g wa u̱ hyu̱-mu̱ ne̱t-tu̱ u-Ru̱ i ware̱ rem-su̱ u̱t-nip su̱ mo̱t-u̱t Ye̱so̱. 
\p Da-u̱ u̱m hyane̱ wu̱n u̱m hog mu̱rimmo̱.  
\v 7 Se̱ wa-to̱m u-Ru̱ zu̱ me̱, <<Rem-u yan-o̱ bo̱ o̱tte̱ u̱ mu̱rimmo̱? U̱m do̱'e̱ waru̱ bo̱ no̱m-tu̱ m-yasa tu̱ ne̱ta-u ya u̱ bisa-u yo̱-ya ya ne̱ yu̱ wa o̱tte̱ m-sak, yu̱ o̱tte̱ u̱t-hi u̱t-ta'er u̱ u̱s-kar ne̱ u̱s-o̱p.  
\v 8 Bisa-u yo̱-o̱ ya yu̱ bo̱ hyane̱, ya o̱o̱g u̱r-fat se̱di ya zaar u̱r-fat u̱ da-o̱ da. Tu̱msu̱ m-ha iyane̱ wa do̱'e̱ rwu̱u̱n du̱gu̱ me̱ kub-u̱ za u̱r-ma tu̱msu̱ ya do̱'e̱ u̱ be-du̱ m-mar. Tu̱msu̱ ne̱t-tu̱ dak-u̱ u-be̱e̱t ne̱ i dim-u̱t e̱ zaare̱ m-pan u̱-me̱ ran-u̱ u̱r-fat du̱gu̱ na no̱m u-dak u-be̱e̱t, u̱n do̱'e̱ no̱m-du̱ mu̱rimmo̱ u̱ remu̱ bisa-u yo̱-ya ya o̱o̱g u̱r-fat se̱di ya zaar u̱r-fat u̱ da-o̱ da tu̱msu̱ wa do̱'e̱ u̱t-swu̱r m-rwu̱u̱n u̱r-fat. 
\p  
\v 9 <<Rem-u̱s sin-se̱ u̱t-sa wu̱ o̱tte̱ jab-u̱ m-nap: Hi-u̱t to̱ u̱t-ta'er to̱ ees-mu̱ u̱t-ro̱r u̱t-ta'er tu̱ ne̱ta-u ya o̱tte̱ shu̱'u̱t. To̱ o̱ tu̱msu̱ shu̱'u̱t mu̱ u̱t-faru̱k u̱t-ta'er.  
\v 10 U̱t-faru̱k u̱t-tan to̱ aru̱kte̱, wu̱ shi-shin wa o̱ u̱r-faru̱k u̱ da-o̱, tu̱msu̱ wu̱ u-ta'er haagu̱n u-ro da, se̱di faru̱k-u̱r wa do̱'e̱ u̱t-shu̱'u̱t u-da cashi.  
\v 11 Bisa-u yo̱-ya ya o̱o̱g u̱r-fat se̱di da-o̱ ya zaar u̱r-fat da, ya o̱o̱ge̱ faru̱k-du̱ u-eer. Wa o̱ te̱k-u̱ u̱t-faru̱k u̱t-ta'er, tu̱msu̱ wa do̱'e̱ ha-mu̱ du̱ mar-m wa. 
\p  
\v 12 <<Kar-su̱ bo̱ hyane̱ u̱s-o̱p faru̱k to̱ u̱t-o̱p tu̱ o̱nke̱ u̱r-faru̱k da u-rò. Na do̱'e̱ ya-du̱ u̱n u̱r-be̱b du̱ no̱m-du̱ u̱r-faru̱k u-kwam u-gan u̱r-kot u̱ bisa-u yo̱-ya ya ne̱.  
\v 13 Faru̱k-u̱t tun-to̱ dorog-u̱s u̱n o̱ u̱s-gan, tu̱msu̱ u̱n do̱'e̱ yasu̱ be̱b-u̱r u̱n u̱ faru̱k-u̱r u̱n ne̱ u̱du̱ bisa-u yo̱-ya ya.  
\v 14 U̱r-koto de̱ u̱n do̱'e m-ha tu̱msu̱ u̱n no̱m m-dum u̱ Kag-u̱r U̱r-ca ya ne̱, se̱di Kag-u̱r U̱r-ca do̱'e u̱ re̱-du̱ u̱n m-gag remu̱ u̱zu̱ wa o̱o̱ge̱ Wa-ko-uyan yu̱ a-ko-uyan ne̱ tu̱msu̱ Faru̱k-du̱ u̱t-faru̱k u̱t-be̱e̱t. Tu̱msu̱ i wa fage̱ u̱ i wa dage̱ ne̱ tu̱msu̱ a jab-u̱ so̱-o̱ wa ne̱ e̱ do̱'e̱ u̱t-shu̱'u̱t u̱r-kot u̱ wa ne̱.>> 
\p  
\v 15 Se̱ wa-to̱m u-Ru̱ zu̱ me̱, <<Bu̱-mu̱ bo̱ hyane̱, be-du̱ kaar-u ya o̱tte̱ shu̱'u̱t, de̱ o̱ ees-mu̱ u̱t-ne̱t, u̱ ban-tu̱ u̱t-ne̱t ne̱, u̱t-dak ne̱ tu̱msu̱ u̱t-rem ne̱.  
\v 16 Bisa-u yo̱-ya ya yu̱ bo̱ hyane̱ tu̱msu̱ u̱s-kar ne̱ u̱s-o̱p e̱ do̱'e̱ gu̱g-mu̱ kaar-u ya. E̱ do̱'e̱ o̱nk-du̱ kwu̱m-u̱t wa u̱t-be̱e̱t u̱n yage̱ wa u̱r-so. U̱n do̱'e̱ tu̱'u̱su̱ war-u wa tu̱msu̱ u̱n tokos wa u-ra.  
\v 17 Remu̱ u̱zu̱ Ru̱-o̱ wa'e̱ go̱-du̱ dorog-u̱s se̱ u̱-me̱ jab-u̱s u̱n, no̱m-u̱ do̱'e̱ u̱t-wa u̱n no̱m no̱m-u̱ wa u̱t-sa u̱n no̱m. U̱n do̱'e̱ u̱t-ees u̱n yase̱ faru̱k-u̱r u̱n u̱du̱ bisa-u yo̱-ya ya, m-te da-u̱ na do̱'e̱ shu̱u̱s-du̱ rem-su̱ u-Ru̱.  
\v 18 Tu̱msu̱ ne̱ta-u inya yu̱ bo̱ hyane̱ u̱-me̱ hyan-u ró wa o̱ shu̱'u̱t-mu̱ bo̱-u yat-o̱ u̱ o̱o̱ge̱ faru̱k-du̱ faru̱k-tu̱ u-dak u-be̱e̱t.>> 
\c 18  
\s1 He̱'e̱ du̱ bo̱-u̱ Babira 
\p  
\v 1 Da taase̱ tu̱msu̱ u̱m hyu̱n waku̱n wa-to̱m u-Ru̱ wa cu̱zu̱n du̱gu̱ me̱ do̱m u-ru̱. U̱ be̱b-u̱r yat-de̱ ne̱ sok, wa o̱tte̱ shin-m yat-mo̱, tu̱msu̱ dak-u̱ no̱m m-zu̱n u̱ remu̱ sek-m wa.  
\v 2 Wa nom u̱t-jar u̱ cwar-yu̱ m-yat: 
\q1 <<Babira o̱ hemu̱sse̱! Babira bo̱-u yat-o̱ hemu̱sse̱! 
\q2 O̱ shu̱'u̱te̱ be-du̱ u̱r-pak du̱ ko̱-uyan go̱-du̱ no̱m u̱s-te ne̱ 
\q1 tu̱msu̱ be-du̱ u̱r-pak du̱ ko-uyan go̱-du̱ yar-u̱t yo̱-to̱ 
\q2 tu̱msu̱ be-du̱ u̱r-pak du̱ ko̱-uyan go̱-du̱ no za so̱-ye̱ ne̱ 
\q1 tu̱msu̱ be-du̱ u̱r-pak du̱ ko̱-uyan go̱-du̱ bisa-o̱ 
\q2 u̱ za u-he̱n tu̱msu̱ u̱ tu̱ u̱s-gu̱r ne̱. 
\q1  
\v 3 U̱t-dak u̱t-be̱e̱t e̱ no̱ng u̱r-kot u̱ wa ne̱, 
\q2 u̱ yu̱-du̱ m-o̱ u̱ wu̱n ne̱ u̱ka ne̱t wu̱ ke̱ ho̱ye̱. 
\q1 Faru̱k-tu̱ u-dak to̱ no̱ng m-o̱ u̱ wu̱n ne̱, 
\q2 tu̱msu̱ a-u-cerpa ne̱ i u-dak u-be̱e̱t shu̱'u̱te̱ a-u̱t-kwu̱m ne̱ 
\q2 so̱k remu̱ u̱zu̱ wu̱n kerge̱ o̱o̱du̱ nom-tu̱ shik u-tát.>> 
\p  
\v 4 Se̱ u̱m hog yaku̱n cwar-ya u̱s-fag du̱gu̱ me̱ do̱m u-ru̱, 
\q1 <<Hatu̱n m-ra du̱gu̱-du̱ wu̱n, ne̱t-u̱t ri. 
\q2 A no̱ same̱ u̱t-hi u̱ ba'as-u̱t wu̱n ne̱ da, 
\q2 taas tu̱msu̱ na ya' no̱ u̱r-ko̱b u̱r-kot u̱ wu̱n ne̱. 
\q1  
\v 5 Remu̱ ba'as-u̱t wu̱n no̱ng u-tát, u̱ka ta'ar-tu̱ na kargu̱sse̱ to̱ nom m-ja m-te̱ me̱ do̱m u-ru̱, 
\q2 tu̱msu̱ Ru̱-u̱ baku̱ste̱ u̱ no̱m-u̱t yo̱-to̱ rò ne̱. 
\q1  
\v 6 No̱mu̱ wu̱n u̱ka wu̱n nomte̱ u̱t-ne̱t. To̱p-u̱ wu̱n u-so yu̱r remu̱ no̱m-u̱t yo̱-to̱ ró. 
\q2 U̱-me̱ ko̱k-du̱ du̱ wu̱n var-tu̱ e̱ke̱n ne̱, 
\q2 varu̱n wu̱n ko̱wu̱n u-so u-yu̱r no̱m-u̱ wu̱n varu̱ e̱. 
\q1  
\v 7 Ya' kaar-u ya u̱r-ko̱b tu̱msu̱ u̱ namu̱ jab ne̱ 
\q2 u̱ka m-sek tu̱msu̱ u̱ ho̱g-du̱ m-re̱me̱r ne̱ 
\q2 du̱ wu̱n ya'e̱ hi-u̱r wu̱n. 
\q1 Wa no̱ng u̱t-u̱k u̱-me̱ jab-u̱ wa, 
\q2 <U̱m shu̱'u̱te̱ u̱ka u-re̱n tu̱msu̱ u̱m zaar bomos da. 
\q2 U̱m zaar u̱ tame̱-du̱ no̱m-du̱ namu̱ jab da.> 
\q1  
\v 8 Remu̱ iya, no̱m-tu̱ haatu̱n swadu̱ u̱r-ko̱b tun-to̱ do̱'e̱ he̱e̱n u̱du̱ rò u̱r-ho̱ u̱r-gan: 
\q2 m-mar u̱ namu̱ jab ne̱ u̱ u̱s-me̱r ne̱. 
\q2 Ra-u̱ do̱'e̱ u̱ toksu̱ wu̱n, 
\q1 remu̱ u̱zu̱ Wa-ko-uyan u-Ru̱ wu̱ do̱'e̱ kwu̱pu̱ wu̱n u̱s-rem 
\q2 wa o̱ wa-u̱r-be̱b u-be̱e̱t. 
\p  
\v 9 <<Tu̱msu̱ faru̱k-tu̱ u-dak u̱t-be̱e̱t tu̱ no̱me̱ m-o̱ u̱ wu̱n ne̱ u̱ yu̱-du̱ ho̱g-du̱ m-re̱me̱r u̱ wu̱n ne̱ e̱ do̱'e̱ no̱m-du̱ u̱s-kan u̱ namu̱ jab ne̱ da-u̱ u̱n hyane̱ m-fu̱'u̱t mu̱ o̱ yu̱ne̱ du̱gu̱ ra-u̱ o̱o̱ge̱ tok-du̱ wu̱n.  
\v 10 E̱ do̱'e̱ u̱t-ees m-ra, e̱ ho̱g u-gye̱r u̱ remu̱ swa-u̱ u̱r-ko̱b wu̱n. Tu̱msu̱ u̱n do̱'e̱ u̱t-zu̱, 
\q1 << <No̱m-tu̱ u̱r-o̱n! No̱m-tu̱ u̱r-o̱n u̱du̱ ró Bo̱-u Yat-o̱, 
\q2 Babira bo̱-u yat-o̱! 
\q1 Remu̱ u̱zu̱ u̱-me̱ u-kwam u-gan 
\q2 kwu̱p-du̱ u̱s-rem su̱ u-Ru̱ he̱e̱gu̱n u̱du̱ rò.> 
\p  
\v 11 <<A-u-cerpa ne̱ i u-dak u-be̱e̱t e̱ no̱m u̱s-kan u̱ namu̱ jab ne̱ rem-u wu̱n, remu̱ u̱zu̱ waku̱n zamu̱n wu̱ do̱'e̱ u̱ o̱o̱du̱ cwu̱-u̱t e̱ da.  
\v 12 Cwu̱-tu̱ u̱n o̱o̱ge̱ u̱t-bab to̱ o̱o̱ge̱, kwam-tu̱ bu̱-mu̱ u̱t-ró tu̱ shik, ta'ar-tu̱ pus-to̱ ne̱ tu̱ shik ne̱, ta'ar-tu̱ shik ne̱, u̱ uz ne̱ i shik, tu̱msu̱ u̱ cwu̱-tu̱ u̱s-ke̱e̱r ne̱ tu̱ so̱-to̱, u̱ kus-tu̱ bu̱-mu̱ u̱r-ge̱ ne̱, u̱ tu̱ jas-to̱, kus-tu̱ m-baku̱t ne̱, u̱s-katako̱ ne̱ su̱ te-yu̱ Sitiru, tu̱msu̱ no̱m-tu̱ na no̱me̱ du̱gu̱ nin u-rwag, u̱ katako-su̱ shik ne̱, kwam-tu̱ bu̱-mu̱ u-dak ne̱ tu̱ shik, kwam-u̱t rim-to̱ ne̱ tu̱msu̱ ta'ar-tu̱ m-baku̱t ne̱,  
\v 13 u̱ u̱t-kirfa, u̱ u̱t-po̱-u̱g ne̱, u̱ no̱o̱g-mu̱ wu̱s u-haku̱n ne̱, u̱ m-no̱o̱g ne̱ u̱ mur ne̱, u̱ no̱o̱g-mu̱ mang u-war ne̱, u̱ ke̱ ne̱, u̱ no̱o̱g-mu̱ inabi ne̱, u̱ hyu̱-mu̱ fat ne̱, u̱ hyu̱-mu̱ bur ne̱, u̱ na ne̱, u̱ ca ne̱, u̱ jwaak ne̱, u̱ ke̱ke̱-su̱ jwaak ne̱, u̱ to̱k-ne̱ wata, u̱ fat-tu̱ u̱t-ne̱t ne̱. 
\p  
\v 14 <<U̱n do̱'e̱ u̱t-zu̱, <Ya-tu̱ u̱s-te tu̱ bo̱ tumbe̱ u̱t-sa bo̱ kum to̱ haag m-ha. Cwu̱-tu̱ shik ró u̱t-be̱e̱t u̱ no̱m-tu̱ bo̱ zu̱ge̱ u̱t-cwan ne̱ to̱ e̱nkte̱ bo̱, bo̱ zamu̱n u̱ kwu̱m-du̱ to̱ da m-mo̱mmo̱.>  
\v 15 A-u-cerpa ne̱ i shu̱'u̱te̱ a-u̱t-kwu̱m ne̱ u̱ remu̱ babu̱ wu̱n no̱m-u̱t tun-to̱ e̱ do̱'e̱ u̱t-ees m-ra, e̱ o̱ ho̱g-du̱ u-gye̱r u̱ remu̱ swa-u̱ u̱r-ko̱b ró. E̱ do̱'e̱ no̱m-du̱ u̱s-kan u̱ namu̱ jab ne̱. 
\q1  
\v 16 << <No̱m-tu̱ u̱r-o̱n! No̱m-tu̱ u̱r-o̱n, u̱du̱ bo̱-u yat-o̱ uno̱! 
\q1 Wu̱ o̱ m-wa' u̱ kus-u̱t so̱-to̱ ne̱ tu̱ u̱s-ke̱e̱r, 
\q2 u̱ tu̱ bu̱-mu̱ u̱r-ge̱ ne̱ tu̱msu̱ tu̱ jas-to̱ ne̱, 
\q2 tu̱msu̱ u̱t-u̱k ne̱ tu̱ kwam-tu̱ bu̱-mu̱ u̱t-ró tu̱ shik, 
\q1 u̱ ta'ar-tu̱ shik ne̱ tu̱msu̱ uz ne̱ i shik! 
\q1  
\v 17 U̱-me̱ u-kwam u-gan kwu̱m-u̱t yatto̱ to̱ natu̱sse̱!> 
\p <<Ko̱yu̱he̱ yu̱ yat-ya hat-su̱ m-bu̱ u̱ i nome̱ m-ha u̱-me̱ m-sa ne̱, u̱ ne̱t-tu̱ nak-du̱ u̱s-hat ne̱ tu̱msu̱ u̱ i kume̱ shik-u̱ e̱ ne̱ du̱gu̱ u̱-me̱ m-sa e̱ do̱'e̱ u̱t-ees m-ra.  
\v 18 Da-u̱ u̱n hyane̱ m-fu̱'u̱t du̱gu̱ be-du̱ wu̱n o̱tte̱ m-tok u̱n do̱'e̱ no̱m-du̱ u̱t-jar u̱n zu̱ <He̱ne̱ o̱ o̱ko̱n bo̱-o̱ o̱tte̱ u̱ o̱ yat-o̱ u̱ka bo̱-u uno̱?>  
\v 19 Tu̱msu̱ e̱ do̱'e̱ u̱s-kan u̱ namu̱ jab ne̱ u̱ as-du̱ m-huug ne̱ u̱ hi-u̱t e̱ remu̱ e̱ ko̱ste̱ namu̱ jab e̱. Tu̱msu̱ e̱ do̱'e̱ u̱t-jar, 
\q1 << <No̱m-tu̱ u̱r-o̱n! No̱m-tu̱ u̱r-o̱n u̱du̱ 
\q2 ró uno̱ bo̱-u yat-o̱ o̱! 
\q1 I o̱tte̱ u̱s-hat e̱ shu̱'u̱t a-u̱t-kwu̱m ne̱ 
\q2 remu̱ pu̱st-du̱ kwu̱m-u̱t wu̱n m-bu̱. 
\q1 U̱-me̱ u-kwam u-gan, to̱ aru̱kte̱ u̱t-be̱e̱t! 
\q1  
\v 20 Cwar-yu̱ re u̱-shu̱ u̱t-zu̱ du̱gu̱ me̱ do̱m-u̱ u-ru̱, 
\q2 No̱mo̱n u̱r-so̱ u̱ remu̱ Babira no̱ ne̱t-tu̱ o̱ me̱ do̱m u-ru̱! 
\q1 No̱mo̱n u̱r-so̱, ne̱t-tu̱ u-Ru̱ u̱ a-to̱mu̱ Ye̱so̱ ne̱ 
\q2 u̱ a-warru̱ rem-su̱ u-Ru̱ ne̱! 
\q1 Ru̱-u̱ no̱mgu̱ wu̱n kwu̱p-du̱ u̱s-rem u̱ka wu̱n no̱m-tu̱ no̱.> >> 
\p  
\v 21 Se̱ wa-to̱m u-Ru̱ wu̱ u̱r-be̱b ku̱b ta'ar-u yat-o̱ u̱ka ta'ar-u̱r du̱ u̱r-na tu̱msu̱ wa gun de̱ u̱-me̱ m-sa, wa o̱ u̱t-zu̱, 
\q1 <<I ya-o̱ bo̱-u yat-o̱ Babira na do̱te̱ u̱ gwu̱n-du̱ wa-u̱r-be̱b 
\q2 tu̱msu̱ na zamu̱n u̱ hyan-du̱ o̱ da. 
\q1  
\v 22 Na zamu̱n u̱t-sur m-ho̱g wan-tu̱ u̱s-mo̱ro̱, u̱ a u̱t-se̱p ne̱, u̱r-tu̱kku̱rma ne̱, tu̱msu̱ u̱s-kar ne̱ u̱-me̱ ró da. 
\q1 Tu̱msu̱ na zamu̱n u̱t-sur m-kwu̱m waku̱n 
\q2 wa no̱m-du̱ u-cerpa u̱-me̱ rò da. 
\q1 Na zamu̱n tu̱msu̱ u̱t-sur m-ho̱g wan-tu̱ u̱r-na u̱-me̱ ró da. 
\q1  
\v 23 Zu̱n-mu̱ u-hitirra 
\q2 zamu̱n u̱t-mo̱k u̱-me̱ ró da. 
\q1 Cwar-yu̱ gwu̱p u̱r-gu̱ u̱ zwar u̱r-gu̱ ne̱ 
\q2 na zamu̱n u̱t-sur m-ho̱g u̱-me̱ ró da. 
\q1 A-u̱t-kwu̱m ne̱ ró e̱ o̱o̱ge̱ i-yate̱ u-dak u-be̱e̱t, 
\q2 rem u̱zu̱ bo̱ e̱ngu̱sse̱ u̱t-dak u̱t-be̱e̱t u̱ gwat-u̱ bo̱ nome̱. 
\q1  
\v 24 U̱-me fu̱n-u̱s rò na byu̱k-u̱t hyu̱-mu̱ a-warru̱ rem-su̱ u-Ru̱ ne̱ u̱ ne̱t-tu̱ u-Ru̱ ne̱ 
\q2 tu̱msu̱ u̱ hyu̱-mu̱ u̱t-ne̱t u̱t-be̱e̱t tu̱ na ho̱ye̱ 
\q2 ne̱ u̱-me̱ u-dak u-be̱e̱t.>> 
\c 19  
\s1 Na vam Wa-ko-uyan 
\p  
\v 1 Da taase̱ u̱m hog na no̱ng u-gwu̱z u̱ka gwu̱z-u̱ u̱t-ne̱t u-tát u̱-me̱ do̱m u-ru̱, u̱n o̱ u̱t-jar: 
\q1 <<Na vam Wa-ko-uyan! 
\q2 U-u̱ku̱r tu̱msu̱ m-sek ne̱ u̱ u̱r-be̱b ne̱ shu̱'u̱t u̱du̱ Ru̱-u in, 
\q1  
\v 2 remu̱ u̱zu̱ kwu̱p-du̱ u̱s-rem u̱ wa nip-to̱ tu̱msu̱ ho̱n-ho̱n. 
\q1 Remu̱ wa no̱ngu̱ kaar-u yat-ya ya kwu̱p-du̱ u̱s-rem 
\q2 wu̱ nase̱ u-dak u-be̱e̱t u̱ m-o̱. 
\q1 Wa no̱ngu̱ wu̱n u-to̱p remu̱ u̱zu̱ 
\q2 wu̱n ho̱o̱g i no̱mu̱ wa m-to̱k.>> 
\p  
\v 3 Tu̱msu̱ u-yu̱ru̱mse̱ u̱n sur m-no̱m u̱t-jar, 
\q1 <<Na vam Wa-ko-uyan! 
\q1 M-fu̱'u̱t mu̱ bo̱-u o̱ do̱'e̱ u̱t-yu̱ne̱ u-ru̱ m-mo̱mmo̱!>> 
\p  
\v 4 Tu̱msu̱ ne̱nge̱n-u̱t to̱ u̱r-shik u̱t-nas u̱ no̱m-tu̱ u̱r-fat ne̱ u̱t-nas (24) u̱n he u-dak u̱n no̱me̱ u-Ru̱ u̱t-huuk wu̱ o̱ shu̱'u̱t u̱ do̱m-u̱ pora-du̱ u̱r-faru̱k. Tu̱msu̱ u̱n zu̱, 
\q1 <<U̱ shu̱'u̱t iya! Na vam Wa-ko-uyan!>> 
\p  
\v 5 Se̱ cwar-yu̱ rwu̱u̱n du̱gu̱ pora-du̱ u̱r-faru̱k, ya zu̱, 
\q1 <<Vamu̱n Ru̱-u in, 
\q2 to̱kne̱ wa be̱e̱t, 
\q1 i o̱o̱ge̱ u̱ gye̱r-u wa, 
\q2 u̱ same̱ i-re̱k-e̱ u̱ i-yate̱.>> 
\p  
\v 6 Se̱ u̱m sur m-ho̱g u̱t-jar u̱ka jar-tu̱ u̱t-ne̱t u-tát, ko̱ sha-mu̱ gwu̱z-u̱ gi-yu̱ o̱ m-ja, ko̱ sha-mu̱ u-kagagag. U̱n zu̱, 
\q1 <<Na vam Wa-ko-uyan! 
\q2 Remu̱ Wa-ko-uyan in u-Ru̱ wu̱ zu̱ge̱ u̱r-be̱b 
\q2 wa he̱se̱te̱ u̱r-faru̱k. 
\q1  
\v 7 Yagu̱n in no̱mo̱n u̱r-so̱ u̱ me̱n-u̱t pus-to̱ ne̱, 
\q2 tu̱msu̱ yagu̱n in ya' wu̱n m-sek. 
\q1 Remu̱ da-u̱ teegu̱n u̱ mo̱ro̱g-du̱ u̱r-gu̱ du̱ Kag-u̱r U̱r-ca, 
\q2 tu̱msu̱ gwu̱p u̱r-gu̱ wu̱n zo̱ngte̱ hi-u̱r wa. 
\q1  
\v 8 Na yaag wa 
\q2 kus-u̱t pus-to̱ tu̱ so̱-to̱ tu̱msu̱ tu̱ m-baku̱t ne̱ u̱ wa wa'.>> 
\m Remu̱ kus-u̱t pus-to̱ tu̱ so̱-to̱ to̱ o̱ ees-mu̱ ank-m so̱-mo̱ mu̱ ne̱t-tu̱ u-Ru̱. 
\p  
\v 9 Se̱ wa-to̱m u-Ru̱ zu̱ me̱, <<Pan inya: <Nu-u so̱-o̱ u̱du̱ i na bane̱ u̱du̱ mo̱ro̱g-du̱ u̱r-gu̱ du̱ Kag-u̱r U̱r-ca!> >> Tu̱msu̱ wa sur m-zu̱, <<Sin-se̱ o̱ rem-su̱ u-Ru̱ su̱ u̱t-nip.>> 
\p  
\v 10 Da-u̱ u̱m ho̱ge̱ no̱m-u̱ wu̱n zu̱ye̱ se̱ u̱m he u-dak u̱t-jwu̱n u-shu̱ wu̱n u̱m no̱mu̱ wu̱n u̱t-huuk. Se̱di wa zu̱ me̱, <<A-bo̱ no̱m iya da! To̱k wa u̱m o̱o̱ge̱ u̱ bo̱ ne̱ tu̱msu̱ u̱ o̱r-u̱t rò ne̱ i o̱ jab-u̱ so̱-o̱ ne̱ u̱du̱ do̱nse̱-du̱ rem-su̱ mo̱t-u̱t Ye̱so̱. No̱me̱ u-Ru̱ u̱t-huuk! Remu̱ rem-su̱ mo̱t-u̱t Ye̱so̱ o̱ haatu̱n be̱b-du̱ warru̱ no̱m-u̱ do̱'e̱ u̱t-no̱m u-shu̱.>> 
\s1 Wa sak-mu̱ do̱m-u̱ jwaak-u pus-ya 
\p  
\v 11 Se̱ u̱m hyu̱n u̱-me̱ do̱m u-ru̱ u̱r-hu̱k tu̱msu̱ jwaak-u pus-ya o̱ ees u̱ku̱n, tu̱msu̱ wu̱ o̱ m-sak u̱ do̱m-u̱ jwaak-u ya dim-u̱r wa o̱ye̱ Wa ya-du̱ jab-u̱ u̱ Wa-u̱t-nip ne̱. Wa nom kwu̱p-du̱ u̱s-rem ho̱n-ho̱n tu̱msu̱ wa nom m-gag ho̱n-ho̱n.  
\v 12 Is-u̱ wa o̱ u̱ka rem-du̱ u-ra, tu̱msu̱ u̱ do̱m-u̱ hi-u̱r wa to̱p-tu̱ u̱r-faru̱k o̱ró u-tát. Dim-du̱ o̱ro m-pan u̱ do̱m-u̱ wa waku̱n ke̱rge̱ nap-du̱ de̱ da se̱ wa hi-u̱r wa.  
\v 13 Wa o̱ m-wa u̱t-cwu̱ ne̱ tu̱ na mase̱ u̱-me̱ m-hyu̱, tu̱msu̱ dim-u̱r wa na foge̱ Rem-su̱ u-Ru̱.  
\v 14 Ban-du̱ karma-ne̱ i o̱ me̱ do̱m u-ru̱ o̱ do̱rru̱ wu̱n, tu̱msu̱ e̱ o̱ m-sak u̱ jwaak-u puse̱ tu̱msu̱ m-wa u̱ kus-u̱t pus-to̱ ne̱ tu̱msu̱ u̱s-myak ne̱.  
\v 15 Du̱gu̱ me̱ nu-u wa van-u̱ m-wu̱r rwu̱u̱n yu̱ o̱ m-re̱ ne̱ remu̱ wa ho̱ru̱sse̱ hu̱u̱b-u̱t yo̱-to̱ tu̱ u-Ru̱ du̱gu̱ ko̱-u̱-he̱ dak-o̱. <<Wa do̱'e̱ no̱m-du̱ faru̱k-u̱r u̱n u̱ ko̱m-yu̱ u-kwam.>> Wa do̱'e̱ jangu̱sse̱ be-du̱ rew-mu̱ inabi, du̱ o̱o̱ge̱ ees-mu̱ ryab-su̱ u-Ru̱ wu̱ zu̱ge̱ u̱r-be̱b u-be̱e̱t.  
\v 16 Wa o̱tte̱ dim-u̱r wa m-pan u̱-do̱mu̱ to̱ggo̱-u wa tu̱msu̱ u̱-do̱mu̱ kut-u wa ne̱: 
\pc FARU̱K-U FARU̱KINA NE̱ TU̱MSU̱ WA-KO-UYAN WU̱ A KO-UYAN NE̱. 
\p  
\v 17 Se̱ u̱m hyu̱n wa-to̱m u-Ru̱ u̱ ees u̱-me̱ u̱r-ho̱, wa o̱ u̱t-jar m-yat u̱du̱ no i o̱o̱ge̱ u̱r-yu̱ne̱ u̱t-kap u̱-do̱m u-ru̱, <<Haanu̱n! Kargu̱n u̱r-be u̱r-gan remu̱ u̱zu̱ ho̱-du̱ mo̱ro̱g-du̱ re̱-du̱ no̱m-u̱ u̱t-re̱ du̱ yat-de̱ du̱ u-Ru̱ zo̱nge̱.  
\v 18 Haanu̱n no̱ tu̱ war-tu̱ u̱t-faru̱k, u̱ i-yate̱ karma-ne̱, u̱ be̱b-ne̱ i m-gag. Tu̱'u̱n ap-mu̱ jwaak u̱ a sakmu̱ jwaak ne̱, tu̱msu̱ u̱ ap-mu̱ u̱t-ne̱t ne̱ u̱t-be̱e̱t, u̱ same̱ to̱k-ne̱ tu̱msu̱ i zaare̱ m-to̱k ne̱ da, i-re̱k-e̱ u̱ i-yate̱ ne̱.>> 
\p  
\v 19 Se̱ u̱m hyu̱n bisa-u yo̱-o̱ ya u̱ faru̱k-tu̱ dak-u̱ u-be̱e̱t ne̱ tu̱msu̱ u̱ a-m-gag ne̱ e̱ karu̱gte̱ u̱r-be u̱r-gan remu̱ e̱ nom-u̱t m-gag u̱ wu̱ o̱ m-sak do̱m-u u-jwaak ne̱ u̱ a-m-gagu̱ wa ne̱.  
\v 20 Se̱di na maas bisa-u yo̱-o̱ ya, tu̱msu̱ u̱r-kot u̱ wa ne̱ u̱ wa-warru̱ rem-su̱ u-Ru̱ ne̱ i u̱s-bi i no̱me̱ no̱m-tu̱ m-shin u-tát u̱ ees-m wa. U̱ nap-u̱s se̱ wa e̱ngu̱sse̱ u̱t-ne̱t u-tát i kabe̱ nap-su̱ bisa-u yo̱-ya ya, tu̱msu̱ u̱n no̱me̱ ma-u̱ o̱o̱ge̱ sha-mu̱ bisa-u yo̱-ya ya u̱t-huuk. U̱n yu̱r na gun u̱n u̱r-fat ne̱ u̱-me̱ u̱r-kaw du̱ u-ra u̱ do̱'e̱ u̱t-wa u̱ kwam-tu̱ u̱'e̱.  
\v 21 Na ho̱ru̱sse̱ karma-ne̱ wa be̱e̱t u̱ van-u̱ m-wu̱r u̱ rwu̱u̱ne̱ du̱gu̱ me̱ nu-u̱ wu̱ o̱ye̱ m-sak u̱ jwaak-u pus-ya. Tu̱msu̱ sagra tu̱'u̱s ap-mu̱ u-u̱t u̱n se̱ da-u̱ e̱ shige̱. 
\c 20  
\s1 U̱s-hak u̱r-zo̱ngu u-gan (1,000) 
\p  
\v 1 Se̱ u̱m hyu̱n wa-to̱m u-Ru̱ wa o̱ cu̱zu̱n du̱gu̱ me̱ do̱m u-ru̱. Wa o̱ m-shu̱p u̱ mabudi ne̱ yu̱ kub-u̱ za u̱r-ma tu̱msu̱ wa o̱ m-shu̱p u̱ ho-su̱ kwam ne̱ su̱ m-no u̱ kom-u wa.  
\v 2 Wa maas fa-u yat-ya yu̱ yo̱-ya ya, wata, fa-u ya yu̱ du̱gu̱ da-u̱ dim, wu̱ na foge̱ faru̱k-u̱ no̱m u̱s-te, ko̱ Shetan. Tu̱msu̱ wa gu̱g wa m-te̱ u̱s-hak u̱r-zo̱ngu u-gan (1,000).  
\v 3 Wa guns wa u̱-me̱ u-kub u̱ za u̱r-ma, wa tage̱ tu̱msu̱ wa rake̱ o. Wa no̱ng iya remu̱ hooste̱ wa e̱ngu̱sse̱ ne̱t-tu̱ u̱t-dak m-te̱ da-u̱ hak-su̱ u̱r-zo̱ngu u-gan (1,000) shiye̱. Da taase̱, na do̱'e̱ yagu̱ wa u-da cashi. 
\p  
\v 4 Se̱ u̱m hyu̱n pora-tu̱ u̱r-faru̱k, tu̱msu̱ ne̱t-tu̱ o̱ shu̱'u̱t u̱ do̱m-u̱ to̱ na yu̱' e̱ be̱b-du̱ kwu̱p-du̱ u̱s-rem. Tu̱msu̱ u̱m hyu̱n ne̱t-tu̱ na ho̱ye̱ u̱ remu̱ warru̱ rem-su̱ mo̱t-u̱t Ye̱so̱ tu̱msu̱ u̱ remu̱ do̱nse̱-du̱ rem-su̱ u-Ru̱ ne̱. E̱ gu̱gu̱mte̱ no̱me̱-du̱ bisa-u yo̱-o̱ ya u̱t-huuk ko̱ ma-u̱ o̱o̱ge̱ sha-mu̱ bisa-u yo̱-ya ya, ko̱ e̱ o̱nk nap-u̱s wa u̱ po̱ng-u̱t e̱ ko̱ u̱ kom-u̱t e̱. E̱ be̱e̱t e̱ yu̱nge̱ tu̱msu̱ u̱r-fat, tu̱msu̱ e̱ nom u̱r-faru̱k u̱ Kiristi ne̱ m-te̱ u̱s-hak u̱r-zo̱ngu u-gan (1,000).  
\v 5 Dinde̱ o̱ yu̱ne̱-du̱ marimari ne̱ du̱ u̱r-taku̱n. Ne̱t-tu̱ mare̱ i kuse̱, e̱ yu̱nge̱ u̱r-fat da se̱ hak-su̱ u̱r-zo̱ngu u-gan (1,000) shu̱u̱g.  
\v 6 I kume̱ yu̱ne̱-du̱ u̱r-taku̱n e̱ kwu̱mu̱g nu-u so̱-o̱ u̱du̱ u-Ru̱, tu̱msu̱ na haste̱ e̱ kit re̱mu̱ ank-m wu̱n. Mar-mu̱ u-yu̱ru̱mse̱ zatte̱ u̱r-be̱b u̱ do̱m u̱n da, se̱di e̱ do̱'e̱ shu̱'u̱t a-to̱o̱g-ne̱ i u-Ru̱ tu̱msu̱ u̱ Kiristi ne̱. Tu̱msu̱ e̱ do̱'e̱ no̱m-du̱ u̱r-faru̱k u̱r-kot u̱ wa ne̱ u̱s-hak u̱r-zo̱ngu u-gan (1,000). 
\s1 Na re̱e̱g faru̱k-u̱ no̱m u̱s-te m-gag 
\p  
\v 7 Da-u̱ hak-su̱ u̱r-zo̱ngu u-gan (1,000) arke̱, na do̱'e̱ u̱ ustu̱ faru̱k-u̱ no̱m u̱s-te du̱gu̱ gu̱g-u wa.  
\v 8 Tu̱msu̱ wa do̱'e̱ u̱r-rwu̱ remu̱ wa e̱ngu̱sse̱ u̱t-dak du̱gu̱ ko̱yu̱he̱ gas-yu̱ u-dak u-be̱e̱t, wata Go̱g u̱ Mago̱g ne̱, tu̱msu̱ Shetan do̱'e̱ kargu̱sse̱ e̱ u̱r-be u̱r-gan remu̱ m-gag. Karma-ne̱ e̱ o̱ u-tát i na zaare̱ kerru̱ u̱t-ogor da, u̱ka m-hereg kit m-sa.  
\v 9 Tu̱msu̱ u̱m hyu̱n u̱n da-u̱ u̱n o̱o̱ge̱ m-no̱k m-pas m-cwa u-dak u-be̱e̱t, tu̱msu̱ u̱n gu̱nu̱s ne̱t-tu̱ u-Ru̱ tu̱msu̱ bo̱-u̱ Ru̱-u̱ tone̱ ne̱. Se̱di ra-u̱ he̱e̱n du̱gu̱ me̱ do̱m u-ru̱ tu̱msu̱ o̱ tokos u̱n be̱e̱t.  
\v 10 Se̱ faru̱k-u̱ no̱m u̱s-te, wu̱ e̱ngu̱sse̱ u̱t-dak na guns wa u̱-me̱ u̱r-ka-u du̱ u-ra u̱ do̱'e̱ u̱t-wa u̱ kwam-tu̱ u̱'e̱, be-du̱ na gunte̱ bisa-u yo̱-ya ya u̱ wa-warru̱ rem-su̱ u-Ru̱ ne̱ wu̱ u̱s-bi. U̱n do̱'e̱ swadu̱ u̱r-ko̱b u̱ku̱n u-ho̱ u̱ m-gyu̱p ne̱ m-mo̱mmo̱. 
\s1 Kwu̱p-du̱ u̱s-rem su̱ m-vaste̱ 
\p  
\v 11 Tu̱msu̱ u̱m hyu̱n pora-du̱ u̱r-faru̱k du̱ pus-de̱ u̱ yat-de̱, u̱ wu̱ o̱ shu̱'u̱t u̱-do̱mu̱ de̱ ne̱. U-dak u-be̱e̱t u̱ u̱-me̱ do̱m u-ru̱ ne̱ e̱ som du̱gu̱-du̱ shu̱ wa, se̱di e̱ kwu̱mu̱g be-du̱ u̱r-pak da.  
\v 12 Tu̱msu̱ u̱m hyu̱n i mare̱, i-yate̱ u̱ i-re̱k-e̱ ne̱ e̱ o̱ ees u̱-shu̱ pora-du̱ u̱r-faru̱k du̱ u-Ru̱. Na upus u̱t-ran, tu̱msu̱ na upus o̱ko̱n ran-o̱, u̱ na foge̱ ran-u̱ u̱r-fat. Na no̱mu̱ i mare̱ kwu̱p-du̱ u̱s-rem u̱ka o̱tte̱ m-pan u̱-me̱ u̱t-ran u̱ka ank-m u̱n.  
\v 13 Se̱ sa-mu̱ yu̱' ne̱t-tu̱ mare̱ u̱-me̱ wa tu̱msu̱ be-du̱ andaka ne̱ o̱ yu̱' tu̱ wa ne̱t-to̱, tu̱msu̱ mar-mu̱ yu̱' tu̱ wa ne̱t-to̱. Tu̱msu̱ Ru̱-u̱ no̱mu̱ u̱n be̱e̱t kwu̱p-du̱ u̱s-rem u̱ka no̱m-tu̱ u̱n no̱me̱.  
\v 14 Se̱ m-mar tu̱msu̱ be-du̱ andaka ne̱ o̱tte̱ ne̱ na gun u̱n u̱-me̱ u̱r-ka-u du̱ u-ra. Ka-w du̱ ra-u uno̱ o̱ o̱o̱ge̱ mar-mu̱ u-yu̱ru̱mse̱.  
\v 15 Ko̱wana na bite̱ dim-u̱r wa m-pan u̱-me̱ ran-u̱ u̱r-fat da, se̱ na guns wa u̱-me̱ u̱r-ka-u du̱ u-ra. 
\c 21  
\s1 Do̱m u-ru̱ po-o̱ u̱ dak-u po-o̱ ne̱ 
\p  
\v 1 Se̱ u̱m hyu̱n me̱ do̱m u-ru̱ u̱ po-o̱ u̱ dak-u po-o̱ ne̱. Remu̱ me̱ do̱m u-ru̱ u̱ u̱r-taku̱n u̱ dak-u̱ u̱r-taku̱n ne̱ o̱ aru̱kte̱, tu̱msu̱ mo̱ko̱n sa-mo̱ zamu̱n da.  
\v 2 Tu̱msu̱ u̱m hyu̱n bo̱-u u-he̱n u̱ u-Ru̱, Urusharima u̱ po-o̱, o̱ u̱ cu̱zu̱n du̱gu̱-du̱ u̱-me̱ do̱m u-ru̱ du̱gu̱-du̱ u-Ru̱. Bo̱-u o̱ o̱o̱g sha-mu̱ gwu̱p u̱r-gu̱ wu̱ no̱me̱ u̱t-u̱k u̱ kus-u̱t so̱-to̱ tu̱msu̱ zo̱ngi zo̱ngi u̱ remu̱ campa u̱r-gu̱ wa wu̱ wa do̱'e̱ u̱t-ga.  
\v 3 Tu̱msu̱ u̱m hog u-cwar m-yat du̱gu̱ pora-du̱ u̱r-faru̱k ya o̱ u̱t-zu̱, <<U̱ da-o̱ be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱ de̱ o̱ u̱r-kot u̱ u̱t-ne̱t ne̱, tu̱msu̱ wa do̱'e̱ u̱r-yu̱ u̱ u̱n ne̱. E̱ do̱'e̱ u̱ u̱t-shu̱'u̱t ne̱t-u̱t wa, tu̱msu̱ u-Ru̱ u̱ hi-u̱r wa, wa do̱'e̱ u̱t-shu̱'u̱t u̱r-kot u̱ u̱n ne̱ tu̱msu̱ wa do̱'e̱ u̱t-shu̱'u̱t Ru̱-u u̱n.  
\v 4 Wa do̱'e̱ ko̱ku̱ u̱n m-is m-be̱e̱t du̱gu̱ is-u̱ u̱n. Mar-mu̱ zamu̱n da ko̱ namu̱ jab ko̱ u̱s-kan ko̱ m-re̱, remu̱ u̱zu̱ ut-u̱t u̱t-no̱m tu̱ ho̱-to̱ to aru̱kte̱.>> 
\p  
\v 5 Se̱ wu̱ o̱ u̱ shu̱'u̱t u̱-do̱m pora-du̱ u̱r-faru̱k wa zu̱, <<Gwatu̱n, u̱m o̱ muutu̱ ko-uyan u̱ po-o̱!>> Se̱ wa zu̱ me̱, <<Pan no̱m-u̱t tun-to̱, remu̱ no̱m-u̱ u̱m waru̱ bo̱ o̱ u̱ ho̱n-ho̱n tu̱msu̱ nip-to̱.>> 
\p  
\v 6 Se̱ wa zu̱ me̱, <<Na taaste̱! Me̱ wa o̱o̱ge̱ Ar-fa u̱ Ome̱ga, wu̱ u̱r-taku̱n tu̱msu̱ m-vaste̱ ne̱. U̱du̱ i o̱ ho̱g-du̱ u-swaat be̱e̱t me̱ ya'u̱ e̱ bu̱-mu̱ u̱t-swa m-ho̱s du̱gu̱ pe̱r-mu̱ m-bu̱ mu̱ u̱r-fat.  
\v 7 I re̱ u̱r-ko̱rro̱ be̱e̱t e̱ do̱'e̱ o̱nk-u̱ dinde̱ o̱g-du̱ u̱r-mat de̱, tu̱msu̱ me̱ u̱t-shu̱'u̱t Ru̱-u u̱n tu̱msu̱ u̱n do̱'e̱ shu̱'u̱t ya'ag-u̱ ri.  
\v 8 Se̱di i o̱ u-gye̱r ne̱, a-ko̱b-du̱ yadu̱ jab ne̱, u̱ a no̱m-du̱ no̱m-tu̱ u̱s-gu̱r ne̱, u̱ a ho̱-du̱ u̱t-ne̱t ne̱, u̱ a m-o̱ ne̱, u̱ a-u-gwat-ne̱, u̱ a no̱me̱-du̱ ru̱-tu̱ za u̱r-fat u̱t-huuk ne̱ tu̱msu̱ u̱ a-u̱s-bi ne̱ be̱e̱t, o̱g-u̱r e̱ o̱ u̱-me̱ u̱r-ka-u du̱ u-ra u̱ do̱'e̱ u̱t-wa u̱ kwam-tu̱ u̱'e̱. Uno̱ o̱ mar-mu̱ u-yu̱ru̱mse̱.>> 
\p  
\v 9 Se̱ wagan u̱ te̱k-u̱ a-to̱m u-Ru̱ ne̱ ta'er wu̱ o̱ m-shu̱p u̱ u̱t-kwano ne̱ u̱t-ta'er tu̱ shiye̱ u̱ no̱m-tu̱ haatu̱n swadu̱ u̱r-ko̱b ne̱ u̱t-ta'er tu̱ m-vaste̱ wa haan tu̱msu̱ wa zu̱ me̱, <<Do̱rnu̱ me̱! Me̱ ko̱su̱ bo̱ gwu̱p u̱r-gu̱, ne̱ta Kag-u̱r U̱r-ca.>>  
\v 10 Se̱ Yar-u̱ u-Ru̱ dor-u̱t me̱, wa ku̱b me̱ m-da ro̱r-u̱r yat-de̱ tu̱msu̱ du̱ m-ja. U̱ku̱n wa ko̱su̱ me̱ bo̱-u̱ u-he̱n, wata Urusharima o̱ u̱ cu̱zu̱n du̱gu̱ me̱ do̱m u-ru̱ du̱gu̱-du̱ u-Ru̱.  
\v 11 Sek-mu̱ u-Ru̱ o̱ u̱r-mo̱k u̱-me̱ o̱. Tu̱msu̱ to̱ o̱ u̱r-myak ne̱ u̱ka ta'ar-tu̱ m-baku̱t tu̱ na foge̱ jaspa, tu̱msu̱ m-zu̱n ne̱ u̱ka u̱r-madibi.  
\v 12 O̱ o̱tte̱ sar u̱ yat-o̱ tu̱msu̱ m-ja ne̱ u̱ u̱s-is ne̱ o̱p u̱s-yu̱r, tu̱msu̱ u̱ a-to̱m u-Ru̱ ne̱ o̱p u̱ yu̱r, wagan u̱ ko̱yu̱he̱ is-ya. Tu̱msu̱ u̱-do̱mu̱ ko̱yu̱he̱ is-ya na panu̱g u̱r-dim u̱r-gan du̱ ko̱du̱he̱ ko̱-du̱ Isra-ne̱ o̱p u̱ u̱t-yu̱r (12).  
\v 13 Is-u̱s o̱ró u̱s-tu̱t u̱ gas-u u-do̱m, u̱s-tu̱t u̱ kom u̱r-beer, u̱s-tu̱t u̱ kom u̱t-cwa, tu̱msu̱ u̱s-tu̱t u̱ gas-u̱ u-ta.  
\v 14 Saru̱ bo̱-u o̱ na maag o̱ u̱-do̱mu̱ ta'ar-u̱t yat-to̱ o̱p u̱t-yu̱r (12). U̱-do̱mu̱ ta'ar-u̱t to̱ dim-du̱ o̱ró u̱r-gan m-pan du̱ ko̱wu̱he̱ a-to̱mu̱ Kag-u̱r U̱r-ca o̱p u̱ u̱t-yu̱r. 
\p  
\v 15 Wa-to̱m u-Ru̱ wu̱ o̱ u̱s-rem u̱ me̱ ne̱ wa o̱tte̱ ko̱m-yu̱ bu̱-mu̱ u̱t-ró yu̱ shik remu̱ mu̱'u̱s-du̱ bo̱-u o̱, is-u̱s wa u̱ saru̱ wa ne̱.  
\v 16 Da-u̱ wa mu̱'u̱se̱ bo̱-u o̱ u̱ u-ko̱m, se̱ wa bit o̱ teeg u̱s-tadiya 12,000 su̱ shu̱'u̱te̱ u̱ka u̱s-kirome̱ta 2,220. Wu̱r-m wa u̱ hu̱k-m wa tu̱msu̱ m-ja ne̱ ganse̱.  
\v 17 Se̱ wa mu̱'u̱s saru̱ bo̱-u o̱, tu̱msu̱ wa bit cam-u wa teeg u̱s-kubit 144, su̱ shu̱'u̱te̱ u̱s-na 200. Mu̱'u̱s-u̱t tun-to̱ to̱ o̱ u̱ka ne̱t-ne̱ mu̱'u̱ste̱, to̱ wa-to̱m u-Ru̱ no̱me̱.  
\v 18 Saru̱ bo̱-u o̱ na maag o̱ u̱t-ta'ar tu̱ so̱-to̱ tu̱ na foge̱ jaspa. Tu̱msu̱ ko̱-uyan u̱ o̱o̱ge̱ me̱ bo̱-u o̱ na no̱ng to̱ u̱ kwam-tu̱ bu̱-mu̱ u̱t-ró tu̱ shik, to̱ o̱ u̱s-mo̱k m-baku̱t ne̱ u̱ka u̱r-madibi.  
\v 19 Saru̱ bo̱-u o̱ na maag o̱ u̱ do̱m-u̱ u̱t-ta'ar tu̱ na no̱me̱ u̱t-u̱k u̱ ko̱-uyan go̱-du̱ ta'ar-tu̱ so̱-to̱ tu̱ shik. Ta'ar du̱ u̱r-taku̱n na no̱ngu̱ wa u̱t-u̱k u̱ ta'ar-u̱t so̱-to̱ na zu̱ to̱ jaspa, tu̱ u-yu̱ru̱mse̱ na zu̱ to̱ sappaya, tu̱ u-tu̱tu̱rse̱ na zu̱ to̱ agata, tu̱ u-nasu̱rse̱ na zu̱ to̱ zumurrudu,  
\v 20 tu̱ u-tanu̱rse̱ na zu̱ to̱ onis, tu̱ u-shishin na zu̱ to̱ yakutu, tu̱ u-ta'er na zu̱ to kirisorata, tu̱ u-eer na zu̱ to̱ berir, tu̱ u-jwu̱u̱r na zu̱ to̱ topaz, tu̱ u-o̱p na zu̱ to̱ kirisoparasa, tu̱ o̱p u̱ u-gan na zu̱ to̱ yakinta, tu̱ o̱p u̱ u-yu̱r na zu̱ to̱ ametis.  
\v 21 Is-su̱ bo̱-u o̱ o̱p u̱ u̱s-yu̱r (12) na no̱ng se̱ u̱ uz i shik tu̱ na foge̱ ru'uru'u. Ko̱yu̱he̱ is-ya na no̱ng ya u̱ ru'uru'u u-gan. Tu̱msu̱ fu̱n-u yat-ya yu̱ bo̱-u o̱ na no̱ng ya u̱ kwam-tu̱ bu̱-mu̱ u̱t-ró tu̱ shik to̱ na nomte̱ ya, m-zu̱n ne̱ u̱ka u̱r-madibi. 
\p  
\v 22 U̱m hyanu̱g be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱ u̱-me̱ bo̱-u o̱ da, remu̱ u̱zu̱ Wa-ko-uyan u-Ru̱ wu̱ zu̱ge̱ u̱r-be̱b u-be̱e̱t u̱ Kag-u̱r U̱r-ca ne̱ e̱ o̱o̱ge̱ be-du̱ u̱r-shu̱'u̱t du̱ u-Ru̱ du̱ bo̱-u o.  
\v 23 Bo̱-u o̱ zaaru̱ cwan-tu̱ zu̱n-mu̱ u̱r-ho̱ ko̱ u-pyaat mo̱ mo̱k o̱ da, remu̱ sek-mu̱ u-Ru̱ mo̱ yu̱'e̱ m-zu̱n, tu̱msu̱ ya-du̱ Kag-u̱r U̱r-ca wa o̱o̱ge̱ u-hitirra yu̱ bo̱-u o̱.  
\v 24 Dak-tu̱ do̱'e̱ u̱r-no̱k u̱ zu̱n-mu̱ bo̱-u o̱, tu̱msu̱ faru̱k-tu̱ u-dak u-be̱e̱t do̱'e̱ haatu̱n sek-m e̱ u̱-me̱ o̱.  
\v 25 Na za tage̱ is-su̱ bo̱-u o̱ u-ho̱ da, tu̱msu̱ gye̱p-mu̱ zaar u̱ku̱n da.  
\v 26 Ne̱t-tu̱ do̱'e̱ haatu̱n m-sek tu̱msu̱ m-ze̱g ne̱ mu̱ u̱t-dak u̱-me̱ o̱.  
\v 27 O̱ko̱n zaar u̱ za u-he̱n u̱ do̱'e̱ cwa-du̱ bo̱-u o da, ko̱ waku̱n wu̱ no̱me̱ no̱mtu̱ m-e̱' u̱ wa-u̱s-bi ne̱. Se̱di i dim-u̱t e̱ o̱o̱ge̱ m-pan u̱ war-e̱ u̱-me̱ ran-u̱ u̱r-fat u̱ Kag-u̱r U̱r-ca e̱ do̱'e̱ cwadu̱ bo̱-u o̱. 
\c 22  
\s1 U-gi yu̱ bu̱-mu̱ u̱r-fat 
\p  
\v 1 Se̱ wa-to̱m u-Ru̱ ko̱se̱ me̱ gi-yu̱ m-bu̱ mu̱ u̱r-fat. Ya o̱ u̱s-baku̱t u̱ka u̱r-madibi, tu̱msu̱ ya rwu̱u̱gu̱n du̱gu̱ pora-du̱ u̱r-faru̱k du̱ u-Ru̱ tu̱msu̱ u̱du̱ Kag-u̱r U̱r-ca ne̱.  
\v 2 Ya jaan m-do̱r te̱k-u̱ fu̱n-u̱ yat-ya yu̱ bo̱-u o̱. U̱ ko̱yu̱he̱ gas-yu̱ gi-u ya te-yu̱ u̱r-fat o̱ ees, su̱ mu̱te̱ u̱t-ya u̱t-go̱ o̱p u̱ u̱t-yu̱r, ko̱yu̱he̱ pyaat-ya ya mu̱t u̱t-ya. Tu̱msu̱ ran-tu̱ te-u ya hen u̱ remu̱ yar-mu̱ u̱t-dak to̱.  
\v 3 Nu-u yo̱-o̱ zamu̱n u̱ku̱n da. Pora-du̱ u̱r-faru̱k du̱ u-Ru̱ u̱ du̱ Kag-u̱r U̱r-ca ne̱ do̱'e̱ u̱t-shu̱'u̱t u̱-me̱ bo̱-u o̱, tu̱msu̱ to̱k-ne̱ wa do̱'e̱ no̱mu̱ wa m-to̱k.  
\v 4 E̱ do̱'e̱ hyan-du̱ shu̱-u wa. Tu̱msu̱ dim-u̱r wa do̱'e̱ u̱t-shu̱'u̱t u̱ po̱ng-u̱t u̱n, u̱t-ko̱se̱ u̱zu̱ u̱n ne̱t-u̱t wa to̱.  
\v 5 Na zamu̱n u̱ no̱m-du̱ m-gye̱p u̱ku̱n da. U̱n zamu̱n u̱ cwan-tu̱ zu̱n-mu̱ u̱s-hitirra ko̱ zu̱n-mu̱ u̱r-ho̱ da, remu̱ Wa-ko-uyan u-Ru̱ wa do̱'e̱ u̱t-shu̱'u̱t zu̱n-m u̱n. Tu̱msu̱ u̱n do̱'e̱ no̱m-du̱ u̱r-faru̱k m-mo̱mmo̱.  
\v 6 Se̱ wa-to̱m u-Ru̱ zu̱ me̱, <<Ko-uyan u̱ bo̱ ho̱ge̱ tu̱msu̱ bo̱ hyu̱n o̱ u̱ ho̱n-ho̱n o̱ tu̱msu̱ u̱ u̱t-nip. Wa-ko-uyan u-Ru̱, wu̱ Yar-u wa dorte̱ a-warru̱ remsu̱ u-Ru̱ ne̱, wa to̱mgo̱n wa-to̱m u-Ru̱ wa, wa ware̱ to̱k-ne̱ wa no̱m-u̱ do̱'e̱ u̱t-no̱m za m-tumb.>> 
\s1 Ye̱so̱ o̱ mu̱u̱n 
\p  
\v 7 <<Gwat, u̱m do̱'e̱ mu̱u̱n za m-tumb! Nu-u so̱-o̱ u̱du̱ i do̱re̱ rem-su̱ no̱m-u̱ do̱'e̱ u̱t-no̱m u-shu̱ su̱ o̱ m-pan u̱-me̱ ran-u uno̱.>> 
\p  
\v 8 Me̱, Yohanna, me̱ wa ho̱ge̱ tu̱msu̱ u̱m hyu̱n no̱m-u̱t tun-to̱ u̱t-be̱e̱t. Tu̱msu̱ da-u̱ u̱m ho̱ge̱ tu̱msu̱ u̱m hyu̱n to̱, u̱m he̱ u-dak u̱ do̱m-u̱ jwu̱n-u̱t ri remu̱ u̱m no̱m-tu̱ wa-to̱m u-Ru̱ u̱t-huuk wu̱ ko̱se̱ me̱ to̱.  
\v 9 Se̱di wa zu̱ me̱, <<O'o! A-bo̱ no̱m-u̱ me̱ u̱t-huuk da. Me̱ to̱k-u u-Ru̱ wa u̱m o̱o̱ge̱, u̱ka u-ró tu̱msu̱ u̱ o̱r-u̱t rò ne̱ a-warru̱ rem-su̱ u-Ru̱ ne̱, tu̱msu̱ u̱ same̱ i do̱re̱ no̱m-u̱ o̱ m-pan u̱-me̱ ran-u uno̱. No̱me̱ u-Ru̱ u̱t-huuk kyak.>> 
\p  
\v 10 Se̱ wu̱n no̱mu̱ me̱ u̱t-him, <<A-bo̱ yase̱ rem-su̱ no̱m-u̱ do̱'e̱ u̱t-no̱m u-shu̱ u̱-me̱ ran-u uno̱ da, remu̱ zu̱ da-u̱ o̱ u̱t-mo̱r.  
\v 11 Yage̱ wu̱ o̱ no̱m-du̱ no̱m-u̱t yo̱-to̱ wa re̱ u-shu̱ u̱ no̱m-du̱ no̱m-u̱t yo̱-to̱ ne̱, tu̱msu̱ wu̱ o̱ no̱m-du̱ no̱m-tu̱ u̱s-gu̱r yage̱ wa re̱ u-shu̱ u̱ no̱m-du̱ no̱m-tu̱ u̱s-gu̱r ne̱. Wu̱ o̱ no̱m-du̱ no̱m-tu̱ jab-u̱ so̱-o̱ yage̱ wa re̱ u-shu̱ u̱ no̱m-du̱ no̱m-tu̱ jab-u̱ so̱-o̱ ne̱, tu̱msu̱ wu̱ o̱ no̱m-du̱ no̱m-tu̱ u-he̱n yage̱ wa re̱ u-shu̱ u̱ no̱m-du̱ no̱m-tu̱ u-he̱n ne̱.>> 
\p  
\v 12 Gwat, u̱m o̱ haan za m-tumb! U̱m o̱ haatu̱n to̱p-u ri u̱r-kot u̱ me̱ ne̱, remu̱ u̱m to̱p-u̱ ko̱wan u̱ka no̱m-tu̱ wa no̱me̱.  
\v 13 Me̱ wa o̱ye̱ Ar-fa u̱ Ome̱ga ne̱, wa u̱r-taku̱n u̱ m-vaste̱ ne̱, taku̱n-du̱ u-no̱m u̱ vaste̱ mu̱ u-no̱m ne̱. 
\p  
\v 14 Nu-u so̱-o̱ u̱du̱ i jaase̱ to̱ggo̱-su̱ m-wu̱r e̱. Na do̱'e̱ ya-du̱ e̱ u̱r-ke̱r e̱ cwa u̱-me̱ is-u̱ bo̱-u o̱ tu̱msu̱ e̱ re ya-tu̱ u-te du̱gu̱ te-yu̱ u̱r-fat.  
\v 15 I o̱ do̱-u̱ u-bo̱ u̱na o̱ye̱ o̱, i nome̱ u-gwat ne̱, a-u-as ne̱, u̱ a ho̱-du̱ u̱t-ne̱t, u̱ a no̱me̱ ru̱-tu̱ za u̱r-fat u̱t-huuk tu̱msu̱ u̱ kowan wu̱ o̱ cwan-tu̱ u̱s-bi ne̱ tu̱msu̱ wa nom u̱s-bi ne̱. 
\p  
\v 16 Me̱ Ye̱so̱, u̱m to̱mgo̱n wa-to̱m u-Ru̱ ri wa waru̱ bo̱ sin-se̱ remse̱ remu̱ mo̱ro̱g-tu̱ a-doru̱ Ye̱so̱ ne̱. Me̱ wa o̱ u̱r-kug tu̱msu̱ du̱gu̱ ko̱-u̱r Dawuda ne̱, tu̱msu̱ me̱ o̱ye̱ re̱ge̱r yu̱' m-zu̱n yu̱ u̱r-gas is. 
\p  
\v 17 Yar-u̱ u-Ru̱ u̱ gwu̱p u̱r-gu̱ ne̱ u̱n zu̱, <<Haane̱!>> Tu̱msu̱ yage̱ wu̱ o̱ ho̱g-du̱ rem-u̱s sin-se̱ wa zu̱, <<Haane!>> Ko̱wana wu̱ o̱ ho̱g-du̱ u-swaat, yage̱ wa haan. Tu̱msu̱ ko̱wana u̱t-sa, yage̱ wa haan tu̱msu̱ wa kab nya-u̱ m-ho̱s u̱ m-bu̱ mu̱ u̱r-fat.  
\v 18 U̱m o̱ no̱mu̱ ko̱wan u̱t-him wu̱ o̱ ho̱g-du̱ rem-su̱ no̱m-u̱ do̱'e̱ u̱t-no̱m u-shu̱ su̱ o̱ me̱ ran-u uno̱: A waku̱n sure̱ de̱ku̱n gom-de̱ u̱ se̱, tu̱msu̱ Ru̱-u̱ do̱'e̱ swu̱ru̱ wa no̱m-tu̱ haatu̱n swadu̱ u̱r-ko̱b ne̱ tu̱ na pane̱ u̱-me̱ ran-u uno̱.  
\v 19 Tu̱msu̱ a waku̱n haste̱ o̱ko̱n no̱m-o̱ du̱gu̱ me̱ ran-u uno̱ u̱ no̱m-u̱ do̱'e̱ u̱t-no̱m u-shu̱, Ru̱-u̱ do̱'e̱ hastu̱ o̱g-u̱r rò du̱gu̱ me̱ te-yu̱ u̱r-fat tu̱msu̱ du̱gu̱ me̱ bo̱-u̱ u-he̱n, su̱ na ware̱ u̱-me̱ uno̱ ran-o̱. 
\p  
\v 20 Ye̱so̱, wu̱ ware̱ rem-u̱s sin-se̱ wa zu̱, <<U̱, U̱m o̱ haan za m-tumb!>> 
\p U̱ shu̱'u̱t iya! Haane̱, Wa-ko̱-uyan Ye̱so̱! 
\p  
\v 21 Yage̱ nya-u Wa-ko-uyan Ye̱so̱ u̱ shu̱'u̱t u̱r-kot u̱ ne̱t-tu̱ u-Ru̱ ne̱! U̱ shu̱'u̱t iya.