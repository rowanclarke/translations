\p
\v 23 De entre los amramitas, de los izharitas, de los hebronitas y de los uzielitas:   
\p
\v 24 \w Sebuel|strong="H7619"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Gersón, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w*, \w era|strong="H1121"\w* jefe \w de|strong="H5921"\w* \w los|strong="H1121"\w* tesoros.  
\v 25 En cuanto \w a|strong="H3068"\w* su hermano Eliezer, \w cuyo|strong="H3141"\w* \w hijo|strong="H1121"\w* \w era|strong="H1121"\w* Rehabías, del cual fue \w hijo|strong="H1121"\w* \w Jesaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* éste \w Joram|strong="H3141"\w*, \w cuyo|strong="H3141"\w* \w hijo|strong="H1121"\w* \w era|strong="H1121"\w* Zicri, del cual fue \w hijo|strong="H1121"\w* Selomit.  
\v 26 \w Este|strong="H1931"\w* Selomit \w y|strong="H5921"\w* \w sus|strong="H1931"\w* hermanos \w estaban|strong="H7218"\w* \w a|strong="H3068"\w* cargo \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* tesoros \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* cosas \w sagradas|strong="H6944"\w* \w que|strong="H1931"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w*, \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* casas paternas, \w junto|strong="H5921"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* millares \w y|strong="H5921"\w* \w de|strong="H5921"\w* centenas \w y|strong="H5921"\w* \w jefes|strong="H8269"\w* \w del|strong="H5921"\w* \w ejército|strong="H6635"\w*,  
\v 27 consagraron \w de|strong="H4480"\w* las \w guerras|strong="H4421"\w* y \w del|strong="H4480"\w* botín \w para|strong="H4480"\w* el mantenimiento \w de|strong="H4480"\w* la \w Casa|strong="H1004"\w* \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 28 Estaba \w a|strong="H3068"\w* \w cargo|strong="H3027"\w* \w de|strong="H5921"\w* Selomit \w y|strong="H5921"\w* sus hermanos \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* consagró \w el|strong="H5921"\w* \w vidente|strong="H7200"\w* \w Samuel|strong="H8050"\w*, \w Saúl|strong="H7586"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Cis|strong="H7027"\w*, Abner, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Ner|strong="H5369"\w*, \w y|strong="H5921"\w* \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Sarvia. \add También estaba a su cargo\add* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w cualquiera|strong="H3605"\w* consagraba.   
\p
