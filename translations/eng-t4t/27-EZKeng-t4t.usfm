\p
\v 1 \w Then|strong="H3318"\w*, \add in the vision\add*, \w the|strong="H6440"\w* \w man|strong="H6440"\w* \w brought|strong="H3318"\w* \w me|strong="H6440"\w* \w back|strong="H7725"\w* \w to|strong="H7725"\w* \w the|strong="H6440"\w* \w entrance|strong="H6607"\w* \w of|strong="H1004"\w* \w the|strong="H6440"\w* \w temple|strong="H1004"\w*. \w There|strong="H2009"\w* \w I|strong="H3588"\w* \w saw|strong="H2009"\w* \w water|strong="H4325"\w* \w flowing|strong="H3381"\w* \w out|strong="H3318"\w* \w from|strong="H7725"\w* \w under|strong="H8478"\w* \w the|strong="H6440"\w* \w entrance|strong="H6607"\w*, \w flowing|strong="H3381"\w* \w toward|strong="H6440"\w* \w the|strong="H6440"\w* \w east|strong="H6921"\w*. \w The|strong="H6440"\w* \w water|strong="H4325"\w* \w was|strong="H1004"\w* \w flowing|strong="H3381"\w* \w from|strong="H7725"\w* \w under|strong="H8478"\w* \w the|strong="H6440"\w* \w south|strong="H5045"\w* \w side|strong="H3802"\w* \w of|strong="H1004"\w* \w the|strong="H6440"\w* \w entrance|strong="H6607"\w*, \w south|strong="H5045"\w* \w of|strong="H1004"\w* \w the|strong="H6440"\w* \w altar|strong="H4196"\w*.  
