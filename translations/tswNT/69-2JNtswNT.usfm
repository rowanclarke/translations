\id 2JN NT0024 Tsishingini (tsw) (Salka Kambari) KLP Feb. 2011
\h 2 Yahaya
\toc1 Mepepelime me Ire ma Yahaya
\toc2 2 Yahaya
\toc3 2 Yah.
\mt2 Mepepelime me Ire ma
\mt1 Yahaya
\is1 Ucuɗuwu wa aatagada a nda
\ip A̱yi nda a̱yi ɗa mepepelime me ire ma na Yahaya ɗanai. E mepepelime ma nda, u damma ta̱ u ɗana yi a̱ tyo a “ka na A̱sula̱ a ɗangwai oɓolo na̱ muwun ma̱ yi.” Ucasu wa̱ a̱tsuma̱lima̱ a̱ a̱za̱ e Itoni a̱ da̱na̱ ta̱ lo a mantsaꞌa, Yahaya yuwan ta̱ ulinga ni idanshi i nda o una̱ wa̱ a̱a̱ꞌisa̱ na ama a na a̱ ri pe.
\ip Yahaya damma ta̱ icigi ili ya̱ a̱ɓula̱ i ɗa e ekere a̱ A̱sula̱, ne ɗa fo icigi i ri na̱ a̱ɓula̱ e ekere a̱ a̱za̱ e Itoni. A mantsa mo ndolo, ama o ro a dansa ta̱ a na Zamawawa vuma ɗa na amayun shi, amma ruhu ɗa na ama ee ene ne esu e le. Reve Yahaya damma a̱yi ndolo epen a ɗa, amma amayun a̱yi ɗa Yesu Zamawawa vuma ɗa na amayun. Reve u damma a̱za̱ e Itoni a ꞌyuwan munlu me epen.
\ip Anaꞌan fo, munlu me epen n ta̱ lo aza a na a yuwusan uritosu wa amayun shi. A̱za̱ e Itoni a ꞌyuwan munlu me epen n ndolo. Ili ya̱ a̱ɓula̱ i ɗa a̱za̱ e Itoni a ciga amayun, waru a cigalai.
\is1 Ili i na i ri pe a̱tsuma̱ a aatagada a nda
\io1 1. Amayun ni Icigi (4-11)
\io1 2. Ica̱su yu Ukosu (12-13)
\c 1
\s1 Ica̱su
\p 
\v 1 A̱mu, Yahaya zagbain,\f + \fr 1:1 \ft Danshi Tsuheleni pa nda ta yuwusan adanshi adama a aabara tsu zagbain.\f* a̱mu ɗa n ɗanai mepepelime ma nda a̱ tyo a ka na A̱sula̱ a ɗangwai oɓolo na̱ muwun ma̱ yi.\f + \fr 1:1 \ft A̱yi ka oɓolo na̱ muwun ma̱ yi u ta yuwusan adanshi a̱ a̱a̱ꞌisa̱ a̱ a̱za̱ e Itoni na aza a na a uwusa pe. \f* N ciga ɗu ta̱ na amayun. A̱mu ɗa n ciga nɗu goon shi. Ama a na e revei amayun suru a ciga ɗu ta̱ fo.
\v 2 Tsu ciga ɗu ta̱ adama a amayun a na a̱ ri pe a̱tsuma̱ a̱ tsu waru u ta̱ da̱na̱ pe babu ukotu.
\p 
\v 3 N ta yuwusan avasa tsa̱ra̱ A̱sula̱ Dada na̱ Yesu Kristi Zamawawa za na a̱yi ɗa Mawun ma̱ yi u yuwaan tsu isaꞌani waru we ene iliyali i tsu! Lyawa a ca tsu asuvu nden, na amayun ni icigi.
\s1 Amayun ni icigi
\p 
\v 4 N yuwan ta̱ ma̱za̱nga̱ ma̱ a̱bunda̱ ana mu uwwai muwun n ɗu n ro oo tono ure wa amayun, cine Dada damma ntsu tsu yuwan.
\v 5 Na̱wa̱yi va̱, n ɗanaa wu tsa̱ra̱ vu yuwan ili i saꞌavu i ro shi. N ɗanaa wu ta̱ tsa̱ra̱ n damma ɗu i cigalai, a̱yi ɗa ili yu ufaru i na a damma ntsu tsu yuwan.
\v 6 A̱yi nda a̱yi ɗa icigi: na̱ tsu yuwain ili i na A̱sula̱ a damma ntsu tsu yuwan. Waru u damma ta̱ diga o ufaru i cigalai.
\p 
\v 7 Munlu me epen na̱ a̱bunda̱ a̱ ta̱ ka̱nda̱ruwusa̱ a̱tsuma̱ o uvaɗi. A̱za̱ a̱ wulumu a nda a ta dansa a na Yesu Zamawawa ri na̱ lipu cuꞌun vu vaɗilima̱ shi. Agba a̱za̱ e epen a ɗa waru nꞌyuwatan mu Zamawawa n ɗa.
\v 8 I yuwan ugbozu. Ni i yuwan ugbozu shi, i ta gura lamba ili i na i lingai adama a̱ yi suru. Amma ni i yuwan ugbozu, i ta̱ tsura̱ iliyinkapa i ɗu tapu.
\v 9 Vuma na isawain a̱tsuma̱ o uritosu wa̱ Yesu Zamawawa shi, a̱vu u feletyo, u ri oɓolo na̱ A̱sula̱ shi. Vuma na isawain a̱tsuma̱ o uritosuꞌu u to oɓolo na̱ Dada na̱ Mawun.
\v 10 Na̱ vuma ta̱wa̱ a̱tsuma̱ e iɓolo i ɗu, agba u yuwan uritosu wa amayun a aci a Zamawawa shi, she i banu yi a ꞌwa ɗu ko i ca̱sa̱ yi ko keꞌen wan.
\v 11 Ni i raba cuꞌun vuma ndolo, i yuwan ta̱ fo cuꞌun vu ulinga vi iwuya ya̱ yi.
\s1 Idanshi yu ukosu
\p 
\v 12 N ta̱ ni ili ya̱ a̱bunda̱ a na n cigai n damma ɗu, agba n ciga n ɗana le a̱ a̱a̱vuꞌun shi. Amma n ta a majiyan n ta̱wa̱ n yuwan adanshi na̱ a̱ɗu esu esu, tsa̱ra̱ tsu da̱na̱ tapu na̱ ma̱za̱nga̱.
\p 
\v 13 Muwun mu za va̱ wu vu ka za na A̱sula̱ a ɗangwai a̱ ta̱ lyungusa̱a̱ wu ni ica̱su i le.\f + \fr 1:13 \ft Ka na a yuwusan adanshi a aci a̱ yi pa nda a̱a̱ꞌisa̱ a na Yahaya da̱na̱i ana u ɗanai mepepelime ma nda ma ɗa, muwun ele ɗa aza a na a uwusa a̱tsuma̱ a̱ a̱a̱ꞌisa̱ a̱ a̱za̱ e Itoni.\f*
