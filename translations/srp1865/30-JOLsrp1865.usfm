\id JOL  
\h Knjiga proroka Joila 
\toc1 Knjiga proroka Joila 
\toc2 Joil 
\toc3 Jl 
\mt1 Knjiga proroka Joila  
\c 1  
\s1 Napast od skakavaca i znaci dana Gospodnjeg, jadikovanje i molba.  
\p
\v 1 Reč Gospodnja koja dođe Joilu sinu Fatuilovom.   
\b  
\q1
\v 2 Čujte, starci;  
\q2 slušajte, svi stanovnici zemaljski;  
\q1 je li ovako šta bilo za vašeg vremena  
\q2 ili za vremena vaših otaca?   
\q1
\v 3 Pripovedajte to sinovima svojim,  
\q2 i sinovi vaši svojim sinovima,  
\q2 i njihovi sinovi potonjem kolenu.   
\b  
\q1
\v 4 Šta osta iza gusenice izjede skakavac,  
\q2 i šta osta iza skakavca izjede hrušt,  
\q2 i šta osta iza hrušta izjede crv.   
\b  
\q1
\v 5 Otreznite se, pijanice, i plačite;  
\q2 i ridajte svi koji pijete vino, za novim vinom,  
\q2 jer se ote iz usta vaših.   
\q1
\v 6 Jer dođe na zemlju moju silan narod i nebrojen;  
\q2 zubi su mu kao u lava  
\q2 i kutnjaci kao u lavice.   
\q1
\v 7 Potre vinovu lozu moju,  
\q2 i smokve moje pokida,  
\q1 sasvim ih oguli i pobaca,  
\q2 te im se grane bele.   
\b  
\q1
\v 8 Ridaj kao mladica opasana kostreću  
\q2 za mužem mladosti svoje.   
\q1
\v 9 Nesta dara i naliva iz doma Gospodnjeg;  
\q2 tuže sveštenici, sluge Gospodnje.   
\q1
\v 10 Opuste polje, tuži zemlja;  
\q2 jer je potrveno žito, usahlo vino, nestalo ulja.   
\b  
\q1
\v 11 Stidite se ratari, ridajte vinogradari,  
\q2 pšenice radi i ječma radi,  
\q2 jer propade žetva na njivi;   
\q1
\v 12 Loza posahnu i smokva uvenu;  
\q2 šipak i palma i jabuka i sva drveta poljska posahnuše,  
\q2 jer nesta radosti između sinova ljudskih.   
\b  
\q1
\v 13 Opašite se i plačite sveštenici;  
\q2 ridajte koji služite oltaru,  
\q1 dođite, noćujte u kostreti, sluge Boga mog;  
\q2 jer se unosi u dom Boga vašeg dar i naliv.   
\b  
\q1
\v 14 Naredite post, oglasite praznik,  
\q2 skupite starešine, sve stanovnike zemaljske, u dom Gospoda Boga svog,  
\q2 i vapite ka Gospodu:   
\b  
\q1
\v 15 Jaoh dana!  
\q2 Jer je blizu dan Gospodnji,  
\q2 i doći će kao pogibao od Svemogućeg.   
\q1
\v 16 Nije li nestalo hrane ispred očiju naših,  
\q2 radosti i veselja iz doma Boga našeg?   
\b  
\q1
\v 17 Seme istruhnu pod grudama svojim,  
\q2 puste su žitnice, razvaljene spreme,  
\q2 jer posahnu žito.   
\q1
\v 18 Kako uzdiše stoka! Kako su se smela goveda!  
\q2 Jer nemaju paše;  
\q2 i ovce ginu.   
\b  
\q1
\v 19 K Tebi, Gospode, vičem,  
\q2 jer oganj sažeže paše u pustinji,  
\q2 i plamen popali sva drveta u polju.   
\q1
\v 20 I zverje poljsko pogleda za tobom,  
\q2 jer usahnuše potoci vodeni  
\q2 i oganj sažeže paše u pustinji.   
\c 2  
\s1 Nastavak opisivanja napasti od skakavaca. Pozivanje na pokajanje. Obricanje novog blagoslova. Sveti duh.  
\q1
\v 1 Trubite u trubu na Sionu,  
\q2 i vičite na svetoj gori mojoj,  
\q1 neka drhću svi stanovnici zemaljski,  
\q2 jer ide dan Gospodnji,  
\q2 jer je blizu.   
\q1
\v 2 Dan, kad je mrak i tama,  
\q2 dan, kada je oblak i magla;  
\q1 kako se zora razastire povrh gora,  
\q2 tako ide narod velik i silan,  
\q1 kakvog nije bilo otkad je veka  
\q2 niti će ga posle kad biti  
\q2 od kolena do kolena.   
\b  
\q1
\v 3 Pred njim proždire oganj,  
\q2 a za njim pali plamen;  
\q1 zemlja je pred njim kao vrt edemski,  
\q2 a za njim pustinja pusta,  
\q2 ništa neće uteći od njega.   
\b  
\q1
\v 4 Na očima su kao konji  
\q2 i trčaće kao konjici.   
\q1
\v 5 Skakaće povrh gora topoćući kao kola,  
\q2 praskajući kao plamen ognjeni koji sažiže strnjiku,  
\q2 kao silan narod spreman za boj.   
\b  
\q1
\v 6 Pred njim će se prepadati narodi,  
\q2 svako će lice pocrneti.   
\q1
\v 7 Oni će trčati kao junaci,  
\q2 kao vojnici skakaće na zid,  
\q1 i svaki će ići svojim putem,  
\q2 niti će odstupati sa svoje staze.   
\q1
\v 8 I jedan drugog neće tiskati,  
\q2 svaki će ići svojim putem,  
\q2 i na mačeve navirući neće se raniti.   
\q1
\v 9 Po gradu će hoditi,  
\q2 po zidovima će trčati,  
\q1 u kuće će se peti,  
\q2 ulaziće kroz prozore kao lupež.   
\b  
\q1
\v 10 Pred njima će se zemlja tresti,  
\q2 nebesa će se pokolebati,  
\q1 sunce će i mesec pomrknuti  
\q2 i zvezde će ustegnuti svetlost svoju.   
\q1
\v 11 A Gospod će pustiti glas svoj pred vojskom svojom,  
\q2 jer će logor Njegov biti vrlo velik,  
\q2 jer će biti silan onaj koji će izvršiti volju Njegovu;  
\q1 jer će dan Gospodnji biti velik i vrlo strašan,  
\q2 i ko će ga podneti?   
\b  
\q1
\v 12 Zato još govori Gospod:  
\q2 Obratite se k meni svim srcem svojim  
\q2 i posteći i plačući i tužeći.   
\q1
\v 13 I razderite srca svoja,  
\q2 a ne haljine svoje,  
\q1 i obratite se ka Gospodu Bogu svom,  
\q2 jer je milostiv i žalostiv,  
\q2 spor na gnev i obilan milosrđem i kaje se oda zla.   
\q1
\v 14 Ko zna, neće li se povratiti i raskajati se,  
\q2 i ostaviti iza toga blagoslov,  
\q2 dar i naliv za Gospoda Boga vašeg.   
\b  
\q1
\v 15 Trubite u trubu na Sionu,  
\q2 naredite post,  
\q2 proglasite svetkovinu.   
\q1
\v 16 Saberite narod,  
\q2 osveštajte sabor,  
\q1 skupite starce,  
\q2 saberite decu i koja sisaju;  
\q1 ženik neka iziđe iz svoje kleti  
\q2 i nevesta iz ložnice svoje.   
\b  
\q1
\v 17 Između trema i oltara neka plaču sveštenici,  
\q2 sluge Gospodnje,  
\q2 i neka kažu:  
\q1 Prosti, Gospode, narodu svom,  
\q2 i ne daj nasledstvo svoje pod sramotu,  
\q2 da njim ovladaju narodi;  
\q1 zašto da kažu u narodima:  
\q2 Gde im je Bog?   
\b  
\q1
\v 18 I Gospod će revnovati za zemlju svoju  
\q2 i požaliće narod svoj.   
\q1
\v 19 I Gospod će odgovoriti  
\q2 i reći će svom narodu:  
\q1 Evo, ja ću vam poslati žita i vina i ulja,  
\q2 i bićete ga siti,  
\q2 i neću vas više dati pod sramotu među narodima.   
\b  
\q1
\v 20 Jer ću udaljiti od vas severca,  
\q2 i odagnati ga u zemlju suvu i pustu,  
\q1 prednju četu njegovu u istočno more,  
\q2 a zadnju u more zapadno,  
\q1 i podignuće se smrad njegov  
\q2 i trulež će se njegov podignuti,  
\q2 pošto učini velike stvari.   
\b  
\q1
\v 21 Ne boj se, zemljo,  
\q2 raduj se i veseli se,  
\q2 jer će Gospod učiniti velike stvari.   
\q1
\v 22 Ne bojte se, zveri poljske;  
\q2 jer će se zeleneti pasišta u pustinji  
\q1 i drveta će nositi rod svoj,  
\q2 smokva će i loza vinova davati silu svoju.   
\b  
\q1
\v 23 I vi, sinovi sionski,  
\q2 radujte se i veselite se u Gospodu Bogu svom,  
\q1 jer će vam dati dažd na vreme,  
\q2 i spustiće vam dažd rani i pozni na vreme.   
\b  
\q1
\v 24 I gumna će se napuniti žita,  
\q2 a kace će se prelivati vinom i uljem.   
\q1
\v 25 I naknadiću vam godine  
\q2 koje izjede skakavac, hrušt i crv i gusenica,  
\q1 velika vojska moja,  
\q2 koju slah na vas.   
\b  
\q1
\v 26 I ješćete izobila,  
\q2 i bićete siti  
\q1 i hvalićete ime Gospoda Boga svog,  
\q2 koji učini s vama čudesa,  
\q2 i narod moj neće se posramiti doveka.   
\q1
\v 27 I poznaćete da sam ja usred Izrailja,  
\q2 i da sam ja Gospod Bog vaš,  
\q2 i da nema drugog,  
\q1 i narod moj neće se posramiti doveka.   
\b  
\q1
\v 28 I posle ću izliti duh svoj na svako telo,  
\q2 i proricaće sinovi vaši i kćeri vaše,  
\q1 starci će vaši sanjati sne,  
\q2 mladići će vaši viđati utvare.   
\q1
\v 29 I na sluge ću i na sluškinje u one dane izliti duh svoj;   
\b  
\p
\v 30 I učiniću čudesa na nebu i na zemlji, krv i oganj i pušenje dima.  
\v 31 Sunce će se pretvoriti u tamu i mesec u krv pre nego dođe veliki i strašni dan Gospodnji.  
\v 32 I svaki koji prizove ime Gospodnje spašće se; jer će na gori Sionu i u Jerusalimu biti spasenje, kao što je rekao Gospod, i u ostatku koji pozove Gospod.   
\c 3  
\s1 Kazna Božija nad neprijateljem. Spasenje i blagovanje naroda Božijeg.  
\p
\v 1 Jer, gle, u one dane i u ono vreme, kad vratim roblje Judino i jerusalimsko,  
\v 2 sabraću sve narode, i svešću ih u dolinu Josafatovu, i onde ću se suditi s njima za svoj narod i za nasledstvo svoje Izrailja, kog rasejaše među narode i razdeliše zemlju moju;  
\v 3 i za moj narod bacaše žreb, i davaše dete za kurvu, i prodavaše devojku za vino, te piše.   
\p
\v 4 I šta hoćete vi sa mnom, Tire i Sidone, i svi krajevi palestinski? Hoćete li da mi platite? I hoćete li da mi vratite? Odmah ću vam bez oklevanja platiti platu vašu na vašu glavu.  
\v 5 Jer uzeste srebro moje i zlato moje, i najlepše zaklade moje unesoste u svoje crkve.  
\v 6 I sinove Judine i sinove jerusalimske prodadoste sinovima grčkim da biste ih oterali daleko od međe njihove.  
\v 7 Evo, ja ću ih dignuti s mesta kuda ih prodadoste, i platiću vam platu vašu na vašu glavu.  
\v 8 I prodaću vaše sinove i vaše kćeri u ruke sinovima Judinim, i oni će ih prodati Savejcima u narod daleki, jer Gospod reče.   
\b  
\q1
\v 9 Objavite ovo po narodima,  
\q2 oglasite rat,  
\q1 podignite junake neka dođu  
\q2 i idu svi vojnici.   
\q1
\v 10 Raskujte raonike svoje na mačeve,  
\q2 i srpove svoje na koplja;  
\q1 ko je slab, neka reče:  
\q2 Junak sam.   
\b  
\q1
\v 11 Skupite se i hodite, svi narodi unaokolo,  
\q2 i saberite se!  
\q1 Tamo svedi, Gospode,  
\q2 junake svoje.   
\q1
\v 12 Neka se podignu i dođu narodi u dolinu Josafatovu;  
\q2 jer ću onde sesti da sudim svim narodima unaokolo.   
\b  
\q1
\v 13 Zamahnite srpom,  
\q2 jer je žetva uzrela;  
\q1 hodite, siđite,  
\q2 jer je tesak pun, kace se prelivaju;  
\q2 jer je zloća njihova velika.   
\b  
\q1
\v 14 Gomile, gomile u dolini sudskoj;  
\q2 jer je dan Gospodnji blizu u dolini sudskoj.   
\q1
\v 15 Sunce će i mesec pomrknuti,  
\q2 i zvezde će ustegnuti svoju svetlost.   
\b  
\q1
\v 16 I Gospod će riknuti sa Siona,  
\q2 i iz Jerusalima će pustiti glas svoj,  
\q2 i zatrešće se nebo i zemlja;  
\q1 ali će Gospod biti utočište svom narodu  
\q2 i krepost sinovima Izrailjevim.   
\b  
\q1
\v 17 I poznaćete da sam ja Gospod Bog vaš,  
\q2 koji nastavam u Sionu,  
\q2 u svetoj gori svojoj;  
\q1 i Jerusalim će biti svet,  
\q2 i tuđinci neće više ići po njemu.   
\b  
\q1
\v 18 I tada će gore kapati slatkim vinom,  
\q2 i humovi će se topiti od mleka,  
\q1 i svim potocima Judinim teći će voda,  
\q2 i izaći će izvor iz doma Gospodnjeg  
\q2 i natopiće dolinu Sitim.   
\b  
\q1
\v 19 Misir će opusteti,  
\q2 i edomska će biti pusta pustinja  
\q1 za nasilje učinjeno sinovima Judinim,  
\q2 jer proliše krv pravu u zemlji njihovoj.   
\q1
\v 20 A Juda će stajati doveka  
\q2 i Jerusalim od kolena do kolena.   
\q1
\v 21 I očistiću krv njihovu,  
\q2 koje ne očistih;  
\q1 i Gospod će nastavati u Sionu.   