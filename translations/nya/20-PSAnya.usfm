\id PSA - Biblica® Open God’s Word in Contemporary Chichewa 2016 
\h MASALIMO 
\toc1 Masalimo 
\toc2 Masalimo 
\toc3 Salimo 
\mt1 Masalimo 
\c 1  
\ms1 BUKU LOYAMBA 
\mr Masalimo 1–41 
\cl Salimo 1 
\q1  
\v 1 Wodala munthu 
\q2 amene satsatira uphungu wa anthu ochimwa, 
\q1 kapena kuyima mʼnjira ya anthu oyipa, 
\q2 kapena kukhala mʼmagulu a anthu onyoza. 
\q1  
\v 2 Koma chikondwerero chake chili mʼmalamulo a Yehova 
\q2 ndipo mʼmalamulo akewo amalingaliramo usana ndi usiku. 
\q1  
\v 3 Iye ali ngati mtengo wodzalidwa mʼmbali mwa mitsinje ya madzi, 
\q2 umene umabereka zipatso zake pa nyengo yake 
\q1 ndipo masamba ake safota. 
\q2 Chilichonse chimene amachita amapindula nacho. 
\q1  
\v 4 Sizitero ndi anthu oyipa! 
\q2 Iwo ali ngati mungu 
\q2 umene umawuluzidwa ndi mphepo. 
\q1  
\v 5 Kotero anthu oyipa sadzatha kuyima pa chiweruzo, 
\q2 kapena anthu ochimwa mu msonkhano wa anthu olungama. 
\b  
\q1  
\v 6 Pakuti Yehova amayangʼanira mayendedwe a anthu olungama, 
\q2 koma mayendedwe a anthu oyipa adzawonongeka. 
\c 2  
\cl Salimo 2 
\q1  
\v 1 Nʼchifukwa chiyani anthu a mitundu ina akufuna kuchita chiwembu? 
\q2 Akonzekeranji zopanda pake anthu? 
\q1  
\v 2 Mafumu a dziko lapansi akugwirizana nazo; 
\q2 ndipo olamulira asonkhana pamodzi 
\q1 kulimbana ndi Ambuye 
\q2 ndi wodzozedwa wakeyo. 
\q1  
\v 3 Iwo akunena kuti, “Tiyeni timasule magoli awo 
\q2 ndipo titaye zingwe zawo.” 
\b  
\q1  
\v 4 Wokhala mmwamba akuseka; 
\q2 Ambuye akuwanyoza iwowo. 
\q1  
\v 5 Ndipo iye awadzudzula mu mkwiyo wake 
\q2 ndi kuwaopseza mu ukali wake, kunena kuti, 
\q1  
\v 6 “Ine ndakhazikitsa mfumu yanga 
\q2 pa Ziyoni, phiri langa loyera.” 
\p  
\v 7 Ine ndidzalengeza zimene Yehova walamula: 
\q1 Iye anati kwa Ine, “Iwe ndiwe mwana wanga; 
\q2 lero Ine ndakhala Atate ako. 
\q1  
\v 8 Tandipempha, 
\q2 ndipo ndidzachititsa kuti mitundu ya anthu ikhale cholowa chako; 
\q2 malekezero a dziko lapansi kuti akhale chuma chako. 
\q1  
\v 9 Iweyo udzawalamulira ndi ndodo yaufumu yachitsulo; 
\q2 udzawaphwanya zidutswazidutswa ngati zowumba zadothi.” 
\b  
\q1  
\v 10 Kotero, inu mafumu, chenjerani; 
\q2 chenjezedwani, inu olamulira a dziko lapansi. 
\q1  
\v 11 Tumikirani Yehova mwa mantha 
\q2 ndi kukondwerera ulamuliro wake monjenjemera. 
\q1  
\v 12 Mpsopsoneni mwanayo kuti angakwiye; 
\q2 kuti mungawonongedwe mʼnjira zanu, 
\q1 pakuti ukali wake utha kuuka mʼkanthawi kochepa. 
\q2 Odala ndi onse amene amathawira kwa Iye. 
\c 3  
\cl Salimo 3 
\d Salimo la Davide. Atathawa mwana wake Abisalomu. 
\q1  
\v 1 Inu Yehova, achulukadi adani anga! 
\q2 Achulukadi amene andiwukira! 
\q1  
\v 2 Ambiri akunena za ine kuti, 
\q2 “Mulungu sadzamupulumutsa.” 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 3 Koma Inu Yehova, ndinu chishango chonditeteza, 
\q2 Inu mwandiveka ulemerero ndipo mwanditukula. 
\q1  
\v 4 Kwa Yehova, Ine ndilira mofuwula 
\q2 ndipo Iye amandiyankha kuchokera ku phiri lake loyera. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 5 Ine ndimagona ndi kupeza tulo; 
\q2 ndimadzukanso chifukwa Yehova amandichirikiza. 
\q1  
\v 6 Sindidzaopa adani anga osawerengeka amene 
\q2 abwera kulimbana nane kuchokera ku madera onse. 
\b  
\q1  
\v 7 Dzukani, Inu Yehova! 
\q2 Pulumutseni, Inu Mulungu wanga. 
\q1 Akantheni adani anga onse pa msagwada; 
\q2 gululani mano a anthu oyipa. 
\b  
\q1  
\v 8 Chipulumutso chimachokera kwa Yehova. 
\q2 Madalitso akhale pa anthu anu. 
\q4 \qs Sela\qs* 
\c 4  
\cl Salimo 4 
\d Kwa mtsogoleri wa mayimbidwe wa zida za zingwe. Salimo la Davide. 
\q1  
\v 1 Ndiyankheni pamene ndiyitana Inu, 
\q2 Inu Mulungu wa chilungamo changa. 
\q1 Pumulitseni ku zowawa zanga; 
\q2 chitireni chifundo ndi kumva pemphero langa. 
\b  
\q1  
\v 2 Anthu inu, mpaka liti mudzakhala mukusandutsa ulemerero wanga kukhala manyazi? 
\q2 Mpaka liti mudzakonda zachabe ndi kufuna milungu yabodza? 
\q4 Sela. 
\q1  
\v 3 Dziwani kuti Yehova wadziyikira padera anthu okhulupirika; 
\q2 Yehova adzamva pamene ndidzamuyitana. 
\b  
\q1  
\v 4 Kwiyani koma musachimwe; 
\q2 pamene muli pa mabedi anu, 
\q2 santhulani mitima yanu ndi kukhala chete. 
\q4 \qs Sela\qs* 
\q1  
\v 5 Perekani nsembe zolungama 
\q2 ndipo dalirani Yehova. 
\b  
\q1  
\v 6 Ambiri akufunsa kuti, “Ndani angationetse chabwino chilichonse?” 
\q2 Kuwunika kwa nkhope yanu kutiwalire, Inu Yehova. 
\q1  
\v 7 Inu mwadzaza mtima wanga ndi chimwemwe chachikulu 
\q2 kuposa kuchuluka kwa tirigu wawo ndi vinyo watsopano. 
\q1  
\v 8 Ine ndidzagona ndi kupeza tulo mwamtendere, 
\q2 pakuti Inu nokha, Inu Yehova, 
\q2 mumandisamalira bwino. 
\c 5  
\cl Salimo 5 
\d Kwa mtsogoleri wa mayimbidwe zoyimbira za zitoliro. Salimo la Davide. 
\q1  
\v 1 Tcherani khutu ku mawu anga, Inu Yehova, 
\q2 ganizirani za kusisima kwanga 
\q1  
\v 2 Mverani kulira kwanga kofuna thandizo, 
\q2 Mfumu yanga ndi Mulungu wanga, 
\q2 pakuti kwa Inu, ine ndikupemphera. 
\q1  
\v 3 Mmawa, Yehova mumamva mawu anga; 
\q2 Mmawa ndimayala zopempha zanga pamaso panu 
\q2 ndi kudikira mwachiyembekezo. 
\b  
\q1  
\v 4 Inu si Mulungu amene mumasangalala ndi zoyipa; 
\q2 choyipa sichikhala pamaso panu. 
\q1  
\v 5 Onyada sangathe kuyima pamaso panu; 
\q2 Inu mumadana ndi onse ochita zoyipa. 
\q1  
\v 6 Mumawononga iwo amene amanena mabodza; 
\q2 anthu akupha ndi achinyengo, 
\q2 Yehova amanyansidwa nawo. 
\b  
\q1  
\v 7 Koma Ine, mwa chifundo chanu chachikulu, 
\q2 ndidzalowa mʼNyumba yanu; 
\q1 mwa ulemu ndidzaweramira pansi 
\q2 kuyangʼana ku Nyumba yanu yoyera. 
\q1  
\v 8 Tsogolereni Inu Yehova, mwa chilungamo chanu 
\q2 chifukwa cha adani anga ndipo 
\q2 wongolani njira yanu pamaso panga. 
\b  
\q1  
\v 9 Palibe mawu ochokera mʼkamwa mwawo amene angadalirike; 
\q2 mtima wawo wadzaza ndi chiwonongeko. 
\q1 Kummero kwawo kuli ngati manda apululu; 
\q2 ndi lilime lawo amayankhula zachinyengo. 
\q1  
\v 10 Lengezani kuti ndi olakwa, Inu Mulungu! 
\q2 Zochita zawo zoyipa zikhale kugwa kwawo. 
\q1 Achotseni pamaso panu chifukwa cha machimo awo ambiri, 
\q2 pakuti awukira Inu. 
\b  
\q1  
\v 11 Koma lolani kuti onse amene apeza chitetezo mwa Inu akondwere; 
\q2 lolani kuti aziyimba nthawi zonse chifukwa cha chimwemwe. 
\q1 Aphimbeni ndi chitetezo chanu, 
\q2 iwo amene amakonda dzina lanu akondwere mwa Inu. 
\q1  
\v 12 Ndithu, Inu Yehova, mumadalitsa olungama; 
\q2 mumawazungulira ndi kukoma mtima kwanu ngati chishango. 
\c 6  
\cl Salimo 6 
\d Kwa mtsogoleri wa mayimbidwe. Pa zoyimbira za zingwe. Molingana ndi seminiti. Salimo la Davide. 
\q1  
\v 1 Inu Yehova, musandidzudzule mu mkwiyo wanu, 
\q2 kapena kundilanga mu ukali wanu. 
\q1  
\v 2 Ndichitireni chifundo Inu Yehova, pakuti ndalefuka; 
\q2 Inu Yehova chiritseni, pakuti mafupa anga ali pa ululu waukulu. 
\q1  
\v 3 Moyo wanga uli pa mazunzo aakulu. 
\q2 Mpaka liti, Inu Yehova, mpaka liti? 
\b  
\q1  
\v 4 Tembenukani Inu Yehova, ndipo mundilanditse; 
\q2 pulumutseni chifukwa cha chikondi chanu chosasinthika. 
\q1  
\v 5 Palibe amene amakukumbukirani pamene wamwalira; 
\q2 Amakutamandani ndani ali ku manda? 
\b  
\q1  
\v 6 Ine ndatopa ndi kubuwula; 
\q2 usiku wonse pa bedi panga pamadzaza ndi misozi yanga; 
\q2 ndimanyowetsa pogona panga ndi misozi. 
\q1  
\v 7 Maso anga atupa chifukwa cha chisoni; 
\q2 akulephera kuona chifukwa cha adani anga. 
\b  
\q1  
\v 8 Chokani kwa ine inu nonse amene mumachita zoyipa, 
\q2 pakuti Yehova wamva kulira kwanga. 
\q1  
\v 9 Yehova wamva kupempha kwanga kofuna chifundo; 
\q2 Yehova walandira pemphero langa. 
\q1  
\v 10 Adani anga onse adzachita manyazi ndipo adzakhala ndi mantha; 
\q2 adzabwerera msangamsanga mwa manyazi. 
\c 7  
\cl Salimo 7 
\d Sigioni wa Davide, amene anayimbira Yehova zokhudza Kusi, wa fuko la Benjamini. 
\q1  
\v 1 Inu Yehova Mulungu wanga, Ine ndikuthawira kwa Inu; 
\q2 pulumutseni ndi kundilanditsa kwa onse amene akundithamangitsa, 
\q1  
\v 2 mwina angandikadzule ngati mkango, 
\q2 ndi kundingʼamba popanda wondipulumutsa. 
\b  
\q1  
\v 3 Inu Yehova Mulungu wanga, 
\q2 ngati ndachita izi ndipo ndapezeka wolakwa, 
\q1  
\v 4 ngati ndachita zoyipa kwa iye amene ndili naye pa mtendere, 
\q2 kapena popanda chifukwa ndalanda mdani wanga, 
\q1  
\v 5 pamenepo lolani adani anga andithamangitse ndi kundipitirira, 
\q2 lolani kuti moyo wanga aupondereze pansi 
\q2 ndipo mundigoneke pa fumbi. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 6 Nyamukani Yehova, mu mkwiyo wanu; 
\q2 nyamukani kutsutsana ndi mkwiyo wa adani anga. 
\q2 Dzukani Mulungu wanga, lamulirani chilungamo chanu. 
\q1  
\v 7 Lolani gulu la anthu a mitundu ina lisonkhane mokuzungulirani. 
\q2 Alamulireni muli kumwambako; 
\q2  
\v 8 Yehova aweruzeni anthu a mitundu inayo. 
\q1 Ndiweruzeni Yehova, monga mwa chilungamo changa, 
\q2 monga mwa moyo wanga wangwiro, Inu Wammwambamwamba. 
\q1  
\v 9 Inu Mulungu wolungama, 
\q2 amene mumasanthula maganizo ndi mitima, 
\q1 thetsani chiwawa cha anthu oyipa 
\q2 ndipo wolungama akhale motetezedwa. 
\b  
\q1  
\v 10 Chishango changa ndi Mulungu Wammwambamwamba, 
\q2 amene amapulumutsa olungama mtima. 
\q1  
\v 11 Mulungu amaweruza molungama, 
\q2 Mulungu amene amaonetsa ukali wake tsiku ndi tsiku. 
\q1  
\v 12 Ngati munthu satembenuka, 
\q2 Mulungu adzanola lupanga lake, 
\q2 Iye adzawerama ndi kukoka uta. 
\q1  
\v 13 Mulungu wakonza zida zake zoopsa; 
\q2 Iye wakonzekera mivi yake yoyaka moto. 
\b  
\q1  
\v 14 Taonani, munthu woyipa amalingalira zoyipa zokhazokha nthawi zonse. 
\q2 Zochita zake ndi zosokoneza ndi zovutitsa anthu ena. 
\q1  
\v 15 Iye amene akumba dzenje ndi kulizamitsa 
\q2 amagwera mʼdzenje limene wakumbalo. 
\q1  
\v 16 Mavuto amene amayambitsa amamubwerera mwini; 
\q2 chiwawa chake chimatsikira pa mutu wake womwe. 
\b  
\q1  
\v 17 Ine ndidzayamika Yehova chifukwa cha chilungamo chake; 
\q2 ndipo ndidzayimba nyimbo zamatamando pa dzina la Yehova Wammwambamwamba. 
\c 8  
\cl Salimo 8 
\d Kwa mtsogoleri wa mayimbidwe. Pa gititi. Salimo la Davide. 
\q1  
\v 1 Inu Yehova Ambuye athu, 
\q2 dzina lanu ndi la lamphamvudi pa dziko lonse lapansi! 
\b  
\q1 Inu mwakhazikitsa ulemerero wanu 
\q2 mʼmayiko onse akumwamba. 
\q1  
\v 2 Kuchokera mʼkamwa mwa ana ndi makanda, 
\q2 Inu mwakhazikitsa mphamvu 
\q1 chifukwa cha adani anu, 
\q2 kukhazikitsa bata adani ndi anthu obwezera zoyipa. 
\b  
\q1  
\v 3 Pamene ndilingalira za mayiko anu akumwamba, 
\q2 ntchito ya zala zanu, 
\q1 mwezi ndi nyenyezi, 
\q2 zimene mwaziyika pa malo ake, 
\q1  
\v 4 munthu ndani kuti Inu mumamukumbukira, 
\q2 ndi mwana wa munthu kuti inu mumacheza naye? 
\q1  
\v 5 Inu munamupanga kukhala wocheperapo kusiyana ndi zolengedwa zakumwamba 
\q2 ndipo mwamuveka ulemerero ndi ulemu. 
\b  
\q1  
\v 6 Inu munamuyika wolamulira ntchito ya manja anu; 
\q2 munayika zinthu zonse pansi pa mapazi ake; 
\q1  
\v 7 nkhosa, mbuzi ndi ngʼombe pamodzi 
\q2 ndi nyama zakuthengo, 
\q1  
\v 8 mbalame zamlengalenga 
\q2 ndi nsomba zamʼnyanja 
\q2 zonse zimene zimayenda pansi pa nyanja. 
\b  
\q1  
\v 9 Inu Yehova, Ambuye athu, 
\q2 dzina lanu ndi lamphamvudi pa dziko lonse lapansi! 
\c 9  
\cl Salimo 9 
\d Kwa mtsogoleri wa mayimbidwe. Monga mwa mayimbidwe a nyimbo ya “Imfa ya Mwana.” Salimo la Davide. 
\q1  
\v 1 Ine ndidzakutamandani, Inu Yehova, ndi mtima wanga wonse; 
\q2 ndidzafotokoza za zodabwitsa zanu zonse. 
\q1  
\v 2 Ndidzakondwa ndi kusangalala mwa inu; 
\q2 Ndidzayimba nyimbo zamatamando pa dzina lanu, Inu Wammwambamwamba. 
\b  
\q1  
\v 3 Adani anga amathawa, 
\q2 iwo amapunthwa ndi kuwonongedwa pamaso panu. 
\q1  
\v 4 Pakuti Inu mwatsimikiza za kulungama kwanga ndi mlandu wanga; 
\q2 Inu mwakhala pa mpando wanu waufumu, kuweruza mwachilungamo. 
\q1  
\v 5 Mwadzudzula mitundu ya anthu ndipo mwawononga anthu oyipa; 
\q2 Inu mwafafaniza dzina lawo kwamuyaya. 
\q1  
\v 6 Chiwonongeko chosatha chagwera adani, 
\q2 mwafafaniza mizinda yawo; 
\q2 ngakhale chikumbutso chawo chawonongedwa. 
\b  
\q1  
\v 7 Yehova akulamulira kwamuyaya; 
\q2 wakhazikitsa mpando wake waufumu woweruzira. 
\q1  
\v 8 Iye adzaweruza dziko mwachilungamo; 
\q2 adzalamulira mitundu ya anthu mosakondera. 
\q1  
\v 9 Yehova ndiye kothawirako kwa opsinjika mtima, 
\q2 linga pa nthawi ya mavuto. 
\q1  
\v 10 Iwo amene amadziwa dzina lanu adzadalira Inu, 
\q2 pakuti Inu Yehova, simunawatayepo amene amafunafuna inu. 
\b  
\q1  
\v 11 Imbani nyimbo zamatamando kwa Yehova, ali pa mpando waufumu mu Ziyoni; 
\q2 lengezani pakati pa mitundu ya anthu zimene wachita. 
\q1  
\v 12 Pakuti Iye amene amabwezera chilango akupha anzawo wakumbukira; 
\q2 Iye salekerera kulira kwa ozunzika. 
\b  
\q1  
\v 13 Inu Yehova, onani momwe adani anga akundizunzira! 
\q2 Chitireni chifundo ndipo ndichotseni pa zipata za imfa, 
\q1  
\v 14 kuti ndilengeze za matamando anu 
\q2 pa zipata za ana aakazi a Ziyoni, 
\q2 kuti pamenepo ndikondwere ndi chipulumutso chanu. 
\q1  
\v 15 Mitundu ya anthu yagwa mʼdzenje limene yakumba; 
\q2 mapazi awo akodwa mu ukonde umene anawubisa. 
\q1  
\v 16 Yehova amadziwika ndi chilungamo chake; 
\q2 oyipa akodwa ndi ntchito za manja awo. 
\q4 \qs Higayoni. Sela\qs* 
\q1  
\v 17 Oyipa amabwerera ku manda, 
\q2 mitundu yonse imene imayiwala Mulungu. 
\q1  
\v 18 Koma osowa sadzayiwalika nthawi zonse, 
\q2 kapena chiyembekezo cha ozunzika kutayika nthawi zonse. 
\b  
\q1  
\v 19 Dzukani Inu Yehova, musalole munthu kuti apambane; 
\q2 mitundu yonse iweruzidwe pamaso panu. 
\q1  
\v 20 Akantheni ndi mantha aakulu, Inu Yehova; 
\q2 mitundu idziwe kuti iwo ndi anthu wamba. 
\q4 \qs Sela\qs* 
\c 10  
\cl Salimo 10 
\q1  
\v 1 Nʼchifukwa chiyani Yehova mwayima patali? 
\q2 Chifukwa chiyani mukudzibisa nokha pa nthawi ya mavuto? 
\b  
\q1  
\v 2 Mwa kunyada kwake munthu woyipa asaka wofowoka, 
\q2 amene akodwa mʼnjira zimene iye wakonza. 
\q1  
\v 3 Iye amatamandira zokhumba za mu mtima wake; 
\q2 amadalitsa aumbombo ndi kuchitira chipongwe Yehova. 
\q1  
\v 4 Mwa kunyada kwake woyipa safunafuna Mulungu; 
\q2 mʼmaganizo ake wonse mulibe malo a Mulungu. 
\q1  
\v 5 Zinthu zake zimamuyendera bwino; 
\q2 iye ndi wamwano ndipo malamulo anu ali nawo kutali; 
\q2 amanyogodola adani ake onse. 
\q1  
\v 6 Iye amadziyankhulira kuti, “Palibe chimene chidzandigwedeze. 
\q2 Ndidzakhala wokondwa nthawi zonse ndipo sindidzakhala pa mavuto.” 
\q1  
\v 7 Mʼkamwa mwake mwadzaza matemberero, mabodza ndi zoopseza; 
\q2 zovutitsa ndi zoyipa zili pansi pa lilime lake. 
\q1  
\v 8 Iye amabisalira anthu pafupi ndi midzi, 
\q2 kuchokera pobisalapo amapha anthu osalakwa, 
\q2 amayangʼanayangʼana mwachinsinsi anthu oti awawononge. 
\q1  
\v 9 Amabisalira anthu ngati mkango pa zitsamba. 
\q2 Amabisalira kuti agwire anthu opanda mphamvu; 
\q2 amagwira anthu opanda mphamvu ndi kuwakokera mu ukonde wake. 
\q1  
\v 10 Anthuwo amawapondaponda ndipo amakomoka; 
\q2 amakhala pansi pa mphamvu zake. 
\q1  
\v 11 Iye amati mu mtima mwake, “Mulungu wayiwala, 
\q2 wabisa nkhope yake ndipo sakuonanso.” 
\b  
\q1  
\v 12 Dzukani Yehova! Onetsani dzanja lanu Inu Mulungu. 
\q2 Musayiwale anthu opanda mphamvu. 
\q1  
\v 13 Nʼchifukwa chiyani munthu woyipa amachitira chipongwe Mulungu? 
\q2 Chifukwa chiyani amati mu mtima mwake, 
\q2 “Iye sandiyimba mlandu?” 
\q1  
\v 14 Komatu Inu Mulungu, mumazindikira mavuto ndi zosautsa, 
\q2 mumaganizira zochitapo kanthu. 
\q1 Wovutikayo amadzipereka yekha kwa Inu pakuti 
\q2 Inu ndi mthandizi wa ana amasiye. 
\q1  
\v 15 Thyolani dzanja la woyipitsitsa ndi la munthu woyipa; 
\q2 muzengeni mlandu chifukwa cha zoyipa zake 
\q2 zimene sizikanadziwika. 
\b  
\q1  
\v 16 Yehova ndi Mfumu kwamuyaya; 
\q2 mitundu ya anthu idzawonongeka kuchoka mʼdziko lake. 
\q1  
\v 17 Mumamva Inu Yehova, zokhumba za osautsidwa; 
\q2 mumawalimbikitsa ndipo mumamva kulira kwawo. 
\q1  
\v 18 Kuteteza ana amasiye ndi oponderezedwa, 
\q2 ndi cholinga chakuti munthu amene ali wa dziko lapansi asaopsenso. 
\c 11  
\cl Salimo 11 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Mwa Yehova ine ndimathawiramo. 
\q2 Nanga mungathe bwanji kunena kwa ine kuti, 
\q2 “Thawira ku phiri lako ngati mbalame. 
\q1  
\v 2 Pakuti taona oyipa akunga mauta awo; 
\q2 ayika bwino mivi yawo pa zingwe za uta, 
\q1 pobisala pawo kuti alase 
\q2 olungama mtima. 
\q1  
\v 3 Tsono ngati maziko awonongeka, 
\q2 olungama angachite chiyani?” 
\b  
\q1  
\v 4 Yehova ali mʼNyumba yake yoyera; 
\q2 Yehova ali pa mpando wake waufumu kumwamba. 
\q1 Iye amayangʼanitsitsa ana a anthu; 
\q2 maso ake amawayesa. 
\q1  
\v 5 Yehova amayesa olungama, 
\q2 koma moyo wake umadana ndi oyipa, 
\q2 amene amakonda zachiwawa. 
\q1  
\v 6 Iye adzakhuthulira pa oyipa 
\q2 makala amoto ndi sulufule woyaka; 
\q2 mphepo yotentha idzakhala yowayenera. 
\b  
\q1  
\v 7 Pakuti Yehova ndi wolungama, 
\q2 Iye amakonda chilungamo; 
\q2 ndipo anthu olungama adzaona nkhope yake. 
\c 12  
\cl Salimo 12 
\d Kwa mtsogoleri wa mayimbidwe. Monga mwa mayimbidwe seminiti. Salimo la Davide. 
\q1  
\v 1 Thandizeni Yehova pakuti palibe munthu wokhulupirika; 
\q2 okhulupirika akusowa pakati pa anthu. 
\q1  
\v 2 Aliyense amanamiza mʼbale wake; 
\q2 ndi pakamwa pawo pabodza amayankhula zachinyengo. 
\b  
\q1  
\v 3 Inu Yehova tsekani milomo yonse yachinyengo 
\q2 ndi pakamwa paliponse podzikuza. 
\q1  
\v 4 Pakamwa pamene pamati, “Ife tidzapambana ndi kuyankhula kwathu; 
\q2 pakamwapa ndi pathupathu, tsono mbuye wathu ndani?” 
\b  
\q1  
\v 5 “Chifukwa cha kuponderezedwa kwa anthu opanda mphamvu 
\q2 ndi kubuwula kwa anthu osowa, 
\q1 Ine ndidzauka tsopano,” akutero Yehova, 
\q2 “Ndidzawateteza kwa owazunza.” 
\q1  
\v 6 Ndipo mawu a Yehova ndi angwiro 
\q2 monga siliva oyengedwa mʼngʼanjo yadothi, 
\q2 oyengedwa kasanu nʼkawiri. 
\b  
\q1  
\v 7 Inu Yehova mudzatitchinjiriza ndipo 
\q2 mudzatiteteza kwa anthu otere kwamuyaya. 
\q1  
\v 8 Oyipa amangoyendayenda ponseponse 
\q2 anthu akamayamikira zochita zawo. 
\c 13  
\cl Salimo 13 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Mpaka liti Yehova? Kodi mudzandiyiwala mpaka kalekale? 
\q2 Mpaka liti mudzandibisira nkhope yanu? 
\q1  
\v 2 Ndidzalimbana ndi maganizo anga 
\q2 ndi kukhala ndi chisoni mu mtima mwanga tsiku lililonse mpaka liti? 
\q2 Mpaka liti adani anga adzandipambana? 
\b  
\q1  
\v 3 Ndiyangʼaneni ndi kundiyankha, Inu Yehova Mulungu wanga. 
\q2 Walitsani maso anga kuti ndingafe; 
\q1  
\v 4 mdani wanga adzati, “Ndamugonjetsa,” 
\q2 ndipo adani anga adzakondwera pamene ine ndagwa. 
\b  
\q1  
\v 5 Koma ndikudalira chikondi chanu chosasinthika; 
\q2 mtima wanga umakondwera ndi chipulumutso chanu. 
\q1  
\v 6 Ine ndidzayimbira Yehova 
\q2 pakuti wandichitira zokoma. 
\c 14  
\cl Salimo 14 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Chitsiru chimati mu mtima mwake, 
\q2 “Kulibe Mulungu.” 
\q1 Oterewa ndi oyipa ndipo ntchito zawo ndi zonyansa; 
\q2 palibe amene amachita zabwino. 
\b  
\q1  
\v 2 Yehova kumwamba wayangʼana pansi, 
\q2 kuyangʼana anthu onse 
\q1 kuti aone ngati alipo wina wanzeru, 
\q2 amene amafunafuna Mulungu. 
\q1  
\v 3 Onse atembenukira kumbali, 
\q2 onse pamodzi asanduka oyipa; 
\q1 palibe amene amachita zabwino, 
\q2 palibiretu ndi mmodzi yemwe. 
\b  
\q1  
\v 4 Kodi anthu ochita zoyipawa sadziwa chilichonse? 
\q2 Akudya anthu anga ngati chakudya chawo 
\q2 ndipo satamanda Yehova? 
\q1  
\v 5 Awo ali apowo, agwidwa ndi mantha aakulu, 
\q2 pakuti Mulungu ali mʼgulu la olungama. 
\q1  
\v 6 Inu ochita zoyipa mumalepheretsa chikonzero cha anthu osauka, 
\q2 koma Yehova ndiye pothawirapo pawo. 
\b  
\q1  
\v 7 Ndithu, chipulumutso cha Israeli chidzachokera ku Ziyoni! 
\q2 Pamene Yehova abwezeretsa ufulu wa anthu ake, 
\q2 Yakobo akondwere ndipo Israeli asangalale! 
\c 15  
\cl Salimo 15 
\d Salimo la Davide. 
\q1  
\v 1 Yehova, ndani angathe kukhala mʼmalo anu opatulika? 
\q2 Kodi ndani angathe kukhala mʼphiri lanu loyera? 
\b  
\q1  
\v 2 Munthu wa makhalidwe abwino, 
\q2 amene amachita zolungama, 
\q1 woyankhula choonadi chochokera mu mtima mwake, 
\q2  
\v 3 ndipo mʼkamwa mwake simutuluka mawu osinjirira, 
\q1 amene sachitira choyipa mnansi wake 
\q2 kapena kufalitsa mbiri yoyipa ya munthu mnzake, 
\q1  
\v 4 amene sapereka ulemu kwa munthu woyipa. 
\q2 Koma amalemekeza amene amaopa Yehova, 
\q1 amene amakwaniritsa zomwe walonjeza 
\q2 ngakhale pamene zikumupweteka, 
\q1  
\v 5 amene amakongoletsa ndalama zake popanda chiwongoladzanja 
\q2 ndipo salandira chiphuphu pofuna kutsutsa anthu osalakwa. 
\b  
\q1 Iye amene amachita zinthu zimenezi 
\q2 sadzagwedezeka konse. 
\c 16  
\cl Salimo 16 
\d Mikitamu ya Davide. 
\q1  
\v 1 Ndisungeni Inu Mulungu, 
\q2 pakuti ine ndimathawira kwa Inu. 
\b  
\q1  
\v 2 Ndinati kwa Yehova, “Inu ndinu Ambuye anga; 
\q2 popanda Inu, ine ndilibe chinthu chinanso chabwino.” 
\q1  
\v 3 Kunena za oyera mtima amene ali pa dziko, 
\q2 amenewa ndi olemekezeka, amene ndimakondwera nawo. 
\q1  
\v 4 Anthu amene amathamangira kwa milungu ina 
\q2 mavuto awo adzachulukadi. 
\q1 Ine sindidzathira nawo nsembe zawo zamagazi 
\q2 kapena kutchula mayina awo ndi pakamwa panga. 
\b  
\q1  
\v 5 Yehova, Inu mwandipatsa cholowa changa ndi chikho changa; 
\q2 mwateteza kolimba gawo langa. 
\q1  
\v 6 Malire a malo anga akhala pabwino; 
\q2 ndithudi, ine ndili cholowa chokondweretsa kwambiri. 
\b  
\q1  
\v 7 Ine ndidzatamanda Yehova amene amandipatsa uphungu; 
\q2 ngakhale usiku mtima wanga umandilangiza. 
\q1  
\v 8 Ndayika Yehova patsogolo panga nthawi zonse. 
\q2 Popeza Iyeyo ali kudzanja langa lamanja, 
\q2 sindidzagwedezeka. 
\b  
\q1  
\v 9 Choncho mtima wanga ndi wosangalala ndipo pakamwa panga pakukondwera; 
\q2 thupi langanso lidzakhala pabwino, 
\q1  
\v 10 chifukwa Inu simudzandisiya ku manda, 
\q2 simudzalola kuti woyera wanu avunde. 
\q1  
\v 11 Inu mwandidziwitsa njira ya moyo; 
\q2 mudzandidzaza ndi chimwemwe pamaso panu, 
\q2 ndidzasangalala mpaka muyaya pa dzanja lanu lamanja. 
\c 17  
\cl Salimo 17 
\d Pemphero la Davide. 
\q1  
\v 1 Imvani Inu Yehova pempho langa lachilungamo; 
\q2 mverani kulira kwanga. 
\q1 Tcherani khutu kuti mumve pemphero langa 
\q2 popeza silikuchokera pakamwa pachinyengo. 
\q1  
\v 2 Kusalakwa kwanga kuchokera kwa inu; 
\q2 maso anu aone chimene ndi cholungama. 
\b  
\q1  
\v 3 Ngakhale Inu mutafufuza mtima wanga ndi kundisanthula usiku, 
\q2 ngakhale mutandiyesa, simudzapeza kanthu; 
\q2 Ine ndatsimikiza kuti pakamwa panga sipadzachimwa. 
\q1  
\v 4 Kunena za ntchito za anthu, 
\q2 monga mwa mawu a pakamwa panu, 
\q1 Ine ndadzisunga ndekha 
\q2 posatsata njira zachiwawa. 
\q1  
\v 5 Mayendedwe anga akhazikika pa njira zanu; 
\q2 mapazi anga sanaterereke. 
\b  
\q1  
\v 6 Ine ndikuyitana Inu, Mulungu wanga, pakuti mudzandiyankha; 
\q2 tcherani khutu lanu kwa ine ndipo mumve pemphero langa. 
\q1  
\v 7 Onetsani kudabwitsa kwa chikondi chanu chachikulu, 
\q2 Inu amene mumapulumutsa ndi dzanja lanu lamanja 
\q2 iwo amene amathawira kwa inu kuchoka kwa adani awo. 
\q1  
\v 8 Mundisunge ine ngati mwanadiso; 
\q2 mundibise mu mthunzi wa mapiko anu, 
\q1  
\v 9 kuchoka kwa oyipa amene amandizinga ine, 
\q2 kuchoka kwa anthu amene ndi adani anga, amene andizungulira ine. 
\b  
\q1  
\v 10 Iwo amatseka mitima yawo yopanda chifundo, 
\q2 ndi pakamwa pawo amayankhula modzitamandira. 
\q1  
\v 11 Andisaka, tsopano andizungulira 
\q2 ndi maso awo atcheru, kuti andigwetse pansi. 
\q1  
\v 12 Iwo ali ngati mkango wofuna nyama; 
\q2 ngati mkango waukulu wokhala mobisala. 
\b  
\q1  
\v 13 Dzukani Yehova, mulimbane nawo ndipo muwagwetse pansi; 
\q2 landitseni kuchoka kwa oyipa ndi lupanga lanu. 
\q1  
\v 14 Inu Yehova, pulumutseni ndi dzanja lanu kwa anthu otere, 
\q2 kwa anthu a dziko lino amene mphotho yawo ili mʼmoyo uno. 
\b  
\q1 Inu mumaletsa njala kwa amene asangalatsidwa nanu; 
\q2 ana awo aamuna ali ndi zinthu zambiri, 
\q2 ndipo iwo amasunga chuma cha ana awo. 
\q1  
\v 15 Ndipo ine mʼchilungamo ndidzaona nkhope yanu; 
\q2 pamene ndidzadzuka, ndidzakondwera kwambiri poonana nanu. 
\c 18  
\cl Salimo 18 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide mtumiki wa Yehova. Iye anayimbira Yehova nyimbo iyi pamene Yehovayo anamupulumutsa mʼdzanja la adani ake onse ndiponso mʼdzanja la Sauli. 
\q1  
\v 1 Davide anati: Ine ndimakukondani Inu Yehova, mphamvu zanga. 
\b  
\q1  
\v 2 Yehova ndiye thanthwe langa, chitetezo changa ndi mpulumutsi wanga; 
\q2 Mulungu wanga ndi thanthwe langa mʼmene ndimathawiramo. 
\q2 Chishango changa ndi ndodo yachipulumutso changa, ndi linga langa. 
\q1  
\v 3 Ndimayitana Yehova amene ndi woyenera matamando, 
\q2 ndipo ndapulumutsidwa kwa adani anga. 
\b  
\q1  
\v 4 Zingwe za imfa zinandizinga; 
\q2 mitsinje yothamanga yachiwonongeko inandiopsa kwambiri. 
\q1  
\v 5 Anandimanga ndi zingwe za ku manda; 
\q2 misampha ya imfa inalimbana nane. 
\q1  
\v 6 Mʼmasautso anga ndinapemphera kwa Yehova; 
\q2 ndinalirira kwa Mulungu wanga kuti andithandize. 
\q1 Ali mʼNyumba yake, anamva mawu anga; 
\q2 kulira kwanga kunafika pamaso pake ndi mʼmakutu mwake. 
\b  
\q1  
\v 7 Dziko lapansi linanjenjemera ndi kuchita chivomerezi, 
\q2 ndipo maziko a mapiri anagwedezeka; 
\q2 ananjenjemera chifukwa Iye anakwiya. 
\q1  
\v 8 Mʼmphuno mwake munatuluka utsi; 
\q2 moto wonyeketsa unatuluka mʼkamwa mwake, 
\q2 makala amoto anali lawilawi mʼkamwa mwake. 
\q1  
\v 9 Iye anangʼamba thambo natsika pansi; 
\q2 pansi pa mapazi ake panali mitambo yakuda. 
\q1  
\v 10 Iye anakwera pa Kerubi ndi kuwuluka; 
\q2 nawuluka ndi mphepo mwaliwiro. 
\q1  
\v 11 Iye anapanga mdima kukhala chofunda chake, 
\q2 chophimba chake chomuzungulira chinali mitambo yakuda ya mlengalenga. 
\q1  
\v 12 Mʼkuwala kumene kunali pamaso pake munkachokera matalala, 
\q2 makala amoto ndi ziphaliwali zongʼanima. 
\q1  
\v 13 Yehova anabangula kumwamba ngati bingu, 
\q2 mawu a Wammwambamwamba anamveka ponseponse. 
\q1  
\v 14 Iye anaponya mivi yake nabalalitsa adani ake, 
\q2 ndi zingʼaningʼani zake anawagonjetsa. 
\q1  
\v 15 Zigwa za mʼnyanja zinaonekera poyera; 
\q2 maziko a dziko lapansi anakhala poyera, 
\q1 Yehova atabangula mwaukali, 
\q2 pamene mpweya wamphamvu unatuluka mʼmphuno mwanu. 
\b  
\q1  
\v 16 Ali kumwamba, Iye anatambalitsa dzanja lake ndipo anandigwira; 
\q2 anandivuwula mʼmadzi ozama. 
\q1  
\v 17 Anandipulumutsa kwa mdani wanga wamphamvu, 
\q2 adani anga, amene anali amphamvu kuposa ine. 
\q1  
\v 18 Adaniwo analimbana nane pamene ndinali pa mavuto, 
\q2 koma Yehova anali thandizo langa. 
\q1  
\v 19 Iye anandipititsa kumalo otakasuka; 
\q2 anandipulumutsa chifukwa amakondwera nane. 
\b  
\q1  
\v 20 Yehova wandithandiza molingana ndi chilungamo changa; 
\q2 molingana ndi makhalidwe anga abwino, Iye wandipulumutsa. 
\q1  
\v 21 Pakuti ine ndinatsata njira za Yehova; 
\q2 ndilibe mlandu wochoka pamaso Mulungu wanga. 
\q1  
\v 22 Malamulo ake onse ali pamaso panga; 
\q2 sindinasiye malangizo ake. 
\q1  
\v 23 Ndakhala moyo wosalakwa pamaso pake 
\q2 ndipo ndakhala ndi kupewa tchimo. 
\q1  
\v 24 Yehova wandipatsa mphotho molingana ndi chilungamo changa, 
\q2 molingana ndi kuyera kwa manja anga pamaso pake. 
\b  
\q1  
\v 25 Kwa wokhulupirika, Inu mumaonetsa kukhulupirika kwanu; 
\q2 kwa anthu amakhalidwe abwino, Inu mumaonetsanso makhalidwe abwino, 
\q1  
\v 26 kwa woyera mtima, Inu mumaonetsa kuyera mtima kwanu, 
\q2 koma kwa achinyengo mumaonetsanso kunyansidwa nawo. 
\q1  
\v 27 Inu mumapulumutsa anthu odzichepetsa, 
\q2 koma anthu amtima odzikuza mumawatsitsa. 
\q1  
\v 28 Inu Yehova, sungani nyale yanga kuti iziyakabe; 
\q2 Mulungu wanga wasandutsa mdima wanga kukhala kuwunika. 
\q1  
\v 29 Ndi thandizo lanu nditha kulimbana ndi gulu la ankhondo; 
\q2 ndi Mulungu wanga nditha kuchita zosatheka ndi munthu. 
\b  
\q1  
\v 30 Kunena za Mulungu, zochita zake ndi zangwiro; 
\q2 mawu a Yehova alibe cholakwika. 
\q1 Iye ndi chishango 
\q2 kwa onse amene amathawira kwa Iye. 
\q1  
\v 31 Mulungu wina ndi uti wofanana nanu Yehova? 
\q2 Ndipo ndani amene ndi Thanthwe kupatula Mulungu wathu? 
\q1  
\v 32 Ndi Mulungu amene anandipatsa mphamvu 
\q2 ndi kulungamitsa njira yanga. 
\q1  
\v 33 Iye amasandutsa mapazi anga kukhala ngati ambawala yayikazi; 
\q2 Iye amandithandiza kuyimirira pamwamba pa mapiri. 
\q1  
\v 34 Iye amaphunzitsa manja anga kuchita nkhondo; 
\q2 manja anga amatha kuthyola uta wachitsulo. 
\q1  
\v 35 Inu mumandipatsa chishango chachipambano, 
\q2 ndipo dzanja lanu lamanja limandichirikiza; 
\q2 mumawerama pansi kundikuza. 
\q1  
\v 36 Munakulitsa njira yoyendamo ine, 
\q2 kuti mapazi anga asaguluke. 
\b  
\q1  
\v 37 Ndinathamangitsa adani anga ndi kuwapitirira; 
\q2 sindinabwerere mpaka atawonongedwa. 
\q1  
\v 38 Ndinakantha adaniwo kotero kuti sanathenso kudzuka; 
\q2 anagwera pa mapazi anga. 
\q1  
\v 39 Inu munandiveka ndi mphamvu yokachitira nkhondo, 
\q2 munachititsa kuti ndigonjetse adani anga. 
\q1  
\v 40 Inu munachititsa adani anga kutembenuka, kuonetsa misana yawo pothawa, 
\q2 ndipo ine ndinawononga adani angawo. 
\q1  
\v 41 Iwo anafuwula kupempha thandizo, koma panalibe ndi mmodzi yemwe owapulumutsa. 
\q2 Analirira kwa Yehova koma sanawayankhe. 
\q1  
\v 42 Ine ndinawaperesa ngati fumbi lowuluka ndi mphepo. 
\q2 Ndinawapondaponda ngati matope a mʼmisewu. 
\b  
\q1  
\v 43 Inu mwandipulumutsa mʼmanja mwa anthu; 
\q2 mwandisandutsa kukhala mtsogoleri wa anthu a mitundu ina. 
\q2 Anthu amene sindikuwadziwa ali pansi pa ulamuliro wanga. 
\q1  
\v 44 Alendo amadzipereka okha pamaso panga; 
\q2 akangomva za ine amandigonjera. 
\q1  
\v 45 Iwo onse anataya mtima; 
\q2 anatuluka mʼmalinga awo akunjenjemera. 
\b  
\q1  
\v 46 Yehova ndi wamoyo! Litamandidwe Thanthwe langa! 
\q2 Akuzike Mulungu Mpulumutsi wanga! 
\q1  
\v 47 Iye ndi Mulungu amene amabwezera chilango, 
\q2 amene amagonjetsa anthu a mitundu yonse amene ali pansi pa ulamuliro wanga, 
\q2  
\v 48 amene amandipulumutsa mʼmanja mwa adani anga. 
\q1 Inu munandikuza kuposa adani anga; 
\q2 munandilanditsa mʼmanja mwa anthu ankhanza. 
\q1  
\v 49 Choncho ine ndidzakutamandani pakati pa anthu a mitundu ina, Inu Yehova; 
\q2 ndidzayimba nyimbo zotamanda dzina lanu. 
\q1  
\v 50 Iye amapereka chipambano chachikulu kwa mfumu yake; 
\q2 amaonetsa chikondi chosasinthika kwa wodzozedwa wake, 
\q2 kwa Davide ndi zidzukulu zake kwamuyaya. 
\c 19  
\cl Salimo 19 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Zakumwamba zimalengeza za ulemerero wa Mulungu; 
\q2 thambo limalalikira ntchito za manja ake. 
\q1  
\v 2 Tsiku ndi tsiku zimayankhula mawu ambiri, 
\q2 usiku ndi usiku zimaonetsa poyera nzeru. 
\q1  
\v 3 Palibe kuyankhula, palibe mawu aliwonse; 
\q2 liwu lawo silimveka. 
\q1  
\v 4 Koma uthenga wawo umapita pa dziko lonse lapansi, 
\q2 mawuwo amafika mpaka 
\q1 kumalekezero a dziko lapansi. 
\q2  
\v 5 Dzuwa lili ngati mkwatibwi wobwera kuchokera ku nsanja yake, 
\q2 ngati katswiri wokondwerera kuthamanga pa mpikisano. 
\q1  
\v 6 Limatuluka kuyambira mbali ina ya thambo 
\q2 ndi kuzungulira mpaka mbali inanso; 
\q2 palibe chinthu chotha kupewa kutentha kwake. 
\b  
\q1  
\v 7 Lamulo la Yehova ndi langwiro, 
\q2 kutsitsimutsa moyo. 
\q1 Maumboni a Yehova ndi odalirika, 
\q2 amapereka nzeru kwa wopanda nzeru. 
\q1  
\v 8 Malangizo a Yehova ndi olungama, 
\q2 amapereka chimwemwe mu mtima. 
\q1 Malamulo a Yehova ndi onyezimira, 
\q2 amapereka kuwala. 
\q1  
\v 9 Kuopa Yehova ndiye chinthu changwiro, 
\q2 chimakhala mpaka muyaya. 
\q1 Maweruzo a Yehova ndi owona 
\q2 ndipo onse ndi olungama; 
\q1  
\v 10 ndi a mtengowapatali kuposa golide, 
\q2 kuposa golide weniweni; 
\q1 ndi otsekemera kuposa uchi, 
\q2 kuposa uchi wochokera pa chisa chake. 
\q1  
\v 11 Mtumiki wanu amachenjezedwa nawo; 
\q2 powasunga pali mphotho yayikulu. 
\b  
\q1  
\v 12 Ndani angathe kudziwa zolakwa zake? 
\q2 Mundikhululukire zolakwa zanga zobisika. 
\q1  
\v 13 Muteteze mtumiki wanunso ku machimo ochita akudziwa; 
\q2 iwo asandilamulire. 
\q1 Kotero ndidzakhala wosalakwa, 
\q2 wopanda mlandu wa tchimo lalikulu. 
\b  
\q1  
\v 14 Mawu a mʼkamwa mwanga ndi zolingalira za mu mtima mwanga 
\q2 zikhale zokondweretsa pamaso panu, 
\q2 Inu Yehova, Thanthwe langa ndi Mpulumutsi wanga. 
\c 20  
\cl Salimo 20 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Yehova akuyankhe pamene uli pa msautso; 
\q2 dzina la Mulungu wa Yakobo likuteteze. 
\q1  
\v 2 Iye atumize thandizo kuchokera ku malo ake opatulika; 
\q2 akugwirizize kuchokera ku Ziyoni. 
\q1  
\v 3 Iye akumbukire nsembe zako zonse 
\q2 ndipo alandire nsembe zako zopsereza. 
\q4 \qs Sela\qs* 
\q1  
\v 4 Akupatse chokhumba cha mtima wako 
\q2 ndipo akuthandize kuti zonse wakonza zichitike. 
\q1  
\v 5 Ife tidzafuwula ndi chimwemwe pamene iwe wapambana 
\q2 ndipo tidzanyamula mbendera zathu mʼdzina la Mulungu wathu, 
\q1 Yehova ayankhe zopempha zako zonse. 
\b  
\q1  
\v 6 Tsopano ndadziwa kuti Yehova amapulumutsa wodzozedwa wake; 
\q2 Iye amamuyankha kuchokera kumwamba ku malo ake opatulika 
\q2 ndi mphamvu yopulumutsa ya dzanja lake lamanja. 
\q1  
\v 7 Ena amadalira magaleta ndipo ena akavalo 
\q2 koma ife tidzadalira dzina la Yehova Mulungu wathu. 
\q1  
\v 8 Iwo amagonjetsedwa ndi kugwa, 
\q2 koma ife timadzuka ndi kuyima chilili. 
\b  
\q1  
\v 9 Inu Yehova, pulumutsani mfumu! 
\q2 Tiyankheni pamene tikuyitanani! 
\c 21  
\cl Salimo 21 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Inu Yehova, mfumu ikusangalala mu mphamvu yanu, 
\q2 chimwemwe chake nʼchachikuludi pa kupambana kumene mumapereka! 
\q1  
\v 2 Inu mwayipatsa zokhumba za mtima wake 
\q2 ndipo simunayimane zopempha za pa milomo yake. 
\q4 \qs Sela\qs* 
\q1  
\v 3 Inu munayilandira ndi madalitso ochuluka 
\q2 ndipo munayiveka chipewa chaufumu chagolide weniweni pa mutu wake. 
\q1  
\v 4 Iye anakupemphani moyo, ndipo munamupatsa 
\q2 masiku ochuluka kwamuyaya. 
\q1  
\v 5 Kudzera mʼzigonjetso zimene munapereka, ulemerero wake ndi waukulu; 
\q2 Inu mwapereka pa iyo ulemerero ndi ufumu. 
\q1  
\v 6 Zoonadi Inu mwayipatsa madalitso amuyaya, 
\q2 Inu mwayipatsa chisangalalo ndi chimwemwe chimene chili pamaso panu. 
\q1  
\v 7 Pakuti mfumu imadalira Yehova; 
\q2 kudzera mʼchikondi chake chosatha cha Wammwambamwamba, 
\q2 iyo sidzagwedezeka. 
\b  
\q1  
\v 8 Dzanja lanu lidzayimitsa adani anu onse; 
\q2 dzanja lanu lamanja lidzagwira adani anu. 
\q1  
\v 9 Pa nthawi ya kuonekera kwanu 
\q2 mudzawasandutsa ngʼanjo yamoto yotentha. 
\q1 Mu ukali wake Yehova adzawameza, 
\q2 ndipo moto wake udzawatha. 
\q1  
\v 10 Inu mudzawononga ana awo pa dziko lapansi, 
\q2 zidzukulu zawo pakati pa anthu. 
\q1  
\v 11 Ngakhale iwo akukonzereni chiwembu mwa kuchenjera kwawo 
\q2 sadzapambana; 
\q1  
\v 12 pakuti mudzawapirikitsa ndipo adzaonetsa misana yawo 
\q2 pamene mudzawaloza ndi mivi yanu. 
\b  
\q1  
\v 13 Mukwezeke Inu Yehova mʼmphamvu yanu, 
\q2 ife tidzayimba nyimbo ndi kutamanda mphamvu yanu. 
\c 22  
\cl Salimo 22 
\d Kwa mtsogoleri wa mayimbidwe. Monga mwa “Mbawala yayikazi ya Mmawa.” Salimo la Davide. 
\q1  
\v 1 Mulungu wanga, Mulungu wanga, nʼchifukwa chiyani mwandisiya? 
\q2 Chifuwa chiyani simukundithandiza ndi pangʼono pomwe? 
\q2 Nʼchifukwa chiyani simukumva mawu a kudandaula kwanga? 
\q1  
\v 2 Inu Mulungu wanga, ine ndimalira masana, koma simuyankha, 
\q2 usikunso, ndipo sindikhala chete. 
\b  
\q1  
\v 3 Inu ndinu Woyera, wokhala pa mpando waufumu; 
\q2 ndinu matamando a Israeli. 
\q1  
\v 4 Pa inu makolo athu anadalira; 
\q2 iwo anadalira ndipo Inu munawapulumutsa. 
\q1  
\v 5 Analirira kwa inu ndipo munawapulumutsa. 
\q2 Iwo anakhulupirira Inu ndipo simunawakhumudwitse. 
\b  
\q1  
\v 6 Koma ine ndine nyongolotsi osati munthu, 
\q2 wosekedwa ndi wonyozedwa ndi anthu onse. 
\q1  
\v 7 Onse amene amandiona amandiseka; 
\q2 amandiyankhulira mawu achipongwe akupukusa mitu yawo kunena kuti 
\q1  
\v 8 “Iyeyu amadalira Yehova, 
\q2 musiyeni Yehovayo amulanditse. 
\q1 Musiyeni Yehova amupulumutse 
\q2 popeza amakondwera mwa Yehovayo.” 
\b  
\q1  
\v 9 Komabe Inu ndinu amene munandibadwitsa, munanditulutsa mʼmimba mwa amayi anga. 
\q2 Munachititsa kuti ndizikudalirani 
\q2 ngakhale pa nthawi imene ndinkayamwa. 
\q1  
\v 10 Chibadwire ine ndinaperekedwa kwa Inu; 
\q2 kuchokera mʼmimba mwa amayi anga Inu mwakhala muli Mulungu wanga. 
\q1  
\v 11 Musakhale kutali ndi ine, 
\q2 pakuti mavuto ali pafupi 
\q2 ndipo palibe wina wondipulumutsa. 
\b  
\q1  
\v 12 Ngʼombe zazimuna zandizungulira; 
\q2 ngʼombe zazimuna zamphamvu za ku Basani zandizinga. 
\q1  
\v 13 Mikango yobangula pokadzula nyama, 
\q2 yatsekula kwambiri pakamwa pawo kulimbana nane. 
\q1  
\v 14 Ine ndatayika pansi ngati madzi 
\q2 ndipo mafupa anga onse achoka mʼmalo mwake. 
\q1 Mtima wanga wasanduka phula; 
\q2 wasungunuka mʼkati mwanga. 
\q1  
\v 15 Mphamvu zanga zauma ngati phale, 
\q2 ndipo lilime langa lamamatira ku nsagwada; 
\q2 mwandigoneka mʼfumbi la imfa. 
\q1  
\v 16 Agalu andizungulira; 
\q2 gulu la anthu oyipa landizinga. 
\q2 Alasa manja ndi mapazi anga. 
\q1  
\v 17 Ine nditha kuwerenga mafupa anga onse; 
\q2 anthu amandiyangʼanitsitsa ndi kundidzuma. 
\q1  
\v 18 Iwo agawana zovala zanga pakati pawo 
\q2 ndi kuchita maere pa zovala zangazo. 
\b  
\q1  
\v 19 Koma Inu Yehova, musakhale kutali; 
\q2 Inu mphamvu yanga, bwerani msanga kuti mudzandithandize. 
\q1  
\v 20 Pulumutsani moyo wanga ku lupanga, 
\q2 moyo wanga wopambanawu ku mphamvu ya agalu. 
\q1  
\v 21 Ndilanditseni mʼkamwa mwa mikango; 
\q2 pulumutseni ku nyanga za njati. 
\b  
\q1  
\v 22 Ine ndidzalengeza dzina lanu kwa abale anga; 
\q2 ndidzakutamandani mu msonkhano. 
\q1  
\v 23 Inu amene mumaopa Yehova mutamandeni! 
\q2 Inu zidzukulu zonse za Yakobo, mulemekezeni! 
\q2 Muopeni mwaulemu, inu zidzukulu zonse za Israeli! 
\q1  
\v 24 Pakuti Iye sanapeputse kapena kunyoza 
\q2 kuvutika kwa wosautsidwayo; 
\q1 Iye sanabise nkhope yake kwa iye. 
\q2 Koma anamvera kulira kwake kofuna thandizo. 
\b  
\q1  
\v 25 Ndidzakutamandani pa msonkhano waukulu chifukwa cha zimene mwandichitira. 
\q2 Ndidzakwaniritsa lonjezo langa pamaso pa amene amaopa Inu. 
\q1  
\v 26 Osauka adzadya ndipo adzakhuta; 
\q2 iwo amene amafunafuna Yehova adzamutamanda. 
\q2 Mitima yanu ikhale ndi moyo mpaka muyaya! 
\q1  
\v 27 Malekezero onse a dziko lapansi 
\q2 adzakumbukira Yehova ndi kutembenukira kwa Iye, 
\q1 ndipo mabanja a mitundu ya anthu 
\q2 adzawerama pamaso pake, 
\q1  
\v 28 pakuti ulamuliro ndi wake wa Yehova 
\q2 ndipo Iye amalamulira anthu a mitundu yonse. 
\b  
\q1  
\v 29 Anthu olemera onse a dziko lapansi adzachita phwando ndi kulambira; 
\q2 onse amene amapita ku fumbi adzagwada pamaso pake; 
\q2 iwo amene sangathe kudzisunga okha ndi moyo. 
\q1  
\v 30 Zidzukulu zamʼtsogolo zidzamutumikira Iye; 
\q2 mibado ya mʼtsogolo idzawuzidwa za Ambuye. 
\q1  
\v 31 Iwo adzalengeza za chilungamo chake 
\q2 kwa anthu amene pano sanabadwe 
\q2 pakuti Iye wachita zimenezi. 
\c 23  
\cl Salimo 23 
\d Salimo la Davide. 
\q1  
\v 1 Yehova ndiye mʼbusa wanga, sindidzasowa kanthu. 
\q2  
\v 2 Amandigoneka pa msipu wobiriwira, 
\q1 amanditsogolera ku madzi akumwa abwino, 
\q2  
\v 3 amatsitsimutsa moyo wanga. 
\q1 Amanditsogolera mʼnjira zachilungamo 
\q2 chifukwa cha dzina lake. 
\q1  
\v 4 Ngakhale ndiyende 
\q2 mʼchigwa cha mdima wakuda bii, 
\q1 sindidzaopa choyipa, 
\q2 pakuti Inu muli ndi ine; 
\q1 chibonga chanu ndi ndodo yanu 
\q2 zimanditonthoza. 
\b  
\q1  
\v 5 Mumandikonzera chakudya 
\q2 adani anga akuona. 
\q1 Mumadzoza mutu wanga ndi mafuta; 
\q2 chikho changa chimasefukira. 
\q1  
\v 6 Zoonadi, zokoma ndi chikondi chosasinthika zidzanditsata 
\q2 masiku onse a moyo wanga, 
\q1 ndipo ndidzakhala mʼNyumba ya Yehova 
\q2 kwamuyaya. 
\c 24  
\cl Salimo 24 
\d Salimo la Davide. 
\q1  
\v 1 Dziko lapansi ndi la Yehova ndi zonse zimene zili mʼmenemo, 
\q2 dziko ndi onse amene amakhala mʼmenemo; 
\q1  
\v 2 pakuti Iye ndiye anayika maziko ake pa nyanja 
\q2 ndi kulikhazika pamwamba pa madzi. 
\b  
\q1  
\v 3 Ndani angakwere phiri la Yehova? 
\q2 Ndani angathe kuyima pa malo ake opatulika? 
\q1  
\v 4 Iye amene ali ndi mʼmanja moyera ndi mtima woyera, 
\q2 amene sapereka moyo wake kwa fano 
\q2 kapena kulumbira mwachinyengo. 
\q1  
\v 5 Iyeyo adzalandira madalitso kwa Yehova 
\q2 ndipo Mulungu mpulumutsi wake adzagamula kuti alibe mlandu. 
\q1  
\v 6 Umenewo ndiwo mʼbado wa amene amafunafuna Yehova; 
\q2 amene amafunafuna nkhope yanu, Inu Mulungu wa Yakobo. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 7 Tukulani mitu yanu inu zipata; 
\q2 tsekukani, inu zitseko zakalekalenu, 
\q2 kuti Mfumu yaulemerero ilowe. 
\q1  
\v 8 Kodi Mfumu yaulemereroyo ndani? 
\q2 Yehova Wamphamvuzonse, 
\q2 Yehova ndiye wamphamvu pa nkhondo. 
\q1  
\v 9 Tukulani mitu yanu, inu zipata; 
\q2 tsekukani, inu zitseko zakalekalenu, 
\q2 kuti Mfumu yaulemerero ilowe. 
\q1  
\v 10 Kodi Mfumu yaulemereroyo ndani? 
\q2 Yehova Wamphamvuzonse, 
\q2 Iye ndiye Mfumu yaulemerero. 
\q4 \qs Sela\qs* 
\c 25  
\cl Salimo 25 
\d Salimo la Davide. 
\q1  
\v 1 Kwa Inu Yehova, ndipereka moyo wanga. 
\q2  
\v 2 Ndimadalira Inu Mulungu wanga. 
\q1 Musalole kuti ndichite manyazi 
\q2 kapena kuti adani anga andipambane. 
\q1  
\v 3 Aliyense amene amayembekezera kwa Ambuye 
\q2 sadzachititsidwa manyazi 
\q1 koma achinyengo ndiwo adzachititsidwe manyazi 
\q2 ndipo sadzakhala ndi chodzitetezera. 
\b  
\q1  
\v 4 Ndidziwitseni njira zanu Inu Yehova, 
\q2 phunzitseni mayendedwe anu; 
\q1  
\v 5 tsogolereni mʼchoonadi chanu ndi kundiphunzitsa, 
\q2 pakuti Inu ndinu Mulungu mpulumutsi wanga, 
\q2 ndipo chiyembekezo changa chili mwa Inu tsiku lonse. 
\q1  
\v 6 Kumbukirani Inu Yehova chifundo ndi chikondi chanu chachikulu, 
\q2 pakuti ndi zakalekale. 
\q1  
\v 7 Musakumbukire machimo a ubwana wanga 
\q2 ndi makhalidwe anga owukira; 
\q1 molingana ndi chikondi chanu ndikumbukireni ine, 
\q2 pakuti Inu Yehova ndinu wabwino. 
\b  
\q1  
\v 8 Yehova ndi wabwino ndi wolungama; 
\q2 choncho Iye akulangiza ochimwa mʼnjira yake. 
\q1  
\v 9 Amatsogolera odzichepetsa kuti achite zolungama 
\q2 ndipo amawaphunzitsa njira zake. 
\q1  
\v 10 Njira zonse za Yehova ndi zachikondi ndi zokhulupirika 
\q2 kwa iwo amene amasunga zofuna za pangano lake. 
\q1  
\v 11 Chifukwa cha dzina lanu, Inu Yehova, 
\q2 khululukireni mphulupulu zanga, ngakhale kuti ndi zochuluka. 
\q1  
\v 12 Tsono ndani munthu amene amaopa Yehova? 
\q2 Yehova adzamulangiza njira yoti ayitsate. 
\q1  
\v 13 Iye adzakhala pa ulemerero masiku ake onse, 
\q2 ndipo zidzukulu zake zidzalandira dziko ngati cholowa chawo. 
\q1  
\v 14 Yehova amawulula chinsinsi chake kwa iwo amene amamuopa; 
\q2 amawulula pangano lake kwa iwowo. 
\q1  
\v 15 Maso anga ali pa Yehova nthawi zonse, 
\q2 pakuti ndi Iye yekha amene adzawonjola mapazi anga mu msampha. 
\b  
\q1  
\v 16 Tembenukirani kwa ine ndipo mundikomere mtima, 
\q2 pakuti ndili ndekhandekha ndipo ndikuzunzika. 
\q1  
\v 17 Masautso a mu mtima mwanga achulukirachulukira; 
\q2 masuleni ku zowawa zanga. 
\q1  
\v 18 Penyani mazunzo anga ndi zovuta zanga 
\q2 ndipo mufafanize machimo anga onse. 
\q1  
\v 19 Onani mmene adani anga achulukira 
\q2 ndi momwe chidani chawo ndi ine chakulira. 
\q1  
\v 20 Tetezani moyo wanga ndi kundilanditsa; 
\q2 musalole kuti ndichite manyazi, 
\q2 pakuti ndimathawira kwa Inu. 
\q1  
\v 21 Kukhulupirika ndi kulungama kwanga kunditeteze, 
\q2 chifukwa chiyembekezo changa chili mwa Inu. 
\b  
\q1  
\v 22 Wombolani Israeli Inu Mulungu, 
\q2 ku mavuto ake onse! 
\c 26  
\cl Salimo 26 
\d Salimo la Davide. 
\q1  
\v 1 Weruzeni Inu Yehova 
\q2 pakuti ndakhala moyo wosalakwa. 
\q1 Ndadalira Yehova 
\q2 popanda kugwedezeka. 
\q1  
\v 2 Patseni mayeso, Inu Yehova ndipo ndiyeseni, 
\q2 santhulani mtima wanga ndi maganizo anga; 
\q1  
\v 3 pakuti chikondi chanu chili pamaso panga nthawi zonse, 
\q2 ndipo ndimayenda mʼchoonadi chanu nthawi zonse. 
\q1  
\v 4 Ine sindikhala pansi pamodzi ndi anthu achinyengo, 
\q2 kapena kufunsa nzeru kwa achiphamaso. 
\q1  
\v 5 Ndimanyansidwa ndi msonkhano wa anthu ochita zoyipa 
\q2 ndipo ndimakana kukhala pansi pamodzi ndi oyipa. 
\q1  
\v 6 Ndimasamba mʼmanja mwanga kuonetsa kusalakwa kwanga 
\q2 ndi kupita kukatumikira pa guwa lanu la nsembe, Inu Yehova, 
\q1  
\v 7 kulengeza mofuwula za matamando anu 
\q2 ndi kuwuza onse za ntchito zanu zodabwitsa. 
\q1  
\v 8 Ndimakonda Nyumba imene Inu Yehova mumakhalamo, 
\q2 malo amene ulemerero wanu umapezekako. 
\b  
\q1  
\v 9 Musachotse moyo wanga pamodzi ndi ochimwa, 
\q2 moyo wanga pamodzi ndi anthu akupha anzawo, 
\q1  
\v 10 amene mʼmanja mwawo muli ndondomeko zoyipa, 
\q2 dzanja lawo lamanja ladzaza ndi ziphuphu. 
\q1  
\v 11 Koma ine ndimakhala moyo wosalakwa; 
\q2 mu msonkhano wa anthu anu ndidzatamanda Yehova. 
\b  
\q1  
\v 12 Ndayima pa malo wopanda zovuta 
\q2 ndipo ndidzatamanda Yehova mu msonkhano waukulu. 
\c 27  
\cl Salimo 27 
\d Salimo la Davide. 
\q1  
\v 1 Yehova ndiye kuwunika kwanga ndi chipulumutso changa; 
\q2 ndidzaopa yani? 
\q1 Yehova ndi linga la moyo wanga; 
\q2 ndidzachita mantha ndi yani? 
\q1  
\v 2 Pamene anthu oyipa abwera kudzalimbana nane 
\q2 kudzadya mnofu wanga, 
\q1 pamene adani anga ndi achiwembu andithira nkhondo, 
\q2 iwo adzapunthwa ndi kugwa. 
\q1  
\v 3 Ngakhale gulu lankhondo lindizinge, 
\q2 mtima wanga sudzaopa. 
\q1 Ngakhale nkhondo itayambika kulimbana nane, 
\q2 ngakhale nthawi imeneyo, ine ndidzalimbika mtima. 
\b  
\q1  
\v 4 Chinthu chimodzi chokha chimene ndipempha kwa Yehova, 
\q2 ichi ndi chimene ndidzachifunafuna: 
\q1 kuti ndikhale mʼNyumba ya Yehova 
\q2 masiku onse a moyo wanga, 
\q1 ndi kuyangʼana kukongola kwa Yehova, 
\q2 ndi kumufunafuna Iye mʼNyumba yake. 
\q1  
\v 5 Pakuti pa tsiku la msautso 
\q2 Iye adzanditeteza mʼmalo ake okhalamo; 
\q1 adzandibisa mʼkati mwa Nyumba yake 
\q2 ndi kukhazika ine pamwamba pa thanthwe. 
\q1  
\v 6 Kotero mutu wanga udzakwezedwa 
\q2 kuposa adani anga amene andizungulira; 
\q1 pa Nyumba yake ndidzapereka nsembe ndi mfuwu wachimwemwe; 
\q2 ndidzayimba nyimbo kwa Yehova. 
\b  
\q1  
\v 7 Imvani mawu anga pamene ndiyitana Inu Yehova 
\q2 mundichitire chifundo ndipo mundiyankhe. 
\q1  
\v 8 Mtima wanga ukuti kwa Inu, “Funafuna nkhope yake!” 
\q2 Nkhope yanu Yehova ndidzayifunafuna. 
\q1  
\v 9 Musandibisire nkhope yanu, 
\q2 musamubweze mtumiki wanu mwamkwiyo; 
\q2 mwakhala muli thandizo langa. 
\q1 Musandikane kapena kunditaya, 
\q2 Inu Mulungu Mpulumutsi wanga. 
\q1  
\v 10 Ngakhale abambo ndi amayi anga anditaya 
\q2 Yehova adzandisamala. 
\q1  
\v 11 Phunzitseni njira yanu Inu Yehova, 
\q2 munditsogolere mʼnjira yowongoka 
\q2 chifukwa cha ondizunza. 
\q1  
\v 12 Musandipereke ku zokhumba za adani anga, 
\q2 pakuti mboni zambiri zauka kutsutsana nane 
\q2 ndipo zikundiopseza. 
\b  
\q1  
\v 13 Ine ndikutsimikiza mtima za zimenezi; 
\q2 ndidzaona ubwino wa Yehova 
\q2 mʼdziko la anthu amoyo. 
\q1  
\v 14 Dikirani pa Yehova; 
\q2 khalani anyonga ndipo limbani mtima 
\q2 nimudikire Yehova. 
\c 28  
\cl Salimo 28 
\d Salimo la Davide. 
\q1  
\v 1 Kwa Inu ine ndiyitana, Yehova ndinu Thanthwe langa; 
\q2 musakhale osamva kwa ine. 
\q1 Pakuti mukapitirira kukhala chete, 
\q2 ndidzakhala ngati iwo amene atsikira ku dzenje. 
\q1  
\v 2 Imvani kupempha chifundo kwanga 
\q2 pomwe ndikuyitana kwa Inu kuti mundithandize, 
\q1 pomwe ndikukweza manja anga 
\q2 kuloza ku malo anu oyeretsetsa. 
\b  
\q1  
\v 3 Musandikokere kutali pamodzi ndi anthu oyipa, 
\q2 pamodzi ndi iwo amene amachita zoyipa, 
\q1 amene amayankhula mwachikondi ndi anzawo 
\q2 koma akusunga chiwembu mʼmitima mwawo. 
\q1  
\v 4 Muwabwezere chifukwa cha zochita zawo 
\q2 ndi ntchito zawo zoyipa; 
\q1 abwezereni chifuwa cha zimene manja awo achita 
\q2 ndipo mubweretse pa iwo zimene zowayenera. 
\q1  
\v 5 Popeza iwowo sakhudzidwa ndi ntchito za Yehova, 
\q2 ndi zimene manja ake anazichita, 
\q1 Iye adzawakhadzula 
\q2 ndipo sadzawathandizanso. 
\b  
\q1  
\v 6 Matamando apite kwa Yehova, 
\q2 popeza Iye wamva kupempha chifundo kwanga. 
\q1  
\v 7 Yehova ndiye mphamvu yanga ndi chishango changa; 
\q2 mtima wanga umadalira Iye, ndipo Ine ndathandizidwa. 
\q1 Mtima wanga umalumphalumpha chifukwa cha chimwemwe 
\q2 ndipo ndidzayamika Iye mʼnyimbo. 
\b  
\q1  
\v 8 Yehova ndi mphamvu ya anthu ake, 
\q2 linga la chipulumutso kwa wodzozedwa wake. 
\q1  
\v 9 Pulumutsani anthu anu ndipo mudalitse cholowa chanu; 
\q2 mukhale mʼbusa wawo ndipo muwakweze kwamuyaya. 
\c 29  
\cl Salimo 29 
\d Salimo la Davide. 
\q1  
\v 1 Perekani kwa Yehova, inu anthu amphamvu, 
\q2 perekani kwa Yehova ulemerero ndi mphamvu. 
\q1  
\v 2 Perekani kwa Yehova ulemerero woyenera dzina lake, 
\q2 pembedzani Yehova mwa kukongola kwa chiyero chake. 
\b  
\q1  
\v 3 Liwu la Yehova lili pamwamba pa madzi; 
\q2 Mulungu waulemerero abangula, 
\q2 Yehova abangula pamwamba pa madzi amphamvu. 
\q1  
\v 4 Liwu la Yehova ndi lamphamvu; 
\q2 liwu la Yehova ndi laulemerero. 
\q1  
\v 5 Liwu la Yehova limathyola mikungudza; 
\q2 Yehova amathyolathyola mikungudza ya ku Lebanoni. 
\q1  
\v 6 Iye amachititsa Lebanoni kulumphalumpha ngati mwana wangʼombe, 
\q2 Siriyoni ngati mwana wa njati: 
\q1  
\v 7 Liwu la Yehova limakantha 
\q2 ngati kungʼanima kwa mphenzi. 
\q1  
\v 8 Liwu la Yehova limagwedeza chipululu; 
\q2 Yehova amagwedeza chipululu cha Kadesi. 
\q1  
\v 9 Liwu la Yehova limapindapinda mibawa 
\q2 ndi kuyeretsa nkhalango. 
\q1 Ndipo mʼNyumba mwake onse amafuwula kuti, “Ulemerero!” 
\b  
\q1  
\v 10 Yehova amakhala pamwamba pa madzi osefukira, 
\q2 Yehova ndiye mfumu kwamuyaya. 
\q1  
\v 11 Yehova amapereka mphamvu kwa anthu ake; 
\q2 Yehova amadalitsa anthu ake ndi mtendere. 
\c 30  
\cl Salimo 30 
\d Salimo la Davide. Nyimbo yoyimba popereka Nyumba ya Mulungu. 
\q1  
\v 1 Ndidzakukwezani Yehova, 
\q2 chifukwa mwanditulutsa kwakuya, 
\q2 ndipo simunalole kuti adani anga akondwere pa ine. 
\q1  
\v 2 Inu Yehova Mulungu wanga ndinapempha kwa Inu thandizo 
\q2 ndipo Inu munandichiritsa. 
\q1  
\v 3 Inu Yehova, munanditulutsa ku manda, 
\q2 munandisunga kuti ndisatsalire mʼdzenje. 
\b  
\q1  
\v 4 Imbirani Yehova inu anthu ake okhulupirika; 
\q2 tamandani dzina lake loyera. 
\q1  
\v 5 Pakuti mkwiyo wake umakhala kwa kanthawi 
\q2 koma kukoma mtima kwake ndi kwa moyo wonse; 
\q1 utha kuchezera kulira usiku wonse, 
\q2 koma chimwemwe chimabwera mmawa. 
\b  
\q1  
\v 6 Pamene ndinaona kuti ndili otetezedwa ndinati, 
\q2 “Sindidzagwedezekanso.” 
\q1  
\v 7 Inu Yehova, pamene munandikomera mtima, 
\q2 munachititsa phiri langa kuyima chilili; 
\q1 koma pamene munabisa nkhope yanu, 
\q2 ndinataya mtima. 
\b  
\q1  
\v 8 Kwa Inu Yehova ndinayitana; 
\q2 kwa Ambuye ndinapempha chifundo; 
\q1  
\v 9 “Kodi pali phindu lanji powonongeka kwanga 
\q2 ngati nditsikira ku dzenje? 
\q1 Kodi fumbi lidzakutamandani Inu? 
\q2 Kodi lidzalengeza za kukhulupirika kwanu? 
\q1  
\v 10 Imvani Yehova ndipo mundichitire chifundo; 
\q2 Yehova mukhale thandizo langa.” 
\b  
\q1  
\v 11 Inu munasandutsa kulira kwanga kukhala kuvina; 
\q2 munachotsa chiguduli changa ndi kundiveka ndi chimwemwe, 
\q1  
\v 12 kuti mtima wanga uthe kuyimbira Inu usakhale chete. 
\q2 Yehova Mulungu wanga, ndidzapereka kwa Inu mayamiko kwamuyaya. 
\c 31  
\cl Salimo 31 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Mwa Inu Yehova, ine ndimathawiramo; 
\q2 musalole nʼkomwe kuti ndichititsidwe manyazi; 
\q2 mundipulumutse chifukwa cha chilungamo chanu. 
\q1  
\v 2 Tcherani khutu lanu kwa ine, 
\q2 bwerani msanga kudzandilanditsa; 
\q1 mukhale thanthwe langa lothawirapo, 
\q2 linga lolimba kundipulumutsa ine. 
\q1  
\v 3 Popeza Inu ndinu thanthwe langa ndi linga langa, 
\q2 chifukwa cha dzina lanu tsogolereni ndi kundiwongolera. 
\q1  
\v 4 Ndimasuleni mu msampha umene anditchera 
\q2 pakuti ndinu pothawirapo panga. 
\q1  
\v 5 Mʼmanja mwanu ndipereka mzimu wanga; 
\q2 womboleni Yehova Mulungu wachoonadi. 
\b  
\q1  
\v 6 Koma ine ndimadana nawo amene amamamatira mafano achabechabe; 
\q2 ine ndimadalira Yehova. 
\q1  
\v 7 Ndidzakondwa ndi kusangalala mʼchikondi chanu 
\q2 popeza Inu munaona masautso anga 
\q2 ndipo mumadziwa kuwawa kwa moyo wanga. 
\q1  
\v 8 Inu simunandipereke kwa mdani 
\q2 koma mwayika mapazi anga pa malo otakasuka. 
\b  
\q1  
\v 9 Mundichitire chifundo Inu Yehova pakuti ndili pa mavuto; 
\q2 maso anga akulefuka ndi chisoni, 
\q2 mʼmoyo mwanga ndi mʼthupi mwanga momwe mukupweteka. 
\q1  
\v 10 Moyo wanga ukunyeka chifukwa cha kuwawidwa mtima 
\q2 ndi zaka zanga chifukwa cha kubuwula; 
\q1 mphamvu zanga zatha chifuwa cha masautso, 
\q2 ndipo mafupa anga akulefuka. 
\q1  
\v 11 Chifukwa cha adani anga onse, 
\q2 ndine wonyozeka kwambiri ndi anansi anga; 
\q1 ndine chochititsa manyazi kwa abwenzi anga. 
\q2 Iwo amene amandiona mu msewu amandithawa. 
\q1  
\v 12 Ine ndinayiwalika kwa iwo ngati kuti ndinamwalira; 
\q2 ndakhala ngati mʼphika wosweka. 
\q1  
\v 13 Pakuti ine ndamva zonena zoyipa za anthu ambiri; 
\q2 zoopsa zandizungulira mbali zonse; 
\q1 iwo akukonza chiwembu kuti alimbane nane, 
\q2 kuti atenge moyo wanga. 
\b  
\q1  
\v 14 Koma ndikudalira Inu Yehova; 
\q2 ndikunena kuti, “Ndinu Mulungu wanga.” 
\q1  
\v 15 Masiku anga ali mʼmanja mwanu; 
\q2 ndipulumutseni kwa adani anga 
\q2 ndi kwa iwo amene akundithamangitsa. 
\q1  
\v 16 Walitsani nkhope yanu pa mtumiki wanu; 
\q2 pulumutseni mwa chikondi chanu chosatha. 
\q1  
\v 17 Yehova musalole kuti ndichite manyazi, 
\q2 pakuti ndalirira kwa Inu; 
\q1 koma oyipa achititsidwe manyazi 
\q2 ndipo agone chete mʼmanda. 
\q1  
\v 18 Milomo yawo yabodzayo ikhale chete, 
\q2 pakuti chifukwa cha kunyada 
\q2 ayankhula modzikuza kutsutsana ndi wolungama. 
\b  
\q1  
\v 19 Ndi waukulu ubwino wanu 
\q2 umene mwawasungira amene amakuopani, 
\q1 umene mumapereka anthu akuona 
\q2 kwa iwo amene amathawira kwa Inu. 
\q1  
\v 20 Mu mthunzi wa pamalo popezeka panu muwabisa, 
\q2 kuwateteza ku ziwembu za anthu; 
\q1 mʼmalo anu okhalamo mumawateteza 
\q2 kwa anthu owatsutsa. 
\b  
\q1  
\v 21 Matamando akhale kwa Yehova, 
\q2 pakuti anaonetsa chikondi chake chodabwitsa kwa ine 
\q2 pamene ndinali mu mzinda wozingidwa. 
\q1  
\v 22 Ndili mʼnkhawa zanga ndinati, 
\q2 “Ine ndachotsedwa pamaso panu!” 
\q1 Komabe Inu munamva kupempha chifundo kwanga 
\q2 pamene ndinapempha thandizo kwa Inu. 
\b  
\q1  
\v 23 Kondani Yehova oyera mtima ake onse! 
\q2 Yehova amasunga wokhulupirika 
\q2 koma amalanga kwathunthu anthu odzikuza. 
\q1  
\v 24 Khalani ndi nyonga ndipo limbani mtima, 
\q2 inu nonse amene mumayembekezera Yehova. 
\c 32  
\cl Salimo 32 
\d Salimo la Davide. Malangizo. 
\q1  
\v 1 Ngodala munthu 
\q2 amene zolakwa zake zakhululukidwa; 
\q2 amene machimo ake aphimbidwa. 
\q1  
\v 2 Ngodala munthu 
\q2 amene machimo ake Yehova sawawerengeranso pa iye 
\q2 ndipo mu mzimu mwake mulibe chinyengo. 
\b  
\q1  
\v 3 Pamene ndinali chete, 
\q2 mafupa anga anakalamba 
\q2 chifukwa cha kubuwula kwanga tsiku lonse. 
\q1  
\v 4 Pakuti usana ndi usiku 
\q2 dzanja lanu linandipsinja; 
\q1 mphamvu zanga zinatha 
\q2 monga nthawi yotentha yachilimwe. 
\q4 \qs Sela\qs* 
\q1  
\v 5 Kotero ine ndinavomereza tchimo langa kwa Inu, 
\q2 sindinabise mphulupulu zanga. 
\q1 Ndinati, “Ine ndidzawulula 
\q2 zolakwa zanga kwa Yehova, 
\q1 ndipo Inu munandikhululukira 
\q2 mlandu wa machimo anga.” 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 6 Choncho aliyense okhulupirika apemphere kwa Inuyo 
\q2 pomwe mukupezeka; 
\q1 ndithu pamene madzi amphamvu auka, 
\q2 sadzamupeza. 
\q1  
\v 7 Inu ndi malo anga obisala; 
\q2 muzinditeteza ku mavuto ndipo muzindizinga 
\q2 ndi nyimbo zachipulumutso. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 8 Ndidzakulangiza ndi kukuphunzitsa njira imene udzayendamo; 
\q2 ndidzakupatsa uphungu ndi kukuyangʼanira. 
\q1  
\v 9 Usakhale ngati kavalo kapena bulu, 
\q2 zimene zilibe nzeru, 
\q1 koma ziyenera kuwongoleredwa ndi zitsulo za mʼkamwa ndi pamutu, 
\q2 ukapanda kutero sizibwera kwa iwe. 
\q1  
\v 10 Zowawa ndi zambiri za anthu oyipa 
\q2 koma chikondi chosatha cha Yehova 
\q2 chimamuzinga munthu amene amadalira Iye. 
\b  
\q1  
\v 11 Kondwerani mwa Yehova inu olungama; 
\q2 imbani, inu nonse amene muli owongoka mtima! 
\c 33  
\cl Salimo 33 
\q1  
\v 1 Imbirani Yehova mokondwera Inu olungama, 
\q2 nʼkoyenera kuti owongoka mtima azitamanda Iyeyo. 
\q1  
\v 2 Mutamandeni Yehova ndi pangwe; 
\q2 muyimbireni Iye nyimbo pa zeze wa zingwe khumi. 
\q1  
\v 3 Muyimbireni nyimbo yatsopano; 
\q2 imbani mwaluso, ndipo fuwulani mwachimwemwe. 
\b  
\q1  
\v 4 Pakuti mawu a Yehova ndi olungama ndi owona; 
\q2 Iye ndi wokhulupirika pa zonse zimene amachita. 
\q1  
\v 5 Yehova amakonda chilungamo ndipo amaweruza molungama; 
\q2 dziko lapansi ladzaza ndi chikondi chake chosatha. 
\b  
\q1  
\v 6 Ndi mawu a Yehova mayiko akumwamba anapangidwa, 
\q2 zolengedwa zake ndi mpweya wa mʼkamwa mwake. 
\q1  
\v 7 Iye amasonkhanitsa pamodzi madzi a mʼnyanja mʼmitsuko; 
\q2 amayika zozama mʼnyumba zosungiramo. 
\q1  
\v 8 Dziko lonse lapansi liope Yehova; 
\q2 anthu onse amulemekeze Iye. 
\q1  
\v 9 Pakuti Iye anayankhula ndipo zinakhalapo; 
\q2 Iye analamulira ndipo zinakhazikika. 
\q1  
\v 10 Yehova amalepheretsa chikonzero cha anthu a mitundu ina; 
\q2 Iye amaphwanya zolinga za anthu ambiri. 
\q1  
\v 11 Koma chikonzero cha Yehova chimakhala mpaka muyaya, 
\q2 zolinga za mu mtima mwake pa mibado yonse. 
\b  
\q1  
\v 12 Wodala mtundu wa anthu umene Mulungu wake ndi Yehova, 
\q2 anthu amene Iye anawasankha kukhala cholowa chake. 
\q1  
\v 13 Kuchokera kumwamba Yehova amayangʼana pansi 
\q2 ndi kuona anthu onse; 
\q1  
\v 14 kuchokera ku malo ake okhalako Iye amayangʼanira 
\q2 onse amene amakhala pa dziko lapansi. 
\q1  
\v 15 Iye amene amapanga mitima ya onse, 
\q2 amaona zonse zimene akuchita. 
\q1  
\v 16 Palibe mfumu imene imapulumutsidwa chifukwa cha kukula kwa gulu lake lankhondo; 
\q2 palibe msilikali amene amathawa ndi mphamvu zake zazikulu. 
\q1  
\v 17 Kavalo ndi chiyembekezo cha chabechabe cha chipulumutso, 
\q2 ngakhale ali ndi mphamvu yayikulu sangathe kupulumutsa. 
\q1  
\v 18 Koma maso a Yehova ali pa iwo amene amaopa Iye; 
\q2 amene chiyembekezo chawo chili mʼchikondi chake chosatha, 
\q1  
\v 19 kuwawombola iwo ku imfa 
\q2 ndi kuwasunga ndi moyo nthawi ya njala. 
\b  
\q1  
\v 20 Ife timadikira kwa Yehova mwachiyembekezo; 
\q2 Iye ndiye thandizo lathu ndi chishango chathu. 
\q1  
\v 21 Mwa Iye mitima yathu imakondwera, 
\q2 pakuti ife timadalira dzina lake loyera. 
\q1  
\v 22 Chikondi chanu chosatha 
\q2 chikhale pa ife Inu Yehova, pamene tikuyembekeza kwa Inu. 
\c 34  
\cl Salimo 34 
\d Salimo la Davide. Pamene iye ananyengezera misala pamaso pa Abimeleki, amene anamupirikitsa, iyeyo nʼkuchoka. 
\q1  
\v 1 Ndidzayamika Yehova nthawi zonse; 
\q2 matamando ake adzakhala pa milomo yanga nthawi zonse. 
\q1  
\v 2 Moyo wanga udzanyadira Yehova; 
\q2 anthu osautsidwa amve ndi kukondwera. 
\q1  
\v 3 Lemekezani Yehova pamodzi ndi ine; 
\q2 tiyeni pamodzi tikuze dzina lake. 
\b  
\q1  
\v 4 Ine ndinafunafuna Yehova ndipo Iye anandiyankha; 
\q2 anandilanditsa ku mantha anga onse. 
\q1  
\v 5 Iwo amene amayangʼana kwa Iye, nkhope zawo zimanyezimira; 
\q2 nkhope zawo sizikhala zophimbidwa ndi manyazi. 
\q1  
\v 6 Munthu wosauka uno anayitana, ndipo Yehova anamumva; 
\q2 Yehova anamupulumutsa ku mavuto ake onse. 
\q1  
\v 7 Mngelo wa Yehova amatchinjiriza amene amakonda Iye 
\q2 ndi kuwalanditsa. 
\b  
\q1  
\v 8 Lawani ndipo onani kuti Yehova ndi wabwino; 
\q2 wodala munthu amene amathawira kwa Iye. 
\q1  
\v 9 Wopani Yehova inu oyera mtima ake, 
\q2 pakuti iwo amene amaopa Iye sasowa kanthu. 
\q1  
\v 10 Mikango itha kulefuka ndi kumva njala 
\q2 koma iwo amene amafunafuna Yehova sasowa kanthu kalikonse kabwino. 
\b  
\q1  
\v 11 Bwerani ana anga, mundimvere; 
\q2 ndidzakuphunzitsani kuopa Yehova. 
\q1  
\v 12 Aliyense wa inu amene amakonda moyo wake 
\q2 ndi kukhumba kuti aone masiku abwino ambiri, 
\q1  
\v 13 asunge lilime lake ku zoyipa 
\q2 ndi milomo yake kuti isayankhule zonama. 
\q1  
\v 14 Tembenuka kuchoka ku zoyipa ndipo chita zabwino; 
\q2 funafuna mtendere ndi kuwulondola. 
\b  
\q1  
\v 15 Maso a Yehova ali pa olungama 
\q2 ndipo makutu ake ali tcheru kumva kulira kwawo; 
\q1  
\v 16 nkhope ya Yehova ikutsutsana ndi amene amachita zoyipa, 
\q2 kuwachotsa kuti asawakumbukirenso pa dziko lapansi. 
\b  
\q1  
\v 17 Olungama amafuwula, ndipo Yehova amawamva; 
\q2 Iye amawalanditsa ku mavuto awo onse. 
\q1  
\v 18 Yehova ali pafupi kwa osweka mtima 
\q2 ndipo amapulumutsa iwo amene asweka mu mzimu. 
\b  
\q1  
\v 19 Munthu wolungama atha kukhala ndi mavuto ambiri, 
\q2 Koma Yehova amamulanditsa ku mavuto onsewo, 
\q1  
\v 20 Iye amateteza mafupa ake onse, 
\q2 palibe limodzi la mafupawo limene lidzathyoledwa. 
\b  
\q1  
\v 21 Choyipa chidzapha anthu oyipa; 
\q2 adani a olungama adzapezeka olakwa. 
\q1  
\v 22 Yehova amawombola atumiki ake; 
\q2 aliyense amene amathawira kwa Iye sadzapezeka wolakwa. 
\c 35  
\cl Salimo 35 
\d Salimo la Davide. 
\q1  
\v 1 Inu Yehova, mulimbane nawo amene akulimbana nane; 
\q2 mumenyane nawo amene akumenyana nane. 
\q1  
\v 2 Tengani chishango ndi lihawo; 
\q2 dzukani ndipo bwerani mundithandize. 
\q1  
\v 3 Tengani mkondo ndi nthungo, 
\q2 kulimbana ndi iwo amene akundithamangitsa. 
\q1 Uzani moyo wanga kuti, 
\q2 “Ine ndine chipulumutso chako.” 
\b  
\q1  
\v 4 Iwo amene akufunafuna moyo wanga 
\q2 anyozedwe ndi kuchita manyazi; 
\q1 iwo amene akukonza kuti moyo wanga uwonongeke 
\q2 abwerere mʼmbuyo mochititsa mantha. 
\q1  
\v 5 Akhale ngati mankhusu owuluka ndi mphepo 
\q2 pamene mngelo wa Yehova akuwapirikitsa. 
\q1  
\v 6 Njira yawo ikhale ya mdima ndi yoterera 
\q2 pamene mngelo wa Yehova akuwathamangitsa. 
\q1  
\v 7 Popeza ananditchera ukonde popanda chifukwa 
\q2 ndipo popanda chifukwa andikumbira dzenje, 
\q1  
\v 8 chiwonongeko chiwapeza modzidzimutsa 
\q2 ukonde umene iwo abisa uwakole, 
\q2 agwere mʼdzenje kuti awonongedwe. 
\q1  
\v 9 Pamenepo moyo wanga udzakondwera mwa Yehova 
\q2 ndi kusangalala ndi chipulumutso chake. 
\q1  
\v 10 Thupi langa lidzafuwula mokondwera, 
\q2 “Ndani angafanane nanu Yehova? 
\q1 Mumalanditsa osauka kwa amene ali ndi mphamvu zambiri, 
\q2 osauka ndi osowa kwa iwo amene amawalanda.” 
\b  
\q1  
\v 11 Mboni zopanda chisoni zinayimirira, 
\q2 zinandifunsa zinthu zimene sindikuzidziwa. 
\q1  
\v 12 Iwo anandibwezera zoyipa pa zabwino 
\q2 ndipo anasiya moyo wanga pa chisoni. 
\q1  
\v 13 Koma pamene iwo ankadwala, ine ndinavala chiguduli 
\q2 ndi kudzichepetsa ndekha posala zakudya. 
\q1 Pamene mapemphero anga anabwerera kwa ine osayankhidwa, 
\q2  
\v 14 ndinayendayenda ndi kulira maliro, 
\q2 kumulira ngati bwenzi langa kapena mʼbale wanga. 
\q1 Ndinaweramitsa mutu wanga mosweka mtima 
\q2 kukhala ngati ndikulira amayi anga. 
\q1  
\v 15 Koma pamene ndinaphunthwa, iwo anasonkhana mosangalala; 
\q2 ondithira nkhondo anasonkhana kutsutsana nane, ineyo osadziwa. 
\q2 Iwo sanasiye kundiyankhulira mawu onyoza. 
\q1  
\v 16 Monga anthu osapembedza, iwo anandinyoza mwachipongwe; 
\q2 anandikukutira mano awo. 
\q1  
\v 17 Ambuye, mpaka liti mudzakhala mukungoyangʼana? 
\q2 Landitsani moyo wanga ku chiwonongeko chawo, 
\q2 moyo wanga wopambana ku mikango. 
\q1  
\v 18 Ndidzakuyamikani mu msonkhano waukulu; 
\q2 pakati pa gulu lalikulu la anthu ndidzakutamandani. 
\b  
\q1  
\v 19 Musalole adani anga onyenga 
\q2 akondwere chifukwa cha masautso anga; 
\q1 musalole kuti amene amadana nane popanda chifukwa 
\q2 andiyangʼane chamʼmbali mondinyoza. 
\q1  
\v 20 Iwowo sayankhula mwamtendere, 
\q2 koma amaganizira zonamizira 
\q2 iwo amene amakhala mwabata mʼdziko. 
\q1  
\v 21 Iwo amandiseka mofuwula ndipo amati, “Haa! Haa! 
\q2 Ndipo ndi maso athuwa ife taziona.” 
\b  
\q1  
\v 22 Yehova mwaona zimenezi; musakhale chete. 
\q2 Ambuye musakhale kutali ndi ine. 
\q1  
\v 23 Dzukani, ndipo nyamukani kunditeteza! 
\q2 Mulimbane nawo chifukwa cha ine, Mulungu wanga ndi Ambuye anga. 
\q1  
\v 24 Onetsani kusalakwa kwanga mwa chilungamo chanu, Inu Yehova Mulungu wanga. 
\q2 Musalole kuti akondwere chifukwa cha mavuto anga. 
\q1  
\v 25 Musalole kuti aganize kuti, “Amati atani, zachitika monga momwe timafunira!” 
\q2 Kapena kunena kuti, “Tamutha ameneyu basi.” 
\b  
\q1  
\v 26 Onse amene amakondwera ndi masautso anga 
\q2 achite manyazi ndi kusokonezeka. 
\q1 Onse amene amadzikweza kufuna kundipambana, 
\q2 avekedwe manyazi ndi mnyozo ngati zovala. 
\q1  
\v 27 Koma amene amakondwera chifukwa chakuti ndine wosalakwa, 
\q2 afuwule mwachimwemwe ndi chisangalalo. 
\q1 Nthawi zonse azinena kuti, “Yehova akwezeke, 
\q2 Iye amene amakondwera ndi kupeza bwino kwa mtumiki wake.” 
\q1  
\v 28 Pakamwa panga padzayankhula za chilungamo chanu 
\q2 ndi za matamando anu tsiku lonse. 
\c 36  
\cl Salimo 36 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide, mtumiki wa Yehova. 
\q1  
\v 1 Uthenga uli mu mtima mwanga 
\q2 wonena za kuchimwa kwa munthu woyipa: 
\q1 Mu mtima mwake 
\q2 mulibe kuopa Mulungu. 
\q1  
\v 2 Pakuti iye mʼkuona kwake amadzinyenga yekha kwambiri, 
\q2 sazindikira kapena kudana ndi tchimo lake. 
\q1  
\v 3 Mawu a pakamwa pake ndi oyipa ndi achinyengo; 
\q2 iyeyo waleka kukhala wanzeru ndi kuchita zabwino. 
\q1  
\v 4 Ngakhale ali pa bedi pake amakonzekera zoyipa; 
\q2 iye amadzipereka yekha ku njira ya uchimo 
\q2 ndipo sakana cholakwa chilichonse. 
\b  
\q1  
\v 5 Chikondi chanu Yehova, chimafika ku mayiko a kumwamba, 
\q2 kukhulupirika kwanu mpaka ku mitambo. 
\q1  
\v 6 Chilungamo chanu Mulungu chili ngati mapiri aakulu, 
\q2 chiweruzo chanu chili ngati kuzama kwakukulu. 
\q1 Yehova mumasunga munthu pamodzi ndi chinyama. 
\q2  
\v 7 Chikondi chanu chosatha ndi chamtengowapatali! 
\q1 Otchuka pamodzi ndi anthu wamba pakati pa anthu 
\q2 amapeza pothawirapo mu mthunzi wa mapiko anu. 
\q1  
\v 8 Iwo amadyerera zinthu zambiri za mʼnyumba yanu; 
\q2 Inu mumawapatsa chakumwa kuchokera mu mtsinje wanu wachikondwerero. 
\q1  
\v 9 Pakuti kwa Inu kuli kasupe wamoyo; 
\q2 mʼkuwala kwanu ifenso timaona kuwala. 
\b  
\q1  
\v 10 Pitirizani chikondi chanu pa iwo amene amakudziwani, 
\q2 chilungamo chanu kwa olungama mtima. 
\q1  
\v 11 Musalole kuti phazi la wodzikuza libwere kulimbana nane, 
\q2 kapena dzanja la oyipa kundithamangitsa. 
\q1  
\v 12 Onani momwe ochita zoyipa agonera atagwa, 
\q2 aponyeni pansi, kuti asathe kudzukanso! 
\c 37  
\cl Salimo 37 
\d Salimo la Davide. 
\q1  
\v 1 Usamavutike chifukwa cha anthu oyipa 
\q2 kapena kuchitira nsanje amene akuchita cholakwa; 
\q1  
\v 2 pakuti monga udzu iwo adzafota msanga, 
\q2 ngati mbewu zobiriwira adzanyala msanga. 
\b  
\q1  
\v 3 Khulupirira Yehova ndipo uzichita zabwino; 
\q2 khazikika mʼdziko ndi kutsata zokhulupirika. 
\q1  
\v 4 Udzikondweretse wekha mwa Yehova 
\q2 ndipo Iye adzakupatsa zokhumba za mtima wako. 
\b  
\q1  
\v 5 Pereka njira yako kwa Yehova; 
\q2 dalira Iye ndipo Iyeyo adzachita izi: 
\q1  
\v 6 Iye adzachititsa chilungamo chako kuwala ngati mʼbandakucha, 
\q2 chiweruzo chako ngati dzuwa la masana. 
\b  
\q1  
\v 7 Khala chete pamaso pa Yehova ndipo umudikire mofatsa; 
\q2 usavutike pamene anthu apambana mʼnjira zawo, 
\q2 pamene iwo achita zinthu zawo zoyipa. 
\b  
\q1  
\v 8 Pewa kupsa mtima ndipo tembenuka kuchoka ku ukali, 
\q2 usavutike chifukwa zimenezi zimatsogolera ku zoyipa. 
\q1  
\v 9 Pakuti anthu oyipa adzachotsedwa, 
\q2 koma iwo amene amayembekeza mwa Yehova adzalandira dziko. 
\b  
\q1  
\v 10 Kwa kanthawi oyipa sadzapezekanso; 
\q2 ngakhale muwafunefune, sadzapezekanso. 
\q1  
\v 11 Koma ofatsa adzalandira dziko 
\q2 ndipo adzasangalala ndi mtendere waukulu. 
\b  
\q1  
\v 12 Oyipa amakonza chiwembu kutsutsana ndi olungama 
\q2 ndipo amawakukutira mano; 
\q1  
\v 13 koma Ambuye amaseka oyipa 
\q2 pakuti Iye amadziwa kuti tsiku lawo likubwera. 
\b  
\q1  
\v 14 Oyipa amasolola lupanga 
\q2 ndi kupinda uta 
\q1 kugwetsa osauka ndi osowa, 
\q2 kupha iwo amene njira zawo ndi zolungama. 
\q1  
\v 15 Koma malupanga awo analasa mitima yawo yomwe, 
\q2 ndipo mauta awo anathyoka. 
\b  
\q1  
\v 16 Zabwino zochepa zimene olungama ali nazo 
\q2 ziposa chuma cha anthu oyipa ambiri; 
\q1  
\v 17 pakuti mphamvu ya oyipa idzasweka, 
\q2 koma Yehova amasunga olungama. 
\b  
\q1  
\v 18 Masiku a anthu osalakwa amadziwika ndi Yehova, 
\q2 ndipo cholowa chawo chidzakhala mpaka muyaya. 
\q1  
\v 19 Pa nthawi ya mavuto iwo sadzafota; 
\q2 mʼmasiku a njala adzakhala ndi zinthu zambiri. 
\b  
\q1  
\v 20 Koma oyipa adzawonongeka; 
\q2 adani a Yehova adzakhala ngati kukongola kwa kuthengo, 
\q2 iwo adzazimirira ngati utsi. 
\b  
\q1  
\v 21 Oyipa amabwereka ndipo sabweza 
\q2 koma olungama amapereka mowolowamanja. 
\q1  
\v 22 Iwo amene Yehova amawadalitsa adzalandira dziko, 
\q2 koma amene Iye amawatemberera adzachotsedwa. 
\b  
\q1  
\v 23 Ngati Yehova akondwera ndi njira ya munthu, 
\q2 amakhazikitsa mayendedwe ake; 
\q1  
\v 24 ngakhale atapunthwa sadzagwa, 
\q2 pakuti Yehova amamutchinjiriza ndi dzanja lake. 
\b  
\q1  
\v 25 Ine ndinali wamngʼono ndipo tsopano ndakalamba 
\q2 koma sindinaonepo olungama akusiyidwa 
\q2 kapena ana awo akupempha chakudya. 
\q1  
\v 26 Iwo ndi owolowamanja nthawi zonse ndipo amabwereketsa mwaufulu; 
\q2 ana awo adzadalitsika. 
\b  
\q1  
\v 27 Tembenuka kuchoka ku zoyipa ndipo chita zabwino; 
\q2 pamenepo udzakhazikika mʼdziko kwamuyaya. 
\q1  
\v 28 Pakuti Yehova amakonda wolungama 
\q2 ndipo sadzasiya okhulupirika ake. 
\b  
\q1 Iwo adzatetezedwa kwamuyaya, 
\q2 koma zidzukulu za oyipa zidzachotsedwa; 
\q1  
\v 29 olungama adzalandira dziko 
\q2 ndipo adzakhazikikamo kwamuyaya. 
\b  
\q1  
\v 30 Pakamwa pa munthu wolungama pamayankhula za nzeru, 
\q2 ndipo lilime lake limayankhula zolungama. 
\q1  
\v 31 Lamulo la Mulungu wake lili mu mtima mwake; 
\q2 mapazi ake saterereka. 
\b  
\q1  
\v 32 Oyipa amabisala kudikira olungama; 
\q2 kufunafuna miyoyo yawoyo; 
\q1  
\v 33 koma Yehova sadzawasiya pansi pa mphamvu yawo 
\q2 kapena kuti atsutsidwe pamene abweretsedwa pa milandu. 
\b  
\q1  
\v 34 Khulupirira Yehova, 
\q2 ndipo sunga njira yake; 
\q1 Iye adzakukweza ndipo udzalandira dziko kuti likhale lako; 
\q2 udzaona anthu oyipa akuwonongeka. 
\b  
\q1  
\v 35 Ine ndinaona munthu woyipa ndi munthu wopanda chifundo 
\q2 akupeza bwino ngati mtengo wobiriwira pa nthaka ya makolo ake. 
\q1  
\v 36 Koma sanachedwe kumwalira ndipo sanaonekenso; 
\q2 ngakhale ndinamuyangʼanayangʼana, sanapezekenso. 
\b  
\q1  
\v 37 Ganizira za munthu wosalakwa, yangʼanitsitsa munthu wolungama; 
\q2 udzaona kuti ali ndi tsogolo labwino ndipo ali ndi zidzukulu zambiri. 
\q1  
\v 38 Koma anthu ochimwa adzawonongeka; 
\q2 iwowo pamodzi ndi zidzukulu zawo zomwe. 
\b  
\q1  
\v 39 Chipulumutso cha olungama chimachokera kwa Yehova; 
\q2 Iye ndiye linga lawo pa nthawi ya masautso. 
\q1  
\v 40 Yehova amawathandiza ndi kuwalanditsa; 
\q2 Iye amawalanditsa kwa oyipa ndi kuwapulumutsa, 
\q2 pakuti amathawira kwa Iye. 
\c 38  
\cl Salimo 38 
\d Salimo la Davide. Kupempha. 
\q1  
\v 1 Yehova musandidzudzule mutapsa mtima 
\q2 kapena kundilanga muli ndi ukali. 
\q1  
\v 2 Pakuti mivi yanu yandilasa, 
\q2 ndipo dzanja lanu latsika ndipo landifikira. 
\q1  
\v 3 Chifukwa cha ukali wanu mulibe thanzi mʼthupi langa; 
\q2 mafupa anga alibe mphamvu chifukwa cha tchimo langa. 
\q1  
\v 4 Kulakwa kwanga kwandipsinja 
\q2 ngati katundu wolemera kwambiri kuposa mphamvu zanga. 
\b  
\q1  
\v 5 Mabala anga akuwola ndipo akununkha 
\q2 chifukwa cha uchitsiru wa moyo wanga wauchimo. 
\q1  
\v 6 Ine ndapindika msana ndipo ndawerama kwambiri; 
\q2 tsiku lonse ndimangolira. 
\q1  
\v 7 Msana wanga wagwidwa ndi ululu wosasimbika, 
\q2 mulibe thanzi mʼthupi langa. 
\q1  
\v 8 Ndilibe mphamvu ndipo ndakunthidwa kwathunthu; 
\q2 ndikubuwula ndi ululu wa mumtima. 
\b  
\q1  
\v 9 Zokhumba zanga zonse zili poonekera pamaso panu Ambuye, 
\q2 kusisima kwanga sikunabisike kwa Inu. 
\q1  
\v 10 Mtima wanga ukugunda, mphamvu zanga zikutha; 
\q2 ngakhale kuwala kwachoka mʼmaso mwanga. 
\q1  
\v 11 Abwenzi anga ndi anzanga akundipewa chifukwa cha mabala anga; 
\q2 anansi anga akhala kutali nane. 
\q1  
\v 12 Iwo amene akufunafuna moyo wanga atchera misampha yawo, 
\q2 oti andipwetekewo amayankhula za kuwonongeka kwanga; 
\q2 tsiku lonse amakonza zachinyengo. 
\b  
\q1  
\v 13 Ine ndili ngati munthu wosamva amene sangamve, 
\q2 monga wosayankhula, amene sangathe kutsekula pakamwa pake; 
\q1  
\v 14 Ndakhala ngati munthu amene samva, 
\q2 amene pakamwa pake sipangathe kuyankha. 
\q1  
\v 15 Ndikudikira Inu Yehova; 
\q2 mudzayankha, Inu Ambuye Mulungu wanga. 
\q1  
\v 16 Pakuti Ine ndinati, “Musawalole kuti akondwere 
\q2 kapena kudzikweza okha pa ine pamene phazi langa laterereka.” 
\b  
\q1  
\v 17 Pakuti ndili pafupi kugwa, 
\q2 ndipo ndikumva kuwawa nthawi zonse. 
\q1  
\v 18 Ndikuvomereza mphulupulu zanga; 
\q2 ndipo ndavutika ndi tchimo langa. 
\q1  
\v 19 Ambiri ndi adani anga amphamvu; 
\q2 amene amandida popanda chifukwa alipo ochuluka kwambiri. 
\q1  
\v 20 Iwo amene amandibwezera zoyipa mʼmalo mwa zabwino 
\q2 amandinyoza pamene nditsatira zabwino. 
\b  
\q1  
\v 21 Inu Yehova, musanditaye; 
\q2 musakhale kutali ndi ine Mulungu wanga. 
\q1  
\v 22 Bwerani msanga kudzandithandiza, 
\q2 Inu Ambuye Mpulumutsi wanga. 
\c 39  
\cl Salimo 39 
\d Kwa mtsogoleri wa mayimbidwe. Kwa Yedutuni. Salimo la Davide. 
\q1  
\v 1 Ndinati, “Ndidzasamalira njira zanga 
\q2 ndipo ndidzasunga lilime langa kuti ndisachimwe; 
\q1 ndidzatseka pakamwa panga ndi chitsekerero 
\q2 nthawi yonse imene woyipa ali pamaso panga.” 
\q1  
\v 2 Koma pamene ndinali chete 
\q2 osanena ngakhale kanthu kalikonse kabwino 
\q2 mavuto anga anachulukirabe. 
\q1  
\v 3 Mtima wanga unatentha mʼkati mwanga, 
\q2 ndipo pamene ndinkalingalira, moto unayaka; 
\q2 kenaka ndinayankhula ndi lilime langa: 
\b  
\q1  
\v 4 “Yehova ndionetseni mathero a moyo wanga 
\q2 ndi chiwerengero cha masiku anga; 
\q2 mundidziwitse kuti moyo wanga ndi wosakhalitsa motani. 
\q1  
\v 5 Inu mwachititsa kuti masiku anga akhale ochepa kwambiri, 
\q2 kutalika kwa zaka zanga ndi kopanda phindu pamaso panu; 
\q2 moyo wa munthu aliyense ndi waufupi. 
\q4 \qs Sela\qs* 
\q1  
\v 6 Munthu ali ngati chithunzithunzi chake pamene akuyenda uku ndi uku: 
\q2 Iye amangovutika koma popanda phindu; 
\q2 amadzikundikira chuma, osadziwa kuti chidzakhala chayani. 
\b  
\q1  
\v 7 “Koma tsopano Ambuye kodi ndifunanso chiyani? 
\q2 Chiyembekezo changa chili mwa Inu. 
\q1  
\v 8 Pulumutseni ku zolakwa zanga zonse; 
\q2 musandisandutse chonyozeka kwa opusa. 
\q1  
\v 9 Ine ndinali chete; sindinatsekule pakamwa panga 
\q2 pakuti Inu ndinu amene mwachita zimenezi. 
\q1  
\v 10 Chotsani mkwapulo wanu pa ine; 
\q2 ndagonjetsedwa ndi nkhonya ya dzanja lanu. 
\q1  
\v 11 Inu mumadzudzula ndi kulanga anthu chifukwa cha tchimo lawo; 
\q2 mumawononga chuma chawo monga njenjete; 
\q2 munthu aliyense ali ngati mpweya. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 12 “Imvani pemphero langa Inu Yehova, 
\q2 mverani kulira kwanga kopempha thandizo; 
\q2 musakhale chete pamene ndikulirira kwa Inu, 
\q1 popeza ndine mlendo wanu wosakhalitsa; 
\q2 monga anachitira makolo anga onse. 
\q1  
\v 13 Musandiyangʼane mwaukali, choncho ndidzatha kusangalala 
\q2 ndisanafe ndi kuyiwalika.” 
\c 40  
\cl Salimo 40 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Mofatsa ndinadikira Yehova 
\q2 Iye anatembenukira kwa ine ndipo anamva kulira kwanga. 
\q1  
\v 2 Ananditulutsa mʼdzenje lachitayiko, 
\q2 mʼthope ndi mʼchithaphwi; 
\q1 Iye anakhazikitsa mapazi anga pa thanthwe 
\q2 ndipo anandipatsa malo oyimapo olimba. 
\q1  
\v 3 Iye anayika nyimbo yatsopano mʼkamwa mwanga, 
\q2 nyimbo yamatamando kwa Mulungu wanga. 
\q1 Ambiri adzaona, 
\q2 nadzaopa ndipo adzakhulupirira Yehova. 
\b  
\q1  
\v 4 Ndi wodala munthu 
\q2 amakhulupirira Yehova; 
\q1 amene sayembekezera kwa odzikuza, 
\q2 kapena kwa amene amatembenukira kwa milungu yabodza. 
\q1  
\v 5 Zambiri, Yehova Mulungu wanga, 
\q2 ndi zodabwitsa zimene Inu mwachita. 
\q1 Zinthu zimene munazikonzera ife 
\q2 palibe amene angathe kukuwerengerani. 
\q1 Nditati ndiyankhule ndi kufotokozera, 
\q2 zidzakhala zambiri kuzifotokoza. 
\b  
\q1  
\v 6 Nsembe ndi zopereka Inu simuzifuna, 
\q2 koma makutu anga mwawatsekula; 
\q1 zopereka zopsereza ndi zopereka chifukwa cha tchimo 
\q2 Inu simunazipemphe. 
\q1  
\v 7 Kotero ndinati, “Ndili pano, ndabwera. 
\q2 Mʼbuku mwalembedwa za ine. 
\q1  
\v 8 Ndikufuna kuchita chifuniro chanu, Inu Mulungu wanga; 
\q2 lamulo lanu lili mu mtima mwanga.” 
\b  
\q1  
\v 9 Ndikulalikira uthenga wa chilungamo chanu mu msonkhano waukulu; 
\q2 sinditseka milomo yanga 
\q2 monga mukudziwa Inu Yehova. 
\q1  
\v 10 Sindibisa chilungamo chanu mu mtima mwanga; 
\q2 ndinayankhula za kukhulupirika kwanu ndi chipulumutso chanu. 
\q1 Ine sindiphimba chikondi chanu ndi choonadi chanu 
\q2 pa msonkhano waukulu. 
\b  
\q1  
\v 11 Musandichotsere chifundo chanu Yehova; 
\q2 chikondi chanu ndi choonadi chanu zinditeteze nthawi zonse. 
\q1  
\v 12 Pakuti mavuto osawerengeka andizungulira; 
\q2 machimo anga andigonjetsa, ndipo sindingathe kuona. 
\q1 Alipo ambiri kuposa tsitsi la mʼmutu mwanga, 
\q2 ndipo mtima wanga ukufowoka mʼkati mwanga. 
\b  
\q1  
\v 13 Pulumutseni Yehova; 
\q2 Bwerani msanga Yehova kudzandithandiza. 
\q1  
\v 14 Onse amene akufunafuna kuchotsa moyo wanga 
\q2 achititsidwe manyazi ndi kusokonezedwa; 
\q1 onse amene amakhumba chiwonongeko changa 
\q2 abwezedwe mwamanyazi. 
\q1  
\v 15 Iwo amene amanena kwa ine kuti, “Hee! Hee!” 
\q2 abwerere akuchita manyazi. 
\q1  
\v 16 Koma iwo amene amafunafuna Inu 
\q2 akondwere ndi kusangalala mwa Inu; 
\q1 iwo amene amakonda chipulumutso chanu 
\q2 nthawi zonse anene kuti, “Yehova akwezeke!” 
\b  
\q1  
\v 17 Komabe Ine ndine wosauka ndi wosowa; 
\q2 Ambuye andiganizire. 
\q1 Inu ndinu thandizo langa ndi wondiwombola wanga; 
\q2 Inu Mulungu wanga, musachedwe. 
\c 41  
\cl Salimo 41 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Wodala ndi munthu amene amaganizira anthu osauka; 
\q2 Yehova amamuwombola pa nthawi yamsautso. 
\q1  
\v 2 Yehova adzamuteteza ndi kusunga moyo wake; 
\q2 Yehova adzamudalitsa iye mʼdziko 
\q2 ndipo sadzamupereka ku zofuna za adani ake. 
\q1  
\v 3 Yehova adzamuthandiza pamene akudwala 
\q2 ndipo adzamuchiritsa pa bedi lake la matenda. 
\b  
\q1  
\v 4 Ndinati, “Inu Yehova, mundichitire chifundo; 
\q2 chiritseni pakuti ndakuchimwirani.” 
\q1  
\v 5 Adani anga mwankhwidzi amanena za ine kuti, 
\q2 “Kodi munthu ameneyu adzafa liti kuti ayiwalike?” 
\q1  
\v 6 Pamene wina abwera kudzandiona, 
\q2 amayankhula mwachinyengo, pomwe mtima wake ukusonkhanitsa zachipongwe; 
\q2 kenaka iye amatuluka ndi kukalengeza kunja. 
\b  
\q1  
\v 7 Adani anga onse amanongʼonezana pamodzi kulimbana nane, 
\q2 iwo amalingalira zoyipa kwambiri za ine, ponena kuti, 
\q1  
\v 8 “Matenda owopsa amugwira; 
\q2 sadzaukapo pamalo pamene wagona.” 
\q1  
\v 9 Ngakhale bwenzi langa la pamtima amene ndinamudalira, 
\q2 iye amene amadya pamodzi ndi ine 
\q2 watukula chidendene chake kulimbana nane. 
\b  
\q1  
\v 10 Koma Yehova mundichititre chifundo, 
\q2 dzutseni kuti ndiwabwezere. 
\q1  
\v 11 Ine ndikudziwa kuti mukukondwera nane, 
\q2 pakuti mdani wanga sandigonjetsa. 
\q1  
\v 12 Mu ungwiro wanga Inu mumandisunga 
\q2 ndi kundiyimika pamaso panu kwamuyaya. 
\b  
\q1  
\v 13 Atamandike Yehova Mulungu wa Israeli 
\q2 kuchokera muyaya mpaka muyaya. 
\q4 Ameni ndi Ameni. 
\c 42  
\ms1 BUKU LACHIWIRI 
\mr Masalimo 42–72 
\cl Salimo 42 
\d Kwa mtsogoleri wa mayimbidwe. Ndakatulo ya ana a Kora. 
\q1  
\v 1 Monga mbawala ipuma wefuwefu kufunafuna mitsinje yamadzi, 
\q2 kotero moyo wanga upuma wefuwefu kufunafuna Inu Mulungu. 
\q1  
\v 2 Moyo wanga uli ndi ludzu lofuna Mulungu, lofuna Mulungu wamoyo. 
\q2 Kodi ndipite liti kukakumana ndi Mulungu? 
\q1  
\v 3 Misozi yanga yakhala chakudya changa 
\q2 usana ndi usiku, 
\q1 pamene anthu akunena kwa ine tsiku lonse kuti, 
\q2 “Mulungu wako ali kuti?” 
\q1  
\v 4 Zinthu izi ndimazikumbukira 
\q2 pamene ndikukhuthula moyo wanga: 
\q1 momwe ndinkapitira ndi gulu lalikulu, 
\q2 kutsogolera mayendedwe a ku Nyumba ya Mulungu 
\q1 ndi mfuwu yachimwemwe ndi mayamiko 
\q2 pakati pa anthu a pa chikondwerero. 
\b  
\q1  
\v 5 Nʼchifukwa chiyani uli ndi chisoni, iwe moyo wanga? 
\q2 Nʼchifukwa chiyani wakhumudwa iwe mʼkati mwanga? 
\q1 Yembekezera Mulungu, 
\q2 pakuti ndidzamulambirabe, 
\q2 Mpulumutsi wanga ndi  
\v 6 Mulungu wanga. 
\b  
\q1 Moyo wanga uli ndi chisoni mʼkati mwanga 
\q2 kotero ndidzakumbukira Inu 
\q1 kuchokera ku dziko la Yorodani, 
\q2 ku mitunda ya Herimoni kuchokera ku phiri la Mizara. 
\q1  
\v 7 Madzi akuya akuyitana madzi akuya 
\q2 mu mkokomo wa mathithi anu; 
\q1 mafunde anu onse obwera mwamphamvu 
\q2 andimiza. 
\b  
\q1  
\v 8 Koma usana Yehova amalamulira chikondi chake, 
\q2 nthawi ya usiku nyimbo yake ili nane; 
\q2 pemphero kwa Mulungu wa moyo wanga. 
\b  
\q1  
\v 9 Ine ndikuti kwa Mulungu Thanthwe langa, 
\q2 “Nʼchifukwa chiyani mwandiyiwala? 
\q1 Nʼchifukwa chiyani ndiyenera kuyenda ndikulira, 
\q2 woponderezedwa ndi mdani?” 
\q1  
\v 10 Mafupa anga ali ndi ululu wakufa nawo 
\q2 pamene adani anga akundinyoza, 
\q1 tsiku lonse akunena kuti, 
\q2 “Mulungu wako ali kuti?” 
\b  
\q1  
\v 11 Bwanji ukumva chisoni, 
\q2 iwe mtima wanga? 
\q1 Chifukwa chiyani ukuvutika chonchi mʼkati mwanga? 
\q2 Khulupirira Mulungu, pakuti ndidzamutamandanso, 
\q2 Iye amene ali thandizo langa ndi Mulungu wanga. 
\c 43  
\cl Salimo 43 
\q1  
\v 1 Onetsani kusalakwa kwanga Inu Mulungu; 
\q2 ndipo mundinenere mlandu wanga kutsutsana ndi mtundu wosapembedza; 
\q2 mundilanditse mʼmanja mwa achinyengo ndi anthu oyipa. 
\q1  
\v 2 Pajatu Inu Mulungu ndinu mphamvu zanga. 
\q2 Nʼchifukwa chiyani mwandikana ine? 
\q1 Nʼchifukwa chiyani ndiyenera kuyenda ndikulira, 
\q2 woponderezedwa ndi mdani? 
\q1  
\v 3 Tumizani kuwunika kwanu ndi choonadi chanu 
\q2 kuti zinditsogolere; 
\q1 mulole kuti zindifikitse ku phiri lanu loyera, 
\q2 kumalo kumene inu mumakhala. 
\q1  
\v 4 Ndipo ndidzapita ku guwa lansembe la Mulungu, 
\q2 kwa Mulungu, chimwemwe changa ndi chikondwerero changa. 
\q1 Ndidzakutamandani ndi zeze, 
\q2 Inu Mulungu wanga. 
\b  
\q1  
\v 5 Nʼchifukwa chiyani uli ndi chisoni iwe moyo wanga? 
\q2 Nʼchifukwa chiyani wakhumudwa iwe mʼkati mwanga? 
\q1 Khulupirira Mulungu, 
\q2 pakuti ndidzamutamandabe Iye, 
\q2 Mpulumutsi wanga ndi Mulungu wanga. 
\c 44  
\cl Salimo 44 
\d Kwa mtsogoleri wa mayimbidwe. Ndakatulo ya ana a Kora. 
\q1  
\v 1 Ife tamva ndi makutu athu, Inu Mulungu; 
\q2 makolo athu atiwuza 
\q1 zimene munachita mʼmasiku awo, 
\q2 masiku akalekalewo. 
\q1  
\v 2 Ndi dzanja lanu munathamangitsa mitundu ya anthu ena 
\q2 ndi kudzala makolo athu; 
\q1 Inu munakantha mitundu ya anthu, 
\q2 koma makolo athuwo Inu munawapatsa ufulu. 
\q1  
\v 3 Sanalande dziko ndi lupanga lawo, 
\q2 si mkono wawo umene unawabweretsera chigonjetso, 
\q1 koma ndi dzanja lanu lamanja, mkono wanu ndi kuwala kwa nkhope yanu, 
\q2 pakuti munawakonda. 
\b  
\q1  
\v 4 Inu ndinu Mfumu yanga ndi Mulungu wanga 
\q2 amene mumalamulira chigonjetso cha Yakobo. 
\q1  
\v 5 Kudzera kwa inu ife timabweza adani athu; 
\q2 kudzera mʼdzina lanu timapondereza otiwukirawo. 
\q1  
\v 6 Sindidalira uta wanga, 
\q2 lupanga langa silindibweretsera chigonjetso; 
\q1  
\v 7 koma Inu mumatigonjetsera adani athu, 
\q2 mumachititsa manyazi amene amadana nafe. 
\q1  
\v 8 Timanyadira mwa Mulungu wathu tsiku lonse, 
\q2 ndipo tidzatamanda dzina lanu kwamuyaya. 
\b  
\q1  
\v 9 Koma tsopano mwatikana ndi kutichepetsa; 
\q2 Inu simupitanso ndi ankhondo athu. 
\q1  
\v 10 Munachititsa ife kubwerera mʼmbuyo pamaso pa mdani 
\q2 ndipo amene amadana nafe atilanda katundu. 
\q1  
\v 11 Inu munatipereka kuti tiwonongedwe monga nkhosa 
\q2 ndipo mwatibalalitsa pakati pa anthu a mitundu ina. 
\q1  
\v 12 Inu munagulitsa anthu anu pa mtengo wotsika, 
\q2 osapindulapo kanthu pa malondawo. 
\b  
\q1  
\v 13 Mwachititsa kuti tikhale chochititsa manyazi kwa anthu a mitundu ina, 
\q2 chonyozeka ndi chothetsa nzeru kwa iwo amene atizungulira. 
\q1  
\v 14 Mwachititsa kuti tikhale onyozeka pakati pa anthu a mitundu ina; 
\q2 anthu amapukusa mitu yawo akationa. 
\q1  
\v 15 Manyazi anga ali pamaso panga tsiku lonse 
\q2 ndipo nkhope yanga yaphimbidwa ndi manyazi 
\q1  
\v 16 chifukwa cha mawu otonza a iwo amene amandinyoza ndi kundichita chipongwe, 
\q2 chifukwa cha mdani amene watsimikiza kubwezera. 
\b  
\q1  
\v 17 Zonsezi zinatichitikira 
\q2 ngakhale kuti ifeyo sitinayiwale Inu 
\q2 kapena kuonetsa kusakhulupirika pa pangano lanu. 
\q1  
\v 18 Mitima yathu sinabwerere mʼmbuyo; 
\q2 mapazi athu sanatayike pa njira yanu. 
\q1  
\v 19 Koma Inu mwatiphwanya ndi kuchititsa kuti tikhale ozunzidwa ndi ankhandwe 
\q2 ndipo mwatiphimba ndi mdima waukulu. 
\b  
\q1  
\v 20 Tikanayiwala dzina la Mulungu wathu 
\q2 kapena kutambasulira manja athu kwa mulungu wachilendo, 
\q1  
\v 21 kodi Mulungu wathu sakanazidziwa zimenezi, 
\q2 pakuti Iye amadziwa zinsinsi zamumtima? 
\q1  
\v 22 Komabe chifukwa cha Inu timakumana ndi imfa tsiku lonse, 
\q2 tili ngati nkhosa zoyenera kuti ziphedwe. 
\b  
\q1  
\v 23 Dzukani Ambuye! Nʼchifukwa chiyani mukugona! 
\q2 Dziwutseni nokha! Musatikane kwamuyaya. 
\q1  
\v 24 Nʼchifukwa chiyani mukubisa nkhope yanu, 
\q2 ndi kuyiwala mavuto athu ndi kuponderezedwa kwathu? 
\b  
\q1  
\v 25 Tatsitsidwa pansi mpaka pa fumbi; 
\q2 matupi athu amatirira pa dothi. 
\q1  
\v 26 Imirirani ndi kutithandiza, 
\q2 tiwomboleni chifukwa cha chikondi chanu chosasinthika. 
\c 45  
\cl Salimo 45 
\d Kwa mtsogoleri wamayimbidwe. Monga mwa mayimbidwe a “Maluwa a Kakombo.” Salimo la ana a Kora. Nyimbo ya pa ukwati. 
\q1  
\v 1 Mtima wanga watakasika ndi nkhani yokoma 
\q2 pamene ndikulakatula mawu anga kwa mfumu; 
\q2 lilime langa ndi cholembera cha wolemba waluso. 
\b  
\q1  
\v 2 Inu ndinu abwino kwambiri kuposa anthu onse 
\q2 ndipo milomo yanu inadzozedwa ndi chikondi cha Mulungu chosasinthika, 
\q2 popeza Mulungu wakudalitsani kwamuyaya. 
\q1  
\v 3 Mangirirani lupanga lanu mʼchiwuno mwanu, inu munthu wamphamvu; 
\q2 mudziveke nokha ndi ulemerero ndi ukulu wanu. 
\q1  
\v 4 Mu ukulu wanu mupite mutakwera mwachigonjetso 
\q2 mʼmalo mwa choonadi, kudzichepetsa ndi chilungamo; 
\q2 dzanja lanu lamanja lionetsere ntchito zanu zoopsa. 
\q1  
\v 5 Mivi yanu yakuthwa ilase mitima ya adani a mfumu, 
\q2 mitundu ya anthu igwe pansi pa mapazi anu. 
\q1  
\v 6 Mpando wanu waufumu, Inu Mulungu, udzakhala ku nthawi za nthawi; 
\q2 ndodo yaufumu yachilungamo idzakhala ndodo yaufumu ya ufumu wanu. 
\q1  
\v 7 Inu mumakonda chilungamo ndi kudana ndi zoyipa; 
\q2 choncho Mulungu, Mulungu wanu, wakukhazikani pamwamba pa anzanu 
\q2 pokudzozani ndi mafuta a chimwemwe. 
\q1  
\v 8 Mikanjo yanu yonse ndi yonunkhira ndi mure ndi aloe ndi kasiya; 
\q2 kuchokera ku nyumba zaufumu zokongoletsedwa ndi mnyanga wanjovu 
\q2 nyimbo za zoyimbira zazingwe zimakusangalatsani. 
\q1  
\v 9 Ana aakazi a mafumu ali pakati pa akazi anu olemekezeka; 
\q2 ku dzanja lanu lamanja kuli mkwatibwi waufumu ali mu golide wa ku Ofiri. 
\b  
\q1  
\v 10 Tamvera, iwe mwana wa mkazi ganizira ndipo tchera khutu; 
\q2 iwala anthu ako ndi nyumba ya abambo ako. 
\q1  
\v 11 Mfumu yathedwa nzeru chifukwa cha kukongola kwako; 
\q2 mulemekeze pakuti iyeyo ndiye mbuye wako. 
\q1  
\v 12 Mwana wa mkazi wa ku Turo adzabwera ndi mphatso, 
\q2 amuna a chuma adzafunafuna kukoma mtima kwako. 
\b  
\q1  
\v 13 Wokongola kwambiri ndi mwana wa mfumu ali mʼchipinda mwake, 
\q2 chovala chake ndi cholukidwa ndi thonje ndi golide. 
\q1  
\v 14 Atavala zovala zamaluwamaluwa akupita naye kwa mfumu; 
\q2 anamwali okhala naye akumutsatira 
\q2 ndipo abweretsedwa kwa inu. 
\q1  
\v 15 Iwo akuwaperekeza ndi chimwemwe ndi chisangalalo; 
\q2 akulowa mʼnyumba yaufumu. 
\b  
\q1  
\v 16 Ana ako aamuna adzatenga malo a makolo ako; 
\q2 udzachititsa kuti akhale ana a mfumu mʼdziko lonse. 
\q1  
\v 17 Ndidzabukitsa mbiri yako mʼmibado yonse; 
\q2 choncho mitundu yonse idzakutamanda ku nthawi za nthawi. 
\c 46  
\cl Salimo 46 
\d Kwa mtsogoleri wa mayimbidwe. Ndakatulo ya ana a Kora. Nyimbo ya anamwali. 
\q1  
\v 1 Mulungu ndiye kothawira kwathu ndi mphamvu yathu, 
\q2 thandizo lopezekeratu pa nthawi ya mavuto. 
\q1  
\v 2 Nʼchifukwa chake sitidzaopa ngakhale dziko lapansi lisunthike, 
\q2 ngakhale mapiri agwe pakati pa nyanja, 
\q1  
\v 3 ngakhale madzi ake atakokoma ndi kuchita thovu, 
\q2 ngakhale mapiri agwedezeke ndi kukokoma kwake. 
\b  
\q1  
\v 4 Kuli mtsinje umene njira zake za madzi zimasangalatsa mzinda wa Mulungu, 
\q2 malo oyera kumene Wammwambamwamba amakhalako. 
\q1  
\v 5 Mulungu ali mʼkati mwake, iwo sudzagwa; 
\q2 Mulungu adzawuthandiza mmawa. 
\q1  
\v 6 Mitundu ikupokosera, mafumu akugwa; 
\q2 Iye wakweza mawu ake, dziko lapansi likusungunuka. 
\b  
\q1  
\v 7 Yehova Wamphamvuzonse ali ndi ife, 
\q2 Mulungu wa Yakobo ndi linga lathu. 
\b  
\q1  
\v 8 Bwerani kuti mudzaone ntchito za Yehova, 
\q2 chiwonongeko chimene wachibweretsa pa dziko lapansi. 
\q1  
\v 9 Iye amathetsa nkhondo ku malekezero a dziko lapansi; 
\q2 Iye amathyola uta ndi kupindapinda mkondo; 
\q2 amatentha zishango ndi moto. 
\q1  
\v 10 Iye akuti, “Khala chete, ndipo dziwa kuti ndine Mulungu; 
\q2 ndidzakwezedwa pakati pa mitundu ya anthu; 
\q2 ine ndidzakwezedwa mʼdziko lapansi.” 
\b  
\q1  
\v 11 Yehova Wamphamvuzonse ali ndi ife, 
\q2 Mulungu wa Yakobo ndi linga lathu. 
\c 47  
\cl Salimo 47 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la ana a Kora. 
\q1  
\v 1 Ombani mʼmanja, inu anthu onse; 
\q2 fuwulani kwa Mulungu ndi mawu achimwemwe. 
\q1  
\v 2 Ndi woopsadi Yehova Wammwambamwamba; 
\q2 Mfumu yayikulu ya dziko lonse lapansi! 
\q1  
\v 3 Iye anatigonjetsera mitundu yambirimbiri ya anthu; 
\q2 anayika anthu pansi pa mapazi athu. 
\q1  
\v 4 Iye anatisankhira cholowa chathu, 
\q2 chonyaditsa cha Yakobo, amene anamukonda. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 5 Mulungu wakwera, anthu akumufuwulira mwachimwemwe, 
\q2 Yehova wakwera, akumuyimbira malipenga. 
\q1  
\v 6 Imbani matamando kwa Mulungu, imbani matamando; 
\q2 imbani matamando kwa mfumu yathu, imbani matamando. 
\b  
\q1  
\v 7 Pakuti Mulungu ndi mfumu ya dziko lonse lapansi; 
\q2 imbirani Iye salimo la matamando. 
\q1  
\v 8 Mulungu akulamulira mitundu ya anthu; 
\q2 Mulungu wakhala pa mpando wake waufumu woyera. 
\q1  
\v 9 Anthu otchuka mwa anthu a mitundu ina asonkhana 
\q2 monga anthu a Mulungu wa Abrahamu, 
\q1 pakuti mafumu a dziko lapansi ndi ake a Mulungu; 
\q2 Iye wakwezedwa kwakukulu. 
\c 48  
\cl Salimo 48 
\d Nyimbo. Salimo la ana a Kora. 
\q1  
\v 1 Wamkulu ndi Yehova, ndi woyenera kwambiri matamando 
\q2 mu mzinda wa Mulungu wathu, phiri lake loyera. 
\q1  
\v 2 Lokongola mu utali mwake, 
\q2 chimwemwe cha dziko lonse lapansi. 
\q1 Malo aatali kwambiri a Zafoni ndiye Phiri la Ziyoni, 
\q2 mzinda wa Mfumu yayikulu. 
\q1  
\v 3 Mulungu ali mu malinga ake; 
\q2 Iye wadzionetsa yekha kuti ndiye malinga akewo. 
\b  
\q1  
\v 4 Pamene mafumu anasonkhana pamodzi, 
\q2 pamene anayendera pamodzi kudzalimbana nafe, 
\q1  
\v 5 iwo anaona mzindawo ndipo anadabwa kwambiri; 
\q2 anathawa ndi mantha aakulu. 
\q1  
\v 6 Pomwepo anagwidwa nako kunjenjemera, 
\q2 ululu wonga wa mkazi woyembekezera pa nthawi yochira. 
\q1  
\v 7 Inu munawawononga monga sitima zapamadzi za ku Tarisisi 
\q2 zitawonongeka ndi mphepo ya kummawa. 
\b  
\q1  
\v 8 Monga momwe tinamvera, 
\q2 kotero ife tinaona 
\q1 mu mzinda wa Yehova Wamphamvuzonse, 
\q2 mu mzinda wa Mulungu wathu. 
\q2 Mulungu adzawuteteza kwamuyaya. 
\b  
\q1  
\v 9 Mʼkati mwa Nyumba yanu Mulungu, 
\q2 ife timalingaliramo zachikondi chanu chosasinthika. 
\q1  
\v 10 Monga dzina lanu, Inu Mulungu, 
\q2 matamando anu amafika ku malekezero a dziko lapansi 
\q2 dzanja lanu lamanja ladzaza ndi chilungamo. 
\q1  
\v 11 Phiri la Ziyoni likukondwera, 
\q2 midzi ya Yuda ndi yosangalala 
\q2 chifukwa cha maweruzo anu. 
\b  
\q1  
\v 12 Yendayendani mu Ziyoni, uzungulireni mzindawo, 
\q2 werengani nsanja zake. 
\q1  
\v 13 Yangʼanitsitsani bwino mipanda yake, 
\q2 penyetsetsani malinga ake, 
\q2 kuti mudzafotokoze za izo ku mʼbado wotsatira. 
\q1  
\v 14 Pakuti Mulungu uyu ndi Mulungu wathu ku nthawi zosatha; 
\q2 Iye adzakhala mtsogoleri wathu mpaka ku mapeto. 
\c 49  
\cl Salimo 49 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la ana a Kora. 
\q1  
\v 1 Imvani izi anthu a mitundu yonse; 
\q2 mvetserani, nonse amene mumakhala pa dziko lonse, 
\q1  
\v 2 anthu wamba pamodzi ndi anthu odziwika, 
\q2 olemera pamodzinso ndi osauka: 
\q1  
\v 3 Pakamwa panga padzayankhula mawu anzeru; 
\q2 mawu ochokera mu mtima mwanga adzapereka nzeru. 
\q1  
\v 4 Ndidzatchera khutu langa ku mwambo, 
\q2 ndi pangwe ndidzafotokoza momveka mwambi wanga. 
\b  
\q1  
\v 5 Ine ndichitirenji mantha pamene masiku oyipa afika, 
\q2 pamene achinyengo oyipa andizungulira. 
\q1  
\v 6 Iwo amene adalira kulemera kwawo 
\q2 ndi kutamandira kuchuluka kwa chuma chawo? 
\q1  
\v 7 Palibe munthu amene angawombole moyo wa mnzake 
\q2 kapena kuperekera mnzake dipo kwa Mulungu. 
\q1  
\v 8 Dipo la moyo ndi la mtengowapatali, 
\q2 palibe malipiro amene angakwanire, 
\q1  
\v 9 kuti iye akhale ndi moyo mpaka muyaya 
\q2 ndi kusapita ku manda. 
\b  
\q1  
\v 10 Pakuti onse amaona kuti anthu anzeru amamwalira; 
\q2 opusa ndi opanda nzeru chimodzimodzinso amawonongeka 
\q2 ndipo amasiyira chuma chawo anthu ena. 
\q1  
\v 11 Manda awo adzakhala nyumba zawo mpaka muyaya, 
\q2 malo awo okhalako kwa nthawi yonse ya mibado yawo, 
\q2 ngakhale anatchula malo mayina awo. 
\b  
\q1  
\v 12 Ngakhale munthu akhale wachuma chotani, 
\q2 adzafa ngati nyama. 
\b  
\q1  
\v 13 Izi ndi zimene zimachitikira iwo amene amadzidalira okha, 
\q2 ndi owatsatira awo amene amavomereza zimene amayankhula. 
\q4 \qs Sela\qs* 
\q1  
\v 14 Monga nkhosa iwo ayenera kupita ku manda, 
\q2 ndipo imfa idzawadya. 
\q1 Olungama adzawalamulira mmawa; 
\q2 matupi awo adzavunda mʼmanda, 
\q2 kutali ndi nyumba zawo zaufumu. 
\q1  
\v 15 Koma Mulungu adzawombola moyo wanga kuchoka ku manda; 
\q2 ndithu Iye adzanditengera kwa Iye mwini. 
\b  
\q1  
\v 16 Usavutike mu mtima pamene munthu akulemera, 
\q2 pamene ulemerero wa nyumba yake ukuchulukirachulukira; 
\q1  
\v 17 Pakuti sadzatenga kanthu pamodzi naye pamene wamwalira, 
\q2 ulemerero wake sudzapita pamodzi naye. 
\q1  
\v 18 Ngakhale pamene munthuyo ali moyo amadziyesa wodala, 
\q2 ndipo ngakhale atamandidwe pamene zinthu zikumuyendera bwino, 
\q1  
\v 19 iyeyo adzakakhala pamodzi ndi mʼbado wa makolo ake, 
\q2 amene sadzaonanso kuwala. 
\b  
\q1  
\v 20 Munthu amene ali ndi chuma koma wopanda nzeru 
\q2 adzafa ngati nyama yakuthengo. 
\c 50  
\cl Salimo 50 
\d Salimo la Asafu. 
\q1  
\v 1 Wamphamvuyo, Yehova Mulungu, 
\q2 akuyankhula ndi kuyitanitsa dziko lapansi 
\q2 kuyambira kotulukira dzuwa mpaka kumene limalowera. 
\q1  
\v 2 Kuchokera ku Ziyoni, mokongola kwambiri 
\q2 Mulungu akuwala. 
\q1  
\v 3 Mulungu wathu akubwera ndipo sadzakhala chete; 
\q2 moto ukunyeketsa patsogolo pake, 
\q2 ndipo pomuzungulira pali mphepo yamkuntho 
\q1  
\v 4 Iye akuyitanitsa zamumlengalenga 
\q2 ndi za pa dziko lapansi kuti aweruze anthu ake. 
\q1  
\v 5 Mundisonkhanitsire okhulupirika anga, 
\q2 amene anachita pangano ndi ine pochita nsembe. 
\q1  
\v 6 Ndipo mayiko akumwamba akulengeza chilungamo chake, 
\q2 pakuti Mulungu mwini ndi woweruza. 
\b  
\q1  
\v 7 Imvani inu anthu anga, ndipo Ine ndidzayankhula, 
\q2 iwe Israeli, ndipo Ine ndidzayankhula mokutsutsa; 
\q2 ndine Mulungu, Mulungu wako. 
\q1  
\v 8 Sindikudzudzula chifukwa cha nsembe zako, 
\q2 kapena nsembe zako zopsereza zimene zili pamaso panga nthawi zonse. 
\q1  
\v 9 Ine sindikufuna ngʼombe yayimuna kuchokera mʼkhola lako 
\q2 kapena mbuzi za mʼkhola lako, 
\q1  
\v 10 pakuti nyama iliyonse yakunkhalango ndi yanga 
\q2 ndiponso ngʼombe za ku mapiri ochuluka. 
\q1  
\v 11 Ine ndimadziwa mbalame iliyonse mʼmapiri 
\q2 ndiponso zolengedwa zonse zakutchire ndi zanga. 
\q1  
\v 12 Ndikanakhala ndi njala sindikanakuwuzani, 
\q2 pakuti dziko lonse ndi zonse zimene zili mʼmenemo ndi zanga. 
\q1  
\v 13 Kodi ndimadya nyama ya ngʼombe zazimuna 
\q2 kapena kumwa magazi a mbuzi? 
\q1  
\v 14 “Pereka nsembe zachiyamiko kwa Mulungu, 
\q2 kwaniritsa malonjezo ako kwa Wammwambamwamba. 
\q1  
\v 15 Ndipo undiyitane pa tsiku lako la masautso; 
\q2 Ine ndidzakulanditsa, ndipo udzandilemekeza.” 
\p  
\v 16 Koma kwa woyipa, Mulungu akuti, 
\q1 “Kodi uli ndi mphamvu yanji kuti uzinena malamulo anga 
\q2 kapena kutenga pangano langa pa milomo yako? 
\q1  
\v 17 Iwe umadana ndi malangizo anga 
\q2 ndipo umaponyera kumbuyo kwako mawu anga. 
\q1  
\v 18 Ukaona wakuba umamutsatira, 
\q2 umachita maere ako pamodzi ndi achigololo 
\q1  
\v 19 Umagwiritsa ntchito pakamwa pako pa zinthu zoyipa 
\q2 ndipo umakonza lilime lako kuchita chinyengo. 
\q1  
\v 20 Nthawi zonse umayankhula motsutsana ndi mʼbale wako 
\q2 ndipo umasinjirira mwana wa amayi ako enieni. 
\q1  
\v 21 Wachita zimenezi ndipo Ine ndinali chete; 
\q2 umaganiza kuti ndine wofanana nawe 
\q1 koma ndidzakudzudzula 
\q2 ndipo ndidzakutsutsa pamaso pako. 
\b  
\q1  
\v 22 “Ganizira izi, iwe amene umayiwala Mulungu 
\q2 kuti ndingakukadzule popanda wokupulumutsa: 
\q1  
\v 23 Iye amene amapereka nsembe yamayamiko amandilemekeza, 
\q2 ndipo amakonza njira zake kuti ndimuonetse 
\q2 chipulumutso cha Mulungu.” 
\c 51  
\cl Salimo 51 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. Pamene Mneneri Natani anabwera kwa iye atachita chigololo ndi Batiseba. 
\q1  
\v 1 Mundichitire chifundo, Inu Mulungu, 
\q2 molingana ndi chikondi chanu chosasinthika; 
\q1 molingana ndi chifundo chanu chachikulu 
\q2 mufafanize mphulupulu zanga. 
\q1  
\v 2 Munditsuke zolakwa zanga zonse 
\q2 ndipo mundiyeretse kuchotsa tchimo langa. 
\b  
\q1  
\v 3 Pakuti ndikudziwa mphulupulu zanga, 
\q2 ndipo tchimo langa lili pamaso panga nthawi zonse. 
\q1  
\v 4 Motsutsana ndi Inu, Inu nokha, ndachimwa 
\q2 ndipo ndachita zoyipa pamaso panu, 
\q1 Kotero kuti inu mwapezeka kuti ndinu wolungama 
\q2 pamene muyankhula ndi pamene muweruza. 
\q1  
\v 5 Zoonadi ine ndinali wochimwa pomwe ndimabadwa, 
\q2 wochimwa kuyambira pa nthawi imene amayi anga anakhala woyembekezera ine. 
\q1  
\v 6 Zoonadi inu mumafuna choonadi mu ziwalo zamʼkati mwanga; 
\q2 mumandiphunzitsa nzeru mʼkati mwanga mwenimweni. 
\b  
\q1  
\v 7 Mundiyeretse ndi hisope ndipo ndidzayera, 
\q2 munditsuke ndipo ndidzayera kuposa matalala 
\q1  
\v 8 Mundilole ndimve chimwemwe ndi chisangalalo, 
\q2 mulole kuti mafupa amene mwawamphwanya akondwere. 
\q1  
\v 9 Mufulatire machimo anga 
\q2 ndi kufafaniza zolakwa zanga zonse. 
\b  
\q1  
\v 10 Mulenge mʼkati mwanga mtima woyera Inu Mulungu 
\q2 ndi kukonzanso mzimu wokhazikika mwa ine. 
\q1  
\v 11 Musandichotse pamaso panu 
\q2 kapena kuchotsa Mzimu wanu Woyera mwa ine. 
\q1  
\v 12 Bwezeretsani mwa ine chimwemwe cha chipulumutso chanu 
\q2 ndipo mundipatse mzimu wofuna kumvera kuti undilimbitse. 
\b  
\q1  
\v 13 Pamenepo ndidzaphunzitsa anthu amphulupulu njira zanu 
\q2 kuti ochimwa adzabwerere kwa inu. 
\q1  
\v 14 Mundipulumutse ku tchimo lokhetsa magazi, Inu Mulungu, 
\q2 Mulungu wa chipulumutso changa, 
\q2 ndipo lilime langa lidzayimba zachilungamo chanu. 
\q1  
\v 15 Inu Ambuye tsekulani milomo yanga, 
\q2 ndipo pakamwa panga padzalengeza matamando anu. 
\q1  
\v 16 Inu simusangalatsidwa ndi nsembe wamba. 
\q2 Ndikanapereka nsembe yopsereza, Inu simukondwera nayo. 
\q1  
\v 17 Nsembe za Mulungu ndi mzimu wosweka; 
\q2 mtima wosweka ndi wachisoni 
\q2 Inu Mulungu simudzawunyoza. 
\b  
\q1  
\v 18 Mwa kukoma mtima kwanu mupange Ziyoni kuti alemere; 
\q2 mumange makoma a Yerusalemu. 
\q1  
\v 19 Kotero kudzakhala nsembe zachilungamo, 
\q2 nsembe yonse yopsereza yokondweretsa Inu; 
\q2 ndipo ngʼombe zazimuna zidzaperekedwa pa guwa lanu la nsembe. 
\c 52  
\cl Salimo 52 
\d Kwa mtsogoleri wa mayimbidwe, ndakatulo ya Davide; pamene Doegi Mwedomu anapita kwa Sauli ndi kunena kuti “Davide wapita ku nyumba ya Ahimeleki.” 
\q1  
\v 1 Nʼchifukwa chiyani ukudzitamandira ndi zoyipa, iwe munthu wamphamvu? 
\q2 Nʼchifukwa chiyani ukudzitamandira tsiku lonse, 
\q2 iwe munthu wochititsa manyazi pamaso pa Mulungu? 
\q1  
\v 2 Tsiku lonse umakhalira kuganizira za kuwononga ena; 
\q2 lilime lako lili ngati lumo lakuthwa, 
\q2 ntchito yako nʼkunyenga. 
\q1  
\v 3 Iwe umakonda choyipa mʼmalo mwa kuyankhula choonadi. 
\q2 Umakonda kunama kupambana kuyankhula zoona. 
\q4 \qs Sela\qs* 
\q1  
\v 4 Umakonda mawu onse opweteka, 
\q2 iwe lilime lachinyengo! 
\b  
\q1  
\v 5 Zoonadi Mulungu adzakutsitsa kupita ku chiwonongeko chamuyaya: 
\q2 iye adzakukwatula ndi kukuchotsa mʼtenti yako; 
\q2 iye adzakuzula kuchoka mʼdziko la amoyo. 
\q1  
\v 6 Olungama adzaona zimenezi ndi kuchita mantha; 
\q2 adzamuseka nʼkumanena kuti, 
\q1  
\v 7 “Pano tsopano pali munthu 
\q2 amene sanayese Mulungu linga lake, 
\q1 koma anakhulupirira chuma chake chambiri 
\q2 nalimbika kuchita zoyipa!” 
\b  
\q1  
\v 8 Koma ine ndili ngati mtengo wa olivi 
\q2 wobiriwira bwino mʼnyumba ya Mulungu; 
\q1 ndimadalira chikondi chosatha cha Mulungu 
\q2 kwa nthawi za nthawi. 
\q1  
\v 9 Ine ndidzakutamandani kwamuyaya chifukwa cha zimene mwachita; 
\q2 chifukwa cha zimene mwachita; mʼdzina lanu ndidzayembekezera 
\q2 pakuti dzina lanulo ndi labwino. Ndidzakutamandani pamaso pa oyera mtima anu. 
\c 53  
\cl Salimo 53 
\d Kwa mtsogoleri wa mayimbidwe. Potsata mayimbidwe a Mahalati. Ndakatulo ya Davide. 
\q1  
\v 1 Chitsiru chimati mu mtima mwake, 
\q2 “Kulibe Mulungu.” 
\q1 Iwo ndi oyipa ndipo njira zawo ndi zonyansa; 
\q2 palibe ndi mmodzi yemwe amene amachita chabwino. 
\b  
\q1  
\v 2 Mulungu kumwamba amayangʼana pansi pano 
\q2 pa ana a anthu 
\q1 kuti aone ngati alipo wina wanzeru, 
\q2 wofunafuna Mulungu. 
\q1  
\v 3 Aliyense wabwerera, 
\q2 iwo onse pamodzi akhala oyipa; 
\q1 palibe ndi mmodzi yemwe amene amachita chabwino, 
\q2 ngakhale mmodzi. 
\b  
\q1  
\v 4 Kodi anthu ochita zoyipawa adzaphunziradi; 
\q2 anthu amene amadya anthu anga monga mmene anthu amadyera buledi, 
\q2 ndipo sapemphera kwa Mulungu? 
\q1  
\v 5 Iwo anali pamenepo atathedwa nzeru ndi mantha aakulu 
\q2 pamene panalibe kanthu kochititsa mantha. 
\q1 Mulungu anamwazamwaza mafupa a anthu amene anakuthirani nkhondo; 
\q2 inuyo munawachititsa manyazi, pakuti Mulungu anawanyoza. 
\b  
\q1  
\v 6 Ndithu, chipulumutso cha Israeli nʼchochokera ku Ziyoni! 
\q2 Pamene Mulungu adzabwezeretsanso ulemerero wa anthu ake, 
\q2 lolani Yakobo akondwere ndi Israeli asangalale! 
\c 54  
\cl Salimo 54 
\d Kwa mtsogoleri wa mayimbidwe. Pa zoyimbira za zingwe. Ndakatulo ya Davide. Pamene anthu a ku Zifi anapita kwa Sauli ndipo anati, “Kodi Davide sakubisala pakati pathu.” 
\q1  
\v 1 Pulumutseni Inu Mulungu, mwa dzina lanu; 
\q2 onetsani kuti ndine wosalakwa mwamphamvu yanu. 
\q1  
\v 2 Imvani pemphero langa, Inu Mulungu 
\q2 mvetserani mawu a pakamwa panga. 
\b  
\q1  
\v 3 Alendo akundithira nkhondo; 
\q2 anthu ankhanza akufunafuna moyo wanga, 
\q2 anthu amene salabadira za Mulungu. 
\b  
\q1  
\v 4 Zoonadi Mulungu ndi thandizo langa; 
\q2 Ambuye ndiye amene amandichirikiza ine. 
\b  
\q1  
\v 5 Lolani kuti choyipa chifike pa iwo amene amandichita chipongwe; 
\q2 mwa kukhulupirika kwanu awonongeni. 
\b  
\q1  
\v 6 Ine ndidzapereka nsembe yaufulu kwa Inu; 
\q2 ndidzatamanda dzina lanu, Inu Yehova, 
\q2 pakuti ndi labwino. 
\q1  
\v 7 Pakuti Iyeyo wandipulumutsa ku masautso anga onse, 
\q2 ndipo maso anga apenya kupambana kwa pa adani anga. 
\c 55  
\cl Salimo 55 
\d Kwa mtsogoleri wa mayimbidwe. Ndakatulo ya Davide. Pa zoyimbira za zingwe. 
\q1  
\v 1 Mvetserani pemphero langa, Inu Mulungu, 
\q2 musakufulatire kupempha kwanga, 
\q2  
\v 2 mverani ndipo mundiyankhe. 
\q1 Maganizo anga akundisautsa ndipo ndathedwa nzeru 
\q2  
\v 3 chifukwa cha mawu a adani anga, 
\q2 chifukwa cha kupondereza kwa anthu oyipa; 
\q1 pakuti andidzetsera masautso 
\q2 ndipo akundizunza mu mkwiyo wawo. 
\b  
\q1  
\v 4 Mtima wanga ukupweteka mʼkati mwanga; 
\q2 mantha a imfa andigwera. 
\q1  
\v 5 Mantha ndi kunjenjemera zandizinga; 
\q2 mantha aakulu andithetsa nzeru. 
\q1  
\v 6 Ndinati, “Ndithu, ndikanakhala ndi mapiko ankhunda! 
\q2 Ndikanawulukira kutali ndi kukapuma. 
\q1  
\v 7 Ndikanathawira kutali 
\q2 ndi kukakhala mʼchipululu. 
\q1  
\v 8 Ndikanathamangira kumalo anga a chitetezo; 
\q2 kutali ndi mphepo yaukali ndi yamkuntho.” 
\b  
\q1  
\v 9 Sokonezani maganizo a oyipa, Inu Ambuye, tsutsani mawu awo; 
\q2 pakuti ine ndikuona chiwawa ndi mkangano mu mzinda. 
\q1  
\v 10 Usana ndi usiku iwo akuzungulirazungulira pa makoma ake; 
\q2 nkhwidzi ndi kuzunza kuli mʼkati mwake. 
\q1  
\v 11 Mphamvu zowononga zili pa ntchito mu mzinda; 
\q2 kuopseza ndi mabodza sizichoka mʼmisewu yake. 
\b  
\q1  
\v 12 Akanakhala mdani akundinyoza, ine 
\q2 ndikanapirira; 
\q1 akanakhala mdani akudzikweza yekha kutsutsana nane, 
\q2 ndikanakabisala. 
\q1  
\v 13 Koma iweyo mnzanga, mnzanga woyenda naye, 
\q2 bwenzi langa la pondaapanʼpondepo, ndi amene ukuchita zimenezi. 
\q1  
\v 14 Mnzanga amene nthawi ina tinkasangalala 
\q2 pa chiyanjano chokoma ku nyumba ya Mulungu. 
\b  
\q1  
\v 15 Mulole imfa itenge adani anga mwadzidzidzi; 
\q2 alowe mʼmanda ali amoyo 
\q2 pakuti choyipa chili pakati pawo. 
\b  
\q1  
\v 16 Koma ine ndinafuwulira kwa Mulungu, 
\q2 ndipo Yehova anandipulumutsa. 
\q1  
\v 17 Madzulo, mmawa ndi masana 
\q2 ndimalira mowawidwa mtima, 
\q2 ndipo Iye amamva mawu anga. 
\q1  
\v 18 Iye amandiwombola ine osavulazidwa 
\q2 pa nkhondo imene yafika kulimbana nane, 
\q2 ngakhale kuti ndi ambiri amene akunditsutsa. 
\q1  
\v 19 Mulungu amene ali pa mpando wake kwamuyaya, 
\q2 adzandimenyera nkhondo; adzawatsitsa adani anga, 
\q1 chifukwa safuna kusintha njira zawo zoyipa 
\q2 ndipo saopa Mulungu. 
\b  
\q1  
\v 20 Mnzanga woyenda naye wathira nkhondo abwenzi ake; 
\q2 iye akuphwanya pangano ake. 
\q1  
\v 21 Mawu ake ndi osalala kuposa batala 
\q2 komabe nkhondo ili mu mtima mwake; 
\q1 mawu ake ndi osalala kwambiri kuposa mafuta, 
\q2 komatu mawuwo ndi malupanga osololoka. 
\b  
\q1  
\v 22 Tulani nkhawa zanu kwa Yehova 
\q2 ndipo Iye adzakulimbitsani; 
\q2 Iye sadzalola kuti wolungama agwe. 
\q1  
\v 23 Koma Inu Mulungu mudzawatsitsa anthu oyipa 
\q2 kulowa mʼdzenje lachiwonongeko; 
\q1 anthu okhetsa magazi ndi anthu achinyengo 
\q2 sadzakhala moyo theka la masiku awo, 
\b  
\q1 koma ine ndimadalira Inu. 
\c 56  
\cl Salimo 56 
\d Kwa mtsogoleri wa mayimbidwe. Potsata mayimbidwe a “Njiwa pa Mtengo wa Thundu wa Kutali.” Mikitamu ya Davide, pamene Afilisti anamugwira ku Gati. 
\q1  
\v 1 Mundichitire chifundo Inu Mulungu, pakuti anthu akundithamangitsa kwambiri; 
\q2 tsiku lonse akundithira nkhondo. 
\q1  
\v 2 Ondinyoza akundithamangitsa tsiku lonse, 
\q2 ambiri akumenyana nane monyada. 
\b  
\q1  
\v 3 Ndikachita mantha 
\q2 ndimadalira Inu. 
\q1  
\v 4 Mwa Mulungu, amene mawu ake ine ndimatamanda, 
\q2 mwa Mulungu ine ndimadaliramo; sindidzachita mantha. 
\q2 Kodi munthu amene amafa angandichite chiyani? 
\b  
\q1  
\v 5 Tsiku lonse amatembenuza mawu anga; 
\q2 nthawi zonse amakonza zondivulaza. 
\q1  
\v 6 Iwo amakambirana, amandibisalira, 
\q2 amayangʼanitsitsa mayendedwe anga 
\q2 ndipo amakhala ndi chidwi chofuna kuchotsa moyo wanga. 
\b  
\q1  
\v 7 Musalole konse kuti athawe; 
\q2 mu mkwiyo wanu Mulungu mugwetse mitundu ya anthu. 
\q1  
\v 8 Mulembe za kulira kwanga, 
\q2 mulembe chiwerengero cha misozi yanga mʼbuku lanu. 
\q2 Kodi zimenezi sizinalembedwe mʼbuku lanulo? 
\b  
\q1  
\v 9 Adani anga adzabwerera mʼmbuyo 
\q2 pamene ndidzalirira kwa Inu. 
\q2 Pamenepo ndidzadziwa kuti Mulungu ali ku mbali yanga. 
\q1  
\v 10 Mwa Mulungu amene mawu ake ndimawatamanda, 
\q2 mwa Yehova amene mawu ake ndimawatamanda, 
\q1  
\v 11 mwa Mulungu ine ndimadalira ndipo sindidzachita mantha. 
\q2 Kodi munthu angandichite chiyani? 
\b  
\q1  
\v 12 Ndiyenera kuchita zomwe ndinalumbira kwa Mulungu; 
\q2 ndidzapereka nsembe zanga zachiyamiko kwa inu. 
\q1  
\v 13 Pakuti mwawombola moyo wanga ku imfa 
\q2 ndi mapazi anga kuti ndingagwe, 
\q1 kuti ndiyende pamaso pa Mulungu 
\q2 mʼkuwala kwa moyo. 
\c 57  
\cl Salimo 57 
\d Kwa mtsogoleri wa mayimbidwe. Potsata mayimbidwe a “Musawononge.” Ndakatulo ya Davide, pamene anathawa Sauli kupita ku phanga. 
\q1  
\v 1 Mundichitire chifundo, Inu Mulungu mundichitire chifundo, 
\q2 pakuti mwa Inu moyo wanga umathawiramo. 
\q1 Ndidzathawira mu mthunzi wa mapiko anu 
\q2 mpaka chiwonongeko chitapita. 
\b  
\q1  
\v 2 Ine ndikufuwulira kwa Mulungu Wammwambamwamba, 
\q2 kwa Mulungu amene amakwaniritsa cholinga chake pa ine. 
\q1  
\v 3 Mulungu amanditumizira kuchokera kumwamba ndi kundipulumutsa, 
\q2 kudzudzula iwo amene akundithamangitsa kwambiri. 
\q2 Mulungu amatumiza chikondi chake ndi kukhulupirika kwake. 
\b  
\q1  
\v 4 Ine ndili pakati pa mikango, 
\q2 ndagona pakati pa zirombo zolusa; 
\q1 anthu amene mano awo ndi milomo yawo ndi mivi, 
\q2 malilime awo ndi malupanga akuthwa. 
\b  
\q1  
\v 5 Mukwezekedwe Inu Mulungu, kuposa mayiko onse akumwamba; 
\q2 mulole kuti ulemerero wanu ukhale pa dziko lonse lapansi. 
\b  
\q1  
\v 6 Iwo anatchera mapazi anga ukonde 
\q2 ndipo ndinawerama pansi mosautsidwa. 
\q1 Anakumba dzenje mʼnjira yanga 
\q2 koma agweramo okha mʼmenemo. 
\b  
\q1  
\v 7 Mtima wanga ndi wokhazikika, Inu Mulungu 
\q2 mtima wanga ndi wokhazikika. 
\q2 Ndidzayimba nyimbo, nyimbo yake yamatamando. 
\q1  
\v 8 Dzuka moyo wanga! 
\q2 Dzukani zeze ndi pangwe! 
\q2 Ndidzadzuka mʼbandakucha. 
\b  
\q1  
\v 9 Ndidzakutamandani Ambuye, pakati pa mitundu ya anthu, 
\q2 ndidzayimba za Inu pakati pa mayiko. 
\q1  
\v 10 Pakuti chikondi chanu nʼchachikulu, kufikira ku mayiko akumwamba; 
\q2 kukhulupirika kwanu kwafika ku mitambo. 
\b  
\q1  
\v 11 Mukwezekedwe Inu Mulungu kuposa mayiko akumwamba, 
\q2 mulole kuti ulemerero wanu ukhale pa dziko lonse lapansi. 
\c 58  
\cl Salimo 58 
\d Kwa mtsogoleri wa mayimbidwe. Potsata mayimbidwe a “Musawononge.” Ndakatulo ya Davide. 
\q1  
\v 1 Kodi inu olamulira mumayankhuladi molungama? 
\q2 Kodi mumaweruza mwachilungamo pakati pa anthu? 
\q1  
\v 2 Ayi, mʼmitima mwanu mumakonzekera zosalungama, 
\q2 ndipo manja anu amatulutsa zachiwawa pa dziko lapansi. 
\q1  
\v 3 Ngakhale kuchokera tsiku lawo lobadwa oyipa amasochera; 
\q2 kuchokera mʼmimba ya amayi awo, iwo ndi otayika ndipo amayankhula mabodza. 
\q1  
\v 4 Ululu wawo uli ngati ululu wa njoka, 
\q2 ngati uja wa mphiri imene yatseka mʼmakutu mwake. 
\q1  
\v 5 Imene simva liwu la munthu wamatsenga, 
\q2 ngakhale akhale wa luso lotani munthu wamatsengayo. 
\b  
\q1  
\v 6 Gululani mano mʼkamwa mwawo, Inu Mulungu, 
\q2 Yehova khadzulani mano a mikango! 
\q1  
\v 7 Mulole kuti asowe ngati madzi oyenda 
\q2 pamene iwo akoka uta mulole kuti mivi yawo ikhale yosathwa. 
\q1  
\v 8 Akhale ngati nkhono imene imasungunuka pamene ikuyenda; 
\q2 ngati mwana wakufa asanabadwe, iwo asaone dzuwa. 
\b  
\q1  
\v 9 Miphika yanu isanagwire moto waminga ya mkandankhuku, 
\q2 kaya iyo ndi yobiriwira kapena yowuma, oyipa adzachotsedwa. 
\q1  
\v 10 Olungama adzasangalala poona kubwezera chilango, 
\q2 pamene adzasambitsa mapazi awo mʼmagazi a anthu oyipa. 
\q1  
\v 11 Ndipo anthu adzanena kuti, 
\q2 “Zoonadi, olungama amalandirabe mphotho; 
\q2 zoonadi kuli Mulungu amene amaweruza dziko lapansi.” 
\c 59  
\cl Salimo 59 
\d Kwa mtsogoleri wa mayimbidwe. Potsata mayimbidwe a “Musawononge.” Ndakatulo ya Davide. Pamene Sauli anatumiza anthu kuti akalondere nyumba ya Davide ndi cholinga choti amuphe. 
\q1  
\v 1 Landitseni kwa adani anga, Inu Mulungu; 
\q2 munditeteze kwa anthu amene auka kutsutsana nane. 
\q1  
\v 2 Landitseni kwa anthu ochita zoyipa 
\q2 ndipo mundipulumutse kwa anthu okhetsa magazi. 
\b  
\q1  
\v 3 Onani momwe iwo akundibisalira! 
\q2 Anthu owopsa agwirizana zolimbana nane; 
\q2 osati chifukwa cha mlandu kapena tchimo langa, Inu Yehova. 
\q1  
\v 4 Ine sindinachite cholakwa, koma iwo ndi okonzeka kundithira nkhondo. 
\q2 Dzukani kuti mundithandize; penyani mavuto anga! 
\q1  
\v 5 Inu Yehova Mulungu Wamphamvuzonse, Mulungu wa Israeli, 
\q2 dzidzutseni nokha kuti mulange anthu a mitundu ina yonse; 
\q2 musaonetse chifundo chanu kwa anthu oyipa achinyengowa. 
\b  
\q1  
\v 6 Iwo amabweranso madzulo 
\q2 akuchita phokoso ngati agalu 
\q2 ndi kumangoyendayenda mu mzinda. 
\q1  
\v 7 Onani zomwe amalavula mʼkamwa mwawo; 
\q2 iwo amalavula malupanga kuchokera pa milomo yawo, 
\q2 ndipo amanena kuti, “Ndani angatimve?” 
\q1  
\v 8 Koma Inu Yehova, mumawaseka, 
\q2 mumayinyoza mitundu yonseyo. 
\b  
\q1  
\v 9 Inu mphamvu yanga, ine ndiyangʼana kwa inu; 
\q2 Inu Mulungu, ndinu linga langa.  
\v 10 Mulungu wanga wachikondi. 
\b  
\q1 Mulungu adzapita patsogolo panga 
\q2 ndipo adzandilola kunyada pa iwo amene amandinyoza. 
\q1  
\v 11 Koma musawaphe, Inu Ambuye chishango chathu, 
\q2 kuopa kuti anthu anga angayiwale. 
\q1 Mwa mphamvu zanu, 
\q2 lolani kuti azingoyendayenda ndipo muwatsitse. 
\q1  
\v 12 Chifukwa cha machimo a pakamwa pawo 
\q2 chifukwa cha mawu a milomo yawo, 
\q2 iwo akodwe mʼkunyada kwawo. 
\q1 Chifukwa cha matemberero ndi mabodza amene ayankhula 
\q2  
\v 13 muwawononge mu ukali (wanu) 
\q2 muwawononge mpaka atheretu. 
\q1 Pamenepo zidzadziwika ku malekezero a dziko lapansi 
\q2 kuti Mulungu amalamulira Yakobo. 
\b  
\q1  
\v 14 Iwo amabweranso madzulo, 
\q2 akuchita phokoso ngati agalu 
\q2 ndi kumangoyenda mu mzinda. 
\q1  
\v 15 Iwo amayendayenda kufuna chakudya 
\q2 ndipo amawuwa ngati sanakhute. 
\q1  
\v 16 Koma ine ndidzayimba za mphamvu yanu, 
\q2 mmawa ndidzayimba zachikondi chanu; 
\q1 pakuti ndinu linga langa, 
\q2 pothawirapo panga mʼnthawi ya mavuto. 
\b  
\q1  
\v 17 Inu mphamvu yanga, ndiyimba matamando kwa inu; 
\q2 Inu Mulungu, ndinu linga langa, Mulungu wanga wachikondi. 
\c 60  
\cl Salimo 60 
\d Kwa mtsogoleri wa mayimbidwe. Potsata mayimbidwe a “Kakombo wa Pangano.” Mikitamu ya Davide yophunzitsira. Pamene anamenyana ndi Mesopotamiya ndi Aramu-Zoba, ndi pamene Yowabu anabwerera ndi kukantha Aedomu 12,000 mʼChigwa cha Mchere. 
\q1  
\v 1 Inu Mulungu mwatikanatu ife, ndipo mwatiwonongera otiteteza. 
\q2 Inu mwatikwiyira, tsopano tibwezeretseni mwakale! 
\q1  
\v 2 Inu mwagwedeza dziko ndipo mwalingʼamba, 
\q2 konzani mingʼalu yake pakuti ikugwedezeka kwambiri. 
\q1  
\v 3 Inu mwaonetsa anthu anu nthawi za mavuto; 
\q2 inu mwatipatsa vinyo amene watichititsa kudzandira. 
\b  
\q1  
\v 4 Koma kwa iwo amene amaopa Inu, Inu mwakweza mbendera 
\q2 kuti tisonkhanireko pothawa uta. 
\b  
\q1  
\v 5 Tipulumutseni ndi kutithandiza ndi dzanja lanu lamanja, 
\q2 kuti iwo amene mumawakonda apulumutsidwe. 
\q1  
\v 6 Mulungu wayankhula kuchokera ku malo ake opatulika: 
\q2 “Mwakupambana ndidzagawa Sekemu 
\q2 ndipo ndidzayeza malire a chigwa cha Sukoti. 
\q1  
\v 7 Giliyadi ndi wanga, Manase ndi wanganso; 
\q2 Efereimu ndi chipewa changa chodzitetezera, 
\q2 Yuda ndi ndodo yanga yaufumu 
\q1  
\v 8 Mowabu ndi mbale yanga yosambira, 
\q2 pa Edomu ndidzaponyapo nsapato yanga, 
\q2 pa Filisitiya ndidzafuwula mwakupambana.” 
\b  
\q1  
\v 9 Adzandifikitse ndani ku mzinda wotetezedwa? 
\q2 Ndani adzanditsogolera ku Edomu? 
\q1  
\v 10 Kodi si Inu Mulungu, Inu amene mwatikana ife 
\q2 ndipo simutuluka pamodzi ndi magulu athu ankhondo. 
\q1  
\v 11 Tipatseni chithandizo kuti tilimbane ndi mdani wathu, 
\q2 pakuti thandizo lochokera kwa munthu ndi lopanda phindu. 
\q1  
\v 12 Chifukwa cha Mulungu, ife tidzapeza chipambano 
\q2 ndipo tidzapondaponda adani athu. 
\c 61  
\cl Salimo 61 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. Loyimbidwa ndi zipangizo za zingwe. 
\q1  
\v 1 Imvani kulira kwanga, Inu Mulungu; 
\q2 mvetserani pemphero langa. 
\b  
\q1  
\v 2 Kuchokera ku malekezero a dziko lapansi ine ndimayitana Inu 
\q2 ndimayitana pomwe mtima wanga ukufowoka; 
\q2 tsogolereni ku thanthwe lalitali kuposa ineyo. 
\q1  
\v 3 Pakuti Inu mwakhala pothawirapo panga, 
\q2 nsanja yolimba polimbana ndi adani anga. 
\b  
\q1  
\v 4 Ine ndikulakalaka kukhala mʼtenti yanu kwamuyaya 
\q2 ndi kupeza chitetezo mu mthunzi wa mapiko anu. 
\q1  
\v 5 Pakuti Inu Mulungu mwamva malumbiro anga; 
\q2 mwandipatsa cholowa cha iwo amene amaopa dzina lanu. 
\b  
\q1  
\v 6 Wonjezerani masiku a moyo wa mfumu, 
\q2 zaka zake kwa mibado yochuluka. 
\q1  
\v 7 Iye akhale pa mpando waufumu pamaso pa Mulungu kwamuyaya; 
\q2 ikani chikondi chanu ndi kukhulupirika kwanu kuti zimuteteze. 
\b  
\q1  
\v 8 Kotero ndidzayimba matamando kwamuyaya pa dzina lanu 
\q2 ndi kukwaniritsa malumbiro anga tsiku ndi tsiku. 
\c 62  
\cl Salimo 62 
\d Kwa mtsogoleri wa mayimbidwe. Kutsata mayimbidwe a Yedutuni. Salimo la Davide. 
\q1  
\v 1 Moyo wanga umapeza mpumulo mwa Mulungu yekha; 
\q2 chipulumutso changa chimachokera kwa Iye. 
\q1  
\v 2 Iye yekhayo ndiye thanthwe langa ndi chipulumutso changa; 
\q2 Iye ndi linga langa, choncho sindidzagwedezeka. 
\b  
\q1  
\v 3 Kodi nonsenu mudzalimbana naye munthu mpaka liti? 
\q2 Kodi mudzamugwetsa pansi ngati khoma losalimba, 
\q2 ngati mpanda wogwedezeka? 
\q1  
\v 4 Iwo akufunitsitsa kumugwetsa 
\q2 kuti achoke pa malo ake apamwamba. 
\q2 Iwo amakondweretsedwa ndi mabodza. 
\q1 Ndi pakamwa pawo amadalitsa 
\q2 koma mʼmitima yawo amatemberera. 
\b  
\q1  
\v 5 Peza mpumulo mwa Mulungu yekhayo iwe moyo wanga; 
\q2 chiyembekezo changa chichokera mwa Iye. 
\q1  
\v 6 Iye yekhayo ndiye thanthwe langa ndi chipulumutso changa; 
\q2 Iyeyo ndi linga langa; sindidzagwedezeka. 
\q1  
\v 7 Chipulumutso changa ndi ulemu wanga zimachokera kwa Mulungu: 
\q2 Iye ndiye thanthwe langa lamphamvu; Mulungu ndiye pothawira panga. 
\q1  
\v 8 Dalirani Iye nthawi zonse, inu anthu; 
\q2 khuthulani mitima yanu kwa Iye, 
\q2 pakuti Mulungu ndiye pothawirapo pathu. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 9 Anthu wamba ndi mpweya chabe; 
\q2 anthu apamwamba ndi bodza chabe; 
\q1 ngati atayezedwa pa sikelo iwo ndi chabe; 
\q2 iwowo pamodzi ndi mpweya ndi chabe 
\q1  
\v 10 Musadalire kulanda mwachinyengo 
\q2 kapena katundu wobedwa; 
\q1 ngakhale chuma chanu chichuluke, 
\q2 musayike mtima wanu pa icho. 
\b  
\q1  
\v 11 Mulungu wayankhula kamodzi, 
\q2 ine ndamvapo zinthu ziwiri; 
\q1 choyamba nʼchakuti Inu Mulungu ndinu wamphamvu, 
\q2  
\v 12 komanso Inu Ambuye, chikondi chanu nʼchosasinthika. 
\q1 Chachiwiri nʼchakuti mumamuchitira munthu 
\q2 molingana ndi ntchito zake. 
\c 63  
\cl Salimo 63 
\d Salimo la Davide. Pamene anali mʼchipululu cha Yuda. 
\q1  
\v 1 Inu Mulungu, ndinu Mulungu wanga, 
\q2 moona mtima ine ndimakufunafunani; 
\q1 moyo wanga uli ndi ludzu lofuna Inu, 
\q2 thupi langa likulakalaka inu, 
\q1 mʼdziko lowuma ndi lotopetsa 
\q2 kumene kulibe madzi. 
\b  
\q1  
\v 2 Inu ndinakuonani ku malo anu opatulika 
\q2 ndipo ndinapenya mphamvu zanu ndi ulemerero wanu. 
\q1  
\v 3 Chifukwa chikondi chanu 
\q2 ndi choposa moyo, milomo yanga idzakulemekezani. 
\q1  
\v 4 Ndidzakutamandani masiku onse a moyo wanga, 
\q2 ndipo mʼdzina lanu ndidzakweza manja anga. 
\q1  
\v 5 Mudzakhutitsa moyo wanga ndi zonona. 
\q2 Ine ndidzakutamandani ndi mawu anthetemya. 
\b  
\q1  
\v 6 Pa bedi panga ndimakumbukira inu; 
\q2 ndimaganiza za Inu nthawi yonse ya usiku. 
\q1  
\v 7 Chifukwa ndinu thandizo langa, 
\q2 ine ndimayimba mu mthunzi wa mapiko anu. 
\q1  
\v 8 Moyo wanga umakangamira Inu; 
\q2 dzanja lanu lamanja limandigwiriziza. 
\b  
\q1  
\v 9 Iwo amene akufunafuna moyo wanga adzawonongedwa; 
\q2 adzatsikira kunsi kozama kwa dziko lapansi. 
\q1  
\v 10 Iwo adzaperekedwa ku lupanga 
\q2 ndi kukhala chakudya cha ankhandwe. 
\b  
\q1  
\v 11 Koma mfumu idzakondwera mwa Mulungu; 
\q2 onse amene amalumbira mʼdzina la Mulungu adzalemekeza Mulunguyo, 
\q2 koma pakamwa pa anthu onama padzatsekedwa. 
\c 64  
\cl Salimo 64 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Ndimvereni Mulungu pomwe ndikunena madandawulo anga; 
\q2 tetezani moyo wanga ku chiopsezo cha mdani. 
\q1  
\v 2 Ndibiseni ku chiwembu cha anthu oyipa, 
\q2 ku gulu laphokoso la anthu ochita zoyipa. 
\b  
\q1  
\v 3 Iwo amanola malilime awo ngati malupanga, 
\q2 amaponya mawu awo olasa ngati mivi. 
\q1  
\v 4 Iwo amaponya mivi yawo ali pa malo wobisala kwa munthu wosalakwa; 
\q2 amamulasa modzidzimutsa ndi mopanda mantha. 
\b  
\q1  
\v 5 Iwo amalimbikitsana wina ndi mnzake pa chikonzero chawo choyipa, 
\q2 amayankhula zobisa misampha yawo; 
\q2 ndipo amati, “Adzayiona ndani?” 
\q1  
\v 6 Iwo amakonzekera zosalungama ndipo amati, 
\q2 “Takonza ndondomeko yabwino kwambiri!” 
\q2 Ndithu maganizo ndi mtima wa munthu ndi zachinyengo. 
\b  
\q1  
\v 7 Koma Mulungu adzawalasa ndi mivi; 
\q2 mwadzidzidzi adzakanthidwa. 
\q1  
\v 8 Iye adzatembenuza milomo yawoyo kuwatsutsa 
\q2 ndi kuwasandutsa bwinja; 
\q2 onse amene adzawaona adzagwedeza mitu yawo mowanyoza. 
\b  
\q1  
\v 9 Anthu onse adzachita mantha; 
\q2 adzalengeza ntchito za Mulungu 
\q2 ndi kulingalira mozama zomwe Iye wazichita. 
\q1  
\v 10 Lolani wolungama akondwere mwa Yehova 
\q2 ndi kubisala mwa Iye, 
\q2 owongoka mtima onse atamande Iye! 
\c 65  
\cl Salimo 65 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. Nyimbo. 
\q1  
\v 1 Matamando akudikira Inu Mulungu mu Ziyoni; 
\q2 kwa inu malumbiro athu adzakwaniritsidwa. 
\q1  
\v 2 Inu amene mumamva pemphero, 
\q2 kwa inu anthu onse adzafika. 
\q1  
\v 3 Pamene tinathedwa nzeru ndi machimo, 
\q2 Inu munakhululukira mphulupulu zathu. 
\q1  
\v 4 Odala iwo amene inu muwasankha 
\q2 ndi kuwabweretsa pafupi kukhala mʼmabwalo anu! 
\q1 Ife tadzazidwa ndi zinthu zabwino za mʼNyumba mwanu, 
\q2 za mʼNyumba yanu yoyera. 
\b  
\q1  
\v 5 Mumatiyankha ife ndi ntchito zodabwitsa zachilungamo, 
\q2 Inu Mulungu Mpulumutsi wathu, 
\q1 chiyembekezo cha mathero onse a dziko lapansi 
\q2 ndi cha nyanja zomwe zili kutali kwambiri, 
\q1  
\v 6 amene munapanga mapiri ndi mphamvu zanu, 
\q2 mutadziveka nokha ndi mphamvu. 
\q1  
\v 7 Amene munakhalitsa bata nyanja 
\q2 kukokoma kwa mafunde ake, 
\q2 ndi phokoso la anthu a mitundu ina. 
\q1  
\v 8 Iwo amene akukhala kutali amaopa zizindikiro zozizwitsa zanu; 
\q2 kumene dzuwa limatulukira ndi kumene dzuwa limalowera. 
\q2 Inu mumafuna nyimbo zachimwemwe. 
\b  
\q1  
\v 9 Inu mumasamalira dziko lapansi ndi kulithirira; 
\q2 Inuyo mumalilemeretsa kwambiri. 
\q1 Mtsinje wa Mulungu ndi wodzaza ndi madzi 
\q2 kuti upereke tirigu kwa anthu, 
\q2 pakuti Inu munakhazikitsa zimenezi. 
\q1  
\v 10 Mwadzaza nthaka yake ndi madzi ndi kusalaza migula yake, 
\q2 mwayifewetsa ndi mvula yamawawa ndi kudalitsa mbewu zake. 
\q1  
\v 11 Inu mumaveka chaka ndi zinthu zochuluka, 
\q2 ndipo ngolo zanu zimasefukira ndi zinthu zochuluka. 
\q1  
\v 12 Malo a udzu a mʼchipululu amasefukira; 
\q2 mapiri avekedwa ndi chisangalalo. 
\q1  
\v 13 Madambo akutidwa ndi zoweta 
\q2 ndi zigwa zavekedwa ndi tirigu; 
\q2 izo pamodzi zikufuwula ndi kuyimba mwachimwemwe. 
\c 66  
\cl Salimo 66 
\d Kwa mtsogoleri wa mayimbidwe. Salimo. 
\q1  
\v 1 Fuwulani kwa Mulungu ndi chimwemwe, dziko lonse lapansi! 
\q2  
\v 2 Imbani ulemerero wa dzina lake; 
\q2 kumutamanda kwake kukhale kwaulemerero. 
\q1  
\v 3 Nenani kwa Mulungu, “Ntchito zanu ndi zoopsa ndithu! 
\q2 Mphamvu yanu ndi yayikulu kwambiri 
\q2 kotero kuti adani anu amawerama pamaso panu. 
\q1  
\v 4 Dziko lonse lapansi limaweramira inu; 
\q2 limayimba matamando kwa Inu; 
\q2 limayimba matamando pa dzina lanu.” 
\q4 Sela. 
\b  
\q1  
\v 5 Bwerani mudzaone zimene Mulungu wachita, 
\q2 ntchito zanu ndi zoopsa ndithu pakati pa anthu. 
\q1  
\v 6 Iye anasandutsa nyanja kukhala malo owuma, 
\q2 iwo anawoloka pa madzi ndi mapazi. 
\q2 Bwerani, tiyeni tikondwere mwa Iye. 
\q1  
\v 7 Iye amalamulira ndi mphamvu zake mpaka muyaya, 
\q2 maso ake amayangʼanira anthu a mitundu ina. 
\q2 Anthu owukira asadzitukumule. 
\b  
\q1  
\v 8 Tamandani Mulungu wathu, inu mitundu ya anthu, 
\q2 mulole kuti mawu a matamando ake amveke; 
\q1  
\v 9 Iye watchinjiriza miyoyo yathu 
\q2 ndi kusunga mapazi athu kuti angaterereke. 
\q1  
\v 10 Pakuti Inu Mulungu munatiyesa; 
\q2 munatiyenga ngati siliva. 
\q1  
\v 11 Inu mwatilowetsa mʼndende 
\q2 ndi kutisenzetsa zolemera pa misana yathu. 
\q1  
\v 12 Inu munalola kuti anthu akwere pa mitu yathu; 
\q2 ife tinadutsa mʼmoto ndi mʼmadzi, 
\q2 koma Inu munatibweretsa ku malo a zinthu zochuluka. 
\b  
\q1  
\v 13 Ine ndidzabwera ku Nyumba yanu ndi nsembe zopsereza 
\q2 ndi kukwaniritsa malumbiro anga. 
\q1  
\v 14 Malumbiro amene milomo yanga inalonjeza 
\q2 ndi pakamwa panga panayankhula pamene ndinali pa mavuto. 
\q1  
\v 15 Ndidzapereka nsembe nyama zonenepa kwa Inu 
\q2 ndi chopereka cha nkhosa zazimuna; 
\q2 ndidzapereka ngʼombe zamphongo ndi mbuzi. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 16 Bwerani ndipo mudzamve inu nonse amene mumaopa Mulungu. 
\q2 Ndidzakuwuzani zimene Iyeyo wandichitira. 
\q1  
\v 17 Ndinafuwula kwa Iye ndi pakamwa panga, 
\q2 matamando ake anali pa lilime panga. 
\q1  
\v 18 Ndikanasekerera tchimo mu mtima mwanga 
\q2 Ambuye sakanamvera; 
\q1  
\v 19 koma ndithu Mulungu wamvetsera 
\q2 ndipo watchera khutu ku mawu a kupempha kwanga. 
\q1  
\v 20 Matamando akhale kwa Mulungu 
\q2 amene sanakane pemphero langa 
\q2 kapena kuletsa chikondi chake pa ine! 
\c 67  
\cl Salimo 67 
\d Kwa mtsogoleri wa mayimbidwe. Pa zoyimbira za zingwe. Salimo. 
\q1  
\v 1 Yehova atikomere mtima ndi kutidalitsa, 
\q2 achititse kuti nkhope yake itiwalire. 
\q1  
\v 2 Kuti njira zanu zidziwike pa dziko lapansi, 
\q2 chipulumutso chanu pakati pa mitundu yonse. 
\b  
\q1  
\v 3 Mitundu ya anthu ikutamandeni Inu Mulungu; 
\q2 mitundu yonse ya anthu ikutamandeni. 
\q1  
\v 4 Mitundu yonse ya anthu isangalale ndi kuyimba mwachimwemwe, 
\q2 pakuti inu mumaweruza mitundu ya anthu mwachilungamo 
\q2 ndi kutsogolera mitundu ya anthu a dziko lapansi. 
\q1  
\v 5 Mitundu ya anthu ikutamandeni Inu Mulungu; 
\q2 mitundu yonse ya anthu ikutamandeni. 
\b  
\q1  
\v 6 Nthaka yabereka zokolola zake; 
\q2 tidalitseni Mulungu wathu. 
\q1  
\v 7 Mulungu atidalitse 
\q2 kuti pamenepo malekezero onse a dziko lapansi apembedze Iyeyo. 
\c 68  
\cl Salimo 68 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Adzuke Mulungu, adani ake amwazikane; 
\q2 adani ake athawe pamaso pake. 
\q1  
\v 2 Monga momwe mphepo imachotsera utsi; Inu muwawulutsire kutali. 
\q2 Monga phula limasungunukira pa moto, 
\q2 oyipa awonongeke pamaso pa Mulungu. 
\q1  
\v 3 Koma olungama asangalale 
\q2 ndi kukondwera pamaso pa Mulungu; 
\q2 iwo akondwere ndi kusangalala. 
\b  
\q1  
\v 4 Imbirani Mulungu imbirani dzina lake matamando, 
\q2 mukwezeni Iye amene amakwera pa mitambo; 
\q2 dzina lake ndi Yehova ndipo sangalalani pamaso pake. 
\q1  
\v 5 Atate wa ana amasiye, mtetezi wa akazi amasiye, 
\q2 ndiye Mulungu amene amakhala mʼmalo oyera. 
\q1  
\v 6 Mulungu amakhazikitsa mtima pansi osungulumwa mʼmabanja, 
\q2 amatsogolera amʼndende ndi kuyimba; 
\q2 koma anthu osamvera amakhala ku malo owuma a dziko lapansi. 
\b  
\q1  
\v 7 Pamene munatuluka kutsogolera anthu anu, Inu Mulungu, 
\q2 pamene munayenda kudutsa chipululu, 
\q1  
\v 8 dziko lapansi linagwedezeka, miyamba inakhuthula pansi mvula, 
\q2 pamaso pa Mulungu, Mmodzi uja wa ku Sinai. 
\q2 Pamaso pa Mulungu, Mulungu wa Israeli. 
\q1  
\v 9 Munapereka mivumbi yochuluka, Inu Mulungu; 
\q2 munatsitsimutsa cholowa chanu cholefuka. 
\q1  
\v 10 Anthu anu anakhala mʼmenemo 
\q2 ndipo munapatsa anthu osauka zimene zinkawasowa chifukwa cha ubwino wanu Mulungu. 
\b  
\q1  
\v 11 Ambuye analengeza mawu, 
\q2 ndipo gulu linali lalikulu la iwo amene anapita kukawafalitsa; 
\q1  
\v 12 “Mafumu ndi ankhondo anathawa mwaliwiro; 
\q2 mʼmisasa anthu anagawana zolanda pa nkhondo. 
\q1  
\v 13 Ngakhale mukugona pakati pa makola a ziweto, 
\q2 mapiko a nkhunda akutidwa ndi siliva, 
\q2 nthenga zake ndi golide wonyezimira.” 
\q1  
\v 14 Pamene Wamphamvuzonse anabalalitsa mafumu mʼdziko, 
\q2 zinali ngati matalala akugwa pa Zalimoni. 
\b  
\q1  
\v 15 Mapiri a Basani ndi mapiri aulemerero; 
\q2 mapiri a Basani, ndi mapiri a msonga zambiri. 
\q1  
\v 16 Muyangʼaniranji mwansanje inu mapiri a msonga zambiri, 
\q2 pa phiri limene Mulungu analisankha kuti azilamulira, 
\q2 kumene Yehova mwini adzakhalako kwamuyaya? 
\q1  
\v 17 Magaleta a Mulungu ndi osawerengeka, 
\q2 ndi miyandamiyanda; 
\q2 Ambuye wabwera kuchokera ku Sinai, walowa mʼmalo ake opatulika. 
\q1  
\v 18 Pamene Inu munakwera mmwamba, 
\q2 munatsogolera a mʼndende ambiri; 
\q2 munalandira mphatso kuchokera kwa anthu, 
\q1 ngakhale kuchokera kwa owukira, 
\q2 kuti Inu Mulungu, mukhale kumeneko. 
\b  
\q1  
\v 19 Matamando akhale kwa Ambuye, kwa Mulungu Mpulumutsi wathu 
\q2 amene tsiku ndi tsiku amasenza zolemetsa zathu. 
\q1  
\v 20 Mulungu wathu ndi Mulungu amene amapulumutsa; 
\q2 Ambuye Wamphamvuzonse ndiye amene amatipulumutsa ku imfa. 
\b  
\q1  
\v 21 Ndithu Mulungu adzaphwanya mitu ya adani ake, 
\q2 zipewa za ubweya za iwo amene amapitiriza kuchita machimo awo. 
\q1  
\v 22 Ambuye akunena kuti, “Ndidzawabweretsa kuchokera ku Basani; 
\q2 ndidzawabweretsa kuchokera ku nyanja zozama. 
\q1  
\v 23 Kuti muviyike mapazi anu mʼmagazi a adani anu, 
\q2 pamene malilime a agalu anu akudyapo gawo lawo.” 
\b  
\q1  
\v 24 Mayendedwe aulemu a anthu anu aonekera poyera, Inu Mulungu; 
\q2 mayendedwe olemekeza Mulungu wanga ndi Mfumu yanga yokalowa mʼmalo opatulika. 
\q1  
\v 25 Patsogolo pali oyimba nyimbo pakamwa, pambuyo pawo oyimba nyimbo ndi zipangizo; 
\q2 pamodzi ndi iwo pali atsikana akuyimba matambolini. 
\q1  
\v 26 Tamandani Mulungu mu msonkhano waukulu; 
\q2 tamandani Yehova mu msonkhano wa Israeli. 
\q1  
\v 27 Pali fuko lalingʼono la Benjamini, kuwatsogolera, 
\q2 pali gulu lalikulu la ana a mafumu a Yuda, 
\q2 ndiponso pali ana a mafumu a Zebuloni ndi Nafutali. 
\b  
\q1  
\v 28 Kungani mphamvu zanu Mulungu; 
\q2 tionetseni nyonga zanu, Inu Mulungu, monga munachitira poyamba. 
\q1  
\v 29 Chifukwa cha Nyumba yanu ku Yerusalemu, 
\q2 mafumu adzabweretsa kwa Inu mphatso. 
\q1  
\v 30 Dzudzulani chirombo pakati pa mabango, 
\q2 gulu la ngʼombe zazimuna pakati pa ana angʼombe a mitundu ya anthu. 
\q1 Mochititsidwa manyazi, abweretse mitanda ya siliva. 
\q2 Balalitsani anthu a mitundu ina amene amasangalatsidwa ndi nkhondo. 
\q1  
\v 31 Nthumwi zidzachokera ku Igupto; 
\q2 Kusi adzadzipereka yekha kwa Mulungu. 
\b  
\q1  
\v 32 Imbirani Mulungu Inu mafumu a dziko lapansi 
\q2 imbirani Ambuye matamando. 
\q4 \qs Sela\qs* 
\q1  
\v 33 Kwa Iye amene amakwera pa mitambo yakalekale ya mmwamba 
\q2 amene amabangula ndi mawu amphamvu. 
\q1  
\v 34 Lengezani za mphamvu za Mulungu, 
\q2 amene ulemerero wake uli pa Israeli 
\q2 amene mphamvu zake zili mʼmitambo. 
\q1  
\v 35 Ndinu woopsa, Inu Mulungu mʼmalo anu opatulika; 
\q2 Mulungu wa Israeli amapereka mphamvu ndi nyonga kwa anthu ake. 
\b  
\q1 Matamando akhale kwa Mulungu! 
\c 69  
\cl Salimo 69 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. Potsata mayimbidwe a “Akakombo.” 
\q1  
\v 1 Pulumutseni Inu Mulungu, 
\q2 pakuti madzi afika mʼkhosi 
\q1  
\v 2 Ine ndikumira mʼthope lozama 
\q2 mʼmene mulibe popondapo. 
\q1 Ndalowa mʼmadzi ozama; 
\q2 mafunde andimiza. 
\q1  
\v 3 Ndafowoka ndikupempha chithandizo; 
\q2 kummero kwanga kwawuma gwaa, 
\q1 mʼmaso mwanga mwada 
\q2 kuyembekezera Mulungu wanga. 
\q1  
\v 4 Iwo amene amadana nane popanda chifukwa 
\q2 ndi ochuluka kuposa tsitsi la kumutu kwanga; 
\q1 ambiri ndi adani anga popanda chifukwa, 
\q2 iwo amene akufunafuna kundiwononga. 
\q1 Ndikukakamizidwa kubwezera 
\q2 zomwe sindinabe. 
\b  
\q1  
\v 5 Mukudziwa uchitsiru wanga, Inu Mulungu, 
\q2 kulakwa kwanga sikuli kobisika kwa Inu. 
\b  
\q1  
\v 6 Iwo amene amadalira Inu 
\q2 asanyozedwe chifukwa cha ine, 
\q2 Inu Ambuye Wamphamvuzonse. 
\q1 Iwo amene amafunafuna Inu 
\q2 asachititsidwe manyazi chifukwa cha ine, 
\q2 Inu Mulungu wa Israeli. 
\q1  
\v 7 Pakuti ndimapirira kunyozedwa chifukwa cha Inu, 
\q2 ndipo manyazi amaphimba nkhope yanga. 
\q1  
\v 8 Ndine mlendo kwa abale anga, 
\q2 munthu wakudza kwa ana aamuna a amayi anga; 
\q1  
\v 9 pakuti changu chochitira nyumba yanu chandiphetsa 
\q2 ndipo chipongwe cha iwo amene amanyoza Inu chandigwera. 
\q1  
\v 10 Pamene ndikulira ndi kusala kudya, 
\q2 ndiyenera kupirira kunyozedwa; 
\q1  
\v 11 pomwe ndavala chiguduli, 
\q2 anthu amandiseweretsa. 
\q1  
\v 12 Iwo amene amakhala pa chipata amandinena, 
\q2 ndipo ine ndine nyimbo ya zidakwa. 
\b  
\q1  
\v 13 Koma ndikupempha kwa Inu Ambuye, 
\q2 pa nthawi yanu yondikomera mtima; 
\q1 mwa chikondi chanu chachikulu 
\q2 Inu Mulungu, mundiyankhe pondipulumutsa. 
\q1  
\v 14 Mundilanditse kuchoka mʼmatope, 
\q2 musalole kuti ndimire, 
\q1 pulumutseni ine kwa iwo 
\q2 amene amadana nane, kuchoka mʼmadzi ozama. 
\q1  
\v 15 Musalole kuti chigumula chindimeze, 
\q2 kuya kusandimeze 
\q2 ndipo dzenje lisatseke pakamwa pake kundimiza. 
\q1  
\v 16 Ndiyankheni Inu Yehova mwa ubwino wanu wa chikondi chanu; 
\q2 mwa chifundo chanu chachikulu tembenukirani kwa ine. 
\q1  
\v 17 Musabisire nkhope yanu mtumiki wanu, 
\q2 ndiyankheni msanga, pakuti ndili pa mavuto. 
\q1  
\v 18 Bwerani pafupi ndi kundilanditsa; 
\q2 ndiwomboleni chifukwa cha adani anga. 
\b  
\q1  
\v 19 Inu mukudziwa momwe ndanyozedwera, 
\q2 kunyozedwa ndi kuchititsidwa manyazi; adani anga onse ali pamaso panu. 
\q1  
\v 20 Mnyozo waswa mtima wanga 
\q2 ndipo wandisiya wopanda thandizo lililonse; 
\q1 ndinafunafuna ena woti andichitire chisoni, 
\q2 koma panalibe ndi mmodzi yemwe woti anditonthoze, sindinapeze ndi mmodzi yemwe. 
\q1  
\v 21 Iwo anayika ndulu mʼchakudya changa 
\q2 ndi kundipatsa vinyo wosasa chifukwa cha ludzu. 
\b  
\q1  
\v 22 Chakudya chomwe chayikidwa patsogolo pawo chikhale msampha; 
\q2 chikhale chobwezera chilango ndiponso khwekhwe. 
\q1  
\v 23 Maso awo adetsedwe kotero kuti asaonenso 
\q2 ndipo misana yawo ipindike mpaka kalekale. 
\q1  
\v 24 Khuthulirani ukali wanu pa iwo; 
\q2 mkwiyo wanu woyaka moto uwathe mphamvu. 
\q1  
\v 25 Malo awo akhale wopanda anthu 
\q2 pasapezeke ndi mmodzi yemwe wokhala mʼmatenti awo. 
\q1  
\v 26 Pakuti iwo amazunza amene inu munamuvulaza 
\q2 ndi kuyankhula zowawa kwa amene munawapweteka. 
\q1  
\v 27 Awonjezereni kulakwa pa kulakwa kwawo, 
\q2 musalole kuti akhale ndi gawo pa chipulumutso chanu. 
\q1  
\v 28 Iwo afufutidwe mʼbuku la amoyo 
\q2 ndipo asalembedwe pamodzi ndi olungama. 
\b  
\q1  
\v 29 Ndikumva zowawa ndi kuzunzika; 
\q2 lolani chipulumutso chanu, Inu Mulungu, chinditeteze. 
\b  
\q1  
\v 30 Ine ndidzatamanda dzina la Mulungu mʼnyimbo, 
\q2 ndidzalemekeza Iye ndi chiyamiko. 
\q1  
\v 31 Izi zidzakondweretsa Yehova kupambana ngʼombe, 
\q2 kupambananso ngʼombe yayimuna, pamodzi ndi nyanga ndi ziboda zake. 
\q1  
\v 32 Wosauka adzaona ndipo adzasangalala, 
\q2 Inu amene mumafunafuna Mulungu, mitima yanu ikhale ndi moyo! 
\q1  
\v 33 Yehova amamvera anthu osowa 
\q2 ndipo sanyoza anthu ake omangidwa. 
\b  
\q1  
\v 34 Kumwamba ndi dziko lapansi zitamanda Iye, 
\q2 nyanja ndi zonse zomwe zimayenda mʼmenemo, 
\q1  
\v 35 pakuti Mulungu adzapulumutsa Ziyoni 
\q2 ndi kumanganso mizinda ya Yuda, 
\q1 anthu adzakhala kumeneko ndipo dzikolo lidzakhala lawo; 
\q2  
\v 36 ana atumiki ake adzalitenga kukhala cholowa chawo, 
\q2 ndipo iwo amene amakonda dzina lake adzakhala kumeneko. 
\c 70  
\cl Salimo 70 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. Pempho. 
\q1  
\v 1 Fulumirani Mulungu kundipulumutsa; 
\q2 Yehova bwerani msanga kudzandithandiza. 
\q1  
\v 2 Iwo amene akufunafuna moyo wanga 
\q2 achititsidwe manyazi ndi kusokonezedwa; 
\q1 onse amene akukhumba chiwonongeko changa 
\q2 abwezedwe mopanda ulemu. 
\q1  
\v 3 Onse amene akunena kwa ine kuti, “Aha, aha,” 
\q2 abwerere chifukwa cha manyazi awo. 
\q1  
\v 4 Koma onse amene akufunafuna Inu 
\q2 akondwere ndi kusangalala mwa Inu; 
\q1 iwo amene amakonda chipulumutso chanu 
\q2 nthawi zonse anene kuti, “Mulungu akuzike!” 
\b  
\q1  
\v 5 Koma ine ndine wosauka ndi wosowa; 
\q2 bwerani msanga kwa ine Inu Mulungu. 
\q1 Inu ndinu thandizo langa ndi momboli wanga; 
\q2 Inu Yehova musachedwe. 
\c 71  
\cl Salimo 71 
\q1  
\v 1 Mwa Inu Yehova ine ndathawiramo; 
\q2 musalole kuti ndichititsidwe manyazi. 
\q1  
\v 2 Mundilanditse ndi kundipulumutsa mwa chilungamo chanu, 
\q2 mutchere khutu lanu ndi kundipulumutsa. 
\q1  
\v 3 Mukhale thanthwe langa lothawirapo, 
\q2 kumene ine nditha kupita nthawi zonse; 
\q1 lamulani kuti ndipulumuke, 
\q2 pakuti Inu ndinu thanthwe langa ndi linga langa. 
\q1  
\v 4 Landitseni Inu Mulungu wanga, kuchoka mʼdzanja la oyipa, 
\q2 kuchoka mʼdzanja la oyipa ndi anthu ankhanza. 
\b  
\q1  
\v 5 Pakuti Inu mwakhala chiyembekezo changa, Inu Ambuye Wamphamvuzonse, 
\q2 chilimbikitso changa kuyambira ndili mwana. 
\q1  
\v 6 Kuyambira pamene ndinabadwa, ndakhala ndikudalira Inu; 
\q2 Inu munanditulutsa mʼmimba mwa amayi anga, 
\q2 ndipo ndidzakupembedzani nthawi zonse. 
\q1  
\v 7 Ine ndakhala chinthu chodabwitsa kwa anthu ambiri 
\q2 koma Inu ndinu wonditchinjiriza wamphamvu. 
\q1  
\v 8 Pakamwa panga padzaza ndi matamando anu, 
\q2 kulengeza ulemerero wanu tsiku lonse. 
\b  
\q1  
\v 9 Musanditaye pamene ndakalamba; 
\q2 musandisiye pamene mphamvu zanga zatha. 
\q1  
\v 10 Pakuti adani anga ayankhula motsutsana nane; 
\q2 iwo amene amadikira kuti andiphe amapangana pamodzi. 
\q1  
\v 11 Iwo amati, “Mulungu wamusiya; 
\q2 mutsatireni ndi kumugwira, 
\q2 pakuti palibe amene adzamupulumutse.” 
\q1  
\v 12 Musakhale kutali ndi ine Inu Mulungu, 
\q2 bwerani msanga, Inu Mulungu wanga; thandizeni. 
\q1  
\v 13 Ondineneza anga awonongeke mwa manyazi, 
\q2 iwo amene akufuna kundipweteka 
\q2 avale chitonzo ndi manyazi. 
\b  
\q1  
\v 14 Koma ine ndidzakhala ndi chiyembekezo mwa Inu nthawi zonse, 
\q2 ndidzakutamandani mowirikizawirikiza. 
\q1  
\v 15 Pakamwa panga padzafotokoza za chilungamo chanu, 
\q2 za chipulumutso chanu tsiku lonse, 
\q2 ngakhale sindikudziwa muyeso wake. 
\q1  
\v 16 Ndidzabwera ndi kulengeza za machitidwe amphamvu zanu Inu Ambuye Wamphamvuzonse. 
\q2 Ndidzalengeza chilungamo chanu, chanu chokha. 
\q1  
\v 17 Kuyambira ubwana wanga, Inu Mulungu mwakhala mukundiphunzitsa, 
\q2 ndipo mpaka lero ine ndikulengeza za ntchito zanu zodabwitsa 
\q1  
\v 18 Ngakhale pamene ndakalamba ndipo imvi zili mbuu 
\q2 musanditaye Inu Mulungu, 
\q1 mpaka nditalengeza mphamvu zanu 
\q2 kwa mibado yonse yakutsogolo. 
\b  
\q1  
\v 19 Mphamvu zanu ndi kulungama kwanu zimafika mpaka kumwambamwamba. 
\q2 Ndani wofanana nanu Inu Mulungu, 
\q2 amene mwachita zazikulu? 
\q1  
\v 20 Ngakhale mwandionetsa mavuto 
\q2 ambiri owawa, 
\q1 mudzabwezeretsanso moyo wanga; 
\q2 kuchokera kunsi kwa dziko lapansi, 
\q2 mudzandiukitsanso. 
\q1  
\v 21 Inu mudzachulukitsa ulemu wanga 
\q2 ndi kunditonthozanso. 
\b  
\q1  
\v 22 Ndidzakutamandani ndi zeze 
\q2 chifukwa cha kukhulupirika kwanu Mulungu, 
\q1 ndidzayimba matamando kwa Inu ndi pangwe, 
\q2 Inu Woyera wa Israeli. 
\q1  
\v 23 Milomo yanga idzafuwula ndi chimwemwe 
\q2 pamene ndidzayimba matamando kwa Inu 
\q2 amene mwandiwombola. 
\q1  
\v 24 Lilime langa lidzafotokoza za ntchito zanu zachilungamo 
\q2 tsiku lonse, 
\q1 pakuti iwo amene amafuna kundipweteka 
\q2 achititsidwa manyazi ndi kusokonezedwa. 
\c 72  
\cl Salimo 72 
\d Salimo la Solomoni. 
\q1  
\v 1 Patsani mwana wa mfumu nzeru zanu zoweruzira mwa chilungamo, 
\q2 Inu Mulungu mupatseni mwana wa mfumu chilungamo chanu. 
\q1  
\v 2 Iye adzaweruza anthu anu mwachilungamo, 
\q2 anthu anu ozunzika mosakondera. 
\q1  
\v 3 Mapiri adzabweretsa chuma kwa anthu anu, 
\q2 timapiri tidzabweretsa zipatso zachilungamo. 
\q1  
\v 4 Iye adzateteza ozunzika pakati pa anthu 
\q2 ndi kupulumutsa ana a anthu osowa; 
\q2 adzaphwanya ozunza anzawo. 
\b  
\q1  
\v 5 Adzakhala ndi moyo pa mibado yonse, 
\q2 nthawi zonse pamene dzuwa ndi mwezi zikuwala. 
\q1  
\v 6 Iye adzakhala kugwa kwa mvula pa minda yolimidwa 
\q2 ngati mivumbi yothirira dziko lapansi. 
\q1  
\v 7 Mʼmasiku a munthu wolungama adzakhazikika; 
\q2 chuma chidzachuluka mpaka mwezi utaleka kuwala. 
\b  
\q1  
\v 8 Iye adzalamulira kuchokera ku nyanja ina mpaka ku nyanja ina 
\q2 ndiponso kuchokera ku mtsinje mpaka ku malekezero a dziko lapansi. 
\q1  
\v 9 Mafuko a mʼchipululu adzawerama pamaso pake 
\q2 ndipo adani ake adzanyambita fumbi. 
\q1  
\v 10 Mafumu a ku Tarisisi ndi a ku zilumba zakutali 
\q2 adzabweretsa mitulo kwa iye, 
\q1 mafumu a ku Seba ndi Seba 
\q2 adzapereka mphatso kwa iyeyo. 
\q1  
\v 11 Mafumu onse adzamuweramira 
\q2 ndipo mitundu yonse idzamutumikira. 
\b  
\q1  
\v 12 Pakuti iye adzawombola wosowa amene akulira, 
\q2 wozunzika amene alibe wina womuthandiza. 
\q1  
\v 13 Iye adzachitira chifundo anthu ofowoka ndi anthu osowa 
\q2 ndi kupulumutsa osowa ku imfa. 
\q1  
\v 14 Iye adzalanditsa iwo ku mazunzo ndi chiwawa 
\q2 pakuti magazi awo ndi amtengo wapatali pamaso pake. 
\b  
\q1  
\v 15 Iye akhale ndi moyo wautali; 
\q2 golide ochokera ku Seba apatsidwe kwa iye. 
\q1 Anthu amupempherere nthawi zonse 
\q2 ndi kumudalitsa tsiku lonse. 
\q1  
\v 16 Mulole kuti tirigu achuluke mʼdziko lonse; 
\q2 pamwamba pa mapiri pakhale tirigu. 
\q1 Zipatso zake zichuluke ngati za ku Lebanoni; 
\q2 zichuluke ngati udzu wakuthengo 
\q1  
\v 17 Dzina lake likhazikike kwamuyaya, 
\q2 lipitirire kukhala monga momwe limakhalira dzuwa. 
\b  
\q1 Mitundu yonse idzadalitsika kudzera mwa iye 
\q2 ndipo iwo adzamutcha iye wodala. 
\b  
\q1  
\v 18 Matamando akhale kwa Yehova Mulungu, Mulungu wa Israeli 
\q2 amene Iye yekha amachita ntchito zodabwitsa. 
\q1  
\v 19 Matamando akhale ku dzina lake laulemerero kwamuyaya 
\q2 dziko lonse lapansi lidzaze ndi ulemerero wake. 
\q4 Ameni ndi Ameni. 
\b  
\q1  
\v 20 Uku ndiko kumaliza kwa mapemphero a Davide mwana wa Yese. 
\c 73  
\ms1 BUKU LACHITATU 
\mr Masalimo 73–89 
\cl Salimo 73 
\d Salimo la Asafu. 
\q1  
\v 1 Mulungu ndi wabwino ndithu kwa Israeli, 
\q2 kwa iwo amene ndi oyera mtima. 
\b  
\q1  
\v 2 Koma kunena za ine, mapazi anga anali pafupi kuterereka; 
\q2 ndinatsala pangʼono kugwa. 
\q1  
\v 3 Pakuti ndinkachitira nsanje odzitamandira, 
\q2 pamene ndinaona mtendere wa anthu oyipa. 
\b  
\q1  
\v 4 Iwo alibe zosautsa; 
\q2 matupi awo ndi athanzi ndi amphamvu. 
\q1  
\v 5 Saona mavuto monga anthu ena; 
\q2 sazunzika ngati anthu ena onse. 
\q1  
\v 6 Nʼchifukwa chake kunyada kuli monga mkanda wa mʼkhosi mwawo; 
\q2 amadziveka chiwawa. 
\q1  
\v 7 Mʼmitima yawo yokhota mumachokera zolakwa; 
\q2 zoyipa zochokera mʼmaganizo awo sizidziwa malire. 
\q1  
\v 8 Iwowo amanyogodola ndi kumayankhula zoyipa; 
\q2 mwa kudzikuza kwawo amaopseza ena nʼkumati, “Tikuponderezani.” 
\q1  
\v 9 Pakamwa pawo pamayankhula monyoza Mulungu kumwamba 
\q2 ndipo lilime lawo limayenda pa dziko lapansi. 
\q1  
\v 10 Nʼchifukwa chake anthu awo amapita kwa iwowo 
\q2 ndi kumwa madzi mochuluka. 
\q1  
\v 11 Iwo amati, “Kodi Mulungu angadziwe bwanji? 
\q2 Kodi Wammwambamwamba angadziwe kalikonse?” 
\b  
\q1  
\v 12 Umu ndi mmene oyipa alili; 
\q2 nthawi zonse ali pabwino ndipo chuma chawo chimachulukirachulukira. 
\b  
\q1  
\v 13 Ndithudi ine ndawusunga pachabe mtima wanga woyera; 
\q2 pachabe ndasamba mʼmanja mwanga mwa kusalakwa kwanga. 
\q1  
\v 14 Tsiku lonse ndapeza mavuto; 
\q2 ndakhala ndi kulangidwa mmawa uliwonse. 
\b  
\q1  
\v 15 Ndikanati, “Ndidzayankhula motere,” 
\q2 ndikanachita chosakhulupirika kwa ana anu. 
\q1  
\v 16 Pamene ndinayesa kuti ndimvetse zonsezi, 
\q2 zinandisautsa kwambiri 
\q1  
\v 17 kufikira nditalowa mʼmalo opatulika a Mulungu; 
\q2 pamenepo ndinamvetsa mathero awo. 
\b  
\q1  
\v 18 Zoonadi Inu munawayika pa malo woterera; 
\q2 Mumawagwetsa pansi kuti awonongeke. 
\q1  
\v 19 Mwamsangamsanga iwo amawonongedwa, 
\q2 amasesedwa kwathunthu ndi mantha! 
\q1  
\v 20 Monga loto pamene wina adzuka, 
\q2 kotero pamene Inu muuka, Inu Ambuye, 
\q2 mudzawanyoza ngati maloto chabe. 
\b  
\q1  
\v 21 Pamene mtima wanga unasautsidwa 
\q2 ndi kuwawidwa mu mzimu mwanga, 
\q1  
\v 22 ndinali wopusa ndi wosadziwa; 
\q2 ndinali chirombo chopanda nzeru pamaso panu. 
\b  
\q1  
\v 23 Komabe ineyo ndili ndi Inu nthawi zonse; 
\q2 mumandigwira dzanja langa lamanja. 
\q1  
\v 24 Inu mumanditsogolera ndi malangizo anu 
\q2 ndipo pambuyo pake mudzanditenga ku ulemerero. 
\q1  
\v 25 Kodi kumwamba ndili ndi yani kupatula Inu? 
\q2 Ndipo dziko lapansi lilibe chilichonse chimene ndimachilakalaka koposa Inuyo. 
\q1  
\v 26 Thupi ndi mtima wanga zitha kufowoka, 
\q2 koma Mulungu ndiye mphamvu ya mtima wanga 
\q2 ndi cholandira changa kwamuyaya. 
\b  
\q1  
\v 27 Iwo amene ali kutali ndi Inu adzawonongeka; 
\q2 Inu mumawononga onse osakhulupirika pamaso panu. 
\q1  
\v 28 Koma kunena za Ine ndi kwabwino kukhala pafupi ndi Mulungu. 
\q2 Ndatsimikiza kuti Ambuye Yehova ndiwo pothawirapo panga 
\q2 ndipo ndidzalalika ntchito zanu zonse. 
\c 74  
\cl Salimo 74 
\d Ndakatulo ya Asafu. 
\q1  
\v 1 Nʼchifukwa chiyani mwatitaya ife kwamuyaya, Inu Mulungu? 
\q2 Chifukwa chiyani mkwiyo wanu ukutukutira pa nkhosa za busa lanu? 
\q1  
\v 2 Kumbukirani anthu amene munawagula kalekale, 
\q2 fuko la cholowa chanu, limene Inu munaliwombola, 
\q2 phiri la Ziyoni, kumene inuyo mumakhala. 
\q1  
\v 3 Tembenuzani mapazi kuloza ku mabwinja awa amuyaya 
\q2 chiwonongeko ichi chonse mdani wabweretsa pa malo opatulika. 
\b  
\q1  
\v 4 Adani anu anabangula pa malo pamene Inu munkakumana nafe; 
\q2 anayimika mbendera zawo monga zizindikiro zachigonjetso. 
\q1  
\v 5 Iwo anachita ngati anthu oti anyamula mbendera zawo 
\q2 kuti adule mitengo mʼnkhalango. 
\q1  
\v 6 Kenaka anaphwanya ndi nkhwangwa ndi akasemasema awo 
\q2 zonse zimene tinapachika. 
\q1  
\v 7 Iwo anatentha malo anu opatulika mpaka kuwagwetsa pansi; 
\q2 anadetsa malo okhalamo dzina lanu. 
\q1  
\v 8 Ndipo anati mʼmitima yawo, “Tawatha kwathunthu.” 
\q2 Anatentha malo aliwonse amene Mulungu amapembedzedwerako mʼdzikomo. 
\q1  
\v 9 Ife sitinapatsidwe chizindikiro chodabwitsa; 
\q2 palibe aneneri amene atsala 
\q2 ndipo palibe aliyense wa ife akudziwa kuti izi zidzatenga nthawi yayitali bwanji. 
\b  
\q1  
\v 10 Kodi mpaka liti, mdani adzanyoze Inu Mulungu? 
\q2 Kodi amaliwongowa adzapeputsa dzina lanu kwamuyaya? 
\q1  
\v 11 Chifukwa chiyani mukubweza dzanja lanu lamanja? 
\q2 Litulutseni kuchoka pachifuwa chanu ndipo muwawononge! 
\b  
\q1  
\v 12 Koma Inu Mulungu, ndinu Mfumu yanga kuyambira kalekale; 
\q2 Mumabweretsa chipulumutso pa dziko lapansi. 
\q1  
\v 13 Ndinu amene munagawa nyanja ndi mphamvu yanu; 
\q2 munathyola mitu ya zirombo za mʼmadzi. 
\q1  
\v 14 Ndinu amene munaphwanya mitu ya Leviyatani 
\q2 ndi kuyipereka ngati chakudya cha zirombo za mʼchipululu. 
\q1  
\v 15 Ndinu amene munatsekula akasupe ndi mitsinje, 
\q2 munawumitsa mitsinje imene siphwa nthawi zonse. 
\q1  
\v 16 Masana ndi anu ndipo usiku ndi wanunso; 
\q2 Inuyo munakhazikitsa dzuwa ndi mwezi. 
\q1  
\v 17 Ndinu amene munakhazikitsa malire onse a dziko lapansi; 
\q2 munakhazikitsa chilimwe ndi dzinja. 
\b  
\q1  
\v 18 Kumbukirani momwe mdani wakunyozerani Inu Yehova, 
\q2 momwe anthu opusa apeputsira dzina lanu. 
\q1  
\v 19 Musapereke moyo wa nkhunda yanu ku zirombo zakuthengo; 
\q2 nthawi zonse musayiwale miyoyo ya anthu anu osautsidwa. 
\q1  
\v 20 Mukumbukire pangano lanu, pakuti malo obisika a mʼdziko 
\q2 asanduka mochitira zachiwawa zochuluka. 
\q1  
\v 21 Musalole kuti osautsidwa abwerere mwamanyazi; 
\q2 osauka ndi osowa atamande dzina lanu. 
\b  
\q1  
\v 22 Dzukani Inu Mulungu ndipo dzitetezeni pa mlandu; 
\q2 kumbukirani momwe opusa akukunyozerani tsiku lonse. 
\q1  
\v 23 Musalekerere phokoso la otsutsana nanu, 
\q2 chiwawa cha adani anu, chimene chikumveka kosalekeza. 
\c 75  
\cl Salimo 75 
\d Kwa mtsogoleri wa mayimbidwe, potsata mayimbidwe a “Musawononge.” Salimo la Asafu. Nyimbo. 
\q1  
\v 1 Tikuthokoza Inu Mulungu, 
\q2 tikuthokoza, pakuti dzina lanu lili pafupi nafe, 
\q2 anthutu amafotokoza za ntchito zanu zodabwitsa. 
\b  
\q1  
\v 2 Mumati, “Ine ndimayika nthawi yoyenera, 
\q2 ndine amene ndimaweruza mwachilungamo. 
\q1  
\v 3 Pamene dziko lapansi ndi anthu ake onse anjenjemera, 
\q2 ndine amene ndimagwiriziza mizati yake molimba. 
\q4 \qs Sela\qs* 
\q1  
\v 4 Kwa odzitama ndikuti, ‘Musadzitamenso,’ 
\q2 ndipo kwa oyipa, ‘Musatukulenso nyanga zanu. 
\q1  
\v 5 Musatukule nyanga zanu motsutsana ndi kumwamba; 
\q2 musayankhule ndi khosi losololoka.’ ” 
\b  
\q1  
\v 6 Kugamula milandu sikuchokera kummawa kapena kumadzulo 
\q2 kapena ku chipululu. 
\q1  
\v 7 Koma ndi Mulungu amene amaweruza: 
\q2 Iyeyo amatsitsa wina, nakwezanso wina. 
\q1  
\v 8 Mʼdzanja la Yehova muli chikho 
\q2 chodzaza ndi vinyo wochita thovu, wosakanizidwa ndi zokometsera; 
\q1 Iye amamutsanulira pansi ndipo onse oyipa a dziko lapansi 
\q2 amamwa ndi senga zake zonse. 
\b  
\q1  
\v 9 Kunena za ine, ndidzalengeza izi kwamuyaya; 
\q2 ndidzayimba matamando kwa Mulungu wa Yakobo. 
\q1  
\v 10 Ndidzadula nyanga za onse oyipa 
\q2 koma nyanga za olungama zidzakwezedwa. 
\c 76  
\cl Salimo 76 
\d Kwa mtsogoleri wa mayimbidwe. Pa zoyimbira za zingwe. Salimo la Asafu. 
\q1  
\v 1 Mulungu amadziwika mu Yuda; 
\q2 dzina lake ndi lotchuka mu Israeli. 
\q1  
\v 2 Tenti yake ili mu Salemu, 
\q2 malo ake okhalamo mu Ziyoni. 
\q1  
\v 3 Kumeneko Iye anathyola mivi yowuluka, 
\q2 zishango ndi malupanga, zida zankhondo. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 4 Wolemekezeka ndinu, 
\q2 wamphamvu kuposa mapiri amene ali ndi nyama zambiri. 
\q1  
\v 5 Anthu owuma mtima amagona atalandidwa chuma, 
\q2 Iwowo amagona tulo tawo totsiriza; 
\q1 palibe mmodzi wamphamvu 
\q2 amene angatukule manja ake. 
\q1  
\v 6 Pa kudzudzula kwanu, Inu Mulungu wa Yakobo, 
\q2 kavalo pamodzi ndi galeta zimakhala chete zitagona pansi. 
\q1  
\v 7 Inu nokha ndiye muyenera kuopedwa. 
\q2 Angathe kuyima pamaso panu ndani mukakwiya? 
\q1  
\v 8 Kuchokera kumwamba Inu munalengeza chiweruzo, 
\q2 ndipo dziko linaopa ndi kukhala chete, 
\q1  
\v 9 pamene Inu Mulungu munadzuka kuti muweruze, 
\q2 kupulumutsa onse osautsidwa mʼdziko. 
\q4 \qs Sela\qs* 
\q1  
\v 10 Zoonadi, ukali wanu pa anthu umakubweretserani matamando 
\q2 ndipo opulumuka ku ukali wanu mumawasunga pafupi nanu. 
\b  
\q1  
\v 11 Chitani malumbiro kwa Yehova Mulungu wanu ndipo muwakwaniritse; 
\q2 anthu onse omuzungulira abweretse mphatso 
\q2 kwa Iye amene ayenera kuopedwa. 
\q1  
\v 12 Iye amaswa mzimu wa olamulira; 
\q2 amaopedwa ndi mafumu a dziko lapansi. 
\c 77  
\cl Salimo 77 
\d Kwa mtsogoleri wa mayimbidwe. Potsata mayimbidwe a Yedutuni. Salimo la Asafu. 
\q1  
\v 1 Ndinafuwulira Mulungu kupempha thandizo; 
\q2 ndinafuwula mokweza kwa Mulungu kuti anditcherere khutu. 
\q1  
\v 2 Pamene ndinali pa masautso ndinafunafuna Ambuye; 
\q2 usiku ndinatambasula manja mosalekeza 
\q2 ndipo moyo wanga unakana kutonthozedwa. 
\b  
\q1  
\v 3 Ndinakumbukira Inu Mulungu, ndipo ndinabuwula; 
\q2 ndinasinkhasinkha ndipo mzimu wanga unalefuka. 
\q4 \qs Sela\qs* 
\q1  
\v 4 Munagwira zikope zanga kuti ndisagone 
\q2 ndipo ndinavutika kwambiri kuti ndiyankhule. 
\q1  
\v 5 Ndinaganizira za masiku akale, 
\q2 zaka zamakedzana; 
\q1  
\v 6 Ndinakumbukira nyimbo zanga usiku. 
\q2 Mtima wanga unasinkhasinkha ndipo mzimu wanga unafunsa kuti, 
\b  
\q1  
\v 7 “Kodi Ambuye adzatikana mpaka muyaya? 
\q2 Kodi Iwo sadzaonetsanso kukoma mtima kwawo? 
\q1  
\v 8 Kodi Chikondi chake chosatha chija chatheratu? 
\q2 Kodi malonjezo ake alephera nthawi yonse? 
\q1  
\v 9 Kodi Mulungu wayiwala kukhala wokoma mtima? 
\q2 Kodi mu mkwiyo wake waleka chifundo chake?” 
\b  
\q1  
\v 10 Ndipo ndinaganiza, “Pa izi ine ndidzapemphanso: 
\q2 zaka za dzanja lamanja la Wammwambamwamba. 
\q1  
\v 11 Ine ndidzakumbukira ntchito za Yehova; 
\q2 Ine ndidzakumbukira zodabwitsa zanu za kalekale. 
\q1  
\v 12 Ndidzakumbukira ntchito zanu 
\q2 ndi kulingalira zodabwitsa zanu.” 
\b  
\q1  
\v 13 Njira zanu Mulungu ndi zoyera. 
\q2 Kodi ndi mulungu uti ali wamkulu kuposa Mulungu wathu? 
\q1  
\v 14 Inu ndinu Mulungu wochita zodabwitsa; 
\q2 Mumaonetsera mphamvu yanu pakati pa mitundu ya anthu. 
\q1  
\v 15 Ndi dzanja lanu lamphamvu munawombola anthu anu, 
\q2 zidzukulu za Yakobo ndi Yosefe. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 16 Madzi anakuonani Mulungu, 
\q2 madzi anakuonani ndipo anachita mantha; 
\q2 nyanja yozama inakomoka. 
\q1  
\v 17 Mitambo inakhuthula madzi ake pansi, 
\q2 mu mlengalenga munamveka mabingu; 
\q2 mivi yanu inawuluka uku ndi uku. 
\q1  
\v 18 Bingu lanu linamveka mʼmphepo ya kamvuluvulu, 
\q2 mphenzi yanu inawalitsa dziko lonse; 
\q2 dziko lapansi linanjenjemera ndi kugwedezeka. 
\q1  
\v 19 Njira yanu inadutsa pa nyanja, 
\q2 njira yanu inadutsa pa madzi amphamvu, 
\q2 ngakhale zidindo za mapazi anu sizinaoneke. 
\b  
\q1  
\v 20 Inu munatsogolera anthu anu ngati gulu la nkhosa 
\q2 mwa dzanja la Mose ndi Aaroni. 
\c 78  
\cl Salimo 78 
\d Ndakatulo ya Asafu. 
\q1  
\v 1 Inu anthu anga imvani chiphunzitso changa; 
\q2 mvetserani mawu a pakamwa panga. 
\q1  
\v 2 Ndidzatsekula pakamwa panga mʼmafanizo, 
\q2 ndidzayankhula zinthu zobisika, zinthu zakalekale 
\q1  
\v 3 zimene tinazimva ndi kuzidziwa, 
\q2 zimene makolo athu anatiwuza. 
\q1  
\v 4 Sitidzabisira ana awo, 
\q2 tidzafotokozera mʼbado wotsatira 
\q1 ntchito zotamandika za Yehova, 
\q2 mphamvu zake, ndi zozizwitsa zimene Iye wachita. 
\q1  
\v 5 Iye anapereka mawu wodzichitira umboni kwa Yakobo 
\q2 ndi kukhazikitsa lamulo mu Israeli, 
\q1 zimene analamulira makolo athu 
\q2 kuphunzitsa ana awo, 
\q1  
\v 6 kotero kuti mʼbado wotsatira uthe kuzidziwa, 
\q2 ngakhale ana amene sanabadwe, 
\q2 ndi kuti iwo akafotokozere ana awonso. 
\q1  
\v 7 Choncho iwo adzakhulupirira Mulungu 
\q2 ndipo sadzayiwala ntchito zake 
\q2 koma adzasunga malamulo ake. 
\q1  
\v 8 Iwo asadzakhale monga makolo awo, 
\q2 mʼbado wosamvera ndi wowukira, 
\q1 umene mitima yake inali yosamvera Mulungu, 
\q2 umene mizimu yake inali yosakhulupirika kwa Iye. 
\b  
\q1  
\v 9 Anthu a ku Efereimu, ngakhale ananyamula mauta, 
\q2 anathawabe pa nthawi ya nkhondo; 
\q1  
\v 10 iwo sanasunge pangano la Mulungu 
\q2 ndipo anakana kukhala mʼmoyo wotsatira lamulo lake. 
\q1  
\v 11 Anayiwala zimene Iye anachita, 
\q2 zozizwitsa zimene anawaonetsa. 
\q1  
\v 12 Iyeyo anachita zodabwitsa makolo athu akuona, 
\q2 mʼdziko la Igupto, mʼchigawo cha Zowani. 
\q1  
\v 13 Anagawa nyanja pakati ndi kudutsitsapo iwowo, 
\q2 Iye anachititsa madzi kuyima chilili ngati khoma. 
\q1  
\v 14 Anawatsogolera ndi mtambo masana 
\q2 ndi kuwala kwa moto usiku wonse. 
\q1  
\v 15 Iye anangʼamba miyala mʼchipululu 
\q2 ndi kuwapatsa madzi ochuluka ngati a mʼnyanja zambiri; 
\q1  
\v 16 Anatulutsa mitsinje kuchokera mʼmingʼalu ya miyala 
\q2 ndi kuyenda madzi ngati mitsinje. 
\b  
\q1  
\v 17 Komabe iwowo anapitiriza kumuchimwira Iye, 
\q2 kuwukira Wammwambamwamba mʼchipululu. 
\q1  
\v 18 Ananyoza Mulungu mwadala 
\q2 pomuwumiriza kuti awapatse chakudya chimene anachilakalaka. 
\q1  
\v 19 Iwo anayankhula motsutsana naye ponena kuti, 
\q2 “Kodi Mulungu angatipatse chakudya mʼchipululu? 
\q1  
\v 20 Iye atamenya thanthwe 
\q2 madzi anatuluka, 
\q2 ndipo mitsinje inadzaza ndi madzi. 
\q1 Koma iye angatipatsenso ife chakudya? 
\q2 Kodi angapereke nyama kwa anthu akewa?” 
\q1  
\v 21 Yehova atawamva anakwiya kwambiri; 
\q2 moto wake unayaka kutsutsana ndi Yakobo, 
\q2 ndipo mkwiyo wake unauka kutsutsana ndi Israeli, 
\q1  
\v 22 pakuti iwo sanakhulupirire Mulungu 
\q2 kapena kudalira chipulumutso chake. 
\q1  
\v 23 Komabe Iye anapereka lamulo kwa mitambo mmwamba 
\q2 ndi kutsekula makomo a mayiko akumwamba; 
\q1  
\v 24 anagwetsa mana kuti anthu adye, 
\q2 anawapatsa tirigu wakumwamba. 
\q1  
\v 25 Anthu anadya buledi wa angelo, 
\q2 Iye anawatumizira chakudya chonse chimene akanatha kudya. 
\q1  
\v 26 Anamasula mphepo ya kummwera kuchokera kumwamba, 
\q2 ndi kutsogolera mphepo ya kummwera mwa mphamvu zake. 
\q1  
\v 27 Iye anawagwetsera nyama ngati fumbi, 
\q2 mbalame zowuluka ngati mchenga wa mʼmbali mwa nyanja. 
\q1  
\v 28 Anazibweretsa kwa iwo mʼkati mwa misasa yawo, 
\q2 kuzungulira matenti awo onse. 
\q1  
\v 29 Iwo anadya mpaka anatsala nazo zochuluka 
\q2 pakuti Iye anawapatsa zimene anazilakalaka. 
\q1  
\v 30 Koma iwowo anasiya kudya chakudya anachilakalakacho, 
\q2 chakudya chili mʼkamwa mwawobe, 
\q1  
\v 31 mkwiyo wa Mulungu unawayakira; 
\q2 Iye anapha amphamvu onse pakati pawo, 
\q2 kugwetsa anyamata abwino kwambiri mu Israeli. 
\b  
\q1  
\v 32 Ngakhale zinali chomwechi, iwo anapitirira kuchimwa; 
\q2 ngakhale anaona zozizwitsa zakezo iwowo sanakhulupirirebe. 
\q1  
\v 33 Kotero Mulungu anachepetsa masiku awo kuti azimirire ngati mpweya. 
\q2 Iye anachepetsa zaka zawo kuti zithere mʼmasautso. 
\q1  
\v 34 Mulungu atawapha, iwo amamufunafuna Iyeyo; 
\q2 iwo ankatembenukiranso kwa Iye mwachangu. 
\q1  
\v 35 Ankakumbukira kuti Mulungu ndiye Thanthwe lawo, 
\q2 kuti Mulungu Wammwambamwamba ndiye Mpulumutsi wawo. 
\q1  
\v 36 Komabe ankamuthyasika ndi pakamwa pawo, 
\q2 kumunamiza ndi malilime awo; 
\q1  
\v 37 Mitima yawo sinali yokhazikika pa Iye, 
\q2 iwo sanakhulupirike ku pangano lake. 
\q1  
\v 38 Komabe Iye anali wachifundo; 
\q2 anakhululukira mphulupulu zawo 
\q2 ndipo sanawawononge. 
\q1 Nthawi ndi nthawi Iye anabweza mkwiyo wake 
\q2 ndipo sanawutse ukali wake wonse. 
\q1  
\v 39 Iye anakumbukira kuti iwo anali anthu chabe, 
\q2 mphepo yopita imene sibwereranso. 
\b  
\q1  
\v 40 Nthawi zambiri iwo ankamuwukira Iye mʼchipululu 
\q2 ndi kumumvetsa chisoni mʼdziko lopanda kanthu! 
\q1  
\v 41 Kawirikawiri iwo ankamuyesa Mulungu; 
\q2 ankamuputa Woyera wa Israeli. 
\q1  
\v 42 Sanakumbukire mphamvu zake, 
\q2 tsiku limene Iye anawawombola kwa ozunza, 
\q1  
\v 43 tsiku limene Iyeyo anaonetsa poyera zizindikiro zozizwitsa zake mu Igupto, 
\q2 zozizwitsa zake mʼchigawo cha Zowani. 
\q1  
\v 44 Iye anasandutsa mitsinje yawo kukhala magazi; 
\q2 Iwo sanathe kumwa madzi ochokera mʼmitsinje yawo. 
\q1  
\v 45 Iye anawatumizira magulu a ntchentche zimene zinawawononga, 
\q2 ndiponso achule amene anawasakaza. 
\q1  
\v 46 Iye anapereka mbewu zawo kwa ziwala, 
\q2 zokolola zawo kwa dzombe. 
\q1  
\v 47 Iye anawononga mphesa zawo ndi matalala 
\q2 ndiponso mitengo yawo yankhuyu ndi chisanu. 
\q1  
\v 48 Iye anapereka ngʼombe zawo ku matalala, 
\q2 zoweta zawo ku zingʼaningʼani. 
\q1  
\v 49 Anakhuthula moto wa ukali wake pa iwo, 
\q2 anawapsera mtima nawakwiyira nʼkuwabweretsera masautso. 
\q2 Zimenezi zinali ngati gulu la angelo osakaza. 
\q1  
\v 50 Analolera kukwiya, 
\q2 sanawapulumutse ku imfa 
\q2 koma anawapereka ku mliri. 
\q1  
\v 51 Anakantha ana oyamba kubadwa a Igupto, 
\q2 zipatso zoyamba kucha za mphamvu zawo mʼmatenti a Hamu 
\q1  
\v 52 Koma Iye anatulutsa anthu ake ngati ziweto; 
\q2 anawatsogolera ngati nkhosa kudutsa mʼchipululu. 
\q1  
\v 53 Anawatsogolera bwinobwino kotero kuti analibe mantha 
\q2 koma nyanja inamiza adani awo. 
\q1  
\v 54 Kotero anawafikitsa ku malire a dziko lake loyera, 
\q2 ku dziko lamapiri limene dzanja lake lamanja linawatengera. 
\q1  
\v 55 Iye anathamangitsa mitundu ya anthu patsogolo pawo 
\q2 ndipo anapereka mayiko awo kwa Aisraeli kuti akhale awo; 
\q2 Iye anakhazikitsa mafuko a Israeli mʼnyumba zawo. 
\b  
\q1  
\v 56 Koma iwo anayesa Mulungu 
\q2 ndi kuwukira Wammwambamwamba; 
\q2 sanasunge malamulo ake. 
\q1  
\v 57 Anakhala okanika ndi osakhulupirika monga makolo awo, 
\q2 anapotoka monga uta wosakhulupirika. 
\q1  
\v 58 Anakwiyitsa Iyeyo ndi malo awo opembedzera mafano; 
\q2 anawutsa nsanje yake ndi mafano awo. 
\q1  
\v 59 Pamene Mulungu anamva zimenezi, anakwiya kwambiri; 
\q2 Iye anakana Israeli kwathunthu. 
\q1  
\v 60 Anasiya nyumba ya ku Silo, 
\q2 tenti imene Iyeyo anayimanga pakati pa anthu. 
\q1  
\v 61 Anatumiza mphamvu zake ku ukapolo, 
\q2 ulemerero wake mʼmanja mwa adani. 
\q1  
\v 62 Anapereka anthu ake ku lupanga; 
\q2 anakwiya kwambiri ndi cholowa chake. 
\q1  
\v 63 Moto unanyeketsa anyamata awo, 
\q2 ndipo anamwali awo analibe nyimbo za ukwati; 
\q1  
\v 64 ansembe awo anaphedwa ndi lupanga, 
\q2 ndipo amayi awo amasiye sanathe kulira. 
\b  
\q1  
\v 65 Kenaka Ambuye anakhala ngati akudzuka kutulo, 
\q2 ngati munthu wamphamvu wofuwula chifukwa cha vinyo. 
\q1  
\v 66 Iye anathamangitsa adani ake; 
\q2 anawachititsa manyazi ku nthawi zonse. 
\q1  
\v 67 Kenaka Iye anakana matenti a Yosefe, 
\q2 sanasankhe fuko la Efereimu; 
\q1  
\v 68 Koma anasankha fuko la Yuda, 
\q2 phiri la Ziyoni limene analikonda. 
\q1  
\v 69 Iye anamanga malo ake opatulika ngati zitunda, 
\q2 dziko limene analikhazikitsa kwamuyaya. 
\q1  
\v 70 Anasankha Davide mtumiki wake 
\q2 ndi kumuchotsa pakati pa makola ankhosa; 
\q1  
\v 71 kuchokera koyangʼanira nkhosa anamubweretsa 
\q2 kuti akhale mʼbusa wa anthu ake, Yakobo, 
\q2 wa Israeli cholowa chake. 
\q1  
\v 72 Ndipo Davide anawaweta ndi mtima wolungama; 
\q2 ndi manja aluso anawatsogolera. 
\c 79  
\cl Salimo 79 
\d Salimo la Asafu. 
\q1  
\v 1 Inu Mulungu, anthu a mitundu ina alowerera mʼcholowa chanu; 
\q2 ayipitsa Nyumba yanu yoyera, 
\q2 asandutsa Yerusalemu kukhala bwinja. 
\q1  
\v 2 Iwo anapereka mitembo ya atumiki anu 
\q2 kwa mbalame zamlengalenga ngati chakudya, 
\q2 matupi a oyera mtima anu kwa zirombo za dziko lapansi. 
\q1  
\v 3 Akhetsa magazi monga madzi 
\q2 kuzungulira Yerusalemu yense, 
\q2 ndipo palibe wina woti ayike mʼmanda anthu akufa. 
\q1  
\v 4 Ife ndife chinthu chonyozeka kwa anansi athu, 
\q2 choseketsa ndi cholalatiridwa kwa iwo amene atizungulira. 
\b  
\q1  
\v 5 Mpaka liti Inu Yehova? Kodi mudzakwiya mpaka muyaya? 
\q2 Kodi mpaka liti nsanje yanu idzayaka ngati moto? 
\q1  
\v 6 Khuthulirani ukali wanu pa anthu a mitundu ina 
\q2 amene sakudziwani Inu, 
\q1 pa maufumu 
\q2 amene sayitana pa dzina lanu; 
\q1  
\v 7 pakuti iwo ameza Yakobo 
\q2 ndi kuwononga dziko lawo. 
\q1  
\v 8 Musatilange chifukwa cha machimo a makolo athu 
\q2 chifundo chanu chibwere msanga kukumana nafe, 
\q2 pakuti tili ndi chosowa chachikulu. 
\b  
\q1  
\v 9 Tithandizeni Inu Mulungu Mpulumutsi wathu, 
\q2 chifukwa cha ulemerero wa dzina lanu; 
\q1 tipulumutseni ndi kutikhululukira machimo athu 
\q2 chifukwa cha dzina lanu. 
\q1  
\v 10 Chifukwa chiyani anthu a mitundu ina akuti, 
\q2 “Ali kuti Mulungu wawo?” 
\q1 Ife tikuona, zidziwike pakati pa anthu a mitundu ina 
\q2 kuti mumabwezera chilango chifukwa cha magazi amene anakhetsedwa a atumiki anu. 
\q1  
\v 11 Kubuwula kwa anthu a mʼndende kufike pamaso panu; 
\q2 ndi mphamvu ya dzanja lanu 
\q2 muwasunge amene aweruzidwa kuti aphedwe. 
\b  
\q1  
\v 12 Mubwezere kwa anansi athu kasanu nʼkawiri 
\q2 kunyoza kumene ananyoza Inu Ambuye. 
\q1  
\v 13 Pamenepo ife anthu anu, nkhosa za pabusa panu, 
\q2 tidzakutamandani kwamuyaya, 
\q1 kuchokera mʼbado ndi mʼbado 
\q2 tidzafotokoza za matamando anu. 
\c 80  
\cl Salimo 80 
\d Kwa mtsogoleri wa mayimbidwe. Potsata mayimbidwe a “Kakombo wa Pangano.” Salimo la Asafu. 
\q1  
\v 1 Tcherani khutu Inu mʼbusa wa Israeli, 
\q2 Inu amene mumatsogolera Yosefe monga nkhosa; 
\q1 Inu amene mumakhala pa mpando waufumu pakati pa akerubi, walani 
\q2  
\v 2 kwa Efereimu, Benjamini ndi Manase. 
\q1 Utsani mphamvu yanu; 
\q2 bwerani ndi kutipulumutsa. 
\b  
\q1  
\v 3 Tibwezereni mwakale Inu Mulungu; 
\q2 nkhope yanu itiwalire 
\q2 kuti tipulumutsidwe. 
\b  
\q1  
\v 4 Inu Mulungu Wamphamvuzonse, 
\q2 mpaka liti mkwiyo wanu udzanyeka 
\q2 kutsutsana ndi mapemphero a anthu anu? 
\q1  
\v 5 Mwawadyetsa buledi wa misozi; 
\q2 mwachitisa iwo kumwa misozi yodzaza mbale. 
\q1  
\v 6 Mwachititsa kuti tikhale gwero la mikangano pakati pa anansi athu, 
\q2 ndipo adani athu akutinyoza. 
\b  
\q1  
\v 7 Tibwezereni mwakale Inu Mulungu Wamphamvuzonse, 
\q2 nkhope yanu itiwalire 
\q2 kuti tipulumutsidwe. 
\b  
\q1  
\v 8 Munatulutsa mpesa kuchoka ku Igupto; 
\q2 munathamangitsa anthu a mitundu ina ndi kuwudzala mpesawo. 
\q1  
\v 9 Munawulimira munda wamphesawo, 
\q2 ndipo unamera ndi kudzaza dziko. 
\q1  
\v 10 Mapiri anaphimbidwa ndi mthunzi wake, 
\q2 mikungudza yamphamvu ndi nthambi zake. 
\q1  
\v 11 Unatambalitsa nthambi zake mpaka ku nyanja, 
\q2 mphukira zake mpaka ku mtsinje. 
\b  
\q1  
\v 12 Chifukwa chiyani mwagwetsa makoma ake 
\q2 kuti onse amene akudutsa athyole mphesa zake? 
\q1  
\v 13 Nguluwe zochokera mʼnkhalango zikuwononga 
\q2 ndipo zirombo za mthengo zimawudya. 
\q1  
\v 14 Bweraninso kwa ife Inu Mulungu Wamphamvuzonse! 
\q2 Yangʼanani pansi muli kumwambako ndipo muone! 
\q1 Uyangʼanireni mpesa umenewu, 
\q2  
\v 15 muzu umene dzanja lanu lamanja ladzala, 
\q2 mwana amene inu munamukuza nokha. 
\b  
\q1  
\v 16 Mpesa wanu wadulidwa ndi kutenthedwa ndi moto; 
\q2 pakudzudzula kwanu anthu anu awonongeka. 
\q1  
\v 17 Dzanja lanu likhale pa munthu amene ali ku dzanja lanu lamanja, 
\q2 mwana wa munthu amene mwalera nokha. 
\q1  
\v 18 Ndipo ife sitidzatembenukira kumbali kuchoka kwa Inu; 
\q2 titsitsimutseni ndipo tidzayitana pa dzina lanu. 
\b  
\q1  
\v 19 Tibwezereni mwakale Inu Yehova Mulungu Wamphamvuzonse 
\q2 nkhope yanu itiwalire 
\q2 kuti tipulumutsidwe. 
\c 81  
\cl Salimo 81 
\d Kwa mtsogoleri wa mayimbidwe. Potsata mayimbidwe a gititi. Salimo la Asafu. 
\q1  
\v 1 Imbani mwachimwemwe kwa Mulungu mphamvu yathu; 
\q2 Fuwulani mokweza kwa Mulungu wa Yakobo! 
\q1  
\v 2 Yambani nyimbo, imbani tambolini 
\q2 imbani pangwe wolira bwino ndi zeze. 
\b  
\q1  
\v 3 Imbani lipenga la nyanga ya nkhosa yayimuna pa mwezi watsopano, 
\q2 ndi pamene mwezi waoneka wonse, pa tsiku la phwando; 
\q1  
\v 4 ili ndi lamulo kwa Israeli, 
\q2 langizo la Mulungu wa Yakobo. 
\q1  
\v 5 Iye anapereka lamulolo kwa zidzukulu za Yosefe 
\q2 pamene anatuluka kulimbana ndi Igupto, 
\q2 kumene tinamva chiyankhulo chimene sitinachidziwe. 
\b  
\q1  
\v 6 Iye akunena kuti, “Ine ndinachotsa zolemetsa pa mapewa awo; 
\q2 Manja awo anamasulidwa mʼdengu. 
\q1  
\v 7 Pa mavuto anu munayitana ndipo ndinakulanditsani, 
\q2 ndinakuyankhani kuchokera mʼmitambo ya mabingu; 
\q2 ndinakuyesani pa madzi a ku Meriba. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 8 “Imvani anthu anga, ndipo ndidzakuchenjezani 
\q2 ngati mungathe kumvetsera, Inu Israeli! 
\q1  
\v 9 Musadzakhale ndi mulungu wachilendo pakati panu; 
\q2 musadzagwadire mulungu wina. 
\q1  
\v 10 Ine ndine Yehova Mulungu wanu, 
\q2 amene ndinakutulutsani mʼdziko la Igupto. 
\q2 Yasamani kukamwa kwanu ndipo ndidzakudyetsani. 
\b  
\q1  
\v 11 “Koma anthu anga sanandimvere; 
\q2 Israeli sanandigonjere. 
\q1  
\v 12 Kotero ndinawasiya ndi mitima yawo yosamverayo 
\q2 kuti atsate zimene ankafuna. 
\b  
\q1  
\v 13 “Anthu anga akanangondimvera, 
\q2 Israeli akanatsatira njira zanga, 
\q1  
\v 14 nʼkanafulumira motani kuti ndigonjetse adani awo 
\q2 ndi kutembenuza mkono wanga kulimbana ndi amaliwongo! 
\q1  
\v 15 Iwo amene amadana ndi Yehova akanakhwinyata pamaso pake, 
\q2 ndipo chilango chawo chinakakhala mpaka kalekale. 
\q1  
\v 16 Koma inu mukanadyetsedwa tirigu wabwino kwambiri; 
\q2 ndikanakukhutitsani ndi uchi wochokera pa thanthwe.” 
\c 82  
\cl Salimo 82 
\d Salimo la Asafu. 
\q1  
\v 1 Mulungu akutsogolera msonkhano waukulu; 
\q2 Iye akuweruza pakati pa “milungu.” 
\b  
\q1  
\v 2 “Mudzateteza osalungama mpaka liti, 
\q2 ndi kukondera anthu oyipa? 
\q1  
\v 3 Tetezani anthu ofowoka ndi amasiye; 
\q2 mukhazikitse ufulu wa anthu osauka ndi ozunzika. 
\q1  
\v 4 Landitsani anthu ofowoka ndi osowa; 
\q2 apulumutseni mʼdzanja la anthu oyipa. 
\b  
\q1  
\v 5 “Iwo sadziwa kanthu, sazindikira kalikonse. 
\q2 Amayendayenda mu mdima; 
\q2 maziko onse a dziko lapansi agwedezeka. 
\b  
\q1  
\v 6 “Ndinati, ‘Inu ndinu Mulungu, 
\q2 nonsenu ndinu ana a Wammwambamwamba.’ 
\q1  
\v 7 Koma mudzafa ngati anthu wamba; 
\q2 mudzagwa ngati wolamula wina aliyense.” 
\b  
\q1  
\v 8 Dzukani Inu Mulungu, weruzani dziko lapansi, 
\q2 pakuti mayiko onse ndi cholowa chanu. 
\c 83  
\cl Salimo 83 
\d Nyimbo. Salimo la Asafu. 
\q1  
\v 1 Inu Mulungu musakhale chete; 
\q2 musangoti phee, Mulungu musangoti duu. 
\q1  
\v 2 Onani adani anu akuchita chiwawa, 
\q2 amene amadana nanu autsa mitu yawo. 
\q1  
\v 3 Mochenjera iwo akukambirana za chiwembu kutsutsana ndi anthu anu; 
\q2 Iwo akukonzekera kutsutsana ndi omwe mumawakonda. 
\q1  
\v 4 Iwo akunena kuti, “Bwerani” akutero, “Tiyeni tiwononge mtundu wonsewu 
\q2 kuti dzina la Israeli lisakumbukikenso.” 
\b  
\q1  
\v 5 Ndi mtima umodzi akukonzekera chiwembu; 
\q2 Iwo achita mgwirizano kutsutsana nanu: 
\q1  
\v 6 Matenti a Edomu ndi Aismaeli, 
\q2 Mowabu ndi Ahagiri, 
\q1  
\v 7 Agebala, Aamoni ndi Aamaleki, 
\q2 Afilisti, pamodzi ndi anthu a ku Turo. 
\q1  
\v 8 Ngakhalenso Aasiriya aphatikizana nawo 
\q2 kupereka mphamvu kwa ana a Loti. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 9 Muwachitire zomwe munachitira Amidiyani, 
\q2 monga munachitira Sisera ndi Yabini ku mtsinje wa Kisoni. 
\q1  
\v 10 Amene anawonongedwa ku Endori 
\q2 ndi kukhala ngati zinyalala. 
\q1  
\v 11 Anthu awo otchuka muwachite zomwe munachita Orebu ndi Zeebu 
\q2 ana a mafumu muwachite zomwe munachita Zeba ndi Zalimuna, 
\q1  
\v 12 amene anati, “Tiyeni tilande dziko 
\q2 la msipu la Mulungu.” 
\b  
\q1  
\v 13 Muwasandutse fumbi lowuluka, Inu Mulungu wanga, 
\q2 ngati mankhusu owuluka ndi mphepo. 
\q1  
\v 14 Monga moto umatentha nkhalango, 
\q2 kapena malawi a moto kuyatsa phiri, 
\q1  
\v 15 kotero muwathamangitse ndi mphepo yamkuntho, 
\q2 ndi kuwachititsa mantha ndi namondwe. 
\q1  
\v 16 Muphimbe nkhope zawo ndi manyazi 
\q2 kuti adzafunefune dzina lanu Yehova. 
\b  
\q1  
\v 17 Achite manyazi ndi mantha nthawi zonse; 
\q2 awonongeke mwa manyazi. 
\q1  
\v 18 Adziwe kuti Inu amene dzina lanu ndi Yehova, 
\q2 ndinu nokha Wammwambamwamba pa dziko lonse lapansi. 
\c 84  
\cl Salimo 84 
\d Kwa mtsogoleri wa mayimbidwe. Potsata mayimbidwe a Gititi. Salimo la ana a Kora. 
\q1  
\v 1 Malo anu okhalamo ndi okomadi, 
\q2 Inu Yehova Wamphamvuzonse! 
\q1  
\v 2 Moyo wanga ukulakalaka, mpaka kukomoka, 
\q2 kufuna mabwalo a Yehova; 
\q1 Mtima wanga ndi thupi langa zikufuwulira 
\q2 Mulungu wamoyo. 
\b  
\q1  
\v 3 Ngakhale timba wapeza nyumba yokhalamo, 
\q2 ndiponso namzeze wadzipezera yekha chisa, 
\q2 kumene amagonekako ana ake 
\q1 pafupi ndi guwa lanu la nsembe, 
\q2 Inu Yehova Wamphamvuzonse, Mfumu yanga ndi Mulungu wanga. 
\q1  
\v 4 Odala amene amakhala mʼNyumba yanu; 
\q2 nthawi zonse amakutamandani. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 5 Odala amene mphamvu yawo ili mwa Inu, 
\q2 mitima yawo ikufunitsitsa kuyenda mʼmisewu yopita ku Ziyoni. 
\q1  
\v 6 Pamene akudutsa chigwa cha Baka, 
\q2 amachisandutsa malo a akasupe; 
\q2 mvula ya chizimalupsa imadzazanso mayiwe ake. 
\q1  
\v 7 Iwo amanka nakulirakulira mphamvu 
\q2 mpaka aliyense ataonekera pamaso pa Mulungu mu Ziyoni. 
\b  
\q1  
\v 8 Imvani pemphero langa, Inu Yehova Mulungu Wamphamvuzonse; 
\q2 mvereni Inu Mulungu wa Yakobo. 
\q4 \qs Sela\qs* 
\q1  
\v 9 Yangʼanani chishango chathu, Inu Mulungu; 
\q2 yangʼanani mokoma mtima pa wodzozedwa wanu. 
\b  
\q1  
\v 10 Nʼkwabwino kukhala mʼmabwalo anu tsiku limodzi 
\q2 kuposa kukhala kwina kwake kwa zaka 1,000; 
\q1 Ine ndingakonde kukhala mlonda wa pa khomo la Nyumba ya Mulungu wanga 
\q2 kuposa kukhala mʼmatenti a anthu oyipa. 
\q1  
\v 11 Pakuti Yehova Mulungu ndi dzuwa ndi chishango; 
\q2 Yehova amapereka chisomo ndi ulemu; 
\q1 Iye sawamana zinthu zabwino 
\q2 iwo amene amayenda mwangwiro. 
\b  
\q1  
\v 12 Inu Yehova Wamphamvuzonse, 
\q2 wodala ndi munthu amene amakhulupirira Inu. 
\c 85  
\cl Salimo 85 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la ana a Kora. 
\q1  
\v 1 Yehova munakomera mtima dziko lanu; 
\q2 munabwezeretsa ulemerero wa Yakobo. 
\q1  
\v 2 Munakhululukira mphulupulu za anthu anu 
\q2 ndi kuphimba machimo awo onse. 
\q4 \qs Sela\qs* 
\q1  
\v 3 Munayika pambali ukali wanu wonse 
\q2 ndi kutembenuka kuchoka ku mkwiyo wanu woopsa. 
\b  
\q1  
\v 4 Tibwezeretseninso mwakale Inu Mulungu Mpulumutsi wathu, 
\q2 ndipo mutichotsere mkwiyo wanu. 
\q1  
\v 5 Kodi mudzatikwiyira mpaka liti? 
\q2 Kodi mudzapitiriza kukwiya pa mibado yathu yonse? 
\q1  
\v 6 Kodi simudzatitsitsimutsanso, 
\q2 kuti anthu anu asangalale mwa Inu? 
\q1  
\v 7 Tionetseni chikondi chanu chosatha, Inu Yehova, 
\q2 ndipo tipatseni chipulumutso chanu. 
\b  
\q1  
\v 8 Ndidzamvetsera zimene Yehova Mulungu adzanena; 
\q2 Iye amalonjeza mtendere kwa anthu ake, oyera mtima ake, 
\q2 koma musawalole kuti abwerere ku zopusa. 
\q1  
\v 9 Ndithu chipulumutso chake chili pafupi ndi iwo amene amaopa Iye, 
\q2 kuti ulemerero wake ukhale mʼdziko lathu. 
\b  
\q1  
\v 10 Chikondi ndi kukhulupirika zimakumana pamodzi; 
\q2 chilungamo ndi mtendere zimapsompsonana. 
\q1  
\v 11 Kukhulupirika kumatumphuka kuchokera ku dziko lapansi, 
\q2 ndipo chilungamo chimayangʼana pansi kuchokera kumwamba. 
\q1  
\v 12 Ndithu Yehova adzapereka chimene chili chabwino, 
\q2 ndipo dziko lathu lidzapereka zokolola zake. 
\q1  
\v 13 Wolungama amapita patsogolo pake 
\q2 ndi kukonza njira za mapazi ake. 
\c 86  
\cl Salimo 86 
\d Pemphero la Davide. 
\q1  
\v 1 Ndimvereni Yehova ndipo mundiyankhe, 
\q2 pakuti ndine wosauka ndi wosowa. 
\q1  
\v 2 Yangʼanirani moyo wanga, pakuti ndine wodzipereka kwa Inu. 
\q2 Inu ndinu Mulungu wanga; 
\q2 pulumutsani mtumiki wanu amene amadalira Inu. 
\q1 Inu ndinu Mulungu wanga. 
\q1  
\v 3 Mundichitire chifundo, Inu Ambuye, 
\q2 pakuti ndikuyitana Inu tsiku lonse. 
\q1  
\v 4 Bweretsani chimwemwe kwa mtumiki wanu, Ambuye, 
\q2 pakuti ndimadalira Inu. 
\b  
\q1  
\v 5 Inu Ambuye, ndinu wokhululuka ndi wabwino, 
\q2 wodzaza ndi chikondi kwa onse amene amayitana Inu. 
\q1  
\v 6 Yehova imvani pemphero langa; 
\q2 mvetserani kulira kwanga kofuna chifundo. 
\q1  
\v 7 Pa tsiku la mavuto anga ndidzayitana Inu, 
\q2 pakuti Inu mudzandiyankha. 
\b  
\q1  
\v 8 Pakati pa milungu palibe wina wofanana nanu Ambuye; 
\q2 palibe ntchito zolingana ndi ntchito zanu. 
\q1  
\v 9 Mitundu yonse ya anthu imene munayipanga 
\q2 idzabwera ndi kudzalambira pamaso panu Ambuye; 
\q2 iwo adzabweretsa ulemerero pa dzina lanu. 
\q1  
\v 10 Pakuti ndinu wamkulu ndipo mumachita zodabwitsa; 
\q2 Inu nokha ndiye Mulungu. 
\b  
\q1  
\v 11 Ndiphunzitseni njira yanu Yehova, 
\q2 ndipo ndidzayenda mʼchoonadi chanu; 
\q1 patseni mtima wosagawikana 
\q2 kuti ndilemekeze dzina lanu. 
\q1  
\v 12 Ndidzakutamandani Ambuye Mulungu wanga, ndi mtima wanga wonse; 
\q2 ndidzalemekeza dzina lanu kwamuyaya. 
\q1  
\v 13 Pakuti chikondi chanu nʼchachikulu kwa ine; 
\q2 mwandipulumutsa ku malo ozama a manda. 
\b  
\q1  
\v 14 Inu Mulungu wanga, anthu odzikuza akundithira nkhondo; 
\q2 anthu ankhanza akufuna kundipha, 
\q2 amene salabadira za Inu. 
\q1  
\v 15 Koma Ambuye ndinu Mulungu wachifundo ndi wokoma mtima, 
\q2 wosakwiya msanga, wodzaza ndi chikondi ndi wokhulupirika. 
\q1  
\v 16 Tembenukirani kwa ine ndipo ndichitireni chifundo; 
\q2 perekani mphamvu zanu kwa mtumiki wanu 
\q2 ndipo pulumutsani mwana wa mdzakazi wanu. 
\q1  
\v 17 Mundionetse chizindikiro cha ubwino wanu 
\q2 kuti adani achione ndi kuchititsidwa manyazi, 
\q2 pakuti Yehova mwandithandiza ndi kunditonthoza. 
\c 87  
\cl Salimo 87 
\d Salimo la Ana a Kora. 
\q1  
\v 1 Iye wakhazikitsa maziko ake pa phiri loyera; 
\q2  
\v 2 Yehova amakonda zipata za Ziyoni 
\q2 kupambana malo onse okhalamo a Yakobo. 
\q1  
\v 3 Za ulemerero wako zimakambidwa, 
\q2 Iwe mzinda wa Mulungu: 
\q4 Sela 
\q1  
\v 4 “Ndidzanena za Rahabe ndi Babuloni 
\q2 pakati pa iwo amene amandidziwa. 
\q1 Dzikonso la Filisitiya, Turo pamodzi ndi Kusi, 
\q2 ndipo ndidzati, ‘Uyu anabadwira mʼZiyoni.’ ” 
\b  
\q1  
\v 5 Ndithudi, za Ziyoni adzanena kuti, 
\q2 “Uyu ndi uyo anabadwira mwa iye, 
\q2 ndipo Wammwambamwamba adzakhazikitsa iyeyo.” 
\q1  
\v 6 Yehova adzalemba mʼbuku la kawundula wa anthu a mitundu ina: 
\q2 “Uyu anabadwira mʼZiyoni.” 
\q4 Sela 
\q1  
\v 7 Oyimba ndi ovina omwe adzati, 
\q2 “Akasupe anga onse ali mwa iwe.” 
\c 88  
\cl Salimo 88 
\d Salimo la ana a Kora. Kwa mtsogoleri wa mayimbidwe. Potsata mayimbidwe a nyimbo yoti: “Pa Matenda ndi pa Mazunzo.” Ndakatulo ya Hemani, wa banja la Ezara. 
\q1  
\v 1 Inu Yehova, Mulungu amene mumandipulumutsa, 
\q2 usana ndi usiku ndimalira pamaso panu. 
\q1  
\v 2 Pemphero langa lifike pamaso panu; 
\q2 tcherani khutu lanu kuti mumve kulira kwanga. 
\b  
\q1  
\v 3 Pakuti ndili ndi mavuto ambiri 
\q2 ndipo moyo wanga ukuyandikira ku manda. 
\q1  
\v 4 Ndikuwerengedwa pamodzi ndi iwo amene akutsikira ku dzenje; 
\q2 ndine munthu wopanda mphamvu. 
\q1  
\v 5 Ndayikidwa pambali pamodzi ndi anthu akufa, 
\q2 monga ophedwa amene agona mʼmanda, 
\q1 amene Inu simuwakumbukiranso, 
\q2 amene achotsedwa pa chisamaliro chanu. 
\b  
\q1  
\v 6 Mwandiyika pansi pa dzenje penipeni, 
\q2 mʼmalo akuya a mdima waukulu. 
\q1  
\v 7 Ukali wanu ukundipsinja kwambiri, 
\q2 mwandiopseza kwambiri ndi mafunde anu onse. 
\q4 \qs Sela\qs* 
\q1  
\v 8 Mwandichotsa pakati pa abwenzi anga enieni 
\q2 ndipo mwachititsa kuti ndikhale chonyansa kwa iwo. 
\q1 Ndatsekerezedwa ndipo sindingathe kuthawa; 
\q2  
\v 9 maso anga ada ndi chisoni. 
\b  
\q1 Ndimayitana Inu Yehova tsiku lililonse; 
\q2 ndimakweza manja anga kwa Inu. 
\q1  
\v 10 Kodi mumaonetsa zozizwitsa zanu kwa anthu akufa? 
\q2 Kodi iwo amene afa amaukanso ndi kutamanda Inu? 
\q4 Sela 
\q1  
\v 11 Kodi chikondi chanu chimalalikidwa mʼmanda, 
\q2 za kukhulupirika kwanu ku malo a chiwonongeko? 
\q1  
\v 12 Kodi zozizwitsa zanu zimadziwika ku malo a mdima, 
\q2 kapena ntchito zanu zolungama ku dziko la anthu oyiwalika? 
\b  
\q1  
\v 13 Inu Yehova, Ine ndimalirira thandizo; 
\q2 mmawa mapemphero anga amafika pamaso panu. 
\q1  
\v 14 Inu Yehova nʼchifukwa chiyani mukundikana 
\q2 ndi kundibisira nkhope yanu? 
\b  
\q1  
\v 15 Kuyambira ubwana wanga ndakhala ndikuzunzika pafupi kufa; 
\q2 ndakhala ndikuchita mantha ndipo ndine wothedwa nzeru. 
\q1  
\v 16 Ukali wanu wandimiza; 
\q2 zoopsa zanu zandiwononga. 
\q1  
\v 17 Tsiku lonse zimandizungulira ngati chigumula; 
\q2 zandimiza kwathunthu. 
\q1  
\v 18 Inu mwatenga anzanga ndi okondedwa anga kuwachotsa pamaso panga; 
\q2 mdima ndiye bwenzi langa lenileni. 
\c 89  
\cl Salimo 89 
\d Ndakatulo ya Etani, wa banja la Ezara. 
\q1  
\v 1 Ndidzayimba za chikondi chachikulu cha Yehova kwamuyaya; 
\q2 ndi pakamwa panga ndidzachititsa kuti kukhulupirika kwanu kudziwike ku mibado yonse. 
\q1  
\v 2 Ndidzalalikira kuti chikondi chanu chidzakhazikika mpaka muyaya, 
\q2 kuti Inu munakhazikitsa kukhulupirika kwanu kumwamba kwenikweniko. 
\b  
\q1  
\v 3 Inu munati, “Ndachita pangano ndi wosankhidwa wanga, 
\q2 ndalumbira kwa Davide mtumiki wanga kuti, 
\q1  
\v 4 ‘Ndidzakhazikitsa zidzukulu zako mpaka muyaya. 
\q2 Ndidzachititsa kuti mpando wako waufumu ukhazikike ku mibado yonse,’ ” 
\q4 Sela. 
\b  
\q1  
\v 5 Mayiko akumwamba amatamanda zozizwitsa zanu Yehova, 
\q2 kukhulupirika kwanunso, mu msonkhano wa oyera mtima anu. 
\q1  
\v 6 Pakuti ndani mu mlengalenga angalingane ndi Yehova? 
\q2 Ndani wofanana ndi Yehova pakati pa zolengedwa zakumwamba? 
\q1  
\v 7 Mu msonkhano wa oyera mtima Mulungu amaopedwa kwambiri; 
\q2 Iye ndiye wochititsa mantha kupambana onse amene amuzungulira. 
\q1  
\v 8 Inu Yehova Mulungu Wamphamvuzonse, ndani wofanana nanu? 
\q2 Yehova ndinu wamphamvu ndipo kukhulupirika kwanu kwakuzungulirani. 
\b  
\q1  
\v 9 Mumalamula nyanja ya mafunde awukali; 
\q2 pamene mafunde ake awundana Inu mumawakhalitsa bata. 
\q1  
\v 10 Munaphwanya Rahabe monga munthu wophedwa; 
\q2 ndi dzanja lanu lamphamvu munabalalitsa adani anu. 
\q1  
\v 11 Mayiko akumwamba ndi anu ndiponso dziko lapansi ndi lanu; 
\q2 munapanga dziko lonse ndi zonse zili mʼmenemo. 
\q1  
\v 12 Munalenga Kumpoto ndi Kummwera; 
\q2 Tabori ndi Herimoni akuyimba ndi chimwemwe pa dzina lanu. 
\q1  
\v 13 Mkono wanu ndi wamphamvu; 
\q2 dzanja lanu ndi lamphamvu, dzanja lanu lamanja ndi lopambana. 
\b  
\q1  
\v 14 Chilungamo ndi chiweruzo cholungama ndiye maziko a mpando wanu waufumu; 
\q2 chikondi ndi kukhulupirika zimayenda patsogolo panu. 
\q1  
\v 15 Ndi odala amene aphunzira kuyamika Inu, 
\q2 amene amayenda mʼkuwunika kwa nkhope yanu Yehova. 
\q1  
\v 16 Amakondwera mʼdzina lanu tsiku lonse lathunthu; 
\q2 amasangalala koposa mʼchilungamo chanu. 
\q1  
\v 17 Pakuti Inu ndiye ulemerero wawo ndi mphamvu yawo 
\q2 ndipo mwa kukoma mtima kwanu Inu mumakweza nyanga yathu. 
\q1  
\v 18 Ndithudi, chishango chathu ndi cha Yehova, 
\q2 Mfumu yathu kwa Woyerayo wa Israeli. 
\b  
\q1  
\v 19 Kale munayankhula mʼmasomphenya, 
\q2 kwa anthu anu okhulupirika munati, 
\q1 “Ndapatsa mphamvu wankhondo; 
\q2 ndakweza mnyamata wochokera pakati pa anthu. 
\q1  
\v 20 Ndamupeza mtumiki wanga Davide; 
\q2 ndamudzoza ndi mafuta opatulika. 
\q1  
\v 21 Dzanja langa lidzamuchirikiza; 
\q2 zoonadi, mkono wanga udzamupatsa mphamvu. 
\q1  
\v 22 Adani sadzamulamula kuti apereke msonkho; 
\q2 anthu oyipa sadzamusautsa. 
\q1  
\v 23 Ndidzaphwanya adani ake pamaso pake 
\q2 ndi kukantha otsutsana naye. 
\q1  
\v 24 Chikondi changa chokhulupirika chidzakhala naye, 
\q2 ndipo kudzera mʼdzina langa nyanga yake idzakwezedwa. 
\q1  
\v 25 Ndidzayika dzanja lake pa nyanja, 
\q2 dzanja lake lamanja pa mitsinje. 
\q1  
\v 26 Iyeyo adzafuwula kwa Ine kuti, ‘Ndinu Atate anga, 
\q2 Mulungu wanga, Thanthwe ndi Chipulumutso changa.’ 
\q1  
\v 27 Ndidzamuyika kuti akhale mwana wanga woyamba kubadwa; 
\q2 wokwezedwa kwambiri pakati pa mafumu a dziko lapansi. 
\q1  
\v 28 Ndidzamusungira chifundo changa kwamuyaya, 
\q2 ndipo pangano langa ndi iye silidzatha. 
\q1  
\v 29 Ine ndidzakhazikitsa zidzukulu zake mpaka muyaya, 
\q2 mpando wake waufumu ngati masiku a miyamba. 
\b  
\q1  
\v 30 “Ngati ana ake adzataya lamulo langa 
\q2 ndi kusatsatira malangizo anga, 
\q1  
\v 31 ngati adzaswa malamulo anga 
\q2 ndi kulephera kusunga ziphunzitso zanga, 
\q1  
\v 32 Ine ndidzalanga tchimo lawo ndi ndodo, 
\q2 mphulupulu zawo powakwapula. 
\q1  
\v 33 Koma sindidzachotsa chikondi changa pa iye, 
\q2 kapena kukhala wosakhulupirika kwa iyeyo. 
\q1  
\v 34 Sindidzaswa pangano langa 
\q2 kapena kusintha zimene milomo yanga yayankhula. 
\q1  
\v 35 Ndinalumbira kamodzi mwa kuyera kwanga 
\q2 ndipo sindidzanama kwa Davide, 
\q1  
\v 36 kuti zidzukulu zake zidzakhale kwamuyaya 
\q2 ndipo mpando wake waufumu udzakhazikika pamaso panga ngati dzuwa; 
\q1  
\v 37 udzakhazikika kwamuyaya monga mwezi, 
\q2 mboni yokhulupirika mʼmitambo. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 38 “Koma tsopano Inu mwamukana, mwamutaya, 
\q2 mwamukwiyira kwambiri wodzozedwa wanu. 
\q1  
\v 39 Mwakana pangano ndi mtumiki wanu 
\q2 ndipo mwadetsa mʼfumbi chipewa chake chaufumu. 
\q1  
\v 40 Inu mwagumula makoma ake onse 
\q2 ndipo mwasandutsa bwinja malinga ake. 
\q1  
\v 41 Onse amene amadutsa amalanda zinthu zake; 
\q2 iye wakhala chotonzedwa cha anansi ake. 
\q1  
\v 42 Mwakweza dzanja lamanja la adani ake; 
\q2 mwachititsa kuti adani ake akondwere. 
\q1  
\v 43 Mwabunthitsa lupanga lake, 
\q2 simunamuthandize pa nkhondo. 
\q1  
\v 44 Inu mwathetsa kukongola kwa ulemerero wake 
\q2 ndipo mwagwetsa pansi mpando wake waufumu. 
\q1  
\v 45 Mwachepetsa masiku a unyamata wake; 
\q2 mwamuphimba ndi chofunda chochititsa manyazi. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 46 “Mpaka liti Yehova? Kodi mudzadzibisa mpaka kalekale? 
\q2 Mpaka liti ukali wanu udzayaka ngati moto? 
\q1  
\v 47 Kumbukirani kuti masiku a moyo wanga ndi ochepa 
\q2 pakuti munalenga kwachabe anthu onse! 
\q1  
\v 48 Kodi ndi munthu uti angakhale ndi moyo ndi kusaona imfa? 
\q2 Kapena kudzipulumutsa yekha ku mphamvu ya manda? 
\q4 Sela 
\q1  
\v 49 Inu Ambuye kodi chili kuti chikondi chanu chachikulu choyamba chija, 
\q2 chimene mwa kukhulupirika kwanu munalumbira kwa Davide? 
\q1  
\v 50 Kumbukirani, Ambuye momwe mtumiki wanu wanyozedwera, 
\q2 momwe ndakhalira ndi kusunga mu mtima mwanga mawu a pangano a anthu a mitundu yonse, 
\q1  
\v 51 mawu achipongwe amene adani anu akhala akunyoza, Inu Yehova, 
\q2 ndi mawu amene akhala akunyoza mayendedwe onse a wodzozedwa wanu. 
\b  
\q1  
\v 52 “Matamando akhale kwa Yehova mpaka muyaya!” 
\qc Ameni ndi Ameni. 
\c 90  
\ms1 BUKU LACHINAYI 
\mr Masalimo 90–106 
\cl Salimo 90 
\d Pemphero la Mose munthu wa Mulungu. 
\q1  
\v 1 Ambuye, mwakhala muli malo athu okhalamo 
\q2 pa mibado yonse. 
\q1  
\v 2 Mapiri asanabadwe, 
\q2 musanalenge nʼkomwe dziko lapansi ndi dziko lonse, 
\q2 kuyambira muyaya mpaka muyaya Inu ndinu Mulungu. 
\b  
\q1  
\v 3 Inu mumabwezera anthu ku fumbi, 
\q2 mumati, “Bwerera ku fumbi iwe mwana wa munthu.” 
\q1  
\v 4 Pakuti zaka 1,000 pamaso panu 
\q2 zili ngati tsiku limene lapita 
\q2 kapena ngati kamphindi ka usiku. 
\q1  
\v 5 Inu mumasesa anthu mʼtulo ta imfa, 
\q2 iwo ali ngati udzu watsopano wa mmawa, 
\q1  
\v 6 ngakhale kuti mmawa umaphuka watsopano, 
\q2 pofika madzulo wauma ndi kufota. 
\b  
\q1  
\v 7 Ife tathedwa ndi mkwiyo wanu; 
\q2 ndipo taopsezedwa ndi kuyipidwa kwanu. 
\q1  
\v 8 Mwayika mphulupulu zathu pamaso panu, 
\q2 machimo athu obisika poonekera pamaso panu. 
\q1  
\v 9 Masiku athu onse amatha ali pansi pa ukali wanu; 
\q2 timatsiriza zaka zathu ndi kubuwula. 
\q1  
\v 10 Kuchuluka kwa masiku athu ndi 70, 
\q2 kapena 80 ngati tili ndi mphamvu; 
\q1 komabe zaka zonsezi ndi za mavuto ndi nkhawa, 
\q2 zimatha mofulumira ndipo ife timawulukira kutali. 
\b  
\q1  
\v 11 Kodi ndani amadziwa mphamvu ya mkwiyo wanu? 
\q2 Pakuti ukali wanu ndi waukulu ngati ulemu umene uyenera Inu. 
\q1  
\v 12 Tiphunzitseni kuwerenga masiku athu molondola, 
\q2 kuti tikhale ndi mtima wanzeru. 
\b  
\q1  
\v 13 Lezani mtima Inu Yehova! Kodi mudzatikwiyira mpaka liti? 
\q2 Achitireni chifundo atumiki anu. 
\q1  
\v 14 Mutikhutitse mmawa ndi chikondi chanu chosatha, 
\q2 kuti tiyimbe ndi chimwemwe ndi kukhala okondwa masiku athu onse. 
\q1  
\v 15 Tisangalatseni masiku ambiri monga masiku amene mwatisautsa, 
\q2 kwa zaka zambiri monga momwe tinaonera mavuto. 
\q1  
\v 16 Ntchito zanu zionetsedwe kwa atumiki anu, 
\q2 kukongola kwanu kwa ana awo. 
\b  
\q1  
\v 17 Kukoma mtima kwa Ambuye Mulungu wathu kukhale pa ife; 
\q2 tikhazikitsireni ntchito ya manja athu; 
\q2 inde, khazikitsani ntchito ya manja athu. 
\c 91  
\cl Salimo 91 
\q1  
\v 1 Iye amene amakhala mu mthunzi wa Wammwambamwamba 
\q2 adzapuma mu mthunzi wa Wamphamvuzonse. 
\q1  
\v 2 Ndidzanena za Yehova, “Iye ndiye pothawira panga ndi linga langa, 
\q2 Mulungu wanga amene ndimadalira.” 
\b  
\q1  
\v 3 Ndithu, Iye adzakupulumutsa ku msampha wa mlenje 
\q2 ndi ku mliri woopsa; 
\q1  
\v 4 Adzakuphimba ndi nthenga zake, 
\q2 ndipo udzapeza malo othawira mʼmapikomo; 
\q2 kukhulupirika kwake kudzakhala chishango chako ndi lihawo. 
\q1  
\v 5 Sudzachita mantha ndi zoopsa za usiku, 
\q2 kapena muvi wowuluka masana, 
\q1  
\v 6 kapena mliri umene umayenda mu mdima, 
\q2 kapena zowononga za pa nthawi ya masana. 
\q1  
\v 7 Anthu 1,000 atha kufa pambali pako, 
\q2 anthu 10,000 kudzanja lako lamanja, 
\q2 koma zoopsazo sizidzafika pafupi ndi iwe. 
\q1  
\v 8 Udzapenya ndi maso ako 
\q2 ndipo udzaona mmene anthu oyipa amalangidwira. 
\b  
\q1  
\v 9 Pakuti wasankha Wammwambamwamba kukhala malo ako okhalamo; 
\q2 wavomera Yehova kukhala kothawira kwako. 
\q1  
\v 10 Choncho palibe choyipa chimene chidzakugwera, 
\q2 zoopsa sizidzafika pafupi ndi tenti yako. 
\q1  
\v 11 Pakuti adzalamulira angelo ake za iwe, 
\q2 kuti akutchinjirize mosamala pa njira zako zonse; 
\q1  
\v 12 ndipo adzakunyamula ndi manja awo, 
\q2 kuti phazi lako lisagunde pa mwala. 
\q1  
\v 13 Udzapondaponda mkango ndi njoka, 
\q2 udzapondereza mkango wamphamvu ndiponso chinjoka. 
\b  
\q1  
\v 14 “Chifukwa iye amandikonda,” akutero Yehova, “Ndidzamulanditsa; 
\q2 ndidzamuteteza pakuti wavomereza dzina langa. 
\q1  
\v 15 Adzandiyitana, ndipo ndidzamuyankha; 
\q2 ndidzakhala naye pa mavuto, 
\q2 ndidzamupulumutsa ndi kumulemekeza. 
\q1  
\v 16 Ndidzamupatsa moyo wautali 
\q2 ndi kumupulumutsa.” 
\c 92  
\cl Salimo 92 
\d Salimo. Nyimbo ya pa tsiku la Sabata. 
\q1  
\v 1 Nʼkwabwino kutamanda Yehova 
\q2 ndi kuyimbira nyimbo dzina lanu, Inu Wammwambamwamba, 
\q1  
\v 2 Kulengeza chikondi chanu mmawa, 
\q2 ndi kukhulupirika kwanu nthawi ya usiku, 
\q1  
\v 3 kuyimbira nyimbo choyimbira cha zingwe khumi 
\q2 ndi mayimbidwe abwino a zeze. 
\b  
\q1  
\v 4 Pakuti Inu mumandisangalatsa ndi ntchito zanu, Inu Yehova; 
\q2 Ine ndikuyimba mwachimwemwe pa ntchito ya manja anu. 
\q1  
\v 5 Ndi yayikuludi ntchito yanu Yehova, 
\q2 maganizo anu ndi ozamadi! 
\q1  
\v 6 Munthu wopanda nzeru sadziwa, 
\q2 zitsiru sizizindikira, 
\q1  
\v 7 kuti ngakhale anthu oyipa aphuka ngati udzu 
\q2 ndipo anthu onse ochita zoyipa apindula, 
\q1 adzawonongedwa kwamuyaya. 
\b  
\q1  
\v 8 Koma Inu Yehova, ndinu wokwezedwa kwamuyaya. 
\b  
\q1  
\v 9 Zoonadi adani anu Yehova, 
\q2 zoonadi adani anu adzawonongeka; 
\q2 onse ochita zoyipa adzabalalitsidwa. 
\q1  
\v 10 Inu mwakweza nyanga yanga ngati nyanga ya njati; 
\q2 mafuta abwino akhuthulidwa pamutu wanga. 
\q1  
\v 11 Maso anga aona kugonjetsedwa kwa olimbana nane, 
\q2 makutu anga amva za kugwa kwa amaliwongo anga oyipa. 
\b  
\q1  
\v 12 Anthu olungama adzaphuka ngati mtengo wa mgwalangwa, 
\q2 adzakula ngati mkungudza wa ku Lebanoni; 
\q1  
\v 13 odzalidwa mʼnyumba ya Yehova, 
\q2 adzakula bwino mʼmabwalo a Mulungu wathu. 
\q1  
\v 14 Iwo adzaberekabe zipatso mu ukalamba wawo, 
\q2 adzakhala anthete ndi obiriwira, 
\q1  
\v 15 kulengeza kuti, “Yehova ndi wolungama; 
\q2 Iye ndiye Thanthwe langa, ndipo mwa Iye mulibe choyipa.” 
\c 93  
\cl Salimo 93 
\q1  
\v 1 Yehova akulamulira, wavala ulemerero; 
\q2 Yehova wavala ulemerero ndipo wadzimangirira mphamvu, 
\q2 dziko lonse lakhazikika kolimba; silingasunthidwe. 
\q1  
\v 2 Mpando wanu waufumu unakhazikika kalekale; 
\q2 Inu ndinu wamuyaya. 
\b  
\q1  
\v 3 Nyanja zakweza Inu Yehova, 
\q2 nyanja zakweza mawu ake; 
\q2 nyanja zakweza mafunde ake ochita mkokomo. 
\q1  
\v 4 Yehova ndi wamphamvu kupambana mkokomo wa madzi ambiri, 
\q2 ndi wamphamvu kupambana mafunde a nyanja, 
\q2 Yehova mmwamba ndi wamphamvu. 
\b  
\q1  
\v 5 Malamulo anu Yehova ndi osasinthika; 
\q2 chiyero chimakongoletsa nyumba yanu 
\q2 mpaka muyaya. 
\c 94  
\cl Salimo 94 
\q1  
\v 1 Inu Yehova, ndinu Mulungu wobwezera chilango, 
\q2 Inu Mulungu amene mumabwezera chilango, wonetsani kuwala kwanu. 
\q1  
\v 2 Nyamukani, Inu woweruza wa dziko lapansi; 
\q2 bwezerani kwa odzikuza zowayenera. 
\q1  
\v 3 Kodi mpaka liti anthu oyipa Inu Yehova, 
\q2 mpaka liti anthu oyipa adzalumpha ndi chimwemwe? 
\b  
\q1  
\v 4 Amakhuthula mawu onyada; 
\q2 onse ochita zoyipa ndi odzaza ndi kudzikuza. 
\q1  
\v 5 Amaphwanya anthu anu, Inu Yehova; 
\q2 amapondereza cholowa chanu. 
\q1  
\v 6 Amaphanso amayi a masiye ndi alendo okhala nawo mʼdziko; 
\q2 amapha ana amasiye. 
\q1  
\v 7 Iwo amati, “Yehova sakuona; 
\q2 Mulungu wa Yakobo salabadirako.” 
\b  
\q1  
\v 8 Samalani, inu anthu opanda nzeru pakati pa anthu; 
\q2 zitsiru inu, kodi mudzakhala liti anzeru? 
\q1  
\v 9 Kodi Iye amene anapanga khutu sangathe kumva? 
\q2 Kodi Iye amene anapanga diso sangathe kuona? 
\q1  
\v 10 Kodi Iye amene amalangiza mitundu ya anthu sangathenso kulanga? 
\q2 Kodi Iye amene amaphunzitsa munthu angasowe nzeru? 
\q1  
\v 11 Yehova amadziwa maganizo a munthu; 
\q2 Iye amadziwa kuti maganizowo ndi achabechabe. 
\b  
\q1  
\v 12 Wodala munthu amene Inu Yehova mumamulangiza, 
\q2 munthu amene mumamuphunzitsa kuchokera mulamulo lanu; 
\q1  
\v 13 mumamupumitsa pa nthawi ya mavuto, 
\q2 mpaka woyipa atakumbiridwa dzenje. 
\q1  
\v 14 Pakuti Yehova sadzawakana anthu ake; 
\q2 Iye sadzasiya cholowa chake. 
\q1  
\v 15 Chiweruzo chidzakhazikikanso pa chilungamo, 
\q2 ndipo onse olungama mtima adzachitsata. 
\b  
\q1  
\v 16 Ndani adzadzuka chifukwa cha ine kulimbana ndi anthu oyipa? 
\q2 Ndani adzayimirira mʼmalo mwanga kulimbana ndi anthu ochita zoyipa? 
\q1  
\v 17 Yehova akanapanda kundithandiza, 
\q2 bwenzi nditakakhala msanga ku malo achete a imfa. 
\q1  
\v 18 Ndikanena kuti, “Phazi langa likuterereka,” 
\q2 chikondi chanu, Inu Yehova, chimandichirikiza. 
\q1  
\v 19 Pamene nkhawa inakula mʼkati mwanga, 
\q2 chitonthozo chanu chinabweretsa chimwemwe mʼmoyo mwanga. 
\b  
\q1  
\v 20 Kodi mpando waufumu woyipa ungathe kugwirizana nanu 
\q2 umene umabweretsa masautso chifukwa cha malamulo ake? 
\q1  
\v 21 Iwo amasonkhana pamodzi kulimbana ndi wolungama 
\q2 ndi kugamula kuti wosalakwa aphedwe. 
\q1  
\v 22 Koma Yehova wakhala linga langa, 
\q2 ndipo Mulungu ndiye thanthwe limene ndimathawirako. 
\q1  
\v 23 Iye adzawabwezera chifukwa cha machimo awo 
\q2 ndi kuwawononga chifukwa cha kuyipa kwawo; 
\q2 Yehova Mulungu wathu adzawawononga. 
\c 95  
\cl Salimo 95 
\q1  
\v 1 Bwerani, tiyeni timuyimbire Yehova mwachimwemwe, 
\q2 tiyeni tifuwule kwa Thanthwe la chipulumutso chathu 
\q1  
\v 2 Tiyeni tibwere pamaso pake ndi chiyamiko 
\q2 ndipo mupembedzeni Iyeyo ndi zida zoyimbira ndi nyimbo. 
\b  
\q1  
\v 3 Pakuti Yehova ndi Mulungu wamkulu, 
\q2 mfumu yayikulu pamwamba pa milungu yonse. 
\q1  
\v 4 Mʼmanja mwake muli maziko ozama a dziko lapansi, 
\q2 ndipo msonga za mapiri ndi zake. 
\q1  
\v 5 Nyanja ndi yake, pakuti anayilenga ndi Iye, 
\q2 ndipo manja ake anawumba mtunda wowuma. 
\b  
\q1  
\v 6 Bwerani, tiyeni tiwerame pomulambira, 
\q2 tiyeni tigwade pamaso pa Yehova Mlengi wathu; 
\q1  
\v 7 pakuti Iye ndiye Mulungu wathu 
\q2 ndipo ife ndife anthu a pabusa pake, 
\q2 ndi nkhosa za mʼdzanja lake. 
\b  
\q1 Lero ngati inu mumva mawu ake, 
\q2  
\v 8 musawumitse mitima yanu monga momwe munachitira pa Meriba, 
\q2 monga munachitira tsiku lija pa Masa mʼchipululu. 
\q1  
\v 9 Kumene makolo anu anandiyesa ndi kundiputa, 
\q2 ngakhale anaona zimene Ine ndinazichita. 
\q1  
\v 10 Kwa zaka makumi anayi ndinali wokwiya ndi mʼbado umenewo; 
\q2 ndipo ndinati, “Iwo ndi anthu amene mitima yawo imasochera 
\q2 ndipo sanadziwe njira zanga.” 
\q1  
\v 11 Choncho ndili chikwiyire, ndinalumbira kuti, 
\q2 “Iwowa sadzalowa ku malo anga a mpumulo.” 
\c 96  
\cl Salimo 96 
\q1  
\v 1 Imbirani Yehova nyimbo yatsopano; 
\q2 Imbirani Yehova dziko lonse lapansi. 
\q1  
\v 2 Imbirani Yehova, tamandani dzina lake; 
\q2 lalikirani chipulumutso chake tsiku ndi tsiku. 
\q1  
\v 3 Lengezani ulemerero wake pakati pa mayiko, 
\q2 ntchito zake zodabwitsa pakati pa mitundu yonse ya anthu. 
\b  
\q1  
\v 4 Pakuti wamkulu ndi Yehova ndipo ndi woyenera kwambiri kumutamanda; 
\q2 ayenera kuopedwa kupambana milungu yonse. 
\q1  
\v 5 Pakuti milungu yonse ya anthu a mitundu ina ndi mafano, 
\q2 koma Yehova analenga mayiko akumwamba. 
\q1  
\v 6 Ulemu ndi ufumu zili pamaso pake, 
\q2 mphamvu ndi ulemerero zili mʼmalo ake opatulika. 
\b  
\q1  
\v 7 Perekani kwa Yehova, inu mabanja a anthu a mitundu ina, 
\q2 perekani kwa Yehova ulemerero ndi mphamvu. 
\q1  
\v 8 Perekani kwa Yehova ulemerero woyenera dzina lake; 
\q2 bweretsani chopereka ndipo mulowe mʼmabwalo ake. 
\q1  
\v 9 Lambirani Yehova mu ulemerero wa chiyero chake; 
\q2 njenjemerani pamaso pake, dziko lonse lapansi. 
\b  
\q1  
\v 10 Nenani pakati pa mitundu ya anthu, “Yehova akulamulira.” 
\q2 Dziko lonse lakhazikika molimba, silingasunthidwe; 
\q2 Iye adzaweruza mitundu ya anthu molungama. 
\q1  
\v 11 Mayiko akumwamba asangalale, dziko lapansi likondwere; 
\q2 nyanja ikokome, ndi zonse zili mʼmenemo; 
\q2  
\v 12 minda ikondwere pamodzi ndi chilichonse chili mʼmenemo. 
\q1 Pamenepo mitengo yonse ya mʼnkhalango idzayimba ndi chimwemwe; 
\q2  
\v 13 idzayimba pamaso pa Yehova, 
\q2 pakuti Iye akubwera kudzaweruza dziko lapansi; 
\q1 adzaweruza dziko lonse mwachilungamo 
\q2 ndi mitundu ya anthu onse mʼchoonadi. 
\c 97  
\cl Salimo 97 
\q1  
\v 1 Yehova akulamulira, dziko lapansi lisangalale; 
\q2 magombe akutali akondwere. 
\b  
\q1  
\v 2 Mitambo ndi mdima waukulu zamuzungulira; 
\q2 chilungamo ndi kuweruza molungama ndiwo maziko a mpando wake waufumu. 
\q1  
\v 3 Moto umapita patsogolo pake 
\q2 ndi kunyeketsa amaliwongo kumbali zonse. 
\q1  
\v 4 Zingʼaningʼani zake zimawalitsa dziko lonse; 
\q2 dziko lapansi limaona ndipo limanjenjemera. 
\q1  
\v 5 Mapiri amasungunuka ngati phula pamaso pa Yehova, 
\q2 pamaso pa Ambuye a dziko lonse lapansi. 
\q1  
\v 6 Mayiko akumwamba amalengeza za chilungamo chake, 
\q2 ndipo mitundu yonse ya anthu imaona ulemerero wake. 
\b  
\q1  
\v 7 Onse amene amalambira mafano osema amachititsidwa manyazi, 
\q2 iwo amene amanyadira mafano; 
\q2 mulambireni, inu milungu yonse! 
\b  
\q1  
\v 8 Ziyoni akumva ndipo akukondwera, 
\q2 midzi ya Yuda ikusangalala 
\q2 chifukwa cha maweruzo anu Yehova. 
\q1  
\v 9 Pakuti Inu Yehova ndi Wammwambamwamba pa dziko lonse lapansi; 
\q2 ndinu wokwezeka kupambana milungu yonse. 
\b  
\q1  
\v 10 Iwo amene amakonda Yehova adane ndi zoyipa 
\q2 pakuti Iye amayangʼanira miyoyo ya amene amamukhulupirira 
\q2 ndipo amawapulumutsa mʼdzanja la anthu oyipa 
\q1  
\v 11 Kuwala kumafika pa anthu olungama, 
\q2 ndi chimwemwe kwa olungama mtima. 
\q1  
\v 12 Kondwerani mwa Yehova Inu olungama 
\q2 ndipo tamandani dzina lake loyera. 
\c 98  
\cl Salimo 98 
\d Salimo. 
\q1  
\v 1 Imbirani Yehova nyimbo yatsopano, 
\q2 pakuti Iyeyo wachita zinthu zodabwitsa; 
\q1 dzanja lake lamanja ndi mkono wake woyera 
\q2 zamuchitira chipulumutso. 
\q1  
\v 2 Yehova waonetsa chipulumutso chake 
\q2 ndipo waulula chilungamo chake kwa anthu a mitundu ina. 
\q1  
\v 3 Iye wakumbukira chikondi chake 
\q2 ndi kukhulupirika kwake pa Aisraeli; 
\q1 malekezero onse a dziko lapansi aona 
\q2 chipulumutso cha Mulungu wathu. 
\b  
\q1  
\v 4 Fuwulani mwachimwemwe kwa Yehova, dziko lonse lapansi, 
\q2 muyimbireni nyimbo mofuwula ndi mokondwera. 
\q1  
\v 5 Imbirani Yehova nyimbo ndi zeze, 
\q2 ndi zeze ndi mawu a kuyimba, 
\q1  
\v 6 ndi malipenga ndi kuliza kwa nyanga ya nkhosa yayimuna 
\q2 fuwulani mwachimwemwe pamaso pa Yehova Mfumu. 
\b  
\q1  
\v 7 Nyanja ikokome pamodzi ndi zonse zili mʼmenemo, 
\q2 dziko lonse ndi onse amene amakhala mʼmenemo. 
\q1  
\v 8 Mitsinje iwombe mʼmanja mwawo, 
\q2 mapiri ayimbe pamodzi mwachimwemwe; 
\q1  
\v 9 izo ziyimbe pamaso pa Yehova, 
\q2 pakuti Iye akubwera kudzaweruza dziko lapansi. 
\q1 Adzaweruza dziko lonse mwachilungamo, 
\q2 ndi mitundu ya anthu mosakondera. 
\c 99  
\cl Salimo 99 
\q1  
\v 1 Yehova akulamulira, 
\q2 mitundu ya anthu injenjemere; 
\q1 Iye wakhala pa mpando wake waufumu, pakati pa akerubi, 
\q2 dziko lapansi ligwedezeke. 
\q1  
\v 2 Mʼziyoni wamkulu ndi Yehova; 
\q2 Iye ndi wokwezeka pamwamba pa mitundu yonse ya anthu. 
\q1  
\v 3 Anthu atamande dzina lanu lalikulu ndi loopsa kwambiri, 
\q2 Iye ndi woyera. 
\b  
\q1  
\v 4 Mfumu yamphamvu, iyo imakonda chilungamo 
\q2 Inu mwakhazikitsa khalidwe losakondera; 
\q1 mwachita zolungama ndi zoyenera mwa Yakobo. 
\q1  
\v 5 Kwezani Yehova Mulungu wathu 
\q2 ndipo mulambireni pa mapazi ake; 
\q2 Iye ndi woyera. 
\b  
\q1  
\v 6 Mose ndi Aaroni anali ena mwa ansembe ake, 
\q2 Samueli anali pamodzi ndi iwo amene anayitana pa dzina lake; 
\q1 iwo anayitana Yehova 
\q2 ndipo Iyeyo anawayankha. 
\q1  
\v 7 Iye anayankhula nawo kuchokera mʼchipilala cha mtambo; 
\q2 iwo anasunga malamulo ake ndi zophunzitsa zomwe anawapatsa. 
\b  
\q1  
\v 8 Inu Yehova Mulungu wathu, 
\q2 munawayankha iwo; 
\q1 Inu kwa Israeli munali Mulungu wokhululuka, 
\q2 ngakhale munawalanga pa zochita zawo zoyipa. 
\q1  
\v 9 Kwezani Yehova Mulungu wathu 
\q2 ndipo mumulambire pa phiri lake loyera, 
\q2 pakuti Yehova Mulungu wathu ndi woyera. 
\c 100  
\cl Salimo 100 
\d Salimo. Nyimbo yothokoza. 
\q1  
\v 1 Fuwulani kwa Yehova mwachimwemwe, inu dziko lonse lapansi. 
\q2  
\v 2 Mulambireni Yehova mosangalala; 
\q2 bwerani pamaso pake ndi nyimbo zachikondwerero. 
\q1  
\v 3 Dziwani kuti Yehova ndi Mulungu. 
\q2 Iye ndiye amene anatipanga ndipo ife ndife ake; 
\q2 ndife anthu ake, nkhosa za pabusa pake. 
\b  
\q1  
\v 4 Lowani ku zipata zake ndi chiyamiko 
\q2 ndi ku mabwalo ake ndi matamando; 
\q2 muyamikeni ndi kutamanda dzina lake. 
\q1  
\v 5 Pakuti Yehova ndi wabwino ndipo chikondi chake ndi chamuyaya; 
\q2 kukhulupirika kwake nʼkokhazikika pa mibado ndi mibado. 
\c 101  
\cl Salimo 101 
\d Salimo la Davide. 
\q1  
\v 1 Ndidzayimba za chikondi ndi chiweruzo chanu cholungama; 
\q2 kwa Inu Yehova ndidzayimba matamando. 
\q1  
\v 2 Ndidzatsata njira yolungama; 
\q2 nanga mudzabwera liti kwa ine? 
\b  
\q1 Ndidzayenda mʼnyumba mwanga 
\q2 ndi mtima wosalakwa. 
\q1  
\v 3 Sindidzayika chinthu chilichonse choyipa 
\q2 pamaso panga. 
\b  
\q1 Ine ndimadana ndi zochita za anthu opanda chikhulupiriro; 
\q2 iwo sadzadziphatika kwa ine. 
\q1  
\v 4 Anthu a mtima wokhota adzakhala kutali ndi ine; 
\q2 ine sindidzalola choyipa chilichonse kulowa mwa ine. 
\b  
\q1  
\v 5 Aliyense wosinjirira mnansi wake mseri 
\q2 ameneyo ndidzamuletsa; 
\q1 aliyense amene ali ndi maso amwano ndi mtima wodzikuza, 
\q2 ameneyo sindidzamulekerera. 
\b  
\q1  
\v 6 Maso anga adzakhala pa okhulupirika mʼdziko, 
\q2 kuti akhale pamodzi ndi ine; 
\q1 iye amene mayendedwe ake ndi wosalakwa 
\q2 adzanditumikira. 
\b  
\q1  
\v 7 Aliyense wochita chinyengo 
\q2 sadzakhala mʼnyumba mwanga. 
\q1 Aliyense woyankhula mwachinyengo 
\q2 sadzayima pamaso panga. 
\b  
\q1  
\v 8 Mmawa uliwonse ndidzatontholetsa anthu 
\q2 onse oyipa mʼdziko; 
\q1 ndidzachotsa aliyense wochita zoyipa 
\q2 mu mzinda wa Yehova. 
\c 102  
\cl Salimo 102 
\d Pemphero la munthu wosautsidwa, pamene walefuka, nakhuthulira pamaso pa Yehova kulira kwakeko. 
\q1  
\v 1 Yehova imvani pemphero langa; 
\q2 kulira kwanga kopempha thandizo kufike kwa Inu. 
\q1  
\v 2 Musandibisire nkhope yanu 
\q2 pamene ndili pa msautso. 
\q1 Munditcherere khutu; 
\q2 pamene ndiyitana ndiyankheni msanga. 
\b  
\q1  
\v 3 Pakuti masiku anga akupita ngati utsi; 
\q2 mafupa anga akunyeka ngati nkhuni zoyaka. 
\q1  
\v 4 Mtima wanga wakanthidwa ndipo ukufota ngati udzu; 
\q2 ndipo ndimayiwala kudya chakudya changa. 
\q1  
\v 5 Chifukwa cha kubuwula kwanga kofuwula 
\q2 ndatsala chikopa ndi mafupa okhaokha. 
\q1  
\v 6 Ndili ngati kadzidzi wa ku chipululu, 
\q2 monga kadzidzi pakati pa mabwinja. 
\q1  
\v 7 Ndimagona osapeza tulo; ndakhala 
\q2 ngati mbalame yokhala yokha pa denga. 
\q1  
\v 8 Tsiku lonse adani anga amandichita chipongwe; 
\q2 iwo amene amandinyoza, amagwiritsa ntchito dzina langa ngati temberero. 
\q1  
\v 9 Pakuti ndimadya phulusa ngati chakudya changa 
\q2 ndi kusakaniza chakumwa changa ndi misozi 
\q1  
\v 10 chifukwa cha ukali wanu waukulu, 
\q2 popeza Inu mwandinyamula ndi kunditayira kumbali. 
\q1  
\v 11 Masiku anga ali ngati mthunzi wa kumadzulo; 
\q2 Ine ndikufota ngati udzu. 
\b  
\q1  
\v 12 Koma Inu Yehova, muli pa mpando wanu waufumu kwamuyaya; 
\q2 kudziwika kwanu ndi kokhazikika ku mibado yonse. 
\q1  
\v 13 Inu mudzadzuka ndi kuchitira chifundo Ziyoni 
\q2 pakuti ndi nthawi yoti muonetse kukoma mtima kwanu pa iyeyo; 
\q2 nthawi yoyikika yafika. 
\q1  
\v 14 Pakuti miyala yake ndi yokondedwa kwa atumiki anu; 
\q2 fumbi lake lokha limawachititsa kuti amve chisoni. 
\q1  
\v 15 Mitundu ya anthu idzaopa dzina la Yehova, 
\q2 mafumu onse a dziko lapansi adzalemekeza ulemerero wanu. 
\q1  
\v 16 Pakuti Yehova adzamanganso Ziyoni 
\q2 ndi kuonekera mu ulemerero wake. 
\q1  
\v 17 Iye adzayankha pemphero la anthu otayika; 
\q2 sadzanyoza kupempha kwawo. 
\b  
\q1  
\v 18 Zimenezi zilembedwe chifukwa cha mibado ya mʼtsogolo, 
\q2 kuti anthu amene sanabadwe adzatamande Yehova: 
\q1  
\v 19 “Yehova anayangʼana pansi kuchokera ku malo ake opatulika mmwamba, 
\q2 kuchokera kumwamba anayangʼana dziko lapansi, 
\q1  
\v 20 kuti amve kubuwula kwa anthu a mʼndende, 
\q2 kuti apulumutse amene anayenera kuphedwa.” 
\q1  
\v 21 Kotero dzina la Yehova lidzalengezedwa mu Ziyoni 
\q2 ndi matamando ake mu Yerusalemu, 
\q1  
\v 22 pamene mitundu ya anthu ndi maufumu 
\q2 adzasonkhana kuti alambire Yehova. 
\b  
\q1  
\v 23 Iye anathyola mphamvu zanga pa nthawi ya moyo wanga; 
\q2 Iyeyo anafupikitsa masiku anga. 
\q1  
\v 24 Choncho Ine ndinati: 
\q2 “Musandichotse, Inu Mulungu wanga, pakati pa masiku a moyo wanga; 
\q2 zaka zanu zimakhalabe pa mibado yonse. 
\q1  
\v 25 Pachiyambi Inu munakhazikitsa maziko a dziko lapansi 
\q2 ndipo mayiko akumwamba ndi ntchito ya manja anu. 
\q1  
\v 26 Izi zidzatha, koma Inu mudzakhalapo; 
\q2 zidzatha ngati chovala. 
\q1 Mudzazisintha ngati chovala 
\q2 ndipo zidzatayidwa. 
\q1  
\v 27 Koma Inu simusintha, 
\q2 ndipo zaka zanu sizidzatha. 
\q1  
\v 28 Ana a atumiki anu adzakhala pamaso panu; 
\q2 zidzukulu zawo zidzakhazikika pamaso panu.” 
\c 103  
\cl Salimo 103 
\d Salimo la Davide. 
\q1  
\v 1 Tamanda Yehova, iwe moyo wanga; 
\q2 ndi zonse zamʼkati mwanga zitamande dzina lake loyera. 
\q1  
\v 2 Tamanda Yehova, iwe moyo wanga, 
\q2 ndipo usayiwale zabwino zake zonse. 
\q1  
\v 3 Amene amakhululuka machimo ako onse 
\q2 ndi kuchiritsa nthenda zako zonse, 
\q1  
\v 4 amene awombola moyo wako ku dzenje 
\q2 ndi kukuveka chikondi ndi chifundo chake ngati chipewa chaufumu, 
\q1  
\v 5 amene akwaniritsa zokhumba zako ndi zinthu zabwino, 
\q2 kotero kuti umakhala wamphamvu zatsopano ngati mphungu. 
\b  
\q1  
\v 6 Yehova amachita chilungamo 
\q2 ndipo amaweruza molungama onse opsinjika. 
\b  
\q1  
\v 7 Iye anadziwitsa Mose njira zake, 
\q2 ntchito zake kwa Aisraeli. 
\q1  
\v 8 Yehova ndi wachifundo ndi wokoma mtima, 
\q2 wosakwiya msanga ndi wachikondi chochuluka. 
\q1  
\v 9 Iye sadzatsutsa nthawi zonse, 
\q2 kapena kusunga mkwiyo wake kwamuyaya; 
\q1  
\v 10 satichitira molingana ndi machimo athu, 
\q2 kapena kutibwezera molingana ndi mphulupulu zathu. 
\q1  
\v 11 Pakuti monga kumwamba kuli kutali ndi dziko lapansi, 
\q2 koteronso chikondi chake nʼchachikulu kwa iwo amene amamuopa; 
\q1  
\v 12 monga kummawa kutalikirana ndi kumadzulo, 
\q2 koteronso Iye watichotsera mphulupulu zathu kuti zikhale kutali nafe. 
\q1  
\v 13 Monga bambo amachitira chifundo ana ake, 
\q2 choncho Yehova ali ndi chifundo ndi iwo amene amamuopa; 
\q1  
\v 14 pakuti Iye amadziwa momwe tinawumbidwira, 
\q2 amakumbukira kuti ndife fumbi. 
\q1  
\v 15 Kunena za munthu, masiku ake ali ngati udzu, 
\q2 amaphuka ngati duwa la mʼmunda; 
\q1  
\v 16 koma mphepo imawombapo ndipo silionekanso 
\q2 ndipo malo ake sakumbukirikanso. 
\q1  
\v 17 Koma kuchokera muyaya mpaka muyaya 
\q2 chikondi cha Yehova chili ndi iwo amene amamuopa, 
\q2 ndi chilungamo chake chili ndi ana a ana awo; 
\q1  
\v 18 iwo amene amasunga pangano lake 
\q2 ndi kukumbukira kumvera malangizo ake. 
\b  
\q1  
\v 19 Yehova wakhazikitsa mpando wake waufumu mmwamba 
\q2 ndipo ufumu wake umalamulira onse. 
\b  
\q1  
\v 20 Tamandani Yehova, inu angelo ake, 
\q2 amphamvu inu amene mumachita zimene amalamula, 
\q2 amene mumamvera mawu ake. 
\q1  
\v 21 Tamandani Yehova, zolengedwa zonse zakumwamba, 
\q2 inu atumiki ake amene mumachita chifuniro chake. 
\q1  
\v 22 Tamandani Yehova, ntchito yake yonse 
\q2 kulikonse mu ulamuliro wake. 
\b  
\q1 Tamanda Yehova, iwe moyo wanga. 
\c 104  
\cl Salimo 104 
\q1  
\v 1 Tamanda Yehova, iwe moyo wanga. 
\b  
\q1 Inu Yehova Mulungu wanga, ndinu wamkulu kwambiri; 
\q2 mwavala ulemerero ndi ufumu. 
\q1  
\v 2 Iye wadzifunditsa kuwala ngati chovala; 
\q2 watambasula miyamba ngati tenti 
\q2  
\v 3 ndipo wayika pa madzi mitanda ya chipinda chake. 
\q1 Iye amasandutsa mitambo kukhala galeta lake, 
\q2 ndi kuwuluka pa mapiko a mphepo. 
\q1  
\v 4 Amapanga mphepo kukhala amithenga ake, 
\q2 malawi amoto kukhala atumiki ake. 
\b  
\q1  
\v 5 Anakhazikitsa dziko lapansi pa maziko ake; 
\q2 silingasunthike. 
\q1  
\v 6 Munaliphimba ndi nyanja yozama ngati chovala; 
\q2 madzi anayimirira pamwamba pa mapiri. 
\q1  
\v 7 Koma pakudzudzula kwanu madzi anathawa, 
\q2 pa mkokomo wa bingu lanu iwo anamwazika; 
\q1  
\v 8 Inu munamiza mapiri, 
\q2 iwo anatsikira ku zigwa 
\q2 kumalo kumene munawakonzera. 
\q1  
\v 9 Inu munayika malire ndipo sangathe kudutsa, 
\q2 iwo sadzamizanso dziko lapansi. 
\b  
\q1  
\v 10 Iye achititsa akasupe kutulutsa madzi kupita ku zigwa; 
\q2 madziwo amayenda pakati pa mapiri. 
\q1  
\v 11 Iwo amapereka madzi kwa zirombo zonse zakuthengo; 
\q2 abulu akuthengo amapha ludzu lawo. 
\q1  
\v 12 Mbalame zamlengalenga zimayika zisa mʼmbali mwa madzi; 
\q2 zimayimba pakati pa thambo. 
\q1  
\v 13 Iye amathirira mapiri kuchokera ku zipinda zake zapamwamba; 
\q2 dziko lapansi limakhutitsidwa ndi chipatso cha ntchito yake. 
\q1  
\v 14 Amameretsa udzu kuti ngʼombe zidye, 
\q2 ndi zomera, kuti munthu azilima 
\q2 kubweretsa chakudya kuchokera mʼdziko lapansi: 
\q1  
\v 15 vinyo amene amasangalatsa mtima wa munthu, 
\q2 mafuta amene amachititsa nkhope yake kuwala, 
\q2 ndi buledi amene amapereka mphamvu. 
\q1  
\v 16 Mitengo ya Yehova ndi yothiriridwa bwino, 
\q2 mikungudza ya ku Lebanoni imene Iye anadzala. 
\q1  
\v 17 Mbalame zimamanga zisa zawo; 
\q2 kakowa ali ndi malo ake mʼmikungudzamo. 
\q1  
\v 18 Mapiri ataliatali ndi a mbalale; 
\q2 mʼmingʼalu ya miyala ndi mobisalamo mbira. 
\b  
\q1  
\v 19 Mwezi umasiyanitsa nyengo 
\q2 ndipo dzuwa limadziwa nthawi yake yolowera. 
\q1  
\v 20 Inu mumabweretsa mdima nukhala usiku, 
\q2 ndipo zirombo zonse za ku nkhalango zimatuluka. 
\q1  
\v 21 Mikango imabangula kufuna nyama, 
\q2 ndi kufunafuna chakudya chawo kuchokera kwa Mulungu. 
\q1  
\v 22 Dzuwa limatuluka ndipo iyo imapita kukabisala; 
\q2 imabwerera kukagona pansi mʼmapanga awo. 
\q1  
\v 23 Pamenepo munthu amapita ku ntchito yake, 
\q2 kukagwira ntchito yake mpaka madzulo. 
\b  
\q1  
\v 24 Ntchito zanu ndi zochulukadi Inu Yehova! 
\q2 Munazipanga zonse mwanzeru, 
\q2 dziko lapansi ladzaza ndi zolengedwa zanu. 
\q1  
\v 25 Kuli nyanja yayikulu ndi yotambalala, 
\q2 yodzaza ndi zolengedwa zosawerengeka, 
\q2 zamoyo zanu zazikulu ndi zazingʼono zomwe. 
\q1  
\v 26 Kumeneko sitima zapamadzi zimayenda uku ndi uku, 
\q2 ndiponso Leviyatani amene munamulenga kuti asewere kumeneko. 
\b  
\q1  
\v 27 Zonsezi zimayangʼana kwa Inu 
\q2 kuti muzipatse chakudya chawo pa nthawi yake yoyenera. 
\q1  
\v 28 Mukazipatsa, 
\q2 zimachisonkhanitsa pamodzi; 
\q1 mukatsekula dzanja lanu, 
\q2 izo zimakhutitsidwa ndi zinthu zabwino. 
\q1  
\v 29 Mukabisa nkhope yanu, 
\q2 izo zimachita mantha aakulu; 
\q1 mukachotsa mpweya wawo, 
\q2 zimafa ndi kubwerera ku fumbi. 
\q1  
\v 30 Mukatumiza mzimu wanu, 
\q2 izo zimalengedwa 
\q2 ndipo mumakozanso maonekedwe a dziko lapansi. 
\b  
\q1  
\v 31 Ulemerero wa Yehova ukhalebe mpaka muyaya; 
\q2 Yehova akondwere ndi ntchito ya manja ake; 
\q1  
\v 32 Iye amene amayangʼana dziko lapansi ndipo limanjenjemera, 
\q2 amene amakhudza mapiri ndipo amatuluka utsi. 
\b  
\q1  
\v 33 Ine ndidzayimbira Yehova moyo wanga wonse; 
\q2 ndidzayimbira matamando Mulungu wanga nthawi yonse imene ndili ndi moyo. 
\q1  
\v 34 Zolingalira zanga zikhale zomukomera Iye, 
\q2 pamene ndikusangalala mwa Yehova. 
\q1  
\v 35 Koma anthu ochimwa awonongeke pa dziko lapansi 
\q2 ndipo anthu oyipa asapezekenso. 
\b  
\q1 Tamanda Yehova, Iwe moyo wanga. 
\b  
\q1 Tamandani Yehova. 
\c 105  
\cl Salimo 105 
\q1  
\v 1 Yamikani Yehova, itanani dzina lake; 
\q2 lalikirani pakati pa anthu a mitundu ina zimene Iye wachita. 
\q1  
\v 2 Imbirani Iye, imbani matamando kwa Iyeyo; 
\q2 fotokozani za machitidwe ake onse odabwitsa. 
\q1  
\v 3 Munyadire dzina lake loyera; 
\q2 mitima ya iwo amene amafunafuna Yehova ikondwere. 
\q1  
\v 4 Dalirani Yehova ndi mphamvu zake; 
\q2 funafunani nkhope yake nthawi yonse. 
\b  
\q1  
\v 5 Kumbukirani zodabwitsa zimene Iye anazichita, 
\q2 zozizwitsa zake ndi maweruzo amene anapereka, 
\q1  
\v 6 inu zidzukulu za Abrahamu mtumiki wake, 
\q2 inu ana a Yakobo, osankhika ake. 
\q1  
\v 7 Iye ndiye Yehova Mulungu wathu; 
\q2 maweruzo ake ali pa dziko lonse lapansi. 
\b  
\q1  
\v 8 Iyeyo amakumbukira pangano lake kwamuyaya, 
\q2 mawu amene analamula kwa mibado yonse, 
\q1  
\v 9 pangano limene Iye anapanga ndi Abrahamu, 
\q2 lumbiro limene analumbira kwa Isake. 
\q1  
\v 10 Iye analitsimikiza kwa Yakobo monga zophunzitsa, 
\q2 kwa Israeli monga pangano lamuyaya: 
\q1  
\v 11 “Ndidzapereka kwa iwe dziko la Kanaani 
\q2 ngati gawo la cholowa chako.” 
\b  
\q1  
\v 12 Pamene iwo anali ngati anthu ochepa mʼchiwerengero, 
\q2 ochepa ndithu, ndiponso alendo mʼdzikolo, 
\q1  
\v 13 ankayendayenda kuchoka ku mtundu wina wa anthu ndi kupita ku mtundu wina, 
\q2 kuchoka mu ufumu wina kupita ku wina. 
\q1  
\v 14 Iye sanalole wina aliyense kuwapondereza; 
\q2 anadzudzula mafumu chifukwa cha iwo: 
\q1  
\v 15 “Musakhudze odzozedwa anga; 
\q2 musachitire choyipa aneneri anga.” 
\b  
\q1  
\v 16 Iye anabweretsa njala pa dziko 
\q2 ndipo anawononga chakudya chonse; 
\q1  
\v 17 Iyeyo anatumiza munthu patsogolo pawo, 
\q2 Yosefe anagulitsidwa ngati kapolo. 
\q1  
\v 18 Iwo anavulaza mapazi ake ndi matangadza, 
\q2 khosi lake analiyika mʼzitsulo, 
\q1  
\v 19 mpaka zimene Iye ananeneratu zitakwaniritsidwa, 
\q2 mpaka mawu a Yehova ataonetsa kuti Iye ananena zoona. 
\q1  
\v 20 Mfumu inatuma munthu kukamumasula, 
\q2 wolamulira wa mitundu ya anthu anamasula iyeyo. 
\q1  
\v 21 Anamuyika kukhala wolamulira nyumba yake, 
\q2 wolamulira zonse zimene iye anali nazo, 
\q1  
\v 22 kulangiza ana a mfumu monga ankafunira 
\q2 ndi kuphunzitsa nzeru akuluakulu. 
\b  
\q1  
\v 23 Tsono Israeli analowa mu Igupto; 
\q2 Yakobo anakhala monga mlendo mʼdziko la Hamu. 
\q1  
\v 24 Yehova anachulukitsa anthu ake; 
\q2 ndipo anachititsa kuti akhale ochuluka kwambiri kuposa adani awo; 
\q1  
\v 25 amene mitima yawo anayitembenuza kuti idane ndi anthu ake, 
\q2 kukonzera chiwembu atumiki ake. 
\q1  
\v 26 Yehova anatuma Mose mtumiki wake, 
\q2 ndi Aaroni amene Iye anamusankha. 
\q1  
\v 27 Iwo anachita zizindikiro zozizwitsa pakati pawo, 
\q2 zodabwitsa zake mʼdziko la Hamu. 
\q1  
\v 28 Yehova anatumiza mdima nasandutsa dziko kuti likhale la mdima. 
\q2 Koma anthuwo anakaniratu mawu a Yehova. 
\q1  
\v 29 Yehova anasandutsa madzi awo kukhala magazi, 
\q2 kuchititsa kuti nsomba zawo zife. 
\q1  
\v 30 Dziko lawo linadzaza ndi achule 
\q2 amene analowa mʼzipinda zogona za olamulira awo. 
\q1  
\v 31 Iye anayankhula, ndipo kunabwera ntchentche zochuluka 
\q2 ndi nsabwe mʼdziko lawo lonse. 
\q1  
\v 32 Iyeyo anatembenuza mvula yawo kukhala matalala, 
\q2 ndi zingʼaningʼani mʼdziko lawo lonse; 
\q1  
\v 33 Anagwetsa mitengo yawo ya mpesa ndi mitengo yawo ya mkuyu, 
\q2 nawononganso mitengo ina ya mʼdziko lawolo. 
\q1  
\v 34 Iye anayankhula, ndipo dzombe linabwera, 
\q2 ziwala zosawerengeka; 
\q1  
\v 35 zinadya chilichonse chobiriwira cha mʼdziko lawo, 
\q2 zinadya zonse zotuluka mʼnthaka yawo. 
\q1  
\v 36 Kenaka anakantha ana onse oyamba kubadwa a mʼdziko lawo, 
\q2 zipatso zoyamba za umunthu wawo wonse. 
\b  
\q1  
\v 37 Yehova anatulutsa Israeli, atatenga siliva ndi golide wambiri, 
\q2 ndipo pakati pa mafuko awo palibe mmodzi amene anafowoka. 
\q1  
\v 38 Dziko la Igupto linakondwa pamene iwo anachoka, 
\q2 pakuti kuopsa kwa Israeli kunawagwera iwo. 
\q1  
\v 39 Iye anatambasula mitambo ngati chofunda chawo, 
\q2 ndi moto owawunikira usiku. 
\q1  
\v 40 Iwo anapempha, ndipo Iye anawabweretsera zinziri 
\q2 ndipo anawakhutitsa ndi chakudya chochokera kumwamba. 
\q1  
\v 41 Iye anatsekula thanthwe, ndipo madzi anatuluka; 
\q2 ngati mtsinje anayenda mʼchipululu. 
\b  
\q1  
\v 42 Pakuti anakumbukira lonjezo lake loyera limene 
\q2 linaperekedwa kwa Abrahamu mtumiki wake. 
\q1  
\v 43 Iye anatulutsa anthu ake akukondwera, 
\q2 osankhika ake akufuwula mwachimwemwe; 
\q1  
\v 44 Iye anawapatsa mayiko a anthu a mitundu ina 
\q2 ndipo anakhala olowamʼmalo a zimene ena anazivutikira, 
\q1  
\v 45 kuti iwo asunge malangizo ake 
\q2 ndi kutsatira malamulo ake. 
\b  
\q1 Tamandani Yehova. 
\c 106  
\cl Salimo 106 
\q1  
\v 1 Tamandani Yehova. 
\b  
\q1 Yamikani Yehova chifukwa ndi wabwino; 
\q2 pakuti chikondi chake ndi chosatha. 
\q1  
\v 2 Ndani angathe kufotokoza za ntchito zamphamvu za Yehova 
\q2 kapena kumutamanda mokwanira? 
\q1  
\v 3 Odala ndi amene amasunga chilungamo, 
\q2 amene amachita zolungama nthawi zonse. 
\q1  
\v 4 Mundikumbukire Yehova, pamene mukuonetsa kukoma mtima kwanu kwa anthu anu, 
\q2 bwerani mudzandithandize pamene mukuwapulumutsa iwo, 
\q1  
\v 5 kuti ndidzasangalale ndi chuma cha anthu anu osankhika, 
\q2 kuti ndidzakhale nacho chimwemwe cha anthu anu 
\q2 ndi kukhala pamodzi ndi cholowa chanu pa kukutamandani. 
\b  
\q1  
\v 6 Ife tachimwa monga momwe anachitira makolo athu; 
\q2 tachita zolakwa ndipo tachita moyipa. 
\q1  
\v 7 Pamene makolo athu anali mu Igupto, 
\q2 sanalingalire za zozizwitsa zanu; 
\q1 iwo sanakumbukire kukoma mtima kwanu kochuluka, 
\q2 ndipo anawukira Inu pa Nyanja Yofiira. 
\q1  
\v 8 Komabe Iye anawapulumutsa chifukwa cha dzina lake, 
\q2 kuti aonetse mphamvu zake zazikulu. 
\q1  
\v 9 Anadzudzula Nyanja Yofiira, ndipo inawuma; 
\q2 anawatsogolera mʼnyanja yakuya ngati akuyenda mʼchipululu. 
\q1  
\v 10 Anawapulumutsa mʼdzanja la amaliwongo; 
\q2 anawawombola mʼdzanja la mdani. 
\q1  
\v 11 Madzi anamiza adani awo, 
\q2 palibe mmodzi wa iwo anapulumuka. 
\q1  
\v 12 Kenaka iwo anakhulupirira malonjezo ake 
\q2 ndi kuyimba nyimbo zamatamando. 
\b  
\q1  
\v 13 Koma posachedwa anayiwala zimene Iye anachita, 
\q2 ndipo sanayembekezere uphungu wake. 
\q1  
\v 14 Mʼchipululu, anadzipereka ku zilakolako zawo; 
\q2 mʼdziko lopanda kanthu anayesa Mulungu. 
\q1  
\v 15 Choncho Iye anawapatsa chimene anapempha, 
\q2 koma anatumiza nthenda yowondetsa. 
\b  
\q1  
\v 16 Mʼmisasa, anachitira nsanje Mose ndi Aaroni, 
\q2 amene Yehova anadzipatulira. 
\q1  
\v 17 Nthaka inatsekuka ndipo inameza Datani; 
\q2 inakwirira gulu la Abiramu. 
\q1  
\v 18 Moto unayaka pakati pa otsatira awo; 
\q2 lawi lamoto linapsereza anthu oyipa. 
\b  
\q1  
\v 19 Iwo anapanga mwana wangʼombe pa Horebu 
\q2 ndi kulambira fano loyengedwa kuchokera ku chitsulo. 
\q1  
\v 20 Anasinthanitsa ulemerero wawo 
\q2 ndi fano la ngʼombe yayimuna imene imadya udzu. 
\q1  
\v 21 Anayiwala Mulungu amene anawapulumutsa, 
\q2 amene anachita zinthu zazikulu mu Igupto, 
\q1  
\v 22 zozizwitsa mʼdziko la Hamu 
\q2 ndi machitidwe ake woopsa pa Nyanja Yofiira. 
\q1  
\v 23 Choncho Iye anawawuza kuti adzawawononga, 
\q2 pakanapanda Mose, mtumiki wake wosankhidwa, 
\q1 kuyima pamaso pake, 
\q2 ndi kuletsa mkwiyo wake kuti usawawononge. 
\b  
\q1  
\v 24 Motero iwo ananyoza dziko lokoma; 
\q2 sanakhulupirire malonjezo ake. 
\q1  
\v 25 Anangʼungʼudza mʼmatenti mwawo 
\q2 ndipo sanamvere Yehova. 
\q1  
\v 26 Kotero Iye analumbira atakweza dzanja lake, 
\q2 kuti adzachititsa kuti iwowo afere mʼchipululu, 
\q1  
\v 27 kuchititsa kuti zidzukulu zawo zifere pakati pa anthu a mitundu ina 
\q2 ndi kuwabalalitsa mʼdziko lonse. 
\b  
\q1  
\v 28 Iwo anayamba kupembedza Baala-Peori 
\q2 ndi kudya nsembe zoperekedwa kwa milungu yopanda moyo; 
\q1  
\v 29 anaputa mkwiyo wa Yehova pa machitidwe awo oyipa, 
\q2 ndipo mliri unabuka pakati pawo. 
\q1  
\v 30 Koma Finehasi anayimirira ndi kulowererapo, 
\q2 ndipo mliri unaleka. 
\q1  
\v 31 Chimenechi ndicho chinayesedwa chilungamo chake, 
\q2 kwa mibado yosatha imene ikubwera. 
\b  
\q1  
\v 32 Pa madzi a ku Meriba iwo anakwiyitsa Yehova 
\q2 ndipo mavuto anabwera kwa Mose chifukwa cha anthuwo, 
\q1  
\v 33 pakuti iwowo anawukira mzimu wa Mulungu, 
\q2 ndipo pa milomo ya Mose panatuluka mawu osayenera. 
\b  
\q1  
\v 34 Aisraeliwo sanawononge mitundu ya anthu 
\q2 monga momwe Yehova anawalamulira. 
\q1  
\v 35 Koma anasakanizana ndi anthu a mitundu inayo 
\q2 ndi kuphunzira miyambo yawo. 
\q1  
\v 36 Ndipo anapembedza mafano awo, 
\q2 amene anakhala msampha kwa iwowo. 
\q1  
\v 37 Anapereka nsembe ana awo aamuna 
\q2 ndi ana awo aakazi kwa ziwanda. 
\q1  
\v 38 Anakhetsa magazi a anthu osalakwa, 
\q2 magazi a ana awo aamuna ndi a ana awo aakazi, 
\q1 amene anawapereka nsembe kwa mafano a ku Kanaani, 
\q2 ndipo dziko linayipitsidwa ndi magazi awo. 
\q1  
\v 39 Iwo anadzidetsa okha ndi zimene anachita; 
\q2 ndi machitidwe awo amakhala ngati munthu wachigololo. 
\b  
\q1  
\v 40 Tsono Yehova anakwiya ndi anthu ake 
\q2 ndipo ananyansidwa ndi cholowa chake. 
\q1  
\v 41 Iye anawapereka kwa anthu a mitundu ina, 
\q2 ndipo adani awo anawalamulira. 
\q1  
\v 42 Adani awo anawazunza 
\q2 ndi kuwakhazika pansi pa mphamvu yawo. 
\q1  
\v 43 Iye ankawapulumutsa nthawi zambiri, 
\q2 koma iwo ankatsimikiza za kuwukira 
\q2 ndipo anawonongeka mʼmachimo awo. 
\b  
\q1  
\v 44 Koma Iye anaona kuzunzika kwawo 
\q2 pamene anamva kulira kwawo; 
\q1  
\v 45 Chifukwa cha iwo Iye anakumbukira pangano lake 
\q2 ndipo anawalezera mtima chifukwa cha kukula kwa chikondi chake. 
\q1  
\v 46 Iye anachititsa kuti amene anawagwira iwo ukapolo 
\q2 awamvere chisoni. 
\b  
\q1  
\v 47 Tipulumutseni Inu Yehova Mulungu wathu, 
\q2 ndipo mutisonkhanitse kuchoka kwa anthu a mitundu ina 
\q1 kuti tithe kuyamika dzina lanu loyera 
\q2 ndi kunyadira mʼmatamando anu. 
\b  
\q1  
\v 48 Atamandike Yehova, Mulungu wa Israeli, 
\q2 Kuyambira muyaya mpaka muyaya. 
\q1 Anthu onse anene kuti, “Ameni!” 
\b  
\q1 Tamandani Yehova. 
\c 107  
\ms1 BUKU LACHISANU 
\mr Masalimo 107–150 
\cl Salimo 107 
\q1  
\v 1 Yamikani Yehova chifukwa ndi wabwino; 
\q2 pakuti chikondi chake ndi chosatha. 
\q1  
\v 2 Owomboledwa a Yehova anene zimenezi 
\q2 amene Iyeyo anawawombola mʼdzanja la mdani, 
\q1  
\v 3 iwo amene anawasonkhanitsa kuchokera ku mayiko, 
\q2 kuchokera kumadzulo ndi kummawa, kuchokera kumpoto ndi kummwera. 
\b  
\q1  
\v 4 Ena anayendayenda mʼchipululu mopanda kanthu, 
\q2 osapeza njira yopitira ku mzinda kumene akanakakhazikikako. 
\q1  
\v 5 Iwo anamva njala ndi ludzu, 
\q2 ndipo miyoyo yawo inafowokeratu. 
\q1  
\v 6 Pamenepo analirira Yehova mʼmavuto awo 
\q2 ndipo Iye anawapulumutsa ku masautso awo. 
\q1  
\v 7 Iye anawatsogolera mʼnjira yowongoka 
\q2 kupita ku mzinda umene anakakhazikikako. 
\q1  
\v 8 Ayamike Yehova chifukwa cha chikondi chake chosatha 
\q2 ndi chifukwa cha machitidwe ake odabwitsa kwa anthu onse, 
\q1  
\v 9 pakuti Iye wapha ludzu la munthu womva ludzu 
\q2 ndipo wakhutitsa wanjala ndi zinthu zabwino. 
\b  
\q1  
\v 10 Ena anakhala mu mdima ndi mʼchisoni chachikulu, 
\q2 amʼndende ovutika mʼmaunyolo achitsulo, 
\q1  
\v 11 pakuti iwowo anawukira mawu a Mulungu 
\q2 ndi kunyoza uphungu wa Wammwambamwamba. 
\q1  
\v 12 Kotero Iye anawapereka kuti agwire ntchito yakalavulagaga; 
\q2 anagwa pansi ndipo panalibe woti awathandize. 
\q1  
\v 13 Pamenepo analirira Yehova mʼmasautso awo 
\q2 ndipo Iye anawapulumutsa ku masautso awo. 
\q1  
\v 14 Yehova anawatulutsa mu mdima ndi mʼchisoni chachikulu 
\q2 ndipo anadula maunyolo awo. 
\q1  
\v 15 Ayamike Yehova chifukwa cha chikondi chake chosatha 
\q2 ndi machitidwe ake odabwitsa kwa anthu onse, 
\q1  
\v 16 pakuti Iye amathyola zipata zamkuwa 
\q2 ndi kudula pakati mipiringidzo yachitsulo. 
\b  
\q1  
\v 17 Ena anakhala zitsiru chifukwa cha njira zawo zowukira, 
\q2 ndipo anamva zowawa chifukwa cha mphulupulu zawo. 
\q1  
\v 18 Iwo ananyansidwa ndi chakudya chilichonse 
\q2 ndipo anafika pafupi ndi zipata za imfa. 
\q1  
\v 19 Pamenepo analirira Yehova mʼmasautso awo 
\q2 ndipo Iye anawapulumutsa ku masautso awowo. 
\q1  
\v 20 Iye anatumiza mawu ake ndi kuwachiritsa; 
\q2 anawalanditsa ku manda. 
\q1  
\v 21 Ayamike Yehova chifukwa cha chikondi chake chosatha 
\q2 ndi machitidwe ake odabwitsa kwa anthu. 
\q1  
\v 22 Apereke nsembe yachiyamiko 
\q2 ndi kufotokoza za ntchito zake ndi nyimbo zachimwemwe. 
\b  
\q1  
\v 23 Ena anayenda pa nyanja mʼsitima zapamadzi; 
\q2 Iwo anali anthu amalonda pa nyanja yayikulu. 
\q1  
\v 24 Anaona ntchito za Yehova, 
\q2 machitidwe ake odabwitsa mʼnyanja yakuya. 
\q1  
\v 25 Pakuti Iye anayankhula ndi kuwutsa mphepo yamkuntho 
\q2 imene inabweretsa mafunde ataliatali. 
\q1  
\v 26 Sitima za pamadzizo zinatukulidwa mmwamba ndi kutsikira pansi pakuya; 
\q2 pamene amawonongeka, kulimba mtima kwawo kunasungunuka. 
\q1  
\v 27 Anachita chizungulire ndi kudzandira ngati anthu oledzera; 
\q2 anali pa mapeto a moyo wawo. 
\q1  
\v 28 Pamenepo analirira Yehova mʼmasautso awo 
\q2 ndipo Iyeyo anawapulumutsa ku masautso awo. 
\q1  
\v 29 Yehova analetsa namondwe, 
\q2 mafunde a mʼnyanja anatontholetsedwa. 
\q1  
\v 30 Anali osangalala pamene kunakhala bata, 
\q2 ndipo Iye anawatsogolera ku dooko limene amalifuna. 
\q1  
\v 31 Ayamike Yehova chifukwa cha chikondi chake chosatha 
\q2 ndi machitidwe ake odabwitsa kwa anthu. 
\q1  
\v 32 Akuze Iye mu msonkhano wa anthu 
\q2 ndi kumutamanda pabwalo la akuluakulu. 
\b  
\q1  
\v 33 Iye anasandutsa mitsinje kukhala chipululu, 
\q2 akasupe otuluka madzi kukhala nthaka yowuma, 
\q1  
\v 34 ndiponso nthaka yachonde kukhala nthaka yamchere, 
\q2 chifukwa cha kuyipa kwa amene amakhala kumeneko. 
\q1  
\v 35 Anasandutsa chipululu kukhala mayiwe a madzi 
\q2 ndi nthaka yowuma kukhala akasupe a madzi oyenda; 
\q1  
\v 36 kumeneko Iye anabweretsa anthu anjala kuti azikhalako, 
\q2 ndipo iwo anamanga mzinda woti akhazikikeko. 
\q1  
\v 37 Anafesa mbewu mʼminda ndi kudzala mipesa 
\q2 ndipo anakolola zipatso zochuluka; 
\q1  
\v 38 Yehova anawadalitsa, ndipo chiwerengero chawo chinachuluka kwambiri, 
\q2 ndipo Iye sanalole kuti ziweto zawo zithe. 
\b  
\q1  
\v 39 Kenaka chiwerengero chawo chinachepa ndipo iwo anatsitsidwa 
\q2 chifukwa cha mazunzo, mavuto ndi chisoni; 
\q1  
\v 40 Iye amene amakhuthulira mʼnyozo pa olemekezeka 
\q2 anawachititsa kuyendayenda mʼmalo owumawo wopanda njira. 
\q1  
\v 41 Koma Iyeyo anakweza anthu osowa kuchoka ku masautso awo 
\q2 ngati magulu a nkhosa. 
\q1  
\v 42 Anthu olungama mtima amaona ndi kusangalala, 
\q2 koma anthu onse oyipa amatseka pakamwa pawo. 
\b  
\q1  
\v 43 Aliyense wanzeru asamalitse zinthu zimenezi 
\q2 ndi kuganizira za chikondi chachikulu cha Yehova. 
\c 108  
\cl Salimo 108 
\d Nyimbo. Salimo la Davide. 
\q1  
\v 1 Mtima wanga ndi wokhazikika, Inu Mulungu; 
\q2 ndidzayimba nyimbo, inde ndidzayimba nyimbo zotamanda ndi moyo wanga wonse. 
\q1  
\v 2 Dzukani, zeze ndi pangwe! 
\q2 Ine ndidzadzutsa mʼbandakucha. 
\q1  
\v 3 Ndidzakutamandani Yehova, pakati pa anthu a mitundu ina; 
\q2 ndidzayimba za Inu pakati pa anthu a mitundu ina. 
\q1  
\v 4 Pakuti chikondi chanu nʼchachikulu, kutalika kwake kuposa kumwamba; 
\q2 kukhulupirika kwanu kumafika mlengalenga. 
\q1  
\v 5 Kwezekani Inu Mulungu, kuposa mayiko akumwamba, 
\q2 ndipo ulemerero wanu uphimbe dziko lonse lapansi. 
\b  
\q1  
\v 6 Tipulumutseni ndi kutithandiza ndi dzanja lanu lamanja 
\q2 kuti iwo amene mumawakonda apulumutsidwe. 
\q1  
\v 7 Mulungu wayankhula kuchokera ku malo ake opatulika: 
\q2 “Mwachipambano Ine ndidzagawa Sekemu 
\q2 ndipo ndidzayesa chigwa cha Sukoti. 
\q1  
\v 8 Giliyadi ndi wanga, Manase ndi wanganso; 
\q2 Efereimu ndi chipewa changa chodzitetezera, 
\q2 Yuda ndi ndodo yanga yaufumu. 
\q1  
\v 9 Mowabu ndi mbale yanga yosambiramo 
\q2 ndidzaponya nsapato zanga pa Edomu; 
\q2 ndidzafuwula mopambana pa Filisitiya.” 
\b  
\q1  
\v 10 Ndani adzandifikitsa ku mzinda wotetezedwa? 
\q2 Ndani adzanditsogolera ku Edomu? 
\q1  
\v 11 Kodi sindinu Mulungu, Inu amene mwatikana 
\q2 ndipo simuperekezanso magulu athu ankhondo? 
\q1  
\v 12 Tithandizeni ife kulimbana ndi mdani, 
\q2 pakuti thandizo la munthu ndi lopanda pake. 
\q1  
\v 13 Chifukwa cha Mulungu wathu, ife tidzapeza chipambano, 
\q2 ndipo adzapondereza pansi adani athu. 
\c 109  
\cl Salimo 109 
\d Kwa mtsogoleri wamayimbidwe. Salimo la Davide. 
\q1  
\v 1 Mulungu amene ndimakutamandani, 
\q2 musakhale chete, 
\q1  
\v 2 pakuti anthu oyipa ndi achinyengo 
\q2 atsekula pakamwa pawo kutsutsana nane; 
\q2 iwo ayankhula motsutsana nane ndi malilime abodza. 
\q1  
\v 3 Andizungulira ndi mawu audani, 
\q2 amandinena popanda chifukwa. 
\q1  
\v 4 Mʼmalo mwa chikondi changa amandineneza, 
\q2 koma ine ndine munthu wapemphero. 
\q1  
\v 5 Iwo amandibwezera zoyipa mʼmalo mwa zabwino, 
\q2 ndi udani mʼmalo mwa chikondi changa. 
\b  
\q1  
\v 6 Sankhani munthu woyipa kuti amutsutse iye; 
\q2 lolani wotsutsa ayime ku dzanja lake lamanja. 
\q1  
\v 7 Pamene aweruzidwa, apezeke kuti ndi wolakwa, 
\q2 ndipo mapemphero ake amutsutse. 
\q1  
\v 8 Masiku ake akhale owerengeka; 
\q2 munthu wina atenge malo ake a utsogoleri. 
\q1  
\v 9 Ana ake akhale amasiye 
\q2 ndipo mkazi wake akhale wopanda mwamuna. 
\q1  
\v 10 Ana ake akhale oyendayenda ndi opemphapempha; 
\q2 apirikitsidwe kuchoka pa mabwinja a nyumba zawo. 
\q1  
\v 11 Wokongoza alande zonse zimene ali nazo; 
\q2 alendo afunkhe ntchito za manja ake. 
\q1  
\v 12 Pasapezeke ndi mmodzi yemwe womukomera mtima 
\q2 kapena kumvera chisoni ana ake amasiye. 
\q1  
\v 13 Zidzukulu zake zithe nʼkufa, 
\q2 mayina awo afafanizidwe mu mʼbado wotsatirawo. 
\q1  
\v 14 Mphulupulu za makolo ake zikumbukiridwe pamaso pa Yehova; 
\q2 tchimo la amayi ake lisadzafafanizidwe. 
\q1  
\v 15 Machimo awo akhale pamaso pa Yehova nthawi zonse, 
\q2 kuti Iye achotse chikumbutso chawo pa dziko lapansi. 
\b  
\q1  
\v 16 Pakuti iye sanaganizirepo zochita chifundo, 
\q2 koma anazunza mpaka kuwapha anthu osauka 
\q2 ndi osweka mtima. 
\q1  
\v 17 Anakonda kutemberera, 
\q2 matembererowo abwerere kwa iye; 
\q1 sanakondwe nʼkudalitsa anthu ena, 
\q2 choncho madalitso akhale kutali naye. 
\q1  
\v 18 Anavala kutemberera ngati chovala; 
\q2 kutemberera kunalowa mʼthupi lake ngati madzi, 
\q2 kulowa mʼmafupa ake ngati mafuta. 
\q1  
\v 19 Matemberero akhale ngati chofunda chodzikutira nacho, 
\q2 ngati lamba wovala tsiku ndi tsiku. 
\q1  
\v 20 Awa akhale malipiro ochokera kwa Yehova pa onditsutsa anga, 
\q2 kwa iwo amene amayankhula zoyipa za ine. 
\b  
\q1  
\v 21 Koma Inu Ambuye Wamphamvuzonse, 
\q2 muchite nane molingana ndi dzina lanu, 
\q2 chifukwa cha ubwino wa chikondi chanu, pulumutseni. 
\q1  
\v 22 Pakuti ndine wosauka ndi wosowa, 
\q2 ndipo mtima wanga ukuwawa mʼkati mwanga. 
\q1  
\v 23 Ndikuzimirira ngati mthunzi wa kumadzulo, 
\q2 ndapirikitsidwa ngati dzombe. 
\q1  
\v 24 Mawondo anga afowoka chifukwa cha kusala zakudya, 
\q2 thupi langa lawonda ndi mutu wanga womwe. 
\q1  
\v 25 Ndine chinthu chotonzedwa kwa otsutsana nane; 
\q2 akandiona, amapukusa mitu yawo. 
\b  
\q1  
\v 26 Thandizeni Inu Yehova Mulungu wanga; 
\q2 pulumutseni molingana ndi chikondi chanu. 
\q1  
\v 27 Adaniwo adziwe kuti limeneli ndi dzanja lanu, 
\q2 kuti Inu Yehova mwachita zimenezi. 
\q1  
\v 28 Angathe kutemberera, koma Inu mudzadalitsa; 
\q2 pamene iwo andiputa adzachititsidwa manyazi, 
\q2 koma mtumiki wanu adzasangalala. 
\q1  
\v 29 Onditsutsa adzavekedwa mnyozo, 
\q2 ndipo adzadzifunditsa manyazi ngati chovala. 
\b  
\q1  
\v 30 Ndi pakamwa panga ndidzathokoza Yehova kwambiri; 
\q2 ndidzamutamanda mʼgulu lalikulu la anthu. 
\q1  
\v 31 Popeza Iye amayima ku dzanja lamanja la munthu wosowayo, 
\q2 kupulumutsa moyo wake kwa iwo amene agamula molakwa. 
\c 110  
\cl Salimo 110 
\d Salimo la Davide. 
\q1  
\v 1 Yehova akuwuza Mbuye wanga kuti, 
\q2 “Khala ku dzanja langa lamanja 
\q1 mpaka nditasandutsa adani ako 
\q2 kukhala chopondapo mapazi ako.” 
\b  
\q1  
\v 2 Yehova adzakuza ndodo yamphamvu ya ufumu wako kuchokera mʼZiyoni; 
\q2 udzalamulira pakati pa adani ako. 
\q1  
\v 3 Ankhondo ako adzakhala odzipereka 
\q2 pa tsiku lako la nkhondo. 
\q1 Atavala chiyero chaulemerero, 
\q2 kuchokera mʼmimba ya mʼbandakucha, 
\q2 udzalandira mame a unyamata wako. 
\b  
\q1  
\v 4 Yehova walumbira 
\q2 ndipo sadzasintha maganizo ake: 
\q1 “Ndiwe wansembe mpaka muyaya 
\q2 monga mwa unsembe wa Melikizedeki.” 
\b  
\q1  
\v 5 Ambuye ali kudzanja lako lamanja; 
\q2 Iye adzaponda mafumu pa tsiku la ukali wake. 
\q1  
\v 6 Adzaweruza anthu a mitundu ina, 
\q2 adzadzaza dziko lapansi ndi mitembo ndipo adzaphwanya olamulira a pa dziko lonse lapansi. 
\q1  
\v 7 Iye adzamwa mu mtsinje wa mʼmbali mwa njira; 
\q2 choncho adzaweramutsa mutu wake. 
\c 111  
\cl Salimo 111 
\q1  
\v 1 Tamandani Yehova. 
\b  
\q1 Ndidzathokoza Yehova ndi mtima wanga wonse 
\q2 mʼbwalo la anthu olungama mtima ndi pa msonkhano. 
\b  
\q1  
\v 2 Ntchito za Yehova nʼzazikulu; 
\q2 onse amene amakondwera nazo amazilingalira. 
\q1  
\v 3 Zochita zake ndi za ulemerero ndi zaufumu, 
\q2 ndipo chilungamo chake ndi chosatha. 
\q1  
\v 4 Iye wachititsa kuti zodabwitsa zake zikumbukirike; 
\q2 Yehova ndi wokoma mtima ndi wachifundo. 
\q1  
\v 5 Amapereka chakudya kwa amene amamuopa Iye; 
\q2 amakumbukira pangano lake kwamuyaya. 
\q1  
\v 6 Waonetsa anthu ake mphamvu ya ntchito zake, 
\q2 kuwapatsa mayiko a anthu a mitundu ina. 
\q1  
\v 7 Ntchito za manja ake ndi zokhulupirika ndi zolungama; 
\q2 malangizo ake onse ndi odalirika. 
\q1  
\v 8 Malamulo ndi okhazikika ku nthawi za nthawi, 
\q2 ochitidwa mokhulupirika ndi molungama. 
\q1  
\v 9 Iyeyo amawombola anthu ake; 
\q2 anakhazikitsa pangano lake kwamuyaya 
\q2 dzina lake ndi loyera ndi loopsa. 
\b  
\q1  
\v 10 Kuopa Yehova ndicho chiyambi cha nzeru; 
\q2 onse amene amatsatira malangizo ake amamvetsa bwino zinthu. 
\q2 Iye ndi wotamandika mpaka muyaya. 
\c 112  
\cl Salimo 112 
\q1  
\v 1 Tamandani Yehova. 
\b  
\q1 Wodala munthu amene amaopa Yehova, 
\q2 amene amakondwera kwambiri ndi malamulo ake. 
\b  
\q1  
\v 2 Ana ake adzakhala amphamvu mʼdziko; 
\q2 mʼbado wa olungama mtima udzadalitsidwa. 
\q1  
\v 3 Kulemera ndi chuma zili mʼnyumba yake, 
\q2 ndipo chilungamo chake ndi chosatha. 
\q1  
\v 4 Ngakhale mu mdima kuwala kumatulukira olungama mtima; 
\q2 wokoma mtima, wachifundo ndi wowongoka mtima. 
\q1  
\v 5 Zinthu zabwino zidzabwera kwa iye amene amapereka mowolowamanja ndi wokongoletsa mwaufulu, 
\q2 amene amachita ntchito yake mwachilungamo. 
\b  
\q1  
\v 6 Ndithu sadzagwedezeka; 
\q2 munthu wolungama sadzayiwalika mpaka muyaya. 
\q1  
\v 7 Saopa akamva zoyipa zimene zachitika; 
\q2 mtima wake ndi wokhazikika ndipo amadalira Yehova. 
\q1  
\v 8 Mtima wake ndi wotetezedwa, sadzakhala ndi mantha; 
\q2 potsiriza pake adzayangʼana adani ake mwachipambano. 
\q1  
\v 9 Wopereka mphatso zake mowolowamanja kwa osauka, 
\q2 chilungamo chake chimanka mpaka muyaya; 
\q2 nyanga yake idzakwezedwa mwaulemu. 
\b  
\q1  
\v 10 Munthu woyipa adzaona zimenezi ndipo adzapsa mtima; 
\q2 adzakukuta mano ake ndipo adzasungunuka. 
\q2 Zolakalaka za anthu oyipa sizidzachitika konse. 
\c 113  
\cl Salimo 113 
\q1  
\v 1 Tamandani Yehova. 
\b  
\q1 Mutamandeni, inu atumiki a Yehova, 
\q2 tamandani dzina la Yehova. 
\q1  
\v 2 Yehova atamandidwe, 
\q2 kuyambira tsopano mpaka muyaya. 
\q1  
\v 3 Kuyambira ku matulukiro a dzuwa mpaka ku malowero ake, 
\q2 dzina la Yehova liyenera kutamandidwa. 
\b  
\q1  
\v 4 Yehova wakwezeka pa anthu a mitundu yonse, 
\q2 ulemerero wake ndi woposa mayiko akumwamba. 
\q1  
\v 5 Ndani wofanana ndi Yehova Mulungu wathu, 
\q2 Iye amene amakhala mwaufumu mmwamba? 
\q1  
\v 6 amene amawerama pansi kuyangʼana 
\q2 miyamba ndi dziko lapansi? 
\b  
\q1  
\v 7 Iye amakweza munthu wosauka kuchoka pa fumbi 
\q2 ndi kutukula munthu wosowa kuchoka pa dzala; 
\q1  
\v 8 amawakhazika pamodzi ndi mafumu, 
\q2 pamodzi ndi mafumu a anthu ake. 
\q1  
\v 9 Amakhazikitsa mayi wosabereka mʼnyumba yake 
\q2 monga mayi wa ana wosangalala. 
\b  
\q1 Tamandani Yehova. 
\c 114  
\cl Salimo 114 
\q1  
\v 1 Pamene Israeli anatuluka mu Igupto, 
\q2 nyumba ya Yakobo kuchoka ku mtundu wa anthu a chiyankhulo chachilendo, 
\q1  
\v 2 Yuda anasanduka malo opatulika a Mulungu, 
\q2 Israeli anasanduka ufumu wake. 
\b  
\q1  
\v 3 Nyanja inaona ndi kuthawa, 
\q2 mtsinje wa Yorodani unabwerera mʼmbuyo; 
\q1  
\v 4 mapiri analumphalumpha ngati nkhosa zazimuna, 
\q2 timapiri ngati ana ankhosa. 
\b  
\q1  
\v 5 Nʼchifukwa chiyani iwe unathawa? 
\q2 iwe mtsinje wa Yorodani unabwereranji mʼmbuyo? 
\q1  
\v 6 inu mapiri, munalumphalumphiranji ngati nkhosa zazimuna, 
\q2 inu timapiri, ngati ana ankhosa? 
\b  
\q1  
\v 7 Njenjemera pamaso pa Ambuye iwe dziko lapansi, 
\q2 pamaso pa Mulungu wa Yakobo, 
\q1  
\v 8 amene anasandutsa thanthwe kukhala chitsime, 
\q2 thanthwe lolimba kukhala akasupe a madzi. 
\c 115  
\cl Salimo 115 
\q1  
\v 1 Kwa ife ayi Yehova, kwa ife ayi 
\q2 koma ulemerero ukhale pa dzina lanu, 
\q2 chifukwa cha chikondi chanu chosasinthika ndiponso chifukwa cha kukhulupirika kwanu. 
\b  
\q1  
\v 2 Chifukwa chiyani anthu a mitundu ina akunena kuti, 
\q2 “Mulungu wawo ali kuti?” 
\q1  
\v 3 Mulungu wathu ali kumwamba; 
\q2 Iye amachita chilichonse chimene chimamukondweretsa. 
\q1  
\v 4 Koma mafano awo ndi siliva ndi golide, 
\q2 opangidwa ndi manja a anthu. 
\q1  
\v 5 Pakamwa ali napo koma sayankhula, 
\q2 maso ali nawo koma sapenya; 
\q1  
\v 6 makutu ali nawo koma samva, 
\q2 mphuno ali nazo koma sanunkhiza; 
\q1  
\v 7 manja ali nawo koma akakhudza samva kanthu; 
\q2 mapazi ali nawo koma sayenda; 
\q2 kapena pakhosi pawo kutulutsa mawu. 
\q1  
\v 8 Anthu amene amapanga mafanowo adzafanana nawo, 
\q2 chimodzimodzinso onse amene amadalira mafanowo. 
\b  
\q1  
\v 9 Inu Aisraeli, dalirani Yehova; 
\q2 Iye ndiye thandizo lanu ndi chishango chanu. 
\q1  
\v 10 Iwe nyumba ya Aaroni, dalira Yehova; 
\q2 Iye ndiye thandizo lako ndi chishango chako. 
\q1  
\v 11 Inu amene mumaopa Iye, dalirani Yehova; 
\q2 Iye ndiye thandizo lanu ndi chishango chanu. 
\b  
\q1  
\v 12 Yehova watikumbukira ndipo adzatidalitsa: 
\q2 adzadalitsa nyumba ya Israeli, 
\q2 adzadalitsa nyumba ya Aaroni, 
\q1  
\v 13 adzadalitsa iwo amene amaopa Yehova; 
\q2 aangʼono ndi aakulu omwe. 
\b  
\q1  
\v 14 Yehova akuwonjezereni madalitso; 
\q2 inuyo pamodzi ndi ana anu. 
\q1  
\v 15 Mudalitsidwe ndi Yehova, 
\q2 Wolenga kumwamba ndi dziko lapansi. 
\b  
\q1  
\v 16 Kumwamba ndi kwa Yehova, 
\q2 koma dziko lapansi Iye walipereka kwa anthu. 
\q1  
\v 17 Si anthu akufa amene amatamanda Yehova, 
\q2 amene amatsikira kuli chete; 
\q1  
\v 18 ndi ife amene timatamanda Yehova, 
\q2 kuyambira tsopano mpaka muyaya. 
\b  
\q1 Tamandani Yehova. 
\c 116  
\cl Salimo 116 
\q1  
\v 1 Ndimakonda Yehova pakuti Iyeyo amamva mawu anga; 
\q2 Iye amamva kulira kwanga kopempha chifundo. 
\q1  
\v 2 Pakuti ananditchera khutu, 
\q2 ndidzayitana Iye masiku onse a moyo wanga. 
\b  
\q1  
\v 3 Zingwe za imfa zinandizinga, 
\q2 zoopsa za ku dziko la anthu akufa zinandigwera; 
\q2 ndinapeza mavuto ndi chisoni. 
\q1  
\v 4 Pamenepo ndinayitana dzina la Yehova: 
\q2 “Inu Yehova, pulumutseni!” 
\b  
\q1  
\v 5 Yehova ndi wokoma mtima ndi wolungama 
\q2 Mulungu wathu ndi wodzaza ndi chifundo. 
\q1  
\v 6 Yehova amateteza munthu wodzichepetsa mtima; 
\q2 pamene ndinali ndi chosowa chachikulu, Iye anandipulumutsa. 
\b  
\q1  
\v 7 Pumula iwe moyo wanga, 
\q2 pakuti Yehova wakuchitira zokoma. 
\b  
\q1  
\v 8 Pakuti Inu Yehova mwapulumutsa moyo wanga ku imfa, 
\q2 maso anga ku misozi, 
\q2 mapazi anga kuti angapunthwe, 
\q1  
\v 9 kuti ine ndiyende pamaso pa Yehova 
\q2 mʼdziko la anthu amoyo. 
\q1  
\v 10 Ine ndinakhulupirira; choncho ndinati, 
\q2 “Ndasautsidwa kwambiri.” 
\q1  
\v 11 Ndipo ndili mʼnkhawa yanga ndinati, 
\q2 “Anthu onse ndi abodza.” 
\b  
\q1  
\v 12 Ndingamubwezere chiyani Yehova, 
\q2 chifukwa cha zokoma zake zonse zimene wandichitira? 
\q1  
\v 13 Ndidzakweza chikho cha chipulumutso 
\q2 ndipo ndidzayitana dzina la Yehova. 
\q1  
\v 14 Ndidzakwaniritsa malonjezo anga kwa Yehova 
\q2 pamaso pa anthu ake onse. 
\b  
\q1  
\v 15 Imfa ya anthu oyera mtima 
\q2 ndi yamtengowapatali pamaso pa Yehova. 
\q1  
\v 16 Inu Yehova, zoonadi ndine mtumiki wanu: 
\q2 ndine mtumiki wanu, mwana wa mdzakazi wanu; 
\q2 Inu mwamasula maunyolo anga. 
\b  
\q1  
\v 17 Ndidzapereka nsembe yachiyamiko kwa Inu 
\q2 ndipo ndidzayitanira pa dzina la Yehova. 
\q1  
\v 18 Ndidzakwaniritsa malonjezo anga kwa Yehova 
\q2 pamaso pa anthu ake onse, 
\q1  
\v 19 mʼmabwalo a nyumba ya Yehova, 
\q2 mʼkati mwako iwe Yerusalemu. 
\b  
\q1 Tamandani Yehova. 
\c 117  
\cl Salimo 117 
\q1  
\v 1 Tamandani Yehova, inu anthu a mitundu yonse; 
\q2 mulemekezeni Iye, inu mitundu ya anthu. 
\q1  
\v 2 Pakuti chikondi chake pa ife ndi chachikulu, 
\q2 ndipo kukhulupirika kwa Yehova nʼkosatha. 
\b  
\q1 Tamandani Yehova. 
\c 118  
\cl Salimo 118 
\q1  
\v 1 Yamikani Yehova chifukwa ndi wabwino; 
\q2 pakuti chikondi chake chosasinthika ndi chosatha. 
\b  
\q1  
\v 2 Israeli anene kuti: 
\q2 “Chikondi chake ndi chosatha.” 
\q1  
\v 3 Banja la Aaroni linene kuti, 
\q2 “Chikondi chake ndi chosatha.” 
\q1  
\v 4 Iwo amene amaopa Yehova anene kuti: 
\q2 “Chikondi chake ndi chosatha.” 
\b  
\q1  
\v 5 Ndili mʼmasautso anga ndinalirira Yehova, 
\q2 ndipo Iye anayankha pondichotsa mʼmasautsowo. 
\q1  
\v 6 Yehova ali nane; sindidzachita mantha. 
\q2 Munthu angandichite chiyani? 
\q1  
\v 7 Yehova ali nane; Iye ndiye thandizo langa. 
\q2 Ndidzayangʼana adani anga mwachipambano. 
\b  
\q1  
\v 8 Nʼkwabwino kuthawira kwa Yehova 
\q2 kusiyana ndi kudalira munthu. 
\q1  
\v 9 Nʼkwabwino kuthawira kwa Yehova 
\q2 kusiyana ndi kudalira mafumu. 
\b  
\q1  
\v 10 Anthu a mitundu yonse anandizinga, 
\q2 koma mʼdzina la Yehova ndinawawononga. 
\q1  
\v 11 Anandizinga mbali zonse, 
\q2 koma mʼdzina la Yehova ndinawawononga. 
\q1  
\v 12 Anandizinga ngati njuchi, 
\q2 koma anatha msanga ngati moto wapaminga; 
\q2 mʼdzina la Yehova ndinawawononga. 
\b  
\q1  
\v 13 Anandikankha uku ndi uko ndipo ndinali pafupi kugwa, 
\q2 koma Yehova anandithandiza. 
\q1  
\v 14 Yehova ndiye mphamvu yanga ndi nyimbo yanga; 
\q2 Iye wakhala chipulumutso changa. 
\b  
\q1  
\v 15 Mfuwu wachimwemwe ndi chipambano 
\q2 ukumveka mʼmatenti a anthu olungama mtima kuti: 
\q1 “Dzanja lamanja la Yehova lachita zamphamvu! 
\q2  
\v 16 Dzanja lamanja la Yehova latukulidwa mmwamba 
\q2 Dzanja lamanja la Yehova lachita zamphamvu!” 
\b  
\q1  
\v 17 Sindidzafa koma ndidzakhala ndi moyo 
\q2 ndipo ndidzalalika za ntchito ya Yehova. 
\q1  
\v 18 Yehova wandilanga koopsa, 
\q2 koma sanandipereke ku imfa. 
\b  
\q1  
\v 19 Tsekulireni zipata zachilungamo, 
\q2 kuti ndifike kudzayamika Yehova. 
\q1  
\v 20 Ichi ndicho chipata cha Yehova 
\q2 chimene olungama mtima okha adzalowerapo. 
\q1  
\v 21 Ndidzakuyamikani chifukwa Inu munandiyankha; 
\q2 mwakhala chipulumutso changa. 
\b  
\q1  
\v 22 Mwala umene amisiri omanga nyumba anawukana 
\q2 wasanduka wapangodya; 
\q1  
\v 23 Yehova ndiye wachita zimenezi 
\q2 ndipo nʼzodabwitsa pamaso pathu. 
\q1  
\v 24 Lero ndiye tsiku limene Yehova walipanga; 
\q2 tiyeni tikondwere ndi kusangalala nalo. 
\b  
\q1  
\v 25 Inu Yehova, tipulumutseni; 
\q2 Yehova, tipambanitseni. 
\q1  
\v 26 Wodala amene akubwera mʼdzina la Yehova. 
\q2 Tikukudalitsani kuchokera ku nyumba ya Yehova. 
\q1  
\v 27 Yehova ndi Mulungu, 
\q2 ndipo kuwala kwake kwatiwunikira Ife. 
\q1 Lowani nawo pa mʼdipiti wa ku chikondwerero mutanyamula nthambi mʼdzanja lanu, 
\q2 mpaka ku nyanga za guwa. 
\b  
\q1  
\v 28 Inu ndinu Mulungu wanga, ndipo ndidzakuyamikani; 
\q2 Inu ndinu Mulungu wanga, ndipo ndidzakukwezani. 
\b  
\q1  
\v 29 Yamikani Yehova chifukwa ndi wabwino; 
\q2 pakuti chikondi chake chosasinthika ndi chosatha. 
\c 119  
\cl Salimo 119 
\qa Alefu 
\q1  
\v 1 Odala ndi amene moyo wawo ulibe cholakwa, 
\q2 amene amayenda monga mwa malamulo a Yehova. 
\q1  
\v 2 Odala ndi amene amasunga malamulo ake, 
\q2 amene amafunafuna Iyeyo ndi mtima wawo wonse. 
\q1  
\v 3 Sachita cholakwa chilichonse; 
\q2 amayenda mʼnjira zake. 
\q1  
\v 4 Inu mwapereka malangizo 
\q2 ndipo ayenera kutsatidwa kwathunthu. 
\q1  
\v 5 Aa! Ndikanakonda njira zanga zikanakhala zokhazikika 
\q2 pa kumvera zophunzitsa zanu! 
\q1  
\v 6 Pamenepo ine sindikanachititsidwa manyazi, 
\q2 poganizira malamulo anu onse. 
\q1  
\v 7 Ndidzakutamandani ndi mtima wolungama, 
\q2 pamene ndikuphunzira malamulo anu olungama. 
\q1  
\v 8 Ndidzamvera zophunzitsa zanu; 
\q2 musanditaye kwathunthu. 
\qa Beti 
\q1  
\v 9 Kodi mnyamata angathe bwanji kuyeretsa mayendedwe ake? 
\q2 Akawasamala potsata mawu anu. 
\q1  
\v 10 Ndimakufunafunani ndi mtima wanga wonse; 
\q2 musalole kuti ndisochere kuchoka pa malamulo anu. 
\q1  
\v 11 Ndasunga mawu anu mu mtima mwanga 
\q2 kuti ndisakuchimwireni. 
\q1  
\v 12 Mutamandike Inu Yehova; 
\q2 phunzitseni malamulo anu. 
\q1  
\v 13 Ndi milomo yanga ndimafotokoza malamulo anu onse 
\q2 amene amachokera pakamwa panu. 
\q1  
\v 14 Ndimakondwera potsatira malamulo anu 
\q2 monga momwe munthu amakondwera akakhala ndi chuma chambiri. 
\q1  
\v 15 Ndimalingalira malangizo anu 
\q2 ndipo ndimaganizira njira zanu. 
\q1  
\v 16 Ndimakondwera ndi malamulo anu; 
\q2 sindidzayiwala konse mawu anu. 
\qa Gimeli 
\q1  
\v 17 Chitirani zokoma mtumiki wanu, ndipo ndidzakhala ndi moyo; 
\q2 kuti tsono ndisunge mawu anu. 
\q1  
\v 18 Tsekulani maso anga kuti ndithe kuona 
\q2 zinthu zodabwitsa mʼmalamulo anu. 
\q1  
\v 19 Ine ndine mlendo pa dziko lapansi; 
\q2 musandibisire malamulo anu. 
\q1  
\v 20 Moyo wanga wafowoka polakalaka 
\q2 malamulo anu nthawi zonse. 
\q1  
\v 21 Inu mumadzudzula onyada, otembereredwa, 
\q2 amene achoka pa malamulo anu. 
\q1  
\v 22 Mundichotsere chitonzo ndi mnyozo 
\q2 pakuti ndimasunga malamulo anu. 
\q1  
\v 23 Ngakhale mafumu akhale pamodzi kundinyoza, 
\q2 mtumiki wanu adzalingalirabe zophunzitsa zanu. 
\q1  
\v 24 Malamulo anu amandikondweretsa; 
\q2 ndiwo amene amandilangiza. 
\qa Daleti 
\q1  
\v 25 Moyo wanga wakangamira fumbi; 
\q2 tsitsimutseni molingana ndi mawu anu. 
\q1  
\v 26 Ndinafotokoza njira zanga ndipo Inu munandiyankha; 
\q2 phunzitseni malamulo anu. 
\q1  
\v 27 Mundidziwitse chiphunzitso cha malangizo anu; 
\q2 pamenepo ndidzalingalira zodabwitsa zanu. 
\q1  
\v 28 Moyo wanga wafowoka ndi chisoni; 
\q2 limbikitseni monga mwa mawu anu. 
\q1  
\v 29 Mundichotse mʼnjira zachinyengo; 
\q2 mundikomere mtima pondiphunzitsa malamulo anu. 
\q1  
\v 30 Ndasankha njira ya choonadi; 
\q2 ndayika malamulo anu pa mtima panga. 
\q1  
\v 31 Ndagwiritsitsa umboni wanu, Inu Yehova; 
\q2 musalole kuti ndichititsidwe manyazi. 
\q1  
\v 32 Ndimathamanga mʼnjira ya malamulo anu, 
\q2 pakuti Inu mwamasula mtima wanga. 
\qa He 
\q1  
\v 33 Yehova, phunzitseni kutsatira zophunzitsa zanu; 
\q2 ndipo ndidzazisunga mpaka kumapeto. 
\q1  
\v 34 Mundipatse mtima womvetsa zinthu ndipo ndidzasunga malamulo anu 
\q2 ndi kuwamvera ndi mtima wanga wonse. 
\q1  
\v 35 Munditsogolere mʼnjira ya malamulo anu, 
\q2 pakuti mʼmenemo ndimapezamo chikondwerero changa. 
\q1  
\v 36 Tembenuzani mtima wanga kuti uzikonda malamulo anu, 
\q2 osati chuma. 
\q1  
\v 37 Tembenuzani maso anga kuchoka ku zinthu zachabechabe; 
\q2 sungani moyo wanga monga mwa mawu anu. 
\q1  
\v 38 Kwaniritsani lonjezo lanu kwa mtumiki wanu, 
\q2 kuti Inu muopedwe. 
\q1  
\v 39 Mundichotsere chipongwe chimene ndikuchiopa, 
\q2 pakuti malamulo anu ndi abwino. 
\q1  
\v 40 Taonani, ndimalakalakatu malangizo anu! 
\q2 Sungani moyo wanga mʼchilungamo chanu. 
\qa Wawi 
\q1  
\v 41 Chikondi chanu chosasinthika chibwere kwa ine, Inu Yehova, 
\q2 chipulumutso chanu monga mwa lonjezo lanu; 
\q1  
\v 42 ndipo ndidzayankha amene amandinyoza, 
\q2 popeza ndimadalira mawu anu. 
\q1  
\v 43 Musakwatule mawu a choonadi mʼkamwa mwanga, 
\q2 pakuti ndakhazikitsa chiyembekezo changa mʼmalamulo anu. 
\q1  
\v 44 Ndidzasunga malamulo anu nthawi zonse, 
\q2 ku nthawi za nthawi. 
\q1  
\v 45 Ndidzayendayenda mwaufulu, 
\q2 chifukwa ndinafunafuna malangizo anu. 
\q1  
\v 46 Ndidzayankhula za umboni wanu pamaso pa mfumu 
\q2 ndipo sindidzachititsidwa manyazi, 
\q1  
\v 47 popeza ndimakondwera ndi malamulo anu 
\q2 chifukwa ndimawakonda. 
\q1  
\v 48 Ndikweza manja anga ku malamulo anu, ku malamulo amene ndimawakonda, 
\q2 ndipo ndimalingalira malangizo anu. 
\qa Zayini 
\q1  
\v 49 Kumbukirani mawu anu kwa mtumiki wanu, 
\q2 popeza mwandipatsa chiyembekezo. 
\q1  
\v 50 Chitonthozo changa pa masautso anga ndi ichi: 
\q2 lonjezo lanu limasunga moyo wanga. 
\q1  
\v 51 Odzikuza amandinyoza popanda chowaletsa, 
\q2 koma sindichoka pa malamulo anu. 
\q1  
\v 52 Ndimakumbukira malamulo anu Yehova akalekale, 
\q2 ndipo mwa iwo ndimapeza chitonthozo. 
\q1  
\v 53 Ndayipidwa kwambiri chifukwa cha oyipa 
\q2 amene ataya malamulo anu. 
\q1  
\v 54 Zophunzitsa zanu ndi mitu ya nyimbo yanga 
\q2 kulikonse kumene ndigonako. 
\q1  
\v 55 Usiku ndimakumbukira dzina lanu Yehova, 
\q2 ndipo ndidzasunga malamulo anu. 
\q1  
\v 56 Ichi ndicho ndakhala ndikuchita: 
\q2 ndimasunga malangizo anu. 
\qa Heti 
\q1  
\v 57 Yehova, Inu ndiye gawo langa; 
\q2 ndalonjeza kumvera mawu anu. 
\q1  
\v 58 Ndimafunafuna nkhope yanu ndi mtima wanga wonse; 
\q2 mundikomere mtima monga mwa lonjezo lanu. 
\q1  
\v 59 Ndinalingalira za njira zanga 
\q2 ndipo ndatembenuza mayendedwe anga kutsatira umboni wanu. 
\q1  
\v 60 Ndidzafulumira ndipo sindidzazengereza 
\q2 kumvera malamulo anu. 
\q1  
\v 61 Ngakhale oyipa andimange ndi zingwe, 
\q2 sindidzayiwala lamulo lanu. 
\q1  
\v 62 Ndimadzuka pakati pa usiku kuyamika Inu 
\q2 chifukwa cha malamulo anu olungama. 
\q1  
\v 63 Ine ndine bwenzi la onse amene amakukondani, 
\q2 kwa onse amene amatsatira malangizo anu. 
\q1  
\v 64 Dziko lapansi ladzaza ndi chikondi chanu chosasinthika, 
\q2 phunzitseni malamulo anu. 
\qa Teti 
\q1  
\v 65 Inu Yehova, chitirani chabwino mtumiki wanu 
\q2 molingana ndi mawu anu. 
\q1  
\v 66 Phunzitseni nzeru ndi chiweruzo chabwino, 
\q2 pakuti ndimakhulupirira malamulo anu. 
\q1  
\v 67 Ndisanayambe kuzunzika ndinasochera, 
\q2 koma tsopano ndimamvera mawu anu. 
\q1  
\v 68 Inu ndinu abwino ndipo zimene mumachita ndi zabwino; 
\q2 phunzitseni malamulo anu. 
\q1  
\v 69 Ngakhale odzikuza andipaka mabodza, 
\q2 ine ndimasunga malangizo anu ndi mtima wanga wonse. 
\q1  
\v 70 Mitima yawo ndi yowuma ndi yosakhudzidwa, 
\q2 koma ine ndimakondwera ndi malamulo anu. 
\q1  
\v 71 Ndi bwino kuti ndinasautsidwa 
\q2 kuti ndithe kuphunzira malamulo anu. 
\q1  
\v 72 Lamulo lochokera mʼkamwa mwanu limandikomera kwambiri 
\q2 kuposa ndalama zambirimbiri za siliva ndi golide. 
\qa Yodi 
\q1  
\v 73 Manja anu anandilenga ndi kundiwumba; 
\q2 patseni nzeru zomvetsa zinthu kuti ndiphunzire malamulo anu. 
\q1  
\v 74 Iwo amene amakuopani akondwere akandiona, 
\q2 chifukwa chiyembekezo changa chili mʼmawu anu. 
\q1  
\v 75 Ine ndikudziwa, Inu Yehova, kuti malamulo anu ndi olungama 
\q2 ndipo mwandizunza chifukwa cha kukhulupirika kwanu. 
\q1  
\v 76 Chikondi chanu chosasinthika chikhale chitonthozo changa, 
\q2 molingana ndi lonjezo lanu kwa mtumiki wanu. 
\q1  
\v 77 Chifundo chanu chindifikire kuti ndikhale ndi moyo, 
\q2 popeza malamulo anu ndiye chikondwerero changa. 
\q1  
\v 78 Odzikuza achititsidwe manyazi chifukwa cha kundilakwira popanda chifukwa; 
\q2 koma ine ndidzalingalira malangizo anu. 
\q1  
\v 79 Iwo amene amakuopani atembenukire kwa ine, 
\q2 iwo amene amamvetsetsa umboni wanu. 
\q1  
\v 80 Mtima wanga ukhale wopanda cholakwa pa chiphunzitso chanu 
\q2 kuti ndisachititsidwe manyazi. 
\qa Kafu 
\q1  
\v 81 Moyo wanga wafowoka ndi kufunafuna chipulumutso chanu, 
\q2 koma chiyembekezo changa chili mʼmawu anu. 
\q1  
\v 82 Maso anga alefuka pofunafuna lonjezo lanu; 
\q2 Ine ndikuti, “Kodi mudzanditonthoza liti?” 
\q1  
\v 83 Ngakhale ndili ngati thumba lachikopa la vinyo pa utsi 
\q2 sindiyiwala zophunzitsa zanu. 
\q1  
\v 84 Kodi mtumiki wanu ayenera kudikira mpaka liti? 
\q2 Kodi mudzawalanga liti amene amandizunza? 
\q1  
\v 85 Anthu osalabadira za Mulungu, 
\q2 odzikuza amandikumbira dzenje motsutsana ndi malamulo anu. 
\q1  
\v 86 Malamulo anu onse ndi odalirika; 
\q2 thandizeni, pakuti anthu akundizunza popanda chifukwa. 
\q1  
\v 87 Iwo anatsala pangʼono kundichotsa pa dziko lapansi 
\q2 koma sindinataye malangizo anu. 
\q1  
\v 88 Sungani moyo wanga molingana ndi chikondi chanu chosasinthika, 
\q2 ndipo ndidzamvera umboni wa pakamwa panu. 
\qa Lamedi 
\q1  
\v 89 Mawu anu Yehova ndi amuyaya; 
\q2 akhazikika kumwambako. 
\q1  
\v 90 Kukhulupirika kwanu kumakhala mpaka ku mibado yonse; 
\q2 Inu munakhazikitsa dziko lapansi ndipo lilipobe. 
\q1  
\v 91 Malamulo anu alipobe mpaka lero lino, 
\q2 pakuti zinthu zonse zimatumikira Inu. 
\q1  
\v 92 Malamulo anu akanapanda kukhala chikondwerero changa, 
\q2 ndikanawonongeka mʼmasautso anga. 
\q1  
\v 93 Ine sindidzayiwala konse malangizo anu, 
\q2 pakuti ndi malangizo anuwo munasunga moyo wanga. 
\q1  
\v 94 Ndine wanu, ndipulumutseni; 
\q2 pakuti ndasamala malangizo anu. 
\q1  
\v 95 Anthu oyipa akudikira kuti andiwononge, 
\q2 koma ndidzalingalira umboni wanu. 
\q1  
\v 96 Ndadziwa kuti zinthu zonse zili ndi malire, 
\q2 koma malamulo anu alibe malire konse. 
\qa Memu 
\q1  
\v 97 Ndithu, ine ndimakonda malamulo anu! 
\q2 Ndimalingaliramo tsiku lonse. 
\q1  
\v 98 Malamulo anu amachititsa kuti ndikhale wanzeru kuposa adani anga, 
\q2 popeza malamulowo ali ndi ine nthawi zonse. 
\q1  
\v 99 Ndimamvetsa zinthu kwambiri kuposa aphunzitsi anga onse 
\q2 popeza ndimalingalira umboni wanu. 
\q1  
\v 100 Ndili ndi nzeru zochuluka zomvetsera zinthu kuposa anthu okalamba, 
\q2 popeza ndimamvera malangizo anu. 
\q1  
\v 101 Ndimaletsa miyendo yanga kuyenda mʼnjira iliyonse yoyipa 
\q2 kuti ndithe kumvera mawu anu. 
\q1  
\v 102 Sindinapatuke kuchoka pa malamulo anu, 
\q2 pakuti Inu mwini munandiphunzitsa. 
\q1  
\v 103 Mawu anu ndi otsekemera ndikawalawa, 
\q2 otsekemera kuposa uchi mʼkamwa mwanga! 
\q1  
\v 104 Ndimapeza nzeru zodziwira zinthu kuchokera mʼmalangizo anu; 
\q2 kotero ndimadana ndi njira iliyonse yoyipa. 
\qa Nuni 
\q1  
\v 105 Mawu anu ndi nyale ya kumapazi kwanga 
\q2 ndi kuwunika kwa pa njira yanga. 
\q1  
\v 106 Ndalumbira ndipo ndatsimikiza, 
\q2 kuti ndidzatsatira malamulo anu olungama. 
\q1  
\v 107 Ndazunzika kwambiri; 
\q2 Inu Yehova, sungani moyo wanga molingana ndi mawu anu. 
\q1  
\v 108 Inu Yehova, landirani matamando aufulu ochokera pakamwa panga, 
\q2 ndipo ndiphunzitseni malamulo anu. 
\q1  
\v 109 Ngakhale moyo wanga umakhala mʼzoopsa nthawi ndi nthawi, 
\q2 sindidzayiwala malamulo anu. 
\q1  
\v 110 Anthu oyipa anditchera msampha, 
\q2 koma sindinasochere kuchoka pa malangizo anu. 
\q1  
\v 111 Umboni wanu ndiye cholowa changa kwamuyaya; 
\q2 Iwo ndiye chimwemwe cha mtima wanga. 
\q1  
\v 112 Mtima wanga wakhazikika pa kusunga zophunzitsa zanu 
\q2 mpaka kumapeto kwenikweni. 
\qa Samekhi 
\q1  
\v 113 Ndimadana ndi anthu apawiripawiri, 
\q2 koma ndimakonda malamulo anu. 
\q1  
\v 114 Inu ndinu pothawirapo panga ndi chishango changa; 
\q2 chiyembekezo changa chili mʼmawu anu. 
\q1  
\v 115 Chokani kwa ine, inu anthu ochita zoyipa, 
\q2 kuti ndisunge malamulo a Mulungu wanga! 
\q1  
\v 116 Mundichirikize molingana ndi lonjezo lanu, ndipo ndidzakhala ndi moyo; 
\q2 musalole kuti chiyembekezo changa chipite pachabe. 
\q1  
\v 117 Gwirizizeni, ndipo ndidzapulumutsidwa; 
\q2 nthawi zonse ndidzasamalira zophunzitsa zanu. 
\q1  
\v 118 Inu mumakana onse amene amasochera kuchoka pa zophunzitsa zanu, 
\q2 pakuti chinyengo chawo ndi chopanda phindu. 
\q1  
\v 119 Anthu onse oyipa a pa dziko lapansi mumawayesa ngati zinthu zakudzala; 
\q2 nʼchifukwa chake ndimakonda umboni wanu. 
\q1  
\v 120 Thupi langa limanjenjemera chifukwa cha kuopa Inu; 
\q2 ndimachita mantha ndi malamulo anu. 
\qa Ayini 
\q1  
\v 121 Ndachita zolungama ndi zabwino; 
\q2 musandisiye mʼmanja mwa ondizunza. 
\q1  
\v 122 Onetsetsani kuti mtumiki wanu akukhala bwino, 
\q2 musalole kuti anthu odzikuza andipondereze. 
\q1  
\v 123 Maso anga alefuka, kufunafuna chipulumutso chanu, 
\q2 kufunafuna lonjezo lanu lolungama. 
\q1  
\v 124 Muchite naye mtumiki wanu molingana ndi chikondi chanu chosasinthika, 
\q2 ndipo mundiphunzitse malamulo anu. 
\q1  
\v 125 Ine ndine mtumiki wanu; patseni mzimu wondizindikiritsa, 
\q2 kuti ndimvetsetse umboni wanu. 
\q1  
\v 126 Yehova, ndi nthawi yoti muchitepo kanthu; 
\q2 malamulo anu akuswedwa. 
\q1  
\v 127 Chifukwa choti ndimakonda malamulo anu 
\q2 kuposa golide, kuposa golide woyengeka bwino, 
\q1  
\v 128 ndiponso chifukwa choti ndimaona kuti malangizo anu onse ndi wowongoka, 
\q2 ndimadana ndi njira iliyonse yoyipa. 
\qa Pe 
\q1  
\v 129 Maumboni anu ndi odabwitsa 
\q2 nʼchifukwa chake ndimawamvera. 
\q1  
\v 130 Mawu anu akamaphunzitsidwa amapereka kuwunika; 
\q2 ngakhale anthu wamba amamvetsetsa. 
\q1  
\v 131 Ndimatsekula pakamwa panga ndi kupuma wefuwefu, 
\q2 kufunafuna malamulo anu. 
\q1  
\v 132 Tembenukirani kwa ine ndipo mundichitire chifundo, 
\q2 monga mumachitira nthawi zonse kwa iwo amene amakonda dzina lanu. 
\q1  
\v 133 Tsogolerani mayendedwe anga molingana ndi mawu anu; 
\q2 musalole kuti tchimo lizindilamulira. 
\q1  
\v 134 Ndiwomboleni mʼdzanja la anthu ondizunza, 
\q2 kuti ndithe kumvera malangizo anu. 
\q1  
\v 135 Nkhope yanu iwalire mtumiki wanu 
\q2 ndipo mundiphunzitse malamulo anu. 
\q1  
\v 136 Mitsinje ya misozi ikuyenda kuchoka mʼmaso mwanga, 
\q2 chifukwa anthu sakumvera malamulo anu. 
\qa Tsade 
\q1  
\v 137 Yehova ndinu wolungama, 
\q2 ndipo malamulo anu ndi abwino. 
\q1  
\v 138 Maumboni amene munatipatsa ndi olungama; 
\q2 ndi odalirika ndithu. 
\q1  
\v 139 Ndikusautsidwa kwambiri mʼkati mwanga 
\q2 chifukwa adani anu amanyalanyaza mawu anu. 
\q1  
\v 140 Mawu anu ndi woyera kwambiri 
\q2 nʼchifukwa chake mtumiki wanune ndimawakonda. 
\q1  
\v 141 Ngakhale ndili wamngʼono ndi wonyozeka, 
\q2 sindiyiwala malangizo anu. 
\q1  
\v 142 Chilungamo chanu nʼchamuyaya, 
\q2 ndipo malamulo anu nʼchoona. 
\q1  
\v 143 Mavuto ndi masautso zandigwera, 
\q2 koma ndimakondwera ndi malamulo anu. 
\q1  
\v 144 Umboni wanu ndi wabwino nthawi zonse; 
\q2 patseni nzeru zomvetsa zinthu kuti ine ndikhale ndi moyo. 
\qa Kofu 
\q1  
\v 145 Ndimayitana ndi mtima wanga wonse; ndiyankheni Inu Yehova, 
\q2 ndipo ndidzamvera zophunzitsa zanu. 
\q1  
\v 146 Ndikuyitana kwa Inu; pulumutseni 
\q2 ndipo ndidzasunga umboni wanu. 
\q1  
\v 147 Ndimadzuka tambala asanalire kuti ndipemphe thandizo; 
\q2 chiyembekezo changa chili mʼmawu anu. 
\q1  
\v 148 Maso anga amakhala chipenyere nthawi yonse ya usiku, 
\q2 kuti ndithe kulingalira malonjezo anu. 
\q1  
\v 149 Imvani mawu anga molingana ndi chikondi chanu chosasinthika; 
\q2 Yehova sungani moyo wanga, molingana ndi malamulo anu. 
\q1  
\v 150 Iwo amene amakonza njira zoyipa andiyandikira, 
\q2 koma ali kutali ndi malamulo anu. 
\q1  
\v 151 Koma Inu Yehova muli pafupi, 
\q2 malamulo anu onse ndi woona. 
\q1  
\v 152 Ndinaphunzira kalekale kuchokera mʼmaumboni anu 
\q2 kuti maumboni amene munakhazikitsawo ndi amuyaya. 
\qa Reshi 
\q1  
\v 153 Yangʼanani masautso anga ndipo mundipulumutse, 
\q2 pakuti sindinayiwale malamulo anu. 
\q1  
\v 154 Mundiyimirire pa mlandu wanga ndi kundiwombola; 
\q2 sungani moyo wanga molingana ndi lonjezo lanu. 
\q1  
\v 155 Chipulumutso chili kutali ndi anthu oyipa, 
\q2 pakuti iwowo safunafuna zophunzitsa zanu. 
\q1  
\v 156 Chifundo chanu Yehova nʼchachikulu; 
\q2 sungani moyo wanga molingana ndi malamulo anu. 
\q1  
\v 157 Adani amene akundizunza ndi ambiri, 
\q2 koma ine sindinatembenuke kuchoka pa umboni wanu. 
\q1  
\v 158 Ndimawayangʼana monyansidwa anthu opanda chikhulupiriro, 
\q2 popeza samvera mawu anu. 
\q1  
\v 159 Onani momwe ndimakondera malangizo anu; 
\q2 sungani moyo wanga, Inu Yehova, molingana ndi chikondi chanu chosanthika. 
\q1  
\v 160 Mawu anu onse ndi owona; 
\q2 malamulo anu onse olungama ndi amuyaya. 
\qa Sini ndi Shini 
\q1  
\v 161 Olamulira amandizunza popanda chifukwa, 
\q2 koma mtima wanga umanjenjemera ndi mawu anu. 
\q1  
\v 162 Ine ndimakondwa ndi lonjezo lanu, 
\q2 ngati munthu amene wapeza chuma chambiri. 
\q1  
\v 163 Ndimadana ndi chinyengo, kwambiri ndimanyansidwa nacho, 
\q2 koma ndimakonda malamulo anu. 
\q1  
\v 164 Ndimakutamandani kasanu ndi kawiri pa tsiku 
\q2 pakuti malamulo anu ndi olungama. 
\q1  
\v 165 Amene amakonda malamulo anu ali ndi mtendere waukulu, 
\q2 ndipo palibe chimene chingawapunthwitse 
\q1  
\v 166 Ndikudikira chipulumutso chanu, Inu Yehova, 
\q2 ndipo ndimatsatira malamulo anu. 
\q1  
\v 167 Ndimamvera umboni wanu 
\q2 pakuti ndimawukonda kwambiri. 
\q1  
\v 168 Ndimamvera malangizo anu ndi umboni wanu, 
\q2 pakuti njira zanga zonse ndi zodziwika pamaso panu. 
\qa Tawu 
\q1  
\v 169 Kulira kwanga kufike pamaso panu Yehova; 
\q2 patseni nzeru zomvetsa zinthu molingana ndi mawu anu. 
\q1  
\v 170 Kupempha kwanga kufike pamaso panu; 
\q2 pulumutseni molingana ndi lonjezo lanu. 
\q1  
\v 171 Matamando asefukire pa milomo yanga, 
\q2 pakuti Inu mumandiphunzitsa malamulo anu. 
\q1  
\v 172 Lilime langa liyimbe mawu anu, 
\q2 popeza malamulo anu onse ndi olungama. 
\q1  
\v 173 Dzanja lanu likhale lokonzeka kundithandiza 
\q2 pakuti ndasankha malangizo anu. 
\q1  
\v 174 Ndikufunitsitsa chipulumutso chanu Yehova, 
\q2 ndipo ndimakondwera ndi malamulo anu. 
\q1  
\v 175 Loleni kuti ndikhale ndi moyo kuti ndikutamandeni, 
\q2 ndipo malamulo anu andichirikize. 
\q1  
\v 176 Ndasochera ngati nkhosa yotayika, 
\q2 funafunani mtumiki wanu, 
\q2 pakuti sindinayiwale malamulo anu. 
\c 120  
\cl Salimo 120 
\d Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 Ndimafuwulira kwa Yehova mʼmasautso anga, 
\q2 ndipo Iye amandiyankha. 
\q1  
\v 2 Pulumutseni Yehova ku milomo yabodza, 
\q2 ndi kwa anthu achinyengo. 
\b  
\q1  
\v 3 Kodi adzakuchitani chiyani, 
\q2 ndipo adzawonjezerapo zotani, inu anthu achinyengo? 
\q1  
\v 4 Adzakulangani ndi mivi yakuthwa ya munthu wankhondo, 
\q2 ndi makala oyaka a mtengo wa tsanya. 
\b  
\q1  
\v 5 Tsoka ine kuti ndimakhala ku Mesaki, 
\q2 kuti ndimakhala pakati pa matenti a ku Kedara! 
\q1  
\v 6 Kwa nthawi yayitali ndakhala pakati 
\q2 pa iwo amene amadana ndi mtendere. 
\q1  
\v 7 Ine ndine munthu wamtendere; 
\q2 koma ndikamayankhula, iwo amafuna nkhondo. 
\c 121  
\cl Salimo 121 
\d Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 Ndikweza maso anga ku mapiri; 
\q2 kodi thandizo langa limachokera kuti? 
\q1  
\v 2 Thandizo langa limachokera kwa Yehova, 
\q2 wolenga kumwamba ndi dziko lapansi. 
\b  
\q1  
\v 3 Sadzalola kuti phazi lako literereke; 
\q2 Iye amene amakusunga sadzawodzera. 
\q1  
\v 4 Taonani, Iye amene amasunga Israeli 
\q2 sadzawodzera kapena kugona. 
\b  
\q1  
\v 5 Yehova ndiye amene amakusunga; 
\q2 Yehova ndiye mthunzi wako ku dzanja lako lamanja. 
\q1  
\v 6 Dzuwa silidzakupweteka nthawi ya masana, 
\q2 kapena mwezi nthawi ya usiku. 
\b  
\q1  
\v 7 Yehova adzakuteteza ku zoyipa zonse; 
\q2 adzasunga moyo wako. 
\q1  
\v 8 Yehova adzayangʼanira kutuluka kwako ndi kulowa kwako; 
\q2 kuyambira tsopano mpaka muyaya. 
\c 122  
\cl Salimo 122 
\d Salimo la Davide. Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 Ndinakondwera atandiwuza kuti, 
\q2 “Tiyeni ku nyumba ya Yehova.” 
\q1  
\v 2 Mapazi athu akuyima mʼzipata 
\q2 zako, Iwe Yerusalemu. 
\b  
\q1  
\v 3 Yerusalemu anamangidwa ngati mzinda 
\q2 umene uli wothithikana pamodzi. 
\q1  
\v 4 Kumeneko ndiye kumene kumapita mafuko, 
\q2 mafuko a Yehova, 
\q1 umboni wa kwa Israeli, 
\q2 kuti atamande dzina la Yehova. 
\q1  
\v 5 Kumeneko anayikako mipando yaufumu yachiweruzo, 
\q2 mipando yaufumu ya nyumba ya Davide. 
\b  
\q1  
\v 6 Pemphererani mtendere wa Yerusalemu: 
\q2 “Iwo amene amakukonda iwe zinthu ziwayendere bwino. 
\q1  
\v 7 Mukhale mtendere mʼkati mwa makoma ako, 
\q2 ndipo mʼnyumba zako zaufumu mukhale chitetezo.” 
\q1  
\v 8 Chifukwa cha abale anga ndi abwenzi anga 
\q2 ndidzati, “Mtendere ukhale mʼkati mwako.” 
\q1  
\v 9 Chifukwa cha Nyumba ya Yehova Mulungu wathu, 
\q2 ndidzakufunira zabwino. 
\c 123  
\cl Salimo 123 
\d Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 Ndikweza maso anga kwa Inu, 
\q2 kwa Inu amene mumakhala kumwamba. 
\q1  
\v 2 Taonani, monga momwe maso a akapolo amayangʼana mʼdzanja la mbuye wawo, 
\q2 monga momwenso maso a mdzakazi amayangʼana mʼdzanja la dona wake, 
\q1 choncho maso athu ali kwa Yehova Mulungu wathu, 
\q2 mpaka atichitire chifundo. 
\b  
\q1  
\v 3 Mutichitire chifundo, Inu Yehova mutichitire chifundo, 
\q2 pakuti tapirira chitonzo chachikulu. 
\q1  
\v 4 Ife tapirira mnyozo wambiri kuchokera kwa anthu odzikuza, 
\q2 chitonzo chachikulu kuchokera kwa anthu onyada. 
\c 124  
\cl Salimo 124 
\d Salimo la Davide. Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 Akanapanda kukhala mbali yathu Yehova, 
\q2 anene tsono Israeli, 
\q1  
\v 2 akanapanda kukhala mbali yathu Yehova, 
\q2 potiwukira anthuwo, 
\q1  
\v 3 iwo atatipsera mtima, 
\q2 akanatimeza amoyo; 
\q1  
\v 4 chigumula chikanatimiza, 
\q2 mtsinje ukanatikokolola, 
\q1  
\v 5 madzi a mkokomo 
\q2 akanatikokolola. 
\b  
\q1  
\v 6 Atamandike Yehova, 
\q2 amene sanalole kuti tikhale chakudya cha mano awo. 
\q1  
\v 7 Moyo wathu wawonjoka ngati mbalame 
\q2 yokodwa mu msampha wa mlenje; 
\q1 msampha wathyoka, 
\q2 ndipo ife tapulumuka. 
\q1  
\v 8 Thandizo lathu lili mʼdzina la Yehova 
\q2 wolenga kumwamba ndi dziko lapansi. 
\c 125  
\cl Salimo 125 
\d Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 Amene amadalira Yehova ali ngati phiri la Ziyoni, 
\q2 limene silingagwedezeke koma ndi lokhala mpaka muyaya. 
\q1  
\v 2 Monga mapiri azungulira Yerusalemu, 
\q2 momwemonso Yehova azungulira anthu ake 
\q2 kuyambira tsopano mpaka muyaya. 
\b  
\q1  
\v 3 Ndodo yaufumu ya anthu oyipa sidzakhala 
\q2 pa dziko limene lapatsidwa kwa anthu olungama, 
\q1 kuti anthu olungamawo 
\q2 angachite nawonso zoyipa. 
\b  
\q1  
\v 4 Yehova chitirani zabwino amene ndi abwino, 
\q2 amene ndi olungama mtima 
\q1  
\v 5 Koma amene amatembenukira ku njira zokhotakhota, 
\q2 Yehova adzawachotsa pamodzi ndi anthu ochita zoyipa. 
\b  
\q1 Mtendere ukhale pa Israeli. 
\c 126  
\cl Salimo 126 
\d Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 Yehova atabwezera akapolo ku Ziyoni, 
\q2 tinali ngati amene akulota. 
\q1  
\v 2 Pakamwa pathu panadzaza ndi kuseka; 
\q2 malilime athu ndi nyimbo zachimwemwe. 
\q1 Pamenepo kunanenedwa pakati pa anthu kuti, 
\q2 “Yehova wawachitira zinthu zazikulu.” 
\q1  
\v 3 Yehova watichitira zinthu zazikulu, 
\q2 ndipo tadzazidwa ndi chimwemwe. 
\b  
\q1  
\v 4 Tibwezereni madalitso athu, Inu Yehova, 
\q2 monga mitsinje ya ku Negevi. 
\q1  
\v 5 Iwo amene amafesa akulira, 
\q2 adzakolola akuyimba nyimbo zachimwemwe. 
\q1  
\v 6 Iye amene amayendayenda nalira, 
\q2 atanyamula mbewu yokafesa, 
\q1 adzabwerera akuyimba nyimbo zachimwemwe, 
\q2 atanyamula mitolo yake. 
\c 127  
\cl Salimo 127 
\d Nyimbo yoyimba pokwera ku Yerusalemu. Salimo la Solomoni. 
\q1  
\v 1 Yehova akapanda kumanga nyumba, 
\q2 omanga nyumbayo agwira ntchito pachabe. 
\q1 Yehova akapanda kulondera mzinda, 
\q2 mlonda akanangolondera pachabe. 
\q1  
\v 2 Mumangodzivuta nʼkulawirira mmamawa 
\q2 ndi kusagona msanga madzulo, 
\q1 kuvutikira chakudya choti mudye, 
\q2 pakuti Iye amapereka tulo kwa amene amawakonda. 
\b  
\q1  
\v 3 Ana ndiye cholowa chochokera kwa Yehova, 
\q2 ana ndi mphotho yochokera kwa Iye. 
\q1  
\v 4 Ana a pa unyamata ali ngati mivi mʼmanja 
\q2 mwa munthu wankhondo. 
\q1  
\v 5 Wodala munthu 
\q2 amene motengera mivi mwake mwadzaza. 
\q1 Iwo sadzachititsidwa manyazi 
\q2 pamene alimbana ndi adani awo pa zipata. 
\c 128  
\cl Salimo 128 
\d Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 Odala ndi onse amene amaopa Yehova, 
\q2 amene amayenda mʼnjira zake. 
\q1  
\v 2 Udzadya chipatso cha ntchito yako; 
\q2 madalitso ndi chuma zidzakhala zako. 
\q1  
\v 3 Mkazi wako adzakhala ngati mpesa wobereka 
\q2 mʼkati mwa nyumba yako; 
\q1 ana ako adzakhala ngati mphukira za mitengo ya olivi 
\q2 kuzungulira tebulo lako. 
\q1  
\v 4 Ameneyu ndiye munthu wodalitsidwa 
\q2 amene amaopa Yehova. 
\b  
\q1  
\v 5 Yehova akudalitse kuchokera mʼZiyoni 
\q2 masiku onse a moyo wako; 
\q1 uwone zokoma za Yerusalemu, 
\q2  
\v 6 ndipo ukhale ndi moyo kuti udzaone zidzukulu zako. 
\b  
\q1 Mtendere ukhale ndi Israeli. 
\c 129  
\cl Salimo 129 
\d Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 “Andizunza kwambiri kuyambira ubwana wanga,” 
\q2 anene tsono Israeli; 
\q1  
\v 2 “Andizunza kwambiri kuyambira ubwana wanga, 
\q2 koma sanandipambane. 
\q1  
\v 3 Anthu otipula analima pa msana panga 
\q2 ndipo anapangapo mizere yayitali: 
\q1  
\v 4 Koma Yehova ndi wolungama; 
\q2 Iye wandimasula ku zingwe za anthu oyipa.” 
\b  
\q1  
\v 5 Onse amene amadana ndi Ziyoni 
\q2 abwezedwe pambuyo mwamanyazi. 
\q1  
\v 6 Akhale ngati udzu womera pa denga la nyumba, 
\q2 umene umafota usanakule; 
\q1  
\v 7 sungadzaze manja a owumweta 
\q2 kapena manja a omanga mitolo. 
\q1  
\v 8 Odutsa pafupi asanene kuti, 
\q2 “Dalitso la Yehova lili pa inu; 
\q2 tikukudalitsani mʼdzina la Yehova.” 
\c 130  
\cl Salimo 130 
\d Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 Ndikulirira kwa Inu Yehova ndili mʼdzenje lozama; 
\q2  
\v 2 Ambuye imvani mawu anga. 
\q1 Makutu anu akhale tcheru kumva 
\q2 kupempha chifundo kwanga. 
\b  
\q1  
\v 3 Inu Yehova, mukanamawerengera machimo, 
\q2 Inu Yehova, akanayima chilili ndani wopanda mlandu? 
\q1  
\v 4 Koma kwa Inu kuli chikhululukiro; 
\q2 nʼchifukwa chake mumaopedwa. 
\b  
\q1  
\v 5 Ndimayembekezera Yehova, moyo wanga umayembekezera, 
\q2 ndipo ndimakhulupirira mawu ake. 
\q1  
\v 6 Moyo wanga umayembekezera Ambuye, 
\q2 kupambana momwe alonda amayembekezera mmawa, 
\q2 inde, kupambana momwe alonda amayembekezera mmawa, 
\b  
\q1  
\v 7 Yembekeza Yehova, iwe Israeli, 
\q2 pakuti Yehova ali ndi chikondi chosasinthika 
\q2 ndipo alinso ndi chipulumutso chochuluka. 
\q1  
\v 8 Iye mwini adzawombola Israeli 
\q2 ku machimo ake onse. 
\c 131  
\cl Salimo 131 
\d Nyimbo yoyimba pokwera ku Yerusalemu. Salimo la Davide. 
\q1  
\v 1 Inu Yehova, mtima wanga siwodzikuza, 
\q2 maso anga siwonyada; 
\q1 sinditengeteka mtima 
\q2 ndi zinthu zapamwamba ndi zodabwitsa. 
\q1  
\v 2 Koma moyo wanga ndawutontholetsa 
\q2 ndi kuwukhalitsa chete ngati mwana amene amayi ake amuletsa kuyamwa, 
\q2 moyo wanga mʼkati mwanga uli ngati mwana amene amuletsa kuyamwa. 
\b  
\q1  
\v 3 Yembekeza Yehova, iwe Israeli, 
\q2 kuyambira tsopano mpaka muyaya. 
\c 132  
\cl Salimo 132 
\d Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 Inu Yehova, kumbukirani Davide 
\q2 ndi mavuto onse anapirira. 
\b  
\q1  
\v 2 Iye analumbira kwa Yehova 
\q2 ndi kulonjeza kwa Wamphamvu wa Yakobo kuti, 
\q1  
\v 3 “Sindidzalowa mʼnyumba mwanga 
\q2 kapena kugona pa bedi langa: 
\q1  
\v 4 sindidzalola kuti maso anga agone, 
\q2 kapena zikope zanga ziwodzere, 
\q1  
\v 5 mpaka nditamupezera malo Yehova, 
\q2 malo okhala a Wamphamvu wa Yakobo.” 
\b  
\q1  
\v 6 Zoonadi, tinamva za Bokosi la Chipangano ku Efurata, 
\q2 tinalipeza mʼminda ya ku Yaara: 
\q1  
\v 7 “Tiyeni tipite ku malo ake okhalamo; 
\q2 tiyeni tikamulambire pa mapazi ake. 
\q1  
\v 8 ‘Dzukani Yehova, ndipo bwerani ku malo anu opumulira, 
\q2 Inuyo ndi Bokosi la Chipangano limene limafanizira mphamvu zanu. 
\q1  
\v 9 Ansembe anu avekedwe chilungamo; 
\q2 anthu anu oyera mtima ayimbe nyimbo mwachimwemwe.’ ” 
\b  
\q1  
\v 10 Chifukwa cha Davide mtumiki wanu, 
\q2 musakane wodzozedwa wanu. 
\b  
\q1  
\v 11 Yehova analumbira kwa Davide, 
\q2 lumbiro lotsimikizika kuti Iye sadzasintha: 
\q1 “Mmodzi wa ana ako 
\q2 ndidzamuyika pa mpando waufumu; 
\q1  
\v 12 ngati ana ako azisunga pangano langa 
\q2 ndi malamulo amene ndiwaphunzitsa, 
\q1 pamenepo ana awo adzakhala pa mpando 
\q2 wako waufumu kwamuyaya ndi muyaya.” 
\b  
\q1  
\v 13 Pakuti Yehova wasankha Ziyoni, 
\q2 Iye wakhumba kuti akhale malo ake okhalamo: 
\q1  
\v 14 “Awa ndi malo anga opumapo ku nthawi za nthawi; 
\q2 ndidzakhala pano pa mpando waufumu, pakuti ndakhumba zimenezi. 
\q1  
\v 15 Ndidzadalitsa mzindawu ndi zinthu zambiri; 
\q2 anthu ake osauka ndidzawakhutitsa ndi chakudya. 
\q1  
\v 16 Ndidzaveka ansembe ake chipulumutso, 
\q2 ndipo anthu ake oyera mtima adzayimba nthawi zonse nyimbo zachimwemwe. 
\b  
\q1  
\v 17 “Pano ndidzachulukitsa mphamvu za Davide 
\q2 ndi kuyikapo nyale ya wodzozedwa wanga. 
\q1  
\v 18 Ndidzaveka adani ake manyazi, 
\q2 koma chipewa chaufumu pamutu pake chidzakhala chowala.” 
\c 133  
\cl Salimo 133 
\d Salimo la Davide. Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 Onani, nʼkokoma ndi kokondweretsa ndithu 
\q2 pamene abale akhala pamodzi mwachiyanjano! 
\q1  
\v 2 Zili ngati mafuta amtengowapatali othiridwa pa mutu, 
\q2 otsikira ku ndevu, 
\q1 ku ndevu za Aaroni, 
\q2 oyenderera mpaka mʼkhosi mwa mkanjo wake. 
\q1  
\v 3 Zili ngati mame a ku Heremoni 
\q2 otsikira pa Phiri la Ziyoni. 
\q1 Pakuti pamenepo Yehova amaperekapo dalitso, 
\q2 ndiwo moyo wamuyaya. 
\c 134  
\cl Salimo 134 
\d Nyimbo yoyimba pokwera ku Yerusalemu. 
\q1  
\v 1 Bwerani, mutamande Yehova, inu atumiki onse a Yehova, 
\q2 amene mumatumikira usiku mʼnyumba ya Yehova. 
\q1  
\v 2 Kwezani manja anu mʼmalo opatulika 
\q2 ndipo mutamande Yehova. 
\b  
\q1  
\v 3 Yehova wolenga kumwamba ndi dziko lapansi, 
\q2 akudalitseni kuchokera mʼZiyoni. 
\c 135  
\cl Salimo 135 
\q1  
\v 1 Tamandani Yehova. 
\b  
\q1 Tamandani dzina la Yehova; 
\q2 mutamandeni, inu atumiki a Yehova, 
\q1  
\v 2 amene mumatumikira mʼnyumba ya Yehova, 
\q2 mʼmabwalo a nyumba ya Mulungu wathu. 
\b  
\q1  
\v 3 Tamandani Yehova, pakuti Yehova ndi wabwino; 
\q2 imbani nyimbo zotamanda dzina lake, pakuti nʼkokoma kutero, 
\q1  
\v 4 Pakuti Yehova wasankha Yakobo kuti akhale wake, 
\q2 Israeli kuti akhale chuma chake chapamtima. 
\b  
\q1  
\v 5 Ndikudziwa kuti Yehova ndi wamkulu, 
\q2 kuti Ambuye athu ndi wamkulu kuposa milungu yonse. 
\q1  
\v 6 Yehova amachita chilichonse chimene chimamukomera, 
\q2 kumwamba ndi dziko lapansi, 
\q2 ku nyanja zazikulu ndi ku malo ake onse akuya. 
\q1  
\v 7 Iye amatulutsa mitambo kuchokera ku malekezero a dziko lapansi, 
\q2 amatumiza zingʼaningʼani pamodzi ndi mvula 
\q2 ndipo amatulutsa mphepo ku malo ake osungiramo. 
\b  
\q1  
\v 8 Anakantha ana oyamba kubadwa a Igupto, 
\q2 ana oyamba kubadwa a anthu ndi nyama. 
\q1  
\v 9 Iye anatumiza zizindikiro zozizwitsa ndi zodabwitsa pakati pako, iwe Igupto, 
\q2 kutsutsana ndi Farao pamodzi ndi atumiki ake onse. 
\q1  
\v 10 Iye anakantha mitundu yambiri ya anthu 
\q2 ndi kupha mafumu amphamvu: 
\q1  
\v 11 Sihoni mfumu ya Aamori, 
\q2 Ogi mfumu ya Basani, 
\q2 ndi maufumu onse a ku Kanaani; 
\q1  
\v 12 ndipo anapereka dziko lawo ngati cholowa, 
\q2 cholowa cha anthu ake Aisraeli. 
\b  
\q1  
\v 13 Dzina lanu, Inu Yehova, ndi losatha mpaka muyaya, 
\q2 mbiri yanu, Inu Yehova, idziwika mibado yonse. 
\q1  
\v 14 Pakuti Yehova adzaonetsa kuti anthu ake ngosalakwa, 
\q2 ndipo adzachitira chifundo atumiki ake. 
\b  
\q1  
\v 15 Mafano a mitundu ya anthu ndi siliva ndi golide, 
\q2 opangidwa ndi manja a anthu. 
\q1  
\v 16 Pakamwa ali napo koma sayankhula 
\q2 maso ali nawo, koma sapenya; 
\q1  
\v 17 makutu ali nawo, koma sakumva 
\q2 ndipo mʼkamwa mwawo mulibe mpweya uliwonse. 
\q1  
\v 18 Iwo amene amapanga mafanowo adzakhala ngati mafanowo, 
\q2 chimodzimodzinso iwo amene amadalira mafanowo. 
\b  
\q1  
\v 19 Inu nyumba ya Israeli, tamandani Yehova; 
\q2 inu nyumba ya Aaroni, tamandani Yehova; 
\q1  
\v 20 Inu nyumba ya Levi, tamandani Yehova; 
\q2 Inu amene mumaopa Iye, tamandani Yehova. 
\q1  
\v 21 Wodalitsika ndi Yehova kuchokera mʼZiyoni, 
\q2 amene amakhala mu Yerusalemu. 
\b  
\q1 Tamandani Yehova. 
\c 136  
\cl Salimo 136 
\q1  
\v 1 Yamikani Yehova chifukwa ndi wabwino. 
\qr Pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 2 Yamikani Mulungu wa milungu. 
\qr Pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 3 Yamikani Ambuye wa ambuye, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\b  
\q1  
\v 4 Iye yekhayo amene amachita zodabwitsa zazikulu, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 5 Amene mwachidziwitso chake anapanga mayiko akumwamba, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 6 Amene anayala dziko lapansi pamwamba pa madzi, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 7 Amene anapanga miyuni ikuluikulu, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 8 Dzuwa lilamulire usana, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 9 Mwezi ndi nyenyezi zilamulire usiku, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\b  
\q1  
\v 10 Amene anakantha ana woyamba kubadwa a Igupto, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 11 Natulutsa Israeli pakati pawo, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 12 Ndi dzanja lamphamvu ndi mkono wotambasuka, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\b  
\q1  
\v 13 Amene anagawa Nyanja Yofiira pakati, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 14 Nadutsitsa Israeli pakati pa nyanjayo, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 15 Koma anakokolola Farao ndi ankhondo ake mʼNyanja Yofiira, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\b  
\q1  
\v 16 Amene anatsogolera anthu ake mʼchipululu 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 17 Amene anakantha mafumu akuluakulu, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 18 Napha mafumu amphamvu, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 19 Siloni mfumu ya Aamori, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 20 Ogi mfumu ya Basani, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 21 Napereka dziko lawo ngati cholowa, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 22 Cholowa cha mtumiki wake Israeli; 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\b  
\q1  
\v 23 Amene anatikumbukira ife anthu opeputsidwa, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 24 Amene anatimasula kwa adani athu, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\q1  
\v 25 Amene amapereka chakudya kwa cholengedwa chilichonse, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\b  
\q1  
\v 26 Yamikani Mulungu wakumwamba, 
\qr pakuti chikondi chake chosasinthika nʼchamuyaya. 
\c 137  
\cl Salimo 137 
\q1  
\v 1 Mʼmbali mwa mitsinje ya ku Babuloni tinakhala pansi ndi kulira 
\q2 pamene tinakumbukira Ziyoni. 
\q1  
\v 2 Kumeneko, pa mitengo ya misondozi 
\q2 tinapachika apangwe athu, 
\q1  
\v 3 pakuti anthu otigwira ukapolo anatipempha kuti tiyimbe nyimbo. 
\q2 Otizunza athu anafuna nyimbo zachisangalalo; 
\q2 iwo anati, “Tiyimbireni imodzi mwa nyimbo za ku Ziyoni!” 
\b  
\q1  
\v 4 Tingayimbe bwanji nyimbo za Yehova 
\q2 mʼdziko lachilendo? 
\q1  
\v 5 Ndikakuyiwala iwe Yerusalemu, 
\q2 dzanja langa lamanja liyiwale luso lake. 
\q1  
\v 6 Lilime langa limamatire ku nkhama za mʼkamwa mwanga 
\q2 ndikapanda kukukumbukira iwe Yerusalemu, 
\q1 ngati sindiyesa iwe 
\q2 chimwemwe changa chachikulu. 
\b  
\q1  
\v 7 Kumbukirani, Inu Yehova, zimene Aedomu anachita 
\q2 pa tsiku limene Yerusalemu anagonja. 
\q1 Iwowo anafuwula kuti, “Mugwetseni pansi, mugwetseni pansi 
\q2 mpaka pa maziko ake!” 
\b  
\q1  
\v 8 Iwe mwana wa mkazi wa Babuloni, woyenera kuwonongedwa, 
\q2 wodalitsika ndi yemwe adzakubwezera 
\q2 pa zimene watichitira. 
\q1  
\v 9 Amene adzagwira makanda ako 
\q2 ndi kuwakankhanthitsa pa miyala. 
\c 138  
\cl Salimo 138 
\d Salimo la Davide. 
\q1  
\v 1 Ndidzakuyamikani Yehova ndi mtima wanga wonse; 
\q2 ndidzayimba nyimbo zokutamandani pamaso pa “milungu.” 
\q1  
\v 2 Ndidzagwada kuyangʼana ku Nyumba yanu yoyera 
\q2 ndipo ndidzayamika dzina lanu 
\q2 chifukwa cha chikondi chanu ndi kukhulupirika kwanu, 
\q1 pakuti Inu mwakuza dzina lanu ndi mawu anu 
\q2 kupambana zinthu zonse. 
\q1  
\v 3 Pamene ndinayitana, munandiyankha; 
\q2 munandisandutsa wamphamvu ndi wolimba mtima. 
\b  
\q1  
\v 4 Mafumu onse a dziko lapansi akuyamikeni Yehova, 
\q2 pamene amva mawu a pakamwa panu. 
\q1  
\v 5 Iwo ayimbe za njira za Yehova, 
\q2 pakuti ulemerero wa Yehova ndi waukulu. 
\b  
\q1  
\v 6 Ngakhale kuti Yehova ngokwezeka, amasamalira odzichepetsa, 
\q2 koma anthu onyada amawadziwira chapatali. 
\q1  
\v 7 Ngakhale ndiyende pakati pa masautso, 
\q2 mumasunga moyo wanga; 
\q1 mumatambasula dzanja lanu kutsutsana ndi mkwiyo wa adani anga, 
\q2 mumandipulumutsa ndi dzanja lanu lamanja. 
\q1  
\v 8 Yehova adzakwaniritsa cholinga chake pa ine; 
\q2 chikondi chanu chosasinthika Yehova, ndi chosatha 
\q2 musasiye ntchito ya manja anu. 
\c 139  
\cl Salimo 139 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Inu Yehova, mwandisanthula 
\q2 ndipo mukundidziwa. 
\q1  
\v 2 Inu mumadziwa pamene ndikhala pansi ndi pamene ndidzuka; 
\q2 mumazindikira maganizo anga muli kutali. 
\q1  
\v 3 Mumapenyetsetsa pamene ndikutuluka ndi kugona kwanga; 
\q2 mumadziwa njira zanga zonse. 
\q1  
\v 4 Mawu asanatuluke pa lilime langa 
\q2 mumawadziwa bwinobwino, Inu Yehova. 
\b  
\q1  
\v 5 Mumandizinga kumbuyo ndi kutsogolo komwe; 
\q2 mwasanjika dzanja lanu pa ine. 
\q1  
\v 6 Nzeru zimenezi ndi zopitirira nzeru zanga, 
\q2 ndi zapamwamba kuti ine ndizipeze. 
\b  
\q1  
\v 7 Kodi ndingapite kuti kufuna kuzemba Mzimu wanu? 
\q2 Kodi ndingathawire kuti kuchoka pamaso panu? 
\q1  
\v 8 Ndikakwera kumwamba, Inu muli komweko; 
\q2 ndikakagona ku malo a anthu akufa, Inu muli komweko. 
\q1  
\v 9 Ngati ndiwulukira kotulukira dzuwa, 
\q2 ngati ndikakhala ku malekezero a nyanja, 
\q1  
\v 10 kumenekonso dzanja lanu lidzanditsogolera, 
\q2 dzanja lanu lamanja lidzandigwiriziza. 
\b  
\q1  
\v 11 Ndikanena kuti, “Zoonadi, mdima udzandibisa ndithu 
\q2 ndipo kuwunika kukhale mdima mondizungulira,” 
\q1  
\v 12 komabe mdimawo sudzakhala mdima kwa Inu; 
\q2 usiku udzawala ngati masana, 
\q2 pakuti mdima uli ngati kuwunika kwa Inu. 
\b  
\q1  
\v 13 Pakuti Inu munalenga za mʼkati mwanga; 
\q2 munandiwumba pamodzi mʼmimba mwa amayi anga. 
\q1  
\v 14 Ndimakuyamikani chifukwa ndinapangidwa mochititsa mantha ndi modabwitsa; 
\q2 ntchito zanu ndi zodabwitsa, 
\q2 zimenezi ndimazidziwa bwino lomwe. 
\q1  
\v 15 Mapangidwe anga sanabisike pamaso panu 
\q2 pamene ndimapangidwa mʼmalo achinsinsi, 
\q1 pamene ndinkawumbidwa mwaluso mʼmimba ya amayi anga. 
\q1  
\v 16 Maso anu anaona thupi langa lisanawumbidwe. 
\q2 Masiku onse amene anapatsidwa kwa ine, analembedwa mʼbuku lanu 
\q2 asanayambe nʼkuwerengedwa komwe. 
\b  
\q1  
\v 17 Zolingalira zanu pa ine ndi zamtengowapatali, Inu Mulungu, 
\q2 ndi zosawerengeka ndithu! 
\q1  
\v 18 Ndikanaziwerenga, 
\q2 zikanakhala zochuluka kuposa mchenga; 
\q2 pamene ndadzuka, ndili nanube. 
\b  
\q1  
\v 19 Ndi bwino mukanangopha anthu oyipa, Inu Mulungu! 
\q2 Chokereni inu anthu owononga anzanu! 
\q1  
\v 20 Amayankhula za Inu ndi zolinga zoyipa; 
\q2 adani anu amagwiritsa ntchito dzina lanu molakwika. 
\q1  
\v 21 Kodi ine sindidana nawo amene amakudani, Inu Yehova? 
\q2 Kodi sindinyansidwa nawo amene amakuwukirani? 
\q1  
\v 22 Ndimadana nawo kwathunthu; 
\q2 ndi adani anga. 
\b  
\q1  
\v 23 Santhuleni, Inu Mulungu ndipo mudziwe mtima wanga; 
\q2 Yeseni ndipo mudziwe zolingalira zanga. 
\q1  
\v 24 Onani ngati muli mayendedwe aliwonse oyipa mwa ine, 
\q2 ndipo munditsogolere mʼnjira yanu yamuyaya. 
\c 140  
\cl Salimo 140 
\d Kwa mtsogoleri wa mayimbidwe. Salimo la Davide. 
\q1  
\v 1 Landitseni Yehova kwa anthu oyipa; 
\q2 tetezeni kwa anthu ankhanza, 
\q1  
\v 2 amene mu mtima mwawo amakonza zinthu zoyipa 
\q2 ndi kuyambitsa nkhondo tsiku lililonse. 
\q1  
\v 3 Iwo amanola malilime awo kukhala akuthwa ngati a njoka; 
\q2 pa milomo yawo pali ululu wa mamba. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 4 Tetezeni Inu Yehova, kwa anthu oyipa; 
\q2 tchinjirizeni kwa anthu ankhanza 
\q2 amene amakonza zokola mapazi anga. 
\q1  
\v 5 Anthu odzikuza anditchera msampha mobisika; 
\q2 iwo atchera zingwe za maukonde awo 
\q2 ndipo anditchera misampha pa njira yanga. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 6 Inu Yehova, ine ndikuti, “Ndinu Mulungu wanga.” 
\q2 Imvani kupempha kwanga Yehova. 
\q1  
\v 7 Inu Ambuye Wamphamvuzonse, Mpulumutsi wanga wamphamvu, 
\q2 mumateteza mutu wanga tsiku lankhondo. 
\q1  
\v 8 Musawapatse anthu oyipa zokhumba zawo, Inu Yehova; 
\q2 musalole kuti zokonza zawo zitheke, 
\q2 mwina iwo adzayamba kunyada. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 9 Mitu ya amene andizungulira 
\q2 iphimbidwe ndi masautso amene milomo yawo yayambitsa. 
\q1  
\v 10 Makala amoto agwere pa iwo; 
\q2 aponyedwe pa moto, 
\q2 mʼmaenje amatope, asatulukemonso. 
\q1  
\v 11 Musalole kuti anthu achipongwe akhazikike mʼdziko; 
\q2 choyipa chilondole anthu ankhanza. 
\b  
\q1  
\v 12 Ndikudziwa kuti Yehova amapereka chiweruzo cholungama kwa anthu osauka, 
\q2 ndipo amateteza zolinga za anthu osowa. 
\q1  
\v 13 Zoonadi anthu olungama adzatamanda dzina lanu, 
\q2 ndipo anthu owongoka mtima adzakhala pamaso panu. 
\c 141  
\cl Salimo 141 
\d Salimo la Davide. 
\q1  
\v 1 Inu Yehova ndikukuyitanani; bwerani msanga kwa ine. 
\q2 Imvani mawu anga pamene ndiyitana Inu. 
\q1  
\v 2 Pemphero langa lifike kwa Inu ngati lubani; 
\q2 kukweza manja kwanga kukhale ngati nsembe yamadzulo. 
\b  
\q1  
\v 3 Yehova ikani mlonda pakamwa panga; 
\q2 londerani khomo la pa milomo yanga. 
\q1  
\v 4 Musalole kuti mtima wanga ukokedwere ku zoyipa; 
\q2 kuchita ntchito zonyansa 
\q1 pamodzi ndi anthu amene amachita zoyipa; 
\q2 musalole kuti ndidye nawo zokoma zawo. 
\b  
\q1  
\v 5 Munthu wolungama andikanthe, chimenecho ndiye chifundo; 
\q2 andidzudzule ndiye mafuta pa mutu wanga. 
\q2 Mutu wanga sudzakana zimenezi. 
\b  
\q1 Komabe pemphero langa nthawi zonse ndi lotsutsana ndi ntchito za anthu ochita zoyipa. 
\q2  
\v 6 Olamulira awo adzaponyedwa pansi kuchokera pa malo okwera kwambiri, 
\q2 ndipo anthu oyipa adzaphunzira kuti mawu anga anayankhulidwa bwino. 
\q1  
\v 7 Iwo adzati, “Monga momwe nkhuni zimamwazikira akaziwaza, 
\q2 ndi momwenso mafupa athu amwazikira pa khomo la manda.” 
\b  
\q1  
\v 8 Koma maso anga akupenyetsetsa Inu Ambuye Wamphamvuzonse; 
\q2 ndimathawira kwa Inu, musandipereke ku imfa. 
\q1  
\v 9 Mundipulumutse ku misampha imene anditchera, 
\q2 ku makhwekhwe amene anthu oyipa andikonzera. 
\q1  
\v 10 Anthu oyipa akodwe mʼmaukonde awo, 
\q2 mpaka ine nditadutsa mwamtendere. 
\c 142  
\cl Salimo 142 
\d Ndakatulo ya Davide, pamene iyeyo anali mʼphanga. Pemphero. 
\q1  
\v 1 Ndikulirira Yehova mofuwula; 
\q2 ndikukweza mawu anga kwa Yehova kupempha chifundo. 
\q1  
\v 2 Ndikukhuthula madandawulo anga pamaso pake; 
\q2 ndikufotokoza za masautso anga pamaso pake. 
\b  
\q1  
\v 3 Pamene mzimu wanga walefuka mʼkati mwanga, 
\q2 ndinu amene mudziwa njira yanga. 
\q1 Mʼnjira imene ndimayendamo 
\q2 anthu anditchera msampha mobisa. 
\q1  
\v 4 Yangʼanani kumanja kwanga ndipo onani; 
\q2 palibe amene akukhudzika nane. 
\q1 Ndilibe pothawira; 
\q2 palibe amene amasamala za moyo wanga. 
\b  
\q1  
\v 5 Ndilirira Inu Yehova; 
\q2 ndikuti, “Ndinu pothawirapo panga, 
\q2 gawo langa mʼdziko la anthu amoyo.” 
\q1  
\v 6 Mverani kulira kwanga 
\q2 pakuti ndathedwa nzeru; 
\q1 pulumutseni kwa amene akundithamangitsa 
\q2 pakuti ndi amphamvu kuposa ine. 
\q1  
\v 7 Tulutseni mʼndende yanga 
\q2 kuti nditamande dzina lanu. 
\b  
\q1 Ndipo anthu olungama adzandizungulira 
\q2 chifukwa cha zabwino zanu pa ine. 
\c 143  
\cl Salimo 143 
\d Salimo la Davide. 
\q1  
\v 1 Yehova imvani pemphero langa, 
\q2 mvetserani kulira kwanga kopempha chifundo; 
\q1 mwa kukhulupirika kwanu ndi chilungamo chanu 
\q2 bwerani kudzandithandiza. 
\q1  
\v 2 Musazenge mlandu mtumiki wanu, 
\q2 pakuti palibe munthu wamoyo amene ndi wolungama pamaso panu. 
\b  
\q1  
\v 3 Mdani akundithamangitsa, 
\q2 iye wandipondereza pansi; 
\q1 wachititsa kuti ndikhale mu mdima 
\q2 ngati munthu amene anafa kale. 
\q1  
\v 4 Choncho mzimu wanga ukufowoka mʼkati mwanga; 
\q2 mʼkati mwanga, mtima wanga uli ndi nkhawa. 
\b  
\q1  
\v 5 Ndimakumbukira masiku amakedzana; 
\q2 ndimalingalira za ntchito yanu yonse, 
\q2 ndimaganizira zimene manja anu anachita. 
\q1  
\v 6 Ndatambalitsa manja anga kwa Inu; 
\q2 moyo wanga uli ndi ludzu lofuna Inu monga nthaka yowuma. 
\q4 \qs Sela\qs* 
\b  
\q1  
\v 7 Yehova ndiyankheni msanga; 
\q2 mzimu wanga ukufowoka. 
\q1 Musandibisire nkhope yanu, 
\q2 mwina ndidzakhala ngati iwo amene atsikira ku dzenje. 
\q1  
\v 8 Lolani kuti mmawa ubweretse mawu achikondi chanu chosasinthika, 
\q2 pakuti ine ndimadalira Inu. 
\q1 Mundisonyeze njira yoti ndiyendemo, 
\q2 pakuti kwa Inu nditukulira moyo wanga. 
\q1  
\v 9 Pulumutseni kwa adani anga, Inu Yehova, 
\q2 pakuti ndimabisala mwa Inu. 
\q1  
\v 10 Phunzitseni kuchita chifuniro chanu, 
\q2 popeza ndinu Mulungu wanga; 
\q1 Mzimu wanu wabwino unditsogolere 
\q2 pa njira yanu yosalala. 
\b  
\q1  
\v 11 Sungani moyo wanga Inu Yehova chifukwa cha dzina lanu; 
\q2 mwa chilungamo chanu tulutseni mʼmasautso anga. 
\q1  
\v 12 Mwa chikondi chanu chosasinthika khalitsani chete adani anga; 
\q2 wonongani adani anga, 
\q2 pakuti ndine mtumiki wanu. 
\c 144  
\cl Salimo 144 
\d Salimo la Davide. 
\q1  
\v 1 Atamandike Yehova Thanthwe langa, 
\q2 amene amaphunzitsa manja anga kuchita nkhondo; 
\q2 zala zanga kumenya nkhondo. 
\q1  
\v 2 Iye ndiye Mulungu wanga wachikondi ndi malo anga otetezedwa, 
\q2 linga langa ndi mpulumutsi wanga, 
\q1 chishango changa mmene ine ndimathawiramo, 
\q2 amene amagonjetsa mitundu ya anthu pansi panga. 
\b  
\q1  
\v 3 Inu Yehova, munthu nʼchiyani kuti mumamusamalira, 
\q2 mwana wa munthu kuti muzimuganizira? 
\q1  
\v 4 Munthu ali ngati mpweya; 
\q2 masiku ake ali ngati mthunzi wosakhalitsa. 
\b  
\q1  
\v 5 Ngʼambani mayiko akumwamba, Inu Yehova, ndipo tsikani pansi; 
\q2 khudzani mapiri kuti atulutse utsi. 
\q1  
\v 6 Tumizani zingʼaningʼani ndi kubalalitsa adani; 
\q2 ponyani mivi yanu ndi kuwathamangitsa. 
\q1  
\v 7 Tambasulani dzanja lanu kuchokera kumwamba; 
\q2 landitseni ndi kundipulumutsa, 
\q1 ku madzi amphamvu, 
\q2 mʼmanja mwa anthu achilendo, 
\q1  
\v 8 amene pakamwa pawo ndi podzala ndi mabodza, 
\q2 amene dzanja lawo lamanja ndi lachinyengo. 
\b  
\q1  
\v 9 Ndidzakuyimbirani nyimbo yatsopano Inu Mulungu; 
\q2 ndidzakuyimbirani nyimbo pa zeze wa nsambo khumi, 
\q1  
\v 10 kwa Iye amene amapambanitsa mafumu, 
\q2 amene amapulumutsa Davide mtumiki wake ku lupanga loopsa. 
\b  
\q1  
\v 11 Landitseni ndi kundipulumutsa, 
\q2 mʼmanja mwa anthu achilendo, 
\q1 amene pakamwa pawo ndi podzaza ndi mabodza, 
\q2 amene dzanja lawo lamanja ndi lachinyengo. 
\b  
\q1  
\v 12 Ndipo ana aamuna pa chinyamata chawo 
\q2 adzakhala ngati mbewu yosamalidwa bwino, 
\q1 ana athu aakazi adzakhala ngati zipilala 
\q2 zosemedwa bwino, zokongoletsera nyumba yaufumu. 
\q1  
\v 13 Nkhokwe zathu zidzakhala zodzaza 
\q2 ndi zokolola za mtundu uliwonse. 
\q1 Nkhosa zathu zidzaswana miyandamiyanda 
\q2 pa mabusa athu. 
\q2  
\v 14 Ngʼombe zathu zidzanyamula katundu wolemera. 
\q1 Sipadzakhala mingʼalu pa makoma, 
\q2 sipadzakhalanso kupita ku ukapolo, 
\q2 mʼmisewu mwathu simudzakhala kulira chifukwa cha mavuto. 
\b  
\q1  
\v 15 Odala anthu amene adzalandira madalitso awa; 
\q2 odala anthu amene Mulungu wawo ndi Yehova. 
\c 145  
\cl Salimo 145 
\d Salimo la matamando la Davide. 
\q1  
\v 1 Ndidzakukwezani Mulungu wanga, Mfumu yanga; 
\q2 ndidzatamanda dzina lanu ku nthawi za nthawi. 
\q1  
\v 2 Ndidzakutamandani tsiku ndi tsiku 
\q2 ndi kulemekeza dzina lanu ku nthawi za nthawi. 
\b  
\q1  
\v 3 Yehova ndi wamkulu ndi woyenera matamando onse; 
\q2 ukulu wake palibe angawumvetsetse. 
\q1  
\v 4 Mʼbado wina udzayamikira ntchito yanu kwa mʼbado wina; 
\q2 Iwo adzafotokoza za machitidwe anu amphamvu. 
\q1  
\v 5 Adzayankhula ulemerero wokongola waufumu wanu, 
\q2 ndipo ine ndidzalingalira za ntchito zanu zodabwitsa. 
\q1  
\v 6 Iwo adzafotokoza za mphamvu ya ntchito zanu zoopsa kwambiri, 
\q2 ndipo ine ndidzalengeza za ntchito zanu zazikulu. 
\q1  
\v 7 Adzakondwerera kuchuluka kwa ubwino wanu, 
\q2 ndi kuyimba mwachimwemwe za chilungamo chanu. 
\b  
\q1  
\v 8 Yehova ndi wokoma mtima ndi wachifundo, 
\q2 wosakwiya msanga ndi wodzaza ndi chikondi chosasinthika. 
\q1  
\v 9 Yehova ndi wabwino kwa onse; 
\q2 amachitira chifundo zonse zimene anazipanga. 
\q1  
\v 10 Zonse zimene munazipanga zidzakutamandani, Inu Yehova; 
\q2 oyera mtima adzakulemekezani. 
\q1  
\v 11 Iwo adzafotokoza za ulemerero wa ufumu wanu 
\q2 ndi kuyankhula za mphamvu yanu, 
\q1  
\v 12 kuti anthu onse adziwe za machitidwe anu amphamvu 
\q2 ndi ulemerero wokongola wa ufumu wanu. 
\q1  
\v 13 Ufumu wanu ndi ufumu wamuyaya, 
\q2 ndipo ulamuliro wanu ndi wosatha pa mibado yonse. 
\b  
\q1 Yehova ndi wokhulupirika pa malonjezo ake onse 
\q2 ndi wokonda zonse zimene Iye anazipanga. 
\q1  
\v 14 Yehova amagwiriziza onse amene akugwa 
\q2 ndipo amakweza onse otsitsidwa. 
\q1  
\v 15 Maso a onse amayangʼana kwa Inu, 
\q2 ndipo Inu mumawapatsa chakudya chawo pa nthawi yoyenera. 
\q1  
\v 16 Mumatsekula dzanja lanu 
\q2 ndi kukwaniritsa zokhumba za chamoyo chilichonse. 
\b  
\q1  
\v 17 Yehova ndi wolungama mʼnjira zake zonse, 
\q2 ndi wokonda zonse zimene anazipanga. 
\q1  
\v 18 Yehova ali pafupi ndi onse amene amamuyitana, 
\q2 onse amene amamuyitana Iye mʼchoonadi. 
\q1  
\v 19 Iye amakwaniritsa zokhumba za iwo amene amamuopa; 
\q2 amamva kulira kwawo ndi kuwapulumutsa. 
\q1  
\v 20 Yehova amayangʼana onse amene amamukonda 
\q2 koma adzawononga anthu onse oyipa. 
\b  
\q1  
\v 21 Pakamwa panga padzayankhula zotamanda Yehova. 
\q2 Cholengedwa chilichonse chitamande dzina lake loyera 
\q2 ku nthawi za nthawi. 
\c 146  
\cl Salimo 146 
\q1  
\v 1 Tamandani Yehova. 
\b  
\q1 Tamanda Yehova, iwe moyo wanga. 
\q2  
\v 2 Ndidzatamanda Yehova ndi moyo wanga wonse; 
\q2 ndidzayimba nyimbo zamatamando kwa Mulungu wanga nthawi yonse ya moyo wanga. 
\b  
\q1  
\v 3 Musamadalire mafumu, 
\q2 anthu osakhalitsa, amene sangathe kupulumutsa. 
\q1  
\v 4 Pamene mizimu yawo yachoka, iwo amabwerera ku dothi; 
\q2 zimene ankafuna kuchita zimatha tsiku lomwelo. 
\b  
\q1  
\v 5 Wodala ndi amene thandizo lake ndi 
\q2 Mulungu wa Yakobo. 
\q1  
\v 6 Wolenga kumwamba ndi dziko lapansi, 
\q2 nyanja ndi zonse zili mʼmenemo; 
\q2 Yehova, amene ndi wokhulupirika kwamuyaya. 
\q1  
\v 7 Iye amachitira chilungamo anthu oponderezedwa 
\q2 ndipo amapereka chakudya kwa anthu anjala. 
\q1 Yehova amamasula amʼndende, 
\q2  
\v 8 Yehova amatsekula maso anthu osaona, 
\q1 Yehova amadzutsa onse amene awerama pansi, 
\q2 Yehova amakonda anthu olungama. 
\q1  
\v 9 Yehova amasamalira alendo 
\q2 ndipo amathandiza ana ndi akazi amasiye, 
\q2 koma amasokoneza njira za anthu oyipa. 
\b  
\q1  
\v 10 Yehova ndiye Mfumu mpaka muyaya, 
\q2 Mulungu wako iwe Ziyoni, pa mibado yonse. 
\b  
\q1 Tamandani Yehova. 
\c 147  
\cl Salimo 147 
\q1  
\v 1 Tamandani Yehova. 
\b  
\q1 Nʼkwabwino kwambiri kuyimba nyimbo zamatamando kwa Mulungu wathu, 
\q2 nʼkokondweretsa ndi koyenera kumutamanda! 
\b  
\q1  
\v 2 Yehova akumanga Yerusalemu; 
\q2 Iye akusonkhanitsa amʼndende a Israeli. 
\q1  
\v 3 Akutsogolera anthu osweka mtima 
\q2 ndi kumanga mabala awo. 
\b  
\q1  
\v 4 Amadziwa chiwerengero cha nyenyezi, 
\q2 ndipo iliyonse amayitchula dzina. 
\q1  
\v 5 Yehova ndi wamkulu ndi wamphamvu kwambiri; 
\q2 nzeru zake zilibe malire. 
\q1  
\v 6 Yehova amagwiriziza anthu odzichepetsa, 
\q2 koma amagwetsa pansi anthu oyipa. 
\b  
\q1  
\v 7 Imbirani Yehova ndi mayamiko; 
\q2 imbani nyimbo kwa Mulungu ndi pangwe. 
\q1  
\v 8 Iye amaphimba mlengalenga ndi mitambo; 
\q2 amapereka mvula ku dziko lapansi 
\q2 ndi kumeretsa udzu mʼmapiri. 
\q1  
\v 9 Iye amapereka chakudya kwa ngʼombe 
\q2 ndi kwa ana a makwangwala pamene akulira chakudya. 
\b  
\q1  
\v 10 Chikondwerero chake sichili mʼmphamvu za kavalo, 
\q2 kapena mʼmiyendo ya anthu amphamvu. 
\q1  
\v 11 Yehova amakondwera ndi amene amamuopa, 
\q2 amene chiyembekezo chawo chili mʼchikondi chake chosasinthika. 
\b  
\q1  
\v 12 Lemekeza Yehova, iwe Yerusalemu; 
\q2 tamanda Mulungu wako, iwe Ziyoni, 
\q1  
\v 13 pakuti Iye amalimbitsa mipiringidzo ya zipata zako 
\q2 ndi kudalitsa anthu ako mwa iwe. 
\q1  
\v 14 Iye amabweretsa mtendere mʼmalire mwako 
\q2 ndi kukukhutitsa ndi ufa wa tirigu wosalala. 
\b  
\q1  
\v 15 Iyeyo amapereka lamulo pa dziko lapansi; 
\q2 mawu ake amayenda mwaliwiro. 
\q1  
\v 16 Amagwetsa chisanu ngati ubweya 
\q2 ndi kumwaza chipale ngati phulusa. 
\q1  
\v 17 Amagwetsa matalala ngati miyala. 
\q2 Kodi ndani angathe kupirira kuzizira kwake? 
\q1  
\v 18 Amatumiza mawu ake ndipo chisanucho chimasungunuka; 
\q2 amawombetsa mphepo ndipo madzi amayenda. 
\b  
\q1  
\v 19 Iye anawulula mawu ake kwa Yakobo, 
\q2 malamulo ake ndi zophunzitsa zake kwa Israeli. 
\q1  
\v 20 Sanachitepo zimenezi kwa mtundu wina uliwonse wa anthu; 
\q2 anthu enawo sadziwa malamulo ake. 
\b  
\q1 Tamandani Yehova. 
\c 148  
\cl Salimo 148 
\q1  
\v 1 Tamandani Yehova. 
\b  
\q1 Tamandani Yehova, inu a kumwamba, 
\q2 mutamandeni Iye, inu a mlengalenga. 
\q1  
\v 2 Mutamandeni, inu angelo ake onse, 
\q2 mutamandeni, mutamandeni, inu zolengedwa za mmwamba. 
\q1  
\v 3 Mutamandeni, inu dzuwa ndi mwezi, 
\q2 mutamandeni, inu nonse nyenyezi zowala. 
\q1  
\v 4 Mutamandeni, inu thambo la kumwambamwamba 
\q2 ndi inu madzi a pamwamba pa thambo. 
\q1  
\v 5 Zonse zitamande dzina la Yehova 
\q2 pakuti Iye analamula ndipo zinalengedwa. 
\q1  
\v 6 Iye anaziyika pa malo ake ku nthawi za nthawi; 
\q2 analamula ndipo sizidzatha. 
\b  
\q1  
\v 7 Tamandani Yehova pa dziko lapansi, 
\q2 inu zolengedwa zikuluzikulu za mʼnyanja, ndi nyanja zonse zakuya, 
\q1  
\v 8 inu zingʼaningʼani ndi matalala, chipale ndi mitambo, 
\q2 mphepo yamkuntho imene imakwaniritsa mawu ake, 
\q1  
\v 9 inu mapiri ndi zitunda zonse, 
\q2 inu mitengo ya zipatso ndi mikungudza yonse, 
\q1  
\v 10 inu nyama zakuthengo ndi ngʼombe zonse, 
\q2 inu zolengedwa zingʼonozingʼono ndi mbalame zowuluka. 
\q1  
\v 11 Inu mafumu a dziko lapansi ndi anthu a mitundu yonse, 
\q2 inu akalonga ndi olamulira a dziko lapansi. 
\q1  
\v 12 Inu anyamata ndi anamwali, 
\q2 inu nkhalamba ndi ana omwe. 
\b  
\q1  
\v 13 Onsewo atamande dzina la Yehova 
\q2 pakuti dzina lake lokha ndi lolemekezeka; 
\q2 ulemerero wake ndi woopsa pa dziko lapansi pano ndi kumwamba komwe. 
\q1  
\v 14 Iye wakwezera nyanga anthu ake, 
\q2 matamando a anthu ake onse oyera mtima, 
\q2 Aisraeli, anthu a pamtima pake. 
\b  
\q1 Tamandani Yehova. 
\c 149  
\cl Salimo 149 
\q1  
\v 1 Tamandani Yehova. 
\b  
\q1 Imbirani Yehova nyimbo yatsopano, 
\q2 matamando ake mu msonkhano wa oyera mtima. 
\b  
\q1  
\v 2 Israeli asangalale mwa mlengi wake; 
\q2 anthu a ku Ziyoni akondwere mwa Mfumu yawo. 
\q1  
\v 3 Atamande dzina lake povina 
\q2 ndi kuyimbira Iye nyimbo ndi tambolini ndi pangwe. 
\q1  
\v 4 Pakuti Yehova amakondwera ndi anthu ake; 
\q2 Iye amaveka chipulumutso odzichepetsa. 
\q1  
\v 5 Oyera mtima asangalale mu ulemu wake 
\q2 ndi kuyimba mwachimwemwe pa mabedi awo. 
\b  
\q1  
\v 6 Matamando a Mulungu akhale pakamwa pawo, 
\q2 ndi lupanga lakuthwa konsekonse mʼmanja mwawo, 
\q1  
\v 7 kubwezera chilango anthu a mitundu ina, 
\q2 ndi kulanga anthu a mitundu yonse, 
\q1  
\v 8 kumanga mafumu awo ndi zingwe, 
\q2 anthu awo otchuka ndi unyolo wachitsulo, 
\q1  
\v 9 kuchita zimene zinalembedwa zotsutsana nawo 
\q2 Uwu ndi ulemerero wa oyera mtima ake onse. 
\b  
\q1 Tamandani Yehova. 
\c 150  
\cl Salimo 150 
\q1  
\v 1 Tamandani Yehova. 
\b  
\q1 Tamandani Mulungu mʼmalo ake opatulika; 
\q2 mutamandeni ku thambo lake lamphamvu. 
\q1  
\v 2 Mutamandeni chifukwa cha machitidwe ake amphamvu; 
\q2 mutamandeni chifukwa cha ukulu wake wopambana. 
\q1  
\v 3 Mutamandeni poyimba malipenga, 
\q2 mutamandeni ndi pangwe ndi zeze. 
\q1  
\v 4 Mutamandeni ndi matambolini ndi kuvina, 
\q2 mutamandeni ndi zingwe ndi zitoliro. 
\q1  
\v 5 Mutamandeni ndi ziwaya zolira za malipenga, 
\q2 mutamandeni ndi ziwaya zolira kwambiri. 
\b  
\q1  
\v 6 Chamoyo chilichonse chopuma chitamande Yehova. 
\b  
\q1 Tamandani Yehova.