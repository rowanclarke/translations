\id ZEP - Biblica® Open Yoruba Contemporary Bible 2017
\h Sefaniah
\toc1 Ìwé Wòlíì Sefaniah
\toc2 Sefaniah
\toc3 Sf
\mt1 Ìwé Wòlíì Sefaniah
\c 1
\p 
\v 1 Ọ̀rọ̀ \nd Olúwa\nd* tí ó tọ Sefaniah ọmọ Kuṣi, ọmọ Gedaliah, ọmọ Amariah, ọmọ Hesekiah, ní ìgbà Josiah ọmọ Amoni ọba Juda.
\b
\s1 Ìkìlọ̀ fún ìparun tí ń bọ̀
\q1 
\v 2 “Èmi yóò mú gbogbo nǹkan kúrò
\q2 lórí ilẹ̀ náà pátápátá,”
\q2 ni \nd Olúwa\nd* wí.
\q1 
\v 3 “Èmi yóò mú ènìyàn àti ẹranko kúrò;
\q2 èmi yóò mú àwọn ẹyẹ ojú ọ̀run kúrò, àti ẹja inú Òkun,
\q2 àti ohun ìdìgbòlù pẹ̀lú àwọn ènìyàn búburú;
\q1 èmi yóò ké ènìyàn kúrò lórí ilẹ̀ ayé,”
\q2 ni \nd Olúwa\nd* wí.
\s1 Ìlòdì sí Juda
\q1 
\v 4 “Èmi yóò na ọwọ́ mi sórí Juda
\q2 àti sórí gbogbo àwọn ènìyàn tí ń gbé ní Jerusalẹmu.
\q1 Èmi yóò sì ké kúrò níhìn-ín yìí ìyókù àwọn Baali, àti orúkọ àwọn abọ̀rìṣà
\q2 pẹ̀lú àwọn àlùfáà abọ̀rìṣà,
\q1 
\v 5 àti àwọn tí ń foríbalẹ̀ lórí òrùlé,
\q2 àwọn tí ń sin ogun ọ̀run,
\q1 àwọn tó ń foríbalẹ̀, tí wọ́n sì ń fi \nd Olúwa\nd* búra,
\q2 tí wọ́n sì ń fi Moleki búra.
\q1 
\v 6 Àwọn tí ó yípadà kúrò lọ́dọ̀ \nd Olúwa\nd*;
\q2 àti àwọn tí kò tí wá \nd Olúwa\nd*, bẹ́ẹ̀ ni wọn kò sì béèrè rẹ̀.”
\b
\q1 
\v 7 Ẹ dákẹ́ jẹ́ẹ́ níwájú \nd Olúwa\nd* Olódùmarè,
\q2 nítorí tí ọjọ́ \nd Olúwa\nd* kù sí dẹ̀dẹ̀.
\q1 \nd Olúwa\nd* ti pèsè ẹbọ kan sílẹ̀,
\q2 ó sì ti ya àwọn alápèjẹ rẹ̀ sí mímọ́.
\b
\q1 
\v 8 “Ní ọjọ́ ẹbọ \nd Olúwa\nd*,
\q2 Èmi yóò bẹ àwọn olórí wò,
\q2 àti àwọn ọmọ ọba ọkùnrin,
\q2 pẹ̀lú gbogbo àwọn tí ó wọ àjèjì aṣọ.
\q1 
\v 9 Ní ọjọ́ náà, èmi yóò fi ìyà jẹ
\q2 gbogbo àwọn tí ó yẹra láti rìn lórí ìloro ẹnu-ọ̀nà,
\q1 tí wọ́n sì kún tẹmpili àwọn ọlọ́run wọn
\q2 pẹ̀lú ìwà ipá àti ẹ̀tàn.
\b
\q1 
\v 10 “Ní ọjọ́ náà,” ni \nd Olúwa\nd* wí,
\q2 “Ohùn ẹkún yóò wà láti ìhà ibodè ẹja,
\q2 híhu láti ìhà kejì wá àti
\q2 ariwo ńlá láti òkè kékeré wá.
\q1 
\v 11 Ẹ hu, ẹ̀yin tí ń gbé ní agbègbè ọjà,
\q2 gbogbo àwọn oníṣòwò rẹ̀ ni a ó mú kúrò,
\q2 gbogbo àwọn ẹni tí ó ń ra fàdákà ni a ó sì parun.
\q1 
\v 12 Ní àkókò wọ̀n-ọn-nì, èmi yóò wá Jerusalẹmu kiri pẹ̀lú fìtílà,
\q2 èmi ó sì fi ìyà jẹ àwọn tí kò ní ìtẹ́lọ́rùn,
\q2 tí wọn sì dàbí àwọn ènìyàn tí ó sinmi sínú gẹ̀dẹ̀gẹ́dẹ̀ wọn,
\q1 àwọn tí wọn sì ń wí ní ọkàn wọn pé, ‘\nd Olúwa\nd* kì yóò ṣe nǹkan kan
\q2 tí ó jẹ́ rere tàbí tí ó jẹ́ búburú.’
\q1 
\v 13 Nítorí náà, ọrọ̀ wọn yóò di ìkógun,
\q2 àti ilé wọn yóò sì run.
\q1 Àwọn yóò sì kọ́ ilé pẹ̀lú,
\q2 ṣùgbọ́n wọn kì yóò gbé nínú ilé náà,
\q1 wọn yóò gbin ọgbà àjàrà,
\q2 ṣùgbọ́n wọn kì yóò mu ọtí
\q1 wáìnì láti inú rẹ̀.”
\s1 Ọjọ́ ńlá \nd Olúwa\nd*
\q1 
\v 14 “Ọjọ́ ńlá \nd Olúwa\nd* kù sí dẹ̀dẹ̀,
\q2 ó kù sí dẹ̀dẹ̀ ó sì ń yára bọ̀ kánkán.
\q1 Ẹ tẹ́tí sílẹ̀, ohùn ẹkún àwọn alágbára;
\q2 ní ọjọ́ \nd Olúwa\nd* yóò korò púpọ̀,
\q1 
\v 15 ọjọ́ náà yóò jẹ́ ọjọ́ ìbínú,
\q2 ọjọ́ ìrora àti ìpọ́njú,
\q1 ọjọ́ òfò àti idà ọjọ́ ìdahoro
\q2 ọjọ́ òkùnkùn àti ìtẹ̀ba,
\q2 ọjọ́ kurukuru àti òkùnkùn biribiri,
\q1 
\v 16 ọjọ́ ìpè àti ìpè ogun
\q2 sí àwọn ìlú olódi
\q2 àti sí àwọn ilé ìṣọ́ gíga.
\b
\q1 
\v 17 “Èmi yóò sì mú ìpọ́njú wá sórí ènìyàn,
\q2 wọn yóò sì máa rìn gẹ́gẹ́ bí afọ́jú,
\q2 nítorí àwọn ti dẹ́ṣẹ̀ sí \nd Olúwa\nd*.
\q1 Ẹ̀jẹ̀ wọn ni a ó sì tú jáde bí eruku
\q2 àti ẹran-ara wọn bí ìgbẹ́.
\q1 
\v 18 Bẹ́ẹ̀ ni fàdákà tàbí wúrà wọn
\q2 kì yóò sì le gbà wọ́n là
\q2 ní ọjọ́ ìbínú \nd Olúwa\nd*.”
\b
\q1 Ṣùgbọ́n gbogbo ayé ni a ó fi iná
\q2 ìjowú rẹ̀ parun,
\q1 nítorí òun yóò fi ìyára fi òpin sí
\q2 gbogbo àwọn tí ń gbé ní ilẹ̀ ayé.
\c 2
\s1 Ìpè si Ìrònúpìwàdà
\q1 
\v 1 Ẹ kó ara yín jọ pọ̀, àní ẹ kó ra yín jọ pọ̀
\q2 orílẹ̀-èdè tí kò ní ìtìjú,
\q1 
\v 2 kí a tó pa àṣẹ náà, kí ọjọ́ náà tó kọjá bí ìyàngbò ọkà,
\q2 kí gbígbóná ìbínú \nd Olúwa\nd* tó dé bá a yín,
\q1 kí ọjọ́ ìbínú \nd Olúwa\nd* kí ó tó dé bá a yín.
\q1 
\v 3 Ẹ wá \nd Olúwa\nd*, gbogbo ẹ̀yin onírẹ̀lẹ̀ ilẹ̀ náà,
\q2 ẹ̀yin tí ń ṣe ohun tí ó bá pàṣẹ.
\q1 Ẹ wá òdodo, ẹ wá ìrẹ̀lẹ̀ pẹ̀lú,
\q2 bóyá á ó pa yín mọ́ ní ọjọ́ ìbínú \nd Olúwa\nd*.
\s1 Ìlòdì sí Filistia
\q1 
\v 4 Nítorí pé, a ó kọ Gasa sílẹ̀,
\q2 Aṣkeloni yóò sì dahoro.
\q1 Ní ọ̀sán gangan ni a ó lé Aṣdodu jáde,
\q2 a ó sì fa Ekroni tu kúrò.
\q1 
\v 5 Ègbé ni fún ẹ̀yin tí ń gbé etí Òkun,
\q2 ẹ̀yin ènìyàn ara Kereti;
\q1 ọ̀rọ̀ \nd Olúwa\nd* dojúkọ ọ́, ìwọ Kenaani,
\q2 ilẹ̀ àwọn ara Filistini.
\q1 “Èmi yóò pa yín run,
\q2 ẹnìkan kò sì ní ṣẹ́kù nínú yín.”
\q1 
\v 6 Ilẹ̀ náà ní etí Òkun, ni ibùgbé àwọn ará Kereti,
\q2 ni yóò jẹ́ ibùjókòó fún àwọn olùṣọ́-àgùntàn àti agbo àgùntàn.
\q1 
\v 7 Agbègbè náà yóò sì jẹ́ ti ìyókù àwọn ilé Juda,
\q2 níbẹ̀ ni wọn yóò sì ti rí koríko fún ẹran.
\q1 Ní ilé Aṣkeloni ni wọn yóò
\q2 dùbúlẹ̀ ni àṣálẹ́.
\q1 \nd Olúwa\nd* Ọlọ́run wọn yóò bẹ̀ wọn wò,
\q2 yóò sì yí ìgbèkùn wọn padà.
\s1 Ìlòdì sí Moabu àti Ammoni
\q1 
\v 8 “Èmi ti gbọ́ ẹ̀gàn Moabu,
\q2 àti ẹlẹ́yà àwọn Ammoni,
\q1 àwọn tó kẹ́gàn àwọn ènìyàn mi,
\q2 tí wọ́n sì ti gbé ara wọn ga sí agbègbè wọn.
\q1 
\v 9 Nítorí náà, bí Èmi tí wà,”
\q2 ni \nd Olúwa\nd* àwọn ọmọ-ogun,
\q2 Ọlọ́run àwọn Israẹli wí,
\q1 “nítòótọ́ Moabu yóò dàbí Sodomu,
\q2 àti Ammoni yóò sì dàbí Gomorra,
\q1 ibi tí ó kún fún yèrèpè,
\q2 àti ìhó iyọ̀ àti ìdahoro títí láéláé.
\q1 Ìyókù àwọn ènìyàn mi yóò kó wọn;
\q2 àwọn tí ó sì yọ nínú ewu ní orílẹ̀-èdè mi ni yóò jogún ilẹ̀ wọn.”
\b
\q1 
\v 10 Èyí ni ohun tí wọn yóò gbà padà nítorí ìgbéraga wọn,
\q2 nítorí wọ́n kẹ́gàn, wọn sì ti fi àwọn ènìyàn \nd Olúwa\nd* àwọn ọmọ-ogun ṣe ẹlẹ́yà.
\q1 
\v 11 \nd Olúwa\nd* yóò jẹ́ ìbẹ̀rù fún wọn;
\q2 nígbà tí Òun bá pa gbogbo òrìṣà ilẹ̀ náà run.
\q1 Orílẹ̀-èdè láti etí odò yóò máa sìn,
\q2 olúkúlùkù láti ilẹ̀ rẹ̀ wá.
\q1 
\v 12 “Ẹ̀yin Etiopia pẹ̀lú,
\q2 a ó fi idà mi pa yín.”
\s1 Asiria
\q1 
\v 13 Òun yóò sì na ọwọ́ rẹ̀ sí apá àríwá,
\q2 yóò sì pa Asiria run,
\q1 yóò sì sọ Ninefe di ahoro,
\q2 àti di gbígbẹ bí aginjù.
\q1 
\v 14 Agbo ẹran yóò sì dùbúlẹ̀ ni àárín rẹ̀,
\q2 àti gbogbo ẹranko àwọn orílẹ̀-èdè.
\q1 Òwìwí aginjù àti ti n kígbe ẹyẹ òwìwí
\q2 yóò wọ bí ẹyẹ ni ọwọ̀n rẹ̀.
\q1 Ohùn wọn yóò kọrin ni ojú fèrèsé,
\q2 ìdahoro yóò wà nínú ìloro ẹnu-ọ̀nà,
\q2 òun yóò sì ṣẹ́ ọ̀pá kedari sílẹ̀.
\q1 
\v 15 Èyí ni ìlú aláyọ̀ tí ó ń gbé láìléwu.
\q2 Ó sì sọ fun ara rẹ̀ pé,
\q1 “Èmi ni, kò sì sí ẹnìkan tí ó ń bẹ lẹ́yìn mi.”
\q2 Irú ahoro wo ni òun ha ti jẹ́,
\q1 ibùgbé fún àwọn ẹranko igbó!
\q2 Gbogbo ẹni tí ó bá kọjá ọ̀dọ̀ rẹ̀
\q1 yóò fi rẹ́rìn-ín ẹlẹ́yà,
\q2 wọ́n yóò sì gbọn ẹsẹ̀ wọn.
\c 3
\s1 Ọjọ́ iwájú Jerusalẹmu
\q1 
\v 1 Ègbé ni fún ìlú aninilára,
\q2 ọlọ̀tẹ̀ àti aláìmọ́.
\q1 
\v 2 Òun kò gbọ́rọ̀ sí ẹnikẹ́ni,
\q2 òun kò gba ìtọ́ni,
\q1 òun kò gbẹ́kẹ̀lé \nd Olúwa\nd*,
\q2 bẹ́ẹ̀ ni òun kò súnmọ́ ọ̀dọ̀ Ọlọ́run rẹ̀.
\q1 
\v 3 Àwọn olórí rẹ̀ jẹ́ kìnnìún tí ń ké ramúramù,
\q2 àwọn onídàájọ́ rẹ̀, ìkookò àṣálẹ́ ni wọn,
\q2 wọn kò sì fi nǹkan kan kalẹ̀ fún òwúrọ̀.
\q1 
\v 4 Àwọn wòlíì rẹ̀ gbéraga,
\q2 wọ́n sì jẹ́ alárékérekè ènìyàn.
\q1 Àwọn àlùfáà rẹ̀ ti ba ibi mímọ́ jẹ́,
\q2 wọ́n sì rú òfin.
\q1 
\v 5 \nd Olúwa\nd* ni àárín rẹ̀ jẹ́ olódodo;
\q2 kì yóò ṣe ohun tí kò tọ̀nà.
\q1 Àràárọ̀ ni ó máa ń mú ìdájọ́ rẹ̀ wá sí ìmọ́lẹ̀,
\q2 kì í sì kùnà ní gbogbo ọjọ́ tuntun,
\q2 síbẹ̀ àwọn aláìṣòótọ́ kò mọ ìtìjú.
\q1 
\v 6 “Èmi ti ké àwọn orílẹ̀-èdè kúrò,
\q2 ilé gíga wọn sì ti bàjẹ́.
\q1 Mo ti fi ìgboro wọn sílẹ̀ ní òfo
\q2 tó bẹ́ẹ̀ tí ẹnìkankan kò kọjá níbẹ̀.
\q1 Ìlú wọn parun tó bẹ́ẹ̀ tí kò sí
\q2 ẹnìkan tí yóò ṣẹ́kù,
\q2 kò sì ní sí ẹnìkan rárá.
\q1 
\v 7 Èmi wí fún ìlú náà wí pé,
\q2 ‘Nítòótọ́, ìwọ yóò bẹ̀rù mi,
\q2 ìwọ yóò sì gba ìtọ́ni!’
\q1 Bẹ́ẹ̀ ni, a kì yóò ké ibùgbé rẹ̀ kúrò
\q2 bí ó ti wù kí ń jẹ wọ́n ní yà tó.
\q1 Ṣùgbọ́n síbẹ̀ wọ́n sì tún ní ìtara
\q2 láti ṣe ìbàjẹ́.
\q1 
\v 8 Nítorí náà ẹ dúró dè mí,” ni \nd Olúwa\nd* wí,
\q2 “títí di ọjọ́ náà tí èmi yóò fi jẹ́rìí sí yin.
\q1 Nítorí ìpinnu mi ni láti kó orílẹ̀-èdè jọ
\q2 kí èmi kí ó lè kó ilẹ̀ ọba jọ
\q1 àti láti da ìbínú mi jáde sórí wọn,
\q2 àní gbogbo ìbínú gbígbóná mi.
\q1 Nítorí gbogbo ayé
\q2 ni a ó fi iná owú mi jẹ run.
\s1 Ìràpadà àwọn ènìyàn tókù
\q1 
\v 9 “Nígbà náà ni èmi yóò yí èdè àwọn ènìyàn padà sí èdè mímọ́,
\q2 nítorí kí gbogbo wọn bá a lè máa pe orúkọ \nd Olúwa\nd*,
\q2 láti fi ọkàn kan sìn ín.
\q1 
\v 10 Láti òkè odò Etiopia,
\q2 àwọn olùjọsìn mi, àwọn ènìyàn mi tí ó ti fọ́nká,
\q2 yóò mú ọrẹ wá fún mi.
\q1 
\v 11 Ní ọjọ́ náà ni a kì yóò sì dójútì
\q2 nítorí gbogbo iṣẹ́ ibi ni tí ó ti ṣẹ̀ sí mi,
\q1 nígbà náà ni èmi yóò mu
\q2 kúrò nínú ìlú yìí, àwọn tí ń yọ̀ nínú ìgbéraga wọn.
\q1 Ìwọ kì yóò sì gbéraga mọ́
\q2 ní òkè mímọ́ mi.
\q1 
\v 12 Ṣùgbọ́n Èmi yóò fi àwọn ọlọ́kàn tútù
\q2 àti onírẹ̀lẹ̀ sílẹ̀ pẹ̀lú ni àárín rẹ̀,
\q2 wọn yóò sì gbẹ́kẹ̀lé orúkọ \nd Olúwa\nd*.
\q1 
\v 13 Àwọn ìyókù Israẹli kì yóò hùwà ibi,
\q2 wọn kì yóò sọ̀rọ̀ èké.
\q1 Bẹ́ẹ̀ ni a kì yóò rí
\q2 ahọ́n àrékérekè ní ẹnu wọn.
\q1 Àwọn yóò jẹun, wọn yóò sì dùbúlẹ̀,
\q2 bẹ́ẹ̀ ni ẹnikẹ́ni kì yóò dẹ́rùbà wọ́n.”
\b
\q1 
\v 14 Kọrin, ìwọ ọmọbìnrin Sioni,
\q2 kígbe sókè, ìwọ Israẹli!
\q1 Fi gbogbo ọkàn yọ̀, kí inú rẹ kí ó sì dùn,
\q2 ìwọ ọmọbìnrin Jerusalẹmu.
\q1 
\v 15 \nd Olúwa\nd* ti mú ìdájọ́ rẹ wọ̀n-ọn-nì kúrò,
\q2 ó sì ti ti àwọn ọ̀tá rẹ padà sẹ́yìn.
\q1 \nd Olúwa\nd*, ọba Israẹli wà pẹ̀lú rẹ;
\q2 ìwọ kì yóò sì bẹ̀rù ibi kan mọ́.
\q1 
\v 16 Ní ọjọ́ náà, wọn yóò sọ fún Jerusalẹmu pé,
\q2 “Má ṣe bẹ̀rù Sioni;
\q2 má sì ṣe jẹ́ kí ọwọ́ rẹ kí ó dẹ̀.
\q1 
\v 17 \nd Olúwa\nd* Ọlọ́run rẹ wà pẹ̀lú rẹ,
\q2 Ó ní agbára láti gbà ọ là.
\q1 Yóò yọ̀ ni orí rẹ fún ayọ̀;
\q2 Yóò tún ọ ṣe nínú ìfẹ́ rẹ̀,
\q2 Yóò sì fi orin yọ̀ ní orí rẹ.”
\b
\q1 
\v 18 “Èmi ó kó àwọn tí ó ń banújẹ́ fún àjọ̀dún tí a yàn jọ,
\q2 àwọn tí ó jẹ́ tirẹ̀;
\q2 àwọn tí ẹ̀gàn rẹ̀ jásí ẹ̀rù.
\q1 
\v 19 Ní àkókò náà
\q2 ni èmi yóò dojúkọ àwọn
\q1 tí ń ni yín lára,
\q2 èmi yóò gba àtiro là,
\q1 èmi yóò sì ṣa àwọn tí ó ti fọ́nká jọ,
\q2 èmi yóò fi ìyìn àti ọlá fún wọn ní
\q2 gbogbo ilẹ̀ tí a bá ti dójútì wọ́n.
\q1 
\v 20 Ní àkókò náà ni èmi yóò ṣà yín jọ;
\q2 nígbà náà ni èmi yóò mú un yín padà wá sílé.
\q1 Èmi yóò fi ọlá àti ìyìn fún un yín
\q2 láàrín gbogbo ènìyàn àgbáyé,
\q1 nígbà tí èmi yóò yí ìgbèkùn yín
\q2 padà bọ sípò ní ojú ara yín,”
\q2 ni \nd Olúwa\nd* wí.
