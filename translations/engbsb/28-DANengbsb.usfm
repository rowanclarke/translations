\m 
\v 29 \w Then|strong="H1768"\w* \w Belshazzar|strong="H1113"\w* gave \w the|strong="H5922"\w* command, \w and|strong="H1722"\w* \w they|strong="H1768"\w* \w clothed|strong="H3848"\w* \w Daniel|strong="H1841"\w* \w in|strong="H5922"\w* purple, placed \w a|strong="H3068"\w* \w gold|strong="H1722"\w* \w chain|strong="H2002"\w* \w around|strong="H5922"\w* \w his|strong="H5922"\w* \w neck|strong="H6676"\w*, \w and|strong="H1722"\w* \w proclaimed|strong="H3745"\w* \w him|strong="H5922"\w* \w the|strong="H5922"\w* \w third|strong="H8531"\w* highest \w ruler|strong="H7990"\w* \w in|strong="H5922"\w* \w the|strong="H5922"\w* \w kingdom|strong="H4437"\w*.
