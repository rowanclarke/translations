\v 9  \w I|strong="G1473"\w*, \w John|strong="G2491"\w*, \w your|strong="G1223"\w* brother \w and|strong="G2532"\w* \w the|strong="G1722"\w* \w one|strong="G3588"\w* \w who|strong="G3588"\w* shares \w with|strong="G1722"\w* \w you|strong="G5210"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w persecution|strong="G2347"\w*, kingdom, \w and|strong="G2532"\w* \w endurance|strong="G5281"\w* \w that|strong="G3588"\w* \w are|strong="G3588"\w* \w in|strong="G1722"\w* \w Jesus|strong="G2424"\w*, \w was|strong="G1096"\w* \w on|strong="G1722"\w* \w the|strong="G1722"\w* \w island|strong="G3520"\w* \w called|strong="G2564"\w* \w Patmos|strong="G3963"\w* \w because|strong="G1223"\w* \w of|strong="G3056"\w* \w the|strong="G1722"\w* \w word|strong="G3056"\w* \w of|strong="G3056"\w* \w God|strong="G2316"\w* \w and|strong="G2532"\w* \w the|strong="G1722"\w* \w testimony|strong="G3141"\w* \w about|strong="G1722"\w* \w Jesus|strong="G2424"\w*.  
