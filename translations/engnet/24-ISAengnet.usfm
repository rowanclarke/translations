\v 1  \w In|strong="H3427"\w* \w the|strong="H5921"\w* \w year|strong="H8141"\w* \w of|strong="H4428"\w* \w King|strong="H4428"\w* \w Uzziah|strong="H5818"\w*’s \w death|strong="H4194"\w*, \w I|strong="H5921"\w* \w saw|strong="H7200"\w* \w the|strong="H5921"\w* sovereign \w master|strong="H3427"\w* \w seated|strong="H3427"\w* \w on|strong="H5921"\w* \w a|strong="H3068"\w* \w high|strong="H7311"\w*, \w elevated|strong="H5375"\w* \w throne|strong="H3678"\w*. \w The|strong="H5921"\w* \w hem|strong="H7757"\w* \w of|strong="H4428"\w* \w his|strong="H5375"\w* \w robe|strong="H7757"\w* \w filled|strong="H4390"\w* \w the|strong="H5921"\w* \w temple|strong="H1964"\w*.  
