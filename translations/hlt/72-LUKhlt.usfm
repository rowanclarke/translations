\c 18  
\s1 Kobawt Kolla Thangthuinah  
\p
\v 1 \w Thangthui|strong="G4336"\w* \w yoeyah|strong="G3842"\w* ham \w neh|strong="G2532"\w* \w thathae|strong="G1573"\w* \w pawt|strong="G3361"\w* ham a \w kuek|strong="G1163"\w* \w soah|strong="G4314"\w* \w amih|strong="G0846"\w* te \w nuettahnah|strong="G3850"\w* neh a \w voek|strong="G3004"\w* tih,  
\v 2 \wj \+w Kho|strong="G4172"\+w* \+w pakhat|strong="G5100"\+w* \+w ah|strong="G1722"\+w* \+w laitloekkung|strong="G2923"\+w* \+w pakhat|strong="G5100"\+w* \+w om|strong="G2258"\+w* tih \+w Pathen|strong="G2316"\+w* \+w taengah|strong="G3588"\+w* \+w birhih|strong="G5399"\+w* \+w pawt|strong="G3361"\+w* \+w tih|strong="G2532"\+w* \+w hlang|strong="G0444"\+w* taengah a \+w yahnah|strong="G1788"\+w* om \+w pawh|strong="G3361"\+w*\wj*.  
\v 3 \wj Te \+w vaengah|strong="G1161"\+w* \+w kho|strong="G4172"\+w* \+w khuiah|strong="G1722"\+w* aka \+w om|strong="G2258"\+w* \+w nuhmai|strong="G5503"\+w* loh \+w anih|strong="G0846"\+w* \+w te|strong="G4314"\+w* a \+w paan|strong="G2064"\+w* tih\wj*, '\wj \+w Ka|strong="G3450"\+w* \+w kocaelh|strong="G0476"\+w* \+w hmaiah|strong="G0575"\+w* \+w kai|strong="G3165"\+w* \+w n'tang|strong="G1556"\+w* sak\wj*,’ \wj a \+w ti|strong="G3004"\+w* nah\wj*.  
\v 4 \wj \+w Tedae|strong="G2532"\+w* te \+w khohnin|strong="G5550"\+w* \+w ham|strong="G1909"\+w* \+w ngaih|strong="G2309"\+w* \+w pawh|strong="G3756"\+w*. \+w Te|strong="G5023"\+w* \+w phoeah|strong="G3326"\+w* \+w amah|strong="G1438"\+w* \+w te|strong="G1722"\+w*\wj*, '\wj \+w Pathen|strong="G2316"\+w* \+w taengah|strong="G3588"\+w* ka \+w birhih|strong="G5399"\+w* \+w pawt|strong="G3756"\+w* tih \+w hlang|strong="G0444"\+w* te ka \+w yahnah|strong="G1788"\+w* \+w mai|strong="G1487"\+w* \+w ngawn|strong="G2532"\+w* \+w pawh|strong="G3761"\+w*\wj*.  
