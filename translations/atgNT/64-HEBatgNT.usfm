\id HEB - Okphela
\h Iburu
\toc1 Iburu
\toc2 Iburu
\toc3 Iburu
\mt2 Ebe ni a kẹkẹ ghi ẹgbọ
\mt1 Iburu
\mt2 Eni e miesuọ
\c 1
\s1 Ungmemhi oyi Ẹshinẹgba ni o rọte obọ oyi Omiọli bhale
\p 
\v 1 Agbọ-nẹdẹ, ebubu ẹghẹghẹ ali odẹ ọdọda Ẹshinẹgba ọ te ri emekẹguele nu ititawa ngme.
\v 2 Ama omiọli ni ọ zẹ ni ọ le ugu emhikpa ọ ke rọ nu awa ngme ogbẹlẹ ikpukhokho ni awa la memena. Obọ oyọli ọ gbo rọte ma agbọ
\v 3 Lọli ọ ri ufumhi oyi Ẹshinẹgba khasẹ. Eri ọ gbo li abi Ẹshinẹgba ọ li tee. Lọli ọ ri ungmemhi ni o tsua ekpabọ oyọli mu agbọ nya mhọli. Abi ọ rọ khuẹsẹ awa olamhẹ-a sẹ, ọ shitọ ukiẹkiẹ obita na Eghiele oyi Ẹshinẹgba ni ọ mhọli ekpabọ ni o funẹ nya.
\s1 Ufumhi oyi Omi Ẹshinẹgba
\p 
\v 4 A ri ọni omiọli fu dọsẹ igẹni abi eva ni Ẹshinẹgba ọ rọ na li o li fu dọsẹ oyẹwẹ.
\p 
\v 5 Agẹni ọnọghuo Ẹshinẹgba ọ tigbe liẹ ọli,
\q1 “Omimhẹ u khi
\q2 amo mhi te khi Itẹ?”
\m Ali ọnọghuo o gbolo ọli;
\q1 “Mhi ya khi Ita ẹ,
\q2 yẹyẹ u khi Omimhẹ?”\f + \fr 1:5 \ft Li zẹ \fq Iwolo 2.7; 2 iSam 7.14; 1 Okhẹ 17.13\f*
\m 
\v 6 Ama abi Ẹshinẹgba ọ rọ ya ghie Omiọli ọghuo kpe je elemhi agbọ, ọọ,
\q1 “Igẹni eyi Ẹshinẹgba nya
\q2 e mema nyẹsẹ ukhomhi ga li.”\f + \fr 1:6 \ft Li zẹ \fq iDẹut 32.43\f*
\m 
\v 7 Abi ọ rọ ọ ngme ingme oyi igẹni, ọọ,
\q1 “Ọ ma igẹni eyọli
\q2 abi akpekpeli,
\q1 ọ ma eni ẹẹ ga eyọli
\q2 abi ẹlẹmhi erẹ.”\f + \fr 1:7 \ft Li zẹ \fq Iwolo 104.4\f*
\m 
\v 8 Ama abi Ẹshinẹgba ọ rọ ọ ngme ingme oyi Omiọli, ọọ,
\q1 “Ẹshinẹgba u khi!
\q2 Omhẹsẹ oyẹ,
\q2 agbọagbọ o ya la ọ.
\q1 Ipfuasẹ ali igẹsikia
\q1 u rọ ya ke mhẹsẹ
\q2 na ẹgbọ eyẹ.
\q1 
\v 9 Ipfuasẹ u nono,
\q2 ingmobe ọa ghọle ẹ,
\q1 irarighọ Ẹshinẹgba u khi!
\q2 Ẹshinẹgba ọyẹ, ọ she rẹ
\q2 fu dọsẹ etu-ẹ,
\q1 itobọ khi ọ ri
\q2 oili oghẹlẹ to ẹ ukhomhi.”\f + \fr 1:9 \ft Li zẹ \fq Iwolo 45.6,7\f*
\m 
\v 10 Ọ gbolo liẹ,
\q1 “Yẹyẹ Ọnọmhuẹ,
\q2 rọte igbaekẹle,
\q1 u te ma agbọ.
\q2 Abọ eyẹ u rọ ma ukhuli.
\q1 
\v 11 Wẹwẹ nya e ya pfua,
\q2 ama yẹyẹ u kiele ẹ la ọ.
\q1 E ya taa abi itsua ni a sọ.
\q1 
\v 12 U khili wẹ abi ide,
\q2 e ya ọghiẹ abi a liẹ
\q2 ọghiẹ itsua ni a sọ.
\q1 Ama abi u li u kiele ẹ li,
\q2 agbọ oyẹ ọa tigbe
\q2 ya mhọli ukpẹsẹ.”\f + \fr 1:12 \ft Li zẹ \fq Iwolo 102.25-27\f*
\m 
\v 13 Agẹni ọnọghuo Ẹshinẹgba ọ tigbe liẹ ọli,
\q1 “Shitọ mhẹ ukiẹkiẹ obita omhẹsẹ,
\q2 ramhi ni mhi rọ ya ri ebe ẹ
\q2 mele ukpẹkhomi akphawẹ-nga oyẹ-a?”\f + \fr 1:13 \ft Li zẹ \fq Iwolo 110.1\f*
\p 
\v 14 Ọa khi iyẹmhẹ eni ẹẹ ga Ẹshinẹgba igẹni nya e khi, ni Ẹshinẹgba ọọ ghie e ke ga eni e ya le ugu imiepfuese?
\c 2
\s1 Ukpokpomhi imiepfuese
\p 
\v 1 Irarighọ a zẹ ni awa lolo mu igẹsikia ni awa suọ mhuẹ, ini a khi tsua awa ibe vu.
\v 2 Irari khi ini usomhi ni igẹni e bhale ya guele, o khi egbegbọ, ni a ya na ẹgbọ ni ẹa rọli gbe akanya osoli to shi;
\v 3 sẹẹ awa li ya pfue oni osoli ona, ini awa ri ẹloe gbe ukpokpomhi imiepfuese oghọghọ ni Ọnọmhuẹ lọlighuo ọ te ododẹ gue le, ni eni e suọ li, e gueyẹ anye khi igẹsikia lọ?
\v 4 Oni usomhi ona ni Ẹshinẹgba ọ gbo ri ọlẹlẹ, ali ikanya ọshabọ ali ọnyaloa ọdọda zẹ ọtsẹlẹ shi, li shi isomhopfa eyi Ayẹmhẹ-nọ-pfuasẹ ni ọ kemhi abi o li ghọle ọli shi.
\s1 IJesu ọ bhale agbọ abi ọgbọ
\p 
\v 5 Ẹshinẹgba ọa ri omhẹsẹ oyi agbọ ni ọọ bhale nga igẹni obọ, ikhi agbọ ni awa ngme ena.
\v 6 Ama, a mhọli ashini a ngme ọli shi elemhi Ebe-no-pfuasẹ, ni ọọ.
\q1 “Elọ ọgbọ fẹ khi,
\q2 ni ingme oyọli o rọ na mu
\q2 yẹyẹ Ẹshinẹgba egbe,
\q1 elọ ọ khi ni u rọ
\q2 lina ri ẹloe ẹ khu ọli?
\q1 
\v 7 U ma li kpọkẹ
\q2 na igẹni dẹnẹ,
\q1 u ri ufumhi
\q2 ali ekpẹ rughu ọli,
\q1 u rọli loghie nga
\q2 emini u ma nya.
\q1 
\v 8 U rọli loghie
\q2 emhi nya.”\f + \fr 2:8 \ft Li zẹ \fq Iwolo 8.4-6\f*
\m Ẹshinẹgba ọ she ri emini ọ ma nya na li ọ rọ ke mhẹsẹ shi. Ọa kẹsẹ emhikhọghuo le ni ọa rọ shi ọli omhẹsẹ. Ama memena, awa aa kie mẹ eni emhi nya pfo ne ni ọ rọ nali ọ ke mhẹsẹ shi.
\v 9 Ama iJesu awa a mẹ, ni a kpẹ ma kpọkẹ na igẹni ukuku ọ dẹnẹ. Ọni a ri ufumhi ali ekpẹ rughu memena itobọ eghuli ni ọ ghu. Ighọ lọ, okhale oyi Ẹshinẹgba o rọli ghu-a na ẹgbọkpa.
\p 
\v 10 Ni Ẹshinẹgba, ni ọ ma emhi nya ni ọ mu wẹ mhọli, ọ mẹ asha ri oni ufumhi ona na ebubu ẹgbọ, ọ rọ ri iJesu khi ọni ọ gba pfo rọte osoli ni ọ mẹ. Irari khi iJesu ọ rẹ ẹgbọ nya bhale imiepfuese.
\p 
\v 11 Ghe ọni ọ ri ẹgbọ pfuasẹ ali eni a rọ pfuasẹ nya, unuẹkpẹ oghuo e ke ga khi. Lọli o zẹ khi omama ọa mu iJesu ni ọ rọ lu wẹ inyọghuo.
\v 12 Ọọ Ẹshinẹgba,
\q1 “Mhi ya gueyẹ
\q1 inyọghuo-mhẹ
\q2 emini u she riẹlẹ,
\q1 Mhi ya la ilegba oyẹwẹ
\q2 to uwolo ikuẹghiẹ oyẹ.”\f + \fr 2:12 \ft Li zẹ \fq Iwolo 22.22\f*
\m 
\v 13 Ọ gbolo ẹ,
\q1 “Mhi ya regbenga
\q2 Ẹshinẹgba.”
\m Ọ gbolo ẹ,
\q1 “Ghe mhẹmhẹ ali eniyẹ
\q2 ni Ẹshinẹgba ọ rọ na mhẹ.”\f + \fr 2:13 \ft Li zẹ \fq Aza 8.17,18\f*
\p 
\v 14 Aborọkhia khi imi Ẹshinẹgba, ẹgbọ ni e zẹ idiegbe ọgbọ ali ọlia e khi, lọli iJesu Omiọli ọ rọ li mele ọgbọ ni ọ mhọli idiegbe ali ọlia-a. Eri ọ lina ini ọ mẹ asha rọte eghuli ni ọ ghu pfuse Ọkphaghiẹ-a ni ọ kpẹ mu ekpabọ oyi eghuli mhuẹ,
\v 15 ni ọ mẹ asha pfuese ẹgbọ ni ulishi eghuli ọọ mu ẹlẹkhẹlẹ.
\v 16 Egbegbọ lọ khi ọa khi igẹni ọ bhale ya kpaghiẹ obọ, ama imimi Aburaamu.\f + \fr 2:16 \ft Li zẹ \fq Aza 41.8-9\f*
\v 17 Itobọ ona a rọ rọli li abi inyọghuo ọli nya odẹkhodẹ. Ni ọ mẹ asha khi Ọkpodalo-ugamhi ọyi Ẹshinẹgba ni ọ kpeda nya, ni ọ mhọli igẹsikia ali ilẹlemhi shi elemhi ugamhi oyi Ẹshinẹgba, ni ọ mẹ asha shishi olamhẹ eyi ẹgbọ-a.
\v 18 Irari khi ọ li mẹ osoli abi a rọ mu ọli fẹ, ọ li dobẹ ẹ kpaghiẹ eni a lili ẹ mufẹ obọ.
\c 3
\s1 IJesu ọ fu dọsẹ iMosisi
\p 
\v 1 Irarighọ, inyọghuo-mhẹ ni Ẹshinẹgba ọ zẹ ni e khi ẹgbọ ni e pfuasẹ eyọli, a sa ingme oyi iJesu ni awa lui aghiusomhi na kẹẹ, ali Ọga ọyi ekpodalo ugamhi nya.
\v 2 Eri ọ ri igẹsikia deba Ẹshinẹgba, ni ọ zẹ ọli ọ ke gbe akanya eyọli, ẹzẹzẹ abi iMosisi ọni ọọ ga ọ li ri igẹsikia gbe akanya elemhi Owa oyi Ẹshinẹgba.\f + \fr 3:2 \ft Li zẹ \fq iNọba 12.7\f*
\v 3 A she mẹ khi iJesu ọ mhuẹ imuẹloe ni o fu dọsẹ oyi iMosisi, ẹzẹzẹ abi atsọna ọ liẹ mhọli imuẹloe ni o fu dọsẹ owa ni ọ tọ.
\v 4 A kie kpẹ lẹsẹ khi ọgbọ ọọ tọ owa kpa, Ẹshinẹgba ọ ma emhikpa.
\v 5 IMosisi ọ khi ọgbọ igẹsikia elemhi Owa oyi Ẹshinẹgba abi ọni ọọ ga. Akanya ni ọ gbe o khi ọtsẹlẹ oyi igẹsikia oyi emini a ya ngme ogbe na akọ.
\v 6 Ama iKirisiti ọ khi Omi Ẹshinẹgba ni ọ mhẹsẹ ẹ shi Owa ugamhi oyọli. Owa oyọli awa khi ini awa da kie mu igbedu ali irudushi oyawa ni awa regbenga mhuẹ ne.
\s1 Iyẹmhẹa ni a rọ na Ẹgbọ eyi Ẹshinẹgba
\p 
\v 7 Irarighọ, abi Ayẹmhẹ-nọ-pfuasẹ ọ ngme, ni ọọ,
\q1 “A kha suọ uruli
\q2 oyi Ẹshinẹgba amo,
\q2 
\v 8 a khi zese udu-a,
\q1 abi eni e bia ẹ e li
\q2 ẹghẹghẹ ni e rọ ọ riẹlẹ
\q2 umha-suesọ deba Ẹshinẹgba.
\q1 Ẹghẹghẹ ni a rọ la
\q2 ọdagbe ifufu mu wẹ fẹ,
\q1 
\v 9 ikhi obini ita ẹ e la
\q2 mu mhẹ fẹ, mhẹsẹ mhẹ bino,
\q1 e mẹ emini mhi riẹlẹ
\q2 elemhi ikpe egbhuẹva
\q1 
\v 10 Lọli o zẹ ni elemhi e rọ bi mhẹ
\q2 deba oni agbhotu oghọ,
\q1 ni mhi rọ liẹ, ‘Ẹghẹghẹ kpa
\q2 udu oyẹwẹ o rọ rẹwẹ lo ebuli,
\q2 ẹa lẹsẹ odẹ eyẹmhẹ.’
\q1 
\v 11 Irarighọ, mhi rọ ri
\q2 elemhi-ibibi shi-ẹmuẹ liẹ,
\q2 ‘Ẹa ya tigbe lo
\q2 iyẹmhẹa oyẹmhẹ.’ ”\f + \fr 3:11 \ft Li zẹ \fq Iwolo 95.7-11\f*
\p 
\v 12 Inyọghuo, a mu egbe ẹ ini ọngẹ ẹ ọ khi mhọli udu umha-miesuọ, ni ọ ya lase odẹ oyi Ẹshinẹgba ni ọ la ọ le.
\v 13 Ochoghọ a ke ye egbe ẹ ude, itobọ khi, “Amo.” Oni ẹghẹghẹ o kie la ọ, ni a rọ ọ mu pfi, ini udimhi ni olamhẹ ọọ di ọgbọ o khi ri ọngẹ ẹ zese udu-a.
\v 14 Eni e kuma iKirisiti ọ awa khi ini awa lolo mu igbedu ni awa rọte ekẹ mhọli mhuẹ ya ramhi ukpẹsẹ.
\v 15 Abi Ebe-no-pfuasẹ o ngme.
\q1 “Ini u suọ uruli
\q2 oyi Ẹshinẹgba amo,
\q2 a khi zese udu-a,
\q1 abi eni e bia ẹ e li
\q2 ẹghẹghẹ ni e rọ ọ riẹlẹ
\q2 umha-suesọ deba Ẹshinẹgba.”\f + \fr 3:15 \ft Li zẹ \fq Iwolo 95.7-8\f*
\p 
\v 16 Eghuo e khi eni ẹgbọ ni e suọ uruli oyi Ẹshinẹgba ni e riẹlẹ umha suọ esọ deba li? Ọa khi eni iMosisi ọ rọte ekẹ iJipiti rue lasele?
\v 17 Eghuo ọ biselemhi deba ikpe egbhuẹva? Ọa khi eni e lamhẹ, ni e ghuloa shi ọdagbe ifufu?
\v 18 Eghuo Ẹshinẹgba ọ shi ẹmuẹ deba khi ẹa ya tigbe lo iyẹmhẹa, ọa khi eni ẹa suọ esọ na li?\f + \fr 3:18 \ft Li zẹ \fq iNọba 14.1-35\f*
\v 19 Irarighọ, awa mẹ khi itobọ umha-miesuọ oyẹwẹ ẹa rọ dobẹ lo.
\c 4
\s1 Iyẹmhẹa ni a shobọ na ẹgbọ eyi Ẹshinẹgba
\p 
\v 1 Aborọkhia khi ishobọ ni awa rọ ya lo iyẹmhẹa khi o kie la ọ, awa mu egbe awa ini o khi de ongẹ ẹ obọ-a.
\v 2 Awa she li suọ oni usomhi onete abi wẹwẹ e ke li suọ ọli. Ama oni usomhi ọa mu wẹ ẹloe irari khi ẹa ri irudunga mie ọli.
\v 3 Awa ni awa mhuẹ irudunga, awa ya lo oni iyẹmhẹa. Ama eni ẹa miesuọ, Ẹshinẹgba ọọ liẹ
\q1 “Elemhi ibibi
\q2 mhi rọ shi-ẹmuẹ,
\q1 khi ‘Ẹa ya tigbe lo
\q2 asha iyẹmhẹa oyẹmhẹ.’ ”
\p Aboriẹkhia rọte abi ọ te ma agbọ ọ te riẹlẹ oni iyẹmhẹa ona shi ekẹ.\f + \fr 4:3 \ft Li zẹ \fq Iwolo 95.11\f*
\v 4 A ngme na shi Ebe-no-pfuasẹ abi ọ rọ ngme ingme ogbẹlẹ onuzi-ishilua khi, “Ẹshinẹgba ọ yẹmhẹ ikanya-a nya-a ẹlẹnizu-ishilua.”\f + \fr 4:4 \ft Li zẹ \fq Igbae 2.2\f*
\v 5 A gbo ngme oni ingme onana khi. “Ẹa tigbe ya lo iyẹmhẹa oyẹmhẹ.”\f + \fr 4:5 \ft Li zẹ \fq Iwolo 95.11\f*
\p 
\v 6 Elese e laọ ni a ya ri ẹghẹghẹ na ni e rọ lo oni iyẹmhẹa. Irari khi eni e kpẹ suọ oni Usomhi Onete ẹa lo oni iyẹmhẹa oghọ, itobọ khi ẹa miesuọ.
\v 7 Irarighọ, Ẹshinẹgba ọ rọ gbo ri ẹlẹlese shi ekẹ ni a rọ ya lo iyẹmhẹa oyọli, ni ọ lu Amo. Ẹzẹzẹ abi ọ rọte unu oyi iDefidi ngme ọli ẹlẹlese abi a kpẹ li ngme ọli, ni ọọ:
\q1 “A kha suọ uruli oyọli Amo,
\q2 a khi zese udu-a.”\f + \fr 4:7 \ft Li zẹ \fq Iwolo 95.7-8\f*
\p 
\v 8 Ini iJoshua ọ̀ọ́ ri iyẹmhẹa na wẹ lọ, Ẹshinẹgba ọa kha gbo te ikpukhokho ri ogbẹlẹ olese shi ekẹ na wẹ.\f + \fr 4:8 \ft Li zẹ \fq iDẹut 31.7; iJosh 22.4\f*
\v 9 Abi o li ena, Ogbẹlẹ iyẹmhẹa o kie la ọ, ni ẹgbọ eyi Ẹshinẹgba e la yẹmhẹ-a
\v 10 Itobọ khi ọni ọ da lo iyẹmhẹa oyi Ẹshinẹgba ne, eri ọ li yẹmhẹ ikanya eyọli-a, abi Ẹshinẹgba ọ li yẹmhẹ eyọli-a.\f + \fr 4:10 \ft Li zẹ \fq Igbae 2.2\f*
\v 11 Irarighọ, awa rọshẹka ini awa dobẹ lo oni iyẹmhẹa oghọ, ini awa khi de itobọ khi awa khọnya wẹ riẹlẹ umha-suesọ.
\p 
\v 12 Irari khi eri ungmemhi oyi Ẹshinẹgba o mhọli agbọ, ọ́ọ́ gbe akanya. Ò mu dọsẹ itakobi ọzalo eva kpa, ni ọ́ọ́ gbese lo ọgbọ udu, o khueghie ọli-a, ni ọọ guanọ emini e la usamhi ali ayẹmhẹ, o gbo li gbese lo ikpẹ́sẹ́ ali ikhọ̀rọ̀ na elemhi igua. O dobẹ ẹ khueghie ingeli ali isamhi na ekelemhi udu-a.
\v 13 Emhikhọghuo ọa la emini a ma nya ni o sheli shi ọli ọ. Eri emhikpa e na khueghie-a shi ukpẹloe oyi Ẹshinẹgba, ikhi ọni awa ya ri abọ khasẹ abi awa li gbe.
\s1 IJesu ọ khi Ọga Ọkpodalo-ugamhi Ọniẹmhi ọyawa
\p 
\v 14 Irarighọ, a zẹ ni awa lolo mu irudunga ni awa mhọli mhuẹ, abi o rọ da khia khi awa mhọli Ọga ọyi ekpodalo ugamhi ni ọ Funẹ ni ọ she je odalo oyi Ẹshinẹgba. Lọli ọ khi iJesu Omi Ẹshinẹgba.\fig Ọga oyi ekpodalo ugamhi|src="hk00267c.tif" size="col" loc="HEB 4.14" copy="TIF" ref="4.14"\fig*
\v 15 Ọa khi Ọga ọyi ekpodalo ugamhi ni ọa ya lẹlemhi awa shi emini awa dọ-a riẹlẹ. Ama ọni a she mu fẹ abi awa, odẹkhodẹ ọ khi, ama ọa tigbe lamhẹ.
\v 16 A zẹ ni awa ri igbedu ti deba Ẹshinẹgba ni ọ mhọli isomhelemhi. Aghọ awa te ya mie ilẹlemhi ali isomhelemhi ni o ya kpaghiẹ awa obọ ẹghẹghẹ ni awa rọ ọ nono ikpaghiobọ.
\c 5
\p 
\v 1 Ọga ọyi ekpodalo ugamhi, ni a da rọte elemhi ẹgbọ zẹ kpa, eri a zẹ ọli ni ọ ke migha na wẹ ingme ugamhi eyi Ẹshinẹgba. Ni ọ ke riẹlẹ irọna ali iluasobo na wẹ shi olamhẹ eyẹwẹ.
\v 2 Ọfiẹ ọ rọọ deba eni ẹa lẹsẹ emini aa li, ni ẹẹ da odẹ, itobọ khi lọli ọ li mhọli odẹ ni ọa te li gba pfo.
\v 3 Onana o zẹ khi egbọli ọ kpẹ luasobo a na shi olamhẹ eyọli, neni ọ luasẹ na ẹgbọ nya shi olamhẹ oyẹwẹ.\f + \fr 5:3 \ft Li zẹ \fq iLẹv 9.7\f*
\v 4 Ọgbọkhọghuo, ọa ya rue oni okhale ona ni a rọ lu ọgbọ shi Ọga ọyi ekpodalo ugamhi. Ẹshinẹgba lọlighuo tsẹ ọọ lu ọgbọ, ọ rọli khi Ọga ọyi ekpodalo ugamhi, ẹzẹzẹ abi a li lu Erọni.\f + \fr 5:4 \ft Li zẹ \fq Okiali 28.1\f*
\p 
\v 5 Ighọ iKirisiti ọa li mie oni okhale rọ lu egbọli Ọga ọyi ekpodalo ugamhi. Ama Ẹshinẹgba ọọ li,
\q1 “Omimhẹ u khi,
\q2 Amo mhi te khi Itẹ.”\f + \fr 5:5 \ft Li zẹ \fq Iwolo 2.7\f*
\m 
\v 6 Ọ gbo ngme ọli shi ashese,
\q1 “Ọkpodalo-ugamhi ọyi Ẹshinẹgba
\q2 u khi agbọagbọ,
\q2 ẹzẹzẹ ọnabi iMẹkizẹdẹki.”\f + \fr 5:6 \ft Li zẹ \fq Iwolo 110.4\f*
\p 
\v 7 Abi iJesu ọ rọ la agbọ, atsẹsẹ ali iku-amẹ-eviẹ alo iJesu ọ rọọ sọ iromhi lema Ẹshinẹgba, ọni ọ kha tsumhi ọli obọ eghuli. Itobọ khi eri ọ ri egbọli tiemhile, ri egbọli na Ẹshinẹgba pfo, lọli ọ rọ suọ iromhi eyọli.\f + \fr 5:7 \ft Li zẹ \fq iMat 26.36-46; iMak 14.32-42; iLuk 22.39-46\f*
\v 8 Abi o riẹ khia khi Omi Ẹshinẹgba ọ khi, osoli ni ọ mẹ, o rọli wẹna isuesọ na Ẹshinẹgba.
\v 9 Abi a rọ rọli gba pfo se, obọ oyọli eni e suọ esọ nali e ke rọte mhọli imiepfuese na agbọagbọ.
\v 10 Ẹshinẹgba ọ zẹ ọli Ọga ọyi ekpodalo ugamhi, ọnabi iMẹkizẹdẹki.
\s1 Ọgbọ khi pfi irudunga ona shi ekẹ
\p 
\v 11 Emhi ebubu e la ọ ni awa ya ngme shi eni ingme enana, ama o ma a munu ni a rọ zọlọ wẹ-a lo ẹ esọ, itobọ khi aa mhọli ọghuẹmhẹ ni a rọ suọ.
\v 12 Abi o riẹ khia khi a she ramhi eni ẹẹ esẹsẹ ẹgbọẹse, ni a rọ kie khi eni a sẹsẹ owẹna eni ododẹ eyi ingme Ẹshinẹgba eghọ, ẹnyeli o ti ẹ egbe a tẹ eminale ni o toto ne.
\v 13 Ọnini ọ da kiele ẹ nye ẹnyeli ne, eri ọ li abi ọmọ ni ọa lolo mhọli ilẹsẹ shi osẹsẹ iguẹ-ngeli.\f + \fr 5:13 \ft Li zẹ \fq 1 iKọri 3.2\f*
\v 14 Ama eminale ni e toto, eni e womhẹ ẹloe ẹẹ le. Ikhi eni e ri itobọ eni eminale ni e toto ni ẹẹ le ẹghẹghẹ kpa lẹsẹ ikhiọda shi emini o migha shi onete ali onobe.
\c 6
\p 
\v 1 Irarighọ, a zẹ ni awa je odalo shi osẹsẹ ni e womhẹloe ni awa pfi osẹsẹ ni a rọ gba ingme eyi iKirisiti ekẹ le. Awa khi ke gbo tiemhi ekẹ je osẹsẹ ena imupfi rọte ikanya ebe lasele, ali osẹsẹ ena irudunga Ẹshinẹgba,
\v 2 ali osẹsẹ ibatizi, ali irobọ-nga ọgbọ egbe, ali irọte eghuli guale oyi eni e ghua, ali osẹsẹ oyi iguẹzọ ni ọgbọ la je obini ọ ya la agbọagbọ.
\v 3 O kha ghọle Ẹshinẹgba awa ya je odalo elemhi owẹna.
\p 
\v 4-6 Ẹgbọ ni e she kpe mẹ ákpá, ni e she kpẹ mie isomhopfa oyi iloghie ghue, ni e kpẹ mie Ayẹmhẹ-nọ-pfuasẹ, ni e she lẹsẹ onete ni o la ungmemhi oyi Ẹshinẹgba ali ekpabọ oyi agbọ ni ọọ bhale, ni e tigbe tsua irudunga oyẹwẹ pfia, ọa ke zẹ ẹ riẹlẹ ni a dobẹ nyenẹ wẹ gbolo bhale imiesuọ, aborọkhia khi eri e she gbolo ta Omi Ẹshinẹgba ma apfida utonuzi-eva, ri omama mu ọli gboo.
\p 
\v 7 Eri awa ẹgbọ awa li abi ekẹ. Ini amẹ o ruẹ shi ekẹ ni emhi ẹkọmhi e rọ zẹ na ọghiale, ikhivọsẹ oyi Ẹshinẹgba o khi.
\v 8 Ama ini o zẹ igba ali ebuli-a, ọgbọ ọa mhọli emini a rọli ya riẹlẹ, o ya la okhẹna ipfiunu-a oyi Ẹshinẹgba ali khi a ya ri erali tosẹ ọli-a.\f + \fr 6:8 \ft Li zẹ \fq Igbae 3.17-18\f*
\p 
\v 9 Emọle mhẹ, ini anye riẹ lina a ngme i, anye lẹsẹ khi ọa khi ẹ ẹ o nu ngme, anye lẹsẹ gboo khi emini e ti egbegbọ a riẹlẹ, enabi ẹgbọ ẹẹ riẹlẹ ini a mie wẹ ẹ pfuese.
\v 10 Ẹshinẹgba ọa ya gbe ọgbọ azẹba. Ọa ya yele ikanya ni u gbe-a ali inono ni u rọkhasẹ khi u nono ọli abi u li ri ikpaghiobọ na ẹgbọ eyọli ni u kiele ẹ kpaghiẹ wẹ.
\v 11 Anye ẹ nono ni ọgbọgbọ ọ mu ọmuegbe ni ọ mhọli mhuẹ ya ramhi ukpẹsẹ, ni ọ rọkhasẹ abi irudushi oyọli o toto ramhi.
\v 12 Anye ẹa nono ni a mele ewaza-a, ama ni a ke khọnya eni e rọte irudunga ali irobọmudu mie ishobọ oyi Ẹshinẹgba.
\s1 Ekha oyi Ẹshinẹgba ọa ya fiakua
\p 
\v 13 Abi Ẹshinẹgba ọ rọ tse ekha na Aburaamu, Ẹshinẹgba ọ romhi egbọli aborọkhia khi ọgbọẹse ọa ke gbo fu dọsẹ ọli ni ọ ke ya romhi.
\v 14 Ọọ li, “Mhi mema ya khi vọsẹ nẹ, mhi ya rẹ mhọli eniyẹ ali imi-imi ni e bu.”\f + \fr 6:14 \ft Li zẹ \fq Igbae 22.16-17\f*
\v 15 Aburaamu ọ ri abọ mu udu, irarighọ ọ mẹ emini Ẹshinẹgba ọ rọ tsekha nali mie.
\v 16 Ini ọgbọ ọ tse ekha, ọgbọẹse ni o fu dọsẹ ọli ọọ romhi ni o mu oni ekha migha, ẹghẹghẹ akhọkhọmhẹ ọa kẹ la ọ, oni ekha o migha.
\v 17 Eri Ẹshinẹgba ọ romhi isheli rọ rọli khasẹ eni ọ tsẹ ekha na gboo, khi emini lọli rọ tse ekha khi lọli ya riẹlẹ ọli, khi ọa ya fiakua.
\v 18 Irarighọ, Ẹshinẹgba ọ rọ ri emhi eva ena shi ekẹ; ekha ali isheli ni ọ romhi. Eni emhi eva ena ẹa zẹ mupfi irari khi Ẹshinẹgba ọa tigbe ya lo ẹgbhọli ghue. Irarighọ awa ni awa she na deba li shi akhukhu, awa ya mhọli iregbeda abi awa li mu irudushi oyọli ni o la odalo mhuẹ.
\v 19 Eri oni irudushi ona o li abi azu ni o toto ni o migha gbaa, ni ayẹmhẹ oyawa o mhuẹ. Onana o ri awa dobẹ dọsẹ ode ugbakpi ni a rọ pfa odẹ ni o lo ashini o pfuasẹ nẹ nya-a.\f + \fr 6:19 \ft Li zẹ \fq iLẹv 16.2\f*\fig Elemhi Okholo ni o la oni Igholo|src="bk00278c.tif" size="col" loc="HEB 6.19" copy="TIF" ref="6.19"\fig*
\v 20 IJesu ọ she ralo itobọ oyawa, ọ mele Ọga ọyi ekpodalo ugamhi na agbọagbọ-a, ọnabi iMẹkizẹdẹki.\f + \fr 6:20 \ft Li zẹ \fq Iwolo 110.4\f*
\c 7
\s1 IMẹkizẹdẹki ọkpodalo-ugamhi ọyi Ẹshinẹgba
\p 
\v 1 Ọni iMẹkizẹdẹki ọna, oghie ọyi ẹoli iSalẹmu ọ khi, ọ gbo khi ọkpodalo-ugamhi ọnayi Ẹshinẹgba ni ọ Yagha nẹ nya. Abi Aburaamu ọ rọ rọte okhọli ni ọ la gbe ighie okhọli jele, iMẹkizẹdẹki ọ ya ẹẹ ọli odẹ, ọ sọ iromhi khivọsẹ na Aburaamu.
\v 2 Ighọ Aburaamu ọ rọte itsua ni ọ rọte okhọli ti nya zẹ azẹ-oghuo-igbe na li. Emini a ri iMẹkizẹdẹki ngme khi, “Oghie Iguẹ-ngeli,” emini a ri oghie iSalẹmu ngme khi, “Oghie opfọmhẹ.”\f + \fr 7:2 \ft Li zẹ \fq Igbae 14.17-20\f*
\v 3 Ọa mhuẹ ita wẹkhi inyọ, wẹkhi eri ọ mhọli unuẹkpẹ ni ọ te lasele, wẹkhi eri a mhuẹ ashini a kẹkẹ abi a li bia li ali abi ọ li ghu-a shi. Abi Omi Ẹshinẹgba, Ọkpodalo-ugamhi ọyi Ẹshinẹgba na agbọagbọ ọ khi.
\p 
\v 4 Wàá mẹ ashini ọ fu ramhi. Egbegbi Aburaamu ọni ọ gba ushishi ẹgbọ iZirẹni ekẹ le, ọ zẹ azẹ-oghuo-igbe ẹpfue ni ọ tsua rọte okhọli ni ọ ye na li.
\v 5 Eri ushi ọọ Imi iLiva ni e khi ekpodalo-ugamhi eyi Ẹshinẹgba e ke mieno ẹgbọ iZirẹni ni e khi inyọghuo wẹ, azẹ-oghuo-igbe, aboriẹkhia khi imi-imi Aburaamu e ga khi.\f + \fr 7:5 \ft Li zẹ \fq iNọba 18.21\f*
\v 6 IMẹkizẹdẹki ọa khi omi iLiva, ama ọ mie Aburaamu azẹ-oghuo-igbe, sọ iromhi khivọsẹ na li, ikhi ọmọse ni ọ mie ekha ni Ẹshinẹgba ọ shi na li.
\v 7 Akhọkhọmhẹ ọa la ọ khi ọgbọ ọni kpeda, ọọ sọ iromhi ikhivọsẹ na ọni ọ kpọkẹ.
\v 8 Eralo-ugamhi eyi Ẹshinẹgba ni ee mie azẹ-oghuo-igbe, ẹgbọ ni ẹẹ ghu-a e khi. Ama iMẹkizẹdẹki ona ọ fu dọsẹ wẹ nya itobọ khi a gueyẹ awa khi agbọagbọ ọ laọ lẹ.
\v 9 Ọgbọ dobẹ ẹ liẹ khi imi imi iLiva ni ẹẹ mie azẹ-oghuo-igbe, e she li zẹ oni azẹ-oghuo-igbe ona rọte obọ oyi iti-iti itawẹ Aburaamu.
\v 10 Itobọ khi ẹghẹghẹ ni iMẹkizẹdẹki ọ rọ mẹ Aburaamu, iLiva ọ kie la elemhi oyi Aburaamu. Ọgbọ a bia li ne.
\s1 Abi iJesu ali iMẹkizẹdẹki e li khọ egbe
\p 
\v 11 Irari khi ini akanya eghiele ekpodalo-ugamhi eyi Ẹshinẹgba, ni Ushi oyi iMosisi o rọ migha, ni imi imi iLiva ee gbe, o dobẹ ri ọgbọkhọghuo gba pfo lọ, aa kha ke gbo ri ọkpodalo-ugamhi ọyi Ẹshinẹgba ọlese lasele, ọni ọ li abi iMẹkizẹdẹki, ni ọa khi unuẹkpẹ oyi iLiva wẹkhi oyi Erọni.
\v 12 Irari khi ini a mu eghiele ona ekpodalo-ugamhi eyi Ẹshinẹgba pfi, a mema li ya mu ushi pfi.
\v 13 Ọnọmhuẹ ọyawa ni a ngme ingme oyọli ena, ẹdẹli olese ọ te lasele. Ọgbọkhọghuo ọa rọte oni ẹdẹli oyọli gbe akanya ọkpodalo-ugamhi ọyi Ẹshinẹgba ukhomhi atẹtẹ ghue.
\v 14 Awa ga lẹsẹ gboo khi Ọnọmhuẹ, ẹdẹli iJuda ọ te lasele. IMosisi ọa teva oni ẹdẹli abi ọ rọ ọ ngme ungmemhi oyi ekpodalo-ugamhi eyi Ẹshinẹgba.
\p 
\v 15 Ibhale ni ọkpodalo-ugamhi ọyi Ẹshinẹgba ọlese ni ọ li abi iMẹkizẹdẹki ọ bhale, o rọkhasẹ gboo khi ushi oyi Ẹshinẹgba o she mu pfi.
\v 16 Ọa khi itobọ khi ọ rọte ẹdẹli oyi iLiva lasele abi ushi ọọ a ke li, lọli a rọ zẹ ọli ọkpodalo-ugamhi ọyi Ẹshinẹgba, ama itobọ khi lọli ọ mhọli ekpabọ ni ọ rọ ọ la agbọ agbọagbọ.
\v 17 Itobọ khi Ebe-no-pfuasẹ o ngme ọli khi,
\q1 “Ọkpodalo-ugamhi
\q2 ọyi Ẹshinẹgba
\q2 ẹlẹ na agbọagbọ u khi,
\q2 ọnabi iMẹkizẹdẹki.”\f + \fr 7:17 \ft Li zẹ \fq Iwolo 110.4\f*
\m 
\v 18 Eri a ri obọ gbe ushi oni ẹlẹlẹ nyẹ, itobọ khi ọa mhọli ekpabọ wẹkhi eri o gbe akanya.
\v 19 Irari khi Ushi oyi iMosisi ọa dobẹ ri emhikhọghuo gba pfo. Memena irudushi oni o ti nẹ a ke rọ na awa, ni o ri awa dobẹ ti bhale mama Ẹshinẹgba.
\p 
\v 20 Ẹshinẹgba ọ gbo romhi ishe ma ọ khi iKirisiti khi ọkpodalo-ugamhi ọyi Ẹshinẹgba ọ ya khi agbọagbọ. Ọa romhi isheli abi a rọ ri ẹgbọẹse ya le oghie ekpodalo-ugamhi eyi Ẹshinẹgba.
\v 21 IJesu tsẹ a romhi isheli rọ le eghie abi Ẹshinẹgba ọ rẹ.
\q1 “Mhẹmhẹ Ọnọmhuẹ
\q2 mhi she shi-ẹmuẹ, khi
\q1 ‘Ọkpodalo-ugamhi ọyi Ẹshinẹgba
\q2 u ya khi agbọagbọ.
\q2 Mhi aa ya da ọ ghue.’ ”\f + \fr 7:21 \ft Li zẹ \fq Iwolo 110.4\f*
\m 
\v 22 Itobọ oni ẹmuẹ ni Ẹshinẹgba ọ shi, iJesu ọ rọ khili oni iregbenga ni ọ ri awa mhọli ishobọ onogbọ ni o tinẹ.
\p 
\v 23 Ikhiọda olese ni o gbo la akaghọ khi, ekpodalo-ugamhi eyi Ẹshinẹgba ebubu elese e la ọ ẹghẹghẹ ishobọ onodiọ. Ẹghẹghẹ aghọ ini ọkpodalo-ugamhi ọyi Ẹshinẹgba ọ ghua, ọlese ọ to ẹlolo ọli.
\v 24 Ama eri iJesu ọ la ọ agbọ lẹ agbọagbọ, akanya ọkpodalo-ugamhi ọyi Ẹshinẹgba oyọli, eri o migha agbọagbọ ni ọa zẹ ẹ kpe na ọgbọẹse.
\v 25 Irarighọ, ọ dobẹ ya tsumhi eni e ri eva oyọli bhale deba Ẹshinẹgba zeghele. Itobọ khi eri ọ la ọ agbọagbọ, ọọ lema na wẹ.
\p 
\v 26 IJesu ọ khi ọni Ọkpodalo-ugamhi ọyi Ẹshinẹgba ni ọ kpeda, ni ọ ri emini awa nono na awa. Ọni ọ pfuasẹ ọ khi, ọa mhọli umhaguẹkia wẹkhi olamhẹ shi egbe. A she zọlọ li iteva ena olamhẹ lasele, a yasẹ ọli nga yagha dọsẹ idane.
\v 27 Ọa li abi Ega eyi ekpodalo-ugamhi eyi Ẹshinẹgba elese ni e kpẹ luasẹ obọ oyi igbe-olamhẹ kua na egbewẹ ẹlẹkhẹlẹ, neni e tigbe ẹ luasẹ na ẹgbọẹse. Iluasobo oghuo iKirisiti ọ lẹsẹ luasẹ utoghuo kpele shi olamhẹ oyi ẹgbọẹse abi ọ rọ ri egbọli luasobo.\f + \fr 7:27 \ft Li zẹ \fq iLẹv 9.7\f*
\v 28 Ẹgbọ eni mhuẹ ashini o kie kpọ wẹ le shi, Ushi oyi iMosisi oo zẹ shi Ọga ọyi ekpodalo ugamhi, ama ishobọ ni Ẹshinẹgba ọ ri isheli shi, ni o kpe ukhokho bhale khẹ Ushi oyi iMosisi, ọ rọ zẹ Omi Ẹshinẹgba, ni a she rọ khi ọni ọ gba pfo agbọagbọ.\fig Igholo ali okholo ni iMosisi ọ tọ|src="lb00259c.tif" size="col" loc="HEB 7.28" copy="TIF" ref="7.28"\fig*
\c 8
\s1 Ọga ọyi ekpodalo ugamhi ọna Ishobọ onogbọ
\p 
\v 1 Ọzukhomhi emini anye ẹ ngme na. Awa mhọli Ọga ọyi ekpodalo ugamhi, ni ọ shitọ ukiẹkiẹ obita omhẹsẹ oyi Ẹshinẹgba ni ọ mhọli ekpabọ nya na obini iloghie agbọagbọ,\f + \fr 8:1 \ft Li zẹ \fq Iwolo 110.1\f*
\v 2 ni ọọ ga abi Ọga oyi ekpodalo-ugamhi eyi Ẹshinẹgba elemhi Okholo ni a ri ode ghi ni o khi egbegbi igholo ni o la iloghie, oni Ọnọmhuẹ lọlighuo ọ tọ, ni ọa khi abọ eyi ẹgbọ a rọ tọ li.
\p 
\v 3 Eri a zẹ eni e kpeda na ekpodalo-ugamhi eyi Ẹshinẹgba kpa ni e ri isomhopfa ali iluasobo ke luasẹ. Lọli o zẹ khi Ọni ọ kpeda na ekpodalo-ugamhi eyi Ẹshinẹgba oyawa, ọ mema mhọli emini ọ li rọ ya luasẹ.
\v 4 Agbọ ọ kha la lọ, ọa kha fẹ khi ọkpodalo-ugamhi oyi Ẹshinẹgba, aborọkhia khi ekpodalo-ugamhi eyi Ẹshinẹgba ni ẹ deba ushi oyi ẹgbọ iJu e la aghọ eghọ.
\v 5 Okholo ni a ri ide tọ ni e la ga, irọkhọkhọ ali aroro oyi emini e la iloghie e khi. Lọli o zẹ khi abi iMosisi ọ rọ ya tọ oni igholo, khi Ẹshinẹgba ọọ li, “Zobẹ ni a bhale ya ẹ khi abi a li rẹ wẹ khasẹ ukhomhi ute, u li ya riẹlẹ wẹ tee.”\f + \fr 8:5 \ft Li zẹ \fq Okiali 25.40\f*
\v 6 Ama, memena, akanya ọkpodalo-ugamhi ni a rọ na iJesu, o mu ẹloe dọsẹ oni a rọ na ekpodalo-ugamhi enediọ, ẹzẹzẹ abi ishobọ ni ọ migha shi rọ gbe akanya o li mu ẹloe dọsẹ onodiọ, itobọ khi o migha nga irọnga eni e ti nẹ.
\p 
\v 7 Ini ishobọ oni ododẹ ọa mhọli ashini o kpọli le shi lọ, ọgbọ ọa kha ke mhọli emini a ri ishobọ olese ẹ riẹlẹ.
\v 8 Ama Ẹshinẹgba ọ mẹ ashini ẹgbọ eyọli ẹa kie te gba pfo, lọli ọ rẹ.
\q1 “Oni ogbẹlẹ ọọ bhale,
\q2 ni mhi rọ ya shobọ onogbọ
\q1 na ẹgbọ iZirẹni
\q2 ali ẹgbọ iJuda.
\q1 
\v 9 Ọa ya li abi ishobọ
\q2 ni mhi nu iti-itita wẹ shi,
\q1 ogbẹlẹ ni mhi mu wẹ oobọ
\q2 rọte ekẹ iJipiti ya fiẹ.
\q1 Ẹa ri igẹsikia deba
\q2 oni ishobọ ni mhi nu wẹ shi,
\q1 itobọ ighọ mhi rọ
\q2 rue wẹ ẹloe egbe-a.
\q1 
\v 10 Ọnọmhuẹ ọọ,
\q2 ogbẹlẹ ni ọọ bhale,
\q1 Ishobọ ni mhi ya shi
\q2 na ẹgbọ eyi iZirẹni na,
\q1 Mhi ya ri ishi eyẹmhẹ
\q2 shi wẹ isamhi,
\q2 mhi kẹkẹ ọli shi wẹ udu.
\q1 Mhi ya khi Ẹshinẹgba ọyẹwẹ,
\q2 wẹwẹ e khi ẹgbọ eyẹmhẹ.
\q1 
\v 11 Ọngẹwẹ ọa kẹ ke sẹsẹ
\q2 ọnuzava ọyọli, wẹkhi eri
\q1 ọ ya liẹ inyọghuo ọli,
\q2 ‘Lẹsẹ Ẹshinẹgba.’
\q1 Itobọ khi wẹwẹ nya
\q2 e ya lẹsẹ mhẹ,
\q1 rọte ọni ọ kpọkẹ nya
\q2 ya je ọni ọ funẹ nya.
\q1 
\v 12 Mhi ya ri olamhẹ topfa wẹ,
\q2 mhi aa ke gbo ya sato
\q2 ipfidọ oyẹwẹ.”\f + \fr 8:12 \ft Li zẹ \fq iJere 31.31-34\f*
\p 
\v 13 Abi ọ rọ da lu ishobọ onana, “Onogbọ” eghọ, o she ri oni ododẹ mele onodiọ-a. Emini o da mele onodiọ-a ni o she ẹ womhẹ, o kẹlẹ ya kele-a.
\c 9
\s1 Ugamhi na iloghie ali ekẹ agbọ
\p 
\v 1 Ishobọ onododẹ o mhọli ishi ni a rọ ọ ga ugamhi, o gbo mhọli igholo ni a ri ide ghi shi ekẹ agbọ.
\v 2 A tọ okholo ni a ri ide ghi gasẹ shi elemhi oni igholo. Elemhi owa eva e la ọ oni okholo. Elemhi owa ni a kpe ramhi aa lui, Asha no Pfuasẹ. Akaghọ a ri emini a ri ákpá ru ẹ nga shi, ali itebu ni a ri ibulẹdi ni o pfuasẹ ẹ nga.\f + \fr 9:2 \ft Li zẹ \fq Okiali 26.1-30; 25.31-40,23-30\f*
\v 3 Elemhi owa onuzi-eva ni o kpẹ oobọ na ode ugbakpi ni a rọ pfa odẹ-a, a lui Ashini o Pfuasẹ nẹ nya.\f + \fr 9:3 \ft Li zẹ \fq Okiali 26.31-33\f*
\v 4 Aghọ adido igolu ni a la tosẹ ituale afu ẹẹra ni ẹẹ pfie o la. Akpati ishobọ ni a ri igolu ku o li la Ashini o Pfuasẹ nẹ nya. Oni akpati ona, omi utasa igolu o la ọ ni a ri ibulẹdi imana a shi.\f + \fr 9:4 \ft Imana khi eminale ni Ẹshinẹgba ọ rọte idane ruẹsẹ kule abi amẹ na eniyẹ iZirẹni abi e rọ rọte iJipiti vu je ekẹ ishobọ, ni a lu iKena\f* Aghọ a li ri orọkpọ oyi Erọni ni o zẹ ukhuli shi, ali ipẹpẹmhi echẹ eva ni a kẹkẹ ishi shi.\f + \fr 9:4 \ft Eri orọkpọ onayi Erọni ni a ngme ena ni o she khakha o kie zẹ ukhui onogbọ.\f*\f + \fr 9:4 \ft Li zẹ \fq Okiali 30.1-6; 25.10-16; 16.33; iNọba 17.8-10; Okiali 25.16; iDẹut 10.3-5\f*\fig Ilolo igolu ni a rọ tosẹ ituale|src="hk00268c.tif" size="col" loc="HEB 9.4" copy="TIF" ref="9.4"\fig*
\v 5 Ikpeda na oni akpati ona, a ma emhi eva ni e li abi igẹni ni e zẹ ipfua shi, ni e sọ alo ghue ufumhi oyi Ẹshinẹgba. E naghiẹ ipfua eyẹwẹ-a guese ashini a la ri olamhẹ ẹ topfa. Ama ọa khi memena awa ya mẹ ẹghẹghẹ rọ ke tọnọ eni emhi ena nya ramhi udi wẹ pfo.\f + \fr 9:5 \ft Li zẹ \fq Okiali 25.18-22\f*
\p 
\v 6 A kha da she lina ri emhi ọgbọgbọ nya shi ashini a rọli ẹ shi se, lọli eni ẹẹ ralo ugamhi e rọ ọ lo elemhi owa onododẹ ya gbe akanya ọdọda eyẹwẹ ogbẹlẹ kpa.\f + \fr 9:6 \ft Li zẹ \fq iNọba 18.2-6\f*
\v 7 Ama Ọga ọyi ekpodalo ugamhi lọlighuo tsẹ ọ dobẹ ẹ lo elemhi Owa Ni o pfuasẹ nẹ nya ni o la ọ. Utoghuo elemhi ukpe ọ lẹsẹ ẹ lo akaghọ. Ọlia eni ọ rọ luasobo na egbọli ali ẹgbọẹse shi olamhẹ ni e lamhẹ elemhi umhalẹsẹ, ọọ rue ẹ mhọli obọ lo akaghọ.\f + \fr 9:7 \ft Li zẹ \fq iLẹv 16.2-34\f*
\v 8 Eri Ayẹmhẹ-nọ-pfuasẹ ọ ri onana guele khi, ọgbọ ọa khueghie odẹ ni o lo elemhi Owa ni o Pfuasẹ nẹ nya-a, na ọgbọkhọghuo ne, ini okholo onododẹ o kie migha.
\v 9 Eri emhi enana e khi irọkhọkhọ na awa ẹghẹghẹ ana. Emini onana o ngme khi irọna ali iluasobo eyi elamhakọ ni a luasẹ ukpe khi ukpe khi, ẹa dobẹ khuẹsẹ eni e bhale ya ga Ẹshinẹgba udu-a pfuasẹ, rẹwẹ gba pfo.
\v 10 Ingme eminale, ali onyọ ali ikpegbe-a enana e migha shi, ni e khi ushi na ẹlẹlẹ. Eri ushi onana o gbe akanya ramhi ẹghẹghẹ ni Ẹshinẹgba ọ rọ ri ushi onogbọ shi ekẹ.
\s1 Ọlia eyi iJesu
\p 
\v 11 Ama iKirisiti ọ she bhale abi Ọga ọyi ekpodalo ugamhi, ni ọ khi ọyi eminete ni e she bhale. Ọ she lo elemhi Okholo ni a ri ode ghi ni o funẹ oghọ ni o gba pfo, ni o la iloghie, ni ọgbọ ọa ri abọ tọ wẹkhi eri o la ekẹ agbọ.
\v 12 Abi iKirisiti ọ rọte elemhi oni okholo lo oni elemhi Owa ni o Pfuasẹ nẹ nya, ọa rue ọlia eyi elamhi ali ena ya luasẹ obo, ama ọlia eyi lọlighuo ọ rue utoghuo kpele rọ mie ipfashekẹ na agbọagbọ na awa.
\v 13 Eri ọlia eyi elamhi ali ena, ali emuẹ eyi ozele ẹna ni a tosẹ-a, ni áá miatsẹ ku ẹgbọ ni ẹa pfuasẹ, o rẹwẹ khi eni e pfuasẹ idiegbe.\f + \fr 9:13 \ft Li zẹ \fq iLẹv 16.15-16; iNọba 19.9,17-19\f*
\v 14 Sẹẹ ọlia eyi iKirisiti ẹa ke liẹ li dobẹ khuẹsẹ udu oyawa-a pfuasẹ, rọte ikanya ni ẹẹ pfi eghuli. Ikhi ọni ọ rọte ekpabọ Ayẹmhẹ oyi Ẹshinẹgba ri egbọli na Ẹshinẹgba abi iluasobo ni o gba pfo itobọ olamhẹ eyawa-a, ni awa dobẹ ke ga Ẹshinẹgba ni ọ la ọ agbọagbọ.
\v 15 Itobọ ona iKirisiti ọ rọ migha iteva Ẹshinẹgba ali ẹgbọ ri ishobọ onogbọ ona gbe ekẹ, ẹghẹghẹ aghọ ni eni Ẹshinẹgba ọ lu, e li mie ugu na agbọagbọ ni Ẹshinẹgba ọ rọ nga. Onana o ya zẹ li, itobọ khi ọ ghu eghuli ni ọ rọ gbe olamhẹ ni ẹgbọ e lamhẹ ẹghẹghẹ ishobọ onododẹ kua.
\v 16 Ini ọgbọ ọ kẹkẹ shi ekẹ abi a li ya kemhi ugu oyọli se, ni ọ rọ ghua, a mema ya mẹ ọli mẹ gbo khi ọ she ghu-a neni ọgbọkhọghuo ọ ya mẹ emhikhọghuo le ugu.
\v 17 Irari khi emhi afuẹ oni ebe ni a kẹkẹ abi a li ri ugu ya kia o ya khi, ini ọni ọ kẹkẹ ọli ọ da kie la agbọ ne. Ama ini ọ ghu-a se, a rọ tigbe ri ọli ẹ gbe akanya.
\v 18 Ona o zẹ khi ishobọ onododẹ ọa kha zẹ rọ gbe akanya ini ọlia ọa ma ọ lọ.
\v 19 Abi iMosisi ọ rọ zẹ ishi eyi Ẹshinẹgba ye eni ẹgbọ se, ọ rue ọlia eyi ena ali elamhi, ọ ku amẹ shi ọ. Ọ rue uguabọ ọọra ni a khili oolu opfopfo shi, ọ rọli miatsẹ eni ọlia shi oni emini a kẹkẹ ishi nya shi, ọ gbo li miatsẹ ku ẹgbọ nya.
\v 20 Ọọ wẹ, “Ọlia eyi oni ishobọ na, ni Ẹshinẹgba ọọ awa rọ ghuẹ.”\f + \fr 9:20 \ft Li zẹ \fq Okiali 24.6-8\f*
\v 21 Ighọ ọ gbo li miatsẹ eni ọlia shi oni owa ugamhi ali emhi nya ni a rọ la ọ riẹlẹ ugamhi.\f + \fr 9:21 \ft Li zẹ \fq iLẹv 8.15\f*
\v 22 Abi o li, khi, eri ushi ọọ a ri ọlia ri emhi nya khi eni e pfuasẹ, ali khi ini aa li ri ọlia luasẹ, irolamhẹ-topfa ọa la ọ.\f + \fr 9:22 \ft Li zẹ \fq iLẹv 17.11\f*
\p 
\v 23 Owa Oyi Ẹshinẹgba na ekẹ agbọ ni a lina ri ọlia rọ khi oni o pfuasẹ, irọkhọkhọ oyi owa ugamhi na obini iloghie o khi. Ama emini e la obini iloghie, iluasobo oni o tinẹ a mema rọ ya rẹwẹ shi ipfuasẹ.
\v 24 IKirisiti ọa lo elemhi okholo ni a ri ode ghi ni ẹgbọ e ri abọ ma ni o khi irọkhọkhọ eyi egbegbewẹ. Ama iloghie ọ ri ochoghọ ya lo, ni ọ la migha odalo oyi Ẹshinẹgba na awa memena.
\v 25 Wẹkhi eri iKirisiti ọ lo iloghie ya ri egbọli luasobo iti-ingmingmẹ, abi Ọga ọyi ekpodalo ugamhi ọ liẹ tsua ọlia eni ẹa khi eyọli ẹ lo elemhi Owa ni o Pfuasẹ nẹ nya, ukpe-khi-ukpe ya luasẹ.
\v 26 Ighọ ó kha khi lọ́, eri iKirisiti ọ kha mẹ osue iti-ingmingmẹ abi a te ma agbọ. Ama ọa khi ighọ. Eri ọ bhale utoghuo tsẹ abi oni ẹghẹghẹ o rọ gba, ni ọ rọ ri egbọli luasobo rọ rue olamhẹ odẹ-a.
\v 27 Ẹzẹzẹ abi ọgbọ ọ liẹ ghu-a utoghuo tsẹ, ọ kha da ghu-a se, ọ bhale shi iguẹzọ.
\v 28 Ighọ a li ri iKirisiti luasobo utoghuo kpele ni a rọ shishi olamhẹ oyi ebubu ẹgbọ-a. Ọ ya gbo bhale utonuzi-eva. Ọa khi ni ọ rọ gbo tsua olamhẹ, ama ni ọ rọ tsumhi eni e migha a khẹ ọli.\f + \fr 9:28 \ft Li zẹ \fq Aza 53.12\f*
\c 10
\s1 Iluasobo utoghuo kpele oyi iKirisiti
\p 
\v 1 Ugamhi onodiọ ni a ga ẹghẹghẹ Ushi oyi iMosisi, aroro oyi eminete ni ẹ bhale e khi. Ẹa khi wẹwẹ e khi egbegbewẹ wẹ. Eni iluasobo ni a kpẹ luasẹ ẹghẹghẹ aghọ ukpe kpa, ẹa tigbe dobẹ ri ipfuasẹ ni o gba pfo na eni bhale odalo oyi Ẹshinẹgba ya ga ugamhi.
\v 2 Ini eni iluasobo ee dobẹ ri eni ẹgbọ pfuasẹ lọ, a kha yẹmhẹ eni iluasobo a? Irari khi e kha ri eni e bhale ya ga pfuasẹ utoghuo kpele, ni udu oyẹwẹ ọa ke mhọli umhaguẹkia.
\v 3 Ama eri eni iluasobo e yele ẹgbọ olamhẹ eyẹwẹ le ukpe khi ukpe.
\v 4 Irari khi ọlia eyi ena ali elamhi ẹa dobẹ rue olamhẹ odẹ-a.
\p 
\v 5 Irarighọ, abi iKirisiti ọ rọ ya bhale agbọ, ọọ Ẹshinẹgba,
\q1 “Iluasobo ali isomhopfa
\q2 ẹa ghọle ẹ.
\q1 Ama u she ri idiegbe na mhẹ,
\q2 ni mhi ri ungmemhi oyẹ
\q2 gbe akanya.
\q1 
\v 6 Iluasobo eni a tosẹ
\q2 ali iluasobo igbe-olamhẹ kua
\q2 ẹa tigbe ti ẹ ẹloe.
\q1 
\v 7 Ighọ mhi rẹ,
\q1 ‘Ghe mhẹ ana,
\q2 Eri mhi bhale ya riẹlẹ
\q2 ọghuẹmhẹ oyẹ, Ẹshinẹgba.’ ”\f + \fr 10:7 \ft Li zẹ \fq Iwolo 40.6-8\f*
\p 
\v 8 Ọ te ekẹ ya ngme, ọọ, “Iluasobo ali isomhopfa ẹa ghọle ẹ, wẹkhi iluasobo eni a tosẹ ali iluasobo igbe-olamhẹ kua e ghọle ẹ, wẹkhi eri e ti ẹ ẹloe.” Ama khi a lẹsẹ khi eri ushi ọọ a mema lighọ ke riẹlẹ wẹ.
\v 9 Ighọ ọ ke rẹ, “Ghe mhẹ ana Ẹshinẹgba, eri mhi bhale ya riẹlẹ ọghuẹmhẹ oyẹ.” Eri ọ ri obọ ri iluasobo eni ẹlẹlẹ shi ekẹ, ọ ri iluasobo oyi iKirisiti to ẹloli wẹ.
\v 10 Itobọ khi iJesu iKirisiti ọ riẹlẹ ọghuẹmhẹ oyi Ẹshinẹgba, lọli o zẹ ni a rọ ri iluasobo ni ọ ri idiegbe oyọli luasẹ utoghuo kpele khuẹsẹ awa nya olamhẹ-a pfuasẹ.
\p 
\v 11 Ẹlẹkhẹlẹ, ekpodalo-ugamhi eyi Ẹshinẹgba nya e rọ gbe ikanya ugamhi eyẹwẹ, eri e riẹlẹ eni iluasobo gbo riẹlẹ iti ingmi-ingmẹ, ama ẹa tigbe dobẹ rue olamhẹ odẹ-a.\f + \fr 10:11 \ft Li zẹ \fq Okiali 29.38\f*
\v 12 Ama abi iKirisiti, ọni ọkpodalo-ugamhi oyi Ẹshinẹgba ọna, ọ rọ luasobo utoghuo kpele oyi igbe-olamhẹ-kua ni o khi oyi ona agbọagbọkpa, ni ọ rọ shitọ obita oyi Eghiele oyi Ẹshinẹgba.
\v 13 Aghọ ọ ke shitọ migha a khẹ ẹghẹghẹ ni Ẹshinẹgba ọ rọ ya ri ebe ọli mele akphawẹ-nga eyọli-a.\f + \fr 10:13 \ft Li zẹ \fq Iwolo 110.1\f*
\v 14 Irari iluasobo utoghuo kpele ni ọ luasẹ ọ rọ ri ẹgbọ eni ọ rọte olamhẹ pfuasẹ khi eni e pfuasẹ agbọagbọ.
\p 
\v 15 Ayẹmhẹ-nọ-pfuasẹ ọ gbo pfi ọtsẹlẹ shi ona yẹ awa. Oni ododẹ, ọọ,
\q1 
\v 16 “Ishobọ ona mhi ya nu wẹ shi.
\q1 Ọnọmhuẹ ọ ngme ghọ khi,
\q2 oni ẹghẹghẹ oghọ o kha ramhi,
\q1 mhi ya ri ishi eyẹmhẹ shi wẹ udu,
\q2 mhi kẹkẹ ọli shi wẹ ayẹmhẹ.”\f + \fr 10:16 \ft Li zẹ \fq iJere 31.33\f*
\m 
\v 17 Ọ ke gbo rọ ma ọ khi, “Mhi aa ke ya sato olamhẹ ali ikanya ebe eyẹwẹ.”\f + \fr 10:17 \ft Li zẹ \fq iJere 31.34\f*
\v 18 Irarighọ, a kha she da ri ena topfa se, ọgbọ ọa ke gbo mhọli emini a ri iluasobo irue-olamhẹ odẹ-a ya riẹlẹ.
\s1 A zẹ ni awa ti bhale deba Ẹshinẹgba
\p 
\v 19 Irarighọ, inyọghuo-mhẹ, aborọkhia ọlia eyi iJesu e ri igbedu na awa rọ lo Ashini o Pfuasẹ nẹ nya eghọ,
\v 20 ikhi odẹ onogbọ ni o mhọli agbọ, ni o ri awa te ode ugbakpi ni a rọ pfa odẹ-a a dọsẹ.
\v 21 Abi o rọ gbo li khia khi awa mhọli ọkpodalo-ugamhi oyi Ẹshinẹgba ọniẹmhi ni ọọ mhẹsẹ shi Owa ugamhi oyi Ẹshinẹgba na iloghie eghọ,
\v 22 awa ri udu igẹsikia ali irudunga ni o migha gboo ti bhale deba Ẹshinẹgba. Awa gbo mhọli udu ni a ri imiatsẹ ọlia eyi iKirisiti rọ khi ipfuasẹ ni ẹa ke mhọli umhaguẹkia, ali awa mhọli idiegbe ni a ri amẹ khuẹsẹ-a pfuasẹ.\f + \fr 10:22 \ft Li zẹ \fq iLẹv 8.30; Ezik 36.25\f*
\v 23 Awa mu irudushi ni awa guele khi awa mhọli mhuẹ gagaga, irari khi Ẹshinẹgba ni ọ shobọ na awa, ọni a ri egbe ẹ nga ọ khi.
\v 24 Awa ke sa abi awa li ya ke ri udu shi egbe ọ, ni awa ke riẹlẹ inono ali awa gbe ikanya enete.
\v 25 Awa khi ti egbe ilona oyi egbawa je ukhokho, abi ẹgbọ eghuo ẹẹ li, ama, awa totobọ ke ri udu shi egbe ọ, aborọkhia khi u mẹ khi Ogbẹlẹ oyi Ọnọmhuẹ o shi ti ẹ bhale.
\p 
\v 26 Irari khi iluasobo olese ọa ke gbo laọ ni o ya rue olamhẹ odẹ-a, ini awa mema famhi ẹ lamhẹ, ikpukhokho khi a she kpẹ gue oni igẹsikia ye awa ne.
\v 27 Emini ẹgbọ eghọghọ e ke ya shitọ ke khẹ khi iguẹzọ ni o ri ulishi ẹ mu ali erali na biobiobio, ni o ya pfuse eni ẹa ya suọ esọ na Ẹshinẹgba-a.\f + \fr 10:27 \ft Li zẹ \fq Aza 26.11\f*
\v 28 Ọnini ọ da gbe Ushi oyi iMosisi-a, ni a rọ da ri ọli gue ẹzọ, ni ọ rọ da lue ne, ni a rọ mẹ ọtsẹlẹ ẹgbọ aava okekhi aasẹ, eri a gbe ọli-a, ni ọa mhọli ilẹlemhi.\f + \fr 10:28 \ft Li zẹ \fq iDẹut 17.6; 19.15\f*
\v 29 Sẹ u sa khi a kha li nasẹ eni e ri awẹ wu Omi Ẹshinẹgba ekẹ-a, ni e ri ukpẹloe gbe ọlia ni Ẹshinẹgba ọ rọ riẹlẹ ishobọ, ikhi ọlia ni o khuẹsẹ wẹ olamhẹ-a pfuasẹ, ali eni o khia khi eri e zẹ ẹmuẹbe na Ayẹmhẹ Okhale?\f + \fr 10:29 \ft Li zẹ \fq Okiali 24.8\f*
\v 30 Irari khi awa lẹsẹ ọni ọọ, “Mhẹmhẹ mhi ya nasẹ eni e lina ngeli, Mhi ya fali oru,” ali ọni ọ gbolo ẹ, “Ọnọmhuẹ ọ ya ri ẹgbọ eyọli gue ẹzọ.”\f + \fr 10:30 \ft Li zẹ \fq iDẹut 32.35,36\f*
\v 31 Irari khi emhi okhẹna o khi ni ọgbọ ọ rọ ya pfi obọ lo ingme oyi Ẹshinẹgba ni ọ la ọ.
\p 
\v 32 A ke sato ẹghẹghẹ ni a rọ lẹsẹ mie oni ákpá, ni a rọ migha mu imiesuọ oyẹ ẹ mhuẹ, aboriẹkhia khi àá na ẹ ukpokpomhi osoli shi ọ.
\v 33 Isheghuo, eri ẹgbọ e ga la igbaa a pfi itsue manya ẹ, a mu okhọli vule shi ẹ ọ. Isheghuo, a kugbe ẹgbọ elese ni a lighọ mu okhọli vule shi ọ.
\v 34 Elemhi eni e la ọgba ighumha ee ala ẹ. Abi a rọ ri itoto mie ẹ itsua, aa khakọ, a ri oghẹlẹ rue wẹ obọ-a na wẹ, itobọ khi a lẹsẹ khi a mhọli itsua eni e tinẹ ni e ya la ọ agbọagbọ.
\p 
\v 35 A khi tsua igbedu oyẹẹ pfia, irari khi o ma mhọli eleli oniẹmhi.
\v 36 A mhọli iregbemie, ni a bhale ya ẹ khi ini a dobẹ riẹlẹ ọghuẹmhẹ oyi Ẹshinẹgba se, ni a mie emini ọ rọ nga na ẹ.
\v 37 Irari khi Ebe-no-pfuasẹ o ngme ọli khi,
\q1 “Ini o riẹ tẹsẹ ukukuọ,
\q2 Ọni ọ ya bhale ọ ya bhale,
\q2 ọa ya tẹsẹ.
\q1 
\v 38 Ama eni Ẹshinẹgba ọ pfa na,
\q2 irudunga e rọ ya ke la agbọ,
\q2 ama ini ọngẹwẹ ọ nyenẹ egbe ukhokho,
\q2 elemhi ẹa ya timhẹ deba li.”\f + \fr 10:38 \ft Li zẹ \fq Abak 2.3-4\f*
\m 
\v 39 Awa aa li abi eni ẹẹ nyenẹ egbe ukhokho ni e ya pfua, ama eni e miesuọ ni a mie pfuese awa khi.
\c 11
\s1 Irudunga
\p 
\v 1 Mena, irudunga khi, ini ọgbọ ọa mhọli akhọkhọmhẹ shi udu shi emini ọ ri udu shi ekẹ ẹ khẹ, ali ni ọgbọ rọ mhọli ọli shi udu guẹguẹguẹ khi emini aa mẹ ne khi e la aghọ.
\v 2 Irudunga ona, o ri ẹgbọ enẹdẹ le eva onete odalo oyi Ẹshinẹgba.
\p 
\v 3 Awa lẹsẹ khi irudunga ona, Ẹshinẹgba ọ rọ ri ungmemhi oyọli ma emini awa mẹ ẹloe nya. Ni a rọ bhale ya ẹ khi, a rọte emini aa ya mẹ ẹloe riẹlẹ emini a mẹ ẹloe.\f + \fr 11:3 \ft Li zẹ \fq Igbae 1.1; Iwolo 33.6,9; iJọn 1.3\f*
\v 4 Irudunga, o ri Ebẹli ri iluasobo ni e ti dọsẹ eyi iKeni na Ẹshinẹgba. Rọte irudunga oyọli, Ẹshinẹgba ọ rọ mie obọ shi ọ khi ọgbọ ni ọ mhọli angeli onete ọ khi, abi Ẹshinẹgba ọ rọ ngme onete irọna eyọli. Irudunga ona o ri Ebẹli kiele ngme, abi ọ rọ ririẹ ghua.\f + \fr 11:4 \ft Li zẹ \fq Igbae 4.3-10\f*
\p 
\v 5 Irudunga a rọ rue Enọki agbọ vu, ini ọ khi mẹ eghuli. Ọgbọ ọa ke mẹ ọli, irari khi eri Ẹshinẹgba ọ rue ọli nga idane. Neni a rue ọli vu, ọ mhọli ọtsẹlẹ khi ọgbọ ni ọ ri egbe mu Ẹshinẹgba ọ khi.\f + \fr 11:5 \ft Li zẹ \fq Igbae 5.21-24\f*
\v 6 Ọgbọkhọghuo ọa dobẹ ya riẹlẹ emini e ri egbe ẹ mu Ẹshinẹgba, ini ọa mhọli irudunga. Irari khi neni ọgbọ ọ́ ya bhale deba Ẹshinẹgba, ọ mema mhọli irudunga khi ọ la aghọ, khi lọli ọ somhi eni e kuegbe-a nono ọli opfa.
\p 
\v 7 Irudunga o ri iNoa, abi ọ rọ suọ agua ni Ẹshinẹgba ọ tse ye ọli shi emini aa mẹ ne, rọli ri ikuegbe-a ali ulishi oyi Ẹshinẹgba, khali ọkọ-okẹ oniẹmhi ni o pfuese apfẹ ọli. Irudunga oyọli o ri umha miesuọ oyi eni ẹgbọ na agbọ khasẹ gboo, ni ọ rọ mie ikhivọsẹ itobọ khi irudunga oyọli o ti Ẹshinẹgba ẹloe.\f + \fr 11:7 \ft Li zẹ \fq Igbae 6.13-22\f*
\v 8 Irudunga o ri Aburaamu vule abi Ẹshinẹgba ọ rọ lu ọli ọ vule ke je ashini lọli shobọ khi lọli rọ ya na li le ugu. Ọ rọte ekẹ oyọli vu, abi otseku khia khi ọa lẹsẹ obini ọọ je.\f + \fr 11:8 \ft Li zẹ \fq Igbae 12.1-5\f*
\v 9 Irudunga o rọli ngeli ekẹ ishobọ abi ọpfẹse. Ọọ la ifui okholo, ighọ li khi Aziki ali iGiekọpu, ni e ga le ugu oni ekha oghuo.\f + \fr 11:9 \ft Li zẹ \fq Igbae 35.27\f*
\v 10 Irari khi eri ọ ri ẹloe shi ekẹ khẹ ẹoli oni o mhọli irọgbekẹ, ni Ẹshinẹgba ọ vi ali ni ọ gbo khi atsọna oyọli.
\v 11 Irari irudunga a rọ ri Aburaamu dobẹ khi ita eniyẹ abi ọ rọ ririẹ rọ she dọsẹ oni ẹghẹghẹ ni ọ kha la dobẹ bia ọmọ ali ni iSera ọ rọ khi aga. Irari khi ọ lẹsẹ khi Ẹshinẹgba ni ọ shobọ nali khi ọna igẹsikia ọ khi lọ.\f + \fr 11:11 \ft Li zẹ \fq Igbae 18.11-14; 21.2\f*
\v 12 Rọte obọ oyi Aburaamu, ni ọ li abi ọni oyọli o she pfo se, a te mẹ imimi ni ẹa zẹ leli abi ikpẹtata na idane ali ekhashẹ na esẹ okẹ oniẹmhi.\f + \fr 11:12 \ft Li zẹ \fq Igbae 15.5; 22.17; 32.12\f*
\p 
\v 13 Agbọ irudunga ẹgbọ ena e kie la ramhi ni e rọ ghua. E kie miesuọ khi wẹwẹ e ya mie emini a rọ shobọ na wẹ. Eri e lẹsẹ li rọte odonuẹ pfi alo o mẹ wẹ odalo, o ri egbe mu wẹ. E lama shi ọ khi ena ẹoli oboese ali epfẹse wẹwẹ e khi shi elemhi ekẹ agbọ.\f + \fr 11:13 \ft Li zẹ \fq Igbae 23.4; 1 Okhẹ 29.15; Iwolo 39.12\f*
\v 14 Ini ẹgbọ e da lina ngme ne, eri o rọkhasẹ khi ẹoli oni e ya ke lu oyẹwẹ ẹẹ nono.
\v 15 Ini eri ẹoli ni e rọte vu kha o la wẹ udu lọ, e kha mhọli ẹghẹghẹ rọ mu egbe pfi je obini e te vu.
\v 16 Eri ẹoli ni o tinẹ o ri okiamhi i gbe wẹ, oni o khi ona iloghie. Irarighọ, ọa ri omama mu Ẹshinẹgba khi ee lu luẹ Ẹshinẹgba ọyẹwẹ, irari khi ọ she mu egbe ẹoli shi ekẹ khẹ wẹ.
\v 17 Irudunga o ri Aburaamu ri Aziki luasobo, abi Ẹshinẹgba ọ rọ mu ọli fẹ bino. Lọli ni ọ she mie oni ekha, ọọ nono ni lọli ri omi ọli ọtuọghuo kpe luasobo,\f + \fr 11:17 \ft Li zẹ \fq Igbae 22.1-14\f*
\v 18 aboriẹkhia khi Ẹshinẹgba ọ gueyẹ ọli khi, “Rọte Aziki u te ya mhọli imi imi ẹ.”\f + \fr 11:18 \ft Li zẹ \fq Igbae 21.12\f*
\v 19 Eri Aburaamu ọ sa li shi udu khi Ẹshinẹgba ọ dobẹ ya rọte eghuli guise ọgbọ le. Eri o li abinẹ khi eri ọni Aziki ọ ghu-a eghọ, ni o rọ li abinẹ khi eri Aburaamu ọ rọte eghuli gbo mie Aziki.
\p 
\v 20 Irudunga o ri Aziki ku isẹmhẹ na iGiekọpu ali iSọ shi emini a ya mẹ odalo.\f + \fr 11:20 \ft Li zẹ \fq Igbae 27.27-29,39-40\f*
\p 
\v 21 Irudunga o ri iGiekọpu abi ọ rọ ya ghu-a sọ iromhi na imi iJosẹfu ava-ava, ọ da abọ na Ẹshinẹgba abi ọ li kie ri egbe da orọkpọ oyọli.\f + \fr 11:21 \ft Li zẹ \fq Igbae 47.31; 48.1-20\f*
\p 
\v 22 Irudunga o ri iJosẹfu, abi ọ rọ ya ghu-a ngme ingme abi eniyẹ iZirẹni e li rọte ekẹ iJipiti ya vu shi ekẹ. Ọ guele shi ekẹ abi a ya li igua eyẹluẹ.\f + \fr 11:22 \ft Li zẹ \fq Igbae 50.24-25; Okiali 13.19\f*
\p 
\v 23 Irudunga o ri eni e bia iMosisi rọli sheli ramhi iki esẹ abi a rọ bia li se, irari khi ọa khi ọmọ na tsẹ, ulishi ọa mu wẹ ni e rọ ri ukpẹloe gbe omhẹsẹ oyi oghie.\f + \fr 11:23 \ft Li zẹ \fq Okiali 2.2; 1.22\f*
\p 
\v 24 Irudunga o zẹ khi abi iMosisi ọ rọ fu vule se, khi ọa lama a ke lu luẹ omi omi iFero ọnọkpotso.\f + \fr 11:24 \ft Li zẹ \fq Okiali 2.10-12\f*
\v 25 Ọ lama khi lọli ya nu ẹgbọ eyi Ẹshinẹgba mẹ osoli, ocho ni luẹ rọ ya li agbọ olamhẹ ukuku ẹghẹghẹ.
\v 26 Ọ bino ọli khi, omama ni ọgbọ ọ ri itobọ iKirisiti ẹẹ mẹ o mu ẹloe dọsẹ ẹpfue na iJipiti nya. Itobọ khi eleli ni o la odalo ọ ri ukpẹloe shi.
\v 27 Irudunga o rọli rọte iJipiti vu, ni o khia khi ulishi elemhi ibibi oyi oghie ọa mu ọli. Itobọ khi o li abinẹ khi eri ọọ mẹ Ẹshinẹgba ni aa ya mẹ ẹloe, lọli ọa rọ mu egbe pfi.
\v 28 Irudunga o rọli ri Ukpe iPasova na iri-ọlia to ogbhele kọ, ni ọ rẹ, eniyẹ iZirẹni e miatsẹ ọlia ku shi ogbhele, ini agẹni eghuli ọ khi gbe emọdiọ eyẹwẹ-a.\f + \fr 11:28 \ft Li zẹ \fq Okiali 12.21-30\f*
\p 
\v 29 Irudunga o ri ẹgbọ iZirẹni dobẹ da okẹ oniẹmhi ni a lu Okẹ Ifulọ, abinẹ khi eni e rọte ekẹ ifufu dọsẹ. Abi ẹgbọ iJipiti e rọ li mu ọli fẹ, khọnya wẹ, oni okẹ o to wẹ luẹ.\f + \fr 11:29 \ft Li zẹ \fq Okiali 14.21-31\f*
\p 
\v 30 Irudunga o ri ugbe ni a khi gasẹ iJẹriko de ya gbe abi ẹgbọ iZirẹni e rọ kia gasẹ ọli se ogbẹlẹ ishilua.\f + \fr 11:30 \ft Li zẹ \fq iJosh 6.12-21\f*
\v 31 Irudunga a rọ tsumhi iRé-àbu ni ọ khi adegbe ni ọa rọ nu eni ẹa suọ esọ na Ẹshinẹgba pfua. Irari khi ẹgbọ iZirẹni ni a ghie e ka bẹna tọkpẹ oni ekẹ bino, ọ mie wẹ shi owa.\f + \fr 11:31 \ft Li zẹ \fq iJosh 2.1-21; 6.22-25\f*
\p 
\v 32 Sẹẹ mhi ke gbo ya ngme ma ọ? Mhi kie ke zọnọ wẹ? Ẹghẹghẹ ọa la ọ na mhẹ ni mhi rọ ya ngme ingme oyi iGidiọni, iBaraki, iSamusi, iJefita, iDefidi, iSamuẹni ali emekẹguele eyi Ẹshinẹgba.\f + \fr 11:32 \ft Li zẹ \fq Eguẹzọ 6.11--8.32; 4.6--5.31; 13.2--16.31; 11.1--12.7; 1 iSam 16.1--1 Ighie 2.11; 1 iSam 1.1--25.1\f*
\v 33 Irudunga e rọ mu omhẹsẹ eyi ighie le, e mhẹsẹ na ẹgbọ abi Ẹshinẹgba ọọ li nono ọli shi. E mie emini Ẹshinẹgba ọ tse ekha na wẹ. E guese inu eyi idu,\f + \fr 11:33 \ft Li zẹ \fq iDan 6.1-27\f*
\v 34 e pfuse erali ebe-a, e na pfue eghuli ọgbhọrọ. O lọsẹ wẹ, ama e toto-a, e khi idenọmọ elemhi okhọli, e pfuse ekhọli-okhuẹ eyi ẹoli oboese-a.\f + \fr 11:34 \ft Li zẹ \fq iDan 3.1-30\f*
\v 35 Irudunga, ikpotso e rọ gbo mie ẹgbọ eyẹwẹ ni a rọte eghuli guise le bhale agbọ.\f + \fr 11:35 \ft Li zẹ \fq 1 Ighie 17.17-24; 2 Ighie 4.25-37\f*
\p Ẹgbọ elese e ri egbe mie ugbemhi obe, ẹa lama a wolọ wẹwẹ abọ-a, ama e ghu-a shi ugbemhi obe, itobọ khi e ri udu shi irọte-eghuli-guale bhale agbọ ni o tinẹ.
\v 36 Eghuo ọ, a rẹwẹ li egia, a gbe wẹ itali, a sọ eghuo igha rọ shi ọgba ighumha.\f + \fr 11:36 \ft Li zẹ \fq 1 Ighie 22.26-27; 2 Okhẹ 18.25-26; iJere 20.2; 37.15; 38.6\f*
\v 37 A tono wẹ echẹ, a ri isọ kie wẹ shi asha eva, a ri ọgbhọrọ gbolo wẹ-a. E ri ekuẹ elamhi ali isumha ku egbe, e khi ena umha mẹ, a nasẹ wẹ, a li wẹ umumumẹ.\f + \fr 11:37 \ft Li zẹ \fq 2 Okhẹ 24.21\f*
\v 38 Ẹgbọ ni agbọ ẹa lu emhi eni ẹgbọ ena e khi. E dudu kia kia ifui ọdagbe ifufu ali ikhomhi ite abi eni ẹa mhọli apfẹ, ee la elemhi irui ali ifui esẹ na elemhi ekẹ.
\p 
\v 39 Itobọ irudunga oyi enana a rọ kuẹghiẹ wẹ, ama ọngẹwẹ ọa kie mie emini Ẹshinẹgba ọ shobọ.
\v 40 Itobọ khi Ẹshinẹgba ọ she mhẹsẹ emini o tinẹ shi ekẹ ẹ khẹ awa, ẹghẹghẹ aghọ e kha kugbe awa ọ, ọ ri awa ali wẹwẹ gba pfo.
\c 12
\p 
\v 1 Aborọkhia khi ebubu ọtsẹlẹ eyi ingme agbọ irudunga e she lina le gasẹ awa ena, awa tsua emini ẹẹ zu awa odẹ ku-a ali olamhẹ ni e kẹlẹ ti awa je ukhokho. Awa zẹ ni awa ri iregbemie ke na oni unamhi ni a rọshi awa odalo.
\v 2 Awa ri ẹloe shi iJesu egbe ke bino ọli, ọni ọ khi igbaekẹle ali ọni ọ ri irudunga oyawa gba pfo. Ọni ọ ri itobọ oghẹlẹ oni a rọ shi ekẹ ẹ khẹ ọli, ri egbe mie eghuli na apfida, ọ ri ukpẹloe gbe omama ni ọ la apfida ya mẹ. Mena, ọ she shitọ obita ukpẹkhomhi Eghiele oyi Ẹshinẹgba.
\v 3 Pfi ukpẹloe ke bino lọli ni ọ ri egbe mie ibiselemhi ni mẹ obọ oyi ẹgbọ olamhẹ, ini o khi lọsẹ ẹ ni o pfanọ ku ẹ alo.
\p 
\v 4 Inu-olamhẹ khẹ abọ oyẹ, ọa kie rẹ ramhi oyi eghuli ne.
\v 5 Eri a she yele ungmemhi iyude ni Ẹshinẹgba ọ nu ẹ ngme-a, abi imi ọli eni emọse ali eni ikpotso? Ni ọ lẹ.
\q1 “Omi mhẹ, khi ri
\q2 ẹloe gbe isheshe shi odẹ
\q2 oyi Ọnọmhuẹ,
\q1 ali a khi zẹ ni
\q2 egbe pfọ ẹ-a
\q2 ini ọ sheshe ẹ shi odẹ,
\q1 
\v 6 Irari khi eni Ọnọmhuẹ
\q2 ọ nono ingme oyẹwẹ
\q2 ọọ sheshe shi odẹ,
\q1 ọgbọkpa ni ọ lama
\q2 khi omiọli luẹ khi
\q2 ọọ na osoli.”\f + \fr 12:6 \ft Li zẹ \fq iJobu 5.17; Ekpi 3.11-12\f*
\m 
\v 7 Ri egbe mie ini a sheshẹ shi odẹ, eri Ẹshinẹgba ọọ riẹlẹ ẹ abi imi ọli. Mhiẹ ii, ọmọ ọnọghuo itali ọa ya sheshe shi odẹ?
\v 8 Ini aa sheshe ẹ shi odẹ abi a liẹ sheshe ọmọ kpa shi odẹ, eri o rọkhasẹ khi waa khi egbegbi omiọli ama ọmọ ni aa lẹsẹ ọni ọ bia li u khi.
\v 9 Itawa ena agbọ ẹa ya sheshe awa shi odẹ, ni awa rọ kiele ẹ mu ekpẹ na wẹ? Elọ o zẹ ni awa aa ke rọ lili ẹ zẹ ni ọni ọ khi Itawa elemhi ayẹmhẹ ọ̌ li sheshe awa ni awa mhọli egbegbi agbọ?
\v 10 Ukuku ẹghẹghẹ itawa ena agbọ ẹẹ sheshe awa shi odẹ abi ọ ti wẹ ẹloe shi, ama itobọ onete oyawa Ẹshinẹgba ọ rọ sheshe awa shi odẹ, ini awa nu ọli mhọli okemhi shi ipfuasẹ oyọli.
\v 11 Isheshe shi odẹ okhọghuo ọa ya viọlọ egbe, ama eri ọọ to. O kha ke dẹnẹ, o ri ọni a lighọ sẹsẹ ingme ẹ ngeli angeli enete, ali ọ gbo mhọli opfọmhẹ.
\v 12 Irarighọ, abọ eyẹ ẹ ni o lọsẹ ali ikhomhẹgbhẹ eyẹ ẹ ni ẹẹ kpheli rẹrẹrẹ, a zese wẹ-a.\f + \fr 12:12 \ft Li zẹ \fq Aza 35.3\f*
\v 13 A ke kia odẹ ni o sheshe talala, ni a ri eni e chẹghẹlẹ awẹ-a ze, ocho ni e rọ ya de.\f + \fr 12:13 \ft Li zẹ \fq Ekpi 4.26\f*
\v 14 A rọshẹka odẹkhodẹ ni a nu ọgbọkpa la agbọ opfọmhẹ, ni a gbo la agbọ ipfuasẹ, irari khi ọgbọkhọghuo ni ọa mhọli ipfuasẹ ọa ya mẹ Ọnọmhuẹ.
\v 15 A rọshẹka ini ọngẹẹ ọ khi khi ọni okhale oyi Ẹshinẹgba ọa ramhi obọ ali a khi zẹ ni iyese-elemhi-a o zẹ shi ẹ iteva ni ọọ pfi ingme obe rọ pfuẹchẹ ẹgbọẹse-a.\f + \fr 12:15 \ft Li zẹ \fq iDẹut 29.18\f*
\v 16 Ọgbọkhọghuo ọ khi khi ọni ọọ ku itsẹbọ, wẹẹ ọngẹẹ ọkhọghuo ọ li abi iSọ ni ọa mhọli ayẹmhẹ ọyi Ẹshinẹgba, ni ọ ri itobọ eminale utoghuo kpele ri ugu ọdiọ oyọli dẹ.\f + \fr 12:16 \ft Li zẹ \fq Igbae 25.29-34\f*
\v 17 A lẹsẹ khi ẹlẹlese, abi ọ ke rọ ọ nono ni lọli mie oni ikhivọsẹ, a kie ọli. Itobọ khi ọa ke mẹ asha mu udu pfi, abi ọ tseku ke ri amẹ eviẹ nono ọli.\f + \fr 12:17 \ft Li zẹ \fq Igbae 27.30-40\f*
\p 
\v 18 Irari khi aa bhale ute ni a dobẹ ri obọ ọ ti, onabi ute iSinai ni ẹgbọ iZirẹni e ke bhale, ni ẹlẹmhi erali o la a de biobiobio, ni obili ulishi o la, ali ni okiki olitsa o la khili ekẹ,
\v 19 ali ni akala o la de limhilimhi, ni uruli oniẹmhi o la a ngme, ni ẹgbọ ni ẹ suọ oni uruli e rọ lema oni ungmemhi o kpẹsẹ aghọ.\f + \fr 12:19 \ft Li zẹ \fq Okiali 19.16-22; 20.18-21; iDẹut 4.11-12; 5.22-27\f*
\v 20 Itobọ khi ẹa dobẹ ri egbe mie ushi ni a shi na wẹ ni ọọ, “Ini o riẹ khia khi ẹlamhakọ ọ ri egbe ti oni ute, a mema ya tono ọli echẹ gbe-a.”\f + \fr 12:20 \ft Li zẹ \fq Okiali 19.12-13\f*
\v 21 Eri emini a mẹ aghọ o lolo ri ulishi mu ramhi ni iMosisi ọ rẹ, “Ulishi oniẹmhi o ga mu mhẹ!”\f + \fr 12:21 \ft Li zẹ \fq iDẹut 9.19\f*
\p 
\v 22 Ama, mena, a she bhale ute iZayọ, ali ẹoli oyi Ẹshinẹgba ọni ọ la ọ, iJerusalẹmu ona iloghie ali obini ilegba oghẹlẹ oyi igẹni upfoleli.
\v 23 A she bhale igbaa oyi eni e mie iJesu iKirisiti suọ oyi emọdiọ eyi Ẹshinẹgba, eni a kẹkẹ eva oyẹwẹ shi iloghie. A she bhale deba Ẹshinẹgba ni ọ khi ọsọ-ẹzọ ọyi ẹgbọ kpa, ali a gbo bhale deba ayẹmhẹ oyi ẹgbọ enete ni a rọ khi eni e gba pfo.
\v 24 A she bhale deba iJesu ọni ọ ri ishobọ onogbọ kọ, a gbo bhale deba ọlia ni a miatsẹ ku, ni ẹẹ ngme emini e ti dọsẹ emini ọlia eyi Ebẹli e ngme.\f + \fr 12:24 \ft Li zẹ \fq Igbae 4.10\f*
\p 
\v 25 A mu egbe ẹ ini a khi kie ungmemhi oyi ọni ọ nu ẹẹ ngme. Ini eni ẹgbọ ẹa dobẹ pfue ọ, abi ẹa rọ ri ungmemhi oyi ọni ọ la agbọ tse agua ye wẹ gbe akanya, sẹ u sa khi awa li ya pfue ọ, ini awa aa ri ungmemhi oyi ọni ọ rọte idane tse agua ye awa gbe akanya.\f + \fr 12:25 \ft Li zẹ \fq Okiali 20.22\f*
\v 26 Eri uruli oyi Ẹshinẹgba o nighise ekẹ agbọ ẹghẹghẹ aghọ, ama mena, ọ she shobọ, ọọ, “Ọa khi ekẹ agbọ tse mhi gbo ya nighise utoghuo shi ọ, ama li shi ukhui.”\f + \fr 12:26 \ft Li zẹ \fq Agai 2.6\f*
\v 27 Eri ungmemhi ni ọọ, “Utoghuo shi ọ,” o rọkhasẹ gboo khi emini a ma nya, khi a ya nighise wẹ, a rue wẹ odẹ-a, ni a bhale ya ẹ khi emini ẹa zẹ nighise e kẹ kpọle.
\p 
\v 28 Irarighọ, aborọkhia khi awa a mie omhẹsẹ ni ọa zẹ nighise eghọ, a zẹ ni awa ke kphẹmhi, awa ri ekpẹ ali ulishi ga Ẹshinẹgba abi o ti shi,
\v 29 irari khi Ẹshinẹgba ọyawa erali opfuse ọ khi.\f + \fr 12:29 \ft Li zẹ \fq iDẹut 4.24\f*
\c 13
\s1 Ugamhi ni o ghọle Ẹshinẹgba
\p 
\v 1 A kie lighọ ke nono ingme oyi egbe ẹ abi inyọghuo.
\v 2 A ke sato mie epfẹse shi owa, a mu wẹ epfẹse. Irari khi ẹgbọ eghuo ee ke lighọ, ni e rọ mu ẹgbọ eghuo epfẹse, ni ẹa lẹsẹ khi igẹni e khi ni wẹwẹ e mu epfẹse.\f + \fr 13:2 \ft Li zẹ \fq Igbae 18.1-8; 19.1-3\f*
\v 3 A ke sato eni a mu shi owa ighumha egbe abinẹ khi eri a nu wẹ la aghọ. A ke sato ẹgbọ eni a na osoli egbe abinẹ khi eri a li nu wẹ mẹ oni osoli.
\p 
\v 4 Ọmọse ali ughuẹ ọli e mu ekpẹ shi angeli oyẹwẹ. Ọmọse ali ughuẹ ọli e khi li egbe le. Irari khi Ẹshinẹgba ọ ya gue eni ẹ ku itsẹbọ ali eni ẹ kia okia ẹzọ.
\p 
\v 5 Zobẹ ni agbọ oyẹ o nuata shi ọghuẹmhẹ ukpaghọ, zẹ ni emini u mhọli o ke khuese ẹ. Irari khi Ẹshinẹgba ọọ liẹ,
\q1 “Mhi aa tigbe ya zẹ obọ,
\q2 mhia ya tsuẹ pfia ghue.”\f + \fr 13:5 \ft Li zẹ \fq iDẹut 31.6,8; iJosh 1.5\f*
\m 
\v 6 Lọli o zẹ ni awa rọ ya ri igbedu liẹ,
\q1 “Ọnọmhuẹ ọ khi
\q2 ọkpaghiobọ ọyẹmhẹ,
\q2 mhia ya tigbe na ulishi.
\q1 Elọ ọgbọ dobẹ ya li mhẹ?”\f + \fr 13:6 \ft Li zẹ \fq Iwolo 118.6\f*
\p 
\v 7 A pfi ẹloe bino eni e ralo na ẹ ena ẹlẹlẹ. Eni e ri irudunga gue ungmemhi oyi Ẹshinẹgba ye ẹ. A sa je abi e li ngeli ramhi ni e rọ ghua, ni a ke khọnya irudunga oyẹwẹ.
\v 8 IJesu iKirisiti, abeghuo ọ khi, odẹ, amo, ali agbọagbọ.
\p 
\v 9 Khi zẹ ni osẹsẹ ẹgbhọli ọdọda e tsua ẹ udu vu. Irari khi okhale o ri udu oyawa ze-a, ọa khi ni a ri ushi eminale gbe akanya, ni ọa kpaghiẹ eni e rẹwẹ gbe akanya obọ.
\v 10 Ama awa mhọli atẹtẹ ni ekpodalo-ugamhi eyi Ẹshinẹgba na elemhi owa ugamhi oyi ẹgbọ iJu ẹa mhọli afu ya rọte le emhi iluasobo.\f + \fr 13:10 \ft Emini onana o ngme khi, ‘Awa mhọli atẹtẹ ni o khi apfida ni iJesu ọ la ri idiegbe oyọli luasobo. Ama ẹgbọ ni ẹẹ sa khi iluasobo ni a luasẹ elemhi owa ugamhi oyi ẹgbọ iJu, e te ya mhọli imiepfuese, ẹa mhọli okemhi shi oni atẹtẹ ona.’\f*
\p 
\v 11 Eri Ọni ọ kpeda na ekpodalo-ugamhi eyi Ẹshinẹgba ọyi ẹgbọ iJu ọọ tsua ọlia eyi elamhakọ lo elemhi Asha-no-Pfuase nẹ nya ya rọ luasẹ obo shi olamhẹ irọtopfa, ama eri a rue eni idiegbe eyi eni elamhakọ fiẹ ifui apfẹ je ọdagbe ya tosẹ-a.\f + \fr 13:11 \ft Li zẹ \fq iLẹv 16.27\f*
\v 12 Onana o zẹ ni iJesu ọ rọ li ghu-a shi ikhokho apfẹ, ni ọ rọ ri ọlia eyọli ri ẹgbọ khi eni e pfuasẹ.
\v 13 Irarighọ, a zẹ ni awa lẹ deba li ikhokho apfẹ ni awa nu ọli mẹ omama ni ọ mẹ.
\v 14 Irari khi agbọ oola, awa aa mhọli ẹoli ni o laọ agbọagbọ, ama ẹoli ni o ya bhale awa ri ukpẹloe shi ekẹ ẹ khẹ.
\v 15 Awa ri irarighọ rọte iJesu ke ri iluasobo ikuẹghiẹ na Ẹshinẹgba. Ini awa lighọ, eri awa pfi ọtsẹlẹ shi ọ khi lọli ọ khi Ọnọmhuẹ.
\v 16 A khi yele onete iriẹlẹ-a, ali ni a gbo ke kpaghiẹ egbe obọ, irari khi enana khi iluasobo ni e liẹ ti Ẹshinẹgba ẹloe.
\p 
\v 17 A ke suọ esọ na eni e ralo na ẹ, a ri egbe ẹ tiemhie na omhẹsẹ oyẹwẹ. Eri e ri ukpẹloe shi ẹ egbe abi eni e ya rọkhasẹ abi e li gbe. A ke suọ esọ na wẹ ni akanya ni ẹẹ gbe o ri oghẹlẹ na wẹ, ini o khi khi itsua na wẹ, irari khi u wa mhọli eleli ni u ya mẹ ọ.
\v 18 A ke lema na anye. Anye lẹsẹ khi udu oyanye o pfuasẹ, anye gbolo ẹ ngeli ke mu ekpẹ shi egbe anye egbe odẹkhodẹ.
\v 19 Mhi gbo ga lolo lema ẹ, a lolo lema Ẹshinẹgba ọ gbo rẹmhẹ kẹlẹ nyenẹ egbe bhale deba ẹ.
\v 20 Mhi lema Ẹshinẹgba ọna opfọmhẹ, ọni ọ ri ọlia oyi ishobọ na agbọagbọ rọte eghuli guise iJesu Ọnọmhuẹ le, ikhi Ọrisumha-kia ọniẹmhi oyi isumha ọghọ.
\v 21 Ọ ri eminete nya shi ẹ egbe ni a rọ ke riẹlẹ ọghuẹmhẹ oyọli. Ọ gbo gbe ikanya eni e ti ọli ẹloe shi awa egbe, rọte obọ oyi iJesu iKirisiti, ni ọ mhọli ufumhi na agbọagbọ. Atsẹ.
\p 
\v 22 Inyọghuo-mhẹ, mhi lema ẹ, a kuegbe-a ri esọ shi oni usomhi irudushọ ona, irari khi ebe ni mhi kẹkẹ ghi ẹ ena ọa lolo nuata.
\v 23 Mhia nono ni a lẹsẹ khi a she rue iTimoti inyọghuo awa ọgba ighumha lasele. Ini ọ kẹlẹ bhale, mhi ya rọli bhale ya mẹ ẹ.
\p 
\v 24 A tsẹ eni ẹẹ ralo na ẹ nya, ali ẹgbọ eyi Ẹshinẹgba nya. Inyọghuo awa eni e la Itili ẹẹ tsẹ ẹ.
\p 
\v 25 Okhale oyi Ẹshinẹgba o ka nu ẹ nya la. Atsẹ.
