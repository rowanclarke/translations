\id 1CO - Maxakal'i NT -Brazil 2011 (DBL -2013)
\h 1 KONĨN
\toc1 Paot Te Konĩn Xop Pu Kax'ãmi' 1
\toc2 1 Konĩn
\toc3 1 Ko
\mt1 PAOT TE KONĨN XOP PU KAX'ÃMI' I
\c 1
\p 
\v 1 'Ũgmũn Paot, ha Topa tek mũn yãykutnãhã', tu nũgkutnãhã 'ãte hãpxopmã Yeyox Kunnix pu', tu xa kax'ãmi', yũmũg xape Xox mũtik 'ãte xa ka'ãmi',
\v 2 nũy tappet xa mõ'kutnã', nũy kõmẽn Konĩn yõg kuxa mãm ka'ok xop xohix hah mõ'kutnã', 'ãkuxa xohip-xet Kunnix kuxa mũtik hah. Yã 'ãxop Kunnix yõg xop, nũy Topa hã tikmũ'ũn xe'e'. Hak mũ'ãte tappet mõ'kutnã'ax kamah 'ũkuxa mãm ka'ok xop xohix hah, nõm xop te yũmũg xuxyã Yeyox Kunnix tu' xak, pu tu' kox ka'ogã'. Yã Yeyox Kunnix te' kuxa mãm ka'ok xop xohix hã' xuxyã'.
\p 
\v 3 Pũyã Topa yũmũg Tak 'ãkuxa mãmmã', nũy tu yũmũg xuxyã Yeyox Kunnix mũtik xa hãmmaxnã'.
\s1 Topa te Kunnix hã yũmũ'ã hãmmaxnãhã'
\p 
\v 4 Topa te xa hãmmaxnãhã', hak hittup, tu: 'Ãmax, Topah! Kaxĩy. Yã Topa te xa hãmmaxnãhã', Yeyox te 'ãxop pupi' xok ha hãmmaxnãhã'.
\v 5 Yã 'ãkuxap-xet Yeyox Kunnix kuxa mũtik, pu hãm'ãktux ka'ok ha 'ãyummũgãhã, xa hãmyũmmũg xohix.
\v 6 'Ãkuxa mãm ka'ok hãm'ãpak'ax kopah, ha Kunnix 'ãktux,
\v 7 yĩy Topa te xa hãmmaxnã xexkah, 'ĩhã 'ãxop te Topa yõg hãptup mõ'nã'ax xexka hip, 'ĩhã yũmũg xuxyã Yeyox Kunnix nũn putup putpu'.
\v 8 Ha 'ãka'ogãp-tup, 'ĩhã' nũn'ax hip, xayĩy 'ãkuxa tu max, 'ĩhã yũmũg xuxyã Yeyox Kunnix xupep, nũy 'ũhep xop xohix yõg hãpxopmã'ax kopit.
\v 9 Topa xip ka'ok, tu mõ'ãgmũg xohix hã' xip ka'ok, tu yũmũg mũtik tihi', tu yũmũg xãnãhã, 'ũ nũ', nũy yũmũg kuxap-xet yũmũg xuxyã kuxa mũtik, nũy Topak-tok Yeyox Kunnix kuxa mũtik yũmũg kuxap-xet.
\s1 'Ũkuxa mãm ka'ok xop te yãy tuk-mĩy
\p 
\v 10 'Ũkxape xop, 'ãte 'ãxop tu' xak, xap-tox puxet xix kuxap-xet, nũy yãy mũtik ta tuk-mĩy hok. Yã yũmũg xuxyã te 'ã' hõm yãy 'ãxet'ax, 'ãte xa' xak, xayĩy 'ãgãy hok.
\v 11 Kono xape te xa 'ãktux, tu 'ãxop te yãy tuk-mĩy'ax 'ãktux,
\v 12 ha kaxĩy tikmũ'ũn 'ũm te: “'Ũgmũn yã Paot yõg,” kaxĩy, ha' nõy te: “'Ũgmũn yã 'Apot yõg,” kaxĩy, ha' nõy te: “'Ũgmũn yã Pet yõg,” kaxĩy, ha' nõy te: “Pak mũn yã Kunnix yõg,” kaxĩy.
\v 13 'Ok 'ãxop te Kunnix yõg tikmũ'ũn koxip putup yãy pu'? 'Ok 'ũgmũn te mĩpkupnix tuk xok 'ãxop pupi'? 'Ãmhok! 'Ok 'ãte yãy 'ãxet'ax hõm, pu tikmũ'ũn 'ũm 'ãp-tox pix? 'Ap hõm'ah. Kunnix puxet te yãy 'ãxet'ax hõm, pup-tox pix. 'Ak mũn'ah.
\p 
\v 14 'Ãte Kinix xix Gax putox pix, pãyã tikmũ'ũn nõy putox pix 'ohnãg, yĩy 'ãte: 'Ãmax Topah! Kaxĩy. Tuk hittup.
\v 15 Yã tikmũ'ũn te hãm'ãktux hok, hu: “Paot te yãy 'ãxet'ax hõm puyĩp-tox pix,” kaxĩy. Yã' koit.
\v 16 Nãy. 'Ãte 'Exteo putox pix kamah, xi' xape xop, pap-tox nõy 'ap pix'ah 'ãte'.
\v 17 Kunnix te nũ 'ũm kutnã'ah 'ũp-tox pix. 'Ãmhok. Pa nũgkutnãhã', 'ũyĩy 'ãte hãm'ãpak max'ax 'ãktux, 'ãte hãm'ãktux max pu kakxop tuk-tup yũmmũg max, nũy Kunnix xexkanã'. Yã yũmũg pupi' xok mĩkupnix tu', yã hãm'ãpak max'ax 'õhõm.
\s1 Topa te Kunnix hã tikmũ'ũn pu hãmyũmmũgãhã'
\p 
\v 18 Tikmũ'ũn kuxa yũm 'ohnãg hãm'ãpak'ax max kopah, puxi' yĩxix, tu hãm'ãktux'ax putup nõg, tu: “'Ãp-tox kummuk!” kaxĩy, tu' yĩpkox 'ohnãg. Pa yũmũ'ãte' xupak, tu: Hamũn! Yã hãmyũmmũg xe'e'! kaxĩy, tuk yĩpkox pip hãm'ãktux'ax ka'ok pu', ha Kunnix yũmũg pupi' xok 'ãktux, ha Topa ka'ok, hu yũmũg kuxa kummuk xit, nũy kuxa max mõ'tat 'ũyãnãn tu'. Yã hãm'ãktux'ax ka'ok, tu yũmũ'ã hã hãm'ãpak max xe'e'.
\v 19 Yã Topa yõg tappet te:
\q1 “'Ãte hãm'ãktux tox xop yõg hãm'ãktux kuxyãp-tup,” kaxĩy.
\p 
\v 20 Piyãp xip tikmũ'ũn te hitop tu yãy pe'paxex, hu: “'Ãte hãmyũmmũg,” kaxĩy. Piyãp xip tikmũ'ũn te hitop tu yãy pe'paxex, hu: “'Ãte hãm'ãktux max,” kaxĩy. Yã' mõg, tu' yĩpkox 'ohnãg. Topa te hãm'ãktux hitop'ax tu' mũg, hap-tox kummuk xop yõg hãm'ãktux.
\p 
\v 21 Topa te hãmyũmmũg, tu' tux hok, pu tikmũ'ũn hãmyũmmũg hok, nũy hãmpe'paxex'ax hã Topa mũn yũmmũg hok, 'ĩhãk mũ'ãte hãm'ãpak max'ax 'ãktux, puyĩy tikmũ'ũn yũmmũg, ha Topa te tikmũ'un hã tu tehet, nõm xop kuxa mãm ka'ok hãm'ãpak max kopah, hã tu tehet, 'ĩhã' kuxa kummuk xit, nũy nõ kuxa max mõ'tat 'ũyãnãn tu'.
\v 22 Yoneo xop te Topa yõg hãpxopmã xe'ẽgnãg xak, nũy pẽnã', nũy hãm'ãpak max'ax yũmmũg, ha Genex yõg puknõg xop te hãmyũmmũg xak,
\v 23 pak mũ'ãte Kunnix 'ãktux, ha mĩpkupnix tu' xok yũmũg pupi', yã hãm'ãpak max. Pa Yoneo xop tep-tup nõg, xi' puknõg xop te hãm'ãpak'ax 'ãktux kummuk,
\v 24 pa Topa te yãy yõg tikmũ'ũn xãnãhã', pe Yoneo yõg tikmũ'ũn, pe' puknõg, ha' yĩmõgatux, pu hãm'ãpak max'ax 'ãpax, ha Topa te Kunnix nũ'kutnãhã', pu yãy yõg tikmũ'ũn ka'ogã', nũy yãy yõg tikmũ'ũn yũmmũgã'.
\v 25 Ha tikmũ'ũn 'ũm te hitop tu hãm'ãktux, hu: “Yã hãm'ãpak'ax kummuk, tu hãmyũmmũgã hok,” kaxĩy. Nãy, tikmũ'ũn te hãm'ãktux kohe'. Nõm hãm'ãpak'ax yã Topa yõg hãmyũmmũg'ax xe'e'. Ha' nõy 'ũm te: “Yã hãm'ãpak max'ax pu'uk, tu' ka'ogã hok,” kaxĩy. Pa Topa te' xuktux, yĩy hãm'ãpak'ax ka'ok.
\p 
\v 26 'Ũkxape xop, hãmpe'ãpaxeh nõmhã. Hõmã 'ãxop te hãmyũmmũg 'ohnãg, tu tikmũ'ũn nõy xat 'ohnãg, ha Topa te 'ãxãnãhã', yã tikmũ'ũn te xa 'ãktux 'ũnõy pu', hu: “Hãmyũmmũg kutõgnãg 'õhõm,” kaxĩy. Tu xa pe'paxex 'ohnãg.
\v 27 Pa Topa te nõm tikmũ'ũn pu' hupmãhã', 'ĩhã 'ãyĩmõgatux, 'ãk-tõgnãg hah 'ãyĩmõgatux, xix 'ãpuk'uk hah 'ãyĩmõgatux.
\v 28 Hõmã 'ãxop yã hãmhok xop, yã Topa hã' puknõg 'ãxop, yĩy Topa te 'ãyĩmõgatux, nũy nõm tikmũ'ũn xop yõg hãmpe'paxex kuxyã',
\v 29 pu tikmũ'ũn 'ũm te yãy mũn xexka pe'paxeh hok Topa keppah.
\v 30 Pa Topa te 'ãxop hã yãykotĩnnãhã', tu yãy tu nũ' xok Kunnix hã', ha Kunnix te hãmyũmmũg xohix, tu yũmũg hĩnnãhã', 'ũ tu hi xe'e', yã Topa te mõ yũmũg yãy, tu yũmũg kuxa tupmãhã', pu Topa hã yũmũ'ã tikmũ'ũn. Yã Kunnix te mĩpkupnix tu' xok, nũy yũmũg yõg hãpxopmã'ax kummuk hã' pago.
\v 31 Yĩy Topa yõg tappet te: “Tikmũ'ũn te hãmpe'paxex xexka putup, pũyã Topa yõg hãpxopmã'ax pe tu paxeh xexkah, nũy yãy yõg hãpxopmã max pe tu paxeh 'ohnãg,” kaxĩy.
\c 2
\s1 Paot te Kunnix xok'ax 'ãktux
\p 
\v 1 'Ũkxape xop, hõmã 'ãte xa hãm'ãktux, tu xa Topa yõg hãm'ãktux'ax 'ãktux. Hõmã, hãmyãxatamuk xohix hã Topa yĩy 'ohnãg, tu hãm'ãktux 'ohnãg, pãyã hõnhã Topa te hãm'ãktux, yĩy 'ãte xa' xuktux Topa pupi', tu hãm'ãktux max, puyĩy kakxop tuktup kama yũmmũg max.
\v 2 Yã 'ãte hãm'ãktux'ax nõy putup 'ohnãg, nũy Yeyox Kunnix puxet 'ãktux, nũy Yeyox xok'ax puxet 'ãktux. Yã mĩpkupnix tu' xok, yũmũg pupi' xok, nũy yũmũg kuxa kummuk xit, nũy kuxa max tat 'ũyãnãn tu'.
\v 3 Hõmã 'ãhak mõg, tu tak pu'uk, tuk kuxãnõg,
\v 4 tu Topa yõg hãm'ãktux xa' xuktux, xix xa hãmyũmmũgãhã', pãyã 'ap hãm'ãktux max'ah, puyĩy tikmũ'ũn te: “Yã hãmyũmmũg 'õhõm!” kaxĩy. 'Ãmhok, pa Topa Koxuk tek ka'ogãhã', 'ũyĩy Yeyox Kunnix 'ãktux, hak ka'ogãhã kamah, 'ãte hãpxopmã ka'ok, pu tikmũ'ũn pẽnã', nũy: “Yã Topa te Paot nũ'kutnãhã', pu yãy pupi hãm'ãktux yũmũ'ã', tu hãpxopmã ka'ok xe'e',” kaxĩy.
\v 5 Yĩy 'ãkuxa mãm ka'ok Topa kopah, hu 'ãkuxa mãm 'ohnãg tikmũ'ũn yõg hãmyũmmũg'ax puknõg kopah, yã Topap-xet kopa 'ãkuxa mãm ka'ok, 'ũka'ok hah.
\s1 Topa te hãmyũmmũg xe'ẽgnãg
\p 
\v 6 Ha 'ãte' kuxa mãm ka'ok xop pu hãm'ãktux, nõm xop te Topa Koxuk pu' yĩpkox pip, ha 'ãte Yeyox Kunnix 'ãktux, 'õhõm yũmũg pupi tu xok, nũy yũmũg kuxa kummuk xit, pãyã hãm xexka yõg tikmũ'ũn te hãm'ãktux kohe', tu Yeyox Kunnix putup nõg, xi' xexka xop tep-tup nõg, ha tikmũ'ũn te nõm xat'ax xop pu' yĩpkox pip putup 'ohnãg.
\v 7 Yã 'ãte Topa yõg hãm'ãktux 'ãktux, ha hãmyũmmũg xe'e'. Hõmã hãmyãxatamuk xohix 'ĩhã', 'ap hãm 'ũm xip'ah, pãyã Topa te hãmpe'paxex, tu yũmũ'ã ha hãmmaxnã xexkap-tup, hu: “Pũyã yãy kutok tikmũ'ũn pupi tu xok, nũy nõ kuxa kummuk xit,” kaxĩy. Pãyã' xaptop, tu' xuktux 'ohnãg, tu' yũmmũgã 'ohnãg.
\v 8 Pax pu Topa hã' puknõg xop yũmmũg, puxix yũmũg xuxyãp-tex hok, 'ũgãy tup-tex. Pãyã' kuxa mãm 'ohnãg, hu yũmũg xuxyã max xe'ẽgnãg putex.
\v 9 Pa Topa yõg tappet te hãmmaxnã xexka 'ãktux, tu yũmũg xuxyã xok yũmũg pupi'ax 'ãktux, hu:
\q1 “Tikmũ'ũn te' pẽnã 'ohnãg, tu' xupak 'ohnãg,
\q1 tu' pe'paxex 'ohnãg,
\q1 pa Topa te hãmpe'paxex, nũy yãy yõg tikmũ'ũn pu hãmmax nã xexkah,
\q1 nũy tup-tup pax xop pu hãmmaxnã xexkah,” kaxĩy.
\p 
\v 10 Yã hõmã Topa yĩy 'ohnãg, pa hõnhã yãy Koxuk te yũmũ'ã hãm'ãktux, nũy yũmũg yũmmũgã', puyĩy xehomip xaptop 'ohnãg. Yã Topa Koxuk te tikmũ'ũn yõg hãmpe'paxex xohix yũmmũg, tu Topa yõg putup'ax xohix yũmmũg, xix Topa yõg hãmpe'paxex xohix yũmmũg.
\v 11 Tikmũ'ũn yãp-xet te yãy yõg hãmpe'paxex xohix yũmmũg, yãp-xehnãg te hãmyũmmũg, ha Topa Koxuk yãp-xehnãg te Topa yõg hãmpe'paxex yũmmũg.
\v 12 Ha Topa te yãy Koxuk xe'ẽgnãg yũmũ'ã nũ'kutnãhã', tu' koxuk puknõg yũmũ'ã nũ'kutnã 'ohnãg, yã Topa Koxuk te yũmũ'ã hãmyũmmũgãhã', nũy Topa yõg hãm'ãktux yũmũgã'.
\p 
\v 13 Yĩk mũ'ãte Topa Koxuk yõg hãm'ãktux'ax 'ãktux putup, xa tikmũ'ũn yõg hãm'ãktux'ax pu 'ãyĩpkox hok. Yã kaxĩy 'ũgmũ'ãte hãm'ãktux, tu Topa Koxuk yõg hãm'ãktux'ax yũmmũgãhã', tu Topa yõg tikmũ'ũn pu hãmyũmmũgãhã', nõm xop te Topa Koxuk pu' yĩpkox pip.
\v 14 Pa Topa Koxuk te tikmũ'ũn 'ũm kopa' xihip hok, puxix tu nõm ka'ogã hok. Nõm tikmũ'ũn yã Topa hã' puknõg, tu' yõg hãm'ãktux 'ãpak, pãyã' yũmmũg 'ohnãg. Yã' Koxuk xe'ẽgnãg te Topa yõg tikmũ'ũn yãp-xet ka'ogãhã'.
\v 15 Topa Koxuk te tikmũ'ũn kopa xihip, puxix tikmũ'ũn pa hãmyũmmũg, nũy hãpxopmã'ax xohix kopit, xix hãmyũmmũg, pe' max, pe' kummuk. Pa' puknõg xop te nõm tikmũ'ũn yõg hãpxopmã'ax kopit hok.
\v 16 Yĩy Topa yõg tappet te:
\q1 “'Õk tikmũ'ũn 'ũm te Topa yõg hãmpe'paxex yũmmũg?
\q1 'Ok tikmũ'ũn 'ũm te Topa pu hãmyũmmũgãhã'? 'Ãmhok.
\q1 Topa yãp-xehnãg te yãy yõg hãmpe'paxex yũmmũg,
\q1 xix yãy pu hãmyũmmũg xe'ẽgnãg,” kaxĩy.
\p Pa Kunnix te hãmyũmmũg, tu yũmũ'ã hãmyũmmũgãhã', 'ũyĩy putox puxet Kunnix putox mũtik.
\c 3
\s1 Yũmũ'ã Topa hã kãmãnat
\p 
\v 1 'Ãte xa hãpxe'e 'ãktux. Yã 'ãxop tek mũn hã 'ãxape', pa 'ãte xa hãm'ãktux yũmmũg, 'okpa Topa Koxuk te 'ãkopa' xip. Yã 'ãxop te hãmpe'ãpanõm kummuk, Topa hã' puknõg xop putuk 'ãxop te hãmpe'ãpanõm, nõm te Topa pu' yĩpkox 'ohnãg, xix kakxop putuk hãmpe'ãpanõm, nõm xop te Topa yõg hãm'ãktux yũmmũg kutõgnãg, yã kakxop putuk, 'ãkuxa mãm pu'uk tu'.
\v 2 Kakxop pu'ũgnãg te' yõktat hep xo'op, tu' xit'ax ka'ok mã hok, ha kaxĩy 'ãxop pu'uk, tu Topa yõg hãm'ãktux yũmmũg kutõgnãg, hõmã xix hõnhã 'ãkuxa mãm pu'uk.
\v 3 'Ãxop te Topa hã' puknõg xop putuk, tu hãpxopmã kummuk, tu' yãykix pax, xix yĩpkumĩy pax, tu Topa hã' puknõg xop putuk, tu hãpxopmã kummuk.
\v 4 Tikmũ'ũn puxet te: “'Ũgmũn yã Paot yõg,” kaxĩy, ha' nõy te: “Pak mũn yã 'Apot yõg,” kaxĩy. Yã Topa hã' puknõg xop putuk hãpxopmãhã'.
\p 
\v 5 'Apot yã 'a' xexka'ah, xik mũn 'ak xexka'ah. Yãk mũ'ãte Kunnix tu hãpxopmãhã', puxi'. Tu xa hãm'ãpak max'ax 'ãktux, ha 'ãkuxa mãm ka'ok yũmũg xuxyã kopah. Yũmũg xuxyã tuk mũ'ãte hãpxopmãhã', yãk mũg xat, 'ũyõg kãmãnat hah.
\v 6 Tikmũ'ũn te hãpxa xexka hã' hãm, ha tik hãmãxap te hãpxop xap xok, ha' nõy kũnãy tu' hãm, tu kõnãg hã hãpxop xokax pix, puyĩy tu tuk mõ'ka'ok. 'Ũtix hãm, pãyã Topa te hãmmaxnãhã'. Ha kaxĩy 'ãte xa hãm'ãpak max 'ãktux, ha 'Apot te xa hãmyũmmũgãhã'. Tikmũg hãm, pãyã Topa te xa hãmmaxnãhã', tu 'ãkuxa mãmmãhã'.
\v 7 Kãmãnat xop 'a' xexka'ah, pãyã Topa mũn xexka xe'ẽgnãg, tu hãmmaxnãhã'.
\v 8 Ha kãmãnat xop xohix yãy putuk, ha Topa te' hãm'ax tu' pagop-tup, tu kãmãnat hãm xexka tu' pagop-tup punethok, ha kãmãnat hãm kutõgnãg tu' pagok-tõgnãg putup.
\v 9 Yã 'Apot xik mũn hãm Topa tu', 'ãxop ha tikmũg hãm, puyĩy Topa 'ãka'ogã', yĩy 'ãxop te hãpxa putuk, ha Topa te xa hãmmaxnãhã', ha 'ãxop te mĩptut putuk kamah, yã Topa yõg mĩptut.
\v 10 'Ũxuxyã te' xat, pu mĩptut max mĩy, tu tik puxet xat hãmãxap, pu mĩkaxxap mĩm mõg hãpkox kopah, pu nõ mãykup mõ'tat, ha' nõy kũnãy tu' xat, pu nõm mõ'xix hãpkox kopah. Ha Kaxĩy Topa tek ka'ogãhã', pu hãm'ãpak max 'ãktux hãmãxap, puyĩy tikmũ'ũn kuxa mãm ka'ok Yeyox Kunnix kopah, ha 'Apot kũnãy tu' nũn, nũy kuxa mãm ka'ok xop yũmmũgã max.
\v 11 Mĩptut xuxyã te mãykup ka'ok putup, yã mãykup te mĩptut ka'ogãhã', pu tu yũm ka'ok. Ha kaxĩy Topa te Yeyox Kunnix yãykutnãhã', pu yãp-xehnãg hã yũmũg pupi tu' xok, nũy yãp-xehnãg hã' kuxa kummuk xit, nũy kuxa max tat 'ũyãnãn tu'. 'Ap nõy xip'ah.
\v 12 Ha tikmũ'ũn yãg te pipkup yãnãm 'ãta hã hãm'ãta max mĩy, xi' nõy te pipkup yãnãm ponnok hã' mĩy, xi' nõy te xap max hã hãm'ãta mĩy. Ha' nõy te mĩmpe hã hãm'ãta kummuk mĩy, xi' nõy te xuxnak hã' mĩy, xi' nõy te xuxnãg xux hã hãm'ãta' mĩy. Hã kaxĩy Topa yõg kãmãnat hãm kamah. 'Ũyãg hãm max, tu Topa yõg hãm'ãktux 'ãktux, tu Topa yõg tikmũ'ũn ka'ogãhã' pu tu hãmyũmmũg. Ha' yãg nõy hãm kummuk, yĩy Topa yõg tikmũ'ũn pu'uk, tu hãmyũmmũg 'ohnãg.
\v 13 'Ũxuxyã te mĩptut kummuk mĩy, puxix kuxap hã mõ'xut mõ'ka'ok, ha' nõg. Hã kaxĩy Kunnix yõg hãptup xe'e mõ'nãp-tup, 'ĩhã Topa te yãy yõg kãmãnat xop yõg hãpxopmã'ax xohix kopit. Kãmãnat hãm kummuk, puxi' yõg hãpxopmã'ax xaxogã'.
\v 14 'Ũxuxyã te mĩptut max mĩy, puxix kuxap hã mõ'xut 'ohnãg, yã' yũm ka'ok. Kaxĩy kãmãnat hãm max Topa tu', puxix Topa yõg hãpxopmã'ax kopit, nũy nõ kãmãnat ha hãmmaxnã xexka'.
\v 15 Mĩptut kummuk mõ'xut kuxap hã, puxix kãmãnat te hãmhok xip, tu tayũmak pop 'ohnãg, pãyã' xok'ah. Kaxĩy Topa yõg kãmãnat hãm kummuk, puxix yãy kuxa tup, Topa te' tupmã hah, tu Topa yõg putat hãmhok hã' mõg, pãyã Topa te nõm kãmãnat pu pexkox yõg hãpxop 'a' hõm putup'ah.
\v 16 Yã 'ãxop Topa pet xe'e', 'ãkopa' xip tu', ha 'ãxop te hãmyũmmũg, ha Topa Koxuk te 'ãkopa' xip,
\v 17 yĩy Topa te 'ãpẽnã max, 'ãkopa' pet tu'. Tikmũ'ũn gãy te 'ãkoxyõy putup, puxix Topa' yãnãn tu 'ũkoxyõy, 'ãxop yã Topa pet xe'e'.
\p 
\v 18 Pũyã 'ãmũn yãy hã mõ'ãmã hok. Tikmũ'ũn te hãmpe'paxex, hu: “'Ãte hãmyũmmũg xexka'!” kaxĩy, pãyã' hitop tu hãmpe'paxex, yã Topa te: “'Õhõm hãmyũmmũg 'ohnãg, 'ũkuxa mãm 'ohnãg tu',” kaxĩy.
\v 19-20 Topa hã' puknõg xop te: “Yã hãmyũmmũg nõ'õm,” kaxĩy, puxix Topa te: “Pũyã yãy hã mõ'ãmã', hãmyũmmũg hok tu'!” kaxĩy. Yĩy Topa yõg tappet te: “Topa te yãy mũn hã' puknõg xop yũmmũg, tu' yõg hãmpe'pãnõm yũmmũg, ha hãmyũmmũg 'ũhitop tu', tup-tox kummuk xop putuk,” kaxĩy.
\v 21 Pũyã tikmũ'ũn yãy mũn xexka 'ãktux hok, tu yãy yõg hãpxopmã'ax tu' kuxa hittup hok. Yã hãpxop xohix 'õgnũ', pu Topa xa hãmmaxnã'.
\v 22 Yĩy Paot, xix 'Apot, xix Pet, 'ũxohix te 'ãpẽnã max, ha Topa te hãm xexka mĩy, nũy 'ãkuxa hittupmã'. Tu 'ãkuxa hĩnnãhã', xayĩy 'ãxakix 'ĩhã, 'ãmõg pexkox hah. Yã hõnhã Topa te mõ'ãyãy xe'ẽgnãg, xix hõmã mõ'ãyãy xe'ẽgnãg, xix hãptup 'ĩhã mõ'ãyãy xe'ẽgnãg putup. Yã' xohix 'õgnũ',
\v 23 ha 'ãxop yã Kunnix yõg tikmũ'ũn, ha Kunnix yã Topa yõg hãmyãykutnã'ax xe'ẽgnãg.
\c 4
\s1 Yeyox yõg mõ'pok xop
\p 
\v 1 'Ũgmũ'ãte xa hã Kunnix yõg kãmãnat, tu hãpxopmãhã', nũy Kunnix pupi xa hãmyũmmũgã', nũy xa Topa yõg hãm'ãktux xe'e 'ãktux,
\v 2 Yĩy Topa tek mũg xat 'ũ hãpxopmã max, nũy xa hãmyũmmũgã' max, ha yũmũg xuxyã tek mũ yõg hãpxopmã'ax pẽnãp-tup, nũy yũmmũg, 'ok pek mũ'ãte hãpxopmã max, 'ok pek mũ'ãte hãpxopmã kummuk.
\v 3 'Ãxop tek mũg hãm'ax pẽnãp-tup. Pũyã tikmũ'ũn pa te hãmyũmmũg tuk mũg hãm'ax pẽnã'. Yã' hitop. 'Ãte yãy yõg hãm'ax pẽnã hok yãy pu kamah.
\v 4 'Ũgkuxa te' mĩy max 'ãktux, pa yũmũg xuxyã puxet tek hãm'ax pẽnãhã', tu' yũmmũg, 'ok pek hãm max, pek hãm kummuk.
\v 5 Yĩy 'ãnõy yõg hãpxopmã'ax kopit hok, nũy nõ 'ãktux kummuk. Nãy, 'ũhip, pu Topa' kopit, 'ĩhã nũ'. Tute hãpxop xaptop'ax mũg putup, xix tikmũ'ũn yõg hãmpe'paxex yũmmũg putup, 'ĩhã Topa te hãpxopmã'ax max pu pago.
\p 
\v 6 'Ũkxape xop, 'ãte xa hãm'ãktux tap, tuk mũn 'ãktux, xix 'Apot 'ãktux. 'Ãtek mũg 'ãktux, xayĩy 'ãxop hãmyũmmũg, ha tappet te' xat, hu: “Tappet yõg hãm'ãktux pu 'ĩpkox pi',” kaxĩy. Yã' kummuk, tik 'ũm 'ãktux max, 'ĩhã' nõy 'ãktux kummuk.
\v 7 'Ok 'ãxop te yãy xexka pe'ãpaxex? 'Ok 'ãxop te 'ãnõy kutõgnãg pe'ãpaxex? Yã' kummuk. Topa mũn te xa hãmmaxnãhã', tu' hok hã hãmmaxnãhã', xayĩy yãy hitop xexka 'ãktux hok!
\p 
\v 8 'Ãxop yã yãy pe'ãpanõm 'ũptexop, tu yãy pe'ãpanõm 'ãxexka xop, tuk mũg pe'ãpanõm kutõgnãg xop, Pãyã yãy mõ'ãmã'. 'Ũyã yũmũg xohix xexka xop!
\v 9 'Ãte hãmpe'paxex. Yãk mũ'ã mõ'pok xop, pe Topa hã yũmũg ka'ax xop, nũy tikmũ'ũn 'ũgmũg kix, 'ĩhã xohix te' pẽnãhã', xix pexkox yõg nũ'pok xop xohix te' pẽnã kamah.
\v 10 Ha Topa hã' puknõg xop te: “'Ũp-tox kummuk,” kaxĩy, huk mũg 'ãktux, tu 'ãxop 'ãktux max, pãyã yũmũg xohix Kunnix yõg tikmũ'ũn. Hak mũg pu'uk, pa 'ãka'ok, ha 'ãp-tup pax, pak mũg putup nõg.
\v 11 Yã putup tek mũg kix, hak mũ'ãte kõnãg tat'ax xak. 'Ũgmũg xax kunox, ha' gãy xop tek mũg kix, tu mũg xũygãhã', 'ak pet 'ũm yũm'ah.
\v 12 Tuk mũg hãm punethok nũy xit, 'ĩhã tikmũ'ũn te: “Pũyã Topa 'ãkix!” kaxĩy. Hak mũ'ãte hãm'ãktux hã' yãnãn, hu: “Pũyã Topa xa hãmmaxnã'!” kaxĩy. Hak mũg kummugãhã', pãyãk mũ'ãte' gãy xop yõg hãm'ãktux kummuk hã' tot, tu hãmmax hip.
\v 13 Ha' gãy xop tek mũ'ã hãpkummugãhã', tuk mũg mãnõg, 'ĩhãk mũg yĩy pu'uk, nũy nõy gãy kuxyã'. Yã Topa hã' puknõg xop tek mũg putup nõg, tu: “Mõg, nũy 'ãpep!” kaxĩy.
\p 
\v 14 'Ãte xa kax'ãmi', nũy xa hãmyũmmũgã'. 'Ãte 'ãxop putup pax, 'ũgkutok putuk hah, 'a 'ãte xa' hupmãp-tup'ah.
\v 15 Yã tik punethok te xa hãmyũmmũgã'ax, pak mũn puxet hã 'õg 'ãtak. 'Ãte xa hã 'ãtak, xa hãm'ãpak max'ax 'ãktux tu', ha 'ãkuxa mãm ka'ok Kunnix kopah.
\v 16 Hu 'ãte xa' kax, pu hãpxopmã max, nũy 'ũgmũn putuk. Yã 'ãte hãpxopmã max,
\v 17 hu 'ãte Timõn mõ'kutnãhã', tuk mũn hã 'ũgkutnã', pu hãpxopmã nũ mũtik, hak mũg tix hãm max yũmũg xuxyã pu'. 'Ãxutigãp-tup, xayĩy Topa yõg putat hã 'ãmõg ka'ok, yã 'ãkuxa mãm ka'ok Yeyox Kunnix kopah, ha taxĩy 'ãte hãmyũmmũgãhã', 'ũkuxa mãm ka'ok xop xohix pu hãmyũmmũgãhã'.
\p 
\v 18 'Ãxop yãy xexka pe'ãpanõm, kopxix 'ãhak mõg hok.
\v 19 Topa 'ũgputup, 'ũ mõg, yã hãpxip kutõgnãg kopxik mõg, nũy nõm xop te hãpxopmã'ax yũmmũg. Ha' yĩy ka'ok, yãy xexka pe'ãpanõm tu'. 'Ãpu hãpxopmã ka'ok kamah!
\v 20 Topa te yãy yõg tikmũ'ũn xat, puyĩy yĩpkox pi' xe'e', nũy hãpxopmã max. Tikmũ'ũn te hitop tu hãm'ãktux, tu hãpxopmã max hok, puxix tu yĩpkox 'ohnãg.
\v 21 Pi'yã' mũn xatep-tup? 'Ok 'ũgmõg, nũy xikot hã 'ãkix'ax? 'Ok pep-tup, 'ũyĩy'ax pu'uk hã 'ãhittupmãhã'? Piya' mũn xatep-tup? Yã xatep-tup 'ũg 'ãhittupmã', yĩy hãpxopmã max.
\c 5
\s1 Tik te' nõy hã' xupxet
\p 
\v 1 Tikmũ'ũn te 'ãxop 'ãktux kummuk, yã 'ãxop 'ũm yõg tik 'ũm te' nõy hã' xupxet kummuk, yã' xonnix kummuk, ha tikmũ'ũn nõy te Topa hã' puknõg te' mĩy 'ohnãg. Yã tik te yãy tak xetut mũg, nũy nũ mũtik 'ãnõm, tu hãpkummuk mĩy pax.
\v 2 Tep te xĩy 'ãxop te yãy mũn max pe'ãpanõm? Yã 'ãkummuk! 'Ãpu yãyhãhup, nũy tik kummuk xupmã.
\v 3 'Ũyãk xihip nõmhã 'ãxop mũtik! 'Ãte tik yõg hãpxopmã'ax kummuk kopit, 'ĩhã hãptox tuk xip, ha yũmũg xuxyã Yeyox Kunnix te 'ã' hõm yãy 'ãxet'ax, 'ãte tik hãpxopmã'ax kummuk kopit.
\v 4 'Ũyãk xihip 'ãxop mũtik, 'ĩhã 'ãxop te yãy kotĩnnãhã', ha yũmũg xuxyã te 'ãka'ogãp-tup,
\v 5 xa tik kummuk hõm Hãmgãyãgnãg pu'. Pũyã tu xok, pãyã Topa te' kuxa kummuk xit, pu' koxuk tu xip ka'ok, 'ĩhã yũmũg xuxyã Yeyox Kunnix nũn putpu'.
\p 
\v 6 'Ãxop yãy mũn max pe'ãpaxex. 'Ap max'ah. Xate hãm hittap yõg hãm'ãktux yũmmũg, yĩy: “Pãm yõg tokatogã'ax kutĩgnãg te pãm xexkanãhã',” kaxĩy.
\v 7 Yã tokatogã'ax te hãpkummuk mĩy'ax putuk, yĩy hãpkummuk mĩy kux, nũy tu max, tu pãm putuk'ax, pãm tokatok hok putuk, yã' tũmnãg. Hãpxip kutõgnãg 'ĩhã 'ũgmũ yõg Yoneo xop te 'ãmuk xexka 'ãxet'ax Nõã'yẽn mĩy putup, 'ĩhã kahnẽn putex, pu' xohix' mã'. Ha Kunnix te yũmũ yõg kahnẽn xe'e', tu mĩpkupnix tu' xok tap yũmũg pupi', hu yũmũg hã kahnẽn xe'e'.
\v 8 'Ãpu yũmũg Kunnix pekpaxeh, nõm te yũmũg pupi' xok pekpaxeh, yã 'ãmuk xexka Nõã'yẽn putuk, yĩy yũmũ'ãte hãpkummuk mĩy kux, ha pãm yõg tokatogã hok putuk. Yã pãm te hãmyok mĩy'ax 'ãktux, xix hãmmaxnã'ax 'ãktux.
\p 
\v 9 'Ãte xa kax'ãmi tap, pu tikmũ'ũn kummuk mũtik 'ãkotĩnnã hok, nõm tikmũ'ũn te' nõy hã' xupxet.
\v 10 'Ãxop te hãm xexka tu' pip, yĩy hãpkummuk mĩy xop te xa yãy kote' pip. Yĩ' xohix tu 'ãxop 'ãxatat hok. Ha nõm kummuk xop te' nõy hã' xupxet, xi' nõy yõg hãpxop putup pax, xix hãpxopmã kummuk xix topa komut pu nũ' xup.
\v 11 Pa tikmũ'ũn te yãy 'ãktux, tu' kuxa yũm ka'ok'ax 'ãktux, tu hãm'ãktux max, pãyã' nõy hã' xupxet kummuk, xi' xupkumĩy, xix topa komut pu nũ'xup, xix kenmuk xo'op tu mõktu paptux, xi' nõy kupex, xix hãpxop hã' xupxet, puxix nõm tu 'ãxatat, nũy nũ mũtik 'ãxit hok.
\p 
\v 12-13 'Ãte Topa hã' puknõg xop yõg hãpxopmã'ax kopit hok. Yã Topa mũn te' kopit putup. Pa 'ãxop te yãy yõg hãpxopmã'ax kopit'ax. Yã' max xa' kopit. Topa yõg tappet te: “Tikmũ'ũn kummuk xupmã', puyĩy 'ãxop mũtik tu ti hok,” kaxĩy.
\c 6
\s1 Tikmũ'ũn te' nõy kumĩy kummuk
\p 
\v 1 'Ãxape te xa hãpkummugã', 'ãpu 'ãxape nõy ha mõg, 'ãxape pa te hãmyũmmũg ha 'ãmõg, pu 'ãtix kopit. 'Ãmõg hok Topa hã' puknõg xop hah, pu tu' kopit, pãyã 'ãxape ha 'ãmõg, tik kuxa yũm ka'ok Yeyox kopa ha 'ãmõg.
\v 2 'Ok yũmmũg hok xate'? Topa yõg tikmũ'ũn te Topa hã' puknõg xop hãpxopmã'ax kopit putup. 'Ok 'ãpa te hãmyũmmũg hok?
\v 3 Yã yũmũ'ãte pexkox yõg nũ'pok xop yõg hãpxopmã'ax kopit putup kamah, hu yãy xape yõg hãpxopmã'ax kopit'ax nõmhã, puyĩ' nõy hã tu xape 'ũxeheh.
\v 4 'Ãxape te 'ãkte'ex kummuk, yã hãpxopmã'ax kutĩgnãg, ha 'ãxape kummugãp-tup 'ũyãnãn tu', puxix tik puknõg tu' xax hok, puyĩy tu' kopit. Kaxĩy hok.
\v 5 'Ok yãyhãhup hok xate'? 'Ok 'ãxop mũtik xip hok tik pa te hãmyũmmũg, puyĩy 'ãtix hu' kopit max?
\v 6 Yã' xip! 'Ãte' yũmmũg! Pa 'ãxop gãy, tu' kuxa mãm hok xop ha 'ãmõg, nũy tu' xax, pu 'õg hãpxopmã kummuk'ax kopit.
\p 
\v 7 'Ãxop yãytukmĩy tik puknõg keppah, yã' kummuk. 'Ok xate hãmyũmmũg'ax xohix xaxok? 'Ũtux hok pu 'ãxape 'ãkummugã'. 'Ũtux hok pu 'ãxape 'õg hãpxop pa'.
\v 8 Pa 'ãxop te 'ãxape pu kummugã pax, ha' nõy yãnãn tu 'ãkummugã pax. 'Ãhup! Puxi'! 'Ãxop xape xop.
\v 9-10 Tikmũ'ũn kummuk te pexkox ha' mõg 'ohnãg, nõm xop Topa pu' yĩpkox 'ohnãg, 'ap mõg putup'ah hãpkummuk mĩy'ax xop xohix, nõm te' nõy hã' xupxet, xix nõm te topa komut pu nũ'xup, xix nõm te' nõy xetut hã' xupxet, xi' nõy yĩpxox hã' xupxet, xix nõm tik te tik nõy pẽnã kummuk, xix 'ũn te 'ũn nõy pẽnã kummuk xix nõm te hãpxop hã' xupxet, xix nõm xupkumĩy, xix nõm te kenmuk xo'op tu mõktu paptux, xix nõm te' nõy kupex, xix nõm te hãpxopmã kummuk pax.
\v 11 Hõmã 'ãxop 'ũm te hãpxopmãhã kaxĩy, pa Topa te 'ãkuxa tupmãhã', xa 'ãkuxa max, ha hõnhã 'ãxop te Topa hã tikmũ'ũn, yũmũg xuxyã Yeyox Kunnix hã 'ãxop yã Topa yõg tikmũ'ũn, xix Topa Koxuk hã 'ãxop yã Topa yõg tikmũ'ũn.
\s1 Topa tu hãpxopmã max
\p 
\v 12 Pa tikmũ'ũn 'ũm te hãm'ãktux'ax, hu: “'Ãte yãy putup'ax xohix mĩy'ax,” kaxĩy. Hamũn. Pãyã yãy putup'ax mĩy, puxix xa kummugã'ax. 'Ãte hãpxopmã'ax xohix kamah, pa 'ãte' tux hok, pu nõ hãpxopmã'ax 'ũgkummugã hok.
\v 13 Pa tikmũ'un nõy te hãm'ãktux'ax, hu: “Topa te hãpxop xit'ax mĩy pu tikmũ'ũn mã', ha Topa te tikmũ'ũn tex mĩy, puyĩy tikmũ'ũn nõ tu xit,” kaxĩy. Hamũn. Pa Topa te tikmũ'ũn tex nõãp-tup, xi' xit'ax nõãp-tup kamah. Yã yũmũg yĩn mĩy, 'ũyĩy yũmũg hãpxopmãhã yũmũg xuxyã tu', yũmũg yĩn 'ũm mĩy'ah, 'ũyĩy yũmũg nõy hã' xupxet. 'Ãmhok. Yã yũmũg yĩn yã yũmũg xuxyã yõg.
\v 14 Topa te yũmũg xuxyã putpu' hĩnnãhã, hu yũmũg hĩnnã'ax putpu kamah, 'ũka'ok tu'.
\p 
\v 15 'Ok 'ãxop te hãmyũmmũg hok? 'Ãxop yã Kunnix hã 'ãyĩn puxet, Yã' kummuk xexka, xa Kunnix yõg tik te xotit mũtik 'ãnõm. Yã' xotit hã' yãyhã yĩn puxet. Pũyã Topa 'ãtux hok, xayĩy 'ãnõm hok!
\v 16 'Ok 'ãxop te hãmyũmmũg hok? Yã tik te xotit mũtik nõm, puxix 'ũn hã' yĩn puxet, Topa yõg tappet te: “Yã' tix te yãyhã' yĩn puxet,” kaxĩy.
\v 17 Pa tikmũ'ũn kuxa yũm ka'ok Yeyox kopah, puxix tu kuxap-xet yũmũg xuxyã kuxa mũtik.
\p 
\v 18 'ũg'ãpax, xayĩy 'ãnõy hã 'ãxupxet hok. Hãpkummuk mĩy'ax nõy tikmũ'ũn yãy yĩn kummugã'ah, pa tikmũ'ũn xonnix, puxix yãy yĩn kummugã'.
\v 19 'Ok 'ãxop te hãmyũmmũg hok? Yã Topa Koxuk xip 'ãkopah, ha Topa te nũ'kutnãhã', pu 'ãmũtik tu xip ka'ok, 'ãxop yã yãy mũn xat'ah, 'ãmhok, yã Topa te yãy yõg tikmũ'ũn xat.
\v 20 Topa te 'ãpop, tu hãpxopmã ka'ok, nũy 'ãkuxa tupmã', yã yãy kutok xok 'ãxop pupi', nũy 'ãkuxa tupmã', yĩy hãpkummuk mĩy hok, puyĩ' puknõg xop pẽnã', tu: “'Ãxop yõg Topa max, tu 'ãka'ogãhã', xayĩy hãpxopmã max!” kaxĩy.
\c 7
\s1 Tikmũ'ũn te yãyta'ax
\p 
\v 1 'Ãxop te 'ã' kax'ãmi tappet tu, tu tappet tu yãy 'ãktux, tuk yĩkopit, tu: “'Ok max tikmũ'ũn yãytax?” kaxĩy. Yã' max pu yã tik yãytax hok, nũy yã' hok xip,
\v 2 pa tikmũ'ũn punethok te' nõy hã' xupxet, yĩy 'ãte: Yã' max tik yãy yõg 'ũn mũy, pu 'ũn kamah yãy yõg tik mũy.
\v 3 'Ãte xe' xat, pu' yĩpxox yãy xetut mũtik tu nõm max, xi' xat, pu' xetut yãy yĩpxox mũtik tu nõm max.
\v 4 'Ũxetut yĩn yã' yĩpxox yõg yĩn, yĩ' yĩpxox te' xat, ha' yĩpxox yĩn yã' xetut yõg yĩn, yĩ' xetut te' xat.
\v 5 Xatix yãy mũn hõm, nũy 'ũ nũ mũtik 'ãnõm, nũy 'ãti ka'õk. Pa Topa pu hãm'ãktux pax, 'ĩhã 'ãp-tox puxet xix 'ãkuxap-xet, hu ta hãpxip kutõgnãg 'ĩhã 'ãhok 'ãnom. Pa hãm'ãktux kux, 'ĩhã nũ mũtik 'ãnõm 'ũxeheh, pu Hãmgãyãgnãg xatix kummugã hok, 'ãnõm putup hah.
\p 
\v 6 'Ãxep xat'ah 'ãte nõmhã, pãyã xa hãmyũmmũgãhã'.
\v 7 'Ãtep-tup, pu tikmũ'ũn xohi' hok pi', 'ũgputuk nũy, pa Topa te tikmũ'ũn xohix ka'ogãhã', pu tu hãpxopmã max, tu tik puxet ka'ogãhã pu' hok xip, xi' nõy ka'ogãhã pu yãyta max.
\p 
\v 8 Yĩy 'ãte' hok pip xop pu hãm'ãktux, puyĩ' hok pi', hu yãyta hok 'ũg putuk nũy. Ha' hok mãm xop pu 'ãte hãm'ãktux kamah, pu' hok mãm.
\v 9 Yãytap-tup te 'ãp-tex, 'ãpu yãytax. Yãyta'ax 'ũmax, yãytap-tup xũy mũn yã' kummuk, yã kuxap putuk 'ãkopah.
\p 
\v 10 Ha 'ãte tikmũ'ũn yãyta xop pu hãm'ãktux, yã yũmũg xuxyã te' xat, pu tu yãy xatat hok.
\v 11 Yãy xatat, puxi' hok xip, tu' nõy mũg hok, tu mõktu xe yãy yĩpxox mũg, xix yãy xetut mũg, nũy nũ mũtik tu ti ka'ok 'ũxeheh.
\p 
\v 12 Tikmũ'ũn nõy pu 'ãte hãmyũmmũgãhã', 'ap Topa te' xat'ah. Tikmũ'ũn kuxa yũm ka'ok Kunnix kopah, ha 'ũn mũg, nõm kuxa yũm 'ohnãg, tu' yĩpxox mũtik tip-tup, puxix 'ãti'. Pũyã' xetut nĩm hok.
\v 13 Ha 'ũn nõy kuxa yũm ka'ok Kunnix kopah, tu tik mũg, nõm kuxa yũm 'ohnãg, ha' yĩpxox te nũ mũtik nõm putup, puxix 'ãti'. Pũyã' yĩpxox nĩm hok.
\v 14 Yã Topa te' yĩpxox ha hãmmaxnã'ax, tu' xetut kuxa yũm'ax hã hãmmaxnã'ax, tu 'ũn nõy ha hãmmaxnã'ax, 'ũyĩpxox kuxa yũm'ax hã' hãmmaxnã'ax, puyĩy tuk-tok xohix hu Topa yõg, ka Topa hã' puknõg xop putuk, nõm te Topa yũmmũg 'ohnãg.
\v 15 Pe' yĩpxox kuxa yũm hok te' xetut nĩm putup, pe' xetut kuxa yũm hok te' yĩpxox nĩm putup, pũyã 'ã' nĩm, ha' kux. Pũyã' kuxa mãm ka'ok xop pip. Yã Topa te yũmũg kuxa mãmmãhã', 'ũyĩy nõy xop mũtik tu ti max.
\v 16 'A xate hãmyũmmũg'ah, 'a 'ãnõy kuxa yũmmũg'ah. 'Ok pe' kuxa yũm'ax Kunnix kopah, 'ok pe' kuxa yũm hok. Pũyã mõg, 'ũgmĩy hok.
\s1 Topa pu' yĩpkox xihip
\p 
\v 17 Pũyã tikmũ'ũn xohix hãpxopmã max. Topa te' xãnãhã', pu tu hãpxopmã max tikmũ'ũn kopah. Pũyã tu pip ka'ok, nũy yãy yõg hãpxopmã'ax mĩy. Yã 'ãte tikmũ'ũn kuxa mãm xop xohix pu hãmyũmmũgãhã'.
\v 18 Tik te yãy nãg xax yĩmap tu' xak tap, 'ĩhã Topa te' xãnãhã', puxi' xak hok, nũy koex xut. Ha tik te yãy xax xak 'õhnãg 'ĩhã Topa te' xãnãhã', puxi' xak hok, nũy xax xak hok.
\v 19 Yã' xax xak'ax, xi' xax xak hok, yã Topa pu yãy putuk, pa Topa yõg xat'ax pu 'ĩpkox pi', nũy hãpxopmã max.
\v 20 Pũyã' xohix hãpxopmã max, Topa te' xãnãhã', pu tu hãpxopma max tikmũ'ũn kopah. Pũyã tu' pip ka'ok, nũy yãy yõg hãpxopmã'ax mĩy.
\v 21 'Ok 'ãhãm 'ãxat'ax pu, 'ĩhã Topa te 'ãxãnãhã'? 'Ok 'ãhok hã 'ãhãm, tu tayũmak 'ũm pa hok? 'Ũxutigã hok, pa mõg'ax nũy 'ãnõy pu 'ãhãm, nũy tayũmak pop, puxi mõy, tu' hãm.
\v 22 Yã yũmũg xuxyã te 'ãkuxa kummuk xut, 'ĩhã 'ãxãnãhã', tu' xut, xa mõg, xayĩy yũmũg xuxyã hã 'ãptix, nũy nõm pu 'ãyĩpkox xihip. Kamah tik hãm 'ũnõy pu', nũy tayũmak pop, yã kamah Kunnix hã 'ũptix, nũy yũmũg xuxyã pu' hãm 'ũhok hã, nũy nõm pu' yĩpkox xip.
\v 23 Topa te yãy kutok nũ'kutnãhã', pu 'ãxop pupi tu xok. Yã yãy kutok yãp-xehnãg, ha Topa te mõ'yãy xe'ẽgnãg, pãyã nũ'kutnãhã', pu 'ãxop pupi tu xok, puyĩy 'ãxop hã 'ãxuxyãp-xet.
\v 24 Topa te 'ãxãnãhã', tu 'ãyĩmõgatux. 'Ãpu pi ka'ok, nũy Topa pu 'ãhãm mõ kuma mõg.
\p 
\v 25 'Ũkxape xop: Xatek yĩkopit, hu: “'Ok max tikmũ'ũn yãytax?” kaxĩy. Topa tek xat'ah, 'ũyĩy 'ãte' hok pip xop pu hãm'ãktux, pãyã 'ãte hãmpe'paxex max, ha Topa tek kuxa ka', yĩy 'ãte nõm xop pu hãmyũmmũgã'ax.
\v 26 Hõnhã' gãyxop te yũmũg xũygã punethok, yĩ' max, pu tu tik yãyta hok.
\v 27 'Ok xate 'ũn mũg'ax, nũy yãytax? 'Ãpu, yãyta'. 'Ok yã' hok 'ãxip? 'Ãpu 'ãhok xihip.
\v 28 Yã' max pu' xetut mũy, yã hãpkummuk 'ohnãg. 'Ũn hok yũm yãytax, hu ta hãmmax mĩy, pãyã' yãykuxop'ax punethok, ha 'ãte 'ãp-tup'ah, xa yãykuxop.
\p 
\v 29 'Ũkxape: 'Ãte xa hãm'ãktux, nũy xa hãmyũmmũgã'. Yã hãmyãxatamuk xohix yõg 'ãmnĩy xox putox, ha hãpxip kutõgnãg 'ĩhã tikmũ'ũn xohix hok pip'ax putuk hãpxopmãp-tup, 'ok pe' yãytaha', 'ok pe' yãytahok.
\v 30 Ha' kuxa hittup 'ohnãg xop te' kuxa hittup xop putuk'ax, xi' kuxa hittup xop te' kuxa hittup 'ohnãg xop putuk'ax, xix hãpxop pop xop te hãmhõgnãg pip xop putuk'ax,
\v 31 ha nõm xop te hãpxop hã' hãm xop te' nõy xop putuk'ax, nõm xop te' yãykuxop 'ohnãg putuk'ax. Yã hãpxip kutõgnãg 'ĩhã hãm xexka nõg putup.
\p 
\v 32 'Ãte 'ãp-tup nõg, xa yãy kuxop, nũy hãpxop xak'ax tat. 'Ũhok pip xop te yũmũg xuxyã xak, nũy tu hãm max, puyĩy tu xuxyã kuxa hittupmã'.
\v 33 Pa' yĩpxox xop te hãpxop xak'ax tat, puyĩ' xetut kuxa hittupmã'.
\v 34 Tu yũmũg xuxyã pu hãpxopmã kamah, yĩp-tox tix, xi' kuxa tix. Ha' xetut xop te yũmũg xuxyã pu hãpxopmãp-tup, yãp-tixix, pa' yĩpxox kuxa hittupmãp-tup kamah, hu yãykuxop, tup-tox tix, xi' kuxa tix.
\p 
\v 35 'Ãte 'ãxop hãk putup, nũy mõ'ãnĩynãm, yĩy xa hãmyũmmũgãhã'. 'A 'ãte 'ãkummugãp-tup'ah, pãyã 'ãp-tup, xa 'ãxop hãpxopmã max, nũy tu mãynãg mĩy, nũy 'ãkuxa hittup, nũy 'ap-tox puxet hã, xix 'ãkuxa 'ãkuxap-xet hã Topa xa tu hãm.
\p 
\v 36 Tik te yãyta'ax, pa yãyta hok pe'paxex, tu' xetut 'ap nõm yũmmũg'ah, tu' mũg putup, pũyã' mũy. 'Ap hãpkummuk 'ũm mĩy'ah.
\v 37 Pa tik te' hok xip putup tu yãy hok, tu' max pe'paxex, pu' xetut nĩm, nũy nũ mũtik nõm 'ohnãg, puxix yãyta hok, pãyã' hok xihip.
\v 38 Tik te' xetut xip tap mũg, nũy nũ mũtik yãytax, yã hãpxopmã max, pa tik te' mũg 'ohnãg, nũy yã' hok xip, yã hãpxopmã max xe'ẽgnãg.
\p 
\v 39 'Ũn te' yĩpxox mũg, nũy nĩm hok, pa' yĩpxox xok, puxix tu kux. Yã' max. pu' nõy mũy, nũy xe yãytax, nũy nõy kuxa yũm ka'ok'ax mũtik yãytax.
\v 40 Pa 'ãte hãmpe'paxex, hu: Yã' max xe'e, pu' hok tu xip ka'ok. Yã kaxĩy Topa Koxuk te 'ã hãmyũmmũgãhã'.
\c 8
\s1 Tikmũ'ũn te xogyĩn hõm topa komut xop pu'
\p 
\v 1 'Ãxop tek yĩkopit, hu: “'Ok max, 'ũgmũg xit'ax xohix mã'?” kaxĩy. Yĩy 'ãte hãpxop xit'ax 'ãktux putup, tikmũ'ũn te' xit'ax hõm topa komut xop pu'. Tikmũ'ũn te hãpxe'e 'ãktux, hu: “Yũmũg xohix te hãmyũmmũg,” kaxĩy. Pa hãmyũmmũg'ax kutõgnãg te hãpkummugãhã', 'ĩhã tikmũ'ũn yãy mũn xexka pe'paxex, pãyã tikmũ'ũn te' nõy putup pax, tu' nõy ka'ogãhã', tu hãmyũmmũg xe'e'.
\v 2 Tikmũ'ũn te yãy pe'paxex, hu: “'Ãte hãmyũmmũg!” kaxĩy, puxix hãmyũmmũg 'ohnãg,
\v 3 pa tikmũ'ũn te Topap-tup pax, puxix yã Topa te nõm yũmmũg.
\p 
\v 4 'Ãte xa topa komut 'ãktux'ax. Yũmũ'ãte' yũmmũg. Topa komut xop 'ap xe'e'ah. Yã mõ'ãmã'ax xop, Topa yãp-xehnãg xip pexkox tu',
\v 5 pa Topa hã' puknõg xop te komut xop 'ãxet “topah”, ha topa komut pip punethok, hãmnõgnõy tu' pip, xix hãm tu' pip, ha kamah tikmũ'ũn xuxyã punethok pip.
\v 6 Pa yũmũ'ãte Topap-xehnãg yũmmũg, yã Kunnix hã mũnũn tu yũmũg 'Ãtak, tu hãpxop xohix mĩy, ha Topa tu yũmũg hi'. Ha yũmũg xuxyã yãp-xet xip kamah, yã Yeyox Kunnix, tu hãpxop xohix mĩy kamah, yãy Tak mũtik, xi' hep xohix xop mĩy, hu yũmũg mĩy kamah.
\p 
\v 7 Pãyã' kuxa mãm ka'ok xop yã xohix te' yũmmũg'ah, 'ũyãg te topa koumut xop pe'paxex tap, xix hõnhã pe'paxex kamah, tu hãpxop xit'ax pe'paxex, hu: “Yã tikmũ'ũn te nõm xit'ax hõm topa komut pu',” kaxĩy. Tu' kuxa hittup 'ohnãg, tu' tux hok pu tu xit hok, 'ap xit'ax mãp-tup'ah.
\v 8 Pa hãpxop xit'ax 'ũm te yũmũg kuxa tupmã 'ohnãg, pu Topa yũmmũg putup! 'Ãmhok. 'Ok pe' xit'ax mã', 'ok pe' xit'ax mã hok, puxix yũmũg kuxa kummugã 'ohnãg.
\p 
\v 9 'Õg pa 'ãti', yãy putup'ax mĩy hok, ka xate 'ãxape pu'uk pu hãpkummugã', tu' mõgã kummuk, pu tu yãy pu hãpkummuk mĩy.
\v 10 'Ãxape kuxa yũm pu'uk, ha' kuxa te' tux hok pu' xit'ax 'ũm mã hok, tu 'ãxit pẽnãhã', xate komut xop yõg xit'ax mãhã', puxix 'ãxape' mãp-tup, 'ĩhã' kuxa te' tux hok pu' mã hok.
\v 11 Ha Kunnix xok 'ãxape pu'uk pupi', pãyã 'ãxape te Topa yõg putat xak, nũy 'ãpe mõg, nũy 'ãmũn pu' yĩpkox xip, yĩy ta 'ãnõy mõgã kummuk,
\v 12 tu 'ãxape kummugãhã', hu Kunnix pu hãpkummugãhã kamah, Kunnix te 'ãxape pupi' xok hah.
\v 13 Yĩy 'ãte xogyĩn mã hok, kak xape mõgã kummuk, pu tu yãy kuxa pu hãpkummuk mĩy, 'ũkxit hah.
\c 9
\s1 Yeyox te mõ tik kutnãhã'
\p 
\v 1 'Ok 'ãte yãy xat hok? Yãk xat. 'Ok Yeyox Kunnix te nũgkutnã hok? Yã nũgkutnãhã'. 'Ok 'ãte yũmũg xuxyã Yeyox pẽnã hok? Yã' pẽnãhã'. Yeyox pu 'ãte hãpxopmãhã', 'ĩhã xa hãm'ãpak'ax max 'ãktux, yĩy 'ãkuxa mãm ka'ok yũmũg xuxyã kopah.
\v 2 Yeyox Kunnix te nũgkutnãhã', pãyã' kuxa mãm xop nõy tek mũn pu' yĩpkox 'ohnãg, ha 'ãxop tek mũn pu 'ãyĩpkox pip, yã 'ãmõg Topa yõg putat hã, ha tikmũ'ũn xohix te' pẽnãhã', hu hãmyũmmũg, yã yũmũg xuxyã te nũgkutnãhã', 'ãte hãm'ãpak max'ax 'ãktux.
\p 
\v 3 Tikmũ'ũn tek kummuk 'ãktux, kopxix yãy 'ãktux,
\v 4 hu: 'Ok tux hok 'ã' hõm 'ũkxit'ax, xix xo'op'ax 'ũghãm hah?
\v 5 Pax 'ũkxetut mũy, ha' kuxa mãm ka'ok, 'ok 'ãxop tek tux hok 'ãte nõm mõgã', pu nũ mũtik mõg, nũy hãm'ãpak max'ax 'ãktux? Yã mõ'pok xop nõy te' xetut xop mõgãhã', yã yũmũg xuxyã Yeyox taknõy xop te' mõgãhã', xix Pet kama te' xetut mõgãhã'.
\v 6 Yã Maname xik mũn puxet hãm, 'ũgmũg yĩm hãk mũg hãm, nũy xit, nũy tu pip'ax tu' pago. Yeyox yõg mõ'pok xop nõy te' hok hã hãpxop pop, hãmyũmmũgã'ax tu' pop.
\v 7 'Ok xonat 'ũm hãm, 'ok yãy yĩm hã' hãm, nũy xit, nũy pip'ax tu' pago? 'Ap hãm'ah! Yã gohet te' pago. Tikmũ'ũn 'ũm te yãy yõg mĩnta xut hok, nũy mã'? Yã' mãhã'. 'Ũxohix te yãy yõg kup tu' xut mĩnta, tu' mãhã'. Maket 'ũm te' yõg mũnũytut hep xo'op hok? Yã' xo'op!
\p 
\v 8 'Ũxohix te' yũmmũg, yã hãpxopmã'ax max, pu yãy hãm'ax hã tu xit, xix tu pet, yĩy Mõyyex yõg xat'ax kamah yã hãm'ãktux,
\v 9 tu: “Mũnũytut tak yĩkox hĩy hok, puyĩ' xit hok, 'ĩhã' xuxnãg xetox xap mõy tu' tonnok. Pũyã' xux mã',” kaxĩy. 'Ok Topa te hãm'ãktux, tu mũnũytut tak putup pax'ax 'aktux? 'Ãmhok.
\v 10 Pa yũmũ'ã' xuktux, 'ũyĩy yũmũg yãy hãm'ax hã yũmũg xit, xik pet. Tikmũ'ũn te hãm'ãpak max'ax 'ãktux, puxix tik putuk, nõm te hãpxop xap xok, ha tikmũ'ũn te hãmyũmmũgãhã', puxix tik putuk, nõm te hãpxop ta'ax nũnnãhã', yã' xohix te yãy hãm'ax hã' xit, xi' pet. Kaxĩy Maname xik mũn hãm, nũy Topa yõg hãm'ãktux 'ãktux. Yã' hãm'ax xe'e'! \fig |src="HK00019B.TIF" size="span" copy="Horace Knowles revised by Louise Bass © The British & Foreign Bible Society, 1994." ref="1Korintios 9.10"\fig*
\v 11 'Ũgmũ'ãte xa hãm'ãpak max'ax 'ãktux. 'Ok 'axop tek mũ'ã ta nemẽn hok, nũy hãpxop 'ũgmũ'ã popmã 'ũyãnãn tu'? Yã 'ãxop te ta nemẽn.
\v 12 Yũmũg xuxyã yõg tik mõ'pok xop te' hip, xa tu' popmã hãpxop. Yã' max, pa 'ãxop tek mũ'ã' ta nemẽn hãmãxap.
\p Pãyãk mũ'ãte xa tu' xak hã hãmhõgnãg, nũy 'ãxop pu hupmã hok, nũy Topa puk mũg hãm max.
\v 13 'Ãxop te hãmyũmmũg. 'Ãmãnex xop te Topa pet xexka kopa' hãm, tu Topa pet tu' xit'ax pop, nũy mã', ha tikmũ'ũn te xokxop mõ'hap, nũy Topa pu hãxyã', ha 'ãmãnex xop te xogyĩn yãg paha', tu' mãhã'.
\v 14 Ha kaxĩy yũmũg xuxyã te' xat, pu' yõg kãmãnat xop kama tu xit, tu yãy yõg hãm'ãx hã' xit, tu hãm'ãpak max'ax 'ãktux hu hã' xit'ax pop hãm'ãpak xop tu'.
\p 
\v 15 Hãmyãxatamuk xohix hã 'ãte hãmyũmmũgãhã', tu hãpxop 'ũm xak 'ohnãg, xak mũ'ã pago, xix hõnhã 'ãte 'a' xak'ah kamah. 'Ũyãk xok, pãyã hãpxop 'ũm xak 'ãte putup'ah. 'A xak xet'ah 'ãte'.
\v 16 'Ãte hãm'ãpak max'ax 'ãktux pax, tuk hittup, pa' kummuk 'ãte yãy xexka pekpaxex, hãm'ãpak'ax 'ãktux tu'. Yã 'ãte ta nemẽn Topa pu', nũy hãm'ãktux. 'Ãte hãm'ãktux hok, puxix Topa 'ũgkummugã'.
\v 17 Yĩy 'ãte hãm'ãpak max'ax 'ãktux putup pax, tu hãmmax hip kamah, pu yũmũg xuxyã 'ã hãmmaxnã'. 'Ãte hãm'ãktux, Topa tek xat hah, yã Topa te 'ã' hõm 'ũghãm'ax.
\v 18 'Ok Topa te 'ã' pagop-tup? Tu te pago hã xĩy? Yãk kuxa hittupmãhã', nũy hãm'ãpak max'ax 'ãktux, nũy hok hã' xuktux, kaxĩy Topa te 'ã' pago, tuk kuxa hittupmãhã', ha 'ãte' nõy yõg tayũmak xak 'ohnãg.
\p 
\v 19 'Ãte yãy xat, nũy Topa yõg hãm'ãktux'ax 'ãktux, ha tikmũ'ũn tek xat 'ohnãg! Pa tikmũ'ũn xohix puk hãm, tuk hok hãk hãm, puyĩy tikmũ'ũn kuxa punethok mãm ka'ok Yeyox Kunnix kopah.
\v 20 'Ũkhãm Yoneo xop mũtik, kopxix 'ãte Yoneo xop yõg hãpxopmã'ax tat, puyĩ' kuxa mãm ka'ok Yeyox Kunnix kopah. 'A Mõyyex yõg xat'ax tek xat'ah, pa Yoneo xop mũtik xip, 'ĩhã 'ãte' xat'ax puk yĩpkox xip, nũy Yoneo xop hãk xape'.
\v 21 'Ũkxip puknõg xop mũtik, kopxix 'ãte Mõyyex yõg xat'ax xaxogãhã', puyĩy puknõg xop kuxa mãm ka'ok yũmũg xuxyã kopah. Pa Topa yõg xat'ax puk yĩpkox xip, ha Kunnix yõg xat'ax tek xat xe'e'.
\v 22 'Ũxip kuxa mãm pu'uk xop mũtik, kopxix 'ãte' yõg hãpxopmã'ax tat, nũy tu ka'ogã', puyĩ' kuxa mãm ka'ok. Ha kaxĩy 'ãte' hep xop xohix yõg hãpxopmã'ax tat, nũy hãpxopmã'ax xohix hã tikmũ'ũn 'ũm mõgã Topa yõg putat hã.
\p 
\v 23 'Ãte hãpxopmã'ax xohix tat, nũy hãm'ãpak max'ax 'ãktux, pu Topa 'ã hãmmaxnã'.
\v 24 Tikmũ'ũn mõg mõ'ka'ok, ha' xohix mõg, pãyã yãp-xehnãg xupep tap, xi' yãg nõy xohix mõxa tu kunãy tu', pãyã' xohix mõg, puyĩ' mõxa tap. Ha kaxĩy 'ãxop mõg.
\v 25 Ha tik xop mõg punethok, tu' xak, nũy tu xupep tap, tu' mõg mõ'ka'ok, pa tik puxehnãg xupep tap, tu kãnẽy mãynãg paha'. Pa hãmyãxatamuk xohix nõg 'ĩhã' kãnẽy yãykoxyõy, pãyã yũmũ'ãte mõxap-tup, tu pexkox tu mõxap-tup, 'ũyĩy pexkox yõg hãpxop xe'ẽgnãg pop, ha yãykoxyõy 'ohnãg.
\v 26 Kaxĩy 'ãte hãpxopmã max, tu Topa Koxuk puk yĩpkox xip, nũy hãmyok mĩy. 'A 'ãte hitop tu hãpxopmã'ah, pãyã mãynãg hãpxopmãhã', tu Topa pu hãpxopmã max.
\v 27 'Ãte yãy yõg putup'ax mĩy'ah, nũy tu hãpxopmã max mõg kumak mõg, tuk kuxa teknõg 'ohnãg, 'ũyĩy hãm'ãpak max'ax 'ãktux kux, puyĩy Topa te: “Xate hãpxopmã mãynãg, mã', mõnãy, nũy 'ũgyĩkãgnãg 'ãxip ka'ok!” Kaxĩy.
\c 10
\s1 Topa komut pu nũ'ãxup hok
\p 
\v 1 'Ũkxape xop, 'ãte hãm'ãktux putup, xayĩy xaxok hok. Hõmã 'ũgmũg mõnãyxop hittap te Mõyyex pe' mõg, 'ĩhã hãpxexka 'Eyit tu nũ'paha'. Hãmgõy xexka te' xohix mõ'nĩy, tu kõnãg xexka 'Ãta' xak.
\v 2 Tu hãmgõy xexka kopa' pip, xix kõnãg xexka hã mõxakux, 'ĩhã Mõyyex pe' mõg,
\v 3 'Ũxohix te pexkox yõg hãpxop puxet mãhã',
\v 4 tu pexkox yõg hep xo'op. Yã mĩkaxxap xexka tu' xo'op, ha kaxĩy Kunnix tu' xo'opmãhã', tu Kunnix mũtik mõg putat tox hã.
\v 5 Pa tikmũ'ũn punethok te Topa gãyãhã', hu' xakix hãm panip xexka tu'.
\p 
\v 6 Ha Topa te' xat, pu tik tappet mĩy, nũy yũmũ'ã hãpxopmã'ax xohix yũmmũgã', 'ũyĩy yũmũg hãpxop hitop xak hok.
\v 7 'Ãpu topa komut xop pu nũ'ãktettex hok, nũy Topa xe'ẽgnãg nĩm hok. Yã Topa yõg tappet te tikmũ'ũn hittap 'ãktux, tu: “Tikmũ'ũn mãm, nũy xit, nũy xo'op, tu' yok, nũy hãmyã' topa komut xop pu',” kaxĩy.
\v 8 'Ãpu yũmũg xonnix hok, yã tikmũ'ũn hittap xonnix punethok, yĩ' yãg xohix te 23.000 xakix, 'ãmnĩy puxet 'ĩhã' xakix.
\v 9 'Ãpu yũmũ'ãte Topa gãyã hok, hãpkummuk mĩy tu'. Yã tikmũ'ũn hittap te' gãyãhã', tu hãpkummuk mĩy pax, yĩy kãyã gãy te' kix.
\v 10 Yã tikmũ'ũn hittap te Topa gãyãhã', yĩy pexkox yõg mõ'kutnã'ax te' kix, yã mõ'kutnã'ax 'ãxet'ax 'Ũxok'ax.
\p 
\v 11 Ha tappet mĩy, nũy yũmũ'ã' yũmmũgã', 'ũyĩy tikmũ'ũn hittap putuk hok. Yã hõnhã hãmyãxatamuk xohix ka'ax, tu' xox putox.
\p 
\v 12 'Õg pa 'ãti'. 'Ãkuxãnõg, Topa tu' xax, pu mõ'ãnĩynãm, xayĩy hãpkummuk mĩy hok.
\v 13 'Ãxop te hãpkummuk mĩy putup, yãy yõg putup'ax kummuk tu' mĩy, ha kaxĩy tikmũ'ũn xohix te hãpkummuk mĩy putup, pa Topa te xa hãm'ãktux xex, tu 'ãka'ogã'ax, xayĩy hãpkummuk mĩy hok, yĩy Topa tu' xax, hu: Topah, mõknĩynãm, 'ũyĩy hãpkummuk mĩy hok!” kaxĩy, ha Topa te 'ãka'ogãp-tup.
\p 
\v 14 'Ãxop tek mũn hã 'ũg 'ãxape xop, hu 'õg pa 'ãti', pu topa komut pu nũ'ãk-tettex hok.
\v 15 'Ãte xa hãm'ãktux, 'ãxop te hãmyũmmũg hah, hu yõgnũ hãm'ãktux kopit max, 'ũyĩy 'ãxop yũmmũgã'. Yã Topa yõg hãm'ãktux xe'e'.
\v 16 Hõmã Kunnix te tik xop pu' hõm kãnẽy, ha mĩnta hep xupyãg 'ũkopa' xup, ha yũmũg xat, 'ũ yũmũg xupyãg xo'op kamah, pu yũmũ'ã ha hãmmaxnã', yĩy yũmũ'ãte kamah kãnẽy hã' xo'op, tu Topa pu: “'Ãmax Topah. Xate yũmũ'ã xupyãg xe'e' hõm, tu pexkox yõg xupyãg xe'e' hõm. Puxi',” kaxĩy. 'Ok hãmyũmmũg hok, xate'? Xate xupyãg xo'op, hu ta 'ãxape xop xohix mũtik xo'op, nũy yũmũg xohix pe'ãpaxex, ha yũmũg xuxyã xok, mĩpkupnix tu' xok, tu yãy hep 'ãta nũ'nãhã', nũy yũmũ'ã ha hãmmaxnã'. Ha yũmũ'ãte pãm koxip, nũy yũmũg xape xop mũtik mã', nũy yũmũg xuxyã pekpaxex. Yã yũmũg xuxyã te mĩpkupnix tu' xũy, nũy yũmũ'ã hãmmaxnã'.
\v 17 Yã pãm puxet, ha' xohix te' mãhã', yĩy Kunnix hã yũmũg yĩn puxet kamah, yã yũmũg kuxap-xet Kunnix kuxa mũtik.
\p 
\v 18 Yoneo yõg tikmũ'ũn pe'ãpaxeh. Tu Topa pet kopa' xit'ax mãhã', 'ĩhã' ãmãnex te mõ'hap, nũy Topa pu' haxyã'.
\v 19 'Ãtep-tep 'ãktux putup? 'Ok topa komut ka'ok? 'Ap ka'ok'ah, yã' hitop. 'Ok hãpxop xit'ax ka'ok, tikmũ'ũn te nõm topa komut xop pu' hõm? Yãmhok!
\v 20 'Ap ka'ok'ah. Pa tikmũ'ũn te nõm xit'ax hõm yãmĩy kummuk pu', 'ĩhã komut xop pu' hõm, 'ap Topa pu' hõm'ah. 'Ãtep-tup'ah, xa yãmĩy kummuk yõg hãpxop pop.
\v 21 'Ãxop te Topa yõg kãnẽy hã' xo'op, nũy yũmũg xuxyã pe'ãpaxex. 'Ãpu yãmĩy kummuk yõg kãnẽy hã xo'op hok. 'Ãxop te Topa yõg hãpxop mãhã', nũy yũmũg xuxyã pe'ãpaxex. 'Ãpu yãmĩy yõg hãpxop mã hok.
\v 22 'Ok yũmũ'ãte Topa gãyãp-tup? 'Ãkuxãnõg! Paxip! Topa ka'ok, ha ta yũmũg pu'uk.
\s1 'Ãnõy yõg putup'ax mĩy
\p 
\v 23 Tikmũ'ũn 'ũm te: “Yũmũ'ãte yãy putup mĩy'ax,” kaxĩy. Mõy mĩy, pãyã' mĩy'ax 'ũm te xa hãpkummugã'ax. Ha xe: “Yũmũ'ãte yãy putup mĩy'ax,” kaxĩy. Hamũn. Pa xate' mĩy'ax 'ũm 'ũhitop tu' mĩy.
\v 24 Yãy putup'ax mĩy hok, pa 'ãnõy putup'ax mĩy, nũy nõm kuxa hittupmã'.
\p 
\v 25 'Ãkuxa te yãy tux hok xa xogyĩn mã', 'ãpu, xogyĩn xohix mã', tu' nõy yĩkopit hok.
\v 26 Yã Topa yõg tappet te: “Hãm xexka yã Topa yõg, xix hãpxop xohix 'ũyõg kamah,” kaxĩy.
\p 
\v 27 Tikmũ'ũn kuxa mãm hok te 'ãxãnãhã xa 'ãxit, 'ãmõg putup, nũy mõg, nũy hãpxop xohix mã', hu 'ãnõy yĩkopit hok, ka 'ãkuxa 'ãkupex, hu 'ãhittup 'ohnãg.
\v 28 Pa tikmũ'ũn 'ũm te: “Nãy! 'Ũmã hok! Yã topa komut xop pu' hõm tap!” kaxĩy, 'ãpu' mã hok, ka 'ãkuxa 'ãkupex, hu' hittup 'ohnãg,
\v 29 xayĩy 'ãnõy pu hãpkummugã hok.
\p Ha tikmũ'ũn 'ũm te: ‘Tep tu 'ãtek nõy pekpaxex, nũy xogyĩn mã hok? Tep tuk yãy putup'ax mĩy hok?’
\v 30 Nãy, 'ãte Topa pu hãm'ãktux hãmãxap, hu: ‘'Ãmax Topah. Yã xate 'ã' hõm hãpxop,’ kaxĩy, tuk-nãy tuk xit. Tep tu tikmũ'ũn te 'ã xuktux kummuk? Yã Topa te 'ã' hõm xit'ax 'ũg 'ũmã',” kaxĩy.
\p 
\v 31 Hãpxopmã max, nũy Topa kuxa hittupmã', pe 'ãxop xit, peyã' xo'op, pe' yã hãpxopmã', nũy ta Topa pu: “'Ãmax Topah. Xate 'ã' hõm hãpxop max punethok. Puxi',” kaxĩy.
\v 32 'Ãpu hãpxopmã max, nũy Yoneo xop pu hãpkummugã hok, nũy puknõg xop pu hãpkummugã hok, nũy ta' kuxa mãm ka'ok xop pu hãpkummugã hok.
\v 33 'Ãpu hãpxopmã', nũy yõgnũ hãpxopmã'ax tat. 'Ãte' xak, nũy xohix kuxa hittupmã', 'ap yãy pekpaxex'ah, pak xape xop pekpaxex, 'ũyĩ' xohix mõgã Topa yõg putat hã.
\c 11
\p 
\v 1 'Ãpu yõgnũ hãpxopmã'ax tat. Yã kaxĩy 'ãte Kunnix yõg hãpxopmã'ax tat.
\s1 'Ũn xop te 'ãmũtik kotĩnnãhã'
\p 
\v 2 'Ãte xa hãm'ãktux max, xate yõg hãm'ãktux xaxok 'ohnãg hah, tu 'ã yĩpkox pip.
\v 3 Pa 'ãte 'ãp-tup, xa hãmyũmmũg. Yã Kunnix te' yĩpxox xat, ha' yĩpxox te yãy xetut xat, ha Topa te Kunnix xat.
\v 4 'Ap max'ah, pu tik xop kuxxax tat, nũy nõ yãykotĩnnã' pip, nũy Topa pu hãm'ãktux, xix Topa pupi hãm'ãktux 'ãxape xop pu'. 'A Kunnix tep putup'ah kaxĩy.
\v 5-6 Pa 'ũn xop tep-tox mõ'nĩy, puxix tu max. Kunnix tep putup. 'Ũtux hok pu 'ũn tep-tox mõ'nĩy, nũy yãykotĩnnã' pip, nũy Topa pu hãm'ãktux, xix Topa pupi hãm'ãktux 'ãxape xop pu'. 'A Kunnix tep putup'ah, 'ĩhã 'ũn tep-tox mõ'nĩy hok, tu 'ũn nõy putuk, nõm te' xe mõy. Pũyãp-tox mõ'nĩy, nũy yãyhãhup hok.
\v 7 Tik xop tep-tox mõ'nĩy hok. Yã Topa te' nõy yãy putuk ha' mĩy, pu Topa kuxa hittupmã', ha 'ũn te tik kuxa hittupmãhã'.
\v 8 Topa te tik mĩy hãmãxap, tuk-nãy tu tik kup tu' xut, nũy 'ũxetut mĩy.
\v 9 'Ap Topa te tik mĩy'ah, puyĩ' xetut hã tu tehe'. 'Ãmhok. pa 'ũn mĩy, puyĩy tik hã tu tehe'.
\v 10 Yĩy 'ũn xop tep-tox mõ'nĩy pexkox yõg nũ'pok xop hah, nũy pẽnã', nũy hãmyũmmũg. Yã' xetut te yãy yĩpxox pu' yĩpkox pip.
\v 11 Topa yõg putat hã tihik xix 'ũhũn te mõ'yãy nĩynãm.
\v 12 Topa te tik tu' kup xut, nũy 'ũn mĩy, ha kama tik te 'ũn tu' nãhã'. Yã Topa te hãpxopmã xohix.
\p 
\v 13 'Ãpu 'ãxop te' kopit: 'Ok max, 'ũn putox mõ'nĩy hok, nũy yãykotĩnnãhã' pi', nũy Topa pu hãm'ãktux?
\v 14 Tik mũn xe tox pu kummuk, yã Topa yõg tikmũ'ũn te' yũmmũg,
\v 15 pa 'ũn mũn xe tox pu max, tup-tox mõ'nĩy.
\v 16 Tikmũ'ũn 'ũm te hãm'ãktux putup yãnãn tu', tu xe tox 'ãktux putup, kopxix 'ãte tu xe hãm'ãktux, hu: 'Ũgmũ'ãte' xat, xi' kuxa mãm xop xohix te' xat, pu 'ũn xop tup-tox mõ'nĩy, nũy yãykotĩnnã' pi', nũy Topa pu hãm'ãktux.
\s1 Yũmũg xuxyã yõg xit'ax
\p 
\v 17 Hõnhã 'ãte xa hãmyũmmũg'ax nõy 'ãktux, 'ãxop te hãpxopmã kummuk hah. 'Ãxop te yãy tu nũ'ãnãhã', tu yãy kummugãhã'.
\v 18 Tikmũ'ũn te 'ã hãm'ãktux, tu 'ãxop 'ãktux, ha 'ãxop yãy tuk-mĩy pax, 'ĩhã yãy tu nũ'ãnãhã', nũy Topa pu hãm'ãktux, hak kuxa yũm kutõgnãg nõm hãm'ãktux kopah.
\v 19 Yã' max 'ãxop yãyxatat kutõgnãg, pu hãpxopmã'ax max xop tu mũg.
\v 20 'Ãxop yãy tu nũ'ãnãhã', nũy xit, nũy yũmũg xuxyã pe'ãpaxex, pu, 'ãxit hok.
\v 21 Yã 'ũyãg xit mõ'ka'ok, nũy 'ũhi mõ'ka'ok, ha' yãg putup xũy, ha' yãg nõy paptux.
\v 22 'Ok yã 'ãpet 'ũm yũm hok, hu ta xit xix xo'op, nũy 'ãhi'? Kaxĩy 'ãxop te' kuxa mãm ka'ok xop putup hok, xi' hok xop pu' hupmãhã'. Xatep tep pe'ãpaxex? 'Ok hãpxopmã'ax max nõ'õm? 'Ap max'ah! Yã' kummuk!
\p 
\v 23 Yũmũg xuxyã te 'ã hãmyũmmũgãhã', ha xa' yũmmũgã'ax, hu: Yũmũg xuxyã Yeyox te yãy yõg tik xop mũtik xit 'ãmnĩy hã, ha tikmũ'ũn gãy te' mũg'ax, nũy tup-tex, yĩy pãm pa' tap,
\v 24 tu Topa pu: “'Ãmax Topah. Tuk mũ'ã' hõm 'ãxit'ax max. Puxi'!” kaxĩy. Tu pãm koxip, tu: “Nũhũ 'ũgyĩn, yãk xok 'ãxop pupi'. 'Ũg pa', nũy mã', huk xaxok hok,” kaxĩy.
\v 25 'Ũxit kux, 'ĩhã yũmũg xuxyã te kãnẽy pa', tu: “Topa te' pa'ax tup mĩy tikmũ'ũn mũtik, tuk yĩn hep 'ãta hã' pa'ax mĩy, 'ũkxok tu'. 'Ãte yãy hep 'ãta nũ'nãp-tup, nũy pa'ax tup mĩy. Kãnẽy pa', nũy tu' xo'op, 'ĩhãk mũn pe'ãpaxex, nũy huk xaxok hok,” kaxĩy.
\v 26 'Ãxop te pãm mãhã', xix kãnẽy tu' xo'op, puxix yũmũg xuxyã xok'ax 'ãktux pax, ha mõktu putpu' nũn.
\p 
\v 27 Tikmũ'ũn kuxa kummuk te nõm pãm mãhã', xix nõm xupyãg xo'op, puxix Topa gãy, yũmũg xuxyã pe'paxex 'ohnãg hah, yĩy Topa te' kummugãp-tup 'ũyãnãn tu'.
\v 28 Yãy kuxa yĩkopit hãmãxap, nũy yãy yõg hãpxopmã'ax yũmmũg, nũy kunãy tu pãm mã', xix kãnẽy hã' xo'op.
\v 29 Tikmũ'ũn xit, xix xo'op, tu hãmpe'paxex 'ohnãg, tu yũmũg xuxyã pe'paxex hok, puxix Topa gãy, nũy tu' xũygã'. Yã yũmũg xuxyã xok yũmũg pupi', nũy yũmũg kuxa kummuk xit.
\v 30 Tikmũ'ũn punethok te hãmpe'paxex 'ohnãg, hu' pakut, xi' pu'uk, ha tikmũ'ũn 'ũm xakix tap.
\v 31 Tikmũ'ũn te yãy kuxa yĩkopit hãmãxap, nũy yãy hãpxopmã'ax yũmmũg, puyĩy Topa 'ũkuxa maxnã', puxix Topa' xũygã hok.
\v 32 Pa Topa te yũmũ yõg hãpxopmã'ax kopit, nũy tu' yũmmũg, tu yũmũg xũygãhã', 'ũyĩy Topa yõg putat xak hok, nũy Hãmgãynãgnãg pet hã yũmũg mõg hok Topa hã' puknõg xop mũtik.
\p 
\v 33 'Ãxop yãytu nũ'ãnãhã', nũy Topa yõg xit'ax mã', nũy yũmũg xuxyã pe'ãpaxex, 'ãpu 'ãxape xop hip.
\v 34 Putup te 'ãp-tex, yĩy ta yãy pet tu 'ãxit hãmãxap, tuk-nãy tu 'ãxape xop mũtik yãy kotĩnnãhã', pu Topa 'ãxop xũygã hok, 'ãxop te hãpkummuk mĩy hah. Ha hãpxopmã'ax nõy 'ãte' kopit putup, 'ĩhã 'ãxop mũtik 'ũkxip.
\c 12
\s1 Topa Koxuk te tikmũ'ũn ka'ogã'ax
\p 
\v 1 'Ũkxape xop, 'ãte 'ãp-tup, xa 'ãxop hãmyũmmũg max, nũy Topa Koxuk yã tikmũ'ũn ka'ogã yũmmũg, ha' kuxa mãm ka'ok xop ka'ogãhã', puyĩy hãpxopmã max.
\v 2 'Ãxop te 'õg hãpxopmã'ax hittap yũmmũg, 'ĩhã Topa hã 'ãpuknõg, ha topa komut xop yĩy hok te 'ãxat, tu 'ãmõgã kummuk.
\v 3 Yĩy 'ãte xa hãmyũmmũgãhã. Tikmũ'ũn 'ũm te: “Pũyã Topa Yeyox pu hãpkummugã',” kaxĩy, yã Topa Koxuk te' ka'ogã 'ohnãg, pu tu hãm'ãktux kummuk. 'Ãmhok. Ha tikmũ'ũn 'ũm te: “Yeyox yã yũmũg xuxyã!” kaxĩy, yã Topa Koxuk te' ka'ogãhã', pu tu hãpxe'e 'ãktux.
\p 
\v 4 Topa Koxuk te tikmũ'ũn ka'ogãhã', pu hãpxopmã max punethok, tup-xehnãg te' ka'ogãhã', pu tu hãpxopmã'.
\v 5 Ha yũmũ'ãte hãpxopmã punethok, nũy yũmũg xuxyã tu hãpxopmã', yã yũmũg xuxyãp-xet puk hãm.
\v 6 Ha tikmũ'ũn 'ũm ka'ogãhã', pu tu hãpxopmã', tu' nõy ka'ogãhã', pu tu hãpxopmã nõy, ha Topap-xet te' xohix ka'ogãhã', pu tu hãpxopmã'.
\v 7 Topa te' kuxa mãm xop xohix ha hãmmaxnãhã', tu' xohix tu' mũg. Yã Topa Koxuk te' kuxa mãm ka'ok xop xohix kopa' xip, ha Topa te' xip'ax tu' mũg, puyĩ' xohix pẽnã'.
\v 8 Topa Koxuk te tikmũ'ũn 'ũm ka'ogãhã', puyĩy' nõy mõ'nĩynãm hãm'ãktux hã, xi' nõy ka'ogãhã', puyĩ' nõy hãmyũmmũgã',
\v 9 xi' nõy ka'ogãhã', puyĩy kuxa yũm ka'ok, xi' nõy ka'ogãhã', puyĩy nõy pakut hittupmã
\v 10 xi' nõy ka'ogãhã', puyĩy hãpxopmã ka'ok xe'ẽgnãg, yã tikmũ'ũn puxet te' mĩy hok, xi' nõy ka'ogãhã', puyĩy Topa pupi hãm'ãktux, xi' nõy ka'ogãhã', puyĩy hãmyũmmũg, nũy Topa Koxuk yõg hãpxopmã'ax yũmmũg, nũy 'ũkoxuk puknõg yõg hãpxopmã'ax yũmmũg kamah, xi' nõy ka'ogãhã', puyĩ' yĩy'ax puknõg hã hãm'ãktux, xi' nõy ka'ogãhã', puyĩy nõ hãm'ãktux puknõg yũmmũgã'.
\v 11 Yã Topa Koxuk puxet, tu' kuxa mãm xop xohix ka'ogãhã', tup-tup, hu tikmũ'ũn ka'ogã'ax pu hãpxopmã punethok.
\s1 Kunnix hã 'ãyĩn puxet
\p 
\v 12 Tikmũ'ũn yĩn puxet, tu' kup punethok pip, ha' mãg te' yĩn kopa' pip punethok, xi' kuxa, xi' tex, yã' xohix, hã kaxĩy yũmũg xohix, tu Kunnix hãk yĩn puxet.
\v 13 Yã yũmũg xohip-tox pix, Topa Koxuk te yũmũg putox pix, nũy Kunnix hã yũmũg yĩn puxet. Yã yũmũg xohix, 'ok pe Yoneo xop, 'ok pe' puknõg xop, 'ok pe tayũmak pop tu yũmũg hãm, 'ok pe' xuxyã xat'ax pu yũmũg hok hã' hãm, yã yũmũg xohix te Kunnix hã' yĩn puxet. Ha Topa Koxuk te yũmũg xohix kopa' xip, yĩy yũmũg kuxap-xet Yeyox Kunnix kuxa mũtik.
\p 
\v 14 Ha' yĩn kup puxet'ah. 'Ãmhok. Yã' kup punethok.
\v 15 Pax pu' pata yĩy, tu hãm'ãktux, hu: “'Akmũn te yãk yĩm'ah, huk yĩn yõg 'ohnãg,” kaxĩy. Puxi' yã' yĩn yõg xe'e'.
\v 16 Pax pu' yĩpkox yĩy, tu: “'Ak pa'ah, huk mũn yĩn yõg 'ohnãg,” kaxĩy. Pãyã yã' yĩn yõg xe'e'.
\v 17 Pax pu' pa puxet xip 'ũyĩn kopah, puxix hãm'ãpak 'ohnãg. Pax pu' yĩpkox puxet xip 'ũyĩn kopah, puxix tu' hax 'ohnãg.
\v 18 Yĩy Topa te tikmũ'ũn mĩy, tu' yĩn mĩy, ha' kup punethok, xi' mãg punethok, 'ũp-tup ha' mĩy.
\v 19 Pax pu' kuxap-xehnãg xip, puxix tu kuxap-xet, 'ap yĩn'ah. 'Ãmhok.
\v 20 Yã' kopa' pip xop xohix hã' yĩn puxet.
\p 
\v 21 Pax pu tikmũ'ũn pa yĩy, nũy tu' yĩm pu hãm'ãktux, hu: “Mõg, 'ãte 'ãp-tupnõg,” kaxĩy. Yã' kummuk, 'ũhitop tu' xuktux. Ha kaxĩy 'ãxop yã 'ãkuxa mãm ka'ok xop, tu Kunnix hã 'ãyĩn puxet, tu 'ãxape xupmã hok.
\v 22 'Amhok. 'Ũyĩm xut, puxi' yĩn tu pu'uk, ha kaxĩy 'ãxop yãy xape xut hok, ka 'ãxop 'ãpu'uk kamah.
\v 23 Tikmũ'ũn te yãy yĩn mõ'nĩy, 'ũyãg mõ'nĩy, nũy nõ xex max,
\v 24 tu mõ' yãg nõy nĩy 'ohnãg. Hã kaxĩy Topa te tikmũ'ũn yĩn xohix mĩy, ha' xohix max,
\v 25 ha' yãyxatat 'ohnãg, yĩy yãy hã tu tehet.
\v 26 'Ũyĩn yãg xũy, puxix tu yĩn xohix xũy kamah. 'Ũyĩn yãg tap, puxix tu yĩn xohix tap. 'Ũkuxa mãm ka'ok xop te tikmũ'ũn yĩn putuk, 'ũyãg xũy, ha' nõy xop xohix hittup 'ohnãg.
\p 
\v 27 'Ãxop te Kunnix hã 'ãyĩn, yã 'ãxohix te Kunnix hã 'ãyĩn yãg.
\v 28 Topa te hãpxopmã mãynãg 'ũkuxa mãm ka'ok xop kopah, tu tik xop mõ'pok hãmãxap, hak-nãy tu tik xop nõy te Topa pupi hãm'ãktux, hak-nãy tu tik xop nõy te hãmyũmmũgãhã', hak-nãy tu tik xop nõy te hãpxopmã ka'ok xe'ẽgnãg, ha tikmũ'ũn puxet te' mĩy hok, hak-nãy tu tik xop nõy te' pakut xop hittupmãhã', xi' nõy xop te' nõy hã tu' tehet, xi' nõy xop te' nõy xat, xi' nõy xop te' yĩy'ax puknõg hã' yĩy.
\v 29 'A' xohix mõ'pok'ah, 'a' xohix te Topa pupi hãm'ãktux'ah, 'a' xohix te hãmyũmmũgã'ah, xix 'a hãpxopmã ka'ok'ah.
\v 30 'A' xohix te' pakut'ax hittupmã'ah, xi' yĩy'ax puknõg hã' yĩy'ah, xi' nõy pu 'a' yĩy'ax 'ũm yũmmũgã'ah.
\v 31 Yĩy Topa tu' xax, pu 'ãka'ogã', xayĩy 'ãnõy ka'ogã 'ũyãnãn tu'.
\p Pãyã 'ãte xa' mũg putup putat xe'ẽgnãg.
\c 13
\s1 'Ãnõy putup pax
\p 
\v 1 Pax tikmũ'ũn yĩy'ax hãk yĩy, xix pexkox yõg nũ'pok xop yĩy'ax hãk yĩy, pãyã 'ãtek nõy putup pax hok, kopxi' hitop tuk yĩy, yãk yĩy'ax te 'ãmãnex te xap kãyã'ax putuk, yã' kax ka'ok, pãyã hitop hã' kax, tu' nõy yũmmũgã 'ohnãg.
\v 2 Pax 'ãte Topa pupi hãm'ãktux, xix hãmyũmmũg xexka', xix hãm'ãktux xe'e yũmmũg, xik kuxa yũm 'ũm ka'ognãg, nũy yĩktix xut hãm tu', pap-tup pax hok, kopxi' hitop hã hãpxopmã'.
\v 3 Pax 'ãte yãy yõg hãpxop xohix popmã', xix yãy yĩn hõm pu mõ'hap, nũy Topa pu haxyã', pa 'ãtep-tup pax hok, kopxi' hitop hã hãpxopmã'.
\p 
\v 4 Tikmũ'ũn te' nõy putup pax, puxi' hip, tu nõã' tot, tu' nõy kuxa ka'. 'Ap yĩpkumĩy'ah, tu yãy mũn kutõgnãg pe'paxex, 'a yãy mũn xexka 'ãktux'ah,
\v 5 tu' yĩy pu'uk, nũy tu' nõy gãyã hok, 'ap yãy mũn te mãxap pe'paxex'ah, 'ap gãy'ah, 'a' nõy yõg hãpkummuk mĩy'ax xutigã'ah, pãyã' xaxogãhã'.
\v 6 Tikmũ'ũn te' nõy putup pax, puxi' nõy hãpkohe' mĩy hã tu hittup hok, pãyã hãmyok mĩy'ax hã' hittup.
\v 7 'Ap kuxa teknõg'ah, pãyã nõã'tot, 'ũkuxa yũm ka'ok tu', tu hãmmax hip, puyĩy Topa hãpxopmã'.
\p 
\v 8 Tup-tup pax, tup-tup kux 'ohnãg. Hõnhã tikmũ'ũn te Topa pupi hãm'ãktux, tu' xuktux kux putup. Ha' yĩy'ax puknõg hã tikmũ'ũn yĩy, pãyã' kux putup kamah. Ha hãmyũmmũg, pãyã' xaxogãp-tup kamah.
\v 9 'Ũgmũ'ãte hãmyũmmũg kutõgnãg, ha tikmũ'ũn te Topa pupi hãm'ãktux kutõgnãg kamah,
\v 10 pa 'ãmnĩy 'ũm mõ'nã'ax, 'ĩhã yũmũg xuxyã nũn, 'ĩhã' xexka xe'ẽgnãg tu' nũn, ha Topa Koxuk te tikmũ'ũn ka'ogã'ax kux putup, yũmũ'ãte yãyhã ka'ok hah, ha hãpxopmã'ax hittap yãyxaxogãp-tup.
\p 
\v 11 Hõmãk kutĩgnãg, yãk mũn hã kakxop, tu hãm'ãktux, tu kakxop putuk, xix 'ãte hãmpekpaxex tu kakxop putuk, pãyã hõnhãk xip tap, hu 'ãte kakxop yõg hãpxopmã putuk 'a mĩy'ah.
\v 12 Hõnhã yũmũ'ãte yãy pa pẽnã'ax hã yãy pa pẽnãhã', tu' pẽnã kummuk, pa 'ãmnĩy 'ũm mõ'nãp-tup, 'ĩhã yũmũ'ãte Topa pa pẽnã max, 'ũyĩkãgnãg hã' tihi tu'. Hõnhã yũmũg'ãte Topa yũmmũg kutõgnãg, pa 'ãmnĩy 'ũm mõ'nãp-tup, ha 'ãte Topa yũmmũg maxp-tup, yã kaxĩy hã Topa tek yũmmũg.
\p 
\v 13 Hõnhã yũmũg kuxa mãm ka'ok Yeyox Kunnix kopah. Yã hãpxopmã'ax max. Xix yũmũ'ãte hãmmax hip, tu Kunnix putpu' nũn'ax hip, nũy yũmũg mõg pexkox hah. Yã hãpxopmã'ax max kamah. Xix yũmũg yãy putup pax, tu' kux 'ohnãg. Yã hãpxopmã max'ax xe'ẽgnãg.
\c 14
\s1 Topa Koxuk te tikmũ'ũn ka'ogãhã'
\p 
\v 1 'Ũmax, ta' nõy putup pax. 'Ãpu 'ãnõy putup pax xexka'. Topa tu' xax pu pexkox yõg hãpxop popmã xa'. Yã' max xe'e', pu Topa pupi hãm'ãktux.
\v 2 'Ũyĩy'ax puknõg hã tikmũ'ũn yĩy, puxix Topa tu hãm'ãktux, pãyã tikmũ'ũn 'ũm pu hãm'ãktux'ah, 'ũyĩy'ax yã' puknõg hah, ha Topa Koxuk te' ka'ogãhã', pu Topa yõg hãm'ãktux xe'e 'ãktux.
\v 3 Pa tikmũ'ũn te Topa pupi hãm'ãktux, puxix tikmũ'ũn pu' xuktux, tu mõ'nĩynãm, tu nõ teheh.
\v 4 Tikmũ'ũn yĩy, 'ũyĩy'ax puknõg hã' yĩy, puxix mõ yãy nĩynãm, pãyã tikmũ'ũn te Topa pupi hãm'ãktux, puxi' kuxa mãm ka'ok xop xohix mõ'nĩynãm.
\p 
\v 5 'Ãte 'ãp-tup, xa yĩy'ax puknõg hã 'ãyĩy, pãyã 'ãte 'ãp-tup xexka', xa Topa pupi hãm'ãktux, nũy 'ãnõy xop ka'ogã', ha' nõy te yãy mũn puxet ka'okgãhã'. Yã' yĩy'ax puknõg hã hãm'ãktux. Pãyã tikmũ'ũn xip, nũy nõy pu hãmyũmmũgã', puxi' yĩy'ax puknõg yõg hãm'ãktux yũmmũgã', nũy hãm'ãktux'ax hã' nõy ka'ogã'.
\v 6 'Ũkxape, 'ãhãk mõg, tu' yĩy'ax puknõg hãk yĩy, kopxix mõ'ãnĩynãm 'okpa Topa yõg hãm'ãktux xe'e 'ãktux. Pãyã 'ãte xa hãmyũmmũgãhã', 'ĩhã tikmũ'ũn yãy yĩy'ax hã 'ãte Topa pupi hãm'ãktux, tu xa' xuktux, kopxix mõ'ãnĩynãm xe'ẽ'.
\p 
\v 7 'Ũg'ãpax, xayĩy hãmyũmmũg. Tikmũ'ũn kutex, ha kama hãpxop kãyã'ax pip punethok. Tik kãyã kummuk, puxix tikmũ'ũn kutex yũmmũg 'ohnãg.
\v 8 Tik 'ũm te kãyã'ax, mĩxux xop tut hã kãyãhã', nũy xonat xop xãnã', tu kãyã kummuk, puxix xonat te hãm'ãpak, pãyã hãmyũmmũg 'ohnãg, 'ok yãykix'ax, 'ok pe' xit'ax.
\v 9 Ha kaxĩy 'ãxop te hãpxopmãhã'. Tikmũ'ũn te' yĩy'ax puknõg hã' yĩy, puxi' nõy te hãm'ãktux 'ũm yũmmũg'ah, 'ũpuknõg hah, ha hãm'ãktux yãyxaxogã'ax.
\v 10 Hãm xexka yõg yĩy'ax xohix punethok, ha' yĩy'ax xohix hã' hep nõy xop te hãm'ãktux, tu yãy yĩy'ax hã hãmyũmmũg.
\v 11 'Ãte' yĩy'ax yũmmũg hok, puxix tik puknõg hãm'ãktux, tu 'ãhã' puknõg, ha hamũn hãk puknõg kamah.
\v 12 Yĩy xax, pu Topa Koxuk 'ãka'ogã', pa' xax hãmãxap, pu 'ãka'ogã, xayĩy 'ãnõy xop ka'ogã kamah.
\p 
\v 13 Yã' max tikmũ'ũn te' yĩy'ax puknõg hã' yĩy, pãyã max xexka', 'ũnõy xop pu hãm'ãktux yũmmũgã', nũy tikmũ'ũn yãy yĩy'ax hã hãmyũmmũgã', puyĩy hãmyũmmũg.
\v 14 Topa pu 'ãte hãm'ãktux, 'ũyĩy'ax puknõg hãk yĩy, kopxik kuxa te hãm'ãktux xe'e', pak putox te hãmyũmmũg 'ohnãg, 'ãte' yĩy'ax puknõg yũmmũg 'ohnãg tu'.
\v 15 'Ãte putep mũn mĩy'ax? 'Ãte Topa pu hãm'ãktux yãy kuxa hã, tu' yĩy'ax puknõg hãk yĩy, pa yãy putox hã 'ãte hãm'ãktux kamah, nũy tikmũ'ũn yãy yĩy'ax hã hãm'ãktux, hu hãmyũmmũg.
\v 16 'Ãkuxa hã xate Topa pu hãm'ãktux, puxix 'ãxape' xupax, pãyã' yĩy'ax yũmmũg hok, puxix hãm'ãktux yũmmũg hok, nũy tu: Hamũn, kaxĩy. Yã' hitop hã' xupak, 'ũyĩy'ax puknõg yũmmũg 'ohnãg tu'.
\v 17 Yĩy xate hãm'ãktux mãynãg, 'ĩhã Topa pu hãm'ãktux, pãyã 'ãxape xop mõ'nĩynãm 'ohnãg.
\v 18 'Ãte Topa pu: 'Ãmax Topah, xatek ka'ogãhã', 'ũg yĩy'ax puknõg hãk yĩy punethok, kaxĩy. Yãk yĩy punethok, ha ta 'ãxop yĩy kutõgnãg.
\v 19 Pãyã yãy kotĩnnã' xop mũtik tihi', kopxix tikmũ'ũn yãy yĩy'ax hã hãm'ãktux, 'ãtep-tup, pu tikmũ'ũn yõg hãm'ãktux kutõgnãg 'ãpax, puyĩy Topa' ka'ogã, pu' nõy xop pu nõ hãm'ãktux. Pa' yĩy'ax puknõg hãk yõg tox 'ãte putup'ah.
\p 
\v 20 'Ũkxape: 'Ãxop hã kakxop'ah, pãyã hãpkummuk mĩy hok, kakxop putuk, 'ihã hãmpe'ãpaxeh 'ũxip tap xop putuk.
\v 21 Yã Topa yõg tappet te Topa yõg hãm'ãktux'ax 'ãktux, hu:
\q1 “'Ãte nũhũ tikmũ'ũn pu hãm'ãktux putup,
\q1 tu' yĩy'ax puknõg hã hãm'ãktux putup,
\q1 xi' puknõg yĩkox hã hãm'ãktux putup,
\q1 pa yõg tikmũ'ũn te hãm 'ũm 'ãpak 'ohnãg,” kaxĩy.
\p 
\v 22 Tikmũ'ũn te' yĩy'ax puknõg hã Topa pupi hãm'ãktux, puxix tu' kuxa mãm hok xop pu hãm'ãktux, yã hãpxopmã xe'ẽgnãg, pãyã' kuxa mãm ka'ok xop pu hãm 'ũm 'ãktux'ah.
\v 23 'Ãxop yãykotĩnnãhã', 'ãxohix te' yĩy'ax puknõg hã 'ãyĩy, puxix hãmyũmmũg hok xop te: “'Ũxohip-tox kummuhnãg!” kaxĩy.
\v 24 Pa 'ãxop xohix te Topa pupi hãm'ãktux, 'ĩhã' kuxa mãm hok xop mõxakux, puxix hãm'ãpax, tu yãy yõg hãpxopmã'ax kummuk tu' yãyhãhup, ha Topa te' kopit putup, hamũn te hãmyũmmũg hah.
\v 25 Ha Topa te hãmpe'paxex yũmmũgãp-tup, yĩy nũ'xup putup, 'ũkuxa te' yẽy tu', tu: “Ya hamũn! Topa te 'ãxop mũtik pip!” kaxĩy.
\s1 Hãpxopmã max 'ĩhã yãy kotĩnnã' pip
\p 
\v 26 'Ũkxape xop, 'ãte xe xa hãm'ãktux putup. 'Ãxop yãykotĩnnã' pip 'ĩhã', yã' max 'ãxape 'ũm kutex, nũy Topa 'ãktux max, xi' nõy hãmyũmmũgã', xi' nõy te Topa yõg hãm'ãktux xe'e 'ãktux, Topa te' yũmmũgã tu' xuktux. Xi' max, 'ãnõy yĩy'ax puknõg hã tu yĩy, xi' nõy te yĩy'ax yõg hãmyũmmũg'ax 'ãktux, tu tikmũ'ũn yãy yĩy'ax hã hãmyũmmũgãhã', puyĩ' kuxa mãm xop xohix mõ'nĩynãm.
\v 27 'Ãxop 'ũm yĩy'ax puknõg hã 'ãyĩy putup, 'ĩhã 'ãyĩy, 'ãp-xet yĩy hãmãxap, xik-nãy tu' nõy yĩy, xik-nãy tu' noy, tu mõktu yã tikoyuk yĩy, tu' hip, pu' nõy 'ũyĩy'ax puknõg hã' yãnãn, nũy tikmũ'ũn yãy yĩy'ax hã' xuktux, puyĩ' xohix hãmyũmmũgã'.
\v 28 'Ũxip hok tik te' yũmmũgã', ha ta' kux, tu yãy pu hãm'ãktux, xix Topa pu hãm'ãktux yãy kuxa kopah.
\v 29 Tikmũ'ũn 2 tu yĩy kux, pe 3 tu yĩy kux, xa' hip, pu' nõy xop kopit, 'ok pe tik te Topa pupi hãm'ãktux, 'ok pe' koxuk puknõg pupi hãm'ãktux.
\v 30 'Ũxape yok, tu hãm'ãktux putup, 'ĩhã' nõy te Topa pupi hãm'ãktux, puxix tikmũ'ũn mãxap hã hãm'ãktux kux, tu ta' yũm, pu' nõy Topa yõg hãm'ãktux 'ũyãnãn tu 'ãktux.
\v 31 'Ãxop xohix te Topa pupi hãm'ãktux'ax, 'ũp-xet hãmãxap, hak-nãy tu' nõy te', xik-nãy tu' nõy, tu mõktu 'ãxohix te hãm'ãktux kux, ha kaxĩy 'ãxop te hãm'ãktux xohix yũmmũg putup, nũy tu hittup.
\v 32 Tikmũ'ũn te Topa pupi hãm'ãktux, puxix yãy mũn xat, 'ok pe' max hãm'ãktux, 'ok pe' kummuk hãm'ãktux.
\v 33 Yã Topa te yũmũg xãnã hok, 'ũg hãpxopmã kummuk, pa yũmũg xãnãhã 'ũg hãpxopmã max.
\p Ha kaxĩy 'ũkuxa mãm ka'ok xop xohix yãykotĩnnãnã' pip.
\v 34 Ha 'ũn xop yĩy hok. 'Ũxat hok, puyĩy hãm'ãktux hok. Yoneo xop yõg xat'ax te' xat hok kamah, yĩy tux hok, pu 'ũn kuxa mãm ka'ok xop xat hok kamah.
\v 35 'Ũn te' yĩkopit putup, puxi' hip, nũy yãy pet kopa yãy yĩpxox yĩkopit. 'Ũn te hãm'ãktux, 'ĩhã' xohix yãykotĩnnãhã' pip, puxix tu hupmã'.
\p 
\v 36 'Ok 'ãxop te Topa yõg hãm'ãktux mĩy? 'Ap mĩy'ah. 'Ok pe Topa te mõ'ãp-xet kutnãhã'? 'Ãmhok.
\v 37 'Ãxop 'ũm te yãy xexka pe'ãpaxeh, nũy mõ 'ãkutnãp-xet pe'ãpaxeh, xix Topa Koxuk te 'ãka'ogã'ax pe'ãpaxeh, kopxix xa hãmyũmmũgã'. Yũmũg xuxyã tek xat 'ũxa kax'ãmi'.
\v 38 Tikmũ'ũn 'ũm te hãm'ãpak hok, 'ãpu nõm pu 'ãyipkox pip hok kamah.
\p 
\v 39 'Ũkxape xop: 'Ãpu, Topa pupi hãm'ãktux pax, tu' tux hok, pu yĩy'ax puknõg hã tu yĩy kamah. Yã' max.
\v 40 Pãyã hãpxopmã mãynãg, 'ĩhã yãykotĩnnãhã' 'ãpip.
\c 15
\s1 Kunnix te putpu' hi'
\p 
\v 1 'Ãte xa hãm'ãpak max'ax 'ãktux, ka' xaxok. 'Ãxop te hãm'ãpak, yã 'ãkuxa mãm ka'ok hõmã xix hõnhã'.
\v 2 Yã hãm'ãpak max'ax hã 'ãxop kuxa tup, tu' mãm ka'ok 'ãmõ kuma 'ãmõg. 'Ok pe 'ãkuxa te yã hitop hã' mãm ka'ok.
\p 
\v 3 Topa te 'ã hãm'ãktux, ha 'ãte xa' xuktux, yã hãm'ãktux xe'e', hu: Kunnix xok, yũmũg pupi' xok, yũmũ'ãte hãpkummuk mĩy pax ha' xok, ha Topa yõg tappet te' xuktux,
\v 4 ha nõ hãpkot, ha 'ãmnĩy 3 nõg, 'ĩhã' putpu' hi', ha Topa yõg tappet te' xuktux,
\v 5 ha Pet te Kunnix pẽnãhã', hak-nãy tu mõ'pok xop te 12 te' pẽnãhã',
\v 6 hak-nãy tu tikmũ'ũn te 500 te' pẽnãhã', nõm xop kuxa mãm ka'ok te 500 te' pẽnãhã'. Tikmũ'ũn 'ũm yã' pip, pãyã' yãg xakix hittap.
\v 7 Hak-nãy tu Tiak te' pẽnãhã', hak-nãy tu mõ'pok xop xohix te' pẽnãhã'.
\p 
\v 8 Ha ka'ax hã 'ãte Kunnix pẽnãhã', 'ũka'ax hãk kuxa te yũmũg xuxyã kopa' yũm ka'ok.
\v 9 Yã 'ãte mõ'pok xop hãk ka'ax, tuk kutõgnãg, huk xax te kutuk, tu yãyhãhup, pãyã Yeyox te nũgkutnãhã 'ũka'ax hã. Hõmã 'ãte kuxa mãm ka'ok xop xũygãhã', huk xax te kutuk.
\v 10 Pa Topa te 'ã hãmmaxnãhã', huk mõgkutnãhã, ha 'ãte hãpxopmãhã punethok, ha mõ'pok xop nõy hãpxopmã kutõgnãg, pak puxet'ah, yã Topa tek ka'ogãhã', 'ũyĩy hãpxopmã ka'ok.
\v 11 Yĩy 'ãtep yũmmũg putup'ah, 'ok pek hãm, 'ok pe yãk nõy hãm, pak mũg xohix te hãm'ãpak max'ax 'ãktux, ha 'ãkuxa mãm ka'ok hãm'ãktux'ax kopah.
\s1 Yũmũ'ãte putpuk hip-tup
\p 
\v 12 Hak mũ'ãte Kunnix te putpu hi'ax 'ãktux. Tep te xĩy 'ãxop 'ũm te: “Yũmũg yog xakix xop te putpu hip-tup 'ohnãg,” kaxĩy.
\v 13 Pax pu' xakix xop putpu tu hi hok, puxix Kunnix 'a putpu hi'ah kamah.
\v 14 Pax pu Kunnix putpu tu hi hok, kopxik mũg hitop hã hãm'ãpak max'ax 'ãktux, ha yã 'ãkuxa kama 'ũhitop hã' mãm.
\v 15 Kamah: Kunnix putpu tu hi hok, kopxik mũg yã' koit, 'ihã Kunnix putpu hi'ax 'ãktux. Pax pu' xakix xop putpu tu hi hok, puxix Topa yã Kunnix putpu hĩnnã hok kamah.
\v 16 Pax pu' xakix xop putpu tu' hi hok, puxix Kunnix putpu tu hi hok.
\v 17 Pax pu Kunnix putpu tu hi hok, puxix 'ãkuxa hitop hã' mãm ka'ok Kunnix kopah, ha 'ãkuxa tup 'ohnãg. Yã' kummuhnãg.
\v 18 Pax pu' xakix xop kuxa hitop tu' mãm, tu Topa yõg putat hã' mõg hok, puxix tu Topa hãptox hã' pi nõmhã'.
\v 19 Pax hãm tup-xet hã yũmũ 'ãte Kunnix hip, xix pexkox hã yũmũg mõg hok, puxix yũmũg kuxa xakix putũmnãg, yũmũg hittup 'ohnãg tu', ha' kuxa mãm hok xop tu hittup.
\p 
\v 20 Pãyã Kunnix te putpu hi xe'ẽgnãg, 'ãte hãpxe'e 'ãktux, yĩ' xakix xop te putpu' hip-tup kamah.
\v 21 Tik puxet 'Anão te hãpkummuk mĩy, yĩy yã' xohix xakix, hã kaxĩy tik puxet nõy te' putpu' hĩnnãhã'.
\v 22 'Ũxohix xakix mõnãyxop te mãxap 'Anão hah, hã kaxĩy 'ũxohix te putpu' hip-tup, Kunnix hãh. Yã Kunnix te' putpu' hĩnnãp-tup.
\v 23 Tu ta putpu' hi hãmãxap, hak-nãy tu Kunnix yõg tikmũ'ũn hip-tup, 'ĩhã Kunnix putpu' nũn.
\v 24 Yã hãmyãxatamuk ka'ax xohix yõg xox putox, ha Kunnix te hãpkummuk xop yõg xexka xop xohix nõãp-tup, xi' xat'ax kummuk xop xohix nõãp-tup, nũy Topa yũmũg Tak ha' nũnnã', puyĩy Topa pu' yĩpkox pi'.
\v 25 Ha Kunnix te' xat putup, tu mõktu Topa te' gãyxop kuxyã', tu mõktu hãmgãy xop xohix kuxyãhã', tuk-tok Kunnix ha' nũnnãp-tup, pu tu' nõa'.
\v 26 Ha' ka'ax hã Topa te' xat putup, puyĩy tikmũ'ũn xakix hok,
\v 27 yĩy Topa yõg tappet te: “Topa te' xexka xop xohix nũnnãhã', pu tu' yĩpkox pi',” kaxĩy. Pãyã Topa mũn xexka', tu Kunnix ha' nũnnã'ax hãmgãy xop yõg xexka xop,
\v 28 tu' kuxyãhã', puxik-tok te yãy Tak pu' yĩpkox xihip, pu tu' xat, tu' hep xop xohix xat'ax, 'ũxexka xe'ẽgnãg tu'.
\p 
\v 29 Tikmũ'ũn 'ũm te' nõy xok tup-tox pix, yĩy 'ãte 'ãyĩkopit, hu: Teptu xatep-tox pix 'ãxape xok pupi', 'ĩhã xate' putpu' hi'ax 'ãktux hok?
\v 30 Xik mũ'ãg. Tep tuk mũg xũy, xik mũg xakix putũmnãg, nũy hãm'ãpak max'ax 'ãktux?
\v 31 'Ũkxape xop, 'ãte xa hãm'ãktux, tu hãpxe'e 'ãktux. 'Ãmnĩy xohix 'ĩhãk xok putũmnãg. 'Ãte xa hãpxe'e 'ãktux. 'Ãxop te hãpxopmã max, yĩk hittup, yã yũmũg kuxap-xet yũmũg xuxyã Yeyox Kunnix kuxa mũtik.
\v 32 Hõmãk xip nũnte kõmẽn 'Epex tu', ha' gãy xop te hãmgãy putuk, tuk putex putup, 'ãte hãm'ãpak max 'ãktux hah. Pax 'ãte hãm'ãktux, puyĩy tikmũ'ũn 'ũgmax 'ãktux, kopxi' hitop hã hãm'ãktux. Pax pu' xakix xop putpu tu hi hok, kopxix max yũmũg hãpxopmã hãmpuknõg xop putuk, ha: “'Ãpu yũmũg xit, xix xo'op. Yã hãptup 'ĩhã yũmũg xakix,” kaxĩy. Yã' hitop hã hãpxopmãhã'.
\p 
\v 33 Yãy hã mõ'ãmã hok. Tik kummuk mũtik 'ãmõg, hu ta 'ãkummuk kamah.
\v 34 'Ãpu hãpxopmã kummuk kuxyã', tu Topa yõg putat hã 'ãmõg putpu'. 'Ãxop 'ũm te Topa yũmmũg 'ohnãg. 'Ãte xa' xuktux nũy xa' hupmã'.
\s1 Yũmũg yĩn te putpu' hip-tup
\p 
\v 35 Pa tikmũ'ũn 'ũm xek yĩkopit, hu: “Tep te xĩy 'ũxakix xop putpu hip-tup?” kaxĩy. “'Ũyĩn te xĩy?” kaxĩy.
\v 36 'Ãxop te hãmyũmmũg 'ohnãg! 'Ãxop te hãpxop xap xok 'ĩhã' xok, pu tu' xokax.
\v 37 Ha' xap, 'ok pe xuxnãg xetox xap, 'ok pe mĩxux xap nõy, 'ũxap mũn 'ap mĩxux yĩnmũn'ah.
\v 38 Ha Topa te hãpxop xap xohix yãyhã mĩxux, yã Topa tep-tup.
\p 
\v 39 Ha' hi'ax xop xohix punethok. Yã tikmũ'ũn yĩn puxet, xix xokxop yĩn yã' nõy, xix putuxnãg xop yĩn yã' nõy, xix mãm xop yĩn yã' nõy.
\p 
\v 40 Ha pexkox yõg xop yĩn yã' nõy, xix hãm xexka yõg xop yĩn yã' nõy. Ha' xohix max, pãyã hãmmax nõy. 'Ap nõy putuk'ah.
\v 41 Mãyõn max, tu hãptupmãhã', ha mãyõnhex max, tu 'ãmnĩy tupmãhã', ha mãyõnnãg xop xohix max kamah, tu hãptupmã nõy. 'Ap nõy putuk'ah.
\p 
\v 42-43 Ha kaxĩy 'ũxakix xop te putpu hip-tup. 'Ũyĩn yã hahãm yõg, ha nõ hãpkot, 'ũkummuk tu', yã' xok xe'e'. Pa putpu' hi, 'ĩhã' yĩn tup, tu yĩn ka'ok, tu yĩn max, 'a xep xok putup'ah.
\v 44 Putpu' hi, 'ihã yã pexkox yõg yĩn. 'Ũyĩn hittap yã hãm yõg, ha' yĩn tup pexkox yõg.
\v 45 Yĩy Topa yõg tappet te: “Tik te mãxap 'ãxet'ax 'Anão, ha Topa te' hĩnnãhã',” kaxĩy. Pa 'Anão nõy 'ãxet'ax Kunnix, tu hãpxohix hĩnnãhã'.
\v 46 Tu hãm yõg yĩn mĩy hãmãxap, nũy kunãy tu pexkox yõg yĩn mĩy.
\v 47 Ha 'Anão te mãxap mĩy, 'ĩhã hãpkõnõn hã' mĩy, pa 'Anão nõy te pexkox tu' nũn.
\v 48 Hãm xexka yõg xop te hãm yõg 'Anão putuk, ha pexkox yõg xop te 'Anão nõy putuk, nõm te pexkox tu' nũn.
\v 49 Yũmũ'ãte hãm yõg tik putuk nõmhã, pãyã tik nõy te pexkox tu' nũn, ha yũmũ'ãte Kunnix putuk putup.
\p 
\v 50 'Ũkxape xop, 'ãte xa hãmyũmmũgãp-tup, hu: Tikmũ'ũn yĩn yã hãm yõg, ha' yĩn xi' hep 'ãta hã' mĩy, yĩy Topa pẽnã hok pexkox kopah, tu pexkox yõg hãpxop pop hok kamah.
\p 
\v 51 'Ũg 'ãpax, nũy hãm'ãktux xe'e 'ãpax. 'Ap xohix xakip-tup'ah. pãyã yũmũg yãyhãp-tup pexkox yõg tikmũ'ũn,
\v 52 hãpxip 'ohnãg 'ĩhã', tikmũ'ũn pa xax te kutãgnãg, 'ĩhã yũmũg yãyhã pexkox yõg tikmũ'ũn, 'ĩhã mĩxux xop tut kãyãp-tup. Ha' xakix xop te putpu hip-tup, 'ũyĩn yã pexkox yõg yĩn, tu putpu' hip-tup, ha yũmũ'ãte yãyhãp-tup kamah.
\v 53 Yã Topa te hãm yõg yĩn xit putup, nũy pexkox yõg yĩn hã yũmũg mõ'tat 'ũyãnãn tu', pu tu xakix'ax xop yãyhã xakix hok xop,
\v 54 Ha pexkox yõg yĩn hã mõ yũmũg tat putup, 'ũyĩy yũmũg xakix hok, yã Topa te' xat putup, nũy yũmũg xakix kuxyã', 'ũyĩy yũmũg hi xe'ẽgnãg mõ kumak mog. Yã Topa yõg tappet te: “Topa te' xat hok pu tikmũ'ũn xep xakix hok, yĩy Topa te' xũy'ax kuxyã kamah, Topa mũn ka'ok xe'ẽgnãg tu'.”
\q1 
\v 55 “Tep tu tikmũ'ũn xohix xũy?
\q1 Teptu tikmũ'ũn xohix xakix?” kaxĩy.
\p 
\v 56 Yã tikmũ'ũn xohix te hãpkummuk mĩy, tu' xat'ax pu' yĩpkox 'ohnãg, hu' xohix xũy, hu' xohix xakix.
\v 57 Pa yũmũ'ãte Topa pu hãm'ãktux, tu: “'Ãmax Topah. Xatek mũ ka'ogãhã', 'ũyĩg mũg xakix hok, yãk mũg xuxyã Yeyox Kunnix tek mũg hĩnnã xe'ẽgnãg,” kaxĩy.
\p 
\v 58 Yĩy Topa yõg putat hã 'ãmõy kuma 'ãmõg. Topa pu hãpxopmã max, yã yũmũg xuxyã te xa pagop-tup, 'ãxop te' yũmmũg.
\c 16
\s1 Paot te tayũmak pop mõg putup hãpxexka Yonex tu'
\p 
\v 1 Hõmã 'ãte hãpxexka Ganax yõg kuxa mãm xop pu hãmyũmmũgãhã', pu tayũmak pop, nũy Yonex yõg 'ũhok xop pu mõ'kutnã'. Yã' max 'ãxop kaxĩy pop kamah, nũy hok pu popmã',
\v 2 yĩy: Yenomĩn xohix 'ĩhã tayũmak 'ũm mõy, nũy xeh, nõm tayũmak 'ãxop te' pop'ax, tu mõktu 'ãhak xupep, pu tayũmak pop hok 'ĩhãk nũn.
\v 3 Tuk xupep 'ĩhã, 'ãte tappet mĩy putup, nũy mõ'kutnã', 'ĩhã 'ãxop te tik xop yĩmõgatux, pu tayũmak mõgã kõmẽn Yenoyanẽn hah.
\v 4 Pek mõg kamah tik xop mũtik.
\s1 Paot te hãmpe'paxex
\p 
\v 5 'Ũgmõg putup hãpxexka Mãxenõn ha hãmãxap, nũy kunãy tu 'ãhak mõg,
\v 6 Pak xip ka'ok putup 'ãxop mũtik hãm'ãxĩ hã, ha 'ãxop 'hã 'ãte'ax, pu 'ãte hãpkumep kumaknãg.
\v 7 'A 'ãtep-tup'ah 'ãxop tuk xip pu'ũgnãg. Topa 'ũkputup, 'ũkxip ka'ok.
\p 
\v 8 Nũn tek xip putup 'Epex tu', tu' hip, pu Yoneo xop yõg 'ãmuk xexka 'ãxet'ax Pẽtekot mĩy,
\v 9 puk hãm xexkah, nũy hãm'ãpak'ax max 'ãktux, tikmũ'ũn xohix pu', pa tikmũ'ũn yãg te hãm'ãpak max'ax putup nõg.
\p 
\v 10 Timõn xupep 'ĩhã', mõy xãnã' pu 'ãpet kopa mõ'xip, nũy nõ hittupmã'. Yã hãpxopmãhã 'ũgmũn putuk, tu yũmũg xuxyã pu hãpxopmãhã'.
\v 11 Pũyã Tĩmõn pe'ãpaxeh kutõgnãg hok. 'Ãmhok, pa hã tu' tehe', pu tu mõg, 'ũkuxa yũm 'ĩhã', nũy 'ũgha nũ putpu'. 'Ãte' hip, pu nũk xape xop mũtik.
\p 
\v 12 'Ãte 'Apot 'ãktux putup. Hõmã 'ãte tu hãm'ãktux, tu xe' xuktux, pu 'ãha mõg, yũmũg xape xop nõy mũtik, pa tute hãmpe'paxex, tu hõnhã' mõg putup'ah. Hãpxip kutõgnãg, puxi' mõg.
\s1 Tu ta hãm'ãktux kux
\p 
\v 13 'Õg pa mõxip, 'ãkuxa mãm ka'ok. 'Ãkuxãnõg hok, nũy ta 'aka'ok.
\v 14 'Ãpu 'ãhãm, 'ĩhã 'ãnõy putup pax xexka'.
\p 
\v 15 'Ãxop te 'Exteo yũmmũg, xi' xape xop. Nõm xop kuxa mãm hãmãxap hãpxexka Genex tu', tu Topa yõg tikmũ'ũn pu hãpxopmã max. 'Ãte xa tu' xak, yãk xape xop,
\v 16 pu nõm xop xi' xape xop yõg hãpxopmã'ax tat, tu hãm'ãpak, nũy nũ mũtik hãpxopmã, xa hã tu tehet.
\p 
\v 17 'Ũgkuxa hittup, 'ũkxape xop nũn, hak kuxa hittup. Yã 'Exteo nũn, xix Potõnãn nũn, xix 'Ahkax nũn, ha mõgnĩynãm 'ãxop pupi', 'ãxop pip hok hah.
\v 18 Ha mõgnĩynãm xexka', tu mõ'ãnĩynãm kamah. 'Ãte' yũmmũg. Yã' max yũmũ'ãte nõm xop 'ãktux max.
\p 
\v 19 Hãpxexka 'Ax yõg kuxa mãm xop te 'ãneo. 'Ak xix Pinixit te 'ãneo, xi' kuxa mãm xop te nõm pet tu yãytu nũ'nãhã', tu 'ãxop pu 'ãneo hõm.
\v 20 Hayũmmũg xape xop nũnte' pip, tu xa 'ũyĩmã'õy, tu 'ãmũg putup yãy kep hã, 'ãp-tup pax tu'.
\p Yũmũg xape xop xohix pu 'ãneo hõm, 'ũgmũn pupi 'ãneo.
\p 
\v 21 'Ãte tappet kup paha', nũy tappet mĩy, hu: 'Ũgmũn Paot te xa 'ãneo.
\p 
\v 22 Nõm xop te yũmũg xuxyã putup nõg, pũyã Topa nõm hã hãpkummugã'. Yã yũmũg xuxyã nũn putpu', yĩy mã', Yãyã'!
\p 
\v 23 Pũyã yũmũg xuxyã Yeyox xa hãmmaxnã'!
\p 
\v 24 Yã 'ãte 'ãxop xohix putup pax Yeyox Kunnix hah. Tu ta tu' kux.
