\mt1 Gálatas  
\c 1  
\s1 Saludo  
\p
\v 1 \w Pablo|strong="G3972"\w*, \w un|strong="G3588"\w* apóstol \w no|strong="G3756"\w* \w por|strong="G1223"\w* hombres \w ni|strong="G3761"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1537"\w* hombre, sino \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1537"\w* \w Jesucristo|strong="G2424"\w* \w y|strong="G2532"\w* \w de|strong="G1537"\w* \w Dios|strong="G2316"\w* \w Padre|strong="G3962"\w*, \w Quien|strong="G3588"\w* \w lo|strong="G3588"\w* \w resucitó|strong="G1453"\w* \w de|strong="G1537"\w* \w entre|strong="G1537"\w* \add los\add* \w muertos|strong="G3498"\w*,  
\v 2 \w y|strong="G2532"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* hermanos \w que|strong="G3588"\w* están \w conmigo|strong="G4862"\w*, a \w las|strong="G3588"\w* \w iglesias|strong="G1577"\w* \w de|strong="G3588"\w* \w Galacia|strong="G1053"\w*.   
\p
\v 3 \w Gracia|strong="G5485"\w* a ustedes, \w y|strong="G2532"\w* \w paz|strong="G1515"\w* de \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Padre|strong="G3962"\w* \w y|strong="G2532"\w* del \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w*,  
\v 4 \w Quien|strong="G3588"\w* \w se|strong="G1438"\w* \w dio|strong="G1325"\w* \w por|strong="G5228"\w* nuestros pecados \w para|strong="G3704"\w* \w librarnos|strong="G1807"\w* \w de|strong="G1537"\w* \w la|strong="G3588"\w* \w presente|strong="G1764"\w* era perversa, \w según|strong="G2596"\w* \w la|strong="G3588"\w* \w voluntad|strong="G2307"\w* \w de|strong="G1537"\w* \w nuestro|strong="G2249"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w Padre|strong="G3962"\w*,  
\v 5 \w a|strong="G1519"\w* \w Quien|strong="G3739"\w* \w sea|strong="G3588"\w* \w la|strong="G3588"\w* \w gloria|strong="G1391"\w* \w por|strong="G1519"\w* \w los|strong="G3588"\w* siglos \w de|strong="G1519"\w* \w los|strong="G3588"\w* siglos. Amén.   
\s1 Las únicas Buenas Noticias  
\p
\v 6 Estoy asombrado \w de|strong="G1722"\w* \w que|strong="G3754"\w* \w tan|strong="G3779"\w* \w pronto|strong="G5030"\w* \w se|strong="G3779"\w* apartaron \w del|strong="G3588"\w* \w que|strong="G3754"\w* \w los|strong="G3588"\w* \w llamó|strong="G2564"\w* \w por|strong="G1722"\w* \w gracia|strong="G5485"\w* \w de|strong="G1722"\w* \w Cristo|strong="G5547"\w* \w hacia|strong="G1519"\w* \w un|strong="G3588"\w* \w evangelio|strong="G2098"\w* diferente.  
\v 7 \w No|strong="G3756"\w* digo \w que|strong="G3588"\w* \w hay|strong="G3588"\w* \w otro|strong="G3739"\w*, \w sino|strong="G1487"\w* \w hay|strong="G3588"\w* \w algunos|strong="G5100"\w* \w que|strong="G3588"\w* \w los|strong="G3588"\w* perturban \w y|strong="G2532"\w* \w que|strong="G3588"\w* \w quieren|strong="G2309"\w* \w pervertir|strong="G3344"\w* \w las|strong="G3588"\w* Buenas Noticias \w de|strong="G3588"\w* \w Cristo|strong="G5547"\w*.   
\p
\v 8 \w Pero|strong="G2532"\w* \w si|strong="G1437"\w* \w aun|strong="G2532"\w* \w nosotros|strong="G2249"\w*, \w o|strong="G2228"\w* un ángel \w del|strong="G1537"\w* \w cielo|strong="G3772"\w*, \w se|strong="G2532"\w* presenta \w con|strong="G3844"\w* un \w evangelio|strong="G2097"\w* contrario \w al|strong="G1537"\w* \w que|strong="G3739"\w* \w les|strong="G3844"\w* proclamamos, sea \w una|strong="G3739"\w* maldición.  
\v 9 \w Como|strong="G5613"\w* \w dije|strong="G3004"\w*, \w también|strong="G2532"\w* \w digo|strong="G3004"\w* \w ahora|strong="G3739"\w* \w otra|strong="G3825"\w* vez: \w Si|strong="G1487"\w* \w alguno|strong="G5100"\w* \w les|strong="G3844"\w* proclama \w otro|strong="G3739"\w* \w evangelio|strong="G2097"\w* contrario al \w que|strong="G3739"\w* \w recibieron|strong="G3880"\w*, sea \w una|strong="G5100"\w* maldición.   
\p
\v 10 \w Porque|strong="G1063"\w*, ¿trato ahora \w de|strong="G3588"\w* convencer a seres humanos, \w o|strong="G2228"\w* a \w Dios|strong="G2316"\w*? ¿\w O|strong="G2228"\w* \w busco|strong="G2212"\w* agradar a seres humanos? \w Si|strong="G1487"\w* \w aún|strong="G2089"\w* complazco a seres humanos, \w no|strong="G3756"\w* me sometería como esclavo \w de|strong="G3588"\w* \w Cristo|strong="G5547"\w*.   
\p
\v 11 Les informo, hermanos, \w que|strong="G3754"\w* \w las|strong="G3588"\w* Buenas Noticias proclamadas \w por|strong="G5259"\w* \w mí|strong="G3588"\w* \w no|strong="G3756"\w* \w son|strong="G1510"\w* \w según|strong="G2596"\w* \w un|strong="G3588"\w* ser humano,  
\v 12 \w pues|strong="G1063"\w* \w yo|strong="G1473"\w* \w no|strong="G3777"\w* las \w recibí|strong="G3880"\w* \w ni|strong="G3761"\w* fui enseñado \w por|strong="G1223"\w* un ser humano, sino \w por|strong="G1223"\w* una revelación \w de|strong="G3844"\w* \w Jesucristo|strong="G2424"\w*.   
\p
\v 13 \w Porque|strong="G1063"\w* \add ustedes\add* oyeron \w que|strong="G3754"\w* \w según|strong="G2596"\w* \w mi|strong="G1699"\w* conducta anterior \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w judaísmo|strong="G2454"\w*, \w perseguía|strong="G1377"\w* excesivamente \w a|strong="G1722"\w* \w la|strong="G3588"\w* \w iglesia|strong="G1577"\w* \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w la|strong="G3588"\w* destrozaba,  
\v 14 \w y|strong="G2532"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w judaísmo|strong="G2454"\w* iba adelante \w de|strong="G1722"\w* \w muchos|strong="G4183"\w* \w de|strong="G1722"\w* \w los|strong="G3588"\w* contemporáneos \w en|strong="G1722"\w* \w mi|strong="G3588"\w* \w nación|strong="G1085"\w*, \w pues|strong="G2532"\w* \w era|strong="G5225"\w* \w mucho|strong="G4183"\w* \w más|strong="G2532"\w* \w celoso|strong="G2207"\w* \w de|strong="G1722"\w* \w las|strong="G3588"\w* \w tradiciones|strong="G3862"\w* \w de|strong="G1722"\w* mis antepasados.   
\p
\v 15 \w Pero|strong="G1161"\w* \w cuando|strong="G3753"\w* \w agradó|strong="G2106"\w* \add a Dios\add* (\w Quien|strong="G3588"\w* \w me|strong="G1473"\w* apartó \w desde|strong="G1537"\w* \add el\add* \w vientre|strong="G2836"\w* \w de|strong="G1537"\w* \w mi|strong="G3588"\w* \w madre|strong="G3384"\w* \w y|strong="G2532"\w* \add me\add* \w llamó|strong="G2564"\w* \w por|strong="G1223"\w* \w su|strong="G3588"\w* \w gracia|strong="G5485"\w*),  
\v 16 revelar \w a|strong="G1722"\w* \w su|strong="G3588"\w* \w Hijo|strong="G5207"\w* \w en|strong="G1722"\w* \w mí|strong="G3588"\w* \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w lo|strong="G3588"\w* proclame \w entre|strong="G1722"\w* \w los|strong="G3588"\w* gentiles, \w no|strong="G3756"\w* consulté inmediatamente \w a|strong="G1722"\w* seres humanos,  
\v 17 \w ni|strong="G3761"\w* fui \w a|strong="G1519"\w* Jerusalén, \w a|strong="G1519"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* eran apóstoles \w antes|strong="G4253"\w* \w de|strong="G1519"\w* \w mí|strong="G3588"\w*, sino fui \w a|strong="G1519"\w* Arabia, \w y|strong="G2532"\w* regresé \w a|strong="G1519"\w* \w Damasco|strong="G1154"\w*.   
\p
\v 18 \w Luego|strong="G1899"\w*, \w después|strong="G3326"\w* \w de|strong="G1519"\w* \w tres|strong="G5140"\w* \w años|strong="G2094"\w*, subí \w a|strong="G1519"\w* Jerusalén \w a|strong="G1519"\w* visitar \w a|strong="G1519"\w* \w Cefas|strong="G2786"\w*, \w y|strong="G2532"\w* permanecí \w con|strong="G3326"\w* él 15 \w días|strong="G2250"\w*.  
\v 19 \w No|strong="G3756"\w* \w vi|strong="G3708"\w* \w a|strong="G1161"\w* \w otro|strong="G2087"\w* \w de|strong="G3588"\w* \w los|strong="G3588"\w* apóstoles \w sino|strong="G1487"\w* \w a|strong="G1161"\w* \w Jacobo|strong="G2385"\w*, \w el|strong="G3588"\w* hermano \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*.  
\v 20 Observen \w que|strong="G3754"\w* \w no|strong="G3756"\w* \w miento|strong="G5574"\w* \w delante|strong="G1799"\w* \w de|strong="G3588"\w* \w Dios|strong="G2316"\w* \w en|strong="G3588"\w* \w lo|strong="G3588"\w* \w que|strong="G3754"\w* les \w escribo|strong="G1125"\w*.   
\p
\v 21 \w Después|strong="G1899"\w* \w fui|strong="G2064"\w* \w a|strong="G1519"\w* \w las|strong="G3588"\w* \w regiones|strong="G2824"\w* \w de|strong="G1519"\w* \w Siria|strong="G4947"\w* \w y|strong="G2532"\w* \w de|strong="G1519"\w* \w Cilicia|strong="G2791"\w*,  
\v 22 \w y|strong="G1161"\w* \w era|strong="G1510"\w* desconocido personalmente \w por|strong="G1722"\w* \w las|strong="G3588"\w* \w iglesias|strong="G1577"\w* cristianas \w de|strong="G1722"\w* \w Judea|strong="G2449"\w*.  
\v 23 \w Solo|strong="G3441"\w* oían: \w El|strong="G3588"\w* \w que|strong="G3754"\w* \w en|strong="G3588"\w* \w un|strong="G3588"\w* \w tiempo|strong="G3568"\w* nos \w perseguía|strong="G1377"\w*, \w ahora|strong="G3568"\w* predica \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w que|strong="G3754"\w* \w en|strong="G3588"\w* \w otro|strong="G3739"\w* \w tiempo|strong="G3568"\w* \w destruía|strong="G4199"\w*.  
\v 24 \w Glorificaban|strong="G1392"\w* \w a|strong="G1722"\w* \w Dios|strong="G2316"\w* \w por|strong="G1722"\w* \w mí|strong="G3588"\w*.   
\c 2  
\p
\v 1 \w Después|strong="G3326"\w* \w de|strong="G1519"\w* 14 \w años|strong="G2094"\w* subí \w otra|strong="G3825"\w* vez \w a|strong="G1519"\w* Jerusalén \w con|strong="G3326"\w* Bernabé, \w y|strong="G2532"\w* \w también|strong="G2532"\w* llevé \w a|strong="G1519"\w* \w Tito|strong="G5103"\w*.  
\v 2 Subí \w según|strong="G2596"\w* \w una|strong="G3588"\w* revelación. \w Para|strong="G1519"\w* \w no|strong="G3361"\w* \w correr|strong="G5143"\w* \w ni|strong="G2532"\w* haber corrido \w en|strong="G1722"\w* \w vano|strong="G2756"\w*, expuse \w en|strong="G1722"\w* privado \w a|strong="G1519"\w* \w los|strong="G3588"\w* \w de|strong="G1722"\w* cierta reputación \w las|strong="G3588"\w* Buenas Noticias \w que|strong="G3588"\w* \w predico|strong="G2784"\w* \w entre|strong="G1722"\w* \w los|strong="G3588"\w* gentiles.  
\v 3 \w Ni|strong="G3761"\w* aun \w Tito|strong="G5103"\w*, \w el|strong="G3588"\w* \w griego|strong="G1672"\w* \w que|strong="G3588"\w* estaba \w conmigo|strong="G4862"\w*, fue obligado a circuncidarse  
\v 4 \w por|strong="G1223"\w* motivo \w de|strong="G1722"\w* \w los|strong="G3588"\w* falsos hermanos \w que|strong="G3588"\w* entraron solapadamente \w para|strong="G2443"\w* espiar \w la|strong="G3588"\w* \w libertad|strong="G1657"\w* \w que|strong="G3588"\w* \w tenemos|strong="G2192"\w* \w en|strong="G1722"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w*, \w a|strong="G1722"\w* fin \w de|strong="G1722"\w* esclavizarnos.  
\v 5 \w Ni|strong="G3761"\w* \w por|strong="G4314"\w* \w un|strong="G3588"\w* momento \w cedimos|strong="G1502"\w* \w a|strong="G4314"\w* someternos \w a|strong="G4314"\w* \w ellos|strong="G3588"\w*, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w la|strong="G3588"\w* verdad \w de|strong="G4314"\w* \w las|strong="G3588"\w* Buenas Noticias permaneciera \w con|strong="G4314"\w* ustedes.   
\p
\v 6 \w Los|strong="G3588"\w* \w de|strong="G3588"\w* reputación \w que|strong="G3588"\w* \w parecían|strong="G1380"\w* ser \w algo|strong="G5100"\w*, \w nada|strong="G3762"\w* \w me|strong="G1473"\w* impartieron. \w Lo|strong="G3588"\w* \w que|strong="G3588"\w* eran \w no|strong="G3756"\w* \w me|strong="G1473"\w* interesa, \w Dios|strong="G2316"\w* \w no|strong="G3756"\w* hace acepción \w de|strong="G3588"\w* personas.   
\p
\v 7 \w Por|strong="G3754"\w* otra parte, \w al|strong="G3588"\w* considerar \w que|strong="G3754"\w* \w las|strong="G3588"\w* Buenas Noticias \w para|strong="G2098"\w* \w los|strong="G3588"\w* no circuncidados me fueron confiadas, \w como|strong="G2531"\w* a \w Pedro|strong="G4074"\w*, \w las|strong="G3588"\w* Buenas Noticias \w para|strong="G2098"\w* \w los|strong="G3588"\w* circuncidados\f + \fr 2:7 \ft Lit. \fqa la circuncisión.\f*  
\v 8 (\w porque|strong="G1063"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* actuó \w en|strong="G1519"\w* \w Pedro|strong="G4074"\w* \w para|strong="G1519"\w* \w el|strong="G3588"\w* apostolado \w a|strong="G1519"\w* \w los|strong="G3588"\w* judíos\f + \fr 2:8 \ft Lit. \fqa de la circuncisión.\f* \w también|strong="G2532"\w* actuó \w en|strong="G1519"\w* \w mí|strong="G3588"\w* \w para|strong="G1519"\w* \w los|strong="G3588"\w* gentiles),  
\v 9 \w y|strong="G2532"\w* \w después|strong="G2532"\w* \w de|strong="G1519"\w* \w reconocer|strong="G1097"\w* \w la|strong="G3588"\w* \w gracia|strong="G5485"\w* \w que|strong="G3588"\w* \w me|strong="G1473"\w* fue \w dada|strong="G1325"\w*, \w Jacobo|strong="G2385"\w*, \w Cefas|strong="G2786"\w* \w y|strong="G2532"\w* \w Juan|strong="G2491"\w*, \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w parecían|strong="G1380"\w* ser \w columnas|strong="G4769"\w*, nos \w dieron|strong="G1325"\w* \w las|strong="G3588"\w* manos derechas \w de|strong="G1519"\w* \w comunión|strong="G2842"\w* \w a|strong="G1519"\w* \w mí|strong="G3588"\w* \w y|strong="G2532"\w* \w a|strong="G1519"\w* Bernabé, \w para|strong="G1519"\w* \w que|strong="G3588"\w* \w nosotros|strong="G2249"\w* \w fuéramos|strong="G1510"\w* \w a|strong="G1519"\w* \w los|strong="G3588"\w* gentiles, \w y|strong="G2532"\w* \w ellos|strong="G3588"\w* \w a|strong="G1519"\w* \w los|strong="G3588"\w* judíos.\f + \fr 2:9 \ft Lit. \fqa la circuncisión.\f*  
\v 10 \w Solo|strong="G3441"\w* nos pidieron \w que|strong="G3588"\w* nos acordemos \w de|strong="G3588"\w* \w los|strong="G3588"\w* \w pobres|strong="G4434"\w*. Yo \w también|strong="G2532"\w* anhelaba \w hacer|strong="G4160"\w* \w esto|strong="G3778"\w*.   
\s1 Un enfrentamiento entre apóstoles  
\p
\v 11 \w Pero|strong="G1161"\w* \w cuando|strong="G3753"\w* \w Cefas|strong="G2786"\w* \w fue|strong="G2064"\w* \w a|strong="G1519"\w* Antioquía, \w le|strong="G2596"\w* resistí \w cara|strong="G4383"\w* \w a|strong="G1519"\w* \w cara|strong="G4383"\w* \w porque|strong="G3754"\w* \w era|strong="G1519"\w* digno \w de|strong="G1519"\w* reprensión.  
\v 12 \w Porque|strong="G1063"\w* \w antes|strong="G4253"\w* \w de|strong="G1537"\w* llegar \w algunos|strong="G5100"\w* \w de|strong="G1537"\w* parte \w de|strong="G1537"\w* \w Jacobo|strong="G2385"\w*, \add Cefas\add* \w comía|strong="G4906"\w* \w con|strong="G3326"\w* \w los|strong="G3588"\w* gentiles. \w Pero|strong="G1161"\w* \w cuando|strong="G3753"\w* \w llegaron|strong="G2064"\w*, \w al|strong="G3588"\w* atemorizarse \w de|strong="G1537"\w* \w los|strong="G3588"\w* judíos,\f + \fr 2:12 \ft Lit. \fqa de la circuncisión.\f* \w se|strong="G1438"\w* retraía \w y|strong="G2532"\w* \w se|strong="G1438"\w* apartaba.  
\v 13 \w Los|strong="G3588"\w* \w demás|strong="G3062"\w* \w judíos|strong="G2453"\w* \w se|strong="G2532"\w* unieron a \w él|strong="G3588"\w* \w en|strong="G3588"\w* \w su|strong="G3588"\w* \w hipocresía|strong="G5272"\w*, \w de|strong="G3588"\w* \w tal|strong="G5620"\w* manera \w que|strong="G3588"\w* \w aun|strong="G2532"\w* Bernabé fue arrastrado \w por|strong="G3588"\w* \w la|strong="G3588"\w* \w hipocresía|strong="G5272"\w* \w de|strong="G3588"\w* \w ellos|strong="G3588"\w*.   
\p
\v 14 \w Pero|strong="G2532"\w* \w cuando|strong="G3753"\w* noté \w que|strong="G3754"\w* \w no|strong="G3756"\w* actuaban rectamente \w en|strong="G4314"\w* \w cuanto|strong="G3588"\w* \w a|strong="G4314"\w* \w la|strong="G3588"\w* verdad \w de|strong="G4314"\w* \w las|strong="G3588"\w* Buenas Noticias, \w dije|strong="G3004"\w* \w a|strong="G4314"\w* \w Cefas|strong="G2786"\w* \w delante|strong="G1715"\w* \w de|strong="G4314"\w* \w todos|strong="G3956"\w*: \w Si|strong="G1487"\w* \w tú|strong="G4771"\w*, \w que|strong="G3754"\w* eres \w judío|strong="G2453"\w*, \w vives|strong="G2198"\w* \w como|strong="G4459"\w* gentil \w y|strong="G2532"\w* \w no|strong="G3756"\w* \w como|strong="G4459"\w* \w judío|strong="G2453"\w*, ¿\w cómo|strong="G4459"\w* obligas \w a|strong="G4314"\w* \w los|strong="G3588"\w* \w gentiles|strong="G1483"\w* \w a|strong="G4314"\w* \w vivir|strong="G2198"\w* \w según|strong="G4314"\w* \w las|strong="G3588"\w* costumbres judías?   
\s1 Las Buenas Noticias encomendadas a Pablo  
