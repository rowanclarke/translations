\v 6 \w Il|strong="G1161"\w* \w leur|strong="G1161"\w* \w dit|strong="G3004"\w* : « \w Ne|strong="G3756"\w* \w soyez|strong="G3361"\w* \w pas|strong="G3756"\w* stupéfaites. \w Vous|strong="G1161"\w* \w cherchez|strong="G2212"\w* \w Jésus|strong="G2424"\w* \w le|strong="G1161"\w* Nazaréen, \w qui|strong="G3588"\w* \w a|strong="G3004"\w* \w été|strong="G3756"\w* \w crucifié|strong="G4717"\w*. \w Il|strong="G1161"\w* \w est|strong="G3588"\w* \w ressuscité|strong="G1453"\w* ! \w Il|strong="G1161"\w* \w n|strong="G3756"\w*'\w est|strong="G3588"\w* \w pas|strong="G3756"\w* \w ici|strong="G5602"\w*. \w Voici|strong="G2396"\w* \w le|strong="G1161"\w* \w lieu|strong="G5117"\w* \w où|strong="G3699"\w* \w on|strong="G1161"\w* \w l|strong="G1161"\w*'\w avait|strong="G2424"\w* \w déposé|strong="G5087"\w* !  
