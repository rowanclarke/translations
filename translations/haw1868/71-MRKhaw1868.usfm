\id MRK
\h Mareko
\toc1 Mareko
\toc2 Mareko
\toc3 Mareko
\mt1 Mareko
\c 1
\s1 KA EUANELIO I KAKAUIA'I
\b
\q1 
\v 1 O KA mua o ka euanelio no Iesu Kristo, ke Keiki a ke Akua;
\b
\q1 
\v 2 E like me ia i palapalaia e ke kaula, e Isaia, Aia hoi, ke hoouna aku nei au i ko'u elele mamua o kou alo, nana no e hoomakaukau i kou alanui mamua ou.
\q1 
\v 3 Ka leo o ka mea e kala ana ma ka waonahele, E hoomakaukau oukou i ke alanui no ka Haku, e hana i kona mau kuamoo, i pololei.
\q1 
\v 4 Bapetizo ae la o Ioane ma ka waonahele, me ke ao mai i ka bapetizo ana no ka mihi, i mea e kalaia mai ai ka hala.
\q1 
\v 5 Hele aku la io na la ko ka aina a pau o Iudea, a me ko Ierusalema a pau, a bapetizoia iho la lakou e ia iloko o ka muliwai o Ioredane, me ka hai ana mai i ko lakou hewa.
\q1 
\v 6 Ua aahuia o loane i ke kapa hulu kamelo, a he kaei ili ma kona puhaka; a he uhini kana ai, a me ka meli o ka nahelehele.
\q1 
\v 7 Ao mai la ia, i mai la, E hele mai ana kekahi mahope nei o'u, ua oi aku ia mamua o'u, aole au e pono ke kulou iho, e wehe i ke kaula o kona mau kamaa.
\q1 
\v 8 Ua bapetizo aku no wau ia oukou i ka wai; aka, nana oukou e bapetizo aku i ka Uhane Hemolele.
\b
\q1 
\v 9 Eia kekahi, ia mau la, hele mai la o Iesu, mai Nazareta o Galilaia mai, a bapetizoia iho la ia e Ioane iloko o Ioredane.
\q1 
\v 10 A i kona pii koke ana, mai ka wai mai, ike aku la ia i na lani, ua hamama, a i ka Uhane me he manu nunu la e iho mai ana maluna ona.
\q1 
\v 11 A pae mai la ka leo, mai ka lani mai, O oe no ka'u Keiki punahele, ka mea a'u i lealea nui aku ai.
\b
\q1 
\v 12 Ia wa iho, kipaku ae la ka Uhane ia ia i ka waonahele.
\q1 
\v 13 Malaila no ia ma ka waonahele, hookahi kanaha la i hoowalewaleia mai e Satana, mawaena o na holoholona hihiu; a malama mai na anela ia ia.
\b
\q1 
\v 14 Mah ope iho o ka paa ana o Ioane iloko o ka halepaahao, hele mai la Iesu i Galilaia, me ka hai ana mai i ka euanelio no ke aupuni o ke Akua;
\q1 
\v 15 I mai la, Ua hiki mai nei ka manawa, ua kokoke mai nei ke aupuni o ke Akua. E mihi oukou a e manaoio i ka euanelio.
\b
\q1 
\v 16 I kona hele ana ae mai ka moanawai o Galilaia, ike mai la oia ia Simona, a me kona kaikaina, o Anederea, e kuu ana i ka upena ma ka moanawai; no ka mea, he mau lawaia laua.
\q1 
\v 17 I mai la Iesu ia laua, E hahai olua mamuli o'u, a e hoolilo wau ia olua i mau lawaia kanaka.
\q1 
\v 18 Haalele koke iho la laua i ka laua mau upena, a hahai aku la ia ia.
\q1 
\v 19 A hele iki ae la ia, ike mai la oia ia Iakobo a Zebedaio, a me kona kaikaina o Ioane, iluna pu laua o ka moku e hono ana i na upena.
\q1 
\v 20 Kahea koke mai la ia laua; a haalele iho la laua i ko laua makuakane, ia Zebedaio, iluna o ka moku, me na kanaka paaua, a hahai aku la laua ia ia.
\b
\q1 
\v 21 Hele ae la lakou i Kaperenauma, komo koke ae la ia iloko o ka halehalawai i ka la Sabati, a ao mai la.
\q1 
\v 22 Mahalo iho la lakou i kana ao ana, no ka mea, ao mai la oia ia lakou, me he mea mana la, aole like me ka poe kakauolelo.
\q1 
\v 23 A maloko o ko lakou halehalawai kekahi kanaka i loohia e ka uhane ino, a walaau ae la ia;
\q1 
\v 24 I ae la, Ea, heaha kau ia makou, e Iesu no Nazereta? I hele mai nei anei oe e luku mai ia makou? Ua ike no au ia oe; o oe no ka mea hoano a ke Akua.
\q1 
\v 25 Papa ae la Iesu ia ia, i ae la, Hamau, e puka mai oe iwaho ona.
\q1 
\v 26 Hookaawili iho la ka uhane ino ia ia, walaau ae la ia me ka leo nui, a paka mai la ia iwaho ona.
\q1 
\v 27 Mahalo aku la lakou a pau, nolaila, nalu lakou ia lakou iho no, i ae la, Heaha la keia? Heaha la hoi keia ao hou ana? No ka mea, me ka leo mana no oia e kauoha aku nei i na uhane ino, a hoolohe io aku no lakou ia ia.
\q1 
\v 28 Kui koke aku la kona kaulana ma na mokuna a pau o Galilaia.
\b
\q1 
\v 29 I ko lakou puka ana iwaho o ka halehalawai, komo koke ae la lakou me Iakobo, a me Ioane iloko o ka hale o Simona laua o Anederea,
\q1 
\v 30 E moe ana ka makuahunoaiwnhine o Simona, i ka mai kuni; a hai koke ae la lakou ia Iesu nona.
\q1 
\v 31 Alaila, hele mai la ia, lalau iho la i kona lima, hoala mai la ia ia; a haalele koke iho la ke kuni ia ia, a lawelawe ae la ia na lakou.
\b
\q1 
\v 32 A ahiahi ae la, i ke komo ana a ka la, halihali mai la lakou io na la i na mea a pau i loohia i ka mai a me na daimonio.
\q1 
\v 33 Akoakoa mai la ko ke kulanakauhale a pau ma ka ipuka.
\q1 
\v 34 He nui na mea mai ana i hoola mai ai, na mea i loohia i kela mai, i keia mai, a nui no hoi na daimonio ana i mahiki aku ai; aole ia i ae mai ia lakou e olelo iki ae, no ka mea, ua ike lakou ia ia.
\b
\q1 
\v 35 A i ka pili o ke ao ae, i ka wa poeleele, ala ae la ia, hele aku la iwaho, a hiki i kahi mehameha, ilaila oia i pule ai.
\q1 
\v 36 A hahai aku la o Simona ia ia a me ka poe me ia pu.
\q1 
\v 37 A loaa mai la oia ia lakou, i aku la lakou ia ia, Ke imi nei na kanaka a pau ia oe.
\q1 
\v 38 I mai la oia ia lakou, E hele kakou ma kela mau kulanakauhale, e ao aku ai au malaila. O ko'u mea ia i hele mai ai iwaho nei.
\q1 
\v 39 A ao mai la ia ma ko lakou halehalawai ma Galilaia a pau, a mahiki aka la hoi i na daimonio.
\b
\q1 
\v 40 Hele aku la kekahi mai lepera io na la, kukuli iho la, nonoi aku ia ia, i aka la, Ina makemake oe, e hiki no ia oe ke huikala mai ia'u.
\q1 
\v 41 Haehae ae la ko Iesu aloha, o aku la kona lima, a hoopa aku la ia ia, i ae la, Ua makemake au, e huikalala oe.
\q1 
\v 42 A i kana olelo ana, haalele koke aku la ka lepera ia ia, a huikalaia oia.
\q1 
\v 43 Kauoha ikaika aku la Iesu ia ia, alaila, kuu iho la.
\q1 
\v 44 I aku la ia ia, E ao oe, mai hai iki aku i kekahi; aka, e hele aku oe e hoike aku ia oe iho i ke kahuna, a e mohai aku no kou huikalaia i ka mea a Mose i kauoha mai ai, i mea e ike ai lakou.
\q1 
\v 45 A hiki aku ua kanaka la iwaho, hoolaha ae la ia, a hookaulana loa ia mea, nolaila, i ole ai e hiki ia Iesu ke komo maopopo iloko o ke kulanakauhale, iwaho aku no ia i na wahi mehameha; a hele aku la ko kela wahi, ko keia wahi io na la.
\c 2
\b
\q1 
\v 1 A MAHOPE iho o ia mau la, hele hou aku la no o Iesu i Kaperenauma, a loheia'e la kona noho ana iloko o ka hale.
\q1 
\v 2 A hoakoakoa koke ia mai la na kanaka he nui loa, aole loa he wahi kaawale iki, aole no hoi ma ka ipuka, a hai mai la ia i ka olelo ia lakou.
\q1 
\v 3 Hele mai la lakou io na la, e halihali pu mai ana i kekahi mai lolo, i kaikaiia e na mea eha.
\q1 
\v 4 Aole hiki ia lakou ke komo aku io na la, no ka paapu i kanaka, nolaila wawahi lakou maluna o ka hale, ma kona wahi; a hemo ia lakou, alaila kuu iho la lakou i kahi moe i moe iho ai ka mai lolo.
\q1 
\v 5 Ike mai la Iesu i ko lakou manaoio, olelo iho la ia i ua lolo la, E ke kamaiki, ua kalaia kou hewa.
\q1 
\v 6 E noho ana kekahi poe kakauolelo malaila, a ohumu iho la lakou iloko o ko lakou naau;
\q1 
\v 7 No ke aha la oia nei e olelo ai i na olelo hoino? Owai la ka meae hiki ai ke kala i ka hala, o ke Akua wale no?
\q1 
\v 8 I ko Iesu ike koke ana ma kona naau, ua ohumu malu lakou pela, i aku la oia ia lakou, No ke aha la oukou e ohumu nei i keia mau mea iloko o ko oukou naau?
\q1 
\v 9 Mahea ka hiki pono o ka olelo i ka mai lolo, Ua kalaia kou hewa; a o ka olelo paha, E ala'e, e kaikai i kou wahi moe, a e hele?
\q1 
\v 10 Aka, i ike oukou, he mana ko ke Keiki a ke kanaka ke kala aku i ka hala ma ka honua nei, (i ae la ia i ka mai lolo,)
\q1 
\v 11 Ke olelo aku nei au ia oe, E ala mai, e kaikai i kou wahi moe, a e hoi aku i kou hale.
\q1 
\v 12 Ala koke ae la ia, kaikai ae la i kona wahi moe, a hele aku la iwaho, imua o lakou a pau; nolaila, mahalo aku la lakou a pau, hoonani aku la i ke Akua, i iho la, Akahi na kakou i ike i keia.
\b
\q1 
\v 13 Hele hou aku la ia ma kapa o ka moanawai; a hele mai la na kanaka a pau io na la, a ao mai la oia ia lakou.
\q1 
\v 14 A i kona hele ana'e, ike iho la oia ia Levi a Alapaio, e noho ana i kahi auhau, i mai la ia ia, E hahai mai oe ia'u. Ku ae la ia, a hahai aku la ia ia.
\b
\q1 
\v 15 Eia kekahi, i kona noho ana i ka aina iloko o kona hale, he nui loa na lunaauhau a me na mea lawehala i noho pu me Iesu a me kana poe haumana; no ka mea, ua nui loa ka poe i hahai mamuli ona.
\q1 
\v 16 A ike aku la ka poe kakauolelo, a me ka poe Parisaio ia ia e ai pu ana me ua lunaauhau, a me na lawehala, ninau ae la lakou i kana poe haumana, No ko aha la oia neie ai pu ai a inu pu hoi me na lunaauhau a me na lawehala?
\q1 
\v 17 Lohe ae la Iesu, i aku la oia ia lakou, Aole no ka poe ola ke kahuna lapaau, no ka poe mai no ia. I hele mai nei au e ao aku i ka poe lawehala e mihi, aole i ka poe pono.
\b
\q1 
\v 18 He poe hookeai na haumana a Ioane, a me na Parisaio; a hele mai la lakou, ninau mai la ia ia, No ke aha la e hookeai ai na haumana a Ioane, a me na Parisaio, aole hoi hookeai kau poe haumana?
\q1 
\v 19 Ninau aku la Iesu ia lakou, E hiki anei i na hoa o ke kanemare ke hookeai i ka wa e noho pu ana ke kanemare me lakou? I ka wa e noho pu ana ke kanemare me lakou, aole e hiki ia lakou ke hookeai.
\q1 
\v 20 Aka, e hiki mai ana no na la e laweia'ku ai ke kanemare, mai o lakou aku, alaila lakou e hookeai ai, i kela la.
\q1 
\v 21 Aole no kekahi e pinai i ka apana lole hou, ma ka lole kahiko, o haehaeia ka mea kahiko, e ka mea hou i pinaiia, a nui aku ka nahae.
\q1 
\v 22 Aole no hoi kekahi i ukuhi i ka waina hou iloko o ka hue ili kahiko, o nahae na hue i ka waina hou, a kahe aku ka waina, a pau pu na hue, aka, e ukuhiia no ka waina hou iloko o na hoe hou.
\b
\q1 
\v 23 Eia kekahi, i kona hele ana iwaena o na mahinaai i ka la Sabati, ako aku na haumana ana i na huhui palaoa, i ko lakou hele ana.
\q1 
\v 24 I mai la ka poe Parisaio ia ia, No ke aha la e hana nei lakou, i ka la Sabati, i ka mea ku ole ma ka pono?
\q1 
\v 25 I aku la oia ia lakou, Aole anei oukou i heluhelu i ka mea a Davida i hana'i i kona wa i haiki ai i ka pololi, a me ka poe me ia?
\q1 
\v 26 I kona komo ana iloko o ka hale o ke Akua, i ka wa o Abiatara, ke kahuna nui, a ai iho la i ka berena hoike, i ka mea ku pono ole ke ai, na na kahuna wale no, a haawi ae la no hoi na ka poe me ia.
\q1 
\v 27 I mai la ia ia lakou, ua hanaia ka la Sabati no kekanaka, aole ke kanaka no ka Sabati.
\q1 
\v 28 Nolaila, o ke Keiki a ke kanaka, oia ka Haku o ka la Sabati.
\c 3
\b
\q1 
\v 1 A KOMO hou aku la ia iloko o ka halehalawai, malaila kekahi kanaka, ua maloo kona lima.
\q1 
\v 2 Hakilo aku la lakou ia ia, ina paha e hoola mai oia ia ia i ka la Sabati, i hoopii aku ai lakou ia ia.
\q1 
\v 3 I mai la ia i ke kanaka, nona ka lima maloo, E ku maioe, iwaena konu.
\q1 
\v 4 Alaila, ninau mai la oia ia lakou, He mea pono anei ke hana i ka maikai i na la Sabati, ake hana i ka ino paha? Ke hoola anei, ko pepehi paha? Pilipu iho la lakou.
\q1 
\v 5 Nana ae la oia ia lakou me ka inaina, no ka mea, ua minamina ia no ka paakiki o ka lakou naau. I ae la ia i ua kanaka la, E o mai kou lima, A o mai la ia, alaila hoolaia iho la ia, e like me kekahi lima.
\q1 
\v 6 Hele aku la ka poe Parisaio iwaho, a me ko Herode poe, ohumu iho la lakou e pepehi ia ia a make.
\b
\q1 
\v 7 Hele aku la Iesu i ka moanawai, me kana poe haumana; he nui no hoi ka poe i hahai aku ia ia, no Galilaia a no Iudea.
\q1 
\v 8 A no Ierusalema, a no Idumia, a no kela aoao o Ioredane, a me ka poe e kokoke ana i Turo, a me Sidona, he poe nui loa: i ko lakou lohe ana i na mea ana i hana'i, hele mai la lakou io na la.
\q1 
\v 9 A no ka nui o kanaka, kauoha mai la ia i kana poe haumana, i wahi moku iki nona, o hooke mai lakou ia ia.
\q1 
\v 10 No ka mea, ua hoola oia i na mea he nui loa, nolaila lakou i lulumi mai ai e hoopa aku ia ia, o ka poe a pau i loohia i ka mai.
\q1 
\v 11 A ike aku la na uhane ino ia ia, moe iho la lakou imua ona, kahea ae, hai ae la, O oe no ke Keiki a ke Akua.
\q1 
\v 12 Papa ikaika mai la oia ia lakou e hoike ole aku ia ia.
\b
\q1 
\v 13 Alaila, pii ae la ia i ka mauna. hea mai la i ka poe ana i makemake ai, a hele aku la lakou io na la.
\q1 
\v 14 Wae mai la ia i umikumamalua e noho pu me ia, I hoouna oia ia lakou e ao aku,
\q1 
\v 15 I lako hoi lakou i ka mana e hoola i na mai, a e mahiki aku i na daimonio.
\q1 
\v 16 Haawi ae la oia ia Simona i ka inoa hou, o Petero,
\q1 
\v 17 O Iakobo a Zebedaio, a me kona kaikaina o Ioane kapa mai la hoi ia ia laua, o Boanerege, oia hoi keia, Na keiki a ke hekili;
\q1 
\v 18 A me Anederea, a me Pilipo, a me Baretolomaio, a me Mataio, a me Toma, a me Iakobo a Alepaio, a me Tadaio, a me Simona no Kanaana,
\q1 
\v 19 A me Iuda Isekariote, ka mea nana ia i kumakaia'ku. Komo aku la lakou iloko o ka hale.
\b
\q1 
\v 20 A akoakoa Lou mai la na kanaka, he nui loa, no ia mea i ole ai e hiki ia lakou ke ai i ka ai.
\q1 
\v 21 A lohe kona poe, hele mai lakou e lalau ia ia, no ka mea, olelo lakou, Ua hehena ia.
\b
\q1 
\v 22 Olelo iho la ka poe kakauolelo i iho mai, mai Ierusalema mai, Ia ia no o Beelezebuba, a ma ke alii o na daimonio kona mahiki ana i na daimonio.
\q1 
\v 23 Hea aku la Iesu ia lakou, olelo aku la ma na olelonane, Pehea la o hiki ai ia Satana ke mahiki aku ia Satana?
\q1 
\v 24 A ina i mokuahana kekahi aupuni ia ia iho, aole e mau ia aupuni.
\q1 
\v 25 A ina i mokuahana ka hale ia ia iho, aole e mau ia hale.
\q1 
\v 26 A ina ku e mai o Satana ia ia iho, a mokuahana, aole ia e mau, aka, e pau no ia.
\q1 
\v 27 Aole no e hiki i kekahi ke komo iloko o ka hale o ke kanaka ikaika a hao i kona waiwai, aia nakinaki mua oia i ke kanaka ikaika; alaila e hao oia i na mea o kona hale.
\q1 
\v 28 He oiaio ka'u e hai aku nei ia oukou, e kalaia no na hala a pau o na keiki a kanaka, a me na olelo hoino a pau o lakou e hoino ai:
\q1 
\v 29 Aka, o ka mea e olelo hoino i ka Uhane Hemolele, aole loa e kalaia kana, aka, na kokoke no ia i ka hoopai mau loa ia mai.
\q1 
\v 30 No ka mea, ua olelo mai lakou, He uhane ino kona.
\b
\q1 
\v 31 Alaila, hele aku la kona makuwahine a me kona mau hoahanau, ku iho la iwaho, hoouna aku la io na la e kii ia ia.
\q1 
\v 32 Ua puni oia i ka poe nui i noho mai la, a hai ae la lakou ia ia, Aia iwaho kou makuwahine, a me kou mau hoahanau, ke imi mai nei ia oe.
\q1 
\v 33 I mai la oia ia lakou, ninau mai la, Owai ko'u makuwahine, a me ko'u mau hoahanau?
\q1 
\v 34 Nana ae la ia i ka poe e noho puni ana ia ia, i mai la, Aia ko'u makuwahine a me ko'u mau hoahanau!
\q1 
\v 35 No ka mea, o ka mea hana i ka makemake o ke Akua, oia ko'u hoahanau, a me ko'u kaikuwahine, a me ko'u makuwahine.
\c 4
\b
\q1 
\v 1 HOOMAKA iho la oia e ao hou ma kapa o ka moanawai; a no ka nui loa o ka poe i akoakoa mai io na la, ee aku la ia maluna e kekahi moku, noho iho la maluna o ka wai, a pau mai la ka ahakanaka mauka, ma kapa o ka moanawai.
\q1 
\v 2 Ao nui mai la oia ia lakou ma na olelo nane, i mai la ia lakou ma kana ao ana,
\q1 
\v 3 E hoolohe mai; aia hoi, hele aku la kekahi kanaka lulu hua, e lulu.
\q1 
\v 4 A i kana lulu aua, helelei iho la kekahi ma kapa alanui, a lele mai la na manu o ka lewa, a ai iho la ia mea.
\q1 
\v 5 Helelei iho la kekahi ma kahi paaa, kahi i nui ole ai kona lepo; kupu wawe ae la ia, no ka papau o ka lepo.
\q1 
\v 6 A puka mai ka la, mae iho la ia, a maloo aku la, no ke aa ole.
\q1 
\v 7 A helelei ae la kekahi mawaena o na kakalaioa; kupu mai la na kakalaioa, a kahihi iho la ia mea, nolaila, aole i hua mai ka hua.
\q1 
\v 8 Helelei iho la kekahi ma kahi lepo maikai, a pun mai la i ka hua, i kupu a mahuahua, a hua mai, pakanakolu, a pakanaono kekahi, a pahaneri kekahi.
\q1 
\v 9 I mai la oia ia lakou, O ka mea pepeiao lohe la, e hoolohe mai ia.
\b
\q1 
\v 10 A loaa ia ia ka mehameha, alaila, ninau aku la ia ia ka poe e ku pu ana me ia, a me ka poe umikumamalua, i ua olelonane la.
\q1 
\v 11 I mai la oia ia lakou, Ua haawiia mai ia oukou e ike i na mea pohihihi o ke aupuni o ke Akua; aka, ua naneia'ku na mea a pau i ka poe mawaho;
\q1 
\v 12 I nana lakou a milimili, aole nae e ike; i hoolohe hoi a lohe, aole nae e hoomaopopo, o hoohulina mai lakou, a e kalaia ko lakou hala.
\q1 
\v 13 Alaila, i mai la oia ia lakou, Aole anei oukou i ike i keia olelonane? Pehea la oukou e ike ai i na olelonane a pau?
\b
\q1 
\v 14 O ke kanaka lulu hua, ua lulu i ka olelo.
\q1 
\v 15 Eia ka poe ma kapa alanui, ma kahi i luluia i ka olelo, a lohe lakou, alaila hele koke mai o Satana a kaili aku i ka olelo i luluia iloko o ko lakou naau.
\q1 
\v 16 Eia no hoi na mea i luluia ma kahi paaa; a lohe lakou i ka olelo, hopu koke lakou ia, me ka olioli.
\q1 
\v 17 Aka, aole o lakou mole iloko o lakou, nolaila, aole i mau, a hiki mai ka pilikia a me ka hoinoia no ka olelo, alaila, lilo koke lakou.
\q1 
\v 18 Eia hoi na mea i luluia iwaena o na kakalaioa, o ka poe i lohe i ka olelo,
\q1 
\v 19 A o ka manao nui i na mea o ke ao, a o ka hoopunipuni ana o ka waiwai, me ke kuko ana i na mea e, oia ka mea i iiia'i ka olelo, a lilo ia i mea hua ole.
\q1 
\v 20 Eia no hoi na mea i luluia ma kahi lepo maikai; o na mea i hoolohe i ka olelo, a hoopaa iho, a hua mai i ka hua, pakanakolu kokahi, a pakanaono kekahi, a pahaneri kekahi.
\b
\q1 
\v 21 I mai la oia ia lakou, Ua laweia mai anei he kukui e hahaoia'i malalo o ke poi, a malalo o kahi moe paha, aole anei no ke kania maluna o kahi e kau ai ke kukui?
\q1 
\v 22 No ka mea, aohe mea huna e koe i ka hoike ole ia, aole hoi he mea i uhi malu ia e koe i ka hu ole mawaho.
\q1 
\v 23 Ina he pepeiao ko ke kauaka e lohe ai, e hoolohe mai ia.
\q1 
\v 24 I mai la oia ia lakou, E noonoo oukou i ka oukou mea e lohe ai: no ka mea, ma ke ana a oukou e ana aku ai, malaila e anaia mai no hoi oukou pela; a e haawi nui ia ia oukou, i ka poe e hoolohe mai
\q1 
\v 25 O ka mea ua loaa, e haawiia 'ku nana; aka, o ka mea ua loaa ole, e kailiia'ku kana, mai ona aku la.
\b
\q1 
\v 26 I mai la ia, Meneia ke aupuni o ke Akua, me ke kana ana a ke kanaka i ka hua ma ka lepo;
\q1 
\v 27 A moe iho, a ala'e i ka po, a me ke ao, e kupu ae ana ua hua la a nui, aole nae ia i ike.
\q1 
\v 28 No ka mea, hoohua wale mai no ka honua, mamua ka hoomaka, mahope iho ka huhui, alaila ka hua oo maloko o ka huhui.
\q1 
\v 29 A i ka makaukau ana o ka hua, alaila, hookomo koke ae la ia i ka pahi, no ka mea, ua hiki mai ka wa e oki ai.
\b
\q1 
\v 30 I mai la oia, Me ke aha la kakou e hoohalike ai i ke aupuni o ke Akua? A ma ka nane hea kakou e hoakaka aku ai ia?
\q1 
\v 31 Ua like no ia me ka hua makeke, i ka wa i kanuia'i ma ka lepo, he hua liilii loa ia o na hua a pau i kanuia ma ka lepo.
\q1 
\v 32 Aka, i ka wa i kanuia'i, kupu no ia, a lilo i laalaau nui o na laalaau a pau, a opuu mai la na lala nui, a hiki no i na manu o ka lewa ke kau mai malalo o kona malu.
\b
\q1 
\v 33 Hai mai la ia i ka olelo ia lakou ma ua olelonane e like me ia he nui loa, me lakou e hiki ai ke hoolohe aku.
\q1 
\v 34 Aole ia i olelo iki aku ia lakou ma ka olelonane ole; a ma kahi mehameha, hoakaka ae la ia i na mea a pau i kana poe haumana.
\b
\q1 
\v 35 Ia la no, a ahiahi ae, i mai la ia ia lakou, E holo kakou i kela kapa.
\q1 
\v 36 A haalele aku la lakou i ka ahakanaka, a lawe aku la ia ia e noho ana ma ka moku: he mau moku liilii no hoi kekahi me ia pu.
\q1 
\v 37 Nou mai la ka makani ikaika, uhi mai la na ale iluna o ka moku, a piha iho la ia.
\q1 
\v 38 E moe ana ia ma ka uluna, ma ka hope o ka moku; hoala ae la lakou ia ia, i aku la, E ke Kumu, he mea ole anei ia oe ke make makou?
\q1 
\v 39 Alaila ku ae la ia iluna, papa ae la i ka makani, a olelo ae la i ka moanawai, Hamau, e noho malie. Oki iho la ka makani, a pohu maikai iho la.
\q1 
\v 40 I mai la oia ia lakou, No ke aha la oukou i makau ai? Pehea ko oukou manaoio ole ana?
\q1 
\v 41 Weliweli loa ae la lakou, i ae la kekahi i kekahi, Heaha la ke ano o ia nei, i hoolohe pono ai ka makani a me ka moanawai ia ia?
\c 5
\b
\q1 
\v 1 A LAILA, holo ae la lakou i kela kapa o ka moanawai i ka aina o Gadara.
\q1 
\v 2 I kona lele ana ae, mai ka moku ae, halawai koke me ia kekahi kanaka i uluhia e ka uhane ino, no na ilina mai.
\q1 
\v 3 Ma na ilina no kona wahi e noho ai, aole me na kaulahao e hiki ai ke hoopaa ia ia a paa.
\q1 
\v 4 Ua hoopaa pinepine ia oia i ke kupee ana a me na kaulahao, a moku ia na kaulahao e ia, a kakihakiia no hoi na kupee, aole no i hiki i kekahi ke hoolakalaka ia ia.
\q1 
\v 5 Mau loa no ia i ka po a me ke ao ma na kuahiwi, a ma na ilina e uwalaau ana, a e okioki ana ia ia iho no i na pohaku.
\q1 
\v 6 I kona ike ana ia Iesu ma kahi mamao aku, holo ae la ia a moe iho la imua ona;
\q1 
\v 7 Kahea ae la ia me ka leo nui, i ae la Heaha kau ia'u, e Iesu, e ke Keiki a ke Akua kiekie loa? Ke papa aku nei au ia oe ma ke Akua, mai hoomainoino mai ia'u.
\q1 
\v 8 No ka mea, na olelo e aku Iesu ia ia, E ka ubane ino, e hele aku oe pela iwaho o ia kanaka.
\q1 
\v 9 Ninau aku la Iesu ia ia, Owai la kou inoa? Hai mai kela, i mai la, O Legeona ko'u inoa, no ka mea, na nui loa makou.
\q1 
\v 10 Nonoi nui ae la kela ia ia, i kipaku ole oia ia lakou, mailoko aku o ia aina.
\q1 
\v 11 Ma ia wahi aku, ma ka pun, he nui ka poe puaa e ai ana.
\q1 
\v 12 Nonoi ae la na daimonio a pau ia ia, i aku la, E hoouna ae oe ia makou i na puaa, i komo aku ai makou iloko o lakou.
\q1 
\v 13 Ae koke ae la Iesu ia lakou. Alaila, puka aku la na uhane ino iwaho, a komo aku la iloko o na puaa; a holo kiki iho la lakou ilalo ma kahi pali, iloko o ka moanawai, (elua paha tausani lakou,) a make iho la iloko o ka wai.
\q1 
\v 14 Holo aku la ka poe i kanai ia lakou, a hai ae la ma ke kulanakauhale, a ma na kauhale; a haelo ae la lakou iwaho, e ike i na mea i hanaia'i.
\q1 
\v 15 A hiki mai la lakou io Iesu la, a ike i ka mea i uluhia e ka daimonio, nona ka legeona, e noho ana me ka aahu, a me ka manao pono; makau ae la lakou.
\q1 
\v 16 O ka poe i ike pono, hai aku la ia lakou i na mea i hanaia'i i ka mea i uluhia o ka daimouio, a no na puaa hoi.
\q1 
\v 17 A hoomaka ae la lakou e nonoi ia ia i haalele ai ia i ko lakou aina.
\q1 
\v 18 I kona ee ana iluna o ka moku, hele aku la io na la ka mea i ulahia e ka daimonio, nonoi aku la ia ia, e noho pu oia me ia.
\q1 
\v 19 Aole Iesu i ae, i mai la no nae ia ia, E hoi oe i kou hale, i kou poe hoahanau, e hai aku ia lakou i na mea nui a ka Haku i hana'i nou, a me kona lokomaikai ia oe.
\q1 
\v 20 Hele ae la ia, a hoomaka ae la e hai aku ma Dekapoli i na mea a Iesu i hana'i nona; a kahaha iho la ka naau o na kanaka a pau.
\b
\q1 
\v 21 I ka hoi ana o Iesu ma ka moku, a hiki i kela kapa, nui loa iho la na kanaka i akoakoa mai la io na la; a aia no ia ma kapa o ka moanawai.
\q1 
\v 22 Aia hoi, hele mai la kekahi luna halehalawai, o Iaero kona inoa, a ike oia ia ia, haule iho la ia ma kona mau wawae.
\q1 
\v 23 A nonoi nui ae la ia ia, i ae la, Ke waiho la kuu kaikamahine i ka welau o ka make; e hele ae oe, e kau iho i kon lima maluna ona, a e ola no ia.
\q1 
\v 24 A hele pu aku la Iesu me ia, he nui loa na kanaka i hahai pu aku la, a hooke iho la ia ia.
\b
\q1 
\v 25 Aia hoi he wahine heekoko, he umi na makahiki a me kumamalua;
\q1 
\v 26 A ua nui kona kaumaha no na kahuna lapaau he nui loa, a ua hoopau loa i kona waiwai, aole nae i maha iki, ua mahuahua no ka mai.
\q1 
\v 27 A lohe aku la ia no Iesu, alaila, hele mai la ia mahope, a iloko o ka ahakanaka, hoopa aku la i kona kapa.
\q1 
\v 28 No ka mea, ua nalu iho no ia, Ina paha e hoopa au i kona kapa wale do, e ola au.
\q1 
\v 29 Maloo koke ae la ke kumu o kona koko; a ike iho la ia iloko o kona kino, ua ola ia i kela mai.
\q1 
\v 30 Alaila, ike koke iho la o Iesu iloko ona, ua puka aku kekahi mane, mai ona aku la, huli ae la ia maloko o ka ahakanaka, i mai la, Owai la ka mea hoopa mai i kuu aahu?
\q1 
\v 31 I aku la kana poe haumana ia ia, Ke ike mai nei no oe i ka ahakanaka, e hooke ana ia oe, a ke ninau mai nei anei oe, Owai ka i hoopa mai ia'u?
\q1 
\v 32 Alawa ae la ia e nana ae i ka mea nana i hana ia mea.
\q1 
\v 33 Aka, o ua wahine la, hele mai la ia me ka makau, a me ka haalulu, no ka mea, ua ike pono ia i ka mea i banaia'e iloko ona, a hai pololei aku la ia ia.
\q1 
\v 34 I mai la oia ia ia, E kuu kaikamahine, ua ola oe i kou manaoio! e hele pomaikai oe, me ke ola ana o kon mai.
\b
\q1 
\v 35 A i kana olelo ana, hele mai la kekahi mea, no ka luna halehalawai, i mai la, Ua make kou kaikamahine, no ke aha la oe e hooluhi hou aku ai i ke kumu?
\q1 
\v 36 A lohe Iesu ia olelo i oleloia'e, i mai la ia i ka luna halehalawai, Mai makau oe, e manaoio wale mai no.
\q1 
\v 37 Aole ia i ae mai i kekahi kanaka e ae e hahai aku ia ia, o Petero wale no, a me Iakobo, a me Ioane, ke kaikaina o Iakobo.
\q1 
\v 38 A hiki ae la ia i ka hale o ua luna halehalawai la, ike ae la ia i ka haunaele, a me ka poe alala, e uwe nui ana.
\q1 
\v 39 A i kona komo ana iloko, i mai la oia ia lakou, No ke aha la oukou e makena'i me ka uwe iho? Aole i make ke kaikamahine, aka, e hiamoe ana no.
\q1 
\v 40 Hoo wahawaha aku la lakou ia ia: aka, kipaku ae la oia ia lakou a pau iwaho, alaila lawe ae la ia i ka makuakane a me ka makuwahine o ua keiki la, a me kona poe iho, a komo ae la iloko o kahi i moe ai ke keiki.
\q1 
\v 41 Lalau ae la ia i ka lima o ua keiki la, i mai la ia ia, Talitakoumi, oia hoi keia ma ka hoohalike ana, E ke kaikamahine, ke olelo aku nei au ia oe, e ala iluna.
\q1 
\v 42 Ala koke ae la ke kaikamahine, a hele ae la; no ka mea, he umikumamalua kona mau makahiki: a kahaha nui loa iho la ko lakou naau.
\q1 
\v 43 Papa ikaika mai la oia ia lakou, mai hai aku i keia i kekahi: alaila, kauoha mai la ia, e haawiia kekahi mea nana e ai ai.
\c 6
\b
\q1 
\v 1 HAALELE iho la ia i kela wahi, a hele i kona aina iho; a hahai aku la kana poe haumana ia ia.
\q1 
\v 2 A hiki i ka la Sabati, hoomaka ia e ao mai iloko o ka halehalawai; a nui loa ka poe i lohe, a kahaha ka naau, i ae la, Nohea la ia mau mea a ia nei? Heaha hoi keia akamai i haawiia'e nana, a me keia hana mana i hanaia'i e kona mau lima?
\q1 
\v 3 Aole anei keia o ke kamana, o ke keiki a Maria, ka hoahanau o Iakobo, a me Iose, a me Iuda, a me Simona? Aole anei kona mau kaikuwahine maanei me kakou? Kuia iho la lakou ia ia.
\q1 
\v 4 I mai la Iesu ia lakou, Aohe kaula i mahalo ole ia ma kahi e, aia ma kona aina iho no, a i kona hanauna, a i kona hale.
\q1 
\v 5 Aole ia i hiki ke hana i na hana mana ilaila, he mau mea mai wale no nae kana i hoola'i, i ke kau ana o kona mau lima iluna iho o lakou.
\q1 
\v 6 A kahaha iho la ia no ko lakou hoomaloka ana: hele ae la ia i na kauhale, e ao ana ia lakou.
\b
\q1 
\v 7 Alaila houluulu mai la ia i ka poe umikumaraalua, a hoomaka e hoouna papalua ae la ia lakou, a haawi mai la i ka mana na lakou maluna iho o na uhane ino.
\q1 
\v 8 Papa mai la oia ia lakou, mai lawe oukou i kekahi mea no ka hele ana, i kookoo wale no, aohe puolo, aohe berena, aohe kala iloko o ka hipuu.
\q1 
\v 9 E hawele i na kamaa, aole hoi e papalua ke kapa komo.
\q1 
\v 10 I mai la oia ia lakou, A i na wahi a pau loa a oukou e komo ai iloko o ka hale, e noho iho oukou malaila, a hiki i ka wa e haalele ai oukou ia wahi.
\q1 
\v 11 A o ka mea hookipa ole mai ia oukou, aole hoi e hoolohe mai i ka oukou, a i ko oukou hele ana aku, e lulu i ka lepo malalo o ko oukou mau wawae, i mea hoike no lakou. Oiaio ke olelo aku nei au ia oukou, i ka la hoopai, e aho no ka make ana o ko Sodoma a me Gomora, i ko ia kulanakauhale.
\q1 
\v 12 Hele ae la lakou iwaho, ao aku la i kanaka, e mihi lakou.
\q1 
\v 13 Mahiki aku la lakou i na daimonio he nui, a hamo ae lakou me ka aila i kanaka mai he nui loa, a hoola ae la ia lakou.
\b
\q1 
\v 14 A lohe ae la o Herode, ke alii, (no ka mea, ua kaulana aku ko Iesu mea,) i ae la ia, Ua ala hou mai nei o Ioano Bapetite, maiwaena mai o ka poe make, no ia mea, ua hoikeia na hana mana, ma o na la.
\q1 
\v 15 Olelo ae la kekahi poe, O Elia keia: a olelo ae la kekahi poe, He kaula ia, a he mea like me kekahi o ka poe kaula.
\q1 
\v 16 Lohe ae la o Herode, i ae la ia, o Ioane keia, nona ke poo a'u i oki ai; na ola hou mai ia, maiwaena mai o ka poe make.
\q1 
\v 17 No ka mea, ua hoouna aku o Herode, a hopu ia Ioane, a hoopau ia ia iloko o ka halepaahao, no Herodia, no ka wahine a Pilipo, a kona kaikaina; no ka mea, ua mare o Herode me ia.
\q1 
\v 18 A ua olelo aku o Ioano ia ia, Aole pono kou lawe ana i ka wahine a Kou kaikaina.
\q1 
\v 19 No ia mea i nkiuki ai o Herodia ia ia, manao iho la no hoi e pepehi ia ia, aole nae i hiki;
\q1 
\v 20 No ka mea, na makau o Herode ia Ioane ua ike ia, ho kanaka pono oia, a me ka hemolele, a malama no o Herode ia ia, a hoolohe no i kana, a nui na mea ana i haua'i me ka hoolohe oluolu ia ia.
\q1 
\v 21 A hiki mai ka la maopopo a Herode i hoomakaukau ai i ahaaina hanau no kana mau alii, a me na lunatausani, a no na mea koikoi o Galilaia;
\q1 
\v 22 Alaila, komo ae la ke kaikamahine a Herodia, a haa iho la ia, a olioli o Herode ia ia, a me ka poe e noho pu ana me ia; alaila, olelo mai la ke alii i na kaikamahine la, E noi mai oe ia'u i kau mea e makemake ai, a e haawi aku no wau ia oe.
\q1 
\v 23 Hoohiki aku la oia ia ia, O ka mea au e noi mai ai ia'u, na'u ia e haawi aku ia oe, a hiki i ka hapalua o ke aupuni o'u.
\q1 
\v 24 Hele aku la ia iwaho, i aku la i kona makuwahine, Heaha la uanei ka'u mea o noi aku ai? Olelo mai la ia, O ke poo o Ioane Bapetite.
\q1 
\v 25 A hele wikiwiki ae la ia i ke alii, nonoi ae la, i ae, Makemake au e haawi koke mai oe ia'u i ke poo o Ioane Bapetite, maluna o kekahi pa.
\q1 
\v 26 Minamina loa iho la ke alii, aka, no kona hoohiki e ana, a no ka poe o noho pu ana me ia, i manao ole ai ia e hoole aku ia ia.
\q1 
\v 27 Kana koke ae la ke alii i kekahi ilamuku, olelo ae la e laweia mai kona poo. Hele aku la ia, a oki ae la i kona poo iloko o ka halepaahao;
\q1 
\v 28 A lawe mai la ia i ke poo, iluna o ke pa, a haawi mai la i ua kaikamahine la, a haawi ae la hoi ke kaikamahine i kona makuwahine.
\q1 
\v 29 Lohe iho la kana poe haumana, hele mai la lakou, a lawe aku la i ke kino, a waiho iho la iloko o ka halekupapau.
\b
\q1 
\v 30 Akoakoa iho la ka poe lunaolelo io Iesu la, hai aku la ia ia i na mea a pau, o na mea hoi a lakou i hana'i, a me na mea a lakou i ao aku ai.
\q1 
\v 31 I mai la oia ia lakou, E hele kaawale mai oukou, a i kahi mehameha, o oukou wale no, a e koomaha iki: no ka mea, na nui loa ka poe i hele mai, a i holo aku, no ia mea, aole o lakou wa kaawale, e ai ai i ka ai.
\q1 
\v 32 Holo kaawale aku la lakou ma ka moku, a i kahi mehameha.
\q1 
\v 33 Ike ae la na kanaka i ko lakou holo ana, a he nui no hoi na mea i hoomaopopo ia ia, holo wawae aku la lakou mai na kulanakauhale aku, a hiki mua aku la lakou a akoakoa iho la io na la.
\q1 
\v 34 A hele ae la Iesu iwaho, ike mai la ia i ka ahakanaka he nui loa, haehae iho la kona aloha ia lakou; no ka mea, ua like lakou me na hipa kahu ole, a hoomaka ia e ao mai ia lakou i na mea he nui.
\q1 
\v 35 I ke kokoke ana e po ka la, hele aku la kana poe haumana io na la, i aku la, He wahi waouahele keia, a kokoke e po ka la;
\q1 
\v 36 E hookuu aku oe ia lakou, e hele lakou ma kuhi mahinaai, a ma na kulanakauhale, e kuai i berena na lakou; no ka mea, aole a lakou mea e paina ai.
\q1 
\v 37 Olelo mai la oia ia lakou, E haawi aku oukou i ai ua lakou. I aku la lakou ia ia, E hele anei makou e kuai lilo aku i elua haneri denari, i mea e loaa mai ai ka berena e haawi aku ia lakou e ai?
\q1 
\v 38 Ninau mai la oia ia lakou, Ehia na popo berena a oukou? E hele e nana. A ike lakou, hai aku la, Elima a me na ia elua.
\q1 
\v 39 Kena mai la oia ia lakou, E hoonoho papa i kanaka a pau ilalo ma ka weuweu.
\q1 
\v 40 Noho papa iho la lakou, ma na pahaneri, a ma na pakanalima.
\q1 
\v 41 Lalau ae la ia i na popo berena elima, a me na ia elua, alaila nana aku la ia iluna i ka lani, hoomaikai aku la, wawahi iho la i na popo berena, haawi mai la i kana mau haumana, e kau ae imua o na kanaka; a puunaue ae la ia i na ia elua na lakou a pau.
\q1 
\v 42 Ai iho la lakou a pau, a maona.
\q1 
\v 43 Hoiliili iho la lakou i ke koena ai, a me ko ka ia, a piha ae la na hinai he umikumamalua.
\q1 
\v 44 O ka poe i ai i na popo berena, elima tausani kanaka lakou.
\b
\q1 
\v 45 A hoolale mai Iesu i kana mau haumana, e ee lakou iluna o ka moku, e holo mua i kela kapa, i Betesaida, a hookuu aku ia i ka ahakanaka.
\q1 
\v 46 A pau kana hoihoi ana aku ia lakou, hele aku la ia i ka mauna e pule.
\q1 
\v 47 A po ae la, iwaena o ka moanawai ua moku la, a mauka no kela, oia hookahi no.
\q1 
\v 48 Ike ae oia ia lakou e hooikaika ana ma ka hoe, no ka mea, ua pakui mai ka makani mamua o lakou; a hiki ae la i ka ha o ka wati o ka po, hele mai la ia io lakou la, e hele ana maluna o ka moanawai, a manao iho la ia e maalo ae, ma o ae o lakou.
\q1 
\v 49 Ike ae la lakou ia ia i ka hele ana maluna iho o ka moanawai, manao iho la lakou he uhane, a hooho nui aku la;
\q1 
\v 50 No ka mea, ike ae la lakou a pau ia ia, weliweli iho la: olelo koke ae la oia ia lakou, i ae la, E hoolana oukou; owau no keia, mai makau.
\q1 
\v 51 Pii aku la ia iluna o ka moku io lakou la, malie iho ka makani; kahaha nui loa iho la ko lakou naau, mahalo ae la.
\q1 
\v 52 Aole lakou i hoomanao i na popo berena, no ka mea, ua paakiki ko lakou naau.
\b
\q1 
\v 53 Holo pu aku la lakou a hiki aku i ka aina i Genesareta, a pae ae la.
\q1 
\v 54 A i ko lakou haalele ana i ka moku, hoomaopopo koke iho la na kanaka ia ia.
\q1 
\v 55 Holo lakou ma ia aina a puni, a hoomaka e halihali ma na wahi moe i ka poe mai i na wahi a lakou i lohe ai, e noho ana o Iesu.
\q1 
\v 56 Ma na wahi a pau loa i komo aku ai ia i na kauhale, a i na kulanakauhale, a i kuaaina, malaila lakou i waiho ai i ka poe mai, ma na alanui, a nonoi aku la ia ia, i hoopa aku ai lakou i ke kihi wale no o kona aahu; a o ka poe i hoopa aku ia ia, ola ae la lakou.
\c 7
\b
\q1 
\v 1 A LAILA, akoakoa mai la ka poe Parisaio io na la, a me kekahi poe kakauolelo, e hele ana, mai Ierusalema mai.
\q1 
\v 2 A ike mai la lakou i kekahi poe haumana a Iesu e ai ana i ka berena me na lima haumia, oia hoi na lima i holoi ole ia, hoohewa mai la lakou.
\q1 
\v 3 No ka mea, o ka poe Parisaio a me na Iudaio a pau, ina aole lakou e holoi pinepine i ka lima, ina aole lakou e ai, no ko lakou malama ana i na kauoha a na lunakahiko.
\q1 
\v 4 A mai kahi kuai mai, ina aole e holoi, ina aole lakou e ai: a he nui no hoi na oihana i loaa mai i malamaia e lakou, o ka holoi ana i na kiaha a me na ipu, a me na ipu keleawe, a me na punee.
\q1 
\v 5 Alaila, ninau ae la ka poe Parisaio, a me ka poe kakauolelo ia ia, No ke aha la e hele ole ai kau poe haumana ma na kauoha a na lunakahiko, aka, ke ai nei lakou i ka berena me na lima haumia?
\q1 
\v 6 Olelo mai la ia, i mai la ia lakou, Ua pono io ka Isaia wanana ana no oukou, e ka poe hookamani, e like me ka mea i palapalaia, Ke hoomaikai nei keia poe kanaka ia'u ma na lehelehe, aka, o ko lakou naau, ua mamao loa aku ia, mai o'u aku nei.
\q1 
\v 7 Makehewa ka lakou hoomana ana mai ia'u, i ka lakou ao ana ae i na kauoha a kanaka i kumu e malamaia'i.
\q1 
\v 8 No ka mea, ke waiho wale nei no oukou i ke kanawai o ke Akua, a hoopaa hoi i na kauoha a kanaka, i ka holoi ana i na ipu, a me na kiaha, a he nui loa no hoi na mea e like me ia, a oukou e hana nei.
\q1 
\v 9 I mai la hoi ia, He oiaio no i ka oukou pale ana i ke kanawai o ke Akua, i malama'i oukou i ka oukou mau kauoha.
\q1 
\v 10 No ka mea, olelo mai la o Mose, E malama oe i kou makuakane, a me kou makuwahine; a, O ka mea i hailiili i ka makuakane a me makuwahine, e pepehiia oia.
\q1 
\v 11 Aka, ke olelo nei oukou, Ina e olelo aku kekahi kanaka i kona makuakane, a i kona makuwahine paha, Korebana, he mea laa hoi ia, o ka'u mea e waiwai ai oe.
\q1 
\v 12 Alaila, aole oukou i ae aku ia ia e hana hou i kekahi mea no kona makuakane, a no kona makuwahine;
\q1 
\v 13 E hoolilo ana i ka olelo a ke Akua i mea ole, ma ka oukou kauoha, ka mea a oukou e haawi aku ai; a ke hana nei oukou i na mea ke nui loa e like me ia.
\b
\q1 
\v 14 A kahea mai la ia i ka ahakanaka, olelo mai la oia ia lakou, E hoolohe mai oukou a pau e hoomaopopo hoi.
\q1 
\v 15 Aole mea mawaho o ke kanaka e haumia'i ia ke komo iloko ona; aka, o ka mea i puai mai, mailoko mai ona, oia na mea e haumia'i ke kanaka.
\q1 
\v 16 Ina he pepeiao ko ke kanaka e lohe, e hoolohe mai ia.
\q1 
\v 17 I kona komo ana'e iloko o ka hale, mai ka ahakanaka ae, ninau aku la kana mau haumana ia ia no ua olelonaue la.
\q1 
\v 18 I mai la oia ia lakou, He naaupo anei oukou pu kekahi? Aole anei oukou i ike, o ka mea mawaho i komo iloko o ke kanaka, aole ia e hiki ke hoohaumia ia ia?
\q1 
\v 19 No ka mea, aole ia i komo iloko o kahi manao, iloko wale no ia o ka opu, a hemo aku ma kiona, kahi e pau ai ka ino o ka ai.
\q1 
\v 20 I hou mai la ia, O ka mea e puai, mailoko mai o ke kanaka, oia no ka mea e haumia'i ke kanaka.
\q1 
\v 21 No ka mea, noloko mai o ka naau o kanaka i puka mai ai ka manao ino, ka moe i ka hai, ka moe ipoipo, ka pepehi kanaka,
\q1 
\v 22 Ka aihue, ka makee waiwai, ka opu inoino, ka wahahee, ka makaleho, ka huahua, ka niania, ka hookano, ka lalau wale;
\q1 
\v 23 Noloko mai keia mau mea ino a pau i puka mai ai, oia no na mea e haumia'i ke kanaka.
\b
\q1 
\v 24 Eu ae la ia iluna, a hele aku la i na mokuna o Turo, a me Sidona, komo aku la iloko o kekahi hale, aole ia i makemake e ike mai kekahi kanaka ia ia, aole nae ia i hiki ke nalo.
\q1 
\v 25 No ka mea, ua lohe e nona kekahi wahine nana ke kaikamahine i uluhia e ka uhane ino, hele mai la ia, a moe iho la ma kona mau wawae.
\q1 
\v 26 He wahine Helene ia, no ka aina o Poinikia ma Suria mai; a nonoi ae la oia ia ia, e mahiki aku i ka daimonio, mailoko aku o kana kaikamahine.
\q1 
\v 27 I mai la Iesu ia ia, Alia, e hoomaona e ia na keiki mamua, no ka mea, aole e pono ke lawe i ka berena a na keiki a hoolei aku na na ilio.
\q1 
\v 28 Olelo aku la kela, i aku la ia ia, He oiaio no, e ka Haku; aka hoi, o na ilio malalo o ka papa aina, ai no lakou i na hunahuna ai a na keiki.
\q1 
\v 29 I mai la oia ia ia, No keia olelo, e hoi oe, ua hele ka daimonio, mailoko aku o kau kaikamahine.
\q1 
\v 30 Hiki aku la ia i kona hale, ike aku la ia, ua hele aku no ka daimonio, mailoko aku, a ua hoomoeia no ke kaikamahine iluna o kahi moe.
\b
\q1 
\v 31 Haalele aku la ia i na mokuna o Turo, a me Sidona, a hele mai la ia mawaena o na aina o Dekapoli, a i ka moanawai o Galilaia.
\q1 
\v 32 Lawe aku la lakou io na la, i kekahi mea kuli, ua uuu no hoi kona leo; nonoi aku la lakou ia ia, e kau i kona lima iluna iho ona.
\q1 
\v 33 Kai ae la oia ia ia mawaho o ka ahakanaka, a kaawale, hookomo iho la i kona mau lima iloko o kona mau pepeiao, kuha ae la, a hoopa mai la i kona alelo.
\q1 
\v 34 Nana ae la iluna i ka lani, uwe aku la, a i mai la ia ia, Epata, oia hoi keia, e weheia.
\q1 
\v 35 Poha koke ae la kona mau pepeiao, a hoaluia ke kaula o kona elelo, a olelo maopopo mai la ia.
\q1 
\v 36 Papa mai la Iesu ia lakou, mai hai aku i kekahi; aka, me ka nui o kana papa ana, pela no ka nui o ko lakou hookaulana ana aku.
\q1 
\v 37 A mahalo loa iho la lakou, i ae la, Ua hana pono loa oia i na mea a pau loa. Hana aku no ia i ke kuli, a lohe ia, a me ka aa hoi, a olelo no ia.
\c 8
\b
\q1 
\v 1 I A mau la no, he ahakanaka nui loa, aole nae a lakou mea e paina'i, kahea mai la Iesu i kana mau haumana, i mai la ia lakou,
\q1 
\v 2 Ke aloha aku nei au i ka ahakanaka, no ka mea, ua noho pu iho nei lakou me au, i na la ekolu, aole hoi a lakou mea e paina'i.
\q1 
\v 3 Ina e hookuu aku au ia lakou i ko lakou hale me ka pololi, e mauleule no lakou ma ke alanui; no ka mea, mai kahi loihi ka hele ana mai o kekahi poe o lakou.
\q1 
\v 4 I aku la kana poe haumana ia ia, Nohea la e hiki ai i kekahi ke hoomaona'i ia lakou nei iloko o ka waonahele?
\q1 
\v 5 Ninau mai la oia ia lakou, Ehia na popo berena a oukou? I mai la lakou, Ehiku.
\q1 
\v 6 Kanoha mai la ia i kanaka e noho ilalo ma ka lepo. Lawe ae la ia i na popo berena ehiku, hoomaikai aku la, wawahi iho la, haawi mai ia i kana poe haumana, e kau aku imua o ka ahakanaka; a kau aku la lakou.
\q1 
\v 7 He mau wahi ia liilii no hoi kekahi a lakou; hoomaikai aku la ia, a kauoha mai la, e kau aku no hoi ia mau mea.
\q1 
\v 8 Ai iho la lakou a maona, a hoiliili iho la lakou i ke koena ai, ehiku hinai i piha.
\q1 
\v 9 A o ka poe i ai, eha tausani lakou; a hookuu aku la oia ia lakou.
\b
\q1 
\v 10 Alaila, ee pu aku la ia me kana poe haumana iluna o ka moku, a holo ae la i na mokuna o Dalamanuta.
\b
\q1 
\v 11 Hele mai la ka poe Parisaio, a hoomaka e ninaninau mai ia ia, me ka imi i hoailona ana, mai ka lani mai, i hoao ai lakou ia ia.
\q1 
\v 12 Uwe nui iho la ia iloko o kona naau, i ae la, No ke aha la keia hanauna e imi mai nei i hoailona? Oiaio ke hai aku nei au ia oukou, Aole e haawiia'ku ka hoailona no keia hanauna.
\q1 
\v 13 Haalele iho la oia ia lakou, ee hou aku la maluna o ka moku, a holo aku la i kela kapa.
\b
\q1 
\v 14 Ua poina ia lakou ke lawe pu i ka berena, hookahi wale no popo berena a lakou iloko o ka moku.
\q1 
\v 15 Kauoha mai la oia ia lakou, i mai la, E ao oukou e makaala, no ka mea hu a ka poe Parisaio, a me ka mea hu o Herode.
\q1 
\v 16 Ohumu malu iho la lakou ia lakou iho no, i ae la, No ko kakou berena ole paha.
\q1 
\v 17 Ua ike no o Iesu, a i mai la oia ia lakou, No ke aba la oukou i ohumu ai i ko oukou berena ole? Aole anei oukou i noonoo? Aole anei iike? Ua paakiki anei ko oukou naau?
\q1 
\v 18 He mau maka no ko oukou, aole anei oukou i ike? He mau pepeiao no ko oukou, aole anei oukou i lohe? Aole anei oukou i hoomanao?
\q1 
\v 19 I kuu wawahi ana i na popo berena elima, na na tausani elima, ehia la na hinai i piha i ke koena ai a oukou i hoiliili ai? Hai aku la lakou ia ia, He umikumamalua.
\q1 
\v 20 A i na hiku na na tausani eha, ehia la na hinai i piha i ke koena ai a oukou i hoiliili ai? Hai aku la lakou ia ia, Ehiku.
\q1 
\v 21 A olelo mai la ia ia lakou, Pehea la hoi i hoomaopopo ole mai ai oukou?
\b
\q1 
\v 22 Hele mai la ia i Betesaida, alaila, nalihali ae la lakou i kekahi kanaka makapo io na la, nonoi aku la ia ia, e hoopa mai ia ia.
\q1 
\v 23 Lalau iho la ia i ka lima o ke kanaka makapo, alakai aku la ia ia, mai ke kauhale aku; kuha mai la ia i kona mau maka, hoopa mai la kona lima ia ia, ninau mai la i kona ike ana i kekahi mea.
\q1 
\v 24 Nana ae la ia iluna, i aku la, Ke ike nei au i kanaka, me he mau laau la e hele ana.
\q1 
\v 25 Mahope iho, kau hou mai la ia i kona lima ma na maka ona, a hoonana hou aku la ia ia iluna; a ola ae la ia, a ike maopopo iho la i kela kanaka i keia kanaka.
\q1 
\v 26 Hoihoi ae la o Iesu ia ia i kona hale, i ae la, Mai hele aku i ke kauhale, mai hai aku i ko ke kauhale.
\b
\q1 
\v 27 Hele aku la Iesu, a me kana poe haumana i na kauhale o Kaisareia Pilipi; ninau ae la ia i kana poe haumana ma ke alaloa, i ka i ana, Owai la wau i ka kanaka olelo?
\q1 
\v 28 I aku la lakou, O Ioane Bapetite; a o Elia i ka kekahi; a o kekahi o na kaula i ka kekahi.
\q1 
\v 29 Ninau mai la oia ia lakou, Owai la hoi au i ka oukou olelo? Hai aku la o Petero, i aku la ia ia, O ka Mesia no oe.
\q1 
\v 30 Papa mai la oia ia lakou, mai hai aku ia ia i kekahi kanaka.
\b
\q1 
\v 31 Ilaila kana hoomaka ana e hoike mai ia lakou e hoomainoino nui ia ke Keiki a ke kanaka, a e hooleia e ka poe kahiko, a me ka poe kahuna nui, a me ka poe kakauolelo, a e pepehiia oia, a po akolu ae e ala hou mai.
\q1 
\v 32 Hai maopopo mai la oia ia olelo; alaila. lalau ae la o Petero ia ia, a hoomaka e papa aku la ia ia.
\q1 
\v 33 Haliu ae la Iesu, nana ae la i kana mau haumana, papa ae la ia Petero, i ae la, E hele oe pela mahope o'u, e Satana, no ka mea, aole i like kou manao me ko ke Akua, aka, me ko na kanaka.
\b
\q1 
\v 34 A kahea mai la ia i kanaka, a i kana poe haumana no hoi, i mai la ia lakou, O ka mea makemake e hahai mai mahope o'u, e hoole oia ia ia iho, a e kaikai i kona kea, a e hahai mai ia'u.
\q1 
\v 35 O ka mea manao e malama i kona ola nei, e lilo auanei kona ola, a o ka mea haalele i kona ola no'u nei, a no ka enanelio, e loaa ia ia ke ola.
\q1 
\v 36 Heaha la uanei ko ke kanaka pomaikai ke loaa ia ia ke ao nei a pau, a lilo aku kona uhane?
\q1 
\v 37 Heaha la hoi ko ke kanaka kumu e haawi aku ai, e loaa hou mai ai kona uhane?
\q1 
\v 38 O ka mea e hilahila mai ia'u a me ka'u olelo, i keia hanauna kolohe a hana hewa, e hilahila no hoi ke Keiki a ke kanaka ia ia i kona wa e hele mai ai me ka nani o kona Makua, me na anela hemolele.
\c 9
\b
\q1 
\v 1 I MAI la oia ia lakou, Oiaio ka'u e olelo aku nei ia oukou; ke ku mai nei kekahi mau mea, aole lakou e make e, a ike no lakou i ka hele ana mai o ke aupuni o ke Akua me ka mana.
\b
\q1 
\v 2 A hala ae la na la eono, kono ae la o Iesu ia Petero, a me lakobo, a me Ioane, alakai aku la ia lakou i kahi mehameha, me kekahi mauna kiekie, hoopahaohao iho la ia imua o lakou.
\q1 
\v 3 Alohi ae la kona kapa, a keokeo loa e like me ka hau; aole e hiki i kanaka hooomaemae lole maluna o ka honua ke hookeokeo pela.
\q1 
\v 4 Ikea mai la e lakou o Elia, laua o Mose e kamailio ana me Iesu.
\q1 
\v 5 Olelo aku la o Petero, i aku la ia Iesu, E ka Haku e, nani wale kakou e noho ai ia nei; e hana paha makou i ekolu halelewa; nou kekahi, no Mose kekahi, a no Elia kekahi.
\q1 
\v 6 Aole ia i ike i kana mea i olelo aku ai, no ka mea, ua makau lakou.
\q1 
\v 7 A he ao hoi ka i uhi mai ia lakou; a pae mai la ka leo mai loko mai o ke ao, i mai la, Eia kuu keiki punahele, e hooloho oukou ia ia.
\q1 
\v 8 Nana koke ae la lakou, aole he kanaka a lakou i ike ai, o Iesu wale no me lakou.
\b
\q1 
\v 9 A i ko lakou iho ana, mai ka mauna mai, papa mai la kela ia lakou, mai hai aku i na mea a lakou i ike ai, a ala hou mai ke Keiki a ke kanaka mai waena mai o ka poe make.
\q1 
\v 10 Umi malu iho la lakou ia olelo me ka nalu nui ia lakou iho no i ke ano o ke ala ana maiwaena mai o ka poe make.
\b
\q1 
\v 11 Ninau aku la lakou ia ia, i aku la, No ke aha la i olelo mai ai ka poe kakauolelo, O Elia ke hele e mai mamua e pono ai?
\q1 
\v 12 Olelo mai la oia ia lakou, i mai la, Oiaio no o Elia ke hele e mai ana, e hooponopono i na mea a pau loa. Ua palapalaia no hoi ka hoomainoinoia o ke Keiki a ke kanaka, a me kona hoowahawahaia.
\q1 
\v 13 Aka, ke hai aku nei au ia oukou, Ua hiki io mai nei no Elia, a ua hana aku lakou ia ia i na mea a pau a lakou i makemake ai, e like me ka mea i palapalaia nona.
\b
\q1 
\v 14 A hele mai la ia i kana poe haumana, ike ae la ia i na kanaka he nui loa, a me ka poe kakauelelo, e ninaninau ana ia lakou.
\q1 
\v 15 A ike aku la na kanaka a pau loa ia ia, pihoihoi iho lakou, holo kiki aku la, a aloha aku la ia ia.
\q1 
\v 16 Ninau aku la oia ia lakou, Heaha ka oukou mea o ninaninau nei me lakou?
\q1 
\v 17 Olelo ae la kekahi o ua aha kanaka la, i aku la, E ka Haku e, ua lawe mai nei au i kuu keikikane ia oe, ua uluhia ia e ka uhane aa.
\q1 
\v 18 A ma na wahi a pau loa i kaina aku ai oia e ia, hookaawili iho la oia ia ia, a kahe mai ka hua, nau iho la na kui, a hokii no hoi; a i aku la au i na haumana au, na lakou ia e mahiki aku; aole i hiki ia lakou.
\q1 
\v 19 Olelo mai la oia ia lakou, i mai la, Auwe ka hanauna hoomaloka; pehea la ka loihi o ko'u noho pu ana me oukou? Pehea ka loihi o ko'u hoomanawanui ana aku ia oukou? E lawe mai ia ia io'u nei.
\q1 
\v 20 Lawe mai la lakou ia ia io na la, ike mai la oia ia ia, alaila, hookaawili hou ae la ka uhane ia ia; haule iho la ia ilalo i ka honua, kaa iho la me ka hua nui.
\q1 
\v 21 Ninau ae la ia i kona makuakane, Pehea la ka loihi o ke kau ana o keia maluna ona? I mai la kela, Mai ka wa kamalii mai no.
\q1 
\v 22 Ua hoolei pinepine ia oia e ia, iloko o ke ahi, a iloko o ka wai, i make ia; aka hoi, ina e hiki ia oe, e aloha mai oe ia maua, a e kokua mai hoi.
\q1 
\v 23 I mai la Iesu ia ia, A i hiki ia oe ke manaoio, e hiki no na mea a pau loa i ka mea mauaoio.
\q1 
\v 24 Kahea koke aku la ka makuakane o ua keiki la, i aku la me na waimaka, E ka Haku, ke manaoio nei au; e kokua mai oe ia'u i kuu manaoio ole.
\q1 
\v 25 Ike mai la Iesu i ka lulumi ana mai o kanaka, alaila, papa aku la ia i ka uhane ino, i aku ia ia ia, Ke olelo aku nei au ia oe, e ka uhane aa, a kuli, e hele aku oe pela, mailoko aku ona, mai komo hou iloko ona.
\q1 
\v 26 Kahea ae la ia, a hookaawili hou iho la ia ia, a puka aku la, mai loko aku ona; a like iho la ia me ka mea i make, no ia mea, ua nui ka poe i olelo ae, Ua make io no.
\q1 
\v 27 Lalau iho la Iesu i kona lima, hoala mai la ia ia iluna, a ku ae la ia.
\q1 
\v 28 A i kona hiki ana aku iloko o ka hale, alaila ninau malu aku la kana poe haumana ia ia, No ke aha la i hiki ole ai ia makou ke mahiki aku ia ia?
\q1 
\v 29 I mai la oia ia lakou, Aole hiki keia mau mea ke mahiki wale ia'ku, aka, i ka pule, a me ka hookeai.
\b
\q1 
\v 30 Hele aku la lakou, mai ia wahi aku, maloko o Galilaia; aole nae ia i makemake e ike mai kekahi.
\q1 
\v 31 No ka mea, ao mai la ia i kana poe haumana, i mai la ia lakou, E kuroakaiaia'ku ana ke Keiki a ke kanaka i na lima o kanaka, a e pepehi mai lakou ia ia; a make loa ia, a po akolu ae, o ala hou mai no ia.
\q1 
\v 32 Aka, aole lakou i ike i ke ano o ia olelo, a na makau no hoi lakou ke ninau ia ia.
\b
\q1 
\v 33 A hele aku la lakou i Kaperenauma; a i kona noho ana iloko o ka hale, alaila, ninau mai la oia ia lakou, Heaha ka oukou i kamailio ai ma ke alaloa?
\q1 
\v 34 Aole lakou i ekemu iki aku, no ka mea, ua kamailio lakou ia lakou iho ma ke alaloa, i ka mea o lakou i oi mamua.
\q1 
\v 35 Noho iho la ia, a kahea mai la i ka poe umikumamalua, i mai la kela ia lakou, Ina e manao kekahi kanaka, e oi ia mamua, e emi auanei ia mahope o na mea a pau, a e lilo no hoi i kauwa na na mea a pau.
\q1 
\v 36 Lawe ae la ia i kekahi keiki, hooku iho la ia ia mawaenakonu o lakou; a i kona hiipoi ana ia ia, i mai la ia ia lakou,
\q1 
\v 37 O ka mea e launa mai i kekahi keiki liilii, e like me ia nei, no ko'u inoa, oia ka mea launa mai ia'u; a o ka mea launa mai ia'u, aole ia i launa mai ia'u wale no, aka, i ka mea nana wau i hoouna mai nei.
\b
\q1 
\v 38 Alaila olelo aku la o Ioane ia ia, i aku la, E ke Kumu, ua ike aku makou i kekahi mea e mahiki aku ana i na daimonio ma kou inoa, aole nae ia i hahai ia makou; a papa aku la makou ia ia, no ka mea, aole ia i hahai ia makou.
\q1 
\v 39 I mai la Iesu, Mai papa aku ia ia; no ka mea, o ke kanaka nana i hana ka hana mana, ma ko'u inoa, aole ia e hiki ke olelo ino no'u.
\q1 
\v 40 O ka mea ku e ole aku ia kakou, no kakou hoi ia.
\q1 
\v 41 O ka mea haawi ia oukou i kekahi kiaha wai e inu ma ko'u inoa, no ka mea, no Kristo oukou; he oiaio ka'u e hai aku nei ia oukou, aole loa ia e nele i ka ukuia.
\q1 
\v 42 A o ka mea hoohihia mai i kekahi o ka poe liilii nana wau e manaoio mai nei, e aho nona, ke nakinakiia ka pohaku wili palaoa ma kona a-i, a e hooleiia'ku ia iloko o ke kai.
\q1 
\v 43 A ina e hoohihia mai kou lima akau ia oe, e oki ae; e aho nou ke komo mumuku aku iloko o ke ola, i ke kiolaia'ku i gehena me na lima elua, i ke ahi pio ole:
\q1 
\v 44 Kahi aole loa e make ko lakou ilo, aole loa hoi e pio ke ahi.
\q1 
\v 45 A ina e hoohihia mai kou wawae ia oe, e oki ae; e aho nou ke komo oopa aku iloko o ke ola, i ke kiolaia'ku i gehena, me na wawae elua, i ke ahi pio ole:
\q1 
\v 46 Kahi aole loa e make ko lakou ilo, aole loa hoi e pio ke ahi.
\q1 
\v 47 A ina hoohihia mai kou maka ia oe, e poalo ae; no ka mea, e aho nou ke komo maka'hi iloko o ke ola, i ke kiolaia'ku i ke ahi o gehena me na maka elua:
\q1 
\v 48 Kahi aole loa e make ko lakou ilo, aole loa hoi e pio ke ahi.
\q1 
\v 49 No ka mea, e kapiia lakou a pau i ke ahi, e like me ka mohai i kapiia i ka paakai.
\q1 
\v 50 He maikai ka paakai, aka, ina i pau ka liu o ka paakai, pehea la ia e liu hou ai? E ao oukou, i loaa ka paakai iloko o oukou, a e kuikahi like oukou.
\c 10
\b
\q1 
\v 1 A LAILA ku ae la ia iluna, a hele aku la ia ma kela kapa o Ioredane, a i na makuna o Iudea; a akoakoa hou mai la na kanaka io na la, ao hou mai la oia ia lakou, e like me kana oihana mamua.
\b
\q1 
\v 2 Hele mai la ka poe Parisaio io na la, me ka hoao mai ia ia, i mai la, He mea pono anei i ke kane ke hooki i kana wahine?
\q1 
\v 3 Olelo aku la ia, i aku la ia lakou, Heaha la ka mea a Mose i kauoha mai ai ia oukou?
\q1 
\v 4 I mai la lakou, I ae mai no o Mose e kakau i ka palapala hoohemo, alaila e hooki aku.
\q1 
\v 5 Olelo aku la Iesu, i aku la ia lakou, No ka paakiki ana o ko oukou naau, i palapala mai ai oia ia olelo na oukou.
\q1 
\v 6 Aka, i kinohi o ka honua nei, hana ke Akua ia laua, he kane, he wahine.
\q1 
\v 7 Nolaila hoi e haalele ai ke kanaka i kona makuakane, a me kona makuwahine, a e hoopili ia i kana wahine:
\q1 
\v 8 A e lilo no laua elua, i hookahi; no ia mea, aole elua hou aku laua, aka, hookahi wale no io.
\q1 
\v 9 O ka mea a ke Akua i hoopili mai ai, mai hoohemo ae ke kanaka.
\q1 
\v 10 A iloko o ka hale, ninau aku la kana poe haumana i kela mea.
\q1 
\v 11 I mai la oia ia lakou, O ka mea hooki i kana wahine, a mare hou i kekahi, he moe kolohe no kana ia ia.
\q1 
\v 12 A i hooki ka wahine i kana kane a mare hou i kekahi, ua moe kolohe no hoi ia.
\b
\q1 
\v 13 Halihali aku la lakou i kahi mau keiki liilii ia ia, i hoopa mai oia ia lakou: papa ae la kana poe haumana i ka poe nana i lawe aku.
\q1 
\v 14 Ike mai la Iesu, alaila, huhu iho la ia, i mai la ia lakou, E ae aku oukou i kamalii ke hele mai io'u nei, mai papa aku hoi ia lakou; no ka mea, e like me lakou nei ke aupuni o ke Akua.
\q1 
\v 15 He oiaio ka'u e olelo aku nei ia oukou, O ka mea aole e launa i ke aupuni o ke Akua, me he keiki uuku la, aole loa ia e komo mai ilaila.
\q1 
\v 16 Hiipoi iho la oia ia lakou, kau ae la i kona lima iluna o lakou. a hoomaikai mai la ia lakou.
\b
\q1 
\v 17 I kona hele ana aku ma ke alaloa, holo kiki ae la kekahi io na la, kukuli iho la imua ona, i ae la, E ke Kumu maikai e, heaha la ka'u mea e hana'i, i loaa ia'u ke ola loa?
\q1 
\v 18 I mai la Iesu ia ia, No ke aha la oe e kapa mai ai ia'u he maikai? Hookahi wale no mea maikai, o ke Akua.
\q1 
\v 19 Ua ike no hoi oe i na kanawai; Mai moe kolohe oe; Mai pepehi kanaka; Mai aihue; Mai hoike wahahee; Mai alunu; E malama oe i kou makuakane, a me kou makuwahine.
\q1 
\v 20 Olelo ae la ia, i ae la ia ia, E ke Kumu, ua pau ia mau mea ia'u i ka malamaia mai ko'u wa uuku mai.
\q1 
\v 21 Nana mai la Iesu ia ia, aloha iho la, a olelo mai la ia ia, Hookahi ou mea hemahema; e hoi aku oe, e kuai lilo aku i kou waiwai a pau, a e haawi aku i ka poe ilihune, alaila e loaa ia oe ka waiwai ma ka lani; a e hele mai oe e hapai i ke kea, a e hahai mai ia'u.
\q1 
\v 22 Alaila kaumaha loa iho la kela ia olelo, a hele aku la me ka minamina, no ka mea, ua nui loa kona waiwai.
\b
\q1 
\v 23 Alawa ae la o Iesu ma o a o, i mai la i kana poe haumana, Manomano ke komo pilikia ana o ke kanaka waiwai iloko o ke aupuni o ke Akua!
\q1 
\v 24 Kahaha iho la ka naau o ka poe haumana i kana olelo. I hou mai la Iesu ia lakou, E na pokii, he mea pilikia loa ke komo ana o ka poe paulele i ka waiwai, iloko o ke aupuni o ke Akua!
\q1 
\v 25 E hiki e ke kamelo ke komo aku iloko o ka puka kuikele, mamua o ke komo ana o ke kanaka waiwai iloko o ke aupuni o ke Akua.
\q1 
\v 26 Kahaha loa ko loko o lakou, i iho la ia lakou iho, Owai la uanei e hiki i ke ola?
\q1 
\v 27 Nana mai la Iesu ia lakou, i mai la, He mea hiki ole keia i kanaka, aka, aole i ke Akua; no ka mea, e hiki no na mea a pau loa i ke Akua.
\b
\q1 
\v 28 Alaila, hoomaka aku la o Petero e olelo ia ia, Aia hoi, ua haalele makou i na mea a pau, a ua hahai aku ia oe.
\q1 
\v 29 Olelo mai la Iesu, i mai la, He oiaio ka'u e olelo aku nei ia oukou, aole ka mea i haalele i ka hale, i na kaikuaana, i na kaikuwahine, i ka wahine, i na keiki, i na aina, no'u nei a no ka euanelio,
\q1 
\v 30 E loaa ole mai ia ia ka pahaneri i keia ao, a me na hale, a me na kaikuaana, a me na kaikuwahine, a me na makuwahine, a me na keiki, a me na aina, me ka hoomainoino nae; a i kela ao mahope, o ke ola mau loa.
\q1 
\v 31 A he nui loa na mea mua e lilo ana i hope, a me na mea hope i mua.
\b
\q1 
\v 32 Ia lakou ma ke alanui e pii ana i Ierusalema, hele aku la Iesu mamua o lakou; a kahaha iho la ko lakou naau; a i ko lakou hahai ana aku, makau iho la lakou. Lawe hou mai la ia i ka poe umikumamalua, a hoomaka e hai mai la ia lakou i kona mea e hanaia mai ai;
\q1 
\v 33 Eia hoi, ke pii aku nei kakou i Ierusalema, a e haawiia'ku auanei ke Keiki a ke kanaka, i ka poe kahuna nui, a me ka poe kakauolelo; a e hoohewa mai lakou ia ia e make, a e haawi no hoi lakou ia ia i ko ka aina e;
\q1 
\v 34 A e hoomaewaewa mai lakou ia ia, a e hahau mai ia ia, a e kuhakuha mai lakou ia ia, a e pepehi mai ia ia, a po akolu ae, e ala hou mai ia.
\b
\q1 
\v 35 Punee aku la io na la o Iakobo, a me Ioane, na keiki a Zebedaio, i aku la, E ke Kumu e, ke ake nei maua, e hana mai oe na maua i ka maua mea e noi aku ai.
\q1 
\v 36 Ninau mai la Iesu ia laua, Heaha ko olua makemake, e hana aku ai au na olua?
\q1 
\v 37 I aku la laua ia ia, E haawi mai oe ia maua, e noho kekahi o maua ma kou lima akau, a o kekahi ma kou lima hema, maloko o kou nani.
\q1 
\v 38 I mai la Iesu ia laua, Aole olua i ike i ka olua mea i noi mai ai. E hiki anei ia olua ke inu i ko ke kiaha a'u e inu ai? a e bapetizoia i ka bapetizo ana a'u e bapetizoia mai ai?
\q1 
\v 39 I aku la laua ia ia, E hiki no ia maua. I mai la Iesu ia laua, E inu io no olua i ko ke kiaha a'u e inu ai, a e bapetizoia no hoi olua i ka bapetizo ana a'u e bapetizoia mai ai:
\q1 
\v 40 Aka, o ka noho ma ko'u lima akau, a me ko'u lima hema, aole o ka'u ia e haawi aku ai; aka, no ka poe ia i hoomakaukauia'i ia mea.
\q1 
\v 41 A lohe ae la ka umi, hoomaka iho la lakou e ukiuki ia Iakobo, a me Ioane.
\q1 
\v 42 Kahea mai la Iesu ia lakou, i mai la, Ua ike no oukou, o ka poe i hoaliiia maluna o ko na aina e, ua hookiekie maluna o lakou; a o na kanaka nui hoi, ua hoolanilani maluna o lakou.
\q1 
\v 43 Aka, mai mea pela iwaena o oukou; a o ka mea makemake e lilo i pookela iwaena o oukou, e lilo ia i kauwa na oukou.
\q1 
\v 44 A o ka mea e makemake i alii ia maluna o oukou, e lilo ia i kauwa na na mea a pau.
\q1 
\v 45 No ka mea, o ke Keiki a ke kanaka, aole ia i hele mai no ka hookauwaia mai, aka, no ka hookauwa aku, a e haawi i kona ola i kumu hoola no na mea he nui loa.
\b
\q1 
\v 46 A hiki mai la lakou i Ieriko; a i ko lakou hele ana, mai Ieriko aku, me kana mau haumana, a me na kanaka he nui loa, e noho ana ma kapa alanui, ka makapo, o Batimea, ke keiki a Timea, e nonoi ana.
\q1 
\v 47 A lohe ae la ia i ko Iesu hele ana ae, hoomaka ia e kahea ae, i ae la, E Iesu e, e ke Keiki a Davida, e aloha mai oe ia'u.
\q1 
\v 48 Nui loa na mea i papa aku ia ai, Hamau: aka, he nui loa aku kona kahea ana'ku, E ke Keiki a Davida, e aloha mai oe ia'u.
\q1 
\v 49 Ku malie iho la o Iesu, kauoha mai la e kaheaia'ku ia. Kahea aku la lakou i ua kanaka makapo nei, i aku la ia ia, E hoolana oe, a e ku ae iluna, ke kahea mai nei kela ia oe.
\q1 
\v 50 Haalele iho la ia i kona aahu, ku ae la iluna, a hele mai io Iesu la.
\q1 
\v 51 Olelo aku la Iesu, i aku la ia ia, Heaha kou makemake e hana aku ai au nou? I mai la ua makapo nei ia ia, E ka Haku e, i kaakaa ko'u mau maka.
\q1 
\v 52 I aku la Iesu ia ia, O hele, ua ola oe, i kou manaoio. Loaa koke ae la ia ia ka ike, a hahai aku la ia Iesu, ma ke alaloa.
\c 11
\b
\q1 
\v 1 A KOKOKE mai la lakou i Ierusalema, ua hiki i Betepage, a me Betania ma ka mauna o Oliveta, hoouna mai la ia i na haumana ana elua,
\q1 
\v 2 I mai la ia laua, E hele olua i kela kulanakauhale mamua o olua; a i ko olua komo ana iloko, e loaa koke no ia olua kekahi hoki keiki, ua nakinakiia, aole i nohoia e ke kanaka; e kala ae olua, a e alakai mai.
\q1 
\v 3 A i olelo mai kekahi ia olua, No ke aha olua e hana'i i keia mea? E olelo aku olua, No ka Haku keia e pono ai; a e hoouna koke mai kela ia ia maanei.
\q1 
\v 4 Hele aku la laua, a loaa iho la ia laua ka hoki keiki, ua nakinakiia ma ka ipuka mawaho, ma na huina alanui. Kala ae la laua ia ia.
\q1 
\v 5 Olelo mai la kekahi o lakou e ku ana malaila ia laua, No ke aha olua i kala'i i ka hoki keiki?
\q1 
\v 6 I aku la laua ia lakou, e like me ka Iesu kauoha ana mai; a kuu mai la lakou ia laua.
\q1 
\v 7 Alakai mai la laua i ua hoki keiki la io Iesu la, hohola ae la lakou i ko lakou kapa maluna ona, a noho no o Iesu iluna iho ona.
\q1 
\v 8 Nui na mea i haliilii ae i ko lakou kapa ma ke alanui; a o kekahi poe e hoi, ooki ae la lakou i na lala laau, a haliilii iho la ma ke alanui.
\q1 
\v 9 Hookani aku la ka poe i hele mamua, a me lakou e hahai ana mahope, i aku la, Hosana; nani wale ka mea i hele mai ma ka inoa o ka Haku.
\q1 
\v 10 Pomaikai ke aupuni o ko kakou kupunakane, o Davida, e hele mai ana ma ka inoa o ka Haku: Hosana iluna lilo loa.
\b
\q1 
\v 11 A komo aku la o Iesu iloko o Ierusalema, a iloko o ka luakini, a nana ao la ia i na mea a pau loa; a ahiahi ao la, hele aku la ia me kana poe haumana i Betania.
\b
\q1 
\v 12 A ia la iho, i ko lakou hoi ana ae mai Betania mai, pololi iho la ia.
\q1 
\v 13 Ike aku la ia i kekahi laau fiku, ma kahi mamao aku, he lau maluna; hele ae la ia e imi i ko luna o ka laau; a hiki ae la ia ilaila, loaa ia ia he lau wale no; no ka mea, aole ia o ka manawa fiku.
\q1 
\v 14 Olelo ae la Iesu, i ae la ia ia, Aole loa e ai kekahi kanaka i kau hua, ma neia hope aku; a lohe no kana poe haumana.
\b
\q1 
\v 15 A hiki ae la lakou i Ierusalema; alaila, komo ae la Iesu iloko o ka luakini, hookuke aku la i ka poe kuai lilo aku, a kuai lilo mai iloko o ka luakini, hookahuli ae la i na papa o ka poe kuai kala, a me na noho o ka poe kuai manu nunu.
\q1 
\v 16 Aole oia i ae mai, o laweia kekahi mea, mawaena ae o ka luakini.
\q1 
\v 17 Ao mai la ia, i mai la ia lakou, Aole anei i palapalaia mai, E kapaia ko'u hale e na aina a pau, he hale pule? Ua hoolilo ae nei oukou ia i lua no na powa.
\q1 
\v 18 A lohe ae la ka poe kakauolelo, a me ka poe kahuna nui, imi iho la lakou i mea nona e make ai ia lakou; makau no nae lakou ia ia, no ka mea, ua mnhalo loa na kanaka a pau i kana olelo.
\b
\q1 
\v 19 A ahiahi ae la, hele aku la ia iwaho o ke kulanakauhale.
\b
\q1 
\v 20 A kakahiaka ae, i ko lakou hoi ana mai, ike aku la lakou i ka laau fiku, ua pau i ka maloo, mai ke kumu ae.
\q1 
\v 21 Hoomanao iho la o Petero, i ae la ia ia, E ka Haku, e nana, aia ka laau fiku au i hoino ai, ua maloo loa.
\q1 
\v 22 Olelo mai la Iesu ia lakou, i mai la, E manaoio aku oukou i ko Akua.
\q1 
\v 23 No ka mea, he oiaio ka'u olelo aku nei ia oukou, O ka mea e olelo mai i keia mauna, E hoonee aku, a e lele i ke kai, aole hoi e kanalua kona naau, aka, ua manaoio no, e hanaia keia mau mea ana e olelo ai; e loaa io no ia ia ka mea ana e olelo ai.
\q1 
\v 24 No ia mea la, ke olelo aku nei au ia oukou, O na mea a pau a oukou e noi aku ai ma ka oukou pule ana, e manaoio oukou i ka loaa ana, alaila e loaa io aku no ia oukou ia.
\q1 
\v 25 A i ko oukou ku ana e pule, ina e hoomauhala ana oukou i kekahi, e kala aku oukou ia ia, i kala mai ai hoi ko oukou Makua iloko o ka lani i ko oukou hewa.
\q1 
\v 26 Ina, aole oukou e kala aku, aole no hoi e kala mai ko oukou Makua iloko o ka lani, i ko oukou hewa.
\b
\q1 
\v 27 Hele hou mai la lakou i Ierusalema; a i kona hele ana iloko o ka luakini, hele mai la io na la ka poe kahuna nui, a me ka poe kakauolelo, a me ka poe lunakahiko,
\q1 
\v 28 I mai la ia ia, Heaha kou pono e hana'i i keia mau mea? Nawai la hoi oe i haawi mai ia pono e hana i ua mau mea la?
\q1 
\v 29 Olelo aku la Iesu ia lakou, i aku la, E niuau aku no hoi au ia oukou i kekahi mea; e hai mai oukou ia'u, alaila, hai aku au ia oukou i ko'u pono e hana'i i keia mau mea.
\q1 
\v 30 No ka lani anei ka bapetiso ana a Ioane? No kanaka anei? E hai mai hoi ia'u.
\q1 
\v 31 Kukakuka iho la lakou ia lakou iho no, i ae la, A i olelo aku paha kakou, No ka lani mai, alaila, e ninau mai no oia ia kakou, No ke aha la hoi oukou i manaoio ole aku ai ia ia?
\q1 
\v 32 Aka, i olelo paha uanei kakou, No kanaka; makau no hoi lakou i kanaka, no ka mea, ua manao nui na kanaka, he kaula io o Ioane.
\q1 
\v 33 Olelo mai la lakou ia Iesu, i mai la, Aole makou ike. Alaila, olelo aku la Iesu ia lakou, i aku la, Aole no hoi au e hai aku ia oukou i ka'u pono e hana'i i keia mau mea.
\c 12
\b
\q1 
\v 1 A LAILA, hoomaka oia e olelo mai ia lakou ma na olelonane. Kanu iho la kekahi kanaka i ka malawaina, a hana iho la ia i ka pa a puni, a kohi ilalo i kahi e kaomi ai i ka waina, kukulu iho la i ka hale kiai, haawi ae la i na hoaaina, a hele aku la i ka aina e.
\q1 
\v 2 A i ka wa pono, hoouna mai la ia i ke kauwa i na hoaaina, i loaa aku ia ia ka hua o ka malawaina, no ka poe hoaaina.
\q1 
\v 3 Hopu iho la lakou ia ia, kuikui aku la, a hoihoi nele aku la ia ia.
\q1 
\v 4 Hoouna hou mai la ia io lakou la i kokahi kauwa hou; a hailuku aku la lakou ia ia, a eha kona poo, a hoihoi aku lakou ia ia me ka hoino.
\q1 
\v 5 Hoouna hou mai la ia i kekahi mea hou; a pepehi aku la lakou ia ia a make; a o na mea e ae he nui loa, kuikui no i kekahi, a pepehi i kekahi.
\q1 
\v 6 He keikikane hookahi kana, o kana punahele, oia kana i hoouna hope mai ai ia lakou, i mai la, E mahalo mai paha lakou i kuu keikikane.
\q1 
\v 7 I ae la kela poe hoaaina ia lakou iho no, Eia no ka hooilina; ina kakou e pepehi ia ia, alaila, e lilo mai ka waiwai no kakou.
\q1 
\v 8 Hopu iho la lakou ia ia, pepehi aku la; a hoolei aku hoi; mailoko aku o ka malawaina.
\q1 
\v 9 No ia mea, pehea la nanei e hana mai ai ka haka o ia malawaina? E hele mai no ia a e luku iho ia poe hoaaina, a e haawi aku i ka malawaina no hai.
\q1 
\v 10 Aole anei oukou i heluhelu i keia palapala, O ka pohaku i haaleleia e ka poe hana hale, ua lilo ia i pohaku kumu no ke kihi:
\q1 
\v 11 O ka hana keia a Iehova, he mea mahalo ia i ko kakou mau maka.
\q1 
\v 12 Imi iho la lakou e hopu ia ia, a makau ae la lakou i kanaka; no ka mea, ua ike lakou ua olelo oia i keia olelonane no lakou: a haalele lakou ia ia, a hele aku.
\b
\q1 
\v 13 Hoouna mai la lakou i kekahi o ka poe Parisaio, a me ko Herode poe io na la e hoohihia ai ia ia ma ka olelo.
\q1 
\v 14 A hiki mai la lakou, olelo mai la lakou ia ia, E ke kumu e, ua ike makou he pono oe, aole oe i makau i kekahi; aole hoi oe i nana i ko waho o ke kanaka, aka, ke hoike pono mai nei oe i ka aoao o ke Akua, ma ka oiaio: He mea pono anei, ke haawi aku i ka waiwai auhau na Kaisara? Aole anei?
\q1 
\v 15 E haawi anei makou? Aole paha makou e haawi aku? Ike aku la ia i ko lakou hookamani ana, i aku la oia ia lakou, No ke aha la oukou e hoao mai nei ia'u? E lawe mai oukou i kekahi denari io'u nei i ike au.
\q1 
\v 16 A lawe mai la lakou. Alila ninau aku oia ia lakou, Nowai keia kii, a me ka palapala? I mai la lakou ia ia. No Kaisara.
\q1 
\v 17 Olelo aku la Iesu, i aku la ia lakou, E haawi aku i ka Kaisara ia Kaisara, a i ka ke Akua hoi i ke Akua. Pilipu iho la lakou ia ia.
\b
\q1 
\v 18 Alaila, hele aku la io na la, na Sadukaio ka poe i olelo, Aole e ala hou mai; ninau aku la lakou ia ia, i aku la,
\q1 
\v 19 E ke kumu, ua palapala mai o Mose ia makou. Ina i make ke kaikuaana o kekahi kanaka, a koe ka wahine ana, aole hoi ana keiki, na ke kaikaina no e mare ia wahine, i loaa ke keiki na kona kaikuaana.
\q1 
\v 20 Ehiku no na keiki kane; a mare aku la ka hiapo i ka wahine, a make ia, aole ana keiki.
\q1 
\v 21 Mare ae la ke kaikaina ia ia, a make ia, aole no hoi ana keiki; a pela no ka muli aku.
\q1 
\v 22 A mare ae la no hoi ka poe ehiku a pau ia ia, aole hoi a lakou keiki; a mahope iho, make aku la no hoi ka wahine.
\q1 
\v 23 Nolaila, i ke ala hou ana mai, a ala hou lakou, nawai la uanei o lakou ua wahine la? No ka mea, moe aku no lakou ehiku ia ia.
\q1 
\v 24 Olelo mai Iesu, i mai la ia lakou, Aole anei oukou i lalau, no ko oukou ike ole ana i ka palapala hemolele, a me ka mana o ke Akua?
\q1 
\v 25 No ka mea, i ka wa e ala hou mai ai lakou, maiwaena mai o ka poe make, aole lakou e mare, aole hoi e hoopalauia; aka, e like ana lakou, me na anela iloko o ka lani.
\q1 
\v 26 A no ke ala hou ana o ka poe make, aole anei oukou i heluhelu iloko o ka palapala a Mose, i ka mea a ke Akua i olelo mai ai ia ia, maloko o ka laau, i mai, Owau no ke Akua o Aberahama, a o ke Akua o Isaaka, a o ke Akua o Iakoba?
\q1 
\v 27 Aole oia ke Akua o ka poe make, aka, ke Akua no ia o ka poe ola; no ia mea, ua lalau oukou.
\b
\q1 
\v 28 Hele mai la kekahi o ka poe kakauolelo, a lohe i ka lakou kamailio ana, a ike ia i ka pono o ka Iesu olelo ana, alaila, ninau aku la oia ia ia, Heaha la ke kanawai nui o na kanawai a pau?
\q1 
\v 29 I mai la Iesu ia ia, Eia ke kanawai nui o na kanawai a pau, E hoolohe mai, e ka Iseraela, o Iehova, o ko kakou Akua, o ka Haku hookahi no ia:
\q1 
\v 30 E aloha oe ia Iehova i kou Akua, me kou naau a pau, a me kou uhane a pau, a me kou manao a pau, a me kou ikaika a pau; oia ke kanawai i oi.
\q1 
\v 31 A ua like no hoi ka lua me ia, E aloha oe i kou hoalauna me kou aloha ia oe iho. Aole kanawai e ae i oi mamua o keia mau kanawai.
\q1 
\v 32 I aku la ua kakauolelo la ia ia, Maikai, e ke Kumu, ua olelo mai oe i ka mea oiaio; no ka mea, hookahi wale no Akua, aole e ae, oia wale no.
\q1 
\v 33 A o ke aloha aku ia ia me ka naau a pau, a me ka manao a pau, a me ka uhane a pau, a me ka ikaika a pau a o ke aloha aku i ka hoalauna, e like me kona aloha ia ia iho, ua oi no keia mau mea mamua o na mohaikuni, a me na mea mohai a pau loa.
\q1 
\v 34 Ike mai la Iesu, ua pono kana olelo ana mai, alaila, i mai la oia ia ia, Aole oe i mamao ae i ke aupuni o ke Akua. Mai ia wa iho, aohe kanaka i aa e ninaninau hou aku ia ia.
\b
\q1 
\v 35 Olelo mai la Iesu, i mai la ma kana ao ana iloko o ka luakini, No ke aha la i olelo mai ai ka poe kakauolelo, He keiki na Davida ka Mesia?
\q1 
\v 36 No ka mea, olelo mai la o Davida ma ka Uhane Hemolele, Olelo mai la o Iehova i ko'u Haku, E noho mai oe ma ko'u lima akau, a hoolilo aku ai au i kou enemi i keehana wawae nou.
\q1 
\v 37 A ina kapa aku o Davida ia ia i Haku, Pehea la hoi oia he keiki nana? A lohe ae la na makaainana ia ia me ka olioli.
\b
\q1 
\v 38 I mai la oia ia lakou ma kana ao ana, E ao oukou no ka ka poe kakauolelo; ke makemake nei lakou e hele me ke kapa loihi, a me ke alohaia mai ma kahi kuai,
\q1 
\v 39 A me na noho hanohano iloko o na halehalawai, a me na wahi maikai ma na ahaaina.
\q1 
\v 40 Ua pau ia lakou na hale o na wahinekanemake, a ke hooloihi nei lakou i ka pule no ka ikeia mai. E nui aku auanei ko lakou hoohewaia.
\b
\q1 
\v 41 Noho iho la Iesu ma ke alo o ka waihonakala, a nana ae la i kanaka e hoolei ana i ke kala iloko o ka waihonakala; a nui loa iho la na mea waiwai i hoolei nui mai.
\q1 
\v 42 Hele mai la kekahi wahinekanemake hune, hoolei mai la ia i elua Iepeta, a o laua pu, hookahi ia keneta.
\q1 
\v 43 Alaila, kahea mai la ia i kana poe haumana, i mai la ia lakou, He oiaio ka'u e olelo aku nei ia oukou, O keia wahinekanemake hune, ua oi aku kana mea i hoolei iho ai, mamua o ko lakou a pau, ka poe i hoolei iho iloko o ka waihonakala:
\q1 
\v 44 No ka mea, hoolei iho lakou a pau, no loko o ka lakou waiwai nui; aka, oia, ma kona hune, ua hoolei mai ia i kona mea a pau, i kona mea ola a pau hoi.
\c 13
\b
\q1 
\v 1 A I kona hele ana mai loko aku o ka luakini, olelo aku la kekahi o kana poe haumana ia ia, E ke kumu, e nana oe, nani wale ke ano o keia mau pohaku, a me na hale.
\q1 
\v 2 Olelo mai la Iesu, i mai la ia ia, Ke ike nei anei oe i keia mau hale nui? Aole e waihoia kekahi pohaku, maluna iho o kekahi pohaku i ka hoohiolo ole ia.
\b
\q1 
\v 3 I kona noho ana iluna o ka mauna Oliveta, ma ka hulinaalo o ka luakini, ninau malu aku la o Petero, a me Iakobo, a me Ioane, a me Anederea ia ia;
\q1 
\v 4 E hai mai oe ia makou i ka wa hea e hiki mai ai keia mau mea, a heaha la ka ouli o ka hiki ana mai o ia mau mea?
\q1 
\v 5 Olelo mai la Iesu ia lakou, i mai la, i kana olelo ana, E ao oukou e malama o alakai hewa ia oukou.
\q1 
\v 6 No ka mea, he nui na mea e hele mai ana ma ko'u inoa, me ka olelo mai, Owau no ia, a e alakai hewa ia na mea he nui loa.
\q1 
\v 7 A i lohe oukou i ke kaua, a me ka lono o ke kaua, mai hopohopo oukou; no ka mea, e hiki io mai no ia mau mea a pau, aole nae ia ka hope.
\q1 
\v 8 E ku e auanei kekahi aina i kekahi aina, a o kekahi aupuni hoi i kekahi aupuni; a e hiki mai auanei na olai, ma kauwahi, a me na wi, a me na kipikipi. Aka, o ka makamua wale no ia o na popilikia.
\b
\q1 
\v 9 E ao nae oukou ia oukou iho, no ka mea, e haawiia'ku no oukou i ka poe hookolokolo, a e hahau mai lakou ia oukou iloko o na halehalawai; a no'u nei e hookuia'i oukou imua o na kiaaina, a me na'lii, i mea e hoike aku ai no lakou.
\q1 
\v 10 E pono nae, ke hai e ia'ku mamua ka euanelio, ma na aina a pau.
\q1 
\v 11 Aia alakai lakou ia oukou, e haawi aku, mai manao mua oukou i ka mea a oukou e olelo aku ai, mai noonoo e; aka, o ka mea e haawiia na oukou ia wa, oia ka oukou mea e olelo aku ai; no ka mea, aole na oukou ka olelo na ka Uhane Hemolele no.
\q1 
\v 12 A e haawi aku ana ke kaikuaana i ke kaikaina e make, a me ka makuakane no hoi i ke keiki; a e ku e mai no hoi na keiki i na makua, a e haawi aku ia lakou e make.
\q1 
\v 13 No ko'u inoa e inainaia'i oukou e na kanaka a pau; aka, o ka mea e hoomanawanui a hiki i ka hopena, e ola ia.
\b
\q1 
\v 14 A ike aku oukou i ka mea haumia e hooneoneo ana, i oleloia mai ai e Daniela, o ke kaula, e ku ana i kahi pono ole, (O ka mea heluhelu, e hoomaopopo oia,) alaila, o ka poe e noho ana ma Iudea, e holo lakou i kuahiwi.
\q1 
\v 15 A o ka mea maluna o ka hale, mai iho mai ia iloko o ka hale, aole hoi e komo e lawe i kekahi mea, mai loko ae o kona hale.
\q1 
\v 16 A o ka mea ma ka waeua, mai hoi hou mai ia e lawe i kona kapa.
\q1 
\v 17 Auwe hoi i ka poe wahine hapai, a me ka poe hanai waiu ana ia mau la!
\q1 
\v 18 A e pule aku oukou, i ole ma ka hooilo ko oukou auhee ana.
\q1 
\v 19 No ka mea, e nui auanei ka popilikia o ua mau la la, aole meneia mai kinohi mai o ka honua a ke Akua i hana'i a hiki loa mai nei i keia wa, aole no hoi mahope aku.
\q1 
\v 20 A i hoopokole ole ka Haku ia mau la, aole loa e ola kekahi kanaka; aka, no ka poe i waeia, e hoopokoleia'e ua mau la la.
\q1 
\v 21 A i kela wa, ina olelo mai kekahi kanaka, Eia ka Mesia maanei, aia hoi mao, mai manaoio oukou ia.
\q1 
\v 22 No ka mea, e ku mai auanei iluna na Mesia wahahee, a me na kaula wahahee, a e hoike mai i na hoailona, a me na hana mana, ina he mea hiki, e hoohihia lakou i poe i waeia.
\q1 
\v 23 E ao hoi oukou; aia, ua hoike e aku no wau ia oukou i na mea a pau loa.
\b
\q1 
\v 24 A pau ka pilikia ana o ia mau la, alaila, e pouli loa no ka la, aole hoi e haawi mai ka mahina i kona malamalama;
\q1 
\v 25 E haule iho no hoi na hoku o ka lani, a e haalulu no na mea mana o ka lani.
\q1 
\v 26 Ilaila lakou e ike ai i ke Keiki a ke kanaka e hele mai ana ma na ao me ka mana nui, a me ka nani.
\q1 
\v 27 Alaila ia e hoouna aku ai i na anela ana, a e akoakoa mai i kana poe i waeia, mai na kukulu eha mai, a mai kela pa o ka honua, a mai kela pa o ka lani mai.
\b
\q1 
\v 28 E ao hoi oukou i ka nane o ka laau fiku: i ka wa e opiopio ai kona lala, a e hoomaka ana na lau, alaila oukou e ike ai, ua kokoke mai ke kau:
\q1 
\v 29 Pela no hoi oukou, a ike oukou e hanaia mai ana keia mau mea la, ilaila oukou e ike ai, ua kokoke mai no, aia ma ka ipuka.
\q1 
\v 30 He oiaio ka'u e olelo aku nei ia oukou, aole e pau keia hanauna, a hana e ia mai no keia mau mea a pau mamua.
\q1 
\v 31 E lilo no ka lani a me ka honua; aka, o ka'u mau olelo, aole loa ia e lilo.
\b
\q1 
\v 32 Aka, o kolaila la, a me kolaila hora, aole loa kekahi kanaka i ike, aole no hoi ka poe anela iluna o ka lani, aole no hoi ke Keiki, o ka Makua wale no.
\b
\q1 
\v 33 E ao oukou, e makaala, a e pule; no ka mea, aole oukou i ike i kela wa.
\q1 
\v 34 E like auanei ia me ke kanaka e hele ana i kahi loihi, haalele ia i kona hale, kauoha ae la i kana poe kauwa, a haawi i kela, a i keia i kana hana, a kauoha mai i ke kiaipuka, e makaala.
\q1 
\v 35 E makaala no hoi oukou; no ka mea, aole oukou i ike i ka wa e hiki mai ai o ka haku mea hale, i ke ahiahi paha, i ke aumoe paha, a i ke kani ana o ka moa, a i ke kakahiaka;
\q1 
\v 36 O hiki e mai ia, a loaa mai oukou e hiamoe ana.
\q1 
\v 37 O ka'u e olelo aku nei ia oukou, oia no ka'u e olelo aku nei i na mea a pau loa, E makaala.
\c 14
\b
\q1 
\v 1 A HALA ae la na la elua, alaila ka ahaaina o ka moliaola, a me ka berena hu ole; imi iho la ka poe kahuna nui a me ka poe kakauolelo e hopu ia ia me ka maalea, a e pepehi.
\q1 
\v 2 I ae la lakou, Aole i ka la ahaaina, o haunaele auanei na kanaka.
\b
\q1 
\v 3 A aia ia i Betania, iloko o ka hale o Simona ka lepero, e moe ana e ai ilaila, hele mai la kekahi wahine me ka ipu alabata, he mea poni koloko, he aila ala, he mea kumukuai nui; a wehe ia i ka ipu, a ninini iho la ia iluna iho o kona poo.
\q1 
\v 4 Huhu ae la kekahi poe iloko o lakou iho, i ae la, No ke aha la i hoomaunaunaia'i keia aila?
\q1 
\v 5 Ina paha i kuaiia'ku ia, ekolu haneri denari a keu aku paha i loaa mai, i mea haawi aku no ka poe ilihune. Ohumu iho la lakou i ua wahine la.
\q1 
\v 6 I mai la Iesu, Uoki, no ke aha oukou e hoino aku nei ia ia? He mea maikai kana i hana mai nei ia'u.
\q1 
\v 7 Ua mau loa ka poe ilihune me oukou, a e hiki no ia oukou ke hana maikai aku ia lakou i na manawa a pau a oukou e makemake ai; aka, owau, aole au e mau loa ana me oukou.
\q1 
\v 8 O ka mea hiki ia ia nei, ua hana io mai ia; a ua hele mua mai e poni i ko'u kino, no ko'u kanuia.
\q1 
\v 9 He oiaio ka'u e olelo aku nei ia oukou, Ma na wahi a pau loa ma ke ao nei e haiia'ku ai keia euanelio, e hai pu ia'ku no hoi ka mea ana i hana mai ai, i mea e hoomanaoia'i oia.
\b
\q1 
\v 10 Ilaila ka hele ana o Iuda Isekariota, kekahi o ka poe umikumamalua, i ka poe kahuna nui, e kumakaia ia ia na lakou.
\q1 
\v 11 A lohe ae la lakou, olioli iho la, a ae mai la lakou i ka haawi ia ia i kala. Imi iho la ia i kahi e hiki pono ai ke kumakaia ia ia.
\b
\q1 
\v 12 A i ka la mua o ka ahaaina berena ha ole, i ka wa e kalua'i i ka moliaola, ninau aku la kana poe haumana ia ia, Auhea la kau wahi makemake e hele ai makou e hoomakaukau, i ai oe i ka moliaola?
\q1 
\v 13 A hoouna ae la ia i na haumana ana elua, i ae la ia laua, E hele aku olua i ke kulanakauhale, alaila olua e halawai ai me kekahi kanaka e hali ana i ke kiaha wai, e hahai aku olua ia ia.
\q1 
\v 14 A i kana wahi e komo aku ai, e olelo olua i ka mea hale, E, ke olelo mai nei ke Kumu, Auhea la ke keena hookipa, kahi e ai pu ai au i ka moliaola me ka'u poe haumana?
\q1 
\v 15 A e hoike mai no kela ia olua i kekahi keena nui maluna, ua makaukau koloko; malaila olua e hoomakaukau ai no kakou.
\q1 
\v 16 Hele aku la na haumana, a hiki aku la i ke kulanakauhale, loaa ia laua e like me kana mea i olelo mai ai ia laua: a hoomakaukau laua i ka moliaola.
\b
\q1 
\v 17 A i ke ahiahi hele mai la ia me ka poe umikumamalua.
\q1 
\v 18 A i ko lakou moe ana i ka ahaaina, olelo mai la Iesu, He oiaio ka'u e olelo aku nei ia oukou, E kumakaiaia auanei au e kekahi o oukou, o ka mea e ai pu ana me au.
\q1 
\v 19 Kaumaha iho la lakou, a olelo pakahi aku la ia ia, Owau anei? a o kekahi, Owau anei?
\q1 
\v 20 Olelo mai la ia, i mai la ia lakou, O kekahi o ka poe umikumamalua e miki pu ana kona lima me au i ke pa, oia no ia.
\q1 
\v 21 Ke hele aku nei no ke Keiki a ke kanaka, e like me ka mea i palapalaia mai ai nona: aka, auwe ke kanaka nana e kumakaia i ke Keiki a ke kanaka! e aho no ia ina aole i hanauia mai ia.
\b
\q1 
\v 22 A i ka lakou ai ana, lalau ae la Iesu i ka berena, hoalohaloha aku la, wawahi iho la, a haawi mai la ia lakou, i mai la, E lawe, e ai; o ko'u kino keia.
\q1 
\v 23 Alaila, lalau iho la ia i ke kiaha a hoalohaloha aku ia, alaila, haawi mai la ia lakou; a inu iho la lakou a pau i ko loko.
\q1 
\v 24 I mai la oia ia lakou, O ko'u koko keia no ke kauoha hou, ua hookaheia no na kanaka he nui loa.
\q1 
\v 25 He oiaio ka'u e hai aku nei ia oukou, aole au e inu hou aku i ko ka hua o ke kumu waina, a hiki aku i ka la o inu ai au i ka mea hou iloko o ke aupuni o ke Akua.
\b
\q1 
\v 26 Himeni ae la lakou, alaila hele aku la iwaho ma ka mauna o Oliveta.
\b
\q1 
\v 27 I mai la Iesu ia lakou, I neia po e hihia auanei oukou a pau no'u; no ka mea, ua palapalaia, E pepehi ana au i ke kahuhipa, a e puehu wale aku no na hipa.
\q1 
\v 28 Aka, mahope iho o ko'u ala hou ana mai, e hele aku au mamua o oukou i Galilaia.
\q1 
\v 29 I aku la o Petero ia ia, Ina e hihia lakou a pau, aole loa owau.
\q1 
\v 30 I mai la Iesu ia ia, He oiaio ka'u e hai aku nei ia oe, i keia la, a i keia po no, aole o hiki ke kani ana o ka moa kualua, ekolu on hoole e ana mai ia'u.
\q1 
\v 31 Alaila, olelo ikaika aku la o Petero, Aole loa wau e hoole aku ia oe, ke make pu au me oe; a pela lakou a pau i olelo aku ai.
\b
\q1 
\v 32 Alaila, hele mai la lakou i kahi i kapaia o Getesemane; i mai la ia i kana poe haumana, E noho oukou maanei, i kuu wa e pule ana.
\q1 
\v 33 A kai aku la oia ia Petero, a me Iakobo, a me Ioane, ilaila ka hoomaka ana o kona kaumaha a me ka luuluu loa.
\q1 
\v 34 I mai la oia ia lakou, Ua kaumaha loa kuu uhane, me he mea make la. E kali oukou maanei, a e makaala no hoi.
\q1 
\v 35 Hele iki aku la ia a hina iho la ma ka lepo, a pule aku la, ina e hiki ia mea, e laweia'ku ia hora.
\q1 
\v 36 I aku la ia, E Aba, e ka Makua, ua hiki na mea a pau loa ia oe, e lawe aku oe i keia kiaha o'u; aka hoi, aole o ko'u makemake e hanaia, aia o kou.
\q1 
\v 37 Hoi mai la ia, loaa iho la lakou ia ia e hiamoe ana; i mai la oia ia Petero, E Simona, ke hiamoe nei anei oe? Aole anei e hiki ia oe ke makaala i hookahi hora?
\q1 
\v 38 E makaala oukou, e pule, o hoowalewaleia mai oukou. Ua makemake no ka naau, aka, o ke kino, ua nawaliwali ia.
\q1 
\v 39 Hele hou aku la ia, a pule aku la, ma ia olelo hookahi ana no.
\q1 
\v 40 A hoi mai la ia, loaa hou no lakou e hiamoe ana, (no ka mea, ua maloeloe ko lakou maka,) aole nae lakou i ike i ka mea e olelo aku ai ia ia.
\q1 
\v 41 Hele hou mai la oia ia lakou, o ke kolu ia o kona hele ana mai, i mai la ia lakou, E hiamoe aku oukou, e hoomaha. Ua pau, ua hiki mai nei ka hora; aia hoi, ua kumakaiaia ke Keiki a ke kanaka i ka lima o ka poe hewa.
\q1 
\v 42 E ala, e haele kakou; aia hoi, ke kokoke mai nei ka mea nana wau e kumakaia.
\b
\q1 
\v 43 I kana olelo ana, hele koke mai la o Iuda, kekahi o ka poe umikumamalua, a me ia no na kanaka he nui loa, me na pabikaua, a me na newa, na ka poe kahuna nui mai, a me ka poe kakauolelo, a me ka poe lunakahiko.
\q1 
\v 44 A o ka mea nana ia i kumakaia, ua haawi ae ia i hoailona na lakou, i ae la, O ka mea a'u e honi aku ai, oia no ia, e hopu aku ia ia, a e alakai paa aku.
\q1 
\v 45 A hiki mai la ia, alaila hele koke aku la ia io na la, i aku la, E Rabi, e Rabi; a honi aku la ia ia.
\b
\q1 
\v 46 Lalau aku la ko lakou lima ia ia, hopu iho la.
\q1 
\v 47 A o kekahi o lakou e ku ana malaila, unuhi ae la ia i ka pahikaua, hahau aku la i kekahi kauwa o ke kahuna nui, a oki ae la i kona pepeiao.
\q1 
\v 48 Olelo mai la Iesu, i mai ia lakou, Ua hele mai nei anei oukou iwaho nei, me na pahikana, a me na newa e hopu mai ia'u, me he powa la?
\q1 
\v 49 Me oukou no au i noho ai iloko o ka luakini, e ao ana aku i kela la i keia la, aole oukou i hopu mai ia'u; aka, e hookoia mai no nae ka palapala hemolele.
\q1 
\v 50 Haalele aku la kana poe haumana a pau ia ia, holo aku la.
\b
\q1 
\v 51 Hahai aku la kekahi kanaka opiopio ia ia, e aahu ana i ke kapa olona ma ka ili, lalau iho la ka poe koa ia ia.
\q1 
\v 52 Haalele iho la ia i ke kapa olona, a holo kohana aku la, mai o lakou aku.
\b
\q1 
\v 53 Alakai aku la lakou ia Iesu i ke kahuna nui; ua akoakoa pu mai no me ia ka poe kahuna nui a pau, a me ka poe lunakahiko, a me ka poe kakauolelo.
\q1 
\v 54 Hahai mamao aku la o Petero ia ia, a hiki i ka hale o ke kahuna nui; a noho pu ia me ka poe kauwa, e lalana ana ia ia iho i ke ahi.
\q1 
\v 55 Imi iho la ka poe kahuna nui, a me ka ahalunakanawai, i mea hoike no Iesu e make ai, aole nae i loaa.
\q1 
\v 56 No ka mea, he nui no ka poe hoike wahahee mai nona, aole hoi i ku like ko lakou hoike ana.
\q1 
\v 57 Ku ae la kekahi mau mea, hoike wahahee ae la, i ae,
\q1 
\v 58 Ua lohe no maua i kana olelo ana mai, E wawahi ana au i keia luakini i hanaia e ka lima, a i na la ekolu e hana hou no wau i kekahi i hana ole ia e ka lima.
\q1 
\v 59 Aole nae i ku like ko laua hoike ana.
\q1 
\v 60 Ku ae la iluna ke kahuna nui iwaenakonu o lakou, ninau aku la ia Iesu, i aku la, Aole anei oe e olelo mai? Heaha la kela mea a laua nei i hoike ai nou?
\q1 
\v 61 Noho malie iho la ia, aole i olelo mai. Ninau hou aku la ke kahuna nui ia ia, i aku la, O oe no anei ka Mesia, ke Keiki a ka mea i hoomaikaiia?
\q1 
\v 62 Olelo mai la Iesu, Owau no ia; a e ike mai auanei oukou i ke Keiki a ke kanaka e noho ana ma ka lima akau o ka Mana loa, a e hele mai ana ma na ao o ka lani.
\q1 
\v 63 Alaila haehae ae la ke kahuna nui i kona kapa, i ae la, No ke aha la kakou e makemake hou ai i mea hoike?
\q1 
\v 64 Ua lohe ae nei oukou i kana olelo hoino ana. Pehea la ko oukou manao? Hoohewa mai la lakou a pau ia ia, he hewa kupono i ka make.
\q1 
\v 65 Kuhakuha aku la kekahi poe ia ia, a uhi aku la kekahi poe i kona maka, kuikui aku la ia ia, me ka i aku, E koho mai. A kuikui aku la ka poe ilamuku ia ia, me ko lakou mau poho lima.
\b
\q1 
\v 66 I ko Petero noho ana malalo, ma ka pa, hele mai la kekahi kaikamahine o ke kahuna nui.
\q1 
\v 67 A ike mai la kela ia Petero e lalana ana ia ia iho, nana ae la oia ia ia, i ae la, O oe no kekahi pu me Iesu no Nazareta.
\q1 
\v 68 Hoole aku la ia, i aku la, Aole au i ike ia ia, aole hoi i maopopo ia'u ka mea au e olelo mai nei. Alaila, hele aku la ia iwaho ma ka lanai, a ooo mai la ka moa.
\q1 
\v 69 Ike hou ae la kekahi kaikamahine ia ia, a olelo ae la ia i ka poe e ku ana malaila, Oia nei no kekahi o lakou.
\q1 
\v 70 Hoole hou aku la ia. A mahope iho, i ae la ka poe e ku ana malaila ia Petero, Oiaio, o oe no kekahi o lakou, no ka mea, no Galilaia oe, ke hoike mai nei no hoi kau olelo ana.
\q1 
\v 71 Alaila, hailiili iho la oia, me ka hoohiki, Aole au i ike ia kanaka a oukou e olelo mai nei.
\q1 
\v 72 Ooo hou mai la ka mea. Alaila, manao iho la o Petero i ka Iesu olelo ana mai ia ia, Aole e hiki i ke kani ana o ka moa kualua, a ekolu no ou hoole ana mai ia'u. A i kona noonoo ana, uwe iho la ia.
\c 15
\b
\q1 
\v 1 A KAKAHIAKA ae la, kukakuka koke iho la na kahuna nui, a me na lunakahiko, a me na kakauolelo, a me ka ahalunakanawai a pau, a nakinaki aku la ia Iesu, a kai ae la, a haawi aku la i Pilato.
\q1 
\v 2 Ninau mai la o Pilato ia ia, O oe no anei ke alii o ka poe Iudaio? Hai aku la ia, i aku la ia ia, Oia no kau e olelo mai la.
\q1 
\v 3 Hoopii aku la na kahuna nui nona, ma na mea he nui loa; aole ia i olelo mai.
\q1 
\v 4 Ninau hou mai la o Pilato ia ia, i mai la, Aole anei oe e olelo iki mai? E noonoo oe i ka nui loa o na mea a lakou e hoopii mai nei nou.
\q1 
\v 5 Aole i olelo iki mai o Iesu; nolaila kahaha aku la ko Pilato naau.
\b
\q1 
\v 6 Ia ahaaina, kuu mai la ia i kekahi paahao no lakou, i ka mea a lakou i noi aku ai.
\q1 
\v 7 Malaila no kekahi i kapaia o Baraba, ua nakinaki pu ia me ka poe i kipikipi, ua pepehi kanaka lakou me ia kipikipi ana.
\q1 
\v 8 Hooho nui ae la na kanaka, me ka nonoi aku ia ia e hana mai ia lakou e like me kana mamua.
\q1 
\v 9 Olelo mai la o Pilato ia lakou, i mai la, Ke makemake nei anei oukou e kuu aku au i ke alii o ka poe Iudaio, no oukou?
\q1 
\v 10 No ka mea, ua ike oia, no ka huahua i hoopea aku ai na kahuna nui ia ia.
\q1 
\v 11 Hookonokono ae la na kahuna nui i na kanaka, i kuu mai oia ia Baraba no lakou.
\q1 
\v 12 Ninau hou mai la o Pilato, i mai la ia lakou, Heaha ko oukou makemake e hana aku ai au i ka mea a oukou i kapa aku ai, O ke alii o ka poe Iudaio?
\q1 
\v 13 Hea hou aku la lakou, E kauia oia ma ke kea.
\q1 
\v 14 Alaila, ninau mai la o Pilato ia lakou, Heaha ka hewa ana i hana'i? Uwauwa nui aku la lakou, E kauia oia ma ke kea.
\b
\q1 
\v 15 Makemake no o Pilato, e hooluolu i kanaka, nolaila ia i kuu mai ai ia Baraba na lakou; alaila, hahau ae la kela ia Iesu, a haawi iho ia ia e kaulia'i ma ke kea.
\b
\q1 
\v 16 Alakai ae la ka poe koa ia ia i ke keena hookolokolo; a houluulu mai la lakou i ka poe koa a pau.
\q1 
\v 17 Hoaahu iho la lakou ia ia i ke kapa ula, a hili iho la i lei alii kakalaioa, a hoolei aku la ia ia.
\q1 
\v 18 Aloha hoomaewaewa aku la lakou ia ia, Aloha oe, e ke alii o ka poe Iudaio!
\q1 
\v 19 Hahau aku la lakou i kona poo i ka laau, a kuhakuha aku la ia ia, a kukuli iho la e hoomana ia ia.
\b
\q1 
\v 20 A pau ko lakou hoomaewaewa ana ia ia, alaila, wehe ae la lakou i ke kapa ula, a hookomo iho la i kona kapa, alakai aku la lakou ia ia e kau ia ia ma ke kea.
\b
\q1 
\v 21 A koi aku la lakou i kekahi Simona no Kurenaio, e lawe i kona kea, e hele ana ia, mai ke kuaaina mai, o ka makuakane hoi ia o Alekanedero, a me Rupo.
\b
\q1 
\v 22 A lawe ae la lakou ia ia i Golegota, o ke ano keia i ka hoakaka ana, He wahi iwipoo.
\q1 
\v 23 Haawi aku la lakou ia ia i ka waina ua wili pu ia me ka mura, aole nae ia i inu.
\q1 
\v 24 A kau aku la lakou ia ia ma ke kea, alaila, puunaue iho la lakou i kona kapa, me ka puu ana ma ka mea a kela kanaka, keia kanaka e lawe ai.
\q1 
\v 25 I ke kolu o ka hora, ko lakou kau ana ia ia ma ke kea.
\q1 
\v 26 Eia ka palapala hoakaka i kona hewa i kauia maluna, O KE ALII O KA POE IUDAIO.
\q1 
\v 27 Kau pu aku la lakou me ia ma ke kea, i na powa elua; o kekahi ma ka aoao akau, a o kekahi, ma ka aoao hema.
\q1 
\v 28 A ko iho la ka ka palapala hemolele i olelo mai ai, Ua helu pu ia oia me ka poe lawehala.
\q1 
\v 29 A o ka poe e maalo ana malaila ae, hoino wale aku la lakou ia ia, me ka hookunokunon i ko lakou poo, i aku la, E, o oe ka mea wawahi i ka luakini, a i na la ekolu, hana hou no,
\q1 
\v 30 E hoola oe ia oe iho, a e iho mai oe mai luna mai o ke kea.
\q1 
\v 31 Pela pu aku la no hoi ka poe kahuna nui a me ka poe kakauolelo, i hoomaewaewa aku ai, i ae kekahi, Hoola no oia ia hai, aole nae e hiki ia ia ke hoola ia ia iho.
\q1 
\v 32 E iho mai ka Mesia, ke Alii o ka Iseraela, mai luna mai o ke kea, i ike kakou a e manaoio aku. A o na mea i kaulia pu me ia ma ke kea, hoomaewaewa pu ae la laua ia ia.
\b
\q1 
\v 33 Mai ka hora aono, a hiki i ka hora aiwa, pouli no ka honua a pau.
\q1 
\v 34 A i ka iwa o ka hora, kahea ae la Iesu me ka leo nui, i ae la, Eli, eli, lama sabaketani! O ke ano keia, E kuu Akua, e kuu Akua, no ke aha la oe i haalele mai ai ia'u?
\q1 
\v 35 A lohe ae la kekahi poe o lakou e ku ana malaila, i iho la, Aia, ke kahea aku nei oia ia Elia.
\q1 
\v 36 Holo aku la kekahi, a hoomau i ka huahuakai i ka vinega, kau iho la ma ka ohe, a haawi aku ia ia e inu, i ae la, Alia; i ike kakou ina paha e hele mai o Elia e wehe ia ia.
\b
\q1 
\v 37 Kahea ae la Iesu me ka leo nui, a kaili aku la ke aho.
\q1 
\v 38 Nahae ae la ka paku o ka luakini i elua, mailuna a ilalo.
\b
\q1 
\v 39 A o ka lunahaneri e ku ana imua o kona alo, i kona ike ana ia ia e kahea ana pela, a me ke kaili ana o kona aho, i ae la ia, Oiaio no, o keia kanaka ke Keiki a ke Akua.
\q1 
\v 40 He poe wahine no hoi kekahi e nana mai ana, ma kahi mamao aku, O Maria no Magedala, a me Maria ka makuwahine o Iakabo ka liilii, a me Iose, a me Salome.
\q1 
\v 41 Ua hahai no lakou mamuli ona, i kona wa ma Galilaia, a lawelawe aku la nana; a me na wahine e he nui loa, a hele pu no lakou me ia i Ierusalema.
\b
\q1 
\v 42 A hiki ae la i ke ahiahi, no ka mea, o ka la hoomalolo ia, o ka la mamua aku o ka la Sabati,
\q1 
\v 43 Hele mai la o Iosepa no Arimataia, he lunakanawai koikoi ia, e kakali ana i ke aupuni o ke Akua, hele aku la ia io Pilato la, me ka hopohopo ole, a noi aku la i ke kino o Iesu.
\q1 
\v 44 Kahaha iho la ka naau o Pilato, no kona make koke ana; a kahea ae la ia i ka lunahaneri, ninau ae la ia ia i kona make e ana.
\q1 
\v 45 A ike pono ia, na ka lunahaneri mai, alaila, haawi mai la ia i ke kino na Iosepa.
\q1 
\v 46 A kuai iho la ia i kapa olona, a lawe ae la i ke kino, a wahi iho iloko o ua kapa la, a waiho ae la ia maloko o ka halekupapau i kalaiia iloko o ka pohaku, a olokaa iho la i pohaku nui ma ka puka o ua halekupapau la.
\q1 
\v 47 A nana ae la o Maria no Magedala a mo Maria ka makuwahine o lose, i kahi i waihoia'i.
\c 16
\b
\q1 
\v 1 A HALA ae la ka Sabati, ua kuai o Maria ka Magedala, a me Maria ka makuwahine o Iakobo, a me Salome, i na mea ala, a hele mai la lakou e ialoa ia ia.
\q1 
\v 2 A i ke kakahiaka nui o ka la mua o ka hebedoma i ka puka ana a ka la, hele aku la lakou, i ka halekupapau.
\q1 
\v 3 Kamailio iho la lakou ia lakou iho no, Nawai la e olokaa ae i ka pohaku no kakou, mai ka puka ae o ka halekupapau?
\q1 
\v 4 Nana aku la lakou, ike iho la ua olokaa e ia'ku ka pohaku; no ka mea, he pohaku nui loa ia.
\q1 
\v 5 I ko lakou komo ana iloko o ka halekupapau, ike aku la lakou i kekahi kanaka opiopio, e noho ana ma ka aoao akau, na aahuia i ke kapa loihi keokeo; a makau iho la lakou.
\q1 
\v 6 Olelo mai la oia ia lakou, Mai makau oukou: ke imi nei oukou ia Iesu no Nazareta, i ka mea i kaulia ma ke kea: ua ala mai ia, aole oia maanei; e nana oukou i kahi a lakou i waiho ai ia ia.
\q1 
\v 7 E hele hoi oukou, e hai aku i kana poe haumana a me Petero, e hele aku ana ia mamua o oukou i Galilaia; malaila oukou e ike aku ai ia ia, e like me kana i olelo mai ai ia oukou.
\q1 
\v 8 Hele aku lakou iwaho, a holo mai ka halekupapau aku; a haalulu lakou me ka weliweli; aole uae lakou i hai i kekahi, no ka mea, ua makau lakou.
\b
\q1 
\v 9 I ke ala ana o Iesu i kakahiaka nui o ka la mua o ka hebedoma, ike mua ia oia e Maria, no Magedala, mawaho ona kona kipaku ana i na daimonio ehiku.
\q1 
\v 10 Hele aku la oia, a hai aku la i ka poe i noho pu me ia, ia lakou e u ana, a e uwe ana no hoi.
\q1 
\v 11 A lohe lakou, ua ola ia, a ua ikeia e ia, aole lakou i manaoio mai.
\b
\q1 
\v 12 A mahope iho o ia mau mea, ikeia oia, me ke ano okoa, e na mea elua, ia laua e hele ana i ke kuaaina.
\q1 
\v 13 Hoi mai la laua, a hai mai la i kekahi poe, aole nae lakou i manaoio.
\b
\q1 
\v 14 A mahope iho, ikeia mai no ia e ka poe umikumamakahi, ia lakou e ai ana, a hoohewa mai ia lakou no ko lakou manaoio ole ana, a no ka paakiki o ko lakou naau, no ka mea, aole lakou i manaoio aku i ka ka poe nana ia i ike mahope iho o kona ala ana.
\q1 
\v 15 I mai la oia ia lakou, E hele aku oukou i na aina a pau, e hai aku i ka Euanelio i na kanaka a pau.
\q1 
\v 16 O ka mea e manaoio mai, a bapetizoia, e hoolaia oia, aka, o ka mea manaoio ole mai, e hoohewaia oia.
\q1 
\v 17 Eia no na ouli kupauaha e pili pu aku i ka poe e manaoio mai ia'u. Ma ko'u inoa lakou e mahiki aku ai i na daimonio, a e olelo no hoi lakou ma na olelo ano e.
\q1 
\v 18 E kaikai no lakou i na nahesa; a ina inu lakou i ka mea make, aole lakou e poino ia mea; a e kau no lakou i ko lakou lima maluna o ka poe mai, a e ola lakou.
\b
\q1 
\v 19 A pau ae la ka olelo ana a ka Haku ia lakou, alaila, laweia'ku la ia iluna i ka lani, a noho iho la ma ka lima akau o ke Akua.
\q1 
\v 20 Hele ae lakou, a ao aku la ma na wahi a pau; hana pu mai la no hoi ka Haku me lakou, e hooiaio ana i ka olelo, me na hana mana e pili ana. Amene. 
