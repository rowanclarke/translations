\id MIC - Biblica® Open Kurdi Sorani Standard Version
\h میخا
\toc1 میخا
\toc2 میخا
\toc3 میخا
\mt1 میخا
\c 1
\p 
\v 1 پەیامی یەزدان کە لە سەردەمی یۆتام و ئاحاز و حەزقیای پاشایانی یەهودا بۆ میخای مۆرەشەتی هات، ئەو بینینەی سەبارەت بە سامیرە و ئۆرشەلیم بوو:
\b
\q1 
\v 2 ئەی هەموو گەلان، گوێ بگرن،
\q2 زەوی و هەموو ئەوانەی تێیدان، سەرنج بدەن:
\q1 پەروەردگار لە پەرستگای پیرۆزیەوە،
\q2 یەزدانی باڵادەست ببێتە شایەت بەسەرتانەوە.
\s1 حوکمدان بەسەر سامیرە و ئۆرشەلیم
\q1 
\v 3 ئەوەتا، یەزدان لە شوێنی نیشتەجێبوونی خۆیەوە دێتە دەرەوە،
\q2 دادەبەزێت و بەسەر بەرزاییەکانی زەویدا دەڕوات.
\q1 
\v 4 چیاکان لە ژێری دەتوێنەوە و
\q2 دۆڵەکان شەق دەبەن،
\q1 وەک مۆم لەبەردەم ئاگردا،
\q2 وەک ئاوی ڕۆیشتوو بە لێژاییدا.
\q1 
\v 5 هەموو ئەمە لەبەر یاخیبوونی یاقوب،
\q2 لەبەر گوناهی بنەماڵەی ئیسرائیل.
\q1 چی هۆکاری یاخیبوونی یاقوبە؟
\q2 ئایا سامیرە نییە؟
\q1 ئەی هۆکاری بتپەرستی بەرزاییەکانی یەهودا چییە؟
\q2 ئایا ئۆرشەلیم نییە؟
\b
\q1 
\v 6 «لەبەر ئەوە سامیرە کاول و وێران دەکەم،
\q2 دەیکەمە کێڵگەی مێو چاندن.
\q1 بەردەکانی فڕێدەدەمە ناو دۆڵەکەوە و
\q2 بناغەکانی دەردەخەم.
\q1 
\v 7 هەموو بتەکانی تێکدەشکێنرێن و
\q2 هەموو کرێی داوێنپیسییەکەی بە ئاگر دەسووتێنرێت،
\q2 هەموو بتەکانی وێران دەکەم.
\q1 لەبەر ئەوەی بە کرێی لەشفرۆشی کۆی کردووەتەوە،
\q2 دەدرێتەوە لەشفرۆش.»
\s1 گریان و شیوەن گێڕان
\q1 
\v 8 لەبەر ئەوە دەلورێنم و دەلاوێنمەوە،
\q2 بەپێی پەتی و بە ڕووتی هاتوچۆ دەکەم.
\q1 وەک چەقەڵ دەلورێنم و
\q2 وەک کوندەپەپوو شیوەن دەگێڕم،
\q1 
\v 9 چونکە برینەکەی ساڕێژ نابێت،
\q2 بەڵکو یەهوداش تووش بوو،
\q1 گەیشتە دەروازەی گەلەکەم،
\q2 هەتا ئۆرشەلیم هات.
\q1 
\v 10 ئەوە لە گەت ڕامەگەیەنن،
\q2 بە هیچ شێوەیەک مەگریێن،
\q1 لە بێت‌عۆفرادا\f + \fr 1:10 \ft (بێت‌عۆفرا) واتا (ماڵی خۆڵ).‏\f*
\q2 خۆت لە خۆڵ بگەوزێنە.
\q1 
\v 11 ئەی دانیشتووانی شافیر
\q2 بە ڕووتی و شەرمەزاری بپەڕنەوە،
\q1 دانیشتووانی چەئەنان دەرنەچن.
\q2 بێت‌ئێچەل دەگریێت
\q2 بەڵام ناتانپارێزێت.
\q1 
\v 12 دانیشتووانی مارۆت بە ئازارەوە دەتلێنەوە،
\q2 بە دڵەڕاوکێوە چاوەڕێی چارەسەر دەکەن،
\q1 چونکە لەلایەن یەزدانەوە
\q2 بەڵا بۆ دەروازەی ئۆرشەلیم دابەزی.
\q1 
\v 13 ئەی دانیشتووانی لاخیش،
\q2 گالیسکە بە ئەسپەوە ببەستن،
\q1 ئێوە یەکەمین شار بوون دوای یاخیبوونەکانی ئیسرائیل کەوتن،
\q2 هەروەها سییۆنی کچتان\f + \fr 1:13 \ft دەربڕینێکی خوازەیە بۆ پایتەخت، مەبەست لە هەموو دانیشتووانی شارەکەیە.‏\f* تووشی گوناه کرد.
\q1 
\v 14 لەبەر ئەوە دیاری ماڵئاوایی دەدەن
\q2 بە مۆرەشەت گەت.
\q1 یارمەتی لە شارۆچکەکانی ئەکزیڤەوە\f + \fr 1:14 \ft ئەکزیڤ واتا هەڵخەڵەتاندنە.‏\f* جێی متمانە نییە
\q2 بۆ پاشاکانی ئیسرائیل.
\q1 
\v 15 داگیرکەرتان دەهێنمە سەر،
\q2 ئەی دانیشتووانی مارێشا\f + \fr 1:15 \ft لە زمانی عیبریدا دەنگی (مارێشا) نزیکەی وشەیەکی دیکە کە واتا (داگیرکەر).‏\f*،
\q1 ئەوەی شکۆی ئیسرائیلە
\q2 دێتە عەدولام.
\q1 
\v 16 سەرتان بتاشن بۆ شیوەنگێڕان
\q2 لەسەر منداڵە نازدارەکانتان،
\q1 وەک سیسارکە کەچەڵ بن و مووتان بە سەرەوە نەبێ،
\q2 چونکە منداڵی ئێوە بە دیل گیراوی ڕاپێچ دەکەن.
\c 2
\s1 پیلانی مرۆڤ و پلانی خودا
\q1 
\v 1 قوڕبەسەر ئەوانەی بیر لە بەدکاری دەکەنەوە و
\q2 لەناو نوێنەکانیان پیلان بۆ خراپە دادەڕێژن!
\q1 کاتێک ڕووناکی بەیان دێت جێبەجێی دەکەن
\q2 چونکە لە دەستیان دێ.
\q1 
\v 2 چاویان لە کێڵگەکانە و داگیری دەکەن،
\q2 هەروەها لە ماڵەکانە و دەستی بەسەردا دەگرن.
\q1 دەست بەسەر ماڵی خەڵکدا دەگرن،
\q2 تاکو لە میراتەکەی بێبەشی بکەن.
\p 
\v 3 لەبەر ئەوە یەزدان ئەمە دەفەرموێت:
\q1 «ئەوەتا من سەبارەت بەم گەلە بیر لە بەڵا دەکەمەوە،
\q2 ئەوەی ناتوانن ملتانی لەبەر لابدەن.
\q1 بە لووتبەرزییەوە هاتوچۆ ناکەن،
\q2 چونکە کاتی خراپە دەبێت.
\q1 
\v 4 لەو ڕۆژەدا پەندتان بەسەردا هەڵدەدرێت و
\q2 شیوەن دەگێڕن و دەگوترێ:
\q1 ”بە تەواوی وێران بووین،
\q2 بەشی گەلەکەی منی گۆڕیوە.
\q1 چۆن لێی داماڵین!
\q2 کێڵگەکانی ئێمەی بەسەر ناپاکەکاندا دابەش کرد؟“»
\b
\q1 
\v 5 لەبەر ئەوە لەنێو کۆمەڵی یەزداندا کەست نابێت
\q2 بە گوریسی پێوانە خاکەکە بە تیروپشک دابەش بکات.
\s1 پێغەمبەرانی درۆزن
\q1 
\v 6 پێغەمبەرەکانیان دەڵێن: «پێشبینی مەکەن!
\q2 دەربارەی ئەم شتانە پێشبینی مەکەن،
\q2 ڕیسواییمان بەسەردا نایەت.»
\q1 
\v 7 ئەی بنەماڵەی یاقوب، ئایا دروستە خەڵک بپرسێت:
\q2 «ئایا یەزدان ئارامی لەبەر دەبڕێت؟
\q2 یان ئەمە کارەکانی ئەوە؟»
\b
\q1 «ئایا وشەکانم باش نین
\q2 بۆ ئەوانەی بە ڕێکی هاتوچۆ دەکەن؟
\q1 
\v 8 بەڵام لەم دواییەدا گەلەکەم
\q2 بۆ دوژمنایەتی ڕاپەڕین.
\q1 ئێوە کراس و کەوا پێکەوە دادەماڵن
\q2 لەوانەی بە دڵنیاییەوە تێدەپەڕن،
\q2 وەک ئەوانەی لە جەنگ دەگەڕێنەوە.
\q1 
\v 9 ژنانی گەلەکەم دەردەکەن
\q2 لەو ماڵانەیان کە دڵیان پێی خۆشە.
\q1 بەرەکەتەکەم لە منداڵەکانیان
\q2 بۆ هەتاهەتایە دەبەیت.
\q1 
\v 10 هەستن و بڕۆن!
\q2 چونکە ئەمە شوێنی حەسانەوە نییە،
\q1 لەبەر ئەوەی گڵاو بوو،
\q2 وێران بوو، وێرانبوونێکی خراپ.
\q1 
\v 11 ئەگەر درۆزن و چەواشەکار بێت و بڵێت:
\q2 ”پێشبینیت بۆ دەکەم، سەبارەت بە شەراب و مەی زۆر دەبێت،“
\q2 ئەوا ئەو دەبێتە پێغەمبەری ئەم گەلە!
\s1 بەڵێنی ڕزگاری
\q1 
\v 12 «ئەی یاقوب، بە دڵنیایی بە تەواوی کۆتدەکەمەوە،
\q2 بە دڵنیایی پاشماوەی ئیسرائیل خڕدەکەمەوە.
\q1 یەکیاندەخەم وەک ڕانە مەڕی ناو پشتیر\f + \fr 2:12 \ft پشتیر: گەوڕ، شوێنێکی تایبەت بووە بە پەروەردەکردنی ئاژەڵ.‏\f*،
\q2 وەک ڕانێک لەناو لەوەڕگاکەی،
\q2 ئەم شوێنە پڕ لە خەڵک دەبێت.
\q1 
\v 13 کەلێندڕ پێشیان دەکەوێت،
\q2 دەروازەکە دەشکێنن و لێی تێدەپەڕن و دێنە دەرەوە.
\q1 پاشاکەشیان لەپێشیانەوە تێدەپەڕێت،
\q2 یەزدانیش پێشەنگیانە.»
\c 3
\s1 سەرزەنشتی ڕابەران و پێغەمبەران
\p 
\v 1 گوتم:
\q1 «ئەی سەرکردەکانی یاقوب،
\q2 ئەی ڕابەرانی بنەماڵەی ئیسرائیل، گوێ بگرن.
\q1 ئایا بۆ ئێوە نییە زانینی دادپەروەری؟
\q2 
\v 2 ئێوە کە ڕقتان لە چاکەیە و حەز لە خراپە دەکەن،
\q1 پێستی گەلەکەم دادەماڵن و
\q2 گۆشتیان لە ئێسکەکانیان جیا دەکەنەوە؛
\q1 
\v 3 ئێوە کە گۆشتی گەلەکەم دەخۆن،
\q2 کەوڵیان دەکەن،
\q2 ئێسکیان دەشکێنن،
\q1 پارچەپارچەیان دەکەن وەک بۆ ناو مەنجەڵ،
\q2 وەک گۆشتی ناو تاوە.»
\b
\q1 
\v 4 ئینجا هاوار بۆ یەزدان دەکەن،
\q2 بەڵام وەڵامیان ناداتەوە.
\q1 لەو کاتەدا ڕووی خۆی لێیان دەشارێتەوە،
\q2 لەبەر ئەو خراپانەی کردیان.
\p 
\v 5 یەزدان ئەمە دەفەرموێت:
\q1 «سەبارەت بە پێغەمبەرەکان،
\q2 ئەوانەی گەلەکەم گومڕا دەکەن،
\q1 بانگەوازی ئاشتی دەکەن
\q2 بۆ ئەوانەی تێریان دەکەن،
\q1 بەڵام جەنگ لە دژی ئەوانە بەرپا دەکەن
\q2 کە تێریان ناکەن.
\q1 
\v 6 لەبەر ئەوە شەوێکتان بەسەردا دێت کە هیچ بینینێکتان بۆ ئاشکرا ناکرێت،
\q2 تاریکییەکی بێ فاڵگرتنەوە.
\q1 خۆر لە پێغەمبەرەکان ئاوا دەبێت،
\q2 ڕۆژیان لێ تاریک دادێت.
\q1 
\v 7 پێشبینیکەران شەرمەزار دەبن،
\q2 فاڵگرەوەکان ڕیسوا دەبن،
\q1 هەموویان چاوەڕوویان نەماوە،
\q2 چونکە خودا وەڵامیان ناداتەوە.»
\b
\q1 
\v 8 بەڵام سەبارەت بە من، پڕم لە هێز،
\q2 پڕ لە ڕۆحی یەزدان،
\q2 لە دادپەروەری و پاڵەوانیێتی،
\q1 تاکو یاخیبوونەکەی یاقوب بە خۆی ڕابگەیەنم،
\q2 بە ئیسرائیلیش گوناهەکەی.
\b
\q1 
\v 9 ئەی سەرکردەکانی بنەماڵەی یاقوب،
\q2 ڕابەرانی بنەماڵەی ئیسرائیل، گوێ لەمە بگرن،
\q1 ئێوە کە قێزتان لە دادپەروەری دەبێتەوە و
\q2 هەموو ڕاستییەک خواروخێچ دەکەن،
\q1 
\v 10 ئێوە سییۆن بە خوێن بنیاد دەنێن و
\q2 ئۆرشەلیم بە ستەم.
\q1 
\v 11 ڕابەرەکانی بە بەرتیل دادوەری دەکەن،
\q2 کاهینەکانی بە کرێ خەڵکی فێردەکەن،
\q2 پێغەمبەرەکانی بە پارە فاڵ دەگرنەوە.
\q1 لەگەڵ ئەوەشدا پشت بە یەزدان دەبەستن و دەڵێن:
\q2 «ئایا یەزدان لەنێوانماندا نییە؟
\q2 هیچ بەڵایەکمان بەسەردا نایەت.»
\q1 
\v 12 لەبەر ئەوە بەهۆی ئێوەوە
\q2 سییۆن وەک کێڵگە دەکێڵدرێت،
\q1 ئۆرشەلیم کاول دەبێت،
\q2 گردەکەی پەرستگاش دەبێتە دارستانێکی بێ کەڵک.
\c 4
\s1 کێوی یەزدان
\p 
\v 1 لە ڕۆژانی کۆتاییدا،
\q1 کێوی پەرستگای یەزدان
\q2 لەسەر لووتکەی چیاکان جێگیر دەبێت،
\q1 بەسەر گردەکانەوە بەرز دەبێتەوە و
\q2 گەلان بە لێشاو بەرەو لای ئەو دەچن.
\p 
\v 2 زۆرێک لە نەتەوەکان بەڕێ دەکەون و دەڵێن:
\q1 «وەرن با بەرەو کێوی یەزدان سەربکەوین،
\q2 بۆ ماڵەکەی خودای یاقوب.
\q1 فێری ڕێگاکانی خۆیمان دەکات،
\q2 بۆ ئەوەی بە ڕێچکەی ئەودا بڕۆین.»
\q1 فێرکردن لە سییۆنەوە دەردەچێت،
\q2 پەیامی یەزدانیش لە ئۆرشەلیمەوە.
\q1 
\v 3 لەنێو چەندین گەل دادوەری دەکات،
\q2 ناوبژی بۆ نەتەوە بەهێز و دوورەکان دەکات،
\q1 شمشێرەکانیان دەکوتنەوە و دەیکەنە گاسن،
\q2 ڕمەکانیشیان دەکەنە داس.
\q1 هیچ نەتەوەیەک شمشێر لە نەتەوەیەکی دیکە هەڵناکێشێت،
\q2 چیتر فێری جەنگ نابن.
\q1 
\v 4 هەریەکە و لەژێر ڕەزەمێوەکەی و
\q2 لەژێر دار هەنجیرەکەی دادەنیشێت،
\q1 کەس نایترسێنێت،
\q2 چونکە یەزدانی سوپاسالار فەرموویەتی.
\q1 
\v 5 هەر گەلێک ڕێگای خۆی دەگرێتەبەر،
\q2 هەریەکە و بە ناوی خوداوەندەکانی خۆیەوە؛
\q1 ئێمەش بە ناوی یەزدانی پەروەردگارمانەوە
\q2 بۆ هەتاهەتایە و هەتاسەر ڕێگا دەگرینەبەر.
\s1 پلانی یەزدان
\p 
\v 6 یەزدان دەفەرموێت:
\q1 «لەو ڕۆژەدا شەلەکان کۆدەکەمەوە و
\q2 ڕاپێچکراوەکان خڕدەکەمەوە،
\q2 هەروەها ئەوانەی سزام داون.
\q1 
\v 7 شەلەکان دەکەمە پاشماوە،
\q2 دوورخراوەکانیش دەکەمە نەتەوەیەکی بەهێز.
\q1 یەزدانیش لە کێوی سییۆن پاشایەتییان دەکات
\q2 لەو کاتەوە و بۆ هەتاهەتایە.
\q1 
\v 8 تۆش ئەی تاوەری پاسەوانی مێگەل،
\q2 ئەی قەڵای سییۆنی کچ،
\q1 هەروەک پێشتر دەسەڵاتت بۆ دەگەڕێتەوە،
\q2 پاشایەتی ئۆرشەلیمی کچ.»
\b
\q1 
\v 9 ئێستا بۆچی بە هاوارەوە دەگریت؟
\q2 بۆچی وەک ژانی منداڵبوون ژانت گرتووە؟
\q1 ئایا پاشات نییە،
\q2 یان ڕاوێژکارت مردووە؟
\q1 
\v 10 ئەی سییۆنی کچ، لەبەر ژان بگەوزێ
\q2 وەک ژنی ژانگرتوو،
\q1 چونکە ئێستا لە شار دێیتە دەرەوە و
\q2 لە دەشتودەر چادر هەڵدەدەیت.
\q1 دەچیتە بابل،
\q2 لەوێ دەرباز دەکرێیت.
\q1 لەوێ یەزدان دەتکڕێتەوە
\q2 لە دەستی دوژمنەکانت.
\b
\q1 
\v 11 بەڵام ئێستا، چەندین نەتەوە
\q2 لە دژی تۆ کۆدەبنەوە.
\q1 دەڵێن: «با گڵاو بێت،
\q2 با بە دیمەنی سییۆن دڵخۆش بین.»
\q1 
\v 12 بەڵام ئەوان نازانن
\q2 بیرکردنەوەی یەزدان چییە،
\q1 هەروەها لە پلانی ئەو تێناگەن،
\q2 چونکە وەک مەڵۆی گەنم بۆ سەر جۆخین کۆی کردنەوە.
\q1 
\v 13 «ئەی سییۆنی کچ، هەستە و پێشێلی بکە،
\q2 چونکە قۆچی ئاسنینت پێ دەبەخشم.
\q1 سمی بڕۆنزت پێ دەبەخشم و
\q2 چەندین گەل تەفروتونا دەکەیت.»
\q1 دەستکەوتی ناڕەوایی ئەوان بۆ یەزدان تەرخان دەکەیت،
\q2 سامانیان بۆ پەروەردگاری هەموو جیهان.
\c 5
\s1 بەڵێنی دەرکەوتنی فەرمانڕەوایەک لە بێت‌لەحمەوە
\q1 
\v 1 ئەی شاری سوپاکان، سوپاکانی خۆت کۆبکەرەوە،
\q2 چونکە گەمارۆ دراوین.
\q1 بە گۆچان لە ڕوومەتی
\q2 ڕابەری ئیسرائیل دەدەن.
\b
\q1 
\v 2 «بەڵام تۆ ئەی بێت‌لەحمی ئەفراتە،
\q2 هەرچەندە لەنێو شارۆچکەکانی\f + \fr 5:2 \ft یان: هۆزەکانی یەهودا.‏\f* یەهودا بچووکیت،
\q1 بەڵام یەکێک لە تۆوە بۆ من دەردەکەوێت
\q2 ئەوەی دەبێتە فەرمانڕەوای ئیسرائیل،
\q1 ڕەچەڵەکی لە دێرزەمانەوەیە،
\q2 لە ئەزەلەوەیە.»
\b
\q1 
\v 3 لەبەر ئەوە یەزدان گەلەکەی خۆی ڕادەستی دوژمن دەکات
\q2 هەتا ئەو کاتەی ئەوەی ژانی گرتووە منداڵی دەبێت،
\q1 پاشماوەی براکانیشی دەگەڕێنەوە
\q2 بۆ لای نەوەی ئیسرائیل.
\b
\q1 
\v 4 جا دەوەستێت و شوانایەتی گەلەکەی دەکات
\q2 بە هێزی یەزدان،
\q2 بە باڵادەستیی ناوی یەزدانی پەروەردگاری خۆی.
\q1 جا بە ئاسوودەیی دەژین،
\q2 چونکە لەو کاتە مەزنایەتی دەگاتە ئەوپەڕی زەوی.
\b
\q1 
\v 5 ئەو دەبێتە ئاشتی ئێمە،
\q2 کاتێک ئاشور هێرش بکاتە سەر خاکەکەمان و
\q2 پێ بنێتە ناو قەڵاکانمان.
\q1 حەوت شوانی لەسەر دادەنێین،
\q2 لەگەڵ هەشت میر.
\q1 
\v 6 بە شمشێر شوانایەتی خاکی ئاشور دەکەن و
\q2 خاکی نەمرودیش بە شمشێری هەڵکێشراو.
\q1 بەڵام لە ئاشور دەربازمان دەکات،
\q2 کاتێک هێرش دەکاتە سەر خاکەکەمان و
\q2 کاتێک پێ دەنێتە سنوورەکانمان.
\b
\q1 
\v 7 پاشماوەی یاقوب لەنێو چەندین گەل دەبێت،
\q2 وەک شەونم لەلایەن یەزدانەوە،
\q1 وەک بارانی بە لێزمەی سەر گژوگیا،
\q2 ئەوەی چاوەڕوانی مرۆڤ ناکات و
\q2 بۆ ئادەمیزاد ناوەستێت.
\q1 
\v 8 پاشماوەی یاقوب لەنێو نەتەوەکان،
\q2 لەنێو چەندین گەل،
\q1 وەک شێر لەنێو دڕندەکانی دارستاندا،
\q2 وەک جوانە شێر لەنێو ڕانە مەڕدا،
\q1 ئەوەی بپەڕێتەوە دەیشێلێت و پەلاماری دەدات،
\q2 کەس نییە لە دەستی دەربازی بکات.
\q1 
\v 9 دەستت بەسەر ناحەزانت زاڵ دەبێت و
\q2 هەموو دوژمنەکانت لەناودەچن.
\p 
\v 10 یەزدان دەفەرموێت:
\q1 «لەو ڕۆژەدا ئەسپەکانت لەنێو خۆت لەناودەبەم و
\q2 گالیسکەکانت تێک دەشکێنم.
\q1 
\v 11 شارەکانی خاکەکەت لەناودەبەم و
\q2 هەموو قەڵاکانت تێکدەدەم.
\q1 
\v 12 ئەو جادووگەرییەی کە دەیکەیت لەناوی دەبەم و
\q2 لەمەودوا ناتوانیت نوشتە بکەیت.
\q1 
\v 13 بتە داتاشراوەکانت لەناودەبەم و
\q2 لەگەڵ هەموو بەردە تەرخانکراوەکانت\f + \fr 5:13 \ft بەردی بە ستوونی دانراو بۆ پەرستن. بڕوانە دواوتار 16‏:21‏-22.‏\f* لە ناوەڕاستت،
\q1 ئیتر کڕنۆش نابەیت
\q2 بۆ دەستکردی دەستەکانت.
\q1 
\v 14 ستوونە ئەشێراکانت\f + \fr 5:14 \ft ستوونە ئەشێرا: هێمای خواژنە. بڕوانە \xt یەکەم پاشایان 11‏:5‏\xt*\ft ‏.‏\f* لەنێوتدا هەڵدەکێشم و
\q2 شارەکانت وێران دەکەم.
\q1 
\v 15 بە تووڕەیی و هەڵچوونەوە تۆڵە دەکەمەوە
\q2 لەو گەلانەی گوێڕایەڵی من نەبوون.»
\c 6
\s1 سکاڵای یەزدان لە دژی ئیسرائیل
\p 
\v 1 گوێ بگرن لەوەی یەزدان دەفەرموێت:
\q1 «هەستە، بڕۆ لەلای چیاکانەوە سکاڵا بکە،
\q2 با گردەکان گوێیان لێبێت کە چی دەڵێیت.
\b
\q1 
\v 2 «ئەی چیاکان، گوێ لە سکاڵای یەزدان بگرن،
\q2 ئەی بناغە هەمیشەییەکانی زەوی، ئێوەش گوێ بگرن!
\q1 چونکە سکاڵای یەزدان لە گەلەکەیەتی،
\q2 داواکەی لە دژی ئیسرائیلە.
\b
\q1 
\v 3 «ئەی گەلەکەم، چیم لێت کردووە؟
\q2 بە چی نیگەرانم کردوویت؟ وەڵامم بدەوە!
\q1 
\v 4 من لە خاکی میسرەوە دەرمهێنایت،
\q2 لە خاکی کۆیلایەتی تۆم کڕییەوە.
\q1 من موسام بۆ ناردی ڕابەرایەتیت بکات،
\q2 هەروەها هارون و مریەمیش.
\q1 
\v 5 ئەی گەلەکەم، بیهێنەرەوە یادت
\q2 بالاقی پاشای مۆئاب پیلانی چی گێڕا و
\q2 بەلعامی کوڕی بەعۆر چی وەڵام دایەوە.
\q1 گەشتەکەت لە شەتیمەوە هەتا گلگال بهێنەرەوە یادت،
\q2 تاکو کارە ڕاستودروستەکانی یەزدان بزانیت.»
\b
\q1 
\v 6 بە چی بچمە بەردەمی یەزدان و
\q2 بۆ خودای پایەبەرز بچەمێمەوە؟
\q1 ئایا بە قوربانی سووتاندن بچمە بەردەمی،
\q2 بە گوێرەکەی تەمەن یەک ساڵە؟
\q1 
\v 7 ئایا یەزدان بە هەزاران بەران و
\q2 بە دەیان هەزار ڕووبار لە ڕۆن ڕازی دەبێت؟
\q1 ئایا نۆبەرەکەم لە جیاتی یاخیبوونەکەم بدەم،
\q2 بەری لەشم لە جیاتی گوناهی خۆم؟
\q1 
\v 8 ئەی مرۆڤ، یەزدان پێی ڕاگەیاندیت کە چی چاکە و
\q2 داوای چیت لێدەکات:
\q1 دادوەری بەجێبهێنە و حەزت لە خۆشەویستی نەگۆڕ بێت و
\q2 بە بێفیزی لەگەڵ خوداکەت هاتوچۆ بکەیت.
\s1 تاوان و سزای ئیسرائیل
\q1 
\v 9 ئەگەر ئێوە دانان لە ناوی خودا بترسن!
\q2 دەنگی یەزدان بانگەواز بۆ شارەکە دەکات:
\q2 «ئەی گەل و ئەوانەی لە شار کۆدەبنەوە، گوێ بگرن!
\q1 
\v 10 ئەی ماڵی خراپەکار، ئایا هێشتا گەنجینەی داهاتی ناڕەواییتان لەبیر دەکەم؟
\q2 ئایا ئێفەی\f + \fr 6:10 \ft ئێفە یەکەیەکی کێشە، بیست و دوو لیتر بوو.‏\f* ناتەواو کە نەفرەت لێکراوە لەیادی دەکەم؟
\q1 
\v 11 ئایا ئەوانەی تەرازوویان درۆیە بێتاوانیان دەکەم،
\q2 ئەوانەی فێڵ لە توورەکەی کێش دەکەن؟
\q1 
\v 12 دەوڵەمەندەکانی ستەمکارن،
\q2 دانیشتووانەکەشی قسەی درۆ دەکەن و
\q2 بە زمانیان فێڵ دەکەن.
\q1 
\v 13 لەبەر ئەوە خەریکم سزاتان دەدەم،
\q2 لەبەر گوناهەکانتان وێرانتان دەکەم.
\q1 
\v 14 ئێوە دەخۆن و تێر نابن،
\q2 گەدەتان هەردەم بەتاڵ دەبێت.
\q1 ئەمبار دەکەن، بەڵام هیچ نامێنێتەوە،
\q2 چونکە ئەوەی مایەوە دەیدەمە شمشێر.
\q1 
\v 15 ئێوە دەچێنن و نادورنەوە،
\q2 زەیتوون دەگوشن و بە ڕۆنەکەی خۆتان چەور ناکەن،
\q2 ترێ دەگوشن و لە شەرابەکەی ناخۆنەوە،
\q1 
\v 16 چونکە فەرزەکانی عۆمری\f + \fr 6:16 \ft عۆمری باوکی ئەحاڤ بوو، هەردووکیان گەلی خودایان بۆ بتپەرستی هاندا. بڕوانە 1 پاشایان 16‏:23‏-26.‏\f* و
\q2 هەموو نەریتەکانی بنەماڵەی ئەحاڤتان بەجێهێناوە و
\q2 ڕێگای ڕاوێژەکانی ئەوانتان گرتووەتەبەر.
\q1 لەبەر ئەوە وێرانتان دەکەم و
\q2 دانیشتووانەکەت دەکەمە مایەی گاڵتەجاڕی و
\q2 تانە و تەشەری نەتەوەکان.»
\c 7
\s1 ناخۆشی ئیسرائیل
\q1 
\v 1 قوڕبەسەرم!
\q1 وەک کەسێکم لێهات لە هاویندا بەر بڕنێت،
\q2 وەک چنینەوەی ڕەزەمێو.
\q1 نە هێشووە ترێ بۆ خواردن هەیە،
\q2 نە هەنجیری یەکەم بەر کە نەوسم ئارەزووی دەکات.
\q1 
\v 2 خواناس لە خاک لەناوچوو،
\q2 کەسێکی سەرڕاست لەنێو خەڵکدا نەماوە.
\q1 هەموو بۆ خوێنڕشتن خۆیان ماتداوە،
\q2 هەریەکە و براکەی خۆی بە تۆڕ ڕاودەکات.
\q1 
\v 3 بۆ خراپە هەردوو دەستەکانیان چالاکن،
\q2 میر داوای دیاری دەکات،
\q1 دادوەر بەرتیل وەردەگرێت،
\q2 بەهێز بە ئارەزووی خۆی قسە دەکات
\q2 پێکەوە دەیڕێسن.
\q1 
\v 4 چاکترینیان وەک وشترالووکە و
\q2 ڕاستترینیان وەک پەرژینی دڕکە.
\q1 ڕۆژی سزادانی خودا بۆ تۆ هات،
\q2 ئەو ڕۆژەی کە چاودێرەکانت\f + \fr 7:4 \ft مەبەست لە پێغەمبەرەکان.‏\f* هاوار دەکەن بۆ ئاگادارکردنەوە.
\q2 ئێستا کاتی سەرلێشێواندنی ئێوەیە.
\q1 
\v 5 متمانە بە برادەر مەکە و
\q2 پشت بە دۆست مەبەستە.
\q1 نهێنیت بپارێزە
\q2 تەنانەت لە ژنەکەشت کە لە باوەشت پاڵکەوتووە،
\q1 
\v 6 چونکە کوڕ سووکایەتی بە باوکی دەکات،
\q2 کچ لە دایکی ڕاستدەبێتەوە،
\q1 بووک لە خەسووی؛
\q2 دوژمنی مرۆڤ لە خانەوادەکەی خۆی دەبێت.
\b
\q1 
\v 7 بەڵام من چاوم لەسەر یەزدان دەبێت،
\q2 چاوەڕوانی خودای ڕزگاریم دەکەم،
\q2 خودام گوێم لێ دەگرێت.
\s1 ئیسرائیل هەڵدەستێتەوە
\q1 
\v 8 ئەی دوژمنەکەم، بە نسکۆی من دڵخۆش نەبیت!
\q2 چونکە ئەگەر بکەوم، هەڵدەستمەوە،
\q1 ئەگەر لە تاریکیدا دانیشم،
\q2 یەزدان ڕووناکییە بۆم.
\q1 
\v 9 لەبەر ئەوەی لە دژی ئەو گوناهم کرد،
\q2 بەرگەی تووڕەیی یەزدان دەگرم،
\q1 هەتا بەرگری لە داواکەم دەکات و
\q2 مافی من دێتە دی.
\q1 دەمهێنێتە دەرەوە بۆ ناو ڕووناکی،
\q2 ڕاستودروستی ئەو دەبینم.
\q1 
\v 10 ئینجا دوژمنەکەم تەماشا دەکات و
\q2 شەرمەزاری دایدەپۆشێت،
\q1 ئەوەی پێی دەگوتم:
\q2 «کوا یەزدانی پەروەردگارت؟»
\q1 چاوەکانم تەماشای کەوتنی دەکەن،
\q2 تەنانەت ئێستاش دەشێلرێت
\q2 وەک قوڕی شەقامەکان.
\b
\q1 
\v 11 ڕۆژی بنیادنانی دیوارەکانت دێت،
\q2 ڕۆژی فراوانکردنی سنوورەکانت.
\q1 
\v 12 لەو ڕۆژەدا خەڵک دێنە لات،
\q2 لەلای ئاشور و لە شارەکانی میسرەوە،
\q1 تەنانەت لە میسرەوە هەتا فورات
\q2 لە دەریاوە بۆ دەریا و
\q2 لە چیاوە بۆ چیا.
\q1 
\v 13 زەوی لەبەر دانیشتووانەکەی وێران دەبێت،
\q2 بەهۆی کردەوەکانیان.
\s1 نوێژ و ستایشکردن
\q1 
\v 14 بە گۆچانەکەت شوانایەتی گەلەکەت بکە،
\q2 مێگەلی میراتەکەت،
\q1 ئەوەی بە تەنها لە دارستان نیشتەجێیە
\q2 لە ناوەڕاستی ڕەزەکان.
\q1 با لە باشان و گلعاد بلەوەڕێن
\q2 وەک ڕۆژگاری کۆن.
\b
\q1 
\v 15 «وەک ڕۆژانی هاتنەدەرەوەت لە خاکی میسر،
\q2 کاری سەرسوڕهێنەریان نیشان دەدەم.»
\b
\q1 
\v 16 نەتەوەکان تەماشا دەکەن و شەرمەزار دەبن،
\q2 سەرباری هەموو پاڵەوانییەتییەکەیان.
\q1 دەست دەخەنە سەر دەمیان
\q2 گوێیان کەڕ دەبێت.
\q1 
\v 17 وەک مار خۆڵ دەلێسنەوە،
\q2 وەک خشۆکەکانی زەوی.
\q1 بە لەرزەوە لە قەڵاکانیان دێنە دەرەوە،
\q2 بۆ لای یەزدانی پەروەردگارمان دێن و دەتۆقن،
\q2 لە تۆ دەترسن.
\q1 
\v 18 کێ خودایەکی وەک تۆیە،
\q2 کە لە تاوان دەبوورێت و
\q2 لە یاخیبوونی پاشماوەی گەلەکەت خۆشدەبێت؟
\q1 هەتاسەر تووڕەیی خۆت هەڵناگریت،
\q2 چونکە بە خۆشەویستییە نەگۆڕەکەت دڵخۆشیت.
\q1 
\v 19 دەگەڕێیتەوە و بەزەییت پێماندا دێتەوە،
\q2 تاوانەکانمان دەخەیتە ژێر پێتەوە و
\q2 هەموو گوناهەکانمان فڕێدەدەیتە ناو قووڵایی دەریا.
\q1 
\v 20 دڵسۆزی بۆ یاقوب پیشان دەدەیت،
\q2 خۆشەویستی نەگۆڕ بۆ ئیبراهیم،
\q1 ئەوەی سوێندت بۆ باوباپیرانمان خوارد
\q2 هەروەک ڕۆژگاری کۆن.
