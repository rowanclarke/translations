\v 2 \w a|strong="G2596"\w* \w la|strong="G3588"\w* hermana Apia, \w a|strong="G2596"\w* Arquipo, \w nuestro|strong="G2249"\w* \w compañero|strong="G4961"\w* \w de|strong="G2596"\w* milicia, \w y|strong="G2532"\w* \w a|strong="G2596"\w* \w la|strong="G3588"\w* \w iglesia|strong="G1577"\w* \w que|strong="G3588"\w* \w está|strong="G3588"\w* \w en|strong="G2596"\w* \w tu|strong="G4771"\w* \w casa|strong="G3624"\w*.
\v 3 \w Gracia|strong="G5485"\w* a ustedes \w y|strong="G2532"\w* \w paz|strong="G1515"\w* de \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Padre|strong="G3962"\w*, \w y|strong="G2532"\w* del \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w*.
\s1 Gracias a Dios por Filemón
\p 
\v 4 Doy \w gracias|strong="G2168"\w* \w a|strong="G1909"\w* \w mi|strong="G3588"\w* \w Dios|strong="G2316"\w* \w siempre|strong="G3842"\w* \w que|strong="G3588"\w* \w me|strong="G1473"\w* acuerdo \w de|strong="G1909"\w* ti \w en|strong="G1909"\w* mis conversaciones \w con|strong="G1909"\w* \w Dios|strong="G2316"\w*,
\v 5 \w pues|strong="G2532"\w* escucho \w de|strong="G1519"\w* \w tu|strong="G4771"\w* amor \w y|strong="G2532"\w* \w de|strong="G1519"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w que|strong="G3588"\w* \w tienes|strong="G2192"\w* \w hacia|strong="G4314"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w* \w Jesús|strong="G2424"\w* \w y|strong="G2532"\w* \w para|strong="G1519"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* santos.
\v 6 \add Ruego\add* \w que|strong="G3588"\w*, \w por|strong="G1722"\w* medio \w del|strong="G3588"\w* \w conocimiento|strong="G1922"\w* \w de|strong="G1722"\w* \w todo|strong="G3956"\w* \w lo|strong="G3588"\w* bueno \w de|strong="G1722"\w* ustedes \w en|strong="G1722"\w* \w Cristo|strong="G5547"\w*, \w la|strong="G3588"\w* \w participación|strong="G2842"\w* \w de|strong="G1722"\w* \w tu|strong="G4771"\w* \w fe|strong="G4102"\w* \w sea|strong="G1096"\w* \w eficaz|strong="G1756"\w*.
\v 7 \w Porque|strong="G1063"\w* \w tuvimos|strong="G2192"\w* \w mucho|strong="G4183"\w* \w gozo|strong="G5479"\w* \w y|strong="G2532"\w* \w consolación|strong="G3874"\w* \w en|strong="G1909"\w* \w tu|strong="G4771"\w* amor, \w pues|strong="G1063"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1909"\w* ti, hermano, fueron refrescados \w los|strong="G3588"\w* corazones \w de|strong="G1909"\w* \w los|strong="G3588"\w* santos.
\s1 Un inútil convertido en útil
\p 
\v 8 \w Por|strong="G1722"\w* tanto, \w aunque|strong="G1722"\w* \w tengo|strong="G2192"\w* \w mucho|strong="G4183"\w* atrevimiento \w en|strong="G1722"\w* \w Cristo|strong="G5547"\w* \w para|strong="G1722"\w* mandarte \w lo|strong="G3588"\w* \w que|strong="G3588"\w* es apropiado,
\v 9 \w más|strong="G1161"\w* \w bien|strong="G3123"\w* \w por|strong="G1223"\w* \w causa|strong="G1223"\w* \w de|strong="G1223"\w* \w mi|strong="G3588"\w* amor \add hacia ti, \add*te \w exhorto|strong="G3870"\w*, \w por|strong="G1223"\w* ser \w como|strong="G5613"\w* \w soy|strong="G1510"\w*, \w Pablo|strong="G3972"\w*, \w ya|strong="G2532"\w* anciano, \w y|strong="G2532"\w* \w ahora|strong="G3570"\w* \w también|strong="G2532"\w* \w prisionero|strong="G1198"\w* \w de|strong="G1223"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w*,
\v 10 \w te|strong="G4771"\w* \w ruego|strong="G3870"\w* \w por|strong="G1722"\w* \w mi|strong="G1699"\w* \w hijo|strong="G5043"\w* \w Onésimo|strong="G3682"\w*, \w a|strong="G1722"\w* \w quien|strong="G3739"\w* \w engendré|strong="G1080"\w* \w en|strong="G1722"\w* \w las|strong="G3588"\w* \w prisiones|strong="G1199"\w*.
\p 
\v 11 \w En|strong="G3588"\w* \w otro|strong="G3739"\w* tiempo \w él|strong="G3588"\w* \w te|strong="G4771"\w* fue inútil, \w pero|strong="G1161"\w* \w ahora|strong="G3570"\w* nos \w es|strong="G3739"\w* \w útil|strong="G2173"\w* \w a|strong="G1161"\w* \w ti|strong="G3739"\w* \w y|strong="G2532"\w* \w a|strong="G1161"\w* \w mí|strong="G3588"\w*.
\v 12 \w Te|strong="G4771"\w* \w lo|strong="G3588"\w* envío \w de|strong="G3588"\w* regreso, a \w él|strong="G3588"\w*, \w es|strong="G3778"\w* decir, \w al|strong="G3588"\w* objeto \w de|strong="G3588"\w* \w mi|strong="G1699"\w* afecto.
\v 13 \w Yo|strong="G1473"\w* \w quería|strong="G1014"\w* retenerlo \w conmigo|strong="G1722"\w*, \w a|strong="G4314"\w* fin \w de|strong="G1722"\w* \w que|strong="G3588"\w* \w me|strong="G1683"\w* sirviera \w por|strong="G1722"\w* \w ti|strong="G3739"\w* \w en|strong="G1722"\w* \w las|strong="G3588"\w* \w prisiones|strong="G1199"\w* \w de|strong="G1722"\w* \w las|strong="G3588"\w* Buenas Noticias.
\p 
\v 14 \w Pero|strong="G1161"\w* \w nada|strong="G3762"\w* \w quise|strong="G2309"\w* \w hacer|strong="G4160"\w* \w sin|strong="G5565"\w* \w tu|strong="G4771"\w* consentimiento, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w tu|strong="G4771"\w* \w bien|strong="G1161"\w* \w no|strong="G3361"\w* \w sea|strong="G3588"\w* \w como|strong="G5613"\w* \w por|strong="G2596"\w* medio \w de|strong="G2596"\w* presión, \w sino|strong="G1161"\w* \w de|strong="G2596"\w* libre voluntad.
\v 15 \w Porque|strong="G1063"\w* probablemente \w por|strong="G1223"\w* \w esto|strong="G3778"\w* \w se|strong="G4314"\w* apartó \w de|strong="G1223"\w* ti \w por|strong="G1223"\w* un \w tiempo|strong="G5610"\w*, \w a|strong="G4314"\w* fin \w de|strong="G1223"\w* \w que|strong="G2443"\w* lo recibas \w para|strong="G2443"\w* \w siempre|strong="G1223"\w*,
\v 16 \w ya|strong="G2089"\w* \w no|strong="G3756"\w* \w como|strong="G5613"\w* \w un|strong="G1722"\w* esclavo, \w sino|strong="G1161"\w* \w más|strong="G1161"\w* \w que|strong="G2532"\w* \w un|strong="G1722"\w* esclavo: \w como|strong="G5613"\w* hermano amado, especialmente \w para|strong="G1722"\w* mí, \w y|strong="G2532"\w* \w cuánto|strong="G4214"\w* \w más|strong="G1161"\w* \w para|strong="G1722"\w* ti, tanto \w en|strong="G1722"\w* \add el \add*cuerpo \w como|strong="G5613"\w* \w en|strong="G1722"\w* \add el\add* \w Señor|strong="G2962"\w*.
\p 
\v 17 Así \w que|strong="G3767"\w*, \w si|strong="G1487"\w* \w me|strong="G1473"\w* consideras un \w compañero|strong="G2844"\w*, recíbelo \w como|strong="G5613"\w* \w a|strong="G5613"\w* mí.
\v 18 \w Si|strong="G1487"\w* \w te|strong="G4771"\w* perjudicó en \w algo|strong="G5100"\w* \w o|strong="G2228"\w* \w te|strong="G4771"\w* \w debe|strong="G3784"\w*, cárgalo \w a|strong="G1161"\w* mi cuenta.
\v 19 \w Yo|strong="G1473"\w*, \w Pablo|strong="G3972"\w*, \w escribí|strong="G1125"\w* \w con|strong="G2532"\w* \w mi|strong="G1699"\w* \w mano|strong="G5495"\w*: ¡\w Yo|strong="G1473"\w* pagaré! \w Para|strong="G2443"\w* \w no|strong="G3361"\w* \w decirte|strong="G3004"\w* \w que|strong="G3754"\w* \w aun|strong="G2532"\w* \w tú|strong="G4771"\w* mismo \w te|strong="G4771"\w* \w debes|strong="G4359"\w* \w a|strong="G2443"\w* \w mí|strong="G1699"\w*.
\v 20 \w Sí|strong="G3483"\w*, hermano, \w que|strong="G3588"\w* \w yo|strong="G1473"\w* \w me|strong="G1473"\w* beneficie \w de|strong="G1722"\w* ti \w en|strong="G1722"\w* \add el\add* \w Señor|strong="G2962"\w*. Conforta \w mi|strong="G3588"\w* corazón \w en|strong="G1722"\w* \w Cristo|strong="G5547"\w*.
\v 21 \w Te|strong="G4771"\w* \w escribí|strong="G1125"\w* \w confiado|strong="G3982"\w* \w en|strong="G3588"\w* \w tu|strong="G4771"\w* \w obediencia|strong="G5218"\w*, \w cuando|strong="G1492"\w* entendí \w que|strong="G3754"\w* \w aun|strong="G2532"\w* \w harás|strong="G4160"\w* \w más|strong="G2532"\w* \w de|strong="G5228"\w* \w lo|strong="G3588"\w* \w que|strong="G3754"\w* \w digo|strong="G3004"\w*.
\p 
\v 22 \w Al|strong="G3588"\w* mismo tiempo, \w prepárame|strong="G2090"\w* \w alojamiento|strong="G3578"\w*, \w porque|strong="G1063"\w* \w espero|strong="G1679"\w* \w que|strong="G3754"\w* seré libertado \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1223"\w* \w las|strong="G3588"\w* conversaciones \w de|strong="G1223"\w* ustedes \w con|strong="G1223"\w* Dios.
\s1 Despedida
\p 
