\c 2  
\s1 Sayathae Soah Laitloeknah  
\p
\v 1 \w Tedae|strong="G1161"\w* \w pilnam|strong="G2992"\w* \w khuiah|strong="G1722"\w* laithae \w tonghma|strong="G5578"\w* rhoek \w khaw|strong="G2532"\w* \w om|strong="G1096"\w* uh. Te \w vanbangla|strong="G5613"\w* \w nangmih|strong="G5213"\w* \w khuiah|strong="G1722"\w* \w khaw|strong="G2532"\w* laithae \w saya|strong="G5572"\w* \w om|strong="G2071"\w* ni. \w Anih|strong="G3748"\w* tah \w pocinah|strong="G0684"\w* \w buhlaelh|strong="G0139"\w* neh ha \w hawn|strong="G3919"\w* ni. \w Amih|strong="G0848"\w* aka \w lai|strong="G0059"\w* \w boeikung|strong="G1203"\w* \w pataeng|strong="G2532"\w* \w te|strong="G3588"\w* a \w hnoel|strong="G0720"\w* uh tih \w pocinah|strong="G0684"\w* te \w amamih|strong="G1438"\w* soah\w pawk|strong="G5031"\w* a \w cuhu|strong="G1863"\w* sak uh.  
