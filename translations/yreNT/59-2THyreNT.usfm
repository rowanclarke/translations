\id 2TH - Yaouré NT [yre] -Côte d'Ivoire 1999 (web version -2013 bd) 
\h 2 Tesalonik 
\toc1 'Fluba "flizan nɛn Pɔl -a crɛn -tɛ Tesalonik 'nɔn lɛ 
\toc2 2 Tesalonik 
\toc3 2 Tes 
\mt2 'Fluba "flizan nɛn Pɔl -a crɛn -tɛ 
\mt1 Tesalonik 
\mt2 'nɔn lɛ 
\c 1  
\p  
\v 1 'An 'bɔ Pɔl 'lee Sila 'lee Timote 'bɛ 'fluba 'gʋɛ -a crɛn -tɛ. Kʋa crɛn -tɛ -leglizi nɛn Tesalonik bɛ -a -ji 'nɔn lɛ. Ka ya -kaa "tɩ Bali 'lee Minsan Zozi Crizi -le vɛ -a. Kʋ 'ka 'tɔ bo. 
\p  
\v 2 -Kaa "tɩ Bali 'lee Minsan Zozi Crizi 'o 'wee "yi 'lee 'wee -fʋdɩ -trɔɔ -nɔn 'cɛɛ. 
\s1 Zozi -taa 'trɛdanɔn 'le tin 'balɛ 
\p  
\v 3 'Kʋ "bʋɩ Zozinɔn, e ya "le 'kʋ Bali muo "fɔ tʋ pɛɛnɔn man 'cee "wɛan. Kɔɔ 'cee yi -tɛradɩ Zozi da ta a 'sʋnan, ɛn 'ka cin yɩdɩ "yi "a 'panan "da.  
\v 4 -Yee "wɛan kʋ 'ka 'sɩ -fɔa Bali -le -leglizi -mienun 'lɛ. Kʋa dra zɩ, kɔɔ minnun a 'tɛ 'panan 'ka da, ɛn ka ya 'ka yra yɩnan, 'pian ka yi -tɛra Zozi da, ɛn ka'a 'silɛ Bali -sru "dɩ. 
\p  
\v 5 'Wɩ zɩɛ -yɛɛ -kɔɔnman 'cɛɛ 'nan, Bali -taa tin 'balɛ 'e 'nɔan da. Kɔɔ 'ka yra nɛn ka cɩ -a yɩnan bɛ, -yɛɛ -kɔɔnman 'nan, Bali -taa 'ka 'silɛa 'yee mingɔnnɛn 'trɛda 'nɔn 'a. 
\p  
\v 6 Fɛ nɛn maan ve zɩɛ -yɛɛ cɩ 'nan, Bali -a ye 'wɩ "yi "a, -e 'e 'tɛ 'pa minnun nɛn o 'tɛ "paa 'ka da bɛ, o da.  
\v 7 Ɛn 'cee vɛ nɛn ka cɩ 'ka yra yɩnan 'labɛ, yaa ye 'wɩ "yi "a -e 'e 'fʋdɩ -trɔɔ -nɔn 'cɛɛ. Yaa -nɔan -kaa pɛɛnɔn lɛ 'e cin va. E 'wɩ zɩɛ -a dra tʋ nɛn Minsan Zozi "sia laji -e 'e 'ta pee wʋ bɛ -a man. Tʋ zɩɛ -a man nɛn e -taa 'o 'vale 'yee 'pasianɔn 'plɛblɛ nɛn laji bɛ waa.  
\v 8 E -taa 'tɛ nrɛn -dan yei. -Te e -ta bɛ, e 'wɩ "nɛn -kɔɔnman minnun nɛn wa'a Bali -tɔlɛ dɩɛ -wlɛ. Ɛn e 'wɩ "nɛn -kɔɔnman minnun nɛn wa'a 'ta wʋlɛa -kaa 'san Zozi 'bɔ 'le 'wɩ 'nɔnnɔn da dɩɛ -wlɛ.  
\v 9 O -taa 'wɩ yɩlɛ -pʋ 'kɔn nɛn -a lɛ "nɛn "ka "dɩɛ -a -ji. O -kɔan 'o 'sidɩ Minsan man -kɔɔbli, ɛn wa'a 'kɔlaman -yee mingɔnnɛn trɛ nɛn e "bia bɛ -a yɩdɩ -a dɩ.  
\v 10 'Wɩ zɩɛ e dra yi nɛn Zozi -taa "man "bɛ, -a da. -A -nan nɛn minnun nɛn o cɩ -yee vɛ -a ɛn o yi -tɛra -a wei da bɛ, waa si -fɔa te waa bɔa. Ka -kɔan "minnun zɩɛ o va, kɔɔ ka yi -tɛra 'wɩnun nɛn kʋa 'vɩ 'cɛɛ bɛ -a da. 
\p  
\v 11 -Yee "wɛan kʋ Bali trʋ "baa tʋ pɛɛnɔn man 'cee 'wɩ man. Kʋa laabo -cee Bali lɔ 'nan, 'e 'ka yɩ 'wɩ nɛn e 'ka laabʋ "man "bɛ -a drɛnɔn tɩglɩ 'a. Ɛn kʋa laabo -yrɔ "nyian 'nan, 'e 'pa 'ka 'va 'yee 'plɛblɛ 'a, -e 'wɩ "yi pɛɛnɔn nɛn e 'sɔ 'cɛɛ 'nan 'ka dra bɛ 'ka drɛ. Ɛn 'e 'pa 'ka 'va -e 'cee 'nyranman nɛn ka 'nan 'ka "paa yi -tɛradɩ -a Zozi da bɛ, 'ka 'pa.  
\v 12 'E drɛ zɩɛ, -e -kaa 'san Zozi 'tɔ 'e drɛ -dan 'cee "wɛan, -e "cee 'tɔ 'e drɛ -dan -yee "wɛan. 'Wɩ pɛɛnɔn zɩɛ, 'e drɛ -kaa "tɩ Bali 'lee Minsan Zozi Crizi -le "yi "a. 
\c 2  
\s1 Bali 'nanmanzan klu "so 
\p  
\v 1 'Kʋ "bʋɩ Zozinɔn, -kaa 'san Zozi Crizi -tadɩ nɛn kʋa 'wɩ 'vɩ bɛ, 'lee -kaa cin yɩdɩ -a "srɔn "nɛn, kʋa 'vɩ bɛ, kʋ 'wɩ "paala 'cɛɛ "da.  
\v 2 -Te min -a 'vɩ 'cɛɛ 'nan, Zozi 'ta 'va bɛ, te 'ka 'ci 'e baa -ji -e 'ka 'si 'si tɩglɩ da dɩ! -Te Bali 'lewei vɩnɔn 'le nɛn kaa 'man oo, te 'ka 'ci 'e baa -ji dɩ! Ɛn -te Bali -le 'wɩ vɩnɔn 'le nɛn kaa 'man oo, te 'ka 'ci 'e baa -ji dɩ! Ɛn -te min -a 'vɩ 'cɛɛ 'nan, kʋɛ crɛn -tɛ 'fluba 'ji oo, te 'ka 'ci 'e baa -ji dɩ! 
\p  
\v 3 Te 'ka 'wɩ "man -e min -tʋ 'e 'ka see "paa 'wɩ zɩɛ -a da dɩ! Fɛ nɛn maan ve zɩɛ -yɛɛ cɩ 'nan, tʋ nɛn min "kaga Bali wei -fɔala 'o "trɔɛn -sru "bɛ, e bɔa 'vaa -e Zozi 'ta yi 'e bɔ. Ɛn min nɛn e 'wɩ 'wlidɩ "paa 'nyranman -a ɛn Bali -a 'pla 'tɛ 'le vɛ -a bɛ, e -taa 'vaa -e yi zɩɛ 'e bɔ.  
\v 4 Min zɩɛ Bali 'nanmanzan nɛn. -Yɛɛ -taa -a vɩlɛ 'nan 'yɛɛ cɩ fɛ pɛɛnɔn nɛn minnun a laabo Bali te waa bɔa "bɛ -a da. E -taa 'e 'fli drɛlɛ -dandan. Yaa dra -trilii, -e 'e -wlala 'yee -dandan 'tandɩ 'bɔ 'a Bali -pan 'kuin, -e 'e -nyran. Yaa ve 'e 'fli man 'nan, 'yɛɛ cɩ Bali -a. 
\p  
\v 5 Tʋ nɛn te an ya tian 'ka 'va bɛ, an -fɔ 'e 'flin an 'wɩnun zɩɛ -a 'vɩ 'cɛɛ. -A -cin 'san 'ka 'ji?  
\v 6 Ɛn fɛ nɛn e -si -tɔa tian Bali 'nanmanzan zɩɛ -yrɔ "bɛ, kaa -tɔa. Fɛ zɩɛ e -si -tɔa -yrɔ "trilii, -e tʋ nɛn Bali 'bɔ 'a -tɔ -yrɛ "bɛ, e 'bɔ. -A -nan nɛn -a ta bɔala.  
\v 7 'Nyranman -wlidɩ "nɛn Bali 'nanmanzan 'bɔ 'a "paa bɛ, e ya -a 'panan 'va. 'Pian yaa "paa 'e yɔɔdɩ, kɔɔ min -tʋ -si -tɔa tian -yrɔ. -Te 'bɛ 'ka "nyian -nan dɩɛ,  
\v 8 -a -nan nɛn Bali 'nanmanzan zɩɛ, -a ta bɔala. Yi zɩɛ -a da nɛn Minsan Zozi -a -tɛa 'e 'le fulɔ -a. 'Wɩ 'kpa Minsan Zozi 'le -tadɩ -a -nan -nyaan. 
\p  
\v 9 Bali 'nanmanzan zɩɛ Satan 'bɛ -kɔladɩ -nɔn -yrɛ. -Yee "wɛan e -kɔlaman -dravia wɩ 'tɔ 'tʋdʋ pɛɛnɔn drɛdɩ -a. Ɛn e -kɔlaman 'wɩ -kɔɔn "man wɩnun 'lee -cɛ -srɔn "wɩnun drɛdɩ -a. 'Wɩ pɛɛnɔn zɩɛ yaa dra 'nan -e 'e minnun see "paa.  
\v 10 'Wɩ 'kpa, minnun nɛn o ya -si nɛn e o "sia Bali man bɛ -a da bɛ, Bali 'nanmanzan -taa o see "paalɛ 'wɩ 'wlidɩ 'tɔ -tʋdʋ pɛɛnɔn nɛn yaa dra bɛ -a. Kɔɔ wa'a Bali -le 'wɩ tɩglɩ nɛn, e o "sia paan 'wɩ 'ji bɛ -a yɩlɛ "yi "dɩ.  
\v 11 -Yee "wɛan nɛn Bali -a drɛ ɛn Bali 'nanmanzan 'le see "paa wɩnun -kɔla o man yɩdɩ -a, 'nan -e 'o yi -tɛra 'wlu wɩnun da.  
\v 12 Bali 'wɩ zɩɛ -a drɛ 'nan -e 'e tin -tɛ minnun zɩɛ o da. Kɔɔ wa'a yi -tɛlɛa 'wɩ tɩglɩ da dɩ, 'pian o 'wɩ 'wlidɩ "drɛdɩ 'yɩ "yi. 
\s1 'Ka 'tɔ 'plɛblɛ Bali -le 'wɩ 'ji! 
\p  
\v 13 'Kʋ "bʋɩ Zozinɔn, kʋa -tɔa 'nan Minsan 'ka ye "yi. Ɛn tʋ nɛn Bali 'ka tian 'trɛ drɛlɛ dɩɛ, e 'ka 'si "va 'nan -e 'e 'ka 'si 'wɩ 'ji. -Yee "wɛan e ya "le 'kʋ Bali muo "fɔ tʋ pɛɛnɔn man 'cee "wɛan. 'Wɩ 'kpa, Bali -taa 'ka 'silɛ 'wɩ 'ji, kɔɔ 'yee lei 'saun 'ka drɛ Bali -le vɛ -a "fo, ɛn ka yi -tɛra 'wɩ tɩglɩ da.  
\v 14 'Ka 'sidɩ 'wɩ 'ji -le "wɛan nɛn Bali 'ka laabʋ 'wɩ 'nɔnnɔn nɛn kʋa 'vɩ 'cɛɛ bɛ -a. E 'ka laabʋ 'nan -e 'tɔ -dan nɛn -kaa san Zozi Crizi -lɔ bɛ, 'ka drɛ -a "nɛn "blɩnɔn 'a. 
\p  
\v 15 -Yee "wɛan 'kʋ "bʋɩ Zozinɔn, 'ka 'tɔ 'plɛblɛ Bali -le 'wɩ 'ji! 'Wɩ pɛɛnɔn nɛn kʋa paa 'ka 'ji bɛ, 'ka 'tɔ "da 'plɛblɛ! -Te kʋa 'vɩ 'kʋ 'le oo, ɛn -te 'fluba nɛn kʋa crɛn -tɛ 'cɛɛ oo, 'ka 'tɔ "da 'plɛblɛ! 
\p  
\v 16 -Kaa "tɩ Bali -kaa 'yɩ "yi, ɛn e "yi -dan drɛ -cɛɛ. -Yee "wɛan -kaa "koe a -kaa da 'li "fo "le vɛ -a, ɛn -kaa 'bli a "da 'nan 'belidɩ a -cee vɛ -a. Kʋa laabo -kaa "tɩ Bali 'lee -kaa 'san Zozi Crizi -lɔ 'nan,  
\v 17 'o 'ka "koe "tɔ 'ka da "fo. Ɛn kʋa laabo -wlɔ "nyian 'nan, 'o 'plɛblɛ 'nɔn 'cɛɛ, -e tʋ pɛɛnɔn man 'ka 'wɩ "yi "drɛ, ɛn 'ka 'wɩ "yi "vɩ. 
\c 3  
\s1 'Ka Bali trʋ 'ba 'kʋɛ! 
\p  
\v 1 'Kʋ "bʋɩ Zozinɔn, kʋa 'le -sɛanla -a laabʋdɩ 'ka 'lɔ 'nan, 'ka Bali trʋ 'ba 'kʋe 'wɩ man. 'Ka Bali trʋ 'ba 'nan -e Minsan -le 'wɩ 'e fuila "man fɛ pɛɛnɔn 'nan. Ɛn 'ka trʋ 'ba 'nan min "kaga 'o 'wɩ "man ci "nrandɩ -a, "le zɩ ka wɩɩ "man "bɛ -yee 'wɩ 'zʋ.  
\v 2 'Ka Bali trʋ 'ba "nyian 'nan, 'e 'pɛ 'pa 'kʋ da min -wlidɩnun nɛn o "naan 'kʋ man bɛ, -wee "wɛan. Fɛ nɛn maan ve zɩɛ -yɛɛ cɩ 'nan, minnun pɛɛnɔn "cɛɛ "we "man -e 'o yi -tɛra Bali wei da dɩ. 
\p  
\v 3 'Wɩ nɛn Minsan -a 'vɩ bɛ, yaa dra. E 'ka man -tɔa 'plɛblɛ 'ta wʋdɩ -a Bali -sru. Ɛn ya'a 'ka 'tʋe -e Satan nɛn e 'wɩ 'wlidɩ "paa 'nyranman -a bɛ 'e 'ka man yɩ dɩ.  
\v 4 Kʋ yi -tɛala Bali da 'nan, 'wɩnun nɛn kʋa 'pla 'cɛɛ bɛ, ka ya -a drɛnan, ɛn kaa dra 'li 'trilii.  
\v 5 Kʋa laabo Minsan lɔ 'nan, 'e 'cee ci "nrɔndɩ 'pla Bali -le min yɩdɩ "yi "da, ɛn e 'pla -pɔan 'sɔdɩ nɛn Zozi 'ji bɛ -a da. 
\s1 Te 'ka drɛ kɔannɔn 'a dɩ! 
\p  
\v 6 'Kʋ "bʋɩ Zozinɔn, kʋ 'wɩ "paala 'cɛɛ -kaa san Zozi Crizi 'tɔ da 'nan, Zozinɔn pɛɛnɔn nɛn o kɔan wo, te wa'a 'nyranman paa dɩɛ, ɛn te wa'a 'ta wʋla 'wɩnun nɛn kʋa paa 'ka 'ji bɛ -a da dɩɛ, te 'ka -blɩ waa dɩ!  
\v 7 Kaa -tɔa 'ka 'bɔ 'a 'nan, e ya "le 'ka drɛ 'kʋ si drɛnɔn 'a. Kɔɔ kʋ 'lʋ 'ka 'va bɛ, kʋ'a kɔan wʋlɛ dɩ,  
\v 8 ɛn kʋ'a min lɔ fɛ -blɩlɛ 'e "tun "dɩ. Bodrun funnin, te 'kʋ "koe -nyaan 'nyranman 'padɩ -a, 'nan -e 'kʋe -blɩfɛ 'e vɩlɛ 'e drɛ 'ka 'tʋ -win -ji -trɔ -a dɩ.  
\v 9 'Kʋ 'blɩfɛ "sia paan 'ka 'lɔ, 'pian ya'a drɛlɛ zɩ dɩ. Kɔɔ kʋa wɛɛ 'nan, 'kʋ drɛ 'cee 'wɩ -kɔɔn "mannɔn 'a, ɛn 'ka drɛ 'kʋ si drɛnɔn 'a.  
\v 10 Ɛn tʋ nɛn te kʋ ya tian 'ka 'va bɛ, kʋa paa 'ka 'ji 'nan, min nɛn 'e 'ka "vale 'e 'nyranman "paa dɩɛ, te 'ka fɛ -nɔn -yrɛ "dɩ. 
\p  
\v 11 'Bɛ nɛn 'gʋɛ, kʋa 'man 'nan, 'ka 'va min -mienun 'o 'fli drɛ kɔannɔn 'a. Wa'a 'nyranman paa dɩ, te o -cia 'o 'tɔ wʋdɩ -a min peenun -le 'wɩ 'ji.  
\v 12 Kʋ 'wɩ "paala minnun zɩɛ -wlɛ Minsan Zozi Crizi 'tɔ da 'nan, 'nyranman 'padɩ da nɛn 'o yiɛ 'trɔa, te waa "nɛn "fɛ -ble. 
\p  
\v 13 'Kʋ "bʋɩ Zozinɔn, te 'ka "koe 'e 'si 'ka da 'wɩ "yi "drɛdɩ -a dɩ! 
\p  
\v 14 Min nɛn ya'a 'ta wʋlɛa 'wɩ nɛn kʋa crɛn -tɛ zɩɛ -a da dɩɛ, 'ka 'san -kɔnnɛn 'pla, te 'ka "nran waa dɩ. 'Ka drɛ zɩɛ -e 'yra 'e -tɛ.  
\v 15 'Pian te 'ka 'san 'sia "le 'ka 'nanmanzan 'zʋ dɩ! E ya 'ka "bʋɩ Zozizan 'tʋ -a, 'wɩ nɛn 'ka 'pla -yrɛ! 
\p  
\v 16 Minsan nɛn -fʋdɩ -trɔɔ "sia "va "bɛ, kʋa laabo -yrɔ 'nan, 'e 'fʋdɩ -trɔɔ -nɔn 'cɛɛ. 'E -nɔn yi pɛɛnɔn man, ɛn 'e -nɔn -pɛ pɛɛnɔn 'ji! Minsan 'e 'pa 'ka pɛɛnɔn 'va! 
\p  
\v 17 An 'bɔ Pɔl 'bɛ 'ka 'tɔ bʋdɩ 'gʋɛ -a crɛn -tɛ 'an 'pɛ -a. Zɩ maan dra 'mɛn 'fluba pɛɛnɔn 'ji zɩɛ -e 'ka -tɔ 'nan mɛɛn 'pa 'sia 'cɛɛ. 
\p  
\v 18 -Kaa 'san Zozi Crizi -le "yi 'e 'kɔn 'ka pɛɛnɔn 'va!