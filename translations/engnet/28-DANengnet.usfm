\v 16 However, \w I|strong="H1768"\w* \w have|strong="H7981"\w* \w heard|strong="H8086"\w* \w that|strong="H1768"\w* \w you|strong="H1768"\w* \w are|strong="H1768"\w* \w able|strong="H3202"\w* \w to|strong="H5922"\w* provide \w interpretations|strong="H6590"\w* \w and|strong="H1722"\w* \w to|strong="H5922"\w* decipher knotty \w problems|strong="H7001"\w*. \w Now|strong="H3705"\w* \w if|strong="H2006"\w* \w you|strong="H1768"\w* \w are|strong="H1768"\w* \w able|strong="H3202"\w* \w to|strong="H5922"\w* \w read|strong="H7123"\w* \w this|strong="H8086"\w* \w writing|strong="H3792"\w* \w and|strong="H1722"\w* \w make|strong="H3046"\w* \w known|strong="H3046"\w* \w to|strong="H5922"\w* \w me|strong="H5922"\w* \w its|strong="H6591"\w* \w interpretation|strong="H6591"\w*, \w you|strong="H1768"\w* \w will|strong="H1768"\w* wear purple \w and|strong="H1722"\w* \w have|strong="H7981"\w* \w a|strong="H3068"\w* \w golden|strong="H1722"\w* \w collar|strong="H2002"\w* \w around|strong="H5922"\w* \w your|strong="H5922"\w* \w neck|strong="H6676"\w* \w and|strong="H1722"\w* \w be|strong="H3705"\w* \w third|strong="H8531"\w* \w ruler|strong="H7981"\w* \w in|strong="H5922"\w* \w the|strong="H5922"\w* \w kingdom|strong="H4437"\w*.”
\s1 Daniel Interprets the Handwriting on the Wall
\p 
\v 17 \w But|strong="H1297"\w* \w Daniel|strong="H1841"\w* \w replied|strong="H6032"\w* \w to|strong="H6925"\w* \w the|strong="H6925"\w* \w king|strong="H4430"\w*, “Keep \w your|strong="H3052"\w* \w gifts|strong="H4978"\w*, \w and|strong="H6032"\w* \w give|strong="H3052"\w* \w your|strong="H3052"\w* \w rewards|strong="H5023"\w* \w to|strong="H6925"\w* someone else! \w However|strong="H1297"\w*, I \w will|strong="H4430"\w* \w read|strong="H7123"\w* \w the|strong="H6925"\w* \w writing|strong="H3792"\w* \w for|strong="H3046"\w* \w the|strong="H6925"\w* \w king|strong="H4430"\w* \w and|strong="H6032"\w* \w make|strong="H3046"\w* \w known|strong="H3046"\w* \w its|strong="H6591"\w* \w interpretation|strong="H6591"\w*.
\v 18 \w As|strong="H4437"\w* for you, \w O|strong="H3068"\w* \w king|strong="H4430"\w*, \w the|strong="H5020"\w* \w most|strong="H5943"\w* \w high|strong="H5943"\w* God \w bestowed|strong="H3052"\w* on \w your|strong="H3052"\w* father \w Nebuchadnezzar|strong="H5020"\w* \w a|strong="H3068"\w* \w kingdom|strong="H4437"\w*, \w greatness|strong="H7238"\w*, \w honor|strong="H3367"\w*, \w and|strong="H4430"\w* \w majesty|strong="H7238"\w*.
\v 19 Due \w to|strong="H6925"\w* \w the|strong="H3606"\w* \w greatness|strong="H7238"\w* \w that|strong="H1768"\w* \w he|strong="H1768"\w* \w bestowed|strong="H3052"\w* on \w him|strong="H4481"\w*, \w all|strong="H3606"\w* \w peoples|strong="H5972"\w*, nations, \w and|strong="H1763"\w* \w language|strong="H3961"\w* groups \w were|strong="H1934"\w* \w trembling|strong="H2112"\w* with \w fear|strong="H1763"\w* \w before|strong="H6925"\w* \w him|strong="H4481"\w*. \w He|strong="H1768"\w* \w killed|strong="H6992"\w* \w whom|strong="H1768"\w* \w he|strong="H1768"\w* \w wished|strong="H6634"\w*, \w he|strong="H1768"\w* \w spared|strong="H2418"\w* \w whom|strong="H1768"\w* \w he|strong="H1768"\w* \w wished|strong="H6634"\w*, \w he|strong="H1768"\w* \w exalted|strong="H7313"\w* \w whom|strong="H1768"\w* \w he|strong="H1768"\w* \w wished|strong="H6634"\w*, \w and|strong="H1763"\w* \w he|strong="H1768"\w* brought low \w whom|strong="H1768"\w* \w he|strong="H1768"\w* \w wished|strong="H6634"\w*.
\v 20 \w And|strong="H4437"\w* \w when|strong="H1768"\w* \w his|strong="H4481"\w* \w mind|strong="H3825"\w* \w became|strong="H8631"\w* arrogant \w and|strong="H4437"\w* \w his|strong="H4481"\w* \w spirit|strong="H7308"\w* \w filled|strong="H8631"\w* with \w pride|strong="H2103"\w*, \w he|strong="H1768"\w* \w was|strong="H3825"\w* \w deposed|strong="H5182"\w* \w from|strong="H4481"\w* \w his|strong="H4481"\w* \w royal|strong="H4437"\w* \w throne|strong="H3764"\w* \w and|strong="H4437"\w* \w his|strong="H4481"\w* \w honor|strong="H3367"\w* \w was|strong="H3825"\w* \w removed|strong="H5709"\w* \w from|strong="H4481"\w* \w him|strong="H4481"\w*.
\v 21 \w He|strong="H1768"\w* \w was|strong="H1655"\w* \w driven|strong="H2957"\w* \w from|strong="H4481"\w* human \w society|strong="H1123"\w*, \w his|strong="H5922"\w* \w mind|strong="H3825"\w* \w was|strong="H1655"\w* changed \w to|strong="H5922"\w* \w that|strong="H1768"\w* \w of|strong="H4481"\w* \w an|strong="H5705"\w* animal, \w he|strong="H1768"\w* lived \w with|strong="H5974"\w* \w the|strong="H5922"\w* \w wild|strong="H6167"\w* \w donkeys|strong="H6167"\w*, \w he|strong="H1768"\w* \w was|strong="H1655"\w* \w fed|strong="H2939"\w* \w grass|strong="H6211"\w* \w like|strong="H2939"\w* \w oxen|strong="H8450"\w*, \w and|strong="H8065"\w* \w his|strong="H5922"\w* \w body|strong="H1655"\w* became \w damp|strong="H6647"\w* \w with|strong="H5974"\w* \w the|strong="H5922"\w* \w dew|strong="H2920"\w* \w of|strong="H4481"\w* \w the|strong="H5922"\w* \w sky|strong="H8065"\w*, \w until|strong="H5705"\w* \w he|strong="H1768"\w* \w came|strong="H1768"\w* \w to|strong="H5922"\w* \w understand|strong="H3046"\w* \w that|strong="H1768"\w* \w the|strong="H5922"\w* \w most|strong="H5943"\w* \w high|strong="H5943"\w* God \w rules|strong="H7990"\w* \w over|strong="H5922"\w* human \w kingdoms|strong="H4437"\w*, \w and|strong="H8065"\w* \w he|strong="H1768"\w* appoints \w over|strong="H5922"\w* \w them|strong="H5974"\w* \w whomever|strong="H1768"\w* \w he|strong="H1768"\w* \w wishes|strong="H6634"\w*.
