\id ACT
\h Oihana
\toc1 Oihana
\toc2 Oihana
\toc3 Oihana
\mt1 Oihana
\c 1
\s1 NA OIHANA
\q1 
\v 1 U A hoonoho aku au, e Teopilo, i ka mooolelo mua, no namea a pau a Iesu i hoomaka'i e hana a e ao mai no hoi,
\q1 
\v 2 A hiki i ka la i laweia'ku ai ia iluna, mahope o kana kauoha ana mai ma ka Uhane Hemolele i na lunaolelo ana i wae mai ai.
\q1 
\v 3 Hoike ola mai no oia ia ia iho ia lakou mahope o kona make ana, ma na hoailona hoike he nui loa, me ka ikeia e lakou i na la ho kanaha, a olelo mai no ia i na mea o ke aupuni o ke Akua:
\q1 
\v 4 A i kona halawai ana me lakou, kauoha mai la oia ia lakou, aole e haalele ia Ierusalema, aka, e kali i ka ka Makua olelo hoopomaikai, a oukou i lohe ai ia'u.
\q1 
\v 5 No ka mea, ua bapetizo io no o Ioane me ka wai; aka, e bapetizoia no hoi oukou i ka Uhane Hemolele, mahope iho o na la aohe nui.
\b
\q1 
\v 6 No ia mea, i ko lakou akoakoa ana, ninau aku la lakou ia ia, i aku la, E ka Haku, e hoihoi mai anei oe i ke aupuni no ka Iseraela i keia wa?
\q1 
\v 7 I mai la oia ia lakou, Aole ia oukou ka ike i na wa, a me na kau a ka Makua i waiho ai i kona mana iho.
\q1 
\v 8 Aka, e loaa no ia oukou ka mana, ke hiki mai ka Uhane Hemolele maluna iho o oukou; a e lilo auanei oukou i poe hoike no'u ma Ierusalema, a ma Iudea a pau, a ma Samaria, a hiki wale aku i ke kihi o ka honua.
\q1 
\v 9 A oki ae la kana olelo ana ia mau mea, e nana aku ana lakou, a laweia'ku la ia iluna; a na ke ao no ia i apo mai, mai ko lakou mau maka aku.
\q1 
\v 10 A i ko lakou haka pono ana aku i ka lani, i kona pii ana, aia hoi, ku kokoke mai la me lakou na kanaka elua, me ka aahu keokeo;
\q1 
\v 11 I mai la hoi laua, E na kanaka o Galilaia, no ke aha la oukou e ku nei e nana aku ana i ka lani? O Iesu nei, ka mea i laweia'ku nei i ka lani, mai o oukou aku nei, pela no ia e hoi hou mai ai e like me ka oukou ike ana aku ia ia e pii ana i ka lani.
\b
\q1 
\v 12 Alaila, hoi aku la lakou i Ierusalema, mai ka mauna aku i kapaia o Oliveta, ua kokoke no ia i Ierusalema, o ko ka la Sabati hele ana.
\q1 
\v 13 A komo lakou iloko, pii aku la, a iloko o kekahi keena maluna, malaila lakou i noho ai, o Petero, a me Iakobo, a me Ioane, a me Anederea, a me Pilipo, a me Toma, a me Baretolomaio, a me Mataio, a me Iakobo a Alepaio, a me Simona Zelote, a me Inda ka hoahanau no Iakobo.
\q1 
\v 14 Hoomau iho la lakou nei a pau i ka pule ana, a me ka nonoi aku, me ka lokahi o ka manao, o na wahine hoi kekahi, a me Maria, ka makuwahine o Iesu, a me kona poe hoahanau.
\b
\q1 
\v 15 I ua mau la la, ku ae la o Petero iwaenakonu o na haumana, i mai la, (o ka nui o ko lakou inoa, hookahi haneri me ka iwakalua,)
\q1 
\v 16 E na kanaka, na hoahanau, he mea pono e hookoia keia palapala a ka Uhane Hemolele i hai mai ai ma ka waha o Davida no Iuda, ka mea nana i alakai i ka poe i hopu ia Iesu.
\q1 
\v 17 No ka mea, ua helu pu ia oia me kakou, a loaa no hoi ia ia kekahi o neia oihana.
\q1 
\v 18 A kuai iho la ia i aina me ka uku no ka hewa; a haule iho la ia ilalo kona poo, nahae iho la iwaenakonu ona, a pahu aku la kona naau a pau iwaho.
\q1 
\v 19 A ikea iho la ia mea e ka poe a pau e noho ana ma Ierusalema; nolaila ua kapaia'ku la ia aina, ma ka lakou olelo, Akeledama, o ke ano keia, O ka aina koko.
\q1 
\v 20 No ka mea, ua palanalaia ma ka buke Halelu, E lilo kona hale i neoneo, aole loa kekahi e noho ilaila; a, E lawe hoi kekahi i kana oihana.
\q1 
\v 21 Nolaila, o na kanaka i hele pu ai me kakou i na wa a pau loa a ka Haku, a Iesu i hele mai ai, a i hele aku ai iwaena o kakou,
\q1 
\v 22 Mai ka hoomaka ana o Ioane e bapetizo ai, a hiki mai i ka la i laweia'ku ai ia mai o kakou aku, he mea pono e lilo kekahi o lakou i mea hoike pu me kakou i kona alahou ana mai.
\q1 
\v 23 Wae aku la lakou i elua, o Iosepa i kapaia o Baresaba, o Iouseto kekahi inoa ona, a me Matia hoi.
\q1 
\v 24 Pule aku la lakou, i aku la, E ka Haku, ka mea ike i ka naau o na mea a pau loa, e hoike mai oe i ka mea o laua nei au e koho mai ai,
\q1 
\v 25 I lawe pu ia i kekahi o keia oihana, a me ko ka lunaolelo, mai ia wahi mai ko Iuda haule ana, i hele aku ia i kona wahi iho.
\q1 
\v 26 Hailona iho la lakou, a lilo ka hailona ia Matia; a helu pu ia iho la ia me na lunaolelo he umikumamakahi.
\c 2
\b
\q1 
\v 1 A HIKI io mai la ka la Penetekota, ua akoakoa pu lakou a pau, me ka manao lokahi.
\q1 
\v 2 Emo ole, pae mai la ka leo, mai ka lani mai, me he makani nui ikaika la; a hoopiha loa iho la i ka hale a pau, kahi a lakou i noho at
\q1 
\v 3 A ikeia'ku la e lakou na elelo manamana, me he ahi la, a kau mai la iluna iho o kela mea keia mea o lakou a pau.
\q1 
\v 4 A piha ae la lakou a pau i ka Uhane Hemolele; a hoomaka lakou e olelo aku me na elelo e, e like me ka haawi ana mai o ka Uhane ia lakou e olelo aku.
\b
\q1 
\v 5 E noho ana no ma Ierusalema na Iudaio, he poe kanaka haipule no na aina a pau malalo nei o ka lani.
\q1 
\v 6 A loheia'ku la keia leo, alaila, lulumi mai la ua ahakanaka la, a pilipu iho la lakou, no ka mea, lohe no kela kanaka keia kanaka i ka lakou olelo ana ma kana olelo iho.
\q1 
\v 7 Pilihua iho la lakou me ke kahaha o ka naau, i ae la kekahi i kekahi, Aia, aole anei no Galilaia lakou a pau e olelo mai nei?
\q1 
\v 8 Pehea hoi keia lohe ana o kela mea keia mea o kakou i ka olelo o kona wahi i hanau ai?
\q1 
\v 9 O ko Paretia, a me ko Media, a me ko Elimai, a me ka pue i noho ma Mesopotamia, a ma Iudea, a ma Kapadosia, a ma Poneto, a ma Asia,
\q1 
\v 10 A ma Perugia, a ma Pamepulia, a ma Aigupita, a ma na aina o Libua e kokoke ana i Kurene, a me na mea malihini o Roma mai, na Iudaio, a me na mea hoi i huli mai,
\q1 
\v 11 O ko Kerete a me ko Arabia, ke lohe nei kakou ia lakou e olelo mai la i na mea nui o ke Akua ma ka kakou olelo iho.
\q1 
\v 12 Kahaha iho la ko lakou naau a pau, a kanalua no hoi, i ae la kekahi i kekahi, Heaha la ke ano o keia mea?
\q1 
\v 13 Hoowahawaha no hoi kekahi poe, i ae la, Ua piha keia poe i ka waina hou.
\b
\q1 
\v 14 Alaihi ku ae la o Petero iluna me ka poe umikumamakahi, hookiekie mai la i kona leo, olelo iho la ia lakou, E na kanaka, na Indaio, a me na mea a pau e noho ana ma Ierusalema nei, e ike pono oukou i keia, a e hoolohe mai oukou i ka'u mau olelo:
\q1 
\v 15 No ka mea, Aole lakou nei i ona, e like me ka oukou e manao mai nei, no ka mea, o ke kolu keia o ka hora o ke ao.
\q1 
\v 16 Aka, eia ka mea i oleloia, e ke kaula, e Ioela;
\q1 
\v 17 I na la mahope, wahi a ke Akua, e ninini iho au i ko'u Uhane maluna o na kanaka a pau; a e wanana ae ka oukou poe keikikane, a me ka oukou mau kaikamahine, a e ike ko oukou poe kanaka hou i na hihio, a e moe no ko oukou poe elemakule i na moe uhane.
\q1 
\v 18 A i kela mau la, ninini aku no hoi au i ko'u Uhane maluna iho o ka'u poe kauwakane a me ka'u poe kauwawahine; a e wanana ae lakou.
\q1 
\v 19 A e hoike no wau i na mea kupanaha ma ka lani maluna, a me na hoailona hoi ma ka honua malalo; he koko, a me ke ahi, a me ke ao uwahi.
\q1 
\v 20 E lilo e no ka la i pouli, a me ka mahina hoi i koko, mamua o ka hiki ana o ua la nui kaulana la o ka Haku.
\q1 
\v 21 Aka, eia kekahi, o ka mea e kahea aku i ka inoa o ka Haku, e ola ia.
\b
\q1 
\v 22 E na kanaka o ka Iseraela, e hoolohe mai oukou i keia mau olelo; O Iesu no Nazareta, he kanaka ia i heakakaia ia oukou e ke Akua, ma na hana mana, a me na mea kupanaha a ke Akua i hana mai ai ma o na la, iwaena o oukou, e like me ko oukou ike ana;
\q1 
\v 23 Ua haawiia mai ia mamuli o ka manao kupaa a me ka ike mua o ke Akua, na oukou ia i hopu, a, me na lima hewa, i kau ai i ke kea a make ia.
\q1 
\v 24 Ua hoala hou mai ke Akua ia ia me ka wehe iho i na apo o ka make; no ka mea, he mea hiki ole i kela mea, e hoopaa ia ia.
\q1 
\v 25 No ka mea, i mai la o Davida nona, Ike maopopo aku la au i ka Haku, e ku mau loa ana mamua o'u; no ka mea, aia no ia ma ko'u lima akau, i ole au e naueue.
\q1 
\v 26 No ia mea, hauoli ko'u naau, a olioli hoi kuu elelo; a e moe malie no ko'u kino me ka manaolana:
\q1 
\v 27 No ka mea, aole oe e waiho i kou Uhane ma ka malu o ka poe make, aole hoi e haawi mai i kou mea hoano, e ike i ka palaho.
\q1 
\v 28 Ua hoike mai oe ia'u i ka aoao o ke ola; e hoopiha mai no hoi oe ia'u i ka olioli ma kou maka.
\q1 
\v 29 E na kanaka, na hoahanau, e hiki mai ia'u ke olelo huna ole aku ia oukou no Davida, ka makua'lii, ua make no ia, ua kanuia hoi, a ke waiho nei no kona halelua io kakou nei, a i keia manawa.
\q1 
\v 30 No ka mea, he kauhi ia, a ike i ka hoohiki ana o ke Akua ana i hoohiki ai nona, no kekahi hua o kona pnhaka ma ko kino, e hoala mai ia Kristo e noho ma kona nohoalii;
\q1 
\v 31 No kona ike mua ana i keia, hai mai la ia i ke alahouana mai o Iesu Kristo, penei, Aole kona Uhane i waihoia ma ka malu o ka poe make, aole hoi i ike kona kino i ka palaho.
\q1 
\v 32 O ua Iesu la, oia ka ke Akua i hoala mai ai, he poe ike maka makou a pau ia mea.
\q1 
\v 33 Ua hookiekieia'e la ia e ka lima akau o ke Akua, ua loaa no hoi ia ia, na ka Makua mai, ka olelo hoolana o kona haawi ana mai i ka Uhane Hemolele, no ia mea, ua haawi nui oia i keia mea a oukou e ike nei, a e lohe nei.
\q1 
\v 34 Aole i pii o Davida i ka lani; aka, nana no i i mai, Olelo mai la ka Haku i ko'u Haku hoi, E noho oe ma ko'u lima akau,
\q1 
\v 35 A hoolilo ai au i kou poe enemi i keehana wawae nou.
\q1 
\v 36 No ia mea, e ike pono ka ohana a pau Iseraela, ua hoolilo ke Akua ia Iesu nei, i ka mea a oukou i kau ai ma ke kea, i Haku a i Mesia hoi.
\b
\q1 
\v 37 A lohe lakou i keia, walama iho la ko lakou naau, i aka la ia Petero, a i na lunaolelo, E na kanaka, na hoahanau, heaha ka makou e hana'i?
\q1 
\v 38 Alaila i mai la o Petero ia lakou, E mihi, a e bapetizoia oukou a pau iloko o ka inoa o Iesu Kristo, i kalaia mai na hala, a e loaa ia oukou ka haawina o ka Uhane Hemolele.
\q1 
\v 39 No ka mea, no oukou ka olelo hoolana, a no ka oakou poe keiki, a no ka poe i kahi mamao aku, a no na mea a pau a ka Haku, a ko kakou Akua e hea mai ai.
\q1 
\v 40 A ma na olelo e ae he nui loa, hoike aku la oia, a nonoi aku hoi, i aku la, E hoola oukou ia oukou iho maiwaena mai o keia hanauna kolohe.
\b
\q1 
\v 41 Alaila, o ka poe ae maoli aku mamuli o kana olelo me ka olioli, bapetizoia iho la lakou, a ia la no, hui pu ia mai ekolu tausani kanaka.
\q1 
\v 42 A hoomau lakou ma ka olelo a ka poe lunaolelo, a me ka launa pu, a me ka wawahi berena ana, a me ka pule.
\b
\q1 
\v 43 Loohia iho la na kanaka a pau e ka makau; ua hanaia hoi na mea kupanaha e ka poe lunaolelo, a me na hoailona he nui loa.
\q1 
\v 44 A o ka poe a pau i manaoio, noho pu lakou, a hui pu ia ka lakou mau mea a pau.
\q1 
\v 45 A kuai aku la i ko lakou waiwai a me ka ukana, a puunaue aku la no kela mea keia mea, e like me kona hemahema.
\q1 
\v 46 Hoomau lakou maloko o ka luakini, i kela la i keia la, me ka manao hookahi, a me ka wawahi berena ana i kela hale i keia hale, a ai iho la lakou i ka ai me ka olioli, a me ke akahai o ka naau,
\q1 
\v 47 Me ka hoomaikai aku i ke Akua, a me ke alohaia e na kana ka a pau. A hookomo hou mai la ka Haku i ka ekalesia, i kela la i keia la, i poe e hoolaia ana.
\c 3
\b
\q1 
\v 1 PII pu aku la o Petero a me Ioane i ka luakini i ka hora pule, i ka iwa.
\q1 
\v 2 A haliia'e la kekahi kanaka, ua oopa mai ka opu mai o kona makuwahine, a waiho no lakou ia ia i kela la i kela la, ma ka puka o ka luakini, i kipaia, He nani, e nonoi aku i ka poe komo, i manawalea.
\q1 
\v 3 A ike ae la oia ia Petero, a me Ioane e komo ana iloko o ka luakini, noi aku la ia i manawalea.
\q1 
\v 4 Haka pono mai la o Petero, laua o Ioane ia ia, i mai la, E nana mai ia maua.
\q1 
\v 5 Nana aku k oia ia laua, me ka manao e loaa ia ia kekahi mea na laua mai.
\q1 
\v 6 Alaila i mai la o Petero, Aole a'u kala, aole he gula; aka, o ka mea i loaa mai ia'u, o ka'u ia e haawi aku nau; Ma ka inoa o Iesu Kristo no Nazareta, e ku oe, a e hele.
\q1 
\v 7 Lalau ae la oia i kona lima akau, a hooku ae la ia ia; ikaika koke iho la na kapuwai, a me na puupuu wawae ona.
\q1 
\v 8 Lele aku la ia, a ku iluna, a hele, a komo pu aku la me lakou iloko o ka luakini, me ka holoholo, a me ka lelele, a me ka hoomaikai aku i ke Akua.
\q1 
\v 9 A ike aku la na kanaka a pau ia ia e hele ana, a e hoomaikai aku ana i ke Akua:
\q1 
\v 10 A i ko lakou ike ana, oia no ka mea i noho ma ka puka nani o ka luakini, no ka manawaleaia mai; pilihua iho k lakou, me ke kahaha o ka naau, i ka mea i hanaia mai ia ia.
\b
\q1 
\v 11 Aka, paa aku la ka oopa i hoolaia ia Petero ma laua o Ioane, a holo mai la na kanaka a pau ma ka lanai i kapaia ko Solomona, me ke kahaha nui o ka naau.
\b
\q1 
\v 12 A ike mai la o Petero, olelo mai la ia i ua poe kanaka la, E na i kanaka o ka Iseraela, no ke aha la i kahaba mai ai ko oukou naau i keia mea? No ke aha la oukou e haka pono mai ai ia maua me he mea la na maua no, i ko maua mana, a me ko maua hemolele iho, i hana aku ai ia ia e hele?
\q1 
\v 13 O ke Akua o Aberahama, a o Isaaka, a o Iakoba, o ke Akua o ko kakou poe kapuna, ua hoonani mai la ia i kana Keiki ia Iesu, i ka mea a oukou i kumakaia aku ai, a hoole aku ia ia imua i ke alo o Pilato, i ka wa i manao iho ai oia e hookuu ia ia.
\q1 
\v 14 Ua hoole aku oukou i ka Mea Hoano a me ka Pono, a ua nouoi aku oukou e hookuuia ka mea pepehi kanaka na oukou;
\q1 
\v 15 Ua pepehi hoi oukou i ke Alii e ola'i, ka mea a ke Akua i hoala mai ai mai ka make mai; he poe ike maka no hoi makou ia mea.
\q1 
\v 16 Aka, o kona inoa iho, i ka manaoio ana i kona inoa, oia ka mea i hoola ai i ke kanaka a oukou e nana aku, a e ike nei: o ka manaoio ana ia ia, oia ka mea i haawi mai ai i ke ola io no ia nei imua i ke alo o oukou nei a pau.
\q1 
\v 17 Ano hoi, e na hoahanau, ua ike no au, no ka naaupo i hana aku ai oukoa i keia, a pela no ko oukou poe alii.
\q1 
\v 18 Aka, o na mea a ke Akua i hoike mua mai ai, ma ka waha o kona poe kaula a pau, e make ana ka Mesia, ua hooko mai ia pela.
\b
\q1 
\v 19 No ia mea e mihi oukou, a e huli mai, i pau ko oukou hewa i ka holoiia, i ka hiki ana mai o na mauawa hoomaha, mai ke alo mai o ka Haku:
\q1 
\v 20 A hoouna mai hoi oia ia Iesu Kristo, i ka mea i hai mua ia mai ia oukou.
\q1 
\v 21 He pono ke hookipa aku ka lani ia ia, a hiki aku i ka wa e hooponoponoia mai ai na mea a pau i oleloia mai e ke Akua, ma ka waha o na kaula hemolele ona, mai kinohi mai.
\q1 
\v 22 Ua hai mai o Mose, i ka poe kupuna, E hoopuka mai ana ka Haku, ko oukou Akua i Kaula e like me au, mailoko mai o ko oukou poe hoahanau; a e hoolohe oukoa ia ia ma na mea a pau ana e olelo mai ai ia oukou.
\q1 
\v 23 A he oiaio, o ka mea hoolohe ole i ua Kaula la, e okiia ia, mai kona poe kanaka aku.
\q1 
\v 24 A o na kaula a pau, mai ka wa mai o Samuela a me ka poe maho pe ona, o na mea olelo, ua hoike mai no lakou i keia mau la.
\q1 
\v 25 O oukou no na keiki a ka poe kaula, a me ka berita a ke Akua i hana mai ai i ko kakou poe kupuna, me ka olelo ana mai ia Aberahama, E hoopomaikaiia'na ko na aina a pau o ka honua i kou hua.
\q1 
\v 26 Ua hoala mai ke Akua i kana Keiki ia Iesu, a ua hoouna mai ia ia io oukou nei mua, e hoomaikai ia oukou i ka hoohuli aua ia oukou a pau, mai ko oukou hewa mai.
\c 4
\b
\q1 
\v 1 A I ka laua olelo ana mai i kanaka, lele aku la na kahuna, a me ka luna o ka luakini, a me na Sadukaio maluna o laua.
\q1 
\v 2 Ua ukiuki lakou i ka laua ao ana i kanaka, a me ka laua hai ana mai i ke alahouana, mai ka make mai, ma o Iesu la.
\q1 
\v 3 A hopu iho la ko lakou lima ia laua, a hahao iloko o kahi paa a kakahiaka; no ka mea, ua ahiahi.
\q1 
\v 4 A he nui na mea o ka poe lohe i ka olelo, i manaoio; a o ka helu ana o na kanaka, elima paha o lakou tausani.
\b
\q1 
\v 5 A ia la iho, akoakoa mai i Ierusalema, na'lii, a me na lunakahiko, a me ka poe kakauolelo,
\q1 
\v 6 A me Anasa, ke kahuna nui, a me Kaiapa, a me Ioane, a me Alekanedero, a me na hoahanau a pau o ke kahuna nui.
\q1 
\v 7 A hooku iho la lakou ia laua iwaenakonu, a ninau aku la, No ka mana hea, a no ka inoa hoa, i hana aku ai olua i keia?
\q1 
\v 8 Alaila olelo ae la o Petero ia lakou, me ka piha i ka Uhane Hemolele, E na alii o na kanaka, a me na lunakahiko o ka Iseraela,
\q1 
\v 9 Ina i hookolokoloia mai maua i keia la, i ka mea maikai i hanaia'ku ai i ua kanaka nawaliwali la, i ka mea ona i ola'i;
\q1 
\v 10 E ike pono oukou a pau, a me na kanaka a pau o ka Iseraela, ma ka inoa o Iesu Kristo no Nazareta, o ka mea a oukou i kau ai ma ke kea, o ka mea i hoalaia mai e ke Akua, mai ka make mai, oia no ka mea i ku ola mai ai keia kanaka imua o ko oukou alo.
\q1 
\v 11 Oia no ka pohaku a oukou a ka poe hana hale i haalele ai; ua lilo ia i pohaku kumu no ke kihi.
\q1 
\v 12 Aole loa he ola maloko o ka mea e ae; no ka mea, aole inoa e ae i haawiia mai malalo iho o ka lani, iwaena o na kanaka, i mea e ola'i kakou.
\b
\q1 
\v 13 A ike aku la lakou i ka wiwo ole o Petero a me Ioane, a ike aku la no hoi, he mau kanaka ao ole ia, a he mau kuaaina, kahaba aku la ko lakou naau; a hoomaopopo iho la lakou, ua noho pu laua me Iesu.
\q1 
\v 14 A ike aku la lakou i ke kanaka i hoolaia, e ku pu ana me lakou, aole hiki ia lakou ke hoopohala aku.
\q1 
\v 15 Kena mai la lakou ia laua e hele mawaho o kahi hookolokolo, alaila kukakuka iho la lakou,
\q1 
\v 16 I ae la, Heaha ka kakou e hana aku ai i keia mau kanaka; no ka mea, o ka hoailona mana kaulana a laua nei i hana'i, ua maopopo no ia i na mea a pau e noho nei ma Ierusalema; aole nae e hiki ia kakou ke hoole aku.
\q1 
\v 17 Aka, o palahalaha hou aku ia iwaena o na kanaka, e olelo hooweliweli aku kakou ia laua, i ole laua e olelo hou aku i kokahi kanaka ma keia inoa.
\q1 
\v 18 Hea mai la lakou ia laua, papa mai la, mai olelo iki aku, aole hoi e ao aku ma ka inoa o Iesu.
\q1 
\v 19 Olelo aku la o Petero laua me Ioane, i aku la ia lakou, E noonoo pono oukou; e pono anei imua o ke Akua ke hoolohe aku ia oukou, aole i ke Akua?
\q1 
\v 20 No ka mea, aole hiki ia maua ke olelo ole aku i na mea a maua i ike ai, a i lohe ai.
\q1 
\v 21 Olelo hooweliweli hou aku la lakou ia laua; alaila kuu aku la ia laua, aole nae i loaa ia lakou kekahi mea e hoopai aku ai ia laua, no na kanaka; no ka mea, ua hoomaikai aku na kanaka a pau i ke Akua no na mea i hanaia.
\q1 
\v 22 No ka mea, ua kanaha a keu na makahiki o ua kanaka la, maluna ona i hoikeia mai ai keia hoailona mana e ola'i.
\b
\q1 
\v 23 A kuuia mai la laua, hele mai la laua i ko laua poe, hai mai la i na mea a pau a ka poe kahuna nui a me ka poe kahiko i olelo mai ai ia lauaa.
\q1 
\v 24 A lohe mai la lakou, hookiekie lokahi ae la ko lakou leo i ke Akua, i aku la, E ka Haku, o oe no ke Akua nana i hana ka lani, a me ka honua, a me ke kai, a me na mea a pau oloko.
\q1 
\v 25 Ua olelo mai no oe ma ka waha o Davida, o kau kauwa, No ke aha la e kupikipikio ai ko na aina e, a me na kanaka hoi i noonoo ai i na mea lapuwale?
\q1 
\v 26 Ku ae la iluna na alii o ka honua, a hoakoakoa no hoi na luna e ku e aku i ka Haku, a i kona Mesia.
\q1 
\v 27 No ka mea, he oiaio no, ua akoakoa mai nei ma keia kulanakauhale, o Herode a me Ponetio Pilato, me ko na aina e, a me na kanaka o ka Iseraela, mo ke ku e i kau Keiki hoano ia Iesu i ka mea au i poni ai;
\q1 
\v 28 E hana hoi i na mea a kou lima a me kou naau i manao mua ai e hanaia mai.
\q1 
\v 29 Ano hoi, e ka Haku, e nana mai oe i ka lakou olelo hooweliweli; a e haawi mai i kau mau kauwa nei e hai aku i kau olelo me ka wiwo ole;
\q1 
\v 30 I ka hohola ana mai i kou lima, e hoola mai, a i hanaia hoi na hoailona a me na mea kupanaha, ma ka inoa o kau Keiki hemolelo o Iesu.
\b
\q1 
\v 31 A pau ka lakou pule ana, naueue ae la kahi a lakou i akoakoa ai; a ua piha iho la lakou i ka Uhano Hemolele, a hai aku la lakou i ka olelo a ke Akua me ka wiwo ole.
\b
\q1 
\v 32 A o ka poe o lakou i manaoio aku, hookahi o lakou naau, hookahi hoi manao; aole hoi i olelo kekahi, nona wale no kekahi waiwai ana i malama'i; no ka mea, hui pu ia ko lakou mea a pau.
\q1 
\v 33 Me ka mana nui i hoike mai ai na lunaolelo i ke alahouana o ka Haku o Iesu; a loaa iho la ia lakou a pau ka koomaikai nui ia.
\q1 
\v 34 Aole hoi i nele kekahi o lakou; no ka mea, o ka poe mea aina, a me ka poe mea hale, kuai lilo aku la lakou, a lawe mai la lakou i ke kala o na mea a lakou i kuai ai,
\q1 
\v 35 A waiho iho la ma na wawae o ka poe lunaolelo; a haawi aku la lakou i kela kanaka i keia kanaka, e like me kona hemahema.
\b
\q1 
\v 36 A o Iose o ka mea i kapaia e na lunaolelo, o Barenaba, (eia hoi ke ano ma ka hoohalike ana, o ke keiki a ka hooluolu,) he mamo na Levi, no ka aina i Kupero;
\q1 
\v 37 He aina no kona, a kuai lilo aku la ia, a lawe mai la i ke kala a waiho iho la ma na wawae o ka poe lunaolelo.
\c 5
\b
\q1 
\v 1 O KEKAHI kanaka, o Anania ka inoa, me Sapeire kana wahine, kuai lilo aku la i ka aina.
\q1 
\v 2 A hoana e iho la ia i kauwahi o ka uku, ua ike no hoi kana wahine, a lawe mai la i kekahi, a waiho iho la ma na wawae o ka poe lunaolelo.
\q1 
\v 3 I aku la o Petero, E Anania, no ke aha la i hoopiha mai ai o Satana i kou naau e wahahee aku i ka Uhane Hemolele, a e hoana e i kekahi mea i loaa mai ai no ka aina?
\q1 
\v 4 I ka wa e waiho wale ana, aole anei nou ponoi ia? a pau i ke kuaiia, aole anei ia oe ka malama? No ke aha la i komo ai keia mea maloko o kou naau? Aole oe i wahahee aku i kanaka, i ke Akua no.
\q1 
\v 5 A lohe iho la o Anania i keia olelo, hina iho la ia ilalo, a lele ae la ke aho. Kau iho la ka makau nui maluna iho o ka poe a pau i lohe i keia mau mea.
\q1 
\v 6 Ku ae la na kanaka ui, wahi iho la ia ia, lawe aku la iwaho, a kanu iho la.
\b
\q1 
\v 7 A mahope iho ekolu paha hora, komo mai la kana wahine, me ka ike ole i ka mea i hanaia'i.
\q1 
\v 8 I aku la o Petero ia ia, E hai mai oe ia'u, ua kuai anei olua i ka aina pela? I mai la kela, Ae, pela no.
\q1 
\v 9 Alaila, i aku la o Petero ia ia, Pehea la i hui pu ai ko olua manao, e hoao aku i ka Uhane o ka Haku? aia hoi ma ka ipuka na wawae o ka poe nana i kanu kau kane; e lawe aku no hoi lakou ia oe iho.
\q1 
\v 10 Alaila, hina iho la ia ma kona mau wawae, a lele aku la ke aho; a komo mai la ua poe ui la, a loaa iho la ia ua make, a lawe aku la lakou ia ia, a kanu aku la ma kahi o kana kane.
\q1 
\v 11 A kau mai ka makau nui maluna o ka ekalesia a pau, a me ka poe a pau i lohe i keia mau mea.
\b
\q1 
\v 12 Ua hanaia no hoi mawaena o kanaka, na hoailona a me na mea kupanaha he nui loa, e na lima o ka poe lunaolelo. (Lokahi ae la lakou a pau ma ka lanai o Solomona.
\q1 
\v 13 Auhe mea o ka poe i koe i makau ole ke hui pu mai me lakou; aka, mahalo aku la kanaka ia lakou.
\q1 
\v 14 Hui pu nui ia'e la i ka Haku ka poe i manaoio, na kane a me na wahine he nui loa.)
\q1 
\v 15 No ia mea, lawe mai la lakou i ka poe mai ma na alanui, a waiho iho la ia lakou maluna o na moe hilinai a me na wahi moe, i malu ae paha ke aka o Petero maluna o kekahi o lakou, i kona hele ana ae.
\q1 
\v 16 He nui ka poe i hele mai i Ierusalema, no ka kulanakauhale a puni, e lawe ana i ka poe mai, a me ka poe i loohia i na uhane ino; a hoolaia lakou a pau.
\b
\q1 
\v 17 Alaila ku ae iluna ke kahuna nui, a me ka poe a pau me ia, (he poe Sadukaio lakou,) ua piha loa lakou i ka ukiuki;
\q1 
\v 18 Hopu aku la ko lakou lima i ka poe lunaolelo, a hahao iho la ia lakou maloko o ka halepaahao.
\q1 
\v 19 Wehe mai la ka anela o ka Haku i na puka o ka halepaahao i ka po, a lawe mai la ia lakou mawaho, i mai la,
\q1 
\v 20 E hele oukou, a e ku maloko o ka luakini, e olelo aku i kanaka i na huaolelo a pau o keia ola.
\q1 
\v 21 A lohe lakou, komo ae la lakou iloko o ka luakini i ke kakahiaka nui, ao ae la lakou. A hiki mai la ke kahuna nui, a me ka poe me ia, hoakoakoa mai la lakou i ka ahalunakanawai, a me na lunakahiko a pau o ka Iseraela, a hoouna aku la ma ka halepaahao i laweia mai lakou.
\q1 
\v 22 A hiki ae la na ilamuku, aole loaa ia lakou maloko o ka halepaahao, hoi mai lakou, i mai la,
\q1 
\v 23 Loaa ia makou ka halepaahao ua paa, ua malu loa hoi, e ku ana no ka poe kiai ma na puka; a wehe makou, aohe kanaka oloko i loaa ia makou.
\q1 
\v 24 A lohe iho la ke kahuna nui, a me ka luna o ka luakini, a me na kahuna nui i keia olelo, kanalua iho la lakou, i ka hope o keia mea.
\q1 
\v 25 Alaila, hele mai kekahi, hai mai la ia lakou, i mai la, Aia hoi na kanaka a oukou i hahao ai iloko o ka halepaahao e ku ana maloko o ka luakini, e ao aku ana i kanaka.
\q1 
\v 26 Alaila, kii aku la ka luna a me na ilamuku, a lawe malie mai la ia lakou; no ka makau o lakou i kanaka o hailukuia mai lakou.
\q1 
\v 27 A laweia mai lakou, hookuia iho la lakou imua i ka ahalunakanawai; a ninau aku la ke kahuna nui ia lakou,
\q1 
\v 28 I aku la, Aole anei makou i papa aku ia oukou, mai ao aku ma keia inoa? Aia hoi, ua hoopiha oukou ia Ierusalema nei i ko oukou manao, a ke makemake nei oukou o hooili mai i ke koko o keia kanaka maluna o makou.
\b
\q1 
\v 29 Alaila, olelo mai o Petero, a me na lunaolelo, i mai la, E pono no ia makou ke malama i ka ke Akua, aole i ka ke kanaka.
\q1 
\v 30 O ke Akua o ko kakou poe kupuna, ua hoala hou mai oia ia Iesu, i ka mea a oukou i pepehi ai, a kau maluna o ka laau.
\q1 
\v 31 Oia ka ke Akua i hookiekie ae ma kona lima akau, i Alii, i Ola hoi, e haawi mai i ka Iseraela, i ka mihi, a me ke kala ana i ka hala.
\q1 
\v 32 O makou no kona poe hoike no keia mau mea; a me ka Uhane Hemolele hoi, o ka mea a ke Akua i haawi mai ai i ka poe malama ia ia.
\b
\q1 
\v 33 A lohe ae la lakou ia mea, walania lakou, kukakuka iho la e pepehi ia lakou.
\q1 
\v 34 Alaila, ku ae la kekahi iluna maloko o ka ahalunakanawai, he Parisaio, o Gamaliela kona inoa, he kumu ao kanawai, ua mahaloia e na kanaka a pau loa, kauoha ae la ia e hookaa iki aku i na lunaolelo mawaho.
\q1 
\v 35 I aku la oia ia lakou, E na kanaka o ka Iseraela, e ao oukou ia oukou iho, i ka mea a oukou e manao ai e hana aku i keia mau kanaka.
\q1 
\v 36 No ka mea, i na la i hala aku nei, ku ae la o Teuda, kaena iho la ia ia iho no, a hoopili aku la kekahi poe kanaka io na la eha paha haneri; pepehiia iho la ia; a o ka poe a pau i malama i kana, ua hoopuehuia lakou, a lilo ae la i mea ole.
\q1 
\v 37 A mahope ona ku ae la o Iuda, no Galilaia, i ka manawa o ka helu auhau ana, a alakai aku la ia i kekahi poe nui mahope ona; make iho la no hoi ia; a o ka poe a pau i malama aku i kana, ua hooauheeia lakou.
\q1 
\v 38 Ano hoi, ke olelo aku nei no hoi au ia oukou, mai mea iki aku oukou i keia poe kanaka, e waiho okoa aku no; no ka mea, ina no kanaka keia manao, a me keia hana, e pau wale no ia.
\q1 
\v 39 Aka, ina na ke Akua, aole hiki ia oukou ke hoolui, o loaa paha uanei oukou e paio ana i ke Akua.
\q1 
\v 40 Ae mai la lakou ia ia; a kii aku la lakou i na lunaolelo, hahau iho la, a papa aku la ia lakou, mai olelo aku ma ka inoa o Iesu, alaila kuu aku la.
\b
\q1 
\v 41 Hele aku la lakou, mai ke alo aku o ka ahalunakanawai mo ka olioli, no ka mea, ua manaoia he pono ke hoinoia mai lakou no kona inoa.
\q1 
\v 42 A i kela la i keia la, aole lakou i hooki i ka lakou ao ana aku, a me ka hai aku ia Iesu Kristo, ma ka luakini, a ia hale aku ia hale aku.
\c 6
\b
\q1 
\v 1 I A manawa, i ka wa i mahuahua'i na haumana, ohumu iho la ka poe Helene i ka poe Hebera; no ka mea, ua malama ole ia ko lakou poe wahinekanemake i ka manawalea ana i kela la i keia la.
\q1 
\v 2 Alaila, hoakoakoa iho la ka umikumamalua i na haumana a pau, i mai la, Aole e pono ia makou, ke waiho wale i ka olelo a ke Akua, a e malama i na papa ai.
\q1 
\v 3 No ia mea, e imi oukou, e na hoahanau, i mau kanaka i ehiku iwaena o oukou, a i ike pono ia, a piha hoi i ka Uhane Hemolele, a me ke akamai, a e hoonoho kakou ia lakou maluna o keia oihana.
\q1 
\v 4 A e hooikaika mau makou i ka pule, a me ka hoike olelo.
\b
\q1 
\v 5 Ua pono keia olelo imua o na kanaka a pau; a wae mai la lakou ia Setepano, he kanaka piha loa i ka manaoio a me ka Uhane Hemolele, a me Pilipo, a me Perokoro, a me Nikanora, a me Timona, a me Paremena, a me Nikolao ka mea i huli mai no Anetioka.
\q1 
\v 6 Hoonohoia iho la lakou imua o ka poe lunaolelo; a pule ae la lakou, a kau iho la i na lima maluna o lakou.
\b
\q1 
\v 7 Hoolahaia ae ka olelo a ke Akua, a mahuahua nui aku la ka poe haumana ma Ierusalema; a he nui no na mea o ka poe kahuna i manaoio.
\b
\q1 
\v 8 A ua piha o Setepano i ka manaoio a me ka mana, hana no ia i na mea mana, a me na mea kupanaha loa, iwaena o na kanaka.
\b
\q1 
\v 9 Aka, ku mai la kekahi poe no ka halehalawai i kapaia o na Liberetino, a me ko Kurene, a me ko Alekanederia, a me ko Kilikia, a me ko Asia, hoopaapaa mai la lakou ia Setepano.
\q1 
\v 10 Aole nae i hiki ia lakou ke ku imua o ke akamai a me ke koikoi o kana olelo ana.
\q1 
\v 11 Alaila, hoowalewale aku la lakou i mau kanaka, e olelo mai penei, Ua lohe makou ia ia nei e olelo ana i na olelo hoino ia Mose, a me ke Akua.
\q1 
\v 12 Hookonokono ae la lakou i na kanaka, a me na lunakahiko, a me ka poe kakauolelo, a lele mai la lakou, a hopu iho la ia ia, a alakai aku la imua o ka ahalunakanawai.
\q1 
\v 13 A hoonoho mai la lakou i mau mea hoike wahahee: i mai la lakou, Aole hooki keia kanaka i ka olelo ana i na olelo hoino i keia wahi hoano, a me ke kanawai:
\q1 
\v 14 No ka mea, ua lohe no makou ia ia e olelo ana, O Iesu no Nazareta, e hoohiolo no ia i keia wahi, a e hoololi hou no ia i na oihana a Mose i haawi mai ai na kakou.
\q1 
\v 15 A o ka poe a pau o noho ana ma kahi hookolokolo, haka pono aku la ia ia, a ike iho la i kona maka me he maka anela la.
\c 7
\b
\q1 
\v 1 NINAU aku la ke kahuna nui, Pela no anei keia mau mea?
\b
\q1 
\v 2 I mai la keia, E na kanaka, na hoahanau, a me na makua, e hoolohe mai; Ua ikea mai ke Akua nani e ko kakou kupuna e Aberahama, i kona noho ana ma Mesopotamia, i ka wa mamua aku o kona noho ana ma Harana:
\q1 
\v 3 A i mai la ia ia, E puka aku oe, mai kou aina aku, a mai kou poe hoahanau aku hoi, a e hele i ka aina a'u e kuhikuhi aku ai ia oe.
\q1 
\v 4 Alaila, hele aku la ia mawaho o ka aina o ko Kaledaio, a noho iho la ma Harana: a make kona makuakane, mai ia wahi mai i lawe mai ai oia ia ia, a i keia aina a oukou e noho nei.
\q1 
\v 5 Aole hoi i haawi ia ia ia i hooilina maloko ona, aole no i kahi e ku ai ka wawae: ua olelo mai nae oia e haawi mai ia ia ia i kuleana nona, a no kana poe mamo mahope ona; ia manawa, aole ana keiki.
\q1 
\v 6 I mai la ke Akua penei, E noho malihini ana kana poe mamo ma ka aina e; a e hooluluhi pio ia ilaila, a e hoomainoinoia mai lakou, i na makahiki eha haneri.
\q1 
\v 7 A o ka lahuikanaka a lakou i hookauwa ai, na'u no ia e hoopai aku, wahi a ke Akua: a mahope iho o keia mau mea, e puka mai lakou iwaho, a e malama mai ia'u ma keia wahi.
\q1 
\v 8 A haawi mai la ia ia i ka berita o ke okipoepoe ana; a hanau mai nana o Isaaka, a okipoepoe iho la ia ia i ka walu o ka la; a na Isaaka o Iakoba, a na Iakoba o na makualii, he umikumamalua.
\q1 
\v 9 A huahuwa iho la na makualii ia Iosepa, a kuai lilo aku la ia ia i ko Aigupita: aia no me ia ke Akua,
\q1 
\v 10 A nana no i hoopakele mai ia ia, mailoko mai o kona mau popilikia a pau, a haawi mai ia ia i ka lokomaikaiia, a me ke akamai imua o Parao, o ke alii o Aigupita; a hoolilo iho la ia ia, i luna maluna o Aigupita, a me kona hale a pau.
\q1 
\v 11 Ua hiki mai he wi maluna o ka aina a pau o Aigupita a me Kanaana, a me ka popilikia nui: aole i loaa i ko kakou mau kupuna ka mea ai.
\q1 
\v 12 A lohe ae la o Iakoba he ai ma Aigupita, hoouna mua aku la ia i ko kakou mau kupuna.
\q1 
\v 13 A i ka lua [o ka hele ana] hoike mai o Iosepa ia ia iho i kona poe hoahanau, a hoikeia'ku la ka ohana o Iosepa ia Parao.
\q1 
\v 14 Alaila, hoouna mai la o Iosepa, a kii mai la i kona makuakane ia Iakoba, a me kona poe hoahanau a pau; he mau uhane kanahikukumamalima lakou.
\q1 
\v 15 Iho ae la o Iakoba i Aigupita, a make iho la ia, a me ko kakou poe kupuna.
\q1 
\v 16 A laweia'ku la lakou i Sukema, a waiho iho la maloko o ka halelua a Aberahama i kuai mai ai i ke kala me na keiki a Hemora, a ka makuakane o Sukema mai.
\q1 
\v 17 A kokoke hiki mai ka wa i oleloia mai ai, a ke Akua i hoohiki mai ai ia Aberahema, mahuahua na kanaka, a lehulehu ae la ma Aigupita;
\q1 
\v 18 A ku mai la kekahi alii e ae, i ike ole ia Iosepa.
\q1 
\v 19 Hana maalea mai la ia i ko kakou lahuikanaka, a hana ino mai i na kupuna o kakou, a kiola aku la i ka lakou keiki hou, i ole lakou e ola.
\q1 
\v 20 Ia manawa i hanau ai o Mose, a ua maikai loa ia, a hanaiia oia i ekolu malama maloko o ka hale o kona makuakane.
\q1 
\v 21 A i kona wa i hooleiia'i mawaho, lawe ae la ke kaikamahine a Parao ia ia, a malama iho la i keiki nana.
\q1 
\v 22 Ua aoia o Mose i ke akamai a pau o ko Aigupita, a ua mana hoi ma na olelo, a ma na hana ana.
\q1 
\v 23 A hala na makahiki ona he kanaha, kupu iho la ka manao maloko o kona naau, e hele aku e ike i kona poe hoahanau, i ka poe mamo a Iseraela.
\q1 
\v 24 A ike aku la ia i kekahi mea e hana ino ia'ua, kokua aku la oia ia ia, a hooponopono mamuli o ka mea i hooluhi hewa ia mai, a pepehi aku la i ke kanaka o Aigupita.
\q1 
\v 25 Manao iho la ia e hoomaopopo auanei kona poe hoahanau e haawi mai ana ke Akua i ola no lakou, ma kona lima; aka, aole lakou i ike.
\q1 
\v 26 A ia la ae, ikea oia ia lakou e paio ana, a koi aku la oia ia laua e kuikahi, i ae la, E na kanaka, he mau hoahanau olua, no ke aha la olua e hana ino nei kekahi i kekahi?
\q1 
\v 27 Aka, o ka mea hana ino i ka hoa, kipaku aku la oia ia ia, i aku la, Nawai la oe i hoonoho ai i alii, a i lunakanawai maluna o makou?
\q1 
\v 28 Ke manao nei anei oe e pepehi mai ia'u, e like me kou pepehi ana i ke kanaka o Aigupita inehinei?
\q1 
\v 29 Holo aku la o Mose no keia olelo, a lilo i malihini ma ka aina Midiana, malaila i hanau ai nana, na keikikane elua.
\q1 
\v 30 A pau na makahiki hookahi kanaha, ikeia mai la he anela o ka Haku ia ia, ma ka waonahele, ma ka mauna Sinai, maloko o ka lapalapa ahi o ka laau ooi.
\q1 
\v 31 A ike aku la o Mose, kahaha aku la i keia mea i ikeia; a hookokoke aku la no hoi ia e makaikai, a hiki mai ka leo o ka Haku io na la,
\q1 
\v 32 Owau no ke Akua o kou mau makua, ke Akua o Aberahama, ke Akua o Isaaka, ke Akua a Iakoba. Haalulu iho la o Mose, a makau ke makaikai aku.
\q1 
\v 33 Olelo mai la ka Haku ia ia, E wehe oe i kou mau kamaa, mai kou mau kapuwai aku; no ka mea, o kahi au e ku nei, he aina hoano ia.
\q1 
\v 34 I ka nana ana, ua ike au i ka poino ana o ko'u poe kanaka ma Aigupita, a ua lohe no au i ko lakou kaniuhu ana, a ua iho mai nei au e hoopakele ia lakou: e hele mai hoi oe, a e hoouna aku au ia oe i Aigupita.
\q1 
\v 35 O ua Mose la, ka mea a lakou i hoole ai, me ka i ana'e, Owai ka mea i hoonoho ia oe, i alii, a i lunakanawai? oia no ka ke Akua i hoouna aku ai i alii, a i ola, ma ka lima o ka anela ana i ike aku ai iwaena o ka laau ooi.
\q1 
\v 36 Nana no lakou i alakai iwaho, e hana ana i na mea kupanaha, a me na hoailona ma ka aina o Aigupita, a me ke Kaiula, a ma ka waonahele i na makahiki hookahi kanaha.
\b
\q1 
\v 37 O ua Mose la keia, ka mea nana i olelo mai i na mamo a Iseraela, E hoala mai ana ka Haku, ko oukou Akua, i kekahi Kaula, mailoko mai o ko oukou poe hoahanau, e like me au nei; oia no ka oukou e hoolohe aku ai.
\q1 
\v 38 Oia no ka mea maloko o ka ekalesia ma ka waonahele me ka anela nana i olelo mai ia ia, ma ka mauna ma Sinai, a me ko kakou poe kupuna hoi; a loaa no ia ia na olelo hoola, e haawi mai ia kakou.
\q1 
\v 39 Aole i makemake ai ko kakou poe kupuna e hoolohe ia ia, aka, kipaku aku la, a ma ka naau, huli hou no lakou i Aigupita,
\q1 
\v 40 I ae la ia Aarona, E hana oe i mau akua no kakou, e hele aku mamua o kakou; no ka mea, o ua Mose la, ka mea i alakai mai ia kakou nei, mai ka aina o Aigupita mai, aole kakou i ike i kona wahi i lilo aku ai.
\q1 
\v 41 A ia mau la, hana iho la lakou i bipi keiki, a haawi aku la i mohai na ua kii akua la, a olioli iho la lakou i ka mea a ko lakou mau lima iho i hana'i.
\q1 
\v 42 Alaila huli aku la ke Akua, a kuu mai la ia lakou e hoomana aku i ka puali o ka lani; e like me ka mea i palapalaia maloko o ka buke a ka poe kaula, E ka ohana a Iseraela e, ua lawe mai anei oukou na'u i na mea i pepehiia, a me na mohai, i na makahiki hookahi kanaha ma ka waonahele?
\q1 
\v 43 A ua kaikai oukou i ka halelewa o Moloka, a me ka hoku o ko oukou akua o Remepana, i na kii a oukou i hana'i, i mea e hoomana aku ai ia lakou; a na'u no oukou e lawe aku ma o aku o Babulona.
\q1 
\v 44 Ua loaa no i ko kakou poe kupuna ma ka waonahele, ka halelewahoike, e like me ka olelo ana i olelo mai ai ia Mose, e hana ia mea me ke kumu ana i ike ai.
\q1 
\v 45 O ka mea hoi a ko kakou poe kupuna i lawe a kai mai ai me Iosua, i ke kuleana o ka lahuikanaka e a ke Akua i kipaku aku ai, mai ka maka aku o ko kakou poe kupuna, a hiki wale mai i na la o Davida.
\q1 
\v 46 Loaa no hoi ia ia ka lokomaikaiia mai imua i ke alo o ke Akua, noi aku la ia e hoomakaukau i wahi e noho ai, no ke Akua o Iakoba.
\q1 
\v 47 Na Solomona nae i kukulu i hale nona.
\q1 
\v 48 Aka, aole e noho ka Mea Kiekie maloko o na luakini i hanaia e na lima; e like me ka mea i oleloia mai ai e ke kaula,
\q1 
\v 49 O ka lani ko'u nohoalii, a o ka honua hoi ko'u keehana wawae. Heaha ka hale a oukou e kukulu ai no'u? wahi a ka Haku; heaha hoi ko'u wahi e maha ai?
\q1 
\v 50 Aole anei na ko'u lima i hana keia mau mea a pau?
\b
\q1 
\v 51 E ka poe ai oolea, ka poe i okipoepoe ole ia ma ka naau, a ma ka pepeiao, ua mau loa ko oukou pale ana i ka Uhane Hemolele; e like me ko oukou kupuna, pela no hoi oukou nei.
\q1 
\v 52 Owai kekahi mea o ka poe kaula i hoomaau ole ia e ko oukou poe kupuna? Ua pepehi hoi lakou i ka poe nana i hai mua mai i ka hiki ana mai o ka Mea Hemolele, ka mea a oukou i kumakaia iho nei a pepehi iho la.
\q1 
\v 53 Ua loaa no hoi ia oukou ke kanawai, na ka poe anela i hoolaha mai, aole nae oukou i malama.
\b
\q1 
\v 54 A lohe lakou i keia mau mea, walania iho la ko lakou naau, nau iho la ko lakou mau kui ia ia.
\q1 
\v 55 Aka, ua piha no ia i ka Uhane Hemolele, a haka pono aku la ia i ka lani, a ike aku la i ka nani o ke Akua, a me Iesu e ku ana ma ka lima akau o ke Akua;
\q1 
\v 56 I mai la ia, Aia hoi, ke ike aku nei au i na lani e hamama ana, a me ke Keiki a ke kanaka e ku ana ma ka lima akau e ke Akua.
\q1 
\v 57 Uwa aku la lakou me ka leo nui, papani iho la i ko lakou mau pepeiao, a lele lokahi mai la maluna ona;
\q1 
\v 58 Kiola aku la ia ia mawaho o ke kulanakauhale, a hailuku aku la; a waiho iho la na mea hoike i ko lakou aahu ma ka wawae o kekahi kanaka ui, i kapaia o Saulo.
\q1 
\v 59 Hailuku aku la lakou ia Setepano, kahea ana me ka olelo aku, E ka Haku, e Iesu, e hookipa aku oe i kuu uhane.
\q1 
\v 60 Kukuli iho la ia a hea aku la me ka leo nui, E ka Haku, mai kau oe i keia hewa maluna o lakou. A pau kana olelo ana pela, hiamoe iho la ia.
\c 8
\b
\q1 
\v 1 E AE mai ana no o Saulo i kona make. Ia la, hoomaau nui ia mai la ka ekalesia ma Ierusalema; hoopuehuia'ku la lakou a pau ma na aina o Iudea, a ma Samaria; koe no nae na lunaolelo.
\q1 
\v 2 Hoolewa aku la kekahi poe kanaka haipule ia Setepano, a kanikau loa lakou ia ia.
\q1 
\v 3 Luku ae la o Saulo i ka ekalesia, komo aku no ia i na hale, a kano mai i na kane a me na wahine, a hahao ae la ia lakou iloko o ka halepaabao.
\b
\q1 
\v 4 No ia mea, kaahele ae la ka poe i hoopuehuia, e hai aku ana i ka euanelio.
\q1 
\v 5 A iho ae la o Pilipo i ke kulanakauhale o Samaria, a hai aku la ia Kristo ia lakou.
\q1 
\v 6 Malama lokahi na lehulehu i na mea a Pilipo i olelo mai ai, me ka hoolohe, a me ka nana aku i na hoailona ana i hana'i.
\q1 
\v 7 No ka mea, ua nui loa ka poe uhane haukae i walaau aku me ka leo nui, puka mai la lakou mawaho o ka poe i uluhia'i; a nui loa ka poe lolo a me ka poe oopa i hoolaia mai.
\q1 
\v 8 Nui loa iho la ka olioli ma kela kulanakauhale.
\b
\q1 
\v 9 Malaila no kekahi kanaka, o Simona ka inoa, he kilo no ia mamua mai ma ia kulanakauhale, a pilihua ka lahuikanaka o Samaria ia ia, i kana olelo ana, o kekahi mea nui ia.
\q1 
\v 10 A malama mai la lakou a pau ia ia, mai ka poe unku mai, a ka poe nui, i ae la, Oia nei no ka mana nui o ke Akua.
\q1 
\v 11 Malama no lakou i kana, no ka mea, loihi ka manawa i hoopilihua ai oia ia lakou i ke kilokilo ana.
\q1 
\v 12 A i ko lakou manaoio ana ia Pilipo, i kana hai ana mai i ka euanelio no ke aupuni o ke Akua, a me ka inoa o Iesu Kristo, bapetizoia iho la lakou, na kane a me na wahine.
\q1 
\v 13 O Simona no hoi kahi i manaoio aku; a bapetizoia iho la no hoi ia, a e hoomau ana me Pilipo, e ike iho la ia i na mea mana, a me na hoailona nui i hanaia, pilihua iho la ia.
\b
\q1 
\v 14 A lohe ka poe lunaolelo ma Ierusalema, ua loaa i ko Samaria ka olelo a ke Akua, hoouna ae la lakou ia Petero a me Ioane io lakou la.
\q1 
\v 15 Iho ae la laua, pule aku la laua no lakou, i loaa ia lakou ka Uhane Hemolele.
\q1 
\v 16 No ka mea, ia manawa, aole ia i haule mai maluna o kekahi o lakou: ua bapetizo wale ia no lakou iloko o ka inoa o ka Haku, o Iesu.
\q1 
\v 17 Alaila, kau iho la laua i na lima maluna iho o lakou, a loaa iho la ia lakou ka Uhane Hemolele.
\q1 
\v 18 A ike iho la o Simona ua haawiia mai ka Uhane Hemolele ma ke kau ana o na lima o na lunaolelo, haawi aku la oia ia lana i kauwahi kala,
\q1 
\v 19 I aku la, E haawi mai olua i keia mana na'u, i loaa ai ka Uhane Hemolele i ka mea a'u e kau ai i na lima maluna iho.
\q1 
\v 20 I mai la o Petero ia ia, E lilo pu kau kala me oe i ka make, no kou manao e loaa mai ka makana o ke Akua ma ke kala.
\q1 
\v 21 Aole ou wahi kuleana, aole ou wahi lihi iki ma keia olelo; no ka mea, aole i pololei kou naau imua i ke alo o ke Akua.
\q1 
\v 22 Nolaila, e mihi oe i keia hewa ou, a e nonoi aku i ke Akua, ina paha e kalaia mai nou ka manao o kon naau.
\q1 
\v 23 No ka mea, ua ike au, aia no oe maloko o ke au awaawa, a me ka mea paa o ka hewa.
\q1 
\v 24 Olelo aku la o Simona, i aku la, E pule aku olua i ka Haku no'u i hiki ole mai ai keia mau mea a olua e olelo mai nei maluna o'u.
\b
\q1 
\v 25 Nolaila, a hoike laua me ka hai mai i ka olelo a ka Haku, hoi mai la laua i Ierusalema, e hai ana i ka euanelio i na kauhale he nui loa o ka poe Samaria.
\b
\q1 
\v 26 A olelo mai la ka anela o ka Haku ia Pilipo, i mai la, E ku oe, a e hele ma ke kukuluhema, ma ke ala e iho aku ai, mai Ierusalema a Gaza, he waonahele no hoi ia.
\q1 
\v 27 Ku ae la ia a hele; aia hoi, he kanaka no Aitiopa, he luna nui na Kanedake, ke aliiwahine o Aitiopa, oia no maluna o kona waiwai a pau, a ua hele mai no hoi ia i Ierusalema e hoomana;
\q1 
\v 28 E hoi aku ana ia e noho ana maloko o kona halekaa, a e heluhelu ana i ka ke kaula Isaia.
\q1 
\v 29 Olelo mai la ka Uhane ia Pilipo, E hele oe, e hoopili aku ia halekaa.
\q1 
\v 30 Holo ae la o Pilipo, a lohe iho la i kana heluhelu ana i ka ke kaula Isaia, i ae la ia, Ua ike anei oe i ka mea au e heluhelu nei?
\q1 
\v 31 I aku la kela, Pehea la e hiki ai ia'u, ke ao ole mai kekahi ia'u? Nonoi aku la oia ia Pilipo e pii ae, a e noho pu me ia.
\q1 
\v 32 Eia kahi o ka palapala ana i heluhelu ai, Ua alakaiia'ku la ia me he hipa la i ka make; a e like hoi me ka hipakeiki i pane ole imua o ka mea nana e ako, pela no ia, aole i ekemu kona waha.
\q1 
\v 33 I kona hoohaahaa ana, ua kailiia'ku la kona hoaponoia; nawai la hoi e hai mai i kona hanauna? no ka mea, ua laweia'ku no kona oia, mai ka honua aku.
\q1 
\v 34 Olelo aku la ua luna la, i aku la ia Pilipo, Ke uinau aku nei au ia oe, i olelo mai ke kaula i keia mea nowai, nona iho anei, no kekahi mea e paha?
\q1 
\v 35 Alaila, oaka ae la o Pilipo i kona waha, a ma ua palapala la kana hoomaka ana e hai mai ai ia ia, ia Iesu.
\q1 
\v 36 A i ko laua hele ana ma ke ala loa, hiki aku la laua ma kahi wai: Olelo ae ua luna la, Aia, he wai, heaha ka mea e keakea mai ia'u e bapetizoia'i?
\q1 
\v 37 I ae la o Pilipo, Ina i manaoio oe me ka naau a pau, ia a ua pono. I mai la kela, Ke manaoio nei au o Iesu Kristo, oia ke Keiki a ke Akua.
\q1 
\v 38 A kena aku la ia, E ku malie ke kaa. Iho pu iho la laua i ka wai, o Pilipo a me ua luna la, a bapetizo ae la oia ia ia.
\q1 
\v 39 A pii ae la laua, mai ka wai mai, kaili aku la ka Uhane o ka Haku ia Pilipo, aole ike hou ae ua luna la ia ia. Hoi aku no ia ma kona ala me ka olioli.
\q1 
\v 40 Ikea ae la o Pilipo ma Azoto. I kona hele ana, hai ae la ia i ka euanelio ma na kulanakauhale a pau, a hiki aku la i Kaisareia.
\c 9
\b
\q1 
\v 1 E HA aku ana o Saulo i ka olelo hooweliweli, a me ka luku aku i na haumana a ka Haku, hele aku la ia i ke kahuna nui,
\q1 
\v 2 Nonoi aku la i mau palapala no na halehalawai ma Damaseko, ina loaa ia ia kekahi mau mea no keia aoao, na kane paha, na wahine paha, e alakai mai no oia ia lakou me ka nakinakiia ma Ierusalema.
\q1 
\v 3 A i kona hele ana aku, a kokoke ia i hiki i Damaseko, anapu koko mai a puni iho la ia i ka malamalama mai ka lani mai.
\q1 
\v 4 Hina iho la i ka honua, e lohe aku la ia i leo, i ka i ana mai ia ia. E Saulo, e Saulo, no ke aha la oe e hoomaau mai nei ia'u?
\q1 
\v 5 I aku la ia, Owai oe, e ka Haku? I mai la ka Haku, O Iesu no wau ka mea au e hoomaau mai nei. O ke keehi ana i na mea oioi, he mea ia e eha ai nou.
\q1 
\v 6 I aku la ia me ka hopohopo a me ka haalulu, e ka Haku, heaha kou makemake e hana aku ai au? I mai la ka Haku ia ia, E ala oe iluna, a e hele i ke kulauakauhale, a e haiia no ia oe ka mea pono nau e hana aku ai.
\q1 
\v 7 A o na kanaka e hele pu ana me ia, ku iho la lakou me ka leopaa, ua lohe no lakou i ka leo, aole nae i ike aku i kekahi mea.
\q1 
\v 8 Ala mai la o Saulo, mai ka honua mai, oaka ae la kona mau maka, aole nae ia i ike i kekahi mea. Alakai lima aku Ia lakou ia ia a hiki aku i Damaseko.
\q1 
\v 9 Ekolu la o kona ike ole ana, aole ia i ai, aole no hoi i inu.
\b
\q1 
\v 10 Aia no ma Damaseko, kekahi haumana, o Anania kona inoa. I mai la ka Haku ia ia ma ka hihio, E Anania, I aku la kela, Eia no wau, e ka Haku.
\q1 
\v 11 I mai la ka Haku ia ia, E ku, a e hele ma ke kuamoo, i kapaia o Pololei, ma ka hale o Iuda, e imi i kekahi mea i kapaia o Saulo, no Tareso, no ka mea, aia hoi, ke pule la ia.
\q1 
\v 12 A ma ka hihio oia i ike aku ai i kekahi kanaka, o Anania kona inoa, e hele mai ana, a kau i ka lima maluna ona, i ike ia.
\q1 
\v 13 I aku la o Anania, E ka Haku e, ua nui loa na mea a'u i lohe ai i ua kanaka la, i ka nui o ka hewa ana i hana aku ai i kou poe haipule ma Ierusalema.
\q1 
\v 14 Ua loaa no hoi ia ia ka mana na ke kahuna nui mai, e hoopaa i na mea a pau i hea aku i kou inoa.
\q1 
\v 15 I mai la ka Haku ia ia, O hele: no ka mea, he ipu i kohoia na'u oia nei, e lawe aka ai i ko'u inoa imua o ko na aina e, a me na'lii, a me na mamo a Iaeraela.
\q1 
\v 16 No ka mea, e hoike aku ana au ia ia i ka nui o kona ohaeha ana no ko'u nei inoa.
\q1 
\v 17 Holo aku la o Anania a komo aka la i ka hale; a kau aku la i kona mau lima maluna ona, i aku la, E Saulo, e ke kaikaina, na hoouna mai nei ka Haku ia'u, o Iesu, ka mea au i ike ai ma ke ala au i hele mai ai, i ike oe, a i piha hoi i ka Uhane Hemolele.
\q1 
\v 18 Haule koke iho la mai kona mau maka mai me he mau unahi la, a ike koke iho la ia, a ku mai la, bapetizoia iho la.
\q1 
\v 19 A i ka lawe ana i ai, ikaika ae la. Noho iho la o Saulo, i kekahi mau la me na haumana ma Damaseko.
\q1 
\v 20 Hai koke aku la ia maloko o na halehalawai, ia Iesu, o ke Keiki ia a ke Akua.
\q1 
\v 21 Kahaha iho la ka poe a pau i lohe, i ae la; Aole anei keia ka mea i luku ai i ka poe i hea aku ma keia inoa ma Ierusalema, a hele mai hoi ia nei e lawe ia lakou me ka paa, i na kahuna nui?
\q1 
\v 22 Mahuahua nui aku la ka ikaika o Saulo: a pilipu ia ia ka poe Iudaio, e noho ana ma Damaseko i kona hoakaka ana, o ka Mesia no keia.
\b
\q1 
\v 23 A hala ia mau la, kukakuka ka poe Iudaio e pepehi ia ia.
\q1 
\v 24 Ike ae la o Saulo i ka lakou kuka ana. Hoomakakiu aku la lakou ma na puka i ke ao a me ka po e pepehi ia ia.
\q1 
\v 25 Lawe aku La na haumana ia ia i ka po, a ma ka hinai, hookuu iho la ia ia ilalo, mawaho o ka pa.
\b
\q1 
\v 26 A hiki aku la o Saulo i Ierusalema, hoao aku la ia e hui pu me na haumana, makau mai la lakou a pau ia ia, no ka mea, aole lakou i manao he haumana ia.
\q1 
\v 27 Lalau aku la o Barenaba ia ia, a alakai aku la ia ia i na lunaolelo, a hoakaka aku la i kona ike ana i ka Haku ma ke alanui, a me kana olelo ana mai ia ia, a me kana ao ikaika ana aku ma Damaseko, ma ka inoa o Iesu.
\q1 
\v 28 Me lakou pu iho la no ia ma Ierusalema, i ka hele ana aku a i ka hoi ana mai.
\q1 
\v 29 A e ao wiwo ole aku ia ma ka inoa o Iesu, me ka hoopaapaa aku i ka poe Helene; a kukakuka iho la lakou e pepehi ia ia.
\q1 
\v 30 A ike iho la na hoahanau, lawe aku la lakou ia ia i Kaisareia, a hoouna aku la ia ia i Tareso.
\b
\q1 
\v 31 A maluhia iho la na ekalesia ma Iudea a pau, a me Galilaia, a me Samaria hoi. Hookupaaia iho la lakou, e hele ana me ka makau i ka Haku, a me ka olioli o ka Uhane Hemolele, a mahuahua iho la lakou.
\b
\q1 
\v 32 A i ko Petero kaahele ana ma na wahi a pau, hiki ae la ia i ka poe haipule e noho ana ma Luda.
\q1 
\v 33 Loaa aku la ia ia ilaila kekahi kanaka, o Ainea kona inoa, ua moe ma ka moe no na makahiki ewalu, i ka mai lolo.
\q1 
\v 34 I mai la o Petero ia ia, E Ainea, ke hoola mai nei o Iesu Kristo ia oe; e ku, a nau no e holahola i kou wahi moe. Ku koke ae la ia.
\q1 
\v 35 O ka poe a pau, e noho ana ma Luda, a ma Sarona, ike aku la lakou ia ia, a huli iho la i ka Haku.
\b
\q1 
\v 36 Aia ma Iope kekahi haumana wahine, o Tabita ka inoa, ma ka hoohalike ana hoi, ua iia o Doreka, ua nui na hana maikai, a me na manawalea ana i hana'i.
\q1 
\v 37 Ia mau la mai iho Ia ia a make. Holoi aku ia lakou ia ia, a waiho iho Ia ma ke keena maluna.
\q1 
\v 38 Ua kokoke no o Luda ma Iope, a lohe ae la na haumana i ko Petero hiki ana mala i la, hoouna aku la lakou i elua kanaka ia ia, nonoi aku la laua aole e hookaulua i kona hele ana io lakou la.
\q1 
\v 39 Ku no la o Petero iluna, a hele pu me laua: a hiki aku la ia, alakai aku la lakou ia ia i ua keena la maluna; a ku pu me ia ua wahinekanemake a pau e uwe ana, a e hoike ana i na palule, a me na kapa komo a Doreka i hana'i i kona wa i noho pu ai me lakou.
\q1 
\v 40 Kipaku aku la o Petero ia lakou a pau mawaho, kukuli iho la a pule aku la; alaila haliu ae la ia ma ke kino, i aku la, E Tabita, e ala mai oe; oaka ao la kona mau maka, a ike ao la oia ia Petero, ala ae la ia iluna.
\q1 
\v 41 Haawi aku la o Petero i ka lima ia ia, hooku ao la ia ia iluna; kii aku la ia i ka poe haipule, a me na wahinokanemake, a hoike aku la ia ia e ola'na.
\q1 
\v 42 A ikea ao la ia mea ma Iope a pau; a nui na mea i manaoio aku i ka Haku.
\q1 
\v 43 A noho iho la ia ma Iopo i kekahi mau la, me Simona ka hanaili.
\c 10
\b
\q1 
\v 1 A IA ma Kaisareia kekahi kanaka, o Korenelio kona inoa, he lunahaneri no kekahi papakoa i kapaia ka Italia.
\q1 
\v 2 He haipule, a makau ia i ke Akua, a me ko kona hale a pau, manawalea nui no ia i kanaka, a pule mau no ia i ko Akua.
\q1 
\v 3 Ma ka hora aiwa paha o ka la, ike paka aku la ia ma ka hihio, i anela o ke Akua, e hele mai ana io na la, a i mai la ia ia, E Korenelio.
\q1 
\v 4 A i ka haka pono ana ia ia, makau iho la, i aku la, E ka Haku, heaha ia? I mai la kela ia ia, Ua pii iluna kau mau pule, a me kau mau manawalea, i mea hoomanao imua o ke Akua.
\q1 
\v 5 E hoouna aku oe ano i mau kanaka ma Iope, e kii ia Simona, i kapaia o Petero.
\q1 
\v 6 Ua hookipaia oia o Simona ka hanaili, aia i ka hale ma kahakai: oia ka mea nana e hai mai ia oe i ka pono au e hana aku ai.
\q1 
\v 7 A hala aku la ka anela i olelo aku ai ia ia, alaila hea aku la ia i na ohua ona elua, a me kekahi koa haipule o ka poe malama mau ia ia.
\q1 
\v 8 A hoike ana'ku i na mea a pau ia lakou, a hoouna aku la ia lakou i Iope.
\b
\q1 
\v 9 A ia la ao, i ko lakou holo ana, a hookokoke ana aku i ke kulanakauhale, pii ae la o Petero i kahi maluna o ka hale e pule ai, i ke ono paha o ka hora.
\q1 
\v 10 Pololi loa iho la, makemake ae la ia e ai; a i ko lakou hoomakaukau ana, haule mai maluna ona he akaku;
\q1 
\v 11 Ike aku la ia, ua weheia ka lani, a iho mai la kekahi puolo io na la, ua like me ke kuina nui i huiia na kihi eha, a kuuia iho la ilalo i ka honua:
\q1 
\v 12 Maloko ona na holoholona wawae eha a pau o ka honua, a me na mea hihiu, a me na mea kolo, a me na manu o ka lewa.
\q1 
\v 13 A hiki mai la kekahi leo io na la, E Petero; e ala, e pepehi, a ai.
\q1 
\v 14 I aku la o Petero, Aole loa pela, e ka Haku; no ka mea, aole loa au i ai i na mea pono ole a pau, a me na mea haumia.
\q1 
\v 15 Hiki hou mai ua leo la ia ia, o ka lua ia, O ka mea i huikalaia e ke Akua, mai kapa aku oe, he pono ole.
\q1 
\v 16 Ekolu hana ana mai pela; a lawe hou ia'ku ua puolo la i ka lani.
\b
\q1 
\v 17 I ko Petero kanalua ana iloko ona, i ke ano o ke akaku ana i ike ai, aia hoi, na kanaka i hoounaia mai e Korenelio, ua ninau mai i ka hale o Simona, a ku iho la lakou ma ka ipuka.
\q1 
\v 18 Hea mai lakou, ninau mai la, Ke noho nei anei o Simona maanei, o ka mea i kapaia o Petero?
\b
\q1 
\v 19 I ka noonoo ana o Petero i ua akaku la, olelo mai la ka Uhane ia ia, Aia hoi, ke imi mai nei na kanaka ekolu ia oe.
\q1 
\v 20 Ea, e ku oe, a e iho ilalo, a e holo pu mo lakou, mai kanalua; no ka mea, na'u no lakou i hoouna.
\q1 
\v 21 Iho mai la o Petero ilalo i ua poe kanaka la i hoounaia mai io na la e Korenelio, i mai la, Eia no wau ka mea a oukou i imi mai nei. Heaha ka mea a oukou i hele mai ai ia nei?
\q1 
\v 22 I mai la lakou, O Korenelio, he lunahaneri, he kanaka pono, e makau ana no hoi i ke Akua, ua ike maopopo ia e ka lahuikanaka a pau o na Iudaio, a na kauohaia ia e kekahi anela hemolele, mai ke Akua mai, e kii aku ia oe e holo i kona hale, i lohe oia i na olelo ma ou la.
\q1 
\v 23 Alaila hea aku la oia ia lakou, a hookipa mai la. A ia la ae, ku ae la ia a hele pu me lakou, a hele pu aku no rae ia kekahi poe hoahanau no Iope.
\b
\q1 
\v 24 A ia la ae, hiki aku la lakou i Kaisareia; a e kakali ana o Korenelio ia lakou, ua hoakoakoa oia i kona poe hoahanau a me kona poe hoalauna punahele.
\q1 
\v 25 A i ko Petero komo ana aku, halawai mai la o Korenelio me ia, a moe iho la kela ma kona mau wawae, a hoomana aku la.
\q1 
\v 26 Hoala mai la o Petero ia ia, i mai la, E ku iluna; no ka mea, he kanaka no hoi au.
\q1 
\v 27 A i ko lana kamailio pu ana, komo ae la ia iloko, a ike iho la i ka poe i hoakoakoaia mai he nui.
\q1 
\v 28 I mai la oia ia lakou, Ua ike no oukou, he mea kapu i ko kanaka Iudaio, e nonoho pu a me ka holo aku i kekahi mea o ka aina e; aka, ua hoike mai ke Akua ia'u, aole e kapa aku i kekahi kanaka, he pono ole, a he haumia.
\q1 
\v 29 No ia mea, i ko'u kiiia'e nei, hele mai no wau me ke kuipehi ole. Nolaila, ke ninau aku nei au, no ke aha la oukou i kii mai ai ia'u.
\q1 
\v 30 I aku la o Korenelio, Eha la mamua aku nei, e hookeai ana au, a hiki i keia hora; a i ka hora aiwa, pule iho la au ma ko'u hale, aia hoi, ku mai la kekahi kanaka imua o'u me ka aahu hinuhinu,
\q1 
\v 31 I mai la, e Korenelio, ua loheia kau pule, ua hoomanaoia no hoi kau mau hoomanawalea ana imua o ke Akua.
\q1 
\v 32 Nolaila e hoouna aku oe ma Iope, e kii ia Simona, i kapaia o Petero; ua hookipaia ia maloko o ka hale o Simona ka hanaili, aia ma ke kahakai; a hiki mai ia, nana no e olelo mai ia oe.
\q1 
\v 33 No ia mea, hoouna koke aku la au i ou la, a ua hana pono oe i kou holo ana mai. Kia noi makou a pau loa imua i ke alo o ke Akua e hoolohe i na mea a pau i kauohaia mai ai ia oe e ke Akua.
\b
\q1 
\v 34 A oaka ae la ko Petero waha, i mai la, Ke ike nei au he oiaio no, aole ke Akua i manao mai i ko waho o ke kanaka:
\q1 
\v 35 Aka, ma na luhui a pau, ua oluolu ia i na mea i makau ia ia, a me ka haua pono.
\q1 
\v 36 O ka olelo ana i hoouna mai ai i na mamo a Iseraela, o hai ana i maluhia ma o Iesu Kristo la; (oia no ka Haku no na mea a pau.)
\q1 
\v 37 Ua ike no oukou i ka olelo I kaulana ma Iudea a pau, ma Galilaia ka hoomaka ana, mahope iho o ka bapetizo a Ioane i hai mai ai.
\q1 
\v 38 O Iesu no Nazareta, ua poni ke Akua ia ia me ka Uhane Hemolele, a me ka mana; nana no i kaahele e hana maikai ana, a me ka hoola ana i na mea a pau i hooluhiia e ka diabolo; no ka mea, o ke Akua pu kekahi me ia.
\q1 
\v 39 He poe hoike makou i na mea a pau ana i hana'i ma ka aina o na Iudaio, a me Ierusalema; na lakou no ia i pepehi, a kau aku hoi maluna o ka laau.
\q1 
\v 40 Hoala mai ke Akua ia ia i ke kolu o ka la, a hoike mai no hoi ia ia ma ke akea:
\q1 
\v 41 Aole nae i kanaka a pau loa, aka, i ka poe hoike a ke Akua i wae mua ai, ia makou no, i ka poe i ai pu a i inu pu me ia mahope o kona alahouana, mai ka make mai.
\q1 
\v 42 Nana no makou i kauoha iho, e ao aku i kanaka, a e hoike aku, oia ka mea i hooholo e ia e ke Akua, i lunakanawai, no ka poe ola, a me ka poe make.
\q1 
\v 43 Ua hoike maopopo mai ka poe kaula a pau nona, e loaa ke kala ana o ka hala ma kona inoa, i ka poe a pau i manaoio ia ia.
\b
\q1 
\v 44 I ka Petero hai ana mai i keia mau olelo, haule mai ka Uhane Hemolele mai una o ka poe a pau i lohe ia olelo.
\q1 
\v 45 O ka poe ma ke okipoepoe i manaoio, a i hele pu me Petero, kahaha iho la lakou, no ka mea, na niniuiia mai ka haawina o ka Uhane Hemolele mai una o ko na aina e.
\q1 
\v 46 Ua lohe lakou i ka lakou olelo ana mai, ma na olelo e, a me ka hoonani aku i ke Akua. Alaila ninau mai la o Petero,
\q1 
\v 47 E hiki anei i kekahi ke papa mai i ka wai i bapetizo ole ia lakou nei, ka poe i loaa ka Uhane Hemolele, o like me makou?
\q1 
\v 48 Kauoha mai la ia, o bapetizoia lakou ma ka inoa o ka Haku. Alaila nonoi aku la lakou ia ia, e noho ia i kekahi mau la.
\c 11
\b
\q1 
\v 1 A LOHE iho la na lunaolelo, a me na hoahanau e noho ana ma Iudea, i ka loaa ana o ka olelo a ke Akua i ko na aina e;
\q1 
\v 2 A pii aku la a Petero i Ierusalema, o ka poe ma ke okipoepoe ana, koopaapaa mai la lakou ia ia,
\q1 
\v 3 I mai la, ua hele ka oe i ka poe okipoepoe ole ia, a ua ai pu oe me lakou.
\q1 
\v 4 Hoomaka iho la o Petero, ma ke kumu, a hoakaka mai la ia lakou, i mai la,
\q1 
\v 5 I kuu pule ana ma ke kulanakauhale ma lope, hihioia iho la wau, ike aku la au ma ke akaku, i ka iho ana mai o kekahi puolo, ua like me ke kuina nui i huiia na kihi eha; i kuuia mai ka lani mai, a kiki mai ia'u.
\q1 
\v 6 Haka pono aku la wau ia mea, noonoo iho la, a ike aku la i na holoholona wawae eha o ka honua, a me na mea hihiu, a me na mea kolo, a me na manu o ka lewa.
\q1 
\v 7 A lohe aku la au i ka leo i ka i ana mai ia'u, E Petero; e ala, e pepehi, a ai.
\q1 
\v 8 I aku la au, E ka Haku, aole loa pela; no ka mea aole i komo iloko o ko'u waha kekahi mea pouo ole, a i haumia.
\q1 
\v 9 I mai ua leo la ia'u, o ka lua ia, mai ka lani mai, O ka mea i huikalaia e ke Akua, mai kapa aku oe, he pono ole.
\q1 
\v 10 Ekolu haua ana mai pela; a huki hou ia'ku la na mea a pau iluna i ka lani.
\q1 
\v 11 Aia hoi, hiki koke mai la na kanaka ekolu, ma ka hale a'u i noho ai, ua hoounaia mai ia'u, mai Kaisareia mai.
\q1 
\v 12 I mai la ka Uhane ia'u, e hele pu me lakou, me ke kanalua ole. Hele pu aku la keia mau hoahanau eono me au, a komo aku la makou iloko o ka hale o ua kanaka la:
\q1 
\v 13 Hai mai la oia ia makou i kona ike ana i ka auela, maloko o kona hale, ku mai la ia, i mai ia ia, E hoouna aku oe i kanaka i Iope, e kii ia Simona i kapaia o Petero:
\q1 
\v 14 Nana no e hai mai ia oe na olelo, na mea e ola'i oe, a me kou poe ohua a pau.
\q1 
\v 15 A i ko'u hoomaka ana e olelo aku, haule mai ka Uhane Hemolele iluna iho o lakou, e like me kakou i kinohou.
\q1 
\v 16 Hoomanao iho la au i ka olelo a ka Haku, ana i olelo mai ai, Bapetizo no o Ioane me ka wai; aka, e bapetizoia auanei oukou i ka Uhane Hemolele.
\q1 
\v 17 A ina haawi mai ke Akua i ka makana na lakou, e like me kakou, ka poe i manaoio aku i ka Haku ia Iesu Kristo, he mea aha la wau e hiki ai ia'u ke hoole aku i ke Akua?
\q1 
\v 18 A lohe lakou i keia mau mea, pilipu iho la lakou, a hoonani aku la i ke Akua, i ae la, Oiaio no, ua haawi mai no ke Akua i ko na aina e kekahi i ka mihi e ola'i.
\b
\q1 
\v 19 Nolaila, o ka poe i hoopuehuia i ka hoomaau ana i puka mai no Setepano, helo no lakou a hiki i Poinike, a i Kupero, a i Anetioka, e hai aku ana i ka olelo i na Iudaio wale no.
\q1 
\v 20 Kekahi poe o lakou, he mau kanaka no Kupero a no Kurenaio kekahi, a hiki lakou i Anetioka, ao mai la lakou i ko Helene, e hai mai ana i ka euanelio o ka Haku o Iesu.
\q1 
\v 21 O ka lima pu o ka Haku kekahi me lakou; nui loa iho la ka poe i manaoio aku, a huli i ka Haku.
\b
\q1 
\v 22 Kaulana aku la ia mea a hiki i na pepeiao o ka ekalesia ma Ierusalema; hoouna ae la lakou ia Barenaba e hele i Anetioka.
\q1 
\v 23 A hiki ae la ia, a ike ae la i ka hoomaikaiia e ke Akua, olioli iho la ia, a hooikaika mai la oia ia lakou a pau, e hoopili lakou i ka Haku me ka manao ikaika o ka naau.
\q1 
\v 24 No ka mea, he kanaka maikai ia, ua piha hoi i ka Uhane Hemolele, a me ka manaoio; a nui loa ae la ka poe i huiia ma ka Haku.
\q1 
\v 25 Alaila hele aku la o Barenaba i Tareso, e imi ia Saulo:
\q1 
\v 26 A loaa iho la, alakai mai la ia ia i Anetioka. A puui no ko laua makahiki malaila, e hoakoakoa ana me ka ekalesia, a ao mai la i kanaka, he nui loa. Ma Anetioka i kapa mua ia mai ai na haumana, o na Kristiano.
\b
\q1 
\v 27 Ia mau La hele mai la kekahi mau kaula, mai Ierusalema mai a Anetioka.
\q1 
\v 28 Ku mai la kekahi o lakou, o Agabo kona inoa, hoike mai la, ma ka Uhane, he wi nui e hiki mai ana ma na aina a pau; a hiki io mai no i ke au ia Kelaudio Kaisara.
\q1 
\v 29 Alaila paa ka manao o na haumana, o kela mea keia mea e like me kona pono, e hoouka aku i ka manawalea na ka poe hoahanau i noho ma Iudea.
\q1 
\v 30 A hana io no hoi lakou ia mea, a hoouka aku la na ka poe lunakahiko, ma ka lima o Barenaba laua o Saulo.
\c 12
\b
\q1 
\v 1 A MA ia wa, o aku la na lima o Herode o ke alii e hoomaino aku i kekaki poe o ka ekalesia.
\q1 
\v 2 Pepehi aku la oia ia Iakobo ke kaikuaana o Ioane i ka pahikaua.
\q1 
\v 3 A ike aku la ia, ua maikai keia i na Iudaio, hana hou aku la no ia, a hopu iho la ia Petero. (Oia na la o ka barena hu ole.)
\q1 
\v 4 A paa, alaila hahao aku la oia ia ia iloko o ka halepaahao, a haawi aku la ia ia i kekahi poe koa, eha kauna, na lakou e malama. Manao iho la ia, a pau ka moliaola, alaila e lawe mai ia ia imua o na kanaka.
\q1 
\v 5 Kiaiia iho la o Petero maloko o ka halepaahao; aka, pule ikaika aku la ka ekalesia i ke Akua nona.
\q1 
\v 6 A i ka wa a Herode i manao ai e lawe mai ia ia iwaho, ia po, e moe ana no o Petero mawaena o na koa elua, ua nakinakiia i na kaulahao elua; a o na kiai mamua o ka puka, e malama ana no i ka halepaahao.
\q1 
\v 7 Aia hoi, he anela o ka Haku i ku mai la, a anapu mai la ka malamalama maloko o ka halepaahao; paipai mai la oia ma ko Petero aoao, hoala mai ia ia, i mai la, E ala koke oe. A haule iho la na kaulahao mai kona lima iho.
\q1 
\v 8 I mai la ka anela ia ia, E liki oe ia oe iho, a e hawele i kou kamaa. Hana iho la no ia pela. I mai la kela ia ia, E aahu oe i kou kapa, a e hahai mai ia'u.
\q1 
\v 9 Hele aku Ia hoi ia iwaho, a hahai aku la ia ia. Aole ia i ike, he oiaio ka mea i hanaia mai ai e ka anela; manao iho la ia, he hihio kana i ike ai.
\q1 
\v 10 A hala kekahi papa kiai, a me ka lua o ka papa, a hiki aku laua i ka pani hao e hiki aku ai i ke kulanakanhale; wehe wale mai ka puka no laua, a puka aku la lana mawaho, a hele aku la, a hala kekahi alanui; haalele koke iho la ka anela ia ia.
\q1 
\v 11 A loaa ia Petero ka manao maopopo, i iho li ia, Ua ike maopopo an, he oiaio no; ua hoouna mai ka Haku i kona anela, a ua hoopakele mai nei ia'u mai ka lima o Herode, a me ka manao a pau o na Iudaio.
\q1 
\v 12 I kona hoomaopopo ana ae, hele mai la ia i ka hale o Maria, ka makuwahine o Ioane, i kapaia o Mareko; he poe nui hoi ka i akoakoa mai malaila, e pule ana.
\q1 
\v 13 I kona kikeke ana ma ka puka o ka hale, hele mai la kekahi kaikamahine e hoolohe, o Rode kona inoa.
\q1 
\v 14 A ike iho la ia i ko Petero leo, aole ia i wehe i ka puka no ka olioli, holo aku la oia iloko, a hai aku la i ke ku ana mai o Petero ma ke alo o ka puka.
\q1 
\v 15 I mai la lakou ia ia. Ua hehena oe. Hoopaa loa aku la kela, he oiaio no. I mai la lakou, O kona anela.
\q1 
\v 16 Hoomau aku la o Petero e kikeke ana, a wehe ae la lakou a ike aku la ia ia, kahaba iho la ko lakou naau.
\q1 
\v 17 Peahi mai la me ka lima ia lakou, e noho malie, a hai mai la oia ia lakou i ka lawe ana mai o ka Haku ia ia mailoko mai o ka halepaahao. I mai la ia, E hai aku i keia mau mea ia Iakobo, a me na hoahanau. Haalele aku la oia ia wahi, a hele aku la i kahi e.
\b
\q1 
\v 18 I ke ao ana ae, nui loa iho la ka pioloke o ka poe koa, i ka mea i lilo aku ai o Petero.
\q1 
\v 19 Imi iho la o Herode ia ia, aole nae i loaa, alaila hookolokolo aku la ia i na kiai, kena ae la, e make lakou. A hele aku la ia mai Iudea aku a Kaisareia, a noho iho la ilaila.
\b
\q1 
\v 20 Huhu loa iho la o Herode i ko Turo, a mo ko Sidona. Hele lokahi mai la lakou io na la, hoomalimali mai la ia Belaseto, i ka mea nana i malama kahi moe o ko alii, nonoi mai la lakou i kuikahi; no ka mea, ua hanaiia ko lakou aina e ko ke alii.
\q1 
\v 21 A i ka la i hai mua ia'i, aahu iho la o Herode i ke kapa alii, a noho iho la ma ka nohoalii, e olelo aku ia lakou.
\q1 
\v 22 Uwa mai la na kanaka, E, he leo ka, no ke Akua, aole no ke kanaka.
\q1 
\v 23 Uhau koke mai la ka anela o ka Haku ia ia, no kona hoonani ole ana i ke Akua. Aiia iho la ia e na ilo, a kaili aku la ke aho.
\b
\q1 
\v 24 Ulu ae la ka olelo a ke Akua a mahuahua aku la.
\b
\q1 
\v 25 A pau ka hana a Barenaba, laua me Saulo, hoi aku laua mai Ierusalema aku, a lawe pu aku la ia Ioane i kapaia o Mareko.
\c 13
\b
\q1 
\v 1 MALOKO hoi o ka ekaleaia, ma Anetioka, kekahi mau kaula a me na kumu, o Barenaba kekahi, a me Simeona i kapaia o Nigera, a me Loukio no Kurene, a me Manaena i hanai pu ia me Herode ke kiaaina, a me Saulo.
\q1 
\v 2 I ko lakou hoomana ana i ka Haku, a me ka hookeai ana, i mai la ka Uhane Hemolele, E hookaawale oukou ia Barenaba laua me Saulo na'u, no ka hana a'u i hea aku ai ia laua.
\q1 
\v 3 Alaila hookeai iho la lakou, pule aku la, kau iho la na lima maluna o laua, a hookuu aku la ia laua.
\b
\q1 
\v 4 Na ka Uhane Hemolele laua i hoouna ae, e hele ae la laua i Seleukia; a malaila aku laua i holo ai a hiki i Kupero.
\q1 
\v 5 A hiki laua i Salami, hai mai la laua i ka olelo a ke Akua maloko o na halehalawai o na Iudaio; o Ioane no hoi kekahi hoalawehana na laua.
\q1 
\v 6 Kaahele aku la lakou i ka mokupuni a hiki i Papo, loaa ia lakou kekahi kilo, he kaula wahahee hoi ia, he Iudaio, o Bariesu kona inoa.
\q1 
\v 7 Aia no ia me Seregio Paulo, ke kiaaina, he kanaka akamai: a kii aku la oia ia Barenaba a me Saulo, makemake iho la ia, e lohe i ka olelo a ke Akua.
\q1 
\v 8 Aka, o Eluma, ke kilo (o kona inoa ia i ka hoolike ana) ku e aku la oia ia laua, manao iho la e hoohuli i ke kiaaina, mai ka manaoio aku.
\q1 
\v 9 Aka, o Saulo, (o Paulo no ia,) ua piha oia i ka Uhane Hemolele, haka pono mai la oia ia ia.
\q1 
\v 10 I mai la, auwe oe ka mea i piha i ka wahahee a me ka hewa a pau, he keiki na ka diabolo, he enemi no ka pono a pau, aole anei e hooki oe i kou keakea ana i na aoao pono o ka Haku?
\q1 
\v 11 Eia hoi, ano la e kau mai ana ka lima o ka Haku maluna ou, a e makapo no oe, aole e ike aku i ka la a hiki i kekahi manawa. Haule koke mai la maluna ona ka pouli a me ka moowini. Holoholo ae la ia e imi i mea alakai lima nona.
\q1 
\v 12 Alaila ike ae la ke kiaaina i ka mea i hanaia mai ai, manaoio aku la ia me ka mahalo aku i ke ao ana a ka Haku.
\b
\q1 
\v 13 Holo aku la o Paulo ma mai Papo a hiki mai i Perege no Pamepulia: a haalele a Ioane ia laua, a hoi aku la i Ierusalema.
\b
\q1 
\v 14 A haalele iho la laua ia Perege, a hele mai la i Anetioka no Pisidia, a komo ae la iloko o ka halehalawai i ka la Sabati, a noho iho la.
\q1 
\v 15 A mahope o ka heluhelu ana o ke kanawai a me ka na kaula, kii ae la na luna o ka halehalawai ia laua, i ae la, E na kanaka, na hoahanau, ina ia olua kekahi olelo hooikaika no na kanaka, ea, e olelo mai.
\q1 
\v 16 Ku mai la o Paulo, a peahi me ka lima, i mai la, E na kanaka o Iseraela, a me ka poe makau i ke Akua, e hoolohe mai.
\q1 
\v 17 Na ke Akua o keia poe kanaka o Iseraela i wae ae ko kakou kupuna, a hookiekie iho la ia poe kanaka i ko lakou noho ana i Aigupita, a lawe mai ia lakou, mailoko mai o ia wahi, me ka lima kakauha;
\q1 
\v 18 Nana no lakou i hiipoi ma ka waonahele i na makahiki he kanaha.
\q1 
\v 19 A pau na lahuikanaka ehiku ma ka aina ma Kanaana i ka anaiia, nana no i puunaue i ko lakou aina no lakou ma ka hailona ana.
\q1 
\v 20 A mahope iho o ia mau mea, haawi mai la ia i mau lunakanawai, i eha paha haneri makahiki a me kanalima, a hiki i ka wa o Samuela, ke kaula.
\q1 
\v 21 A ia wa mai, nonoi aku lakou i alii nui; a haawi mai la ke Akua ia Saulo i keiki a Kisa no lakou, he kanaka no ka ohana a Beniamina, hookahi no kanaha makahiki.
\q1 
\v 22 Alaila, kapae ae la kela ia ia, a hookiekie ae la ia Davida i alii no lakou; hoike mai la ia i mai la ia ia, Ua loaa ia'u o Davida a Iese, he kanaka ku pono i ko'u naau, nana no e hana i ko'u makemake a pau.
\q1 
\v 23 Ua hoopuka mai ke Akua ia Iesu noloko mai o kana poe mamo, e like me kana olelo mua ana mai, i mea ola no ka Iseraela.
\q1 
\v 24 Mamua o kona hiki ana mai, ua hai mua mai no o Ioane, i ka bapetizo ana o ka mihi i na kanaka a pau o Iseraela.
\q1 
\v 25 A hoopau o Ioane i kana hana, ninau mai la ia, Owai la wau i ko oukou manao? Aole au ia. Aia hoi, ke hele mai nei kekahi mahope o'u aole au e pono ke wehe i na kamaa o kona mau kapuwai.
\q1 
\v 26 E na kanaka, na hoahanau mamo a Aberahama, a me ka poe o oukou nei e makau i ke Akua, ua hoounaia mai ia oukou nei ka olelo o keia ola.
\q1 
\v 27 No ka mea, e ka poe i noho ma Ierusalema, a me ko lakou mau alii, aole lakou i ike ia ia, a me ka leo a na kaula, ka mea i heluhelaia i na la Sabati a pau, ua hoeko lakou ia leo i ko lakou hoohewa ana ia ia.
\q1 
\v 28 Aole ne i lona ia lakou kekahi hala e make ai, aka, aku la lakou ia e make ia.
\q1 
\v 29 A pau ne la na mea i nona, i ka hookaia e lakou lawe mai la lakou ia ia, mai ka lauu mai a maloko o ka hale.
\q1 
\v 30 Na ke Akua no ia i houla mai mai ka make mai.
\q1 
\v 31 Ikeia mai la no ia i na la he mai ka i hele pau me ia, mai mai a Ierusalema na lakou no ia i aku ai i kanaka.
\q1 
\v 32 Ke hui aku nei makou i ka olela mukai ia oukou, i ka olela hoopunipuni i i na kupuna;
\q1 
\v 33 Oia ka ke Akua i mai nui i ka lakou mue mama ia mukau, i kona ana mai ia Iesu; e like me ka mea i palapalaia ma ka Halelu elua, O oe no ka'u Keiki, i keia la wau i hoohanau ai ia oe.
\q1 
\v 34 A no kona hoala ana mai ia ia mai ka make mai aole hoi ia e hoi hou i ka palaho, i mai la ia penei, E haawi aku wau ia oukou i ka lokomaikai oiaio o Davida.
\q1 
\v 35 No ia mea, i mai no hoi ia ma kahi e, Aole oe e haawi aku i kau mea hoano e ike i ka palaho.
\q1 
\v 36 Aka, o Davida, hookauwa aku la ia na kona hanauna, ma ka manao o ke Akua, a hiamoe iho la ia, a hui pu ia iho la me kona poe kupuna, a ike i ka palaho.
\q1 
\v 37 Aka, o ka mea a ke Akua i hoala mai ai, aole ia i ike i ka palaho.
\b
\q1 
\v 38 No ia mea, e ike pono oukou, e na kanaka, na hoahanau, ma ona la, ua haiia'ku ia oukou ke kala ana o ka hala.
\q1 
\v 39 A o na mea a pau, aole e hike ia oukou ma ke kanawai o Mose ke hoaponoia, ua hoaponoia no ma ona la ka poe manaoio a pou.
\q1 
\v 40 Nolaila e malama pono oukou, o hiki mai ananei maluna o oukou, ka mea i oleloia mai ai e na kaula;
\q1 
\v 41 E ka poe hoowahawaha, e nana mai oukou, e pilihua hoi, a e hoomawale; no ka mea, ke hana nei au i ka hana i ko oukou mau la ina e hai aku kekahi ia oukou ia hana ina aole no oukou e mai.
\b
\q1 
\v 42 I ka hele ana o na Iudaio iwaha o ka halehaluwai, nonui aku la ma kanaka e ae i hai hou ia mai keia mau olelo ia lakou ia la Sabuti mai.
\q1 
\v 43 A i ka hoi ana o ke ka halehalawai, he nui Ioa ka poe haipule, a me ka poe haipule i huli mea i hahai aku ia Paula, lana me; na luna ne i olelo mai ia lakou a hooikaika mai ia lakou e ka pau ma ka maikai e ka Akua.
\b
\q1 
\v 44 A hiki i ka la Sabati pau Ioa ke kulanakauhale i ke, e i ka olelo a ke Akua.
\q1 
\v 45 A ike aku la ka poe Iudaio i ka nui e kanaka, pinu Ioa lakau i ka, hoopahala aku la i na mea a Paule i olelo ai, a olelo heino aku la.
\q1 
\v 46 Alaiila, hooikaika nui la e Pualo laua me Barenaba, i mai la, He mea pono ke hai mua ia ia oukou ka olelo a ke Akua; ua kapae oukou ia mea, a ua mauao oukou ia oukou iho, aole oukou e pono ke ola loa, eia hoi, ke huli aku nei maua i ko na aina e.
\q1 
\v 47 No ka mea, pela ka Haku i kauoha mai ai ia makou, Ua hoonoho wau ia oe i malamalama no ko na aina e, i lilo oe i mea e ola'i a hiki i na kukulu o ka honua.
\q1 
\v 48 A lohe ko na aina e i keia, olioli lakou, a hoonani aku la lakou i ka olelo a ka Haku: a o ka poe i waeia no ke ola loa, manaoio aku no lakou.
\q1 
\v 49 A haiia no boi ka olelo a ka Haku ma ia aina a pau.
\q1 
\v 50 Hookonokono aku la ka poe Iudaio i na wahine haipule koikoi, a me na mea kiekie o ke kulanakauhale, a pai mai la lakou ma ka hoomaau no Paulo a me Barenaba, a kipaku aku la ia laua mai ko lakou wahi aku.
\q1 
\v 51 A lulu aku la laua i ka lepo o ko laua mau wawae ia lakou, a hele mai la laua i Ikonio.
\q1 
\v 52 Piba loa iho la na haumana i ka olioli, a me ka Uhane Hemolele.
\c 14
\b
\q1 
\v 1 A LA ma Ikonio, komo ae la laua iloko o ka halehalawai o na Iudaio, a no ka laua olelo ana, nui loa na Iudaio a me na Helene i manaoio aku.
\q1 
\v 2 Aka, o ka poe Iudaio i hoomaloka, hookonokono lakou, a hoonaukiuki i na uhane o ko na aina e i na hoahanau.
\q1 
\v 3 Loihi loa no nae ko laua hoomau ana e olelo wiwo ole aku no ka Haku, nana no i hoike mai i ka oiaio o ka olelo o kona lokomaikai, a haawi mai la no hoi ia i na hoailona a me na mea kupanaba a ko laua lima i hana'i.
\q1 
\v 4 Mokuahana ae la ka ahakanaka o ke kulanakauhale; me na Iudaio kekahi, me na lunaolelo kekahi.
\q1 
\v 5 A i ka wa i hoao ai ko na aina e, a me ka poe Iudaio, me ko lakou alii, e hana ino aku ia laua, a e hailuku aku;
\q1 
\v 6 Ike e no laua, a mahuka aku la i na kulanakauhale o Lukaonia ia Lusetera a me Derebe, a me ka aina i puni mai.
\q1 
\v 7 A malaila laua i hai mai ai i ka euanelio.
\b
\q1 
\v 8 E noho ana kekahi kanaka ma Lusetera, ua nawaliwali na wawae, ua oopa ia mai ka opu mai o kona makuwahine, aole loa ia i hele:
\q1 
\v 9 Lohe aku la oia ia Paulo e olelo ana, a haka pono mai la oia ia ia, a ike iho la, he manaoio kona e hoolaia'i,
\q1 
\v 10 I mai la ia me ka leo nui, E ku pololei ae iluua ma kou mau wawae. Lelele ae la ia a hele aku la.
\q1 
\v 11 Ike aku la ka ahakanaka i ka mea a Paulo i hana'i, hookiekie aku la lakou i ko lakou leo, i aku la, ma ka olelo Lukaonio, Ua iho mai na akua io kakou nei, ma ke ano o kanaka.
\q1 
\v 12 Kapa aku la lakou ia Barenaba o Dia; a me Paulo hoi, o Hereme, no ka mea, ia ia no ka olelo.
\q1 
\v 13 Na ke kahuna o Dia, o ka mea ma ke alo o ua kulanakauhale la, nana no i lawe mai i na bipikane, a me na lei, ma na puka pa, manao iho la e kaumaha aku me ka ahakanaka.
\q1 
\v 14 A lohe na lunaolelo, o Barenaba laua roe Paulo, haehae laua i ko laua aahu, a holo aku la iwaena o ka ahakanaka, e hea aku ana,
\q1 
\v 15 I aku la, E na kanaka, no ke aha la oukou e hana mai ai i keia mau mea? he mau kanaka no maua, o ko kakou ano hookahi ano no; a ke hai aku nei no hoi maua ia oukou i ka olelo maikai, i huli ai oukou mai keia mau mea lapuwale aku a i ke Akua ola, ka mea nana i hana ka lani, a me ka honua, a me ke kai, a me na mea a pau iloko o lakou:
\q1 
\v 16 I na hanauna mamua, waiho wale aku no ia i ko na aina a pau, e hele ai ma ko lakou aoao iho.
\q1 
\v 17 Aka hoi, aole ia i waiho wale ia ia iho, me ka hoike ole ia mai; hana maikai mai no ia, a haawi mai no ia i ka ua, mai ka lani mai, a me na kau ai e hoopiha mai ana i ka naau i ka ai, a me ka olioli.
\q1 
\v 18 I ka laua olelo ana i keia mau mea, mai hiki ole no ia laua ke hoopaa mai i ka ahakanaka, i ole lakou e kaumaha aku na laua.
\b
\q1 
\v 19 Hele mai la kekahi poe Iudaio mai Anetioka mai, a mai Ikonio mai, hookonokono ae la i ka ahakanaka, a hailuku no ia Paulo, a kano aku la ia ia mawaho o ke kulanakauhale, manao iho la lakou, ua make loa ia.
\q1 
\v 20 Aka, i ke ku poai ana mai o na haumana ma o na la, ala mai la ia, a hele mai la iloko o ke kulanakauhale. A ia la ae, hele pu aku la ia me Barenaba i Derebe.
\q1 
\v 21 Hai mai la laua i ka olelo maikai i ko ia kulanakauhale, a hoohaumana mai la i kekahi poe, alaila hoi aku la i Lusetera, a me Ikonio, a me Anetioka,
\q1 
\v 22 E hookupaa ana i na Uhane o na haumana e hooikaika ana ia lakou e kupaa ma ka manaoio, no ka mea, me ka popilikia he nui loa, e komo ana kakou iloko o ke aupuni o ke Akua.
\q1 
\v 23 A e koho ana no lakou i na lunakahiko, ma kela ekalesia, keia ekalesia, pule aku la a me ka hookeai, a haawi aku la ia lakou i ka Haku, i ka mea a lakou i manaoio aku ai.
\q1 
\v 24 Kaahele ae la laua ia Pisidia, a hiki ae la i Pamepulia.
\q1 
\v 25 Hai mai la laua i ka olelo ma Perege, a iho ae la i Atalia.
\q1 
\v 26 Mailaila ko laua holo ana aka i Anetioka i kahi o laua i haawiia'ku ai i ka lokomaikai o ke Akua, no ka hana a laua i hoopau ai.
\q1 
\v 27 A hiki ana ae ilaila, hoakoakoa mai la laua i ka ekalesia, a hai mai la i na mea a ke Akua i hana mai ai me laua, a me kona wehe ana i ka puka o ka manaoio no ko na aina e.
\q1 
\v 28 Noho liuliu laua malaila me na haumana.
\c 15
\b
\q1 
\v 1 A IHO mai la kekahi poe, mai Iudea mai ao mai la lakou i na hoahanau, Ina aole oukou e okipoepoeia, e like me ka aono o Mose, aole hiki ia oukou ke hoolaia.
\q1 
\v 2 Nui iho la ke kamailio ku e, a me ka hoopaapaa ana o lakou me Paulo laua me Barenaba. Manao iho la lakou e hele o Paulo, me Barenaba, a me kekahi poe o lakou, i Ierusalema, i na lunaolelo, a me na lunakahiko, no keia manao.
\q1 
\v 3 Na ka ekalesia lakou i kai maikai aku, a kaahele lakou ma Poinike, a ma Samaria e hai mai ana i ka huli ana o ko na aina e; a hoolioli loa lakou i na hoahanau a pau.
\q1 
\v 4 A hiki lakou i Ierusalema, apo mai la ka ekalesia ia lakou, a me na lunaolelo, a me na lunakahiko, a hai aku la lakou i na mea a pau a ke Akua i hana mai ai mo lakou.
\q1 
\v 5 Ku mai la kekahi poe i manaoio, noloko mai o ka aoao Parisaio, i mai la, Pono ke okipoepoe ia lakou, a e kauoha aku e malama i ke kanawai o Mose.
\b
\q1 
\v 6 Hoakoakoa mai la ka poe lunaolelo, a me na lunakahiko, e kukakuka i keia mea.
\q1 
\v 7 Nui loa iho la ka hoopaapaa, alaila, ku mai la o Petero, i mai la ia lakou, E na kanaka, na hoahanau, ua ike no oukou i na la mamua, wau no ko kakou mea a ke Akua i wae ai, i lohe ko na aina e i ka olelo maikai ma ko'u waha, a e manaoio mai.
\q1 
\v 8 A na ke Akua, ka mea i ike i ka naau, i koike mai no lakou, e haawi ana ia lakou i ka Uhaue Hemolele, me ia ia kakou.
\q1 
\v 9 Aole ia i hookaawale iki mawaena o kakou a me lakou, hoomaemae no ia i ko lakou naau i ka manaoio ana.
\q1 
\v 10 No ia mea la ea, no ke aha la oukou e hoao aku nei i ke Akua e kau mai maluna o ka ai o na haumana i ka auamo hiki ole ia kakon a me ko kakou poe kupuna, ke amo?
\q1 
\v 11 Ke manaoio nei no hoi kakou, e hoolaia'i kakou i ka lokomaikai mai o ka Haku, o Iesu e like me lakou.
\b
\q1 
\v 12 Alaila noho malie ua ahakanaka la n pau, hoolohe aku la ia Barenaba laua me Paulo, i ko laua hai ana i na hoailona mana, a me na mea kupanaha a ke Akua i hana mai ai ma o laua la iwaena o ko na aina e.
\b
\q1 
\v 13 Mahope iho i ko laua oki ana alaila olelo mai la o Iakobo, i mai la, E na kanaka, na hoahanau, e hoolohe mai ia'u:
\q1 
\v 14 Ua hai mai noi o Simeona i ko ke Akua holo ana mai mamua aku nei e ike i ko na aina e, e lawe mai i kekahi poe kanaka no kona inoa, mailoko mai o lakou.
\q1 
\v 15 Ua pili no hoi ka olelo a na kaula i keia mea: penei ka palapala ana,
\q1 
\v 16 A mahope iho, e hoi hou mai au, a e kukulu hou ae i ka halelewa o Davida i hiolo; a e hookuikui hou au i na mea hina, a e kukulu hou ia;
\q1 
\v 17 I imi ai hoi na mea i koe o kanaka i ka Haku, a me ko na aina e a pau, ka poe i heaia ko'u inoa maluna o lakou, wahi a ka Haku, nana i hana keia mau mea.
\q1 
\v 18 Mai kinohi mai ua ikeia no e ke Akua kana hana ana a pau.
\q1 
\v 19 Nolaila hoi, ke manao aku nei au, aole e hookaumaha i ko na aina e i hoohuliia mai i ke Akua:
\q1 
\v 20 E palapala aku no nae kakou ia lakou, e hookaaokoa lakou i na mea haumia o na kii, a me ka moe kolohe, a me na mea umi wale ia, a me ke koko.
\q1 
\v 21 No ka mea, he poe no ko Mose, mai ka wa kahiko mai, ma na kulanakauhale a pau, nana e ao aku ma kana, na heluheluia no hoi kana maloko o na halehalawai, i na la Sabati a pau.
\b
\q1 
\v 22 Alaila manao iho la na lunaolelo, a me ua lunakahiko, a me ka ekalesia a pau, he mea pono ke hoouna aku me Paulo laua o Barenaba, i mau kanaka i waeia, mailoko mai o lakou, i Anetioka, o Iuda i kapaia o Baresaba, a me Sila, he mau kanaka koikoi laua mawaena o na hoahanau.
\q1 
\v 23 Palapala aku la lakou, ma ko lakou lima, penei: Ke aloha aku nei na lunaolelo, a me na lunakahiko, a me na hoahanau, i na hoahanau o na lahuikanaka e ma Anetioka, a ma Suria, a ma Kilikia;
\q1 
\v 24 No ka mea, ua lohe makou i kekahi poe hele aku, mai o makou aku, ua hoohihia ia oukou i na olelo, me ka hoohuli e ana i ko oukou uhane, i ka i ana ae, E okipoepoeia oukou, a e malama i ke kanawai; aole makou i kauoha aku ia lakou pela.
\q1 
\v 25 I ko makou akoakoa lokahi ana, manao makou, he mea maikai ke hoouna aku ia oukou i kekahi mau kanaka i kohoia, i hele pu me ka makou mau mea i alohaia, me Barenaba lana o Paulo.
\q1 
\v 26 Ua haawi ia mau kanaka i ko laua ola no ka inoa o ko kakou Haku o Iesu Kristo.
\q1 
\v 27 Nolaila, ua hoouna no hoi makou ia Iuda, laua me Sila, a na laua no e hai ana aku ma ka olelo i keia mau mea hookahi no.
\q1 
\v 28 No ka mea, ua manao ka Uhane Hemolele a me makou no hoi, aole e kau maluna o oukou, i kekahi mea kaumaha nui aku; o keia mau mea e pono ai wale no;
\q1 
\v 29 E hookaaokoa i ka io i mohaiia no na kii, a me ke koko, a me na mea i umi wale ia, a mo ka moe kolohe. Ina e pili ole oukou ia mau mea, ua hana maikai oukou. Aloha oukou.
\b
\q1 
\v 30 A kuuia mai la lakou, hele lakou i Anetioka; a hoakoakoa iho la lakou i ka ahakanaka, haawi aku la lakou i ua palapala la.
\q1 
\v 31 A i ko lakou heluhelu ana, olioli lakou no ka olelo hoolana.
\q1 
\v 32 He mau kaula no hoi o Iuda laua me Sila, a hooikaika aku la iaua i na hoahanau, me na olelo he nui loa, a hookupaa iho la ia lakou.
\q1 
\v 33 Noho iho la lakou i kokahi wa, kuu maikai ia'ku la lakou, mai na hoahanau aku, i hele aku i na lunaolelo.
\q1 
\v 34 Ua maikai no hoi i ko Sila manao e noho malaila.
\q1 
\v 35 A o Paulo laua o Barenaba, a me kekahi poe nui e ae, noho no lakou ma Anetioka, o ao ana, a e hai ana i ka olelo a ka Haku.
\b
\q1 
\v 36 A hala kekahi mau la, i mai la o Paulo ia Barenaba, E hele hon kaua o ike i ko kaua mau hoahanau ma na kulanakauhale a pau a kaua i hai aku ai i ka olelo a ka Haku, pehea i noho la.
\q1 
\v 37 Manao paa iho la o Barenaba, e lawe pu aku ia Ieane i kapaia o Mareko.
\q1 
\v 38 Aole nae i makemake o Paulo, e lawe pu i ka mea i haalele mai ia laua ma Pamepulia, a hele pu ole akai me laua i ka hana.
\q1 
\v 39 Nolaila, hoopaapaa ikaika ae la laua, a hookaawale iho la kekahi I kekahi; lawe pu aku la o Barenaba ia Mareko, a holo aku la i Kupero.
\q1 
\v 40 Koho aku la o Paulo ia Sila, a hele aku la, me ka haawiia i ka lokomaikai o ko Akua e na hoahanau.
\q1 
\v 41 Hele aku la i Suria, a me Kilikia, e hookupaa aku ana i na ekalesia.
\c 16
\b
\q1 
\v 1 A HELE aku la ia i Derebe a me Lusetera; aia hoi, malaila kekahi haumana, o Timoteo kona inoa, he keiki ia na kekahi wahine Iudaio i manaoio; a o kona makuakane hoi he Helene.
\q1 
\v 2 Ua hoike maikai ia oia e na hoahanau ma Lusetera a me Ikonio.
\q1 
\v 3 Makemake aku la o Paulo ia ia e hele pu me ia; lawe iho la oia ia ia, okipoepoe iho la, no ka poe Iudaio i noho ma ia mau wahi; no ka mea, us ike no hoi lakou a pau i kona makuakane, he Helene.
\q1 
\v 4 A i ko lakou kaahele ana i na kulanakauhale, haawi mai la ia lakou e malama i na olelo i hooholoia'i e na lunaolelo, a me na lunakahiko ma Ierusalema.
\b
\q1 
\v 5 Pela i hookupaaia'i na ekalesia ma ka manaoio, a hoonuiia ae la ka ekalesia i kela la i keia la.
\b
\q1 
\v 6 A hele lakou ma Perugia, a me ka aina o Galatia, papa mai la ka Uhane Hemolele ia lakou, mai hai aku i ka olelo ma Asia;
\q1 
\v 7 A hiki mai la lakou i Musia, hoao iho la e hele ia Bitunia; aka, aole i ae mai ka Uhane ia lakou.
\q1 
\v 8 A maalo ae ia Musia, iho aku la lakou a hiki i Teroa.
\q1 
\v 9 A ikea mai la e Paulo i ka po ka hihio; ku mai la kokahi kanaka no Makedonia, nonoi mai la ia ia, i mai la, E hele mai i Makedonia, e kokua mai ia makou.
\q1 
\v 10 I kona ike ana i ka hihio, imi koke aku la makou, e hele ia Makedonia, no ka mea, i ko makou manao ua kahea mai ka Haku ia makou, e hai aku i ka euanelio ia lakou.
\b
\q1 
\v 11 Nolaila hoi, hookuuia makou mai Teroa, a holo pololei aku la i Samoterake, a ia la iho, i Neapoli;
\q1 
\v 12 A malaila aku i Pilipi, oia ke kulanakauhale nui o ia aoao o Makedonia, he panalaau ia. Noho iho la makou ma ia kulanakauhale i kekahi mau la.
\q1 
\v 13 A i ka la Sabati hele ako la makou iwaho o ke kulanakauhale ma kekahi kahawai, i kahi e pule mau ia'i; noho iho la makou, e olelo aku i na wahine i akoakoaia.
\b
\q1 
\v 14 A o kekahi wahine, o Ludia kona mea, no ke kulanakauhale, no Tuateira, he wahine kuai i ka lole poni, na hoomana hoi i ke Akua, hoolohe mai la ia, a na ka Haku no i holahola kona naau, i hoolohe ia i na mea i oleloia'i e Paulo.
\q1 
\v 15 A bapetizoia iho la ia, a me ko kona hale, a nonoi mai la ia, i mai la, Ina manao oukou na malama pono wau i ka Haku, e hele mai i ko'u bale, e noho ai. Koi mai la oia ia makou.
\b
\q1 
\v 16 I ko makou hele ana i kahi e pule ai, halawai mai la kekahi kaikamahine me makou he uhane kilokilo koloko ona; oia no ka i waiwai nui ai kona mau haku, no kana kilokilo ana.
\q1 
\v 17 Hahai mai la no hoi oia ia Paulo a me makou, a kahea mai la, i mai, O keia mau kanaka, he mau kauwa lakou na ke Akua kiekie loa, na lakou no i hoike mai ia kakou i ke ala o ke ola.
\q1 
\v 18 Hana mai no ia i kela mea i na la he nui. Ana ae la o Paulo, a huli ae la, i aku i ua uhane la, Ke hookikina aku nei au ia oe, ma ka inoa o Iesu Kristo, e puka mai mawaho ona. Puka mai la no ia ia hora no.
\b
\q1 
\v 19 A ike iho la kona mau haku ua lilo ko lakou mea i waiwai ai, hopu mai la lakou ia Paulo laua me Sila, a kauo aku la ia lana i kahi kuai, i na'lii;
\q1 
\v 20 A alako aku la ia laua i na luna, i aku la, Ua nui loa ka hoohaunaele ana mai o keia mau kanaka Iudaio i ko kakou kalanakauhale,
\q1 
\v 21 A ke ao mai nei laua i ka aoao pono ole ia kakou ke apo aku a malama, no ka mea, ho poe Roma kakou.
\q1 
\v 22 Ku e pu mai la ka ahakanaka ia laua, a haehae iho la na luna i ko laua kapa, kauoha aku la e hahau ia laua.
\q1 
\v 23 Hahau nui mai la lakou ia laua, hahao aku la ia laua iloko o ka halepaahao, kauoha aku la i ka luna o ka halepaahao, e kiai ikaika loa ia.
\q1 
\v 24 I ka loaa ana o keia kauoha, hahao aku la oia ia laua maloko lilo o ka halepaahao, a hoopaa iho la i ko laua mau wawae ma ka laau.
\b
\q1 
\v 25 A i ko aumoe, pule aku la o Paulo laua o Sila, himeni iho la i ke Akua, a lohe mai la ka poo paahao ia laua.
\q1 
\v 26 Emo ole hoi he olai nm, haalulu ae la ke kumu o ka halepaahao; a wehe koke ia iho la na puka a pau, a hemo wale no hoi na mea paa o lakou a pau.
\q1 
\v 27 A o ka luna o ka halepaahao, ala iho la ia, mai ka hiamoe ana, ike ae la ua hamama na puka o ka halepaahao, unuhi aku la ia i ka pahikaua, e pepehi ia ia iho; no ka mea, manao iho la ia, ua holo na paahao.
\q1 
\v 28 A hea mai la o Paulo me ka leo nui, i mai la, Mai hana ino oe ia oe iho; no ka mea, eia no makou a pau.
\q1 
\v 29 Noi aku la ia i kukui, lele aku la iloko, e haalulu ana, moe iho la imua o Paulo laua me Sila,
\q1 
\v 30 A kai mai la ia laua mawaho, i aku la, E na haku, heaha ka'u e hana'i i ola au?
\q1 
\v 31 I mai la laua, E manaoio aku i ka Haku ia Iesu Kristo, a e ola oe a me ko ka hale ou.
\q1 
\v 32 Hai mai la laua ia ia i ka olelo a ka Haku, a i ka poe a pau maloko o kona hale.
\q1 
\v 33 Ia hora no o ka po, lawe ae la oia ia laua, a holoi iho la i ko laua mau palapu; a bapetizo koke ia iho la ia a me kona poe a pau.
\q1 
\v 34 Alakai aku la oia la laua iloko o kona hale, a kau mai i ka papaaina, a olioli iho la ia me kona mau ohua a pau, me ka manaoio aku i ke Akua.
\b
\q1 
\v 35 A ao ae la, hoouna mai la na luna i ilamuku, i mai la, E kuu aku i kela mau kanaka.
\q1 
\v 36 A hai aku la ka luna o ka halepaahao i keia mau olelo ia Paulo, Ua hoouna mai nei na luna e kuu wale aku ia olua; no ia mea, e puka iwaho, a e hele me ka maluhia.
\q1 
\v 37 Aka, i mai la o Paulo ia lakou, Ua hanau akea mai la lakou ia maua he mau Roms, me ka hooku ole i ka hala, a ua hahao mai maloko o ka halepaahao; a ke manao nei anei lakou e kipaku malu ia maua? Aole loa pela; na lakou no e kii mai, a e kai aku ia maua iwaho
\q1 
\v 38 Hai ae la na ilamuku i keia mau olelo i na luna; a lohe lakou, he mau Roma, makau iho la lakou.
\q1 
\v 39 Hele ae la lakou, nonoi ae la ia laua, a kai aku la mawaho, nonoi aku la e haalele laua ia kulanakauhale.
\q1 
\v 40 A hele aku la laua mawaho o ka halepaahao, a komo ako la iloko o ka hale o Ludia; a ike laua i na hoahanau, a hooikaika aku la ia lakou, alaila hele aku la laua.
\c 17
\b
\q1 
\v 1 A KAAHELE laua ma Amepipoli, a ma Apolonia, hele ae la laua i Tesalonike, a malaila kekahi halehalawai o ka poe Iudaio.
\q1 
\v 2 Komo aku la o Paulo io lakou la, e like me kona aoao mau, a ekoiu Sabati ana i kamailio aku ai ia lakou, ma ka palapala hemolele;
\q1 
\v 3 E wehewehe ana a e hooiaio ana, he pono ke make ka Mesia, a e ala hou ae mai ka make mai; a o Iesu nei, ka mea a'u e hai aku nei ia oukou, oia no ka Mesia.
\q1 
\v 4 A ae aku la kekahi poe o lakou, a hoopili aku la me Paulo laua me Sila, a me kekahi poe Helene haipule he nui loa, a me na wahine koikoi aole kakaikahi.
\b
\q1 
\v 5 Lili nae na ludaio manaoio ole, a kii aku la i mau kanaka ino o ka poe palaualelo, a hoakoakoa iho la i poe nui, a hoohaunaele iho la i ke kulanakauhale, lele aku la i ka hale o Iasona, imi iho la ia laua e alako i kanaka.
\q1 
\v 6 A i ka loaa ole o laua, kauo mai la lakou ia Iasona, a me kekahi poe hoahanau i na luna o ua kulanakauhale la, uwauwa mai la lakou, O keia poe nana i hoohaunaele i ko na aina a pau, ua hele mai hoi lakou ia nei;
\q1 
\v 7 Na Iasona i hookipa ia lakou. Ua hana lakou a pau ma ke ku e i ke kanawai o Kaisara; no ka mea, ke olelo mai nei lakou, he alii e o Iesu.
\q1 
\v 8 Pioloke iho la ka ahakanaka, a me na luna o ke kulanakauhale i keia mau mea, i ko lakou lohe ana.
\q1 
\v 9 A lawe lakou i uku panai no Iasona, a no kekahi poe o ae, alaila bookuu aku la ia lakou.
\b
\q1 
\v 10 Hoouna koko ae la na hoahanau ia Paulo laua me Sila i Beroia i kapo. A hiki laua ilaila, komo ae la iloko o ka halehalawai o ka poo Iudaio.
\q1 
\v 11 Oi aku ko lakou nei maikai, i ko Tesalonike, no ka mea, ua apo mai lakou i ka olelo me ka manao koke, huli no hoi lakou i kela la i keia la ma ka palapala hemolele, ina paha ho oiaio keia mau mea.
\q1 
\v 12 No ia mea, nui no lakou i manaoio mai, a me na wahine Helene koikoi, a me na kane aohe uuku.
\q1 
\v 13 A ike ka poe Iudaio no Tesalonike ua haiia ka olelo a ke Akua ma Beroia e Paulo, kele mai no hoi lakou ilaila, a hoohaunaele i kanaka.
\q1 
\v 14 Alaila hoouna koke ae la na hoabanau ia Paulo e hele i kai; aka, noho iho la o Sila laua me Temoteo malaila.
\q1 
\v 15 A o ka poe alakai aku ia Paulo, lawe aku la lakou ia ia i Atenai. A loaa ia lakou kahi kauoha no Sila laua me Timoteo, e hele koke laua io na la, alaila hoi mai la lakou.
\b
\q1 
\v 16 I ko Paulo kali ana ia laua ma Atenai, ua hooeoeuia kona naau iloko ona, i kona ike ana, ua lilo loa ke kulanakauhale i ka malama kii.
\q1 
\v 17 Nolaila, hoopaapaa aku la ia me ka poe Iudaio maloko o ka halehalawai, a me kekahi poe haipule, a ma kahi kuai no hoi i kela la i keia la, me ka poe i halawai me ia.
\q1 
\v 18 Hoopaapaa aku la ia ia kekahi poe akeakamai o ka poe Epikoureio, a me ka poe Setoiko. A i mai la kekahi poe, Heaha ka mea a keia haukae e olelo mai ai? I mai la kekahi, Me he kanaka e hai ana i na akua e keia; no ka mea, ua hai i mai la no oia ia Iesu ia lakou, a me ke alahouana.
\q1 
\v 19 Lalau aku la lakou ia ia, a lawe aku la ia ia i Areiopago, i aku la, E hiki anei ia makou ke ao i keia olelo hou au e hai mai nei?
\q1 
\v 20 No ka mea, ko lawo mai nei oe i na mea o na ko makou mau pepeiao, ke makemake nei makou e ike i ke ano o keia mau mea.
\q1 
\v 21 (O ko Atonai a pau a me ko laila malihini, o ka lakou hana wale no keia, o ka bai mai a me ka hoolohe aku i na mea hou.)
\b
\q1 
\v 22 Alaila ku mai la o Paulo mawaenakonu o Areiopago, i mai ia, E na kanaka o Atonai nei, ke ike nei au, ua ikaika loa oukou i ka malama i na akua, ma na mea a pau.
\q1 
\v 23 No ka mea, i ko'u hele ana ae, nana aku la au i ko oukou mea e hoomana'i, a ike au i kokahi lele, ua palapalaia maluna penei, NO KE AKUA IKE OLE IA. Nolaila o ka mea a oukou e hoomana naaupo aku ai, oia no ka'u e bai aku nei ia oukou.
\q1 
\v 24 O ke Akua nana i bana ke ao nei, a me na mea a pau iloko, o ka Haku no ia o ka lani a me ka honoa, aole ia e nobo maloko o ka hale i hanaia e na lima;
\q1 
\v 25 Aole hoi ia i malamaia e na lima kanaka, aole nae ia i nelo i kekahi mea; nana no i haawi mai nei ke ola no na mea a pau, a me ka banu, a me na mea a pau;
\q1 
\v 26 A nana no i hana i na lahuikanaka a pau i ke koko hookahi, i noho lakou ma ka honua nei; aia hoi ua paa i kona manao kahiko ka hope o na wa, a me na mokuna o ko iakou wahi e noho ai;
\q1 
\v 27 I imi lakou i ke Akua, ina paha lakou e haha a e loaa no ia, aole hoi ia e loihi aku o kela mea keia mea o kakou;
\q1 
\v 28 No ka mea, maloko ona e ola nei, a e hele nei, a e noho nei kakou; e like me ka olelo ana a kekahi haku mele o oukou, He poe keiki kakou nana.
\q1 
\v 29 Ina he poe keiki kakou na ke Akua, aole pono ia kakou ke manao i ko ke Akua ano, ua like ia me ke gula, a me ke kala, a me ka pohaku i kalaiia ma ke akamai a me ka noonoo o kanaka.
\q1 
\v 30 Hoomanawanui mai la ke Akua i na wa o keia naaupo ana; aka, keia manawa, ke kauoha mai nei ia i kanaka a pau ma na wahi a pau loa, e mihi.
\q1 
\v 31 No ka mea, ua hoomaopopo oia i ka la e hookolokolo ai i ko ke ao nei me ka pono, na ke kanaka ana i olelo ai; ua hoike pono mai hoi ia i ka oiaio o ia mea i na kanaka a pau, i kona hoala ana mai ia ia, mai ka make mai.
\b
\q1 
\v 32 A lohe lakou i ke alahouana o ka poe make, hoohenehene kekahi poe; a i mai la kekahi, E hoolohe hou aku paha makou ia oe i keia mea.
\q1 
\v 33 No ia mea, hele aku la o Paulo mai waena aku o lakou.
\q1 
\v 34 Aka hoi, pipili aku la kekahi poe ia ia, a manaoio aku la, o Dionusio, no Areiopago, kekahi o lakou, a me kekahi wahine o Damari kona inoa, a me kekahi poe pu me laua.
\c 18
\b
\q1 
\v 1 A MAHOPE iho o keia mau mea, haalele iho la o Paulo ia Atenai, a hele ae la i Korineto.
\q1 
\v 2 A loaa ia ia kekahi Iudaio, o Akula kona inoa, i hanauia ma Poneto, ia wa mua iho kona hiki ana mai, mai Italia mai, me kana wahine, o Perisekila, (no ka mea, ua kauoha aku la o Kelaudio i ka poe Iudaio a pau e haalele ia Roma,) a hele mai la ia io laua la.
\q1 
\v 3 A no ka like o kana oihana, noho ia me laua, a hana iho la; no ka mea, he poe humuhumu halelole lakou.
\q1 
\v 4 Kamailio ae la ia maloko o ka halehalawai, i na la Sabati a pau, e hoohuli i na Iudaio a me na Helene.
\b
\q1 
\v 5 A hiki mai la o Sila laua me Timoteo, mai Makedonia mai, alaila ikaika loa o Paulo ma ka olelo, a hoike aku la i na Iudaio ia Iesu, oia no ka Mesia.
\q1 
\v 6 Kuee aku la lakou, olelo hoino mai la, alaila lulu iho la ia i kona kihei, i mai la ia lakou, Aia maluna o ko oukou poo iho ko oukou koko; ua maemae au; ma keia hope aku e hele au i ko na aina e.
\b
\q1 
\v 7 Hele aku la ia mai ia wahi aku, a kipa aku la i ka hale o kekahi kanaka, o Iouseto kona inoa, ua malama i ke Akua; ua pili no hoi kona hale ma ka halehalawai.
\q1 
\v 8 A o Kerisepo ka luna o ka halehalawai, manaoio aku la ia i ka Haku me ko kona hale a pau. A lohe ko Korineto he nui loa, a manaoio aku la, a bapetisoia iho la.
\q1 
\v 9 Olelo mai la ka Haku ia Paulo ma ka hihio i ka po, Mai makau oe, aka, e olelo aku, mai hoomumule:
\q1 
\v 10 No ka mea, owau pu kekahi me oe, aole hoi e lele kekahi ia oe e hana ino aku ia oe; no ka mea, ua nui o'u poe kanaka maloko o keia kulanakauhale.
\q1 
\v 11 Noho iho la ia malaila, hookahi makahiki a me na malama keu eono, e ao ana ia lakou ma ka olelo a ke Akua.
\b
\q1 
\v 12 A i ka wa e noho ana o Galio i alii kiaaina no Akaia, lele lokahi mai la na Iudaio maluna o Paulo, a alakai aku la ia ia ma ka noho hookolokolo.
\q1 
\v 13 I aku la, Ke hooikaika aku nei keia i na kanaka e hoomana aku i ke Akua, ma ka mea ku ole i ke kanawai.
\q1 
\v 14 A ia Paulo e oaka ana i na waha, olelo ae la o Galio i na Iudaio, E na Iudaio, ina he hewa keia, a he mea kolohe, ina he pono ia'u ke hoomanawanui ia oukou:
\q1 
\v 15 Aka, ina he mea ninau no kahi huaolelo, a me na inoa, a me ke kanawai o oukou, ia oukou no ka nana aku ia mea. Aole loa wau ake e noho i lunakanawai ma kela mau mea.
\q1 
\v 16 Kipaku aku la oia ia lakou mai ka noho hookolokolo aku.
\q1 
\v 17 Alaila hopu aku la na Helene a pau ia Sosetene, i ka luna o ka halehalawai, kuikui aku la ia ia imua i ke alo o ka noho hookolokolo. Aole nae i manao o Galio i keia mau mea.
\b
\q1 
\v 18 Noho iho la o Paulo malaila i kekahi mau la, uwe ae la i na hoahanau, holo aku la ia i Suria, o Perisekila laua me Akula kekahi pu me ia. Ua amu e kona poo ma Kenekerea, no ka mea, ua hoohiki ia.
\q1 
\v 19 A hele mai la ia i Epeso, a malaila ia i haalele ai ia laua; a komo aku la ia iloko o ka halehalawai, a kamailio aku la i ka poe Iudaio.
\q1 
\v 20 Nonoi aku la lakou ia ia e noho hooliuliu iho me lakou, aole nae ia i ae mai.
\q1 
\v 21 A uwe aku la ia ia lakou, i aku la, He mea pono ia'u ke malama i keia ahaaina e hiki mai ana, ma Ierusalema; aka, e hoi hou mai no wau io oukou nei ke ae mai ke Akua. Holo aku la ia, mai Epeso aku.
\b
\q1 
\v 22 A pae aku la i Kaisareia, pii aku la ia, a uwe ae la i ka ekalesia, alaila hele ae la ia i Anetioka.
\q1 
\v 23 A noho malaila, i kekahi wa, a hele aku la, kaahele ae la i na aina a pau o Galatia a me Perugia, e hooikaika ana i na haumana a pau.
\b
\q1 
\v 24 Aia kekahi Iudaio, o Apolo kona inoa, i hanauia ma Alekanedero, he kanaka akamai i ka olelo, a hele ae la i Epeso, ua ikaika ia i na palapala hemolele.
\q1 
\v 25 Ua aoia mai no ia ma ka aoao o ka Haku; a ikaika ma ka naau, olelo mai la ia, a ao ikaika mai la i na mea o ka Haku, o ka Ioaue bapetizo ana wale no, kana i ike ai.
\q1 
\v 26 Hoomaka iho la ia e olelo wiwo ole mai maloko o ka halehalawai. A lohe o Akula laua me Perisekila, kii aku la laua ia ia, a hoakaka pono aku la ia ia i ka aoao o ke Akua.
\q1 
\v 27 Manao iho la ia e hele aku i Akaia, alaila palapala aku la na hoahanau i na haumana, kauoha aku la ia lakou e apo mai ia ia. A hiki aku la ia, kokua nui aku la ia i ka poe manaoio, no ka lokomaikaiia mai.
\q1 
\v 28 Hoohuli nui mai la ia i na Iudaio imua i ke alo o na kanaka, hoakaka ae la ma na palapala hemolele ia Iesu oia no ka Mesia.
\c 19
\b
\q1 
\v 1 I KA wa a Apolo i noho ai ma Korineto, kaahele o Paulo i na aina mauka, a hele aku la i Epeso; a loaa ia ia kekahi mau haumana,
\q1 
\v 2 I mai la ia lakou, Ua loaa anei ia oukou ka Uhane Hemolele i ko oukou manaoio ana? I aku la lakou ia ia, Aole makou i lohe no ka Uhane Hemolele.
\q1 
\v 3 I mai la kela ia lakou, I ke aha la oukou i bapetizoia'i? I aku la hoi lakou ia ia, I ka bapetizo a Ioane.
\q1 
\v 4 I mai la o Paulo, Bapetizo mai la o Ioane i ka bapetizo ana o ka mihi, i ka i ana mai i kanaka, e manaoio aku lakou i ka mea e hiki mai ana mahope ona, o ka Mesia no ia, o Iesu no.
\q1 
\v 5 A lohe lakou, bapetizoia iho la lakou ma ka inoa o ka Haku, o Iesu.
\q1 
\v 6 A kau aku la o Paulo i na lima maluna iho o lakou, hiki mai la ka Uhane Hemolele maluna o lakou; a olelo ae la lakou ma ka olelo e, a wanana mai la.
\q1 
\v 7 A oia mau kanaka a pau, he umikumamalua lakou.
\b
\q1 
\v 8 Hele mai la ia iloko o ka halehalawai, olelo wiwo ole mai la, ekolu malama ana i hooakaka ai, a i hoohuli mai ma na mea o ke aupuni o ke Akua.
\q1 
\v 9 A paakiki kekahi poe, a hoomaloka no hoi, olelo ino no lakou i keia aoao imua i ke alo o kanaka; alaila haalele oia ia lakou a hookaawale iho la i na haumana, a hoakaka mai la ia i kela la i keia la, maloko o ke kula o kahi Turano.
\q1 
\v 10 Ua hana mau ia keia mea i na makahiki elua; no ia mea, lohe ka poe a pau i noho ma Asia i ka olelo a ka Haku, a Iesu, o ka poe Iudaio a me ka poe Helene.
\q1 
\v 11 Na ke Akua no i hana i na mea mana ano e, ma na lima o Paulo.
\q1 
\v 12 No ia mea, laweia'ku la, mai kona kino aku, na hainaka a me na pale, no ka poe mai, a haalele iho la ka mai ia lakou, a puka aku la na uhane ino mailoko aku o lakou.
\b
\q1 
\v 13 Hoao nae kekahi poe Iudaio, he poe kuewa mahiki daimonio, a hea aku la lakou i ka inoa o ka Haku o Iesu maluna o ka poe i loohia e na uhane ino, i aku la, Ma o Iesu la, ka mea a Paulo e hai mai nei, ke hookikina aku nei makou ia oukou.
\q1 
\v 14 Aia malaila kekahi mau keiki na Sekena, he Iudaio, a he kahuna nui, ehiku lakou i hana pela.
\q1 
\v 15 Olelo mai la ka uhane ino, i mai, Ua ike no wau ia Iesu, a ua ike no hoi au ia Paulo, aka hoi, owai oukou?
\q1 
\v 16 A o ke kanaka maloko ona ua uhane ino la, lele mai la ia maluna o lakou, a lanakila iho la maluna o lakou, a hana ino mai la, a holo kohana aku la lakou mawaho o ia hale, ua eha hoi.
\q1 
\v 17 Ua ikea iho la keia e na Iudaio a pau, a me ua Helene, e noho ana ma Epeso. A kau mai ka makau maluna o lakou a pau, a ua hoonuiia ka inoa o ka Haku o Iesu.
\q1 
\v 18 He nui na mea o ka poe manaoio i hele mai, a hai mai, a hoike mai i ka lakou mau hana.
\q1 
\v 19 A he nui na mea o ka poe i hana kilokilo, i lawe mai i ka lakou mau buke, a puhi iho la i ke ahi imua o kanaka a pau; a helu lakou i ke kumukuai o ua mau buke la ke kuaiia, he kanalima tausani hapalua.
\q1 
\v 20 Pela i ulu ai me ka mana ka olelo a ka Haku, a lanakila iho la.
\b
\q1 
\v 21 A pau keia mau mea i ka hanaia, manao iho la o Paulo ma ka uhane, e kaahele ma Makedonia a me Akaia, alaila, e hele i Ierusalema, i ae la, A hiki au ilaila, ma ia hope aku, pono ia'u ke ike ia Roma.
\q1 
\v 22 Hoouna aku la ia ma Makedonia i kekahi mau hoalawehana ona elua, o Timoteo laua me Eraseto; a noho iho la ia ma Asia a liuliu.
\b
\q1 
\v 23 Ia manawa, aole okana mai ka pioloke no keia aoao.
\q1 
\v 24 No ka mea, he kanaka, o Demeterio ka inoa, he kahuna hana kala e hana ana i na luakini kala no Diana, a nui loa iho la ka waiwai i loaa mai i ka poe paahana.
\q1 
\v 25 Hoakoakoa ae la oia ia lakou, a me ka poe paahana ma ua mea me ia, i aku la, E na kanaka, ua ike no oukou, no keia hana i loaa mai ai ka kakou waiwai.
\q1 
\v 26 Ua ike no hoi oukou, a ua lohe, aole ma Epeso wale no, aka, ma Asia a pau, o Paulo nei i hooikaika aku ai a i hoohuli i kanaka, he nui loa, me ka i ana ae, aohe akua na mea i hanaia e na lima.
\q1 
\v 27 No ia mea, aole ka kakou oihana wale no ke aneane lilo i mea ole; aka, o ka heiau o keia akua nui o Diana kekahi, e hoowahawahaia, a kokoke e pau i ke kahuliia ka nani o ka mea i hoomanaia'i e ko Asia a pau, a me ko ke ao nei.
\q1 
\v 28 A lohe ae la lakou, piha iho la lakou i ka huhu, wawa aku la, i ae la, Nani ka mana o Diana o ko Epeso.
\q1 
\v 29 Piha iho la ke kulanakauhale a pau i ka haunaele. Hopu aku la lakou ia Gaio, a me Arisetareko no Makedonia, he mau hoahele no Paulo, a holo lokahi aku la lakou i ka hale kiaka.
\q1 
\v 30 Makemake iho la o Paulo e komo pu aku mawaena o na kanaka, aole nae na haumana i ae aku ia ia.
\q1 
\v 31 A o kekahi poe luna ma Asia, he poe makamaka nona, hoouna aku la lakou, kauoha ae la ia ia, aole hoike ia ia iho maloko o ka hale kiaka.
\q1 
\v 32 Nolaila uwauwa ae la kekahi poe i kekahi mea a me kela poe i kela mea; no ka mea, ua mokuahana ua ahakanaka la; a o ka nui o lakou, aole lakou i ike i ka lakou mea i hoakoakoa'i.
\q1 
\v 33 Hoeueu ae la lakou ia Alekanedero, noloko mai o ka lehulehu, na ka poe Iudaio ia i alakai mai. Peahi aku la o Alekanedero i ka lima, manao iho la ia e hoapono ia ia iho imua o na kanaka.
\q1 
\v 34 A ike lakou he Iudaio ia, kahea aku la lakou me ka leo hookahi, a liuliu, elua no hora. Nani ka mana o Diana o ko Epeso.
\q1 
\v 35 Hoolai iho la nae ke kakaolelo i ua ahakanaka la, i aku la, E na kanaka o Epeso nei, owai ke kanaka ike ole i ke kulanakauhale o Epeso nei he poe kakou e hoomaua ana ia Diana, i ka mea i haule no Iupita mai?
\q1 
\v 36 No ka hiki ole i kekahi ke hoole i keia mau mea, he pono ia oukou e hoolai, aole hoi e hana wikiwiki.
\q1 
\v 37 Ua kai mai oukou i keia mau kanaka, aole lakou he poe hao heiau, aole hoi i olelo hoino i ko oukou akua.
\q1 
\v 38 No ia mea, ina i loaa ia Demeterio, a me ka poe paahana me ia, ka hala o kekahi, ua maopopo na la hookolokolo, a me na lunakanawai. E hoopii lakou kekahi i kekahi.
\q1 
\v 39 Aka, ina imi oukou ma kekahi mea e, e hooponoponoia ia mea, ma ka ahakanaka ku i ke kanawai.
\q1 
\v 40 No ka mea, e hoopiiia mai paha auanei kakou, no ka haunaele o keia la, aole hoi e hiki ia kakou ke hai aku i ka mea i akoakoa'i keia ahakanaka.
\q1 
\v 41 A i ka olelo ana i keia mea, hookuu aku la ia i ua ahakanaka la.
\c 20
\b
\q1 
\v 1 MAHOPE iho o ka pau ana ae o keia haunaele, hoakoakoa iho la o Paulo i na hanmana, a honi ae la, a puka aku la iwaho, e hele i Makedonia.
\q1 
\v 2 Kaahele ae la ia ma ia mau aina, a hooikaika aku la ia lakou me ka olelo nui, hele aku la i Helene;
\q1 
\v 3 Noho iho la malaila ekolu malama: a i kona kokoko ana o holo i Suria, hoohalua aku la na Iudaio ia ia, nolaila, manao iho la ia e hoi ma Makedonia aku.
\q1 
\v 4 Hele pu aku la me ia a hiki i Asia o Sopatero, no Beroia, a me Arisetareko laua o Sekunedo no Tesalonike, a me Gaio laua o Timoteo no Derebe, a me Tukiko laua o Teropima no Asia.
\q1 
\v 5 Hele mua aku la lakou nei, a kakali iho la ma Teroa no makou.
\q1 
\v 6 A mahope iho o na la o ka berena hu ole, holo aku la makou mai Pilipi aku, po alima hiki aku makou io lakou la ma Teroa; malaila makou i noho ai i na la ehiku.
\b
\q1 
\v 7 A i ka la mua o ka hebedoma, i ko na haumana akoakoa ana o wawahi i ka berena, kamailio mai la o Paulo ia lakou, ua makaukau hoi e holo ia kakahiaka ae. Hooloihi hoi i ka olelo ana a hiki i ke aumoe.
\q1 
\v 8 Ua nui no hoi na kukui ma ke keena maluna, i kahi a makou i akoakoa ai.
\q1 
\v 9 Noho iho la kekahi kanaka opiopio ma ka pukamakani, o Eutuko kona inoa, ua kaumaha i ka hiamoe nui; a i ka Paulo kamailio loihi ana, pauhia iho la ia i ka hiamoe, a haule iho la ia ilalo, mai ke kolu o ka papa mai, a hapaiia ae la ia, ua make.
\q1 
\v 10 Iho mai la o Paulo ilalo, moe iho la maluna ona, puliki aku la ia ia, i mai la, Mai makau oukou; no ka mea, eia no kona ola maloko ona.
\q1 
\v 11 Pii hou aku la ia, wawahi ae la i ka berena, ai iho la, kamailio loihi mai la, a wanaao ae, alaila, hele aku la ia.
\q1 
\v 12 Lawe mai la lakou i ua kanaka opiopio la, ua ola, aole okana mai ko lakou olioli.
\b
\q1 
\v 13 Holo mua aku la makou ma ka moku, a holo aku la i Aso: manao iho la malaila e hoee ia Paulo maloko, no ka mea, pela ia i kauoha mai ai, no kona makemake a hele wawae ilaila.
\q1 
\v 14 A halawai mai la ia me makou ma Aso, hoee mai la makou ia ia, a holo ma Mitulene.
\q1 
\v 15 Holo aku la makou mailaila aku, a ao ae hiki ma Kio, a ia la ae, hiki makou i Samo, a noho ma Terogulio; a ia la ae, hele mai makou a Mileto.
\q1 
\v 16 Ua paa no ko Paulo manao, e holo ma Epeso ae, aole hoi e kali ma Asia; no ka mea, ua wikiwiki no ia, ina pono ia ia ke hiki i Ierusalema ma ka la Penetekota.
\b
\q1 
\v 17 Hoouna ae la ia, mai Mileto aku a Epeso, e kii i na lunakahiko o ka ekalesia.
\q1 
\v 18 A hiki lakou io na la, i mai la oia ia lakou, Ua ike no oukou, mai ka la makamua a'u i hiki mai ai i Asia nei, i ke ano o ko'u noho ana me oukou i na manawa a pau,
\q1 
\v 19 E hookauwa ana'ku na ka Haku me ka manao hoohaahaa a pau, a me na waimaka, a me na pilikia i loaa ia'u, no ka hoohalua ana o na Iudaio;
\q1 
\v 20 Aole hoi au i huna i kekahi mea pono, aka, ua hoike au ia oukou, ua ao aku hoi ia oukou ma ke akea, a ma kela hale a ia hale aku,
\q1 
\v 21 E hoike ana'ku i na Iudaio, a i na Helene, i ka mihi aku i ke Akua, a me ka manaoio aku i ka Haku, ia Iesu Kristo.
\q1 
\v 22 Eia hoi au, ke hele paa aku nei ma ka uhane i Ierusalema; aole nae au i ike i na mea e loohia ai ia'u ilaila:
\q1 
\v 23 Aka, ke hoike pono mai nei ka Uhane Hemolele ma na kulanakauhale a pau, i mai, Ua makaukau na kaula paa a me ka pilikia no'u.
\q1 
\v 24 Aole hoi au e manao i keia mau mea, aole no hoi e manao wau he mea makemake no'u kuu ola nei, i hoopau wau i ko'u hele ana me ka olioli, a me ka oihana i loaa mai ia'u na ka Haku mai, na Iesu; i hoike aku no hoi au i ka euanelio o ka lokomaikai o ke Akua.
\q1 
\v 25 Aia hoi, ano la, ua ike no wau, aole e ike hou ia ko'u maka e oukou a pau, ka poe au i hoike aku ai i ke aupuni o ke Akua, i ko'u hele ana mawaena o oukou.
\q1 
\v 26 No ia mea, ke hoike aku nei au ia oukou i keia la, ua maemae au i ke koko o na mea a pau.
\q1 
\v 27 No ka mea, aole au i molowa i ko'u hai ana aku ia oukou i ka makemake a pau a ke Akua.
\b
\q1 
\v 28 Nolaila e ao oukou ia oukou iho, a me ka ohana a pau, maluna ona i hooliloia'i oukou e ka Uhane Hemolele i poe kahu. E hanai i ka ekalesia o ke Akua, i ka mea ana i kuai ai i kona koko iho.
\q1 
\v 29 No ka mea, ua ike no au i keia, a hala au, alaila e komo mai na iliohae ino loa iwaena o oukou, aole loa lakou e minamina i ka ohana.
\q1 
\v 30 E ku mai no hoi kekahi poe kanaka no oukou iho, e olelo no i na mea hoopunipuni e hoohuli i haumana mamuli o lakou.
\q1 
\v 31 No ia mea, e makaala oukou, e hoomanao hoi i na makahiki ekolu a'u i hoomaha ole ai ke ao aku ia oukou a pau i ka po, a me ke ao, me na waimaka.
\q1 
\v 32 E na hoahanau, ano la, ke haawi aku nei au ia oukou i ke Akua, a i ka olelo o kona lokomaikai, i ka mea hiki ke hookupaa ia oukou, a me ka haawi ia oukou i hooilina mawaena o ka poe a pau i hoomaemaeia.
\q1 
\v 33 Aole loa au i kuko aku i ke kala, a me ke gula, a me ka aahu o kekahi.
\q1 
\v 34 Oiaio, ua ike no oukou, ua hookauwa mai keia mau lima no ko'u hemahema, a no ka poe me a'u.
\q1 
\v 35 Ua hoike aku no au ia oukou, i na mea a pau, a pela hoi e pono ai ke hana oukou, a e kokua aku no hoi i ka poe palupalu; e manao no hoi i ka olelo a ka Haku, a Iesu, i kana i ana mai, Ua oi aku ka pomaikai o ka haawi ana aku mamua o ka loaa ana mai.
\b
\q1 
\v 36 Olelo mai la ia i keia mau mea, kukuli iho la ia, a pule aku la me lakou a pau.
\q1 
\v 37 Uwe nui iho la lakou a pau, a hina lakou ma ka ai o Paulo, honi mai la ia ia;
\q1 
\v 38 No kela olelo ana i i mai ai, aole lakou e ike hou i kona maka, nolaila ko lakou kaumaha nui. Ukali aku la lakou ia ia ma ka moku.
\c 21
\b
\q1 
\v 1 A I ko makou kaawale ana aku, mai o lakou aku, ee aku la makou, a holo pololei mai la i Ko, a ia la ae, i Rode, a malaila mai i Patara.
\q1 
\v 2 A loaa ia makou kekahi moku e holo ana i Poinike, ee aku la makou, a holo aku la.
\q1 
\v 3 A ike aku la makou ia Kupero, haalele aku la makou ia wahi ma ka lima hema, a holo aku la makou i Suria, a pae makou ma Turo; no ka mea, malaila e hooleiia'i ka ukana o ka moku.
\q1 
\v 4 Loaa ia makou kekahi mau haumana, noho iho la makou ilaila i na la ehiku; olelo mai la lakou ia Paulo, na ka Uhane, i pii ole oia i Ierusalema.
\q1 
\v 5 A i ka pau ana o keia mau la, haalele iho la makou ia wahi a hele aku la; ukali aloha mai la lakou a pau, a me na wahine, a me na keiki ia makou, a hiki mawaho o na kulanakauhale la; kukuli iho la makou ma kahakai, pule aku la.
\q1 
\v 6 Honi ae la makou i kekahi i kekahi, ee aku la makou i ka moku; a hoi aku la lakou i ko lakou wahi.
\b
\q1 
\v 7 A pau ko makou holo ana ma ka moku, mai Turo mai, hiki makou i Petolemai, honi aku la i na hoahanau, a noho pu iho la me lakou, hookahi la.
\q1 
\v 8 A ia la ae, hele mai la makou ka poe me Paulo a hiki i Kaisareia; a komo aku la iloko o ka hale o Pilipo, o ke kahuna euanelio, oia kekahi o na hiku, a noho pu iho la makou me ia.
\q1 
\v 9 Eba ana mau kaikamahine puupaa i wanana mai la.
\q1 
\v 10 Noho iho la makou ilaila i na la he nui, a iho mai la kekahi kaula mai Iudea mai, o Agebo ka inoa.
\q1 
\v 11 A hiki mai la ia io makou la, lawe iho la ia i ko Paulo kaei, nakinaki iho la i kona mau lima a me na wawae ona iho, i ae la, Ke i mai nei ka Uhane Hemolele, Penei e nakinaki ai na Iudaio ma Ierusalema i ke kanaka nona keia kaei, a e haawi aku ia ia i na lima o ko na aina e.
\q1 
\v 12 A lohe makou i kela mau mea, noi ae la makou, a me kolaila poe ia ia, i pii ole ia i Ierusalema.
\q1 
\v 13 I mai la o Paulo, Heaha ka oukou e hana'i pela, me ka uwe mai, a nahae ko'u naau? No ka mea, ua makaukau no wau, aole e nakinaki wale no, aka, e make no hoi kekahi ma Ierusalema, no ka inoa o ka Haku o Iesu.
\q1 
\v 14 Aole loa ia i ae mai, oki ae la makou, i iho la, E hookoia no ko ka Haku makemake.
\b
\q1 
\v 15 A mahope iho o keia mau la, hoomakaukau iho la makou, a pii aku la i Ierusalema.
\q1 
\v 16 Hele pu aku la no me makou kekahi poe o na haumana, no Kaisareia, e alakai pu ana ia Menasona, no Kupero, he haumana kahiko ia, a hookipaia makou e ia.
\b
\q1 
\v 17 A hiki makou i Ierusalema, apo mai la na haumana ia makou me ka olioli.
\q1 
\v 18 A ia la ae, hele pu aku la o Paulo me makou io Iakobo la; malaila no na lunakahiko a pau.
\q1 
\v 19 Honi aku la oia ia lakou, hai pakahi aku la ia i na mea a pau a ke Akua i hana'i i ko na aina e, ma kana oihana.
\q1 
\v 20 A i ko lakou lohe ana, hoomaikai aku lakou i ke Akua, i mai la ia ia, E ke kaikaina, ke ike nei oe i ka nui o na umi tausani o na Indaio i manaoio; ua ikaika loa lakou a pau ma ke kanawai.
\q1 
\v 21 Ua lohe lakou nou, ua ao aku oe i na Iudaio a pau ma na aina e, e haalele i ke kanawai o Mose, a ua papa aku i ke okipoepoe ana i na keiki, aole hoi e hele ma ia aoao.
\q1 
\v 22 Heaha la hoi? E akoakoa io mai no ka ahakanaka; no ka mea, e lohe auanei lakou i kou hiki ana mai.
\q1 
\v 23 Nolaila, e hana oe i keia a makou e olelo aku ai ia oe. Eia no ia makou na kanaka eha, ua hoohiki lakou.
\q1 
\v 24 E lawe ae ia lakou, a e huikala ia oe iho me lakou, a e hui pu me lakou ma ka waiwai makana, i amu lakou i na poo; i ike na mea a pau, he mea ole keia mau mea a lakou i lohe ai nou; aka, ua hele pololei oe, ua malama hoi i ke kanawai.
\q1 
\v 25 I ka poe manaoio no na aina e, ua palapala makou i ka mea a kakou i manao ai, aole lakou e malama i keia mau mea, eia wale no, e hookaaokoa lakou i ko na akua e, a me ke koko, a me na mea i umi wale ia, a me ka moe kolohe.
\q1 
\v 26 Alaila lawe ae la o Paulo i ua mau kanaka la, a ia la ae, huikala pu ae la kela ia ia iho me lakou, a komo aku la i ka luakini, e hoike aku i ka malama ana o na la huikala, a hiki i ka wa e haawiia'ku ai ka mohai, no kela mea keia mea o lakou.
\b
\q1 
\v 27 A kokoke e pau kela mau la ehiku, ike ae la ka poe Iudaio no Asia ia ia, maloko o ka luakini, hoohaunaele ae la lakou i ka lehulehu, a hopu iho la ko lakou lima ia ia,
\q1 
\v 28 Kahea aku la lakou, E na kanaka o ka Iseraela, e alu. Eia ke kanaka nana i ao aku i kanaka a pau mai o a o i ka mea ku e i kanaka, a me ke kanawai, a me keia wahi; a lawe mai no hoi ia i mau Helene maloko o ka luakini, a ua hoohaumia i keia wahi hemolele.
\q1 
\v 29 (No ka mea, ua ike mua lakou me ia maloko o ke kulanakauhale, ia Teropima, no Epeso, kuhi iho la lakou ua kai mai o Paulo ia ia maloko o ka luakini.)
\q1 
\v 30 Ua pioloke ke kulanakauhale a pau, holo kiki mai la na kanaka a pau; hopu mai la lakou ia Paulo, kauo aku la lakou ia ia mawaho o ka luakini; papani koke iho la i na puka.
\q1 
\v 31 I ko lakou imi ana e pepehi ia ia, lohe aku la ka lunatausani koa, ua haunaele o Ierusalema a pau;
\q1 
\v 32 A lawe koke ae la ia i na koa, a me na lunahaneri, a holo kiki aku la io lakou la: a ike mai lakou i ua lunatausani la, a me na koa, oki ae la ko lakou pepehi ana ia Paulo.
\q1 
\v 33 A hiki mai ua lunatausani la, hopu mai la ia ia, a kauoha aku la e paa ia i na kaulahao elua; ninau mai la, Owai keia? Heaha ka mea ana i hana'i?
\q1 
\v 34 Uwauwa aku la kekahi i kekahi mea, a o kekahi i kekahi mea, iwaena o ka ahakanaka. Aole i hiki ia ia ke ike i ka oiaio, no ka haunaele, kauoha aku la ia, e alakai ia ia maloko o ka pakaua.
\q1 
\v 35 Aia ia iluna o na anuu, kaikaiia'ka la ia e na koa, no ka anehenehe o ua ahakanaka la.
\q1 
\v 36 No ka mea, hahai aku la ka ahakanaka, uwauwa aku la, E, e kai aku ia ia.
\b
\q1 
\v 37 A kokoke kaiia iloko o ka pakaua, i aku la o Paulo i ka lunatausani, E pono anei ia'u ke olelo aku ia oe? I mai la kela, Ua ike anei oe i ka ololo Helene?
\q1 
\v 38 Aole anei oe ka Aigupita, i ku iluna i na la mamua aku nei, a alakai ai i na kanaka eha tausani ma ka waonahele, he poe powa?
\q1 
\v 39 I mai la o Paulo, He kanaka Iudaio no wau, no Tareso i Kilikia, he kamaaina wau no kekahi kulanakauhale kaulana; ke nonoi aku nei au ia oe e ae mai ia'u e olelo aku i kanaka.
\q1 
\v 40 Ae mai la no kela; alaila, ku mai la o Paulo ma na anuu, peahi mai la ka lima i kanaka; hooneoneo nui iho la, olelo mai la ia ma ka olelo Hebera, i mai la,
\c 22
\b
\q1 
\v 1 E NA kanaka, na hoahanan, a me na makua, e hoolohe mai oukou i ka'u olelo hoakaka ia oukou.
\b
\q1 
\v 2 (A lohe lakou i kana olelo ana mai ia lakou ma ka olelo Hebera, hooneoneo loa iho la lakou; a i mai la ia,)
\b
\q1 
\v 3 He kanaka Iudaio no wau i hanauia ma Tareso i Kilikia, ma keia kulanakauhale nae au i hauaiia'i, ma na wawae o Gamaliela, ua aoia au mamuli o ke kanawai ikaika o na makua: ikaika loa no hoi au i ke Akua, e like me oukou i keia la.
\q1 
\v 4 Hana ino aku au a make ko keia aoao, me ka paa aku i na kane a me na wahine, a me ka haawi ia lakou i na halepaahao.
\q1 
\v 5 Ua ike pono ke kahuna nui, a me ka papa a pau o na lunakahiko; na lakou ka'u palapala i loaa mai ai no na hoahanau, a hele au ma Damaseko, e lawe mai i ka poe paa malaila i Ierusalema, i hoopaiia lakou.
\q1 
\v 6 A i ko'u hele ana a kokoke i Damaseko, i ke awakea, anapu koke mai la ka malamalama nui, mai ka lani mai, a puni au.
\q1 
\v 7 A hina iho la au i ka lepo, a lohe aku la au i ka leo, i ka i ana mai ia'u, E Saulo, e Saulo, no ke aha la oe e hoomaau mai nei ia'u?
\q1 
\v 8 I aku la au, E ka Haku e, owai oe? I mai la kela ia'u, O Iesu no wau no Nazareta, ka mea au e hoomaau mai nei.
\q1 
\v 9 A ike aku la ka poe me au i ka malamalama, a makau iho la; aole lakou i lohe i ka leo o ka mea i olelo mai ai ia'u.
\q1 
\v 10 I aku la au, E ka Haku e, heaha ka'u e hana'i? I mai la ka Haku ia'u, E ku, a e hele i Damaseko, a malaila e haiia mai ai ia oe na mea a pau i hoomakaukauia'i nau e hana'i.
\q1 
\v 11 A i ka hiki ole ana ia'u ke ike, no ka nani o ia malamalama, alakai lima ia'ku au e ko'u poe hoahele, a hiki i Dameseko.
\q1 
\v 12 A o Anania, he kanaka haipule ma ke kanawai, i hoike pono ia e na Iudaio a pau i noho ilaila,
\q1 
\v 13 Oia ka i hele mai ia'u, ku mai, i mai ia'u, E Saulo, e ke kaikaina, e ike oe. Ia hora no ike aku la au ia ia.
\q1 
\v 14 I mai la ia, Ua koho mai ke Akua o ko kakou poe kupuna ia oe, i ike oe i kona makemake, a e ike aku hoi i ka Mea pono, a e lohe hoi i ka leo o kona waha.
\q1 
\v 15 No ka mea, e lilo ana oe i mea hoike nona i kanaka a pau, ma na mea au i ike ai, a i lohe ai no hoi.
\q1 
\v 16 Ano hoi, e aha ana? E ku iluna, e bapetizoia, e holoi aku i kou hewa, a e hea aku i ka inoa o ka Haku.
\q1 
\v 17 A i ko'u hoi hou ana mai i Ierusalema nei, i ka'u pule ana maloko o ka luakini, loaa ia'u ka hihio;
\q1 
\v 18 A ike aku la au ia ia i ka i ana mai ia'u, E wiki oe, a e hele koke oe mawaho o Ierusalema nei; no ka mea, aole lakou nei e malama mai i ka mea au e hoike aku ai no'u.
\q1 
\v 19 I aku la au, E ka Haku e, ua ike no lakou, owau no ka mea i hookomo iloko o ka halepaahao, a hahau aku la maloko o na halehalawai, i ka manaoio aku ia oe:
\q1 
\v 20 A i hookaheia'i hoi ke koko o Setepano, o kou mea hoike, e ku ana no wau malaila me ka ae aku i kona make, a na'u no i malama ka aahu o ka poe i pepehi ia ia.
\q1 
\v 21 I mai la kela ia'u, O hele; no ka mea, e hoouna aku ana au ia oe i kahi loihi aku, i ko na aina e.
\b
\q1 
\v 22 Hoolohe aku la lakou ia ia a hiki i keia hua, alaila hookiekie loa ae la lakou i ko lakou leo, i ae la, E kiola aku ia ia pela, mai ka honua aku; no ka mea, aole ia e pono ke ola.
\q1 
\v 23 I ko lakou kahea ana pela, hemo aku la lakou i ko lakou aahu, a kuehuehu aku la lakou i ka lepo iluna ma ka lewa;
\q1 
\v 24 Kauoha ae la ka lunatausani e kai ia ia iloko o ka pakaua, kauoha ae la, e hoopoipoi ia ia me ka hahau aku, i ike pono ia i ke kumu a lakou i uwauwa'i ia ia.
\q1 
\v 25 Hikii iho la lakou ia ia i na kaula ill, i aku la o Paulo i kekahi lunahaneri e ku ana ilaila, He mea pono anei ke hahau oukou i ka Roma, me ka hooku ole mai i ka hala?
\q1 
\v 26 A lohe ka lunahaneri, hele aku la ia a hai aku la i ka lunatausani, i aku la, Heaha kau e hana nei? no ka mea, he Roma keia.
\q1 
\v 27 Alaila, hele mai la ka lunatausani, i mai la ia ia, E hai mai oe ia'u, he Roma anei oe? I aku la ia, Ae.
\q1 
\v 28 I mai la ua lunatausani la, He kumukuai nui ko'u i loaa mai ai ia'u keia kupa ana. I aku la o Paulo, Ua hanauia mai au, pela.
\q1 
\v 29 Nolaila haalele koke iho la ka poe hoopoipoi ia ia; a ike ka lunatausani, he Roma ia, makau iho la no ia, no kona hoopaa ana ia ia.
\b
\q1 
\v 30 A ia la ae manao iho la ia e ike pono i kona mea i hoopiiia'i e na Iudaio, wehe ae la oia ia ia, a kauoha aku la i ua kahuna nui, a me ka ahalunakanawai a pau, e hele mai, a alakai mai la oia ia Paulo, a hooku iho la ia ia imua o lakou.
\c 23
\b
\q1 
\v 1 HAKA pono mai la o Paulo i ka ahalunakanawai, i mai la, E na kanaka, na hoahanau, ua noho kupa wau me ka lunaikehala maikai wale no i ke Akua a hiki mai nei i keia la.
\q1 
\v 2 Kena ae la ke kahuna nui o Anania i ka poe e ku kokoke ana io na la, e pai ia ia ma ka waha.
\q1 
\v 3 Alaila, i aku la o Paulo ia ia, E pai mai no hoi ke Akua ia oe, e ka paia i hookeokeoia. Ke noho nei anei oe e hooko mai i ke kanawai ia'u, a ke kena mai nei anei oe, e paiia mai au ma ka mea ku ole i ke kanawai.
\q1 
\v 4 Olelo mai la ka poe o ku ana ilaila. Ke olelo ino nei anei oe i ke kahuna nui o ke Akua?
\q1 
\v 5 I aku la o Paulo, E na hoahanau, aole au i ike, o ke kahuna nui ia. No ka mea, ua palapalaia mai, Mai olelo hoino aku oe i ke alii o kou poe kanaka.
\q1 
\v 6 A ike aku la o Paulo, he poe Sadukaio kekahi o lakou, a he poe Parisaio kekahi, alaila hea aku la ia ma ka ahalunakanawai, E na kanaka, na hoahanau, he Parisaio wau, he keiki na kekahi Parisaio; a no ka manaolana i ke alahouana o ka poe make, ua hookolokoloia mai nei au.
\q1 
\v 7 A i kana olelo ana pela, kuee iho la ka poe Parisaio, a me ka poe Sadukaio; a mokuahana iho la ua aha kanaka la.
\q1 
\v 8 No ka mea, ua olelo mai ka poe Sadukaio, aole alahouana, aole anela, aole uhane; aka, o ka poe Parisaio, hooiaio no lakou i keia mau mea elua.
\q1 
\v 9 Nui loa iho la ka uwa; ku mai la na kakauolelo no ka poe Parisaio, hoopaapaa ikaika ae la lakou, i ae la, Aole loaa ia makou ka hewa iloko o keia kanaka. A ina he uhane, a he anela paha i olelo mai ia ia, mai ku e kakou i ke Akua.
\q1 
\v 10 Nui loa iho la ke kuee, no ia mea, makau ae la ka lunatausani o weluwelu o Paulo ia lakou, kena ae la ia i ka poe koa e iho ilalo, a e kaili mai ia ia mailoko mai o lakou, a e alakai aku ia ia iloko o ka pakaua.
\b
\q1 
\v 11 A ia po iho, ku mai la ka Haku imua ona, i mai la, E hoolana oe, e Paulo; no ka mea, e like me kou hoike ana aku ia'u ma Ierusalema nei, pela no hoi oe e hoike aku ai ia'u ma Roma.
\b
\q1 
\v 12 A wanaao, ohumu kuikahi mai la kekahi poe Iudaio e hoohalua ia ia, hoohiki ae la, aole loa lakou e ai, aole hoi e inu, a pepehi lakou ia Paulo.
\q1 
\v 13 He kanaha lakou a keu aku i ohumu pela i keia hoohalua ana.
\q1 
\v 14 Hele mai la lakou i na kahuna nui a me na lunakahiko, i mai la, Ua hoohiki makou ia makou iho i kahi hoino nui, aole loa makou e ai a pepehi makou ia Paulo.
\q1 
\v 15 No ia mea, ano, e nonoi aku oukou me ka ahalunakanawai i ka lunatausani, e kai mai ia ia io oukou nei, i ka la apopo, me he mea la e ninau hou aku i mea e akaka'i nona: a o makou nei, ua makaukau makou e pepehi ia ia i ka wa aole ia e hiki kokoke mai.
\q1 
\v 16 A lohe ke keikikane a ke kaikuwahine o Paulo i ko lakou hoohalua ana, hele aku la ia, komo aku la iloko o ka pakaua, a hai aku la ia Paulo.
\q1 
\v 17 Alaila, hea aku la o Paulo i kekahi o na lunahaneri, i aku la ia ia, E alakai oe i keia kanaka opio i ka lunatausani; no ka mea, he olelo kana e hai aku ai ia ia.
\q1 
\v 18 Nolaila, lawe ae la oia ia ia, alakai aku la i ka lunatausani, i aku la, I hea mai nei ia'u o Paulo ka mea i paa, a nonoi mai ia'u e alakai mai i keia kanaka opio ia oe, he olelo kana e hai aku ai ia oe.
\q1 
\v 19 Alaila, lalau ae la ka lunatausani i kona lima, a hele malu ae la, ninau aku la, Heaha kau mea e hai mai ia'u?
\q1 
\v 20 I aku la ia, Ua ohumu ka poe Iudaio e nonoi aku ia oe e kai aku ia Paulo i ka ahalunakanawai, i ka la apopo, me he mea la e ninau hou aku i mea nona e akaka'i.
\q1 
\v 21 Mai ae aku oe ia lakou; no ka mea, ke hoohalua nei nona hookahi kanaha kanaka, a keu o lakou; ua hoohiki lakou ia lakou iho i kahi hoino nui, aole e ai, aole hoi e inu, a pepehi lakou ia ia: Ano hoi ke makaukau nei lakou, e kakali ana no kau olelo.
\q1 
\v 22 Nolaila kuu mai la ka lunatausani i ua kanaka opio la, papa mai la, Mai hai ae oe i kekahi kanaka i kou hoike ana mai ia'u i keia mau mea.
\q1 
\v 23 Nolaila, kii aku la ia i na lunahaneri elua, i aku la, E hoomakaukau i na koa, elua haneri, e hele i Kaisareia, a me na hoohololio, he kanahiku, a me na kanaka ihe, elua haneri, i ke kolu o ka hora o ka po;
\q1 
\v 24 A e hoomakaukau i na holonolona hoi, i kau lakou ia Paulo maluna, a e lawe maikai aku ia ia io Pelika la, i ke alii kiaaina.
\q1 
\v 25 Kakau aku la ia i kekahi palapala, penei;
\b
\q1 
\v 26 O Kelaudio Lusia, i ke alii kiaaina hanohano, ia Pelika, aloha:
\q1 
\v 27 Ua hopuia keia kanaka e na Iudaio, a mai pepehiia oia e lakou; alaila, hiki e aku la au me ka poe koa, a hoopakele ia ia, no ko'u lohe ana, he Roma ia.
\q1 
\v 28 A i kou ake ana e ike i ke kumu a lakou i hoopii ai ia ia, kai ae la au ia ia iloko o ko lakou ahalunakanawai:
\q1 
\v 29 A ike aku la au ia ia, ua hoopiiia oia no kekahi mau mea o ko lakou kanawai, aole hoi lakou i hoopii mai ia ia, ma ka mea e pono ai ka make, a me ka paa.
\q1 
\v 30 A i haiia mai ia'u ka hoohalua ana o na Iudaio i ua kanaka la, hoouna koke aku la au ia oe, a kauoha aku la no hoi i ka poe i hoopii mai ia ia, e hai aku imua ou i ka mea a lakou i ike ai ia ia. Aloha oe.
\b
\q1 
\v 31 Alaila, lawe ae la ka poe koa ia Paulo, e like me ke kena ana mai ia lakou, a alakai aku la ia ia i ka po, i Anetipateri.
\q1 
\v 32 A ia la ae, waiho iho la lakou i ka poe hoohololio, e hele pu me ia, a hoi aku la lakou i ka pakaua.
\q1 
\v 33 A hiki aku la lakou i Kaisareia, haawi aku la lakou i ka palapala i ke alii kiaaina, a hooku iho la ia Paulo imua ona.
\q1 
\v 34 A heluhelu iho la ke alii, a ninau mai la ia, No ka panalaau hea ia? A lohe ia, no Kilikia,
\q1 
\v 35 I mai la ia, A hiki mai ka poe hoopii ia oe, alaila e hoolohe aku au ia oe. Kauoha ae la ia e malamaia oia maloko o ko Herode hale alii.
\c 24
\b
\q1 
\v 1 A HALA na la elima, iho ae la o Anania, ke kahuna nui, a me na lunakahiko, a me kekahi loio, o Teretulo, hoopii mai la lakou ia Paulo i ke alii kiaaina.
\q1 
\v 2 Kiiia'ku la ia, hoomaka iho la o Teretulo e hoopii ia ia, i ae la, Ua malu loa makou ia oe, ua nui loa no hoi na mea kaulana i loaa mai i keia aina i kou malama ana,
\q1 
\v 3 E Pelika kiekie, ke lawe maikai nei makou ia mau mea, ma na wahi a pau loa, me ke aloha nui aku:
\q1 
\v 4 Aka, o hooluhi aku au ia oe, ke nonoi aku nei au ia oe, i kou lokomaikai, e hoolohe iki mai ia makou.
\q1 
\v 5 No ka mea, ua ike makou i keia kanaka, ua kolohe, he kanaka hooeueu ana o ke ku e mawaena o na Iadaio a pau ma na aina a pau, oia no hoi kekahi kumu nui o ka papa Nazarene.
\q1 
\v 6 Ua hoao ae la ia e hoohaumia i ka luakini; na makou ia i hopu iho, a makemake iho la makou e hookolokolo e like me ko makou kanawai.
\q1 
\v 7 Aka, hele mai la o Lusia, ka lunatausani, a kai aku la ia ia me ka ikaika nui, mailoko aku o ko makou mau lima,
\q1 
\v 8 Kena mai no hoi ia i ka poe nana ia i hoopii e hele mai iou nei. A ina hookolokolo oe, e ike auanei oe i ka oiaio o keia mau mea a pau a makou e hoopii aku nei nona.
\q1 
\v 9 Ae mai la na Iudaio, i mai la, Oiaio no keia mau mea.
\b
\q1 
\v 10 Kunou ae la ke alii ia Paulo e olelo mai, alaila i mai la ia. No kuu ike ana, he nui na makahiki ia oe, i lunakanawai no ko keia aina, no ia mea, ua oluolu loa wau e olelo aku i na mea no'u iho.
\q1 
\v 11 E hiki no ia oe ke hoomaopopo, he umi ae nei la wale no i hala, a me kumamalua, mai ko'u pii ana aku i Ierusalema e hoomana.
\q1 
\v 12 Aole hoi au i loaa ia lakou maloko o ka luakini, e hoopaapaa ana me kekahi, aole hoi e hoohaunaele ana i ke lehulehu, aole maloko o na halehalawai, aole hoi maloko o ke kulanakauhale;
\q1 
\v 13 Aole hoi e hiki ia lakou ano ke hooiaio i na mea a lakou e hoopii mai nei ia'u.
\q1 
\v 14 Aka, ke hai pono aku nei au ia oe i keia, ma ka aoao i oleloia'i e lakou, he aoao ku e, pela no wau e hoomana aku nei i ke Akua o ko'u mau kupuna, e manaoio ana aku i na mea a pau i kakauia'i ma ke kanawai, a ma ka na kaula.
\q1 
\v 15 Ke lana nei ko'u manao i ke Akua, ua ae mai no hoi lakou i keia, i ke alahouana o ka poe make, o ka poe pono a me ka poe pono ole.
\q1 
\v 16 Malaila no hoi au e hooikaika nei e loaa mau ka lunaikehala hewa ole imua o ke Akua a me na kanaka.
\q1 
\v 17 A hala na makahiki he nui, hele aku la au e lawe i ka waiwai manawalea, a me na mohai, no na kanaka o ko'u aina.
\q1 
\v 18 Loaa iho la au maloko o ka luakini i kekahi mau Iudaio, mai Asia mai, ua huikalaia, aole me ka lehulehu, aole hoi me ka hoohaunaele.
\q1 
\v 19 Ina i loaa ia lakou kekahi hewa no'u, e hoopii mai ai, ina ua pono o lakou kekahi pu mai imua ou.
\q1 
\v 20 E pono no hoi ia lakou nei ke olelo mai, ina paha ua loaa ia lakou ko'u hewa, ia'u i ku ai imua o ka ahalunakanawai;
\q1 
\v 21 No keia leo hookahi wale no a'u i hea aku ai, i ko'u ku ana iwaena o lakou. No ke alahouana o ka poe make, oia ko'u mea i hookolokoloia mai ai imua o oukou i keia la.
\b
\q1 
\v 22 A lohe o Pelika i keia, hoopanee aku ia lakou a ike maopopo aku la oia i na mea o keia aoao, i ae la, A iho mai o Lusia, ka lunatausani, alaila, e hoomaopopo lea au i ka oukou.
\q1 
\v 23 Alaila, olelo aku la ia i ka lunahaneri e malama ia Paulo, aole hoi e paa maoli, aole e papa aku i kekahi o kona mau makamaka, ke lawelawe nana, a e hele mai hoi ia ia.
\b
\q1 
\v 24 A hala kekahi mau la, hiki mai la o Pelika me kana wahine, o Derausila, he Iudaio no ia, kii aku la kela ia Paulo, hoolohe aku la ia ia no ka manaoio iloko o Kristo.
\q1 
\v 25 A i kana kamailio ana no ka pono, a me ka pakiko, a me ka hookolokoloia e hiki mai ana mahope, haalulu iho la o Pelika, i aku la, O hoi oe i keia wa; a loaa ia'u ka manawa kaawale, e kii hou aku no au ia oe.
\q1 
\v 26 E manaolana ana hoi ia e haawiia mai e Paulo na kala nana, i weheia'ku ai ia e ia. No ia mea, kii pinepine aku la oia ia ia, i kamakamailio laua.
\q1 
\v 27 A hala ae la na makahiki elua, hiki ae la ma ko Pelika hakahaka, o Porekio Peseto, a waiho iho la o Pelika ia Paulo e paa ana, no kona makemake e hooluolu i na Iudaio.
\c 25
\b
\q1 
\v 1 A HIKI ae la o Peseto i ua panalaau la, a hala na la ekolu, a pii aku la ia i Ierusalema, mai Kaisareia aku.
\q1 
\v 2 A o ke kahuna nui a me ka poe koikoi o na Iudaio, hoopii aku la lakou no Paulo ia ia, nonoi aku la,
\q1 
\v 3 A koi aku no hoi ia ia i ka lokomaikai ku e ia ia e kii aku kela ia ia, e hele mai i Ierusalema; e hoohalua ana lakou ma ke alanui e pepehi ia ia.
\q1 
\v 4 I mai la o Peseto, ma Kaisareia e malamaia'i o Paulo, a oia iho no e hoi koke aku ilaila.
\q1 
\v 5 I hou mai la ia, O ka poe e hiki o oukou, e iho pu lakou me au; ina he mea hewa iloko o ia kanaka, e hoopii lakou nona.
\b
\q1 
\v 6 A noho iho la ia me lakou i na la he umi paha a keu, alaila, iho ae la ia i Kaisareia; a ia la ae, noho iho la ia ma ka noho hookolokolo, a kena aku la ia e kaiia mai o Paulo.
\q1 
\v 7 A hiki mai la ia, ku mai la ka poe Iudaio, i iho mai mai Ierusalema mai, a hoopii aku la ia Paulo i na mea hewa, he nui loa, aole hoi i hiki ia lakou ke hooiaio mai.
\q1 
\v 8 Olelo iho la ia nona iho, Aole loa au i lawehala ma ke kanawai o na Iudaio, aole hoi ma ka luakini, aole hoi i ko Kaisara.
\q1 
\v 9 No ka makemake ana o Peseto, e lokomaikai aku i na Iudaio, ninau aku la kela ia Paulo, i aku la, Ke makemake nei anei oe e pii i Ierusalema, a malaila e hookolokoloia'i e au, ma keia mau mea?
\q1 
\v 10 Alaila, olelo mai o Paulo, Ke ku nei au ma ka noho hookolokolo o Kaisara, i kahi kupono e hookolokoloia mai ai au: aole au i lawehala i na Iudaio, ua ike pono no oe.
\q1 
\v 11 Ina i hewa au, a ina i hana au i ka mea e pono ai ka make, aole au e hoole aku i ka make; aka, ina he mea ole keia mau mea a lakou e hoopii mai nei ia'u, aole loa e hiki i kekahi ke haawi aku ia'u ia lakou. Ke hoopii nei au ia Kaisara.
\q1 
\v 12 Alaila, kamailio iho la o Peseto me ka poe ahaolelo, i aku la ia, Ua hoopii oe ia Kaisara, ea! ia Kaisara oe e hele ai.
\b
\q1 
\v 13 A hala ae la kekahi mau la, hiki mai la i Kaisareia, o Ageripa, ke alii laua me Berenike e aloha mai ia Peseto.
\q1 
\v 14 A nui na la a laua i noho ai ilaila, hai aku la o Peseto i ua alii la i na mea a Paulo, i aku la, Ua waihopaaia mai nei kekahi kanaka e Pelika;
\q1 
\v 15 I ka wa a'u ma Ierusalema, hai mai la na kahuna nui a me na lunakahiko o na Iudaio ia'u nona, koi mai la lakou e hoahewaia oia.
\q1 
\v 16 I aku la au ia lakou, Aole ia o ko Roma aoao, ke haawi aku i kekahi kanaka e make, me ka halawai maka ole o ka mea i hoopiiia, a me ka poe e hoopii mai, a aeia'ku ia e olelo mai nona iho ma na mea i hoopiiia mai nona.
\q1 
\v 17 A hiki mai la lakou ia nei, aole au i kali hou aku; ia la ae, noho au ma ka noho hookolokolo, a kena aku la e kaiia mai ua kanaka la.
\q1 
\v 18 A ku mai la ka poe hoopii ia ia, aole lakou i hoike mai i kekahi mea e like me ko'u manao mua:
\q1 
\v 19 He mau ninau nae ko lakou no ko lakou hoomana ana, e hoopii mai ia ia, a no kekahi Iesu, ka mea i make, a ua hai mai o Paulo, ua ola.
\q1 
\v 20 A i ko'u kanalua ana no keia hoopaapaa ana, ninau aku la au, Ke makemake nei anei oe e hele i Ierusalema, a malaila e hookolokoloia'i, no keia mau mea?
\q1 
\v 21 A i ka Paulo hoopii ana e waihoia'i oia no ka hookolokolo mai o Auguseto, kauoha aku la au e malamaia oia, a hoouna aku au ia ia io Kaisara la.
\q1 
\v 22 Alaila, i ae la o Ageripa ia Peseto, Owau no kekahi e hoolohe aku i na kanaka la. I mai la kela, Apopo e lohe oe ia ia,
\b
\q1 
\v 23 A ia la ae, hiki mai la o Ageripa, laua me Berenike, me ka hanobano nui, a komo aku la i kahi hoolohe, me na lunatausani, a me na kanaka koikoi o ia kulanakauhale, alaila, kauoha aku o Peseto a kaiia mai o Paulo.
\q1 
\v 24 A olelo ae la o Peseto, E ke alii, e Ageripa e, a me na kanaka a pau me kakou, Ke ike nei oukou i keia kanaka a ka poe Iudaio ma Ierusalema, a maanei no hoi i hoopii mai ai ia'u, a me ke kahea ana, aole ia e pono ke ola hou aku.
\q1 
\v 25 A ike aku la au, aole ia i hana i ka mea e pono ai ka make, a nana iho i hoopii aku ia Auguseto, manao paa au e hoouna aku ia ia ilaila.
\q1 
\v 26 Aole a'u mea e palapala aku ai nona i ko'u haku. No ia mea, ua kai mai au ia ia imua o oukou nei, a imua no hoi ou, e ke alii, e Ageripa e, i loaa ia'u kekahi mea e palapala aku ai, mahope o keia hookolokolo ana.
\q1 
\v 27 No ka mea, aole e pono i ko'u manao ke hoouna aku i ke kanaka paa, me ka hoike ole aku i ka hewa ana i hoopiiia mai ai.
\c 26
\b
\q1 
\v 1 A LAILA olelo mai la o Ageripa ia Paulo, Ke aeia'ku nei ia oe e olelo mai nou iho. Hohola ae la o Paulo i kona lima, olelo mai la nona iho;
\b
\q1 
\v 2 Pomaikai au i ko'u manao, e ke alii, o Ageripa e, no ka mea, e hoakaka ana au imua ou i keia la, no na mea a pau a'u i hoopiiia mai nei e na Iudaio:
\q1 
\v 3 No ka mea, ua ike no oe i na aoao, a me na mea hoopaapaa a pau o na Iudaio; nolaila, ke nonoi aku nei au ia oe, e hoolohe ahonui mai ia'u.
\q1 
\v 4 O ko'u noho ana, mai ko'u wa uuku mai, aia ia mai kinohi mai ma Ierusalema iwaena o kou lahuiaina iho, ua ike na Iudaio a pau;
\q1 
\v 5 Ka poe i ike mai ia'u i kinohou, ina i ake lakou e hoike mai, noho Parisaio no wau ma ka aoao ikaika loa o ko makou hoomana.
\q1 
\v 6 Ke ku nei no au, ua hookolokoloia mai nei no hoi, no ka manaolana o ka olelo hoopomaikai a ke Akua i olelo mai ai i ko makou mau kupuna.
\q1 
\v 7 Ke manaolana nei no hoi ko makou poe ohana, he umi a me kumamalua, e loaa ia mea, me ka malama mau aku i ka po a me ke ao; no ia manaolana o'u, e ke alii, e Ageripa e, ua hoopiiia mai noi au e na Iudaio.
\q1 
\v 8 No ke aha la oukou i manao ai ho mea hiki ole i ke Akua ke hoala mai i ka poe make?
\q1 
\v 9 Nolaila, manao no au iloko o'u iho, he mea pono ia'u ke hana i na mea he nui i ku e i ka inoa o Iesn no Nazareta.
\q1 
\v 10 Hana no au ia mau mea ma Ierusalema; hana paa iho la au i na haipule he nui maloko o na halepaahao, ua loaa no ia'u ka mana no ka poe kahuna nui; a ia lakou i pepehiia, owau no kekahi i hoahewa pu aku la lakou.
\q1 
\v 11 Hoopai pinepine aku la au ia lakou maloko o na halehalawai a pau, a koi aku la au ia lakou e olelo hoino; a no ko'u ukiuki loa ia lakou, hoomaau aku la au ia lakou a hiki i na kulanakauhale o na aina e.
\q1 
\v 12 No ia mau mea i hele ai au i Damaseko, me ka mana a me ke aeia na na kahuna nui mai,
\q1 
\v 13 I ke awakea, e ke alii e, ike aku la au ma ke alanui, he malamalama mai ka lani mai, he mea oi loa aku mamua o ka malamalama o ka la, ua puni au i ka malamalama, a me ka poe i hele pu me au.
\q1 
\v 14 A hina makou a pau i ka honua, lohe aku la au i ka leo, i ka i ana mai ia'u, i mai la ma ka olelo Hebera, E Saulo, e Saulo, no ke aha la oe e hoomaau mai nei ia'u? He mea eha nou ke keehi mai i na kui.
\q1 
\v 15 I aku la au, Owai oe, e ka Haku? I mai la kela, o Iesu no wau, o ka mea au e hoomaau mai nei.
\q1 
\v 16 Aka, e ala hoi oe, a e ku iluna ma na wawae ou; no ka mea, ua ikea au ia oe, no keia mea, e hoolilo ana au ia oe i lawehana, a i mea hoike aku i keia mea au i ike iho nei, a me na mea a'u e hoike hou aku ai nau.
\q1 
\v 17 Na'u no oe e hoopakele i kanaka a me ko na aina e; e hoouna aku ana no au ia oe io lakou la,
\q1 
\v 18 E hookaakaa'i i ko lakou mau maka, a e hoohuli ia lakou, mai ka pouli mai i ka malamalama, a mai ka mana o Satana i ke Akua, i loaa ia lakou ke kala ana o ka hala, a me ka hooilina mawaena o ka poe i hoomaemaeia e ka manaoio mai ia'u.
\q1 
\v 19 Nolaila, e ke alii, e Ageripa e, aole au i hoole aku ia hoakaku, mai ka lani mai.
\q1 
\v 20 Aka, hoike mua aku la au ia lakou ma Damaseko, a ma Ierusalema, a ma na mokuna a pau ma Iudea, a i ko na aina e, i mihi lakou, a e huli i ke Akua, a e hana i na hana e ku i ka mihi.
\q1 
\v 21 No keia mau mea, lalau mai na Iudaio ia'u maloko o ka luakini, hoao mai la lakou e pepehi mai ia'u a make.
\q1 
\v 22 No ke kokua ana mai o ke Akua ia'u, ua ku paa no wan, a hiki mai nei i keia la, e hoike ana aku i ka poe liilii, a me ka poe nui, i ka i ana aku i keia mau mea wale no, i na mea a ka poe kaula, a me Mose no hoi i olelo mai ai, e hiki mai ana:
\q1 
\v 23 E make no ka Mesia e pono ai, oia hoi ka mua o ka poe make i ala hou mai, nana no e hoike aku i ka malamalama i ko onei kanaka, a me ko na aina e.
\b
\q1 
\v 24 A i kana hoakaka ana pela i kona iho, i ae la o Peseto me ka leo nui, E Paulo, ua hehena oe; na na palapala he nui oe i hoolilo ai i hehena.
\q1 
\v 25 I aku la ia, Aole au hehena, e Peseto maikai e, aka, ke olelo aku nei au i na olelo oiaio a me ka naauao.
\q1 
\v 26 Ua ike no hoi ke alii i keia mea, ke olelo wiwo ole aku nei au imua o kona alo; no ka mea, ke manao nei au aole i nalo ia ia kekahi o keia mau mea, no ka mea, aole i hanaia keia ma kahi nalo.
\q1 
\v 27 E ke alii, e Ageripa e, ke manaoio mai nei anei oe i ka na kaula! Ua ike no au, ua manaoio no oe.
\q1 
\v 28 Olelo aku la o Ageripa ia Paulo, Ua aneane oe e hoohuli mai ia'u i Kristiano.
\q1 
\v 29 I mai la o Paulo, Ke pule nei au i ke Akua, i ole oe ma ka aneane wale no, aka, ma ka oiaio e lilo ai oe, a me ka poe a pau e hoolohe mai ia'u i keia la, i mea e like io ai me au nei, ma na mea a pau, o keia paa wale no ke koe.
\b
\q1 
\v 30 A ku ae la ke alii iluna, a me ke alii kiaaina, a me Berenike, a me ka poe e noho pu ana me lakou.
\q1 
\v 31 I ko lakou hoi ana'ku, kamailio ae la lakou ia lakou iho no, i ae la, Aole i hana keia kanaka i ka mea ku i ka make a me ka paa.
\q1 
\v 32 I ae la o Ageripa ia Peseto, Ina aole keia kanaka i hoopii ia Kaisara, ina ua pono ke wehe ia ia.
\c 27
\b
\q1 
\v 1 A PAA iho la ka manao e holo makou i Italia, haawi ae la lakou ia Paulo, a me kekahi poe i paa pu, i kahi lunahaneri, o Iulio kona inoa, no ka papa koa o Auguseto.
\q1 
\v 2 A ee makou i kekahi moku no Aderamuteno, a hemo aku la me ka manao e holo ma ke kapa o Asia; a o Arisetareko, no Teselonike i Makedonia, kekahi me makou.
\q1 
\v 3 A ia la ae, pae makou i Sidona. Hana lokomaikai aku la o Iulio ia Paulo, ae aku la ia ia e hele i kona mau makamaka e hoomaha ia ia iho.
\q1 
\v 4 A hemo aku la makou mai ia wahi aku, holo makou malalo o Kupero, no ka mea, pakuikui mai ka makani.
\q1 
\v 5 Holo ae la makou a hala ke kai o Kilikia, a me Pamepulia, a hiki makou ma Mura o Lukia.
\q1 
\v 6 A malaila loaa i ka lunahaneri he moku no Alekanederia, e holo ana i Italia; hoee ae la oia ia makou iloko.
\q1 
\v 7 Holo lohi aku la makou i na la he nui loa, a hiki apuepue makou i Kenido, no ka mea, aole i aeia ka makani ia makou, holo ae la makou malalo o Kerete, ma Salemone;
\q1 
\v 8 A hala ia wahi me ka apuepne hiki aku la makou i kahi i kapaia o Naawamaikai, kahi i kokoke mai i ke kulanakauhale o Lasaia.
\b
\q1 
\v 9 Ua loihi loa ka manawa i hala, a ua hiki no hoi ka wa pono ole ke holo, no ka mea, ua hala ka wa hookeai, alaila ao mai la o Paulo ia lakou,
\q1 
\v 10 I mai la, E na kanaka, ke ike nei au i keia holo ana, e pilikia ana, a me ka lilo nui, aole ka ukana a me ka moku wale no, aka, o ko kakon mau ola kekahi.
\q1 
\v 11 Manao iho la ka lunahaneri i ka ke kahu moku, a me ka mea nona ka moku, aole i na mea i oleloia mai e Paulo.
\q1 
\v 12 Aole hoi i pono loa kela awa i ka hooilo, no ia mea, hoike mai ka nui i ka manao e holo aku, ina paha lakou e hiki aku i Poinike i ka hooilo, he awa no ia ma Kerete e huli ana ma Liba, a me Koro.
\q1 
\v 13 A aniani mai la ka makani, mai ke kukuluhema mai, manao iho la lakou, ua loaa ko lakou manao, hemo aku la a holo pili loko aku la i Kerete.
\q1 
\v 14 Aole i emo, pa mai la kekahi makani ino, he Eurokeludo ka inoa.
\q1 
\v 15 Punia iho la ka moku, aole hiki ke hooku i ka makani, hookuu ae la makou a holo.
\q1 
\v 16 A holo ae la makou malalo o kekahi aina, ua kapaia o Kelaude, hiki apuepue ia makou ke paa iho i ka waapa,
\q1 
\v 17 A hukiia ia iluna, hana iho la lakou i mea e kokua ai, hawele iho la lakou malalo o ka moku, a makau iho la o haule lakou ma ka Sureti, no ia mea, kuu iho la lakou i ka pea, a hooholoia pela.
\q1 
\v 18 Kahulihuli loa makou i ka ino, nolaila, ia la ae, hoomama iho la lakou i ka moku.
\q1 
\v 19 A i ke kolu o ka la, na ko makou lima no i hoolei aku i ka ukana pili i ka moku.
\q1 
\v 20 A hala ae la na la he nui, aole hoi i ikea mai ka la a me na hoku, aole hoi okana mai o ka ino i kau ia maluna o makou, alaila pau aku la ka manaolana e hoolaia'i makou.
\q1 
\v 21 A loihi ka ai ole ana, alaila ku mai la o Paulo iwaenakonu o lakou, i mai la, E na kanaka, ina oukou i hoolohe mai i ka'u, aole hoi i hemo mai, mai Kerete mai, ina ua pono, alaila aole kakou i loaa i keia ino, a me keia poho.
\q1 
\v 22 Ano hoi, ke nonoi aku nei au ia oukou, e olioli oukou; no ka mea, aole e lilo ana kekahi ola o oukou, o ka moku wale no.
\q1 
\v 23 No ka mea, i ka po nei, ku mai la kekahi anela o ke Akua, nona no wan, a oia hoi ka'u e malama nei,
\q1 
\v 24 I mai la ia, Mai makau oe, e Paulo; e pono ia oe ke ku aku imua i ke alo o Kaisara; aia hoi, ua haawi mai la ke Akua i ka poe a pau e holo pu ana me oe nau.
\q1 
\v 25 Nolaila, e kanaka e, e olioli oukou; no ka mea, ke manaoio aku nei au i ke Akua, e hanaia mai, e like me ka mea i oleloia mai ai ia'u.
\q1 
\v 26 Aka hoi, e ili ana kakou ma kekahi mokupuni.
\b
\q1 
\v 27 A hiki i ka po umikumamaha, na hooholoholoia ae la makou ma Aderia, a i ke aumoe, manao iho la na luina e kokoke ana lakou i ka aina.
\q1 
\v 28 A hoailona iho la, a he iwakalua anana i loaa ia lakou; a panee iki aku, hoailona hon, a loaa he umikumamalima anana.
\q1 
\v 29 Makau ae la o ili makou ma kahi pohaku, hoolei iho la lakou i na heleuma eha ma ka hope o ka moku, a iini iho la i ke ao ana ae.
\q1 
\v 30 A imi na luina e mahuka aku, mai ka moku aku, ua kuu iho la i ka waapa ilalo i ke kai, me he mea la e lawe aku ana i mau heleuma, ma ka ihu;
\q1 
\v 31 Olelo ae la o Paulo i ka lunahaneri, a me ka poe koa, Ina aole lakou nei e noho i ka moku, aole loa e hiki ia oukou ke hoolaia.
\q1 
\v 32 Alaila oki ae la ka poe koa i na kaula o ka waapa, a kuu ia ia e haule iho la.
\q1 
\v 33 A kokoke ae la i ke ao, koi ae la o Paulo ia lakou a pau, e ai i ka ai, i ae la, Eia ka la umikumamaha o ko oukou hookeai ana, ua noho oukou me ka lalau ole i ka ai.
\q1 
\v 34 No ia mea, ke nonoi aku nei au ia oukou, e lalau i ka ai; no ka mea, o ko oukou mea ola ia. No ka mea, aole e haule kekahi lauo, ho o ko oukou mau poo.
\q1 
\v 35 A i olelo ana pela, lalau iho la ia i ka berena, hoomaikai aku la i ke Akua imua o lakou a pau; a wawahi ae la, ai iho la.
\q1 
\v 36 Alaila, olioli iho la lakou a pau, a o lakou kekahi i lalau i ka ai.
\q1 
\v 37 A o na uhane a pau, maluna o ka moku, elua o makou haneri a me kanahikukumamaono kanaka.
\q1 
\v 38 A maona ae la lakou i ka ai, hoomama iho la lakou i ka moku, a hoolei iho la i ka hua palaoa iloko o ke kai.
\q1 
\v 39 A ao ae la, aole lakou i ike ia aina; kaunana nae lakou i kekahi kaikuono me ke kahakai. Mauao iho la lakou, ina e hiki, e hookomo i ka moku ilaila.
\q1 
\v 40 Ooki iho la lakou i na heleuma, a waiho iho la i ke kai, a wehe iho la i na kaula o ka hoeuli, a huki i ka pea nui i ka makani, a holo iuka.
\q1 
\v 41 Ika iho la lakou ilalo i kahi wili au, ili iho la ka moku, paa iho la ka ihu, aole loa i hemo, nahaha iho la ka hope i ka ikaika o na ale.
\q1 
\v 42 Manao iho la ka poe koa e pepehi i ka poe paahao, o au aku kekahi o lakou a pakele.
\q1 
\v 43 Makemake iho la ka lunahaneri e hoola ia Paulo, hoole aku la i ko lakou manao; kena aku la i ka poe hiki ke au, o lakou ke lele mua a hiki iuka.
\q1 
\v 44 A o ke koena, ma na papa kahi, a ma na mea o ka moku kahi; a pela lakou a pau i pakele ai a hiki i ka aina.
\c 28
\b
\q1 
\v 1 A HOOPAKELEIA ae la, alaila, ike iho la lakou i ka mokupuni, ua kapaia o Melita.
\q1 
\v 2 He mea e ka lokomaikai o ia poe kanaka e ia makou; no ka mea, hoaa iho la lakou i ahi, a hookipa mai la ia makou a pau, no ka ua e haule ana, a no ke anuanu.
\q1 
\v 3 Lapulapu iho la o Paulo i puapua hoaa, a i kona kau ana ma ke ahi, puka mai la he moonihoawa mailoko mai o ka wela, a pipili iho la i kona lima.
\q1 
\v 4 A ike mai la kela poe kanaka e i ua mea nihoawa la e kau ana i kona lima, i ae la lakou kekahi i kekahi, Oiaio no he kanaka pepehi kanaka keia, ua pakele no ia i ke kai, aka, o ka mea hoopai, aole ia i ae mai i kona ola.
\q1 
\v 5 Nolaila lulu aku la ia i ua mea nihoawa la iloko o ke ahi, aole hoi i loaa ia ia ka poino.
\q1 
\v 6 Kakali iho la lakou i kona pehu ana, a me ka hina ilalo a make koke; a loihi ko lakou kakali ana, aole hoi i ike ia ia e loaa ana i ka poino, huli hou ae la ko lakou manao, i ae la, He akua ka ia.
\b
\q1 
\v 7 Kokoke ma ia wahi ka aina o ka luna o ia moku, o Popelio kona inoa, nana no i kii mai ia makou, a hookipa maikai aku la i na la ekolu.
\q1 
\v 8 E kaa ana ka makuakane o Popelio i ke kuni, a me ka hi koko. Komo aku la o Paulo io na la, pule aku la, kau iho la i kona lima maluna ona, hoola aku la ia ia.
\q1 
\v 9 Nolaila hanaia ae la keia, o kekahi poe e i loohia i ka mai ma ia mokupuni, hele mai la lakou, a hoolaia iho la.
\q1 
\v 10 Hoomahalo mai la lakou ia makou, me na mahaloia he nui; a holo makou, kau mai la lakou i na mea e pono ai.
\b
\q1 
\v 11 A hala na malama ekolu, holo aku la makou ma kekahi moku no Alokanederia, i ku ma ia mokupuni i ka hooilo, o Diosekouro ka hoailona.
\q1 
\v 12 A pae aku la makou ma Surakausa, a noho iho la i na la ekolu.
\q1 
\v 13 A mailaila aku makou i holo ai a hiki i Regio, a hala kekahi la, pa mai la ka makani, mai ke kukuluhema mai, a ia la ae, hiki makou i Puteoli:
\q1 
\v 14 A malaila loaa ia makou he mau hoahanau, kaohi mai lakou ia makou e noho me lakou ehiku la; a pela makou i hele aku ai i Roma.
\q1 
\v 15 A lohe mai na hoahanau ia makou, malaila mai la lakou i hele mai ai a Apioporo, a me Teriatubereno, e halawai me makou. A ike o Paulo ia lakou, hoomaikai aku la ia i ke Akua, a hoolana mai.
\b
\q1 
\v 16 A hiki makou i Roma, haawi aku la ka lunahaneri i ka poe paahao i ke alii o ka poe koa. I aeia'ku la o Paulo e noho kaawale i kona wahi iho, me kekahi koa nana ia i malama aku.
\b
\q1 
\v 17 A hala na la ekolu, hoakoakoa iho la o Paulo i ka poe koikoi o na Iudaio. A pau lakou i ka hoakoakoaia, i aku la ia ia lakou, E na kanaka, na hoahanau, aole au i hana i kekahi mea i kuee i na kanaka, a me na aoao o na makua; aka ua haawi paaia'ku la au ma Ierusalema i na lima o ko Roma.
\q1 
\v 18 A hookolokolo mai lakou ia'u, manao iho la e kuu mai, no ka mea, aole he mea ia'u i ku i ka make.
\q1 
\v 19 A papa aku la na Iudaio, kaohiia au e hoopii ia Kaisam, aole hoi o'u mea e hoopii aku ai i ko'u lahuikanaka.
\q1 
\v 20 No keia mea, i kii aku nei au ia oukou, i ike aku au, a e kamailio aku ia oukou; no ka mea, ua paa au i keia kaulahao no ka manaolana o ka Iseraela.
\q1 
\v 21 I mai la lakou ia ia, Aole i loaa ia makou ka palapala mai Iudea mai nou, aole hoi i hoike mai a olelo mai paha kekahi o na hoahanau i hele mai, i hewa ou.
\q1 
\v 22 Ke makemake nei no hoi makou e hoolohe ia oe i kou manao; no ka mea, ua ike no makou i keia aoao, ua olelo ku e ia i na wahi a pau.
\b
\q1 
\v 23 A i ko lakou hoakaka ana i ka la, alaila hele mai la na mea he nui loa io na la, i kona wahi; hoakaka aku la oia, a mai kakahiaka a ahiahi kona hoike ana aku i ke aupuni o ke Akua, a me ka hooikaika aku ma na mea o Iesu, ma ke kanawai ia Mose, a ma ka na kaula.
\q1 
\v 24 Manaoio iho la kekahi poe i na mea i oleloia mai, a hoomaloka kekahi poe.
\q1 
\v 25 A i ka like pu ole ana o ko lakou manao kekahi i kekahi, hele aku lakou, mahope iho o ka hai ana aku o Paulo i kahi olelo hou; Pololei wale ka olelo a ka Uhane Hemolele, ma o Isaia la, o ke kaula, i ko kakou poe kupuna,
\q1 
\v 26 I ka i ana mai, E hele i keia poe kanaka, a e i aku, I ka lohe ana, e lohe auanei oukou, aole nae e ike i ke ano; i ka ike ana, e ike auanei oukou, aole nae e hoomaopopo.
\q1 
\v 27 Ua manoanoa hoi ka naau o keia poe kanaka, kaumaha ko lakou pepeiao ke lohe, ua hoopili i ko lakou maka; o ike lakou me na maka, a lohe me na pepeiao, a ike hoi ka naau, a e huli mai, a hoola aku au ia lakou.
\q1 
\v 28 No ia mea, e ike pono oukou, ua hoounaia'ku ke ola o ke Akua i ko na aina e, a e hoolohe mai no lakou.
\q1 
\v 29 A i kana hai ana aku i keia mau mea, hele aku la na Iudaio, a nui loa iho la ko lakou hoopaapaa ana ia lakou iho.
\b
\q1 
\v 30 Noho iho la o Paulo a hala na makahiki elua, iloko o kona hale hoolimalimaia, e hookipa ana i ka poe a pau i hele aku io na la,
\q1 
\v 31 Me ka hai mai i ke aupuni o ke Akua, a me ka hoike mai i na mea e pili i ka Haku ia Iesu Kristo, me ka wiwo ole, a me ka papa ole ia aku. 
