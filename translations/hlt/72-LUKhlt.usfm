\p
\v 6 Te \w phoeiah|strong="G1161"\w* \w Boeipa|strong="G2963"\w* \w loh|strong="G3588"\w*, \wj “ \+w Laitloekkung|strong="G2923"\+w* \+w loh|strong="G3588"\+w* a \+w boethae|strong="G0093"\+w* \+w kah|strong="G3588"\+w* a \+w cal|strong="G3004"\+w* \+w te|strong="G5101"\+w* \+w ya|strong="G0191"\+w* uh\wj*.  
