\id NAM - Gamo Full Bible final version 
\h Nahome Tinbite 
\toc1 Nahome Tinbite 
\toc2 Nahome Tinbite 
\toc3 Naho 
\mt1 Nahome Tinbite 
\imt1 Giddo Qofa 
\ip Nahomey beniisofe Isra7eele asaas wolqqama morkke gidida Asoore waanna katama Nannawe dhayo gishshas yootiza ginxo. Nannawey Kirstoosi yelettanaappe kase laappunththa xeetu layththas wurseththa bolla iza dhayanayssa, Xoossi menxe iita dere bollanne otoranchchata bolla pirdanayssa bessees. 
\iot Ha Maxaafay Oykkida Kumeththa Qofa 
\io1 Daro yashshiza Xoossa hanqo \ior 1:1-6\ior* 
\io1 Asoore bolla aadhdhida pirday Isra7eele deraas hidota gideth \ior 1:7-15\ior* 
\io1 Asoore waanna katama Nannawe dhayo \ior 2:1—3:19\ior* 
\c 1  
\p  
\v 1 Elqoshe dere as Nahomey Nannawe dhayo gishshas yootida ajjuuta maxaafay hayssafe kaallizayssa.\x - \xo 1:1—3:19 \xt Isa 10:5-34; 14:24-27; Sofo 2:13-15\x* 
\s1 Nannawe Bolla Qonccida Xoossa Hanqo 
\q1  
\v 2 GODAY zil7ettizanne 
\q2 halo kessiza Xoossa; 
\q2 GODAY halo kessizanne 
\q2 hanqon kumida Xoossa. 
\q1 GODAY halo kessizaadenne 
\q2 pala miishshi izan kumidaade. 
\q1 GODAY ba baalgaarata bolla 
\q2 halo kessees; 
\q2 ba morkketa bolla 
\q2 ba hanqo ehees. 
\q1  
\v 3 GODAY hanqettanaas eesotenna; 
\q2 iza wolqqayka gita. 
\q2 GODAY mooranchcha 
\q2 qaxxayontta aggenna; 
\q2 gote carkoynne abba dambalay 
\q2 izas oge; 
\q2 shaaray iza toho gudulla. 
\b  
\q1  
\v 4 Abba seeridi melissees; 
\q2 Shaafata ubbaa micinchchees. 
\q2 Baasaaneynne 
\q2 Qarmeloosey shullida. 
\q2 Libaanoose ciishshatikka 
\q2 qoqofettida. 
\q1  
\v 5 Zumati iza sinththan kokkorida; 
\q2 zumbullatikka seerida. 
\q2 Iza sinththan biittay, alameynne 
\q2 izin diza ubbati qaaxxida. 
\q1  
\v 6 Iza hanqora eqettana 
\q2 dandayzay oonee? 
\q2 iza hanqo minoza 
\q2 tookkana dandayzay oonee? 
\q2 Iza hanqoy tama mala eexxides; 
\q2 zaallatikka iza sinththafe za7ida. 
\q1  
\v 7 GODAY lo7o; 
\q2 meto gallassika qotetti attizaso. 
\q2 Izan ammanettizayta naagees. 
\q1  
\v 8 Gido attiin izi Nannawe 
\q2 wolqqama di7o haaththan 
\q2 dhayssana; 
\q2 ba morkketa dhumay 
\q2 dizaso yedeththana. 
\q1  
\v 9 Istti Xoossa bolla ay duulatikkoka 
\q2 izi istta dhayssana. 
\q2 Metoy nam7anththo dendenna. 
\q1  
\v 10 Istti agunththan qaxettana; 
\q2 ba woyne ushshan 
\q2 istti maththottana; 
\q2 tamay istta buuxa mala maana. 
\q1  
\v 11 Hanne Nannawe! 
\q2 GODAA bolla iita duulatizaytinne 
\q2 iita zore zorettizayti 
\q2 ne garsafe beettida; 
\p  
\v 12 GODAY, «Istti ay wolqqamatanne 
\q2 darota gidikkoka 
\q2 istti qanxxetti dhayana. 
\q1 Haysso Yuhuda neni hayssafe kase 
\q2 ta nena un7eththidaa gidikko 
\q2 hayssafe guye 
\q2 ta nena un7eththike. 
\q1  
\v 13 Ha7ikka ta istta qambara 
\q2 ne morgefe menththa diggana; 
\q2 ne izan qashettida sansalatakka 
\q2 duuththa yeggana» gees. 
\q1  
\v 14 Hanne Nannawe GODAY nena, 
\q2 «Hayssafe sinththan ne sunth 
\q2 xeygiza yeletay deenna. 
\q2 Ne eeqa xoossata keeththan diza 
\q2 masetti giigida misletanne 
\q2 seerisi giigsida 
\q2 eeqa xoossata dhayssana; 
\q2 ne iita gidida gishshas 
\q2 ne moogettanaaso 
\q2 ta bookkana» gees. 
\q1  
\v 15 Hekko mishiraachcho yootizayssi, 
\q2 saroteth awajjizayssi 
\q2 zumaa bollara 
\q2 yuussan dees. 
\q2 Yuhuda ne ba7aaleta bonchcha; 
\q2 ne adinettidayssa gaththa; 
\q2 hayssafe guye iitati 
\q2 ne dere worajjettenna; 
\q2 istti mulera dhayana.\x - \xo 1:15 \xt Isa 52:7\x* 
\c 2  
\s1 Nannawe Kundeth 
\q1  
\v 1 Hanne Nannawe! 
\q2 Nena qohanay ne bolla yides; 
\q2 ne miixa naaga; 
\q2 ne oge xomosa; 
\q2 minththa gixxa; 
\q2 ne wolqqa ubbaa minththa. 
\q1  
\v 2 Dhayssizayti istta mela 
\q2 ashshikokka, 
\q2 istti woyne atakilte tokkizasoho 
\q2 mulera dhayssikoka 
\q2 Isra7eele bonchcho ubbaa mala 
\q2 GODAY Yaaqoobe 
\q2 bonchchoka zaarana. 
\q1  
\v 3 Iza wottadarata gondalley zo7o; 
\q2 iza olanchchatikka 
\q2 zo7o may7o may7ida; 
\q2 istti olettanaas giigettida gallas 
\q2 istta para-gaareta 
\q2 biratay xolqees; 
\q2 istta toora toomay luuxxees. 
\q1  
\v 4 Para-gaareti demban 
\q2 yaanne haa buraqeettes; 
\q2 ogeta bollaka 
\q2 shom7ushom7u geettes; 
\q2 laciza xomppe misateettes; 
\q2 wolqqanththa mala 
\q2 wawaci geettes. 
\q1  
\v 5 Doorettida olanchchata xeygees; 
\q2 gido attiin istti yishe 
\q2 ogen dhuphetteettes; 
\q2 katamaa gimbeko woxeettes; 
\q2 ola teqqiza gondalleyka 
\q2 heen dees. 
\q1  
\v 6 Shaafa pengey waggi gi doyettides; 
\q2 kawoteththa keeththi kundides. 
\q1  
\v 7 Nannawey kawuyiin 
\q2 izi kawoya di7ettada buussi 
\q2 attonttayssi kaseti yootettides. 
\q2 Izi macca aylleti 
\q2 haraphphe mala yeekkana; 
\q2 bantta tirakka iccana. 
\q1  
\v 8 Nannawey eele haaththa mala; 
\q2 izi haaththika miccana. 
\q2 «Eqqa! Eqqa!» gi istti waassana; 
\q2 gido attiin guye 
\q2 simmizay deenna. 
\q1  
\v 9 Iza minjja keeththan 
\q2 dagattida aqotas 
\q2 qooday deenna; 
\q2 biidi biraakka, 
\q2 worqqaaka bonqqi ekkite. 
\q1  
\v 10 Qocirettadus; bonqqettadus; 
\q2 kallottadus; wozinay taahides; 
\q2 gulbatey kokkorides; 
\q2 ashoy qaaxxides; 
\q2 ayfesoykka gilqides. 
\q1  
\v 11 Gaammoti kase de7iza gongoloy, 
\q2 istta marati mizasoy, 
\q2 macca gaammoynne 
\q2 adde gaammoy bizasohoy, 
\q2 istta marati hirgay baynda 
\q2 mizasoy ha7i awan dizee? 
\q1  
\v 12 Gaammoy ba maratas 
\q2 gidanayssa keena wodhides; 
\q2 maccataska cuulli wodhides; 
\q2 ba wodhidayssa ba shemppizason, 
\q2 ba bonqqi shiishshidayssa 
\q2 ba gongolo kunththides. 
\q1  
\v 13 Ubbaafe Wolqqama GODAY, 
\q2 «Ta intte bolla dendadis; 
\q2 intte para-gaaretakka xuuggana; 
\q2 intte gaammo marata mashshay maana; 
\q2 inttes maana miishshika 
\q2 biitta bolla ashke; 
\q2 intte kiittizayta cenggurssi 
\q2 hayssafe guye seetettenna» 
\q2 gi awajjees. 
\c 3  
\s1 Nannawes Aayye Ana 
\q1  
\v 1 Suuththa katamays aayye ana; 
\q2 wordoynne bonqqay 
\q2 izin kumides; 
\q2 izippe qociretti shiiqidayssi 
\q2 efinkka wurenna. 
\q1  
\v 2 Xurqafe giirissi, 
\q2 irizo cenggurssi, 
\q2 pilata para adaraasoy, 
\q2 para-gaareta giirissi siyettides. 
\q1  
\v 3 Toganchchay toggees; 
\q2 mashshay popol7u gees; 
\q2 tooray xolqettees; 
\q2 daroy hayqqides; 
\q2 ahay aha bolla korettides; 
\q2 izas qoodaykka deenna; 
\q2 aadhdhi bizasoykka 
\q2 beettibeenna. 
\q1  
\v 4 Hayssi ubbay haniday 
\q2 buute aaththada 
\q2 as baleththizanne 
\q2 muurenniza laymay gaasonna. 
\q2 Iza ba laymateththan 
\q2 kawoteththa, maroteththan 
\q2 dereza ayllesidaaro. 
\q1  
\v 5 Ubbaafe Wolqqama GODAY, 
\q2 «Hanne tani ne bolla 
\q2 morkketeththan dendadis; 
\q2 tani ne qamisa qaara 
\q2 ne ayfeso kammana; 
\q2 ne kalloteththaa deraas, 
\q2 yeellateththaa kawoteththatas 
\q2 ta bessana. 
\q1  
\v 6 Tani ne bolla buura olana; 
\q2 ta nena kadhana; 
\q2 qidheska aaththa immana. 
\q1  
\v 7 Nena be7izayti neeppe baqatishe, 
\q2 ‹Nannawey laalettadus; 
\q2 izis yeekkanay oonee?› gaana. 
\q2 Nena minththeththanaade 
\q2 ta awappe demmanee?» gides. 
\q1  
\v 8 Neni Abbaye shaafa achchan diza, 
\q2 haaththan doodetta diza 
\q2 No7e Amooneppe goobay? 
\q2 Shaafazi izis teqe haaththazikka 
\q2 izis gimbe. 
\q1  
\v 9 Tophphiyaynne Gibxey izis 
\q2 zaway baynda wolqqa; 
\q2 Puuxeynne Liibiyay 
\q2 izo maaddizayta; 
\q1  
\v 10 Gido attiin iza di7ettadus; 
\q2 goodetta badus; 
\q2 izi nayti ogeta tiixa bolla 
\q2 dinccettida; 
\q2 izi daannata bolla 
\q2 saamay wodhdhides; 
\q2 izi gita asati 
\q2 ubbay sansalatan qashettida. 
\q1  
\v 11 Nenikka qasse 
\q2 maththottananne qotettana; 
\q2 morkketappe attizaso ne koyana. 
\b  
\q1  
\v 12 Ne miixati ubbay muussas gakkida 
\q2 balase miththas koyro ayfe mala; 
\q2 istti qaaxxiza wode 
\q2 istta ayfeti 
\q2 mizaade doonan wodhdheettes. 
\q1  
\v 13 Hekko ne ola asay 
\q2 wurikka macca xalla! 
\q2 Ne zawati ne morkketas 
\q2 waggi gi doyettida; 
\q2 istta kolatatakka tamay mides. 
\q1  
\v 14 Nena giddoththiza wodes 
\q2 haath duuqqa; 
\q2 nees teqe minththa giigsa; 
\q2 mana urqqa koya; 
\q2 Urqqaa yedhdhada 
\q2 xuube ooththa. 
\q1  
\v 15 Nena heen tamay maana; 
\q2 Mashshayka nena qanxxana; 
\q2 gumbaroy miza mala 
\q2 nena garccana; 
\q2 gumbaro mala yeletta; 
\q2 boole mala dara. 
\q1  
\v 16 Ne zal7anchchata 
\q2 salo xoolinttepekka darsadasa. 
\q2 Istti gidikko biittayo boole mala 
\q2 pitti miidi piradhdhi bida. 
\q1  
\v 17 Nena naagizayti boole mala; 
\q2 ne gita asati meego gallas 
\q2 gimbe garsan 
\q2 uttiza gumbaro mala. 
\q2 Istti arshey kezishin 
\q2 piradhdheettes; 
\q2 istti piradhdhi bizasoy 
\q2 awakko erettenna. 
\b  
\q1  
\v 18 Asoore kawoo, 
\q2 ne heenththanchchati dhiskida; 
\q2 ne gita asati woppu gi ichchida; 
\q2 ne derey shiishshizay dhayiin 
\q2 zuma bolla laalettides. 
\q1  
\v 19 Ne madunth paththana 
\q2 dandayzay deenna; 
\q2 neni hayqos gaththiza 
\q2 meqo meqqadasa; 
\q2 ne gishshas siyida ubbay 
\q2 ne kundeththaan ufayetti 
\q2 kushe baqqana; 
\q2 zaway baynda 
\q2 ne menxe iitateththi 
\q2 bochchonttay oonee?