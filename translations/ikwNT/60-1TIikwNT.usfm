\id 1TI - Ikwerre
\h 1 Timoti
\toc1 Ọkwukwo izi ke Mbọm Pọlu gbaznennu Timoti
\toc2 1 Timoti
\toc3 1 Tim
\mt2 Ọkwukwo izi
\mt2 ke Mbọm
\mt2 Pọlu gbaznennu
\mt1 Timoti
\imt1 Nhne gbasịri ọkwukwo izi ka
\im Timoti snornu Pọlu zne izne, rnụ masị ẹrnu izi ọma Karaịsi. Timoti nụ Pọlu nwernu otu ọkwnata mkpọma, kam kpayarụ, Timoti nụ lele nnwọ ke Pọlu mụrnu (1:2). Timoti bụ nye ẹrnu ke Pọlu kwnatarụ mkpọma k'agịda.
\ip Ọ bụ n'ezi nụ Pọlu gbaznennu Timoti ọkwukwo izi ka, kọvu o kwuru agịda nhne ke gbasịri kpakara ọgbako Chiokike. Pọlu kahịaru kpa be jeeji nọohoru ele risi ọgbako Chiokike. Ọ kaa nụ ele Karaịsi kwesiri neekpenu ibne be okpukpe. A nwernu otu Chiokike nụ Karaịsi Jizọsi, nye nwernu rikne o kwuru aị znekwnusi Chiokike.
\iot Nhne zị n'ọkwukwo izi ka
\io1 Obekwu ikwu \ior (1:1,2)\ior*
\io1 Bụdnu ọgbako Chiokike \ior (1:3---3:13)\ior*
\io1 Nhne tugwaru otugwa ke okpukpe aị \ior (3:14-16)\ior*
\io1 Pọlu znirni Timoti ezni \ior (4:1---6:21)\ior*
\c 1
\p 
\v 1 Mawa, Pọlu, nye izi Karaịsi Jizọsi lele kpa Chiokike Nye Ọznohia aị nyernu n'iwu nụ ke Jizọsi Karaịsi nye bụ olile anya aị.
\p 
\v 2 M naagbaznenu Timoti nnwọ m n'ezi n'ọkwnata ovu ọkwukwo.
\p Chiokike Nda aị, nụ Nyenwe aị Jizọsi Karaịsi nyee i oru, obirizi nụ udno.
\s1 Anụ zeru iznizni // aghalaghala
\p 
\v 3 Lele kpa me kannụ ị nga me neezne Masidonia, dazịri n'Efesọsi ma i bnosni ele zni iwu aghalaghala ma be kwụsi o zni nhne nụ kpam.
\v 4 Be túwhuma ige o zni ọtnutnu ruwhere nụ osnusno ọmumu kwó okwo. Kpakara nhne ka, tnụnuma be jeeme ẹrnu Chiokike ke hi n'ọkwnata ovu neezne nụ ruwhnu, be noovuya okewa.
\v 5 Ka bụ ma i zni ele badnụ be whnụrita n'anya hite nụ mkpọma zị snam nụ ovu bụru ọma nụ ezi ọkwnata ovu.
\v 6 Agwna ele badnụ kpawhulem, snornu ikwu-ọnu etekne.
\v 7 Be noopio ọ bụru ele zni iwu, kọvu be máa nhne be nookwu, ọ bụ n'ezi be nookwusi a rikne.
\p 
\v 8 A magwụ nụ iwu bụru ọma, ọ bụru badnụ mekwa a nkarị.
\v 9 A magwụ nụ be kwnóge ele mee mma bịta iwu, kọvu ele noolulu iwu nụ ele risi rikne, ma ele máa Chiokike, nụ ele mmehie, ele zị́la rịchna, ele tụ́ ogwnu Chiokike, ma ele noogbu badnụ, ele noogbu nne nụ nda be,
\v 10 ele neeme ọyi, nụ omekọrita nyerukna nụ ibne a, nụ omekọrita nyerinya nụ ibne a, ele neerne ọhi, ele aghalaghala, ele kwú ezi ọka n'ikpe, nụ kpakara nhne ọbula ke neemegidne iznizni ka zị snam.
\v 11 Iznizni ka bụ izi ọma wam ke zị igwugwu ke hi n'aka Chiokike nye nwe ngọzi. Chiokike nyernu m izi ọma ka n'aka me bịta.
\s1 Oru Nyenwe aị // nyernu Pọlu
\p 
\v 12 M nọotunu Karaịsi Jizọsi Nyenwe aị mmamma nye nyernu m rikne, nye gwnụsiri m nye kwesiri ọkwnata ovu, mee m bụru nye nọornu a ẹrnu.
\v 13 Ọ bụ n'ezi nụ m bụ m nye nookwulu a nụ mbọm nụ nye kpaknarnụ ele ke a ẹhni, nụ nye mee nhne rikne, kọvu ọ dọnu m obirizi kwnornu nụ m mernu m kpakara nhne ka nụ ọ́ma ama nụ ókwe ekwe.
\v 14 Nyenwe aị wụkwasiri m oru a zị agịda nụ ọkwnata ovu nụ ọwhnun'anya a ke zị nụ rime Karaịsi Jizọsi.
\p 
\v 15 Ka bụ ikwu-ọnu ke kwesiri ọkwnata ovu, ke nye ọbula kwesiri o kweru, Karaịsi Jizọsi varụ n'ọwa ọ znọhia ele mmehie, me bụ nye risi ele mmehie.
\v 16 Ka bụ nhne kpahịaru Chiokike jiri dọnu m obirizi, me nye risi ele mmehie ma Karaịsi Jizọsi gesi ọsnuta ovu a zị ogologo ma m bụru m nhne atụ nyee ele jeekweru nụ ya ma be nwehịa bụdnu kwó okwo.
\v 17 Kịtna, eze ke zị ọkwnukokwnu, nye nwụ́ ọnwu, nye be whnụ́ anya, nye ya nụ nsnụnu a bụ Chiokike, ya nụ nsnụnu a nwe igwugwu nụ ọson'anya tim tọm. Amịm.
\p 
\v 18 Timoti nnwọ m, m neenye i iwu ka lele kpa ọwhnurninya be whnụrnu gbasịri ị n'ige wheru ewhe, snornu nhne be kwuru gbasịri ị, ma i nwernu rikne lụ ọgwnu ọma lele nye Karaịsi.
\v 19 Jikwasi ọkwnata ovu i rikne nụ ovu zị snam. Agwna ele badnụ ghasarụ be, ke kpahịaru ọgbo ọkwnata ovu be kpuru.
\v 20 N'esilawụru be bụ Haịmenousi nụ Alẹkizanda ele me sịgbasiri n'aka Setani ma be mụhia gharụ o kwulu Chiokike.
\c 2
\s1 Kpa be kpe okpukpe
\p 
\v 1 Ke mbọm, m naakaa, anụ kpe okpukpe nụ risi kpakara ele badnụ, nọorio arịrio, nọotunu Chiokike mmamma.
\v 2 Anụ kpenu ele eze nụ kpakara ele zị n'ọchichi okpukpe, ma a wuru bụdnu udno nụ bụdnu bụru ọma, nọotu ogwnu Chiokike.
\v 3 Ka bụ nhne bụru ọma, ke nọoso Chiokike Nye Ọznohia aị mkpọma n'ọnu,
\v 4 kwnornu nụ Chiokike noopio ma ọ znọhia kpakara ele badnụ, ma be mahịa ezi ọka.
\p 
\v 5 Otu Chiokike zị, otu nye ibno zị n'esilawụru Chiokike nụ badnụ. Nye ibno wam bụ Karaịsi Jizọsi,
\v 6 nye gweru ẹhni a nyega ma ọ bụru nhne ọgbahia ke kpakara badnụ. Chiokike gesiri aị ka n'ige kwesiri.
\v 7 Ka bụ nhne mernu Chiokike họhiaru m ma m bụru nye nọokpo okwo nụ nye izi. Ka bụ ezi ọka, ọ bụ́o aghalaghala, Chiokike họhiaru m ma m bụru m nye zni nhne ke ezi ọka ọkwnata ovu ke ele bụ́o ele Ju.
\p 
\v 8 M noopio nụ rime ọgbako ọbula ele rukna chịlizo aka lawụru zị nsọ n'okpukpe énwe ovu owe ẹhni nụ agịgo.
\p 
\v 9 M noopio ele rinya masị yịri ẹyi lele kpa o kwesiri, ke bụru ọma n'anya. Ele rinya kpá risi gburu okne ọnu, mọbu tụru golu mọbu palị, mọbu woru iwo gburu okne ọnu,
\v 10 kọvu rnụ ẹrnu ọma, bụ ke kwesiri ele rinya ele ka nụ be neekpenu Chiokike.
\p 
\v 11 Ele rinya kwesiri ọ dazịri bii, mụhia nhne hite n'orube risi.
\v 12 M kwéle m nyerinya zni nhne mọbu zịri nụ risi nyerukna, o kwesiri ọ dazịri bii.
\v 13 Kwnornu nụ Chiokike beru ọsno kpụ Adam, omekwo, ọ kpụ Ivu.
\v 14 Setani dúhiele Adam, kọvu o duhieru nyerinya wam, ọ ghọ nye mmehie.
\v 15 Kọvu Chiokike jọoznohia ele rinya hite n'ọmumu nnwọ\f + \fr 2:15 \fq hite n'ọmumu nnwọ \ft mọbu \fq nụ ọmumu nnwọ \f* ọ bụru nụ be jeenwe ọkwnata ovu, nụ ọwhnun'anya, nụ ọzi nsọ nụ anya udno.
\c 3
\s1 Ele risi ọgbako Chiokike
\p 
\v 1 Ka bụ ikwu-ọnu ke kwesiri be kwnata ovu. Ọ bụru nụ nye ọbula ke pioru ọ bụru nye risi ọgbako Chiokike, o noopio nhne bụru ọma.
\v 2 Kịtna, nye risi ọgbako Chiokike jọoburu nye nwée ọtna, nye nwernu otu nnwerne, nye anya udno, nye mkpọma dụru ẹli, nye be nọosonu anya, nye nookwubna ele izne, nye nwernu rikne o zni nhne,
\v 3 nye nwọ́ okne manya, nye mée nhne rikne, enwerne badnụ, nye zá nookno ọka, nye whnụ́ge ịwai n'anya.
\p 
\v 4 Nye risi ọgbako Chiokike jọoburiri nye nwernu rikne chịkwa ezi-nụ-ọro a nkarị, rụmu a jọoburu ele noobnonu a nsnị, nọoso a anya.
\v 5 (Ọ bụru nụ nye ọbula nwée rikne chịkwa ọro a nkarị, ndaa kpa o jeenwe rikne legidne ọgbako Chiokike anya?)
\v 6 Ọ jọ́oburu nye varụ ikne n'ọgbako Chiokike, ọ zị o mee oknomokno, dnabna n'otu ikpe ọmuma wam lele Ekwensu.
\v 7 Ọ jọoburu nye nwernu rẹwhna ọma n'ederezi, ọ zị ọ dnabna nụ nhne iwhnerne nụ mbịta Ekwensu.
\p 
\v 8 Ele dikneni masị jọoburu ele be nọosonu anya, ele ezi ọka, ele nwọ́ okne manya, ele zá noopio iru zíle ezi.
\v 9 Be jeeji mkpọma bụru ọma jidnesi ezi ọka ke Chiokike nyernu aị rikne gbasịri ọkwnata ovu.
\v 10 Be jeebe ọsno kpa be iru, ọ bụru nụ ọ zá nhne ke megidnernu be, be bụru dikneni ọgbako Chiokike.
\p 
\v 11 Ele nnwerne be masị jọoburu ele nwernu ọson'anya, ele zá nookwu ọka etekne, kọvu ele ovu ọma, ele be kwesiri ọ tụkwasi ovu nụ kpakara nhne.
\p 
\v 12 Nye dikneni jọoburiri nye nwernu otu nnwerne, nye nẹechikwa rụmu a nụ ezi-nụ-ọro a nkarị.
\v 13 Ele nọornu ẹrnu be nkarị jeenwehịa ovulizọ n'olu bụru ọma, be joogwuzosi rikne n'ọkwnata ovu ke zị nụ rime Karaịsi Jizọsi.
\s1 Nhne tugwaru otugwa // ke okpukpe aị
\p 
\v 14 M naagbanụ ị ọkwukwo ka, ọ bụ n'ezi nụ m neele anya nụ m jaava wara wara.
\v 15 Kọvu ọ bụru me gbu ọkwnu, m naagba ma ị mahịa kpa ele badnụ jaabịta ẹhni be nụ ezi-nụ-ọro Chiokike ke bụ ọgbako Chiokike ke zị bụdnu, ke bụ nsnụsnu ọro nụ ntụ-ẹli ezi ọka.
\v 16 A zá neesigha ọka, nhne tugwaru otugwa ke okpenu Chiokike zị agịda,
\q1 Jizọsi whụyaru iwhne n'anọ-ẹhni,
\q2 Enine Nsọ gbarụ akebne a,
\q1 ele enine izi whnụrnu a,
\q2 be kpọru okwo a n'esilawụru kpakara mba,
\q1 ele badnụ kweru a n'ọwa,
\q2 Chiokike kwuru a la n'oligwe n'igwugwu.
\c 4
\s1 Pọlu znirni Timoti ezni
\p 
\v 1 Enine Nsọ kwuru kpa o dnornu anya nụ ige ipne-aznụ nụ ele badnụ jọowhoga n'ọkwnata ovu snornu enine ke nooduwhu nụ nhne ele rẹnwu ọjo neezni.
\v 2 Ka bụ iznizni ke ele ruwhnu lawụru neezni n'aghalaghala, ele jiri rugwe bẹkwnu da akọniche be.
\v 3 Be kwéle ele badnụ lụ nnwerne mọbu gbọ nzi, be kanụ ele badnụ be rí agwna wiri, ke Chiokike keru ma ele kweru ekwe gweru ọtu mmamma ri, bụ ele mahịaru ezi ọka.
\v 4 Kwnornu nụ kpakara nhne Chiokike keru bụru ọma, ọ zá ke badnụ jéeri, ọ bụru nụ o gweru a, tụ mmamma.
\v 5 Be ji ikwu-ọnu nụ okpukpe Chiokike bịta wiri nsọ.
\p 
\v 6 Ọ bụru nụ ị kanụ rụmu nda kpakara nhne ka, ị jọoburu nye izi Karaịsi Jizọsi ọma, nye be jiri ezi ọka ke ọkwnata ovu nụ iznizni ọma ke i snornu znụ.
\v 7 Ọ zá nhne i ji ọtnutnu ruwhere etekne nụ ọka ele nnwerne okno badnụ mee, znụhia ẹhni ị ma ị bụru nye nọotu ogwnu Chiokike.
\v 8 Kwnornu nụ ọznuznu ke anọ-ẹhni nwernu iru matị, kọvu ọmahia Chiokike bnarnụ iru nụ kpakara nhne, o vugwu mkwna ke bụdnu ka nụ bụdnu ke jaava.
\p 
\v 9 Ka bụ ikwu-ọnu ke be kwesiri ọ tụkwasi ovu, ke badnụ kwesiri o kweru.
\v 10 Ka bụ risi nhne a kwno nọodoli n'ẹrnu, naagba ọtna, nụ olile anya aị zị nụ Chiokike ke zị bụdnu, Nye Ọznohia ke kpakara badnụ, ke kakwo ke ele kweru ekwe.
\p 
\v 11 Zni kpakara nhne ka, nyee iwu ma ele badnụ mee nhne i neezni.
\v 12 I kwé nye ọbula ledna ị anya kwnornu nụ ị bụ nnwọ ikoro. Kọvu bụru nhne atụ ke ele kweru ekwe, ma n'ikwu-ọnu, nụ bụdnu, nụ ọwhnun'anya, nụ ọkwnata ovu, nụ ọzi snam.
\v 13 Tem m va, gweru ẹhni ị yisi nụ ọgwnu nhne be gbarụ n'ọkwukwo nsọ nụ rime ọgbako Chiokike, nọokpo okwo, neezni nhne.
\v 14 I léwhu nkesi i anya, ke be nyernu hite n'izi ọwhnurninya wam nga ele okno badnụ tụkwasiri ị aka nụ risi.
\p 
\v 15 Anya dụ ị ẹli gbasịri kpakara nhne ka, gweru ẹhni ị yisi neeme be ma kpakara ele badnụ whnụ nụ i nooso oso.
\v 16 Ledu anya nụ bụdnu ị nụ kpakara nhne i neezni. Gbalị neeme kpakara nhne ka, kwnornu nụ i mee kpam, i jọoznohia ẹhni ị ma ele nọonu nhne i neezni.
\c 5
\s1 Kpa a jeemesno ele badnụ
\p 
\v 1 I bígbọ nye okno badnụ rikne rikne, kọvu kwunu a ọka lele nụ ọ bụ nda ị. Mesno rụmu ikoro lele rụmu nwene.
\v 2 Mesno ele rinya okno badnụ lele nụ be bụ nne i, gweru ọzi rịchna sọ rụmu oknornokno anya lele rụmu nwene i rinya.
\p 
\v 3 Lekọta ele rinya nzi be nwụrnu ele zị nụ mkpa anya nkarị.
\v 4 Kọvu ọ bụru nụ nyerinya nzi a nwụrnu nwernu rụmu mọbu rụmu rụmu a, rụmu be beru ọsno mụhia kpa be kpenu Chiokike, hite n'olekasi ele mụrnu be anya, lele kpa ele mụrnu be jiri lekasi be. Ka bụ nhne nọoso Chiokike ovu n'ọnu.
\v 5 Nyerinya nzi a nwụrnu ke nwée badnụ ọbula neelekwasi Chiokike anya, neekpe okpukpe iwhnehnie nụ abalị ma Chiokike yisinu a aka.
\v 6 Kọvu nyerinya nzi a nwụrnu ke noowu bụdnu ke nọoso a n'ọnu nwụrnu ọnwu kpa ọ zị bụdnu.
\v 7 Kanụ be mee kpakara nhne ka, ma be mee nhne bụru ọma.
\v 8 Ọ bụru nụ nye ọbula nwée rikne legidne ele ọro a, ke kakwo ele ezi-nụ-ọro a, nye wam gọnahorulam ọkwnata ovu, nye máa Chiokike ka nye wam mma.
\p 
\v 9 Nyerinya ke nzi a nwụrnu ke gbarụ nri awha isunu, be gwnụsi a n'esilawụru ele nzi be nwụrnu, nye kwesiri nzi a kwnata a ovu,\f + \fr 5:9 \ft mọbu \fq nye nwernu otu nzi \f*
\v 10 nye be jiri ẹrnu ọma a mahịa, nye nọoznu rụmu a nkarị, neelekọta ele izne nkarị, snornu ele nsọ snụ ọchi be, nye neeyinu ele zị nụ mkpa aka, nọornu agịda ẹrnu ọma.
\p 
\v 11 Kọvu ị gbásị rẹwhna oknornokno nye nzi a nwụrnu n'ọkwukwo. Kwnornu nụ nga anọ-ẹhni kpalizọru be, be jéenwe rikne gwuzonu Karaịsi, be pio ọ gbọru nzi berere.
\v 12 Be bụru ele ikpe marnụ, kwnornu nụ be luluru mkwna be kweru nụ mbọm.
\v 13 Tụkwasi n'olu ka, be bụru ele nwée nhne be mee, be neezne n'ọro n'ọro noozno izno, nookwu nhne gbásịla be, nookwu nhne be kwésile o kwu.
\v 14 Kam kpayarụ, m neeznikwa ele oknornokno ele nzi be nwụrnu, be gbọru nzi berere, mụhia rụmu, legidne ọro be anya ọ zị be nyee nye irno wam oghere ọ kaja be nụ ọgbako Chiokike.
\v 15 Agwna ele rinya wam snornulem Setani.
\p 
\v 16 Ọ bụru nụ nyerinya ọbula nwernu nnwerne nzi a nwụrnu n'ọro a, o yinu be aka, o kwé ọgbako Chiokike vuru ivu nye wam, kọvu ma ọgbako Chiokike lebna anya n'oyinu ele rinya nzi be nwụrnu ele zị nụ mkpa aka.
\p 
\v 17 Ele okno badnụ, ele neelegidne ọgbako Chiokike anya kwesiri be sọnu be anya okpukpu lawụru, ke kakwo ele nọokpo okwo izi ọma, neezni nhne.
\v 18 Kwnornu nụ ọkwukwo nsọ kwuru kpa, “Ị knésni ọnu ehni ke nọozosna ịkpa,” nụ “Nye ẹrnu kwesiri ọgwo ẹrnu a.”
\v 19 Ị kwékọ nhne ọbula be bnornu nye okno badnụ, okwolem ma be nwernu ele akebne lawụru mọbu ẹto.
\v 20 Bigbọ nye okno badnụ ọbula mernu mmehie nụ ruwhnu ọhna, ma ele berere mụhia nhne.
\p 
\v 21 M noogwuzo nụ ruwhnu Chiokike nụ Karaịsi Jizọsi nụ ele enine izi Chiokike họhiaru neenye i iwu ka, bịta kpakara nhne ka me nyernu ị, i lé badnụ anya nụ ruwhnu kpa ị neeme be.
\p 
\v 22 I mée wara wara nọotukwasi ele badnụ aka, i snó ele berere nụ mmehie be. Kọvu bịta ẹhni ị nsọ.
\p 
\v 23 Ị nwọ́ma mini kpọi, kọvu nwọ manya matị kwnornu nụ rụwho i nụ ẹhni igbugbu ị naarịa ige ọbula.
\p 
\v 24 Mmehie agwna ele badnụ kpumernu, beru be ọsno neezne n'ikpe, kọvu mmehie agwna ele berere sno be n'aznụ.
\v 25 Kpam masị, ẹrnu ọma whụyaru iwhne, ọ bụru nụ be whọ́ge iwhne, be nwée rikne kpusni be.
\c 6
\p 
\v 1 Nye ọbula ke bụ ọhi whnụ nụ ọ nọoso nye nwe a anya lele kpa o kwesiri, ma be gharụ ọ kaja rẹwhna Chiokike nụ iznizni a.
\v 2 Ele ọhi ke ele nwe be kweru nụ Chiokike lédna be anya, kwnornu nụ be bụ rụmu nda. Tnụnuma, be rnụnu be ẹrnu ka mma kwnornu nụ ele neerihịa mbnarna n'ẹrnu be bụ ele kweru ekwe, ele be whnụrnu n'anya. Ka bụ nhne i kwesiri neezni, ma be neeme masị be.
\s1 Ọwhnu ịwai n'anya
\p 
\v 3 Ọ bụru nụ nye ọbula neezni iznizni aghalaghala, ke kwéle nụ n'iznizni ke nọotu ogwnu Chiokike nụ iznizni ke zị snam ke Nyenwe aị Jizọsi Karaịsi,
\v 4 nye wam bụ nye oknomokno. Kọvu ọ máa nhne ọbula. Echiche a bụ́o ọma, ka noodubna nụ okno ọka, nụ ọwho-anya, ọlu ọgwnu, ọka ọjo, anya ọjo,
\v 5 ọdogbuta zị n'esilawụru ele ovu ọjo, ele tuwhuru ezi ọka. Be neeche nụ okpenu Chiokike bụ apna be jeeji neenwehịa iru ke be.
\p 
\v 6 Kọvu okpenu Chiokike nụ rụwho ojiji bnarnụ mbnarna k'agịda.
\v 7 Kwnornu nụ ọ zá nhne a vuru va n'ọwa, a nwée masị rikne vuru nhne ọbula whọga nụ rime a.
\v 8 Kọvu ọ bụru nụ a nwernu wiri oriri nụ iwo o kpusni ẹto aị, ka kwesiri o ji aị rụwho.
\v 9 Ele noopio ọ bụru ele eze naadnabna nụ rime ọrnurna nụ mbịta, nụ agịda nhne iwhnirniwhno ke naakpakna be ẹhni, ke noodubna ele badnụ nụ mwhu.
\v 10 Kwnornu nụ ọwhnun'anya ịwai bụ mgbarẹgwnugwnu kpakara nhne ọjo zị ọdo nụ ọdo. Agwna ele noopio ịwai k'agịda kpawhuru n'ọkwnata ovu, gweru agịda nhne igbugbu mekasi ẹhni be ẹhni.
\s1 Lụ ọgwnu ọma // ke ọkwnata ovu
\p 
\v 11 Kọvu, jị badnụ ke Chiokike, gbanahọru kpakara nhne ka. Tnụnuma, snornu ome mma, ọtu ogwnu Chiokike, ọkwnata ovu, ọwhnun'anya, ndidi nụ ọzi wọhnernerne.
\v 12 Lụ ọgwnu ọma ke ọkwnata ovu. Jikwasi bụdnu kwó okwo aka ke Chiokike nyernu i nga ị kwuhịaru ọkwnata ovu i nkarị nụ ruwhnu agịda ele akebne.
\v 13 Nụ ruwhnu Chiokike nye neenye kpakara nhne bụdnu, nụ Karaịsi Jizọsi, nye gbarụ akebne ọma nụ ruwhnu Pọntiosi Paịleti, m neenye i iwu,
\v 14 bịta nhne ka ma ị gharụ o nwe ntụpo nụ ọtna tem Nyenwe aị Jizọsi Karaịsi va,
\v 15 nye Chiokike jeegweya n'ige ke a, nye nwe ngọzi, nye nẹechi kpọi, Eze kakwo ele eze, nụ Nyenwe kakwo ele nwe.
\v 16 Chiokike ke zị bụdnu ọkwnukokwnu, nye wu n'iwhne ke ọ zá nye nwernu rikne vadu ndụndu, nye ọ zá nye whnụleru anya, mọbu whnụli a anya, ọson'anya nụ rikne bụru ke a tim tọm. Amịm.
\p 
\v 17 Dọ ele eze ke ọwa ka aka nụ nsnị be bụ́o ele oknomokno, be tụ́kwasi ẹkwnu be ovu, ke jáazị tim tọm, kọvu be tụkwasi Chiokike ovu nye naasama aka a neenye aị kpakara nhne bụru ọma ke a neeri.
\v 18 Dọ be aka nụ nsnị, be mee nhne bụru ọma, be bụru ele barụ aba n'ome nhne bụru ọma, ele ovu ọma ke neekesi ele badnụ nhne be nwernu.
\v 19 Be mee kpam, be nọotu ntụ-ẹli bụru ọma ke zị kwem n'ige naava, ma be nwehịa bụdnu ke bụ ezi.
\p 
\v 20 Timoti, legidne nhne be yisiri ị n'aka anya nkarị. Whọga nụ nhne ọbula ke neegweya ikwu-ọnu ke neemegidne ogwnu Chiokike nụ ọka iwhnirniwhno ke nụ lele nụ o nwernu akọniche, kọvu o nwée.
\v 21 Agwna ele badnụ snornu a kpawhu n'ọkwnata ovu.
\p Oru Chiokike dazịnu anụ.
