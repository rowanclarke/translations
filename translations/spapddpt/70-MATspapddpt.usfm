\v 11 \wj \+w Lo|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w entra|strong="G1525"\+w* \+w en|strong="G1519"\+w* \+w la|strong="G3588"\+w* \+w boca|strong="G4750"\+w* \+w no|strong="G3756"\+w* \+w contamina|strong="G2840"\+w* \+w al|strong="G3588"\+w* hombre, sino \+w lo|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w sale|strong="G1607"\+w* \+w de|strong="G1537"\+w* \+w la|strong="G3588"\+w* \+w boca|strong="G4750"\+w*.\wj*   
