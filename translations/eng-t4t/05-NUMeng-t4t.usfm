\p 
\v 31 \w Then|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w sent|strong="H3068"\w* \w a|strong="H3068"\w* strong \w wind|strong="H7307"\w* \w from|strong="H4480"\w* \w the|strong="H6440"\w* \w sea|strong="H3220"\w*. \w It|strong="H5921"\w* blew \w quail|strong="H7958"\w* \w into|strong="H5921"\w* \w the|strong="H6440"\w* \w area|strong="H5439"\w* \w all|strong="H5439"\w* \w around|strong="H5439"\w* \w the|strong="H6440"\w* \w camp|strong="H4264"\w* \w for|strong="H5921"\w* miles \w in|strong="H5921"\w* \w every|strong="H5439"\w* \w direction|strong="H1870"\w*, \add and caused the quail to fall onto the ground\add*. \w They|strong="H3117"\w* \w were|strong="H3117"\w* piled \w up|strong="H5921"\w* \w on|strong="H5921"\w* \w the|strong="H6440"\w* \w ground|strong="H6440"\w* \w about|strong="H5439"\w* ◄3 feet/1 meter► \w high|strong="H4480"\w*!
