\id EXO  
\h Pukaana 
\toc1 Pukaana 
\toc2 Pukaana 
\toc3 Pukaana 
\mt1 Pukaana  
\c 1  
\s1 KA BUKE ALUA A MOSE, I KAPAIA  
\q1
\v 1 EIA na inoa o na keiki a Iseraela, i hele aku me Iakoba i Aigupita, o kela kanaka keia kanaka i hele aku me ko ka hale ona.   
\q1
\v 2 O Reubena, o Simeona, o Levi, o Iuda,   
\q1
\v 3 O Isakara, o Zebuluna, o Beniamina,   
\q1
\v 4 O Dana, o Napetali, o Gada a o Asera.   
\q1
\v 5 O na mea ola a pau i puka mai ai, mai loko ae o ko Iakoba puhaka, he kanahiku lakou; a ma Aigupita no o Iosepa.   
\q1
\v 6 A make iho la o Iosepa, a me kona poe hoahanau a pau, a me ia hanauna a pau.   
\b  
\q1
\v 7 Hanau nui iho la na mamo a Iseraela, a laha loa ae la, a kawowo loa: ua nui loa ko lakou ikaika, a ua piha hoi ka aina ia lakou.   
\b  
\q1
\v 8 A ku mai la kekahi alii hou ma Aigupita, aole i ike ia Iosepa.   
\q1
\v 9 I mai la ia i kona poe kanaka, Aia hoi, ua oi aku ka nui o na kanaka mamo a Iseraela, a me ko lakou ikaika i ko kakou.   
\q1
\v 10 E hana maalea kakou ia lakou; o nui auanei lakou, a hiki mai ke kaua, huipu lakou me ko kakou poe enemi, a e kaua mai hoi ia kakou, a pela ia lakou e pii aku ai mai ka aina aku.   
\q1
\v 11 A hoonoho aku lakou i na luna hooluhi maluna o lakou, i mea e hookaumaha loa ai ia lakou i na haua nui. A hana iho la lakou i na kulanakauhale papaa no Parao, o Pitoma, a o Ramese.   
\q1
\v 12 E like me ko lakou hooluhi ana mai, pela no hoi ko lakou nei mahuahua, a me ka palahalaha ana aku. A makau loa lakou i na mamo a Iseraela.   
\q1
\v 13 Hoohana iho la ko Aigupita i na mamo a Iseraela me ka hookoikoi.   
\q1
\v 14 Hooawahia iho la lakou i ko lakou nei ola ana i ka hana luhi iloko o ka palolo, a i na pohakulepo, a me na hana a pau ma ka mahinaai: a o ka hana a pau a lakou i hoohana iho ai ia lakou nei, he mea koikoi ia.   
\b  
\q1
\v 15 Olelo mai la ke alii o Aigupita i na palekeiki Hebera, o Sipera ka inoa o kekahi, a o Pua hoi ka inoa o kekahi;   
\q1
\v 16 I mai la, A i palekeiki olua i na wahine Hebera, a nana olua iloko o na paholoi; ina he keikikane ia, alaila e pepehi olua ia ia; aka ina he kaikamahine, e ola no ia.   
\q1
\v 17 Aka, makau iho la na palekeiki i ke Akua; aole laua i hana i ka mea a ke alii o Aigupita i kauoha ai in laua; aka, hoola ae la laua i na keikikane.   
\q1
\v 18 Kii mai la ke alii o Aigupita i na palekeiki, i mai la ia laua, No ke aha la olua i hana'i i keia mea, a hoola i na keikikane?   
\q1
\v 19 I aku la na palekeiki ia Parao, No ka mea, aole i like na wahine Hebera me ko Aigupita poe wahine, he hiki wawe ko lakou, aole e hiki aku na palekeiki, a hanau e no lakou.   
\q1
\v 20 A hoomaikai mai la ke Akua i na palekeiki: a mahuahua aku la na kanaka, a ua nui loa no hoi ko lakou ikaika.   
\q1
\v 21 A no ka makau ana o na palekeiki i ke Akua, a no kona hoomahuahua ana i ko lakou mau ohana,   
\q1
\v 22 Kauoha ae la o Parao i kona poe kanaka a pau, i aku la, O na keikikane a pau ke hanau mai, e kiola aku ia lakou i ka muliwai, aka, o na kaikamahine a pau, ka oukou ia e hoola ai.   
\c 2  
\b  
\q1
\v 1 KII aku la kekahi kanaka o ka ohana a Levi, a lawe ae la i kekahi kaikamahine a Levi.   
\q1
\v 2 Hapai ae la ua wahine la, a hanau mai la he keikikane; a ike iho la oia ia ia he maikai, huna iho la oia ia ia ekolu malama.   
\q1
\v 3 A i ka wa hiki ole ia ia ke huna hou aku, lawe ae la ia i waa kome nona, a hapala ia mea i ka bitumena a me ke kepau, a hahao iho la i ke keiki maloko; a waiho iho la maloko o na kaluha ma kapa o ka muliwai.   
\q1
\v 4 A ku iho la kona kaikuwahine i kahi mamao aku, e nana i ka mea e hanaia mai ai ia ia.   
\b  
\q1
\v 5 Iho iho la ke kaikamahine a Parao e auau ma ka muliwai, hele ae la hoi kona mau wahine ma kapa o ka muliwai: a ike aku la kela i ka waa iwaena o na kaluha, hoouna aku la ia i kona wahine e lawe mai.   
\b  
\q1
\v 6 A wehe aku la ia, alaila ike iho la i ke keiki: aia hoi, uwe ae la ua keiki la. Aloha aku la kela ia ia, i aku la. He keiki keia na ka Hebera.   
\q1
\v 7 Alaila, olelo aku la kona kaikuwahine i ke kaikamahine a Parao, E hele hoi ha wau, e kii aku nou i kekahi wahine Hebera i kahu nana e hanai i ke keiki nau?   
\q1
\v 8 I mai la ke kaikamahine a Parao ia ia, O hele. A hele aku la ke kaikamahine, a kii aku la i ka makuwahine o ua keiki la.   
\q1
\v 9 I mai la ke kaikamahine a Parao ia ia, E lawe oe i keia keiki a e hanai ia ia na'u, a na'u no oe e uku aku. Lawe ae la ua wahine la i ke keiki, a hanai iho la.   
\q1
\v 10 A nui ae ua keiki la: a lawe ae la oia ia ia i ke kaikamahine a Parao, a lilo ae la ia i keiki nana. Kapa iho la oia i kona inoa, o Mose, i iho la ia, No ka mea, ua lawe mai au ia ia mailoko mai o ka wai.   
\b  
\q1
\v 11 Ia mau la mai, i ko Mose wa kanaka makua, hele aku la ia i kona poe hoahanau, nana aku la ia i ko lakou luhi ana; ike aku la ia i kekahi kanaka o Aigupita e pepehi ana i ka Hebera, i kekahi o kona poe hoahanau.   
\q1
\v 12 Aloalo ae la ia, a ike iho la, aole kanaka, alaila pepehi iho la ia i ka Aigupita a make, a huna ia ia maloko o ke one.   
\q1
\v 13 A i ka lua o ka la, hele hou aku la no ia, aia hoi, elua kanaka Hebera e hakaka ana; i aku la ia i ka mea nona ka hewa, No ke aha la oe e pepehi aku nei i kou hoa?   
\q1
\v 14 I mai la kela, Nawai la oe i hoolilo ao nei i alii, a i lunakanawai maluna o makou? Ke manao nei anei oe e pepehi mai ia'u, e like mo kou pepehi ana i ka Aigupita? Alaila makau iho la o Mose, i iho la, Oiaio no, ua ikeia koia mea.   
\q1
\v 15 A lohe ae la o Parao ia mea, imi iho la ia o pepehi ia Mose. Mahuka aku la o Mose mai ka maka aku o Parao, a noho ma ka aina ma Midiana: a noho iho la ia ilalo ma kekahi luawai.   
\b  
\q1
\v 16 He mau kaikamahine ehiku na ke kahuna ma Midiana. Hele mai la lakou a hukihuki i ka wai, a ninini iloko o na holowaa, e hooinu ai i na holoholona a ko lakou makuakane.   
\q1
\v 17 Hele mai la kekahi poe kahuhipa, a kipaku ae la ia lakou. Ku ae la o Mose iluna, a kokua ia lakou, a hooinu aku la i ka lakou poe holoholona.   
\q1
\v 18 A hoi aku la lakou ia Reuela i ko lakou makuakane, ninau mai la ia, No ke aha la oukou i hoi koke mai ai i koia la?   
\q1
\v 19 I aku la lakou, Na kekahi kanaka o Aigupita i hoopakele ae ia makou mai ka lima mai o ka poe kahuhipa, a huki iho la ia i ka wai no makou a nui, a hooinu aku la i na holoholona.   
\q1
\v 20 I mai la ia i kana poe kaikamahine, Auhea la hoi ia? No ke aha la oukou i haalele aku ai i ua kanaka la? E kii aku ia ia e ai ia i ka ai.   
\q1
\v 21 A walea iho la o Mose e noho me ia kanaka, a haawi mai la oia ia Zipora, kana kaikamahine na Mose.   
\q1
\v 22 A hanau mai la ia he keikikane, a kapa aku la ia i kona inoa o Geresoma; no ka mea, i iho la ia, Ua malihini au ma ka aina e.   
\b  
\q1
\v 23 A nui na la i hala, make ke alii o Aigupita, a kaniuhu iho la ka poe mamo a Iseraela, no ka luhi loa ana, a uwe aku la lakou; a hiki aku la ko lakou uwe ana i ke Akua no ko lakou luhi.   
\q1
\v 24 A lohe ke Akua i ko lakou uwe ana, a manao iho la ia i kana berita me Aberahama, a me Isaaka, a me Iakoba.   
\q1
\v 25 A nana mai la ke Akua i ka poe mamo a Iseraela, a manao mai la ko Akua ia lakou.   
\c 3  
\b  
\q1
\v 1 HANAI iho la o Mose i na holoholona a Ietero a kona makuahonowaikane, a ke kahuna ma Midiana; alakai aku la no ia i na holoholona ma ke kua o ka waonahele, a hiki aku la i ke kuahiwi o ke Akua, i Horeba.   
\q1
\v 2 Ikea mai la e ia ka anela o Iehova maloko o ka lapalapa o ke ahi mawaenakonu o ka laalaau: nana aku la ia, aia hoi, e aa ana ka laalaau i ko ahi, aole nae i pau ka laau.   
\q1
\v 3 I iho la o Mose, E kipa ae no wau e ike i keia mea nui, i ka mea i pau ole ai ka laau i ke ahi.   
\q1
\v 4 A ike mai la o Iehova i kona huli ana e makaikai, hea mai la ke Akua ia ia mailoko mai o ua laalaau la, E Mose, e Mose. I aku la ia, Eia no wau.   
\q1
\v 5 I mai la kela, Mai hookokoke mai oe: e wehe ae oe i kou mau kamaa mai kou mau kapuwai aku, no ka mea, o kahi au e ku nei, he aina hoano ia.   
\q1
\v 6 I mai la hoi oia, Owau no ke Akua o kou makuakane, ke Akua o Aberahama, ke Akua o Isaaka, ke Akua hoi o Iakoba. Papani iho la o Mose i kona maka; no ka mea, ua makau ia ke nana aku i ke Akua.   
\b  
\q1
\v 7 I mai la o Iehova, I kuu nana ana ua ike no wau i ka luhi ana o ko'u poe kanaka ma Aigupita, ua lohe no hoi au i ka lakou kaniuhu ana, no na luna hooluhi o lakou; ua ike hoi au i ko lakou ehaeha ana.   
\q1
\v 8 Ua iho mai nei au ilalo nei e hookuu ia lakou mai ka lima mai o ko Aigupita, a e lawe mai ia lakou mai ia aina mai, a kekahi aina maikai. a nui no hoi. he aina e kahe ana o ka waiu a me ka meli; i kahi o ka poe Kanaana, a me ka Heta, a me ka Amora, a me ka Pereza, a me ka Hiva, a me ka Iebusa.   
\q1
\v 9 Eia hoi, no ka mea, ua hiki mai io'u nei ke kaniuhu ana o na mamo a Iseraela; a na ike no hoi au i ka luhi ana a ko Aigupita i hooluhi iho ai ia lakou.   
\q1
\v 10 Nolaila la, e hele mai oe, a na'u no oe e hoouna aku io Parao la, i lawe mai ai oe i o'u poe kanaka, i na mamo a Iseraela mailoko ae o Aigupita.   
\b  
\q1
\v 11 I aku la o Mose i ke Akua, Owai la wau, i hele aku ai au io Parao la, a i lawe mai ai hoi au i na mamo a Iseraela mailoko mai o Aigupita?   
\q1
\v 12 I mai la kela, He oiaio, owau no kekahi me oe, eia hoi ka hoailona o ko'u hoouna ana aku ia oe; i ka wa au e lawe mai ai i ka poe kanaka mai Aigupita mai, e hoomana auanei oukou i ke Akua ma keia kuahiwi.   
\b  
\q1
\v 13 Ninau aku la o Mose i ke Akua, Aia hoi, a hiki aku au i na mamo a Iseraela, a e olelo au ia lakou, Na ke Akua o ko oukou poe kupuna owau i hoouna mai io oukou nei, a e ninau lakou ia'u, Owai kona inoa? Pehea la hoi ka'u e olelo aku ai ia lakou?   
\q1
\v 14 I mai la ke Akua ia Mose, OWAU MAU LOA AKU NO. I mai la hoi oia, Penei kau e olelo aku ai i na mamo a Iseraela, OWAU MAU, oia ka i hoouna mai ia'u io oukou nei.   
\q1
\v 15 I hou mai la ke Akua ia Mose, Penei oe e olelo aku ai i na mamo a Iseraela, Na Iehova ke Akua o ko oukou poe kupuna, ke Akua o Aberahama, ke Akua o Isaaka, ke Akua o Iakoba, owau i hoouna mai io oukou nei. Oia no ko'u inoa mau loa, oia hoi ko'u mea e hoomanaoia i ia hanauna aku ia hanauna aku.   
\q1
\v 16 O hele oe, a e hoakoakoa ae i ka poe lunakahiko o ka Iseraela, a e olelo aku ia lakou, Ua ikeia'ku e au o Iehova ke Akua o ko oukou poe kupuna, ke Akua o Aberahama, o Isaaka a o Iakoba; ua olelo mai oia, Ua ike io no au ia oukou, a me ka mea i hanaia mai ia oukou ma Aigupita.   
\q1
\v 17 Ua olelo hoi au, Na'u no oukou e lawe aku iluna, mailoko ae o ka popilikia o Aigupita, a hiki i ka aina o ka Kanaana a me ka Heta a me ka Amora a me ka Pereza a me ka Hiva, a me ka Iebusa, i ka aina e kahe ana o ka waiu a me ka meli.   
\q1
\v 18 A e hoolohe mai lakou i kou leo: a e hele pu oe me ka poe lunakahiko o ka Iseraela i ke alii o Aigupita, a e olelo aku oukou ia ia, Ua halawai mai me makou o Iehova ke Akua o ka poe Hebera: no ia mea, e hookuu mai oe ia makou e hele ma ka waonahele, i ekolu la hele, e kaumaha aku ai na Iehova ko makou Akua.   
\b  
\q1
\v 19 Ua ike no nae au, aole e hookuu mai ke alii o Aigupita ia oukou, aole no ma ka lima ikaika.   
\q1
\v 20 Aka, e o aku no wau i ko'u lima, a e paopao wau ia Aigupita me na mea mana a pau a'u e hana aku ai mawaena konu o lakou: a mahope e hookuu no oia ia oukou.   
\q1
\v 21 Ae haawi aku wau i ka lokomaikai i keia poe kanaka imua o na maka o ko Aigupita, a i ka wa a oukou e hele mai ai, aole oukou e hele nele mai.   
\q1
\v 22 E noi aku no kela wahine keia wahine i kona hoalauna, a i ka mea e noho pu ana maloko o kona hale, i na mea kala, a me na mea gula, a me na mea aahu, a e hoaahu iho oukou i ka oukou poe keikikane, a me ka oukou poe kaikamahine; e hao hoi oukou i ko Aigupita.   
\c 4  
\b  
\q1
\v 1 OLELO aku la o Mose, i aku la, Aia hoi; aole paha auanei lakou e manaoio mai ia'u, aole hoi e hoolohe mai i ko'u leo; no ka mea, e olelo auanei lakou, Aole i ikeia 'ku o Iehova e oe.   
\q1
\v 2 I mai la o Iehova ia ia, Heaha kela mea ma kou lima? I aku la ia, He kookoo.   
\q1
\v 3 I mai la kela, E hoolei ia ilalo i ka honua. Hoolei iho la ia ilalo i ka honua, a lilo ae la ia i nahesa: a holo aku la o Mose mai kona maka aku.   
\q1
\v 4 I mai la o Iehova ia Mose, E kikoo aku kou lima, a e lalau aku ma kona huelo. Kikoo aku la kona lima a lalau iho la, a hoi hou ae la ia i kookoo ma kona lima.   
\q1
\v 5 Ilaila e manaoio ai lakou, ua ikea e oe o Iehova ke Akua o ko lakou poe kupuna, ke Akua o Aberahama, ke Akua o Isaaka, ke Akua hoi o Iakoba.   
\b  
\q1
\v 6 Olelo hou mai la o Iehova ia ia, E hooholo oe i kou lima ma kou umauma iho. Hooholo ae la ia i kona lima ma kona umauma, a i kona unuhi ana mai, aia hoi, ua lepera ia e like me ka hau.   
\q1
\v 7 I mai la oia, E hooholo hou ae oe i kou lima ma kou umauma. Hooholo hou i kona lima ma kona umauma, a unuhi hou mai, aia hoi, ua hoi hou ae la no e like me kekahi io ona.   
\q1
\v 8 A ina aole lakou e manaoio mai ia oe, aole hoi e hoolohe mai i ka leo o ka hoailona mua, e manaoio paha lakou i ka leo o ka hoailona hope.   
\q1
\v 9 A ina aole lakou e manaoio mai i keia mau hoailona elua, aole hoi e hoolohe i kou leo, alaila e lawe ae oe i kahi wai o ka muliwai, a e ninini ma kahi maloo, a e lilo auanei ka wai au e lawe ai mailoko mai o ka muliwai, i koko ma kahi maloo.   
\b  
\q1
\v 10 I aku la o Mose ia Iehova, E kun Haku e, he kanaka akamai ole wau i ka olelo, aole mamua mai a hiki i keia wa au e olelo mai ai i kau kauwa nei, he kali ko'u waha, a he kali hoi ko'u elelo.   
\q1
\v 11 I mai la o Iehova ia ia, Nawai i hana ka waha o ke kanaka? Nawai hoi i hana i ka aa, a me ke kuli, a me ka ike, a me ka makapo? Aole anei na'u, na Iehova?   
\q1
\v 12 Nolaila, o hele, a owau pu no me kou waha, e ao aku ana ia oe i ka mea au e olelo aku ai.   
\q1
\v 13 I aku la ia, E kuu Haku e, ke noi aku nei au ia oe, e hoouna aku oe ma ka lima o ka mea au e hoouna aku ai.   
\q1
\v 14 Wela mai la ka inaina o Iehova ia Mose, i mai la kela, Aole anei ke kaikuaana ou o Aarona ka Levi? Ua ike no au e hiki no ia ia ke olelo; aia hoi ke hele mai nei ia e halawai me oe: aia ike mai kela ia oe, e olioli auanei oia ma kona naau.   
\q1
\v 15 Nau e olelo aku ia ia, a e waiho aku i na hua ma kona waha; a owau pu no me kou waha, a me kona waha, a e ao aku ia olua i ka olua mea e hana'i.   
\q1
\v 16 A oia no kou mea nana e olelo aku i na kanaka: a e lilo no oia i waha nou, a o oe hoi nona e like me ke Akua.   
\q1
\v 17 E lawe pu aku oe i keia kookoo maloko o kou lima, i mea e hana aku ai i na hoailona.   
\b  
\q1
\v 18 Alaila hele aku la o Mose a hoi aku la io Ietero la i kona makuahonowaikane, i aku la ia ia, E hele paha au, a hoi hou i o'u poe hoahanau aia ma Aigupita, i ike ai au i ko iakou ola ana. I mai la o Ietero ia Mose, O hele oe me ka maluhia.   
\q1
\v 19 I mai la o Iehova ia Mose ma Midiana, E hele oe, a e hoi hou i Aigupita, no ka mea, ua make na kanaka a pau, ka poe i imi e lawe i kou ola.   
\q1
\v 20 Lawe ae la o Mose i kana wahine, a me kana mau keikikane, a hoonoho aku la ia lakou maluna o ka hoki, a hoi aku la ia i ka aina o Aigupita. A lawe pu aku la o Mose i ke kookoo o ke Akua maloko o kona lima.   
\q1
\v 21 I mai la o Iehova ia Mose, I kou hele ana aku e hoi i Aigupita, e ao oe, e hana aku imua o Parao i na hana mana a pau a'u i waiho ai maloko o kou lima: a na'u no e hoopaakiki i kona naau, i hookuu ole ai ia i na kanaka.   
\q1
\v 22 E olelo aku oe ia Parao, Ke i mai nei o Iehova penei, O Iseraela no ka'u keikikane, o ka'u hiapo hoi;   
\q1
\v 23 Ke olelo aku nei au ia oe, E hookuu oe i ka'u keiki, i malama mai ia ia'u: a ina e hoole mai oe i kona hookuuia, aia hoi, e pepehi aku no au i kau keikikane, i kau hiapo hoi.   
\b  
\q1
\v 24 A hiki mai hoi ia ma ke ala, maloko o ka halekipa, halawai mai la o Iehova me ia, a imi iho la e pepehi ia ia.   
\q1
\v 25 Lalau aku la o Zipora i pahi, a okipoepoe iho la i ka omaka o kana keikikane, a hoolei iho la ma kona mau wawae, i mai la, He kane koko oe na'u.   
\q1
\v 26 Hookuu iho la oia ia ia. Alaila olelo ae la ia, He kane koko oe no ke okipoepoe ana.   
\b  
\q1
\v 27 I mai la o Iehova ia Aarona, E hele oe e halawai me Mose ma ka waonahele. Hele aku la ia, a halawai iho la ma ke kuahiwi o ke Akua, a honi ae la ia ia.   
\q1
\v 28 Hai ae la o Mose ia Aarona i na olelo a pau a Iehova, nana ia i hoouna mai, a me na ouli a pau ana i kauoha mai ai ia ia.   
\b  
\q1
\v 29 Hele aku la o Mose laua o Aarona, hoakoakoa iho la laua i na lunakahiko a pau o na mamo a Iseraela.   
\q1
\v 30 Hai aku la o Aarona i na olelo a pau a Iehova i olelo mai ai ia Mose; a hana iho la ia i na ouli imua o na maka o kanaka.   
\q1
\v 31 Manaoio iho la no hoi na kanaka: a lohe pono no lakou, ua ike mai o Iehova i ka poe mamo a Iseraela, a ua nana mai hoi oia i ko lakou popilikia, alaila kulou iho la ko lakou poo, a hoomana aku la.   
\c 5  
\b  
\q1
\v 1 MAHOPE iho, hele aku la o Mose laua o Aarona, a hai aku la ia Parao, Ke i mai nei o Iehova ke Akua o ka Iseraela penei, E hookuu mai oe i ko'u poe kanaka, i ahaaina lakou na'u ma ka waonahele.   
\q1
\v 2 I mai la o Parao, Owai la o Iehova i hoolohe ai au i kona leo, e hookuu aku ai i ka Iseraela? Aole au i ike ia Iehova, aole hoi au e hookuu aku i ka Iseraela.   
\q1
\v 3 I aku la laua, ua halawai mai me makou ke Akua o ka poe Hebera; no ia mea, e hookuu oe ia makou e hele i ka waonahele, i kahi ekolu la hiki, e kaumaha aku ai na Iehova o ko makou Akua, o kau mai ia maluna o makou i ke ahulau a me ka pahikaua.   
\q1
\v 4 I mai la ke alii o Aigupita ia laua, No ke aha la olua, e Mose a me Aarona, e hooki nei i kanaka i ka lakou hana? E hoi oukou ma ko oukou luhi.   
\q1
\v 5 Olelo mai la o Parao, Aia hoi, ua nui loa na kanaka o ka aina, a ke hooki nei olua ia lakou i ko lakou luhi.   
\b  
\q1
\v 6 Ia la no, kauoha mai la o Parao i na lunahooluhi o na kanaka; a me ko lakou mau luna iho, i mai la,   
\q1
\v 7 Mai haawi hou aku i ka mauu i kanaka no na pohakulepo, e like mamua. E hele lakou e hoiliili i ka lakou mauu.   
\q1
\v 8 A o ka nui o na pohakulepo a lakou i hana'i mamua, pela oukou e haawi hou aku ai ia lakou; mai hoemi iki ia mea; no ka mea, ua molowa lakou: no ia mea, ke uwe mai nei lakou, i ka i ana mai, E hele makou e kaumaha aku na ko makou Akua.   
\q1
\v 9 E kau i ka hana kaumaha maluna o na kanaka, i hana aku ai lakou ilaila, i hoolohe ole ai hoi lakou i na olelo wahahee.   
\b  
\q1
\v 10 Hele aku la na lunahooluhi o na kanaka, a me ko lakou poe luna iho, olelo ae la i kanaka, i ae la, Ke i mai nei o Parao penei, Aole au e haawi aku i mauu ia oukou.   
\q1
\v 11 E hele oukou, e kii i mauu na oukou iho i kahi e loaa'i ia oukou; no ka mea, aole loa e hoemi iki ia ka oukou mea hana.   
\q1
\v 12 No ia mea, auwana wale aku no na kanaka ma ka aina a pau o Aigupita, e hoiliili i ka opala i mauu.   
\q1
\v 13 Wikiwiki mai la na lunahooluhi, i mai la ia lakou, E hoolawa i ka oukou hana, i ka hana o kela la o keia la, e like me ka wa mauu.   
\q1
\v 14 A o na luna o na mamo a Iseraela, o ka poe i hoonohoia maluna o lakou e na lunahooluhi o Parao, ua hahauia mai lakou, me ka ninauia mai, No ke aha la oukou i hoolawa ole ai i ka oukou hana i na pohakulepo inehinei, a i keia la hoi, e like mamua?   
\b  
\q1
\v 15 Hele aku la na luna o na mamo a Iseraela, a uwe aku la ia Parao, i aku la, No ke aha la oe e hana mai ai pela i kau poe kauwa nei?   
\q1
\v 16 Aole i haawiia mai ka mauu i kau poe kauwa, a ke i mai nei lakou ia makou, E hana oukou i na pohakulepo: aia hoi, ua hahauia mai nei kau poe kauwa: aka, no kou poe kanaka iho ka hewa.   
\q1
\v 17 I mai la kela, Ua palela oukou, ua palela oukou; no ia mea, ke olelo mai nei oukou, E hookuu mai oe ia makou e hele, e kaumaha aku na Iehova.   
\q1
\v 18 E hele hoi oukou pela e hana, no ka mea, aole loa e haawiia'ku ka mauu na oukou, aka, e hoolawa oukou i ka hana o na pohakulepo.   
\q1
\v 19 Ike iho la na luna o na mamo a Iseraela, ua nui ko lakou pilikia, i ka i ana mai, Mai hoemi iki oukou i na pohakulepo i ka oukou hana ana i kela la i keia la.   
\b  
\q1
\v 20 Halawai lakou me Mose laua o Aarona, e ku ana ma ke alanui i ko lakou hele ana mai, mai o Parao mai.   
\q1
\v 21 I ae la lakou ia laua, E nana mai o Iehova ia olua, a e hoahewa mai; no ka mea, ua hoolilo olua i ko makou ala i mea pilau imua o Parao, a imua o kana poe kauwa, i ka haawi ana i ka pahikaua maloko o ko lakou lima, e pepehi mai ai ia makou.   
\b  
\q1
\v 22 Hoi hou aku la o Mose io Iehova la, i aku la ia ia, E ka Haku e, no ke aha la oe i hana ino mai ai i keia poe kanaka? No ke aha la oe i hoouna mai nei ia'u?   
\q1
\v 23 No ka mea, mai ka manawa a'u i hele aku ai io Parao la e olelo aku ma kou inoa, ua hana ino mai kela i keia poe kanaka, aole hoi oe i hookuu iki mai i kou poe kanaka.   
\c 6  
\b  
\q1
\v 1 ALAILA olelo mai la o Iehova ia Mose, Ano, e ike auanei oe i ka mea a'u e hana aku ai ia Parao: no ka mea, e hookuu aku no oia ia lakou me ka lima ikaika, a me ka lima ikaika hoi oia e kipaku aku ai ia lakou, mai kona aina aku.   
\b  
\q1
\v 2 Olelo mai la ke Akua ia Mose, i mai la ia ia, Owau no o Iehova.   
\q1
\v 3 Hoike aku wau ia'u iho ia Aberahama, ia Isaaka, a ia Iakoba, o ke Akua Mana; aka, ma ko'u inoa, o IEHOVA, aole au i ikeia mai e lakou.   
\q1
\v 4 Ua hoopaa no hoi au i kuu berita me lakou, e haawi aku ai no lakou i ka aina o Kanaana, i ka aina i noho ai lakou, he mau malihini ilaila.   
\q1
\v 5 Ua lohe hoi au i ka uu ana o na mamo a Iseraela, o ka poe i hooluhiia'i e ko Aigupita; a ua hoomanao wau i kuu berita.   
\q1
\v 6 No ia mea, e olelo aku oe i na mamo a Iseraela, Owau no Iehova, a e lawe mai ana no wau ia oukou mailalo mai o na mea kaumaha a ko Aigupita, a e hoopakele no wau ia oukou i ko lakou hooluhi ana; a e hoola wau ia oukou me ka lima kakauha, a me na hoopai ana he nui loa.   
\q1
\v 7 A e hoonoho no wau ia oukou i poe kanaka no'u, a owau auanei hoi ko oukou Akua: a e ike auanei hoi oukou, owau no Iehova, o ko oukou Akua, nana oukou e lawe ae, mailalo ae o na mea kaumaha a ko Aigupita.   
\q1
\v 8 A e lawe aku no au ia oukou i ka aina a'u i pai ai i ko'u lima, e haawi aku ia wahi no Aberahama, no Isaaka a no Iakoba, oia ka'u e haawi aku ai no oukou i wahi e noho ai: owau no Iehova.   
\b  
\q1
\v 9 Pela no hoi o Mose i olelo aku ai i na mamo a Iseraela: aole nae lakou i hoolohe i ka Mose, no ka ehaeha o ka naau, a no ka luhi koikoi.   
\b  
\q1
\v 10 Olelo mai la o Iehova ia Mose, i mai la,   
\q1
\v 11 E hele oe, e olelo aku ia Parao i ke alii o Aigupita, e hookuu aku oia i na mamo a Iseraela mai kona aina aku.   
\q1
\v 12 Olelo aku o Mose imua o Iehova, i aku la, Aia hoi, aole i hoolohe mai na mamo a Iseraela ia'u, pehea la hoi e hoolohe mai ai o Parao ia'u, i ka mea lehelehe hemahema?   
\q1
\v 13 Olelo mai la o Iehova ia Mose a ia Aarona, a hoouna ia laua i na mamo a Iseraela, a ia Parao, no ka lawe ana mai i na mamo a Iseraela mai ka aina mai o Aigupita.   
\b  
\q1
\v 14 Eia hoi na mea mua o ko lakou mau ohana kupuna: O na keiki a Reubena, a ka hiapo a Iseraela; o Hanoka, o Palu, o Hezerona, a o Karemi: o lakou na ohana a Reubena.   
\q1
\v 15 A o na keiki a Simeona; o Iemuela, a o Iamina, o Ohada, o Iakina, o Zohara, a o Saula ke keiki a kekahi wahine Kanaana: o lakou na ohana a Simeona.   
\b  
\q1
\v 16 Eia hoi na inoa o na keiki a Levi, ma ko lakou mau hanauna: o Geresona, o Kohata, a o Merari: a o na makahiki o ko Levi ola ana, hookahi haneri me kanakolukumamahiku na makahiki.   
\q1
\v 17 O na keiki a Geresona, o Libeni, a o Simi, ma ka laua mau ohana.   
\q1
\v 18 A o na keiki a Kohata; o Amerama, o Izehara, o Heberona, a me Uziela: a o na makahiki o ko Kohata ola ana, hookahi haneri me kanakolukumamakolu na makahiki.   
\q1
\v 19 A o na keiki a Merari; o Mahali a o Musi: o lakou nei na ohana a Levi, ma na hanauna o lakou.   
\q1
\v 20 Lawe iho la o Amerama ia Iokebeda, i ke kaikuwahine o kona makuakane, i wahine nana; a hanau mai la nana o Aarona laua o Mose: a o na makahiki o ko Amerama ola ana, hookahi haneri me kanakolukumamahiku na makahiki.   
\b  
\q1
\v 21 A o na keiki a Izehara, o Kora, o Nepega, a me Zikeri.   
\q1
\v 22 A o na keiki a Uziela; o Misaela, o Elezapana, a me Ziteri.   
\q1
\v 23 Lawe ae la o Aarona ia Eliseba, i ke kaikamahine a Aminadaba, o ke kaikuwahine o Nahesona i wahine nana, a hanau mai la nana, o Nadaba, o Abihu, o Eleazara a me Itamara.   
\q1
\v 24 A o na keiki a Kora; o Asira, o Elekana, a o Abiasapa; o lakou na ohana a Kora.   
\q1
\v 25 Lawe ae la o Eleazara ke keiki a Aarona i kekahi kaikamahine a Putiela i wahine nana: a ua hanau mai nana o Pinehasa; o lakou na mea mua o na makua o ka Levi, ma ka lakou mau ohana.   
\q1
\v 26 Oia o ua Aarona la laua o ua Mose la, na mea a Iehova i olelo mai ai, E lawe mai olua i na mamo a Iseraela mai Aigupita mai, ma ko lakou poe kaua.   
\q1
\v 27 O laua no na mea i olelo ia Parao i ke alii o Aigupita, no ka lawe ana mai i na mamo a Iseraela, mai Aigupita mai: o ua Mose la no keia laua o Aarona.   
\b  
\q1
\v 28 A i ka la a Iehova i olelo mai ai ia Mose ma ka aina o Aigupita,   
\q1
\v 29 Olelo mai la o Iehova ia Mose, i mai la, Owau no Iehova: e hai aku oe ia Parao i ke alii o Aigupita, i na mea a pau a'u e olelo aku ai ia oe.   
\q1
\v 30 Olelo aku o Mose imua o Iehova, Aia hoi, he lehelehe hemahema ko'u, pehea la e hoolohe mai ai o Parao ia'u?   
\c 7  
\b  
\q1
\v 1 I MAI la o Iehova ia Mose, e nana hoi, ua hoonoho wau ia oe i akua no Parao, a o Aarona kou kaikuaana, oia no auanei kou kaula.   
\q1
\v 2 O na mea a pau a'u e kauoha aku ai ia oe, oia kau e hai aku ai: a o Aarona kou kaikuaana ke olelo aku ia Parao, e hoouna aku ia i na mamo a Iseraela mai kona aina aku.   
\q1
\v 3 A e hoopaakiki auanei au i ka naau o Parao, a e hana no au i ko'u mau ouli a nui, a me ko'u mau mea mana ma ka aina o Aigupita.   
\q1
\v 4 Aole nae e hoolohe mai o Parao ia olua, i kau aku ai au i ko'u lima maluna o Aigupita, a e lawe mai iwaho i ko'u poe kaua i ka poe kanaka o'u, i na mamo a Iseraela, mai ka aina o Aigupita mai, me ka hoopai nui aku.   
\q1
\v 5 A e ike auanei ko Aigupita, owau no Iehova, ia'u e hookakauha aku ai i ko'u lima maluna o Aigupita, a e lawe mai i na mamo a Iseraela maiwaena mai o lakou.   
\q1
\v 6 Hana iho la o Mose laua o Aarona, e like me ka Iehova i kauoha mai ai ia laua; pela laua i hana aku ai.   
\q1
\v 7 He kanawalu na makahiki o Mose, a he kanawalu na makahiki o Aarona a me kumamakolu, i ka wa a laua i olelo aku ai ia Parao.   
\b  
\q1
\v 8 Olelo mai la o Iehova ia Mose a me Aarona, i mai la,   
\q1
\v 9 I ka wa e olelo mai ai o Parao ia olua, i ka i ana mai, E hoike mai olua i kekahi hana mana; alaila e olelo ae oe ia Aarona, E lalau i kou kookoo, a e kiola iho imua o Parao, a e lilo ia i nahesa:   
\b  
\q1
\v 10 Hele aku la o Mose laua o Aarona io Parao la, hana iho la laua e like me ke kauoha ana a Iehova, a kiola iho la o Aarona i kona kookoo imua o Parao, a imua o kana poe kauwa, a lilo iho la ia i nahesa.   
\q1
\v 11 Kii aku la hoi o Parao i na kanaka akamai, a me na kilo; a o na magoi o Aigupita, hana iho la hoi lakou pela, i ko lakou kilokilo ana.   
\q1
\v 12 No ka mea, kiola iho la kela kanaka keia kanaka a pau i kona kookoo iho, i lilo lakou i mau nahesa: aka, o ke kookoo o Aarona, moni iho la ia i ko lakou mau kookoo.   
\q1
\v 13 A hoopaakikiia mai la ka naau o Parao, i hoolohe ole ai oia ia laua, e like me ka mea a Iehova i olelo mai ai.   
\b  
\q1
\v 14 I mai la o Iehova ia Mose, Ua hoopaakikiia ko Parao naau, i ole ai ia e hookuu mai i ka poe kanaka.   
\q1
\v 15 A kakahiaka ae, e hele oe io Parao la, aia e hele ana no ia i ka wai; e ku oe ma ke kapa o ka muliwai e halawai me ia: a e lawe oe ma kou lima i ke kookoo i lilo ai i nahesa.   
\q1
\v 16 A e olelo aku oe ia ia, Ua hoouna mai nei ke Akua o ka poe Hebera ia'u ion nei, ua i mai, E hookuu mai oe i ko'u poe kanaka, i hookauwa mai lakou na'u ma ka waonahele: aia hoi, aole oe i manao e hoolohe mamua.   
\q1
\v 17 Ke olelo mai nei o Iehova penei, Ma keia mea e ike auanei oe, owau no Iehova: aia hoi, e hahau no wau i keia kookoo ma kuu lima, maluna o ka wai maloko o ka muliwai, a e lilo ia i koko.   
\q1
\v 18 A e make no ka ia maloko o ka muliwai, a e hoopailua ko Aigupita ke inu i ka wai o ka muliwai.   
\b  
\q1
\v 19 I mai la o Iehova ia Mose, E olelo aku oe ia Aarona, E lalau oe i kou kookoo, a e o aku kou lima maluna o na wai o Aigupita, ma na kahawai, a ma na muliwai, a ma na loko, a ma na huinawai a pau o lakou, i lilo ai lakou i koko: i hiki mai ke koko ma na aina a pau o Aigupita nei, maloko o ka laau, a maloko o ka pohaku.   
\b  
\q1
\v 20 A hana iho la o Mose laua o Aarona e like me ka mea a Iehova i olelo mai ai. Hapai ae la ia i ke kookoo a hahau iho la i ka wai maloko o ka muliwai, imua i ke alo o Parao, a imua i ke alo o kana poe kauwa: a lilo ae la ka wai a pau o ka muliwai i koko.   
\q1
\v 21 A make iho la ka ia maloko o ka muliwai; pilau mai la ka muliwai; aole i hiki i ko Aigupita ke inu i ka wai o ua muliwai la: a he koko no ma ka aina o Aigupita a pau.   
\q1
\v 22 Hana iho la no pela na magoi o Aigupita i ko lakou mea e kilokilo ai; a ua hoopaakikiia ka naau o Parao, aole hoi ia i hoolohe mai ia laua, e like no me ka mea a Iehova i olelo mai ai.   
\q1
\v 23 Huli ae la o Parao, a hoi aku la i kona hale; aole hoi ia i kau aku i kona manao ma ia mea.   
\q1
\v 24 Kohi iho la ko Aigupita a pau i na wahi e kokoke ana i ka muliwai, i loaa'i ka wai e inu: no ka mea, aole i hiki ia lakou ke inu i ka wai o ka muliwai.   
\q1
\v 25 A ua hala ae la na la ehiku mai ka wa mai o ko Iehova hahau ana i ka muliwai.   
\c 8  
\b  
\q1
\v 1 ALAILA, i mai la o Iehova ia Mose, O hele oe io Parao la, a e i aku ia ia, Ke i mai nei o Iehova penei, E hookuu mai oe i ko'u poe Kanaka, i hookauwa mai lakou na'u.   
\q1
\v 2 A ina paha e hookuu ole mai oe, aia hoi, e hoino no wau i kou mau mokuna a pau i na rana;   
\q1
\v 3 A e hoopuka nui mai ka muliwai i na rana, a e hele mai lakou iloko o kou hale, a me kou keena moe, a maluna o kou hikiee, a iloko o ka hale o kau poe kauwa, a maluna o kou poe kanaka, a maloko o kou mau imu, a maloko hoi o kou mau pa wili ai.   
\q1
\v 4 A e hele mai auanei na rana maluna ou, a maluna o kou poe kanaka, a maluna o kau poe kauwa a pau.   
\b  
\q1
\v 5 I mai la o Iehova ia Mose, E i aku oe ia Aarona, E o aku kou lima me kou kookoo maluna o na kahawai, a me na muliwai, a me na loko, i hiki mai na rana maluna o ka aina o Aigupita.   
\q1
\v 6 O aku la no ko Aarona lima maluna o ka wai o Aigupita, a hiki mai la na rana, a hoouhi paapu ae la i ka aina o Aigupita.   
\q1
\v 7 Hana iho la no pela na magoi i ka lakou mea e kilokilo ai, i hoohiki mai ai i na rana ma ka aina o Aigupita.   
\b  
\q1
\v 8 Alaila, hea mai la o Parao ia Mose a me Aarona, i mai la, E pule aku olua ia Iehova, i lawe aku ia i na rana mai o'u aku nei, a mai ko'u poe kanaka aku, a e hookuu no wau i na kanaka, i kaumaha ai lakou na Iehova.   
\q1
\v 9 I aku la o Mose ia Parao, E kauoha pono mai oe ia'u, i ka manawa hea ka'u e pule aku ai nou, a no kau poe kauwa hoi, a no kou poe kanaka, i laweia aku na rana mai ou aku la, a mai kou kauhale aku, a koe ma ka muliwai wale no?   
\b  
\q1
\v 10 Olelo mai la kela, Apopo. I aku la ia, E like me kau olelo, pela no auanei ia, i ike pono ai oe, aohe mea e ae e like me Iehova ko makou Akua.   
\q1
\v 11 A e haalele mai no na rana ia oe, a me kou hale, a me kau poe kauwa, a me kou poe kanaka, a e koe ma ka muliwai wale no.   
\b  
\q1
\v 12 Hele aku la o Mose laua o Aarona mai o Parao aku la: uwe aku la o Mose ia Iehova no na rana ana i lawe mai ai maluna o Parao.   
\q1
\v 13 Hana iho la o Iehova e like me ka Mose olelo ana, a make iho la na rana ma na hale, a ma na pahale a ma na kula.   
\q1
\v 14 Hoiliili ae la lakou i na rana ma na puu: a pilau iho la ka aina.   
\q1
\v 15 A ike iho la o Parao, he maha, hoopaakiki iho la ia i kona naau, aole i hoolohe mai i ka laua; e like me ka Iehova i olelo mai ai.   
\b  
\q1
\v 16 Olelo mai la o Iehova ia Mose, E i aku oe ia Aarona, e o aku oe i kou kookoo, a e hahau i ka lepo o ka aina, i lilo ia i makika ma ka aina a pau o Aigupita.   
\q1
\v 17 Hana iho la laua pela; o aku la no ko Aarona lima me kona kookoo, hahau iho la i ka lepo o ka aina, a lilo ae la ia i makika ma na kanaka, a ma na holoholona; lilo no na hunalepo a pau o ka aina i makika ma ka aina a pau o Aigupita.   
\q1
\v 18 Hana iho la no pela na magoi, me ko lakou mea kilokilo, i hiki mai ai ka makika, aole nae i hiki ia lakou. He makika no nae maluna o na kanaka, a maluna o na holoholona.   
\q1
\v 19 Alaila olelo ae la na magoi ia Parao, Eia no ka lima o ke Akua. Ua hoopaakikiia no nae ko Parao naau; aole ia i hoolohe i ka laua, e like me ka Iehova i olelo mai ai.   
\b  
\q1
\v 20 Olelo mai la o Iehova ia Mose, A kakahiaka nui, e ala ae oe, a e ku imua i ke alo o Parao, aia hoi, e hele mai no ia iwaho i ka wai, a e i aku oe ia ia, Ke olelo mai nei o Iehova penei, E hookuu oe i ko'u poe kanaka, i hookauwa mai lakou na'u.   
\b  
\q1
\v 21 Aka hoi, ina aole oe e hookuu mai i ko'u poe kanaka, aia hoi, e hoouna aku no au i na nalonahu maluna ou, a maluna o kau poe kauwa, a maluna o kou poe kanaka, a maloko o kou mau hale; a e piha na hale o ko Aigupita i na nalonahu, a me ka aina hoi kahi a lakou e noho ai.   
\q1
\v 22 Ia la hoi, e hookaawale auanei au i ka aina o Gosena, i kahi e noho nei ko'u poe kanaka, i hiki ole ai ka nalonahu ilaila; i mea e ike ai oe, owau no Iehova mawaena o ka honua.   
\q1
\v 23 A e kaa no au i pale mawaena o ko'u poe kanaka a me kou poe kanaka. Apopo e hiki mai keia mea.   
\q1
\v 24 Hana iho la no o Iehova pela: a hiki mai la na nalonahu he nui loa maloko o ka hale o Parao, a me na hale o kana poe kauwa, a ma ka aina a pau o Aigupita: ua oki loa ka aina i na nalonahu.   
\b  
\q1
\v 25 Hea mai la o Parao ia Mose a me Aarona, i mai la, E hele oukou, a e kaumaha aku i ko oukou Akua maloko o ka aina nei.   
\q1
\v 26 I aku la o Mose, Aole pono ke hana pela; no ka mea, e kaumaha auanei makou na Iehova ko makou Akua i ka mea hoopailua a ko Aigupita nei: a ina e kaumaha aku makou i ka mea hoopailua a ko Aigupita nei imua o ko lakou maka, aole anei lakou e hailuku mai ia makou i ka pohaku?   
\q1
\v 27 E hele no makou i ekolu la hele iloko o ka waonahele, a e kaumaha aku na Iehova ko makou Akua, e like me kana e kauoha mai ai ia makou.   
\q1
\v 28 I mai la o Parao, E hookuu aku no wau ia oukou, i kaumaha aku ai oukou na Iehova ko oukou Akua, ma ka waonahele: aka, mai hele aku oukou i kahi mamao. E pule aku olua no'u.   
\q1
\v 29 I aku la o Mose, Aia hoi, ke hele aku nei au mai ou aku nei, a e nonoi aku au ia Iehova e lawe aku ia i na nalonahu mai o Parao aku, a mai kana poe kauwa aku, a mai kona poe kanaka aku; aia apopo. Aka, mai hoopunipuni hou mai o Parao. i ka hookuu ole i na kanaka e kaumaha aku na Iehova.   
\q1
\v 30 Hele aku la o Mose mai o Parao aku, a nonoi aku la ia Iehova.   
\q1
\v 31 Hana mai la o Iehova e like me ka olelo a Mose, a lawe aku la ia i na nalonahu mai o Parao aku, a mai kana poe kauwa aku, a mai kona poe kanaka aku; aole hookahi i koe.   
\q1
\v 32 Hoopaakiki hou iho la o Parao i kona naau ia manawa no hoi, aole i hookuu aku i na kanaka.   
\c 9  
\b  
\q1
\v 1 OLELO mai la o Iehova ia Mose, E hele oe io Parao la, a e i aku ia ia, ke olelo mai nei o Iehova ke Akua o na Hebera penei, E hookuu mai oe i ko'u poe kanaka, i hookauwa mai ai lakou na'u.   
\q1
\v 2 No ka mea, ina aole oe e hookuu mai, a e hoopaa loa ia lakou,   
\q1
\v 3 Aia hoi, e kau ana no o Iehova i kona lima maluna o kau poe holoholona ma ke kula, maluna o na lio, a maluna o na hoki, a maluna o na kamelo, a maluna o na bipi, a maluna o na hipa: he ahulau nui loa.   
\q1
\v 4 A e hookaawale o Iehova mawaena o na holoholona a ka Iseraela, a me na holoholona a ko Aigupita. Aole no e make kekahi mea a ka poe mamo a Iseraela.   
\q1
\v 5 Haawi mai la o Iehova i wa maopopo, i mai la, Apopo e hana mai ai o Iehova i keia mea ma ka aina.   
\q1
\v 6 A ia la iho no, hana mai la o Iehova i ua mea la, a make iho la na holoholona a pau o Aigupita: aka, o na holoholona a na mamo a Iseraela, aole kekahi i make.   
\q1
\v 7 Hoouna aku la o Parao, aia hoi, aole i make kekahi o ka Iseraela poe holoholona. A na hoopaakikiia ka naau o Parao, aole ia i hookuu aku i na kanaka.   
\b  
\q1
\v 8 Olelo mai la o Iehova ia Mose a me Aarona, E lalau olua a piha ko olua mau poho lima i ka lehu o ke kapuahi, a na Mose e lu aku ia mea ma ka lani imua o na maka o Parao.   
\q1
\v 9 A e lilo no ia i lepo makalii ma ka aina a pau o Aigupita, a e lilo ia i puupuu e poha ana i na maihehe, maluna o na Kanaka, a maluna o na holoholona, ma ka aina a pau o Aigupita.   
\q1
\v 10 Lalau ae la laua i lehu o ke kapuahi, a ku iho la imua o Parao; a lu ae la o Mose iluna i ka lani, a lilo ae la ia mea i puupuu e poha ana i na maihehe maluna o kanaka, a maluna o na holoholona.   
\q1
\v 11 Aole i hiki i na Magoi ke ku imua o Mose, no na maihehe, no ka mea, maluna no o ka poe Magoi ua maihehe la, a maluna no o ko Aigupita a pau.   
\q1
\v 12 Hoopaakiki mai la o Iehova i ka naau o Parao, a hoolohe ole mai la oia ia laua, e like me ka Iehova i olelo mai ai ia Mose.   
\b  
\q1
\v 13 I mai la o Iehova ia Mose, E ala ae oe i kakahiaka nui, a e ku imua o Parao, a e olelo aku ia ia, Ke i mai nei o Iehova ke Akua o ka poe Hebera penei, E hookuu mai i ko'u poe kanaka i hookauwa mai lakou na'u.   
\q1
\v 14 No ka mea, ma keia hope aku, e hoouna aku no wau i ko'u mau mea hoino a pau maluna o kou naau, a maluna o kau poe kauwa, a maluna o kou poe kanaka, i ike pono ai oe, ohe mea e ae e like me au ma ka honua a pau.   
\q1
\v 15 No ka mea, ano e o aku ana ko'u lima, i hahau aku ai au ia oe, a me kou poe kanaka i ke ahulau, a e hookiia'e oe mai ka honua aku.   
\q1
\v 16 Aka, no keia mea, i hooku ae au ia oe, i mea e holke aku ai au i ko'u mana ma ou la, a i kaulana aku ai ko'u inoa ma ka honua a pau.   
\q1
\v 17 Ke hookiekie nei anei oe ia oe iho a hiki i keia wa, e ku e i ko'u poe kanaka, i ole ai e hookuu aku ia lakou?   
\q1
\v 18 Aia hoi, a hiki i keia hora o ka la apopo, alaila e hooua iho no au i ka huahekili he nui loa, aole lua e like me ia ma Aigupita nei, mai kona wa i hookumuia'i a hiki i keia manawa.   
\q1
\v 19 Nolaila la, e hoouna aku oe e hoakoakoa ae i kau poe holoholona a me kau mau mea a pau ma ke kula: o na kanaka a me na holoholona a pau e koe ma ke kula, aole e hoihoiia maloko o ka hale, e haule mai no ka huahekili maluna iho o lakou, a e make lakou.   
\q1
\v 20 A o ka mea iwaena o na kauwa a Parao i makau i ka olelo a Iehova, hoakoakoa iho la ia i kana poe kauwa, a me kana poe holoholona iloko o na hale.   
\q1
\v 21 A o ka mea huli ole i kona naau ma ka olelo a Iehova, waiho iho la ia i kana poe kauwa a me kana poe holoholona ma ke kula.   
\b  
\q1
\v 22 I mai la o Iehova ia Mose, E o aku i kou lima ma ka lani, i hiki mai ai ka huahekili ma ka aina a pau o Aigupita, maluna o na kanaka, a maluna o na holoholona, a maluna o na mea uliuli a pau o ke kula, a puni ka aina o Aigupita.   
\q1
\v 23 O aku la o Mose i kona kookoo ma ka lani; a hoouka mai la o Iehova i ke hekili a me ka huahekili, a naholo mai la ka uila maluna o ka honua; a hooua mai la o Iehova i ka huahekili maluna o ka aina o Aigupita.   
\q1
\v 24 He huahekili no, a ua hui pu ka uila me ka huahekili, he nui loa, aohe mea e like ai ma ka aina a pau o Aigupita, mai ka manawa i lilo ai ia i aupuni.   
\q1
\v 25 Paopao mai la ka huahekili ma ka aina a pau o Aigupita, i na mea a pau ma ke kula, i na kanaka a me na holoholona: paopao mai la ka huahekili i na mea uliuli a pau o ke kula, a weluwelu iho la na laau a pau ma ke kula.   
\q1
\v 26 O ka aina i Gosena wale no, o kahi i noho ai na mamo a Iseraela, aohe huahekili ilaila.   
\b  
\q1
\v 27 Hoouna mai la o Parao, hea mai la ia Mose a me Aarona, i mai la ia laua, Ua hewa no wau i keia manawa; ua hemolele o Iehova, aka, owau a me ko'u poe kanaka, ua hewa makou.   
\q1
\v 28 E nonoi aku olua ia Iehova, U'oki; i ole ai e kui hou ke hekili o ke Akua, a i pau hoi ka huahekili: a e hookuu aku no wau ia oukou, aole oukou e kali hou aku.   
\q1
\v 29 I aku la o Mose ia ia, I ko'u puka ana aku mawaho o ke kulanakauhale, e kikoo aku no wau i ko'u mau lima ia Iehova; a e pau no ke hekili, aole hoi e huahekili hou, i ike ai oe, no Iehova ka honua.   
\q1
\v 30 Aka o oe, a me kau poe kauwa, ua ike no au, aole no oukou e makau i keia manawa ia Iehova ke Akua.   
\q1
\v 31 A make iho la ke olona, a me ka palaoa huluhulu, no ka mea, ua pua ae la ka palaoa huluhulu, a ua pua ke olona.   
\q1
\v 32 Aka, o ka palaoa, a me ka palaoa eleele, aole i make, no ka mea, ua opiopio.   
\q1
\v 33 Hele aku la o Mose mawaho o ke kulanakauhale, mai o Parao aku, a kikoo aku la i kona mau lima imua o Iehova; a ua pau iho la ke hekili a me ka huahekili, aole i ninini hou ia mai ka ua maluna o ka honua.   
\q1
\v 34 A ike iho la o Parao, ua pau ka ua, a me ke hekili, hewa hou iho la no ia, a hoopaakiki iho la i kona naau, oia a me kana poe kauwa.   
\q1
\v 35 Ua hoopaakikiia ka naau o Parao, aole hoi ia i hookuu aku i na mamo a Iseraela, e like me ka Iehova i olelo mai ai ma o Mose la.   
\c 10  
\b  
\q1
\v 1 OLELO mai la o Iehova ia Mose, E hele aku oe iloko io Parao la, no ke mea, ua hoopaakiki au i kona naau, a me ka naau o kana poe kauwa, i hoike aku ai au i keia mau hoailona o'u iwaena o lakou;   
\q1
\v 2 A i hai aku ai oe maloko o na pepeiao o kau keiki, a o ke keiki a kau keiki i na mea a'u i hana'i ma Aigupita, a me ko'u mau hoailona a'u i hana aku ai ia lakou, i ike ai oukou, owau no Iehova.   
\q1
\v 3 Hele aku la o Mose laua o Aarona iloko io Parao la, i aku la ia ia, Ke i mai nei o Iehova, ke Akua o na Hebera, penei, Pehea la ka loihi o kou hoohaahaa ole ana ia oe iho imua o'u? E hookuu mai oe i ko'u poe kanaka, i hookauwa mai lakou na'u.   
\q1
\v 4 Aka, ina e hoole oe, aole e hookuu mai i ko'u poe kanaka, aia hoi, i ka la apopo, e halihali mai no wau i na uhini ma kou aina.   
\q1
\v 5 A e uhi mai auanei lakou maluna o ka aina, aole e ikea ka aina ke nana aku: a e ai iho no lakou i ke koena o na mea i waihoia na oukou e ka huahekili: a e ai iho hoi lakou i na laau a pau e ulu ana no oukou ma ke kula.   
\q1
\v 6 E hoopiha hoi lakou i na hale ou, a me na hale o kau poe kauwa a pau, a me na hale o ko Aigupita a pau: aole i ike kou poe makua i keia mea, aole hoi na makua o kou poe makua, mai ka wa i noho mai ai lakou ma ka honua, a hiki i keia la, Haliu ae la ia, a hele aku la mai o Parao aku.   
\b  
\q1
\v 7 Olelo aku la na kauwa a Parao ia ia, Pehea la ka loihi o ka hoohihia ana o keia kanaka ia kakou? E hookuu aku i ua poe kanaka la, i hookauwa aku ai lakou na Iehova na ko lakou Akua. Aole anei oe i ike i neia manawa, ua oki loa o Aigupita nei?   
\q1
\v 8 Ua lawe hou ia aku o Mose laua o Aarona io Parao la, i mai la ia ia laua, E hele oukou, e hookauwa na Iehova na ko oukou Akua. Owai, owai hoi ka poe hele?   
\q1
\v 9 I aku la o Mose, E hele pu no makou me ko makou poe opiopio a me ko makou poe elemakule, me na keikikane a me na kaikamahine a makou, me ka makou hipa, a me ka makou bipi makou e hele aku ai: no ka mea, he ahaaina ka makou no Iehova.   
\q1
\v 10 I mai la kela ia laua, o Iehova kekahi pu me oukou, ke hookuu aku au ia oukou, e hele me ka oukou poe keiki. E malama ia olua, no ka mea, aia no ka hewa ma ko olua alo.   
\q1
\v 11 Aole pela: o oukou na kanaka ke hele, e hookauwa aku na Iehova; no ka mea, oia ka oukou mea i imi mai nei. A ua kipakuia mai laua, mai ke alo mai o Parao.   
\b  
\q1
\v 12 I mai la o Iehova ia Mose, E o aku kou lima, maluna o ka aina o Aigupita no na uhini, i hele mai ai lakou maluna o ka aina o Aigupita, a e ai iho i na laauikiai a pau o ka aina, i na mea a pau i waihoia e ka huahekili.   
\q1
\v 13 O aku la o Mose i kona kookoo maluna o ka aina o Aigupita, a huai mai la o Iehova i ka makani mai ka hikina mai maluna o ka aina, ia la a po, ia po a ao; a i kakahiaka, hoopuka mai la ua makani hikina la i na uhini.   
\q1
\v 14 Lele ae la na uhini maluna o ka aina a pau o Aigupita, a kau iho la ma na mokuna a pau o Aigupita: he ino loa; aohe uhini mamua e like ai, aole hoi e hiki mai ana mahope o lakou na mea e like ai.   
\q1
\v 15 No ka mea, uhi paapu iho la lakou i ka aina a pau, a poeleele hoi ka aina; ai iho la lakou i na laauikiai a pau o ka aina, a me ka hua a pau o na laau, a ka huahekili i waino mai ai; aole i koe kekahi mea uliuli ma na laau, a ma na laauikiai o ke kula, ma ka aina a pau o Aigupita.   
\b  
\q1
\v 16 Alaila, wikiwiki ae la o Parao e hea mai ia Mose laua o Aarona, i mai la, Ua hana hewa wau ia Iehova i ko oukou Akua, a ia olua no hoi.   
\q1
\v 17 Ke noi aku nei au, e kala mai no hoi olua i keia hewa hookahi ana no, a e nonoi aku ia Iehova ike oukou Akua, i lawe aku ai ia i keia make wale no, mai o'u aku nei.   
\q1
\v 18 Hele aku la ia mai o Parao aku, a nonoi aku la ia Iehova.   
\q1
\v 19 Huai hou mai la o Iehova i makani komohana ikaika, a lawe aku la ia i na uhini, a hoopaa iho la ia lakou iloko o ke Kaiula. Aohe uhini hookahi i koe ma ka aina a pau i Aigupita.   
\q1
\v 20 Aka, hoopaakiki iho la o Iehova i ko Parao naau, aole ia hookuu aku i na mamo a Iseraela.   
\b  
\q1
\v 21 I mai la o Iehova ia Mose, E o aku kou lima i ka lani, i kau mai ka poeleele maluna o ka aina o Aigupita, i aaki ka pouli.   
\q1
\v 22 O aku la no ko Mose lima i ka lani, a pouli loa iho la ka aina a pau o Aigupita i na la ekolu.   
\q1
\v 23 Aole loa lakou i ike i kekahi i kekahi, aole hoi i ala ae kekahi mai kona wahi ae, i na la ekolu; aka, o na mamo a pau a Iseraela, he malamalama ko lakou iloko o ko lakou mau hale.   
\b  
\q1
\v 24 Hea mai la o Parao ia Mose, i mai la, Ou haele oukou, e hookauwa aku na Iehova; aka, o ka oukou hipa, a me ka oukou bipi, e waiho ia lakou: e hele pu no hoi ka oukou poe keiki.   
\q1
\v 25 I aku la o Mose, E haawi mai hoi iloko o ko makou mau lima, i na mohai, a me na mohai kuni, i kanmaha aku ai makou na Iehova na ko makou Akua.   
\q1
\v 26 E hele pu no hoi ka makou holoholona, aole e waihoia kekahi maanei; no ka mea, e lawe ana makou i na mea o lakou e malama'i ia Iehova i ko makou Akua: aole nae makou e ike i na mea o lakou ka makou e malama ai ia Iehova, a hiki aku makou ilaila.   
\b  
\q1
\v 27 Aka, hoopaakiki mai la o Iehova i ka naau o Parao, aole no ia i hookuu ia lakou.   
\q1
\v 28 I mai la o Parao ia ia, E hele aku oe pela, mai o'u aku nei, e malama ia oe iho, aole e ike hou mai i ko'u maka, no ka mea, i ka la au e nana hou mai ai i ko'u maka, e make oe.   
\q1
\v 29 I aku la o Mose ia ia, Ua olelo pono mai oe; aole au e ike hou aku i kou maka.   
\c 11  
\b  
\q1
\v 1 I MAI la o Iehova ia Mose, E hoouka mai ana au i hookahi hoino hou maluna o Parao, a maluna o Aigupita, a mahope iho, e hookuu mai no ia ia oukou: a i ka la ana e hookuu mai ai ia oukou, alaila e kipaku loa oia ia oukou.   
\q1
\v 2 E olelo aku oe iloko o na pepeiao o kanaka, e nonoi aku kela kanaka keia kanaka a pau i kona hoalauna, a o kela wahine keia wahine i kona hoalauna, i na mea kala a me na mea gula.   
\q1
\v 3 Haawi mai la o Iehova i ka lokomaikai i na kanaka imua o ka maka o ko Aigupita. He kanaka nui no hoi o Mose ma ka aina o Aigupita imua o ka maka o na kauwa a Parao, imua hoi o na maka o kanaka.   
\b  
\q1
\v 4 Olelo aku la o Mose, Penei ka Iehova i i mai nei, A hiki i ke aumoe, e hele aku no au iwaena konu o Aigupita nei.   
\q1
\v 5 A e make auanei na hiapo a pau o ka aina o Aigupita nei, mai ka hiapo mai a Parao, ka mea noho ma kona nohoalii, a hiki i ka hiapo a ke kauwawahine e noho ana ma ka mea wili palaoa; a me na hiapo a pau a na holoholona.   
\q1
\v 6 A e nui loa auanei ka uwe ana ma ka aina a pau i Aigupita nei; aohe mea e like me ia mamua, aole hoi he mea e like ana mahope.   
\q1
\v 7 Aka, aole loa e hookala mai kekahi ilio i kona alelo e ku e i kekahi o na mamo a Iseraela; aole i ke kanaka, aole i na holoholona; i ike ai oukou i ka Iehova pale ana mawaena o ko Aigupita a me ka Iseraela.   
\q1
\v 8 A o keia poe kauwa au, e hele mai no lakou io'u nei, a e kulou ilalo imua o'u, a e i mai, E hele aku oe, a me na kanaka a pau mamuli ou. A mahope iho e puka aku no wau. Hele ae la ia mai o Parao mai me ka wela o kona huhu.   
\b  
\q1
\v 9 Olelo mai la o Iehova ia Mose, Aole e hoolohe mai o Parao ia olua, i mea e nui ai ko'u mau ouli ma ka aina o Aigupita.   
\q1
\v 10 Hana iho la o Mose laua o Aarona i keia mau ouli a pau imua i ke alo o Parao; a hoopaakiki mai la o Iehova i ka naau o Parao, aole ia i hookuu mai i na mamo a Iseraela mai kona aina mai.   
\c 12  
\b  
\q1
\v 1 OLELO mai la o Iehova ia Mose laua o Aarona, ma ka aina o Aigupita, i mai la,   
\q1
\v 2 Eia ka malama makamua o ko oukou mau malama, eia ka malama mua o ko oukou makahiki.   
\b  
\q1
\v 3 E olelo aku olua i ka poe kanaka o ka Iseraela a pau, e i aku, I ka la umi o keia malama, e lawe kela kanaka keia kanaka i hipakeiki ma ko ka hale o na makua, he hipakeiki no ka hale hookahi.   
\q1
\v 4 Aka, ina he uuku ko ka hale, aole lawa no ka hipakeiki, e lawe pu ia me kona hoalauna e kokoke aua ma kona hale, e like me ka nui o lakou; e like me ka ai ana a kela kanaka keia kanaka, pela no oukou e helu ai i na hipakeiki.   
\q1
\v 5 I hipakeiki kina ole ka oukou, he kane o ka makahiki hookahi: noloko o ka poe hipa paha, noloko o ka poe kao paha ka oukou e lawe ai ia ia.   
\q1
\v 6 Na oukou ia e malama a hiki i ka la umikumamaha o ia malama; a na ke anaina kanaka a pau o ka Iseraela e pepehi iho ia i ke ahiahi.   
\q1
\v 7 A e lawe lakou i ke koko, a e kau aku ma na lapauila a elua, a maluna ma ka hoaka o ka puka o na hale, kahi a lakou e ai ai ia mea.   
\q1
\v 8 A ia po no, e ai lakou i ka io i ohinuia i ke ahi, e ai pu lakou ia mea me ka palaoa hu ole, a me na mea mulemule.   
\q1
\v 9 Mai ai maka oukou ia mea, aole hoi i hoolapalapaia i ka wai; aka, e ohinuia i ke ahi; o kona poo, me kona mau wawae, a me kona naau.   
\q1
\v 10 Mai waiho oukou i kekahi a ao; a ina e koe kekahi mea a ao, e hoopau oukou ia mea i ke ahi.   
\b  
\q1
\v 11 Penei oukou e ai ai; e hoolikiia ko oukou puhaka, a me na kamaa e paa ana ma ko oukou mau wawae, a me ke kookoo ma ko oukou lima: e ai wikiwiki oukou, no ka mea, o ka moliaola ia na Iehova.   
\q1
\v 12 No ka mea, e hele aku ana au ma ka aina a pau o Aigupita i keia po, a e pepehi no wau i na hiapo a pau ma ka aina o Aigupita, o ka ke kanaka a me ka ka holoholona: a e hoopai aku no wau i na akua a pau o Aigupita: owau no Iehova.   
\q1
\v 13 A o ke koko, oia ka hoailona no oukou ma na hale o ko oukou wahi: aia ike aku au i ke koko, e waiho wau ia oukou, aole e kau mai ka mea ino maluna o oukou e make ai, ia'u e pepehi iho ai i ko ka aina o Aigupita.   
\q1
\v 14 A e lilo no keia la i mea e hoomanao ai no oukou: a e malama oukou ia la i ahaaina na Iehova, a hiki i ko oukou mau hanauna a pau: e malama oukou ia i ahaaina, ma ke kanawai mau loa.   
\b  
\q1
\v 15 Ehiku mau la ka oukou e ai ai i ka berena hu ole; i ka la mua e hoolei aku oukou i ka mea hu mawaho o ko oukou mau hale: o ka mea nana e ai i ka berena hu, mai ka la akahi a hiki i ka la hiku, e okiia'ku ia mai ka Iseraela aku.   
\q1
\v 16 A i ka la makamua, hookahi halawai hemolele ana, a i ka hiku o ka la, hookahi halawai hemolele ana o oukou. Ia mau la la, aohe hana maoli, o ka mea wale no a kela kanaka a keia kanaka e ai ai, oia wale no ka mea a oukou e hana'i.   
\q1
\v 17 E malama no oukou i ka ahaaina berena hu ole; no ka mea, ia la no ua lawe mai au i ko oukou poe koa, mai ka aina mai o Aigupita: no ia mea, e malama oukou i keia la i ka oukou mau hanauna aku, ma ke kanawai mau loa.   
\b  
\q1
\v 18 I ka malama makamua, i ka la umikumamaha o ka malama, i ke ahiahi, alaila e ai oukou i ka berena hu ole, a hiki i ke ahiahi o ka la iwakaluakumamakahi o ua malama la.   
\q1
\v 19 Ehiku la e loaa ole ai ka mea hu maloko o ko oukou mau hale. O ka mea ai i ka palaoa hu, oia ke hookiia aku mai ke anaina kanaka o ka Iseraela aku: ina paha ho kanaka e oia, a ina paha o ka mea i hanau ma ka aina.   
\q1
\v 20 Mai ai oukou i kekahi mea hu: ma na hale o oukou a pau, e ai oukou i ka berena hu ole.   
\b  
\q1
\v 21 Alaila, kii aku la o Mose i na lunakahiko a pau o ka Iseraela, i aku la ia lakou, E wae oukou, a e lawe i ka oukou hipakeiki, ma ka oukou mau ohana, a e pepehi i ka moliaola.   
\q1
\v 22 A e lawe oukou i pupu husopa, a e kupenu iho iloko o ke koko ma ko kiaha, a e hamo i ka hoaka a me na lapauila elua o ka puka, i ke koko oloko o ke kiaha, a mai puka aku kekahi o oukou mawaho o ka puka o kona hale, a kakahiaka.   
\q1
\v 23 No ka mea, e hele ae ana o Iehova e pepehi i ko Aigupita, a ike mai ia i ke koko ma ka hoaka a ma na lapauila, e waiho no o Iehova ia puka, aole ia e ae mai i ka mea luku e komo i ko oukou mau hale e pepehi mai.   
\q1
\v 24 E malama oukou i keia mea i kanawai mau loa no oukou, a no ka oukou poe keiki.   
\q1
\v 25 A hiki aku oukou i ka aina a Iehova e haawi mai ai no oukou, e like me kana i olelo mai ai, alaila e malama oukou i keia oihana.   
\q1
\v 26 A i ka wa e olelo mai ai ka oukou poe keiki ia oukou, Heaha ke ano o keia oihana ia oukou?   
\q1
\v 27 E olelo aku oukou, O ka mohai moliaola keia na Iehova, nana no i waiho i na hale o na mamo a Iseraela ma Aigupita, i ka wa ana i pepehi aku ai i ko Aigupita, a hoopakele mai i ko na hale o makou. Kulou iho la ke poo o kanaka a hoomana aku la.   
\q1
\v 28 Hele aku la na mamo a Iseraela, hana iho la e like me ka mea a Iehova i kauoha mai ai ia Mose laua o Aarona, pela lakou i hana'i.   
\b  
\q1
\v 29 A hiki i ke aumoe, pepehi iho la o Iehova i na hiapo a pau, ma ka aina o Aigupita, mai ka hiapo a Parao, a ka mea noho maluna o kona nohoalii, a hiki i ka hiapo a ka mea pio iloko o ka hale luapaahao, a me na hiapo a pau a na holoholona.   
\q1
\v 30 Ala ae la o Parao i ka po, oia a me kana poe kauwa a pau, a me ko Aigupita a pau: a he nui loa ke kupinai ana ma Aigupita, no ka mea, aohe hale i make ole ai kekahi.   
\b  
\q1
\v 31 Hea mai la oia ia Mose laua o Aarona i ka po, i mai la, E ku ae olua e hele aku maiwaena aku o ko'u poe kanaka, o olua a me na mamo a Iseraela: e hele, e hookauwa aku na Iehova, e like me ka olua i olelo mai ai.   
\q1
\v 32 E lawe pu aku no i ka oukou poe hipa, a me ka oukou poe bipi, e like me ka olua i olelo ai, a e hele: a e hoomaikai hoi olua ia'u.   
\q1
\v 33 Ikaika iho la ka manao o ko Aigupita, e kipaku koke ia lakou mai ka aina aku: no ka mea, Ua pau makou i ka make, wahi a lakou.   
\q1
\v 34 Lawe mai la na kanaka i ka lakou berena maka, hu ole, a me ko lakou mau papawiliai, ua ope pu ia me ko lakou lole maluna o ko lakou mau hokua.   
\q1
\v 35 Hana iho la na mamo a Iseraela, e like me ka olelo ana a Mose, a nonoi aku la i ko Aigupita i na mea kala, a me na mea gula, a me na mea aahu.   
\q1
\v 36 A haawi mai la o Iehova i ka lokomaikaiia i na kanaka imua o ka maka o ko Aigupita, a haawi mai la lakou: pela lakou i hao ai i ko Aigupita.   
\b  
\q1
\v 37 Hele mai la na mamo a Iseraela mai Ramese a hiki i Sukota, eono paha haneri tausani kane i hele wawae, a he okoa na kamalii.   
\q1
\v 38 Hele pu mai la ka poe e he nui loa, i hui pu ia mai, a me na hipa, a me na bipi, he nui loa na holoholona.   
\q1
\v 39 Pulehu iho la lakou i berena hu ole o ka berena maka a lakou i lawe mai ai mai Aigupita mai, aole ia i hu, no ka mea, ua kipakuia lakou mailoko mai o Aigupita, aole i hiki ia lakou ke kali, aole hoi lakou i hoomakaukau i o na lakou iho.   
\b  
\q1
\v 40 O ka noho ana o na mamo a Iseraela, i noho ai lakou ma Aigupita, eha haneri makahiki a me ke kanakolu.   
\q1
\v 41 A pau aku la ia mau makahiki eha haneri a me ke kanakolu, ia la no, hele mai la ka poe koa a pau o Iehova, mai ka aina mai o Aigupita.   
\q1
\v 42 He po ia e hoomanao nui ia'i no Iehova, no kona lawe ana mai ia lakou mai ka aina mai o Aigupita: eia no ka po o Iehova e hoomanaoia'i e na mamo a pau a Iseraela, ma na hanauna o lakou.   
\b  
\q1
\v 43 I mai la o Iehova ia Mose laua o Aarona, Eia no ke kanawai o ka moliaola; aole e ai ke kanaka e i a mea.   
\q1
\v 44 Aka, o ke kauwa a kela kanaka keia kanaka i kuaiia i ke kala, aia okipoepoe iho oe ia ia, alaila ia e ai iho ai ia mea.   
\q1
\v 45 O ke kanaka e, a me ke kauwa i hoolimalimaia, aole laua e ai ia mea.   
\q1
\v 46 I ka hale hookahi no e aiia'i ia mea; mai lawe oukou i kekahi io ma kahi e aku mawaho o ka hale; mai uhai hoi oukou i kekahi iwi o ia mea.   
\q1
\v 47 E hana no ke anaina kanaka o Iseraela a pau ia mea.   
\q1
\v 48 A i noho pu kekahi kanaka e me oe, a manao no ia e malama i ka moliaola no Iehova, e okipoepoeia kona poe kane a pau; alaila e hookokoke mai ia e malama ia mea; a e lilo ia i mea like me ka mea i hanauia ma ka aina: no ka mea, aole loa e ai kekahi ia mea, ke okipoepoe ole ia oia.   
\q1
\v 49 Hookahi no kanawai no ke kanaka i hanauia ma ko oukou wahi, a me ke kanaka e, e noho pu ana me oukou.   
\q1
\v 50 Pela no i hana'i na mamo a Iseraela a pau; e like me ka mea a Iehova i kauoha mai ai ia Mose a ia Aarona, pela lakou i hana'i.   
\q1
\v 51 Ia la no, lawe mai la no o Iehova i na mamo a Iseraela mai ka aina o Aigupita mai, ma ko lakou poe koa.   
\c 13  
\b  
\q1
\v 1 OLELO mai la o Iehova ia Mose, i mai la,   
\q1
\v 2 E hoolaa mai i na hiapo a pau na'u, o na mea a pau o na mamo a Iseraela i hanau mua o ka ke kanaka, a o ka ka holoholona, na'u no ia.   
\b  
\q1
\v 3 I aku la o Mose i na kanaka, E hoomanao oukou i keia la a oukou i puka mai ai, mailoko mai o Aigupita, a mailoko ae o ka hale hooluhi; no ka mea, ua lawe mai nei o Iehova ia oukou mailoko mai o ia wahi, me ka lima ikaika: aole e aiia ka berena hu.   
\q1
\v 4 I keia la oukou i hele mai ai, i ka malama o Abiba.   
\b  
\q1
\v 5 A i ka wa a Iehova e lawe aku ai ia oe iloko i ka aina o ka Kanaana, a o ka Heta, a o ka Amora, a o ka Hiva a me ka Iebusa, i kahi ana i hoohiki ai i kou poe kupuna, e haawi mai oia nou, he aina e kahe ana o ka waiu a me ka meli; alaila, i keia malama, e hana oe i keia oihana.   
\q1
\v 6 Ehiku mau la au e ai ai i ka berena hu ole, a i ka hiku o ka la, he ahaaina no Iehova.   
\q1
\v 7 I na la ehiku e aiia ka berena hu ole; aole loa e ikea ka berena hu me oe, aole hoi e ikea ka mea hu me oe, i kou mau wahi a pau.   
\b  
\q1
\v 8 A e hoike aku oe i kau keikikane i kela la, i ka i ana aku, No ka mea keia a Iehova i hana mai ai ia'u, i ko'u puka ana mai iwaho o Aigupita.   
\q1
\v 9 He hoailona no ia nou ma kou lima, he mea hoomanao no hoi mawaena o kou mau maka, i mau ke kanawai o Iehova ma kou waha; no ka mea, me ka lima ikaika ka Iehova i lawe mai ai ia oe mai Aigupita mai.   
\q1
\v 10 No ia mea, e malama oe i keia oihana, i kona manawa, ia makahiki aku, ia makahiki aku.   
\b  
\q1
\v 11 Eia hoi kekahi, a hiki i ka wa a Iehova e lawe aku ai ia oe i ka aina o ka Kanaana, e like me kana i hoohiki mai ai ia oe, a i kou poe kupuna, a e haawi mai ana hoi nou;   
\q1
\v 12 Alaila e hoolaa ae oe no Iehova i na mea a pau i hanau mua, a o na hiapo a pau a na holoholona ou; no Iehova no na kane.   
\q1
\v 13 A o na keiki mua a pau a ka hoki, e panai aku oe no ia i keikihipa; a i ole oe e panai, alaila e uhai i kona a-i. A o na keiki mua a pau a kanaka, iwaena o kau poe keiki, o lakou kau e panai aku.   
\b  
\q1
\v 14 Eia hoi, a i ka wa e ninau mai ai kau keikikane mahope aku nei, e i mai ana, Heaha keia? alaila e hai aku oe ia ia, Me ka lima ikaika ka Iehova i lawe mai ai ia makou mailoko mai o Aigupita, a mailoko mai hoi o ka hale hooluhi;   
\q1
\v 15 A i ka wa i aua ai o Parao i ke kuu mai ia makou, alaila pepehi iho la o Iehova i na hiapo a pau ma ka aina o Aigupita, o ka hiapo a ke kanaka a me ka hiapo a ka holoholona: nolaila ka'u e mohai aku nei i na kane a pau i hanau mua: aka, o na hiapo a pau a ka'u mau keiki, oia ka'u e hoolapanai aku.   
\q1
\v 16 A e lilo keia mea i hoailona ma kou lima, a he mea hoomanao hoi mawaena o kou mau maka; no ka mea, me ka lima ikaika i lawe mai ai o Iehova ia kakou mawaho mai o Aigupita.   
\b  
\q1
\v 17 A i ka wa i hookuu mai ai o Parao i na kanaka, aole i alakai mai ke Akua ia lakou ma ke ala o ka aina o ka poe Pilisetia, oia no nae ke ala kokoke; no ka mea, i iho la ke Akua, E makau paha na kanaka, ke ike lakou i ke kaua, a hoi hou lakou i Aigupita.   
\q1
\v 18 Aka, alakai puni ae la ke Akua i na kanaka ma ke ala o ka. waonahele o ke Kaiula: hele makaukau mai la na mamo a Iseraela, mai ka aina o Aigupita mai.   
\q1
\v 19 Lawe pu mai la o Mose me ia i na iwi o Iosepa; no ka mea, ua kauoha ikaika mai oia i na mamo a Iseraela, i ka i ana mai, He oiaio no, e hele mai ke Akua e ike ia oukou; a e lawe aku hoi oukou i ko'u mau iwi me oukou.   
\b  
\q1
\v 20 Hele aku la lakou mai Sukota aku, a hoomoana ma Etama, ma ke kihi o ka waonahele.   
\q1
\v 21 Hele aku la o Iehova mamua o lakou maloko o ke kia ao i ke ao, e alakai ia lakou ma ke ala; a maloko o ke kia ahi i ka po, e hoomalamalama mai ia lakou; i hele lakou i ke ao a me ka po.   
\q1
\v 22 Aole ia i lawe aku i ke kia ao i ke ao, aole hoi i ke kia ahi i ka po, mai ke alo o na kanaka aku.   
\c 14  
\b  
\q1
\v 1 OLELO mai la o Iehova ia Mose, i mai la,   
\q1
\v 2 E i aku oe i na mamo a Iseraela, e kipa ae lakou, a e hoomoana ma ke alo o Pihahirota, mawaena o Migedola a me ke kai, ma kahi e ku pono ana i Baalazepona: ma ke alo o ia wahi oukou e hoomoana ai, ma kahakai.   
\q1
\v 3 E olelo auanei o Parao no na mamo a Iseraela, Ua pilikia lakou iloko o ua aina la, ua paa lakou i ka waonahele.   
\q1
\v 4 A na'u no e hoopaakiki i ka naau o Parao, i hahai mai ai oia mahope o lakou: a e hoouaniia auanei au maluna o Parao, a maluna o kona puali a pau; i ike ai hoi ko Aigupita, owau no Iehova. A pela no lakou i hana'i.   
\b  
\q1
\v 5 A haiia aku la i ke alii o Aigupita, Ua holo na kanaka; huli ka naau o Parao a me na kauwa ana e ku e i na kanaka: olelo iho la lakou, no ke aha la kakou i hana'i i keia, a hookuu aku i ka Iseraela i hookauwa ole ai lakou na kakou?   
\q1
\v 6 Hoomakaukau ae la ia i kona kaakaua, a lawe pu aku la i kona poe kanaka me ia.   
\q1
\v 7 Lawe aku la ia i na halekaa i waeia eono haneri, a me na kaakaua a pau o Aigupita, a me na luna o ia mau mea a pau.   
\q1
\v 8 Hoopaakiki iho la o Iehova i ka naau o Parao, o ke alii o Aigupita, a hahai mai la ia mahope o na mamo a Iseraela: a puka mai la na mamo a Iseraela mawaho me ka lima hookiekie.   
\q1
\v 9 Hahai mai la ko Aigupita mahope o lakou, o na lio a pau, a me na kaakaua o Parao, a me kona hoohololio, a me kona poe koa, a loaa mai lakou nei e hoomoana ana ma kahakai, ma Pihahirota, e ku pono ana i Baalazepona.   
\b  
\q1
\v 10 A hookokoke mai la o Parao, alawa ae la na maka o na mamo a Iseraela, aia hoi, e hele mai ana ko Aigupita mahope o lakou; makau loa iho la lakou: a uwe aku la na mamo a Iseraela ia Iehova.   
\q1
\v 11 I mai la hoi lakou ia Mose, No ka mea, aohe lua kupapau ma Aigupita, ua lawe mai anei oe ia makou e make ma keia waonahele? No ke aha la kau i hana mai ai ia makou pela, i ka lawe ana mai nei ia makou mai Aigupita mai?   
\q1
\v 12 Aole anei keia o ka olelo a makou i hai aku ai ia oe ma Aigupita, i ka i ana aku, E waiho pela ia makou, i hookauwa aku ai makou na ko Aigupita? No ka mea, he mea maikai no makou ke hookauwa aku na ko Aigupita, aole hoi e make ma ka waonahele.   
\b  
\q1
\v 13 Olelo aku la o Mose i na kanaka, mai makau oukou, e ku malie oukou, a e nana aku i ka hoola ana o Iehova, i ka mea ana e hoike mai ai ia oukou i keia la; no ka mea, o ko Aigupita a oukou i ike ai i keia la, aole oukou e ike hou ia lakou, mahope mau loa aku.   
\q1
\v 14 Na Iehova no e kaua aku no oukou, a e noho malie oukou.   
\b  
\q1
\v 15 I mai la o Iehova ia Mose, No ke ah a la oe e kahea mai nei ia'u? e i aku oe i na mamo a Iseraela, e hele aku lakou imua.   
\q1
\v 16 Aka, E hapai oe i kou kookoo, a e o aku kou lima maluna o ke kai, a e hookaawale ia: a e hele aku no na mamo o Iseraela mawaena o ke kai, ma kahi maloo.   
\q1
\v 17 A na'u iho no e hoopaakiki i na naau o ko Aigupita, a e hahai mai lakou mahope o lakou nei: a e hoonani au ia'u iho ma o Parao la a ma kona poe koa a pau, a ma kona mau kaakaua, a me na hoohololio ona.   
\q1
\v 18 A e ike auanei ko Aigupita, owau no Iehova, ke hoonani wau ia'u iho ma o Parao la, a me kona mau kaakaua, a me na hoohololio ona.   
\b  
\q1
\v 19 A o ka anela o ke Akua i hele mamua o ke kahua hoomoana o ka Iseraela, hoi aku la ia mahope o lakou; a hele ae la hoi ke kia ao mai mua ao o lakou, a ku iho la mahope o lakou.   
\q1
\v 20 Hele mai la ia mawaena o ko Aigupita poe a me ka Iseraela: a lilo ia i ao pouli; a hoomalamalama mai no nae i ka po; nolaila, aole i hookokoke mai kela poe i keia mai ia po a ao.   
\b  
\q1
\v 21 O aku la o Mose i kona lima maluna o ke kai; na Iehova i hookahe ke kai me ka makani ikaika, mai ka hikina mai, i kela po a ao, a lilo iho la ke kai i aina maloo, a ua maheleia ae la na wai.   
\q1
\v 22 Hele mai la na mamo a Iseraela mawaena o ke kai ma kahi maloo: a lilo ka wai i pali no lakou ma ko lakou lima akau a me ko lakou lima hema.   
\b  
\q1
\v 23 Hahai mai la ko Aigupita, a hele mai mahope o lakou, o na lio a pau o Parao, a me kona mau kaakaua, a me na hoohololio iwaena o ke kai.   
\q1
\v 24 A hiki i ka wati wanaao, nana mai la o Iehova i ka poe kaua o Aigupita, mai ke kia ahi a me ke ao mai, a hoopilikia ae la i ka poe kaua o Aigupita.   
\q1
\v 25 Hoohemohemo iho la ia i na huila o ko lakou mau kaakaua, i hele pupu ai lakou; no ia mea, olelo mai la ko Aigupita, E auhee kakou mai ke alo aku o ka Iseraela; no ka mea, ua kaua mai no o Iehova me lakou pu i ko Aigupita.   
\b  
\q1
\v 26 Olelo mai la o Iehova ia Mose, E o aku kou lima maluna o ke kai, i hoi hou mai ai ka wai maluna o ko Aigupita, maluna o ko lakou mau halekaa, a maluna o ko lakou poe hoohololio.   
\q1
\v 27 Hoo aku la no o Mose i kona lima maluna o ke kai, a hoi mai no ke kai i kona piha ana i ka wa e pualena ana o ke ao; auhee aku la ko Aigupita i ka loaa ana o ka wai; a lulu iho la o Iehova i ko Aigupita iloko o ke kai.   
\q1
\v 28 Hoi hou aku la ke kai, a popoi iho la maluna o na kaakaua, a me na hoohololio, a me ka poe koa a pau o Parao i hele mai iloko o ke kai mahope o lakou: aole loa kekahi o lakou i koe.   
\q1
\v 29 Aka, o na mamo a Iseraela, hele mai la lakou ma kahi maloo iwaenakonu o ke kai: a o na wai, he pali ia no lakou ma ko lakou lima akau, a me ko lakou lima hema.   
\q1
\v 30 Pela i hoola mai ai o Iehova i ka Iseraela ia la, mai ka lima o ko Aigupita mai; a ike aku la ka Iseraela i ko Aigupita maluna o kahakai, ua make.   
\q1
\v 31 Ike aku la ka Iseraela i kela hana nui a Iehova i hana aku ai i ko Aigupita: a makau iho la na kanaka ia Iehova; a manaoio aku la lakou ia Iehova, a me kana kauwa o Mose.   
\c 15  
\b  
\q1
\v 1 A LAILA mele aku la o Mose, a me na mamo a Iseraela i keia mele ia Iehova: olelo aku la ia me ka i ana aku,  
\q1 Ia Iehova no wau e mele aku ai,  
\q1 No ka mea, ua hoonani loa oia ia ia iho;  
\q1 Ua kiola oia i ka lio, a me kona mea hooholo iloko o ke kai.   
\q1
\v 2 O Iehova no ko'u ikaika, a me ka'u mele,  
\q1 Oia ko'u hoola, o ko'u Akua hoi ia,  
\q1 E hoomakaukau no wau i wahi nona e noho ai.  
\q1 O ke Akua no ia o ko'u makua,  
\q1 A e mililani aku au ia ia.   
\q1
\v 3 He kanaka kaua o Iehova,  
\q1 O Iehova no kona inoa.   
\q1
\v 4 Ua ka oia i ke kai i na kaakaua o Parao,  
\q1 A me kona poe koa;  
\q1 Ua poho ilalo o ke Kaiula kona poe kaua ma na kaa:   
\q1
\v 5 Ua poipu ka hohonu ia lakou;  
\q1 Poho lakou ilalo me he pohaku la.   
\q1
\v 6 Ua nani kou lima akau, e Iehova, no ka mana;  
\q1 Na kou lima akau, e Iehova, i paki iho i ka enemi.   
\q1
\v 7 I ka nui o kou nani, ua hoopuehu aku oe i ka poe i ala ku e mai ia oe;  
\q1 Hoouna aku oe i kou huhu,  
\q1 Pau iho la lakou me he opala la.   
\q1
\v 8 I ka hoohanu ana o kou mau pukaihu, ua hoakoakoaia mai na wai,  
\q1 Ea ae la na wai iluna, me he puu la:  
\q1 Lilo no ka hohonu i mea paa maloko o ka opu o ke kai.   
\q1
\v 9 I iho la ka enemi, E hahai aku no au,  
\q1 E loaa no, a puunauwe aku i ka waiwai pio.  
\q1 E maona auanei ko'u kuko ia lakou,  
\q1 E unuhi au i ko'u pahikaua,  
\q1 A e loaa hou no lakou i ko'u lima.   
\q1
\v 10 Pupuhi no oe me kou makani,  
\q1 Uhi mai la ke kai ia lakou,  
\q1 Poho iho la lakou ilalo i ke kai me he kepau la.   
\q1
\v 11 Owai ka mea iwaena o ka poe ikaika e like me oe, e Iehova?  
\q1 Owai kou mea like, ma ka nani o ka hemolele?  
\q1 He mea weliweli ka hoomana aku,  
\q1 Ua hana oe i na mea kupanaha.   
\q1
\v 12 O aku la no kou lima akau,  
\q1 Ale iho la ka honua ia lakou.   
\q1
\v 13 Ma ka lokomaikai no oe i alakai mai ai i na kanaka au i hoolapanai ai;  
\q1 Me kou mana no oe i alakai ai ia lakou i kahi hemolele au i noho ai.   
\q1
\v 14 E lohe auanei na kanaka, a e makau hoi.  
\q1 E loohia auanei ka poe noho ma Palisetina i ka weliweli.   
\q1
\v 15 Alaila, e weliweli mai na'lii o Edoma,  
\q1 E loohia no hoi ka poe ikaika o Moaba i ka haalulu,  
\q1 E hehee auanei ka poe a pau e noho ana ma Kanaana.   
\q1
\v 16 E kau mai no ka makau a me ka weliweli maluna o lakou;  
\q1 No ka nui o kou lima e noho malie lakou me he pohaku la;  
\q1 A hala'e kou poe kanaka, e Iehova,  
\q1 A hala'e na kanaka au i hoolapanai ai.   
\q1
\v 17 Nau no lakou e hookomo,  
\q1 A e hoonoho hoi ia lakou ma ka puu o kou hooilina,  
\q1 I kahi au i hana'i i wahi e noho ai nou, e Iehova,  
\q1 I ke keenakapu hoi a kou mau lima i hookumu ai, e ka Haku.   
\q1
\v 18 E noho alii mau loa aku no o Iehova.   
\b  
\q1
\v 19 No ka mea, hele ae la ka lio o Parao,  
\q1 Me kona kaahaua, a me na hoohololio ona,  
\q1 A iloko o ke kai,  
\q1 A hoihoi mai la o Iehova i na wai o ke kai maluna o lakou;  
\q1 Aka, o na mamo a Iseraela,  
\q1 Hele ae la lakou ma kahi maloo mawaenakonu o ke kai.   
\b  
\q1
\v 20 A o Miriama, ke kaula wahine, ke kaikuwahine o Aarona, lawe  
\q1 ae la ia i mea kuolokani ma kona lima, a hahai aku la na wahine  
\q1 a pau mamuli ona, me na mea kuolokai, a me ka hula.   
\q1
\v 21 I mai la o Miriama ia lakou,  
\q1 E mele aku oukou ia Iehova,  
\q1 No ka mea, ua lanakila loa oia,  
\q1 Ua kiola oia i ka lio a me kona mea hooholo i ke kai.   
\b  
\q1
\v 22 Pela i lawe mai ai o Mose i ka Iseraela, mai ke Kaiula mai, a hele mai la lakou i ka waonahele i Sura; hele mai la lakou maloko o ka waonahele i na la ekolu, aole hoi i loaa ka wai.   
\b  
\q1
\v 23 A hiki mai la lakou i Mara; aole hiki ia lakou ke inu i ka wai o Mara, no ka mea, ua mulea ia; no ia mea, i kapaia'ku ai ia o Mara.   
\q1
\v 24 Ohumu ae la na kanaka ia Mose, i ae la, Heaha la ko makou mea inu?   
\q1
\v 25 Uwe aku la oia ia Iehova; a hoike mai la o Iehova ia ia i kekahi laau, a hooleiia'ku la ia mea e ia iloko o ka wai, hanaia mai la ka wai a ono: malaila ia i hana'i i olelo kupaa no lakou, a i kanawai hoi, a maiaila oia i hoao ai ia lakou.   
\q1
\v 26 I mai la, A i hoolohe mau mai oe i ka leo o Iehova, o kou Akua, a e hana i ka mea pono imua o kona maka, a e hoolohe i ka mea ana e kauoha mai ai, a malama i kona mau kanawai, alaila aole au e kau maluna ou i kekahi o keia mau mai a'u i kau ai maluna o ko Aigupita; no ka mea, owau no Iehova, ka mea hoola aku ia oe.   
\b  
\q1
\v 27 A hele mai la lakou i Elima, malaila na punawai he umikumamalua, a me na laau pama he kanahiku: noho iho la lakou ilaila ma kahi o na wai.   
\c 16  
\b  
\q1
\v 1 HELE mai la lakou, mai Elima mai, a hiki mai la ka poe mamo a pau a Iseraela i ka waonahele i Sina, he wahi ia mawaena o, Elima a me Sinai, o ka la umikumamalima ia o ka malama alua, mai ko lakou puka ana mai iwaho, mai ka aina o Aigupita mai.   
\q1
\v 2 Ohumu ae la ka poe mamo a pau a Iseraela ia Mose ma laua o Aarona, ma ka waonahele;   
\q1
\v 3 I mai la na mamo a Iseraela ia laua, Ina i haawiia mai ka make no kakou, i ka lima o Iehova, ma ka aina o Aigupita, i ka wa a kakou i noho ai ma na ipu ia, a ai aku no hoi kakou i ka ai a maona; no ka mea, ua lawe mai olua ia kakou, maloko o keia waonahele, e pepehi i keia poe a pau i ka pololi.   
\b  
\q1
\v 4 I mai la o Iehova ia Mose, Aia hoi, e hooua aku au i ka ai, mai ka lani aku; a e hele aku na kanaka mawaho, e hoouluulu i ko ka la ma ia la, i hoao aku ai au ia lakou, e hele paha lakou ma ko'u kanawai, aole paha.   
\q1
\v 5 A hiki i ka la aono, e hoomakaukau lakou i ka mea a lakou e lawe mai ai iloko; e papalua ia i ka mea a lakou e hoouluulu ai i kela la i keia la.   
\q1
\v 6 Olelo mai la o Mose laua o Aarona i na mamo a pau a Iseraela, A ahiahi, alaila oukou e ike, na Iehova no oukou i lawe mai nei, mai ka aina mai o Aigupita:   
\q1
\v 7 A kakahiaka, alaila oukou e ike ai i ka nani o Iehova; no kona hoolohe ana i ka mea a oukou i ohumu aku ai ia Iehova: heaha hoi maua, i ohumu mai ai oukou ia maua?   
\q1
\v 8 I mai la o Mose, E haawi mai ana o Iehova i ke ahiahi, i ia na oukou e ai ai, a kakahiaka i ai e maona ai; no ka mea, ua lohe mai o Iehova i ka ohumu ana a oukou i ohumu aku ai ia ia: Heaha hoi o maua? aole no maua ka oukou ohumu ana, aka, no Iehova.   
\b  
\q1
\v 9 Olelo ae la o Mose ia Aarona, E i aku oe i ka poe mamo a pau a Iseraela, E hele mai lakou imua i ke alo o Iehova: no ka mea, ua lohe ia i ka oukou ohumu ana.   
\q1
\v 10 A i ka Aarona olelo ana i ka poe mamo a pau a Iseraela, alawa ae la lakou ma ka waonahele, aia hoi, ikea aku la ka nani o Iehova ma ke ao.   
\b  
\q1
\v 11 Olelo mai la o Iehova ia Mose, i mai la,   
\q1
\v 12 Ua lohe au i na ohumu ana a na mamo a Iseraela: E olelo aku oe ia lakou, e i aku, A ahiahi, e ai ana oukou i ka ia, a kakahiaka ae, e maona oukou i ka ai: a e ike auanei oukou, owau no Iehova, ko oukou Akua.   
\b  
\q1
\v 13 A i ke ahiahi, hiki mai la na selu, a uhi mai la ma kahi a lakou i hoomoana'i: a kakahiaka ae, ahu iho la ka hau, a puni na kahua.   
\q1
\v 14 A i ka lele ana o ka hau i ahuia mai ai, aia hoi, ma ka ili honua o ka waonahele, he mea liilii me he unahi la, me he hau paa la ka liilii.   
\q1
\v 15 A ike aku la na mamo a Iseraela, olelo ae la kekahi o na kanaka i kona hoa, Heaha keia? no ka mea, aole lakou i ike ia mea. Olelo mai la o Mose ia lakou, Eia ka ai a Iehova i haawi mai ai, i mea na oukou o ai ai.   
\b  
\q1
\v 16 Eia hoi ka olelo a Iehova i kauoha mai ai, E hoiliili ke kanaka ia mea, e like me ka kona waha e ai ai, hookahi kanaka hookahi omera; e lawe oukou a pau e like me ka nui o ko oukou poe, o kela kanaka keia kanaka no ka poe o kona halelewa.   
\q1
\v 17 Hana iho la na mamo a Iseraela pela, a he nui ka kekahi i hoiliili ai, a he uuku iho ka kekahi.   
\q1
\v 18 A i ko lakou ana ana ma ka omera, o ka mea hoiliili nui, aohe ana i koe, a o ka mea hoiliili uuku, aole hoi i emi kana: hoiliili kela kanaka keia kanaka e like me ka kona waha i ai ai.   
\q1
\v 19 I aku la o Mose ia lakou, Mai hookoe kekahi kanaka ia mea a kakahiaka.   
\q1
\v 20 Aole nae lakou i hoolohe mai i ka Mose; hookoe no kekahi ia mea a kakahiaka, a piha iho la ia i na ilo, a pilau no hoi: a huhu aku la o Mose ia lakou.   
\q1
\v 21 Hoiliili lakou ia mea i kela kakahiaka i keia kakahiaka, o kanaka a pau e like me ka lakou ai ana; a i ka wa i mahana ae ai ka la, hehee iho la ia mea.   
\b  
\q1
\v 22 A hiki i ka la eono, hoiliili papalua iho la lakou i ka ai, elua omera a ke kanaka hookahi: a hele aku la na luna a pau o na kanaka, a hai aku la ia Mose.   
\q1
\v 23 I mai la ia ia lakou, Oia hoi ka mea a Iehova i olelo mai ai, i ka la apopo ka hoomaha ana o ka sabati laa no Iehova: ka mea a oukou e kalua ai, e kalua, a o ka mea a oukou e hoolapalapa ai, e hoolapalapa: a o ke koena a pau e hoana e oukou, i malamaia ia mea na oukou no ke kakahiaka.   
\q1
\v 24 Hoana e no lakou ia mea, a kakahiaka, e like me ka Mose i kauoha mai ai; aole hoi ia i pilau, aohe ilo hoi maloko o ia mea.   
\q1
\v 25 I mai la o Mose, E ai oukou ia mea i keia la; no ka mea, eia ka sabati no Iehova, i keia la aole e loaa ia mea ma ke kula.   
\q1
\v 26 Eono o oukou la e hoouluulu ai; a o ka hiku o ka la, o ka sabati ia, ia la, aole.   
\b  
\q1
\v 27 A i ka hiku o ka la, hele aku la no kekahi o na kanaka e hoouluulu, aole nae i loaa ia lakou.   
\q1
\v 28 Olelo mai la o Iehova ia Mose, Pehea la ka loihi o ko oukou hoole ana, aole e malama i ka'u mau kauoha, a me ko'u mau kanawai?   
\q1
\v 29 E nana hoi, no ka mea, ua haawi aku o Iehova ia oukou i ka sabati: no ia mea, ua haawi aku la ia na oukou ma ke ono o ka la, i ai no na la elua; e noho oukou, o keia kanaka keia kanaka ma kona wahi iho; mai hele ke kanaka mai kona wahi aku i ka la sabati.   
\q1
\v 30 A hoomaha iho la na kanaka ma ka hiku o ka la.   
\b  
\q1
\v 31 Kapa aku ka ohana Iseraela i ka inoa o ia mea he Mane: ua like no ia me ka hua koriana, ua keokeo; a i ka ai ana ua like no ia me na wepa me ka meli.   
\b  
\q1
\v 32 I mai la o Mose, Eia ka mea a Iehova i kauoha mai nei, E hoopiha i kekahi omera o ia mea, i malama loa ia no kau poe mamo; i ike lakou i ka ai a'u i hanai aku ai ia oukou ma ka waonahele, i ka wa a'u i lawe mai ai ia oukou mai ka aina o Aigupita mai.   
\q1
\v 33 I ae la o Mose ia Aarona, E lawe oe i ipu, a e hahao iloko i kekahi omera a piha i ka mane, a e hoana e imua i ke alo o Iehova, i malama loa ia ia mea no kau poe mamo.   
\q1
\v 34 E like me ka mea a Iehova i kauoha mai ai ia Mose, pela i hoana e ai o Aarona ia mea imua i ke alo o ke kanawai e malama loa ia'i.   
\q1
\v 35 Ai iho la na mamo o Iseraela i ka mane hookahi kanaha makahiki, a hiki lakou i ka aina kanaka; ai no lakou i ka mane, a hiki lakou i ke kihi o ka aina i Kanaana.   
\q1
\v 36 Hookahi omera, he hapanmi ia no ka epa.   
\c 17  
\b  
\q1
\v 1 HELE mai la ka poe mamo a pau a Iseraela, mai ka waonahele o Sina, i ko lakou hele ana, e like no me ke kauoha a Iehova, a hoomoana iho la lakou ma Repidima: aohe hoi wai e inu no na kanaka.   
\q1
\v 2 Nuku mai la na kanaka ia Mose, i mai la, E haawi mai i wai no makou e inu ai. I aku la, o Mose ia lakou, No ke aha la oukou i nuku mai ai ia'u? no ke aha la oukou i aa aku ai ia Iehova?   
\q1
\v 3 Malaila na kanaka i makewai ai; ohumu ae la na kanaka ia Mose, i mai la lakou, No ke aha la oe i lawe mai ai ia makou, mai Aigupita mai, e make makou, a me ka makou keiki, a me ka makou holoholona, i ka makewai?   
\q1
\v 4 Uwe aku la o Mose ia Iehova, i aka la, Pehea la ka'u e hana mai ai i keia poe kanaka? ua kokoke lakou e hailuku mai ia'u.   
\q1
\v 5 I mai la o Iehova ia Mose, E hele ae oe mamua o na kanaka; a e lawe pu aku me oe i na lunakahiko o ka Iseraela; a e lawe no hoi ma kou lima i ke kookoo au i hahau ai i na wai, a e hele:   
\q1
\v 6 Aia hoi, e ku no wau ilaila imua ou maluna o ka pohaku ma Horeba; a e hahau oe i ka pohaku, a e puka mai no ka wai mailoko mai o ia mea i inu ai na kanaka. Hana iho la no o Mose pela imua o na lunakahiko a pau o ka Iseraela.   
\q1
\v 7 Kapa aku la oia i ka inoa o ia wahi, o Masa, a me Meriba, no ka nuku ana o na mamo o Iseraela, a me ko lakou aa ana ia Iehova, i ae la, O Iehova anei kekahi iwaena o kakou, aole paha?   
\b  
\q1
\v 8 Hele mai la ka Ameleka, a kaua mai i ka Iseraela ma Repidima.   
\q1
\v 9 Olelo ae la o Mose ia Iosua, E wae ae oe i kanaka no kakou, a e hele e kaua aku i ka Ameleka: apopo e ku wau maluna pono o ka puu, me ke kookoo o ke Akua ma ko'u lima.   
\q1
\v 10 Hana iho la o Iosua e like me ka mea a Mose i olelo mai ai ia ia, a kaua aku la i ka Ameleka: a o Mose, a me Aarona, a me Hura, pii aku la lakou maluna pono o ka puu.   
\q1
\v 11 A i ka wa a Mose i kikoo aku ai i kona lima, ikaika ka Iseraela: a i ka wa i alu mai ai kona lima, ikaika ka Ameleka.   
\q1
\v 12 Kaumaha iho la ko Mose mau lima; a lawe lakou i ka pohaku, a hoonoho iho la malalo iho ona, a noho iho la ia maluna; a o Aarona laua o Hura, paepae ae la laua i kona mau lima, o kekahi ma kekahi aoao, a o kela, ma kela aoao; a paa iho la kona mau lima a napoo ka la.   
\q1
\v 13 Hooauhee aku la o Iosua i ka Ameleka, a me kona kanaka, me ka maka o ka pahikaua.   
\b  
\q1
\v 14 I mai la o Iehova ia Mose, E palapala oe i keia maloko o ka buke, i mea e hoomanao ai, a e hai ma ka pepeiao o Iosua; no ka mea, e anai loa ana au i ka Ameleka mailalo ae o ka lani.   
\q1
\v 15 Hana iho la o Mose i kuahu malaila, a kapa aku la ia i ka inoa o ia mea O IEHOVA-NISI.   
\q1
\v 16 Ua olelo no ia, No ka lima ma ka nohoalii o Iehova, e mau loa no ke kaua ana o Iehova i ka Ameleka, mai keia hanauna a ia hanauna aku.   
\c 18  
\b  
\q1
\v 1 LOHE ae la o Ietero, ke kahuna o Midiana, ka makuahonowaikane o Mose, i na mea a pau a ke Akua i hana mai ai ia Mose, a me kona poe kanaka o ka Iseraela i ko Iehova lawe ana mai i ka Iseraela mai loko mai o Aigupita;   
\q1
\v 2 Alaila kai mai la o Ietero, ka makuahonowaikane o Mose ia Zipora i ka wahine a Mose, mahope o kona hoihoi ana aku ia ia,   
\q1
\v 3 A me na keiki kane ana elua; o Geresona ka inoa o kekahi; no ka mea, ua olelo ia, He malihini au ma ka aina e:   
\q1
\v 4 A o ka inoa o kekahi, o Eliezera; no ka mea, o ke Akua o ko'u makua, i kona kokua ana mai ia'u, hoola mai ia ia'u, mai ka pahikaua mai o Parao;   
\q1
\v 5 Hele mai la io Mose la o Ietero, ka makuahonowaikane o Mose, a me kana mau keikikane, a me kana wahine, ma ka waonahele, i kahi ana i hoomoana ai ma ka mauna o ke Akua:   
\q1
\v 6 Olelo mai la ia ia Mose, Owau no Ietero, kou makuahonowaikane, ua hele mai au i ou nei a me kau wahine, a me kau mau keikikane elua.   
\b  
\q1
\v 7 Hele aku la o Mose e halawai me kona makuahonowaikane, a kulou iho la ia, a honi aku la ia ia: a ninau kekahi i kekahi, i ka maikai o ko laua noho ana; a komo ae la laua iloko o ka halelewa.   
\q1
\v 8 Hai ae la o Mose i kona makuahonowaikane, i na mea a pau a Iehova i hana mai ai ia Parao, a i ko Aigupita, no ka Iseraela, a me ka pilikia a pau i loaa ia lakou ma ke alanui, a me ka hoopakele ana o Iehova ia lakou.   
\q1
\v 9 Olioli iho la o Ietero no na mea raaikai a pau a Iehova i hana mai ai i ka Iseraela, i ka poe ana i hoopakele ai, mai ka lima mai o ko Aigupita.   
\q1
\v 10 I ae la o Ietero, E hoomaikaiia o Iehova, o ka mea i hoopakele ia oukou mai ka lima mai o ko Aigupita, a me ka lima o Parao, o ka mea i hoopakele i kanaka, mailalo mai o ka lima o ko Aigupita.   
\q1
\v 11 Ano, ua ike au i ka oi ana o ko Iehova mana mamua o ko na akua a pau: no ka mea, ma kahi a lakou i kookiekie ai, aia no ia maluna o lakou.   
\q1
\v 12 Lawe iho la o Ietero, ka makuahonowaikane o Mose, i mohaikuni, a me na alana no ke Akua, a hele mai la o Aarona, a me na lunakahiko a pau o ka Iseraela, e ai pu ai me ka makuahonowaikane o Mose, imua o ke Akua.   
\b  
\q1
\v 13 A ia la hope iho, noho iho la o Mose e hooponopono i na kanaka; a ku mai la na kanaka imua o Mose, mai ke kakahiaka a ahiahi.   
\q1
\v 14 A ike ka makuahonowaikane o Mose i na mea a pau ana i hana'i i kanaka; alaila, olelo ae la ia, Heaha keia mea au e hana nei i kanaka? No ke aha la e noho oe, o oe wale no, a ku mai la na kanaka a pau imua ou, mai ke kakahiaka mai a ahiahi?   
\q1
\v 15 I aku la o Mose i kona makuahonowaikane, No ka mea, ua hele mai na kanaka io'u nei e ninau i ke Akua:   
\q1
\v 16 Ina loaa ia lakou kekahi mea, hele mai lakou ia'u; a na'u no e hooponopono aku mawaena o ke kanaka, a me. kona hoa; a na'u no e hoike aku ia lakou i ka olelo kupaa a ke Akua, a me kona kanawai.   
\q1
\v 17 I mai la ka makuahonowaikane o Mose ia ia, Aole pono ka mea au e hana nei.   
\q1
\v 18 E oiaio no, e mae wale oe, o oe, a me keia poe kanaka me oe; no ka mea, ua kaumaha keia mea ia oe; aole hiki ia oe ke hana, o oe wale no.   
\q1
\v 19 E hoolohe mai hoi oe i ko'u leo, a e ao aku au ia oe, a o ke Akua pu kekahi me oe; o oe no ko na kanaka mea ma ke Akua, e hai aku i na mea imua o ke Akua:   
\q1
\v 20 A e ao aku oe ia lakou i na oihana a me na kanawai, a e hoike aku oe ia lakou i ke ala e hele ai lakou, a me ka hana e hana'i lakou.   
\q1
\v 21 Eia hoi kekahi, e hoomakaukau oe i poe maiau o na kanaka, he poe makau i ke Akua, he poe kanaka oiaio, a huhu i ka waiwai alunu; a e hoonoho ia lakou maluna o kanaka, i luna lakou no na tausani, i luna no hoi no na haneri, a i luna no na kanalima, a i luna no na umi:   
\q1
\v 22 Na lakou no e hooponopono i kanaka i na wa a pau; a o na mea nui a pau, na lakou e lawe mai ia oe, a o na mea liilii, na lakou ia e hooponopono: pela oe e mama ai, a na lakou e amo pu me oe.   
\q1
\v 23 Ina e hana mai oe i keia mea, a kauoha mai ke Akua ia oe pela, alaila e hiki ia oe ka mau loa ana, a e hele no hoi keia poe kanaka a pau i ko lakou wahi me ka malumaluhia.   
\b  
\q1
\v 24 Hoolohe ae la o Mose i ka leo o kona makuahonowaikane, a hana iho la ia i na mea a pau ana i olelo ai.   
\q1
\v 25 Wae aku la o Mose i kanaka maiau o ka Iseraela a pau, a hoolilo iho la ia lakou i mau poo maluna o kanaka, na luna no na tausani, na luna no na haneri, na luna no na kanalima, a me na luna no na umi.   
\q1
\v 26 Na lakou i hooponopono i kanaka i na wa a pau; a o na mea nui ka lakou i lawe mai ai ia Mose, a na lakou no i hooponopono na mea liilii a pau.   
\b  
\q1
\v 27 Kuu aku la o Mose i kona makuahonowaikane: a hoi aku la i kona aina iho.   
\c 19  
\b  
\q1
\v 1 A I ke kolu o ka malama o ka puka ana mai o na mamo a Iseraela mai loko mai o Aigupita, ia la no, hiki mai la lakou i ka waonakele o Sinai.   
\q1
\v 2 A hele mai la lakou, mai Repidima mai, a hiki ma ka waonahele o Sinai, a hoomoana iho la lakou ma ka waonahele; malaila ka Iseraela i hoomoana ai ma kahi e pili ana i ka mauna.   
\q1
\v 3 Pii aku la o Mose i ke Akua, a hea mai la o Iehova ia ia mai ka mauna mai, me ka i ana mai, Penei oe e olelo aku ai i na pua a Iakoba, a e hai aku i na mamo a Iseraela;   
\q1
\v 4 Ua ike no oukou i na mea a'u i hana'i i ko Aigupita, i ko'u kaikai ana ia oukou ma na eheu o ka aeto, a lawe mai ia oukou io'u nei.   
\q1
\v 5 A ina hoolohe io mai oukou i ko'u leo, a malama hoi i ko'u berita, alaila e lilo auanei oukou i waiwai no'u, mamua o na kanaka a pau; no ka mea, no'u no ka honua nei a pau:   
\q1
\v 6 E lilo no hoi oukou i aupuni kahuna pule no'u, a he lahuikanaka laa. Oia hoi na olelo au e hai aku ai i na mamo a Iseraela.   
\b  
\q1
\v 7 Hele ae la o Mose, a hea aku la i na lunakahiko o kanaka, a hoonoho iho la imua o lakou i keia mau olelo a pau a Iehova i kauoha mai ai ia ia.   
\q1
\v 8 Olelo pu mai la na kanaka a pau, i mai la, O na mea a pau a Iehova i olelo mai ai, e hana makou ia mea. Hai aku la o Mose i na olelo a kanaka ia Iehova.   
\q1
\v 9 Olelo mai la o Iehova ia Mose, Aia hoi, e hele mai ana au i ou nei maloko o ke ao panopano, i lohe na kanaka i ka'u kamailio ana me oe, a e manaoio mau loa mai ia oe. A hai aku la o Mose i na olelo a kanaka ia Iehova.   
\b  
\q1
\v 10 Olelo mai la o Iehova ia Mose, E hele oe i kanaka, e hoolaa ia lakou i keia la, a apopo; e holoi hoi lakou i ko lakou kapa.   
\q1
\v 11 E hoomakaukau, no ke kolu o ka la, no ka mea, i ke kolu o ka la, e iho mai ai o Iehova, imua o na maka o kanaka a pau, ma ka mauna o Sinai.   
\q1
\v 12 A e kau iho oe i pale, no na kanaka a puni, a e i aku hoi, E malama oukou ia oukou iho, i ko oukou pii ana i ka mauna, a me ka pa ana i kona kihi: o ka mea e pa i ka mauna, he oiaio no e make ia.   
\q1
\v 13 Mai hoopa aku kekahi lima ia mea, no ka mea, he oiaio no, e hailukuia oia, a houia; ina he holoholona, a he kanaka, aole ia e ola: a i kani loihi ka pu, alaila e hele mai lakou i ka mauna.   
\b  
\q1
\v 14 Iho iho la o Mose ilalo, mai ka mauna iho i kanaka; hoolaa iho la i kanaka; a holoi iho la lakou i ko lakou kapa.   
\q1
\v 15 I aku la ia i kanaka, E hoomakaukau oukou, no ke kolu o ka la; mai komo ae i na wahine.   
\b  
\q1
\v 16 A i ke kakahiaka o ke kolu o ka la, he hekili. a he uila, a he ao polohiwa ma ka mauna, a he leo no ka pu e kani ikaika loa ana; haalulu iho la na kanaka a pau ma. ko lakou wihi i hoomoana ai.   
\q1
\v 17 Kai mai la o Mose i kanaka mawaho o kahi a lakou e hoomoana ai, e halawai me ke Akua; a ku iho la lakou ma kahi malalo iho o ka mauna.   
\q1
\v 18 Ma ka mauna a pau i Sinai, he uwahi, no ka mea, ua iho mai o Iehova maluna ona maloko o ke ahi: a punohu aku la kona uwahi, me he uwahi umu hao la, haalulu nui iho la ka mauna a pau.   
\q1
\v 19 A i ke kani loihi loa ana o ka pu, a ikaika nui ae la, olelo aku la o Mose, a pane mai la ka leo o ke Akua ia ia.   
\q1
\v 20 Iho mai la o Iehova maluna o ka mauna o Sinai, ma ke poo o ka mauna, a hea mai la o Iehova ia Mose e pii aku i ke poo o ka mauna; a pii aku la o Mose.   
\q1
\v 21 I mai la o Iehova ia Mose, E iho oe ilalo, e kauoha aku i kanaka, o hemo mai lakou io Iehova nei, e nana, a haule lakou he nui loa.   
\q1
\v 22 A e huikala hoi na kahuna ia lakou iho, o ka poe e hookokoke ana ia Iehova, o poha aku o Iehova io lakou la.   
\q1
\v 23 I aku la o Mose ia Iehova, Aole e hiki na kanaka ke pii mai i ka mauna nei i Sinai: no ka mea, ua kauoha mai oe ia makou, ua i mai, E kau iho i pale a puni ka mauna, a e hookapu ia mea.   
\q1
\v 24 I mai la o Iehova ia ia, O hele, e iho oe ilalo, a e pii hou mai oe, o oe, a me Aarona pu; aka, o na kahuna a me kanaka, mai hemo mai lakou, e pii mai io Iehova nei, o poha aku ia maluna o lakou.   
\q1
\v 25 Iho mai la o Mose ilalo i kanaka, a olelo aku la ia lakou.   
\c 20  
\b  
\q1
\v 1 OLELO mai la ke Akua i keia mau olelo a pau, i mai la.   
\b  
\q1
\v 2 Owau no Iehova o kou Akua, ka mea nana oe i lawe mai nei, mai ka aina o Aigupita mai, mailoko mai hoi o ka hale hooluhi.   
\b  
\q1
\v 3 Aole ou akua e ae imua o ko'u alo.   
\b  
\q1
\v 4 Mai hana oe i ke kii i kalaiia nou, aole ma ka like ana o kekahi mea i ka lani iluna, a me ko ka honua ilalo, a maloko hoi o ka wai malalo o ka honua:   
\q1
\v 5 Mai kulou oe ilalo ia lakou, aole hoi e hoomana ia lakou; no ka mea, owau no Iehova o kou Akua, he Akua lili; e hoopai ana i ka na makua hala i na keiki, a hiki aku i ke kuakahi a me ke kualua o ka poe e inaina mai ia'u:   
\q1
\v 6 A e aloha ana hoi i na tausani o ka, poe e aloha mai ia'u, a e malama hoi i ko'u mau kanawai.   
\b  
\q1
\v 7 Mai hoohiki wahahee oe i ka inoa o Iehova o kou Akua; no ka mea, aole loa e hoapono o Iehova i ka mea hoohiki wahahee i kona inoa.   
\b  
\q1
\v 8 E hoomanao i ka la sabati, a e hoano ia.   
\q1
\v 9 I na la eono e hana'i oe i kau haua a pau;   
\q1
\v 10 Aka, o ka hiku o ka la, he sabati ia no Iehova no kou Akua, aole loa oe e hana ia la, aole oe, aole hoi kou keikikane, aole hoi kou kaikamahine, aole hoi kau kauwakane, aole hoi kau kauwawahine, aole hoi kou holoholona, aole hoi kou kanaka e ma kou mau ipuka:   
\q1
\v 11 No ka mea, i na la eono i hana'i o Iehova i na lani, a me ka honua, a me ke kai, a me na mea a pau maloko o ia mau mea, a i ka iku o ka la i hoomaha'i; nolaila hoi i hoomaikai ai o Iehova i ka la sabati, a hoano ai hoi oia ia la.   
\b  
\q1
\v 12 E hoomaikai oe i kou makuakane, a me kou makuwahine; i loihi ai kou mau la maluna o ka aina a Iehova a kou Akua i haawi mai ai ia oe.   
\b  
\q1
\v 13 Mai pepehi kanaka oe.   
\b  
\q1
\v 14 Mai moe kolohe oe.   
\b  
\q1
\v 15 Mai aihue oe.   
\b  
\q1
\v 16 Mai hoike hoopunipuni oe e hewa ai kou hoalauna.   
\b  
\q1
\v 17 Mai kuko oe i ka hale o kou hoalauna, mai kuko i ka wahine a kou hoalauna, aole hoi i kana kauwakane, aole hoi i kana kauwawahine, aole hoi i kona bipi, aole hoi i kona hold, aole hoi i kekahi mea a kou hoalauna.   
\b  
\q1
\v 18 Ike aku la na kanaka a pau i ke hekili, a me ka uila, a me ke kani ana o ka pu, a me ka mauna e uwahi ana: a ike aku la na kanaka, weliweli iho la; neenee aku la, a ku ma kahi mamao aku.   
\b  
\q1
\v 19 I aku la lakou ia Mose, Nau no makou e olelo mai, a e hoolohe aku no makou: aka, mai olelo mai ke Akua ia makou, o make auanei makou.   
\q1
\v 20 I aku la o Mose i kanaka, Mai weliweli oukou; no ka mea, ua hele mai ke Akua e hoao ia oukou, i mau kona makauia maluna o oukou, i lawehala ole oukou.   
\b  
\q1
\v 21 Ku mai la na kanaka ma kahi loihi e aku, a hookokoke aku la o Mose, i ke ao panopano a ke Akua i uoho ai.   
\b  
\q1
\v 22 I mai la o Iehova ia Mose, E olelo aku oe i na mamo a Iseraela penei, Ua ike oukou i ka'u olelo ana ia oukou, mai ka lani mai.   
\q1
\v 23 Mai hana oe i na akua e me a'u nei i na akua kala, a mai hana i na akua gula no oukou.   
\b  
\q1
\v 24 E hana oe i kuahu lepo no'u a e mohai mai maluna iho i kou mohaikuni, a me kou mohai hoomalu, i kou mau hipa, a me kou mau bipi; i na wahi a pau a'u e hoopaa ai i ko'u inoa, mataila au e hele aku ai i ou la, a e hoomaikai ai ia oe.   
\q1
\v 25 A i hana oe i kuahu pohaku, ea, mai hana oe i pohaku i kalaiia; no ka mea, ina e kau oe i kou koilipi maluna iho, ua haumia ia ia oe.   
\q1
\v 26 Mai pii oe maluna o ko'u kuahu ma ke ala hanuu, o ikea aku kou wahi huna malaila.   
\c 21  
\b  
\q1
\v 1 EIA na olelo kupaa au e kau ai imua o lakou.   
\q1
\v 2 Ina kuai oe nau i kauwa Hebera, e hookauwa mai no oia i eono makahiki; a i ka hiku hoi, o kuu wale ia'ku no oia.   
\q1
\v 3 Ina i komo mai oia iloko, o kona kino wale no, alaila, e hele aku no oia iwaho, o kona kino wale no: aka, ina i mareia oia, alaila e hele pu aku no kana wahine me ia.   
\q1
\v 4 Ina ua haawi mai kona haku i wahine nana, a ua hanau mai oia i mau keikikane nana, a i mau kaikamahine paha, alaila no ka haku ka wahine a me kana mau keiki. a e hele aku no ke kane, oia wale no.   
\q1
\v 5 Aka, ina olelo ikaika mai ke kauwa, Ua aloha au i kuu haku, a me kuu wahine, a me ka'u mau ken ki, aole au e hele kuu wale ia;   
\q1
\v 6 Alaila, e lawe mai kona haku ia ia i na lunakanawai; a lawe mai no hoi ia ia i ka puka, a i ka lapauwila o ka puka paha; a e hou iho koua haku i kona pepeiao i ke kui, a e hookauwa mau loa mai oia nana.   
\b  
\q1
\v 7 Ina e kuai lilo aku ke kanaka i kana kaikamahine i kauwawahine, aole ia e hookuuia aku e like me ke kuuia'na o na kauwakane.   
\q1
\v 8 Ina i hewa oia i na maka o kona haku, ka mea i hoopalau mai ia ia nana, alaila, o hoolapanai oia ia ia. Aole ia e hiki ke kuai aku ia ia i ko ka aina e, no kana hana ino ana ia ia.   
\q1
\v 9 A ina ua hoopalau oia ia ia na kana keikikane, e hana aku no oia ia ia e like me ka hana ana i na kaikamahine.   
\q1
\v 10 A ina i lawe oia i wahine hou nana, mai hoemi ia i ka ai a me ka aahu, a me ka launa mare o kela wahine.   
\q1
\v 11 A i ole ia e hana aku i keia mau mea ekolu ia ia, alaila, e hookuu wale ia aku oia, me ka uku ole ia mai i ke kala.   
\b  
\q1
\v 12 O ka mea pepehi i kanaka, a make ia, e oiaio no e pepehiia oia.   
\q1
\v 13 Ina hoohalua ole ke kanaka, a na ke Akua i haawi mai ia ia iloko o kona lima, alaila, na'u no e kuhikuhi aku ia oe i kahi nona e pee aku ai.   
\q1
\v 14 Aka, ina i hana hookiekie ke kanaka i kona hoalauna, e pepehi maalea ia ia, e lawe no oe ia ia mai ko'u kuahu aku, i make ia.   
\b  
\q1
\v 15 O ka mea hahau i kona makuakane, a i kona makuwahine, e oiaio no, e make ia.   
\b  
\q1
\v 16 O ka mea aihne i ke kanaka, a kuai lilo aku ia ia, a ina i loaa oia ma kona lima, e oiaio no, e make ia.   
\b  
\q1
\v 17 A o ka mea hailiili i kona makuakane, a me kona makuwahine, he oiaio no, e make ia.   
\b  
\q1
\v 18 A ina hakaka na kanaka, a pehi aku kekahi i kona hoa i ka pohaku, a kui aku i ka lima, aole hoi ia i make, na moe nae ma kahi moe;   
\q1
\v 19 Ina ala hou oia a hele iwaho ma kona kookoo, alaila, e pakele no ka mea nana ia i pepehi; aka, e uku no oia, no kona booki ana i kana hana, a nana no hoi e hoola loa aku ia ia.   
\b  
\q1
\v 20 A ina e hahau ke kanaka i kana kauwakane, a i kana kauwawahine, i ka laau, a make ia malalo iho o kona lima, e oiaio no, e hoopaiia oia.   
\q1
\v 21 Aka, ina e ola oia i hookahi la paha, a i elua paha, alaila, aole ia e hooukuia: no ka mea, oia kana kala.   
\b  
\q1
\v 22 Ina hakaka na kanaka, a hooeha i ka wahine hapai keiki, a hemo aku la kana keiki, aole hoi he hewa mahope; e oiaio no e hooukuia oia e like me ka mea e kauia maluna ona e ke kane a ka wahine; a e haawi no oia imua o na lunakanawai.   
\q1
\v 23 Aka, ina he hewa mahope, alaila, e haawi no oe i ke ola no ke ola,   
\q1
\v 24 I ka maka no ka maka, i ka lima no ka lima, i ka wawae no ka wawae.   
\q1
\v 25 I ke kuni ana no ke kuni ana, i ka palapu no ka palapu, i ka paopao ana no ka paopao ana.   
\b  
\q1
\v 26 A ina e hahau ke kanaka i ka maka o kana kauwakane, a i ka maka o kana kauwawahine, a oki loa ia, alaila, e hookuu wale iho oia ia ia, no kona maka.   
\q1
\v 27 A ina kui oia i ka niho o kana kauwakane, a i ka niho o kana kauwawahine, alaila, e hookuu wale iho oia ia ia, no kona niho.   
\b  
\q1
\v 28 Ina e o iho ka bipi i ke kanaka, a i ka wahine, a make laua; alaila, e oiaio no e hailukuia ua bipi la, aole hoi e aiia kona io, a e hala ole ke kahu o ka bipi.   
\q1
\v 29 Aka, ina i o oia mamua, a na haiia i kona kahu, aole nae ia i hoopaa ia ia, a ua pepehi oia i ke kanaka, a i ka wahine paha, alaila, e hailukuia ua bipi la, a e make no hoi kona kahu.   
\q1
\v 30 Aka, ina o hooukuia oia i ke kala, alaila, e haawi no oia i ka uku no kona ola, e like me ka mea i kauia maluna ona.   
\q1
\v 31 Ina i o oia i ke keikikane, a ina i o oia i ke kaikamahine paha, e hanaia aku no oia e like me keia kanawai.   
\q1
\v 32 Ina e o iho ka bipi i ke kauwakane, a i ke kauwawahine paha, alaila, e uku aku oia i kanakolu sekela kala na ko laua haku, a e hailukuia ua bipi la.   
\b  
\q1
\v 33 A ina wehe ke kanaka i lua, a ina eli ke kanaka i lua, aole hoi e uhi, a i haule ka bipi maloko, a he hoki paha;   
\q1
\v 34 Alaila, e uku ka mea nana ka lua, a e haawi hoi i kala na ke kahu o laua; a e lilo ka mea make nana.   
\b  
\q1
\v 35 A ina hooeha ka bipi a ke kahi kanaka i ka kekahi, a make ia, alaila, e kuai lilo aku laua i ka bipi ola, a e puunaue i ke kala, a e puunaue no hoi laua i ka bipi i make.   
\q1
\v 36 Aka, ina i ikeia ua o no ia bipi mamua, aole nae i hoopaa kona kahu ia ia, alaila, e oiaio no e uku aku no ia i bipi no ka bipi, a e lilo no ka bipi make nana.   
\c 22  
\b  
\q1
\v 1 I NA e aihue ke kanaka i ka bipi a i hi pa paha, a kalua, a kuai lilo aku paha, alaila, e haawi aku oia i elima bipi no ka bipi, a i eha hipa no ka hipa.   
\b  
\q1
\v 2 Ina e loaa ka aihue e wawahi ana, a ina i pepehiia oia a make, aole e pili kona koko.   
\q1
\v 3 Aka, ina i puka mai ka la maluna ona, alaila, ua pili no kona koko. Ua pono no ia ia ke uku pau loa mai, a ina i nele oia, alaila, ua pono ke kuaiia oia no kona aihue ana.   
\q1
\v 4 Ina i loaa maopopo ma kona lima ka mea i aihueia e ola ana, ina he bipi, a ina he hoki a ina he hipa paha, e haawi aku no oia i papalua.   
\b  
\q1
\v 5 Ina e hoopau ke kanaka i ko ka mala, a i ko ka pawaina, a hookomo i kona holoholona iloko: a ai oia maloko o ka mala a hai, alaila e uku aku oia i kahi maikai o kana mala iho, a me kahi maikai o kaua pawaina.   
\b  
\q1
\v 6 A ina holo aku ke ahi, a loaa na kakalaioa, a aiia na puu huapalaoa, a o ka hua palaoa e ku ana paha, a o ko ka mala paha, alaila, e oiaio no e uku aku ka mea nana i kuni i ke ahi.   
\b  
\q1
\v 7 Ina haawi ke kanaka i wahi kala na kona hoalauna e malama, a i waiwai e paha, a ua aihueia mai kona hale aku, ina e loaa ka mea nana i aihue, e uku papalua aku oia.   
\q1
\v 8 Ina aole i loaa ka mea nana i aihue, alaila, e laweia mai ka hakuhale i na lunakanawai, ina paha ua kau aku oia i kona lima maluna o ka waiwai o kona hoalauna.   
\q1
\v 9 O na hewa no kela mea keia mea, no ka bipi, no ka hoki, no ka hipa, no ka aahu, no na mea nalowale a pau a kekahi e olelo ai, nana ia, e laweia ko laua pono imua o na lunakanawai, a o ka mea a na lunakanawai e hoohewa ai, e uku papalua aku oia i kona hoalauna.   
\b  
\q1
\v 10 Ina haawi ke kanaka i hoki na kona hoalauna e malama, a i bipi paha, a i hipa, a i kekahi holoholona e ae nana, a i make ia, a eha, a hooholoia ma kahi e paha, aole mea i ike aku;   
\q1
\v 11 Alaila, mawaena o laua ka hoohiki ana ia Iehova, aole oia i kau i kona lima maluna o ka waiwai o kona hoalauna; a e ae aka no ka mea nana ka waiwai, aole kela e uku.   
\q1
\v 12 Aka, ina i aihueia'ku ia mea, mai ona aka, e uka aku no oia i ka mea nana ka waiwai.   
\q1
\v 13 Ina e haehaeia oia, alaila, e lawe mai kela i ke kino, i mea koike, aole hoi oia e uku no ka mea i haehaeia.   
\b  
\q1
\v 14 A ina nonoi ke kanaka i kekahi mea a kona hoalauna, a eha ia mea, a make paha, aole e noho pu ana ka mea nana ia, alaila, e oiaio no e uku oia.   
\q1
\v 15 Aka ina e noho pu ana ka mea nana ka waiwai, alaila, aole oia e uku mai. Ina he mea hoolimalima, ua loaa ia no ka uku.   
\b  
\q1
\v 16 Ina e pue ke kanaka i ke kaikamahine i noopalau ole ia, a moe pu me ia, e oiaio no e kuai no oia ia ia i wahine nana.   
\q1
\v 17 Ina hoole loa kona makuakane aole e haawi ia ia nana, e kaupauna aku oia i kala e like me ke kuai ana i na wahinepuupaa.   
\b  
\q1
\v 18 Mai hoola i ke kupua.   
\b  
\q1
\v 19 O ka mea moe pu me ka holoholona, e oiaio no e make ia.   
\b  
\q1
\v 20 O ka mea mohai aku na kekahi akua e, aole na Iehova, e luku loa ia'ku la ia.   
\b  
\q1
\v 21 Mai hookaumaha oe i ka malihini, aole hoi e hooluhi ia ia, no ka mea, he poe malihini oukou ma ka aina o Aignpita.   
\b  
\q1
\v 22 Mai hookaumaha oe i ka wahinekanemake, a me ke keiki makun ole.   
\q1
\v 23 Ina hookaumaha iki oe in lakou, a uwe uuku mai lakou ia'u, e oiaio no e hoolohe au i ko lakou uwe ana:   
\q1
\v 24 A e wela auanei ko'u huhu, a e pepehi aku au ia oukou i ka pahikaua, a e lilo no ka oukou wahine i wahinekanemake a me ka oukou kamalii i kamalii makua ole.   
\b  
\q1
\v 25 Ina haawi aie aku oe i ke kala no ko'u poe kanaka i hune e noho pu ana me oe, mai lilo oe ia ia i mea hoouku kuala, mai kau hoi oe i ka uku hoopanee maluna ona.   
\q1
\v 26 Ina lawe iki oe i ka aahu o kou hoalauna i ukupanai, e haawi hou aku no oe ia ia ia i ka wa e napoo ai ka la ilalo:   
\q1
\v 27 No ka mea, oia kona mea e uhi ai, o kona aahu no kona ili. Maloko o ke aba oia e moe ai? A hiki i ka manawa e uwe mai ai oia ia'u e hoolohe no wau, no ka mea, ua lokomaikai no au.   
\b  
\q1
\v 28 Mai olelo hoino oe i na lunakanawai, aole hoi e olelo hoino i ka mea e noho alii ana maluna o ko'u poe kanaka.   
\b  
\q1
\v 29 Mai aua oe i kau ai i oo mua, a me kou waina mua, E haawi mai no oe i kau hiapo, o kau mau keikikane na'u.   
\q1
\v 30 Pela no oe e hana'i me kau mau bipi a me kau poe hipa; ehiku la e noho ai me kona makuwahine, a i ka walu o ka la, e haawi mai oe ia mea ia'u.   
\b  
\q1
\v 31 A e lilo auanei oukou i poe kanaka hoano no'u, aole hoi oukou e ai i ka io i haehaeia e na holoholona ma ke kula, e kiola aku oukou ia na na ilio.   
\c 23  
\b  
\q1
\v 1 MAI hoala oe i ka olelo wahahee. Mai kau pu i kou lima me ka poe hewa e lilo i mea hoike hookaumaha.   
\b  
\q1
\v 2 Mai hahai mamuli o ka lehulehu e hana hewa, mai paue aku hoi ma ke ku e mamuli o ka lehulehu, e hoohewa wale.   
\b  
\q1
\v 3 Mai kokua oe mamuli o ka ilihune i kona hewa ana.   
\b  
\q1
\v 4 Ina halawai oe me ka bipi a kou hoalauna e hele hewa ana, me kona hoki paha, e oiaio no e hoihoi mai oe ia mea io na la.   
\q1
\v 5 Ina ike oe i ka hoki a ka mea i huhu mai ia oe, o moe ana malalo iho o kona kaumaha, a manao oe aole kokua ia ia, alaila, e kokua aku no oe ia ia.   
\q1
\v 6 Mai hookahuli oe i ka pono o ke kanaka hune i kona hookolokolo ana.   
\q1
\v 7 E mamao aku oe i ka mea wahahee; a mai pepehi oe i ka mea i hewa ole, a me ka mea i pono: no ka mea, aole au e hoapono aku i ka mea i hewa.   
\b  
\q1
\v 8 Mai lawe oe i ka waiwai kipe: no ka mea, o ka waiwai kipe ka mea e makapo ai ka poe ike, a e kekee ai na olelo a ka poe pono.   
\b  
\q1
\v 9 Mai hookaumaha oe i ka malihini, no ka mea, ua ike no oukou i ka manao o ka malihini, no ko oukou noho malihini ana ma ka aina o Aigupita.   
\b  
\q1
\v 10 E lulu oe i kou aina i eono mau makahiki, a e hoiliili hoi i kona hua.   
\q1
\v 11 Aka i ka hiku o ka makahiki e hoomaha oe i ka aina, e waiho wale hoi; i ai iho ka poe hune o kou poe kanaka; a o ka mea a lakou e hookoe ai, na na holoholona o ke kula ia e ai. Pela no oe e hana'i i kon pawaina, a me kon laau oliva.   
\b  
\q1
\v 12 I na la eono e hana'i oe i kau hana, a e hoomaha hoi i ka la hiku; i hoomaha ai kau bipi a me kou hoki, i hoohoihoiia hoi ke koikikane a kau kauwa wahine, a me ka malihini.   
\q1
\v 13 Ma na mea a pau au i olelo ai ia oukou e malama ia oukou iho; mai hai iki i ka inoa o na'kna e, aole hoi e loheia ia ma kon waha.   
\b  
\q1
\v 14 E malama oe i ekolu ahaaina no u i ka makahiki.   
\q1
\v 15 E malama oe i ka ahaaina o ka berena huole: Ehikn la oe e ai ai i ka berena huole, me a'u i kanoha aka ai ia oe, i ka manawa i haawiia, ma ka malama o Abiba; no ka mea, ia wa oe i hele mai ai mailoko mai o Aigupita: Mai ikeia nae kekahi imua o'u me ka waiwai ole:   
\q1
\v 16 A me ka ahaaina o ka ohi mua ana, o na hua mua hoi o kau hooikaika ana, ka mea au i lulu ai ma ke kola, a me ka ahaaina o ka hoiliili ai ana, oia hoi ka hope o ka makahiki, i kou wa e hoiliili ai mailoko mai o ke kula, i kau mea i hooikaika ai.   
\q1
\v 17 E ikeia no ko oukou poe kane a pau imua o Iehova ke Akua, i ekolu no ikea ana i ka makahiki hookahi.   
\b  
\q1
\v 18 Mai kaumaha aku oe i ke koko o ko'u mohai, me ka berena hu, aole hoi e hookoeia ke kelekele o ka'u ahaaina a kakahiaka.   
\q1
\v 19 E lawe mai no oe iloko o ka hale o Iehova, kou Akua, i ka mua o na hua mua o kou aina. Mai hoolapalapa oe i ke kaokeiki malokool ka waiu o kona makuwahine.   
\b  
\q1
\v 20 Aia hoi, e hoouna aku ana au i ko'u Anela mamua on, e malama ia oe ma ke ala, a e hookomo ia oe i kahi a'u i hoomakaukau ai.   
\q1
\v 21 E ao ia ia e hoolohe i kona leo, mai hoohuhu aku ia ia; no ka mea, aole ia e kala mai i kon hewa: aia hoi, maloko ona ko'u inoa.   
\q1
\v 22 Aka, ina hoolohe io mai oe i kona leo, a e hana hoi i na mea a'u e olelo aku ai: alaila, e lilo wau i enemi no kou poe enemi, a e hana ino aku au i ka mea e hana ino mai ia oe.   
\q1
\v 23 No ka mea, e hele ana ko'u Anela mamua on, a e kai aku ia oe i kahi o ka Amora a me ka Heta a me ka Pereza, a me ko Kanaana, a me ka Heva a me ka Iebusa, a na'u no lakou e anai aku.   
\q1
\v 24 Mai kulou oe i ko lakou akua, aole hoi e malama aku ia lakou, aole hoi e hana aku mamuli o ka lakou hana: aka, e hookahuli loa oe ia lakou, a e wawahi loa i ko lakou mau kii.   
\q1
\v 25 E malama hoi oukou ia Iehova i ko oukou Akua; alaila, nana no e hoomaikai i kau ai, a me kon wai; a e lawe aku no hoi i ka mai, mailoko aku ou.   
\b  
\q1
\v 26 Aole loa e poholo wale ka hanau ana o kekahi mea ma kon aina, aole hoi e pa; e hooko no wau i kou mau la.   
\q1
\v 27 Na'u no e haawi i ka makau mamna on, a na'u no e luku aku i na kanaka a pau, ma kahi au e hele aku ai, a na'u no e hana aku i kou poe enemi, i huli ai ko lakou kua ia oe.   
\q1
\v 28 A na'u no e hoouna aku i nalohopeeha mamna ou, na lakou no e kipaku aku i ka Heva, a me ko Kanaana, a me ka Heta, mamua ou,   
\q1
\v 29 Aole nae au e kipaku aku ia lakou mamua on i ka makahiki hookahi; o nahelehele ka aina, a nui loa iho na holoholona hihiu e alo mai ia oe.   
\q1
\v 30 E kipaku liill aku au ia lakou mai kou alo aku, a lilo oe i nui, a ill mai ka aina nou.   
\q1
\v 31 A na'u no e kau i kon palena mai ke Kaiula, a hiki i ke kai o Pilisetia, a mai ka waonahele hoi a hiki i ka muliwai; no ka mea, e haawi aku ana au i na kanaka o ia aina i ko oukou lima; a e kipaku aku oe ia lakou mai kou alo aku.   
\q1
\v 32 Mai hoopaa berita me lakou, aole hoi me ko lakou mau akua.   
\q1
\v 33 Aole lakou e noho i kou aina, o hoolilo lakou ia oe i mea hana hewa mai ia'u; no ka mea, ina e malama oe i ko lakou mau akua, e lilo auanei ia i mea hoowalewale nou.   
\c 24  
\b  
\q1
\v 1 I MAI la oia ia Mose, E pii mai oe io Iehova nei, o oe, a me Aarona, a me Nadaba, a me Abihu, a me na lunakahiko o ka Iseraela he kanahiku; a e hoomana oukou ma kahi mamao aku.   
\q1
\v 2 A o Mose wale no ka mea hele mai a kokoke io Iehova nei: aka, o lakou aole hele mai a kokoke; aole hoi e pii pu na kanaka me ia.   
\b  
\q1
\v 3 Hoi ae la o Mose, a hai aku la i kanaka i na olelo a pau a Iehova, a me na kanawai a pau; hooho mai la na kanaka a pau me ka leo kahi, i mai la, O na olelo a pau a Iehova i olelo mai ai, e hana no makou.   
\q1
\v 4 A kahakaha iho la o Mose i na olelo a pau a Iehova, a ala'e la i kakahiaka nui, a kukulu iho la i kuahu malalo o ka mauna, a me na kia he umikumamalua, e like me na ohana he umikumamalua o ka Iseraela.   
\q1
\v 5 A hoouna ae la ia i mau kanaka ui o na mamo a Iseraela, na lakou i mohai aku i na mahaikuni, no Iehova, a kaumaha aku no hoi lakou i mau bipi kane i mohai hoomalu.   
\q1
\v 6 A lawe iho la o Mose i ka hapalua o ke koko, a waiho aku la maloko o na kiaha, a kapipi iho la ia i kekahi hapalua o ke koko maluna o ke kuahu.   
\q1
\v 7 A lawe iho la ia i ka buke o ka berita, a heluhelu ma na pepeiao o na kanaka. Olelo aku la lakou, E hana no makou i na mea a pau a Iehova i olelo mai ai, a e hoolohe no.   
\q1
\v 8 A lawe ae la o Mose i ke koko, a kapipi iho la maluna o na kanaka, olelo mai la, Aia hoi ke koko o ka berita a Iehova i hana mai ai me oukou no keia mau olelo a pau.   
\b  
\q1
\v 9 Alaila, pii aku la o Mose, a me Aarona, a me Nadaba, a me Abihu, a me na lunakahiko o ka Iseraela.   
\q1
\v 10 A ike aku la lakou i ke Akua o ka Iseraela, a malalo iho o kona mau wawae he mea me he sapeiro ka aiai, e like hoi me ke kino o na lani ke kalae.   
\q1
\v 11 Aole ia i kau mai i kona lima maluna o na luna o na mamo o ka Iseraela. A ike no lakou i ke Akua, a ai no, a inu no hoi.   
\b  
\q1
\v 12 Olelo mai la o Iehova ia Mose, E hele mai oe io'u nei i ka mauna, a e noho malaila; a e haawi aku au ia oe i pohaku papa, me ke kanawai, a me na kauoha a'u i palapala ai, i ao aku oe ia mea.   
\q1
\v 13 Ku ae la o Mose iluna, a me kana kauwa o Iosua: a pii aku la o Mose i ka mauna o ke Akua.   
\q1
\v 14 Olelo iho la ia i na lunakahiko, E kakali oukou no maua, a hoi mai maua ia oukou: aia hoi, me oukou o Aarona haua me Hura; a o ka mea loaa kahi pilikia, e hele ae ia io laua la.   
\q1
\v 15 Pii aku la o Mose i ka mauna, a uhi mai la ka ohu i ka mauna.   
\q1
\v 16 Puwa mai la ka nani a Iehova maluna o ka mauna i Sinai, a uhi mai la ka ohu maluna iho i na la eono; a i ka hiku o ka la hea mai la oia ia Mose, maloko mai o ka ohu.   
\q1
\v 17 I na maka o na mamo a Iseraela, i ka nana ana i ka nani o Iehova, ua like ia me ke ahi e ai ana ma ke poo o ka mauna.   
\q1
\v 18 Hele aku la o Mose iloko pono o ka ohu, a pii aku la i ka mauna, a malaila no o Mose ma ka mauna hookahi kanaha ao, hookahi kanaha po.   
\c 25  
\b  
\q1
\v 1 OLELO mai o Iehova ia Mose, i mai la,   
\q1
\v 2 E i aku oe i na mamo a Iseraela, e lawe mai lakou i mohaimakana na'u. E lawe no oukou na'u i ka mohaimakana o kela kanaka keia kanaka i haawi oluolu mai me kona naau.   
\q1
\v 3 Eia hoi ka mohaimakana a oukou e lawe ai no lakou mai, he gula, he kala, he keleawe,   
\q1
\v 4 He lole uliuli, a me ka poni, a me ka ulaula, a me ka lole olona keokeo, a me ka hulu kao,   
\q1
\v 5 A me na ili hipakane i hooluu ulaula ia, a me na ili tehasa, a me ka laau sitima,   
\q1
\v 6 I aila hoi i mea malamalama, a me na hua ala, i mea aila poni, a i mea ala maikai,   
\q1
\v 7 A me na pohaku saredonuka, i mea e hoonohonoho ai iloko o ka epoda, a iloko o ka paleumauma.   
\q1
\v 8 A e hana hoi lakou i keenakapu no'u, i noho ai au iwaena o lakou.   
\q1
\v 9 E like me na mea a pau a'u e hoike aku ai ia oe, o ke kumu hoohalike o ke keenakapu, a me ke kumu hoohalike o kona mau mea e pili ana, pela no oe e hana'i.   
\b  
\q1
\v 10 A e hana no lakou i pahu laau sitima, i elua kubita a me ka hapalua kona loihi, i hookahi kubita a me ka hapalua kona laula, a hookahi kubita a me ka hapalua kona kiekie.   
\q1
\v 11 A e uhi no hoi oe ia me ke gula maikai, maloko, a mawaho oe e uhi ai ia, a e hana no hoi oe maluna i lei gula a puni ia mea.   
\q1
\v 12 A e hoohehee oe i eha apo gula nona, a e hookomo ma na kihi eha o ka pahu, i elua apo ma kekahi aoao ona, a i elua apo ma kekahi aoao ona.   
\q1
\v 13 A e hana oe i mau auamo laau sitima, a e uhi ia mau mea i ke gula.   
\q1
\v 14 A e hookomo oe i na auamo maloko o na apo ma na aoao o ka pahu, i laweia ka pahu ma ia mau mea.   
\q1
\v 15 E paa no na auamo maloko o na apo o ka pahu, aole laua e laweia mai ka pahu aku.   
\q1
\v 16 A e waiho oe iloko o ka pahu i na papa kanawai a'u e haawi aku ai ia oe.   
\b  
\q1
\v 17 A e hana oe i nohoaloha, he gula maikai: i elua kubita a me ka hapalua kona loa, i hookahi kubita a me ka hapalua kona laula.   
\q1
\v 18 E hana no hoi oe i elua kerubima gula, e hana oe ia mau mea i gula paa wale no, ma na welau o ka nohoaloha.   
\q1
\v 19 E hana oe i kekahi kerubima ma kekahi welau, a i kekahi kerubima ma kela welau, ma ka nohoaloha kau e hana'i ia mau kerubima, ma kona mau welau elua.   
\q1
\v 20 A e hohola aku na kerubima i na eheu maluna, e uhi ana i ka nohoaloha i ko lakou mau eheu: a e ku pono no na maka o laua kekahi i kekahi E kau no ko laua mau maka ma ka nohoaloha.   
\q1
\v 21 A e kau no oe i ka nohoaloha maluna ma ka pahu; a maloko o ka pahu oe e waiho ai i na pahu kanawai a'u e haawi aku ai ia oe.   
\q1
\v 22 A malaila wau e halawai ai me oe, a e kamailio pu no hoi au me oe, mailuna iho o ka nohoaloha, a mawaena aku hoi o na kerubima maluna o ka pahu hoike, no na mea a pau a'u e kauoha aku ai i na mamo a Iseraela.   
\b  
\q1
\v 23 E hana no hoi oe i papaaina laau sitima: i elua kubita kona loihi, a i hookahi kubita kona laula, a i hookahi kubita a me ka hapalua kona kiekie.   
\q1
\v 24 A e uhi oe ia mea i ke gula maikai, a e hana hoi oe i lei gula a puni ia mea.   
\q1
\v 25 A e hana oe i kae a puni ia mea, i hookahi lima ka laula, a e hana no hoi oe i lei gula ma ua kae la a puni.   
\q1
\v 26 A e hana no hoi oe i eha apo gula no ua papaaina la, a e hookomo i ua mau apo la ma na kiki eha maluna o kona mau wawae.   
\q1
\v 27 E ku pono no na apo i na kae, i wahi e hookomo ai i na auamo e lawe ai i ua papaaina la.   
\q1
\v 28 A e hana oe i ua mau auamo la, he laau sitima, a e uhi ia mea i ke gula, i laweia ka papaaina maluna o laua.   
\q1
\v 29 A e hana oe i kona mau kiaha, a me kona mau puna, a me kona mau poi, a me kona mau ipu i mea ninini mohai E hana oe ia mau mea, he gula maikai.   
\q1
\v 30 E kau no hoi maluna o ka papaaina i berena hoike mau loa imua o'u.   
\b  
\q1
\v 31 A e hana no hoi i ipu kukui manamana he gula maikai, e hanaia ua ipukukui la a poepoe. O kona kumu, o kona mau lala, a me kona mau ipu, a me kona mau puupuu, a me kona mau pua, o ia apana hookahi no.   
\q1
\v 32 E puka mai no na lala eono ma na aoao ona; ekolu lala o ka ipukukui mailoko mai o kekahi aoao, a ekolu lala o ka ipukukui, mailoko mai o kekahi aoao.   
\q1
\v 33 Ekolu no ipu e like me na alemona, me ka puupuu a me ka pua, ma ka lala hookahi; a ekolu no ipu e like me na alemona, me ka puupuu a me ka pua, a pela ma na lala eono i puka mai, mailoko mai o ka ipukukui.   
\q1
\v 34 A ma ke kumuipukukui, eha no ipu e like me na alemona, me ko lakou mau puu a me ko lakou mau pua.   
\q1
\v 35 He puu malalo iho o kona mau lala elua, a he puu malalo iho o kona mau lala elua, a he puu malalo iho o kona mau lala elua, e like me na lala eono e puka mai ana mailoko mai o ua ipukukui la.   
\q1
\v 36 E hana hookahi ia na puu a me na lala, o kona mau mea a pau, he gula paa wale no.   
\q1
\v 37 A e hana no hoi oe i kona mau ipu aila ehiku, a e kau oia ia mau mea maluna, i hoomalamalama aku ai lakou ma kona alo.   
\q1
\v 38 A o kona upaahi a me kona upakolikukui, he gula maikai.   
\q1
\v 39 E hana no oia ia mea, a me kona mau mea hana, hookahi talena gula maikai.   
\q1
\v 40 E malama hoi oe e hana e like me ke kumu hoohalike i hoikeia ia oe ma ka mauna.   
\c 26  
\b  
\q1
\v 1 E HANA no oe i ka halelewa me na pale he umi, he olona i hiloia, he uliuli, he poni a me ka ulaula; he mau kerubima kekahi, o ka hana a ka poe akamai;   
\q1
\v 2 He iwakaluakumamawalu kubita ka loa o kekahi pale, a o ka laula o kekahi pale, eha no kubita. Hookahi no ana o na pale a pau.   
\q1
\v 3 E huiia na pale elima, o kekahi me kekahi, a e huiia na pale elima, o kekahi me kekahi.   
\q1
\v 4 A e hana oe i mau puka lou lole uliuli ma ke kihi o kekahi pale, ma ke kae kahi o ka hui ana, a e hana no hoi oe pela ma ke kihi loa o kekahi pale, ma ke kihi e hui ai me ka lua.   
\q1
\v 5 E hana oe i kanalima puka lou ma ka pale hookahi, a e hana hoi i kanalima puka lou ma ke kihi o ka pale, ma ka hui ana o ka lua, i lou ae kekahi puka lou i kekahi puka lou.   
\q1
\v 6 E hana no hoi oe i kanalima lou gula, a e hui i na pale me ua mau lou la. A e lilo i halelewa hookahi.   
\b  
\q1
\v 7 A e hana oe i mau pale hulu kao i mea uhi maluna o ka halelewa. I umikumamakahi pale kau e hana'i.   
\q1
\v 8 He kanakolu kubita ka loihi o kekahi pale, a i eha kubita ka laula o kekahi pale. E like no ke ana o ua mau pale la, he umikumamakahi.   
\q1
\v 9 A e hui oe i elima mau pale, i kaawale lakou, a e hui i eono mau pale, i kaawale lakou, a e pelu ae i ke ono o ka pale ma ke alo o ka halelewa.   
\q1
\v 10 A e hana oe i kanalima puka lou ma ke kihi o kekahi pale mawaho, ma ka hui ana, a i Kanalima puka lou ma ke kihi o ka pale i hui me ka lua.   
\q1
\v 11 A e hana oe i kanalima lou keleawe, a e hookomo i ua mau lou la iloko o na puka lou, a e hui i ua uhi la, i lilo ai i hookahi.   
\q1
\v 12 A o ka puehu ka mea i puehu aku o na pale o ua uhi la, a ka hapalua o ka pale puehu, e kau no ia ma ke kua o ka halelewa.   
\q1
\v 13 A o ke kubita ma kekahi aoao, a o ke kubita ma kela aoao, ka mea i puehu o ka loihi o na pale o ka hale, e kaulai no ia ma na aoao o ka halelewa, ma kela aoao, a ma keia aoao, i mea uhi nona.   
\q1
\v 14 E hana no hoi oe i uhi no ka hale he mau ili hipa kane i hooluu ulaula ia, a maluna aku i uhi hou, he mau ili tehasa.   
\b  
\q1
\v 15 A e hana oe i mau papa laau sitima no ka halelewa, i mea ku iluna.   
\q1
\v 16 He umi kubita ka loihi o kekahi papa, a he kubita a me ka hapalua ka laula o kekahi papa.   
\q1
\v 17 Elua komo ma ka papa hookahi, e ku pono kekahi i kekahi. Pela no oe e hana'i ma na papa a pau o ka halelewa.   
\q1
\v 18 A e hana no hoi oe i na papa o ka halelewa, i iwakalua papa ma ka aoao hema, ma ke kukulu hema hoi.   
\q1
\v 19 A e hana no hoi oe i hookahi kanaha kumu kala, malalo iho o na papa he iwakalua, i elua kumu maloko iho o ka papa hookahi, no kona mau komo elua, a i elua kumu malalo iho o kekahi papa no kona mau komo elua.   
\q1
\v 20 A no ka lua o ka aoao o ka halelewa ma ke kukulu akau, he iwakalua no papa:   
\q1
\v 21 A me ko lakou mau kumu kala, he kanaha, elua kumu malalo iho o kekahi papa, a elua kumu malalo iho o kekahi papa.   
\q1
\v 22 A no na aoao o ka halelewa ma ke komohana, e hana no oe i eono papa.   
\q1
\v 23 A e hana no hoi oe i elua papa no na kihi o ka halelewa, ma na aoao elua.   
\q1
\v 24 E huiia no ia mau mea malalo, a e huiia no hoi maluna, ma ke poo, a iloko o ke apo hookahi; pela no laua a elua, a no na kihi elua o laua.   
\q1
\v 25 Ewalu no ia mau papa, a me ko lakou mau kumu kala, he umikumamaono kumu, elua no kumu malalo o kekahi papa, a elua no kumu malalo o kekahi papa.   
\b  
\q1
\v 26 A e hana no hoi oe i mau laau ki, he sitima ka laau, i elima ki no na papa ma kekahi aoao o ka halelewa,   
\q1
\v 27 A i elima ki no na papa ma kekahi aoao o ka halelewa, a i elima ki hoi no na papa o na aoao o ka halelewa, no na aoao elua hoi ma ke komohana.   
\q1
\v 28 A o ke ki waena, mawaena konu o na papa, e holo no ia, mai kekahi kala a i kekahi kala.   
\q1
\v 29 E uhi no hoi oe i na papa i ke gula, a e hana no hoi oe i ko lakou mau apo, he gula, i wahi no na ki, a e uhi no noi oe i na ki i ke gula.   
\q1
\v 30 A e kukulu oe i ka halelewa me ke kumu hoohalike i hoikeia aku ai ia oe ma ka mauna.   
\b  
\q1
\v 31 A e hana hoi oe i paku, he uliuli a me ka poni a me ka ulaula, a me ke olona i hiloia, o ka hana a ka poe akamai: e hanaia hoi ia me na kerubima.   
\q1
\v 32 A e kaulai no hoi ia ma na kia laau sitima eha, i uhiia i ke gula; he gula no ko lakou mau lou, maluna o na kumu kala eha.   
\b  
\q1
\v 33 A e kaulai oe i ka paku malalo iho o na lou i lawe mai ai oe i ka pahu hoike malalo o ka paku; a na ka paku e hookaawale no oukou mawaena o kahi hoano, a me kahi hoano loa.   
\q1
\v 34 A e kau no oe i ka noho aloha maluna ma ka pahu hoike, maloko o kahi hoano loa.   
\q1
\v 35 E hoonoho oe i ka papaaina mawaho o ka paku, a e kau oe i ka ipukukui manamana ma ke alo o ka papaaina ma ka aoao o ka halelewa ma ke kukulu hema. A e hoonoho oe i ka papaaina ma ka aoao akau.   
\b  
\q1
\v 36 A e hana no hoi oe i pale no ka puka komo o ka halelewa, he uliuli, he poni, he ulaula, a me ke olona i hiloia, i hanaia e ka mea humuhumu lopi ano e.   
\q1
\v 37 E hana hoi oe i elima kia laau sitima no na pale, a e uhi ia mau mea i ke gula, a he gula hoi ko lakou mau lou; a e hoohehee i elima kumu keleawe no lakou.   
\c 27  
\b  
\q1
\v 1 E HANA oe i kuahu, he laau sitima, elima kubita ka loihi, elima hoi kubita ka lanla: eha no aoao o ke kuahu, a ekolu kubita kona kiekie.   
\q1
\v 2 A e hana oe i mau pepeiao ma kona mau kihi eha, no ia laau hookahi, a e uhi ia mau mea i ke keleawe.   
\q1
\v 3 E hana oe i kona mau ipu, i mea e lawe aku ai i kona lehu, a me kona mau mea hao lanahu, a me kona mau kiaha, a me kona lou io, a me kona mau ipu ahi, o kona mau oihana a pau, he keleawe.   
\q1
\v 4 E hana no hoi oe i papa manamana, pukapuka keleawe, a ma ia mea e hana oe i eha mau apo keleawe ma kona mau kihi eha.   
\q1
\v 5 A e waiho hoi ia mea malalo iho o ke kae o ke kuahu, i mau ai ua mea pukapuka la mawaena konu o ke kuahu.   
\q1
\v 6 E hana no hoi oe i mau auamo no ke kuahu, i mau auamo laau sitima, e uhi ia mau mea i ke keleawe.   
\q1
\v 7 A e hookomoia na auamo maloko o na apo, aia ma na aoao elua o ke kuahu, ua mau auamo la, e amo ai ia mea.   
\q1
\v 8 E hana oe ia mea me na papa, a kawaha mawaena; me ia i hoikeia'ku ai ia oe ma ka mauna, pela lakou e hana'i.   
\b  
\q1
\v 9 E hana no hoi oe i kahua no ka halelewa: no ka aoao akau, ma ke kukulu akau, i mau paku no ke kahua, he olona i hiloia, hookahi haneri kubita ka loihi no ka aoao hookahi:   
\q1
\v 10 A o kona mau pou, he iwakalua, me ko lakou mau kumu he iwakalua, o ke keleawe: o na lou o na kia, a me na auka e paa ai, he kala.   
\q1
\v 11 A no ka aoao akau hoi, ma ka loa, he mau paku, hookahi haneri kubita ka loihi, a me kona mau kia he iwakalua, a me ko lakou mau kumu he iwakalua: o na lou o na kia, a me ko lakou mau auka e paa ai, he kala.   
\b  
\q1
\v 12 A no ka laula o ke kahua ma ka aoao komohana, he mau paku no, he kanalima kubita ka loihi, he umi ko lakou mau kia, a he umi ko lakou mau kumu.   
\q1
\v 13 A o ka laula o ke kahua ma ka aoao hikina, ma ka hikina hoi, he kanalima ia mau kubita.   
\q1
\v 14 O na paku ma kekahi aoao, he umikumamalima kubita, ekolu o lakou mau kia, a me ko lakou mau kumu, ekolu no.   
\q1
\v 15 A ma kekahi aoao, he mau paku, he umikumamalima kubita, ekolu o lakou mau kia, a me ko lakou mau kumu, ekolu no.   
\b  
\q1
\v 16 A no ka puka o ke kahua, he paku, he iwakalua kubita ka loihi, he uliuli, he poni, he ulaula, a me ke olona i hiloia, i hanaia e ka mea humuhumu lopi ano e: eha ko lakou mau kia, a me ko lakou mau kumu eha.   
\q1
\v 17 O na kia a pau, a puni ke kahua, e hoopaaia lakou i na auka kala: a o ko lakou mau kumu he keleawe.   
\b  
\q1
\v 18 O ka loihi o ke kahua, hookahi haneri kubita, a o ka laula, he kanalima, mai o a o; a o ke kiekie, elima no kubita, he olona i hiloia, a o ko lakou mau kumu, he keleawe.   
\q1
\v 19 O na oihana a pau o ka halelewa, na mea e lawelawe ai a me kona mau makia a pau, a me na makia a pau o ke kahua, he keleawe.   
\b  
\q1
\v 20 E kauoha hoi oe i na mamo a Iseraela, e lawe mai lakou nou, i aila oliva maikai, i kuiia, no ka malamalama, i mea e aa mau ai ka ipukukui.   
\q1
\v 21 Ma ka halelewa o ka ahakanaka, mawaho o ka paku, imua o ka pahu kauawai, na Aarona a me kana mau keiki ia e hooponopono, mai ke ahiahi a kakahiaka imua o Iehova. He kanawai mau loa ia no ko lakou hanauna, no na mamo a Iseraela.   
\c 28  
\b  
\q1
\v 1 E LAWE oe iou la ia Aarona, i kou kaikuaana, a me kana mau keikikane pu me ia, mai waena mai o na mamo a Iseraela, i lawelawe oia na'u ma ka oihana a ke kahuna, o Aarona, o Nadaba, o Abihu, o Eleazara, a me Itamara, na keikikane a Aarona.   
\q1
\v 2 A e hana hoi oe i aahu laa no Aarona, no kou kaikuaana, i mea nani, a i mea maikai.   
\q1
\v 3 E olelo aku no hoi oe i ka poe a pau i akamai ma ka naau, ka poe a'u i hoopiha ai i ka manao akamai, e hana lakou i ko Aarona mau aahu, e hookapu ia ia, i lawelawe oia na'u, ma ka oihana a ke kahuna.   
\q1
\v 4 Eia na aahu a lakou e hana'i: he paleumauma, he epoda, he holoku, he palule onionio, he papale hainika, a me ke kaei. E hana no lakou i aahu kapu no Aarona, kou kaikuaana, a no kana mau keikikane, i lawelawe oia na'u ma ka oihana a ke kahuna.   
\q1
\v 5 A e lawe lakou i gula, a i lole uliuli, a i poni, a i ulaula, a i keokeo.   
\b  
\q1
\v 6 E hana lakou i ka epoda, he gula, a he lole uliuli, i poni, a ulaula, a he olona i hiloia, i humuhumuia e ka poe akamai.   
\q1
\v 7 E huiia kona mau apana poohiwi elua, ma kona mau kihi elua, a e pili no ia.   
\q1
\v 8 A o ke kaei o ka epoda maluna iho, hookahi no ano me ia, ma ka hana ana, he gula, he uliuli, he poni, a me ke olona i hiloia.   
\q1
\v 9 A e lawe hoi oe i elua pohaku onika, a e kahakaha maluna o laua i na inoa o na keiki a Iseraela.   
\q1
\v 10 Eono o lakou inoa ma kekahi pohaku, a o na inoa eono i koe, ma kekahi pohaku, e like me ko lakou hanau ana.   
\q1
\v 11 Me ka hana a ka mea kahakaha pohaku, o ke kahakaha ana o ka hoailona, pela oe e kahakaha ai i na pohaku elua, me na inoa o na keiki a Iseraela; e hana oe ia mau mea e kau maloko o na kawaha gula.   
\q1
\v 12 A e kau oe ia mau pohaku elua maluna o na poohiwi o ka epoda, i mau pohaku e hoomanao ai i na keiki a Iseraela; a e lawe no o Aarona i ko lakou inoa imua o Iehova, maluna o kona mau poohiwi elua, i mea e hoomanao ai.   
\b  
\q1
\v 13 E hana oe i mau kawaha gula:   
\q1
\v 14 A i elua kaula gula maikai ma na welau; e hana ia mau mea i mea e hookaawale ai, he kaula hilo, a e hoopaa i ua mau kaula la ma na kawaha.   
\b  
\q1
\v 15 A e hana oe i ka paleumauma o ka hooponopono ana; he hana na ka poe akamai, e like me ka hana ana i ka epoda, pela oe e hana'i: he gula, he uliuli, he poni, he ulaula, he olona i hiloia, pela oe e hana'i.   
\q1
\v 16 Eha ona mau aoao ahalike, a papalua hoi: hookahi kikoo kona loihi, a hookahi kikoo kona laula.   
\q1
\v 17 A e hoopiha oe ia mea, a piha i na pohaku, eha lalani pohaku: o ka lalani mua, he saredio, he topazo, he bareka, oia ka lalani mua.   
\q1
\v 18 A o ka lalani lua, he omaomao, he sapeiro, he daimana.   
\q1
\v 19 A o ka lalani kolu, he ligura, he agati, a he ametuseto.   
\q1
\v 20 A o ka lalani ha, he berulo, he onika, he iasepi: e hoopaaia ia mau mea iloko o ke gula, oia ko lakou mea e paa ai.   
\q1
\v 21 A ma ia mau pohaku no, na inoa o na keiki a Iseraela, he umikumamalua, e like me ko lakou inoa, me ke kahakaha ana o ka hoailona: o kela mea, keia mea ma kona inoa, e like me na ohana he umikumamalua.   
\b  
\q1
\v 22 A e hana oe ma ka paleumauma, i elua kaula ma na welau, he gula maikai i hiloia.   
\q1
\v 23 A e hana no hoi oe ma ka paleumauma, i elua apo gula, a e hookomo i na apo ma na welau elua o ka paleumauma.   
\q1
\v 24 A e hookomo oe i ua mau kaula hilo la elua, na kaula gula, iloko o na apo elua ma na welau o ka paleumauma.   
\q1
\v 25 A o kekahi mau welau elua o na kaula hilo elua, e hoopaa oe ia ma na kawaha, a e kau hoi maluna o na apana poohiwi elua o ka epoda, ma ke alo.   
\b  
\q1
\v 26 E hana no hoi oe i elua apo gula, a e hookomo oe ia i na welau elua o ka paleumauma, ma kona kae, ma ka aoao maloko o ka epoda.   
\q1
\v 27 A e hana oe i elua apo gula, a e hookomo ia ma na apana poohiwi elua o ka epoda malalo, ma ke alo hoi e ku pono ana i kona mau huina, maluna o ke kaei o ka epoda.   
\q1
\v 28 A e nakiki lakou i ka paleumauma ma kona mau apo a i na apo o ka epoda me ke kaula uliuli, i kau oia maluna o ke kaei o ka epoda, i hemo ole ai ka paleumauma, mai ka epoda aku.   
\q1
\v 29 A e lawe o Aarona i na inoa o na keiki a Iseraela ma ka paleumauma o ka hooponopono ma kona naau, i ka wa e hele aku ai ia i kahi kapu, i mea e hoomanao mau ai imua o Iehova.   
\b  
\q1
\v 30 A e kau oe iloko o ka paleumauma o ka hooponopono i ka Urima, a me ke Tumima, a e mau no laua ma ka naau o Aarona, ia ia e hele aku ai imua o Iehova. A lawe mau no o Aarona i ka hooponopono ana o na mamo a Iseraela, ma kona naau, imua o Iehova.   
\b  
\q1
\v 31 E hana oe i ka holoku o ka epoda, he uliuli wale no.   
\q1
\v 32 He puka no mawaenakonu ona maluna, a o ka pelupelu ana ma ke kae o ka puka, he mea i ulanaia, e like me ka puka o ka puliki koa nahae ole.   
\b  
\q1
\v 33 A ma kona mau lepa, e hana oe i mau pomeraite, he uliuli, he poni, he ulaula, a puni kona lepa, a he mau bele gula mawaena o lakou a puni:   
\q1
\v 34 He bele gula, a me ka pomeraite, a he bele gula, a me ka pomeraite, ma ka lepa o ka holoku a puni.   
\q1
\v 35 A maluna ia o Aarona e lawelawe ai; a e loheia kona kani ana, i kona wa e hele aku ai i kahi kapu, imua o Iehova, a i kona wa e puka aku ai iwaho, i ole ia e make.   
\b  
\q1
\v 36 E hana hoi oe i papa gula maikai, a e kahakaha hoi i ke kahakaha ana o ka hoailona, UA LAA NO IEHOVA.   
\q1
\v 37 A e hoopaa oe ia mea me ke kaula uliuli, i paa ia maluna o ka papale hainika, ma ke alo o ka papale ia e kau ai.   
\q1
\v 38 A e kauia ia mea ma ka lae o Aarona, i lawe o Aarona i ka hewa o na mea laa, na mea a na mamo a Iseraela e hoolaa ai, i ko lakou mau makana laa a pau: a e mau no ia ma kona lae, i aponoia'i lakou imua o Iehova.   
\b  
\q1
\v 39 E hoonionio oe i ka palule olona, a e hana oe i ka papale hainika, he olona; a e hana oe i ke kaei, he humuhumu onionio.   
\b  
\q1
\v 40 E hana no hoi oe i mau palule no na keikikane a Aarona, a e hana hoi i mau kaei no lakou; e hana no hoi i mau papale no lakou, i mea nani, a i mea maikai.   
\q1
\v 41 A e kau no oe ia mau mea maluna o Aarona o kou kaikuaana, a me kana mau keikikane pu me ia; a e poni oe ia lakou, a e hoolaa ia lakou, a e hookahuna ia lakou, i lawelawe lakou na'u ma ka oihana a ke kahuna.   
\q1
\v 42 E hana oe i wawae olona e uhi ai i ko lakou wahi huna; mai ka puhaka a i ka uha ka loihi:   
\q1
\v 43 Maluna o Aarona ia mea, a maluna o kana mau keikikane, ia lakou e hele mai ai iloko o ka halelewa o ka ahakanaka, a ia lakou e hookokoke mai ai i ke kuahu, e lawelawe ma kahi kapu, i kau ole ai ka hewa maluna o lakou a make. He kanawai mau loa ia nona, a no kana poe mama mahope ona.   
\c 29  
\b  
\q1
\v 1 EIA ka mea au e hana'i ia lakou, e hoolaa ia lakou, e lawelawe na'u ma ka oihana kahuna. E lawe oe i hookahi bipi opiopio, a i elua hipakane kina ole,   
\q1
\v 2 A i berena hu ole, a i mau popoberena hu ole i miko i ka aila, a me na papa hu ole i hamoia i ka aila: he palaoa o ka huita kau e hana'i ia mau mea.   
\q1
\v 3 A e uhao oe ia mau mea iloko o ka hinai hookahi, a e lawe mai oe ia mau mea ma ka hinai, me ka bipi a me na hipakane elua.   
\q1
\v 4 A e kai mai oe ia Aarona, a me kana mau keikikane, a i ka puka o ka halelewa o ke anaina kanaka, a e holoi ia lakou i ka wai.   
\q1
\v 5 A lawe oe i na aahu, a e hookomo i ka palule maluna o Aarona, a i ka holoku o ka epoda, a me ka epoda, a me ka paleumauma, a e kaei ia ia i ke kaei o ka epoda;   
\q1
\v 6 A e kau oe i ka papale hainaka maluna o kona poo, a e kau hoi i ka lei kapu, maluna o ka papale.   
\q1
\v 7 Alaila e lawe oe i ka aila poni, a e ninini iho maluna o kona poo, a e poni hoi ia ia.   
\q1
\v 8 A e kai mai hoi oe i kana mau keikikane, a e hookomo i na palule maluna o lakou.   
\q1
\v 9 A e kaei ia lakou i na kaei, ia Aarona, a me kana mau keikikane pu, a e nakiikii hoi i na papale maluna o lakou; a o ka oihana a ke kahuna, na lakou no, he kanawai mau loa ia: a e hoolaa oe ia Aarona, a me kana mau keikikane.   
\b  
\q1
\v 10 E kai mai hoi oe i bipi imua o ka halelewa o ke anaina kanaka; a e kau o Aarona, a me kana mau keikikane i ko lakou mau lima ma ke poo o ka bipi.   
\q1
\v 11 A e pepehi oe i ka bipi imua o Iehova, ma ka puka o ka halelewa o ke anaina kanaka.   
\q1
\v 12 A e lawe oe i kekahi koko o ka bipi, a e kau ma na pepeiao o ke kuahu me kou manamana lima, a e ninini iho i ke koko a pau ma ke kumu o ke kuahu.   
\q1
\v 13 E lawe hoi oe i ke kaikea a pau e wahi ana i na naau, a me ke aa maluna o ke ake, a me na konahua elua, a me ke kaikea e pili ana, a e puhi ia mau mea i ke ahi maluna o ke kuahu.   
\q1
\v 14 Aka, o ka io o ka bipi, a me kona ili, a me kona lepo, e puhi oe ia i ke ahi, mawaho o ke kahua hoomoana. He mohai hala ia.   
\b  
\q1
\v 15 E lawe hoi oe i hookahi hipakane, a e kau no o Aarona, a me kana mau keikikane i ko lakou mau lima ma ke poo o ka hipa.   
\q1
\v 16 A e pepehi oe i ka hipa, a e lawe i kona koko, a e kapii iho maluna iho o ke kuahu a puni.   
\q1
\v 17 A e oki liilii oe i ka hipa, a e holoi i ko loko ona, a me kona mau wawae, a e hoolilo i kona mau apana, a me kona poo.   
\q1
\v 18 A e puhi oe i ka hipa a pau maluna o ke kuahu; he mohaikuni ia na Iehova, he mea ala, i puhiia na Iehova.   
\b  
\q1
\v 19 E lawe no hoi oe i kekahi hipakane, a e kau no o Aarona a me kana mau keikikane i na lima o lakou ma ke poo o ka hipa.   
\q1
\v 20 Alaila, e pepehi oe i ka hipa, a e lawe i kekahi o kona koko, a e kau ma ka piko o ka pepeiao akau o Aarona, a ma ka piko o ka pepeiao akau o kana mau keikikane, a ma ka manamana nui o ko lakou lima akau, a ma ka manamana nui o ko lakou wawae akau, a e kapii hoi i ke koko maluna o ke kuahu a puni.   
\q1
\v 21 A e lawe oe i kekahi o ke koko ma ke kuahu, a me kahi o ka aila poni, a e kapii maluna o Aarona, a maluna o kona kahiko, a maluna o kana mau keikikane, a maluna o ke kahiko o kana mau keikikane pu me ia. A e hoolaaia oia, a me kona kahiko, a o kana mau keikikane, a me ke kahiko o kana mau keikikane pu me ia.   
\q1
\v 22 A e lawe hoi oe i ko ka hipa, i ke kelekele, a me ka huelo a me ke kaikea e wahi ana i na naau, a me ke aa maluna o ke ake, a me na konahua elua a me ke kaikea e pili ana, a me ka uha mua akau, no ka mea, he hipa ia e hoolaa ai:   
\q1
\v 23 A i hookahi popo berena, a i hookahi papa berena, he berena me ka aila, a hookahi papa mailoko mai o ka hinai berena hu ole, ka mea imua o Iehova.   
\q1
\v 24 A e haawi oe ia mau mea a pau iloko o na lima o Aarona, a iloko o na lima a kana mau keikikane, a e hoali lakou i mohai hoali imua o Iehova.   
\q1
\v 25 A e lawe oe ia mau mea mai ko lakou lima, a e puhi maluna o ke kuahu, i mohai kuni, i mea ala imua o Iehova; he mohai ahi ia na Iehova.   
\b  
\q1
\v 26 E lawe hoi oe i ka umauma o ka hipa o ko Aarona hoolaaia, a e hoali ae, i mohai hoali imua o Iehova, oia hoi kau apana.   
\q1
\v 27 A e hoolaa oe i ka umauma o ka mohai hoali, a me ka uha mua o ka mohai kaikai, ka mea i hoaliia, a kaikaiia hoi, o ka hipakane o ka hoolaa ana, ka mea no Aarona, a no kana mau keikikane;   
\q1
\v 28 A e lilo ia na Aarona, a na kana mau keikikane, mai na mamo a Iseraela ae, he kanawai mau loa ia; no ka mea, he mohai kaikai ia: a e lilo ia i mohai kaikai, mai na mamo a Iseraela ae, i alana hoi no na mohai hoomalu o ko lakou mohai kaikai no Iehova.   
\b  
\q1
\v 29 A o na kahiko laa o Aarona, na kana mau keikikane ia mahope ona; i poniia lakou maloko o ia mau mea, a hoolaaia maloko olaila.   
\q1
\v 30 A o ke keiki e lilo ana i kahuna ma kona hakahaka, nana no e hookomo ia mau mea i ehiku la, i kona manawa e hele mai ai iloko o ka helelewa o ke anaina kanaka, e lawelawe ma kahi hoano.   
\b  
\q1
\v 31 A e lawe oe i ka hipakane o ka hoolaa ana, a e hoolapalapa i kona io maloko o kahi hoano.   
\q1
\v 32 A e ai no o Aarona, a me kana mau keikikane i ka io o ka hipakane, a me ka berena maloko o ka hinai, ma ka puka o ka halelewa o ke anaina kanaka.   
\q1
\v 33 A e ai no lakou ia mau mea i huikalaia'i, e hookahuna, a e hoolaa ia lakou: aole e ai ka malihini, no ka mea, ua laa ia mau mea.   
\q1
\v 34 A ina e koe iho kekahi io o ka hoolaa ana, a kekahi berena paha, a kakahiaka, alaila e puhi oe i ke koena i ke ahi; aole ia e aiia, no ka mea, ua laa ia.   
\b  
\q1
\v 35 A pela oe e hana'i ia Aarona, a i kana mau keikikane, e like me na mea a pau a'u i kauoha aku ai ia oe, i ehiku la e hoolaa ai oe ia lakou.   
\q1
\v 36 A e kaumaha oe i kela la i keia la, i bipi, he mohai hala, i mea e kalahala ai: a e hoomaemae oe i ke kuahu, i ka wa au e hookalahala ai nona, a e poni oe ia mea, a e hoolaa hoi.   
\q1
\v 37 Ehiku la e kalahala'i oe no ke kuahu, a e hoolaa ia men; a e lilo ia i kuahu laa loa. E laa no na mea a pau i pa mai i ke kuahu.   
\b  
\q1
\v 38 Eia hoi ka mea au e kaumaha'i maluna o ke kuahu a mau i kela la i keia la, elua keikihipa o ka makahiki hookahi.   
\q1
\v 39 E kaumaha oe i hookahi keikihipa i ke kakahiaka, a o kekahi keikihipa kau e kaumaha ai i ke ahiahi.   
\q1
\v 40 Me ke keikihipa hookahi, he hapaumi o ka epa palaoa, i huiia me ka hapaha o ka hina aila i kuiia; a me ka hapaha o ka hina waina, i mea mohai inu.   
\q1
\v 41 E kaumaha hoi oe i kekahi keikihipa i ke ahiahi, a e hana aku hoi ia mea, e like me ka mohai makana o ke kakahiaka, a e like hoi me kona mohai inu, i mea ala, he mohai ahi hoi ia no Iehova.   
\q1
\v 42 He mohaikuni mau ia no ko oukou hanauna, ma ka puka o ka halelewa o ke anaina, imua o Iehova; kahi a'u e halawai ai me oe, e kamailio pu me oe malaila.   
\q1
\v 43 A malaila wau e halawai ai me na mamo a Iseraela, a e hoolaaia mai ai, e ko'u nani.   
\q1
\v 44 A e hoolaa no wau i ka halelewa o ke anaina kanaka, a me ke kuahu: e hoolaa no hoi au ia Aarona. a me kana mau keikikane, e lawelawe no'u ma ka oihana kahuna.   
\b  
\q1
\v 45 A e noho no wau iwaena konu o na mamo a Iseraela, a owau auanei ko lakou Akua.   
\q1
\v 46 A e ike auanei lakou, owau no Iehova, ko lakou Akua, ka mea i lawe mai ia lakou, mai ka aina o Aigupita mai, i noho wau iwaena o lakou. Owau, o Iehova no ko lakou Akua.   
\c 30  
\b  
\q1
\v 1 E HANA oe i kuahu, i wahi e puhi ai i ka mea ala. E hana oe ia mea i ka laau sitima.   
\q1
\v 2 Hookahi kubita kona loihi, a he kubita hoi kona laula; e hanaia na aoao ahalike, a elua kubita kona kiekie, oia mea hookahi me na pepeiao ona.   
\q1
\v 3 A e uhi oe ia mea i ke gula maikai, o ko luna, a me na aoao ona a puni, a me kona mau pepeiao, a e hana oe i lei gula a puni ia mea.   
\q1
\v 4 A e hana oe i mau apo gula nona elua, malalo iho o kona lei; ma kona mau kihi, ma na aoao elua ona kau e hana'i ia mea; i mau wahi ia no na auamo e lawe ai i ke kuahu.   
\q1
\v 5 A e hana oe i na auamo, he laau sitima, a e wahi ia mau mea i ke gula.   
\q1
\v 6 A e waiho oe ia mea imua o ka paku e kau ana imua o ka pahu hoike, imua hoi o ka noho aloha e kau ana maluna o ka pahu kanawai, kahi a'u e halawai ai me oe.   
\q1
\v 7 A e puhi o Aarona maluna olaila i mea ala maikai, i kela kakahiaka, keia kakahiaka: i kona wa e koli ai i na kukui, e puhi oia i ka mea ala maluna olaila.   
\q1
\v 8 A i ka wa e hoa ai o Aarona i na kukui i ke ahiahi, e puhi no oia i ka mea ala maluna olaila, he mea ala hoomau no ko oukou mau hanauna a pau.   
\q1
\v 9 Mai Kaumaha oe i ka mea ala e maluna olaila, aole hoi he mohaikuni, aole hoi he mohai makana, mai ninini hoi i ka mohai inu maluna olaila.   
\q1
\v 10 A maluna o kona mau pepeiao, e kalahala ai o Aarona, i hookahi kalahala ana o ka makahiki, me ke koko o ka mohai hala o ke kalahala ana. E kalahala no oia maluna olaila, i hookahi no hana ana o ka makahiki no ko oukou hanauna; ua laa loa ia no Iehova.   
\b  
\q1
\v 11 Olelo mai la o Iehova ia Mose, i mai la,   
\q1
\v 12 I ka wa e helu ai oe i na mamo a Iseraela, i ka poe e heluia'i, alaila, e haawi no kela kanaka, keia kanaka i uku ia Iehova, no kona uhane, i ka wa au e helu ai ia lakou, i ole ai ka mai ahulau iwaena o lakou, i kou wa e helu ai ia lakou.   
\q1
\v 13 Eia ka lakou e haawi mai ai, o kela mea keia mea e hele ae ranwaena o ka poe i heluia, he hapalua o ka sekela, ma ka sekela o ke keenakapu, (he iwakalua gera hookahi ia sekela,) a he hapalua o ka sekela, oia ka haawina ia Iehova.   
\q1
\v 14 O kela mea keia mea e hele ae iwaena o ka poe i heluia, mai ka iwakalua o ka makahiki a keu aku, a haawi no oia i haawina ia Iehova.   
\q1
\v 15 Aole hookeu aku ka mea waiwai, aole hoi ka mea hune e hoemi iho i ka hapalua o ka sekela i ko lakou haawi ana ia Iehova, e kalahala ai no ko oukou uhane.   
\q1
\v 16 A e lawe oe i ke kala kalahala o na mamo a Iseraela, a e haawi ia mea no ka hana o ka halelewa o ke anaina kanaka, i lilo ia i mea paipai manao no na mamo a Iseraela imua o Iehova, i mea hoi e kalahala'i no ko oukou poe uhane.   
\b  
\q1
\v 17 Olelo mai la o Iehova ia Mose, i mai la,   
\q1
\v 18 E hana no oe i ipu auau keleawe, a o kona kumu hoi he keleawe, i wahi e holoi ai. A e waiho oe ia mea mawaena o ka halelewa o ke anaina kanaka, a me ke kuahu, a e ninini oe i ka wai maloko.   
\q1
\v 19 No ka mea, malaila no e holoi ai o Aarona, a me kana mau keiki i ko lakou mau lima, a me ko lakou mau wawae.   
\q1
\v 20 A hele lakou iloko o ka halelewa o ke anaina kanaka, alaila, e holoi lakou me ka wai, i ole ai lakou e make; a i ka manawa hoi e hookokoke mai ai lakou i ke kuahu e lawelawe ai, e puhi i mohai ahi no Iehova:   
\q1
\v 21 I holoi lakou i ko lakou mau lima, a me ko lakou mau wawae, i ole ai lakou e make. He kanawai mau loa ia no lakou; nona, a no kana poe mamo ma ko lakou hanauna.   
\b  
\q1
\v 22 Olelo mai no hoi o Iehova ia Mose, i mai la,   
\q1
\v 23 E lawe oe nou i mau hua ala nui, i mura maikai, elima haneri sekela, a i kinemona ikaika, he hapalua, elua hoi haneri sekela, a me ke kanalima, a i oheala, elua haneri a me ke kanalima sekela.   
\q1
\v 24 A i kida, elima haneri sekela, ma ka sekela o ke keenakapu, a i hookahi hina aila oliva:   
\q1
\v 25 A e hana oe ia i aila poni hoano, he mea poni i huiia ma ke ano o ka hana ana i na mea ala. E lilo ia i aila poni hoano.   
\q1
\v 26 A me ia no oe e poni ai i ka halelewa o ke anaina kanaka, a me ka pahu o ke kanawai,   
\q1
\v 27 A me ka papaaina, a me kona mau oihana a pau, a me ka ipukukui, a me kona mau oihana a pau, a me ke kuahu no ka mea ala,   
\q1
\v 28 A me ke kuahu no ka mohaikuni, a me kona mau oihana a pau, a me ka ipu auau, a me kona kumu.   
\q1
\v 29 A e hoolaa oe ia mau mea, i laa loa lakou: o na mea a pau e pili ana me ia mau mea, e laa no lakou.   
\q1
\v 30 A e poni no hoi oe ia Aarona, a me kana mau keikikane, a e hoolaa ia lakou, i lawelawe lakou na'u ma ka oihana kahuna.   
\q1
\v 31 A e olelo aku oe i na mamo a Iseraela, e i aku, He aila poni hoano keia no'u, ma ko oukou mau hanauna.   
\q1
\v 32 Aole ia e nininiia maluna o ka io o ke kanaka, mai hana hoi oe i kekahi mea hamo like, ma ke ano hookahi me ia; ua laa ia, a e laa auanei ia no oukou.   
\q1
\v 33 O ka mea hana i mea ala e like me ia, a o ka mea kau ia mea maluna o ka malihini, e okiia oia mai kona poe kanaka aku.   
\b  
\q1
\v 34 I mai la o Iehova ia Mose, E lawe oe i mea ala nou, i natapa, i onika, a i metopio, ia mau mea ala, a me ka libano, e like no ke kaumaha o ia mau mea a pau.   
\q1
\v 35 A e hana oe he mea ala, i laau poni hoi, e like me ka hana ana i na mea ala, i hanaia a miko, maikai, a laa hoi.   
\q1
\v 36 A e kui oe i kekahi o ia mea a wali loa, a e kau aku imua o ke kanawai, maloko o ka halelewa o ke anaina kanaka, kahi a'u e halawai ai me oe. E laa loa auanei ia no oukou.   
\q1
\v 37 A o ka mea ala au e hana'i, mai hana oukou i mea e like ai no oukou; e laa no ia ia oe no Iehova.   
\q1
\v 38 O ka mea hana e like me ia, i mea e honi ai, e okiia no ia, mai kona poe kanaka aku.   
\c 31  
\b  
\q1
\v 1 OLELO mai o Iehova ia Mose, i mai la,   
\q1
\v 2 E nana hoi, ua kahea aku au ma ka inoa, ia Bezalela, i ke keiki a Uri, i ka keiki a Hura, no ka ohana a Iuda.   
\q1
\v 3 A ua hoopiha au ia ia i ka uhane o ke Akua, ma ke akamai, ma ka naauao, ma ka ike, a ma ka hana ana i na mea a pau,   
\q1
\v 4 E imi i na mea akamai, e hana hoi ma ke gala, a ma ke kala, a ma ke keleawe,   
\q1
\v 5 A i ke okioki pohaku, i mea kapili: a i ke kalai ana i ka laau e hana hoi i na hana a pau.   
\q1
\v 6 A owau, aia hoi, ua haawi no wau ia Aholiaba nona, i ke keiki a Ahisamaka, no ka ohana a Dana; a ua haawi no wau i ke akamai maloko o ka naau o ka poe a pau i naauao, i hana lakou i na mea a pau a'u i kauoha aku at ia oe:   
\q1
\v 7 I ka halelewa o ke anaina kanaka, a me ka pahu kanawai, a me ka noho aloha maluna iho, a me ka oihana a pau o ka halelewa,   
\q1
\v 8 A me ka papaaina, a me kona oihana, a me ka ipukukui, me kona oihana a pau, a me ke kuahu no ka mea ala,   
\q1
\v 9 A me ke kuahu no ka mohaikuni a me kona oihana a pau, a me ka ipu auau, a me kona kumu,   
\q1
\v 10 A me na lole hana, a me na kahiko laa no Aarona ke kahuna, a me na kahiko no kana mau keikikane e lawelawe ai ma ka oihana kahuna,   
\q1
\v 11 A me ka aila poni, a mo ka mea ala maikai no kahi laa; e like me na mea a pau a'u i kauoha aku ai ia oe, pela laua e hana'i.   
\b  
\q1
\v 12 Olelo mai la o Iehova ia Mose, i mai la,   
\q1
\v 13 E olelo aku oe i na mamo a Iseraela, e i aku, E malama io oukou i ko'u mau sabati, no ka mea, he hoailona ia mawaena o'u a me oukou, i ko oukou mau hanauna; i ike hoi oukou, owau no Iehova, ka mea hoolaa ia oukou.   
\q1
\v 14 Nolaila oukou e malama'i i ka sabati; no ka mea, ua hoanoia ia no oukou, O kela mea keia mea hoohaumia ia la, e oiaio no e pepehiia oia: no ka mea, o ka mea hana i ka hana ia la, e okiia kela kanaka, mai kona poe kanaka aku.   
\q1
\v 15 Eono la e hanain'i ka hana, aka o ka hiku, he sabati ia e hoomaha'i, he mea laa no Iehova, o ka mea hana i kekahi hana i ka sabati, e oiaio no e pepehiia oia.   
\q1
\v 16 A e malama na mamo a Iseraela i ka sabati e hooponopono i ka sabati, i ko lakou hanauna, i berita mau loa.   
\q1
\v 17 He hoailona mau loa ia mawaena o'u a me na mamo a Iseraela; no ka mea, i na la eono i hana'i o Iehova i ka lani, a me ka honua, a i ka hiku o ka la, hoomaha oia, a oluolu iho la,   
\b  
\q1
\v 18 A i kona hoopau ana i ke kamailio me Mose, maluna o ka mauna o Sinai, haawi mai la oia ia ia i elua papa kanawai he mau papa pohaku, ua kahakahaia e ka lima o ke Akua.   
\c 32  
\b  
\q1
\v 1 A IKE aku la na kanaka i ko Mose hookaulua ana i ka iho mai, mai ka mauna mai, akoakoa iho la na kanaka io Aarona la, olelo ae la ia ia, E ku oe, e hana i akua no kakou, i mea hele mamua o kakou: no ka mea, o ua Mose la, ke kanaka nana kakou i alakai mai nei, mai ka aina o Aigupita mai; aole kakou ike i kona wahi i lilo aku ai.   
\q1
\v 2 I mai la o Aarona ia lakou, E uhai oukou i na apo gula pepeiao, i na mea iloko o na pepeiao o ka oukou wahine, a me ka oukou keikikane, a me ka oukou kaikamahine, a e lawe mai io'u nei.   
\q1
\v 3 Uhai iho la na kanaka a pau i na gula pepeiao, i na mea iloko o ko lakou pepeiao, a lawe mai io Aarona la.   
\q1
\v 4 Lawe iho la ia, mai ko lakou lima aku, a koli iho la ia mea i ke kila, a hana ae la i bipi keiki i hooheheeia; a olelo iho la lakou, Eia kou akua, e ka Iseraela, nana oe i lawe mai nei, mai ka aina o Aigupita mai.   
\q1
\v 5 A ike aku la o Aarona, hana iho la ia i kuahu imua i ke alo o ia mai; hea aku la o Aarona, i aku la, E, I apopo, he ahaaina na Iehova.   
\q1
\v 6 A ia la iho, ala koke ae la lakou, a mohai aku la i mohaikuni, a lawe mai no hoi i mohaihoomalu; a noho iho la na kanaka e ai, a e inu, a ku ae la iluna e paani.   
\b  
\q1
\v 7 I mai la o Iehova ia Mose, O hele oe, e iho ilalo; ua hana hewa kou poe kanaka au i lawe mai ai, mai ka aina o Aigupita mai.   
\q1
\v 8 Ua huli koke ae lakou, mai ke ala aku a'u i kauoha aku ai ia lakou; ua hana lakou i bipi keiki i hooheheeia no lakou, ua hoomana lakou ia mea, a ua mohai hoi lakou ia ia, me ka i ana aku, E ka Iseraela e, eia kou akua, nana oe i lawe mai nei, mai ka aina o Aigupita mai.   
\q1
\v 9 I mai la o Iehova ia Mose, Ua ike no au i keia poe kanaka, aia hoi, he poe kanaka a-i oolea:   
\q1
\v 10 Ano hoi, e ae mai oe ia'u, i wela loa ko'u huhu ia lakou, i hoopau wau ia lakou; a na'u no e hana aku ia oe i lahuikanaka nui.   
\q1
\v 11 Nonoi aku la o Mose ma ke alo o Iehova, o kona Akua, i aku la, E Iehova, no ke aha la i wela ai kou huhu i kou poe kanaka au i lawe mai ai, mai ka aina o Aigupita mai, me ka mana nui, a me ka lima ikaika?   
\q1
\v 12 No ke aha la e olelo mai ai ko Aigupita, me ka i ana mai, No ka hewa i lawe mai ai oia ia lakou, e pepehi ia lakou ma na mauna, a e luku aku ia lakou, mai ka maka aku o ka honua? E maliu mai oe mai ka wela mai o kou huhu, a e aloha mai oe no ka hewa e hiki mai ana i kou poe kanaka.   
\q1
\v 13 E hoomanao oe ia Aberahama, ia Isaaka, ia Iseraela, i kau mau kauwa, i kou hoohiki ana ia lakou ma ou iho; i kau olelo ana mai ia lakou, E hoonui ana au i ka oukou ohana e like me na hoku o ka lani; a o keia aina a pau a'u i olelo ai, na'u no e haawi aku no ka oukou poe mamo, a e noho mau loa lakou ma ia aina.   
\q1
\v 14 Maliu mai la no o Iehova mai ka hoino mai ana i manao ai e hana mai i kona poe kanaka.   
\b  
\q1
\v 15 Huli mai la o Mose, a iho mai la, mai ka mauna mai, aia hoi, maloko o kona lima na pohaku papa kanawai elua: ua palapalaia na papa ma na aoao elua, ua palapalaia no ma kahi aoao, a ma kahi aoao.   
\q1
\v 16 O ia mau papa ka ke Akua i hana'i, a o ka palapala, na ke Akua ka palapala, ua kahakahaia maloko o na papa.   
\q1
\v 17 A lohe o Iosua i ka walaau o kanaka i ko lakou uwauwa ana, i ae la ia ia Mose, He walaau kaua ka ma kahi e hoomoana'i.   
\q1
\v 18 I mai la kela, Aole ia he leo no ka poe uwauwa lanakila, aole hoi ka leo o ka poe uwe i ke pio ana; aka o ka walaau mele ka'u e lohe nei.   
\b  
\q1
\v 19 A kokoke ia i hiki i kahi o lakou i hoomoana'i, ike aku la ia i ka bipi keiki, a me ka haa ana: ulu puni iho la ko Mose huhu, kiola aku la ia i na papa, mai kona lima aku, a naha iho la laua malalo iho o ka mauna.   
\q1
\v 20 Lawe iho la ia i ka bipi keiki a lakou i hana'i, a puhi aku la i ke ahi, a hoowali iho la a okaoka, a lulu aku la ia maluna o ka wai, a hoohainu aku la i na mamo a Iseraela i ka wai.   
\b  
\q1
\v 21 I aku la o Mose ia Aarona, Heaha ka mea a keia poe kanaka i hana'i ia oe, i hooili mai ai oe i keia hewa nui maluna o lakou.   
\q1
\v 22 I mai la o Aarona, Mai ulu puni mai ka huhu o kuu haku, ua ike no oe i ka poe kanaka, na paa lakou ma ke kolohe.   
\q1
\v 23 No ka mea, olelo mai lakou ia'u, E hana oe i na akua no kakou, e hele aku imua o kakou; no ka mea, o ua Mose nei, ke kanaka nana kakou i lawe mai nei, mai ka aina o Aigupita mai, aole kakou i ike i kona wahi i lilo aku ai.   
\q1
\v 24 I aku la au ia lakou, O ka mea ia ia kekahi gula, e uhai oia ia mea. Haawi mai no hoi lakou ia'u: alaila hahao aku la au ia mea iloko o ke ahi, a puka mai la mawaho ua bipi keiki nei.   
\b  
\q1
\v 25 A ike mai la o Mose i na kanaka, ua haunaele; (no ka mea, ua hoohaunaele o Aarona ia lakou i ka lukuia imua o ko lakou poe enemi:)   
\q1
\v 26 Alaila ku mai la o Mose ma ka puka o kahi a lakou i hoomoana'i, i mai la, Owai ka mea ma ko Iehova aoao? e hele mai ia io'u nei. A akoakoa pu mai la na mamo a pau a Levi io na la.   
\q1
\v 27 I mai la ia ia lakou, Ke i mai nei o Iehova o ke Akua o Iseraela penei, E kau na kanaka a pau i na pahikaua a lakou ma ko lakou aoao, e hele ae lakou a hoi mai, ma kela ipuka a keia ipuka o kahi hoomoana, a e pepehi ke kanaka i kona hoahanau, a o ke kanaka i kona makamaka, a o ke kanaka i kona hoalauna.   
\q1
\v 28 Hana iho la na mamo a Levi e like me ka olelo a Mose: a haule iho la ia lakou ia la na kanaka ekolu paha tausani.   
\q1
\v 29 No ka mea, ua olelo mai o Mose, E hoolaa oukou ia oukou iho no Iehova i keia la, o ke kanaka maluna o kana keiki a maluna o kona hoahanau; i hoomaikai mai kela ia oukou i keia la.   
\b  
\q1
\v 30 A ia la iho, i mai la o Mose i na kanaka, Ua lawehala loa oukou; ke pii aku nei no hoi au io Iehova la; e hana paha wau i mea e kalaia mai ai ko oukou hewa.   
\q1
\v 31 Hoi aku la o Mose io Iehova la, i aku la, Auwe hoi, ua lawehala loa keia poe kanaka, a ua hana i akua gula no lakou.   
\q1
\v 32 Ano hoi, ina paha e kala mai oe i ko lakou hewa?; aka, i ole, ke nonoi aku nei au ia oe e holoi mai oe ia'u, mai ka buke au i palapala ai.   
\q1
\v 33 I mai la o Iehova ia Mose, O ka mea i lawehala i ka'u, e holoi aku au ia ia, mai ka'u buke aku.   
\q1
\v 34 No ia mea, o hele oe, e alakai ia poe kanaka i kahi a'u i olelo ai ia oe: aia hoi, e hele no ko'u anela mamua ou, aka hoi, i ko'u la e hoopai ai, e hoopai aku au i ko lakou hewa maluna o lakou.   
\q1
\v 35 Hahau mai la Iehova i na kanaka no ka lakou hana ana i ka bipi keiki a Aarona i hana'i.   
\c 33  
\b  
\q1
\v 1 OLELO mai la o Iehova ia Mose, o hele, e pii aku, o oe a me na kanaka au i alakai mai nei, mai ka aina o Aigupita mai, a i ka aina a'u i hoohiki ai ia Aberahama, a ia Isaaka, a ia Iakoba, i ka i ana iho, Ke haawi nei au ia na kau poe mamo.   
\q1
\v 2 A e hoouna aku au i ko'u anela imua ou; a na'u no e kipaku aku i ka Kanaana, i ka Amora, i ka Heta, i ka Pereza, i ka Heva, a i ka Iebusa;   
\q1
\v 3 A i ka aina e kahe ana o ka waiu a me ka mele; no ka mea, aole au e pii aku iwaena ou, no ka mea, he poe kanaka a-i oolea oukou; o hoopau auanei au ia oe ma ke ala.   
\b  
\q1
\v 4 A lohe na kanaka i keia olelo o ka hewa, uwe iho la lakou, aohe kanaka i hookomo i kona kahiko ana.   
\q1
\v 5 No ka mea, ua olelo mai o Iehova ia Mose, E i aku oe i na mamo a Iseraela, He poe kanaka a-i oolea oukou: i ka minute hookahi, e pii aku no au iwaena konu ou, a e hoopau ia oe, Nolaila, e wehe oe i kou kahiko ana mai ou aku la, i ike au i ka mea e hana aku ai ia oe.   
\q1
\v 6 A wehe na mamo a Iseraela i ko lakou kahiko ana, ma ka mauna o Horeba.   
\b  
\q1
\v 7 A lawe ae la o Mose i ka halelewa, a kukulu iho la mawaho o kahi e hoomoana'i, ma kahi mamao aku o ke kahua i hoomoana'i; a kapa ae la oia ia mea, o ka Halelewa o ke anaina kanaka. A o kela mea keia mea i imi ia Iehova, hele aku la ia iwaho i ka halelewa o ke anaina kanaka, ka mea mawaho o kahi i hoomoana'i.   
\q1
\v 8 A i ka hele ana aku o Mose i ka halelewa, ala ae la na kanaka a pau iluna, a ku no kela kanaka keia kanaka ma ka puka o kona halelewa, a nana aku la mahope o Mose, a hala ia iloko o ka halelewa.   
\q1
\v 9 A i ko Mose komo ana iloko o ka halelewa, iho mai la ke kia ao, a ku ma ka puka o ka halelewa, a kamailio mai la [o Iehova] me Mose.   
\q1
\v 10 A ike ae la na kanaka a pau i ke kia ao e ku ana ma ka puka o ka halelewa, a ku ae la na Kanaka a pau iluna, a hoomana aku la, o kela kanaka keia kanaka ma ka puka o kona halelewa.   
\q1
\v 11 A kamailio mai la o Iehova ia Mose, he maka no he maka, e like me ke kamailio ana o ke kanaka me kona hoa. A hoi aku la ia iloko o kahi e hoomoana'i, a me kana kauwa, o Iosua, ke keiki a Nuna, he kanaka opiopio; aka, aole ia i hele iwaho o ka halelewa.   
\b  
\q1
\v 12 I aku la o Mose ia Iehova, E nana hoi, ke olelo mai nei oe ia'u, E kai mai oe i keia poe kanaka; aole nae oe i hoike mai ia'u i ka mea au e hoouna pu ai me au. Aka, na olelo mai no, Ua ike no wau ia oe ma ka inoa, a e loaa ia oe ka lokomaikaiia i ko'u mau maka.   
\q1
\v 13 Nolaila, ke nonoi aku nei au ia oe, ina i loaa ia'u ka lokomaikaiia i kou mau maka, e hoike mai oe ia'u i kou aoao, i ike aku au ia oe, i loaa ia'u ka lokomaikaiia i kou mau maka: a e hoomanao hoi, o kou aupuni no keia poe kanaka.   
\q1
\v 14 I mai la keia, E hele pa ne ko'u maka, a na'u no oe e hoomaha aku.   
\q1
\v 15 I aka la keia, I ole e hele pu kou maka, mai lawe aku oe ia makou.   
\q1
\v 16 Mahea la e ikeia'i ua loaa ia'u a me kou poe kanaka ka lokomaikaiia i kou maka? Aole anei ma kou hele pu ana me makou? A pela makou e hookaawaleia'i, owau a me ko'u poe kanaka, mai na kanaka e aka a pau loa e noho ana maluna o ka honua.   
\b  
\q1
\v 17 Olelo mai la o Iehova, ia Mose, E hana no hoi au i keia mea au i olelo mai ai; no ka mea, ua loaa ia oe ka lokomaikaiia i ko'u maka, a ua ike aka au ia oe ma ka inoa.   
\q1
\v 18 A i aku la keia, Ke nonoi aku nei au ia oe, e hoike mai oe i kou nani ia'u.   
\q1
\v 19 Olelo mai la ia, E hoohele au i ko'u maikai a pau imua o kou maka, a e hea aku au i ka inoa o Iehova imua o kou maka; a e lokomaikai aka au i ka mea a'u e manao ai e lokomaikai aku, a e aloha aku au i ka mea a'u e manao ai e aloha aka.   
\q1
\v 20 A i mai la ia, Aole hiki ia oe ke ike mai i ko'u maka; no ka mea, aohe kanaka e ike mai ia'u, a ola.   
\q1
\v 21 A i mai la o Iehova, Aia kahi e kokoke ana ia'u, a e ku no oe maluna o ka pohaku.   
\q1
\v 22 A i ka wa e hele ae ko'u nani, e hookomo no wau ia oe iloko o ka mauae o ka pohaku, a e uhi aku au ia oe i ko'u lima, ia'u e hele ana'e.   
\q1
\v 23 A e lawe aku au i ko'u lima, a e ike mai oe i ko'u kua; aka, aole e ikeia ko'u maka.   
\c 34  
\b  
\q1
\v 1 OLELO mai la o Iehova ia Mose, E kalai oe i mau pohaku papa elua nou, e like me na mea mamua; a na'u no e palapala maluna o ua mau papa la i na olelo i kauia'i ma na papa mua au i wahi ai.   
\q1
\v 2 E hoomakaukau oe no ke kakahiaka, a i ke kakahiaka e pii mai oe i ka mauna nei i Sinai, a e hoike mai oe ia oe iho ia'u ilaila ma ke poo o ka mauna.   
\q1
\v 3 Mai hele pu mai kekahi kanaka me oe, aole hoi e ikea kekahi kanaka ma ka mauna a pau; aole hoi e ai na hipa a me na holoholona ma ke alo o ia mauna.   
\b  
\q1
\v 4 Kalai iho la ia i na pohaku papa elua e like me na mea mamua; a ala ae la o Mose i kakahiaka nui, a pii aka la i ka mauna i Sinai, e like me ke kauoha ana mai o Iehova ia ia, a lawe aku la maloko o kona lima i ua mau pohaku papa la elua.   
\q1
\v 5 Iho mai la o Iehova maloko o ke ao, a ku pu me ia ilaila, a hai mai la i ka inoa o Iehova.   
\q1
\v 6 Hele ae la o Iehova mamua e kona alo, hai mai la ia, O Iehova, o Iehova, ke Akua lokomaikai, a manawalea, a ahonui, ua nui kona maikai a me ka oiaio.   
\q1
\v 7 Ke malama nei no i ka lokomaikai no na lehulehu, a me ke kala mai i ka ino a me ka hala a me ka hewa, aole hoi e hoapono loa, e uku ana no i ka ka makua hala i ke keiki, a me na keiki a na keiki, a hiki aku i ke kuakahi a me ke kualua.   
\q1
\v 8 Wikiwiki ae la o Mose e kulou i kona poo ilalo i ka honoa a hoomana aku la.   
\q1
\v 9 I aku la ia, A ina i loaa ia'u ka lokomaikaiia mai imua ou, e ka Haku e, ke nonoi aku nei au e hele pa aku ko'u Haku me makou: (he poe kanaka a-i eolea nae keia;) a e kala mai oe i ko makou hala me ko makou hewa, a e lawe oe ia makou i hooilina nou.   
\b  
\q1
\v 10 I mai la kela, Aia hoi, ke hana nei au i berita; a e hana no wau i na mea kupanaha mamua o kou poe kanaka a pau, aole i hanaia kekahi mea e like ai ma ka honua a pau, aole ma kekahi aina; a e ike auanei na kanaka a pau o kou wahi i ka hana a Iehova: he mea weliweli kela mea a'u e hana aku ai ia oe.   
\q1
\v 11 E malama hoi oe i ka mea a'u e kauoha aku ai ia oe i keia la. Aia hoi, e kipaku ana au imua ou, i ka Amora, a me ka Kanaaua, a me ka Heta, a me ka Periza, a me ka Heva, a me ka Iebusa.   
\q1
\v 12 E malama oe ia oe, o hana auanei oe i berita me ka poe e uoho ana i ka aina, kahi au e hele ai, o lilo ia i upiki iwaena o oukou.   
\q1
\v 13 Aka, e hoopau oukou i ko lakou mau kuahu, a e wawahi i ko lakou kii, a e kua ilalo i ko lakou nlulaau.   
\q1
\v 14 No ka mea, mai hoomana oe i kekahi akua e, no ka mea, o Iehova, nona ka inoa o Lili, he Akua lili ia;   
\q1
\v 15 O hana oe i berita me na kanaka o ka aina, a hele moe kolohe lakou mamuli o ko lakou mau akua, a mohai aku na ko lakou mau akua, a hea mai ia oe, a ai oe i kana mohai.   
\q1
\v 16 A lawe paha oe i ka lakou kaikamahine na ka oukou keikikane; a hele moe kolohe ka lakou kaikamahine mamuli o ko lakou poe akua, a hoomoe kolohe lakou i ka oukou keikikane mamuli o ko lakou poe akua.   
\q1
\v 17 Mai hana oe i akua hooheheeia nou.   
\b  
\q1
\v 18 E malama oe i ka ahaaina o ka berena huole. Ehiku la kau e ai ai i ka berena huole, me a'u i kauoha aku ai ia oe, i ka vra o ka malama o Abiba; no ka mea, i ka malama o Abiba i puka mai ai oe mawaho mai o Aigupita.   
\q1
\v 19 O na mea a pau i hemo mua, mai ka opu mai, o ka'u ia, a o na hanau mua a pau o na holoholona, ina ho bipi, a ina he hipa.   
\q1
\v 20 Aka, o ka hanau mua o ka hoki, e panai aku oe i keiki hipa; a i ole oe e panai, e uhai oe i koua a-i. E hoola panai hoi oe i kau mau hiapo kane a pau. Mai ike nele ia kekahi imua o'u.   
\b  
\q1
\v 21 Eono la kau e hana'i, aka, e hoomaha oe i ka hiku o ka la. I ka wa kanu, a i ka wa hoiliili ai, e hoomaha no oe.   
\b  
\q1
\v 22 E malama hoi oe i ka ahaaina hebedoma, no ka hoiliili mua ana i ka palaoa, a i ka ahaaina o ka hoiliili i ka puni ana o ka makahiki.   
\b  
\q1
\v 23 I ekolu no hoikeia'na i ka makahiki hookahi o ka oukou poe keikikane a pau imua o Iehova, ke Akua, ke Akua hoi o ka Iseraela.   
\q1
\v 24 No ka mea, e kipaku aku au i ko na aina imua ou. a e hoopalahalaha ae i kou mau mokuna; aole hoi e kuko mai kekahi kanaka i kou aina i ka wa e pii aku ai oe e ikeia imua o Iehova, kou Akua, ekolu pii ana o ka makahiki.   
\b  
\q1
\v 25 Mai kaumaha oe i ke koko o kou mohai me ka mea hu; mai hookoe hoi i ka mohai o ka ahaaina moliaola, a kakahiaka.   
\q1
\v 26 E lawe mai no oe i ka mua o na hua mua o kou aina iloko o ka hale o Iehova, o kou Akua. Mai hoolapalapa oe i ke keiki kao iloko o ka waiu o kona makuwahine.   
\b  
\q1
\v 27 I mai la o Iehova ia Mose, E palapala oe i keia mau olelo: no ka mea, ma ke ano o keia mau olelo ka'u i hana aku ai i berita me oe, a me ka Iseraela.   
\q1
\v 28 Malaila no ia me Iehova hookahi kanaha ao, hookahi kanaha po; aole ia i ai i ka ai, aole hoi i inu i ka wai. A palapala iho la ia ma na papa i na olelo o ka berita, i na olelo he umi.   
\b  
\q1
\v 29 A iho mai la o Mose, mai ka mauna o Sinai mai, aia no iloko o ko Mose lima na papa kanawai elua, i ka wa i iho mai ai ia mai ka mauna mai, aole o Mose i ike i ka puwa ana o ka ili o kona maka, i ka wa i kamailio pu ai oia me ia.   
\q1
\v 30 A ike aku la o Aarona, a me na mamo a pau a Iseraela ia Mose, aia hoi, ua puwa ka ili o kona maka; makau iho la lakou ke hookokoke ia ia.   
\q1
\v 31 Hea mai la o Mose ia lakou; hoi aku la o Aarona a me na luna a pau o kanaka io na la: a kamailio ae la o Mose me lakou.   
\q1
\v 32 A mahope iho, hookokeke na mamo a pau a Iseraela: a kauoha mai la ia ia lakou i na mea a pau a Iehova i olelo mai ai ia ia, ma ka mauna i Sinai.   
\q1
\v 33 Uhi mai la o Mose i ka pale ma kona maka, a pau kana kamailio ana me lakou.   
\q1
\v 34 A i ka wa i komo aku ai o Mose imua i ke alo o Iehova e olelo me ia, wehe ae la ia i ka pale a hiki i ka wa i puka mai ai mawaho mai; a puka mai la ia mawaho, a olelo mai i na mamo a Iseraela i na mea i kauohaia mai ia ia.   
\q1
\v 35 A ike aku la na mamo a Iseraela i ka maka o Mose, ua puwa ka ili o ko Mose maka: a uhi hou ae la o Mose i ka pale maluna o kona maka, a komo hou aku la ia e olelo pu me ia.   
\c 35  
\b  
\q1
\v 1 HOAKOAKOA iho la o Mose i ka aha kanaka a pau o ka Iseraela, i mai la ia lakou, Eia na olelo a Iehova i kauoha mai ai, i hana oukou ia mau mea.   
\q1
\v 2 I eono la e hanaia'i ka hana, aka o ka hiku o ka la, he la hoano ia, he Sabati e hoomaha'i no Iehova. O ka mea hana i ka hana ia la, e pepehiia oia.   
\q1
\v 3 Mai hoa oukou i ke ahi ma ko oukou mau wahi e noho ai a pau loa, i ka la Sabati.   
\b  
\q1
\v 4 Olelo mai la o Mose i ka aha kanaka a pau o ka Iseraela, i mai la, Eia ka mea a Iehova i kauoha mai ai, i mai la,   
\q1
\v 5 E lawe oukou, maiwaena aku o oukou, i mohai na Iehova; o na mea naau manawalea a pau, e lawe mai lakou i mohai na Iehova; i gula, a i kala, a i keleawe,   
\q1
\v 6 A i uliuli, a i poni, a i ulaula, a i olona keokeo, a i hulu kao;   
\q1
\v 7 A me na ili hipakane i hooluu ulaula ia, a me na ili tehasa, a me ka laau sitima;   
\q1
\v 8 A me ka aila no ka malamalama, a me na hua ala no ka aila poni, a no ka mea ala maikai;   
\q1
\v 9 A me na pohaku onika, a me na pohaku e kau ai maloko o ka epoda, a maloko o ka paleumauma.   
\b  
\q1
\v 10 A e hele mai no na mea naau akamai a pau, a e hana i na mea a pau a Iehova i kauoha mai ai;   
\q1
\v 11 I ka halelewa, i kona halelole a me kona uhi, a me kona mau lou, a me kona mau papa, a me kona mau auamo, a me kona mau kia, a me kona mau kumu;   
\q1
\v 12 I ka pahu, a me kona mau auamo, a me ka noho aloha, a me ka paku e uhi ai;   
\q1
\v 13 I ka papaaina, a me kona mau auamo, a me kona oihana a pau, a me ka berena hoike;   
\q1
\v 14 I ka ipukukui hoi no ka malamalama, a me kona oihana, a me kona mau ipu aila, me ka aila no ka malamalama;   
\q1
\v 15 I ke kuahu no ka mea ala, a me kona mau auamo, a me ka aila poni, a me ka mea ala maikai, a me ka paku no ka puka e komo aku ai iloko o ka halelewa;   
\q1
\v 16 I ke kuahu no ka mohaikuni, a me kona papa manamana pukapuka, a me kona mau auamo, a me kona mau oihana a pau, a me ka ipu auau, a me kona kumu;   
\q1
\v 17 I na paku o ke kahua, a me kona mau kia, a me ko lakou mau kumu, a me ka paku no ka puka o ke kahua;   
\q1
\v 18 I na makia o ka halelewa, a me na makia o ke kahua, a me ko lakou mau kaula;   
\q1
\v 19 I na lole no ka hana, e hana'i i ka hana ma kahi laa, i na kahiko laa no Aarona ke kahuna, a me na kahiko o kana mau keikikane, e lawelawe ai ma ka oihana kahuna.   
\b  
\q1
\v 20 A hele aku la ke anaina kanaka a pau o na mamo a Iseraela, mai ko Mose alo aku.   
\q1
\v 21 A hele mai no lakou, o kela mea keia mea i hooeueuia e kona naau, o kela mea keia mea hoi i hooikaikaia e kona uhane, a lawe mai lakou i ko Iehova haawina no ka hana o ka halelewa o ke anaina kanaka, a no kana hana a pau, a no na kahiko laa.   
\q1
\v 22 A hele mai lakou, o na kane, a me na wahine, o ka poe a pau i makemake ma ka naau, a lawe mai la i na kupee lima, a me na gula pepeiao, a me na apo, a ma na gula a-i, a me na mea gula a pau loa; a o kela mea, keia mea i haawi, haawi oia i gula no Iehova.   
\q1
\v 23 A o kela kanaka keia kanaka i loaa ia ia ka uliuli, ka poni, a me ka ulaula, a me ke olona keokeo, a me ka hulu kao, a me na ili ulaula o na hipakane, a me na ili tehasa, lawe mai no lakou la mau mea.   
\q1
\v 24 O kela mea keia mea i haawi i ka haawina kala, a keleawe, lawe mai no oia i ka Iehova haawina. A o kela kanaka keia kanaka i loaa ia ia ka laau sitima no kahi hana e hana'i, lawe mai la oia ia.   
\q1
\v 25 A o na wahine a pau i akamai ma ka naau, milo lakou me ko lakou lima, a lawe mai la i ka mea a lakou i milo ai, i ka uliuli, a me ka poni, a me ka ulaula, a me ke olona keokeo.   
\q1
\v 26 A o na wahine a pau i hooikaikaia ma ka naau, i mea e akamai ai, milo lakou i ka hulu kao.   
\q1
\v 27 A lawe mai na'lii i pohaku onika, a me na pohaku e kau ai ma ka epoda, a ma ka paleumauma;   
\q1
\v 28 A me na mea ala, a me ka aila no ka malamalama, a no ka aila poni a me ka mea ala maikai.   
\q1
\v 29 Lawe mai no na mamo a Iseraela i makana aloha no Iehova, o kela kane keia kane i makemake ma ka naau e lawe, no ka hana a pau a Iehova i kauoha mai ai ma ka lima o Mose.   
\b  
\q1
\v 30 Olelo mai la o Mose i na mamo a Iseraela, E nana hoi, ma ka inoa no i hea mai ai o Iehova ia Bezalela, i ke keiki a Uri, i ke keiki a Hura, no ka ohana a Iuda;   
\q1
\v 31 A ua hoopiha ia ia i ka uhane o ke Akua, i ke akamai, a i ka naauao, a i ka ike, a i ke ano o na hana a pau;   
\q1
\v 32 I imi oia i na hana akamai, e hana i ke gula, a i ke kala, a i ke keleawe,   
\q1
\v 33 A i ke okioki pohaku ana, a me ke kapilipili, i ke kalai laau, a me ka hana i na hana akamai a pau.   
\q1
\v 34 A ua haawi hoi oia iloko o kona naau i ke ao aku, oia, a me Aholiaba, ke keiki a Ahisamaka, no ka ohana a Dana.   
\q1
\v 35 Ua hoopiha oia ia laua i ke akamai o ka naau, e hana i na hana a pau, o ka mea kahakaha, a me ka mea hana akamai, a me ka mea humuhumu i ka uliuli, a me ka poni, a me ka ulaula, a me ke olona keokeo, a me ka mea upena, a me ka mea hana i na hana a pau, a me ka mea imi i ka hana akamai,   
\c 36  
\b  
\q1
\v 1 A LAILA hana o Bezalela, a me Aholiaba, a me na kanaka a pau i akamai ka naau, na mea a Iehova i haawi mai ai i ke akamai, a me ka naauao e ike ai i ka hana i na hana a pau no ka oihana o ke keenakapu, e like me na mea a pau a Iehova i kauoha mai ai.   
\b  
\q1
\v 2 A hea aku la o Mose ia Bezalela, a me Aholiaba, a me na kanaka a pau i akamai ma ka naau, a Iehova i haawi mai ai i naau akamai, i na mea a pau hoi i ikaika ma ko lakou naau e hele e kokua i ka hana.   
\q1
\v 3 A loaa ia lakou, na Mose ae, na haawina a pau a na mamo a Iseraela i lawe mai ai no ka hana o ka oihana o ke keenakapu, i mea e paa ai ka hana. A lawe mai no lakou ia ia i makana hou i kela kakahiaka, i keia kakahiaka.   
\q1
\v 4 A hele mai la na kanaka akamai a pau, ka poe i hana i na hana a pau o ke keenakapu, mai ka hana mai, a lakou i hana'i.   
\b  
\q1
\v 5 A olelo mai la lakou ia Mose, i mai la, Ke lawe mai nei na kanaka a nui okoa aku, mamua o ka lawelawe ana i ka hana a Iehova i kauaha mai ai e hana.   
\q1
\v 6 A kauoha ae la o Mose, a hookala aku la lakou ia, a puni kahi i hoomoana'i, i ae la, Mai hana hou kekahi kanaka, aole hoi kekahi wahine i hana no ka haawina o ke keenakapu. A hookiia iho la ka lawe ana mai o na kanaka.   
\q1
\v 7 No ka mea, ua lawa na mea e paa ai ka hana a pau e hanaia'i a keu aku no.   
\b  
\q1
\v 8 A o ka poe mea naau akamai a pau i hana i ka hana o ka halelewa, hana lakou i umi mau pale, he olona i hiloia, he uliuli, he poni, a me ka ulaula; hana no oia ia mau mea na kerubima, o ka hana a ka poe akamai.   
\q1
\v 9 He iwakaluakumamawalu kubita ka loihi o kekahi pale, eha kubita ka laula o kekahi pale, ua like hoi ka nui o na pale a pau.   
\q1
\v 10 A hai pu oia i na pale elima, kekahi i kekahi, a hui pu oia i kekahi mau lima, kekahi i kekahi.   
\q1
\v 11 A hana iho la no hoi ia i na puka lou uliuli, ma ke kae o kekahi pale, ma ka pelupelu ana maloko o ka huina. A pela no oia i hana'i, ma ke kihi loa o kekahi pale, ma kahi i huiia'i me ka lua.   
\q1
\v 12 Hana no oia i kanalima puka lou ma kekahi pale, a hana no hoi i kanalima puka lou ma ke kae o ka pale, kahi i haiia'i me ka lua. O na puka lou ka mea i paa ai kekahi i kekahi.   
\q1
\v 13 A hana oia i kanalima lou gula, a hui oia i na pale, kekahi me kekahi a paa i na lou. A lilo iho la ia i halelewa hookahi.   
\b  
\q1
\v 14 A hana no hoi oia i pale hulu kao no ka hale maluna o ka halelewa: hana oia ia mau mea, he umikumamakahi pale.   
\q1
\v 15 He kanakolu kubita ka loihi o kekahi pale, a eha no kubita ka laula o kekahi pale; ua like ka nui o na pale he umikumamakahi.   
\q1
\v 16 A hui oia i elima mau pale a kaawale lakou, a i eono mau pale a kaawale lakou.   
\q1
\v 17 A hana iho la no oia i kanalima puka lou ma ke kae loa o kekahi pale ma ka hui ana, a hana no hoi oia i kanalima puka lou ma ke kae o ka pale i hui me ka lua.   
\q1
\v 18 A hana no hoi oia i kanalima lou keleawe e paa ai ka hale, i lilo ia i hookahi.   
\q1
\v 19 A hana no hoi oia i uhi no ka hale, he mau ili hipakane i hooluu ulaula ia, a maluna aku, i uhi hou, he mau ili tehasa.   
\b  
\q1
\v 20 A hana no hoi oia i mau papa no ka halelewa, he laau sitima, e ku pono ana iluna.   
\q1
\v 21 He umi kabita ka loa o kekahi papa, a hookahi kubita a me ka hapalua ka laula o kekahi papa.   
\q1
\v 22 Elua no komo ko ka papa hookahi, ua like no ke kaawale ana o kekahi, a me kekahi. Pela no ia i hana'i no na papa a pau o ka halelewa.   
\q1
\v 23 A hana oia i papa no ka halelewa, he iwakalua papa no ka aoao hema ma ka hema.   
\q1
\v 24 A hana oia i hookahi kanaha kumu kala malalo iho o na papa he iwakalua; elua kumu malalo o ka papa hookahi, no kona mau komo elua, a elua hoi kumu malalo o kekahi papa no kona mau komo elua.   
\q1
\v 25 A no kela aoao hoi o ka halelewa, ma ke kihi akau, hana no oia i iwakalua papa,   
\q1
\v 26 A me ko lakou kumu kala he kanaha; elua kumu malalo iho o kekahi papa, elua hoi kumu malalo iho o kekahi papa.   
\q1
\v 27 A no na aoao o ka halelewa, ma ke komohana, hana oia i eono papa.   
\q1
\v 28 A hana oia i elua papa no na kihi o ka halelewa, ma na aoao elua.   
\q1
\v 29 A ua huiia ia mau mea malalo, a ua huiia ma na poo ma ke apo hookahi. Pela no oia i hana'i ia laua a elua, ma na kihi elua.   
\q1
\v 30 Ewalu no ia mau papa a o ko lakou mau kumu, he umikumamaono kumu kala, elua no kumu, a elua hoi kumu malalo o ka papa hookahi.   
\b  
\q1
\v 31 A hana no oia i mau laau ki, he laau sitima; i elima no na papa ma kekahi aoao o ka halelewa,   
\q1
\v 32 A i elima hoi ki no na papa o kekahi aoao o ka halelewa, a i elima hoi ki no na papa o ka halelewa no na aoao ma ke komohana.   
\q1
\v 33 A hana iho la oia i ka laau ki mawaenakonu, e puka loa, mai kekahi kala a i kekahi kala.   
\q1
\v 34 A wahi iho la oia i na papa i ke gula, a hana iho la i ko lakou mau apo, he gula, i wahi no na laau ki, a wahi iho la i na ki i ke guia.   
\b  
\q1
\v 35 A hana iho la oia i paku, he uliuli, a he ulaula, a he olona i hiloia, a hana no hoi i na kerubima, he hana na ka mea akamai.   
\q1
\v 36 A hana oia i eha kia nona, he laau sitima, a uhi oia ia mau mea i ke gula. He gula no ko lakou mau lou, a hoohehee oia no lakou i mau kumu kala eha.   
\b  
\q1
\v 37 Hana iho la no hoi oia i pale no ka puka komo o ka halelewa, he uliuli, he poni, he ulaula, a me ke olona i hiloia, ka hana a ka mea humuhumu lope ano e;   
\q1
\v 38 A me na kia ona elima, a me ko lakou mau lou; a uhi no hoi oia i ko lakou mau poo, a me ko lakou mau auka e paa ai i ke gula. Aka, he keleawe no ko lakou mau kumu elima.   
\c 37  
\b  
\q1
\v 1 A HANA iho la o Bezalela i ka pahu, he laau sitima; elua kubita a me ka hapalua kona loihi, a hookahi kubita a me ka hapalua kona laula; a hookahi kubita a me ka hapalua kona kiekie:   
\q1
\v 2 A uhi iho la oia ia mea i ke gula maikai, maloko, a mawaho, a hana iho la oia nona i lei gula a puni.   
\q1
\v 3 A hoohehee oia i eha apo gula nona, no kona mau kihi eha; i elua apo ma kekahi aoao ona, a i elua apo ma kekahi aoao ona.   
\q1
\v 4 A hana iho la oia i mau auamo laau sitima, a uhi iho la ia mau mea i ke gula.   
\q1
\v 5 Hookomo ae la oia i na auamo iloko o na apo, ma na aoao o ka pahu e amo ai i ka pahu.   
\b  
\q1
\v 6 A hana iho la oia i ka noho aloha, he gula maikai; elua kubita a me ka hapalua kona loa, a hookahi kubita a me ka hapalua kona laula.   
\q1
\v 7 A hana iho la oia i elua kerabima, he gula paa wale no, hookahi apana ia i hana'i ia laua ma na welau o ka noho aloha.   
\q1
\v 8 Hookahi kerubima ma kekahi welau, ma keia aoao, a o kekahi kerubima ma kekahi welau ma kela aoao. Maluna o ka noho aloha oia i hana'i i na kerubima, ma kona mau welau elua.   
\q1
\v 9 A hohola ae la na kerubima i ko laua mau eheu iluna, a uhi ao la ko laua mau eheu i ka noho aloha, a ku pono iho la ko laua mau maka kekahi i kekahi, ma ka noho aloha na maka o na kerubima.   
\b  
\q1
\v 10 Hana no hoi oia i ka papaaina, he laau sitima; elua kubita kona loa, hookahi kubita kona laula, a hookahi kubita a me ka hapa kona kiekie.   
\q1
\v 11 A uhi iho la oia ia i ke gula maikai, a hana ae la i lei gula nona a puni.   
\q1
\v 12 A hana no hoi oia i kae a puni ia mea, i hookahi lima ka laula, a hana ae la ia i lei gula no ua kae la a puni.   
\q1
\v 13 A hoohehee oia nona i eha apo gula, a kau oia i na apo ma na kihi eha ma kona mau wawae eha.   
\q1
\v 14 I ku pono na apo i ko kae, na wahi e komo ai na auamo e lawe i ka papaaina.   
\q1
\v 15 A nana iho la oia i na auamo, he laau sitima, a uhi iho la ia lakou i ke gula, i mea e lawe ai i ka papaaina.   
\q1
\v 16 A hana no hoi oia i ka oihana maluna o ka papa, i kona mau kiaha, a me kona mau puna, a me kona mau ipu, a me na poi e ninini ai, he gula maikai.   
\b  
\q1
\v 17 A hana iho la ia i ka ipukukui manamana he gula maikai, hana oia i ka ipukukui he gula wale no a paa, o kona kumu, a me kona lala, o kona mau puupuu, a me kona mau pua, oia apana hookahi no.   
\q1
\v 18 Eono no lala e puka ana mawaho o kona mau aoao; ekolu manamana o ka ipukukui mai kekahi aoao ona mai, a ekolu manamana o ka ipukukui, mai kela aoao ona mai.   
\q1
\v 19 Ekolu no ipu e like me na alemona ma ka mana hookahi, he puupuu, a me ka pua; a ekolu no ipu e like me na alemona ma kekahi mana, he puupuu a me ka pua: a pela wale no ma na manamana eono, e puka ana mawaho o ka ipukukui manamana.   
\q1
\v 20 Eha no ipu ma ke knmukukui, ua hanaia e like me na alemona, o kona mau puupuu, a me kona mau pua.   
\q1
\v 21 A he puupuu malalo o kona mau lala elua, a he puupuu malalo iho o kona mau lala elua, a he puupuu malalo iho o kona mau lala elua, e like me na lala eono, o puka mai ana mawaho ona.   
\q1
\v 22 Hookahi no apana ko lakou puupuu, a me ko lakou manamana. Hookahi no apana ia hana a pau, he gula maikai.   
\q1
\v 23 A hana no hoi oia i kona mau ipu aila ehiku, a me kona mau upaahi, a me kona mau upakolikukui, he gula maikai.   
\q1
\v 24 Hana no oia ia mea, a me kona oihana a pau, hookahi talena gula maikai.   
\b  
\q1
\v 25 A hana no hoi oia i ke kuahu no ka mea ala, he laau sitima: hookahi kubita kona loa, hookahi kubita kona laula, he ahalike; a elua kubita kona kiekie, a hookahi no ia apana me kona mau pepeiao elua.   
\q1
\v 26 A uhi oia ia mea i ke gala maikai, ma ko luna ona a me kona mau aoao a puni, a me kona mau pepeiao. A hana no hoi oia i lei gala a puni ia mea.   
\q1
\v 27 A hana iho la oia i elua apo gula nona, malalo iho o kona lei, ma kona mau kihi elua, ma na aoao ona elua, i wahi no na auamo, e amo ai ia mea.   
\q1
\v 28 A hana iho la oia i na auamo, he laau sitima, a uhi iho la ia mau mea i ke gula.   
\b  
\q1
\v 29 A hana iho la oia i ka aila poni laa, a me ka mea ala maikai i hua ala loa, e like me ka hana ana a ka mea kaawili laau.   
\c 38  
\b  
\q1
\v 1 A HANA no hoi oia i ke kuahu no ka mohaikuni: elima kubita kona loihi, a elima kubita kona laula, he ahalike: a ekolu kubita kona kiekie.   
\q1
\v 2 A hana oia i kona mau pepeiao, ma na kihi eha ona; no ia mea hookahi no na pepeiao, a uhi oia ia i ke keleawe.   
\q1
\v 3 A hana oia i na oihana a pau o ke kaahu, i na ipu, a me na papale, a me na kiaha, a me na o io, a me na ipu ahi; hana no oia i kona oihana a pau, he keleawe.   
\q1
\v 4 A hana no hoi oia no ke kuahu, i papa manamana pukapuka malalo iho o ke kae ona, mawaenakonu.   
\q1
\v 5 A hoohehee oia i eha mau apo no na welau eha o ua mea manamana keleawe la, i wahi no na auamo.   
\q1
\v 6 A hana oia i na auamo, he laau sitima, a ubi iho la ia laua i ko keleawe.   
\q1
\v 7 A hookomo oia i na auamo iloko o na apo ma na aoao o ke kuahu i mea e lawe ai, a hana oia i ke kuahu, he papa laau, ua kawaha.   
\b  
\q1
\v 8 A hana oia i ka ipu auau, he keleawe, ko loko o kona kumu, he keleawe, a me na aniani keleawe o ka poe e akoakoa nui ana, ka poe i akoakoa ma ka puka o ka halelewa o ke anaina.   
\b  
\q1
\v 9 A hana oia i ke kahua, ma ka aoao hema, ma ka hema hoi; a o na pale o ke kahua, he olona ia i hiloia, hookahi haneri kubita.   
\q1
\v 10 O ko lakou mau pou, he iwakalua, o ko lakou mau Kumu keleawe, he iwakalua. O na lou o na pou, a me ko lakou auka e paa ai, ne kala.   
\q1
\v 11 A no ka aoao akau, hookahi haneri kubita, o ko lakou mau pou, he iwakalua, a o ko lakou mau kumu keleawe, he iwakalua. O na lou o na pou, a me ko lakou auka e paa ai, he kala.   
\q1
\v 12 A no ka aoao komohana, he pale no, he kanalima kubita ka loihi, o ko lakou mau pou, he umi, a o ko lakou mau kumu he umi. O na lou o na pau a me ko lakou auka e paa ai, he kala.   
\q1
\v 13 A no ka aoao hikina ma na hikina, he kanalima kubita.   
\q1
\v 14 A o na pale ma kekahi aoao o ka puka, he umikumamalima kubita; a o ko lakou mau pau ekolu, a o ko lakou mau kumu, ekolu.   
\q1
\v 15 A no kela aoao o ka puka o ke kahua, he mau pale ma keia aoao a ma kela aoao, he umikumamalima kubita, o ko lakou mau pau ekolu, a o ko lakou mau kumu ekolu.   
\q1
\v 16 O na pale a pau a puni ke kahua, he olona no i hiloia.   
\q1
\v 17 A o na kumu no na pou, he keleawe ia. O na lou o na pou, a me ko lakou mau auka e paa ai, he kala no. A o ka uhi ana o ko lakou mau poo, he kala: a paa no na pau a pau o ke kahua i na auka kala.   
\q1
\v 18 A o ka pale o ka puka o ke kahua, he hana no ia a ka mea humuhumu lope ano e, he uliuli, he poni, he ulaula, he olona i hiloia: he iwakalua kubita ka loihi, a o ke kiekie ma ka laula, elima no kubita, e like me na pale o ke kahua.   
\q1
\v 19 A o ko lakou mau pou, eha, a. o ko lakou mau kumu, eha no, he keleawe; o ko lakou lou, he kala, a o ka uhi ana o ko lakou mau poo, a o ko lakou mau auka e paa ai, he kala no.   
\q1
\v 20 A o na makia a pau o ka halelewa, a me ke kahua e puni ana, he keleawe no ia.   
\b  
\q1
\v 21 Eia ka huina o ka halelewa, o ka halelewa hoi o ke kanawai, e like me ia i heluia, mamuli o ke kauoha a Mose, no ka hana a ko Levi, ma ka lima o Itamara, ke keiki a Aarona, ke kahuna.   
\q1
\v 22 A hana iho la o Bezalela, ke keiki a Uri, ke keiki a Hura, no ka ohana a Iuda, i na mea a pau a Iehova i kauoha mai ai ia Mose.   
\q1
\v 23 A me ia pu no o Aholiaba, ke keiki a Ahisamaka, no ka ohana a Dana, he kahuna kalai, he mea akamai i ka hana, a he mea humuhumu lope ano e, he uliuli, a he poni, a he ulaula, a me ke olona keokeo.   
\b  
\q1
\v 24 A o ke gula a pau i hanaia ma ka hana o ia mea laa, o ke gula laa he iwakaluakumamaiwa talena a me na sekela ehiku haneri me kanakolu, ma ka sekela o ke keenakapu.   
\q1
\v 25 A o ke kala o ka poe i heluia o ka aha kanaka, hookahi haneri talena, a me ka sekela hookahi tausani, ehiku haneri, me kanahikukumamalima, ma ka sekela o ke keenakapu.   
\q1
\v 26 He beka no kela kanaka keia kanaka, he hapalua sekela hoi, ma ka sekela o ke keenakapu, no kela mea keia mea i hele ae i ka helu ana, mai ka iwakalua o ka makahiki a keu aku, no na kanaka eono haneri kumamakolu tausani, elima haneri, a me kanalima.   
\q1
\v 27 A noloko o ia haneri talena kala, i hooheheeia'i na kumu o ke keenakapu, a me na kumu o ka paku: hookahi haneri kumu, noloko o ia mau haneri talena, hookahi talena, hookahi kumu.   
\q1
\v 28 A noloko mai o ke tausani sekela a me na haneri keu ehiku, a me kanahikukumamalima, hana iho la oia i mau lou no na pou, a uhi iho la i ko lakou poo, a hoopaa ne la ia lakou i na auka.   
\q1
\v 29 A o ke keleawe o ka haawina, he kanahiku ia mau talena, a me na sekela keu elua tausani, a me na haneri eha.   
\q1
\v 30 A noloko olaila hana ae la oia i na kumu no ka puka o ka halelewa o ke anaina kanaka, a me ke kuahu keleawe, a me kona papa manamana pukapuka, a me ka oihana a pau o ke kuahu,   
\q1
\v 31 A me na kumu o ke kahua a puni, a me na kumu o ka puka o ke Kahua, a me na makia a pau o ka halelewa, a me na makia a pau o ke kahua a puni.   
\c 39  
\b  
\q1
\v 1 A HANA lakou i lole hana, he uliuli, he poni, he ulaula, i mea hana maloko o kahi kapu, a hana no hoi lakou i na kahiko laa no Aarona, e like me ka Iehova i kauoha mai ai ia Mose.   
\b  
\q1
\v 2 A hana iho la oia i ka epoda, he gula, he uliuli, he poni, he ulaula, a me ke olona i hiloia.   
\q1
\v 3 A kui lakou i ke gula a lahilahi, a okioki iho la i kaula, i mea hana pu me ka uliuli, a me ka poni, a me ka ulaula, a me ke olona i hiloia, he hana na ka mea akamai.   
\q1
\v 4 Hana no hoi lakou i mau apana poohiwi no ka epoda, i mea e uhiia oia a paa. Ua huiia ma na kihi a elua.   
\q1
\v 5 A o ke kaei o kona epoda, ka mea maluna ona, o ia ano hookahi no, e like me ia i hanaia, he gula, he uliuli, he poni, he ulaula, a me ke olona i hiloia, me ka Iehova i kauoha mai ai ia Mose.   
\b  
\q1
\v 6 A hana iho la lakou i pohaku onika, i hoopaaia a puni iloko o na kawaha gula, i kahakahaia e like me ke kahakaha ana o na hoailona me na inoa o na keiki a Iseraela.   
\q1
\v 7 A kau aku la oia ia mau mea maluna o na poohiwi o ka epoda, i pohaku paipai manao no na mamo a Iseraela, me ka Iehova i kauoha mai ai ia Mose.   
\b  
\q1
\v 8 A hana iho la oia i ka paleumauma, he hana na ka mea akamai, e like me ka hana ana i ka epoda, he gula, he uliuli, he poni, he ulaula, a me ke olona i hiloia.   
\q1
\v 9 He ahalike ia; a hana lakou i ka paleumauma a papalua: hookahi kikoo kona loa, a hookahi kikoo kona laula, a ua papalua.   
\q1
\v 10 A kau lakou iloko olaila i eha lalani pohaku; he saredio, he topazo, he paea, oia ka lalani mua.   
\q1
\v 11 A o ka lalani lua, he omaomao he sapeiro, he daimana.   
\q1
\v 12 A o ka lalani kolu, he lesema, he ula, he ametuseto.   
\q1
\v 13 A o ka lalani aha, he berulo, he onika, he iasepi. Ua hoopaaia ia mau mea iloko o na kawaha gula, oia ko lakou mea i paa ai.   
\q1
\v 14 A ua like na pohaku me na keiki a Iseraela, he umikumamalua, ma ko lakou inoa, e like me ke kahakaha ana o ka hoailona, o kela mea keia mea ma kona inoa, ma na ohana he umikumamalua.   
\q1
\v 15 A hana no hoi lakou ma ka paleumauma i mau kaula ma na welau, he gula maikai i hiloia.   
\q1
\v 16 A hana lakou i elua kawaha gula, a elua hoi apo gula, a hookomo ae la i na apo elua iloko o na welau o ka paleumauma.   
\q1
\v 17 A hookomo lakou i na kaula gula elua i hiloia a i loko o na apo elua ma na welau o ka paleumauma.   
\q1
\v 18 A hoopaa lakou i na piko o na kaula kilo elua a i na kawaha elua, a kau aku la ia laua maluna o na apana poohiwi o ka epoda, a ma kona alo.   
\q1
\v 19 A hana iho la lakou i elua apo gula, a kau aku la ma na welau elua o ka paleumauma, ma kona kae, ma ka aoao maloko o ka epoda.   
\q1
\v 20 A hana no hoi lakou i elua apo gula, a kau aku la ia laua ma na aoao elua o ka epoda malalo iho, ma kona alo, e ku pono ana i ka huina, maluna o ke kaei o ka epoda.   
\q1
\v 21 A nakinaki lakou i ka paleumauma ma na apo ona, a paa i na apo o ka epoda me ke kaula uliuli, i kau ia maluna o ke kaei o ka epoda, i ole ai e weheia ka paleumauma mai ka epoda aku, me ka Iehova i kauoha mai ai ia Mose.   
\b  
\q1
\v 22 A hana iho la oia i ka holoku o ka epoda, he hana na ka mea ulana, he uliuli wale no.   
\q1
\v 23 A he puka no mawaena konu o ka holoku, e like me ka puka o ka puliki koa, ua pelupeluia a puni ka puka, i ole ia e nahae.   
\q1
\v 24 A hana lakou i mau pomegerane ma na lepa o ka holoku, he uliuli, he poni, he ulaula, a me ke olona i hiloia.   
\q1
\v 25 A hana no hoi lakou i mau bele he gula maikai, a kau aku la i na bele mawaena o na pomegerane, ma ka lepa o ka holoku a puni na pomegerane mawaena.   
\q1
\v 26 He bele a me ka pomegerane, he bele a me ka pomegerane, a puni ka lepa o ka holoku hana, me ka Iehova i kauoha mai ai ia Mose.   
\b  
\q1
\v 27 A hana no hoi lakou i mau palule, he olona i hiloia, o ka hana a ka mea ulana, no Aarona, a no kana mau keikikane,   
\q1
\v 28 A me ka papale hainaka, he olona keokeo, a me na papale migebo, he olona keokeo, a me na wawae, he olona i hiloia,   
\q1
\v 29 A me ke kaei he olona i hiloia, he uliuli, he poni, a me ka ulaula, he mea i humuhumuia: me ka Iehova i kauoha mai ai ia Mose.   
\b  
\q1
\v 30 A hana no hoi lakou i ka papa o ka papale laa, he gula maikai, a palapala iho la i ka palapala e like me ke kahakaha ana o ka hoailona, UA LAA NO IEHOVA.   
\q1
\v 31 A nakinaki lakou ia me ke kaula uliuli, i mea e paa ai ia maluna, ma ka papale; me ka Iehova i kauoha mai ai ia Mose.   
\b  
\q1
\v 32 A paa iho la ka hana a pau o ka halelewa, ka halelole hoi o ke anaina kanaka. A hana iho la na mamo a Iseraela, e like me na mea a pau a Iehova i kauoha mai ai ia Mose, pela lakou i hana'i.   
\b  
\q1
\v 33 A lawe mai lakou i ka halelewa ia Mose, i ka halelole, a me kona oihana a pau, i kona mau lou, i kona mau papa, i kona mau auka e paa ai, i kona mau pou, i kona mau kumu;   
\q1
\v 34 A me ka uhi ili hipakane i hooluu ulaula ia, a me ka uhi ili tehasa, a me ka paku e uhi ai;   
\q1
\v 35 I ka pahu kanawai, a me kona mau auamo, a me ka noho aloha;   
\q1
\v 36 I ka papaaina, a me kona oihana, a me ka berena hoike;   
\q1
\v 37 I ka ipukukui manamana maikai, a me kona mau ipu aila, e ku pololei ana, a me kona oihana a pau, a me ka aila no ka malamalama;   
\q1
\v 38 I ke kuahu gula, a me ka aila poni a me ka mea ala maikai, a me ka pale no ka puka o ka halelewa;   
\q1
\v 39 I ke kahua keleawe, a me kona pa keleawo manamana pukapuka, a me kona mau auamo, a me kona oihana a pau, i ka ipu auau a me kona kumu;   
\q1
\v 40 I na pale o ke kahua, a me kona mau pou, a me kona mau kumu, a me ka pale no ka puka o ke kahua, a me kona mau kaula, a me kona mau makia, a me na mea hana a pau no ka halelewa, no ka halelole o ke anaina kanaka;   
\q1
\v 41 I ka lole hana e hana'i iloko o kahi laa, a mo na kahiko laa no Aarona ke kahuna, a me na kahiko o kana mau keiki, e lawelawe ai ma ka oihana kahuna.   
\q1
\v 42 E like me ka Iehova i kauoha mai ai ia Mose, pela i hana'i na mamo a Iseraela i ka hana a pau.   
\q1
\v 43 A makaikai ae la o Mose i ka hana a pau, aia hoi, ua hana lakou ia e like me ka Iehova i kauoha mai ai, pela no lakou i hana'i. A hoomaikai ae la o Mose ia lakou.   
\c 40  
\b  
\q1
\v 1 OLELO mai la hoi o Iehova ia Mose, i mai la,   
\q1
\v 2 I ka la mua o ka malama mua, e kukulu oe i ka halelewa o ka halelole o ke anaina kanaka:   
\q1
\v 3 A e waiho oe maloko olaila i ka pahu kanawai, a e uhi i ka pahu i ka paku.   
\q1
\v 4 A e lawe oe i ka papaaina iloko, a e hoonohonoho i na ohana maluna iho; a e lawe mai hoi i ka ipukukui manamana, a e hoa hoi i kona mau ipu aila.   
\q1
\v 5 A e kau oe i ke kuahu gula no ka mea ala imua o ka pahu kanawai, a e kau aku i ka pale o ka puka o ka halelewa.   
\q1
\v 6 A e hoonoho oe i ke kuahu no ka mohaikuni imua o ka puka o ka halelewa o ka halelole o ke anaina kanaka.   
\q1
\v 7 A e kau oe i ka ipuanau mawaena o ka halelole o ke anaina kanaka, a me ke kuahu, a e ninini hoi i ka wai maloko.   
\q1
\v 8 A e kukulu oe i ka paku kahua a pau, a e kau aku i ka pale ma ka puka o ke kahua.   
\b  
\q1
\v 9 E lawe no hoi oe i ka aila poni, a e poni iho i ka halelewa, a me na mea a pau maloko, a e hoolaa ia mea, a me kona oihana a pau, a e lilo ia i mea laa.   
\q1
\v 10 A e poni no hoi oe i ke kuahu no ka mohaikuni, a me kana oihana a pau, a e hoolaa i ke kuahu, a e lilo ia i kuahu laa loa.   
\q1
\v 11 A e poni oe i ka ipuauau a me kona kumu, a e hoolaa ia mea.   
\b  
\q1
\v 12 A e lawe mai oe ia Aarona a me kana mau keikikane i ka puka o ka halelewa o ke anaina kanaka, a e holoi ia lakou i ka wai.   
\q1
\v 13 A e hookomo no oe maluna o Aarona i na kahiko laa, a e poni ia ia, a e hoolaa ia ia, i lawelawe oia na'u ma ka oihana kahuna.   
\q1
\v 14 A e lawe mai no hoi oe i kana mau keikikane, a e hookomo maluna o lakou i na palule:   
\q1
\v 15 A e poni oe ia lakou, e like me kou poni ana i ko lakou makuakane, i lawelawe lakou na'u ma ka oihana kahuna; no ka mea, he oiaio, e lilo ko lakou poni ana, i mea e kahuna mau loa ai, i ko lakou mau hanauna aku.   
\q1
\v 16 Pela o Mose i hana'i: e like me na mea a pau a Iehova i kauoha mai ai ia ia, pela no ia i hana'i.   
\b  
\q1
\v 17 A i ka malama mua o ka makahiki alua, i ka la mua o ka malama, ua kukuluia ka halelewa.   
\q1
\v 18 A kukulu o Mose i ka halelewa, a hoopaa iho la i kona mau kumu, a kukulu hoi i kona mau papa, a hookomo ae la i kona mau auka e paa ai, a kukulu no hoi i kona mau pou.   
\q1
\v 19 A haalii ae la oia i ka halelole maluna o ka halelewa, a kau aku la i ka uhi o ka halelole maluna aku; e like me ka Iehova i kauoha mai ai ia Mose.   
\b  
\q1
\v 20 A lawe oia, a waiho aku la i ke kanawai iloko o ka pahu, a hoonoho i ka noho aloha maluna ma ka pahu.   
\q1
\v 21 A lawe ae la oia i ka pahu iloko o ka halelewa, a kau aku la maluna i ka paku e uhi ai, a uhi ae la i ka pahu kanawai; e like me ka Iehova i kauoha mai ai ia Mose.   
\b  
\q1
\v 22 A waiho aku la oia i ka papaaina iloko o ka halelole o ke anaina kanaka, ma ka aoao akau o ka halelewa, mawaho o ka paku.   
\q1
\v 23 A hoonohonoho oia i ka berena maluna olaila, imua o Iehova; e like me ka Iehova i kauoha mai ai ia Mose.   
\b  
\q1
\v 24 A kau aku la oia i ka ipukukui manamana maloko o ka halelewa o ke anaina e ka pono ana i ka papaaina, ma ka aoao hema o ka halelewa.   
\q1
\v 25 A hoa iho la oia i na kukui imua o Iehova; e like me ka Iehova i kauoha mai ai ia Mose.   
\b  
\q1
\v 26 A waiho aku la oia i ke kuahu gula maloko o ka halelole o ke anaina kanaka, imua o ka paku.   
\q1
\v 27 A puhi iho la oia i ka mea ala maikai maluna olaila; e like me ka Iehova i kanoha mai ai ia Mose.   
\b  
\q1
\v 28 A kau aku la oia i ka pale o ka puka o ka halelewa.   
\q1
\v 29 A waiho aku la oia i ke kuahu o ka mohaikuni ma ka puka o ka halelewa o ka halelole o ke anaina kanaka, a kaumaha aku la maluna olaila i ka mohaikuni, a me ka mohaiai; e like me ka Iehova i kauoha mai ai ia Mose.   
\b  
\q1
\v 30 A kau aku la oia i ka ipuanau mawaena o ka halelole o ke anaina kanaka, a me ke kuahu, a ninini iho la i ka wai iloko, i mea e holoi ai.   
\q1
\v 31 A holoi no Mose, a me Aarona, a me kana mau keikikane i ko lakou mau lima, a me ko lakou mau wawae malaila.   
\q1
\v 32 A ia lakou i komo ai iloko o ka halelole o ke anaina kanaka, a ia lakou i hookokoke ai i ke kuahu, holoi no lakou; me ka Iehova i kauoha mai ai ia Mose.   
\q1
\v 33 A kukula no hoi oia i ka paku kahuna a puni ka halelewa a me ke kuahu, a kau aku la i ka pale o ka puka o ke kahua; pela o Mose i hoopau ai i ka hana.   
\b  
\q1
\v 34 Alaila, uhi mai la ke ao i ka halelole o ke anaina kanaka, e hoopiha mai la ka nani o Iehova i ka halelewa.   
\q1
\v 35 Aole hiki ia Mose ke komo iloko o ka halelole o ke anaina kanaka, no ka mea, kau mau no ke ao maluna olaila, a hoopiha hoi ka nani o Iehova i ka halelewa.   
\q1
\v 36 A i ka pii ana o ke ao mai ka halelewa aku, alaila, hele aku la na mamo a Iseraela i ko lakou hele ana a pau.   
\q1
\v 37 A i ole e pii aku ke ao, alaila, aole lakou i hele, a hiki i ka la i pii aku ai ia.   
\q1
\v 38 No ka mea, aia no maluna o ka halelewa, ua ao la o Iehova i ke ao, a he ahi hoi maluna olaila i ka po, imua o na maka o ko ka hale a pau o ka Iseraela, i ko lakou hele ana a pau.   