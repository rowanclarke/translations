\id ZEP - Biblica® Open Ndebele Contemporary Bible 
\h UZefaniya 
\toc1 UZefaniya 
\toc2 UZefaniya 
\toc3 Zef 
\mt1 UZefaniya 
\c 1  
\p  
\v 1 Ilizwi \nd likaThixo\nd* elafika kuZefaniya indodana kaKhushi, indodana kaGedaliya, indodana ka-Amariya, indodana kaHezekhiya, ekubuseni kukaJosiya indodana ka-Amoni inkosi yakoJuda: 
\b  
\s1 Isixwayiso Ngencithakalo Ezayo 
\q1  
\v 2 “Ngizakhucula konke 
\q2 ebusweni bomhlaba,” 
\q2 kutsho \nd uThixo\nd*. 
\q1  
\v 3 “Ngizakhucula kokubili abantu lezinyamazana; 
\q2 ngizakhucula izinyoni zasemoyeni 
\q2 kanye lenhlanzi zasolwandle, 
\q2 lezithombe ezenza ababi bakhubeke. 
\b  
\q1 Lapho ngiqeda abantu 
\q2 ebusweni bomhlaba,” 
\q2 kutsho \nd uThixo\nd*. 
\s1 Ukumelana LoJuda 
\q1  
\v 4 “Ngizakwelulela isandla sami koJuda 
\q2 lakubo bonke abahlala eJerusalema. 
\q1 Ngizaqeda konke okukaBhali okuseleyo kule indawo, 
\q2 amabizo abahedeni labaphristi abakhonza izithombe 
\q1  
\v 5 labo abakhothama phezu kwezindlu 
\q2 bakhonze ixuku lezinkanyezi, 
\q1 labo abakhothama bafunge \nd ngoThixo\nd*, 
\q2 abafunga langoMoleki futhi, 
\q1  
\v 6 labo ababuyela emuva bedela ukulandela \nd uThixo\nd* 
\q2 njalo abangamdinganga \nd uThixo\nd* loba babuze ngaye. 
\b  
\q1  
\v 7 Thula phambi \nd kukaThixo\nd* Wobukhosi, 
\q2 ngoba usuku \nd lukaThixo\nd* seluseduze. 
\q1 \nd UThixo\nd* uselungise umhlatshelo; 
\q2 usebangcwelisile labo abanxusileyo. 
\b  
\q1  
\v 8 Ngosuku lomhlatshelo \nd kaThixo\nd* 
\q2 ngizajezisa izikhulu 
\q2 lamadodana amakhosi labo bonke 
\q1 labo abagqoke 
\q2 izigqoko zezizweni. 
\q1  
\v 9 Ngalolosuku ngizabajezisa 
\q2 bonke abaxwaya ukunyathela umbundu womnyango, 
\q1 abagcwalisa ithempeli labonkulunkulu 
\q2 babo ngodlakela langenkohliso.” 
\b  
\q1  
\v 10 \nd UThixo\nd*, uthi, 
\q1 “Ngalolosuku ilizwi lokukhala 
\q2 lizaqonga ngaseSangweni leNhlanzi, 
\q1 ukulila kuvelela esiGabeni eSitsha 
\q2 lomsindo omkhulu wokufohloza uvela emaqaqeni. 
\q1  
\v 11 Lilani lina elihlala esigodini sokuthengisela saseMakhithashi, 
\q2 bonke abathengisi benu bazaqedwa, 
\q2 bonke abathengiselana ngesiliva bazabhujiswa. 
\q1  
\v 12 Ngalesosikhathi ngizaphenya iJerusalema ngezibane 
\q2 ngijezise labo abangakhathaliyo, 
\q2 abanjengewayini elitshiywe phakathi kwensipho zalo, 
\q1 abathi, \nd ‘UThixo\nd* kayikwenza lutho, 
\q2 oluhle loba olubi.’ 
\q1  
\v 13 Inotho yabo izaphangwa, 
\q2 izindlu zabo zidilizwe. 
\q1 Bazakwakha izindlu 
\q2 kodwa bangahlali kuzo; 
\q1 bazahlanyela izivini, 
\q2 kodwa iwayini bangalinathi.” 
\b  
\q1  
\v 14 Usuku olukhulu \nd lukaThixo\nd* seluseduze, 
\q2 njalo luza ngokuphangisa. 
\q1 Lalelani! Ukukhala ngosuku \nd lukaThixo\nd* 
\q2 kuzakuba buhlungu, lokuklabalala kwebutho khonapho. 
\q1  
\v 15 Lolosuku luzakuba lusuku lolaka, 
\q2 usuku losizi lokudabuka; 
\q3 usuku lokuhlupheka lokuchitheka, 
\q2 usuku lomnyama lokudana, 
\q3 usuku lwamayezi lobumnyama, 
\q2  
\v 16 usuku lwecilongo lokuhlaba umkhosi wokulwa impi 
\q1 lamadolobho avikelweyo 
\q2 kanye lezinqaba zasemajikweni. 
\b  
\q1  
\v 17 “Ngizaletha usizi ebantwini 
\q2 njalo bazahamba njengeziphofu, 
\q2 ngoba bonile \nd kuThixo\nd*. 
\q1 Igazi labo lizachithwa njengothuli 
\q2 lezibilini zabo njengamanyala. 
\q1  
\v 18 Isiliva sabo loba igolide labo 
\q2 kakungeke kwenelise ukubasindisa 
\q2 ngosuku lolaka \nd lukaThixo\nd*. 
\b  
\q1 Umhlaba wonke uzatshiswa emlilweni 
\q2 womona wakhe 
\q1 ngoba uzakwenza isiphetho ngokuphangisa 
\q2 kubo bonke abahlala emhlabeni.” 
\c 2  
\s1 IJuda LeJerusalema Yahlulelwa Kanye Lezinye Izizwe. 
\s2 UJuda Ukhuthazwa Ukuthi Aphenduke 
\q1  
\v 1 Buthanani ndawonye, buthanani ndawonye, 
\q2 wena sizwe esiyangisayo, 
\q1  
\v 2 isikhathi esimisiweyo singakafiki 
\q2 losuku ludlule njengamakhoba, 
\q1 ukuthukuthela okwesabekayo \nd kukaThixo\nd* 
\q2 kungakafiki kuwe, 
\q1 usuku lolaka \nd lukaThixo\nd* 
\q2 lungakafiki kuwe. 
\q1  
\v 3 Dingani \nd uThixo\nd*, lonke lina abathobekileyo belizwe, 
\q2 lina elenza lokho akulayayo. 
\q1 Dingani ukulunga, dingani ukuthobeka; 
\q2 mhlawumbe lingavikelwa 
\q2 ngosuku lwentukuthelo \nd kaThixo\nd*. 
\s1 Ukumelana LeFilistiya 
\q1  
\v 4 IGaza izadelwa 
\q2 le-Ashikheloni isale isingamanxiwa. 
\q1 Abantu base-Ashidodi bazaxotshwa emini, 
\q2 le-Ekroni isitshulwe. 
\q1  
\v 5 Maye kini lina elihlala ngasolwandle, 
\q2 lina sizwe samaKherethi; 
\q1 ilizwi \nd likaThixo\nd* limelana lani, 
\q2 wena Khenani, lizwe lamaFilistiya. 
\q1 “Ngizakutshabalalisa, 
\q2 njalo kakho ozasala.” 
\q1  
\v 6 Ilizwe elingasolwandle 
\q2 lizakuba yindawo yabelusi 
\q2 lezibaya zezimvu. 
\q1  
\v 7 Ilizwe lizakuba 
\q2 ngelabaseleyo abendlu kaJuda; 
\q2 bazathola amadlelo khona. 
\q1 Kusihlwa bazalala phansi 
\q2 ezindlini zase-Ashikheloni. 
\q1 \nd UThixo\nd* uNkulunkulu wabo uzabalondoloza; 
\q2 uzabenza baphumelele futhi. 
\s1 Ukumelana LeMowabi Le-Amoni 
\q1  
\v 8 “Ngizizwile izithuko zeMowabi 
\q2 lokuchothoza kwama-Amoni, 
\q1 abathuka abantu bami 
\q2 besongela lelizwe labo. 
\q1  
\v 9 Ngakho ngeqiniso elinjengoba ngikhona,” 
\q2 kutsho \nd uThixo\nd* uSomandla, 
\q2 uNkulunkulu ka-Israyeli, 
\q1 “impela iMowabi izakuba njengeSodoma, 
\q2 ama-Amoni abe njengeGomora, 
\q1 indawo yokhula lemigodi yetshwayi, 
\q2 ilizwe elichithekileyo nini lanini. 
\q1 Abaseleyo babantu bami bazabaphanga; 
\q2 abaphephileyo babantu bami bazathatha ilizwe labo.” 
\b  
\q1  
\v 10 Lokhu yikho abazakuthola kungumvuzo wokuzigqaja kwabo, 
\q2 ngenxa yokuthuka lokuklolodela 
\q2 abantu \nd bakaThixo\nd* uSomandla. 
\q1  
\v 11 \nd UThixo\nd* uzakwesabeka kubo 
\q2 lapho esetshabalalisa bonke onkulunkulu belizwe. 
\q1 Izizwe ezisemakhunjini wonke zizamkhonza, 
\q2 ngulowo elizweni lakhe. 
\s1 UKumelana LeKhushi 
\q1  
\v 12 “Lani futhi, lina maKhushi 
\q2 lizabulawa ngenkemba yami.” 
\s1 Ukumelana Le-Asiriya 
\q1  
\v 13 Uzakwelulela isandla sakhe enyakatho 
\q2 achithe i-Asiriya, 
\q1 atshiye iNiniva itshabalele ngokupheleleyo 
\q2 njalo yome njengenkangala. 
\q1  
\v 14 Imihlambi yezimvu leyenkomo izalala phansi khonapho, 
\q2 lezidalwa zezinhlobo zonke. 
\q1 Isikhova senkangala lomandukulo 
\q2 kuzahlala ensikeni zakhe. 
\q1 Ukukhala kwazo kuzezwakala emawindini, 
\q2 imfucuza izakuba eminyango, 
\q2 imijabo yemisedari ichayeke. 
\q1  
\v 15 Leli lidolobho elingakhathaliyo 
\q2 elalizihlalele livikelekile. 
\q1 Lazitshela lathi: 
\q2 “Ngiyimi, kakho omunye ngaphandle kwami.” 
\q1 Yeka ukuchitheka eseliyikho, 
\q2 isikhundla sezinyamazana zeganga! 
\q1 Bonke abadlula kulo bahleka usulu 
\q2 balikhombe ngeminwe. 
\c 3  
\s1 Ikusasa LeJerusalema 
\q1  
\v 1 Maye kulo idolobho labancindezeli, 
\q2 elihlamukayo lelingcolileyo! 
\q1  
\v 2 Kalilaleli muntu, 
\q2 kalivumi kukhuzwa. 
\q1 Kalithembeli \nd kuThixo\nd*, 
\q2 kalisondeli kuNkulunkulu walo. 
\q1  
\v 3 Izikhulu zalo 
\q2 ziyizilwane ezibhongayo, ababusi balo 
\q1 bazimpisi zakusihlwa, 
\q2 ezingatshiyi lutho lwekuseni. 
\q1  
\v 4 Abaphrofethi balo bayazazisa; 
\q2 bangabantu bamacebo amabi. 
\q1 Abaphristi balo bangcolisa indawo engcwele 
\q2 bephule lomthetho. 
\q1  
\v 5 \nd UThixo\nd* phakathi kwalo ulungile; 
\q2 kenzi okubi, 
\q1 nsuku zonke ekuseni wenza ukulunga kwakhe 
\q2 njalo kaphambanisi ukusa kwamalanga wonke, 
\q2 ikanti abangalunganga kabalanhloni. 
\s2 IJerusalema Yala Ukuphenduka 
\q1  
\v 6 “Ngizichithile izizwe; 
\q2 izinqaba zazo zidiliziwe. 
\q1 Ngitshiye imigwaqo yazo ideliwe 
\q2 kungekho odlula khona. 
\q1 Amadolobho azo adiliziwe; 
\q2 kakho ozasala kakho lamunye. 
\q1  
\v 7 Ngathi kulo idolobho, 
\q2 ‘Impela uzangesaba 
\q2 uvume ukukhuzwa!’ 
\q1 Lapho-ke indlu yalo yokuhlala yayingayikudilizwa 
\q2 loba isijeziso sami sehlele phezu kwalo. 
\q1 Kodwa babelokhu betshisekela izenzo zokuxhwala 
\q2 kukho konke abakwenzayo. 
\q1  
\v 8 Ngakho ngilindela,” kutsho \nd uThixo\nd*, 
\q2 “lolusuku engizasukuma ngalo ngifakaze. 
\q1 Sengimise ukubuthanisa izizwe, 
\q2 ngiqoqe imibuso, 
\q1 ngehlisele ulaka lwami phezu kwabo 
\q2 konke ukuthukuthela kwami okukhulu. 
\q1 Umhlaba wonke uzaqothulwa 
\q2 ngomlilo womona wentukuthelo yami.” 
\s1 Ukuvuselelwa Kwensalela Yako-Israyeli 
\q1  
\v 9 “Lapho-ke ngizahlambulula izindebe zezizwe, 
\q2 ukuze zonke zikhuleke ebizweni \nd likaThixo\nd* 
\q2 zimkhonze zimanyane. 
\q1  
\v 10 Kusukela ngaphetsheya kwemifula yaseKhushi 
\q2 abakhonzi bami, abantu bami abahlakazekileyo, 
\q2 bazangilethela iminikelo. 
\q1  
\v 11 Ngalolosuku kaliyikuyangiswa 
\q2 ngobubi bonke elabenza kimi, 
\q1 ngoba ngizabasusa kulelidolobho 
\q2 abathokoziswa yikuzigqaja kwabo. 
\q1 Kaliyikuzikhukhumeza futhi 
\q2 entabeni yami engcwele. 
\q1  
\v 12 Kodwa ngizatshiya phakathi kwenu 
\q2 abathambileyo labathobekileyo, 
\q2 abathembele ebizweni \nd likaThixo\nd*. 
\q1  
\v 13 Kabayikwenza okubi; 
\q2 kabayikuqamba amanga, 
\q1 loba kube lenkohliso 
\q2 emilonyeni yabo. 
\q1 Bazakudla balale phansi, 
\q2 kakho ozabenza besabe.” 
\b  
\q1  
\v 14 Hlabela wena Ndodakazi yeZiyoni, 
\q2 klabalala kakhulu, wena Israyeli! 
\q1 Thaba uthokoze ngenhliziyo yakho yonke 
\q2 wena ndodakazi yaseJerusalema! 
\q1  
\v 15 \nd UThixo\nd* usesisusile isijeziso sakho, 
\q2 usesixotshile isitha sakho. 
\q1 \nd UThixo\nd*, iNkosi ka-Israyeli, ulawe; 
\q2 akulangozi ozaphinda uyesabe futhi. 
\q1  
\v 16 Ngalolosuku bazakuthi kulo iJerusalema, 
\q2 “Ungesabi, 
\q1 wena Ziyoni; 
\q2 ungavumeli ukuba izandla zakho zibe buthakathaka. 
\q1  
\v 17 \nd UThixo\nd* uNkulunkulu wakho ulawe, 
\q2 ulamandla okusindisa. 
\q1 Uzathokoza kakhulu ngawe, 
\q2 uzakududuza ngothando lwakhe, 
\q2 uzakuthokozela ngokuhlabelela.” 
\b  
\q1  
\v 18 “Insizi zemikhosi emisiweyo 
\q2 ngizazisusa kuwe; 
\q2 zingumthwalo lehlazo kuwe. 
\q1  
\v 19 Ngalesosikhathi ngizababona 
\q2 bonke abalincindezelayo; 
\q1 ngizahlenga abaqhulayo 
\q2 ngibuthe lalabo abahlakazwayo, 
\q1 ngizabapha udumo lenhlonipho 
\q2 kuwo wonke amazwe lapho abahlaziswa khona. 
\q1  
\v 20 Ngalesosikhathi ngizalibutha; 
\q2 ngalesosikhathi ngizalisa ekhaya. 
\q1 Ngizalipha inhlonipho lodumo 
\q2 phakathi kwezizwe zonke zasemhlabeni 
\q1 lapho sengiliphumelelisa futhi 
\q2 phambi kwamehlo enu uqobo,” 
\q2 kutsho \nd uThixo\nd*.