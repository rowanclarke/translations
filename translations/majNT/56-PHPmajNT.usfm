\id PHP Mazatec of Jalapa de Díaz
\h Xu̱ju̱n xi kin'ekjíhi̱ xu̱ta̱ ni̱nku̱ Filipo̱
\toc1 Xu̱ju̱n xi kits'ínkjihi̱ nda̱ postru̱ Pablo̱ xu̱ta̱ ni̱nku̱ Filipo̱
\toc2 Xu̱ju̱n xi kin'ekjíhi̱ xu̱ta̱ ni̱nku̱ Filipo̱
\toc3 Fil.
\mt1 Xu̱ju̱n xi kits'ínkjihi̱ nda̱ postru̱ Pablo̱ xu̱ta̱ ni̱nku̱ Filipo̱
\c 1
\s1 B'i̱ ts'ín kikjaniñaha̱ Pablo̱ xu̱ta̱ ni̱nku̱ xi tjín nanki Filipo̱
\p 
\v 1 An Pablo̱ ko̱ Timoteo̱, ji̱n xi tín'exát'ai̱hi̱ Jesucristo̱. Ngayjee̱ jun xi tintsu̱bo̱o nanki Filipo̱, jun xi kikj'áts'e̱nu̱u Jesucristo̱ tísuniñai̱hi̱ ko̱ ta̱ tísuniñai̱hi̱ já xi basehe̱ xu̱ta̱ ni̱nku̱ ko̱ já xi ta̱ tjíhi̱n xá.
\p 
\v 2 Kas'enu̱u kju̱a̱nda ko̱ kju̱a̱jyu xi tsjáná Nti̱a̱ Na̱'miná ko̱ Nda̱ Nti̱a̱ná Jesucristo̱.
\s1 B'i̱ ts'ín kitsúya Pablo̱ xi nkú ts'ín nchja̱ntjai xu̱ta̱ ni̱nku̱ Filipo̱
\p 
\v 3 Tsjaha̱ máb'a̱chjíhi̱ Nti̱a̱ná xki̱ nga f'áítsjenna jun.
\v 4 Xki nga nchjaka̱ Nti̱a̱ná nchjantjáínu̱u ngatentoo̱. Tsjo mana nga b'a̱ ts'ian
\v 5 a̱t'aha̱ nkuhú maka̱á xinki̱á nga tín'exát'aha̱á én nda tsuhu̱ Jesucristo̱. B'aha̱ ra̱ ni̱stjin nga tjun tsichujinnu̱u ée̱n ko̱ santaha nd'a̱i̱.
\v 6 Behe̱ k'an nga xi kik'atuts'i̱hi̱n ni xi nda a̱jinnu̱u, kui xi tu̱ nku ngju̱a̱i̱ko̱ndjuhú santaha ni̱stjin nga kj'u̱a̱í ngáha Jesucristo̱.
\p 
\v 7 A̱jin ani̱ma̱na̱ tintsu̱ba̱jiun, kui nga f'áítsjehenna jun. Xian nga nda ts'ian nga f'áítsjenna jun a̱t'aha̱ nkuhú kju̱a̱ndaha̱ Nti̱a̱ná tísakúná jun ko̱ an, ndaha tsa nu̱ba̱yá kjíi̱ya'yán ko̱ ndaha tsa nginku̱n já tjíxóo̱ tíxinya chich'an én nda tsuhu̱ Jesucristo̱ ko̱ tíb'ejñá chja nga najmi én tiya niu̱.
\v 8 Nti̱a̱ná be xi nkú ts'ín mjena jun. Kju̱a̱tjoho̱ Jesucristo̱ xi tíjñajinna, kui xi tjoko̱ho̱nu̱u.
\p 
\v 9 Nk'ie nga nchjantjáínu̱u, bankihi̱ Nti̱a̱ná nga 'yún kasaá sa kju̱a̱tjo xi tjínnu̱u, ko̱ nga 'yún kas'enu̱u kju̱a̱nkjintak'un, ko̱ nga kixi̱ ka̱mankjinnu̱u ni xi ts'e̱ Nti̱a̱ná.
\v 10 B'a̱ ts'ín ka̱ma chj'a̱jihinnu má nihi xi kju̱axi̱ nga nda tu̱ xi je ku̱i̱ntsu̱ba̱hanu ko̱ najmi s'e̱ ni xi n'e̱nijéhe̱nu̱u ni̱stjin nga kj'u̱a̱í ngáha Cristo̱.
\v 11 Kui ni̱stjiu̱n ku̱a̱kuchjíú nkjin tíkjá ni xi na̱xu̱ kin'o, xi kitsjánu̱u Jesucristo̱ nga n'o̱o tu̱ xi s'e̱jña chjihi kju̱a̱chánkaha̱ Nti̱a̱ná ko̱ n'e̱tsjoho̱ ra̱.
\s1 B'i̱ ts'ín kitsúya Pablo̱ nga ngandaha̱ tíma ni xi tíf'ajin
\p 
\v 12 Mjena nga cho̱o, já nts'e, nga ni xi tímat'an e̱i̱, kui xi tu̱ sahá títs'ín nga tífindju én nda tsuhu̱ Jesucristo̱.
\v 13 A̱t'aha̱ tíbe ngayjee̱ já juhu̱n nda̱ títjuu̱n ko̱ ngayjee̱ xu̱ta̱ xingisoo̱ nga nga̱t'aha̱ Cristo̱ kjíi̱ya'yúhunna.
\v 14 Tu̱ nga̱t'aha̱ nga kjíi̱ya'yán, nkjin já nts'eé 'yún tíi̱ncha ma 'yún k'un Nda̱ Nti̱a̱ná ko̱ tíi̱ncha ma k'un tíb'éni̱jmí éhe̱n.
\p 
\v 15 Kju̱axi̱ nga tjín xi tíb'éni̱jmí ni xi kits'ín Cristo̱ a̱t'aha̱ tíma xintak'un ko̱ mjehe̱ nga ts'i̱ín ngana̱. Tu̱nga tjíhín ngá xi ngayjehe ani̱ma̱ha̱ tíb'éni̱jmí.
\v 16 Xi tíma xintak'un, kui xi tíi̱ncha b'éni̱jmí Cristo̱ a̱t'aha̱ ngandaha̱ tíi̱ncha bangisjai. Najmi kju̱axi̱hi̱ nga b'a̱ tíi̱ncha ts'ín. Ni xi i̱ncha mje níhi̱ nk'ie nga tu̱ sahá 'yún sa̱kúna kju̱a̱ni̱ma̱ nk'ie nga kjíi̱ya'yán.
\v 17 Tu̱nga máha xu̱ta̱ xingisoo̱, tíi̱ncha b'éni̱jmí Cristo̱ a̱t'aha̱ tjíhi̱n ku̱a̱tjo. Be nga kjíi̱ya e̱i̱ tu̱ xi xínya chich'ihinna én nda tsuhu̱ Nti̱a̱ná nginku̱n já tjíxóo̱.
\p 
\v 18 Tu̱nga najmi chumi ni ts'i̱hín ra̱. Ndaha tsa najmi kju̱axi̱hi̱ ko̱ ndaha tsa ngayjehe k'un nga tíi̱ncha b'éni̱jmí, xi tu̱ ja ní tís'eni̱jmíhi ni xi kits'ín Cristo̱ ko̱ kui niu̱ xi tsjo mana. Ko̱ 'yún s'e̱ sana kju̱a̱tsjo.
\v 19 A̱t'aha̱ be nk'ie nga tu̱ nga̱t'aha̱ nga tíchubantjáínú nginku̱n Nti̱a̱ná ko̱ xi nkú ts'ín títsjá nga'yúnna Espiri̱tu̱hu̱ Jesucristo̱ ku̱i̱tju'a.
\v 20 Mje ṉkjúnna ko̱ tíkuyá nga ndaha̱chí najmi sa̱kúna kju̱a̱suba. Tu̱ sa ní 'yún ndjá kúási̱njña nd'a̱i̱ xi nkú nga títs'in tehe̱nte, ko̱ cha̱ kju̱a̱chánkaha̱ Cristo̱ a̱jihi̱n ni xi tímat'ain yjonintena̱. B'a̱ ka̱ma tsa tíi̱jña ko̱ tsa ja kabaya.
\p 
\v 21 A̱t'aha̱ an bi nk'ie nga tíi̱jña tík'un sa, Cristo̱ tíi̱jña tík'uhunna. Ko̱ tsa ni xi tíbayahana, tu̱ sahá ts'in ngana̱ka̱.
\v 22 Tsa kúáte̱jña tík'un sa, 'yún xúbáya xána̱. Najmi be má nihi xi kj'uajián.
\v 23 A̱t'aha̱ síi̱jñaya masehe̱n nga joo̱ niu̱. Mjena k'uejñá a̱sunntee̱ ko̱ kfínsehe̱ Cristo̱. Tsa ni xi kfínsehe̱ ra̱ Cristo̱, tu̱ sahá 'yún nda tjín nga̱t'a ts'a̱n.
\v 24 Tu̱nga nga̱t'aha̱ ní ngandanu̱u 'yún machjén saha̱ nga kúáte̱jña tík'un sa.
\v 25 Behe̱ k'an nga b'a̱ tjín niu̱, kui nga behena nga kúáte̱jña tík'un sahana ko̱ nga k'u̱a̱ndaya sana a̱jinnu̱u, tu̱ xi 'yún s'e̱jin saha̱nu̱u ko̱ tsjo k'úénu̱u nga b'a̱ n'o̱o.
\v 26 B'a̱ ts'ín nk'ie nga ku̱i̱chuse ngáha̱nu̱u, tsjo ka̱manu̱u nga n'e̱tsjoho̱o Cristo̱ Jesu.
\s1 B'i̱ ts'ín kitsúyaha̱ Pablo̱ xu̱ta̱ ni̱nku̱ nga tu̱ nku ndjáhá ku̱i̱ncha
\p 
\v 27 Nkuhú nga ti̱ntsu̱ba̱hanu xi nkú ts'ín tje̱he̱n ra̱ xu̱ta̱ xi y'a én nda tsuhu̱ Cristo̱. Kui nga tsa kfínsenu̱u, skue, ko̱ tsa kjin kúáte̱jña, kuint'e én xi nkú ts'ín tintsu̱bo̱o, nga ndjá tincho, nga nkuhú ni xi n'e̱nkjíntak'un, ko̱ nga nkuhú tín'e mo yjonu̱u nga ta̱ ñja ta̱ ñja tín'o̱o nga'yún ngandaha̱ én nda tsuhu̱ Cristo̱ xi s'ejinná.
\v 28 Ndaha̱chí najmi tu̱ binkjun já kontra̱nu̱u. Kui niu̱ xi ku̱a̱kúchjihi̱ xu̱ta̱ xu'bo̱ nga ndyja̱ ko̱ nga jun xi n'e̱k'ankinu̱u. Nti̱a̱ná tsjánu̱u nga n'e̱ ngano̱o.
\p 
\v 29 A̱t'aha̱ jun bi kik'a̱i̱nu̱u nga s'e̱jinnu̱u Cristo̱, tu̱nga ta̱ kik'a̱i̱hínu̱u nga nga̱t'aha̱ ta̱ cho̱o kju̱a̱ni̱ma̱.
\v 30 B'a̱ ta̱ ts'ín tíbitjajíún kju̱a̱ni̱ma̱ nd'a̱i̱ xi nkúhu kju̱a̱ni̱ma̱ xi kiyo nga j'a̱jian ko̱ xi tínu'yó nd'a̱i̱.
\c 2
\s1 B'i̱ ts'ín tsakúya Pablo̱ xi nkú ts'ín tjíhin nga s'e̱yaná
\p 
\v 1 Kui b'a̱ maha tsa Cristo̱ basinko̱nu̱u, ko̱ tsa kju̱a̱tjoho̱ tsjá nga'yúnnu̱u, ko̱ tsa Espiri̱tu̱hu̱ nkuhú títs'ín manu̱u, ko̱ tsa nda tíchasoho̱o ko̱ tíma ni̱ma̱nu̱u xinki̱u,
\v 2 kui nga n'e̱henu nga tu̱ xí tsjohó kat'ena. Nkuhú kas'eyanu̱u ko̱ nkuhú kju̱a̱tjo xi kas'eya ani̱ma̱nu̱u. Nkuhú ch'a̱ xinki̱u ko̱ nkuhú ni xi n'e̱nkjíntak'un.
\v 3 Ndaha nku ni najmi tu̱ n'o tsa tu̱ xi n'e̱ ngana̱ha̱ ru̱u xinki̱u ko̱ tsa tu̱ xi nk'a n'e̱sjehenu yjonu̱u. Tu̱ sa ní ni̱ma̱kju̱a̱ n'e̱sjo yjonu̱u ko̱ cha̱so̱ho̱ xinki̱u, cha̱so̱ho̱ xi nkúhu tsa 'yún nk'a tje̱n nga jun.
\v 4 Najmi tu̱ nku ni xi ts'a̱jun chasoho̱, ta̱ cha̱so̱ho̱ ni xi ts'e̱ já nts'o.
\p 
\v 5 B'a̱ ta̱ ts'ín kas'eyanu̱u xi nkú ts'ín kis'eyaha̱ Cristo̱ Jesu.
\v 6 Kui xi tu̱ b'a̱ ts'ín Nti̱a̱náhá, tu̱nga najmi kits'ínnisihí ni nga y'éjña chji nga kui xi Nti̱a̱ná.
\v 7 Tu̱ sa ní y'éch'oho̱ yjoho̱ yáha kui ko̱ nku nda̱ musu̱ kits'ín ma yjoho̱ nga j'ai tsin xi nkú ts'ín tsin xu̱ta̱.
\v 8 Ko̱ nk'ie nga kik'a yjoninte, kinte ts'asje yjoho̱. Kint'é'éhe̱n Nti̱a̱ná santaha nga ngji ngabayoo̱. Kruu̱ kin'ek'ient'á.
\p 
\v 9 Kui kju̱a̱ha Nti̱a̱ná 'yún tse kju̱a̱chánka kitsjáha̱ ra̱, ko̱ kitsjáha̱ nku j'áín xi tu̱ xí 'yúhún nk'a tje̱n,
\v 10 tu̱ xi nk'ie nga ku̱i̱nú'yáha j'áíhi̱n Jesu ku̱i̱nchakúnch'in tu̱ yáhá ni xi tjín ndji̱o̱jmi ján ko̱ a̱sunntee̱ ko̱ kinte t'anankiu̱.
\v 11 Ko̱ ngayjee̱ xi tjín b'a̱ ku̱i̱tsu̱ nga Jesucristo̱ xi Nti̱a̱. B'a̱ ts'ín s'e̱jña chjihi kju̱a̱chánkaha̱ Nti̱a̱ Na'miu̱.
\s1 B'i̱ ts'ín tsakúya Pablo̱ xi nkú ts'ín k'úéntu xu̱ta̱ ni̱nku̱ a̱jihi̱n xu̱ta̱
\p 
\v 12 Kui b'a̱ maha, jun já nts'ena̱, xi nkú ts'ín tehe̱nte kinu'yá'énnú nk'ie nga tsáte̱jñajinnu̱u, b'a̱ ta̱ n'o̱o nd'a̱i̱ nk'ie nga kjin tíi̱jñanu̱u. Cha̱nkjún Nti̱a̱ná ko̱ kat'atsó nga n'e̱ndju̱ú ni xi títs'ín Nti̱a̱ná a̱jinnu̱u nga títs'ínk'ankinu̱u.
\v 13 A̱t'aha̱ xi nkú ts'ín sasíhi̱n Nti̱a̱ná, kui xi títs'ín nga n'e̱ mjo ko̱ nga n'o̱o ni xi mjehe̱.
\p 
\v 14 Tsa tjín ni xi n'o̱o, najmi tu̱ katuma stinu̱u nga b'a̱ n'o ko̱ najmi tu̱ chubatiko̱o xinki̱u,
\v 15 tu̱ xi je ko̱ na̱xu̱ sku̱e̱he̱nu̱u xu̱ta̱. Jun xi ntíhi̱ Nti̱a̱ná ko̱ tjíhin nga je ku̱i̱ntsu̱ba̱jiuhu̱n xu̱ta̱ xi tjín nd'a̱i̱ xi ch'onk'un ko̱ xi ja kits'ínkatsún kju̱a̱nkjintak'uhu̱n. Katumo a̱jihi̱n xu̱ta̱ xu'bo̱ xi nkúhu niñu xi tíbat'ai má jyuu̱n.
\v 16 Chu̱bani̱jmíyahanu én xi ts'ínk'íéntu tík'uhu̱n xu̱ta̱. Tsa b'a̱ n'o̱o, tsjo k'úéna ni̱stjin nga kj'u̱a̱í ngáha Cristo̱. A̱t'aha̱ nk'ie ka̱ma chji nga najmi tu̱ kju̱a̱ndahá kits'ian nga'yún nga kits'inxá a̱jinnu̱u.
\p 
\v 17 Nk'ie nga s'ejinnu̱u Nti̱a̱ná, b'a̱ joyaha tsa chje̱ tí'bo̱ho̱o Nti̱a̱ná. Ko̱ tsa n'e̱k'ienna e̱i̱, an xi ku̱i̱chú ma xi nkú joyaha chje̱ xi ts'i̱ínndju̱út'a chje̱ xi tí'bo̱ho̱ Nti̱a̱ná. Tu̱nga tsjohó tjínna ndaha tsa b'a̱ n'e̱na. Ta̱ n'e̱tsjoko̱ho kju̱a̱tsjona̱.
\v 18 B'a̱ ta̱ ts'ín tsjo katumanu̱u ko̱ ta̱ tjennú kju̱a̱tsjonu̱u.
\s1 B'i ts'ín kitsúyaha̱ Pablo̱ xu̱ta̱ Filipo̱ nga ts'i̱ínkjisehe̱ Timoteo̱
\p 
\v 19 Tsa Nda̱ Nti̱a̱ná Jesu tsjánte, ki̱tsa̱ ts'inkjísenu̱u Timoteo̱ tu̱ xi tsjo ka̱mahana nga kuint'e ni xi tíma a̱jinnu̱u.
\v 20 Najmi tjín sana kj'a̱í xi nkúhu kui, xi b'a̱ ta̱ ts'ín ts'ínnkjink'un xi nkúhu an nga kjinta̱ha̱ ra̱ jun.
\v 21 A̱t'aha̱ kj'a̱í xu̱ta̱ha bi ni xi ts'e̱ bangisjai, najmi ni xi ts'e̱ Jesucristo̱.
\p 
\v 22 Tu̱nga jahá yo xi nkú k'un Timoteo̱ ko̱ xi nkú ts'ín títs'ínxáko̱na nga tíb'éni̱jmíko̱na én nda tsuhu̱ Jesucristo̱, xi nkú joyaha nku nda̱ti xi ts'ínxáko̱ na̱'mihi̱.
\v 23 Kui nga tíb'endáhana nga kui ts'inkjísenu̱u chu̱ba̱ nga skue xi nkú ts'ín s'e̱nda ni xi tíf'a̱jian.
\v 24 Ko̱ behe̱ k'an nga Nda̱ Nti̱a̱ná ta̱ tsjántena nga ka̱ma kfínsenu̱u.
\s1 B'i ts'ín kitsúyaha̱ Pablo̱ xu̱ta̱ Filipo̱ nga títs'ínkjisehe̱ Epafrodito̱
\p 
\v 25 Tu̱nga nd'a̱i̱ títs'innkjíhi̱n k'an nga tjíhin nga ta̱ ts'inkjísehé ngáha̱nu̱u nda̱ nts'eé Epafrodito̱. Kui xi títs'ínxáko̱na nga tíf'ajinko̱na kju̱a̱ni̱ma̱ nga̱t'aha̱ Cristo̱. Kui xi y'exó nga kin'e nibásenú tu̱ xi ku̱a̱si̱nko̱hona nga ts'i̱ín ni xi machjénna.
\v 26 Tu̱ xí tíma bahá ra̱ jun ko̱ kjinta̱ha̱ ra̱ jun, a̱t'aha̱ be nga kinu'yó nga kisaté ch'in.
\v 27 Kju̱axi̱ kjáíhin nga 'yún ndjáhá kisaté ch'in, nga ja ma ku̱a̱yáhá kai. Tu̱nga Nti̱a̱náhá tsase ni̱ma̱ha̱ nga kits'ínnkihi̱. Ko̱ najmi tu̱ suba kui xi tsase ni̱ma̱ha̱ Nti̱a̱ná, ta̱ tsase ni̱ma̱na ko̱ an, a̱t'aha̱ tsa k'ien ndo̱ 'yún kama tse kju̱a̱bana̱ kai.
\p 
\v 28 Kui nga ki̱tsa̱ mjehena nga ts'inkjísehe̱nu̱u tu̱ xi tsjo k'úéhe̱nu̱u nga cha̱ ngáhanu ko̱ tu̱ xi najmi ta̱ 'yún s'e̱nta̱hana.
\v 29 N'e̱kjóho̱on ndo̱ xi nkú ts'ín tje̱he̱n ra̱ xu̱ta̱ xi ts'e̱ Nda̱ Nti̱a̱ná. Tsjo kat'enu̱u nga b'a̱ n'o̱o. Cha̱nkjún xu̱ta̱ xi b'a̱ k'un xi nkúhu kui.
\v 30 A̱t'aha̱ nga̱t'aha̱ xáha̱ Cristo̱ ja ma k'ienntjáíhí ni kai. Kitsjá yjoho̱ ndaha tsa ja ma k'iehén tu̱ xi ts'i̱íntjusuhun ngandana̱ xá xi kik'a̱i̱hi̱ru̱u.
\c 3
\s1 B'i̱ ts'ín kitsúya Pablo̱ nkú ts'ín y'éjña ni xi kis'ehe̱
\p 
\v 1 Kui b'a̱ maha, já nts'ena̱, tsjo kat'enu̱u a̱t'aha̱ Nda̱ Nti̱a̱ná Jesucristo̱ tíjñajinnu̱u. Najmi tífehe̱ k'an nga ta̱ kui ta̱ maha ni xi tíb'et'ánu̱u, a̱t'aha̱ ngandanu̱u niu̱.
\p 
\v 2 Chúhu̱un yjonu̱u já ch'onk'un xi ja yo, xi ch'onk'un xá xi títs'ín, xi mjehe̱ nga n'e̱ circuncision tiya.
\v 3 A̱t'aha̱ circuncision xi ndoo̱, kui xi kich'aá ñá xi yankjáán Nti̱a̱ná xi nkú ts'ín bakúyaná Espiri̱tu̱hu̱ Nti̱a̱ná ko̱ ma 'yún k'aán nga̱t'aha̱ ni xi kits'ín Cristo̱ Jesu, najmi nga̱t'aha̱ ni xi n'ehe̱ yjonintená.
\p 
\v 4 An bi ka̱ma ṉkjún ka̱ma 'yún k'an ntje̱ xi y'ahana. Najmi tjín kj'a̱í xi b'a̱ ts'ín ka̱ma 'yún k'un nii̱ xi nkúhu an,
\v 5 nga a̱jihi̱n xu̱ta̱ xi ntje̱ Israel tje̱he̱n ra̱ kitsian ko̱ kin'ena ni circuncision nga tjínna jin ni̱stjin nga kitsian. Ntje̱ cháni̱ Benjamin tje̱henna. Xu̱ta̱ hebreo̱hó xi chána̱. Nku nda̱ fariseo̱ xi 'yún kits'íntjusun chich'in kju̱a̱téxumaha̱ Moise kama.
\v 6 Kui kju̱a̱téxumoo̱ 'yún kikuhu̱n nga santaha kitsjennkí unkie xu̱ta̱ ni̱nku̱hu̱ Cristo̱. Na̱xu̱ tsáte̱jña xi nkú ts'ín bakúya kju̱a̱téxumoo̱. Najmi tjín xi ch'on ts'ín kinchja̱yanena nga̱t'a ts'e̱ kui nii̱.
\p 
\v 7 Nk'ie bi, nga̱t'a ts'a̱n 'yún chjíhi̱ ra̱ ngatentee̱ ni xu'bi̱, tu̱nga nd'a̱i̱ tu̱ nga̱t'a ts'e̱ Cristo̱ xi nkú joyaha ni xi najmi chumi ni chjíhi̱ ra̱ kits'in ma kui niu̱.
\v 8 Nd'a̱i̱ b'a̱ xian nga najmi chumi ni chjíhí ra̱ ngayjee̱ niu̱, a̱t'aha̱ ja be Cristo̱ Jesu. Kui xi Nda̱ Nti̱a̱na̱ maha ko̱ kui xi 'yún chjí saha̱ ra̱ nga tu̱ mí nihí ni. Nga̱t'aha̱ Cristo̱ kits'inndyja ngayjee̱ ni xi tjínna tu̱ xi ka̱ma ts'in ngana̱hana Cristo̱. Nd'a̱i̱ nk'ie nga basehe̱ ni xi kindyjoo̱, b'a̱ mana xi nkúhu tsa stjé niu̱ mana.
\v 9 Mjena kúáte̱jñajian ni xi kits'ín Cristo̱. Nk'ie kits'intjusan kju̱a̱téxumoo̱. Kuenta̱ ts'a̱n tsangisja nga na̱xu̱ ku̱i̱chú ma nginku̱n Nti̱a̱ná. Tu̱nga nd'a̱i̱hí s'ejinna Jesucristo̱. Kui nga Nti̱a̱ná títsjáhana nga na̱xu̱ tíi̱jña nginku̱n tu̱ nga̱t'aha̱ nga s'ejinna.
\p 
\v 10 Ni xi mjena nd'a̱i̱, mjena nga skue sisian Cristo̱ ko̱ nga'yúhu̱n Nti̱a̱ná xi kits'ínkj'áíya ngáha̱ ra̱ Cristo̱ ngabayoo̱. Mjena nga ta̱ sa̱kúna kju̱a̱ni̱ma̱ xi kits'ínkjáíhi̱n. Mjena b'a̱ k'úé xi nkú kik'ie Cristo̱ nk'ie nga k'ien
\v 11 tu̱ xi ta̱ kj'u̱a̱íyahana ko̱ an a̱jihi̱n xu̱ta̱ k'ie̱n.
\s1 B'i̱ ts'ín kitsúya Pablo̱ ni xi kingjásihi̱n nga y'ejña
\p 
\v 12 Najmi b'a̱ tíxian tsa ja kisakúna ni xi kuaxian ko̱ a ra̱ tsa ja kama yá xi tjíhin nga ka̱ma. Tu̱nga tu̱ nku tífi tje̱nnkiná ni xi kuaxian, tu̱ xi sa̱kúhuna ni xi kama mjehe̱ Cristo̱ Jesu nk'ie nga kisakúhu̱ an.
\v 13 Jun já nts'e, najmi b'a̱ mana tsa ja kisakúna niu̱. Ni xi títs'inná, títs'inchaya ni xi chóo̱ ko̱ títs'in kju̱a̱'yúhún ra̱ yjona̱ tu̱ xi sa̱kúhuna ni xi ni̱ba a̱skahan.
\v 14 Cristo̱ Jesu ts'ínchjén Nti̱a̱ná nga tínchja̱ná nk'a ján. An bi tífi tje̱nnkia ni xi títsu nga tsjáha̱ xi nt'é éhe̱n.
\p 
\v 15 B'a̱ ts'ín tjíhin nga s'e̱yahaná ñá xi ja tsichu maá xi tjíhin nga ka̱maá. Ko̱ tsa tjín xi kj'a̱í ts'ín s'e̱yaha̱, Nti̱a̱ná ta̱ k'u̱éjña chjihi̱ ni xu'bo̱.
\v 16 Tu̱nga tjíhín ni nga tu̱ nku ndjáhá ku̱i̱nchajián ni xi ja kin'ekjáíhi̱ín santaha nd'a̱i̱.
\p 
\v 17 Jun já nts'e, b'a̱ n'o̱o xi nkú nga títs'ian ko̱ ta̱ cha̱se̱ chu̱ba̱yoho̱o xu̱ta̱ xi b'a̱ ta̱ tíi̱ncha ts'ín xi nkú ts'ín kik'iejña chu̱ba̱yai̱hi̱.
\v 18 A̱t'aha̱ nkjin maha xi tjíntu xi nkúhu tsa tu̱ kju̱a̱ndahá kin'ek'ien Cristo̱ a̱t'a kruu̱. Ja ma nkjin ni̱yá b'a̱ xinnu̱u ko̱ nd'a̱i̱ santaha tíi̱nta ts'íhinna nga tíxinyanu̱u xi nkú ts'ín tjíyaha̱ xu̱ta̱ xu'bo̱.
\v 19 Kui xi tíi̱ncha fi má nga ndyja̱, ko̱ ni xi i̱ncha mjehe̱ s'e̱he̱ kui xi nti̱a̱ha̱. Tíi̱ncha bangisjai kju̱a̱chánka a̱jihi̱n ni xi tu̱ subahá maná, ko̱ tu̱ nku ni xi ts'e̱hé a̱sunntee̱ tjíntuyáha̱ kju̱a̱nkjintak'uhu̱n.
\p 
\v 20 Tu̱nga máha ñá, nanki xi tíjña nk'a ján tje̱he̱nná. Yo̱hó nankiná má nga tíchuyáha̱á nga ni̱bajehen Nda̱ Nti̱a̱ná Jesucristo̱ xi ts'i̱ínk'ankiná.
\v 21 Tjíhi̱n nga'yún nga ku̱a̱téxumaha̱ ngatentee̱ ni xi tjín ko̱ ts'i̱ínchjén nga'yúhu̱n nga ts'i̱ínk'óntjaiya yjoninte x'a̱n xi kich'aá nd'a̱i̱. Xi nkú ts'ín tjíhi̱n kju̱a̱chánka yjonintehe̱, b'a̱ ta̱ ts'i̱ínk'íé xi ts'a̱ñá.
\c 4
\s1 B'i̱ ts'ín kitsúya Pablo̱ ni xi i̱ncha ts'i̱ín xu̱ta̱ ni̱nku̱ Filipo̱
\p 
\v 1 Kui b'a̱ maha, já nts'ena̱, tjo ṉkjúnna jun ko̱ f'áítsjenna jun. Jun xi kju̱a̱tsjona̱ ko̱ nga chjihi̱ xána̱. Tu̱ nku b'a̱ n'e̱ ndjáhá ti̱nchajiun Nda̱ Nti̱a̱ná, jun xu̱ta̱ tjona̱.
\p 
\v 2 Tíbankihi̱ na̱ Ebodi̱a̱ ko̱ tíbankihi̱ na̱ Sinti̱ke̱ nga kanchja̱ko̱ nda ngáha xinkjín a̱t'aha̱ nkuhú Nda̱ Nti̱a̱ná i̱ncha yjanki.
\v 3 Ko̱ ji ta̱ tíbankihi nga ti̱si̱nko̱i̱ jminchjíu̱n, ji xi b'a̱ ta̱ tsu xá xi tín'ei. A̱t'aha̱ nga y'eni̱jmíá yo̱, kui jminchjíu̱n ta̱ y'éni̱jmí én nda tsuhu̱ Nti̱a̱ná, xi nkú nga ta̱ kits'ín nda̱ Clemente̱ ko̱ xu̱ta̱ xingisoo̱ xi kits'ínxáko̱na. Kui xi ja tjíntut'á j'áíhi̱n xu̱ju̱n má nga tjíntut'á j'áíhi̱n xu̱ta̱ xi k'úéntu tík'un sín.
\p 
\v 4 Kas'enu̱u kju̱a̱tsjoho̱ Nda̱ Nti̱a̱ná. B'a̱há ta̱ tíxin ngáha̱nu̱u. Tsjo kat'enu̱u.
\v 5 Ngatentee̱ xu̱ta̱ i̱ncha kate nga nda ani̱ma̱nu̱u. Ja tíjña tiña Nda̱ Nti̱a̱ná.
\p 
\v 6 Najmi tu̱ chumi nihi xi fanta̱ha̱ ru̱u yjonu̱u. Tu̱ sa ní tehe̱nte t'inyoho̱o Nti̱a̱ná ni xi machjénnu̱u nga chu̱bako̱o. Ti̱nchíhu̱u ko̱ ta̱ tjoho̱on máb'a̱chjíhi̱ ni xi tí'ba̱i̱nu̱u.
\v 7 Kju̱a̱jyuhu̱ Nti̱a̱ná xi najmi mankjihi̱n xu̱ta̱, kui xi kúhu̱n ani̱ma̱nu̱u ko̱ tsjáni̱yá xi nkú ts'ín n'e̱nkjínk'un a̱t'aha̱ Cristo̱ Jesu ts'e̱nu̱u.
\p 
\v 8 Ko̱ ni xi fekuhu, já nts'e, tíbankinu̱u nga n'e̱nkjínk'un ni xi na̱xu̱ tjín, ni xi yankjún, ni xi nda, ni xi je, ni xi tsjo k'un, ni xi nda chasehe̱. Ngayjee̱ ni xi 'yún nda ko̱ ni xi sasínná, kui nii̱ xi n'e̱nkjínk'un.
\v 9 N'e̱tjusun ni xi tsakuyánu̱u ko̱ xi kixinyanu̱u nga n'o̱o, ni xi kinu'yó nga kinchja ko̱ xi kiyo nga kits'ian. B'a̱ n'o̱o ko̱ k'úéjñajinnu̱u Nti̱a̱ná xi tsjáná kju̱a̱jyu.
\s1 B'i̱ ts'ín kitsjáha̱ Pablo̱ máb'a̱chjíhi̱ xu̱ta̱ ni̱nku̱ Filipo̱ a̱t'aha̱ tsasinko̱ho̱
\p 
\v 10 'Yún títsjána kju̱a̱tsjo Nda̱ Nti̱a̱ná nga ta̱ kis'enta̱há ngáha̱nu̱u an. Kju̱axi̱ nga tehe̱nte kjinta̱ha̱nu̱u an, tu̱nga santahá ni nd'a̱i̱ kisakú ni̱yánu̱u nga tsisinko̱nú.
\v 11 Najmi tsuhu̱ ra̱ tsa ndyjat'ana tsa mí nihi, tsa kui nga b'a̱ tíxihi̱nnu̱u. A̱t'aha̱ ja kamankjinna nga tsjo k'úéna a̱jihi̱n tu̱ mí nihí ni xi ka̱mat'an.
\v 12 Be xi nkú ts'ín bintsu̱ba̱jián kju̱a̱x'a̱n ko̱ ta̱ be xi nkú ts'ín bintsu̱ba̱jián kju̱a̱nchi̱ná. Ja kama nkana tu̱ mí nihí ni, tsa tsé sisinna ko̱ tsa ka̱ma bjona, tsa 'yún s'e̱na ni ko̱ tsa najmi chumi nihi xi s'e̱na.
\v 13 Ts'in chúkju̱a̱ tu̱ mí nihí ni, a̱t'aha̱ Cristo̱ tsjá nga'yúnna.
\v 14 Tu̱nga ndahá tín'o nga tíbisinko̱nú a̱jihi̱n kju̱a̱ni̱ma̱ xi tíf'a̱jian.
\p 
\v 15 Jun xu̱ta̱ ni̱nku̱ nanki Filipo̱, yo ni xu'bi̱. Nk'ie nga tjun y'eni̱jmínu̱u én nda tsuhu̱ Jesucristo̱ ko̱ nk'ie nga tsitja a̱nte Macedoni̱a̱, a̱jihi̱n xu̱ta̱ ni̱nku̱ xingisoo̱ tu̱ nkuhú jun xi tsisinko̱nú. Kik'a̱i̱nú xi nkú tjín kitsjánu̱u Nti̱a̱ná.
\v 16 Santaha nga tsáte̱jña nanki Tesaloni̱ka̱, nku jo ni̱yá ta̱ kin'ekjínú ni xi kamachjénna.
\v 17 Najmi chje̱ xi tí'ba̱i̱nú tíbangisja. Tíbangisja níná nga 'yún kas'e sanu̱u kju̱a̱nchi̱ná nginku̱n Nti̱a̱ná.
\p 
\v 18 Ja kits'inkjáíhi̱n ngayjee̱ ni xi kin'e nibánú ko̱ santaha tíb'anki tímana nd'a̱i̱. Ni xi kin'e nibáko̱nú Epafrodito̱, kui xi kits'ínndju̱ú ngayjee̱ ni xi machjénna. Kui niu̱ xi nkú joyaha nku chje̱ sinjne̱ xi ts'ínkjáíhi̱n Nti̱a̱ná ko̱ sasíhi̱n.
\v 19 Tsjánu̱u Nti̱a̱ná ngatentee̱ ni xi machjénnu̱u, xi nkú ts'ín tíjñajin kju̱a̱nchi̱ná chánka xi sakújinná Cristo̱ Jesu.
\v 20 ¡Nti̱a̱ná xi Na̱'miná maha, kui xi kayaha̱ kju̱a̱chánkaha̱ santaha tu̱ nkjéhé ni! B'a̱ katuma.
\s1 B'i̱ ts'ín kits'ínkje Pablo̱ xu̱ju̱i̱n
\p 
\v 21 Tjoho̱on kju̱a̱suniñana̱ ngatentee̱ xu̱ta̱ xi ts'e̱ Cristo̱ Jesu. Títs'ínkjinu̱u kju̱a̱suniña já nts'eé xi tjíntuko̱na e̱i̱.
\v 22 Títs'ínkjinu̱u kju̱a̱suniña ngatentee̱ xu̱ta̱ xi ts'e̱ Nti̱a̱ná xi tjín e̱i̱. Ko̱ xi tíi̱ncha ts'ínxá ni'yaha̱ nda̱ títjun k'aku̱ Cesa̱r, kui xi 'yún títs'ínkji sanu̱u kju̱a̱suniña.
\p 
\v 23 Kat'ejñajinnu̱u kju̱a̱ndaha̱ Nda̱ Nti̱a̱ná Jesucristo̱.
