\id OBA
\h ئوبادىيا 
\toc1 ئوبادىيا 
\toc2 ئوبادىيا 
\toc3 ئ‍وب. 
\mt1 ئوبادىيا  
\c 1
\s1 ئېدومنىڭ بەربات بولۇشى  
\m
\v 1 ئوبادىيا كۆرگەن ئالامەت كۆرۈنۈش: ــ  
\m رەب پەرۋەردىگار ئېدوم توغرۇلۇق مۇنداق دەيدۇ: ــ  
\m (بىز پەرۋەردىگاردىن بۇ خەۋەرنى ئاڭلاشقا مۇيەسسەر بولدۇق)  
\m ــ «بىر ئەلچى ئەللەر ئارىسىغا ئەۋەتىلدى؛  
\m ئۇ: «ئورنۇڭلاردىن تۇرۇڭلار، بىز ئۇنىڭغا قارشى جەڭ قىلىش ئۈچۈن تۇرايلى!» ــ دەپ خەۋەر بېرىدۇ. \f ◼ \fr 1:1 \ft \+bd «بىر ئەلچى ئەللەر ئارىسىغا ئەۋەتىلدى»\+bd* ــ «ئەللەر» (ياكى «يات ئەللەر») ــ ئىسرائىلغا يات بولغان ئەللەرنى كۆرسىتىدۇ. \+bd «ئورنۇڭلاردىن تۇرۇڭلار، بىز ئۇنىڭغا قارشى جەڭ قىلىش ئۈچۈن تۇرايلى!»\+bd* ــ «ئۇنىڭغا» بولسا، ئېدومغا. بەلكىم بۇ ئەلچى ئېدومغا دۈشمەن ئەللەرنىڭ بىرىدىن چىققان بولۇپ، ئۇ باشقا ئەللەرنى ئېدومنى يوقىتىشقا چاقىرىدۇ.\f*   
\m
\v 2 مانا، مەن سېنى ئەللەر ئارىسىدا كىچىك قىلدىم؛  
\m سەن \add ئەللەر ئارىسىدا\add* قاتتىق كەمسىتىلگەن خەلق بولىسەن! \f ◼ \fr 1:2 \ft \+bd «مەن سېنى ئەللەر ئارىسىدا كىچىك قىلدىم؛ سەن ئەللەر ئارىسىدا قاتتىق كەمسىتىلگەن خەلق بولىسەن!»\+bd* ــ خۇدا ئېدومنى «سېنى» دەپ، مۇشۇ يەردە ئۇنىڭغا بىۋاسىتە سۆز قىلىدۇ.\f*   
\m
\v 3 ھەي تىك قىيانىڭ يېرىقلىرى ئىچىدە تۇرغۇچى،  
\m تۇرالغۇسى يۇقىرى بولغۇچى،  
\m كۆڭلۈڭدە: «كىم مېنى يەرگە چۈشۈرەلىسۇن؟!» دېگۈچى،  
\m كۆڭلۈڭدىكى تەكەببۇرلۇق ئۆزۈڭنى ئالداپ قويدى! \f ◼ \fr 1:3 \ft \+bd «تىك قىيانىڭ يېرىقلىرى ئىچىدە تۇرغۇچى، تۇرالغۇسى يۇقىرى بولغۇچى»\+bd* ــ دېمىسەكمۇ، ئېدوم پىنھانراق، ئۈستىگە چىقىش تەس بولغان تاغلىق رايوندا تۇرغان.\f*   
\m
\v 4 سەن بۈركۈتتەك ئۆزۈڭنى يۇقىرى كۆتۈرسەڭمۇ،  
\m چاڭگاڭنى يۇلتۇزلار ئارىسىغا تىزساڭمۇ،  
\m مەن شۇ يەردىن سېنى چۈشۈرۈۋېتىمەن،  
\m ــ دەيدۇ پەرۋەردىگار. \x ◘ \xo 1:4 \xt يەر. 49‏:16\x*   
\m
\v 5 بۇلاڭچىلار قېشىڭغا كەلسىمۇ،  
\m ئوغرىلار كېچىلەپ يېنىڭغا كىرسىمۇ،  
\m (ھەي، شۇنچە ئۈزۈپ تاشلىنىسەن!)  
\m ئۇلار ئۆزلىرىگە چۇشلۇقلا ئوغرىلايتتى ئەمەسمۇ؟  
\m ئۈزۈم ئۈزگۈچىلەر يېنىڭغا كەلسىمۇ، ئازراق ۋاساڭلارنى قالدۇرىدۇ ئەمەسمۇ؟ \f ◼ \fr 1:5 \ft \+bd «ھەي، شۇنچە ئۈزۈپ تاشلىنىسەن!»\+bd* ــ تىرناق ئىچىدىكى سۆزلەر، بەلكىم پەيغەمبەرنىڭ ھاياجاندىن پەرۋەردىگارنىڭ سۆزىنى ئۈزۈپ قويۇپ دېگەن گېپىدۇر. \+bd «ئۈزۈم ئۈزگۈچىلەر يېنىڭغا كەلسىمۇ، ئازراق ۋاساڭلارنى قالدۇرىدۇ ئەمەسمۇ؟»\+bd* ــ مۇسا پەيغەمبەرگە چۈشۈرۈلگەن قانۇن بويىچە ئۈزۈم ھوسۇلىنى ئالغاندا ئۈزگۈچىلەر كەمبەغەللەرنىڭ تېرىۋېلىشى ئۈچۈن بىرئاز ۋاساڭلارنى قالدۇرۇش كېرەك ئىدى. بەزى شەرقىي دۆلەتلەردە بۇ بىر ئادەتكە ئايلىنىپ قالغان.\f*  \x ◘ \xo 1:5 \xt يەر. 49‏:9\x*   
\m
\v 6 بىراق ئەساۋنىڭ تەئەللۇقاتى قانداق ئاختۇرۇلدى!  
\m ئۇنىڭ يوشۇرۇن بايلىقلىرى قانداق تېپىپ چىقىلدى! \f ◼ \fr 1:6 \ft \+bd «... ئەساۋنىڭ تەئەللۇقاتى قانداق ئاختۇرۇلدى!»\+bd* ــ «ئەساۋ» ئېدومنىڭ باشقا بىر ئىسمى. \+bd «... ئۇنىڭ يوشۇرۇن بايلىقلىرى قانداق تېپىپ چىقىلدى!...»\+bd* ــ 5-6-ئايەتلەر «مەرسىيە» (ماتەم تۇتۇش مۇناجىتى) شەكلىدە.\f*   
\m
\v 7 بارلىق ئىتتىپاقداشلىرىڭ سېنى چېگرايىڭغىچە ھەيدىۋېتىدۇ؛  
\m سەن بىلەن ئىناق ئۆتكەنلەر سېنى ئالداپ، ئۈستۈڭدىن غەلىبە قىلىدۇ؛  
\m نېنىڭنى يېگەنلەر ساڭا قىلتاق قۇرىدۇ؛  
\m \add سەن\add* دەرۋەقە يورۇتۇلمىغاندۇرسەن! \f ◼ \fr 1:7 \ft \+bd «سېنى... ھەيدىۋېتىدۇ؛ ... ئۈستۈڭدىن غەلىبە قىلىدۇ؛ ... ساڭا قىلتاق قۇرىدۇ...»\+bd* ــ 5-7-ئايەتلەردە ئېيتىلغان بېشارەتلەردىكى پېئىللار «ئۆتكەن زامان» بىلەن ئىپادىلىنىدۇ. لېكىن ئۇلار كەلگۈسى ئىشلارنى كۆرسىتىدۇ (8-ئايەتتە ئېنىق كۆرسىتىلىدۇ). ئىبرانىي تىلىدا، بېشارەتلەردە پېئىللارنىڭ «ئۆتكەن زامان»دا ئىشلىتىشى «بۇ ئىش جەزمەن يۈز بېرىدۇ» دېگەننى تەكىتلەيدۇ. \+bd «... سەن بىلەن ئىناق ئۆتكەنلەر سېنى ئالداپ، ئۈستۈڭدىن غەلىبە قىلىدۇ؛ نېنىڭنى يېگەنلەر ساڭا قىلتاق قۇرىدۇ»\+bd* ــ بۇ ئايەت بەلكىم ئەرەبلەرنىڭ ئېدومىيلارنى ئالدام خالتىسىغا چۈشۈرۈپ، ئۇلارنى ئۆز زېمىنىدىن ھەيدىۋېتىشى توغرۇلۇق بېشارەت بېرىدۇ (ۋەقە بەلكىم مىلادىيەدىن ئىلگىرىكى 6-ئەسىرنىڭ ئاخىرىدا بولغان). ئىبرانىي تىلىنى چۈشىنىش تەس. 
\fp  بېشارەت كەلگۈسىدىكى ئىشلارنى كۆرسەتكىنى بىلەن، پېئىللار «ئۆتكەن زامان»دا ئىپادىلىنىدۇ. ئادەتتە ئىبرانىي تىلىدا بېشارەت «ئۆتكەن زامان»دا ئىپادىلەنگەن بولسا، ئۇنىڭ جەزمەنلىكىنى تەكىتلەيدۇ.\f*   
\m
\v 8 مەن شۇ كۈنى، ــ دەيدۇ پەرۋەردىگار،  
\m ــ ئېدومدىن دانىشمەنلەرنى،  
\m ئەساۋدىن ئەقىل-پاراسەتنى يوقاتمامدىمەن؟ \f ◼ \fr 1:8 \ft \+bd «مەن شۇ كۈنى...ئېدومدىن دانىشمەنلەرنى، ئەساۋدىن ئەقىل-پاراسەتنى يوقاتمامدىمەن؟»\+bd* ــ «شۇ كۈنى» بەلكىم بابىل ئىمپېرىيەسى ئۇلارغا تاجاۋۇز قىلىدىغان كۈنىنى (مىلادىيەدىن ئىلگىرىكى 587-يىلى) ياكى ئەرەبلەر ئۇلارنى ئالداپ ھەيدىۋېتىدىغان كۈنىنى، يەنە ئاخىرقى زاماندا «پەرۋەردىگارنىڭ كۈنى»نى كۆرسىتىشىمۇ مۇمكىن. ئېدوم ئۆز دانىشمەنلىرى بىلەن داڭقى چىققان. ئايۇپ پەيغەمبەرنىڭ ئۈچ دوستىدىن بىرى بولغان «تېمانلىق ئېلىفاز»مۇ ئېدوملۇق ئىدى.\f*  \x ◘ \xo 1:8 \xt يەش. 29‏:14؛ يەر. 49‏:7\x*   
\m
\v 9 شۇنىڭ بىلەن پالۋانلىرىڭ پاراكەندە بولىدۇ، ئى تېمان،  
\m شۇنىڭ بىلەن ئەساۋنىڭ تېغىدىكى ھەربىر ئادەم قىرغىنچىلىقتا قەتل قىلىنىدۇ. \f ◼ \fr 1:9 \ft \+bd «شۇنىڭ بىلەن پالۋانلىرىڭ پاراكەندە بولىدۇ، ئى تېمان،...»\+bd* ــ «تېمان» ئېدومنىڭ چوڭ بىر شەھىرى.\f*  \x ◘ \xo 1:9 \xt ئام. 2‏:14، 16\x*   
\b  
\m  
\s1 ئېدومنىڭ بەربات بولۇشىنىڭ سەۋەبى  
\m
\v 10 ئۇكاڭ ياقۇپقا قىلغان زۇلۇم-زوراۋانلىقىڭ تۈپەيلىدىن،  
\m ئىزا-ئاھانەت سېنى قاپلايدۇ؛  
\m سەن مەڭگۈگە ئۈزۈپ تاشلىنىسەن. \x ◘ \xo 1:10 \xt يار. 27‏:41؛ ئ‍ەز. 35‏:5؛ ئام. 1‏:11\x*   
\m
\v 11 سەن بىر چەتتە \add پەرۋاسىز\add* قاراپ تۇرغان كۈنى،  
\m يەنى ياقا يۇرتتىكىلەر \add بۇرادىرىڭنىڭ\add* مۈلكىنى بۇلاپ كەتكەن كۈنى،  
\m تائىپىلەر ئۇنىڭ دەرۋازىلىرىدىن كىرىپ يېرۇسالېم ئۈستىگە چەك تاشلىغان كۈنى،  
\m سەن ئۇلارنىڭ بىر ئەزاسىغا ئوخشاش بولغانسەن. \x ◘ \xo 1:11 \xt زەب. 137‏:7\x*   
\m
\v 12 بىراق قېرىندىشىڭنىڭ ئاپەتلىك كۈنىگە پەرۋاسىز قاراپ تۇرماسلىقىڭ كېرەك ئىدى،  
\m يەھۇدانىڭ بالىلىرىنىڭ ھالاكەت كۈنىدە خۇشال بولۇپ كەتمەسلىكىڭ كېرەك ئىدى؛  
\m كۈلپەتلىك كۈنىدە ئاغزىڭنى يوغان قىلماسلىقىڭ كېرەك ئىدى؛   
\m
\v 13 ئۆز خەلقىمنى ئاپەت باسقان كۈنىدە، ئۇلارنىڭ دەرۋازىسىغا كىرمەسلىكىڭ كېرەك ئىدى؛  
\m ئۇلارنى ئاپەت باسقان كۈنىدە ئۇلارنىڭ دەرد-ئەلەمىگە ئېرەنسىز قاراپ تۇرماسلىقىڭ كېرەك ئىدى،  
\m ئاپەت باسقان كۈنىدە قولۇڭنى مال-مۈلكىگە سوزماسلىقىڭ كېرەك ئىدى؛   
\m
\v 14 سەن شەھەردىن قېچىپ قۇتۇلغانلارنى ئۈزۈپ تاشلاش ئۈچۈن ئاچا يولدا تۇرماسلىقىڭ كېرەك ئىدى؛  
\m كۈلپەت باسقان كۈنىدە ئۇنىڭدىن قۇتۇلۇپ قالغانلارنى دۈشمەنگە تاپشۇرماسلىقىڭ كېرەك ئىدى.   
\b  
\m  
\s1 پەرۋەردىگارنىڭ كۈنى  
\m
\v 15 چۈنكى پەرۋەردىگارنىڭ كۈنى بارلىق ئەللەر ئۈستىگە چۈشۈشكە يېقىن قالغاندۇر؛  
\m سېنىڭ باشقىلارغا قىلغىنىڭدەك، ساڭىمۇ شۇنداق قىلىنىدۇ؛  
\m ساڭا تېگىشلىك جازا ئۆز بېشىڭغا چۈشىدۇ؛ \x ◘ \xo 1:15 \xt ئ‍ەز. 35‏:15\x*   
\m
\v 16 چۈنكى سەن ئۆز مۇقەددەس تېغىمدا \add غەزىپىمنى\add* ئىچكىنىڭدەك،  
\m بارلىق ئەللەرمۇ شۇنداق توختاۋسىز ئىچىدۇ؛  
\m بەرھەق، ئۇلار ئىچىدۇ، يۇتىدۇ،  
\m ئاندىن ئۇلار ھېچ مەۋجۇت ئەمەستەك يوقاپ كېتىدۇ. \f ◼ \fr 1:16 \ft \+bd «چۈنكى سەن ئۆز مۇقەددەس تېغىمدا غەزىپىمنى ئىچكىنىڭدەك»\+bd* ــ ئىبرانىي تىلىدا «چۈنكى سەن ئۆز مۇقەددەس تېغىمدا ئىچكىنىڭدەك...» ــ چۈشەنچىمىز بويىچە ئېدومىيلار خۇدانىڭ قولىدا ئۇنىڭ غەزىپىنى ئىچكەنىدى. 
\fp  باشقا بىرخىل چۈشەنچىسى، ئېدومىيلار يەھۇدا ئۈستىدىن قىلغان غەلىبىسىنى تەبرىكلەپ، «خۇدانىڭ مۇقەددەس تېغى»دا شاراب ئىچكەن؛ ۋە ئۇلار (ئايەتنىڭ ئىككىنچى قىسمى بويىچە) شۇ گۇناھى ئۈچۈن بارلىق ئەللەر بىلەن تەڭ خۇدانىڭ غەزىپىنى ئىچىدۇ. \+bd «بارلىق ئەللەرمۇ شۇنداق توختاۋسىز ئىچىدۇ؛ بەرھەق، ئۇلار ئىچىدۇ، يۇتىدۇ، ئاندىن ئۇلار ھېچ مەۋجۇت ئەمەستەك يوقاپ كېتىدۇ»\+bd* ــ ئەللەرنىڭ نېمىنى ئىچىدۇ؟ خۇدانىڭ غەزىپىنى ئىچىدۇ (مەسىلەن «زەب.» 8:75، «يەش.» 26:49، «يەر.» 15:25-16، «زەب.» 4:16نىمۇ كۆرۈڭ).\f*  \x ◘ \xo 1:16 \xt زەب. 8:75، 4:16؛ يەش. 26:49؛ يەر. 2-5:1516؛ مات. 39:26، 42؛ يۇھ. 11:18\x*   
\b  
\m  
\s1 ئىسرائىلنىڭ ئەسلىگە كەلتۈرۈلۈشى  
\m
\v 17 بىراق زىئون تېغى ئۈستىدە پاناھ-قۇتقۇزۇلۇش بولىدۇ،  
\m تاغ پاك-مۇقەددەس بولىدۇ؛  
\m ياقۇپ جەمەتىنىڭ تەئەللۇقاتلىرى ئۆزىگە تەۋە بولىدۇ؛ \f ◼ \fr 1:17 \ft \+bd «بىراق زىئون تېغى ئۈستىدە پاناھ-قۇتقۇزۇلۇش بولىدۇ»\+bd* ــ باشقا بىرخىل تەرجىمىسى: «بىراق زىئون تېغىدا قۇتۇلۇپ قالغانلار بولىدۇ».\f*   
\m
\v 18 ۋە ياقۇپ جەمەتى ئوت، يۈسۈپ جەمەتى يالقۇن،  
\m ئەساۋ جەمەتى ئۇلارغا پاخال بولىدۇ؛  
\m \add ئوت ۋە يالقۇن\add* ئەساۋ جەمەتى ئىچىدە يېقىلىپ، ئۇلارنى يۇتۇپ كېتىدۇ؛  
\m ئەساۋ جەمەتىدىن ھېچبىرسى قالمايدۇ؛  
\m چۈنكى پەرۋەردىگار شۇنداق سۆز قىلغان.   
\m
\v 19 \add يەھۇدانىڭ\add* جەنۇبىدىكىلەر ئەساۋنىڭ تېغىغا ئىگە بولىدۇ؛  
\m شەفەلاھ تۈزلەڭلىكىدىكىلەر فىلىستىيلەرنىڭ زېمىنىغا ئىگە بولىدۇ،  
\m بەرھەق، ئۇلار ئەفرائىمنىڭ دالاسى ھەم سامارىيەنىڭ دالاسىغا ئىگە بولىدۇ؛  
\m بىنيامىن گىلېئادقا ئىگە بولىدۇ؛ \f ◼ \fr 1:19 \ft \+bd «يەھۇدانىڭ جەنۇبىدىكىلەر»\+bd* ــ ئىبرانىي تىلىدا «نەگەۋدىكىلەر». «نەگەۋ» ــ يەھۇدانىڭ جەنۇبىي تەرىپىدىكى چوڭ چۆل-باياۋان. 
\fp  \+bd «يەھۇدانىڭ جەنۇبىدىكىلەر ئەساۋنىڭ تېغىغا ئىگە بولىدۇ؛ شەفەلاھ تۈزلەڭلىكىدىكىلەر فىلىستىيلەرنىڭ زېمىنىگە ئىگە بولىدۇ، .... بىنيامىن گىلېئادقا ئىگە بولىدۇ؛»\+bd* ــ 19-ئايەتتىكى بېشارەتلەرنىڭ كۆپ قىسمى مىلادىيەدىن ئىلگىرىكى 2-ئەسىردە ئەمەلگە ئاشۇرۇلىدۇ («ماكاببىيلار» ھەم «يوسېفۇس» دېگەن كونا تارىخىي كىتابلاردا خاتىرىلەنگەن). بىراق پىكىرىمىزچە، بۇ بېشارەتنىڭ تولۇق ئەمەلگە ئاشۇرۇلۇشى ئاخىرقى زاماندا بولىدۇ.\f*   
\m
\v 20 سۈرگۈن بولغانلاردىن قېلىپ قالغان ئىسرائىللاردىن تەركىب تاپقان بۇ قوشۇن قانائاندىكىلەرگە تەۋە بولغان زېمىنغا زارەفاتقىچە ئىگە بولىدۇ؛  
\m سەفارادتا سۈرگۈندە تۇرغان يېرۇسالېمدىكىلەر بولسا جەنۇبتىكى شەھەرلەرگە ئىگە بولىدۇ. \f ◼ \fr 1:20 \ft \+bd «سۈرگۈن بولغانلاردىن قېلىپ قالغان ئىسرائىللاردىن تەركىب تاپقان بۇ قوشۇن...»\+bd* ــ باشقا بىرخىل تەرجىمىسى: «قانائانغا قايتىپ كەلگەن، سۈرگۈن بولغان ئىسرائىللار جامائىتى... ».\f*   
\m
\v 21 ئاندىن زىئون تېغى ئۈستىگە قۇتقۇزغۇچىلار چىقىدۇ،  
\m ئۇلار ئەساۋ تېغى ئۈستىدىن ھۆكۈم سۈرىدۇ؛  
\b  
\m شۇنىڭ بىلەن پادىشاھلىق پەرۋەردىگارغا تەۋە بولىدۇ! \f ◼ \fr 1:21 \ft \+bd «ئۇلار ئەساۋ تېغى ئۈستىدىن ھۆكۈم سۈرىدۇ»\+bd* ــ ياكى «ئۇلار ئەساۋ تېغى ئۈستىدىن ھۆكۈم چىقىرىدۇ». \+bd «شۇنىڭ بىلەن پادىشاھلىق پەرۋەردىگارغا تەۋە بولىدۇ!»\+bd* ــ ھازىر «ئەساۋ تېغىدىكىلەر»نىڭ ھېچقايسىسى ئېدوملۇقلار ئەمەس (18-ئايەتنى كۆرۈڭ). بۇ «قۇتقۇزغۇچىلار»نىڭ كىم ئىكەنلىكى دېيىلمىدى؛ پىكرىمىزچە، «قۇتقۇزغۇچىلار» كونا زامانلاردا ئىسرائىلنى قۇتقۇزغان پەيغەمبەرلەر ۋە «باتۇر ھاكىملار» سۈپىتىدە بولىدۇ. ئۇلار ھازىر ئۆلۈمدىن تىرىلگەن. ئىسرائىل خۇدانىڭ تولۇق ئىدارە-ھۆكۈمى ئاستىدا بولۇپ، ئۇنىڭ ئەھۋالى پۈتۈنلەي مۇكەممەل بولىدۇ.\f*   