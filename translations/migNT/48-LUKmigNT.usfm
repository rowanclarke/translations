\id LUK
\h Lucas
\toc1 TU'UN VA'A NI CHAA SAN LUCAS
\toc2 Lucas
\toc3 Lc.
\mt2 EL SANTO EVANGELIO SEGUN SAN LUCAS
\mt1 TU'UN VA'A NI CHAA SAN LUCAS
\c 1
\s1 Sɨkɨ̱ tú'un ni̱ chaa San Lucas
\p 
\v 1 Kua'a̱ cháa ni̱ ka̱chaa‑de tu̱'un ná ta̱ká tiñu ni̱ sá'a Jesús ni̱ kajini̱‑yo̱.
\v 2 Te cha̱a ni̱ kajini̱ nuu̱‑yá ná onde̱ kɨvɨ̱ ní kejá'á‑yá, ni̱ ka̱jani‑de tu̱'un‑ya̱. Te ni̱ kaka̱stu̱'ún‑de nuu̱‑yo̱.
\v 3 Te náá, a ni̱ nandúkú víi‑ná ta̱ká tu̱'un‑ya̱, ná onde̱ kɨvɨ̱ ní kejá'á. Te jáni ini̱‑ná ja̱ súni íó va̱'a chaa kájí‑ná tu̱'un yá'a nuu̱‑ní, Teófilo máni̱,
\v 4 náva̱'a ná kuní‑ní ja̱ íó ndaa̱ ta̱ká tu̱'un ni̱ skuá'a‑ní.
\s1 Ja̱ ní ka'a̱n ndajá'a̱ Dios jíín Zacarías
\p 
\v 5 Te kɨvɨ̱ ní kuu Herodes rey ñuu̱ Judea, ni̱ i̱o ɨɨn sutu̱ nání‑de Zacarías ja̱ ní chindéé tá'an‑de jíín Abías. Te ñasɨ́'ɨ́‑de nání‑ña Elisabet. Te onde̱ chi̱i Aarón va̱i tata̱‑ña.
\v 6 Te cha̱a ndaa̱ ni̱ ka̱kuu ndendúú‑de nuu̱ Dios. Te ñúkúún ní ka̱skíkuu‑de ta̱ká tu̱'un jíín tíñu tá'ú‑yá nuu̱‑yo̱.
\v 7 Te tú se̱'e‑de ní íó, chi̱ Elisabet, ña'an numá kúu‑ña, te vina, a ni̱ ka̱yii‑de.
\v 8 Yúan‑na te ni̱ jaa̱ kɨvɨ̱ ní ka̱teta'a̱n‑i nuu̱ Zacarías jíku‑de jíín tíñu ja̱ kúu‑de sutu̱ nuu̱ Dios,
\v 9 nátu̱'un ni̱ ka̱sá'a máá sutú. Te ja̱ yúán ni kɨ̱vɨ‑de ini̱ ve̱'e ii̱ máá Jíto'o̱‑yo̱. Te ní ja'mu‑de su̱sia ku̱tú.
\v 10 Te nini já'mu‑de su̱sia ku̱tú, te ichi yatá vé'e ii̱, kájika̱n ta'u̱ ñáyɨvɨ kuá'a̱.
\v 11 Te ni̱ kenda ɨɨn ndajá'a̱ máá Jito'o̱‑yo̱ núu̱‑dé, kándii̱‑ya̱ íchi ndává'a altar nuu̱ já'mu‑de su̱sia ku̱tú.
\v 12 Te ni̱ jini̱ Zacarías nuu̱‑yá, te ni̱ yu̱'ú‑de, te ni̱ kɨsɨ‑i‑de.
\v 13 Ko máá ndájá'a̱‑ún, ni̱ ka'a̱n‑ya̱ jíín‑de: Zacarías, ma̱ yú'ú‑ro̱, chi ja̱ ní jika̱n ta'u̱‑ro̱ a ni̱ jini so̱'o Dios. Te ñasɨ́'ɨ́‑ro̱ Elisabet, skáku‑ña ɨ́ɨn se̱'e yíí, te skúnání‑ró‑i Juan.
\v 14 Te kusɨɨ̱ xáa̱n iní‑ro̱. Te kusɨɨ̱ iní kua'a̱ ñáyɨvɨ jíín‑i kɨvɨ̱ káku‑i.
\v 15 Te kuu‑i ɨɨn cha̱a kúñá'nu nuu̱ Dios. Te ma̱ kó'o‑i vino, ni ndɨxɨ̱. Te kukútú Espíritu Santo ini̱‑i, va̱sa ñú'un‑ga̱‑i chi̱i náa̱‑i.
\v 16 Te kua'a̱ cháa Israel ndíó káva ini̱‑de nuu̱ Dios sá'a‑i.
\v 17 Te kuxnúú‑i jíín modo jíín fuerza Elías nuu̱ I'a̱ kii. Te ta̱ká táa̱, ndundá'ú ini̱‑de se̱'e‑de, te cha̱a ni̱'in ini̱, nakuandatu̱‑de tu̱'un ndíchí ká'a̱n cha̱a ndaa̱, sá'a‑i. Te sátu̱'a‑i ña̱yɨvɨ kóo tu̱'a ja̱ cháa̱ máá Jito'o̱‑yo̱. Achí‑ya̱ jíín‑de.
\v 18 Te ni̱ ka'a̱n Zacarías jíín ndájá'a̱‑ún: Ndasa kuni̱‑ná te nú ja̱ndáa̱ kúu, chi cha̱a ni̱ yii kúu‑ná, te ñasɨ́'ɨ́‑ná, suni a ni̱ yii‑ña, áchí‑de.
\v 19 Te ni̱ ka'a̱n ndajá'a̱‑yá: Máá‑rí kúu Gabriel, ja̱ kándii̱‑ri̱ nuu̱ Dios. Te ni̱ tájí‑yá ruu̱, va̱i ka'a̱n‑ri̱ jíín‑ró, te kachi̱‑ri̱ tu̱'un va̱'a yá'a nuu̱‑ro̱.
\v 20 Vina te kuñí'ín‑ro̱, te ma̱ kúu ka'a̱n‑ro̱ ondé kɨvɨ̱ skíkuu tu̱'un yá'a, chi̱ tú ní kándíja‑ró tú'un ni̱ ka'a̱n‑ri̱, te tu̱'un skíkuu ná'ín kúu, ná jáa̱ kɨvɨ̱, áchí‑ya̱ jíín‑de.
\v 21 Te ña̱yɨvɨ‑ún, káinda̱tu‑i Zacarías. Te kájani ini̱‑i na̱ún tá'a̱n‑de ja̱ ní kuná'án kándee‑de ini̱ ve̱'e ii̱.
\v 22 Yúan‑na te ni̱ ndenda‑de, te tuká ní kúu ka'a̱n‑de jíín‑i. Te ni̱ kaju̱ku̱'un ini̱‑i ja̱ iní ve̱'e ii̱‑ún ni̱ jini̱‑de ɨɨn ja̱ Dios ni̱ skóto‑ya̱‑dé. Te máá seña‑na̱ ni̱ sá'a‑de nuu̱‑í, chi̱ a ni̱ kuñí'ín‑de.
\v 23 Te nuu̱ ní ji̱nu tiñu ndíso‑de, te kua̱no'on‑dé ve'e‑de.
\v 24 Yúan‑na te ni̱ kuu yaku̱ kɨvɨ̱. Te ñasɨ́'ɨ́‑de Elisabet, ni̱ ni'i̱n sé'e‑ña. Te ni̱ chisa̱'í‑ña máá‑ña ú'u̱n yoo̱. Te ni̱ ka'a̱n‑ña:
\v 25 Súan ni̱ sá'a máá Jito'o̱‑yo̱ jíín‑rí ja̱ ní jini̱‑ya̱ núu̱‑rí. Te vina tuká kúka nuu̱‑rí nuu̱ táká ña̱yɨvɨ. Achí‑ña.
\s1 Ja̱ ní ka'a̱n Gabriel jíín María
\p 
\v 26 Te nuu̱ iñú yoo̱, te ni̱ tájí Dios ndajá'a̱ Gabriel, ni̱ ja'a̱n‑ya̱ ɨ́ɨn ñuu̱ nání Nazaret, ndañúu̱ Galilea.
\v 27 Ni̱ ja'a̱n‑ya̱ núu̱ ɨ́ɨn ña'an jáá, já á yani ta̱nda'a‑ñá jíín ɨ́ɨn cha̱a nání José. Te onde̱ chi̱i David va̱i tata̱‑de. Te ña'an jáá‑ún nání‑ña María.
\v 28 Te ni̱ jaa̱ ndajá'a̱‑yá nuu̱ kánchaa̱‑ña yúan. Te ni̱ ka'a̱n‑ya̱ jíín‑ña: Ta̱á ndii, ta'u̱‑ro̱ kúu, chi̱ máá Jito'o̱‑yo̱ jíka‑ya̱ jíín‑ró. Te xáán ndatu̱ kéndo̱o‑ró vásá táká ña'an. Achí‑ya̱.
\v 29 Te máá‑ña, ni̱ jini̱‑ña núu̱‑yá. Te ni̱ kuñáá ini̱‑ña já súan ni̱ ka'a̱n‑ya̱. Te jáni ini̱‑ña na̱ún tu̱'un kúu ja̱ ní ka'a̱n‑ya̱‑ún.
\v 30 Yúan‑na te ni̱ ka'a̱n ndajá'a̱‑yá jíín‑ña: María, ma̱ yú'ú‑ro̱, chi ni̱ kusɨɨ̱ iní Dios jíín‑ró.
\v 31 Vina te juku̱'un se̱'e‑ró, te skáku‑ró ɨ́ɨn se̱'e yíí. Te skúnání‑ró‑i Jesús.
\v 32 Kuñá'nu su̱chí‑ún. Te kunání‑i Se̱'e I'a̱ kúñá'nu xaa̱n. Te máá Tatá Dios kua̱'a‑ya̱ mesa táa̱‑i David nuu̱‑í.
\v 33 Te tá'ú‑i tiñu ini̱ ve̱'e Jacob nɨ́ɨ́ káni. Te kɨvɨ̱ tá'ú‑i tiñu‑ún, ma̱ ndɨ́'ɨ kutɨ. Achí‑ya̱.
\v 34 Yúan‑na te ni̱ ka'a̱n María jíín ndájá'a̱‑yá: Ndasa koo Táta̱, chi̱ tú yii‑ná íó, áchí‑ña.
\v 35 Te ni̱ kachi̱ ndajá'a̱‑yá jíín‑ña: Máá Espíritu Santo kii sɨkɨ̱‑ro̱, te fuerza máá I'a̱ kúñá'nu xaa̱n sá'a katɨ sɨkɨ́‑ro̱. Yu̱án máá súchí íi̱ káku‑ún, kunání‑i Se̱'e Dios.
\v 36 Te kástu̱'ún‑rí nuu̱‑ro̱, já tá'an‑ró Elisabet, suni a ni̱ ni'i̱n sé'e‑ña vína va̱sa a ni̱ yii‑ña. Te vina íó iñu̱ yoo̱ já tuká nání‑ña ñá'an numá.
\v 37 Chi ta̱ká ja̱ kuní Dios, te kuu sá'a‑ya̱, áchí ndajá'a̱‑yá
\v 38 yúan‑na te ni̱ ka'a̱n María: Kuu, chi̱ játíñu‑ná nuu̱ máá Tatá Dios, te súan ná kóo nátu̱'un ni̱ ka'a̱n‑ní núsáá, áchí‑ña. Te máá ndájá'a̱‑ún, kua'a̱n‑ya̱.
\s1 Ja̱ ní jaa̱ María nuu̱ Elisabet
\p 
\v 39 Te ni̱ kuu kɨvɨ̱. Te ni̱ ndukuiñi̱ María, ni̱ kaa‑ña ɨ́ɨn yuku kuá'a̱n‑ña, ni̱ jaa̱‑ña ɨ́ɨn ñuu̱ nání Judá.
\v 40 Te ni̱ kɨ̱vɨ‑ña iní ve̱'e Zacarías. Te ni̱ ka'a̱n‑ña jíín Elisabet.
\v 41 Te nuu̱ ní jini so̱'o Elisabet tu̱'un ni̱ ka'a̱n María jíín‑ña, te su̱chí lúlí‑ún ni̱ tuñu‑ni‑i chi̱i‑ña. Te ni̱ chítú ndɨ́ɨ Elisabet jíín Espíritu Santo.
\v 42 Te ni̱ ka'a̱n jaa‑ña: Xáán ndatu̱ kúu‑ró núu̱ táká ña'an. Te suni xáán ndatu̱ kúu su̱chí ñú'un chi̱i‑ró.
\v 43 Te na̱ún ña'an kúu ruu̱ ja̱ ní chaa̱ náa̱ máá Jito'o̱‑ri̱ nuu̱‑rí.
\v 44 Chi ja̱ ní jini so̱'o‑ri̱ tu̱'un ni̱ ka'a̱n‑ro̱ jíín‑rí, te su̱chí ñú'un chi̱i‑ri̱ yá'a, ni̱ tuñu‑ni‑i ja̱ kúsɨɨ̱ iní‑i.
\v 45 Xáán ndatu̱ kúu ña'an ní kandíja‑ún, chi ta̱ká tu̱'un ni̱ keyu'u máá Tatá Dios, skíkuu ná'ín jíín‑ña, áchí Elisabet.
\v 46 Yúan‑na te ni̱ ka'a̱n María: Kúu ini̱‑ri̱ ja̱ ná ndúñá'nu máá Tatá Dios.
\v 47 Te kúsɨɨ̱ iní‑ri̱ jíín Dios ja̱ náma‑ya̱ rúu̱.
\v 48 Chi ni̱ jini̱‑ya̱ já kúka nuu̱ iní ña'an játíñu nuu̱‑yá núú. Ko onde̱ vina te ka'a̱n ta̱ká ña̱yɨvɨ jíín‑rí ja̱ xáán ndatu̱‑ri̱.
\v 49 Chi̱ I'a̱ tɨ́ɨn ndɨ'ɨ fuerza, ni̱ sá'a‑ya̱ tíñu ñá'nu jíín‑rí, te sɨ́'vɨ́ íi̱ ñáva̱'a‑ya̱.
\v 50 Te nɨ́ɨ́ káni kúndá'ú ini̱‑ya̱ táká ña̱yɨvɨ kájandatu̱ nuu̱‑yá.
\v 51 Ni̱ sá'a‑ya̱ tíñu ñá'nu jíín ndá'a‑yá. Te ni̱ skúnu‑ya̱ cháa vixi̱ kája'a̱n‑de, onde̱ jíín táká ja̱ kájani sáni ini̱‑de.
\v 52 Te ni̱ chaxio‑ya̱ cháa kákuñá'nu nuu̱ mesa‑de. Ko cha̱a kákundá'ú, ni̱ nasáñá'nu‑ya̱‑dé.
\v 53 Te nuu̱ cháa káji'i̱ so̱ko, ni̱ ja̱'a‑ya̱ já kée vá'a‑de. Ko cha̱a kúká, ni̱ kiñi'in sáni‑ya̱‑dé kája'a̱n‑de.
\v 54 Te ni̱ chindéé ní chituu‑ya̱ mozo‑ya̱ ñáyɨvɨ Israel, chi̱ núku̱'un ini̱‑ya̱ já ní kundá'ú ini̱‑ya̱‑í.
\v 55 Chi ni̱ ka'a̱n‑ya̱ jíín ndɨ́yi táa̱‑yo̱ jíná'an‑de, ja̱ nɨ́ɨ́ káni kundá'ú ini̱‑ya̱ Abraham jíín táká tata̱‑de, áchí María.
\v 56 Te ni̱ kanchaa̱ María jíín‑ña nátu̱'un uni̱ yoo̱. Yúan‑na te kua̱no'on‑ñá ve'e‑ña.
\s1 Kɨvɨ̱ ní kaku Juan, cha̱a skuánducha
\p 
\v 57 Te Elisabet ni̱ jaa̱ kɨvɨ̱ skáku‑ña sé'e‑ña. Te ni̱ skáku‑ña ɨ́ɨn se̱'e yíí.
\v 58 Te ni̱ ka̱jini tu̱'un tá'an‑ña jíín ñáyɨvɨ káxiu̱kú yáni, ja̱ Dios xaa̱n ní kundá'ú ini̱‑ya̱‑ñá. Te kákusɨɨ̱ iní‑i jíín‑ña.
\v 59 Yúan‑na te nuu̱ uná kɨvɨ̱, te ni̱ cha̱koyo‑de ja̱ xɨtɨ́ ndúu̱ su̱chí yɨ́kɨ́n‑ún. Te skúnání‑de‑i sɨ́'vɨ́ táa̱‑i Zacarías núú.
\v 60 Ko ni̱ ka'a̱n náa̱‑i: Ma̱ kúu, chi̱ Juan kunání‑i, áchí‑ña.
\v 61 Te ni̱ kaka'a̱n‑de jíín‑ña: Naja̱. Te tú ni ɨɨn tá'an‑ró nání súan, áchí‑de.
\v 62 Yúan‑na te jíín seña kájika̱ tu̱'ún‑de táa̱‑i ndasa kuní‑de kunání‑i.
\v 63 Te ni̱ jika̱n máá‑de ɨɨn tutu̱. Te yúan ni̱ chaa‑de: Juan kunání‑i, áchí. Te ta̱ká ña̱yɨvɨ‑ún ni̱ ka̱naa iní kánde̱'é‑i.
\v 64 Te ni̱ nanuña‑ni yu'u‑dé. Te ni̱ nduvi̱tá‑ni yáa‑dé. Te ni̱ naka'a̱n‑ni‑de ni̱ nakana jaa‑de Dios.
\v 65 Te ta̱ká ña̱yɨvɨ kákuu tá'an‑de, ni̱ kayu̱'ú‑i. Te ni̱ jicha̱ ta̱ká tu̱'un yá'a kua'a̱n nɨ́ɨ́ yúku ndáñúu̱ Judea.
\v 66 Te ta̱ká ja̱ ní ka̱jini so̱'o tu̱'un‑ún, ni̱ kañu̱'un‑ni ini̱ máá. Te káka'a̱n: Ndasa koo su̱chí yá'a núsáá, chi̱ máá Tatá Dios ndíto‑ya̱‑í, áchí.
\v 67 Yúan‑na te táa̱‑i Zacarías, ni̱ chítú ndɨ́ɨ‑dé jíín Espíritu Santo. Te ni̱ jani‑de tu̱'un:
\v 68 Ná nákana jaa‑yó máá Tatá Dios ña̱yɨvɨ Israel, chi ni̱ kinde̱'é‑yá ña̱yɨvɨ‑yá. Te ni̱ nama‑ya̱‑í.
\v 69 Te onde̱ ini̱ ve̱'e mozo‑ya̱ David, ni̱ jani‑ya̱ ɨ́ɨn cha̱a kúñá'nu nama yóó.
\v 70 Nátu̱'un ni̱ kaka'a̱n cha̱a ndoo ni̱ ka̱jani tu̱'un‑ya̱ ní kikoyo‑de onde̱ xnáñúú,
\v 71 ja̱ náma‑ya̱ yóó ini̱ nda'a cháa kájito u'u̱ yóó jíín núu̱ já kákiti̱ ini̱ kájito yóó.
\v 72 Chi̱ kúndá'ú ini̱‑ya̱ táa̱‑yo̱. Te núku̱'un ini̱‑ya̱ tú'un ii̱ ní keyu'u‑yá.
\v 73 Tu̱'un‑ún ni̱ chísó tú'un téyíí‑yá nuu̱ Abraham, ja̱ kuá'a‑ya̱ núu̱‑yo̱.
\v 74 Ja̱ náma‑ya̱ yóó nuu̱ cháa kájito u'u̱ yóó. Te ma̱ yú'ú‑ga̱‑yo̱, kuatíñu‑yó núu̱‑yá.
\v 75 Jíín tíñu ndoo jíín tíñu ndaa̱ ta̱ká kɨvɨ̱ kúchaku̱‑yo̱.
\v 76 Te róó su̱chí lúlí, kunání‑ró cháa jáni tu̱'un I'a̱ kúñá'nu xaa̱n, chi̱ kuxnúú‑ró kí'i̱n‑ro̱ íchi núu̱ máá Jito'o̱‑yo̱ náva̱'a sátu̱'a‑ró íchi‑yá.
\v 77 Te kastu̱'ún‑ró núu̱ ñáyɨvɨ máá‑yá ja̱ náma‑ya̱‑í, jíín já kóo tu̱ká'nu ini̱ nuu̱ táká kua̱chi‑i.
\v 78 Chi̱ xaa̱n kúndá'ú ini̱ Dios yóó. Ja̱ yúán kúndiji̱n nuu̱‑yo̱ sá'a I'a̱ ñá'nu.
\v 79 Náva̱'a kundiji̱n nuu̱ já ká'i̱in ñu̱ñáa jíín núu̱ já kákuni̱ naa. Yúan‑na te kuu kaka‑yó íchi vá'a, jíín íchi túu tu̱ndó'o, sá'a‑ya̱, áchí‑de.
\v 80 Te su̱chí lúlí‑ún, ni̱ ja'nu ndéé‑i, te ni̱ yija ini̱‑i. Te ni̱ kanchaa̱‑i onde̱ nuu̱ ñú'un té'é ondé kɨvɨ̱ ní stá'a̱n ndiji̱n‑i máá‑i nuu̱ ñáyɨvɨ Israel.
\c 2
\s1 Kɨvɨ̱ ní kaku Jesucristo
\p 
\v 1 Te ni̱ kuu yaku̱ kɨvɨ̱. Te Augusto César, ni̱ jacha̱‑de tu̱'un ja̱ táká ña̱yɨvɨ ndútútú xiní‑í jíná'an‑i.
\v 2 Ya̱'á kúu ja̱ ní ndutútú núú xiní‑í. Te Cirenio ni̱ kuu‑de gobernador ñuu̱ Siria.
\v 3 Te ta̱ká ña̱yɨvɨ‑ún, kája'a̱n‑i ndɨta'a̱n ñuu̱‑i ja̱ nákua̱'a‑i xini̱‑í.
\v 4 Te ja̱ yúán ní kenda José ini̱ ñuu̱ Nazaret, ndañúu̱ Galilea. Te ni̱ kaa‑de kua'a̱n‑de ñuu̱ Judea. Te ni̱ kɨ̱vɨ‑de ñuu̱ David ja̱ nání Belén. Chi̱ tá'an ini̱ ve̱'e David kúu‑de.
\v 5 Náva̱'a nakua̱'a‑de xini̱‑dé jíín ñásɨ́'ɨ́‑de María, chi̱ a yani ta̱nda'a‑ñá jíín‑de, te ñú'un se̱'e‑ña.
\v 6 Te nini ká'i̱in‑de yúan, te ni̱ ji̱nu kɨvɨ̱ skáku‑ña‑í.
\v 7 Te ni̱ skáku‑ña sé'e yíí núú‑ña. Te ni̱ chisúkun‑ñá‑i, te ni̱ jaki̱n‑ña‑í ini̱ nu̱ndóó kɨ́tɨ, chi̱ tuká núña mesón.
\v 8 Te suni ñuu̱ yúan íó cha̱a kándi̱to ñúú‑de rɨɨ̱‑de.
\v 9 Te yúan ni̱ kii ɨɨn ndajá'a̱ máá Tatá Dios nuu̱‑dé. Te káyu̱'ú xaa̱n‑dé.
\v 10 Te ni̱ ka'a̱n máá ndájá'a̱‑yá jíín‑de: Ma̱ yú'ú‑ro̱ jíná'an‑ró, chi va̱i‑ri̱ kástu̱'ún‑rí ɨɨn tu̱'un va̱'a nuu̱‑ro̱, te kusɨɨ̱ iní ta̱ká ña̱yɨvɨ sá'a.
\v 11 Chi̱ vina onde̱ ini̱ ñuu̱ David ni̱ kaku ɨɨn I'a̱ nama róó. Cristo máá Jito'o̱‑yo̱ kúu‑ya̱.
\v 12 Te kuni̱‑ro̱ já súan íó, chi̱ nani'i̱n‑ro̱ súchí yɨ́kɨ́n‑ún yísúkun‑í sa'ma te kátúu‑í ini̱ ɨɨn nu̱ndóó kɨ́tɨ. Achí‑ya̱.
\v 13 Te sanaa‑ní te ni̱ kenda ɨɨn tɨku'ni̱ andɨ́vɨ́, ká'i̱in kua'a̱‑yá jíín ndájá'a̱‑yá‑ún, kánakana jaa‑ya̱ Dios, te káka'a̱n‑ya̱:
\v 14 Ná nákana jaa‑yó Dios onde̱ andɨ́vɨ́. Te ná ndúndéé iní ta̱ká ña̱yɨvɨ iní ñu̱yɨ́vɨ yá'a, sá'a Dios ja̱ kúsɨɨ̱ iní‑ya̱ jíín‑i, áchí.
\v 15 Yúan‑na te ndajá'a̱‑yá‑ún, ni̱ xndóo‑ya̱‑dé te káno'o̱n‑ya̱ ándɨ́vɨ́. Te máá cháa ndíto‑tɨ̱, káka'a̱n‑de: Ná kí'o̱n ondé Belén te kuni̱‑yo̱ na̱ún ní kuu. Chi̱ súan ni̱ kastu̱'ún máá Tatá Dios nuu̱‑yo̱. Achí‑de.
\v 16 Te yachi̱ kája'a̱n‑de. Te ni̱ kajini̱‑de nuu̱ María jíín José, jíín núu̱ súchí yɨ́kɨ́n‑ún kátúu‑í ini̱ nu̱ndóó kɨ́tɨ.
\v 17 Te súan ni̱ kajini̱‑de nuu̱‑í. Te ni̱ kajacha̱‑de tu̱'un ndasa ni̱ kajini̱‑de sɨkɨ̱ súchí yɨ́kɨ́n‑ún.
\v 18 Te ni̱ ka̱naa iní ta̱ká ña̱yɨvɨ ní ka̱jini so̱'o‑i tu̱'un káka'a̱n cha̱a kándi̱to rɨɨ̱.
\v 19 Ko María ni̱ chiva̱'a‑ña táká tu̱'un yá'a. Te náxndáa̱‑ña tú'un‑ún ini̱ añú‑ña.
\v 20 Te ni̱ ka̱naxíó káva cha̱a kándi̱to rɨɨ̱, káno'o̱n‑de, kánakana jaa‑de Dios. Chi̱ ni̱ ka̱jini̱‑de ja̱ íó ndaa̱ ta̱ká tu̱'un ni̱ ka̱jini so̱'o‑de, nátu̱'un ni̱ ka'a̱n ndajá'a̱‑yá jíín‑de.
\s1 Ja̱ ní stá'a̱n‑de‑i nuu̱ máá Dios ini̱ ve̱'e ii̱
\p 
\v 21 Te ni̱ kuu una̱ kɨvɨ̱. Te ni̱ xɨtɨ̱ ndúu̱ su̱chí yɨ́kɨ́n‑ún. Te ni̱ ka̱skúnání‑de‑i Jesús, chi̱ sɨ́'vɨ́‑ún ni̱ ka'a̱n ndajá'a̱‑yá ná té júku̱'un‑ga̱‑i núú.
\v 22 Yúan‑na te ni̱ ji̱nu kɨvɨ̱ ndúndoo‑ña, nátu̱'un ká'a̱n ley Moisés. Te ni̱ kaja̱ncha̱ka‑de‑i ñuu̱ Jerusalén náva̱'a stá'a̱n‑de‑i nuu̱ máá Tatá Dios.
\v 23 Chi̱ yóso núu̱ tutú máá Tatá Dios: Ta̱ká su̱chí yíí káku núú, su̱chí‑ún, ná kúña ii̱‑í nuu̱ máá Tatá Dios, áchí.
\v 24 Te suni soko̱‑dé uu̱ lɨ́'vɨ, xí úu̱ paloma, nátu̱'un ká'a̱n ley máá Tatá Dios.
\v 25 Te yúan íó ɨɨn cha̱a ñuu̱ Jerusalén, nání‑de Simeón. Te cha̱a ndaa̱, cha̱a ndoo kúu‑de, te ñúkuu ini̱‑de chaa̱ I'a̱ ka'a̱n tu̱'un ndéé jíín ñáyɨvɨ Israel. Te Espíritu Santo jíka‑ya̱ jíín‑de.
\v 26 Chi̱ a ni̱ kastu̱'ún Espíritu Santo nuu̱‑dé ja̱ má kúu̱ kutɨ‑dé te nú tú kuni̱‑de nuu̱ Cristo máá Tatá Dios xna'a̱n‑ga̱.
\v 27 Te ni̱ chaa̱‑de ini̱ ve̱'e ii̱, ni̱ sá'a Espíritu Santo. Yúan‑na te táa̱ su̱chí lúlí Jesús, ni̱ ka̱skɨ́vɨ‑de‑i ini̱ ve̱'e ii̱, ja̱ sá'a‑de jíín‑i nátu̱'un ká'a̱n ley.
\v 28 Te Simeón, ni̱ junu nchaa̱‑de‑i. Te ni̱ nakana jaa‑de Dios. Te ni̱ ka'a̱n‑de:
\v 29 Ai̱ Táta̱, sía̱‑ní mozo‑ní ná kí'i̱n‑de, nátu̱'un ni̱ ka'a̱n‑ní, chi̱ ni̱ kuva̱'a ini̱‑ná vina.
\v 30 Chi ni̱ jini̱ jíín núu̱‑ná ja̱ náma‑ní yóó.
\v 31 Chi yu̱án ní sátu̱'a‑ní jíto nuu̱ táká ña̱yɨvɨ,
\v 32 náva̱'a ná kúndiji̱n nuu̱ ñáyɨvɨ sɨ́ɨn nación, te nduñá'nu ña̱yɨvɨ máá‑ní Israel, sá'a‑ní. Achí‑de.
\v 33 Te José jíín náa̱‑i, kánaa iní‑de kájini so̱'o‑de tu̱'un‑i ndasa ká'a̱n cha̱a‑ún.
\v 34 Te ni̱ jika̱n ta'u̱ Simeón ja'a̱‑dé jíná'an‑de. Te ni̱ ka'a̱n‑de jíín náa̱‑i María: Su̱chí yá'a va̱i‑i ja̱ nduá te ndonda kua'a̱ ñáyɨvɨ Israel sá'a‑i. Te státá'an ña̱yɨvɨ já sɨkɨ́‑í.
\v 35 Náva̱'a ná kénda ndiji̱n ndasa kájani ini̱ kua'a̱ ñáyɨvɨ. Te ɨɨn yuchi̱ kui̱so ini̱ añú‑ro̱. Achí‑de.
\v 36 Te suni kándee Ana yúan, ña'an jáni tu̱'un Dios kúu‑ña, se̱'e Fanuel tata̱ Aser kúu‑ña. Te a ni̱ yii‑ña chi̱ onde̱ ná jáá‑ña te ni̱ kanchaa̱‑ña jíín yíi‑ñá usia̱ kuia̱.
\v 37 Te ni̱ kendo̱o ndá'ú‑ña ondé ni̱ ji̱nu‑ña kúu̱n xíko kuu̱n kuiá‑ña. Te tú kúxio‑ña iní ve̱'e ii̱, chi̱ sua játíñu‑ña ndúú ñúú. Te ndicha̱ ini̱‑ña. Te jikán ta'u̱‑ñá.
\v 38 Te suni hora‑ún ni̱ chaa̱‑ña, ni̱ nakana jaa‑ña Dios. Te ni̱ ka'a̱n‑ña tú'un su̱chí yɨ́kɨ́n‑ún nuu̱ táká ña̱yɨvɨ káñukuu ini̱‑i kenda ɨɨn cha̱a nama‑de ñuu̱ Jerusalén.
\v 39 Te ni̱ kuu ni̱ skíkuu‑de ta̱ká tiñu ká'a̱n ley máá Tatá Dios. Te káno'o̱n‑de ñuu̱‑de Nazaret ndañúu̱ Galilea.
\v 40 Te su̱chí lúlí‑ún, ni̱ ja'nu ndéé‑i, te ni̱ yija‑i, te ni̱ kundíchí xáa̱n‑í, te ni̱ kusɨɨ̱ iní Dios jíín‑i.
\s1 Ja̱ ní kɨ̱vɨ ndúu̱ Su̱chí Jesús ini̱ ñuu̱ Jerusalén
\p 
\v 41 Te ndɨta'a̱n kuia̱ kája'a̱n táa̱‑i ñuu̱ Jerusalén, ja̱ ndé'é‑de viko Pascua yúan.
\v 42 Te nuu̱ ní kuu uxi̱ uu̱ kuia̱‑i, te ni̱ ka̱kaa táa̱‑i kája'a̱n‑de ñuu̱ Jerusalén, nátu̱'un kásá'a máá‑de kɨvɨ̱ víko‑ún.
\v 43 Te ni̱ ji̱nu kɨvɨ̱ víko‑ún, te káno'o̱n‑de. Te su̱chí lúlí Jesús ni̱ kendo̱o‑i ini̱ ñuu̱ Jerusalén, ni tú ní kájini̱ táa̱‑i náa̱‑i.
\v 44 Te kájani ini̱‑de ja̱ ndé kándee nduu̱‑i ma̱'ñú ñáyɨvɨ káno'o̱n ichi‑ún. Te ni̱ ka̱jika‑de ɨɨn kɨvɨ̱ ncháka, te vásá ní ka̱nandúkú‑de‑i ma̱'ñú táká tá'an‑de.
\v 45 Ko tú ní kánani'i̱n‑dé‑i, te ni̱ ka̱naxíó káva‑de káno'o̱n‑de ñuu̱ Jerusalén, kua̱nandúkú‑de‑i.
\v 46 Te onde̱ nuu̱ uní kɨvɨ̱ te vásá ní ka̱nani'i̱n‑dé‑i ini̱ ve̱'e ii̱, kánchaa̱‑i ma̱'ñú cháa kákuu maestro, jíni ná'ín‑i, te xndichí‑i‑de.
\v 47 Te ta̱ká ja̱ kájini so̱'o tu̱'un ká'a̱n‑i‑ún, ni̱ ka̱naa iní kánde̱'é núu̱‑í ja̱ bueno ndito xini̱‑í, te va̱'a xndíó káni‑i tu̱'un.
\v 48 Te nuu̱ ní kajini̱‑de nuu̱‑í, te ni̱ ka̱naa iní‑de kánde̱'é‑de. Te ni̱ ka'a̱n náa̱‑i jíín‑i: Hijo, naja̱ sá'a‑ró súan jíín‑rí, chi̱ táa̱‑ro̱ jíín rúu̱, kánandúkú xáa̱n‑rí róó te kándukuí'a̱ ini̱‑ri̱, áchí‑ña.
\v 49 Yúan‑na te ni̱ kachi̱‑i jíín‑ña: Na̱ún ní kuu, náa̱. Naja̱ kánandúkú‑ní náá. Tú kájini̱‑ní ja̱ jínu ñú'ún kúkuu‑ná jíín tíñu Táa̱‑ná náún. Achí‑i.
\v 50 Ko máá‑ña, tú ní kájuku̱'un ini̱‑ña tú'un ni̱ ka'a̱n‑i jíín‑ña.
\v 51 Te ni̱ nuu‑i kua̱no'on‑í jíín‑de jíná'an‑de. Te ni̱ najaa̱‑i ñuu̱ Nazaret, jándatu̱‑i nuu̱‑dé. Te náa̱‑i ni̱ chiva̱'a va̱'a‑ña táká tu̱'un yá'a ini̱ añú‑ña.
\v 52 Te Jesús, ni̱ ja'nu‑ga̱‑i, te ni̱ kundíchí‑ga̱‑i. Te Dios jíín táká ña̱yɨvɨ, ni̱ ka̱kusɨɨ̱‑gá ini̱ jíín‑i.
\c 3
\s1 Juan, cha̱a skuánducha
\p 
\v 1 Te nuu̱ xiá'u̱n kuia̱ ja̱ tá'ú tíñu cha̱a Tiberio César, te Poncio Pilato kúu‑de gobernador ñuu̱ Judea. Te Herodes tá'ú‑de tiñu ñuu̱ Galilea. Te ñani̱‑de Felipe tá'ú tíñu ñuu̱ Iturea ndañúu̱ Traconite. Te Lisanias tá'ú tíñu‑de ñuu̱ Abilinia.
\v 2 Te sutu̱ ñá'nu kákuu Anás jíín Caifás, te ni̱ chaa̱ tu̱'un máá Tatá Dios nuu̱ Juan, se̱'e Zacarías kánchaa̱‑de nuu̱ ñú'un té'é.
\v 3 Te ni̱ kii‑de ni̱ jíkó núu‑de nɨ́ɨ́ ñúu̱ Jordán. Te jáni‑de tu̱'un jánducha, jíín tú'un nakani ini̱ náva̱'a sá'a Dios tu̱ká'nu ini̱ nuu̱ kuáchi.
\v 4 Te súan ni̱ chaa Isaías tutu̱, chi cha̱a jáni tu̱'un Dios ni̱ kuu‑de sáá: Ɨɨn ndajá'a̱, kana jaa‑de onde̱ nuu̱ ñú'un té'é: Sátu̱'a‑ró íchi máá Jito'o̱‑yo̱, te sándóó‑ró íchi‑yá.
\v 5 Ta̱ká yi'ndɨ̱ nachítú. Te nuu ta̱ká yuku jíín tɨ́nduu̱. Te ndundóó íchi yákuá. Te ichi ndáí ndulɨɨ.
\v 6 Te ta̱ká ña̱yɨvɨ, kuni̱‑i ja̱ Dios nama‑ya̱‑í. Achí.
\v 7 Te ni̱ kenda koyo kua'a̱ ñáyɨvɨ núu̱‑dé ja̱ skuánducha‑dé‑i. Te ni̱ ka'a̱n‑de jíín‑i: Se̱'e koo̱ kákuu‑ró. Ndéja̱ ní kastu̱'ún núu̱‑ro̱ já kúnu‑ró kóto‑ró juicio chaa̱.
\v 8 Núsáá te sá'a‑ró tíñu sɨkɨ̱ já á ni̱ nakani ini̱‑ro̱‑ún. Te ma̱ kéjá'á‑ró káni ini̱‑ro̱: Abraham kúu táa̱‑ri̱, achí‑ro̱. Chi̱ ká'a̱n‑ri̱ jíín‑ró ja̱ kúu‑ni sá'a Dios ja̱ táká yuu̱ yá'a nduu se̱'e Abraham.
\v 9 Te vina a kátúu tú'a hacha ja̱ xɨ́tɨ yúnu ondé yo'o. Te ta̱ká yunu já tú kúun nde'e̱ vá'a xini̱, xɨtɨ̱ te kɨ̱vɨ nuu̱ ñú'u̱n. Achí‑de.
\v 10 Te ña̱yɨvɨ kuá'a̱‑ún, ni̱ kajika̱ tu̱'ún‑i‑de: Te ndasa sá'a‑ná núsáá, áchí‑i.
\v 11 Te ni̱ ka'a̱n‑de: Ja̱ ñáva̱'a uu̱ su'nu̱, ná kuá'a nuu̱ já tú ñáva̱'a kutɨ. Te ja̱ ñáva̱'a ja̱ kée, suni súan ná sá'a, áchí‑de jíín‑i.
\v 12 Te suni ni̱ cha̱koyo yaku̱ cha̱a xíní já kuánducha‑dé. Te ni̱ kaka'a̱n‑de jíín Juan: Maestro, te náá, na̱ún sá'a‑ná, áchí‑de.
\v 13 Te ni̱ ka'a̱n‑de jíín: Ma̱ skáa‑ró kakán‑ro̱ ndasa ni̱ ta'u̱ tíñu nuu̱‑ro̱, áchí‑de.
\v 14 Te suni yaku̱ soldado, ni̱ kajika̱ tu̱'ún yúan‑de: Te náá, ndasa sá'a‑ná jíná'an‑ná, áchí. Te ni̱ ka'a̱n‑de jíín: Ma̱ kuánchaa̱‑ro̱ ndátíñu tá'an‑ró, ni ma̱ sátú'ún‑ró, te koo sɨɨ̱‑ní ini̱‑ro̱ jíín yá'u‑ró.
\v 15 Te kájani ini̱ ta̱ká cha̱a sɨkɨ̱ Juan ja̱ sánaa te kúu‑de Cristo xí túu, chi ña̱yɨvɨ‑ún, káinda̱tu‑i chaa̱‑ya̱.
\v 16 Te ni̱ ka'a̱n Juan: Ruu̱, chi̱ jíín ndúcha skuánducha ndíja‑ri̱ róó. Ko va̱i ɨɨn I'a̱ kúñá'nu‑ga̱ vásá rúu̱, ja̱ tú kúñá'nu‑ri̱ ndájí‑rí ñii yí'i ndija̱n‑yá. Máá‑yá, chi̱ jíín Espíritu Santo skuánducha‑yá róó jíín ñú'u̱n.
\v 17 Te tɨ́ɨn‑ya̱ pala chíxí'ú trigo. Te nasándoo va̱'a‑ya̱ era‑ya̱. Te nastútú‑yá trigo ndɨ̱vɨ ini̱ yaka̱‑ya̱. Te ka'mu‑ya̱ paja nuu̱ ñú'u̱n ja̱ má ndá'va̱ kutɨ‑gá.
\v 18 Te kua'a̱‑gá tu̱'un ni̱ ka'a̱n xaa̱n‑dé nuu̱ ñáyɨvɨ‑ún. Chi̱ súan ni̱ jani‑de tu̱'un va̱'a‑ya̱ núu̱‑í.
\v 19 Te suni ni̱ ka'a̱n xaa̱n‑dé nuu̱ Herodes, cha̱a tá'ú tíñu‑ún. Chi cha̱a‑ún, ni̱ jaka‑de Herodías, ñasɨ́'ɨ́ ñani̱‑de Felipe. Te kua'a̱‑gá tiñu ñáá súan ni̱ sá'a Herodes.
\v 20 Te ja̱ ví'í‑gá ni̱ sá'a‑de kúu ja̱ ní chindee‑de Juan veka̱a.
\s1 Ja̱ ní janducha Jesús ni̱ sá'a Juan
\p 
\v 21 Te nuu̱ ní ndɨ'ɨ ni̱ ka̱janducha ñáyɨvɨ, te suni ni̱ janducha Jesús. Te nini jikán ta'u̱‑yá, te ni̱ nuña‑ni andɨ́vɨ́.
\v 22 Te nátu̱'un forma paloma ni̱ jungava Espíritu Santo sɨkɨ̱‑yá. Te ichi ándɨ́vɨ́ ní kenda ɨɨn tu̱'un ni̱ ka'a̱n: Máá‑ró kúu Se̱'e‑ri̱ te kúndá'ú ini̱‑ri̱ róó. Te kúsɨɨ̱ iní‑ri̱ jíín‑ró. Achí.
\s1 Lista ndasa va̱i tata̱ Jesucristo
\p 
\v 23 Te ná ni̱ kejá'á Jesús stá'a̱n‑ya̱ tú'un, íó‑ya̱ okó uxi̱ kuia̱. Te kájani ini̱ ña̱yɨvɨ já sé'e José kúu‑ya̱. Te táa̱ José ni̱ kuu Elí,
\v 24 ja̱ kúu se̱'e Matat, se̱'e Leví, se̱'e Melqui, se̱'e Jana, se̱'e José,
\v 25 ja̱ kúu se̱'e Matatías, se̱'e Amós, se̱'e Nahum, se̱'e Esli, se̱'e Nagai,
\v 26 ja̱ kúu se̱'e Maat, se̱'e Matatías, se̱'e Semei, se̱'e José, se̱'e Judá,
\v 27 ja̱ kúu se̱'e Joana, se̱'e Resa, se̱'e Zorobabel, se̱'e Salatiel, se̱'e Neri,
\v 28 ja̱ kúu se̱'e Melqui, se̱'e Adi, se̱'e Cosam, se̱'e Elmodam, se̱'e Er,
\v 29 ja̱ kúu se̱'e Josué, se̱'e Eliezer, se̱'e Jorim, se̱'e Matat,
\v 30 ja̱ kúu se̱'e Leví, se̱'e Simeón, se̱'e Judá, se̱'e José, se̱'e Jonán, se̱'e Eliaquim,
\v 31 ja̱ kúu se̱'e Melea, se̱'e Mainán, se̱'e Matata, se̱'e Natán,
\v 32 ja̱ kúu se̱'e David, se̱'e Isaí, se̱'e Obed, se̱'e Booz, se̱'e Salmón, se̱'e Naasón,
\v 33 ja̱ kúu se̱'e Aminadab, se̱'e Aram, se̱'e Esrom, se̱'e Fares, se̱'e Judá,
\v 34 ja̱ kúu se̱'e Jacob, se̱'e Isaac, se̱'e Abraham, se̱'e Taré, se̱'e Nacor,
\v 35 ja̱ kúu se̱'e Serug, se̱'e Ragau, se̱'e Peleg, se̱'e Heber, se̱'e Sala,
\v 36 ja̱ kúu se̱'e Cainán, se̱'e Arfaxad, se̱'e Sem, se̱'e Noé, se̱'e Lamec,
\v 37 ja̱ kúu se̱'e Matusalén, se̱'e Enoc, se̱'e Jared, se̱'e Mahalaleel, se̱'e Cainán,
\v 38 ja̱ kúu se̱'e Enós, se̱'e Set, se̱'e Adán, se̱'e Dios.
\c 4
\s1 Sɨkɨ̱ já ní jito nchaa̱ tá'an kui'na̱ jíín‑yá
\p 
\v 1 Te Jesús, ni̱ chítú ndɨ́ɨ‑yá jíín Espíritu Santo. Te ni̱ ndenda‑ya̱ yúcha Jordán kua'a̱n‑ya̱. Te ni̱ jaa̱‑ya̱ ondé nuu̱ ñú'un té'é ní sá'a Espíritu Santo.
\v 2 Te yúan ni̱ kanchaa̱‑ya̱ úu̱ xiko kɨvɨ̱. Te ni̱ jito nchaa̱ tá'an kui'na̱ jíín‑yá. Te ta̱ká kɨvɨ̱‑ún, tú ní yée kútɨ‑yá, chi̱ onde̱ ni̱ ja̱'a kɨvɨ̱, te vásá ni̱ ji'i̱‑ya̱ sóko.
\v 3 Yúan‑na te ni̱ kachi̱ kui'na̱‑ún jíín‑yá: Nú Se̱'e Dios kúu‑ró, ka'a̱n jíín yúu̱ yá'a ná ndúu staa̱, áchí.
\v 4 Te Jesús ni̱ ka'a̱n‑ya̱ jíín: Yóso núu̱ tutú: Nasu̱ máni máá stáa̱ kée cháa te kuchaku̱‑de, chi̱ sua jíín tú'un Dios, áchí‑ya̱.
\v 5 Te ni̱ jaka kui'na̱‑ún‑ya̱ kuá'a̱n jíín‑yá xini̱ ɨ́ɨn yuku súkún. Te ɨɨn núnúu‑ni te ni̱ stá'a̱n‑ni ta̱ká ñuu̱ nɨ́ɨ́ ñúyɨ́vɨ núu̱‑yá.
\v 6 Te ni̱ kachi̱ kui'na̱‑ún jíín‑yá: Kua̱'a‑ri̱ ta̱ká ñuu̱ luu yá'a nuu̱‑ro̱ te tá'ú tíñu‑ró núu̱. Chi̱ máá‑rí tɨ́ɨn ndɨ'ɨ, te ndé nuu̱ kuní‑ri̱, te kuu kua̱'a‑ri̱.
\v 7 Núsáá te nú chiñú'ún‑ró rúu̱, te kua̱'a‑ri̱ ta̱ká ñuu̱ yá'a nuu̱‑ro̱. Achí.
\v 8 Te ni̱ ka'a̱n Jesús: Satanás, kuxio kuá'án, chi̱ yóso núu̱ tutú: Chiñú'ún‑ró máá Tatá Dios máá‑ró, te nuu̱ máá ɨ́ɨn‑ni‑ya̱ kuátíñu‑ró, áchí. Achí‑ya̱.
\v 9 Te kua'a̱n tuku jíín‑yá ñuu̱ Jerusalén. Te yúan ni̱ kaa jíín‑yá xini̱ torre ve'e ii̱. Te ni̱ ka'a̱n jíín‑yá: Te nú Se̱'e Dios kúu‑ró, te súngava‑ró máá‑ró yá'a te onde̱ nuu̱ ñú'un,
\v 10 chi̱ yóso núu̱ tutú: Tájí‑yá ndajá'a̱‑yá kii te koto‑ya̱ róó.
\v 11 Kunu nchaa̱‑ya̱ róó náva̱'a tú stují‑ro̱ já'a̱‑ro̱ núu̱ yúu̱, áchí. Achí kui'na̱.
\v 12 Te ni̱ ka'a̱n Jesús: A yóso núu̱ tutú: Ma̱ kóto nchaa̱‑ro̱ máá Tatá‑ro̱ Dios, áchí‑ya̱ jíín kuí'na̱‑ún.
\v 13 Te ni̱ ndɨ'ɨ ni̱ jito nchaa̱ kui'na̱‑ún‑ya̱. Te ni̱ kuxio núu‑ni kua'a̱n.
\s1 Ja̱ ní ka̱ské'ichi̱‑i‑ya̱ iní ñuu̱ Nazaret
\p 
\v 14 Te jíín fuerza Espíritu kua̱no'on Jesús ñuu̱ Galilea. Te ni̱ jicha̱ tu̱'un‑ya̱ nɨ́ɨ́ ndáñúu̱ yani yúan.
\v 15 Te ni̱ stá'a̱n‑ya̱ tú'un ini̱ ve̱'e sinagoga ña̱yɨvɨ yúan. Te ni̱ ka̱nakana jaa ndɨ'ɨ‑i‑ya̱.
\v 16 Te ni̱ jaa̱‑ya̱ ñúu̱ Nazaret, nuu̱ ní ja'nu‑ya̱. Te ni̱ kɨ̱vɨ‑ya̱ iní ve̱'e sinagoga nátu̱'un sá'a‑ya̱ táká kɨvɨ̱ ndéta̱tú. Te ni̱ ndukuiñi̱‑ya̱ ní ka'u‑ya̱ ɨ́ɨn tutu̱.
\v 17 Te yúan íó tutu̱ Isaías cha̱a ni̱ jani tu̱'un Dios onde̱ sáá. Te ni̱ kaja̱'a‑de nuu̱ Jesús. Te ni̱ janu̱‑ya̱ tutú‑ún. Te ni̱ jini̱‑ya̱ ɨ́ɨn nuu̱ yóso, te ni̱ ka'u‑ya̱:
\v 18 Espíritu máá Tatá Dios jíka‑ya̱ jíín‑rí, chi ni̱ teta'a̱n‑ya̱ rúu̱ náva̱'a kani‑ri̱ tu̱'un va̱'a nuu̱ ñáyɨvɨ ndá'ú. Te ni̱ tájí‑yá ruu̱ va̱i‑ri̱ náva̱'a sá'a‑ri̱ tana̱ ñáyɨvɨ kákukuí'a̱ ini̱, te kastu̱'ún‑rí nuu̱ ñáyɨvɨ káindasu̱ koo libre‑i. Te ta̱ká ña̱yɨvɨ kuáá, ndundiji̱n nuu̱‑í, te nama‑ri̱ ña̱yɨvɨ ní katuji̱.
\v 19 Te náva̱'a kani‑ri̱ tu̱'un sɨkɨ̱ kuiá játa'a̱n ini̱ máá Tatá Dios, áchí‑ya̱.
\v 20 Te ni̱ na̱tuu‑yá tutu̱‑ún. Te ni̱ nakua̱'a‑ya̱ núu̱ cháa játíñu. Te ni̱ nungo̱o‑ya̱. Te ta̱ká cha̱a ká'i̱in ini̱ ve̱'e sinagoga, kánde̱'é vá'a‑de nuu̱‑yá.
\v 21 Yúan‑na te ni̱ ka'a̱n‑ya̱ jíín‑de: Vina a ni̱ ka̱jini so̱'o‑ró já ní skíkuu tu̱'un ká'a̱n tutu̱ ii̱ yá'a, áchí‑ya̱.
\v 22 Te ndivii‑dé ni̱ kaka'a̱n va̱'a‑de tu̱'un‑ya̱. Te kánaa iní‑de kánde̱'é‑de nuu̱‑yá ja̱ lúu ká'a̱n‑ya̱. Te ni̱ kaka'a̱n‑de: Á nasu̱ sé'e José kúu cha̱a yá'a. Achí‑de.
\v 23 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Jáni ini̱‑ri̱ ja̱ sánaa te ka'a̱n‑ro̱ tú'un yátá yá'a jíín‑rí: Cha̱a táná, sá'a tana̱ máá‑ró, te ta̱ká tiñu ni̱ ka̱jini tu̱'un‑ri̱ ni̱ sá'a‑ró ñúu̱ Capernaum, suni súan ná sá'a‑ró ñúu̱‑ro̱ yá'a vii̱, achi̱‑ro̱.
\v 24 Te ni̱ ka'a̱n‑ga̱‑ya̱: Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró, ja̱ ñáyɨvɨ máá ñúu̱ cha̱a jáni tu̱'un Dios, máá‑i kúu ja̱ tú kájatá'ú‑i‑de.
\v 25 Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró, ja̱ ní i̱o kua'a̱ ñá'an ní kendo̱o ndá'ú ñuu̱ Israel kɨvɨ̱ ní chaku̱ Elías, te kɨvɨ̱‑ún ni̱ ndasu̱ andɨ́vɨ́ uní kuia̱ iñu̱ yoo̱. Te ni̱ i̱o ɨɨn tama̱ xáa̱n nɨ́ɨ́‑ni ñuu̱‑ún.
\v 26 Ko tú ní tájí‑yá Elías ki'i̱n‑de nuu̱ ní ɨɨn ña'an‑ún, chi̱ máá‑ni onde̱ ñuu̱ Sarepta ndañúu̱ Sidón ni̱ ja'a̱n‑de nuu̱ ɨ́ɨn ña'an ní kendo̱o ndá'ú.
\v 27 Te ini̱ ñuu̱ Israel, suni ni̱ i̱o kua'a̱ cháa ni̱ kate'yu̱ ndɨ̱'yi, kɨvɨ̱ ní chaku̱ Eliseo, cha̱a ni̱ jani tu̱'un Dios. Ko tú ni ɨɨn cha̱a‑ún ní ndúndoo, chi̱ máá‑ni Naamán, cha̱a ñuu̱ Siria. Achí‑ya̱.
\v 28 Yúan‑na te ta̱ká cha̱a ká'i̱in ini̱ ve̱'e sinagoga, ni̱ kakiti̱ ini̱‑de ja̱ ní ka̱jini so̱'o‑de tu̱'un ká'a̱n‑ya̱.
\v 29 Te ni̱ ka̱ndonda‑de sɨkɨ̱‑yá ni̱ ka̱kiñi'in‑de‑ya̱ yatá ñúu̱‑ún, te kua'a̱n‑de jíín‑yá xini̱ yúku núu̱ kándii̱ ñuu̱‑de. Te yúan súngava‑de‑ya̱ kákuni̱‑de.
\v 30 Ko máá‑yá, ni̱ ja̱'a‑ya̱ má'ñú‑de, te kua'a̱n‑ya̱.
\s1 Ja̱ ní kiñi'in‑ya̱ tachí kíni
\p 
\v 31 Te ni̱ najinu̱‑ya̱ ñúu̱ Capernaum, ndañúu̱ Galilea. Te ni̱ stá'a̱n‑ya̱ tú'un nuu̱‑dé jíná'an‑de ndɨta'a̱n kɨvɨ̱ ndéta̱tú.
\v 32 Te ni̱ ka̱naa iní‑de kájini so̱'o‑de tu̱'un stá'a̱n‑ya̱, chi̱ ni̱ stá'a̱n‑ya̱ nátu̱'un ɨɨn cha̱a ndíso tíñu.
\v 33 Te ini̱ ve̱'e sinagoga kándee ɨɨn cha̱a tá'a̱n tachi̱ kíni. Te cha̱a‑ún, ni̱ kana kó'ó‑de:
\v 34 Kuxio‑ní Táta̱, chi̱ tú káyi̱tá'an‑ná jíín‑ní, Jesús ñuu̱ Nazaret. Va̱i‑ní xnáa‑ní náá náún. A jiní‑ná na̱ níí kúu, cha̱a ndoo nuu̱ Dios. Achí.
\v 35 Te Jesús, ni̱ ka'a̱n xaa̱n‑yá jíín: Kasu̱ yu'u‑ro te kenda‑ró‑de, áchí‑ya̱. Yúan‑na te ni̱ ndua̱‑ni cha̱a‑ún ma̱'ñú ñáyɨvɨ, ni̱ sá'a tachi̱ kíni‑ún. Te ni̱ kenda kua'a̱n ini̱‑de. Te tú na̱ún ní sá'a jíín‑de.
\v 36 Te ndivii‑í, ni̱ kayu̱'ú‑i. Te kándatu̱'ún‑i: Na̱ún tu̱'un kúu ya̱'á. Chi̱ ndíso tíñu‑de ja̱ tá'ú ní'in‑de tiñu nuu̱ tachí kíni te kénda koyo, káka'a̱n‑i.
\v 37 Te tu̱'un‑ya̱ ní jicha̱ nu̱u kua'a̱n ta̱ká lado ndañúu̱ yúan.
\s1 Ja̱ ní nasáva̱'a‑ya̱ náchi̱só Pedro jíín sáva‑ga̱‑i
\p 
\v 38 Yuán‑na te ni̱ ndukuiñi̱ Jesús, ni̱ kenda‑ya̱ iní ve̱'e sinagoga. Te ni̱ kɨ̱vɨ‑ya̱ vé'e Simón. Te náchi̱só Simón, yí'i xaa̱n kíji‑ña. Te ni kaka'a̱n nda̱'ú‑de jíín‑yá ndasa kuu‑ña.
\v 39 Te ni̱ kandita‑ya̱ núu̱‑ñá, te ni̱ ka'a̱n xaa̱n‑yá nuu̱ kíji‑ún. Te ni̱ kee‑ni ki̱ji‑ún‑ña. Te ni̱ nduko̱o‑ni‑ña. Te ni̱ jatíñu‑ña núu̱‑yá jíná'an‑ya̱.
\v 40 Te kuake̱e ndika̱ndii, te ta̱ká ja̱ káñava̱'a ña̱yɨvɨ káku'u̱ tɨnɨ̱ nuu̱ kué'e̱, ni̱ ka̱kinchaka‑i nuu̱‑yá. Te ni̱ xndée‑ya̱ ndá'a‑yá sɨkɨ̱ ɨ́ɨn ɨɨn‑i te ni̱ nasáva̱'a‑ya̱‑í.
\v 41 Te suni ini̱ kua'a̱ ñáyɨvɨ ní ka̱kenda tachi̱ kíni. Te ni̱ ka̱kana kó'ó: Máá‑ní kúu Se̱'e Dios, áchí. Ko ni̱ ka'a̱n xaa̱n‑yá jíín. Te tú ní já'a‑ya̱ tú'un ka'a̱n. Chi̱ a kájini̱ ja̱ máá‑yá kúu Cristo.
\v 42 Te ni̱ kundiji̱n. Te ni̱ kenda‑ya̱ kuá'a̱n‑ya̱ ɨ́ɨn nuu̱ ñú'un té'é. Te ña̱yɨvɨ kánandúkú‑i‑ya̱, ni̱ ja̱koyo‑i nuu̱‑yá. Te kásténdatu‑i‑ya̱ náva̱'a tú kuxio‑ya̱ núu̱‑í núú.
\v 43 Ko máá‑yá ni̱ ka'a̱n‑ya̱ jíín‑i: Jínu ñú'ún já súni nuu̱ sáva‑ga̱ ñuu̱ kani‑ri̱ tu̱'un va̱'a ñuu̱ nuu̱ tá'ú Dios tiñu. Chi yu̱án ní tájí‑yá ruu̱ va̱i‑ri̱. Achí‑ya̱.
\v 44 Te jáni‑ya̱ tú'un ini̱ ve̱'e sinagoga ñuu̱ Galilea.
\c 5
\s1 Ja̱ ní kana‑ya̱ xiní cháa tɨ́ɨn ti̱yáká
\p 
\v 1 Te ni̱ kuu ja̱ kándee Jesús yu'u mar Genesaret. Te ña̱yɨvɨ, ni̱ kajaxi̱n‑i‑ya̱ já ndúkú‑i kuni so̱'o‑i tu̱'un Dios.
\v 2 Te ni̱ jini̱‑ya̱ úu̱ barco ká'i̱in yani yu'u mar. Te cha̱a kátɨɨn ti̱yáká, a ni̱ ka̱kenda‑de ini̱ barco. Te kánakacha‑de ñunu‑dé.
\v 3 Te ni̱ kɨ̱vɨ‑ya̱ iní barco Simón. Te ni̱ ka'a̱n‑ya̱ jíín‑de ja̱ ná skáka‑de ɨɨn tí'li̱ kuxio nuu̱ ñú'un. Te ni̱ jungo̱o‑ya̱. Te onde̱ ini̱ barco ni̱ stá'a̱n‑ya̱ tú'un nuu̱ ñáyɨvɨ.
\v 4 Te nuu̱ ní ji̱nu ni̱ ka'a̱n‑ya̱, te ni̱ kachi̱‑ya̱ jíín Simón: Ná chó'o̱ núu̱ kúnú ndúcha, te skuíta ka'nu‑ró ñúnu‑ro, te tɨɨn‑ró tíyáká, áchí‑ya̱.
\v 5 Te ni̱ ka'a̱n Simón: Maestro, nɨ́ɨ́ niñú ni̱ ka̱sátiñu‑ná, ko tú ni ɨɨn ní kátɨɨn kutɨ‑ná. Ko ja̱ ká'a̱n máá‑ní kúu, te ná skuíta ka'nu‑ná ñunu‑ná, áchí‑de.
\v 6 Te ni̱ sá'a‑de súan. Te ni̱ jasu̱‑de ti̱yáká kuá'a̱ xáa̱n iní ñunu‑dé. Te ñunu‑dé ndúkú té'nde̱ núú.
\v 7 Te ni̱ ka̱sá'a‑de seña nuu̱ tá'an‑de, ká'i̱in ini̱ ɨnga̱ barco, ná kíi chindéé tá'an jíín‑de. Te ni̱ cha̱koyo‑de. Te ni̱ ka̱schítú ndɨ́ɨ‑dé‑tɨ̱ iní ndendúú barco ja̱ kuní ke̱e barco‑ún chi̱i nducha núú.
\v 8 Te Simón Pedro, ni̱ jini̱‑de ja̱ súan ni̱ kuu. Te ni̱ jukuiñi̱ jítɨ́‑de nuu̱ Jesús, te ni̱ ka'a̱n‑de: Kuxio‑ní Táta̱, chi cha̱a íó kua̱chi kúu‑ná, áchí‑de.
\v 9 Chi̱ máá‑de jíín táká ja̱ ní ka̱chindéé tá'an jíín‑de‑ún, ni̱ ka̱naa iní‑de kánde̱'é‑de ja̱ ní katɨɨn‑de ti̱yáká‑ún,
\v 10 te suni súan Jacobo jíín Juan, ndendúú se̱'e Zebedeo, chi cha̱a káchindéé tá'an jíín Simón kákuu‑de. Te ni̱ kachi̱ Jesús jíín Simón: Ma̱ yú'ú‑ro̱. Onde̱ vina te tɨɨn‑ró cháa. Achí‑ya̱.
\v 11 Yúan‑na te nuu̱ ní ka̱ndenda barco nuu̱ ñú'un íchí, te ni̱ ka̱xndóo ndɨ'ɨ‑de ndatíñu‑de. Te ni̱ kandiki̱n‑de‑ya̱.
\s1 Ja̱ ní nasáva̱'a‑ya̱ ɨ́ɨn cha̱a té'yu̱ ndɨ̱'yi
\p 
\v 12 Te Jesús, kándee‑ya̱ ɨ́ɨn ñuu̱. Te ni̱ jaa̱ ɨɨn cha̱a nuu̱‑yá, té'yu̱ ndɨ̱'yi‑de. Te cha̱a‑ún, ni̱ jini̱‑de nuu̱ Jesús. Te ni̱ jukuiñi̱ jítɨ́‑de. Te ni̱ ka'a̱n nda̱'ú‑de jíín‑yá: Táta̱, nú kuní‑ní te kuu nasándoo‑ní náá, áchí‑de.
\v 13 Yúan‑na te ni̱ skáa̱‑ya̱ ndá'a‑yá. Te ni̱ ké'é‑yá‑de. Te ni̱ ka'a̱n‑ya̱: Kuní‑ri̱, ná ndúndoo‑ró, áchí‑ya̱. Te ndɨ̱'yi té'yu̱‑ún, ni̱ kuxio‑ni kua'a̱n.
\v 14 Te ni̱ ka'a̱n xaa̱n‑yá jíín‑de: Ma̱ kachí kutɨ‑ro núu̱ ní ɨɨn. Chi̱ kuá'án, te stá'a̱n‑ro̱ máá‑ró núu̱ sutú. Te kundá'á‑ró ndátíñu stá'a̱n‑ro̱ núu̱‑dé, náva̱'a kuni̱‑de ja̱ ní ndundoo‑ró, nátu̱'un ni̱ tá'ú Moisés tiñu sáá. Achí‑ya̱.
\v 15 Ko tu̱'un‑ya̱‑ún, ni̱ jicha̱‑ga̱ kua'a̱n. Te ni̱ kataka̱ kua'a̱ xáa̱n ñáyɨvɨ já kúni ná'ín‑i, te nduva̱'a‑i ta̱ká kue'e̱ káta'a̱n‑i kákuni̱‑i.
\v 16 Te máá‑yá, ni̱ kusɨ́ɨn‑ya̱ kuá'a̱n‑ya̱ ondé ñu'un té'é. Te yúan ni̱ jika̱n ta'u̱‑yá.
\s1 Cha̱a ni̱ kuyúnú
\p 
\v 17 Te ɨɨn kɨvɨ̱ kándee Jesús stá'a̱n‑ya̱ tú'un. Te cha̱a fariseo jíín maestro ley, káxiu̱kú‑de yúan. Te cha̱a‑ún, ni̱ kikoyo‑de ichi táká ñuu̱ Galilea ndañúu̱ Judea jíín ñúu̱ Jerusalén. Te fuerza máá Tatá Dios kándee jíín‑yá náva̱'a nasáva̱'a‑ya̱ ñáyɨvɨ kú'u̱.
\v 18 Te ni̱ chaa̱ yaku̱ cha̱a, te nuu̱ ɨ́ɨn ji̱to yuu kándi̱so‑de ɨɨn cha̱a ni̱ kuyúnú. Te kándúkú‑de skɨ́vɨ‑de cha̱a‑ún nuu̱ kándee‑ya̱, te kani‑de cha̱a‑ún nuu̱‑yá.
\v 19 Te ja̱ kuá'a̱ ñáyɨvɨ, te tú ní káni'i̱n‑dé ndénu̱ skɨ́vɨ‑de cha̱a‑ún. Yúan‑na te ni̱ ka̱kaa‑de xini̱ vé'e. Te yúan ni̱ ka̱xndónda‑de teja, te ni̱ ka̱skúun‑de cha̱a‑ún nuu̱ Jesús sava ma̱'ñú jíín jíto yuu.
\v 20 Te ni̱ jini̱‑ya̱ já kákandíja cha̱a‑ún. Te ni̱ ka'a̱n‑ya̱ jíín cháa ni̱ kuyúnú‑ún: Súchi̱, a íó tu̱ká'nu ini̱ nuu̱ táká kua̱chi‑ró, áchí‑ya̱.
\v 21 Yúan‑na te cha̱a káchaa tutu̱ jíín cháa fariseo, ni̱ kejá'á‑de kájani ini̱‑de: Ndé cha̱a kúu ya̱'á ja̱ ká'a̱n tu̱'un ndɨva̱'a. Ndéja̱ kúu sá'a tu̱ká'nu ini̱ nuu̱ kuáchi, chi̱ ɨɨn‑ni máá Dios, áchí‑de.
\v 22 Yúan‑na te Jesús, a ni̱ jini̱‑ya̱ já súan kájani ini̱‑de. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Na̱ún kájani ini̱‑ro̱.
\v 23 Ja̱ úu̱ tu̱'un yá'a ndéja̱ yíí‑ga̱ káa. Á ka'a̱n‑ri̱: A íó tu̱ká'nu ini̱ nuu̱ táká kua̱chi‑ró, xí ká'a̱n‑ri̱: Nduko̱o, te kaka‑ró.
\v 24 Ko náva̱'a ná kuní‑ro̱ já máá Sé'e cha̱a ndíso‑ya̱ tíñu nuu̱ ñúyɨ́vɨ yá'a ja̱ sá'a‑ya̱ túká'nu ini̱ nuu̱ kuáchi, te ná ká'a̱n‑ri̱ ɨnga̱ tu̱'un jíín cháa ni̱ kuyúnú yá'a núsáá: Jíín‑ró ká'a̱n‑ri̱, nduko̱o, te naki'in‑ró jíto yuu‑ro, te no'o̱n‑ro̱ vé'e‑ró. Achí‑ya̱.
\v 25 Te ni̱ nduko̱o‑ni cha̱a‑ún jíto nuu̱ ñáyɨvɨ‑ún. Te ni̱ naki'in‑de ji̱to nuu̱ ní ka̱túu‑dé‑ún. Te kua̱no'on‑dé ve'e‑de, nákana jaa‑de Dios.
\v 26 Te ta̱ká ña̱yɨvɨ‑ún, ni̱ ka̱naa iní‑i kánde̱'é‑i. Te ni̱ kayu̱'ú xaa̱n‑í. Te ni̱ ka̱nakana jaa‑i Dios: Vina te ni̱ ka̱jini̱‑yo̱ tíñu ñá'nu xaa̱n yá'a, áchí‑i.
\s1 Ja̱ ní kana‑ya̱ xiní Leví
\p 
\v 27 Yu̱án‑na, te ni̱ kenda Jesús kua'a̱n‑ya̱. Te ni̱ jini̱‑ya̱ núu̱ ɨ́ɨn cha̱a xíní, nání‑de Leví, kánchaa̱‑de nuu̱ kútútú xú'ún ñúu̱. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Kundiki̱n‑ro̱ rúu̱, áchí‑ya̱.
\v 28 Te ni̱ xndóo‑de ta̱ká ndatíñu‑de. Te ni̱ ndukuiñi̱‑de. Te ni̱ ndiki̱n‑de‑ya̱.
\v 29 Te ni̱ sá'a Leví ɨɨn gasto ká'nu ini̱ ve̱'e‑de, te ni̱ i̱o kua'a̱ tá'an‑de, cha̱a xíní jíín sáva‑ga̱‑de. Te cha̱a‑ún, káyee‑dé staa̱ jíín‑yá.
\v 30 Te cha̱a káchaa tutu̱ jíín cháa fariseo, ni̱ kaka'a̱n‑de sɨkɨ̱ cháa káskuá'a jíín‑yá: Naja̱ káyee‑ro káji'i‑ró jíín cháa xíní jíín cháa ká'i̱o kua̱chi, áchí‑de.
\v 31 Te ni̱ ka'a̱n Jesús, cha̱a ká'i̱o ndáján, tú kánandɨ'ɨ‑de cha̱a táná, chi cha̱a káku'u̱ kúu ja̱ kájinu ñú'ún.
\v 32 Na̱ tú va̱i‑ri̱ kana‑ri̱ xini̱ cháa ndaa̱. Chi cha̱a ká'i̱o kua̱chi, kána‑ri̱ xini̱ ná nákani ini̱‑de, áchí‑ya̱ jíín‑de.
\s1 Sɨkɨ̱ tú'un kondicha̱ ini̱
\p 
\v 33 Yúan‑na te ni̱ kaka'a̱n‑de jíín‑yá: Cha̱a káskuá'a jíín Juan, tɨnɨ̱ jínu ká'i̱o ndicha̱ ini̱‑de te kájika̱n ta'u̱‑dé. Te suni súan kásá'a cha̱a káskuá'a jíín cháa fariseo. Ko cha̱a káskuá'a jíín máá‑ní, naja̱ máni káyee‑dé káji'i‑de. Achí‑de.
\v 34 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Á kuu sá'a‑ró já kóndicha̱ ini̱ ña̱yɨvɨ ká'i̱in viko tánda'a, te nú kánchaa̱ yii jíín‑i.
\v 35 Ko chaa̱ ɨɨn kɨvɨ̱ já kuxio yii núu̱‑í. Te kɨvɨ̱‑ún, kuu kondicha̱ ini̱‑i. Achí‑ya̱.
\v 36 Te ni̱ ka'a̱n‑ya̱ ɨ́ɨn tu̱'un yátá jíín‑de: Tú ni ɨɨn náchu'un sa'ma jáá núu̱ sú'nu̱ tu̱'ú. Te nú súan, suni máá já jáá‑ún ka'ncha̱‑ga̱, chi̱ nuu̱ sú'nu̱ tu̱'ú ma̱ kúu nuku̱'un sa'ma jáá.
\v 37 Te tú ni ɨɨn chu'un vino jáá iní ñii tú'ú, chi̱ nú súan, te máá vino jáá‑ún ndátá ñíi‑ún, te vino‑ún katɨ, te ñii‑ún naa.
\v 38 Ko vino jáá jíín ñíi jáá, kúu ja̱ kúu ku'un ini̱. Te kendo̱o va̱'a ndendúú.
\v 39 Te tú ni ɨɨn‑i íó, ja̱ á ni̱ ji'i‑i ja̱ tu̱'ú, te kuní tuku‑i ko'o‑i ja̱ jáá, chi: Ja̱ ni̱ kutú'ú kúu ja̱ vá'a‑ga̱, áchí‑i. Achí‑ya̱.
\c 6
\s1 Ja̱ ní ka̱kachi‑de yoko trigo kɨvɨ̱ ndéta̱tú
\p 
\v 1 Te kɨvɨ̱ ndéta̱tú nuu̱ semana uni̱, te ni̱ ja̱'a Jesús kua'a̱n‑ya̱ ɨ́ɨn nuu̱ káa trigo. Te cha̱a káskuá'a jíín‑yá ni̱ ka̱kachi‑de yoko trigo, ni̱ ka̱kɨɨn‑dé ini̱ nda'a‑dé, te káyee‑dé.
\v 2 Te sava cha̱a fariseo ni̱ kaka'a̱n‑de jíín‑yá: Naja̱ kásá'a‑ró jián, chi̱ tú íó ley sá'a‑ró súan kɨvɨ̱ ndéta̱tú, áchí‑de.
\v 3 Te ni̱ ka'a̱n Jesús: Á tú ní káka'u kutɨ‑ro tutú na̱ún ní sá'a David. Chi̱ máá‑de jíín cháa ni̱ kaxiu̱kú jíín‑de, ni̱ kaji'i̱‑de so̱ko ɨɨn kɨvɨ̱.
\v 4 Te ni̱ kɨ̱vɨ‑de ini̱ ve̱'e Dios, te ni̱ ki'in‑de sta̱tilá káxiu̱kú ndijín, ni̱ yee‑dé. Te suni ni̱ ja̱'a‑de nuu̱ cháa káxiu̱kú jíín‑de‑ún ni̱ ka̱yee. Te tú íó ley kee ní ɨɨn cha̱a sta̱tilá‑ún, chi̱ máni sutu̱ káyee núú. Achí‑ya̱ jíín‑de.
\v 5 Te ni̱ ka'a̱n‑ga̱‑ya̱ jíín‑de: Máá Sé'e cha̱a, suni Jito'o̱ kɨvɨ̱ ndéta̱tú kúu‑ya̱, áchí‑ya̱.
\s1 Ɨɨn cha̱a ni̱ ichi̱ nda'a vá'a
\p 
\v 6 Te ɨnga̱ kɨvɨ̱ ndéta̱tú, suni ni̱ kɨvɨ̱‑ya̱ iní ve̱'e sinagoga, te ni̱ stá'a̱n‑ya̱ tú'un. Te yúan kándee ɨɨn cha̱a ni̱ ichi̱ káján ndá'a vá'a‑de.
\v 7 Te cha̱a fariseo jíín cháa káchaa tutu̱, kájito yu'u‑dé Jesús nú sá'a‑ya̱ taná kɨvɨ́ ndéta̱tú, náva̱'a kaka̱n‑de kua̱chi sɨkɨ̱‑yá kuní‑de.
\v 8 Ko máá‑yá, a ni̱ jini̱‑ya̱ tú'un kájani ini̱‑de. Te ni̱ ka'a̱n‑ya̱ jíín cháa kátí'íchi nda'a‑ún: Ndukuiñi̱, te ichi má'ñú yá'a kundii̱‑ro̱, áchí‑ya̱. Te máá cháa‑ún, ni̱ ndukuiñi̱‑de, te ni̱ jukuiñi̱‑de.
\v 9 Yúan‑na te ni̱ ka'a̱n Jesús jíín‑de jíná'an‑de: Ná kaká tu̱'ún‑rí róó ɨɨn tu̱'un. Ndé ley íó sɨkɨ̱ kɨvɨ́ ndéta̱tú. Á sá'a va̱'a‑yó, xí sá'a ñáá‑yo̱. Á nama‑yó ɨ́ɨn cha̱a ndúkú kúu̱, xí ká'ni‑yo ɨ́ɨn ndɨ̱yi. Achí‑ya̱.
\v 10 Te ndé'é‑yá nuu̱ táká ja̱ káxiu̱kú xíin‑yá‑ún. Te ni̱ ka'a̱n‑ya̱ jíín cháa kú'u̱: Skáa̱ nda'a‑ro, áchí‑ya̱. Te ni̱ sá'a‑de súan. Te nda'a‑dé‑ún, ni̱ nduva̱'a ii̱‑ní.
\v 11 Te máá‑ún, ni̱ kakiti̱ xaa̱n iní, te kándatu̱'ún ndasa sá'a jíín Jesús.
\v 12 Te ni̱ kuu kɨvɨ̱. Te ni̱ kenda Jesús kua̱kaka̱n ta'u̱‑yá onde̱ yuku. Te nɨ́ɨ́ niñú ni̱ jika̱n ta'u̱‑yá nuu̱ Dios.
\s1 Ja̱ ní ka̱ji‑ya̱ uxí uu̱ cha̱a skuá'a jíín‑yá
\p 
\v 13 Te nuu̱ ní kundiji̱n, te ni̱ kana‑ya̱ xiní cháa káskuá'a jíín‑yá. Te ni̱ naka̱ji‑ya̱ uxí uu̱ tá'a̱n‑de. Te cha̱a‑ún, ni̱ skúnání‑yá‑de apóstol.
\v 14 Te Simón, ni̱ naskúnání‑yá‑de Pedro, jíín ñaní‑de, Andrés, Jacobo, Juan, Felipe, Bartolomé.
\v 15 Mateo jíín Tomás, Jacobo se̱'e Alfeo, jíín Simón cha̱a nání Zelote,
\v 16 Judas ñani̱ Jacobo, jíín Judas Iscariote ja̱ ní nastúu‑de Jesús.
\s1 Tu̱'un ni̱ stá'a̱n‑ya̱ núu̱‑í
\p 
\v 17 Te ni̱ nuu‑ya̱ jíín‑de jíná'an‑de. Te ni̱ jukuiñi̱‑ya̱ ɨ́ɨn ndu'a̱. Te kua'a̱ xáa̱n cháa káskuá'a jíín‑yá jíín kuá'a̱ ñáyɨvɨ ñúu̱ Judea jíín ñáyɨvɨ ñúu̱ Jerusalén, jíín ñáyɨvɨ yú'u mar ñuu̱ Tiro jíín ñúu̱ Sidón, ni̱ kikoyo‑i ja̱ kúni ná'ín‑i tu̱'un ka'a̱n‑ya̱, te suni ja̱ ná ndúva̱'a‑i kue'e̱ káta'a̱n‑i kuní‑i.
\v 18 Te ta̱ká ña̱yɨvɨ kándo'o jíín tachí kíni, ni̱ kandu̱va̱'a ndɨ'ɨ‑i ni̱ sá'a‑ya̱.
\v 19 Te ndivii ñáyɨvɨ kuá'a̱‑ún, ni̱ ka̱ndúkú ndéé‑i ké'é‑i‑ya̱. Chi̱ íó fuerza ini̱‑ya̱. Te ni̱ nasáva̱'a‑ya̱ ta̱ká‑i.
\v 20 Te ni̱ ndakoto‑ya̱ núu̱ cháa káskuá'a jíín‑yá. Te ni̱ ka'a̱n‑ya̱: Xáán ndatu̱ róó, cha̱a káta'a̱n ndá'ú, chi̱ kuu kɨ̱vɨ‑ró ñúu̱ nuu̱ tá'ú Dios tiñu.
\v 21 Xáán ndatu̱ róó ja̱ káji'i̱‑ro̱ sóko vina, chi̱ nda'a̱ chi̱i‑ró. Xáán ndatu̱ róó ja̱ kánde'e̱‑ro̱ vína, chi̱ kuaku̱‑ro̱.
\v 22 Xáán ndatu̱ róó jíná'an‑ró nú kákiti̱ ini̱ cha̱a kájito‑de róó, jíín nú kákuxio‑de nuu̱‑ro̱ kí'i̱n‑de, jíín nú káka'a̱n tásɨ́‑de sɨkɨ̱‑ro̱, jíín nú káské'ichi̱‑de róó nátu̱'un cha̱a ñáá, ja̱ sɨkɨ́ máá Sé'e cha̱a.
\v 23 Sɨɨ̱ ná kóo ini̱‑ro̱ kɨvɨ̱‑ún, te kusɨɨ̱ xáa̱n iní‑ro̱, chi̱ ká'nu xaa̱n kóo ta'u̱‑ro̱ ondé andɨ́vɨ́. Chi̱ súan ni̱ ka̱sá'a táa̱‑de jíín cháa ni̱ ka̱jani tu̱'un Dios onde̱ sáá.
\v 24 Ko naka̱ ndá'ú kúu róó, cha̱a kúká, chi̱ vina‑ni ká'i̱o sɨɨ̱ iní‑ro̱.
\v 25 Naka̱ ndá'ú kúu róó ja̱ ká'i̱in tɨɨ chi̱i‑ró vína, chi̱ kuu̱‑ro̱ sóko. Naka̱ ndá'ú kúu róó ja̱ vína kájaku̱‑ro̱, chi̱ ndukuí'a̱ ini̱‑ro̱ te nde'e̱‑ro̱.
\v 26 Naka̱ ndá'ú kúu róó nú vina ká'a̱n jíñú'ún táká cha̱a jíín‑ró. Chi̱ súan ni̱ ka̱sá'a táa̱‑de jíín cháa ni̱ ka̱jani tu̱'un xndá'ú onde̱ sáá.
\v 27 Ko ká'a̱n‑ri̱ jíín róó ja̱ kájini so̱'o: Kundá'ú ini̱‑ro̱ cháa kájito u'u̱ róó, te sá'a va̱'a‑ró jíín cháa kákiti̱ ini̱ nuu̱‑ro̱.
\v 28 Te ka'a̱n va̱'a‑ró jíín cháa káka'a̱n ndɨva̱'a jíín‑ró. Te kaka̱n ta'u̱‑ro̱ já'a̱ cháa kásá'a tu̱'un tú'ún sɨkɨ́‑ro̱.
\v 29 Te nú ndé cha̱a stují ɨ́ɨn yikɨ núu̱‑ro̱, suni kua̱'a‑ró tú'un ná stují‑dé ɨnga̱. Te nú ndé cha̱a jánchaa̱‑de tɨka̱chí‑ró, ni su'nu̱‑ro̱ ma̱ sásá'án‑ró ná kí'i̱n‑de jíín.
\v 30 Na̱ni cha̱a jikán nuu̱‑ro̱, te kua̱'a‑ró núu̱‑dé. Te cha̱a kí'in ndatíñu‑ró, ma̱ nándaka̱n‑ro̱.
\v 31 Te nátu̱'un kuní‑ro̱ sá'a ña̱yɨvɨ jíín‑ró, suni súan sá'a máá‑ró jíín‑i.
\v 32 Chi̱ nú mani̱‑ro̱ jíín cháa mani̱ jíín máá‑ró, ndé cha̱a nakuatá'ú núu̱‑ro̱ núsáá. Chi cha̱a ká'i̱o kua̱chi, suni mani̱‑dé jíín cháa mani̱ jíín máá‑de.
\v 33 Te nú sá'a va̱'a‑ró jíín cháa kásá'a va̱'a jíín máá‑ró, ndé cha̱a nakuatá'ú núu̱‑ro̱, chi cha̱a ká'i̱o kua̱chi, suni súan kásá'a‑de.
\v 34 Chi̱ nú kua̱'a núu‑ró núu̱ cháa ja̱ ñúkuu ini̱‑ro̱ kuá'a‑de nuu̱‑ro̱, ndé cha̱a nakuatá'ú núu̱‑ro̱, chi cha̱a ká'i̱o kua̱chi, suni já'a núu‑de nuu̱ sáva‑ga̱ cha̱a ká'i̱o kua̱chi, náva̱'a nani'i̱n‑gá‑de.
\v 35 Núsáá te kundá'ú ini̱‑ro̱ cháa kájito u'u̱ róó, te sá'a va̱'a‑ró jíín‑de. Te kua̱'a núu‑ró núu̱‑dé. Te ma̱ kúñukuu ini̱‑ro̱ na̱ún kuá'a‑de nuu̱‑ro̱. Te ká'nu koo ta'u̱‑ro̱, te kuu‑ró sé'e Dios andɨ́vɨ́. Chi̱ máá‑yá, va̱'a ini̱‑ya̱ jíín cháa já'a̱ ini̱ jíín cháa ndɨva̱'a.
\v 36 Núsáá te kundá'ú ini̱‑ro̱ ñáyɨvɨ nátu̱'un máá Táa̱‑ro̱ já súni kundá'ú ini̱‑ya̱‑í.
\v 37 Ma̱ ndónda‑ró sɨkɨ́ ñáyɨvɨ, náva̱'a ma̱ ndónda‑i sɨkɨ̱ máá‑ró. Ma̱ náku̱xndíi‑ró sɨkɨ́‑í, náva̱'a ma̱ náku̱xndíi‑i sɨkɨ̱ máá‑ró. Sá'a tu̱ká'nu ini̱‑ro̱ núu̱‑í, náva̱'a ná sá'a‑i tu̱ká'nu ini̱‑i nuu̱ máá‑ró.
\v 38 Kua̱'a nuu̱‑í te suni súan kua̱'a‑i nuu̱‑ro̱. Chikua̱'á va̱'a‑i, sáni̱'in‑i, kaja‑í, te onde̱ jichá chu'un‑i kua̱'a‑i nuu̱‑ro̱. Chi̱ suni jíín kú'a ni̱ chikua̱'á‑ro̱‑ún, suni naku̱kua̱'á‑ro̱. Achí‑ya̱.
\v 39 Te ni̱ ka'a̱n‑ya̱ ɨ́ɨn tu̱'un yátá jíín‑i: Cha̱a kuáá á kuu stá'a̱n‑de ichi núu̱ ɨngá cha̱a kuáá. Á tú jungava ndendúú‑de ini̱ xa'va̱.
\v 40 Ɨɨn cha̱a skuá'a, nasu̱ ñá'nu‑ga̱ kúu‑de vásá maestro‑de. Ko ta̱ká cha̱a káskuá'a, nú a ni̱ kutu̱'a va̱'a‑de, te koo‑de nátu̱'un maestro‑de.
\v 41 Naja̱ ndé'é‑ró já kándee mi̱'ín ndúchi ñaní‑ro̱, te tú nákani ini̱‑ro̱ já ɨ́ɨn vitu̱ kándee nduchi máá‑ró náún.
\v 42 Naja̱ ká'a̱n‑ro̱ jíín ñaní‑ro̱: Ñáni̱, kundatu ná táva‑rí mi̱'ín kándee nduchi‑ro, te tú nákani ini̱‑ro̱ já kándee ɨɨn vitu̱ ndúchi‑ro náún. Cha̱a uu̱ xini̱, xna'a̱n‑ga̱ tava‑ro vitú kándee nduchi máá‑ró. Yúan‑na te kuu nde̱'é vá'a‑ró já táva‑ro mí'ín kándee nduchi ñaní‑ro̱.
\v 43 Chi̱ xini̱ yúnu vá'a tú kúun nde'e̱ káñáá. Te ni xini̱ yúnu káñáá tú kúun nde'e̱ vá'a.
\v 44 Chi̱ ndɨta'a̱n yunu, jíín ndé'e̱ te jiní‑yo̱ na̱ún yunu kúu, chi̱ tú táxín‑yó mérkexe̱ xini̱ nú íñú, ni tú táxín‑yó uva xini̱ zarza.
\v 45 Cha̱a va̱'a, sá'a‑de tiñu va̱'a, chi̱ íó va̱'a ini̱‑de. Te cha̱a ñáá, sá'a‑de tiñu ñáá, chi̱ káñáá ini̱‑de. Chi tu̱'un ñú'un ini̱ añú cha̱a, tu̱'un‑ún ká'a̱n‑de.
\v 46 Naja̱ káka'a̱n‑ro̱ jíín‑rí: Táta̱, Táta̱, te tú káskíkuu‑ró tíñu ká'a̱n‑ri̱ jíín‑ró núsáá.
\v 47 Ta̱ká ña̱yɨvɨ vái nuu̱‑rí, te jíni so̱'o tu̱'un ká'a̱n‑ri̱, te skíkuu, ná stá'a̱n‑ri̱ nuu̱‑ro̱ na̱ jíín kétá'an.
\v 48 Kúu nátu̱'un ɨɨn cha̱a ja̱ jáni‑de ve'e‑de, te ni̱ jacha kúnú‑de. Te ni̱ jani‑de ja'a̱ sɨkɨ́ káva. Te nuu̱ ní chaa̱ ɨɨn nducha ñú'ún xáa̱n, te yu̱cha‑ún ni̱ kuni̱ stúncháa̱ ve'e‑ún núú. Ko tú ní kandá kutɨ, chi̱ sɨkɨ̱ káva kandii̱.
\v 49 Ko ña̱yɨvɨ jíni so̱'o, te tú skíkuu, yu̱án kúu nátu̱'un ɨɨn cha̱a ni̱ jani‑de ve'e‑de nuu̱ ñú'un, te tú yíndu̱ji ja'a̱. Te ɨɨn nducha ñú'ún ní kani ve'e‑ún, te ni̱ stúncháa̱‑ni. Te ni̱ naa íi̱‑ní ve'e‑ún. Achí‑ya̱.
\c 7
\s1 Ja̱ ní nasáva̱'a‑ya̱ mozo capitán
\p 
\v 1 Te ni̱ ji̱nu ni̱ ka'a̱n‑ya̱ ní ka̱jini ná'ín ñáyɨvɨ‑ún. Yúan‑na te ni̱ kɨ̱vɨ‑ya̱ kuá'a̱n‑ya̱ ñúu̱ Capernaum.
\v 2 Te ɨɨn cha̱a kúu capitán, íó ɨɨn mozo‑de ja̱ maní‑dé jíín. Te mozo‑ún, kú'u̱‑i te a yani kuu̱‑i.
\v 3 Te cha̱a capitán yúan, ni̱ jini‑de tu̱'un Jesús. Te ni̱ tájí‑de yaku̱ cha̱a judío ñá'nu, kua'a̱n nuu̱‑yá, ka'a̱n nda̱'ú jíín‑yá ja̱ ná kíi‑ya̱ te nama‑ya̱ mozo‑de.
\v 4 Te ni̱ ja̱koyo cha̱a‑ún nuu̱ Jesús. Te ni̱ kaka'a̱n nda̱'ú‑de jíín‑yá: Kánúú sá'a‑ní ja̱ ká'a̱n‑de,
\v 5 chi̱ mani̱‑dé jíín ñúu̱‑ná. Te ni̱ jani‑de ɨɨn ve'e sinagoga kuu‑ná jíná'an‑ná. Achí‑de.
\v 6 Te kua'a̱n Jesús jíín‑de. Te nuu̱ ní ka̱kuyani‑ya̱ vé'e‑ún, te ni̱ tájí capitán yaku̱ amigo‑de, kua'a̱n nuu̱‑yá. Te ni̱ ka'a̱n‑de jíín‑yá: Táta̱, tú kuní‑ná sátéñu‑ná níí ja̱ kɨ́vɨ‑ní ini̱ ve̱'e‑ná.
\v 7 Ja̱ yúán tú ní kuní‑ná kii‑ná nuu̱‑ní núú, ko máni ka'a̱n‑ní, te ná ndúva̱'a mozo‑ná.
\v 8 Chi̱ máá‑ná, suni cha̱a ndíso tíñu kúu‑ná. Te tá'ú‑ná tiñu nuu̱ soldado‑ná. Te ká'a̱n‑ná jíín ɨ́ɨn‑de: Kuá'án, te já'a̱n‑de. Te jíín ɨngá‑de: Ña'a̱n, te cháa̱‑de. Te jíín mozo‑ná: Sá'a ya̱'á, te sá'a‑i. Achí‑de.
\v 9 Tu̱'un yá'a ni̱ jini so̱'o Jesús. Te ni̱ naa iní‑ya̱ ní nde̱'é‑yá nuu̱‑dé. Te ni̱ xíó káva‑ya̱. Te ni̱ ka'a̱n‑ya̱ jíín ñáyɨvɨ kuá'a̱ kándiki̱n yata̱‑yá: Ndaa̱ ká'a̱n‑ri̱ jíín‑ró, ja̱ ní ini̱ ñuu̱ Israel tú súan ní jiní‑ri̱ cha̱a kándíja, áchí‑ya̱.
\v 10 Te cha̱a ni̱ tájí‑de nuu̱‑yá núú, ni̱ naja̱koyo‑de ve'e. Te ni̱ jini̱‑de ja̱ á ni̱ nduva̱'a mozo‑ún.
\s1 Ja̱ ní nachaku̱ se̱'e yíí ña'an viuda
\p 
\v 11 Yúan‑na te ni̱ kuu kɨvɨ̱. Te ni̱ kɨ̱vɨ Jesús kua'a̱n‑ya̱ ñúu̱ Naín. Te kua'a̱ cháa skuá'a jíín‑yá, jíín ñáyɨvɨ kuá'a̱, kája'a̱n‑i jíín‑yá.
\v 12 Te ni̱ kuyani‑ya̱ yúñúu̱‑ún. Te kákiñi'in ña̱yɨvɨ‑ún ɨɨn su̱chí yíí ní ji'i̱‑i, ja̱ máá ɨ́ɨn‑i nuu̱ náa̱‑i núú. Te ña'an viuda kúu‑ña. Te suni kua'a̱ ñáyɨvɨ ñúu̱‑ún ká'i̱in jíín‑ña.
\v 13 Te ni̱ jini̱ máá Jito'o̱‑yo̱ núu̱‑ñá. Te ni̱ kundá'ú ini̱‑ya̱‑ñá. Te ni̱ kachi̱‑ya̱ jíín‑ña: Ma̱ ndé'e̱‑ro̱, áchí‑ya̱.
\v 14 Te ni̱ kandita‑ya̱. Te ni̱ tɨɨn‑ya̱ camilla ndɨ̱yi‑ún. Te ni̱ ka̱jukuiñi̱ cha̱a kándi̱so‑ún. Te ni̱ ka'a̱n‑ya̱: Súchi̱, jíín‑ró ká'a̱n‑ri̱, nduko̱o, áchí‑ya̱.
\v 15 Yúan‑na te ni̱ nduko̱o su̱chí já á ni̱ ji'i̱‑ún. Te ni̱ kejá'á‑i náka'a̱n‑i. Te Jesús, ni̱ nakua̱'a‑ya̱‑í nuu̱ náa̱‑i.
\v 16 Te ndivii ñáyɨvɨ, ni̱ kayu̱'ú‑i. Te kánakana jaa‑i Dios. Te sava‑i káka'a̱n‑i: Ni̱ chaa̱ ɨɨn cha̱a jáni tu̱'un Dios nuu̱‑yo̱, te kúñá'nu‑de. Te sava‑ga̱‑i káka'a̱n‑i: Máá Dios, ni̱ chaa̱‑ya̱ núu̱‑yo̱. Achí‑i.
\v 17 Te tu̱'un‑ya̱‑ún ni̱ jicha̱ kua'a̱n nɨ́ɨ́ ñúu̱ Judea jíín nɨ́ɨ́ ñúu̱ yani yúan.
\s1 Uu̱ cha̱a ni̱ tájí Juan nuu̱‑yá
\p 
\v 18 Te cha̱a káskuá'a jíín Juan, ni̱ kaka̱stu̱'ún núu̱‑dé ndasa íó ta̱ká tiñu. Yúan‑na te ni̱ kana Juan xini̱ úu̱ cha̱a káskuá'a jíín‑de.
\v 19 Te ni̱ tájí‑de kua'a̱n nuu̱ Jesús, náva̱'a kaka̱ tu̱'ún‑de‑ya̱: Máá‑ní kúu cha̱a kii‑ún, xí kúndatu‑yó ɨngá‑de náún, achi̱‑de.
\v 20 Te ni̱ ja̱koyo cha̱a‑ún nuu̱‑yá. Te ni̱ kaka'a̱n‑de jíín‑yá: Juan, cha̱a skuánducha, ni̱ tájí‑de náá va̱i koyo‑ná nuu̱‑ní va̱i kaka̱ tu̱'ún‑ná níí: Á máá‑ní kúu cha̱a kii‑ún xí kúndatu‑yó ɨngá‑de náún, áchí‑de.
\v 21 Te suni máá hora‑ún ni̱ nasáva̱'a‑ya̱ kuá'a̱ ñáyɨvɨ káku'u̱, jíín já káte'yu̱, jíín já káta'a̱n tachi̱ kíni. Te suni kua'a̱ cháa kuáá, ni̱ ndundiji̱n nuu̱‑dé ni̱ sá'a‑ya̱.
\v 22 Te ni̱ ka'a̱n Jesús: Kuá'án, te kastu̱'ún‑ró núu̱ Juan na̱ún ní kajini̱‑ro̱, jíín tú'un ni̱ ka̱jini so̱'o‑ró. Cha̱a kuáá, kándundiji̱n nuu̱‑dé. Te cha̱a rengo kánakaka‑de. Te cha̱a té'yu̱ ndɨ̱'yi kándundoo‑de. Te cha̱a só'ó kánakuni so̱'o‑de. Te cha̱a ni̱ ji'i̱ kánachaku̱‑de sá'a‑ri̱. Te suni jáni‑ri̱ tu̱'un va̱'a Dios nuu̱ ñáyɨvɨ ndá'ú.
\v 23 Te xáán ndatu̱ koo cha̱a ja̱ má náyu̱'ú‑de koto‑de ruu̱. Achi̱‑ro̱.
\v 24 Te cha̱a ni̱ tájí Juan ni̱ kenda‑de káno'o̱n‑de. Te Jesús, ni̱ kejá'á‑yá ká'a̱n‑ya̱ tú'un Juan jíín ñáyɨvɨ: Naja̱ ní kenda‑ró kája'a̱n‑ro̱ ondé ñu'un té'é. Ja̱ ndé'é‑ró ɨ́ɨn icha̱ ja̱ kandá sá'a tachi̱ náún.
\v 25 Ko naja̱ ní kenda‑ró kája'a̱n‑ro̱. Ja̱ ndé'é‑ró núu̱ ɨ́ɨn cha̱a ñú'un sa'ma ndúchá náún. Ko ná kástu̱'ún‑rí, cha̱a káñu̱'un sa'ma lúu te ncháá va̱'a‑de ja̱ kákusɨɨ̱ iní‑de, máni ini̱ ve̱'e rey káxiu̱kú‑de.
\v 26 Ko naja̱ ní kenda‑ró kája'a̱n‑ro̱. Ja̱ ndé'é‑ró núu̱ ɨ́ɨn cha̱a jáni tu̱'un Dios náún. Te suni ká'a̱n‑ri̱ jíín‑ró: Kúñá'nu xaa̱n‑gá‑de vásá ɨ́ɨn cha̱a jáni tu̱'un Dios.
\v 27 Cha̱a yá'a kúu cha̱a yóso tú'un‑de nuu̱ tutú: Kuni so̱'o‑ró chi̱ tájí‑rí ndajá'a̱‑rí kuxnúú‑de jaa̱‑de, te cha̱a‑ún sátu̱'a‑de ichi‑ro vásá jáa̱‑ro̱, áchí.
\v 28 Chi̱ a ká'a̱n‑ri̱ jíín‑ró ja iní ñu̱yɨ́vɨ yá'a tú íó ni ɨɨn cha̱a jáni tu̱'un Dios ja̱ kúñá'nu‑ga̱ máá‑de vásá Juan cha̱a skuánducha. Ko máá cháa lúlí‑ga̱ ini̱ ñuu̱ ñátu̱'un andɨ́vɨ́, cha̱a‑ún kúñá'nu‑ga̱‑de vásá Juan. Achí‑ya̱.
\v 29 Te cha̱a xíní jíín táká ña̱yɨvɨ‑ún, kájini so̱'o tu̱'un ká'a̱n‑ya̱, te ni̱ ka̱jatá'ú‑i tu̱'un Dios. Te ni̱ ka̱janducha‑í nuu̱ Juan.
\v 30 Ko cha̱a fariseo jíín cháa maestro ley, ni̱ ka̱ské'ichi̱‑de tu̱'un kuní Dios ja̱ sá'a‑de, kua̱chi ja̱ tú ní kájanducha‑dé nuu̱ Juan.
\v 31 Te ni̱ kachi̱ máá Jíto'o̱‑yo̱: Na̱ún tu̱'un yátá skétá'an‑ri̱ jíín ñáyɨvɨ yá'a núsáá, te na̱ún ní ka̱ndaku‑i.
\v 32 Kákuu‑i nátu̱'un su̱chí lúlí káxiu̱kú núyá'u, ja̱ kákana kó'ó‑i xini̱ tá'an‑i: Ni̱ ka̱xndé'e̱‑ri̱ xkuili nuu̱‑ro̱, te tú ní kájita já'á‑ró: Ni̱ kanda'i̱‑ri̱ nuu̱‑ro̱, te tú ní kánde'e̱‑ro̱, áchí‑i.
\v 33 Chi ni̱ kii Juan cha̱a skuánducha. Tú ní yée‑dé staa̱, tú ní jí'i‑de vino, te káka'a̱n‑ro̱: Tá'a̱n‑de tachi̱ kíni.
\v 34 Ko máá Sé'e cha̱a yée‑yá, jí'i‑ya̱. Te káka'a̱n‑ro̱: Yá'a íó ɨɨn cha̱a yáji téyíí, te jí'i xaa̱n‑dé vino, cha̱a jiní tá'an jíín cháa xíní jíín cháa ká'i̱o kua̱chi kúu‑de. Achí‑ro̱.
\v 35 Ko ɨɨn cha̱a ndíchí, máni tiñu ndíchí sá'a‑de. Te súan kuni̱‑ro̱ jándáa̱ ndíchí‑de. Achí‑ya̱.
\s1 Jesús jíín ñá'an ndíso perfume
\p 
\v 36 Te ɨɨn cha̱a fariseo, ni̱ ka'a̱n nda̱'ú‑de jíín Jesús kee‑yá staa̱ jíín‑de. Te ni̱ kɨ̱vɨ‑ya̱ iní ve̱'e‑de, te ni̱ jungo̱o‑ya̱ já kée‑yá.
\v 37 Te ɨɨn ña'an íó kua̱chi, kánchaa̱‑ña ñúu̱ yúan. Te ni̱ jini̱‑ña já kánchaa̱ Jesús ve'e ɨɨn cha̱a fariseo. Te ni̱ chaa̱‑ña jíín ɨ́ɨn tiya'a̱ perfume.
\v 38 Te kánchaa̱‑ña núu̱ já'a̱‑yá ichi yatá‑yá. Te ndé'e̱‑ña, te ni̱ xndáji‑ña já'a̱‑yá jíín ndúcha núu̱‑ñá. Te ni̱ na̱sí'ichí‑ña já'a̱‑yá jíín íxi xiní‑ñá. Te ni̱ tiyú'ú‑ña já'a̱‑yá, te ni̱ ji'i‑ñá perfume ja'a̱‑yá.
\v 39 Te fariseo, cha̱a ni̱ kana xini̱‑yá‑ún, súan ni̱ jini̱‑de, te ni̱ jani ini̱ máá‑de: Nú cha̱a jáni tu̱'un Dios kúu cha̱a yá'a, te kuni̱‑de ndé ña'an kúu ña'an yá'a núú. Chi̱ ña'an yá'a, ja̱ ké'é‑ña‑dé, ña'an íó kua̱chi kúu‑ña, áchí‑de.
\v 40 Yúan‑na te ni̱ ka'a̱n Jesús: Simón, ka'a̱n‑ri̱ ɨɨn tu̱'un jíín‑ró kuní‑ri̱, áchí‑ya̱ jíín‑de. Te máá‑de, ni̱ ka'a̱n‑de: Ka'a̱n‑ní, Maestro, áchí‑de.
\v 41 Te ni̱ ka'a̱n Jesús: Ɨɨn cha̱a já'a núu xu̱'ún, ni̱ i̱o uu̱ cha̱a taú nuu̱‑dé. Ɨɨn cha̱a, ni̱ tau̱ u'u̱n ciento peso. Te ɨnga̱ cha̱a ni̱ tau̱ uu̱ xiko uxi̱ peso nuu̱‑dé.
\v 42 Te tú na̱ jíín káñava̱'a cha̱a‑ún ja̱ náku̱náa. Te ni̱ sá'a‑de tu̱ká'nu ini̱ nuu̱ ndéndúú cha̱a‑ún. Ka'a̱n, ndé ɨɨn cha̱a‑ún kúmani̱‑gá jíín‑de núsáá. Achí‑ya̱.
\v 43 Te ni̱ ka'a̱n Simón: Jáni ini̱‑ná ja̱ cháa ni̱ sá'a‑ga̱‑de tu̱ká'nu ini̱ nuu̱‑ún, áchí‑de. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ja̱ndáa̱ ká'a̱n‑ro̱, áchí‑ya̱.
\v 44 Te ni̱ xíó kóto‑ya̱ íchi núu̱ ñá'an‑ún. Te ni̱ ka'a̱n‑ya̱ jíín Simón: Jiní‑ro̱ ñá'an yá'a náún. Ni̱ kɨ̱vɨ‑ri̱ ini̱ ve̱'e‑ró, te tú ní já'a‑ró ndúcha já ndúndoo ja'a̱‑rí. Ko ña'an yá'a, ni̱ xndáji‑ña já'a̱‑rí jíín ndúcha núu̱‑ñá. Te ni̱ na̱sí'ichí‑ña jíín íxi xiní‑ñá.
\v 45 Tú ní tíyú'ú‑ró rúu̱. Ko ña'an yá'a, onde̱ ni̱ kɨ̱vɨ‑ri̱ ini̱ ve̱'e‑ró, tú júkuiñi̱‑ña já tíyú'ú‑ña já'a̱‑rí.
\v 46 Tú ní jí'i‑ro aceite xini̱‑rí. Ko ña'an yá'a ni̱ ji'i‑ñá perfume ja'a̱‑rí.
\v 47 Núsáá te ká'a̱n‑ri̱ jíín‑ró, ja̱ á ni̱ sá'a‑ri̱ tu̱ká'nu ini̱ nuu̱ táká kua̱chi‑ña va̱sa íó kua'a̱, chi ni̱ kumani̱ xáa̱n‑ñá jíín‑rí. Ko nú sá'a‑ri̱ tu̱ká'nu ini̱ nuu̱ ɨ́ɨn cha̱a íó yaku̱‑ni kua̱chi‑de, te yaku̱‑ni kumani̱‑dé jíín‑rí, áchí‑ya̱.
\v 48 Te ni̱ ka'a̱n‑ya̱ jíín‑ña: A ni̱ sá'a‑ri̱ tu̱ká'nu ini̱ nuu̱ táká kua̱chi‑ró, áchí‑ya̱.
\v 49 Te cha̱a káyee stáa̱ jíín‑yá, ni̱ ka̱kejá'á‑de kájani ini̱ máá‑de: Ndé cha̱a kúu cha̱a yá'a, ja̱ sá'a‑de tu̱ká'nu ini̱ nuu̱ kuáchi, áchí‑de.
\v 50 Te ni̱ ka'a̱n‑ya̱ jíín ñá'an‑ún: Ni̱ kandíja‑ró, te yu̱án ní nama‑ri̱ róó. Kuá'án, te ma̱ yú'ú‑ga̱‑ro̱, áchí‑ya̱.
\c 8
\s1 Tu̱'un ña'an ní ka̱jatíñu nuu̱‑yá
\p 
\v 1 Yúan‑na te kúkuéé‑ga̱, te ni̱ jika kuu‑ya̱ táká ñuu̱ jíín rancho. Te jáni‑ya̱ tú'un va̱'a te kástu̱'ún‑yá ndasa koo máá ñúu̱ nuu̱ tá'ú Dios tiñu. Te máá uxí uu̱ apóstol, kája'a̱n‑de jíín‑yá.
\v 2 Te suni íó yaku̱ ña'an já á ni̱ kata'a̱n‑ña tachí kíni jíín kué'e̱, ja̱ á ni̱ nasáva̱'a‑ya̱‑ñá. Te ña'an‑ún, suni kája'a̱n‑ña jíín‑yá. Te ɨɨn‑ña kúu María ñuu̱ Magdala. Te ini̱ ña'an yúan ni̱ kiñi'in‑ya̱ usiá tachi̱ kíni kája'a̱n onde̱ sáá.
\v 3 Te sava‑ga̱‑ña káinání‑ña Juana, ñasɨ́'ɨ́ cha̱a nání Chuza, cha̱a ndíso tiñu Herodes, jíín Susana, jíín kuá'a̱‑gá ña'an. Te kájatíñu‑ña núu̱‑yá jíná'an‑ya̱.
\s1 Tu̱'un yátá sɨkɨ́ cháa sáka trigo
\p 
\v 4 Te ni̱ ka̱kutútú kuá'a̱ xáa̱n ñáyɨvɨ. Te ña̱yɨvɨ káxiu̱kú táká ñuu̱‑ún, ni̱ ja̱koyo‑i nuu̱‑yá. Te ni̱ ka'a̱n‑ya̱ ɨ́ɨn tu̱'un yátá jíín‑i:
\v 5 Ɨɨn cha̱a sáka trigo, ni̱ kenda‑de sáka‑dé trigo‑de. Te jachá‑de, te ɨɨn nuni̱ ní jungava yu'íchi te ni̱ jañu̱‑i sɨkɨ̱. Te tɨsaa̱ andɨ́vɨ́ ní ka̱kókó‑tɨ́.
\v 6 Te ɨnga̱ ni̱ jungava sɨkɨ̱ yúu̱. Te ni̱ kana. Ko ni̱ ichi̱, chi̱ tú kajin.
\v 7 Te ɨnga̱ ni̱ jungava ma̱'ñú íñu. Te ɨɨn núú‑ni ni̱ ka̱kana iñu jíín. Te ni̱ kajasu̱ nuu̱.
\v 8 Te sava ni̱ ka̱jungava nuu̱ ñú'un vá'a. Te nuu̱ ní ka̱kana, te ja̱ ɨ́ɨn, te ni̱ ja̱'a ciento nuni̱. Achí‑ya̱. Yúan‑na te ká'a̱n jaa‑ya̱: Cha̱a íó so̱'o, kuni ná'ín‑de, te ná kúni so̱'o‑de, áchí‑ya̱.
\v 9 Te cha̱a káskuá'a jíín‑yá, ni̱ kajika̱ tu̱'ún‑de‑ya̱ na̱ún kuní ka'a̱n tu̱'un yátá‑ún.
\v 10 Te ni̱ ka'a̱n‑ya̱: Róó, chi̱ a kuaju̱ku̱'un ini̱‑ro̱ tú'un yísa̱'í yá'a sá'a Dios, ndasa koo ñuu̱ nuu̱ tá'ú Dios tiñu. Ko ká'a̱n‑ri̱ tu̱'un yátá jíín sáva‑ga̱‑i náva̱'a va̱sa ndé'é‑i, ko ma̱ kuní‑i, te va̱sa jíni so̱'o‑i, ko ma̱ júku̱'un ini̱‑i.
\v 11 Tu̱'un yátá yá'a kuní ka'a̱n: Tata̱‑ún kúu tu̱'un Dios.
\v 12 Tata̱ ni̱ ka̱jungava yu'íchi‑ún kákuu cha̱a kájini so̱'o tu̱'un. Te cháa̱‑ni kui'na̱ te jánchaa̱ tu̱'un‑ún ini̱ añú‑de náva̱'a tú kandíja‑de te ka̱ku‑de.
\v 13 Te ja̱ ní ka̱jungava sɨkɨ̱ yúu̱‑ún kákuu cha̱a kájini so̱'o‑de tu̱'un. Te kúsɨɨ̱ iní‑de jíín. Ko túu nuu̱ káka yo'o iní‑de. Te yaku̱‑ni kɨvɨ̱ kákandíja‑de. Te nú ndónda tu̱ndó'o sɨkɨ̱‑dé te kánayu̱'ú‑de.
\v 14 Te ja̱ ní ka̱jungava ma̱'ñú íñu kákuu cha̱a kájini so̱'o‑de. Ko nú kua'a̱n‑de, te kákutéñu‑de jíín ndátíñu‑de, chi̱ kákuni̱‑de kukúká‑de náva̱'a koo sɨɨ̱ iní‑de. Yu̱án náa tú'un ini̱‑de. Te tú yíja va̱'a nuni̱‑dé.
\v 15 Ko ja̱ ní ka̱jungava nuu̱ ñú'un vá'a kákuu cha̱a kándee añú va̱'a añú ndaa̱ ini̱‑de. Te tu̱'un ni̱ ka̱jini so̱'o‑de‑ún, ñú'un ni̱'in ini̱‑de. Te kája̱'a‑de nuni̱ táká kɨvɨ̱.
\s1 Tu̱'un yitɨ
\p 
\v 16 Tú ni ɨɨn ña̱yɨvɨ chí'i‑i ñu'u̱n xini̱ yítɨ te jasú‑i kɨ̱sɨ sɨkɨ̱, ni tú jáni‑i chi̱i ji̱to. Chi̱ sua kundii̱ nuu̱ ɨ́ɨn candelero, náva̱'a tuu̱n ndua ñú'u̱n nuu̱ ñáyɨvɨ kɨ́vɨ koyo.
\v 17 Chi̱ tú íó ni ɨɨn tiñu yísa̱'í sáni, chi̱ stá'a̱n ndiji̱n‑ya̱ táká‑ni. Ni tú íó ni ɨɨn tu̱'un yísa̱'í sáni, chi va̱i ndiji̱n ta̱ká‑ni sá'a‑ya̱, te kuni̱‑yo̱ núu̱.
\v 18 Núsáá te ná kúni so̱'o va̱'a‑ró, chi cha̱a ñáva̱'a, te kii‑ga̱ nuu̱‑dé, te cha̱a tú ñáva̱'a, va̱sa jáni ini̱‑de ja̱ á ñáva̱'a‑de te kuxio ki'i̱n, áchí‑ya̱.
\s1 Náa̱‑ya̱ jíín ñaní‑ya̱
\p 
\v 19 Yúan‑na te ni̱ jaa̱ náa̱‑ya̱ jíín ñaní‑ya̱ núu̱‑yá. Te tú ní kúu kɨ̱vɨ koyo‑ña núu̱‑yá sɨkɨ̱ já kuá'a̱ ñáyɨvɨ.
\v 20 Te ni̱ kaka̱stu̱'ún ñáyɨvɨ‑ún nuu̱‑yá: Náa̱‑ní jíín ñaní‑ní ká'i̱in‑ña yatá vé'e, te ka'a̱n‑ña jíín‑ní kákuni̱‑ña, áchí‑i.
\v 21 Yúan‑na te ni̱ ka'a̱n‑ya̱: Náa̱‑ri̱ jíín ñaní‑ri̱ kákuu ña̱yɨvɨ kájini so̱'o tu̱'un Dios, te káskíkuu‑i, áchí‑ya̱ jíín‑i.
\s1 Ja̱ ní jukuiñi̱ tachi̱ xáa̱n ní sá'a‑ya̱
\p 
\v 22 Te ɨɨn kɨvɨ̱, ni̱ kɨ̱vɨ‑ya̱ iní ɨɨn barco jíín cháa káskuá'a jíín‑yá. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ná kíja̱'a‑yó ɨngá lado mar. Te ni̱ ka̱skáka‑ya̱ barco kája'a̱n‑ya̱.
\v 23 Ko nini káskáka‑de barco, te ni̱ kixi̱‑ya̱. Te ni̱ ndonda ɨɨn tachi̱ xáa̱n núu̱ mar. Te ndúkú chítú ndúcha iní barco, te a yani koo tu̱ndó'o núú.
\v 24 Te ni̱ ja̱koyo‑de nuu̱‑yá. Te ni̱ ka̱xndúko̱o‑de‑ya̱. Maestro, Maestro, vina te naa‑yo, áchí‑de. Te ni̱ nata'u̱ núu̱‑yá. Te ni̱ ka'a̱n xaa̱n‑yá nuu̱ tachí‑ún jíín núu̱ mar. Te ni̱ kuná'ín‑ni. Te ná'ín yúú íi̱‑ní ni̱ kuu.
\v 25 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Naja̱ tú kákandíja‑ró. Te káyu̱'ú‑de, te kánaa iní‑de kánde̱'é‑de. Te káka'a̱n jíín tá'an máá‑de: Ndé cha̱a kúu cha̱a yá'a, ja̱ ondé nuu̱ tachí jíín núu̱ ndúcha tá'ú‑de tiñu te kájandatu̱ nuu̱‑dé, áchí‑de.
\s1 Cha̱a tá'a̱n tachi̱ kíni onde̱ ndañúu̱ Gadara
\p 
\v 26 Te ni̱ ja̱koyo‑de ñuu̱ Gadara, ja̱ kánchaa̱ ichi núu̱ ñúu̱ Galilea.
\v 27 Te nuu̱ ní jaa̱‑ya̱ núu̱ ñú'un íchí, te ɨɨn cha̱a ñuu̱‑ún ni̱ kita'a̱n‑de‑ya̱. Te tá'a̱n‑de kua'a̱ tachí kíni. Te ni̱ kuu kua'a̱ kuiá ja̱ tú ñú'un kutɨ‑dé sa'ma, ni tú ncháá‑de ɨɨn ve'e, chi ma̱'ñú vé'e añú ncháá‑de.
\v 28 Te cha̱a‑ún, ni̱ jini̱‑de nuu̱ Jesús. Te ni̱ jukuiñi̱ jítɨ́‑de nuu̱‑yá. Te ni̱ kana jaa‑de: Na̱ún sá'a‑ní jíín‑ná Jesús, Se̱'e Dios, I'a̱ kúñá'nu xaa̱n. Ká'a̱n nda̱'ú‑ná jíín‑ní ma̱ xndó'o‑ní náá, áchí‑de.
\v 29 Te ni̱ tá'ú‑yá tiñu nuu̱ tachí kíni‑ún ná kénda ki'i̱n ini̱ cha̱a‑ún, chi ni̱ kuu kua'a̱ kuiá xndó'o cha̱a‑ún. Te ni̱ kaju'ni̱‑i cha̱a‑ún jíín cadena jíín manea ka̱a. Ko ndɨ'ɨ ni̱ kukuáchí sá'a‑de. Te kénda‑de já'a̱n‑ni‑de onde̱ ñu'un té'é sá'a tachi̱ kíni‑ún.
\v 30 Te Jesús, ni̱ jika̱ tu̱'ún‑yá‑de: Na̱ún nání‑ró, áchí‑ya̱. Te ni̱ ka'a̱n‑de jíín‑yá: Ja̱ kuá'a̱ xáa̱n nání‑ná, áchí, chi̱ yí'i kua'a̱ xáa̱n tachí kíni ini̱‑de.
\v 31 Te ni̱ kaka'a̱n nda̱'ú tachi̱‑ún jíín‑yá ja̱ ná tú tájí‑yá ki'i̱n ini̱ tu̱nchi kúnú.
\v 32 Te yuku yúan íó ɨɨn tɨku'ni̱ kɨnɨ̱ kájitu‑tɨ̱. Te yúan ni̱ kaka'a̱n nda̱'ú jíín‑yá ja̱ ná kuá'a‑ya̱ tú'un kɨ̱vɨ koyo ini̱‑tɨ̱. Te ni̱ ja̱'a‑ya̱ tú'un kája'a̱n.
\v 33 Te ni̱ kenda tachi̱ kíni‑ún ini̱ cha̱a‑ún kája'a̱n. Te ni̱ kɨ̱vɨ koyo ini̱ kɨnɨ̱. Te tɨku'ni̱ kɨnɨ̱‑ún ni̱ ka̱jungoyo‑tɨ̱ yúkáva‑ún onde̱ ini̱ mar. Te nuu̱ mar ni̱ kaji'i̱‑tɨ̱.
\v 34 Te cha̱a kándi̱to‑tɨ̱, ni̱ kajini̱‑de ja̱ súan ni̱ kuu. Te ni̱ ka̱jinu‑de kája'a̱n‑de. Te ni̱ kaka̱stu̱'ún‑de nuu̱ ñáyɨvɨ ñúu̱‑ún jíín táká rancho.
\v 35 Te ni̱ kenda koyo ña̱yɨvɨ‑ún ja̱ ndé'é‑i na̱ún ní kuu. Te ni̱ ja̱koyo‑i nuu̱ Jesús. Te ni̱ kajini̱‑i nuu̱ cháa ni̱ kenda tachi̱ kíni‑ún, kánchaa̱‑de nuu̱ já'a̱ Jesús, ñú'un‑de sa'ma, te a ni̱ nduva̱'a xini̱‑dé. Te ni̱ kayu̱'ú‑i.
\v 36 Te cha̱a ni̱ kajini̱, ni̱ ka̱jani‑de tu̱'un nuu̱ ñáyɨvɨ‑ún, ndasa ni̱ nduva̱'a cha̱a ni̱ ta'a̱n tachi̱ kíni.
\v 37 Yúan‑na te ta̱ká ña̱yɨvɨ ñúu̱ Gadara, ni̱ kaka'a̱n nda̱'ú‑i jíín‑yá ja̱ ná kúxio‑ya̱ kí'i̱n‑ya̱, chi̱ xaa̱n káyu̱'ú‑i. Te máá‑yá, ni̱ ndɨ̱vɨ‑ya̱ iní barco. Te ni̱ na̱xíó káva‑ya̱ kuá'a̱n‑ya̱.
\v 38 Te cha̱a ni̱ ka̱kenda tachi̱‑ún, ni̱ ka'a̱n nda̱'ú‑de ja̱ kuéni ki'i̱n‑de jíín‑yá. Ko Jesús, ni̱ tájí‑yá‑de kua'a̱n‑de:
\v 39 Kuáno'on vé'e‑ró, te kani‑ró tú'un ná ñá'nu xaa̱n tíñu ni̱ sá'a Dios jíín‑ró, áchí‑ya̱ jíín‑de. Te máá cháa‑ún ni̱ kee‑de kua'a̱n‑de. Te ni̱ jani‑de tu̱'un nɨ́ɨ́ ñúu̱ yúan ná ñá'nu xaa̱n tíñu ni̱ sá'a Jesús jíín‑de.
\v 40 Yúan‑na te ni̱ najaa̱‑ya̱. Te ña̱yɨvɨ‑ún ni̱ kaka'a̱n va̱'a‑i jíín‑yá, chi̱ ndivii‑í káinda̱tu‑i‑ya̱.
\s1 Tu̱'un se̱sɨ́'ɨ́ Jairo
\p 
\v 41 Te ɨɨn cha̱a kúñá'nu ini̱ ve̱'e sinagoga nání‑de Jairo, ni̱ chaa̱‑de. Te ni̱ jukuiñi̱ jítɨ́‑de nuu̱ já'a̱ Jesús. Te ni̱ ka'a̱n nda̱'ú‑de jíín‑yá ja̱ ná kɨ́vɨ‑ya̱ iní ve̱'e‑de.
\v 42 Chi̱ íó ɨɨn se̱sɨ́'ɨ́‑de ja̱ máá ɨ́ɨn‑i nuu̱‑dé, nátu̱'un uxi̱ uu̱ kuia̱‑i. Te su̱chí‑ún ndúkú‑i kuu̱‑i. Te ni̱ kee Jesús kua'a̱n‑ya̱. Te kua'a̱ ñáyɨvɨ ní kajaxi̱n‑i‑ya̱.
\s1 Ja̱ ní nasáva̱'a‑ya̱ ɨ́ɨn ña'an kú'u̱ kue'e̱ nɨñi̱
\p 
\v 43 Te ɨɨn ñasɨ́'ɨ́ ni̱ kuu uxi̱ uu̱ kuia̱ játɨ nɨñi̱‑ñá. Te ña'an‑ún ni̱ janu̱‑ña táká ndatíñu‑ña ní kuu cha̱a táná. Te tú ní ndúva̱'a‑ña sá'a ni ɨɨn‑de.
\v 44 Te ni̱ jaa̱‑ña íchi yatá‑yá. Te ni̱ ké'é‑ña yú'u sá'ma‑yá. Te ni̱ ichi̱‑ni nuu̱ játɨ nɨñi̱‑ñá‑ún.
\v 45 Yúan‑na te ni̱ ka'a̱n Jesús: Ndéja̱ ní ké'é rúu̱, áchí‑ya̱. Te ndivii‑dé tú ní kája̱'a‑de tu̱'un. Te Pedro jíín cháa ká'i̱in jíín‑de yúan, ni̱ kaka'a̱n‑de: Maestro, ña̱yɨvɨ kuá'a̱ yá'a kájaxi̱n‑i níí, te a ká'a̱n‑ní: Ndéja̱ ní ké'é rúu̱, áchí‑de.
\v 46 Ko ni̱ ka'a̱n Jesús: Ndaa̱ ja̱ ɨ́ɨn ña̱yɨvɨ ní ké'é rúu̱, chi ni̱ jini̱‑ri̱ ja̱ ní kenda fuerza ini̱‑ri̱, áchí‑ya̱.
\v 47 Yúan‑na te ña'an‑ún, ni̱ jini̱‑ña já tú ní kúu chisa̱'í‑ña máá‑ña, te ni̱ chaa̱‑ña kɨ́sɨ‑i‑ña. Te ni̱ jukuiñi̱ jítɨ́‑ña núu̱ Jesús, te jíto nuu̱ táká ña̱yɨvɨ, ni̱ jani ndaa̱‑ña tú'un naja̱ ní ké'é‑ña‑yá, te ndasa ni̱ nduva̱'a‑ni‑ña ní sá'a‑ya̱.
\v 48 Te máá‑yá ni̱ ka'a̱n‑ya̱ jíín‑ña: Ni̱ kandíja‑ró, te yu̱án ní ka̱ku‑ró. Kuá'án, te ma̱ yú'ú‑ro̱. Achí‑ya̱.
\s1 Ja̱ ní nachaku̱ se̱sɨ́'ɨ́ Jairo
\p 
\v 49 Te nini ká'a̱n‑ya̱ súan, te ni̱ chaa̱ ɨɨn mozo cha̱a kúñá'nu ini̱ ve̱'e sinagoga‑ún, ni̱ kachi̱ nuu̱‑dé: A ni̱ ji'i̱ se̱sɨ́'ɨ́‑ro̱. Ma̱ sátéñu‑ga̱‑ro̱ Maestro, áchí.
\v 50 Te ni̱ jini so̱'o Jesús ja̱ ní ka'a̱n mozo‑ún. Te ni̱ kachi̱‑ya̱ jíín cháa‑ún: Ma̱ yú'ú‑ro̱: Kandíja‑ni, te ná káku se̱sɨ́'ɨ́‑ro̱.
\v 51 Te ni̱ kɨ̱vɨ‑ya̱ iní ve̱'e. Te tú ní já'a‑ya̱ tú'un kɨ̱vɨ ni ɨɨn jíín‑yá, chi̱ máá‑ni Pedro jíín Jacobo, jíín Juan, jíín táa̱ náa̱ su̱chí sɨ́'ɨ́‑ún.
\v 52 Te kánde'e̱ ndivii ñáyɨvɨ te kándukuí'a̱ ini̱‑i. Te ni̱ kachi̱‑ya̱: Ma̱ ndé'e̱‑ro̱ jíná'an‑ró. Tú ní jí'i̱‑i, chi̱ kixí‑ni‑i, áchí‑ya̱.
\v 53 Te ni̱ ka̱sákátá‑i nuu̱‑yá, chi ni̱ kajini̱‑i ja̱ á ni̱ ji'i̱ su̱chí‑ún.
\v 54 Ko máá‑yá, ni̱ tɨɨn‑ya̱ ndá'a‑í. Te ni̱ ka'a̱n jaa‑ya̱: Súchi̱, nduko̱o, áchí‑ya̱.
\v 55 Yúan‑na te ni̱ nachaku̱‑i. Te ni̱ nduko̱o‑ni‑i. Te ni̱ tá'ú‑yá tiñu ja̱ ná kuá'a‑de staa̱ kée‑í.
\v 56 Te táa̱‑i náa̱‑i, ni̱ ka̱kee nuu̱‑dé kánde̱'é‑de. Ko ni̱ tá'ú‑yá tiñu nuu̱‑dé ja̱ tú ni ɨɨn nuu̱ kachí‑de ja̱ súan ni̱ kuu.
\c 9
\s1 Ja̱ ní tájí Jesús uxi̱ uu̱‑de kája'a̱n‑de
\p 
\v 1 Te ni̱ na̱stútú‑yá ndɨ́'uxí uu̱ cha̱a‑ún. Te ni̱ ja̱'a‑ya̱ fuerza ini̱‑de ja̱ kúndéé‑de jíín táká tachi̱ kíni jíín já kuánchaa̱‑de ta̱ká kue'e̱.
\v 2 Te ni̱ tájí‑yá‑de kája'a̱n‑de ja̱ ná káni‑de tu̱'un ndasa koo ñuu̱ nuu̱ tá'ú Dios tiñu, te ná násáva̱'a‑de ña̱yɨvɨ káku'u̱.
\v 3 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ma̱ kúndiso kutɨ‑ro já kúu ichi, ni vara, ni ñunu, ni staa̱, ni xu̱'ún, ni ma̱ kúndiso‑ró úu̱ su'nu̱.
\v 4 Te na̱ni ve'e kúu nú ni̱ kɨ̱vɨ‑ró, te kendo̱o‑ró yúan. Te yúan kenda‑ró kí'i̱n‑ro̱.
\v 5 Te nú ndé nuu̱ tú kákuni̱‑i kuatá'ú‑i róó, te nú ni̱ kenda‑ró ñúu̱ yúan, te skóyo‑ró tɨ́kacha̱ iní ja'a̱‑ro̱. Te súan kani ndaa̱‑ro̱ tú'un nuu̱‑í jíná'an‑i, áchí‑ya̱.
\v 6 Te ni̱ kenda‑de kája'a̱n‑de, ni̱ ka̱jíkó ndúu̱‑de ta̱ká ñuu̱, ni̱ ka̱jani‑de tu̱'un. Te ta̱ká lado ni̱ kana̱sáva̱'a‑de ña̱yɨvɨ káku'u̱.
\s1 Ja̱ ní kuñáá ini̱ Herodes
\p 
\v 7 Te Herodes, cha̱a tá'ú tíñu, ni̱ jini tu̱'un‑de ta̱ká tiñu ni̱ sá'a‑ya̱, te kúñáá ini̱‑de, chi̱ káka'a̱n sava‑i: Juan, cha̱a ni̱ ji'i̱, ni̱ nachaku̱‑de.
\v 8 Te sava tuku‑i: Ni̱ ndenda Elías. Te sava‑ga̱ tuku‑i: Ɨɨn cha̱a ni̱ jani tu̱'un Dios onde̱ sáá a ni̱ nachaku̱‑de. Achí‑i.
\v 9 Te ni̱ kachi̱ Herodes: Ni̱ janchaa̱‑ri̱ xini̱ Juan. Te ndé cha̱a kúu cha̱a yá'a núsáá, chi̱ jíni tu̱'un‑ri̱ ja̱ sá'a‑de tiñu yá'a, áchí‑de. Te ni̱ kuni̱‑de nde̱'é‑de nuu̱ Jesús.
\s1 Ja̱ ní skée‑yá u'u̱n mil ña̱yɨvɨ
\p 
\v 10 Te ni̱ nchaa̱ cha̱a káskuá'a‑ún. Te ni̱ ka̱nakani‑de tu̱'un nuu̱‑yá ta̱ká tiñu ni̱ ka̱sá'a‑de. Te ni̱ ki'in‑ya̱‑dé, te kua'a̱n sɨ́ɨn‑ya̱ jíín‑de ɨɨn nuu̱ ñú'un té'é, ñúu̱ nání Betsaida.
\v 11 Te ni̱ kajini̱ ña̱yɨvɨ‑ún. Te ni̱ kandiki̱n‑i‑ya̱, kája'a̱n‑i jíín‑yá. Te ni̱ jatá'ú‑yá‑i, te ni̱ jani‑ya̱ tú'un ndasa koo ñuu̱ nuu̱ tá'ú Dios tiñu. Te ni̱ nasáva̱'a‑ya̱ táká ña̱yɨvɨ káku'u̱.
\v 12 Te a kua̱'ini. Te ni̱ ncha̱koyo ndɨ́'uxí uu̱‑de nuu̱‑yá. Te ni̱ kaka'a̱n‑de jíín‑yá: Tájí‑ní ña̱yɨvɨ kuá'a̱ yá'a ná kíngoyo‑i ta̱ká ñuu̱ jíín táká rancho yani yá'a, te ndúkú‑i ndénu̱ ndo̱o‑i te ni'i̱n‑í staa̱ kée‑í, chi̱ yá'a nuu̱ ñú'un té'é ká'i̱in‑yó, áchí‑de.
\v 13 Te ni̱ kachi̱‑ya̱ jíín‑de: Kua̱'a máá‑ró já ná kée‑í, áchí‑ya̱. Te ni̱ kaka'a̱n‑de: Tú na̱ún káñava̱'a‑ná, chi̱ u'u̱n‑ni sta̱tilá jíín úu̱‑ni ti̱yáká. Te nú túu kikua̱an‑ná staa̱ kée táká ña̱yɨvɨ yá'a, te ma̱ kánda, áchí‑de.
\v 14 Chi̱ íó nátu̱'un u'u̱n mil cha̱a. Yúan‑na te ni̱ ka'a̱n‑ya̱ jíín cháa káskuá'a‑ún: Ka'a̱n jíín ñáyɨvɨ ná júngo̱o ɨɨn nuu ɨ́ɨn nuu‑í nátu̱'un uu̱ xiko uxi̱, uu̱ xiko uxi̱ ja̱ ɨ́ɨn ɨɨn, áchí‑ya̱.
\v 15 Te súan ni̱ ka̱sá'a‑de, ni̱ ka̱súngo̱o ndɨ'ɨ‑de‑i.
\v 16 Te ni̱ ki'in‑ya̱ ndɨ́'ú'u̱n sta̱tilá jíín úu̱ ti̱yáká‑ún. Te ni̱ ndakoto‑ya̱ íchi ándɨ́vɨ́ te ni̱ jika̱n ta'u̱‑yá ja'a̱ státilá. Te ni̱ sákuáchí‑yá sta̱tilá‑ún. Te ni̱ ja̱'a‑ya̱ núu̱ cháa káskuá'a jíín‑yá ni̱ ka̱jani‑de nuu̱‑í.
\v 17 Te ndivii‑í ni̱ ka̱yee‑í. Te ni̱ kanda'a̱ chi̱i‑i. Te ni̱ ka̱nastútú‑de uxi̱ uu̱ ji̱ka staa̱ kua̱chí já ní ndendoso.
\s1 Tu̱'un ni̱ ka'a̱n ndaa̱ Pedro
\p 
\v 18 Te ɨɨn kɨvɨ̱ jikán ta'u̱ máá ɨ́ɨn‑ni Jesús, chi̱ máá‑ni cha̱a káskuá'a‑ún ká'i̱in‑de jíín‑yá. Te ni̱ jika̱ tu̱'ún‑yá‑de: Te ruu̱, na̱ cha̱a kúu‑ri̱, káka'a̱n ña̱yɨvɨ, áchí‑ya̱.
\v 19 Te ni̱ kaka'a̱n‑de: Juan, cha̱a skuánducha, káka'a̱n‑i. Te sava‑i: Elías. Te sava‑ga̱‑i: Ɨɨn cha̱a ni̱ jani tu̱'un Dios onde̱ aná'án, ni̱ nachaku̱‑de, áchí‑de.
\v 20 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Te róó, na̱ cha̱a kúu‑ri̱ káka'a̱n máá‑ró, áchí‑ya̱. Yúan‑na te Simón Pedro, ni̱ ka'a̱n‑de: Máá‑ní kúu Cristo Se̱'e Dios, áchí‑de.
\v 21 Yúan‑na te ni̱ ka'a̱n xaa̱n‑yá jíín‑de, te ni̱ tá'ú‑yá tiñu nuu̱‑dé ja̱ tú ni ɨɨn nuu̱ kachí‑de tu̱'un yá'a.
\s1 Jíín kɨvɨ́ ní ka'a̱n Jesús ja̱ kúu̱‑ya̱
\p 
\v 22 Te ni̱ ka'a̱n‑ya̱: Jínu ñú'ún ndó'o xaa̱n máá Sé'e cha̱a, te cha̱a ni̱ ka̱yii jíín táká sutu̱ ñá'nu jíín cháa káchaa tutu̱, ma̱ kuátú'ún‑de‑ya̱, chi̱ ka'ni‑dé‑ya̱. Te nuu̱ uní kɨvɨ̱ te nachaku̱‑ya̱. Achí‑ya̱.
\v 23 Te ni̱ ka'a̱n‑ya̱ jíín ndɨ́'ɨ‑de: Na̱ni cha̱a nú kuní‑de kii‑de yata̱‑rí, te ma̱ chíñú'ún‑de máá‑de te ná kuándéé iní‑de jíín túndó'o kii sɨkɨ̱‑dé ta̱ká kɨvɨ̱, te ná kúndiki̱n‑de ruu̱ kii‑de.
\v 24 Chi cha̱a jítú iní‑de ka̱ku‑de chi̱i tu̱ndó'o kii sɨkɨ̱‑dé, naa‑dé. Te va̱sa ná kúu̱ ɨɨn cha̱a ja̱ sɨkɨ́ rúu̱, ko ka̱ku‑de.
\v 25 Chi na̱ún ní'i̱n cháa, va̱sa ná kúndéé‑de ni'i̱n‑dé nɨ́ɨ́ ñúyɨ́vɨ, te nú xnáa‑dé máá‑de, xí síjíta‑de añú‑de.
\v 26 Chi̱ nú ndé cha̱a kúka nuu̱ iní‑de nuu̱‑rí jíín núu̱ tú'un ká'a̱n‑ri̱, suni súan kuka nuu̱ iní máá Sé'e cha̱a nuu̱ cháa‑ún kɨvɨ̱ ndíi‑ya̱. Te kɨvɨ̱‑ún ñá'nu koto luu‑ya̱ jíín Táa̱‑ya̱, te suni jíín táká ndajá'a̱ ndóo‑ya̱.
\v 27 Te ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró, ja̱ íó sava cha̱a ká'i̱in yá'a ja̱ má kúu̱ kutɨ‑dé onde̱ nú tú kuni̱‑de ñuu̱ nuu̱ tá'ú Dios tiñu. Achí‑ya̱.
\s1 Sɨkɨ̱ já túku ni̱ nduu‑ya̱
\p 
\v 28 Yúan‑na te nátu̱'un nuu̱ uná kɨvɨ̱ já ní ka'a̱n‑ya̱ tú'un yá'a, te ni̱ jaka‑ya̱ Pedro, jíín Juan, jíín Jacobo, ni̱ kaa‑ya̱ kuá'a̱n‑ya̱ jíín‑de ɨɨn yuku, kuákaka̱n ta'u̱‑yá.
\v 29 Te nini jikán ta'u̱‑yá, te nuu̱‑yá, tuku ni̱ nduu. Te sa'ma‑yá ní nduu kɨyi̱ xaa̱n. Te ni̱ ka̱nandii ncháa̱.
\v 30 Te yúan ni̱ kanda̱tu̱'ún úu̱ cha̱a jíín‑yá. Te cha̱a‑ún kákuu Moisés jíín Elías.
\v 31 Te kándii ncháa̱ cha̱a‑ún. Te ni̱ kaka'a̱n‑de tu̱'un ja̱ á yani skíkuu‑ya̱ tíñu‑ya̱ te kuu̱‑ya̱ ñúu̱ Jerusalén.
\v 32 Te Pedro jíín cháa ká'i̱in jíín‑de‑ún káji'i̱ xaa̱n‑dé numa̱'ná te kákixi̱‑de. Te nuu̱ ní ka̱nata'u̱ núu̱‑dé, te ni̱ kajini̱‑de ja̱ ndíi ncháa̱ Jesús, jíín úu̱ cha̱a ká'i̱in jíín‑yá‑ún.
\v 33 Te nuu̱ ní ka̱kuxio cha̱a‑ún nuu̱ Jesús, te ni̱ ka'a̱n Pedro jíín‑yá: Maestro, va̱'a‑ga̱ ná kéndo̱o‑yó yá'a. Te ná sá'a‑ná uni̱ ve'e kuii, ɨɨn kuu máá‑ní, ɨnga̱ kuu Moisés, te ɨnga̱ kuu Elías, áchí‑de. Te tú jiní‑de na̱ún tu̱'un ni̱ ka'a̱n‑de.
\v 34 Te nini ká'a̱n‑de, Te ni̱ chaa̱ ɨɨn viko̱ nu̱'ún ní jasu̱ nɨ́ɨ́ núu̱‑dé jíná'an‑de. Te ni̱ kayu̱'ú xaa̱n‑dé ja̱ ní kɨ̱vɨ koyo‑de chi̱i viko̱ nu̱'ún‑ún.
\v 35 Te chi̱i viko̱ nu̱'ún yúan, ni̱ kenda ɨɨn tu̱'un ja̱ ní ka'a̱n: Ya̱'á kúu Se̱'e‑ri̱, ja̱ kúndá'ú ini̱‑ri̱‑i, te kuni ná'ín‑ró tú'un ká'a̱n‑ya̱, áchí.
\v 36 Yúan‑na te ni̱ jukuiñi̱ tu̱'un‑ún. Te máá ɨ́ɨn‑na̱ Jesús kándii̱‑ya̱ núu̱‑dé. Te máá‑de tú ní káka'a̱n kutɨ‑dé. Te nɨ́ɨ́‑ni kɨvɨ̱‑ún tú ni ɨɨn nuu̱ ní kákachi̱‑de ja̱ súan ni̱ kajini̱‑de.
\s1 Sɨkɨ̱ súchí tá'a̱n tachi̱ kíni
\p 
\v 37 Te ɨnga̱ kɨvɨ̱ xía̱n‑ún, ni̱ ka̱nuu‑ya̱ yúku‑ún. Te ɨɨn ña̱yɨvɨ kuá'a̱, ni̱ kenda‑i ni̱ ka̱jata'a̱n‑i Jesús.
\v 38 Te nuu̱ ñáyɨvɨ kuá'a̱‑ún ni̱ kenda ɨɨn cha̱a ni̱ kana jaa‑de: Maestro, jikán ta'u̱‑ná nuu̱‑ní ja̱ ndé'é‑ní se̱'e‑ná, chi̱ máá ɨ́ɨn‑i ñáva̱'a‑ná.
\v 39 Chi̱ ɨɨn tachi̱ kíni tɨ́ɨn‑ni‑i. Te sanaa‑ní te kána kó'ó‑i sá'a, te já'ni yí'í‑ni‑i. Te sjáa‑ni ti'iñu̱ yu'u‑í. Te xaa̱n stují‑í. Te xaa̱n ú'u̱ kénda.
\v 40 Te ni̱ ka'a̱n nda̱'ú‑ná jíín cháa káskuá'a jíín‑ní yá'a ja̱ ná kíñi'in‑de ki'i̱n. Te tú ní kákuu sá'a‑de, áchí‑de jíín Jesús.
\v 41 Te ni̱ ka'a̱n Jesús: Ña̱yɨvɨ xáa̱n ní'in ini̱ kákuu‑ró já tú kákandíja‑ró. Na̱saa‑ga̱ kɨvɨ̱ kúnchaa̱‑ri̱ jíín‑ró te ndo'o‑ri̱ jíín‑ró. Kua̱'a se̱'e‑ró ná kíi‑i, áchí‑ya̱.
\v 42 Te nini ni̱ kandita‑i nuu̱‑yá, te tachi̱ kíni ni̱ stúncháa̱‑ni‑i. Te ni̱ ja'ni yí'í xáa̱n‑ní‑i. Ko máá Jesús ni̱ ka'a̱n xaa̱n‑yá nuu̱ tachí kíni‑ún. Te ni̱ nasáva̱'a‑ya̱ súchí‑ún. Te ni̱ nakua̱'a‑ya̱‑í nuu̱ táa̱‑i.
\s1 Jíín kɨvɨ́ ní ka'a̱n‑ya̱ já kúu̱‑ya̱
\p 
\v 43 Te ndivii ñáyɨvɨ ní ka̱naa iní‑i kánde̱'é‑i ndasa ñá'nu káa Dios. Te ni̱ ka̱kee nuu̱‑í kánde̱'é‑i ta̱ká tiñu ni̱ sá'a Jesús. Te ni̱ ka'a̱n Jesús jíín cháa káskuá'a jíín‑yá:
\v 44 Chu'un tu̱'un yá'a ini̱‑ro̱ jíná'an‑ró. Chi̱ máá Sé'e cha̱a natu̱u‑ya̱ iní nda'a cháa ká'i̱o kua̱chi, áchí‑ya̱.
\v 45 Ko máá‑de, tú ní kájuku̱'un ini̱‑de tu̱'un yá'a. Chi ni̱ ka'a̱n sa̱'í‑ya̱ tú'un yá'a náva̱'a ma̱ júku̱'un ini̱‑de. Te ni̱ kayu̱'ú‑de kaka̱ tu̱'ún‑de‑ya̱ sɨkɨ́ tú'un‑ún.
\s1 Ja̱ ní ka̱státá'an‑de ndé cha̱a kúñá'nu‑ga̱
\p 
\v 46 Yúan‑na te ni̱ ka̱státá'an‑de nú ndé cha̱a kúñá'nu‑ga̱.
\v 47 Ko Jesús, ni̱ jini̱‑ya̱ já súan kájani ini̱‑de. Te ni̱ ki'in‑ya̱ ɨ́ɨn su̱chí lúlí. Te ni̱ jani‑ya̱‑í xiin‑yá.
\v 48 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Cha̱a ja̱ jíín sɨ́'vɨ́‑rí játá'ú‑de su̱chí yá'a, te ruu̱ játá'ú‑de. Te cha̱a játá'ú rúu̱, játá'ú‑de i̱'a̱ ni̱ tájí rúu̱ va̱i‑ri̱. Te cha̱a súchí‑ga̱ ma̱'ñú róó jíná'an‑ró, cha̱a‑ún kúñá'nu‑de, áchí‑ya̱.
\v 49 Yúan‑na te ni̱ ka'a̱n Juan: Maestro, ni̱ kajini̱‑ná ɨɨn cha̱a ja̱ jíín sɨ́'vɨ́‑ní kíñi'in‑de tachi̱ kíni kája'a̱n, te ni̱ kajasu̱‑ná nuu̱‑dé, chi̱ tú ndikín‑de yóó, áchí‑de.
\v 50 Ko ni̱ ka'a̱n Jesús jíín‑de: Ma̱ kasú‑ro̱ núu̱‑dé jíná'an‑ró, chi cha̱a tú jíto u'u̱ yóó, jíín yóó ndújíín‑de.
\s1 Ña̱yɨvɨ ñúu̱ Samaria ni̱ ka̱ské'ichi̱‑i‑ya̱
\p 
\v 51 Te ni̱ kuyani jaa̱ kɨvɨ̱ nó'o̱n máá‑yá onde̱ andɨ́vɨ́. Te ni̱ chaa téyíí iní‑ya̱ já kí'i̱n‑ya̱ ñúu̱ Jerusalén.
\v 52 Te ni̱ tájí‑yá cha̱a kua'a̱n jíín tú'un káyo̱xnúú‑de nuu̱‑yá. Te cha̱a‑ún kája'a̱n‑de. Te ni̱ kɨ̱vɨ‑de ɨɨn ñuu̱ Samaria náva̱'a sátu̱'a‑de te vásá jáa̱‑ya̱.
\v 53 Ko ña̱yɨvɨ yúan tú ní kájatá'ú‑i‑ya̱, chi ni̱ kajini̱‑i ja̱ íchi ñúu̱ Jerusalén ki'i̱n‑ya̱ núú.
\v 54 Te Jacobo jíín Juan, cha̱a káskuá'a jíín‑yá, ni̱ kajini̱‑de yu̱án. Te ni̱ kaka'a̱n‑de: Táta̱, á tú kuní‑ní ná tá'ú tíñu‑yó kíi ñu'u̱n ichi ándɨ́vɨ́ te ná xndɨ́'ɨ ña̱yɨvɨ yá'a, nátu̱'un ni̱ sá'a Elías. Achí‑de.
\v 55 Yúan‑na te ni̱ jíó káva Jesús nuu̱‑dé. Te ni̱ ka'a̱n xaa̱n‑yá jíín‑de: Tú kájini̱‑ro̱ ndasa káa ini̱‑ro̱,
\v 56 chi̱ máá Sé'e cha̱a, tú va̱i‑ya̱ já xnáa‑yá añú ña̱yɨvɨ, chi̱ sua nama‑ya̱‑í, áchí‑ya̱. Te kája'a̱n‑ya̱ ɨngá ñuu̱.
\s1 Uu̱ cha̱a ndúkú‑de kundiki̱n‑de‑ya̱
\p 
\v 57 Te kájika‑ya̱ kuá'a̱n‑ya̱. Te ɨɨn cha̱a ni̱ ka'a̱n‑de jíín‑yá ichi‑ún: Táta̱, kundiki̱n‑ná níí va̱sa ndé onde̱ ki'i̱n‑ní, áchí‑de.
\v 58 Te ni̱ kachi̱ Jesús jíín‑de: Ta̱ká ñu̱kuii, ká'i̱o yau̱ kava káyi̱'i‑tɨ̱, te suni tɨsaa̱ andɨ́vɨ́ ká'i̱o taka̱‑tɨ̱. Ko máá Sé'e cha̱a, tú nuu̱ kusú‑ya̱, áchí‑ya̱.
\v 59 Te ni̱ ka'a̱n‑ya̱ jíín ɨngá‑de: Kundiki̱n ruu̱ ná kí'o̱n, áchí‑ya̱. Te máá cháa‑ún ni̱ kachi̱‑de: Táta̱, kua̱'a‑ní tu̱'un ná kíchindu̱ji‑ná táa̱‑ná xna'a̱n‑ga̱, áchí‑de.
\v 60 Te ni̱ ka'a̱n Jesús jíín‑de: Skéndo̱o ta̱ká ndɨ̱yi‑ún ná chíndu̱ji tá'an ndɨ̱yi jíná'an. Te róó kuá'án te kani‑ró tú'un ta̱ká lado, ndasa koo ñuu̱ nuu̱ tá'ú Dios tiñu, áchí‑ya̱.
\v 61 Yúan‑na te suni ni̱ ka'a̱n ɨnga̱‑de: Táta̱, kundiki̱n‑ná níí, ko kua̱'a‑ní tu̱'un ná kíka'a̱n‑ná xna'a̱n‑ga̱ jíín já ká'i̱o ve'e‑ná, áchí‑de.
\v 62 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Ɨɨn cha̱a nú jítu‑de jíín latú‑de, te ndé'é‑de ichi yatá‑dé, tú va̱'a cha̱a kúu‑de ja̱ kɨ́vɨ‑de ini̱ ñuu̱ nuu̱ tá'ú Dios tiñu, áchí‑ya̱.
\c 10
\s1 Ja̱ ní tájí‑yá uni̱ xiko uxi̱‑de kua'a̱n‑de
\p 
\v 1 Yúan‑na te onde̱ ni̱ kuu ta̱ká tiñu yá'a, te máá Jíto'o̱‑yo̱ ní jani‑ya̱ uní xiko uxi̱‑ga̱‑de. Te cha̱a‑ún, ni̱ tájí‑yá uu̱ uu̱‑de káyoxnúú‑de nuu̱‑yá kua'a̱n‑de ta̱ká ñuu̱ jíín lugar nuu̱ á jáni ini̱ máá‑yá ja̱ kí'i̱n‑ya̱.
\v 2 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Trigo ta'nu̱, ja̱ndáa̱ kúu ja̱ kuá'a̱, ko cha̱a ka'nu̱ yaku̱‑ni‑de íó. Núsáá, te kaka̱n ta'u̱‑ro̱ núu̱ máá Tatá xíin trigo, ná tájí‑yá cha̱a ka'nu̱ kikoyo‑de nuu̱ trigo‑ya̱.
\v 3 Kuá'án jíná'an‑ró. Ná kástu̱'ún‑rí nuu̱‑ro̱, chi̱ tájí‑rí róó ki'i̱n‑ro̱ nátu̱'un lélú má'ñú yí'ɨ̱.
\v 4 Te ma̱ kúndiso‑ró bolsa, ni ñunu, ni ndija̱n‑ro̱. Te nú ndéja̱ ní ketá'an‑ró jíín íchi, te ma̱ ndátu̱'ún‑ró jíín.
\v 5 Te na̱ni ve'e nú kɨ̱vɨ‑ró, te xna'a̱n‑ga̱ ka'a̱n‑ro̱: Ná sándéé iní ve̱'e yá'a, achi̱‑ro̱.
\v 6 Te nú ini̱ ve̱'e yúan íó ɨɨn cha̱a va̱'a ini̱, te tu̱'un ndéé ní ka'a̱n‑ro̱‑ún ná jáa̱ sɨkɨ̱‑dé. Te nú tú kánchaa̱ ɨɨn cha̱a va̱'a ini̱, te tu̱'un ndéé‑ún najaa̱‑ni nuu̱‑ro̱.
\v 7 Te suni ve'e yúan kendo̱o‑ró, te kee‑ro, ko'o‑ró na̱ún kája̱'a‑i nuu̱‑ro̱. Chi cha̱a sátiñu, ni'i̱n‑dé kee‑dé. Ma̱ káka‑ró ndɨ́ta'a̱n ve'e.
\v 8 Te na̱ni ñuu̱ nú ni̱ kɨ̱vɨ koyo‑ró, te nú kuatá'ú‑i róó, yúan te kaji‑ro jíná'an‑ró na̱ún kájani‑i nuu̱‑ro̱.
\v 9 Te nasáva̱'a‑ró ñáyɨvɨ káku'u̱ káxiu̱kú‑i ñuu̱ yúan. Te kachi̱‑ro̱ kúni‑i: Nuu̱‑ro̱ jíná'an‑ró, a yani koo ñuu̱ nuu̱ tá'ú Dios tiñu, achi̱‑ro̱.
\v 10 Ko na̱ni ñuu̱ nú ni̱ kɨ̱vɨ koyo‑ró, te nú tú ní kájatá'ú‑i róó, te kenda koyo‑ró iní ichi‑í yúan, te ka'a̱n‑ro̱:
\v 11 Onde̱ tɨkacha̱ ñú'un íó ñuu̱‑ro̱ yá'a ni̱ tɨ̱ɨn ini̱ ja'a̱‑rí jíná'an‑ri̱, ná náskóyo‑ri̱ ja̱ kúu sɨkɨ̱ máá‑ró. Te kuni̱‑ro̱, ja̱ á yani koo ñuu̱ nuu̱ tá'ú Dios tiñu.
\v 12 Te ká'a̱n‑ri̱ jíín‑ró, kɨvɨ̱‑ún te koo‑ga̱ tu̱ká'nu ini̱ ya̱ núu̱ ñáyɨvɨ ñúu̱ Sodoma, vásá núu̱ ñúu̱‑ún.
\v 13 Naka̱ ndá'ú kuu róó ñuu̱ Corazín, te naka̱ ndá'ú kuu róó ñuu̱ Betsaida. Chi̱ nú ini̱ ñuu̱ Tiro jíín iní ñuu̱ Sidón ní sá'a‑ri̱ tiñu ñá'nu ja̱ ní sá'a‑ri̱ nuu̱ máá‑ró yá'a núú, te ɨnga̱ kɨvɨ̱ te a ni̱ ka̱nakani ini̱ ña̱yɨvɨ‑ún núú, te ku'un‑i sa'ma ndáí te ku'u‑í yaa̱ núu̱‑í núú.
\v 14 Núsáá te kɨvɨ̱ kíi juicio te koo‑ga̱ tu̱ká'nu ini̱‑ya̱ núu̱ ñúu̱ Tiro jíín núu̱ ñúu̱ Sidón vásá núu̱ máá‑ró.
\v 15 Te róó, ñuu̱ Capernaum, a ni̱ kuñá'nu xaa̱n‑ro̱ jiní‑ro̱ náún, ko onde̱ infierno najinu̱‑ro̱.
\v 16 Cha̱a jíni so̱'o tu̱'un ká'a̱n máá‑ró, nuu̱‑rí jíni so̱'o‑de. Te cha̱a sájá'a̱ ini̱ nuu̱‑ro̱, nuu̱‑rí sájá'a̱ ini̱‑de. Te cha̱a sájá'a̱ ini̱ nuu̱‑rí, sájá'a̱ ini̱‑de nuu̱ I'a̱ ni̱ tájí rúu̱ va̱i‑ri̱. Achí‑ya̱.
\v 17 Te ni̱ naja̱koyo uni̱ xiko uxi̱ cha̱a‑ún kákusɨɨ̱ iní‑de, te káka'a̱n‑de: Táta̱, onde̱ tachi̱ kíni kájandatu̱ nuu̱‑ná ja̱ jíín sɨ́'vɨ́‑ní vidáa̱, áchí‑de.
\v 18 Te Jesús, ni̱ ka'a̱n‑ya̱ jíín‑de: Ni̱ jini̱‑ri̱ nuu̱ Satanás ni̱ jungava ichi ándɨ́vɨ́, nátu̱'un ɨɨn taja.
\v 19 Vina te kua̱'a‑ri̱ fuerza nuu̱‑ro̱ náva̱'a kuañu̱‑ro̱ sɨkɨ́ kóo̱ jíín sɨkɨ́ kúrsiuku̱, jíín sɨkɨ́ táká fuerza máá já jíto u'u̱ yóó. Te tú na̱ún sá'a kutɨ jíín‑ró.
\v 20 Ko ma̱ kúsɨɨ̱ iní‑ro̱ jíín tíñu yá'a ja̱ kájandatu̱ tachi̱ núu̱‑ro̱, chi̱ sua ná kúsɨɨ̱ iní‑ro̱ já á káyo̱so sɨ́'vɨ́‑ró ondé andɨ́vɨ́. Achí‑ya̱.
\v 21 Te suni hora‑ún ni̱ kusɨɨ̱ iní Jesús, onde̱ jíín Espíritu Santo, te ni̱ ka'a̱n‑ya̱: Ná kúta'u̱‑ná nuu̱‑ní Táa̱, Jito'o̱ andɨ́vɨ́ jíín ñúyɨvɨ kúu máá‑ní, ja̱ ní jasu̱‑ní ta̱ká tu̱'un yá'a nuu̱ cháa ndíchí jíín núu̱ cháa kájuku̱'un ini̱. Te ni̱ stá'a̱n ndiji̱n‑ní nuu̱ cháa súchí iní jíná'an‑de. Chi̱ súan ni̱ jata'a̱n ini̱‑ní Táa̱.
\v 22 Ta̱ká ndatíñu ni̱ ja̱'a Táa̱‑ri̱ ini̱ nda'a‑rí. Te tú ni ɨɨn jiní nuu̱ máá Sé'e, chi̱ máni máá Táa̱ jiní‑ya̱. Ni tú jiní ni ɨɨn nuu̱ máá Táa̱, chi̱ máá Sé'e jiní, jíín na̱ni cha̱a ja̱ kuní máá Sé'e te stá'a̱n ndiji̱n‑ya̱ núu̱‑dé. Achí‑ya̱.
\v 23 Te sɨ́ɨn ni̱ jíó káva máá Jesús nuu̱ cháa káskuá'a jíín‑yá. Te ni̱ ka'a̱n‑ya̱: Xáán ndatu̱ cha̱a kuni̱ tiñu ja̱ ní kajini̱ máá‑ró.
\v 24 Chi̱ ká'a̱n‑ri̱ jíín‑ró ja̱ kuá'a̱ cháa kájani tu̱'un Dios jíín cháa kákuu rey, ni̱ kakuni̱‑de nde̱'é‑de nuu̱ já kánde̱'é máá‑ró, ko tú ní kájini̱‑de, te kuni so̱'o‑de ja̱ ní kájini so̱'o‑ró kuní‑de núú, ko tú ní kájini so̱'o‑de, áchí‑ya̱.
\s1 Cha̱a va̱'a ñuu̱ Samaria
\p 
\v 25 Te yúan kánchaa̱ ɨɨn maestro ley, te ni̱ ndukuiñi̱‑de chi̱ koto nchaa̱‑de‑ya̱ kuní‑de: Maestro, na̱ún sá'a‑ná náva̱'a ni'i̱n tá'u̱‑ná kuchaku̱‑ná nɨ́ɨ́ káni, áchí‑de.
\v 26 Te ni̱ ka'a̱n máá Jesús jíín‑de: Ndasa yóso núu̱ tutú ley. Ndasa ká'a̱n ká'u‑ró. Achí‑ya̱.
\v 27 Te máá cháa‑ún ni̱ ka'a̱n‑de: Kumani̱‑ro̱ jíín máá Tatá‑ro̱ Dios onde̱ jíín iní jíín añú‑ro̱ jíín nɨ́ɨ́ fuerza‑ro̱ jíín nɨ́ɨ́ núu̱ jiní tuní‑ro̱, te kundá'ú ini̱‑ro̱ tá'an‑ró nátu̱'un kúndá'ú ini̱‑ro̱ máá‑ró, áchí‑de.
\v 28 Te ni̱ kachi̱ Jesús jíín‑de: Va̱'a ni̱ ka'a̱n‑ro̱. Sá'a súan, te ni'i̱n tá'u̱‑ro̱ kúchaku̱‑ro̱ núsáá, áchí‑ya̱.
\v 29 Ko máá cháa‑ún, kuní‑de ja̱ kée ndaa̱‑de jíín tú'un ká'a̱n‑de, te ni̱ jika̱ tu̱'ún‑de Jesús: Te ndéja̱ kúu tá'an‑ná, áchí‑de.
\v 30 Te máá Jesús ni̱ ka'a̱n‑ya̱: Ɨɨn cha̱a ni̱ kenda‑de ñuu̱ Jerusalén. Te ni̱ kuun‑de kua'a̱n‑de ñuu̱ Jericó. Te ichi‑ún ni̱ kenda ñakui̱'ná núu̱‑dé, te ni̱ ka̱janchaa̱ ndatíñu‑de, te ni̱ ka̱stují‑dé. Te ni̱ kee kája'a̱n, ni̱ ndo̱o cha̱a‑ún kátúu‑dé. Te a yani kuu̱‑de núú.
\v 31 Te ni̱ kuu ja̱ íchi‑ún ni̱ kuun ɨɨn sutu̱ va̱i‑de. Te ni̱ jini̱‑de nuu̱ cháa‑ún. Te ni̱ sío‑ni‑de kua'a̱n‑de.
\v 32 Suni súan ɨɨn cha̱a levita, ni̱ kuyani‑de lugar yúan. Te ni̱ jini̱‑de nuu̱ cháa‑ún. Te ni̱ sío‑ni‑de kua'a̱n‑de.
\v 33 Ko ɨɨn cha̱a ñuu̱ Samaria, jíka‑de kua'a̱n‑de ichi‑ún, ni̱ kuyani‑de nuu̱ kátúu cháa‑ún. Te ni̱ jini̱‑de. Te ni̱ kundá'ú ini̱‑de cha̱a‑ún.
\v 34 Te ni̱ jaa̱‑de. Te ni̱ chu'un‑de aceite jíín alcohol nuu̱ ní tuji̱ cháa‑ún. Te ni̱ ju'ni̱‑de nuu̱. Te ni̱ skáa‑de cha̱a‑ún sɨkɨ̱ caballo‑de. Te kua'a̱n‑de jíín‑de onde̱ mesón. Te ni̱ jito‑de cha̱a.
\v 35 Te ɨnga̱ kɨvɨ̱ xía̱n‑ún ni̱ kenda‑de kua'a̱n‑de. Te ni̱ tava‑dé uu̱ peso ni̱ ja̱'a‑de nuu̱ cháa xíin mesón. Te ni̱ ka'a̱n‑de: Koto‑ní‑de. Jíín táká‑ga̱ ja̱ kanú‑ní jíín‑de, te nuu̱ ncháa̱‑ná, te nachunáa‑ná nuu̱‑ní, áchí‑de.
\v 36 Núsáá te ja̱ uní tá'a̱n cha̱a‑ún, te ndé ɨɨn‑de ni̱ kuu tá'an cha̱a ni̱ kenda ñákui̱'ná nuu̱‑ún, jáni ini̱‑ro̱, áchí‑ya̱ jíín‑de.
\v 37 Te ni̱ ka'a̱n máá cháa‑ún: Cha̱a ni̱ kundá'ú ini̱‑de‑ún, áchí‑de. Yúan‑na te ni̱ ka'a̱n Jesús jíín‑de: Kuá'án núsáá, te suni súan sá'a máá‑ró, áchí‑ya̱.
\s1 Ja̱ ní jaa̱‑ya̱ núu̱ María jíín Marta
\p 
\v 38 Te jíka‑ya̱ kuá'a̱n‑ya̱ íchi. Te ni̱ kɨ̱vɨ‑ya̱ ɨ́ɨn ñuu̱. Te ɨɨn ñasɨ́'ɨ́, nání‑ña Marta, ni̱ kana‑ña xiní‑yá ni̱ kɨ̱vɨ‑ya̱ iní ve̱'e‑ña.
\v 39 Te ña'an yá'a, íó ɨɨn ku'u̱‑ña nání María. Te María‑ún, ni̱ jungo̱o‑ña núu̱ já'a̱ Jesús, jíni ná'ín‑ña tú'un ká'a̱n‑ya̱.
\v 40 Ko Marta kútéñu‑ña já tɨnɨ́ tiñu sá'a‑ña. Te ni̱ jaa̱‑ña núu̱‑yá, te ni̱ kachi̱‑ña: Táta̱, tú ndé'é‑ní ja̱ kú'u̱‑ná ni̱ xndóo‑i náá játíñu máá ɨ́ɨn‑ná. Núsáá te ka'a̱n‑ní jíín‑i ná chíndéé tá'an‑i jíín‑ná. Achí‑ña.
\v 41 Ko ni̱ ka'a̱n Jesús: Marta, Marta, xaa̱n jítú iní‑ro̱ sátiñu‑ró, te ja̱ kuá'a̱ tíñu sá'a‑ró, te ni̱ ndukuí'a̱ ini̱‑ro̱ jíín.
\v 42 Ko íó ɨɨn‑ni tiñu kánúú xáa̱n. Te María, ni̱ naka̱ji‑i tiñu kánúú‑ún. Te ni ɨɨn, ma̱ kúu kuanchaa̱ nuu̱‑í. Achí‑ya̱.
\c 11
\s1 Ja̱ jikán ta'u̱‑yo̱ jíín Padre Nuestro
\p 
\v 1 Te ni̱ kuu ja̱ jikán ta'u̱‑yá kánchaa̱‑ya̱ ɨ́ɨn lugar. Te nuu̱ ní ndɨ'ɨ ni̱ ka'a̱n‑ya̱, te ɨɨn cha̱a káskuá'a jíín‑yá, ni̱ ka'a̱n‑de jíín‑yá: Táta̱, stá'a̱n‑ní nuu̱‑ná ndasa kaka̱n ta'u̱‑ná jíná'an‑ná, nátu̱'un ni̱ stá'a̱n Juan nuu̱ cháa káskuá'a jíín‑de, áchí‑de.
\v 2 Te ni̱ kachi̱‑ya̱ jíín‑de: Nú kájika̱n ta'u̱‑ro̱, te sua ka'a̱n‑ro̱: Táa̱ máá‑ná ja̱ kánchaa̱‑ní onde̱ andɨ́vɨ́, ná nákana jaa‑ná níí jíín sɨ́'vɨ́‑ní. Te ná kóo ñuu̱ nuu̱ tá'ú‑ní tiñu. Te ná kóo ta̱ká tiñu játa'a̱n ini̱ máá‑ní, nátu̱'un íó ini̱ andɨ́vɨ́ suni súan ná kóo ini̱ ñu̱yɨ́vɨ yá'a.
\v 3 Staa̱ káyee‑ná ta̱ká kɨvɨ̱ kuá'a‑ní nuu̱‑ná vina.
\v 4 Te sá'a‑ní tu̱ká'nu ini̱‑ní nuu̱ táká kua̱chi‑ná, chi̱ suni máá‑ná kásá'a‑ná tu̱ká'nu ini̱‑ná nuu̱ ñáyɨvɨ kásá'a‑i falta nuu̱‑ná. Te ma̱ skɨ́vɨ‑ní náá koto nchaa̱‑i náá chi̱ sua nama‑ní náá nuu̱ kíni nuu̱ kuí'a̱. Achí‑ya̱.
\v 5 Te ni̱ ka'a̱n‑ga̱‑ya̱ jíín‑de: Ndé róó íó ɨɨn amigo‑ro̱ te nú ki'i̱n‑ro̱ núu̱‑dé sava ñúú te kachi̱‑ro̱ kúni‑de: Amigo, kua̱'a núu uni̱ staa̱ núu̱‑rí,
\v 6 chi̱ ɨɨn amigo‑ri̱ ni̱ chaa̱‑de ve'e‑ri̱ ja̱ jíka‑de viaje. Te tú na̱ún kuá'a‑ri̱ nuu̱‑dé kee‑dé. Achi̱‑ro̱.
\v 7 Te cha̱a kándee ichi iní ve̱'e ka'a̱n‑de: Ma̱ stá'a̱n‑ro̱ rúu̱, chi̱ a ndasú yuxé'é‑rí, te se̱'e‑ri̱ kákixi̱‑i jíín‑rí. Te ma̱ kúu nduko̱o‑ri̱ te kua̱'a‑ri̱ nuu̱‑ro̱. Achi̱‑de.
\v 8 Ká'a̱n‑ri̱ jíín‑ró, va̱sa ma̱ ndúko̱o‑de kua̱'a‑de nuu̱‑ro̱ já kúu‑de amigo‑ro̱, ko ja̱ xáa̱n stá'a̱n‑ro̱‑dé te yu̱án ndúko̱o‑de te kua̱'a‑de ta̱ká ja̱ jínu ñú'ún‑ró.
\v 9 Te ká'a̱n‑ri̱ jíín‑ro̱ jíná'an‑ró: Kaka̱n, te kua̱'a‑ya̱ núu̱‑ro̱. Ndúkú, te ni'i̱n‑ro̱. Ka'a̱n, te ná núña ve'e kɨ̱vɨ‑ró.
\v 10 Chi cha̱a jikán, te kíi nuu̱‑dé. Te cha̱a ndúkú, te ní'i̱n‑dé. Te cha̱a ká'a̱n, te núña ve'e kɨ̱vɨ‑de.
\v 11 Te ndé ɨɨn róó ɨɨn táa̱ ini̱ ve̱'e kúu‑ró. Te nú se̱'e‑ró jikán‑i staa̱ núu̱‑ro̱, te kua̱'a‑ró ɨ́ɨn yuu̱ núu̱‑í náún. Xí nú jikán‑i ɨɨn ti̱yáká, te lugar ja̱ kuá'a‑ró tíyáká, te kua̱'a‑ró ɨ́ɨn koo̱ nuu̱‑í náún.
\v 12 Xí nú jikán‑i ɨɨn ndɨvɨ̱ núu̱‑ro̱, te kua̱'a‑ró ɨ́ɨn kúrsiuku̱ nuu̱‑í náún.
\v 13 Te nú róó va̱sa cha̱a ñáá kákuu‑ró, te kájini̱‑ro̱ kuá'a‑ró ndátíñu va̱'a nuu̱ sé'e‑ró, naga̱ ni̱ kuu máá Táa̱‑ro̱ I'a̱ kánchaa̱ andɨ́vɨ́ já má kuá'a‑ya̱ Espíritu Santo nuu̱ cháa jikán núsáá. Achí‑ya̱.
\s1 Sɨkɨ̱ tú'un Beelzebú káka'a̱n‑i jíín‑yá
\p 
\v 14 Te kíñi'in‑ya̱ ɨ́ɨn tachi̱ ñí'ín. Te nuu̱ ní kenda tachi̱‑ún kua'a̱n, te cha̱a ñí'ín‑ún ni̱ naka'a̱n‑de. Te ta̱ká ña̱yɨvɨ ká'i̱in yúan ni̱ ka̱kee nuu̱‑í kánde̱'é‑i.
\v 15 Ko sava ña̱yɨvɨ‑ún ni̱ kaka'a̱n‑i: Jíín Beelzebú, cha̱a kúñá'nu nuu̱ táká tachi̱, kíñi'in‑de tachi̱ kája'a̱n, áchí‑i.
\v 16 Te sava‑ga̱‑i kájito nchaa̱‑i‑ya̱. Te ni̱ kajika̱n‑i ɨɨn tuni̱ ichi ándɨ́vɨ́ núu̱‑yá.
\v 17 Ko máá Jesús ni̱ jini̱‑ya̱ já súan kájani ini̱‑i. Te ni̱ ka'a̱n‑ya̱ jíín‑i: Te nú ɨɨn ñuu̱ sásɨ́ɨn máá, te kánakua̱tá'an máá, te ñuu̱ yúan ma̱ kúni̱'in. Te nú ɨɨn ve'e sásɨ́ɨn máá te kánakua̱tá'an máá, te ve'e yúan ma̱ kúni̱'in.
\v 18 Te nú Satanás suni sásɨ́ɨn máá, ndasa kuni̱'in ñuu̱ nuu̱ tá'ú tíñu máá núsáá. Chi̱ káka'a̱n máá‑ró ja̱ jíín Beelzebú kíñi'in‑ri̱ tachi̱‑ún kája'a̱n.
\v 19 Te nú ndújíín Beelzebú jíín‑rí ja̱ kíñi'in‑ri̱ tachi̱ kíni. Núsáá te se̱'e‑ró, ndé jíín kákiñi'in máá‑i tachi̱‑ún. Ja̱ yúán máá‑i, ná nákuxndíi‑i sɨkɨ̱‑ro̱.
\v 20 Ko nú jíín xiní ndá'a Dios kíñi'in‑ri̱ tachi̱ kíni kája'a̱n, ja̱ndáa̱ kúu ja̱ núu̱‑ro̱ ní chaa̱ ñuu̱ nuu̱ tá'ú Dios tiñu núsáá.
\v 21 Nú ɨɨn cha̱a kándáján, te jíín machete ndíto‑de yujé'é‑de, yúan‑na te ká'i̱in va̱'a ta̱ká ndatíñu‑de.
\v 22 Ko nú jaa̱ ɨnga̱ cha̱a ni̱'in‑ga̱ vásá máá‑de, yúan‑na te kundéé cháa‑ún jíín‑de, te kuanchaa̱ ndɨ'ɨ‑ni machete‑de nuu̱‑dé ja̱ ndíto‑de jíín. Te kiñi'in ndɨ'ɨ ndatíñu‑de.
\v 23 Nú ndé cha̱a tú ndújíín‑de jíín‑rí, núsáá te jíto u'u̱‑de ruu̱. Te cha̱a tú nástútú jíín‑rí, jachá‑de.
\v 24 Nú ni̱ kenda ɨɨn tachi̱ kíni ini̱ ɨɨn cha̱a te jíka kuu nuu̱ ñú'un té'é, ndúkú núu̱ júngo̱o te tú ní'i̱n, yúan‑na te ka'a̱n: Ná nó'o̱n‑ri̱ ve'e nuu̱ ní kenda‑ri̱, achi̱.
\v 25 Te nú ni̱ nchaa̱ te jiní ja̱ vé'e luu kúu, chi ni̱ ndundoo,
\v 26 yúan‑na te ki'i̱n tachi̱‑ún, te kuaka tá'an jíín usiá‑ga̱ tachi̱ ñáá‑ga̱ káa vásá máá. Te kɨ̱vɨ koyo, te kuxiu̱kú yúan. Núsáá te ví'í‑gá tá'a̱n cha̱a yúan onde̱ sandɨ̱'ɨ́‑na̱ vásá já xnáñúú núú, áchí‑ya̱.
\v 27 Te ni̱ kuu ja̱ ká'a̱n‑ya̱ tú'un yá'a. Te ɨɨn ña'an kándee ma̱'ñú ñáyɨvɨ kuá'a̱‑ún, ni̱ kana jaa‑ña xiní‑yá: Xáán ndatu̱ ña'an ní skáku níí, te ni̱ skáxin‑ña níí, áchí‑ña.
\v 28 Te ni̱ ka'a̱n‑ya̱: Sua ndatu̱‑ga̱ kúu ña̱yɨvɨ kájini so̱'o tu̱'un Dios, te káchu'un ini̱‑i, áchí‑ya̱.
\s1 Ja̱ kájika̱n‑i ɨɨn tuni̱
\p 
\v 29 Te ni̱ kataka̱ ña̱yɨvɨ núu̱‑yá, te ni̱ ka'a̱n‑ya̱: Ña̱yɨvɨ ñáá yá'a, kájika̱n‑i tuni̱, ko ma̱ kuá'a‑ri̱ nuu̱‑í, chi̱ tuni̱ Jonás kúu ja̱ kíi nuu̱‑í.
\v 30 Chi̱ nátu̱'un Jonás, ni̱ kuu‑de ɨɨn tuni̱ nuu̱ cháa ñuu̱ Nínive, suni súan máá Sé'e cha̱a kuu‑ya̱ ɨ́ɨn tuni̱ nuu̱ ñáyɨvɨ yá'a jíná'an‑i.
\v 31 Te reina onde̱ ichi sur, nachaku̱‑ña jíín ñáyɨvɨ yá'a kɨvɨ̱ kíi juicio. Te naku̱xndíi‑ña sɨkɨ́‑í. Chi̱ onde̱ jíká xáa̱n ní kii‑ña ní jini so̱'o‑ña tú'un ndíchí ní ka'a̱n Salomón. Te vina ví'í‑gá kúñá'nu I'a̱ kándii̱ yá'a vásá Salomón.
\v 32 Ta̱ká cha̱a ñuu̱ Nínive nachaku̱‑de jíín ñáyɨvɨ yá'a kɨvɨ̱ kíi juicio, te naku̱xndíi‑de sɨkɨ̱‑í. Chi̱ máá‑de ni̱ ka̱nakani ini̱‑de kɨvɨ̱ ní jani Jonás tu̱'un nuu̱‑dé. Te vina ví'í‑gá kúñá'nu I'a̱ kándii̱ yá'a vásá Jonás.
\s1 Tu̱'un yitɨ
\p 
\v 33 Tú ni ɨɨn cha̱a, nú ni̱ chi'i‑de ñu'u̱n xini̱ yítɨ, te chisa̱'í‑de yitɨ‑ún chi̱i nu̱ndóó. Chi̱ sua kani‑de nuu̱ candelero, náva̱'a ná kuní ña̱yɨvɨ kɨ́vɨ koyo ini̱ ve̱'e, nuu̱ máá luz.
\v 34 Lámpara yikɨ kúñu kúu nduchi‑yo. Te nú nduchi‑ro íó va̱'a, nɨ́ɨ́‑ni yikɨ kúñu‑ró ndíi ncháa̱. Ko nú nduchi‑ro káñáá, te nɨ́ɨ́‑ni yikɨ kúñu‑ró kándee ñu̱ñáa.
\v 35 Koto ñúkúún‑ró máá‑ró núsáá, chi̱ luz kándee ini̱‑ro̱ sanaa te ñu'u̱n tu̱ún kúu.
\v 36 Nú nɨ́ɨ́ yíkɨ kúñu‑ró ndíi ncháa̱, ni tú íó ɨɨn tí'li̱ nuu̱ túún, nɨ́ɨ́ nándii ncháa̱ núsáá, nátu̱'un ɨɨn lámpara ja̱ xú'ún kayú. Achí‑ya̱.
\s1 Ja̱ ní kana jíín‑yá nuu̱ cháa fariseo
\p 
\v 37 Te nini ká'a̱n‑ya̱, te ni̱ ka'a̱n nda̱'ú‑ni ɨɨn cha̱a fariseo jíín‑yá ja̱ kée‑yá staa̱ jíín‑de. Te ni̱ kɨ̱vɨ Jesús ini̱ ve̱'e cha̱a‑ún. Te ni̱ jungo̱o‑ya̱ kée‑yá staa̱ jíín‑de.
\v 38 Te cha̱a‑ún, ni̱ jini̱‑de nuu̱‑yá. Te ni̱ naa iní‑de ndé'é‑de ja̱ tú ní nándá'á‑yá te yée‑yá staa̱.
\v 39 Te máá Jíto'o̱‑yo̱ ní ka'a̱n‑ya̱ jíín‑de: Ja̱ndáa̱ kúu, chi̱ róó, cha̱a fariseo, kánakacha‑ró íchi yatá tɨ́ndo'o̱ jíín íchi yatá kó'o̱. Ko ichi iní‑ro̱, chi ni̱ ka̱chítú ndɨ́ɨ‑ro jíín tú'un kuí'ná jíín tú'un ñáá.
\v 40 Cha̱a káñáá jíná'an‑ró. I'a̱ ni̱ sá'a ichi yatá, á tú suni ní sá'a‑ya̱ íchi iní.
\v 41 Ko ta̱ká ja̱ kéndo̱o sobra nuu̱‑ro̱, te kája̱'a‑ró kúu caridad, te kájani ini̱‑ro̱ já táká tiñu kásá'a‑ró íó ndoo ja̱ súan.
\v 42 Naka̱ ndá'ú kuu róó cha̱a fariseo, chi̱ kája̱'a‑ró ɨ́ɨn sɨkɨ̱ uxí ita̱ mi̱nú jíín ruda jíín táká yua̱, nuu̱ Dios, te tú kásá'a kutɨ‑ro tíñu ndaa̱, ni tú mani̱‑ro̱ jíín‑yá. Ní kásá'a‑ró ndéndúú tiñu yá'a te ma̱ xndóo‑ró ɨngá tiñu‑ún núú.
\v 43 Naka̱ ndá'ú kuu róó cha̱a fariseo, chi̱ xaa̱n kákuni̱‑ro̱ silla onde̱ xini̱ mesa ini̱ ve̱'e sinagoga. Te ka'a̱n sa̱'án ña̱yɨvɨ jíín‑ró núyá'u kákuni̱‑ro̱.
\v 44 Naka̱ ndá'ú kuu róó cha̱a káchaa tutu̱ jíín cháa fariseo, chi cha̱a uu̱ xini̱ kákuu‑ró. Nátu̱'un ve'e añú ja̱ tú ndiji̱n kándee, súan ká'i̱o‑ró, te cha̱a kájika kuu, tú jiní‑de ja̱ jañú‑de sɨkɨ̱, áchí‑ya̱ jíín‑de.
\v 45 Te ɨɨn cha̱a kúu maestro ley, ni̱ ka'a̱n‑de: Maestro, nuu̱ ní ka'a̱n‑ní tu̱'un yá'a, suni ni̱ ka'a̱n‑ní sɨkɨ̱ máá‑ná jíná'an‑ná, áchí‑de jíín‑yá.
\v 46 Te ni̱ ka'a̱n‑ya̱: Naka̱ ndá'ú kuu róó cha̱a maestro ley jíná'an‑ró, chi̱ káchaa‑ró carga ve̱e sɨkɨ̱ táká cha̱a ja̱ tú kákuu kundiso‑de. Ko máá‑ró, ni tú káké'é‑ró carga‑ún va̱sté jíín ɨ́ɨn nda'a lúlí‑ró.
\v 47 Naka̱ ndá'ú kuu róó jíná'an‑ró. Chi̱ kásá'a‑ró vé'e añú cha̱a ni̱ ka̱jani tu̱'un Dios. Te ni̱ ka̱ja'ni táa̱‑ro̱‑dé jíná'an‑de.
\v 48 Súan kúu ja̱ káka'a̱n ndaa̱‑ro̱ já kájata'a̱n ini̱‑ro̱ tíñu ni̱ ka̱sá'a táa̱‑ro̱. Chi ja̱ndáa̱ kúu ja̱ ní ka̱ja'ni‑dé cha̱a‑ún. Te máá‑ró, ni̱ ka̱sá'a‑ró vé'e añú ndɨ̱yi‑ún.
\v 49 Ja̱ yúán súni ni̱ ka'a̱n Dios ɨɨn tu̱'un ndíchí: Tájí‑rí cha̱a kani tu̱'un‑ri̱ jíín cháa apóstol ki'i̱n nuu̱‑í jíná'an‑i. Te sava‑de ka'ni‑í te sava‑ga̱‑de chindiki̱n‑i, áchí Dios,
\v 50 náva̱'a sɨkɨ̱ ñáyɨvɨ yá'a ná kóo kua̱chi cuenta ja̱ ní jatɨ nɨñi̱ táká cha̱a ni̱ ka̱jani tu̱'un‑ri̱ onde̱ kɨvɨ̱ ní jungo̱o ñu̱yɨ́vɨ,
\v 51 onde̱ nɨñi̱ Abel, te onde̱ nɨñi̱ Zacarías, cha̱a ni̱ ji'i̱ sava ma̱'ñú altar jíín vé'e ii̱. Súan ká'a̱n‑ri̱ jíín‑ró, ja̱ sɨkɨ́ ñáyɨvɨ yá'a kuu kua̱chi‑ún.
\v 52 Naka̱ ndá'ú kuu róó maestro ley, chi ni̱ ka̱janchaa̱‑ro̱ ndákáa kɨ̱vɨ‑i ini̱ tu̱'un ndíchí núú, te ni̱ kajasu̱‑ro̱ núu̱ cháa kákuni̱ skuá'a. Ko ni máá‑ró suni tú ní káskuá'a‑ró, áchí‑ya̱.
\v 53 Te nini ká'a̱n‑ya̱ tú'un yá'a, te cha̱a káchaa tutu̱ jíín cháa fariseo, ni̱ katau̱ xaa̱n‑dé nuu̱‑yá. Te ni̱ ka̱státá'an‑de jíín‑yá ja̱ ná ká'a̱n‑ga̱‑ya̱ kuá'a tú'un.
\v 54 Chi̱ kájito yu'u‑dé‑ya̱, ja̱ sánaa te ni'i̱n‑dé yaku̱ tu̱'un ká'a̱n‑ya̱, náva̱'a kaka̱n‑de kua̱chi sɨkɨ̱‑yá.
\c 12
\s1 Cuenta yujan íá cháa fariseo
\p 
\v 1 Nini súan kúu, te ni̱ ka̱kutútú kuá'a̱ xáa̱n ñáyɨvɨ, ja̱ kájañu̱ tá'an‑i. Te ni̱ ka'a̱n‑ya̱ jíín cháa káskuá'a jíín‑yá: Koto va̱'a‑ró máá‑ró núu̱ yújan íá cháa fariseo, chi yu̱án kúu tu̱'un yóso yú'u.
\v 2 Chi̱ tú ni ɨɨn na̱ún yíndi'u̱ ja̱ má kénda ndiji̱n. Ni tú ni ɨɨn ja̱ yísa̱'í ja̱ má kuní‑yo̱ núu̱.
\v 3 Núsáá, ta̱ká tu̱'un ni̱ ka'a̱n‑ro̱ ñúñáa, onde̱ nuu̱ íó ndiji̱n ná kúni so̱'o‑i. Te tu̱'un ni̱ ka'a̱n ya̱á‑ro̱ ní ka̱jini so̱'o‑i ká'i̱in‑i ini̱ ve̱'e, te onde̱ xini̱ vé'e ná kóo jaa tu̱'un.
\s1 Ndéja̱ yú'ú‑yo̱ kóto‑yó
\p 
\v 4 Ko amigo, ká'a̱n‑ri̱ jíín‑ró jíná'an‑ró: Ma̱ yú'ú‑ro̱ kóto‑ró ñáyɨvɨ já'ni yíkɨ kúñu‑yó, chi̱ nú ni̱ ndɨ'ɨ ni̱ ka̱ja'ni‑í, te tuká ɨnga̱ na̱ún kúu sá'a‑ga̱‑i.
\v 5 Ko ná stá'a̱n‑ri̱ nuu̱‑ro̱ ndé ja̱ yú'ú‑ro̱ kóto‑ró. Ió ɨɨn ja̱ nú a ni̱ ja'ni‑í róó te íó poder yu̱án chíndee róó nuu̱ infierno. Yu̱án yú'ú‑ro̱ kóto‑ró núsáá. Yu̱án kástu̱'ún‑rí nuu̱‑ro̱.
\v 6 Tú kúya̱'u u'u̱n tɨsaa̱ ja̱ úu̱ xu̱'ún náún. Te tú ni ɨɨn‑tɨ̱ náa iní Dios.
\v 7 Chi̱ a ni̱ ka'u‑ya̱ ondé ta̱ká ixi xiní‑ro̱. Núsáá te ma̱ yú'ú‑ro̱ jíná'an‑ró, chi̱ kánúú‑ga̱‑ro̱ vásá kuá'a̱ tɨ́saa̱.
\v 8 Te ká'a̱n‑ri̱ jíín‑ró: Nú ndé cha̱a kani ndaa̱‑de tu̱'un‑ri̱ nuu̱ ñáyɨvɨ, suni súan máá Sé'e cha̱a nakani ndaa̱‑ya̱ tú'un‑de nuu̱ ndájá'a̱ Dios.
\v 9 Ko nú ndé cha̱a ské'ichi̱‑de ruu̱ nuu̱ ñáyɨvɨ, suni súan ské'ichi̱‑ri̱‑de nuu̱ táká ndajá'a̱ Dios.
\v 10 Te nú ndé cha̱a ka'a̱n ndɨva̱'a‑de sɨkɨ̱ máá Sé'e cha̱a, koo tu̱ká'nu ini̱‑ya̱ núu̱‑dé. Ko nú ndé cha̱a ka'a̱n ndɨva̱'a‑de sɨkɨ̱ Espíritu Santo, ma̱ kóo tu̱ká'nu ini̱ nuu̱‑dé.
\v 11 Te nú ni̱ kaja̱ncha̱ka‑i róó ini̱ ve̱'e sinagoga nuu̱ cháa kákuñá'nu jíín núu̱ cháa tá'ú tíñu, ma̱ nákani xaa̱n iní‑ro̱ ndasa xndíó káni‑ró tú'un, xí ndasa ka'a̱n‑ro̱.
\v 12 Chi̱ máá Espíritu Santo stá'a̱n‑ya̱ núu̱‑ro̱ ndasa kanúú tú'un ka'a̱n‑ro̱ hora‑ún, áchí‑ya̱.
\s1 Sɨkɨ̱ já kútóó iní
\p 
\v 13 Yúan‑na te ɨɨn cha̱a kándee‑de nuu̱ ñáyɨvɨ kuá'a̱‑ún, ni̱ ka'a̱n‑de jíín‑yá: Maestro, ka'a̱n‑ní jíín ñaní‑ná ná ká'ncha̱ sava‑de ta'u̱‑ná jíín‑ná, áchí‑de.
\v 14 Ko máá‑yá ni̱ ka'a̱n‑ya̱ jíín‑de: Utale̱, ndéja̱ ní jani ruu̱ ja̱ kúu‑ri̱ cha̱a sándaa̱ xí cháa ka'ncha̱ sava ta'u̱ já kúu róó jíná'an‑ró. Achí‑ya̱.
\v 15 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Koto va̱'a‑ró máá‑ró, te ma̱ kútóó iní‑ro̱, chi va̱sa kua'a̱ xáa̱n ndátíñu ñáva̱'a ɨɨn cha̱a, ko nasu̱ já jíín yúán te kuchaku̱ jíñú'ún‑de, áchí‑ya̱.
\v 16 Yúan‑na te ni̱ ka'a̱n‑ya̱ ɨ́ɨn tu̱'un yátá jíín‑i: Ni̱ i̱o ɨɨn cha̱a kúká. Te ni̱ ndea̱ xaa̱n nuní‑dé.
\v 17 Te cha̱a‑ún, nákani ini̱‑de: Ndasa sá'a‑ri̱, chi̱ tuká núña yaka̱‑ri̱ nataan‑gá‑ri̱ nɨñi‑rí, áchí‑de.
\v 18 Te ni̱ kachi̱‑de: Sua ná sá'a‑ri̱. Ná kanú‑ri̱ yaka̱‑ri̱. Te nakani‑ri̱ ja̱ ká'nu‑ga̱. Te yúan nataan ndɨ́'ɨ‑ri̱ nɨñi‑rí jíín táká‑ga̱ ndatíñu‑ri̱.
\v 19 Yúan‑na te kachi̱‑ri̱ jíín iní jíín añú‑ri̱: Vina te kua'a̱ xáa̱n ndátíñu ñáva̱'a‑ró já kánda kua'a̱ kuiá. Ná ndéta̱tú‑ro̱ te kaji‑ro kó'o‑ró, te ná kúsɨɨ̱ iní‑ro̱ núsáá, áchí‑de jíín máá‑de.
\v 20 Ko ni̱ kachi̱ Dios jíín‑de: Cha̱a ñáá kúu‑ró. Akuáa vína te kuu̱‑ro̱. Te ndatíñu ni̱ sátu̱'a‑ró‑ún, ndé cha̱a kuu. Achi̱ Dios.
\v 21 Súan íó sɨkɨ̱ cháa ja̱ sákúká‑de máá‑de, ko tú kúká‑de nuu̱ Dios.
\s1 Ma̱ nákani ini̱‑yo̱ sɨkɨ́ já kúchaku̱‑yo̱
\p 
\v 22 Te ni̱ ka'a̱n‑ya̱ jíín cháa káskuá'a jíín‑yá: Núsáá te ká'a̱n‑ri̱ jíín‑ró, ma̱ nákani ini̱‑ro̱ sɨkɨ́ já kúchaku̱‑ro̱, nú ndasa kee‑ro, ni sɨkɨ̱ yíkɨ kúñu‑ró, nú ndasa kundii kuna̱má‑ro̱.
\v 23 Á tú kánúú‑gá vida‑ro̱ vásá já kée‑ro, te yikɨ kúñu‑ró vásá sá'ma‑ro náún.
\v 24 Nde̱'é‑ró tɨ́ka̱ká, tú jítu‑tɨ̱, ni tú nástútú‑tɨ́, ni tú náchiva̱'a‑tɨ̱ iní yaka̱‑tɨ̱, chi̱ máá Dios skée‑yá‑tɨ̱. Á tú kánúú‑ga̱‑ro̱ vásá kɨ́tɨ‑ún.
\v 25 Ko ndé róó ja̱ súan nákani ini̱‑ro̱ te á kuu chísó‑ga̱‑ro̱ máá‑ró ɨ́ɨn yíkɨ́.
\v 26 Te nú ma̱ kúu sá'a‑ró va̱sté ɨ́ɨn tiñu lúlí‑ga̱ súan, te naja̱ kánakani ini̱‑ro̱ jíín sáva‑ga̱‑ún núsáá.
\v 27 Nde̱'é ndasa kája'nu ita̱ yuku. Tú sátiñu, ni tú táú. Ko ká'a̱n‑ri̱ jíín‑ró ja̱ rey Salomón kɨvɨ̱ ní kuñá'nu xaa̱n‑dé ni tú ní kúu ku'un‑de sa'ma súan nátu̱'un ita̱‑ún.
\v 28 Te Dios, nú súan skúna̱má‑ya̱ itá yuku‑ún ja̱ íó vina te yuchaa̱n kayu̱ nuu̱ ñú'u̱n, naga̱ ni̱ kuu ja̱ má skúna̱má‑ya̱ róó. Te naja̱ tú kákandíja va̱'a‑ró.
\v 29 Te ma̱ kuítú iní‑ro̱ ndasa kee‑ro, xí ndása ko'o‑ró ni ma̱ nákani xaa̱n iní‑ro̱ núsáá.
\v 30 Chi ta̱ká ndatíñu yá'a kájítú iní ña̱yɨvɨ ñúyɨ́vɨ jíín. Ko máá Táa̱‑ro̱ a jiní‑ya̱ já kánandɨ'ɨ‑ró táká ndatíñu yá'a.
\v 31 Ko kuítú iní‑ro̱ kɨ́vɨ‑ró iní ñuu̱ nuu̱ tá'ú Dios tiñu. Yúan‑na te kua̱'a‑ga̱‑ya̱ táká ndatíñu‑ún nuu̱‑ro̱.
\v 32 Ma̱ yú'ú‑ro̱ jíná'an‑ró, chi va̱sa tɨku'ni̱ lúlí kákuu‑ró, ko máá Táa̱‑ro̱ ándɨ́vɨ́, a ni̱ kusɨɨ̱ iní‑ya̱ já núu̱‑ro̱ kuá'a‑ya̱ ñúu̱ nuu̱ tá'ú‑yá tiñu.
\v 33 Xi̱kó táká ndatíñu‑ró, te sá'a‑ró caridad. Ndúkú‑ró bolsa ja̱ má kútú'ú kuátíñu‑ró. Te suni taan‑ro yají‑ro̱ ondé andɨ́vɨ́ nuu̱ tú naa. Chi̱ yúan ma̱ kúu kɨ̱vɨ ñakui̱'ná, ni ma̱ kúu chaa ti̱kixin te stɨ́vɨ́‑tɨ́.
\v 34 Chi nuu̱ kándee yaji̱‑ro̱, yúan kúu nuu̱ kuítú iní‑ro̱ jíín.
\v 35 Ku'ni̱ ni̱'in chi̱i‑ró jíná'an‑ró, te lámpara máá‑ró, ná kóo tu̱'a‑ni ñu'u̱n ini̱.
\s1 Ja̱ ní káinda̱tu mozo jito'o̱‑i
\p 
\v 36 Te máá‑ró jíná'an‑ró ná kóo tu̱'a‑ró nátu̱'un mozo káinda̱tu‑i jito'o̱‑i ja̱ ncháa̱‑de kua'a̱n‑de viko tánda'a, náva̱'a nú ni̱ nchaa̱‑de te ka'a̱n‑de, te kuña‑ni‑i ve'e jíná'an‑i.
\v 37 Xáán ndatu̱ kuu mozo‑ún te nú ni̱ nchaa̱ jito'o̱‑i nuu̱‑í, te jiní‑de ja̱ kándi̱to‑i. Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró ja̱ kú'ni̱‑de chi̱i‑de, te nuu̱ mesa súngo̱o‑de mozo‑de te kani‑de ko'o̱‑í jíná'an‑i.
\v 38 Te va̱sa ná cháa̱‑de ñúú, xí va̱sa ná ncháa̱‑de ja̱'a ñu̱u, te nú suni súan kuní‑de sá'a mozo‑ún ja̱ kándi̱to‑i, ndatu̱ xaa̱n kéndo̱o mozo‑ún jíná'an‑i.
\v 39 Ko ná júku̱'un ini̱‑ro̱ tú'un yá'a. Táa̱ ini̱ ve̱'e, nú ní jiní‑de na̱ hora kúu ja̱ kíi ñakui̱'ná te kundito‑de núú, te ma̱ kuá'a‑de tu̱'un sákuí'ná vé'e‑de núú.
\v 40 Te róó suni súan koo tu̱'a‑ró, chi̱ máá kɨvɨ́ já tú na̱ún kájani ini̱‑ro̱, te nchaa̱‑ni máá Sé'e cha̱a, áchí‑ya̱ jíín‑de.
\v 41 Yúan‑na te Pedro, ni̱ jika̱ tu̱'ún‑de‑ya̱: Táta̱, máá‑ni nuu̱ náá jíná'an‑ná ká'a̱n‑ní tu̱'un yá'a náún, xí súni ká'a̱n‑ní nuu̱ táká‑ga̱ cha̱a yá'a, áchí‑de.
\v 42 Te ni̱ ka'a̱n máá Jíto'o̱‑yo̱: Ndéja̱ kúu ɨɨn mozo ndito xini̱ já skíkuu va̱'a, chi̱ máá jíto'o̱, kani‑de mozo‑ún ná kóto‑i se̱'e‑de náva̱'a skée‑í su̱chí‑ún máá hora ja̱ xíin tíñu.
\v 43 Xáán ndatu̱ kuu mozo‑ún, te nú ni̱ nchaa̱ jito'o̱‑i te nani'i̱n‑dé‑i sá'a‑i súan.
\v 44 Ja̱ndáa̱ ká'a̱n‑ri̱, ja̱ káni‑de mozo‑ún ja̱ kóto‑i ta̱ká ndatíñu‑de.
\v 45 Ko nú mozo‑ún jáni ini̱‑i: Kúkuéé‑ga̱ te nchaa̱ jito'o̱‑ri̱, achi̱ máá‑i. Te kejá'á‑i stují‑í mozo máá‑i jíín ñá'an kájatíñu nuu̱‑í. Te kee‑í te ko'o‑i, te naji̱ni‑i.
\v 46 Te mozo‑ún, nú ni̱ nchaa̱ jito'o̱‑i kɨvɨ̱ já tú ndátu‑i jíín hora ja̱ tú jiní‑i, te xndó'o‑de‑i, te kiñi'in‑de‑i onde̱ jíín cháa tú káskíkuu va̱'a.
\v 47 Chi̱ nú ndé mozo a jiní‑i tiñu ndasa játa'a̱n ini̱ jito'o̱‑i, te nú tú ní sátu̱'a‑i, ni tú ní skíkuu‑i tiñu kuní máá‑de, ndo'o xaa̱n‑í yunu xíi.
\v 48 Ko nú ndé mozo tú jiní‑i tiñu ndasa játa'a̱n ini̱ jito'o̱‑i, te nú sá'a‑i tiñu ñáá ja̱ xndó'o‑de‑i núú, yúan‑na te yaku̱‑ni yunu xíi ndo'o‑i. Chi̱ nú kua̱'a‑ya̱ kuá'a̱ ndátíñu nuu̱ ɨ́ɨn cha̱a, te nandaka̱n kua'a̱‑yá nuu̱‑dé. Te suni súan nú kua'a̱ ndátíñu kátatu̱‑i ɨɨn cha̱a, ví'í‑gá nandaka̱n‑i nuu̱‑dé.
\s1 Sɨkɨ̱ tú'un sásɨ́ɨn máá jíná'an
\p 
\v 49 Ni̱ kii‑ri̱ ja̱ chíndee‑ri̱ ñu'u̱n ini̱ ñu̱yɨ́vɨ yá'a. Te xaa̱n kuní‑ri̱ ja̱ ná kóo.
\v 50 Te íó ɨɨn tu̱ndó'o ja̱ kuánducha‑rí jíín, ko xaa̱n ndukuí'a̱ ini̱‑ri̱ onde̱ ná skíkuu‑ri̱.
\v 51 Kájani ini̱‑ro̱ já ní chaa̱‑ri̱ ja̱ kóo ná'ín‑ni ini̱ ñu̱yɨ́vɨ náún. Ká'a̱n‑ri̱ jíín‑ró ja̱ ná túu, chi̱ sua ndonda sɨkɨ̱ tá'an.
\v 52 Chi̱ ɨɨn‑ni ve'e koo u'u̱n ña̱yɨvɨ, te sásɨ́ɨn máá jíná'an. Uni̱ ndonda sɨkɨ̱ úu̱, te uu̱ ndonda sɨkɨ̱ uní.
\v 53 Chi̱ ndonda sɨkɨ̱ tá'an, táa̱ sɨkɨ̱ sé'e‑de, te se̱'e sɨkɨ̱ táa̱‑i. Náa̱ sɨkɨ̱ sésɨ́'ɨ́‑ña, te se̱sɨ́'ɨ́ sɨkɨ̱ náa̱‑i. Náchi̱só sɨkɨ̱ séja̱nú‑ña, te seja̱nú sɨkɨ́ náchi̱só‑i. Achí‑ya̱.
\s1 Sɨkɨ̱ tuní skuá'a‑yó
\p 
\v 54 Te suni ni̱ ka'a̱n‑ya̱ jíín ñáyɨvɨ kuá'a̱‑ún: Nú ni̱ kajini̱‑ro̱ nána viko̱ íchi nú kée ndika̱ndii, te káka'a̱n‑ro̱: Kuun sau̱, áchí‑ro̱, te kúu súan.
\v 55 Te nú ni̱ nana nuu tachi̱, te káka'a̱n‑ro̱: Nandii, áchí‑ro̱, te súan kúu.
\v 56 Cha̱a uu̱ xini̱ kákuu‑ró. A kájini̱‑ro̱ na̱ún kuní ka'a̱n tuni̱ ini̱ ñu̱yɨ́vɨ jíín ándɨ́vɨ́, te naja̱ tú kánakuni̱‑ro̱ kɨvɨ́ yá'a núsáá.
\v 57 Te naja̱ tú kátava máá‑ró cuenta ndé ja̱ kúu tiñu va̱'a núsáá.
\v 58 Ko nú kua'a̱n‑ro̱ núu̱ juez jíín cháa jíto u'u̱ róó, te yachi̱ ná ndátu̱'ún vá'a‑ró jíín‑de nini ká'i̱in‑ró íchi jíín‑de. Chi̱ nú túu, te kua̱'a‑de róó nuu̱ juez, te juez kua̱'a‑de róó nuu̱ policía, te policía chindee‑de róó veka̱a.
\v 59 Te ká'a̱n‑ri̱ jíín‑ró, ja̱ má kénda kutɨ‑ro yúan onde̱ nú tú chunáa‑ro táká centavo, áchí‑ya̱ jíín‑de.
\c 13
\s1 Kánúú nákani ini̱‑yo̱
\p 
\v 1 Te suni kɨvɨ̱‑ún ká'i̱in yaku̱ cha̱a jíín‑yá yúan. Te ni̱ ka̱jani‑de tu̱'un nuu̱‑yá ndasa ni̱ kata'a̱n cha̱a ñuu̱ Galilea. Chi̱ Pilato, ni̱ sáká núu‑de nɨñi̱ cháa‑ún jíín nɨñí kɨ́tɨ já kásoko̱‑í nuu̱ Dios.
\v 2 Te ni̱ ka'a̱n Jesús: Cha̱a ñuu̱ Galilea yúan, ja̱ súan kándo'o‑de tu̱ndó'o‑ún, te á ni̱ i̱o xaa̱n kuáchi‑de vásá táká‑ga̱ cha̱a ñuu̱ Galilea, kájani ini̱‑ro̱ náún.
\v 3 Ná kástu̱'ún‑rí nuu̱‑ro̱ já túu, chi̱ suni súan naa‑ro jíná'an‑ró nú tú nakani ini̱‑ro̱.
\v 4 Te suni xia'u̱n uni̱ cha̱a ja̱ sɨkɨ́ máá‑de ni̱ ndua̱ torre ñuu̱ Siloé te ni̱ kaji'i̱‑de, á ni̱ ka̱sá'a‑de kua̱chi xaa̱n‑gá vásá táká‑ga̱ cha̱a káxiu̱kú ñúu̱ Jerusalén, kájani ini̱‑ro̱ náún.
\v 5 Ná kástu̱'ún‑rí nuu̱‑ro̱ já túu. Chi̱ suni súan naa‑ro jíná'an‑ró nú tú nakani ini̱‑ro̱. Achí‑ya̱.
\s1 Tu̱'un mérkexe̱
\p 
\v 6 Te ni̱ ka'a̱n‑ya̱ tú'un yátá yá'a: Ɨɨn cha̱a ñáva̱'a‑de ɨɨn mérkexe̱ ja̱ ní nachu'un‑de ma̱'ñú itú uva‑de. Te ni̱ jaa̱‑de ndúkú‑de nde'e̱ xiní. Te tú ní ní'i̱n kútɨ‑dé.
\v 7 Te ni̱ kachi̱‑de jíín mozo ndíto itu̱ uva‑ún: Vina te a íó uni̱ kuia̱ kíndúkú‑rí nde'e̱ xiní mérkexe̱ yá'a, te tú ní'i̱n kútɨ‑rí. Xɨtɨ ná kí'i̱n. Naja̱ kándii̱ satéñu nuu̱ ñú'un yá'a. Achí‑de.
\v 8 Yúan‑na te ni̱ ka'a̱n máá mozo: Táta̱, skéndo̱o‑ní, ná kúndii̱ va̱sté ɨngá kuia̱ yá'a, onde̱ ná sáyúchí‑ná ja'a̱ te chu'un‑ná ja̱'an te nándéó.
\v 9 Te nú ni̱ ja̱'a nde'e̱, te íó va̱'a. Te nú túu, te vásá xɨ́tɨ‑ní áchí‑i. Achí‑ya̱.
\s1 Tu̱'un ña'an jíka tɨ́'ɨ́
\p 
\v 10 Te ɨɨn kɨvɨ̱ ndéta̱tú ni̱ stá'a̱n‑ya̱ tú'un ini̱ ɨɨn ve'e sinagoga.
\v 11 Te ni̱ kenda ɨɨn ña'an tá'a̱n‑ña ɨ́ɨn tachi̱ kíni ja̱ ní kuu xia'u̱n uni̱ kuia̱ kú'u̱‑ña. Te ni̱ ka̱í‑ña, jíka tɨ́'ɨ́‑ña, chi̱ tú kúu kutɨ ndúko̱o tuun‑ña.
\v 12 Te ni̱ jini̱ Jesús nuu̱‑ñá. Te ni̱ kana‑ya̱ xiní‑ñá. Te ni̱ kachi̱‑ya̱ jíín‑ña: Nána̱, vina te a ni̱ nduva̱'a‑ní ja̱ kú'u̱‑ní, áchí‑ya̱.
\v 13 Te ni̱ chaa‑ya̱ ndá'a‑yá sɨkɨ̱‑ñá. Te ni̱ ndúko̱o tuun‑ni‑ña, te ni̱ na̱kana jaa‑ña Dios.
\v 14 Te cha̱a kúñá'nu ini̱ ve̱'e sinagoga, ni̱ kiti̱ ini̱‑de nuu̱ Jesús ja̱ ní nasáva̱'a‑ya̱‑ñá kɨvɨ̱ ndéta̱tú. Te ni̱ ka'a̱n‑de jíín ñáyɨvɨ kuá'a̱‑ún: Iñu̱ kɨvɨ̱ íó sátiñu‑ró, te kɨvɨ̱‑ún cha̱koyo‑ró kúu tana̱‑ro̱. Ko kɨvɨ̱ ndéta̱tú yá'a, chi ma̱ kúu, áchí‑de.
\v 15 Yúan‑na te ni̱ ka'a̱n máá Jíto'o̱‑yo̱ jíín‑de; Cha̱a uu̱ xini̱ kákuu‑ró. Ja̱ kúu kɨvɨ̱ ndéta̱tú te tú kándájí‑ró xndɨkɨ̱‑ro̱ xí burro‑ró núu̱ káyee‑tɨ́‑ún, te tú káskó'o‑ró‑tɨ́ nducha náún.
\v 16 Te se̱sɨ́'ɨ́ Abraham yá'a, nú'ni̱‑ña xiá'u̱n uni̱ kuia̱ ni̱ sá'a kui'na̱. Te tú íó va̱'a ndájí‑rí‑ña kɨvɨ́ ndéta̱tú náún, áchi‑ya̱.
\v 17 Te súan ni̱ ka'a̱n‑ya̱ tú'un yá'a. Te ni̱ ka̱kuka nuu̱ táká cha̱a kájito u'u̱‑ya̱‑ún. Ko ta̱ká ña̱yɨvɨ, ni̱ ka̱kusɨɨ̱ iní‑i jíín táká tiñu ñá'nu ni̱ sá'a‑ya̱.
\s1 Tu̱'un ndɨkɨn yuá mostaza
\p 
\v 18 Te ni̱ ka'a̱n‑ya̱: Ndasa kuní koo ñuu̱ nuu̱ tá'ú Dios tiñu. Te na̱ jíín skétá'an‑ri̱.
\v 19 Kúu nátu̱'un ndɨkɨn yuá mostaza ja̱ ní ki'in ɨɨn cha̱a te ni̱ chaa‑de nuu̱ itú‑de. Te ni̱ ja'nu. Te ni̱ kuu ɨɨn yunu ká'nu. Te tɨsaa̱ andɨ́vɨ́ ni̱ ka̱sá'a‑tɨ̱ taká‑tɨ̱ chíi nda'a‑ún. Achí‑ya̱.
\s1 Tu̱'un yátá yújan íá
\p 
\v 20 Te ni̱ ka'a̱n tuku‑ya̱: Na̱ún tu̱'un yátá skétá'an‑ri̱ jíín ñúu̱ nuu̱ tá'ú Dios tiñu.
\v 21 Kúu nátu̱'un yujan íá já ní ki'in ɨɨn ña'an. Te ni̱ chisa̱'í‑ña chíi uni̱ ti̱yii yúchi onde̱ ni̱ ndɨ'ɨ ni̱ kuu íá ní sá'a. Achí‑ya̱.
\s1 Sɨkɨ̱ íchi yúxé'é túu̱
\p 
\v 22 Te nini kua'a̱n‑ya̱ íchi ñúu̱ Jerusalén, te ni̱ jika kuu‑ya̱ táká ñuu̱ jíín táká rancho, ni̱ stá'a̱n‑ya̱ tú'un.
\v 23 Te ni̱ ka'a̱n ɨɨn cha̱a jíín‑yá: Táta̱, yaku̱‑ni cha̱a ka̱ku‑de náún, áchí‑de. Te ni̱ kachi̱‑ya̱ jíín‑de:
\v 24 Ndúkú ndéé téyíí‑ró kɨ́vɨ koyo‑ró íchi yúxé'é túu̱, chi̱ ká'a̱n‑ri̱ jíín‑ró ja̱ kuá'a̱ ñáyɨvɨ ndúkú ndéé‑i kɨ́vɨ‑i, ko ma̱ kúu kɨ̱vɨ koyo‑i.
\v 25 Chi̱ táa̱ ini̱ ve̱'e, ndukuiñi̱‑de, te kasu̱‑de yuxé'é. Te ichi yatá vé'e kuiñi‑ró. Te skáján‑ró vitú yúxé'é te ka'a̱n‑ro̱: Táta̱, táta̱, kuña‑ní ve'e, ná kɨ́vɨ koyo‑ná, achi̱‑ro̱. Te kachi̱‑de kuni‑ró: Aa̱, tú jiní‑ri̱ ná ñuu̱ va̱ikoyo‑ró, achi̱‑de.
\v 26 Yúan‑na te kejá'á‑ró ká'a̱n‑ro̱ jíín‑de: Ni̱ ka̱yee‑ná staa̱ jíín‑ní, te ini̱ ya̱'ya ñuu̱‑ná ni̱ stá'a̱n‑ní tu̱'un nuu̱‑ná, achi̱‑ro̱.
\v 27 Te máá‑de kachi̱‑de kuni‑ró: Achí‑ri̱ jíín‑ró ja̱ tú jiní‑ri̱ róó ndé ñuu̱ va̱ikoyo‑ró. Kuxio jíná'an‑ró chi ña̱yɨvɨ kásá'a tiñu ñáá kákuu‑ró. Achi̱‑de.
\v 28 Te yúan nde'e̱‑ro̱, te nakaji‑ro ñíi yú'u‑ro kuíñi‑ró. Te kuni̱‑ro̱ núu̱ Abraham jíín núu̱ Isaac jíín núu̱ Jacob jíín núu̱ táká‑ga̱ cha̱a ni̱ ka̱jani tu̱'un Dios kuiñi‑de ini̱ ve̱'e Dios. Te róó kuxio‑ró sásɨ́ɨn‑ya̱ róó.
\v 29 Te kikoyo‑i ichi núu̱ kána ndika̱ndii jíín íchi núu̱ kée ndika̱ndii, ichi norte jíín íchi sur, te jungo̱o‑i ini̱ ñuu̱ nuu̱ tá'ú Dios tiñu.
\v 30 Kuni so̱'o va̱'a‑ró: Sava cha̱a sandɨ̱'ɨ́‑na̱, ndunúú‑de. Te sava cha̱a kúnúú, nduu‑de sandɨ̱'ɨ́‑na̱. Achí‑ya̱.
\s1 Tu̱'un Herodes
\p 
\v 31 Te kɨvɨ̱‑ún ni̱ ja̱koyo yaku̱ tá'an cha̱a fariseo, te ká'a̱n‑de jíín‑yá: Kuxio‑ní yá'a te kenda‑ní ki'i̱n‑ní, chi cha̱a Herodes ka'ni‑dé níí kuní‑de, áchí‑de.
\v 32 Te ni̱ kachi̱‑ya̱ jíín‑de: Kuá'án, te kastu̱'ún‑ró núu̱ máá ñúkuii jia̱n: Vina chi̱ kíñi'in‑ri̱ tachi̱ kíni kája'a̱n. Te sá'a‑ri̱ tana̱ vína jíín yúchaa̱n. Te onde̱ nuu̱ uní kɨvɨ̱ te síjínu‑ri̱ tiñu‑ri̱.
\v 33 Ko kánúú xáa̱n já vína jíín yúchaa̱n jíín ísá te kaka‑ri̱ ki'i̱n‑ri̱, chi ma̱ kúu ja̱ ɨ́ɨn cha̱a jáni tu̱'un kenda‑de yata̱ ñúu̱ Jerusalén, te kuu̱‑de. Achi̱‑ro̱.
\s1 Sɨkɨ̱ já ní kukuí'a̱ ini̱‑ya̱ jíín ñúu̱ Jerusalén
\p 
\v 34 Jerusalén, Jerusalén, ni̱ ka̱ja'ni‑ro cháa kájani tu̱'un Dios, te ni̱ kaja̱'a‑ró yúu̱ xiní cháa ni̱ tájí‑yá va̱i nuu̱‑ro̱. Ió kua'a̱ vuelta ni̱ kuni̱‑ri̱ nastútú‑rí se̱'e‑ró, nátu̱'un chukí ja̱ nástútú‑tɨ́ tɨrɨ̱ɨ‑tɨ̱ chíi ndiji̱n‑tɨ́, ko tú ní kákuni̱‑ro̱.
\v 35 Vina te kéndo̱o víchí vé'e‑ró núsáá. Ko ká'a̱n‑ri̱ jíín‑ró já má kuní kutɨ‑gá‑ro̱ núu̱‑rí jíná'an‑ró onde̱ jaa̱ ɨɨn kɨvɨ̱ ká'a̱n‑ro̱: Ná nákana jaa‑yó‑yá chi̱ ndíso‑ya̱ tíñu máá Tatá Dios, achi̱‑ro̱. Achí‑ya̱.
\c 14
\s1 Ja̱ ní nasáva̱'a‑ya̱ ɨ́ɨn cha̱a kú'u̱ kɨvɨ̱ ndéta̱tú
\p 
\v 1 Te ɨɨn kɨvɨ̱ ndéta̱tú ni̱ kɨ̱vɨ‑ya̱ iní ve̱'e ɨɨn cha̱a kúñá'nu nuu cháa fariseo jíná'an‑de ja̱ kée‑yá staa̱ jíín‑de. Te kájito yu'u‑dé‑ya̱.
\v 2 Te ni̱ kenda ɨɨn cha̱a kú'u̱‑de kue'e̱ kuiñi, kándii̱‑de nuu̱‑yá.
\v 3 Te ni̱ ka'a̱n Jesús jíín cháa kákuu maestro ley jíín cháa fariseo: Á kuu sá'a‑ri̱ tana̱ kɨvɨ́ ndéta̱tú xí túu, áchí‑ya̱.
\v 4 Ko máá‑de, tú ní káka'a̱n kutɨ‑dé. Yúan‑na te ni̱ ki'in‑ya̱ cháa ñú'un kuiñi‑ún. Te ni̱ nasáva̱'a‑ya̱‑dé. Te ni̱ natájí‑yá‑de kua̱no'on‑dé.
\v 5 Te ni̱ ka'a̱n‑ya̱ jíín‑ún: Te nú burro máá‑ró xí xndɨkɨ̱‑ro̱ júngava‑tɨ̱ iní ɨɨn sókó, te tú natava‑ro‑tɨ́ va̱sa kɨvɨ̱ ndéta̱tú kúu náún. Achí‑ya̱.
\v 6 Te tú ní kákuu xndíó káni‑de ni ɨɨn tu̱'un nuu̱‑yá ja̱ súan ni̱ ka'a̱n‑ya̱ jíín‑de.
\s1 Sɨkɨ̱ ñáyɨvɨ sáñá'nu‑i máá‑i
\p 
\v 7 Te ni̱ jini̱‑ya̱ já kándúkú‑de jungo̱o jíñú'ún‑de silla xini̱ mesa. Te ni̱ ka'a̱n‑ya̱ ɨ́ɨn tu̱'un yátá jíín cháa ni̱ kataka̱ yúan.
\v 8 Nú ni̱ kana ɨɨn cha̱a xini̱‑ro̱ já kí'i̱n‑ro̱ ɨ́ɨn viko tánda'a, te ma̱ júngo̱o jíñú'ún‑ró silla xini̱ mesa. Chi̱ nú súan, sanaa te a ni̱ kana‑de xini̱ ɨ́ɨn cha̱a kúñá'nu‑ga̱ vásá róó.
\v 9 Te chaa̱ cha̱a ni̱ kana xini̱‑ro̱‑ún jíín‑de. Te ka'a̱n‑de jíín‑ró: Kuxio, ná kúnchaa̱ cha̱a yá'a jia̱n. Yúan‑na te kúka nuu̱‑ro̱ kí'i̱n‑ro̱ ondé sandɨ̱'ɨ́‑na̱ kunchaa̱‑ro̱.
\v 10 Ko nú ni̱ kana ɨɨn cha̱a xini̱‑ro̱, kuá'án te jungo̱o‑ró ondé sandɨ̱'ɨ́‑na̱. Chi̱ nú jaa̱ cha̱a ni̱ kana róó yúan te kachi̱‑de kuni‑ró: Amigo, nuu̱ silla jíñú'ún yá'a jungo̱o‑ró, achi̱‑de. Yúan‑na te nduñá'nu‑ró jíto nuu̱ cháa káxiu̱kú ká'nu jíín‑ró.
\v 11 Chi ta̱ká cha̱a sáñá'nu‑de máá‑de, ndusúchí‑de. Te ta̱ká cha̱a sásúchí‑de máá‑de, nduñá'nu‑de. Achí‑ya̱.
\v 12 Te suni ni̱ ka'a̱n‑ya̱ jíín cháa ni̱ kana xini̱‑yá‑ún: Nú sá'a‑ró sámá xí xíni, ma̱ kána‑ró xiní cháa kákuu amigo‑ro̱, ni xini̱ ñaní‑ro̱, ni xini̱ tá'an‑ró, ni xini̱ cháa kúká. Chi̱ nú súan te suni máá‑de nakana‑de xini̱‑ro̱. Te ni̱ kuu ja̱ ní nani'i̱n‑ro̱ tá'u̱‑ro̱.
\v 13 Ko nú sá'a‑ró gasto, te kana‑ró xiní cháa ndá'ú, cha̱a tɨ́kú'lu, cha̱a tá'nú, jíín xiní cháa kuáá.
\v 14 Te xáán ndatu̱ kendo̱o‑ró nú súan, chi̱ tú na̱ún nákua̱'a‑de nuu̱‑ro̱. Ko ni'i̱n‑ro̱ yá'u‑ró kɨvɨ́ náchaku̱ ta̱ká cha̱a ndaa̱, áchí‑ya̱.
\s1 Ɨɨn xíni ká'nu
\p 
\v 15 Te ɨɨn cha̱a yée stáa̱ jíín‑yá, ni̱ jini so̱'o‑de tu̱'un yá'a. Te ni̱ kachi̱‑de jíín‑yá: Xáán ndatu̱ kuu cha̱a ja̱ kée‑dé staa̱ onde̱ ini̱ ñuu̱ nuu̱ tá'ú Dios tiñu. Achí‑de.
\v 16 Yúan‑na te ni̱ kachi̱‑ya̱ jíín‑de: Ɨɨn cha̱a ni̱ sá'a‑de ɨɨn xíni ká'nu, te ni̱ kana‑de xini̱ kuá'a ñáyɨvɨ.
\v 17 Te nuu̱ ní jaa̱ hora ja̱ kúxíni‑de‑ún, te ni̱ tájí‑de mozo‑de kua̱kachi̱ nuu̱ já kée stáa̱ xíni‑ún: Ña'a̱n‑ní jíná'an‑ní. Chi̱ a ni̱ ndɨ'ɨ íó tu̱'a. Achí.
\v 18 Te ɨɨn‑ni ni̱ ka̱sájá'a̱ ini̱ ndɨ'ɨ‑de. Te cha̱a ɨɨn ni̱ kachi̱‑de jíín mozo. Ni̱ jaan‑ri̱ ɨɨn ñu'un te kánúú kínde̱'é‑rí. Te ná kúña ká'nu ini̱‑de nuu̱‑rí, chi̱ ma̱ jáa̱‑ri̱. Achí‑de.
\v 19 Te ni̱ ka'a̱n ɨnga̱‑de: Ni̱ jaan‑ri̱ u'u̱n yunta xndɨkɨ̱ te kikoto nchaa̱‑ri̱‑tɨ̱. Ná kúña ká'nu ini̱‑de nuu̱‑rí, chi ma̱ jáa̱‑ri̱. Achí‑de.
\v 20 Te ni̱ ka'a̱n tuku ɨnga̱‑de: Sáá ní ta̱nda'a‑rí. Te ja̱ yúán má kúu jaa̱‑ri̱. Achí‑de.
\v 21 Te kua̱no'on mozo‑ún ni̱ kastu̱'ún‑de nuu̱ jíto'o̱‑de. Yúan‑na te máá táa̱ ini̱ ve̱'e‑ún, ni̱ kiti̱ ini̱‑de. Te ni̱ kachi̱‑de jíín mozo‑de: Kuá'án yachi̱ nɨ́ɨ́ núyá'u jíín táká ya̱'ya, te kana‑ró xiní cháa ndá'ú, cha̱a tɨ́kú'lu, cha̱a tá'nú, jíín cháa kuáá, ná kíkoyo‑de. Achí‑de.
\v 22 Te ni̱ kachi̱ mozo‑ún: Táta̱, a ni̱ kuu nátu̱'un ká'a̱n‑ní ko núña‑ga̱ lugar. Achí‑i.
\v 23 Te jito'o̱‑ún ni̱ ka'a̱n‑de jíín mozo‑de: Kuá'án ta̱ká ichi jíín táká rancho te stétuu‑ró ñáyɨvɨ‑ún ná kíi‑i yá'a, náva̱'a ná chítú iní ve̱'e‑ri̱.
\v 24 Chi̱ ká'a̱n‑ri̱ jíín‑ró já ní ɨɨn cha̱a ni̱ jaka̱na‑ró‑ún, ma̱ kúxíni kutɨ‑dé ve'e‑ri̱, áchí‑de. Achí‑ya̱.
\s1 Sɨkɨ̱ cháa kuní‑de kundiki̱n‑de‑ya̱
\p 
\v 25 Te kája'a̱n kua'a̱ xáa̱n ñáyɨvɨ jíín Jesús. Te ni̱ ka'a̱n‑ya̱ jíín‑i:
\v 26 Nú ndé cha̱a kii‑de nuu̱‑rí, te nú chíñú'ún‑de táa̱‑de, náa̱‑de, ñasɨ́'ɨ́‑de, se̱'e‑de, ñani̱‑de, kua̱'a‑de, xí ondé jíín máá‑de, ma̱ kúu kuu‑de cha̱a skuá'a jíín‑rí.
\v 27 Te cha̱a tú ndóyo‑de jíín túndó'o kii sɨkɨ̱‑dé, te kundiki̱n‑de ruu̱ kii‑de, ma̱ kúu kuu‑de cha̱a skuá'a jíín‑rí.
\v 28 Chi̱ nú ndé róó kuní‑ro̱ káni‑ró ɨ́ɨn ve'e, á tú xna'a̱n‑ga̱ jungo̱o‑ró te tava‑ro cuenta na̱saa kuu gasto, te kuni̱‑ro̱ nú va̱tu‑ni kanda‑ró jínu xí túu.
\v 29 Chi̱ nú túu, te nú a ni̱ jani‑ró já'a̱, te ma̱ kánda xu̱'ún‑ró síjínu‑ró. Yúan‑na te ta̱ká ña̱yɨvɨ kájini̱ nuu̱ vé'e tɨ́kú'lu‑ró‑ún, sákátá‑i nuu̱‑ro̱.
\v 30 Te ka'a̱n‑i: Cha̱a yá'a, ni̱ kejá'á‑de jáni‑de ɨɨn ve'e, te tú ní kánda‑de síjínu‑de, achi̱‑i.
\v 31 Xí nú ndé rey kuní‑de ki'i̱n‑de kua̱tá'an‑de jíín ɨngá rey, á tú xna'a̱n‑ga̱ jungo̱o‑de te nakani ini̱‑de te nú va̱tu‑ni kuu jíín uxí mil soldado kua̱tá'an‑de jíín ɨngá rey ja̱ vái sɨkɨ̱‑dé jíín okó mil soldado.
\v 32 Chi̱ nú túu, te nini jíká‑ga̱ va̱i ɨnga̱ rey, te tájí‑de ɨɨn cha̱a ki'i̱n ka'a̱n nda̱'ú jíín‑de ja̱ ná júkuiñi̱.
\v 33 Te suni súan nú ndé róó tú síjíta‑ró táká ndatíñu ñáva̱'a‑ró, ma̱ kúu kuu‑ró cháa skuá'a jíín‑rí núsáá.
\s1 Tu̱'un yátá sɨkɨ́ ñíi̱
\p 
\v 34 Va̱'a íó ñii̱, ko nú onde̱ ñii̱‑ún ná náa xikó, te ndasa ndu'u'a̱ núsáá.
\v 35 Ma̱ kuátíñu kutɨ, ni ja̱ kúu nuu̱ ñú'un já ndúu ja̱'an, chi̱ kacha̱‑de ki'i̱n. Cha̱a íó so̱'o kuni ná'ín, ná kúni so̱'o‑de. Achí‑ya̱.
\c 15
\s1 Sɨkɨ̱ rɨ́ɨ̱, kɨtɨ ní sa̱na
\p 
\v 1 Te ta̱ká cha̱a xíní jíín cháa ká'i̱o kua̱chi, ni̱ ja̱koyo‑de nuu̱ Jesús náva̱'a kuni so̱'o‑de tu̱'un ká'a̱n‑ya̱.
\v 2 Te cha̱a fariseo jíín cháa káchaa tutu̱, ni̱ kaka'a̱n‑de: Cha̱a yá'a, játá'ú‑de cha̱a ká'i̱o kua̱chi te yée‑dé staa̱ jíín cháa‑ún, áchí‑de.
\v 3 Te máá Jesús, ni̱ ka'a̱n‑ya̱ tú'un yátá yá'a jíín‑de:
\v 4 Ndé ɨɨn róó nú ñáva̱'a‑ró ɨ́ɨn ciento rɨɨ́, te skuíta‑ró ɨ́ɨn‑tɨ̱, á tú skéndo̱o‑ró kúu̱n xíko xia'u̱n kuu̱n‑gá‑tɨ̱ ondé nuu̱ ñú'un té'é, te kina̱ndúkú‑ró kɨ́tɨ ní naa‑ún onde̱ nani'i̱n‑ro̱‑tɨ́ xí túu.
\v 5 Te nú ni̱ nani'i̱n‑ro̱‑tɨ́, kúsɨɨ̱ iní‑ro̱ xndée‑ró‑tɨ́ nuu̱ chó'o̱‑ro̱.
\v 6 Te nú ni̱ najaa̱‑ro̱ vé'e te nastútú‑ró cháa kákuu amigo‑ro̱ jíín tá'an‑ró, te kachi̱‑ro̱ kúni cha̱a‑ún: Ná kúsɨɨ̱ iní‑yo̱ chi̱ ni̱ nani'i̱n‑rí rɨɨ̱‑ri̱‑ri̱ kɨtɨ á ni̱ naa núú. Achi̱‑ro̱.
\v 7 Ká'a̱n‑ri̱ jíín‑ró, ja̱ súan kusɨɨ̱‑gá ini̱‑ya̱ ondé andɨ́vɨ́ jíín ɨ́ɨn cha̱a íó kua̱chi nú nakani ini̱‑de, vásá jíín kúu̱n xíko xia'u̱n kuu̱n‑gá cha̱a va̱'a ja̱ tú kájinu ñú'ún‑de tu̱'un nakani ini̱.
\s1 Tu̱'un ña'an ní skuíta‑ña ɨ́ɨn peso
\p 
\v 8 Xí nú ɨɨn ñasɨ́'ɨ́ ñáva̱'a‑ña uxí peso, te skuíta‑ña ɨ́ɨn peso, á tú chi'i‑ña yítɨ te nastáa‑ña vé'e, te nandúkú víi‑ñá onde̱ nani'i̱n‑ñá.
\v 9 Te nú ni̱ nani'i̱n‑ñá, te kána‑ña xiní tá'an‑ña jíín amiga‑ña, te kachi̱‑ña kúni‑i: Ná kúsɨɨ̱ iní‑yo̱, chi ni̱ nani'i̱n‑rí peso‑ri̱ ja̱ ní skuíta‑ri̱‑ún núú. Achí‑ña.
\v 10 Ká'a̱n‑ri̱ jíín‑ró, ja̱ súan kúsɨɨ̱‑gá ini̱ ta̱ká ndajá'a̱ Dios jíín ɨ́ɨn cha̱a íó kua̱chi nú nakani ini̱‑de.
\s1 Tu̱'un su̱chí ní naa, te ni̱ ndenda‑i
\p 
\v 11 Te ni̱ ka'a̱n‑ga̱‑ya̱: Ɨɨn cha̱a ni̱ i̱o uu̱ se̱'e yíí‑de.
\v 12 Te su̱chí súchí‑ún ni̱ ka'a̱n‑i jíín táa̱‑i: Táa̱, kua̱'a‑ní sava ñu'un núu̱‑ná ja̱ kúu ta'u̱‑ná, áchí‑i. Te ni̱ teta'a̱n‑de ta'u̱‑í nuu̱ ndéndúú‑i.
\v 13 Te ni̱ kuu yaku̱ kɨvɨ̱, te su̱chí súchí‑ún ni̱ stútú ndɨ́'ɨ‑i ndatíñu‑i. Te ni̱ kee‑i kua'a̱n jíká‑i ɨnga̱ ñuu̱. Te yúan ni̱ xnáa‑í ta'u̱‑í, chi ni̱ janu̱ ndɨva̱'a‑i.
\v 14 Súan ni̱ ndɨ'ɨ ni̱ janu̱ sáni‑i, te vásá ní chaa̱ ɨɨn tama̱ xáa̱n iní ñuu̱‑ún, te ni̱ kejá'á nándɨ'ɨ‑i.
\v 15 Te ni̱ kee‑i kua'a̱n‑i, te ni̱ jaa̱‑i nuu̱ ɨ́ɨn cha̱a ñuu̱‑ún. Te cha̱a‑ún ni̱ tájí‑de‑i kua'a̱n‑i onde̱ rancho‑de ja̱ yúan koto‑i kɨnɨ̱‑de.
\v 16 Te kuní‑i taan tɨ́ɨ́‑i chi̱i‑i jíín tíxi̱ko káyee kɨnɨ́‑ún. Chi̱ tú kutɨ ní ɨɨn na̱ún ní já'a nuu̱‑í.
\v 17 Yúan‑na te ni̱ jini̱ máá‑i. Te ni̱ ka'a̱n‑i: Ta̱ká mozo íó ini̱ ve̱'e táa̱‑ri̱, íó kua'a̱ stáa̱ káyee‑dé. Te ruu̱ jí'i̱‑ri̱ so̱ko yá'a.
\v 18 Ná ndúkuiñi̱‑ri̱ te ná nó'o̱n‑ri̱ nuu̱ táa̱‑ri̱. Te kachi̱‑ri̱ kuni‑de: Táa̱, a ni̱ sá'a‑ná kua̱chi nuu̱ Dios andɨ́vɨ́ jíín núu̱ máá‑ní.
\v 19 Tuká va̱'a cha̱a kúu‑ná ja̱ kúnání‑ná se̱'e‑ní. Ko kua̱'a‑ní tu̱'un kuu‑ná nátu̱'un ɨɨn mozo‑ní. Achi̱‑ri̱.
\v 20 Te ni̱ ndukuiñi̱‑i, te ni̱ kee‑i kua̱no'on‑í nuu̱ táa̱‑i. Te nini jíká‑gá va̱i‑i, te ni̱ jini̱ táa̱‑i nuu̱‑í. Te ni̱ kundá'ú ini̱‑de‑i. Te jínu‑de ni̱ jaa̱‑de. Te ni̱ nuu‑de suku̱n‑í, te ni̱ titú‑de‑i.
\v 21 Yúan‑na te ni̱ ka'a̱n‑i jíín‑de: Táa̱, a ni̱ sá'a‑ná kua̱chi nuu̱ Dios andɨ́vɨ́ jíín núu̱ máá‑ní. Tuká va̱'a cha̱a kúu‑ná ja̱ kúnání‑ná se̱'e‑ní. Achí‑i.
\v 22 Ko máá táa̱‑i, ni̱ ka'a̱n‑de jíín mozo‑de: Kuáki̱'in ɨɨn su'nu̱ vá'a‑ga te chu'un‑ró‑i. Te chu'un‑ró ɨ́ɨn xe'e ndá'a‑í. Te chi'i‑ró ndiján já'a̱‑í.
\v 23 Te suni kiki̱'in‑ró chélu xá'án. Te ka'ni‑ro‑tɨ́ ná kée‑yo. Chi̱ sá'a‑yó víko.
\v 24 Chi se̱'e yíí‑rí yá'a a ni̱ ji'i̱‑i núú, te ni̱ nachaku̱‑i. A ni̱ naa‑í núú, te ni̱ ndenda‑i, áchí‑de. Te ni̱ ka̱kejá'á‑de sá'a‑de viko.
\v 25 Te se̱'e yíí ñá'nu‑de, kándee‑i onde̱ rancho. Su̱chí‑ún va̱i ndii‑i. Te ni̱ nduyani‑i yata̱ vé'e. Te ni̱ jini so̱'o‑i tɨvɨ́ música te kájita já'á ñáyɨvɨ.
\v 26 Te ni̱ kana‑i xini̱ ɨ́ɨn mozo. Te ni̱ jika̱ tu̱'ún‑i mozo‑ún nú na̱ún viko íó.
\v 27 Te ni̱ kachi̱ mozo‑ún nuu̱‑í: Ni̱ nchaa̱ ñani̱‑ro̱ te táa̱‑ro̱, ni̱ ja'ni‑dé chelu xá'án, chi ni̱ ndenda va̱'a se̱'e yíí‑de, áchí mozo.
\v 28 Yúan‑na te ni̱ kiti̱ ini̱‑i, te tú ní kuní‑i ndɨ̱vɨ‑i, ko ni̱ kenda táa̱‑i. Te ni̱ ka'a̱n nda̱'ú‑de jíín‑i ná ndɨ́vɨ‑i.
\v 29 Ko máá‑i ni̱ ka'a̱n‑i: Ió kua'a̱ kuiá játíñu‑ná nuu̱‑ní, ni tú sáni̱'in kutɨ iní‑ná tiñu tá'ú‑ní. Te tú ní já'a‑ní va̱sté ɨ́ɨn lítú núu̱‑ná kee sɨ́ɨ̱‑ná jíín amigo‑na, áchí‑i.
\v 30 Ko ni̱ nchaa̱ se̱'e‑ní yá'a. Te va̱sa ni̱ xnáa ndɨ́'ɨ‑i ndatíñu‑ní jíín ñá'an téné, te ni̱ ja'ni‑ní chelu xá'án kée‑í, áchí‑i jíín táa̱‑i.
\v 31 Yúan‑na te ni̱ kachi̱‑de jíín‑i: Hijo, róó chi̱ nene̱ ncháá‑ro̱ jíín‑rí. Te ta̱ká ndatíñu máá‑rí suni ndatíñu máá‑ró kúu.
\v 32 Ko jínu ñú'ún sá'a‑yó víko te kusɨɨ̱ iní‑yo̱. Chi̱ ñani̱‑ro̱ yá'a, a ni̱ ji'i̱‑i núú, te ni̱ nachaku̱‑i. A ni̱ naa‑í núú, te ni̱ ndenda‑i, áchí‑de. Achí‑ya̱.
\c 16
\s1 Tu̱'un mandador xndá'ú
\p 
\v 1 Te suni ni̱ ka'a̱n‑ya̱ jíín cháa káskuá'a jíín‑yá: Ɨɨn cha̱a kúká, ni̱ ñava̱'a‑de ɨɨn mandador. Te cha̱a kúká‑ún ni̱ jini tu̱'un‑de ja̱ stɨ́vɨ́ mandador ndatíñu‑de.
\v 2 Te ni̱ kana‑de xini̱ cháa‑ún. Te ni̱ ka'a̱n‑de jíín‑de: Na̱ún tu̱'un kúu ja̱ jíni tu̱'un‑ri̱ sɨkɨ̱‑ro̱. Nakua̱'a cuenta tiñu ndíso‑ró, chi ma̱ kúu‑ga̱‑ro̱ mandador nuu̱‑rí. Achí‑de.
\v 3 Yúan‑na te cha̱a mandador, ni̱ ka'a̱n máá‑de: Ndasa sá'a‑ri̱. Chi̱ jito'o̱‑ri̱ jánchaa̱‑de tiñu mandador nuu̱‑rí. Nú kacha‑ri̱ ñu'un, ma̱ kánda‑ri̱. Nú kaka̱n‑ri̱ caridad, xaa̱n kúka nuu̱‑rí.
\v 4 A jiní‑ri̱ ndasa sá'a‑ri̱ náva̱'a kɨvɨ̱ kuánchaa̱‑de tiñu ndíso‑ri̱, te koo ña̱yɨvɨ maní jíín‑rí, te kuu kɨ̱vɨ‑ri̱ ini̱ ve̱'e‑i.
\v 5 Te ni̱ kana‑de xini̱ ná ɨɨn cha̱a káitau̱ nuu̱ jíto'o̱‑de. Te ni̱ kachi̱‑de jíín cháa‑ún: Na̱saa taú‑ro̱ núu̱ jíto'o̱‑ri̱, áchí‑de.
\v 6 Te máá cháa‑ún, ni̱ kachi̱‑de: Uni̱ mil litro aceite, áchí‑de. Te ni̱ kachi̱ mandador jíín‑de: Ki'in lista‑ro̱. Te jungo̱o yachi̱‑ro̱. Te chaa‑ró úu̱ mil‑na̱. Achí‑de.
\v 7 Yúan‑na te ni̱ ka'a̱n‑de jíín ɨngá cha̱a: Te róó, na̱saa taú‑ro̱, áchí‑de. Te cha̱a‑ún, ni̱ kachi̱‑de: Ɨɨn ciento ve'e trigo, áchí‑de. Te máá‑de ni̱ kachi̱‑de jíín cháa‑ún: Ki'in lista‑ro̱, te nachaa‑ró kúu̱n xíko‑ni, áchí‑de.
\v 8 Te jito'o̱‑ún, ni̱ ka'a̱n‑de jíín cháa mandador xndá'ú ja̱ bueno ndíchí ní sá'a‑de. Chi ta̱ká se̱'e kuia̱ yá'a, ndíchí‑ga̱ máá‑i nuu̱ ñáyɨvɨ íó vina, vásá táká se̱'e luz.
\v 9 Te máá‑rí, ká'a̱n‑ri̱ jíín‑ró: Jíín xú'ún xndá'ú, ná sá'a‑ró amigo‑ro̱ náva̱'a nú ni̱ ndɨ'ɨ xu̱'ún‑ró, te naki'in‑i róó kunchaa̱‑ro̱ iní ve̱'e‑i nɨ́ɨ́ káni.
\v 10 Chi cha̱a skíkuu va̱'a ɨɨn tiñu va̱sa lúlí‑ni, suni skíkuu va̱'a‑de jíín tíñu ándéé. Te cha̱a ja̱ xndá'ú‑de jíín ɨ́ɨn tiñu va̱sa lúlí‑ni, suni xndá'ú‑de jíín tíñu ándéé.
\v 11 Chi̱ nú sɨkɨ̱ xú'ún xndá'ú tú ní káskíkuu va̱'a‑ró, ndé cha̱a kua̱'a tiñu ndaa̱ nuu̱‑ro̱ núsáá.
\v 12 Te nú tú ní káskíkuu va̱'a‑ró jíín ndátíñu sava‑ga̱ cha̱a, ndéja̱ kuá'a ndatíñu máá‑ró núu̱‑ro̱ núsáá.
\v 13 Ni ɨɨn mozo ma̱ kúu kuatíñu‑de nuu̱ úu̱ jito'o̱. Chi̱ kiti̱ ini̱‑de nuu̱ ɨ́ɨn, te kumani̱‑dé jíín ɨngá, xí kuándatu̱‑de nuu̱ ɨ́ɨn te sáni̱'in ini̱‑de nuu̱ ɨnga. Ma̱ kúu kuatíñu‑ró núu̱ Dios jíín núu̱ xú'ún, áchí‑ya̱.
\v 14 Te cha̱a fariseo ká'i̱in‑de yúan, cha̱a tóó iní kákuu‑de. Te ni̱ ka̱jini so̱'o‑de ta̱ká tu̱'un ká'a̱n‑ya̱. Te ni̱ ka̱sákátá‑de nuu̱‑yá.
\v 15 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Máá‑ró kákuni̱‑ro̱ já ná káni ini̱ ña̱yɨvɨ já cháa ndaa̱ kákuu‑ró. Ko Dios, a jiní‑ya̱ ndasa káa ichi iní añú‑ro̱. Chi̱ tiñu kájani ini̱ ña̱yɨvɨ já tíñu ñá'nu kúu‑ún, te nuu̱ Dios tiñu chá'án kúu.
\v 16 Máá ley jíín cháa kájani tu̱'un Dios, ni̱ kuu‑ga̱ onde̱ kɨvɨ̱ ní kii Juan. Yúan‑na te ni̱ kejá'á tú'un va̱'a ñuu̱ nuu̱ tá'ú Dios tiñu. Te ña̱yɨvɨ, jíín fuerza kɨ́vɨ koyo‑i yúan.
\v 17 Ko yachi̱‑ga̱ naa ándɨ́vɨ́ jíín ñúyɨ́vɨ, vásá já náa ɨ́ɨn punto nuu̱ tutú ley.
\v 18 Nú ndé cha̱a skéndo̱o‑de ñasɨ́'ɨ́‑de te ta̱nda'a‑dé jíín ɨngá ña'an, yu̱án ísɨ́kɨ ncháa̱‑de‑ña. Te cha̱a tánda'a jíín ñá'an ní ndo̱o‑ún, suni ísɨ́kɨ ncháa̱‑de tá'an‑de.
\s1 Cha̱a kúká jíín Lázaro
\p 
\v 19 Ni̱ i̱o ɨɨn cha̱a kúká, ni̱ ñu̱'un‑de sa'ma kuá'á tíndí'í jíín sá'ma tɨ́ndu̱'á vá'a. Te ndɨta'a̱n kɨvɨ̱ ní sá'a‑de ndeyu ní ka̱yee vá'a‑de.
\v 20 Te suni ni̱ i̱o ɨɨn cha̱a ndá'ú nání‑de Lázaro, ni̱ jika̱n‑de caridad. Kátúu‑dé yuxé'é cháa kúká‑ún. Te nɨ́ɨ́‑de ni̱ kana ndɨ̱'yi.
\v 21 Te kuní‑de kee ndá'a̱ chi̱i‑de jíín yúxi stáa̱ kóyo chi̱i mesa cha̱a kúká‑ún. Te jákoyo ti'ina̱ te kána yuu‑tɨ̱ núu̱ ndɨ́'yi‑de.
\v 22 Te ni̱ ji'i̱ cha̱a jikán caridad‑ún. Te ndajá'a̱ ándɨ́vɨ́, ni̱ jaka‑ya̱‑dé kua̱no'on‑yá jíín‑de nuu̱ Abraham. Te suni ni̱ ji'i̱ cha̱a kúká‑ún, te ni̱ yu̱ji‑de.
\v 23 Te cha̱a kúká‑ún, ndó'o xaa̱n‑dé kándee‑de infierno. Te ni̱ ndakoto‑de. Te onde̱ jíká ní jini̱‑de nuu̱ Abraham, te kánchaa̱ Lázaro jíín‑de.
\v 24 Yúan‑na te máá cháa‑ún, ni̱ kana kó'ó‑de: Táta̱ Abraham, kundá'ú ini̱‑ní náá, te tájí‑ní Lázaro ná kíchi̱ndaji‑de xini̱ ndá'a‑dé nuu̱ ndúcha, te ná xndáji‑de yáa‑ná. Chi̱ xaa̱n jatú‑ná kayú‑ná nuu̱ yáá ñú'u̱n yá'a. Achí‑de.
\v 25 Te ni̱ kachi̱ Abraham jíín‑de: Hijo, a núku̱'un ini̱‑ro̱ já ní i̱o kúká‑ró ná ni̱ chaku̱‑ro̱, te Lázaro, sua ndá'ú ni̱ ta'a̱n‑de, ko vina, a ni̱ ndundéé iní‑de yá'a, te róó ndó'o‑ró jián.
\v 26 Te suni ni̱ sá'a Dios ɨɨn xa'va̱ kúnú xáa̱n, kándee ma̱'ñú róó jíín rúu̱. Te cha̱a ká'i̱in yá'a, va̱sa kákuni̱‑de ja̱'a‑de jaa̱‑de jia̱n, ko ma̱ kúu, ni ma̱ kúu ja̱'a máá‑ró kíi‑ró yá'a. Achí Abraham.
\v 27 Yúan‑na te ni̱ ka'a̱n, cha̱a kúká‑ún: Táa̱, jikán ta'u̱‑ná nuu̱‑ní, tájí‑ní‑de ki'i̱n‑de ve'e táa̱‑ná núsáá.
\v 28 Chi̱ íó u'u̱n‑ga̱ ñani̱‑ná, te ná káni ndaa̱‑de tu̱'un nuu̱‑í, náva̱'a ma̱ kíkoyo‑i nuu̱ ndó'o‑ná yá'a, áchí‑de.
\v 29 Te ni̱ kachi̱ Abraham jíín‑de: A káñava̱'a‑i tutu̱ ni̱ chaa Moisés jíín tutú ni̱ ka̱chaa cha̱a ni̱ jani tu̱'un Dios onde̱ sáá. Yúan ná kúni so̱'o‑i, áchí Abraham.
\v 30 Yúan‑na te máá‑de ni̱ kachi̱‑de: Túu, táta̱ Abraham, chi̱ nú ɨɨn cha̱a ni̱ ji'i̱ ki'i̱n nuu̱‑í, yúan‑na te nakani ini̱‑i jíná'an‑i, áchí‑de.
\v 31 Ko ni̱ kachi̱ Abraham jíín‑de: Nú tú chú'un ini̱‑i tu̱'un ni̱ jani Moisés jíín cháa ni̱ ka̱jani tu̱'un Dios, suni ma̱ kándíja kutɨ‑í nú nachaku̱ ɨɨn ndɨ̱yi ki'i̱n nuu̱‑í, áchí‑de.
\c 17
\s1 Sɨkɨ̱ ñáyɨvɨ skɨ́vɨ tá'an nuu̱ kuáchi
\p 
\v 1 Te ni̱ kachi̱‑ya̱ jíín cháa káskuá'a jíín‑yá: Tú modo te nú tú koto nchaa̱‑i ña̱yɨvɨ. Ko naka̱ ndá'ú kuu cha̱a skɨ́vɨ ña̱yɨvɨ‑ún nuu̱ kuáchi.
\v 2 Va̱'a‑ga̱ nú ní nú'ni̱ ɨɨn yo̱só sukún‑dé te kenda‑de ki'i̱n‑de nuu̱ ndúcha mar, nasu̱ já skɨ́vɨ‑de ɨɨn su̱chí lúlí yá'a nuu̱ kuáchi.
\s1 Sɨkɨ̱ tú'un sá'a tu̱ká'nu ini̱
\p 
\v 3 Koto va̱'a‑ró máá‑ró: Nú ñani̱‑ro̱ sá'a‑de kua̱chi sɨkɨ̱‑ro̱, kana jíín núu̱‑dé. Te nú ni̱ nakani ini̱‑de, te sá'a‑ró túká'nu ini̱‑ro̱ núu̱‑dé.
\v 4 Te nú usia̱ jínu ja̱ ɨ́ɨn kɨvɨ̱ ní sá'a‑de kua̱chi sɨkɨ̱‑ro̱, te nú usia̱ jínu nakani ini̱‑de te ka'a̱n‑de jíín‑ró: Sá'a tu̱ká'nu ini̱‑ro̱ núu̱‑rí, achi̱‑de, yúan‑na te ná sá'a‑ró túká'nu ini̱‑ro̱ núu̱‑dé. Achí‑ya̱.
\v 5 Te ni̱ kaka'a̱n cha̱a kákuu apóstol jíín máá Jíto'o̱‑yo̱: Sá'a‑ní ja̱ vá'a‑ga̱ ná kándíja‑ná núsáá, áchí‑de.
\v 6 Te ni̱ kachi̱ máá Jíto'o̱‑yo̱ jíín‑de: Nú kákandíja‑ró va̱sté ɨ́ɨn tí'li̱ nátu̱'un ɨɨn ndɨkɨn yuá mostaza núú, te ka'a̱n‑ro̱ jíín núyu̱'ndú yá'a: Tu'un máá‑ró onde̱ jíín yó'o‑ro, te nachu'un‑ró máá‑ró ondé nuu̱ mar, achi̱‑ro̱. Te kuandatu̱ nuu̱‑ro̱.
\s1 Tu̱'un yátá mozo játíñu
\p 
\v 7 Ndé ɨɨn róó, ñáva̱'a‑ró ɨ́ɨn mozo jítu‑de jíín xndɨkɨ̱ xí skáji‑dé rɨɨ̱. Te najaa̱‑de ve'e ja̱ ní ja'a̱n‑de yuku. Te kachi̱‑ni‑ró kúni‑de: Ña'a̱n te nungo̱o‑ró.
\v 8 Á tú xna'a̱n‑ga̱ ka'a̱n‑ro̱ jíín‑de: Sá'a ndeyu ná kúxíni‑ri̱. Naku'ni̱ va̱'a chi̱i‑ró, te kani‑ró kó'o̱‑rí. Te onde̱ nú ni̱ ndɨ'ɨ ni̱ yee‑rí staa̱, yúan‑na te vásá kée máá‑ró kó'o‑ró, achi̱‑ro̱ xí túu.
\v 9 Te á nakuatá'ú‑ró núu̱ mozo‑ún ja̱ ní skíkuu‑i tiñu ni̱ tá'ú‑ró núu̱‑í. Jáni ini̱‑ri̱ ja̱ túu.
\v 10 Suni súan máá‑ró jíná'an‑ró, nú ni̱ ka̱skíkuu‑ró tíñu ni̱ tá'ú‑yá nuu̱‑ro̱, te ka'a̱n‑ro̱: Tú va̱'a mozo kákuu‑ná, chi̱ máni tiñu ja̱ taú‑ná sá'a‑ná, kúu ja̱ á ni̱ ka̱sá'a‑ná, achi̱‑ro̱. Achí‑ya̱.
\s1 Uxi̱ cha̱a té'yu̱ ndɨ̱'yi
\p 
\v 11 Te jíka Jesús kua'a̱n‑ya̱ ñúu̱ Jerusalén. Te ichi iní ñuu̱ Samaria jíín iní ñuu̱ Galilea ni̱ ja̱'a‑ya̱ kuá'a̱n‑ya̱.
\v 12 Te nuu̱ ní kɨ̱vɨ‑ya̱ iní ɨɨn ñuu̱ yúan, te uxi̱ cha̱a té'yu̱ ndɨ̱'yi ni̱ ka̱ketá'an‑de jíín‑yá. Te cha̱a‑ún onde̱ jíká ní ka̱jukuiñi̱‑de.
\v 13 Te ni̱ ka̱kana jaa‑de: Maestro, Jesús, kundá'ú ini̱‑ní náá víi̱, áchí‑de.
\v 14 Te ni̱ jini̱ Jesús nuu̱‑dé, te ni̱ kachi̱‑ya̱ jíín‑de: Kuá'án jíná'an‑ró te stá'a̱n‑ro̱ máá‑ró núu̱ sutú, áchí‑ya̱. Te nini kája'a̱n‑de, te ni̱ ka̱ndundoo‑ni‑de.
\v 15 Yúan‑na te ɨɨn‑de, ni̱ jini̱‑de ja̱ ní nduva̱'a‑de. Te ni̱ na̱xíó káva‑de kua'a̱n‑de. Te nákana jaa‑de Dios.
\v 16 Te ni̱ jukuiñi̱ jítɨ́‑de nuu̱ já'a̱ Jesús. Te ni̱ nakuatá'ú‑de nuu̱‑yá. Te cha̱a‑ún, cha̱a ñuu̱ Samaria kúu‑de.
\v 17 Te ni̱ ka'a̱n Jesús jíín‑de: Nasu̱ uxí tá'a̱n‑ro̱ ní ka̱ndundoo náún. Te ɨɨ̱n‑ga̱‑de, ndénu̱ ká'i̱in‑de núsáá.
\v 18 Tú íó ɨnga̱‑de ja̱ cháa̱‑de te nakana jaa‑de Dios, xí sá cha̱a sɨ́ɨn ñuu̱ yá'a náún. Achí‑ya̱.
\v 19 Te ni̱ kachi̱ tuku‑ya̱ jíín‑de: Ndukuiñi̱, te no'o̱n‑ro̱ vé'e‑ró. Ni̱ kandíja‑ró te yu̱án ní nduva̱'a‑ró, áchí‑ya̱.
\s1 Sɨkɨ̱ ñúu̱ nuu̱ tá'ú Dios tiñu
\p 
\v 20 Te cha̱a fariseo, ni̱ kajika̱ tu̱'ún‑de‑ya̱: Ndé kɨvɨ̱ cháa̱ ñuu̱ nuu̱ tá'ú Dios tiñu. Achí‑de. Te ni̱ kachi̱‑ya̱ jíín‑de: Ñuu̱ nuu̱ tá'ú Dios tiñu, ma̱ cháa̱ ndiji̱n,
\v 21 ni ma̱ kúu ka'a̱n‑i: Nde̱'é yá'a, ni̱ chaa̱, xí ndé'é yúan, ni̱ jaa̱, chi̱ ñuu̱ nuu̱ tá'ú Dios tiñu, a íó ma̱'ñú máá‑ró jíná'an‑ró. Achí‑ya̱.
\v 22 Yúan‑na te ni̱ ka'a̱n‑ya̱ jíín cháa káskuá'a jíín‑yá: Chaa̱ tiempo ja̱ kákuni̱‑ro̱ ndé'é‑ró ɨ́ɨn kɨvɨ̱ kénda máá Sé'e cha̱a, ko ma̱ kuní‑ro̱ jíná'an‑ró.
\v 23 Te kachi̱‑i kuni‑ró: Nde̱'é yá'a kánchaa̱‑ya̱, xí nde̱'é yúan kánchaa̱‑ya̱, achi̱‑i. Te ma̱ kí'i̱n‑ro̱ jíín‑i, ni ma̱ kúndiki̱n‑ro̱‑í.
\v 24 Chi̱ nátu̱'un ndíi ncháa̱ ja̱ nándeyu̱ onde̱ ɨɨn lado andɨ́vɨ́ te jáa̱ onde̱ ɨnga̱ lado andɨ́vɨ́, suni súan kuu kɨvɨ̱ kíi máá Sé'e cha̱a.
\v 25 Ko jínu ñú'ún já xná'a̱n‑ga̱ ndo'o xaa̱n‑yá, te ña̱yɨvɨ yá'a ské'ichi̱‑i‑ya̱.
\v 26 Chi̱ nátu̱'un ni̱ kuu kɨvɨ̱ ní kii Noé, suni súan kuu kɨvɨ̱ kíi máá Sé'e cha̱a.
\v 27 Káyee‑í, káji'i‑i, káta̱nda'a cháa, káta̱nda'a ñá'an, te ni̱ jaa̱ kɨvɨ̱ já ní kɨ̱vɨ Noé ini̱ barco ká'nu‑de. Te ni̱ chaa̱ sau̱ xáa̱n. Te ni̱ xnáa ndɨ́'ɨ‑cha̱‑í jíná'an‑i.
\v 28 Suni súan ni̱ kuu kɨvɨ̱ Lot. Káyee‑í káji'i‑i, kájaan‑i káxi̱kó‑i, káchi'i‑i itu̱, kájani‑i ve'e,
\v 29 onde̱ ni̱ jaa̱ kɨvɨ̱ ní kenda Lot ini̱ ñuu̱ Sodoma kua'a̱n‑de. Te ni̱ kuun ñu'u̱n jíín azufre ichi ándɨ́vɨ́. Te ni̱ naa ndɨ́'ɨ ña̱yɨvɨ‑ún.
\v 30 Suni súan kuu kɨvɨ̱ kíi máá Sé'e cha̱a kistá'a̱n ndiji̱n‑ya̱ máá‑yá.
\v 31 Te kɨvɨ̱‑ún, te cha̱a kándee xini̱ vé'e‑de, ma̱ núu‑de naki'in‑de ndatíñu‑de ja̱ ní ndo̱o ini̱ ve̱'e. Te cha̱a kándee onde̱ rancho, ma̱ náxíó káva‑de no'o̱n‑de.
\v 32 Ma̱ náa iní‑ro̱ ndasa ni̱ ta'a̱n ñasɨ́'ɨ́ Lot.
\v 33 Chi cha̱a jítú iní‑de ka̱ku‑de chi̱i tu̱ndó'o kii sɨkɨ̱‑dé, naa‑dé. Ko cha̱a kuu̱ ja̱ sɨkɨ́ rúu̱, ka̱ku‑de.
\v 34 A ká'a̱n‑ri̱ jíín‑ró ja̱ ákuáa‑ún kunda̱a uu̱‑i nuu̱ jíto. Te ɨɨn‑i naki'in‑ya̱, te ndo̱o ɨnga̱‑i.
\v 35 Uu̱ ñasɨ́'ɨ́ ndiko ká'nu‑ña. Te ɨɨn‑ña náki'in‑ya̱, te ndo̱o ɨnga̱‑ña.
\v 36 Uu̱ cha̱a kuiñi‑de rancho. Te ɨɨn‑de naki'in‑ya̱, te ɨnga̱‑de xndóo‑ya̱.
\v 37 Te ni̱ kaka'a̱n‑de jíín‑yá: Ndénu̱ kúu Táta̱, áchí‑de. Te ni̱ kachi̱‑ya̱ jíín‑de: Nuu̱ kútúu ndɨ́yi, yúan taka̱ tijii̱, áchí‑ya̱.
\c 18
\s1 Tu̱'un yátá sɨkɨ́ juez jíín ñá'an viuda
\p 
\v 1 Te ni̱ ka'a̱n‑ya̱ ɨ́ɨn tu̱'un yátá jíín‑de ja̱ nené kaka̱n ta'u̱‑dé te ma̱ kuítá‑de jíín.
\v 2 Te ni̱ kachi̱‑ya̱: Ni̱ i̱o ɨɨn juez ini̱ ɨɨn ñuu̱. Te ni tú ní yú'ú‑de nuu̱ Dios, ni tú ní jíto‑de nuu̱ ní ɨɨn cha̱a.
\v 3 Te suni ni̱ i̱o ɨɨn ña'an ní kendo̱o ndá'ú‑ña ñúu̱ yúan. Te ña'an‑ún, ni̱ ja'a̱n ni̱ ja'a̱n‑ña núu̱‑dé. Te ni̱ ka'a̱n‑ña jíín‑de: Sá'a‑ní justicia ja̱ ní sá'a ña̱yɨvɨ jíín‑ná jíto u'u̱‑i náá. Achí‑ña.
\v 4 Ko máá juez‑ún, kua'a̱ kɨvɨ́ tú ní kuní‑de sá'a‑de. Yúan‑na te ni̱ nakani ini̱ máá‑de: Va̱sa tú yú'ú‑ri̱ jíto‑ri̱ Dios ni tú jíto‑ri̱ nuu̱ ní ɨɨn cha̱a,
\v 5 ko ja̱ ñá'an viuda yá'a, xaa̱n stá'a̱n‑ña rúu̱. Te yu̱án ná sá'a‑ri̱ justicia jíín‑ña. Chi̱ nú tú, te kunɨ́nɨ íi̱ iní‑ri̱ sá'a‑ña.
\v 6 Te ni̱ kachi̱ máá Jíto'o̱‑yo̱: Kuni ná'ín‑ró jíná'an‑ró ndasa ni̱ ka'a̱n juez káñáá‑ún.
\v 7 Te Dios tú sá'a‑ya̱ justicia jíín ñáyɨvɨ ní naka̱ji‑ya̱ náún, ja̱ ndúú ñúú‑ni káka'a̱n nda̱'ú‑i jíín‑yá, va̱sa kuéé sándaa̱‑ya̱ já'a̱‑í.
\v 8 A ká'a̱n‑ri̱ jíín‑ró ja̱ yachí nama‑ya̱‑í jíná'an‑i. Ko kɨvɨ̱ cháa̱ máá Sé'e cha̱a, á ni'i̱n‑yá ña̱yɨvɨ kákandíja nuu̱‑yá ini̱ ñu̱yɨ́vɨ yá'a xí túu, áchí‑ya̱.
\s1 Tu̱'un yátá cháa fariseo jíín cháa xíní
\p 
\v 9 Te suni ni̱ ka'a̱n‑ya̱ tú'un yátá yá'a jíín yakú cha̱a ká'i̱in yúan, chi̱ kájani ini̱‑de ja̱ cháa ndaa̱ kákuu máá‑de te kásájá'a̱ ini̱‑de nuu̱ sáva‑ga̱ ña̱yɨvɨ.
\v 10 Uu̱ tá'a̱n cha̱a ni̱ ka̱kaa‑de kája'a̱n‑de ve'e ii̱, ja̱ kakán ta'u̱‑dé. Ɨɨn‑de kúu cha̱a fariseo, te ɨnga̱‑de kúu cha̱a xíní.
\v 11 Te cha̱a fariseo, ni̱ kandii̱‑de, te ni̱ jika̱n ta'u̱‑dé tu̱'un yá'a: Táta̱ Dios, ná kúta'u̱‑ná nuu̱‑ní chi̱ tú káa‑ná nátu̱'un káa sava‑ga̱ cha̱a, cha̱a kuí'ná, cha̱a ñáá, cha̱a ísɨ́kɨ ncháa̱ tá'an kákuu‑de, ni tú káa‑ná nátu̱'un káa cha̱a xíní yá'a.
\v 12 Uu̱ jínu ja̱ semana íó ndicha̱ ini̱‑ná. Te já'a‑ná ɨɨn ja̱ uxí sɨkɨ̱ táká ndatíñu ñáva̱'a‑ná nuu̱‑ní, áchí‑de.
\v 13 Ko cha̱a xíní‑ún, ni̱ kandii̱ jíká‑ni‑de, ni tú ní kuní‑de ndukani‑de nuu̱‑dé, chi ni̱ kani‑de ji̱kí jiká‑dé ja̱ kúkuí'a̱ ini̱‑de. Te ni̱ ka'a̱n‑de: Táta̱ Dios, kundá'ú ini̱‑ní náá, chi cha̱a íó kua̱chi kúu‑ná, áchí‑de.
\v 14 Ká'a̱n‑ri̱ jíín‑ró já cháa ndá'ú yá'a, ni̱ nuu‑de kua̱no'on‑dé ve'e‑de, te ni̱ janchaa̱‑ya̱ kuáchi‑de, ko ɨngá cha̱a‑ún, chi̱ túu. Chi ta̱ká cha̱a sáñá'nu‑de máá‑de ndusúchí‑de. Te ta̱ká cha̱a sásúchí‑de máá‑de, nduñá'nu‑de. Achí‑ya̱.
\s1 Jesús jíín súchí lúlí
\p 
\v 15 Te ni̱ cha̱koyo ña̱yɨvɨ jíín sé'e lúlí‑i nuu̱ Jesús ja̱ ná ké'é‑yá‑i. Te cha̱a káskuá'a jíín‑yá, ni̱ kajini̱‑de ja̱ súan íó, te ni̱ kaka'a̱n xaa̱n‑dé nuu̱ ñáyɨvɨ‑ún.
\v 16 Ko máá Jesús, ni̱ kana‑ya̱ xiní‑dé. Te ni̱ ka'a̱n‑ya̱: Sía̱ ná kíkoyo su̱chí lúlí núu̱‑rí. Te ma̱ kasú‑ro̱ íchi‑í, chi̱ nátu̱'un su̱chí yá'á kákuu ja̱ kúu kɨ̱vɨ ini̱ ñuu̱ nuu̱ tá'ú Dios tiñu.
\v 17 Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró: Nú ɨɨn cha̱a tú játú'ún‑de ñuu̱ nuu̱ tá'ú Dios tiñu nátu̱'un játú'ún ɨ́ɨn su̱chí lúlí, ma̱ kɨ́vɨ kutɨ‑dé yúan, áchí‑ya̱.
\s1 Cha̱a kúká
\p 
\v 18 Te ɨɨn cha̱a kúñá'nu, ni̱ jika̱ tu̱'ún‑de‑ya̱: Cha̱a va̱'a kúu‑ní Maestro. Na̱ún sá'a‑ná te ni'i̱n tá'u̱‑ná kuchaku̱‑ná nɨ́ɨ́ káni. Achí‑de.
\v 19 Te ni̱ ka'a̱n Jesús jíín‑de: Naja̱ ká'a̱n‑ro̱ cháa va̱'a jíín‑rí. Tú ni ɨɨn cha̱a va̱'a íó, chi̱ máá ɨ́ɨn‑ni Dios.
\v 20 A jiní‑ro̱ tú'un ni̱ tá'ú tíñu‑ya̱ núu̱‑ro̱: Ma̱ ká'ni‑ro ndɨ́yi, ma̱ kúsɨ́kɨ ncháa̱ tá'an‑ró, ma̱ sákuí'ná‑ró, ma̱ ká'a̱n‑ro̱ tú'un tú'ún, kuandatu̱ nuu̱ táa̱‑ro̱, nuu̱ náa̱‑ro̱, áchí‑ya̱.
\v 21 Te máá‑de ni̱ kachi̱‑de: Ta̱ká tiñu yá'a a ni̱ skíkuu‑ná onde̱ ná lúlí‑ná, áchí‑de.
\v 22 Te Jesús, ni̱ jini so̱'o‑ya̱ tú'un yá'a. Te ni̱ kachi̱‑ya̱ jíín‑de: Ɨɨn‑na̱ tiñu kúmani̱ sá'a‑ró. Xi̱kó ndɨ́'ɨ ja̱ ñáva̱'a‑ró, te kua̱'a‑ró núu̱ ñáyɨvɨ ndá'ú. Te onde̱ andɨ́vɨ́ kóo yaji̱‑ro̱. Yúan‑na te kii‑ró kúndiki̱n‑ro̱ rúu̱ ki'o̱n. Achí‑ya̱.
\v 23 Yúan‑na te máá cháa‑ún, ni̱ jini so̱'o‑de ja̱ súan ni̱ ka'a̱n‑ya̱. Te ni̱ kuxíí xáa̱n iní‑de, chi̱ kúká xáa̱n‑dé.
\v 24 Te ndé'é Jesús ja̱ súan ni̱ kuxíí xáa̱n iní‑de, te ni̱ kachi̱‑ya̱: Xaa̱n ú'u̱ kɨ̱vɨ ɨɨn cha̱a kúká iní ñuu̱ nuu̱ tá'ú Dios tiñu.
\v 25 Yachi̱‑ga̱ kɨ̱vɨ ɨɨn camello yau̱ yɨkɨ tɨ́kuɨ́ vásá ɨ́ɨn cha̱a kúká kɨ́vɨ‑de ini̱ ñuu̱ nuu̱ tá'ú Dios tiñu. Achí‑ya̱.
\v 26 Te ña̱yɨvɨ, ni̱ ka̱jini so̱'o‑i tu̱'un ni̱ ka'a̱n‑ya̱‑ún, ni̱ kaka'a̱n‑i: Te ndé cha̱a ka̱ku núsáá, áchí‑i.
\v 27 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ió tiñu ja̱ má kúu sá'a ni ɨɨn cha̱a. Ko Dios, chi̱ kúu sá'a‑ya̱ táká‑ni. Achí‑ya̱.
\v 28 Yúan‑na te ni̱ ka'a̱n Pedro jíín‑yá: Náá, ni̱ ka̱skéndo̱o‑ná ta̱ká ndatíñu‑ná te káindiki̱n‑ná níí va̱i‑yó. Achí‑de.
\v 29 Te máá‑yá ni̱ kachi̱‑ya̱ jíín‑de: Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró, nú ɨɨn cha̱a ni̱ skéndo̱o‑de ve'e‑de, xí táa̱‑de, xí ñaní‑de, xí ñásɨ́'ɨ́‑de, xí sé'e‑de ja̱ sɨkɨ́ ñúu̱ nuu̱ tá'ú Dios tiñu,
\v 30 te nani'i̱n kuá'a̱‑gá‑de vina. Te onde̱ ɨnga̱ vida chaa̱, te kuchaku̱‑de nɨ́ɨ́ káni. Achí‑ya̱.
\s1 Jíín kɨvɨ́ ní ka'a̱n Jesús ja̱ kúu̱‑ya̱
\p 
\v 31 Te Jesús, ni̱ ki'in‑ya̱ ndɨ́'uxí uu̱‑de, te ni̱ ka'a̱n‑ya̱ jíín‑de: Vina chi̱ kaa‑yó kí'i̱n‑yo̱ ñúu̱ Jerusalén. Te yúan skíkuu ta̱ká tu̱'un ni̱ chaa cha̱a ni̱ ka̱jani tu̱'un Dios onde̱ sáá sɨkɨ́ máá Sé'e cha̱a.
\v 32 Chi̱ natu̱u‑ya̱ núu̱ ñáyɨvɨ sɨ́ɨn nación. Te sákátá‑i nuu̱‑yá. Te sá'a ndɨva̱'a‑i jíín‑yá. Te tɨvɨ̱ sɨ̱'vɨ́‑i nuu̱‑yá.
\v 33 Yúan‑na te nú ni̱ ndɨ'ɨ ni̱ ka̱xndó'o‑i‑ya̱, te ka'ni‑í‑ya̱. Ko nuu̱ uní kɨvɨ̱ te nachaku̱‑ya̱. Achí‑ya̱.
\v 34 Ko máá‑de, tú ní kájuku̱'un kutɨ iní‑de tu̱'un yá'a. Te tu̱'un‑ún ni̱ ka'a̱n sa̱'í‑ya̱. Yu̱án tú ní kájuku̱'un ini̱‑de ja̱ ní ka'a̱n‑ya̱ jíín‑de.
\s1 Ja̱ ní ndundiji̱n nduchi cháa kuáá
\p 
\v 35 Te ni̱ kuyani‑ya̱ kuá'a̱n‑ya̱ ñúu̱ Jericó. Te ɨɨn cha̱a kuáá, kánchaa̱‑de yu'íchi jikán‑de caridad.
\v 36 Te cha̱a kuáá‑ún, ni̱ jini so̱'o‑de kája̱'a ña̱yɨvɨ kája'a̱n‑i. Te ni̱ jika̱ tu̱'ún‑de na̱ún kúu yu̱án.
\v 37 Te ni̱ kakachi̱‑i nuu̱‑dé ja̱ Jesús, ñuu̱ Nazaret, ni̱ ja̱'a‑ya̱ kuá'a̱n‑ya̱.
\v 38 Yúan‑na te ni̱ kana kó'ó‑de: Jesús, Se̱'e David, kundá'ú ini̱‑ní náá, áchí‑de.
\v 39 Te ña̱yɨvɨ kája'a̱n ichi núu̱‑yá, ni̱ kaka'a̱n‑i jíín‑de ja̱ ná kasú‑de yu'u‑dé. Ko máá‑de ví'í‑gá ni̱ kana kó'ó‑de: Se̱'e David, kundá'ú ini̱‑ní náá víi̱, áchí‑de.
\v 40 Yúan‑na te ni̱ jukuiñi̱ Jesús. Te ni̱ tá'ú‑yá tiñu ná kíi‑de nuu̱‑yá. Te ni̱ jaa̱‑de. Te ni̱ jika̱ tu̱'ún‑yá‑de:
\v 41 Na̱ún sá'a‑ri̱ jíín‑ró kuní‑ro̱, áchí‑ya̱. Te cha̱a‑ún ni̱ ka'a̱n‑de: Táta̱, ja̱ ná ndúndiji̱n nduchi‑ná kuní‑ná, áchí‑de.
\v 42 Te ni̱ kachi̱ Jesús jíín‑de: Kuá'án, chi ni̱ kandíja‑ró te yu̱án ní nduva̱'a‑ró, áchí‑ya̱.
\v 43 Te ni̱ ndundiji̱n‑ni nduchi‑dé. Te ni̱ ndiki̱n‑de‑ya̱, nákana jaa‑de Dios. Te ta̱ká ña̱yɨvɨ‑ún, ni̱ kajini̱‑i nuu̱‑dé. Te ni̱ ka̱nakana jaa‑i Dios.
\c 19
\s1 Tu̱'un Zaqueo
\p 
\v 1 Te ni̱ kɨ̱vɨ Jesús ini̱ ñuu̱ Jericó, ni̱ ja̱'a‑ni‑ya̱ kuá'a̱n‑ya̱ núú.
\v 2 Te yúan ni̱ kenda‑ni ɨɨn cha̱a kúká, nání‑de Zaqueo. Te cha̱a‑ún kúñá'nu‑de nuu̱ táká cha̱a xíní.
\v 3 Te ndúkú ndéé‑de nde̱'é‑de nuu̱ Jesús nú ndé cha̱a kúu‑ya̱. Ko tú ní kúu, chi̱ kua'a̱ ñáyɨvɨ ní kajasu̱‑i‑ya̱, te vina lɨkɨ̱‑ni‑de.
\v 4 Te jínu‑de ni̱ ja̱kuxnúú‑de. Te ni̱ kaa‑de xini̱ ɨ́ɨn nuyu̱'ndú náva̱'a kuni̱‑de nuu̱‑yá. Chi̱ yúan ja̱'a‑ya̱ kí'i̱n‑ya̱.
\v 5 Te ni̱ jaa̱ Jesús yúan. Te ni̱ ndakoto‑ya̱ núu̱‑dé. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Zaqueo, yachi̱ nuu‑ró chi̱ vina jínu ñú'ún já kéndo̱o‑ri̱ ve'e‑ró. Achí‑ya̱.
\v 6 Yúan‑na te yachi̱ ni̱ nuu‑de. Te kúsɨɨ̱ xáa̱n iní‑de ni̱ jaka‑de‑ya̱.
\v 7 Te ña̱yɨvɨ‑ún, ni̱ kajini̱‑i ja̱ súan ni̱ kuu. Te ni̱ kaka'a̱n sóó‑i: A kua'a̱n‑tu‑ya̱ kéndo̱o‑ya̱ jíín ɨ́ɨn cha̱a íó kua̱chi, áchí‑i.
\v 8 Yúan‑na te Zaqueo ni̱ jukuiñi̱‑de. Te ni̱ kachi̱‑de jíín máá Jíto'o̱‑yo̱: Táta̱, sava ndatíñu‑ná, ná kuá'a‑ná nuu̱ ñáyɨvɨ ndá'ú. Te nú nuu̱ ɨ́ɨn cha̱a ni̱ janchaa̱‑ná ndatíñu‑de, te ná nákua̱'a‑ná kuu̱n já súan nuu̱‑dé. Achí‑de.
\v 9 Te ni̱ kachi̱ Jesús jíín‑de: Vina te ini̱ ve̱'e yá'a ni̱ ka̱ku ɨɨn cha̱a núsáá, chi̱ máá, suni se̱'e Abraham kúu.
\v 10 Chi̱ máá Sé'e cha̱a va̱i nándúkú‑yá te nama‑ya̱ já á ni̱ naa. Achí‑ya̱.
\s1 Tu̱'un yátá uxí mozo jíín xú'ún
\p 
\v 11 Te ni̱ ka̱jini so̱'o ña̱yɨvɨ‑ún ta̱ká tu̱'un yá'a. Te Jesús ni̱ ka'a̱n‑ga̱‑ya̱ ɨ́ɨn tu̱'un yátá, chi̱ a ni̱ kuyani‑ya̱ ñúu̱ Jerusalén, te kájani ini̱‑i ja̱ vítan ñú'ni koo ndiji̱n ñuu̱ nuu̱ tá'ú Dios tiñu.
\v 12 Ja̱ yúán ní ka'a̱n‑ya̱: Ɨɨn cha̱a kúñá'nu, ni̱ kenda‑de kua'a̱n jíká‑de ɨnga̱ ñuu̱ náva̱'a ni'i̱n‑dé fuerza ja̱ tɨ́ɨn‑de ñuu̱, te chaa̱‑de.
\v 13 Te ni̱ kana‑de xini̱ uxí tá'a̱n mozo‑de, te ni̱ ja̱'a‑de ciento ciento peso nuu̱ ɨ́ɨn ɨɨn‑i. Te ni̱ ka'a̱n‑de jíín‑i: Sátiñu jíná'an‑ró nini ki'i̱n‑ri̱ te nchaa̱‑ri̱, áchí‑de.
\v 14 Ko kájito u'u̱ ña̱yɨvɨ ñúu̱‑ún‑de, te ni̱ ka̱tájí ɨ́ɨn comisión kua̱kasu̱ nuu̱‑dé: Tú játa'a̱n ini̱‑yo̱ já tá'ú cháa yúan tiñu nuu̱‑yo̱. Achí.
\v 15 Te ni̱ kuu ja̱ ní ni'i̱n‑dé fuerza ja̱ tɨ́ɨn‑de ñuu̱, te ni̱ nchaa̱‑de. Te ni̱ tá'ú‑de tiñu ná kíi mozo ja̱ ní ja̱'a‑de xu̱'ún núu̱‑ún, náva̱'a ná kuní‑de ndasa ni̱ ka̱sátiñu ɨɨn ɨɨn‑i.
\v 16 Te mozo ɨɨn ni̱ jaa̱ nuu̱‑dé. Te ni̱ ka'a̱n‑i: Táta̱, ni̱ ja̱'a‑ní ciento peso nuu̱‑ná, te ni̱ ni'i̱n‑ná mil peso sɨkɨ̱, áchí‑i.
\v 17 Te máá‑de ni̱ kachi̱‑de jíín mozo: Ió va̱'a chi̱ mozo va̱'a kúu‑ró. Ni̱ skíkuu va̱'a‑ró jíín yakú ndatíñu‑ri̱. Vina te tá'ú‑ró tíñu nuu̱ uxí ñuu̱ tɨ́ɨn‑ri̱, áchí‑de.
\v 18 Te ni̱ chaa̱ ɨnga̱ mozo te ni̱ ka'a̱n: Táta̱, ni̱ ja̱'a‑ní ciento peso nuu̱‑ná, te ni̱ ni'i̱n‑ná u'u̱n ciento peso sɨkɨ̱, áchí‑i.
\v 19 Te suni ni̱ ka'a̱n‑de jíín mozo‑ún: Róó, suni tá'ú‑ró tíñu nuu̱ ú'u̱n ñuu̱ tɨ́ɨn‑ri̱, áchí‑de.
\v 20 Te ni̱ chaa̱ ɨnga̱ mozo. Te ni̱ ka'a̱n: Táta̱, yá'a íó ciento peso‑ní, chi ni̱ chiva̱'a‑ná ini̱ ɨɨn pañito.
\v 21 Chi ni̱ yu̱'ú‑ná ni̱ jito‑ná níí ja̱ cháa xaa̱n iní kúu‑ní, te náki'in‑ní ja̱ tú jáitúu‑ní, te já'nu̱‑ní ja̱ tú jachá‑ní, áchí‑i.
\v 22 Yúan‑na te ni̱ kachi̱‑de jíín‑i: Mozo káñáá kúu‑ró, te jíín tú'un ni̱ kenda yu'u‑ro jián, náku̱xndíi‑ri̱ sɨkɨ̱‑ro̱. Chi̱ a jiní‑ro̱ já cháa xaa̱n iní kúu‑ri̱, ja̱ náki'in‑ri̱ ja̱ tú jáitúu‑rí, te já'nu̱‑ri̱ ja̱ tú jachá‑ri̱.
\v 23 Núsáá, naja̱ tú ní já'a‑ró xú'ún‑rí no'o̱n banco núú. Te nuu̱ ncháa̱‑ri̱ te nandaka̱n‑ri̱ xu̱'ún‑rí onde̱ jíín sé'e xu̱'ún núú. Achí‑de.
\v 24 Yúan‑na te ni̱ kachi̱‑de jíín sáva‑ga̱ ña̱yɨvɨ ká'i̱in yani nuu̱‑dé: Kuanchaa̱ ciento peso jia̱n núu̱‑í, te kua̱'a‑ró núu̱ mozo ñáva̱'a mil peso, áchí‑de.
\v 25 Te máá ñáyɨvɨ, ni̱ kaka'a̱n jíín‑de: Táta̱, a ñáva̱'a‑i mil peso xáa̱n, áchí.
\v 26 Te ni̱ ka'a̱n tuku máá cháa kúñá'nu: A ká'a̱n‑ri̱ jíín‑ró, cha̱a ja̱ á ñáva̱'a, te kii‑ga̱ nuu̱‑dé, te cha̱a ja̱ tú ñáva̱'a, va̱sa ja̱ á ñáva̱'a‑de‑ún, te kuxio ki'i̱n.
\v 27 Te suni cha̱a kájito u'u̱ ruu̱, ja̱ tú ní kákuni̱‑de ja̱ tá'ú‑rí tiñu nuu̱‑dé, kuáki̱'in‑de ná kíkoyo‑de nuu̱‑rí yá'a. Te ka'ni‑ro‑dé jíná'an‑de. Achí‑de.
\s1 Ja̱ ní kɨ̱vɨ Jesús ini̱ ñuu̱ Jerusalén
\p 
\v 28 Te ni̱ ndɨ'ɨ ni̱ ka'a̱n‑ya̱ tú'un yá'a. Te ni̱ ja̱kuxnúú‑yá kua̱kaa‑ya̱ núu̱ Jerusalén.
\v 29 Te nuu̱ ní kuyani‑ya̱ ñúu̱ Betfagé jíín ñúu̱ Betania, ni̱ jaa̱‑ya̱ ɨ́ɨn yuku nání yúku Olivos. Te ni̱ tájí‑yá uu̱ cha̱a káskuá'a jíín‑yá kája'a̱n‑de:
\v 30 Kuá'án rancho kándee lado jia̱n. Te nuu̱ kɨ́vɨ‑ni‑ró yúan, te ni'i̱n‑ro̱ ɨ́ɨn burro nú'ni̱‑tɨ̱, ja̱ ní ɨɨn cha̱a té koso‑gá‑de‑tɨ̱. Te ndájí‑ró‑tɨ́. Te kii‑ró jíín‑tɨ́.
\v 31 Te nú ndé cha̱a ká'a̱n jíín‑ró, naja̱ kándájí‑ró‑tɨ́, achi̱‑de, te ka'a̱n‑ro̱ jíín‑de: Máá Jíto'o̱‑yo̱ jínu ñú'ún‑yá‑tɨ̱, achi̱‑ro̱, áchí‑ya̱.
\v 32 Te kája'a̱n cha̱a ni̱ tájí‑yá‑ún te ni̱ kani'i̱n‑dé‑tɨ̱ nátu̱'un ni̱ ka'a̱n‑ya̱ jíín‑de.
\v 33 Te nini kándájí‑de burro‑ún te ni̱ kaka'a̱n jito'o̱‑tɨ̱ jíín‑de: Naja̱ kándájí‑ró burro‑ri̱, áchí‑de.
\v 34 Te máá‑de, ni̱ kaka'a̱n‑de: Chi̱ máá Jíto'o̱‑yo̱ jínu ñú'ún‑yá‑tɨ̱, áchí‑de.
\v 35 Te ni̱ cha̱koyo‑de jíín‑tɨ́ nuu̱ Jesús. Te ni̱ ka̱xndée‑de tɨka̱chí‑de sɨkɨ̱ burro‑ún. Te ni̱ ka̱skáa‑de Jesús sɨkɨ̱‑tɨ́ yóso‑yá‑tɨ̱.
\v 36 Te nini jíka‑ya̱ kuá'a̱n‑ya̱, te ni̱ kajaki̱n‑de tɨka̱chí‑de ini̱ ichi.
\v 37 Te nini kákuyani‑ya̱ ñúu̱ Jerusalén ja̱ kákuun‑ya̱ yúku Olivos, te ta̱ká cha̱a káskuá'a jíín‑yá, kánakana jaa‑de Dios sɨkɨ̱ táká tiñu ñá'nu ja̱ ní kajini̱‑de ni̱ sá'a‑ya̱.
\v 38 Te káka'a̱n‑de: Ná nákana jaa‑yó Rey yá'a chi̱ ndíso‑ya̱ tíñu máá Tatá Dios. Chi̱ vindaa̱ vinené íó onde̱ andɨ́vɨ́, te suni luu ñá'nu káa yúan. Achí.
\v 39 Yúan‑na te sava cha̱a fariseo ká'i̱in ma̱'ñú ñáyɨvɨ kuá'a̱‑ún, ni̱ kaka'a̱n‑de jíín‑yá: Maestro, kana jíín‑ní nuu̱ cháa káskuá'a jíín‑ní, ná kasú‑de yu'u‑dé, áchí‑de.
\v 40 Te máá Jesús ni̱ ka'a̱n‑ya̱: A ká'a̱n‑ri̱ jíín‑ró ja̱ nú cha̱a yá'a ná kasú‑de yu'u‑dé, te súan kana kó'ó táká yuu̱, áchí‑ya̱.
\v 41 Te ni̱ kuyani‑ya̱. Te ni̱ jini̱‑ya̱ núu̱ ñúu̱‑ún. Te ni̱ nde'e̱‑ya̱ sɨkɨ́ ñúu̱‑ún.
\v 42 Te ni̱ ka'a̱n‑ya̱: Aa̱, xáán va̱'a nú ní jiní máá‑ró ndasa va̱i tu̱'un vindaa̱ vinené núú. Ko vina chi̱ a yísa̱'í te ma̱ kuní‑ro̱ núu̱.
\v 43 Chi̱ jaa̱ kɨvɨ̱, ja̱ cháa kájito u'u̱ róó kuíkó ndúu̱ nɨ́nɨ‑dé róó. Te ta̱ká lado kasu̱‑de róó. Te nataan ní'in‑de róó.
\v 44 Te stúncháa̱‑de róó nuu̱ ñú'un onde̱ jíín sé'e‑ró já káxiu̱kú‑i ini̱‑ro̱. Te ma̱ skéndo̱o‑de yuu̱ kóso tá'an sɨkɨ̱ yúu̱, chi̱ tú ní jiní‑ro̱ já ní kii‑ya̱ núu̱‑ro̱. Achí‑ya̱.
\v 45 Te ni̱ kɨ̱vɨ Jesús ini̱ ve̱'e ii̱. Te ni̱ kejá'á‑yá kíñi'in‑ya̱ ñáyɨvɨ kájaan káxi̱kó íin‑i ini̱ ve̱'e ii̱‑ún kája'a̱n‑i.
\v 46 Te ni̱ ka'a̱n‑ya̱ jíín‑i: Á tú yóso núu̱ tutú: Ve'e‑ri̱, chi̱ ve'e nuu̱ kájika̱n ta'u̱ kúu, ko máá‑ró, a ni̱ ka̱nasá'a‑ró yaú kava ñákui̱'ná, áchí‑ya̱.
\v 47 Te ndɨta'a̱n kɨvɨ̱ stá'a̱n‑ya̱ tú'un ini̱ ve̱'e ii̱. Ko sutu̱ ñá'nu jíín cháa káchaa tutu̱ jíín cháa kákuñá'nu ini̱ ñuu̱‑ún, ni̱ ka̱ndúkú‑de modo ndasa ka'ni‑dé‑ya̱.
\v 48 Ko tú ní kákuu ndasa sá'a‑de jíín‑yá, chi̱ ndivii ñáyɨvɨ, ni̱ ka̱kee nuu̱‑í ká'i̱in‑i kájini ná'ín‑i tu̱'un ká'a̱n‑ya̱.
\c 20
\s1 Sɨkɨ̱ tíñu ndíso Jesús
\p 
\v 1 Te ɨɨn kɨvɨ̱ jián stá'a̱n‑ya̱ tú'un nuu̱ ñáyɨvɨ iní ve̱'e ii̱, te jáni‑ya̱ tú'un va̱'a. Te sutu̱ ñá'nu jíín cháa káchaa tutu̱ jíín cháa ni̱ ka̱yii, ni̱ ja̱koyo‑de nuu̱‑yá.
\v 2 Te ni̱ kajika̱ tu̱'ún‑de‑ya̱: Kastu̱'ún, na̱ jíín tú'un sá'a‑ró tíñu yá'a. Te ndéja̱ ní ka'a̱n jíín‑ró sá'a‑ró súan, áchí‑de.
\v 3 Yúan‑na te ni̱ ka'a̱n Jesús jíín‑de: Suni ná kaká tu̱'ún‑rí róó ɨɨn tu̱'un: Kastu̱'ún,
\v 4 ja̱ ní skuánducha Juan sáá, á onde̱ andɨ́vɨ́ ní kii tu̱'un, xí cháa ni̱ tá'ú tíñu, áchí‑ya̱.
\v 5 Yúan‑na te ni̱ kanda̱tu̱'ún máá‑de: Nú ka'a̱n‑yo̱ já ondé andɨ́vɨ́, te kachi̱‑de kuni‑yó: Naja̱ tú ní kákandíja‑ró núu̱‑dé núsáá.
\v 6 Te nú ka'a̱n‑yo̱ já cháa ni̱ tá'ú tíñu, te ndivii ñáyɨvɨ kuá'a‑i yuu̱ xiní‑yo̱. Chi̱ kájani ndija ini̱‑i ja̱ cháa ni̱ jani tu̱'un Dios ni̱ kuu Juan, áchí‑de jíín tá'an‑de.
\v 7 Te ni̱ kaka'a̱n‑de ja̱ tú kájini̱‑de ndénu̱ ní kii tu̱'un‑ún.
\v 8 Yúan‑na te ni̱ ka'a̱n Jesús jíín‑de: Suni ruu̱ tú kachi̱‑ri̱ nuu̱‑ro̱ na̱ jíín tú'un sá'a‑ri̱ tiñu yá'a, áchí‑ya̱.
\s1 Cha̱a kásátiñu nuu̱ itú uva
\p 
\v 9 Te ni̱ kejá'á‑yá ni̱ ka'a̱n‑ya̱ tú'un yátá yá'a jíín ñáyɨvɨ‑ún: Ɨɨn cha̱a ni̱ nachu'un‑de ɨɨn itu̱ uva. Te ni̱ xndóo‑de nuu̱ cháa kásátiñu jíín. Te ni̱ kee‑de kua'a̱n jíká‑de ja̱ ná'án xáa̱n.
\v 10 Te ɨɨn kɨvɨ̱ ni̱ tájí‑de ɨɨn mozo‑de kua'a̱n nuu̱ cháa kásátiñu jíín uva ja̱ ná nákua̱'a‑de nde'e̱ uva nuu̱ mozo‑ún núú. Ko cha̱a kásátiñu‑ún, ni̱ kastují‑dé mozo. Te ni̱ ka̱kiñi'in‑de‑i kua̱no'on sáni‑ni‑i.
\v 11 Te jito'o̱‑ún, ni̱ na̱tájí tuku‑de ɨnga̱ mozo‑de. Ko máá cháa kásátiñu‑ún, suni ni̱ ka̱stují‑dé mozo‑ún, te ni̱ ka̱sákátá‑de jíín‑i te ni̱ ka̱kiñi'in‑de‑i kua̱no'on sáni‑ni‑i.
\v 12 Te jito'o̱ uva‑ún ni̱ na̱tájí tuku‑de mozo uni̱‑de kua'a̱n. Ko máá cháa kásátiñu‑ún, suni ni̱ ka̱stují‑dé mozo‑ún. Te ni̱ ka̱skúnu‑de‑i.
\v 13 Yúan‑na te ni̱ ka'a̱n máá jíto'o̱ itu̱ uva: Ndasa sá'a‑ri̱. Ná tájí‑rí se̱'e‑ri̱ ja̱ kúndá'ú ini̱‑ri̱‑i. Sanaa te koo ja̱ jíñú'ún‑de nuu̱ sé'e‑ri̱. Achí‑de.
\v 14 Ko máá cháa kásátiñu‑ún, ni̱ kajini̱‑de nuu̱‑í. Te ni̱ kanda̱tu̱'ún máá‑de: Su̱chí yá'a xíin tá'u̱. Ná chó'o̱, ná ká'ni‑yo‑í náva̱'a ná ndóo ta'u̱‑í kuu‑yó, áchí‑de.
\v 15 Te ni̱ ka̱kiñi'in‑de‑i ichi yatá itú uva. Te ni̱ ka̱ja'ni‑dé‑i. Te ndasa sá'a máá jíto'o̱ itu̱ uva jíín‑de núsáá.
\v 16 Chaa̱‑de, te xnáa‑dé cha̱a kásátiñu‑ún. Te kua̱'a‑de itu̱ uva nuu̱ ɨngá cha̱a. Achí‑ya̱. Te ña̱yɨvɨ‑ún ja̱ ní ka̱jini so̱'o‑i tu̱'un yá'a, te ni̱ kaka'a̱n‑i: Ma̱ kúu kutɨ súan, Táta̱. Achí‑i.
\v 17 Ko máá‑yá ni̱ nde̱'é‑yá nuu̱‑í te ni̱ ka'a̱n‑ya̱: Núsáá te na̱ún kuní ka'a̱n tu̱'un yóso yá'a: Yuu̱ ní ka̱ské'ichi̱ cha̱a káchutá'an, ya̱'á kúu máá yúu̱ ndíso fuerza jiki̱. Achí.
\v 18 Ta̱ká‑i ja̱ nduá sɨkɨ̱ yúu̱‑ún, te ta'nu̱. Ko nú ndé sɨkɨ̱ júngava máá yúu̱‑ún, te kukuáchí‑i sá'a. Achí‑ya̱.
\s1 Sɨkɨ̱ xú'ún César
\p 
\v 19 Yúan‑na te sutu̱ ñá'nu‑ún jíín cháa káchaa tutu̱ ni̱ ka̱ndúkú‑de modo tɨɨn‑de‑ya̱ máá hora‑ún. Chi ni̱ kaju̱ku̱'un ini̱‑de ja̱ sɨkɨ́ máá‑de kúu tu̱'un yátá ní ka'a̱n‑ya̱‑ún. Ko ni̱ kayu̱'ú‑de ni̱ ka̱jito‑de ña̱yɨvɨ.
\v 20 Te ndé'é ndé'é‑de ichi‑yá. Te ni̱ ka̱tájí‑de sava cha̱a ja̱ kóto yu'u‑dé‑ya̱. Te cha̱a‑ún, káka'a̱n‑de ja̱ cháa ndaa̱ kákuu‑de, náva̱'a tɨɨn yátá‑de‑ya̱ sɨkɨ́ tú'un ká'a̱n‑ya̱, te nastúu‑de‑ya̱ núu̱ fuerza gobernador, cha̱a tá'ú tíñu yúan, kákuni̱‑de.
\v 21 Te cha̱a‑ún, ni̱ kajika̱ tu̱'ún‑de‑ya̱: Maestro, kájini̱‑ná ja̱ ká'a̱n va̱'a‑ní te stá'a̱n ndaa̱‑ní tu̱'un. Te tú ndé'é‑ní ndasa jíto ta̱ká ña̱yɨvɨ, chi̱ sua stá'a̱n ndaa̱‑ní ichi Dios.
\v 22 Á kuu kua̱'a‑yó xú'ún yóo̱ nuu̱ César xí túu, áchí‑de.
\v 23 Ko máá‑yá, ni̱ jini̱‑ya̱ já xndá'ú‑de‑ya̱ kákuni̱‑de. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Naja̱ kájito nchaa̱‑ro̱ rúu̱.
\v 24 Stá'a̱n xu̱'ún jián ná ndé'é‑rí. Ndé cha̱a kúu cha̱a ncháá nuu̱ yá'a, jíín tú'un yóso yá'a. Achí‑ya̱. Te ni̱ kaka'a̱n‑de: César kúu, áchí‑de.
\v 25 Yúan‑na te ni̱ ka'a̱n‑ya̱ jíín‑de: Kua̱'a ja̱ xíin César nuu̱ César, te ja̱ xíin Dios nuu̱ Dios núsáá, áchí‑ya̱.
\v 26 Te tú ní kákuu tɨɨn yátá‑de‑ya̱ jíín tú'un yá'a jíto nuu̱ ñáyɨvɨ. Te ni̱ ka̱naa iní‑de ni̱ ka̱jini so̱'o‑de tu̱'un ni̱ ka'a̱n‑ya̱ jíín‑de. Te tú ní káka'a̱n kutɨ‑gá‑de.
\s1 Sɨkɨ̱ já náchaku̱ ndɨ̱yi
\p 
\v 27 Yúan‑na te ni̱ ja̱koyo yaku̱ cha̱a saduceo. Te cha̱a‑ún, káka'a̱n‑de ja̱ tú nachaku̱ kutɨ ndɨ́yi. Te ni̱ kajika̱ tu̱'ún‑de‑ya̱:
\v 28 Maestro, Moisés ni̱ chaa‑de tutu̱ ni̱ ndo̱o jíín‑yó: Nú ñani̱ ɨɨn cha̱a kuu̱‑de, te íó ñasɨ́'ɨ́‑de, te nú tú se̱'e‑de ní íó. Yúan‑na te ñani̱‑de ná náki'in ñasɨ́'ɨ́‑de, te nandaki̱n‑de tata̱ ñani̱‑de, áchí tutu̱‑ún.
\v 29 Bueno, ni̱ ka'i̱o usia̱ ñani̱. Te cha̱a núú, ni̱ ta̱nda'a‑dé. Te ni̱ ji'i̱‑de. Te tú kutɨ sé'e‑de ní íó.
\v 30 Te cha̱a uu̱, ni̱ naki'in‑de‑ña. Te ni̱ ji'i̱‑de. Te tú kutɨ sé'e‑de ní íó.
\v 31 Te cha̱a uni̱ ni̱ naki'in‑de‑ña. Te ni̱ ji'i̱ tuku‑de. Te ndɨ́'usiá‑de suni súan. Te ni̱ kaji'i̱‑de. Te tú kutɨ ní ɨɨn se̱'e ní káxndóo‑de.
\v 32 Te onde̱ sandɨ̱'ɨ́‑na̱ te suni ni̱ ji'i̱ máá ñá'an‑ún.
\v 33 Te kɨvɨ̱ náchaku̱ ta̱ká ndɨ̱yi, ndé ɨɨn‑de kuu‑ña ñásɨ́'ɨ́‑de núsáá. Chi̱ ndɨ́'usiá‑de ni̱ kancha̱ka‑de‑ña, áchí‑de jíín‑yá.
\v 34 Yúan‑na te ni̱ kachi̱ Jesús jíín‑de: Se̱'e ña̱yɨvɨ yá'a, chi̱ káta̱nda'a‑í jíná'an‑i.
\v 35 Ko íó ña̱yɨvɨ já jáni ini̱ Dios ja̱ ñáyɨvɨ vá'a kúu‑i. Te ña̱yɨvɨ‑ún nachaku̱‑i ma̱'ñú ndɨ́yi, te kɨ̱vɨ‑i ɨnga̱ vida. Te tú ta̱nda'a kútɨ‑í jíná'an‑i yúan.
\v 36 Ni ma̱ kúu̱ kutɨ‑gá‑i. Chi̱ ɨɨn núú‑ni kákuu‑i jíín ndájá'a̱ ándɨ́vɨ́, te suni se̱'e Dios kákuu‑i, chi̱ a ni̱ nachaku̱‑i.
\v 37 Te sɨkɨ̱ ndɨ́yi ja̱ náchaku̱, suni ɨɨn‑ni tu̱'un ni̱ stá'a̱n Moisés nuu̱ yóso tú'un cuenta yuku̱. Chi ni̱ skúnání‑de‑ya̱ Dios Abraham, Dios Isaac, jíín Dios Jacob.
\v 38 Chi̱ Dios, nasu̱ Dios ña̱yɨvɨ ní kaji'i̱ kúu‑ya̱, chi̱ sua Dios ña̱yɨvɨ káichaku̱ kúu‑ya̱. Chi̱ nuu̱ máá‑yá káichaku̱ ta̱ká ña̱yɨvɨ. Achí‑ya̱.
\v 39 Te yaku̱ cha̱a káchaa tutu̱, ni̱ kaka'a̱n‑de: Va̱'a‑ni ni̱ ka'a̱n‑ní Maestro, áchí‑de.
\v 40 Te tuká ní kátava iní‑de ja̱ kaká tu̱'ún‑de‑ya̱.
\s1 Sɨkɨ̱ Cristo, Se̱'e David
\p 
\v 41 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Naja̱ káka'a̱n‑de ja̱ Cristo kúu Se̱'e David.
\v 42 Chi̱ máá David ni̱ ka'a̱n‑de nuu̱ tutú Salmo: Máá Tatá Dios ni̱ ka'a̱n‑ya̱ jíín Jíto'o̱‑ri̱: Nungo̱o‑ró íchi ndává'a‑ri̱,
\v 43 te ná chúkú‑rí ña̱yɨvɨ kájito u'u̱ róó kuu‑i teyu̱ kuxndíi ja'a̱‑ro̱, áchí.
\v 44 Te máá David: Jito'o̱ ni̱ ka'a̱n‑de jíín‑yá: Te ndasa kúu‑ya̱ sé'e‑de núsáá, áchí‑ya̱.
\v 45 Te kánchaa̱‑ya̱ má'ñú táká ña̱yɨvɨ. Te ni̱ ka'a̱n‑ya̱ jíín cháa káskuá'a jíín‑yá:
\v 46 Koto‑ró máá‑ró núu̱ cháa káchaa tutu̱, chi̱ kákuni̱‑de kaka‑de jíín sú'nu̱ káni. Te kákuni̱‑de ja̱ ká'a̱n sa̱'án‑yo̱ jíín‑de nu̱yá'u. Te silla jíñú'ún ondé xini̱ mesa ini̱ ve̱'e sinagoga, jíín silla xini̱ mesa nuu̱ íó xíni kákuni̱‑de.
\v 47 Te suni cha̱a yá'a kákókó‑de ve'e ña'an kéndo̱o ndá'ú. Te kándúkú‑de modo sáni, ja̱ kájika̱n ta'u̱ ná'án‑de. Cha̱a yá'a, ví'í‑gá ta'nu̱ ndatu̱‑de, áchí‑ya̱.
\c 21
\s1 Ja̱ ní soko̱ ñá'an viuda xu̱'ún
\p 
\v 1 Te ni̱ ndakoto‑ya̱, te ni̱ jini̱‑ya̱ núu̱ ñáyɨvɨ kúká káchu'un‑i xu̱'ún iní janu̱.
\v 2 Te ni̱ jini̱‑ya̱ núu̱ ɨ́ɨn ña'an viuda ja̱ ní kendo̱o ndá'ú íi̱‑ñá, te ni̱ chu'un‑ña úu̱ xu̱'ún yɨ́kɨ́n náa iní janu̱‑ún.
\v 3 Te ni̱ ka'a̱n‑ya̱: Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró, ja̱ ñá'an ní kendo̱o ndá'ú yá'a, ni̱ chu'un‑ga̱‑ña vásá táká‑ga̱‑i.
\v 4 Chi ta̱ká‑i, ni̱ ka̱chu'un‑i ja̱ ní ndendoso sɨkɨ́‑í ni̱ kasoko̱‑í nuu̱ Dios. Ko ña'an yá'a, va̱sa kúndá'ú‑ña ko ni̱ chu'un ndɨ'ɨ‑ña já kúchaku̱‑ña jíín, áchí‑ya̱.
\s1 Na̱ún tuni̱ koo kɨvɨ̱ jínu ñu̱yɨ́vɨ
\p 
\v 5 Te sava‑de káka'a̱n‑de tu̱'un ve'e ii̱, ndasa ni̱ nduluu jíín yúu̱ lúu jíín ofrenda. Te ni̱ ka'a̱n‑ya̱:
\v 6 Ta̱ká ndatíñu ja̱ kánde̱'é‑ró yá'a, chaa̱ ɨɨn kɨvɨ̱ já má kútá'an‑ga̱ ni ɨɨn yuu̱, chi̱ ndɨ'ɨ ndua̱ sá'a‑i, áchí‑ya̱.
\v 7 Yúan‑na te ni̱ kajika̱ tu̱'ún‑de‑ya̱: Maestro, ndé kɨvɨ̱ kóo ta̱ká tiñu yá'a. Te na̱ún tuni̱ koo nuu̱ kúyani chaa̱ ta̱ká tiñu yá'a, áchí‑de.
\v 8 Yúan‑na te ni̱ ka'a̱n‑ya̱ jíín‑de: Koto‑ró máá‑ró jíná'an‑ró náva̱'a tú xndá'ú ni ɨɨn‑i róó. Chi̱ kikoyo kua'a̱ ñáyɨvɨ kí'in núu sɨ́'vɨ́‑rí, te ka'a̱n‑i: Máá‑rí kúu I'a̱‑ún. A ni̱ chaa̱ kɨvɨ̱‑ún, achi̱‑i. Ko ma̱ kí'i̱n‑ro̱ jíín‑i.
\v 9 Te nú ni̱ ka̱jini tu̱'un‑ró já íó guerra te kája̱tá'an ña̱yɨvɨ, te ma̱ yú'ú‑ro̱, chi̱ kánúú já xná'a̱n‑ga̱ koo ta̱ká tiñu yá'a. Ko ma̱ ndɨ́'ɨ yachi̱.
\v 10 Yúan‑na te ni̱ ka'a̱n‑ya̱ jíín‑de: Ndonda nación sɨkɨ̱ nación te ñuu̱ sɨkɨ̱ ñúu̱.
\v 11 Te ta̱an xaa̱n. Te yá'a yúan koo tama̱ jíín kué'e̱ xaa̱n. Te koo tuni̱ ñá'nu ichi ándɨ́vɨ́, te yu̱'ú ña̱yɨvɨ jíná'an‑i.
\v 12 Ko onde̱ té chá'a̱n‑ga̱ koo ta̱ká tiñu yá'a, te chindiki̱n‑i róó te katɨɨn‑i róó. Te nastúu‑i róó ini̱ ve̱'e sinagoga jíín iní veka̱a, kincha̱ka‑i róó nuu̱ rey jíín núu̱ gobernador ja̱ sɨkɨ́ rúu̱.
\v 13 Te koo súan náva̱'a kani ndaa̱‑ro̱ tú'un.
\v 14 Núsáá te ná kúndaa̱ ini̱‑ro̱ já má nákani ini̱‑ro̱ ndasa xndíó káni‑ró tú'un nuu̱‑í.
\v 15 Chi̱ ruu̱, kua̱'a‑ri̱ ɨɨn yu'u jíín tú'un ndíchí núu̱‑ro̱, náva̱'a cha̱a kájito u'u̱ róó, ma̱ kúu ka'a̱n‑de sɨkɨ̱‑ro̱ ni ma̱ kúu kundéé‑de jíín‑ró.
\v 16 Te suni táa̱‑ro̱, ñani̱‑ro̱, tá'an‑ró, jíín ñáyɨvɨ kájini̱ tá'an‑ró jíín, nastúu‑i róó. Te kuu̱ sava‑ró sá'a‑i.
\v 17 Te ta̱ká ña̱yɨvɨ, koto u'u̱‑i róó ja̱ sɨkɨ́ rúu̱.
\v 18 Ko ni ɨɨn ixi xiní‑ro̱ ma̱ náa kútɨ.
\v 19 Te nú kua̱ndéé iní‑ro̱ te kuchaku̱ añú‑ro̱.
\v 20 Ko nú ni̱ kajini̱‑ro̱ já ní ka̱jíkó ndúu̱ soldado yata̱ ñúu̱ Jerusalén, yúan‑na te juku̱'un ini̱‑ro̱ já á yani naa ñúu̱‑ún.
\v 21 Yúan‑na te ña̱yɨvɨ káxiu̱kú iní ñuu̱ Judea, kunu‑i ki̱ngoyo‑i onde̱ yuku. Te ña̱yɨvɨ ká'i̱in ma̱'ñú ñúu̱‑ún, kuxio‑i ki'i̱n‑i. Te ña̱yɨvɨ ká'i̱in onde̱ rancho, ma̱ ndɨ́vɨ‑i ini̱ ñuu̱.
\v 22 Chi̱ kɨvɨ̱ yúan kuu kɨvɨ̱ náni'i̱n tá'an Dios jíín‑i, náva̱'a náskíkuu ta̱ká tu̱'un yóso núu̱ tutú.
\v 23 Ko kɨvɨ̱‑ún, naka̱ ndá'ú kuu ña'an káñu̱'un se̱'e jíín ñá'an káskáxin‑í, chi̱ kii tu̱ndó'o xaa̱n sɨkɨ́ ñúyɨ́vɨ. Te kiti̱ ini̱ Dios jíín ñáyɨvɨ yá'a.
\v 24 Te kuu̱‑i jíín machete. Te ki̱ngoyo‑i preso onde̱ ta̱ká nación. Te ña̱yɨvɨ sɨ́ɨn nación, kuañu̱‑i sɨkɨ̱ ñúu̱ Jerusalén onde̱ ji̱nu kɨvɨ̱ ñáyɨvɨ sɨ́ɨn nación.
\v 25 Yúan‑na te koo tuni̱ nuu̱ ndíka̱ndii jíín núu̱ yóo̱ jíín núu̱ tíñu̱ú xíní. Te kii tu̱ndó'o sɨkɨ̱ táká ña̱yɨvɨ ñúyɨ́vɨ yá'a. Te yu̱'ú ña̱yɨvɨ já nɨ́'ɨn mar jíín sú'ma̱ mar.
\v 26 Te kuu̱ xáan sáva cha̱a ja̱ káyu̱'ú‑de, chi̱ káinda̱tu‑de chaa̱ tu̱ndó'o yá'a sɨkɨ̱ nɨ́ɨ́ ñúyɨ́vɨ. Te ta̱ká fuerza andɨ́vɨ́, ndɨ'ɨ ka'ya.
\v 27 Yúan‑na te kuni̱‑i nuu̱ máá Sé'e cha̱a kii‑ya̱ núu̱ ɨ́ɨn viko̱ nu̱'ún, jíín fuerza ja̱ ndúñá'nu xaa̱n‑yá.
\v 28 Te nú a ni̱ kejá'á táká tiñu yá'a, yúan‑na te ndukani‑ró xiní‑ro̱ te ndakoto‑ró, chi̱ a yani nama‑ya̱ róó, áchí‑ya̱ jíín‑de.
\v 29 Te suni ni̱ ka'a̱n‑ya̱ ɨ́ɨn tu̱'un yátá jíín‑de: Nde̱'é yúnu mérkexe̱, jíín táká‑ga̱ yunu.
\v 30 Nú ni̱ kajini̱‑ro̱ já ní kejá'á nájaa numa yúnu‑ún, yúan‑na te kájuku̱'un ini̱‑ro̱ já á yani nchaa̱ viko sáú.
\v 31 Suni súan máá‑ró, nú ni̱ kajini̱‑ro̱ kuákuu ta̱ká tiñu yá'a, yúan‑na te kuni̱‑ro̱ já á yani koo ñuu̱ nuu̱ tá'ú Dios tiñu.
\v 32 Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró ja̱ má náa ñáyɨvɨ yá'a onde̱ nú tú skíkuu ta̱ká tiñu.
\v 33 Andɨ́vɨ́ jíín ñúyɨ́vɨ chi̱ naa, ko tu̱'un ká'a̱n‑ri̱ chi ma̱ náa.
\v 34 Koto‑ró máá‑ró náva̱'a ma̱ kutéñu añú‑ro̱ jíín já kée ndásɨ́‑ró xí já kóo náji̱ni‑ró. Te ma̱ kútéñu‑ró jíín ndátíñu kuchaku̱‑ro̱, chi̱ sanaa te chaa̱‑ni kɨvɨ̱‑ún sɨkɨ̱‑ro̱.
\v 35 Chi̱ nátu̱'un ɨɨn xeyu̱, súan jinu̱ sɨkɨ̱ táká ña̱yɨvɨ káxiu̱kú nɨ́ɨ́ ñúyɨ́vɨ yá'a.
\v 36 Núsáá te kundito‑ró táká kɨvɨ̱, te kaka̱n ta'u̱‑ro̱ náva̱'a kuu ka̱ku‑ró núu̱ táká tu̱ndó'o ja̱ kíi‑ún, te kundii̱‑ro̱ núu̱ máá Sé'e cha̱a. Achí‑ya̱.
\v 37 Te ndɨta'a̱n kɨvɨ̱ ní stá'a̱n‑ya̱ tú'un ini̱ ve̱'e ii̱. Te ndɨta'a̱n akuáa ní kenda‑ya̱ kuá'a̱n‑ya̱ ondé yuku Olivos. Te yúan ni̱ ndo̱o‑ya̱.
\v 38 Te ta̱ká ña̱yɨvɨ, ña'a̱n chákoyo‑i nuu̱‑yá ini̱ ve̱'e ii̱, náva̱'a kuni so̱'o‑i tu̱'un ká'a̱n‑ya̱.
\c 22
\s1 Ja̱ ní ka̱natɨɨn tu̱'un tá'an sɨkɨ̱ Jesús
\p 
\v 1 Yúan‑na te ni̱ kuyani viko kóo sta̱tilá tú yí'i yujan íá, ja̱ nání víko Pascua.
\v 2 Te ta̱ká sutu̱ ñá'nu jíín táká cha̱a káchaa tutu̱, ni̱ ka̱ndúkú sá'í‑de modo ndasa ka'ni‑dé‑ya̱, chi ni̱ kayu̱'ú‑de ni̱ ka̱jito‑de ña̱yɨvɨ.
\v 3 Te ni̱ kɨ̱vɨ Satanás ini̱ Judas, cha̱a nání Iscariote, ɨɨn tá'an ja̱ uxí uu̱‑ún kúu‑de.
\v 4 Te cha̱a‑ún, ni̱ kee‑de kua'a̱n‑de. Te ni̱ ndatu̱'ún‑de jíín sutú ñá'nu jíín cháa kákuu jefe nú ndasa nastúu‑de Jesús.
\v 5 Te máá cháa‑ún ni̱ ka̱kusɨɨ̱ iní‑de. Te ni̱ ka̱kee yu'u‑dé ja̱ kuá'a‑de xu̱'ún núu̱ Judas.
\v 6 Te ni̱ jatu̱'un Judas. Te ni̱ ndúkú‑de modo ndasa nastúu‑de‑ya̱ núu̱ sutú jíná'an náva̱'a tú kuvaa̱ ña̱yɨvɨ.
\s1 Viko lélú Pascua
\p 
\v 7 Te ni̱ jaa̱ viko kóo sta̱tilá tú yí'i yujan íá. Te máá kɨvɨ́‑ún jínu ñú'ún ká'ni‑í lélú Pascua.
\v 8 Te ni̱ tájí‑yá Pedro jíín Juan kua'a̱n‑de, te ni̱ ka'a̱n‑ya̱ jíín‑de: Kuá'án te sátu̱'a‑ró núu̱ kée‑yo lélú Pascua, áchí‑ya̱.
\v 9 Te ni̱ kaka'a̱n‑de jíín‑yá: Ndénu̱ kuní‑ní sátu̱'a‑ná, áchí‑de.
\v 10 Te ni̱ kachi̱‑ya̱ jíín‑de: Kuni so̱'o, nú a ni̱ jaa̱‑ro̱ iní ñuu̱‑ún, te ketá'an‑ró jíín ɨ́ɨn cha̱a ndíso ɨɨn kɨ̱yi nducha. Kundiki̱n‑ro̱‑dé ki'i̱n‑ro̱ jíín‑de onde̱ ini̱ ve̱'e nuu̱ ndɨ́vɨ‑de.
\v 11 Te ka'a̱n‑ro̱ jíín jíto'o̱ ve'e‑ún: Achí máá Maestro jíín‑ní: Ndénu̱ íó ɨɨn ve'e kua̱'a núu‑ní nuu̱ kée‑ná lélú Pascua jíín cháa káskuá'a jíín‑ná, achi̱‑ro̱.
\v 12 Yúan‑na te jito'o̱‑ún stá'a̱n‑de ɨɨn cuarto ká'nu onde̱ xini̱ vé'e nuu̱‑ro̱, ja̱ á núña. Te yúan sátu̱'a‑ró. Achí‑ya̱.
\v 13 Te kája'a̱n‑de. Te ni̱ kani'i̱n‑dé nátu̱'un ni̱ ka'a̱n‑ya̱ jíín‑de. Te ni̱ ka̱sátu̱'a‑de ndasa kuxíni‑de lélú Pascua.
\v 14 Te ni̱ jaa̱ hora‑ún, te ni̱ jungo̱o‑ya̱ núu̱ mesa. Te suni ni̱ kaju̱ngo̱o apóstol‑ya̱ jíín‑yá.
\v 15 Te ni̱ kachi̱‑ya̱ jíín‑de: Xaa̱n kúu ini̱‑ri̱ kee‑rí lélú Pascua yá'a jíín‑ró jíná'an‑ró ja̱ té ndo'o‑ga̱‑ri̱.
\v 16 Chi̱ kástu̱'ún‑rí nuu̱‑ro̱, ja̱ má kée kútɨ‑gá‑ri̱ Pascua yá'a, onde̱ nú tú skíkuu máá iní ñuu̱ nuu̱ tá'ú Dios tiñu. Achí‑ya̱.
\v 17 Te ni̱ ki'in‑ya̱ ɨ́ɨn taza. Te ni̱ jika̱n ta'u̱‑yá, te ni̱ ka'a̱n‑ya̱: Ki'in ya̱'á. Te saka‑ro núu̱ tá'an‑ró.
\v 18 Chi̱ ká'a̱n‑ri̱ jíín‑ró já ondé vina ma̱ kó'o kutɨ‑gá‑ri̱ nducha ndé'e̱ uva, onde̱ nú tú koo ñuu̱ nuu̱ tá'ú Dios tiñu.
\v 19 Te ni̱ ki'in‑ya̱ stáa̱. Te ni̱ jika̱n ta'u̱‑yá. Te ni̱ sákuáchí‑yá. Te ni̱ ja̱'a‑ya̱ núu̱‑dé jíná'an‑de. Te ni̱ ka'a̱n‑ya̱: Ya̱'á kúu yikɨ kúñu‑ri̱ ja̱ ní jatañaa‑ri̱ ja̱ sɨkɨ́ róó jíná'an‑ró. Ya̱'á sá'a‑ró já núku̱'un ini̱‑ro̱ rúu̱.
\v 20 Suni súan ni̱ sá'a‑ya̱ jíín taza, nuu̱ ní ndɨ'ɨ ni̱ kuxíni‑ya̱. Te ni̱ ka'a̱n‑ya̱: Taza yá'a kúu nɨñi̱‑rí ja̱ sá'a contrato jáá. Te ni̱ jatɨ ja̱ sɨkɨ́ róó jíná'an‑ró.
\v 21 Ko nde̱'é‑ró já cháa nastúu ruu̱, kánchaa̱‑de jíín‑rí nuu̱ mesa yá'a.
\v 22 Chi ja̱ndáa̱, máá Sé'e cha̱a ki'i̱n‑ya̱ íchi já ní sándaa̱ Dios. Ko naka̱ ndá'ú kuu cha̱a nástúu I'a̱‑ún, áchí‑ya̱.
\v 23 Yúan‑na te cha̱a káskuá'a jíín‑yá, ni̱ ka̱kejá'á‑de kájika̱ tu̱'ún tá'an máá‑de, nú ndé ɨɨn‑de kúu cha̱a sá'a tiñu yá'a.
\s1 Ja̱ ní ka̱státá'an‑de ndé cha̱a kúñá'nu‑ga̱
\p 
\v 24 Te ni̱ ka̱kejá'á‑de kástátá'an máá‑de nú ndé ɨɨn‑de kúñá'nu‑ga̱ nuu̱ tá'an‑de.
\v 25 Yúan‑na te máá‑yá ni̱ ka'a̱n‑ya̱ jíín‑de: Ta̱ká rey, chi̱ nuu̱ táká ña̱yɨvɨ kátá'ú téyíí‑de tiñu. Te cha̱a kákuñá'nu nuu̱ máá‑i, cha̱a kásá'a va̱'a káskúnání‑i‑de.
\v 26 Ko sɨkɨ̱ róó jíná'an‑ró na̱ tú súan koo. Ndé róó ja̱ kúñá'nu‑ga̱, ná ndúu‑ró nátu̱'un cha̱a súchí‑ga̱. Te ndé róó ja̱ kúñá'nu‑ga̱‑ro̱, ná ndúu‑ró nátu̱'un cha̱a játíñu nuu̱ tá'an‑ró.
\v 27 Te ndéja̱ kúñá'nu‑ga̱ íó, á cha̱a yée stáa̱ núu̱ mesa, xí cháa játíñu. Nasu̱ cháa ja̱ yée stáa̱ núu̱ mesa náún. Te ruu̱, nátu̱'un cha̱a játíñu kúu‑ri̱ nuu̱‑ro̱.
\v 28 Ko máá‑ró jíná'an‑ró, ni̱ ka'i̱in‑ró jíín‑rí va̱sa kájito nchaa̱‑i ruu̱.
\v 29 Te nátu̱'un ni̱ ja̱'a Táa̱‑ri̱ ɨɨn ñuu̱ ja̱ tá'ú‑rí tiñu nuu̱, suni súan kua̱'a‑ri̱ nuu̱‑ro̱.
\v 30 Náva̱'a kee‑ro kó'o‑ró núu̱ mesa jíín‑rí ini̱ ñuu̱ nuu̱ tá'ú‑rí tiñu. Te jungo̱o‑ró núu̱ silla. Te sándaa̱‑ro̱ tíñu ndɨ́'uxí uu̱ tata̱ Israel.
\s1 Tu̱'un Pedro jíín lí'li
\p 
\v 31 Te suni ni̱ ka'a̱n máá Jíto'o̱‑yo̱: Simón, Simón, kuni so̱'o‑ró, chi ni̱ jika̱n Satanás róó jíná'an‑ró ja̱ síjin‑ún róó nátu̱'un trigo.
\v 32 Ko ni̱ jika̱n ta'u̱‑rí ja̱ kúu róó náva̱'a ma̱ náyu̱'ú‑ro̱. Te máá‑ró, nú a ni̱ naxíó káva ini̱‑ro̱, te ná síyíja‑ró táká ñani̱‑ro̱. Achí‑ya̱.
\v 33 Te ni̱ ka'a̱n‑de jíín‑yá: Táta̱, a kándii̱ tu̱'a‑ná ja̱ kí'i̱n‑ná jíín‑ní va̱sá veka̱a te kuu̱‑yo̱, áchí‑de.
\v 34 Te ni̱ ka'a̱n‑ya̱: Pedro, áchí‑ri̱ jíín‑ró, ja̱ ondé ná té kana‑ga̱ lí'li vina te uni̱ jínu ka'a̱n‑ro̱ já tú jiní kutɨ‑ro rúu̱, áchí‑ya̱.
\v 35 Yúan‑na te ni̱ jika̱ tu̱'ún‑yá‑de: Ná ni̱ tájí‑rí róó ni̱ kaja'a̱n‑ro̱ já tú ní kándi̱so‑ró ñúnu, ni bolsa, ni tú ní káyi̱'i‑ró ndiján, á ni̱ kumani̱ ɨ́ɨn ndatíñu nuu̱‑ro̱ náún, áchí‑ya̱. Te ni̱ kaka'a̱n‑de: Tú ni ɨɨn, áchí‑de.
\v 36 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ko vina, cha̱a ñáva̱'a ñunu, ná náki'in‑de. Te suni súan jíín bolsa. Te cha̱a ja̱ tú na̱ún ñáva̱'a‑de, ná xíkó‑de tɨka̱chí‑de te ná kuáan‑de ɨɨn machete.
\v 37 Chi̱ ká'a̱n‑ri̱ jíín‑ró, ja̱ kánúú skíkuu‑ri̱ tu̱'un yá'a ja̱ yóso núu̱ tutú: Te onde̱ jíín cháa ñáá ni̱ skétá'an‑de‑ya̱, áchí. Chi ta̱ká tu̱'un‑ri̱ ja̱ yóso ná skíkuu ná'ín, áchí‑ya̱.
\v 38 Yúan‑na te ni̱ kaka'a̱n‑de: Táta̱, yá'a íó uu̱ machete, áchí‑de. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Suu jia̱n‑ni, áchí‑ya̱.
\s1 Jesús ini̱ Jardín Getsemaní
\p 
\v 39 Te ni̱ kenda‑ya̱. Te ni̱ kee‑ya̱ kuá'a̱n‑ya̱ ondé yuku Olivos nátu̱'un sá'a sá'a‑ya̱. Te cha̱a káskuá'a jíín‑yá, suni kája'a̱n‑de jíín‑yá.
\v 40 Te nuu̱ ní jaa̱‑ya̱ yúan, te ni̱ kachi̱‑ya̱ jíín‑de: Kaka̱n ta'u̱ jíná'an‑ró náva̱'a tú koto nchaa̱‑i róó, áchí‑ya̱.
\v 41 Te ni̱ kuxio‑ya̱ núu̱‑dé kua'a̱n‑ya̱ nátu̱'un ɨɨn nuu̱ skánda yuu̱. Te ni̱ jukuiñi̱ jítɨ́‑yá. Te ni̱ jika̱n ta'u̱‑yá.
\v 42 Táa̱, nú játa'a̱n ini̱‑ní te chaxio‑ní tu̱ndó'o‑ná yá'a ná kí'i̱n, ko nasu̱ já kuní máá‑ná, chi ja̱ kuní máá‑ní ná kúu, áchí‑ya̱.
\v 43 Te ni̱ kenda ɨɨn ndajá'a̱ ándɨ́vɨ́ ní jaa̱ nuu̱‑yá. Te ni̱ ka'a̱n ɨɨn tu̱'un ndéé iní jíín‑yá.
\v 44 Te ni̱ ndukuí'a̱ xaa̱n iní‑ya̱. Te ni̱ ndúkú ndéé téyíí‑ga̱‑ya̱ ní jika̱n ta'u̱‑yá. Te ni̱ kana tañi̱‑yá ja̱ ní to̱o onde̱ nuu̱ ñú'un nátu̱'un yúyú ná'nu nɨñi̱.
\v 45 Te nuu̱ ní ndukuiñi̱‑ya̱ já ní ndɨ'ɨ ni̱ jika̱n ta'u̱‑yá, te ni̱ najaa̱‑ya̱ núu̱ cháa káskuá'a jíín‑yá. Te ni̱ jini̱‑ya̱ já kákixi̱‑de, chi̱ kándukuí'a̱ ini̱‑de.
\v 46 Te ni̱ kachi̱‑ya̱ jíín‑de: Naja̱ kákixi̱‑ro̱. Nduko̱o, te kaka̱n ta'u̱‑ro̱ náva̱'a tú koto nchaa̱‑i róó, áchí‑ya̱.
\s1 Ja̱ ní ka̱katɨɨn‑de Jesús
\p 
\v 47 Te nini sásúan ká'a̱n‑ya̱, te ni̱ ja̱koyo kua'a̱ ñáyɨvɨ. Te ɨɨn cha̱a nání Judas, ɨɨn tá'an ja̱ uxí uu̱‑ún, yóxnúú‑de nuu̱ ñáyɨvɨ‑ún ni̱ jaa̱‑de. Te ni̱ kandita‑de nuu̱ Jesús ja̱ tíyú'ú‑de‑ya̱.
\v 48 Yúan‑na te ni̱ ka'a̱n Jesús jíín‑de: Judas, tiyú'ú‑ró rúu̱ te súan nastúu‑ró máá Sé'e cha̱a náún. Achí‑ya̱.
\v 49 Te cha̱a ká'i̱in jíín Jesús, ni̱ kajini̱‑de ndasa kua̱kuu. Te ni̱ kaka'a̱n‑de jíín‑yá. Táta̱, stují‑yo̱‑dé jíín machete xí túu, áchí‑de.
\v 50 Te ɨɨn máá cháa‑ún, ni̱ stují‑ní‑de ɨɨn mozo máá sutú ñá'nu‑ga̱. Te ni̱ kachi‑de so̱'o lado vá'a.
\v 51 Yúan‑na te ni̱ ka'a̱n Jesús: Sía̱, áchí‑ya̱. Te ni̱ ké'é‑yá so̱'o mozo‑ún, te ni̱ nasáva̱'a‑ya̱.
\v 52 Te ni̱ ka'a̱n Jesús jíín sutú ñá'nu‑ún jíín cháa kákuu jefe ini̱ ve̱'e ii̱ jíín cháa ni̱ ka̱yii, ja̱ ní cha̱koyo‑de sɨkɨ̱‑yá: Nátu̱'un sɨkɨ̱ ɨ́ɨn cha̱a kuí'ná vái koyo‑ró jíín machete jíín yúnu náún.
\v 53 Ndɨta'a̱n kɨvɨ̱ ní ka̱ndee‑ri̱ jíín‑ró iní ve̱'e ii̱ te tú ní kákatɨɨn‑ró rúu̱. Ko ya̱'á kúu hora máá‑ró jíín fuerza ñu̱ñáa. Achí‑ya̱.
\s1 Ja̱ tú ní játu̱'un Pedro
\p 
\v 54 Te ni̱ ka̱katɨɨn‑de‑ya̱ kuá'a̱n‑de jíín‑yá. Te ni̱ kaskɨ́vɨ‑de‑ya̱ iní ve̱'e sutu̱ ñá'nu‑ga̱. Te Pedro, jíká‑ni ndikín‑de‑ya̱.
\v 55 Te sava ña̱yɨvɨ, ni̱ ka̱nastá'a̱n‑i ɨɨn ñu'u̱n yata̱ vé'e‑ún. Te ni̱ ka̱nakuíkó ndúu̱‑i káxiu̱kú‑i. Te Pedro, suni ni̱ jungo̱o‑de jíín ñáyɨvɨ‑ún.
\v 56 Te ɨɨn ña'an játíñu ini̱ ve̱'e‑ún, ni̱ jini̱‑ña núu̱‑dé ja̱ kánchaa̱‑de yuñú'u̱n yúan. Te ni̱ nde̱'é vá'a‑ña núu̱‑dé. Te ni̱ ka'a̱n‑ña: Te cha̱a yá'a, suni jíka‑de jíín cháa‑ún vii, áchí‑ña.
\v 57 Yúan‑na te máá‑de, tú ní játu̱'un‑de: Nána̱, na̱ tú jiní‑ná cha̱a‑ún, áchí‑de.
\v 58 Te ni̱ kunúu ɨɨn tí'lí‑ga̱. Te ni̱ jini̱ tuku ɨnga̱‑de nuu̱ Pedro te ni̱ ka'a̱n‑de: Te róó, suni tá'an‑de kúu‑ró vii, áchí. Te ni̱ ka'a̱n Pedro: Hombre, nasu̱ú kúu‑ri̱, achí‑de.
\v 59 Te nátu̱'un ɨɨn hora‑ga̱ te ni̱ kachi̱ ɨnga̱‑de: Ja̱ndáa̱ ja̱ cháa yá'a, suni jíka‑de jíín cháa‑ún, chi cha̱a ñuu̱ Galilea kúu‑de, áchí.
\v 60 Te ni̱ ka'a̱n Pedro: Hombre, tú jiní kutɨ‑rí na̱ún tu̱'un ká'a̱n‑ro̱, áchí‑de. Te nini súan ká'a̱n‑de, te ni̱ kana‑ni lí'li.
\v 61 Yúan‑na te ni̱ xíó kóto máá Jíto'o̱‑yo̱. Te ni̱ nde̱'é‑yá nuu̱ Pedro. Te ni̱ nuku̱'un ini̱‑de tu̱'un ni̱ ka'a̱n máá Jíto'o̱‑yo̱ jíín‑de: Onde̱ ná té kana‑ga̱ lí'li, te ma̱ kuátu̱'un‑ró rúu̱ uni̱ jínu, áchí‑ya̱.
\v 62 Te ni̱ kenda Pedro kua'a̱n‑de. Te ni̱ nde'e̱ xaa̱n‑dé.
\s1 Ja̱ ní ka̱sákátá‑de nuu̱‑yá
\p 
\v 63 Te ta̱ká cha̱a kándi̱to Jesús, ni̱ ka̱sákátá‑de nuu̱‑yá. Te ni̱ ka̱stují‑dé‑ya̱.
\v 64 Te ni̱ kajasu̱‑de nuu̱‑yá. Te ni̱ ka̱stují‑dé nuu̱‑yá. Te ni̱ kajika̱ tu̱'ún‑de‑ya̱: Kastu̱'ún, ndé cha̱a ni̱ stují róó, áchí‑de.
\v 65 Te íó kua'a̱‑gá tu̱'un ni̱ kaka'a̱n‑de sɨkɨ̱‑yá ja̱ ní ka̱sá'a ndɨva̱'a‑de jíín‑yá.
\s1 Ja̱ ní kajancha̱ka‑de‑ya̱ núu̱ junta
\p 
\v 66 Te nuu̱ ní kundiji̱n, te ni̱ ka̱nataka̱ cha̱a ni̱ ka̱yii, jíín sutú ñá'nu jíín cháa káchaa tutu̱, ni̱ kaja̱ncha̱ka‑de‑ya̱ núu̱ junta máá‑de.
\v 67 Te ni̱ kaka'a̱n‑de: Máá‑ró kúu máá Cristo, náún. Kachi̱ nuu̱‑rí, áchí‑de. Te ni̱ kachi̱‑ya̱ jíín‑de: Va̱sa ná kachí‑ri̱ nuu̱‑ro̱, te ni ma̱ kándíja kutɨ‑ro.
\v 68 Te suni nú ruu̱ xndichí‑ri̱ róó, te ma̱ xndíó káni‑ró tú'un nuu̱‑rí. Te ni ma̱ sía̱‑ro̱ rúu̱.
\v 69 Ko onde̱ vina te máá Sé'e cha̱a kunchaa̱‑ya̱ íchi ndává'a nuu̱ íó fuerza Dios, áchí‑ya̱.
\v 70 Te ndɨ'ɨ‑de, ni̱ kajika̱ tu̱'ún‑de‑ya̱: Núsáá te máá‑ró kúu Se̱'e Dios náún, áchí‑de. Te ni̱ kachi̱‑ya̱ jíín‑de: Máá‑ró káka'a̱n ja̱ rúu̱ kúu, áchí‑ya̱.
\v 71 Yúan‑na te ni̱ kaka'a̱n‑de: Na̱ún nɨ́nɨ kúni so̱'o‑ga̱‑yo̱ ká'a̱n ɨnga̱ cha̱a núsáá, chi̱ jíín yú'u máá‑de ni̱ ka̱jini so̱'o‑yó vína, áchí‑de.
\c 23
\s1 Ja̱ kuá'a̱n Jesús nuu̱ Pilato
\p 
\v 1 Yúan‑na te ni̱ ka̱ndonda ndɨ'ɨ‑de ni̱ kaja̱nchaka‑de‑ya̱ núu̱ Pilato.
\v 2 Te ni̱ kejá'á‑de kásátú'ún‑de sɨkɨ̱‑yá: Cha̱a yá'a ni̱ kani'i̱n‑ná‑de ja̱ sáká núu‑de xini̱ ñáyɨvɨ ñúu̱‑yo̱. Te tú já'a‑de tu̱'un kua̱'a‑yó xú'ún yóo̱ nuu̱ César. Te ká'a̱n‑de ja̱ máá‑de kúu Cristo Rey, áchí.
\v 3 Yúan‑na te Pilato, ni̱ jika̱ tu̱'ún‑de‑ya̱: Máá‑ró kúu Rey ña̱yɨvɨ judío náún, áchí‑de. Te máá‑yá ni̱ ka'a̱n‑ya̱: Ká'a̱n ndaa̱‑ro̱, áchí‑ya̱.
\v 4 Te ni̱ kachi̱ Pilato jíín táká sutu̱ ñá'nu jíín ñáyɨvɨ kuá'a̱‑ún: Tú ni ɨɨn kua̱chi ní'i̱n‑rí sɨkɨ̱ cháa yá'a, áchí‑de.
\v 5 Ko máá cháa‑ún, ví'í‑gá ni̱ kaka'a̱n‑de: Xaa̱n kúvaa̱ ña̱yɨvɨ sá'a‑de jíín tú'un stá'a̱n‑de nɨ́ɨ́ ñúu̱ Judea, ni̱ kejá'á‑de onde̱ ñuu̱ Galilea te ni̱ kenda‑de onde̱ yá'a, áchí‑de.
\s1 Ja̱ kándii̱ Jesús nuu̱ Herodes
\p 
\v 6 Yúan‑na te Pilato, ja̱ ní jini so̱'o‑de ja̱ Galilea káka'a̱n, te ni̱ jika̱ tu̱'ún‑de nú cha̱a ñuu̱ Galilea kúu‑ya̱.
\v 7 Te nuu̱ ní juku̱'un ini̱‑de ja̱ ndá'a Herodes yí'i ñuu̱‑ya̱, te ni̱ tájí‑de‑ya̱ kuá'a̱n‑ya̱ núu̱ Herodes chi̱ kɨvɨ̱‑ún suni kándee Herodes ini̱ ñuu̱ Jerusalén.
\v 8 Te nuu̱ ní jini̱ Herodes nuu̱ Jesús, ni̱ kusɨɨ̱ xáa̱n iní‑de, chi̱ íó kua'a̱ kɨvɨ́ kuní‑de nde̱'é‑de nuu̱‑yá, chi ni̱ jini tu̱'un‑de kua'a̱ tú'un sɨkɨ̱‑yá. Te ñúkuu ini̱‑de ja̱ sá'a‑ya̱ ɨ́ɨn tuni̱ nuu̱‑dé.
\v 9 Te xaa̱n ní xndichí‑de‑ya̱. Ko tú ni ɨɨn tu̱'un ní xndíó káni‑ya̱ núu̱‑dé.
\v 10 Te ta̱ká sutu̱ ñá'nu jíín táká cha̱a káchaa tutu̱, ká'i̱in‑de yúan, kásátú'ún téyíí‑ga̱‑de sɨkɨ̱‑yá.
\v 11 Yúan‑na te Herodes jíín soldado‑de, ni̱ kasándɨva̱'a‑de jíín‑yá. Te ni̱ ka̱sákátá‑de nuu̱‑yá. Te ni̱ chu'un‑de‑ya̱ ɨ́ɨn sa'ma tɨ́ndu̱'á. Te ni̱ na̱tájí tuku‑de‑ya̱ kuáno'on‑yá nuu̱ Pilato.
\v 12 Te suni máá kɨvɨ́‑ún, ni̱ ka̱nakuni̱ mani̱ tá'an Herodes jíín Pilato, chi̱ aná'án chi̱ kájito u'u̱ tá'an‑de núú.
\v 13 Yúan‑na te ni̱ kana Pilato xini̱ táká sutu̱ ñá'nu, jíín táká cha̱a kákuu jefe jíín táká ña̱yɨvɨ. Te ni̱ ka̱ndutútú‑i.
\v 14 Te ni̱ ka'a̱n‑de jíín‑i: Ni̱ ka̱kinchaka‑ró cháa yá'a nuu̱‑rí, ja̱ sáká núu‑de xini̱ ñáyɨvɨ, áchí‑ro̱. Te vina a ni̱ xndichí‑ri̱‑de jíto nuu̱ máá‑ró. Te tú ni ɨɨn kua̱chi ní ní'i̱n‑rí sɨkɨ̱‑dé nátu̱'un kásátú'ún‑ró,
\v 15 te ni Herodes, chi ni̱ tájí‑rí‑de ni̱ ja'a̱n‑de yúan. Te tú ni ɨɨn kua̱chi ní sá'a‑de ja̱ ká'ni‑yo‑dé.
\s1 Ja̱ kuá'a̱n tuku‑ya̱ núu̱ Pilato
\p 
\v 16 Núsáá te ná xndó'o‑ri̱‑de te sía̱‑ri̱‑de ki'i̱n‑de. Achí‑de.
\v 17 Chi̱ ndɨta'a̱n viko‑ún kánúú já sía̱‑de ɨɨn preso.
\v 18 Ko ta̱ká ña̱yɨvɨ kuá'a̱‑ún, ɨɨn núú‑ni ni̱ ka̱kana jaa‑i: Ka'ni‑ní cha̱a yá'a. Te sía̱‑ní Barrabás ná kí'i̱n‑de, áchí‑i.
\v 19 Te Barrabás, kándee‑de veka̱a kua̱chi ja̱ ní xndónda‑de‑i ni̱ ka̱nakua̱tá'an máá‑i, te ni̱ ja'ni‑dé ɨɨn ndɨ̱yi.
\v 20 Te ni̱ ka'a̱n tuku Pilato jíín‑i, chi̱ sía̱‑de Jesús kuní‑de núú.
\v 21 Ko máá‑i ni̱ kakana jaa tuku‑i: Ka'ni‑ní‑de jika̱ cruz, kata kaa‑ní‑de, áchí‑i.
\v 22 Te ni̱ ka'a̱n tuku‑de jíín‑i vuelta uni̱: Te na̱ún kua̱chi ni̱ sá'a cha̱a yá'a vii. Tú ní'i̱n kútɨ‑rí ni ɨɨn kua̱chi sɨkɨ̱‑dé ja̱ kúu̱‑de. Núsáá te xndó'o‑ri̱‑de, te sía̱‑ri̱‑de ki'i̱n‑de. Achí Pilato.
\s1 Ja̱ ní ka̱jata kaa‑de‑ya̱
\p 
\v 23 Ko ɨɨn jínu‑ni ni̱ ka̱kana jaa ña̱yɨvɨ‑ún, ni̱ kajika̱n‑i ja̱ ná kúu̱‑ya̱ jiká cruz. Te máá‑i jíín táká sutu̱ ñá'nu, ni̱ ka̱kana jaa téyíí‑i. Te yu̱án ní kundéé‑i jíín Pilato.
\v 24 Yúan‑na te Pilato, ni̱ sándaa̱‑de ja̱ ná kúu ja̱ ní kajika̱n‑i.
\v 25 Te ni̱ sía̱ Pilato cha̱a ni̱ ka̱ndee veka̱a sɨkɨ̱ já ní xndónda‑de‑i ni̱ ka̱nakua̱tá'an máá‑i te ni̱ ja'ni‑dé ndɨ̱yi. Chi̱ súan ni̱ kajika̱n ña̱yɨvɨ‑ún. Te ni̱ nakua̱'a‑de Jesús nuu̱‑í ja̱ ná sá'a‑i ndasa kákuu ini̱ máá‑i jíín‑yá.
\v 26 Te ni̱ ka̱kiñi'in‑i‑ya̱. Te ni̱ ka̱katɨɨn‑i ɨɨn cha̱a nání Simón ñuu̱ Cirene ja̱ vái‑de ichi rancho. Te ni̱ ka̱chaa‑i cruz sɨkɨ̱‑dé. Te ndíso‑de kua'a̱n‑de yata̱ Jesús.
\v 27 Te kua'a̱ ñáyɨvɨ jíín ñá'an, ni̱ kandiki̱n‑i yata̱‑yá. Te ña'an‑ún, kánde'e̱‑ña te kákana jíkó'ó‑ña já'a̱‑yá.
\v 28 Ko máá Jesús, ni̱ xíó kóto‑ya̱ núu̱‑ñá. Te ni̱ ka'a̱n‑ya̱ jíín‑ña: Se̱'e ñuu̱ Jerusalén, ma̱ ndé'e̱‑ro̱ já'a̱‑rí. Nde'e̱ ja'a̱ máá‑ró jíín já'a̱ sé'e‑ró jíná'an‑i.
\v 29 Te kuni so̱'o‑ró, chi̱ chaa̱ kɨvɨ̱ já ká'a̱n‑i: Xáán ndatu̱ ña'an numá, jíín já tú ní skáku se̱'e, jíín já tú ní skáxin‑í, achi̱‑i.
\v 30 Yúan‑na te ka'a̱n ña̱yɨvɨ jíín táká yuku: Ndua̱ sɨkɨ̱‑rí jíná'an‑ri̱. Te suni jíín táká tɨnduu̱: Kasu̱ sɨkɨ̱‑rí jíná'an‑ri̱, achi̱‑i.
\v 31 Chi̱ nú jíín yúnu yí'í kásá'a‑de tiñu yá'a, te ndasa sá'a‑de jíín yúnu íchí núsáá, áchí‑ya̱.
\v 32 Te suni ni̱ i̱o uu̱ cha̱a ká'i̱o kua̱chi kája'a̱n‑de jíín‑yá ja̱ kúu̱‑de.
\v 33 Te ni̱ ja̱koyo‑i jíín‑yá tɨnduu̱ nání yíkɨ xiní, te yúan ni̱ ka̱jata kaa‑i‑ya̱ jiká cruz. Te suni ni̱ ka̱jata kaa‑i ndendúú cha̱a ká'i̱o kua̱chi‑ún, ɨɨn‑de ichi ndává'a‑ya̱, te ɨnga̱‑de ichi ndávésé‑yá.
\v 34 Te ni̱ ka'a̱n Jesús: Táa̱, sá'a‑ní tu̱ká'nu ini̱‑ní nuu̱‑í, chi̱ tú kájini̱‑i na̱ún kásá'a‑i, áchí‑ya̱. Te ni̱ ka̱ndátá‑i sa'ma‑yá, ni̱ ka̱sá'a‑i ɨɨn apuesto sɨkɨ̱.
\v 35 Te ña̱yɨvɨ ká'i̱in yúan kánde̱'é‑i nuu̱‑yá. Te cha̱a kákuñá'nu, suni ni̱ ka̱sákátá‑de nuu̱‑yá. Te ni̱ kaka'a̱n‑de: Sava ña̱yɨvɨ á ni̱ kuu ni̱ nama‑de. Ná náma‑de máá‑de, te nú Cristo I'a̱ ni̱ ka̱ji Dios kúu‑de, áchí‑de.
\v 36 Te soldado, suni ni̱ ka̱sákátá‑de nuu̱‑yá. Te ni̱ ka̱kandita‑de nuu̱‑yá. Te kája̱'a‑de vinagre ko'o‑ya̱.
\v 37 Te ni̱ kaka'a̱n‑de jíín‑yá: Nú máá‑ró kúu rey ña̱yɨvɨ judío, te ná náma‑ró máá‑ró, áchí‑de.
\v 38 Te suni ni̱ i̱o ɨɨn tutu̱ yoso sɨkɨ̱‑yá jíín yú'u griego, jíín latín, jíín hebreo: Ya̱'á kúu Rey ña̱yɨvɨ judío, áchí.
\v 39 Te ɨɨn máá cháa íó kua̱chi‑ún ja̱ ndíta kaa‑de, ni̱ ka'a̱n ndɨva̱'a‑de jíín‑yá: Nú máá‑ró kúu Cristo, te ná náma‑ró máá‑ró te suni nama‑ró rúu̱ jíná'an‑ri̱ núsáá, áchí‑de.
\v 40 Ko ɨnga̱‑de, ni̱ ka'a̱n xaa̱n‑dé nuu̱ tá'an‑de: Tú íó ja̱ jíñú'ún‑ró núu̱ Dios náún, chi̱ ɨɨn núú‑ni tá'nu̱ ndatu̱‑ro̱ jíín‑yá.
\v 41 Chi̱ máá‑yó, ja̱ndáa̱ va̱tu‑ni ndó'o‑yó yá'a, chi̱ súan kúta'u̱‑yo̱ táká tiñu ni̱ sá'a‑yó, Ko I'a̱ yá'a, tú ni ɨɨn kua̱chi ní sá'a‑ya̱, áchí‑de.
\v 42 Te ni̱ ka'a̱n‑de jíín Jesús: Nuku̱'un ini̱‑ní náá nú ni̱ najaa̱‑ní ini̱ ñuu̱ nuu̱ tá'ú‑ní tiñu, áchí‑de.
\v 43 Yúan‑na te ni̱ ka'a̱n Jesús jíín‑de: Ja̱ndáa̱ ká'a̱n‑ri̱ jíín‑ró, ja̱ vína te kunchaa̱‑ro̱ jíín‑rí nuu̱ jardín andɨ́vɨ́, áchí‑ya̱.
\v 44 Te nuu̱ ní kuu nátu̱'un ka̱xiuu̱, te ni̱ kuxkɨ́'vɨ̱ nɨ́ɨ́ núu̱ ñú'un onde̱ ka̱'uni̱.
\v 45 Te ni̱ kutúún ndika̱ndii. Te sa'ma ndíta kaa ini̱ ve̱'e ii̱, ni̱ ndata̱ sáva sava.
\v 46 Yúan‑na te ni̱ ka'a̱n jaa Jesús: Táa̱, ini̱ nda'a‑ní nákua̱'a‑ná añú‑ná, áchí‑ya̱. Te súan ni̱ ka'a̱n‑ya̱, te ni̱ ji'i̱‑ni‑ya̱.
\v 47 Te cha̱a capitán, nuu̱ ní jini̱‑de ja̱ súan ni̱ kuu, te ni̱ nakana jaa‑de Dios: Ndaa̱ ndija ja̱ cháa yá'a ɨɨn cha̱a ndaa̱ ni̱ kuu‑de, áchí‑de.
\v 48 Te ndivii ñáyɨvɨ ká'i̱in yúan, ni̱ kajini̱‑i ja̱ súan ni̱ kuu. Te ni̱ ka̱naxíó káva‑i kákani‑i ji̱kí jiká‑í kája'a̱n‑i.
\v 49 Ko ta̱ká cha̱a kájini̱ tá'an jíín‑yá, jíín táká ña'an kándiki̱n‑ña‑yá onde̱ ñuu̱ Galilea, ká'i̱in jíká‑ña kánde̱'é‑ña táká tiñu yá'a.
\s1 Ja̱ ní ka̱chiyu̱ji‑de‑ya̱
\p 
\v 50 Te ni̱ i̱o ɨɨn cha̱a nání José, cha̱a vá'a cha̱a ndaa̱ kúu‑de. Te suni ɨɨn cha̱a junta kúu‑de.
\v 51 Ko tú ní játa'a̱n ini̱‑de tu̱'un ni̱ kanda̱tu̱'ún junta‑ún ni tiñu ni̱ ka̱sándaa̱‑ún. Te ñuu̱ Arimatea ini̱ ñuu̱ Judea ncháá‑de. Te ñúkuu ini̱‑de koo ñuu̱ nuu̱ tá'ú Dios tiñu.
\v 52 Cha̱a yá'a, ni̱ jaa̱‑de nuu̱ Pilato. Te ni̱ jika̱n‑de yikɨ kúñu Jesús.
\v 53 Te ni̱ janchaa̱‑de‑ya̱. Te ni̱ chisúkun‑dé‑ya̱ jíín ɨ́ɨn sa'ma kuítá. Te ni̱ chindee‑de‑ya̱ iní ve̱'e añú ja̱ ní jacha jika̱ ɨ́ɨn kava nuu̱ tú kundu̱ji‑ga̱ ni ɨɨn ndɨyi.
\v 54 Te kɨvɨ̱ xía̱n‑ún koo viko Pascua. Te a yani kundiji̱n kɨvɨ̱ ndéta̱tú.
\v 55 Te ña'an ní kikoyo jíín‑yá onde̱ ñuu̱ Galilea, káindiki̱n‑ña̱ José kua'a̱n‑ña jíín‑de. Te ni̱ kajini̱‑ña yaú kava‑ún nuu̱ ní yu̱ji yikɨ kúñu‑ya̱.
\v 56 Te ni̱ ka̱naxíó káva‑ña káno'o̱n‑ña. Te ni̱ ka̱sátu̱'a‑ña jí'o jíín perfume, te ni̱ kandéta̱tú‑ña kɨvɨ́ ndéta̱tú‑ún, nátu̱'un ni̱ tá'ú tíñu ley.
\c 24
\s1 Ja̱ ní nachaku̱ Jesús
\p 
\v 1 Te tɨ́kuáán‑na̱ kɨvɨ̱ ɨ́ɨn semana ni̱ ja̱koyo‑ña yaú kava‑ún, kái̱ndá'á‑ña táká ji̱'o ni̱ kasátu̱'a‑ña. Te suni kája'a̱n sava‑ga̱ ña'an jíín‑ña.
\v 2 Te ni̱ kajini̱‑ña já ní kuxio yuu̱ ndí'u̱ yu'u yaú kava‑ún kua'a̱n.
\v 3 Te ni̱ kɨ̱vɨ koyo‑ña. Te tú ní kájini̱‑ña yíkɨ kúñu máá Jíto'o̱‑yo̱ Jesús.
\v 4 Te nini kákuñáá ini̱‑ña já súan ni̱ kajini̱‑ña, te uu̱ cha̱a káñu̱'un sa'ma kuíjín kándii ncháa̱, ni̱ ka̱jukuiñi̱‑ni‑de xiin‑ñá.
\v 5 Te ni̱ kayu̱'ú‑ña. Te ni̱ kaja̱xin‑ña núu̱‑ñá nuu̱ ñú'un. Te ni̱ kaka'a̱n cha̱a‑ún jíín‑ña: Naja̱ sá ma̱'ñú ndɨ́yi kánandúkú‑ró I'a̱ chakú.
\v 6 Túu‑ya̱ yá'a, chi̱ a ni̱ nachaku̱‑ya̱. Á tú ná'án‑ró ndasa ni̱ ka'a̱n‑ya̱ jíín‑ró ná ni̱ ka̱ndee‑ga̱‑ya̱ ondé ñuu̱ Galilea núú.
\v 7 Chi ni̱ ka'a̱n‑ya̱: Jínu ñú'ún já máá Sé'e cha̱a natu̱u‑ya̱ núu̱ ndá'a cháa ká'i̱o kua̱chi, te kuu̱‑ya̱ jiká cruz, te nachaku̱‑ya̱ kɨvɨ́ uní. Achí.
\v 8 Yúan‑na te ni̱ kanu̱ku̱'un ini̱‑ña tú'un ni̱ ka'a̱n‑ya̱ jíín‑ña.
\v 9 Te ni̱ kenda‑ña yaú kava‑ún káno'o̱n‑ña. Te ni̱ kaka̱stu̱'ún‑ña tú'un yá'a nuu̱ ndɨ́'uxí ɨɨn‑de jíín táká nuu̱ sáva‑ga̱‑de.
\v 10 Te ña'an kákastu̱'ún tú'un yá'a nuu̱ apóstol kákuu María ñuu̱ Magdala, jíín Juana, jíín ɨngá María náa̱ Jacobo, jíín sáva‑ga̱‑ña.
\v 11 Ko máá apóstol, kájani ini̱‑de ja̱ tú'un tá'a̱n tachi̱ káka'a̱n‑ña. Te tú ní kákandíja‑de.
\v 12 Te ni̱ ndukuiñi̱‑ni Pedro. Te ni̱ jinu‑de kua'a̱n‑de onde̱ yau̱ kava‑ún. Te ni̱ jukui̱ta ndee‑de. Te ni̱ jini̱‑de ja̱ sá'ma kuítá‑ún kánda̱a‑na̱ máá. Te ni̱ kee‑de kua̱no'on‑dé ve'e‑de jáni ini̱‑de na̱ún ní kuu.
\s1 Ja̱ ní ketá'an‑ya̱ jíín úu̱‑de
\p 
\v 13 Te suu kɨvɨ̱‑ún, te kája'a̱n uu̱‑de ichi ɨ́ɨn ñuu̱ nání Emaús ja̱ ncháá nátu̱'un uxi̱ kilómetro yósáva jíín ñúu̱ Jerusalén.
\v 14 Te kándatu̱'ún máá‑de ta̱ká tiñu yá'a ja̱ ní kuu‑ún.
\v 15 Te nini kándatu̱'ún‑de te kájika̱ tu̱'ún tá'an máá‑de. Te máá Jesús, ni̱ jaa̱‑ya̱ yatá‑dé. Te kájika ta̱í‑ya̱ kuá'a̱n‑ya̱ jíín‑de.
\v 16 Ko nátu̱'un ndasú nduchi‑dé náva̱'a ma̱ nákuni̱‑de‑ya̱.
\v 17 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Na̱ún tu̱'un kándatu̱'ún‑ró yá'a nini kájika‑ró. Te naja̱ kándukuí'a̱ ini̱‑ro̱, áchí‑ya̱.
\v 18 Te ɨɨn‑de ja̱ nání‑de Cleofas, ni̱ ka'a̱n‑de jíín‑yá: Á sá ní chaa̱‑ní ini̱ ñuu̱ Jerusalén, te máá ɨ́ɨn‑ni níí tú jiní‑ní ta̱ká tiñu ja̱ ní kuu ini̱ ñuu̱‑ún kɨvɨ̱ yá'a náún, áchí‑de.
\v 19 Te ni̱ jika̱ tu̱'ún‑yá‑de: Te na̱ún ní i̱o, áchí‑ya̱. Te máá‑de ni̱ kaka'a̱n‑de jíín‑yá: Aa̱, ja̱ ní ta'a̱n Jesús ñuu̱ Nazaret, cha̱a ni̱ jani tu̱'un Dios te ni̱ sá'a‑de tiñu ñá'nu. Te jíín fuerza ni̱ jani‑de tu̱'un jíto nuu̱ Dios jíín núu̱ táká ña̱yɨvɨ.
\v 20 Te sutu̱ ñá'nu jíín cháa kákuñá'nu nuu̱‑yo̱, ni̱ ka̱nastúu yu̱án‑de. Te ni̱ ka̱naku̱xndíi sɨkɨ̱‑dé ja̱ ná kúu̱‑de. Te ni̱ ka̱ja'ni‑ún‑de jika̱ cruz.
\v 21 Ko máá‑ná jíná'an‑ná, ni̱ ka̱ñukuu iní‑ná ja̱ máá‑de kúu cha̱a ja̱ náma ñuu̱ Israel núú. Te ni̱ ndɨ'ɨ ta̱ká tiñu yá'a, te vina ni̱ kuu uni̱ kɨvɨ̱ já ní kuu ta̱ká tiñu‑ún.
\v 22 Ko sava ñasɨ́'ɨ́ íó jíín‑ná jíná'an‑ná, suni ni̱ ka̱síyú'ú‑ña‑ná, chi ja̱ñá'a̱n xaa̱n ní ja̱ngoyo‑ña yaú kava‑ún.
\v 23 Te tú ní kánani'i̱n‑ñá yikɨ kúñu‑de. Te ni̱ cha̱koyo‑ña te áchí‑ña já ní kajini̱‑ña já ní kenda koyo ndajá'a̱ ándɨ́vɨ́ núu̱‑ñá. Te ni̱ kaka'a̱n ndajá'a̱‑ún jíín‑ña já chakú‑de.
\v 24 Te ni̱ kaja'a̱n sava tá'an‑ná onde̱ yau̱ kava‑ún. Te ni̱ kajini̱‑de nátu̱'un ni̱ kaka'a̱n ña'an‑ún. Ko tú ní kájini̱ kutɨ‑dé nuu̱ máá cháa‑ún. Achí‑de.
\v 25 Yúan‑na te ni̱ ka'a̱n‑ya̱ jíín‑de: Cha̱a xíní ñáá kákuu‑ró. Xaa̱n úun ini̱ añú‑ro̱ já kándíja‑ró táká tu̱'un ni̱ kaka'a̱n cha̱a ni̱ ka̱jani tu̱'un Dios.
\v 26 Á tú kánúú já ndó'o Cristo tu̱ndó'o yá'a te vásá ndɨ́vɨ‑ya̱ núu̱ ndúñá'nu‑ya̱ náún. Achí‑ya̱.
\v 27 Te ni̱ kejá'á‑yá onde̱ tu̱'un Moisés jíín tú'un cha̱a ni̱ ka̱jani tu̱'un Dios, te ni̱ jani kájí‑yá ta̱ká tu̱'un tutu̱ ii̱ núu̱‑dé ja̱ ká'a̱n tu̱'un máá‑yá.
\v 28 Te ni̱ ka̱kuyani‑de rancho nuu̱ kája'a̱n‑de‑ún. Te máá‑yá ni̱ sá'a‑ya̱ nátu̱'un ki'i̱n jíká‑ga̱‑ya̱.
\v 29 Ko máá‑de ni̱ ka̱stétuu‑de‑ya̱, ni̱ kaka'a̱n‑de jíín‑yá: Kendo̱o‑ní jíín‑ná, chi̱ a kua̱'ini te kua̱kuxkɨ́'vɨ̱, áchí‑de. Yúan‑na te ni̱ kɨ̱vɨ‑ya̱ já kéndo̱o‑ya̱ jíín‑de.
\v 30 Te nuu̱ ní ka̱jungo̱o‑de ja̱ kée‑dé staa̱, te ni̱ ki'in‑ya̱ stáa̱‑ún, te ni̱ jika̱n ta'u̱‑yá. Te ni̱ ja'ncha̱ sava‑ya̱. Te ni̱ ja̱'a‑ya̱ núu̱‑dé jíná'an‑de.
\v 31 Yúan‑na te nátu̱'un ni̱ ka̱nanuña nduchi‑dé. Te ni̱ ka̱nakuni̱‑de‑ya̱. Ko ii̱‑ní ni̱ kuxio‑ni‑ya̱ kuá'a̱n‑ya̱.
\v 32 Yúan‑na te ni̱ kaka'a̱n máá‑de: Ja̱ndáa̱ ja̱ ní tá'u'u̱ ini̱ añú‑yo̱ ja̱ níni jáni‑ya̱ tú'un nuu̱‑yo̱ íchi‑ún nuu̱ ní juña‑ya̱ tutú ii̱ núu̱‑yo̱.
\v 33 Te suni hora‑ún ni̱ ka̱ndukuiñi̱‑de. Te kua̱no'on‑dé ichi ñúu̱ Jerusalén. Te yúan ni̱ ka̱naketá'an‑de jíín uxí ɨɨn‑ga̱ cha̱a‑ún ká'i̱in tútú‑de jíín sáva‑ga̱ tá'an‑de.
\v 34 Te ni̱ kaka'a̱n‑de: Ja̱ndáa̱ ja̱kútɨ a ni̱ nachaku̱ máá Jíto'o̱‑yo̱. Te a ni̱ ndenda ndiji̱n‑ya̱ núu̱ Simón. Achí‑de.
\v 35 Yúan‑na te ndendúú cha̱a‑ún, ni̱ kaka̱stu̱'ún‑de ndasa ni̱ ka̱ketá'an‑de jíín‑yá ichi‑ún. Te ndasa ni̱ ka̱nakuni̱‑de nuu̱‑yá nuu̱ ní ja'ncha̱ sava‑ya̱ stáa̱.
\v 36 Te nini kándatu̱'ún‑de tu̱'un yá'a, te ni̱ jukuiñi̱‑ni máá‑yá sava ma̱'ñú‑de. Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ma̱ kúkuí'a̱ ini̱‑ro̱ jíná'an‑ró, áchí‑ya̱.
\v 37 Ko máá‑de, ni̱ kayu̱'ú‑de. Te ni̱ ka̱ndakoto i̱o‑de. Te kájani ini̱‑de ja̱ ɨ́ɨn añú kúu‑ya̱.
\v 38 Ko máá‑yá ni̱ kachi̱‑ya̱ jíín‑de: Naja̱ káyu̱'ú‑ro̱. Naja̱ súan kájani ini̱‑ro̱.
\v 39 Nde̱'é ndá'a‑rí jíín já'a̱‑rí, te kuni̱‑ro̱ já máá‑rí kúu. Tɨɨn ruu̱ te kuni̱‑ro̱, chi̱ ɨɨn añú tú ñáva̱'a ku̱ñu ni yikɨ nátu̱'un kánde̱'é‑ró já ñáva̱'a máá‑rí. Achí‑ya̱.
\v 40 Te ni̱ kuu ni̱ ka'a̱n‑ya̱ tú'un yá'a. Te ni̱ stá'a̱n‑ya̱ ndá'a‑yá ja'a̱‑yá nuu̱‑dé jíná'an‑de.
\v 41 Te va̱sa kákusɨɨ̱ xáa̱n iní‑de, ko tú ní kákandíja va̱'a‑de. Te yu̱án ní ka'a̱n‑ya̱ jíín‑de: Ió ja̱ kée‑rí yá'a xí túu, áchí‑ya̱.
\v 42 Yúan‑na te ni̱ kaja̱'a‑de ɨɨn ti̱yáká táú núu̱‑yá, jíín ɨ́ɨn yoko̱ ja̱ ñú'un ndu̱xi.
\v 43 Te ni̱ ki'in‑ya̱ ní yee‑yá nuu̱‑dé jíná'an‑de.
\v 44 Te ni̱ ka'a̱n‑ya̱ jíín‑de: Ya̱'á kúu ta̱ká tu̱'un ni̱ ka'a̱n‑ri̱ jíín‑ró ná ni̱ kanchaa̱‑ri̱ jíín‑ró sáá, ja̱ kánúú skíkuu ta̱ká tu̱'un‑ri̱ ja̱ yóso núu̱ tutú ley Moisés, jíín núu̱ tutú cha̱a ni̱ ka̱jani tu̱'un Dios jíín núu̱ tutú Salmo. Achí‑ya̱.
\v 45 Te ni̱ juña‑ya̱ já jiní tuní‑de jíná'an‑de, náva̱'a kuu juku̱'un ini̱‑de tu̱'un ká'a̱n tutu̱ ii̱.
\v 46 Te ni̱ kachi̱‑ya̱ jíín‑de: Súan yóso núu̱ tutú ja̱ ndó'o Cristo, te nuu̱ uní kɨvɨ̱ te nachaku̱‑ya̱ má'ñú ndɨ́yi.
\v 47 Te jíín sɨ́'vɨ́‑yá ná kuichá tu̱'un nuu̱ táká ña̱yɨvɨ já ná nákani ini̱‑i, náva̱'a koo tu̱ká'nu ini̱‑ya̱ núu̱ táká kua̱chi‑i. Te kejá'á tú'un yá'a onde̱ ñuu̱ Jerusalén ki'i̱n.
\v 48 Máá‑ró kákuu cha̱a kani ndaa̱ tu̱'un yá'a.
\v 49 Te vina tájí‑rí ja̱ ní keyu'u Táa̱‑ri̱. Te kii sɨkɨ̱‑ro̱ jíná'an‑ró. Ko kendo̱o‑ró iní ñuu̱ Jerusalén onde̱ ná kú'un‑ró fuerza ja̱ kíi onde̱ andɨ́vɨ́, áchí‑ya̱.
\s1 Ja̱ ní ndaa‑ya̱ kuá'a̱n‑ya̱ ándɨ́vɨ́
\p 
\v 50 Yúan‑na te ni̱ kiñi'in‑ya̱‑dé kua'a̱n‑ya̱ jíín‑de onde̱ ñuu̱ Betania. Te yúan ni̱ kañaa‑ya̱ ndá'a‑yá. Te ni̱ jika̱n ta'u̱‑yá ja'a̱‑dé jíná'an‑de.
\v 51 Te nini jikán ta'u̱‑yá ja'a̱‑dé, te ni̱ kuxio‑ni‑ya̱ núu̱‑dé, ni̱ ndaa‑ni‑ya̱ kuá'a̱n‑ya̱ ondé andɨ́vɨ́.
\v 52 Te máá‑de, ni̱ ka̱chiñú'ún‑de‑ya̱. Yúan‑na te ni̱ ka̱naxíó káva‑de káno'o̱n‑de ñuu̱ Jerusalén kákusɨɨ̱ xáa̱n iní‑de.
\v 53 Te nene̱ ni̱ ka'i̱in‑de ini̱ ve̱'e ii̱ kájika̱n ta'u̱‑dé te kánakana jaa‑de Dios. Amén.
