\s1 Haman Expresses His Hatred of Mordecai  
\p
\v 9  \w Now|strong="H3117"\w* \w Haman|strong="H2001"\w* \w went|strong="H3318"\w* \w forth|strong="H3318"\w* \w that|strong="H7200"\w* \w day|strong="H3117"\w* \w pleased|strong="H2896"\w* \w and|strong="H6965"\w* \w very|strong="H2896"\w* \w much|strong="H5921"\w* encouraged. \w But|strong="H3808"\w* \w when|strong="H3117"\w* \w Haman|strong="H2001"\w* \w saw|strong="H7200"\w* \w Mordecai|strong="H4782"\w* \w at|strong="H5921"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w*’s \w gate|strong="H8179"\w*, \w and|strong="H6965"\w* \w he|strong="H1931"\w* \w did|strong="H3808"\w* \w not|strong="H3808"\w* \w rise|strong="H6965"\w* \w nor|strong="H3808"\w* \w tremble|strong="H2111"\w* \w in|strong="H5921"\w* \w his|strong="H5921"\w* \w presence|strong="H5921"\w*, \w Haman|strong="H2001"\w* \w was|strong="H3820"\w* \w filled|strong="H4390"\w* \w with|strong="H4390"\w* \w rage|strong="H2534"\w* \w toward|strong="H5921"\w* \w Mordecai|strong="H4782"\w*.  
