\id JHN - Biblica® Open Igbo Contemporary Bible 2020 
\h Jọn 
\toc1 Oziọma Jọn 
\toc2 Jọn 
\toc3 Jọn 
\mt1 Oziọma Jọn 
\c 1  
\s1 Okwu ghọrọ mmadụ 
\p  
\v 1 Na mbụ okwu ahụ dịrịị, okwu ahụ na Chineke nọ, okwu ahụ bụkwa Chineke.  
\v 2 Ya na Chineke nọ site na mbụ.  
\v 3 E sitere na ya kee ihe niile, ọ dịghịkwa ihe ọbụla e kere eke nke a na-ekeghị site na ya.  
\v 4 Nʼime ya ka ndụ dịrịị, ndụ ahụ bụkwa ìhè nye mmadụ niile,  
\v 5 ìhè ahụ na-enwu nʼime ọchịchịrị, ma ọchịchịrị ahụ emenyụghị ya. 
\p  
\v 6 Ọ dị otu nwoke Chineke zitere, aha ya bụ Jọn.  
\v 7 Ọ bịara dị ka onye akaebe ịgba ama banyere ìhè ahụ, ka mmadụ niile site nʼaka ya kwere.  
\v 8 Ya onwe ya abụghị ìhè ahụ, ọ bịara naanị ịgba akaebe banyere ìhè ahụ. 
\p  
\v 9 Ezi ìhè ahụ nke na-enye mmadụ ọbụla ìhè na-abịa nʼime ụwa.  
\v 10 Ọ bịara nʼụwa, ma ụwa bụ ihe e kere site nʼaka ya, ma ụwa amataghị onye ọ bụ.  
\v 11 Ọ bịakwutere ihe ndị ahụ bụ ndị nke ya, ma ndị ahụ bụ ndị nke ya anabataghị ya.  
\v 12 Ma ndị ahụ niile nabatara ya, ndị ahụ niile kweere nʼaha ya ka o nyere ike ịghọ ụmụ Chineke.  
\v 13 Ụmụ a na-amụghị site nʼọbara, maọbụ site na mkpebi nke anụ ahụ, ma ọ bụkwanụ mkpebi nke mmadụ, kama site na Chineke. 
\p  
\v 14 Okwu ahụ ghọrọ anụ ahụ\f + \fr 1:14 \ft Maọbụ, \fqa mmadụ\f* birikwa nʼetiti anyị. Anyị ahụla ebube ya, ebube nke onye naanị ya bụ Ọkpara Nna mụrụ, onye si nʼebe Nna nọ bịa, onye jupụtara nʼamara na eziokwu. 
\p  
\v 15 Jọn gbara ama banyere ya mgbe ọ na-eti mkpu na-asị, “Onye a bụ onye ahụ m kwuru banyere ya, ‘Onye na-abịa m nʼazụ dị ukwuu karịa m, nʼihi na o bukwa m ụzọ dịrị.’ ”  
\v 16 Site nʼịba ụba nke amara ya, anyị niile anatala amara a tụkwasịrị nʼamara.  
\v 17 Nʼihi na e nyere iwu site nʼaka Mosis, ma amara na eziokwu bịara site nʼaka Jisọs Kraịst.  
\v 18 Ọ dịbeghị onye ọbụla hụrụla Chineke, ma Chineke, onye naanị ya bụ Ọkpara Nna mụrụ. Onye ya na Nna dị na mma, emeela ka anyị mata ya. 
\s1 Jọn ekwupụta na ya abụghị Kraịst 
\p  
\v 19 Nke a bụ ịgba ama Jọn mgbe ndị ndu ndị Juu nọ na Jerusalem zipụrụ ndị nchụaja na ndị Livayị ka ha bịa jụọ ya onye ọ bụ?  
\v 20 O mechighị ọnụ ya, kama o kwupụtara sị, “Abụghị m Kraịst ahụ.” 
\p  
\v 21 Mgbe ahụ ha jụrụ ya sị, “Ị bụkwanụ onye? Ị bụ Ịlaịja?” 
\p Ọ zara sị ha, “Abụghị m ya.” 
\p “Ị bụ Onye amụma ahụ?” 
\p “Mba.” 
\p  
\v 22 Ha sịrị ya, “Ị bụ onye? Nye anyị ọsịsa anyị ga-eweghachiri ndị zitere anyị. Gịnị ka i kwuru banyere onwe gị?” 
\p  
\v 23 Ọ sịrị, dịka Aịzaya onye amụma kwuru, “Abụ m onye na-eti mkpu nʼime ọzara, ‘Meenụ ka ụzọ Onyenwe anyị guzozie.’ ”\f + \fr 1:23 \ft \xt Aịz 40:3\f* 
\p  
\v 24 Ma ndị Farisii ahụ ezitere  
\v 25 jụrụ ya, sị, “Gịnị mere i ji na-eme baptizim ọ bụrụ na ị bụghị Kraịst maọbụ Ịlaịja, maọbụ onye amụma ahụ?” 
\p  
\v 26 Jọn zara ha sị, “Eji m mmiri na-eme baptizim, ma ọ dị otu onye nọ nʼetiti unu nke unu na-amaghị.  
\v 27 Onye ahụ nke na-abịa nʼazụ m, onye m na-erughị ịtọpụ eriri akpụkpọụkwụ ya.” 
\p  
\v 28 Ihe a mere na Betani nʼofe osimiri Jọdan bụ ebe Jọn nọ na-eme baptizim. 
\s1 Nwa atụrụ Chineke 
\p  
\v 29 Nʼechi ya, ọ hụrụ ka Jisọs na-abịakwute ya sị, “Leekwa, Nwa Atụrụ Chineke, onye na-ebupụ mmehie ụwa.  
\v 30 Ọ bụ onye a ka m kwuru okwu ya mgbe ahụ m sịrị, ‘otu nwoke na-abịa nʼazụ m, onye dị ukwuu karịa m, nʼihi na o bukwa m ụzọ dịrị.’  
\v 31 Mụ onwe m amataghị ya, ma a bịara m were mmiri na-eme baptizim nʼihi nke a, ka e kpughee ya nye ndị Izrel.” 
\p  
\v 32 Mgbe ahụ Jọn gbara ama a sị, “Ahụrụ m ka Mmụọ Nsọ sitere nʼeluigwe rịdata dị ka nduru, nọkwasị ya.  
\v 33 Mụ onwe m amabughị ya, ma onye ahụ zitere m ka m jiri mmiri mee baptizim kwuru, ‘Onye ahụ ị ga-ahụ, onye Mmụọ Nsọ ga-ebekwasị, ma nọgidekwa, ọ bụ ya ga-eji Mmụọ Nsọ mee baptizim.’  
\v 34 Mụ onwe m ahụla ya, na-agbakwa ama na onye a bụ Ọkpara Chineke.”\f + \fr 1:34 \ft Onye Chineke họọrọ.\f* 
\s1 Ndị mbụ soro Kraịst 
\p  
\v 35 Nʼechi ya, Jọn na mmadụ abụọ ndị na-eso ụzọ ya guzoro nʼebe ahụ ọzọ.  
\v 36 Mgbe ọ hụrụ Jisọs ka ọ na-agafe, ọ sịrị, “Leenụ, Nwa Atụrụ Chineke.” 
\p  
\v 37 Mgbe mmadụ abụọ ahụ na-eso ụzọ ya nụrụ nke a, ha tụgharịrị soro Jisọs.  
\v 38 Mgbe Jisọs tụgharịrị hụ ka ha na-eso ya, ọ sịrị ha, \wj “Gịnị ka unu chọrọ?”\wj* 
\p Ha sịrị ya, “Rabbi”\f + \fr 1:38 \ft Ụfọdụ na-akpọkwa mkpụrụ okwu a, Rabaị.\f* (nke pụtara “Onye ozizi”), “olee ebe i bi?” 
\p  
\v 39 Ọ sịrị ha, \wj “Bịanụ, unu ga-ahụ.”\wj* 
\p Ha sooro ya ga hụ ebe ọ na-anọ. Ha nọnyekwara ya ụbọchị ahụ niile. Ọ bụ nʼihe dị ka elekere anọ nke mgbede. 
\p  
\v 40 Otu nʼime mmadụ abụọ ahụ nụrụ ihe Jọn kwuru, nke sooro ya bụ Andru nwanne Saimọn Pita.  
\v 41 Ihe mbụ o mere bụ ịchọta Saimọn nwanne ya sị ya, “Anyị achọtala Mezaya ahụ” (onye a na-akpọkwa Kraịst).  
\v 42 Ọ kpọtaara ya Jisọs. 
\p O lere ya anya sị, \wj “Ị bụ Saimọn nwa Jọn. A ga-akpọ gị Sefas”\wj* (nke nsụgharị ya, pụtara Pita\f + \fr 1:42 \fq Sefas \ft bụ asụsụ Hibru, ebe \fq Pita \ft bụ asụsụ Griik, ma ha abụọ pụtara otu ihe \fqa okwute.\f*). 
\s1 Jisọs akpọọ Filip na Nataniel 
\p  
\v 43 Nʼechi ya, o kpebiri ịga Galili. Mgbe ọ hụrụ Filip, ọ sịrị ya, \wj “Soro m.”\wj* 
\p  
\v 44 Filip bụ onye obodo Betsaida dị ka Andru na Pita.  
\v 45 Filip chọtara Nataniel sị ya, “Anyị achọtala onye ahụ Mosis dere banyere ya nʼiwu, onye ndị amụma dekwara banyere ya, Jisọs onye Nazaret, nwa Josef.” 
\p  
\v 46 Nataniel sịrị ya, “Ihe ọma ọbụla ọ pụrụ i si na Nazaret pụta?” 
\p Ma Filip sịrị ya, “Bịa ka ị hụrụ.” 
\p  
\v 47 Mgbe Jisọs hụrụ ka Nataniel na-abịaru ya nso, o kwuru sị, \wj “Leenụ ezi nwa afọ Izrel onye aghụghọ na-adịghị nʼime ya.”\wj* 
\p  
\v 48 Nataniel sịrị ya, “Olee otu i si mata onye m bụ?” 
\p Jisọs sịrị ya, \wj “Tupu Filip akpọ gị, ahụlarị m gị ka ị nọ nʼokpuru osisi fiig.”\wj* 
\p  
\v 49 Mgbe ahụ, Nataniel zaghachiri, “Onye ozizi, ị bụ Ọkpara Chineke; ị bụ eze Izrel.” 
\p  
\v 50 Jisọs zara sị ya, \wj “I kwere nʼihi na agwara m gị na ahụrụ m gị nʼokpuru osisi fiig? Ị ga-ahụ ihe dị ukwuu karịa nke a.”\wj* 
\v 51 Ọ sịkwara ya, \wj “Nʼezie, nʼezie agwa m unu, unu ga-ahụ eluigwe ka o meghere hụkwa ndị mmụọ ozi Chineke ka ha na-arịgokwuru, ma na-arịdakwuru Nwa nke Mmadụ.”\wj* 
\c 2  
\s1 Jisọs emee mmiri ya aghọọ mmanya 
\p  
\v 1 Nʼụbọchị nke atọ, o nwere mmemme agbamakwụkwọ na Kena nke Galili, nne Jisọs bịakwara ebe ahụ.  
\v 2 A kpọkwara Jisọs na ndị na-eso ụzọ ya oku na mmemme agbamakwụkwọ a.  
\v 3 Mgbe mmanya ha gwụrụ, nne Jisọs sịrị ya, “Ha enweghị mmanya.” 
\p  
\v 4 Jisọs sịrị ya, \wj “Nwanyị, gịnị gbasara mụ na gị na nke a? Oge awa m erubeghị.”\wj* 
\p  
\v 5 Nne ya gwara ndị na-eje ozi, “Ihe ọbụla ọ gwara unu, meenụ ya.” 
\p  
\v 6 A dọbara ite mmiri nkume isii buru ibu nʼakụkụ ebe ahụ, nke a na-eji agbanye mmiri ndị Juu na-eji asachasị onwe ha ma ha chọọ ikpe ekpere. Otu nʼime ha na-eri ihe dị ka galọọnụ iri abụọ ma ihe ruru iri atọ.\f + \fr 2:6 \ft Nke a bụ ihe dị ka lita iri asaa na ise maọbụ ihe ruru narị na iri ise.\f* 
\p  
\v 7 Jisọs gwara ha, \wj “Gbajuonụ ite ndị a mmiri.”\wj* Ya mere, ha gbajupụtara ha mmiri. 
\p  
\v 8 Mgbe ahụ, ọ gwara ha, \wj “Ugbu a, gbapụtanụ ụfọdụ bugara onyeisi oche.”\wj* 
\p Ha mekwara nke a.  
\v 9 Mgbe ahụ onyeisi oche ahụ detụrụ mmiri ahụ e mere ka ọ ghọọ mmanya ọnụ. Ọ mataghị ebe o siri pụta (ma ndị na-eje ozi, ndị kutere mmiri ahụ matara), onyeisi oche ahụ kpọpụtara onye ahụ na-alụ nwunye ọhụrụ iche  
\v 10 sị ya, “Nʼoge mmemme ọbụla, a na-ebu ụzọ buputa mmanya dị ụtọ, ma bupụtakwa nke na-adịghị ụtọ nʼikpeazụ, mgbe ndị mmadụ ṅụjuchara afọ, ma i chebere mmanya dị ụtọ buputa ya ugbu a.” 
\p  
\v 11 Nke a bụ mmalite ihe ama Jisọs mere na Kena nke Galili, o sitere na nke a kpughee ebube ya, ndị na-eso ụzọ ya kwenyekwara na ya. 
\p  
\v 12 Mgbe nke a gasịrị, ọ gara Kapanọm, ya na nne ya na ụmụnne ya, nakwa ndị na-eso ụzọ ya. Ha nọrọ ụbọchị ole na ole nʼebe ahụ. 
\s1 Mmemme Ngabiga 
\p  
\v 13 Mgbe mmemme oriri Ngabiga nke ndị Juu na-abịaru nso, Jisọs gara Jerusalem.  
\v 14 Nʼime ụlọnsọ ukwu, ọ hụrụ ndị na-ere ehi, na atụrụ na nduru. Hụkwa ndị nọdụrụ na tebul na-agbanwe ego.  
\v 15 Ya mere, o jiri eriri mere ụtarị chụpụsịa ndị niile nọ na-ere ahịa nʼụlọnsọ ukwu ahụ, tinyekwara ehi na atụrụ ha. Ọ kwafusịrị mkpụrụ ego ndị ahụ na-agbanwe ego, kpugharịakwa tebul ha ihu.  
\v 16 Ọ sịrị ndị ahụ na-ere nduru, \wj “Wepụnụ ihe ndị a nʼebe a. Kwụsịnụ ime ụlọ Nna m ka ọ bụrụ ebe a na-azụ ahịa.”\wj* 
\v 17 Ndị na-eso ụzọ ya chetara na e dere ya rịị nʼakwụkwọ nsọ, “Ihe banyere ụlọ gị na-anụ m ọkụ nʼobi.”\f + \fr 2:17 \ft \xt Abụ 69:9\f* 
\p  
\v 18 Ma ndị Juu sịrị ya, “Olee ihe ịrịbama ị pụrụ igosi anyị na ikike i ji eme ihe ndị a.” 
\p  
\v 19 Jisọs zara sị, \wj “Kwatuonụ ụlọnsọ ukwu a, aga m ewughachikwa ya nʼabalị atọ.”\wj* 
\p  
\v 20 Ndị Juu kwuru, “Ụlọnsọ ukwu a were anyị iri afọ anọ na isii ịrụ ya, ị ga-ewughachi ya nʼabalị atọ?”  
\v 21 Ma ụlọnsọ o kwuru maka ya bụ ahụ ya.  
\v 22 Ndị na-eso ụzọ ya chetara okwu ya a mgbe o siri nʼọnwụ bilie. Mgbe ahụkwa, ha kweere akwụkwọ nsọ ya na okwu niile Jisọs kwuru. 
\p  
\v 23 Mgbe ọ nọ na Jerusalem nʼoge Mmemme Ngabiga, ọtụtụ mmadụ hụrụ ihe ịrịbama o mere kweere na ya.  
\v 24 Ma Jisọs atụkwasịghị ha obi nʼihi na ọ matara mmadụ niile nke ọma.  
\v 25 Ọ dịghị ya mkpa ka onye ọbụla gbaa akaebe banyere ụmụ mmadụ, nʼihi na ya onwe ya maara ihe dị nʼime mmadụ. 
\c 3  
\s1 Jisọs na Nikọdimọs 
\p  
\v 1 O nwere otu nwoke onyeisi ndị Juu nke so nʼotu ndị Farisii aha ya bụ Nikọdimọs.  
\v 2 Ọ bịakwutere ya nʼabalị sị ya, “Onye ozizi, anyị maara na ị bụ onye ozizi sitere na Chineke, nʼihi na o nweghị onye ọbụla pụrụ ịrụ ọrụ ebube dị otu a ma ọ bụrụ na Chineke anọnyereghị ya.” 
\p  
\v 3 Jisọs zara sị ya, \wj “Nʼezie, nʼezie agwa m unu, ọ bụrụ na amụghị mmadụ ọzọ, ọ pụghị ịhụ alaeze Chineke anya.”\wj* 
\p  
\v 4 Nikọdimọs sịrị ya, “Olee otu a ga-esi mụgharịa mmadụ mgbe o mere okenye? Ọ ga-aba nʼafọ nne ya nke ugboro abụọ?” 
\p  
\v 5 Ma Jisọs sịrị, \wj “Nʼezie, nʼezie agwa m unu, ọ bụrụ na amụghị mmadụ site na mmiri na Mmụọ Nsọ, o nweghị ike ịba nʼalaeze Chineke.\wj* 
\v 6 \wj Ihe e si nʼanụ ahụ mụọ bụ anụ ahụ, ma ihe a mụrụ site na Mmụọ bụ mmụọ.\wj* 
\v 7 \wj Ya ejula gị anya na m sịrị gị, ‘Agaghị ịmụ unu ọzọ.’\wj* 
\v 8 \wj Ifufe na-efe nʼebe ọbụla masịrị ya. I nwere ike nụ ụzụ ya ma ịmataghị ebe o si abịa maọbụ ebe ọ na-aga. Otu a ka ọ dịkwara onye ọbụla a mụrụ site na Mmụọ.”\wj* 
\p  
\v 9 Nikọdimọs zara sị ya, “Olee otu ihe ndị a ga-esi mee?” 
\p  
\v 10 Jisọs zara sị ya, \wj “Ị bụ onye ozizi ndị Izrel, ma ị ghọtaghị ihe ndị a?\wj* 
\v 11 \wj Nʼezie, nʼezie agwa m unu. Anyị na-ekwu banyere ihe anyị maara, na-akọwapụtakwa ihe anyị hụrụ, ma unu onwe unu adịghị anabata akaebe anyị.\wj* 
\v 12 \wj Ekwuola m banyere ihe dị nʼụwa ma unu ekweghị ya, oleekwanụ otu unu ga-esi kwere, ma ọ bụrụ na mụ agwa unu banyere ihe ndị dị nʼeluigwe?\wj* 
\v 13 \wj O nwebeghị onye ọbụla rigooro nʼeluigwe ewezuga Nwa nke Mmadụ bụ onye siri nʼeluigwe rịdata.\wj* 
\v 14 \wj Dị ka Mosis weliri agwọ elu nʼime ọzara, otu a ka a ga-ewelikwa Nwa nke Mmadụ elu.\wj* 
\v 15 \wj Ka onye ọbụla kwere na ya nwee ndụ ebighị ebi.”\wj* 
\p  
\v 16 Nʼihi na Chineke hụrụ ụwa nʼanya, nke a mere o jiri nye Ọkpara ọ mụrụ naanị ya, ka onye ọbụla kweere na ya ghara ịla nʼiyi, kama ka o nwee ndụ ebighị ebi.  
\v 17 Nʼihi na Chineke eziteghị Ọkpara ya nʼụwa ka o maa ụwa ikpe, kama ka e site nʼaka ya zọpụta ụwa.  
\v 18 Ikpe amaghị onye ọbụla kwere na ya, ma onye ọbụla na-ekweghị aghọọlarị onye ikpe mara, nʼihi na o kweghị nʼaha Ọkpara Chineke mụrụ naanị ya.  
\v 19 Nke a bụ mkpebi ikpe ahụ; na Ìhè abịala nʼụwa, ma ụmụ mmadụ hụrụ ọchịchịrị nʼanya kama ìhè ahụ, nʼihi na ọrụ ha jọrọ njọ.  
\v 20 Nʼihi na onye ọbụla na-eme ihe ọjọọ kpọrọ ìhè ahụ asị, ọ dịghị abịakwute ìhè ahụ, ka a ghara ime ka ọrụ ya pụta ìhè.  
\v 21 Ma ndị na-ebi ndụ nʼeziokwu na-abịakwute ìhè ahụ, ka e nwee ike hụta ya nke ọma, na ihe niile ha na-eme sitere na ike Chineke. 
\s1 Nkwupụta Jọn omee baptizim maka Jisọs 
\p  
\v 22 Emesịa, Jisọs na ndị na-eso ụzọ ya banyere nʼime obodo Judịa, ebe ọ nọtụrụ nwa oge, meekwa baptizim.  
\v 23 Nʼotu aka ahụ, Jọn nọkwa nʼọnụ mmiri Enọn dị nso na Salim na-eme baptizim nʼihi na mmiri buru ibu nʼebe ahụ, ndị mmadụ gakwara nʼihu na-abịakwute ya, ọ na-emekwa ha baptizim.  
\v 24 E tinyebeghị Jọn nʼụlọ mkpọrọ mgbe ahụ.  
\v 25 Nʼoge a, ịrụrịta ụka malitere nʼetiti ndị na-eso ụzọ Jọn na otu onye Juu banyere mmemme ịdị ọcha.  
\v 26 Ha bịakwutere Jọn sị ya, “Onye ozizi, onye ahụ ị gbara ama banyere ya nọ nʼofe Jọdan na-eme baptizim, mmadụ niile na-agakwukwara ya.” 
\p  
\v 27 Jọn zaghachiri sị, “Ihe mmadụ nwere ike ịnata bụ naanị ihe ahụ e nyere ya site nʼeluigwe.  
\v 28 Unu onwe unu ga-agbara m akaebe na m sịrị, na abụghị m Kraịst ahụ, kama e zitere m ka m buru ụzọ bịa.  
\v 29 Nwanyị a na-alụ ọhụrụ bụ nke di ya. Enyi onye na-alụ nwunye ọhụrụ na-eche ma na-egekwa ntị ịnụ olu ya, ọṅụ na-ejupụtakwa ya obi mgbe ọ nụrụ olu onye ahụ na-alụ nwunye ọhụrụ. Ya mere, ọṅụ m e zuola oke ugbu a.  
\v 30 Ọ ghaghị ịdị elu, ma mụ onwe m aghaghị ịdịkwa ala. 
\p  
\v 31 “Onye ahụ si nʼelu bịa dị elu karịa ihe niile, onye ahụ si nʼụwa bụkwa nke ụwa ma na-ekwukwa okwu dị ka onye si nʼụwa. Onye ahụ si nʼeluigwe dị elu karịa ihe niile.  
\v 32 Ọ na-agba ama banyere ihe ọ hụrụ nakwa nke ọ nụrụ, ma o nweghị onye na-anabata ama ya.  
\v 33 Onye ọbụla nabatara akaebe ya ji nke a mere akara, na Chineke bụ eziokwu.  
\v 34 Nʼihi na onye Chineke zitere na-ekwu okwu Chineke. Nʼihi na ọ na-enye Mmụọ ya nʼuju.  
\v 35 Nna hụrụ Ọkpara ya nʼanya, o tinyekwala ihe niile nʼaka ya.  
\v 36 Onye ọbụla kwere nʼỌkpara ahụ nwere ndụ ebighị ebi, ma onye ọbụla jụrụ Ọkpara ahụ agaghị ahụ ndụ nʼihi na iwe Chineke ga-adịrị ya.” 
\c 4  
\s1 Nwanyị Sameria 
\p  
\v 1 Ugbu a, Jisọs matara na ndị Farisii anụla na ọ na-eme ka ọtụtụ mmadụ bụrụ ndị na-eso ụzọ ya na-emekwa baptizim karịa Jọn.  
\v 2 Ma ọ bụkwaghị Jisọs na onwe ya na-eme baptizim kama ọ bụ ndị na-eso ụzọ ya mere ha baptizim.  
\v 3 Ọ hapụrụ Judịa laghachi azụ na Galili. 
\p  
\v 4 Ma ọ ga-esite nʼetiti Sameria gafee.  
\v 5 Ya mere, ọ batara nʼotu obodo nta dị na Sameria a na-akpọ Saika, nʼakụkụ ala ahụ Jekọb nyere Josef nwa ya nwoke.  
\v 6 Olulu mmiri Jekọb dị nʼebe ahụ, ma ebe ọ bụ na ike gwụrụ Jisọs nʼije ya, ọ nọdụrụ ala nʼakụkụ olulu mmiri ahụ. Ọ bụ ihe dị ka oge ehihie. 
\p  
\v 7 Otu nwanyị onye Sameria\f + \fr 4:7 \ft Ndị Sameria bụ ụmụ a mụtara site nʼọlụlụ di na nwunye dị nʼetiti ụfọdụ ndị Juu ha na ndị Asịrịa.\f* bịara ịdọrọ mmiri, Jisọs sịrị ya, \wj “Nyetụ m mmiri ka m ṅụọ.”\wj* 
\v 8 (Ndị na-eso ụzọ ya abaala nʼime obodo ịga zụta nri.) 
\p  
\v 9 Nwanyị ahụ sịrị ya, “Olee otu gị bụ onye Juu si arịọ m bụ nwanyị Sameria mmiri ka ị ṅụọ?” (Nʼihi na ndị Juu na ndị Sameria anaghị emekọrịta ihe ọbụla.) 
\p  
\v 10 Jisọs zara sị, \wj “Ọ bụrụ na ị matara onyinye Chineke, na onye ahụ na-arịọ gị mmiri, ị gaara arịọ ya, ọ gakwara enye gị mmiri nke ndụ.”\wj* 
\p  
\v 11 Nwanyị ahụ sịrị ya, “Nna anyị ukwu, o nweghị ihe ọbụla i ji ị ga-eji dọrọ mmiri, olulu a dịkwa omimi. Oleekwanụ ebe ị ga-eweta mmiri ndụ a.  
\v 12 Ọ bụ na ị ka nna nna anyị Jekọb ukwuu, onye gwuuru anyị olulu mmiri a? Ya onwe ya na ụmụ ya na igwe ehi na atụrụ ya ṅụkwara mmiri sitere na ya?” 
\p  
\v 13 Jisọs zara sị, \wj “Onye ọbụla ṅụrụ mmiri a, akpịrị ga-akpọ ya nkụ ọzọ.\wj* 
\v 14 \wj Ma onye ọbụla ga-aṅụ mmiri ahụ m nyere ya, akpịrị agaghị akpọkwa ya nkụ ọzọ. Nʼeziokwu, mmiri ahụ m nyere ya ga-aghọrọ ya isi iyi nke na-asọpụtara ya ndụ ebighị ebi.”\wj* 
\p  
\v 15 Mgbe ahụ nwanyị ahụ sịrị ya, “Onyenwe anyị nye m mmiri a, ka akpịrị ghara ịkpọ m nkụ ọzọ, ka m gharakwa ịdị na-abịa ebe a ịdọrọ mmiri.” 
\p  
\v 16 Ọ gwara ya sị, \wj “Gaa kpọta di gị ma lọghachi.”\wj* 
\p  
\v 17 Nwanyị ahụ zaghachiri ya sị, “Enweghị m dị.” 
\p Jisọs sịrị ya, \wj “I kwuru eziokwu mgbe ị sịrị na i nweghị di.\wj* 
\v 18 \wj I nweela di ise, ma nwoke gị na ya bi ugbu a abụghị di gị. Ihe kwuru bụ nnọọ eziokwu.”\wj*\f + \fr 4:18 \ft Omume a megidere iwu Chineke banyere ọlụlụ di na nwunye.\f* 
\p  
\v 19 Nwanyị ahụ sịrị ya “Nna anyị ukwu, ahụrụ m na ị bụ onye amụma.  
\v 20 Nna nna anyị ha fere ofufe nʼugwu a, ma unu na-ekwu nʼebe ndị mmadụ ga-eferịrị ofufe bụ naanị na Jerusalem.” 
\p  
\v 21 Jisọs sịrị ya, \wj “Nwanyị kwere okwu m, oge na-abịa mgbe ị na-agaghị akpọ isiala nye Nna, maọbụ nʼugwu a ma ọ bụkwanụ na Jerusalem.\wj* 
\v 22 \wj Unu na-efe ihe unu na-amaghị ma anyị na-efe ihe anyị matara, nʼihi na nzọpụta sitere nʼaka ndị Juu.\wj* 
\v 23 \wj Ma oge na-abịa, ugbu a ọ bịala, mgbe ndị na-efe Nna ahụ nʼeziokwu ga-efe ya nʼime mmụọ na nʼeziokwu. Nʼihi na ọ bụ ndị dị otu a ka Nna chọrọ ka ha na-efe ya.\wj* 
\v 24 \wj Chineke bụ mmụọ ndị niile na-efe ya ga-eferịrị ya nʼime mmụọ na eziokwu.”\wj* 
\p  
\v 25 Nwanyị ahụ sịrị ya, “Amaara m na Mezaya” (onye a na-akpọ Kraịst) “na-abịa. Mgbe ọ bịara, ọ ga-akọwaziri anyị ihe niile.” 
\p  
\v 26 Jisọs sịrị ya, \wj “Mụ, onye na-agwa gị okwu, abụ m ya.”\wj* 
\s1 Ndị na-eso ụzọ ya lọghachikwutere ya 
\p  
\v 27 Nʼoge ahụ ndị na-eso ụzọ ya lọghachitara. Ọ gbagwojukwara ha anya nke ukwuu ịhụ na ya na nwanyị na-ekwurịta okwu. Ma o nweghị onye nʼime ha jụrụ nwanyị ahụ sị, “Gịnị ka ị chọrọ?” ma ọ bụkwanụ, “Gịnị kpatara gị na ya ji na-ekwurịta okwu?” 
\p  
\v 28 Mgbe ahụ, nwanyị ahụ hapụrụ ite mmiri ya laghachi nʼime obodo ga gwa ndị mmadụ,  
\v 29 “Bịanụ lee otu nwoke onye gwara m ihe niile m merela. Ọ ga-abụ na ọ bụ ya bụ Kraịst ahụ?”  
\v 30 Ha sitere nʼobodo ahụ gbapụtasịa soro ụzọ ahụ, ka ha gakwuru ya. 
\p  
\v 31 Ma otu ọ dị, ndị na-eso ụzọ ya rịọrọ ya sị, “Onye ozizi rienụ nri.” 
\p  
\v 32 Ma ọ sịrị ha, \wj “Enwere m nri m na-eri nke unu na-amaghị maka ya.”\wj* 
\p  
\v 33 Mgbe ahụ ndị na-eso ụzọ ya sịrịtara onwe ha, “Ọ ga-abụ na o nwere onye butere ya nri?” 
\p  
\v 34 Jisọs sịrị ha, \wj “Nri m bụ ime uche onye ahụ zitere m nakwa ịrụcha ọrụ ya.\wj* 
\v 35 \wj Unu na-asị, ‘ọ fọdụghị ọnwa anọ ka ịghọ mkpụrụ nʼubi ruo?’ Ma ana m agwa unu, megheenụ anya unu lee ubi ahụ, ha achaala maka ọghụghọ.\wj* 
\v 36 \wj Ọ bụladị ugbu a, onye na-aghọ mkpụrụ na-anata ụgwọ ọrụ, ọ na-achịkọta mkpụrụ ahụ maka ndụ ebighị ebi, ka onye ghara mkpụrụ na onye ghọrọ ya nwee ike ịṅụrịkọta ọṅụ.\wj* 
\v 37 \wj Ya mere okwu ahụ nke na-asị, ‘Otu onye na-agha mkpụrụ, onye ọzọ na-aghọkwa ya bụ eziokwu.’\wj* 
\v 38 \wj E zigara m unu ka unu gaa ghọta ihe unu na-arụghị ọrụ maka ya. Ndị ọzọ rụrụ ọrụ a, ma unu ewe uru dị nʼọrụ ha.”\wj* 
\s1 Ọtụtụ ndị Sameria e kwere 
\p  
\v 39 Ọtụtụ ndị obodo Sameria kweere na ya nʼihi ama ahụ nwanyị ahụ gbara, “Ọ gwara m ihe niile m mere.”  
\v 40 Ya mere mgbe ndị Sameria bịakwutere ya, ha rịọrọ ya ka ọ nọnyetụrụ ha, ọ nọnyekwaara ha ụbọchị abụọ.  
\v 41 Ọtụtụ ndị ọzọ kwerekwara na ya nʼihi okwu ya. 
\p  
\v 42 Ha gwara nwanyị ahụ, “Ihe anyị jiri kwere ugbu a abụghị ihe i kwuru, kama ọ bụ nʼihi na anyị onwe anyị anụla olu ya, matakwa na onye a bụ Onye nzọpụta nke ụwa nʼeziokwu.” 
\s1 Jisọs agwọọ nwa otu onyeisi 
\p  
\v 43 Mgbe ụbọchị abụọ ahụ gasịrị, ọ hapụrụ ebe ahụ gawa Galili.  
\v 44 (Jisọs nʼonwe ya ekwuola na onye amụma anaghị enwe ugwu nʼobodo ya.)  
\v 45 Mgbe ọ bịaruru Galili, ndị Galili nabatara ya ebe ha onwe ha gara mmemme na Jerusalem, ma hụkwa ọtụtụ ọrụ ebube ọ rụrụ nʼoge mmemme ahụ. 
\p  
\v 46 Ọzọkwa, ọ bịaruru Kena nke Galili bụ ebe ahụ o mere mmiri ka ọ ghọọ mmanya. E nwekwara otu onye na-arụ ọrụ nʼụlọeze nọ nʼebe ahụ, nke ahụ na-adịghị nwa ya nwoke ike na Kapanọm.  
\v 47 Mgbe ọ nụrụ na Jisọs esitela na Judịa bịarute na Galili, o jekwuuru ya rịọ ya ka ọ bịa gwọọ nwa ya, nʼihi na ọ nọ nʼọnụ ọnwụ. 
\p  
\v 48 Jisọs sịrị ya, \wj “Ọ bụrụ na unu ahụghị ọrụ ebube na ihe ịrịbama, unu agaghị ekwe ma ọlị.”\wj* 
\p  
\v 49 Onye a na-arụ ọrụ nʼụlọeze sịrị ya, “Nna m ukwu, biko bịa tupu nwa m a nwụọ.” 
\p  
\v 50 Jisọs sịrị ya, \wj “Laa, nwa gị nwoke ga-adị ndụ.”\wj* 
\p Nwoke ahụ kweere nʼihe Jisọs kwuru laa.  
\v 51 Mgbe ọ ka nọ nʼụzọ, ndị ohu ya zutere ya kọọrọ ya na ahụ adịla nwa ya nwoke mma.  
\v 52 Mgbe ọ jụrụ ha oge nwa ya jiri gbakee, ha sịrị ya, “Oke ahụ ọkụ ahụ kwụsịrị ya ụnyaahụ nʼelekere mbụ nke ehihie.” 
\p  
\v 53 Nwoke ahụ ghọtara na ọ bụ kpomkwem nʼoge awa ahụ Jisọs gwara ya, \wj “Nwa gị nwoke ga-adị ndụ.”\wj* Ya mere ya na ezinaụlọ ya niile kwenyere. 
\p  
\v 54 Nke a bụ ihe ịrịbama nke abụọ Jisọs rụrụ na Galili mgbe o siri Judịa bịa. 
\c 5  
\s1 Ọgwụgwọ nʼọdọ mmiri Betsaida 
\p  
\v 1 Mgbe nke a gasịrị, otu mmemme ndị Juu ruru, Jisọs agaa Jerusalem.  
\v 2 Ma otu ọdọ mmiri nta dị nʼime Jerusalem nʼakụkụ Ọnụ ụzọ ama Atụrụ. Aha ọdọ mmiri ahụ nʼasụsụ Hibru bụ Betsaida, nke nwere mgbe ọnụ ụzọ ise.  
\v 3 Nʼime ya ka igwe ndị ahụ na-esighị ike na-edina; ndị ìsì, ndị ngwụrọ, na ndị akụkụ ahụ ha kpọnwụrụ akpọnwụ, ha na-eche mgbe mmiri ahụ ga-enugharị.  
\v 4 Nʼihi na mmụọ ozi Onyenwe anyị na-agbadata site na mgbe ruo na mgbe gbarụọ mmiri ahụ. Onye ọrịa ọbụla buru ụzọ daba nʼime mmiri ahụ ma a gbarụọ ya, ka a na-agwọ ihe ọbụla bụ ọrịa ya.\f + \fr 5:3,4 \ft Ụfọdụ akwụkwọ na-edebanye ụfọdụ ma ọ bụkwanụ amaokwu niile a, \fqa Nʼime ya ka igwe ndị ahụ na-esighị ike na-edina; ndị ìsì, ndị ngwụrọ, na ndị akụkụ ahụ ha kpọnwụrụ akpọnwụ, ha na-eche mgbe mmiri ahụ ga-enugharị. \ft Tinyere amaokwu nke anọ.\f* 
\v 5 Otu nwoke nọ nʼebe ahụ bụ onye nọrọla nʼọrịa iri afọ atọ na asatọ.  
\v 6 Mgbe Jisọs hụrụ ya, matakwa na ọ nọọla nʼọnọdụ a ogologo oge, ọ jụrụ ya sị, \wj “Ị chọrọ ka a gwọọ gị ọrịa?”\wj* 
\p  
\v 7 Onye ọrịa ahụ zara, “Nna m ukwu, enweghị m onye ọbụla ga-enyere m aka kuba m nʼime ọdọ mmiri a ma a gbarụọ ya, mgbe o bụla m chọrọ ka m danye, onye ọzọ na-eburu m ụzọ danye.” 
\p  
\v 8 Jisọs gwara ya, \wj “Bilie, chilie ute gị jegharịa.”\wj* 
\v 9 Nʼotu oge ahụ, ahụ dịrị nwoke ahụ mma, ọ chịlịri ute ya, malite ijegharị. 
\p Ihe a mere nʼụbọchị izuike.  
\v 10 Ma ndị Juu gwara nwoke ahụ a gwọrọ ọrịa, “Taa bụ ụbọchị izuike, o megidere iwu na ị ga-ebu ute gị.” 
\p  
\v 11 Ma ọ zaghachiri ha, “Nwoke ahụ mere ka ahụ dị m mma sịrị m, \wj ‘Chilie ute gị laa.’\wj* ” 
\p  
\v 12 Ha jụrụ ya, “Onye bụ onye ahụ gwara gị ka ị chilie ya laa?” 
\p  
\v 13 Ma nwoke ahụ a gwọrọ amataghị onye ọ bụ nʼihi na Jisọs zoro onwe ya banye nʼetiti igwe mmadụ. 
\p  
\v 14 Emesịa, Jisọs hụrụ ya nʼime ụlọnsọ ukwu sị ya, \wj “Lee, e mela ka ahụ dị gị mma, emehiekwala ọzọ ka nke dị njọ karịa nke a hapụ ịbịakwasị gị.”\wj* 
\v 15 Nwoke a siri nʼebe ahụ pụọ gaa gwa ndị Juu na ọ bụ Jisọs gwọrọ ya. 
\s1 Ndụ site nʼọkpara ahụ 
\p  
\v 16 Ya mere, nʼihi na Jisọs na-eme ihe ndị a nʼụbọchị izuike, ndị Juu malitere isogbu ya.  
\v 17 Jisọs sịrị ha, \wj “Nna m na-arụ ọrụ mgbe niile ruo ugbu a, mụ onwe m kwa, ana m arụ ọrụ.”\wj* 
\v 18 Nʼihi nke a, ndị Juu chọsịrị ike igbu ya. Ọ bụghị naanị na o mebiri ụbọchị izuike, kama ọ na-akpọkwa Chineke Nna ya, sitekwa otu a na-eme ka ya na Chineke hara. 
\p  
\v 19 Jisọs zara ha sị, \wj “Nʼezie, nʼezie agwa m unu, o nweghị ihe ọbụla Ọkpara pụrụ ime nʼonwe ya; naanị ihe o nwere ike ime bụ ihe ọ hụrụ Nna ya na-eme, nʼihi na ihe ọbụla Nna ahụ na-eme ka Ọkpara ya na-emekwa.\wj* 
\v 20 \wj Nʼihi na Nna ahụ hụrụ Ọkpara ya nʼanya ma na-egosikwa ya ihe niile ọ na-eme. Nʼezie ọ ga-agbagwoju unu anya nʼihi na ọ ga-egosi ya ihe karịrị ndị a.\wj* 
\v 21 \wj Nʼihi na dị ka nna ahụ si akpọte ndị nwụrụ anwụ na-enyekwa ha ndụ, otu ahụ ka Ọkpara ya si enye onye ọbụla ọ masịrị ya ndụ.\wj* 
\v 22 \wj Nna anaghị ekpe onye ọbụla ikpe, kama o nyefere ikpe niile nʼaka Ọkpara.\wj* 
\v 23 \wj Ka mmadụ niile nye Ọkpara ahụ nsọpụrụ dị ka ha na-asọpụrụ Nna ahụ. Onye ọbụla nke na-adịghị asọpụrụ Ọkpara ahụ adịghị asọpụrụ Nna nke zitere ya.\wj* 
\p  
\v 24 \wj “Nʼezie, nʼezie agwa m unu, onye ọbụla na-anụ okwu m ma kwerekwa nʼonye zitere m nwere ndụ ebighị ebi, a gaghị amakwa ya ikpe, ọ gafeela site nʼọnwụ banye na ndụ.\wj* 
\v 25 \wj Nʼezie, nʼezie agwa m unu, oge na-abịa, ọ bịakwala ugbu a mgbe ndị nwụrụ anwụ ga-anụ olu Ọkpara Chineke, ndị ahụ nụrụ ya ga-adịkwa ndụ.\wj* 
\v 26 \wj Dị ka Nna ahụ nwere ndụ nʼime onwe ya, otu a ka o nyekwara Ọkpara ahụ ike inwe ndụ nʼime onwe ya.\wj* 
\v 27 \wj O nyekwala ya ikike ikpe ikpe nʼihi na ọ bụ Nwa nke Mmadụ.\wj* 
\p  
\v 28 \wj “Ka nke a hapụ iju unu anya, nʼihi na oge na-abịa, mgbe ndị niile nọ nʼili ha ga-anụ olu ya\wj* 
\v 29 \wj ma pụta, ndị mere ihe dị mma ga-ebili dịrị ndụ. Ma ndị mere ihe ọjọọ ga-ebili bụrụ ndị a ga-ama ikpe.\wj* 
\v 30 \wj Enweghị m ike ime ihe ọbụla nʼonwe m, ikpe m na-ekpe bụ naanị dị ka m nụrụ, ikpe m bụkwa nke ziri ezi, nʼihi na anaghị m eme ihe ga-amasị m, kama ọ bụ ihe ga-amasị onye ahụ zitere m.\wj* 
\s1 Ọgbụgba ama maka Jisọs 
\p  
\v 31 \wj “Ọ bụrụ na m na-agba ama banyere onwe m, ama m abụghị eziokwu.\wj* 
\v 32 \wj Enwere m onye ọzọ na-agbara m ama, amatakwara m na ama ya banyere m bụ eziokwu.\wj* 
\p  
\v 33 \wj “Unu zigaara Jọn ndị ozi, ọ gbakwaala ama maka eziokwu ahụ.\wj* 
\v 34 \wj Ọ bụghị na m na-anabata ama nke mmadụ, kama a na m ekwu ya ka enwe ike ịzọpụta unu.\wj* 
\v 35 \wj Ọ bụ oriọna nke na-enwu na-amụkekwa, unu họrọkwara ịṅụrị ọṅụ nʼìhè ya nʼoge nta.\wj* 
\p  
\v 36 \wj “Ma e nwere m ama dị ukwuu karịa nke Jọn, nʼihi na ọrụ ahụ ya bụ Nna nyere m ka m rụchapụ, bụkwa nke m na-arụ, na-agbara m ama na ọ bụ Nna ahụ zitere m.\wj* 
\v 37 \wj Ya bụ Nna ahụ zitere m na-agbakwa ama nʼonwe ya banyere m. Unu anụbeghị olu maọbụ hụ ụdịdị ya.\wj* 
\v 38 \wj Okwu ya anọkwaghị nʼime unu nʼihi na unu ekweghị nʼonye o zitere.\wj* 
\v 39 \wj Unu na-enyocha akwụkwọ nsọ nʼihi na unu chere na unu ga-esite na ha nwee ndụ ebighị ebi maọbụ ha na-agba ama banyere m.\wj* 
\v 40 \wj Ma unu jụrụ ịbịakwute m ka unu nwee ndụ.\wj* 
\p  
\v 41 \wj “Anaghị m anabata otuto nke ụmụ mmadụ.\wj* 
\v 42 \wj Ma amatara m na unu enweghị ịhụnanya Chineke nʼobi unu.\wj* 
\v 43 \wj Abịala m nʼaha Nna m ma unu anabataghị m. Ma ọ bụrụ na onye ọzọ abịa nʼaha nke onwe ya, unu ga-anabata ya.\wj* 
\v 44 \wj Olee otu unu ga-esi kwere ebe unu na-anara otuto site nʼaka ibe unu, ma unu adịghị achọ otuto nke si nʼaka onye naanị ya bụ Chineke?\wj* 
\p  
\v 45 \wj “Unu echela na m ga-ebo unu ebubo nʼihu Nna ahụ. Onye ga-ebo unu ebubo bụ Mosis, bụ onye unu tụkwasịrị obi na ya.\wj* 
\v 46 \wj Ọ bụrụ na unu kwenyeere Mosis, unu gakwara ekwere na m, nʼihi na o dere banyere m.\wj* 
\v 47 \wj Ma ebe unu na-ekweghị nʼihe o dere, olee otu unu ga-esi kwere nʼihe m kwuru?”\wj* 
\c 6  
\s1 Jisọs azụọ puku mmadụ ise 
\p  
\v 1 Mgbe nke a gasịrị, Jisọs gafere nʼofe nke ọzọ nke osimiri Galili (nke a na-akpọkwa osimiri Tiberịas).  
\v 2 Oke igwe mmadụ sooro ya, nʼihi na ha hụrụ ọrụ ebube ọ na-arụ nʼahụ ndị ọrịa.  
\v 3 Jisọs rigooro nʼelu ugwu nọdụ ala ya na ndị na-eso ụzọ ya.  
\v 4 Nʼoge a, mmemme oriri Ngabiga ndị Juu na-abịa nso. 
\p  
\v 5 Mgbe Jisọs leliri anya elu hụ oke igwe mmadụ na-abịakwute ya, ọ sịrị Filip, \wj “Olee ebe anyị ga-azụta achịcha ndị a ga-ata?”\wj* 
\v 6 Ọ jụrụ nke a naanị iji nwalee ya, ya onwe ya mararị ihe ọ ga-eme. 
\p  
\v 7 Filip zara ya, “Ụgwọ ọrụ ọnwa isii agaghị ezu ịzụta achịcha nke onye ọbụla nʼime ha ga-atatụ naanị ihe ntakịrị.” 
\p  
\v 8 Onye ọzọ nʼime ndị na-eso ụzọ ya bụ Andru, nwanne Saimọn Pita, kwupụtara,  
\v 9 “Otu nwantakịrị nwoke nọ nʼebe a nwere ogbe achịcha balị ise, na azụ abụọ, ma gịnị ka ha bụ nʼetiti igwe mmadụ ha otu a?” 
\p  
\v 10 Jisọs sịrị, \wj “Meenụ ka ndị mmadụ ndị a nọdụ ala.”\wj* E nwere ọtụtụ ahịhịa nʼebe ahụ, ụmụ nwoke nọdụrụ ala, ha dị ihe ruru puku mmadụ ise.  
\v 11 Ya mere, Jisọs weere achịcha ahụ nye ekele, kee ha ndị niile nọdụrụ ala dị ka ha sịrị chọọ. O jikwa azụ ahụ mee otu ihe ahụ. 
\p  
\v 12 Mgbe ha niile rijuchara afọ, ọ sịrị ndị na-eso ụzọ ya, \wj “Tụtụkọtanụ iberibe niile fọdụrụ, ka ihe ọbụla hapụ ịla nʼiyi.”\wj* 
\v 13 Ya mere, ha tụtụkọtara ha, kpojuo nkata iri na abụọ, bụ iberibe si nʼogbe achịcha balị ise nke ndị ahụ rifọrọ. 
\p  
\v 14 Mgbe ndị mmadụ ahụ hụrụ ihe ịrịbama ahụ, o mere ha bidoro na-asị, “Nʼeziokwu, onye a bụ onye amụma ahụ nke ga-abịa nʼime ụwa.”  
\v 15 Mgbe Jisọs matara na ha chọrọ ịbịa dọkpụrụ ya nʼike chie ya eze, ọ hapụrụ ha ga nʼugwu naanị ya, nʼonwe ya. 
\s1 Jisọs agaa ije nʼelu mmiri 
\p  
\v 16 Mgbe o ruru nʼuhuruchi, ndị na-eso ụzọ ya rịdara gaa nʼọnụ mmiri,  
\v 17 ebe ha banyere nʼotu ụgbọ mmiri, malite ịgabiga osimiri gawa nʼofe Kapanọm. Nʼoge a ọchịchịrị agbaala ma Jisọs alọghachikwutebeghị ha.  
\v 18 Ebili mmiri maliri elu nʼihi nʼoke ifufe bidoro na-efe.  
\v 19 Ha akwọọla ụgbọ ihe dịka kilomita ise maọbụ isii, mgbe ha hụrụ Jisọs ka ọ na-aga ije nʼelu mmiri ahụ na-abịa nso nʼụgbọ mmiri ha. Oke egwu tụkwara ha.  
\v 20 Ma ọ sịrị ha, \wj “Unu atụla egwu. Ọ bụ m.”\wj* 
\v 21 Mgbe ahụ, ha nabatara ya nʼime ụgbọ ahụ, ọ dịkwaghị anya ụgbọ ha bịaruru nʼelu ala ebe ha na-aga. 
\p  
\v 22 Nʼechi ya, igwe mmadụ ahụ nọdụrụ nʼofe ọzọ nke ọnụ mmiri ahụ chọpụtara na ọ bụ naanị otu ụgbọ mmiri nta bịara nʼebe ahụ, na Jisọs esoghị ndị na-eso ụzọ ya banye nʼime ya, kama na ọ bụ naanị ndị na-eso ụzọ ya ka ụgbọ mmiri ahụ buuru pụọ.  
\v 23 Mgbe ahụ ụfọdụ ụgbọ mmiri si Tiberịas bịara kwụsị nso nso ebe ahụ ndị mmadụ nọ rie achịcha mgbe Onyenwe anyị nyechara ekele maka ya.  
\v 24 Ma mgbe igwe mmadụ ahụ ghọtara na Jisọs na ndị na-eso ụzọ ya anọghị nʼebe ahụ, ha banyere nʼụgbọ mmiri nta ndị ahụ kwọfee gawa Kapanọm ịchọ Jisọs. 
\s1 Jisọs achịcha nke ndụ 
\p  
\v 25 Mgbe ha hụrụ ya nʼofe ọzọ nke osimiri ahụ, ha sịrị ya, “Onye ozizi, olee mgbe i jiri bịa nʼebe a?” 
\p  
\v 26 Jisọs sịrị ha, \wj “Nʼezie, nʼezie agwa m unu, ihe unu ji na-achọ m abụghị nʼihi na unu hụrụ ihe ịrịbama m mere, kama na unu riri achịcha rijuokwa afọ.\wj* 
\v 27 \wj Unu adọgbula onwe unu maka nri nke na-emebi emebi, kama maka nri nke na-adịgide ruo ndụ ebighị ebi, bụ nke Nwa nke Mmadụ ga-enye unu. Nʼihi na Chineke Nna akakwasịla ya akara nkwado ya.”\wj* 
\p  
\v 28 Mgbe ahụ, ha sịrị, “Gịnị ka anyị ga-eme iji rụọ ọrụ Chineke?” 
\p  
\v 29 Jisọs zara sị ha, “Ọrụ Chineke bụ nke a, ikwere nʼonye ahụ o zitere.” 
\p  
\v 30 Ya mere ha sịrị ya, “Olee ihe ịrịbama ị ga-egosi anyị nke anyị ga-ahụ ma kwere na gị? Kedụ ọrụ ị ga-arụ?  
\v 31 Nna nna anyị ha riri mánà nʼọzara; dị ka e dere ya nʼakwụkwọ nsọ sị, ‘O sitere nʼeluigwe nye ha achịcha ka ha rie.’\f + \fr 6:31 \ft \xt Ọpụ 16:4; Neh 9:15; Abụ 78:24,25\f*” 
\p  
\v 32 Jisọs sịrị ha, \wj “Nʼezie, nʼezie agwa m unu, ọ bụghị Mosis nyere unu achịcha ahụ site nʼeluigwe, kama ọ bụ Nna m na-enye unu ezi achịcha ahụ site nʼeluigwe.\wj* 
\v 33 \wj Nʼihi na achịcha Chineke bụ nke ahụ si nʼeluigwe rịdata, na-enyekwa ụwa ndụ.”\wj* 
\p  
\v 34 Ha sịrị ya, “Nna anyị ukwu, nye anyị ụdị achịcha a site ugbu a gawa.” 
\p  
\v 35 Jisọs sịrị ha, \wj “Abụ m achịcha ahụ na-enye ndụ. Onye ọbụla na-abịakwute m, agụụ agaghị agụ ya. Onye ọbụla kwa kweere na m, akpịrị agaghị akpọ ya nkụ.\wj* 
\v 36 \wj Ma agwa m unu, unu ahụla m ma unu ekweghịkwa.\wj* 
\v 37 \wj Onye ọbụla Nna ahụ nyere m ga-abịakwute m, onye ọbụla na-abịakwute m, agaghị m achụpụ ya.\wj* 
\v 38 \wj Nʼihi na esi m nʼeluigwe rịdata nʼụwa ime uche onye ahụ zitere m, ọ bụghị ime uche nke m.\wj* 
\v 39 \wj Nke a bụkwa uche onye ahụ zitere m, na o nweghị onye ọbụla o nyere m ga-efunarị m, kama m ga-eme ka ha site nʼọnwụ bilie nʼụbọchị ikpeazụ.\wj* 
\v 40 \wj Nke a bụ uche nke Nna m, na onye ọbụla lere Ọkpara ahụ anya, kwerekwa na ya ga-enweta ndụ ebighị ebi, m ga-emekwa ka o bilie nʼụbọchị ikpeazụ.”\wj* 
\p  
\v 41 Nʼihi nke a, ndị Juu bidoro itamu ntamu megide ya nʼihi na ọ sịrị, \wj “Abụ m achịcha ahụ siri nʼeluigwe rịdata.”\wj* 
\v 42 Ha sịrị, “Onye a ọ bụghị Jisọs, nwa Josef, bụ onye anyị matara nne na nna ya? Oleekwanụ otu o si ekwu ugbu a sị, \wj ‘Esi m nʼeluigwe rịdata’\wj*?” 
\p  
\v 43 Jisọs zara sị ha, \wj “Unu atamula nʼetiti onwe unu.\wj* 
\v 44 \wj O nweghị onye nwere ike ịbịakwute m ma ọ bụghị na Nna ahụ zitere m kpọtara ya, aga m akpọlitekwa ya nʼụbọchị ikpeazụ.\wj* 
\v 45 \wj E dere ya nʼakwụkwọ ndị amụma, ‘Ha niile ga-abụ ndị Chineke ga-akụziri ihe.’\wj*\f + \fr 6:45 \ft \xt Aịz 54:13\f*\wj Onye ọbụla nke gere Nna ahụ ntị ma mụtakwa ihe site na ya na-abịakwute m.\wj* 
\v 46 \wj O nweghị onye ọbụla hụrụla Nna ahụ karịakwa onye ahụ sitere na Chineke, naanị ya hụrụla Nna ahụ.\wj* 
\v 47 \wj Nʼeze, nʼezie agwa m unu, onye ọbụla kwerenụ nwere ndụ ebighị ebi.\wj* 
\v 48 \wj Abụ m achịcha nke ndụ.\wj* 
\v 49 \wj Nna nna unu ha riri mánà ahụ nʼime ọzara ma mecha nwụọ.\wj* 
\v 50 \wj Ma nke a bụ achịcha ahụ nke si nʼeluigwe bịa, nke mmadụ pụrụ iri ma ghara ịnwụ anwụ.\wj* 
\v 51 \wj Abụ m achịcha dị ndụ nke siri nʼeluigwe bịa. Ọ bụrụ na onye ọbụla erie achịcha a, ọ ga-adị ndụ ruo ebighị ebi. Nri a bụ anụ ahụ m, nke m ga-enye maka ndụ nke ụwa.”\wj* 
\p  
\v 52 Mgbe ahụ, ndị Juu bidoro na-arụrịta ụka ike nʼetiti onwe ha sị, “Olee otu nwoke a ga-esi nye anyị anụ ahụ ya ka anyị rie?” 
\p  
\v 53 Jisọs sịrị ha, \wj “Nʼezie, nʼezie agwa m unu, naanị ma unu riri anụ ahụ Nwa nke Mmadụ ma ṅụọkwa ọbara ya, unu agaghị enwe ndụ nʼime onwe unu.\wj* 
\v 54 \wj Onye ọbụla riri anụ ahụ m, ṅụọkwa ọbara m nwere ndụ ebighị ebi. A ga m akpọlitekwa ya nʼụbọchị ikpeazụ ahụ.\wj* 
\v 55 \wj Nʼihi na anụ ahụ m bụ ezigbo nri, ọbara m bụkwa ezigbo ihe ọṅụṅụ.\wj* 
\v 56 \wj Onye ọbụla na-eri anụ ahụ m na-aṅụkwa ọbara m na-anọgide nʼime m mụ onwe m kwa nʼime ya.\wj* 
\v 57 \wj Dị ka Nna ahụ dị ndụ zitere m, ana m adịkwa ndụ nʼihi Nna ahụ, otu a ka onye na-eri m ga-adịkwa ndụ site na m.\wj* 
\v 58 \wj Nke a bụ achịcha ahụ si nʼeluigwe bịa. Nna nna unu ha riri mánà ma nwụkwaa, ma onye ọbụla na-eri achịcha a ga-adị ndụ ruo mgbe ebighị ebi.”\wj* 
\v 59 O kwuru ihe ndị a mgbe ọ na-akụzi ihe nʼụlọ ekpere dị na Kapanọm. 
\s1 Ọtụtụ ndị na-eso ụzọ ya a hapụ Jisọs 
\p  
\v 60 Mgbe ọtụtụ nʼime ndị na-eso ụzọ ya ha nụrụ nke a, ha sịrị, “Nke a bụ ozizi siri ike, onye nwere ike ịnabata ya?” 
\p  
\v 61 Ebe Jisọs matara na ndị na-eso ụzọ ya na-atamu ntamu maka nke a ọ sịrị ha, \wj “Nke a ọ na-ewute unu?\wj* 
\v 62 \wj Gịnị ka unu ga-ekwu ma ọ bụrụ na unu ahụ Nwa nke Mmadụ ka ọ na-arịgo ebe ọ nọrịị na mbụ.\wj* 
\v 63 \wj Ọ bụ Mmụọ ahụ na-enye ndụ; anụ ahụ abaghị uru ọbụla, okwu ndị m gwara unu bụ mmụọ bụrụkwa ndụ.\wj* 
\v 64 \wj Ma nʼetiti unu, ọ dị ụfọdụ na-ekwenyeghị.”\wj* Nʼihi na Jisọs maara site na mmalite ndị ahụ nʼime ha na-ekwenyeghị, matakwa onye ahụ nke ga-arara ya nye.  
\v 65 Ọ sịrị, \wj “Ọ bụ nke a mere m jiri gwa unu na o nweghị onye ọbụla nwere ike ịbịakwute m ma ọ bụrụ na Nna m enyeghị ya ike.”\wj* 
\p  
\v 66 Nʼihi nke a, ọtụtụ ndị na-eso ụzọ ya laghachiri azụ, kwụsị iso ya. 
\p  
\v 67 Jisọs sịrị mmadụ iri na abụọ ahụ, \wj “Unu chọkwara iso ha pụọ?”\wj* 
\p  
\v 68 Saimọn Pita zara ya sị, “Onyenwe anyị, onye ka anyị ga-agakwuru? Ọ bụ gị ji okwu nke ndụ ebighị ebi.  
\v 69 Anyị kweere marakwa na ị bụ Onye Nsọ nke Chineke.” 
\p  
\v 70 Jisọs zara ha, \wj “Ọ bụghị m họpụtara unu mmadụ iri na abụọ? Ma otu onye nʼime unu bụ ekwensu!”\wj* 
\v 71 Ọ na-ekwu banyere Judas nwa Saimọn Iskarịọt, onye nʼagbanyeghị na ọ bụ otu nʼime mmadụ iri na abụọ ahụ, bụ onye ga-arara ya nye. 
\c 7  
\s1 Jisọs na ụmụnne ya 
\p  
\v 1 Mgbe nke a gasịrị, Jisọs gagharịrị na Galili, ma ọ kpachapụrụ anya hapụ ịga Judịa nʼihi na ndị Juu na-achọ ụzọ igbu ya.  
\v 2 Mmemme Ụlọ ikwu ndị Juu dị nso,\f + \fr 7:2 \ft Nke a bụ mmemme ndị Juu ji echeta ịdị ndụ ha biri nʼọzara mgbe ha hapụrụ ala Ijipt.\f* 
\v 3 ya mere, ụmụnne ya ndị nwoke sịrị ya, “Si nʼebe a pụọ, gaa Judịa, ka ndị na-eso ụzọ gị nwe ike ịhụ ọrụ ị na-arụ.  
\v 4 Nʼihi na o nweghị onye ọbụla chọrọ ịbụ onye ọha mmadụ ma, nke na-eme ihe na nzuzo. Ebe ọ bụkwanụ na ị na-eme ihe ndị a, gosi ụwa onwe gị.”  
\v 5 Nʼihi na ọ bụladị ụmụnne ya ekwenyeghị na ya. 
\p  
\v 6 Jisọs sịrị ha, \wj “Oge nke m erubeghị, ma oge nke unu nọ nʼebe a mgbe niile.\wj* 
\v 7 \wj Ụwa enweghị ike ịkpọ unu asị, ma ọ kpọrọ m asị nʼihi na ana m agba ama megide ya nʼọrụ ya jọrọ njọ.\wj* 
\v 8 \wj Unu onwe unu gaanụ na mmemme ahụ, agaghị m aga mmemme a nʼihi na oge m erubeghị.”\wj* 
\v 9 Mgbe o kwusiri nke a, ọ nọgidere na Galili. 
\p  
\v 10 Ma otu ọ dị, mgbe ụmụnne ya gawara mmemme ahụ ya onwe ya gakwara. Ọ gaghị ebe mmadụ niile ga-ahụ ya kama ọ gara na nzuzo.  
\v 11 Na mmemme ahụ ndị Juu nọ na-ele anya ma na-ajụgharị sị, “Olee ebe ọ nọ?” 
\p  
\v 12 E nwere oke ntamu nʼetiti igwe mmadụ ahụ banyere ya. Ndị ụfọdụ na-asị, “Ọ bụ ezigbo mmadụ.” 
\p Ndị ọzọ na-asị, “Mba, ọ na-eduhie igwe mmadụ.”  
\v 13 Ma o nweghị onye ọbụla kwulitere okwu maka ya nʼihu ọha nʼihi egwu ndị Juu. 
\s1 Jisọs a kuzie ihe na mmemme ahụ 
\p  
\v 14 Mgbe o ruru nʼetiti mmemme ahụ, Jisọs banyere nʼime ụlọnsọ ukwu ma bido ikuzi ihe.  
\v 15 Site nʼoke mgbagwoju anya, ndị Juu jụrịtara onwe ha sị, “Olee otu nwoke a sịrị nweta amamihe dị otu a ebe ọ bụ na o nwebeghị onye kuziri ya ihe ọbụla?” 
\p  
\v 16 Jisọs zara ha, \wj “Ozizi m abụghị nke m, kama ọ bụ nke onye ahụ zitere m.\wj* 
\v 17 \wj Onye ọbụla na-achọ ime uche Chineke, ọ ga-achọpụta ma ozizi m ọ bụ nke m ma o sikwanụ na Chineke.\wj* 
\v 18 \wj Ndị ahụ na-ekwu nke onwe ha na-eme nke a iji wetara onwe ha ugwu, ma onye ahụ na-achọ ugwu nke onye zitere ya bụ onye eziokwu; o nwekwaghị ihe ọbụla bụ ụgha banyere ya.\wj* 
\v 19 \wj Mosis o nyeghị unu iwu? Ma o nweghị onye ọbụla nʼime unu na-edebe iwu ahụ. Gịnị mere unu ji achọ igbu m?”\wj* 
\p  
\v 20 Igwe mmadụ ahụ zara, “Mmụọ ọjọọ bi nʼime gị, onye chọrọ igbu gị?” 
\p  
\v 21 Jisọs zara sị ha, \wj “Arụrụ m otu ọrụ, ma unu niile nọ na mgbagwoju anya.\wj* 
\v 22 \wj Mosis nyere unu iwu ibi ugwu (nʼagbanyeghị na o siteghị na Mosis, kama na nna nna anyị ha), nʼụbọchị izuike unu na-ebikwa mmadụ ugwu.\wj* 
\v 23 \wj Ọ bụrụ na e nwere ike bie mmadụ ugwu nʼụbọchị izuike ka a ghara imebi iwu Mosis, gịnị mere o ji na-ewute unu na m mere ka ahụ mmadụ zuo oke nʼụbọchị izuike?\wj* 
\v 24 \wj Kwụsịnụ ikpe ikpe site nʼihe anya na-ahụ, kama na-ekpenụ ikpe ziri ezi.”\wj* 
\s1 Ọ bụ Jisọs bụ Kraịst? 
\p  
\v 25 Nʼoge ahụ, ụfọdụ nʼime ndị Jerusalem bidoro na-asị, “Onye a ọ bụghị nwoke ahụ ha chọrọ igbu?  
\v 26 Lee ka ọ nọ na-ekwu okwu nʼihu mmadụ niile ma o nwekwaghị onye na-agwa ya ihe ọbụla. Ọ pụtara na ndịisi amatala nʼeziokwu na ọ bụ Kraịst?  
\v 27 Ma anyị matara ebe nwoke a siri pụta, mgbe Kraịst ahụ ga-abịa, o nweghị onye ga-amata ebe o siri pụta.” 
\p  
\v 28 Ma dị ka Jisọs na-ezi ihe nʼime ụlọnsọ ukwuu ahụ, o tiri mkpu sị, \wj “Nʼezie, unu maara m, matakwa ebe m siri pụta. Anọghị m nʼebe a na nke onwe m, ma onye ahụ zitere m bụ eziokwu. Unu amaghị ya.\wj* 
\v 29 \wj Ma amara m ya, nʼihi na esitere m na ya bịa. Ọ bụkwa ya zitere m.”\wj* 
\p  
\v 30 Mgbe ahụ ha chọrọ ijide ya, ma o nweghị onye ọbụla metụrụ ya aka nʼihi na oge ya erubeghị.  
\v 31 Ma otu ọ dị, ọtụtụ nʼime igwe mmadụ ahụ kweere na ya. Ha sịrị, “Mgbe Kraịst ahụ ga-abịa, ọ ga-arụ ọrụ ebube ọzọ karịrị ndị a nwoke a rụrụla?” 
\p  
\v 32 Ndị Farisii nụrụ ka igwe mmadụ ahụ na-atamu ntamu nʼolu nta banyere ya. Mgbe ahụ ndịisi nchụaja na ndị Farisii zigara ndị na-eche nche nʼụlọnsọ ukwuu ahụ ka ha gaa jide ya. 
\p  
\v 33 Jisọs sịrị, \wj “Naanị nwa oge ka mụ na unu ga-anọ, aga m alakwurukwa onye zitere m.\wj* 
\v 34 \wj Unu ga-achọ m ma unu agaghị achọta m. Ebe m na-agakwa unu enweghị ike ịbịaru ya.”\wj* 
\p  
\v 35 Ndị Juu sịrịtara onwe ha, “Olee ebe nwoke a chọrọ ịga anyị na-agaghị achọta ya? Ọ ga-eje ebe ndị nke anyị a chụsasịrị achụsasị bi nʼetiti ndị Griik, ka ọ ga kuziere ndị Griik ihe?  
\v 36 Kedụ ụdị okwu bụ nke a ọ na-ekwu sị, \wj ‘Unu ga-achọ m ma unu agaghị achọta m,’\wj* na \wj ‘Ebe m na-agakwa unu enweghị ike ịbịaru’\wj*?” 
\s1 Isi iyi mmiri nke ndụ 
\p  
\v 37 Nʼụbọchị ikpeazụ bụkwa ụbọchị kacha ibe ya nke mmemme ahụ, Jisọs guzooro ọtọ jiri oke olu tie mkpu sị, \wj “Ọ bụrụ na akpịrị na-akpọ onye ọbụla nkụ, ya bịakwute m bịa ṅụrụ mmiri.\wj* 
\v 38 \wj Onye ọbụla kweere na m, dị ka akwụkwọ nsọ kwururị, isi iyi mmiri nke ndụ ga na-asọpụta site nʼime afọ ya.”\wj* 
\v 39 O kwuru nke a banyere Mmụọ ahụ ndị kwere na ya ga-anata. Tutu ruo oge ahụ, e nyebeghị Mmụọ ahụ, nʼihi na e nyebeghị Jisọs otuto. 
\p  
\v 40 Mgbe ha nụrụ nke a, ụfọdụ nʼime igwe mmadụ ahụ sịrị, “Nʼeziokwu onye a bụ onye amụma ahụ.” 
\p  
\v 41 Ndị ọzọ sịrị, “Ọ bụ Kraịst ahụ.” 
\p Ma ndị nke ọzọ sịkwara, “Nʼezie Kraịst ahụ, ọ ga-esi na Galili pụta?  
\v 42 Ọ bụ na akwụkwọ nsọ ekwughị na Kraịst ga-esi nʼagbụrụ Devid pụta, na Betlehem bụ obodo Devid?”  
\v 43 Ya mere nkewa dapụtara nʼetiti igwe mmadụ ahụ nʼihi ya.  
\v 44 Ụfọdụ chọrọ ijide ya ma ọ dịghị onye ọbụla metụrụ ya aka. 
\s1 Ekweghị ekwe nke ndị ndu ndị Juu 
\p  
\v 45 Mgbe ahụ, ndị nche ụlọnsọ ukwu lọghachiri nʼebe ndịisi nchụaja na ndị Farisii nọ, ndị sịrị ha, “Gịnị mere unu akpụtaghị ya?” 
\p  
\v 46 Ha zara, “Anyị ahụbeghị onye kwuru okwu dị ka nwoke a.” 
\p  
\v 47 Ndị Farisii zara ha, “Unu esorola bụrụ ndị a ghọgburu?  
\v 48 Ọ dị onye ọbụla nʼime ndịisi maọbụ nʼime ndị Farisii tụkwasịrị ya obi?  
\v 49 E e! Kama igwe mmadụ ndị a na-amaghị iwu bụ ndị a bụrụ ọnụ.” 
\p  
\v 50 Nikọdimọs, otu nʼime ha bụ onye bịakwutere ya na mbụ sịrị ha,  
\v 51 “Iwu anyị ọ na-ama mmadụ ikpe, ma ọ bụrụ na o bụghị ụzọ nụta okwu nʼọnụ ya, ịchọpụta ihe onye ahụ na-eme?” 
\p  
\v 52 Ha zaghachiri ya sị, “Gị onwe gị, i sokwa na ndị si Galili pụta? Nyochaa nke ọma, ị ga-achọpụta na onye amụma ọbụla agaghị esi na Galili pụta.” 
\iex [Akwụkwọ ndị mbụ na ọtụtụ ndị ochie gbara akaebe enweghị amaokwu nke iri ise na atọ nʼakwụkwọ Jọn isi nke asaa ruo Jọn isi asatọ amaokwu nke iri na otu \xt Jọn 7:53–8:11\xt*. Ụfọdụ akwụkwọ na-edebanye amaokwu ndị a, nʼebe o zuruoke maọbụ ụfọdụ nʼime ya, ma o bụrụ na ha edechaa Jọn isi asaa amaokwu nke iri atọ na isii, \xt Jọn 7:36\xt*, \xt Jọn 21:25\xt*, \xt Luk 21:38\xt* maọbụ \xt Luk 24:53\xt*.] 
\p  
\v 53 \it Mgbe ahụ, onye ọbụla nʼime ha lara nʼụlọ ya.\it* 
\c 8  
\nb  
\v 1 \it Ma Jisọs rigooro nʼUgwu Oliv.\it* 
\p  
\v 2 \it Nʼisi ụtụtụ echi ya, ọ bịara ọzọ nʼụlọnsọ ukwuu ebe ọtụtụ mmadụ bịakwutere ya. Ọ nọdụrụ ala malite ikuziri ha ihe.\it* 
\v 3 \it Ndị ozizi iwu na ndị Farisii dọkpụtara otu nwanyị ha jidere nʼịkwa iko. Ha mere ka o guzo nʼihu igwe mmadụ ahụ niile.\it* 
\v 4 \it Ha sịrị ya, “Onye ozizi, anyị jidere nwanyị a ka ọ na-akwa iko.\it* 
\v 5 \it Nʼiwu, Mosis nyere anyị ikike ka e jiri okwute tugbuo onye mere ihe dị otu a. Gịnị ka i nwere ikwu banyere nke a?”\it* 
\v 6 \it Ha kwuru nke a iji nwalee ya, iji nweta ihe ha ga-eji ebo ya ebubo.\it* 
\p \it Ma Jisọs hulatara ala were mkpịsịaka ya dee ihe nʼala.\it* 
\v 7 \it Mgbe ha nọgidere na-ajụ ya ajụjụ, o biliri sị ha, \+wj “Onye ọbụla nʼime unu na-emebeghị mmehie ọbụla, ya buru ụzọ tụọ ya nkume.”\+wj*\it* 
\v 8 \it Ọzọ, o hulatakwara ala malite ide ihe ọ na-ede nʼala.\it* 
\p  
\v 9 \it Mgbe ha nụrụ nke a, ha niile nʼotu nʼotu, malite nʼonye okenye ha, sitere nʼebe ahụ pụọ. Nʼikpeazụ, ọ fọdụrụ naanị Jisọs na nwanyị ahụ, ebe o guzoro nʼihu ya.\it* 
\v 10 \it Jisọs guzoro ọtọ jụọ ya sị, \+wj “Nwanyị, oleekwanụ ha? Ọ dịghị onye mara gị ikpe?”\+wj*\it* 
\p  
\v 11 \it Ọ sịrị, “O nweghị onye ọbụla Onyenwe anyị.”\it* 
\p \it Jisọs sịrị ya, \+wj “Mụ onwe m amakwaghị gị ikpe: Gawa, kama emehiekwala ọzọ.”\+wj*\it* 
\s1 Jisọs ìhè nke ụwa 
\p  
\v 12 Ọzọ, Jisọs gwara ha sị, \wj “Abụ m ihe nke ụwa. Onye ọbụla na-eso m agaghị ejegharị nʼọchịchịrị, kama ọ ga-enwe ìhè nke ndụ.”\wj* 
\p  
\v 13 Ndị Farisii sịrị, “Ị na-agbara onwe gị ama! Ya mere ama ị na-agbara onwe gị abụghị ezie.” 
\p  
\v 14 Ma Jisọs zara sị, \wj “A sịkwarị na mụ na-agbara onwe m ama, ama m na-agba bụ eziokwu. Nʼihi na-amara m ebe m si bịa, marakwa m ebe m na-aga. Ma unu aghọtaghị ebe m si bịa, maọbụ ebe m na-aga.\wj* 
\v 15 \wj Unu na-ekpe ikpe dị ka mmadụ; ma ekpeghị m onye ọbụla ikpe.\wj* 
\v 16 \wj Ma ọ bụrụ na m ekpe ikpe, ikpe m bụ eziokwu nʼihi na ọ bụghị naanị m nọ, kama ọ bụ mụ na Nna m, onye zitere m.\wj* 
\v 17 \wj E dere nʼiwu unu sị, ‘ama mmadụ abụọ gbara bụ eziokwu.’\wj* 
\v 18 \wj Ana m agba ama banyere onwe m. Nna m, onye zitere m, na-agbakwa ama banyere m.”\wj* 
\p  
\v 19 Mgbe ahụ ha jụrụ ya, “Olee ebe Nna gị nọ?” 
\p Jisọs zara, \wj “Unu amaghị m, unu amakwaghị Nna m. Ọ bụrụ na unu matara m unu ga-amatakwa onye Nna m bụ.”\wj* 
\v 20 Okwu ndị a niile ka o kwuru nʼụlọnsọ ukwu ha, mgbe ọ na-akụzi ihe na mpaghara ụlọ ahụ ebe a na-adọba onyinye. Ma ọ dịghị onye ọbụla jidere ya nʼihi na oge ya erubeghị. 
\s1 Jisọs ekwuo banyere ọnwụ ya 
\p  
\v 21 Ọzọ ọ gwara ha, \wj “Aga m ahapụ unu, unu ga-achọ m, ma unu ga-anwụ nʼime mmehie unu. Ma unu apụghị ịbịa nʼebe m na-aga.”\wj* 
\p  
\v 22 Nke a mere ka ndị Juu na-asị, “Ọ ga-egbu onwe ya? Ọ bụ ya mere o ji sị, \wj ‘Ebe m na-aga unu apụghị ị bịa’\wj*?” 
\p  
\v 23 Ma ọ sịrị ha, \wj “Unu si nʼala ma esi m nʼelu bịa. Unu bụkwa ndị ụwa, ma abụkwaghị m nke ụwa a.\wj* 
\v 24 \wj A sịrị m unu na unu ga-anwụ nʼime mmehie unu, naanị na unu kwenyere na mụ onwe m, bụ onye ahụ.”\wj* 
\p  
\v 25 Ha jụrụ ya, “Onye ka ị bụ?” 
\p Jisọs zara sị ha, \wj “Abụ m onye ahụ m gwara unu na m bụ na mbụ.\wj* 
\v 26 \wj E nwere m ọtụtụ ihe m ga-ekwu nʼikpe unu ikpe. Ma matanụ na onye ahụ zitere m bụ onye eziokwu. Nʼihi nke a, ihe niile m nụrụ site nʼọnụ ya ka m gwara ụwa.”\wj* 
\p  
\v 27 Ọ bụ ihe banyere Nna ya ka ọ na-agwa ha, ma ha aghọtaghị ya.  
\v 28 Ya mere Jisọs sịrị, \wj “Mgbe unu weliri Nwa nke Mmadụ elu, mgbe ahụ ka unu ga-ama na mụ onwe m bụ ya. Unu ga-amatakwa na ọ dịghị ihe m na-eme nʼonwe m, kama, dị ka Nna m ziri m ka m na-ekwu ihe ndị a.\wj* 
\v 29 \wj Onye ahụ nke zitere m na-anọnyekwara m. Ọ hapụghịkwa m mgbe ọbụla, nʼihi na ọ bụ ihe na-amasị ya ka m na-eme mgbe niile.”\wj* 
\v 30 Mgbe ọ na-ekwu ihe ndị a, ọtụtụ kwenyere na ya. 
\s1 Ụmụ nke Ebraham 
\p  
\v 31 Jisọs gwara ndị Juu ndị kwere na ya, \wj “Ọ bụrụ na unu anọgide nʼokwu m nʼezie unu ga-abụ ndị na-eso ụzọ m.\wj* 
\v 32 \wj Unu ga-amatakwa eziokwu ahụ, eziokwu ahụ ga-emekwa ka unu nwere onwe unu.”\wj* 
\p  
\v 33 Ha zara ya, “Anyị bụ ụmụ Ebraham, o nwebeghị oge anyị ji bụrụ ohu onye ọbụla. Olee otu i si na-asị na a ga-eme ka anyị nwere onwe anyị?” 
\p  
\v 34 Jisọs zara ha, \wj “Nʼezie, nʼezie asị m unu, onye ọbụla na-eme mmehie bụ ohu mmehie.\wj* 
\v 35 \wj Ohu enwekwaghị ọnọdụ mgbe ọbụla nʼezinaụlọ, ma ọkpara nwere ọnọdụ ruo ebighị ebi.\wj* 
\v 36 \wj Ya mere, ọ bụrụ na Ọkpara ahụ emee ka unu nwere onwe unu nʼezie, unu ga-abụ ndị nwere onwe unu.\wj* 
\v 37 \wj Ama m na unu bụ ụmụ ụmụ Ebraham, ma unu na-achọ igbu m nʼihi na okwu m enweghị ọnọdụ nʼime unu.\wj* 
\v 38 \wj Ana m ekwu ihe m hụrụ nʼebe Nna m nọ, ma unu na-eme ihe unu nụrụ site nʼaka nna unu.”\wj* 
\p  
\v 39 Ha zara ya, “Ebraham bụ nna anyị.” 
\p Jisọs sịrị ha, \wj “Ọ bụrụ na unu bụ ụmụ Ebraham, unu gara na-arụ ọrụ Ebraham rụrụ.\wj* 
\v 40 \wj Ma unu na-achọ igbu m, bụ onye gwara unu eziokwu ahụ m nụrụ nʼebe Chineke nọ. Ebraham emeghị otu a.\wj* 
\v 41 \wj Unu na-arụ ọrụ nna unu rụrụ.”\wj* 
\p Ha sịrị ya, “Anyị abụghị ụmụ a mụrụ site nʼịkwa iko; naanị Chineke ya onwe ya bụ otu Nna anyị nwere.” 
\s1 Ụmụ nke Ekwensu 
\p  
\v 42 Jisọs gwara ha, \wj “Ọ bụrụ nʼezie na Chineke bụ Nna unu, unu ga-ahụ m nʼanya, nʼihi na ọ bụ Chineke zitere m. Abịaghị m site nʼike aka m.\wj* 
\v 43 \wj Gịnị mere unu adịghị aghọta ihe m na-ekwu? Ọ bụ na unu enweghị ike ịnabata okwu m.\wj* 
\v 44 \wj Unu bụ ụmụ nke nna unu ekwensu. Uche unu bụ imezu ihe nke nna unu na-achọ. Ọ bụ ogbu ọchụ site na mbụ. Ọ dịghị ejigide eziokwu nʼihi na eziokwu adịghị nʼime ya. Mgbe ọ na-ekwu okwu ụgha, ọ na-ekwu dị ka ọdịdị ya sịrị dị, nʼihi na ọ bụ onye ụgha bụrụkwa nna nke ụgha.\wj* 
\v 45 \wj Ma nʼihi na m na-ekwu eziokwu, ọ bụ ya mere unu ekwenyeghị na m.\wj* 
\v 46 \wj O nwere onye nʼime unu pụrụ ịtụ m mmehie m nʼihu? Ọ bụrụ na m na-ekwu eziokwu, gịnị mere unu ekwenyeghị na m?\wj* 
\v 47 \wj Onye ọbụla sitere na Chineke na-anụ ihe Chineke na-ekwu. Ihe kpatara unu adịghị anụ bụ maka unu abụghị ndị nke Chineke.”\wj* 
\s1 Jisọs na Ebraham 
\p  
\v 48 Ndị Juu zara sị, “Anyị e kwughị eziokwu mgbe anyị sịrị na ị bụ onye Sameria, na mmụọ ọjọọ bikwa nʼime gị?” 
\p  
\v 49 Jisọs zaghachiri, \wj “Mmụọ ọjọọ ọbụla adịghị nʼime m, kama ana m asọpụrụ Nna m, ma unu adịghị asọpụrụ m.\wj* 
\v 50 \wj Anaghị m achọ otuto nke onwe m, kama ọ dị onye nke na-achọ ya. Ọ bụkwa ya bụ onye ikpe.\wj* 
\v 51 \wj Nʼezie, nʼezie, agwa unu, onye ọbụla na-edebe okwu m agaghị anwụ ọzọ.”\wj* 
\p  
\v 52 Mgbe ahụ ndị Juu sịrị ya, “Anyị maara ugbu a na mmụọ ọjọọ bi nʼime gị. Ebraham nwụrụ anwụ ya na ndị amụma, ma gị onwe gị na-asị na onye ọbụla kwere na gị agaghị anwụ ruo mgbe ebighị ebi.  
\v 53 Ị dị ukwuu karịa nna anyị Ebraham? Ọ nwụrụ, ma ndị amụma nwụkwara. Onye ka ị na-eche na ị bụ?” 
\p  
\v 54 Jisọs zara, \wj “Ọ bụrụ na m etoo onwe m, otuto m bụ ihe efu, Nna m, onye unu na-asị na ọ bụ Chineke unu, bụ onye na-eto m.\wj* 
\v 55 \wj Amaara m onye ọ bụ nʼagbanyeghị na unu amaghị ya. Aga m abụ onye ụgha ma ọ bụrụ na m ga-asị na-amaghị m onye ọ bụ. Amaara m ya na-edebekwa okwu ya.\wj* 
\v 56 \wj Nna unu Ebraham ṅụrịrị ọṅụ mgbe o chetara na ọ ga-ahụ ụbọchị m; ọ hụrụ ya ma ṅụrịakwa ọnụ.”\wj* 
\p  
\v 57 Ndị Juu sịrị ya, “Ị gbabeghị iri afọ ise ma ị hụla Ebraham?” 
\p  
\v 58 Jisọs sịrị ha, \wj “Nʼezie, nʼezie agwa m unu, tupu amụọ Ebraham, mụ onwe m nọ ya.”\wj* 
\v 59 Ya mere, ha tụtụlitere nkume ịtụ ya, ma Jisọs zoro onwe ya, sitekwa nʼụlọnsọ ukwuu ahụ pụọ. 
\c 9  
\s1 Jisọs agwọọ onye ìsì 
\p  
\v 1 Mgbe ọ na-agafe, ọ hụrụ otu nwoke kpuru ìsì site nʼafọ nne ya.  
\v 2 Ndị na-eso ụzọ ya jụrụ ya sị, “Onye ozizi, onye mehiere? Nwoke a ka ọ bụ ndị mụrụ ya, nke mere e ji mụọ ya nʼìsí?” 
\p  
\v 3 Jisọs sịrị, \wj “Nwoke a emehieghị, ndị mụrụ ya emehiekwaghị, kama o kpuru ìsì ka ọrụ Chineke pụta ìhè na ndụ ya.\wj* 
\v 4 \wj Anyị aghaghị ịrụ ọrụ onye ahụ zitere m, mgbe chi ka dị, anyasị na-abịa mgbe o nweghị onye pụrụ ịrụ ọrụ.\wj* 
\v 5 \wj Dị ka m nọ nʼụwa, Abụ m ìhè nke ụwa.”\wj* 
\p  
\v 6 Mgbe o kwusiri nke a, ọ bụsara ọnụ mmiri asụ nʼala gwakọta ya na aja, werekwa aja ahụ tee nwoke ahụ nʼanya.  
\v 7 Ọ gwara ya, \wj “Gaa nʼọdọ mmiri Sailọm saa ihu gị”\wj* (nke a pụtara “Zitere”). Ọ gara saa ihu ya, lọghachita na-ahụ ụzọ. 
\p  
\v 8 Ndị agbataobi ya na ndị nʼahụ ya nʼoge gara aga ka ọ na-arịọ arịrịọ sịrị, “Nke a, ọ bụghị nwoke ahụ na-anọdụ ala na-arịọ arịrịọ?”  
\v 9 Ụfọdụ na-asị, “Ọ bụ ya.” 
\p Ma ndị ọzọ na-asịkwa, “Ọ bụghị ya. Ọ bụ onye yiri ya.” 
\p Ma ọ na-asị, “Abụ m nwoke ahụ.” 
\p  
\v 10 Ha na-asị ya, “Olee otu anya gị sịrị meghee?” 
\p  
\v 11 Ọ zara, “Nwoke a na-akpọ Jisọs gwakọtara ụrọ tee m nʼanya. Ọ gwara m sị, ‘Gaa saa ihu gị nʼọdọ mmiri Sailọm.’ A gara m saa onwe m, malitekwa ịhụ ụzọ.” 
\p  
\v 12 Ha sịrị ya, “Olee ebe nwoke ahụ nọ?” 
\p Ọ sịrị, “Amaghị m.” 
\s1 Ndị Farisii emee nchọpụta maka ọgwụgwọ ahụ 
\p  
\v 13 Ha dutere nwoke ahụ kpuru ìsì na mbụ nʼihu ndị Farisii.  
\v 14 Ma ọ bụ nʼụbọchị izuike ka Jisọs gwakọtara aja, jiri ya meghe anya ya.  
\v 15 Ya mere, ndị Farisii jụrụ ya otu o si bido ịhụ ụzọ. Ọ sịrị ha, “Ọ gwakọtara aja tee m nʼanya, a sakwara m ihu ma ugbu a ana m ahụ ụzọ.” 
\p  
\v 16 Ụfọdụ ndị Farisii sịrị, “Nwoke a esiteghị nʼebe Chineke nọ bịa, nʼihi na ọ dịghị edebe ụbọchị izuike.” 
\p Ma ndị ọzọ na-asị, “Olee otu onye mmehie ga-esi rụọ ọrụ ịrịbama ndị dị otu a?” Nkewa dịrị nʼetiti ha. 
\p  
\v 17 Ya mere, ha sịrị nwoke ahụ kpuru ìsì, “Gịnị ka i nwere ikwu banyere ya? Ọ bụ anya gị ka o meghere.” 
\p Ọ sịrị, “Ọ bụ onye amụma.” 
\p  
\v 18 Ma ndị Juu ahụ ekweghị na nwoke a bụ onye kpuru ìsì na mbụ, nke e mere ka ọ hụ ụzọ, tutu ruo mgbe ha kpọrọ ndị mụrụ ya.  
\v 19 Ha jụrụ ha sị, “Onye a ọ bụ nwa unu, onye unu na-asị na o kpuru ìsì site nʼoge a mụrụ ya? O si aṅaa ahụ ụzọ ugbu a?” 
\p  
\v 20 Ndị mụrụ ya zara, “nke a bụ nwa anyị. Anyị matakwara na o kpuru ìsì site nʼoge anyị mụrụ ya.  
\v 21 Ma otu o si ahụ ụzọ ugbu a maọbụ onye meghere anya ya, anyị amaghị. Jụọnụ ya. Ọ bụ dimkpa, ya zara ọnụ ya.”  
\v 22 Ihe a ka ndị mụrụ ya kwuru nʼihi na ha na-atụ egwu ndị Juu. Ndị kpebirila na ọ bụrụ na onye ọbụla ekwuo na Jisọs bụ Kraịst ahụ, ha ga-achụpụ onye ahụ site nʼụlọ ekpere ha.  
\v 23 Nke a mere ndị mụrụ ya jiri sị, “Ọ bụ dimkpa, unu jụọ ya.” 
\p  
\v 24 Ha kpọrọ nwoke a nke ugboro abụọ, bụ onye ahụ kpuburu ìsì, sị ya, “Nye Chineke otuto. Anyị maara na nwoke a bụ onye mmehie.” 
\p  
\v 25 Ọ zara, “Amaghị m maọbụ onye mmehie ma ọ bụghị. Ma otu ihe ka m maara, ekpuru m ìsì na mbụ ma ugbu a ana m ahụ ụzọ.” 
\p  
\v 26 Ha sịrị ya, “Gịnị ka o mere gị? Olee otu o si meghe anya gị?” 
\p  
\v 27 Ọ zara ha, “Agwala m unu ihe niile, ma unu achọghị ikwere. Gịnị mere unu ji chọọ ịnụ ya ọzọ? Unu chọkwara ịghọ ndị na-eso ụzọ ya?” 
\p  
\v 28 Ha bigbọrọ ya sị, “Gị onwe gị bụrụkwa onye na-eso ụzọ ya! Anyị bụ ndị na-eso ụzọ Mosis.  
\v 29 Anyị mara na Chineke gwara Mosis okwu, ma gbasara nwoke a, anyị amaghị ebe o siri bịa.” 
\p  
\v 30 Nwoke ahụ zaghachiri sị ha, “Ma otu ọ dị, nke a bụ ihe ịtụnanya! Unu amaghị ebe o sịrị bịa ma o meghere anya m.  
\v 31 Anyị mara na Chineke adịghị ege ndị mmehie ntị, ma ọ na-ege ntị onye na-atụ egwu ya na onye na-eme uche ya.  
\v 32 Site na mgbe e kere ụwa, ọ dịbeghị onye a nụrụ na o meghere anya onye kpuru ìsì.  
\v 33 Ọ bụrụ na nwoke a esiteghị nʼebe Chineke nọ, ọ gaghị enwe ike ime ihe ọbụla.” 
\p  
\v 34 Ha zara sị ya, “Gị onye a mụrụ nʼime mmehie, ị na-achọ ikuziri anyị ihe?” Ha chụpụrụ ya nʼezi. 
\s1 Ikpu ìsì nke ime mmụọ 
\p  
\v 35 Jisọs nụrụ na ha achụpụla ya nʼezi, ma mgbe ọ chọtara ya, ọ sịrị ya, \wj “I kweere na Nwa nke Mmadụ?”\wj* 
\p  
\v 36 Ọ zara sị, “Onyenwe m, ọ bụ onye? Gwa m ka m nwe ike ikwere na ya.” 
\p  
\v 37 Jisọs sịrị ya, \wj “Ị hụla ya ugbu a; onye gị na ya na-ekwurịta okwu bụ onye ahụ.”\wj* 
\p  
\v 38 Ọ sịrị, “Onyenwe m, ekwela m.” Ọ kpọrọ isiala nye ya. 
\p  
\v 39 Jisọs sịrị, \wj “Ọ bụ nʼihi ikpe ka m ji bịa nʼụwa, ka ndị na-adịghị ahụ ụzọ bido ịhụ ụzọ, na ka ndị na-ahụ ụzọ ghọọ ndị kpuru ìsì.”\wj* 
\p  
\v 40 Mgbe ụfọdụ ndị Farisii nọ nso nʼebe ahụ nụrụ nke a, ha sịrị ya, “Anyị onwe anyị, anyị bụkwa ndị kpuru ìsì?” 
\p  
\v 41 Jisọs sịrị ha, \wj “Ọ bụrụ na unu kpuru ìsì, ikpe ọmụma mmehie agaghị ama unu, ma ugbu a ebe unu sị na unu na-ahụ ụzọ ikpe ọmụma unu na-adịgide.”\wj* 
\c 10  
\s1 Onye ọzụzụ atụrụ na igwe atụrụ ya 
\p  
\v 1 \wj “Nʼezie, nʼezie, agwa m unu, onye ọbụla na-adịghị esite nʼọnụ ụzọ aba nʼọgba atụrụ kama ọ na-arị elu ka o site nʼelu ụlọ ahụ wufee, bụ onye ohi bụrụkwa onye na-apụnara mmadụ ihe.\wj* 
\v 2 \wj Onye na-esite nʼọnụ ụzọ abanye bụ onye ọzụzụ atụrụ.\wj* 
\v 3 \wj Onye nche ọnụ ụzọ na-emeghere ya ụzọ, atụrụ ya na-anụkwa olu ya. Ọ na-akpọ atụrụ nke ya aha, ma duru ha pụọ.\wj* 
\v 4 \wj Mgbe ọ kpọpụtasịrị ndị niile bụ nke ya, ọ na-aga nʼihu ha. Atụrụ ya na-esokwa ya nʼazụ nʼihi na ha maara olu ya.\wj* 
\v 5 \wj Ha agaghị eso onye ọbịa, kama ha gbaara ya ọsọ. Nʼihi na ha amaghị olu onye ọbịa.”\wj* 
\v 6 Jisọs ji ihe yiri ihe gwa ha okwu. Ma ha aghọtaghị ihe ọ nọ na-agwa ha. 
\p  
\v 7 Ọzọ, Jisọs sịrị, \wj “Nʼezie, nʼezie, ana m agwa unu, mụ onwe m bụ ọnụ ụzọ ọgba atụrụ ahụ.\wj* 
\v 8 \wj Ndị niile bịara tupu mụ onwe m abịa bụ ndị ohi na ndị na-apụnara mmadụ ihe nʼike. Ụmụ atụrụ aṅakwaghị ha ntị.\wj* 
\v 9 \wj Mụ onwe m bụ ụzọ. Onye ọbụla sitere na m banye, a ga-azọpụta ya. Ọ ga na-apụ na-abata na-achọtakwa nri.\wj* 
\v 10 \wj Onye ohi na-abịa naanị ka o zuo ohi, gbuo ma bibiekwa; abịara m ka ha nwe ndụ ma nwebigakwa ya oke.\wj* 
\p  
\v 11 \wj “Mụ onwe m bụ onye ọzụzụ atụrụ ọma. Ezi onye ọzụzụ atụrụ na-atọgbọ ndụ ya nʼihi atụrụ ya.\wj* 
\v 12 \wj Onye e goro ọrụ, nke na-abụghị onye nche atụrụ, onye atụrụ na-abụghị nke ya, ọ na-ahapụ ha gbaa ọsọ mgbe ọ hụrụ agụ ka ọ na-abịa; mgbe ahụ agụ na-achụso atụrụ ahụ chụsasịa ha.\wj* 
\v 13 \wj Onye e goro ọrụ na-agbapụ, nʼihi na ọ bụ onye e goro ọrụ, ọ naghị echegbu onwe ya banyere atụrụ ndị ahụ.\wj* 
\p  
\v 14 \wj “Abụ m onye ọzụzụ atụrụ ọma; amaara m atụrụ m, atụrụ nke m makwaara m.\wj* 
\v 15 \wj Dị ka Nna ahụ maara m, mụ onwe m makwa Nna ahụ. Ana m atọgbọ ndụ m nʼihi atụrụ ahụ.\wj* 
\v 16 \wj Enwere m ụmụ atụrụ ọzọ ndị na-anọghị nʼọgba atụrụ a. Aghaghị m ịkpọbatakwa ha. Ha onwe ha ga-anụ olu m, a ga-enwekwa otu igwe atụrụ na otu onye ọzụzụ atụrụ.\wj* 
\v 17 \wj Maka nke a ka Nna jiri hụ m nʼanya, nʼihi na ana m atọgbọ ndụ m, ka m wereghachikwa ya ọzọ.\wj* 
\v 18 \wj O nweghị onye ọbụla pụrụ ịnara m ya, kama ana m atọgbọ ya nʼike nke onwe m. Enwere m ikike ịtọgbọ ya, nweekwa ikike iwereghachi ya ọzọ. Anatara m iwu a site nʼaka Nna m.”\wj* 
\p  
\v 19 Ọzọkwa, nkewa batara nʼetiti ndị Juu nʼihi okwu ndị a.  
\v 20 Ọtụtụ nʼime ha na-ekwu, “Ọ bụ onye mmụọ ọjọọ na-achị ya, onye isi mebiri. Ọ bara uru ige ya ntị?” 
\p  
\v 21 Ma ndị ọzọ na-ekwu, “Okwu ndị a adịghị ka nke onye mmụọ ọjọọ bi nʼime ya. Mmụọ ọjọọ o nwere ike ime ka anya onye kpuru ìsì meghee?” 
\s1 Ekweghị ekwe nke ndị juu 
\p  
\v 22 Nʼoge ahụ, mmemme icheta mgbe e doro ụlọnsọ ukwu ahụ nsọ ruru na Jerusalem. Ọ bụ oge oke oyi,\f + \fr 10:22 \ft Nke a bụ mmemme icheta ido nsọ e doro ụlọnsọ ukwu ahụ mgbe e wugharịrị ya nʼihi mmerụ ndị Siria merụrụ ya. E mere ka anyị mata na ọ bụ onye a na-akpọ Antiokus Efifanis merụrụ ụlọnsọ ahụ, mgbe o ji ezi chụọ aja nʼelu ebe ịchụ aja ya, dịka akwụkwọ akụkọ si kọọ ya.\f* 
\v 23 ma Jisọs nọ na-ejegharị nʼụlọnsọ ukwu, nʼịba\f + \fr 10:23 \ft Maọbụ, \fqa mgbe ụlọ\f* Solomọn.  
\v 24 Ndị Juu gbara ya gburugburu sị ya, “Ruo ole mgbe ka ị ga-edebe anyị nʼọnọdụ olileanya? Ọ bụrụ na ị bụ Kraịst ahụ, gwaghee anyị ọnụ.” 
\p  
\v 25 Jisọs zara ha, \wj “Agwara m unu, ma unu ekweghị. Ọrụ m na-arụ nʼaha Nna m na-agba ama banyere m.\wj* 
\v 26 \wj Ma unu ekwenyeghị, nʼihi na unu esoghị nʼigwe atụrụ m.\wj* 
\v 27 \wj Atụrụ m na-anụ olu m. Amaara m ha, ha na-esokwa m.\wj* 
\v 28 \wj Ana m enye ha ndụ ebighị ebi. Ha agaghị ala nʼiyi. Mmadụ ọbụla enwekwaghị ike ịpụnarị ha nʼaka m.\wj* 
\v 29 \wj Nna m onye nyere m ha dị ukwuu karịa ihe niile. O nweghị onye nwere ike ịnapụ ha site nʼaka Nna m.\wj* 
\v 30 \wj Mụ na nna m bụ otu.”\wj* 
\p  
\v 31 Ndị Juu tụtụlitekwara nkume ọzọ ịtụ ya.  
\v 32 Ma Jisọs zara ha, \wj “E zila m unu ọtụtụ ọrụ ọma nke sitere nʼaka Nna m, olee nke unu na-achọ ịtụ m nkume nʼihi ya?”\wj* 
\p  
\v 33 Ndị Juu zara ya, “Anyị achọghị ịtụ gị nkume nʼihi ọrụ ọma ndị a, kama nʼihi nkwulu na nʼihi na gị bụ mmadụ efu, ma ị na-eme onwe gị Chineke.” 
\p  
\v 34 Jisọs zara ha, \wj “Edeghị ya nʼiwu unu, sị, ‘Mụ onwe m sịrị na unu bụ chi’\wj*\f + \fr 10:34 \ft \xt Abụ 82:6\f*\wj ?\wj* 
\v 35 \wj Ọ bụrụ na a kpọrọ ndị ahụ nabatara okwu Chineke ‘chi,’ apụghịkwa imebi ihe e dere nʼakwụkwọ nsọ.\wj* 
\v 36 \wj Unu na-ekwu na onye ahụ Chineke doro nsọ ma zitekwa ya nʼime ụwa na-ekwulu Chineke nʼihi na m sịrị, ‘Abụ m Ọkpara Chineke?’\wj* 
\v 37 \wj Unu ekwenyela na m, ma ọ bụrụ na ọ bụghị ọrụ Nna m ka m na-arụ.\wj* 
\v 38 \wj Ma ọ bụrụ na m na-arụ ya, a sịkwarị na unu ekweghị na m, kwerenụ nʼọrụ ndị a, ka unu nwee ike mata ma ghọtakwa na Nna ahụ nọ nʼime m, mụ onwe m nọkwa nʼime Nna ahụ.”\wj* 
\v 39 Ọzọkwa, ha gbalịrị ijide ya ma ọ siri nʼaka ha pụọ. 
\p  
\v 40 Mgbe ahụ ọ laghachiri azụ nʼofe osimiri Jọdan, bụ ebe Jọn nọrọ na mbụ mee baptizim, ebe ahụ ka ọ nọdụrụ.  
\v 41 Ọtụtụ ndị mmadụ bịakwutere ya. Ha na-asị, “Jọn arụghị ọrụ ihe ịrịbama ọbụla, ma ihe niile Jọn kwuru banyere nwoke a bụ eziokwu.”  
\v 42 Ọtụtụ mmadụ kwenyekwara na ya nʼebe ahụ. 
\c 11  
\s1 Ọnwụ Lazarọs 
\p  
\v 1 Nʼoge ahụ, ahụ adịghị otu nwoke a na-akpọ Lazarọs onye Betani, nke bụ obodo nta nke Meri na Mata nwanne ya nwanyị.  
\v 2 Nke a bụ Meri ahụ weere mmanụ otite dị oke ọnụahịa tee Onyenwe anyị, ma jirikwa agịrị isi ya hichaa ụkwụ ya. Ọ bụ nwanne ya nwoke Lazarọs bụ onye nọ nʼọrịa.  
\v 3 Nke a mere ụmụnne ya nwanyị zigara Jisọs ozi sị, “Onyenwe anyị, onye ahụ nke ị hụrụ nʼanya nọ nʼọrịa.” 
\p  
\v 4 Mgbe Jisọs nụrụ ya, ọ sịrị, \wj “Ọrịa a abụghị nke ọnwụ kama ọ bụ iji nye Chineke otuto nakwa ka e site na ya nye Ọkpara Chineke otuto.”\wj* 
\v 5 Jisọs hụrụ Mata, na nwanne ya nwanyị na Lazarọs nʼanya.  
\v 6 Mgbe ọ nụrụ na Lazarọs nọ nʼọrịa, ọ nọkwuru mkpụrụ ụbọchị abụọ nʼebe ahụ ọ nọ.  
\v 7 Ya mere, ọ gwara ndị na-eso ụzọ ya, \wj “Ngwanụ ka anyị laghachi azụ na Judịa.”\wj* 
\p  
\v 8 Ma ndị na-eso ụzọ ya sịrị ya, “Onye ozizi, nʼoge nta gara aga ka ndị Juu chọrọ ịtụ gị nkume. Ị na-agakwa ebe ahụ ọzọ?” 
\p  
\v 9 Jisọs zara, \wj “Ọ bụghị awa iri na abụọ dị nʼotu ehihie nke ụbọchị? Onye na-ejegharị nʼehihie anaghị asụ ngọngọ, nʼihi na ọ na-eji ìhè nke ụwa a ahụ ụzọ.\wj* 
\v 10 \wj Ma ndị na-ejegharị nʼabalị na-azọhie ụkwụ, nʼihi na ìhè adịghị nʼime ha.”\wj* 
\p  
\v 11 Mgbe o kwusiri nke a, ọ gwakwara ha, \wj “Enyi anyị Lazarọs na-arahụ ụra, ma ana m aga ịkpọte ya nʼụra.”\wj* 
\p  
\v 12 Ndị na-eso ụzọ ya sịrị ya, “Onyenwe anyị, ọ bụrụ na ọ na-arahụ ụra, ọ ga-adị mma.”  
\v 13 Ihe Jisọs na-ekwu bụ banyere ọnwụ ya ma ha chere na ọ na-ekwu banyere ịrahụ ụra efu. 
\p  
\v 14 Mgbe ahụ, Jisọs gwaghere ha ọnụ, \wj “Lazarọs anwụọla.\wj* 
\v 15 \wj Ma nʼihi unu, obi dị m ụtọ na anọghị m nʼebe ahụ, ka unu nwe ike kwere. Ma bịanụ ka anyị gakwuru ya.”\wj* 
\p  
\v 16 Tọmọs, onye a na-akpọ Didimọs, gwara ndị na-eso ụzọ ibe ya, “Ka anyị gakwanụ ka anyị soro ya nwụọ.” 
\s1 Jisọs akasịe ụmụnne nwanyị Lazarọs obi 
\p  
\v 17 Mgbe Jisọs rutere, ọ chọpụtara na Lazarọs anọọlarị nʼili ụbọchị anọ.  
\v 18 Betani dị Jerusalem nso, ihe dị ka kilomita atọ.  
\v 19 Ma ọtụtụ ndị Juu bịakwutere Mata na Meri ịkasị ha obi nʼihi ọnwụ nwanne ha nwoke.  
\v 20 Mgbe ozi ọbịbịa Jisọs ruru Mata ntị, ọ gara izute ya, ma Meri nọdụrụ nʼụlọ. 
\p  
\v 21 Mata sịrị Jisọs, “Onyenwe m, a sị na ị nọ nʼebe a, nwanne m nwoke agaraghị anwụ.  
\v 22 Ma ugbu a, amara m na Chineke ga-enye gị ihe ọbụla ị rịọrọ.” 
\p  
\v 23 Jisọs sịrị ya, \wj “Nwanne gị nwoke ga-ebili ọzọ.”\wj* 
\p  
\v 24 Mata sịrị ya, “Amara m na ọ ga-ebili ọzọ nʼụbọchị mbilite nʼọnwụ nʼoge ikpeazụ.” 
\p  
\v 25 Jisọs gwara ya, \wj “Mụ onwe m bụ mbilite nʼọnwụ na ndụ. Onye ọbụla kwere na m, a sịkwarị na ọ nwụrụ anwụ, ọ ga-adị ndụ ọzọ.\wj* 
\v 26 \wj Ma onye ọbụla dị ndụ nke na-ekwere na m agaghị anwụ. Ị kwere nke a?”\wj* 
\p  
\v 27 Ọ sịrị ya, “E, Onyenwe m, ekwere m na ị bụ Kraịst ahụ, Ọkpara Chineke, onye ga-abịa nʼụwa.” 
\s1 Jisọs bere akwa 
\p  
\v 28 Mgbe o kwuchara nke a, ọ gara kpọọ nwanne ya nwanyị bụ Meri, jiri nwayọọ sị ya, “Onye ozizi abịala, ọ na-akpọ gị.”  
\v 29 Mgbe ọ nụrụ nke a, ọ biliri ọsịịsọ ga zute ya.  
\v 30 Ruo mgbe a, Jisọs abịarutebeghị nʼobodo nta ahụ, ma ọ ka nọ nʼebe ahụ Mata zutere ya.  
\v 31 Ndị Juu nọ nʼụlọ na-akasị Meri obi hụrụ ya ka ọ pụrụ ngwangwa. Ha sochiri ya nʼazụ nʼihi na ha chere na ọ na-aga nʼili ibe akwa nʼebe ahụ. 
\p  
\v 32 Mgbe Meri rutere nʼebe Jisọs nọ, ọ dara nʼụkwụ ya sị, “Onyenwe m, ọ bụrụ na ị nọ nʼebe a, nwanne m nwoke agaraghị anwụ.” 
\p  
\v 33 Mgbe Jisọs hụrụ ya ka ọ na-ebe akwa ya na ndị Juu ahụ so ya ka ha na-ebekwa akwa, o metụrụ ya nʼime mmụọ ya. O nwere ọmịiko dị ukwuu.  
\v 34 Ọ sịrị, \wj “Olee ebe unu liri ya?”\wj* 
\p Ha sịrị ya, “Onyenwe anyị bịa ka ị hụ.” 
\p  
\v 35 Jisọs ebee akwa. 
\p  
\v 36 Mgbe ahụ ndị Juu na-asị, “Lee ka o si hụ ya nʼanya.” 
\p  
\v 37 Ma ụfọdụ nʼime ha sịrị, “Nwoke a meghere anya onye kpuru ìsì, ọ garaghị enwe ike mee ka nwoke a hapụ ịnwụ?” 
\s1 Jisọs akpọlite Lazarọs site nʼọnwụ 
\p  
\v 38 Ọzọkwa, Jisọs sụrụ ude nʼime onwe ya nke ukwuu, bịarute nʼili ahụ nso. Ili ahụ bụ ọgba e jiri nkume dị ukwuu mechie ọnụ ya.  
\v 39 Jisọs sịrị, \wj “Bupunụ nkume ahụ!”\wj* 
\p Ma Mata, nwanne nwanyị onye ahụ nwụrụ anwụ, sịrị ya, “Onyenwe anyị, ọ ga na-esi isi ugbu a, nʼihi na nke a bụ abalị anọ ọ nwụrụ.” 
\p  
\v 40 Ma Jisọs sịrị ya, \wj “Ọ bụ na m agwaghị gị sị na ọ bụrụ na ị kwere ị ga-ahụ ọrụ ebube Chineke?”\wj* 
\p  
\v 41 Ya mere, ha bupụrụ nkume ahụ. Jisọs lere anya nʼelu sị, \wj “Nna, ana m ekele gị nʼihi na ị nụla olu m.\wj* 
\v 42 \wj Amaara m na ị na-anụ olu m mgbe niile. Ana m ekwu nke a nʼihi ndị a gbara m gburugburu nʼebe a, ka ha kwere na ọ bụ gị zitere m.”\wj* 
\p  
\v 43 Mgbe o kwusiri nke a, o jiri oke olu tie mkpu, \wj “Lazarọs, pụta!”\wj* 
\v 44 Onye ahụ nwụrụ anwụ pụtara, e jikwa akwa ozu kekọta aka ya na ụkwụ ya, werekwa akwa ịchafu kechie ihu ya. 
\p Jisọs sịrị ha, \wj “Tọpụnụ ya, hapụ ya ka ọ laa.”\wj* 
\s1 Izu igbu Jisọs 
\p  
\v 45 Ọtụtụ ndị Juu bịakwutere Meri bụ ndị hụrụ ihe a o mere, kwere na ya.  
\v 46 Ma ụfọdụ nʼime ha lara gaa kọọrọ ndị Farisii ihe o mere.  
\v 47 Mgbe ahụ, ndịisi nchụaja na ndị Farisii kpọrọ nzukọ ndị Sanhedrin. 
\p Ha na-asị, “Gịnị ka anyị ga-eme? Nʼihi na nwoke a na-eme ọtụtụ ihe ịrịbama.  
\v 48 Ọ bụrụ na anyị ahapụ ya ka ọ gaa nʼihu, mmadụ niile ga-ekwere na ya. Ndị Rom ga-abịakwa, kwatuo ụlọnsọ ukwu ma napụ anyị obodo anyị.” 
\p  
\v 49 Ma otu onye nʼime ha bụ Kaịfas, onyeisi nchụaja nʼafọ ahụ sịrị ha, “Unu amaghị ihe ọbụla.  
\v 50 Ọ bụ na unu amaghị na ọ ka mma ka otu onye nwụọ nʼihi mmadụ niile, karịa nʼobodo anyị niile ga-ala nʼiyi.” 
\p  
\v 51 Dị ka onyeisi nchụaja nke afọ ahụ, o kwughị nke a site nʼechiche ya, kama o buru amụma na Jisọs ga-anwụ nʼihi mba ndị Juu.  
\v 52 Ọ bụghị nʼihi mba ahụ naanị, kama, ka ọ kpọkọta ụmụ Chineke ndị gbasara nʼebe niile.  
\v 53 Ya mere, site nʼụbọchị ahụ, ha malitere ịgba izu otu ha ga-esi gbuo ya. 
\p  
\v 54 Ya mere, Jisọs kwụsịrị ịgagharị ebe ndị Juu ga-ahụ ya. O siri nʼebe ahụ pụọ gaa nʼakụkụ ọzara nʼotu obodo nta a na-akpọ Ifrem. Ya na ndị na-eso ụzọ ya nọdụrụ nʼebe ahụ. 
\p  
\v 55 Mmemme Ngabiga ndị Juu dịkwa nso. Ọtụtụ ndị mmadụ si nʼakụkụ ala ndị Juu niile bịa Jerusalem. Ha bịara tutu mmemme ahụ ebido ka ha mee onwe ha ka ha dị ọcha.  
\v 56 Ha na-achọ Jisọs na-ajụrịta onwe ha nʼime ụlọnsọ ukwu ahụ, “Gịnị ka unu chere? Ọ bụ na ọ gaghị abịa na mmemme a?”  
\v 57 Ma nʼoge ahụ, ndịisi nchụaja na ndị Farisii enyela iwu ka onye ọbụla hụrụ ya bịa gwa ha ka ha gaa jide ya. 
\c 12  
\s1 Meri etee Jisọs Mmanụ 
\p  
\v 1 Ụbọchị isii tupu e mee Mmemme Ngabiga, Jisọs gara Betani bụ obodo Lazarọs, onye ahụ ọ mere ka o site nʼọnwụ bilie.  
\v 2 Nʼebe ahụ, ha siiri Jisọs nri, ọ bụkwa Mata na-eje ozi isi nri ahụ, Lazarọs bụ otu onye nʼime ndị sooro ya nọdụ na nri ahụ.  
\v 3 Mgbe ahụ, Meri weere mmanụ otite dị ọkara lita nke ezigbo naad, mmanụ isi ụtọ dị oke ọnụahịa, ọ wụkwasara ya Jisọs nʼụkwụ, jirikwa agịrị isi ya hichaa ụkwụ ya. Nke a mere ka ụlọ ahụ jupụta nʼisi ụtọ nke mmanụ otite ahụ. 
\p  
\v 4 Ma Judas Iskarịọt, otu nʼime ndị na-eso ụzọ ya, onye ahụ ga-arara ya nye, kwuru,  
\v 5 “Gịnị mere na-ereghị mmanụ otite a narị denarị atọ,\f + \fr 12:5 \ft Narị denarị atọ ruru ụgwọ ọnwa onye ọrụ ga-anata nʼotu afọ.\f* were ego ya nye ndị ogbenye?”  
\v 6 O kwughị nke a nʼihi na ihe banyere ndị ogbenye na-emetụ ya nʼobi kama nʼihi na ọ bụ onye ohi; dị ka onye na-ejide akpa ego ha, mgbe ụfọdụ, ọ na-amanye aka nʼego ahụ zubiri ego. 
\p  
\v 7 Jisọs sịrị, \wj “Hapụ ya aka, ọ zụtara ya ka ọ na-akwado maka ụbọchị olili m.\wj* 
\v 8 \wj Unu nwere ndị ogbenye nʼetiti unu mgbe niile, ma mụ na unu agaghị anọ mgbe niile.”\wj* 
\p  
\v 9 Ma mgbe igwe ndị Juu nụrụ na ọ nọ nʼebe ahụ, ha bịara, ọ bụghị naanị ka ha hụ ya, kama ka ha hụkwa Lazarọs onye o mere ka o si na ndị nwuru anwụ bilie.  
\v 10 Ya mere, ndịisi nchụaja gbakwara izu igbukwa Lazarọs.  
\v 11 Nʼihi na ọ bụ nʼihi ya ka ọtụtụ ndị Juu ji na-ahapụ ha ma na-ekwerekwa na Jisọs. 
\s1 Jisọs abịa na Jerusalem dị ka Eze 
\p  
\v 12 Nʼechi ya oke igwe mmadụ ahụ ndị bịara mmemme nụrụ na Jisọs na-abịa Jerusalem.  
\v 13 Ha weere igu nkwụ pụọ izute ya na-eti mkpu, 
\q1 “Hozanna!” 
\b  
\q1 “Onye a gọziri agọzi ka onye ahụ bụ nke na-abịa nʼaha Onyenwe anyị!”\f + \fr 12:13 \ft \xt Abụ 118:25,26\f* 
\b  
\q1 “Ngọzị dịrị eze Izrel!” 
\m  
\v 14 Jisọs hụrụ nwa ịnyịnya ibu, nọkwasị nʼelu ya, dị ka e dere ya, 
\q1  
\v 15 “Atụla egwu, gị ada Zayọn! 
\q2 Lee, eze gị ka ọ na-abịa. 
\q2 Ọ nọkwasịrị nʼelu nwa ịnyịnya ibu.”\f + \fr 12:15 \ft \xt Zek 9:9\f* 
\p  
\v 16 Na mbụ ndị na-eso ụzọ ya aghọtaghị ihe ndị a niile. Ma mgbe e nyesịrị Jisọs otuto, ka ha chetara na-edererị ihe ndị a banyere ya, na e mekwara ya rịị ihe ndị a. 
\p  
\v 17 Igwe mmadụ ahụ bụ ndị ya na ha nọ mgbe o si nʼili kpọpụta Lazarọs, mee ka o sị nʼọnwụ bilie, gara nʼihu na-agba ama ya.  
\v 18 Ọtụtụ mmadụ pụrụ izute ya nʼihi na ha nụrụ akụkọ ọrụ ihe ịrịbama niile ọ rụrụ.  
\v 19 Ya mere, ndị Farisii sịrịtara onwe ha, “Unu ahụla na o nweghị ihe unu pụrụ ime, leenụ ka ụwa niile na-eso ya.” 
\s1 Jisọs gbara ama ọnwụ ya 
\p  
\v 20 Ma ụfọdụ ndị Griik so nʼime ndị ahụ bịara ife ofufe nʼoge mmemme ahụ.  
\v 21 Ha bịakwutere Filip onye si Betsaida dị na Galili, gwa ya sị, “Nna anyị ukwu, anyị chọrọ ịhụ Jisọs.”  
\v 22 Filip pụrụ gaa gwa Andru, ya na Andru sooro gaa gwa Jisọs. 
\p  
\v 23 Jisọs zara sị, \wj “Oge awa ahụ eruola mgbe a ga-enye Nwa nke Mmadụ otuto.\wj* 
\v 24 \wj Nʼezie, nʼezie, agwa m unu, ọ bụrụ na mkpụrụ ọka wiiti adaghị nʼala nwụọ, ọ ga-anọ naanị ya. Ma ọ bụrụ na ọ nwụọ, ọ ga-amị ọtụtụ mkpụrụ.\wj* 
\v 25 \wj Ndị ọbụla hụrụ ndụ ha nʼanya ga-atụfu ya, ebe ndị ọbụla kpọrọ ndụ ha asị nʼụwa a, ga-edebe ya ruo mgbe ebighị ebi.\wj* 
\v 26 \wj Onye ọbụla na-ejere m ozi aghaghị iso m; ebe m nọ ka onye na-ejere m ozi ga-anọkwa. Onye ọbụla na-ejere m ozi ka Nna m ga-asọpụrụ.\wj* 
\p  
\v 27 \wj “Ugbu a, mkpụrụobi m jupụtara nʼihe mgbu. Gịnịkwa ka m ga-ekwu, Nna, zọpụta m nʼawa nke a? Mba! Ọ bụ nʼihi nke a ka m ji bịa nʼoge awa a.\wj* 
\v 28 \wj Nna, nye aha gị otuto.”\wj* 
\p Mgbe ahụ, otu olu siri nʼeluigwe bịa, “Enyela m ya otuto, m ga-enyekwa ya otuto ọzọ.”  
\v 29 Igwe ndị mmadụ guzo nʼebe ahụ, ndị nụrụ ya na-ekwu, “Ọ bụ egbe eluigwe gbara.” Ndị ọzọ na-asị, “Ọ bụ mmụọ ozi na-agwa ya okwu.” 
\p  
\v 30 Jisọs zara ma sị, \wj “Olu a abịaghị nʼihi m kama ọ bịara nʼihi unu.\wj* 
\v 31 \wj Ugbu a bụ oge a ga-ekpe ụwa a ikpe. Ugbu a ka a ga-achụpụ onye ahụ na-achị ụwa a.\wj* 
\v 32 \wj Ma mụ onwe m, mgbe e si nʼụwa welie m elu, aga m adọta mmadụ niile nye onwe m.”\wj* 
\v 33 O kwuru nke a iji gosi ụdị ọnwụ nke ọ gaje ịnwụ. 
\p  
\v 34 Igwe mmadụ ahụ zara ya, “Anyị anụla site nʼakwụkwọ iwu na Kraịst ahụ ga-adị ndụ ruo mgbe ebighị ebi. Ma gịnị mere i ji asị na, \wj ‘A ghaghị iweli Nwa nke Mmadụ elu’\wj*? Onye bụ ‘Nwa nke mmadụ a’?” 
\p  
\v 35 Jisọs sịrị ha, \wj “Ìhè ga-enwuru unu naanị nwa oge nta. Jegharịanụ nʼìhè a, ugbu a unu nwere ya, tupu ọchịchịrị abịakwasị unu. Onye na-ejegharị nʼọchịchịrị amaghị ebe ọ na-aga.\wj* 
\v 36 \wj Kwerenụ nʼìhè ahụ ugbu a unu nwere ya ka unu ghọọ ụmụ nke ìhè.”\wj* Mgbe Jisọs kwusiri nke a ọ hapụrụ ha pụọ ga zoo onwe ya. 
\s1 Ndị Juu gara nʼihu na-ekweghị ekwe ha 
\p  
\v 37 Nʼagbanyeghị ọrụ ịrịbama niile ọ rụrụ nʼetiti ha, ha ekwereghị na ya.  
\v 38 Nke a bụ imezu ihe Aịzaya onye amụma kwuru, 
\q1 “Onyenwe anyị, onye kweere ozi anyị 
\q2 ọ bụkwa nʼahụ onye ka e kpugheere ogwe aka Onyenwe anyị?”\f + \fr 12:38 \ft \xt Aịz 53:1\f* 
\p  
\v 39 Ma ha enweghị ike kwere, nʼihi na Aịzaya kwukwara nʼebe ọzọ, sị, 
\q1  
\v 40 “O meela ka ha kpuo ìsì, 
\q2 mekwa ka obi ha kpọchie 
\q1 Ka ha ghara iji anya ha hụ ụzọ 
\q2 maọbụ jiri obi ha ghọta ihe ọbụla 
\q2 Ka ha gharakwa ichigharị, ka m gwọọ ha.”\f + \fr 12:40 \ft \xt Aịz 6:10\f* 
\m  
\v 41 Aịzaya kwuru ihe ndị a nʼihi na ọ hụrụ ebube ya, ma kwuo banyere ya. 
\p  
\v 42 Otu ọ dị, ọtụtụ nʼime ndịisi kweere na ya, ma ha ekwupụtaghị nke a. Nʼihi na ha tụrụ egwu na ndị Farisii ga-achụpụ ha site nʼụlọ ekpere.  
\v 43 Nʼihi na ha hụrụ otuto mmadụ nʼanya karịa otuto Chineke. 
\p  
\v 44 Jisọs tiri mkpu sị, \wj “Onye ọbụla kwere na m, ọ bụghị na m ka o kwere, kama ọ bụ na onye nke zitere m.\wj* 
\v 45 \wj Nʼihi na onye ọbụla hụrụ m ahụla onye nke zitere m.\wj* 
\v 46 \wj Abịara m nʼime ụwa dị ka ìhè ka onye ọbụla nke kwere na m ghara ịnọ nʼọchịchịrị.\wj* 
\p  
\v 47 \wj “Ma ọ bụrụ na onye ọbụla anụ okwu m ma ju ime ya, ọ bụghị m na-ekpe ya ikpe. Nʼihi na abịara m ịzọpụta ụwa, ọ bụghị ikpe ụwa ikpe.\wj* 
\v 48 \wj Onye ọbụla jụrụ m ma jụkwa okwu m, nwere onye ga-ekpe ya ikpe. Okwu niile m kwuru ga-ama ya ikpe nʼụbọchị ikpeazụ.\wj* 
\v 49 \wj Okwu ndị a esiteghị nʼaka m. Ha sitere nʼaka Nna ahụ onye zitere m ma nyekwa m iwu ihe m ga-ekwu na otu m ga esi kwuo ya.\wj* 
\v 50 \wj Ama m na iwu ya bụ ndụ ebighị ebi, nʼihi ya, ihe ọbụla Nna gwara m ka m na-ekwu.”\wj* 
\c 13  
\s1 Jisọs asaa ụkwụ ndị na-eso ụzọ ya 
\p  
\v 1 Tupu oge Mmemme Ngabiga eruo, Jisọs amatala na oge ọ ga-ahapụ ụwa lakwuru Nna ya eruola. Ọ hụrụ ndị nke ya nọ nʼụwa nʼanya, hụkwa ha nʼanya ruo ọgwụgwụ. 
\p  
\v 2 Mgbe a na-eri nri anyasị, ekwensu etinyelarị ya nʼime obi Judas Iskarịọt, nwa Saimọn ka ọ rara ya nye.  
\v 3 Jisọs matara na Nna enyefeela ya ihe niile nʼaka. Ọ maara na ya si nʼebe Chineke nọ bịa, matakwa na ya ga-alaghachikwuru Chineke.  
\v 4 Ya mere, o sitere nʼoche ọ nọkwasịrị bilie ọtọ, yipụ uwe nke elu ya, chiri akwa mmiri e ji ehicha ahụ kee nʼukwu ya.  
\v 5 Ọ wụnyere mmiri nʼime efere ịsa aka, bido ịsa ndị na-eso ụzọ ya ụkwụ, jirikwa akwa mmiri ahụ o kere nʼukwu ya na-ehicha ụkwụ ha. 
\p  
\v 6 Ọ bịakwutere Saimọn Pita, onye sịrị ya, “Onyenwe m, ị ga-asa m ụkwụ?” 
\p  
\v 7 Ma Jisọs zara sị ya, \wj “Ị ghọtaghị ihe m na-eme ugbu a, ma emesịa ị ga-aghọta ya.”\wj* 
\p  
\v 8 Pita sịrị ya, “Ị gaghị asaa m ụkwụ ma ọlị.” 
\p Jisọs zara ya, \wj “Ọ bụrụ na m asachaghị gị ụkwụ, mụ na gị enweghị oke ọbụla.”\wj* 
\p  
\v 9 Saimọn Pita sịrị ya, “Onyenwe m, ọ bụghị naanị ụkwụ m ka ị ga-asa, kama saakwa aka m na isi m.” 
\p  
\v 10 Jisọs sịrị ya, \wj “Onye ọbụla sara ahụ agaghị asakwa ya ọzọ, ọ bụ naanị ịsa ụkwụ ya dịrị ya nʼihi na ahụ ya niile dị ọcha. Unu dị ọcha, kama ọ bụghị unu niile.”\wj* 
\v 11 Nʼihi na ọ maararị onye ahụ ga-arara ya nye. Ya mere o ji sị, “Ọ bụghị unu niile dị ọcha.” 
\p  
\v 12 Mgbe ọ sachasịrị ha ụkwụ, o yiiri uwe ya, nọdụkwa ala ọzọ, ọ sịrị ha, \wj “Unu ghọtara ihe m meere unu?\wj* 
\v 13 \wj Unu na-akpọ m Onyenwe unu na Nna unu ukwu, unu mere nke ọma nʼihi na nke a ka m bụ.\wj* 
\v 14 \wj Ebe ọ bụ na mụ onwe m, bụ Nna unu ukwu na Onyenwe unu sachara unu ụkwụ, unu kwesikwara ịsachakwa ụkwụ ibe unu.\wj* 
\v 15 \wj Nke a bụ ihe nṅomi m nyere unu, meenụ dị ka mụ onwe m mere unu.\wj* 
\v 16 \wj Nʼezie, nʼezie, ohu adịghị adị ukwuu karịa nna ya ukwu, maọbụ onye e ziri ozi a karịa onye ziri ya ozi.\wj* 
\v 17 \wj Ọ bụrụ na unu a mara ihe ndị a, ngọzị ga-adịrị unu ma unu mee ha.\wj* 
\s1 Jisọs agbaa ama maka mgba okpuru ya 
\p  
\v 18 \wj “Anaghị m ekwu maka unu niile, amaara m ndị m họpụtara. Ma nke a bụ imezu ihe e dere nʼakwụkwọ nsọ, ‘Onye mụ na ya na-erikọ nri ebiliela megide m.’\wj*\f + \fr 13:18 \ft \xt Abụ 41:9\f* 
\p  
\v 19 \wj “Ana m agwa unu ugbu a tupu ihe ndị a emee, ka unu kwere na mụ bụ ya mgbe ọ ga-emezu.\wj* 
\v 20 \wj Nʼezie, nʼezie, agwa m unu, onye ọbụla nabatara onye m zitere nabatara m. Onye ọbụla nabatara m nabatakwara onye zitere m.”\wj* 
\p  
\v 21 Mgbe Jisọs kwusiri ihe ndị a, o nweghị udo nʼime mmụọ ya. Ọ gbara ama sị, \wj “Nʼezie, nʼezie, a sị m unu, na otu onye nʼime unu ga-arara m nye.”\wj* 
\p  
\v 22 Ndị na-eso ụzọ ya lerịtara onwe ha anya na-eche nʼime obi ha onye ọ na-ekwu maka ya.  
\v 23 Otu nʼime ndị na-eso ụzọ ya nke Jisọs hụrụ nʼanya dabere ya nso.  
\v 24 Saimọn Pita fufeere ya isi, ka ọ, Jụọ ya onye ọ na-ekwu maka ya. 
\p  
\v 25 Ebe ọ dabere Jisọs nso, ọ sịrị ya, “Onyenwe anyị, onye ka ọ bụ?” 
\p  
\v 26 Jisọs zara, \wj “Ọ bụ onye ahụ m ga-enye iberibe achịcha a mgbe m sunyere ya nʼime efere nri.”\wj* Mgbe o sunyesịrị achịcha ahụ nʼime efere ahụ, o nyere ya Judas nwa Saimọn Iskarịọt.  
\v 27 Mgbe ọ narasịrị iberibe achịcha ahụ, ekwensu bara nʼime ya. 
\p Jisọs sịrị ya, \wj “Ihe ọbụla ị chọrọ ime, mee ya ngwangwa.”\wj* 
\v 28 Ma ọ dịghị onye ọbụla so nọrọ nʼoche nri ghọtara ihe mere o ji gwa ya otu a.  
\v 29 Nʼihi na ụfọdụ na-eche, ebe Judas ji akpa ego ha, Jisọs na-asị ya ka ọ gaa zụta ihe ndị dị mkpa maka mmemme, maọbụ ka ọ gaa nye ndị ogbenye ihe.  
\v 30 Mgbe ọ natachara iberibe achịcha ahụ, ọ pụrụ na-atụfughị oge, ọchịchịrị agbaala. 
\s1 Jisọs agbaa ama na Pita ga-agọnarị ya 
\p  
\v 31 Mgbe ọ pụrụ, Jisọs sịrị, \wj “Ugbu a ka a na-enye Nwa nke Mmadụ otuto, a na-enyekwa Chineke otuto nʼime ya.\wj* 
\v 32 \wj Ọ bụrụ na e nye Chineke otuto nʼime ya, Chineke ga-enyekwa Ọkpara ya otuto nʼime onwe ya, ọ ga-enyekwa ya otuto ahụ ngwangwa.\wj* 
\p  
\v 33 \wj “Ụmụntakịrị m, enwere m oge ntakịrị nke mụ na unu ga-anọ. Unu ga-achọ m, ma dị ka m gwara ndị Juu ka m na-agwa unu ugbu a. Ebe m na-aga unu enweghị ike ịbịa ya.\wj* 
\p  
\v 34 \wj “Ana m enye unu iwu ọhụrụ: Hụrịtanụ onwe unu nʼanya. Dị ka m hụrụ unu nʼanya, otu a ka unu ga-esi hụrịta onwe unu nʼanya.\wj* 
\v 35 \wj Ọ bụrụ na unu ahụrịta onwe unu nʼanya, otu a ka mmadụ niile ga-esi mata na unu bụ ndị na-eso ụzọ m.”\wj* 
\p  
\v 36 Saimọn Pita sịrị ya, “Onyenwe anyị ebee ka ị na-aga?” 
\p Jisọs zaghachiri ya, \wj “Ebe m na-aga, i nweghị ike iso m gaa ya ugbu a. Ma ị ga-abịa ma emesịa.”\wj* 
\p  
\v 37 Pita sịrị ya, “Onyenwe anyị, gịnị mere na m apụghị isoro gị ugbu a? Aga m atọgbọ ndụ m nʼihi gị.” 
\p  
\v 38 Jisọs zaghachiri, \wj “I jikeere ịtọgbọ ndụ gị nʼihi m? Nʼezie, nʼezie, asị m gị, tupu oke ọkụkụ akwaa akwa, ị ga-agọnarị m ugboro atọ.”\wj* 
\c 14  
\s1 Jisọs akasịe ha obi 
\p  
\v 1 \wj “Ka obi ghara ịlọ unu mmiri. Kwerenụ na Chineke; kwerekwanụ na m.\wj* 
\v 2 \wj Nʼụlọ Nna m, e nwere ọtụtụ ebe obibi. Ọ bụrụ na o sighị otu a dịrị, agaara m agwa unu na m na-aga kwadoro unu ebe obibi?\wj* 
\v 3 \wj Ọ bụrụ na m agaa dozichara unu ebe obibi, aga m alọghachi bịa kpọrọ unu, ka ebe m nọ bụrụkwa ebe unu ga-anọ.\wj* 
\v 4 \wj Unu maara ụzọ ebe m na-aga.”\wj* 
\s1 Jisọs bụ ụzọ 
\p  
\v 5 Tọmọs sịrị ya, “Onyenwe anyị, anyị amaghị ebe ị na-aga, olee otu anyị ga-esi mata ụzọ ya?” 
\p  
\v 6 Jisọs sịrị ya, \wj “Mụ onwe m bụ ụzọ, na eziokwu, na ndụ. O nweghị onye na-abịakwute Nna m ma ọ bụghị site na m.\wj* 
\v 7 \wj Ọ bụrụ na unu maara onye m bụ, unu gaara amatakwa Nna m. Site ugbu a, unu amatala ya. Ma hụkwa ya.”\wj* 
\p  
\v 8 Filip sịrị ya, “Onyenwe anyị, zi anyị Nna ahụ, afọ ga-ejukwa anyị.” 
\p  
\v 9 Jisọs sịrị ya, \wj “Ọtụtụ oge ndị a mụ na unu nọrọ ọ bụ na ị matabeghị onye m bụ, Filip? Onye ọbụla hụrụ m ahụla Nna. Olee otu i si asị, ‘zi anyị Nna ahụ?’\wj* 
\v 10 \wj Ọ bụ na i kweghị na m nọ nʼime Nna, na Nna nọkwa nʼime m? Okwu niile m na-agwa unu esitekwaghị nʼebe m nọ pụta, kama ọ bụ Nna bi nʼime m na-arụ ọrụ ya.\wj* 
\v 11 \wj Kwere ihe m kwuru na anọ m nʼime Nna, na Nna nọkwa nʼime m. Ma ọ bụghị otu a, kwerenụ nʼihi ọrụ ebube ndị a.\wj* 
\v 12 \wj Nʼezie, nʼezie, agwa m unu, onye ọbụla kwere na m ga-arụ ọrụ ndị m rụrụ, rụọkwa ọrụ karịrị ndị a, nʼihi na m na-alakwuru Nna m.\wj* 
\v 13 \wj Ihe ọbụla unu ga-arịọ site nʼaha m, aga m enye unu ya, ka e nwe ike nye Nna ahụ otuto site nʼỌkpara ya.\wj* 
\v 14 \wj Ihe ọbụla unu rịọrọ nʼaha m, aga m eme ya.\wj* 
\s1 Nkwa izite Mmụọ Nsọ 
\p  
\v 15 \wj “Ọ bụrụ na unu hụrụ m nʼanya unu ga-edebe iwu m niile.\wj* 
\v 16 \wj Aga m arịọ Nna m, ọ ga-enye unu Onye Nkasiobi ọzọ,\wj*\f + \fr 14:16 \ft Maọbụ, \fqa Onye Inyeaka\f*\wj onye ga-enyere unu aka ma nọnyekwara unu ruo mgbe niile ebighị ebi.\wj* 
\v 17 \wj Onye bụ Mmụọ nke eziokwu. Ndị bi nʼụwa agaghị anabata ya, nʼihi na ha adịghị ahụ ya anya, ha amakwaghị ya. Ma unu maara ya nʼihi na unu na ya nọ, o bikwa nʼime unu.\wj* 
\v 18 \wj Agaghị m ahapụ unu dị ka ndị na-enweghị nne na nna. Aga m abịakwute unu.\wj* 
\v 19 \wj Mgbe na-adịghị anya, ụwa agaghị ahụkwa m anya. Ma unu ga-ahụ m anya. Nʼihi na m dị ndụ, unu ga-adịkwa ndụ.\wj* 
\v 20 \wj Nʼụbọchị ahụ, unu ga-amata na m nọ nʼime Nna m na unu nọ nʼime m, na mụ onwe m nọkwa nʼime unu.\wj* 
\v 21 \wj Onye ọbụla nabatara iwu m ma na-edebekwa ha bụ onye hụrụ m nʼanya. Onye hụrụ m nʼanya ka Nna m ga-ahụ nʼanya. Aga m ahụkwa ya nʼanya gosikwa ya onwe m.”\wj* 
\p  
\v 22 Judas (ọ bụghị Iskarịọt) sịrị ya, “Onyenwe anyị, olee otu ị ga-esi gosi anyị onwe gị ma hapụ igosi ụwa onwe gị?” 
\p  
\v 23 Jisọs zara sị ya, \wj “Onye ọbụla hụrụ m nʼanya, ga-edebe okwu m. Nna m ga-ahụkwa ya nʼanya. Mụ na Nna m ga-abịakwa nʼebe onye ahụ nọ soro ya biri.\wj* 
\v 24 \wj Onye na-ahụghị m nʼanya agaghị edebe okwu m. Okwu ndị a niile unu nụrụ abụghị nke m. Ha bụ nke Nna ahụ, onye zitere m.\wj* 
\p  
\v 25 \wj “Agwala m unu ihe ndị a niile ugbu a mụ na unu nọ.\wj* 
\v 26 \wj Ma Onye Nkasiobi ahụ bụ Mmụọ Nsọ, onye Nna m ga-ezite nʼaha m, ga-akụziri unu ihe niile, ọ ga-echetakwara unu ihe niile m gwara unu.\wj* 
\v 27 \wj Udo ka m na-ahapụrụ unu. Udo m ka m na-enyekwa unu. Ọ bụghị dị ka ụwa si enye ka m na-enye unu. Unu ekwela ka obi lọọ unu mmiri, ka ụjọ hapụkwa ịtụ unu.\wj* 
\p  
\v 28 \wj “Unu anụla na m gwara unu, ‘Ana m ala, ma lọghachikwutekwa unu.’ Ọ bụrụ na unu hụrụ m nʼanya, unu gaara aṅụrị ọṅụ na m na-alakwuru Nna, nʼihi na Nna dị ukwuu karịa m.\wj* 
\v 29 \wj Ugbu a, agwala m unu ihe a tupu o mezuo, ka ọ ga-abụ mgbe o mezuru, unu enwee ike kwere.\wj* 
\v 30 \wj Agaghị m agwa unu ọtụtụ okwu ọzọ nʼihi na eze na-achị ụwa a na-abịa. O nwekwaghị ike ọbụla nʼebe m nọ.\wj* 
\v 31 \wj Ana m eme dịka Nna m nyere m nʼiwu, ka ụwa mara na m hụrụ Nna m nʼanya.\wj* 
\p \wj “Bilienụ ugbu a ka anyị si ebe a pụọ.\wj* 
\c 15  
\s1 Ezi osisi vaịnị na alaka ya 
\p  
\v 1 \wj “Mụ onwe m bụ ezigbo osisi vaịnị ahụ. Nna m bụkwa onye ọrụ ubi.\wj* 
\v 2 \wj Ọ na-egbuda alaka ọbụla dị nʼime m nke na-adịghị amị mkpụrụ. Ma alaka ọbụla na-amị mkpụrụ ka ọ na-egbucha, ka o nwee ike mịa mkpụrụ dị ọtụtụ.\wj* 
\v 3 \wj Ugbu a, e meela ka unu dịrị ọcha nʼihi okwu m gwara unu.\wj* 
\v 4 \wj Nọgidenụ nʼime m, ka mụ onwe m nọgidekwa nʼime unu. Dịka alaka ọbụla apụghị ịmị mkpụrụ nʼonwe ya ma ọ bụrụ na ọ nọgideghị nʼosisi vaịnị. Otu a, unu apụghịkwa ịmị mkpụrụ ma ọ bụrụ na unu anọgideghị nʼime m.\wj* 
\p  
\v 5 \wj “Mụ onwe m bụ osisi vaịnị ahụ; unu bụkwa alaka ya. Onye ọbụla na-anọgide nʼime m, nke mụ onwe m na-anọgidekwa nʼime ya, na-amị ọtụtụ mkpụrụ. Nʼihi na ewezuga m, unu enweghị ike ime ihe ọbụla.\wj* 
\v 6 \wj Onye ọbụla na-adịghị anọgide nʼime m dị ka alaka e gbuturu, tụpụ ya, ọ kpọnwụọ. A ga-achịkọta ya, chịnye ya nʼọkụ, o repịa.\wj* 
\v 7 \wj Ọ bụrụ na unu anọgide nʼime m, okwu m anọgidekwa nʼime unu, rịọọnụ ihe ọbụla unu chọrọ, a ga-emere unu ya.\wj* 
\v 8 \wj Nke a ga-abụrụ Nna m otuto na unu mịrị ọtụtụ mkpụrụ hie nne, ọ na-egosikwa na unu bụ ndị na-eso ụzọ m.\wj* 
\p  
\v 9 \wj “Dị ka Nna sị hụ m nʼanya, otu a ka m sị hụkwa unu nʼanya. Ya mere, nọgidenụ nʼime ịhụnanya m.\wj* 
\v 10 \wj Unu ga-anọgide nʼịhụnanya m ma ọ bụrụ na unu edebe iwu m. Dị ka m debere iwu Nna m ma nọgidekwa nʼịhụnanya ya.\wj* 
\v 11 \wj Agwala m unu ihe ndị a ka ọṅụ m dịrị nʼime unu ka ọṅụ unu zukwaa oke.\wj* 
\v 12 \wj Nke a bụkwa iwu m, ka unu hụrịta onwe unu nʼanya dị ka m siri hụ unu nʼanya.\wj* 
\v 13 \wj Ọ dịghị onye ọbụla nwere ịhụnanya karịrị nke a na mmadụ tọgbọrọ ndụ ya nʼihi ndị enyi ya.\wj* 
\v 14 \wj Unu onwe unu bụkwa ndị enyi m ma ọ bụrụ na unu edebe ihe m nyere nʼiwu.\wj* 
\v 15 \wj Anaghị m akpọkwa unu ndị ohu ọzọ. Nʼihi na ohu adịghị amatazu ihe niile onyenwe ya na-eme. Ma ana m akpọ unu ndị enyi m nʼihi na agwala m unu ihe niile m nụrụ nʼọnụ Nna m.\wj* 
\v 16 \wj Ọ bụkwaghị unu onwe unu họọrọ m. Ọ bụ m họọrọ unu, wepụtakwa unu iche ka unu gaa mịa ọtụtụ mkpụrụ, mkpụrụ nke ga-adịgidekwa. Ya mere, Nna m ga-enye unu ihe ọbụla unu ga-arịọ nʼaha m.\wj* 
\v 17 \wj Ihe ndị a ka m na-enye unu nʼiwu, hụrịtanụ onwe unu nʼanya.\wj* 
\s1 Ụwa kpọrọ ha asị 
\p  
\v 18 \wj “Ọ bụrụ na ụwa akpọọ unu asị, chetanụ na o buru ụzọ kpọọ m asị.\wj* 
\v 19 \wj A sị na unu bụ nke ụwa, ụwa ga-ahụ unu nʼanya dịka ndị nke ya. Ma otu ọ dị unu abụghị nke ụwa. Kama, esi m nʼime ụwa họrọ unu. Ọ bụkwa nʼihi ya ka ụwa ji akpọ unu asị.\wj* 
\v 20 \wj Chetakwanụ ihe m gwara unu, ‘Ohu adịghị adị ukwuu karịa Onyenwe ya.’\wj*\f + \fr 15:20 \ft \xt Jọn 13:16\f*\wj Ya mere, ebe ha kpagburu m, ha ga-akpagbukwa unu. Ọ bụrụ na ha debere okwu m, ha ga-edebekwa nke unu.\wj* 
\v 21 \wj Ee, ha ga-eme unu ihe niile ndị a nʼihi aha m, na nʼihi na ha amaghị onye ahụ zitere m.\wj* 
\v 22 \wj Ọ bụrụ na abịaghị m, gwa ha okwu, ikpe mmehie agaraghị ama ha. Ma ugbu a, ha enweghị ngọpụ ọbụla banyere mmehie ha.\wj* 
\v 23 \wj Onye ọbụla kpọrọ m asị kpọkwara Nna m asị.\wj* 
\v 24 \wj A sị na ọrụ niile m rụrụ nʼetiti ha akarịghị ọrụ nke onye ọbụla ọzọ rụrụ, ha agaraghị abụ ndị ikpe mmehie mara. Ma ugbu a ha ahụzuola ọrụ ebube ndị a niile, ma ha nọgidekwara na-akpọ mụ na Nna m asị.\wj* 
\v 25 \wj Nke a bụ imezu ihe e dere nʼakwụkwọ iwu ha. ‘Ha kpọrọ m asị na-enweghị ihe m mere.’\wj*\f + \fr 15:25 \ft \xt Abụ 35:19; 69:4\f* 
\s1 Ọrụ Mmụọ nsọ na-arụ 
\p  
\v 26 \wj “Mgbe Onye Ndụmọdụ\wj*\f + \fr 15:26 \ft Onye inyeaka maọbụ onye nkasiobi.\f*\wj ahụ ga-abịa, onye m ga-ezitere unu site nʼaka Nna, bụ Mmụọ eziokwu ahụ sitere na Nna pụta, ọ ga-agba ama banyere m.\wj* 
\v 27 \wj Ma unu onwe unu aghaghị ịgba ama, nʼihi na mụ na unu anọọla site na mmalite.\wj* 
\c 16  
\p  
\v 1 \wj “Ihe ndị a niile ka m gwara unu ka unu ghara ịda.\wj* 
\v 2 \wj Ha ga-esite nʼụlọ ekpere ha chụpụ unu. Nʼezie, oge na-abịa mgbe onye ọbụla ga-egbu unu ga-echekwa na ọ na-efe Chineke mgbe ha na-eme nke a.\wj* 
\v 3 \wj Ha ga-eme ihe ndị a nʼihi na ha amaghị Nna maọbụ m.\wj* 
\v 4 \wj Ana m agwa unu ihe ndị a ka ọ ga-abụ na mgbe oge ga-eru, unu echeta na m gwara unu. Agwaghị m unu ihe ndị a na mbụ nʼihi na mụ na unu nọ mgbe ahụ.\wj* 
\v 5 \wj Ma ugbu a, ana m alaghachikwuru onye ahụ zitere m. Ma ọ dịghị onye ọbụla nʼetiti unu jụrụ m, ‘Olee ebe ị na-aga?’\wj* 
\v 6 \wj Ma nʼihi na m gwara unu ihe ndị a, obi unu ejupụtala na mwute.\wj* 
\v 7 \wj Nʼagbanyeghị nke a, aga m agwa unu eziokwu, ọ bụ maka ọdịmma unu ka m ji ala. Ọ bụrụ na m alaghị, Onye Ndụmọdụ ahụ agaghị abịa. Ọ bụrụ na m laa, aga m ezitere unu ya.\wj* 
\v 8 \wj Mgbe ọ bịara, ọ ga-eme ka ụwa mata ezughị oke nke nghọta ya banyere mmehie, na ezi omume na ikpe,\wj* 
\v 9 \wj maka mmehie nʼihi na ha ekwenyeghị na m;\wj* 
\v 10 \wj ma gbasara ezi omume, nʼihi na ana m alakwuru Nna, ebe unu na-apụghị ịhụ m ọzọ,\wj* 
\v 11 \wj maka ikpe, nʼihi na e kpeela onyeisi ụwa a ikpe.\wj* 
\p  
\v 12 \wj “Enwere m ọtụtụ ihe ọzọ m ga-agwa unu. Ma ugbu a, unu agaghị anabatalị ha.\wj* 
\v 13 \wj Ma mgbe Mmụọ eziokwu ahụ bịara, ọ ga-eduba unu nʼeziokwu niile. Ọ gaghị ekwu ihe banyere onwe ya, kama ọ bụ ihe niile ọ nụrụ ka ọ ga-ekwu. Ọ ga-ezikwa unu ihe niile gaje ịbịa.\wj* 
\v 14 \wj Ọ ga-enye m otuto, nʼihi na ọ ga-esite nʼaka m nata ihe ọ ga-akọrọ unu.\wj* 
\v 15 \wj Ihe niile Nna nwere bụ nke m. Ọ bụ ya mere m ji sị, na ọ ga-ewere site nʼihe bụ nkem, kọwara ya unu.\wj* 
\s1 Mwute nke ndị na-eso ụzọ ya ga-aghọ ọnụ 
\p  
\v 16 \wj “Ọ fọdụrụ nwantakịrị oge unu agaghị ahụkwa m. Ma mgbe nwantịntị oge gasịkwara, unu ga-ahụkwa m anya ọzọ.”\wj* 
\p  
\v 17 Ụfọdụ ndị na-eso ụzọ ya sịrịtara onwe ha, “Gịnị ka o bu nʼuche mgbe ọ na-asị, \wj ‘Nwa oge nta unu agaghị ahụkwa m ọzọ, ma mgbe nwa oge gasịkwara unu ga-ahụkwa m,’\wj* na \wj ‘Nʼihi na ana m alakwuru Nna’\wj*?”  
\v 18 Ha na-asị, “Gịnị ka okwu a pụtara bụ \wj ‘nwa oge nta’\wj*? Anyị aghọtaghị ihe ọ na-ekwu.” 
\p  
\v 19 Jisọs matara na ha chọrọ ịjụ ya ihe banyere nke a, nʼihi ya ọ sịrị ha, \wj “Unu na-ajụrịta onwe unu ihe okwu m pụtara mgbe m sịrị, ‘Na nwa oge nta unu agaghị ahụkwa m ọzọ, ma nwa mgbe nta unu ga-ahụkwa m’?\wj* 
\v 20 \wj Nʼezie, nʼezie, agwa m unu, unu ga-akwa akwa ma nwekwa obi mwute, ma ụwa ga-aṅụrị ọṅụ. Ma iru ụjụ unu ga-aghọrọ unu ọṅụ.\wj* 
\v 21 \wj Mgbe ime na-eme nwanyị, ọ na-anọ nʼọnọdụ ihe mgbu. Mgbe ọ mụsịrị nwa ya, ọ dịghị echetakwa ihe mgbu ya ọzọ. Nʼihi ọṅụ na a mụpụtala nwa nʼelu ụwa.\wj* 
\v 22 \wj Unu nọ nʼọnọdụ iru ụjụ ugbu a, ma aga m ahụ unu anya ọzọ, obi unu ga-ejupụta nʼọṅụ. Mmadụ ọbụla apụghịkwa ịnapụ unu ọṅụ unu.\wj* 
\v 23 \wj Ma nʼụbọchị ahụ, unu agakwaghị arịọ m ihe ọbụla. Nʼezie, nʼezie, agwa m unu, ihe ọbụla unu ga-arịọ Nna m nʼaha m, ọ ga-enye unu.\wj* 
\v 24 \wj Ruo ugbu a, ọ dịbeghị ihe unu rịọrọ nʼaha m. Rịọọnụ, unu ga-arịọta, ka ọṅụ unu zukwaa oke.\wj* 
\p  
\v 25 \wj “Eji m ilu na-agwa unu okwu ugbu a, ma oge na-abịa mgbe m na-agaghị ejikwa ilu gwa unu okwu. Mgbe ahụ ka m ga-akọwara unu niile ihe banyere Nna m nʼụzọ unu ga-aghọta ya.\wj* 
\v 26 \wj Nʼụbọchị ahụ, unu ga-arịọ ihe nʼaha m. Asịghị m unu na m ga-arịọ Nna ihe nʼihi unu.\wj* 
\v 27 \wj Nʼihi na Nna m nʼonwe ya hụrụ unu nʼanya, nʼihi na unu hụrụ m nʼanya kwerekwa na m si nʼebe Chineke nọ bịa.\wj* 
\v 28 \wj Esi m nʼebe Nna nọ pụta, bịa nʼime ụwa. Ana m ahapụkwa ụwa ịlaghachikwuru Nna.”\wj* 
\p  
\v 29 Ndị na-eso ụzọ ya sịrị, “Lee, ugbu a ka okwu gị doro anya. Ọ bụkwaghị ilu ka i na-atụ.  
\v 30 Ugbu a ka o doro anyị anya na ị maara ihe niile. Ọ bakwaghị uru ka onye ọbụla jụọ gị ihe ọbụla. Nʼihi nke a, anyị kwere na i si nʼebe Chineke nọ bịa.” 
\p  
\v 31 Jisọs zara ha, \wj “Unu ekwerela ugbu a?\wj* 
\v 32 \wj Lee! Oge na-abịa, oge ahụ eruola, mgbe unu ga-agbasacha. Onye ọbụla nʼụlọ nke ya. Mgbe ahụ, unu ga-ahapụ naanị m, ma ọ bụghị naanị m nọ nʼihi na mụ na Nna m nọ.\wj* 
\p  
\v 33 \wj “Agwala m unu ihe ndị a niile ka unu nwee udo nʼime m. Nʼime ụwa, unu ga-enwe nsogbu. Ma ka obi sie unu ike, nʼihi na emeriela m ụwa.”\wj* 
\c 17  
\s1 Ekpere Jisọs kpeere Onyenwe ya 
\p  
\v 1 Mgbe Jisọs kwusiri okwu ndị a, o leliri anya nʼeluigwe sị, 
\pm \wj “Nna, oge ahụ a kara aka eruola, nye Ọkpara gị otuto, ka Ọkpara gị nyekwa gị otuto.\wj* 
\v 2 \wj I nyela ya ikike nʼebe mmadụ niile nọ, na ike inye ndị niile i nyere ya ndụ ebighị ebi.\wj* 
\v 3 \wj Nke a bụkwa ndụ ebighị ebi ahụ. Ka ha mata na naanị gị bụ Chineke nʼezie, matakwa Jisọs Kraịst onye ahụ i zitere nʼụwa.\wj* 
\v 4 \wj Enyere m gị otuto nʼụwa site nʼịrụzu ọrụ niile ị nyere m ka m rụọ.\wj* 
\v 5 \wj Ma ugbu a, Nna, nye m otuto nʼihu gị, ụdị otuto ahụ m nwere nʼihu gị tupu e kee ụwa.\wj* 
\s1 Ekpere Jisọs kpeere ndị na-eso ụzọ ya 
\pm  
\v 6 \wj “Emere m ka ndị ahụ i siri nʼụwa kponye m mara aha gị. Ha bụ ndị nke gị, i nyere m ha, ha debekwara okwu gị.\wj* 
\v 7 \wj Ugbu a, ha amarala na ihe niile i nyere m si nʼaka gị bịa.\wj* 
\v 8 \wj Ma ugbu a, enyela m ha okwu ahụ i nyere m, ha nabatakwara ya, marakwa nʼeziokwu na-esi m nʼebe ị nọ bịa. Ha kwenyekwara na ọ bụ gị zitere m.\wj* 
\v 9 \wj Ana m ekpere ha ekpere, ọ bụghị nʼihi ụwa ka m na-ekpe ekpere. Kama ana m ekpe ekpere banyere ndị ahụ i nyere m, nʼihi na ha bụkwa ndị nke gị.\wj* 
\v 10 \wj Ihe niile m nwere bụ nke gị, ihe niile i nwere bụkwa nke m. E sitere na ha mee ka otuto m pụta ìhè.\wj* 
\v 11 \wj Ugbu a, anọghịkwa nʼime ụwa, ma ha ka nọ nʼime ụwa, ana m alaghachikwute gị. Ya mere, Nna dị nsọ, chebe ha nke ọma site nʼike nke aha gị, bụ aha nke ahụ i nyere m, ka ha bụrụ otu dịka anyị onwe anyị si bụrụ otu.\wj* 
\v 12 \wj Mgbe mụ na ha nọ nʼụwa, echebere m ha site nʼaha gị nke i nyere m. Echebekwara m ha, o nwekwaghị onye ọbụla nʼime ha lara nʼiyi, karịakwa onye ahụ bụ nwa nke ịla nʼiyi, ka e mezuo ihe akwụkwọ nsọ kwuru.\wj* 
\pm  
\v 13 \wj “Ma ugbu a, ana m alọghachikwute gị, ma ana m ekwu ihe ndị a nʼụwa ugbu a ka ha nwee nʼọṅụ m, nʼebe o zuruoke nʼime ha.\wj* 
\v 14 \wj Enyela m ha okwu gị. Ma nʼihi ya, ụwa akpọọla ha asị. Nʼihi na ha abụghị ndị nke ụwa dị ka mụ onwe m na-abụghị onye nke ụwa.\wj* 
\v 15 \wj Ekpeghị m ekpere ka iwepụ ha nʼụwa, kama ka ịnapụta ha site nʼaka ajọ onye ahụ.\wj* 
\v 16 \wj Ha onwe ha abụghị ndị nke ụwa dị ka mụ onwe m na-abụkwaghị onye nke ụwa.\wj* 
\v 17 \wj Were eziokwu doo ha nsọ, okwu gị bụ eziokwu.\wj* 
\v 18 \wj Dị ka i siri zite m nʼụwa, otu a ka m na-ezipụkwa ha nʼụwa.\wj* 
\v 19 \wj Ọ bụkwa nʼihi ha ka m jiri debe onwe m nsọ, ka ha onwe ha bụrụkwa ndị e doro nsọ nʼeziokwu.\wj* 
\s1 Ekpere Jisọs maka ndị niile kwere ekwe 
\pm  
\v 20 \wj “Ekpeghị m ekpere a nʼihi ndị a naanị. Kama ana m ekpekwa ekpere a nʼihi ndị niile ga-ekwere na mụ, site nʼokwu ha.\wj* 
\v 21 \wj Ka ha niile bụrụ otu, Nna, dị ka ị nọ nʼime m mụ a nọrọ nʼime gị. Ka ha nọrọkwa nʼime anyị ka ụwa kwere na ọ bụ gị zitere m.\wj* 
\v 22 \wj Enyere m ha otuto nke i nyere m, ka ha bụrụ otu dị ka anyị onwe anyị si bụrụ otu;\wj* 
\v 23 \wj Mụ onwe m nʼime ha, gị onwe gị nʼime m. Ka e mee ka ha bụrụ otu nʼụzọ zuruoke, ka ụwa matakwa na ọ bụ gị zitere m, na ị hụkwara ha nʼanya dị ka ị si hụ m nʼanya.\wj* 
\pm  
\v 24 \wj “Nna, achọrọ m ka ndị niile i nyere m soro m nọrọ ebe m nọ. Ka ha hụ otuto m nke i nyere m nʼihi na ị hụrụ m nʼanya tupu atọọ ntọala nke ụwa.\wj* 
\pm  
\v 25 \wj “Nna onye ezi omume, ụwa amaghị gị. Ma amaara m gị. Ndị a matakwara na ọ bụ gị zitere m.\wj* 
\v 26 \wj Emekwara m ka ha mara aha gị. Aga m agakwa nʼihu ime ka ha mara ya. Ka ịhụnanya ahụ i nwere nʼebe m nọ dịgide nʼime ha, ka mụ onwe m nọgidekwa nʼime ha.”\wj* 
\c 18  
\s1 Ha jidere Jisọs 
\p  
\v 1 Mgbe Jisọs kwusiri okwu ndị a, ya na ndị na-eso ụzọ ya rịdara ndagwurugwu iyi Kidrọn rigorokwa nʼofe nke ọzọ, ebe e nwere otu ogige, ya na ndị na-eso ụzọ ya banyere nʼime ya. 
\p  
\v 2 Judas, onye rara ya nye matakwara ebe ahụ. Nʼihi na Jisọs na ndị na-eso ụzọ ya na-anọ nʼebe ahụ ọtụtụ oge.  
\v 3 Ya mere, Judas duuru otu ndị agha, na ụfọdụ ndị ozi sitere nʼetiti ndịisi nchụaja na ndị Farisii bịa nʼebe ahụ. Ha chịkwa ọwaọkụ, oriọna na ngwa agha. 
\p  
\v 4 Ebe Jisọs maara ihe niile na-akwado ịbịakwasị ya, ọ pụtara sị ha, \wj “Onye ka unu na-achọ?”\wj* 
\p  
\v 5 Ha zaghachiri ya, “Ọ bụ Jisọs onye Nazaret.” 
\p Ọ sịrị ha, \wj “Ọ bụ m”\wj* (Judas onye ahụ rara ya nye so ha guzo nʼebe ahụ.)  
\v 6 Mgbe Jisọs gwara ha, \wj “Ọ bụ m,”\wj* ha laghachiri azụ, daa nʼala. 
\p  
\v 7 Ọzọ ọ jụkwara ha, \wj “Onye ka unu na-achọ?”\wj* 
\p Ha sịrị, “Ọ bụ Jisọs onye Nazaret.” 
\p  
\v 8 Jisọs zara, \wj “Agwara m unu na Ọ bụ m. Ọ bụrụ na unu na-achọ m, hapụnụ ndị a ka ha laa.”\wj* 
\v 9 Nke a bụ iji mezuo okwu ahụ o kwuru na mbụ, \wj “Etufughị m onye ọbụla nʼime ndị ahụ i nyere m.”\wj*\f + \fr 18:9 \ft \xt Jọn 6:39\f* 
\p  
\v 10 Ya mere Saimọn Pita, onye ji mma agha, mịpụtara ya, gbuo ohu onyeisi nchụaja, gbupụ ntị aka nri ya. Aha ohu ahụ bụ Malkus. 
\p  
\v 11 Ma Jisọs gwara Pita, \wj “Mịghachi mma agha gị nʼọbọ ya! Ọ bụ na mụ agaghị aṅụ site nʼiko ahụ Nna m nyere m ka m ṅụọ?”\wj* 
\s1 A kpụrụ Jisọs gaa na nke Anas 
\p  
\v 12 Ya mere ndị agha ahụ na ọchịagha ha, na ndị na-ejere ndị Juu ozi, jidere Jisọs kee ya agbụ.  
\v 13 Ha buru ụzọ duru ya jekwuru Anas, onye bụ nna nwunye Kaịfas. Onye bụ onyeisi nchụaja nʼafọ ahụ.  
\v 14 Kaịfas bụkwa onye ahụ dụrụ ndị ndu ndị Juu ọdụ, sị na ọ ka mma ka otu onye nwụọ nʼihi mmadụ niile. 
\s1 Ngọpụ mbụ nke Pita 
\p  
\v 15 Saimọn Pita na otu onye ọzọ na-eso ụzọ ya sooro Jisọs. Nʼihi na onye nke ahụ na-eso ụzọ ya bụ onye onyeisi nchụaja maara nke ọma, o sooro Jisọs banye nʼobi onyeisi nchụaja.  
\v 16 Ma Pita na-eguzo nʼezi nʼọnụ ụzọ. Onye ọzọ ahụ na-eso ụzọ ya, nke onyeisi nchụaja maara nke ọma, pụrụ nʼezi gwa nwaagbọghọ ahụ na-eche ọnụ ụzọ okwu, ma kpọbata Pita. 
\p  
\v 17 Nwaagbọghọ ahụ sịrị Pita, “Ọ bụ na ị bụghị otu nʼime ndị na-eso ụzọ nwoke a?” 
\p Pita sịrị, “Mba! Abụghị m.” 
\p  
\v 18 Ndị ohu na ndị nche kwanyere ọkụ nʼihi na oyi na-atụ. Ha guzoro nʼebe ahụ na-anya ọkụ. Pita soro ha guzo na-anyakwa ọkụ. 
\s1 Onyeisi nchụaja ajụọ Jisọs ajụjụ 
\p  
\v 19 Nʼoge ahụ onyeisi nchụaja ahụ jụrụ Jisọs banyere ndị na-eso ụzọ ya, na ozizi ya. 
\p  
\v 20 Jisọs zara ya, \wj “Nʼihu ọha mmadụ ka m kwuru okwu niile m kwuru. A kuziri m ihe nʼime ụlọ ekpere na nʼime ụlọnsọ ukwu ebe ndị Juu na-ezukọ. Ekwukwaghị m ihe ọbụla na nzuzo.\wj* 
\v 21 \wj Gịnị mere i ji ajụ m? Jụọ ndị niile gere m ntị! Ha makwaara ihe niile m kwuru.”\wj* 
\p  
\v 22 Mgbe o kwuru nke a, otu onye nʼime ndị na-eje ozi guzo nʼakụkụ ya, mara Jisọs ụra nʼihu, sị, “Ọ bụ otu a ka ị si aza onyeisi nchụaja ajụjụ?” 
\p  
\v 23 Jisọs zara ya, \wj “Ọ bụrụ na ọ dị ihe ọjọọ m kwuru, gbaa ama megide okwu ọjọọ dị otu a, ma ọ bụrụ na m kwuru eziokwu, gịnị mere i ji ama m ụra.”\wj* 
\v 24 Ya mere, Anas kere ya agbụ zigara ya Kaịfas onyeisi nchụaja. 
\s1 Pita agọnarị Jisọs nke ugboro abụọ na nke atọ 
\p  
\v 25 Ma dịka Saimọn Pita ka guzo nʼebe ahụ na-anya ọkụ, ha sịrị ya, “Ọ bụ na ị bụghị otu onye nʼime ndị na-eso ụzọ ya?” 
\p Ma ọ gọrọ agọ sị, “Abụghị m ya.” 
\p  
\v 26 Otu nʼime ndị ohu onyeisi nchụaja, bụ onye ikwu nwoke ahụ Pita bipụrụ ntị, sịrị, “Ọ bụ na m ahụghị gị na ya nʼime ogige ahụ?”  
\v 27 Ma Pita gọkwara agọ ọzọ. Nʼotu mgbe ahụ oke ọkụkụ kwara akwa. 
\s1 Jisọs nʼihu Pailet 
\p  
\v 28 Mgbe ahụ, ha sitere nʼụlọ Kaịfas duru Jisọs gaa nʼụlọeze Pailet. Ọ bụkwa nʼisi ụtụtụ, ma ha onwe ha abanyeghị nʼime ụlọeze ahụ nʼihi na ha achọghị imerụ onwe ha, ka ha nwee ike isoro rie nri na Mmemme Ngabiga.  
\v 29 Pailet gakwuru ha nʼezi sị, “Gịnị bụ ebubo unu na-ebo nwoke a?” 
\p  
\v 30 Ha zara ma sị ya, “Ọ bụrụ na onye a abụghị onye arụrụala, anyị agaraghị akpọtara gị ya.” 
\p  
\v 31 Pailet sịrị, “Durunụ ya pụọ kpee ya ikpe nʼonwe unu dị ka iwu unu si dị.” 
\p Ndị Juu sịrị ya, “Ma anyị enweghị ikike igbu onye o bụla.”  
\v 32 Nke a mere iji mezuo okwu ahụ Jisọs kwuru banyere ụdị ọnwụ ọ gaje ịnwụ. 
\p  
\v 33 Mgbe ahụ Pailet baghachiri nʼime ụlọeze ahụ, zie ozi ka a kpọọrọ ya Jisọs. Ọ jụrụ ya, “Ị bụ eze ndị Juu?” 
\p  
\v 34 Jisọs zara, \wj “Ị na-ajụ nke a nʼonwe gị ka ọ bụ ihe ndị ọzọ gwara gị banyere m?”\wj* 
\p  
\v 35 Pailet zara, “Abụ m onye Juu? Ọ bụ ndị ala gị na ndịisi nchụaja unu kpọtaara m gị. Gịnị ka i mere?” 
\p  
\v 36 Jisọs zara, \wj “Alaeze m abụghị nke ụwa a. A sị na alaeze m bụ nke ụwa a, ndị na-ejere m ozi gaara ịlụrụ m ọgụ iji gbochie m ịdaba nʼaka ndị Juu. Ma ugbu a, alaeze m abụghị nke ụwa a.”\wj* 
\p  
\v 37 Pailet sịrị ya, “Ya bụ na ị bụ eze?” 
\p Jisọs zara, \wj “Gị onwe gị kwuru na m bụ eze. Amụrụ m nʼihi nke a, ọ bụkwa nʼihi nke a ka m ji bi a nʼụwa ịgba ama banyere eziokwu. Onye ọbụla hụrụ eziokwu nʼanya na-ege m ntị.”\wj* 
\p  
\v 38 Pailet sịrị ya, “Gịnị bụ eziokwu?” Mgbe o kwuchara nke a, ọ pụrụ jekwuuru ndị Juu ọzọ sị ha, “Ọ dịghị ihe ọbụla m chọpụtara megidere ya.  
\v 39 Ma ọ bụ omenaala unu, na m ga-ahapụrụ unu otu onye mkpọrọ nʼoge Mmemme Ngabiga. Unu chọrọ ka m hapụrụ unu ‘eze ndị Juu’?” 
\p  
\v 40 Ha tiri mkpu ọzọ sị, “Ọ bụghị nwoke a, ma hapụrụ anyị Barabas.” Barabas bụ onye abalị dị egwu. 
\c 19  
\s1 I ma Jisọs ikpe 
\p  
\v 1 Mgbe ahụ, Pailet kpụụrụ Jisọs, a pịa ya ihe.  
\v 2 Ndị agha kpara okpueze nke e ji ogwu mee, kpukwasị ya nʼisi, yinyekwa ya uwe mwụda na-acha odo odo.  
\v 3 Ha bịakwutere ya ọtụtụ mgbe na-asị, “Ekele, gị Eze ndị Juu!” Ha na-amakwa ya ụra nʼihu. 
\p  
\v 4 Pailet pụkwara nʼezi ọzọ sị ha, “Lee, ana m akpọpụtara unu ya, ka unu mara na achọpụtaghị m ihe ọjọọ ọbụla o mere.”  
\v 5 Mgbe Jisọs yi okpu ogwu na uwe odo odo pụta, Pailet sịrị ha, “Lekwanụ nwoke ahụ!” 
\p  
\v 6 Ngwangwa, ndịisi nchụaja na ndị nche hụrụ ya, ha tiri mkpu sị, “Kpọgide ya nʼobe! Kpọgide ya nʼobe!” 
\p Pailet sịrị ha, “Kpọrọnụ ya kpọgbuo ya nʼonwe unu. Achọpụtaghị m ihe ọjọọ ọbụla o mere.” 
\p  
\v 7 Ndị Juu zara ya, “Anyị nwere iwu, dị ka iwu ahụ siri dị, ihe kwesiri ya bụ ọnwụ, nʼihi na ọ kpọrọ onwe ya Ọkpara Chineke.” 
\p  
\v 8 Mgbe Pailet nụrụ nke a, oke egwu tụrụ ya karịa.  
\v 9 Ọ laghachiri azụ nʼime ụlọeze ahụ, jụọ Jisọs, “Olee ebe i siri bịa?” Ma Jisọs azaghị ya ihe ọbụla.  
\v 10 Pailet sịrị ya, “Ị na-agba m nkịtị? Ọ bụ na ị maghị na m nwere ike ịkpọgide gị nʼobe, nweekwa ike ịhapụ gị ka ị laa?” 
\p  
\v 11 Jisọs zara ya, \wj “Ị garaghị enwe ike ọbụla nʼebe m nọ, ma ọ bụrụ na o siteghị nʼelu rute gị aka. Nke a mere mmehie onye duru m nye nʼaka gị ji karịa.”\wj* 
\p  
\v 12 Site na mgbe ahụ Pailet chọsịrị ike ịhapụ ya. Ma ndị Juu tisiri mkpu ike sị, “Ị hapụ nwoke a ka ọ laa, ị bụkwaghị enyi Siza. Nʼihi na onye ọbụla na-eme onwe ya eze na-elelị Siza.” 
\p  
\v 13 Mgbe Pailet nụrụ okwu ndị a, ọ kpọpụtara Jisọs nʼezi, nọdụkwa ala nʼoche ikpe ya dị nʼebe a na-akpọ Pevumentị (maọbụ Gabata nʼasụsụ Hibru).  
\v 14 Ọ bụ nʼihe dịka nʼoge ehihie nke ụbọchị nkwadebe maka oriri Ngabiga. 
\p Ọ sịrị ndị Juu, “Leenụ eze unu!” 
\p  
\v 15 Ma ha tiri mkpu, “Kpọpụ ya, Kpọpụ ya! Kpọgide ya nʼobe.” 
\p Pailet jụrụ ha, “Unu chọrọ ka m kpọgide eze unu nʼobe?” 
\p Ma ndịisi nchụaja zara, “Anyị enweghị eze ọzọ karịa Siza.” 
\p  
\v 16 Mgbe ahụ, o nyefere ya nʼaka ha, ka ha kpọgide ya nʼobe. 
\s1 Mkpọgbu Jisọs 
\p Ha kpọọrọ Jisọs pụọ.  
\v 17 O buuru obe ya gaa nʼebe a na-akpọ Okpokoro Isi (nke pụtara Gọlgọta nʼasụsụ Hibru).  
\v 18 Nʼebe ahụ ka ha kpọgidere ya nʼobe, ya na mmadụ abụọ ndị ọzọ. Otu onye nʼaka nri ya, onye nke ọzọ nʼaka ekpe ya. 
\p  
\v 19 O nwere ihe Pailet dere kụpanye nʼelu obe ahụ. Ihe o dere bụ nke a: 
\pc Jisọs onye Nazaret, Eze ndị Juu. 
\m  
\v 20 Ọtụtụ ndị Juu gụrụ ihe a o dere, nʼihi na ebe a kpọgburu Jisọs dị nso nʼobodo ahụ. E dekwara ya nʼasụsụ Hibru, Griik na Latin.  
\v 21 Ndịisi nchụaja nke ndị Juu gwara Pailet sị, “Edela na ọ bụ Eze ndị Juu, kama dee na nwoke a sịrị, abụ m eze ndị Juu.” 
\p  
\v 22 Ma Pailet zara, “Ihe m dere, edeela m ya.” 
\p  
\v 23 Mgbe ndị agha kpọgidechara Jisọs nʼobe, ha kere uwe ya ụzọ anọ. Onye ọbụla nʼime ha nwetara otu ụzọ. Ha chịrị uwe mwụda ya nke a na-adụghị adụ, kama a kpara ya akpa site nʼelu ya ruo nʼala ya. 
\p  
\v 24 Ha gwarịtara onwe ha, “Ka anyị hapụnụ ịdọka ya, kama ka anyị fee nza lee onye ọ ga-adanyere i were ya.” 
\p Nke a bụ iji mezuo ihe e dere nʼakwụkwọ nsọ, 
\q1 “Ha kere uwe m nʼetiti onwe ha, 
\q2 feekwa nza banyere uwe mwụda m.”\f + \fr 19:24 \ft \xt Abụ 22:18\f* 
\m Nke a bụ ihe ndị agha ahụ mere. 
\p  
\v 25 Nne ya, nwanne ya nwanyị, bụ Meri nwunye Klopas, na Meri Magdalin guzo nso nʼakụkụ obe Jisọs.  
\v 26 Mgbe Jisọs hụrụ nne ya na onye na-eso ụzọ ya ọ hụrụ nʼanya ka o guzo nʼakụkụ ya, ọ sịrị nne ya, \wj “Nwanyị lee nwa gị nwoke.”\wj* 
\v 27 Ọ sịrị onye ahụ nke na-eso ụzọ ya, \wj “Lee nne gị.”\wj* Site nʼoge ahụ, onye ahụ na-eso ụzọ ya kpọọrọ ya laa nʼụlọ nke ya. 
\s1 Ọnwụ Jisọs 
\p  
\v 28 Nʼikpeazụ, mgbe Jisọs matara na ihe niile emezuola. Ma iji mezuo ihe e dere nʼakwụkwọ nsọ, ọ sịrị, \wj “Akpịrị na-akpọ m nkụ.”\wj* 
\v 29 Otu ite mmanya ọra dọrọ nso nʼebe ahụ. Ha were ogbo denye nʼime mmanya ahụ, kenye ogbo ahụ nʼosisi hisọp welie ya elu chee ya nʼọnụ.  
\v 30 Mgbe Jisọs detụrụ mmanya ahụ ọnụ, ọ sịrị, \wj “Ọ gwụchaala.”\wj* O hulatara isi ya, kubie ume. 
\p  
\v 31 Ma ndị Juu achọghị ka ahụ ndị ahụ a kpọgidere nʼobe nọgide nʼebe ahụ ka chi bọọ, nʼihi na ọ bụ Ụbọchị Nkwadebe. Echi ya bụ ga-abụ ụbọchị izuike pụrụ iche. Ha rịọọrọ Pailet ka a gbajisie ha ụkwụ ma bupụkwa ahụ ha.  
\v 32 Ndị agha ahụ bịara gbajie ụkwụ onye nke mbụ na onye nke ọzọ a kpọgburu ha na ya.  
\v 33 Ma mgbe ha bịaruru nʼebe Jisọs nọ, ha hụrụ na ọ nwụọlarị. Nʼihi nke a, ha agbajighị ụkwụ ya.  
\v 34 Kama otu onye nʼime ndị agha ahụ weere ùbe mapuo ya akụkụ ya. Ngwangwa ọbara na mmiri gbapụtara.  
\v 35 Onye hụrụ ihe ndị a gbara ama ka unu kwere, ama ya bụ eziokwu, ọ matakwara na ihe ọ na-ekwu bụ eziokwu.  
\v 36 Ihe ndị a niile mere ka e mezuo ihe e dere nʼakwụkwọ nsọ, “Ọ dịghị ọkpụkpụ ya ọbụla nke a ga-agbaji.”\f + \fr 19:36 \ft \xt Ọpụ 12:46; Ọnụ 9:12; Abụ 34:20\f* 
\v 37 E dekwara nʼebe ọzọ nʼakwụkwọ sị, “Ha ga-elegide onye ahụ ha mapuru ahụ anya.”\f + \fr 19:37 \ft \xt Zek 12:10\f* 
\s1 Olili Jisọs 
\p  
\v 38 Mgbe ihe ndị a gasịrị, otu nwoke aha ya bụ Josef, onye sitere Arimatia, onye na-eso ụzọ Jisọs na nzuzo, nʼihi egwu ndị Juu, jekwuuru Pailet rịọ ka o nye ya ikike iburu ahụ Jisọs, Pailet kwere, ya mere ọ bịara buru ahụ ya.  
\v 39 Nikọdimọs, onye ahụ bịakwutere Jisọs nʼabalị na mbụ, bịakwara. O wetara máá na aloos a gwakọtara agwakọta, nke ọtụtụ ya ruru ihe dịka kilogram iri atọ na anọ.  
\v 40 Ha buuru ahụ Jisọs, tee ya ụda ndị ahụ, fụchikwaa ya nʼakwa ọcha linin dịka omenaala olili ozu nke ndị Juu si dị.  
\v 41 Ebe ahụ a kpọgidere ya nʼobe dị nʼotu ubi a gbara ogige. Nʼime ogige a, otu ili ọhụrụ dị na ya nke e jibeghị lie onye ọbụla.  
\v 42 Nʼihi na ọ bụ ụbọchị Nkwadebe nke ndị Juu,\f + \fr 19:42 \ft maka ụbọchị izuike ndị Juu\f* nakwa nʼihi na ili ahụ dị nso, ha dọnyere ahụ Jisọs nʼime ya. 
\c 20  
\s1 Mbilite nʼọnwụ nke Jisọs 
\p  
\v 1 Nʼisi ụtụtụ ụbọchị mbụ nke izu ụka, mgbe chi na-abọzibeghị nke ọma, Meri Magdalin bịara nʼili ahụ, ma hụ na e wepụla nkume ahụ e jiri mechie ọnụ ili ahụ.  
\v 2 O ji ọsọ bịakwute Saimọn Pita na onye ọzọ ahụ nke na-eso ụzọ ya, bụ onye Jisọs hụrụ nʼanya sị, “Ha esitela nʼili ahụ bupụ Onyenwe anyị. Anyị amaghị ebe ha dobere ya!” 
\p  
\v 3 Ya mere Pita na onye nke ọzọ ahụ na-eso ụzọ ya pụrụ gawa nʼili ahụ.  
\v 4 Ha abụọ jiri ọsọ na-aga, ma onye ọzọ ahụ na-eso ụzọ ya gbakarịrị Pita nʼọsọ buru ya ụzọ ruo nʼili ahụ.  
\v 5 O hulatara ala, nyoo anya nʼime ili, hụ akwa ọcha ahụ ebe ha wụsara nʼala, ma ọ baghị nʼime.  
\v 6 Ya mere Saimọn Pita, onye na-eso ya nʼazụ bịarutere banye nʼime ili ahụ. Ọ hụrụ akwa ozu ahụ ka ọ wụsara nʼala,  
\v 7 ya na akwa nke e ji kechie ya isi. Ịchafọ a na akwa ọcha ahụ adịkọtaghị nʼotu ebe, kama a pịara ya apịa dobe ya iche nʼebe ọzọ.  
\v 8 Onye ọzọ ahụ nke na-eso ụzọ ya, onye nke buru ụzọ bịaruo nʼili banyekwara nʼime ili ahụ. Ọ hụrụ ma kwerekwa.  
\v 9 (Ruo nʼoge a, ha aghọtabeghị site nʼakwụkwọ nsọ na ọ ghaghị i si nʼọnwụ bilie.)  
\v 10 Emesịa ndị na-eso ụzọ ya laghachiri nʼụlọ ha. 
\s1 Jisọs egosi Meri Magdalin onwe ya 
\p  
\v 11 Ma Meri guzo nʼakụkụ ili ahụ na-ebe akwa. Mgbe ọ nọ na-ebe akwa, o hulatara ala nyoo anya nʼime ili ahụ  
\v 12 hụ ndị mmụọ ozi abụọ yi uwe ọcha, ka ha nọdụrụ ala otu nʼisi, nke ọzọ nʼụkwụ, nʼebe ahụ atọgbọrọ ahụ Jisọs. 
\p  
\v 13 Ha sịrị ya, “Nwanyị, gịnị mere i ji ebe akwa?” 
\p Ọ sịrị ha, “Ha ebupụla Onyenwe m, amaghị m ebe ha bujere ya.”  
\v 14 Nʼoge a, ọ tụgharịrị hụ ka Jisọs guzo nʼebe ahụ. Ma ọ mataghị na ọ bụ Jisọs. 
\p  
\v 15 Jisọs sịrị ya, \wj “Nwanyị, gịnị mere iji ebe akwa? Onye ka ị na-achọ?”\wj* 
\p Ebe o chere na ọ bụ onye na-elekọta ogige ahụ, ọ sịrị ya, “Nna anyị ukwu, ọ bụrụ na ọ bụ gị bupụrụ ya, gwa m ebe i debere ya ka m gaa buru ya.” 
\p  
\v 16 Jisọs sịrị ya, \wj “Meri.”\wj* 
\p Ọ tụgharịrị tie mkpu nʼolu Hibru sị ya, \tl “Raboni!”\tl* (nke pụtara “Onye nkuzi.)” 
\p  
\v 17 Jisọs sịrị ya, \wj “Emetụkwala m aka nʼihi na alakwurubeghị m Nna m. Kama gakwuru ụmụnna m gwa ha, ‘Ana m alakwuru Nna m na Nna unu. Chineke m na Chineke unu.’ ”\wj* 
\p  
\v 18 Meri Magdalin gara gwa ndị na-eso ụzọ ya, “Ahụla m Onyenwe anyị.” Ọ kọọrọ ha na ọ bụ ya gwara ya ihe ndị a niile. 
\s1 Jisọs egosi ndị na-eso ụzọ ya onwe ya 
\p  
\v 19 Nʼuhuruchi nke ụbọchị ahụ, bụ ụbọchị mbụ nke izu ụka, mgbe ndị na-eso ụzọ ya zukọtara nʼime otu ụlọ. Ha mechiri ụzọ niile nʼihi egwu ndị Juu. Jisọs batara guzo nʼetiti ha sị ha, \wj “Udo dịrị unu!”\wj* 
\v 20 Mgbe o kwusiri nke a, o gosiri ha aka ya na akụkụ ya. Ọṅụ juru ndị na-eso ụzọ ya obi nʼihi na ha ahụla Onyenwe anyị. 
\p  
\v 21 Ọzọkwa, Jisọs sịrị ha, \wj “Udo dịrị unu! Dị ka Nna m si zite m, otu a ka m na-eziga unu.”\wj* 
\v 22 Mgbe o kwuchara nke a, o kusara ha ume sị ha, \wj “Naranụ Mmụọ Nsọ.\wj* 
\v 23 \wj Ọ bụrụ na unu agbaghara onye ọbụla mmehie ya, a ga-agbaghara ya, ọ bụrụkwa na unu ajụ ịgbaghara ha, agaghị agbaghara ha.”\wj* 
\s1 Jisọs egosi Tọmọs onwe ya 
\p  
\v 24 Ma Tọmọs (onye a na-akpọ Didimọs), otu nʼime ndị ozi iri na abụọ ahụ, anọghị ya mgbe Jisọs bịara.  
\v 25 Ya mere, ndị ọzọ na-eso ụzọ ya gwara ya, “Anyị ahụla Onyenwe anyị!” 
\p Ma ọ sịrị ha, “Ọ bụ naanị mgbe m jiri anya m hụ ebe ahụ ntu kpọpuru ya aka, tinye mkpịsịaka m nʼapa ntu ndị ahụ, ma tinyekwa aka m nʼakụkụ ya ebe ahụ a mara ya ùbe, ka m ga-ekwere.” 
\p  
\v 26 Mgbe abalị asatọ gasịrị, ndị na-eso ụzọ ya zukọtara ọzọ. Ugbu a Tọmọs nọkwa nʼetiti ha. Nʼagbanyeghị na e mechisịrị ụzọ niile, Jisọs batara guzo nʼetiti ha sị ha, \wj “Udo dịrị unu.”\wj* 
\v 27 Mgbe ahụ ọ sịrị Tọmọs, \wj “Rụnye mkpịsịaka gị nʼebe a, leekwa aka m abụọ. Wepụta aka gị tinyekwa nʼakụkụ m. Abụla onye na-enweghị okwukwe, kama kwere.”\wj* 
\p  
\v 28 Tọmọs zara sị ya, “Onyenwe m na Chineke m!” 
\p  
\v 29 Ma Jisọs sịrị ya, \wj “I kweere nʼihi na ị hụla m? Ma ngọzị dịrị ndị na-ahụghị ma kwere.”\wj* 
\s1 Ihe mere e ji dee akwụkwọ oziọma Jọn 
\p  
\v 30 Ọ dị ọtụtụ ihe ịrịbama ndị ọzọ Jisọs rụrụ nʼihu ndị na-eso ụzọ ya. Ma edeghị ha nʼime akwụkwọ a.  
\v 31 Ma e dere ihe ndị a niile ka unu kwere na Jisọs bụ Kraịst, Ọkpara Chineke. Nʼihi na ọ bụ site nʼikwere ka unu ga-eji nweta ndụ ọhụrụ site nʼaha ya. 
\c 21  
\s1 Jisọs na ọrụ ebube nke igbute azụ 
\p  
\v 1 Mgbe ihe ndị a gasịrị, Jisọs gosiri ndị na-eso ụzọ ya onwe ya ọzọ. O mere nke a nʼakụkụ osimiri nke Tiberịas,\f + \fr 21:1 \ft Maọbụ, \fqa Galili\f* lee otu o si mee.  
\v 2 Ụfọdụ nʼime ndị na-eso ụzọ ya nọkọrọ otu ebe. Ndị a bụ Saimọn Pita na Tọmọs (onye a na-akpọ Didimọs), na Nataniel, onye Kena nke Galili na ụmụ Zebedi, na mmadụ abụọ ndị ọzọ bụkwa ndị ozi ya.  
\v 3 Saimọn Pita sịrị ha, “Ana m aga igbu azụ.” Ha sịrị, “Anyị ga-eso gị.” Ha biliri gaa, banye nʼime ụgbọ mmiri. Ma nʼabalị ahụ niile ha egbuteghị ihe ọbụla. 
\p  
\v 4 Mgbe chi na-abọ Jisọs guzoro nʼakụkụ mmiri. Ma ndị na-eso ụzọ ya amataghị na ọ bụ Jisọs. 
\p  
\v 5 Jisọs sịrị ha, \wj “Ụmụntakịrị, unu gbutere azụ ọbụla?”\wj* 
\p Ha zara ya, “Mba.” 
\p  
\v 6 Ọ gwara ha, \wj “Wụnyenụ ụgbụ unu nʼakụkụ aka nri nke ụgbọ. Unu ga-egbutekwa azụ.”\wj* Mgbe ha mere nke a, ha enwekwaghị ike ịdọpụta ụgbụ ha, nʼihi ọtụtụ azụ nke dị nʼime ya. 
\p  
\v 7 Mgbe ahụ onye ahụ na-eso ụzọ ya Jisọs hụrụ nʼanya gwara Pita, “Ọ bụ Onyenwe anyị!” Ngwangwa Saimọn Pita nụrụ na “ọ bụ Onyenwe anyị,” ọ yiiri uwe ya (nʼihi na ọ gba ọtọ), wụba nʼime mmiri ahụ.  
\v 8 Ndị ọzọ ndị na-eso ụzọ ya bịara nʼụgbọ mmiri nta ahụ, na-adọpụta ụgbụ ha nke azụ juru nʼime ya, nʼihi na ha nọ nso nʼala ihe dị ka narị nzọ ụkwụ na ise.\f + \fr 21:8 \ft Maọbụ, \fqa narị kubit abụọ\f* 
\v 9 Mgbe ha pụtara nʼelu ala, ha hụrụ ọkụ a kwanyere, nke a hụkwasịrị azụ nʼelu ya na ogbe achịcha. 
\p  
\v 10 Jisọs gwara ha, \wj “Wetanụ ụfọdụ nʼime azụ ndị ahụ unu gbutere ugbu a.”\wj* 
\v 11 Saimọn Pita pụrụ gaa dọgota ụgbụ azụ ahụ nʼelu ala. Ihe juru ya bụ azụ ndị ukwuu nke ọnụọgụgụ ya dị narị na iri ise na atọ. Ma ụgbụ ahụ adọwaghị nʼagbanyeghị na azụ juru nʼime ya.  
\v 12 Jisọs sịrị ha, \wj “Bịanụ rie nri ụtụtụ.”\wj* Ọ dịghị onye ọbụla nʼime ndị ahụ na-eso ụzọ ya jụrụ ya, “Ị bụ onye?” Nʼihi na ha maara na ọ bụ Onyenwe anyị.  
\v 13 Jisọs bịara were achịcha ahụ nye ha. Otu ahụ ka o mekwara azụ ahụ.  
\v 14 Nke a bụ ugboro atọ Jisọs gosiri ndị na-eso ụzọ ya onwe ya mgbe e mere ka o si nʼọnwụ bilie. 
\s1 Jisọs akpọghachite Pita 
\p  
\v 15 Mgbe ha risiri nri ụtụtụ, Jisọs sịrị Saimọn Pita, \wj “Saimọn nwa Jọn, ị hụrụ m nʼanya karịa ndị a niile?”\wj* 
\p Ọ sịrị ya, “E, Onyenwe anyị, ị maara na m hụrụ gị nʼanya.” 
\p Jisọs sịrị ya, \wj “Na-azụ ụmụ atụrụ m.”\wj* 
\p  
\v 16 Jisọs sịrị ya nke ugboro abụọ, \wj “Saimọn nwa Jọn, ị hụrụ m nʼanya?”\wj* 
\p Ọ sịrị, “E, Onyenwe anyị, ị maara na m hụrụ gị nʼanya.” 
\p Ọ sịrị ya, \wj “Na-elekọta atụrụ m.”\wj* 
\p  
\v 17 Ọ sịrị ya nke ugboro atọ, \wj “Saimọn nwa Jọn, ị hụrụ m nʼanya?”\wj* 
\p O wutere Pita na ọ sịrị ya nke ugboro atọ, \wj “ị hụrụ m nʼanya?”\wj* Ọ sịrị ya, “Onyenwe anyị, ị mazuru ihe niile, ị makwaara na m hụrụ gị nʼanya.” 
\p Jisọs sịrị ya, \wj “Na-azụ atụrụ m.\wj* 
\v 18 \wj Nʼezie, nʼezie asị m gị, mgbe ị bụ okorobịa ị na-eke ajị nʼukwu, gaa ebe ị chọrọ ịga. Ma mgbe ị ghọrọ agadi, ị ga-esetipụ aka gị, onye ọzọ ga-ekee gị ihe okike nʼukwu ma duru gị gaa ebe ị na-achọghị ịga.”\wj* 
\v 19 O kwuru nke a iji gosi ụdị ọnwụ ọ ga-anwụ iji nye Chineke otuto. Mgbe nke a mesịrị, ọ sịrị ya, \wj “Soro m.”\wj* 
\p  
\v 20 Pita chigharịrị hụ onye ahụ na-eso ụzọ ya nke Jisọs hụrụ nʼanya ka ọ na-esokwa ha nʼazụ. (Ọ bụ onyeozi ahụ dabeere ya nʼobi na nri anyasị, nke sịrị, “Onyenwe anyị, onye ga-arara gị nye?”)  
\v 21 Mgbe Pita hụrụ ya, ọ sịrị Jisọs, “Onyenwe anyị kedụ maka onye a?” 
\p  
\v 22 Jisọs sịrị ya, \wj “Ọ bụrụ na m achọọ ka ọ nọgide ruo mgbe m ga-alọghachi gịnị ka nke a bụ nye gị? Soro m.”\wj* 
\v 23 Ya mere, akụkọ a gbasara nʼetiti ụmụnna na onye a na-eso ụzọ ya agaghị anwụ. Ma Jisọs asịghị ya na ọ gaghị anwụ anwụ, kama, \wj “Ọ bụrụ na m chọrọ ka ọ nọgide ruo mgbe m ga-abịa, ọ gbasara gị?”\wj* 
\p  
\v 24 Nke a bụ onye ahụ na-eso ụzọ ya onye na-agba ama ihe ndị a niile, ma deekwa ha nʼakwụkwọ. Anyị makwaara na ama ya bụ eziokwu. 
\p  
\v 25 Ma ọ dị ọtụtụ ihe ndị ọzọ Jisọs mere. Ọ bụrụ na e dee ha niile nʼakwụkwọ, ọ dịghị m ka ụwa niile ọ ga-aba akwụkwọ a ga-ede banyere ha.