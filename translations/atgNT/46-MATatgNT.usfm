\id MAT - Okphela
\h iMatiu
\toc1 iMatiu
\toc2 iMatiu
\toc3 iMat
\mt2 Usomhi Onete oyi iJesu iKirisiti ni
\mt1 IMatiu
\mt2 Ọ kẹkẹ
\c 1
\s1 Unuẹkpẹ oyi iJesu iKirisiti
\r (iLuk 3.23-38)
\p 
\v 1 Ona o khi akẹkẹ shi ekẹ abi unuẹkpẹ oyi iJesu iKirisiti Omi iDefidi ni ọ khi Omi Aburaamu o li zẹ.
\p 
\v 2 Aburaamu ọ bia Aziki,
\q1 Aziki ọ bia iGiekọpu,
\q1 IGiekọpu ọ bia iJuda
\q1 ali inyọghuo ọli nya.
\q1 
\v 3 IJuda ọ bia iPẹrẹzi
\q1 ali iZẹra, ọkpotso ni ọ bia wẹ,
\q2 a lu iTama.
\q1 IPẹrẹzi ọ bia Ezirọni.
\q1 Ezirọni ọ bia iRamu.
\q1 
\v 4 IRamu ọ bia Aminadabu.
\q1 Aminadabu ọ bia iNashọni,
\q1 iNashọni ọ bia iSalimọni.
\q1 
\v 5 ISalimọni ọ bia iBoazi,
\q1 ọkpotso ni ọ bia iBoazi,
\q2 a lu iRe-abu.
\q1 IBoazi ọ bia Obẹdi
\q1 ni a lu inyọli iRutu.
\q1 Obẹdi ọ bia iJese.
\q1 
\v 6 IJese ọ bia iDefidi
\q2 ni ọ khi oghie.
\q1 IDefidi ọ bia iSolomoni
\q1 ni inyọli ọ kpẹ khi ughuẹ Uraya.
\q1 
\v 7 ISolomoni ọ bia iReobuamu.
\q1 IReobuamu ọ bia Abija.
\q1 Abija ọ bia Asa.
\q1 
\v 8 Asa ọ bia iJeoshafati.
\q1 IJeoshafati ọ bia iJeoramu,
\q1 iJeoramu ọ bia Uzaya.
\q1 
\v 9 Uzaya ọ bia iJotamu.
\q1 IJotamu ọ bia Aazi.
\q1 Aazi ọ bia Ezekaya.
\q1 
\v 10 Ezekaya ọ bia iManasẹ,
\q1 iManasẹ ọ bia Amọni.
\q1 Amọni ọ bia iJosaya.
\q1 
\v 11 IJosaya ọ bia iJekonaya
\q1 ali inyọghuo ọli nya
\q1 ẹghẹghẹ ni a rọ muno
\q1 ẹgbọ iZirẹni ighumha je iBabilọ.\f + \fr 1:11 \ft Li zẹ \fq 2 Ighie 24.14-15; 2 Okhẹ 36.10; iJere 27.20\f*
\q1 
\v 12 Abi e ke rọ rọte iBabilọ jele,
\q1 iJekonaya ọ bia iShalitiẹni.
\q1 IShalitiẹni ọ bia IZerubabẹli.
\q1 
\v 13 IZerubabẹli ọ bia Abiudu.
\q1 Abiudu ọ bia Eliakimu.
\q1 Eliakimu ọ bia Azori.
\q1 
\v 14 Azori ọ bia iZadọki.
\q1 IZadọki ọ bia Akimu.
\q1 Akimu ọ bia Eliudu.
\q1 
\v 15 Eliudu ọ bia Eliaza.
\q1 Eliaza ọ bia iMataani.
\q1 IMataani ọ bia iGiekọpu.
\q1 
\v 16 IGiekọpu ọ bia iJosẹfu,
\q1 ni ọ rue iMeli inyi iJesu shi
\q1 ni a lu iKirisiti.
\p 
\v 17 Rọte ẹghẹghẹ Aburaamu bhale ẹghẹghẹ iDefidi, e khi agbhotu igbẹne. Ke rọte ẹghẹghẹ iDefidi bhale ẹghẹghẹ ni a rọ muno ẹgbọ iZirẹni ighumha je iBabilọ, e khi agbhotu igbẹne. Ke rọte ẹghẹghẹ iBabilọ bhale ẹghẹghẹ ni a rọ bia iJesu iKirisiti, e gbo li khi agbhotu igbẹne ghọ.
\s1 Abi a li bia iJesu iKirisiti
\r (iLuk 2.1-7)
\p 
\v 18 Abi a li bia iJesu iKirisiti na. Neni iMeli inyọli ọ ngeli na iJosẹfu ni ọọ gue ọli. A bhale ya ẹ khi iMeli ọọ mẹ ọmọ ni ọ rọte obọ oyi Ayẹmhẹ-nọ-pfuasẹ bhale.\f + \fr 1:18 \ft Li zẹ \fq iLuk 1.27\f*
\v 19 Itobọ khi iJosẹfu ughuọli, ọ khi ọgbọ ni ọ guẹ angeli, ọọ sali shi udu khi lọli ya kuegbe-a ri imeli shi ekẹ, ini lọli khi yẹghẹ ọlia ukpẹloe agbọ.
\p 
\v 20 Abi ọ lii sa ona shi udu, agẹni ọ bhale deba li alo ẹlena, ọọ li, “IJosẹfu omi iDefidi, khi ke zẹ ni ulishi o mu ẹ abi u li ya rue iMeli shi ughuẹ, irari khi ọmọ ni ọọ mẹ, obọ oyi Ayẹmhẹ-nọ-pfuasẹ ọ te bhale.
\v 21 Ọ ya bia ọmọ ọmọse, eva ni u ya lu ọni ọmọ khi iJesu, irari khi ọ ya mie ẹgbọ eyọli olamhẹ pfuese.”\f + \fr 1:21 \ft Li zẹ \fq iLuk 1.31\f*
\p 
\v 22 Eri a mẹ enana ni a rọ bhẹ ya ẹ khi ingmemhi ni Ẹshinẹgba ọ rọte unu oyi ọmekẹguele ngme, ni e bhale ya tsẹ. Ni ọọ,
\v 23 “Ghe khẹ! Ọmueshi ni ọa lẹ deba ọmọse ghue ọ ya ke mẹ ọmọ, ọ bia ọmọ ọmọse, eva oyọli a ya ke lu iManuẹni.”\f + \fr 1:23 \ft Li zẹ \fq Aza 7.14; 8.8,10\f* Abi ona o ngme khi, “Ẹshinẹgba ọ nu awa la.”
\p 
\v 24 Abi iJosẹfu ọ rọ guale, ọ riẹlẹ emini Ọnọmhuẹ ọ mhẹsẹ na li ọ riẹlẹ, ọ rue iMeli ughuẹ abi Ẹshinẹgba ọ gueyẹ ọli.
\v 25 Eri-tsẹ khi iJosẹfu ọa tigbe lẹ deba iMeli, ramhi ni ọ rọ bia ọni ọmọ ọmọse. IJosẹfu ọ lu eva oyi ọni ọmọ, iJesu.\f + \fr 1:25 \ft Li zẹ \fq iLuk 2.21\f*
\c 2
\s1 Epfẹse ni e rọte obini ovọ o te ẹ ngale bhale
\p 
\v 1 Ẹoli ni a lu iBẹtilẹẹmu obini ekẹ iJudia a bia iJesu shi, ẹghẹghẹ ni oghie ni a lu Erọdu ọ rọ khi oghie. Emọse elẹsingme eghuo e rọte obini ovọ o te ẹ ngale bhale ekẹ iJerusalẹmu.
\v 2 Ee mhila, ee liẹ, “Obo a bia ọni ọmọ ni ọ ya khi oghie ọyi ẹgbọ iJu shi? Irari khi anye she mẹ ukpẹtata oyọli obini ovọ o te ẹ ngale, lọli o zẹ khi anye bhale ni anye ya ga li.”
\p 
\v 3 Abi ọni oghie Erọdu ọ rọ suọ ona, egbe ẹa ke sheshe lọli ali ẹgbọ kpa ni e la iJerusalẹmu.
\v 4 Ọ luno ighie eyi ekpodalo-ugamhi nya ali esẹsẹ Ishi eyi iMosisi kugbe. Ọ mhila wẹ, ọọ wẹ, “Obo ẹ khi a ya bia iKirisiti Ọmiepfuese shi?”
\v 5 E gueyẹ ọli, “Ẹoli iBẹtilẹẹmu na ekẹ iJudia lọ.” “Irari khi ighọ emekẹguele e kẹkẹ shi ekẹ khi:
\q1 
\v 6 “ ‘IBẹtilẹẹmu na ekẹ iJudia,
\q2 yẹyẹ u ga khi ọni ọ mu ẹloe nẹ nya
\q1 elemhi ẹoli eniẹmhi
\q2 ni e la ekẹ iJudia.
\q1 Ayẹ oghie ọ te ya lasele,
\q2 ni ọ ya ri ẹgbọ iZirẹni
\q2 khasẹ odẹ.’ ”\f + \fr 2:6 \ft Li zẹ \fq iMika 5.2\f*
\p 
\v 7 Ighọ oghie Erọdu ọ lu eni emọse eghọ ochi, ọ mhila wẹ, “Ẹghẹghẹ onoghuo a rọ mẹ oni ukpẹtata?”
\v 8 Ighọ ọ ghie wẹ je iBẹtilẹẹmu, ọọ wẹ, “A ke lẹ, a kuegbe-a ya nono ọli. A kha da mẹ ọli ne, a nyenẹ egbe bhale ya gueyẹ mhẹ ni mhi li ya ga li.”
\p 
\v 9 Abi e rọ suọ abi Erọdu ọ ngme se, e te aghọ fiẹ lasele. Ighọ e gbo mẹ oni ukpẹtata ni e kpẹ mẹ obini ovọ o te ẹ ngale. O rẹ wẹ khasẹ odẹ ya ramhi ni o rọ migha ukhomhi oni owa ni ọni ọmọ ọ la.
\v 10 Egbe e mema mu wẹ abi e rọ mẹ oni ukpẹtata.\fig Epfẹse aasẹ ali ukpẹtata oyi iJesu|src="CN01629b.tif" size="col" loc="MAT 2.10" copy="TIF" ref="2.10"\fig*
\v 11 Ighọ e lo elemhi oni owa. Abi e rọ mẹ ọni ọmọ ali inyọli iMeli, e wugha e ga li. E khueghie ẹkuẹ ni e tsua-a, e rue igolu ali afu ituale ali oili ituale ni ẹẹ pfie ni e ghalẹ somhi ọli opfa.
\v 12 Ighọ Ẹshinẹgba ọ tse agua yẹ wẹ alo ẹlena e khi gbo nyenẹ egbe ukhokho deba ọni oghie. Itobọ ighọ e rọte odẹ olese ya je apfẹ.
\s1 A rue iJesu na je ekẹ iJipiti
\p 
\v 13 Abi eni emọse e rọ je se, agẹni ọyi Ọnọmhuẹ ọ gueyẹ iJosẹfu alo ẹlena, ọọ li, “Erọdu ọọ nono ọni ọmọ ọna ni luẹ gbe ọli-a. Rue ọli ali inyọli na je ekẹ iJipiti. La aghọ ramhi ẹghẹghẹ ni mhi rọ ya gueyẹ u rọte aghọ vu.”
\v 14 Obili o bi, iJosẹfu ọ rue ọni ọmọ ali inyọli na je ekẹ iJipiti.
\v 15 Oobọ ọ la ramhi ni oghie Erọdu ọ rọ ghu-a. Eri Ẹshinẹgba ọ riẹlẹ ona ni a rọ bhale ya ẹ khi emini ọmekẹguele ọ ngme khi o bhale ya tsẹ. Ni ọọ, “Ekẹ iJipiti mhi te lu omi mhẹ.”\f + \fr 2:15 \ft Li zẹ \fq Osia 11.1\f*
\s1 Erọdu ọ shi ushi a gbolo eniyẹ enikeke-a
\p 
\v 16 Abi Erọdu ọ rọ mẹ khi eni emọse ni e rọte obini ovọ o te ẹ ngale bhale eghọ khi e di luẹ, Elemhi ee bi ọ egbegbọ. Ọ shi ushi a gbolo eniyẹ emọse enikeke ni e la ẹoli iBẹtilẹẹmu ali ẹoli ni e la gasẹ ọli-a nya. Eniyẹ rọte ikpe eva tiemhi ekẹ, abi eni epfẹse e gueyẹ ọni oghie ẹghẹghẹ ni e rọ mẹ oni ukpẹtata.
\p 
\v 17 Abi a li mẹ ọli ena, o ri ungmemhi ni ọmekẹguele iJeremaya ọ ngme bhale ya tsẹ.
\q1 
\v 18 “A suọ okokokhuẹ
\q1 ekẹ iRama,\f + \fr 2:18 \ft Li zẹ \fq iJere 31.15\f*
\q2 ni o khi oyi eviẹ,
\q2 ali eviẹ oya.
\q1 IRechẹ ọọ viẹ imi ọli,
\q2 Àá yẹsẹ ọli,
\q2 ọa zẹ yẹsẹ, irari
\q2 khi imi ọli e ghulo-a.”
\s1 IJosẹfu ali apfọli e rọte ekẹ iJipiti jele apfẹ
\p 
\v 19 Erọdu ọ ghu-a se, agẹni ọyi Ẹshinẹgba ọ bhale deba iJosẹfu alo ẹlena obini ekẹ iJipiti.
\v 20 Ọọ, “IJosẹfu, vule, rue omiẹ ali ughuẹ, a ke je ekẹ iZirẹni irari khi eni ẹẹ nono ni wẹwẹ e gbe ọni ọmọ-a, e she ghuloa.”
\p 
\v 21 Ighọ iJosẹfu ọ vule, ọ rue ọni ọmọ ali inyọli, ọ nyenẹ egbe je ekẹ iZirẹni.
\v 22 Eri-tsẹ khi abi iJosẹfu ọ rọ suọ khi Achẹlusi ọ ke shitọ ukpẹkhomhi oyi itali shi ekẹ iJudia, ulishi o mu ọli ọa gbudu je oobọ, ọ ri ochoghọ ya je obini ekẹ iGalili abi agẹni ọ she kpẹ tse agua yẹ ọli.
\v 23 Ọ ri iNazarẹti mele apfẹ oyọli-a. Irarighọ, ungmemhi ni emekẹguele e ngme, o bhale ya tsẹ. Ni ọọ. “A ya ke lu ọli ọngi iNazarẹti.”\f + \fr 2:23 \ft Li zẹ \fq iMak 1.24; iLuk 2.39; iJọn 1.45\f*
\c 3
\s1 IJọni Ọni ọọ batazi ẹgbọ ọọ tse abọ
\r (iMak 1.1-8; iLuk 3.1-18; iJọn 1.19-28)
\p 
\v 1 Ikpe ni e bu e dọsẹ, iJọni Ọni ọọ batazi ẹgbọ ọ lasele shi elemhi ọdagbe ifufu na ekẹ iJudia, ọọ tse abọ.
\v 2 Ọọ liẹ, “A rọte olamhẹ eyẹ ẹ mu pfi irari khi Eghiele oyi Ẹshinẹgba o she ti bhale.”\f + \fr 3:2 \ft Li zẹ \fq iMat 4.17; iMak 1.15\f*
\v 3 Ingme oyi iJọni ọna, Azaya ọmekẹguele ọọ ngme abi ọ rọ liẹ,
\q1 “Ọgbọ ọghuo ọ la elemhi
\q2 ọdagbe ifufu ẹ tsẹsẹ, ọọ liẹ,
\q1 ‘Bẹ odẹ-a na Ọnọmhuẹ rọte,
\q2 bẹ ọli sheshe.’ ”\f + \fr 3:3 \ft Li zẹ \fq Aza 40.3\f*
\p 
\v 4 Itsua ni iJọni ọ rọ sọ, iriria akphẹrẹ a rọ do wẹ. Ọ ri ọgbẹnẹ ẹkuẹ ẹlamhi mu oku. Initso ali oribo e khi eminale eyọli.\f + \fr 3:4 \ft Li zẹ \fq 2 Ighie 1.8\f*
\p 
\v 5 IJerusalẹmu ali ekẹ iJudia ali ẹdẹli ni e mama okẹ iJọdani nya ẹgbọ e rọte e bhale ni e suọ ungmemhi oyọli.
\v 6 Ọ la elemhi okẹ iJọdani batazi ẹgbọ, ee zọnọ olamhẹ eyẹwẹ lasele.
\p 
\v 7 Abi iJọni ọ rọ mẹ khi ẹgbọ otu iFarisi ali iSadusi ni e bu e bhale deba li ọ batazi wẹwẹ, ọọ wẹ, “Ẹẹ enyẹ ali imi enyẹ! Ọghuo ọ tse agua yẹ ẹ, a na, khi anasẹmhẹ ọọ bhale ni Ẹshinẹgba ọ ya ghie ghi ẹ?\f + \fr 3:7 \ft Li zẹ \fq iMat 12.34; 23.33\f*
\v 8 A ke ngeli ingeli eni e ya rọkhasẹ khi a she mu pfi.
\v 9 A khi ke sa khi a ya na pfue anasẹmhẹ ini a da liẹ, ‘Aburaamu ọ khi itita anye.’ Itobọ khi Ẹshinẹgba ọ dobẹ ya rọte echẹ ena wolọ eniyẹ lasele na Aburaamu.\f + \fr 3:9 \ft Li zẹ \fq iJọn 8.33\f*
\v 10 A she tọ uze sọ udi ọara. Ọara ni ọa da mọ umọmhi onete ne, a ya khi ọli pfilo erali.\f + \fr 3:10 \ft Li zẹ \fq iMat 7.19\f*
\p 
\v 11 “Amẹ mhi rọ ọ batazi ẹ memena, irari khi a she mu pfi. Ọgbọẹse ni ọọ bhale ikpukhokho oyẹmhẹ, ọ fu dọsẹ mhẹ. Mhi a fẹ futẹ ọni ọ tsua ekuẹ oyọli ekẹ. Lọli ọ ya ri Ayẹmhẹ-nọ-pfuasẹ ali erali batazi ẹ.
\v 12 Ọ̀ mu ukpokpo ni a tọ akhuli ni o zẹ epfia sọ mhuẹ obọ oyọli, ni ọ rọ ya ke ghiaghiẹ wẹ, ọ pfie efuẹ ado-a, ashini a la kpishi wẹ. Ọọ ti wẹ gbili shi ashini a ri eminale ẹ shi, eni efuẹ wẹ eghọ, ọ ya ri erali ni ẹa ya pfua ghue tosẹ wẹ-a.”
\s1 Abi iJesu ọ li batazi
\r (iMak 1.9-11; iLuk 3.21-22)
\p 
\v 13 IJesu ọ ya rọte ekẹ iGalili bhale okẹ iJọdani ni iJọni ọ batazi luẹ.
\v 14 IJọni, ọọ nono ni lọli khu iJesu oni ibatizi, ọọ iJesu, “Yẹyẹ u kha batazi mhẹ, sẹ u ke gbo li bhale deba mhẹ mhi batazi ẹ?”
\p 
\v 15 IJesu ọ sọli ọ, ọọ li, “Iiye. Kie zẹ ni awa lina riẹlẹ ọli ẹghẹghẹ ona, ni awa mẹ asha ri ọghuẹmhẹ oyi Ẹshinẹgba gbe akanya pfo.” IJọni ọ lama shi ọli ọ.
\p 
\v 16 A batazi iJesu se, khi ọ lẹsẹ na rọte elemhi okẹ ngale esọ egele, ọ mẹ khi idane o khueghie a. Ighọ ọ mẹ khi Ayẹmhẹ oyi Ẹshinẹgba ọ li abi anekhukhu tiemhile bhale ya ma li egbe.
\v 17 A suọ khi uruli o rọte idane ngme, ọọ li, “Omimhẹ ni mhi nono ingme oyọli na, ni ọ ri egbe ẹ mu mhẹ.”\f + \fr 3:17 \ft Li zẹ \fq Igbae 22.2; Iwolo 2.7; Aza 42.1; iMat 12.18; 17.5; iMak 1.11; iLuk 9.35\f*
\c 4
\s1 Imufẹ oyi iJesu
\r (iMak 1.12-13; iLuk 4.1-13)
\p 
\v 1 Ayẹmhẹ ọ rue iJesu je ọdagbe ifufu ni Ọkphaghiẹ ọ mẹ asha mu ọli fẹ.\f + \fr 4:1 \ft Li zẹ \fq Iburu 2.18; 4.15\f*
\v 2 Abi iJesu ọ rọ pfi azumhi ogbẹlẹ egbhuẹva se, okiamhi oo gbe ọli.
\v 3 Ighọ Ọkphaghiẹ ọ bhale deba li, ọọ li, “Ini o khia khi Omi Ẹshinẹgba u khi, nu eni echẹ ena ngme ni e mele eminale-a nẹ ni u le.”
\p 
\v 4 IJesu ọọ li, “Ebe-no-pfuasẹ o ngme ghọ khi:
\q1 “ ‘Ọa khi eminale tsẹ,
\q1 o ri agbọ a na ọgbọ,
\q2 ama ungmemhi ni
\q2 o rọte Ẹshinẹgba unu lasele kpa.’ ”\f + \fr 4:4 \ft Li zẹ \fq iDẹut 8.3\f*
\p 
\v 5 Ighọ Ọkphaghiẹ ọ rue iJesu je iJerusalẹmu, ẹoli no pfuasẹ. Ọ rue ọli ya nga apfiẹpfiẹmhi ashini o yagha nẹ shi Owa Oyi Ẹshinẹgba ya migha.
\v 6 Ọọ iJesu, “Ini o khi Omi Ẹshinẹgba u khi, rọte ukhomhi ana ji ya tiemhi ekẹkhẹ.” Irari khi Ebe-no-pfuasẹ o ngme ọli khi:
\q1 “ ‘Ẹshinẹgba ọ ya
\q2 ri unu na igẹni eyọli
\q2 e ri ẹloe shi ẹ egbe
\q2 e kpe abọ muẹ,
\q1 Ini u khi khi owẹ
\q2 shi ẹchẹ.’\f + \fr 4:6 \ft Li zẹ \fq Iwolo 91.11,12\f*”
\p 
\v 7 IJesu ọọ li, “A gbo li kẹkẹ ọ shi Ebe-no-pfuasẹ khi, ‘Khi mu Ẹshinẹgba Ọnọmhuẹ ọyẹ fẹ bino.’ ”\f + \fr 4:7 \ft Li zẹ \fq iDẹut 6.16\f*
\p 
\v 8 Ighọ Ọkphaghiẹ ọ rue iJesu nga ukhomhi ute ni o lolo yagha, ọ ga ri eghiele ni e la agbọ ona nya ali isomhotse oyẹwẹ khasẹ ọli.
\v 9 Ọọ li, “Ena nya mhi ya rọ nẹ ini u lẹsẹ nyẹsẹ ukhomhi ga mhẹ.”
\p 
\v 10 IJesu ọọ li, “Vu mhẹ alo-a, Ọkphaghiẹ! Ebe-no-pfuasẹ òó liẹ,
\q1 “ ‘Nyẹsẹ ukhomhi na
\q1 Ẹshinẹgba Ọnọmhuẹ oyẹ,
\q2 lọlighuo kpe wa ke ga.’ ”\f + \fr 4:10 \ft Li zẹ \fq iDẹut 6.13\f*
\p 
\v 11 Ighọ Ọkphaghiẹ ọ zẹ iJesu obọ, igẹni e bhale ya kpaghiẹ ọli obọ.
\s1 IJesu ọ rọte iGalili gba ikanya eyọli ekẹ le
\r (iMak 1.14-15; iLuk 4.14-15)
\p 
\v 12 Abi iJesu ọ rọ suọ khi a mu iJọni shi owa ighumha, ọ nyenẹ egbe je ẹdẹli iGalili.\f + \fr 4:12 \ft Li zẹ \fq iMat 14.3; iMak 6.17; iLuk 3.19-20\f*
\v 13 Ọa migha iNazarẹti, ọ je iKapanọmu, ẹdẹli ni o la ukiẹkiẹ okẹ iGalili ni o la ekẹ iZebulọ ali iNafutali.\f + \fr 4:13 \ft Li zẹ \fq iJọn 2.12\f*
\v 14 Eri a mẹ ena ni a rọ bhale ya ẹ khi ungmemhi ni Azaya ọmekẹguele ọ ngme, o bhale ya tsẹ, ni ọ la liẹ,
\q1 
\v 15 “Ẹẹ ekẹ iZebulọ
\q2 ali ekẹ iNafutali,
\q2 ni a la ini a da okẹ iJọdani lase,
\q1 IGalili, ni ẹgbọ
\q2 iJẹta\f + \fr 4:15 \ft Ẹgbọ iJẹta khi ẹgbọ ni e la ekẹ agbọ ona nya ni ẹa khi ẹgbọ iZirẹni.\f* e ngeli, ni o la odẹ ni o je okẹ oniẹmhi.
\q1 
\v 16 Ẹgbọ ni e la alo ebili
\q2 e ya mẹ ákpá oniẹmhi.
\q1 Oni ákpá ọọ ngale na
\q2 ẹgbọ ni o li abinẹ khi
\q2 eghuli o ti mama wẹ.”\f + \fr 4:16 \ft Li zẹ \fq Aza 9.1-2\f*
\p 
\v 17 Rọte aghọ vu iJesu ọ rọte tse abọ kia guele, “Ọgbọgbọ ọ mu pfi, irari khi Eghiele oyi Ẹshinẹgba o she ramhi.”\f + \fr 4:17 \ft Li zẹ \fq iMat 3.2\f*
\s1 IJesu ọ lu egbifẹlẹ aane e deba luẹ
\r (iMak 1.16-20; iLuk 5.1-11)
\p 
\v 18 Abi iJesu ọ li kia epfepfẹ okẹ oniẹmhi iGalili, ighọ ọ mẹ iPita ali Aduru, ọgbọ ali inyọghuo ni e khi egbifẹlẹ khi e ri aga a gbe ifẹlẹ oni okẹ-no-khishi.
\v 19 IJesu ọọ wẹ, “A bhale deba mhẹ khi mhi ya sẹsẹ ẹ abi a ke liẹ ke lu ẹgbọ bhale, ocho ni a rọ ọ gbe ifẹlẹ.”
\v 20 Aghọaghọ e zẹ aga eyẹwẹ obọ, e deba li.
\p 
\v 21 Ọ ke lẹ, ọ mẹ ọgbọ ali inyọghuo, iJemhisi ali iJọni imi iZebedi khi e nu itawẹ la elemhi ọkọ okẹ ni e lo, e riẹlẹ aga oyẹwẹ ẹ riẹlẹ. IJesu ọ lu wẹ e bhale.
\v 22 Aghọaghọ e lase ọkọ-okẹ le, e pfi itawẹ shi aghọ, e deba li vu.
\s1 IJesu ọ ri eni ẹẹ ghua ze
\r (iLuk 6.17-19)
\p 
\v 23 IJesu ọ kia asha kpa ekẹ iGalili ọ la owa ugamhi eyẹwẹ sẹsẹ wẹ usomhi onete oyi iloghie, ali ọ ri ẹgbọ ni e mhuẹ ighuamhi ọdọda ze.
\v 24 Ighọ a li suọ eko ọli ushishi iSiria oghọ nya, ya ramhi khi ẹgbọ e tsua eni mhuẹ ighuamhi ali anasẹmhẹ ọdọda, ghe eni e mhuẹ ayẹmhẹ ọkphaghiẹ ali ughuamhi ni ọọ mu ọgbọ pfi gbe ali eni e guọghọ-a bhale deba iJesu. Ọ ga rẹwẹ ze nya.
\v 25 Ighọ ebubu ẹgbọ e rọte iGalili ali ẹoli iDikapolisi ali iJerusalẹmu, ekẹ iJudia ali ẹgbọ ni e la ukiẹkiẹ obinokpọle oyi okẹ iJọdani, e deba li.
\c 5
\s1 Osẹsẹ ni iJesu ọ la esọ ute sẹsẹ
\p 
\v 1 Abi iJesu ọ rọ mẹ oni olele ẹgbọ, ọ ti nga esọ ute dẹnẹ, ọ shitọ. Eniyẹ odukhokho eyọli e bhale ya shitọ gasẹ ọli.\fig IJesu ọ shitọ ukhomhi ute e sẹsẹ|src="CN01700B.TIF" size="col" loc="MAT 5.1" copy="Cook" ref="5.1"\fig*
\v 2 Ọọ sẹsẹ wẹ, ọọ liẹ,
\q1 
\v 3 “Ikhivọsẹ o khi oyi ẹgbọ
\q1 ni e lẹsẹ khi
\q1 Ẹshinẹgba ọ mhuẹ emhikpa,
\q2 wẹwẹ e mhọli obọ shi
\q2 Eghiele oyi Ẹshinẹgba.
\q1 
\v 4 Ikhivọsẹ o khi na ẹgbọ
\q1 ni ẹẹ viẹ,\f + \fr 5:4 \ft Li zẹ \fq Aza 61.2\f*
\q2 Ẹshinẹgba ọ ya yẹsẹ wẹ.
\q1 
\v 5 Ikhivọsẹ o khi oyi ẹgbọ ni
\q1 e ti egbewẹ tiemhile,\f + \fr 5:5 \ft Li zẹ \fq Iwolo 37.11\f*
\q2 Ẹshinẹgba ọ ya ri
\q2 agbọ ona nya na wẹ.
\q1 
\v 6 Ikhivọsẹ o khi oyi ẹgbọ ni
\q1 okiamhi ali okiamẹ
\q1 iguẹ-ngeli ọọ gbe,\f + \fr 5:6 \ft Li zẹ \fq Aza 55.1-2\f*
\q2 Ẹshinẹgba ọ ya ri
\q2 emini ẹ nono na wẹ.
\q1 
\v 7 Ikhivọsẹ o khi oyi ẹgbọ
\q1 ni e mhọli ilẹlemhi na ẹgbọẹse,
\q2 Ẹshinẹgba ọ ya
\q2 mhọli ilẹlemhi na wẹ.
\q1 
\v 8 Ikhivọsẹ o khi oyi ẹgbọ
\q1 ni e mhọli udu no pfuasẹ,\f + \fr 5:8 \ft Li zẹ \fq Iwolo 24.3-4\f*
\q2 e ya mẹ Ẹshinẹgba.
\q1 
\v 9 Ikhivọsẹ o khi oyi ẹgbọ
\q1 ni ẹẹ dua ini opfọmhẹ o la ọ,
\q2 Ẹshinẹgba ọ ya lu wẹ imiọli.
\q1 
\v 10 Ikhivọsẹ o khi oyi ẹgbọ
\q1 ni a mu okhọli vule shi ọ
\q2 irari khi e da riẹlẹ
\q2 emini Ẹshinẹgba ọ nono,\f + \fr 5:10 \ft Li zẹ \fq 1 iPit 3.14\f*
\q1 wẹwẹ e mhọli obọ shi
\q2 eghiele oyi Ẹshinẹgba.
\p 
\v 11 “Ikhivọsẹ o khi nẹ, ini ẹgbọ e mu okhọli vule shi ẹ ọ, ẹẹ kiẹ iwali ẹgbhọli ọdọda mẹ irari khi u mie mhẹ suọ.\f + \fr 5:11 \ft Li zẹ \fq 1 iPit 4.14\f*
\v 12 Zẹ ni u ke ghẹlẹ, egbe ẹẹ muẹ, irari khi eleli oyẹ ni o la iloghie oo gbẹdi gba. Ina e li mu okhọli vule shi emekẹguele ọ ni e kpẹ bhale khẹ.\f + \fr 5:12 \ft Li zẹ \fq 2 Okhẹ 36.16; Ika 7.52\f*
\s1 Ugbheli ali ákpá oyi agbọ a khi
\r (iMak 1.16-20; iLuk 5.1-11)
\p 
\v 13 “Eri a li abi ugbheli shi agbọ ọ. Ini ugbheli o wasẹ oviọlọ oyọli-a, aa ke tigbe mhọli abi a li ya rọli gbo mele ugbheli-a. Aa ke rọli ya li emhikhọghuo dọsẹ a ku ọli kua ni a ri awẹ lighi ọli ekẹ.
\p 
\v 14 “Eri a li abi ákpá shi agbọ ọ. Owa ni a tọ shi ukhomhi ute ọa ya sheli.\f + \fr 5:14 \ft Li zẹ \fq iJọn 8.12; 9.5\f*
\v 15 Aa mẹ ọgbọ ni ọ ya ri ákpá ru se, ọ khukhu ọli shi atalabi. Eri ọ ya ri ochoghọ rue ọli nga asha na keghe, ni o ke mẹ ekẹ ni ẹgbọ ni e la oni owa e ke mẹ ekẹ.\f + \fr 5:15 \ft Li zẹ \fq iMak 4.21; iLuk 8.16; 11.33\f*
\v 16 Lighọ zẹ ni ákpá oyẹ o ke gẹ khasẹ ẹgbọ, ni e rọ mẹ ikanya enete eyẹ ni e mẹ asha kuẹghiẹ Ẹshinẹgba ni ọ la iloghie.\f + \fr 5:16 \ft Li zẹ \fq 1 iPit 2.12\f*
\s1 Osẹsẹ abi ishi eyi iMosisi o ngme
\p 
\v 17 “A khi dabi khi eri mhi bhale ya shishi Ishi eyi iMosisi ekẹ-a, a khi a dabi khi eri mhi bhale ya shishi emini emekẹguele e sẹsẹ-a. Iiye! Eri mhi bhale ya rẹ wẹ tsẹ.
\v 18 Zẹ mhẹ gueyẹ khi ekẹ ali ukhuli e kha da kie la ọ ne, ukpamhi ingme okhọghuo ọa ya wa Ishi eyi iMosisi-a, ini emini e kẹkẹ wẹ shi ekẹ shi nya ẹa li bhale ya tsẹ.\f + \fr 5:18 \ft Li zẹ \fq iLuk 16.17\f*
\v 19 Itobọ ighọ, ọnini ọ da gbe ushi ni o ga shẹ nẹ a nya, ni ọ gbolo ẹ sẹsẹ ẹgbọ e li lighọ ne, lọli ọ ga ya shẹ nẹ nya Eghiele oyi Ẹshinẹgba, ọnini ọ da riẹlẹ wẹ ni ọ gbolo ẹ sẹsẹ ẹgbọ eni ishi eyi Ẹshinẹgba ne, ọ ya khi ọnọfunẹ Eghiele oyi Ẹshinẹgba.
\v 20 Mhi gueyẹ ẹ khi ini iguẹ-ngeli oyẹẹ ọa da dọsẹ iguẹ-ngeli oyi esẹsẹ Ishi eyi iMosisi ali ẹgbọ iFarisi ne, aa ya lo Eghiele oyi Ẹshinẹgba.
\s1 Osẹsẹ oyi ingme elemhi ibibi
\r (iLuk 12.57-59)
\p 
\v 21 “A suọ khi ẹghẹghẹ ni o dọsẹ khi a gueyẹ eni egbhali, ẹẹ, ‘Khi gbe ugbeli, ọnini ọ da lighọ ne, a ya ri ọli gue ẹzọ.’\f + \fr 5:21 \ft Li zẹ \fq Okiali 20.13; iDẹut 5.17\f*
\v 22 Ama memena mhi gueyẹ ẹ khi ọni ọ da mhuẹ ofu deba inyọghuo ọli ne, a ya rọli gue ẹzọ. Ọni ọ da liẹ inyọghuo ọli, ‘Yẹyẹ ọgbọ afuẹ ọna!’ A ya rue ọli bhale deba enighie. Ọni ọ da lu inyọghuo ọli, ‘Yẹyẹ ọyẹghẹ ọna!’ Ọ ya la okhẹna erali na ilimhi iriẹriẹ.
\p 
\v 23 “Ini u mhuẹ isomhopfa ni u wa nono ni u rọ ghi Ẹshinẹgba ukhomhi atẹtẹ, ni u rọ da sato khi inyọghuo ẹ ọ mhuẹ ofu nẹ shi emini u riẹlẹ ọli ne,
\v 24 zẹ oni isomhopfa oghọ obọ shi odalo atẹtẹ, u je apfẹ ni yẹyẹ ali ọni inyọghuo ẹ ni a rọ riẹlẹ, u tigbe bhale ya ri isomhopfa oyẹ na Ẹshinẹgba.
\p 
\v 25 “Ini ọbe ẹ ọ rue ẹ lẹ ikọtu, nyanya lema li abi a li la odẹ ẹ lẹ eghọ neni a ramhi aghọ. Ini ọa khi ighọ, ọ ya rue ẹ na ọsọ-ẹzọ, ọni ọsọ-ẹzọ ọ rue ẹ na ọgbanelemhi, ọ́ rue ẹ ya khukhu shi owa ighumha.
\v 26 Abi o li mhi li gue ọli ẹ yẹ ẹ khi, waa ya rọte aghọ lasele ini u waa li zẹ oko na fiẹ pfo nya.
\s1 Osẹsẹ ingme okia
\p 
\v 27 “A suọ ẹghẹghẹ ni o dọsẹ khi a liẹ, ‘Khi kia okia.’\f + \fr 5:27 \ft Li zẹ \fq Okiali 20.14; iDẹut 5.18\f*
\v 28 Ama memena mhi gueyẹ ẹ khi ọnini ọ da ri ọghuẹmhẹ itsẹbọ bino ọkpotso ne, ọ she kia okia deba ọni ọkpotso elemhi usamhi udu oyọli.
\v 29 Irarighọ, ini o khia khi ẹloe na obita oyẹ o ya zẹ ni u lo owa erẹ, vuọnyọ li pfia, irari khi o ti nẹ ini egbe ẹa gba nẹ ya lo iloghie, dọsẹ khi yẹyẹ nya u lo ilimhi iriẹriẹ.\f + \fr 5:29 \ft Li zẹ \fq iMat 18.9; iMak 9.47\f*
\v 30 Ini o khia khi obita oyẹ o ya zẹ ni u pfidọ ya lo owa erẹ, khi ọli pfia. O tinẹ ni u zẹ obọ oghuo ya lo iloghie dọsẹ khi yẹyẹ nya u lo ilimhi iriẹriẹ.\f + \fr 5:30 \ft Li zẹ \fq iMat 18.8; iMak 9.43\f*
\s1 Osẹsẹ ipfa ughuẹ-a
\r (iMat 19.9; iMak 10.11-12; iLuk 16.18)
\p 
\v 31 “A li ngme ọli shi Ishi eyi iMosisi khi, ‘Ọmọse ọ kha khu ughuẹ ọli, ọ nya ebe ipfa ughuẹ-a na li.’\f + \fr 5:31 \ft Li zẹ \fq iDẹut 24.1-4; iMat 19.7; iMak 10.4\f*
\v 32 Ama memena mhi gue ẹ yẹ ẹ khi, ọni ọ da khu ughuẹ ọli ni o khia khi ọa khi eri ọ kia okia ne, ọ she yẹsẹ ọni ọkpotso mele ọkiokia-a. Ọmọse ni ọ rue ọni ọkpotso ọghọ, eri ọ li kia okia.\f + \fr 5:32 \ft Li zẹ \fq iMat 19.9; iMak 10.11-12; iLuk 16.18; 1 iKọri 7.10-11\f*
\s1 Osẹsẹ irọnga
\p 
\v 33 “A gbo li suọ khi a gueyẹ ẹgbọ ena ẹlẹlẹ, ‘A khi da irọnga ni a rọ nga, ama emini u romhi Ọnọmhuẹ rọ nga, khi da ọ, lighọ rọli tsẹ.’\f + \fr 5:33 \ft Li zẹ \fq iLẹv 19.12; iNọba 30.2; iDẹut 23.21\f*
\v 34 Emini mhi ke gue ẹ yẹ ẹ mena khi, khi ga romhi isheli kpa. Khi romhi idane irari khi oobọ ukpẹkhomhi oyi Ẹshinẹgba o la.\f + \fr 5:34 \ft Li zẹ \fq iJem 5.12; Aza 66.1; iMat 23.22\f*
\v 35 Khi gbo li romhi ekẹkhẹ, irari khi lọli khi akphawẹ-nga oyi Ẹshinẹgba. Wẹkhi iJerusalẹmu, irari khi lọli o khi ẹoli oyi Oghie nọ funẹ.\f + \fr 5:35 \ft Li zẹ \fq Aza 66.1; Iwolo 48.2\f*
\v 36 Khi ga ri ukhomhi oyẹ romhi ishe, irari khi waa ya dobẹ ri ẹtsui oghuo kpe bishi a wẹ khi eri u dobẹ rọli ya pfuasẹ-a.
\v 37 Ungmemhi oyẹ o lẹsẹ migha shi ii, okekhi iiye, emini o da dọsẹ ighọ ne, obọ oyi Ọkphaghiẹ o te bhale.
\s1 Khi ri onobe fali ota onobe
\r (iLuk 6.29-30)
\p 
\v 38 “A suọ khi a kpẹ ngme ọli, khi, ‘A ri ukpẹloe fata ukpẹloe, ali ẹkọli o fata ẹkọli.’\f + \fr 5:38 \ft Li zẹ \fq Okiali 21.24; iLẹv 24.20; iDẹut 19.21\f*
\v 39 Ama mena, mhi gueyẹ ẹ, a khi riẹlẹ ọgbọ to ọ ini ọ riẹlẹ ẹ onobe. Ini ọgbọ, ọ lase ẹ esọ obita nyenẹ ona ọgobọ na li gbo lase.
\v 40 Ini ọgbọ ọọ nono ni lọli luẹ ẹzọ, ni lọli rọ mie ẹ awulu oyẹ, bie gbo gueghie oni u sọ kpọkẹ ma ọ nali.
\v 41 Ini ọgbọ ọ ri itoto liẹ u tsua itsua na luẹ imali oghuo, tsua wẹ imali eva.
\v 42 Ini ọgbọ ọ mhila ẹ emhi, rọna li. Ngmomhi na ọni ọ ye ongmomhi deba ẹ.
\s1 Mhọli inono na ebe ẹ
\r (iLuk 6.27-28,32-36)
\p 
\v 43 “A she suọ khi a liẹ, ‘Nono ingme oyi ọnuzi-ava ọyẹ, u ke biselemhi ọbe ẹ.’\f + \fr 5:43 \ft Li zẹ \fq iLẹv 19.18\f*
\v 44 Ama mhi gueyẹ ẹ. Nono ingme oyi ọbe ẹ, u gbo sọ iromhi na eni mu okhọli vule shi ẹ ọ.
\v 45 U kha lina, eri u wa ngeli abi itẹ na iloghie. Irari khi lọli ọ ri ovọ oyọli ẹ to na ẹgbọ ọkhọlọ ali ẹgbọ enete. Ighọ ọ gbo liẹ ruẹsẹ amẹ na ẹgbọ ọkhọlọ abi ọ liẹ ruẹsẹ ọli na ẹgbọ enete.
\v 46 Sẹ u ke li ya mẹ asha mhuẹ eleli obọ oyi Ẹshinẹgba ini u lẹsẹ nono ẹgbọ ni e nono ingme oyẹ? Egbegbi emionoga e lili ẹ lighọ.
\v 47 Ini o khia khi inyọghuo ẹ tsẹ u lẹsẹ ẹ tsẹ, ighe ikhiọda ni o la yẹyẹ ali eni ẹa miesuọ ọ? Eni ẹa miesuọ e lili ẹ lighọ.
\v 48 Itobọ ona, zẹ ni u gba pfo abi Itẹ na iloghie ọ li gba pfo.”\f + \fr 5:48 \ft Li zẹ \fq iLẹv 19.2; iDẹut 18.13\f*
\c 6
\s1 Osẹsẹ isomhopfa
\p 
\v 1 “Guẹ kia ini u khi riẹlẹ iguẹ-ngeli abamẹmhẹ ukpẹloe ẹgbọ. Ini u wa a lighọ, wa a ya mhuẹ eleli obọ oyi Ẹshinẹgba Ita ni ọ la iloghie.\f + \fr 6:1 \ft Li zẹ \fq iMat 23.5\f*
\p 
\v 2 “Ini u ri isomhopfa na ẹgbọ ni ẹa mhuẹ, khi rọli pfi akala ke kiakia, abi eni ẹa miesuọ ẹẹ li elemhi owa ugamhi ali ifuapfẹ. Eri ẹ lighọ ni ẹgbọ e ba kuẹghiẹ wẹ. Abi o li mhi li gue ẹ yẹ ẹ, khi, e she mie eleli eyẹwẹ se.
\v 3 Ama rọna ọni ọ la ọmunu, khi zẹ ni ọgbọẹse ọ lẹsẹ.
\v 4 Ẹghẹghẹ aghọ o khi emhi osheli, ni Itẹ ni ọ la iloghie ni ọọ mẹ emini u riẹlẹ elemhi osheli, ọ ri eleli nẹ.
\s1 Osẹsẹ abi a liẹ sọ iromhi
\r (iLuk 11.2-4)
\p 
\v 5 “Yẹyẹ o yẹ ini u ya sọ iromhi khi ya riẹlẹ ọli abi eri ugamhi ku alo ni ẹẹ migha epfẹ odẹ ali elemhi owa ugamhi ini ẹgbọ e ba ke mẹ wẹ. Abi o li mhi liẹ gue ọli ẹ yẹ ẹ khi e she mhuẹ eleli oyẹwẹ gba se.\f + \fr 6:5 \ft Li zẹ \fq iLuk 18.10-14\f*
\v 6 Ama ini u ya sọ iromhi, lo elemhi owa oyẹ, u khukhu odẹ, u sọ iromhi ghi Ita ẹ ni ọ la osheli, Itẹ ni ọ la osheli ni ọọ mẹ emini a li osheli, ọ ya ri eleli gba nẹ.
\v 7 Ini u ya sọ iromhi, khi ke riẹlẹ ungmemhi oghuo ngme itingmingmẹ, abi eni ẹa miesuọ ẹẹ li. Eri ẹẹ dabi khi ingmemhi ni e bu dọsẹ Ẹshinẹgba ọyẹwẹ ọ rọ suọ wẹ.
\v 8 Khi li abi wẹwẹ. Itobọ khi Itẹ ọ shẹ kpẹ lẹsẹ emini u wa nono neni u mhila li.
\p 
\v 9 “U kha sọ iromhi, ke liẹ:
\q1 “Ita anye ni ọ la iloghie,
\q1 anye ri ufumhi na
\q2 eva oyẹ no pfuasẹ,
\q1 
\v 10 zẹ ni Omhẹsẹ oyẹ o bhale.
\q1 Zẹ ni a riẹlẹ ọghuẹmhẹ oyẹ
\q2 ekẹ agbọ abi a liẹ riẹlẹ ọli
\q2 obini iloghie.
\q1 
\v 11 Ri eminale ona
\q2 ogbe-namo na anye.
\q1 
\v 12 Gbe olamhẹ kua na anye,
\q2 abi anye liẹ gbe kua
\q2 na ẹgbọ ni e lamhẹ shi anye ọ.
\q1 
\v 13 ‘Khi zẹ ni anye
\q2 de pfilo imufẹ,
\q1 mie anye pfuese obọ oyi ọkphaghiẹ.’
\m 
\v 14 U kha gbekua na eni e lamhẹ shi ẹ ọ, Itẹ na iloghie ọ ya li gbekua nẹ.
\v 15 Ama ini u wa a gbekua na eni e lamhẹ shi ẹ ọ, Itẹ na iloghie ọa ya li gbekua nẹ.\f + \fr 6:15 \ft Li zẹ \fq iMak 11.25-26\f*
\s1 Abi a liẹ pfi azumhi
\p 
\v 16 “U kha pfi azumhi, khi wushe alo-a shi ukhomhi abi eni ẹa miesuọ ẹẹ li. Eri ẹẹ nyenẹ alo zẹ shi ukhomhi ini ẹgbọ e ba lẹsẹ khi ẹẹ pfi azumhi. Abi o li mhi li gue ẹ yẹ ẹ, e she mhuẹ eleli oyẹwẹ se.
\v 17 Ama u kha pfi azumhi, ri oili shishi ukhomhi rọ dala egbe-a, u pfiono itsu-a shi ukhomhi,
\v 18 ini ẹgbọ e khi lẹsẹ khi azumhi wa pfi. Ama ọni Itẹ ni ọọ mẹ osheli nya ọ ya ri eleli nẹ gbodojo.
\s1 Ẹpfue ena obini iloghie
\r (iLuk 12.33-34)
\p 
\v 19 “Khi ti ẹpfue ma leghe na egbe ẹ shi elemhi agbọ ona, ni ifu e la le emhi, ni emhi e la mu ọghuọghuọ-a, ali ni ighiatọ e la dobẹ ẹ do.\f + \fr 6:19 \ft Li zẹ \fq iJem 5.2-3\f*
\v 20 Ochoghọ ti ẹpfue ma iloghie ni ifu ẹa dobẹ la le emhi, ali ni emhi ẹa la mu ọghuọghuọ-a wẹkhi ighiatọ e dobẹ la do.
\v 21 Irari khi asha ni ẹpfue oyẹ o la aghọ udu oyẹ ọọ la.
\s1 Ákpá oyi idiegbe
\r (iLuk 11.34-36)
\p 
\v 22 “Ikpamhi alo e khi ákpá ni idiegbe o mhuẹ. Ini ukpẹloe oyẹ o dala, egbe eyẹ nya o khi ákpá.
\v 23 Ama ini alo eyẹ ẹa ti, idiegbe eyẹ nya e khi alo ebili. Ini a ke bhale ya ẹ khi ákpá ni o la idiegbe oyẹ o khi obili, sẹ oni obili o ke bẹshi liẹ gba ramhi shi idiegbe oyẹ!
\s1 Ẹshinẹgba ali ẹpfue
\r (iLuk 16.13; 12.22-31)
\p 
\v 24 “Ọgbọkhọghuo ọa dobẹ ya ga ega ava. Eri ọ ya nono ingme oyi ọghuo, elemhi ọnọkpọle ẹẹ bi ọli. Ọ ya ke suọ esọ na ọghuo, ọ ri ukpẹloe gbe ọnọkpọle. Ọgbọ ọa ya dobẹ ga Ẹshinẹgba ali ukpaghọlọ utoghuo.
\p 
\v 25 “Onana o zẹ ni mhi rọ gueyẹ u khi ke sa usamhi emini a le ali emini a da, wẹkhi usamhi egbe ẹ emini u ya sọ. Agbọ oyẹ ọa fu dọsẹ eminale? Abi khi eri idiegbe oyẹ ọa fu dọsẹ ode?
\v 26 A bino ipfeli ni e la idane, ẹa rọ kọ wẹkhi eri ẹẹ khiẹsẹ tima shi aka. Ama eri Itẹ na iloghie ọ kie ri ẹloe ẹ khu wẹ. Aa mu ẹloe dọsẹ wẹ?
\v 27 Ọngẹẹ ọnọghuo ọ dobẹ ya ri isamhi ali ayele khi iwakati oghuo kpe ma agbọ oyọli?
\p 
\v 28 “Elọ o zẹ ni a rọ ọ sa usamhi ode ni a rọ ọ ku egbe? A bino idodo ni e la ifui ebuli, khi ẹa ya gbe akanya wẹkhi eri ẹ fia ide zu egbewẹ.
\v 29 Ama mhi gueyẹ ẹ khi ashini Oghie iSolomoni ọ mhuẹ ufumhi ramhi, ọa khuẹ akhuẹ ramhi udodo okhọghuo ena.\f + \fr 6:29 \ft Li zẹ \fq 1 Ighie 10.4-7; 2 Okhẹ 9.3-6\f*
\v 30 Ini Ẹshinẹgba ọ lina ri ide ku ebuli tsẹ, ni o kha la ọ amo, akọ o to-a, sẹ ọa kẹ liẹ li ri ode ku ẹ? Ẹẹ ẹgbọ ni irudunga oyẹẹ o shẹ.
\v 31 Itobọ ighọ khi ke yele obini u ya mẹ eminale le ali obini u te ya mẹ da, ali obini u te ya mẹ ide ku egbe.
\v 32 Emhi enana eni ẹa miesuọ e na khu, ama Itẹ na iloghie ọ lẹsẹ khi a kha mhọli emhi eghọghọ kpa.
\v 33 Ochoghọ kpẹ zẹ ni Ẹshinẹgba ọ mhẹsẹ shi agbọ oyẹ ne, ni u ri eni omhẹsẹ gbe akanya, khi ọ ya ri emhi enekpọle nya ma ọ nẹ.
\v 34 Irarighọ, khi ke zẹ ni ayele akọ o nasẹ udu amo, akọ o ya sa usamhi egbọli. Ogbẹlẹ ọgbọgbọ o mhuẹ anasẹmhẹ oyọli.”
\c 7
\s1 Igue ẹgbọ ẹzọ
\r (iLuk 6.37-38,41-42)
\p 
\v 1 “A khi gue ẹgbọ ẹzọ, ini Ẹshinẹgba ọ khi gue ẹ ẹzọ.
\v 2 Irari khi abi u li gue ẹgbọẹse ẹzọ, ighọ Ẹshinẹgba ọ li ya gue ẹzọ oyẹ. Emini u rọ mhẹsẹ na ọgbọẹse a li rọ ya mhẹsẹ nẹ.\f + \fr 7:2 \ft Li zẹ \fq iMak 4.24\f*
\p 
\v 3 “Elọ o zẹ ni u rọ mẹ uku ni o la inyọghuo ẹ ẹloe ni u waa rọ mẹ ufolo ọara ni o pfida ẹ ẹloe?
\v 4 Sẹ u ke liẹ gueyẹ inyọghuo ẹ, ‘Zẹ ni mhi rue ẹ uku ẹloe le,’ ni yẹyẹ ọyẹ wa a rọ mẹ ufolo ọara ni o pfida ẹ ẹloe?
\v 5 Yẹyẹ ọ ri ugamhi ku alo, kpẹ rue ufolo ọara ni o pfida ẹ ẹloe-a ne neni u tigbe ya mekẹ rue oni o la oyi inyọghuo ẹ ọ-a.
\p 
\v 6 “Khi ri emhi ipfuasẹ na ewa. Khi pfi emini o mu ẹloe abi igolu ghi igulu. Eri e ya wu wẹ ekẹ-a, e sọ alo okhọli ghue ẹ.
\s1 Mhila, u nono, u kpheli
\r (iLuk 11.9-13)
\p 
\v 7 “Mhila khi a ya rọ nẹ. Nono khi u ya mẹ rue, kpheli obọ odẹ khi a ya khueghie-a nẹ.
\v 8 Irari khi ọni ọ mhila, lọli a rọ ọ na. Ọgbọ ni ọ nono lọli ọ mẹ ẹ rue. Ọni ọ kpheli obọ odẹ, lọli a khueghie-a a na.
\p 
\v 9 “Ọngẹẹ ọnọghuo ọ bia ni omiọli ọ ya mhila li ibulẹdi ni ọ ya rue ẹchẹli na li?
\v 10 Ọ kha mhila ẹ afẹlẹ, ẹnyẹ u ya rue na li?
\v 11 Ini ẹẹ ni a khi ẹgbọ ebe a lẹsẹ abi a li ri eminete ẹ na imi ẹ, sẹ Ita ni ọ la iloghie ọ ke bẹshi li ya ri eminete na ẹgbọ ni e mhila li?
\v 12 Irarighọ, abi u nono ni ọgbọ li riẹlẹ deba ẹ, yẹyẹ li lighọ riẹlẹ deba li. Irari khi emini Ushi oyi iMosisi ali emekẹguele e sẹsẹ nya na.\f + \fr 7:12 \ft Li zẹ \fq iLuk 6.31\f*
\s1 Odẹ unuẹkpẹ na pfi ali ona gbada
\r (iLuk 13.24)
\p 
\v 13 “Rọ te odẹ unuẹkpẹ na pfi lo. Irari khi odẹ unuẹkpẹ na gbada ali odẹ agbala na gbada o khi odẹ ni o je owa erẹ, ebubu ẹgbọ e rọte ọ.
\v 14 Odẹ ni o je iloghie eri oo riele, odẹ unuẹkpẹ ni a te ẹ je ọ, oo pfi, ama ikuku ẹgbọ e rọte ọ.
\s1 Ọara ali ikpamhi eyọli
\r (iLuk 6.43-44)
\p 
\v 15 “A bẹ ekẹ ma emekẹguele ẹgbhọli. Eri e ri ẹkuẹ osumha ku egbe, ama elemhi udu oyẹwẹ, idumhi ni ẹ nyanọ ọgbọ le e khi.
\v 16 Angeli oyẹwẹ o rẹ wẹ ẹ khasẹ emini e khi. Ọkphẹkphẹ ọa ya mọ udumhi olomu, wẹ khi eri ọọ mọ udumhi ọkhua eni.
\v 17 Ọara onete ọọ mọ udumhi onete. Ọara ni ọa ti ọọ mọ udumhi ni ọa ti.
\v 18 Ọara onete ọa ya mọ udumhi ni ọa ti, wẹkhi eri ọara ni ọa ti o dobẹ ya mọ udumhi onete.
\v 19 Ọara kpa ni ọa da mọ udumhi onete ne, eri a ya khi ọli pfia, a tosẹ ọli a.\f + \fr 7:19 \ft Li zẹ \fq iMat 3.10; iLuk 3.9\f*
\v 20 Itobọ ighọ emini emekẹguele ẹgbhọli ẹẹ riẹlẹ, u te ẹ lẹsẹ wẹ.\f + \fr 7:20 \ft Li zẹ \fq iMat 12.33\f*
\s1 Mhi aa lẹsẹ ọni u khi
\r (iLuk 13.25-27)
\p 
\v 21 “Ọa khi ọgbọkpa ni ọọ lu mhẹ, ‘Ọnọmhuẹ, Ọnọmhuẹ’ ọ ya lo eghiele oyi Ẹshinẹgba, ama ẹgbọ ni ẹ riẹlẹ ọghuẹmhẹ oyi Itamhẹ ni ọ la iloghie.
\v 22 Ini ẹlẹ iguẹzọ o ramhi, ebubu ẹgbọ e ya liẹ mhẹ, ‘Ọnọmhuẹ, Ọnọmhuẹ, anye ẹẹ she ri eva oyẹ mẹ ekẹ guele, anye ri eva oyẹ khu ẹgbọ iyẹmhẹ ebe egbe-a, anye gbo gbe ikanya ọnyaloa ọdọda?’
\v 23 Ẹghẹghẹ aghọ mhi ya gueyẹ wẹ gboo, ‘Mhi aa lẹsẹ ẹ. A vu mhẹ ana le pia, ẹẹ ẹgbọ ọkhọlọ ena.’\f + \fr 7:23 \ft Li zẹ \fq Iwolo 6.8\f*
\s1 Ẹgbọ ava ni e tọ owa
\r (iLuk 6.47-49)
\p 
\v 24 “Ọgbọkpa ni ọ da suọ ungmemhi oyẹmhẹ ni ọ da rọli gbe akanya ne, eri ọ li abi ọgbọ ọlẹsingme ni ọ tọ owa nga ukhomhi ẹchẹ.
\v 25 Ini amẹ o riẹ ruẹ, ni ochikpho o rọ tu, khi akpekpeli o riẹ li gbe oni owa oghọ, ọa o ya de, irari khi ukhomhi ẹchẹ a tọ li nga.
\v 26 Ama ọgbọ ni ọ da suọ ungmemhi oyẹmhẹ ni ọa da rọli gbe akanya ne eri ọ li abi ọyẹghẹ ni ọ tọ owa nga ekhashẹ.
\v 27 Amẹ o kha ruẹ, ni ochikpho o rọ tu, ni akpekpeli o rọ li gbe oni owa oghọ, oni owa o de kua, o de udemhi ọsanabẹ.”
\p 
\v 28 Abi iJesu ọ rọ ngme se, osẹsẹ oyọli o ri abọ sha eni e legba.
\v 29 Irari khi eri ọ sẹsẹ ẹgbọ abi ọgbọ ni ọ lẹsẹ emini ọọ sẹsẹ.\f + \fr 7:29 \ft Li zẹ \fq iMak 1.22; iLuk 4.32\f*
\c 8
\s1 Ọmọse ashọmha
\r (iMak 1.40-45; iLuk 5.12-16)
\p 
\v 1 Abi iJesu ọ rọte ukhomhi ute tiemhile, ebubu ẹgbọ e bhale deba li.
\v 2 Ighọ ọmọse ashọmha ọghuo ọ bhale ya wugha iJesu odalo, ọọ li, “Ọnọmhuẹ, ini o ghọle ẹ, u dobẹ ya rẹ mhẹ ze.”
\v 3 IJesu ọ nise obọ-a ti ọli, ọọ li. “O ghọle mhẹ, khi ọni ọ ze.” Aghọaghọ ọni ọmọse ọ ze.
\v 4 IJesu ọọ li, “Khi gueyẹ ọgbọkhọghuo, ama ka ri egbe ẹ khasẹ ekpodalo-ugamhi eyi Ẹshinẹgba, ni u riẹlẹ iluasobo ni iMosisi ọọ a ke riẹlẹ ini a ri ọni efafe mu pfuasẹ.”\f + \fr 8:4 \ft Li zẹ \fq iLẹv 14.1-32\f*
\s1 Irudunga ni ọkhọli-okhuẹ ọ rọkhasẹ
\r (iLuk 7.1-10)
\p 
\v 5 Abi iJesu ọ rọ lo iKapanọmu le, ọkhọli-okhuẹ ni ọ mhẹsẹ na ekhọli-okhuẹ egbhuẹshe ọyi iRomu ọghuo ọ bhale ya lema li ikpaghiobọ.
\v 6 Ọọ li, “Ọnọmhuẹ, ọni ọọ ga mhẹ ọ ga yẹshi apfẹ ẹ ghu-a egbegbọ. Eri ọ guọghọ a.”
\p 
\v 7 IJesu ọọ li, “Mhi ya bhale ya rọli ze.”
\p 
\v 8 Ọni ọkhọli-okhuẹ ọọ li, “Ọnọmhuẹ, iiye, lẹsẹ ngme oni ungmemhi tsẹ, khi ọni ọọ ga mhẹ ọ ya ze. Irari khi mhia fu tẹ ni u wa bhale apfẹ oyẹmhẹ.
\v 9 Mhẹmhẹ oyẹmhẹ, mhi li mhọli ekhọli-okhuẹ eni e fu dọsẹ mhẹ, mhi li mhuẹ elese ni mhia mhẹsẹ na. Mhi kha gueyẹ ọna ọ ke lẹ, ọọ lẹ, mhiẹ ọlese ọ bhale, ọ bhale. Mhi khẹ ọni ọọ ga mhẹ ọ li ona, ọ li ọli.”
\p 
\v 10 Abi iJesu ọ rọ suọ emini ọni ọmọse ọ ngme, abọ e sha li. Ọọ eni ẹ deba li, “Abi o li mhi li gue ọli ẹ yẹ ẹ ena khi mhia mẹ irudunga onabi onana ghue ekẹ iZirẹni.
\v 11 Mhi gueyẹ ẹ khi ebubu ẹgbọ e ya rọte obini ovọ o te ẹ ngale ali obini ovọ o te ẹ lo eko, bhale ya nu Aburaamu ali Aziki ali iGiekọpu shitọ ukue na eghiele na iloghie\f + \fr 8:11 \ft Li zẹ \fq iLuk 13.29\f*.
\v 12 Ama ẹgbọ ni é khá lá iloghie, a ya pfi wẹ je ekẹ alo ebili ni e la ke viẹ, ẹẹ le akọ akọ.”\f + \fr 8:12 \ft Li zẹ \fq iMat 22.13; 25.30; iLuk 13.28\f*
\v 13 IJesu ọọ ọni ọkhọli-okhuẹ ọghọ, “Ke je khi o ya lighọ nẹ abi u li mhọli irudunga eghọ.” Ighọ ọni ọọ ga li ọ ze oni ẹghẹghẹ ni iJesu ọ la ngme ọli ighọ tee.
\s1 IJesu ọ ri ebubu ẹgbọ ze
\r (iMak 1.29-34; iLuk 4.38-41)
\p 
\v 14 Abi iJesu ọ rọ bhale apfẹ oyi iPita, ọ mẹ khi ọgọ iPita ni ọkpotso ọ yẹshi khi ọọ ghu ughuamhi iba.
\v 15 IJesu ọ ri obọ ti ọli, eni iba e lase ọli egbe le. Ọ vule ọ fẹli ọli epfẹse.
\p 
\v 16 Abi ogbọmhi o rọ mu ekẹ, ebubu ẹgbọ e wolọ eni e mhọli ayẹmhẹ ebe ọdọda bhale ghi iJesu. Ighọ iJesu ọ ri ungmemhi unu khu wẹ eni ayẹmhẹ ebe eghọ egbe ku a. Ọ gbo ri eni ẹẹ ghua nya ze.
\v 17 Eri a mẹ enana ni ungmemhi ni Azaya ọmekẹguele ọ ngme o bhale ya tsẹ; Ni ọọ,
\q1 “Lọlighuo ọ mie awa umha-ze,
\q2 ọ tsua ighuamhi eyawa ya kua.”\f + \fr 8:17 \ft Li zẹ \fq Aza 53.4\f*
\s1 Emini ideba-iJesu-kia o ya mie ọgbọ ọ rue
\r (iLuk 9.57-62)
\p 
\v 18 IJesu ọ mẹ olele ẹgbọ ni e le gasẹ ọli, ọọ e zẹ ni wẹwẹ e da je ukiẹkiẹ obini o kpọle oyi okẹ oniẹmhi iGalili.
\v 19 Ọsẹsẹ Ishi eyi iMosisi ọghuo ọ bhale deba li ọọ li, “Ọsẹsẹ, mhi ya debẹ ke je obiobini wa je kpa.”
\p 
\v 20 IJesu ọ sọli ọ, ọọ li. “Inyakọ e mhọli esẹ, ipfeli e mhọli eko, ama Omi Ọgbọ ọa mhọli ashini ọ de ukhomhi ẹ gbe.”
\p 
\v 21 Ọmọse olese ni ọ khi ọmọ odukhokho oyọli, ọ lu ọli, ọọ li, “Ọsẹsẹ, zẹ mhẹ kpẹ je apfẹ ya ri itamhẹ ni ọ ghu-a tọ ne.”
\p 
\v 22 IJesu ọ sọli ọ, ọọ li “Ke deba mhẹ, zẹ ni eni e ghu-a e ri eni e ghu-a tọ.”
\s1 IJesu ọ pfọmhise akpekpeli ukhomhi okẹ oniẹmhi
\r (iMak 4.35-41; iLuk 8.22-25)
\p 
\v 23 IJesu ọ lo elemhi ọkọ-okẹ oniẹmhi, eniyẹ odukhokho eyọli e li lo deba li.
\v 24 Utoghuo-kpe, akpekpeli oniẹmhi oo li oni ukhomhi okẹ oniẹmhi. Ukuku emhi o kpọle dẹnẹ ni oni ọkọ-okẹ oniẹmhi ọa rọ ku luẹ. Ama iJesu ọọ lesẹ-a
\v 25 Eniyẹ odukhokho eyọli e ya guise ọli le, ẹ ọli, “Ọnọmhuẹ, tsumhi anye! Awa ya pfua!”
\p 
\v 26 Ọọ wẹ, “Elọ o zẹ ni a rọ lina na ulishi, Eri irudunga oyẹẹ oo na bẹshi shẹ?” Ighọ ọ vule nu oni akpekpeli ngme, oni okẹ o de ma.
\p 
\v 27 Abọ e sha ẹgbọ nya ni e la aghọ, e mhila, “Ọgbọ nabisẹ ọnana ọ khi, egbegbi ozughu oyi okẹ oniẹmhi ali akpekpeli e ga suọ esọ ọ na li.”
\s1 IJesu ọ ri emọse ava eni e mhọli ayẹmhẹ ebe ze
\r (iMak 5.1-20; iLuk 8.26-39)
\p 
\v 28 Abi iJesu ọ rọ da je ukiẹkiẹ obini o kpọle oyi okẹ oniẹmhi iGalili obini iGadara, emọse ava ni e rọte atalimhi lasele e bhale deba li. Eni emọse ava ena e mhọli ayẹmhẹ ebe ni e yẹsẹ wẹ ngme ni o rẹwẹ nono ingme. Ẹgbọ ẹa ke gbudu rọte oni odẹ dọsẹ.
\v 29 Eni ayẹmhẹ ebe eghọ ni e la eni emọse egbe, e tsẹsẹ utoghuokpe, ẹ ọli, “Elọ e ku anye ali yẹyẹ gbe, yẹyẹ Omi Ẹshinẹgba? Eri u bhale ya nasẹ anye neni oni ẹghẹghẹ o ramhi?”
\p 
\v 30 Igulu ni e bu é la epfẹ aghọ le eminale.
\v 31 Ighọ eni ayẹmhẹ ebe eghọ e lema iJesu, ẹ ọli, “Ini u khu anye ya fiẹ, khu anye ya lo eni igulu eghọ egbe.”
\p 
\v 32 Ighọ iJesu ọọ, “A ke vu!” Ighọ e lasele ya lo eni igulu egbe. Eni igulu nya e na ya tiemhi esesọ oni ute, ya lo oni okẹ, e ghuloa.
\v 33 Emọse ni e ri eni igulu u kia, e na kua, e je ifui apfẹ ya guele emini a mẹ ali emini eni emọse ni e mhọli ayẹmhẹ ebe e mẹ.
\v 34 Ighọ ẹgbọ ni e la oni ẹoli nya e fiẹ lasele deba iJesu. Abi e rọ mẹ ọli, e lema li ọ kpẹkpẹ ọ lase wẹwẹ ekẹ le.
\c 9
\s1 IJesu ọ ri ọmọse ni ọ guọghọ-a ze
\r (iMak 2.1-12; iLuk 5.17-26)
\p 
\v 1 IJesu ọ̀ lo ọkọ-okẹ oniẹmhi, ọ́ da oni okẹ iGalili mu egbe pfi je ukiẹkiẹ obini o kpọle, ọ́ bhale apfẹ oyọli obini iKapanọmu.
\v 2 Emọse eghọ e tsua ọmọse ni ọ guọghọ-a shi iya bhale. Abi iJesu ọ rọ mẹ irudunga oyẹwẹ, ọọ ọni ọmọse ni ọ guọghọ-a, “Ri obọ shi udu, omimhẹ, a she ri olamhẹ topfa ẹ.”
\p 
\v 3 Ighọ esẹsẹ Ishi eyi iMosisi eghuo e nu egbe wẹ ngme, e liẹ, “Ọni ọmọse ọna ọ pfi unu-a!”
\p 
\v 4 IJesu ọ lẹsẹ usamhi ni ẹ sa, ọ mhila wẹ, “Elọ o zẹ ni a rọ sa isamhi ebe udu?
\v 5 Onoghuo o kẹlẹ mhẹ ya ngme ọni ọmọse nẹ? Ni mhi liẹ, ‘A she gbe olamhẹ kua nẹ,’ Ali ‘Vule ke kia?’
\v 6 Ama, ni a rọ lẹsẹ khi Omi Ọgbọ ọ mhuẹ afu elemhi ekẹ agbọ ni ọ rọ gbe olamhẹ kua na ọgbọ.” Ighọ, ọọ ọni ọmọse ni ọ guọghọ-a, “Vule, rue iya oyẹ u ke je apfẹ.”
\p 
\v 7 Ighọ ọni ọmọse ọ vule ọọ je apfẹ.
\v 8 Abi eni ebubu ẹgbọ e rọ mẹ ona, abọ e sha wẹ. E kuẹghiẹ Ẹshinẹgba ni ọ ri afu onana na ẹgbọ.
\s1 IJesu ọ lu iMatiu ọ deba luẹ
\r (iMak 2.13-17; iLuk 5.27-32)
\p 
\v 9 Abi iJesu ọ rọte aghọ je odalo, ọ mẹ khi ọmionoga ọghuo ni a lu iMatiu, ọ shitọ okholo ni a la miono oga. Ọọ li, “Deba mhẹ.” Ighọ ọ vule deba li.
\p 
\v 10 Abi iJesu ọ rọ la owa oyi iMatiu le eminale, emionoga eni e bu elese ali ena olamhẹ e bhale ya ku ma wẹ ọ, e ga nu ọli ali eniyẹ odukhokho eyọli le eminale.
\v 11 Abi ẹgbọ iFarisi eghuo e rọ mẹ ona, e mhila eniyẹ odukhokho eyọli, ẹẹ, “Elọ o zẹ ni ọsẹsẹ oyẹ ẹ ọ rọ nu emionoga ali ena olamhẹ ẹ le eminale?”\f + \fr 9:11 \ft Li zẹ \fq iLuk 15.1-2\f*
\p 
\v 12 IJesu ọ suọ ona, ọọ wẹ, “Ọni ọ toto ọa mhuẹ emini ọ ri ọbo ẹ li, ama ọni ọ́ọ́ to ọọ ye apfẹ ọbo.
\v 13 A ka wẹna emini a ri ona ngme, ikhi, ‘Ọa khi iluasobo e ghọle mhẹ, ama isomhelemhi’ Ọa khi ẹgbọ eni e pfuasẹ ne mhi bhale ya lu e mu pfi, ama ẹgbọ ena olamhẹ.”\f + \fr 9:13 \ft Li zẹ \fq iMat 12.7; Osia 6.6\f*
\s1 Omhila oyi ingme azumhi
\r (iMak 2.18-22; iLuk 5.33-39)
\p 
\v 14 Eniyẹ odukhokho eyi iJọni Ọni ọọ batazi ẹgbọ, e bhale deba iJesu, e mhila li, “Elọ o fẹ zẹ khi anye ali ẹgbọ iFarisi, khi anye ẹ pfi azumhi ni eniyẹ odukhokho eyẹ ẹa rọ pfi?”
\p 
\v 15 IJesu ọọ wẹ, “Emọle ọmọse ni ọọ rue ọmueshi ọnọgbọ e famhi ya mhuẹ iyese udu-a ini ọni ọọ rue ọmueshi ọ kie la wẹ iteva? Ẹghẹghẹ ọọ bhale ni a rọ ya rue ọni ọmọse ni ọọ rue ọmueshi ọnọgbọ iteva oyẹwẹ vu, ẹghẹghẹ aghọ e rọ tigbe ya ke pfi azumhi.
\p 
\v 16 “Ọgbọ ọa ya gbẹla ode onogbọ toma onodiọ, ini a mẹ ghọ, onodiọ oghọ o ya nyanọ-a toma onogbọ, o fia esẹ ni o ke fu nẹ shi ọ.
\v 17 U kẹ neta khi eri ọgbọ ọ ya ku onyọ onogbọ kulo akpaba ẹkuẹ ẹlamhi onodiọ,\f + \fr 9:17 \ft Akpaba oyi ẹkuẹ ẹlamhi ẹgbọ iJu e ku onyọ ọ shi.\f* ini a mẹ ghọ, eri oni akpaba o ya vẹ-a, oni onyọ o ku kua, oni akpaba onyọ o li opfu-a. Onyọ onogbọ a ku ẹ shi akpaba onogbọ, ẹghẹghẹ aghọ, oni onyọ ali oni akpaba onyọ e ga migha.”\fig Akpaba Onyọ|src="lb00145c.tif" size="col" loc="MAT 9.17" copy="TIF" ref="9.17"\fig*
\s1 Ọmọ ọmueshi ni ọ ghu-a ali ọkpotso ni ọa ze
\r (iMak 5.21-43; iLuk 8.40-56)
\p 
\v 18 Abi oni ungmemhi o kie la iJesu unu, ọkhẹmhuẹ iJu ọghuo ọ bhale ya wugha li odalo, ọọ li, “Kpẹkpẹ bhale ya ri obọ ti omimhẹ ni ọ lẹsẹ ghu-a, ni ọ guale.”
\v 19 Ighọ iJesu ọ vule deba li vu, eniyẹ odukhokho eyọli e li deba li.
\p 
\v 20 Ighọ ọkpotso ọghuo ni ọlia e she ku ọli egbe ramhi ikpe igbẹva ọ rọte ukhokho ti mama iJesu, ọ ri obọ ti ọli esọ ode.
\v 21 Itobọ khi ọ she ngme ọli shi udu khi, “Mhi kha da lẹsẹ ri obọ ti iJesu ode tsẹ ne, mhi ya ze.”
\p 
\v 22 Ighọ iJesu ọ mu egbe nyenẹ, ọ mẹ ọli, ọọ li, “Kpotso khi ke zẹ ni ulishi o muẹ irudunga ni u mhuẹ o she rẹ ze.” Aghọaghọ ọni ọkpotso ọ ze.
\p 
\v 23 Abi iJesu ọ rọ ramhi owa oyi ọni ọkhẹmhuẹ, ọ bhale ya ẹ khi ẹgbọ e la aghọ. Ee viẹ ọni ọmueshi ni ọ ghu-a eghọ. Aghọ oo li nyoghoo.
\v 24 Ọ gueyẹ ọgbọkpa ọ lase aghọ le, khi ọni ọmueshi ọa ghu ne khi eri ọ lesẹ-a. Eni ẹgbọ e suọ ungmemhi ni ọ ngme, ee gia li.
\v 25 Eni ẹgbọ e fiẹ je olase se, iJesu ọ lo elemhi oni owa, ọ mu ọni ọmueshi obọ, ọni ọmueshi ọ vule.
\v 26 Okeke oni ingme ona o gbhiaku asha kpa oni ẹdẹli.
\s1 IJesu ọ khueghie ezalo ava alo-a
\p 
\v 27 IJesu ọ ke rọte aghọ vu je odalo, ezalo ava e deba li. Ee tsẹsẹ lema li, e liẹ ọli, “Mhuẹ isomhelemhi na anye, omi iDefidi.”
\p 
\v 28 Abi iJesu ọ rọ lo elemhi oni owa, eni ezalo ava e bhale deba li. Ọ mhila wẹ, “A miesuọ khi mhi ya dobẹ rẹ ẹ ze?”
\p Ẹ kẹ ọli, “Guẹguẹguẹ.”
\p 
\v 29 Ighọ iJesu ọ ri obọ ti wẹ alo, ọọ wẹ, “Alo eyẹ ẹ e khueghie-a abi a mhuẹ irudunga.”
\v 30 Ikpamhi alo eyẹwẹ e khueghie-a. IJesu ọ tse agua yẹ wẹ e khi gueyẹ ọgbọkhọghuo emini a mẹ.
\v 31 Ama asha ni e ramhi kpa, eri e gueyẹ ẹgbọ, e gue ingme oyi iJesu yẹ ẹgbọ asha kpa.
\s1 IJesu ọ ri ungmenu ze
\p 
\v 32 Eni emọse e vu, a tsua ọmọse ọghuo ni ọ mhuẹ ayẹmhẹ ebe bhale, ni ọa li ngme unu.
\v 33 IJesu ọ khu ọli oni ayẹmhẹ ebe oghọ egbe ya lase, ọni ọmọse ọ ngme. Abọ e sha ọgbọkpa e liẹ, “Anye ẹa kpẹ mẹ ingme onana ghue ekẹ iZirẹni.”
\p 
\v 34 Ama ẹgbọ iFarisi e liẹ khi oghie ọyi iyẹmhẹ ebe ọ ri ekpabọ na li. Lọli o zẹ ni ọ rọ dobẹ ẹ khu ẹgbọ ayẹmhẹ ebe egbe-a.\f + \fr 9:34 \ft Li zẹ \fq iMat 10.25; 12.24; iMak 3.22; iLuk 11.15\f*
\s1 Egbikanya eyi Ẹshinẹgba ẹa bu
\p 
\v 35 IJesu ọ kia la ẹoli khi ẹoli sẹsẹ ungmemhi oyi Ẹshinẹgba elemhi owa ugamhi eyẹwẹ, ọ tse abọ usomhi onete oyi Eghiele oyi Ẹshinẹgba. Ọ ri ẹgbọ ni e mhuẹ ighuamhi khi ighuamhi i ze.\f + \fr 9:35 \ft Li zẹ \fq iMat 4.23; iMak 1.39; iLuk 4.44\f*
\v 36 Abi ọ rọ mẹ eni ebubu ẹgbọ, elemhi wẹ e lala li irari khi udu oyẹwẹ ọa sheshe itobọ khi ẹa mhọli ọni ọọ kpaghiẹ wẹ obọ, abi isumha ni ẹa mhuẹ ọrẹwẹkia.\f + \fr 9:36 \ft Li zẹ \fq iNọba 27.17; 1 Ighie 22.17; 2 Okhẹ 18.16; Ezik 34.5; iMak 6.34\f*
\v 37 Ọ gueyẹ eniyẹ odukhokho eyọli, “Oni ikhiẹsẹ oo gbẹdi gba, ama khi eni ẹ khiẹsẹ wẹ, ẹa bu.”
\v 38 “A sọ iromhi, ni Ẹshinẹgba ọni ọ mhuẹ ikhiẹsẹ, ni ọ ghie eni e ya khiẹsẹ oni ikhiẹsẹ fiẹ lasele.”\f + \fr 9:38 \ft Li zẹ \fq iLuk 10.2\f*
\c 10
\s1 IJesu ọ ghie ighiusomhi na kẹẹ ogbava eyọli fiẹ
\r (iMak 3.13-19; iLuk 6.12-16)
\p 
\v 1 IJesu ọ lu eniyẹ odukhokho ogbava eyọli kugbe. Ọ ri afu na wẹ, e ke ya khu iyẹmhẹ ebe ọdọda ẹgbọ egbe-a, e gbo ri ẹgbọ ni e mhuẹ ighuamhi ọdọda ke ze.
\p 
\v 2 Eva eyi eni ighiusomhi na kẹẹ ogbava na. Ọni ododẹ khi ISamọ ni a gbolo o lu iPita, ali inyọghuo ọli, Aduru. IJemhisi ali inyọghuo ọli ni a lu iJọni ni e khi imi iZebedi.
\v 3 IFilipu ali iBatolomiu. ITọmọsi ali iMatiu ni e khi emionoga. IJemhisi omi Afeusi ali iTadiusi.
\v 4 ISamọ ni ingme o ghọ mu egbe ali iJudasi Isikarọti ni ọ ri iJesu dẹ.
\s1 Usomhi ni a ghie eni etuogbava
\r (iMak 6.7-13; iLuk 9.1-6)
\p 
\v 5 IJesu ọ ghie eniyẹ odukhokho ogbava ena fiẹ, ọ tse agua yẹwẹ, ọọ wẹ, “A khi je ẹoli oyi ẹgbọ iJẹta wẹkhi ẹoli na ekẹ iSameria.
\v 6 Ochoghọ a lẹ deba ẹgbọ iZirẹni ni e li abi isumha ni e waa.
\v 7 Abi a liẹ ke lẹ, a ke tse abọ usomhi ona-yẹwẹ, a liẹ wẹ, ‘Eghiele oyi Ẹshinẹgba o she ti bhale.’
\v 8 A ri ẹgbọ ni e mhuẹ ighuamhi ze, a ri eni e mhuẹ efafe ze, a guise eni e ghu-a le, eni e mhuẹ ayẹmhẹ ebe, a khu wẹ ẹwẹ egbe lasele. Afuẹ a ri eni ekpabọ ena na ẹ, a rẹ wẹ kpaghiẹ ẹgbọ obọ afuẹ, a khi mie ifata shi ọ.
\v 9 Abi a liẹ lẹ ena, a khi tsua ukpaghọ okhọghuo shi ọmọ-emhi.
\v 10 A khi tsua ẹkuẹ pfi sọ, wẹkhi itsua na rọ sọ elese, wẹkhi ekuẹ ni a sọ, wẹkhi ukpokpo na rọ a to ọkpọ, irari khi asha ni ọgbọ ọ la gbe aghọ ọ te ẹ le.\f + \fr 10:10 \ft Li zẹ \fq 1 iKọri 9.14; 1 iTimo 5.18\f*
\p 
\v 11 “Ẹoli oni a da bhale kpa, a kushi ayi ọgbọ nọ da kpẹ abọ mie ẹ, ramhi ẹghẹghẹ ni a ya rọte aghọ vu.
\v 12 Neni a ya sọ ukhomhi owa okhọghuo, a kpe liẹ, ‘Opfọmhẹ o la oni owa ona.’
\v 13 Ini ẹgbọ ne la oni owa e kpe abọ mie ẹ, opfọmhẹ oyẹẹ o ka nu wẹ la, ama, ini ẹa mie ẹ, opfọmhẹ oyẹẹ o gbo nyenẹ deba ẹ.
\v 14 Ini a bhale ẹoli, khi ẹgbọ ne la oni ẹoli ẹa da kpe abọ mie ẹ ne, a kpe abọ ọ-a na wẹ ini a te ọ fiẹ lase.\f + \fr 10:14 \ft Li zẹ \fq Ika 13.51\f*
\v 15 Ogbẹlẹ iguẹzọ, mhi gueyẹ ẹ khi Ẹshinẹgba ọ ya mhọli isomhelemhi na ẹgbọ iSodomu ali iGomora dọsẹ oni ẹoli oghọ.\f + \fr 10:15 \ft Li zẹ \fq iMat 11.24; Igbae 19.24-28\f*\f + \fr 10:15 \ft Li zẹ \fq iLuk 10.4-12\f*
\v 16 A sato khi eri mhi ghie ẹ fiẹ lase abi isumha ne la ifuabọ idumhi. Irarighọ, a zẹ ni a lẹsẹ ingme abi ẹnyẹ, ama a mhuẹ ikuegbe-a abi anekhukhu.\f + \fr 10:16 \ft Li zẹ \fq iLuk 10.3\f*
\s1 Okhọli ni a ya mu vule shi ẹ ọ
\r (iMak 13.9-13; iLuk 21.12-17)
\p 
\v 17 “A mu egbe ẹ tsukẹ, irari khi ẹgbọ e ya mu ẹ bhale ikọtu, odalo egbhali ni ẹẹ sọ ẹzọ. E gbe ẹ itali elemhi owa ugamhi eyẹwẹ.
\v 18 E ya ri itobọ eva oyẹmhẹ muno e bhale deba igọvunọ ali enighie, ni a gue usomhi onete oyẹmhẹ yẹ wẹ. A gbo pfi ọtsẹlẹ oyẹmhẹ yẹ ẹgbọ iJu ali ẹgbọ iJẹta.
\v 19 A khi yele abi a ya ngme ali abi a ya sọ wẹ, ini e muno ẹ bhale agbala ẹzọ. Irari khi emini a ya ngme o ya bhale unu oyẹ ẹ ẹghẹghẹ ni a nono ọli shi.
\v 20 Irari khi ingmemhi ni a ya ngme, ẹa ya khi eyẹ ẹ. Ayẹmhẹ-nọ-pfuasẹ oyi Ẹshinẹgba ni ọ khi ita ẹ, ọ ya ri ungmemhi ni a ke ngme shi ẹ unu.\f + \fr 10:20 \ft Li zẹ \fq iMak 13.9-11; iLuk 12.11-12; 21.12-15\f*
\p 
\v 21 “Ẹghẹghẹ na ngme ena, ẹgbọ e ya ri inyọghuo wẹ bhale ni a gbe-a, ita eniyẹ e wolọ imi wẹ bhale na gbolo-a, ighọ eniyẹ e li ya rue itawẹ bhale na gbe-a.\f + \fr 10:21 \ft Li zẹ \fq iMak 13.12; iLuk 21.16\f*
\v 22 Ẹgbọ kpa e ya ke biselemhi ẹ shi irari oyẹmhẹ. Ama ọgbọ ni ọ da mu irudunga oyọli mhuẹ ramhi ukpẹsẹ ne, lọli a ya mie pfuese.\f + \fr 10:22 \ft Li zẹ \fq iMat 24.9,13; iMak 13.13; iLuk 21.17\f*
\v 23 Ini a la asheghuo mu okhọli vule shi ẹ ọ, a na je ẹoli olese. Mhi zẹ ẹ lẹsẹ khi, aa ya gbe akanya ona pfo ne ekẹ iZirẹni neni Omi Ọgbọ ọ nyenẹ egbe ẹ bhale.
\p 
\v 24 “Ọmọ odukhokho ọa lẹsẹ dọsẹ ọga ọyọli, wẹkhi eri ọni ọọ ga ọgbọ ọ ya fu dọsẹ ọga ọyọli.\f + \fr 10:24 \ft Li zẹ \fq iLuk 6.40; iJọn 13.16; 15.20\f*
\v 25 Ọmọ odukhokho ọ dobẹ ya li abi ọga ọyọli, ọni ọọ ga ọgbọ ọ ya dobẹ li abi ọga ọyọli. Ini a lu ọdapfẹ iBezebọ, sẹẹ a ke bẹshi ẹ lu eni e la oni ọmhuẹ-apfẹ oyọli.\f + \fr 10:25 \ft Li zẹ \fq iMat 9.34; 12.24; iMak 3.22; iLuk 11.15\f*
\s1 Ọni a ya ke na ulishi oyọli
\r (iLuk 12.2-7)
\p 
\v 26 “Itobọ ighọ a khi zẹ ni ulishi o mu ẹ irari khi aa mẹ emini a gba khukhu ni ọa ya khueghie a, wẹkhi eri a mẹ emini o sheli ni ọa ya lasele.\f + \fr 10:26 \ft Li zẹ \fq iMak 4.22; iLuk 8.17\f*
\v 27 Emini mhi gueyẹ ẹ ẹliyọsẹ a ngme ọli lasele ini ogbe o gbe-a. Ungmemhi ni a bẹna gueyẹ ẹ, a la ukhomhi owa ngme ọli lase ni ẹgbọ e suọ gboo.
\v 28 A khi na ulishi ẹgbọ ni o khia khi idiegbe e lẹsẹ dobẹ ya gbe-a, ni ẹa dobẹ ya pfuse ọgbọ ayẹmhẹ-a. Ama a na ulishi oyi Ẹshinẹgba nọ kha gbe-a se ọ gbo mhuẹ ekpabọ rọ ya pfuse ayẹmhẹ-a elemhi ilimhi iriẹriẹ.
\v 29 U lẹsẹ khi ukpaghuo a ri ipfeli otuava dẹ? Ama aa mẹ ọngẹwẹ ni ọ ya ghu-a ni Ẹshinẹgba ọa ya lẹsẹ.
\v 30 Ẹshinẹgba ọ she leli egbegbi itsu ni e la ẹ ukhomhi nya.
\v 31 Itobọ ighọ, a khi zẹ ni ulishi o mu ẹ, irari khi a mu ẹloe dọsẹ ipfeli ni e bububu.
\s1 Eni e migha na iJesu ali eni e kie ọli
\r (iLuk 12.8-9)
\p 
\v 32 “Ọgbọ ni ọ da gue ungmemhi oyẹmhẹ yẹ ẹgbọ ne, mhi ya li gue ingme oyọli ye Itamhẹ ni ọ la iloghie.
\v 33 Ama ọnini ọ da la ukpẹloe ẹgbọ kie mhẹ, mhi ya li kie ọli ukpẹloe oyi Itamhẹ na obini iloghie.\f + \fr 10:33 \ft Li zẹ \fq 2 iTimo 2.12\f*
\s1 IJesu ọa ri opfọmhẹ bhale ama okemhi
\r (iLuk 12.51-53; 14.26-27)
\p 
\v 34 “A khi sa khi opfọmhẹ mhi rọ bhale ekẹ agbọ. Mhi aa rọ opfọmhẹ bhale, ama ọgbhọrọ.
\v 35 Eri mhi bhale ya to okhuẹ na
\q1 “ ‘Ọmọse ali itali,
\q2 ọkpotso ali inyọli,
\q1 ọsamọ ali inyọdọli.
\q1 
\v 36 Unuẹkpẹ oyi ọgbọ,
\q2 ebe ọli e la.’\f + \fr 10:36 \ft Li zẹ \fq iMika 7.6\f*
\p 
\v 37 “Ọgbọ ni ọ da nono ingme oyi ita okekhi inyọ dọsẹ ingme oyẹmhẹ ne, ọa ya dobẹ khi ọmọ odukhokho ọyẹmhẹ. Ọgbọ ni ọ da nono ingme oyi omi ọli dọsẹ mhẹ ne, ọa ya dobẹ khi ọmọ odukhokho ọyẹmhẹ.
\v 38 Ọgbọ ni ọa da kpha apfida oyọli tsua ni ọ ke deba ẹtẹ-awẹ oyẹmhẹ ne, ọa ya dobẹ khi ọmọ odukhokho ọyẹmhẹ.\f + \fr 10:38 \ft Li zẹ \fq iMat 16.24; iMak 8.34; iLuk 9.23\f*
\v 39 Ọni ọ da mu agbọ oyọli mhuẹ gagaga ne, o mema ya de ọli obọ-a, ama ọni rue agbọ oyọli obọ-a shi ekẹ itobọ oyẹmhẹ ne, ọ ya mẹ eleli agbọ oyọli.\f + \fr 10:39 \ft Li zẹ \fq iMat 16.25; iMak 8.35; iLuk 9.24; 17.33; iJọn 12.25\f*
\s1 Eleli
\r (iMak 9.41)
\p 
\v 40 “Ọgbọ ni ọ da kpe abọ mie ẹ ne, mhẹmhẹ ọ kpe abọ mie. Ọni ọ da kpe abọ mie mhẹ, ọni ọ ghie mhẹ ọ kpe abọ mie.\f + \fr 10:40 \ft Li zẹ \fq iMak 9.37; iLuk 9.48; 10.16; iJọn 13.20\f*
\v 41 Ọgbọ ni ọ da kpe abọ mie ọmekẹguele ọyi Ẹshinẹgba ne, ọ ya mhuẹ isomhopfa onayi ọmekẹguele. Ọni ọ da kpe abọ mie ọgbọ ni ọ pfuasẹ ne irari khi ọ da khi ọgbọ ni ọ pfuasẹ, ọ ya mhuẹ eleli oyi ọgbọ ni ọ pfuasẹ.
\v 42 Ini ọgbọkhọghuo ọ diẹ amẹ ni e pfọmhẹ na ẹgbọ eni ẹa mu ẹloe ena da ne, irari khi e da khi eniyẹ odukhokho eyẹmhẹ, mhi gue ọ yẹ ẹ guẹguẹguẹ khi eleli oyọli ọa ya de ọli obọ a.”
\c 11
\s1 IJesu ali iJọni Ọni ọọ batazi ẹgbọ
\r (iLuk 7.18-35)
\p 
\v 1 Abi iJesu ọ rọ gueyẹ eniyẹ odukhokho ogbava eyọli emini e ya riẹlẹ se, ọ je ẹoli ni e la ekẹ iGalili ya sẹsẹ, ọ gbolo tse abọ oni usomhi onete.
\p 
\v 2 Abi iJọni Ọni ọọ batazi ẹgbọ ọ rọ la owa ighumha suọ ikanya ni iKirisiti ọọ gbe, ọ ghie eniyẹ odukhokho eyọli ghi ọli,
\v 3 E lẹ ya lina mhila li. “Yẹyẹ u khi ọni iJọni ọ ngme khi ọ ya bhale, abi anye ri ẹloe shi ekẹ ke khẹ ọgbọ ọlese?”
\p 
\v 4 IJesu ọ sọ wẹ ọ, ọọ wẹ, “A nyenẹ egbe ya gueyẹ iJọni emini a suọ ni a mẹ.
\v 5 Ezalo ẹẹ khueghie alo-a, eni e guọghọ awẹ-a, e vule ẹẹ kia, a ri eni e mhuẹ ighuamhi ẹkuẹ idiegbe ọdọda ze, elesọ ẹẹ suọ esọ, ẹgbọ ni e ghu-a, a guise wẹ le. A gbolo ẹ tse abọ usomhi onete yẹ ẹgbọ eni ẹa mhuẹ.\f + \fr 11:5 \ft Li zẹ \fq Aza 35.5-6; 61.1\f*
\v 6 Ikhivọsẹ o khi na ọgbọ ni ọa mhọli akhọkhọmhẹ shi ingme oyẹmhẹ!”
\p 
\v 7 Eniyẹ odukhokho eyi iJọni ee vu se, iJesu ọọ ngme ingme oyi iJọni khasẹ eni e legba. Ọ mhila wẹ, ọọ. “Abi a rọ fiẹ je ọdagbe ifufu ni a rọ ya bino iJọni, ọgbọ nabisẹ a dabi khi a ya mẹ? Ebuli ifulọ ni akpekpeli ọ pfi ẹ nga pfi ẹ tiemhi a dabi khi a ya mẹ?
\v 8 Ini ọa khi ighọ shọ, elọ a dabi khi a ya mẹ abi a rọ fẹ fiẹ lase? Ọmọse ni ọ sọ itsua eni e somhi otse a sa khi a ya mẹ? Iiye o! Ẹgbọ eni ẹẹ sọ itsua eni e somhotse, apfẹ oyi oghie ẹẹ la.
\v 9 Elọ a fẹ fiẹ lase khi a ya mẹ shọ? Ọmekẹguele? Guẹguẹguẹ, ama mhi gueyẹ ẹ, ọni ọ gbo fu dọsẹ ọmekẹguele a mẹ.
\v 10 IJọni ọ khi ọni ọgbọ ni Ebe-no-pfuasẹ o ngme ingme oyọli, ni Ẹshinẹgba ọ la liẹ,
\q1 “ ‘Mhi ya kpẹ ghie aghiusomhi ọyẹmhẹ ralo nẹ,
\q2 ni ọ ya khueghie odẹ-a nẹ.’\f + \fr 11:10 \ft Li zẹ \fq iMala 3.1\f*
\m 
\v 11 Abi o li mhi li gue ọli yẹ ẹ khi, iJọni ọ fu dọsẹ ọgbọkpa ni ọ la agbọ ona ghue, ama, ọgbọ ni ọ ga kpọkẹ nya obini Eghiele oyi Ẹshinẹgba, ọ fu dọsẹ ọli.
\v 12 Rọte ẹghẹghẹ oyi iJọni Ọni ọọ batazi ẹgbọ ya ramhi ogbe na amo, Ẹshinẹgba ọ te ẹ ri ikakabọ mhọli omhẹsẹ oyọli shi agbọ oyi ẹgbọ, ama ikakabọ ẹgbọ e ke rọ ọ lo ọ.
\v 13 Irari khi emekẹguele nya ali Ishi eyi iMosisi, e mẹ guele shi ekẹ ramhi ẹghẹghẹ oyi iJọni.\f + \fr 11:13 \ft Li zẹ \fq iLuk 16.16\f*
\v 14 Ini a ya lama shi ọ, iJọni ọ khi ọni Elaja ni ẹ khi ọ ya nyenẹ egbe bhale.\f + \fr 11:14 \ft Li zẹ \fq iMala 4.5; iMat 17.10-13; iMak 9.11-13\f*
\v 15 A mhọli esọ, a suọ emini mhia gueyẹ ẹ, ni a rọli gbe akanya.
\p 
\v 16 “Elọ mhi ri agbhotu ona ya khọkhọ? Eri e li abi ikuku eniyẹ ni e shitọ epfepfẹ oki ni e lu egbe wẹ,
\q1 
\v 17 “ ‘Anye pfi ofele na ẹ,
\q2 aa lama gbe ishimhi,
\q1 anye to uwolo
\q1 ni a rọ viẹ olimhi shi ẹ ọ,
\q2 ama aa lama viẹ.’
\m 
\v 18 Abi iJọni ọ rọ bhale, eri ọọ pfi azumhi, ọa lama da onyọ, irarighọ ẹgbọ e liẹ khi, ‘Ayẹmhẹ Ọkphaghiẹ oo nasẹ ọli.’
\v 19 Ama Omi Ọgbọ ọ ke bhale, ọọ le ọọ da, ẹgbọ kpa e kẹ liẹ khi, ‘Ọgbọ unu-emhi ali ọdonyọ ọ khi, ni ọ nu emionoga ali ena olamhẹ ẹ mu ọmọle.’ Emini Ẹshinẹgba ọọ riẹlẹ, o ri ilẹsingme oyọli ẹ khasẹ.”
\s1 Emini ẹoli ni ẹa lama mu pfi ẹẹ mẹ
\r (iLuk 10.13-15)
\p 
\v 20 Ighọ iJesu ọ li zẹ ẹmuẹbe na ẹgbọ ni e la ẹoli ni ọ la gbe ikanya ọnyaloa ebubu eyọli, itobọ khi ẹa mu pfi, ọọ li.
\v 21 “Epfua o khi nẹ, iKorazi! Epfua o khi nẹ, iBẹtisaida! Irari khi ini ikanya ọnyaloa ni a gbe ifui ẹoli eyẹ ẹ khi a li gbe wẹ iTai ali iSidọni lọ, e kha she viẹ osoli na egbewẹ shi olamhẹ eyẹwẹ, e te olamhẹ eyẹwẹ mu pfi agbọagbọ.\f + \fr 11:21 \ft Li zẹ \fq Aza 23.1-18; Ezik 26.1--28.26; iJọẹ 3.4-8; Emọ 1.9-10; iZaka 9.2-4\f*
\v 22 Ama mhi gueyẹ ẹ khi, o ya somhi iTai ali iSidọni egbe dọsẹ ẹ, ogbẹlẹ isọ-ẹzọ
\v 23 Yẹyẹ iKapanọmu, eri a nono ni a ya yasẹ ẹ nga idane ramhi irarogbe? Iiye o! Eri a ya pfi ẹ tiemhi ọọkẹ ilimhi iriẹriẹ. Irari khi ini ọnyaloa ni a gbe khasẹ ẹ khi a gbe wẹ ekẹ iSodomu lọ, o kha la ọ ramhi amo.\f + \fr 11:23 \ft Li zẹ \fq Aza 14.13-15; Igbae 19.24-28\f*
\v 24 Ama mhi gueyẹ ẹ khi o ya somhi iSodomu egbe dọsẹ ẹ, ogbẹlẹ isọ-ẹzọ.”\f + \fr 11:24 \ft Li zẹ \fq iMat 10.15; iLuk 10.12\f*
\s1 Bhale deba mhẹ ni u mhọli iyẹmhẹa
\r (iLuk 10.21-22)
\p 
\v 25 Ẹghẹghẹ aghọ iJesu ọ liẹ, “Ita, Ọnọmhuẹ, ni ọ mhuẹ ekẹ ali ukhuli, mhi tsẹ uwegbe khi emini u rọ sheli na eguebe, ali eni e fialo-a, khi u rẹwẹ khasẹ ẹgbọ ni ẹa mu ẹloe.
\v 26 Ighọ, Ita, ina o li ghọle ẹ shi.
\p 
\v 27 “Itamhẹ ọ she ri emhikpa nga mhẹ obọ. Ọgbọkhọghuo ọa la ọ, ni ọ lẹsẹ ọni Ọmọ, sẹ ni Ita. Ọgbọkhọghuo ọa la ọ ni ọ lẹsẹ Ita sẹ ni ọni Ọmọ, ali eni ọni Ọmọ ọ lama ri ọni Ita khasẹ.\f + \fr 11:27 \ft Li zẹ \fq iJọn 3.35; 1.18; 10.15\f*
\p 
\v 28 “A bhale deba mhẹ, ẹẹ nya ni a tsua itsua ni ẹẹ khọsẹ ẹ, mhi ya ri iyẹmhẹa na ẹ.
\v 29 A ri egbe mie emini mhiẹ a ke riẹlẹ, a rọte obọ oyẹmhẹ wẹna, itobọ khi mhii pfọmhẹ gba, ali khi udu oyẹmhẹ o mhọli iriegbe-tiemhile, ni a mhuẹ iyẹmhẹa.\f + \fr 11:29 \ft Li zẹ \fq iJere 6.16\f*
\v 30 Irari khi emini mhia liẹ a riẹlẹ oni o zẹ ẹ riẹlẹ yẹghẹlẹ lọ, ali khi eri itsua eyẹmhẹ ee fuẹ.”
\c 12
\s1 IJesu ọ khi Ọnọmhuẹ ọyi ẹlẹ iyẹmhẹa
\r (iMak 2.23-28; iLuk 6.1-5)
\p 
\v 1 Ẹghẹghẹ ni a ngme ena, iJesu ọ rọte ifui ishemhi iakpa dọsẹ ẹlẹ iyẹmhẹa. Okiamhi oo gbe eniyẹ odukhokho eyọli. Ighọ e li bẹ eni iakpa, e le wẹ.\f + \fr 12:1 \ft Li zẹ \fq iDẹut 23.25\f*
\v 2 Abi ẹgbọ iFarisi e rọ mẹ ona, ẹ ọli, “Ghe khẹ! Eniyẹ odukhokho eyẹ ẹẹ riẹlẹ emini Ishi eyi iMosisi ọa lama shi a riẹlẹ ẹlẹ iyẹmhẹa.”
\p 
\v 3 Ọ sọ wẹ ọ, ọọ, “Aa she kpe zẹ emini iDefidi ọ riẹlẹ abi okiamhi o rọ gbe ọli ali apfọli?
\v 4 Eri ọ lo elemhi owa oyi Ẹshinẹgba, lọli ali apfọli, e ya rue ibulẹdi oni o pfuasẹ le, ni ushi ọa lama shi e le. Oni ibulẹdi ona, ekpodalo-ugamhi eyi Ẹshinẹgba tsẹ, e lẹsẹ le ọli.\f + \fr 12:4 \ft Li zẹ \fq iLẹv 24.9\f*\f + \fr 12:4 \ft Li zẹ \fq 1 iSam 21.1-6\f*
\v 5 Abi khi aa rọte ebe ushi iMosisi zẹ ọli khi ekpodalo-ugamhi eyi Ẹshinẹgba ni e la Owa Oyi Ẹshinẹgba, ee gbe ushi-a ogbẹlẹ iyẹmhẹa, ama ọgbọ ọa rọ mu ota sọ wẹ?\f + \fr 12:5 \ft Li zẹ \fq iNọba 28.9-10\f*
\v 6 Ama mhi gueyẹ ẹ khi ọgbọ ni ọ fu dọsẹ Owa Oyi Ẹshinẹgba ọ la ana.
\v 7 Ini a lẹsẹ emini a ri oni ungmemhi ona ngme shi Ebe-no-pfuasẹ lọ, ni ọọ, ‘Ilẹlemhi o ghọle mhẹ, ọa khi iluasobo,’ aa kha ke pfa ẹzọ mu eni ẹa lue.\f + \fr 12:7 \ft Li zẹ \fq iMat 9.13; Osia 6.6\f*
\v 8 Irari khi mhẹmhẹ Omi Ọgbọ mhi khi Ọnọmhuẹ ọyi ogbẹlẹ iyẹmhẹa.”
\s1 IJesu ọ ri ọmọse ni obọ oyọli o chẹghẹlẹ-a ze
\r (iMak 3.1-6; iLuk 6.6-11)
\p 
\v 9 Abi iJesu ọ rọte aghọ vu, ọ lo elemhi owa ugamhi oyẹwẹ.
\v 10 Ighọ ọmọse ọghuo ni ọ chẹghẹlẹ obọ oghuo-a, ọ la akaghọ. Ẹgbọ eghuo e la aghọ ni e nono ni wẹwẹ e mu ingme shi iJesu egbe, ighọ e mhila li. Ẹ ọli, “O fẹ ti ni a ri ọgbọ ze ẹlẹ iyẹmhẹa?”
\p 
\v 11 IJesu ọọ wẹ, “Ini ọngẹẹ ọ fẹ mhọli osumha, ni ọ rọ de pfilo atekẹ ẹlẹ iyẹmhẹa, wa a ya fẹ mu ọli ọ lasele?\f + \fr 12:11 \ft Li zẹ \fq iLuk 14.5\f*
\v 12 Ọgbọ ọ mu ẹloe dọsẹ osumha! Irarighọ, Ishi eyi iMosisi o lama shi ọ, ọgbọ ọ riẹlẹ onete ogbẹlẹ iyẹmhẹa.”
\p 
\v 13 Ighọ ọọ ọni ọmọse ni ọ chẹghẹlẹ obọ oghuo a eghọ, “Nise obọ oyẹ-a.” Ighọ ọ nise ọli-a. Oni obọ o na ya to abi onokpọle
\v 14 Ighọ eni ẹgbọ iFarisi e fiẹ ya ye ugbamhi abi e li ya gbe iJesu-a.
\s1 Ọni ọọ ga ni Ẹshinẹgba ọ zẹ
\p 
\v 15 Abi iJesu ọ ke rọ lẹsẹ ugbamhi ni e gba, ọ rọte aghọ vu je oboese, ebubu ẹgbọ e deba li. Ọ ri eni e mhọli umha-ze nya ze.
\v 16 Ọ tse agua yẹ wẹ e khi gueyẹ ẹgbọ ọni lọli khi.
\v 17 Eri a ri ona ri ungmemhi ni Azaya ọmekẹguele ọ ngme bhale ya tsẹ, ni ọ la liẹ,
\q1 
\v 18 “Ọni ọọ ga oyẹmhẹ
\q1 ni mhi zẹ na,
\q2 ọni mhi nono ingme oyọli,
\q2 ni ọ ri egbe ẹ mu mhẹ,
\q1 mhi ya ri Ayẹmhẹ oyẹmhẹ
\q1 shi ọli egbe,
\q2 ọ ya ri iguẹ-sọ-ẹzọ oyẹmhẹ
\q2 khasẹ ishishi nya.
\q1 
\v 19 Ọa ya nu ẹgbọ wola
\q1 wẹkhi eri ọ ya tsẹsẹ
\q2 ni ọgbọ suọ ifui apfẹ.
\q1 
\v 20 Ọ ya kuegbe-a
\q1 nu eni ẹa mhuẹ ekpabọ ngeli,
\q2 abi a li kuegbe-a mu ọakpa
\q2 ni akpekpeli o pfigbe vule.
\q1 Ọ ya lẹ elemhi
\q1 eni ẹẹ nono ikpaghiobọ,
\q2 abi ọgbhali ọa liẹ la apfẹ
\q2 ni amẹ o gbe erali
\q2 ni o la umutse pfuse-a,
\q1 ya ramhi ni ọ rọ
\q2 ri iguẹ-sọ-ẹzọ leghie.
\q1 
\v 21 Itobọ ighọ ẹgbọ iJẹta nya
\q2 e rọ regbenga eva oyọli.”\f + \fr 12:21 \ft Li zẹ \fq Aza 42.1-4\f*
\s1 IJesu ali iBezebọ
\r (iMak 3.20-30; iLuk 11.14-23)
\p 
\v 22 Ighọ ẹgbọ eghuo e rue ọmọse ọghuo ni ọ mhọli ayẹmhẹ obe bhale ghi iJesu. Ọ zalo ọ gbo khi ungmenu. IJesu ọ ri ọni ọmọse ze. Ọọ ngme, ọ gbolo ẹ mẹ ekẹ.
\v 23 Ighọ abọ e sha eni ẹgbọ nya, e mhila, e liẹ, “Abi khi iJesu ọna ọ khi Ọni Ọmiepfuese omi iDefidi ni ẹ khi ọ ya bhale?”
\p 
\v 24 Abi ẹgbọ iFarisi e rọ suọ ona, e kẹ, “Ekpabọ eyi iBezebọ ni ọ khi oghie ọyi iyẹmhẹ ebe nya, ọ rọ khu ẹgbọ iyẹmhẹ ebe egbe lasele.”\f + \fr 12:24 \ft Li zẹ \fq iMat 9.34; 10.25\f*
\p 
\v 25 IJesu ọ she lẹsẹ usamhi oyẹwẹ, ọọ wẹ, “Eghiele ni o da kemhi shi iku-iku ni o nu egbewẹ ẹ khọli ne, eri o ya pfua. Ighọ khi ẹoli ali unuẹkpẹ ni e kemhi egbe nu egbewẹ ẹ khọli, ẹa dobẹ ya migha.
\v 26 Ini Ọkphaghiẹ ọọ khu Ọkphaghiẹ lase, ọ she kemhi egbọli. Sẹẹ eghiele oyọli o ke li dobẹ ya migha?
\v 27 Ini mhi ri ekpabọ eyi iBezebọ ẹẹ khu ẹgbọ ayẹmhẹ ebe egbe a, ekpabọ eyi ọghuo ẹgbọ eyẹ ẹ e rọ khu wẹ kua? Emini eni ẹẹ deba ẹ ẹẹ riẹlẹ o rọkhasẹ khi aa rọte odẹ.
\v 28 Ama ini o khia khi Ayẹmhẹ oyi Ẹshinẹgba mhi rọ ọ khu ayẹmhẹ ebe kua, lọli o rọkhasẹ khi Ẹshinẹgba ọ she ẹ mhẹsẹ shi ẹ egbe.
\p 
\v 29 “Ọghuo ọ fẹ lẹsẹ ya vule, ọ dọsẹ lo apfẹ oyi ọmọse akama ya tsua li itsua vu. Ọa khi eri ọ kpẹ ya gẹ ọli shi ekẹ? Ọ tigbe dobẹ tsua li itsua owa?
\p 
\v 30 “Ọni ọa da nu mhẹ la ne, eri ọ biselemhi mhẹ, ali khi ọni ọa da nu mhẹ ti ẹ gbili ne, eri ọ miatsẹ ku a.\f + \fr 12:30 \ft Li zẹ \fq iMak 9.40\f*
\v 31 Irarighọ, mhi gueyẹ ẹ khi, a ya ri olamhẹ ali ungmemhi ipfiunu-a nya topfa ọgbọ, ama aa ya tigbe ri ungmemhi ipfiunu-a ni a ngme deba Ayẹmhẹ-nọ-pfuasẹ topfa ọgbọ.
\v 32 A ya dobẹ rọ topfa ọnini ọ da pfi unu-a deba Omi Ọgbọ, ama aa ya rọ topfa ọni ọ da pfi unu-a deba Ayẹmhẹ-nọ-pfuasẹ, elemhi agbọ ni a la memena, ghe agbọ ni o ke ẹ bhale.\f + \fr 12:32 \ft Li zẹ \fq iLuk 12.10\f*
\s1 Udumhi ọọra a te ẹ lẹsẹ ọọra
\r (iLuk 6.43-45)
\p 
\v 33 “Ri ẹloe khu ọara, o ya mọ umọmhi onete, ini u waa ri ẹloe khu ọara, o mọ umọmhi ni ọa ti. Irari khi umọmhi oyi ọara a te ẹ lẹsẹ emini oni ọara o khi.\f + \fr 12:33 \ft Li zẹ \fq iMat 7.20; iLuk 6.44\f*
\v 34 Sẹẹ ẹẹ ẹgbọ ebe ni a khọlọ abi ẹnyẹ afue, a liẹ ngme ungmemhi onete unu? Usamhi ni e vọ ọgbọ udu o rọli ẹẹ ngme ungmemhi rọte unu lasele.\f + \fr 12:34 \ft Li zẹ \fq iMat 3.7; 23.33; 15.18; iLuk 3.7; 6.45\f*
\v 35 Udu onete ọgbọ ọnete ọ te ẹ ngme ungmemhi onete lasele. Ighọ ungmemhi obe o li rọte udu oyi ọgbọbe ẹ lasele.
\v 36 Ama a lẹsẹ khi ọgbọgbọ ọ ya zọnọ abi ọ li ngme ungmemhi afuẹ unu lasele ogbẹlẹ isọ-ẹzọ.
\v 37 Irari khi ungmemhi unu oyẹ a rọ ya pfa ẹzọ nẹ, ungmemhi unu oyẹ a gbo rọ ya pfa ẹzọ mu ẹ.”
\s1 Irọkhasẹ oyi iJona
\r (iMak 8.11-12; iLuk 11.29-32)
\p 
\v 38 Ighọ ẹgbọ iFarisi ali esẹsẹ Ishi eyi iMosisi eghuo ẹẹ iJesu, “Ọsẹsẹ, ri ọlẹlẹ ọnyaloa oghuo khasẹ anye.”\f + \fr 12:38 \ft Li zẹ \fq iMat 16.1; iMak 8.11; iLuk 11.16\f*
\p 
\v 39 Ọ sọ wẹ ọ, ọọ, “Ẹẹ ẹgbọ ọkhọlọ ni aa ri igẹsikia ga Ẹshinẹgba.” Àá mhila mhẹ ọlẹlẹ ọnyaloa? Ọgbọkhọghuo ọa ya ri ọlẹlẹ okhọghuo khasẹ ẹ, sẹẹ ni onabi a rọkhasẹ oyi iJona ọmekẹguele.\f + \fr 12:39 \ft Li zẹ \fq iJona 1.17--2.10; iMat 16.4; iMak 8.12\f*
\v 40 Irari khi abi iJona ọ li la elemhi oyi afẹlẹ ogbẹlẹ esẹ ẹlẹ ọguota ali ẹlẹ iyọsẹ, ighọ Omi Ọgbọ ọ li ya li la elemhi ekẹ ogbẹlẹ esẹ, ẹlẹ ọguota ali ẹlẹ iyọsẹ.\f + \fr 12:40 \ft Li zẹ \fq iJona 1.17\f*
\v 41 Ẹgbọ iNinevẹ e ya mu ẹzọ vule shi ẹ ẹgbọ agbhotu ona ọ ogbẹlẹ iguẹzọ, irari khi e mu nyenẹ abi iJona ọ rọ tse abọ ungmemhi oyi Ẹshinẹgba yẹ wẹ. Ama memena, ọni ọ ga fu dọsẹ iJona ọ la akana, ama aa lama mu pfi.\f + \fr 12:41 \ft Li zẹ \fq iJona 3.5\f*
\s1 Abi ayẹmhẹ obe o liẹ kia
\r (iLuk 11.24-26)
\p 
\v 42 Oghie-ọkpotso ọyi ekẹ iShẹba ọ ya mu ẹzọ vule shi ẹ ẹgbọ agbhotu ona ọ ogbẹlẹ iguẹzọ, ọ pfa ẹzọ mu wẹ. Itobọ khi ọọ rọte obini odonuẹ bhale ya ri esọ kpẹ osẹsẹ ilẹsingme oyi iSolomoni. Ama memena ọni ọ fu dọsẹ iSolomoni ọ la akana, ama aa lama pfi esọ shi ọli ọ.\f + \fr 12:42 \ft Li zẹ \fq 1 Ighie 10.1-10; 2 Okhẹ 9.1-12\f*
\p 
\v 43 “Ini ayẹmhẹ ebe o rọte ọgbọ egbe lasele, eri ọ kpẹ je ekẹ okhakha ya dudu kia nono ashini ọ je ya yẹmhẹ-a. Ama ini ọa mẹ,
\v 44 ọ gueyẹ egbọli, ‘Mhi ya nyenẹ egbe ukhokho je owa ni mhi kpẹ te vu.’ Ini ọ nyenẹ egbe bhale aghọ ni ọ rọ ya ẹ khi aghọ o gboo, khi asha kpa oo pfuasẹ nguẹnẹ.
\v 45 Ẹghẹghẹ aghọ, ọ fiẹ je olase ya rue ayẹmhẹ ebe ishilua elese ni e khọlọ dọsẹ ọli bhale ya lo aghọ, e la aghọ. Ẹghẹghẹ aghọ, ikpukhokho oyi ọni ọgbọ ọghọ o ke ya khọlọ dọsẹ abi o kpẹ li. Ighọ o ya li ẹ egbe ẹẹ ẹgbọ ọkhọlọ ena.”
\s1 Inyọ iJesu ali inyọghuo iJesu
\r (iMak 3.31-35; iLuk 8.19-21)
\p 
\v 46 IJesu ọ kie ghọ nu eni ebubu ẹgbọ ọ ngme, inyọli ali inyọghuo ọli e bhale. E migha olase, e nono ni wẹwẹ e nu ọli ngme.
\v 47 Ọgbọghuo aghọ, ọọ li, “Inyẹ ali inyọghuo ẹ, e migha olase, ẹẹ nono ni wẹwẹ e nu ẹ ngme.”
\p 
\v 48 IJesu ọ sọli ọ, ọọ, “Eghuo e khi inyẹmhẹ ali inyọghuo-mhẹ?”
\v 49 Ọ nise obọ ghue eniyẹ odukhokho eyọli, ọọ, “Enana e khi inyẹmhẹ ali inyọghuo-mhẹ.
\v 50 Ọnini ọ da ri ungmemhi oyi Itamhẹ na iloghie gbe akanya, lọli ọ khi inyọghuo-mhẹ ọni ọmọse ali ọni ọkpotso ali inyẹmhẹ.”
\c 13
\s1 Okhẹ irọkhọkhọ oyi ọghiale ni ọ kọ ikpamhemhi
\r (iMak 4.1-9; iLuk 8.4-8)
\p 
\v 1 Ẹlẹ ni a ngme ena, iJesu ọ fiẹ owa ya lase, ọ shitọ epfẹ okẹ oniẹmhi.
\v 2 Ebubu ẹgbọ e le gasẹ ọli ramhi ni ọ rọ vu ya lo ọkọ-okẹ oniẹmhi shitọ, eni ẹgbọ nya e migha egele oni okẹ oniẹmhi.\f + \fr 13:2 \ft Li zẹ \fq iLuk 5.1-3\f*
\v 3 Ọ ri okhẹ irọkhọkhọ gue emhi ebubu u yẹ wẹ, ọọ wẹ, “A ghe i! Ọghiale ọghuo ọ je ishemhi ya ku ikpamhi emhi.
\v 4 Abi ọ li i ku eni ikpamhi emhi eghọ, eghuo ọ e de kua epfẹ odẹ. Ipfeli e bhale ya sanọ wẹ le.
\v 5 Eghuo ọ, e de nga ukhomhi ọkpegbhẹ, ni ọa mhuẹ ekẹ ni e bu. E nyanya zẹ. Ama itobọ khi oni ekẹ ọa mhuẹ ẹlamhi ni e pfi imhili lo,
\v 6 ovọ o gbolo wẹ-a. E khakha-a, irari khi ẹa mẹ asha pfi imhili lo ekẹ egbegbọ.
\v 7 Ikpamhi eghuo ọ, e de kulo ashini igba e la. Eni igba e zẹ, e tono wẹ gbolo-a.
\v 8 Ama ikpamhi eghuo, e de shi egbegbi ekẹ, e fu, e nyẹsẹ ekhẹ. Eghuo e ri imọmhi asha egbhuẹshe lasele, elese e ri asha egbhuẹsẹ lasele, enekpọle, asha uye ali igbe. Ẹghẹghẹ aghọ e ke ya bu dọsẹ emini a kpẹ rọ kọ.
\v 9 A zẹ esọ, a suọ emini mhia gueyẹ ẹ, ni a rọli gbe akanya.”
\s1 Emini oni okhẹ irọkhọkhọ o migha shi
\r (iMak 4.10-12; iLuk 8.9-10)
\p 
\v 10 Eniyẹ odukhokho eyọli e bhale deba li, e mhila li, “Elọ o zẹ ni u rọ ri okhẹ irọkhọkhọ ọ sẹsẹ eni ẹgbọ?”
\p 
\v 11 IJesu ọọ wẹ, a she mhọli ilẹsẹ oyi osheli abi Ẹshinẹgba ọ she mhọli omhẹsẹ shi ẹ egbe, ama a rọli sheli wẹ.
\v 12 Ọnini ọ da kpẹ mhọli, a ya rọ ma ọ na li, ọ mhọli gbeku ọ. Ama ọni ọa mhuẹ, a ya mie ọli oni ọ kpẹ mhuẹ.\f + \fr 13:12 \ft Li zẹ \fq iMat 25.29; iMak 4.25; iLuk 8.18; 19.26\f*
\v 13 Emini o zẹ ni mhi rọ ri okhẹ irọkhọkhọ nu wẹ ngme khi.
\q1 Ini e riẹ bino,
\q2 ẹa ya mẹ ekẹ,
\q1 ini e riẹ ri esọ shi ekẹ,
\q2 ọa ya lo wẹ esọ.
\q1 
\v 14 Lọli o zẹ khi ungmemhi
\q1 ni ọmekẹguele Azaya
\q2 ọ ngme o tsẹ shi wẹ egbe
\q2 ni ọ la liẹ.
\q1 “A ya ri esọ shi ekẹ khue,
\q1 ama ọa ya tigbe lo ẹ esọ,
\q2 a fẹli ofẹli khue,
\q2 aa mẹ emhikhọghuo.
\q1 
\v 15 Udu oyẹwẹ o bi obili-a.
\q1 Itobọ khi eri
\q2 esọ eyẹwẹ e zuse,
\q2 e gbo guese alo.
\q1 Ini ọa khi ighọ,
\q1 e kha ri alo eyẹwẹ
\q1 ke mẹ ekẹ,
\q2 esọ eyẹwẹ e kha suọ,
\q2 udu oyẹwẹ o kha
\q2 mhọli ilẹsingme,
\q1 ee kha mu pfi
\q1 bhale deba mhẹ,
\q2 mhi rẹwẹ ze.”
\q1 “Eni ẹgbọ e ya ri esọ
\q2 shi ekẹ khue,
\q1 ama ọa ya tigbe lo wẹ esọ,
\q2 e fẹli ofẹli khue,
\q2 ama ẹa mẹ emhikhọghuo.”\f + \fr 13:15 \ft Li zẹ \fq Aza 6.9-10\f*
\p 
\v 16 Ama oyẹẹ ọa khi ighọ. Á mẹ afa gba. A ri alo eyẹ ẹ mẹ ekẹ, a ri esọ eyẹ ẹ suọ.
\v 17 Abi o li mhi li gue ọli yẹ ẹ khi, emekẹguele ebubu ali ẹgbọ eyi Ẹshinẹgba ebubu, e li dua ini wẹwẹ e mẹ emini a mẹ ali ini wẹwẹ e suọ emini a suọ, ama ẹa dobẹ.\f + \fr 13:17 \ft Li zẹ \fq iLuk 10.23-24; iJọn 8.56; Iburu 11.13; 1 iPit 1.10-12\f*
\s1 Emini okhẹ irọkhọkhọ oyi ọghiale o ngme
\r (iMak 4.13-20; iLuk 8.11-15)
\p 
\v 18 IJesu ọọ. “A ri esọ shi ekẹ, ni e suọ emini oni okhẹ irọkhọkhọ o ngme.
\v 19 Ọgbọ ni suọ ungmemhi omhẹsẹ ni Ẹshinẹgba ọ mhọli shi agbọ oyi ẹgbọ, ni ọa lo ọli esọ ne, lọli ọ li abi ikpamhi emini e de kua epfẹ odẹ. Eri ọkphaghiẹ ọ́ọ́ bhale ya sanọ li wẹwẹ udu kua.
\v 20 Eni e zẹ nga ukhomhi ọkpegbhẹ, eri e li abi ọgbọ ni ọ kha suọ ungmemhi, ọ ga ri oghẹlẹ mie ọli.
\v 21 Ama ọa tiemhi ọli udu, itobọ ighọ, ọa migha tẹsẹ. Irarighọ, ini ọmunu o bhale ali ni a rọ mu okhọli vule shi ọli ọ shi itobọ oni ungmemhi, ọ de odẹ a aghọaghọ.
\v 22 Ikpamhi ni e zẹ shi ifu igba, wẹwẹ e li abi ọgbọ ni ọ kha suọ ungmemhi oyi Ẹshinẹgba, inasẹ-udu shi ingme agbọ ali ọghuẹmhẹ oyi ẹpfue, e tono oni ungmemhi abi igba, ọa dobẹ mọ umọmhi.\f + \fr 13:22 \ft Li zẹ \fq iMat 19.23; 1 iTimo 6.9-10,17\f*
\v 23 Ikpamhi ni e zẹ shi egbegbi ekẹ, e li abi ọgbọ ni ọ kha suọ ungmemhi oyi Ẹshinẹgba o lo ọli esọ. O mọ umọmhi. Eghuo e kha mọ imọmhi egbhuẹshe, elese mọ egbhuẹsẹ, eghuo ọ uye ali igbe.”
\s1 Okhẹ irọkhọkhọ oyi ebuli ọfaghue ali ado
\p 
\v 24 IJesu ọ gbo zẹ okhẹ irọkhọkhọ olese khasẹ wẹ, ọọ wẹ, “Eri omhẹsẹ oyi Eghiele oyi Ẹshinẹgba o li abi ọmọse ọghuo ni ọ kọ ado enete shi ishemhi oyọli.”
\v 25 Ẹliyọsẹ, khi ẹgbọkpa e ya lesẹ-a, ọbe ọli ọ bhale ya kọ ebuli ọfaghue sọlọ shi ọli ọ, ọ vu.
\v 26 Eni ado e zẹ khi e fu khi e ri itsagha lasele, eni ebuli ọfaghue e li zẹ lasele.
\p 
\v 27 “Ighọ eni ẹẹ ga eyi ọni ọmọse e bhale ya gueyẹ ọli, ẹẹ ọli, ‘Ọga egbegbi ado ni u kọ shi ishemhi oyẹ, ebuli ọfaghue e nu wẹ zẹ lasele kia sọlọ shi wẹ?’
\p 
\v 28 “Ọbe mhẹ ọ riẹlẹ ona.
\p “Eni ẹẹ ga e mhila li, ‘Wa a nono ni anye vuolo eni ebuli ọ kua?’
\v 29 Ọọ wẹ, Iiye! Irari khi ini a vuolo eni ebuli-a, a ya dọ obọ vuolo eni ado ma eni ebuli.
\v 30 A zẹ ni e ga fu kugbe ya ramhi ẹghẹghẹ ikhiẹsẹ. Ẹghẹghẹ aghọ, mhi ya gueyẹ eni ẹẹ khiẹsẹ, e kpẹ vuolo eni ebuli-a, e gẹ wẹ ikhuli, e tosẹ wẹ-a, e tigbe khiẹsẹ eni egbegbi ado shi aka na mhẹ.”
\s1 Okhẹ irọkhọkhọ oyi ukpamhi ọara imọsitadi
\r (iMak 4.30-32; iLuk 13.18-19)
\p 
\v 31 IJesu ọ zẹ okhẹ irọkhọkhọ olese khasẹ wẹ. Ọọ wẹ, “Eri omhẹsẹ ni Ẹshinẹgba ọ mhọli shi agbọ oyi ẹgbọ o li abi ukpamhi ọara ni a lu imọsitadi ni ọmọse ọghuo ọ rọ ya kọ ishemhi oyọli.
\v 32 Ukpamhi ọli, o khi oghuo ikpamhi ẹẹra ni e shẹ nẹ nya, ama ini o fu vule, lọli o ke fu dọsẹ emini a kọ shi oni ishemhi nya. O mele ọara oni ofunẹ a. Ipfeli e bhale ya ku eko shi iguabọ eyọli.”
\s1 Okhẹ irọkhọkhọ oyi ifuma
\r (iLuk 13.20-21)
\p 
\v 33 IJesu ọ gbo zẹ okhẹ irọkhọkhọ olese khasẹ wẹ, ọọ wẹ, “Eri omhẹsẹ ni Ẹshinẹgba ọ mhọli shi agbọ oyi ẹgbọ o li abi ifuma ni ọkpotso ọ rọ ma ifulawa ni o bu wushe, ni o rọli fuma shi ọ.”\f + \fr 13:33 \ft Li zẹ \fq iLuk 13.20-21; iGal 5.9; Igbae 18.6\f*
\p 
\v 34 Okhẹ irọkhọkhọ iJesu ọ rọ gue ingme ena yẹwẹ. Ọa tigbe gue ingme okhọghuo yẹwẹ ni ọa khi okhẹ irọkhọkhọ.
\v 35 Eri ona o ya tse shi ungmemhi ni ọmekẹguele ọ ngme. Ni ọọ,
\q1 “Okhẹ irọkhọkhọ
\q2 mhi rọ ya nu wẹ ngme.
\q1 Mhi ya gue ingme
\q2 ni a rọte igbaekẹle
\q2 oyi agbọ rọ sheli yẹ wẹ.”\f + \fr 13:35 \ft Li zẹ \fq Iwolo 78.2\f*
\p 
\v 36 Abi iJesu ọ rọ zẹ eni ebubu ẹgbọ obọ, ni ọ rọ ya lo elemhi owa, eniyẹ odukhokho eyọli e bhale deba li. Ẹẹ ọli, “Gueyẹ anye emini okhẹ irọkhọkhọ oyi ebuli ọfaghue oghọ o ngme.”
\p 
\v 37 IJesu ọọ, “Ọgbọ ni ọ ri eni egbegbi ikpamhi emhi ẹkọmhi kọ, ọ khi Omi Ọgbọ.
\v 38 Oni ishemhi o khi oni agbọ ona, eni ikpamhi ado enete eghọ e khi ẹgbọ ni e ya ri egbewẹ na Eghiele oyi Ẹshinẹgba. Eni ebuli ọfaghue e khi ẹgbọ eyi Ọkphaghiẹ.
\v 39 Ọkphaghiẹ ọ khi Ọbe ni ọ ri eni ebuli kọ ifu ishemhi. Oni ẹghẹghẹ ikhiẹsẹ o khi ikpukhokho agbọ, eni eni ẹẹ ga eghọ e khi igẹni eyi Ẹshinẹgba.
\p 
\v 40 “Ẹzẹzẹ abi a li ti eni ebuli gbili tosẹ-a eghọ, ighọ ikpukhokho agbọ o ya li.
\v 41 Omi Ọgbọ ọ ya ghie igẹni eyọli ya wolọ ẹgbọ ni e yẹsẹ ẹgbọ pfidọ ali eni e li ọkhọlọ elemhi eghiele oyọli lasele.
\v 42 A ya pfi wẹ kulo elemhi avuerẹ, aghọ ẹgbọ e la ya ke viẹ ẹ le akọ akọ.
\v 43 Ẹghẹghẹ aghọ ẹgbọ eyi Ẹshinẹgba e ya ke gẹ abi ovọ elemhi agbọ onogbọ oyi Ẹshinẹgba. A mhọli esọ, a suọ emini mhia gueyẹ ẹ ni a rọli gbe akanya.”
\s1 Okhẹ irọkhọkhọ oyi ẹpfue ni a rọ sheli
\p 
\v 44 “Eri omhẹsẹ ni Ẹshinẹgba ọ mhọli shi agbọ oyi ẹgbọ o li abi ẹpfue ni a rọ sheli ifui ishemhi, ni ọmọse ọ tọnọ ekẹ mẹ rue, ni ọ nyanya gbo rọli sheli. Egbe e mu ọli, ọ ya ri emini ọ mhọli nya dẹ, ọ ya dẹ oni ishemhi oghọ.
\p 
\v 45 “Eri omhẹsẹ ni Ẹshinẹgba ọ mhọli shi agbọ oyi ẹgbọ o li abi ọmọse ni ọ́ nònò ugbhẹ-ema.
\v 46 Ini ọ mẹ oni o lo mu ẹloe, ọ je apfẹ ya ri emini ọ mhọli nya dẹ, ọ dẹ ọli.
\s1 Okhẹ irọkhọkhọ oyi aga
\p 
\v 47 “Eri omhẹsẹ ni Ẹshinẹgba mhọli shi agbọ oyi ẹgbọ o gbo li abi aga ni egbifẹlẹ e pfi lo okẹ oniẹmhi ni o khishi, e muno ifẹlẹ ọdọda.
\v 48 Abi oni aga o rọ vọ, e ti ọli ngale egele. Ighọ, e shitọ e sanọ ifẹlẹ eni e khi egbegbewẹ ọ kulo ughughu, e tsua eni ẹa ti kua.
\v 49 Ighọ o ya li ogbẹlẹ ni o kpe ukhokho. Igẹni eyi Ẹshinẹgba e ya sanọ ẹgbọ ọkhọlọ ifuabọ ẹgbọ eni e pfuasẹ lasele.
\v 50 E pfi ẹgbọ ọkhọlọ eghọ kulo owa erẹ, ni e la ke viẹ, ẹẹ le akọ akọ.
\p 
\v 51 “Eni ingmemhi ena nya e she lo ẹ esọ?” Ẹ ọli, “Ii.”
\v 52 Ọọ wẹ, “Irarighọ, eri ọsẹsẹ ushi nya ni ọ mele ọmọ odukhokho-a, ni ọ da mie Eghiele oyi Ẹshinẹgba shi udu, ọ li abi ọgbọ ni ọ mhọli owa, ni ọ rọte elemhi owa ni ọ ri itsua shi ẹ rue ẹpfue onogbọ ali onodiọ lasele.”
\s1 Ẹdẹli eyi iJesu e kie ọli
\r (iMak 6.1-6; iLuk 4.16-30)
\p 
\v 53 Abi iJesu ọ rọ zẹ eni okhẹ irọkhọkhọ ena se, Ọ lase aghọ le.
\v 54 Ọ nyenẹ egbe je ẹoli oyọli. Ọ la owa ugamhi sẹsẹ, ẹgbọ ni e suọ ọli, abọ e sha wẹ. E mhila, e liẹ, “Obo ọ te mhuẹ ilẹsingme enana, obo ọ te mẹ ikanya ọshabọ ena a gbe?”
\v 55 “Ọa she khi omi ikapita na? Ọa khi iMeli ọ khi inyọli, iJemhisi ali iJosẹfu ali iSamọ ali iJudasi ẹa she khi inyọghuo ọli?
\v 56 Ena ẹa khi inyọghuo ọli eni ikpotso ni e ga nu awa la ana ena? Mhiẹ, Obo ọ te mẹ enana nya?”
\v 57 Irarighọ, ọ ri elemhi bi wẹ.\f + \fr 13:57 \ft Li zẹ \fq iJọn 4.44\f*
\p Ighọ iJesu ọọ wẹ, “Aa mẹ ashini aa la mu ekpẹ na ọmekẹguele, sẹ ni apfẹ oyọli ali unuẹkpẹ oyọli tsẹ aa la mu ekpẹ na li.”
\p 
\v 58 Itobọ khi ẹa mhuẹ irudunga, ọa la aghọ gbe ikanya ọnyaloa ni e bu.
\c 14
\s1 Eghuli oyi iJọni Ọni ọọ batazi
\r (iMak 6.14-29; iLuk 9.7-9)
\p 
\v 1 Ẹghẹghẹ aghọ, Erọdu oghie ekẹ iGalili ọ suọ eko iJesu.
\v 2 Ọ gueyẹ eni ẹ ga li, ọọ, “IJọni Ọni ọọ batazi na, ni ọ nyenẹ egbe bhale agbọ. Lọli o zẹ ni ọ rọ lighọ mhọli afu rọ ọ gbe ikanya ọnyaloa enana.”
\p 
\v 3 Irari khi Erọdu ọ ke kpẹ ghie ya mu iJọni. Ọọ, a ri iwẹghẹ gẹ ọli, a mu ọli pfilo owa ighumha shi itobọ ingme oyi Ẹrodiasi ughuẹ iFilipu inyọghuo ọni Erọdu.
\v 4 Eri iJọni ọ ke gueyẹ Erọdu khi ushi oyi ẹgbọ iJu ọa lama shi ọ ni ọ rọ rue ughuẹ inyọghuo ọli iFilipu shi.\f + \fr 14:4 \ft Li zẹ \fq iLẹv 18.16; 20.21\f*\f + \fr 14:4 \ft Li zẹ \fq iLuk 3.19-20\f*
\v 5 Oni ẹghẹghẹ Erọdu ọ nono ni lọli gbe iJọni-a shi oni ingme, ama ulishi oyi ẹgbọ iJu oo mu ọli irari khi ọ lẹsẹ khi ẹgbọ kpa e lẹsẹ khi ọmekẹguele iJọni ọ khi.
\p 
\v 6 Ama, ẹlẹ ni Erọdu ọ ghẹlẹ shi ogbẹlẹ ni a rọ bia li, omi Ẹrodiasi ọ gbe ishimhi khasẹ wẹ ni o ri egbe mu ọni Erọdu dọsẹ.
\v 7 O ri ọni Erọdu romhi ishe, ọ neta ọmọse gueyẹ ọni ọmueshi khi lọli ya ri emiemini ọ mhila luẹ na li.
\v 8 Ighọ inyọli ọ ya sẹsẹ ọni ọmueshi, ọ ka gueyẹ itali ọ khi iJọni ukhomhi shi ukpẹko na luẹ.
\p 
\v 9 Abi ọ rọ ngme ọli ghọ, egbe pfọ ọni oghie-a. Ama irari ishe ni ọ romhi ali apfọli ni e nu ọli shitọ, ọọ a ri emini ọ mhila na li.
\v 10 Ighọ ọ ghie ya khi iJọni ukhomhi ọ elemhi owa ighumha.
\v 11 A khi oni ukhomhi shi ukpẹko a ri ọli na ọni ọmueshi, ọni ọmueshi ọ tsua li ghi inyọli.
\v 12 Eniyẹ odukhokho eyi iJọni e bhale ya tsua ekuli oyọli rọ ya tọ. E vu ya gueyẹ iJesu.
\s1 IJesu ọ ri eminale na ẹgbọ agbẹlẹ ishe le
\r (iMak 6.30-44; iLuk 9.10-17; iJọn 6.1-14)
\p 
\v 13 Abi iJesu ọ rọ suọ emini a mẹ, ọ fiẹ aghọ lase. Ọ lo ọkọ-okẹ oniẹmhi je asha ni o da-ya ya shitọ. Abi eni ẹgbọ e rọ suọ ona e ri awẹ kia lẹ deba li.
\v 14 Abi iJesu ọ rọte oni ọkọ-okẹ oniẹmhi fiẹ lase, ni ọ rọ mẹ eni ebubu ẹgbọ eghọ, elemhi wẹ e ala li, eni ẹa ze, ọ rẹ wẹ ze.
\p 
\v 15 Ogbọmhi o mu ekẹ, eniyẹ odukhokho e bhale, ẹẹ ọli, “Waa ke zẹ ẹgbọ ena ke je, irari khi oola o nuata shi apfẹ, ni e je ifu ẹoli ya dẹ emhi le.”
\p 
\v 16 IJesu ọọ wẹ, “Ọa ti ni e lighọ vu tsẹ, a nono eminale na wẹ le.”
\p 
\v 17 Ẹẹ iJesu, “Ibulẹdi ishe ali ifẹlẹ ava e khi emini awa lẹsẹ mhuẹ shi ana.”
\p 
\v 18 IJesu ọọ wẹ, “A rue wẹ bhale ghi mhẹ ghue.”
\v 19 Ọọ, ọgbọgbọ ọ shitọ ukhomhi ebuli. Ọ rue eni ifẹlẹ ava ali ibulẹdi ishe eghọ, ọ tsua wẹ idane ọ ri ikphẹmhi na Ẹshinẹgba. Ọ kholo eni ibulẹdi-a, ọ rẹ wẹ na eniyẹ odukhokho eyọli. Eni eniyẹ odukhokho eyọli e kemhi wẹ na wẹ.
\v 20 Ọgbọgbọ ọ le, ọ khue, e kpọle. Ighọ eniyẹ odukhokho eyọli e sanọ eni e kpọle vọ ighughu igbẹva tsululu.
\v 21 Emọse agbẹlẹ ishe (5,0000) e le eni eminale, ini aa leli ikpotso ali eniyẹ ma ọ.
\s1 IJesu ọ la ukhomhi okẹ kia
\r (iMak 6.45-52; iJọn 6.15-21)
\p 
\v 22 Aghọaghọ iJesu ọ gueyẹ eniyẹ odukhokho eyọli e lo ọkọ-okẹ da je ukiẹkiẹ okẹ obini o kpọle, ọ gueyẹ eni ebubu ẹgbọ, ọgbọgbọ ọ ke je.
\v 23 Ọ vẹsẹ eni ẹgbọ kua se, ọ je ukhomhi ute ya sọ iromhi. Ogbọmhi o mu ekẹ, iJesu lọlighuo ọ kie la oobọ.
\v 24 Ẹghẹghẹ ni a ngme ena, oni ọkọ-okẹ o she rọte ekẹ lo oni okẹ kia nuata. Ighọ akpekpeli oniẹmhi oo zughuse oni okẹ, ni o tsua oni ọkọ-okẹ ya nga ya tiemhi.
\p 
\v 25 Ẹlẹ uzogbe neni ogbe o gbe-a, iJesu bhale deba wẹ, ọ la oni ukhomhi okẹ ẹ kia.
\v 26 Abi eni eniyẹ odukhokho e rọ mẹ ọli khi ọ la ukhomhi oni okẹ ẹ kia, e yila. E tsẹsẹ, e liẹ, “Ayẹmhẹ olimi lọ!”
\p 
\v 27 IJesu ọ nyanya nu wẹ ngme, ọọ, “A mhọli udu, mhẹmhẹ lọ, a khi ke na ulishi.”
\p 
\v 28 IPita ọọ, “Ọnọmhuẹ ini yẹyẹ lọ igẹsikia, wẹẹ mhẹ mhi bhale debẹ oni ukhomhi okẹ.”
\v 29 IJesu ọọ li, “Bhale.” Ighọ iPita ọ fiẹ oni ọkọ-okẹ lasele, ọọ kia ukhomhi okẹ, ọọ lẹ deba iJesu.
\v 30 Ama abi ọ ke rọ mẹ abi oni ukpokpomhi akpekpeli o li pfiolo, ulishi o mu ọli, ọọ tiemhi elemhi oni okẹ. Ọ tsẹsẹ, ọọ, “Ọnọmhuẹ tsumhi mhẹ!”
\p 
\v 31 Ighọ iJesu ọ nise obọ-a ọ mu ọli. Ọọ li, “Elọ o zẹ ni irudunga oyẹ o rọ na shẹ. Elọ o zẹ ni u rọ mhuẹ akhọkhọmhẹ?”\fig IJesu ọ la ukhomhi okẹ kia|src="cn01722B.tif" size="col" loc="MAT 14.31" copy="tif" ref="14.31"\fig*
\p 
\v 32 Ighọ e ga ya lo elemhi oni ọkọ-okẹ, oni akpekpeli o pfọmhẹ.
\v 33 Ighọ eniyẹ odukhokho eyọli e nyẹsẹ ukhomhi na li ẹẹ ọli, “Igẹsikia lọ khi, Omi Ẹshinẹgba u khi.”
\s1 IJesu ọ la iGẹnẹsarẹti ri ọni ọọ ghua ze
\r (iMak 6.53-56)
\p 
\v 34 Abi e ke rọ da oni okẹ ni o khishi, e bhale ekẹ iGẹnẹsarẹti.
\v 35 Abi ẹgbọ ni e la oni ekẹ e rọ lẹsẹ khi iJesu lọ, e ghie ghi ẹgbọ ni e la ẹoli i kia gasẹ oni ẹoli nya. Ẹgbọ e tsua ẹgbọ eyẹwẹ nya ni ẹẹ ghua ghi ọli.
\v 36 E lema li ọ kpẹkpẹ ọ lẹsẹ zẹ ni eni ẹ ghua e ri obọ ti esọ awulu ni ọ sọ. Ẹgbọ nya ni e ri obọ ti ọli, e ze.
\c 15
\s1 Osẹsẹ ipfuasẹ na ekelemhi
\r (iMak 7.1-13)
\p 
\v 1 Ighọ ẹgbọ iFarisi ali esẹsẹ Ishi eyi iMosisi eghuo e te iJerusalẹmu bhale ya mhila iJesu, ẹẹ,
\v 2 “Elọ o zẹ khi eniyẹ odukhokho eyẹ ẹa ya ri osẹsẹ ni ititawa e rọ shi ekẹ gbe akanya? Ẹa ya kpe abọ-a neni e le eminale!”
\p 
\v 3 IJesu ọọ wẹ, “Elọ o zẹ ni a rọ ri itobọ ushi oyẹẹ gbe ushi oyi Ẹshinẹgba-a?
\v 4 Irari khi Ẹshinẹgba ọọ liẹ, ‘Ọgbọ ọ ke ri ekpẹ na itali ali inyọli,’ ali khi, ‘Ọnini ọ da ku itsẹ na itali okekhi inyọli ne, a gbe ọli-a.’\f + \fr 15:4 \ft Li zẹ \fq Okiali 20.12; 21.17; iLẹv 20.9; iDẹut 5.16\f*
\v 5 Ama abi ẹẹ a ke ngme khi, ini ọgbọ ọ mhọli ikpaghọ ni ọ kha rọ na itali okekhi inyọli, ni ọ ke rọ liẹ khi eni ikpaghọ eghọ khi lọli mu udu pfi, khi Ẹshinẹgba lọli ke ri eni ikpaghọ ya na.
\v 6 Khi ọ guẹ kia ini ọa ke riẹ ri ikpaghọ na itali ali inyọli. Ina a li ri ẹloe ẹ gbe ushi oyi Ẹshinẹgba ni a ba mẹ asha ke deba osẹsẹ oyẹ ẹ.
\v 7 Ẹẹ e ri ugamhi ku alo! Azaya Ọmekẹguele ọ kpẹ lina ngme ọli shi ẹ egbe ni ọ rẹ,
\q1 
\v 8 “Eni ẹgbọ ena, unu e rọ mu ekpẹ ẹ na mhẹ,
\q2 ama udu oyẹwẹ o nuata shi mhẹ ọ.
\q1 
\v 9 Afuẹ e mema ga mhẹ,
\q2 irari khi osẹsẹ oyi ẹgbọ ẹẹ sẹsẹ ẹgbọ,
\q2 abinẹ khi ishi eyẹmhẹ lo.”\f + \fr 15:9 \ft Li zẹ \fq Aza 29.13\f*
\s1 Emini e ri ọgbọ ọọ khi ọni ọa pfuasẹ
\r (iMak 7.14-23)
\p 
\v 10 IJesu ọ lu ẹgbọ ni e legba, ọọ wẹ, “A ri esọ shi mhẹ ekẹ, ni a mhuẹ ilẹsingme.
\v 11 Ọa khi emini ọgbọ ọ rọte unu le tiemhi elemhi e rọli ẹ khi ọni ọa pfuasẹ, ama emini e te ọli unu ya fiẹ e ri ọgbọ khi ọni ọa pfuasẹ.”
\p 
\v 12 Ighọ eniyẹ odukhokho eyọli e bhale deba li e mhila li, ẹẹ ọli, “U li lẹsẹ khi ingmemhi ni u ngme amo khi, o ri elemhi ẹ bi ẹgbọ iFarisi?”
\p 
\v 13 IJesu ọọ wẹ, “Ọara ni Itamhẹ na iloghie ọa da rọ kọ ne, a ya vu ọli ekẹ-a.”
\v 14 A khi zẹ ni ingme oyẹwẹ o nasẹ ẹ udu. Ezalo ni eri ezalo ẹ kia e khi. Ini ọzalo ọ mu ọzalo ọnabi lọli obọ rọ ọ kia, eri wẹwẹ ava e ga de ya pfilo atekẹ.\f + \fr 15:14 \ft Li zẹ \fq iLuk 6.39\f*
\p 
\v 15 IPita ọọ iJesu, “Gueyẹ anye abi oni okhẹ irọkhọkhọ ena e ngme.”
\p 
\v 16 IJesu ọọ wẹ “Aa kie lẹsẹ emini mhia ngme?”
\v 17 A lẹsẹ khi emini o da te unu ya tiemhi elemhi khi eri a nẹ ọli ẹ kua?
\v 18 Ama emini o da te unu lasele ne, elemhi udu o te lasele. Ena e khi emini e dobẹ ri ọgbọ ọ khi ọni ọa pfuasẹ.\f + \fr 15:18 \ft Li zẹ \fq iMat 12.34\f*
\v 19 Irari khi elemhi udu isamhi ebe e te ẹ lasele. Usamhi abi a liẹ gbe ugbeli, ali abi a liẹ kia okia, abi liẹ do ighiatọ ni a rọ na eta ali iku itsẹbọ ali iyese ọgbọ-a, ali ni a rọ ọ pfi ọtsẹlẹ ẹgbhuẹ.\f + \fr 15:19 \ft Li zẹ \fq iGal 5.19-21; 1 iKọri 6.9-10; iRom 14.14\f*
\v 20 Emhi enana e ri ọgbọ ọ khi ọni ọa pfuasẹ. Ama ini ọgbọ ọ le eminale ni ọa rọ kpe abọ, ọa ri ọgbọ khi ọni ọa pfuasẹ.
\s1 Irudunga oyi ọkpotso ọngi iKena
\r (iMak 7.24-30)
\p 
\v 21 IJesu ọ te aghọ vu, ọ bhale ekẹ iTai ali iSidọni.
\v 22 Ọkpotso ọngi iKena ni ọ la ukiẹkiẹ ekẹ oghọ ọ bhale deba iJesu ọ lema li, ọọ li, “Ọnọmhuẹ Omi iDefidi kpẹkpẹ mhọli ilẹlemhi na mhẹ. Omimhẹ ni ọmueshi ọ mhuẹ ayẹmhẹ ọkphaghiẹ. Oo ze mu ọli gba memena.”
\p 
\v 23 Ama iJesu ọa sọ ọli ọ. Eniyẹ odukhokho eyi iJesu, ẹ iJesu ọ khu ọni ọkpotso khi ọọ kpe okeke deba ẹwẹ.
\p 
\v 24 IJesu ọọ wẹ, “Isumha eyi iZirẹni ni e waa, a ghie mhẹ ghi tsẹ.”
\p 
\v 25 Ọni ọkpotso ọ suọ ona, ọ bhale ya de wugha odalo oyi iJesu, ọọ li, “Ọnọmhuẹ kpẹkpẹ kpaghiẹ mhẹ obọ.”
\p 
\v 26 IJesu ọọ li, “Ọa ti ni a rue eminale oyi eniyẹ pfi ghi ewa.”
\p 
\v 27 Ọni ọkpotso ọọ, “Ighọ lọ guẹguẹguẹ, Ọnọmhuẹ. Ama ewa ẹẹ le eminale ni o rọte ukhomhi itebu oyi ọni ọ mhọli wẹ de kua ekẹ.”
\p 
\v 28 IJesu ọọ ọni ọkpotso, “Egbegbọ u mhuẹ irudunga, a ya ri emini u nono nẹ.” Aghọaghọ omi ọli ọ ze.
\p 
\v 29 IJesu ọ te aghọ vu, ọ rọte okẹ oniẹmhi iGalili lẹ. Ọ nga ukhomhi ute ya shitọ.
\v 30 Ebubu ẹgbọ e bhale deba li aghọ, e tsua ẹgbọ ni e guọghọ awẹ-a, ali eni e zẹ alo ali eni e le esọ, ali eni e ki shi, ali ingmenu ali ebubu ẹgbọ ni e mhuẹ ighuamhi ọdọda bhale ya shi ufuẹgẹ oyi iJesu. Ọ ri wẹwẹ nya ze.
\v 31 Abọ e sha ẹgbọ abi e rọ mẹ khi ingmenu ee ngme, ẹgbọ ni e guọghọ a, e vule kia, eni e zẹ alo e mẹ ekẹ, ighọ, ee kuẹghiẹ Ẹshinẹgba ọyi iZirẹni.
\s1 IJesu ọ ri eminale na ẹgbọ agbẹlẹ ene le
\r (iMak 8.1-10)
\p 
\v 32 IJesu ọ lu eniyẹ odukhokho eyọli, ọ́ọ́ wẹ, “Elemhi ẹgbọ ena e ga lala mhẹ irari khi ẹlẹ-esẹ na ni e te nu mhẹ la akana. Ẹa mẹ eminale le. Mhi aa nono ni mhi gueyẹ wẹ e ri elemhi ofuẹ ke je, ini ubi o khi rue wẹ shi odẹ.”
\p 
\v 33 Eniyẹ odukhokho eyọli e mhila li, “Obo a te ya mẹ eminale ni ebubu ẹgbọ ena e ya le ifu oyẹmhi ni awa la ena?”
\p 
\v 34 IJesu ọ mhila wẹ, “Ibulẹdi ingmẹ a mhọli shi aghọ?”
\p Ẹ ọli “Iruli ishilua ali ikuku ifẹlẹ.”
\p 
\v 35 Ighọ iJesu ọọ eni ẹgbọ e shitọ ekẹkhẹ.
\v 36 Ighọ ọ rue eni ibulẹdi eghọ ali eni ifẹlẹ ọ kphẹmhi na Ẹshinẹgba shi ọ. Ọ khi wẹ a, ọ rẹwẹ na eniyẹ odukhokho eyọli e kemhi wẹ na eni ẹgbọ.
\v 37 Ọgbọkpa ọ le, ọ khue. Eniyẹ odukhokho eyọli e sanọ eni e le kpọle shi ighughu ishilua e vọ tsuulu.
\v 38 Emọse agbẹlẹ ene 4,000 e le eni eminale. Ini ọgbọ ọa leli ikpotso ali eniyẹ ma ọ.
\v 39 IJesu ọ vẹsẹ eni ebubu ẹgbọ kua se, ọ lo ọkọ-okẹ oniẹmhi je ukiẹkiẹ ekẹ iMagidaleni.
\c 16
\s1 E mhila iJesu ọ ri ọlẹlẹ khasẹ ẹwẹ
\r (iMak 8.11-13; iLuk 12.54-56)
\p 
\v 1 Ẹgbọ iFarisi ali iSadusi eghuo e bhale deba iJesu e ya mu ọli fẹ. E mhila li ọ ri ọlẹlẹ ni o te iloghie bhale khasẹ wẹ.\f + \fr 16:1 \ft Li zẹ \fq iMat 12.38; iLuk 11.16\f*
\v 2 IJesu ọọ wẹ, “Ini ogbọmhi ọọ mu ekẹ, a guele khi, ‘Ogbe-namo o ma ti irari khi idane o yilẹ-a.’
\v 3 Ẹlẹ uzogbe, a guele khi, ‘Amẹ o ya ruẹ amo irari khi idane ọọ yilẹ, o gbo bishi-a.’ A guẹ bino irarogbe guele abi ogbe o ya li, ama aa dobẹ ẹ guele emini ẹghẹghẹ ni a la memena o ngme.
\v 4 Ẹẹ ẹgbọ ebe na agbhotu ona ni aa ri igẹsikia ga Ẹshinẹgba! A mhila mhẹ ọlẹlẹ? Aa ya ri okhọghuo khasẹ ẹ, sẹ ni onayi iJona ọmekẹguele.”\f + \fr 16:4 \ft Li zẹ \fq iMat 12.39; iLuk 11.29\f*
\p Ighọ iJesu ọ pfi wẹ shi aghọ vu.
\s1 Oyese oyi ẹgbọ iFarisi ali iSadusi
\r (iMak 8.14-21)
\p 
\v 5 Abi eniyẹ odukhokho eyọli e rọ́ da oni okẹ oniẹmhi ni o khi shi je egele ukiẹkiẹ obini o kpọle se, e sato khi wẹwẹ ẹa yelele tsua ibulẹdi.
\v 6 IJesu ọọ wẹ a mhuẹ ẹgbhẹ ẹ shi angeli oyi ẹgbọ iFarisi ali iSadusi ni o li abi afuma oyi oyese.\f + \fr 16:6 \ft Li zẹ \fq iLuk 12.1\f*
\p 
\v 7 Eni eniyẹ odukhokho e nu egbewẹ ngme ọli khi itobọ khi wẹwẹ ẹa tsua ibulẹdi bhale iJesu ọ rọ ngme ona.
\p 
\v 8 IJesu ọ suọ emini e ngme, ọọ wẹ, “Eni ẹa mhọli irudunga ena, elọ o zẹ ni a rọ gue ẹzọ eminale?
\v 9 Aa kie lẹsẹ ingme? Aa sato abi mhi rọ kemhi ibulẹdi ishe na ẹgbọ agbẹlẹ ishe, ighughu ingmẹ a sanọ eni e le kpọle vọ?\f + \fr 16:9 \ft Li zẹ \fq iMat 14.17-21\f*
\v 10 Ali ibulẹdi ishilua ni mhi rọ na ẹgbọ agbẹlẹ ene le, ighughu ingmẹ a sanọ eni e le kpọle vọ?\f + \fr 16:10 \ft Li zẹ \fq iMat 15.34-38\f*
\v 11 Elọ o zẹ khi aa kie lẹsẹ khi ọa khi ingme ibulẹdi mhi nu ẹ gue? Ama, mhiẹ a mu egbe ẹ shi oyese oyi ẹgbọ iFarisi ali iSadusi ni o li abi ifuma.”
\v 12 Lọli eniyẹ odukhokho eyọli e rọ tigbe lẹsẹ khi, ọa khi ingme ifuma ni a rọ nye ibulẹdi ọ nu wẹ ngme ẹ shi, ama ingme osẹsẹ ẹgbhọli oyi ẹgbọ iFarisi ali iSadusi ọọ ngme.
\s1 IPita ọ guele ọni iJesu ọ khi
\r (iMak 8.27-30; iLuk 9.18-21)
\p 
\v 13 Abi iJesu ọ rọ bhale ekẹ iSizeria iFilipi, ọ mhila eniyẹ odukhokho eyọli, ọọ wẹ, “Ọghuo ẹgbọ e famhi ẹ liẹ khi Omi Ọgbọ ọ khi?”
\p 
\v 14 Ẹẹ iJesu, “Eri ẹgbọ eghuo ẹ khi iJọni Ọni ọọ batazi ẹgbọ u khi, eghuo ẹ lu ẹ, Elaja, eghuo ọ ẹ khi, iJeremaya u khi, eghuo ẹ khi, ọọghuo emekẹguele u khi.”\f + \fr 16:14 \ft Li zẹ \fq iMat 14.1-2; iMak 6.14-15; iLuk 9.7-8\f*
\p 
\v 15 IJesu ọọ wẹ, “Ẹẹ oyẹ ẹ, ọghuo ẹ khi mhi khi?”
\p 
\v 16 ISamọ iPita ọ rọ ọli, “Yẹyẹ u khi ọni iKirisiti Omi Ẹshinẹgba ni ọ la ọ.”\f + \fr 16:16 \ft Li zẹ \fq iJọn 6.68-69\f*
\p 
\v 17 IJesu ọọ li, “Ọni a khi vọsẹ na u khi, iSamọ omi iJona. Ọa khi ọgbọ ọ ri igẹsikia ona khasẹ ẹ, obọ oyi Itamhẹ na iloghie o te bhale.
\v 18 Mhi gueyẹ, yẹyẹ iPita, (ni u khi ẹchẹ). Oni ungmemhi ni u ngme ena mhi ya ma Igbaa oyẹmhẹ ni e mie mhẹ suọ nga, ekpabọ oyi eghuli ọa dobẹ ya mu ọli ọ le.
\v 19 Mhi ya rue okpẹ oyi eghiele oyi Ẹshinẹgba nẹ, emiemini u waa da lama shi elemhi agbọ ona ne, Ẹshinẹgba ọa ya li lama shi ọ obini iloghie, emini u da lama shi elemhi agbọ ona ne, ọ ya lama shi ọ obini iloghie.”\f + \fr 16:19 \ft Li zẹ \fq iMat 18.18; iJọn 20.23\f*
\p 
\v 20 IJesu ọ gueyẹ eniyẹ odukhokho eyọli e khi gueyẹ ẹgbọ khi lọli khi ọni iKirisiti.
\s1 IJesu ọ gue ingme eghuli oyọli le shi ekẹ
\r (iMak 8.31--9.1; iLuk 9.22-27)
\p 
\v 21 Rọte ẹghẹghẹ aghọ vu iJesu ọ te gueyẹ eniyẹ odukhokho eyọli, ọọ, liẹ, “Mhi mema ya je ekẹ iJerusalẹmu ni mhi la ya mẹ osoli ebubu abọ eyi eni egbhali ali ighie eyi ekpodalo-ugamhi ali esẹsẹ Ishi eyi iMosisi. A mema ya gbe mhẹ-a, ama ẹlẹ nuzi-esẹ a ya guise mhẹ le bhale agbọ.”
\p 
\v 22 Ighọ iPita ọ lu ọli fiẹ je olase ọ liẹ ọli ọ khi ke gbo ngme ghọ, “Ẹshinẹgba ọ bighi ọli ku a, oghọ ọa ya tsẹ shi ẹ egbe!”
\p 
\v 23 IJesu ọ mu egbe pfi ọọ iPita, “Vu mhẹ ana, ọkphaghiẹ! Ọzuodẹ u khi shi mhẹ ọ, irari khi waa ya sa isamhi ni e rọte obọ oyi Ẹshinẹgba bhale, ama usamhi oyi agbọ.”
\p 
\v 24 Ighọ iJesu ọ gueyẹ eniyẹ odukhokho eyọli, ọọ wẹ, “Ini ọgbọ ọ da nono ni lọli deba mhẹ ne ọ mema ya kie egbọli ọ tsua apfida oyọli ọọ deba mhẹ.\f + \fr 16:24 \ft Li zẹ \fq iMat 10.38; iLuk 14.27\f*
\v 25 Irari khi ọgbọ ni ọ́ da dua ni lọli tsumhi ayẹmhẹ oyọli ne, agbọ onabi oyi Ẹshinẹgba o ya de ọli obọ-a, ama ọgbọ ni ọ da ri itobọ oyẹmhẹ rue ayẹmhẹ oyọli pfi-a ne, ọ ya tsumhi ọli.\f + \fr 16:25 \ft Li zẹ \fq iMat 10.39; iLuk 17.33; iJọn 12.25\f*
\v 26 Ighe eleli ni ọgbọ ọ ya mẹ ini ọ le ugu agbọ ona nya, ni ayẹmhẹ oyọli o rọ de ọli obọ-a? Abi khi elọ ọgbọ ọ dobẹ rọ ya fali ota rọ to ayẹmhẹ oyọli.
\v 27 Irari khi Omi Ọgbọ ọ ya bhale elemhi ufumhi oyi Ẹshinẹgba lọli ali igẹni eyọli, ẹghẹghẹ aghọ ọ ya ri eleli na ọgbọgbọ abi ọ li gbe.\f + \fr 16:27 \ft Li zẹ \fq iMat 25.31; Iwolo 62.12; iRom 2.6\f*
\v 28 Mhi gueyẹ ẹ khi ẹgbọ eghuo e la ana memena ni ẹa ya ghu ne, ni e rọ ya mẹ khi Omi Ọgbọ ọọ bhale abi oghie.”
\c 17
\s1 Imamachi oyi iJesu
\r (iMak 9.2-13; iLuk 9.28-36)
\p 
\v 1 Ogbẹlẹ-esesa o dọsẹ se, iJesu ọ rue iPita ali iJemhisi ali iJọni ikhi inyọghuo iJemhisi, wẹwẹghuo kpe e ya nga ukhomhi ute ni o yagha.
\v 2 Ọ la aghọ mu mela-a ukpẹloe wẹ. Alo eyọli e gẹ abi ovọ, itsua ni ọ sọ e gẹ abi ákpá.
\v 3 O li dẹnẹ, ghe khẹ, e mẹ khi iMosisi ali Elaja khi e nu iJesu ẹ ngme.
\p 
\v 4 Ighọ iPita ọọ iJesu, “Ọnọmhuẹ, o ma guẹ ti khi anye la ana! Ini o ghọle ẹ, mhi ya tọ okholo esẹ, oghuo ọ o khi o yẹ, olese ọ o khi oyi iMosisi, onokpọle o khi oyi Elaja.”
\p 
\v 5 Abi ọ kie li ngme, ighọ otughunu ni o gẹ nyanyanya o bhale ya khukhu wẹ-a. E suọ khi uruli o rọte oni otughunu liẹ, “Omimhẹ ni mhi nono ingme oyọli na, ni ọ ri egbe ẹ mu mhẹ. A suọ emini ọ gueyẹ ẹ.”\f + \fr 17:5 \ft Li zẹ \fq Igbae 22.2; iDẹut 18.15; Iwolo 2.7; Aza 42.1; iMat 3.17; 12.18; iMak 1.11; iLuk 3.22\f*\f + \fr 17:5 \ft Li zẹ \fq 2 iPit 1.17-18\f*
\p 
\v 6 Abi eni eniyẹ odukhokho e rọ suọ ona, e de yẹshi ta alo rughu, ulishi oo mu wẹ.
\v 7 Ighọ iJesu ọ bhale ya ri obọ ti wẹ, ọọ wẹ, “A vule, a khi ke zẹ ni ulishi o mu ẹ.”
\v 8 Abi e ke rọ yasẹ alo ekẹ, ẹa ke mẹ ọgbọkhọghuo aghọ sẹ ni iJesu lọlighuo kpe.
\p 
\v 9 Abi e rọ tiemhi oni ute le, iJesu ọ tse agua yẹ wẹ, ọọ. “A khi gueyẹ ọgbọkhọghuo emini a mẹ, ini aa li rọte eghuli guise Omi Ọgbọ le.”
\p 
\v 10 Eni eniyẹ odukhokho eyọli e mhila li, ẹẹ, “Elọ o zẹ khi esẹsẹ Ishi eyi iMosisi ẹ liẹ khi Elaja ọ mema kpẹ ya bhale?”\f + \fr 17:10 \ft Li zẹ \fq iMala 4.5\f*
\p 
\v 11 IJesu ọọ wẹ, “Elaja ọ mema kpẹ ya te odẹ bhale ya mu egbe emhikpa shi ekẹ.
\v 12 Ama mhi gue ẹ yẹ ẹ khi Elaja ọ she bhale ama ẹgbọ ẹa lama khi lọli ọ khi, e li ọli abi o ghọle wẹ. Ighọ e ya li na Omi Ọgbọ osoli.”\f + \fr 17:12 \ft Li zẹ \fq iMat 11.14\f*
\v 13 Ighọ eniyẹ odukhokho eyọli e tigbe lẹsẹ khi ingme oyi iJọni Ọni ọọ batazi ẹgbọ ọọ ngme.
\s1 IJesu ọ ri ọmọ ze
\r (iMak 9.14-29; iLuk 9.37-43a)
\p 
\v 14 Abi e rọ nyenẹ egbe bhale deba eni ebubu ẹgbọ, ọmọse ọghuo ọ bhale ya wugha odalo oyi iJesu.
\v 15 Ọọ, “Ọnọmhuẹ, kpẹkpẹ lẹ elemhi omi mhẹ ni ọ mhuẹ ughuamhi ni ọ mu ọgbọ pfi gbe. O ma nasẹ ọli gba. Isheghuo o mu ọli ẹ pfilo erali, isheghuo ọ de pfilo okẹ.
\v 16 Eri mhi rue ọli ghi eniyẹ odukhokho eyẹ, ẹa dobẹ rọli ze.”
\p 
\v 17 IJesu ọọ, “Ashi mhi bẹshi ri abọ mu udu na ẹ ya ramhi, ẹẹ ẹgbọ ni ẹa mhuẹ irudunga ali iwali ẹgbọ, ẹlẹ ingmẹ mhi ke bẹshi ri abọ mu udu na ẹ ya ramhi? A rue ọni ọmọ ghi mhẹ ana.”
\v 18 Ighọ iJesu ọ mhẹsẹ na oni ayẹmhẹ ọkphaghiẹ ọghọ, o te ọli egbe fiẹ ya lase, ọni ọmọ ọ ze aghọaghọ.
\p 
\v 19 Ighọ eniyẹ odukhokho e bhale deba iJesu abi o rọ kpe lọlighuo le, e mhila li, ẹẹ ọli. “Elọ o fẹ zẹ khi anye ẹa dobẹ khu oni ayẹmhẹ ọkphaghiẹ ya lase?”
\p 
\v 20 IJesu ọọ wẹ, “Itobọ khi irudunga oyẹ ẹ oo shẹ lọ. Mhi gueyẹ ẹ khi ini a mhuẹ irudunga ni o shẹ abi ukpamhi ọara imọsitadi, a ya dobẹ gueyẹ ute ona, ẹẹ ọli, ‘Vu ana lasele je oobọ.’ O lighọ nẹ abi u ngme. Aa mẹ emini ọa ya zẹ ẹ ke li.”
\v 21 [Ama odẹ ni a te dobẹ khu ayẹmhẹ obe onana fiẹ lase khi, ode iromhi isọsọ ali azumhi ipfipfi.]\f + \fr 17:21 \ft Li zẹ \fq iMat 21.21; iMak 11.23; 1 iKọri 13.2\f*
\s1 IJesu ọ gbo gue ingme eghuli oyọli le shi ekẹ
\r (iMak 9.30-32; iLuk 9.43b-45)
\p 
\v 22 Abi eniyẹ odukhokho eyọli e rọ bhale iGalili, iJesu ọọ wẹ, “Ẹghẹghẹ o she ramhi ni a rọ ya ri Omi Ọgbọ na ẹgbọ dẹ.
\v 23 E ya gbe ọli-a, ama ẹlẹnuzi-esẹ a ya guise ọli le bhale agbọ.” Oni ungmemhi o ri egbe pfọ wẹ-a.
\s1 E mhila iJesu oga oyi Owa ugamhi
\p 
\v 24 Abi iJesu ali eniyẹ odukhokho eyọli e rọ nyenẹ egbe jele iKapanọmu, emionoga na Owa oyi Ẹshinẹgba e bhale deba iPita, e mhila li, “Ọsẹsẹ oyẹẹ ọ li fẹ zẹ oga oyi Owa oyi Ẹshinẹgba?”\f + \fr 17:24 \ft Li zẹ \fq Okiali 30.13; 38.26\f*
\p 
\v 25 IPita ọọ wẹ, “Ee.”
\p Abi iPita ọ rọ lo elemhi owa le ya mhila iJesu, iJesu ọ kpẹ ngme. Ọọ, “ISamọ, eghuo u fẹ sa khi enighie ena agbọ ona e famhiẹ mie oga? Emọ-ekẹ abi epfẹse?”
\p 
\v 26 IPita ọọ, “Epfẹse.”
\p IJesu ọ li, “O ti shọ! Oghọ o rọkhasẹ khi ọmọ ekẹ ọa khi ọni ọọ zẹ oga.”
\v 27 “Ama ini awa khi lue na wẹ, je okẹ ya pfi ugba oyẹ pfilo. Afẹlẹ ni u todẹ ya mu, khueghie ọli unu-a, u ya mẹ ọli ukpaghọ unu rue. Rue ọli ni u rọli ya zẹ oni oga oyẹmhẹ ali oyẹẹ.”
\c 18
\s1 Ọghuo ọ funẹ shi Eghiele oyi Ẹshinẹgba
\r (iMak 9.33-37; iLuk 9.46-48)
\p 
\v 1 Ẹghẹghẹ aghọ, eni eniyẹ odukhokho e bhale deba iJesu, e mhila li, “Ọghuo ọ fẹ funẹ shi Eghiele oyi Ẹshinẹgba?”\f + \fr 18:1 \ft Li zẹ \fq iLuk 22.24\f*
\v 2 Ighọ iJesu ọ lu ukuku ọmọ bhale migha wẹ odalo.
\v 3 Ọọ wẹ, “Abi o li mhi li gue ọli ẹ yẹ ẹ, khi, ini aa li mu pfi ni a li abi ikuku eniyẹ, aa ya lo Eghiele oyi Ẹshinẹgba.\f + \fr 18:3 \ft Li zẹ \fq iMak 10.15; iLuk 18.17; 1 iPit 2.2\f*
\v 4 Ọgbọ ni ọ ga funẹ shi Eghiele oyi Ẹshinẹgba khi, ọni ọ ri egbọli tiemhile abi ukuku ọmọ ọnana.
\p 
\v 5 “Ọnini ọ da ri irari eva oyẹmhẹ mie ọmọ ọnana ne, mhẹmhẹ ọ mie.
\v 6 Ama ini ọgbọkhọghuo ọ yẹsẹ enana ni e mie mhẹ suọ pfidọ, ini a bie mu iko zu ọgbọ ọghọghọ uruli tsua pfilo elemhi okẹ oniẹmhi, o ti nẹ.
\p 
\v 7 “O maa khọlọ mu ẹgbọ ni e yẹsẹ ẹgbọ ọ lamhẹ. Ọgbọ ọa dobẹ ya na pfue imufẹ oyi olamhẹ. Ama o ma khọlọ ẹgbọ ni e zẹ khi a mẹ eni imufẹ eghọghọ egbe.
\v 8 Ini obọ oyẹ, okekhi owẹ oyẹ, o zẹ ni u lamhẹ, khi ọli pfi-a. Irari khi o ti nẹ ini ọgbọ ọ khi ọkhomhi ya lo agbọ na agbọagbọ, ni abọ ali awẹ e gba pfo nali ya lo owa erẹ.\f + \fr 18:8 \ft Li zẹ \fq iMat 5.30\f*
\v 9 Ini o khia khi ẹloe oyẹ o zẹ ẹ lamhẹ, vuọnyọ li pfia. O ti nẹ u ri ukpẹloe oghuo ya lo iloghie, ni alo e rọ gba nẹ, pfi ẹ ya lo ilimhi iriẹriẹ.\f + \fr 18:9 \ft Li zẹ \fq iMat 5.29\f*
\s1 Okhẹ irọkhọkhọ oyi osumha ni ọ wa
\r (iLuk 15.3-7)
\p 
\v 10 “A khi zẹ ni a ri ẹloe gbe eni ẹa mu ẹloe enana, irari khi eri igẹni eyẹwẹ na iloghie ẹ migha odalo oyi Itamhẹ ẹghẹghẹkpa.
\v 11 [Eri mhẹmhẹ Omi Ọgbọ mhi bhale ya tsumhi eni e wa-a.]\fig Osumha ni o wa a|src="BK00005B.TIF" size="col" loc="MAT 18.11" copy="TIF" ref="18.11"\fig*
\p 
\v 12 “Sẹ a sa shi ọ? Ini ọgbọ ọ mhuẹ isumha egbhuẹshe ni ọghuo ọ, ọ rọ wa-a. Ọa khi eri ọ ya zẹ ọghuo ọa la egbhuẹshe eghọ obọ, ọ ya nono ọghuo ni ọ wa a eghọ?
\v 13 Ini ọ mẹ ọli, mhi gue ẹ yẹ ẹ khi egbe e ya mu ọli shi ọghuo ọghọ dọsẹ ọghuo ọa la egbhuẹshe enekpọle ni ẹa waa.
\v 14 Ighọ Ita ẹ na iloghie ọa li nono eni ẹa mu ẹloe enana ni e wa-a.
\s1 Inyọghuo ẹ ni ọ pfidọ nẹ
\p 
\v 15 “Ini inyọghuo ẹ ọ lue nẹ, lẹ deba li ka gueyẹ ọli emini ọ li. Ama zẹ ni o khi yẹyẹ ali lọlighuo kpe. Ini ọ ri esọ shi ẹ ekẹ, u she gbo sheshe ọli shi odẹ.\f + \fr 18:15 \ft Li zẹ \fq iLuk 17.3\f*
\v 16 Ama ini ọa ri esọ shi ẹ ekẹ, lu ọgbọ ọghuo abi ava elese, ẹghẹghẹ aghọ ni e khi ọtsẹlẹ abi Ebe-no-pfuasẹ o ngme.\f + \fr 18:16 \ft Li zẹ \fq iDẹut 19.15\f*
\v 17 Ini ọa ri esọ shi ẹ ọ, lẹ ya gue eni ingme nya yẹ ena igbaa oyi eni e mie iJesu iKirisiti suọ. Ini ọa gbo da ri esọ shi igbaa oyi eni e mie iJesu iKirisiti suọ ọ ne, a ti kia nali. A rue ọli shi ọgbọ ni ọa miesuọ ali ọmionoga ọgbọ ọkhọlọ.
\p 
\v 18 “Abi o li mhi li gue ọli ẹ yẹ ẹ khi emiemini aa da lama shi oni agbọ ona ne, aa ya li lama shi ọ na ẹ obini iloghie. Ali khi emiemini a da lama shi agbọ ona ne, a ya lama shi ọ na ẹ obini iloghie.\f + \fr 18:18 \ft Li zẹ \fq iMat 16.19; iJọn 20.23\f*
\p 
\v 19 “Mhi gbo gueyẹ ẹ khi ini ẹẹ otuava a da lama shi emhikhọghuo agbọ ona ni a rọ sọ iromhi shi ọ ne, Itamhẹ ni ọ la iloghie ọ ya riẹlẹ ọli na ẹ.
\v 20 Irari khi asha ni ẹgbọ ava o khi aasẹ e da lona kugbe irari eva oyẹmhẹ ne, mhi nu wẹ la aghọ.”
\s1 Okhẹ irọkhọkhọ ọni ọa ya gbe kua na ọgbọ
\p 
\v 21 IPita ọ bhale deba iJesu, ọ mhila li, “Iti-ingmẹ inyọghuo-mhẹ ọ fẹ ya lue na mhẹ ramhi ni mhi rọ ya gbe kua nali? Iti ishilua?”
\p 
\v 22 IJesu ọọ li, “Iiye, ọa khi iti ishilua tsẹ, ama iti egbhuẹsẹ ali igbe asha ishilua.\f + \fr 18:22 \ft Li zẹ \fq Igbae 4.24\f*\f + \fr 18:22 \ft Li zẹ \fq iLuk 17.3-4\f*
\p 
\v 23 “Irari khi eri Eghiele oyi Ẹshinẹgba o li abi oghie ọghuo ni ọọ eni ẹẹ ga eyọli e bhale ya rọkhasẹ luẹ abi e li gbe akanya.
\v 24 Abi ọ rọ ghọ bino na wẹ abi e li gbe na li, a rue ọmọse ọghuo ni ọ lo ọli ẹkpa idududu bhale.
\v 25 Abi ọni ọmọse ọa rọ dobẹ fali eni ikpaghọ, ọni oghie ọọ e mu ọli ali ughuẹ ọli ali imi ọli ya dẹ ni ọ rọ fali eni ota.
\p 
\v 26 “Ọni ọọ ga ọghọ ọ de ya wugha odalo oyi ọni oghie, ọọ li, ‘Kpẹkpẹ, rabọmudu na mhẹ, mhi ya fali ẹ eni ikpaghọ nya.’
\v 27 Ighọ ọni oghie ọ ya mhuẹ isomhelemhi na li, ọ gbe eni ota kua na li, ọ zẹ ọli vu.
\p 
\v 28 “Ama abi ọni ọọ ga ọ rọ fiẹ lase, ọ mẹ ọni ọọ ga nabi lọli ni ọ lo ọli ikuku ikpaghọ. Ighọ, ọ khi awulu shi ọli uruli, ọọ li, ‘Fali mhẹ ota ni u lo mhẹ!’
\p 
\v 29 “Ọnuzava ọyọli ọghọ, ọ de ya wugha, ọọ lema li, ọọ li, ‘Kpẹkpẹ rabọmudu na mhẹ, mhi ya fali ẹ.’
\p 
\v 30 “Ama ọa lama na li. Ọọ a mu ọli ya shi owa ighumha ya ramhi ni ọ rọ ya fali eni ota.
\v 31 Abi eni ẹẹ ga enekpọle e rọ mẹ emini ọ li, elemhi ee bi wẹ. E lẹ ya gue eni ingme nya yẹ ọni oghie ọghọ.
\p 
\v 32 “Ighọ ọni oghie ọ ghie ya lu ọni ọọ ga ọghọ, ọọ li, ‘Yẹyẹ ọni ọọ ga ọna ọkhọlọ ọna, mhẹmhẹ mhi gbe ikpokpomhi ikpaghọ ni u lo mhẹ kua nẹ irari khi u lema mhẹ,
\v 33 waa khi ọni ọ kha li mhuẹ isomhelemhi na ọnuzi-ava ọyẹ abi mhi mhuẹ isomhelemhi nẹ?’
\v 34 Ighọ elemhi e bi ọni oghie, ọ mu ọli ya shi owa ighumha ni a nali osue ya ramhi ni ọ rọ ya fali eni ota ni o lo nya.
\p 
\v 35 “Ina Itamhẹ na iloghie ọ li ya li ẹ ini aa rọte ekelemhi udu gbekua na inyọghuo ẹ.”
\c 19
\s1 Ipfa-ughuẹ-a
\r (iMak 10.1-12)
\p 
\v 1 Abi iJesu ọ rọ ngme se, ọ te ekẹ iGalili vu je ekẹ iJudia ukiẹkiẹ okẹ iJọdani,
\v 2 Ebubu ẹgbọ ẹ vẹ deba li. Ọ rẹwẹ la aghọ ze.
\p 
\v 3 Ẹgbọ iFarisi eghuo e bhale ya mu ọli fẹ ni e ba mẹ asha mu ingme ma li obọ. E mhila li, “Ushi oyawa o fẹ lama shi ọ ọmọse ọ ri itobọ emhikhọghuo khu ughuẹ ọli?”
\p 
\v 4 IJesu ọ mhila wẹ, “Aa zẹ abi Ebe-no-pfuasẹ o ngme khi eri Ẹshinẹgba ni ọ ma ẹgbọ te igbaekẹle, ọ ma ẹgbọ ọmọse ali ọkpotso?\f + \fr 19:4 \ft Li zẹ \fq Igbae 1.27; 5.2\f*
\v 5 Ẹshinẹgba ọ gbolo ẹ, ‘Itobọ ona ọmọse ọ ya zẹ itali ali inyọli obọ, ọ to ma ughuẹ-ọli ọ, wẹwẹ ava e mele ọgbọ ọghuo-a.’
\v 6 Ẹghẹghẹ aghọ ẹa ke khi ava ama ọghuo. Itobọ ona, emini Ẹshinẹgba ọ she to ma, ọgbọ khi vasẹ ọli-a.”\f + \fr 19:6 \ft Li zẹ \fq Igbae 2.24\f*
\p 
\v 7 Eni ẹgbọ iFarisi e mhila iJesu, “Elọ o zẹ khi Ushi oyi iMosisi o lama ọgbọ ọ nya ebe ipfa-ughuẹ-a mhọli ughuẹ ọli obọ, ọ khu ọli?”\f + \fr 19:7 \ft Li zẹ \fq iDẹut 24.1-4; iMat 5.31\f*
\p 
\v 8 IJesu ọọ wẹ, “Itobọ khi aa gbe udu o zẹ ni Ushi oyi iMosisi o rọ lama li na ẹ, ama ọa kpẹ te igbaekẹle lighọ.
\v 9 Mhi gueyẹ ẹ khi ọnini ọ khu ughuẹ ọli ni ọa rọ khi itobọ okia, ni ọ rọ ya rue ọkpotso ọlese ne, o she kia okia.”\f + \fr 19:9 \ft Li zẹ \fq iMat 5.32; 1 iKọri 7.10,11\f*
\p 
\v 10 Eniyẹ odukhokho eyi iJesu ẹẹ, ini o khia khi ina o bie khi iteva ọmọse ali ughuẹ ọli, o bie ti nẹ ọgbọ khi rue ọkpotso shi.
\p 
\v 11 IJesu ọọ wẹ, “Ọa khi ọgbọkpa oni osẹsẹ ona o gọ lu, sẹ ni eni Ẹshinẹgba ọ ri oni afu na e khi rue ọkpotso.
\v 12 Irari khi emhi ebubu ẹẹ zẹ khi ebubu ẹgbọ ẹa ya rue ọkpotso, eghuo, itobọ khi ighọ Ẹshinẹgba ọ ma wẹ, eghuo, itobọ khi ẹgbọ e rẹ wẹ khi ighọ, elese e ri egbewẹ mele ọwali-a ni e mẹ asha ga Ẹshinẹgba egbegbọ. Ọgbọ ni ọ dobẹ ya ri egbe mie oni osẹsẹ, ọ ri egbe mie.”
\s1 IJesu ọ lema na eniyẹ enikeke
\r (iMak 10.13-16; iLuk 18.15-17)
\p 
\v 13 Ẹghẹghẹ aghọ, ẹgbọ eghuo e wolọ eniyẹ enikeke bhale ghi iJesu ini ọ ri obọ nga wẹ ukhomhi, ni ọ sọ iromhi na wẹ. Ama eniyẹ odukhokho eyọli ee khu wẹ, e ti je ukhokho.
\p 
\v 14 IJesu ọọ wẹ “A zẹ ni ikuku eniyẹ e bhale deba mhẹ, a khi ke khu wẹ irari khi wẹwẹ enana e mhọli agbọ oyi Ẹshinẹgba.”
\v 15 Ọ ri obọ nga wẹ ukhomhi sẹ, ọ rọte aghọ vu.
\s1 Ọzẹo ni lolo pfue
\r (iMak 10.17-31; iLuk 18.18-30)
\p 
\v 16 Ọzẹo ọghuo ọ bhale ya mhila iJesu, ọọ, “Ọsẹsẹ ọnete, elọ mhi fẹ ya li ni mhi rọ ya mhọli agbọ onabi oyi Ẹshinẹgba?”
\p 
\v 17 IJesu ọọ li, “Elọ o zẹ ni u rọ ọ lu mhẹ ọnete? Ẹshinẹgba luẹghuo kpe ọ lẹsẹ ti. Ini u wa nono ni u mhọli agbọ onabi oyọli, ri ishi eyọli gbe akanya.”
\p 
\v 18 Ọ mhila iJesu, “Ishi eneghuo ọ?”\f + \fr 19:18 \ft Li zẹ \fq Okiali 20.13-16; iDẹut 5.17-20\f*
\p IJesu ọọ li, “ ‘Khi gbe ugbeli, khi kia okia, khi do ughiatọ, khi pfi ọtsẹlẹ ẹgbhuẹ mu ọgbọ.
\v 19 Mu ekpẹ na itẹ ali inyẹ, gbo zẹ ni, u nono ingme oyi ọnuzava ọyẹ abi u li nono egbe ẹ.’ ”\f + \fr 19:19 \ft Li zẹ \fq Okiali 20.12; iDẹut 5.16; iLẹv 19.18\f*
\p 
\v 20 Ọni ọzẹo ọọ iJesu, “Te ekẹ vu mhi te ri eni u ga ngme ena nya a gbe akanya, onoghuo o ke kpọ mhẹ le?”
\p 
\v 21 IJesu ọọ li, “Ini u wa nono ni u gba pfo, lẹ ya ri itsua ni u mhọli nya dẹ u kemhi eni ikpaghọ na ẹgbọ ni ẹa mhọli, ni u mhọli ẹpfue shi obini iloghie. U tigbe bhale ke ya deba mhẹ kia.”
\p 
\v 22 Abi ọni ọzẹo ọ rọ suọ ona, egbe e pfọ li-a itobọ khi ọọ pfue gba.
\p 
\v 23 IJesu ọọ eniyẹ odukhokho eyọli, “Mhi gue ọli ẹ yẹ ẹ khi, o ma munu ni ẹgbọ ni e pfue e zẹ ni Ẹshinẹgba ọ mhẹsẹ na wẹ.
\v 24 Mhi gbo gueyẹ ẹ khi, ni ọgbọ ni ọ pfue ọ rọ lo eghiele oyi Ẹshinẹgba, o ya munu dọsẹ, ni ọgbọ ke dua ni lọli ri akphẹrẹ rọte esẹ asugẹ ya fiẹ.”
\p 
\v 25 Abi eniyẹ odukhokho eyi iJesu e rọ suọ ona, abọ e sha wẹ, e mhila li, “Ọghuo ọ ke dobẹ ya lo Eghiele oyi Ẹshinẹgba shọ?”
\p 
\v 26 IJesu ọ bino wẹ, ọọ, “Ini a ri oyi ọgbọ ngme, ona o ya munu, ama obọ oyi Ẹshinẹgba, emhikpa o zẹ ọli ẹ riẹlẹ.”
\p 
\v 27 IPita ọ mhila iJesu, ọọ li, “Anye ni anye zẹ emhikpa obọ bhale deba ẹ ena, elọ anye ya mẹ ọ rue?”
\p 
\v 28 IJesu ọọ wẹ, “Abi o li mhi li gue ọli ẹ yẹ ẹ khi ini Omi Ọgbọ ọ da shitọ ukpẹkhomhi ufumhi oyọli ẹghẹghẹ agbọ Onogbọ, ẹẹ ogbava ni a deba mhẹ a ya nu mhẹ shitọ ikpẹkhomhi igbẹva, a mhẹsẹ ẹ na ẹdẹli igbẹva eyi iZirẹni.\f + \fr 19:28 \ft Li zẹ \fq iMat 25.31; iLuk 22.30\f*
\v 29 Ọgbọkpa ni ọ da zẹ owa oyọli obọ, okekhi inyọghuo ọli, ni ọ zẹ itali ali inyọli obọ ali inyọghuo ọli ali imiọli ali ẹpfue eyọli obọ shi itobọ oyẹmhẹ ne, ọ ya mhuẹ ẹpfue eghọghọ asha egbhuẹshe, ọ gbo mhuẹ agbọ onabi oyi Ẹshinẹgba.
\v 30 Ama ẹgbọ eghuo ni e ralo e ya kpukhokho eni e kpe ukhokho, e ya ralo.”\f + \fr 19:30 \ft Li zẹ \fq iMat 20.16; iLuk 13.30\f*
\c 20
\s1 Okhẹ irọkhọkhọ oyi egbikanya na elemhi ogba ipfonu
\p 
\v 1 “Eri Eghiele oyi Ẹshinẹgba o li abi ọmọse ọghuo ni ọ fiẹ lase ya wolọ ẹgbọ ẹluzogbe je ogba ipfonu oyọli ya gbe akanya.
\v 2 Ọ lama khi lọli ya fali ọgbọgbọ ingmẹ ni a mie ogbẹlẹ. Ọ rẹwẹ je ogba ẹẹra ipfonu oyọli ya gbe akanya.
\p 
\v 3 “Elemhi agogo itili ẹluzogbe, ọ fiẹ lasele, ọ mẹ khi emọse eghuo e migha elemhi oki ni ẹa mhuẹ oni ẹẹ gbe.
\v 4 Ọọ wẹ, ‘A je ogba ẹẹra ipfonu oyẹmhẹ ya gbe akanya khi mhi ya fali ẹ emini o ti.’
\v 5 Ighọ e vu.
\p “Elemhi agogo igbẹva ẹlẹ ọguota ali agogo esẹ ẹlẹ ogbọmhi, ọ gbo lighọ ya wolọ emọse elese.
\v 6 Agogo ishe o she ramhi, ọ gbo bhale ya ẹ emọse elese ni ẹa li gbe okhọghuo. Ọ mhila wẹ, ọ wẹ, ‘Elọ o zẹ ni a rọ migha ana amo kpa pfuse ẹghẹghẹ-a, ni aa rọ gbe okhọghuo?’
\p 
\v 7 “Ẹ ọli, ‘Irari khi ọgbọkhọghuo ọa lu anye shi akanya lọ.’
\p “Ọọ wẹ, ‘A je ogba ipfonu oyẹmhẹ ya gbe akanya.’
\p 
\v 8 “Ogbọmhi o ke mu ekẹ, ọni ọ mhuẹ ogba ọghọ, ọ lu ọni ọ ri ẹgbọ ẹ gbe akanya na li, ọọ, ‘Lu eni e gbe akanya ni u fali ọgbọgbọ ota. Ọ kpẹ rọte ẹgbọ ni e kpẹ ukhokho bhale fali ota ya ramhi eni e kpẹ bhale.’\f + \fr 20:8 \ft Li zẹ \fq iLẹv 19.13; iDẹut 24.15\f*
\p 
\v 9 “Ọ fali ẹgbọ ni e te agogo ishe ẹlogbọmhi gba akanya le ukpaghuo.
\v 10 Abi eni e te ododẹ gba akanya le e rọ bhale ya mie ifata, e dabi khi ikpaghọ eyẹwẹ e ya bu dọsẹ eni e kpe ukhokho bhale oni akanya. Ama a ga fali wẹ abizize.
\v 11 E mie ifata se, ee wọlọ ọni ọ mhuẹ ishemhi.
\v 12 E ọli, ‘Emọse ena ni a kpukhokho mie, iwakati oghuo e lẹsẹ gbe akanya, ama rọte ẹlẹ uzogbe fiefie anye te ri ukhomhi shi ovọ ya ramhi ogbọmhi. Ama u ya fali anye abizize!’
\p 
\v 13 “Ọmhuẹ-ishiemhi ọ rọ ọtuọghuo elemhi wẹ, ‘Ọmuẹ, mhi aa liẹle. Ọa khi ukpaghuo-ghuo a lama na mhẹ shi akanya ogbẹlẹ?
\v 14 A mọ ikpaghọ eyẹ ẹ ni a ke je apfẹ. Onoghuo o de ẹ shi ọ ini mhi fali ọmọse ni mhi kpukhokho mie abi mhi fali ẹ.
\v 15 Abi khi mhia dobẹ ya li ikpaghọ eyẹmhẹ abi o ghọle mhẹ? Eri a kẹ kpe ofuma irari khi mhi da khi ọgbọ ni ọ somhopfa?’
\p 
\v 16 “Ama ẹgbọ eghuo ni e ralo e ya kpukhokho eni e kpe ukhokho e ya ralo.”\f + \fr 20:16 \ft Li zẹ \fq iMat 19.30; iMak 10.31; iLuk 13.30\f*
\s1 IJesu ọ gbo gue ingme eghuli oyọli le shi ekẹ
\r (iMak 10.32-34; iLuk 18.31-34)
\p 
\v 17 Abi iJesu ọ rọ ọ nga iJerusalẹmu, ọ lu eniyẹ odukhokho eyọli je asheghuo ya gueyẹ, ọọ wẹ.
\v 18 “IJerusalẹmu ni awa je ena, a ya la oobọ ri Omi Ọgbọ na ighie eyi ekpodalo-ugamhi ali esẹsẹ Ishi eyi iMosisi dẹ, aghọ e la ya pfa ẹzọ igbe-a mu ọli.
\v 19 E tigbe rue ọli na ẹgbọ iJẹta, e rọli li egia, e gbe ọli itẹ, e ta li ma apfida, ama ẹlẹnuzi-esẹ, a guise ọli le bhale agbọ.”
\s1 Emini ughuẹ iZebedi ọọ iJesu ọ riẹlẹ na luẹ
\r (iMak 10.35-45)
\p 
\v 20 Ighọ ughuẹ iZebedi ọ rue imi ọli ava bhale deba iJesu, ọ wugha li odalo, ọọ li ọ kpẹkpẹ ọ somhi luẹ opfa.
\p 
\v 21 IJesu ọ mhila li, “Elọ wa nono.”
\p Ọọ li, “Lama na mhẹ khi imimhẹ aava ena, khi ọghuo ọ kha shitọ ẹ obọ ita, ọnọkpọle ọ shitọ ẹ ọgobọ eghiele oyẹ.”
\p 
\v 22 IJesu ọọ wẹ, “Aa lẹsẹ emini a mhila. A ya dobẹ da uko osoli ni mhi ya da?”
\p Ẹ ọli, “Anye ya dobẹ.”
\p 
\v 23 IJesu ọọ, “A rọte uko ni mhi te da ya da, ama, ọa khi mhẹmhẹ mhi ya zẹ ọni ọ ya shitọ mhẹ obọ ita ali ọgobọ. Eni Ita ọ riẹlẹ wẹ shi na e mhọli wẹ.”
\p 
\v 24 Abi eniyẹ odukhokho ogbe enekpọle e rọ suọ, e pfaa na ọgbọ ali inyọghuo eghọ.
\v 25 Ighọ iJesu ọ lu wẹ tigbili, ọọ wẹ, “A lẹsẹ khi ighie eyi ẹgbọ iJẹta eri ẹẹ jili ẹgbọ eyẹwẹ. Eni e kpeda e ri omhẹsẹ ri itoto ẹ sha wẹ ma.
\v 26 Ama, ọa khi ighọ iteva oyẹ ẹ. Ọni ọ da nono ni lọli fu ne, ọ khi ọni ọọ ga enekpọle.\f + \fr 20:26 \ft Li zẹ \fq iLuk 22.25-26\f*
\v 27 Ini ọngẹẹ ọọ nono ni lọli khi ọnododẹ, ọ mele ọni ọọ ga ọyi enekpọle a.\f + \fr 20:27 \ft Li zẹ \fq iMat 23.11; iMak 9.35; iLuk 22.26\f*
\v 28 Ẹzẹzẹ abi Omi Ọgbọ, ọa li bhale ni a ke ga li, ama ọ bhale ni ọ rọ ga ẹgbọ ali ni ọ gbo ri agbọ oyọli mie ebubu pfuese.”
\s1 IJesu ọ ri ezalo aava ze
\r (iMak 10.46-52; iLuk 18.35-43)
\p 
\v 29 IJesu ali eniyẹ odukhokho eyọli e rọte iJẹriko vu, ebubu ẹgbọ e vẹ deba li.
\v 30 Emọse ezalo aava e shitọ epfẹ-odẹ. Abi e suọ khi iJesu ọ rọte aghọ dọsẹ. E tsẹsẹ, e liẹ. “Ọnọmhuẹ, Omi iDefidi, lẹ elemhi anye.”
\p 
\v 31 Oni ebubu ẹgbọ e dese wẹ, e khukhu unu, ama e kiele tsẹsẹ leghe, e liẹ, “Ọnọmhuẹ, Omi iDefidi kpẹkpẹ lẹ elemhi anye.”
\p 
\v 32 Ighọ iJesu ọ migha, ọ lu wẹ, ọọ wẹ, “Elọ a nono ni mhi riẹlẹ na ẹ?”
\p 
\v 33 Ẹẹ ọli. “Ọnọmhuẹ, kpẹkpẹ anye ẹ nono ni u khueghie anye alo-a.”
\p 
\v 34 IJesu ọ mhuẹ ilẹlemhi na wẹ, ọ ri obọ ti wẹ alo, eni alo e khueghie-a, e deba li.
\c 21
\s1 Ẹgbọ e ri ufumhi na iJesu abi ọ́ rọ́ lo elemhi iJerusalẹmu
\r (iMak 11.1-11; iLuk 19.28-40; iJọn 12.12-19)
\p 
\v 1 Abi iJesu ali eniyẹ odukhokho eyọli e li ti i mama iJerusalẹmu, e bhale ikuku ẹoli na lui iBẹtifagi ni o la Ute ẹẹra Olivu. IJesu ọ la aghọ ghie eniyẹ odukhokho eyọli aava je ẹoli ni o la odalo.
\v 2 Ọọ wẹ, “A je ẹoli ni a fẹ odalo oyẹẹ ena, khi a ya mẹ akphẹrẹ ali omiọli. A taghiẹ wẹ-a, a mu wẹ ghi mhẹ ana.
\v 3 Ini ọgbọkhọghuo ọ mhila ẹ emhikhọghuo, a gueyẹ ọli khi Ọnọmhuẹ ọ ya rẹwẹ riẹlẹ emhi, ọ gbo ya nyenẹ wẹ bhale lẹna.”
\p 
\v 4 Eri a mẹ enana ni a rọ bhale ya ẹ khi ungmemhi ni emekẹguele e ngme, ni e bhale ya tsẹ. Ni ọọ
\q1 
\v 5 “A gueyẹ ẹdẹli iZayọ,\f + \fr 21:5 \ft Li zẹ \fq iZaka 9.9\f*
\q2 ‘A bino khi oghie ọyẹ ẹ ọọ bhale deba ẹ.
\q1 Ọ mhọli ikuegbe-a, ọ nga ozele akphẹrẹ,
\q2 ikhi Omi akphẹrẹ.’ ”
\p 
\v 6 Ighọ eniyẹ odukhokho eyi iJesu e ye abi ọ ghie wẹ.
\v 7 Ighọ e rue ọni akphẹrẹ ali omi ọli bhale, e banọ ide eyẹwẹ egbe nga li egbe, iJesu ọ nga li shitọ.
\v 8 Ebubu ẹgbọ e gueghie itsua eyẹwẹ naghiẹ-a shi odẹ, eghuo e kholo eyamhi naghiẹ-a shi odẹ.
\v 9 Eni ẹgbọ ni e ralo ali eni e kpe ukhokho e tsẹsẹ, e kuẹghiẹ ọli, e liẹ,
\q1 “Tsumhi anye, Tsumhi anye, Omi iDefidi!”
\q1 “Ikhivọsẹ khi ọni ọ ri eva oyi Ọnọmhuẹ bhale.”
\q2 Ikuẹghiẹ khi oyi Ẹshinẹgba.
\q1 “Tsumhi anye.”\f + \fr 21:9 \ft Li zẹ \fq Iwolo 118.25,26\f*
\p 
\v 10 Abi iJesu ọ rọ lo elemhi iJerusalẹmu, oni ẹdẹli nya o wushe-a, ẹgbọ e mhila, e liẹ, “Ọghuo ọni ọmọse onana ọ fẹ khi?”
\p 
\v 11 Eni ẹgbọ ni e nu ọli kia e gueyẹ wẹ, ẹẹ “Ọna khi iJesu ọni ọmekẹguele ọnge iNazarẹti na ekẹ iGalili, ni a shobọ na awa khi ọọ bhale, ikhi ọni awa migha khẹ.”\f + \fr 21:11 \ft Li zẹ \fq iJọn 6.14; 7.40; Ika 3.22; iMak 6.15; iLuk 13.33\f*
\s1 IJesu ọ lo elemhi Owa Oyi Ẹshinẹgba
\r (iMak 11.15-19; iLuk 19.45-48; iJọn 2.13-22)
\p 
\v 12 IJesu ọ lo elemhi Owa Oyi Ẹshinẹgba. Ọ khu ẹgbọ ni e la elemhi ọli ẹ du oki kua. Ọ ghino wẹ abọ itebu ni e la ngmomhi ikpaghọ kua, ali ibẹchi oyi eni e ri inekhukhu u ẹ dẹ.
\v 13 Ọọ wẹ “A she kẹkẹ ọli shi Ebe-no-pfuasẹ, ‘Owa oyẹmhẹ, owa ni a la lema o khi,’ ama a she rọli mele owa oyi ighiatọ-a.”\f + \fr 21:13 \ft Li zẹ \fq Aza 56.7; iJere 7.11\f*
\p 
\v 14 Ezalo ali eni e guọghọ awẹ-a e bhale deba li obini Owa Oyi Ẹshinẹgba, Ọ rẹwẹ ze nya.
\v 15 Abi ighie eyi ekpodalo-ugamhi ali esẹsẹ Ishi eyi iMosisi e rọ mẹ khi iJesu ọọ gbe ikanya ọnyaloa ọdọda, elemhi Owa oyi Ẹshinẹgba, ali khi eniyẹ e la akaghọ tsẹsẹ leghe kuẹghiẹ ọli, e liẹ, “Ikuẹghiẹ o khi oyi Omi iDefidi,” elemhi e bi wẹ.
\p 
\v 16 Ighọ e mhila iJesu, ẹ ọli “Wa a suọ abi eniyẹ ẹẹ ngme ẹ?”
\p IJesu ọọ, “Mhi suọ.” Ọ mhila wẹ, “Aa kpẹ suọ abi Ebe-no-pfuasẹ o ngme ni ọ.
\q1 “ ‘U she ri eniyẹ ali emọfẹ
\q2 kuẹghiẹ ikuẹghiẹ ni o gba pfo’ ”\f + \fr 21:16 \ft Li zẹ \fq Iwolo 8.2\f*
\p 
\v 17 IJesu ọ te aghọ vu je iBẹtani. Ọ gbhẹ aghọ ni ogbe o gbe.
\s1 IJesu ọ ku itsẹ na ọkhua-eni
\r (iMak 11.12-14,20-24)
\p 
\v 18 Ẹlẹ uzogbe abi ọ ke rọ nyenẹ egbe ukhokho je iJerusalẹmu, okiamhi o gbe ọli.
\v 19 Ighọ ọ mẹ ọkhua-eni epfẹ odẹ, ọ lẹ ya bino ọli, ama ọa mẹ udumhi okhọghuo ukhomhi ọ, sẹ ni ebebe. Ighọ ọọ oni ọara oghọ “Wa gbo ya mọ udumhi ghue!” Aghọaghọ oni ọara o ku ebe-a.
\p 
\v 20 Abi eni eniyẹ odukhokho eyọli e rọ mẹ ọli, abọ e sha wẹ. E mhila li, ẹẹ. “Sẹ o li kia khi oni ọkhua o rọ ghọ nyanya ku ebe-a?”
\p 
\v 21 IJesu ọọ wẹ, “Mhi gueyẹ ẹ khi, ini a mhuẹ irudunga ni aa rọ mhuẹ akhọkhọmhẹ, a ya dobẹ li emini mhi li oni ọkhua ona. Ọa khi onana tsẹ, a ya liẹ oni ute ona, ‘Vu ya de pfilo okẹ oniẹmhi,’ oni ute o suọ na ẹ.\f + \fr 21:21 \ft Li zẹ \fq iMat 17.20; 1 iKọri 13.2\f*
\v 22 Irari khi ini a mhuẹ irudunga, emiemini a sọ iromhi mhila a ya mhọli ọli.”
\s1 A mhila iJesu obini ọ te mhọli afu
\r (iMak 11.27-33; iLuk 20.1-8)
\p 
\v 23 IJesu ọ lo elemhi apfẹ oyi Owa oyi Ẹshinẹgba le, ighie eyi ekpodalo-ugamhi ali eni egbhali e mhila li, “Afu eyi ọghuo u rọ gbe ikanya enana? Ọghuo ọ ri afu nẹ?”
\p 
\v 24 IJesu ọọ wẹ, “Mhẹmhẹ mhi ya li mhila ẹ ogbọ oghuo, ini a da gbaghiẹ ọlia ne, mhi ya gueyẹ ẹ ọni ọ ri afu ona na mhẹ.
\v 25 Mhiẹ i, ibatazi ni iJọni ọọ batazi na ẹgbọ, ọghuo ọ ri afu na li ọ ke batazi ẹgbọ? Ẹgbọ e ri ọli na li abi khi Ẹshinẹgba lọ?”
\p E nu egbewẹ khakọ, e liẹ, “Ini awa ẹ khi ‘Obọ oyi Ẹshinẹgba o te bhale,’ ọ ya mhila awa, ‘Elọ o zẹ ni aa rọ mie ọli suọ?’
\v 26 Ama ini awa ẹ khi, ‘Obọ oyi ọgbọ o te bhale,’ ulishi apfọwa ọọ mu awa, irari khi ọgbọkpa ọ lẹsẹ khi ọmekẹguele iJọni ọ khi.”
\p 
\v 27 Itobọ ighọ e kẹ iJesu “Anye aa lẹsẹ.” IJesu ọọ wẹ “Mhẹmhẹ mhi aa li ya gueyẹ ẹ obini mhi te mẹ afu.”
\s1 Okhẹ irọkhọkhọ oyi eniyẹ aava
\p 
\v 28 “Sẹ a mẹ ona shi? Ọmọse ọghuo ọ mhuẹ eniyẹ emọse aava. Ọ bhale deba ọni ọgbhali, ọọ li, ‘Ọmọ ke lẹ ogba ipfonu amo ni u ya gbe akanya.’
\p 
\v 29 “Ọọ itali, ‘Mhi a ya ye.’ Ama o li dẹnẹ, ọ mu udu pfi, ọọ lẹ oni ogba ipfonu.
\p 
\v 30 “Ọni itawẹ ọ gbo lẹ deba ọnikeke, ọ gbo ngme ọli abi ọ kpẹ ngme ọni ọgbhali. Ọni ikeke ọghọ ọ lama khi lọli ya ye, ama ọa tigbe ye.
\p 
\v 31 “Ọnọghuo eniyẹ aava ena ọ riẹlẹ emini itawẹ ọ nono?”
\p Ẹẹ iJesu, “Ọni ọgbhali.”
\p IJesu ọọ wẹ, “Abi o li mhi li gue ọli ẹ yẹ ẹ khi emionoga ali idegbe e she pfi ẹ shi ana kpẹ lo Eghiele oyi Ẹshinẹgba.
\v 32 Irari khi abi iJọni Ọni ọọ batazi ẹgbọ ọ̀ọ́ bhale ya sẹsẹ ẹ odẹ ni a ya rọte, ni aa lama mie ọli suọ. Ama emionoga ali idegbe e mie ọli suọ, e mu pfi. Abi a tseku ri ẹloe oyẹẹ mẹ, aa kie mu udu pfi ni a miesuọ.\f + \fr 21:32 \ft Li zẹ \fq iLuk 3.12; 7.29-30\f*
\s1 Okhẹ irọkhọkhọ oyi eni a mie shi ogba ipfonu
\r (iMak 12.1-12; iLuk 20.9-19)
\p 
\v 33 “A suọ okhẹ irọkhọkhọ olese. Ọmhuẹ-apfẹ ọghuo ọ ya laọ ni ọ gua ogba ipfonu shi ukhokho apfẹ oyọli. Ọ khi ogba gasẹ ọli, ọ riẹlẹ ashini a la nye onyọ shi ọ, Ọ gbo tọ owa ni o yagha ni a la khẹ-ekhẹ shi ọ. Ọ rọli na ẹgbọ e ke ri ẹloe khu ọli, ọ vu ẹoli oboese.\f + \fr 21:33 \ft Li zẹ \fq Aza 5.1-2\f*
\v 34 Abi ẹghẹghẹ ikhiẹsẹ o rọ ramhi, ọ ghie eni ẹẹ ga eyọli ghi eni ẹgbọ, e ka mie wẹ eni e khi eyẹluẹ ghi luẹ.
\p 
\v 35 “Eni ẹgbọ ni ọ rọ shi oni ogba oghọ, e mu eni eni ẹẹ ga eyọli, e gbe ọghuo, e gbe ọghuo-a, e tono ọnọkpọle echẹ.
\v 36 Ighọ ọni ọmọse ọ gbo ghie eni ẹẹ ga elese ghi wẹ ni e ke bu dọsẹ eni ọ kpẹ ghie. Ighọ eni e la oni ogba e li wẹ abi e kpẹ li eghọ.
\v 37 Ikpukhokho ọ, ọ ghie omi ọli ghi wẹ. Ọọ, ‘E ya mu ekpẹ na li.’
\p 
\v 38 “Ama abi eni e la oni ogba e rọ mẹ khi ọni omi ọli ọọ bhale, e lu egbewẹ ochi, ẹẹ egbe, ‘Awa gbe ọni omi ọli-a, ni awa le ugu oyọli.’
\v 39 Ighọ e mu ọli e rue ọli je olase oni ogba, e gbe ọli-a.
\p 
\v 40 “Irarighọ, ini ọni ọ mhuẹ oni ogba ipfonu oghọ ọ fẹ bhale, sẹ ẹẹ a sa khi ọ ya li eni ẹgbọ eghọ?”
\p 
\v 41 Ẹẹ iJesu, “Eri ọ ya gbolo eni ẹgbọ ọkhọlọ eghọ-a, ọ ri oni ogba na ẹgbọ elese, eni e ya ke ri eni e khi eyọli ghi ọli.”
\p 
\v 42 IJesu ọọ wẹ, “Ẹẹ a kpẹ zẹ ọli abi a li kẹkẹ ọli shi Ebe-no-pfuasẹ khi:
\q1 “ ‘Ẹchẹ ni itsọna e kie pfia,
\q2 lọli o ke ya mele egbegbi ẹchẹ
\q2 ni o kẹ mu ẹloe nẹ nya-a.
\q1 Ọnọmhuẹ ọ lighọ riẹlẹ ona,
\q2 óó ti anye ẹloe gba’ ”\f + \fr 21:42 \ft Li zẹ \fq Iwolo 118.22-23\f*
\p 
\v 43 “Irarighọ, ighọ a li ya mie ẹ Eghiele oyi Ẹshinẹgba obọ, a rue ọli na ẹgbọ ni ẹ riẹlẹ emini Ẹshinẹgba ọọ a ke riẹlẹ.
\v 44 Ọgbọ ni ọ da ya de nga oni ẹchẹ ne, ọ ya guọghọ-a, ama ọgbọ ni oni ẹchẹ o da de nga egbe ne ọ ya mhẹli-a abi ifufu.”
\p 
\v 45 Abi ighie eyi ekpodalo-ugamhi ali ẹgbọ iFarisi e rọ suọ oni okhẹ irọkhọkhọ ona, e lẹsẹ khi wẹwẹ iJesu ọ nu ngme.
\v 46 E nono odẹ ni wẹwẹ e tẹ mu ọli ya khukhu, ama ulishi o mu wẹ irari khi ẹgbọ e lẹsẹ khi ọmekẹguele iJesu ọ khi.
\c 22
\s1 Okhẹ irọkhọkhọ oyi ukue ni á lá rue ọmueshi
\r (iLuk 14.15-24)
\p 
\v 1 IJesu ọ gbo ri okhẹ irọkhọkhọ ona nu wẹ ngme, ọọ,
\v 2 Eri Eghiele oyi Ẹshinẹgba o li abi oghie ọghuo ni ọ gbhẹ ukue na omiọli ni ọọ rue ọmueshi.
\v 3 Ọ ghie eni ẹẹ ga eyọli e ka gueyẹ ẹgbọ ni ọ gbhẹ oni ukue na e bhale, ama ẹa lama ye.
\p 
\v 4 “Ighọ ọ gbo ghie eni ẹẹ ga elese, ọọ wẹ, ‘A ka gueyẹ eni a lu shi oni ukue khi mhi she nye ekhe shi ekẹ. Mhi she gbolo ena-a, ena ni e mhuẹ ila, shi elamhakọ eyẹmhẹ, a she mu egbe emhikpa shi ekẹ. A bhale oni ukue ikhuẹsẹ ọmueshi.’
\p 
\v 5 “Ama eni ẹgbọ ẹa pfi esọ shi, e vu asha. Ọghuo ọ vu ishemhi, ọlese ọ vu oki.
\v 6 Eghuo ọ ni a lu shi oni ukue e mu eni eni ẹẹ ga eghọ, e gbe wẹ, e gbolo wẹ-a.
\v 7 Ighọ elemhi e bi ọni oghie, ọ ghie ekhọli-okhuẹ eyọli, e ka gbolo eni ẹgbọ ni e gbolo eni ẹẹ ga eyọli-a, e tosẹ wẹ apfẹ-a.
\p 
\v 8 “Ighọ ọni oghie ọ luno eni eni ẹẹ ga eyọli, ọọ wẹ, ‘A she mu egbe ukue oyẹmhẹ shi ekẹ se, ama ẹgbọ ni mhi lu shi ọ, ẹa khi eni a kha lu shi ọ.
\v 9 Mena, a ke je ifu ẹoli ikpe ni ebubu ẹgbọ e legba, ọgbọkpa ni a da mẹ ne, a lu ọli bhale oni ukue.’
\v 10 Ighọ eni eni ẹẹ ga e lo ifu ẹoli e luno ẹgbọ ni e mẹ kpa tigbili, ghe ẹgbọ enete ali ikhiakhiamhi ẹgbọ. Oni ashini a gbhẹ oni ukue shi o vọ ẹgbọ.
\p 
\v 11 “Ama abi ọni oghie ọ rọ bhale ya bino eni ẹgbọ, ọ mẹ khi ọmọse ọghuo ọ la aghọ ni ọa sọ itsua ukue ni a rọ khuẹsẹ ọmueshi ye ughuẹ.
\v 12 Ọni oghie ọ mhila li, ‘Ọmuẹ sẹ u li lo ana le ni u wa rọ sọ itsua oyi ukue ni a rọ khuẹsẹ ọmueshi,’ Ọni ọmọse ọa dobẹ sọli ọ.
\p 
\v 13 “Ighọ ọni oghie ọ gueyẹ eni eni ẹẹ ga eghọ, ‘A mu ọli gẹ abọ ali awẹ, a tsua li pfi je olase alo ebili ni a la viẹ, ni a la le akọ akọ.’\f + \fr 22:13 \ft Li zẹ \fq iMat 8.12; 25.30; iLuk 13.28\f*
\p 
\v 14 “Ọgbọkpa a lu ama ikuku wẹ ni e mie oni ulumhi, a zẹ.”
\s1 A mhila iJesu ini a ke zẹ oga na iSiza
\r (iMak 12.13-17; iLuk 20.20-26)
\p 
\v 15 Ighọ ẹgbọ iFarisi e fiẹ ya gba abi e li ya ri omhila mẹ asha mu iJesu.
\v 16 E ghie eniyẹ odukhokho eyẹwẹ ali eniyẹ odukhokho eyi Erọdu deba iJesu, ẹ ọli, “Ọsẹsẹ, anye lẹsẹ khi ọgbọ igẹsikia u khi, u gbolo ẹ sẹsẹ igẹsikia oyi ọghuẹmhẹ oyi Ẹshinẹgba. Wa a ya na ulishi oyi ọgbọkhọghuo, itobọ khi ẹgboliẹ ọa la ọnini ọgbọ ọ khi.
\v 17 Gueyẹ anye, sẹ o fẹ li udu oyẹ? Abi ushi oyawa o ngme, o fẹ ti ni awa zẹ oga na oghie iSiza abi khi ọa ti?”
\p 
\v 18 IJesu ọ lẹsẹ ugbamhi obe ni e gba, ọọ wẹ, “Ẹẹ eri ugamhi ku alo, elọ o zẹ ni a rọ nono ni a di mhẹ mu?
\v 19 A rue ukpaghuo ni a rọ zẹ oga khasẹ mhẹ ghue!” Ighọ e rue ukpaghuo bhale ghi ọli.
\v 20 Ọ mhila wẹ “Alo eyi ọghuo na? Eva oyi ọghuo na?”
\p 
\v 21 Ẹ ọli “Eyi iSiza.”
\p Ighọ iJesu ọọ wẹ, “Irarighọ, a ri oni o khi oyi iSiza na iSiza a ri oyi Ẹshinẹgba na Ẹshinẹgba.”
\p 
\v 22 Abi e rọ suọ ona, abọ e sha wẹ, e zẹ ọli obọ, e vu.
\s1 Ingme ughuẹ iruerue ali irọte eghuli guale
\r (iMak 12.18-27; iLuk 20.27-40)
\p 
\v 23 Oni ogbẹlẹ ẹlẹghọ, ẹgbọ iSadusi ni ẹ khi iteghuli guale ọa la ọ, e bhale deba iJesu ya mhila li ogbọ.\f + \fr 22:23 \ft Li zẹ \fq Ika 23.8\f*
\v 24 Ẹ ọli “Ọsẹsẹ, iMosisi ọ gueyẹ anye khi, ini ọmọse ọ ghu-a ni ọa rọ bia eniyẹ, inyọghuo ọli ọ rue ọni ọsamhi olimhi ni ọ bia eniyẹ na li na inyọghuo ọli ni ọ ghu-a ọghọ.\f + \fr 22:24 \ft Li zẹ \fq iDẹut 25.5\f*
\v 25 Mena inyọghuo etuoshilua e ke nu anye la ana. Ọni ọgbhali ọ rue ọkpotso ọ ghua, abi ọa rọ bia eniyẹ, ọ zẹ ọni ọkpotso obọ na inyọghuo.
\v 26 Ighọ eghuli o li gbe inyọghuo ọli ọnuzava ali ọnuzasẹ ya ramhi ọnuzi-oshilua ẹa ga bia ọmọ ọkhọghuo na ọni ọkpotso.
\v 27 Ikpukhokho ọ ọni ọkpotso ọ ghu a.
\v 28 Mena, ogbẹlẹ iteghuli guale, ughuẹ ọghuo ọ fẹ ya khi elemhi ẹwẹ nya, aborọkhia khi wẹwẹ oshilua e ga rue ọli shi?”
\p 
\v 29 IJesu ọọ wẹ, “Eri a da odẹ! Itobọ khi aa lẹsẹ ungmemhi oyi Ẹshinẹgba ali itoto eyọli lọ.
\v 30 Irari khi ini ẹgbọ e rọte eghuli guale, ẹa ke ya rue ikpotso, wẹ khi ikpotso e ke ya ke ngeli na emọse, eri e ke ya li abi igẹni na iloghie.
\v 31 Ama oyi ingme ite-eghuli-guale oyi ẹgbọ ni e ghu-a ne, eri aa suọ abi Ẹshinẹgba ọ ngme ẹ.
\v 32 Ọ khi, ‘Mhẹmhẹ mhi khi Ẹshinẹgba ọyi Aburaamu ali Ẹshinẹgba ọyi Aziki, ali Ẹshinẹgba ọyi iGiekọpu.’ Ẹshinẹgba ọyi ẹgbọ ni e la agbọ ọ khi, ọa khi Ẹshinẹgba ọyi ẹgbọ ni e ghua.”\f + \fr 22:32 \ft Li zẹ \fq Okiali 3.6\f*
\p 
\v 33 Abi eni ebubu ẹgbọ e rọ suọ ona, abọ e sha wẹ shi osẹsẹ ni ọ sẹsẹ.
\s1 Ushi ni o ga funẹ nya
\r (iMak 12.28-34; iLuk 10.25-28)
\p 
\v 34 Abi ẹgbọ iFarisi e rọ suọ khi iJesu ọ pfi ẹgbọ iSadusi okpẹ unu, e le gba.
\v 35 Ọghuo ọ elemhi wẹ ni ọ khi ọsẹsẹ ushi ọ rọshẹka ni lọli dobẹ ri ushi mu iJesu. Ọ mhila li ogbọ.
\p 
\v 36 Ọọ li, “Ọsẹsẹ, Ushi onoghuo o ga funẹ nya elemhi Ishi eyi iMosisi?”
\v 37 IJesu ọọ li, “ ‘Ri udu oyẹ nya ali ayẹmhẹ oyẹ nya ali usamhi udu oyẹ nya nono ingme oyi Ọnọmhuẹ Ẹshinẹgba ọyẹ.’\f + \fr 22:37 \ft Li zẹ \fq iDẹut 6.5\f*
\v 38 Onana o khi ushi onododẹ ali oni o ga fu nẹ nya.
\v 39 Eri onuzi-eva o gbo li abi lọli, ni ọọ li, ‘Nono ingme oyi ọgbọ ọlese abi u li nono ingme egbe ẹ.’\f + \fr 22:39 \ft Li zẹ \fq iLẹv 19.18\f*
\v 40 Ishi eva ena elemhi Ishi eyi iMosisi ali emekẹguele nya, e te zẹ.”\f + \fr 22:40 \ft Li zẹ \fq iLuk 10.25-28\f*
\s1 Omi ọghuo Ọmiepfuese ọ khi
\r (iMak 12.35-37; iLuk 20.41-44)
\p 
\v 41 Abi ẹgbọ iFarisi e kie li la aghọ eghọ, iJesu ọ mhila wẹ.
\v 42 “Sẹ a khọkhọ shi Ọmiepfuese ọ? Omi ọghuo ọ fẹ khi?”
\p Ẹ ọli “Omi iDefidi.”
\p 
\v 43 IJesu ọọ wẹ, “Elọ o ke ze khi iDefidi ọ rọte elemhi ayẹmhẹ lu ọli, ‘Ọnọmhuẹ’? Irari khi iDefidi ọ liẹ,
\q1 
\v 44 “ ‘Ọnọmhuẹ gueyẹ Ọnọmhuẹ ọyẹmhẹ.
\q2 Shitọ mhẹ ukiẹkiẹ obita ramhi
\q1 ni mhi rọ ya ri ebe ẹ
\q2 shi ẹ ufu ẹkowẹ.’\f + \fr 22:44 \ft Li zẹ \fq Iwolo 110.1; Ika 2.34-35; Iburu 1.13; 10.13\f*
\p 
\v 45 “Ini iDefidi ọ lu ọli ‘Ọnọmhuẹ,’ sẹẹ ọni Ọmiepfuese ọ ke gbolo ẹ khi omiomi iDefidi?”
\v 46 Ọngẹwẹ ọa dobẹ gbaghiẹ oni ogbọ-a. Rọte ẹlẹghọ vu ọgbọ okhọghuo ọa ke gbo gbudu mhila li ogbọ okhọghuo.
\c 23
\s1 A mhuẹ ẹgbhẹ shi esẹsẹ Ishi eyi iMosisi ali iFarisi egbe
\r (iMak 12.38-39; iLuk 11.43,46; 20.45-46)
\p 
\v 1 Ighọ iJesu ọ nu ẹgbọ ni e ri esọ shi ọli ekẹ ali eniyẹ odukhokho eyọli i ngme.
\v 2 Ọọ wẹ, “Esẹsẹ Ishi eyi iMosisi ali ẹgbọ iFarisi a ri afu na ni e ke guele abi Ushi oyi iMosisi o ngme.
\v 3 Irarighọ, a mema ya suọ esọ na wẹ, a li abi e gueyẹ ẹ a ke li, ama a khi khọnya wẹ ngeli ingeli enabi eyẹwẹ. Irari khi wẹwẹ ẹa ri emini ẹẹ sẹsẹ ẹgbọ gbe akanya.
\v 4 Eri ẹ gẹ itsua ni e khọ na ẹgbọ tsua. Ama wẹwẹ ọyẹwẹ ẹa lama ri umiesobọ da wẹ ọ kpaghiẹ wẹ tsua eni itsua.
\p 
\v 5 “Emhikpa e ri abamẹmhẹ ẹ riẹlẹ. E ri ọgbẹnẹ ni a fia ọtsuọtsuọ shi mu alukpo ali abọ. E pfi emini a rọte ebe-no-pfuasẹ kẹkẹ emhi shi lo eni ọtsuọtsuọ. E gbo fia emhi na yayagha na dọlọdọlọ shi esọ iwulu ni ẹẹ sọ.\f + \fr 23:5 \ft Li zẹ \fq iMat 6.1; iNọba 15.38; iDẹut 6.8\f*
\v 6 Ashini o mhuẹ ekpẹ ukue ali ikpẹkhomhi ni e funẹ ọọ ghọle wẹ ini e bhale owa ugamhi.
\v 7 E ma nono ni a ke tsẹ wẹ otsẹ ekpẹ atuoki, ali ni a gbo ke lu wẹ, ‘Ọsẹsẹ.’
\p 
\v 8 “Ama ẹẹ ọyẹ ẹ a khi lama ni ẹgbọ e lu ẹ ‘Osẹsẹ,’ irari khi Ọga ọghuo ọ ga mhọli ẹ nya, a gbo khi inyọghuo.
\v 9 A khi lu ọgbọkhọghuo agbọ ona ‘Ita,’ irari khi Ita ọghuo kpe a mhuẹ, iloghie ọ la.
\v 10 Wẹ khi a zẹ ni ọgbọ ọ lu ẹ ‘Ọsẹsẹ,’ irari khi Ọsẹsẹ ọghuo kpe a mhuẹ ni ọ khi iKirisiti.
\v 11 Ọni ọ ga funẹ elemhi ẹ, ọ mema mele ọni ọọ ga ọyẹẹ a.\f + \fr 23:11 \ft Li zẹ \fq iMat 20.26-27; iMak 9.35; 10.43-44; iLuk 22.26\f*
\v 12 Ọnini ọ da ya ti egbọli nga ne, a ya ti ọli tiemhile. Ama ọnini ọ da ti egbọli tiemhile ne, a ya ti ọli nga.\f + \fr 23:12 \ft Li zẹ \fq iLuk 14.11; 18.14\f*
\p 
\v 13 “O ma khọlọ ẹ egbe, ẹẹ esẹsẹ Ishi eyi iMosisi ali ẹgbọ iFarisi erugamhi-ku-alo, ni e pfi okpẹ odẹ iloghie zuse ẹgbọ shi olase. Ẹẹ oyẹẹ na, aa lama lo elemhi ọ wẹkhi eri a zẹ ni eni ẹ nono ni wẹwẹ e lo, ni e mẹ asha le.
\v 14 [O ma khọlọ ẹ egbe, ẹẹ esẹsẹ Ishi eyi iMosisi ali ẹgbọ iFarisi! Ẹẹ eri-ugamhi ku alo! Eri a li esamhi olimhi le, ni a ri abamẹmhẹ a sọ iromhi ni o nuata. Itobọ ighọ a ya na ẹ osoli egbegbọ.]
\p 
\v 15 “O ma khọlọ ẹ egbe, ẹẹ esẹsẹ Ishi eyi iMosisi ali ẹgbọ iFarisi erugamhi-ku-alo! A ga rọshẹka kia ekẹ ali ukhomhi okẹ ye obini odonuẹ ya nono ọgbọ mu pfi lama shi osẹsẹ oyẹẹ. O kha da tsẹ na ẹ se, osoli ni ọni ọgbọ ọghọ ọ ke ya mẹ ilimhi iriẹriẹ, o ke fu dọsẹ oni ẹẹ a ya mẹ agbhagbhamhi eva.
\p 
\v 16 “O ma khọlọ ẹ egbe irari khi ezalo a khi ni a sẹsẹ ẹgbọ. Ẹẹ ni a sẹsẹ khi, ‘Ini ọgbọ ọ romhi Owa Oyi Ẹshinẹgba ọa mhuẹ abi o ngme, ama ini ọ romhi igolu ni o la ukhomhi oni Owa Oyi Ẹshinẹgba, oni ishe o ya mu ọli.’
\v 17 Ẹẹ eyẹghẹ, ezalo, onoghuo o fẹ funẹ? Igolu abi Owa oyi Ẹshinẹgba ni o ri oni igolu rọ khi oni o pfuasẹ?
\v 18 A gbolo ẹ sẹsẹ ẹgbọ khi ini ọgbọ ọ romhi atẹtẹ khi ọa mhuẹ abi o ngme, ama ọ khada romhi emini a rọ luasẹ oni atẹtẹ, oni ishe o ya mu ọli.
\v 19 Ẹẹ ezalo, onoghuo o fẹ funẹ? Emini a rọ luasẹ obo ni o la ukhomhi oni atẹtẹ abi oni atẹtẹ ni o ri oni iluasobo khi oni o pfuasẹ?
\v 20 Itobọ ighọ, ini ọgbọ ọ da romhi atẹtẹ ne, oni atẹtẹ ali emini o la ukhomhi ọli nya ọ romhi eghọ.
\v 21 Ini ọgbọ ọ romhi Owa Oyi Ẹshinẹgba, oni Owa Oyi Ẹshinẹgba ali Ẹshinẹgba ni ọ la ọ ọ romhi eghọ.
\v 22 Ini ọgbọ ọ romhi iloghie, ukpẹkhomhi oyi Ẹshinẹgba ali ọni ọ shitọ ọ ọ romhi eghọ.\f + \fr 23:22 \ft Li zẹ \fq Aza 66.1; iMat 5.34\f*
\p 
\v 23 “O ma a khọlọ ẹ egbe, ẹẹ esẹsẹ Ishi eyi iMosisi ali ẹgbọ iFarisi. Ẹẹ erugamhi-ku-alo. Aa zẹ azẹ-oghuo-igbe oyi ebe akhọkhọ ali okphasa, ama a ri ẹloe ẹ gbe emini e mu ẹloe shi elemhi ishi, nabi, umha gbe azẹba ali isomhelemhi ali igbe akanya te ode igẹsikia. Enana khi egbegbi emini a kha riẹlẹ, aa kha pfi enana shi ekẹ ni aa riẹlẹ wẹ.\f + \fr 23:23 \ft Li zẹ \fq iLẹv 27.30\f*
\v 24 Ẹẹ ezalo ni a ri ẹgbọ ọ kia, a pfiolo akia onyọ-a, ama a to akphẹrẹ luẹ.
\p 
\v 25 “O ma a khọlọ ẹ egbe, ẹẹ esẹsẹ Ishi eyi iMosisi ali ẹgbọ iFarisi, erugamhi-ku-alo. A kpe ukhokho iko ali itasa-a, ama emini a ri emhi itoegbe ali ufa mie e vọ elemhi wẹ.
\v 26 Ẹgbọ iFarisi ezalo! A kpẹ ke kpe elemhi uko ali utasa-a ne, ẹghẹghẹ aghọ ikhokho wẹ e li pfuasẹ.
\p 
\v 27 “O ma a khọlọ ẹ egbe, esẹsẹ Ishi eyi iMosisi ali ẹgbọ iFarisi, erugamhi-ku-alo. Eri a li abi uji ni a ri ẹtseli opfopfo gbolo-a, ni o te odato ọli ti ẹloe, ama elemhi wẹ, e vọ igua ẹgbọ ni e ghu-a ni e kẹ-a.\f + \fr 23:27 \ft Li zẹ \fq Ika 23.3\f*
\v 28 Ighọ a lili ẹ li, eri a rọte odato idiegbe ga li abi egbegbi ẹgbọ, ama ọkhọlọ ali irugamhi ku alo, o vọ ẹ elemhi.
\s1 IJesu ọ gue anasẹmhẹ oyẹwẹ le shi ekẹ
\r (iLuk 11.47-51)
\p 
\v 29 “O ma a khọlọ ẹ egbe ẹẹ esẹsẹ Ishi eyi iMosisi ali ẹgbọ iFarisi, erugamhi-ku-alo! A ga tọ iji na emekẹguele a riẹlẹ iji eyi eni e guẹ ngeli somhotse.
\v 30 A gbolo ọ liẹ, ‘Ini anye la agbọ ẹghẹghẹ oyi itita anye lọ, anye a kha nu wẹ mhọli obọ shi emekẹguele igbolo-a.’
\v 31 Eri a ri ona pfi ọtsẹlẹ mu egbe ẹ khi a lama shi ọ khi imimi eni e gbolo emekẹguele-a, a khi.
\v 32 A ke je odalo, ni a pfuse gbe ikanya ni ititaẹ e gbaekẹle gbe.
\p 
\v 33 “Ẹẹ enyẹ ali imi enyẹ, sẹ a dabi khi a li ya na pfue ilimhi iriẹriẹ ni ọọ bhale?\f + \fr 23:33 \ft Li zẹ \fq iMat 3.7; 12.34; iLuk 3.7\f*
\v 34 Itobọ ighọ mhi ya gueyẹ ẹ khi mhi ya ghie emekẹguele ghi ẹ ali ẹgbọ ni e fialo-a ali esẹsẹ ni e bu, a ya gbolo eghuo ọ-a, a tanọ wẹ ma apfida, elese a gbe wẹ itẹ elemhi owa ugamhi eyẹ ẹ, a khu wẹ te ẹoli oghuo ya je olese.
\v 35 Itobọ ighọ a ya ri ọlia eyi ẹgbọ eni e pfuasẹ nya ni a gbolo-a shi ekẹ agbọ ona mu ota sọ ẹ, rọte idiegbe oyi Ebẹli ni ọa mhuẹ abi ọ li vu, ya ramhi idiegbe oyi iZakaraya omi iBẹrẹkaya ni a gbe-a shi agadamhi eva atẹtẹ ali Owa Oyi Ẹshinẹgba.\f + \fr 23:35 \ft Li zẹ \fq Igbae 4.8; Iburu 11.4; iZaka 1.1; 2 Okhẹ 24.21\f*
\v 36 Abi o li mhi li gue ọli ẹ yẹ ẹ khi, osoli ni a ya mẹ shi ugbeli ni a gbe idiegbe oyi ẹgbọ eghọ, ẹgbọ na agbhotu ona oni osoli o ya de rughu.”
\s1 Inono ni iJesu ọ mhuẹ na iJerusalẹmu
\r (iLuk 13.34-35)
\p 
\v 37 IJesu ọ rọ liẹ, “Eekhue-oo! IJerusalẹmu, iJerusalẹmu! A gbolo emekẹguele-a, a tono eni Ẹshinẹgba ọ ghie ghi ẹ echẹ gbolo-a. Iti-ingmi-ingmẹ mhi she rọshẹka ni mhi kolo ẹgbọ eyẹ ẹ kugbe, abi ọkhọkhọ ọ liẹ kolo imiọli shi ifui ipfua, ama aa lama na mhẹ.
\v 38 Ghe i! Ẹshinẹgba ọ ya te Owa oyi Ẹshinẹgba oyẹ ẹ vu, o mele afuẹ a.\f + \fr 23:38 \ft Li zẹ \fq iJere 22.5\f*
\v 39 Mhi gueyẹ ẹ khi rọte memena vu, khi aa ke gbolo ya mẹ mhẹ ya ramhi ni ẹghẹghẹ ni a rọ ya ke liẹ, ‘Oghẹlẹ o khi ni ọni ọ ri eva oyi Ọnọmhuẹ bhale.’ ”\f + \fr 23:39 \ft Li zẹ \fq Iwolo 118.26\f*
\c 24
\s1 Ọlẹlẹ oyi ikpukhokho agbọ
\r (iMak 13.1-2; iLuk 21.5-6)
\p 
\v 1 Abi iJesu ọ rọte oni Owa oyi Ẹshinẹgba fiẹ lasele, eniyẹ odukhokho eyọli e rọli khasẹ ugbe oyi oni owa.
\v 2 IJesu ọ rọ wẹ, “A ga mẹ emhi enana nya, ama mhi gue a yẹ ẹ khi aa mẹ ẹchẹli ni a rọ nga egbe egbe rọ tọ oni owa ona ni aa ya che kua.”
\s1 Ozughu ali imu-okhọli vule
\r (iMak 13.3-13; iLuk 21.7-19)
\p 
\v 3 Abi iJesu ọ li shitọ ukhomhi Ute ẹẹra Olivu, eniyẹ odukhokho eyọli e bhale ya ye ọli ochi, ẹẹ ọli. “Gueyẹ anye ẹghẹghẹ ni eni ingme enana e rọ bhale ya tsẹ, ali emini a ya ke mẹ ni anye rọ ya lẹsẹ khi a she ramhi ukpẹsẹ agbọ.”
\p 
\v 4 IJesu ọ sọ wẹ ọ, ọọ. “A ke tọkpẹ ekẹ ini ọgbọkhọghuo ọ khi di ẹ.
\v 5 Irari khi ebubu ẹgbọ e ya ri eva oyẹmhẹ bhale, ẹẹ liẹ ‘Mhẹmhẹ mhi khi ọni iKirisiti,’ ẹẹ di ebubu ẹgbọ.
\v 6 A ya suọ eko okhọli ali okeke okhọli. Ama a khi zẹ ni ulishi o mu ẹ. A mema ya mẹ emhi eghọghọ, ama ukpẹsẹ agbọ ọa kie ramhi ne.
\v 7 Ushishi e ya mu okhọli vule shi ushishi ọ, ẹgbọ e mu egbe iku iku nu egbe ẹ khọli. Ukpokpomhi okiamhi o ya ke pfi, ekẹ e ya ke dekuluẹ asha khi asha.
\v 8 Eri enana nya e ya li abi khi oku o lẹsẹ to ọkpotso ni ọ ya bia.
\p 
\v 9 “Ẹghẹghẹ aghọ a ya mu ẹ na wẹ ni e nasẹ ẹ, a gbolo ẹ-a. Ẹgbọ na agbọ nya e ya ke biselemhi ẹ, itobọ khi a khi ẹgbọ eyẹmhẹ.\f + \fr 24:9 \ft Li zẹ \fq iMat 10.22\f*
\v 10 Ẹghẹghẹ aghọ ebubu ẹgbọ e ya de irudunga lasele, e ri egbe ẹ dẹ, ẹẹ biselemhi egbe.
\v 11 Ẹghẹghẹ aghọ ebubu emekẹguele eyi ẹgbhọli e ya lasele, ẹẹ di ebubu ẹgbọ.
\v 12 Irari khi ọkhọlọ o ya gba ekẹ dọsẹ, imhuẹ-inono na egbe ọa ke lolo ẹ la ọ.
\v 13 Ama ọgbọ ni ọ da migha irudunga oyọli gbagbagba ramhi ukpẹsẹ, ọ ya khi ọni a mie pfuese.\f + \fr 24:13 \ft Li zẹ \fq iMat 10.22\f*
\v 14 A ya she ri oni usomhi onete oyi oni Eghiele oyi Ẹshinẹgba onana, tse abọ gasẹ agbọ kpa, ni o khi ọtsẹlẹ na ishishi nya, ẹghẹghẹ aghọ ukpẹsẹ agbọ o tigbe ramhi.
\s1 Ighuighuẹ
\r (iMak 13.14-23; iLuk 21.20-24)
\p 
\v 15 “ ‘Irarighọ, a kha da mẹ emhi obe ni o vẹsẹ ẹgbọ ọ kua khi ighuighuẹ ni ọọ vẹsẹ ẹgbọ kua, ni oo pfi ebemulishi, khi o da ya migha ashini o pfuasẹ ne,’ ẹzẹzẹ abi ọmekẹguele iDaniẹ ọ gue ọli le ne, ọni ọọ zẹ ebe ọ lẹsẹ emini ọ zẹ.\f + \fr 24:15 \ft Li zẹ \fq iDan 9.27; 11.31; 12.11\f*
\v 16 Ẹghẹghẹ aghọ, ẹgbọ ni e la ekẹ iJudia e na ya nga ukhomhi ite.
\v 17 Ọgbọ ni ọ la ukhomhi owa ọ khi tiemhile ya rue emhikhọghuo elemhi owa.
\v 18 Ọgbọ ni ọ la ishemhi ọ khi jele apfẹ ya rue awulu oyọli apfẹ.\f + \fr 24:18 \ft Li zẹ \fq iLuk 17.31\f*
\v 19 O ma khọlọ ikpotso ni ẹ mẹ egbe ali eni e ri emọfẹ shi egbe.
\v 20 A lema Ẹshinẹgba ọ khi zẹ ni ẹlẹ unamhi oyẹẹ o khi ẹghẹghẹ oruẹ wẹkhi ogbẹlẹ iyẹmhẹa.
\v 21 Irari khi osoli oniẹmhi o ya lasele ọ. Osoli ni ọgbọ aa kpẹ mẹ ghue rọte igbaekẹle agbọ ya ramhi ogbe ni amo, wẹkhi eri a ke gbolo ya mẹ oghọghọ ghue.\f + \fr 24:21 \ft Li zẹ \fq iDan 12.1; Irọ 7.14\f*
\v 22 Ini aa rọte eni ogbẹlẹ eni a ngme ena khi-a, ọgbọkhọghuo ọa ya pfue ọ. Ama itobọ oyi ẹgbọ ni Ẹshinẹgba ọ zẹ, ọ ya khi eni ogbẹlẹ-a.
\v 23 Ẹghẹghẹ aghọ, ini ọgbọkhọghuo ọọ u, ‘Bino, ghe ọni iKirisiti!’ Okekhia khi eri ọ li, ‘Ghe ọli oobọ khẹ,’ khi mie ọli suọ.
\v 24 Irari khi iromhi emiepfuese ali emekẹguele eyi ẹgbhọli e ya lasele, ẹẹ ri ọlẹlẹ eniẹmhi ẹ khasẹ, ali ẹẹ gbe ikanya ọnyaloa rọ ke di egbegbi eni Ẹshinẹgba ọ zẹ, ini o ya zẹ li lọ.
\v 25 A ghe i, eri mhi gue onana yẹ ẹ shi ekẹ neni oni ẹghẹghẹ o ya ramhi.
\p 
\v 26 “Ighọ, ini ọgbọkhọghuo ọ gueyẹ ẹ, ‘Ghe ọli oobọ, obini ọdagbe ifufu,’ a khi je oobọ. Okekhia khi eri ọọ, ‘Ghe ọli ana, elemhi owa aza,’ a khi mie ọli suọ.
\v 27 Irari khi eri inyenegbe bhale oyi Omi Ọgbọ o ya li abi akphala o liẹ nyamhise alo nyaa, o rọte udi ukhuli gẹ ya je udi ukhuli, rọte obini ovọ o te ẹ ngale ya je obini o te ẹ lo eko.\f + \fr 24:27 \ft Li zẹ \fq iLuk 17.23-24\f*
\v 28 Itobọ khi ashini elamhakọ ọ kẹ-a shi aghọ ighuli ẹẹ legba.\f + \fr 24:28 \ft Li zẹ \fq iLuk 17.37\f*
\s1 Inyenegbe bhale oyi Omi Ọgbọ
\r (iMak 13.24-27; iLuk 21.25-28)
\p 
\v 29 “Ẹghẹghẹ osoli oghọ o kha da lẹsẹ dọsẹ tee,
\q1 “ ‘Ovọ o ya bishi alo-a,
\q2 uki ọa kẹ gẹ
\q1 ikpẹtata e deno ukhuli kule,
\q1 ekpabọ ena ukhuli ẹẹ nighise.’\f + \fr 24:29 \ft Li zẹ \fq Irọ 8.12; Aza 13.10; Ezik 32.7; iJọẹ 2.10-11,31; 3.15; iZef 1.15; Aza 13.10; 34.4; Irọ 6.12-13\f*
\p 
\v 30 “Ẹghẹghẹ aghọ, ọlẹlẹ irọkhasẹ oyi Omi Ọgbọ o ya lasele shi ukhomhi idane. Ẹgbọ ni e la agbọ ona nya, e ya ke viẹ oya abi Omi Ọgbọ ọ li rọte irarogbe ẹ tiemhile elemhi ekpabọ ali ukpokpomhi ufumhi.\f + \fr 24:30 \ft Li zẹ \fq iDan 7.13; iZaka 12.10-14; Irọ 1.7\f*
\v 31 Ẹghẹghẹ aghọ akala onofunẹ o ya de. Omi Ọgbọ ọ ghie igẹni eyọli je iguabọ enenene na ekẹ agbọ nya, e ka ti ẹgbọ eyọli ni ọ zẹ gbili.\f + \fr 24:31 \ft Li zẹ \fq 1 iKọri 15.52; 1 iTẹsa 4.16; Aza 27.13; iZaka 9.14\f*
\s1 Owẹna ni a te ọọra ọkhua-eni wẹna
\r (iMak 13.28-31; iLuk 21.29-33)
\p 
\v 32 “A zẹ ni ọara ọkhua o sẹsẹ ẹ ingme. Ini iguabọ eyọli e da tsọtsọghọ ne, ni o rọ ta ebe, a lẹsẹ khi okasẹ o she ramhi.
\v 33 Ighọ ini a da mẹ emini mhi gue ẹ yẹ ena ne, a lẹsẹ khi oni ẹghẹghẹ o she ti ramhi ana.
\v 34 Abi o li mhi li gue ẹ yẹ ẹ khi agbhotu ona ọa ya dọsẹ ne, ni emhi ena nya e rọ bhale ya tsẹ.
\v 35 Ekẹ ali ukhuli e ya dọsẹ, ama ingmemhi eyẹmhẹ, ẹa ya de kua.
\s1 Ọgbọ ọa lẹsẹ oni ogbẹlẹ wẹkhi oni ẹghẹghẹ
\r (iMak 13.32-37; iLuk 17.26-30,34-36)
\p 
\v 36 “Ọgbọkhọghuo ọa lẹsẹ oni ogbẹlẹ wẹkhi oni ẹghẹghẹ. Egbegbi igẹni na iloghie ẹa lẹsẹ wẹkhi Omi Ọgbọ ọ lẹsẹ, sẹ ni Ita lọlighuo tsẹ.
\v 37 Abi o ke li ẹghẹghẹ oyi iNoa, ighọ ibhale oyi Omi Ọgbọ o ya li.\f + \fr 24:37 \ft Li zẹ \fq Igbae 6.5-8\f*
\v 38 Neni a mẹ ogbẹlẹ oyi ochikpho oniẹmhi, eri ẹgbọ e le, e da, eghuo e wolọ ikpotso, a ri ikpotso ye ughuẹ, ya ramhi ogbẹlẹ ni iNoa ọ rọ mu ọkọ-okẹ oniẹmhi nga,
\v 39 Ama ẹa kie lẹsẹ emini a ya mẹ ramhi ni ochikpho o rọ bhale ya tsua wẹ kua nya. Ighọ ibhale oyi Omi Ọgbọ o ya li.\f + \fr 24:39 \ft Li zẹ \fq Igbae 7.6-24\f*
\v 40 Emọse aava e ya la ishemhi ke gbe akanya, a rue ọghuo vu, a zẹ ọni ọ kpọle obọ.
\v 41 Ikpotso aava e ya la iko ke mhẹli emhi, a rue ọghuo vu, a zẹ ọni ọ kpọle obọ.
\p 
\v 42 “A ri ukpẹloe shi ekẹ irari khi aa lẹsẹ ẹlẹ ni Ọnọmhuẹ ọyẹ ẹ ọ ya bhale.
\v 43 A lẹsẹ khi ini ọmhuẹ-apfẹ ọ lẹsẹ ẹghẹghẹ ni ighiatọ e rọ ya do ọli lọ, eri ọ ya shitọ ni ogbe o gbe-a. Ọa ya zẹ ni ighiatọ e gbe ọli odẹ-a lo owa le.
\v 44 Itobọ ighọ, a mema ya mu egbe shi ekẹ, irari khi ẹghẹghẹ ni aa sa shi, Omi Ọgbọ ọ rọ ya bhale.
\s1 Ọni ọ guẹ ẹẹ ga ali ọni ọa guẹ ẹẹ ga
\r (iLuk 12.41-48)
\p 
\v 45 “Ọghuo ọ fẹ khi ọni ọọ ga ni ri egbe ẹ nga ni ọ lẹsẹ ingme. Ni ọga ọyọli ọ zẹ kpeda na eni ẹẹ ga eyọli, ọ ri ẹloe khu ọmhọapfẹ oyọli, ni ọ ke ri emhi na wẹ le shi ẹghẹghẹ?
\v 46 Oghẹlẹ o khi na ọni ọọ ga ọghọ ini ọga ọyọli ọ jele ya ẹ khi ọọ riẹlẹ emini ọ mhẹsẹ na li.
\v 47 Abi o li mhi li gue ẹ yẹ ẹ khi ọga ọyọli ọ ya ri emini ọ mhọli nya nga li obọ.
\v 48 Ama ini ọ khi ọni ọọ ga ni ọa ya suọ esọ lọ, eri ọ ya ke gueyẹ egbọli, ‘Ọga ọyẹmhẹ ọ ya la oobọ tẹsẹ,’
\v 49 Ọọ gbe eni ẹẹ ga ni e kpọle, ọ le, ọ deba edonyọ a da onyọ kia kia.
\v 50 Ọga ọyi ọni ọọ ga ọghọ ọ ya jele apfẹ ogbẹlẹ ali ẹghẹghẹ ni ọni ọọ ga ọghọ ọa sa shi.
\v 51 Ọni ọga ọyọli ọghọ ọ ya nasẹ ọli agbọagbọ, ọ rọli je asha ni a ri erugamhi-ku-alo shi. Aghọ ọ la ke viẹ ọ le akọ akọ.”\f + \fr 24:51 \ft Li zẹ \fq iLuk 12.39-46; 1 iTẹsa 5.2; Irọ 3.3; 16.15; 2 iPit 3.10\f*
\c 25
\s1 Okhẹ irọkhọkhọ imueshi ogbe ni ẹa mẹ ọmọse ghue
\p 
\v 1 “Ẹghẹghẹ ni a ngme ena, eri Eghiele oyi Ẹshinẹgba o ya li abi imueshi etuogbe ni ẹa mẹ ọmọse ghue, ni e ya rue ikpa eyẹwẹ, ni e vu ya a lu ọmọse ọni ọọ rue ọmueshi ọnọgbọ odẹ.\f + \fr 25:1 \ft Li zẹ \fq iLuk 12.35\f*
\v 2 Imueshi oshe elemhi wẹ e khi eyẹghẹ, oshe eni e kpọle e khi elẹsingme.
\v 3 Eyẹghẹ ni e la ọ, e wolọ ikpa eyẹwẹ ama ẹa sato tsua oili olese shi emhi.
\v 4 Elẹsingme ni e la ọ, e wolọ ikpa, gbo diẹ oili olese shi emhi.
\v 5 Abi ọni ọmọse ni ọọ rue ọmueshi eghọ ọa rọ kẹlẹ ẹ bhale, eni imueshi nya e ri ukhomhi bọ, olesẹ o dọwẹ rue.
\p 
\v 6 “Abi itsotsogbiẹ rọ mu ekẹ, uruli o de leghe, ọọ, ‘A ghe khẹ! Ọni ọọ rue ọmueshi ọ she ẹ bhale o! A vule ni a ya lu ọli odẹ!’
\p 
\v 7 “Ighọ eni imueshi e ti vule, e ti ikpa eyẹwẹ ngale.
\v 8 Ama ikpa eyi eyẹghẹ ni e la ọ, e ẹa ke dobẹ lala. E lẹ deba eni e khi elẹsingme, ẹẹ wẹ, ‘A kpẹkpẹ a te oili oyẹẹ diẹ na anye irari khi ikpa eyanye e she ẹ pfua.’
\p 
\v 9 “Ighọ imueshi elẹsingme eghọ, ẹẹ wẹ, ‘Iiye e! Oni anye mhuẹ ena ọa ya lo anye ni o gbolo lo ẹ ọ. A lẹ deba eni e ri oili ẹ dẹ ya dẹ.’
\p 
\v 10 “Ighọ eni imueshi eyẹghẹ oshe eghọ, e le deba eni e rọ dẹ ya a dẹ. Abi e rọ vu ya dẹ oni oili, ọni ọọ rue ọmueshi ọ lole. Eni imueshi oshe ni e mu egbe oili olese eghọ e deba li lo elemhi owa ukue. A khukhu odẹ.
\p 
\v 11 “O ke li dẹnẹ, enekpọle e bhale, é ya kpheli odẹ, e liẹ, ‘Ọga! Ọga! Khueghie odẹ-a na anye.’
\p 
\v 12 “Ama ọni ọọ rue ọmueshi ọghọ, ọọ wẹ, ‘Abi o li mhi li gue ẹ yẹ ẹ, mhi aa lẹsẹ ẹ.’\f + \fr 25:12 \ft Li zẹ \fq iLuk 13.25\f*
\p 
\v 13 “Irarighọ, a ri ẹloe shi ekẹ, itobọ khi aa lẹsẹ oni ogbẹlẹ wẹ khi oni ẹghẹghẹ.
\s1 Okhẹ irọkhọkhọ oyi eni ẹẹ ga etuasẹ
\r (iLuk 19.11-27)
\p 
\v 14 “Ẹghẹghẹ aghọ, eri Eghiele oyi Ẹshinẹgba o ya li abi ọmọse ọghuo ni ọọ vu asha, ni ọ lu eni ẹẹ ga eyọli, ọ ri ẹpfue eyọli nga wẹ obọ.
\v 15 Ọ kemhi ikpaghọ na ọgbọgbọ abi e li mhuẹ afu ramhi. Ọ ri ikpẹshe na ọghuo, ọ ri ikpẹva na ọlese. Ọ ri ukpaghuo na ọnọkpọle. Ọ vu ẹoli.
\v 16 Ọni ọga ọ lẹsẹ vu se, ọni ọ mie ikpẹshe eghọ, ọ nyanya ya ri ikpẹshe eyọli du oki, ọ mẹ eleli ikpẹshe elese nga ọ.
\v 17 Ighọ ọni ọ mhuẹ ikpẹva eghọ, ọ li ri eyọli du oki, ọ li mẹ eleli ikpẹva elese nga ọ.
\v 18 Ama ọni a ri ukpaghuo na eghọ, ọ vu ya tọ oni ukpaghọ ekẹ sọ.
\p 
\v 19 “O tẹsẹ, ọni ọga ọyẹwẹ ọ jele. Ọ lu wẹ ọgbọgbọ ọ bhale ya guele abi ọ li gbe.
\v 20 Ọni ọọ ga ni ọ mhuẹ ikpẹshe eghọ, ọ bhale deba ọga ọyọli, ọọ, ‘Ọga, ikpẹshe u rọ na mhẹ, ama mhi she rọli du oki, mhi mẹ ikpẹshe eleli.’
\p 
\v 21 “Ọni Ọga ọyọli ọọ li, ‘Mu akanya, yẹyẹ ọni ọọ ga ọnete ni ọ mhuẹ igẹsikia! U she ri igẹsikia khasẹ shi ukuku emini mhi rọ ngẹẹ obọ, mhi ya ri emini e bu ngẹẹ obọ. Bhale ni awa ga la oghẹlẹ!’
\p 
\v 22 “Ighọ ọni a ri ikpẹva na eghọ, ọọ li, ‘Ọga, ikpẹva u rọ na mhẹ, mhi she mẹ eleli ikpẹva.’
\p 
\v 23 “Ọni ọga ọyọli ọọ li, ‘Mu akanya, yẹyẹ ọni ọọ ga ọnete ni ọ mhuẹ igẹsikia! U she ri igẹsikia khasẹ shi ukuku emini mhi rọ ngẹẹ obọ. Mhi ya ri emini e bu ngẹẹ obọ. Bhale ni awa ga la oghẹlẹ!’
\p 
\v 24 “Ighọ ọni ọ mie ukpaghuo eghọ ọ bhale, ọọ li, ‘Ọga, mhi lẹsẹ khi uwali ọgbọ u khi; khi ashini u waa gua shi wa je ya khiẹsẹ, ali khi ashini u waa ri ukpamhi kọ, u je ya tima.
\v 25 Itobọ ighọ eri ulishi oyẹ oo mu mhẹ, lọli o zẹ ni mhi rọ ya tọ ikpaghọ eyẹ ekẹ sọ. Ghe ikpaghọ eyẹ emhikhọghuo ẹa li wẹ.’
\p 
\v 26 “Ọni ọga ọyọli, ọ sọli ọ, ọọ li, ‘Yẹyẹ ọgbọ ọkhọlọ ọwaza ọna. U lẹsẹ khi eri mhia khiẹsẹ emini mhi aa rọkọ, mhi gbo rọte asha ni mhi aa pfi ukpamhi shi ẹ khiẹsẹ.
\v 27 Abi o rọ khi ighọ, wa a kẹ ri ikpaghọ eyẹmhẹ shi ilu ikpaghọ, mhi kha jele, mhi kha bhale ya ẹ khi e gbe nga ọ.
\p 
\v 28 “ ‘A mie ọli oni ukpaghọ, a ri ọli na ọni ọ mhuẹ ikpẹshe.
\v 29 Irari khi ọgbọ ni ọ mhuẹ, a ya rọ ma ọ na li, ọ mhuẹ gbeku ọ, ama ọni ọa mhuẹ kpa, ukukuọ ni ọ kpẹ mhuẹ a ya mie ọli luẹ.\f + \fr 25:29 \ft Li zẹ \fq iMat 13.12; iMak 4.25; iLuk 8.18\f*
\v 30 Ama ọni ukhiakhiamhi ọni ọọ ga ọnana, a mu ọli pfi lase ya pfia alo ebili, aghọ ọ la ke viẹ ọọ le akọ akọ.’\f + \fr 25:30 \ft Li zẹ \fq iMat 8.12; 22.13; iLuk 13.28\f*
\s1 Iguẹzọ ni o kpukhokho
\p 
\v 31 “Ini Omi Ọgbọ o bhale abi Oghie Ọnọmhuẹ, ni igẹni eyọli nya e rọ nu ọli bhẹ, ọ ya shitọ eghiele oyọli.\f + \fr 25:31 \ft Li zẹ \fq iMat 16.27; 19.28\f*
\v 32 Ẹgbọ ni e la agbọ nya a ya tigbili odalo oyọli. Ẹghẹghẹ aghọ ọ khi wẹ-a asha eva, abi ọrisumha-kia ọ liẹ vasẹ isumha ali elamhi-a.
\v 33 Ọ ya wolọ ẹgbọ ni e pfuasẹ je ukiẹkiẹ obita. Enekpọle e la obọgobọ.
\p 
\v 34 “Ighọ ọni oghie ọ ya gueyẹ ẹgbọ ni e la li obọ obita, ọọ wẹ, ‘A bhale ni a ke li agbọ elemhi iloghie ni Itamhẹ ọ riẹlẹ na ẹ rọte ẹghẹghẹ ni agbọ o te gba ekẹ le. Ẹẹ ni Ẹshinẹgba ọ khi vọsẹ na.
\v 35 Irari khi abi okiamhi o rọ gbe mhẹ, a ri emhi na mhẹ le, okiamẹ o gbe mhẹ, a diẹ amẹ na mhẹ da. Abi mhi rọ khi ọpfẹse, a mie mhẹ shi owa oyẹẹ.
\v 36 Abi mhi rọ la irumheba a ri itsua na mhẹ sọ. Mhii ghua, a ri ẹloe khu mhẹ. Mhi la owa ighumha, a bhale ya bino mhẹ.’
\p 
\v 37 “Ighọ eni ẹgbọ ni e pfuasẹ eghọ e ya mhila mhẹ, ẹ mhẹ, ‘Ọnọmhuẹ, ẹghẹghẹ onoghuo anye rọ mẹ khi okiamhi oo gbe ẹ ni anye rọ ri eminale nẹ le, ni okiamẹ o rọ gbe ẹ ni anye rọ rọ nẹ da?
\v 38 Ẹghẹghẹ onoghuo u rọ khi ọpfẹse ni anye rọ mie lo owa le. Ẹghẹghẹ onoghuo u rọ banọ-a ni anye rọ ri itsua nẹ sọ?
\v 39 Ẹghẹghẹ onoghuo u rọọ ghua ni u rọ la owa ighumha ni anye rọ bhale ya bino ẹ?’
\p 
\v 40 “Ọni oghie ọ ya sọ wẹ ọ, ọ wẹ, ‘Abi o li mhi li gue ẹ yẹ ẹ eghọ khi, emiemini u da riẹlẹ na ẹgbọ ni e khi Inyọghuo-mhẹ ni e miesuọ ni ẹa mu ẹloe ena ne, mhẹmhẹ u riẹlẹ ọli na.’
\p 
\v 41 “Ẹghẹghẹ aghọ ọni oghie ọ ya gueyẹ ẹgbọ ni e la li ukiẹkiẹ obọ ọgobọ, ‘A vu mhẹ ana le, ẹẹ ni a pfi unu na, a ke je owa erẹ ni Ẹshinẹgba ọ riẹlẹ na ọkphaghiẹ ali igẹni eyọli.
\v 42 Irari khi abi okiamhi o rẹ gbe mhẹ, aa ri emhi na mhẹ le. Abi okiamẹ o rẹ gbe mhẹ, aa bọ amẹ na mhẹ da.
\v 43 Abi mhi rọ khi ọpfẹse, aa lama ni mhi lo ẹ apfẹ le. Abi mhi rọ la irumheba, aa bọ ide na mhẹ sọ. Mhi ghua, aa ri ẹloe khu mhẹ. Mhi la owa ighumha aa bhale ya bino mhẹ.’
\p 
\v 44 “Ẹghẹghẹ aghọ e ya liẹ mhẹ, ‘Ọnọmhuẹ, obo anye la mẹ khi okiamhi o gbe ẹ, ni u rọ khi ọpfẹse, ni u rọ la irumheba, ni u rọ ọ ghua, ni u rọ la owa ighumha ni anye aa rọ kpaghiẹ obọ?’
\p 
\v 45 “Ọni oghie ọ ya sọ wẹ ọ, ọ wẹ, ‘Abi o li mhi li gue ẹ yẹ ẹ eghọ khi, emiemini wa a da riẹlẹ na ẹgbọ ena ni ẹa mu ẹloe ni e mie mhẹ suọ ne, mhẹmhẹ wa a riẹlẹ ọli na.’
\p 
\v 46 “Ẹghẹghẹ aghọ, e vu ya lo osoli na agbọagbọ, ama eni e guẹ ngeli, e je agbọ na agbọagbọ.”\f + \fr 25:46 \ft Li zẹ \fq iDan 12.2; iJọn 5.29\f*
\c 26
\s1 Ugbamhi ni a gba khẹ iJesu
\r (iMak 14.1-2; iLuk 22.1-2; iJọn 11.45-53)
\p 
\v 1 Abi iJesu ọ li sẹsẹ emhi ena se, ọọ eniyẹ odukhokho eyọli,
\v 2 “A lẹsẹ khi akọpfua khi ukpe iPasova. A ya mu Omi Ọgbọ, a gbe ọli-a shi apfida.”\f + \fr 26:2 \ft Li zẹ \fq Okiali 12.1-27\f*
\p 
\v 3 Ẹghẹghẹ aghọ, ighie eyi ekpodalo-ugamhi ali eni egbhali e ya lona agbala oyi iKefasi ni ọ khi Ọga ọyi ekpodalo ugamhi nya.
\v 4 E la aghọ gba ugbamhi abi e li ya bẹna mu iJesu ya gbe-a.
\v 5 E gueyẹ egbe khi, ọa ya khi ẹghẹghẹ oyi oni imu, ini ẹgbọ khi ri itobọ ighọ tsua onyaghu lasele.
\s1 A la iBẹtani ku oili shi iJesu egbe
\r (iMak 14.3-9; iJọn 12.1-8)
\p 
\v 6 IJesu ọ bhale iBẹtani, ikhi owa oyi ọmọse ọghuo ni a lu iSamọ ni efafe e kpẹ mu.
\v 7 Abi iJesu ọ li la aghọ le eminale, ọkpotso ọghuo ọ tsua ituale ni o lolo ghalẹ shi ukoko alabasita ni a ri ẹchẹ riẹlẹ bhale. Ọ ya ku ọli shi iJesu ukhomhi.\f + \fr 26:7 \ft Li zẹ \fq iLuk 7.37-38\f*
\p 
\v 8 Abi eniyẹ odukhokho eyi iJesu e rọ mẹ ona, e liẹ, “Elọ o zẹ ni a rọ na pfuẹchẹ oni ituale kua shi afuẹ?” Elemhi e bi wẹ.
\p 
\v 9 “A kha ri ituale ona dẹ ghalẹ lọ, a kemhi eni ikpaghọ na eni ẹa mhuẹ.”
\p 
\v 10 IJesu ọ lẹsẹ emini e ngme, ọ mhila wẹ, ọ wẹ, “Elọ o zẹ ni a rọ nyama ọni ọkpotso ọna? Emini o somhi otse ọ riẹlẹ na mhẹ.
\v 11 Ẹghẹghẹ kpa eni ẹa mhuẹ e rọ a la ẹ ifuabọ. Ama aa ya ke mẹ mhẹ ẹghẹghẹ kpa.\f + \fr 26:11 \ft Li zẹ \fq iDẹut 15.11\f*
\v 12 Emini o zẹ ni ọkpotso ọna ọ rọ ku ituale ona shi mhẹ egbe khi, ni ọ rọ mu mhẹ egbe khẹ irọtọ oyẹmhẹ.
\v 13 Mhi gueyẹ ẹ khi ashiashini a da la tse abọ usomhi onete ona ekẹ agbọ ona ne, a ya ngme emini ọni ọkpotso ọna ọ riẹlẹ rọ sato ọli egbe.”
\s1 IJudasi ọ lama khi lọli ya ri iJesu dẹ
\r (iMak 14.10-11; iLuk 22.3-6)
\p 
\v 14 Ighọ ọghuo eniyẹ odukhokho ogbava eyi iJesu ni a lu iJudasi na Isikarọti, ọ fiẹ deba ighie eyi ekpodalo-ugamhi.
\v 15 Ọ mhila wẹ, “Ingmẹ a ya rọ na mhẹ ini mhi ri odẹ khasẹ ẹ ni a te ya mu ọli?” Ighọ e leli ikpaghuo-ghuo uye ali igbe na li.\f + \fr 26:15 \ft Li zẹ \fq iZaka 11.12\f*
\v 16 Rọte aghọ vu, eri iJudasi ọ ke ri ukpẹloe shi ekẹ nono ode ni ọ te ya ri iJesu na wẹ.
\s1 Eminale ogbọmhi oyi Ọnọmhuẹ
\r (iMak 14.12-21; iLuk 22.7-13,21-23; iJọn 13.21-30)
\p 
\v 17 Ogbẹlẹ onododẹ oyi oni ukpe na ibulẹdi ni aa ri ifuma wushe o ramhi, eniyẹ odukhokho eyi iJesu e bhale deba li, e mhila li, ẹ ọli, “Obo wa nono ni anye mu egbe shi ni u la le eminale iPasova?”
\p 
\v 18 Ọọ wẹ “A lẹ deba ọmọse ọghuo ni ọ la elemhi oni ẹoli, a ka gueyẹ ọli khi, ‘Ọsẹsẹ ọ khi ẹghẹghẹ oyẹmhẹ o she ti ramhi, owa oyẹ, mhẹmhẹ ali eniyẹ odukhokho eyẹmhẹ anye la le eminale iPasova.’ ”
\v 19 Ighọ eni eniyẹ odukhokho eyi iJesu e riẹlẹ abi ọ li ghie wẹ. E ya mu egbe oni eminale shi aghọ.
\v 20 Abi ogbọmhi o rọ mu ekẹ, iJesu ali eniyẹ odukhokho ogbava eyọli ee shitọ shi eminale.
\v 21 Abi e rọ le oni eminale, iJesu ọọ wẹ, “Ọghuo elemhi ẹ ọ ya rẹmhẹ dẹ.”
\p 
\v 22 Ighọ egbe e pfọ wẹ a. Ọghuo ọghuo ọ mhila li “Ọnọmhuẹ she khi ọa khi mhẹmhẹ wẹ khi o khi?”
\p 
\v 23 IJesu ọọ wẹ, “Ọghuo ẹ ni ọ nu mhẹ ẹ sọ obọ utasa, ọ ya rẹ mhẹ dẹ.\f + \fr 26:23 \ft Li zẹ \fq Iwolo 41.9\f*
\v 24 Omi ọgbọ ọ ya ghu-a abi a kẹkẹ nali. Ama o ma khọlọ ọmọse ni ọ ri Omi Ọgbọ ya dẹ egbe. O kha bie ti nẹ ini ọgbọ aa bie bia li.”
\p 
\v 25 IJudasi ni ọ ya rọli dẹ ọọ li, “Ọsẹsẹ, she khi ọa khi mhẹmhẹ wẹkhi o khi?” IJesu ọọ li, “Ii, yẹyẹ lọ.”
\s1 Eminale ogbọmhi oyi Ọnọmhuẹ
\r (iMak 14.22-26; iLuk 22.14-20; 1 iKọri 11.23-25)
\p 
\v 26 Abi e li le eghọ, iJesu ọ rue ibulẹdi, ọ kphẹmhi, ọ khi ọli a, ọ rọli na eniyẹ odukhokho eyọli, ọọ wẹ, “A mọ, a le khi idiegbe oyẹmhẹ na.”
\p 
\v 27 Ighọ ọ gbo li rue uko, ọ kphẹmhi, ọ rọli na wẹ, ọ wẹ, “Ẹẹ nya a rọte ọ da.
\v 28 Ọlia eyẹmhẹ ni a ku rọ luasẹ obo na ẹgbọkpa a na, ni o gbe olamhẹ kua na wẹ. Ọlia ena Ẹshinẹgba ọ rọ nu ẹgbọ eyọli mhuẹ ishobọ.\f + \fr 26:28 \ft Li zẹ \fq Okiali 24.8; iJere 31.31-34\f*
\v 29 Mhi gueyẹ ẹ khi mhi a ke gbo rọte oni ukpamhi ọara upfonu onana ya da rọte memena vu. Sẹẹ ni ẹlẹ ni mhi ke ya nu ẹ da li odẹ onogbọ Iloghie oyi Itamhẹ.”
\p 
\v 30 Abi e rọ to uwolo se, e vu ya je ute ẹẹra Olivu.
\s1 IJesu ọ guele shi ekẹ khi iPita ọ ya kie luẹ
\r (iMak 14.27-31; iLuk 22.31-34; iJọn 13.36-38)
\p 
\v 31 Abi e li lẹ eghọ, iJesu ọọ wẹ, “Amiọsẹ ena, ẹẹ nya a ya mhuẹ akhọkhọmhẹ shi mhẹ egbe, a na tsua mhẹ pfia, irari khi ebe o ngme ọli khi.
\q1 “ ‘Mhi ya ri emhi li
\q2 ọrisumhakia,
\q1 eni isumha
\q2 e ya gbhiaku-a.’\f + \fr 26:31 \ft Li zẹ \fq iZaka 13.7\f*
\p 
\v 32 “Ama ini mhi rọte eghuli guale, mhi ya ralo na ẹ iGalili.”\f + \fr 26:32 \ft Li zẹ \fq iMat 28.16\f*
\p 
\v 33 IPita ọọ li, “Ini ẹgbọ nya e tseku mhuẹ akhọkhọmhẹ shi ẹ egbe, mhẹmhẹ mhi aa ya mhuẹ.”
\p 
\v 34 IJesu ọọ li, “Abi o li mhi li gue ọli ẹ yẹ, khi amiọsẹ ena, neni ọkpa ọ gbiẹghẹ, itesẹ u ya liẹ khi waa lẹsẹ mhẹ.”
\p 
\v 35 IPita ọọ li, “Mhi aa ya ngme ghọ ini o tseku khia khi oni mhi ya nu ẹ ghu-a lọ, mhi aa ya liẹ khi mhi aa lẹsẹ.”
\p Eniyẹ odukhokho enekpọle nya e li ngme ghọ.
\s1 IJesu ọ la iGẹtisẹmani lema
\r (iMak 14.32-42; iLuk 22.39-46)
\p 
\v 36 Ighọ iJesu ọ lu eniyẹ odukhokho eyọli, e je ashini a lu iGẹtisẹmani, ọọ wẹ, “A shitọ ana khi mhi ya je oobọ ya sọ iromhi.”
\v 37 Ọ rue iPita ali imi iZebedi aava ma egbe. Ọ viẹ osoli, egbe ẹa ke sheshe ọli.
\v 38 Ọọ wẹ, “Udu oyẹmhẹ o vọ osoli ramhi khi mhi ya ghua. A shitọ ana, a nu mhẹ ke tọkpẹ.”
\p 
\v 39 Ọ ti lẹ dẹnẹ, ọ de yẹshi tọ alo mu ekẹ ọ sọ iromhi. Ọọ, “Ita, ini o ya tsẹ lọ, zẹ ni u mie mhẹ uko osoli ona. Ama ọa khi abi o li ghọle mhẹ, ama abi o li ghọle ẹ.”
\p 
\v 40 Ọ nyenẹ egbe bhale deba eni eniyẹ odukhokho, ọ mẹ khi ẹẹ lesẹa. Ọọ wẹ, “Aa dobẹ nu mhẹ tọkpẹ ukuku ẹghẹghẹ tsẹ?”
\v 41 “A ke tọkpẹ, a sọ iromhi ini a khi de pfilo imufẹ. Ayẹmhẹ o mu egbe, ama o lọsẹ idiegbe.”
\p 
\v 42 Ọ gbo vu utonuzi-eva, ọ ya lema, ọọ, “Itamhẹ, ini o khia khi ọa zẹ li ni uko osoli ona o dọsẹ, sẹẹ khi mhi da li, zẹ ni ọghuẹmhẹ oyẹ o tsẹ.”
\p 
\v 43 Ọ gbo nyenẹ egbe ukhokho bhale, ọ mẹ khi e lesẹa ẹa ke dobẹ khueghie alo-a.
\v 44 Ighọ ọ zẹ wẹ obọ shi aghọ. Ọ gbo ya lema utonuzi-esẹ, o gbo ngme abi ọ kpẹ ngme.
\p 
\v 45 Ighọ ọ nyenẹ egbe ukhokho bhale deba eni eniyẹ odukhokho, ọọ wẹ, “Eri a kiele ẹ lesẹ-a, a kiele ẹ yẹmhẹ-a? A bino khi ẹghẹghẹ o she ramhi khi a she ri Omi Ọgbọ na ẹgbọ olamhẹ dẹ.
\v 46 A vule ni awa vu! Ọni ọ rẹmhẹ ẹ dẹ ọọ bhale!”
\s1 A mu iJesu
\r (iMak 14.43-50; iLuk 22.47-53; iJọn 18.3-12)
\p 
\v 47 IJesu ọ kie lighọ ngme, iJudasi ni ọ khi ọghuo eni eniyẹ odukhokho ogbava, ọ bhale. Ebubu ẹgbọ ni e tsua epia ali itakobi e nu ọli bhale, eni ighie eyi ekpodalo-ugamhi ali eni egbhali e ghie.
\v 48 Ọni ọ rọli dẹ ọ she ri ọlẹlẹ na eni ẹgbọ, ọọ wẹ, “Ọni mhi da ya pfipfi egbe ne, lọli lọ, a mu ọli.”
\v 49 Ọni iJudasi ọ lẹ deba iJesu, ọọ li, “Opfọmhẹ o ka nu ẹ la Ọsẹsẹ,” ọ pfipfi ọli egbe.
\p 
\v 50 IJesu ọọ li, “Ọmuẹ, nyanya riẹlẹ emini u bhale shi.”
\p Ighọ eni emọse e fiẹ lasele, e mu ọli.
\v 51 Ghe i, abi a rọ mẹ na, ọghuo eni e nu iJesu kia, ọ ji itakobi emhi lasele. Ọ khi ọni ọọ ga ọyi Ọga ekpodalo ugamhi esọ-a.
\p 
\v 52 IJesu ọọ li, “Rue itakobi oyẹ shi irari khi ọni ọ ji itakobi, ọ ya li ghu eghuli itakobi.
\v 53 Eri u dabi khi mhi aa dobẹ ya mhila Itamhẹ ikpaghiobọ, aghọaghọ ọ ri igẹni ni e dọsẹ agbhagbhamhi igbẹva ghi mhẹ.
\v 54 Ama, sẹ Ebe-no-pfuasẹ o ke li bhale ya tsẹ, ni ọọ khi a mema lina mẹ ọli?”
\p 
\v 55 Ighọ iJesu ọọ eni ebubu ẹgbọ eghọ, “Eri mhi ri ẹgbọ ẹ pfi ozughu ni a rọ tsua igbhọrọ ali itakobi bhale ya mu mhẹ? Ẹlẹ kpa mhi rọ shitọ Owa oyi Ẹshinẹgba ẹ sẹsẹ, ama aa mu mhẹ.\f + \fr 26:55 \ft Li zẹ \fq iLuk 19.47; 21.37\f*
\v 56 Ama eri a mẹ ena nya ni a bhale ya ẹ khi emini emekẹguele e ngme shi ebe o bhale ya tsẹ.” Ighọ eniyẹ odukhokho nya e zẹ ọli obọ, e na kua.
\s1 Igba enighie ni a lu iSaẹdiri e ri iJesu gue ẹzọ
\r (iMak 14.53-65; iLuk 22.54-55,63-71; iJọn 18.13-14,19-24)
\p 
\v 57 Eni e mu iJesu e rue ọli je apfẹ oyi iKefasi ni ọ khi Ọga ọyi ekpodalo ugamhi, ashini eni ẹ sẹsẹ ishi ali eni egbhali e legbe.
\v 58 Ama iPita ọ tapfia a deba wẹ. Ọ deba wẹ lo ramhi atukpapfẹ oyi Ọga ọyi ekpodalo ugamhi. Ọ lo se, ọ nu eni ẹẹ khẹ ekhẹ shitọ, ni ọ mẹ abi oni ingme o ke li ya kia.
\p 
\v 59 Ighie eyi ekpodalo-ugamhi ali eni iSahẹdiri nya, e nono ọtsẹlẹ ẹgbhọli ni e ya mu mhọli iJesu obọ ni e ba mẹ asha gbe ọli-a.
\v 60 Ama ẹa mẹ okhọghuo, abi ebubu ẹgbọ e tseku fiẹ lasele ya pfi ọtsẹlẹ ẹgbhọli.
\p Ikpukhokho ọ, emọse aava e fiẹ lasele.
\v 61 Ẹ li “Ọmọse ọna ọ̀ọ́, ‘Mhi ya dobẹ guọghọ Owa Oyi Ẹshinẹgba-a, mhi gbo riẹlẹ ọli tọ ogbẹlẹ esẹ.’ ”\f + \fr 26:61 \ft Li zẹ \fq iJọn 2.19\f*
\p 
\v 62 Ọga ọyi ekpodalo ugamhi ọ vule, ọọ iJesu, “Waa bie mhuẹ emini u ya ngme shi ẹzọ ni a gue ẹ shi ẹ egbe ena?”
\v 63 Ama iJesu tsaghiẹ-a.
\p Ighọ Ọga ọyi ekpodalo ugamhi ọ gbo vule migha, ọọ iJesu, “Mhi ri eva oyi Ẹshinẹgba ni ọ la ọ rẹ romhi ishe, gueyẹ anye, ini yẹyẹ u khi Ọmiepfuese Omi Ẹshinẹgba.”
\p 
\v 64 IJesu ọọ li, “Ighọ o khi abi u ngme. Ama mhi gueyẹ ẹẹ nya khi, rọte memena vu, a ya mẹ khi Omi Ọgbọ ọ shitọ obita oyi Ẹshinẹgba ni ọ funẹ nya, ọ la elemhi otughunu te irarogbe ẹ bhale.”\f + \fr 26:64 \ft Li zẹ \fq iDan 7.13\f*
\p 
\v 65 Ighọ, Ọga ọyi ekpodalo ugamhi ọ nyanọ awulu a shi egbọli uruli. Ọọ, “Ọ she pfi unu-a! Ọtsẹlẹ olese awa ke gbolo ẹ nono? Ẹẹ a she suọ oni ungmemhi ipfiunu-a ni ọ ngme.
\v 66 Sẹ a sa shi ọ?”
\p Ẹ ọli “Ọ she lue, ọ mema ya ghua.”\f + \fr 26:66 \ft Li zẹ \fq iLẹv 24.16\f*
\p 
\v 67 Ighọ e tono etẹ ku iJesu alo, e ri ekpa gbe ọli. Eghuo, e lase ọli esọ.\f + \fr 26:67 \ft Li zẹ \fq Aza 50.6\f*
\v 68 E liẹ ọli “Mẹ ekẹ na anye ghue yẹyẹ Ọmiepfuese. Gueyẹ anye ghue ọni ọ ri emhi gbe ẹ.”
\s1 IPita ọ kie iJesu
\r (iMak 14.66-72; iLuk 22.56-62; iJọn 18.15-18,25-27)
\p 
\v 69 IPita ọ shitọ olase, ọmueshi ọghuo ọyi Ọga ọyi ekpodalo ugamhi ọ bhale deba li, ọọ li, “Yẹyẹ, u li nu iJesu ọnge iGalili kia.”
\v 70 IPita ọ tia li ukpẹloe wẹ nya, ọọ li, “Mhi aa fẹ lẹsẹ emini a ngme.”
\p 
\v 71 Ọ ke rọte aghọ fiẹ je unu odẹ unuẹkpẹ ni a rọte ẹ lo oni apfẹ le, ọkpotso ọni ọọ ga ọlese ọ gbo mẹ ọli, ọ gueyẹ emọse ni e la aghọ, ọọ “Ọmọse ọna ọ nu iJesu na iNazarẹti kia.”
\p 
\v 72 Ighọ iPita ọ gbo tia li. Utona, ọ romhise ma ọ, ọọ, “Mhi romhi ishe, khi mhi aa lẹsẹ ọni ọmọse ọghọ!”
\p 
\v 73 O kẹ li dẹnẹ, emọse ni e migha aghọ e bhale deba iPita, ẹ ọli, “Igẹsikia lọ khi ọtuọghuo elemhi wẹ u khi. Ungmemhi oyẹ o she ngmasẹ le.”
\p 
\v 74 Ighọ ọ li sẹ egbọli isheli, ọọ romhi isheli. Ọ liẹ, “Mhi aa ga lẹsẹ ọni ọmọse!”
\p Utoghuokpe ọkpa ọ gbiẹghẹ.
\v 75 Ighọ iPita ọ sato ungmemhi ni iJesu ọ gueyẹ ọli ni ọ rẹ ọli, “Neni ọkpa ọ ya gbiẹghẹ, itesẹ u ya liẹ khi waa lẹsẹ mhẹ.” Ọ fiẹ je olase ya viẹ oya.
\c 27
\s1 A mu iJesu ghi iPaleti
\r (iMak 15.1; iLuk 23.1-2; iJọn 18.28-32)
\p 
\v 1 Ogbe o gbe-a ogbeakọlọ, ighie eyi ekpodalo-ugamhi nya ali egbhali e mhẹsẹ abi e li ya gbe iJesu-a.
\v 2 E gẹ ọli, e rue ọli vu ghi iPaleti ni ọ khi igọvunọ.
\s1 IJudasi ọ gbe egbọli-a
\r (Ika 1.18-19)
\p 
\v 3 Abi iJudasi ni ọ rọli dẹ, ọ rọ suọ khi a pfa ẹzọ mu ọli khi a ya gbe ọli-a, o ri egbe pfọ li-a, ọ nyenẹ egbe rue ikpaghuo uye ali igbe eghọ ghi ighie eyi ekpodalo-ugamhi ali eni egbhali.
\v 4 Ọọ wẹ, “Mhi she lamhẹ, irari khi mhi she ri ọgbọ ni ọa mhọli olamhẹ okhọghuo dẹ,” Ẹ ọli, “Ẹgboli oyi anye onoghuo o ke la oghọ? Yẹyẹ u lẹsẹ.”
\p 
\v 5 Ighọ iJudasi ọ ku eni ikpaghọ kua ekẹ elemhi Owa oyi Ẹshinẹgba, ọ vu ya soli egbọli-a.
\p 
\v 6 Ighọ ighie eyi ekpodalo-ugamhi e sanọ eni ikpaghọ ekẹ, ẹ ọli, “Ikpaghọ ọlia na, awa aa ya ku wẹ ma ikpaghọ ugamhi.”
\v 7 E gba ugbamhi nga eni ikpaghọ se, e rẹwẹ ya dẹ ekẹ onayi ọni ọọ ma ekhe, ni a ri ilimhi epfẹse ke tọ aghọ.
\v 8 Lọli o zẹ ni a rọ lu ọli Ekẹ Ọlia ramhi ogbe na amo.\f + \fr 27:8 \ft Li zẹ \fq Ika 1.18-19\f*
\v 9 Ighọ ungmemhi ni ọmekẹguele ni a lu iJeremaya ọ ngme, o li bhale ya tsẹ. Ni ọọ, “E rue ikpaghuo uye ali igbe ni e khi ikpaghọ ni ẹgbọ iZirẹni e lama fali shi ọli egbe.
\v 10 E rue eni ikpaghọ ya dẹ ekẹ ẹmẹ onayi eni ẹẹ ma ekhe, abi Ẹshinẹgba ọ mhẹsẹ na mhẹ mhi ngme.”\f + \fr 27:10 \ft Li zẹ \fq iZaka 11.12-13; iJere 19.1-13; 32.6-9\f*
\s1 IPaleti ọ mhila iJesu ogbọ
\r (iMak 15.2-5; iLuk 23.3-5; iJọn 18.33-38)
\p 
\v 11 IJesu ọ migha odalo oyi igọvunọ iRomu, ọni igọvunọ ọ mhila li, “Yẹyẹ u khi oghie ọyi ẹgbọ iJu?” IJesu ọọ li, “Ii, Ighọ o khi abi u ngme.”
\p 
\v 12 Ama ọa mhọli emini ọ sọ shi ingme ni ighie eyi ekpodalo-ugamhi ali egbhali e ngme shi ọli egbe.
\v 13 Ighọ iPaleti ọ mhila li, ọọ. “Wa a suọ emini a ngme shi ẹ egbe?”
\v 14 Ama iJesu ọa lama sọ ọli abikhọghuo, o ga lolo ri abọ sha ọni igọvunọ.
\s1 A pfa ẹzọ igbe-a mu iJesu
\r (iMak 15.6-15; iLuk 23.13-25; iJọn 18.39--19.16)
\p 
\v 15 Ini a da li ukpe iPasova, eri igọvunọ ọọ rue ọgbọ ọghuo ni a mu shi owa ighumha obọ-a na ẹgbọ iJu. Ikhi ọni e zẹ, a rue igha le na wẹwẹ.
\v 16 Ẹghẹghẹ aghọ, a mẹ ọmọse ni a mema lẹsẹ shi ukhiakhiamhi ọgbọ, ni aa khẹna, ni a mu shi owa ighumha, ni a lu iBarabasi.
\v 17 Ighọ abi eni ẹgbọ e rọ le gba, iPaleti ọ mhila wẹ, “Ọnọghuo elemhi ẹgbọ aava ena a nono ni mhi wolọ abọ-a na ẹ? IBarabasi abi iJesu ni a lu Ọmiepfuese?”
\v 18 Irari khi ọ she lẹsẹ khi itobọ khi ighie eyi ẹgbọ iJu ẹẹ biselemhi iJesu e rọ mu ọli ghi luẹ.
\p 
\v 19 Abi iPaleti ọ li shitọ ukpẹkhomhi ẹzọ oyọli, ughuẹ ọli ọ ghie usomhi ghi ọli, ọọ. “Khi mhuẹ emini u li ọmọse ni ọa mhuẹ emini ọ li eghọ. Irari khi mhii mẹ osoli elemhi ẹlena ooyọsẹ shi ingme oyọli.”
\p 
\v 20 Ama ighie eyi ekpodalo-ugamhi ali eni egbhali, e tanọ shi eni ebubu ẹgbọ elemhi, e liẹ iPaleti ọ rue iBarabasi obọ-a, ama a gbe iJesu-a.
\p 
\v 21 Ighọ igọvunọ ọ mhila wẹ, “Elemhi aava ena, ọnọghuo ọ, a nono ni mhi rue obọ-a?” Wẹwẹ nya ẹẹ.
\p “IBarabasi!”
\p 
\v 22 Ọ mhila wẹ, “Sẹ mhi ya li iJesu ni a lu Ọmiepfuese ọna shọ?”
\p Wẹwẹ nya ẹẹ, “A ka ta li ma apfida!”
\p 
\v 23 Ama iPaleti ọ mhila wẹ, “Elọ o zẹ, onobe onoghuo ọ riẹlẹ?”
\p Ama e kie tsẹsẹ leghe “A ta li ma apfida!”
\p 
\v 24 Abi iPaleti ọ rọ mẹ khi lọli ẹa mhọli emini lọli ke ya li ọ, khi onyaghu o tigbe te ọ lasele, ọ diẹ amẹ, ọ kpe abọ-a ukpẹloe wẹ nya, ọọ wẹ “Mhi aa mhuẹ obọ shi eghuli oyi ọmọse ọna o! Obọ oyẹẹ o la o!”\f + \fr 27:24 \ft Li zẹ \fq iDẹut 21.6-9\f*
\p 
\v 25 Eni ẹgbọ nya ẹ li, “Ọlia eyọli e la ukhomhi oyanye ali oyi eniyẹ eyanye.”
\p 
\v 26 Ighọ ọọ rue iBarabasi obọ-a na wẹ. Ọọ a gbe iJesu itali, ọ rue ọli na ekhọli-okhuẹ eyi iRomu e ka ta li ma apfida.
\s1 Eni ekhọli-okhuẹ e ri iJesu li egia
\r (iMak 15.16-20; iJọn 19.2-3)
\p 
\v 27 Ighọ ekhọli-okhuẹ eyi iPaleti e rue iJesu lo elemhi agbala oyọli, ọ rue eni ekhọli-okhuẹ nya le gasẹ ọli.
\v 28 Ighọ e gueghie ọli itsua ni ọ sọ, e ri itsua ọyilẹ sọ li.
\v 29 E ri igba do arula rughu ọli. E ri ukpokpo mhọli ọli obọ ita, e wugha li odalo, e ri ọli li egia. E liẹ ọli, “Ẹshinẹgba ọ zẹ ni u tọ agbọ yẹyẹ oghie iJu.”
\v 30 E to etẹ ku ọli, e mie ọli oni ukpokpo gbe ọli ukhomhi.
\v 31 E ri ọli li egia se, e gueghie ọli itsua eyilẹ ni e rọ sọ li eghọ, e tigbe ri itsua eyọli sọ li. E rue ọli je obini a la ya gbọli-a.
\s1 A ta iJesu ma apfida gbe-a
\r (iMak 15.21-32; iLuk 23.26-43; iJọn 19.17-27)
\p 
\v 32 Abi e li lẹ eghọ, wẹwẹ ali ọmọse ni a lu iSamọ ọngi iZirẹni e ya lona, e ri itoto mu ọli ọ tsua apfida oyi iJesu.
\v 33 E bhale asha ni a lu iGọgọta. Abi iGọgọta o ngme khi “Asha ugua ukhomhi ọgbọ.”
\v 34 Aghọ e la ri onyọ ni a ri emhi oyala shi na iJesu da, ama ọ to unu ọ bino, ọa lama da li.\f + \fr 27:34 \ft Li zẹ \fq Iwolo 69.21\f*
\v 35 E ta li ma apfida se, e pfi onolo rọ kemhi itsua ni ọ sọ mhọli egbe abọ. Onana o ri emini ọmekẹguele ọ ngme bhale ya tsẹ, ni ọọ. “E kemhi iwulu eyẹmhẹ, e pfi onolo shi ide eyẹmhẹ.”\f + \fr 27:35 \ft Li zẹ \fq Iwolo 22.18\f*
\v 36 E riẹlẹ se, e shitọ, e khẹ ọli ekhẹ.
\v 37 E kẹkẹ emini a gue shi ọli egbe shi upẹpẹ ọara rọ kphase kpeda nali. Emini a kẹkẹ shi ọ khi, Ọna khi iJesu, Oghie ẹgbọ iJu.
\v 38 Ighọ e gbe ighiatọ aava ma li egbe. Ọghuo ọ la ukiẹkiẹ obita, ọnọkpọle ọ la li ukiẹkiẹ ọgobọ.
\v 39 Ẹgbọ ni ee dọsẹ, e pfi itsue ọdọda manya iJesu.\f + \fr 27:39 \ft Li zẹ \fq Iwolo 22.7; 109.25\f*
\v 40 E liẹ “Yẹyẹ ni u ya guọghọ Owa Oyi Ẹshinẹgba-a, ogbẹlẹ nuzi-esẹ u gbo tọli pfo. Tsumhi egbe ẹ! Rọte ukhomhi apfida ona tiemhile shọ, ini Omi Ẹshinẹgba u khi.”
\p 
\v 41 Ina ighie eyi ekpodalo-ugamhi, ali esẹsẹ Ishi eyi iMosisi ali egbhali e gbo li tsue ọli.
\v 42 E liẹ, “Ọ tsumhi ẹgbọẹse,” “Ama ọa dobẹ tsumhi egbọli! Ọa khi lọli khi oghie ọyi iZirẹni? Ini ọ da te ukhomhi apfida onana tiemhile ne, anye ya mie ọli suọ.
\v 43 Eri ọ ri egbe da Ẹshinẹgba o gbo liẹ khi, ‘Omi Ẹshinẹgba mhi khi.’ Awa ke bino ini Ẹshinẹgba ọ ya tsumhi ọli mena.”\f + \fr 27:43 \ft Li zẹ \fq Iwolo 22.8\f*
\v 44 Ighọ khi ighiatọ ni a ta ma apfida e li tsue ọli.
\s1 Eghuli oyi iJesu
\r (iMak 15.33-41; iLuk 23.44-49; iJọn 19.28-30)
\p 
\v 45 Ọguota o mu ekẹ obili o todẹ bi asha kpa elemhi iwakati esẹ.
\v 46 Agogo esẹ o de te, iJesu ọ viẹ lasele leghe ọọ “Eloi, Eloi, Lama Sabachi tani?” Abi ona o ngme khi “Ẹshinẹgba ọyẹmhẹ, Ẹshinẹgba ọyẹmhẹ, elọ o zẹ ni u rọ pfi mhẹ esọ a?”\f + \fr 27:46 \ft Li zẹ \fq Iwolo 22.1\f*
\p 
\v 47 Ẹgbọ eghuo ni e la aghọ e suọ ona, e liẹ li, “Elaja ọọ lu.”
\p 
\v 48 Aghọaghọ, ọghuo ọ, ọ na ya rue isoso, ọ sọ li onyọ ni o khẹ-a, ọ gẹnọ li shi ukpokpo nise a ji iJesu unu ni ọ da.\f + \fr 27:48 \ft Li zẹ \fq Iwolo 69.21\f*
\v 49 Ama enekpọle ẹ ọli, “Migha, zẹ ọli obọ ni awa mẹ ini Elaja ọ ya bhale ya tsumhi ọli.”
\p 
\v 50 Ighọ iJesu ọ gbo viẹ leghe, ọ ghu-a.
\p 
\v 51 Ẹghẹghẹ aghọ tee, ode ugbakpi, ni a rọ ta pfa odẹ-a ni o la elemhi Owa Oyi Ẹshinẹgba o te ododẹ rọte idane kiẹsẹ-a ya tiemhi ekẹ. Ekẹ agbọ o nighise, echẹ e vẹnọ-a.\f + \fr 27:51 \ft Li zẹ \fq Okiali 26.31-33\f*
\v 52 Iji e khueghie-a, ebubu ẹgbọ ni e pfuasẹ ni eghuloa e guale bhale agbọ.
\v 53 E fiẹnọ iji lasele. Abi iJesu ọ rọ rọte eghuli guale se, e je elemhi ẹoli no pfuasẹ, e ri egbe khasẹ ebubu ẹgbọ.
\p 
\v 54 Abi ekhọli-okhuẹ ni a zẹ e ke khẹ iJesu ekhẹ e rọ mẹ abi ekẹ o li nighise ali emhi elese ni e mẹ nya, ulishi oo mu wẹ, e liẹ li, “Egbegbọ lọ khi Omi Ẹshinẹgba ọmọse ọna ọ khi.”
\p 
\v 55 Ikpotso ebubu e la aghọ ni e ta pfi-a fẹ. Eri e deba iJesu rọte iGalili bhale ni wẹwẹ e ri ukpẹloe khu ọli.
\v 56 Eghuo ọ khi, iMeli ọngi iMagidaleni, iMeli inyi iJemhisi ali iJosẹfu, ali inyi iJemhisi ali iJọni.
\s1 Abi a ri iJesu tọ
\r (iMak 15.42-47; iLuk 23.50-56; iJọn 19.38-42)
\p 
\v 57 Abi ogbọmhi o rọ mu ekẹ, ọmọse ni ọ pfue ọngi Arimatia ni a lu iJosẹfu ni ọ li khi ọghuo eniyẹ odukhokho eyi iJesu,
\v 58 ọ lẹ deba iPaleti ya mhila li olimhi ọyi iJesu, ọ rọli na luẹ ya tọ. IPaleti ọ ri unu bhale e ka rue ọli na iJosẹfu.
\v 59 Ighọ iJosẹfu ọ rue ọli, ọ ri ode onogbọ no pfuasẹ khuli ọli.
\v 60 Ọ ri ọli tọ uji onogbọ oyọli ni a lẹsẹ tọ shi elemhi ẹchẹ. Ọ gheghele ẹchẹ oniẹmhi khukhu oni uji unu, ọ vu je apfẹ.
\v 61 Ighọ iMeli ọngi iMagidaleni ali iMeli ọnọkpọle e shitọ sọ alo ghue oni uji.
\s1 Ekhekhẹ ni e la oni uji
\p 
\v 62 Ogbeakọlọ, ni o khi ẹlẹ Iyẹmhẹa oyi ẹgbọ iJu, ighie eyi ekpodalo-ugamhi ali ẹgbọ iFarisi e bhale deba iPaleti, ẹ ọli,
\v 63 “Ọga, anye sa ya to khi abi ọni ọloẹgbhuẹ ọghọ ọ rọ la agbọ ọ liẹ khi, ‘Mhi ya guale ẹlẹ-esẹ.’\f + \fr 27:63 \ft Li zẹ \fq iMat 16.21; 17.23; 20.19; iMak 8.31; 9.31; 10.33-34; iLuk 9.22; 18.31-33\f*
\v 64 Mena ri unu bhale a ke ya khẹ aghọ ekhẹ ramhi ẹlẹ nuzi-esẹ, ini eniyẹ odukhokho eyọli e khi bẹna ya tsua olimhi oyọli, ni e ke gueyẹ ẹgbọ khi a she te eghuli guise ọli le. Ẹgbhọli oni o ya kpukhokho ona, lọli o ke ya khọlọ dọsẹ oni ododẹ.”
\p 
\v 65 IPaleti ọọ wẹ, “A rue ekhe-khẹ, a zẹ ni ẹ khẹ ekhẹ aghọ. A lolo khukhu ọli abi o ti ẹ ẹloe shi.”
\p 
\v 66 Ighọ e ya khukhu oni uji egbegbọ, e zuse ọli, e zẹ ekhe-khẹ shi aghọ.
\c 28
\s1 Irọte eghuli guale oyi iJesu
\r (iMak 16.1-10; iLuk 24.1-12; iJọn 20.1-10)
\p 
\v 1 Ogbe o ya gbe khi ẹlẹ Iyẹmhẹa o dọsẹ ni o khi ẹlẹ ni ododẹ elemhi ẹfo uka, iMeli ọngi iMagidaleni ali iMeli ọnọkpọle e lẹ ya bino oni uji.
\p 
\v 2 Utoghuokpe ekẹ o nighise, irari khi agẹni ọyi Ọnọmhuẹ ọ rọte idane tiemhile. Ọ gheghele oni ẹchẹ ni o khukhu oni unu uji odẹ-a. Ọ shitọ nga ọ.
\v 3 Ọ li abi erali akphala. Itsua ni ọ sọ e pfuasẹ pẹpẹpẹ abi otughunu opfopfo.
\v 4 Ulishi o mu eni e la aghọ khẹ ekhẹ, ee guọ, ubi o rue wẹ pfi gbe.
\p 
\v 5 Ọni agẹni ọọ eni ikpotso, “A khi zẹ ni ulishi o mu ẹ irari khi mhi lẹsẹ khi iJesu ni a gbe-a shi apfida a nono.
\v 6 Ọa la akana, ọ she te eghuli guale abi ọ kie kpẹ ngme. A bhale ya bino ashini a ri ọli yẹshi.
\v 7 A nyanya ke lẹ memena, a ka gueyẹ eniyẹ odukhokho eyọli khi. ‘A she te eghuli guise ọli le, khi mena, ọọ kia khẹ ẹ, ọ je elemhi iGalili. Oobọ a ya mẹ ọli.’ Ghe i, a khi yele-a abi mhi gueyẹ ẹ.”
\p 
\v 8 Ighọ eni ikpotso e nyanya rọte oni uji vu, ulishi o mu wẹ ama oghẹlẹ o vọ wẹ elemhi, e na ya gueyẹ eniyẹ odukhokho eyọli.
\v 9 Utoghuokpe iJesu ọ bhale deba wẹ, ọọ. “Opfọmhẹ o ka nu ẹ la.” E bhale deba li, e mu ọli awẹ, e nyẹsẹ ukhomhi ga li.
\v 10 IJesu ọọ wẹ, “A khi zẹ ni ulishi o mu ẹ, ama a ka gueyẹ Inyọghuo-mhẹ e ke je iGalili. Aghọ e te ya mẹ mhẹ.”
\s1 Emini ekhe-khẹ e guele
\p 
\v 11 Abi eni ikpotso e rọ vu se, eni ekhọli-okhuẹ ni e khẹ oni uji ekhẹ, e vu ya gueyẹ ighie eyi ekpodalo-ugamhi emini a ga mẹ nya.
\v 12 Ighọ ighie eyi ekpodalo-ugamhi e lẹ deba eni egbhali e lona ye ugbamhi abi e ke ya li. E gba, e ri ikpokpomhi ikpaghọ na eni ekhọli-okhuẹ eghọ.
\v 13 Ẹẹ wẹ. “A liẹ khi, ‘Eniyẹ odukhokho eyọli e bhale ya tsua li vu abi obili o rọ bi ni anye rọ lesẹa.’
\v 14 Ini igọvunọ ọ suọ ona, anye ya pfa ẹ shi ekẹ, a khi zẹ ni emhikhọghuo o nasẹ ẹ udu.”
\v 15 Ighọ eni ekhọli-okhuẹ e mie wẹ eni ikpaghọ e li abi e sẹsẹ wẹ. Eri ingme emini e riẹlẹ o gbhiaku asha kpa ifuabọ ẹgbọ iJu. Ramhi ogbe-namo, eri a kiele ẹ zẹ oni okhẹ ona.
\s1 Usomhi ni o funẹ ni iJesu ọ ghie
\r (iMak 16.14-18; iLuk 24.36-49; iJọn 20.19-23; Ika 1.6-8)
\p 
\v 16 Ighọ eniyẹ odukhokho ogbaghuo eyọli e je iGalili deba iJesu ukhomhi ute ni ọ sẹsẹ wẹ.\f + \fr 28:16 \ft Li zẹ \fq iMat 26.32; iMak 14.28; 1 iKọri 15.5; iJọn 21.1-23\f*
\v 17 Abi e rọ mẹ ọli, e nyẹsẹ egbe ga li, ama eghuo ọ e kiele khọkhọ ọli.
\v 18 Ighọ iJesu ọ kia ti mama wẹ, ọọ. “A she rue afu nya na agbọ ona ali iloghie na mhẹ.\f + \fr 28:18 \ft Li zẹ \fq iMat 11.27; iLuk 10.22; iFili 2.9; Ẹfi 1.20-22\f*
\v 19 Irarighọ, a fiẹ lase je asha kha asha, a ke ya ri ẹgbọ mele eniyẹ odukhokho eyẹmhẹ-a, a ri eva oyi Ita, ali oyi Ọmọ ali oyi Ayẹmhẹ-nọ-pfuasẹ batazi.\f + \fr 28:19 \ft Li zẹ \fq Ika 1.8\f*
\v 20 A sẹsẹ wẹ, e ke ri emhi nya ni mhi mhẹsẹ na ẹ gbe akanya. A ghe i, mhi nu ẹ la ramhi ukpẹsẹ agbọ.”
