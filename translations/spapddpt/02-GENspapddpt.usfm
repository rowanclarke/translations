\p Raquel respondió: Bueno, \w que|strong="H1571"\w* \w se|strong="H3651"\w* una \w contigo|strong="H5973"\w* \w esta|strong="H3651"\w* \w noche|strong="H3915"\w* \w en|strong="H5973"\w* pago \w por|strong="H8478"\w* las \w mandrágoras|strong="H1736"\w* \w de|strong="H8478"\w* tu \w hijo|strong="H1121"\w*.   
\p
\v 16 \w Cuando|strong="H3588"\w* \w Jacob|strong="H3290"\w* regresaba \w del|strong="H4480"\w* \w campo|strong="H7704"\w* \w al|strong="H4480"\w* llegar \w la|strong="H1931"\w* \w noche|strong="H3915"\w*, \w Lea|strong="H3812"\w* \w le|strong="H1931"\w* \w salió|strong="H3318"\w* \w al|strong="H4480"\w* encuentro, \w y|strong="H3588"\w* dijo: Únete \w a|strong="H3068"\w* mí, \w porque|strong="H3588"\w* \w te|strong="H4480"\w* alquilé formalmente \w por|strong="H3588"\w* unas \w mandrágoras|strong="H1736"\w* \w de|strong="H4480"\w* mi \w hijo|strong="H1121"\w*. \w Y|strong="H3068"\w* \w se|strong="H1931"\w* unió \w con|strong="H5973"\w* \w ella|strong="H1931"\w* \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w*.   
\p
\v 17 \nd ʼElohim\nd* \w oyó|strong="H8085"\w* \w a|strong="H3068"\w* \w Lea|strong="H3812"\w*, quien \w concibió|strong="H2029"\w* y dio \w a|strong="H3068"\w* luz un \w quinto|strong="H2549"\w* \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*.  
\v 18 \w Y|strong="H3068"\w* \w Lea|strong="H3812"\w* dijo: \nd ʼElohim\nd* me \w dio|strong="H5414"\w* mi recompensa, \w por|strong="H5414"\w* cuanto \w di|strong="H5414"\w* mi esclava \w a|strong="H3068"\w* mi esposo. \w Por|strong="H5414"\w* eso lo \w llamó|strong="H7121"\w* Isacar.   
\p
\v 19 \w Lea|strong="H3812"\w* \w concibió|strong="H2029"\w* \w otra|strong="H5750"\w* vez y dio \w a|strong="H3068"\w* luz un \w sexto|strong="H8345"\w* \w hijo|strong="H1121"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*.  
\v 20 \w Y|strong="H3068"\w* \w Lea|strong="H3812"\w* dijo: \nd ʼElohim\nd* \w me|strong="H3588"\w* dio \w buena|strong="H2896"\w* \w dote|strong="H2064"\w*. \w Porque|strong="H3588"\w* le di \w a|strong="H3068"\w* luz \w seis|strong="H8337"\w* \w hijos|strong="H1121"\w*, esta \w vez|strong="H6471"\w* mi esposo vivirá conmigo. \w Y|strong="H3068"\w* lo \w llamó|strong="H7121"\w* \w Zabulón|strong="H2074"\w*.   
\p
\v 21 Después dio \w a|strong="H3068"\w* luz una \w hija|strong="H1323"\w* y la \w llamó|strong="H7121"\w* \w Dina|strong="H1783"\w*.   
\p
\v 22 \nd ʼElohim\nd* se acordó de Raquel. \nd ʼElohim\nd* la \w oyó|strong="H8085"\w* y \w abrió|strong="H6605"\w* su \w matriz|strong="H7358"\w*.  
\v 23 \w Concibió|strong="H2029"\w* y dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*, y dijo: \nd ʼElohim\nd* quitó mi \w afrenta|strong="H2781"\w*.  
\v 24 Lo \w llamó|strong="H7121"\w* \w José|strong="H3130"\w* y dijo: \w Añádame|strong="H3254"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* otro \w hijo|strong="H1121"\w*.   
\p
\v 25 \w Aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* Raquel dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w José|strong="H3130"\w*, \w Jacob|strong="H3290"\w* dijo \w a|strong="H3068"\w* \w Labán|strong="H3837"\w*: Despídeme \w para|strong="H1961"\w* \w que|strong="H1961"\w* me \w vaya|strong="H3212"\w* \w a|strong="H3068"\w* \w mi|strong="H1961"\w* \w lugar|strong="H4725"\w* y \w a|strong="H3068"\w* \w mi|strong="H1961"\w* tierra.  
\v 26 \w Dame|strong="H5414"\w* \w mis|strong="H5414"\w* esposas \w y|strong="H3588"\w* \w mis|strong="H5414"\w* \w hijos|strong="H3206"\w* \w por|strong="H3588"\w* \w los|strong="H3588"\w* cuales \w te|strong="H3588"\w* serví, \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w iré|strong="H3212"\w*, \w pues|strong="H3588"\w* tú \w bien|strong="H3588"\w* \w sabes|strong="H3045"\w* \w cuál|strong="H3588"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* trabajo \w que|strong="H3588"\w* realicé \w para|strong="H3588"\w* ti.   
\p
\v 27 Pero \w Labán|strong="H3837"\w* \w le|strong="H5869"\w* respondió: \w Halle|strong="H4672"\w* \w yo|strong="H4994"\w* \w gracia|strong="H2580"\w* ante tus \w ojos|strong="H5869"\w*. Percibí \w que|strong="H4994"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* me \w bendijo|strong="H1288"\w* por tu causa.  
\v 28 \w Y|strong="H3068"\w* añadió: \w Señálame|strong="H5344"\w* tu \w salario|strong="H7939"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w lo|strong="H5921"\w* \w pagaré|strong="H5414"\w*.   
