\v 12 \w May|strong="H1961"\w* \w the|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd* \w reward|strong="H7999"\w* \w your|strong="H3068"\w* efforts! \w May|strong="H1961"\w* \w your|strong="H3068"\w* \w acts|strong="H6467"\w* \w of|strong="H3068"\w* kindness \w be|strong="H1961"\w* \w repaid|strong="H7999"\w* \w fully|strong="H7999"\w* \w by|strong="H3068"\w* \w the|strong="H3068"\w* \nd \w Lord|strong="H3068"\w*\nd* \w God|strong="H3068"\w* \w of|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w from|strong="H3478"\w* whom \w you|strong="H5973"\w* \w have|strong="H1961"\w* \w sought|strong="H2620"\w* \w protection|strong="H2620"\w*!”
\v 13 \w She|strong="H3588"\w* \w said|strong="H1696"\w*, “\w You|strong="H3588"\w* really \w are|strong="H5869"\w* \w being|strong="H1961"\w* kind \w to|strong="H1696"\w* \w me|strong="H5921"\w*, sir, \w for|strong="H3588"\w* \w you|strong="H3588"\w* \w have|strong="H1961"\w* reassured \w and|strong="H5869"\w* encouraged \w me|strong="H5921"\w*, \w your|strong="H5921"\w* \w servant|strong="H8198"\w*, \w even|strong="H3588"\w* \w though|strong="H3588"\w* \w I|strong="H3588"\w* \w am|strong="H1961"\w* \w not|strong="H3808"\w* \w one|strong="H3808"\w* \w of|strong="H5869"\w* \w your|strong="H5921"\w* \w servants|strong="H8198"\w*!”
\p 
\v 14 \w Later|strong="H4480"\w* during \w the|strong="H4480"\w* \w mealtime|strong="H6256"\w* \w Boaz|strong="H1162"\w* said \w to|strong="H6256"\w* \w her|strong="H7646"\w*, “\w Come|strong="H5066"\w* \w here|strong="H1988"\w* \w and|strong="H3899"\w* \w have|strong="H7646"\w* \w some|strong="H4480"\w* \w food|strong="H3899"\w*! \w Dip|strong="H2881"\w* \w your|strong="H4480"\w* \w bread|strong="H3899"\w* \w in|strong="H3427"\w* \w the|strong="H4480"\w* \w vinegar|strong="H2558"\w*!” \w So|strong="H4480"\w* \w she|strong="H6256"\w* \w sat|strong="H3427"\w* \w down|strong="H3427"\w* \w beside|strong="H6654"\w* \w the|strong="H4480"\w* harvesters. \w Then|strong="H5066"\w* \w he|strong="H4480"\w* handed \w her|strong="H7646"\w* \w some|strong="H4480"\w* \w roasted|strong="H7039"\w* \w grain|strong="H7039"\w*. \w She|strong="H6256"\w* ate \w until|strong="H3899"\w* \w she|strong="H6256"\w* \w was|strong="H3427"\w* \w full|strong="H7646"\w* \w and|strong="H3899"\w* \w saved|strong="H3498"\w* \w the|strong="H4480"\w* \w rest|strong="H3498"\w*.
