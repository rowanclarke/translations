\id 2PE
\h ÁR ÑOHO AR PEDRO
\toc1 ÁR ÑOHO AR PEDRO Ár ñoho ar he̱ꞌmi bi ꞌyotꞌa ar Pedro
\toc2 ÁR ÑOHO AR PEDRO
\toc3 2 P.
\mt1 ÁR ÑOHO AR PEDRO
\mt2 Ár ñoho ar he̱ꞌmi bi ꞌyotꞌa ar Pedro
\c 1
\s1 Ar nze̱ngwa
\p 
\v 1 Nuga dar Simu, tꞌengagi ar Pedro, ár ꞌbe̱gogi ne ár mpo̱tegi ar tsi Hmu Hesukristo. Di otꞌahu̱ nunar he̱ꞌminu̱ nuꞌahu̱ xka tsu̱hu̱ nꞌar nza̱tho jamfi ngu nöꞌö di pe̱ꞌsje. Xka tsu̱hu̱ nunar jamfinu̱, ngetho xa ar hogajöꞌi ma Jöhu̱ ne ma Po̱ho̱tehu̱ ma tsi Hmuhu̱ Hesukristo.
\p 
\v 2 Dá hñuxa ar nhwëki ne ar hogamꞌu̱i gi höñhu̱, ngetho gi pöhu̱ Jö ne ma tsi Hmuhu̱ Hesukristo.
\s1 Nuya ku di hñöxa ár mꞌu̱i Jö
\p 
\v 3 Jö xa pe̱ꞌsa ár tsꞌe̱di, ne xi ꞌrakagihu̱ gatho nöꞌö di hoñhu̱ ga ꞌbu̱hu̱ ne ga pe̱fu̱ xiñho, ngetho nöꞌö togo bi zokagihu̱ xa döta ár nsunda, gese̱ꞌö bi ñꞌudi ga pötwabihu̱.
\p 
\v 4 Ne xi ꞌraju̱ ya nza̱tho ñhötꞌi thota ár mhödi ne xa döta. Njapꞌu̱ da tsa̱ di hñöxꞌahu̱ ár mꞌu̱i Jö, ngetho xka hye̱hu̱pꞌu̱ ar tsꞌoki jawa har ximha̱i, tꞌo̱tꞌe te̱nga yá tsꞌonhe ya jöꞌi.
\p 
\v 5 Jange nuꞌahu̱ xa gi umba ri mu̱ihu̱ gi te̱twabihu̱ da me̱wi ri jamfihu̱ ar hogamꞌu̱i, ha nunar hogamꞌu̱i di pe̱wi ar hoga mfödi.
\p 
\v 6 Nunar hoga mfödi di pe̱wi ar ntsꞌuni, ha nunar ntsꞌuni di pe̱wi ar tsꞌe̱ti, ha nunar tsꞌe̱ti di pe̱wi ar nhwëki.
\p 
\v 7 Ha nunar nhwëki di pe̱wi ar mhöte nꞌa ngu nꞌa, ne nöꞌö gi mhöhu̱ nꞌa ngu nꞌa, di pe̱wi gi möhu̱ gatho nu maꞌra.
\p 
\v 8 Ngetho nuꞌmu̱ xa gi pe̱ꞌsu̱yu̱, ne gi jafu̱ da xu, hinda ma da mꞌe̱pꞌu̱ xka pöhu̱ ar tsi Hmu Hesukristo, hingi ꞌbu̱hu̱ njapꞌu̱tho hinter mꞌe̱fi ri tehu̱.
\p 
\v 9 Ha nuꞌu̱ togo hingi pe̱ꞌsa nuya ñhoyu̱ pe̱wi yá jamfi, o̱tꞌa ngoda̱, hingi honga nöꞌö bi e mhetsꞌi, ne xi pumhni xi nsu̱kwa yá tsꞌoki xki ꞌyo̱tꞌa mamꞌe̱tꞌo.
\p 
\v 10 Jange tsi kuhu̱, xa gi umba ri mu̱ihu̱ gi ñꞌuhu̱ xi tsꞌoñꞌahu̱ ne xi thañꞌahu̱, ngetho nuꞌmu̱ gi ꞌyo̱thu̱ njapꞌu̱, xi ñhembi gi ta̱hu̱.
\p 
\v 11 Ne njapꞌu̱ ma da sokꞌahu̱ nꞌar döta ne nza̱tho goxthi, ne gi ku̱thu̱ har tsꞌu̱tꞌwi hiñhamꞌu̱ da thege, ár me̱ti ma Po̱ho̱tehu̱ ne ma tsi Hmuhu̱ Hesukristo.
\p 
\v 12 Nuga hinga ma ga tsa̱ya̱ ga beñꞌahu̱ gathoyu̱, mödi xka pöhu̱ ne xi ze̱tꞌa ri jamfihu̱ gi te̱ñhu̱ nöꞌö majöni xi nsiꞌahu̱.
\p 
\v 13 Di beni nupya di ꞌbu̱tho, gehnu̱ ma ꞌbe̱fi ga bempꞌahu̱ gi ꞌyo̱thu̱yu̱.
\p 
\v 14 Ngetho di pödi ngutꞌa ma ga he̱kwa nunar ndoꞌyonu̱, ngu xi xikagi ar tsi Hmu Hesukristo.
\p 
\v 15 Ma ga umba ma mu̱i nꞌehe, núꞌmu̱ xka ñꞌeꞌbe nunar ha̱inu̱, nuꞌahu̱ hyaxꞌmu̱ gi benthu̱ nuya xta utꞌahu̱.
\s1 Da̱majöni nuꞌu̱ togo bi hyandwase̱ ár nsunda ar tsi Hmu Hesukristo
\p 
\v 16 Nuje xta utꞌahe ngu da handwase̱he ár tsꞌe̱di ne ár ꞌñehe ma tsi Hmuhu̱ Hesukristo, hinge ngu enga ya ꞌbede xi bense̱ ya jöꞌi.
\p 
\v 17 Da hanthe núꞌmu̱ Jö ar Dada bi ꞌñeꞌspa ár nsu ne bi umba ar nsunda, núnu̱ habu̱ bi nheki nunar mhö ndi ꞌñe har nsunda mhetsꞌi, mi enö: Gehnu̱ ma hmöka Tꞌu̱, jakagi ga njohya.
\p 
\v 18 Ne nuje da o̱he nunar mhönu̱ ndi ꞌñe mhetsꞌi núꞌmu̱ ndi ꞌbu̱ꞌbehe har jöpa tꞌo̱ho̱.
\p 
\v 19 Gatho nuya thogiyu̱ xi ñꞌudi majöni nöꞌö xki mönga yá mꞌe̱hni Jö. Jange xiñho gi jafu̱masu nuya mhöyu̱, ngu nꞌar ñotꞌi yotꞌahu̱ madeda ar ꞌbe̱xui, gi to̱ꞌmhu̱ da hatsꞌi ne da yotꞌahu̱ ar njötso̱ po̱xa ꞌbu̱ xudi.
\p 
\v 20 Ho̱nse̱ beñhu̱ mꞌe̱tꞌo, gatho nöꞌö xi ꞌyotꞌa yá mꞌe̱hni Jö har Tꞌofo, hinda tsa̱ ga bense̱hu̱ nöꞌö tema ne da mö, go utkagihu̱ Jö.
\p 
\v 21 Ngetho nuya te bi mönga nuya mꞌe̱hniꞌu̱, hingar mfenise̱ nꞌar jöꞌi. Bi tꞌumbabi nuꞌu̱ yá ꞌbe̱go Jö mi ꞌbu̱ nꞌar mꞌu̱i xintꞌaxi, mi möñꞌu̱ ngu mi xipa ár Hñö Jö nda mö.
\c 2
\s1 Ya kate mꞌe̱hni ne ya kate utate
\r (Ar Huda 3‑13)
\p 
\v 1 Mi ꞌbu̱ nuya paꞌu̱ ya kate mꞌe̱hni har hnini Israel, ngu ma da nja ya kate utate habu̱ gi ꞌbu̱hu̱ nꞌehe. Nuyu̱ ma da ku̱tꞌa ñꞌöntho ya tsꞌomhö da hwata ar nijö. Hinge ho̱nse̱ꞌö, ma da ko̱nga ar tsi Hmu togo bi gu̱ka har tsꞌoki, ne njapꞌu̱ ma da nhwati nꞌagitho.
\p 
\v 2 Ne nze̱ye̱ ma da de̱mba yá tsꞌoꞌbe̱fi, ne go yá tsꞌokiyu̱ ma da tsꞌanga ar ꞌñu majöni.
\p 
\v 3 Xa ya nzibjö, ma da gu̱kꞌahu̱ yá nthöhö di mönga ya nhemhñö. Nuyu̱ yanu̱ mahamꞌu̱ xi tꞌe̱kwa yá mfe̱i, ne ꞌba̱pꞌu̱tho ar pa da nhwati.
\p 
\v 4 Ngetho Jö himbi pumbabi ya e̱nxe̱ bi ntsꞌoki. Bi ꞌyu̱tꞌa har tsibi, ne bi ꞌñetꞌa har fa̱di xi mꞌe̱xui, tꞌe̱gi da zo̱nga ár pa ar mfe̱i.
\p 
\v 5 Ne himbi pumba nuya jöꞌi mi ꞌbu̱ mamꞌe̱tꞌo, ba pe̱mpa ar döꞌye bi goꞌma xo̱ge ar ximha̱i mi ꞌbu̱ har tsꞌoki. Ho̱nse̱ bi ꞌye̱ ar Noe mi uta ya jöꞌi ar hogamꞌu̱i, nunu̱ ne ma yoto bi kꞌontꞌwi.
\p 
\v 6 Ne mba mꞌe̱mpa ar mfe̱i nda nhwata ar hnini Sodoma ne Gomora, ho̱nse̱ ar ꞌbospi bi gohi. Ne bi japꞌu̱ ngu nꞌar ntꞌudi ma da njapabipꞌu̱ nuꞌu̱ ne da mꞌu̱ nꞌar tsꞌomꞌu̱i.
\p 
\v 7 Ne bi ꞌye̱kwa ár te ar Lot togo mar hogajöꞌi, mi tupa ár mu̱i mi handi hanja mi ꞌbu̱ nuya tsꞌojöꞌiyu̱.
\p 
\v 8 Ngetho nunar hogajöꞌinu̱ mi ꞌbu̱hwiꞌu̱, jange hyaxꞌmu̱ mi tupa ár hogamu̱i mi handi ne mi o̱ꞌspa yá tsꞌoꞌbe̱fi.
\p 
\v 9 Ja nhekinu̱, ar tsi Hmu njambödi da ma̱xa da tho ar tsꞌa̱ti nuꞌu̱ ya hogajöꞌi, ne da ꞌye̱kwatho yá mfe̱i nuꞌu̱ togo o̱tꞌa ar tsꞌoki, da tꞌumba nunar pa da thöxamajöni.
\p 
\v 10 Ne töte yá mfe̱i nuꞌu̱ togo bi de̱nga gatho nöꞌö mi ne yá ndoꞌyo. ꞌYoꞌu̱ har tsꞌoki ne o̱tꞌa gatho nöꞌö xintsꞌotho, hingi ne togo da me̱hni. Xa ya gese̱ ne xi me yá ñö, hingi ntsu da zanga nuꞌu̱ togo pe̱ꞌsa yá tsꞌe̱di.
\p 
\v 11 Nuya e̱nxe̱ mödi töte yá tsꞌe̱di ne yá nsunda, tsupi hingi a̱ nꞌar mfe̱i da zu̱hyu̱ núꞌmu̱ ꞌbu̱ꞌu̱ hár nthandi ar tsi Hmu.
\p 
\v 12 Ha nuya jöꞌiyu̱ ñömañꞌu̱ nöꞌö hingi pödi, ngu ya me̱ti hiñꞌotho yá mfeni, xi tꞌe̱ntꞌi da tho ne da nhwati. Nuyá tsꞌokise̱ da zixa har ꞌbe̱xui.
\p 
\v 13 Ma da hñönga yá nthöhö ngu ya tsꞌokte, ngetho gehyu̱ yá johyayu̱, zo̱da ar hyadi o̱tꞌa gatho nöꞌö neꞌu̱. Nꞌar mꞌe̱tsa̱yu̱, ngetho núꞌmu̱ gi ntsixkwihu̱, ñꞌentho o̱tꞌu̱ nöꞌö hingi ho.
\p 
\v 14 Nuyu̱ ho̱nse̱ xa hyo̱kwa yá nthöti maꞌra, hingi tsa̱bi o̱tꞌa ya tsꞌoki. Ha̱tꞌi da zo ha yá ꞌye̱yu̱ nuꞌu̱ togo hinxi ze̱ta yá ñꞌemu̱i. Ha yá mu̱i xi nzöi hyo̱kwa yá me̱ti maꞌra. Yá bötsiyu̱ ar ꞌbe̱xui.
\p 
\v 15 Xi hye̱ꞌu̱ ar ꞌñu majöni, ne xi de̱mba ár ꞌñu ar Balam ár tꞌu̱ ar Beor, togo xa bi mö ár nthöhö ar tsꞌoki.
\p 
\v 16 Mödi nꞌar me̱ti ndu bi ñö ngu nꞌar ñꞌo̱ho̱, bi zu̱i himbi hye̱gi nda ꞌyo̱tꞌa nöꞌö mi beni.
\p 
\v 17 Nuya jöꞌiyu̱ ñhe̱hwi ya po̱the hinte unga ar dehe, ne ngu ya gui tuxta ar ꞌyomndöhi. Xi tꞌe̱kwabi da mꞌu̱ har ꞌbe̱xui hiñhamꞌu̱ da götsꞌi.
\p 
\v 18 Ngetho ñö ya mhö ñꞌetsꞌi hinte yá ñho. Njapꞌu̱ koꞌsa nuꞌu̱ majöni mi ne nda hye̱ nuꞌu̱ togo ꞌbu̱ har tsꞌoki, ne kadi da ꞌyo̱tꞌa gatho nöꞌö ne yá ndoꞌyo.
\p 
\v 19 Xipabiꞌu̱ da xotꞌa yá nthötꞌi, ha gese̱ꞌu̱ xi nthötꞌa har tsꞌoki. Ngetho nöꞌö togo da nthöhö, nu togo bi döhö po̱ntho xi dötꞌi, japi da ꞌyo̱tꞌa nöꞌö neꞌö.
\p 
\v 20 Xa majöni di xiꞌahu̱, nuꞌmu̱ xki kꞌothmöꞌu̱ ha ya tsꞌoki ja har ximha̱i ngetho xki bötwa ár ꞌñu ar tsi Hmu ne ar Po̱ho̱te Hesukristo, ne da mengi da zo habu̱ mi ku̱ꞌu̱, da mꞌe̱di ne yá mꞌu̱i töpa ár ntsꞌotho mi ꞌbu̱ mꞌe̱tꞌo.
\p 
\v 21 Ngetho mar ñhomhö hinxi böhmöꞌu̱ ar ꞌñu tsixa ar hogajöꞌi, hinge ho̱nse̱ bi bödi, ne bi mengi bi hye̱pꞌu̱ ar döta ꞌbe̱pate bi tꞌumbabi.
\p 
\v 22 Ne xpa epabi ngu enga ar mhö majöni: Ar ꞌyo pengi ju̱xa ár tsꞌodi, ne ar tsꞌu̱di xi nsati, pengi da ntönga har bo̱ha̱i.
\c 3
\s1 Ar pa da nheki ár tsꞌe̱di ar tsi Hmu xi ꞌñepꞌu̱
\p 
\v 1 Ma tsi hmöka kuhu̱, gehnu̱ ár ñoho ar he̱ꞌmi di otꞌahu̱, ne gatho yohoyu̱ di hupꞌa ri mu̱ihu̱ gi pe̱ꞌsu̱ nꞌar mfeni xintꞌaxi.
\p 
\v 2 Di ne gi beñhu̱ nuya mhö bi mönga mamꞌe̱tꞌo yá hoga mꞌe̱hni Jö, ne nuya ꞌbe̱pate bi zokꞌahu̱ ma tsi Hmuhu̱ ne ma Po̱ho̱tehu̱, gehnu̱ bi xiꞌahu̱ yá mpo̱te ar tsi Hmu gi ꞌñehu̱.
\p 
\v 3 Pöhu̱ mꞌe̱tꞌo, nuya ngöxapa ma da e ya thente di ꞌbu̱ ngu nese̱ꞌu̱.
\p 
\v 4 Di eñꞌu̱: Te bi ja ar ñhötꞌi nda e ar tsi Hmu Hesukristo. Ngetho bi the ma palehu̱, ha nunar ximha̱i njangutho ngu ar pa bi thoki.
\p 
\v 5 Nuyu̱ nese̱ da pumhni gehnu̱ ár mhö Jö bi hyoka mamꞌe̱tꞌo ar mhetsꞌi ne ar ximha̱i. Ba ehyu̱ har dehe ne oxta har dehe.
\p 
\v 6 Jange nunar ximha̱i mi ꞌbu̱ mahamꞌu̱, bi hwata ar dehe mi ñutsꞌi.
\p 
\v 7 Ha nunar mhetsꞌi ne nunar ha̱i ꞌbu̱pya, getnu̱ ár mhö Jö e̱kwi da nzo̱ har tsibi nunar pa da thöxamajöni, ne da tꞌumba ár mfe̱i ya tsꞌokte.
\p 
\v 8 Tsi kuhu̱, yo gi pumhnihu̱ nꞌehe, nunar tsi Hmu handa nꞌapa ngu ꞌre̱tꞌanthebe ya je̱ye̱, ne ꞌre̱tꞌanthebe ya je̱ye̱ handa ngu nꞌapatho.
\p 
\v 9 Ar tsi Hmu hingi huꞌsta ar pa da ꞌyo̱tꞌa nöꞌö xi ñötꞌi, ngu benga ꞌra. Pe̱ꞌskagihu̱ ar tsꞌe̱ti hingi ne togo da mꞌe̱di, neꞌö gatho da ꞌyo̱tꞌwa yá ntso̱ꞌmi.
\p 
\v 10 Ha nunar pa da e ar tsi Hmu, ma da zo̱ ngu nꞌar bë tso̱ ꞌbu̱ nxui. Nuꞌmú̱, nuya mhetsꞌi ma da nhwati, da ntꞌo̱ nꞌar döta ñu̱ni, ne gatho nöꞌö te janu̱ ma da xutꞌa har tsibi, ha nu ar ximha̱i ne gatho nöꞌö te jawa ma da nzo̱.
\p 
\v 11 Nuꞌmu̱ ma da nhwata gathoyu̱, yoꞌö hingi ꞌbu̱hu̱ nꞌar mꞌu̱i xintꞌaxi ne gi ñhogajöꞌihu̱.
\p 
\v 12 Ne gi ndo̱ꞌmhu̱ da zo̱ ár pa Jö, ne xa gi umba ri mu̱ihu̱ gi jafu̱ ngutꞌa da zo̱ho̱. Nuya paꞌu̱ ar mhetsꞌi ma da nde̱ ne da xutꞌi, ne gatho nöꞌö te janu̱ ma da mi har tsibi.
\p 
\v 13 Ha nuju̱ di to̱ꞌmhu̱ manꞌar ꞌraꞌyo mhetsꞌi ne manꞌar ꞌraꞌyo ximha̱i, habu̱ ho̱nse̱ ja ar hogamꞌu̱i.
\p 
\v 14 Jange tsi kuhu̱, nuꞌmu̱ gi to̱ꞌmhu̱ nuya ñhötꞌiyu̱, umba ri mu̱ihu̱ da diñꞌahu̱ hinte ma ja̱xtꞌi gi pe̱ꞌsu̱, dar ntꞌaxiꞌihu̱ ne gi ꞌbu̱hu̱ nꞌar hogamꞌu̱i.
\p 
\v 15 Ne pöhu̱ xiñho, nunar tsi Hmu pe̱ꞌsa ar tsꞌe̱ti honi da mpo̱ gatho ya jöꞌi, jangu ma tsi kuhu̱ Pablo xi tꞌumba ar hoga mfödi xi ꞌyotꞌahu̱.
\p 
\v 16 Gatho nuya he̱ꞌmi xi ꞌyotꞌi, no̱nga nöꞌö xta xiꞌahu̱. ꞌRayu̱ xi ñhembi da födi te ne da ꞌñenö. Jange nuꞌu̱ hintsꞌu̱ pödi ne hingi tse̱ yá mu̱i, pa̱ti. Japꞌu̱ nu maꞌra ya Tꞌofo nꞌehe, ne da ꞌyo̱tꞌa ngu neꞌu̱, ne njapꞌu̱ honse̱ yá mfe̱ise̱.
\p 
\v 17 Jange nuꞌahu̱ ma tsi hmöka kuhu̱, xka pöhu̱, jamasuhu̱ yo ma da hya̱ꞌahu̱ yá tsꞌoki ya tsꞌokte, ne gi hye̱hu̱pꞌu̱ ár tsꞌe̱di ri jamfihu̱.
\p 
\v 18 Nöꞌö gi ꞌyo̱thu̱, dá hñutsꞌi gi pöhu̱ ma tsi Hmuhu̱ ne ma Po̱ho̱tehu̱ Hesukristo, ne dá te ri mfödihu̱ hár nhwëki. Go di ꞌñepꞌu̱ da tꞌumba ar nsunda nupya ne hiñhamꞌu̱ da ntsa̱ya̱. Dá njapꞌu̱.
