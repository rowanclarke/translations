\v 12 \w In|strong="H1004"\w* similar fashion, \w one|strong="H3671"\w* \w wing|strong="H3671"\w* \w of|strong="H1004"\w* \w the|strong="H5060"\w* second \w cherub|strong="H3742"\w* \w was|strong="H1004"\w* \w five|strong="H2568"\w* \w cubits|strong="H2568"\w* long \w and|strong="H1004"\w* \w touched|strong="H5060"\w* \w one|strong="H3671"\w* \w Temple|strong="H1004"\w* \w wall|strong="H7023"\w*, \w while|strong="H1004"\w* \w its|strong="H5060"\w* \w other|strong="H3671"\w* \w wing|strong="H3671"\w*, also \w five|strong="H2568"\w* \w cubits|strong="H2568"\w* long, \w touched|strong="H5060"\w* \w the|strong="H5060"\w* first \w cherub|strong="H3742"\w*.  
