\v 49 \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Hanan|strong="H2605"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Guiddel|strong="H1435"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Gahar,  
\v 50 \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Reaja|strong="H7211"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Retsin|strong="H7526"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Nekoda|strong="H5353"\w*,  
\v 51 \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Gazzam|strong="H1502"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* d'\w Uzza|strong="H5798"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Paséah,  
\v 52 \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Bésaï|strong="H1153"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Meunim, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Nephushesim,  
\v 53 \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Bakbuk|strong="H1227"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Hakupha|strong="H2709"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Harhur|strong="H2744"\w*,  
\v 54 \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Batslith|strong="H1213"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Mehida|strong="H4240"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Harsha,  
\v 55 \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Barkos|strong="H1302"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Sisera|strong="H5516"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Théma,  
\v 56 \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Netsiah, \w et|strong="H1121"\w* \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Hatipha.   
\p
\v 57 \w Les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w des|strong="H1121"\w* \w serviteurs|strong="H5650"\w* \w de|strong="H1121"\w* \w Salomon|strong="H8010"\w* : \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Sotaï, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Sophereth|strong="H5618"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Périda|strong="H6514"\w*,  
\v 58 \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Jaala|strong="H3279"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Darkon|strong="H1874"\w*, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* \w Guiddel|strong="H1435"\w*,  
\v 59 \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Shephatia, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Hattil, \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w de|strong="H1121"\w* Pokéreth-Hatsebajim, \w et|strong="H1121"\w* \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* d'Amon.  
\v 60 \w Tous|strong="H3605"\w* \w les|strong="H1121"\w* \w serviteurs|strong="H5650"\w* \w du|strong="H1121"\w* temple \w et|strong="H1121"\w* \w les|strong="H1121"\w* \w enfants|strong="H1121"\w* \w des|strong="H1121"\w* \w serviteurs|strong="H5650"\w* \w de|strong="H1121"\w* \w Salomon|strong="H8010"\w* \w étaient|strong="H1121"\w* \w au|strong="H1121"\w* \w nombre|strong="H1121"\w* \w de|strong="H1121"\w* \w trois|strong="H7969"\w* \w cent|strong="H3967"\w* quatre-vingt-douze.   
\p
\v 61 Voici \w ceux|strong="H1992"\w* \w qui|strong="H3478"\w* \w montèrent|strong="H5927"\w* \w de|strong="H1004"\w* Tel-Mélah, \w de|strong="H1004"\w* Tel-Harsha, \w de|strong="H1004"\w* \w Kerub|strong="H3743"\w*, \w d|strong="H1992"\w*'Addon \w et|strong="H3478"\w* \w d|strong="H1992"\w*'Immer ; mais \w ils|strong="H1992"\w* \w ne|strong="H3808"\w* \w purent|strong="H3201"\w* \w montrer|strong="H5927"\w* \w leurs|strong="H1004"\w* \w maisons|strong="H1004"\w* \w paternelles|strong="H1004"\w*, \w ni|strong="H3808"\w* \w leur|strong="H3478"\w* descendance,\f + \fr 7.61 \ft ou, postérité\f* \w pour|strong="H1004"\w* prouver qu'\w ils|strong="H1992"\w* \w étaient|strong="H3478"\w* \w d|strong="H1992"\w*'\w Israël|strong="H3478"\w* :   
\li1
\v 62 Les enfants de Delaja, les enfants de Tobija, les enfants de Nekoda : six cent quarante-deux.   
\li1
\v 63 Et parmi les prêtres : les enfants de Hobaja, les enfants de Hakkots, les enfants de Barzillaï, qui avait pris pour femme l'une des filles de Barzillaï le Galaadite, et fut appelé de leur nom.   
\p
\v 64 Ceux-ci \w cherchèrent|strong="H1245"\w* \w leurs|strong="H1245"\w* registres \w généalogiques|strong="H3187"\w*, mais \w ne|strong="H3808"\w* purent \w les|strong="H4672"\w* \w trouver|strong="H4672"\w*. C'est pourquoi \w ils|strong="H3808"\w* \w furent|strong="H3808"\w* déclarés \w impurs|strong="H1351"\w* \w et|strong="H3808"\w* exclus \w de|strong="H4480"\w* \w la|strong="H4672"\w* prêtrise.  
\v 65 \w Le|strong="H5975"\w* \w gouverneur|strong="H8660"\w* \w leur|strong="H5975"\w* \w dit|strong="H5975"\w* \w de|strong="H3808"\w* \w ne|strong="H3808"\w* \w pas|strong="H3808"\w* \w manger|strong="H3808"\w* \w des|strong="H3808"\w* \w choses|strong="H5975"\w* \w très|strong="H6944"\w* \w saintes|strong="H6944"\w*, jusqu'\w à|strong="H5704"\w* \w ce|strong="H3808"\w* qu'\w un|strong="H5975"\w* \w prêtre|strong="H3548"\w* \w se|strong="H3808"\w* lève \w pour|strong="H5704"\w* consulter l'Urim \w et|strong="H3548"\w* \w le|strong="H5975"\w* \w Thummim|strong="H8550"\w*.   
\p
\v 66 \w L|strong="H3068"\w*'\w assemblée|strong="H6951"\w* \w tout|strong="H3605"\w* \w entière|strong="H3605"\w* s'élevait à \w quarante-deux|strong="H6951"\w* \w mille|strong="H3967"\w* \w trois|strong="H7969"\w* \w cent|strong="H3967"\w* \w soixante|strong="H8346"\w*,  
\v 67 \w en|strong="H5650"\w* plus \w de|strong="H5650"\w* leurs \w serviteurs|strong="H5650"\w* \w et|strong="H5650"\w* \w de|strong="H5650"\w* leurs servantes, \w au|strong="H5650"\w* \w nombre|strong="H5650"\w* \w de|strong="H5650"\w* \w sept|strong="H7651"\w* \w mille|strong="H3967"\w* \w trois|strong="H7969"\w* \w cent|strong="H3967"\w* \w trente-sept|strong="H3967"\w*. Ils \w avaient|strong="H7969"\w* deux \w cent|strong="H3967"\w* \w quarante-cinq|strong="H3967"\w* \w chantres|strong="H7891"\w* \w et|strong="H5650"\w* \w chanteuses|strong="H7891"\w*.  
\v 68 \w Leurs|strong="H1581"\w* chevaux \w étaient|strong="H1581"\w* au nombre \w de|strong="H6242"\w* \w sept|strong="H7651"\w* \w cent|strong="H3967"\w* \w trente-six|strong="H3967"\w* ; \w leurs|strong="H1581"\w* mulets, deux \w cent|strong="H3967"\w* \w quarante-cinq|strong="H3967"\w* ;  
\v 69 \w leurs|strong="H5414"\w* chameaux, \w quatre|strong="H5414"\w* \w cent|strong="H3967"\w* \w trente-cinq|strong="H3967"\w* ; \w leurs|strong="H5414"\w* ânes, six \w mille|strong="H3967"\w* sept \w cent|strong="H3967"\w* vingt.   
\p
\v 70 Quelques-uns \w des|strong="H5414"\w* \w chefs|strong="H7218"\w* \w des|strong="H5414"\w* \w maisons|strong="H7218"\w* paternelles firent \w des|strong="H5414"\w* \w dons|strong="H5414"\w* \w pour|strong="H5414"\w* l'\w œuvre|strong="H4399"\w*. \w Le|strong="H5414"\w* \w gouverneur|strong="H5414"\w* \w donna|strong="H5414"\w* \w au|strong="H5414"\w* \w trésor|strong="H5414"\w* \w mille|strong="H3967"\w* \w dariques|strong="H1871"\w* d'\w or|strong="H2091"\w*,\f + \fr 7.70 \ft une darique était une pièce d'or émise par un roi perse, pesant environ 8,4 grammes.\f* cinquante coupes, \w et|strong="H3701"\w* cinq \w cent|strong="H3967"\w* trente tuniques \w de|strong="H7218"\w* prêtres.  
\v 71 Quelques \w chefs|strong="H5414"\w* \w de|strong="H5971"\w* \w maisons|strong="H3548"\w* paternelles \w donnèrent|strong="H5414"\w* \w pour|strong="H5414"\w* \w le|strong="H5414"\w* \w trésor|strong="H5414"\w* \w de|strong="H5971"\w* \w l|strong="H5971"\w*'œuvre \w vingt|strong="H8147"\w* \w mille|strong="H7239"\w* \w dariques|strong="H1871"\w* d'\w or|strong="H2091"\w*, \w et|strong="H5971"\w* \w deux|strong="H8147"\w* \w mille|strong="H7239"\w* \w deux|strong="H8147"\w* \w cents|strong="H8147"\w* \w mines|strong="H4488"\w*\f + \fr 7.71 \ft Une mine pèse environ 600 grammes, donc 2 200 mines représentent environ 1,3 tonne métrique.\f* d'\w argent|strong="H3701"\w*.  
\v 72 \w Le|strong="H1121"\w* \w reste|strong="H3427"\w* \w de|strong="H1121"\w* \w ce|strong="H3605"\w* \w que|strong="H1121"\w* \w le|strong="H1121"\w* \w peuple|strong="H5971"\w* donna \w fut|strong="H1121"\w* vingt \w mille|strong="H1121"\w* dariques d'or, \w plus|strong="H5971"\w* \w deux|strong="H5892"\w* \w mille|strong="H1121"\w* mines d'argent, \w et|strong="H1121"\w* soixante-sept tuniques \w de|strong="H1121"\w* \w prêtres|strong="H3548"\w*.   
\p
\v 73 Ainsi les prêtres, les Lévites, les portiers, les chantres, quelques-uns du peuple, les serviteurs du temple et tout Israël, s'établirent dans leurs villes.  
\p Quand le septième mois arriva, les enfants d'Israël étaient dans leurs villes.   
\c 8  
\p
