\id 1TI
\h 1 Timoteo
\toc1 Xo̱jo̱n carta‑la̱ San Pablo xi kiskiì ítjòn‑la̱ jè Timoteo
\toc2 1 Timoteo
\toc3 1 Ti.
\mt1 Xo̱jo̱n carta‑la̱ San Pablo xi kiskiì ítjòn‑la̱ jè Timoteo
\c 1
\s1 Kó tsò Pablo nga síhixat'aà Timoteo
\p 
\v 1 'A̱n, Pablo, tìkjiì‑lè xo̱jo̱n jè, nga 'a̱n tsibíxáya‑na Jesucristo, nga k'oa̱s'ín kitsjaà o̱kixi̱ Nainá xi ochrjekàjiìn‑ná kjo̱'in ko̱ Na̱'èn‑ná Jesucristo nga titsa̱chiñá‑lá kjo̱ndaà‑la̱.
\v 2 Ngaji̱ Timoteo, koni tsà ki'ndí ts'a̱n xan‑lè nga 'a̱n tsakoòyandaà‑lè koni s'ín mokjeiín‑ná i̱t'aà ts'e̱ Cristo. Nainá xi Na̱'èn‑ná ko̱ Na̱'èn‑ná Jesucristo kàtatsjá‑lè kjo̱ndaà, kàtahi̱ma̱keè‑lè, kàtas'e‑la̱ kjoa̱'nchán i̱jiìn ini̱ma̱‑lè.
\s1 Pablo tsibínè‑la̱ Timoteo nga si̱ìkixi̱ya xi̱ta̱ xi kj'ei̱í kjo̱hítsjeèn okóya
\p 
\v 3 Koni s'ín tsibìtsi'ba‑lè k'e̱ nga kiaà nangui Macedonia, ya̱á ti̱jni na̱xa̱ndá Éfeso mé‑ne nga ki̱chakjáya‑la̱ xi̱ta̱ xi mìtsà 'én kixi̱ nchihokóya i̱jiìn na̱xa̱ndá‑la̱ Nainá.
\v 4 Ngaji̱ Timoteo, k'oa̱á s'ín tjínè‑la̱ jñà xi̱ta̱ koi, kì kiì sís'in‑la̱ cuento jchínga xi mìtsà kixi̱ kjoa̱ ti̱koa̱ kì kiì sís'in‑la̱ kjoa̱ xi mìkiì fehet'aà ts'e̱ xi̱ta̱ jchínga kjòtseé. Kjoa̱ koi ni̱mé chjí‑la̱. Tà síkjaán‑kjoò‑ná. Mì kì osìko̱‑ná nga mokjeiín‑ná i̱t'aà ts'e̱ Cristo mé‑ne nga ko̱ma si̱kitasoán koni s'ín mejèn‑la̱ Nainá.
\p 
\v 5 Xá xi tìbìnè‑lè, jè‑né nga tsjeè tíjna ini̱ma̱‑ná, nga tsjeè tjín kjo̱hítsjeèn‑ná koa̱ nga nguì ndaà mokjeiín‑ná; ya̱á nchrobát'aà‑ne nga si̱tjòchaà xinguia̱á.
\v 6 Ta̱nga tjín i'nga xi̱ta̱ xi xìn ndi̱yá tjímaya; tà koií joóya‑ne 'én xi ni̱mé chjí‑la̱.
\v 7 Mejèn‑la̱ maestro ts'e̱ kjo̱tíxoma‑la̱ Nainá kítsa̱jna. Ta̱nga ti̱jñà‑ne, skanda mìkiì machi̱ya‑la̱ 'én xi chja̱ nga 'ñó chja̱ nga tsò nga kixi̱ kjoa̱.
\p 
\v 8 Tíjiìn‑ná nga jè kjo̱tíxoma xi kitsjaà Nainá, ndaà tjín tsà k'oa̱s'ín ko̱chjeén koni s'ín mejèn‑la̱ Nainá.
\v 9 'Ya‑ná, kjo̱tíxoma‑la̱ Nainá, mìtsà ts'e̱ jñà xi̱ta̱ xi ndaà s'ín. Ts'e̱‑né jñà xi̱ta̱ xi mìkiì 'nchréñijon koa̱ mìkiì síkitasòn; ts'e̱‑né xi̱ta̱ xi mìkiì beèxkón Nainá koa̱ ótsji jé; ts'e̱‑né xi̱ta̱ xi mì tsjeè tjín kjo̱hítsjeèn‑la̱ xi tjé beèhikon jè kjoa̱tsjeè‑la̱ Nainá; ts'e̱‑né xi̱ta̱ xi sík'en na̱'èn‑la̱ ko̱ nea̱‑la̱, ko̱ ngats'iì xi̱ta̱ xi xi̱ta̱ sík'en.
\v 10 Ti̱koa̱ ts'e̱‑né jñà xi̱ta̱ xi kjoa̱ chijnguií s'ín, jñà xi xi̱ta̱ xa'nda, xi̱ta̱ xi xíkjín fìko̱ chijé nga otíjna. Ti̱koa̱ ts'e̱‑né jñà xi̱ta̱ ndiso ko̱ xi̱ta̱ xi mìtsà 'én kixi̱ chja̱, jñà xi̱ta̱ xi ch'o tjín kjoa̱ xi s'ín xi kondra̱ ts'e̱ kjo̱hítsjeèn xi kixi̱ tjín.
\v 11 Jè kjo̱hítsjeèn kixi̱, k'oa̱á tjín xi okóya jñà 'én jeya‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo. Nainá xi 'ñó jeya tíjna, jè kisìnga̱tsja‑na nga 'a̱n kichjàya 'én koi.
\s1 Mé kjoa̱‑ne nga kitsjaà‑la̱ kjo̱ndaà Nainá jè Pablo
\p 
\v 12 Tsjaà‑la̱ kjo̱ndaà Na̱'èn‑ná Jesucristo. Ndaà chjí‑la̱ nga kitsjaà‑na nga'ñó ti̱koa̱ ndaà kijtseè ikon‑na nga 'a̱n kisìnga̱tsja‑na xá‑la̱,
\v 13 na̱s'ín k'e̱ nga sa̱ ítjòn, 'ñó ch'o kis'iaàn; kichjàjno‑la̱ Nainá; kondra̱ kiìtji̱ngui‑la̱; toòn kijtseè xi̱ta̱‑la̱. Ta̱nga kjòhi̱ma̱keè‑na Nainá, nga kj'eè kiì be, koa̱ kj'eè kiì mokjeiín‑na i̱t'aà ts'e̱ Cristo.
\v 14 Ta̱nga jè kjo̱tjò‑la̱ Na̱'èn‑ná ìsa̱á 'ñó tse kitsjaà‑na ti̱koa̱ kisìhiseèn‑na nga mokjeiín‑na ko̱ kitsjaà‑na kjoa̱tjòcha‑la̱ nga jè Cristo tìjna̱koa̱a.
\p 
\v 15 Jñà 'én koi, nguì 'én kixi̱‑né. Mochjeén‑né nga ko̱kjeiín yije‑la̱ xi̱ta̱ nga jè Jesucristo j'iì i̱ i̱sò'nde nga ko̱chrjekàjiìn kjo̱'in ngats'iì xi̱ta̱ xi jé tjín‑la̱. Ngats'iì xi̱ta̱ xi ch'o s'ín, 'a̱án tìjna̱ ítjoàn nga tsohotsjià jé.
\v 16 Na̱s'ín 'ñó ch'o kis'iaàn, Nainá kis'e‑la̱ kjo̱hi̱ma̱takòn i̱t'aà ts'a̱n. Jñà xi̱ta̱, k'e̱ nga skoe̱ kó s'ín kisìko̱‑na Na̱'èn‑ná Jesucristo, nga 'ñó tjín‑la̱ kjoa̱tsetakòn, ti̱koa̱á ko̱kjeiín‑la̱ i̱t'aà ts'e̱ Cristo nga s'e̱‑la̱ kjoa̱binachon ni̱ta̱ mé na̱chrjein‑ne.
\v 17 Nainá, 'nga kàtìjna, kàtas'e‑la̱ kjoa̱jeya ni̱ta̱ mé nó, ni̱ta̱ mé na̱chrjein‑ne nga jè otíxoma ni̱ta̱ mé na̱chrjein‑ne koa̱ mìkiì kjoe̱het'aà na̱chrjein‑la̱ ni̱ta̱ kjé‑ne, ti̱koa̱ mìkiì tsejèn ñánda tíjna koa̱ nguì jè ta̱jngoò xi Nainá. K'oa̱s'ín kàtama.
\p 
\v 18 Ngaji̱ Timoteo koni tsà ki'ndí‑na̱ xan‑lè, sìnga̱tsja‑lè 'én koi, koni s'ín kitsò xi̱ta̱ xi kisìkjeén Nainá nga kiìchja̱ i̱t'aà tsi̱ji, mé‑ne nga i̱t'aà ts'e̱ 'én koi, tsjá‑lè nga'ñó nga ndaà si̱xá‑la̱ Nainá koni s'ín síxá soldado.
\v 19 Ndaà kàtakjeiín‑lè i̱t'aà ts'e̱ Cristo, ti̱koa̱ ndaà kàtìjna kjo̱hítsjeèn‑lè. Tjín i'nga xi̱ta̱ xi mìkiì kisìs'in kjo̱hítsjeèn xi ndaà tjín. K'oa̱á komà‑ne nga kisìkje‑la̱ ikon nga mì ti̱ kiì kòkjeiín‑la̱.
\v 20 K'oa̱á s'ín komàt'in jè Himeneo ko̱ Alejandro xi 'a̱n kisìkítsa̱jnakoa̱a xi̱ta̱ nei̱í mé‑ne nga kàtakixi̱ya‑ne nga mì ta̱xki̱ ki̱chja̱jno‑la̱ Nainá.
\c 2
\s1 Mochjeén‑né nga kítsi'batjiá xinguia̱á
\p 
\v 1 Jè kjoa̱ xi ìsa̱ 'ñó mochjeén, k'oa̱á s'ín tìbìnè‑nò nga titsi'batjiò ngats'iì xi̱ta̱, ti̱nókjoa̱t'aà‑là Nainá, tìtsi'ba‑là Nainá, tjiì‑là kjo̱ndaà i̱t'aà ts'e̱ ngats'iì xi̱ta̱ xi tjín nga tíjtsa i̱sò'nde.
\v 2 Mochjeén‑né nga kítsi'batjiá xi xi̱ta̱xá ítjòn títsa̱jna ko̱ ngats'iì xi kjo̱tíxoma tjíya tsja mé‑ne nga 'nchán ki̱tsa̱jna‑ná ti̱koa̱ ta̱fì ta̱fì si̱jchá yijo‑ná ti̱koa̱ jcha̱xkoán Nainá ko̱ jcha̱xkoán kjoa̱ xi ndaà tjín.
\v 3 K'e̱ nga k'oa̱s'ín s'e̱én ndaà tjín koa̱ ndaà sasén‑la̱ Nainá xi ochrjekátjì‑ná kjo̱'in.
\v 4 Nainá, jè xi mejèn‑la̱ nga ngats'iì xi̱ta̱ ki̱tjokàjiìn kjo̱'in ti̱koa̱ si̱jiìn‑la̱ kós'ín tjín xi kjoa̱kixi̱.
\v 5 Tà jngoò ma Nainá; ti̱koa̱á tà jngoò ma xi̱ta̱ xi chja̱tjì‑ná i̱t'aà ts'e̱ Nainá, jè xi̱ta̱ xi Jesucristo 'mì.
\v 6 K'e̱ nga kichìya na̱chrjein‑la̱ Nainá, Jesucristo kitsjaà kjo̱tjò yijo‑la̱ nga k'en mé‑ne nga ko̱chjítjì‑ne ngats'iì xi̱ta̱ nga ma ki̱tjokàjiìn kjo̱'in. K'oa̱á s'ín kis'iìn nga kisijiìn yije‑la̱ xi̱ta̱.
\v 7 'A̱án kjònga̱tsja xá jè nga 'a̱n tsibíxáya‑na Cristo nga kichjàya 'én ndaà‑la̱ ti̱koa̱ kokoòya‑la̱ jñà xi mìtsà xi̱ta̱ judío nga ko̱kjeiín‑la̱ i̱t'aà ts'e̱ Cristo ti̱koa̱ skoe̱ xi kjoa̱kixi̱. 'Én kixi̱í xi tìxan‑lè, mìtsà 'én ndiso.
\p 
\v 8 I̱t'aà ts'e̱ xi̱ta̱ x'i̱n, mejèn‑na k'e̱ nga chja̱t'aà‑la̱ Nainá ni̱ta̱ ñánda i̱'nde títsa̱jna, tsjeè kàtasíkítsa̱jna ini̱ma̱‑la̱ k'e̱ nga skímiìtje̱n‑la̱ tsja Nainá. Kì kjoa̱jti tíjiìn ini̱ma̱‑la̱, koa̱ kì nchikjaán‑kjoò‑jèn.
\v 9 Ti̱koa̱ jñà íchjín, jè nikje xi ndaà ok'ìn‑la̱ kàtakjá. Kì nikje chjí ókjá. Kì ta̱xki̱ sí'ñójno sko̱ ko̱ yijo‑la̱ tsojmì xi 'ñó chjí koni ki̱cha̱ oro ko̱ perla. Chiba chiba kàtíndaà yijo‑la̱ mé‑ne nga mì xi̱ta̱ skótsejèn‑jno‑ne.
\v 10 Ta̱ sa̱á xá xi ndaà tjín kàtas'ín koni s'ín ok'ìn‑la̱ jñà íchjín xi beèxkón Nainá.
\v 11 Jñà íchjín jyò kàtìtsa̱jna k'e̱ nga skóta'yà 'én‑la̱ Nainá; kàta'nchréñijon‑la̱ jè xi okóya.
\v 12 'A̱n, mìkiì tsjaà'nde nga jñà íchjín ko̱tìxoma‑la̱ xi xi̱ta̱ x'i̱n koa̱ ko̱kòya‑la̱. Íchjín, jyò kàtìtsa̱jna.
\v 13 Koií kjoa̱‑la̱ jè Nainá ítjòn tsibíndaà Adán, i̱skan tsibíndaà Eva.
\v 14 Mìtsà jè Adán xi kichona̱cha̱n‑la̱; jè Eva xi chjo̱ón‑la̱. K'oa̱á s'ín komà‑ne nga kisakò jé‑la̱.
\v 15 Ta̱nga, jñà íchjín, tsà si̱ìkitasòn koni s'ín mejèn‑la̱ Nainá nga s'e̱‑la̱ i̱xti, ki̱tjokàjiín kjo̱'in. Mochjeén‑né nga ndaà ko̱kjeiín‑la̱ i̱t'aà ts'e̱ Cristo, nga s'e̱‑la̱ kjoa̱tjòcha, nga tsjeè kítsa̱jnako̱ Nainá koa̱ ndaà si̱ìjchá yijo‑la̱.
\c 3
\s1 Kjoa̱ xi mochjeén ts'e̱ xi̱ta̱ xi síkinda̱ na̱xa̱ndá‑la̱ Nainá
\p 
\v 1 'Én jè, nguì 'én kixi̱‑né: Tsà tjín jngoò xi̱ta̱ xi mejèn‑la̱ xá nga na̱xa̱ndá‑la̱ Nainá si̱ìkinda̱, 'ñó ndaà tjín xá xi mejèn‑la̱.
\v 2 Jè xi̱ta̱ xi si̱ìkinda̱ na̱xa̱ndá‑la̱ Nainá mochjeén‑né nga ndaà s'i̱in mé‑ne nga mì yá xi ch'o ki̱tso̱‑la̱. Jngoò chjo̱ón s'e̱‑la̱; jngoò xi̱ta̱ xi indaà tjín ikon; xi̱ta̱ xi ndaà kosòn‑la̱ yijo‑la̱; xi̱ta̱ xi yaxkón nga ndaà tísíjchá yijo‑la̱; xi ndaà sís'in‑la̱ xi̱ta̱ xi bijchókon; xi̱ta̱ xi ndaà ma‑la̱ okóya;
\v 3 xi mìtsà xi̱ta̱ ch'i̱; xi mìtsà xi̱ta̱ kjaán‑ko̱; xi mìtsà to̱n chijé kjòtsjakeè. Jè xi̱ta̱ xi mochjeén xi ndaà xi̱ta̱, xi mìtsà kjoa̱siì sís'in‑la̱, xi mìtsà to̱n kájno‑la̱.
\v 4 Mochjeén‑né nga ndaà kjo̱tíxoma‑la̱ xi̱ta̱ ni'ya‑la̱; ndaà si̱ìkixi̱ i̱xti‑la̱ mé‑ne nga s'e̱‑la̱ kjo̱xkón i̱xti ti̱koa̱ si̱ìkitasòn koni s'ín tsò xi̱ta̱ jchínga‑la̱.
\v 5 Tsà mìkiì ma‑la̱ otíxoma‑la̱ xi̱ta̱ ni'ya‑la̱, ¿kó s'ín ko̱ma si̱ìkinda̱ xi̱ta̱ na̱xa̱ndá‑la̱ Cristo?
\v 6 Jè xi síkinda̱ xi̱ta̱ na̱xa̱ndá‑la̱ Nainá jè xi mochjeén xi kjòtseé kòkjeiín‑la̱, mé‑ne nga mì 'nga ikon ko̱ma‑ne nga mì kjo̱'in s'e̱‑la̱ koni komàt'in xi̱ta̱ nei̱í.
\v 7 Mochjeén‑né nga ndaà si̱ìjchá yijo‑la̱ mé‑ne nga skoe̱xkón‑ne jñà xi̱ta̱ xi mìkiì mokjeiín‑la̱ i̱t'aà ts'e̱ Cristo nga mì ch'o kíjna, nga mì jè xi̱ta̱ nei̱í si̱ìkijne‑la̱.
\s1 Kjoa̱ xi mochjeén ts'e̱ xi̱ta̱ xi si̱ìchját'aà‑la̱ na̱xa̱ndá‑la̱ Nainá
\p 
\v 8 K'oa̱á ti̱s'ín tjín ts'e̱ xi̱ta̱ xi si̱ìkitasòn xá nga si̱ìchját'aà‑la̱ xi̱ta̱ na̱xa̱ndá‑la̱ Nainá, jñà mochjeén xi̱ta̱ xi yaxkón nga ndaà nchisíjchá yijo‑la̱. Mìkiì ko̱ma si̱ìkjatjìya‑la̱ 'én xi chja̱. Mìkiì ko̱ma xán koa̱hijtako̱. Mìkiì ko̱ma to̱n chijé ko̱tsjakeè.
\v 9 Mochjeén‑né nga ndaà kàtafìt'aà‑la̱ kjoa̱tjí'ma xi jye tsakó Nainá koni s'ín mokjeiín‑ná i̱t'aà ts'e̱ Cristo. Ti̱koa̱ mochjeén‑né nga tsjeè kàtasíkítsa̱jna kjo̱hítsjeèn‑la̱.
\v 10 Jñà xi̱ta̱ xi si̱ìkitasòn xá nga si̱ìchját'aà‑la̱ xi̱ta̱ na̱xa̱ndá‑la̱ Nainá, ítjòn kàtachìt'aà tsà ni̱mé kjoa̱ tjín‑la̱, i̱kjoàn, k'e̱é kàtasíkitasòn.
\v 11 K'oa̱á ti̱s'ín tjín ts'e̱ íchjín; mochjeén‑né nga yaxkón nga ndaà nchisíjchá yijo‑la̱. Mì 'én ndiso ki̱chja̱. Indaà k'oe̱è ikon. Ndaà si̱ìkitasòn yije ni̱ta̱ mé kjoa̱‑ne.
\v 12 Jè xi̱ta̱ xi síkitasòn xá nga síchját'aà‑la̱ xi̱ta̱ na̱xa̱ndá‑la̱ Nainá, mochjeén‑né nga tà jngoò chjo̱ón s'e̱‑la̱. Ndaà kàtatíxoma‑la̱ i̱xti‑la̱ ko̱ xi̱ta̱ ni'ya‑la̱.
\v 13 Jñà xi̱ta̱ xi ndaà si̱ìkitasòn xá koi, ìsa̱ ndaà jcha̱xkón koa̱ ìsa̱ 'ñó ndaà s'e̱ ikon koni s'ín mokjeiín‑la̱ i̱t'aà ts'e̱ Cristo Jesús.
\s1 Kjoa̱'ma‑la̱ Nainá
\p 
\v 14 Mejèn‑na nga kjíkon ni̱to̱n‑lè, ta̱nga tsà koií na̱chrjein‑la̱ ko̱chrjein‑ya‑na, k'oa̱á ma‑ne tìkjiì‑lè xo̱jo̱n jè
\v 15 mé‑ne nga jcha̱‑ne kós'ín ki̱tsa̱jnakoa̱á xi̱ta̱ xinguia̱á ya̱ i̱jiìn na̱xa̱ndá‑la̱ Cristo xi tíjnakon. Jè na̱xa̱ndá‑la̱ Cristo tjíya tsja 'én kixi̱‑la̱ Nainá.
\v 16 Nguì 'én kixi̱‑né nga 'ñó jeya jè kjoa̱'ma‑la̱ Nainá xi jye tsakó koni s'ín yaxkoán Nainá:
\q1 Nainá, xi̱ta̱á komà nga j'iì i̱ i̱sò'nde;
\q1 i̱t'aà ts'e̱ Ini̱ma̱ Tsjeè‑la̱ ki'ya‑la̱ nga tjín‑la̱ kjoa̱kixi̱;
\q1 jñà àkja̱le̱ kijtseè‑né;
\q1 'én‑la̱ kinokjoàyajiìn‑la̱ ngats'iì xi mìtsà xi̱ta̱ judío;
\q1 nga tíjtsa i̱sò'nde kòkjeiín‑la̱ xi̱ta̱ i̱t'aà ts'e̱ Cristo;
\q1 jeya kitjoétjò‑ne ján ngajmiì.
\c 4
\s1 Xi̱ta̱ xi mìtsà 'én kixi̱ ko̱kòya
\p 
\v 1 Ta̱nga jè Ini̱ma̱ Tsjeè‑la̱ Nainá ndaà béno̱jmíya‑ná nga tsò: k'e̱ nga chiba na̱chrjein chija‑ìsa‑la̱ nga kjoi̱í ìjngoò k'a Cristo, s'e̱é xi̱ta̱ xi mì ti̱ kiì ko̱kjeiín‑la̱ i̱t'aà ts'e̱ Cristo. Ya̱á kji̱t'aà‑la̱ ini̱ma̱ ch'o‑la̱ nei̱í xi kona̱cha̱n koa̱ kjo̱hítsjeèn‑la̱ nei̱í si̱ìkitasòn.
\v 2 Jñà kji̱'nchré‑la̱ xi̱ta̱ ndiso xi jò i̱sén tjín‑la̱. Xi̱ta̱ koi, nga jye kjòtájaàjiìn kjo̱hítsjeèn‑la̱, mì ti̱ kinda̱ fìko̱‑ne kjoa̱ch'o xi nchis'ín.
\v 3 Jñà xi̱ta̱ koi mìkiì tsjá'nde nga ki̱xan xi̱ta̱. Ti̱koa̱á tjín tsojmì xi ma chine, mìkiì tsjá'nde nga ko̱ma chji̱ne̱. Ta̱nga tsojmì koi, Nainá tsibíndaà nga tjí'nde‑la̱ nga ko̱ma ski̱ne̱ xi̱ta̱ xi mokjeiín‑la̱ ko̱ xi ndaà tíjiìn‑la̱ kjoa̱kixi̱. K'e̱ nga ski̱ne̱ tsjá‑la̱ kjo̱ndaà Nainá.
\v 4 Ngats'iì tsojmì xi Nainá tsibíndaà, ndaà‑né, mìkiì ko̱ma ki̱náchrjenguiaá. Ko̱ma si̱kjeén yije tsà k'oi̱‑lá kjo̱ndaà Nainá k'e̱ nga si̱kjeén.
\v 5 Jè 'én‑la̱ Nainá si̱ìtsjeè tsojmì k'e̱ nga ki̱nókjoa̱t'aà‑lá.
\s1 Jngoò chi̱'nda‑la̱ Cristo xi ndaà síxá
\p 
\v 6 Ji̱, tsà k'oa̱s'ín ko̱kóya‑la̱ jñà xi̱ta̱ xinguia̱á kjoa̱ koi, 'ñó ndaà si̱xát'aà‑la̱ Cristo Jesús. Ska̱sòn‑ìsa̱ kjo̱hítsjeèn‑lè i̱t'aà ts'e̱ 'én xi mokjeiín‑ná ko̱ kjo̱hítsjeèn xi ndaà tjín xi ndaà tì'mìtji̱ngui‑la̱.
\p 
\v 7 Ta̱nga kì ta̱xki̱ nìs'in‑la̱ 'én jchínga ts'e̱ i̱sò'nde xi nìmé chjí‑la̱ xi tà kjo̱hítsjeèn‑la̱ xi̱ta̱. Tìnè‑la̱ yijo‑lè nga cha̱xkoín Nainá.
\v 8 Tsà kínè‑lá yijo‑ná nga k'oi̱‑lá nga'ñó, sakó chiba‑la̱ kjo̱ndaà, ta̱nga tsà kínè‑lá ini̱ma̱‑ná nga ndaà jcha̱xkoán Nainá, ìsa̱á sakó‑ná kjo̱ndaà xi mochjeén‑ná nga kjit'aà na̱chrjein. Sakó‑ná kjo̱ndaà i̱ i̱t'aà nangui ko̱ nga ko̱ma i̱skan ti̱koa̱á sakó‑ná ján ngajmiì.
\v 9 'Én koi, 'én kixi̱‑né. Mochjeén‑né nga kàtakjeiín yije‑la̱ xi̱ta̱.
\v 10 Koií k'oa̱s'ín bìnè‑lá xá yijo‑ná, ti̱koa̱ nìkjiaán kjo̱'in nga jè titsa̱chiñá‑lá Nainá xi tíjnakon xi ma‑la̱ ochrjekàjiìn kjo̱'in ngats'iì xi̱ta̱. Jñà‑né xi ki̱tjokàjiìn kjo̱'in xi mokjeiín‑la̱ i̱t'aà ts'e̱ Cristo.
\p 
\v 11 K'oa̱á s'ín tatìxoma‑la̱ jñà xi̱ta̱, k'oa̱ tì s'ín ta̱kóya‑la̱ 'én koi.
\v 12 Kì yá xi ochrjekàngui‑lè na̱s'ín nguì sa̱ i̱xti‑ìsi. Ya̱ i̱jiìn‑la̱ xi̱ta̱ xi mokjeiín‑la̱ i̱t'aà ts'e̱ Cristo, ji̱, ndaà t'in ítjoìn mé‑ne skíngui‑ne kós'ín nokjoì, kós'ín 'nì, kós'ín tjòcha 'yi Nainá ko̱ xi̱ta̱, [kós'ín ndaà tíjna ini̱ma̱‑lè], kós'ín mokjeiín‑lè i̱t'aà ts'e̱ Nainá, kós'ín tsjeè tìnìjchí yijo‑lè nga nguixko̱n Nainá.
\v 13 Skanda k'e̱ nga kìjchokon‑lè, k'oa̱á s'ín t'i̱in: tìxke̱jiìn‑la̱ xi̱ta̱ 'én‑la̱ Nainá; tìnè‑la̱ nga 'ñó kàt'eé‑la̱ ikon; ti̱koa̱ ta̱kóya‑la̱.
\v 14 Kì nìjchàajiìn‑jèn nga si̱xát'aà‑la̱ Nainá i̱t'aà ts'e̱ kjo̱tjò xi kitjoé‑lè k'e̱ nga jñà xi̱ta̱ jchínga‑la̱ na̱xa̱ndá‑la̱ Nainá tsohósòn‑lè tsja nga jñà kiìchja̱ ngajo‑la̱ Nainá i̱t'aà tsi̱ji.
\p 
\v 15 I̱t'aà ts'e̱ kjoa̱ koi, kjit'aà na̱chrjein ti̱yakoi̱i, ti̱koa̱ ti̱xákoi̱i mé‑ne nga skoe̱ yije‑ne xi̱ta̱ nga ndaà tímajchíngakoi̱i.
\v 16 Ndaà ti̱kindi̱i yijo‑lè mé xi 'nì. Ti̱koa̱ t'i̱in kinda̱ jè 'én xi okoòya‑la̱ xi̱ta̱. Kixi̱ ti̱jni. Tsà k'oa̱s'ín si̱kitasoìn, ngaji̱, ki̱tjokàjiìn kjo̱'in; ti̱koa̱á ki̱tjokàjiìn kjo̱'in jñà xi̱ta̱ xi 'nchré‑lè.
\c 5
\s1 Kjo̱ndaà xi mochjeén i̱t'aà ts'e̱ xi̱ta̱ xi kj'ei̱í
\p 
\v 1 Jñà xi̱ta̱ xi jye 'ñó jchínga, kì ta̱xki̱ nìkaká‑la̱; k'oa̱á s'ín tèno̱jmíya‑la̱ koni tsà na̱'èn‑lè ma; ti̱koa̱ jñà xi ìsa̱ i̱xti‑ìsa, k'oa̱á s'ín tèno̱jmíya‑la̱ koni tsà 'ndsì ma.
\v 2 Jñà íchjín xi jye 'ñó jchínga, k'oa̱á s'ín tèno̱jmíya‑la̱ koni tsà nea̱‑lè ma. Jñà xi íchjín i̱xti k'oa̱á s'ín tèno̱jmíya‑la̱ koni tsà tichji ma nga nguì tsjeè tíjna kjo̱hítsjeèn‑lè.
\p 
\v 3 Ti̱si̱ko̱ò jñà íchjín xi jye k'en x'i̱n‑la̱ tsà kixi̱ kjoa̱ nga tsjìn xi osìko̱.
\v 4 Tsà tjín íchjín ka'àn xi tjín‑la̱ i̱xti, ko̱ tsà tjín‑la̱ i̱xti 'ndei̱í, i̱xti koi, ítjòn kàtasíkitasòn ya̱ ni'ya‑la̱ kós'ín beèxkón Nainá. Kàtasìko̱ xi̱ta̱ xíkjín, mé‑ne nga tsjá ngajo‑la̱ kjoa̱tjòcha ts'e̱ xi̱ta̱ jchínga‑la̱. Kjoa̱ koi, ndaà tjín. K'oa̱á s'ín sasén‑la̱ Nainá.
\v 5 Jè chjo̱ón ka'àn xi kixi̱ kjoa̱ nga tíjna ta̱jngoò, Nainá 'ñót'aà‑takòn ko̱ na̱chrjein ko̱ ni̱tje̱n bítsi'ba nga chja̱t'aà‑la̱ Nainá.
\v 6 Ta̱nga jè chjo̱ón ka'àn xi kjo̱tsja ts'e̱ i̱sò'nde xi ch'o tjín tsjá‑la̱ yijo‑la̱, i̱t'aà ts'e̱ Nainá tíjnak'en‑né na̱s'ín tíjnakon.
\v 7 K'oa̱á s'ín tatìxoma‑la̱ kjoa̱ koi mé‑ne nga ndaà si̱ìjchá‑ne yijo‑la̱ nga mì yá xi ch'o ki̱tso̱‑la̱.
\v 8 Tsà yá xi mìkiì si̱ìkinda̱ xi̱ta̱ xíkjín nga si̱ìchját'aà‑la̱, mats'ia̱ko̱ ítjòn‑ne xi ya̱ títsa̱jnako̱ ni'ya‑la̱, tsà mì k'oa̱á s'ín ko̱si̱ko̱ xíkjín, mìkiì nchisíkitasòn 'én xi mokjeiín‑la̱ i̱t'aà ts'e̱ Cristo. Ìsa̱á ch'o nchisíkítsa̱jna yijo‑la̱ mì k'oa̱á‑ne koni jñà xi̱ta̱ xi mìkiì mokjeiín‑la̱ 'én‑la̱ Nainá.
\p 
\v 9 Íchjín ka'àn xi si̱t'aà xo̱jo̱n nga ko̱chját'aà‑la̱, tà jñà‑né xi tsato jàn kaàn nó tjín‑la̱ xi kixi̱ tsibìtsa̱jnako̱ x'i̱n‑la̱,
\v 10 jñà xi 'ya‑la̱ nga ndaà kisìjchá yijo‑la̱ ts'e̱ xá xi ndaà tjín: tsà ndaà kisìjchá i̱xti‑la̱, tsà ndaà kisìs'in‑la̱ xi̱ta̱ xi ijchòkon ni'ya‑la̱, tsà tsaníjno ndso̱ko̱ xi̱ta̱‑la̱ Cristo nga ndaà kisìs'in‑la̱, tsà kisìchját'aà‑la̱ xi̱ta̱ xi kjoa̱ títsa̱jiìn. Tsà k'oa̱s'ín kisìkitasòn yije xá xi ndaà tjín, ko̱ma si̱t'aà xo̱jo̱n.
\p 
\v 11 Ta̱nga jñà íchjín ka'àn xi sa̱ i̱xti ìsa̱ mìkiì ko̱ma xo̱jo̱n si̱t'aà. K'e̱ nga x'i̱n kjoa̱ajiìn‑la̱, mìtsà 'iín ko̱ma‑la̱ nga ki̱nchat'aàxìn‑la̱ Cristo nga ki̱xan ìjngoò k'a‑ne.
\v 12 Tsà k'oa̱s'ín s'i̱in, kjo̱'iín s'e̱‑la̱ nga mìkiì nchisíkitasòn koni s'ín kitsjaà tso'ba nga sa̱ ítjòn.
\v 13 Íchjín koi, ti̱koa̱á mangaá‑la̱ nga xki̱ xi ján ni'ya binchimajto. Ma ts'eè‑né. Mìtsà tà ma ts'eè. Ti̱koa̱á 'én ndiso bíxkó. Chja̱jiìn chja̱'a ñánda mì jñà oko̱‑la̱.
\v 14 'A̱n, k'oa̱á s'ín mejèn‑na nga kàtixan ìjngoò k'a‑ne jñà íchjín ka'àn xi sa̱ i̱xti ìsa̱. Kàtas'e‑la̱ i̱xti. Ndaà kàtatíxoma ni'ya‑la̱ mé‑ne nga mì ch'o ki̱chja̱jno‑ná xi kondra̱.
\v 15 Tjín i'nga íchjín ka'àn xi jye tsohófaya‑ne, jè kiìt'aà ìjngoò k'a‑la̱ xi̱ta̱ nei̱í.
\p 
\v 16 Tsà jngoò xi̱ta̱ xi mokjeiín‑la̱ 'én‑la̱ Nainá tsà tjín xíkjín xi chjo̱ón ka'àn, mochjeén‑né nga kàtasíchját'aà‑la̱ xíkjín mé‑ne nga mì jè na̱xa̱ndá‑la̱ Cristo 'ñó ska̱nè‑ne xá. Jè na̱xa̱ndá‑la̱ Cristo ko̱maá ko̱si̱ko̱ xi kixi̱ kjoa̱ nga nguì ndí chjo̱ón ka'àn i̱ma̱.
\p 
\v 17 Jñà xi̱ta̱ jchínga xi ndaà otíxoma ya̱ na̱xa̱ndá‑la̱ Nainá, ok'ín‑la̱ nga ìsa̱ ndaà jcha̱xkón koa̱ ko̱chját'aà‑la̱ xi mochjeén‑la̱, mats'ia̱ko̱‑ne jñà xi chja̱ya koa̱ okóya 'én‑la̱ Nainá.
\v 18 Xo̱jo̱n‑la̱ Nainá, k'oa̱á s'ín tíchja̱ nga tsò: “Jè nchra̱ja̱ xi síxá, kì na̱'ya bì'a tso'ba.” Ti̱koa̱á tjít'aà xi tsò: “Jè xi̱ta̱ xi síxá, mochjeén‑né nga kàtachjí‑la̱.”
\p 
\v 19 Kì kiì nìs'in‑la̱ tsà yá xi óngui xi̱ta̱ jchínga xi otíxoma ts'e̱ na̱xa̱ndá‑la̱ Nainá tsà mì jò jàn ma‑ne xi̱ta̱ xi kijtseè‑ne xko̱n kjoa̱ xi komà.
\p 
\v 20 Ta̱nga jñà xi̱ta̱ jchínga xi ótsji jé‑ìsa, ti̱kaká‑la̱ nga nguixko̱n ngats'iì xi̱ta̱ na̱xa̱ndá‑la̱ Nainá, mé‑ne jñà xi̱ta̱ xi i'nga k'oa̱á s'ín sincháxkón‑ne.
\p 
\v 21 Tìbìnè‑lè nga nguixko̱n Nainá ko̱ Na̱'èn‑ná Jesucristo ko̱ àkja̱le̱‑la̱ xi xó jè jaàjiìn‑ne, ndaà ti̱kitasoìn kjoa̱ koi. Ni̱mé kjoa̱ xi bìndaàjiìn k'e̱ nga kj'eè kiì 'ya‑la̱ tsà kixi̱ kjoa̱. Kì chjaàjiìn xi̱ta̱ xi nìs'in‑la̱; ngásòn ti̱s'in yije‑la̱.
\v 22 Kì yá xi̱ta̱ xi ta̱xki̱ chjaàjiìn nga kjósòn‑la̱ ndsei̱i k'e̱ nga k'oi̱‑la̱ xá i̱jiìn na̱xa̱ndá‑la̱ Nainá. Ítjòn ndaà ti̱kítsjiìn mé‑ne nga mì ji̱ ko̱ko̱t'aà‑lè jé‑la̱ xi̱ta̱ xi kj'ei̱í. Tsjeè ti̱jni.
\p 
\v 23 Nga ch'in tjín kjit'aà‑la̱ i̱ndso̱'boì, kì tà nandá 'yoì, ti̱koa̱á t'i chibi nandá vino.
\p 
\v 24 Tjín i'nga xi̱ta̱ xi ti̱k'e̱ 'ya‑la̱ jé‑la̱ k'e̱ nga ti̱kj'eè si̱ndaàjiìn. Ta̱nga ti̱koa̱á tjín i'nga xi i̱skan 'ya‑la̱.
\v 25 K'oa̱ ti̱s'ín tjín xá xi ndaà tjín, tjín xi ni̱to̱n beè xi̱ta̱. Ti̱koa̱á tjín xá ndaà xi mì ni̱to̱n 'ya‑la̱ ta̱nga mìkiì ko̱ma jngoò k'a si̱jna'ma. I̱skan jcha̱‑la̱.
\c 6
\p 
\v 1 Ngats'iì xi̱ta̱ na̱xa̱ndá‑la̱ Nainá xi chi̱'nda títsa̱jna'ñó, ndaà kàteèxkón nei‑la̱ mé‑ne nga mì yá xi ch'o ki̱chja̱jno‑la̱ Nainá ko̱ 'én xi okoòyaá i̱t'aà ts'e̱ Cristo.
\v 2 Jñà xi̱ta̱ chi̱'nda xi mokjeiín‑la̱ nei‑la̱ i̱t'aà ts'e̱ Cristo, mochjeén‑né nga ngásòn ndaà kàteèxkón nei‑la̱ nga 'ndse̱é joó i̱t'aà ts'e̱ Cristo. Ìsa̱á ndaà kàtasíxá‑la̱ nga ngásòn mokjeiín‑la̱ 'én‑la̱ Nainá ti̱koa̱ tsjakeè xíkjín.
\p Jñà 'én koi, ta̱kóyi ti̱koa̱ ti̱nókjoa̱yi.
\s1 Kjoa̱ xi sakó‑ná k'e̱ nga to̱n matsjachaá
\p 
\v 3 Tsà tjín xi̱ta̱ xi kj'ei̱í tsò 'én xi okóya nga mì tíjngoò ikon koni tsò 'én ndaà‑la̱ Na̱'èn‑ná Jesucristo ti̱koa̱ mìkiì tíjngoò ikon i̱t'aà ts'e̱ kjo̱tíxoma koni s'ín yaxkoán Nainá.
\v 4 Xi̱ta̱ koi, xi̱ta̱ 'nga takòn‑né, ni̱mé machi̱ya‑la̱. 'Ñó tsjakeè nga ótiya‑ne 'én xi nìmé chjí‑la̱. Ya̱á nchrobát'aà‑ne nga maxìtakòn‑chaá xinguia̱á, nga bixkán‑kjoaá, nga nokjoàjno‑lá xinguia̱á 'én xi ch'o tsò, ti̱koa̱ ch'o nìkítsjeèn i̱t'aà ts'e̱ xi̱ta̱ xi kj'ei̱í.
\v 5 Ti̱koa̱á ya̱á nchrobát'aà‑ne nga kjit'aà na̱chrjein nchikjaán‑kjoò jñà xi̱ta̱ xi mì kixi̱ síkjeén kjo̱hítsjeèn‑la̱ ko̱ mì kjoa̱kixi̱ fìt'aà‑la̱. K'oa̱á s'ín síkítsjeèn, tsò‑né: tsà ndaà jcha̱xkoán Nainá, ya̱á sakó‑ná to̱n. Ngaji̱, kì k'oa̱á tjín kjoa̱ xi nìkítsjiìn.
\v 6 Kixi̱í kjoa̱, tseé kjo̱ndaà sakó‑la̱ xi̱ta̱ k'e̱ nga beèxkón Nainá tsà ti̱koa̱ tsja tjín‑la̱ ini̱ma̱‑la̱ mé xi tjín‑la̱.
\v 7 Nga ni̱mé xi kich'á k'e̱ nga kits'iaán i̱ i̱sò'nde. Ti̱koa̱á ni̱mé xi kjikoa̱á k'e̱ nga ki̱yá.
\v 8 Tsà tjín‑ná tsojmì xi chineé koa̱ tjín‑ná nikje xi chíkjá, mochjeén‑né nga tsjaá kíjngoò‑lá takoán.
\v 9 Ta̱nga jñà xi̱ta̱ xi mejèn‑la̱ kjoa̱nchi̱ná, nga mìkiì chíkjoa̱ko̱‑la̱ kjo̱hítsjeèn xi ch'o tjín nga kjìn tsojmì mejèn‑la̱, ya̱á ki̱xo̱ngui ch'a̱n koa̱ ya̱á si̱ngui'ñó. 'Ñó mejèn‑la̱ kjoa̱ xi ni̱mé chjí‑la̱ koa̱ xi ch'o síko̱‑ná, kjoa̱ xi síkits'ón xi̱ta̱ koa̱ ya̱á chi̱jajiìn.
\v 10 K'e̱ nga to̱n matsjachaá, ya̱á mats'ia̱‑ne kjoa̱ ts'e̱ jé ko̱ ngats'iì kjoa̱ xi ch'o tjín. Tjín i'nga xi̱ta̱ xi jye chinchat'aàxìn‑la̱ kjoa̱ xi mokjeiín‑ná i̱t'aà ts'e̱ Cristo jè nga̱tjì‑la̱ nga tse to̱n mejèn‑la̱. K'oa̱á s'ín ma‑ne nga ti̱jñà‑ne tse kjo̱'in tsjá‑la̱ yijo‑la̱.
\s1 Tìnè‑la̱ yijo‑lè kjoa̱ xi mokjeiín‑lè
\p 
\v 11 Ta̱nga ngaji̱ xi xi̱ta̱‑la̱ Nainá 'mì‑lè, ti̱si̱t'aàxìn‑la̱ ngats'iì kjoa̱ koi. Jè t'in tji̱ngui‑la̱ xi kjoa̱kixi̱. Jcha̱xkoín Nainá. Ndaà kàtakjeiín‑lè i̱t'aà ts'e̱ Cristo. Kàtas'e‑lè kjoa̱tjòcha. Kàtas'e‑lè kjoa̱tsetakòn. Indaà kjoa̱ ti̱kíjni ini̱ma̱‑lè.
\v 12 Ndaà ti̱xkàtjì kjoa̱ xi mokjeiín‑ná i̱t'aà ts'e̱ Cristo. Kì nìkíjna‑jèn ndi̱yá kixi̱ ts'e̱ kjoa̱binachon xi mìkiì fehet'aà ni̱ta̱ kjé‑ne. Nga koií xá kiìchja̱‑lè Nainá. Ngaji̱ jyeé k'oa̱s'ín ndaà kits'iì ndso̱boi nga kinìkixi̱yi 'én xi mokjeiín‑lè i̱t'aà ts'e̱ Cristo nga nguixko̱n xi̱ta̱ xi kjìn ma‑ne nga kiì'nchré.
\v 13 I̱'ndei̱ jngoò xá tìbìnè‑lè nga nguixko̱n Nainá xi síkítsa̱jnakon yije ni̱ta̱ mé xi tjín, ti̱koa̱ nguixko̱n Jesucristo xi ndaà kitsjaà tso'ba nga kisìkixi̱ya 'én ndaà‑la̱ k'e̱ nga kiìchja̱ nga nguixko̱n Poncio Pilato.
\v 14 K'oa̱á s'ín tìhotiìxoma‑lè, ndaà ti̱kitasoìn kjo̱tíxoma koi; kì nìkjatjìya‑la̱ mé‑ne nga mì yá xi ko̱chrjengui‑lè skanda k'e̱ nga kjoi̱í ìjngoò k'a Na̱'èn‑ná Jesucristo.
\v 15 K'e̱ nga ki̱jchòya na̱chrjein, Nainá, k'oa̱á s'ín si̱ìkitasòn yije kjoa̱ koi. Mé tà ndaà‑la Nainá nga jè ta̱jngoò tíhotíxoma. Jè tíjna ítjòn‑la̱ jñà xi xi̱ta̱xá ítjòn títsa̱jna ti̱koa̱ tíjna ítjòn‑la̱ jñà xi xi̱ta̱ sko̱‑la̱ títsa̱jna.
\v 16 Ta̱jngoò Nainá xi xó k'oa̱s'ín tíjna‑ne nga mìkiì biyaà. Ya̱á tíjnajiìn kjoa̱hiseèn ñánda mì yá xi ko̱ma ki̱jchò kinchat'aà‑la̱. Ni̱ sa̱á jngoò xi̱ta̱ beèxkon ni̱ mìkiì tjí'nde‑la̱ nga skoe̱xkon. Nainá, kjit'aà na̱chrjein jeya kàtìjna. Kàtayaxkón kjo̱tíxoma‑la̱ ni̱ta̱ kjé‑ne. K'oa̱s'ín kàtama.
\p 
\v 17 Jñà xi̱ta̱ nchi̱ná xi tjín i̱ i̱sò'nde, k'oa̱á s'ín tìnè‑la̱: “Kì bí'nga‑la̱ ikon.” Kì koií ma'ñót'aà ikon kjoa̱nchi̱ná xi tjín‑la̱ nga tà ni̱to̱n fehet'aà. Jè kàtama'ñót'aà ikon Nainá xi tíjnakon nga jè tsjá yije‑ná xi mochjeén‑ná skanda síkatonè‑la̱ mé‑ne nga ko̱ kjo̱tsja si̱kjeén tsojmì xi tsjá‑ná.
\v 18 Koa̱tìn‑la̱, kjo̱ndaà kàtas'ín. Kàtas'e‑la̱ kjoa̱nchi̱ná nguixko̱n Nainá i̱t'aà ts'e̱ kjo̱ndaà xi s'ín. Kì kjoa̱xkon fìkjaá, ko̱ ini̱ma̱‑la̱ kàtatsjá i̱tsé‑la̱ xíkjín mé xi tjín‑la̱.
\v 19 Tsà k'oa̱s'ín si̱ìkitasòn na̱chrjein i̱'ndei̱, s'e̱é‑la̱ kjoa̱nchi̱ná xi mìkiì kjoe̱het'aà k'e̱ nga jye títsa̱jna nguixko̱n Nainá. Ti̱koa̱á tjoé‑la̱ kjo̱ndaà xi nguì ts'e̱ kjoa̱binachon.
\s1 'Én xi fehet'aà‑ne
\p 
\v 20 Ngaji̱ Timoteo, ndaà ti̱kitasoìn 'én ndaà‑la̱ Nainá xi ji̱ kjònga̱tsjei. Kì kiì na'yà‑la̱ 'én ndiso xi ni̱mé chjí‑la̱. Kì kiì nìs'in‑la̱ kjoa̱ xi chitiya‑ná ts'e̱ kjoa̱chji̱ne̱ ndiso.
\v 21 Tjín i'nga xi̱ta̱ xi k'oa̱ tjín kjo̱hítsjeèn fìtji̱ngui‑la̱. K'oa̱á ma‑ne nga chinchat'aàxìn‑la̱ kjoa̱ xi mokjeiín‑ná i̱t'aà ts'e̱ Cristo.
\p Jè kàtìjnako̱‑lè kjo̱ndaà‑la̱ Nainá.
