\p 
\v 9 \w Cuando|strong="H3588"\w* \w Toi|strong="H8583"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Hamat, \w oyó|strong="H8085"\w* \w que|strong="H3588"\w* \w David|strong="H1732"\w* \w venció|strong="H5221"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w ejército|strong="H2426"\w* \w de|strong="H3588"\w* \w Hadad-ezer|strong="H1909"\w*,
