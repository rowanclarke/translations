\v 1 \w Porque|strong="G1063"\w* \w quiero|strong="G2309"\w* \w que|strong="G3588"\w* ustedes sepan \w cuán|strong="G3745"\w* \w grande|strong="G5228"\w* lucha \w tengo|strong="G2192"\w* \w por|strong="G1722"\w* ustedes, \w por|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w están|strong="G2192"\w* \w en|strong="G1722"\w* \w Laodicea|strong="G2993"\w* \w y|strong="G2532"\w* \w por|strong="G1722"\w* \w todos|strong="G3745"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w no|strong="G3756"\w* \w me|strong="G1473"\w* han \w visto|strong="G1492"\w*,  
