\v 17 \w This|strong="H3606"\w* decision \w is|strong="H1768"\w* \w the|strong="H3606"\w* decree \w of|strong="H1768"\w* \w the|strong="H3606"\w* watchers,
\q2 \w the|strong="H3606"\w* verdict declared by \w the|strong="H3606"\w* holy ones,
