\s1 The 30 great warriors
\p 
\v 13 Altogether there \w were|strong="H6430"\w* 30 special warriors \w among|strong="H7218"\w* \w David|strong="H1732"\w*’s soldiers. \w Once|strong="H3381"\w*, \w when|strong="H7105"\w* \w it|strong="H3381"\w* \w was|strong="H1732"\w* almost \w time|strong="H7218"\w* \w to|strong="H3381"\w* \w harvest|strong="H7105"\w* \add the crops\add*, \w three|strong="H7970"\w* \w of|strong="H7218"\w* \w those|strong="H2583"\w* 30 \w men|strong="H7218"\w* \w went|strong="H3381"\w* \w down|strong="H3381"\w* \w to|strong="H3381"\w* \w Adullam|strong="H5725"\w* \w Cave|strong="H4631"\w*, where \w David|strong="H1732"\w* \w was|strong="H1732"\w* \add staying\add*. \w A|strong="H3068"\w* group \w of|strong="H7218"\w* \w men|strong="H7218"\w* \w from|strong="H3381"\w* \w the|strong="H1732"\w* Philistia \w army|strong="H6010"\w* \w had|strong="H1732"\w* set up \w their|strong="H1732"\w* \w tents|strong="H2583"\w* \w in|strong="H2583"\w* \w Rephaim|strong="H7497"\w* \w Valley|strong="H6010"\w* \add near Jerusalem\add*.
\v 14 \w David|strong="H1732"\w* \add and his soldiers\add* \w were|strong="H6430"\w* \w in|strong="H1035"\w* \w the|strong="H1732"\w* cave \add because it was safe there\add*, \w and|strong="H1732"\w* \add another\add* group \w of|strong="H1732"\w* Philistia soldiers \w was|strong="H1732"\w* occupying \w Bethlehem|strong="H1035"\w*.
\v 15 \add One day\add* \w David|strong="H1732"\w* very much wanted \add some water\add* \w to|strong="H1732"\w* \w drink|strong="H8248"\w*, \w and|strong="H1732"\w* said “I \w wish|strong="H4310"\w* \w that|strong="H4325"\w* \w someone|strong="H4310"\w* \w would|strong="H4310"\w* \w bring|strong="H1732"\w* \w me|strong="H8248"\w* some \w water|strong="H4325"\w* \w from|strong="H4325"\w* \w the|strong="H1732"\w* well near \w the|strong="H1732"\w* \w gate|strong="H8179"\w* \w at|strong="H1732"\w* \w Bethlehem|strong="H1035"\w*!”
\v 16 \w So|strong="H3808"\w* \w his|strong="H5375"\w* \w three|strong="H7969"\w* greatest \w warriors|strong="H1368"\w* forced \w their|strong="H3068"\w* way \w through|strong="H1234"\w* \w the|strong="H5375"\w* \w camp|strong="H4264"\w* \w of|strong="H3068"\w* Philistia \w soldiers|strong="H1368"\w* \w and|strong="H3068"\w* \w drew|strong="H7579"\w* some \w water|strong="H4325"\w* \w from|strong="H3068"\w* \w the|strong="H5375"\w* well, \w and|strong="H3068"\w* \w brought|strong="H5375"\w* \w it|strong="H5375"\w* \w to|strong="H3068"\w* \w David|strong="H1732"\w*. \w But|strong="H3808"\w* \w he|strong="H3068"\w* \w would|strong="H3068"\w* \w not|strong="H3808"\w* \w drink|strong="H8354"\w* \w it|strong="H5375"\w*. \w Instead|strong="H3808"\w*, \w he|strong="H3068"\w* \w poured|strong="H5258"\w* \w it|strong="H5375"\w* \w out|strong="H5258"\w* \add on the ground\add* \w as|strong="H3068"\w* \w an|strong="H5375"\w* \w offering|strong="H3068"\w* \w to|strong="H3068"\w* \w Yahweh|strong="H3068"\w*.
\v 17 \w He|strong="H6213"\w* said, “\w Yahweh|strong="H3068"\w*, \w it|strong="H6213"\w* \w would|strong="H3068"\w* \w certainly|strong="H6213"\w* \w not|strong="H3808"\w* \w be|strong="H3808"\w* \w right|strong="H3068"\w* \w for|strong="H6213"\w* \w me|strong="H5315"\w* \w to|strong="H1980"\w* \w drink|strong="H8354"\w* \w this|strong="H2063"\w* water! \w That|strong="H5315"\w* \w would|strong="H3068"\w* \w be|strong="H3808"\w* \w like|strong="H3808"\w* [RHQ] \w drinking|strong="H8354"\w* \w the|strong="H6213"\w* \w blood|strong="H1818"\w* \w of|strong="H3068"\w* \w these|strong="H6213"\w* \w men|strong="H1368"\w* \w who|strong="H3068"\w* \w were|strong="H5315"\w* willing/\w ready|strong="H6213"\w* \w to|strong="H1980"\w* \w die|strong="H1980"\w* \w for|strong="H6213"\w* \w me|strong="H5315"\w*!” \w So|strong="H6213"\w* \w he|strong="H6213"\w* \w refused|strong="H3808"\w* \w to|strong="H1980"\w* \w drink|strong="H8354"\w* \w it|strong="H6213"\w*.
\p \w That|strong="H5315"\w* \w was|strong="H3068"\w* \w one|strong="H3808"\w* \w of|strong="H3068"\w* \w the|strong="H6213"\w* \w things|strong="H7969"\w* \w that|strong="H5315"\w* \w those|strong="H6213"\w* \w three|strong="H7969"\w* \w great|strong="H6213"\w* \w warriors|strong="H1368"\w* \w did|strong="H6213"\w*.
