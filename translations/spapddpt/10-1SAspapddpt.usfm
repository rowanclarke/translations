\v 22 ¡\w Así|strong="H3541"\w* \w haga|strong="H6213"\w* \nd ʼElohim\nd* \w a|strong="H3068"\w* \w los|strong="H3605"\w* enemigos \w de|strong="H5704"\w* \w David|strong="H1732"\w*, \w y|strong="H5704"\w* \w aun|strong="H5704"\w* \w añada|strong="H3254"\w* si \w de|strong="H5704"\w* \w aquí|strong="H3541"\w* \w a|strong="H3068"\w* \w mañana|strong="H1242"\w* \w dejo|strong="H7604"\w* \w de|strong="H5704"\w* \w los|strong="H3605"\w* suyos un solo \w meante|strong="H8366"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w pared|strong="H7023"\w*!
\p 
\v 23 Cuando Abigail \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w se|strong="H5921"\w* apresuró \w a|strong="H3068"\w* bajar \w de|strong="H5921"\w* su \w asno|strong="H2543"\w*, \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* su \w rostro|strong="H6440"\w* \w ante|strong="H6440"\w* \w David|strong="H1732"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* postró \w en|strong="H5921"\w* tierra.
