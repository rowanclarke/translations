\id 2TH
\h 2 Tesalonicenses
\toc1 Ja ua rá̱ yoho ra̱ carta bi 'yo'tra̱ Pablo, ngue bi̱ mɛnnba̱ yø 'yɛ̱c'ɛ̱i̱ Tesalónica.
\toc2 2 Tesalonicenses
\toc3 2 Ts.
\mt1 2 Tesalonicenses
\mt2 Ja ua rá̱ yoho ra̱ carta bi 'yo'tra̱ Pablo, ngue bi̱ mɛnnba̱ yø 'yɛ̱c'ɛ̱i̱ Tesalónica.
\c 1
\p 
\v 1 Nu̱gä drá̱ Pablo, conna̱ Silvano 'nɛ̱hra̱ Timoteo, da̱di zɛnguagähe'ʉ ma̱ zi cu̱hʉ yø 'yɛ̱c'ɛ̱i̱ rá̱ m'mʉp'ʉ ja ra̱ hni̱ni̱ Tesalónica. Gue'a̱hʉ yø ja̱'i̱ Oja̱ ma̱ Papáhʉ, co 'nɛ̱'a̱ ma̱ Hmu̱hʉ Jesucristo.
\v 2 Dí̱ nnegähe ngue guehya di ja̱p'a̱hʉ ya 'nɛ̱ da̱ hyu̱t'a̱ ni̱ mmʉihʉ.
\s1 ---------
\p 
\v 3 Ague ma̱ zi cu̱'a̱hʉ, za̱nt'a̱ da̱di ja ma̱mma̱di̱gähe Oja̱ conná̱ ngue'a̱hʉ. Ní̱ 'yu̱p'ʉ ngue gue'a̱ ga̱ øthe'a̱, porque ni̱ nt'ɛ̱c'ɛ̱i̱hʉ i ja̱, ma̱n'na ni̱ hyu̱xtho. 'Nɛ̱ xquet'a̱ ma̱n'na ma̱n'na ga̱di̱ mma̱hmʉ n'na ngu̱ n'na'a̱hʉ.
\v 4 A nu̱csɛga̱he p'ʉ ha nná̱ mähme, nu̱p'ʉ di̱ mpɛti yø ja̱'i̱ Oja̱, i jaje mpähä ngue dí xihme yø ja̱'i̱ hanja ni̱ nt'ɛ̱c'ɛ̱i̱hʉ. Nu̱'a̱ te ra̱ n'ʉ guí sähʉ ngue sʉ'a̱hʉ yø ja̱'i̱, gä guí sɛthʉ.
\p 
\v 5 Nu̱yá, guí sähʉ ra̱ n'ʉ ngue guí ɛ̱c'ɛ̱i̱hʉ rá̱ hya̱ Oja̱. A nu̱'a̱ ga̱ dʉ ni̱ nt'ɛ̱c'ɛ̱i̱hʉ, gue'a̱ gui̱ nɛ̱qui̱'a̱ ya ngue gä xa̱nho te øt'Oja̱. Gue'a̱ di zʉdi ngue gui thohmʉ p'ʉ di̱ ma̱nda Oja̱'a̱.
\v 6 Pɛ ní̱ 'yu̱p'ʉ di ʉn'Oja̱'ʉ te'o di ʉn'a̱hʉ.
\v 7 A nu̱jʉ ngue dí sähʉ ra̱ n'ʉ, da̱ 'yɛ̱hra̱ pa da̱ zɛp'ʉ'a̱ ra̱ n'ʉ dí sähʉ. Di̱ n'nacjʉ ra̱ ts'äya 'mø ra̱ pa da̱ ɛ̱p'ʉ ra̱ Hmu̱ Jesús. Nu̱na̱ di 'yɛ̱ ma̱hɛ̱ts'i̱, da̱ n'youi yø anxɛ ja yø ts'ɛdi. Nu̱'mø bá̱ ɛ̱hɛ̱, da̱di yoxni̱ tengu̱tho gui yoxni̱ ra̱ sibi.
\v 8 Di 'yɛ̱hɛ̱ da̱ mɛnhna̱ castigo gätho yø ja̱'i̱ hi̱nxa̱ mba̱ Oja̱, 'nɛ̱ hi̱nxa̱ 'yɛ̱c'ɛ̱i̱ ra̱ hoga̱ 'da'yo hya̱ i hma̱ ngue hanja'a̱ ra̱ Hmu̱ Jesucristo.
\v 9 A nu̱ya yø ja̱'i̱ ya, da̱ ma ra̱ castigo, di̱ m'mɛdi para za̱ntho. Da̱ ma ma̱'ueque p'ʉ ja rá̱ hmi̱ rá̱ dä ra̱ Hmu̱ Jesús. Nu̱p'ʉ da̱ 'yu̱di̱ hague ngu̱ ga̱ngu̱ rá̱ ts'ɛdi i ja, ya hi̱ndi̱ njapi di̱ m'mʉp'ʉ ngue da̱ nu̱.
\v 10 Nu̱'a̱ ra̱ pa da̱ ɛ̱p'ʉ ra̱ Hmu̱, gätho yø 'yɛ̱c'ɛ̱i̱ da̱ 'yɛ̱spa̱bi̱ 'nɛ̱ da̱ da̱nne. Xquet'a̱ 'nɛ̱'a̱hʉ gui̱ m'mʉhmʉ p'ʉ ngue gá̱ 'yɛ̱c'ɛ̱i̱hʉ na̱ ra̱ hya̱ dá̱ xi'a̱hʉ.
\p 
\v 11 Ja̱na̱ngue nu̱yá, za̱nt'a̱ dí̱ mmat'Oja̱ gähe conná̱ ngue'a̱hʉ. Dí äpähe Oja̱ ngue nu̱'a̱ ra̱ hya̱ i zon'na̱hʉ ngue gdí̱ n'yohʉ, gue'a̱ gdí̱ n'yohʉ'a̱. Dí äpähe Oja̱ ngue nu̱'a̱ te gä ra̱ nho so ni̱ mmʉi gui 'yøthʉ, di ha̱'a̱hʉ ra̱ ts'ɛdi gui 'yøthʉ. 'Nɛ̱ di ha̱'a̱hʉ ra̱ ts'ɛdi gui 'yøthʉ'a̱ te gä ra̱ nho rá̱ nsäui ni̱ nt'ɛ̱c'ɛ̱i̱hʉ i ja.
\v 12 Nu̱'mø da̱ nu̱ yø ja̱'i̱ ngue guí 'bʉhmʉ xa̱nho, yø ja̱'i̱ da̱ nu̱ ma̱nsu̱ ra̱ Jesucristo. Xquet'a̱ 'nɛ̱'a̱hʉ da̱ hnu̱ ma̱nsu̱'a̱hʉ p'ʉya ngue gui̱ n'yohʉ ra̱ Jesús. Ngu̱na̱ di̱ nja conná̱ nguehrá̱ ma̱te Oja̱ 'nɛ̱ conná̱ nguehrá̱ ma̱te ma̱ Hmu̱hʉ Jesucristo.
\s1 ---------
\c 2
\p 
\v 1 Ague ma̱ zi cu̱'a̱hʉ, da̱ ɛ̱p'ʉ ma̱ Hmu̱hʉ Jesucristo ngue di pɛrca̱hʉ 'dap'ʉ ga̱ m'mʉhmʉ. Dí̱ nne ga̱ xi'a̱hʉ te 'bɛ'a̱ ja ngue di̱ nja.
\v 2 Nu̱'mø to da̱ 'yɛ̱n'a̱hʉ, ya da̱ guehra̱ pa jap'ʉ da̱ zøhra̱ Hmu̱ ya, da̱ 'yɛ̱na̱, 'yo sä da̱di fɛ'ni̱ mmʉihʉ. 'Yo guí ɛ̱c'ɛ̱i̱hʉ te da̱ ma̱, ma̱da̱gue'a̱ da̱ 'yɛ̱na̱ ngue Oja̱ di bɛ̱nnbi̱ te i̱ mma̱, ogue da̱ 'yɛ̱n'a̱hʉ ngue go dá̱ ot'ä ra̱ sʉcua̱ n'youi yø hya̱ da̱ xi'a̱hʉ.
\v 3 Xi̱nda̱ ha̱ngu̱ da̱ si'a̱hʉ, 'yo ga̱di̱ n'u̱ni̱ da̱ thä'a̱hʉ. Porque hante da̱ zønna̱ pa da̱ ɛ̱p'ʉ ra̱ Hmu̱, i jatho ngue rá̱ mʉditho di̱ n'yo yø ja̱'i̱ ngue dyø mmɛjma̱hya̱, da̱ gohi ngue yø nsʉiui Oja̱. Nu̱'mø bi̱ nja na̱ ra̱ hya̱ na̱, ja di̱ nɛ̱qui̱ p'ʉ ra̱ ja̱'i̱ ngue ta̱te ja rá̱ ts'oqui p'ʉya. 'Nɛ̱ guehna̱ ya xpa̱ ts'ännbi̱ ngue da̱ ma ra̱ castigo.
\v 4 Nu̱na̱ guehna̱ da̱ bøni̱ ngue da̱ zʉmba̱bi̱'a̱ te gä tha̱nne yø ja̱'i̱ na̱, da̱ gue Oja̱ da̱ zʉi. Hønsɛ na̱ da̱ ne ngue da̱ ma ntha̱nne na̱. 'Nɛ̱ da̱ mi̱p'ʉ ja rá̱ ni̱ja̱ Oja̱ tengu̱tho 'mø ngue da̱ guehna̱ Oja̱ na̱. Da̱ 'yɛ̱mp'ʉya: “Nu̱gä, guecä Oja̱gä ya”, da̱ 'yɛ̱na̱.
\p 
\v 5 Da̱mi̱ bɛ̱mhmʉ'a̱ ra̱ hya̱ dá̱ xi'a̱hʉ 'mø da̱mbí 'bʉcä p'ʉ guí 'bʉhmʉ. Guí̱ nnu̱ ngue dá̱ xi'a̱hʉ tengu̱ na̱ ra̱ hya̱ na̱.
\v 6 Ya guí pa̱hmʉ te 'bɛ'a̱ sa̱mya ngue hi̱ngui̱ nɛ̱qui̱ nts'ɛdi, hante ngue da̱ zønna̱ pa bá̱ ts'ännbi̱ ngue di̱ nɛ̱qui̱ te'o na̱ ra̱ ts'oc'ɛ̱i̱ na̱.
\v 7 Tobe hi̱ndi̱ nɛ̱qui̱ xa̱ndønho'a̱ te gä rá̱ ts'ɛdi ra̱ nts'o, pɛ nu̱'a̱ ra̱ nts'o, ya i ja. Høntho ngue hi̱ndi̱ u̱nna̱ nt'ɛ̱di̱'a̱ to sa̱mmi̱ ngue di̱ nɛ̱qui̱ xa̱nho te'o ni̱ ja̱'i̱ na̱ dí xi'a̱hʉ.
\v 8 Pɛ nu̱'mø bi zønna̱ pa di t'u̱nna̱ nt'ɛ̱di̱ da̱ 'yu̱hrá̱ ts'ɛdi, ya di̱ nɛ̱qui̱ na̱ ra̱ ts'oc'ɛ̱i̱ dí xi'a̱hʉ p'ʉya. Pɛ nu̱'mø bá̱ ɛ̱p'ʉ ra̱ Hmu̱ Jesús, ya da̱ hnu̱ ngue ma̱thoguitho ja rá̱ ts'ɛdi, porque conná̱ hya̱netho di hyo na̱ ra̱ ts'oc'ɛ̱i̱ na̱.
\p 
\v 9 Nu̱'mø bi̱ nɛ̱qui̱ na̱ ra̱ ts'oc'ɛ̱i̱ na̱, ra̱ zithu̱'a̱ di ha̱tra̱ ts'ɛdi. Da̱ hnu̱ ngue ja rá̱ ts'ɛdi da̱ 'yøtyø hmɛ̱ya hi̱njongui̱ sä da̱ 'yøt'e. Gue'a̱ di̱ nhäte'a̱ p'ʉya.
\v 10 Xa̱nts'o te gätho da̱ 'yøt'e. 'Dama̱ 'dan'yo te gä da̱ 'yøt'e, da̱ hyoni̱ ha di hyätyø ja̱'i̱ ja ngue di̱ m'mɛdi. Nu̱'a̱ di̱ m'mɛdi ngue hi̱mbi ne xta̱ mba̱hna̱ ra̱ hya̱ ma̱jua̱ni̱. 'Nɛ̱ guehna̱ ra̱ hya̱ xtí̱ nya̱nyø te yø ja̱'i̱ na̱.
\v 11 Ja̱na̱ngue Oja̱ di japi ngue da̱ thätya yø ja̱'i̱ ya, da̱ 'yɛ̱c'ɛ̱i̱'a̱ ra̱ hya̱ ngue ra̱ fɛhni̱.
\v 12 Gue'a̱ di̱ ma ra̱ castigo gätho ya yø ja̱'i̱, ngue hi̱mbi̱ 'yɛ̱c'ɛ̱i̱ na̱ ra̱ hya̱ ma̱jua̱ni̱. 'Nɛ̱ hønt'a̱ te yø nts'o ga̱ 'yo nnu̱ ma̱nho.
\s1 ---------
\p 
\v 13 Ague ma̱ zi cu̱'a̱hʉ, nu̱na̱ ma̱ Hmu̱hʉ Jesucristo di̱ ma̱'a̱hʉ. Ja̱na̱ngue nu̱yá, za̱nt'a̱ jatho ngue ga̱ ja ma̱mma̱di̱gähe Oja̱ ngue te bi 'yøt'a̱hʉ. Porque rá̱ mʉditho bi huan'na̱hʉ Oja̱, ya xpá̱ nzänni̱ ngue di̱ nya̱nni̱ tehʉ. Nu̱'mø gmi̱ 'yɛ̱c'ɛ̱i̱hʉ na̱ ra̱ hya̱ ma̱jua̱ni̱, ra̱ Espíritu Santo bi 'yøt'e ngue gá̱ sohʉ rá̱ 'yɛ Oja̱.
\v 14 Dá̱ xi'a̱hʉ ra̱ hoga̱ 'da'yo hya̱, guehna̱ ra̱ hya̱ i zon'na̱hʉ Oja̱ na̱. I̱ nnepe ngue di toca'a̱hʉ na̱ ra̱ nho jap'ʉ ha 'bʉhma̱ Hmu̱hʉ Jesucristo.
\v 15 Ja̱na̱ngue nu̱ya ma̱ zi cu̱'a̱hʉ, di̱ ndʉ xa̱nho ni̱ nt'ɛ̱c'ɛ̱i̱hʉ ya. Ma̱n'nan'yo mi̱ 'yøt'e ngue guí pu̱mbɛ̱ni̱hʉ ya yø hya̱ dá̱ xän'na̱sɛhʉ. Da̱ gue'ʉ yø hya̱ dá̱ orpʉ ja ra̱ carta dá̱ pɛn'na̱hʉ p'ʉ, ma̱n'nan'yo mi̱ 'yøt'e ngue guí pu̱mbɛ̱ni̱hʉ.
\p 
\v 16 Bi̱ ma̱cjʉ Oja̱ ma̱ Papáhʉ, 'nɛ̱ bi 'dacjʉ rá̱ ma̱te ngue bi hoga̱ ma̱ mmʉihʉ para za̱ntho. Xquet'a̱ dí tømhmʉ'a̱ ra̱ nho di 'dacjʉ Oja̱ m'mɛfa. Da̱ ne Oja̱ co 'nɛ̱'a̱ ma̱ Hmu̱hʉ Jesucristo di ja̱p'a̱hʉ.
\v 17 Da̱ ne Oja̱ ngue di ha̱tra̱ ts'ɛdi ni̱ mmʉihʉ 'nɛ̱ gui dʉ'ni̱ n'yomfɛ̱ni̱hʉ ngue nu̱p'ʉ guí ya̱hʉ, ra̱ hya̱ xta̱nho gui̱ ma̱mhmʉ. Nu̱'mø te guí øthʉ, gä da̱ gue'a̱ te xa̱nho gui 'yøthʉ.
\s1 ---------
\c 3
\p 
\v 1 Hønt'a̱ di 'bɛhya ma̱ zi cu̱'a̱hʉ, da̱mi̱ marca̱he Oja̱, n'namhma̱ ngue nu̱p'ʉ dí̱ mma̱ngähe rá̱ hya̱ ma̱ Hmu̱hʉ, xta̱ngu̱ yø ja̱'i̱ da̱ 'yɛ̱c'ɛ̱i̱ tengu̱tho bi̱ njap'ʉ guí 'bʉhmʉ.
\v 2 Xquet'a̱ da̱mi̱ marca̱he Oja̱ n'namhma̱ ngue da̱ ya̱ngähe Oja̱ ngue'a̱ te mbɛ̱nngähe yø ts'oc'ɛ̱i̱. Porque hi̱nga̱ gätho yø ja̱'i̱ da̱ 'yɛ̱c'ɛ̱i̱ ra̱ hya̱ dí̱ mma̱ngähe.
\p 
\v 3 Pɛ nu̱'a̱ ra̱ Hmu̱ hi̱ngui̱ hɛga̱hʉ'a̱. Da̱ 'yøt'e ngue gui hya̱hʉ ra̱ ts'ɛdi 'nɛ̱ da̱ ya̱n'a̱hʉ ngue ra̱ nts'o.
\v 4 Da̱di seguragä ngue di̱ mfäxte ra̱ Hmu̱. Ja̱na̱ngue dí pa̱cä ngue nu̱na̱ te ra̱ hya̱ ga̱ 'bɛp'a̱hʉ, guehna̱ guí̱ nne gui 'yøthʉ na̱, hi̱nda̱ 'yɛ̱hra̱ pa guí fɛsthohʉ na̱ ra̱ hya̱ na̱.
\p 
\v 5 Da̱ ne Oja̱ ngue da̱ di̱nni̱ mmʉihʉ'a̱ te gui̱ ma̱'a̱hʉ Oja̱. 'Nɛ̱ da̱ 'yøt'e ngue gui sɛti hangu̱ ra̱ n'ʉ guí thohmʉ tengu̱tho ra̱ Cristo bi zɛti hangu̱ ra̱ n'ʉ bi thogui.
\s1 ---------
\p 
\v 6 Ague ma̱ zi cu̱'a̱hʉ, ma̱ Hmu̱hʉ Jesucristo di 'dacähe ra̱ ts'ɛdi ga̱ xi'a̱he na̱ ra̱ hya̱ ga̱ mma̱nya. Nu̱'ʉ ma̱ cu̱hʉ hi̱ngui̱ nne di̱ mpɛfi, 'nɛ̱ hi̱ngui̱ ha̱xra̱ hya̱ dá̱ xän'na̱hʉ, oga̱di̱ nsixhʉ'ʉ.
\v 7 Ya guí pa̱hmʉ te gdí 'bʉhmʉ, hi̱n tema̱ nda̱nhyɛ̱i̱ gá̱ nu̱rca̱he.
\v 8 Hi̱njonda̱ äptho te dá̱ sihe. Sinoque dá̱ honi̱ ha da̱ japi te dí homhme. Ra̱ pa ra̱ xu̱i̱ dá̱ mpɛfi ngue di ta̱ha̱ te ga̱ sihe, porque hi̱ndá̱ negähe ngue di toca'a̱hʉ ra̱ gasto ngue te dí sihe.
\v 9 Ma̱da̱gue'a̱ ní̱ 'yu̱p'ʉ xcá̱ ma̱ngähe ngue xquí fäxca̱he, pɛ hi̱nte dá̱ ma̱ngähe. Sinoque dá̱ mpɛhme para ngue ga̱ u̱t'a̱he te ja ngue gdí̱ n'yohʉ.
\v 10 Porque nu̱'mø da̱mbá̱ m'mʉcähe p'ʉ guí 'bʉhmʉ, guehna̱ ra̱ hya̱ dá̱ xi'a̱he na̱, dá̱ ma̱ngähe ngue nu̱ to hi̱ngui̱ nne di̱ mpɛfi, ya hi̱ndi̱ nsi̱hmɛ̱.
\v 11 Dí øcähe n'na ra̱ hya̱ ua, ngue 'bʉ i'da ni̱ amigohʉ hi̱ngui̱ nne di̱ mpɛfi. Nu̱'a̱ te ga̱ 'yo, høndyø ja̱'i̱ di a̱ts'i̱ te ga̱ 'bʉi para ngue da̱ zäp'ʉ di c'a̱.
\v 12 A nu̱ya yø ja̱'i̱ njap'ʉ, guesɛ ra̱ Jesucristo di ha̱cje ra̱ ts'ɛdi ngue ga̱ xifi ngue 'yo ni̱ma̱ntho di orpa̱bi̱ yø ja̱'i̱, njua̱ntho da̱ ma ra̱ 'bɛfi da̱ da̱ha̱ te da̱ zi.
\p 
\v 13 Ague ma̱ zi cu̱'a̱hʉ, 'yo gui säyahʉ, hangu̱ ra̱ pa da̱mi̱ 'yøthʉ ra̱ nho.
\v 14 Nu̱'mø toni̱ ja̱'i̱ da̱ 'yɛ̱na̱ ngue hi̱nda̱ 'yɛ̱c'ɛ̱i̱ na̱ ra̱ hya̱ dá̱ cuatähe ua ja ra̱ carta ja ua, 'yo ga̱di̱ nsixhʉ, n'namhma̱ ngue da̱ mɛsrá̱ sä.
\v 15 Pɛ 'yo guí øt'e ngue ni̱ nsʉiui. Sinoque da̱mi̱ hɛjpa̱hʉ'a̱ te øt'e, porque ni̱ cu̱hʉ.
\s1 ---------
\p 
\v 16 Nu̱na̱ ma̱ Hmu̱hʉ Jesucristo guehna̱ da̱ zä da̱ hyu̱t'a̱ ni̱ mmʉihʉ na̱. Da̱ ne ngue hi̱nda̱ hyɛc'a̱hʉ hangu̱ ra̱ pa. Nu̱'mø tema̱ hya̱ guí thohmʉ, da̱ hyoni̱ ha di japi ngue da̱ hyu̱t'a̱ ni̱ mmʉihʉ, hønt'a̱ bi zä ma̱hya̱ guí thohmʉ.
\p 
\v 17 Nu̱gui̱ drá̱ Pablo conma̱ 'yɛsɛ nna̱ cuatä na̱ ra̱ letra ja ua ngue nná̱ zɛngua'a̱hʉ. Nu̱'mø da̱di firmagä ma̱ carta 'mø bi gua'a̱ nt'ot'i, guehna̱ ra̱ hya̱ ja ua da̱di cuati:
\v 18 Nu̱na̱ ma̱ Hmu̱hʉ Jesucristo di ja̱pi̱ gätho'a̱hʉ. Da̱ ngu̱t'a̱tho.
