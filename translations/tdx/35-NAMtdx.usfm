\id NAM
\h Nakòme
\toc1 Nakòme
\toc2 Nakòme
\toc3 Nak
\mt1 Nakòme
\c 1
\p 
\v 1 Ty talily i Ninevè\f + \fr 1:1 \ft Ninevè: soa vintañe; mete\f*. Ty boken’ aroñaro’ i Nakòme\f + \fr 1:1 \ft Nakome: mpañohò; veka’e hisoloho\f* nte-Elkose\f + \fr 1:1 \ft Elkose: ty figahiñan’Añahare\f*.
\q1 
\v 2 Mpamarahy t’i Andrianañahare,
\q1 Mpamale fate t’\nd Iehovà\nd*;
\q1 Mpañondroke miforoforo t’\nd Iehovà\nd*;
\q1 Mpañava-kabò amo rafelahi’eo t’\nd Iehovà\nd*,
\q1 ie mañaja haviñerañe amo malaiñe azeo.
\q1 
\v 3 Malaon-kaviñerañe t’\nd Iehovà\nd*,
\q1 ra’elahy ty haozara’e,
\q1 fe tsy hapò’e tsy ho lafaeñe
\q1 o aman-kakeoo;
\q1 \nd Iehovà\nd*: amo tangololahio
\q1 o lala’eo, naho ami’ty tio-bey ao;
\q1 o rahoñeo ro debom-pandia’e.
\q1 
\v 4 Endaha’e i riakey le ampimaihe’e,
\q1 ampikarakankaiñe’e o sakao;
\q1 rinotsake t’i Basane naho i Karmele;
\q1 miheatse ty voñen-katae’ i Libanone.
\q1 
\v 5 Miezeñezeñe aolo’e eo o vohitseo,
\q1 mitranake iaby o haboañeo,
\q1 forototo ty tane toy ami’ty fiatrefa’e,
\q1 ty voatse toy naho ze mpimoneñe ama’e ao.
\q1 
\v 6 Ia ty mahafijohañe añatrefa’
\q1 o fifombo’eo?
\q1 Ia ty mahatambeloñe amy
\q1 fiforoforoan-kaviñera’ey?
\q1 Ailiñe hoe afo ty filevelevea’e,
\q1 avokovoko’e ambane iaby ze vato.
\q1 
\v 7 Soa t’\nd Iehovà\nd*, fipalirañe
\q1 añ’andron-kankàñe;
\q1 arofoana’e iaby o miato ama’eo.
\v 8 F’ie an-tsorotombahañe mivovò,
\q1 ty hamongora’e i toe’ey,
\q1 vaho ho roahe’e mb’ an-kamoromoroñañe ao o rafelahi’eo.
\v 9 Ino ze o fikililia’ areo am’ \nd Iehovà\nd* zao?
\q1 Fa harotsa’e,
\q1 tsy hiongake fañindroe’e ty hekoheko.
\v 10 Fa manahake ty fivandiram-patike
\q1 naho ty hamamoa’ o jikeo,
\q1 ty hampangotomomoheñe iereo hoe ahe-maike.
\v 11 Boak’ ama’o ty niavia’
\q1 i nikitro-draha am’ \nd Iehovà\nd*y,
\q1 ie mañeretse hatsivokarañe.
\v 12 Hoe t’\nd Iehovà\nd*:
\q1 ndra t’ie lifo-kaozarañe,
\q1 naho mitozantozañe,
\q1 mbe hampikorovoheñe,
\q1 vaho hihelañe añe;
\q1 fa ndra te nanilofeko irehe,
\q1 tsy ho silofeko ka.
\v 13 Hapozako ama’o henaneo ty joka’e,
\q1 vaho ho rafadrafateko o tali-randra’oo.
\v 14 Fa nandily ty ama’o t’\nd Iehovà\nd*,
\q1 te tsy ho tongisañe ka ty tahina’o;
\q1 le haitoako amy akiban-drahare’oy
\q1 ty sare sokin-katae
\q1 naho ty sare natranake;
\q1 f’ie hanoako kibory,
\q1 amy t’ie tsy manjofake.
\c 2
\q1 
\v 1 Hehek’ an-kaboañe ey
\q1 o fandia’ i mpinday talily soaio,
\q1 i mampiboele fifampilongoañey!
\q1 O ry Iehodà, anò o sabadidake miavakeo, henefo o nifantà’oo;
\q1 amy te tsy hiranga ama’o ka
\q1 ty Beliale, fa naitoañe.
\v 2 Fa nitroatse añ’atrefan-dahara’o eo
\q1 ty mpandrotsake,
\q1 tano i kijoliy, jilovo i lalañey,
\q1 mitokia an-kaozarañe, avorio o hafatrara’oo.
\v 3 Vaòe’ \nd Iehovà\nd* ty enge’ Iakobe
\q1 naho ty volonahe’ Israele;
\q1 fa nampikoake iareo o mampikoakeo,
\q1 vaho jinoi’ iareo o singam-bahe’eo.
\v 4 Ho mena mañabarà ty fikalan-defo’
\q1 o fanalolahio,
\q1 misikiñe mena iaby o lahin-defo’eo,
\q1 afo amam-bý miloeloe o sarete’eo
\q1 amy andro fihentseña’ey,
\q1 vaho miriñariña iaby o lefon-ambilazoo;
\v 5 Mitrakotrako amo lalañeo o sareteo,
\q1 mifaniotsiotse an-diolio eo;
\q1 manahake ty fañilo ty vinta’ iareo,
\q1 ie mihelatse mb’etia mb’eroa.
\v 6 Tiahi’e i mpiaolo rey;
\q1 mamingañe iereo te miloka;
\q1 malisa t’ie handrombake i kijoliy,
\q1 fa nihentseñeñe ty fikala’e,
\v 7 Misokake o lalam-pikalañañe i sakaio
\q1 vaho rinava’e i anjombay.
\v 8 Fa nivoloseñe i mpanjaka ampelay,
\q1 fa nasese añe,
\q1 miñeoñeoñe hoe feon-deho-fona
\q1 o anak’ ampata’eo,
\q1 ie mamofok’ arañañe;
\v 9 Manahake o antara haehaeo
\q1 t’i Ninevè, ie mihelañe añe;
\q1 mijohaña, mitsangana!
\q1 fe leo raike tsy mitoli-boho.
\v 10 Kopaho o volafotio,
\q1 haofo o volamenao
\q1 amy te tsy ho revo ty an-driha ao,
\q1 fanake tsifotofoto ty ao.
\v 11 Kapaike re, mangoakoake naho mavo,
\q1 mitranake ty arofo,
\q1 mifampigaiñe o ongotseo,
\q1 mikoritoke iaby ze fisafoa,
\q1 mikò mainte iaby o vintañeo.
\v 12 Aia i lakaton-dionay,
\q1 ty famahanañe o liona tora’eo,
\q1 i fipiapià’ i lionay naho i liona-vavey
\q1 naho i ana-dionaiy,
\q1 ie tsy amam-pañembañe?
\v 13 Nahaeneñe o ana’eo ty rinimi’ i lionay,
\q1 nahatseke o vali’eo o vinono’eo,
\q1 natsafe’e tsindroke o lava’eo,
\q1 le nofotse riniatse an-dakato’eo.
\v 14 Miatreatre azo iraho, hoe t’\nd Iehovà\nd*’ i Màroy
\q1 Haonjoko an-katòeñe o sarete’eo,
\q1 habotse’ i fibaray o liona tora’oo;
\q1 le haitoako ami’ty tane toy o tsindro’oo,
\q1 vaho tsy ho janjiñeñe ka
\q1 ty fiarañanaña’ o ira’oo.
\c 3
\q1 
\v 1 Hankàñe amy rova mpampiori-dioy,
\q1 lifotse vande naho vara kinopake,
\q1 le lia’e tsy modo o tsindroheñeo.
\v 2 Inay ty karavantsy!
\q1 Inao ty fikatrakatrà’ o laròn-tsareteo;
\q1 heheke ty fitsapio­tsapio’ o soavalao,
\q1 naho o sarete mitrakotrakoo.
\v 3 Mañoridañe o mpiningitse soavalao,
\q1 mimilomilotse i fibaray;
\q1 mipelapelatse i lefoñey;
\q1 zinamañe i lahialeñey,
\q1 tsifotofoto o votrin-doloo,
\q1 o fañova mifitakeo;
\q1 ie mitsikapy amo fateo;
\v 4 ty ami’ty hamaro’ o hakarapiloa’
\q1 i tsimirira kenakenakeio,
\q1 i hekohekom-pamorekey,
\q1 i mandetake fifeheañe amo
\q1 hakalalijaha’eoy,
\q1 naho hasavereñañe amo famoreha’eo.
\v 5 Inao! miatreatre azo iraho,
\q1 hoe t’\nd Iehovà\nd*’ i Màroy,
\q1 le hatsingako an-doha’o eo o siki’oo,
\q1 naho haboako amo kilakila’ondatio ty fihalo’o
\q1 vaho amo fifeheañeo ty heña’o.
\v 6 Hafetsako ama’o ty raha mampangorý,
\q1 hanivà’e azo, ie hanoeko fisambàñe.
\v 7 Ie amy zao, hene handripak’ ama’o
\q1 ze maharendrek’ azo, hanao ty hoe:
\q1 Fa mangoakoake ty Ninevè;
\q1 ia’ ty handala aze?
\q1 aia ty hahatreavako mpañohò ho azo.
\v 8 Soa te amy No-amone v’iheo,
\q1 Ie nitoetse añivon-tsaka eoy,
\q1 naho niarikatohen-drano,
\q1 i riakey ty nañaro aze,
\q1 naho i ranoy ty ni-kijoli’e?
\v 9 I Kose naho i Mitsraime ty nanolo-kaozarañ’ ama’e tsy nete ritse;
\q1 nimpañolots’aze t’i Pote naho i Lobý\f + \fr 3:9 \ft Lobý: taliñiereñe\f*.
\v 10 F’ie nasese mb’eo,
\q1 nisese mb’am-pandrohizañe añe,
\q1 fonga naretsak’ an-doha’ o lalan-drovao ey o anak’ ajaja’eo;
\q1 nanoe’ iereo tsato-piso o roandria’eo,
\q1 vaho rinohy an-tsilisily iaby
\q1 o ana-dona’eo.
\v 11 Toe ho jike ka irehe, vaho hiàmpitse;
\q1 ie hipay fitsolohañe ty amy rafelahiy.
\v 12 Manahake o rotseo
\q1 ze hene golobo’o mifahetse,
\q1 ie ezeñezeñeñe ro mihintsañe
\q1 mb’am-paliem-pikama ao.
\v 13 Oniño te hambañe aman’ampela
\q1 ondaty añivo’oo;
\q1 midañadaña ho a o rafelahio
\q1 o lalambein-tane’oo;
\q1 hampangotomomohe’ ty afo o sikada’eo.
\v 14 Mitariha rano ho amy fiarikoboñañey, haozaro o kijolio;
\q1 mionjona amo lietseo,
\q1 lialiao i pakotsey,
\q1 vontitiro i mòlim-birìkey;
\v 15 Hamorototo azo ao ty afo,
\q1 hañito azo i fibaray,
\q1 habotse’e manahake i valalay;
\q1 mifamorohota hoe kijeja,
\q1 mivorovoroa hoe sy.
\v 16 Nampamasiañe’o mandikoatse
\q1 o vasian-dikerañeo
\q1 o mpibalibalik’ ama’oo;
\q1 miofoke i kijejay vaho mitiliñe añe.
\v 17 Hoe valala o mpigari’oo,
\q1 mifamorohotse hoe kijeja
\q1 o mpifehe’oo, ie mitobe an-kijoly eo
\q1 naho manintsiñe ty andro,
\q1 fe mipitsik’ añe te mafana-voho,
\q1 vaho tsy fohiñe ty tane nombà’e.
\v 18 Mirotse o mpiara’oo ry mpanjaka’
\q1 i Asore, mitofa o roandria’oo;
\q1 mivarakaik’ am-bohitse ey ondati’oo,
\q1 vaho tsy eo ty hanontoña’o.
\v 19 Tsy hay melañeñe ty bae’o,
\q1 mahaferenay o fere’oo;
\q1 fonga hitehateha-pitàñe ty ama’o
\q1 o mahajanjiñe i talili’oio;
\q1 fa ia ty tsy nifetsaha’ o fampisoaña’o
\q1 nitoloñeñe nainai’eo? 
