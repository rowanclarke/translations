\id JHN Leachin Oct 00
\h San Juan
\toc1 Juúh⁴ dxú⁴ chiáh² Jesús hi³ gá⁴xɨɨ́³ Juan
\toc2 San Juan
\toc3 Jn.
\mt1 Juúh⁴ dxú⁴ chiáh² Jesús hi³ gá⁴xɨɨ́³ Juan
\c 1
\s1 Fáh⁴liu⁴ chiáh² Dios nɨ³ gá⁴lɨ́y⁴ ja̱y³ dsa³
\p 
\v 1 Mɨ³xa³ ba² Fáh⁴liu⁴ chiáh² Dios nɨ³ liáh³ca̱á̱h³ gá⁴niaá⁴ jmɨɨyh⁴²güii³. Mɨ³chie̱é̱yh¹ ba² Dios nɨ³ Fáh⁴liu⁴ nɨ³, ba² hí̱³ba² Dios nɨ³ Fáh⁴liu⁴ nɨ³.
\v 2 Liáh³ gá⁴niaá⁴ jmɨɨyh⁴²güii³ la³, mɨ²ja̱³ mɨ³jey¹ chie̱é̱yh¹ Dios Fáh⁴liu⁴ nɨ³.
\v 3 Hi³ja̱³ dxɨ́⁴lieey³² hi³nɨy³² ja̱³ gá⁴jooy³ gá⁴jmeé³ Dios ja̱³ jɨɨ⁴ hi³la³ hi³nɨ³. Há⁴hé³ xa³ cáh³ti³² hi³ gá⁴jmeé³ Dios ja̱³ hi³ há⁴hé³ nieéy¹.
\v 4 Hi³nɨy³² nɨ³ xe̱y³ ca̱³ñiih³², baáy⁴ hi³ fáh⁴ hi³ na³ji̱í̱yh⁴ nɨ³, hi³ja̱³ na³lɨ́y⁴ liáh³xɨ³ ya⁴²jmɨɨ́⁴ chiáh² diáh⁴ dsa³ jmɨɨyh⁴²güii³.
\v 5 Hi²xiáh³ veyh³ ga³dxiih³² ya⁴²jmɨɨ́⁴ nɨ³ xi² ñu³ha̱a̱h³, hi³ja̱³ há⁴hé³ hí⁴tiaá⁴ xi² ñu³ha̱a̱h³ nɨ³ hí⁴ií⁴ ya⁴²jmɨɨ́⁴ nɨ³.
\p 
\v 6 Ca̱á̱h³ tiaah² ja̱³ gá⁴sa̱y³ ja̱y³ dsa³ hi³ gá⁴xɨ́y⁴ Dios, hi³ xɨ̱ɨ̱y³ Juan.
\v 7 Na³lɨ́y⁴ dsa³ñi³² chiáh² ya⁴²jmɨɨ́⁴ ja̱³ chiaah¹ liu⁴ jɨy³ cáh³ti³² duh³ hu̱² dsá⁴taáy³ liáh⁴jɨy³ diáh⁴ dsa³ ja̱³ chiáh² Dios dxɨ́⁴lieey³² Juan ja̱³.
\v 8 Há⁴hí̱³ Juan ja̱³ na³lɨ́y⁴ ya⁴²jmɨɨ́⁴ ja̱³, na³lɨ́y⁴ ja̱y³ dsa³ñi³² chiáh² ya⁴²jmɨɨ́⁴ ja̱³ ba².
\v 9 Chiaah¹ mɨ³dsa³güéy³ jmɨɨyh⁴²güii³ ja̱³ jmɨ́yh³ ya⁴²jmɨɨ́⁴ hi³ ga³dxiih³² chiáh² diáh⁴ dsa³ jmɨɨyh⁴²güii³.
\p 
\v 10 Mɨ³jey¹ ba² jmɨɨyh⁴²güii³ la³ hi³ na³lɨ́y⁴ ya⁴²jmɨɨ́⁴ ja̱³ joó⁴ há⁴hé³ dɨ³cui̱i̱y⁴ diáh⁴ dsa³ ja̱³, gu³xɨ³ ba² dxɨ́⁴lieey³² ja̱³ gá⁴jmeé³ Dios ja̱³ jmɨɨyh⁴²güii³.
\v 11 Güéy⁴ ja̱³ba² jmɨɨyh⁴²güii³ chiáh², hi³ bi²ñi³ diáh⁴ dsa³ oóyh² joó⁴ há⁴hé³ cá⁴dah²jmeéh⁴ he̱é̱yh³.
\v 12 Joó⁴ liáh⁴jɨy³ diáh⁴ hi³ cá⁴dah²jmeé³ he̱é̱yh³ chiáh² baáy⁴ gá⁴taáy³ diáh⁴ chiáh², diáh⁴ hi³hí̱³ gá⁴cuoó⁴ diáh⁴ jú¹hiíh⁴ hi³ hí⁴lí³ diáh⁴ ja̱á̱² Dios.
\v 13 Há⁴ja̱³ hi³ hí⁴sa̱y³ diáh⁴ liáh³xɨ³ dsa³ jmɨɨyh⁴²güii³ nɨ³ hi³ja̱³ na³lɨ́y⁴ diáh⁴ ja̱á̱² Dios. Ba² há⁴ja̱³ hi³ bií⁴ niaá⁴ ja̱y³ dsaá⁴ hi³ hu̱² hí⁴sa̱y³ ja̱y³ ja̱á̱² ca³jaa¹ chiáh² Dios. Haá², hí⁴lí³ diáh⁴ ja̱á̱² Fii³²a² chiaah¹ liáh³ja̱³ gá⁴féh³ ñaá² ba².
\p 
\v 14 Hi³ja̱³ hí̱³ba² hi³ na³lɨ́y⁴ Fáh⁴liu⁴ chiáh² Dios ja̱³ gá⁴lɨ́y⁴ dsa³ jmɨɨyh⁴²güii³, gá⁴guá³ jee⁴² chiaa⁴²ah¹ la³. Baáy⁴ gá⁴joo⁴²ah¹ hi³ booy¹ dɨ́h¹ gaáy³ chiaah¹ na³lɨ́y⁴ ja̱á̱² ñaá² Ñúh³a² Dios ba². Fáh⁴yeey¹ dɨ́h¹ dxú⁴ dsɨ́², baáy⁴ jmɨ́yh³ xiaa³dsaay³² cáh³ti³².
\v 15 Juan ja̱³ na³lɨ́y⁴ dsa³ñi³² chiáh², liáh³la³ gá⁴féh³:
\p ―Hi³ley³² ja̱³ ga³hó⁴á⁴ liáh³ gá⁴foóh²á⁴ niaá⁴ah³ liáh³la³: “Hi³ hí⁴güéy³ dsa³cɨ̱ɨ̱y³ gɨh¹ liáh³xɨ³ jniá³ nɨ³, hi³nɨy³² ba² nɨ³ ná⁴ŋɨy¹ gɨh¹ liáh³xɨ³ jniá³, chiaah¹ mɨ³xe̱y³ ba² liáh³ca̱á̱h³ ja̱a̱h¹ gá⁴sa̱⁴²á⁴ jniá³.”
\p 
\v 16 Hi³ fáh⁴ hi³ bií⁴ xaa³² Dios nɨ³, hi³ja̱³ liáh⁴jɨ³²a² ba² ma³tɨ̱́³a² hi³ bií⁴ dxú⁴ hi³ xa³ chiáh² nɨ³, baáy⁴ há⁴ja̱³ ca̱a̱³ nɨ³ hi³ ma³cuoó⁴ jnia² nɨ³.
\v 17 Gá⁴tɨ̱́³ah¹ jniaah¹ ley chiáh² Dios ja̱³ dxɨ́⁴lieey³² Moisés. Joó⁴ dxɨ́⁴lieey³² Jesucristo ja̱³ gá⁴heé⁴ jnia² Dios nɨ³ liáh³nɨɨh¹ dɨ́h¹ nieéy² jnia², baáy⁴ gá⁴heé⁴ jnia² jmáyh² hi³ xiaa³dsaa³².
\v 18 Gu³xɨ³ hí̱³ há⁴hé³ jlɨ́h³ ma³joóy² Dios nɨ³. Joó⁴ Ja̱á̱² hi³ ja̱y³ nɨ³, hi³ jey¹ tiá¹ chie̱é̱yh¹ jmii³ nɨ³, ma³héy² jnia² liáh³xɨ³ na³lɨ́y⁴ hi³ja̱³ ma³lɨ³cui̱i̱⁴²a² ja̱³nɨ́⁴.
\s1 Liáh³la³ gá⁴féh³ Juan Bautista ca³jaa¹ chiáh²
\r (Mt. 3:11-12; Mr. 1:7-8; Lc. 3:15-17)
\p 
\v 19 Ca̱a̱³ jmɨɨ́¹ ja̱³ cá⁴dah²xɨɨ́⁴ diáh⁴ israelitas hi³ nieeyh⁴² Jerusalén ja̱³, cá⁴dah²xɨ́y⁴ diáh⁴ jmii³dsa³ chie̱é̱yh¹ diáh⁴ levitas, duh³ cá⁴dah²ŋɨɨ́h⁴ diáh⁴ juúh⁴ Juan hi³ ga³xeey³ jmɨɨ³ dsa³ ja̱³ hi³ he² ja̱³ jmɨ́yh³ na³lɨ́y⁴.
\v 20 Hi³ja̱³ gá⁴jmeé³ juúh⁴ xiaa³dsaa³² cáh³ti³² ba², liáh³la³ gá⁴féh³ Juan ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Há⁴hí̱³ Cristo nɨ³ jniá³.
\p 
\v 21 Hi³ja̱³ liáh³la³ cá⁴dah²sɨɨ́h⁴ ca̱á̱h³:
\p ―¿He² ba² na³lɨ́⁴u³ xa³ja̱³? ¿Xɨ² niu³ nɨ³ profeta Elías?
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ Juan ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Haá², há⁴hí̱³ Elías nɨ³ jniá³.
\p Mɨ²ja̱³ cá⁴dah²ŋɨɨ́h⁴ ca̱á̱h³ juúh⁴:
\p ―Hi³ja̱³ ¿xɨ² niu³ nɨ³ profeta hi³ ná⁴lɨ¹ cua̱a̱y¹ná² hí⁴güéy³ nɨ³?
\p Mɨ²ja̱³ gá⁴hí̱¹ Juan ja̱³:
\p ―Haá².
\p 
\v 22 Mɨ²ja̱³ liáh³la³ cá⁴dah²sɨɨ́h⁴ ca̱á̱h³:
\p ―Hi³ja̱³ ¿he² ba² na³lɨ́⁴u³ xa³ja̱³? Xɨɨh² jniaah¹, chiaah¹ ga³jmee⁴ dsa³ca̱a̱⁴²ah¹ juúh⁴ chiáh² diáh⁴ hi³ ma³dah²xɨ́y⁴ jniaah¹ nɨ³. Xɨɨh² jniaah¹ he² ba² na³lɨ́⁴u³ niu³.
\p 
\v 23 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Juan ja̱³:
\p ―Jniá³ na³lɨ́⁴á⁴ ja̱y³ hi³ jla³te³² hiíy⁴ vó⁴ xi² cueh³chiu̱u̱³ ba², liáh³la³ fayh⁴: “Niá¹ah³ ca̱a̱³ fi¹ dsaá² chiáh² Ñúh³a² nɨ³” ―liáh³xɨ³ gá⁴féh³ profeta Isaías mɨ³xa³ lɨ́⁴.
\p 
\v 24 Diáh⁴ dsa³ hi³ xɨ̱ɨ̱y³ fariseos ja̱³ cá⁴dah²xɨɨ́⁴, duh³ hí⁴dsá⁴liúy¹ diáh⁴ Juan ja̱³.
\v 25 Hi³ja̱³ cá⁴dah²ŋɨɨ́h⁴ ca̱á̱h³ juúh⁴ Juan ja̱³:
\p ―Xɨ³ nɨ³ há⁴hí̱³ niu³ nɨ³ Cristo, ñé⁴ Elías, ñé⁴ profeta hi³ ga³he³²ah¹ nɨ³, hi³ja̱³ ¿he² ba² chiaah¹ hi³ ga³xaa⁴²u³ jmɨɨ³ dsa³ nɨ³ xa³ja̱³?
\p 
\v 26 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Juan ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Jmɨɨ³ ba² ga³xaa⁴²á² jniá² diáh⁴ dsa³ nɨ³. Joó⁴ ja̱³ba² jee⁴² chia̱á̱²ah³ nɨ³ caayh³² ja̱y³ hi³ há⁴hé³ cui̱i̱⁴ah³.
\v 27 Hi³nɨy³² nɨ³ hí⁴güéy³ dsa³cɨ̱ɨ̱y³ liáh³xɨ³ jniá³, joó⁴ ná⁴ŋɨy¹ gɨh¹ liáh³xɨ³ jniá³. Ñé⁴ gu³xɨ³ hi³ hi²sɨɨyh¹ sɨ̱ɨ̱yh² laa³ chiáh² há⁴hé³ hí⁴tiá³ dsɨy⁴, chiaah¹ há⁴hé³ na³jmɨɨ́h³á⁴ jniá³ ―liáh³ja̱³ ba² gá⁴féh³ Juan ja̱³.
\p 
\v 28 Liáh³ja̱³ gá⁴lɨ́⁴ vó⁴ hi³ xɨ̱ɨ̱y³ Betábara, hi³ niaá² ca³jaa¹ xi² yéy⁴ ñíh² liáh³xɨ³ ji̱h²jmɨɨ³ Jordán ja̱³. Nɨɨ́⁴ ja̱³ gá⁴xaa³ jmɨɨ³ Juan ja̱³ gá⁴xeey³ diáh⁴ dsa³ ja̱³.
\s1 Mɨ¹ja̱á̱² dsɨɨ³jaa³ chié̱y² Dios
\p 
\v 29 Dxaáh² jmɨɨ́¹ liáh³ja̱³ gá⁴joó² Juan ja̱³ gá⁴joóy² Jesús hi³ mɨ³dsa³hɨɨ́y⁴ xi² hiíy⁴ ja̱³, hi³ja̱³ liáh³la³ gá⁴féh³ Juan ja̱³ gá⁴sɨɨ́h⁴ diáh⁴ dsa³:
\p ―Joo⁴²ah³ ruh³. Hi³nɨy³² nɨ³ Mɨ¹ja̱á̱² dsɨɨ³jaa³ chié̱y² Dios hi³ hí⁴bé² dsaa² chiáh² diáh⁴ dsa³ jmɨɨyh⁴²güii³ nɨ³. \fig Juan 1:29|src="CN011660B.TIF" size="span" ref="San Juan 1:29"\fig*
\v 30 Hi³nɨy³² ja̱³ ga³hó⁴á⁴ liáh³ gá⁴foóh²á⁴ niaá⁴ah³ liáh³la³: “Hi³ hí⁴güéy³ dsa³cɨ̱ɨ̱y³ gɨh¹ liáh³xɨ³ jniá³ nɨ³, hi³nɨy³² ba² nɨ³ ná⁴ŋɨy¹ gɨh¹ liáh³xɨ³ jniá³, chiaah¹ mɨ³xe̱y³ ba² liáh³ca̱á̱h³ ja̱a̱h¹ hí⁴sa̱⁴²á⁴ jniá³.”
\v 31 Ba² ñé⁴ jniá³ há⁴hé³ maay⁴ hi̱² hí̱³, joó⁴ hi³ja̱³ nɨ³ güé⁴á⁴ jniá³ hi³ hi²xaa⁴²á² jmɨɨ³ diáh⁴ dsa³ nɨ³ duh³ liáh⁴jɨy³ diáh⁴ dsa³ Israel nɨ³ hí⁴cui̱i̱⁴ diáh⁴.
\p 
\v 32 Ba² liáh³la³ gá⁴féh³ Juan ja̱³:
\p ―Gá⁴joó²á⁴ Espíritu Santo chié̱y² Dios nɨ³ gá⁴xiaá² yuuh¹ güii³ na³lɨ́y⁴ liáh³xɨ³ ja̱y³ juu³. Gá⁴xiaá² ca̱a̱³ dsaá² xi² hiíy⁴ ja̱³, ja̱³ba² gá⁴guá³ ñiíh² chiáh².
\v 33 Há⁴hé³ mɨ³cui̱i̱⁴²á⁴ jniá³ mɨ²ja̱³, joó⁴ hi³ gá⁴xɨ́y⁴ jniá³ hi³ hi²xaa⁴²á² jmɨɨ³ diáh⁴ dsa³ nɨ³, liáh³la³ gá⁴sɨɨ́h⁴ jniá³: “Liu³u²xɨ³ mɨ² ma³joo⁴²u³ Espíritu Santo chia̱á̱²á⁴ nɨ³, hi³ ya³xiaá³ baáy⁴ hí⁴güe³ ñiíh² chiáh² ja̱y³ dsaá⁴, mɨ²ja̱³ lii⁴ hi³ hi³nɨy³² nɨ³ hí⁴xeey³ diáh⁴ dsa³ nɨ³ Espíritu Santo.”
\v 34 Baáy⁴ ma³joó²á⁴ ja̱³nɨ́⁴, hi³ja̱³ jniá³ na³lɨ́⁴á⁴ dsa³ñi³² hi³ hi³nɨy³² nɨ³ na³lɨ́y⁴ Ja̱á̱² Dios.
\s1 Liáh³la³ cá⁴lɨ́⁴liaá² gá⁴sa̱y³ diáh⁴ xɨh³chie̱y³²
\p 
\v 35 Dxaáh² jmɨɨ́¹ liáh³ja̱³, mɨ³hiíy⁴ ca̱á̱h³ nɨɨ́⁴ Juan hi³ ga³xeey³ jmɨɨ³ dsa³ ja̱³ chie̱é̱yh¹ aáy⁴ diáh⁴ xɨh³chie̱y³².
\v 36 Mɨ²ja̱³ gá⁴ŋɨ́y³ nɨɨ́⁴ Jesús ja̱³. Hi³ja̱³ liáh³ gá⁴joó² Juan ja̱³ gá⁴joóy², mɨ²ja̱³ liáh³la³ féh³:
\p ―Joo⁴²ah³ ruh³, hi³nɨy³² nɨ³ Mɨ¹ja̱á̱² dsɨɨ³jaa³ chié̱y² Dios nɨ³.
\p 
\v 37 Liáh³ cá⁴dah²nuú³ liú⁴u³ aáy⁴ diáh⁴ xɨh³chie̱y³² Juan ja̱³ hi³ ja̱³, mɨ²ja̱³ gá⁴dxí̱⁴ diáh⁴ chie̱é̱yh¹ Jesús ja̱³.
\v 38 Mɨ²ja̱³ gá⁴ji̱í̱² ñi² Jesús ja̱³ xiáh³ rúh⁴cah². Liáh³ gá⁴joóy² diáh⁴ hi³ ta³nieéy¹ rúh⁴cah² ja̱³ mɨ²ja̱³ liáh³la³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―¿He² nɨ³ naáh³ah³ nɨ³?
\p Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ cá⁴dah²sɨɨ́h⁴:
\p ―Dsa³he⁴, ¿xiah² nɨ³ je¹u³?
\p 
\v 39 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Má⁴dxia⁴²a² duh³ hí⁴cui̱i̱³ah³.
\p Mɨ²ja̱³ gá⁴dxí̱⁴ diáh⁴ cá⁴dxá⁴joó¹ xi² jey¹ ja̱³. Nɨɨ́⁴ gá⁴cueeyh⁴ diáh⁴ gá⁴cú⁴laá³ lɨ́⁴, chiaah¹ mɨ³dsa³hɨɨ́² chiú̱³ ca̱³laá³ mɨ²ja̱³.
\p 
\v 40 Andrés xɨ̱ɨ̱y³ ja̱y³ diáh⁴ hi³ aáy⁴ hi³ gá⁴dxí̱⁴ chie̱é̱yh¹ Jesús ja̱³ liáh³ cá⁴dah²nuú³ hi³ gá⁴féh³ Juan ja̱³. Andrés ja̱³ na³lɨ́y⁴ du³ñuúh² Simón.
\v 41 Hi³ja̱³ ŋáyh² ji̱³nɨɨ́⁴ Andrés ja̱³ cá⁴dxá⁴nieeyh³ Simón ja̱á̱¹ ja̱³. Liáh³ gá⁴ji̱i̱h⁴ ja̱³ mɨ²ja̱³ liáh³la³ gá⁴sɨɨ́h⁴:
\p ―Ma³ji̱i̱h⁴²ah¹ Mesías chia̱a̱⁴²a² nɨ³ ―Mesías ja̱³ niaá⁴ hí⁴féh³ Cristo.
\p 
\v 42 Ja̱³ba² ya²jaa⁴ Andrés ja̱³ ya²jay⁴ Simón xi² jey¹ Jesús ja̱³. Hi³ja̱³ liáh³ gá⁴joó² Jesús gá⁴joóy² Simón ja̱³ mɨ²ja̱³ liáh³la³ gá⁴sɨɨ́h⁴:
\p ―Niu³ nɨ³ xɨ̱ɨ̱³u³ Simón, ja̱á̱² Jonás, joó⁴ jniá³ hi²bi³chiá̱¹á² niu³ Cefas ―Cefas ja̱³ niaá⁴ hí⁴féh³ Pedro.
\s1 Gá⁴té⁴ Jesús ja̱³ gá⁴teé⁴ Felipe chie̱é̱yh¹ Natanael
\p 
\v 43 Dxaáh² jmɨɨ́¹ liáh³ja̱³ gá⁴lɨ́⁴ dsɨ́² Jesús ja̱³ dsaa³² vó⁴ Galilea, mɨ²ja̱³ gá⁴ji̱i̱h⁴ Felipe hi³ja̱³ liáh³la³ gá⁴sɨɨ́h⁴ Felipe ja̱³:
\p ―Ña³ chia̱á̱h¹u³ jniá³.
\p 
\v 44 Dsa³ fɨɨ³ Betsaida ja̱³ Felipe, ja̱³ba² fɨɨ³ chiáh² Andrés chie̱é̱yh¹ Pedro ja̱³.
\v 45 Mɨ²ja̱³ ya²niaah³ Felipe ja̱³ ya²nieeyh³ ja̱y³ hi³ xɨ̱ɨ̱y³ Natanael. Liáh³ gá⁴ji̱i̱h⁴ ja̱³ mɨ²ja̱³ liáh³la³ gá⁴sɨɨ́h⁴:
\p ―Ma³ji̱i̱h⁴²ah¹ dsa³ hi³ gá⁴héy² Moisés ja̱³ ñi² xi³ hi³ tiaah² ley nɨ³, hí̱³ba² hi³ cá⁴dah²héy² diáh⁴ profetas nɨ³ mɨ² dsa³jéy⁴ lɨ́⁴. Ma³ji̱i̱h⁴²ah¹ Jesús, ja̱á̱² José dsa³ fɨɨ³ Nazaret nɨ³.
\p 
\v 46 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Natanael ja̱³:
\p ―¿Xɨ² foóh¹ hí⁴jooy³ hí⁴sa̱y³ ja̱y³ dsa³ hi³ ná⁴ŋɨy¹ fɨɨ³ Nazaret nɨ³?
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ Felipe ja̱³:
\p ―Ña³ má⁴dxia⁴²a² má⁴joo⁴²a² duh³ hí⁴cui̱i̱⁴u³.
\p 
\v 47 Liáh³ gá⁴joó² Jesús ja̱³ hi³ mɨ³dsa³hɨɨ́y⁴ yeey⁴ Natanael ja̱³, mɨ²ja̱³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ diáh⁴ hi³ na³ta̱a̱y⁴ chie̱é̱yh¹ ja̱³:
\p ―Mɨ³je³ la³ ja̱y³ hi³ he̱é̱yh³ ba² na³lɨ́y⁴ israelita, hi³ há⁴hé³ ga³juu³² cáh³ti³².
\p 
\v 48 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Natanael ja̱³ gá⁴sɨɨ́h⁴:
\p ―¿Jmiih⁴² ja̱³ hi³ cui̱i̱⁴u³ jniá³ nɨ³?
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Ma³joó²á⁴ ba² niu³ liáh³ca̱á̱h³ ja̱a̱h¹ hí⁴dsá⁴jey³ niu³ Felipe nɨ³, liáh³ hií⁴u³ ñuúh⁴ ma³ higo nɨ³.
\p 
\v 49 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Natanael ja̱³ gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―Dsa³he⁴, niu³ nɨ³ Ja̱á̱² Dios. Niu³ nɨ³ Rey chia̱a̱⁴²a² jnia² dsa³ Israel nɨ³.
\p 
\v 50 Mɨ²ja̱³ liáh³la³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Ca³gua³taá³u³ chieéy⁴ ca³liuh² hi³ ma³foóh²á⁴ niu³ hi³ ma³joó²á⁴ ba² niu³ hií⁴u³ ñuúh⁴ ma³ higo nɨ³. Ja̱a̱h¹ ba² hi²joóy³ hi³ hí⁴dsaáy² gɨh¹ háy² ca̱á̱h³liaáh³.
\p 
\v 51 Baáy⁴ liáh³la³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³:
\p ―Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³: Ja̱³nɨ́⁴ gɨh¹ hi²joó³ah³ hi³ hí⁴niá³ yuuh¹ güii³, baáy⁴ hi²joo⁴ah³ diáh⁴ ángeles chié̱y² Dios nɨ³ hi³ dsa³saayh⁴ baáy⁴ ya³xiaá³ xi² jey¹ Ja̱á̱² Dsa³ nɨ³.
\c 2
\s1 Gá⁴ji̱í̱³ guaa³ dsa³, fɨɨ³ Caná
\p 
\v 1 Hi³dxá³ nɨ³ jmɨɨ́¹ dsa³cɨ̱ɨ̱y³ liáh³ja̱³, mɨ²ja̱³ gá⁴ji̱í̱³ guaa³ ja̱y³ dsa³ fɨɨ³ Caná hi³ na³hii⁴ vó⁴ Galilea. Ba² caayh³² nɨɨ́⁴ xaá¹ Jesús ja̱³.
\v 2 Ba² cá⁴dah²jéy⁴ Jesús ja̱³ jmɨ́¹feh⁴ ja̱³ chie̱é̱yh¹ jniaah¹.
\v 3 Ca̱³ji̱i̱³ ba² liáh³ja̱³ gá⁴dsá⁴ vino, jmɨɨh¹ mɨ¹jóh¹ hi³ dah²hɨ̱h³² diáh⁴ dsa³ ja̱³. Mɨ²ja̱³ liáh³la³ gá⁴féh³ xaá¹ Jesús ja̱³ gá⁴sɨɨ́h⁴ Jesús:
\p ―Há⁴hé³ máh⁴ xa³ vino chiáh² diáh⁴ dsa³ la³.
\p 
\v 4 Joó⁴ liáh³la³ ba² gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ xaá¹ ja̱³:
\p ―Mɨ́³, ¿he²chiaah¹ xiáh³ hi³ jniá³ nɨ³ ga³fooyh³² hi³nɨ³? Há⁴hé³ ma³dxa³héy³ hora chieéy⁴ jniá³.
\p 
\v 5 Mɨ²ja̱³ liáh³la³ gá⁴féh³ xaá¹ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴ hi³ dah²dxaah³² vino ja̱³:
\p ―Hi³jmee³ah³ jɨɨ⁴ lɨ́⁴ hi³ hí⁴féh³ ja̱a̱y⁴ nɨ³.
\p 
\v 6 Caa¹ ja̱³ niaá² jñuú³ mɨ¹ya³ na¹cu̱ú̱¹ hi³ ga³jmeeh⁴²ah¹ ta² jniaah¹ israelitas mɨ² ca³bi³xɨ² ca³bi³ŋɨɨ́¹ah¹ voo³²ah¹ liáh³xɨ³ ná⁴lɨ¹ costumbres chiaa⁴²ah¹. Ca̱³liáh³ noventa hu̱² ca̱a̱³ ñá⁴laá³ litros jmɨɨ³ ga³ta̱a̱⁴ liáh³ca̱a̱³ diáh⁴ mɨ¹ya³ ja̱³.
\v 7 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴ hi³ ná⁴tayh¹ guaa³ dah²dxaah³² vino ja̱³:
\p ―Bi³chia̱h⁴ah³ jmɨɨ³ diáh⁴ mɨ¹ya³ la³.
\p Mɨ²ja̱³ cá⁴dah²tiáh³ jmɨɨ³ gá⁴ca̱yh⁴ cáh³ti³².
\v 8 Liáh³ ma³dah²tiáh³ jmɨɨ³ ja̱³, mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴ ca̱á̱h³:
\p ―Ja̱³nɨ́⁴ yáh¹, tiáh¹ah³ ca³liuh² duh³ gua³ca̱a̱⁴²ah³ cua²ya³dsaa³ hiíh⁴ dsa³ hi³ ná⁴tayh¹ guaa³ jmɨ́¹feh⁴ la³.
\p Hi³ja̱³ cá⁴dah²jmeé³ liáh³xɨ³ gá⁴féh³ Jesús ja̱³.
\v 9 Mɨ²ja̱³ cá⁴yá⁴dsaa³ hiíh⁴ vino ja̱³ dsa³ hi³ ná⁴tayh¹ guaa³ jmɨ́¹feh⁴ ja̱³, jmɨɨ³ ja̱³ ba² ja̱³ ma³lɨ⁴ vino. Ñé⁴ há⁴hé³ ñi³² dsa³ ja̱³ xɨ³ xiáh³ ja̱³ ma³ja³² vino ja̱³, ti̱¹ diáh⁴ hi³ dah²dxaah³² ja̱³ ba² ja̱³ dɨ³ñi³², chiaah¹ diáh⁴ hi³hí̱³ ja̱³ cá⁴dah²tiáh³ jmɨɨ³ he̱é̱yh³ diáh⁴ ya³ ja̱³. Hi³ja̱³ mɨ²ja̱³ gá⁴té⁴ dsa³ hi³ ná⁴tayh¹ guaa³ jmɨ́¹feh⁴ ja̱³ gá⁴teé⁴ dsaá⁴ hi³ dsa³ji̱í̱³ guaa³ ja̱³,
\v 10 duh³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴:
\p ―Liáh⁴jɨy³ ba² diáh⁴ dsa³ nɨ³ ca³dah²cuo⁴ dsa³jéy⁴ vino hi³ dxú⁴ gɨh¹, duh³ liu³u²xɨ³ mɨ² há⁴hé³ máh⁴ chi³liíh⁴ diáh⁴, mɨ²ja̱³ ba² ca³dah²cuo⁴ vino hi³ sáy⁴ gɨh¹ nɨ³. Joó⁴ na³ji̱i̱⁴ ba² jmeey³ niu³, hi³ mɨ³dsa³hɨɨ́⁴ gɨh¹ ñi² la³ ba² mɨ³cuoy³ vino hi³ dxú⁴ gɨh¹.
\p 
\v 11 Hi³la³ ja̱³, hi³dxá³ ca̱a̱³ fáh⁴lí³ hi³ gá⁴jmeé³ Jesús ja̱³, fɨɨ³ Caná hi³ na³hii⁴ vó⁴ Galilea. Gá⁴jmeé³ liáh³ja̱³ yáh¹ duh³ hí⁴dsaá⁴ dsɨ́² diáh⁴ dsa³ ja̱³ hi³ bií⁴ gaáy³. Ba² gá⁴taá³ah¹ jniaah¹ chiáh².
\p 
\v 12 Dsa³cɨ̱ɨ̱y³ liáh³ja̱³ ŋaá² Jesús ja̱³ fɨɨ³ Capernaúm, na³cu̱yh⁴ chie̱é̱yh¹ xaá¹, diáh⁴ ja̱á̱¹ baáy⁴ ji̱í̱⁴ jniaah¹ diáh⁴ xɨh³chie̱y³² ja̱³, nɨɨ́⁴ gá⁴yaa²ah¹ ca̱a̱³tú̱⁴ jmɨɨ́¹.
\s1 Cá⁴bí⁴ŋɨɨ́³ Jesús ja̱³ dxaa² guah³ gaáy³
\r (Mt. 21:12-13; Mr. 11:15-18; Lc. 19:45-46)
\p 
\v 13 Mɨ³ya³chie̱y¹ jmɨ́¹feh⁴ chiaa⁴²ah¹ jniaah¹ israelitas ja̱³ hi³ ga³cuh³²ah¹ mɨ¹ja̱á̱² dsɨɨ³jaa³, hi³ja̱³ ŋaá² Jesús ja̱³ Jerusalén.
\v 14 Liáh³ gá⁴dxaá² Jerusalén xi² jey¹ guah³ gaáy³ ja̱³, mɨ²ja̱³ gá⁴joóy² diáh⁴ hi³ dah²nɨɨy⁴ cue²yah³, dah²nɨɨy⁴ dsɨɨ³jaa³, baáy⁴ ta̱á̱²dsɨy⁴² dah²nɨɨy⁴ juu³. Ba² nieeyh⁴² nɨɨ́⁴ diáh⁴ hi³ dah²fi̱³² cuu² chiáh² diáh⁴ dsa³ ja̱³.
\v 15 Liáh³ gá⁴joó² Jesús ja̱³ hi³ dah²jmee⁴ liáh³ja̱³, mɨ²ja̱³ cá⁴bí⁴cú̱yh² ca³liuh² sɨ̱ɨ̱yh² láh¹laa³ hi³ ja̱³ chie̱é̱yh¹ gá⁴jmí² diáh⁴, gá⁴hóy⁴ diáh⁴ cáh³ti³², chie̱é̱yh¹ diáh⁴ cue²yah³ baáy⁴ dsɨɨ³jaa³ chié̱y² diáh⁴ ja̱³. Gá⁴ta̱á̱⁴ dxaah¹vó⁴ cuu² chiáh² diáh⁴ dsa³ hi³ dah²fi̱³² cuu² ja̱³ baáy⁴ gá⁴cɨ́yh² diáh⁴ mesas chiáh² diáh⁴.
\v 16 Mɨ²ja̱³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ diáh⁴ hi³ dah²nɨɨy⁴ juu³ ja̱³:
\p ―¡Voó¹ah³ tɨɨ́² diáh⁴ hi³la³! ¡Há⁴ hi³jmee³ah³ liáh³xɨ³ mah² ñu² Ñuyh⁴ nɨ³!
\p 
\v 17 Mɨ²ja̱³ cá⁴lɨ́⁴liíh⁴ah¹ jniaah¹ diáh⁴ xɨh³chie̱y³² ja̱³ liáh³xɨ³ ná⁴lɨ¹ na³xɨɨ² xi³ chiáh² Dios. Chiaah¹ liáh³la³ na³xɨɨ²: “Jmɨ́yh³ hí⁴jú̱³á⁴ lɨ́⁴ dɨ́h¹ ta⁴hɨy⁴ ñuú³ chiáh² ñúy¹ nɨ³.”
\p 
\v 18 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas hi³ na³ta̱a̱y⁴ ñi² chiaa⁴²ah¹ ja̱³, cá⁴dah²sɨɨ́h⁴ Jesús ja̱³:
\p ―¿Xɨ² xa³ hi³ ca̱a̱³ hi²jmeey³ duh³ lii⁴ hi³ haay³ ba² jú¹hiíh⁴ liáh³xɨ³ jmeey³ nɨ³?
\p 
\v 19 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Yaa⁴²ah³ guah³ la³, baáy⁴ duh³ hi³dxá³ nɨ³ jmɨɨ́¹ hi²jmeeh¹á² ca̱á̱h³.
\p 
\v 20 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³ cá⁴dah²sɨɨ́h⁴ ca̱á̱h³:
\p ―Tú̱⁴laá³ dsɨ³² jñuú³ ji̱i̱³ bih³ ja̱a̱h¹ ba² gá⁴jooy³ cá⁴dah²jmeéh² guah³ la³. ¿Xɨ² niu³ gɨh³ nɨ³ hí⁴jooy³ hi²jmeéyh³ nɨ³ jmɨɨ́¹ ba² nɨɨh¹?
\p 
\v 21 Joó⁴ ñaá² ba² ja̱³ ga³hey³² Jesús ja̱³ hi³ liu⁴ chiáh² guah³ ja̱³.
\v 22 Hi³ja̱³ liáh³ca̱á̱h³ cá⁴lɨ́⁴ji̱i̱h⁴ ca̱á̱h³ Jesús ja̱³, mɨ²ja̱³ cá⁴lɨ́⁴liíh⁴ dsɨ³²ah¹ liáh³xɨ³ gá⁴féh³ ja̱³. Hi³ja̱³ mɨ²ja̱³ ba² gá⁴taá³ah¹ gɨh¹ dxú⁴ liáh³xɨ³ na³xɨɨ² fah² Dios ja̱³, baáy⁴ gá⁴taá³ah¹ gɨh¹ dxú⁴ fáh⁴liu⁴ chiáh² Jesús ja̱³.
\s1 Cui̱i̱⁴ ba² jnia² liáh⁴jɨ³²a² Jesús nɨ³
\p 
\v 23 Liáh³ jey¹ Jesús ja̱³ Jerusalén, liáh³ dsa³lí³ jmɨ́¹feh⁴ hi³ ga³cuh³²ah¹ mɨ¹ja̱á̱² dsɨɨ³jaa³ ja̱³, mɨ²ja̱³ hi²xiáh³ fɨɨ́y⁴ diáh⁴ hi³ gá⁴taáy³ chiáh² Jesús ja̱³, chiaah¹ dah²joo³² hi³ xa³ jmee⁴ dɨ́h¹ ca̱a̱³ fáh⁴lí³.
\v 24 Joó⁴ há⁴hé³ jmɨ́yh³ jmeéh⁴ diáh⁴ he̱é̱yh³, chiaah¹ hi²xiáh³ dxú⁴ cui̱i̱⁴ diáh⁴ dsa³ jmɨɨyh⁴²güii³.
\v 25 Há⁴hé³ niaáh² hi³ xe̱y³ hí⁴sɨɨ́h⁴ Jesús ja̱³ liáh³xɨ³ na³lɨ́y⁴ liáh³ja̱y³ liáh³ja̱y³ diáh⁴ dsa³ jmɨɨyh⁴²güii³. Chiaah¹ ñi³² ba² ñaá² Jesús ja̱³ liáh³xɨ³ ná⁴lɨ¹ fáh⁴ji̱í̱h⁴ chiáh² diáh⁴ dsa³.
\c 3
\s1 Ya²liú³ Nicodemo chie̱é̱yh¹ Jesús
\p 
\v 1 Xe̱y³ ja̱y³ dsa³ hi³ xɨ̱ɨ̱y³ Nicodemo, na³lɨ́y⁴ fariseo baáy⁴ na³lɨ́y⁴ ja̱y³ dsa³ gaáy³ jee⁴² chiáh² diáh⁴ israelitas.
\v 2 Ca̱á̱h³ tiaah² ja̱³ ñií¹ Nicodemo ya²ñi³ Jesús ja̱³ ca̱a̱³ mɨ² xiáh³liaá⁴. Liáh³ gá⁴dxaá² ja̱³ mɨ²ja̱³ liáh³la³ gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―Dsa³he⁴, nia⁴²ah¹ ba² hi³ Dios nɨ³ ma³xɨ́y⁴ niu³ duh³ hi²hooy¹ jniaah¹. Chiaah¹ gu³xɨ³ hí̱³ dsa³ há⁴hé³ hí⁴jooy³ hí⁴jmeé⁴ diáh⁴ fáh⁴lí³ hi³ ga³jmeey³ nɨ³, xɨ³ nɨ³ há⁴hé³ chie̱é̱yh¹ Dios.
\p 
\v 3 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ Nicodemo ja̱³:
\p ―Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi²fooh¹á² niu³: Há⁴hé³ hí⁴jooy³ hí⁴lí³ cua̱a̱y¹ná² chiáh² Dios ja̱y³ dsa³ hi³ há⁴hé³ hí⁴sa̱y³ ca̱á̱h³.
\p 
\v 4 Mɨ²ja̱³ gá⁴ŋɨɨ́³ juúh⁴ Nicodemo ja̱³, liáh³la³ gá⁴féh³:
\p ―Joó⁴, ¿jmiih⁴² ja̱³ hí⁴jooy³ hi³ hí⁴sa̱y³ ca̱á̱h³ ja̱y³ dsa³ mɨ³gaáy³? ¿Xɨ² foóh¹ hí⁴jooy³ dsá⁴hí³ ca̱á̱h³ ñuúh⁴ chiáh² xaá¹ duh³ hí⁴sa̱y³ ca̱á̱h³?
\p 
\v 5 Mɨ²ja̱³ liáh³la³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi²fooh¹á² niu³: Liu³u²xɨ³ ja̱y³ dsa³ hi³ há⁴hé³ hí⁴sa̱y³ chie̱é̱yh¹ jmɨɨ³, baáy⁴ chie̱é̱yh¹ Espíritu chié̱y² Dios, hi³hí̱³ há⁴hé³ hí⁴jooy³ hí⁴hiiy⁴ chiáh² Dios.
\v 6 Dsa³ ca̱a̱³ cua̱a̱y¹ná² ba² na³lɨ́y⁴ diáh⁴ hi³ ga³sa̱y³ jmɨɨyh⁴²güii³. Joó⁴ diáh⁴ hi³ ga³sa̱y³ chiáh² Espíritu chié̱y² Dios nɨ³, na³lɨ́y⁴ espíritu ba².
\v 7 Há⁴ hi³jmeey³ dsaay³² háy² hi³ ga³fooh³²á⁴ niu³ hi³ liáh⁴jɨy³ ba² diáh⁴ dsa³ ga³jmee⁴ hí⁴sa̱y³ ca̱á̱h³.
\v 8 Liáh³xɨ³ dxɨ́³ xu̱ú̱³, ga³hɨɨ³ xiah² ga³lɨ́³ dsɨ́² ba². Ga³nuuy³ hi³ ga³hi̱i̱h² ga³ra̱a̱h⁴ joó⁴ há⁴hé³ maáy³ xiah² ja̱³ je³ baáy⁴ xɨ³ xiáh³ ja̱³ dsaa³². Ja̱³ba² liáh³ja̱³ ná⁴lɨ¹ chiáh² diáh⁴ hi³ ga³sa̱y³ ca̱á̱h³ chiáh² Espíritu chié̱y² Dios nɨ³.
\p 
\v 9 Mɨ²ja̱³ gá⁴ŋɨɨ́³ ca̱á̱h³ juúh⁴ Nicodemo ja̱³, liáh³la³ gá⁴sɨɨ́h⁴:
\p ―¿Jmiih⁴² ja̱³ dɨ́h¹ hí⁴jooy³ liáh³ja̱³?
\p 
\v 10 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―¿Jmiih⁴² ja̱³ hi³ há⁴hé³ maáy³ hi³nɨ³, niu³ na³lɨ́⁴u³ dsa³he⁴ gaáy³ chié̱y² diáh⁴ dsa³ Israel nɨ³?
\v 11 Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niu³ la³: Jmáyh² diáh⁴ hi³ nia⁴²ah¹ ba² nɨ³ jniaah¹ ga³liu⁴²ah¹ nɨ³, baáy⁴ na³lɨ́⁴ah¹ dsa³ñi³² chiáh² hi³ ma³joo⁴²ah¹. Joó⁴ há⁴hé³ ca³gua³taá³ah³ niaá⁴ah³ hi³ ga³féh³ah¹ jniaah¹ nɨ³.
\v 12 Liu³u²xɨ³ há⁴hé³ ca³gua³taá³ah³ mɨ² ga³liu⁴²á² niaá⁴ah³ chiáh² hi³ xa³ jmɨɨyh⁴²güii³ la³, hi³ja̱³ jmiih⁴² ja̱³ hí⁴dsá⁴taá³ah³ liu³u²xɨ³ hi²liu⁴²á² niaá⁴ah³ chiáh² hi³ xa³ yuuh¹ güii³ nɨ³.
\p 
\v 13 ’Gu³xɨ³ hí̱³ há⁴hé³ ma³saayh⁴ yuuh¹ güii³, ja̱y³ hi³ yá⁴xiaá² nɨ³ ba² nɨ³ cui̱i̱³ yuuh¹ güii³ nɨ³, hí̱³ba² Ja̱á̱² Dsa³ hi³ na³hiiy⁴ yuuh¹ güii³ nɨ³.
\v 14 Joó⁴ ja̱³ba² liáh³xɨ³ gá⁴jmeé³ Moisés gá⁴xeéy² ñií² ja̱y³ iíh¹ na¹ñí¹ vó⁴ xi² cueh³chiu̱u̱³, ja̱³ba² liáh³ja̱³ ga³jmee⁴ hí⁴dah²xeéy² ñií² Ja̱á̱² Dsa³ nɨ³,
\v 15 duh³ja̱³ xɨ³ xe̱y³ hí⁴dsá⁴taáy³ chiáh², hi³hí̱³ ca̱á̱h³ tiaah² ba² xe̱y³, há⁴hé³ máh⁴ hí⁴jú̱y³.
\s1 Hi²xiáh³ niaá² Dios nɨ³ nieéy² diáh⁴ dsa³ jmɨɨyh⁴²güii³
\p 
\v 16 ’Hi²xiáh³ niaá² Dios nɨ³ nieéy² diáh⁴ dsa³ jmɨɨyh⁴²güii³, hi³ja̱³ gá⁴cuóy² Ja̱á̱² gu³xɨ³ ba² ja̱y³ ba² xe̱y³, duh³ hi³ hí⁴dsá⁴taáy³ chiáh², ca̱á̱h³ tiaah² ba² xe̱y³, há⁴hé³ máh⁴ hí⁴jú̱y³.
\v 17 Há⁴ja̱³ duh³ hi³ hí⁴bí⁴chiíy⁴ diáh⁴ dsa³ jmɨɨyh⁴²güii³ nɨ³ gá⁴xɨɨ́⁴ Dios nɨ³ gá⁴xɨ́y⁴ Ja̱á̱², gá⁴xɨ́y⁴ duh³ hí⁴jooy³ hí⁴sa̱y³ diáh⁴ dxú⁴ ba² nɨ³.
\p 
\v 18 ’Hi³ja̱³ liu³u²xɨ³ xe̱y³ hí⁴dsá⁴taáy³ chiáh² Ja̱á̱² nɨ³, mɨ²ja̱³ há⁴hé³ dsá⁴chi². Joó⁴ xɨ³ nɨ³ há⁴hé³ dsá⁴taáy³ chiáh², dsá⁴chi² chiaah¹ hi³ há⁴hé³ ma³taáy³ chiáh² Ja̱á̱² Dios, Ja̱á̱² hi³ ja̱y³ nɨ³.
\v 19 Dsá⁴chi² diáh⁴ chiaah¹ liáh³ güé⁴ ya⁴²jmɨɨ́⁴ jmɨɨyh⁴²güii³ la³, mɨ²ja̱³ xiáh³ xi² ñu³ha̱a̱h³ ba² gá⁴lɨ́⁴ dsɨ́² diáh⁴. Há⁴hé³ gá⁴lɨ́⁴ dsɨ́² diáh⁴ ya⁴²jmɨɨ́⁴ chiaah¹ jmáyh² hi³ mɨ³hee³² ba² ca³dah²jmee⁴.
\v 20 Liáh⁴jɨy³ diáh⁴ hi³ ca³dah²jmee⁴ hi³ mɨ³hee³² nɨ³ dɨ³cɨ̱ɨ̱y³² ca³dah²joo³² ya⁴²jmɨɨ́⁴. Há⁴hé³ ca³dsa³jé̱yh⁴ diáh⁴ xi² hií² ya⁴²jmɨɨ́⁴ nɨ³ duh³ há⁴hé³ hí⁴lii⁴ hi³ mɨ³hee³² ca³dah²jmee⁴ nɨ³.
\v 21 Joó⁴ diáh⁴ hi³ dɨ³nieeyh⁴² xiaa³dsaa³², hi³ já⁴ ca³dsa³jé̱yh⁴ ba² diáh⁴ xi² hií² ya⁴²jmɨɨ́⁴ nɨ³, duh³ hí⁴lii⁴ hi³ dxɨ́⁴lieey³² Dios ba² nɨ³ ca³dah²jmee⁴ hi³ dxú⁴.
\s1 Gá⁴liú³ ca̱á̱h³ Juan Bautista ja̱³ chiáh² Jesús
\p 
\v 22 Dsa³cɨ̱ɨ̱y³ liáh³ ma³liú³ Jesús ja̱³ chie̱é̱yh¹ Nicodemo, mɨ²ja̱³ ŋaá² vó⁴ Judea chie̱é̱yh¹ jniaah¹ diáh⁴ xɨh³chie̱y³² ja̱³. Nɨɨ́⁴ gá⁴yaa²ah¹ ca̱a̱³tú̱⁴ jmɨɨ́¹, ba² xeey³ jmɨɨ³ dsa³.
\v 23 Ba² rúh⁴ xeey³ jmɨɨ³ dsa³ Juan ja̱³ fɨɨ³ Enón, yeey⁴ caa¹ fɨɨ³ Salim, chiaah¹ hi²xiáh³ xa³ jmɨɨ³ nɨɨ́⁴. Hi³ja̱³ nɨɨ́⁴ dsa³dxí̱⁴ diáh⁴ dsa³ ja̱³ duh³ dsa³ja̱á̱y³ diáh⁴ jmɨɨ³.
\v 24 Chiaah¹ há⁴hé³ ma³tɨ́³ ma³dah²ta̱a̱yh³ ñuúh⁴ñí¹ Juan ja̱³ mɨ²ja̱³.
\p 
\v 25 Ja̱³ba² mɨ²ja̱³ diáh⁴ xɨh³chie̱y³² Juan hi³ ga³xeey³ jmɨɨ³ dsa³ ja̱³ mɨ³dah²liu⁴ ñuú³ chie̱é̱yh¹ ja̱y³aáy⁴ diáh⁴ israelitas ca³jaa¹ chiáh² hi³hí̱³ ca³bi³xɨ³ ca³bi³ŋɨɨ́y³ mii⁴.
\v 26 Hi³ja̱³ gá⁴dxi̱i̱³² duh³ liáh³la³ cá⁴dah²sɨɨ́h⁴ Juan ja̱³:
\p ―Dsa³he⁴, ba² mɨ³xeey³ jmɨɨ³ diáh⁴ dsa³, dsaá⁴ hi³ gá⁴ji̱i̱h⁴u³ ji̱h²jmɨɨ³ Jordán nɨ³, dsaá⁴ hi³ gá⁴liu⁴²u³ jniaah¹ chiáh². Hi³ja̱³ liáh⁴jɨy³ bɨh¹ mɨ³dsa³dxí̱⁴ chie̱é̱yh¹.
\p 
\v 27 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Juan ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Dios ba² nɨ³ ga³tieyh³² guaa³²a² ta² hi³ ga³jmee⁴²a² liáh³ja̱³ liáh³ja̱³²a².
\v 28 Niaá⁴ah³ na³lɨ́⁴ah³ dsa³ñi³² chia̱á̱²á⁴ hi³ gá⁴fáyh² liáh³la³: “Há⁴hí̱³ Cristo nɨ³ jniá³. Hi³ güé⁴á⁴ duh³ hi²jmeey⁴² juúh⁴ hi³ mɨ³hí⁴güéy³ ba² nɨ³.”
\v 29 Liu³u²xɨ³ xi² dsa³ji̱í̱³ guaa³ dsa³, dsaá⁴ hi³ dsa³ji̱í̱³ guaa³ nɨ³ ba² nɨ³ ná⁴ŋɨy¹. Amigo chié̱y² dsaá⁴ nɨ³ ca̱a̱³ hiíy⁴ nɨɨ́⁴ nuu³ liáh³xɨ³ liu⁴ dsaá⁴ ja̱³ ba², hi³ja̱³ hi²xiáh³ jé⁴ dsɨ́² nuu³ fáh⁴liu⁴ chiáh². Ba² liáh³ja̱³ xa̱⁴²á⁴ jniá³, ja̱³nɨ́⁴ gɨh¹ cua̱a̱y¹ná² gaáy³ dɨ́h¹ jé⁴ dsɨy⁴.
\v 30 Liáh³ ga³jmee⁴ ba² nɨ³ hi³ dsa³saa³ chiáh². Baáy⁴ jniá³ yáh¹, hi³ já⁴ hí⁴dsá⁴xieey⁴ ba² chieéy⁴ liáh³ca̱a̱³ jmɨɨ́¹.
\s1 Hi³ cá⁴yá⁴xiaá² yuuh¹ güii³
\p 
\v 31 ’Hi³ gá⁴xiaá² yuuh¹ güii³ nɨ³ ná⁴ŋɨy¹ gɨh¹ liáh³xɨ³ liáh⁴jɨy³ diáh⁴ dsa³. Joó⁴ hi³ ga³sa̱y³ jmɨɨyh⁴²güii³ la³, na³hii⁴ chiáh² dxaah¹vó⁴ la³ ba². Baáy⁴ ca³jaa¹ chiáh² hi³ xa³ jmɨɨyh⁴²güii³ la³ ba² ga³liu⁴. Joó⁴ hi³ güéy⁴ yuuh¹ güii³ nɨ³, ná⁴ŋɨy¹ gɨh¹ liáh³xɨ³ liáh⁴jɨy³ lɨ́⁴.
\v 32 Ga³liu⁴ chiáh² hi³ ma³joó², ga³liu⁴ chiáh² hi³ ma³nuú³. Jmɨ́yh³he̱é̱yh³ ba² dsa³ hi³ ñi³² nɨ³. Joó⁴ gu³xɨ³ hí̱³ há⁴hé³ ca³dsa³taáy³ chiáh² lii³²a².
\v 33 Joó⁴ liu³u²xɨ³ xe̱y³ dsa³ hí⁴dsá⁴taáy³ chiáh² hi³ gá⁴xiaá² yuuh¹ güii³ nɨ³, hi³hí̱³ na³lɨ́y⁴ dsa³ñi³² hi³ he̱é̱yh³ ba² hi³ ga³féh³ Dios nɨ³.
\v 34 Jmáyh² fáh⁴liu⁴ chiáh² Dios ba² ga³liu⁴ hi³ gá⁴xɨ́y⁴ ñaá² Dios nɨ³, chiaah¹ Dios nɨ³ ga³cuoy³² cáh³ti³² Espíritu Santo chié̱y².
\v 35 Hi²xiáh³ niaá² Dios nɨ³ nieéy² Ja̱á̱² nɨ³, hi³ja̱³ ma³tiéyh² guaa³ Ja̱á̱² nɨ³ jɨɨ⁴ lɨ́⁴.
\v 36 Hi³ja̱³ hi³ hí⁴dsá⁴taáy³ chiáh² Ja̱á̱² Dios nɨ³ ca̱á̱h³ tiaah² ba² xe̱y³, há⁴hé³ máh⁴ hí⁴jú̱y³. Joó⁴ hi³ há⁴hé³ dɨ́⁴dsá⁴taáy³, há⁴hé³ hí⁴jooy³ hí⁴güe³ dxú⁴ dsa³cɨ̱ɨ̱y³. Xiáh³ hi³ já⁴ hí⁴bí⁴chiíy⁴ ba² Dios nɨ³ chiáh².
\c 4
\s1 Gá⁴ji̱i̱h⁴ Jesús ja̱³ ja̱y³ mɨ́³ dsa³ Samaria
\p 
\v 1 Gá⁴dsaá⁴ dsɨ́² diáh⁴ fariseos ja̱³ hi³ fɨɨ́y⁴ gɨh¹ dsa³ na³cu̱yh⁴ chie̱é̱yh¹ Jesús liáh³xɨ³ Juan ja̱³, ba² fɨɨ́y⁴ gɨh¹ diáh⁴ dsa³ hi³ xeey³ jmɨɨ³.
\v 2 (Gu³xɨ³ ba² há⁴hí̱³ ñaá² Jesús ja̱³ xeey³ jmɨɨ³ diáh⁴ dsa³ ja̱³, jniaah¹ ba² ja̱³ xaa³ah¹ jmɨɨ³ diáh⁴ dsa³.)
\v 3 Hi³ja̱³ liáh³ gá⁴dsaá⁴ dsɨ́² Jesús ja̱³ hi³ja̱³, mɨ²ja̱³ cá⁴bí⁴hɨɨ́y⁴ Judea, duh³ ŋáyh² ca̱á̱h³ vó⁴ Galilea.
\p 
\v 4 Fi¹ hi³ gá⁴cá̱⁴ ja̱³, jmɨ́yh³ Samaria ja̱³ ga³jmee⁴ hí⁴ŋɨ́y³.
\v 5 Hi³ja̱³ gá⁴dxéyh² ca̱a̱³ fɨɨ³ liuh² hi³ xɨ̱ɨ̱y³ Sicar hi³ na³hii⁴ vó⁴ Samaria. Ja̱³ba² yeey⁴ nɨɨ́⁴ na³jniaa³ vó⁴ hi³ gá⁴cueeyh³ Jacob chiáh² José ja̱á̱² ja̱³.
\v 6 Nɨɨ́⁴ na³jniaa³ pozo chiáh² lɨ² Jacob. Hi²xiáh³ vaayh⁴ Jesús ja̱³ hi³ híy¹ fi¹ ja̱³, hi³ja̱³ gá⁴guá³ haah² pozo ja̱³, ca̱³liáh³ dxaá⁴ñíh² xɨ³ jmiih⁴.
\v 7 Liáh³ jey¹ Jesús ja̱³ nɨɨ́⁴, mɨ²ja̱³ gá⁴dxaá² ja̱y³ mɨ́³ dsa³ fɨɨ³ Samaria hi³ mɨ³hí⁴cá̱² jmɨɨ³. Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Cuoo² jniá³ ca³liuh² jmɨɨ³ nɨ³ hi²uuyh⁴².
\p 
\v 8 (Mɨ²ja̱³ mɨ³xa³ ca̱³ji̱i̱³ hi³ ma³dxia⁴²ah¹ jee⁴² fɨɨ³ Sicar ja̱³, hi³ cá⁴dxá⁴lia³²ah¹ ca³liuh² hi³ hi²chia⁴²ah¹.)
\p 
\v 9 Mɨ²ja̱³ liáh³la³ gá⁴féh³ mɨ́³ ja̱³ gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―¿Jmiih⁴² ja̱³ hi³ ga³ŋɨɨyh³² jniá³ jmɨɨ³ niu³ israelita nɨ³, baáy⁴ dsa³ Samaria ba² jniá²?
\p (Gá⁴féh³ liáh³ja̱³ mɨ́³ ja̱³ chiaah¹ há⁴hé³ dɨ³naáy³ diáh⁴ israelitas ja̱³ chie̱é̱yh¹ diáh⁴ dsa³ Samaria.)
\p 
\v 10 Hi³ja̱³ mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ mɨ́³ ja̱³:
\p ―Hu̱² ca̱a̱³² ba² maáy³ hi³ xa³ hi³ hí⁴cuoó⁴ niu³ Dios, baáy⁴ hu̱² maáy³ hi̱² nɨy³² jniá³ hi³ ga³ŋɨɨ́h⁴á⁴ niu³ jmɨɨ³ nɨ³, mɨ²ja̱³ niu³ ba² hi²ŋɨɨyh¹ jniá³ jmɨɨ³ hu̱² liáh³ja̱³. Chiaah¹ hi²cuoó⁴á⁴ niu³ jmɨɨ³ hi³ hí⁴jmeé⁴ xa̱³u³ liáh³nɨ³.
\p 
\v 11 Mɨ²ja̱³ liáh³la³ gá⁴féh³ mɨ́³ ja̱³ gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―Ñuyh⁴, há⁴hé³ xa³ hi²xeeyh¹ jmɨɨ³ nɨ³, hi²xiáh³ juh³ pozo la³. ¿Xiah² ja̱³ gua³chie̱y³ jmɨɨ³ hi³ ga³fáyh³ hi²cuooy¹ jniá³ nɨ³, hi³ ga³fáyh³ hi³ hí⁴jmeé⁴ xa̱⁴²á⁴ chieéy⁴ liáh³nɨ³?
\v 12 Ñúh³ah¹ Jacob nɨ³ gá⁴cueeyh³ chiaa⁴²ah¹ pozo la³, ja̱³ba² la³ gá⁴cá̱⁴ jmɨɨ³ hi³ gá⁴hɨ̱́h⁴ ñaá², cá⁴dah²hɨ̱́h⁴ diáh⁴ ja̱á̱², chie̱é̱yh¹ diáh⁴ gú⁴nuú¹ chié̱y² diáh⁴. ¿Xɨ² liáh³ca̱a̱y³ gaá³u³ gɨh¹ niu³ liáh³xɨ³ ñaá² Jacob ja̱³?
\p 
\v 13 Mɨ²ja̱³ liáh³la³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³:
\p ―Liáh⁴jɨy³ diáh⁴ hi³ hí⁴dah²hɨ̱́h² jmɨɨ³ la³, hí⁴lí³ dɨ́⁴dah²hɨ̱́h² ca̱á̱h³.
\v 14 Joó⁴ ja̱y³ dsa³ hi³ hí⁴hɨ̱́h² jmɨɨ³ hi³ hi²cuoy⁴² jniá², mɨ²ja̱³ há⁴hé³ máh⁴ hí⁴lí³ dɨ́⁴hɨ̱́h² ca̱á̱h³ jmɨɨ³. Chiaah¹ jmɨɨ³ hi³ hi²cuoó⁴á⁴ nɨ³ hí⁴lí³ liáh³xɨ³ mɨ¹ñi² jmɨɨ³ ba² fáh⁴ji̱í̱h⁴ chiáh², hí⁴jmeé⁴ hí⁴güe³ dxú⁴ chie̱é̱yh¹ Dios ca̱³ñiih³².
\p 
\v 15 Mɨ²ja̱³ liáh³la³ gá⁴féh³ mɨ́³ ja̱³ gá⁴sɨɨ́h⁴:
\p ―Ñuyh⁴, cuoo² jniá³ jmɨɨ³ hi³ ga³hoy³ nɨ³ duh³ há⁴hé³ máh⁴ hí⁴lí³ dɨ²uuyh⁴² ca̱á̱h³, ba² há⁴hé³ máh⁴ ná⁴dsɨ¹ hiíh⁴ hí⁴güé³á⁴ la³ hi²ya³chié̱y⁴ jmɨɨ³ he̱é̱yh³ pozo la³.
\p 
\v 16 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Má⁴dxi² gua³jéy⁴ dsaá⁴ chiú̱h²u³, duh³ hi²liu²a².
\p 
\v 17 Mɨ²ja̱³ liáh³la³ gá⁴féh³ mɨ́³ ja̱³:
\p ―Há⁴hé³ xe̱y³ dsaá⁴ chia̱á̱²á⁴.
\p Hi³ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―He̱é̱yh³ ba² chiú̱h²u³ hi³ ga³fáyh³ hi³ há⁴hé³ xe̱y³ dsaá⁴ chiú̱h²u³.
\v 18 Chiaah¹ mɨ³ñéy³ dsaá⁴ ma³ñíy³ chia̱á̱h¹u³. Baáy⁴ dsaá⁴ hi³ je¹u³ chia̱á̱h¹u³ ja̱³nɨ́⁴, ba² há⁴ja̱³ he̱é̱yh³ ba² jmɨ́yh³ dsaá⁴ chiú̱h²u³ nɨ³. Hi³ja̱³ he̱é̱yh³ ba² chiú̱h²u³ hi³ ga³fáyh³ hi³ há⁴hé³ xe̱y³ dsaá⁴ chiú̱h²u³.
\p 
\v 19 Mɨ²ja̱³ liáh³la³ gá⁴féh³ mɨ́³ ja̱³ gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―Ñuyh⁴, na³lɨ́⁴u³ profeta, ¿xɨ² haá²? chiaah¹ maáy³ jɨɨ⁴ lɨ́⁴.
\v 20 Diáh⁴ xa²yaa²ah¹ ñú⁴uuh²ah¹ hi³ cá⁴dah²guá³ mɨ³xa³ lɨ́⁴ cá⁴dah²jmeéh⁴ hu̱u̱¹rá² Dios cua̱h³ la³. Joó⁴ niaá⁴ah³ israelitas nɨ³ ga³fáh³ah³ hi³ Jerusalén ba² ga³jmee⁴ dsa³dxia⁴²a² dsa³jmeeh²a² hu̱u̱¹rá².
\p 
\v 21 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Ga³jmee⁴ gua³taá³u³ hi³ hi²fooh¹á² niu³ la³. Mɨ³hí⁴dxá⁴héy³ hiíh⁴ hi³ hi²jmeeh¹ah³ hu̱u̱¹rá² Ñúh³a² Dios nɨ³. Joó⁴ há⁴hé³ máh⁴ ná⁴dsɨ¹ hiíh⁴ hi³ hí⁴bí⁴dxí̱⁴ah³ cua̱h³ la³, ñé⁴ há⁴hé³ máh⁴ ná⁴dsɨ¹ hiíh⁴ hi³ cua³dxí̱⁴ah³ Jerusalén.
\v 22 Há⁴hé³ maá³ah³ niaá⁴ah³ samaritanos nɨ³ hi̱² nɨy³² hi³ ga³jmeeh³²ah³ hu̱u̱¹rá². Joó⁴ nia⁴²ah¹ ba² jniaah¹ israelitas hi̱² nɨy³² hi³ ga³jmeeh⁴²ah¹ hu̱u̱¹rá² nɨ³. Chiaah¹ dxɨ́⁴lieey³² diáh⁴ israelitas nɨ³, hí⁴liaá² Dios nɨ³ hí⁴lieéy² diáh⁴ dsa³ jmɨɨyh⁴²güii³.
\v 23 Hí⁴dxá⁴héy³ hiíh⁴, baáy⁴ ja̱³ba² ja̱³nɨ́⁴ ma³dxa³héy³, hi³ diáh⁴ hi³ he̱é̱yh³ ba² ca³dah²jmeéh⁴ hu̱u̱¹rá² Ñúh³a² Dios nɨ³ hí⁴dah²jmeéh⁴ hu̱u̱¹rá² dxɨ́⁴lieey³² Espíritu Santo baáy⁴ liáh³ xiaa³dsaa³² cáh³ti³² ba². Chiaah¹ liáh³ja̱³ ba² jmɨ́yh³ niaá⁴ Ñúh³a² nɨ³ hí⁴dah²jmeéh⁴ hu̱u̱¹rá².
\v 24 Espíritu ba² na³lɨ́y⁴ Dios nɨ³. Hi³ja̱³ diáh⁴ hi³ ca³dah²jmeéh⁴ hu̱u̱¹rá² nɨ³, ga³jmee⁴ hí⁴dah²jmeéh⁴ liáh³xɨ³ ca³bi³jmeé³ Espíritu Santo nɨ³ ca³bi³jmeéy³ diáh⁴, baáy⁴ jmɨ́yh³ liáh³ xiaa³dsaa³² ba².
\p 
\v 25 Mɨ²ja̱³ liáh³la³ gá⁴féh³ mɨ́³ ja̱³ gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―Maay⁴ ba² hi³ hí⁴güéy³ Mesías ―hi³ ca³dah²hey³² Cristo―. Mɨ² ma³güey⁴ hi³nɨy³², mɨ²ja̱³ hí⁴sɨɨ́h⁴ jniaah¹ jɨɨ⁴ lɨ́⁴.
\p 
\v 26 Mɨ²ja̱³ liáh³la³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Jniá³ nɨ³ Cristo, hí̱³ba² hi³ liúy¹ chia̱á̱h¹u³ nɨ³.
\p 
\v 27 Ja̱³ba² mɨ²ja̱³ cá⁴dxá⁴dxii³²ah¹ jniaah¹ diáh⁴ xɨh³chie̱y³² Jesús ja̱³. Mɨ²ja̱³ hi²xiáh³ dsaay³² dsɨ³²ah¹ chiaah¹ hi³ liu⁴ chie̱é̱yh¹ mɨ́³ ja̱³. Joó⁴ gu³xɨ³ hí̱³ jniaah¹ há⁴hé³ lɨ́⁴tiá³ dsɨ³²ah¹ gá⁴ŋɨɨh²ah¹ juúh⁴ Jesús ja̱³ hi³ he² ja̱³ liu⁴ chie̱é̱yh¹ mɨ́³ ja̱³.
\v 28 Mɨ²ja̱³ gá⁴cueeyh³ mɨ́³ ja̱³ mɨ¹dsuu² chiáh² duh³ ŋáyh² jee⁴² fɨɨ³. Liáh³ gá⁴dxéyh² ja̱³ mɨ²ja̱³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ diáh⁴ dsa³ oóyh² ja̱³:
\p 
\v 29 ―Ya³dxí̱⁴ah³ ya³joo⁴²ah³ ja̱y³ dsaá⁴ hi³ ma³sɨɨ́h⁴ jniá³ jɨɨ⁴ lɨ́⁴ hi³ ma³ŋɨ́³ ma³jmeéy⁴. ¿Xɨ² há⁴hí̱³ ruh³ Cristo hi³ ná⁴lɨ¹ cua̱a̱y¹ná² hí⁴güéy³ nɨ³?
\p 
\v 30 Mɨ²ja̱³ gá⁴voóy⁴ diáh⁴ dsa³ ja̱³ gá⁴dxí̱⁴ xi² hiíy⁴ Jesús ja̱³.
\v 31 Ja̱³ba² mɨ²ja̱³ hi²xiáh³ ŋɨɨ⁴²ah¹ jmɨ²heé¹ chiáh² Jesús ja̱³, liáh³la³ sɨɨh⁴²ah¹:
\p ―Dsa³he⁴, chiéh³ ca³liuh².
\p 
\v 32 Joó⁴ liáh³la³ ba² gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Xa³ ba² hi³ hi²eeyh⁴² jniá², hi³ há⁴hé³ cui̱i̱³ah³ niaá⁴ah³.
\p 
\v 33 Mɨ²ja̱³ liáh³la³ féh³ah¹ xi² niaa³²ah¹ voo³²ah¹:
\p ―¿Xɨ² foóh¹ xe̱y³ ma³bi²ca̱³ ma³eéh²?
\p 
\v 34 Joó⁴ mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Hí⁴lií² ba² nɨɨh¹ hi³ hi²jmeey⁴² liáh³xɨ³ ga³lɨ́³ dsɨ́² hi³ gá⁴xɨ́y⁴ jniá³ nɨ³. Ga³jmee⁴ hi²bi³ya⁴²á⁴ ta² chiáh². Hi³nɨ³ ba² nɨ³ ná⁴lɨ¹ liáh³xɨ³ hi³ ga³eeyh⁴ jniá³.
\p 
\v 35 ’Liáh³la³ ga³fáh³ah³ niaá⁴ah³ maay⁴ jniá³: “Jmee⁴ gɨh¹ chiú̱y³ sɨh³ hi³ hí⁴raa³ cuɨɨ³ chiaa⁴²a² nɨ³.” Joó⁴ liáh³la³ ba² hi²fooh¹á² niaá⁴ah³ jniá³. Joo⁴²ah³ xi² na³jñi¹ na³haa¹ nɨ³, ma³raa³ bɨh¹ cuɨɨ³ nɨ³, hi³ja̱³ mɨ³ga³jmee⁴ hí⁴chia̱a̱⁴² ja̱³nɨ́⁴.
\v 36 Ja̱y³ dsa³ hi³ ca³dxa³chie̱e̱yh⁴² hi³ ma³raa³, hi³hí̱³ ga³tɨ̱y⁴ jñiiy⁴. Hi³ ga³ca̱a̱⁴ ja̱³ yáh¹, diáh⁴ dsa³ ba² nɨ³, diáh⁴ hi³ hí⁴dah²güe³ chie̱é̱yh¹ Dios ca̱³ñiih³². Liáh³ja̱³ hí⁴jé⁴ dsɨ́² ree³ diáh⁴ hi³ ca³dah²jmee⁴ ta², liáh³ ba² hi³ ga³haa³², liáh³ ba² hi³ ca³dxa³chie̱e̱yh⁴² cuɨɨ³ hi³ ma³raa³ nɨ³.
\v 37 Hi³ja̱³ he̱é̱yh³ ba² liáh³xɨ³ dsa³féh³ ca̱a̱³ juúh⁴: “Ca̱a̱³ chiáh² ba² dsa³ hi³ ga³jmee⁴ jma², baáy⁴ dxeeyh⁴ ba² nɨ³ hi³ ga³ca̱a̱⁴ cuɨɨ³ nɨ³.”
\v 38 Hi³ja̱³ gá⁴sɨ́⁴á⁴ niaá⁴ah³ ya²chia̱a̱⁴ah³ hi³ ma³raa³, xi² há⁴hé³ jlɨh² gá⁴jmeé¹ah³ ta². Dxeeyh⁴ ba² ja̱³ cá⁴dah²haá², joó⁴ niaá⁴ah³ ba² ma³dxa³hee⁴ah³ hi²ca̱a̱⁴ah³ ta² chiáh² diáh⁴.
\p 
\v 39 Hi²xiáh³ fɨɨ́y⁴ diáh⁴ dsa³ vó⁴ Samaria gá⁴taáy³ chiáh² Jesús ja̱³, chiaah¹ hi³ gá⁴jmeé³ juúh⁴ mɨ́³ liáh³xɨ³ gá⁴féh³ Jesús ja̱³. Chiaah¹ liáh³la³ gá⁴féh³ mɨ́³ ja̱³: “Ma³sɨɨ́h⁴ jniá³ jɨɨ⁴ lɨ́⁴ hi³ ma³ŋɨ́³ ma³jmeéy⁴.”
\v 40 Hi³ja̱³ liáh³ cá⁴dxá⁴dxí̱⁴ diáh⁴ samaritanos xi² hiíy⁴ Jesús ja̱³, mɨ²ja̱³ cá⁴dah²ŋɨɨ́³ jmɨ²heé¹ chiáh² hi³ hu̱² hí⁴cueeyh⁴ chie̱é̱yh¹ diáh⁴. Hi³ja̱³ gá⁴cueeyh⁴ Jesús ja̱³ tú̱⁴ jmɨɨ́¹. \fig Juan 4:40|src="CN01667B.TIF" size="span" ref="San Juan 4:40"\fig*
\v 41 Mɨ²ja̱³ hi²xiáh³ fɨɨ́y⁴ gɨh¹ dsa³ gá⁴taáy³ chiáh² liáh³ cá⁴dah²nuú³ jmɨ́yh³ hi³ féh³ ñaá² Jesús ja̱³.
\v 42 Hi³ja̱³ liáh³la³ cá⁴dah²féh³ cá⁴dah²sɨɨ́h⁴ mɨ́³ dsa³ oóyh² diáh⁴ ja̱³:
\p ―Mɨ³nia⁴²ah¹ dxú⁴ cáh³ti³² ja̱³nɨ́⁴ hi³ he̱é̱yh³ ba² Cristo nɨ³, hi³nɨy³² nɨ³ hí⁴lieéy² diáh⁴ dsa³ jmɨɨyh⁴²güii³. Chiaah¹ ma³niuu²ah¹ voo³²ah¹ hi³ ma³féh³ ñaá² hi³ja̱³ ma³taá³ah¹ chiáh², há⁴ja̱³ ti̱¹ ba² hi³ ma³xɨɨ́yh¹ jniaah¹ liáh³xɨ³ ma³sɨɨ́h⁴ niu³ nɨ³.
\s1 Cá⁴bí⁴lieéy³ Jesús ja̱³ ja̱á̱² ja̱y³ dsa³ chié̱y² gobierno
\p 
\v 43 Liáh³ ma³yey³ hi³ tú̱⁴ jmɨɨ́¹ ja̱³ mɨ²ja̱³ cá⁴bí⁴hɨɨ́y⁴ ca̱á̱h³ Jesús ja̱³ vó⁴ Samaria, duh³ gá⁴hí³ ca̱á̱h³ fi¹, ŋáyh² vó⁴ Galilea.
\v 44 Hí̱³ba² ñaá² Jesús ja̱³, liáh³la³ gá⁴féh³ ca̱á̱h³ tiaah²: “Liu³u²xɨ³ ja̱y³ profeta hí⁴dxéyh² fɨɨ³ chiáh², há⁴hé³ jmɨ́yh³ dɨ³nieéy² diáh⁴ dsa³ oóyh².”
\v 45 Liáh³ gá⁴dxéyh² vó⁴ Galilea ja̱³, mɨ²ja̱³ cá⁴dah²tee³ ba² dxú⁴ diáh⁴ dsa³ nɨɨ́⁴, chiaah¹ liáh³ dah²ya²dxí̱⁴ jmɨ́¹feh⁴ pascua hi³ gá⁴tɨ́³ Jerusalén ja̱³, mɨ²ja̱³ nɨɨ́⁴ cá⁴dah²joó² jɨɨ⁴ lɨ́⁴ hi³ gá⁴jmeé³ Jesús ja̱³ jee⁴² jmɨ́¹feh⁴ ja̱³.
\p 
\v 46 Mɨ²ja̱³ ŋáyh² ca̱á̱h³ Jesús ja̱³ fɨɨ³ Caná hi³ na³hii⁴ vó⁴ Galilea, fɨɨ³ xi² gá⁴jmeé³ gá⁴lɨɨy⁴ vino jmɨɨ³ ja̱³. Ba² xa³ ca̱a̱³ fɨɨ³ hi³ xɨ̱ɨ̱y³ Capernaúm hi³ na³hii⁴ vó⁴ Galilea. Nɨɨ́⁴ jey¹ ja̱y³ empleado gaáy³ chié̱y² rey, joó⁴ dsaah⁴² ja̱á̱² dsa³ ja̱³.
\v 47 Hi³ja̱³ liáh³ gá⁴dsaá⁴ dsɨ́² dsa³ gaáy³ ja̱³ hi³ güéyh² Jesús ja̱³ Galilea hi³ naay³ vó⁴ Judea, mɨ²ja̱³ ñií¹ xi² jey¹, duh³ ya²xɨɨh⁴² hi³ hu̱² hí⁴jmeé⁴ jmɨ²heé¹ dsaa³² xɨ¹ñúh⁴ chiáh², duh³ hí⁴bí⁴lieéy³ ja̱á̱² ja̱³, chiaah¹ mɨ³hí⁴jú̱y³ ja̱³nɨ́⁴ ja̱³nɨ́⁴.
\v 48 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ dsa³ ja̱³:
\p ―Xɨ³ nɨ³ há⁴hé³ hi²joó³ah³ hi³ xa³ hi²jmeey⁴² hi³ dɨ́h¹ ca̱a̱³ fáh⁴lí³, mɨ²ja̱³ há⁴hé³ dsá⁴taá³ah³ niaá⁴ah³.
\p 
\v 49 Joó⁴ mɨ²ja̱³ liáh³la³ gá⁴féh³ empleado ja̱³:
\p ―Ñuyh⁴, ña³ xé̱yh², liáh³ca̱á̱h³ ja̱a̱h¹ hí⁴jú̱y³ ja̱a̱y⁴ nɨ³.
\p 
\v 50 Hi³ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ dsa³ ja̱³:
\p ―Má⁴dxi² xɨ¹ñúh⁴ chiú̱h²u³ chiaah¹ ma³laáy³ ba² ja̱a̱y³ nɨ³.
\p Gá⁴taáy³ dsa³ ja̱³ liáh³xɨ³ gá⁴féh³ Jesús ja̱³, hi³ja̱³ ŋáyh².
\v 51 Liáh³ mɨ³hí⁴dxéyh² xɨ¹ñúh⁴ chiáh² dxaáh² jmɨɨ́¹ liáh³ja̱³, mɨ²ja̱³ gá⁴voóy⁴ diáh⁴ mozos chié̱y² dah²bi²jé̱y¹, duh³ liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―Ma³laáy³ ba² ja̱a̱y³ nɨ³.
\p 
\v 52 Mɨ²ja̱³ gá⁴ŋɨɨ́h⁴ juúh⁴ diáh⁴ mozos chié̱y² ja̱³ hi³ he² hora ja̱³ cá⁴lɨ́⁴liaá² mɨ³dsa³váy² chiáh² ja̱á̱² ja̱³. Hi³ja̱³ liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―Ja̱³dxaá³ ca̱³liáh³ mɨ³ca̱a̱³ ca̱³laá³ gá⁴guaay⁴ dsaá¹ hi³ chie̱é̱yh¹ nɨ³.
\p 
\v 53 Mɨ²ja̱³ cá⁴lɨ́⁴liíh⁴ empleado ja̱³ hi³ ja̱³ba² mɨ³ca̱a̱³ ca̱³laá³ ja̱³ liáh³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ hi³ cua²dxéyh³, chiaah¹ ma³laáy³ ba² ja̱á̱² ja̱³. Hi³ja̱³ gá⁴taáy³ empleado ja̱³ chiáh² Jesús chie̱é̱yh¹ diáh⁴ familia chié̱y².
\p 
\v 54 Hi³la³ ja̱³ hi³dxá³ tú̱h⁴ tiaah² ja̱³ gá⁴jmeé³ Jesús lii⁴ ja̱³, hi³ he̱é̱yh³ ba² hee⁴ fáh⁴lí³, liáh³ güéyh² Galilea hi³ cá⁴bí⁴hɨɨ́y⁴ vó⁴ Judea ja̱³.
\c 5
\s1 Cá⁴bí⁴lieéy³ Jesús ja̱³ hi³ ná⁴hi̱y¹ xi² xɨ̱ɨ̱y³ Betesda
\p 
\v 1 Dsa³cɨ̱ɨ̱y³ liáh³ ma³bi³lieéy³ Jesús ja̱³ ja̱á̱² dsa³ hí̱³, mɨ²ja̱³ mɨ³hí⁴dah²jmeé⁴ jmɨ́¹feh⁴ diáh⁴ dsa³ Jerusalén ja̱³, hi³ja̱³ ŋaá² ca̱á̱h³ Jesús ja̱³ Jerusalén.
\v 2 Haah² fɨɨ³ Jerusalén ja̱³ na³jniaa³ ca̱a̱³ jnɨ́¹ñú² gaáy³ hi³chiaah³² diáh⁴ dsɨɨ³jaa³. Ja̱³ba² nɨɨ́⁴ na³jniaa³ ca̱a̱³ tanque gaáy³ hi³ ná⁴ha⁴² jmɨɨ³. Baáy⁴ xa³ ñá³ voó² liuh² caa¹ ja̱³. Betesda xɨ̱ɨ̱y³ nɨɨ́⁴ fáh² hebreo.
\v 3 Hi²xiáh³ fɨɨ́y⁴ diáh⁴ dsa³ dsaah⁴² na³saay³ nɨɨ́⁴. Xe̱y³ hi³ tuúy¹, xe̱y³ hi³ ná⁴hi̱y¹ baáy⁴ xe̱y³ diáh⁴ hi³ há⁴hé³ hí⁴jooy³ hí⁴bɨ́y² hí⁴xíh² diáh⁴ cáh³ti³². Na³saay³ nɨɨ́⁴ dah²je̱e̱³² hi³ hí⁴bɨ́² jmɨɨ³, duh³ dsá⁴taáyh¹ diáh⁴.
\v 4 Chiaah¹ ca̱á̱h³ca̱á̱h³ ga³guáy³ ja̱y³ ángel ca³bi³bí¹ jmɨɨ³ ja̱³. Mɨ²ja̱³ ga³laáy³ hi³dxá³ ja̱y³ dsa³ dsaah⁴² hi³ dsá⁴hí³ he̱é̱yh³ jmɨɨ³ ja̱³, ga³laáy³ gu³xɨ³ hé³ ba² dsaá¹ hi³ chie̱é̱yh¹.
\v 5 Nɨɨ́⁴ na³caayh³² ja̱y³ dsaá⁴ hi³ dsaah⁴², mɨ³xa³ ca̱³liáh³ dxiá⁴dxiá³ dsɨ³² jñá⁴ ji̱i̱³ bih³ hi³ na³caayh³² dsaah⁴².
\v 6 Liáh³ gá⁴joó² Jesús ja̱³ hi³ na³caayh³² nɨɨ́⁴, mɨ²ja̱³ cá⁴lɨ́⁴chii⁴ hi³ hi²xiáh³ mɨ³voó³ dsaah⁴², hi³ja̱³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ dsa³ dsaah⁴² ja̱³:
\p ―¿Xɨ² naay³ hí⁴liaá³u³?
\p 
\v 7 Mɨ²ja̱³ liáh³la³ gá⁴féh³ dsa³ dsaah⁴² ja̱³:
\p ―Ñuyh⁴, há⁴hé³ xe̱y³ hí⁴ta̱a̱yh³ jniá³ he̱é̱yh³ jmɨɨ³ nɨ³ mɨ² ga³bɨ³² nɨ³. Liu³u²xɨ³ mɨ² naáy⁴ ya³húy², mɨ²ja̱³ dxeeyh⁴ ba² ca³dsa³hí³ ji̱³nɨɨ́⁴.
\p 
\v 8 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Na³hɨɨ́y¹, chia̱a̱⁴ hi³ bí⁴dxɨ́y¹ nɨ³ duh³ má⁴dxi².
\p 
\v 9 Xé̱yh² ba² mɨ²ja̱³ gá⁴laáy³ dsaá⁴ ja̱³, ja̱³ba² gá⁴xaáh² hi³ bí⁴dxɨ² ja̱³, duh³ gá⁴laá⁴ mɨ³chie⁴ji̱i̱⁴. Joó⁴ jmɨɨ́¹ mah² ja̱³ liáh³ cá⁴bí⁴liaá³ Jesús ja̱³ cá⁴bí⁴lieéy³ dsa³ dsaah⁴² ja̱³.
\v 10 Hi³ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³ cá⁴dah²sɨɨ́h⁴ dsa³ hi³ ma³laáy³ ja̱³:
\p ―Há⁴hé³ xa³ jú¹hiíh⁴ hi³ hi²ca̱a̱y⁴ hi³ bí⁴dxɨ́y¹ nɨ³ ja̱³nɨ́⁴, chiaah¹ na³héy¹. Chiaah¹ jmɨɨ́¹ mah² ba² ja̱³nɨ́⁴.
\p 
\v 11 Mɨ²ja̱³ liáh³la³ gá⁴féh³ dsa³ ja̱³:
\p ―Joó⁴ dsa³ hi³ ma³bi³lieéy³ jniá³ nɨ³ ba² nɨ³ ma³sɨɨ́h⁴ jniá³: “Chia̱a̱⁴ láh³ hi³ bí⁴dxɨ́y¹ nɨ³ baáy⁴ duh³ má⁴dxi².”
\p 
\v 12 Mɨ²ja̱³ liáh³la³ cá⁴dah²sɨɨ́h⁴ dsaá⁴ ja̱³:
\p ―¿Hi̱² nɨy³² hi³ ma³sɨɨ́h⁴ niu³ liáh³nɨ³?
\p 
\v 13 Joó⁴ há⁴hé³ ñi³² dsaá⁴ ja̱³ hi³ hi̱² hí̱³ cá⁴bí⁴liaá³ chiáh² ja̱³, chiaah¹ ja̱³ba² gá⁴caáyh² gá⁴dxiuúyh² jee⁴² chiáh² diáh⁴ dsa³ ja̱³ ba² Jesús ja̱³, hi³ja̱³ há⁴hé³ máh⁴ gá⁴joóy².
\v 14 Dsa³cɨ̱ɨ̱y³ liáh³ja̱³ gá⁴ji̱i̱h⁴ ca̱á̱h³ Jesús ja̱³ xi² jey¹ guah³ gaáy³ ja̱³, hi³ja̱³ liáh³la³ gá⁴sɨɨ́h⁴:
\p ―Niuu³ ruh³ la³, ja̱³nɨ́⁴ gɨh¹ ma³laá³u³, há⁴ máh⁴ hi³bi³sáy¹ dsaa² chiú̱h²u³, duh³ há⁴hé³ hí⁴chi̱í̱h²u³ ca̱a̱³ hi³ mɨ³hee³² gɨh¹ ca̱á̱h³liaáh³.
\p 
\v 15 Mɨ²ja̱³ ŋáyh² dsaá⁴ ja̱³ duh³ cá⁴dxá⁴xɨɨh⁴² diáh⁴ israelitas ja̱³ hi³ Jesús ja̱³ ja̱³ cá⁴bí⁴liaá³ chiáh².
\v 16 Hi³ja̱³ ja̱³ ca³dah²laá⁴ mɨ³dah²bi³dxɨɨ́y² Jesús ja̱³ hi³ dɨ³niaá⁴ hí⁴dah²jɨ̱́yh⁴, chiaah¹ hi³ ga³jmee⁴ liáh³ja̱³ jmɨɨ́¹ mah² ja̱³.
\v 17 Joó⁴ mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Jmee⁴ ta² Dia² chia̱á̱²á⁴ nɨ³ ma³güe⁴ la³ ja̱³nɨ́⁴, hi³ja̱³ ba² jmeey⁴ ta² jniá².
\p 
\v 18 Hi³ja̱³ hi³ já⁴ dɨ³niaá⁴ ba² diáh⁴ israelitas ja̱³ hí⁴dah²jɨ̱́yh⁴ Jesús ja̱³. Há⁴ja̱³ ti̱¹ ba² hi³ fáh⁴ hi³ há⁴hé³ ga³jmee⁴ he̱é̱yh³ jmɨɨ́¹ mah² ja̱³. Ba² hi²xiáh³ dɨ³cɨ̱ɨ̱y³² diáh⁴ chiaah¹ hi³ gá⁴féh³ hi³ Dios ja̱³ na³lɨ́y⁴ jmɨ́yh³ jmii³, hi³ja̱³ lii⁴ hi³ jmey³² ñaá² ree³ liáh³xɨ³ Dios.
\s1 Jesús nɨ³ ga³chiuuh³² hiíh⁴ jɨɨ⁴ lɨ́⁴
\p 
\v 19 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Niuu³ah³ hi³ hi²fooh¹á² niaá⁴ah³ la³. Gu³xɨ³ hé³ há⁴hé³ hí⁴jooy³ hí⁴jmeé⁴ Ja̱á̱² Dios nɨ³ hi³ hí⁴jmeé⁴ ñaá². Jmáyh² hi³ ga³joo³² ga³jmee⁴ Ñúh³a² Dios nɨ³ ba² nɨ³ ga³jmee⁴. Chiaah¹ jɨɨ⁴ lɨ́⁴ hi³ ga³jmee⁴ Ñúh³a² nɨ³, ba² ga³jmee⁴ Ja̱á̱² nɨ³.
\v 20 Chiaah¹ hi²xiáh³ niaá² Ñúh³a² nɨ³ nieéy² ja̱á̱² nɨ³, hi³ja̱³ ga³heé⁴ jɨɨ⁴ lɨ́⁴ hi³ ga³jmee⁴ ñaá². Baáy⁴ hí⁴heé⁴ dxaáh² hi³ gaáy³ gɨh¹ ca̱á̱h³liaáh³, hi³ja̱³ hi²xiáh³ hí⁴dsaáy² há²ah³ niaá⁴ah³ mɨ² ma³joo⁴²ah³.
\v 21 Chiaah¹ ja̱³ba² liáh³xɨ³ ca³bi³ji̱i̱yh³ Ñúh³a² nɨ³ diáh⁴ dsa³jú̱y¹, ga³cuoó⁴ diáh⁴ fáh⁴ji̱í̱h⁴, ba² liáh³ja̱³ Ja̱á̱² nɨ³ hí⁴cuoó⁴ diáh⁴ fáh⁴ji̱í̱h⁴, diáh⁴ dsa³ hi³ ga³lɨ́³ dsɨ́² hí⁴cuoó⁴.
\v 22 Chiaah¹ há⁴hé³ ga³ca̱a̱⁴ cua̱a̱y¹ná² chiáh² diáh⁴ dsa³ Ñúh³a² nɨ³, ñé⁴ chiáh² gu³xɨ³ ja̱y³. Gá⁴tiéyh² guaa³ Ja̱á̱² nɨ³ ba² duh³ hi³nɨy³² ba² hí⁴ca̱a̱⁴ cua̱a̱y¹ná² chiáh² diáh⁴ dsa³,
\v 23 duh³ja̱³ liáh⁴jɨy³ ba² dsa³ hí⁴dah²jmeéh⁴ hu̱u̱¹rá² Ja̱á̱² liáh³xɨ³ ca³dah²jmeéh⁴ ñaá² Ñúh³a² nɨ³. Ja̱y³ hi³ há⁴hé³ hí⁴jmeéh⁴ hu̱u̱¹rá² Ja̱á̱² nɨ³, ja̱³ba² hi³ há⁴hé³ ga³jmeéh⁴ hu̱u̱¹rá² Ñúh³a² hi³ gá⁴xɨ́y⁴ Ja̱á̱² nɨ³ ja̱³.
\p 
\v 24 ’Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³, hi³ ga³jmee⁴ he̱é̱yh³ fáh⁴liu⁴ chieéy⁴ la³, baáy⁴ hi³ ca³dsa³taáy³ chiáh² Ñuyh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³, hi³hí̱³ mɨ³xe̱y³ chie̱é̱yh¹ Dios. Há⁴hé³ máh⁴ dsá⁴chi². Chiaah¹ ma³túy² chiáh² fáh⁴ju̱y¹, mɨ³na³ji̱í̱yh⁴ bɨh¹ ba².
\v 25 Jmɨ́yh³he̱é̱yh³ hí⁴dxá⁴héy³ hora, baáy⁴ ja̱³ ba² ja̱³nɨ́⁴ nɨ³ mɨ³hí⁴dah²nuú⁴ diáh⁴ dsa³jú̱y¹ nɨ³ fáh⁴liu⁴ chieéy⁴. Hi³ja̱³ diáh⁴ hi³ hí⁴dah²jmeé⁴ he̱é̱yh³, hí⁴ji̱i̱h⁴ diáh⁴ ca̱á̱h³ duh³ hí⁴dah²güe³ chie̱é̱yh¹ Dios.
\v 26 Chiaah¹ liáh³xɨ³ na³ji̱í̱yh⁴ ñaá² ba² nɨ³ Dios nɨ³, ja̱³ba² liáh³nɨ³ ma³cuoó⁴ jú¹hiíh⁴ ja̱á̱² nɨ³, hi³ ba² hí⁴jooy³ xe̱y³ na³ji̱í̱yh⁴ liáh³nɨ³.
\v 27 Ba² ma³cuoó⁴ jú¹hiíh⁴ hi³ hí⁴ca̱a̱⁴ cua̱a̱y¹ná² chiáh² diáh⁴ dsa³ jmɨɨyh⁴²güii³, chiaah¹ hi³ na³lɨ́y⁴ Ja̱á̱² Dsa³ nɨ³.
\v 28 Há⁴ hi³dsaay³² há²ah³ hi³la³, chiaah¹ hí⁴dxá⁴héy³ hiíh⁴ hi³ hí⁴dah²nuú⁴ diáh⁴ dsa³jú̱y¹ nɨ³ hi³ teé⁴ diáh⁴,
\v 29 mɨ²ja̱³ hí⁴ji̱i̱h⁴ diáh⁴ ca̱á̱h³. Diáh⁴ hi³ cá⁴dah²jmeé³ dxú⁴, hí⁴ji̱i̱h⁴ diáh⁴ ca̱á̱h³ duh³ hí⁴dah²güe³ chie̱é̱yh¹ Dios. Joó⁴ diáh⁴ hi³ cá⁴dah²jmeé³ mɨ³hee³² yáh¹, hí⁴ji̱i̱h⁴ diáh⁴ ca̱á̱h³ duh³ hí⁴dsá⁴chi² diáh⁴.
\s1 Lii⁴ ba² hi³ Dios nɨ³ gá⁴xɨ́y⁴ Jesús
\p 
\v 30 Gá⁴hɨɨ́² liu⁴ liáh³ja̱³ Jesús ja̱³, liáh³la³ féh³:
\p ―Há⁴hé³ xa³ cáh³ti³² hi³ hí⁴jooy³ hi²jmeey⁴², hi³ hi²jmeey⁴² ñeéy⁴. Liáh³xɨ³ ga³nuuy⁴ ga³féh³ Ñuyh⁴ nɨ³ ba² nɨ³ ga³ca̱a̱y³² cua̱a̱y¹ná² chiáh² diáh⁴ dsa³, baáy⁴ xiaa³dsaa³² cáh³ti³² ba² nɨ³ ga³ca̱a̱y³² cua̱a̱y¹ná² nɨ³. Chiaah¹ há⁴hé³ ga³naayh³² liáh³xɨ³ ga³lɨ́³ dsɨy⁴ ñeéy⁴. Ga³jmeey⁴ liáh³xɨ³ ga³lɨ́³ dsɨ́² Ñuyh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³ ba² nɨ³.
\v 31 Liu³u²xɨ³ hi²jmeey⁴² dsa³ñi³² chieéy⁴ ñeéy⁴, mɨ²ja̱³ há⁴hé³ maá³ah³ xɨ³ he̱é̱yh³, chiaah¹ ñeéy⁴ ba² ja̱³ liuy⁴ ca³jaa¹ chiáh² hi³ maay⁴.
\v 32 Joó⁴ xe̱y³ ba² dxeeyh⁴ hi³ na³lɨ́y⁴ dsa³ñi³² chieéy⁴ jniá³, baáy⁴ maay⁴ hi³ he̱é̱yh³ ba² jɨɨ⁴ lɨ́⁴ hi³ ga³féh³ ca³jaa¹ chieéy⁴.
\v 33 Ca̱á̱h³ tiaah² ja̱³ gá⁴xɨ́⁴ah³ diáh⁴ dsa³ hi³ dah²ya²ñi³ Juan hi³ ga³xeey³ jmɨɨ³ dsa³, hi³ xa³ dah²ya²ŋɨɨh⁴² juúh⁴, baáy⁴ he̱é̱yh³ ba² jɨɨ⁴ liáh³xɨ³ gá⁴hí̱¹ Juan ja̱³.
\v 34 Joó⁴ há⁴hé³ na³xɨ́h¹á² máh³ xɨ³ xe̱y³ hí⁴liú⁴ dxú⁴ chieéy⁴, ga³fayh⁴ liáh³nɨ³ ga³hó⁴á⁴ Juan nɨ³ duh³ja̱³ hí⁴jooy³ hí⁴sa̱³ah³ dxú⁴ ba² nɨ³.
\v 35 Juan ja̱³ gá⁴lɨ́y⁴ liáh³xɨ³ ca̱a̱³ lámpara hi³ na³hi̱i̱⁴ xi³. Niaá⁴ah³ yáh¹ gá⁴lɨ́⁴ ba² há²ah³ ca̱³ji̱i̱³ liáh³xɨ³ gá⁴hé³ Juan ja̱³.
\v 36 Joó⁴ xa³ dxaáh² hi³ liu⁴ gɨh¹ jɨy³ chieéy⁴ jniá³ liáh³xɨ³ hi³ gá⁴hé³ Juan nɨ³. Diáh⁴ hi³ ga³jmeey⁴ nɨ³ ga³jmee⁴ dsa³ñi³² chieéy⁴ hi³ he̱é̱yh³ ba² Ñúh³a² nɨ³ gá⁴xɨ́y⁴ jniá³. Chiaah¹ ga³jmeey⁴ ja̱³ba² ta² hi³ gá⁴tiéyh² guaay⁴ hi²jmeey⁴².
\v 37 Ji̱í̱⁴ Ñuyh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³, ba² ga³liu⁴ dxú⁴ chieéy⁴. Joó⁴ há⁴hé³ jlɨ́h³ ma³niuu³ah³ ma³liú³, ba² há⁴hé³ jlɨ́h³ ma³joo⁴²ah³ ñaá²,
\v 38 ba² há⁴hé³ ma³jmeé¹ah³ chia̱á̱²ah³ fáh⁴liu⁴ chiáh², chiaah¹ há⁴hé³ ca³gua³taá³ah³ chiáh² hi³ gá⁴xɨ́y⁴ Ñuyh⁴ nɨ³.
\v 39 Hi²xiáh³ dxú⁴ ca³bi³tɨ̱⁴ah³ fáh⁴liu⁴ chiáh² Dios nɨ³, chiaah¹ naa³ah³ hi³ hu̱² hí⁴dxaah⁴ah³ jmiih⁴² hí⁴jooy³ hi²ñí³ah³ chia̱á̱²ah³ Dios ca̱³ñiih³². Baáy⁴ ja̱³ba² ca³jaa¹ chieéy⁴ jniá³ nɨ³ dsa³liú⁴ xi³ chiáh² Dios nɨ³.
\v 40 Joó⁴ niaá⁴ah³ há⁴hé³ naa³ah³ hi³ hi²ta̱a̱h⁴ah³ vo̱ó̱h²ah³ chia̱á̱h¹ah³ jniá³ duh³ja̱³ hí⁴tɨ̱́⁴ah³ hi²ñí³ah³ chia̱á̱²ah³ Dios.
\p 
\v 41 ’Há⁴hé³ ga³naayh³² jniá³ hi³ hí⁴dah²liú⁴ dxú⁴ chieéy⁴ diáh⁴ dsa³.
\v 42 Joó⁴ cui̱i̱⁴²á⁴ ba² niaá⁴ah³ hi³ja̱³ maay⁴ ba² hi³ há⁴hé³ jmɨ́yh³ naá⁴ah³ Dios.
\v 43 Liáh³xɨ³ taah⁴ ta² Ñuyh⁴ ba² nɨ³ güé⁴á⁴ jniá³. Joó⁴ niaá⁴ah³ há⁴hé³ dɨ²jmee³ah³ he̱é̱yh³ chieéy⁴. Joó⁴ liu³u²xɨ³ dxeeyh⁴ dsa³ hí⁴güéy³ cua̱a̱y¹ná² chiáh² ñaá², chiáh² hi³hí̱³ si¹ hi²jmee³ah³ he̱é̱yh³.
\v 44 Jmiih⁴² ja̱³ hí⁴jooy³ dsá⁴taá³ah³ chieéy⁴, chiaah¹ xiáh³ hi³ ga³naáh³ah³ hi³ hí⁴dah²liú⁴ dxú⁴ chia̱á̱²ah³ diáh⁴ oóh²ah³ nɨ³, dxa² hi³ hi²naáh³ah³ hi³ hí⁴liú⁴ dxú⁴ chia̱á̱²ah³ ja̱y³ Dios Hi³bií⁴gaáy³ nɨ³.
\v 45 Há⁴ hi³ta³ hi³hɨ³ah³ hi³ hi²cuoy⁴² dsaa² chia̱á̱²ah³ rúh⁴ñi² Ñuyh⁴ nɨ³. Hí̱³ba² Moisés hi³ ga³jmee³ah³ he̱é̱yh³ chiáh² nɨ³, hi³nɨy³² ba² nɨ³ hí⁴cuó⁴ dsaa² chia̱á̱²ah³ rúh⁴ñi² Ñúh³a² nɨ³.
\v 46 Liu³u²xɨ³ he̱é̱yh³ ba² ca³gua³taá³ah³ hi³ gá⁴féh³ Moisés, mɨ²ja̱³ ba² hí⁴dsá⁴taá³ah³ chieéy⁴ jniá³ hu̱² liáh³ja̱³. Chiaah¹ ca³jaa¹ chieéy⁴ jniá³ ja̱³ gá⁴xɨɨ́³ Moisés.
\v 47 Joó⁴ xɨ³ nɨ³ há⁴hé³ ca³gua³taá³ah³ hi³ gá⁴xɨɨ́³ Moisés nɨ³, hi³ja̱³ jmiih⁴² ja̱³ hí⁴dsá⁴taá³ah³ hi³ ga³fayh⁴ jniá³ nɨ³.
\c 6
\s1 Gá⁴cuó³ Jesús ja̱³ cá⁴dah²eéh² ñéy³ mil dsa³
\r (Mt. 14:13-21; Mr. 6:30-44; Lc. 9:10-17)
\p 
\v 1 Dsa³cɨ̱ɨ̱y³ liáh³ja̱³, ŋaá² Jesús ja̱³ xiaáh³ ca³jaa¹ dxaa² gaáy³ hi³ xɨ̱ɨ̱y³ Galilea, ja̱³ba² hi³ xɨ̱ɨ̱y³ Tiberias.
\v 2 Ba² hi²xiáh³ fɨɨ́y⁴ dsa³ gá⁴dxí̱⁴ chie̱é̱yh¹, chiaah¹ dah²joo³² liáh³xɨ³ jmee⁴ Jesús ja̱³, hi³ bi³lieéy³ diáh⁴ dsa³ dsaah⁴² hi³ dɨ́h¹ ca̱a̱³ fáh⁴lí³.
\v 3 Mɨ²ja̱³ gá⁴saáh² Jesús ja̱³ yuuh¹ ca̱a̱³ cua̱h³, duh³ gá⁴guá³ nɨɨ́⁴ chie̱é̱yh¹ jniaah¹ diáh⁴ xɨh³chie̱y³² ja̱³.
\v 4 Mɨ³ya³chie̱y¹ jmɨ́¹feh⁴ chiaa⁴²ah¹ jniaah¹ israelitas hi³ ga³cuh³²ah¹ mɨ¹ja̱á̱² dsɨɨ³jaa³ ja̱³.
\v 5 Liáh³ gá⁴joó² Jesús ja̱³ hi³ hi²xiáh³ fɨɨ́y⁴ diáh⁴ dsa³ dsa³dxí̱⁴ xi² jey¹ ja̱³, mɨ²ja̱³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ Felipe:
\p ―¿Xiah² ja̱³ hi²lia⁴²a² hi³ hí⁴dah²eéh² diáh⁴ dsa³ hi³ booy¹ fɨɨ́y⁴ la³?
\p 
\v 6 Jmɨ́yh³ hi³ nieeh¹ dsɨ́² féh³ ba² ja̱³ hi³ ya³dsaa³ hiíh⁴ jmiih⁴² hí⁴féh³ Felipe ja̱³. Chiaah¹ mɨ³ñi³² ba² ñaá² liáh³xɨ³ hí⁴jmeé⁴.
\v 7 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Felipe ja̱³ gá⁴sɨɨ́h⁴:
\p ―Há⁴hé³ hí⁴lií² ma² tú̱⁴ ñá⁴laá³ denarios hó² ya³dsɨ² hi³ hí⁴dah²eéh² máh⁴ ca³liuh² liáh⁴jɨy³ lɨ́⁴.
\p 
\v 8 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Andrés ja̱á̱¹ Simón Pedro dxeeyh⁴ xɨh³chie̱y³² ja̱³:
\p 
\v 9 ―Hi³ley³² ja̱y³ mɨ¹liuh² hi³ chia̱³ ñá³ fɨɨh⁴² hó² ya³dsɨ², baáy⁴ aáy⁴ hi³tieéyh¹ jmɨɨ³. Joó⁴ xiah² ja̱³ dɨ́h¹ niaáh² hi³la³, chiaah¹ cua̱a̱y¹ná² gaáy³ dɨ́h¹ fɨɨ́y⁴ diáh⁴ dsa³ la³.
\p 
\v 10 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹ na³lɨ́⁴ah¹, xɨh³chie̱y³²:
\p ―Xɨɨ́h¹ah³ diáh⁴ dsa³ nɨ³ hi³ cua²dah²güe³ xa³ja̱³.
\p Hi²xiáh³ liih² xa³ xaah¹ nuu³ nɨɨ́⁴, hi³ja̱³ nɨɨ́⁴ cá⁴dah²guá³ liú⁴u³ ñéy³ mil diáh⁴ dsaá⁴ ja̱³.
\v 11 Mɨ²ja̱³ gá⁴cá̱⁴ Jesús ja̱³ liú⁴u³ ñá³ fɨɨh⁴² hó² ya³dsɨ² ja̱³ duh³ gá⁴liúy² Dios. Liáh³ ma³jooy³ ma³cuó³ jmɨ²heé¹ ja̱³, mɨ²ja̱³ gá⁴cuoó⁴ jniaah¹ hó² ya³dsɨ² ja̱³, duh³ hi²dxaa⁴²ah¹ hi²cuoo²ah¹ diáh⁴ dsa³ hi³ dɨ³nieeyh⁴² ñiíh² nuu³ ja̱³. Ba² gá⁴jmeé³ chiáh² liáh³ja̱³ chie̱é̱yh¹ diáh⁴ hi³tieéyh¹ jmɨɨ³ ja̱³, gá⁴cuoó⁴ diáh⁴ dsa³ ja̱³ liáh³nɨɨh¹ lɨ́⁴ ga³lɨ́³ dsɨ́² diáh⁴.
\v 12 Liáh³ ma³jooy³ ma³dah²eéh² hi³ ma³lií² chiáh² diáh⁴ cáh³ti³² ja̱³, mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Dxa³chia̱a̱h⁴²ah³ diáh⁴ jaa¹naa¹ hi³ ma³cueeyh⁴ nɨ³, duh³ há⁴hé³ dsá⁴yeéy⁴ cáh³ti³².
\p 
\v 13 Mɨ²ja̱³ xa³ dxiá⁴tiú̱³ láh¹mɨh³ gɨh¹ bih³ diáh⁴ jaa¹naa¹ hi³ gá⁴cueeyh⁴ ja̱³ cá⁴dxá⁴chia̱a̱h⁴²ah¹, chiáh² hi³ ñá³ fɨɨh⁴² hó² ya³dsɨ² ja̱³.
\v 14 Hi³ja̱³ liáh³ cá⁴dah²joó² diáh⁴ dsa³ hi³ ca̱a̱³ fáh⁴lí³ ba² ja̱³ gá⁴jmeé³ liáh³ja̱³ Jesús ja̱³, mɨ²ja̱³ liáh³la³ cá⁴dah²féh³:
\p ―He̱é̱yh³ ba² hi³nɨy³² nɨ³ profeta hi³ ná⁴lɨ¹ cua̱a̱y¹ná² hí⁴güéy³ jmɨɨyh⁴²güii³ la³.
\p 
\v 15 Joó⁴ cá⁴lɨ́⁴chii⁴ Jesús ja̱³ hi³ dɨ³niaá⁴ diáh⁴ dsa³ ja̱³ hí⁴dah²jéy⁴ fáh⁴dxá⁴tie̱é̱y¹ duh³ hí⁴dah²jméy² rey chié̱y² diáh⁴. Há⁴hé³ niaá⁴ Jesús ja̱³ liáh³ja̱³, hi³ja̱³ ŋaá² ca̱á̱h³ yuuh¹ cua̱h³ ja̱³, chiaah¹ niaá⁴ hí⁴cueeyh⁴ ñaá² ba².
\s1 Gá⁴hí³ fi¹ Jesús ja̱³ ñiíh² jmɨɨ³
\r (Mt. 14:22-27; Mr. 6:45-52)
\p 
\v 16 Liáh³ ma³niuu³ ja̱³ mɨ²ja̱³ cá⁴dxá⁴dxia⁴²ah¹ dxaá² gaáy³ ja̱³,
\v 17 mɨ²ja̱³ gá⁴taah²ah¹ ca̱a̱³ maá² duh³ hi²ha³²ah¹ dxaá² gaáy³ ja̱³ hi³ dsa³dxia⁴²ah¹ fɨɨ³ Capernaúm. Mɨ³ñu³ha̱a̱h³, baáy⁴ há⁴hé³ ma³dxéyh² Jesús ja̱³.
\v 18 Liáh³ tiaah²ah¹ fi¹ he̱é̱yh³ maá² ja̱³, mɨ²ja̱³ cá⁴lɨ́⁴liaá² mɨ³hɨɨ³ ca̱a̱³ dxɨ́³ veyh³, hi³ja̱³ hi²xiáh³ ñií² dsa³na³hɨɨ́y¹ jmɨɨ³ ja̱³.
\v 19 Liáh³ mɨ³tiaah²ah¹ fi¹ ca̱³liáh³ ñá³ jñuú³ kilómetros ja̱³, mɨ²ja̱³ gá⁴joo⁴²ah¹ Jesús ja̱³ dsa³hɨɨ́y⁴ ñiíh² jmɨɨ³, hi³ mɨ³hí⁴dxaá² xi² dsa³hɨɨ́² maá² chiaa⁴²ah¹ ja̱³, hi³ja̱³ hi²xiáh³ gá⁴foh⁴²ah¹.
\v 20 Joó⁴ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―¡Jniá³ ba² la³, há⁴ hi³foh³²ah³ chiáh²!
\p 
\v 21 Mɨ²ja̱³ hi²xiáh³ jé⁴ dsɨ³²ah¹ gá⁴tiee⁴²ah¹ he̱é̱yh³ maá² Jesús ja̱³, mɨ²ja̱³ dɨ́h¹ lɨ² gá⁴lɨ́⁴ ba² mɨ³na³ta̱a̱⁴²ah¹ vó⁴ cuéh⁴ xi² dsa³dxia⁴²ah¹ ja̱³.
\s1 Cá⁴dah²naayh³² Jesús ja̱³ diáh⁴ dsa³
\p 
\v 22 Dxaáh² jmɨɨ́¹ liáh³ja̱³, mɨ³dɨ³nieeyh⁴² ca̱á̱h³ diáh⁴ hi³ cá⁴dah²eéh² hó² ya³dsɨ² mɨ³dxaá³ liáh³ja̱³. Cá⁴dah²joó² hi³ na³jniaa³ ca̱a̱³ maá² bɨh¹ ba² caa¹ dxaá² gaáy³ ja̱³. Baáy⁴ dɨ³ñi³² diáh⁴ hi³ há⁴hé³ ŋáyh² Jesús ja̱³ chie̱é̱yh¹ jniaah¹ liáh³ca̱á̱h³ gá⁴taah²ah¹ maá² ja̱³.
\v 23 Joó⁴ ja̱³ba² mɨ²ja̱³, cá⁴dxá⁴dxí̱⁴ dxeeyh⁴ dsa³ hi³ gá⁴voóy⁴ fɨɨ³ Tiberias, dɨ³tieéyh¹ diáh⁴ maá². Cá⁴dxá⁴dxí̱⁴ diáh⁴ dsa³ ja̱³ caa¹ xi² gá⁴liúy² Dios Jesús ja̱³ liáh³ gá⁴cuó³ cá⁴dah²eéh² diáh⁴ hi³ ñéy³ mil dsaá⁴ ja̱³.
\v 24 Liáh³ cá⁴dah²joó² diáh⁴ dsa³ hi³ mɨ³na³ta̱a̱y⁴ nɨɨ́⁴ hi³ há⁴hé³ máh⁴ xe̱y³ Jesús ja̱³ baáy⁴ há⁴hé³ xa̱³²ah¹ jniaah¹ diáh⁴ xɨh³chie̱y³² ja̱³, mɨ²ja̱³ gá⁴taáyh¹ diáh⁴ he̱é̱yh³ maá² ja̱³ duh³ gá⁴dxí̱⁴ fɨɨ³ Capernaúm hi³ dah²naayh³² Jesús ja̱³.
\s1 Jesús nɨ³ na³lɨ́y⁴ fáh⁴ji̱í̱h⁴ chiaa⁴²a²
\p 
\v 25 Liáh³ cá⁴dxá⁴dxí̱⁴ diáh⁴ dsa³ ja̱³ ca³jaa¹ dxaá² gaáy³ ja̱³, mɨ²ja̱³ gá⁴ji̱i̱h⁴ diáh⁴ Jesús ja̱³. Hi³ja̱³ cá⁴dah²ŋɨɨ́h⁴ juúh⁴, liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―Dsa³he⁴, ¿jlɨh² güéh²u³ la³?
\p 
\v 26 Joó⁴ mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Jmɨ́yh³he̱é̱yh³ hi³ hi²fooh¹á² niaá⁴ah³ la³. Hi³ fáh⁴ hi³ gá⁴chiéh³ah³ gá⁴lií² lɨ́⁴ chia̱á̱²ah³ ja̱³dxaá³, hi³ja̱³ ba² nɨ³ ga³naah⁴ah³ jniá³ nɨ³. Há⁴ja̱³ hi³ gá⁴joo⁴²ah³ hi³ xa³ gá⁴jmeéy⁴ hi³ dɨ́h¹ ca̱a̱³ fáh⁴lí³ nɨ³.
\v 27 Há⁴ hi³ta³ hi³hɨ³ah³ ti̱¹ chiáh² hi³ hi²cáh³ah³, chiaah¹ hí⁴ŋɨ́³ ba² hi³ nɨ³. Na³fáyh⁴ hi³jmee³ah³ he̱é̱yh³ hí⁴tɨ̱́⁴ah³ comida hi³ há⁴hé³ hí⁴dxa³, hi³ hí⁴cuó⁴ fáh⁴ji̱í̱h⁴ chia̱á̱²ah³ ba², duh³ há⁴hé³ máh⁴ hí⁴jú̱³ah³. Hi³nɨ³ nɨ³ hí⁴cuoó⁴ niaá⁴ah³ Ja̱á̱² Dsa³ nɨ³. Chiaah¹ hi³nɨ³ nɨ³ ma³tiéyh² guaa³ Ñúh³a² Dios nɨ³ hí⁴jmeé⁴.
\p 
\v 28 Mɨ²ja̱³ cá⁴dah²ŋɨɨ́h⁴ juúh⁴ Jesús ja̱³, liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―¿He² nɨ³ ga³jmee⁴ hi²jmee²ah¹ duh³ hi²jmee²ah¹ liáh³xɨ³ niaá⁴ Dios nɨ³?
\p 
\v 29 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Niaá⁴ Dios nɨ³ hi³ gua³taá³ah³ chiáh² hi³ gá⁴xɨ́y⁴ nɨ³.
\p 
\v 30 Hi³ja̱³ liáh³la³ cá⁴dah²sɨɨ́h⁴ ca̱á̱h³ Jesús ja̱³:
\p ―¿Xɨ² xa³ hi²jmeey³ hi²joo⁴²ah¹, duh³ hí⁴dsá⁴taá³ah¹ chiú̱h²u³? ¿He² nɨ³ hi²jmeey³ hi²joo⁴²ah¹ nɨ³?
\v 31 Cá⁴dah²eéh² diáh⁴ xa²yaa²a² ñú⁴uuh²a² comida hi³ xɨ̱ɨ̱y³ maná vó⁴ xi² cueh³chiu̱u̱³. Chiaah¹ liáh³la³ dsa³féh³ ñi² xi³ nɨ³: “Gá⁴cuó³ Dios nɨ³ hó² ya³dsɨ² hi³ gá⁴xiaá² yuuh¹ güii³, cá⁴dah²eéh².”
\p 
\v 32 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Jmɨ́yh³he̱é̱yh³ hi³ hi²fooh¹á² niaá⁴ah³ la³. Há⁴hí̱³ ñaá² Moisés ja̱³ gá⁴cuó³ hó² ya³dsɨ² hi³ cá⁴dah²eéh² diáh⁴ dsa³ ja̱³. Dia² chia̱á̱²á⁴ ba² ja̱³ ga³cuo⁴ jmɨ́yh³ hó² ya³dsɨ² hi³ je³ yuuh¹ güii³.
\v 33 Chiaah¹ hí̱³ba² hi³ cá⁴yá⁴xiaá² yuuh¹ güii³ nɨ³ na³lɨ́y⁴ hó² ya³dsɨ² hi³ ga³cuo⁴ Dios nɨ³, hi³ja̱³ hí⁴jooy³ hí⁴cuoó⁴ fáh⁴ji̱í̱h⁴ diáh⁴ dsa³ jmɨɨyh⁴²güii³.
\p 
\v 34 Mɨ²ja̱³ liáh³la³ cá⁴dah²sɨɨ́h⁴ Jesús ja̱³ liáh³ gá⁴féh³ liáh³ja̱³:
\p ―Ñuyh⁴, cuoo² jniaah¹ liáh⁴jɨ³ fɨɨy⁴ hó² ya³dsɨ² hi³nɨ³.
\p 
\v 35 Mɨ²ja̱³ gá⁴hí̱¹ Jesús ja̱³:
\p ―Jniá³ nɨ³ na³lɨ́⁴á⁴ hó² ya³dsɨ² hi³ hí⁴cuó⁴ fáh⁴ji̱í̱h⁴. Hi³ja̱³ xɨ³ xe̱y³ hí⁴ta̱a̱yh³ ñaá² chie̱é̱yh¹ jniá³, hi³hí̱³ há⁴hé³ máh⁴ hí⁴cue̱é̱h⁴. Hi³ hí⁴dsá⁴taáy³ chieéy⁴, hi³hí̱³ há⁴hé³ máh⁴ jlɨ́h³ jmɨɨ́¹ hí⁴lí³ dɨ́⁴hɨ̱́h² jmɨɨ³.
\v 36 Joó⁴ liáh³xɨ³ ma³foóh²á⁴ niaá⁴ah³ nɨ³, há⁴hé³ ca³gua³taá³ah³ gu³xɨ³ ba² ma³joo⁴²ah³ jniá³.
\v 37 Liáh⁴jɨy³ diáh⁴ hi³ ga³cuoy³² jniá³ Ñuyh⁴ nɨ³, ca³bi³dxí̱⁴ ba² mii⁴ diáh⁴. Baáy⁴ gu³xɨ³ ja̱y³ diáh⁴ hi³ ca³bi³dxí̱⁴ nɨ³ há⁴hé³ hi²ta̱a̱¹á² diáh⁴ ca³jaa¹.
\v 38 Chiaah¹ há⁴ja̱³ hi³ cá⁴yá⁴güɨ̱ɨ̱́y² yuuh¹ güii³ duh³ hi²jmeey⁴² liáh³xɨ³ ga³lɨ́³ dsɨy⁴ ñeéy⁴ nɨ³. Hi³ güé⁴á⁴ duh³ hi²jmeey⁴² liáh³xɨ³ ga³lɨ́³ dsɨ́² Ñúh³a² hi³ gá⁴xɨ́y⁴ jniá³ nɨ³ ba² nɨ³.
\v 39 Chiaah¹ liáh³la³ jmɨ́yh³ niaá⁴ Ñuyh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³, hi³ há⁴hé³ hí⁴tiuu⁴²á⁴ gu³xɨ³ ja̱y³ diáh⁴ hi³ ma³cuóy² jniá³ ñaá² nɨ³. Duh³ hi²bi³ji̱i̱h⁴²á⁴ diáh⁴ ca̱á̱h³, mɨ² mɨ³hí⁴hɨɨ́⁴ gɨh¹ ñi² jmɨɨyh⁴²güii³.
\v 40 Chiaah¹ jmɨ́yh³ niaá⁴ hi³ há⁴hé³ hí⁴dsá⁴yeéy⁴ liáh⁴jɨy³ diáh⁴ hi³ hí⁴dah²joóy² Ja̱á̱² nɨ³. Diáh⁴ hi³ dsá⁴taáy³ chiáh² hí⁴cuoó⁴ diáh⁴ fáh⁴ji̱í̱h⁴. Duh³ jniá³ hi²bi³ji̱i̱h⁴²á⁴ diáh⁴ ca̱á̱h³ mɨ² mɨ³hí⁴hɨɨ́⁴ ñi² jmɨɨyh⁴²güii³.
\p 
\v 41 Liáh³ cá⁴dah²nuú³ diáh⁴ israelitas hi³ gá⁴féh³ liáh³ja̱³ Jesús ja̱³, mɨ²ja̱³ cá⁴dah²laá⁴ mɨ³dah²liu⁴ mɨ³hee³² chiáh², chiaah¹ hi³ féh³ hi³ na³lɨ́y⁴ hó² ya³dsɨ² hi³ yá⁴xiaá² yuuh¹ güii³ ja̱³.
\v 42 Hi³ja̱³ liáh³la³ cá⁴dah²féh³:
\p ―¿Xɨ² há⁴hí̱³ Jesús, ja̱á̱² José nɨ³ la³? Cui̱i̱⁴²a² ba² xaá¹jmii³. ¿Jmiih⁴² ja̱³ hi³ ga³féh³ hi³ ma³ya³xiaá² yuuh¹ güii³?
\p 
\v 43 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Há⁴ máh⁴ hi³liú¹ah³ ñuú³ chiáh² hi³ ma³fáyh² nɨ³.
\v 44 Gu³xɨ³ hí̱³ há⁴hé³ hí⁴jooy³ hí⁴je³ chie̱é̱yh¹ jniá³ hi³ hí⁴lí³ dsɨ́² ñaá², chiaah¹ Ñuyh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³ ba² nɨ³ ca³bi³jay⁴ diáh⁴ dsa³ nɨ³. Duh³ jniá³ hi²bi³ji̱i̱h⁴²á⁴ diáh⁴ ca̱á̱h³ mɨ² mɨ³hí⁴hɨɨ́⁴ gɨh¹ ñi² jmɨɨyh⁴²güii³.
\v 45 Liáh³la³ dsa³heé² xi³ chiáh² diáh⁴ profetas: “Dios nɨ³ hí⁴heé⁴ liáh⁴jɨy³ diáh⁴ dsa³.” Hi³ja̱³ liáh⁴jɨy³ diáh⁴ hi³ ca³dah²nuu³ hi³ ga³féh³ Dios nɨ³, baáy⁴ liu³u²xɨ³ ga³lí̱y³ diáh⁴, diáh⁴ hi³hí̱³ hí⁴yá⁴dxí̱⁴ chie̱é̱yh¹ jniá³.
\p 
\v 46 ’Há⁴hé³ xe̱y³ jlɨ́h³ ma³joóy² Ñuyh⁴ nɨ³, ja̱y³ hi³ güéy⁴ xi² jey¹ Dios nɨ³ ba² nɨ³ ma³joóy².
\v 47 Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³. Hi³ ca³dsa³taáy³ chieéy⁴, hi³hí̱³ ca̱á̱h³ tiaah² ba² xe̱y³, há⁴hé³ máh⁴ hí⁴jú̱y³.
\v 48 Jniá³ nɨ³ na³lɨ́⁴á⁴ hó² ya³dsɨ² hi³ ga³cuo⁴ fáh⁴ji̱í̱h⁴ chiáh² diáh⁴ dsa³.
\v 49 Cá⁴dah²eéh² maná diáh⁴ xa²yaá¹ah³ ñú⁴uúh¹ah³ liáh³ cá⁴dah²guá³ vó⁴ xi² há⁴hé³ xa³fáh³ cáh³ti³², joó⁴ jú̱y⁴ diáh⁴ liáh³bií⁴ gu³xɨ³ ba² jmiih⁴.
\v 50 Joó⁴ hó² ya³dsɨ² hi³ ca³ya³xiaá² yuuh¹ güii³ hi³ ga³hoy⁴ jniá³ nɨ³, xɨ³ xe̱y³ hí⁴eéh² mɨ²ja̱³ há⁴hé³ máh⁴ hí⁴jú̱y³.
\v 51 Hí̱³ba² jniá³ nɨ³ na³lɨ́⁴á⁴ hó² ya³dsɨ² hi³ yá⁴xiaá² yuuh¹ güii³ hi³ hí⁴cuó⁴ fáh⁴ji̱í̱h⁴ chiáh² diáh⁴ dsa³. Ja̱³ba² xe̱y³ liáh³nɨ³ hi³ hí⁴eéh² hó² ya³dsɨ² nɨ³, há⁴hé³ máh⁴ hí⁴jú̱y³. Ja̱³ba² cuerpo chieéy⁴ nɨ³ ná⁴lɨ¹ hó² ya³dsɨ² hi³ hi²cuoy⁴² nɨ³. Hi²cuoy⁴² cuerpo chieéy⁴, duh³ hí⁴jooy³ hí⁴sa̱y³ dxú⁴ diáh⁴ dsa³ jmɨɨyh⁴²güii³.
\p 
\v 52 Mɨ²ja̱³ cá⁴dah²laá⁴ mɨ³dah²tɨ̱́³ dah²nɨɨ́y³ liáh³du³ca̱y⁴ diáh⁴ israelitas ja̱³, liáh³la³ dah²féh³:
\p ―¿Jmiih⁴² ja̱³ hí⁴jooy³ hí⁴cuoó⁴ jnia² cuerpo chiáh² hi²chia⁴²a² dsaá⁴ nɨ³?
\p 
\v 53 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³: Xɨ³ nɨ³ há⁴hé³ hi²cáh³ah³ cuerpo chiáh² Ja̱á̱² Dsa³ nɨ³, baáy⁴ há⁴hé³ hi²húh³ah³ jmɨ³háy¹, mɨ²ja̱³ há⁴hé³ jmɨ́yh³ na³ji̱í̱h⁴ah³.
\v 54 Joó⁴ hi³ hí⁴eéh² cuerpo chieéy⁴ baáy⁴ hí⁴hɨ̱́h² jmɨ³ha⁴²á² nɨ³, hi³hí̱³ jmɨ́yh³ mɨ³na³ji̱í̱yh⁴, mɨ²ja̱³ jniá³ hi²bi³ji̱i̱h⁴²á⁴ ca̱á̱h³ mɨ² mɨ³hí⁴hɨɨ́⁴ gɨh¹ ñi² jmɨɨyh⁴²güii³.
\v 55 Chiaah¹ jmɨ́yh³he̱é̱yh³ ba² comida nɨ³ cuerpo chieéy⁴ baáy⁴ jmɨ́yh³he̱é̱yh³ ba² hi³ dxú⁴ hi²húh³ah³ nɨ³ jmɨ³ha⁴²á².
\v 56 Hi³ja̱³ hi³ hí⁴eéh² cuerpo chieéy⁴ baáy⁴ hi³ hí⁴hɨ̱́h² jmɨ³ha⁴²á² nɨ³, hi³hí̱³ na³cu̱yh⁴ tiá¹ chie̱é̱yh¹ jniá³, baáy⁴ na³cu̱h⁴²á⁴ chia̱a̱h⁴²á² ñaá².
\v 57 Na³ji̱í̱yh⁴ Ñuyh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³, hi³ja̱³ ba² na³ji̱í̱h⁴á⁴ jniá³ vih²chiaah¹. Ba² liáh³ja̱³ xe̱y³ hi³ hí⁴cuyh³ jniá³, ba² hí⁴güe³ na³ji̱í̱yh⁴ vih²chieéy⁴.
\v 58 Hó² ya³dsɨ² hi³ gá⁴xiaá² yuuh¹ güii³ nɨ³ nɨ³ ga³hoy⁴. Há⁴ja̱³ liáh³xɨ³ maná hi³ cá⁴dah²eéh² diáh⁴ xa²yaá¹ah³ ñú⁴uúh¹ah³. Chiaah¹ jú̱y⁴ diáh⁴ liáh³bií⁴ gu³xɨ³ ba² cá⁴dah²eéh² hi³ ja̱³. Joó⁴ hi³ hí⁴eéh² hó² ya³dsɨ² hi³ ga³hoy⁴ jniá³ nɨ³, ca̱á̱h³ tiaah² ba² xe̱y³, há⁴hé³ máh⁴ hí⁴jú̱y³.
\p 
\v 59 Liáh³ gá⁴ŋɨɨyh⁴ diáh⁴ dsa³ ñuúh⁴guah³ liuh² Capernaúm ja̱³, mɨ²ja̱³ ja̱³ gá⁴liú³ Jesús ja̱³ ca³jaa¹ chiáh² hó² ya³dsɨ² ja̱³.
\s1 Diáh⁴ fáh⁴liu⁴ hi³ hí⁴cuó⁴ fáh⁴ji̱í̱h⁴ chiaa⁴²a²
\p 
\v 60 Liáh³ cá⁴dah²nuú³ liáh³xɨ³ féh³ Jesús ja̱³ diáh⁴ hi³ ta³nieéy¹ ja̱³, mɨ²ja̱³ liáh³la³ cá⁴dah²féh³:
\p ―Hi²xiáh³ fɨɨh⁴²caáh⁴ fáh⁴liu⁴ la³. ¿Hi̱²hí̱³ hí⁴jmeé⁴ he̱é̱yh³ chiáh²?
\p 
\v 61 Cá⁴lɨ́⁴chii⁴ ba² Jesús ja̱³ hi³ dah²liu⁴ lɨ² va² dah²hey³² ja̱³, hi³ja̱³ liáh³la³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―¿Xɨ² cɨ̱ɨ̱³²ah³ chiaah¹ hi³ ga³fooh³²á⁴ niaá⁴ah³ liáh³nɨ³?
\v 62 Jmiih⁴² nɨɨh¹ gɨh¹ hí⁴lí³ liu³u²xɨ³ hi²joo⁴ah³ dsa³saayh⁴ ca̱á̱h³ Ja̱á̱² Dsa³ nɨ³ xi² jey¹ mɨ² dsa³jéy⁴.
\v 63 Espíritu chié̱y² Dios nɨ³ ba² nɨ³ ga³cuo⁴ fáh⁴ji̱í̱h⁴ chiaa⁴²a² nɨ³. Há⁴hé³ chi̱í̱⁴ cáh³ti³² ŋu²a² nɨ³. Espíritu ba² nɨ³ ga³cuo⁴ fáh⁴liu⁴ hi³ ma³foóh²á⁴ niaá⁴ah³ nɨ³ baáy⁴ hí⁴jmeé⁴ hí⁴jooy³ hi²ñí³ah³ chia̱á̱h¹ah³ Dios.
\v 64 Joó⁴ xa̱³ah³ niaá⁴ah³ há⁴hé³ ca³gua³taá³ah³ hi³ ga³fayh⁴ nɨ³.
\p Chiaah¹ mɨ³ñi³² ba² mɨ² dsa³jéy⁴ Jesús ja̱³ hi̱² ga² hí̱³ diáh⁴ hi³ há⁴hé³ ca³dsa³taáy³ ja̱³, baáy⁴ mɨ³ñi³² ba² hi³ hi̱² na²nɨy¹ ja̱³ hí⁴nɨɨ́y⁴ xiáh³ rúh⁴cáh⁴ ja̱³.
\v 65 Hi³ja̱³ liáh³la³ gá⁴féh³:
\p ―Hi³ja̱³ nɨ³ ga³fooh³²á⁴ niaá⁴ah³ hi³ gu³xɨ³ hí̱³ há⁴hé³ hí⁴jooy³ dsá⁴taáy³ chieéy⁴ xɨ³ nɨ³ há⁴hí̱³ Ñuyh⁴ nɨ³ ma³bi³jmeéy³.
\p 
\v 66 Xé̱yh² ba² mɨ²ja̱³, hi²xiáh³ fɨɨ́y⁴ diáh⁴ hi³ ta³nieéy¹ xi² dsa³hɨɨ́y⁴ ja̱³ cá⁴dah²tiúy², há⁴hé³ máh⁴ dah²chie⁴ dah²ji̱i̱⁴ chie̱é̱yh¹.
\v 67 Mɨ²ja̱³ gá⁴ŋɨɨ́h⁴ jniaah¹ juúh⁴ Jesús ja̱³, liú⁴u³ dxiá⁴tiú̱³ah¹ diáh⁴ xɨh³chie̱y³² ja̱³, liáh³la³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―¿Xɨ³ ba² ji̱í̱⁴ niaá⁴ah³ dɨ²gua³dxi̱i̱³²ah³?
\p 
\v 68 Joó⁴ mɨ²ja̱³ liáh³la³ gá⁴féh³ Simón Pedro ja̱³:
\p ―Ñuyh⁴, ¿hi̱² chia̱a̱h²ah¹ ja̱³ dsa³dxia⁴²ah¹? Niu³ ba² nɨ³ ga³fooyh³² jniaah¹ jmiih⁴² hí⁴jooy³ hi²yaa²ah¹ na³ji̱í̱h⁴ah¹ liáh³nɨ³.
\v 69 Nia⁴²ah¹ ba² hi³ niu³ nɨ³ Cristo, Ja̱á̱² ñaá² Dios hi³ na³ji̱í̱yh⁴. Hi³ja̱³ nɨ³ ma³taá³ah¹ ba² jniaah¹ chiú̱h²u³.
\p 
\v 70 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Ma³dxɨ́²á⁴ ba² niaá⁴ah³ dxiá⁴tiú̱³ah³. Joó⁴ gu³xɨ³ ba² jmiih⁴ liáh³ja̱³, ja̱³ah³ niaá⁴ah³ nɨ³ na³lɨ́⁴ah³ hi³há⁴dxúy⁴.
\p 
\v 71 Judas Iscariote ja̱á̱² Simón ja̱³ ja̱³ ga³hey³² Jesús hi³ féh³ liáh³ja̱³. Chiaah¹ Judas ja̱³ ja̱³ hí⁴nɨɨ́y⁴ Jesús ja̱³ xiáh³ rúh⁴cáh⁴ gu³xɨ³ ba² na³lɨ́y⁴ ja̱y³ diáh⁴ hi³ dxiá⁴tiú̱³ah¹ ja̱³.
\c 7
\s1 Há⁴hé³ dɨ́⁴dsá⁴taáy³ diáh⁴ ja̱á̱¹ Jesús ja̱³ chiáh²
\p 
\v 1 Dsa³cɨ̱ɨ̱y³ liáh³ ma³liú³ Jesús ja̱³, mɨ²ja̱³ ŋaá² chie⁴ji̱i̱⁴ vó⁴ Galilea. Há⁴hé³ jmɨ́yh³ dɨ́⁴dsaá² vó⁴ Judea, chiaah¹ diáh⁴ israelitas ja̱³ dɨ³niaá⁴ hí⁴dah²jɨ̱́yh⁴.
\v 2 Ja̱³ba² mɨ³ya³chie̱y¹ jmɨ́¹feh⁴ chiáh² diáh⁴ mɨ¹láh¹ñú², ca̱a̱³ jmɨ́¹feh⁴ hi³ ca³dah²jmee⁴ diáh⁴ israelitas ja̱³.
\v 3 Hi³ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ ja̱á̱¹ ja̱³, cá⁴dah²sɨɨ́h⁴ Jesús:
\p ―Há⁴ hi³cueeh⁴u³ la³, má⁴dxií⁴ Judea nɨ³, duh³ ba² hí⁴dah²joó² diáh⁴ xɨh³chiú̱h²u³ hi³ nieeyh⁴² nɨ³ liáh³xɨ³ ga³jmeey³ nɨ³.
\v 4 Chiaah¹ liu³u²xɨ³ niaa³²a² hí⁴cui̱i̱⁴ jnia² diáh⁴ dsa³, mɨ²ja̱³ há⁴hé³ ga³jmee⁴ hi²jmee²a² na³ma² hi³la³ hi³nɨ³. Chiaah¹ ga³jmeey³ gɨh³ fáh⁴lí³ nɨ³, hi³ja̱³ jmee² jí̱⁴ñí³ ba² duh³ hí⁴cui̱i̱⁴ niu³ diáh⁴ dsa³ jmɨɨyh⁴²güii³.
\p 
\v 5 Chiaah¹ ba² há⁴hé³ ca³dsa³taáy³ diáh⁴ ja̱á̱¹ Jesús ja̱³ chiáh².
\v 6 Hi³ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Há⁴hé³ ma³dxa³héy³ hiíh⁴ chieéy⁴ jniá³, joó⁴ niaá⁴ah³ hí⁴jooy³ ba² cua³dxí̱⁴ah³ jlɨ́h³ ga³ji̱i̱³²ah³.
\v 7 Diáh⁴ dsa³ hi³ na³hiiy⁴ jmɨɨyh⁴²güii³ la³, há⁴hé³ dɨ³cɨ̱ɨ̱y³² ca³dah²ñi³² niaá⁴ah³ niaá⁴ah³. Joó⁴ jniá³ si¹ dɨ³cɨ̱ɨ̱y³² ca³dah²ñi³² chiaah¹ hi³ ga³fooh³²á⁴ diáh⁴ hi³ ca³dah²jmee⁴ mɨ³hee³² nɨ³.
\v 8 Cua³dxí̱⁴ah³ ba² chia̱á̱²ah³ jmɨ́¹feh⁴ nɨ³, há⁴hé³ ñii⁴ jniá³, chiaah¹ há⁴hé³ ma³dxa³héy³ hiíh⁴ chieéy⁴.
\p 
\v 9 Dsa³cɨ̱ɨ̱y³ liáh³ gá⁴sɨɨ́h⁴ diáh⁴ liáh³ja̱³, mɨ²ja̱³ gá⁴cueeyh⁴ gɨh¹ ca̱³ji̱i̱³ Jesús ja̱³ Galilea.
\s1 Ñií¹ liáh³bií⁴ Jesús ja̱³ jmɨ́¹feh⁴
\p 
\v 10 Dsa³cɨ̱ɨ̱y³ liáh³ ma³dxí̱⁴ diáh⁴ ja̱á̱¹ ja̱³, mɨ²ja̱³ ba² ŋaá² liáh³bií⁴ Jesús ja̱³ jmɨ́¹feh⁴, gu³xɨ³ ba² há⁴ja̱³ jmɨ́yh³ jí̱⁴ñí³. Há⁴ dsɨɨh⁴ na³ma² ba² ŋaá².
\v 11 Dah²naayh³² diáh⁴ israelitas ja̱³ jee⁴² jmɨ́¹feh⁴, liáh³la³ dah²féh³:
\p ―¿Xiah² chie⁴ji̱i̱⁴ Jesús nɨ³ dsa³juú¹ nɨ³?
\p 
\v 12 Hi²xiáh³ fɨɨ́y⁴ diáh⁴ dsa³ jee⁴² jmɨ́¹feh⁴ ja̱³ dah²liu⁴ ca³jaa¹ chiáh² Jesús ja̱³. Liáh³la³ dah²féh³ ta̱á̱²dsɨy⁴²: “Hi²xiáh³ dxú⁴ ga³jmee⁴ dsaá⁴ nɨ³.” Joó⁴ liáh³la³ ba² dah²féh³ dxeeyh⁴: “Há⁴hé³ dxúy⁴ hi³nɨy³², hi²xiáh³ ga³juuy³² diáh⁴ dsa³.”
\p 
\v 13 Joó⁴ gu³xɨ³ hí̱³ há⁴hé³ tiá³ dsɨ́² hí⁴liú⁴ jí̱⁴ñí³ ca³jaa¹ chiáh² Jesús ja̱³, chiaah¹ dɨ³foyh⁴ dah²jooy³² diáh⁴ israelitas hi³ na³ta̱a̱y⁴ ñi² ja̱³.
\p 
\v 14 Liáh³ ma³na³dxaah² jmɨ́¹feh⁴ ja̱³ mɨ²ja̱³ gá⁴dxaá² Jesús ja̱³ xi² jey¹ guah³ gaáy³, ja̱³ba² gá⁴laá⁴ mɨ³he⁴ fáh⁴liu⁴ chiáh² Dios.
\v 15 Hi²xiáh³ dah²dsaay³² dsɨ́² diáh⁴ israelitas ja̱³, hi³ja̱³ liáh³la³ dah²féh³:
\p ―¿Jmiih⁴² nɨ³ hi³ bií⁴ ñuú³ hi³ ñi³² dsa³ nɨ³, gu³xɨ³ ba² há⁴hé³ cá⁴bí⁴tɨ̱y⁴?
\p 
\v 16 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Há⁴ja̱³ hi³ chieéy⁴ ñeéy⁴ nɨ³ hi³ ga³hoy⁴ la³, hi³chiaah³² hi³ gá⁴xɨ́y⁴ jniá³ nɨ³ ba² nɨ³.
\v 17 Hi³ niaá⁴ hí⁴jmeé⁴ liáh³xɨ³ niaá⁴ Dios nɨ³, hi³hí̱³ hí⁴cá̱² cua̱a̱y¹ná² xɨ² hi³chiaah³² Dios ha²xɨ² hi³ chieéy⁴ ñeéy⁴ nɨ³ fáh⁴liu⁴ hi³ ga³liuy⁴ nɨ³.
\v 18 Diáh⁴ hi³ ca³dah²liu⁴ cua̱a̱y¹ná² chiáh² mii⁴ diáh⁴, ca³dah²naah³² jmiih⁴² hí⁴dsá⁴saa³ chiáh² mii⁴ diáh⁴ ba². Joó⁴ hi³ niaá⁴ hí⁴jmeéh⁴ gaáy³ hi³ gá⁴xɨ́y⁴ nɨ³, jmɨ́yh³ liáh³ xiaa³dsaa³² ba² ga³liu⁴, há⁴hé³ ga³juu³² cáh³ti³².
\p 
\v 19 ’¿Xɨ² há⁴hé³ gá⁴cueeyh³ chia̱á̱²ah³ Moisés ja̱³ ley chiáh²? Joó⁴ gu³xɨ³ hí̱³ niaá⁴ah³ há⁴hé³ ga³jmee³ah³ he̱é̱yh³ ley nɨ³. ¿He²chiaah¹ nɨ³ hi³ dɨ²jɨ̱́h⁴ah³ jniá³?
\p 
\v 20 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ dsa³ ja̱³:
\p ―Hi³há⁴dxúy⁴ ba² nɨ³ haá⁴u³ nɨ³, ¿hi̱² hí̱³ niaá⁴ dɨ́⁴jɨ̱́yh⁴ niu³?
\p 
\v 21 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴ dsa³ ja̱³:
\p ―Gá⁴jmeéy⁴ ca̱a̱³ hi³ dxú⁴ jmɨɨ́¹ mah², joó⁴ liáh⁴jɨ³ah³ ba² hi²xiáh³ dsaay³² há²ah³.
\v 22 Joó⁴ gá⁴chiaa³ Moisés nɨ³ costumbre chiáh² circuncisión. (Gu³xɨ³ ba² há⁴hí̱³ Moisés ja̱³ gá⁴laá⁴, diáh⁴ xa²yaa²ah¹ ñú⁴uuh²ah¹ ba² ja̱³ cá⁴dah²laá⁴.) Hi³ja̱³ nɨ³ ca³lɨ³reey⁴² la³he² diáh⁴ xɨ́⁴ñuu², baáy⁴ xa³ mɨ² jmɨɨ́¹ mah² ga³jmee³ah³ liáh³ja̱³ yáh¹.
\v 23 Xɨ³ nɨ³ ga³ree⁴²ah³ ca³liuh² chiáh² diáh⁴ dsa³ gu³xɨ³ ba² jmɨɨ́¹ mah² duh³ há⁴hé³ hí⁴ná⁴ah³ chiáh² ley nɨ³, ¿hi³ja̱³ he²chiaah¹ hi³ cɨ̱ɨ̱³²ah³ ga³joo⁴ah³ jniá³ hi³ cá⁴bí⁴liaá¹á⁴ dxú⁴ cáh³ti³² ja̱y³ dsa³ jmɨɨ́¹ mah² nɨ³?
\v 24 Há⁴ hi³ca̱a̱⁴ah³ cua̱a̱y¹ná² liáh³xɨ³ ga³ji̱i̱³²ah³ vo̱ó̱h²ah³, hi³ca̱a̱⁴ah³ cua̱a̱y¹ná² liáh³ xiaa³dsaa³² ba².
\s1 ¿Xɨ² hi³ley³² nɨ³ Cristo?
\p 
\v 25 Mɨ²ja̱³ ta̱á̱²dsɨy⁴² diáh⁴ hi³ dɨ³nieeyh⁴² Jerusalén ja̱³ cá⁴dah²laá⁴ mɨ³dah²ŋɨɨ́h⁴ juúh⁴, liáh³la³ dah²féh³:
\p ―¿Xɨ² há⁴hí̱³ hi³nɨy³² nɨ³ hi³ dah²naayh³² hi³ hí⁴dah²jɨ̱́yh⁴ nɨ³?
\v 26 Hi³ hiíy⁴ nɨ³, liu⁴ rúh⁴ñi² diáh⁴ dsa³ nɨ³, baáy⁴ há⁴hé³ xe̱y³ sɨɨ́h⁴ cáh³ti³². ¿Ha²xɨ² foóh¹ ma³dah²ca̱⁴ cua̱a̱y¹ná² diáh⁴ autoridad nɨ³ hi³ hi³nɨy³² nɨ³ Cristo?
\v 27 Joó⁴ nia⁴²a² ba² jnia² hi̱² dsa³ nɨ³ hi³nɨy³². Joó⁴ mɨ² mɨ³hí⁴güéy³ Cristo nɨ³, gu³xɨ³ hí̱³ há⁴hé³ ñi³² xiáh³ ja̱³ hí⁴güéy³.
\p 
\v 28 Liáh³ gá⁴nuú³ Jesús ja̱³ liáh³xɨ³ dah²féh³ ja̱³, mɨ²ja̱³ gá⁴liú³ chiu̱u̱³ cáh³ti³² liáh³la³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Ga³fáh³ah³ hi³ cui̱i̱⁴ah³ ba² jniá³, baáy⁴ maá³ah³ ba² xiáh³ nɨ³ ma³güe⁴²á⁴. Joó⁴ há⁴ja̱³ cua̱a̱y¹ná² chieéy⁴ ñeéy⁴ nɨ³ güé⁴á⁴ nɨ³. Güé⁴á⁴ chiaah¹ ja̱y³ hi³ bií⁴ xiaa³dsaay³² ba² nɨ³ gá⁴xɨ́y⁴ jniá³, ja̱y³ hi³ há⁴hé³ cui̱i̱⁴ah³ niaá⁴ah³.
\v 29 Joó⁴ cui̱i̱⁴²á⁴ jniá³, chiaah¹ xi² jey¹ hi³nɨy³² nɨ³ cá⁴bí⁴hɨɨ́⁴á⁴ liáh³ gá⁴xɨ́y⁴ jniá³ la³.
\p 
\v 30 Liáh³ gá⁴féh³ liáh³ja̱³ Jesús ja̱³, mɨ²ja̱³ mɨ³dɨ³niaá⁴ hí⁴dah²jéy⁴ preso. Joó⁴ gu³xɨ³ ja̱y³ há⁴hé³ lɨ́⁴tiá³ dsɨ́² gá⁴sa̱yh³², chiaah¹ há⁴hé³ ma³dxa³héy³ hiíh⁴ chiáh².
\v 31 Joó⁴ hi²xiáh³ fɨɨ́y⁴ dsa³ gá⁴taáy³ chiáh², hi³ja̱³ liáh³la³ cá⁴dah²féh³:
\p ―¿Mɨ² ma³güey⁴ Cristo nɨ³, xɨ² ga³ji̱i̱³²ah³ hí⁴jmeé⁴ gɨh¹ ñuú³ fáh⁴lí³ liáh³xɨ³ dsaá⁴ la³?
\s1 Cá⁴dxá⁴dxí̱⁴ diáh⁴ policías duh³ hí⁴dah²güeéyh² Jesús
\p 
\v 32 Cá⁴dah²nuú³ diáh⁴ fariseos ja̱³ liáh³xɨ³ dah²jmee⁴ juúh⁴ diáh⁴ dsa³ chiáh² Jesús ja̱³. Hi³ja̱³ diáh⁴ fariseos chie̱é̱yh¹ diáh⁴ jmii³dsa³ ja̱³ cá⁴dah²xɨ́y⁴ diáh⁴ policías hi³ hí⁴dsá⁴jey³ diáh⁴ Jesús ja̱³ duh³ hí⁴dah²ta̱a̱yh³ ñuúh⁴ñí¹.
\v 33 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Ca̱³ji̱i̱³ ba² nɨ³ hi²güey⁴² chia̱a̱h⁴²á² niaá⁴ah³, dsa³cɨ̱ɨ̱y³ ñeh³²á⁴ ca̱á̱h³ xi² jey¹ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³.
\v 34 Hi²naah⁴ah³ jniá³ joó⁴ há⁴hé³ máh⁴ hí⁴dxaah⁴ah³ jniá³, chiaah¹ há⁴hé³ hí⁴jooy³ cua³dxi̱i̱³²ah³ niaá⁴ah³ xi² ya³güéy⁴ jniá³ nɨ³.
\p 
\v 35 Mɨ²ja̱³ cá⁴dah²laá⁴ diáh⁴ israelitas ja̱³ mɨ³dah²liu⁴ xi² dɨ³ñi³² mii⁴, liáh³la³ dah²féh³:
\p ―¿Xiah² ja̱³ ga³he⁴ dsayh³² hi³ ga³féh³ há⁴hé³ máh⁴ hí⁴dxaah⁴²a² dsa³cɨ̱ɨ̱y³? ¿Xɨ² foóh¹ dsaa³² xi² nieeyh⁴² diáh⁴ oóh²a² hi³ nieeyh⁴² jee⁴² chiáh² diáh⁴ griegos nɨ³, duh³ hí⁴heé⁴ diáh⁴ griegos?
\v 36 ¿Jmiih⁴² nɨ³ ga³he⁴ hi³ ga³sɨɨ́h⁴ jnia²: “Hi²naah⁴ah³ jniá³ joó⁴ há⁴hé³ máh⁴ hí⁴dxaah⁴ah³ jniá³, chiaah¹ há⁴hé³ hí⁴jooy³ cua³dxi̱i̱³²ah³ niaá⁴ah³ xi² ya³güéy⁴ jniá³ nɨ³”?
\s1 Jmɨɨ³ hi³ hí⁴cuó⁴ fáh⁴ji̱í̱h⁴ chiaa⁴²a²
\p 
\v 37 Jmɨɨ́¹ hi³ gá⁴hɨɨ́³ gɨh¹ ñi² ja̱³, hi²xiáh³ gaáy³ gɨh¹ jmɨ́¹feh⁴ ja̱³ ga³lɨ́³. Mɨ²ja̱³ gá⁴bɨ́y² Jesús ja̱³ duh³ gá⁴liú³ chiu̱u̱³ cáh³ti³², liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ diáh⁴ dsa³ ja̱³:
\p ―Xɨ³ xe̱y³ hi³ dɨ́⁴hɨ̱́h² jmɨɨ³, gua²je³ la³ duh³ hi²cuoó⁴á⁴ jmɨɨ³ hí⁴hɨ̱́h².
\v 38 Ja̱³ba² liáh³xɨ³ dsa³féh³ xi³ chiáh² Dios nɨ³, xɨ³ xe̱y³ hí⁴dsá⁴taáy³ chieéy⁴, mɨ²ja̱³ cua̱a̱y¹ná² gaáy³ dɨ́h¹ dxú⁴ hí⁴lí³ chiáh², xɨ³ ba² hi³ yá³ jmɨɨ³ gaáy³ ba² fáh⁴ji̱í̱h⁴ chiáh², jmɨɨ³ hi³ ga³cuo⁴ fáh⁴ji̱í̱h⁴ chiaa⁴²a² nɨ³.
\p 
\v 39 Liáh³ja̱³ gá⁴féh³ Jesús ja̱³, hi³ hey³² Espíritu Santo hi³ hí⁴tɨ̱́y⁴ diáh⁴ hi³ hí⁴dsá⁴taáy³ chiáh² ja̱³. Joó⁴ há⁴hé³ ma³tɨ́³ ma³güe⁴ Espíritu mɨ²ja̱³, chiaah¹ há⁴hé³ ma³tɨ́³ ma³saayh⁴ ca̱á̱h³ Jesús ja̱³ yuuh¹ güii³.
\s1 Gá⁴dsaáy³ diáh⁴ dsa³ ja̱³
\p 
\v 40 Liáh³ cá⁴dah²nuú³ diáh⁴ dsa³ ja̱³ liáh³xɨ³ gá⁴féh³ Jesús ja̱³, mɨ²ja̱³ cá⁴dah²féh³ ta̱á̱²dsɨy⁴² diáh⁴:
\p ―Hi³ley³² nɨ³ jmɨ́yh³ profeta hi³ ná⁴lɨ¹ cua̱a̱y¹ná² hí⁴güéy³ nɨ³.
\p 
\v 41 Baáy⁴ liáh³la³ dah²féh³ dxeeyh⁴:
\p ―Hi³ley³² nɨ³ jmɨ́yh³ Cristo.
\p Joó⁴ liáh³la³ ba² cá⁴dah²féh³ dxeeyh⁴:
\p ―¿Jmiih⁴² ja̱³ hí⁴jooy³ hí⁴lí³ Cristo ja̱y³ dsa³ Galilea?
\v 42 Dxaa⁴² David ba² nɨ³ hí⁴lí³ Cristo dsa³féh³ xi³ chiáh² Dios nɨ³. Baáy⁴ fɨɨ³ Belén xi² gá⁴guá³ David ba² nɨ³ hí⁴sa̱y³.
\p 
\v 43 Hi³ja̱³ mɨ²ja̱³ gá⁴dsaáy³ diáh⁴ dsa³ ja̱³ vih²chiaah¹ Jesús.
\v 44 Ta̱á̱²dsɨy⁴² dɨ³niaá⁴ hí⁴dah²jéy⁴ preso, joó⁴ gu³xɨ³ hí̱³ há⁴hé³ lɨ́⁴tiá³ dsɨ́² gá⁴sa̱yh³².
\s1 Hi²xiáh³ ba³ dsɨ́² diáh⁴ autoridad ja̱³
\p 
\v 45 Liáh³ cá⁴dxá⁴dxi̱i̱³² diáh⁴ policías xi² nieeyh⁴² diáh⁴ fariseos chie̱é̱yh¹ diáh⁴ jmii³dsa³ ja̱³, mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ fariseos ja̱³ cá⁴dah²sɨɨ́h⁴ diáh⁴ policías ja̱³:
\p ―¿He²chiaah¹ hi³ há⁴hé³ ma³jé⁴ah³ nɨ³?
\p 
\v 46 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ policías ja̱³:
\p ―¡Gu³xɨ³ hí̱³ há⁴hé³ ga³liu⁴ liáh³xɨ³ liu⁴ dsaá⁴ nɨ³!
\p 
\v 47 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ fariseos ja̱³:
\p ―¿Xɨ² ji̱í̱⁴ niaá⁴ah³ ma³cuó¹ah³ je² ma³juúy² niaá⁴ah³?
\v 48 ¿Xɨ² foóh¹ xe̱y³ diáh⁴ hi³ na³ta̱a̱y⁴ ñi² chiaa⁴²a² nɨ³, hu̱² gɨh³ diáh⁴ fariseos nɨ³ hi³ ma³taáy³ chiáh²?
\v 49 Joó⁴ diáh⁴ dsa³ hi³ há⁴hé³ dɨ³cui̱i̱³ ley chiaa⁴²a² ba² nɨ³, xiáh³ ja̱³ dɨ́h¹ niaáh² diáh⁴ hi³nɨy³².
\p 
\v 50 Ba² caayh³² jee⁴² chiáh² diáh⁴ ja̱³ Nicodemo hi³ ñií¹ ya²ñi³ Jesús ja̱³ ca̱a̱³ mɨ² xiáh³liaá⁴, hi³ja̱³ liáh³la³ gá⁴féh³:
\p 
\v 51 ―Dsa³féh³ ley chiaa⁴²a² nɨ³ hi³ há⁴hé³ ga³jmee⁴ hi²tiaah¹a² ta² hí⁴jú̱y³ ja̱y³ dsa³ xɨ³ nɨ³ há⁴hé³ ma³niuu²a² ma³liú³ duh³ hí⁴dsaá⁴ dsɨ³²a² hi³ ma³jmeé³.
\p 
\v 52 Mɨ²ja̱³ cá⁴dah²hí̱¹, liáh³la³ cá⁴dah²sɨɨ́h⁴ Nicodemo ja̱³:
\p ―¿Xɨ² ba² dsa³ Galilea nɨ³ niu³? Hi³joóy³ xi³ chiáh² Dios nɨ³ duh³ hí⁴dsaá⁴ háy² hi³ gu³xɨ³ ja̱y³ profeta há⁴hé³ ma³sa̱y³ Galilea nɨ³.
\s1 Ja̱y³ mɨ́³ gá⁴jmeé³ ga̱y³
\p 
\v 53 Ja̱³ba² gá⁴dxi̱i̱³² xɨ¹ñúh⁴ chiáh² liáh³ja̱y³ liáh³ja̱y³ diáh⁴ bɨh¹ ba².
\c 8
\p 
\v 1 Joó⁴ mɨ²ja̱³ ŋaá² Jesús ja̱³ cua̱h³ hi³ xɨ̱ɨ̱y³ Olivos.
\v 2 Liáh³ mɨ³dse³jnia³ dxaáh² jmɨɨ́¹ liáh³ja̱³, mɨ²ja̱³ ŋaá² ca̱á̱h³ xi² jey¹ guah³ gaáy³ ja̱³, ja̱³ba² cá⁴dxá⁴jé̱yh⁴ liáh⁴jɨy³ diáh⁴ dsa³ ja̱³ xi² hiíy⁴. Mɨ²ja̱³ gá⁴guá³ duh³ gá⁴laá⁴ mɨ³heé⁴ diáh⁴ fah² Dios.
\v 3 Mɨ²ja̱³ cá⁴dxá⁴dxí̱⁴ diáh⁴ dsa³he⁴ chiáh² ley chie̱é̱yh¹ diáh⁴ fariseos xi² jey¹ Jesús ja̱³, dɨ³jey⁴ ja̱y³ mɨ́³ hi³ ma³lɨ³jnieéy² jmee⁴ ga̱y³. Mɨ²ja̱³ cá⁴dah²xɨ́yh⁴ jee⁴² chiáh² diáh⁴ dsa³ ja̱³,
\v 4 duh³ liáh³la³ cá⁴dah²sɨɨ́h⁴ Jesús ja̱³:
\p ―Dsa³he⁴, ma³jaáy³ diáh⁴ mɨ́³ la³ liáh³ca̱á̱h³ jmɨ́yh³ na³caayh³² jmee⁴ ga̱y³ chie̱é̱yh¹ dsaá⁴.
\v 5 Ley hi³ gá⁴cueeyh³ Moisés nɨ³, dsa³féh³ hi³ ga³jmee⁴ hi²jɨ̱h⁴²ah¹ chie̱é̱yh¹ na¹cu̱ú̱¹ diáh⁴ mɨ́³ hi³ ca³dah²jmee⁴ liáh³nɨ³. ¿Hi³ja̱³ jmiih⁴² gɨh³ ga³fáyh³ niu³?
\p 
\v 6 Hi³ dah²ya³dsaa³ hiíh⁴ jmiih⁴² hí⁴féh³ Jesús ja̱³, hi³ja̱³ ba² ja̱³ cá⁴dah²féh³ liáh³ja̱³, duh³ hu̱² hí⁴jooy³ hí⁴dah²cuó⁴ dsaa² chiáh². Mɨ²ja̱³ gá⁴jmeé³ na³hi³² Jesús ja̱³ duh³ gá⁴laá⁴ mɨ³xɨɨ⁴ dxaah¹vó⁴ chie̱é̱yh¹ xɨh¹guaa³.
\v 7 Joó⁴ dah²ŋɨɨ́h⁴ chiáh² juúh⁴ liáh³ja̱³ hi³ja̱³ gá⁴naayh⁴ ca̱á̱h³ dsaá² duh³ liáh³la³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Liáh³ja̱³ xa³ja̱³, joó⁴ ja̱³ah³ niaá⁴ah³ hi³ há⁴hé³ xa³ cáh³ti³² dsaa² chiáh², gua²tia̱á̱³ hi³dxá³ ca̱a̱³ na¹cu̱ú̱¹ gua²chiúyh² mɨ́³ nɨ³.
\p 
\v 8 Mɨ²ja̱³ gá⁴jmeé³ ca̱á̱h³ na³hi³² Jesús ja̱³, gá⁴laá⁴ mɨ³xɨɨ⁴ ca̱á̱h³ dxaah¹vó⁴ ja̱³.
\v 9 Joó⁴ liáh³ cá⁴dah²nuú³ diáh⁴ fariseos ja̱³ liáh³xɨ³ gá⁴féh³ Jesús ja̱³, mɨ²ja̱³ cá⁴lɨ́⁴hiih⁴ diáh⁴ chiaah¹ dɨ³ñi³² ba² mii⁴ hi³ xa³ dsaa² chiáh² diáh⁴. Hi³ja̱³ cá⁴dah²laá⁴ mɨ³dsa³voóy⁴ gɨh¹ máh⁴ ja̱y³ diáh⁴ liáh³ja̱³. Diáh⁴ du³dsaáy⁴ cá⁴dah²laá⁴ mɨ³dsa³voóy⁴ dsa³jéy⁴, dsa³cɨ̱ɨ̱y³ liáh³ja̱³ diáh⁴ mɨ¹liuh². Liáh³ ma³voóy⁴ liáh⁴jɨy³ diáh⁴ ja̱³, mɨ²ja̱³ gá⁴cueeyh⁴ ñaá² bɨh¹ Jesús ja̱³ chie̱é̱yh¹ mɨ́³ ja̱³.
\v 10 Liáh³ gá⁴joó² Jesús ja̱³ hi³ há⁴hé³ máh⁴ xe̱y³ dxeeyh⁴ dsa³ nɨɨ́⁴, ti̱¹ mɨ́³ ja̱³ bɨh¹, mɨ²ja̱³ liáh³la³ gá⁴sɨɨ́h⁴ mɨ́³ ja̱³:
\p ―Mɨ́³, ¿nɨy¹ diáh⁴ dsa³ hi³ dah²cuo⁴ dsaa² chiú̱h²u³ nɨ³? ¿Xɨ² há⁴hé³ máh⁴ xe̱y³ la³ diáh⁴ hi³ dɨ́⁴dah²jɨ̱́yh⁴ niu³ nɨ³?
\p 
\v 11 Mɨ²ja̱³ liáh³la³ gá⁴féh³ mɨ́³ ja̱³:
\p ―Haá² Ñuyh⁴, há⁴hé³ máh⁴ xe̱y³ gu³xɨ³ ja̱y³ diáh⁴.
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Ba² há⁴hé³ xa³ hi²jmeéh⁴á⁴ niu³ jniá³. Má⁴dxi², joó⁴ há⁴ máh⁴ hi³jmeey³ ca̱á̱h³ ba².
\s1 Jesús nɨ³ na³lɨ́y⁴ ya⁴²jmɨɨ́⁴
\p 
\v 12 Mɨ²ja̱³ gá⁴laá⁴ ca̱á̱h³ Jesús ja̱³ mɨ³liuy³² diáh⁴ dsa³ ja̱³, liáh³la³ sɨɨ́h⁴ diáh⁴:
\p ―Jniá³ nɨ³ na³lɨ́⁴á⁴ ya⁴²jmɨɨ́⁴ chiáh² diáh⁴ dsa³ jmɨɨyh⁴²güii³, hi³ja̱³ liu³u²xɨ³ xe̱y³ hí⁴ta̱a̱yh³ ñaá² chie̱é̱yh¹ jniá³, hi³hí̱³ hí⁴sa³ ya⁴²jmɨɨ́⁴ fáh⁴ji̱í̱h⁴ chiáh², há⁴hé³ máh⁴ hí⁴chié⁴ hí⁴ji̱í̱⁴ xi³ ñu³ha̱a̱h³.
\p 
\v 13 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ fariseos ja̱³ cá⁴dah²sɨɨ́h⁴ Jesús ja̱³:
\p ―Ca³jaa¹ chiú̱h²u³ vo̱ó̱h²u³ ba² nɨ³ ga³liúy¹ nɨ³, hi³ja̱³ há⁴hé³ hí⁴jmeé⁴ ta² hi³ ga³liúy¹ nɨ³.
\p 
\v 14 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Gu³xɨ³ ba² ga³liuy⁴ ca³jaa¹ chieéy⁴ ñeéy⁴, joó⁴ hí⁴jmeé⁴ ba² ta² chiaah¹ maay⁴ ba² xiah² nɨ³ cá⁴bí⁴hɨɨ́⁴á⁴, baáy⁴ maay⁴ ba² xiah² nɨ³ ñeh³²á⁴ ca̱á̱h³. Joó⁴ há⁴hé³ maá³ah³ niaá⁴ah³ xiah² nɨ³ cá⁴bí⁴hɨɨ́⁴á⁴ baáy⁴ xiah² nɨ³ ñeh³²á⁴ ca̱á̱h³.
\v 15 Niaá⁴ah³ ga³ca̱a̱⁴ah³ cua̱a̱y¹ná² liáh³xɨ³ ga³ji̱i̱³²ah³ vo̱ó̱h²ah³ ba². Joó⁴ jniá³ há⁴hé³ xe̱y³ ga³ca̱a̱y³² cua̱a̱y¹ná² chiáh².
\v 16 Joó⁴ liu³u²xɨ³ hi²ca̱a̱y¹ cua̱a̱y¹ná² chiáh² diáh⁴ dsa³, mɨ²ja̱³ liáh³ xiaa³dsaa³² cáh³ti³² ba² hi²jmeey⁴². Chiaah¹ há⁴ja̱³ ñeéy⁴ nɨ³, na³cu̱h⁴²á⁴ ba² chia̱a̱h⁴²á² Ñuyh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³.
\v 17 Dsa³heé² ley chia̱á̱²ah³ nɨ³ hi³ liu³u²xɨ³ aáy⁴ dsa³ñi³² dah²féh³ ree³, mɨ²ja̱³ ná⁴lɨ¹ xiaa³dsaa³².
\v 18 Ba² liáh³ja̱³ xa̱⁴²á⁴ jniá³. Hí̱³ba² ñeéy⁴ nɨ³ na³lɨ́⁴á⁴ hi³dxá³ ja̱y³ dsa³ñi³² chieéy⁴, baáy⁴ Ñuyh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³ na³lɨ́y⁴ hi³dxá³ aáy⁴ dsa³ñi³² chieéy⁴.
\p 
\v 19 Mɨ²ja̱³ cá⁴dah²ŋɨɨ́h⁴ juúh⁴ Jesús ja̱³, liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―¿Xiah² nɨ³ jey¹ dia² chiú̱h²u³ nɨ³?
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Há⁴hé³ cui̱i̱⁴ah³ jniá³, hi³ja̱³ ba² há⁴hé³ cui̱i̱⁴ah³ Ñuyh⁴ nɨ³. Joó⁴ hu̱² hí⁴cui̱i̱⁴ah³ jniá³, mɨ²ja̱³ ba² hí⁴cui̱i̱⁴ah³ Ñuyh⁴ nɨ³ hu̱² liáh³ja̱³.
\p 
\v 20 Liáh³ he⁴ fah² Dios xi² jey¹ guah³ gaáy³ ja̱³, mɨ²ja̱³ ja̱³ gá⁴féh³ liáh³ja̱³ Jesús ja̱³, caa¹ xi² na³jniaa³ guaá² hi³ ca³dah²taah⁴ foo³ diáh⁴ dsa³. Joó⁴ gu³xɨ³ hí̱³ há⁴hé³ gá⁴caáyh² chiaah¹ há⁴hé³ ma³dxa³héy³ hiíh⁴ chiáh².
\s1 Yuuh¹ güii³ ba² jmɨ́yh³ na³hiiy⁴ Jesús
\p 
\v 21 Mɨ²ja̱³ liáh³la³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Hí⁴dxá⁴héy³ ñeh³²á⁴ jniá³, mɨ²ja̱³ hi²naah⁴ah³ jniá³, joó⁴ xa³ liáh³nɨ³ dsaa² chia̱á̱²ah³ hí⁴jú̱³ah³. Hi³ja̱³ há⁴hé³ hí⁴jooy³ cua³dxi̱i̱³²ah³ niaá⁴ah³ xi² ñeh³²á⁴ jniá³ nɨ³.
\p 
\v 22 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³:
\p ―¿Xɨ² foóh¹ hí⁴jɨ̱́yh⁴ ñaá² hi³ja̱³ nɨ³ ga³féh³ hi³ há⁴hé³ hí⁴jooy³ dsa³dxii²a² xi² dsayh³² nɨ³?
\p 
\v 23 Mɨ²ja̱³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Xiáh³chia̱³² la³ ba² na³hii⁴ah³ niaá⁴ah³, joó⁴ yuuh¹ nɨ³ ba² na³hii⁴²á⁴ jniá³. Jmɨɨyh⁴²güii³ la³ ba² na³hii⁴ah³ niaá⁴ah³, joó⁴ há⁴ja̱³ la³ na³hii⁴²á⁴ jniá³.
\v 24 Hi³ja̱³ nɨ³ ma³foóh²á⁴ niaá⁴ah³ hi³ xa³ liáh³nɨ³ dsaa² chia̱á̱²ah³ hí⁴jú̱³ah³, chiaah¹ xɨ³ nɨ³ há⁴hé³ dsá⁴taá³ah³ hi³ xa³ na³lɨ́⁴á⁴, mɨ²ja̱³ hí⁴jú̱³ah³ xa³ liáh³nɨ³ dsaa² chia̱á̱²ah³.
\p 
\v 25 Mɨ²ja̱³ cá⁴dah²ŋɨɨ́h⁴ juúh⁴:
\p ―¿He² nɨ³ na³lɨ́⁴u³ ruh³?
\p Mɨ²ja̱³ gá⁴hí̱¹ Jesús ja̱³, liáh³la³ gá⁴féh³:
\p ―Gá⁴foóh²á⁴ ba² niaá⁴ah³ dsa³jéy⁴ lɨ́⁴.
\v 26 Hi²xiáh³ xa³ hi³ hi²fooh¹á² niaá⁴ah³ baáy⁴ há⁴ja̱³ ca̱a̱³ nɨ³ hi³ hi²ca̱a̱y¹ cua̱a̱y¹ná² chia̱á̱²ah³ hu̱² liáh³ja̱³. Joó⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³ hi²xiáh³ xiaa³dsaay³². Hi³ja̱³ liáh³xɨ³ ga³nuuy⁴ ga³féh³ ba² nɨ³ ga³fooh³²á⁴ diáh⁴ dsa³ nɨ³.
\p 
\v 27 Joó⁴ há⁴hé³ cá⁴lɨ́⁴dsaay⁴ diáh⁴ dsa³ ja̱³ hi³ liu⁴ ca³jaa¹ chiáh² Jmii³ ja̱³.
\v 28 Hi³ja̱³ liáh³la³ gá⁴sɨɨ́h⁴ diáh⁴ ca̱á̱h³:
\p ―Liu³u²xɨ³ mɨ² ma³xaa⁴²ah³ ñií² Ja̱á̱² Dsa³ nɨ³, mɨ²ja̱³ gɨh¹ hí⁴dsaa⁴ah³ há²ah³ jmɨ́yh³ hi³ na³lɨ́⁴á⁴, baáy⁴ hí⁴dsaá⁴ há²ah³ hi³ há⁴hé³ xa³ cáh³ti³² jmeey⁴ liáh³xɨ³ ga³ji̱í̱y⁴ ñeéy⁴. Jmáyh² hi³ ga³heé⁴ jniá³ Ñuyh⁴ nɨ³ ba² nɨ³ ga³liuy⁴.
\v 29 Chiaah¹ na³cu̱yh⁴ chie̱é̱yh¹ jniá³ liáh³nɨ³ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³, há⁴hé³ jlɨ́h³ ma³tiúy² jniá³ ñeéy⁴ Ñuyh⁴ nɨ³. Chiaah¹ ca̱³ñiih³² ba² ga³jmeey⁴ liáh³xɨ³ gá⁴lɨ́⁴ dsɨ́².
\p 
\v 30 Liáh³ gá⁴féh³ liáh³ja̱³ Jesús ja̱³ mɨ²ja̱³ hi²xiáh³ fɨɨ́y⁴ gá⁴taáy³ chiáh².
\s1 Hi³ xiaa³dsaa³² nɨ³, hí⁴jmeé⁴ hí⁴tú²a²
\p 
\v 31 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴ israelitas hi³ ma³taáy³ chiáh² ja̱³:
\p ―Liu³u²xɨ³ hi²ñí³ah³ xiaa³dsaa³² baáy⁴ hi²jmee³ah³ jɨɨ⁴ liáh³xɨ³ ga³fayh⁴ nɨ³, mɨ²ja̱³ lii⁴ hi³ he̱é̱yh³ ba² mɨ³na³lɨ́⁴ah³ xɨh³chia̱á̱²á⁴.
\v 32 Ba² hí⁴cui̱i̱³ah³ liáh⁴jɨ³ hi³ xiaa³dsaa³², baáy⁴ hi³ xiaa³dsaa³² nɨ³ hí⁴lieéy² niaá⁴ah³.
\p 
\v 33 Mɨ²ja̱³ cá⁴dah²hí̱¹ diáh⁴ israelitas ja̱³, liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―Ja̱á̱² dxaa⁴² Abraham ba² jniaah¹, hi³ja̱³ há⁴hé³ jlɨ́h³ ma³táh²ah¹ chiáh² dsa³. ¿Jmiih⁴² nɨ³ hi³ ga³fáyh³ hi³ hí⁴liaá³ah¹ nɨ³?
\p 
\v 34 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³: Liáh⁴jɨy³ ba² diáh⁴ hi³ ca³dah²jmee⁴ mɨ³hee³² nɨ³ ná⁴tayh¹ diáh⁴ cáh³ti³² chiáh² hi³ mɨ³hee³².
\v 35 Ja̱y³ hi³ ná⁴tayh¹ chiáh² ja̱y³ dsa³, xɨ²fáh³ na³lɨ́y⁴ cua̱a̱y¹ná² jee⁴² chiáh² diáh⁴ familia. Joó⁴ ja̱á̱² fii² ja̱³ si¹ na³lɨ́y⁴ cua̱a̱y¹ná² jee⁴² chiáh² diáh⁴ familia chié̱y².
\v 36 Hi³ja̱³ liu³u²xɨ³ Ja̱á̱² Dios nɨ³ hí⁴lieéy² niaá⁴ah³ chiáh² hi³ mɨ³hee³², mɨ²ja̱³ jmɨ́yh³ ca̱á̱h³ tiaah² ba² hí⁴tú²ah³ cáh³ti³².
\v 37 Mɨ³maay⁴ ba² hi³ na³lɨ́⁴ah³ familia chié̱y² Abraham, joó⁴ naa³ah³ dɨ²jɨ̱́h⁴ah³ jniá³, chiaah¹ há⁴hé³ ga³ji̱i̱³²ah³ dxú⁴ liáh³xɨ³ ga³fooh³²á⁴ niaá⁴ah³ nɨ³.
\v 38 Jmáyh² hi³ ma³heé⁴ jniá³ Ñuyh⁴ ba² nɨ³ ga³liuy⁴, joó⁴ niaá⁴ah³ yáh¹ jmáyh² hi³ ma³heé⁴ niaá⁴ah³ ñúh³ah³ ba² nɨ³ ga³jmee³ah³.
\p 
\v 39 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ dsa³ ja̱³:
\p ―Hí̱³ba² Abraham nɨ³ na³lɨ́y⁴ ñúh³ah¹ jniaah¹.
\p Joó⁴ mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Liu³u²xɨ³ he̱é̱yh³ ba² na³lɨ́⁴ah³ ja̱á̱² Abraham, mɨ²ja̱³ hi²jmee³ah³ hi³ dxú⁴ liáh³xɨ³ gá⁴jmeé³ ñaá² hu̱² liáh³ja̱³.
\v 40 Gu³xɨ³ ba² jmiih⁴ ma³foóh²á⁴ niaá⁴ah³ hi³ Dios nɨ³ ma³heé⁴ jniá³ jɨɨ⁴ lɨ́⁴, ná⁴lɨ¹ chiáh² naa³ah³ dɨ²jɨ̱́h⁴ah³ jniá³. ¡Há⁴hé³ jlɨ́h³ gá⁴jmeé³ liáh³ja̱³ Abraham liáh³xɨ³ ga³jmee³ah³ nɨ³!
\v 41 Ja̱³ba² liáh³xɨ³ ga³jmee⁴ jmɨ́yh³ ñúh³ah³ ba² nɨ³ ga³jmee³ah³ niaá⁴ah³.
\p Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³:
\p ―Há⁴hí̱³ ja̱á̱² dxeeyh⁴ jniaah¹, Dios ba² nɨ³ jmɨ́yh³ Ñúh³ah¹ jniaah¹.
\p 
\v 42 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Liu³u²xɨ³ jmɨ́yh³he̱é̱yh³ ba² Dios nɨ³ na³lɨ́y⁴ Ñúh³ah³, hi²xiáh³ naá⁴ah³ jniá³ hu̱² liáh³ja̱³, chiaah¹ Dios nɨ³ nɨ³ gá⁴xɨ́y⁴ jniá³, hi³ja̱³ nɨ³ je¹á² la³ ja̱³nɨ́⁴. Há⁴ja̱³ hi³ güé⁴á⁴ hi³ fáh⁴ hi³ naáy⁴ ñeéy⁴ nɨ³. Dios ba² nɨ³ gá⁴xɨ́y⁴ jniá³.
\v 43 ¿He²chiaah¹ há⁴hé³ hí⁴dsaa⁴ah³ hi³ ga³fooh³²á⁴ niaá⁴ah³ nɨ³? Chiaah¹ hi³ há⁴hé³ dɨ²nuu³ah³ dsaá² fáh⁴liu⁴ chieéy⁴ nɨ³.
\v 44 Na³lɨ́⁴ah³ xɨh³chie̱y³² ñaá² ñúh³ah³ hi³há⁴dxúy⁴ nɨ³, baáy⁴ liáh³xɨ³ niaá⁴ ñúh³ah³ nɨ³ ba² nɨ³ dɨ²jmee³ah³. Mɨ² du³ñi² lɨ́⁴ bih³ gá⁴laá⁴ hi³há⁴dxúy⁴ nɨ³ ga³jɨ̱yh⁴ dsa³. Há⁴hé³ tɨ́³ dsɨ́² cáh³ti³² hi³ xiaa³dsaa³² chiaah¹ há⁴hé³ jlɨ́h³ ga³liu⁴ xiaa³dsaa³². Liu³u²xɨ³ mɨ² ga³juu³², mɨ²ja̱³ lii⁴ jmɨ́yh³ liáh³xɨ³ na³lɨ́y⁴. Chiaah¹ hi²xiáh³ sɨ²juuy³, baáy⁴ ñaá² nɨ³ na³lɨ́y⁴ fii² fáh⁴sɨ²juu².
\v 45 Joó⁴ xiáh³ chieéy⁴ jniá³ hi³ ga³liuy⁴ xiaa³dsaa³² nɨ³, há⁴hé³ ca³gua³taá³ah³.
\v 46 ¿Hi̱² na²nɨ¹ah³ niaá⁴ah³ hí⁴jooy³ hi²fáh³ah³ hi³ xa³ dsaa² chieéy⁴ hi²nia⁴²a²? Baáy⁴ xɨ³ nɨ³ ga³liuy⁴ liáh³ xiaa³dsaa³², ¿he² chiaah¹ hi³ há⁴hé³ ca³gua³taá³ah³ chieéy⁴ nɨ³?
\v 47 Ja̱y³ hi³ na³lɨ́y⁴ chié̱y² Dios, hi³hí̱³ ga³nuu³ dsaá² fáh⁴liu⁴ chiáh² Dios. Joó⁴ há⁴hé³ na³lɨ́⁴ah³ chié̱y² Dios niaá⁴ah³, hi³ja̱³ nɨ³ há⁴hé³ dɨ²nuu³ah³ dsaá² fáh⁴liu⁴ chieéy⁴ nɨ³.
\s1 Mɨ³xe̱y³ ba² Cristo liáh³ gá⁴sa̱y³ Abraham
\p 
\v 48 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³ cá⁴dah²sɨɨ́h⁴ Jesús ja̱³:
\p ―Hi³ja̱³ he̱é̱yh³ ba² chiaa⁴²ah¹ jniaah¹ hi³ ga³féh³ah¹ hi³ na³lɨ́⁴u³ samaritano, baáy⁴ haá⁴u³ hi³há⁴dxúy⁴.
\p 
\v 49 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Há⁴hé³ xe̱y³ hi³há⁴dxúy⁴ haá⁴á⁴ jniá³. Ñuyh⁴ ba² nɨ³ ga³jmeéh⁴á⁴ hu̱u̱¹rá². Joó⁴ niaá⁴ah³ há⁴hé³ ga³jme³²ah³ jniá³ cua̱a̱y¹ná².
\v 50 Ba² há⁴ja̱³ ruh³ hi³ naayh³² hi³ hu̱² hi²jmeeh¹ah³ jniá³ hu̱u̱¹rá² nɨ³, xe̱y³ ba² ja̱y³ hi³ naayh³² diáh⁴ hi³ hí⁴dah²jmeéh⁴ jniá³ hu̱u̱¹rá², hí̱³ba² hi³ ga³ca̱a̱⁴ cua̱a̱y¹ná² chiáh² diáh⁴ dsa³ nɨ³.
\v 51 Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³: Liu³u²xɨ³ xe̱y³ hi³ hí⁴jmeé⁴ he̱é̱yh³ hi³ ga³fayh⁴ la³, hi³hí̱³ há⁴hé³ jlɨ́h³ hí⁴joó² fáh⁴ju̱y¹.
\p 
\v 52 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³ cá⁴dah²sɨɨ́h⁴:
\p ―Ja̱³nɨ́⁴ gɨh¹ mɨ³nia⁴²ah¹ dxú⁴ hi³ he̱é̱yh³ ba² haá⁴u³ hi³há⁴dxúy⁴. Chiaah¹ jú̱y⁴ ba² Abraham chie̱é̱yh¹ liáh⁴jɨy³ diáh⁴ profetas, baáy⁴ niu³ ga³fáyh³ hi³ liu³u²xɨ³ xe̱y³ hí⁴jmeé⁴ he̱é̱yh³ hi³ ga³fáyh³ nɨ³, há⁴hé³ máh⁴ hí⁴jú̱y³.
\v 53 ¿Xɨ² liáh³ca̱a̱y³ gaá³u³ gɨh¹ niu³ liáh³xɨ³ ñúh³ah¹ Abraham hi³ jú̱y⁴ nɨ³? Ba² jú̱y⁴ ba² diáh⁴ profetas. ¿He² nɨ³ ga³ji̱i̱³²u³ vo̱ó̱h²u³ na³lɨ́⁴u³ xa³ja̱³?
\p 
\v 54 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Hu̱² ga³jmé⁴á⁴ ñeéy⁴ gaá³á⁴, há⁴hé³ cua̱a̱y¹ná² cáh³ti³² hu̱² liáh³ja̱³. Joó⁴ Ñuyh⁴ nɨ³ ba² nɨ³ ga³jmeéh⁴ jniá³ gaáy³, hí̱³ba² hi³ ga³hó⁴ah³ niaá⁴ah³ hi³ na³lɨ́y⁴ Dios chia̱á̱²ah³ nɨ³.
\v 55 Joó⁴ há⁴hé³ cui̱i̱⁴ah³ niaá⁴ah³ hi³nɨy³². Jniá³ si¹ cui̱i̱⁴²á⁴. Joó⁴ liu³u²xɨ³ hi²fayh¹ hi³ há⁴hé³ cui̱i̱⁴²á⁴ mɨ²ja̱³ hí⁴lí³á⁴ sɨ²juu⁴²á⁴ liáh³xɨ³ niaá⁴ah³. Joó⁴ he̱é̱yh³ ba² cui̱i̱⁴²á⁴ jniá³, baáy⁴ ga³jmeey⁴ he̱é̱yh³ fáh⁴liu⁴ chiáh².
\v 56 Hi²xiáh³ lɨ́⁴jé⁴ dsɨ́² ñúh³ah³ Abraham ja̱³, chiaah¹ hi³ cá⁴lɨ́⁴dsaay⁴ hi³ hí⁴joó² jmɨɨ́¹ chieéy⁴. Baáy⁴ gá⁴joó² liáh³bií⁴ yáh¹ hi³ja̱³ hi²xiáh³ cá⁴lɨ́⁴jé⁴ dsɨ́².
\p 
\v 57 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³ cá⁴dah²sɨɨ́h⁴ Jesús ja̱³:
\p ―Ñé⁴ tú̱⁴ná⁴dxiá³ ji̱i̱h⁴u³ há⁴hé³ mɨ³xa³, baáy⁴ ga³fáyh³ hi³ gá⁴joo⁴²u³ Abraham nɨ³.
\p 
\v 58 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi²fooh¹á² niaá⁴ah³: Mɨ³xa̱⁴²á⁴ ba² jniá² liáh³ca̱á̱h³ ja̱a̱h¹ hí⁴sa̱y³ Abraham nɨ³.
\p 
\v 59 Hi³ja̱³ mɨ²ja̱³ cá⁴dah²cá̱⁴ na¹cu̱ú̱¹ diáh⁴ israelitas ja̱³ duh³ hí⁴dah²chiúyh² Jesús ja̱³. Joó⁴ mɨ²ja̱³ ca̱a̱³ ba² dɨ́h¹ cá⁴lɨ́⁴máy¹ duh³ cá⁴bí⁴hɨɨ́y⁴ xi² jey¹ guah³ ja̱³. Ja̱³ba² jee⁴² chiáh² diáh⁴ dsa³ ja̱³ gá⁴ŋɨ́y³ liáh³ ŋáyh² ja̱³.
\c 9
\s1 Cá⁴bí⁴lieéy³ Jesús ja̱³ ja̱y³ dsa³ tuu²
\p 
\v 1 Liáh³ híy¹ fi¹ Jesús ja̱³, mɨ²ja̱³ gá⁴joóy² ja̱y³ dsaá⁴ hi³ tuúy¹ liáh³ gá⁴sa̱y³ lɨ́⁴.
\v 2 Mɨ²ja̱³ gá⁴ŋɨɨh²ah¹ juúh⁴ jniaah¹ diáh⁴ xɨh³chie̱y³² Jesús ja̱³, liáh³la³ gá⁴xɨɨh²ah¹:
\p ―Dsa³he⁴, ¿he²chiaah¹ hi³ gá⁴sa̱y³ tuúy¹ dsaá⁴ la³? ¿Xɨ² vih²chiaah¹ dsaa² chiáh² diáh⁴ xaá¹jmii³, ha²xɨ² vih²chiaah¹ dsaa² chiáh² ñaá² nɨ³?
\p 
\v 3 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Há⁴ja̱³ vih²chiaah¹ dsaa² chiáh² ñaá² nɨ³, ñé⁴ vih²chiaah¹ dsaa² chiáh² diáh⁴ xaá¹jmii³. Duh³ hí⁴lii⁴ liáh³xɨ³ hí⁴jooy³ hí⁴jmeé⁴ Dios nɨ³ chiáh² ba² nɨ³, hi³ja̱³ ba² nɨ³ gá⁴lɨ́y⁴ liáh³nɨ³.
\v 4 Liáh³ rúh⁴ jmɨɨ⁴ la³ ga³jmee⁴ hi²jmeey⁴² ta² chiáh² hi³ gá⁴xɨ́y⁴ jniá³ nɨ³. Chiaah¹ hí⁴niuu³, mɨ²ja̱³ gu³xɨ³ hí̱³ há⁴hé³ máh⁴ hí⁴jooy³ hí⁴jmeé⁴ ta².
\v 5 Liáh³ rúh⁴ je¹á² jmɨɨyh⁴²güii³ la³, na³lɨ́⁴á⁴ ya⁴²jmɨɨ́⁴ chiáh² diáh⁴ dsa³ jmɨɨyh⁴²güii³.
\p 
\v 6 Dsa³cɨ̱ɨ̱y³ liáh³ gá⁴féh³ liáh³ja̱³ mɨ²ja̱³ gá⁴hoóh² Jesús ja̱³ dxaah¹vó⁴, ja̱³ba² gá⁴jmeé³ ca³liuh² ñuu³ chie̱é̱yh¹ jmɨ́⁴hóh¹ ja̱³, gá⁴xuúh⁴ mɨ¹ñi² dsa³ tuu² ja̱³.
\v 7 Mɨ²ja̱³ liáh³la³ gá⁴sɨɨ́h⁴ dsa³ ja̱³:
\p ―Gua³u̱ú̱h² mɨ¹ñíy¹ nɨ³ he̱é̱yh³ jmɨɨ³ hi³ ta̱a̱⁴ xi² xɨ̱ɨ̱y³ Siloé ―Siloé ja̱³ niaá⁴ hí⁴féh³: ja̱y³ hi³ cá⁴lɨ́⁴xɨy⁴².
\p Mɨ²ja̱³ ñií¹ dsa³ tuu² ja̱³, duh³ ya²u̱ú̱h² mɨ¹ñi² ja̱³. Liáh³ güéyh² ja̱³ mɨ²ja̱³ mɨ³jniaá⁴ gɨh¹ ba².
\v 8 Hi³ja̱³ liáh³ cá⁴dah²joó² diáh⁴ hi³ nieeyh⁴² yeey⁴ xi² jey¹ ja̱³ hi³ mɨ³jniaá⁴ ja̱³, mɨ²ja̱³ liáh³la³ cá⁴dah²féh³:
\p ―¿Xɨ² há⁴hí̱³ hi³nɨy³² nɨ³ hi³ ga³guá³ ga³ŋɨɨ⁴ foo³ nɨ³?
\p Baá⁴ ba² xe̱y³ gɨh¹ fɨɨ́y⁴ diáh⁴ hi³ cá⁴dah²joóy² liáh³ tuúy¹ ja̱³, hi³ja̱³ ree³ ba² cá⁴dah²féh³.
\p 
\v 9 Ba² liáh³la³ dah²féh³ ta̱á̱²dsɨy⁴²:
\p ―Hí̱³ba² hi³nɨy³² nɨ³.
\p Joó⁴ liáh³la³ ba² dah²féh³ dxeeyh⁴:
\p ―Ja̱³ba² liáh³nɨ³ na³lɨ́y⁴, joó⁴ há⁴hí̱³ hi³nɨy³² nɨ³.
\p Joó⁴ mɨ²ja̱³ liáh³la³ gá⁴féh³ ñaá² dsaá⁴ ja̱³:
\p ―Hí̱³ba² jniá³ la³.
\p 
\v 10 Hi³ja̱³ cá⁴dah²ŋɨɨ́h⁴ juúh⁴, liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―¿Jmiih⁴² nɨ³ ma³lɨ⁴ hi³ mɨ³jniaa³²u³ nɨ³?
\p 
\v 11 Mɨ²ja̱³ liáh³la³ gá⁴féh³ dsaá⁴ ja̱³:
\p ―Dsa³ hi³ xɨ̱ɨ̱y³ Jesús nɨ³ ma³jmeé³ ñuu³, duh³ ma³xuúh⁴ mɨ¹ñiy⁴ nɨ³, mɨ²ja̱³ liáh³la³ ma³sɨɨ́h⁴ jniá³: “Má⁴dxií⁴ xi² ná⁴ha⁴² jmɨɨ³ hi³ xɨ̱ɨ̱y³ Siloé nɨ³ duh³ gua³u̱ú̱h² mɨ¹ñíy¹ nɨ³.” Mɨ²ja̱³ ma³ñii⁴²á² ma³ya²u̱ú̱yh⁴. Liáh³ ma³u̱ú̱yh⁴ mɨ¹ñiy⁴ nɨ³, mɨ²ja̱³ ma³lɨ³jnieéy⁴.
\p 
\v 12 Mɨ²ja̱³ cá⁴dah²ŋɨɨ́h⁴ ca̱á̱h³ juúh⁴ dsaá⁴ ja̱³:
\p ―¿Nɨy¹ ñaá² yáh¹?
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ dsa³ ja̱³:
\p ―Há⁴hé³ maay⁴.
\s1 Cá⁴dah²ca̱a̱⁴ cua̱a̱y¹ná² chiáh² dsa³ tuu² ja̱³
\p 
\v 13 Dsa³cɨ̱ɨ̱y³ liáh³ja̱³ dah²ya²jay⁴ dsa³ tuu² hi³ ma³laáy³ ja̱³ rúh⁴ñi² diáh⁴ fariseos.
\v 14 Chiaah¹ jmɨɨ́¹ mah² ja̱³, liáh³ gá⁴jmeé³ ñuu³ Jesús ja̱³ hi³ chie̱é̱yh¹ gá⁴niá² mɨ¹ñi² dsa³ dsaah⁴² ja̱³.
\v 15 Hi³ja̱³ cá⁴dah²ŋɨɨ́³ ca̱á̱h³ juúh⁴ diáh⁴ fariseos ja̱³ cá⁴dah²ŋɨɨ́h⁴ juúh⁴ dsa³ ja̱³, hi³ jmiih⁴² ja̱³ ma³lɨ⁴ hi³ ma³laáy³ ja̱³. Hi³ja̱³ liáh³la³ gá⁴féh³ dsa³ ja̱³:
\p ―Ma³xuúh⁴ ñuu³ mɨ¹ñiy⁴ la³, mɨ²ja̱³ ma³u̱ú̱yh⁴ hi³ja̱³ mɨ³jnieéy⁴ ja̱³nɨ́⁴.
\p 
\v 16 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ ta̱á̱²dsɨy⁴² diáh⁴ fariseos ja̱³:
\p ―Há⁴hí̱³ Dios nɨ³ gá⁴xɨ́y⁴ dsaá⁴ nɨ³, chiaah¹ hi³ja̱³ nɨ³ há⁴hé³ ga³jmee⁴ he̱é̱yh³ jmɨɨ́¹ mah².
\p Joó⁴ liáh³la³ ba² dah²féh³ dxeeyh⁴:
\p ―¿Jmiih⁴² ja̱³ dɨ́h¹ hí⁴jooy³ hí⁴jmeé⁴ fáh⁴lí³ liáh³xɨ³ hi³ joo³²a² la³ liu³u²xɨ³ na³lɨ́y⁴ dsa³ hi³ xa³ dsaa² chiáh²?
\p Hi³ja̱³ há⁴hé³ hí⁴jooy³ hí⁴taayh³ fi¹ fáh⁴liu⁴ chiáh² diáh⁴ ja̱³ chiaah¹ hi³ dxaáh² ba² dah²féh³ liáh³ja̱y³ liáh³ja̱y³ diáh⁴.
\v 17 Hi³ja̱³ cá⁴dah²ŋɨɨ́h⁴ ca̱á̱h³ juúh⁴ dsaá⁴ hi³ ma³laáy³ ja̱³, liáh³la³ cá⁴dah²sɨɨ́h⁴ ca̱á̱h³:
\p ―¿Jmiih⁴² ga³ji̱i̱³²u³ niu³ chiáh² dsaá⁴ hi³ ma³bi³lieéy³ niu³ nɨ³?
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ dsa³ ja̱³:
\p ―Na³lɨ́y⁴ profeta ga³ji̱í̱y⁴ jniá³.
\p 
\v 18 Joó⁴ há⁴hé³ dsa³taáy³ diáh⁴ fii² diáh⁴ israelitas ja̱³ hi³ he̱é̱yh³ ba² dsa³ hi³ tuúy¹ ja̱³ ja̱³ mɨ³jniaá⁴. Hi³ja̱³ cá⁴dah²teé⁴ lɨ́⁴ diáh⁴ xaá¹jmii³ dsa³ ja̱³,
\v 19 duh³ liáh³la³ cá⁴dah²sɨɨ́h⁴ diáh⁴:
\p ―¿Xɨ² hi³ley³² nɨ³ ja̱a̱³ah³ hi³ ga³hó⁴ah³ gá⁴sa̱y³ tuúy¹ nɨ³? ¿Jmiih⁴² nɨ³ hi³ mɨ³jniaá⁴ ja̱³nɨ́⁴?
\p 
\v 20 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ xaá¹jmii³ dsa³ ja̱³:
\p ―Nia⁴²ah¹ ba² hi³ ja̱a̱³²ah¹ hi³ gá⁴sa̱y³ tuúy¹ nɨ³.
\v 21 Joó⁴ há⁴hé³ nia⁴²ah¹ jmiih⁴² nɨ³ hi³ mɨ³jniaá⁴ ja̱³nɨ́⁴, ba² ñé⁴ há⁴hé³ nia⁴²ah¹ hi̱² nɨy³² ma³bi³liaá³ chiáh². Ŋɨɨ́h¹ah³ juúh⁴ ñaá². Mɨ³xa³ ba² ji̱i̱yh⁴ hi³ja̱³ hí⁴jooy³ ba² hí⁴sɨɨ́h⁴ niaá⁴ah³ na³fáyh⁴.
\p 
\v 22 Cá⁴dah²féh³ liáh³ja̱³ diáh⁴ xaá¹jmii³ dsa³ ja̱³ chiaah¹ dɨ³foyh⁴ dah²jooy³² diáh⁴ hi³ na³ta̱a̱y⁴ ñi² ja̱³. Chiaah¹ ma³dah²dxá³ dxú⁴ diáh⁴ hi³ na³ta̱a̱y⁴ ñi² ja̱³ hi³ há⁴hé³ máh⁴ hí⁴dah²cuó⁴ je² hí⁴dsá⁴hí³ ñuúh⁴guah³ liuh² ja̱³, ja̱y³ hi³ hí⁴féh³ hi³ Jesús ja̱³ ja̱³ Cristo, há⁴hé³ máh⁴ hí⁴dah²cuó⁴ je² hi³ dsá⁴taáyh¹ ñuúh⁴guah³ liuh² ja̱³.
\v 23 Hi³ja̱³ ja̱³ cá⁴dah²féh³: “Ŋɨɨ́h¹ah³ juúh⁴ ñaá², chiaah¹ mɨ³xa³ ba² ji̱i̱yh⁴.”
\p 
\v 24 Hi³ja̱³ cá⁴dah²teé⁴ ca̱á̱h³ dsa³ hi³ ma³laáy³ ja̱³, duh³ cá⁴dah²ŋɨɨ́h⁴ juúh⁴, liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―Hey⁴² Fii³²a² hi²nia⁴²a² duh³ lii⁴ hi³ he̱é̱yh³ ba² chiú̱h²u³, chiaah¹ jniaah¹ nia⁴²ah¹ dxú⁴ hi³ dsa³ mɨ³hey³² ba² nɨ³.
\p 
\v 25 Mɨ²ja̱³ liáh³la³ gá⁴féh³ dsa³ ja̱³:
\p ―Há⁴hé³ maay⁴ jniá² xɨ³ mɨ³hey³² xɨ³ jmiih⁴. Ca̱a̱³ mɨ³ja̱³ maay⁴ hi³ tuu⁴²á² mɨ² dsa³jéy⁴, baáy⁴ ja̱³nɨ́⁴ mɨ³jnieéy⁴ ba² nɨɨh¹.
\p 
\v 26 Cá⁴dah²ŋɨɨ́h⁴ ca̱á̱h³ juúh⁴ liáh³la³ cá⁴dah²sɨɨ́h⁴ ca̱á̱h³:
\p ―¿Jmiih⁴² nɨ³ ma³jmeéh⁴ niu³ nɨ³? ¿Jmiih⁴² nɨ³ ma³jmeé³ hi³ ma³lɨ³jniaá²u³ nɨ³?
\p 
\v 27 Mɨ²ja̱³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ diáh⁴ ca̱á̱h³:
\p ―Ma³foóh²á⁴ ba² niaá⁴ah³ baáy⁴ há⁴hé³ ga³jmee³ah³ he̱é̱yh³ nɨ³. ¿He²chiaah¹ hi³ naa³ah³ hi³ hi²fayh¹ ca̱á̱h³? ¿Xɨ² ba² naa³ah³ niaá⁴ah³ hi²jmee³ah³ xɨh³chie̱y³²?
\p 
\v 28 Liáh³ gá⁴féh³ liáh³ja̱³, mɨ²ja̱³ cá⁴dah²liúy² sá⁴guáy⁴, liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―Xɨh³chie̱y³² na¹hi³nɨy³² ba² niu³, joó⁴ ley chiáh² Moisés ba² ga³jmee⁴²ah¹ he̱é̱yh³ jniaah¹.
\v 29 Jniaah¹ nia⁴²ah¹ hi³ ñaá² Dios ba² ja̱³ gá⁴liúy² Moisés, joó⁴ chiáh² hi³nɨy³² há⁴hé³ nia⁴²ah¹ cáh³ti³² xiah² nɨ³ ma³bi³hɨɨ́y⁴.
\p 
\v 30 Mɨ²ja̱³ liáh³la³ gá⁴féh³ dsa³ ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―¡Jmiih⁴² ná⁴lɨ¹ xa³ja̱³ hi³ há⁴hé³ maá³ah³ niaá⁴ah³ hi̱² dsa³ nɨ³, baáy⁴ ma³bi³lieéy³ jniá³ jniá²!
\v 31 Nia⁴²a² ba² dxú⁴ hi³ há⁴hé³ ga³nuu³ Dios chiáh² diáh⁴ hi³ mɨ³hey³². Joó⁴ chiáh² diáh⁴ hi³ dɨ³foyh⁴ rúh⁴ñi² ñaá² baáy⁴ diáh⁴ hi³ ca³dah²jmee⁴ liáh³xɨ³ ga³lɨ́³ dsɨ́² ñaá², chiáh² diáh⁴ hi³hí̱³ si¹ ga³nuu³ Dios nɨ³.
\v 32 Há⁴hé³ jlɨ́h³ ma³niuu²a² hi³ xe̱y³ ma³jmeé³ ma³lɨ³jniaá⁴ ja̱y³ dsa³ tuu² hi³ ga³sa̱y³ tuúy¹.
\v 33 Liu³u²xɨ³ há⁴ja̱³ chiáh² Dios bí⁴hɨɨ́y⁴ dsaá⁴ nɨ³, mɨ²ja̱³ há⁴hé³ xa³ lií² hí⁴jooy³ hí⁴jmeé⁴ hu̱² liáh³ja̱³.
\p 
\v 34 Mɨ²ja̱³ liáh³la³ cá⁴dah²sɨɨ́h⁴ dsaá⁴ ja̱³:
\p ―¿Xɨ² niu³ gá⁴sa̱³u³ xa³ dsaa² chiú̱h²u³ nɨ³, hi²hooy¹ jniaah¹? Bi³hɨɨ́y⁴, ca̱á̱h³ tiaah² há⁴hé³ máh⁴ hí⁴jooy³ hí⁴güé³u³ ñuúh⁴guah³ liuh² la³.
\s1 Diáh⁴ hi³ tuúy¹ chiáh² Dios
\p 
\v 35 Gá⁴dsaá⁴ dsɨ́² Jesús ja̱³ hi³ ma³dah²dxɨy³ cáh³ti³² dsa³ hi³ ma³laáy³ ja̱³, hi³ja̱³ liáh³ gá⁴ji̱i̱h⁴ ca̱á̱h³ ja̱³, mɨ²ja̱³ liáh³la³ gá⁴sɨɨ́h⁴:
\p ―¿Xɨ² ca³gua³taá³u³ niu³ chiáh² Ja̱á̱² Dios nɨ³?
\p 
\v 36 Mɨ²ja̱³ liáh³la³ gá⁴féh³ dsa³ ja̱³:
\p ―Ñuyh⁴, xɨɨh² jniá³ hi̱² nɨy³², duh³ dsá⁴taá³á⁴ chiáh².
\p 
\v 37 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Ma³joo⁴²u³ ba², hí̱³ba² hi³ liúy¹ chia̱á̱h¹u³ nɨ³.
\p 
\v 38 Mɨ²ja̱³ gá⁴xɨ́h² ji̱² rúh⁴ñi² Jesús ja̱³, duh³ liáh³la³ gá⁴sɨɨ́h⁴:
\p ―Ca³dsa³taá³á⁴ ba² chiú̱h²u³ Ñuyh⁴.
\p Mɨ²ja̱³ gá⁴jmeéh⁴ hu̱u̱¹rá².
\p 
\v 39 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Güé⁴á⁴ jmɨɨyh⁴²güii³ la³ duh³ hí⁴jooy³ hí⁴chia̱a̱⁴² cua̱a̱y¹ná² chiáh² diáh⁴ dsa³. Güé⁴á⁴ duh³ja̱³ hí⁴jooy³ hí⁴jniaá⁴ diáh⁴ hi³ dɨ³tuúy¹, baáy⁴ duh³ hí⁴tuúy³ diáh⁴ hi³ dɨ³jniaá⁴.
\p 
\v 40 Liáh³ cá⁴dah²nuú³ ta̱á̱²dsɨy⁴² diáh⁴ fariseos hi³ na³ta̱a̱y⁴ xi² hiíy⁴ Jesús ja̱³, hi³ gá⁴féh³ liáh³ja̱³, mɨ²ja̱³ cá⁴dah²ŋɨɨ́h⁴ juúh⁴, liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―¿Xɨ² liáh³ca̱a̱y³ ji̱í̱⁴ jniaah¹ nɨ³ tuu²ah¹ ga³ji̱i̱³²u³?
\p 
\v 41 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Liu³u²xɨ³ he̱é̱yh³ ba² tuú¹ah³ mɨ²ja̱³ há⁴hé³ xa³ dsaa² chia̱á̱²ah³ hu̱² liáh³ja̱³. Joó⁴ ga³fáh³ah³ hi³ jniaá²ah³ ba², hi³ja̱³ na³jniaa³ chiáh² liáh³nɨ³ dsaa² chia̱á̱²ah³ nɨ³.
\c 10
\s1 Gá⁴liú³ Jesús ja̱³ chiáh² yá³ chiáh² dsɨɨ³jaa³
\p 
\v 1 Gá⁴hɨɨ́² liu⁴ liáh³ja̱³ Jesús ja̱³, liáh³la³ féh³:
\p ―Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³: Liu³u²xɨ³ ja̱y³ hi³ ca³dsa³hí³ ñuúh⁴ yá³ xi² tieéyh¹ diáh⁴ dsɨɨ³jaa³, baáy⁴ xɨ³ xiáh³ rúh⁴cáh⁴ ba² hí⁴dsá⁴hí³ dxa² hi³ dsá⁴hí³ xiáh³ haah²ñu¹, dsa³ hi̱i̱³ ba² hí̱³ hi³ hí⁴jmeé⁴ liáh³ja̱³.
\v 2 Joó⁴ liu³u²xɨ³ hi³ ca³dsa³hí³ jmɨ́yh³ haah²ñu¹, mɨ²ja̱³ jmɨ́yh³ pastor hi³ ga³heeyh³ hí¹ diáh⁴ dsɨɨ³jaa³ ja̱³ ba² ja̱³.
\v 3 Dsa³ hi³ ga³heeh⁴ hí¹ haah²ñu¹ ja̱³ hí⁴niá² duh³ dsá⁴hí³, baáy⁴ ca³lɨ³cui̱i̱³ ba² diáh⁴ dsɨɨ³jaa³ ñii² jmɨ́yh³ fii² diáh⁴. Ja̱³ba² ga³te³² pastor ja̱³ ga³teé⁴ diáh⁴ liáh³xɨ³ xɨ̱ɨ̱y³ liáh³ja̱y³ liáh³ja̱y³ diáh⁴, duh³ ga³vooy³² diáh⁴ tɨɨ́².
\v 4 Mɨ² ma³voóy² diáh⁴ ja̱³, mɨ²ja̱³ ga³dsaa³² ñaá² dsa³jéy⁴ rúh⁴ñi² diáh⁴. Ja̱³ba² ca³dsa³dxí̱⁴ diáh⁴ dsɨɨ³jaa³ ja̱³ xi² dsa³hɨɨ́y⁴ chiaah¹ dɨ³cui̱i̱³ ñii² pastor chié̱y² diáh⁴.
\v 5 Joó⁴ há⁴hé³ ca³dsa³dxí̱⁴ xi² ga³dsaa³² ja̱y³ hi³ há⁴hé³ dɨ³cui̱i̱y⁴, hi³ ca³dah²cui̱i̱⁴ ba² mɨ² ma³dah²joóy², chiaah¹ há⁴hé³ dɨ³cui̱i̱³ ñii².
\p 
\v 6 Liáh³ja̱³ gá⁴féh³ Jesús ja̱³, hi³ liu⁴ ca³jaa¹ chiáh² ñaá² chie̱é̱yh¹ diáh⁴ dsa³ chié̱y², joó⁴ há⁴hé³ cá⁴lɨ́⁴dsaay⁴ diáh⁴ liáh³xɨ³ niaá⁴ hí⁴sɨɨ́h⁴ diáh⁴ ja̱³.
\s1 Jesús nɨ³ na³lɨ́y⁴ jmɨ́yh³ pastor
\p 
\v 7 Mɨ²ja̱³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³: Jniá³ nɨ³ na³lɨ́⁴á⁴ haah²ñu¹ xi² ca³dsa³taáyh¹ diáh⁴ dsɨɨ³jaa³ nɨ³.
\v 8 Diáh⁴ hi³ bí⁴dxí̱⁴ liáh³ca̱á̱h³ ja̱a̱h¹ hí⁴güé³á⁴ jniá³, diáh⁴ dsa³hi̱i̱³ ba² ja̱³. Hi³ja̱³ há⁴hé³ cá⁴dah²jmeé³ he̱é̱yh³ diáh⁴ dsɨɨ³jaa³ ja̱³ chiáh² diáh⁴.
\v 9 Jniá³ nɨ³ na³lɨ́⁴á⁴ haah²ñu¹, hi³ja̱³ liu³u²xɨ³ xe̱y³ hí⁴dsá⁴hí³ xiáh³ haah²ñu¹ chieéy⁴, mɨ²ja̱³ hi³hí̱³ hí⁴bé⁴ dsaa² chiáh². Hí⁴lí³ liáh³xɨ³ ja̱y³ dsɨɨ³jaa³ hi³ ca³dsa³hii³² baáy⁴ ca³bi³hɨɨ́y⁴ ñuúh⁴ yá³ chiáh², baáy⁴ xa³ dxú⁴ ñii³ hi³ ga³eeh³².
\v 10 Ti̱¹ hi³ hí⁴jmeé⁴ hi̱i̱³ baáy⁴ hi³ hí⁴jɨ̱ɨ̱́h⁴ ba² nɨ³ ga³guáy³ ja̱y³ dsa³hi̱i̱³, jmáyh² hi³ ga³yeey³² ba². Joó⁴ jniá³ güé⁴á⁴ duh³ja̱³ hí⁴tɨ̱́⁴ah³ fáh⁴ji̱í̱h⁴ ba², duh³ hi²ñí³ah³ dxú⁴ cáh³ti³².
\p 
\v 11 ’Jniá³ nɨ³ na³lɨ́⁴á⁴ jmɨ́yh³ pastor hi³ dxúy⁴. Pastor hi³ dxúy⁴ cáh³ti³² nɨ³, hí⁴cuóy² ñaá² hí⁴jú̱y³ lɨ́⁴ chiáh² diáh⁴ dsɨɨ³jaa³ chié̱y².
\v 12 Joó⁴ pastor hi³ chi̱í̱⁴ jñiiy⁴, mɨ² ma³joó² hi³ mɨ³je³ lobo xi² na³ta̱a̱y⁴ diáh⁴ dsɨɨ³jaa³ nɨ³, ja̱³ba² hí⁴cui̱í̱⁴ ba², hí⁴cueeyh³ mii⁴ diáh⁴ dsɨɨ³jaa³. Chiaah¹ há⁴ja̱³ he̱é̱yh³ ba² na³lɨ́y⁴ pastor, baáy⁴ há⁴hí̱³ hi³chie̱y³² ja̱³ diáh⁴ dsɨɨ³jaa³ ja̱³. Mɨ²ja̱³ ca³dsa³hí³ lobo ja̱³ jee⁴² chiáh² diáh⁴ dsɨɨ³jaa³ ja̱³ duh³ hí⁴sa̱yh³² diáh⁴, ja̱³ba² dsá⁴saáy⁴ dsá⁴jay⁴ gɨh¹ diáh⁴ tú̱⁴dsaayh⁴.
\v 13 Ga³cui̱i̱⁴ dsa³ ja̱³ yáh¹, chiaah¹ hi³ fáh⁴ hi³ xa³ jñiiy⁴ ba² ja̱³ ga³jmee⁴ ta², hi³ja̱³ há⁴hé³ cua̱a̱y¹ná² chiáh² xɨ³ jmiih⁴ hí⁴lí³ diáh⁴ dsɨɨ³jaa³ ja̱³.
\p 
\v 14 ’Jniá³ nɨ³ pastor hi³ dxúy⁴. Cui̱i̱⁴²á⁴ ba² diáh⁴ dsɨɨ³jaa³ chia̱á̱²á⁴, ba² dɨ³cui̱i̱y⁴ ba² jniá³ mii⁴ diáh⁴.
\v 15 Ja̱³ba² liáh³ja̱³ cui̱i̱⁴ jniá³ Ñuyh⁴ nɨ³, ba² liáh³ja̱³ cui̱i̱⁴²á⁴ jniá³ ñaá². Ba² hi²cuó⁴á⁴ ñeéy⁴ hí⁴jú̱³á⁴ chiáh² diáh⁴ dsɨɨ³jaa³ nɨ³.
\v 16 Ba² xe̱y³ gɨh¹ dxeeyh⁴ diáh⁴ dsɨɨ³jaa³ chia̱á̱²á⁴ hi³ há⁴hé³ mɨ³dɨ³tieéyh¹ ñuúh⁴ yá³ la³, hi³ja̱³ ba² ga³jmee⁴ ya³jé²á⁴ diáh⁴. Hí⁴dah²nuú⁴ ba² dsaá² fáh⁴liu⁴ chieéy⁴, duh³ ca̱á̱h³ tiéyh⁴ bɨh¹ hí⁴lí³ diáh⁴, baáy⁴ ja̱y³ bɨh¹ pastor chié̱y² diáh⁴ hí⁴sa̱y³.
\p 
\v 17 ’Hi²xiáh³ nieéy² jniá³ Ñuyh⁴ nɨ³, chiaah¹ hi³ hi²cuó⁴á⁴ ñeéy⁴ hí⁴jú̱³á⁴ duh³ hí⁴ji̱i̱h⁴²á⁴ ca̱á̱h³ dsa³cɨ̱ɨ̱y³.
\v 18 Gu³xɨ³ hí̱³ há⁴hé³ hí⁴jɨ̱́yh⁴ jniá³, hi³ hi²cuó⁴á⁴ ñeéy⁴ hí⁴jú̱³á⁴ liáh³xɨ³ ga³lɨ́³ dxú⁴ dsɨy⁴ ba² nɨ³. Haay⁴ jú¹hiíh⁴ hi²cuó⁴á⁴ ñeéy⁴ hí⁴jú̱³á⁴. Ba² haay⁴ jú¹hiíh⁴ hí⁴ji̱i̱h⁴²á⁴ ca̱á̱h³. Hi³la³ nɨ³ jmɨ́yh³ gá⁴taáh⁴ ta² Ñuyh⁴ hi³ hi²jmeey⁴².
\p 
\v 19 Liáh³ cá⁴dah²nuú³ ca̱á̱h³ diáh⁴ israelitas hi³ gá⁴féh³ liáh³ja̱³ Jesús ja̱³, mɨ²ja̱³ gá⁴sa³ ca̱á̱h³ fáh⁴liu⁴ jee⁴² chiáh² diáh⁴.
\v 20 Hi²xiáh³ fɨɨ́y⁴ diáh⁴ hi³ dah²féh³:
\p ―¿He²chiaah¹ hi³ ga³jmee³ah³ he̱é̱yh³ chiáh² nɨ³? Hi³ heey³² hi³há⁴dxúy⁴ ba² nɨ³, ha̱á̱¹ hi³ dse³taay³ ba² nɨ³.
\p 
\v 21 Joó⁴ liáh³la³ ba² dah²féh³ tú̱⁴dsaayh⁴:
\p ―Gu³xɨ³ hí̱³ba² hi³ heey³² hi³há⁴dxúy⁴ há⁴hé³ hí⁴jooy³ hí⁴liú⁴ liáh³xɨ³ ga³liu⁴ dsa³ nɨ³. ¿Xɨ² ga³ji̱i̱³²ah³ hi³ hí⁴jooy³ hí⁴bí⁴lieéy³ diáh⁴ dsa³ tuu² ja̱y³ hi³ heey³² hi³há⁴dxúy⁴?
\s1 Há⁴hé³ dɨ³nieéy² Jesús ja̱³ diáh⁴ hi³ na³ta̱a̱y⁴ ñi²
\p 
\v 22 Du³chia̱a̱²u² jí̱h²maá¹ ja̱³, dsa³tɨ́⁴ jmɨ́¹feh⁴ Jerusalén ja̱³, hi³ liíh⁴ dsɨ́² diáh⁴ jmɨɨ́¹ mɨ² cá⁴dah²bi³hii³ ca̱á̱h³ guah³ chiáh² diáh⁴ ja̱³.
\v 23 Mɨ²ja̱³ chie⁴ji̱i̱⁴ Jesús ja̱³ xi² jey¹ guah³, voó² chiáh² Salomón.
\v 24 Mɨ²ja̱³ cá⁴dxá⁴máyh³ diáh⁴ hi³ na³ta̱a̱y⁴ ñi² ja̱³ ji̱h²caayh⁴, duh³ liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―¿He²chiaah¹ hi³ ga³jmeey³ ga³ta³ ga³hɨ³²ah¹ ñuú³ nɨ³? Xɨɨh² jniaah¹ jí̱⁴ñí³ xɨ² niu³ nɨ³ Cristo.
\p 
\v 25 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Ma³ŋɨ́³ ba² ma³fáyh² joó⁴ há⁴hé³ ma³taá³ah³. Chiaah¹ liáh⁴jɨ³ fáh⁴tiaah⁴ ta² chiáh² Ñuyh⁴ hi³ ga³jmeey⁴ nɨ³ ga³féh³ hi³ ñaá² nɨ³ gá⁴xɨ́y⁴ jniá³.
\v 26 Joó⁴ há⁴hé³ ca³gua³taá³ah³ niaá⁴ah³, chiaah¹ há⁴hé³ na³lɨ́⁴ah³ dsɨɨ³jaa³ chia̱á̱²á⁴, liáh³xɨ³ ma³foóh²á⁴ niaá⁴ah³ dsa³jéy⁴ nɨ³.
\v 27 Diáh⁴ dsɨɨ³jaa³ chia̱á̱²á⁴ dɨ³cui̱i̱³ ba² ñiiy⁴, baáy⁴ cui̱i̱⁴²á⁴ ba² mii⁴ diáh⁴, hi³ja̱³ ca³dsa³dxí̱⁴ diáh⁴ chie̱é̱yh¹ jniá³ xi² dsa³hɨɨ́⁴á⁴.
\v 28 Jniá³ nɨ³ ga³cuoó⁴á⁴ diáh⁴ fáh⁴ji̱í̱h⁴ hi³ há⁴hé³ máh⁴ hí⁴jú̱y³. Gu³xɨ³ hí̱³ há⁴hé³ máh⁴ hí⁴tiaá⁴ hí⁴booy³ jniá³.
\v 29 Ñuyh⁴ hi³ ma³cuóy² diáh⁴ jniá³ nɨ³, hi³nɨy³² nɨ³ ná⁴ŋɨy¹ cáh³ti³², hi³ja̱³ gu³xɨ³ hí̱³ há⁴hé³ máh⁴ hí⁴tiaá⁴ hí⁴booy³ Dios nɨ³ diáh⁴ dsɨɨ³jaa³.
\v 30 Jniá³ chia̱a̱h⁴²á² Ñuyh⁴ nɨ³, ja̱y³ dsa³ ba² jniaah¹.
\p 
\v 31 Mɨ²ja̱³ cá⁴dah²cá̱⁴ ca̱á̱h³ na¹cu̱ú̱¹ diáh⁴ israelitas ja̱³ duh³ hí⁴dah²chiúyh² Jesús ja̱³.
\v 32 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Hi²xiáh³ ñuú³ hi³ dxú⁴ ma³jmeéy⁴ rúh⁴ñí¹ah³ dxɨ́⁴lieey³² fáh⁴lí³ chiáh² Ñuyh⁴ nɨ³. ¿He² na²nɨ¹ chiáh² liáh⁴jɨ³ hi³ ma³jmeéy⁴ nɨ³ naa³ah³ hi²chiuh⁴ah³ jniá³ na¹cu̱ú̱¹ nɨ³?
\p 
\v 33 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³:
\p ―Há⁴ja̱³ vih²chiaah¹ hi³ dxú⁴ hi³ ma³jmeéy¹ nɨ³, hi³ja̱³ nɨ³ hi²chiuh⁴²ah¹ niu³. Hi³ fáh⁴ hi³ ca³bi³cuaá¹u³ Dios nɨ³ ba² nɨ³. Dsa³ jmɨɨyh⁴²güii³ ba² niu³, joó⁴ ga³jme³²u³ vo̱ó̱h²u³ Dios.
\p 
\v 34 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Ñi² xi³ chiáh² ley chia̱á̱²ah³ nɨ³ dsa³féh³ hi³ liáh³la³ gá⁴féh³ Dios: “Niaá⁴ah³ na³lɨ́⁴ah³ dioses”, liáh³ja̱³ dsa³féh³ xɨ² haá².
\v 35 Dios nɨ³ cá⁴bí⁴chié̱y³ niaá⁴ah³ “dioses”, niaá⁴ah³ hi³ gá⁴tɨ̱́³ah³ fáh⁴liu⁴ chiáh² ja̱³. Baáy⁴ nia⁴²a² hi³ há⁴hé³ hí⁴jooy³ hí⁴dsá⁴yeéy⁴ liáh³xɨ³ na³xɨɨ² ja̱³.
\v 36 Hi³ja̱³ xɨ³ nɨ³ Ñúh³a² nɨ³ gá⁴dxɨy³ jniá³ baáy⁴ gá⁴xɨ́y⁴ jniá³ jmɨɨyh⁴²güii³ la³, ¿he²chiaah¹ hi³ ga³fáh³ah³ hi³ ma³bi³cuaa⁴²á² Dios nɨ³, nɨɨh¹ hi³ ga³fayh⁴ hi³ na³lɨ́⁴á⁴ Ja̱á̱² ba² nɨ³?
\v 37 Xɨ³ nɨ³ há⁴hé³ jmeey⁴ liáh³xɨ³ ga³jmee⁴ Ñuyh⁴ nɨ³, mɨ²ja̱³ há⁴hé³ ga³jmee⁴ gua³taá³ah³ chieéy⁴.
\v 38 Joó⁴ xɨ³ jmeey⁴ ba² ja̱³ba² liáh³xɨ³ ga³jmee⁴ Ñuyh⁴ nɨ³, mɨ²ja̱³ gua³taá³ah³ hi³ he̱é̱yh³ ba² fáh⁴lí³ chiáh² Ñuyh⁴ hi³ ga³jmeey⁴ nɨ³, gu³xɨ³ ba² há⁴hé³ ca³gua³taá³ah³ chieéy⁴ jniá³. Chiaah¹ liáh³ja̱³ hí⁴dsaá⁴ há²ah³ hi³ he̱é̱yh³ ba² hi²xiáh³ chia̱a̱h⁴²á² Fii³²a².
\p 
\v 39 Liáh³ gá⁴féh³ liáh³ja̱³ Jesús ja̱³ mɨ²ja̱³ cá⁴dah²laá⁴ mɨ³hí⁴dah²güeéyh², joó⁴ há⁴hé³ gá⁴jooy³ cá⁴dah²sa̱yh³².
\p 
\v 40 Mɨ²ja̱³ ŋaá² ca̱á̱h³ Jesús ja̱³ ca³jaa¹ xi² yéy⁴ ñíh² ji̱h²jmɨɨ³ Jordán ja̱³ duh³ gá⁴cueeyh⁴ nɨɨ́⁴, ja̱³ba² xi² gá⁴xeey³ jmɨɨ³ diáh⁴ dsa³ Juan ja̱³.
\v 41 Hi²xiáh³ fɨɨ́y⁴ diáh⁴ dsa³ dah²ya²joóy¹ Jesús ja̱³ baáy⁴ liáh³la³ cá⁴dah²féh³:
\p ―He̱é̱yh³ ba² jɨɨ⁴ hi³ gá⁴liú³ Juan ca³jaa¹ chiáh² dsa³ la³, gu³xɨ³ ba² há⁴hé³ gá⁴jmeé³ cáh³ti³² fáh⁴lí³.
\p 
\v 42 Hi³ja̱³ hi²xiáh³ fɨɨ́y⁴ dsa³ gá⁴taáy³ chiáh² Jesús ja̱³ ji̱h²jmɨɨ³ Jordán ja̱³.
\c 11
\s1 La³ dsa³féh³ hi³ jú̱y⁴ Lázaro
\p 
\v 1 Ca̱á̱h³ tiaah² ja̱³ cá⁴lɨ́⁴dsaah⁴² ja̱y³ dsa³ hi³ xɨ̱ɨ̱y³ Lázaro, dsa³ fɨɨ³ Betania, ja̱³ba² fɨɨ³ xi² jey¹ María chie̱é̱yh¹ Marta ja̱á̱¹ ja̱³.
\v 2 Hí̱³ba² María, mɨ́⁴oóyh² Lázaro ja̱³ ñií¹ ca̱á̱h³ tiaah² ya²xuúh⁴ naa⁴²jmɨɨ³ mɨ³fɨɨ³ diáh⁴ tɨɨ² Jesús ja̱³, ja̱³ba² cá⁴bí⁴chiu̱u̱³ chie̱é̱yh¹ jñu³ dxɨ².
\v 3 Hi³ja̱³ liú⁴u³ aáy⁴ diáh⁴ mɨ́⁴oóyh² Lázaro ja̱³ cá⁴dah²xɨ́y⁴ ja̱y³ dsa³, duh³ liáh³la³ ya²xɨɨh⁴² Jesús ja̱³:
\p ―Ñuyh⁴, na³caayh³² dsaah⁴² amigo chiú̱h²u³ nɨ³.
\p 
\v 4 Liáh³ gá⁴nuú³ hi³ja̱³ Jesús ja̱³, mɨ²ja̱³ liáh³la³ gá⁴féh³:
\p ―Há⁴ja̱³ dsaá¹ hi³ hí⁴jú̱y³ nɨ³ dsa³ nɨ³, duh³ hí⁴lii⁴ hi³ bií⁴ hee⁴ fáh⁴lí³ Dios ba² nɨ³. Baá⁴ ba² duh³ hí⁴lii⁴ hi³ haay⁴ fáh⁴lí³ jniá³ Ja̱á̱² Dios nɨ³, hi³ja̱³ ba² nɨ³ chie̱é̱yh¹ dsaá¹ dsa³ nɨ³.
\p 
\v 5 Hi²xiáh³ niaá² Jesús ja̱³ nieéy² Marta chie̱é̱yh¹ María baáy⁴ Lázaro ja̱³.
\v 6 Gu³xɨ³ ba² cá⁴dah²sɨɨ́h⁴ hi³ dsaah⁴² Lázaro ja̱³, joó⁴ gá⁴cueeyh⁴ gɨh¹ tú̱⁴ jmɨɨ́¹ xi² jey¹ ja̱³.
\v 7 Dsa³cɨ̱ɨ̱y³ liáh³ja̱³ ba² ja̱³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹ diáh⁴ xɨh³chie̱y³² ja̱³:
\p ―Má⁴dxia⁴²a² ca̱á̱h³ vó⁴ Judea nɨ³.
\p 
\v 8 Mɨ²ja̱³ liáh³la³ gá⁴xɨɨh²ah¹:
\p ―Dsa³he⁴, hi³du³ lɨ́⁴ ba² ja̱³ cá⁴dah²laá⁴ mɨ³hí⁴dah²jɨ̱́yh⁴ niu³, hi³ hí⁴dah²chiúyh² niu³ na¹cu̱ú̱¹ diáh⁴ israelitas nɨ³. ¿Jmiih⁴² ja̱³ hi³ dɨ²guaáy³ ca̱á̱h³ nɨ³?
\p 
\v 9 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―¿Xɨ² há⁴ja̱³ dxiá⁴tiú̱³ horas xa³ hi³ ca̱a̱³ jmɨɨ́¹? Liu³u²xɨ³ hí̱³ hí⁴chié⁴ hí⁴ji̱í̱⁴ jmɨɨ⁴ mɨ²ja̱³ há⁴hé³ hí⁴nieéy², chiaah¹ hi²xiáh³ dxú⁴ lii⁴.
\v 10 Joó⁴ liu³u²xɨ³ hí̱³ hí⁴chié⁴ hí⁴ji̱í̱⁴ mɨ² voo⁴, mɨ²ja̱³ foóh¹ hí⁴nieéy² chiaah¹ hi²xiáh³ ñu³ha̱a̱h³.
\p 
\v 11 Liáh³ ma³féh³ liáh³ja̱³, mɨ²ja̱³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³:
\p ―Ma³guɨ̱ɨ̱y³ Lázaro amigo chia̱a̱⁴²a² nɨ³, joó⁴ ñii⁴ ya³ñi⁴²á².
\p 
\v 12 Mɨ²ja̱³ liáh³la³ gá⁴xɨɨh²ah¹ jniaah¹ diáh⁴ xɨh³chie̱y³² ja̱³:
\p ―Ñuyh⁴, hi³ mɨ³dsa³váy² chiáh² ba² nɨ³, hi³ja̱³ ba² nɨ³ na³guɨ̱ɨ̱y³ nɨ³.
\p 
\v 13 Gá⁴feh²ah¹ liáh³ja̱³ chiaah¹ ji̱i̱³²ah¹ jniaah¹ hi³ he̱é̱yh³ ba² hi³ na³guɨ̱ɨ̱y³ ba² ja̱³ ga³he⁴ Jesús ja̱³, joó⁴ hi³ ma³ju̱y⁴ ba² ja̱³ ga³he⁴.
\v 14 Mɨ²ja̱³ gá⁴féh³ jɨy³ cáh³ti³² Jesús ja̱³, liáh³la³ gá⁴féh³:
\p ―Ma³ju̱y⁴ Lázaro nɨ³.
\v 15 Hi²xiáh³ naáy⁴ hi³ há⁴ja̱³ nɨ³ je¹á² liáh³ ma³ju̱y⁴ nɨ³, chiaah¹ dxú⁴ gɨh¹ chia̱á̱²ah³, duh³ hu̱² dsá⁴taá³ah³ gɨh¹ dxú⁴. Hi³ja̱³ má⁴dxia⁴²a² má⁴joo⁴²a².
\p 
\v 16 Mɨ²ja̱³ ja̱y³ oóh²ah¹ hi³ xɨ̱ɨ̱y³ Tomás hi³ ga³sɨɨ́h⁴ah¹ xɨh³su̱u̱⁴², liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Ba² má⁴dxia⁴²a² ji̱í̱⁴ jnia² duh³ hí⁴jú̱³a² chia̱a̱h²a² xa³ja̱³.
\s1 Jesús nɨ³ hí⁴jooy³ hí⁴bí⁴ji̱i̱yh³ diáh⁴ dsa³jú̱y¹
\p 
\v 17 Liáh³ gá⁴dxaá² Jesús ja̱³ fɨɨ³ Betania, mɨ²ja̱³ gá⁴dsaá⁴ dsɨ́² hi³ mɨ³xa³ chiú̱³ jmɨɨ́¹ hi³ mɨ³na³haay⁴ Lázaro ja̱³.
\v 18 Mɨ³ji̱í̱³ yeey⁴ Jerusalén niaá² fɨɨ³ Betania ja̱³, ca̱³liáh³ tú̱⁴ kilómetros dsɨ³² tú̱⁴dsaáh² ba² xa³.
\v 19 Hi²xiáh³ fɨɨ́y⁴ diáh⁴ israelitas dɨ³nieeyh⁴² chiáh² Marta chie̱é̱yh¹ María ja̱³, hi³ dah²bi³jee⁴ dsɨ́² diáh⁴ chiáh² hi³ jú̱y⁴ Lázaro ja̱á̱¹ diáh⁴ ja̱³.
\v 20 Liáh³ gá⁴dsaá⁴ dsɨ́² Marta ja̱³ hi³ ma³dxaá² Jesús ja̱³, mɨ²ja̱³ ñií¹ ya²tiee³, joó⁴ gá⁴cueeyh⁴ xɨ¹ñúh⁴ ba² María ja̱³.
\v 21 Hi³ja̱³ liáh³ gá⁴ji̱i̱h⁴ Jesús ja̱³ mɨ²ja̱³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴:
\p ―Ñuyh⁴, há⁴hé³ jú̱y⁴ ja̱a̱y³² nɨ³ liu³u²xɨ³ hu̱² je¹u³ la³ liáh³ rúh⁴ dsaah⁴².
\v 22 Joó⁴ gu³xɨ³ ba² jmiih⁴ liáh³ja̱³ yáh¹, hí⁴cuoó⁴ ba² niu³ Dios nɨ³ jɨɨ⁴ lɨ́⁴ hi³ hi²ŋɨɨyh¹.
\p 
\v 23 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Hí⁴ji̱i̱h⁴ ba² ca̱á̱h³ ja̱á̱y¹ nɨ³.
\p 
\v 24 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Marta ja̱³:
\p ―Ja̱a̱¹, maay⁴ ba² hi³ hí⁴ji̱i̱h⁴ ca̱á̱h³ mɨ² mɨ³hí⁴ji̱i̱h⁴ diáh⁴ dsa³jú̱y¹, mɨ² mɨ³hí⁴hɨɨ́⁴ gɨh¹ ñi² jmɨɨyh⁴²güii³.
\p 
\v 25 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ Marta ja̱³:
\p ―Jniá³ nɨ³ hi²bi³ji̱i̱h⁴²á⁴ ca̱á̱h³ diáh⁴ dsa³ jmɨɨyh⁴²güii³ baáy⁴ hi²cuoó⁴á⁴ diáh⁴ ca̱á̱h³ fáh⁴ji̱í̱h⁴. Dsa³ hi³ dsá⁴taáy³ chieéy⁴, hi³hí̱³ hí⁴ji̱i̱h⁴ ca̱á̱h³ gu³xɨ³ ba² hí⁴jú̱y³.
\v 26 Baáy⁴ gu³xɨ³ hí̱³ba² hi³ rúh⁴ na³ji̱í̱yh⁴ baáy⁴ ca³dsa³taáy³ chieéy⁴, hi³hí̱³ há⁴hé³ jlɨ́h³ jmɨɨ́¹ hí⁴jú̱y³. ¿Xɨ² ca³gua³taá³u³ hi³ ga³fooh³²á⁴ niu³ la³?
\p 
\v 27 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Marta ja̱³:
\p ―Ja̱a̱¹, Ñuyh⁴, ca³dsa³taá³á⁴ ba² hi³ niu³ nɨ³ Cristo, Ja̱á̱² Dios, hi³ ná⁴lɨ¹ cua̱a̱y¹ná² hí⁴güéy³ jmɨɨyh⁴²güii³ la³.
\s1 Gá⁴chíh⁴ Jesús ja̱³ haah² he̱e̱³ chiáh² Lázaro
\p 
\v 28 Dsa³cɨ̱ɨ̱y³ liáh³ gá⁴féh³ liáh³ja̱³ Marta ja̱³, mɨ²ja̱³ ñéyh¹ ya²jey³ María ja̱á̱¹ ja̱³, duh³ liáh³la³ gá⁴sɨɨ́h⁴ ca̱a̱³ há⁴ tiaah² dxɨ́³:
\p ―Ma³güey⁴ la³ Dsa³he⁴ nɨ³, baáy⁴ te³² teé⁴ niu³.
\p 
\v 29 Xé̱yh² ba² liáh³ gá⁴nuú³ hi³ja̱³ María ja̱³, mɨ²ja̱³ ŋaá² dxá⁴joóy¹ Jesús ja̱³.
\v 30 Há⁴hé³ ma³tɨ́³ ma³hí³ jee⁴² fɨɨ³ Jesús ja̱³, rúh⁴ hiíy⁴ xi² gá⁴ji̱i̱h⁴ Marta ja̱³ ba².
\v 31 Xɨ¹ñúh⁴ chiáh² María ja̱³ dɨ³nieeyh⁴² diáh⁴ israelitas hi³ dah²bi³jee⁴ dsɨ́² María ja̱³. Hi³ja̱³ liáh³ cá⁴dah²joóy² hi³ ca̱a̱³tiá³ ca̱a̱³bí³ ba² cá⁴bí⁴hɨɨ́y⁴ María ja̱³, mɨ²ja̱³ gá⁴dxí̱⁴ diáh⁴ chie̱é̱yh¹, chiaah¹ dah²ta³ dah²hɨ³ hi³ ŋaá² María ja̱³ cá⁴dxá⁴jláy¹ haah² he̱e̱³ chiáh² Lázaro ja̱³.
\p 
\v 32 Joó⁴ liáh³ gá⁴dxaá² María xi² hiíy⁴ Jesús ja̱³, mɨ²ja̱³ gá⁴xɨ́h² ji̱² rúh⁴ñi² Jesús ja̱³, baáy⁴ duh³ liáh³la³ gá⁴sɨɨ́h⁴:
\p ―Ñuyh⁴, há⁴hé³ jú̱y⁴ ja̱a̱y³² nɨ³ liu³u²xɨ³ hu̱² je¹u³ la³.
\p 
\v 33 Liáh³ gá⁴joó² Jesús ja̱³ hi³ jlay³² María ja̱³, baá⁴ ba² dah²jlay³² diáh⁴ israelitas hi³ chie̱é̱yh¹ ja̱³, mɨ²ja̱³ hi²xiáh³ ba³ gá⁴bɨ́² fáh⁴ji̱í̱h⁴ chiáh² hi³ bií⁴ fɨɨh⁴² dsɨ́²,
\v 34 hi³ja̱³ gá⁴ŋɨɨ́h⁴ diáh⁴ juúh⁴:
\p ―¿Xiah² nɨ³ gá⁴haa⁴²ah³ nɨ³?
\p Mɨ²ja̱³ liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―Ñuyh⁴, ña³ duh³ má⁴joo⁴²a².
\p 
\v 35 Mɨ²ja̱³ gá⁴chíh⁴ Jesús ja̱³.
\v 36 Hi³ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³:
\p ―Hi²xiáh³ dɨ́h¹ nieéy² dsa³juú¹ nɨ³.
\p 
\v 37 Joó⁴ liáh³la³ ba² cá⁴dah²féh³ ta̱á̱²dsɨy⁴²:
\p ―Cá⁴bí⁴lieéy³ dsa³ tuu², hi³ja̱³ xɨ² há⁴hé³ xa³ hi³ lií² gá⁴jmeé³ duh³ há⁴hé³ jú̱y⁴ Lázaro nɨ³.
\s1 La³ dsa³féh³ hi³ cá⁴lɨ́⁴ji̱i̱h⁴ Lázaro ja̱³
\p 
\v 38 Jmɨ́yh³ dsɨ́² lɨ́⁴ dɨ́h¹ fɨɨh⁴² dsɨ́² ca̱á̱h³ Jesús ja̱³, ja̱³ba² cá⁴dxá⁴jé̱yh⁴ haah² he̱e̱³ ja̱³. Ca̱a̱³ cu³haah³ ba² he̱e̱³ ja̱³, hi³ja̱³ xa³ dxaáh² ca̱a̱³ na¹cu̱ú̱¹ hi³ na³jnɨ⁴ haah² ja̱³.
\v 39 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴ dsa³ ja̱³:
\p ―Je̱h⁴²ah³ na¹cu̱ú̱¹ la³ hi²nia⁴²a².
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ Marta ja̱á̱¹ lɨ² Lázaro ja̱³:
\p ―Ñuyh⁴, joó⁴ mɨ³jmeéyh² mɨ³juuy³ chiaah¹ mɨ³xa³ chiú̱³ jmɨɨ́¹ nɨ³ hi³ gá⁴jú̱y⁴.
\p 
\v 40 Joó⁴ mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ Marta ja̱³:
\p ―Ma³foóh²á⁴ ba² niu³ hi³ liu³u²xɨ³ ca³gua³taá³u³ chiáh² Dios, mɨ²ja̱³ hi²joóy³ liáh³xɨ³ bií⁴ hee⁴ fáh⁴lí³.
\p 
\v 41 Mɨ²ja̱³ cá⁴dah²jé̱yh² na¹cu̱ú̱¹ ja̱³. Liáh³ ma³dah²jé̱yh² ja̱³ mɨ²ja̱³ gá⁴joó² yuuh¹ güii³ Jesús ja̱³ duh³ gá⁴liúy² Dios, liáh³la³ gá⁴féh³:
\p ―Ñuyh⁴, jmɨ²heé¹u³ chiaah¹ hi³ ga³nuuy³ jɨɨ⁴ hi³ ga³ŋɨɨy⁴ chiú̱h²u³ nɨ³.
\v 42 Maay⁴ ba² hi³ ga³nuuy³ chieéy⁴, joó⁴ ga³liu⁴²á² niu³ duh³ hí⁴dah²joó² diáh⁴ dsa³ hi³ na³ta̱a̱y⁴ la³, duh³ hu̱² dsá⁴taáy³ diáh⁴ hi³ he̱é̱yh³ ba² niu³ nɨ³ gá⁴xɨ́⁴u³ jniá³.
\p 
\v 43 Dsa³cɨ̱ɨ̱y³ liáh³ gá⁴liú³ ja̱³, mɨ²ja̱³ gá⁴liú³ chiu̱u̱³ cáh³ti³² liáh³la³ gá⁴féh³:
\p ―¡Lázaro, bi³hɨɨ́y⁴ nɨ³! \fig Juan 11:43|src="CN01768B.TIF" size="span" ref="San Juan 11:43"\fig*
\p 
\v 44 Mɨ²ja̱³ cá⁴bí⁴hɨɨ́y⁴ dsa³jú̱y¹ ja̱³, ná⁴ñuu¹ diáh⁴ guaa³tɨɨ², ná⁴lieéy¹ sɨ̱ɨ̱yh² mɨh³ baá⁴ ba² ná⁴liaá¹ ñi²dxɨ². Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴ dsa³ ja̱³:
\p ―Ji̱i̱h⁴²ah³ duh³ cua²dxéyh³ chiáh².
\s1 Cá⁴dah²dxá³ dxú⁴ hi³ hí⁴dah²jɨ̱́yh⁴ Jesús ja̱³
\r (Mt. 26:1-5; Mr. 14:1-2; Lc. 22:1-2)
\p 
\v 45 Hi²xiáh³ fɨɨ́y⁴ diáh⁴ israelitas hi³ dah²ya²dxí̱⁴ dah²ya²ñi³ María ja̱³, gá⁴taáy³ chiáh² Jesús liáh³ cá⁴dah²joó² liáh³xɨ³ gá⁴jmeé³ Jesús ja̱³.
\v 46 Joó⁴ ta̱á̱²dsɨy⁴² dah²ya²dxí̱⁴ dah²ya²ñi³ diáh⁴ fariseos, duh³ dah²ya²xɨɨh⁴² liáh³xɨ³ gá⁴jmeé³ Jesús ja̱³.
\v 47 Mɨ²ja̱³ gá⁴ŋɨɨyh⁴ diáh⁴ fariseos baáy⁴ diáh⁴ jmii³dsa³ cáyh¹, chie̱é̱yh¹ diáh⁴ hi³ na³ta̱a̱y⁴ ñi² chiáh² diáh⁴ ja̱³, duh³ liáh³la³ cá⁴dah²féh³:
\p ―¿Jmiih⁴² hi²jmee²a²? Chiaah¹ ña²hé³ ba² jmee⁴ dsaá⁴ nɨ³, hi³ dɨ́h¹ ca̱a̱³ fáh⁴lí³.
\v 48 Liu³u²xɨ³ hi²cuo²a² je² dsá⁴hɨɨ́² jmee⁴ chiáh² liáh³nɨ³, mɨ²ja̱³ liáh⁴jɨy³ bɨh¹ dsá⁴taáy³ chiáh². Mɨ²ja̱³ gɨh¹ hí⁴bí⁴dxí̱⁴ diáh⁴ autoridad romana nɨ³ hí⁴dah²yeéy² guah³ chiaa⁴²a² baáy⁴ hí⁴dah²yeéy² fɨɨ³ chiaa⁴²a² la³.
\p 
\v 49 Joó⁴ ja̱y³ hi³ xɨ̱ɨ̱y³ Caifás hi³ na³lɨ́y⁴ fii² diáh⁴ jmii³dsa³ ji̱i̱³ mɨ²ja̱³, liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ diáh⁴ dsa³ ja̱³:
\p ―Há⁴hé³ maá³ah³ cáh³ti³² xɨ³hé³ja̱³ niaá⁴ah³.
\v 50 Ba² há⁴hé³ ga³ca̱³ah³ cua̱a̱y¹ná² hi³ dxú⁴ gɨh¹ chiaa⁴²a², hi³ ja̱y³ ba² dsa³ hí⁴jú̱y³ dxa²a² liáh⁴jɨ³²a² dsa³ fɨɨ³, duh³ há⁴hé³ hí⁴dsá⁴yeéy⁴ na³ca̱á̱y⁴ vó⁴ chiaa⁴²a² la³.
\p 
\v 51 Joó⁴ ba² há⁴ja̱³ hi³ lɨ́³ dsɨ́² ñaá² ja̱³ gá⁴féh³ liáh³ja̱³ Caifás ja̱³, Dios ba² ja̱³ cá⁴bí⁴jmeéy³, chiaah¹ hi³ na³lɨ́y⁴ fii² diáh⁴ jmii³dsa³ ji̱i̱³ mɨ²ja̱³. Cá⁴bí⁴jmeé³ Dios ja̱³ hi³ hí⁴jmeé⁴ juúh⁴ hi³ Jesús ja̱³ ga³jmee⁴ hí⁴jú̱y³ dxa² diáh⁴ israelitas.
\v 52 Baáy⁴ há⁴ja̱³ ti̱¹ chiáh² diáh⁴ dsa³ vó⁴ chiaa⁴²ah¹ ja̱³ hí⁴jú̱y³ Jesús. Ba² hí⁴jú̱y³ duh³ hí⁴jooy³ hí⁴ñiih⁴ ca̱a̱³ hí¹ chie̱é̱yh¹ diáh⁴ ja̱á̱² Dios hi³ na³saa⁴ na³jay⁴ jee⁴² jmɨɨyh⁴²güii³.
\v 53 Hi³ja̱³ xé̱yh² ba² mɨ²ja̱³ cá⁴dah²dxá³ dxú⁴ diáh⁴ autoridades ja̱³ hi³ hí⁴dah²jɨ̱́yh⁴ Jesús ja̱³.
\p 
\v 54 Hi³ja̱³ há⁴hé³ máh⁴ chie⁴ji̱i̱⁴ jí̱⁴ñí³ Jesús ja̱³ jee⁴² chiáh² diáh⁴ israelitas. Na³fáyh⁴ cá⁴bí⁴hɨɨ́y⁴ vó⁴ Judea, duh³ ŋaá² fɨɨ³ hi³ xɨ̱ɨ̱y³ Efraín hi³ niaá² yeey⁴ vó⁴ cueh³chiu̱u̱³ gɨh¹ ba². Nɨɨ́⁴ gá⁴cueeyh⁴ chie̱é̱yh¹ jniaah¹ diáh⁴ xɨh³chie̱y³² ja̱³.
\p 
\v 55 Ca̱a̱³tú̱⁴ jmɨɨ́¹ bɨh¹ jmee⁴ hi³ hí⁴tɨ́⁴ jmɨ́¹feh⁴ chiaa⁴²ah¹ jniaah¹ israelitas hi³ ga³cuh³²ah¹ mɨ¹ja̱á̱² dsɨɨ³jaa³ ja̱³, hi³ja̱³ hi²xiáh³ fɨɨ́y⁴ diáh⁴ dsa³ liáh³ca̱a̱³ fɨɨ³ liáh³ca̱a̱³ fɨɨ³ gá⁴dxí̱⁴ jmɨɨ́¹ dsa³jéy⁴ Jerusalén ja̱³, hi³ hí⁴dah²bi³xɨ³ hí⁴dah²bi³ŋɨɨ́y³ mii⁴ diáh⁴ chiáh² jmɨ́¹feh⁴ ja̱³.
\v 56 Dah²chie⁴ dah²ji̱i̱⁴ dah²naayh³² Jesús ja̱³ xi² jey¹ guah³ gaáy³ ja̱³, ba² dah²ŋɨɨ́h⁴ juúh⁴ oóyh² diáh⁴, liáh³la³ dah²féh³:
\p ―¿Jmiih⁴² ga³ji̱i̱³²ah³? ¿Xɨ² foóh¹ hí⁴güéy³ jmɨ́¹feh⁴ la³, ha²xɨ² haá²?
\p 
\v 57 Cá⁴dah²taáh⁴ ta² diáh⁴ fariseos ja̱³ chie̱é̱yh¹ diáh⁴ jmii³dsa³ cáyh¹, hi³ liu³u²xɨ³ xe̱y³ hi³ ñi³² xiah² chie⁴ji̱i̱⁴ Jesús ja̱³, mɨ²ja̱³ ga³jmee⁴ hí⁴dah²féh³, duh³ja̱³ hí⁴jooy³ hí⁴dah²güeéyh².
\c 12
\s1 Ja̱y³ mɨ́³ gá⁴xuuyh³ naa⁴²jmɨɨ³ Jesús ja̱³
\r (Mt. 26:6-13; Mr. 14:3-9)
\p 
\v 1 Jñuú³ jmɨɨ́¹ gɨh¹ jmee⁴ hí⁴tɨ́⁴ jmɨ́¹feh⁴ hi³ ga³cuh³²ah¹ mɨ¹ja̱á̱² dsɨɨ³jaa³ ja̱³, mɨ²ja̱³ gá⁴dxaá² Jesús ja̱³ fɨɨ³ Betania, xi² jey¹ Lázaro, hí̱³ba² hi³ cá⁴bí⁴ji̱i̱yh³ Jesús ja̱³.
\v 2 Nɨɨ́⁴ cá⁴dah²jmeé³ ca̱a̱³ máh⁴liaá⁴ chiáh². Marta ja̱³ jniaa³ comida ja̱³ ñiíh² mesa, ba² caayh³² Lázaro ja̱³ jee⁴² chiáh² diáh⁴ hi³ dah²eeh³² chie̱é̱yh¹ Jesús ja̱³.
\v 3 Mɨ²ja̱³ gá⁴cá̱⁴ María ja̱³ tú̱⁴dsaáh² litro naa⁴²jmɨɨ³ hi³ mɨ³fɨɨ³, hi³ xɨ̱ɨ̱y³ nardo, baáy⁴ jmáyh² ba² hi³ja̱³ cua̱a̱y¹ná² gaáy³ dɨ́h¹ chi̱í̱⁴. Mɨ²ja̱³ gá⁴huúh⁴ tɨɨ² Jesús ja̱³, duh³ cá⁴bí⁴chiu̱u̱³ chie̱é̱yh¹ jñu³ dxɨ². Na³ca̱á̱y⁴ lɨ́⁴ xɨ¹ñúh⁴ ja̱³ cá⁴yá⁴niaá⁴ ñii² naa⁴² ja̱³.
\v 4 Mɨ²ja̱³ liáh³la³ gá⁴féh³ ja̱y³ oóh²ah¹ hi³ xɨ̱ɨ̱y³ Judas Iscariote, ja̱á̱² Simón ja̱³, hí̱³ba² hi³ mɨ³hí⁴nɨɨ́y⁴ Jesús ja̱³ xiáh³ rúh⁴cáh⁴:
\p 
\v 5 ―Na³fáyh⁴ gɨh¹ hu̱² ma³nɨɨ́³ ba² naa⁴² nɨ³ mɨ́³ nɨ³, chiaah¹ hí⁴cɨ̱ɨ̱́y⁴ nɨ³ ñá⁴laá³ denarios, baáy⁴ duh³ xa³ dsa³tia̱a̱² chiáh² diáh⁴ dsa³tieey³ hu̱² liáh³ja̱³.
\p 
\v 6 Há⁴ja̱³ hi³ he̱é̱yh³ ba² hi³ nieéy² diáh⁴ dsa³tieey³ ja̱³ Judas ja̱³ hi³ gá⁴féh³ liáh³ja̱³, hi³ fáh⁴ hi³ na³lɨ́y⁴ dsa³ hi̱i̱³ ba² ja̱³. Chiaah¹ ñaá² ja̱³ ná⁴tayh¹ guaa³ xa̱h³ mɨh³tuh³ hi³ tiaah² cuu² chiaa⁴²ah¹, hi³ja̱³ ga³hi̱i̱⁴ hi³ tiaah² he̱é̱yh³ mɨh³tuh³ ja̱³.
\v 7 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Tiúy⁴ há⁴ hi³caah⁴u³ mɨ́³ nɨ³, chiaah¹ hi³ niaáh² mɨ² mɨ³hí⁴haá⁴á⁴ ba² nɨ³ ma³jniaa³ dxú⁴ naa⁴²jmɨɨ³ nɨ³.
\v 8 Ca̱³ñiih³² ba² hí⁴ji̱i̱h⁴ah³ niaá⁴ah³ diáh⁴ dsa³tieey³, joó⁴ há⁴hé³ máh⁴ hi²cueeh⁴²á⁴ jniá² voó³ chia̱a̱h⁴²á² niaá⁴ah³.
\s1 Ba² cá⁴dah²dxá³ dxú⁴ hi³ hí⁴dah²jɨ̱́yh⁴ Lázaro
\p 
\v 9 Hi²xiáh³ fɨɨ́y⁴ diáh⁴ israelitas ja̱³, gá⁴dsaá⁴ dsɨ́² hi³ jey¹ Jesús ja̱³ fɨɨ³ Betania, hi³ja̱³ dah²ya²dxí̱⁴ nɨɨ́⁴. Há⁴ja̱³ ti̱¹ ba² hi³ dɨ́⁴dah²joóy² Jesús ja̱³, ba² dɨ́⁴dah²joóy² Lázaro, hi³ cá⁴bí⁴ji̱i̱yh³ Jesús ja̱³.
\v 10 Mɨ²ja̱³ cá⁴dah²dxá³ dxú⁴ diáh⁴ jmii³dsa³ cáyh¹ ja̱³ hi³ ba² hí⁴dah²jɨ̱́yh⁴ ji̱í̱⁴ Lázaro ja̱³.
\v 11 Chiaah¹ hi²xiáh³ fɨɨ́y⁴ diáh⁴ israelitas ja̱³ cá⁴dah²tiúy² diáh⁴ jmii³dsa³ ja̱³ chiaah¹ hi³ gá⁴taáy³ diáh⁴ chiáh² Jesús vih²chiaah¹ Lázaro ja̱³.
\s1 Hi²xiáh³ gaáy³ gá⁴dxaá² Jesús ja̱³ Jerusalén
\r (Mt. 21:1-11; Mr. 11:1-11; Lc. 19:28-40)
\p 
\v 12 Hi²xiáh³ fɨɨ́y⁴ dsa³ gá⁴dxí̱⁴ jmɨ́¹feh⁴ pascua hi³ mɨ³hí⁴tɨ́⁴ Jerusalén ja̱³. Dxaáh² jmɨɨ́¹ liáh³ja̱³ gá⁴dsaá⁴ dsɨ́² diáh⁴ hi³ mɨ³hí⁴dxaá² Jesús ja̱³ fɨɨ³ ja̱³.
\v 13 Mɨ²ja̱³ cá⁴dah²su̱ú̱h⁴ diáh⁴ dsa³ ja̱³ guaa³ mee³ñu³² duh³ gá⁴dxí̱⁴ cá⁴dxá⁴jé̱y¹ diáh⁴ Jesús ja̱³, liáh³la³ dah²féh³ diáh⁴, dah²jla³² dah²te³²:
\p ―¡Hosanna! ¡Cua̱a̱y¹ná² gaáy³ dɨ́h¹ dxúy⁴ hi³ ma³güey⁴ la³ fáh⁴tiaah⁴ ta² chiáh² Ñúh³a² nɨ³! ¡Jmɨ́yh³ Rey chia̱a̱⁴²a² la³!
\p 
\v 14 Gá⁴dsaáyh⁴ Jesús ja̱³ ja̱y³ burro hi³ja̱³ cá⁴bí⁴dxɨy¹ burro ja̱³, ja̱³ba² liáh³xɨ³ dsa³féh³ ñi² xi³ chiáh² Dios. Chiaah¹ liáh³la³ dsa³féh³:
\q1 
\v 15 Há⁴ hi³foh³²ah³ niaá⁴ah³ dsa³ fɨɨ³ Sión.
\q2 Mɨ³je³ Rey chia̱á̱²ah³ nɨ³,
\q2 bí⁴dxɨy¹ ja̱y³ mɨ¹ja̱á̱² burro.
\p 
\v 16 Dsa³jéy⁴ ruh³ há⁴hé³ lɨ́⁴dsaa⁴²ah¹ jmiih⁴² ja̱³ ga³he⁴ hi³ dsa³féh³ liáh³ja̱³. Joó⁴ dsa³cɨ̱ɨ̱y³, liáh³ ma³ŋɨ́³ ma³saayh⁴ Jesús ja̱³ yuuh¹ güii³, mɨ²ja̱³ cá⁴lɨ́⁴liíh⁴ah¹ jɨɨ⁴ hi³ na³xɨɨ² ca³jaa¹ chiáh² ja̱³. Chiaah¹ jɨɨ⁴ liáh³xɨ³ dsa³féh³ ñi² xi³ ja̱³, liáh³ja̱³ ja̱³ gá⁴cɨ̱ɨ̱́yh² Jesús ja̱³.
\p 
\v 17 Diáh⁴ hi³ cá⁴dah²joó² liáh³xɨ³ gá⁴jmeé³ Jesús ja̱³ cá⁴bí⁴ji̱i̱yh³ Lázaro ja̱³, liáh³ gá⁴teé⁴ haah² he̱e̱³ ja̱³, diáh⁴ hi³hí̱³ ja̱³ cá⁴dah²jmeé³ juúh⁴ liáh³xɨ³ ná⁴lɨ¹ cá⁴dah²joó² ja̱³.
\v 18 Hi³ja̱³ ja̱³ gá⁴voóy⁴ diáh⁴ dsa³ ja̱³ dah²ya²jé̱y¹ Jesús ja̱³, chiaah¹ gá⁴dsaá⁴ dsɨ́² diáh⁴ hi³ ca̱a̱³ fáh⁴lí³ ba² ja̱³ cá⁴bí⁴ji̱i̱yh³ Lázaro ja̱³.
\v 19 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ fariseos ja̱³:
\p ―Ma³joo⁴²ah³ ba² hi³ há⁴hé³ lií² xa³ hi²jmee²a² cáh³ti³². Liáh⁴jɨy³ ba² diáh⁴ dsa³ jmɨɨyh⁴²güii³ nɨ³ ma³dxí̱⁴ chie̱é̱yh¹ Jesús nɨ³.
\s1 Ja̱y³aáy⁴ griegos cá⁴dah²naayh³² Jesús
\p 
\v 20 Jee⁴² chiáh² diáh⁴ dsa³ hi³ ma³dxa³dxí̱⁴ jmɨ́¹feh⁴ Jerusalén ja̱³, caayh³² ta̱á̱²dsɨy⁴² diáh⁴ griegos.
\v 21 Mɨ²ja̱³ cá⁴dxá⁴jé̱yh⁴ diáh⁴ griegos ja̱³ rúh⁴ñi² Felipe, dsa³ fɨɨ³ Betsaida, hi³ na³hii⁴ vó⁴ Galilea, duh³ cá⁴dah²ŋɨɨ́³ ca̱a̱³ jmɨ²heé¹ chiáh², liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―Ñuyh⁴, niaa³²ah¹ hi²liu⁴²ah¹ chia̱a̱h²ah¹ Jesús nɨ³.
\p 
\v 22 Mɨ²ja̱³ Felipe ja̱³ gá⁴sɨɨ́h⁴ Andrés, hi³ja̱³ liú⁴u³ aáy⁴ diáh⁴ dah²ya²xɨɨh⁴² Jesús ja̱³.
\v 23 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Ma³dxa³héy³ hiíh⁴ hi³ mɨ³hí⁴lii⁴ hi³ bií⁴ gaáy³ Ja̱á̱² Dsa³ nɨ³.
\v 24 Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³: Liu³u²xɨ³ há⁴hé³ hí⁴haa¹ ca̱a̱³ mɨɨ¹ mɨ¹cuɨɨ³ ya³dsɨ² mɨ²ja̱³ dsa³hɨɨ́² chiáh² ca̱a̱³ liáh³nɨ³. Joó⁴ xɨ³ nɨ³ hí⁴haa¹, mɨ²ja̱³ hí⁴ñuúyh³ cáh³ti³², gu³xɨ³ ba² hí⁴tiuu⁴ hi³ ná⁴lɨ¹ mɨ¹ju̱³ ja̱³.
\v 25 Ba² liáh³ja̱³ xe̱y³ hi³ bií⁴ niaá⁴ chiáh² hi³ xa³ jmɨɨyh⁴²güii³ la³, chiaah¹ hi³ hí⁴tiuu⁴ ba² jmɨɨyh⁴²güii³ chiáh² hi³ liáh³ja̱³. Joó⁴ ja̱y³ hi³ ga³ji̱í̱h⁴ hi³ há⁴hé³ xɨ³hé³ gu³xɨ³ ba² hí⁴tiuu⁴ jmɨɨyh⁴²güii³ chiáh², xiáh³ hi³hí̱³ ba² hí⁴tɨ̱́y⁴ fáh⁴ji̱í̱h⁴ hi³ há⁴hé³ máh⁴ hí⁴jú̱y³.
\v 26 Ja̱y³ hi³ niaá⁴ hí⁴jmeé⁴ ta² chieéy⁴, hi³hí̱³ ga³jmee⁴ dsaa³² fi¹ chieéy⁴ ca̱³ñiih³², duh³ ja̱³ba² xi² ya³güéy⁴ nɨ³, ja̱³ba² nɨ³ hí⁴dsá⁴güe³. Baáy⁴ hí̱³ hí⁴jmeé⁴ ta² chieéy⁴, mɨ²ja̱³ hí̱³ba² ñaá² Ñuyh⁴ nɨ³ hí⁴jmeé⁴ hí⁴lí³ gaáy³.
\s1 Gá⁴jmeé³ juúh⁴ Jesús ja̱³ hi³ hí⁴jú̱y³
\p 
\v 27 ’Hi²xiáh³ ta⁴hɨy⁴ ñuú³ ja̱³nɨ́⁴, há⁴hé³ maay⁴ xɨ³ jmiih⁴ hi²fayh¹. ¿Xɨ²fáh³ hi²fayh¹: “Ñuyh⁴ lieey⁴² jniá³, há⁴ hi³cuoy³ je² hí⁴chi̱í̱h² hí⁴beéh²á⁴”? Haá². Chiaah¹ jmɨ́yh³ hi³ja̱³ gɨh³ nɨ³ güé⁴á⁴ la³.
\v 28 Ñuyh⁴, jmee² lii⁴ hi³ bií⁴ gaá³u³.
\p Mɨ²ja̱³ cá⁴yá⁴niuúh³ hi³ xe̱y³ gá⁴liú³ yuuh¹ güii³ ja̱³ liáh³la³ gá⁴féh³:
\p ―Ma³hoó⁴á⁴ ba² diáh⁴ hi³ bií⁴ gaá³á⁴, baáy⁴ hi²jmeey⁴² ca̱á̱h³ lii⁴.
\p 
\v 29 Mɨ²ja̱³ cá⁴dah²nuú³ diáh⁴ dsa³ hi³ dɨ³nieeyh⁴² nɨɨ́⁴ liáh³ gá⁴liú³ Dios ja̱³. Mɨ²ja̱³ cá⁴dah²féh³ hi³ ma³ŋaa³² ba² ja̱³. Baáy⁴ liáh³la³ dah²féh³ gɨh³ dxeeyh⁴:
\p ―Ja̱y³ ángel ba² nɨ³ ma³liúy² Jesús nɨ³.
\p 
\v 30 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Há⁴ja̱³ hi³ dxú⁴ chieéy⁴ jniá³ nɨ³ hi³ ma³ya³niuúh³ hi³ xe̱y³ ma³liú³ nɨ³, hi³ dxú⁴ chia̱á̱²ah³ niaá⁴ah³ ba² nɨ³.
\v 31 Ja̱³ba² ja̱³nɨ́⁴ mɨ³hí⁴chia̱a̱⁴² cua̱a̱y¹ná² chiáh² jmɨɨyh⁴²güii³. Mɨ³hí⁴jmeeh² ca³jaa¹ ñaá² hi³ ga³chiuuh³² hiíh⁴ jmɨɨyh⁴²güii³ la³.
\v 32 Baáy⁴ jniá³ liu³u²xɨ³ mɨ² ma³dah²xeéy² jniá³ ñií² nɨ³, mɨ²ja̱³ hi²tee¹á² liáh⁴jɨy³ diáh⁴ dsa³ nɨ³ xi² ya³güéy⁴.
\p 
\v 33 Gá⁴féh³ liáh³ja̱³ duh³ lii⁴ liáh³xɨ³ ná⁴lɨ¹ hí⁴lí³ hí⁴jú̱y³.
\v 34 Hi³ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ dsa³ ja̱³:
\p ―Ga³nuu³²ah¹ ba² liáh³xɨ³ dsa³féh³ ley nɨ³, xi² dsa³féh³ hi³ há⁴hé³ hí⁴jú̱y³ Cristo. ¿Jmiih⁴² nɨ³ hi³ ga³fáyh³ niu³ hi³ ga³jmee⁴ hí⁴xeey⁴² ñií² Ja̱á̱² Dsa³ nɨ³? ¿Hi̱² nɨy³² ga³hó⁴u³ hi³ na³lɨ́y⁴ Ja̱á̱² Dsa³ nɨ³?
\p 
\v 35 Liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴ ca̱á̱h³:
\p ―Ca̱³ji̱i̱³ gɨh¹ ba² hí⁴cueeyh⁴ jee⁴² chia̱á̱²ah³ nɨ³ ya⁴²jmɨɨ́⁴. Hi³ja̱³ chie²ji̱í̱¹ah³ liáh³ rúh⁴ xa³ ya⁴²jmɨɨ́⁴ nɨ³, duh³ja̱³ há⁴ja̱³ ca̱a̱³ hí⁴dxá⁴chiá̱¹ah³ ba² xi² ñu³ha̱a̱h³. Chiaah¹ liu³u²xɨ³ ja̱y³ hi³ ga³chie⁴ ga³ji̱i̱y⁴ jee⁴² xi² ñu³ha̱a̱h³, hi³hí̱³ há⁴hé³ ñi³² xɨ³ xiáh³ dsaa³².
\v 36 Hi³ja̱³ ga³jmee⁴ gua³taá³ah³ chiáh² ya⁴²jmɨɨ́⁴ nɨ³ liáh³ rúh⁴ xa³ ya⁴²jmɨɨ́⁴ nɨ³, duh³ hí⁴lí³ah³ dsa³ hi³ xa³ ya⁴²jmɨɨ́⁴ chiáh² ba².
\p Dsa³cɨ̱ɨ̱y³ liáh³ gá⁴féh³ liáh³ja̱³ Jesús ja̱³, mɨ²ja̱³ ŋáyh², cá⁴dxá⁴méyh⁴ duh³ há⁴hé³ máh⁴ hí⁴dah²joóy².
\s1 Há⁴hé³ gá⁴taáy³ diáh⁴ israelitas chiáh² Jesús
\p 
\v 37 Gu³xɨ³ ba² hi²xiáh³ ñuú³ fáh⁴lí³ gá⁴jmeé³ Jesús ja̱³ xi² ca³dah²joo³² diáh⁴ israelitas ja̱³, joó⁴ há⁴hé³ gá⁴taáy³ diáh⁴ chiáh².
\v 38 Hi³ja̱³ gá⁴lɨ́⁴ liáh³xɨ³ ná⁴lɨ¹ gá⁴xɨɨ́³ profeta Isaías, chiaah¹ liáh³la³ gá⁴xɨɨ́³:
\q1 Ñuyh⁴, ¿hi̱² hí̱³ ma³taáy³ fáh⁴liu⁴ chiaa⁴²ah¹ nɨ³?
\q2 ¿Hi̱² hí̱³ ma³joó² liáh³nɨɨh¹ dɨ́h¹ haay³ fáh⁴lí³ nɨ³?
\m 
\v 39 Hi³ja̱³ ba² ja̱³ há⁴hé³ hí⁴jooy³ hí⁴dsá⁴taáy³ diáh⁴ israelitas ja̱³, chiaah¹ ba² liáh³la³ gá⁴xɨɨ́³ Isaías ja̱³:
\q1 
\v 40 Gá⁴jmeé³ Dios nɨ³ gá⁴tuúy³ diáh⁴,
\q2 gá⁴jmeé³ cá⁴lɨ́⁴ba³ dsɨ́² diáh⁴,
\q1 duh³ há⁴hé³ hí⁴dah²joó² na³fáyh⁴,
\q2 duh³ há⁴hé³ hí⁴dsaay⁴ diáh⁴ jmɨ́yh³ fáh⁴ji̱í̱h⁴ chiáh² diáh⁴.
\q1 Baáy⁴ ñé⁴ há⁴hé³ hí⁴dah²tá⁴ hí⁴dah²hɨ́⁴ dxú⁴ duh³ hi²bi³liaá¹á⁴ diáh⁴.
\m 
\v 41 Ca³jaa¹ chiáh² Jesús ja̱³ gá⁴liú³ Isaías hi³ gá⁴féh³ liáh³ja̱³, chiaah¹ gá⁴joó² hi³ bií⁴ gaáy³.
\p 
\v 42 Joó⁴ gu³xɨ³ ba² jmiih⁴ liáh³ja̱³, ba² hi²xiáh³ fɨɨ́y⁴ diáh⁴ israelitas ja̱³ gá⁴taáy³ chiáh² Jesús, ji̱í̱⁴ ta̱á̱²dsɨy⁴² diáh⁴ hi³ na³ta̱a̱y⁴ ñi² chiáh² diáh⁴. Joó⁴ há⁴hé³ ca³dah²taah⁴ dxɨ́³ chiaah¹ dɨ³foyh⁴ ca³dah²jooy³² diáh⁴ fariseos ja̱³. Chiaah¹ xɨ³ hí⁴dah²taáh⁴ dxɨ́³ mɨ²ja̱³ há⁴hé³ máh⁴ hí⁴dah²cuó⁴ je² hi³ dsá⁴dxí̱⁴ diáh⁴ ñuúh⁴guah³ liuh² ja̱³.
\v 43 Chiaah¹ dɨ³niaá⁴ gɨh¹ hi³ hí⁴cueeyh⁴ dxú⁴ rúh⁴ñi² diáh⁴ dsa³ liáh³xɨ³ gɨh³ Dios.
\s1 Fáh⁴liu⁴ chiáh² Jesús nɨ³ hí⁴ca̱a̱⁴ cua̱a̱y¹ná² chiaa⁴²a²
\p 
\v 44 Mɨ²ja̱³ gá⁴liú³ chiu̱u̱³ cáh³ti³² Jesús ja̱³, liáh³la³ gá⁴féh³:
\p ―Ja̱y³ hi³ ca³dsa³taáy³ chieéy⁴, ba² há⁴ja̱³ ti̱¹ ba² chieéy⁴ ca³dsa³taáy³, ba² ca³dsa³taáy³ chiáh² Ñuyh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³.
\v 45 Baáy⁴ ja̱y³ hi³ ga³jooy³² jniá³, ja̱³ba² hi³ ga³jooy³² ñaá² Ñuyh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³.
\v 46 Jniá³ nɨ³ na³lɨ́⁴á⁴ ya⁴²jmɨɨ́⁴, hi³ja̱³ nɨ³ güé⁴á⁴ jmɨɨyh⁴²güii³ la³ duh³ liáh⁴jɨy³ diáh⁴ hi³ hí⁴dsá⁴taáy³ chieéy⁴, há⁴hé³ máh⁴ hí⁴dah²güe³ ñu³ha̱a̱h³.
\v 47 Joó⁴ hi³ ga³nuu³ fáh⁴liu⁴ chieéy⁴ baáy⁴ há⁴hé³ ga³jmee⁴ he̱é̱yh³, há⁴hí̱³ jniá³ nɨ³ hi²ca̱a̱y¹ cua̱a̱y¹ná² chiáh². Chiaah¹ há⁴ja̱³ hi³ güé⁴á⁴ hi³ hi²ca̱a̱y¹ cua̱a̱y¹ná² chiáh² diáh⁴ dsa³ jmɨɨyh⁴²güii³ nɨ³, hi³ güé⁴á⁴ duh³ hi²béy⁴ dsaa² chiáh² diáh⁴ ba² nɨ³.
\v 48 Ja̱y³ hi³ hí⁴féh³ hi³ há⁴hé³ xiáh³ niaáh² jniá³, baáy⁴ há⁴hé³ hí⁴jmeé⁴ he̱é̱yh³ fáh⁴liu⁴ chieéy⁴, mɨ³xa³ ba² hi³ hí⁴ca̱a̱⁴ cua̱a̱y¹ná² chiáh². Ja̱³ba² diáh⁴ fáh⁴liu⁴ hi³ ma³liúy⁴ nɨ³, hi³ nɨ³ nɨ³ hí⁴ca̱a̱⁴ cua̱a̱y¹ná² chiáh², mɨ² mɨ³hí⁴hɨɨ́⁴ gɨh¹ ñi² jmɨɨyh⁴²güii³.
\v 49 Chiaah¹ há⁴ja̱³ hi³ ga³ñii³ dsɨy⁴ ñeéy⁴ nɨ³ hi³ ga³liuy⁴. Ñuyh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³ ba² nɨ³, gá⁴tiéyh² guaay⁴ liáh³xɨ³ ga³jmee⁴ hi²fayh¹ baáy⁴ liáh³xɨ³ hi²hoó⁴á⁴ diáh⁴ dsa³ nɨ³.
\v 50 Baáy⁴ maay⁴ hi³ fáh⁴liu⁴ hi³ ná⁴tayh¹ guaay⁴ nɨ³ hí⁴jmeé⁴ na³ji̱í̱yh⁴ liáh³nɨ³ diáh⁴ dsa³, há⁴hé³ máh⁴ hí⁴jú̱y³ diáh⁴. Hi³ja̱³ liáh³xɨ³ ga³taah⁴ ta² Ñuyh⁴ nɨ³ ba² nɨ³ ga³liuy⁴ nɨ³.
\c 13
\s1 Gá⁴u̱ú̱h² Jesús ja̱³ tɨɨ² diáh⁴ xɨh³chie̱y³²
\p 
\v 1 Jmee⁴ gɨh¹ ca̱a̱³ jmɨɨ́¹ hi³ hí⁴tɨ́⁴ jmɨ́¹feh⁴ hi³ ga³cuh³²ah¹ mɨ¹ja̱á̱² dsɨɨ³jaa³ ja̱³. Hi³ja̱³ mɨ³ñi³² ba² Jesús ja̱³, hi³ ma³dxa³héy³ hiíh⁴ hi³ hí⁴tiú² jmɨɨyh⁴²güii³ la³ duh³ dsayh³² ca̱á̱h³ xi² jey¹ Ñúh³a² Dios. Hi²xiáh³ nieéy² diáh⁴ dsa³ chié̱y², diáh⁴ hi³ dɨ³nieeyh⁴² jmɨɨyh⁴²güii³ la³. Xé̱yh² ba² mɨ²ja̱³ cá⁴bí⁴lii³² gɨh¹ liáh³nɨɨh¹ dɨ́h¹ nieéy² diáh⁴.
\p 
\v 2 Cá⁴dah²guá³ dah²eeh³² máh⁴liaá⁴ baáy⁴ ma³ŋɨ́³ ma³bi³taa³ hi³há⁴dxúy⁴ ja̱³ chiáh² Judas Iscariote, ja̱á̱² Simón, duh³ hí⁴nɨɨ́y⁴ Jesús ja̱³ xiáh³ rúh⁴cáh⁴.
\v 3 Mɨ³ñi³² ba² Jesús ja̱³ hi³ xi² jey¹ Dios ja̱³ güéy⁴, baáy⁴ ja̱³ba² xi² jey¹ Dios ja̱³ dsayh³² ca̱á̱h³. Baáy⁴ ñi³² ba² hi³ ma³tiéyh² Dios ja̱³ guaa³ hi³ hí⁴chiuúh² hiíh⁴ jɨɨ⁴ lɨ́⁴.
\v 4 Hi³ja̱³ gá⁴bɨ́y², ja̱³ba² gá⁴dxɨy³ mɨh³ hi³ dsɨ³² ñiíh² chiáh², duh³ gá⁴ñuúyh⁴ ca̱a̱³ toalla.
\v 5 Mɨ²ja̱³ gá⁴tiáh³ jmɨɨ³ ca̱a̱³ mɨ¹cueh² duh³ gá⁴laá⁴ mɨ³u̱u̱h³² tɨɨ¹ah¹ jniaah¹ diáh⁴ xɨh³chie̱y³², ja̱³ba² cá⁴bí⁴chiu̱u̱³ ca̱á̱h³ chie̱é̱yh¹ toalla hi³ ta̱a̱⁴ rúh⁴ñi² ja̱³.
\p 
\v 6 Liáh³ca̱á̱h³ mɨ³hí⁴u̱ú̱h² tɨɨ² Simón Pedro ja̱³, mɨ²ja̱³ liáh³la³ gá⁴féh³ Pedro ja̱³ gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―Ñuyh⁴, ¿jmiih⁴² ja̱³ xiáh³ hi³ niu³ nɨ³ hi²u̱u̱yh¹ tɨɨy⁴ nɨ³? \fig Juan 13:6|src="CN01800B.TIF" size="span" ref="San Juan 13:6"\fig*
\p 
\v 7 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Há⁴hé³ hí⁴dsaa⁴u³ xé̱yh² la³ he²chiaah¹ hi³ jmeey⁴ liáh³nɨ³, joó⁴ hí⁴dsaa⁴u³ ba² dsa³cɨ̱ɨ̱y³.
\p 
\v 8 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Pedro ja̱³ gá⁴sɨɨ́h⁴:
\p ―Há⁴hé³ jlɨ́h³ jmɨɨ́¹ hi²u̱u̱yh¹ niu³ diáh⁴ tɨɨy⁴ nɨ³.
\p Joó⁴ mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Liu³u²xɨ³ há⁴hé³ hi²u̱ú̱yh⁴ diáh⁴ tɨɨy¹ nɨ³, mɨ²ja̱³ há⁴hé³ máh⁴ xa³ dxéy¹ chia̱á̱h¹u³ jniá³.
\p 
\v 9 Hi³ja̱³ mɨ²ja̱³ gá⁴féh³ Pedro ja̱³ gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―Ñuyh⁴, há⁴ja̱³ ti̱¹ ba² diáh⁴ tɨɨy⁴ nɨ³ xa³ja̱³, ba² u̱ú̱h² ji̱í̱⁴ diáh⁴ guaay⁴, baáy⁴ dxɨy⁴ la³.
\p 
\v 10 Joó⁴ mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Liu³u²xɨ³ ja̱y³ hi³ ma³laáh⁴, ti̱¹ diáh⁴ tɨɨ² ba² nɨɨh¹ ga³jmee⁴ hí⁴u̱u̱h¹, chiaah¹ mɨ³na³xɨ³ na³ŋɨɨ́y³ ba² na³ca̱á̱y⁴ lɨ́⁴. Mɨ³na³xɨ³ na³ŋɨɨ́³ah³ ba² niaá⁴ah³ gu³xɨ³ ba² há⁴ja̱³ liáh⁴jɨ³ah³.
\p 
\v 11 Gá⁴féh³ Jesús ja̱³, há⁴ja̱³ liáh⁴jɨ³²ah¹ ja̱³ na³xɨ³ na³ŋɨɨ́³ah¹ chiaah¹ mɨ³ñi³² ba² hi̱² na²nɨ¹ah¹ jniaah¹ ja̱³ hi²nɨɨ⁴²ah¹ xiáh³ rúh⁴cáh⁴.
\p 
\v 12 Liáh³ ma³jooy³ ma³u̱ú̱h² tɨɨ¹ah¹ ja̱³, mɨ²ja̱³ gá⁴cɨ́h⁴ ca̱á̱h³ mɨh³ hi³ dsɨ³² ñiíh² chiáh², ja̱³ba² gá⁴guá³ ca̱á̱h³ haah² mesa ja̱³, duh³ liáh³la³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―¿Xɨ² dsaa⁴ah³ liáh³xɨ³ ná⁴lɨ¹ hi³ ma³jmeéh⁴á⁴ niaá⁴ah³ nɨ³?
\v 13 Niaá⁴ah³ nɨ³ ga³fooh³²ah³ jniá³ Dsa³he⁴, baáy⁴ Ñuyh⁴. He̱é̱yh³ ba² chia̱á̱²ah³, chiaah¹ he̱é̱yh³ ba² liáh³ja̱³.
\v 14 Hi³ja̱³ xɨ³ nɨ³ jniá³ hi³ na³lɨ́⁴á⁴ Ñúh³ah³ baáy⁴ Dsa³he⁴ chia̱á̱²ah³ nɨ³ ma³u̱ú̱yh⁴ diáh⁴ tɨɨ¹ah³, hi³ja̱³ ba² liáh³nɨ³ ga³jmee⁴ hi²jmee³ah³ niaá⁴ah³.
\v 15 Ma³jmeéy⁴ ñeéy⁴ liáh³xɨ³ ga³jmee⁴ hi²jmee³ah³ duh³ ja̱³ba² liáh³nɨ³ hi²jmee³ah³ chia̱á̱h¹ah³ diáh⁴ oóh²ah³.
\v 16 Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³: Ná⁴ŋɨy¹ gɨh¹ fii² ja̱y³ mozo. Ba² liáh³ja̱³ ja̱y³ hi³ ga³xɨy⁴ dsa³, ná⁴ŋɨy¹ gɨh¹ ñaá² liáh³xɨ³ hi³ ma³xɨ́y⁴ ja̱³.
\v 17 Xɨ³ nɨ³ hí⁴dsaa⁴ah³ hi³la³ baáy⁴ hi²jmee³ah³ he̱é̱yh³, mɨ²ja̱³ cua̱a̱y¹ná² gaáy³ dɨ́h¹ dxú⁴ hí⁴lí³ chia̱á̱²ah³.
\p 
\v 18 ’Há⁴ja̱³ liáh⁴jɨ³ah³ nɨ³ ga³hó⁴á⁴ nɨ³, chiaah¹ maay⁴ ba² hi̱² ga² nɨy³² diáh⁴ hi³ ma³dxɨ́²á⁴ ñeéy⁴. Joó⁴ ga³jmee⁴ hí⁴lí³ liáh³bií⁴ liáh³xɨ³ ná⁴lɨ¹ na³xɨɨ² ñi² xi³ hi³ tiaah² fah² Dios nɨ³, chiaah¹ liáh³la³ na³xɨɨ²: “Hí̱³ba² hi³ ga³eeyh⁴ chia̱a̱h⁴²á² ba² nɨ³, yá⁴chi⁴ chie̱é̱yh¹ jniá³.”
\v 19 Ga³fooh³²á⁴ niaá⁴ah³ hi³la³ dsa³jéy⁴ duh³ liu³u²xɨ³ mɨ² ma³lɨ⁴ liáh³ja̱³, mɨ²ja̱³ hí⁴dsaá⁴ há²ah³ hi³ he̱é̱yh³ ba² na³lɨ́⁴á⁴ hi³ na³lɨ́⁴á⁴.
\v 20 Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³: Liu³u²xɨ³ ja̱y³ dsa³ hí⁴tee³ dxú⁴ ja̱y³ hi³ hi²sɨ́⁴á⁴, hí̱³ba² jniá³ ja̱³ ma³tee³. Baáy⁴ liu³u²xɨ³ ja̱y³ hi³ hí⁴tee³ jniá³, ja̱³ba² hi³ ma³tee³ ñaá² hi³ gá⁴xɨ́y⁴ jniá³ nɨ³ ja̱³.
\s1 Gá⁴féh³ Jesús hi³ Judas ja̱³ hí⁴jmeéh⁴ mɨ³hee³²
\r (Mt. 26:20-25; Mr. 14:17-21; Lc. 22:21-23)
\p 
\v 21 Liáh³ ma³féh³ liáh³ja̱³ Jesús ja̱³, mɨ²ja̱³ gá⁴bɨ́² lɨ́⁴ fáh⁴ji̱í̱h⁴ chiáh² liáh³nɨɨh¹ dɨ́h¹ fɨɨh⁴² dsɨ́². Mɨ²ja̱³ gá⁴féh³ jɨy³ cáh³ti³², liáh³la³ gá⁴féh³:
\p ―Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³: Ja̱³ah³ niaá⁴ah³ hi²nɨɨ́⁴ah³ jniá³ xiáh³ rúh⁴cáh⁴.
\p 
\v 22 Mɨ²ja̱³ mɨ³joo³²ah¹ oóh²ah¹ chiaah¹ há⁴hé³ nia⁴²ah¹ hi̱² hí̱³ ga³hey³² Jesús ja̱³.
\v 23 Ja̱y³ xɨh³chie̱y³² hi³ bií⁴ nieéy² Jesús ja̱³, jey¹ yeey⁴ caayh⁴ Jesús ja̱³ liáh³ chia⁴²ah¹ máh⁴liaá⁴ ja̱³.
\v 24 Mɨ²ja̱³ gá⁴jmeé³ guaa³ Simón Pedro hi³ cua²ŋɨɨ́h⁴ juúh⁴ Jesús ja̱³ hi³ hi̱² na²nɨy¹ ja̱³ ga³hey³².
\v 25 Mɨ²ja̱³ cá⁴dxá⁴jé̱yh⁴ gɨh¹ yeey⁴ caayh⁴ Jesús ja̱³, duh³ gá⁴ŋɨɨ́h⁴ juúh⁴, liáh³la³ gá⁴sɨɨ́h⁴:
\p ―Ñuyh⁴, ¿hi̱² nɨy³² hi³ hí⁴jmeéh⁴ niu³ mɨ³hee³² nɨ³?
\p 
\v 26 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Hi²bi³sɨyh⁴ ca³liuh² hó² ya³dsɨ² duh³ hi²cuoó⁴á⁴. Hi³nɨy³² nɨ³ hí⁴jmeéh⁴ jniá³ mɨ³hee³² nɨ³.
\p Mɨ²ja̱³ cá⁴bí⁴sɨh³ ca³liuh² hó² ya³dsɨ², duh³ gá⁴cuoó⁴ Judas Iscariote, ja̱á̱² Simón ja̱³.
\v 27 Xé̱yh² ba² liáh³ gá⁴cá̱⁴ Judas hó² ya³dsɨ² ja̱³, mɨ²ja̱³ gá⁴sa̱a̱h³² Hi³há⁴dxúy⁴ ja̱³ chiáh². Hi³ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Jmee² ji̱³nɨɨ́⁴ hi³ hi²jmeey³ nɨ³.
\p 
\v 28 Joó⁴ gu³xɨ³ hí̱³ jniaah¹ liáh³nɨɨh¹ah¹ niaah⁴²ah¹ chia⁴²ah¹ ja̱³ há⁴hé³ cá⁴lɨ́⁴dsaa⁴²ah¹ hi³ he²chiaah¹ ja̱³ hi³ gá⁴féh³ liáh³ja̱³ Jesús ja̱³.
\v 29 Judas ja̱³ ná⁴tayh¹ guaa³ mɨh³tuh³ hi³ tiaah² cuu² chiaa⁴²ah¹. Hi³ja̱³ xe̱y³ jniaah¹ gá⁴tia² gá⁴hi²ah¹ hi³ féh³ Jesús ja̱³ hi³ cua²liá³ Judas ja̱³ hi³ niaa³²ah¹ chiáh² jmɨ́¹feh⁴ ja̱³, hu̱² gɨh³ gua²cuoó⁴ ca³liuh² cuu² ja̱³ diáh⁴ dsa³tieey³.
\v 30 Liáh³ ma³tɨ̱́y³ hó² ya³dsɨ² Judas ja̱³, mɨ²ja̱³ cá⁴bí⁴hɨɨ́y⁴. Baáy⁴ ja̱³ba² ma³ca̱⁴ voo⁴.
\s1 Gá⁴cuó³ Jesús ja̱³ mandamiento hi³mɨɨ³²
\p 
\v 31 Liáh³ cá⁴bí⁴hɨɨ́y⁴ Judas ja̱³, mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Ja̱³nɨ́⁴ hí⁴lii⁴ hi³ he̱é̱yh³ ba² hi²xiáh³ gaáy³ Ja̱á̱² Dsa³ nɨ³, baáy⁴ dxɨ́⁴lieey³² hi³nɨy³² nɨ³ hí⁴lii⁴ hi³ hi²xiáh³ gaáy³ Dios.
\v 32 Baáy⁴ xɨ³ hi³nɨy³² nɨ³ hí⁴jmeé⁴ lii⁴ hi³ bií⁴ dɨ́h¹ gaáy³ Dios nɨ³, mɨ²ja̱³ ba² hí⁴jmeé⁴ lii⁴ ñaá² Dios nɨ³ hi³ bií⁴ gaáy³ ja̱á̱², baáy⁴ mɨ³hí⁴jmeé⁴ ba² ji̱³nɨɨ́⁴.
\v 33 Ja̱a̱y⁴, há⁴hé³ máh⁴ hi²güey⁴² chia̱a̱h⁴²á² niaá⁴ah³ voó³. Hi²xiáh³ hi²naah⁴ah³ jniá³, joó⁴ há⁴hé³ hí⁴jooy³ cua³dxi̱i̱³²ah³ xi² ñeh³²á⁴ nɨ³. Ja̱³ba² liáh³xɨ³ gá⁴foóh²á⁴ diáh⁴ israelitas nɨ³, ja̱³ba² liáh³ja̱³ nɨ³ ga³fooh³²á⁴ niaá⁴ah³ ja̱³nɨ́⁴.
\v 34 Hi³ja̱³ hi²cuoó⁴á⁴ niaá⁴ah³ ca̱a̱³ mandamiento hi³mɨɨ³²: Hi³jmee³ah³ naá⁴ah³ ja̱á̱¹oóh²ah³. Ja̱³ba² liáh³xɨ³ naá⁴á⁴ jniá³ niaá⁴ah³, ja̱³ba² liáh³ja̱³ ga³jmee⁴ hi²jmee³ah³ naá⁴ah³ diáh⁴ ja̱á̱¹oóh²ah³.
\v 35 Liu³u²xɨ³ hi²jmee³ah³ naá⁴ah³ ja̱á̱¹oóh²ah³, mɨ²ja̱³ liáh⁴jɨy³ ba² diáh⁴ dsa³ hí⁴dsaá⁴ dsɨ́² hi³ na³lɨ́⁴ah³ xɨh³chia̱á̱²á⁴.
\s1 Gá⁴féh³ Jesús ja̱³ hi³ hí⁴féh³ Pedro hi³ há⁴hé³ cui̱i̱⁴
\r (Mt. 26:31-35; Mr. 14:27-31; Lc. 22:31-34)
\p 
\v 36 Mɨ²ja̱³ gá⁴ŋɨɨ́³ juúh⁴ Simón Pedro ja̱³ gá⁴ŋɨɨ́h⁴ juúh⁴ Jesús ja̱³, liáh³la³ gá⁴sɨɨ́h⁴:
\p ―Ñuyh⁴, ¿xiah² nɨ³ guoh³²u³ nɨ³?
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Há⁴hé³ hí⁴jooy³ guoh³²u³ chia̱á̱h¹u³ jniá³ xé̱yh² la³ xi² ñeh³²á⁴ nɨ³. Guoh³²u³ ruh³ joó⁴ dsa³cɨ̱ɨ̱y³ ba².
\p 
\v 37 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Pedro ja̱³:
\p ―Ñuyh⁴, ¿he²chiaah¹ ja̱³ hi³ há⁴hé³ hí⁴jooy³ ñii⁴ chia̱a̱h⁴²á² niu³ xé̱yh² la³? Hií⁴á⁴ ba² hí⁴jú̱³á⁴ jniá³ ca³jaa¹ chiú̱h²u³.
\p 
\v 38 Mɨ²ja̱³ liáh³la³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³:
\p ―¿Xɨ² jmɨ́yh³he̱é̱yh³ hi²cuo¹u³ vo̱ó̱h²u³ hí⁴jú̱³u³ ca³jaa¹ chieéy⁴? Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi²fooh¹á² niu³: Liáh³ca̱á̱h³ ja̱a̱h¹ hí⁴chíh⁴ nɨɨh² dsaá⁴ nɨ³ voo⁴ la³ ja̱³nɨ́⁴, mɨ²ja̱³ mɨ³nɨɨh⁴ tiaah² ma³féyh¹ hi³ há⁴hé³ cui̱i̱⁴u³ jniá³.
\c 14
\s1 Jesús nɨ³ na³lɨ́y⁴ fi¹ xi² jey¹ Dios
\p 
\v 1 ’Há⁴ hi³ta³ hi³hɨ³ah³ ñuú³ fáh⁴yeey¹. Ma³taá³ah³ ba² chiáh² Dios, hi³ja̱³ ba² cua²dsa³taá³ah³ chieéy⁴ jniá³.
\v 2 Hi²xiáh³ xa³ je² hi²yaa²a² xi² jey¹ Ñuyh⁴ nɨ³. Ma³foóh²á⁴ ba² niaá⁴ah³ hi³ liu³u²xɨ³ há⁴hé³ xa³ je². Hi³ja̱³ ñeh³²á⁴ ya³bi³tɨɨ⁴²á⁴ ca̱a̱³ hí¹ xi² hi²ñí³ah³.
\v 3 Mɨ² ma³ŋah³²á⁴ baáy⁴ ma³bi³tɨɨ⁴²á⁴ xi² hi²ñí³ah³ nɨ³, mɨ²ja̱³ hí⁴güé³á⁴ ca̱á̱h³ duh³ hi²ya³tee¹á² niaá⁴ah³, duh³ gua³ñí³ah³ xi² ya³güéy⁴ jniá² nɨ³.
\v 4 Maá³ah³ ba² xiah² nɨ³ ñeh³²á⁴ baáy⁴ cui̱i̱³ah³ ba² fi¹.
\p 
\v 5 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Tomás ja̱³ gá⁴sɨɨ́h⁴:
\p ―Ñuyh⁴, há⁴hé³ nia⁴²ah¹ xiah² nɨ³ guoh³²u³ nɨ³. ¿Jmiih⁴² ja̱³ hi²jmee²ah¹ jniaah¹ hí⁴dxaah⁴²ah¹ fi¹?
\p 
\v 6 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Jniá³ nɨ³ na³lɨ́⁴á⁴ fi¹, na³lɨ́⁴á⁴ fáh⁴liu⁴ hi³ xiaa³dsaa³², baá⁴ ba² jniá³ nɨ³ na³lɨ́⁴á⁴ fáh⁴ji̱í̱h⁴ chiáh² diáh⁴ dsa³ jmɨɨyh⁴²güii³. Hi³ fáh⁴ hi³ jniá³ ba² nɨ³ hí⁴jooy³ hí⁴dxá⁴dxi̱i̱³² diáh⁴ dsa³ nɨ³ xi² jey¹ Ñúh³a² nɨ³.
\v 7 Liu³u²xɨ³ cui̱i̱⁴ah³ jniá³, ja̱³ba² hi³ cui̱i̱⁴ah³ Ñuyh⁴ nɨ³. Baáy⁴ ja̱³nɨ́⁴ mɨ³cui̱i̱⁴ah³, chiaah¹ ma³joo⁴²ah³ ba².
\p 
\v 8 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Felipe ja̱³ gá⁴sɨɨ́h⁴:
\p ―Ñuyh⁴, cuo² jú¹hiíh⁴ hi²joo⁴²ah¹ Ñúh³a² nɨ³, duh³ hí⁴lií² ba² nɨɨh¹ ja̱³ chiaa⁴²ah¹.
\p 
\v 9 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Hi²xiáh³ mɨ³voó³ na³cu̱h⁴²á⁴ chia̱a̱h⁴²á² niaá⁴ah³, ¿xɨ² há⁴hé³ ma³lɨ³cui̱i̱⁴u³ jniá³ Felipe? Ja̱y³ dsa³ hi³ ga³jooy³² jniá³, ja̱³ba² hi³ ga³jooy³² Ñuyh⁴ nɨ³ ja̱³. ¿Jmiih⁴² ba² nɨ³ hi³ ga³fooyh³² jniá³ hi³ hi²cuoy⁴² jú¹hiíh⁴ hi³ hi²joo⁴ah³ Ñuyh⁴ nɨ³?
\v 10 ¿Xɨ² há⁴hé³ ca³gua³taá³u³ hi³ ga³fayh⁴ hi³ na³cu̱h⁴²á⁴ chia̱a̱h⁴²á² Ñuyh⁴ nɨ³, baáy⁴ na³cu̱yh⁴ chie̱é̱yh¹ jniá³? Fáh⁴liu⁴ hi³ ga³liuy⁴ nɨ³, há⁴ja̱³ fáh⁴liu⁴ chieéy⁴ ñeéy⁴ nɨ³. Ñuyh⁴ hi³ na³cu̱yh⁴ chie̱é̱yh¹ jniá³ nɨ³ ba² nɨ³ ca³bi³jmeéy³ jniá³ ta² hi³ ga³jmeey⁴ nɨ³.
\v 11 Gua³taá³ah³ hi³ ga³fayh⁴ hi³ na³cu̱h⁴²á⁴ chia̱a̱h⁴²á² Ñuyh⁴ nɨ³ baáy⁴ na³cu̱yh⁴ ñaá² nɨ³ chie̱é̱yh¹ jniá³. Xɨ³ nɨ³ haá² yáh¹, mɨ³ja̱³ ruh³ hu̱² gua³taá³ah³ chieéy⁴ vih² chiaah¹ diáh⁴ fáh⁴lí³ hi³ ga³jmeey⁴ nɨ³.
\v 12 Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi²fooh¹á² niaá⁴ah³: Hi³ ca³dsa³taáy³ chieéy⁴, ba² hí⁴jmeé⁴ liáh³xɨ³ ga³jmeey⁴ jniá³, baáy⁴ hí⁴jmeé⁴ hi³gaay³² gɨh¹ ca̱á̱h³liaáh³. Chiaah¹ hi³ ñeh³²á⁴ jniá³ xi² jey¹ Ñuyh⁴ nɨ³.
\v 13 Hi³ja̱³ jɨɨ⁴ ba² hi³ hi²ŋɨɨh¹ah³ Dios nɨ³ dxɨ́⁴liaa³²á⁴ jniá³, hí̱³ba² jniá³ hi²cuoy⁴² duh³ hí⁴lii⁴ hi³ bií⁴ gaáy³ Dios nɨ³ dxɨ́⁴lieey³² ja̱á̱² nɨ³.
\v 14 Jniá³ hi²cuoy⁴² jɨɨ⁴ he² nɨ³ hi²ŋɨɨh¹ah³ Dios nɨ³, liu³u²xɨ³ hi²ŋɨɨh¹ah³ dxɨ́⁴liaa³²á⁴ jniá³.
\s1 Gá⁴féh³ Jesús ja̱³ hi³ hí⁴xɨ́y⁴ Espíritu Santo
\p 
\v 15 ’Xɨ³ nɨ³ naá⁴ah³ jniá³, hi³ja̱³ hi³nuu³ah³ dsaá² diáh⁴ mandamientos chieéy⁴.
\v 16 Mɨ²ja̱³ jniá³ hi²ŋɨɨy⁴² chiáh² Ñúh³a² nɨ³ duh³ hí⁴xɨ́y⁴ dxeeyh⁴ hi³ hí⁴dsá⁴tia̱a̱² chia̱á̱²ah³ baáy⁴ duh³ hí⁴güe³ chie̱é̱yh¹ niaá⁴ah³ ca̱³ñiih³².
\v 17 Espíritu hi³ bií⁴ xiaa³dsaay³² nɨ³ nɨ³ ga³hó⁴á⁴ nɨ³. Há⁴hé³ hí⁴jooy³ hí⁴tɨ̱́y⁴ Espíritu Santo diáh⁴ hi³ rúh⁴ na³hiiy⁴ jmɨɨyh⁴²güii³ la³, chiaah¹ há⁴hé³ ca³dah²jooy³², ba² há⁴hé³ dɨ³cui̱i̱y⁴. Joó⁴ mɨ³cui̱i̱⁴ah³ ba² niaá⁴ah³, chiaah¹ mɨ³na³cu̱yh⁴ ba² chie̱é̱yh¹ niaá⁴ah³ baáy⁴ dsa³cɨ̱ɨ̱y³ dsá⁴hí³ cáh³ti³² fáh⁴ji̱í̱h⁴ chia̱á̱²ah³.
\p 
\v 18 ’Há⁴hé³ hi²tú⁴á⁴ niaá⁴ah³, hí⁴güé³á⁴ ba² ca̱á̱h³ duh³ hi²güey⁴² ca̱á̱h³ chia̱a̱h⁴²á² niaá⁴ah³.
\v 19 Há⁴hé³ máh⁴ hí⁴dah²joóy² jniá³ diáh⁴ dsa³ nɨ³, joó⁴ hi²joo⁴ah³ ba² jniá³ niaá⁴ah³. Chiaah¹ na³ji̱í̱h⁴á⁴ chieéy⁴ liáh³nɨ³, hi³ja̱³ ba² hi²ñí³ah³ na³ji̱í̱h⁴ah³ chia̱á̱²ah³ liáh³nɨ³ niaá⁴ah³.
\v 20 Jmɨɨ́¹ mɨ²ja̱³ hí⁴dsaá⁴ há²ah³ hi³ he̱é̱yh³ ba² na³cu̱h⁴²á⁴ chia̱a̱h⁴²á² Ñuyh⁴ nɨ³, baáy⁴ na³cu̱h⁴ah³ chia̱á̱h¹ah³ jniá³, ba² na³cu̱h⁴²á⁴ jniá³ chia̱a̱h⁴²á² niaá⁴ah³.
\v 21 Ja̱y³ hi³ ñi³² baáy⁴ hi³ ga³jmee⁴ he̱é̱yh³ mandamientos chieéy⁴, hi³hí̱³ ba² nɨ³ nieéy² jniá³. Baáy⁴ hi²xiáh³ niaá² Dios nɨ³ nieéy², ba² hi²xiáh³ naá⁴á⁴ jniá³, hi³ja̱³ hi²hó⁴á⁴ ñeéy⁴ chiáh² jmɨ́yh³ liáh³xɨ³ na³lɨ́⁴á⁴.
\p 
\v 22 Mɨ²ja̱³ liáh³la³ gá⁴féh³ xɨh³chie̱y³² hi³ xɨ̱ɨ̱y³ Judas, joó⁴ há⁴hí̱³ Judas Iscariote:
\p ―Ñuyh⁴, ¿jmiih⁴² ja̱³ hi³ ti̱¹ jniaah¹ ba² nɨ³ hi²ho¹u³ vo̱ó̱h²u³ nɨ³, baáy⁴ há⁴hé³ hi²ho¹u³ vo̱ó̱h²u³ chiáh² liáh⁴jɨy³ diáh⁴ dsa³ jmɨɨyh⁴²güii³?
\p 
\v 23 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Ja̱y³ hi³ nieéy² jniá³, hi³hí̱³ hí⁴jmeé⁴ he̱é̱yh³ fáh⁴liu⁴ chieéy⁴ baáy⁴ hi²xiáh³ hí⁴niaá² Ñuyh⁴ nɨ³ hí⁴nieéy², hi³ja̱³ na³cu̱h⁴²á⁴ liáh³nɨ³ chia̱a̱h⁴²á² Ñuyh⁴ nɨ³ hi²yaa²ah¹ chia̱a̱h²ah¹ dsa³ ja̱³.
\v 24 Ja̱y³ hi³ há⁴hé³ nieéy² jniá³, hi³hí̱³ há⁴hé³ ga³jmee⁴ he̱é̱yh³ fáh⁴liu⁴ chieéy⁴. Baáy⁴ há⁴ja̱³ hi³ chieéy⁴ nɨ³ fáh⁴liu⁴ hi³ ga³nuu³ah³ la³, hi³chiaah³² Ñuyh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³ ba² nɨ³.
\p 
\v 25 ’Liáh⁴jɨ³ hi³ la³ ga³fooh³²á⁴ niaá⁴ah³, liáh³ rúh⁴ je¹á² chia̱a̱h⁴²á² niaá⁴ah³ nɨ³.
\v 26 Hi³ fáh⁴ hi³ jniá³ ba² nɨ³ hí⁴xɨ́y⁴ Ñúh³a² nɨ³ Espíritu Santo chié̱y² duh³ dsá⁴tia̱a̱² chia̱á̱²ah³. Hí⁴heé⁴ gɨh¹ niaá⁴ah³ jɨɨ⁴ lɨ́⁴ baáy⁴ hí⁴bí⁴liíh⁴ há²ah³ liáh⁴jɨ³ hi³ ma³foóh²á⁴ niaá⁴ah³ nɨ³.
\p 
\v 27 ’Jniá³ yáh¹ há⁴hé³ jna²baah⁴²á² ñeéy⁴. Ba² hi²jmeey⁴² chiáh² liáh³ja̱³ chia̱á̱²ah³. Há⁴hé³ ca³bi³jee⁴²á² há²ah³ liáh³xɨ³ ca³dah²jmeéh⁴ oóyh² diáh⁴ dsa³ jmɨɨyh⁴²güii³. Há⁴ hi³ta³ hi³hɨ³ah³ ñuú³, há⁴ hi³foh³²ah³ chiáh² cáh³ti³².
\v 28 Ma³niuu³ah³ ba² hi³ ma³foóh²á⁴ niaá⁴ah³ hi³ ñeh³²á⁴ joó⁴ hí⁴güé³á⁴ ba² ca̱á̱h³ duh³ hi²cu̱h⁴²á² ca̱á̱h³ chia̱a̱h⁴²á² niaá⁴ah³. Liu³u²xɨ³ jmɨ́yh³he̱é̱yh³ ba² naá⁴ah³ jniá³, mɨ²ja̱³ hi²xiáh³ hí⁴jé⁴ há²ah³ hi³ ma³dsaá⁴ há²ah³ hi³ mɨ³ñeh³²á⁴ xi² jey¹ Ñuyh⁴ nɨ³, chiaah¹ ná⁴ŋɨy¹ gɨh¹ Ñuyh⁴ nɨ³ liáh³xɨ³ jniá³.
\v 29 Ga³fooh³²á⁴ niaá⁴ah³ hi³la³ liáh³ca̱á̱h³ ja̱a̱h¹ hí⁴lí³, duh³ liu³u²xɨ³ mɨ² ma³lɨ⁴ liáh³ja̱³, mɨ²ja̱³ dsá⁴taá³ah³ gɨh¹ dxú⁴.
\p 
\v 30 ’Há⁴hé³ máh⁴ hi²liuy⁴² gɨh¹ voó³ chia̱a̱h⁴²á² niaá⁴ah³, chiaah¹ mɨ³ya³tɨ́⁴ hí⁴güéy³ hi³ ga³chiuuh³² hiíh⁴ jmɨɨyh⁴²güii³ la³. Joó⁴ há⁴hé³ ga³chiuuh³² hiíh⁴ chieéy⁴ jniá³.
\v 31 Joó⁴ liáh³ja̱³ ga³jmee⁴ hí⁴lí³ duh³ hí⁴dsaá⁴ dsɨ́² diáh⁴ dsa³ jmɨɨyh⁴²güii³ nɨ³, hi³ he̱é̱yh³ ba² naá⁴á⁴ Dios, baáy⁴ hí⁴dsaá⁴ dsɨ́² diáh⁴ hi³ ga³jmeey⁴ ba² liáh³xɨ³ gá⁴taáh⁴ ta² ñaá². Bɨ́²ah³ duh³ má⁴dxii³²a² la³.
\c 15
\s1 Jesús nɨ³, jmɨ́yh³ xaah¹ mɨ¹jóh¹
\p 
\v 1 ’Jniá³ na³lɨ́⁴á⁴ jmɨ́yh³ xaah¹ mɨ¹jóh¹, baáy⁴ Ñuyh⁴ nɨ³ ga³heeh⁴ hí¹.
\v 2 Ñuyh⁴ nɨ³ ga³chiuuh³² diáh⁴ guaa³ hi³ há⁴hé³ ga³cuo⁴ mɨɨ¹ chiáh². Baáy⁴ ca³bi³xɨ³ bi³ŋɨɨ́³ diáh⁴ guaa³ hi³ ga³hɨɨ³ mɨɨ¹, duh³ hí⁴hɨɨ́⁴ gɨh¹ dxú⁴.
\v 3 Mɨ³na³xɨ³ na³ŋɨɨ́³ah³ ba² niaá⁴ah³ vih²chiaah¹ diáh⁴ fáh⁴liu⁴ hi³ ma³hoó⁴á⁴ niaá⁴ah³ nɨ³.
\v 4 Cua²na³cú̱h¹ah³ chia̱á̱h¹ah³ jniá³ liáh³nɨ³, ja̱³ba² liáh³xɨ³ jniá³ na³cu̱h⁴²á⁴ chia̱a̱h⁴²á² niaá⁴ah³ nɨ³. Chiaah¹ ca̱a̱³ guaa³ mɨ¹jóh¹ há⁴hé³ hí⁴jooy³ hí⁴hɨɨ́⁴ mɨɨ¹, xɨ³ nɨ³ há⁴hé³ na³lieey³² chie̱é̱yh¹ xaah¹ chiáh². Ba² ja̱³ba² liáh³ja̱³ xa̱³ah³ niaá⁴ah³, há⁴hé³ hí⁴jooy³ hi²jmee³ah³ hi³ dxú⁴, xɨ³ nɨ³ há⁴hé³ na³cu̱h⁴ah³ chia̱á̱h¹ah³ jniá³.
\p 
\v 5 ’Jniá³ nɨ³ na³lɨ́⁴á⁴ jmɨ́yh³ xaah¹ mɨ¹jóh¹ nɨ³, baáy⁴ niaá⁴ah³ nɨ³ na³lɨ́⁴ah³ diáh⁴ meeh¹ guaah⁴². Hi³ja̱³ ja̱y³ hi³ na³cu̱yh⁴ tiá¹ chie̱é̱yh¹ jniá³, baáy⁴ jniá³ na³cu̱h⁴²á⁴ chia̱a̱h⁴²á² ñaá², hi²xiáh³ ñuú³ hi³ dxú⁴ hí⁴jmeé⁴ hi³hí̱³. Gu³xɨ³ hé³ há⁴hé³ hí⁴jooy³ hi²jmee³ah³ vo̱ó̱h²ah³ xɨ³ nɨ³ há⁴hé³ na³cu̱h⁴ah³ chia̱á̱h¹ah³ jniá³.
\v 6 Ja̱y³ dsa³ hi³ há⁴hé³ na³cu̱yh⁴ chie̱é̱yh¹ jniá³, hi³hí̱³ hí⁴tie̱e̱y⁴² tɨɨ́² liáh³xɨ³ ca³lɨ³tia̱a̱² diáh⁴ guaa³ ma³ duh³ hí⁴chiu̱u̱³. Mɨ² ma³lɨ³chiu̱u̱³ ja̱³ mɨ²ja̱³ hí̱³ ca³dxa³cua̱a̱yh⁴² duh³ hí⁴caa³.
\p 
\v 7 ’Liu³u²xɨ³ hu̱² na³cu̱h⁴ah³ chia̱á̱h¹ah³ jniá³ liáh³nɨ³, baáy⁴ nuu³ah³ dsaá² fáh⁴liu⁴ chieéy⁴, mɨ²ja̱³ hi³ŋɨɨ́¹ah³ jɨɨ⁴ lɨ́⁴ hi³ naa³ah³, baáy⁴ he̱é̱yh³ ba² hí⁴lí³ liáh³ja̱³ chia̱á̱²ah³.
\v 8 Xɨ³ nɨ³ hi²jmee³ah³ jmáyh² hi³ dxú⁴, mɨ²ja̱³ hí⁴lii⁴ hi³ bií⁴ gaáy³ Dios, baá⁴ ba² hí⁴lí³ah³ jmɨ́yh³ xɨh³chia̱á̱²á⁴.
\v 9 Hi²xiáh³ nieéy² jniá³ Ñuyh⁴ nɨ³, ba² liáh³ja̱³ jniá³ hi²xiáh³ naá⁴á⁴ niaá⁴ah³. Hi³ja̱³ há⁴ hi³tu³²ah³ cáh³ti³² hi³ bií⁴ naá⁴á⁴ niaá⁴ah³ nɨ³.
\v 10 Xɨ³ hi²nuu³ah³ dsaá² diáh⁴ mandamiento chieéy⁴ nɨ³, ba² liáh³ja̱³ há⁴hé³ hi²tu¹ah³ cáh³ti³² hi³ bií⁴ naá⁴á⁴ niaá⁴ah³ nɨ³. Chiaah¹ ba² liáh³ja̱³ jniá³ ga³nuuy⁴ dsaá² diáh⁴ mandamiento chiáh² Ñuyh⁴ nɨ³, hi³nɨ³ lii⁴ hi³ há⁴hé³ ga³túy⁴ hi³ bií⁴ nieéy² jniá³ nɨ³.
\p 
\v 11 ’Ga³fooh³²á⁴ niaá⁴ah³ liáh³nɨ³ duh³ hí⁴jé⁴ há²ah³ liáh³xɨ³ jé⁴ dsɨy⁴ jniá³, baáy⁴ duh³ jmɨ́yh³he̱é̱yh³ ba² hí⁴jé⁴ há²ah³ dxú⁴ cáh³ti³².
\v 12 Liáh³la³ ná⁴lɨ¹ mandamiento chieéy⁴: hi³jmee³ah³ naá⁴ah³ diáh⁴ ja̱á̱¹oóh²ah³, ja̱³ba² liáh³xɨ³ naá⁴á⁴ jniá³ niaá⁴ah³ nɨ³.
\v 13 Lii⁴ ba² hi³ bií⁴ niaa³²a² diáh⁴ amigos chia̱a̱⁴²a², liu³u²xɨ³ hi²cuo²a² voo³²a² hí⁴jú̱³a² chiáh² diáh⁴.
\v 14 Niaá⁴ah³ na³lɨ́⁴ah³ amigos chia̱á̱²á⁴ xɨ³ nɨ³ hi²jmee³ah³ liáh³xɨ³ ga³fooh³²á⁴ niaá⁴ah³ nɨ³.
\v 15 Há⁴hé³ máh⁴ hi²fayh¹ hi³ na³lɨ́⁴ah³ mozos chia̱á̱²á⁴, chiaah¹ há⁴hé³ na³fáyh⁴ dɨ³ñi³² diáh⁴ mozos he² nɨ³ jmɨ́yh³ ga³jmee⁴ fii² diáh⁴. Hi²fayh¹ hi³ na³lɨ́⁴ah³ amigos chia̱á̱²á⁴ bɨh¹ ba², chiaah¹ ma³hoó⁴á⁴ niaá⁴ah³ jɨɨ⁴ lɨ́⁴ hi³ ma³féh³ Ñuyh⁴ nɨ³ ma³sɨɨ́h⁴ jniá³.
\v 16 Há⁴hí̱³ niaá⁴ah³ nɨ³ gá⁴dxɨ́⁴ah³ jniá³. Jniá³ ba² nɨ³ gá⁴dxɨ́²á⁴ niaá⁴ah³, duh³ ma³táh⁴á⁴ guaa³²ah³ cua³dxí̱⁴ah³ gua³liu⁴²ah³ diáh⁴ dsa³ duh³ hí⁴sa³ cua̱a̱y¹ná² ta² chia̱á̱²ah³ baáy⁴ hi³nɨ³ há⁴hé³ jlɨ́h³ jmɨɨ́¹ hí⁴dsá⁴yeéy⁴. Mɨ²ja̱³ hí⁴cuoó⁴ ba² niaá⁴ah³ Ñuyh⁴ nɨ³ jɨɨ⁴ lɨ́⁴ hi³ hi²ŋɨɨ́¹ah³, xɨ³ nɨ³ dxɨ́⁴liaa³²á⁴ jniá³.
\v 17 Hi³ja̱³ ga³fooh³²á⁴ niaá⁴ah³ ca̱á̱h³: hi³jmee³ah³ naá⁴ah³ diáh⁴ ja̱á̱¹oóh²ah³.
\s1 Hi²xiáh³ dɨ³cɨ̱ɨ̱y³² diáh⁴ dsa³ ca³dah²jooy³² jnia²
\p 
\v 18 ’Liu³u²xɨ³ dɨ³cɨ̱ɨ̱y³² diáh⁴ dsa³ jmɨɨyh⁴²güii³ la³ dah²ñi³² niaá⁴ah³, bi³liih⁴² há²ah³ hi³ jniá³ ba² nɨ³ cá⁴lɨ́⁴cɨ̱ɨ̱y³² cá⁴dah²ñí² dsa³jéy⁴.
\v 19 Liu³u²xɨ³ na³hii⁴ah³ jmɨɨyh⁴²güii³ la³, mɨ²ja̱³ hi²xiáh³ dɨ³nieéy² niaá⁴ah³ hu̱² liáh³ja̱³. Joó⁴ jee⁴² chiáh² diáh⁴ dsa³ jmɨɨyh⁴²güii³ la³ gá⁴dxɨ́²á⁴ niaá⁴ah³, hi³ja̱³ nɨ³ dɨ³cɨ̱ɨ̱y³² ca³dah²ñi³² niaá⁴ah³, chiaah¹ há⁴hé³ máh⁴ na³hii⁴ah³ jmɨɨyh⁴²güii³ la³.
\v 20 Bi³liih⁴² há²ah³ liáh³xɨ³ gá⁴foóh²á⁴ niaá⁴ah³ dsa³jéy⁴: “Há⁴hé³ xe̱y³ mozo hi³ gaáy³ gɨh¹ liáh³xɨ³ fii².” Xɨ³ nɨ³ jniá³ ma³dah²jmeéh⁴ mɨ³hee³², ná⁴lɨ¹ chiáh² hí⁴dah²jmeéh⁴ niaá⁴ah³ mɨ³hee³². Baáy⁴ xɨ³ nɨ³ ma³dah²nuú³ dsaá² hi³ ma³hoó⁴á⁴ diáh⁴, ba² hí⁴dah²nuú⁴ dsaá² chia̱á̱²ah³.
\v 21 Joó⁴ liáh³ja̱³ hí⁴dah²jmeéh⁴ niaá⁴ah³ vih²chieéy⁴, chiaah¹ há⁴hé³ dɨ³cui̱i̱y⁴ diáh⁴ hi³ gá⁴xɨ́y⁴ jniá³ nɨ³.
\p 
\v 22 ’Há⁴hé³ dɨ³dsɨ̱y³² dsaa² liu³u²xɨ³ há⁴hé³ güé⁴á⁴ bi²liu⁴²á² diáh⁴. Joó⁴ ja̱³nɨ́⁴ há⁴hé³ máh⁴ hí⁴jooy³ hí⁴dah²féh³ hi³ há⁴hé³ xa³ dsaa² chiáh² diáh⁴.
\v 23 Diáh⁴ hi³ dɨ³cɨ̱ɨ̱y³² ca³dah²ñi³² jniá³, ba² dɨ³cɨ̱ɨ̱y³² ca³dah²ñi³² Ñuyh⁴ nɨ³.
\v 24 Há⁴hé³ xa³ dsaa² chiáh² diáh⁴, liu³u²xɨ³ hu̱² há⁴hé³ ma³jmeéy⁴ diáh⁴ fáh⁴lí³ hi³ há⁴hé³ jlɨ́h³ ma³jmeé³ dxeeyh⁴. Joó⁴ ja̱³nɨ́⁴ ma³dah²joó² diáh⁴ fáh⁴lí³ nɨ³, joó⁴ gu³xɨ³ ba² jmiih⁴ liáh³ ja̱³ hi²xiáh³ dɨ³cɨ̱ɨ̱y³² ca³dah²ñi³² jniá³ baáy⁴ hi²xiáh³ dɨ³cɨ̱ɨ̱y³² ca³dah²ñi³² Ñuyh⁴ nɨ³.
\v 25 Joó⁴ ga³lɨ́³ liáh³nɨ³ duh³ja̱³ hí⁴lí³ cumplido liáh³xɨ³ ná⁴lɨ¹ na³xɨɨ² ley chiáh² diáh⁴, xi² dsa³féh³ liáh³la³: “Cá⁴lɨ́⁴cɨ̱ɨ̱y³² cá⁴dah²ñí² jniá³, gu³xɨ³ ba² há⁴hé³ xa³ dsa³lí³.”
\p 
\v 26 ’Joó⁴ mɨ² ma³dxáh²á⁴ xi² jey¹ Ñuyh⁴ nɨ³, mɨ²ja̱³ hi²sɨ́⁴á⁴ Espíritu hi³ bií⁴ xiaa³dsaay³² nɨ³ duh³ hí⁴dsá⁴tia̱a̱² chiáh² diáh⁴ dsa³ nɨ³. Mɨ² ma³güey⁴ nɨ³ mɨ²ja̱³ hi³nɨy³² nɨ³ hí⁴jmeé⁴ dsa³ñi³² chia̱á̱²á⁴.
\v 27 Ba² ji̱í̱⁴ niaá⁴ah³ hí⁴lí³ah³ dsa³ñi³² chia̱á̱²á⁴, chiaah¹ hi³ na³cu̱h⁴ah³ chia̱á̱h¹ah³ jniá³ liáh³nɨ³ liáh³ gá⁴laáy⁴ lɨ́⁴ jmeey⁴ ta² chiáh² Dios nɨ³.
\c 16
\p 
\v 1 ’Ga³fooh³²á⁴ niaá⁴ah³ liáh³nɨ³ duh³ há⁴hé³ hí⁴fɨɨh⁴² há²ah³ baáy⁴ duh³ há⁴hé³ hi²tu¹ah³ cáh³ti³².
\v 2 Chiaah¹ há⁴hé³ máh⁴ hí⁴dah²cuó⁴ je² cua³dxí̱⁴ah³ diáh⁴ ñuúh⁴guah³ liuh² nɨ³. Baáy⁴ hí⁴dxá⁴héy³ lɨ́⁴ hí⁴dah²jɨ̱́yh⁴ niaá⁴ah³, mɨ²ja̱³ hí̱³ba² mii⁴ diáh⁴ hí⁴ji̱í̱h⁴ hi³ ta² chiáh² Dios ja̱³ dah²jmee⁴.
\v 3 Liáh³ja̱³ hí⁴dah²jmeé⁴ diáh⁴, chiaah¹ há⁴hé³ ma³lɨ³cui̱i̱⁴ Ñuyh⁴, ñé⁴ há⁴hé³ ma³lɨ³cui̱i̱⁴ diáh⁴ jniá³.
\v 4 Joó⁴ ga³fooh³²á⁴ niaá⁴ah³ liáh³nɨ³, duh³ liu³u²xɨ³ mɨ² ma³dxa³héy³ dsa³lí³ liáh³ja̱³, mɨ²ja̱³ hí⁴liih³²ah³ hi³ ma³ŋɨ́³ ba² ma³foóh²á⁴ niaá⁴ah³.
\s1 Liáh³la³ ga³jmee⁴ Espíritu Santo
\p ’Há⁴hé³ gá⁴foóh²á⁴ niaá⁴ah³ hi³la³ dsa³jéy⁴, chiaah¹ rúh⁴ je¹á² ba² chia̱a̱h⁴²á² niaá⁴ah³.
\v 5 Joó⁴ ja̱³nɨ́⁴ hi³ mɨ³ñeh³²á⁴ ya³güéy⁴ chia̱a̱h⁴²á² hi³ gá⁴xɨ́y⁴ jniá³ nɨ³, ba² gu³xɨ³ hí̱³ niaá⁴ah³ há⁴hé³ ma³ŋɨɨ́¹ah³ jniá³ juúh⁴ xiah² nɨ³ ñeh³²á⁴ nɨ³.
\v 6 Xiáh³ hi³ ma³lɨ³fɨɨh⁴² há²ah³ ba², chiaah¹ hi³ ma³foóh²á⁴ niaá⁴ah³ liáh³nɨ³.
\v 7 Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi²fooh¹á² niaá⁴ah³ hi³ hí⁴lí³ dxú⁴ chia̱á̱²ah³ ba² nɨ³ hi³ ñeh³²á⁴ nɨ³. Chiaah¹ liu³u²xɨ³ há⁴hé³ ñeh³²á⁴, mɨ²ja̱³ há⁴hé³ hí⁴yá⁴güe³ chie̱é̱yh¹ niaá⁴ah³ Espíritu chié̱y² Dios hi³ ga³hoó⁴á⁴ dsá⁴tia̱a̱² chia̱á̱²ah³ nɨ³. Joó⁴ liu³u²xɨ³ ñeh³²á⁴, mɨ²ja̱³ jniá³ hi²sɨ́⁴á⁴ hi³ ga³hó⁴á⁴ nɨ³,
\v 8 duh³ mɨ² ma³güey⁴, mɨ²ja̱³ hí⁴bí⁴jmeéy³ diáh⁴ dsa³ jmɨɨyh⁴²güii³ nɨ³ hi³ he̱é̱yh³ ba² xa³ dsaa² chiáh² diáh⁴. Baáy⁴ hí⁴heé⁴ diáh⁴ hi³ ja̱y³ jniá³ ba² nɨ³ jmɨ́yh³ xiaa³dsaa³²á⁴, baáy⁴ hí⁴heé⁴ diáh⁴ hi³ hí⁴ca̱a̱⁴ cua̱a̱y¹ná² Dios nɨ³ chiáh² diáh⁴.
\v 9 Xa³ dsaa² chiáh² diáh⁴ dsa³, chiaah¹ hi³ há⁴hé³ ca³dsa³taáy³ diáh⁴ chieéy⁴.
\v 10 Hí⁴dah²cá̱² ba² cua̱a̱y¹ná² hi³ ja̱y³ jniá³ ba² nɨ³ xiaa³dsaa³²á⁴ chiaah¹ hi³ fáh⁴ hi³ ñeh³²á⁴ xi² jey¹ Ñuyh⁴ nɨ³, ba² há⁴hé³ máh⁴ hi²joo⁴ah³ jniá³ niaá⁴ah³.
\v 11 Ba² hí⁴dah²cá̱² cua̱a̱y¹ná² diáh⁴ dsa³ nɨ³, hi³ hí⁴ca̱a̱⁴ cua̱a̱y¹ná² Dios nɨ³ chiáh² diáh⁴. Chiaah¹ ma³bi³chiíy⁴ Dios nɨ³ hi³há⁴dxúy⁴ hi³ ga³chiuuh³² hiíh⁴ jee⁴² jmɨɨyh⁴²güii³ la³.
\p 
\v 12 ’Hi²xiáh³ ñuú³ gɨh¹ hi³ ga³jmee⁴ hi²fooh¹á² niaá⁴ah³, joó⁴ há⁴hé³ hí⁴dsaa⁴ah³ xé̱yh² la³.
\v 13 Joó⁴ mɨ² ma³güey⁴ Espíritu hi³ bií⁴ xiaa³dsaay³² nɨ³, mɨ²ja̱³ hí⁴heé⁴ niaá⁴ah³ jɨɨ⁴ lɨ́⁴ hi³ xiaa³dsaa³², chiaah¹ há⁴ja̱³ liáh³xɨ³ ga³lɨ́³ dsɨ́² ñaá² nɨ³ hí⁴liú⁴. Jmáyh² hi³ hí⁴nuú⁴ ba² nɨ³ hí⁴féh³, baáy⁴ hí⁴jmeé⁴ hí⁴dsaá⁴ há²ah³ hi³ hí⁴lí³ dsa³cɨ̱ɨ̱y³.
\v 14 Hi³nɨy³² hí⁴jmeéh⁴ jniá³ hu̱u̱¹rá² chiaah¹ hí⁴nuú⁴ fáh⁴liu⁴ chieéy⁴, mɨ²ja̱³ hí⁴heé⁴ niaá⁴ah³ duh³ hí⁴dsaá⁴ há²ah³ liáh³xɨ³ ná⁴lɨ¹.
\v 15 Ba² ja̱³ba² hi³ chieéy⁴ nɨ³ liáh⁴jɨ³ hi³ xa³ chiáh² Ñúh³a² Dios nɨ³, hi³ja̱³ nɨ³ ma³fáyh² hi³ hí⁴nuú⁴ Espíritu chié̱y² nɨ³ fáh⁴liu⁴ chieéy⁴, mɨ²ja̱³ hí⁴heé⁴ niaá⁴ah³ duh³ hí⁴dsaá⁴ há²ah³.
\s1 La³ dsa³liú⁴ hi³hí̱³ hí⁴jé⁴ dsɨ́²
\p 
\v 16 ’Há⁴hé³ máh⁴ hi²joo⁴ah³ jniá³ já̱⁴mɨ²hee³ yaá², joó⁴ hi²joo⁴ah³ ba² jniá³ ca̱á̱h³ dsa³cɨ̱ɨ̱y³, chiaah¹ ñeh³²á⁴ xi² jey¹ Ñuyh⁴ Dios nɨ³.
\p 
\v 17 Mɨ²ja̱³ gá⁴ŋɨɨh²ah¹ juúh⁴ oóh²ah¹, liáh³la³ gá⁴feh²ah¹:
\p ―¿Jmiih⁴² nɨ³ ga³he⁴ hi³ ga³féh³ liáh³nɨ³? Féh³ hi³ há⁴hé³ máh⁴ mɨ³hi²joo⁴²a² xé̱yh² heé⁴ yaá², joó⁴ hi²joo⁴²a² ba² ca̱á̱h³ ji̱³nɨɨ́⁴, ba² féh³ hi³ dsayh³² xi³ jey¹ Ñúh³a² Dios nɨ³.
\v 18 ¿Jmiih⁴² nɨ³ ga³he⁴ hi³ ga³féh³ “heé⁴ yaá²”? Há⁴hé³ dsaa⁴²a² jmiih⁴² nɨ³ ga³he⁴ hi³ ga³féh³ liáh³nɨ³.
\p 
\v 19 Cá⁴lɨ́⁴chii⁴ Jesús ja̱³ hi³ niaa³²ah¹ hi²ŋɨɨh²ah¹ juúh⁴, hi³ja̱³ liáh³la³ gá⁴sɨɨ́h⁴ jniaah¹ ca̱á̱h³:
\p ―Ma³foóh²á⁴ ba² niaá⁴ah³ hi³ há⁴hé³ máh⁴ hi²joo⁴ah³ jniá³ heé⁴ yaá², baáy⁴ dsa³cɨ̱ɨ̱y³ ba² hi²joo⁴ah³ jniá³ ca̱á̱h³. ¿Xɨ² hi³ nɨ³ nɨ³ ŋɨɨ́h¹ah³ juúh⁴ oóh²ah³ nɨ³?
\v 20 Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³: Hi²xiáh³ hi²jla⁴²ah³ baáy⁴ hí⁴fɨɨh⁴² há²ah³, joó⁴ xiáh³ hi³ hí⁴jé⁴ dsɨ́² ba² diáh⁴ dsa³ hi³ dɨ³niaá⁴ chiáh² hi³ xa³ jmɨɨyh⁴²güii³ la³. Joó⁴ gu³xɨ³ ba² hí⁴fɨɨh⁴² há²ah³, joó⁴ dsa³cɨ̱ɨ̱y³ hí⁴jé⁴ ca̱á̱h³ há²ah³.
\v 21 Liu³u²xɨ³ mɨ² ga³sa̱y³ mɨ¹ja̱á̱² ja̱y³ mɨ́³, mɨ²ja̱³ hi²xiáh³ ga³cɨ̱ɨ̱h³² ga³beeyh³² mɨ² ma³dxa³héy³ hiíh⁴ chiáh². Joó⁴ mɨ² ma³sa̱y³ xɨ³yu̱u̱y³ ja̱³, há⁴hé³ máh⁴ liíh⁴ hi³ booy¹ ma³ca̱⁴ dxɨɨ́³, chiaah¹ hi³ bií⁴ mɨ³jé⁴ dsɨ́² hi³ ma³sa̱y³ ja̱y³ xɨ³yu̱u̱y³ jmɨɨyh⁴²güii³ la³.
\v 22 Ba² liáh³ja̱³ xa̱³ah³ niaá⁴ah³, fɨɨh⁴² túh²há²ah³ ja̱³nɨ́⁴. Joó⁴ mɨ² mɨ³hi²joo⁴ah³ jniá³ ca̱á̱h³, mɨ²ja̱³ hi²xiáh³ hí⁴jé⁴ ca̱á̱h³ há²ah³. Cua̱a̱y¹ná² gaáy³ dɨ́h¹ jé⁴ há²ah³ hí⁴lí³, baáy⁴ gu³xɨ³ hí̱³ há⁴hé³ máh⁴ hí⁴bí⁴fɨɨh⁴² há²ah³.
\p 
\v 23 ’Mɨ²ja̱³ há⁴hé³ máh⁴ hi²ŋɨɨh¹ah³ jniá³ juúh⁴ cáh³ti³². Jmɨ́yh³he̱é̱yh³ cáh³ti³² hi³ hi²fooh¹á² niaá⁴ah³ la³: Hí⁴cuoó⁴ niaá⁴ah³ Ñúh³a² nɨ³ jɨɨ⁴ lɨ́⁴ hi³ hi²ŋɨɨ́¹ah³ dxɨ́⁴liaa³²á⁴ jniá³.
\v 24 Ma³güe⁴ la³ ja̱³nɨ́⁴ há⁴hé³ xa³ ma³ŋɨɨ́¹ah³ cáh³ti³² dxɨ́⁴liaa³²á⁴ jniá³, hi³ja̱³ ja̱³nɨ́⁴ ŋɨɨ́¹ah³ duh³ hí⁴tɨ̱́⁴ah³, mɨ²ja̱³ hí⁴jé⁴ há²ah³ cáh³ti³².
\s1 Gá⁴tiaá⁴ Jesús ja̱³ jmɨɨyh⁴²güii³ la³
\p 
\v 25 ’Ma³foóh²á⁴ niaá⁴ah³ hi³la³ chie̱é̱yh¹ fáh⁴liu⁴ na³ma², joó⁴ hí⁴tɨ́⁴ ba² hiíh⁴ hi²liu⁴²á² niaá⁴ah³ jɨy³ cáh³ti³² ca³jaa¹ chiáh² Ñúh³a² nɨ³.
\v 26 Jmɨɨ́¹ mɨ²ja̱³ hi²ŋɨɨ́¹ah³ hi³la³ hi³nɨ³ dxɨ́⁴liaa³²á⁴ jniá³. Há⁴ja̱³ hi³ ga³fooh³²á⁴ niaá⁴ah³ hi³ jniá³ hi²ŋɨɨy⁴² jmɨ²heé¹ chiáh² Ñúh³a² nɨ³ chia̱á̱²ah³.
\v 27 Chiaah¹ hi²xiáh³ nieéy² niaá⁴ah³ Ñúh³a² nɨ³ chiaah¹ hi³ naá⁴ah³ jniá³ vo̱ó̱h²ah³, baáy⁴ ma³taá³ah³ hi³ he̱é̱yh³ ba² Dios nɨ³ gá⁴xɨ́y⁴ jniá³ jmɨɨyh⁴²güii³ la³.
\v 28 Xi² jey¹ Ñúh³a² nɨ³ bí⁴hɨɨ́⁴á⁴ jáy² jmɨɨyh⁴²güii³ la³, joó⁴ ja̱³nɨ́⁴ mɨ³hi²túy⁴ jmɨɨyh⁴²güii³ la³, duh³ mɨ³ñeh³²á⁴ ca̱á̱h³ xi² jey¹ Ñúh³a² nɨ³.
\p 
\v 29 Mɨ²ja̱³ liáh³la³ gá⁴xɨɨh²ah¹ jniaah¹ diáh⁴ xɨh³chie̱y³² ja̱³:
\p ―Ja̱³nɨ́⁴ gɨh¹ mɨ³liúy¹ gɨh¹ jɨy³, há⁴hé³ máh⁴ liúy¹ na³ji̱i̱⁴.
\v 30 Ja̱³nɨ́⁴ gɨh¹ ma³dsaá⁴ dsɨ³²ah¹ hi³ maáy³ ba² jɨɨ⁴ lɨ́⁴. Há⁴hé³ ná⁴dsɨ¹ hiíh⁴ hi³ xe̱y³ hí⁴ŋɨɨ́h⁴ niu³ juúh⁴. Hi³ja̱³ nɨ³ ca³dsa³taá³ah¹ hi³ he̱é̱yh³ ba² Dios nɨ³ gá⁴xɨ́y⁴ niu³.
\p 
\v 31 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹ ca̱á̱h³:
\p ―¿Hi³ja̱³ xɨ³ ca³gua³taá³ah³ ja̱³nɨ́⁴?
\v 32 Ja̱³nɨ́⁴ gɨh¹ mɨ³hí⁴dxá⁴héy³ hiíh⁴, ja̱³nɨ́⁴ gɨh¹ mɨ³hí⁴tú⁴ah³ jniá³ ñeéy⁴, xiaáh³ bɨh¹ cua³dxí̱⁴ah³ liáh³ja̱³ liáh³ja̱³ah³. Joó⁴ há⁴hé³ ruh³ he̱é̱yh³ ba² ñeéy⁴ chiaah¹ na³cu̱yh⁴ ba² chie̱é̱yh¹ jniá³ Dios nɨ³.
\v 33 Ga³fooh³²á⁴ niaá⁴ah³ liáh³nɨ³ duh³ há⁴hé³ hi²ta³ hi²hɨ³ah³ ñuú³ chiaah¹ na³cu̱h⁴²á⁴ ba² chia̱a̱h⁴²á² niaá⁴ah³. Hí⁴chi̱í̱h² hí⁴beéh²ah³ liáh³bií⁴ jmɨɨyh⁴²güii³ la³, joó⁴ jmeé¹ah³ ba³ há²ah³ ba², chiaah¹ ma³tieéy⁴ jniá² ma³meéy² liáh⁴jɨ³ hi³ xa³ jmɨɨyh⁴²güii³ la³.
\c 17
\s1 Gá⁴liúy² Dios Jesús ja̱³ chiáh² diáh⁴ xɨh³chie̱y³²
\p 
\v 1 Liáh³ ma³jooy³ ma³liú³ Jesús ja̱³ chie̱é̱yh¹ jniaah¹, mɨ²ja̱³ gá⁴joó² yuuh¹ güii³, duh³ liáh³la³ gá⁴féh³:
\p ―Ñuyh⁴, ma³dxa³héy³ hiíh⁴ chieéy⁴. Jmee² lii⁴ hi³ bií⁴ gaáy³ Ja̱a̱y³ nɨ³, duh³ ba² hí⁴jmeé⁴ lii⁴ hi³ bií⁴ gaá³u³ vo̱ó̱h²u³.
\v 2 Niu³ ma³cuoóy¹ jú¹hiíh⁴ hi³ hí⁴chiuúh² hiíh⁴ chiáh² liáh⁴jɨy³ diáh⁴ dsa³ duh³ hí⁴jmeé⁴ hi³ há⁴hé³ máh⁴ hí⁴jú̱y³ diáh⁴ hi³ ma³cuó¹u³ nɨ³.
\v 3 Hi³ hí⁴dah²güe³ na³ji̱í̱yh⁴ diáh⁴ liáh³nɨ³, hi³ nɨ³ nɨ³ niaá⁴ hí⁴féh³, hi³ hí⁴cui̱i̱⁴ diáh⁴ niu³ hi³ vo̱ó̱h²u³ nɨ³ jmɨ́yh³ Dios baáy⁴ hí⁴cui̱i̱⁴ diáh⁴ Jesucristo hi³ gá⁴xɨ́⁴u³ jmɨɨyh⁴²güii³ la³.
\p 
\v 4 ’Ma³hoó⁴á⁴ diáh⁴ dsa³ jmɨɨyh⁴²güii³ nɨ³ hi³ bií⁴ gaá³u³, ma³jooy³ ba² ma³jmeéy⁴ ta² hi³ gá⁴tieéyh² ta² hi²jmeey⁴² nɨ³.
\v 5 Ja̱³nɨ́⁴ yáh¹ Ñuyh⁴, dxey⁴² jniá³ ca̱á̱h³ gaáy³ ji̱h²caah⁴u³, xi² je¹á² chia̱a̱h⁴²á² niu³ mɨ² dsa³jéy⁴ liáh³ca̱á̱h³ ja̱a̱h¹ hí⁴niaá⁴ jmɨɨyh⁴²güii³ la³.
\p 
\v 6 ’Diáh⁴ hi³ gá⁴dxɨ́⁴u³ jee⁴² jmɨɨyh⁴²güii³ nɨ³ gá⁴cuó¹u³ jniá³, diáh⁴ hi³nɨy³² ma³hoó⁴á⁴ liáh³xɨ³ na³lɨ́⁴u³. Diáh⁴ hi³ chiú̱h²u³ ja̱³ gá⁴cuó¹u³ jniá³, hi³ja̱³ ma³dah²nuú³ dsaá² fáh⁴liu⁴ chiú̱h²u³.
\v 7 Ja̱³nɨ́⁴ mɨ³dɨ³ñi³² hi³ jɨɨ⁴ hi³ gá⁴cuoóy¹ jniá³ nɨ³, jmáyh² hi³ chiú̱h²u³ ba² nɨ³.
\v 8 Ma³hoó⁴á⁴ diáh⁴ fáh⁴liu⁴ hi³ gá⁴cuoóy¹ jniá³, baáy⁴ ma³dah²nuú³ dsaá². Chiaah¹ ma³dah²ca̱⁴ cua̱a̱y¹ná² hi³ he̱é̱yh³ ba² xi² je¹u³ nɨ³ cá⁴bí⁴hɨɨ́⁴á⁴ jáy² la³, baáy⁴ ma³taáy³ diáh⁴ hi³ he̱é̱yh³ ba² niu³ nɨ³ gá⁴xɨ́⁴u³ jniá³.
\p 
\v 9 ’Ga³ŋɨɨy⁴ ca̱a̱³ jmɨ²heé¹ chiú̱h²u³ ca³jaa¹ chiáh² diáh⁴, há⁴ja̱³ chiáh² liáh⁴jɨy³ diáh⁴ dsa³ jmɨɨyh⁴²güii³ la³. Ga³liu⁴²á² niu³ ca³jaa¹ chiáh² diáh⁴ hi³ ma³cuó¹u³ jniá³ nɨ³ ba², chiaah¹ hí̱³ba² diáh⁴ hi³ chiú̱h²u³ nɨ³.
\v 10 Hí̱³ba² hi³ chiú̱h²u³ nɨ³ liáh⁴jɨy³ diáh⁴ hi³ ná⁴tayh¹ guaay⁴, baá⁴ ba² hí̱³ba² hi³ chia̱á̱²á⁴ nɨ³ liáh⁴jɨy³ diáh⁴ hi³ ná⁴tayh¹ guaay³². Baáy⁴ ca³dah²jmee⁴ lii⁴ hi³ bií⁴ gaá³á⁴.
\p 
\v 11 ’Há⁴hé³ máh⁴ hi²cueeh⁴²á⁴ jniá³ jmɨɨyh⁴²güii³ la³ joó⁴ hí⁴cueeyh⁴ la³ diáh⁴ hi³ley³², chiaah¹ jniá³ mɨ³ñeh³²á⁴ xi² je¹u³ nɨ³. Baáy⁴ ga³fooh³²á⁴ niu³ Ñuyh⁴, hi³ bií⁴ dxúy⁴, hi³haáh⁴u³ hí¹ diáh⁴ chie̱é̱yh¹ fáh⁴lí³ chiú̱h²u³, diáh⁴ hi³ ma³cuó¹u³ jniá³ nɨ³, duh³ ja̱y³ bɨh¹ hí⁴lí³ diáh⁴ liáh³xɨ³ na³lɨ́⁴a² jnia² nɨ³.
\v 12 Liáh³ rúh⁴ je¹á² chia̱a̱h⁴²á² diáh⁴ jmɨɨyh⁴²güii³ la³, ga³haáh⁴á⁴ hí¹ diáh⁴ hi³ gá⁴cuó¹u³ jniá³ nɨ³ chie̱é̱yh¹ fáh⁴lí³ chiú̱h²u³, baáy⁴ há⁴hé³ ma³cuóy⁴ je² hi³ xa³ hí⁴chi̱í̱yh² diáh⁴. Gu³xɨ³ ja̱y³ há⁴hé³ gá⁴yeéy⁴, ja̱y³ hi³ liáh³dsaayh⁴ mɨ³ná⁴lɨ¹ cua̱a̱y¹ná² dsá⁴yeéy⁴ nɨ³ ba², duh³ hí⁴lí³ liáh³xɨ³ dsa³féh³ ñi² xi³ chiú̱h²u³ nɨ³.
\p 
\v 13 ’Joó⁴ ja̱³nɨ́⁴ mɨ³ñeh³²á⁴ ca̱á̱h³ xi² je¹u³, hi³ja̱³ liáh³ rúh⁴ je¹á² jmɨɨyh⁴²güii³ la³ ga³fayh⁴ hi³la³ duh³ hí⁴jé⁴ dsɨ́² diáh⁴ ja̱³ba² liáh³xɨ³ jé⁴ dsɨy⁴ jniá³.
\v 14 Ma³hoó⁴á⁴ ba² diáh⁴ fáh⁴liu⁴ chiú̱h²u³, joó⁴ hi²xiáh³ dɨ³cɨ̱ɨ̱y³² diáh⁴ dsa³ jmɨɨyh⁴²güii³ nɨ³ ca³dah²ñi³² diáh⁴, chiaah¹ há⁴hé³ máh⁴ na³hiiy⁴ diáh⁴ jmɨɨyh⁴²güii³ la³, ja̱³ba² liáh³xɨ³ xa̱⁴²á⁴ jniá³ há⁴hé³ na³hii⁴²á⁴ jmɨɨyh⁴²güii³ la³.
\v 15 Há⁴hé³ ga³ŋɨɨy⁴ chiú̱h²u³ hi³ hi²teey¹ diáh⁴, duh³ hí⁴dah²tiú² jmɨɨyh⁴²güii³ la³. Ga³ŋɨɨy⁴ hi³ hi²haáh⁴u³ diáh⁴ hí¹ duh³ há⁴hé³ hí⁴juú² hi³há⁴dxúy⁴ nɨ³ chiáh² diáh⁴ ba².
\v 16 Há⁴hé³ máh⁴ na³hiiy⁴ diáh⁴ jmɨɨyh⁴²güii³ la³, ja̱³ba² liáh³xɨ³ jniá³, há⁴hé³ na³hii⁴²á⁴ jmɨɨyh⁴²güii³ la³.
\v 17 Bi³xɨ³ bi³ŋɨɨ́y¹ diáh⁴ dxɨ́⁴lieey³² diáh⁴ fáh⁴liu⁴ hi³ xiaa³dsaa³² chiú̱h²u³ nɨ³. Chiaah¹ ca̱a̱³ fáh⁴liu⁴ chiú̱h²u³ nɨ³ ba² nɨ³ ná⁴lɨ¹ xiaa³dsaa³² cáh³ti³².
\v 18 Ja̱³ba² liáh³xɨ³ gá⁴xɨ́⁴u³ jniá³ jmɨɨyh⁴²güii³, ba² liáh³ja̱³ jniá³ hi²sɨ́⁴á⁴ diáh⁴ xɨh³chia̱á̱²á⁴ nɨ³ jee⁴² jmɨɨyh⁴²güii³.
\v 19 Ga³táh⁴á⁴ guaa³ Dios nɨ³ jmɨɨyh⁴²güii³ chieéy⁴ vih²chiaah¹ diáh⁴ hi³nɨy³², duh³ja̱³ ba² hí⁴xɨ³ hí⁴ŋɨɨ́y³ diáh⁴ dxɨ́⁴lieey³² fáh⁴liu⁴ hi³ xiaa³dsaa³² nɨ³.
\p 
\v 20 ’Joó⁴ ba² há⁴ja̱³ ti̱¹ ca³jaa¹ chiáh² diáh⁴ xɨh³chia̱á̱²á⁴ la³ ga³liu⁴²á² niu³. Ba² ga³ŋɨɨy⁴ ca³jaa¹ chiáh² diáh⁴ hi³ hí⁴dsá⁴taáy³ chieéy⁴ dsa³cɨ̱ɨ̱y³, dxɨ́⁴lieey³² fáh⁴liu⁴ hi³ hí⁴dah²hé⁴ diáh⁴ xɨh³chia̱á̱²á⁴ la³.
\v 21 Ga³ŋɨɨy⁴ chiú̱h²u³ hi³ hu̱² hí⁴ca̱a̱y³ liáh⁴jɨy³ diáh⁴ xɨh³chia̱á̱²á⁴ nɨ³, liáh³xɨ³ jniá³ Ñuyh⁴ chia̱a̱h⁴²á² niu³. Ba² hu̱² hí⁴ca̱a̱y³ diáh⁴ chie̱é̱yh¹ jnia², duh³ dsá⁴taáy³ diáh⁴ dsa³ jmɨɨyh⁴²güii³ nɨ³ hi³ he̱é̱yh³ ba² niu³ nɨ³ gá⁴xɨ́⁴u³ jniá³.
\v 22 Ma³hoó⁴á⁴ ba² diáh⁴ xɨh³chia̱á̱²á⁴ nɨ³ hi³ bií⁴ ná⁴ŋɨy¹ hi³ gá⁴cuoóy¹ jniá³ nɨ³, duh³ hí⁴ca̱a̱y³ diáh⁴, ja̱³ba² liáh³xɨ³ xa̱³²a² jnia² hi³ na³lɨ́⁴a² ja̱y³ dsa³ ba².
\v 23 Jniá³ na³cu̱h⁴²á⁴ chia̱a̱h⁴²á² diáh⁴ baáy⁴ niu³ na³cu̱h⁴u³ chia̱á̱h¹u³ jniá³, duh³ja̱³ hu̱² hí⁴ca̱a̱y³ diáh⁴. Mɨ²ja̱³ hí⁴dah²cá̱² cua̱a̱y¹ná² diáh⁴ dsa³ jmɨɨyh⁴²güii³ nɨ³ hi³ niu³ nɨ³ gá⁴xɨ́⁴u³ jniá³, baáy⁴ duh³ hí⁴dsaá⁴ dsɨ́² diáh⁴ hi³ bií⁴ naá⁴u³ diáh⁴ xɨh³chia̱á̱²á⁴ nɨ³ ja̱³ba² liáh³xɨ³ naá⁴u³ jniá³.
\p 
\v 24 ’Ñuyh⁴, niu³ nɨ³ ma³cuó¹u³ jniá³ diáh⁴ dsa³ nɨ³, hi³ja̱³ naáy⁴ hi³ hí⁴dah²güe³ chie̱é̱yh¹ jniá³, ja̱³ba² xi² ya³güéy⁴ nɨ³, duh³ hí⁴dah²joó² liáh³nɨɨh¹ gaáy³ xi² ma³dxa⁴²u³ jniá³. Chiaah¹ liáh³dsaayh⁴ naá⁴u³ jniá³ ba² nɨ³ liáh³ca̱á̱h³ ja̱a̱h¹ hí⁴niaá⁴ jmɨɨyh⁴²güii³ nɨ³.
\v 25 Ñuyh⁴ hi³ bií⁴ dxúy⁴ nɨ³, há⁴hé³ dɨ³cui̱i̱y⁴ niu³ diáh⁴ dsa³ jmɨɨyh⁴²güii³ nɨ³. Joó⁴ cui̱i̱⁴²á⁴ ba² jniá³ niu³, baáy⁴ mɨ³dɨ³ñi³² ba² diáh⁴ xɨh³chia̱á̱²á⁴ la³ hi³ niu³ nɨ³ gá⁴xɨ́⁴u³ jniá³.
\v 26 Ma³hoó⁴á⁴ ba² diáh⁴ liáh³xɨ³ na³lɨ́⁴u³, baáy⁴ dsá⁴hɨɨ́² gɨh¹ hi²hoó⁴á⁴ diáh⁴ liáh³xɨ³ na³lɨ́⁴u³, duh³ hí⁴dsaá⁴ dsɨ́² diáh⁴ hi³ naá⁴u³ diáh⁴ ja̱³ba² liáh³xɨ³ naá⁴u³ jniá³, baáy⁴ duh³ hi²cu̱h⁴²á² chia̱a̱h⁴²á² diáh⁴.
\c 18
\s1 La³ dsa³féh³ hi³ cá⁴dah²güeéyh² Jesús ja̱³
\r (Mt. 26:47-56; Mr. 14:43-50; Lc. 22:47-53)
\p 
\v 1 Liáh³ ma³jooy³ ma³liúy² Dios Jesús ja̱³, mɨ²ja̱³ ŋaá² chie̱é̱yh¹ jniaah¹ diáh⁴ xɨh³chie̱y³² ja̱³ xiaáh³ ca³jaa¹ guaá³ hi³ xɨ̱ɨ̱y³ Cedrón. Nɨɨ́⁴ tiaah² ma³ olivo, hi³ja̱³ jee⁴² ma³ olivo ja̱³ gá⁴hí³ Jesús ja̱³ chie̱é̱yh¹ jniaah¹.
\v 2 Ba² cui̱i̱³ nɨɨ́⁴ Judas hi³ mɨ³hí⁴jmeéh⁴ mɨ³hee³² Jesús ja̱³, chiaah¹ hi²xiáh³ ñuú³ tiaah² ñií¹ nɨɨ́⁴ Jesús ja̱³ chie̱é̱yh¹ jniaah¹ mɨ² dsa³jéy⁴ liáh³ja̱³.
\v 3 Hi³ja̱³ gá⁴dxaá² nɨɨ́⁴ Judas ja̱³ chie̱é̱yh¹ ca̱á̱h³ tiéyh⁴ diáh⁴ soldados baáy⁴ chie̱é̱yh¹ diáh⁴ policías, hi³ cá⁴dah²xɨɨ́⁴ diáh⁴ jmii³dsa³ cáyh¹ chie̱é̱yh¹ diáh⁴ fariseos, dɨ³xa̱h³ lanzas, dɨ³xa̱h³ túh², ba² dɨ³xa̱h³ xi³.
\v 4 Mɨ³ñi³² ba² Jesús ja̱³ liáh³xɨ³ mɨ³hí⁴chi̱í̱yh² ja̱³, hi³ja̱³ gá⁴ŋɨɨ́h⁴ diáh⁴ juúh⁴, liáh³la³ ba² gá⁴sɨɨ́h⁴ diáh⁴:
\p ―¿Hi̱² nɨy³² ga³naah⁴ah³ nɨ³?
\p 
\v 5 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ dsa³ ja̱³:
\p ―Jesús dsa³ Nazaret nɨ³ ga³naah³²ah¹.
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Jniá³ nɨ³ Jesús.
\p Hiíy⁴ nɨɨ́⁴ Judas hi³ mɨ³hí⁴jmeéh⁴ mɨ³hee³² Jesús ja̱³ na³cu̱yh⁴ chie̱é̱yh¹ diáh⁴ dsa³ ja̱³.
\v 6 Liáh³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴: “Jniá³ nɨ³”, mɨ²ja̱³ gá⁴dxí̱⁴ diáh⁴ xiáh³ rúh⁴caáh¹ ja̱³ba² gá⁴cɨ́yh⁴ diáh⁴ dxaah¹vó⁴.
\v 7 Mɨ²ja̱³ gá⁴ŋɨɨ́³ ca̱á̱h³ juúh⁴ Jesús ja̱³, liáh³la³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―¿Hi̱² nɨy³² ga³naah⁴ah³ nɨ³?
\p Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ dsa³ ja̱³:
\p ―Jesús dsa³ Nazaret nɨ³ nɨ³ ga³naah³²ah¹.
\p 
\v 8 Mɨ²ja̱³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Ma³foóh²á⁴ ba² niaá⁴ah³ hi³ jniá³ nɨ³. Hi³ja̱³ xɨ³ jniá³ nɨ³ ga³naah⁴ah³, cuó¹ah³ je² cua²dsa³dxi̱i̱³² diáh⁴ oóh²á⁴ la³.
\p 
\v 9 Gá⁴lɨ́⁴ liáh³ja̱³ duh³ hí⁴dxá⁴héy³ hí⁴lí³ liáh³xɨ³ gá⁴féh³ ñaá² Jesús ja̱³, chiaah¹ liáh³la³ ma³féh³ mɨ³du³liáh³ liáh³ja̱³: “Gu³xɨ³ ja̱y³ diáh⁴ hi³ ma³cuó¹u³ jniá³ nɨ³ Ñuyh⁴ há⁴hé³ gá⁴yeéy⁴.”
\v 10 Xa̱h³ Pedro ja̱³ ca̱a̱³ túh², hi³ja̱³ ja̱³ba² gá⁴dxɨ³ túh² chiáh² ja̱³ duh³ gá⁴chiuúh² la³gua² hi³ nuy¹ ja̱y³ dsa³ hi³ xɨ̱ɨ̱y³ Malco, hi³ na³lɨ́y⁴ mozo chié̱y² jmii³dsa³ gaáy³ ja̱³.
\v 11 Joó⁴ liáh³la³ ba² gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ Pedro ja̱³:
\p ―Tia̱a̱h⁴ ca̱á̱h³ ñu² túh² chiú̱h²u³ nɨ³. Chiaah¹ ga³jmee⁴ hi²uuyh⁴² hi³ ma³cuó³ Ñuyh⁴ nɨ³ hi²uuyh⁴².
\s1 Dah²ya²jay⁴ Jesús ja̱³ rúh⁴ñi² jmii³dsa³ gaáy³
\r (Mt. 26:57-58; Mr. 14:53-54; Lc. 22:54)
\p 
\v 12 Mɨ²ja̱³ diáh⁴ soldados ja̱³ chie̱é̱yh¹ comandante chié̱y² diáh⁴, baáy⁴ na³cu̱yh⁴ liáh³ja̱³ chie̱é̱yh¹ diáh⁴ policías ja̱³, cá⁴dah²güeéyh² Jesús ja̱³ baáy⁴ duh³ cá⁴dah²ñuúy⁴.
\v 13 Mɨ²ja̱³ dah²ya²jay⁴ xiaa³dsaa³² chiáh² ja̱y³ hi³ xɨ̱ɨ̱y³ Anás, jmii³ mɨ́⁴chiáh² Caifás hi³ na³lɨ́y⁴ fii² diáh⁴ jmii³dsa³ ji̱i̱³ mɨ²ja̱³,
\v 14 hí̱³ba² Caifás hi³ gá⁴féh³ gá⁴sɨɨ́h⁴ diáh⁴ israelitas ja̱³ hi³ ja̱y³ ba² dsa³ ga³jmee⁴ hí⁴jú̱y³ dxa² liáh⁴jɨy³ diáh⁴ dsa³ vó⁴ chiáh².
\s1 Gá⁴féh³ Pedro ja̱³ hi³ há⁴hé³ cui̱i̱⁴ Jesús
\r (Mt. 26:69-70; Mr. 14:66-68; Lc. 22:55-57)
\p 
\v 15 Ŋaá² Simón Pedro ja̱³ ta³nieéy¹ rúh⁴cah² Jesús ja̱³ liáh³ cá⁴dah²jéy⁴, chie̱é̱yh¹ gɨh¹ ja̱y³ diáh⁴ oóyh² ja̱³. Joó⁴ cui̱i̱⁴ oóyh² chie̱é̱yh¹ fii² diáh⁴ jmii³dsa³ ja̱³ hi³ ŋaá² chie̱é̱yh¹ Pedro ja̱³, hi³ja̱³ gá⁴jooy³ ŋaá² chie̱é̱yh¹ Jesús ja̱³ dxaa² chiáh² fii² diáh⁴ jmii³dsa³ ja̱³.
\v 16 Joó⁴ xiáh³ tɨɨ́² calle ba² gá⁴cueeyh⁴ Pedro ja̱³. Hi³ja̱³ cá⁴bí⁴hɨɨ́y⁴ xɨh³chie̱y³² hi³ dɨ³cui̱i̱y⁴ oóyh² chie̱é̱yh¹ Anás ja̱³, duh³ gá⁴liú³ chie̱é̱yh¹ mɨ́³ hi³ heeh⁴ hí¹ haah²ñu¹ ja̱³, gá⁴sɨɨ́h⁴ hi³ hu̱² hí⁴jooy³ dsá⁴hí³ Pedro ja̱³. Hi³ja̱³ gá⁴ta̱a̱yh³ Pedro ja̱³ dxaa² chiáh² jmii³dsa ja̱³.
\v 17 Mɨ²ja̱³ liáh³la³ gá⁴féh³ mɨ́³ ja̱³ gá⁴sɨɨ́h⁴ Pedro ja̱³:
\p ―Niu³ nɨ³ oóyh² diáh⁴ xɨh³chie̱y³² Jesús nɨ³, ¿xɨ² haá²?
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ Pedro ja̱³:
\p ―Haá², há⁴hé³ na³lɨ́⁴á⁴ xɨh³chie̱y³² dsa³ nɨ³.
\p 
\v 18 Hi²xiáh³ güií³ voo⁴ mɨ²ja̱³, hi³ja̱³ cá⁴dah²xé̱yh² xi³ diáh⁴ policías ja̱³ chie̱é̱yh¹ diáh⁴ mozos chié̱y² diáh⁴ jmii³dsa³ cáyh¹, hi³ja̱³ na³ta̱a̱y⁴ nɨɨ́⁴ dah²dxaáh⁴ xi³. Ba² hiíy⁴ nɨɨ́⁴ Pedro ja̱³ chie̱é̱yh¹ diáh⁴, ba² dxaáh⁴ xi³.
\s1 Gá⁴ca̱a̱⁴ cua̱a̱y¹ná² Anás ja̱³ chiáh² Jesús
\r (Mt. 26:59-66; Mr. 14:55-64; Lc. 22:66-71)
\p 
\v 19 Mɨ²ja̱³ gá⁴laá⁴ fii² diáh⁴ jmii³dsa³ ja̱³ mɨ³ŋɨɨ́h⁴ juúh⁴ Jesús ja̱³ hi³ hi̱² ga² hí̱³ diáh⁴ xɨh³chie̱y³² ja̱³, baá⁴ ba² ŋɨɨ́h⁴ juúh⁴ hi³ he² ga² ja̱³ ga³he⁴ ja̱³. \fig Juan 18:19|src="CN01815B.TIF" size="span" ref="San Juan 18:19"\fig*
\v 20 Hi³ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Ga³liu⁴²á² ba² jí̱⁴ñí³ diáh⁴ dsa³. Ga³hoy⁴ ba² fah² Dios nɨ³ diáh⁴ ñuúh⁴guah³ liuh² baáy⁴ xi² jey¹ guah³ gaáy³, ja̱³ba² xi² ga³ŋɨɨh⁴²a² liáh⁴jɨ³²a² nɨ³. Hi³ja̱³ há⁴hé³ xa³ hi³ ma³liúy⁴ na³ma².
\v 21 ¿He²chiaah¹ hi³ jniá³ nɨ³ ga³ŋɨɨyh³² juúh⁴ nɨ³? Ŋɨɨh² juúh⁴ diáh⁴ hi³ ma³dah²nuú³ liáh³xɨ³ ma³hóy⁴ nɨ³ ba². Diáh⁴ hi³nɨy³² ba² nɨ³ dɨ³ñi³² he² ga² nɨ³ ma³hóy⁴ nɨ³.
\p 
\v 22 Liáh³ gá⁴féh³ liáh³ja̱³ Jesús ja̱³, mɨ²ja̱³ ja̱y³ diáh⁴ policía hi³ na³ta̱a̱y⁴ nɨɨ́⁴ gá⁴chiu̱ú̱³ ñi² Jesús ja̱³, baáy⁴ duh³ liáh³la³ gá⁴sɨɨ́h⁴:
\p ―¿He²chiaah¹ hi³ ga³liu⁴²u³ liáh³nɨ³ fii² diáh⁴ jmii³dsa³ nɨ³?
\p 
\v 23 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³:
\p ―Xɨ³ nɨ³ ma³liúy⁴ mɨ³hee³², feh² jmiih⁴² nɨ³ ná⁴lɨ¹ hi³ mɨ³hee³² nɨ³. Joó⁴ xɨ³ ma³liúy⁴ ba² dxú⁴, hi³ja̱³ he²chiaah¹ hi³ ga³tɨ̱́⁴u³ jniá³ nɨ³.
\p 
\v 24 Mɨ²ja̱³ gá⁴xɨɨ́⁴ Anás ja̱³ gá⁴xɨ́y⁴ Jesús ja̱³, xi² jey¹ Caifás, fii² diáh⁴ jmii³dsa³ ja̱³, na³ñuúy⁴ liáh³ja̱³ Jesús ja̱³.
\s1 Gá⁴féh³ ca̱á̱h³ Pedro ja̱³ hi³ há⁴hé³ cui̱i̱⁴ Jesús
\r (Mt. 26:71-75; Mr. 14:66-72; Lc. 22:58-62)
\p 
\v 25 Hiíy⁴ chiáh² liáh³ja̱³ Pedro ja̱³ caa¹ xi³ ja̱³, hi³ dxaáh⁴ xi³. Mɨ²ja̱³ liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―¿Xɨ² há⁴hí̱³ niu³ nɨ³ na³lɨ́⁴u³ ja̱y³ diáh⁴ xɨh³chie̱y³² dsa³ nɨ³?
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ ca̱á̱h³ Pedro ja̱³:
\p ―Haá², há⁴hé³ na³lɨ́⁴á⁴ xɨh³chie̱y³² dsa³ nɨ³.
\p 
\v 26 Ba² hiíy⁴ nɨɨ́⁴ ja̱y³ mozo chié̱y² fii² diáh⁴ jmii³dsa³ ja̱³, hí̱³ba² ja̱á̱¹ hi³chie̱y³² dsa³ hi³ gá⁴chiuúh² Pedro ja̱³ la³gua² liáh³ cá⁴dah²jéy⁴ Jesús ja̱³. Hi³ja̱³ liáh³la³ gá⁴féh³ hi³hí̱³ gá⁴sɨɨ́h⁴ Pedro ja̱³:
\p ―Ma³joó²á⁴ ba² jniá² niu³ jee⁴² huerto nɨ³ na³cu̱h⁴u³ chia̱á̱h¹u³ dsa³ nɨ³.
\p 
\v 27 Mɨ²ja̱³ gá⁴féh³ ca̱á̱h³ Pedro ja̱³ hi³ há⁴hé³ na³lɨ́y⁴ oóyh² Jesús ja̱³. Xé̱yh² ba² mɨ²ja̱³ gá⁴chíh⁴ ja̱y³ nɨɨh² dsaá⁴.
\s1 Dah²ya²jay⁴ Jesús ja̱³ rúh⁴ñi² Pilato
\r (Mt. 27:1-2, 11-14; Mr. 15:1-5; Lc. 23:1-5)
\p 
\v 28 Mɨ²ja̱³ cá⁴dah²jéy⁴ Jesús ja̱³ duh³ dah²ya²jay⁴ palacio chiáh² gobernador. Ja̱³ba² mɨ³dse³jnia³, joó⁴ há⁴hé³ gá⁴taáyh¹ diáh⁴ israelitas ja̱³ xɨ¹ñúh⁴ palacio ja̱³, chiaah¹ na³héy¹ diáh⁴. Chiaah¹ liu³u²xɨ³ hu̱² gá⁴taáyh¹ diáh⁴, mɨ²ja̱³ há⁴hé³ máh⁴ hí⁴jooy³ hí⁴dah²cuyh³ mɨ¹ja̱á̱² dsɨɨ³jaa³ ja̱³.
\v 29 Hi³ja̱³ cá⁴bí⁴hɨɨ́y⁴ Pilato ja̱³ gá⁴liúy² diáh⁴, liáh³la³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―¿He² dsaa² nɨ³ cuo³ah³ chiáh² dsaá⁴ nɨ³?
\p 
\v 30 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³:
\p ―Há⁴hé³ ma³ya³já⁴ah¹ rúh⁴ñíy¹ la³ liu³u²xɨ³ hu̱² há⁴hé³ gaáy³ dsaa² hi³ ma³jmeé³ nɨ³.
\p 
\v 31 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Pilato ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Jé⁴ah³ niaá⁴ah³, duh³ chia̱a̱⁴ah³ cua̱a̱y¹ná² liáh³xɨ³ ná⁴lɨ¹ ley chia̱á̱²ah³ vo̱ó̱h²ah³ xa³ja̱³.
\p Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³:
\p ―Joó⁴ há⁴hé³ hee⁴²ah¹ jú¹hiíh⁴ jniaah¹ israelitas nɨ³ hi²jɨ̱h⁴²ah¹ gu³xɨ³ ja̱y³ dsa³.
\p 
\v 32 Liáh³ja̱³ gá⁴lɨ́⁴ duh³ hí⁴dxá⁴héy³ hí⁴lí³ liáh³xɨ³ gá⁴féh³ ñaá² Jesús ja̱³ hi³ gá⁴jmeé³ juúh⁴ liáh³xɨ³ ná⁴lɨ¹ hí⁴lí³ hí⁴jú̱y³.
\v 33 Mɨ²ja̱³ gá⁴hí³ ca̱á̱h³ Pilato ja̱³ palacio chiáh², ja̱³ba² gá⁴teé⁴ Jesús ja̱³, duh³ liáh³la³ gá⁴sɨɨ́h⁴:
\p ―¿Xɨ² niu³ nɨ³ Rey chié̱y² diáh⁴ israelitas?
\p 
\v 34 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―¿Xɨ² hi³ ga³ŋɨɨ́y¹ juúh⁴ hi³ lɨ́³ háy² vo̱ó̱h²u³ nɨ³, ha²xɨ² hi³ ma³niuuy³ liáh³xɨ³ dah²féh³ chieéy⁴ diáh⁴ dsa³ nɨ³?
\p 
\v 35 Mɨ²ja̱³ gá⁴féh³ ca̱á̱h³ Pilato ja̱³:
\p ―¿Xɨ²fáh³ na³lɨ́⁴á⁴ jniá³ israelita? Hí̱³ba² diáh⁴ dsa³ oóh²u³ nɨ³ chie̱é̱yh¹ diáh⁴ jmii³dsa³ cáyh¹ nɨ³ ba² nɨ³, ma³dah²bi²jay⁴ niu³ rúh⁴ñiy⁴ la³. ¿He² nɨ³ gá⁴jmeéy¹?
\p 
\v 36 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ Pilato ja̱³:
\p ―Há⁴ja̱³ jmɨɨyh⁴²güii³ la³ nɨ³ ga³chiuuyh³² hiíh⁴ jniá³. Chiaah¹ hu̱² liáh³ja̱³, mɨ²ja̱³ ma³dah²tí̱² diáh⁴ xɨh³chia̱á̱²á⁴ nɨ³, duh³ há⁴hé³ ma³dah²güeéyh² jniá³ diáh⁴ israelitas nɨ³ hu̱² liáh³ja̱³. Joó⁴ há⁴ja̱³ dxaah¹vó⁴ la³ nɨ³ ga³chiuuyh³² hiíh⁴ jniá³.
\p 
\v 37 Mɨ²ja̱³ gá⁴féh³ Pilato ja̱³ gá⁴sɨɨ́h⁴ Jesús:
\p ―¿Hi³ja̱³ xɨ² he̱é̱yh³ ba² na³lɨ́⁴u³ rey?
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―He̱é̱yh³ ba² na³lɨ́⁴á⁴ rey liáh³xɨ³ ma³féyh¹ nɨ³. Hi³ja̱³ nɨ³ gá⁴sa̱⁴²á⁴ jniá² duh³ hi²hoy⁴² jmáyh² hi³ xiaa³dsaa³². Hi³ja̱³ ba² nɨ³ güé⁴á⁴ jmɨɨyh⁴²güii³ la³. Liáh⁴jɨy³ diáh⁴ hi³ ga³ji̱í̱h⁴ dxú⁴ fáh⁴liu⁴ hi³ xiaa³dsaa³² nɨ³, ca³dah²jmee⁴ he̱é̱yh³ fáh⁴liu⁴ chieéy⁴.
\p 
\v 38 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Pilato ja̱³ gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―¿He² ga² nɨ³ hi³ xiaa³dsaa³² nɨ³?
\s1 Cá⁴dah²taáh⁴ ta² hi³ hí⁴jú̱y³ Jesús ja̱³
\r (Mt. 27:15-31; Mr. 15:6-20; Lc. 23:13-25)
\p Liáh³ gá⁴féh³ liáh³ja̱³, mɨ²ja̱³ cá⁴bí⁴hɨɨ́y⁴ ca̱á̱h³ duh³ hí⁴liú⁴ chie̱é̱yh¹ diáh⁴ israelitas ja̱³, liáh³la³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Ma³ca̱á̱y² cua̱a̱y¹ná² hi³ há⁴hé³ xa³ dsaa² chiáh² dsa³ nɨ³.
\v 39 Joó⁴ niaá⁴ah³ nɨ³ ná⁴lɨ¹ costumbre chia̱á̱²ah³ hi³ ga³jmee⁴ hi²tú⁴á⁴ ja̱y³ hi³ ná⁴híy¹ ñuúh⁴ñí¹ nɨ³ jee⁴² jmɨ́¹feh⁴ hi³ ga³cuh³ah³ mɨ¹ja̱á̱² dsɨɨ³jaa³ nɨ³. Hi³ja̱³ ¿xɨ² naa³ah³ hi³ hi²tú⁴á⁴ Rey chié̱y² diáh⁴ israelitas nɨ³?
\p 
\v 40 Mɨ²ja̱³ liáh⁴jɨy³ lɨ́⁴ cá⁴dah²liú³ chiu̱u̱³ cáh³ti³², liáh³la³ cá⁴dah²féh³:
\p ―¡Haá², há⁴hí̱³ hi³nɨy³²! ¡Tiúy⁴ Barrabás nɨ³ ba²!
\p Chiaah¹ na³lɨ́y⁴ dsa³hi̱i̱³ Barrabás ja̱³, hi³ja̱³ ja̱³ na³lɨ́y⁴ preso.
\c 19
\p 
\v 1 Mɨ²ja̱³ gá⁴jeé⁴ Pilato ja̱³ gá⁴jéy⁴ Jesús, duh³ gá⁴taáh⁴ ta² hí⁴bay⁴².
\v 2 Ba² cá⁴dah²vó² diáh⁴ soldados ja̱³ ca̱a̱³ lɨh³ ná¹ta̱á̱² duh³ cá⁴dah²ta̱á̱h⁴ dxɨ² Jesús ja̱³ dxa² corona, baáy⁴ cá⁴dah²bi³chíh³ ca̱a̱³ mɨh³ hi³ yu̱ú̱³ lieyh³ liáh³xɨ³ hi³ ga³cɨh³² ja̱y³ rey.
\v 3 Ja̱³ba² cá⁴dxá⁴jé̱yh⁴ diáh⁴ yeey⁴ rúh⁴ñi² Jesús ja̱³, duh³ liáh³la³ cá⁴dah²sɨɨ́h⁴:
\p ―¡Gua²xa̱³u³ liáh³nɨ³ niu³ Rey chié̱y² diáh⁴ israelitas nɨ³!
\p Ja̱³ba² dah²chiu̱u̱⁴ liáh³ja̱³ ñi² Jesús ja̱³.
\p 
\v 4 Mɨ²ja̱³ cá⁴bí⁴hɨɨ́y⁴ ca̱á̱h³ Pilato ja̱³ duh³ liáh³la³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Joo⁴²ah³ ruh³, hi²dxɨ¹á² la³ duh³ hí⁴dsaá⁴ há²ah³ hi³ jniá³ ca³jaa¹ chieéy⁴ há⁴hé³ hí⁴dxeeyh⁴ cáh³ti³² dsaa² chiáh².
\p 
\v 5 Hi³ja̱³ cá⁴bí⁴hɨɨ́y⁴ Jesús ja̱³, ná⁴hi⁴² liáh³ja̱³ lɨh³ ná¹ta̱á̱² ja̱³ mɨ¹dxɨ², ba² chih³ liáh³ja̱³ mɨh³ yu̱ú̱³ lieyh³ hi³ ma³dah³bi³chíyh³ ja̱³. Mɨ²ja̱³ liáh³la³ gá⁴féh³ Pilato ja̱³ gá⁴sɨɨ́h⁴ diáh⁴ dsaá⁴ ja̱³:
\p ―¡Hi³ley³² dsaá⁴ nɨ³!
\p 
\v 6 Liáh³ cá⁴dah²joóy² Jesús ja̱³ diáh⁴ jmii³dsa³ cáyh¹ chie̱é̱yh¹ diáh⁴ policías ja̱³, mɨ²ja̱³ cá⁴dah²laá⁴ mɨ³dah²jla³² dah²te³², liáh³la³ dah²féh³:
\p ―¡Tie̱e̱y⁴² cruz! ¡Tie̱e̱y⁴² cruz!
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ Pilato ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Na³fáyh⁴ jé⁴ah³ niaá⁴ah³ duh³ gua³tia̱a̱⁴²ah³ cruz, chiaah¹ jniá³ maay⁴ hi³ há⁴hé³ xa³ dsaa² chiáh² dsa³ la³.
\p 
\v 7 Joó⁴ mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³:
\p ―Xa³ ca̱a̱³ ley chiaa⁴²ah¹ jniaah¹, baáy⁴ liáh³xɨ³ na³caah⁴ ley nɨ³ ga³jmee⁴ hí⁴jú̱y³, chiaah¹ gá⁴jméy² ñaá² Ja̱á̱² Dios.
\p 
\v 8 Liáh³ gá⁴nuú³ Pilato liáh³xɨ³ cá⁴dah²féh³ ja̱³ mɨ²ja̱³ hi³ já⁴ gá⁴foyh⁴ ba².
\v 9 Hi³ja̱³ gá⁴hii³² ca̱á̱h³ palacio ja̱³ duh³ liáh³la³ gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―¿Hi̱² dsa³ nɨ³ niu³?
\p Joó⁴ há⁴hé³ gá⁴hí̱¹ cáh³ti³² Jesús ja̱³.
\p 
\v 10 Hi³ja̱³ liáh³la³ gá⁴féh³ ca̱á̱h³ Pilato ja̱³ gá⁴sɨɨ́h⁴:
\p ―¿Xɨ² há⁴hé³ hi²hí̱¹u³ hi³ ga³fooh³²á⁴ niu³ liáh³nɨ³? ¿Xɨ² há⁴hé³ maáy³ hi³ haay⁴ jú¹hiíh⁴ hi³ hi²tia̱a̱⁴²á² niu³ cruz baá⁴ ba² haay⁴ ba² jú¹hiíh⁴ hi³ hi²tú⁴á⁴ niu³?
\p 
\v 11 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Há⁴hé³ hí⁴jooy³ hi²chiuúyh³ hiíh⁴ chieéy⁴, xɨ³ nɨ³ há⁴hé³ ma³cuoó⁴ niu³ jú¹hiíh⁴ Dios nɨ³. Hi³ja̱³ hi³ ma³bi²jay⁴ jniá³ rúh⁴ñíy¹ nɨ³ ba² nɨ³ veyh³ gɨh¹ dsaa² chiáh² liáh³xɨ³ niu³.
\p 
\v 12 Xé̱yh² ba² mɨ²ja̱³ mɨ³naah³² Pilato ja̱³ jmiih⁴² hí⁴jmeé⁴ duh³ hí⁴tiúy² Jesús ja̱³. Joó⁴ mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ israelitas ja̱³:
\p ―¡Há⁴hé³ na³lɨ́⁴u³ amigo chié̱y² César xɨ³ nɨ³ hi²tú⁴u³ Jesús nɨ³! ¡Chiaah¹ gu³xɨ³ hí̱³ba² hi³ hí⁴jméy² ñaá² rey, hi³hí̱³ na³chiy⁴ chie̱é̱yh¹ César nɨ³!
\p 
\v 13 Liáh³ gá⁴nuú³ Pilato hi³ cá⁴dah²féh³ liáh³ja̱³ diáh⁴ dsa³ ja̱³, mɨ²ja̱³ gá⁴taáh⁴ ta² cá⁴dah²dxɨy³ tɨɨ́² Jesús ja̱³, duh³ gá⁴guá³ ñaá² Pilato ja̱³ xi² ga³guá³ ga³ca̱a̱⁴ cua̱a̱y¹ná². Gábata xɨ̱ɨ̱y³ nɨɨ́⁴, liáh³ja̱³ ca³dah²féh³ fáh² hebreo, hi³ niaá⁴ hí⁴féh³: Xi² na³jaáh³ na¹cu̱ú̱¹.
\v 14 Jmɨɨ́¹ liáh³ laáh² chiáh² jmɨ́¹feh⁴ hi³ ga³cuh³²ah¹ mɨ¹ja̱á̱² dsɨɨ³jaa³ ja̱³ mɨ²ja̱³, ca̱³liáh³ dxaá⁴ñíh² xɨ³ jmiih⁴, mɨ²ja̱³ liáh³la³ gá⁴féh³ Pilato ja̱³ gá⁴sɨɨ́h⁴ diáh⁴ israelitas ja̱³:
\p ―¡Hi³ley³² rey chia̱á̱²ah³ nɨ³!
\p 
\v 15 Joó⁴ liáh³la³ ba² cá⁴dah²féh³ diáh⁴ dsa³ ja̱³:
\p ―¡Gua²jú̱y³! ¡Gua²jú̱y³! ¡Tie̱e̱y⁴² cruz!
\p Mɨ²ja̱³ gá⁴féh³ Pilato ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―¿Xɨ² foóh¹ hí⁴jooy³ hi²tia̱a̱⁴²á² cruz rey chia̱á̱²ah³ nɨ³?
\p Joó⁴ mɨ²ja̱³ cá⁴dah²féh³ diáh⁴ jmii³dsa³ cáyh¹ ja̱³:
\p ―Há⁴hé³ máh⁴ xe̱y³ gɨh¹ dxeeyh⁴ rey chia̱a̱⁴²ah¹ jniaah¹, ti̱¹ rey César nɨ³ ba².
\p 
\v 16 Liáh³ cá⁴dah²féh³ liáh³ja̱³, mɨ²ja̱³ gá⁴cuó³ je² Pilato ja̱³ hí⁴dsá⁴ta̱a̱y⁴² cruz Jesús ja̱³, hi³ja̱³ mɨ²ja̱³ cá⁴dah²jeé⁴ diáh⁴ soldados ja̱³.
\s1 La³ dsa³féh³ hi³ gá⁴ta̱a̱y⁴² cruz Jesús
\r (Mt. 27:32-44; Mr. 15:21-32; Lc. 23:26-43)
\p 
\v 17 Hi³ja̱³ cá⁴bí⁴hɨɨ́y⁴ Jesús ja̱³ mɨ³chia̱³ cruz chiáh², duh³ ŋaá² xi² xɨ̱ɨ̱y³ Mee⁴ mɨ¹dxɨ² dsa³, xi² ca³dah²he⁴ Gólgota fáh² hebreo. \fig Juan 19:17|src="CN01833B.TIF" size="span" ref="San Juan 19:17"\fig*
\v 18 Nɨɨ́⁴ cá⁴dah²tie̱e̱y³ cruz Jesús ja̱³. Ba² aáy⁴ gɨh¹ diáh⁴ hi³ xa³ dsaa² chiáh² cá⁴dah²tie̱e̱y³ dsaah⁴ cruz máh⁴ ja̱y³ liáh³ ca³jaa¹ caayh⁴ Jesús ja̱³, jee⁴² cá⁴dah²tie̱e̱y³ Jesús ja̱³.
\v 19 Ba² gá⁴xɨɨ́³ Pilato ja̱³ ca̱a̱³ má⁴jma¹ duh³ cá⁴dah²tia̱á̱² dsaah⁴ cruz xi² ta̱a̱y⁴ Jesús ja̱³, liáh³la³ gá⁴xɨɨ́³: “Jesús dsa³ Nazaret, Rey chié̱y² diáh⁴ israelitas.”
\v 20 Na³xɨɨ² fáh² hebreo, fáh² griego, baáy⁴ latín. Hi³ja̱³ hi²xiáh³ fɨɨ́y⁴ diáh⁴ israelitas cá⁴dah²hé³ vóh² ja̱³, chiaah¹ yeey⁴ yaa¹ fɨɨ³ ja̱³ cá⁴dah²tie̱e̱y³ cruz Jesús ja̱³.
\v 21 Hi³ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ jmii³dsa³ cáyh¹ chié̱y² diáh⁴ israelitas ja̱³, cá⁴dah²sɨɨ́h⁴ Pilato ja̱³:
\p ―Há⁴ hi³xɨɨy³ “Rey chié̱y² diáh⁴ israelitas.” Na³fáyh⁴ xɨɨ², “Hi³ley³² nɨ³ ga³féh³ hi³ na³lɨ́y⁴ Rey chié̱y² diáh⁴ israelitas nɨ³.”
\p 
\v 22 Joó⁴ mɨ²ja̱³ gá⁴féh³ Pilato ja̱³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Cua¹á²lɨ¹ liáh³xɨ³ ná⁴lɨ¹ ma³xɨɨ́y⁴ nɨ³.
\p 
\v 23 Liáh³ ma³dah²tie̱e̱y³ cruz Jesús ja̱³ diáh⁴ soldados ja̱³, mɨ²ja̱³ cá⁴dah²cá̱⁴ mɨh³ chiáh² duh³ cá⁴dah²jmeé³ chiú̱³ sɨ̱ɨ̱yh², máh⁴ ca̱a̱³ sɨ̱ɨ̱yh² chiáh² liáh³ja̱y³ liáh³ja̱y³ diáh⁴ soldado ja̱³. Ba² cá⁴dah²cá̱⁴ mɨh³ ta³sɨh² vó⁴ chiáh², hi³ há⁴hé³ na³fáyh⁴ na³mi², ca̱a̱³ jmaa² mɨh³ dsaá² liáh³nɨ³ ba².
\v 24 Hi³ja̱³ liáh³la³ cá⁴dah²sɨɨ́h⁴ oóyh² diáh⁴ soldados:
\p ―Há⁴hé³ hi²xɨɨ⁴²a² hi³la³, na³fáyh⁴ gɨh¹ hi²caah⁴²a² jmɨɨ́⁴ duh³ hi²nia⁴²a² hi̱² jnia² hí⁴dxá⁴hé³a² ba².
\p Gá⁴lɨ́⁴ liáh³ja̱³ duh³ hí⁴dxá⁴héy³ hí⁴lí³ liáh³xɨ³ na³xɨɨ² xi³ chiáh² Dios, chiaah¹ liáh³la³ na³xɨɨ²: “Cá⁴dah²caáh² jmɨɨ́⁴ chiáh² mɨh³ chieéy⁴ duh³ hí⁴dah²ñí² hi̱² na²nɨy¹ diáh⁴ hí⁴tɨ̱́y⁴.” Hi³ja̱³ liáh³ja̱³ cá⁴dah²jmeé³ diáh⁴ soldados ja̱³.
\p 
\v 25 Yeey⁴ xi² xɨ́h² cruz ja̱³ hiíy⁴ xaá¹ Jesús ja̱³, chie̱é̱yh¹ du³mɨɨ́h³, María mɨ́⁴chiáh² Cleofas, baáy⁴ chie̱é̱yh¹ María Magdalena.
\v 26 Liáh³ gá⁴joó² Jesús ja̱³ gá⁴joóy² xaá¹, baáy⁴ gá⁴joóy² xɨh³chie̱y³² hi³ bií⁴ nieéy² ja̱³, hiíy⁴ caayh³² xaá¹ ja̱³, mɨ²ja̱³ liáh³la³ gá⁴sɨɨ́h⁴ xaá¹ ja̱³:
\p ―Niáh³, hi³nɨy³² nɨ³ ja̱a̱y³ nɨ³.
\p 
\v 27 Ba² liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ xɨh³chie̱y³² ja̱³:
\p ―Hi³nɨy³² nɨ³ niáh³ chiú̱h²u³.
\p Xé̱yh² ba² mɨ²ja̱³ gá⁴tee³ xaá¹ Jesús ja̱³ duh³ gá⁴dxi̱i̱³² diáh⁴ xɨ¹ñúh⁴ chiáh² xɨh³chie̱y³² ja̱³.
\s1 La³ dsa³féh³ hi³ jú̱y⁴ Jesús ja̱³
\r (Mt. 27:45-56; Mr. 15:33-41; Lc. 23:44-49)
\p 
\v 28 Mɨ³ñi³² ba² Jesús ja̱³ hi³ ma³jooy³ jɨɨ⁴ lɨ́⁴, hi³ja̱³ liáh³la³ gá⁴féh³ duh³ hí⁴lí³ liáh³xɨ³ na³xɨɨ² ñi² xi³ chiáh² Dios ja̱³:
\p ―Hi²xiáh³ dɨ²uuyh⁴² jmɨɨ³.
\p 
\v 29 Niaá² nɨɨ́⁴ ca̱a̱³ mɨ¹dsuu² hi³ ná⁴ha⁴² vino hi³ ji̱h³. Hi³ja̱³ cá⁴dah²jmeé³ gá⁴yaáh² ca̱a̱³ mɨɨ¹ hi³ va² hi³ liáh³ca̱a̱y³ jaa³, duh³ cá⁴dah²tiá² ca̱a̱³ guaa³ ma³ hi³ xɨ̱ɨ̱y³ hisopo, duh³ cá⁴dah²ya³dxɨ́² haa² Jesús ja̱³.
\v 30 Liáh³ gá⁴ñí² Jesús ja̱³ liáh³xɨ³ lɨ́² vino hi³ ji̱h³ ja̱³, mɨ²ja̱³ liáh³la³ gá⁴féh³:
\p ―Ma³yey³ ma³jooy³ jɨɨ⁴ lɨ́⁴.
\p Mɨ²ja̱³ cá⁴dxá⁴tiáh² mɨ¹dxɨ², ja̱³ba² jú̱y⁴.
\s1 Ja̱y³ soldado gá⁴hɨ́h⁴ tɨɨ́² caayh⁴ Jesús ja̱³
\p 
\v 31 Jmɨɨ́¹ liáh³ laáh² jmɨ́¹feh⁴ hi³ ga³cuh³²ah¹ mɨ¹ja̱á̱² dsɨɨ³jaa³ ja̱³ cá⁴dah²tie̱e̱y³ cruz Jesús ja̱³. Hi³ja̱³ há⁴hé³ dɨ³niaá⁴ diáh⁴ israelitas ja̱³ hi³ hí⁴cueeyh⁴ ta̱a̱y⁴ diáh⁴ dsaah⁴ cruz hí⁴dxaá² jmɨɨ́¹ mah² ja̱³. Chiaah¹ hi²xiáh³ ná⁴ŋɨy¹ jmɨɨ́¹ mah² mɨ²ja̱³, chiaah¹ hi³ jmɨ́¹feh⁴ hi³ ga³cuh³²ah¹ mɨ¹ja̱á̱² dsɨɨ³jaa³ ja̱³. Hi³ja̱³ cá⁴dah²ŋɨɨ́³ jmɨ²heé¹ chiáh² Pilato hi³ gua²tiaáh⁴ ta² hí⁴dah²su̱ú̱h⁴ chiu² diáh⁴ hi³ ta̱a̱y⁴ dsaah⁴ cruz ja̱³, baáy⁴ gua²tiaáh⁴ ta² hí⁴dah²xieéy² diáh⁴.
\v 32 Mɨ²ja̱³ dah²ya²dxí̱⁴ diáh⁴ soldados ja̱³ dah²ya²xu̱u̱h⁴ chiu² liú⁴u³ aáy⁴ diáh⁴ hi³ ta̱a̱y⁴ liáh³ ca³jaa¹ caayh⁴ Jesús ja̱³.
\v 33 Joó⁴ liáh³ cá⁴dxá⁴jé̱yh⁴ diáh⁴ yeey⁴ xi² ta̱a̱y⁴ Jesús ja̱³ mɨ²ja̱³ cá⁴dah²joó² hi³ mɨ³na³jú̱y¹ Jesús ja̱³, hi³ja̱³ há⁴hé³ máh⁴ cá⁴dah²su̱ú̱h⁴ diáh⁴ chiu² Jesús ja̱³.
\p 
\v 34 Joó⁴ ja̱y³ soldado ja̱³ gá⁴hɨ́h⁴ tɨɨ́² caayh⁴ Jesús ja̱³ chie̱é̱yh¹ lanza chiáh², xé̱yh² ba² mɨ²ja̱³ gá⁴tu̱u̱³ jmɨ³ chie̱é̱yh¹ jmɨɨ³.
\v 35 Jmɨ́yh³ hi³ gá⁴joó² nɨ³ dsa³ hi³ ga³jmee⁴ juúh⁴ hi³la³, baáy⁴ liáh³ xiaa³dsaa³² cáh³ti³² ga³liu⁴. Ñi³² ba² ñaá² hi³ ga³liu⁴ xiaa³dsaa³² duh³ja̱³ ba² dsá⁴taá³ah³ niaá⁴ah³.
\v 36 Gá⁴lɨ́⁴ liáh³ja̱³ duh³ hí⁴lí³ liáh³xɨ³ dsa³liú⁴ ñi² xi³ chiáh² Dios, chiaah¹ liáh³la³ na³xɨɨ²: “Gu³xɨ³ ca̱a̱³ na¹mee⁴ chiáh² há⁴hé³ hí⁴fí̱².”
\v 37 Ba² xa³ xiaáh³ xi² na³xɨɨ² liáh³la³: “Hí⁴dah²joóy² ba² ca̱á̱h³ hí̱³ba² hi³ cá⁴dah²jméy² hooy³² nɨ³.”
\s1 Cá⁴dah²haáy² Jesús ja̱³
\r (Mt. 27:57-61; Mr. 15:42-47; Lc. 23:50-56)
\p 
\v 38 Liáh³ ma³ju̱y⁴ Jesús ja̱³, mɨ²ja̱³ José dsa³ fɨɨ³ Arimatea gá⁴ŋɨɨ́³ jú¹hiíh⁴ chiáh² Pilato hi³ hu̱² hí⁴jooy³ hí⁴xiaá² cuerpo chiáh² Jesús ja̱³. Ba² ca³dsa³taáy³ José ja̱³ chiáh² Jesús ja̱³, joó⁴ ca̱a̱³ há⁴ tiaah² dxɨ́³ ba² chiaah¹ foyh⁴ ga³jooy³² diáh⁴ fii² diáh⁴ israelitas ja̱³. Gá⁴cuó³ ba² jú¹hiíh⁴ Pilato ja̱³ hi³ hí⁴xiaá² José ja̱³ cuerpo chiáh² Jesús, hi³ja̱³ ŋaá² dxá⁴xiaá¹ cuerpo chiáh² ja̱³.
\v 39 Ba² gá⁴dxaá² nɨɨ́⁴ Nicodemo hi³ ñií¹ ca̱a̱³ mɨ² xiáh³liaá⁴ ya²liú³ chie̱é̱yh¹ Jesús ja̱³. Chia̱³ ca̱³liáh³ dxiá⁴dxiá³ kilos naa⁴² mɨ³fɨɨ³, caah⁴ mirra baáy⁴ caah⁴ áloes.
\v 40 Hi³ja̱³ gá⁴xiaá² José ja̱³ chie̱é̱yh¹ Nicodemo cuerpo chiáh² Jesús ja̱³, duh³ cá⁴dah²ye̱e̱yh³ mɨh³ hi³ tiaah² naa⁴² mɨ³fɨɨ³ ja̱³, liáh³xɨ³ chia̱³ dxá³ ga³haay⁴ diáh⁴ israelitas. \fig Juan 19:40|src="CN01847B.TIF" size="span" ref="San Juan 19:40"\fig*
\v 41 Caa¹ xi² cá⁴dah²tie̱e̱y³ cruz Jesús ja̱³, xa³ ca̱a̱³ huerto. Jee⁴² huerto ja̱³ xa³ ca̱a̱³ he̱e̱³ hi³mɨɨ³² xi² há⁴hé³ jlɨ́h³ ma³haáy⁴ dsa³.
\v 42 Hi³ja̱³ nɨɨ́⁴ cá⁴dah²ta̱a̱yh³ Jesús ja̱³, chiaah¹ he̱e̱³ hi³ja̱³ na³jniaa³ gɨh¹ yeey⁴ baáy⁴ chiaah¹ ca̱³laá³ liáh³ mɨ³laáh² jmɨ́¹feh⁴ hi³ ga³cuh³²ah¹ mɨ¹ja̱á̱² dsɨɨ³jaa³ hi³ mɨ³hí⁴jnia³ jmɨɨ́¹ mah² ja̱³. Hi³ja̱³ ja̱³ dɨ́h¹ ca̱a̱³tiá³ ca̱a̱³bí³ ba² cá⁴dah²ta̱a̱yh³ nɨɨ́⁴ Jesús ja̱³.
\c 20
\s1 La³ dsa³féh³ hi³ cá⁴lɨ́⁴ji̱i̱h⁴ ca̱á̱h³ Jesús
\r (Mt. 28:1-10; Mr. 16:1-8; Lc. 24:1-12)
\p 
\v 1 Tiá³ xiáh³hee³ jmɨɨ́¹ jmɨ́¹dxiaa³ ja̱³, liáh³ rúh⁴ ñu³ha̱a̱h³ ja̱³, mɨ²ja̱³ ñií¹ María Magdalena xi² na³haay⁴ Jesús ja̱³. Liáh³ gá⁴dxaá² ja̱³ mɨ²ja̱³ gá⁴joó² hi³ há⁴hé³ máh⁴ na³jniaa³ na¹cu̱ú̱¹ hi³ na³jnɨ⁴ haah² he̱e̱³ ja̱³.
\v 2 Mɨ²ja̱³ dxɨ³ ba² dɨ́h¹ ŋáyh² xi² jey¹ Simón Pedro ja̱³ chie̱é̱yh¹ xɨh³chie̱y³² hi³ bií⁴ niaá² Jesús ja̱³ nieéy². Liáh³ gá⁴dxéyh² María ja̱³ mɨ²ja̱³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ diáh⁴:
\p ―Ma³dah²dxɨ³ cuerpo chiáh² Ñúh³a² Jesús nɨ³, baáy⁴ há⁴hé³ nia⁴²a² xɨ³ xiáh³ ma³dah²ya²ca̱³.
\p 
\v 3 Mɨ²ja̱³ ŋaá² Pedro ja̱³ chie̱é̱yh¹ ja̱y³ diáh⁴ xɨh³chie̱y³² Jesús xi² na³jniaa³ he̱e̱³ ja̱³.
\v 4 Liú⁴u³ aáy⁴ diáh⁴ gá⁴dxí̱⁴ tiá³bí³, joó⁴ gá⁴dxaá² gɨh¹ ji̱³nɨɨ́⁴ hi³ na³cu̱yh⁴ chie̱é̱yh¹ ja̱³.
\v 5 Liáh³ gá⁴dxaá² ja̱³ mɨ²ja̱³ gá⁴jmeé³ na³hi³² gá⁴joó² ñuúh⁴ he̱e̱³ ja̱³, hi³ja̱³ gá⁴joó² diáh⁴ sɨ̱ɨ̱yh² mɨh³ hi³ cá⁴dah²ye̱e̱yh³ Jesús ja̱³ na³jniaa³ nɨɨ́⁴, joó⁴ há⁴hé³ gá⁴hí³ ñuúh⁴ he̱e̱³ ja̱³.
\v 6 Dsa³cɨ̱ɨ̱y³ liáh³ja̱³ gá⁴dxaá² Simón Pedro ja̱³, ja̱³ba² gá⁴hí³ ñuúh⁴ he̱e̱³ ja̱³. Hi³ja̱³ gá⁴joó² yeey⁴ cáh³ti³² Pedro ja̱³ diáh⁴ sɨ̱ɨ̱yh² mɨh³ hi³ na³jniaa³ nɨɨ́⁴.
\v 7 Ba² gá⁴joó² hi³ ca̱a̱³ chiáh² bɨh¹ na³jniaa³ mɨh³ hi³ cá⁴dah²liaá³ dxɨ² Jesús ja̱³, há⁴hé³ máh⁴ na³jniaa³ chie̱é̱yh¹ diáh⁴ tú̱⁴dsaáh² mɨh³ ja̱³, baáy⁴ mɨ³na³juh³ dxú⁴ cáh³ti³².
\v 8 Ba² mɨ²ja̱³ gá⁴hí³ ñuúh⁴ he̱e̱³ ja̱³ dxeeyh⁴ xɨh³chie̱y³² hi³ gá⁴dxaá² dsa³jéy⁴ ja̱³. Liáh³ gá⁴joó² liáh³xɨ³ gá⁴lɨ́⁴ ja̱³ mɨ²ja̱³ ba² gá⁴taáy³ dxú⁴ hi³hí̱³ hi³ he̱é̱yh³ ba² cá⁴lɨ́⁴ji̱i̱h⁴ ca̱á̱h³ Jesús ja̱³.
\v 9 Chiaah¹ há⁴hé³ na³fáyh⁴ cá⁴lɨ́⁴dsaay⁴ diáh⁴ liáh³xɨ³ ná⁴lɨ¹ na³xɨɨ² xi³ chiáh² Dios ja̱³, hi³ ga³jmee⁴ hí⁴ji̱i̱h⁴ ca̱á̱h³ Jesús ja̱³.
\v 10 Mɨ²ja̱³ gá⁴dxi̱i̱³² xɨ¹ñúh⁴ chiáh² diáh⁴ hi³ aáy⁴ xɨh³chie̱y³² Jesús ja̱³.
\s1 Cá⁴lɨ́⁴jnieey³² Jesús ja̱³ rúh⁴ñi² María Magdalena
\r (Mr. 16:9-11)
\p 
\v 11 Joó⁴ xiáh³ tɨɨ́² ba² gá⁴cueeyh⁴ María ja̱³, hi²xiáh³ cɨɨh⁴ chiaah¹ hi³ bií⁴ fɨɨh⁴² dsɨ́². Liáh³ cɨɨh⁴ ja̱³ mɨ²ja̱³ gá⁴jmeé³ na³hi³² gá⁴joó² ñuúh⁴ he̱e̱³ ja̱³,
\v 12 mɨ²ja̱³ gá⁴joóy² aáy⁴ ángeles dɨ³chih³ mɨh³ tiaa³, dɨ³nieeyh⁴² xi² cá⁴dah²chieey³ Jesús ja̱³. Ja̱y³ jey¹ ca³jaa¹ xi² gá⁴jniaa³ mɨ¹dxɨ² baáy⁴ dxeeyh⁴ ja̱³ jey¹ xiáh³ xi² gá⁴jniaa³ diáh⁴ tɨɨ².
\v 13 Mɨ²ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ ángeles ja̱³ cá⁴dah²sɨɨ́h⁴ María ja̱³:
\p ―Mɨ́³, ¿he²chiaah¹ hi³ ga³jla⁴²u³ nɨ³?
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ María ja̱³:
\p ―Chiaah¹ ma³dah²jéy⁴ Ñuyh⁴ Jesús nɨ³, baáy⁴ há⁴hé³ maay⁴ xɨ³ xiah² ma³dah²ya²jay⁴.
\p 
\v 14 Ca̱³liáh³ féh³ ba² liáh³ja̱³, ja̱³ba² gá⁴xaáh² ñi². Liáh³ gá⁴xaáh² ñi² ja̱³ mɨ²ja̱³ gá⁴joóy² Jesús ja̱³ hiíy⁴ nɨɨ́⁴. Joó⁴ há⁴hé³ ñi³² hi³hí̱³ ba² Jesús ja̱³ ja̱³.
\v 15 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Mɨ́³, ¿he²chiaah¹ hi³ ga³jla⁴²u³ nɨ³? ¿Hi̱² nɨy³² ga³naah⁴u³ nɨ³?
\p Ta³hɨ³ María ja̱³ hi³ dsa³ hi³ ga³heeh⁴ hí¹ huerto ja̱³ ba² ja̱³, hi³ja̱³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴:
\p ―Dia², xɨɨh² jniá³ xiah² nɨ³ ma³ya²já⁴u³ Jesús nɨ³ xɨ³ niu³ nɨ³ ma³jé⁴u³, duh³ jniá³ ya³tieé²á⁴.
\p 
\v 16 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―¡María!
\p Mɨ²ja̱³ gá⁴ji̱í̱² ca̱á̱h³ ñi² María ja̱³ gá⁴joóy², duh³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ Jesús ja̱³, fáh² hebreo:
\p ―¡Raboni! ―hi³ niaá⁴ hí⁴féh³: Dsa³he⁴.
\p 
\v 17 Mɨ²ja̱³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³ gá⁴sɨɨ́h⁴ mɨ́³ ja̱³:
\p ―Tiúy⁴ jniá³ chiaah¹ há⁴hé³ ma³tɨ́³ ma³vɨɨh⁴²á⁴ yuuh¹ güii³ xi² jey¹ Ñuyh⁴. Joó⁴ má⁴dxi² gua³xɨɨh² diáh⁴ du³ñuúh²á⁴ nɨ³ hi³ ya³vɨɨh⁴²á⁴ xi² jey¹ Ñuyh⁴, hí̱³ba² Ñúh³ah³ niaá⁴ah³ nɨ³, Dios chia̱á̱²á⁴ baáy⁴ Dios chia̱á̱²ah³ niaá⁴ah³.
\p 
\v 18 Mɨ²ja̱³ ŋáyh² María Magdalena ja̱³ cá⁴dxá⁴xɨɨh⁴² jniaah¹ hi³ ma³joóy² Ñúh³a² Jesús ja̱³, baáy⁴ gá⁴jmeé³ juúh⁴ liáh³xɨ³ gá⁴féh³ Jesús ja̱³.
\s1 Cá⁴lɨ́⁴jnieey³² Jesús ja̱³ xi² nieeyh⁴² diáh⁴ xɨh³chie̱y³²
\r (Mt. 28:16-20; Mr. 16:14-18; Lc. 24:36-49)
\p 
\v 19 Xiáh³ liaá⁴ ja̱³ba² jmɨɨ́¹ jmɨ́¹dxiaa³ ja̱³, mɨ²ja̱³ na³ŋɨɨh⁴²ah¹ ca̱á̱h³ hí¹, baáy⁴ niaah⁴²ah¹ na³jnɨ⁴ ñú², chiaah¹ foh⁴²ah¹ diáh⁴ hi³ na³ta̱a̱y⁴ ñi² chiaa⁴²ah¹ ja̱³. Ja̱³ba² voo⁴ mɨ²ja̱³ cá⁴lɨ́⁴jnieey³² Jesús ja̱³, ca̱a̱³ ba² dɨ́h¹ gá⁴joo⁴²ah¹ mɨ³hiíy⁴ jee⁴² chiaa⁴²ah¹ ja̱³. Mɨ²ja̱³ gá⁴hí̱¹ gá⁴jmeéh⁴ jniaah¹, liáh³la³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Bi³jee⁴²ah³ há²ah³ ba².
\p 
\v 20 Liáh³ gá⁴féh³ liáh³ja̱³, mɨ²ja̱³ gá⁴heé⁴ jniaah¹ liáh³xɨ³ ná⁴lɨ¹ diáh⁴ guaa³ ja̱³, baáy⁴ gá⁴heé⁴ jniaah¹ tɨɨ́² caayh⁴. Mɨ²ja̱³ hi²xiáh³ cá⁴lɨ́⁴jé⁴ dsɨ³²ah¹ liáh³ gá⁴joo⁴²ah¹ ca̱á̱h³ Ñúh³a² ja̱³.
\v 21 Mɨ²ja̱³ liáh³la³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³:
\p ―Há⁴ máh⁴ hi³ta³ hi³hɨ³ah³ ñuú³. Ja̱³ba² liáh³xɨ³ gá⁴xɨ́y⁴ jniá³ Ñuyh⁴ nɨ³ ja̱³ba² liáh³nɨ³ hi²sɨ́⁴á⁴ niaá⁴ah³ jniá³.
\p 
\v 22 Mɨ²ja̱³ gá⁴xií² jniaah¹, baáy⁴ liáh³la³ gá⁴féh³:
\p ―Gua²tɨ̱́⁴ah³ Espíritu Santo.
\v 23 Liu³u²xɨ³ hi²jmee³ah³ gaáy³ há²ah³ dsaa² chiáh² diáh⁴ dsa³, mɨ²ja̱³ hí⁴bé⁴ dsaa² chiáh² diáh⁴, joó⁴ chiáh² diáh⁴ hi³ há⁴hé³ hi²jmee³ah³ gaáy³ há²ah³ mɨ²ja̱³ há⁴hé³ hí⁴bé⁴ dsaa² chiáh² diáh⁴.
\s1 Gá⁴joó² Tomás ja̱³ gá⁴joóy² Jesús hi³ mɨ³na³ji̱í̱yh⁴
\p 
\v 24 Joó⁴ ja̱y³ xɨh³chie̱y³² hi³ xɨ̱ɨ̱y³ Tomás, hi³ ga³sɨɨ́h⁴ah¹ xɨh³su̱u̱⁴² ja̱³, há⁴hé³ jey¹ chie̱é̱yh¹ jniaah¹ liáh³ cá⁴lɨ́⁴jnieey³² Jesús ja̱³.
\v 25 Hi³ja̱³ liáh³la³ cá⁴dah²féh³ diáh⁴ tú̱⁴dsaayh⁴ xɨh³chie̱y³² ja̱³ cá⁴dah²sɨɨ́h⁴ Tomás:
\p ―Ma³joo⁴²ah¹ Ñúh³a² Jesús nɨ³.
\p Joó⁴ liáh³la³ ba² gá⁴féh³ Tomás ja̱³:
\p ―Liu³u²xɨ³ hi²jooy¹ guaa³ xi² gá⁴lɨ́⁴ hoo⁴ nɨ³, baáy⁴ xɨ³ hi²jɨɨ́⁴á⁴ xɨh¹guaay⁴ guaa³ xi² gá⁴tiá⁴ diáh⁴ xiíh² nɨ³, baáy⁴ hi²jɨɨ́⁴á⁴ guaay⁴ tɨɨ́² caayh⁴ nɨ³, mɨ²ja̱³ ba² hí⁴dsá⁴taá³á⁴.
\p 
\v 26 Liáh³ ma³ŋɨ́³ ca̱³dxiaa³ liáh³ja̱³, mɨ²ja̱³ na³ŋɨɨh⁴²ah¹ ca̱á̱h³ xɨ¹ñúh⁴ ja̱³, mɨ²ja̱³ gɨh¹ chie̱é̱yh¹ jniaah¹ Tomás ja̱³, ba² na³jnɨ⁴ ñú². Joó⁴ mɨ²ja̱³ gá⁴hí³ ca̱á̱h³ Jesús ja̱³, ca̱a̱³ ba² dɨ́h¹ gá⁴joo⁴²ah¹ mɨ³hiíy⁴ jee⁴² chiaa⁴²ah¹. Mɨ²ja̱³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Há⁴ máh⁴ hi³ta³ hi³hɨ³ah³ ñuú³.
\p 
\v 27 Mɨ²ja̱³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ Tomás ja̱³:
\p ―Jniaa³ la³ xɨh¹guaay³² nɨ³, baáy⁴ joo⁴² diáh⁴ guaay⁴ la³, jɨɨ́⁴ guaay³² nɨ³ tɨɨ́² caah⁴²á⁴ la³. Há⁴ máh⁴ hi³jmeey³ ba³ háy², gua³taáy³ ba².
\p 
\v 28 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Tomás ja̱³, gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―¡Jmɨ́yh³ Ñuyh⁴ chia̱á̱²á⁴ niu³, baáy⁴ Dios chia̱á̱²á⁴!
\p 
\v 29 Mɨ²ja̱³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Tomás, hi³ fáh⁴ hi³ ma³joo⁴²u³ jniá³ nɨ³ ba² nɨ³ ma³taá³u³. Hi²xiáh³ dxú⁴ chiáh² diáh⁴ hi³ ma³taáy³ gu³xɨ³ ba² jmiih⁴ há⁴hé³ ma³dah²joóy² jniá³.
\s1 La³ dsa³liú⁴ he²chiaah¹ hi³ xa³ xi³ la³
\p 
\v 30 Hi²xiáh³ ñuú³ gɨh¹ fáh⁴lí³ gá⁴jmeé³ Jesús ja̱³ xi² gá⁴joo⁴²ah¹ hi³ há⁴hé³ na³xɨɨ² xi³ la³.
\v 31 Joó⁴ nɨɨh¹ la³ nɨɨh¹ ma³lɨ³xɨɨ², duh³ dsá⁴taá³ah³ niaá⁴ah³ hi³ he̱é̱yh³ ba² Jesús nɨ³ na³lɨ́y⁴ Cristo, Ja̱á̱² Dios, baáy⁴ duh³ liu³u²xɨ³ dsá⁴taá³ah³ mɨ²ja̱³ hí⁴jooy³ hi²ñí³ah³ chia̱á̱h¹ah³ Dios dxɨ́⁴lieey³² Ja̱á̱² nɨ³.
\c 21
\s1 Cá⁴lɨ́⁴jnieey³² Jesús ja̱³ rúh⁴ñi² dxieéy⁴ diáh⁴ xɨh³chie̱y³²
\p 
\v 1 Dsa³cɨ̱ɨ̱y³ liáh³ja̱³ cá⁴lɨ́⁴jnieey³² ca̱á̱h³ Jesús ja̱³ rúh⁴ñi²ah¹ yaa¹ dxaá² gaáy³ hi³ xɨ̱ɨ̱y³ Tiberias. Liáh³la³ gá⁴lɨ́⁴.
\v 2 Na³cu̱yh⁴ Pedro ja̱³ chie̱é̱yh¹ Tomás hi³ ga³sɨɨ́h⁴ah¹ xɨh³su̱u̱⁴² chie̱é̱yh¹ Natanael dsa³ Caná, fɨɨ³ hi³ na³hii⁴ Galilea. Ba² caah³²ah¹ jniaah¹ diáh⁴ ja̱á̱² Zebedeo ja̱³, baáy⁴ chia̱a̱h²ah¹ gɨh¹ aáy⁴ diáh⁴ xɨh³chie̱y³² Jesús ja̱³.
\v 3 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Pedro ja̱³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Ñii⁴ ya³güeéh²á⁴ hi³tieéyh¹ jmɨɨ³.
\p Mɨ²ja̱³ liáh³la³ gá⁴xɨɨh²ah¹:
\p ―Ba² dsa³dxia⁴²ah¹ jniaah¹ chia̱a̱h²ah¹ niu³.
\p Hi³ja̱³ gá⁴dxia⁴²ah¹ he̱é̱yh³ jmɨɨ³ ja̱³ tiaah²ah¹ ca̱a̱³ maá², joó⁴ há⁴hé³ xe̱y³ cáh³ti³² gá⁴jaá³ah¹ voo⁴ mɨ²ja̱³.
\v 4 Liáh³ mɨ³dse³jnia³ ja̱³, mɨ²ja̱³ cá⁴lɨ́⁴jnieey³² Jesús ja̱³ yaa¹ dxaá² gaáy³ ja̱³, joó⁴ há⁴hé³ nia⁴²ah¹ hi³ Jesús ja̱³ ja̱³.
\v 5 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Mɨ¹liuh², ¿xɨ³ xe̱y³ ma³jaá³ah³ hi²chiuh²a²?
\p Mɨ²ja̱³ liáh³la³ gá⁴xɨɨh²ah¹:
\p ―Há⁴hé³ xe̱y³ ma³jaá³ah¹ cáh³ti³².
\p 
\v 6 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Tia̱a̱h⁴ah³ ca̱á̱h³ má² chia̱á̱²ah³ nɨ³ he̱é̱yh³ jmɨɨ³ caa³jaa¹ xi² nu¹ah³ liáh³xɨ³ na³jniaa³ maá² nɨ³ duh³ dsá⁴taáyh¹ hi³tieéyh¹ jmɨɨ³.
\p Hi³ja̱³ gá⁴tia̱a̱⁴²ah¹ ca̱á̱h³ má² chiaa⁴²ah¹ ja̱³. Mɨ²ja̱³ há⁴hé³ máh⁴ hí⁴tiaá⁴ah¹ hi²dxɨ²ah¹ má² ja̱³ chiaah¹ hi²xiáh³ fɨɨ́y⁴ hi³tieéyh¹ jmɨɨ³ ja̱³ gá⁴taáyh¹.
\v 7 Mɨ²ja̱³ liáh³la³ gá⁴féh³ xɨh³chie̱y³² hi³ bií⁴ niaá² Jesús ja̱³ nieéy² gá⁴sɨɨ́h⁴ Pedro ja̱³:
\p ―¡Hí̱³ba² Ñúh³a² nɨ³ nɨ³!
\p Liáh³ gá⁴nuú³ ba² Simón Pedro ja̱³ hi³ Jesús ja̱³ ja̱³, mɨ²ja̱³ gá⁴cɨ́h⁴ cua̱a̱³ chiaah¹ na³dxɨy⁴² cua̱a̱³, duh³ gá⁴ta̱a̱yh³ ñaá² he̱é̱yh³ jmɨɨ³ duh³ cá⁴dxá⁴bí⁴ji̱í̱³ Jesús ja̱³.
\v 8 Diáh⁴ gɨh¹ tú̱⁴dsaah⁴ah¹ xɨh³chie̱y³² Jesús ja̱³ yáh¹, tiaah²ah¹ liáh³ja̱³ maá² ja̱³ gá⁴dxii³²ah¹ ji̱h²nɨɨh¹ jmɨɨ³ ja̱³, xee³²ah¹ liáh³ja̱³ má² hi³ na³ca̱yh⁴ hi³tieéyh¹ jmɨɨ³ ja̱³. Chiaah¹ ca̱³liáh³ ca̱a̱³ ñá⁴laá³ metros ba² vɨ̱ɨ̱́³ tiaah²ah¹ liáh³xɨ³ ji̱h²nɨɨh¹ jmɨɨ³ ja̱³.
\v 9 Liáh³ cá⁴dxá⁴dxii³²ah¹ vó⁴ cuéh⁴ ja̱³, mɨ²ja̱³ gá⁴joo⁴²ah¹ hi³ mɨ³niaá² xi³ chiáh², baáy⁴ mɨ³dse³chiu̱ú̱y⁴ ja̱y³ hi³tieéyh¹ jmɨɨ³, baáy⁴ na³jniaa³ hó² ya³dsɨ².
\v 10 Hi³ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Ya³jaa⁴²ah³ la³ ja̱y³aáy⁴ diáh⁴ hi³tieéyh¹ jmɨɨ³ hi³ ma³jaá³ah³ nɨ³.
\p 
\v 11 Mɨ²ja̱³ gá⁴saáh² Simón Pedro ja̱³ he̱é̱yh³ maá² ja̱³ duh³ gá⁴laá⁴ mɨ³seéh⁴ má² hi³ na³ca̱yh⁴ diáh⁴ hi³tieéyh¹ jmɨɨ³ ja̱³ baáy⁴ hi²xiáh³ dɨ³cáyh¹. Xe̱y³ ca̱³liáh³ ca̱a̱³ ñá⁴laáy³ dsɨ³² tú̱⁴ ná⁴dxiéy³ dsɨ³² aay³ hi³tieéyh¹ jmɨɨ³ ja̱³, baáy⁴ há⁴hé³ gá⁴tuy³ má² ja̱³ gu³xɨ³ ba² fáh⁴yeey¹ dɨ́h¹ fɨɨ́y⁴ ja̱³.
\v 12 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ jniaah¹:
\p ―Ya³chiéh³ah³ máh⁴hee³.
\p Joó⁴ gu³xɨ³ hí̱³ jniaah¹ há⁴hé³ lɨ́⁴tiá³ dsɨ³²ah¹ gá⁴ŋɨɨh²ah¹ juúh⁴ hi³ hi̱² dsa³ ja̱³, chiaah¹ ta³hɨ³²ah¹ chiaa⁴²ah¹ hi³ Jesús ja̱³ ja̱³.
\v 13 Mɨ²ja̱³ cá⁴dxá⁴jé̱yh⁴ Jesús ja̱³ yeey⁴ duh³ gá⁴cá̱⁴ hó² ya³dsɨ² ja̱³ duh³ gá⁴cuoó⁴ jniaah¹. Ba² gá⁴jmeé³ chiáh² liáh³ja̱³ chie̱é̱yh¹ diáh⁴ hi³tieéyh¹ jmɨɨ³ ja̱³, gá⁴cuóy² jniaah¹ gá⁴chiuh²ah¹.
\p 
\v 14 Liáh³ja̱³ gá⁴lɨ́⁴, hi³dxá³ nɨɨh⁴ tiaah² ja̱³ hi³ cá⁴lɨ́⁴jnieey³² Jesús ja̱³ rúh⁴ñi²ah¹ jniaah¹ diáh⁴ xɨh³chie̱y³² liáh³ ma³ŋɨ́³ ma³lɨ³ji̱i̱h⁴ ca̱á̱h³.
\s1 Gá⁴liú³ Jesús ja̱³ chie̱é̱yh¹ Simón Pedro
\p 
\v 15 Dsa³cɨ̱ɨ̱y³ liáh³ ma³jooy³ ma³chia⁴²ah¹ máh⁴hee³ ja̱³, mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ Simón Pedro ja̱³:
\p ―Simón, ja̱á̱² Jonás, ¿xɨ² naá⁴u³ gɨh¹ jniá³ liáh³xɨ³ diáh⁴ tú̱⁴dsaayh⁴ la³?
\p Mɨ²ja̱³ gá⁴hí̱¹ Pedro ja̱³:
\p ―Ja̱a̱¹, maáy³ ba² hi³ naá⁴á⁴ niu³ Ñuyh⁴.
\p Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Hi³ja̱³ hi³haáh⁴u³ hí¹ diáh⁴ mɨ¹ja̱á̱² dsɨɨ³jaa³ chia̱á̱²á⁴ nɨ³.
\p 
\v 16 Mɨ²ja̱³ gá⁴ŋɨɨ́h⁴ ca̱á̱h³ juúh⁴ hi³dxá³ tú̱h⁴ tiaah², liáh³la³ gá⁴sɨɨ́h⁴:
\p ―Simón ja̱á̱² Jonás, ¿xɨ² naá⁴u³ jniá³?
\p Hi³ja̱³ liáh³la³ gá⁴féh³ ca̱á̱h³ Pedro ja̱³:
\p ―Ja̱a̱¹, maáy³ ba² hi³ bií⁴ naá⁴á⁴ niu³ Ñuyh⁴.
\p Hi³ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴ ca̱á̱h³:
\p ―Hi³ja̱³ hi³haáh⁴u³ hí¹ diáh⁴ dsɨɨ³jaa³ chia̱á̱²á⁴ nɨ³ xa³ja̱³.
\p 
\v 17 Mɨ²ja̱³ gá⁴ŋɨɨ́h⁴ ca̱á̱h³ juúh⁴ hi³dxá³ nɨɨh⁴ tiaah², liáh³la³ gá⁴sɨɨ́h⁴ ca̱á̱h³:
\p ―Simón, ja̱á̱² Jonás, ¿xɨ² naá⁴u³ jniá³?
\p Mɨ²ja̱³ hi²xiáh³ cá⁴lɨ́⁴fɨɨh⁴² dsɨ́² Pedro ja̱³, chiaah¹ hi³ gá⁴ŋɨɨ́³ juúh⁴ Jesús ja̱³ hi³dxá³ nɨɨh⁴ tiaah². Hi³ja̱³ liáh³la³ gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―Ñuyh⁴, maáy³ ba² jɨɨ⁴ lɨ́⁴. Maáy³ ba² hi³ naá⁴á⁴ ba² niu³.
\p Hi³ja̱³ liáh³la³ gá⁴féh³ ca̱á̱h³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Hi³ja̱³ hi³haáh⁴u³ hí¹ diáh⁴ dsɨɨ³jaa³ chia̱á̱²á⁴ nɨ³ xa³ja̱³.
\v 18 Liáh³ca̱á̱h³ rúh⁴ míh⁴u³ gɨh¹ mɨ²ja̱³ ga³cɨ́yh³ mɨh³ chiú̱h²u³ jmiih⁴² ga³lɨ́³ háy², baáy⁴ ga³tɨ̱¹u³ xi² ga³lɨ́³ háy². Joó⁴ liu³u²xɨ³ mɨ² ma³lɨ³dsaa⁴u³ mɨ²ja̱³ hi²ñiih⁴²u³ diáh⁴ guaay³² nɨ³ duh³ dxeeyh⁴ bɨh¹ ba² hí⁴bí⁴chíh³ niu³ mɨh³ chiú̱h²u³, baáy⁴ dsá⁴jay⁴ diáh⁴ niu³ xi² há⁴hé³ dɨ²guaáy³.
\p 
\v 19 Gá⁴féh³ liáh³ja̱³ Jesús ja̱³, joó⁴ liáh³xɨ³ ná⁴lɨ¹ hí⁴lí³ hí⁴jú̱y³ Pedro ja̱³ ba² ja̱³ ga³he⁴, duh³ hí⁴jmeé⁴ gaáy³ chiáh² Dios. Dsa³cɨ̱ɨ̱y³ gɨh¹ liáh³ja̱³ gá⁴féh³ ca̱á̱h³ gá⁴sɨɨ́h⁴ Pedro ja̱³:
\p ―¡Ña³, má⁴dxia⁴²a²!
\s1 La³ dsa³liú⁴ chiáh² xɨh³chie̱y³² hi³ nieéy²
\p 
\v 20 Liáh³ gá⁴ji̱í̱² ñi² Pedro ja̱³, mɨ²ja̱³ gá⁴joó² hi³ dsa³hɨɨ́y⁴ xɨh³chie̱y³² hi³ bií⁴ nieéy² Jesús ja̱³ xiáh³ rúh⁴cah² diáh⁴, hí̱³ba² hi³ gá⁴guá³ yeey⁴ caayh⁴ Jesús ja̱³ liáh³ gá⁴hɨɨ́³ gɨh¹ ñi² gá⁴chia⁴²ah¹ máh⁴liaá⁴ ja̱³. Baáy⁴ gá⁴ŋɨɨ́h⁴ juúh⁴ Jesús ja̱³, hi³ hi̱² na²nɨy¹ ja̱³ hí⁴nɨɨ́y⁴ ja̱³.
\v 21 Liáh³ gá⁴joó² Pedro ja̱³ gá⁴joóy² xɨh³chie̱y³² ja̱³, mɨ²ja̱³ liáh³la³ gá⁴féh³ gá⁴sɨɨ́h⁴ Jesús ja̱³:
\p ―Ñuyh⁴, ¿he² gɨh³ hí⁴chi̱í̱yh² hi³ley³²?
\p 
\v 22 Mɨ²ja̱³ liáh³la³ gá⁴féh³ Jesús ja̱³ gá⁴sɨɨ́h⁴:
\p ―Há⁴hé³ cua̱a̱y¹ná² chiú̱h²u³ niu³. Chiaah¹ hí⁴jooy³ ba² hí⁴güe³ voó³ jmɨɨyh⁴²güii³ hi³nɨy³² hí⁴tɨ́⁴ lɨ́⁴ hiíh⁴ hí⁴güé³á⁴ ca̱á̱h³, xɨ³ nɨ³ naáy⁴ liáh³ja̱³. Ña³, má⁴dxia⁴²a² ruh³ liáh³xɨ³ ga³fooh³²á⁴ niu³ nɨ³.
\p 
\v 23 Mɨ²ja̱³ gá⁴sa³ juúh⁴ jee⁴² chiáh² diáh⁴ du³ñuúh²a² ja̱³ hi³ há⁴hé³ máh⁴ hí⁴jú̱y³ xɨh³chie̱y³² hi³ bií⁴ nieéy² ja̱³. Joó⁴ há⁴hé³ gá⁴féh³ Jesús ja̱³ hi³ há⁴hé³ máh⁴ hí⁴jú̱y³. Liáh³la³ ba² ja̱³ gá⁴féh³: “Hí⁴jooy³ ba² jey¹ liáh³nɨ³ jmɨɨyh⁴²güii³ hi³nɨy³² hí⁴tɨ́⁴ lɨ́⁴ hiíh⁴ hí⁴güé³á⁴ ca̱á̱h³, xɨ³ nɨ³ naáy⁴ liáh³ja̱³, joó⁴ há⁴hé³ cua̱a̱y¹ná² chiú̱h²u³ niu³.”
\p 
\v 24 Hí̱³ba² xɨh³chie̱y³² hi³ bií⁴ nieéy² Jesús ja̱³, hi³nɨy³² nɨ³ ga³jmee⁴ juúh⁴ jɨɨ⁴ hi³la³, baáy⁴ hí̱³ba² ñaá² nɨ³ gá⁴xɨɨ́³ xi³ la³. Baáy⁴ nia⁴²a² ba² hi³ liáh³ xiaa³dsaa³² ba² nɨ³ ga³liu⁴.
\p 
\v 25 Hi²xiáh³ ñuú³ gɨh¹ hi³ gá⁴jmeé³ Jesús ja̱³, joó⁴ liu³u²xɨ³ hi³ hí⁴xɨɨ² liáh³ca̱a̱³ liáh³ca̱a̱³ fáh⁴liu⁴ chiáh², chiáh²ha̱á̱¹ hí⁴chie̱yh⁴ na³ca̱á̱y⁴ jee⁴² jmɨɨyh⁴²güii³ diáh⁴ xi³ nɨ³ hu̱²ca̱a̱³² ba² liáh³ja̱³. Amén.
