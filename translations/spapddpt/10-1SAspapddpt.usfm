\c 1
\s1 Elcana y su familia en el Santuario de Silo
\p 
\v 1 \w Hubo|strong="H1961"\w* un \w hombre|strong="H1121"\w* \w de|strong="H4480"\w* Ramataim \w de|strong="H4480"\w* Sofim, \w de|strong="H4480"\w* la región montañosa \w de|strong="H4480"\w* Efraín, \w que|strong="H4480"\w* \w se|strong="H1961"\w* \w llamaba|strong="H8034"\w* Elcana, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Jeroham|strong="H3395"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Eliú, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Toju, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Suf, efrainita.
\v 2 \w Tenía|strong="H1961"\w* \w dos|strong="H8147"\w* esposas: una \w se|strong="H1961"\w* \w llamaba|strong="H8034"\w* Ana y la \w otra|strong="H8145"\w* Penina. Penina \w tenía|strong="H1961"\w* \w hijos|strong="H3206"\w*, pero Ana \w no|strong="H1961"\w* \w los|strong="H1961"\w* \w tenía|strong="H1961"\w*.
\p 
\v 3 \w Cada|strong="H3117"\w* \w año|strong="H8147"\w* Elcana \w subía|strong="H5927"\w* desde \w su|strong="H1931"\w* \w ciudad|strong="H5892"\w* para adorar y ofrecer \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H1121"\w* las huestes en \w Silo|strong="H7887"\w*, \w donde|strong="H8033"\w* \w los|strong="H1121"\w* \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Elí|strong="H5941"\w*, Ofni y Finees, eran \w sacerdotes|strong="H3548"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 4 Elcana \w daba|strong="H5414"\w* \w porciones|strong="H4490"\w* \w a|strong="H3068"\w* su esposa Penina y \w a|strong="H3068"\w* \w cada|strong="H3605"\w* uno \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w sacrificaba|strong="H2076"\w*,
\v 5 \w pero|strong="H3588"\w* \w daba|strong="H5414"\w* una \w porción|strong="H4490"\w* doble \w a|strong="H3068"\w* Ana \w porque|strong="H3588"\w* \w la|strong="H3588"\w* amaba, \w aunque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w había|strong="H3588"\w* cerrado \w su|strong="H3588"\w* \w matriz|strong="H7358"\w*.
\p 
\v 6 \w Su|strong="H3588"\w* rival, \add Penina\add*, \w la|strong="H1571"\w* irritaba \w y|strong="H1571"\w* maltrataba \w de|strong="H3588"\w* continuo \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w le|strong="H1157"\w* \w había|strong="H3588"\w* cerrado \w la|strong="H1571"\w* \w matriz|strong="H7358"\w*.
\v 7 \w Cada|strong="H8141"\w* \w año|strong="H8141"\w* cuando \w subían|strong="H5927"\w* \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* de \nd \w Yavé|strong="H3068"\w*\nd* la mortificaba.
\p Ana \w lloraba|strong="H1058"\w* de continuo y \w no|strong="H3808"\w* comía.
\p 
\v 8 Su esposo Elcana le decía: Ana, ¿\w por|strong="H4100"\w* \w qué|strong="H4100"\w* \w lloras|strong="H1058"\w* y \w no|strong="H3808"\w* comes? ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* estás triste? ¿\w No|strong="H3808"\w* soy yo para ti \w mejor|strong="H2896"\w* \w que|strong="H4100"\w* \w diez|strong="H6235"\w* \w hijos|strong="H1121"\w*?
\s1 Petición y voto de Ana
\p 
\v 9 Entonces Ana, \w después|strong="H5921"\w* \w de|strong="H5921"\w* comer \w y|strong="H5921"\w* \w beber|strong="H8354"\w* \w en|strong="H5921"\w* \w Silo|strong="H7887"\w*, \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* presentó ante \nd \w Yavé|strong="H3068"\w*\nd*.
\p \w El|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w Elí|strong="H5941"\w* \w estaba|strong="H3427"\w* \w sentado|strong="H3427"\w* \w en|strong="H5921"\w* su silla, \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* jamba \w de|strong="H5921"\w* \w la|strong="H5921"\w* puerta \w del|strong="H5921"\w* Santuario \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 10 \w Ella|strong="H1931"\w* \w lloraba|strong="H1058"\w* \w mucho|strong="H1058"\w* \w con|strong="H5921"\w* \w amargura|strong="H4751"\w* \w de|strong="H5921"\w* \w alma|strong="H5315"\w*, \w oró|strong="H6419"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*
\v 11 \w e|strong="H3068"\w* \w hizo|strong="H5088"\w* un \w voto|strong="H5087"\w*: \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes, \w si|strong="H3808"\w* \w te|strong="H5921"\w* dignas \w mirar|strong="H7200"\w* \w la|strong="H5921"\w* \w aflicción|strong="H6040"\w* \w de|strong="H5921"\w* tu esclava, \w te|strong="H5921"\w* acuerdas \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* olvidas \w de|strong="H5921"\w* tu esclava, \w sino|strong="H3808"\w* \w das|strong="H5414"\w* \w a|strong="H3068"\w* tu esclava un hijo varón, yo \w lo|strong="H3808"\w* dedicaré \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* su \w vida|strong="H2416"\w*. \w No|strong="H3808"\w* pasará \w navaja|strong="H4177"\w* \w sobre|strong="H5921"\w* su \w cabeza|strong="H7218"\w*.
\p 
\v 12 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w mientras|strong="H3588"\w* ella oraba largamente \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w Elí|strong="H5941"\w* observaba \w la|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H3588"\w* ella,
\v 13 pero Ana \w hablaba|strong="H1696"\w* \w en|strong="H5921"\w* \w su|strong="H1931"\w* \w corazón|strong="H3820"\w*. \w Solo|strong="H1931"\w* \w se|strong="H1931"\w* movían \w sus|strong="H1931"\w* \w labios|strong="H8193"\w*, pero \w su|strong="H1931"\w* \w voz|strong="H6963"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* \w escuchaba|strong="H8085"\w*, \w por|strong="H5921"\w* \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w Elí|strong="H5941"\w* pensó \w que|strong="H1931"\w* \w ella|strong="H1931"\w* estaba ebria.
\p 
\v 14 \w Entonces|strong="H5493"\w* \w Elí|strong="H5941"\w* \w le|strong="H5921"\w* dijo: ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* estarás \w ebria|strong="H7937"\w*? Aleja \w de|strong="H5921"\w* \w ti|strong="H5921"\w* tu \w vino|strong="H3196"\w*.
\p 
\v 15 Pero Ana \w respondió|strong="H6030"\w*: \w No|strong="H3808"\w*, \tl ʼadón\tl* mío. \w Yo|strong="H5315"\w* soy una mujer \w de|strong="H6440"\w* \w espíritu|strong="H7307"\w* afligido. \w No|strong="H3808"\w* \w bebí|strong="H8354"\w* \w vino|strong="H3196"\w* \w ni|strong="H3808"\w* licor fuerte, \w sino|strong="H3808"\w* \w derramo|strong="H8210"\w* \w mi|strong="H6030"\w* \w alma|strong="H5315"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 16 \w No|strong="H3588"\w* juzgues \w a|strong="H3068"\w* tu esclava \w como|strong="H3588"\w* una mujer despreciable, \w porque|strong="H3588"\w* \w hasta|strong="H5704"\w* \w ahora|strong="H2008"\w* \w hablé|strong="H1696"\w* \w de|strong="H3588"\w* \w mis|strong="H5414"\w* congojas \w y|strong="H3588"\w* aflicción.
\p 
\v 17 Entonces \w Elí|strong="H5941"\w* \w respondió|strong="H6030"\w*: \w Vé|strong="H3212"\w* \w en|strong="H5973"\w* \w paz|strong="H7965"\w*, y \w el|strong="H5973"\w* \nd ʼElohim\nd* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w* \w te|strong="H5973"\w* otorgue la \w petición|strong="H7596"\w* que hiciste.
\p 
\v 18 Ella dijo: \w Que|strong="H3808"\w* tu esclava \w halle|strong="H4672"\w* \w gracia|strong="H2580"\w* \w ante|strong="H6440"\w* ti. \w Y|strong="H3068"\w* la mujer \w siguió|strong="H3212"\w* su \w camino|strong="H1870"\w*, comió y ya \w no|strong="H3808"\w* \w estuvo|strong="H1961"\w* triste.
\s1 Nacimiento de Samuel
\p 
\v 19 Después \w de|strong="H6440"\w* levantarse \w de|strong="H6440"\w* \w mañana|strong="H1242"\w*, \w se|strong="H3045"\w* postraron \w ante|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*, regresaron y llegaron \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* en \w Ramá|strong="H7414"\w*. Elcana \w se|strong="H3045"\w* unió \w a|strong="H3068"\w* su esposa Ana, y \nd \w Yavé|strong="H3068"\w*\nd* \w se|strong="H3045"\w* acordó \w de|strong="H6440"\w* ella.
\v 20 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w* Ana \w concibió|strong="H2029"\w*, \w y|strong="H3588"\w* al cumplirse \w el|strong="H3588"\w* \w tiempo|strong="H3117"\w*, dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*. Lo \w llamó|strong="H7121"\w* \w Samuel|strong="H8050"\w* \w y|strong="H3588"\w* dijo: \w Porque|strong="H3588"\w* lo \w pedí|strong="H7592"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 21 Otra vez \w aquel|strong="H3605"\w* hombre Elcana \w subió|strong="H5927"\w* con \w toda|strong="H3605"\w* su \w familia|strong="H1004"\w* \w a|strong="H3068"\w* ofrecer \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w el|strong="H3605"\w* \w sacrificio|strong="H2077"\w* anual y pagar su \w voto|strong="H5088"\w*.
\v 22 \w Pero|strong="H3588"\w* Ana \w no|strong="H3808"\w* \w subió|strong="H5927"\w*, \w sino|strong="H3588"\w* dijo \w a|strong="H3068"\w* \w su|strong="H3588"\w* esposo: \w Yo|strong="H3588"\w* \w no|strong="H3808"\w* \w subiré|strong="H5927"\w* \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w niño|strong="H5288"\w* sea destetado. \w Entonces|strong="H3588"\w* \w lo|strong="H3808"\w* llevaré \w para|strong="H5704"\w* presentarlo \w ante|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w y|strong="H3588"\w* \w se|strong="H3808"\w* \w quede|strong="H3427"\w* \w allí|strong="H8033"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.
\p 
\v 23 Su marido Elcana \w le|strong="H5869"\w* respondió: \w Haz|strong="H6213"\w* \w lo|strong="H1697"\w* \w que|strong="H5704"\w* \w te|strong="H5869"\w* parezca \w bien|strong="H2896"\w*. \w Quédate|strong="H3427"\w* \w hasta|strong="H5704"\w* \w cuando|strong="H5704"\w* \w lo|strong="H1697"\w* destetes. Solo \w que|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w cumpla|strong="H6965"\w* la \w Palabra|strong="H1697"\w*. Así \w que|strong="H5704"\w* se \w quedó|strong="H3427"\w* la mujer, \w y|strong="H5704"\w* crió \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w lo|strong="H1697"\w* destetó.
\p 
\v 24 Después que lo destetó lo llevó \w consigo|strong="H5973"\w* \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* \w de|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w en|strong="H5973"\w* \w Silo|strong="H7887"\w*, \w con|strong="H5973"\w* un \w becerro|strong="H6499"\w* \w de|strong="H5973"\w* \w tres|strong="H7969"\w* años, 22 litros \w de|strong="H5973"\w* flor \w de|strong="H5973"\w* \w harina|strong="H7058"\w* y un \w odre|strong="H5035"\w* \w de|strong="H5973"\w* \w vino|strong="H3196"\w*. \w El|strong="H5973"\w* \w niño|strong="H5288"\w* era pequeño.
\v 25 Después de degollar el \w becerro|strong="H6499"\w*, llevaron el \w niño|strong="H5288"\w* \w a|strong="H3068"\w* \w Elí|strong="H5941"\w*.
\p 
\v 26 \w Y|strong="H3068"\w* \add Ana\add* dijo: Oh, \tl ʼadón\tl* mío, \w vive|strong="H2416"\w* tu \w alma|strong="H5315"\w*. \tl ʼAdón\tl* mío, \w yo|strong="H5315"\w* soy aquella mujer \w que|strong="H2088"\w* estuvo \w aquí|strong="H2088"\w* \w junto|strong="H5973"\w* \w a|strong="H3068"\w* \w ti|strong="H5973"\w* y oraba \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 27 \w Por|strong="H2088"\w* \w este|strong="H2088"\w* \w niño|strong="H5288"\w* oraba, y \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H5973"\w* concedió \w lo|strong="H2088"\w* \w que|strong="H2088"\w* \w le|strong="H5973"\w* \w pedí|strong="H7592"\w*.
\v 28 Por tanto, yo \w también|strong="H1571"\w* \w lo|strong="H1931"\w* dedico \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Mientras|strong="H3605"\w* viva, \w él|strong="H1931"\w* \w está|strong="H1931"\w* dedicado \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p \w Y|strong="H3068"\w* \add Elí\add*\f + \fr 1:28 \ft El original dice: él. No pudo ser el bebé. El único varón presente era el sacerdote Elí.\f* \w se|strong="H1961"\w* postró \w allí|strong="H8033"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*.
\c 2
\s1 Cántico de Ana
\p 
\v 1 \w Entonces|strong="H3588"\w* Ana \w oró|strong="H6419"\w* \w y|strong="H3588"\w* exclamó:
\q1 \w Mi|strong="H5921"\w* \w corazón|strong="H3820"\w* \w se|strong="H5921"\w* exalta \w en|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\q1 \w Mi|strong="H5921"\w* \w cuerno|strong="H7161"\w* \w se|strong="H5921"\w* exalta \w en|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\q1 \w Mi|strong="H5921"\w* \w boca|strong="H6310"\w* habla osadamente \w contra|strong="H5921"\w* mis enemigos,
\q1 \w Porque|strong="H3588"\w* \w me|strong="H5921"\w* regocijo \w en|strong="H5921"\w* tu salvación.
\q1 
\v 2 \w No|strong="H3588"\w* hay \w santo|strong="H6918"\w* \w como|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*,
\q1 \w Porque|strong="H3588"\w* ninguno hay fuera \w de|strong="H3588"\w* Ti,
\q1 \w Ni|strong="H1115"\w* hay refugio \w como|strong="H3588"\w* \w el|strong="H3588"\w* \nd ʼElohim\nd* nuestro.
\q1 
\v 3 \w No|strong="H3808"\w* multipliquen \w palabras|strong="H1696"\w* altivas,
\q1 \w Ni|strong="H3808"\w* \w salga|strong="H3318"\w* arrogancia \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w boca|strong="H6310"\w*,
\q1 \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H3588"\w* \nd ʼElohim\nd* \w de|strong="H3588"\w* \w entendimiento|strong="H1844"\w*,
\q1 \w Y|strong="H3068"\w* \w Él|strong="H3588"\w* \w pesa|strong="H8505"\w* las acciones.
\q1 
\v 4 Los \w arcos|strong="H7198"\w* de los \w fuertes|strong="H2428"\w* son quebrados,
\q1 Pero los que se tambalean son fortalecidos.
\q1 
\v 5 \w Los|strong="H1121"\w* \w que|strong="H5704"\w* estaban saciados se venden \w por|strong="H5704"\w* \w pan|strong="H3899"\w*,
\q1 Pero \w los|strong="H1121"\w* \w hambrientos|strong="H7457"\w* \w dejan|strong="H2308"\w* \w de|strong="H5704"\w* tener hambre.
\q1 \w Mientras|strong="H5704"\w* la estéril da \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w siete|strong="H7651"\w*,
\q1 La \w que|strong="H5704"\w* tiene \w muchos|strong="H7227"\w* \w hijos|strong="H1121"\w* se debilita.
\q1 
\v 6 \nd \w Yavé|strong="H3068"\w*\nd* \w mata|strong="H4191"\w* y da \w vida|strong="H2421"\w*.
\q1 Él hace bajar al \tl Seol\tl* y hace \w subir|strong="H5927"\w*.
\q1 
\v 7 \nd \w Yavé|strong="H3068"\w*\nd* \w empobrece|strong="H3423"\w* y \w enriquece|strong="H6238"\w*.
\q1 Él \w abate|strong="H8213"\w* y enaltece.
\q1 
\v 8 \w Él|strong="H5921"\w* \w levanta|strong="H7311"\w* \w al|strong="H5921"\w* \w pobre|strong="H1800"\w* \w del|strong="H5921"\w* \w polvo|strong="H6083"\w*,
\q1 \w Y|strong="H3068"\w* exalta \w al|strong="H5921"\w* necesitado \w desde|strong="H5921"\w* \w el|strong="H5921"\w* muladar
\q1 \w Para|strong="H5921"\w* sentarlo \w con|strong="H5973"\w* príncipes \w y|strong="H3588"\w* heredar un \w trono|strong="H3678"\w* \w de|strong="H5921"\w* honor.
\q1 \w Porque|strong="H3588"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w son|strong="H3588"\w* \w las|strong="H5921"\w* columnas \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w tierra|strong="H6083"\w*,
\q1 \w Y|strong="H3068"\w* \w Él|strong="H5921"\w* colocó \w el|strong="H5921"\w* \w mundo|strong="H8398"\w* \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w*.
\q1 
\v 9 \w Él|strong="H3588"\w* \w guarda|strong="H8104"\w* \w los|strong="H3588"\w* \w pies|strong="H7272"\w* \w de|strong="H3588"\w* sus \w santos|strong="H2623"\w*,
\q1 \w Pero|strong="H3588"\w* \w los|strong="H3588"\w* perversos \w perecen|strong="H1826"\w* \w en|strong="H3588"\w* \w la|strong="H8104"\w* \w oscuridad|strong="H2822"\w*,
\q1 \w Porque|strong="H3588"\w* \w por|strong="H3588"\w* \w su|strong="H3588"\w* propia \w fuerza|strong="H3581"\w* \w no|strong="H3808"\w* prevalece un hombre.
\q1 
\v 10 \w Los|strong="H5921"\w* adversarios \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* son destrozados.
\q1 \w Contra|strong="H5921"\w* \w ellos|strong="H5921"\w* truena \w desde|strong="H5921"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w*.
\q1 \nd \w Yavé|strong="H3068"\w*\nd* \w juzgará|strong="H1777"\w* \w los|strong="H5921"\w* confines \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra,
\q1 \w Dará|strong="H5414"\w* \w fortaleza|strong="H5797"\w* \w a|strong="H3068"\w* su \w Rey|strong="H4428"\w*
\q1 \w Y|strong="H3068"\w* exaltará \w el|strong="H5921"\w* \w cuerno|strong="H7161"\w* \w de|strong="H5921"\w* su \w Ungido|strong="H4899"\w*.
\s1 Conducta perversa de los hijos de Elí
\p 
\v 11 Entonces Elcana regresó \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* \w en|strong="H5921"\w* \w Ramá|strong="H7414"\w*, pero \w el|strong="H5921"\w* \w niño|strong="H5288"\w* \w ministraba|strong="H8334"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w Elí|strong="H5941"\w*.
