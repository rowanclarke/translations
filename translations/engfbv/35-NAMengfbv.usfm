\v 2 \w The|strong="H3068"\w* \w Lord|strong="H3068"\w* \w is|strong="H3068"\w* \w a|strong="H3068"\w* \w jealous|strong="H7072"\w* \w and|strong="H3068"\w* \w avenging|strong="H5358"\w* \w God|strong="H3068"\w*—\w the|strong="H3068"\w* \w Lord|strong="H3068"\w* \w God|strong="H3068"\w* \w is|strong="H3068"\w* \w avenging|strong="H5358"\w* \w and|strong="H3068"\w* \w angry|strong="H2534"\w*. \w The|strong="H3068"\w* \w Lord|strong="H3068"\w* \w takes|strong="H5358"\w* \w vengeance|strong="H5358"\w* \w on|strong="H3068"\w* \w his|strong="H3068"\w* \w enemies|strong="H6862"\w*, \w he|strong="H1931"\w* \w is|strong="H3068"\w* \w angry|strong="H2534"\w* \w with|strong="H3068"\w* \w those|strong="H1931"\w* \w who|strong="H1931"\w* \w are|strong="H3068"\w* \w hostile|strong="H6862"\w* \w to|strong="H3068"\w* \w him|strong="H1931"\w*.
