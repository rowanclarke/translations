\p 
\v 9 \w If|strong="H3588"\w* \w there|strong="H3605"\w*'s \w an|strong="H5414"\w* argument \w over|strong="H5414"\w* \w the|strong="H3605"\w* ownership \w of|strong="H3605"\w* \w an|strong="H5414"\w* \w ox|strong="H7794"\w*, \w a|strong="H3068"\w* \w donkey|strong="H2543"\w*, \w a|strong="H3068"\w* \w sheep|strong="H7716"\w*, \w a|strong="H3068"\w* garment, \w or|strong="H2543"\w* \w anything|strong="H3605"\w* \w that|strong="H3588"\w* \w was|strong="H5414"\w* lost \w that|strong="H3588"\w* \w someone|strong="H5414"\w* says, ‘\w This|strong="H5414"\w* \w is|strong="H3605"\w* \w mine|strong="H8104"\w*,’ \w both|strong="H3605"\w* parties are \w to|strong="H4191"\w* \w bring|strong="H5414"\w* \w their|strong="H3605"\w* \w case|strong="H3588"\w* \w before|strong="H7200"\w* \w the|strong="H3605"\w* judges. \w The|strong="H3605"\w* \w one|strong="H3605"\w* \w whom|strong="H3588"\w* \w the|strong="H3605"\w* judges \w find|strong="H7200"\w* \w in|strong="H4191"\w* \w the|strong="H3605"\w* wrong \w must|strong="H4191"\w* \w pay|strong="H5414"\w* \w the|strong="H3605"\w* \w other|strong="H7453"\w* back double.
