\id TDX Topical Index for the Anjam NT Robert Rucker 13-September-2000
\h Anjam Mutu Qudei
\toc2 Anjam Mutu Qudei
\toc1 Anjam Mutu Qudei
\mt1 Anjam Mutu Qudei
\ip Ni qalie bei oqajqa are soqnimqa kiyo gulbe bei inoq di brantimqa kiyo ni Qotei aqa anjam mutu endi sisiy.
\c 1
\p 
\v 1 Ni Qotei qa qalieqajqa marsimqa ni anjam mutu endi sisiy:
\tr 
\tc1 Aposel 14:14-17
\tc2 Aposel 17:22-31
\tc3 Rom 1:18-23
\tr 
\tc1 Rom 11:33-36
\tc2 1 Korin 8:4-6
\tc3 Mak 12:29-30
\tr 
\tc1 Jon 4:23-24
\tc2 1 Timoti 1:17
\tc3 1 Timoti 6:15-16
\tr 
\tc1 Hibru 4:13
\tc2 Hibru 10:30-31
\tc3 Jems 1:17
\tr 
\tc1 1 Pita 1:14-17
\tc2 1 Jon 1:5
\tc3 1 Jon 4:7-12, 16
\tr 
\tc1 2 Korin 1:3
\tc2 Jut 24-25
\tc3 Uli Anjam 4:8-11
\tr 
\tc1 Uli Anjam 15:3-4
\tc2 
\tc3 
\p 
\v 2 Ni Qotei aqa Ŋiri Yesus Kristus qa qalieqajqa marsimqa ni anjam mutu endi sisiy:
\tr 
\tc1 Jon 1:1-18
\tc2 Filipai 2:5-11
