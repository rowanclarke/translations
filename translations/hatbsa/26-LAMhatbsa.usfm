\id LAM
\h Lamantasyon Yo
\toc1 LAMANTASYON YO
\toc2 Lamantasyon Yo
\toc3 Lam
\mt1 LAMANTASYON YO
\c 1
\p 
\v 1 A la sèl,
\q1 vil ki te konn \x + \xo 1:1 \xt És 22:2\x*plen moun nan chita sèl!
\q1 Li vin tankou yon vèv
\q1 ki te konn byen pwisan pami nasyon yo!
\q1 Sila ki te konn yon fanm
\q1 byen gran pami nasyon yo!
\q1 Li menm ki te yon prensès pami pwovens yo,
\q1 Koulye a, se travo fòse li oblije fè!
\b
\q1 
\v 2 Li kriye byen anmè nan nwit lan.
\q1 Dlo zye li kouri desann figi l.
\q1 Pami tout sila ki te renmen l yo,
\q1 nanpwen moun ki pou bay li rekonfò.
\q1 Tout zanmi li yo fè l trèt;
\q1 yo te tounen lènmi l.
\b
\q1 
\v 3 \x + \xo 1:3 \xt Jr 13:19\x*Juda antre an egzil anba gwo opresyon;
\q1 anba esklavaj byen di.
\q1 Li demere pami nasyon yo;
\q1 pou repo, nanpwen.
\q1 Tout sila k ap pèsekite l yo,
\q1 fin sezi li nan mitan gwo twoub li.
\b
\q1 
\v 4 \x + \xo 1:4 \xt Jl 1:8-13\x*Chemen Sion yo ap fè dèy;
\q1 pèsòn pa rive nan fèt li yo.
\q1 Tout pòtay li yo vin dezole.
\q1 Prèt li yo ap plenn nan gòj,
\q1 vyèj li yo vin aflije,
\q1 e li menm, li vin anmè.
\b
\q1 
\v 5 Advèsè li yo te vin mèt li.
\q1 Lènmi li yo ap byen reyisi;
\q1 paske SENYÈ a te \x + \xo 1:5 \xt Sòm 90:7-8\x*koze doulè l,
\q1 akoz gwo kantite transgresyon li yo.
\q1 Pitit li yo se prizonye devan advèsè yo.
\b
\q1 
\v 6 Tout \x + \xo 1:6 \xt Jr 13:18\x*majeste fin kite fi a Sion an.
\q1 Prens li yo vin tankou sèf ki pa t jwenn patiraj.
\q1 Yo sove ale san rezistans
\q1 devan mèt lachas la.
\b
\q1 
\v 7 Jérusalem sonje tout bagay presye li yo \x + \xo 1:7 \xt Jr 37:7-10\x*nan jou afliksyon li.
\q1 Tout bèl bagay ki te la depi nan jou ansyen yo;
\q1 lè pèp li a te tonbe nan men a advèsè a,
\q1 e pa t gen okenn moun ki pou ede l.
\q1 Advèsè yo te wè l.
\q1 Yo te giyonnen l akoz tristès li.
\b
\q1 
\v 8 Jérusalem te \x + \xo 1:8 \xt És 59:2-13\x*fè gwo peche.
\q1 Konsa, li te vin yon bagay ki pa pwòp.
\q1 Tout sila ki te konn louwe l yo,
\q1 meprize l akoz yo te wè li toutouni.
\q1 Menm li menm plenn nan gòj, e vire an aryè.
\b
\q1 
\v 9 Depi nan jip li, salte a te la.
\q1 Li pa t konsidere davni li.
\q1 Akoz sa li te vin tonbe yon fason etonan.
\q1 Nanpwen moun pou konsole l.
\q1 “Gade, O SENYÈ, afliksyon mwen an;
\q1 paske ènmi an vante tèt li.
\q1 Li vin ògeye!”
\b
\q1 
\v 10 Advèsè a te lonje men l sou tout bagay
\q1 presye fi a te genyen;
\q1 li te wè ènmi yo antre nan sanktyè li a;
\q1 sila ke Ou menm te kòmande pou yo
\q1 \x + \xo 1:10 \xt Det 23:3\x*pa antre nan asanble Ou a.
\b
\q1 
\v 11 Tout pèp li a plenn nan gòj.
\q1 Yap \x + \xo 1:11 \xt Jr 38:9\x*chache pen.
\q1 Tout sa ak valè deja vèse bay pou manje,
\q1 pou kenbe nanm yo vivan an.
\q1 “Gade, O SENYÈ, paske mwen vin meprize.”
\b
\q1 
\v 12 Èske sa pa anyen pou nou tout ki pase nan wout sa a?
\q1 Gade pou wè si genyen yon doulè ki tankou doulè mwen an,
\q1 doulè ki te pase vin nan men m nan,
\q1 avèk sila \x + \xo 1:12 \xt Jr 30:23-24\x*SENYÈ a te aflije m nan jou a gran kòlè Li a.
\b
\q1 
\v 13 Soti anwo, Li te voye dife antre nan \x + \xo 1:13 \xt Job 30:30\x*zo m,
\q1 e l ap domine yo.
\q1 Li te ouvri yon pèlen pou pye m;
\q1 Li te fè m vire fè bak.
\q1 Li te fè m vin dezole, fèb tout lajounen.
\b
\q1 
\v 14 Jouk transgresyon mwen yo vin mare;
\q1 ak men Li yo koude nèt ansanm.
\q1 Yo te rive jis nan kou m;
\q1 Li te fè fòs mwen vin kraze disparèt.
\q1 Senyè a te \x + \xo 1:14 \xt Jr 32:3-5\x*livre m nan men a sila yo;
\q1 kont yo, mwen pa ka kanpe.
\b
\q1 
\v 15 Senyè a te rejte tout mesye pwisan ki nan mitan m yo.
\q1 Li te rele yon asanble solanèl kont mwen pou kraze \x + \xo 1:15 \xt Jr 6:11\x*jennonm mwen yo.
\q1 Senyè a te foule, konsi se nan yon pèz rezen, fi vyèj a Juda a.
\b
\q1 
\v 16 Pou bagay sa yo, mwen ap kriye.
\q1 Zye m koule ak dlo.
\q1 Konsolatè k ap rafrechi nanm mwen an lwen m,
\q1 Nanpwen \x + \xo 1:16 \xt Sòm 69:20\x*okenn moun ki ta ka konsole mwen,
\q1 okenn moun ki ta ka restore nanm mwen.
\q1 Pitit mwen yo vin dezole akoz ènmi an te vin genyen.
\b
\q1 
\v 17 Sion lonje men l ouvri nèt.
\q1 Nanpwen moun ki pou konsole l.
\q1 SENYÈ a te bay lòd konsènan Jacob,
\q1 ke sila ki antoure l yo ta lènmi avè l.
\q1 \x + \xo 1:17 \xt Lam 1:8\x*Jérusalem te devni yon bagay pa pwòp pami yo.
\b
\q1 
\v 18 SENYÈ a jis;
\q1 paske mwen te \x + \xo 1:18 \xt I Sam 12:14-15\x*fè rebèl kont lòd Li.
\q1 Tande koulye a, tout pèp yo
\q1 e gade byen doulè m nan.
\q1 Vyèj mwen yo ak jennonm mwen yo
\q1 te antre an kaptivite.
\b
\q1 
\v 19 Mwen te rele vè renmen mwen yo,
\q1 men yo te fè m desi.
\q1 \x + \xo 1:19 \xt Jr 14:15\x*Prèt mwen yo ak ansyen mwen yo te peri nan vil la
\q1 pandan yo t ap chache manje
\q1 pou restore fòs yo pou kont yo.
\b
\q1 
\v 20 Gade, O SENYÈ, paske mwen nan gwo twoub.
\q1 \x + \xo 1:20 \xt És 16:11\x*Lespri m twouble anpil;
\q1 kè m boulvèse anndan m,
\q1 paske mwen te fè rebèl anpil.
\q1 Nan lari, se nepe k ap touye;
\q1 nan kay, se tankou lanmò.
\b
\q1 
\v 21 Yo te tande ke m ap plenyen nan gòj;
\q1 men nanpwen moun ki pou konsole m.
\q1 Tout lènmi mwen yo tande afè gwo malè m nan.
\q1 Yo \x + \xo 1:21 \xt Sòm 35:15\x*kontan Ou te fè sa.
\q1 O ke Ou ta mennen jou ke Ou te pwoklame a,
\q1 pou yo ka vin tankou mwen.
\b
\q1 
\v 22 Kite tout mechanste yo vini devan Ou.
\q1 Konsa, \x + \xo 1:22 \xt Né 4:4\x*aji avèk yo kon Ou te aji avè m nan,
\q1 pou tout transgresyon mwen yo.
\q1 Paske plent k ap sòti anndan m yo anpil
\q1 e kè m vin fèb nèt.
\c 2
\p 
\v 1 Gade kijan Senyè a te kouvri fi a Sion an
\q1 ak yon nwaj nan kòlè li!
\q1 Li te \x + \xo 2:1 \xt És 14:12-15\x*jete soti nan syèl la, jis rive atè glwa Israël la.
\q1 Li pa t menm sonje machpye pa L la, nan jou kòlè Li.
\b
\q1 
\v 2 Senyè a te vale tout nèt.
\q1 Li pa t epanye tout abitasyon Jacob yo.
\q1 Nan gwo chalè Li, Li te jete sitadèl fi a Juda a.
\q1 Li te \x + \xo 2:2 \xt És 25:12\x*bese yo nèt jis rive atè.
\q1 Li te pwofane wayòm nan ak tout prens li yo.
\b
\q1 
\v 3 Nan gwo chalè, Li te koupe tout fòs Israël la.
\q1 Li te retire men dwat Li soti devan lènmi an.
\q1 Konsa, Li te \x + \xo 2:3 \xt És 42:25\x*brile Jacob tankou flanm dife
\q1 ki konsome toupatou.
\b
\q1 
\v 4 Li te koube \x + \xo 2:4 \xt Job 6:4\x*banza Li kon yon lènmi.
\q1 Li te poze men dwat li konsi se yon advèsè.
\q1 Konsa, Li te touye tout sa yo ki bèl pou gade.
\q1 Nan tant a fi a Sion an,
\q1 Li te vin vide gwo kòlè Li tankou dife.
\b
\q1 
\v 5 Senyè a vin tankou yon \x + \xo 2:5 \xt Jr 30:14\x*lènmi.
\q1 Li te vale Israël nèt.
\q1 Li te vale tout palè li yo.
\q1 Li te detwi sitadèl li yo.
\q1 Li te miltipliye doulè yo ak plent yo
\q1 nan fi a Juda yo.
\b
\q1 
\v 6 Ak vyolans, Li te aji sou tanp Li an,
\q1 konsi se yon tonèl jaden.
\q1 Li te \x + \xo 2:6 \xt Jr 52:13\x*detwi kote ke Li menm te deziye
\q1 pou asanble yo.
\q1 SENYÈ a te fè bliye tout jou fèt ak Saba Sion yo,
\q1 e Li te meprize ni wa a, ni prèt la
\q1 nan gwo kòlè Li a.
\b
\q1 
\v 7 Senyè a te rejte lotèl Li a.
\q1 Li te abandone sanktyè Li a.
\q1 Li te \x + \xo 2:7 \xt Jr 33:4-5\x*livre nan men lènmi an, miray a palè li yo.
\q1 Yo te fè yon bri nan kay SENYÈ a, konsi
\q1 li ta nan yon jou fèt deziye.
\b
\q1 
\v 8 SENYÈ a te pran desizyon pou detwi miray a fi a Sion an.
\q1 Li te \x + \xo 2:8 \xt II Wa 21:13\x*lonje yon lign.
\q1 Li pa t ralanti men l nan destriksyon.
\q1 Li te fè ni ranpa, ni miray la plen tristès;
\q1 y ap kriye ansanm.
\b
\q1 
\v 9 \x + \xo 2:9 \xt Né 1:3\x*Pòtay li yo te fonse antre nan tè,
\q1 Li te detwi e kraze fè fòje a.
\q1 Wa li yo ak prens li yo vin gaye pami nasyon yo;
\q1 lalwa, nanpwen ankò.
\q1 Anplis, pwofèt li yo pa resevwa vizyon de SENYÈ a.
\b
\q1 
\v 10 Ansyen a fi a Sion yo chita atè.
\q1 Yo rete an silans.
\q1 Yo te jete \x + \xo 2:10 \xt Job 2:12\x*pousyè sou tèt yo.
\q1 Yo abiye yo ak twal sak.
\q1 Vyèj Jérusalem yo fin bese tèt yo jis a tè a.
\b
\q1 
\v 11 Zye m gate akoz dlo k ap sòti ladann,
\q1 \x + \xo 2:11 \xt Jr 4:19\x*lespri m vin nan gwo twoub;
\q1 kè m vin vide atè nèt, akoz
\q1 fi a pèp mwen an vin detwi
\q1 e timoun ak tibebe yo ap fennen
\q1 nan lari vil la.
\b
\q1 
\v 12 Yo mande manman yo: \x + \xo 2:12 \xt Jr 5:17\x*“Kote sereyal ak diven an?”
\q1 Konsa, yo fennen tankou yon nonm ki blese nan lari vil yo,
\q1 pandan lavi yo menm vin vide nan sen manman yo.
\b
\q1 
\v 13 Kisa pou m ta di ou?
\q1 A kilès pou m ta konpare ou, O fi Jérusalem nan?
\q1 A kisa pou m ta di ou sanble pandan mwen
\q1 ap mennen rekonfò bay ou a,
\q1 O fi vyèj a Sion an?
\q1 Paske destriksyon ou an vast tankou lanmè.
\q1 Se kilès ki ka \x + \xo 2:13 \xt Jr 8:22\x*geri ou?
\b
\q1 
\v 14 Pwofèt ou yo te wè pou ou vizyon ki te fo;
\q1 ki te plen foli.
\q1 Yo pa t \x + \xo 2:14 \xt És 58:1\x*dekouvri inikite ou
\q1 pou restore ou sòti an kaptivite,
\q1 men yo te wè pou ou vizyon
\q1 pòt pawòl ki te fo,
\q1 ki te egare ou.
\b
\q1 
\v 15 Tout moun ki pase akote chemen an
\q1 \x + \xo 2:15 \xt Job 27:23\x*bat men yo pou moke ou.
\q1 Yo sifle anlè kon koulèv
\q1 sou fi Jérusalem nan, epi yo di:
\q1 “Men èske se vil sa a yo te konn rele
\q1 ‘pèfeksyon a bèlte a, yon jwa de tout tè a’?”
\b
\q1 
\v 16 Tout lènmi ou yo te louvri bouch yo laj kont ou.
\q1 Yo sifle anlè kon koulèv.
\q1 Yo fwote dan yo.
\q1 Yo di: “Nou te \x + \xo 2:16 \xt Sòm 56:2\x*vale l nèt!
\q1 Anverite, se jou sa ke nou t ap tann nan.
\q1 Nou gen tan jwenn li.
\q1 Nou gen tan wè l.”
\b
\q1 
\v 17 SENYÈ a te \x + \xo 2:17 \xt Jr 4:28\x*acheve objektif Li;
\q1 Li te akonpli pawòl Li, pawòl ke Li
\q1 te kòmande soti nan jou ansyen yo.
\q1 Li te jete ba,
\q1 Li pat fè pitye.
\q1 Li te fè lènmi an rejwi sou ou.
\q1 Li te egzalte pwisans a advèsè ou yo.
\b
\q1 
\v 18 \x + \xo 2:18 \xt Sòm 119:145\x*Kè yo te kriye fò a Senyè a.
\q1 O miray a fi Sion an,
\q1 kite dlo sòti nan zye ou lajounen kon lannwit.
\q1 Pa aksepte okenn soulajman;
\q1 'Pa kite zye ou pran repo.
\b
\q1 
\v 19 Leve, kriye fò nan nwit lan,
\q1 nan kòmansman vèy nwit lan!
\q1 \x + \xo 2:19 \xt I Sam 1:15\x*Vide kè ou konsi se dlo devan prezans Senyè a.
\q1 Leve men ou a Li menm pou lavi pitit ou yo
\q1 ki fèb nèt ak grangou sou tèt a tout ri yo.
\b
\q1 
\v 20 Gade pou wè, O SENYÈ! Avèk kilès ou te aji konsa?
\q1 Èske fanm ta dwe \x + \xo 2:20 \xt Jr 19:9\x*manje pwòp pitit pa yo,
\q1 pitit yo ki te fèt an bòn sante?
\q1 Èske prèt la ak pwofèt la
\q1 dwe vin touye nan sanktyè Senyè a?
\b
\q1 
\v 21 Sou tè nan lari yo, kouche \x + \xo 2:21 \xt II Kwo 36:17\x*jenn yo ak granmoun yo.
\q1 Vyèj mwen yo ak jennonm mwen yo te tonbe sou nepe.
\q1 Ou te touye yo nan jou gwo kòlè Ou a;
\q1 Ou te fè masak, san pitye.
\b
\q1 
\v 22 Ou te rele nou konsi se nan jou a yon fèt etabli,
\q1 gwo laperèz mwen yo tout kote.
\q1 \x + \xo 2:22 \xt Jr 11:11\x*Nanpwen moun ki te chape sòti vivan
\q1 nan jou kòlè SENYÈ a.
\q1 Sila ke m te fè e leve yo,
\q1 lènmi m te anile yo nèt.
\c 3
\q1 
\v 1 Mwen se moun ki te \x + \xo 3:1 \xt Sòm 88:7-16\x*wè afliksyon
\q1 akoz baton kòlè Li a.
\q1 
\v 2 Li te mennen mwen,
\q1 e te fè m mache nan \x + \xo 3:2 \xt Job 30:26\x*tenèb,
\q1 pa nan limyè.
\q1 
\v 3 Anverite, li te \x + \xo 3:3 \xt Sòm 38:2\x*vire men L kont mwen
\q1 plizyè fwa, tout jounen an.
\b
\q1 
\v 4 Li te fè chè m ak po m vin epwize sòti sou mwen,
\q1 Li te \x + \xo 3:4 \xt Sòm 51:8\x*kase zo m yo.
\q1 
\v 5 Li te \x + \xo 3:5 \xt Job 19:8\x*jennen mwen e te antoure m
\q1 ak amètim ak difikilte.
\q1 
\v 6 Nan kote ki \x + \xo 3:6 \xt Sòm 88:5-6\x*fènwa, li te fè m abite,
\q1 tankou sila ki fin mouri lontan yo.
\b
\q1 
\v 7 Li te \x + \xo 3:7 \xt Job 3:23\x*antoure m anndan pou m pa ka sòti.
\q1 Li te fè chenn mwen an byen lou.
\q1 
\v 8 Menm lè m kriye e rele sekou,
\q1 Li \x + \xo 3:8 \xt Job 30:20\x*fèmen lapriyè m deyò.
\q1 
\v 9 Li te \x + \xo 3:9 \xt És 63:17\x*bloke wout mwen yo ak wòch taye.
\q1 Li te fè chemen mwen yo vin kwochi.
\b
\q1 
\v 10 Li pou mwen tankou yon lous ki kouche ap tann,
\q1 tankou yon lyon nan kote an kachèt.
\q1 
\v 11 Li te detounen tout chemen mwen yo
\q1 e Li te \x + \xo 3:11 \xt Job 16:12-13\x*chire mwen an mòso;
\q1 Li te fè m vin dezole nèt.
\q1 
\v 12 Li te koube banza Li,
\q1 e Li te \x + \xo 3:12 \xt Job 6:4\x*chwazi m kon pwen final pou flèch Li.
\b
\q1 
\v 13 Li te fè flèch nan \x + \xo 3:13 \xt Jr 5:16\x*fouwo L yo
\q1 antre nan ren mwen.
\q1 
\v 14 Mwen te vin yon \x + \xo 3:14 \xt Sòm 22:6-7\x*rizib pou tout pèp mwen an,
\q1 chante giyonnen yo sonnen tout lajounen.
\q1 
\v 15 Li te \x + \xo 3:15 \xt Jr 9:15\x*plen mwen ak amètim.
\q1 Li te fè m sou ak dlo absent.
\b
\q1 
\v 16 Li te \x + \xo 3:16 \xt Sòm 3:7\x*kase dan m ak gravye.
\q1 Li fè m kache nan pousyè.
\q1 
\v 17 Nanm mwen \x + \xo 3:17 \xt És 59:11\x*p ap jwenn lapè ankò.
\q1 Bonè vin bliye pou mwen.
\q1 
\v 18 Konsa mwen di: “Fòs mwen fin peri,
\q1 ansanm ak \x + \xo 3:18 \xt Job 17:5\x*espwa m ki sòti nan SENYÈ a.”
\b
\q1 
\v 19 Sonje soufrans mwen ak mizè mwen an;
\q1 dlo absent ak amètim ki nan kè m nan.
\q1 
\v 20 Anverite, nanm mwen sonje yo.
\q1 Li vin \x + \xo 3:20 \xt Sòm 42:5-11\x*koube anndan mwen.
\q1 
\v 21 Men sa mwen sonje nan tèt mwen;
\q1 pou sa, mwen gen \x + \xo 3:21 \xt Sòm 130:7\x*espwa.
\b
\q1 
\v 22 Lanmou dous SENYÈ a, anvèrite, p ap janm sispann,
\q1 \x + \xo 3:22 \xt Mal 3:6\x*paske mizerikòd Li p ap janm manke.
\q1 
\v 23 Yo renouvle chak maten.
\q1 Gran se \x + \xo 3:23 \xt Eb 10:23\x*fidelite Ou.
\q1 
\v 24 “SENYÈ a se \x + \xo 3:24 \xt Sòm 16:5\x*pòsyon mwen.”
\q1 Se sa nanm mwen di m.
\q1 Konsa, mwen mete espwa m nan Li.
\b
\q1 
\v 25 SENYÈ a montre dousè Li a sila ki \x + \xo 3:25 \xt Sòm 27:14\x*tann Li yo,
\q1 a moun ki chache Li a.
\q1 
\v 26 Se bon pou yon nonm gen espwa,
\q1 e \x + \xo 3:26 \xt Sòm 37:7\x*tann byen trankil pou sali SENYÈ a.
\q1 
\v 27 Se bon pou yon nonm pote jouk la nan jenès li.
\b
\q1 
\v 28 Kite li \x + \xo 3:28 \xt Jr 15:7\x*chita apa pou kont li, e rete an silans,
\q1 akoz Li te poze sa sou li.
\q1 
\v 29 Kite li mete bouch li nan pousyè,
\q1 si se konsa, pou l ka gen \x + \xo 3:29 \xt Jr 31:17\x*espwa.
\q1 
\v 30 Kite li lonje \x + \xo 3:30 \xt Job 16:10\x*machwè li, bay sila k ap frape l la.
\q1 Kite li ranpli ak repwòch.
\b
\q1 
\v 31 Paske se pa pou tout tan ke Senyè a ap \x + \xo 3:31 \xt Sòm 77:7\x*rejte.
\q1 
\v 32 Paske malgre se gwo doulè ke Li fè rive;
\q1 alò, Li va gen \x + \xo 3:32 \xt Sòm 78:38\x*mizerikòd selon gran lanmou dous Li a.
\q1 
\v 33 Paske \x + \xo 3:33 \xt Sòm 119:67-75\x*se pa ak kè kontan ke Li aflije,
\q1 oswa pou atriste fis a lòm yo.
\b
\q1 
\v 34 Pou kraze anba pye, tout prizonye nan mond lan,
\q1 
\v 35 pou retire \x + \xo 3:35 \xt Sòm 140:12\x*jistis sou yon nonm nan prezans a Pi Wo a,
\q1 
\v 36 pou \x + \xo 3:36 \xt Jr 22:3\x*fè yon nonm tò nan pwosè legal pa li,
\q1 sou bagay sa yo, Senyè a p ap dakò.
\b
\q1 
\v 37 Se kilès li ye ki pale, e \x + \xo 3:37 \xt Sòm 33:9-11\x*sa vin rive,
\q1 amwenske Senyè a te pase lòd la?
\q1 
\v 38 Èske \x + \xo 3:38 \xt Job 2:10\x*sa ki bon ak sa ki mal
\q1 pa soti nan bouch a Pi Wo a?
\q1 
\v 39 Poukisa yon nonm vivan dwe plenyen,
\q1 yon nonm\x + \xo 3:39 \xt Jr 30:15\x*ta plenyen lè l resevwa pinisyon pou pwòp peche l yo?
\b
\q1 
\v 40 Annou \x + \xo 3:40 \xt Sòm 119:59\x*egzamine e sonde wout nou yo
\q1 pou nou retounen kote SENYÈ a.
\q1 
\v 41 Annou \x + \xo 3:41 \xt Sòm 25:1\x*leve kè nou ak men nou vè Bondye nan syèl la;
\q1 
\v 42 Nou te \x + \xo 3:42 \xt Né 9:26\x*peche e nou te fè rebèl;
\q1 Ou pa t padone.
\b
\q1 
\v 43 Ou te kouvri nou ak \x + \xo 3:43 \xt Lam 2:2-21\x*kòlè e te kouri dèyè nou.
\q1 Ou te touye.
\q1 Ou pa t gen pitye menm.
\q1 
\v 44 Ou te \x + \xo 3:44 \xt Lam 3:8\x*kouvri tèt Ou ak yon nwaj lakòlè,
\q1 pou okenn lapriyè pa ka pase ladann.
\q1 
\v 45 Ou fè nou kon \x + \xo 3:45 \xt I Kor 4:13\x*poupou bèt ak fatra
\q1 ki rejte nan mitan lòt nasyon yo.
\b
\q1 
\v 46 Tout lènmi nou yo te \x + \xo 3:46 \xt Job 30:9-10\x*ouvri bouch yo laj kont nou.
\q1 
\v 47 \x + \xo 3:47 \xt És 24:17-18\x*Sezisman ak pyèj tonbe sou nou,
\q1 ravaj ak destriksyon.
\b
\q1 
\v 48 \x + \xo 3:48 \xt Sòm 119:136\x*Zye m koule nèt ak flèv dlo
\q1 akoz destriksyon a fi a pèp mwen an.
\q1 
\v 49 Zye m koule \x + \xo 3:49 \xt Sòm 77:2\x*san sès, san rete menm pou yon ti moman,
\q1 
\v 50 jiskaske SENYÈ a \x + \xo 3:50 \xt Sòm 80:14\x*gade anba
\q1 soti nan wotè syèl la pou wè.
\q1 
\v 51 Zye m pote doulè rive nan nanm mwen,
\q1 akoz tout fi nan vil mwen.
\b
\q1 
\v 52 \x + \xo 3:52 \xt I Sam 26:20\x*Lènmi m yo san koz te fè lachas dèyè m tankou zwazo.
\q1 Se lènmi m san koz.
\q1 
\v 53 Yo te fè m rete an silans \x + \xo 3:53 \xt Dan 6:17\x*nan twou fòs la
\q1 e te poze yon wòch sou mwen.
\q1 
\v 54 Dlo yo te koule \x + \xo 3:54 \xt Sòm 69:2\x*depase tèt mwen.
\q1 Mwen te di: “Mwen fin koupe retire nèt”!
\b
\q1 
\v 55 Mwen \x + \xo 3:55 \xt Sòm 130:1\x*te rele non Ou, O SENYÈ,
\q1 depi nan twou fòs pi ba a.
\q1 
\v 56 Ou te \x + \xo 3:56 \xt Job 34:28\x*tande vwa m:
\q1 pa kache zòrèy W de lapriyè mwen pou sekou,
\q1 ak kriye mwen yo.
\b
\q1 
\v 57 Ou te \x + \xo 3:57 \xt Sòm 145:18\x*vin rapwoche lè m te rele Ou a.
\q1 Ou te di: “Pa pè!”
\b
\q1 
\v 58 O Senyè, Ou \x + \xo 3:58 \xt Jr 50:34\x*te plede ka pou nanm mwen an.
\q1 Ou te rachte lavi mwen.
\q1 
\v 59 O SENYÈ, Ou te wè jan m oprime.
\q1 \x + \xo 3:59 \xt Sòm 26:1\x*Jije ka m nan.
\q1 
\v 60 Ou te wè tout vanjans pa yo;
\q1 tout \x + \xo 3:60 \xt Jr 11:19\x*manèv yo kont mwen.
\b
\q1 
\v 61 Ou te tande \x + \xo 3:61 \xt Sòm 74:18\x*repwòch yo, O SENYÈ,
\q1 tout manèv yo kont mwen.
\q1 
\v 62 \x + \xo 3:62 \xt Sòm 59:7-12\x*Lèv a sila k ap atake m yo
\q1 ak konplo yo kont mwen tout lajounen.
\q1 
\v 63 Gade jan yo \x + \xo 3:63 \xt Sòm 139:2\x*chita ak jan yo leve;
\q1 se mwen ki sijè chan giyonnen yo a.
\b
\q1 
\v 64 Ou va \x + \xo 3:64 \xt Sòm 28:4\x*rekonpanse yo, O SENYÈ,
\q1 selon zèv men yo.
\q1 
\v 65 Ou va bay yo yon kè ki di;
\q1 \x + \xo 3:65 \xt Egz 14:8\x*madichon pa yo va sou yo.
\q1 
\v 66 Ou va \x + \xo 3:66 \xt Lam 3:43\x*kouri dèyè yo nan kòlè Ou
\q1 e detwi yo soti anba syèl SENYÈ a!
\c 4
\q1 
\v 1 A la briyans lò a vin \x + \xo 4:1 \xt Éz 7:19-22\x*bese!
\q1 Lò pi a pa menm ankò!
\q1 Wòch tanp yo vide deyò nan tout kwen lari.
\b
\q1 
\v 2 Pyè presye a fis a Sion yo;
\q1 ki gen valè kon lò fen,
\q1 gade kijan yo konsidere kon \x + \xo 4:2 \xt És 30:14\x*veso tè,
\q1 travay a potye a!
\b
\q1 
\v 3 Menm chen mawon yo konn bay tete;
\q1 yo kite pitit yo souse yo.
\q1 Men fi a pèp mwen an te vin \x + \xo 4:3 \xt És 49:15\x*mechan
\q1 kon yon otrich nan dezè.
\b
\q1 
\v 4 \x + \xo 4:4 \xt Sòm 22:15\x*Lang a ti bebe a kole nan fon bouch yo,
\q1 tèlman yo swaf;
\q1 ti piti yo mande pen,
\q1 men pèsòn pa kase bay yo.
\b
\q1 
\v 5 Sila ki te konn manje \x + \xo 4:5 \xt Jr 6:2\x*ti manje delika yo,
\q1 vin abandone nan lari.
\q1 Sila ki te leve nan abiman an mov yo
\q1 ap degaje yo chèche kaka bèf.
\b
\q1 
\v 6 Paske inikite a fi a pèp mwen an
\q1 pi gwo ke peche Sodome,
\q1 ki te \x + \xo 4:6 \xt Jen 19:25\x*boulvèse nan yon moman,
\q1 san pa t gen men ki boulvèse l.
\b
\q1 
\v 7 Prens li yo te \x + \xo 4:7 \xt Sòm 51:7\x*pi pwòp ke lanèj.
\q1 Yo te pi blan ke lèt.
\q1 Yo te pi wouj pase koray.
\q1 Yo te poli tankou pyè safì.
\b
\q1 
\v 8 Aparans yo koulye a \x + \xo 4:8 \xt Job 30:30\x*pi nwa ke poud chabon.
\q1 Yo pa menm rekonèt yo nan lari.
\q1 Chè yo vin kole sou zo yo.
\q1 Li fennen nèt.
\q1 Li vin tankou bwa.
\b
\q1 
\v 9 Pi bon se sila ki te touye ak nepe yo,
\q1 ke sila ki touye ak grangou yo;
\q1 paske yo vin chagren
\q1 e epwize akoz mank fwi chan an.
\b
\q1 
\v 10 Men a fanm ki te konn plen konpasyon yo
\q1 te bouyi pwòp pitit yo.
\q1 Yo te devni \x + \xo 4:10 \xt Det 28:53-55\x*manje pou yo,
\q1 akoz destriksyon a fi a pèp mwen an.
\b
\q1 
\v 11 SENYÈ a te \x + \xo 4:11 \xt Jr 7:20\x*acheve gwo kòlè Li a.
\q1 Li te vide gwo kòlè Li a.
\q1 Li te limen yon dife nan Sion,
\q1 ki te manje tout fondasyon Li yo.
\b
\q1 
\v 12 Wa latè yo pa t kwè,
\q1 ni okenn abitan nan mond lan,
\q1 ke advèsè ak ènmi an ta ka \x + \xo 4:12 \xt Jr 21:13\x*antre
\q1 nan pòtay Jérusalem nan.
\b
\q1 
\v 13 Akoz peche a pwofèt li yo
\q1 ak inikite a prèt li yo,
\q1 ki te vèse nan mitan li
\q1 \x + \xo 4:13 \xt Jr 2:30\x*san a moun ladwati yo.
\b
\q1 
\v 14 Yo egare e avèg nan lari yo.
\q1 Yo te vin souye ak \x + \xo 4:14 \xt És 1:15\x*san,
\q1 jiskaske pèsòn pa t ka manyen abiman yo.
\b
\q1 
\v 15 “Sòti! \x + \xo 4:15 \xt Lev 13:45-46\x*Pa pwòp!” Yo te kriye a yo menm.
\q1 “Sòti, sòti, pa touche!”
\q1 Konsa yo te sove ale, e te mache toupatou.
\q1 Pami nasyon yo, yo te di:
\q1 “Yo p ap ka kontinye rete pami nou”.
\b
\q1 
\v 16 Prezans a SENYÈ a te gaye yo.
\q1 Li p ap kontinye bay yo swen.
\q1 Yo pa t \x + \xo 4:16 \xt És 9:14-16\x*onore prèt yo,
\q1 Yo pa t respekte ansyen yo.
\b
\q1 
\v 17 Malgre sa, zye nou febli.
\q1 Chache sekou te vin \x + \xo 4:17 \xt Jr 37:7\x*initil.
\q1 Nan chache, nou te chache pou yon nasyon
\q1 ki pa t ka sove.
\b
\q1 
\v 18 Konsa, yo te \x + \xo 4:18 \xt Jr 16:16\x*fè lachas dèyè nou
\q1 jiskaske nou pa t ka mache nan lari nou yo.
\q1 Lafen nou vin pwòch.
\q1 Jou nou yo fin akonpli,
\q1 paske dènye moman nou vin rive.
\b
\q1 
\v 19 Sila ki te kouri dèyè nou yo
\q1 te pi vit pase èg k ap vole anlè.
\q1 Yo te fè lachas sou nou nan mòn yo.
\q1 Yo te kache tann anbiskad pou nou nan savann nan.
\b
\q1 
\v 20 Souf lè ki nan nen nou,
\q1 nou menm ki onksyone de \x + \xo 4:20 \xt II Sam 1:14\x*SENYÈ a,
\q1 te vin kaptire nan twou fòs yo,
\q1 de sila nou te konn di:
\q1 “Anba lonbraj li, nou va viv pami nasyon yo”.
\b
\q1 
\v 21 Rejwi e fè kè kontan, O fi a \x + \xo 4:21 \xt Sòm 137:7\x*Edom an,
\q1 ki rete nan peyi Uts la.
\q1 Tas la va fè wonn vin jwenn ou tou.
\q1 Ou va vin sou.
\q1 Ou va vin toutouni.
\b
\q1 
\v 22 Pinisyon pou inikite nou yo fin \x + \xo 4:22 \xt És 40:2\x*konplete,
\q1 O fi a Sion an.
\q1 Li p ap ekzile nou ankò.
\q1 Li va pini inikite nou an, O fi Edom an.
\q1 Li va fè parèt tout peche ou yo!
\c 5
\p 
\v 1 Sonje, O SENYÈ, sa ki te rive nou an.
\q1 Gade pou wè \x + \xo 5:1 \xt Sòm 44:13-16\x*repwòch nou.
\q1 
\v 2 Eritaj nou te bay kon don a \x + \xo 5:2 \xt És 1:7\x*etranje yo,
\q1 kay nou yo a moun nou pa konnen.
\q1 
\v 3 Nou te devni òfelen \x + \xo 5:3 \xt Egz 22:24\x*san papa.
\q1 Manman nou yo tankou vèv.
\q1 
\v 4 Nou oblije achte \x + \xo 5:4 \xt És 3:1\x*dlo pou nou bwè.
\q1 Bwa nou se pou vann, yo vann nou li.
\q1 
\v 5 Sila k ap kouri dèyè nou yo rive sou kou nou.
\q1 Nou vin bouke nèt.
\q1 \x + \xo 5:5 \xt Né 9:36-37\x*Nanpwen repo pou nou.
\q1 
\v 6 Nou te vin soumèt devan \x + \xo 5:6 \xt Os 9:3\x*Egypte ak Assyrie
\q1 pou nou jwenn ase pen.
\q1 
\v 7 \x + \xo 5:7 \xt Jr 14:20\x*Papa zansèt nou yo te peche,
\q1 men yo pa la ankò;
\q1 se nou menm ki te pote inikite pa yo.
\q1 
\v 8 Se \x + \xo 5:8 \xt Né 5:15\x*esklav yo k ap domine sou nou;
\q1 nanpwen moun ki pou delivre nou nan men yo.
\q1 
\v 9 Nou \x + \xo 5:9 \xt Jr 40:9-12\x*riske lavi nou pou jwenn pen
\q1 akoz nepe nan dezè a.
\q1 
\v 10 Po nou vin \x + \xo 5:10 \xt Job 30:30\x*kwit tankou yon fou,
\q1 akoz gwo chalè grangou a.
\q1 
\v 11 Yo te ravaje tout \x + \xo 5:11 \xt És 13:16\x*fanm Sion yo;
\q1 vyèj lavil a Juda yo.
\q1 
\v 12 Prens yo te pann pa men yo;
\q1 \x + \xo 5:12 \xt És 47:6\x*ansyen yo te vin pa respekte.
\q1 
\v 13 Jennonm yo te \x + \xo 5:13 \xt Jij 16:21\x*fòse travay devan moulen an
\q1 e timoun yo te kilbite anba gwo chaj bwa yo.
\q1 
\v 14 Ansyen yo ale kite pòtay la;
\q1 jennonm yo ale kite \x + \xo 5:14 \xt És 24:8\x*mizik yo.
\q1 
\v 15 Jwa nan kè nou vin \x + \xo 5:15 \xt Jr 25:10\x*sispann;
\q1 danse vin ranplase pa fè dèy.
\q1 
\v 16 Kouwòn nan soti sou tèt nou;
\q1 \x + \xo 5:16 \xt És 3:9-11\x*malè a nou menm, paske nou te peche!
\q1 
\v 17 Akoz sa, \x + \xo 5:17 \xt És 1:5\x*kè nou febli;
\q1 akoz bagay sa yo, zye nou pa wè klè.
\q1 
\v 18 Akoz \x + \xo 5:18 \xt Mi 3:12\x*Mòn Sion ki kouche dezole nèt,
\q1 rena yo fè patwouj ladann.
\b
\q1 
\v 19 Ou menm, O SENYÈ, Ou renye jis pou tout tan;
\q1 \x + \xo 5:19 \xt Sòm 45:6\x*twòn Ou se de jenerasyon an jenerasyon.
\q1 
\v 20 Poukisa Ou \x + \xo 5:20 \xt Sòm 13:1\x*bliye nou jis pou tout tan?
\q1 Poukisa Ou abandone nou jis rive tout tan sa a?
\q1 
\v 21 \x + \xo 5:21 \xt Sòm 80:3\x*Restore nou a Ou menm O SENYÈ,
\q1 pou nou ka vin restore.
\q1 Fè jou nou yo vin jan yo te ye nan tan pase yo.
\q1 
\v 22 Men \x + \xo 5:22 \xt Sòm 60:1-2\x*Ou deja fin rejte nou nèt.
\q1 Ou rete byen fache nèt ak nou. 
