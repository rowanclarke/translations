\id DEU
\h Kanawailua
\toc1 Kanawailua
\toc2 Kanawailua
\toc3 Kanawailua
\mt1 Kanawailua
\c 1
\s1 KA BUKE ALIMA A MOSE, I KAPAIA
\q1 
\v 1 EIA na olelo a Mose i olelo aku ai i ka Iseraela a pau ma keia aoao o Ioredane, ma ka waonahele, ma ka papu e ku pono ana i Zupa, mawaena o Parana a me Topela, a me Labana, a me Hazerota, a me Dizahaba.
\q1 
\v 2 (He umikumamakahi la hele mai Horeba, ma ke ala o Mauna Seira, a hiki i Kadesabanea.)
\q1 
\v 3 A i ka makahiki kanaha, i ka malama umikumamakahi, i ka la mua o ka malama, olelo aku la o Mose i na mamo a Iseraela, e like me na mea a pau a Iehova i kauoha mai ai ia ia no lakou;
\q1 
\v 4 Mahope iho o kana pepehi ana ia Sihona ke alii o ka Amora, ka mea i noho ma Hesebona, a ia Oga ke alii o Basana, ka mea i noho ma Asetarota i Ederei:
\q1 
\v 5 Ma keia aoao o Ioredane, ma ka aina o Moaba, i hoomaka'i o Mose e hai aku i keia kanawai, i aku la,
\q1 
\v 6 Olelo mai la o Iehova ko kakou Akua ia kakou ma Horeba, i mai la, Ua loihi ko oukou noho ana ma keia mauna:
\q1 
\v 7 E huli ae oukou, a i ka hele ana, e hele oukou i ka mauna o ka Amora, a i kona poe e noho ana a pau, ma na papu, ma na puu, a ma ke awawa, a ma ke kukuluhema, a ma kahakai, i ka aina o ko Kanaana, a i Lebanona, a i ka muliwai nui, ka muliwai o Euperate.
\q1 
\v 8 Aia hoi, ua haawi aku au i ka aina no oukou, e komo oukou, a e la we i ka aina a Iehova i hoohiki ai i ko oukou mau kupuna, ia Aberahama, ia Isaaka, a ia Iakoba, e haawi ia lakou, a me ka lakou poe mamo mahope o lakou.
\b
\q1 
\v 9 Olelo aku la au ia oukou i kela manawa, i aku la, Aole e hiki ia'u, owau wale, ke halihali ia oukou:
\q1 
\v 10 Ua hoonui mai o Iehova ko oukou Akua ia oukou, aia hoi, ua like oukou i keia la me na hoku o ka lani, he nui loa.
\q1 
\v 11 (A na Iehova ke Akua o ko oukou poe kupuna, e hoonui patausani aku ia oukou, a e hoomaikai mai ia oukou e like me kana i olelo mai ai ia oukou!)
\q1 
\v 12 Pehea la e hiki ai ia'u, owau wale no ke halihali i ko oukou kaumaha, a me ko oukou luhi, a me ko oukou hoopaapaa ana?
\q1 
\v 13 E wae oukou no oukou i na kanaka akamai, naauao, a ikeia e na hanauna kanaka o oukou, a e hoolilo au ia lakou i poe luna no oukou.
\q1 
\v 14 Olelo mai la oukou ia'u, i mai la, He mea pono ke hana i ka mea au i olelo mai nei.
\q1 
\v 15 A lawe aku la au i na luna o ko oukou mau ohana, i na kanaka naauao, a ikeia, a hoolilo iho la ia lakou i poo maluna o oukou, i luna no na tausani, i luna no na haneri, i luna no na kanalima, a i luna no na umi. i alii no ko oukou mau ohana.
\b
\q1 
\v 16 A kauoha aku la au i na lunakanawai o oukou i kela manawa, i ka i ana'e, E hoolohe oukou i na mea iwaena o na hoahanau o oukou, a e hoopono ma ka pololei iwaena o ke kanaka a me kona hoahanau, iwaena o ka malihini me ia.
\q1 
\v 17 Mai nana oukou i na maka i ka hooponopono ana; e lohe oukou i ka ka mea uuku e like me ka ka mea nui; mai makau oukou i ka maka o ke kanaka; no ka mea, na ke Akua ka hooponopono ana; a o ka mea pohihihi ia oukou, e lawe mai ia mea ia'u, a na'u ia e lohe aku.
\q1 
\v 18 A kauoha aku la au ia oukou i kela manawa i na mea a pau a oukou e hana aku ai.
\b
\q1 
\v 19 A ia kakou i haalele ai ia Horeba, hele kakou maloko o kela waonahele nui weliweli a pau, a oukou i ike ai ma ke ala o ka mauna o ka Amora, e like me ka Iehova i kauoha mai ai ia kakou; a hiki kakou ma Kadesabanea.
\q1 
\v 20 A aku la au ia oukou, Ua hiki mai oukou ma ka mauna o ka Amora, ka mea a Iehova ko kakou Akua i haawi mai ai no kakou.
\q1 
\v 21 Aia hoi, ke waiho mai nei o Iehova kou Akua i ka aina imua ou: e pii ae, e komo, e like me ka Iehova ke Akua o kou mau kupuna i olelo mai ai ia oe; mai makau, mai hoopauaho.
\b
\q1 
\v 22 A hele mai la oukou a pau io'u nei, i mai la, E hoouna aku kakou i na kanaka imua o kakou, a e makaikai lakou i ka aina no kakou, a e hai mai ia kakou i ke ala a kakou e pii aku ai, a me na kulanakauhale a kakou e hele aku ai.
\q1 
\v 23 Oluolu iho la au ia olelo: a lawe ae la au i na kanaka o oukou, he umikumamalua, pakahi ke kanaka no kela ohana, keia ohana.
\q1 
\v 24 Huli ae la lakou, a pii aku la ma ka mauna, a hiki ma ke kahawai o Esekola, a makaikai aku la i ka aina
\q1 
\v 25 Lawe lakou i ka hua o ka aina ma ko lakou mau lima, a iho mai io kakou nei, a hai mai ia kakou, i mai la, He maikai ka aina a Iehova ko kakou Akua e haawi mai nei ia kakou.
\b
\q1 
\v 26 Aole nae oukou i pii aku, aka, kipi aku oukou i ke kauoha a Iehova ko oukou Akua.
\q1 
\v 27 A ohumu ae la oukou iloko o ko oukou mau halelewa, i iho la, No ka inaina o Iehova ia kakou, i lawe mai ai oia ia kakou mailoko mai o ka aina o Aigupita, e haawi ia kakou iloko o ka lima o ka Amora, e luku mai ia kakou.
\q1 
\v 28 Mahea la uanei kakou e pii aku ai? Ua hooweliweli mai ko kakou mau hoahanau i ko kakou naau, ua i mai, Ua nui e aku na kanaka, na loihi hoi lakou ia kakou; a o na kulanakauhale nui, ua paa i ka pa pohaku a hala i ka lani; a ua ike hoi makou i na keiki a Anaka malaila.
\q1 
\v 29 I aku la au ia oukou, Mai hopohopo oukou, mai makau hoi ia lakou.
\q1 
\v 30 O Iehova ko oukou Akua, ka mea hele imua o oukou, nana no e kaua aku no oukou, e like me na mea a pau ana i hana'i no oukou ma Aigupita imua o ko oukou maka:
\q1 
\v 31 A ma ka waonahele, kahi au i ike ai ia Iehova kou Akua, e like me ka ke kanaka hali ana i kana keiki, pela ia i hali ai ia oe ma ke ala a pau a oukou i hele ai, a hiki mai oukou ma keia wahi.
\q1 
\v 32 Aka, ma keia mea, aole no oukou i hooiaio aku i ka Iehova ko oukou Akua;
\q1 
\v 33 Oia ka i hele ae ma ke ala imua o oukou, ma ke ahi i ka po, a ma ke ao i ke ao, e imi ana i wahi no oukou e kukulu ai i ko oukou mau halelewa, e kuhikuhi ana ia oukou i ke ala e hele ai.
\b
\q1 
\v 34 A lohe mai la o Iehova i ka leo o ka oukou olelo, a huhu mai la ia oukou, a hoohiki iho la, i ka i ana mai,
\q1 
\v 35 He oiaio, aole loa kekahi o keia poe kanaka o keia hanauna ino e ike aku i ka aina maikai a'u i hoohiki ai e haawi aku no ko oukou poe kupuna;
\q1 
\v 36 O Kaleba wale no ke keiki a Iepune; oia ke ike aku ia, a e haawi aku au i ka aina ana i hehi iho ai nona, a no kana mau keiki; no ka mea, ua hahai kupaa aku la ia ia Iehova.
\q1 
\v 37 Huhu mai no hoi o Iehova ia'u no oukou, i mai la, Aole hoi oe e hele ilaila.
\q1 
\v 38 O Iosua, ke keiki a Nuna, e ku ana imua on, oia ke hele ilaila: e hooikaika oe ia ia, no ka mea, nana no ia e hooili aku no ka Iseraela.
\q1 
\v 39 O ka oukou poe keiki uuku a oukou i i mai ai e lilo auanei i poe pio, a me na keiki a oukou, ka poe ike ole ai i ka pono a i hewa ia la, o lakou ke hele ilaila, a na'u ia e haawi aku no lakou, a e komo no lakou ia wahi.
\q1 
\v 40 Aka, o oukou, e haliu ae oukou, a e hele ma ka waonahele ma ke ala o ke Kaiula.
\b
\q1 
\v 41 Alaila, olelo mai la oukou, i mai la ia'u, Ua hana hewa makou ia Iehova, e pii no makou, a e kaua aku, e like me na mea a pau a Iehova ko kakou Akua i kauoha mai ai ia kakou. A i ka wa a oukou, a kela kanaka, keia kanaka i hawele ai i kana mea kaua, ua makaukau oukou e pii maluna o ka puu.
\q1 
\v 42 I mai la o Iehova ia'u, E i aku oe ia lakou, Mai pii oukou, aole hoi e kaua aku: no ka mea, aole owau me oukou; o lukuia mai oukou e ko oukou poe enemi.
\q1 
\v 43 A olelo aku la au ia oukou, aole oukou i hoolohe mai; hoohala oukou i ke kauoha a Iehova, aa aku la oukou, a pii ae la maluna o ka puu.
\q1 
\v 44 A o ka Amora e noho ana ma ua puu la, hele mai lakou e ku e ia oukou, a hahai mai lakou ia oukou, e like me ka ka nalomeli hana ana, a pepehi mai ia oukou ma Seira a hiki mai i Horema.
\q1 
\v 45 A hoi hou mai oukou, a uwe iho la imua o Iehova: aka, aole o Iehova i hoolohe mai i ko oukou leo, aole hoi ia i haliu mai i ka pepeiao ia oukou.
\q1 
\v 46 A noho iho la oukou ma Kadesa i na la he nui, e like me na la a oukou i noho ai.
\c 2
\b
\q1 
\v 1 A LAILA huli ae la kakou, a hele aku la i ka waonahele ma ke ala o ke Kaiula, e like me ka Iehova i kauoha mai ai ia'u; a hoopuni ae la kakou i ka mauna o Seira i na la he nui.
\q1 
\v 2 Olelo mai la o Iehova ia'u, i mai la,
\q1 
\v 3 Ua loihi ko oukou hoopuni ana i keia mauna: e huli ae oukou ma ke kukuluakau.
\q1 
\v 4 A e kauoha aku oe i na kanaka, penei, E hele ana oukou ma ka mokuna o ko oukou poe hoahanau, o na mamo a Esau e noho ana ma Seira; a e makau mai auanei lakou ia oukou: nolaila e malama nui oukou ia oukou iho:
\q1 
\v 5 Mai hakaka oukou me lakou; no ka mea, aole au e haawi aku i kekahi o ko lakou aina no oukou, aole i kekahi kapuwai; no ka mea, ua haawi aku au i ka mauna o Seira i wahi e noho ai no Esau.
\q1 
\v 6 E kuai oukou i ka lakou ai i ke kala, i ai ai oukou; a e kuai hoi oukou i ko lakou wai i ke kala, i inu ai oukou.
\q1 
\v 7 No ka mea, ua hoopomaikai mai o Iehova kou Akua ia oe ma na hana a pau a kou lima; ua ike no ia i kou hele ana ma keia waonahele nui; me oe no o Iehova kou Akua i neia mau makahiki he kanaha; aole oe i nele i kekahi mea.
\b
\q1 
\v 8 A ia kakou i maalo ae mai ko kakou poe hoahanau aku, na mamo a Esau, e noho ana ma Seira, ma ke ala o ka papu mai Elata aku, a mai Ezionagabera, huli ae kakou a hele i ke ala ma ka waonahele o Moaba.
\q1 
\v 9 Olelo mai la o Iehova ia'u, Mai hana ino aku i ko Moaba, aole e ku e ia lakou i ke kaua ana; aole au e haawi i ko lakou aina i wahi e noho ai no oukou; no ka mea, ua haawi aku au ia Ara i wahi e noho ai no na mamo a Lota.
\q1 
\v 10 I ka manawa mamua i noho ai ka poe Emima malaila, he poe nunui a lehulehu, he poe loihi e like me ka poe Anakima;
\q1 
\v 11 Ua manaoia lakou, he poe kanaka nunui e like me ka poe Anakima; aka, ua kapaia lakou e ko Moaba, he poe Emima.
\q1 
\v 12 I ka manawa mamua i noho ai ka poe Horima ma Seira: aka, na na mamo a Esau i hookuke aku lakou, a luku i ua poe la imua o lakou, a noho iho la ma ko lakou la wahi; e like me ka Iseraela i hana aku ai i ka aina o ko lakou wahi i noho ai a Iehova i haawi mai ai no lakou.
\q1 
\v 13 Ano hoi, e ku iluna, a e hele aku ma kela aoao o ke kahawai o Zareda: a hele aku kakou ma kela aoao o ke kahawai o Zareda.
\q1 
\v 14 A o na makahiki o ko kakou hele ana mai Kadesabanea mai, a hiki kakou ma ke kahawai o Zareda, he kanakolu ia a me kumamawalu; a pau ka hanauna a pau o na kanaka koa i ka nalowale iwaena o ka poe kaua, e like me ka Iehova i hoohiki ai ia lakou.
\q1 
\v 15 No ka mea, ku e mai la ka lima o Iehova ia lakou e luku ia lakou mailoko aku o ka poe kaua, a pau lakou i ka make.
\b
\q1 
\v 16 A i ka manawa i pau ai na kanaka koa i ka lukuia, a i ka make iwaena o na kanaka,
\q1 
\v 17 Olelo mai la o Iehova ia'u, i mai la,
\q1 
\v 18 E hele ana oe i ka mokuna o Moaba i Ara i keia la:
\q1 
\v 19 A hiki aku oe a kokoke i na mamo a Amona, mai hana ino aku ia lakou, aole hoi e hakaka aku me lakou: aole au e haawi i wahi e noho ai nou ma ka aina o na mamo a Amona; no ka mea, ua haawi aku au ia i wahi e noho ai no na mamo a Lota.
\q1 
\v 20 (Ua manaoia hoi ia he aina kanaka nunui: o na kanaka nunui i noho ai malaila i ka manawa kahiko, a ua kapaia lakou e ka Amona, he Zamezumima;
\q1 
\v 21 He poe kanaka nunui, a lehulehu, a loihi, e like me na Anakima; aka, na Iehova lakou i luku aku imua o lakou, a hookuke aku lakou ia poe, a noho iho la ma ko lakou wahi:
\q1 
\v 22 E like me kana i hana aku ai no na mamo a Esau e noho ana ma Seira, ia ia i luku ai i ka poe Horima imua o lakou; hookuke aku la lakou ia poe, a noho iho la ma ko lakou wahi, a hiki i keia la:
\q1 
\v 23 A o ko Ava e noho ana ma Hazerima a hiki i Aza, na ko Kapetora, mai Kapetora mai, i luku aku lakou, a noho iho la ma ko lakou la wahi.)
\b
\q1 
\v 24 E ku oukou iluna, e hele aku, a hiki ma keia kapa o ke kahawai o Arenona: aia hoi, ua haawi aku au ia Sihona no ka Amora, ke alii o Hesebona, a me kona aina iloko o kou lima; e hoomaka oe e komo, a e ku e aku ia ia i ke kaua.
\q1 
\v 25 I keia la e hoomaka ai au e kau i ka makau ia oe, a me ka weliweli ia oe, maluna o na lahuikanaka malalo ae o ka lani a pau, ka poe i lohe i kou kaulana ana, a e haalulu lakou, a e pilihua auanei nou.
\b
\q1 
\v 26 A hoouna aku la au i na elele mai ka waonahele o Kedemota aku io Sihona la, ke alii o Hesebona, me ka olelo aloha, i aku la,
\q1 
\v 27 E ae mai oe ia'u e hele au ma kou aina: e hele au ma ke ala loa, aole au e kapae ma ka akau, aole hoi ma ka hema.
\q1 
\v 28 E kuai mai oe i ai na'u no ke kala, i ai iho ai au; a e haawi mai i wai no'u no ke kala, i inu ai hoi au; e hele wawae wale no au;
\q1 
\v 29 (E like me na mamo a Esau, e noho ana ma Seira, a me ko Moaba e noho ana ma Ara i hana mai ai ia'u;) a hiki aku au ma keia kapa o Ioredane, ma ka aina a Iehova ko makou Akua i haawi mai ai ia makou.
\q1 
\v 30 Aka, aole i ae mai o Sihona, ke alii o Hesebona, e hele kakou ma o na la; no ka mea, hoopaakiki mai la o Iehova kou Akua i kona naau, a hooku e oia i kona manao, i hoolilo ai oia ia ia iloko o kou lima, e like me ia i keia la.
\q1 
\v 31 A olelo mai o Iehova ia'u, aia hoi, ua hoomaka iho nei au e hoolilo ia Sihona, a me kona aina ia oe: e komo oe, i lilo ai kona aina ia oe.
\b
\q1 
\v 32 Alaila hele ku e mai la o Sihona ia kakou, oia a me kona poe kanaka a pau, i ke kana ma Iahaza.
\q1 
\v 33 A hoolilo mai o Iehova ko kakou Akua ia ia imua o kakou, a luku aku la kakou ia ia, a me kana mau keiki, a me kona poe kanaka a pau.
\q1 
\v 34 A hoopio aku la kakou i kona mau kulauakauhale a pau, a luku aku i na kanaka o na kulanakauhale a pau, a me na wahine a me na kamalii, aole kakou i hookoe i kekahi.
\q1 
\v 35 O na holoholona wale no ka kakou i la we pio ai na kakou, a me ka waiwai o na kulanakauhale, oia ka kakou i lawe.
\q1 
\v 36 Mai Aroera ma kapa o ke kahawai o Arenona, a me ke kulanakauhale ma ke kahawai a hiki i Gileada, aole kekahi kulanakauhale i lanakila maluna o kakou; na Iehova ko kakou Akua i hoolilo mai na mea a pau ia kakou.
\q1 
\v 37 Aole nae oe i hele ma ka aina o na mamo a Amona, aole hoi ma na wahi o ke kahawai o Iaboka, aole hoi ma na kulanakauhale o na mauna, aole hoi ma kekahi wahi a Iehova ko kakou Akua i papa mai ai ia kakou.
\c 3
\b
\q1 
\v 1 A LAILA haliu ae la kakou, a pii aku la ma ke alanui o Basana; a hele mai la o Oga ke alii o Basana e ku e ia kakou, oia a me kona poe kanaka a pau i ke kaua ma Ederei.
\q1 
\v 2 Olelo mai o Iehova ia'u, Mai makau ia ia: no ka mea, e hoolilo ana au ia ia, a me kona poe kanaka a pau, a me kona aina, iloko o kou lima; a e hana aku oe ia ia e like me kau i hana aku ai ia Sihona i ke alii o ka Anion, ka mea i noho ma Hesebona.
\q1 
\v 3 A hoolilo mai hoi o Iehova ko kakou Akua ia Oga ke alii o Basana, a me kona poe kanaka a pau iloko o ko kakou lima: a luku aku la kakou ia ia, aole i hookoeia kekahi mea nona.
\q1 
\v 4 A lawe iho la kakou i kona mau kulanakauhale a pau i kela manawa; aole i koe ko kulanakauhale i lawe ole ia e kakou, he kanaono kulanakauhale, na wahi a pau o Aregoba, ke aupuni o Oga ma Basana,
\q1 
\v 5 A ua paa neia mau kulanakauhale a pau i na pa pohaku kiekie, a me na ipuka a me na kaola; a he nui loa na kulanakauhale e ae, aole i paa i ka pa pohaku.
\q1 
\v 6 A luku loa aku la kakou ia lakou, e like me kakou i luku aku ai ia Sihona ke alii o Hesebona, luku aku la i na kanaka, i na wahine me na kamalii o na kulanakauhale a pau.
\q1 
\v 7 Aka, o na holoholona a pau a me ka waiwai pio o na kulanakauhale, lawe mai la kakou ia mea no kakou.
\q1 
\v 8 A lawe aku la kakou i kela manawa, mailoko mai o na lima o ua mau alii elua la o ka Amora, i ka aina ma keia aoao o Ioredane, mai ke kahawai o Arenona a hiki i ka mauna o Heremona;
\q1 
\v 9 (Kapa aku la ko Sidona i Heremona, o Siriona; a kapa aku la ka Amora ia, o Senira;)
\q1 
\v 10 O na kulanakauhale a pau o ka papu, a me Gileada a pau, a me Basana a pau, a hiki i Saleka a me Ederei, na kulanakauhale o ke aupuni o Oga i Basana.
\q1 
\v 11 No ka mea, o Oga ke alii o Basana wale no i koe o na kanaka nunui; aia hoi, o kona wahi moe, he wahi moe hao: aole anei ia ma Rabata no na mamo a Amona? Eiwa no kubita o kona loihi, a eha kubita o kona laula, ma ka ke kanaka kubita.
\b
\q1 
\v 12 A o keia aina i lilo mai ai ia kakou i kela manawa, mai Aroera ma ke kahawai o Arenona, a me ka hapalua o ka mauna o Gileada, a me ko laila mau kulanakauhale, o ka'u ia i haawi aku ai no ka Reubena a me ka Gada.
\q1 
\v 13 A o ke koena o Gileada a me Basana a pau, ke aupuni o Oga, o ka'u ia i haawi aku ai no ka ohana hapa a Manase: o ka aina a pau o Aregoba a me Basana a pau, oia ka i kapaia, he aina o na kanaka nunui.
\q1 
\v 14 Lawe aku la o Iaira ke keiki a Manase i ka aina a pau o Aregoba a hiki i ka mokuna o Gesuri, a me Maakati; a kapa aku la ia lakou ma kona inoa iho, o Basanahavotaiaira, a hiki i keia la.
\q1 
\v 15 A haawi aku la au ia Gileada no Makira.
\q1 
\v 16 A haawi aku au no ka Reubena a me ka Gada, mai Gileada a hiki i ke kahawai o Arenona, iwaena o ke awawa, ka mokuna a hiki i ke kahawai o laboka, oia hoi ka mokuna o na mamo a Amoua.
\q1 
\v 17 O ka papu hoi a me Ioredane, a o ka mokuna, mai Kinereta a hiki i ke kai o ka papu, oia ka moanakai ma ke kumu o Pisega ma ka hikina.
\b
\q1 
\v 18 Kauoha aku la au ia oukou i kela manawa, i aku la, Ua haawi mai o Iehova ko oukou Akua i keia aina ia oukou e lilo no oukou: o oukou ka poe koa ke hele me ke kahiko i ke kaua imua o ko oukou poe hoahanau, o na mamo a Iseraela.
\q1 
\v 19 Aka, o ka oukou wahine a me ka oukou kamalii, a me na holoholona a oukou, (ua ike au, he nui na holoholona a oukou,) e noho lakou ma na kulanakauhale a'u i haawi aku ai no oukou:
\q1 
\v 20 A i ka manawa a Iehova e hoomaha mai ai i ko oukou poe hoahanau, e like me ia oukou. a lilo no lakou ka aina a Iehova ko oukou Akua i haawi mai ai ia lakou ma kela aoao o Ioredane; alaila e hoi hou mai oukou, o kela kanaka keia kanaka i kona aina a'u i haawi aku ai no oukou.
\b
\q1 
\v 21 Kauoha aku la hoi au ia Iosua i kela manawa, i aku la, Ua ike kou maka i na mea a pau a Iehova ko oukou Akua i hana mai ai i keia mau alii elua: pela o Iehova e hana aku ai i na aupuni a pau au e hele ai.
\q1 
\v 22 Mai makau oukou ia lakou; no ka mea, o Iehova ko oukou Akua, oia ke kaua mai no oukou.
\b
\q1 
\v 23 A noi aku la au ia Iehova i kela manawa, i aku la,
\q1 
\v 24 E Iehova ke Akua, ua hoomaka ae nei oe e hoike i kau kauwa i kou mana, a me kou lima ikaika: no ka mea, owai ke Akua iloko o ka lani, a me ka honua, e hiki ia ia ke hana e like me kau mau hana, a me kou ikaika?
\q1 
\v 25 Ke noi aku nei au, e ae mai oe ia'u e hele aku au e ike i ka aina maikai ma kela aoao o Ioredane, i kela kuahiwi maikai o Lebanona.
\q1 
\v 26 Aka, ua huhu mai o Iehova ia'u no oukou, aole i hoolohe mai ia'u: a i mai la o Iehova ia'u, Ua oki; mai olelo hou mai oe ia'u i keia mea.
\q1 
\v 27 E pii aku oe maluna pono o Pisega, a e nana aku kou maka ma ke komohana, a ma ke kukuluakau, a ma ke kukuluhema, a ma ka hikina, a e ike me kou mau maka; no ka mea, aole oe e hele ma kela kapa o Ioredane nei.
\q1 
\v 28 Aka, e kauoha oe ia Iosua, e hoeueu aku, a e hooikaika aku ia ia; no ka mea, oia ke hele aku imua o keia poe kanaka, a nana no lakou e hoonoho ma ka aina au i ike ai.
\q1 
\v 29 A noho iho la kakou ma ke awawa e ku pono ana i Bete-peora.
\c 4
\b
\q1 
\v 1 A NO hoi, e hoolohe, e ka Iseraela, i na kanawai a me na olelo kupaa a'u e ao aku nei ia oukou, e malama, i ola oukou, i komo hoi oukou, a noho ma ka aina a Iehova ke Akua o ko oukou poe kupuna e haawi mai ai no oukou.
\q1 
\v 2 Mai hoopili mai oukou i kekahi olelo me ka mea a'u e kauoha aku nei ia oukou, aole hoi oukou e hooemi iho ia, i malama ai oukou i na kauoha a Iehova ko oukou Akua a'u e kauoha aku nei ia oukou.
\q1 
\v 3 Ua ike ko oukou maka i ka mea a Iehova i hana mai ai no Baala-peora; no ka mea, o na kanaka a pau i hahai mamuli o Baala-peora, na Iehova kou Akua lakou i luku aku mai o oukou aku.
\q1 
\v 4 Aka, o oukou, ka poe i pili aku ia Iehova ko oukou Akua, ke ola nei no oukou a pau i keia la.
\q1 
\v 5 Aia hoi, ua ao aku au ia oukou i na kanawai a me na olelo kupaa, e like me ka Iehova ko'u Akua i kauoha mai ai ia'u, e malama oukou pela ma ka aina a oukou e hele aku ai e noho.
\q1 
\v 6 E malama hoi oukou, a e hana aku; no ka mea, o ko oukou naauao keia, a me ko oukou ike imua o na lahuikanaka, ka poe e lohe i keia mau kanawai a pau, a e i ae lakou, He oiaio, o keia lahuikanaka nui, he poe kanaka naauao a me ka ike.
\q1 
\v 7 No ka mea, owai la ka lahuikanaka nui, ia lakou ke Akua e hookokoke ana ia lakou, e like me Iehova ko kakou Akua, ma na mea a pau a kakou i kahea aku ai ia ia?
\q1 
\v 8 A owai hoi ka lahuikanaka nui, ia ia na kanawai, a me na olelo kupaa ma ka pono e like me keia kanawai a pau a'u e waiho nei imua o oukou i keia la.
\b
\q1 
\v 9 E makaala ia oe iho, a e malama nui hoi i kou naau, o hoopoina auanei oe i na mea a kou maka i ike ai, a o nalowale auanei ia mea i kou naau i na la a pau o kou ola ana; aka, e ao aku ia mau mea i kau mau keiki, a me kau mau moopuna;
\q1 
\v 10 I ka la au i ku ai imua o Iehova kou Akua ma Horeba, i ka Iehova olelo ana mai ia'u, E houluulu oe i na kanaka imua o'u, a e ao aku au ia lakou e hoolohe i ka'u mau olelo, i aoia'i lakou e makau ia'u i na la a pau o ko lakou noho ana ma ka honua, a i ao aku ai lakou i ka lakou poe keiki.
\q1 
\v 11 Hele kokoke mai oukou, a ku ae la malalo o ka mauna; a ua wela ka mauna i ke alii, a iwaena o ka lani me ka poeleele, me ke ao, a me ka pouli nui.
\q1 
\v 12 A olelo mai o Iehova ia oukou maiwaena mai o ke ahi: a lohe oukou i ka leo o na olelo, aole nae oukou i ike aku i ke ano, o ka leo wale no.
\q1 
\v 13 Hai mai la no oia ia oukou i ka berita ana i kauoha mai ai ia oukou e malama, oia na kanawai he umi; a kakau iho la no oia ia mau mea ma na papapohaku elua,
\b
\q1 
\v 14 A kauoha mai o Iehova ia'u i kela manawa e ao aku ia oukou i na kanawai a me na olelo kupaa, e malama oukou ia mau mea ma ka aina a oukou e hele ai a noho.
\b
\q1 
\v 15 E malama nui oukou ia oukou iho; no ka mea, aole oukou i ike i kekahi ano kii i ka la a Iehova i olelo mai ai ia oukou ma Horeba mailoko mai o ke ahi;
\q1 
\v 16 O hana hewa auanei, a hana aku oukou i kii kalaiia no oukou, ma ka like ana me kekahi mea, o ke kane, a o ka wahine paha,
\q1 
\v 17 Ma ka like ana me kekahi holoholona ma ka honua, ma ka like ana me kekahi manu e lele ana i ke ao;
\q1 
\v 18 Ma ka like ana me kekahi mea e kolo ana ma ka honua, ma ka like ana me kekahi ia maloko o ka wai malalo ae o ka honua:
\q1 
\v 19 A o leha ae auanei kou maka ma ka lani, a ike aku oe i ka la, a me ka mahina, a me na hoku, i na mea a pau o ka lani, a e koiia oe e hoomana aku ia mau mea, a e malama ia lakou, i na mea a Iehova kou Akua i hana'i no na lahuikanaka a pau malalo ae o ka lani.
\q1 
\v 20 Aka, ua lawe mai o Iehova ia oukou, a ua alakai hoi ia oukou mailoko mai o ke kapuahihao, mai Aigupita mai, e lilo oukou i poe kanaka hooilina nona, e like me oukou i keia la.
\b
\q1 
\v 21 A huhu mai o Iehova ia'u no oukou, a hoohiki iho, aole au e hele ma kela kapa o Ioredane, aole hoi au e komo iloko o kela aina maikai a Iehova kou Akua i hooili mai ai no oukou:
\q1 
\v 22 No ka mea, e make no wau ma keia aina, aole au e hele ma kela kapa o Ioredane: aka, e hele no oukou ma kela aoao, a e lilo kela aina maikai no oukou.
\q1 
\v 23 E malama pono ia oukou iho, o poina ia oukou ka berita a Iehova i hana mai ai me oukou, a hana oukou i kii kalaiia no oukou, ma ka like ana me kekahi mea a Iehova kou Akua i papa mai ai ia oe.
\q1 
\v 24 No ka mea, o Iehova kou Akua, he ahi ia e hoopau ana, he Akua lili.
\b
\q1 
\v 25 A loaa ia oukou na keiki a me na mamo, a loihi ko oukou noho ana ma ka aina, a e hana hewa oukou, a e hana oukou i kii kalaiia, ma ke ano o kekahi mea, a hana ino hoi imua o na maka o Iehova, e hoonaukiuki ia ia;
\q1 
\v 26 Ke hai aku nei au i keia la, he ike maka ka lani a me ka honua ia oukou, e make koke ana oukou, mai ka aina aku a oukou e hele aku ma kela kapa o Ioredane e noho ai; aole e noho loihi oukou malaila, aka, e luku loa ia aku oukou.
\q1 
\v 27 A na Iehova oukou e hoopuehu aku iwaena o na lahuikanaka, a e waihoia oukou, he poe uuku iwaena o ko na aina e, kahi a Iehova e kai aku ai ia oukou.
\q1 
\v 28 A malaila oukou e malama ai i na akua i hanaia e na lima o kanaka, he laau, he pohaku, ka mea ike ole aole hoi e lohe, aole hoi e ai, aole hoi e honi.
\q1 
\v 29 Aka, ina ma ia wahi oe e imi ai ia Iehova kou Akua, e loaa ia oe, ke imi oe ia ia me kou naau a pau, a me kou uhane a pau.
\q1 
\v 30 A loaa ia oe ka popilikia, a hiki mai keia mau mea a pau maluna ou i na la mahope, a i huli mai oe ia Iehova kou Akua, a hoolohe i kona leo,
\q1 
\v 31 (No ka mea, o Iehova kou Akua, he Akua aloha,) aole ia e haalele mai ia oe, aole e luku mai ia oe, aole hoi ia e hoopoina i ka berita o kou mau kupuna ana i hoohiki ai ia lakou.
\b
\q1 
\v 32 Ano e ninau aku oe i na la i hala mahope, i ka wa mamua ou, a mai ka manawa mai a ke Akua i hana'i ke kanaka ma ka honua, a mai kela aoao o ka lani a hiki i keia aoao o ka lani, auhea ae nei ka mea like me keia mea nui, auhea ka mea i loheia e like ai me ia?
\q1 
\v 33 Owai la ka poe kanaka i lohe i ka leo o ke Akua e olelo ana, mailoko mai o ke ahi, e like me kou lohe ana, a ola?
\q1 
\v 34 Ua hoao anei ke Akua e hele a e lawe i lahuikanaka nona maiwaena mai o kekahi lahuikanaka, ma na hoao ana, a ma na hoailona, a ma na mea kupanaha, a ma ke kaua, a ma ka lima ikaika, a ma ka lima kakauha, a ma na mea weliweli nui, e like me na mea a pau a Iehova ko oukou Akua i hana mai ai no oukou ma Aigupita imua o kou maka?
\q1 
\v 35 Ua hoikeia ia mea ia oe, i ike ai oe, o Iehova, oia ke Akua, aohe mea e ae, oia wale no.
\q1 
\v 36 Oia no ka mea i lohe ai oe i kona leo mai ka lani mai, i ao ai oia ia oe; a ma ka honua, i hoike mai ia ia oe i kona ahi nui; a ua lohe oe i kana mau huaolelo mailoko mai o ke ahi.
\q1 
\v 37 A no kona aloha i na kupuna ou, oia ka mea i wae mai ai ia i ka lakou poe mamo mahope o lakou, a lawe mai oia ia oe imua ona me kona mana nui mai Aigupita mai;
\q1 
\v 38 E hookuke aku i na lahuikanaka mai kou alo aku, i ka poe ua oi aku ko lakou nui, a me ko lakou ikaika i kou, e hookomo ia oe, a e hoolilo i ko lakou aina nou, e like me ia i keia la.
\q1 
\v 39 E ike hoi oe i keia la, a e noonoo maloko o kou naau, o Iehova, oia ke Akua ma ka lani iluna, a ma ka honua ilalo, aole e ae.
\q1 
\v 40 E malama hoi oe i kona mau kanawai a me kana mau kauoha a'u e kauoha aku nei ia oe i keia la, i pomaikai ai oe, a me kau mau keiki mahope ou, a i hooloihi ai oe i na la ma ka aina a Iehova kou Akua i haawi mai ai nou i na la a pau loa.
\b
\q1 
\v 41 Alaila hookaawale ae la o Mose i na kulanakauhale ekolu ma keia aoao o Ioredane ma ka hiki ana o ka la;
\q1 
\v 42 I holo ai ka pepehi kanaka malaila, ka mea i pepehi i kona hoalauna me ka ike ole, aole i inaina aku ia ia mamua; a i kona holo ana i kekahi o keia mau kulanakauhale, e ola ia:
\q1 
\v 43 O Bezera ma ka waonahele i ka aina papu o ka Reubena; a o Ramota ma Gileada o ka Gada; a o Golana ma Basana o ka Manase.
\b
\q1 
\v 44 A o keia ke kanawai a Mose i waiho ai imua o na mamo a Iseraela:
\q1 
\v 45 Oia na kauoha a me na kanawai, a me na olelo kupaa a Mose i olelo mai ai i na mamo a Iseraela, mahope o ka lakou hele ana mai Aigupita mai;
\q1 
\v 46 Ma keia aoao o Ioredane, ma ke awawa e ku pono ana i Betepeora, i ka aina o Sihona, ke alii o ka Amora ka mea i noho ma Hesebona, ka mea a Mose a me na mamo a Iseraela i pepehi ai, mahope o ka puka ana, mai Aigupita mai:
\q1 
\v 47 A lilo kona aina ia lakou, a me ka aina o Oga, ke alii o Basana, na'lii elua o ka Amora, ma keia aoao o Ioredane ma ka hiki ana o ka la:
\q1 
\v 48 Mai Aroera, ma ke kae o ke kahawai o Arenona, a i ka mauna o Ziona, oia hoi o Heremona,
\q1 
\v 49 A o ka papu a pau ma keia aoao o Ioredane ma ka hikina, a hiki i ke kai o ka papu, o kahi haahaa ma ke kumu o Pisega,
\c 5
\b
\q1 
\v 1 KAHEA aku la o Mose i ka Iseraela a pau, i aku la ia lakou, E hoolohe, e ka Iseraela, i na kanawai, a me na olelo kupaa a'u e olelo aku nei iloko o ko oukou pepeiao i keia la, i ao ai oukou ia mea, a e malama pono oukou e hana.
\q1 
\v 2 O Iehova ko kakou Akua i hana mai i berita me kakou ma Horeba.
\q1 
\v 3 Aole i hana mai o Iehova i keia berita me ko kakou mau makua, aka, me kakou no; me kakou, ka poe a pau e ola ana maanei i keia la.
\q1 
\v 4 Kamailio o Iehova me oukou ma ka mauna, he maka no he maka, mailoko mai o ke ahi,
\q1 
\v 5 (Ku ae la au mawaena o Iehova a o oukou i kela manawa, e hoike aku ia oukou i ka olelo a Iehova; no ka mea, ua makau oukou i ke ahi, aole i pii oukou i ka mauna;) i mai la,
\b
\q1 
\v 6 Owau no Iehova, o kou Akua, ka mea nana oe i lawe mai nei mai ka aina o Aigupita mai, mailoko mai hoi o ka hale hooluhi.
\b
\q1 
\v 7 Aole ou akua e ae imua o ko'u alo.
\b
\q1 
\v 8 Mai hana oe i kiikalaiia nou, i kekahi like ana me ko ka lani iluna, a me ko ka honua ilalo, a me koloko o ka wai malalo i ka honua;
\q1 
\v 9 Mai kulou oe ilalo ia lakou, aole hoi e malama ia lakou; no ka mea, owau no Iehova o kou Akua, he Akua lili, e hoopai ana i ka hala o na makua i na keiki a i ke kuakahi, a i ke kualua o ka poe inaina mai ia'u,
\q1 
\v 10 E aloha ana hoi i na tausani o ka poe aloha mai ia'u, a malama mai hoi i ka'u mau kauoha.
\b
\q1 
\v 11 Mai hoohiki ino oe i ka inoa o Iehova o kou Akua: no ka mea, aole e apono o Iehova i ka mea e hoohiki mo i kona inoa.
\b
\q1 
\v 12 E hoomanao i ka la Sabati e hoano ia, e like me ka Iehova kou Akua i kauoha mai ai ia oe.
\q1 
\v 13 I na la eono e hana'i oe i kau hana a pau;
\q1 
\v 14 Aka, o ka hiku o ka la, he Sabati ia no Iehova no kou Akua, aole loa oe e hana, aole oe, aole hoi kou kaikamahine, aole hoi kau kauwakane, aole hoi kau kauwawahine, aole kou bipikane, aole hoi kou hokikane, aole hoi kekahi holoholona ou, aole hoi kou kanaka e maloko o kou mau ipuka; i hoomaha'i kau kauwakane, a me kau kauwawahine e like me oe.
\q1 
\v 15 E hoomanao hoi oe, he kauwa no oe ma ka aina o Aigupita, a na Iehova na kou Akua oe i lawe mai nei mailaila mai, me ka lima ikaika, a me ka lima kakauha; no ia mea, i kauoha mai ai o Iehova kou Akua ia oe e malama i ka la Sabati.
\b
\q1 
\v 16 E hoomaikai oe i kou makuakane a me kou makuwahine, e like me ka Iehova kou Akua i kauoha mai ai ia oe; i loihi ai kou mau la, a i pomaikai ai hoi oe ma ka aina a Iehova kou Akua i haawi mai ai ia oe.
\b
\q1 
\v 17 Mai pepehi kanaka oe.
\b
\q1 
\v 18 Mai moe kolohe oe.
\b
\q1 
\v 19 Mai aihue oe.
\b
\q1 
\v 20 Mai hoike wahahee oe e hewa'i kou hoalauna.
\b
\q1 
\v 21 Mai kuko wale i ka wahine a kou hoalauna, aole hoi oe e kuko i ka hale o kou hoalauna, i kana mahinaai, aole i kana kauwakane, aole hoi i kana bipikane, aole hoi i kona hokikane, aole hoi i kekahi mea a kou hoalauna.
\b
\q1 
\v 22 Oia na olelo a Iehova i olelo mai ai i ko oukou ahakanaka a pau, ma ka mauna, mailoko mai o ke ahi, a me ke ao, a me ka pouli paapu, me ka leo nui, a hooki ae la: a kakau iho la ia ia mau mea ma na papapohaku elua, a haawi mai ia'u.
\q1 
\v 23 A ia oukou i lohe ai i ka leo mailoko mai o ka pouli, (no ka mea, na wela ka mauna i ke ahi,) hookokoke mai oukou ia'u, o na luna a pau o ko oukou mau ohana, a me ka poe lunakahiko;
\q1 
\v 24 I mai la oukou, Aia hoi, ua hoike mai o Iehova ia makou i kona nani a me kona mana, a ua lohe makou i kona leo mailoko mai o ke ahi; a ua ike hoi makou i keia la i ka ke Akua olelo pu ana me kanaka, a ola ia.
\q1 
\v 25 Ano hoi, no ke aha la makou e make ai? no ka mea, e pau auanei makou i keia ahi nui. Ina paha makou e lohe hou i ka leo o Iehova ko makou Akua, alaila e make makou.
\q1 
\v 26 Owai la o na io a pau i lohe i ka leo o ke Akua ola e olelo mai ana mailoko mai o ke ahi, e like me makou, a ola ia?
\q1 
\v 27 E hookokoke aku oe, a hoolohe i na mea a pau a Iehova ko makou Akua e olelo mai ai; a e hai mai oe ia makou i na mea a pau a Iehova ko makou Akua e olelo mai ai ia oe; a e hoolohe makou, a e hana aku hoi.
\b
\q1 
\v 28 A lohe no Iehova i ka leo o ka oukou olelo a oukou i olelo mai ai ia'u; a i mai la o Iehova ia'u, Ua lohe au i ka leo o ka olelo a keia poe kanaka i olelo mai ai ia oe; a ua pono na mea a pau a lakou i olelo mai ai.
\q1 
\v 29 Ina paha i loaa ia lakou keia naau, e makau mai ia'u, a e malama mau hoi i ka'u mau kauoha a pau, i pomaikai mau ai lakou, a me ka lakou poe keiki!
\q1 
\v 30 E hele oe, e olelo aku ia lakou, E hoi hou aku oukou i ko oukou mau halelewa.
\q1 
\v 31 Aka, o oe, e ku oe maanei me a'u, a e olelo aku au ia oe i na kauoha a pau, a me na kanawai, a me na olelo kupaa, na mea au e ao aku ai ia lakou, e malama lakou ma ka aina a'u i haawi aku ai no lakou.
\q1 
\v 32 E malama pono hoi oukou, e hana e like me ka Iehova ko oukou Akua i kauoha mai ai ia oukou; aole oukou e huli ae ma ka akau, aole hoi ma ka hema.
\q1 
\v 33 E hele oukou ma na aoao a pau a Iehova ko oukou Akua i kauoha mai ai ia oukou i ola'i oukou, a i pomaikai ai oukou, i loihi ai hoi ko oukou mau la ma ka aina e ili mai ana no oukou.
\c 6
\b
\q1 
\v 1 EIA na kauoha, na kanawai, a me na olelo kupaa, a Iehova ko oukou Akua i kauoha mai ai e ao aku ia oukou, i malama aku ai oukou ma ka aina e hele aku nei oukou e noho:
\q1 
\v 2 I mea e makau aku ai oe ia Iehova i kou Akua, e malama i kona mau kanawai a pau, a me kana mau kauoha a'u e kauoha aku nei ia oe; o oe, a me kau keiki, a me kau moopuna, i na la a pau o kou ola'na, i hooloihiia'i kou mau la.
\b
\q1 
\v 3 E hoolohe hoi oe, e ka Iseraela, a hoomanao e malama hoi, i pomaikai ai oe, i mahuahua loa ai noi oukou, ma ka aina e kahe ana o ka waiu a me ka meli, e like me ka Iehova ke Akua o kou poe kupuna i olelo mai ai ia oe.
\b
\q1 
\v 4 E hoolohe mai, e ka Iseraela; O Iehova ko kakou Akua, hookahi no Iehova.
\q1 
\v 5 E aloha aku oe ia Iehova i kou Akua me kou naau a pau, me kou uhane a pau, a me kou ikaika a pau.
\q1 
\v 6 O keia mau olelo a'u e kauoha aku nei ia oe i keia la, e waiho no ia maloko o kou naau;
\q1 
\v 7 A e ao pono aku oe ia mau mea i au mau keiki, a e kamailio aku ia mau mea i kou noho ana ma kou hale, a i kou hele ana ma ke ala, i kou moe ana ilalo, a me kou ala ana iluna.
\q1 
\v 8 A e nakii oe ia mau mea i hoailona ma kou lima, a e lilo ia i mea e hoomanao ai mawaena o kou mau maka.
\q1 
\v 9 A e kakau oe ia mau mea ma na lapauila o kou puka hale, a me na puka pa ou.
\b
\q1 
\v 10 A i ka manawa a Iehova kou Akua i kai aku ai ia oe i ka aina ana i hoohiki mai ai i kou mau kupuna, ia Aberahama, ia Isaaka, a me Iakoba, e haawi mai ia oe i na kulanakauhale nui a maikai, aole nau i kukulu,
\q1 
\v 11 A me na hale piha i ka waiwai, aole nau i hoolako, a me na luawai i eliia, aole nau i eil, i na pawaina a me na laau oliva, aole nau i kanu; aia ai iho oe a maona;
\q1 
\v 12 Alaila e malama ia oe iho, o hoopoina oe ia Iehova, nana oe i lawe mai ka aina o Aigupita mai, mailoko mai hoi o ka hale hooluhi.
\q1 
\v 13 E makau oe ia Iehova i kou Akua, e malama ia ia, a e hoohiki oe ma kona inoa.
\q1 
\v 14 Mai hele aku oukou mamuli o na akua e, o na akua o na kanaka e noho ana a puni o oukou;
\q1 
\v 15 O hoaaia mai auanei ka inaina o Iehova kou Akua ia oe, a lukuia mai oe mai ke alo aku o ka honua: (no ka mea, o Iehova kou Akua, he Akua lili ia iwaena o oukou.)
\b
\q1 
\v 16 Mai aa aku oukou ia Iehova i ko oukou Akua, e like me ko oukou aa ana ma Masa.
\q1 
\v 17 E malama pono oukou i na kauoha a Iehova ko oukou Akua, me kana mau oihana, a me kona mau kanawai, ana i kauoha mai ai ia oe.
\q1 
\v 18 E hana oe i ka pono a me ka maikai imua i ke alo o Iehova; i pomaikai ai oe, i komo ai hoi oe a noho ma ka aina maikai a Iehova i hoohiki mai ai i ou mau kupuna;
\q1 
\v 19 I hookuke aku ai i kou poe enemi a pau mai kou alo aku, e like me ka Iehova i olelo mai ai.
\b
\q1 
\v 20 Aia ninau mai kau keiki ia oe ma ia hope aku, i ka i ana mai, Heaha na oihana, na kanawai, a me na olelo kupaa a Iehova ko kakou Akua i kauoha mai ai ia oukou?
\q1 
\v 21 Alaila oe e olelo aku ai i kau keiki, He poe kauwa hooluhi makou a Parao i Aigupita, na Iehova makou i kai ae mai Aigupita mai me ka lima ikaika.
\q1 
\v 22 Ua hoike mai o Iehova i na hoailona, a me na mea kupanaha, he nui a he ino maluna o Aigupita, maluna o Parao, a maluna hoi o kona mau ohua a pau, imua o ko makou maka;
\q1 
\v 23 A kai mai la oia ia makou mai ia wahi mai, i hookomo mai ai ia ia makou iloko, e haawi ia makou i ka aina ana i hoohiki ai i ko makou poe kupuna.
\q1 
\v 24 Kauoha mai la o Iehova ia makou e malama i keia mau kanawai a pau, e makau ia Iehova ko makou Akua, i pomaikai mau ai makou, i malama mai ai hoi oia ia makou e ola ana, e like me ia i keia la.
\q1 
\v 25 A e lilo ia i pono no kakou, ke hoomanao kakou e malama i neia mau kauoha imua o Iehova ko kakou Akua, e like me ia i kauoha mai ai ia kakou.
\c 7
\b
\q1 
\v 1 A IA kai aku o Iehova kou Akua ia oe i ka aina au e hele aku nei e noho ilaila, a hookuke aku ia i na lahuikanaka, he nui mamua ou, i ka Heta, i ka Giregasa, me ka Amora, me ka Kanaana, me ka Periza, me ka Heva, a me ka Iebusa, i ehiku lahuikanaka, ua oi aku ko lakou nui a me ko lakou ikaika i kou;
\q1 
\v 2 A hoolilo mai o Iehova kou Akua ia lakou imua ou; alaila e pepehi aku oe ia lakou, a pau lakou i ka make; mai hookuikahi oe me lakou; a mai aloha aku ia lakou:
\q1 
\v 3 Mai hoopalau hoi me lakou; mai haawi i kau kaikamahine na kana keikikane; mai lawe oe i kana kaikamahine na kau keikikane.
\q1 
\v 4 No ka mea, e hoohuli ae lakou i kau keiki, i ole ia e hahai mai ia'u, i malama aku lakou i na akua e: pela e hoaaia mai ai ka inaina o Iehova ia oukou, a e luku koke mai ia oe.
\q1 
\v 5 Penei oukou hana aku ai ia lakou; e hoohiolo oukou i ko lakou mau kuahu, e wawahi iho i ko lakou poe kii, e kua ilalo i ko lakou mau kii o Asetarota, a e puhi aku i ko lakou mau kiikalaiia i ke ahi.
\b
\q1 
\v 6 No ka mea, he poe kanaka laa oukou no Iehova kou Akua: na Iehova na kou Akua i wae mai ia oukou, i poe kanaka ponoi nona, mamua o na kanaka a pau maluna o ka honua.
\q1 
\v 7 Aole o Iehova i aloha mai ia oukou, a i wae mai ia oukou, no ka oi o ko oukou nui i ko na kanaka e ae a pau; no ka mea, he poe uuku oukou i na kanaka a pau:
\q1 
\v 8 Aka, no ke aloha o Iehova ia oukou, a no kona malama i ka hoohiki ana i hoohiki ai i ko oukou poe kupuna; nolaila i kai mai nei o Iehova ia oukou me ka lima ikaika, a e hoopakele ia oukou mai ka hale hooluhi mai, mailoko mai o ka lima o Parao, ke alii o Aigupita.
\q1 
\v 9 E ike hoi oe, o Iehova kou Akua, oia no ke Akua, he Akua oiaio, e malama ana i ka berita, a i ke aloha no ka poe i aloha aku ia ia, a malama hoi i kana mau kauoha, a hiki i ke tausani o na hanauna:
\q1 
\v 10 A e hoopai koke ana hoi i ka poe inaina ia ia, e luku ia lakou, aole ia e lohi i ka mea inaina ia ia, e hoopai koke ana no ia ia.
\q1 
\v 11 Nolaila, e malama oe i na kauoha a me na kanawai, a me na olelo kupaa a'u e kauoha aku nei ia oe i keia la, a e hana hoi ia mea.
\b
\q1 
\v 12 No ia hoi, ina e hoolohe oukou i keia mau olelo kupaa, a e malama, a e hana hoi ia mau mea, alaila e malama mai o Iehova kou Akua i ka berita a me ke aloha nou, ana i hoohiki ai i kou poe kupuna.
\q1 
\v 13 A e aloha mai ia ia oe a e hoopomaikai mai ia oe, a e hoomahuahua mai ia oe: e hoopomaikai mai hoi ia i ka hua o kou opu, a me ka hua o kou aina, i kau palaoa a me kou waina, a me kou aila, a me ka hanau ana o kou poe bipi, a me kau poe hipa, ma ka aina ana i hoohiki ai i kou mau kupuna e haawi mai ia oe.
\q1 
\v 14 E oi aku kou hoopomaikaiia mamua o ko ua kanaka a pau: aole he kane keiki ole, aole he wahine pa iwaena o oukou, aole hoi iwaena o na holoholona a oukou.
\q1 
\v 15 A e lawe aku o Iehova i na mai a pau mai ou aku nei, aole hoi ia e kau i kekahi mai ahulau o Aigupita maluna iho ou, au i ike ai; aka, e kau aku kela ia mea maluna iho o ka poe a pau e inaina mai ia oe.
\q1 
\v 16 A e hoopau aku oe i na kanaka a pau a Iehova kou Akua e hoolilo mai nou; mai minamina aku kou maka ia lakou, mai malama hoi oe i ko lakou mau akua; no ka mea, e lilo ia i mea hihia nou.
\b
\q1 
\v 17 Ina paha e i iho oe maloko o kou naau, Ua oi aku ka nui o keia mau lahuikanaka i ko'u; pehea la e hiki ia'u ke kipaku aku ia lakou?
\q1 
\v 18 Mai makau oe ia lakou; e hoomanao pono oe i ka mea a Iehova kou Akua i hana'i ia Parao, a me ko Aigupita a pau:
\q1 
\v 19 I na hoao nui a kou maka i ike ai, a me na hoailona, a me na mea kupanaha, a me ka lima ikaika, a me ka lima kakauha a Iehova kou Akua i lawe mai nei ia oe; pela no o Iehova kou Akua e hana aku ai i na kanaka a pau au e makau nei.
\q1 
\v 20 A e hoouna aku hoi o Iehova kou Akua i ka nalohopeeha iwaena o lakou, a pau lakou i ka lukuia, ka poe i waihoia, a me ka poe i pee mai ou aku la.
\q1 
\v 21 Mai makau oe ia lakou; no ka mea, iwaena ou o Iehova kou Akua, he Akua nui, hooweliweli.
\q1 
\v 22 A e kipaku liilii aku o Iehova kou Akua i kela mau luhuikanaka mamua ou: mai luku koke aku ia lakou a pau, o nui mai auanei na holoholona e alo mai ia oe.
\q1 
\v 23 A o Iehova kou Akua e hoolilo mai ia lakou imua ou, a e luku aku ia lakou me ka luku nui, a pau lakou i ka make.
\q1 
\v 24 A e hoolilo mai ia i ko lakou mau alii iloko o kou lima, a e hokai oe i ko lakou inoa malalo iho o ka lani; aole e hiki i kekahi kanaka ke ku imua ou, a pau lakou i ka lukuia e oe.
\q1 
\v 25 O na kii o ko lakou mau akua e puhi oukou i ke ahi; mai kuko aku oe i ke kala a i ke gula maluna o ia mea, aole hoi e lawe ia mea nau, o hihia auanei oe ilaila; no ka mea, he mea hoowahawahaia e Iehova kou Akua.
\q1 
\v 26 Aole hoi e lawe oe maloko o kou hale i ka mea hoowahawahaia, o lilo auanei oe i mea laa e like me ia; e hoowahawaha loa aku oe ia mea, a e hoopailua loa aku oe ia mea; no ka mea, he mea laa ia.
\c 8
\b
\q1 
\v 1 O NA kauoha a pau a'u e kauoha aku nei ia oe i keia la, o ka oukou ia e hoomanao ai e hana, i ola oukou, i mahuahua ae, i komo aku oukou, a noho ma ka aina a Iehova i hoohiki ai i ko oukou mau kupuna.
\q1 
\v 2 E hoomanao hoi oe i ke ala a pau a Iehova kou Akua i kai mai ai ia oe ma ka waonahele i keia mau makahiki he kanaha, e hoohaahaa iho ia oe, e hoao hoi ia oe, e ike hoi ia i ka mea maloko o kou naau, i malama paha oe, i malama ole paha i kana mau kauoha.
\q1 
\v 3 Ua hoohaahaa ia ia oe, ua haawi mai oia ia oe i ka pololi, a ua hanai mai ia oe i ka mane au i ike ole ai, aole hoi i ike kou mau kupuna; i hoike mai ia ia oe, aole e ola ke kanaka ma ka berena wale no; aka, ke ola nei ke kanaka i na huaolelo a pau mailoko mai o ka waha o Iehova.
\q1 
\v 4 Aole i weluwelu kou aahu maluna ou, aole hoi i pehu kou wawae i neia mau makahiki he kanaha.
\q1 
\v 5 E hoomanao hoi oe iloko o kou naau, e like me ke kanaka e hooehaeha ana i kana keiki, pela hoi o Iehova e hooehaeha mai ai ia oe.
\q1 
\v 6 No ia hoi, e malama oe i na kauoha a Iehova a kou Akua, e hele oe ma kona mau aoao, a e makau ia ia.
\q1 
\v 7 No ka mea, ke alakai aku nei o Iehova kou Akua ia oe i ka aina maikai he aina wai e kahe ana ma kahawai, o na punawai, o na waipuna e piipii mai ana, mailoko mai o na awawa a me na puu:
\q1 
\v 8 He aina mea palaoa, a me ka bale, a me na kumu waina, a me na laau fiku, a me na pomegerane, he aina laau oliva mea aila, a me ka meli:
\q1 
\v 9 He aina kahi au e ai ai i ka berena me ka wi ole, aole oe e nele i kekahi mea malaila; he aina mea pohaku hao, a ma na puu ona e eli iho ai oe i ke keleawe.
\q1 
\v 10 Aia ai iho oe a maona, alaila e hoomaikai aku oe ia Iehova kou Akua, no ka aina maikai ana i haawi mai ai ia oe.
\b
\q1 
\v 11 E ao, o hoopoina oe ia Iehova kou Akua, ma ka malama ole i kana mau kauoha, i kana mau olelo kupaa, a me kona mau kanawai, a'u e kauoha aku nei ia oe i keia la.
\q1 
\v 12 Malia paha, a ai iho oe a maona, a kukulu oe i na hale maikai a noho iho iloko;
\q1 
\v 13 A hoomahuahuaia'e kou poe bipi a me kau poe hipa, a mahuahua hoi kau kala a me kau gula, a ua nui hoi kau mau mea a pau;
\q1 
\v 14 Alaila e hookiekieia'e kou naau iluna, a hoopoina oe ia Iehova kou Akua, nana oe i lawe mai nei mai ka aina o Aigupita mai, mailoko mai hoi o ka liale hooluhi;
\q1 
\v 15 Nana oe i alakai mai mawaena o kela waonahele nui weliweli; kahi o na nahesa wela, a me na moohueloawa, he maloo, he wahi wai ole, nana i hookahe mai ka wai nou mailoko mai o ka pohaku paa;
\q1 
\v 16 Nana no hoi oe i hanai me ka mane ma ka waonahele, ka mea a ko oukou mau kupuna i ike ole ai, i hoohaahaa mai ai ia ia oe, a i hoao mai ai hoi ia ia oe, i mea e pomaikai ai oe i kou wa mahope;
\q1 
\v 17 O i iho oe ma kou naau, Na ko'u mana, a me ka ikaika o kuu lima, i loaa'i ia'u keia waiwai.
\q1 
\v 18 E hoomanao oe ia Iehova i kou Akua: no ka mea, oia ke haawi mai ia oe i ka pono e loaa'i ka waiwai, i hookupaa oia i kana berita ana i hoohiki ai i ou mau kupuna, e like me ia i keia la.
\q1 
\v 19 A ina oe e hoopoina iki ia Iehova i kou Akua, a e hele mamuli o na akua e, e malama, a e hoomana aku ia lakou, ke hoike aku nei au ia oukou i keia la, he oiaio, e make oukou.
\q1 
\v 20 E like me na lahuikanaka a Iehova e luku aku ana imua o ko oukou maka, pela oukou e make ai; no ka mea, aole oukou i hoolohe i ka leo o Iehova ko oukou Akua.
\c 9
\b
\q1 
\v 1 E HOOLOHE, e ka Iseraela; e hele ana oe i keia la ma kela kapa o Ioredane, e komo a hoolilo nou i na lahuikanaka, he oi aku ka nui a me ka ikaika o lakou i kou, a i na kulanakauhale nui, ua paa i ka pa pohaku, a hala i ka lani.
\q1 
\v 2 He poe kanaka nunui a loihi, na keiki a ka poe Anakima, a oukou i ike ai, a ua lohe hoi oe, Owai la auanei e hiki ke ku imua o na keiki a Anaka?
\q1 
\v 3 E ike pono oe i keia la, o Iehova kou Akua, ka mea e hele ana imua ou, he ahi ia e hoopau ana, nana lakou e luku aku, a nana lakou e hoohaahaa iho imua o kou maka: a e hookuke aku oe ia lakou, a e luku koke aku ia lakou, e like me ka Iehova i olelo mai ai ia oe.
\q1 
\v 4 Mai i iho oe iloko o kou naau mahope o ka Iehova kou Akua kipaku ana aku ia lakou mai kou alo aku, i ka i ana ae, No ko'u pono i lawe mai nei o Iehova ia'u e hoonoho ma keia aina; aka, no ka hewa o keia mau lahuikanaka i kipaku aku ai o Iehova ia lakou mai kou alo aku.
\q1 
\v 5 Aole no kou pono, a me ka pololei o kou naau, kou hele ana e noho ma ko lakou aina; aka, no ka hewa o kela mau luhuikanaka, e kipaku aku ai o Iehova kou Akua ia lakou mai kou alo aku, a e hooko hoi ia i ka olelo a Iehova i hoohiki ai i kou mau kupuna, ia Aberahama, ia Isaaka, a me Iakoba.
\q1 
\v 6 E ike hoi oe, aole o Iehova kou Akua e haawi mai i keia aina maikai i lilo ia nou, no kou pono; no ka mea, he poe kanaka a-i oolea oukou,
\b
\q1 
\v 7 E hoomanao oe, mai hoopoina i kou hoonaukiuki ana ia Iehova kou Akua ma ka waonahele: ma ka la i puka mai ai oukou mai ka aina o Aigupita mai, a hiki oukou ma keia wahi, ua kipi oukou ia Iehova.
\q1 
\v 8 Ma Horeba hoi i hoonaukiuki aku ai oukou ia Iehova, a huhu mai la o Iehova ia oukou e luku aku ia oukou.
\q1 
\v 9 Ia'u i pii ae i ka mauna e loaa na papapohaku, na papa o ke kanawai a Iehova i hana'i no oukou, hookahi kanaha ao, a hookahi kanaha po, a'u i noho ai ma ka mauna; aole au i ai i ka ai, aole hoi i inu i ka wai:
\q1 
\v 10 A haawi mai o Iehova ia'u i na papapohaku elua, i kakauia e ka lima o ke Akua; a maluna o ia mau mea na huaolelo a pau a Iehova i olelo mai ai ia oukou ma ka mauna, mailoko mai o ke ahi i ka la o ka houluulu ana.
\q1 
\v 11 A pau na la he kanaha, a me na po he kanaha, haawi mai la o Iehova ia'u i na papapohaku elua, oia na papa o ke kanawai.
\q1 
\v 12 A olelo mai o Iehova ia'u, E ku ae oe, e iho koke oe mai keia wahi aku; no ka mea, ua hana hewa kou poe kanaka au i lawe mai nei mai ka aina o Aigupita mai: ua kapae koke ae lakou mai ke ala aku a'u i kauoha aku ai ia lakou; ua hana lakou i kii i hooheeheeia no lakou.
\q1 
\v 13 Olelo mai hoi o Iehova ia'u, i mai la, Ua ike au i keia poe kanaka, aia hoi, he poe kanaka a-i oolea keia.
\q1 
\v 14 E waiho mai oe ia'u, i luku aku ai au ia lakou, a i hokai aku ai i ko lakou inoa malalo ae o ka lani: a e hoolilo aku au ia oe i lahuikanaka ikaika loa, a nui loa hoi i ko lakou.
\q1 
\v 15 A huli ae au, a iho ilalo mai ka mauna mai, ua wela ka mauna i ke ahi; a ma kuu mau lima elua na papa elua o ke kanawai.
\q1 
\v 16 A nana iho la au, aia hoi, ua hana hewa oukou ia Iehova i ko oukou Akua, ua hana oukou i bipikeiki i hooheeheeia no oukou; ua kapae koke oukou mai ke ala aku a Iehova i kauoha mai ai ia oukou.
\q1 
\v 17 A lawe ae la au i na papa elua a hoolei aku la mai ko'u mau lima aku, a nahaha iho la imua o ko oukou maka.
\q1 
\v 18 A haule iho la au imua o Iehova, e like mamua, hookahi kanaha ao, hookahi kanaha po; aole au i ai i ka berena, aole hoi i inu i ka wai, no ko oukou hewa a pau a oukou i hana hewa ai imua o Iehova, e hoonaukiuki aku ai ia ia.
\q1 
\v 19 No ka mea, makau iho la au i ka huhu a me ka inaina nui a Iehova i huhu mai ai ia oukou e luku ia oukou: aka, hoolohe mai no o Iehova ia'u i kela manawa.
\q1 
\v 20 A huhu nui mai no hoi o Iehova ia Aarona e pepehi ia ia: a pule aku au no Aarona hoi i kela manawa.
\q1 
\v 21 Lawe aku la au i ko oukou hala, i ka bipikeiki a oukou i hana'i, a puhi aku la i ke ahi, a kui iho la, a pepe liilii a aiai e like me ka lepo; a hoolei aku i kona lepo iloko o ke kahawai, e kahe ana mai ka mauna mai.
\b
\q1 
\v 22 A ma Tabera, a ma Masa, a ma Kiberohataava, hoonaukiuki aku la oukou ia Iehova.
\q1 
\v 23 A ia Iehova hoi i hoouna aku ai ia oukou mai Kadesabanea aku, i ka i ana aku, E pii oukou a noho ma ka aina a'u i haawi ai no oukou; alaila kipi mai la oukou i ke kauoha a Iehova ko oukou Akua, aole oukou i hooia aku ia ia, aole hoi oukou i hoolohe i kona leo.
\q1 
\v 24 He poe kipi oukou ia Iehova mai ka manawa mai o kuu ike ana ia oukou.
\b
\q1 
\v 25 A haule iho la au imua o Iehova, hookahi kanaha ao, hookahi kanaha po, e like me kuu haule ana mamua; no ka mea, ua i mai o Iehova e luku aku ia oukou.
\q1 
\v 26 No ia mea, pule aku la au ia Iehova, i aku la, E Iehova, e ka Haku e, mai luku mai oe i kou poe kanaka, a me kou hooilina au i hoola'i ma kou mana, i ka mea hoi au i lawe mai nei mai Aigupita mai me ka lima ikaika.
\q1 
\v 27 E hoomanao oe i kau mau kauwa, ia Aberahama, ia Isaaka, a me Iakoba: mai manao oe i ka paakiki o keia poe kanaka, aole hoi i ko lakou hewa a me ko lakou hala;
\q1 
\v 28 O olelo mai auanei ko ka aina nolaila i lawe mai ai oe ia makou, No ka hiki ole ia Iehova ke lawe aku ia lakou ma ka aina ana i olelo mai ai ia lakou, a no kona inaina ia lakou, i lawe mai oia ia lakou e luku ia lakou ma ka waonahele.
\q1 
\v 29 O kou poe kanaka no nae lakou, a me kou hooilina au i lawe mai nei me kou mana ikaika, a me kou lima kakauha.
\c 10
\b
\q1 
\v 1 I KELA manawa, olelo mai o Iehova ia'u, E kalai oe nou i elua papapohaku e like me na mea mamua, a e pii mai io'u nei ma ka mauna, a e hana oe nou i pahu laau.
\q1 
\v 2 A e kahakaha iho au maluna o na papa i na huaolelo i kakauia'i ma na papa mamua i naha ia oe, a e waiho oe ia mau mea iloko o ka pahu.
\q1 
\v 3 A hana aku la au i pahu laau sitima, a kalai iho la au i na papapohaku elua, e like me na mea mamua, a pii aku la i ka mauna me na papa elua ma kuu lima.
\q1 
\v 4 A kahakaha iho la ia maluna o na papa, e like me ke kahakaha ana mamua, i na kauoha he umi, a Iehova i olelo mai ai ia oukou ma ka mauna mailoko mai o ke ahi, i ka la o ka houluulu ana: a haawi mai o Iehova ia mau mea ia'u.
\q1 
\v 5 A huli ae la au, a iho iho la ilalo mai ka mauna mai, a waiho iho la au i na papa maloko o ka pahu a'u i hana i, aia no ilaila oia mau mea, e like me ka Iehova i kauoha mai ai ia'u.
\b
\q1 
\v 6 A hele aku la na mamo a Iseraela mai Beerota o Bene-iaakana a Mosera: malaila i make ai o Aarona, a malaila i kanuia'i oia; a lilo iho la o Eleazara kana keiki i kahuna, i mea pani i kona hakahaka.
\q1 
\v 7 Hele aku la lakou mailaila aku a Gudegoda: a mai Gudegoda a Iotebata, he aina o na kahawai.
\b
\q1 
\v 8 I kela manawa hookaawale ae la o Iehova i ka ohana a Levi, e halihali i ka pahuberita o Iehova, e ku imua o Iehova o lawelawe nana, a e hoomaikai aku ma kona inoa, a hiki i keia la.
\q1 
\v 9 No ia mea, aole ho kuleana o ka Levi, aohe aina hooili pu me kona poe hoahanau; o Iehova, oia kona mea hooili e like me ka Iehova kou Akua i olelo mai ai ia ia.
\b
\q1 
\v 10 A noho iho la au ma ka mauna o like me ka manawa mamua, hookahi kanaha ao, a hookahi kanaha po; a hoolohe mai o Iehova ia'u i kela manawa, aole i luku mai o Iehova ia oe.
\q1 
\v 11 Olelo mai la o Iehova ia'u, E ku ae oe, a hele aku imua o na kanaka, i komo ai lakou, a lilo ia lakou ka aina a'u i hoohiki ai i ko lakou mau kupuna e haawi ia lakou.
\b
\q1 
\v 12 Ano hoi, e ka Iseraela, heaha la ka mea a Iehova kou Akua i kauoha mai ai ia oe, aole anei o ka makau ia Iehova kou Akua, o ka hele ma kona mau aoao, a o ke aloha ia ia, a o ka hookauwa na Iehova na kou Akua me kou naau a pau, a me kou uhane a pau,
\q1 
\v 13 O ka malama i na kauoha a Iehova, a me kona mau kanawai a'u e kauoha aku nei ia oe i keia la no kou pono?
\q1 
\v 14 Aia hoi, no Iehova kou Akua ka lani, a me ka lani o na lani, a me ka honua, a me ka mea a pau iloko.
\q1 
\v 15 No ka makemake wale o Iehova i kou mau kupuna e aloha aku ia lakou, i wae mai ai ia i ka lakou poe mamo mahope o lakou, oia hoi ia oukou, mamua o na kanaka a pau, e like me ia i keia la.
\q1 
\v 16 No ia hoi, e okipoepoe oukou i ka omaka o ko oukou naau, mai hoopaakiki hou aku i ko oukou a-i.
\q1 
\v 17 No ka mea, o Iehova ko oukou Akua, he Akua ia o na akua, a he Haku o na haku, he Akua nui, mana, weliweli, aole ia i manao i na maka, aole hoi i lawe i ke kipe:
\q1 
\v 18 E hoopono aku ana ia no ka poe makua ole, a me na wahinekanemake, a ua aloha hoi ia i ka malihini, a ua haawi ia ia i ka ai a me ka aahu.
\q1 
\v 19 E aloha hoi oukou i ka malihini: no ka mea, he poe malihini oukou ma ka aina o Aigupita.
\q1 
\v 20 E makau aku oe in Iehova i kou Akua, e hookauwa oe nana, a e hoopili aku ia ia, a e hoohiki ma kona inoa.
\q1 
\v 21 Oia no kou hoolea, a oia kou Akua, ka mea i hana mai nou i keia mau mea nui, weliweli a kou mau maka i ike ai.
\q1 
\v 22 Hele iho kou poe kupuna ma Aigupita, he kanahiku lakou; ano hoi, ua hoolilo mai o Iehova kou Akua ia oe, a like me na hoku o ka lani ka lehulehu.
\c 11
\b
\q1 
\v 1 NO ia mea, e aloha aku oe ia Iehova kou Akua, a e malama i kana mea i kauohaia, a me kona mau kanawai, a me kana mau olelo kupaa, a me kana mau kauoha i na la a pau.
\q1 
\v 2 E ike pono oukou i keia la; no ka mea, aole au e olelo aka i na keiki a oukou, ka poe naauao ole, a ike ole hoi i ka paipai ana a Iehova ko oukou Akua, i kona nui, i kona lima ikaika, a me kona lima kakauha;
\q1 
\v 3 A me kana mau hana mana, a me na mea ana i hana'i iwaena o Aigupita ia Parao ke alii o Aigupita, a me kona aina a pau;
\q1 
\v 4 I ka mea hoi ana i hana ai i ka poe kaua o Aigupita, i ko lakou mau lio, a me ko lakou mau halekaa; i kona hoopopoi ana i ka wai o ke Kaiula maluna o lakou i ko lakou hahai ana mai ia oukou, a luku mai o Iehova ia lakou a hiki i keia la:
\q1 
\v 5 I ka mea hoi ana i hana mai ai no oukou ma ka waonahele a hiki aku ma keia wahi;
\q1 
\v 6 A i ka mea ana i hana mai ai ia Datana, a me Abirama i na keiki a Eliaba, ke keiki a Reubena, i hamama ai ka honua i kona waha, a ale iho la ia lakou, a me ko lakou ohua, a me ko lakou mau halelewa, a me ko lakou waiwai a pau me lakou iwaena o ka Iseraela a pau:
\q1 
\v 7 Aka, ua ike ko oukou maka i na hana nui a pau a Iehova i hana'i.
\b
\q1 
\v 8 E malama no oukou i na kauoha a pau a'u e kauoha aku nei ia oukou i keia la, i ikaika ai oukou, a i hele oukou a komo i ka aina, kahi a oukou e hele ai e noho;
\q1 
\v 9 A i loihi ai ko oukou mau la ma ka aina a Iehova i hoohiki ai i ko oukou mau kupuna e haawi no lakou, a me ka lakou poe mamo, he aina e kahe ana o ka waiu a me ka meli.
\b
\q1 
\v 10 No ka mea, aole like ka aina a oukou e hele aku nei e noho ai, me ka aina o Aigupita, kahi a oukou i hele mai nei, kahi a oukou i lulu ai i ka oukou hua, a hookahe i ka wai me ko oukou wawae, e like me ke kihapai mea kanu:
\q1 
\v 11 Aka, o ka aina a oukou e hele aku nei e noho, he aina puu, a me na awawa, e inu ana i ka wai ua o ka lani;
\q1 
\v 12 He aina a Iehova kou Akua i malama ai; e mau ana na maka o Iehova kou Akua maluna ona, mai ka mua o ka makahiki, a i ka hope o ka makahiki.
\b
\q1 
\v 13 Ina paha oukou e hoolohe pono i ka'u mau kauoha a'u e kauoha aku nei ia oukou i keia la, e aloha aku ia Iehova ko oukou Akua, a e malama ia ia me ko oukou naau a pau, a me ko oukou uhane a pau;
\q1 
\v 14 Alaila e haawi iho au i ka ua o ko oukou aina i kona manawa pono, i ka ua mua, a i ka ua hope, i ohi ai oe i kau palaoa a me kau waina a me kau aila.
\q1 
\v 15 A e haawi au i ka weuweu ma ke kula na na holoholona au, i ai iho oe a maona.
\q1 
\v 16 E malama oukou ia oukou iho, o hoowalewaleia ko oukou naau, a huli ae oukou, a malama aku i na akua e, a e hoomana aku ia lakou.
\q1 
\v 17 A e hoaaia ka inaina o Iehova ia oukou, a e hoopaa aku ia i ka lani, i ua ole ai, a i hua ole ai ka aina i kona hua; a e lukuia aku oukou mai ka aina maikai aku a Iehova i haawi mai ai no oukou.
\b
\q1 
\v 18 No ia mea, e waiho oukou i keia mau olelo a'u maloko o ko oukou naau, a me ko oukou uhane, a e nakii oukou ia mau mea i hoailona ma ko oukou mau lima, a i mea e hoomanao ai iwaena o ko oukou mau maka.
\q1 
\v 19 A e ao aku oukou ia mau mea i ka oukou kamalii, e olelo ana ma ia mau mea i kou noho ana ma kou hale, a i kou hele ana ma ke ala, a i kou moe ana ilalo, a me kou ala ana iluna.
\q1 
\v 20 A e kakau oe ia mau mea ma na lapauila o kou puka hale, a ma na puka pa ou.
\q1 
\v 21 I hoonuiia'i ko oukou mau la, a me na la o ka oukou poe keiki, ma ka aina o Iehova i hoohiki ai i ko oukou mau kupuna e haawi no lakou, e like me na la o ka lani maluna o ka honua.
\b
\q1 
\v 22 No ka mea, ina paha e malama pono oukou i keia mau kauoha a pau a'u e kauoha aku nei ia oukou e hana ia mea, e aloha aku ia Iehova i ko oukou Akua, a o hele ma kona aoao a pau, a e hoopili aku ia ia;
\q1 
\v 23 Alaila e hookuke aku o Iehova i keia mau lahuikanaka a pau mai ko oukou alo aku, a e lilo no oukou na lahuikanaka nui aku, a ikaika aku i ko oukou.
\q1 
\v 24 No oukou na wahi a pau a ko oukou kapuwai e hehi iho ai: mai ka waonahele a hiki i Lebanona, a mai ka muliwai, ka muliwai o Euperate, a hiki i ke kai ma ke komohana, oia ko oukou palena aina.
\q1 
\v 25 Aole e hiki i kekahi kanaka ke kupaa imua o oukou, na Iehova ko oukou Akua e kau mai ka makau a me ka weliweli ia oukou maluna o ka aina a pau a oukou e hehi iho ai, e like me kana i olelo mai ai ia oukou.
\b
\q1 
\v 26 Eia hoi ke waiho nei au imua o ko oukou alo i keia la i ka pomaikai, a me ka poino:
\q1 
\v 27 I ka pomaikai, ke hoolohe oukou i na kauoha a Iehova ko oukou Akua, a'u e kauoha aku nei ia oukou i keia la;
\q1 
\v 28 I ka poino, ke hoolohe ole oukou i na Kauoha a Iehova ko oukou Akua; a huli ae oukou mai ka aoao aku, a'u e kauoha aku nei ia oukou i keia la, a hele mamuli o na akua e, a oukou i ike ole ai.
\q1 
\v 29 Aia hookomo aku o Iehova kou Akua ia oe i ka aina au e hele aku nei a noho ilaila, e kau aku oe i ka pomaikai ma ka puu o Gerizima, a i ka poino ma ka puu o Ebala.
\q1 
\v 30 Aole anei oia mau mea ma kela kapa o Ioredane ma ka aoao e napoo ana o ka la, i ka aina o ka Kanaana, e noho ana ma ka papu e ku pono ana i Gilegala, e pili ana i na papu o More?
\q1 
\v 31 No ka mea, e hele ana oukou ma kela kapa o Ioredane e komo iloko o ka aina a Iehova ko oukou Akua e haawi mai ai no oukou, a e komo no oukou, a e noho oukou malaila.
\q1 
\v 32 A e malama pono oukou i na kanawai a pau a me na olelo kupaa a'u e waiho nei imua o oukou i keia la.
\c 12
\b
\q1 
\v 1 EIA na kanawai a me na olelo kupaa a oukou e malama pono ai ma ka aina a Iehova ke Akua o ko oukou mau kupuna e haawi mai ia oukou e noho, i na la a pau o ko oukou ola ana maluna o ka honua.
\q1 
\v 2 E luku loa aku oukou i na wahi a pau, kahi a na lahuikanaka i hooliloia no oukou, i malama'i i ko lakou mau akua, maluna o na mauna kiekie, a me na puu, a malalo o na laau uliuli.
\q1 
\v 3 E hookahuli oukou i ko lakou mau kuahu, a e wawahi i ko lakou kii, a e puhi i ko lakou mau kii o Asetarota i ke ahi, a e kua ilalo i na kii kalaiia o ko lakou mau akua, a e hokai i ko lakou inoa mai keia wahi aku.
\q1 
\v 4 Mai hana oukou pela ia Iehova ko oukou Akua.
\q1 
\v 5 Aka, ma kahi a Iehova ko oukou Akua e wae ai noloko mai o ko oukou mau ohana, a waiho i kona inoa malaila, ma kona hale, malaila oukou e imi ai, a malaila e hele ai.
\q1 
\v 6 A malaila oukou e lawe aku ai i ka oukou mau mohaikuni, a me ka oukou alana, a me na hapaumi o ko oukou waiwai, a me na mohaihoali a ko oukou lima, a me ko oukou hoohiki ana, a me ka oukou mohaialoha, a me na hanau mua o ka oukou bipi a me ka oukou hipa.
\q1 
\v 7 A malaila oukou e ai ai imua o Iehova ko oukou Akua; a e olioli oukou ma na mea a pau a ko oukou lima i lawe ai, o oukou, a me ko oukou poe ohua, no ka mea, ua hoopomaikai o Iehova kou Akua ia oe.
\q1 
\v 8 Mai hana oukou e like me na mea a pau o kakou i keia la, o kela kanaka keia kanaka ma ka mea pono i kona maka iho.
\q1 
\v 9 No ka mea, aole oukou i hiki aku i keia manawa ma kahi e maha'i, a ma ka noho ana a Iehova ko oukou Akua e haawi mai ia oukou.
\q1 
\v 10 Aia hele oukou ma kela kapa o Ioredane, a noho oukou ma ka aina a Iehova ko oukou Akua e hoolilo mai ai no oukou, a haawi mai ia i ka maha no oukou i ko oukou poe enemi a puni, a noho oukou me ka maluhia;
\q1 
\v 11 Alaila ma kahi a Iehova ko oukou Akua e wae ai i wahi e hoopaa ai i kona inoa, malaila oukou e lawe aku ai i na mea a pau a'u e kauoha aku nei ia oukou: i ka oukou mohaikuni, a me ka oukou alana, a me ka hapaumi o ko oukou waiwai, a me ka mohaihoali o ko oukou lima, a me ka mea maikai o ko oukou hoohiki ana a oukou i hoohiki ai ia Iehova.
\q1 
\v 12 A e olioli oukou imua o Iehova ko oukou Akua, o oukou, a me ka oukou mau keikikane, a me ka oukou mau kaikamahine, a me na kauwakane a oukou, a me ka oukou mau kauwawahine, a me ka Levi e noho pu ana me oukou; no ka mea, aohe ona kuleana, aohe ona aina hooili me oukou.
\q1 
\v 13 E malama ia oe iho, o kaumaha aku auanei oe i kau mau mohaikuni ma na wahi a pau au e ike ai;
\q1 
\v 14 Aka, ma kahi a Iehova e wae ai iloko o kekahi o kou mau ohana, malaila oe e kaumaha aku ai i kau mau mohaikuni, a malaila oe e hana aku ai i na mea a pau a'u e kauoha aku nei ia oe.
\b
\q1 
\v 15 Aka, o ka mea a pau a kou naau e makemake ai, he pono e kalua oe a e ai hoi i ka io ma kou mau ipuka a pau, e like me ka pomaikai a Iehova kou Akua i haawi mai ai ia oe: o ke kanaka haumia, a me ke kanaka maemae e ai no oia ia mea, e like me ka ke gazela, a me ka ka dea.
\q1 
\v 16 Aole nae oukou e ai i ke koko, e ninini oukou ia mea ma ka lepo e like me ka wai.
\b
\q1 
\v 17 Mai ai oe ma kou mau ipuka i ka hapaumi o kau palaoa, a me kau waina, a me kau aila, a me ka hanau mua a kau poe bipi a me kau poe hipa, aole hoi i kekahi o na mea a pau au i hoohiki ai, a me kau mohaialoha, a me ka mohaihoali a kou lima.
\q1 
\v 18 Aka, e ai oe ia mau mea imua o Iehova kou Akua, ma kahi a Iehova kou Akua i wae ai, o oe, a me kau keikikane, a me kau kaikamahine, a me kau kauwakane, a me kau kauwawahine, a me ka mamo a Levi ma kou mau ipuka: a e olioli oe imua o Iehova kou Akua i na mea a pau a kou lima e lawe ai.
\q1 
\v 19 E malama ia oe iho, o hoowahawaha auanei oe i ka Levi i na la a pau o kou ola ana ma ka honua.
\b
\q1 
\v 20 Aia hooakea mai o Iehova kou Akua i kou mokuna, e like me kana i olelo mai ai ia oe; a e i iho oe, E ai au i ka io, no ka mea, ke ake nei kou naau e ai i ka io; e ai no oe i ka io, i ka mea a pau a kou naau i makemake ai.
\q1 
\v 21 Ina paha loihi ia oe ka wahi a Iehova kou Akua i wae ai e hoopaa i kona inoa malaila; alaila e kalua oe i ka mea o kau poe bipi a me kau poe hipa a Iehova i haawi mai ai ia oe, e like me ka'u i kauoha ai ia oe, a e ai oe ma kou mau ipuka i ka mea a pau a kou naau i makemake ai.
\q1 
\v 22 E like me ke gazela a me ka dea i aiia, pela oe e ai ai ia mea: o ke kanaka haumia, a me ke kanaka maemae, e ai no ia mau mea.
\q1 
\v 23 Aole loa oe e ai i ke koko: no ka mea, o ke koko, oia ke ola, mai ai oe i ke ola me ka io.
\q1 
\v 24 Mai ai oe ia mea: e ninini iho oe ia mea ma ka lepo, me he wai la.
\q1 
\v 25 Mai ai oe ia mea; i pomaikai oe, a me kau mau keiki mahope ou, i kau hana ana i ka pono imua o Iehova.
\b
\q1 
\v 26 O kau mau mea i hoolaaia wale no, a me na mea au i hoohiki ai, oia kau e lawe, a hele ma kahi a Iehova i wae ai.
\q1 
\v 27 A e kaumaha aku oe i kau mau mohaikuni, i ka io a me ke koko maluna o ke kuahu o Iehova kou Akua: a o ke koko o kau mau mohai e nininiia maluna o ke kuahu o Iehova kou Akua, a e ai iho oe i ka io.
\q1 
\v 28 E malama, e hoolohe hoi i neia mau olelo a pau a'u e kauoha nei ia oe, i pomaikai ai oe a me kau mau keiki mahope ou i ka manawa a pau, i kau hana ana i ka maikai a me ka pono imua o Iehova kou Akua.
\b
\q1 
\v 29 Aia hooki aku o Iehova kou Akua i na lahuikanaka mai kou alo aku, kahi au e hele e hooliloia'i lakou nou, a lilo lakou nou, a noho iho oe ma ko lakou aina:
\q1 
\v 30 E malama oe ia oe iho, i hihia ole ai oe mamuli o lakou, mahope o ko lakou lukuia, mai kou alo aku; a i ninau ole ai oe no ko lakou mau akua, i ka i ana ae, Pehea la keia mau lahuikanaka i malama'i i ko lakou mau akua? a pela hoi wau e hana'i.
\q1 
\v 31 Mai hana aku oe ia Iehova kou Akua pela: ua hana lakou no ko lakou akua i na mea ino a pau a Iehova i inaina ai; no ka mea, ua puhi lakou i ka lakou keikikane, a me ka lakou kaikamahine i ke ahi no ko lakou mau akua.
\b
\q1 
\v 32 O ka mea a pau a'u e kauoha aku nei ia oukou, o ka oukou ia e malama pono ai; mai hooi aku, aole hoi e hoemi iho ia mea.
\c 13
\b
\q1 
\v 1 A I KU mai iwaena o oukou ke kaula, a he mea moe uhane paha, a hoike mai ia oukou i hoailona, i mea kupanaha paha;
\q1 
\v 2 A ko io ka hoailona, a ka mea kupanaha paha, ana i olelo e mai ai ia oe, i ka i ana mai, E hele kakou mamuli o na akua e, i na mea au i ike ole ai, a e malama kakou ia lakou:
\q1 
\v 3 Mai hoolohe oe i ka olelo a ua kaula la, a me ua mea moe uhane la; no ka mea, ke hoao mai nei o Iehova ko oukou Akua ia oukou, i ike ai ia i ko oukou aloha ana ia Iehova ko oukou Akua, me ko oukou naau a pau, a me ko oukou uhane a pau.
\q1 
\v 4 E hele oukou mamuli o Iehova ko oukou Akua, e makau ia ia, a e malama i kana mau kauoha, e hoolohe i kona leo, e hookauwa aku oukou nana, a e hoopili aku ia ia.
\q1 
\v 5 A o ua kaula la, a o ua mea moe uhane la paha, e pepehiia oia; no ka mea, ua olelo hookipi oia ia Iehova ko oukou Akua, nana oukou i lawe mai, mai ka aina o Aigupita mai, a hoopakele mai ia oukou mailoko mai o ka hale hooluhi, i mea e hooauwana ai ia oe mai ke ala aku a Iehova kou Akua i kauoha mai ai ia oe e hele. Pela oe e hoolei aku ai i ka mea hewa mai ou aku la.
\b
\q1 
\v 6 A o kou hoahanau kane, ke keiki a kou makuwahine, a o kau keiki iho paha, a o kau kaikamahine paha, a o ka wahine o kou poli, a o kau mea aloha paha e like me kou uhane iho, ke hoowalewale malu mai ia oe, i ka i ana mai, E hele kaua e malama i na akua e, i na mea au i ike ole ai, aole hoi kou mau kupuna;
\q1 
\v 7 I na akua o na kanaka e noho ana a puni o oukou, o na mea kokoke mai ia oe, a me na mea mamao aku, mai kekahi aoao o ka honua, a hiki i kekahi aoao o ka honua;
\q1 
\v 8 Mai ae aku oe ia ia, aole hoi e hoolohe ia ia, aole e aloha kou maka ia ia, aole oe e aua ia ia, aole no hoi oe e huna ia ia;
\q1 
\v 9 Aka, e oiaio, nau no ia e pepehi, e kau mua ia kou lima maluna ona e make ia, a mahope iho ka lima o kanaka a pau.
\q1 
\v 10 A e hailuku aku oe ia ia i ka pohaku e make ia; no ka mea, ua imi mai ia e hoohuli ia oe mai o Iehova kou Akua aku, nana oe i lawe mai nei mai ka aina o Aigupita mai, a mailoko mai hoi o ka hale hooluhi.
\q1 
\v 11 A e hoolohe mai ka Iseraela a pau, a e makau hoi, aole hoi e hana hewa hou i kekahi hewa e like me ia iwaena o oukou.
\b
\q1 
\v 12 Ina paha e lohe oe ma kekahi kulanakauhale ou, kahi a Iehova kou Akua i haawi mai ia oe e noho ai, i ka i ana mai,
\q1 
\v 13 Ua hele na kanaka, he poe hewa mai ou aku la, a ua koi aku lakou i na kanaka o ko lakou kulanakauhale, e i aku ana, Ina kakou e hele, a e malama aku i na akua e a oukou i ike ole ai:
\q1 
\v 14 Alaila e ninau aku oe, a e imi aku, a e ninau pono; aia hoi, ina he oiaio no, a ua maopopo, ua hanaia no keia mea ino iwaena o oukou;
\q1 
\v 15 E oiaio no, e pepehi aku oe i na kanaka o ia kulanakauhale me ka maka o ka pahikaua, e luku loa aku ia wahi, a me ko laila mea a pau, a me ko laila holoholona, me ka maka o ka pahikaua.
\q1 
\v 16 A e hoiliili oe i ko laila waiwai pio a pau iwaena konu o kona alanui, a e puhi aku i ke kulanakauhale i ke ahi, a me kona waiwai pio a pau loa, no Iehova kou Akua; a e lilo ia i puu mau loa, aole e kukulu hou ia.
\q1 
\v 17 Aole e pipili mai kekahi o ia mea laa i kou lima: i huli aku ai o Iehova mai kona inaina nui aku, a e haawi mai ia i ke aloha ia oe, a me ka lokomaikai ia oe, a e hoonui mai oia ia oe, e like me kana i hoohiki ai i kou mau kupuna.
\q1 
\v 18 Aia e hoolohe oe i ka leo o Iehova kou Akua i ka malama ana i kana mau kauoha a pau a'u e kauoha aku nei ia oe i keia la, a e hana i ka mea i pono i na maka o Iehova kou Akua.
\c 14
\b
\q1 
\v 1 HE poe keiki oukou na Iehova ko oukou Akua: mai okioki oukou ia oukou iho, aole hoi oukou e ako i ke oho mawaena o na maka o oukou no ka mea i make.
\q1 
\v 2 No ka mea, he poe oukou i hoolaaia no Iehova no ko oukou Akua, a na Iehova oukou i wae mai i kanaka ponoi nona, mamua o na lahuikanaka a pau maluna o ka honua.
\b
\q1 
\v 3 Mai ai oe i kekahi mea i hoowahawahaia.
\q1 
\v 4 Eia na holoholona a oukou e ai ai: o ka bipi, o ka hipa a me ke kao,
\q1 
\v 5 O ka dea hihiu, o ka dea, o ka dea ulaula, o ke kao hihiu, o ka disona, o ka bipi hihiu, a me ke kao o ka waonahele.
\q1 
\v 6 A o na holoholona maiuu mahele, elua manamana o ka mahele ana, a hoolualuai a nau hou i ka ai mawaena o na holoholona; oia ka oukou e ai ai.
\q1 
\v 7 Aka, aole oukou e ai i keia mau mea o na holoholona hoolualuai a nau hou i ka ai, a o ka mea maiuu mahele: o ke kamelo, o ka hare, a me ke kone; no ka mea, ua hoolualuai lakou, a nau hou i ka ai aole nae i mahele i ka maiuu; ua haumia lakou ia oukou.
\q1 
\v 8 A o ka puaa, no ka mea, ua mahele ia i ka maiuu, aole nae ia i hoolualuai a nau hou i ka ai, ua haumia oia ia oukou: mai ai oukou i ko lakou io, mai hoopa aku oukou i ko lakou kino i make.
\b
\q1 
\v 9 O keia ka oukou e ai ai, o na mea a pau iloko o na wai: o na mea halo a me na mea unahi a pau, o ka oukou ia e ai.
\q1 
\v 10 A o na mea halo ole a pau, a me na mea unahi ole, aole oukou e ai ia mea; ua haumia ia ia oukou.
\b
\q1 
\v 11 O na manu maemae a pau, o ka oukou ia e ai ai.
\q1 
\v 12 Eia na mea aole oukou e ai: o ka aeto, o ka osiferaga, o ka osepera;
\q1 
\v 13 O ke korenisa, o ka aeselona, o ka vuletura eleele, a me ka mea like;
\q1 
\v 14 O na koraka a pau a me kona mea like;
\q1 
\v 15 O ka ulula, o ke tama, o ka laru, o ka nisu a me kona mea like;
\q1 
\v 16 O ka bubo, o ka pueo, o ka noketura;
\q1 
\v 17 O ka pelikana, o ka vuletura keokeo, o ke katarakete;
\q1 
\v 18 O ke kikonia, o ka aredea e like me kona ano iho, o ka upupa, a me ka opeapea.
\q1 
\v 19 O na mea kolo a pau e lele ana, ua haumia ia ia oukou; mai ai oukou ia mau mea.
\q1 
\v 20 O na manu maemae a pau, o ka oukou ia e ai ai.
\b
\q1 
\v 21 Mai ai oukou i kekahi mea make wale: e haawi aku na ke kanaka e iloko o kou mau ipuka, i ai iho ai oia ia mea; a e kuai aku paha ia mea i ka malihini: no ka mea, he poe kanaka oukou i hoolaaia no Iehova kou Akua. Mai hoolapalapa oe i ke keikikao iloko o ka waiu o kona makuwahine.
\b
\q1 
\v 22 E hookupu oe i ka hapaumi o kau hua a pau a ka mahinaai i hua mai ai i kela makahiki i keia makahiki.
\q1 
\v 23 A e ai oe imua o Iehova kou Akua, ma kahi ana i wae ai e hoopaa i kona inoa malaila, i ka hapaumi o kau palaoa, a me kou waina, a me kou aila, a me na hanau mua o kau poe bipi, a me kau poe hipa, i ao iho ai oe e makau ia Iehova kou Akua i na la a pau.
\q1 
\v 24 Ina paha loihi ke ala ia oe, aole e hiki ia oe ke lawe aku ia mea malaila; a i mamao aku paha ia oe ka wahi a Iehova kou Akua i wae ai e hoopaa i kona inoa malaila; no ka mea, ua hoopomaikai o Iehova kou Akua ia oe;
\q1 
\v 25 Alaila e hoolilo aku oe ia i mea kala, a e hoopaa iho i ke kala ma kou lima, a hele aku ma kahi a Iehova kou Akua i wae ai:
\q1 
\v 26 A e hoolilo aku oe i ua kala la no ua mea a pau a kou naau i makemake ai, no ka bipi paha, a no ka hipa, a no ka waina paha, a no ka mea inu awaawa paha, a no ka mea a pau a kou naau e imi ai; a e ai iho oe malaila imua o Iehova kou Akua, a e olioli oe a me kou ohua.
\q1 
\v 27 A o ka Levi ma kou ipuka, mai hoopoina oe ia ia: no ka mea, aohe ona kuleana, aohe ona aina hooili me oe.
\b
\q1 
\v 28 I ka hope o na makahiki ekolu, e lawe mai oe i ka hapaumi a pau o kau mea i loaa i ua makahiki la, a e waiho ia mea iloko o kou mau ipuka.
\q1 
\v 29 A o ka Levi, (no ka mea, aohe ona kuleana, aohe ona aina hooili me oe,) a o ka malihini, a o ka mea makua ole, a me ka wahinekanemake iloko o kou mau ipuka, o lakou ke hele mai, a e ai a maona; i hoopomaikai ai o Iehova kou Akua ia oe ma na hana a pau a kou lima e lawe ai.
\c 15
\b
\q1 
\v 1 I KA pau ana o na makahiki pahiku e kala aku oe i na mea.
\q1 
\v 2 Penei ke ano o ke kala ana'ku: o ka mea nona ka aie, nana e haawi aie i kona hoalauna, oia ke kala aku; mai kii hou aku oia ia mea i kona hoalauna, aole hoi i kona hoahanau; no ka mea, ua oleloia mai, o ko ke Akua kala ana ia.
\q1 
\v 3 He pono e kii hou aku oe i ke kanaka e, aka, o kau mea me kou hoahanau, na kou lima ia e kala aku;
\q1 
\v 4 I mea e ilihune ole ai kekahi mea o oukou; no ka mea, na Iehova oe e hoopomaikai nui mai ma ka aina a Iehova kou Akua e haawi mai ai ia oe i wahi e noho ai nou:
\q1 
\v 5 I kou manawa wale no e hoolohe pono ai i ka leo o Iehova kou Akua, i ka malama pono i neia mau kauoha a pau a'u e kauoha aku nei ia oe i keia la.
\q1 
\v 6 No ka mea, ke hoopomaikai nei o Iehova kou Akua ia oe, e like me kana olelo ana mai ia oe: e haawi lilo ole aku oe i na lahuikanaka he nui, aole oe e noi wale aku; e noho alii oe maluna o na lahuikanaka he nui, aole hoi lakou e noho alii maluna on.
\b
\q1 
\v 7 Ina iwaena o oukou kekahi hoahanau ilihune ou maloko o kekahi o kou mau ipuka ma ka aina a Iehova kou Akua e haawi mai ai ia oe, mai hoopaakiki oe i kou naau, aole hoi e aua kou lima no kou hoahanau ilihune:
\q1 
\v 8 Aka, e wehe loa oe i kou lima ia ia, a e haawi io aku ia ia i ka mea e pono ai kona nele, ana i hemahema ai.
\q1 
\v 9 E ao, o kupu mai ka manao iloko o kou naau ino, e i iho ana, Ua kokoke mai nei ka hiku o ka makahiki, ka makahiki e hookala aku ai; a nana ino aku kou maka i kou hoahanau ilihune, a haawi ole aku oe nana; a e kahea aku oia ia Iehova nou, a e lilo ia i hewa nou.
\q1 
\v 10 E oiaio no, e haawi aku oe nana, aole e minamina kou naau i kou haawi ana'ku nana: no ka mea, oia ka mea e hoopomaikai mai ai o Iehova kou Akua ia oe ma kau hana ana a pau, a ma na mea a pau a kou lima e lawe ai.
\q1 
\v 11 No ka mea, aole e pau ka poe ilihune ma ka honua; nolaila, ke kauoha aku nei au ia oe, i ka i ana'ku, E wehe loa oe i kou lima i kou hoahanau, i kou poe ilihune, a me kou poe nele ma kou aina.
\b
\q1 
\v 12 Ina paha e kuaiia mai nou kou hoahanau, he kanaka Hebera. he wahine Hebera paha, a e hookauwa mai oia nau i na makahiki eono; a o ka hiku o ka makahiki e hookuu aku oe ia ia mai ou aku la.
\q1 
\v 13 A i hookuu aku oe ia ia mai ou aku la, mai hookuu wale aku oe ia ia.
\q1 
\v 14 E hoolako oe ia ia i kekahi o kau poe hipa, a me kau palaoa, a me kau waina: i ka mea a Iehova kou Akua, i hoopomaikai ai ia oe, e haawi aku ia ia.
\q1 
\v 15 A e hoomanao hoi oe, he kauwa no oe ma ka aina o Aigupita, a na Iehova na kou Akua oe i hoopakele: nolaila e kauoha aku nei au ia oe ia mea i keia la.
\q1 
\v 16 Ina paha e olelo oia ia oe, Aole au makemake e hele mai ou aku la, no kona aloha ia oe a me kou ohua, a no kona pomaikai ia oe;
\q1 
\v 17 Alaila e lalau oe i ke kui, a hou aku i kona pepeiao a ma ka puka, a e lilo ia i kauwa mau nau: a pela oe e hana aku ai i kau kauwawahine.
\q1 
\v 18 Mai minamina oe i kou hookuu aku ia ia mai ou aku la; no ka mea, ua oi aku kona pono ia oe, i ko na kauwa hoolimalima elua, i kona malama ana ia oe i na makahiki eono: a e hoopomaikai o Iehova kou Akua ia oe i na mea a pau au e hana'i.
\b
\q1 
\v 19 O na hanau mua a pau o kau poe bipi, a me kau poe hipa e hoolaa oe no Iehova kou Akua; mai hoohana oe i ka hanau mua o kau bipi, aole hoi e ako i ka hulu o kau hipa hanau mua.
\q1 
\v 20 Imua o Iehova kou Akua e ai ai oe ia mea ma kahi a Iehova e wae ai, o oe a me kou ohua.
\q1 
\v 21 Ina paha he wahi kina o ia mea, he oopa paha, he makapo paha, a he wahi mea kina iki, mai kaumaha aku oe ia mea ia Iehova kou Akua.
\q1 
\v 22 E ai oe ia mea iloko o kou mau ipuka: o ke kanaka haumia, a me ke kanaka maemae e ai no, e like me ke gazela, a me ka dea hihiu.
\q1 
\v 23 Aole nae oe e ai i ke koko o ia mea; e ninini oe ia mea ma ka honua e like me ka wai.
\c 16
\b
\q1 
\v 1 E HOOMANAO oe i ka malama o Abiba, a e malama oe i ka moliaola na Iehova kou Akua: no ka mea, o Abiba ka malama a Iehova kou Akua i lawe mai ai ia oe mailoko mai o Aigupita i ka po.
\q1 
\v 2 E kalua oe i ka moliaola na Iehova kou Akua, no ka poe hipa a me ka bipi ma kahi a Iehova e wae ai e hoopaa i kona inoa malaila.
\q1 
\v 3 Mai ai pu oe me ia i ka berena hu: i na la ehiku e ai oe i ka berena hu ole me ia, i ka berena o ka poino; no ka mea, ua hele mai oe mai ka aina o Aigupita mai me ka lalelale, i hoomanao oe i ka la au i hele mai ai mailoko mai o ka aina o Aigupita i na la a pau o kou ola ana.
\q1 
\v 4 I na la ehiku aole e ikeia ka berena hu me oe ma kou mau wahi a pau; aole e waiho oe a ao ka po i kekahi io o ka mea au i kalua ai i ka la mua i ke ahiahi.
\q1 
\v 5 Mai pepehi oe i ka moliaola ma kou mau ipuka a pau a Iehova kou Akua i haawi mai ai ia oe:
\q1 
\v 6 Aka, ma kahi a Iehova kou Akua i wae ai e hoopaa i kona inoa, malaila oe e pepehi ai i ka moliaola i ke ahiahi, i ka napoo ana o ka la, i ka manawa au i puka ae mai Aigupita mai.
\q1 
\v 7 A e hoolapalapa oe ia mea, a e ai iho ma kahi a Iehova kou Akua e wae ai: a kakahiaka e huli ae oe a hoi i kou mau halelewa.
\q1 
\v 8 I na la eono oe e ai ai i ka berena hu ole; a i ka hiku o ka la, he halawai no Iehova kou Akua; mai hana oe i ka hana.
\b
\q1 
\v 9 E helu oe i na hebedoma ehiku nou; mai ka manawa e hoomaka'i e oki i ka palaoa, e hoomaka'i oe e helu i na hebedoma ehiku.
\q1 
\v 10 A e malama oe i ka ahaaina o na hebedoma na Iehova kou Akua me ka makanaaloha ma kou lima au e haawi wale aku, e like me ka Iehova kou Akua i hoopomaikai ai ia oe.
\q1 
\v 11 A e olioli oe imua o Iehova kou Akua, o oe, a me kau keikikane, a me kau kaikamahine, a me kau kauwakane a me kau kauwawahine, a me ka Levi iloko o kou mau ipuka, a me ka malihini, a me ka mea makua ole, a me ka wahinekanemake me oe, ma kahi a Iehova kou Akua i wae ai e hoopaa i kona inoa malaila.
\q1 
\v 12 A e hoomanao hoi oe, he kauwa luhi no oe ma Aigupita; a e malama, e hana hoi i keia mau kanawai.
\b
\q1 
\v 13 E malama oe i ka ahaaina kauhalelewa i na la ehiku, mahope o kau ohi ana i kau palaoa a me kau waina.
\q1 
\v 14 A e olioli oe i kau ahaaina, o oe, a me kau keikikane, me kau kaikamahine, a me kau kauwakane, a me kau kauwawahine, a me ka Levi, a me ka malihini, a o ka mea makua ole, a me ka wahinekanemake iloko o kou mau ipuka.
\q1 
\v 15 I na la ehiku oe e ahaaina ai na Iehova kou Akua, ma kahi a Iehova i wae ai; no ka mea, e hoomaikai o Iehova kou Akua ia oe, ma kau loaa ana a pau, a ma na hana a pau a kou lima; a e olioli nui no oe.
\b
\q1 
\v 16 Ekolu manawa i ka makahiki hookahi e hoikeia na kane a pau ou imua o Iehova kou Akua, ma kahi ana i wae ai: i ka ahaaina berena hu ole, i ka ahaaina o na hebedoma, a me ka ahaaina kauhalelewa: aole e hoike wale ia o lakou imua o Iehova;
\q1 
\v 17 O kela kanaka keia kanaka me ka makana a kona lima, e like me ka pomaikai a Iehova kou Akua i haawi mai ai ia oe.
\b
\q1 
\v 18 A e hoonoho oe i na lunakanawai a me na ilamuku ma kou mau ipuka a pau a Iehova kou Akua i haawi mai ai nou ma kou mau ohana, a e hooponopono lakou i na kanaka me ka hoopono pololei.
\q1 
\v 19 Mai pale ae oe i ka pono, aole hoi e nana aku i na maka, aole hoi oe o lawe i ke kipe; no ka mea, ke hoomakapo ke kipe i na maka o ka poe naauao, a ke hoololi ae i na mea o ka poe pono.
\q1 
\v 20 O ka pono io kau e hahai ai, i ola'i oe, a i hooliloia'i nou ka aina a Iehova kou Akua i haawi mai ai ia oe.
\b
\q1 
\v 21 Mai kanu oe i ululaau o kela laau o keia laau nou e kokoke ana i ke kuahu o Iehova kou Akua au e hana'i nou.
\q1 
\v 22 Mai kukulu hoi oe i kii nou, ka mea ia a Iehova kou Akua e inaina ai.
\c 17
\b
\q1 
\v 1 MAI kaumaha aku oe ia Iehova kou Akua i ka bipikane a i ka hipa paha, ina he wahi mea kina iki kona, a he wahi mea ino paha: no ka mea, he mea hoowahawahaia 2 Iehova kou Akua.
\b
\q1 
\v 2 Ina paha i loaa iwaena o oukou ma kou mau ipuka a Iehova kou Akua i haawi mai ai ia oe, he kanaka, he wahine paha, i hana hewa imua o Iehova kou Akua i ka pale aku i kana berita,
\q1 
\v 3 A ua hele aku ia, a ua malama aku i na akua e, a ua hoomana aku ia lakou, i ka la paha, i ka mahina paha, a i kekahi paha o ko ka lani mau mea, a'u i kauoha ole aku ai:
\q1 
\v 4 A ua haiia ia oe, a ua lohe, a ua ninau pono oe, aia hoi, he oiaio no ia, ua hanaia keia mea ino iloko o ka Iseraela:
\q1 
\v 5 Alaila e lawe mai oe i kela kanaka, a i kela wahine paha, i ka mea nana i hana keia mea hewa, ma kou mau ipuka, i ke kanaka, i ka wahine paha, a e hailuku ia lakou i ka pohaku a make lakou.
\q1 
\v 6 Ma ka waha o na mea hoike elua, ekolu paha mea hoike, e pepehiia'ku ai ka mea pono no ka make; aole e pepehiia oia a make ma ka waha o ka mea hoike hookahi.
\q1 
\v 7 O na lima o na mea hoike ke kau mua maluna ona e pepehi ia ia, a o na lima o na kanaka a pau mahope aku; a pela oe e, hookaawale aku ai i ka hewa mai ou aku la.
\b
\q1 
\v 8 Ina paha he mea hihia pohihihi ia oe ke hooponopono iwaena o kahi koko a me kahi koko, iwaena o kahi pono a me kekahi pono, iwaena o kahi hahau ana a me kekahi hahau ana, he mea hookolokolo ma kou mau ipuka; alaila e ku oe a pii aku ma kahi a Iehova i wae ai,
\q1 
\v 9 A hele aku i na kahuna, i ka Levi, a i ka lunakanawai e noho ana o ia mau la, a e ninau aku; a e hai mai lakou ia oe i ka olelo o ka hooponopono ana.
\q1 
\v 10 A e hana aku oe e like me ka olelo a lakou e hai mai ai ia oe ma kela wahi a Iehova i wae ai; a e malama e hana aku e like me ka lakou i hai mai ai ia oe;
\q1 
\v 11 E like me ka olelo o ke kanawai a lakou e hoike mai ai ia oe, a e like me ka hooponopono ana a lakou e olelo mai ai ia oe, pela oe e hana'i: mai huli ae oe mai ka olelo aku a lakou e hoike mai ai ia oe, ma ka akau, aole hoi ma ka hema.
\q1 
\v 12 A o ke kanaka e hana aku me ke kiekie, aole e hoolohe i ke kahuna e ku ana e lawelawe na Iehova kou Akua malaila, aole hoi i ka lunakanawai, e make ua kanaka la; a e lawe aku oe i ka hewa mai ka Iseraela aku.
\q1 
\v 13 A e hoolohe na kanaka a pau, e makau, aole e hana hookiekie hou aku.
\b
\q1 
\v 14 A hiki aku oe ma ka aina a Iehova kou Akua e haawi mai ai ia oe, a lilo ia nou, a noho oe ilaila, a e olelo iho oe, E hoonoho au i alii maluna o'u, e like me na lahuikanaka a puni o'u:
\q1 
\v 15 He oiaio, e hoonoho oe maluna ou i ke alii a Iehova kou Akua e wae ai; o kekahi mai waena mai o kou poe hoahanau kau e hoonoho ai i alii maluna ou: mai hoonoho oe i ke kanaka e maluna ou, i ka mea aole o kou hoahanau.
\q1 
\v 16 Aka, mai hoomahuahua oia i na lio nona, aole hoi ia e hoihoi i na kanaka i Aigupita, i mea e hoomahuahua ai ia i na lio: no ka mea, ua olelo mai o Iehova ia oukou, Mai hoi hou aku oukou ilaila.
\q1 
\v 17 Mai hoomahuahua hoi oia i na wahine nana, o huli ae kona naau; aole hoi ia e hoomahuahua loa ae i ke kala a me ke gula nona.
\b
\q1 
\v 18 A i kona manawa e noho ai maluna o ka nohoalii o kona aupuni, e kakau iho ia nana i kope o keia kanawai, e like me ka buke imua o ka poe kahuna, na mamo a Levi.
\q1 
\v 19 Me ia no ia e waiho ai, a e heluhelu no oia ia mea i na la a pau o kona oia ana; i aoia'i oia i ka makau ia Iehova kona Akua, e malama i na huaolelo a pau o keia kanawai, a me keia mau kauoha, e hana aku ia mau mea:
\q1 
\v 20 I hookiekie ole ai ia i kona naau maluna o kona poe hoahanau, i huli ole aku ia mai ke kauoha ae, ma ka akau, aole hoi ma ka hema; i mea e nui ai na la o kona aupuni, oia a me kana mau keiki iwaena o ka Iseraela.
\c 18
\b
\q1 
\v 1 O NA kahuna, na Levi, o na ohana a pau a Levi, aohe o lakou kuleana, aohe aina hooili me ka Iseraela: e ai no lakou i na mohai no Iehova i puhi i ke ahi, a me ka mea e ili mai ana nona.
\q1 
\v 2 No ia mea, aole o lakou aina hooili iwaena o ko lakou poe hoahanau; o Iehova oia ko lakou hooilina e like me kana i olelo mai ai ia lakou.
\b
\q1 
\v 3 Eia ka ke kahuna wahi na na kanaka mai, na ka poe e kaumaha aku i ka mohai, i ka bipikane paha, i ka hipa paha: a e haawi aku lakou i ka uha mua a me na papalina elua, a me ka opu na ke kahuna.
\q1 
\v 4 O ka hua mua o kau palaoa, o kou waina, a me kou aila, a o ka hulu ako mua o kau poe hipa, o kau ia e haawi aku ai nana.
\q1 
\v 5 No ka mea, ua wae mai o Iehova ia ia mailoko mai o kou mau ohana a pau, e ku e lawelawe ma ka inoa o Iehova, oia a me kana mau keiki i na la a pau loa.
\b
\q1 
\v 6 Ina paha e hele mai kekahi o ka Levi mailoko mai o kekahi o kou mau ipuka o ka Iseraela a pau ana i noho malihini ai; a e hele mai ia me ka makemake a pau o kona naau ma kahi a Iehova e wae ai;
\q1 
\v 7 Alaila e lawelawe no ia ma ka inoa o Iehova kona Akua, e like me kona poe hoahanau a pau, o ka Levi e ku ana malaila imua o Iehova.
\q1 
\v 8 E hoohalikeia ka lakou mea e ai ai, a o kona waiwai hoi i kuaiia na na makua mai.
\b
\q1 
\v 9 A hiki aku oe ma ka aina a Iehova kou Akua e haawi mai ai ia oe, mai ao iho oe e hana e like me na mea haumia o ua mau lahuikanaka la.
\q1 
\v 10 Aole e ikeia iwaena o oukou ka mea nana e kuu aku i kana keikikane a i kana kaikamahine paha e hele mawaena o ke ahi; aole hoi he kahuna anaana, aole he mea nana i ke ao, aole hoi he mea nana moo, aole ka mea kilo;
\q1 
\v 11 Aole hoi he mea hoowalewale i na nahesa, aole hoi he mea ninau i na uhane ino, aole hoi he kupua, aole he mea ninau i ka poe make.
\q1 
\v 12 No ka mea, o ka poe a pau e hana ana ia mea, ua haumia lakou imua o Iehova: no keia mau mea hoohaumia, na Iehova kou Akua e kipaku aku ana ia lakou mai kou alo aku.
\q1 
\v 13 E hemolele oe imua o Iehova kou Akua.
\b
\q1 
\v 14 No ka mea, o keia mau lahuikanaka e lilo ana nou, ua hoolohe lakou i na mea nana i ke ao, a me na kahuna anaana: aka o oe, aole o Iehova kou Akua i ae mai ia oe e hana pela.
\b
\q1 
\v 15 E hooku mai auanei o Iehova kou Akua mai waena mai ou i Kaula nou, i kekahi hoahanau on e like me au, e hoolohe oukou ia ia;
\q1 
\v 16 E like me ka mea a pau na i noi aku ai ia Iehova kou Akua ma Horeba, i ka la i houluulu ai, i ka i ana'ku, Aole au e lohe hou i ka leo o Iehova ko'u Akua, aole hoi au e ike hou i keia ahi nui, o make au.
\q1 
\v 17 I mai la o Iehova ia'u, He pono ka lakou i olelo mai ai.
\q1 
\v 18 E hooku auanei au i Kaula no lakou no waena mai o ko lakou poe hoahanau, e like me oe, a e waiho ana au i ka'u mau olelo maloko o kona waha; a nana e olelo aku ia lakou ka mea a pau a'u e kauoha aku ai ia ia.
\q1 
\v 19 A o ke kanaka hoolohe ole i ka'u mau olelo, ana e olelo aku ai ma ko'u inoa, na'u no ia e hoopai aku.
\q1 
\v 20 A o ke kaula e aa ana e olelo aku i kekahi olelo ma ko'u inoa i ka mea a'u i kauoha ole aku ai ia ia e olelo, a e olelo aku paha ia ma ka inoa o na akua e, e make ua kaula la.
\q1 
\v 21 Ina e i iho oe iloko o kou naau, Pehea la makou e ike ai i ka olelo a Iehova i olelo ole mai ai?
\q1 
\v 22 A i olelo aku kekahi kaula ma ka inoa o Iehova, a hiki ole mai ia mea, aole hoi ia e ko, oia ka mea a Iehova i olelo ole mai ai; ua olelo aku ua kaula la me ka hookiekie; mai makau aku oe ia ia.
\c 19
\b
\q1 
\v 1 A IA hoopau o Iehova kou Akua i na lahuikanaka, no lakou ka aina a Iehova kou Akua e haawi mai ai nou, a lilo ko lakou wahi nou, a e noho iho oe ma ko lakou kulanakauhale, a maloko hoi o ko lakou mau hale;
\q1 
\v 2 Alaila e hookaawale oe i na kulanakauhale ekolu nou iwaena o kou aina a Iehova kou Akua e haawi lilo mai ai nou.
\q1 
\v 3 E hoomakaukau i alanui nou, a o kou aina a Iehova kou Akua i hoolilo mai ai nou, o kau ia e mahele i na mokuna ekolu, i holo ai na pepehi kanaka a pau ilaila.
\b
\q1 
\v 4 Eia ke ano o ka pepehi kanaka e holo ai ilaila i ola ia: o ka mea pepehi i kona hoalauna me ka ike ole, aole ia i inaina aku ia ia mamua;
\q1 
\v 5 A o ka mea e hele aku i ka ululaau me kona hoalauna e kua laau, a hahau iho kona lima me ke koilipi e oki i ka laau, a hemo aku la ke koilipi mai ke au aku, a pa i kona hoalauna a make ia, e holo aku ia i kekahi o ia mau kulanakauhale, a ola;
\q1 
\v 6 O hahai auanei ka hoopai koko mahope o ka pepehi kanaka i kona wa e ukiuki ai kona naau, no ka mea, ua loihi ke ala, a pepehi ia ia; aole nae ona hewa e make ai, no ka mea, aole ia i inaina aku ia ia mamua.
\q1 
\v 7 No ia mea, ke kauoha aku nei au ia oe, i ka i ana'ku, E hookaawale nou i na kulanakauhale ekolu.
\q1 
\v 8 Ina e hoopalahalaha o Iehova kou Akua i kou mokuna e like me kana i hoohiki ai i kou mau kupuna, a haawi ia oe i ka aina a pau ana i olelo ni e haawi i kou mau kupuna:
\q1 
\v 9 Ina paha oe e malama i keia mau kauoha a pau e hana aku ia mea a'u e kauoha aku nei ia oe i keia la, e aloha aku in Iehova kou Akua, a e hele ma kona aoao i na la a pau, alaila e hookaawale oe nou i na kulanakauhale hou ekolu me kela mau mea ekolu:
\q1 
\v 10 I ole e hookaheia ke koko hala ole iloko o kou aina a Iehova kou Akua i hoolilo mai ai nou, a maluna ou ke koko.
\b
\q1 
\v 11 Aka, ina e inaina aku kekahi kanaka i kona hoalauna, a halua ia ia, a popoi ia ia, a hahau ia ia a make ia, a holo aku ia iloko o kekahi o keia mau kulanakauhale:
\q1 
\v 12 Alaila e hoouna aku na lunakahiko o kona kulanakauhale, a e lawe ia ia mai laila mai. a haawi aku ia ia iloko o ka lima o ka mea hoopai koko, i make ai oia.
\q1 
\v 13 Mai minamina kou maka ia ia; aka, e huikala aku oe i ke koko hala ole mai ka Iseraela aku, i pomaikai ai oe.
\b
\q1 
\v 14 Mai hoonee aku oe i ka palena aina o kou hoalauna a ka poe kahiko i hoonoho ai ma kou aina, au i loaa ai ma ka aina a Iehova kou Akua e hoolilo mai ai nou.
\b
\q1 
\v 15 Mai ku mai ka mea hoike hookahi i ke kanaka, no kekahi hala, a no kekahi hewa i na hewa a pau ana i hana hewa ai: ma ka waha o na mea hoike elua, a o na mea hoike ekolu paha, e hookupaaia'i ia mea.
\b
\q1 
\v 16 Ina paha e ku mai ka mea hoike hewa i kekahi kanaka, a hoike wahahee ia ia;
\q1 
\v 17 Alaila, o laua, na mea hoopaapaa, e ku imua o Iehova, imua o na kahuna a me na lunakanawai e noho ana ia manawa;
\q1 
\v 18 A e imi pono na lunakanawai: aia hoi, he wahahee ka mea nana i hoike, a ua hoike wahahee i kona hoahanau:
\q1 
\v 19 Alaila e hana aku oukou ia ia e like me kana i manao ai e hana aku i kona hoahanau: a e lawe aku oe i ka hewa mai ou aku la.
\q1 
\v 20 A e hoolohe ka poe i koe, a makau hoi, aole e hana hou lakou e like me keia hewa iwaena o oukou.
\q1 
\v 21 Mai minamina kou maka; he ola no ke ola; he maka no ka maka; he niho no ka niho; he lima no ka lima; he wawae no ka wawae.
\c 20
\b
\q1 
\v 1 A IA hele oe e kaua aku i kou poe enemi, a ike aku i na lio a me na halekaa, a i na kanaka he nui aku i kou, mai makau ia lakou: no ka mea, me oe no o Iehova o kou Akua, nana oe i lawe mai nei mai ka aina o Aigupita mai.
\q1 
\v 2 A kokoke oukou e hoouka, alaila e hookokoke mai ke kahuna, a e olelo aku i na kanaka,
\q1 
\v 3 E i aku ia lakou, E hoolohe, e ka Iseraela, Ke hookokoke oukou i keia la e kaua aku i ko oukou poe enemi: mai hoonawaliwaliia ko oukou naau, mai makau, mai pihoihoi, mai weliweli ia lakou:
\q1 
\v 4 No ka mea, o Iehova ko oukou Akua, oia ke hele me oukou e kaua aku no oukou i ko oukou poe enemi, a e hoopakele ia oukou.
\b
\q1 
\v 5 Ae olelo aku na luna i na kanaka, i ka i ana'ku, Owai ke kanaka i kukulu i hale hou, aole nae i hoolilo aku? e hele ia a hoi aku i kona hale, o make auanei ia i ke kana, a o ke kanaka e ke hoolilo aku ia.
\q1 
\v 6 Owai la ke kanaka i kana i ka malawaina, aole nae i ohi i ka hua? e hele ia, a hoi aku i kona hale, o make auanei ia i ke kaua, a e ohi ke kanaka e i ka hua.
\q1 
\v 7 Owai ke kanaka i hoopalau i ka wahine, aole nae i lawe ia ia? e hele no ia, a hoi aku i kona hale, o make auanei ia i ke kana, a e lawe ke kanaka e ia ia.
\q1 
\v 8 A e olelo hou na luna i na kanaka, a e i aku, Owai la ke kanaka makau a nawaliwali ma ka naau? e hele no ia, a e hoi aku i kona hale, o hee auanei ka naau o kona poe hoahanau e like me kona naau.
\q1 
\v 9 A pau ka olelo a na luna i na kanaka, alaila e hoonoho lakou i na luna o ke kaua i alakai no na kanaka.
\b
\q1 
\v 10 Aia hookokoke aku oe i ke kalanakauhale e kaua aku ia ia, e hai aku oe i ka mea e malu ai ia.
\q1 
\v 11 A ina i ae mai ia i ka mea e malu ai, a wehe mai ia nou, alaila e lilo na kanaka a pau i loaa malaila i mea hookupu nau, a e hookauwa mai lakou nau.
\q1 
\v 12 A i ole ia e ae mai i ka mea e malu ai me oe, aka, e hana mai ia i ke kaua me oe, alaila oe e hoopuni aku ai ia ia.
\q1 
\v 13 Aia hoolilo mai o Iehova kou Akua ia ia iloko o kou lima, alaila e luku oe i na kane a pau o ia wahi me ka maka o ka pahikaua.
\q1 
\v 14 Aka, o na wahine a me na kamalii, a me na holoholona, a me na mea a pau iloko o ke kulanakauhale, a me kona waiwai pio a pau, e lawe pio oe ia mau mea nau; a e ai iho oe i ka waiwai pio o kou poe enemi a Iehova kou Akua i haawi mai ai ia oe.
\q1 
\v 15 Pela oe e hana aku ai i na kulanakauhale a pau i mamao loa aku ia oe, aole no na kulanakauhale o keia mau lahuikanaka.
\q1 
\v 16 Aka, o na kulanakauhale o keia poe kanaka a Iehova kou Akua i haawi mai ai nou, mai hoola oe i kekahi mea e hanu ana.
\q1 
\v 17 E luku loa aku ia lakou: i ka Heta, i ka Amora, i ka Kanaana, i ka Periza, i ka Heva, a me ka Iebusa, e like me ka Iehova kou Akua i kauoha mai ai ia oe:
\q1 
\v 18 O ao mai auanei lakou ia oukou e hana aku e like me ka lakou mea haumia i hana aku ai lakou i ko lakou mau akua; a e hana hewa oukou ia Iehova i ko oukou Akua.
\b
\q1 
\v 19 Ina e loihi kou hoopilikia ana i kekahi kulanakauhale i ke kaua ana aku e hoopio ia ia, mai luku wale oe i kona laau i ka hahau ana ia mea i ke koilipi; no ka mea, e ai paha oe i kona, mai kua ilalo oe ia mea, i mea e pono ai ke kaua ana; no ka mea, no ke kanaka ka laau o ke kula.
\q1 
\v 20 O ka laau au i ike ai aole he laau ai, oia wale no kau e luku aku, a e kua ilalo, a kukulu iho me ia i pakaua no ke kulanakauhale i kaua mai ai ia oe, a hiolo ia.
\c 21
\b
\q1 
\v 1 I NA ma ka aina a Iehova kou Akua i haawi mai ai ia oe, a lilo ia nou, i loaa ka mea i pepehiia e waiho ana ma ke kula, aole i ikeia ka mea nana i pepehi:
\q1 
\v 2 Alaila e hele mai kou poe lunakahiko a me kou poe lunakanawai, a e ana aku lakou a hiki i na kulanakauhale e puni ana i ka mea i pepehiia.
\q1 
\v 3 A o ke kulanakauhale kokoke i ka mea i pepehiia, o na lunakahiko o ia kulanakauhale e lawe lakou i ka bipiwahine hou i hoohana ole ia, aole hoi i kauo iloko o ka auamo;
\q1 
\v 4 A o na lunakahiko o ia kulanakauhale e alakai aku i ka bipiwahine hou ma ke kahawai e kahe mau ana, ma kahi mahi ole ia, aole hoi i luluia, a malaila lakou e oki ai i ke poo o ua bipiwahine la ma ke kahawai:
\q1 
\v 5 A o na kahuna, na mamo a Levi e hookokoke mai; no ka mea, ua wae mai o Iehova kou Akua ia lakou e lawelawe nana, a e hoomaikai aku ma ka inoa o Iehova, aia no ia lakou ka olelo no na hakaka a me na hahau ana a pau.
\q1 
\v 6 A o na lunakahiko a pau o ke kulanakauhale e kokoke ana i ka mea i pepehiia, e holoi i ko lakou lima maluna o ka bipiwahine i okiia o kona poo ma ke kahawai:
\q1 
\v 7 A e olelo mai lakou, e i mai, Aole ko makou lima i hookahe i keia koko, aole hoi i ike ko makou maka.
\q1 
\v 8 E Iehova, e kala mai i kou poe kanaka, i ka Iseraela au i hoola ai, a mai hoopai i ke koko hala ole maluna o kou poe kanaka o ka Iseraela: a e kalaia ke koko no lakou.
\q1 
\v 9 A pela e huikala aku ai oe i ke koko hala ole mai ou aku la, no ka mea, ua hana oe i ka pono imua o Iehova.
\b
\q1 
\v 10 Aia hele aku oe e kaua aku i kou poe enemi, a e hoolilo mai o Iehova kou Akua ia lakou iloko o kou lima, a e lawe pio aku oe ia lakou,
\q1 
\v 11 A ike aku oe i wahine maikai iwaena o ka poe pio, a makemake oe e lawe ia ia i wahine nau;
\q1 
\v 12 Alaila e lawe oe ia ia ma kou hale; a e ako iho oia i kona poo, a e oki hoi i kona maiuu;
\q1 
\v 13 A e waiho aku ia i ka aahu pio mai ona aku la, a e noho ia ma kou hale, a e uwe iho ia i kona makuakane, a me kona makuwahine i hookahi malama; a mahope aku e komo aku oe iloko io na la e lilo i kane nana, a e lilo ia i wahine nau.
\q1 
\v 14 A ina aole oe e makemake ia ia, e kuu aku oe ia ia e hele i kona wahi e makemake ai; mai kuai aku oe ia ia no ke kala, aole hoi oe e hoolilo ia ia i waiwai nau, no ka mea, ua hoohaahaa oe ia ia.
\b
\q1 
\v 15 Ina elua wahine a kekahi kanaka, ua alohaia kekahi, na aloha ole ia kekahi, a o ka mea alohaia, a me ka mea aloha ole ia i hanau keiki nana: a ina na ka wahine aloha ole ia ka makahiapo;
\q1 
\v 16 Alaila, i ka manawa e hooili ai oia i kona waiwai i kana mau keikikane, aole ia e haawi i ka ka hanau mua na ke keiki a ka mea alohaia mamua o ke keiki a ka mea aloha ole ia, oia ka hiapo maoli:
\q1 
\v 17 Aka, e hoolilo ia i ke keikikane a ka mea aloha ole ia i hiapo, a e haawi papalua ia ia o kona loaa a pau; no ka mea, oia ka mua o kona ikaika, a nona ka pono o ka hanau mua.
\b
\q1 
\v 18 A o ke kanaka ia ia ke keiki hewa, paakiki, aole e hoolohe i ka leo o kona makuakane, a me ka leo o kona makuwahine, a ia laua i ao aku ai ia ia, aole ia i maliu mai ia laua;
\q1 
\v 19 Alaila e lalau aku kona makuakane a me kona makuwahine ia ia, a e lawe aku ia ia i na lunakahiko o kona kulanakauhale, a i ka ipuka o kona wahi:
\q1 
\v 20 A e olelo aku i na lunakahiko o kona kulanakauhale, Ua hewa, a ua paakiki keia keiki a maua, aole ia i hoolohe i ko maua leo, ua pakela ai, a ua ona.
\q1 
\v 21 A o na kanaka a pau o kona kulanakauhale e hailuku ia ia i ka pohaku e make ia; a e lawe aku oe i ka hewa mai ou aku la; a e hoolohe ka Iseraela a pau a e makau hoi.
\b
\q1 
\v 22 Ina e hana hewa kekahi kanaka e pono ai ke make, a e pepehiia oia, a e kau aku oe ia ia maluna o ka laau;
\b
\q1 
\v 23 Aole e waiho i kona kino a ao ka po maluna o ka laau, aka, e kanu no ia ia ia la, (no ka mea, ua hoinoia e ke Akua ka mea i kaulia,) i haumia ole ai kou aina a Iehova kou Akua i haawi lilo mai ai i wahi e noho ai nou.
\c 22
\b
\q1 
\v 1 A IKE aku oe i ka bipi a kou hoahanau, a i kana hipa paha e auwana ana, mai haalele oe ia lakou; nau no lakou e hoihoi mai i kou hoahanau.
\q1 
\v 2 Ina aole kokoke mai kou hoahanau ia oe, a ua ike ole paha oe ia ia, alaila oe e lawe mai ia mea i kou hale iho, a e noho pu ia me oe, a hiki i ka manawa e imi mai ai kou hoahanau ia ia, alaila e hoihoi aku oe ia mea ia ia.
\q1 
\v 3 Pela kau e hana aku ai i kona hoki, a pela hoi kau e hana aku ai i kona kapa; a me na mea a pau a kou hoahanau i haule, a i nalowale ia ia, a i loaa ia oe, pela hoi oe e hana aku ai; aole oe e haalele aku.
\b
\q1 
\v 4 Ina e ike oe i ka hoki, a i ka bipi paha a kou hoahanau i haule iho ma ke ala, mai haalele aku oe ia lakou, nau no ia e kokua aku e hoala hou ae.
\b
\q1 
\v 5 Aole e komo ka wahine i ke kapa o ke kane, aole hoi e komo ke kane i ke kapa o ka wahine: no ka mea, o na mea a pau e hana ana pela, ua haumia lakou ia Iehova kou Akua.
\b
\q1 
\v 6 A i ikea ka punana manu imua ou ma ke ala, ma kekahi laau, a ma ka honua paha, a he ohana paha, a he hua paha, a e hoomoe ana ka makua maluna o na ohana, a o na hua paha, mai lawe pu oe i ka makua me na keiki.
\q1 
\v 7 E kuu aku no oe i ka makua, a e lawe i na keiki nau: i pomaikai oe, i loihi ai hoi kou mau la.
\b
\q1 
\v 8 A i kukulu oe i hale hou, e hana ae i pa a puni maluna iho, i hooili ole mai ai oe i ke koko maluna o kou hale, ke haule iho kekahi mai laila mai.
\b
\q1 
\v 9 Mai kanu oe ma kou malawaina i na hua ku e na ano, o laa auanei ka hua o kau mea i kanu, a me ka hua o kou malawaina.
\b
\q1 
\v 10 Mai kaulua oe i ka bipi a me ka hoki ma ka oopalau.
\b
\q1 
\v 11 Mai aahu oe i ke kapa ku e na ano, o ka huluhipa i hui pu ia me ke olona.
\b
\q1 
\v 12 E hana oe i pihapiha ma na aoao eha o kou aahu au e aahu ai.
\b
\q1 
\v 13 A i lawe kekahi kanaka i wahine nana, a moe me ia, a i inaina ia ia,
\q1 
\v 14 A olelo ino ia ia, a hookaulana i kona inoa ma ka hewa, i ka i ana'ku, Ua lawe au i keia wahine, a i kuu hele ana io na la, aole i loaa ia'u ia he puupaa.
\q1 
\v 15 Alaila e lawe ka makuakane o ke kaikamahine, a me kona makuwahine, a hali aku i na hoailona puupaa o ke kaikamahine i na lunakahiko o ke kulanakauhale ma ka ipuka:
\q1 
\v 16 A e olelo aku ka makuakane o ke kaikamahine i na lunakahiko, Haawi aku la au i kuu kaikamahine i wahine na koia kanaka, a ua inaina mai oia ia ia;
\q1 
\v 17 Aia hoi, ua olelo ino mai oia ia ia, i ka i ana mai, Aole i loaa ia'u kau kaikamahine, ho puupaa; aka, oia na hoailona puupaa o kuu kaikamahine: a o hohola ae la laua i ke kapa imua o na lunakahiko o ke kulanakauhale.
\q1 
\v 18 A e lawe na lunakahiko o ia kulanakauhale i kela kanaka a e hahau ia ia;
\q1 
\v 19 A e hoouku ia ia i hookahi haneri sekela kala, a e haawi aku ia no ka makuakane o ke kaikamahine; no ka mea, ua hookaulana aku ia i ka inoa o ka wahine puupaa o ka Iseraela ma ka hewa: a e lilo ia i wahine nana; aole ia e hookuke aku ia ia i kona mau la a pau.
\q1 
\v 20 Aka, ina he oiaio keia mea, aole i loaa na hoailona puupaa no ke kaikamahine;
\q1 
\v 21 Alaila e lawe mai lakou i ke kaikamahine iwaho o ka puka hale o kona makuakane, a e hailuku aku na kanaka o ia kulanakauhale ia ia i ka pohaku e make ia; no ka mea, ua hana ino ia iloko o ka Iseraela, ua moe koloho iloko o ka hale o kona makuakane; a e lawe aku oe i ka hewa mai ou aku la.
\b
\q1 
\v 22 A i loaa ke kanaka e moe ana me ka wahine i mareia na ke kane, alaila e make laua a elua, o ke kane i moe pu me ka wahine, laua o ka wahine. Pela oe e hemo aku ai i ka ino mai ka Iseraela aku.
\b
\q1 
\v 23 O ke kaikamahine puupaa i hoopalauia na ke kane, a loaa oia i ke kanaka maloko o ke kulanakauhale, a moe pu me ia;
\q1 
\v 24 Alaila e kai aku oukou ia laua a elua ma ka ipuka o ke kulanakauhale, a e hailuku oukou ia laua i ka pohaku, a make laua; o ke kaikamahine no kona hooho ole ana: a o ke kanaka no kona hoohaahaa ana i ka wahine a kona hoalauna: pela oukou e hemo aku ai i ka ino mai waena aku o oukou.
\b
\q1 
\v 25 Aka, a i loaa i ke kanaka ma ke kula kekahi kaikamahine i hoopalauia, a hoopaa iho oia ia ia, a moe pu me ia; alaila, o ke kanaka wale no i moe me ia ke make:
\q1 
\v 26 Aka, mai mea iki aku oe i ke kaikamahine; aohe ona hewa e make ai: no ka mea, e like me ke kanaka i ku e i kona hoalauna, a pepehi iho ia ia, pela hoi keia mea.
\q1 
\v 27 No ka mea, ua loaa oia ia ia ma ke kula, a ua hooho aku la ua kaikamahine la i hoopalauia, aole nae he mea nana ia o hoopakele.
\b
\q1 
\v 28 A i loaa i ke kanaka ke kaikamahine puupaa i hoopalau ole ia, a lalau aku ia ia ia, a moe me ia, a ua loaa pono laua;
\q1 
\v 29 Alaila e uku aku ko kanaka i moe me ia i kanalima sekela na ka makuakane o ua kaikamahine la, a o lilo ia i wahine nana; no kona hoohaahaa ana ia ia, aole ia e hookuke aku ia ia a pau na la ona.
\b
\q1 
\v 30 Mai lawe ke kanaka i ka wahine a kona makuakane, aole hoi e wehe i ke kapa o kona makuakane.
\c 23
\b
\q1 
\v 1 A OLE e komo iloko o ke anainakanaka o Iehova ke kanaka i paopaoia a i okiia kona mea huna.
\q1 
\v 2 Aole e komo iloko o ke anainakanaka o Iehova ka mea poo ole, a hiki i ka umi o kona hanauna aole e komo iloko o ke anainakanaka o Iehova.
\q1 
\v 3 Aole e komo iloko o ke anainakanaka o Iehova ka Amora, a me ka Moaba, a hiki i ka umi o ko lakou hanauna, aole loa e komo iloko o ke anainakanaka o Iehova:
\q1 
\v 4 No ka mea, aole lakou i hele mai io oukou la me ka berena a me ka wai ma ke ala i ko oukou hele ana, mai Aigupita mai; a no ka lakou uku ana'ku ia Balaama, ke keiki a Beora o Petora ma Mesopotamia e ku o ia oukou, a e hoino aku ia oukou.
\q1 
\v 5 Aole nae o Iehova kou Akua i hoolohe ia Balaama; aka, ua hoohuli ae o Iehova kou Akua i ka hoino i hoomaikai nou; no ka mea, ua aloha o Iehova kou Akua ia oe.
\q1 
\v 6 Mai imi oe i ko lakou malu, aole hoi i ko lakou pono i kou mau la a pau.
\b
\q1 
\v 7 Mai hoowahawaha oe i ka Edoma, no ka mea, oia kou hoahanau: mai hoowahawaha i ko Aigupita, no ka mea, ua malihini oe ma kona aina.
\q1 
\v 8 O na keiki i hanau na lakou i ka hanauna ekolu, e komo lakou iloko o ke anainakanaka o Iehova.
\b
\q1 
\v 9 A hele aku ka poe kaua e ku e i kou poe enemi, e malama ia oe iho i na mea ino a pau.
\b
\q1 
\v 10 Ina paha mawaena ou kekahi kanaka maemae ole no ka haumia i hiki mai ia ia i ka po, e hele ia iwaho o kahi e hoomoana'i, aole ia e hele mai iloko o kahi e hoomoaua'i:
\q1 
\v 11 Aia i ka manawa e hiki mai ana ke ahiahi, e holoi ia ia iho i ka wai; a i ka napo ana o ka la, e hele mai ia iloko o kahi e hoomoana'i.
\b
\q1 
\v 12 A e hookaawale oe i kauwahi nou mawaho o kahi hoomoana, i hele aku ai oe malaila:
\q1 
\v 13 A i wahi oo nou kekahi mea kaua, a i kou hoomaha ana mawaho, e kohi iho oe me ia, a e huli hou no e kanu oe i ka mea e puka aku ana mailoko ou.
\q1 
\v 14 No ka mea, e hele ana o Iehova kou Akua iwaena o kou wahi o hoomoana'i e hoopakele ia oe, a e hoolilo i kou poe enemi imua ou: nolaila, i maemae kou wahi e hoomoana'i, o ike mai auanei ia i ka mea ino iloko ou, a huli ae ia mai ou aku la.
\b
\q1 
\v 15 O ke kauwa i mahuka mai kona haku a i ou la, mai hoihoi aku oe ia ia i kona haku:
\b
\q1 
\v 16 E noho no ia me oe, mawaena ou, ma kahi ana e wae ai, ma kekahi o kou mau ipuka ana e makemake ai: mai hookaumaha oe ia ia.
\b
\q1 
\v 17 Aole e noho kekahi o na kaikamahine o ka Iseraela i ka moe kolohe, Aole e noho hoi kekahi o na keikikane o ka Iseraela i ka moe kolohe.
\b
\q1 
\v 18 Mai lawe oe iloko o ka hale o Iehova kou Akua i ka uku no ka wahine moe kolohe, aole hoi i ke kumukuai no ka ilio, no kekahi hoohiki ana; no ka mea, ua hoowahawahaia ia mau mea elua e Iehova kou Akua.
\b
\q1 
\v 19 Mai haawi aie aku na kou hoahanau, no ka uku kuala hou ia mai, i uku kuala no ke kala, a i ukn kuala no ka ai, a i uku kuala no kekahi mea i haawi aie ia'ku no ka ukn hou ia mai.
\b
\q1 
\v 20 E pono e haawi aie aku i ke kanaka e i uku hoopanee mai; aka, mai haawi aie i kou hoahanau, i uku nui mai; i hoopomaikai mai ai o Iehova o kou Akua ia oe i na mea a pau a kou lima e lawe ai ma ka aina au e hele aku nei e hooliloia nou.
\b
\q1 
\v 21 Aia hoohiki oe i ka hoohiki ana ia Iehova kou Akua, mai hookaulua oe i ka hooko aku ia; no ka mea, e hoopai io mai o Iehova kou Akua ia mea maluna ou, a e lilo ia i hewa nou.
\q1 
\v 22 Aka, ina aole oe e hoohiki, aole e lilo ia i hewa nou.
\q1 
\v 23 O ka mea a kou lehelehe i olelo aku ai e malama oe, a e hana hoi e like me kau i hoohiki ai ia Iehova kou Akua, i ka mohaialoha a kou waha i olelo aku ai.
\b
\q1 
\v 24 Ina paha e hele oe ma ka malawaina o kou hoalauna, e ai iho oe i na hua waina, a maona oe e like me kou makemake; aka, mai waiho i kekahi iloko o kau ipu.
\b
\q1 
\v 25 A i komo oe iloko o ka mala palaoa a kou hoalauna e ku ana, e lalau oe i ka hua ai me kou lima; aka, mai hookomo i ka pahikakiwi iloko o ka mala palaoa a kou hoalauna e ku ana.
\c 24
\b
\q1 
\v 1 A IA lawe ke kanaka i kekahi wahine a mare ia ia, a loaa ole i ka wahine ke alohaia mai imua o kona maka, no ka loaa i ke kane kekahi kina o ka wahine; alaila e kakau kela i palapala e hemo ai ka wahine, a e haawi aku ia mea ma kona lima, a e hookuke aku ia ia iwaho o kona hale.
\q1 
\v 2 A hala kela iwaho o kona hale, e hele no ia e lilo i wahine na kekahi kane hou.
\q1 
\v 3 Ina e inain ke kane hou ia ia, a kakau nana i palapala no ka hemo ana, a e haawi aku ia mea ma kona lima, a e hookuke aku ia ia mawaho o kona hale; a i make paha ke kane hou, nana ia i lawe i wahine nana:
\q1 
\v 4 O kana kane mamua, nana ia i hookuke aku, aole e pono ia ke lawe hou ia ia i wahine nana, mahope mai o kona haumia ana; no ka mea, he mea hoopailuaia imua o Iehova: mai hana aku oe i ka mea e hewa'i ka aina a Iehova kou Akua e haawi mai ai i wahi e noho ai nou.
\b
\q1 
\v 5 Aia lawe ke kanaka i wahine hou nana, mai hele aku ia me ka poe kaua, aole hoi e kauia maluna ona kekahi hana: e noho kaawale ia ma kona wahi i hookahi makahiki, a e hooluolu aku i kana wahine ana i lawe ai.
\b
\q1 
\v 6 Mai laweia ka mea wili palaoa i uku panai, aole ka pohaku kaa luna; no ka mea, oia ke lawe i ko ke kanaka mea e ola'i i uku panai.
\b
\q1 
\v 7 Ina e ikeia ke kanaka e aihue ana i kekahi hoahanau ona o na mamo a Iseraela, a hoolilo ia ia i kauwa hooluhi, a kuai lilo aku paha ia ia; alaila e make ua kanaka aihue la; a e hoolei aku oe i ka ino mai waena aku o oukou.
\b
\q1 
\v 8 E makaala i ka mai lepera, e malama pono, a e hana aku hoi i na mea a pau a na kahuna, a ka Levi e ao mai ai ia oukou; e like me ka'u i kauoha aku ai ia lakou, pela oukou e malama ai, a e hana'i hoi.
\q1 
\v 9 E hoomanao i ka mea a Iehova kou Akua i hana mai ai ia Miriama ma ke ala, i ko oukou hele ana mai Aigupita mai.
\b
\q1 
\v 10 A i haawi lilo ole oe i kekahi mea i kou hoalauna, mai hele aku iloko o kona hale e kii i kona uku panai.
\q1 
\v 11 Mawaho oe e ku ai, a o ke kanaka ia ia ka mea au i haawi lilo ole, nana no e lawe mai mawaho i ka uku panai ia oe.
\q1 
\v 12 Ina he kanaka ilihune ia, mai hiamoe oe me kona uku panai:
\q1 
\v 13 E hoihoi no i ka uku panai ia ia i ka napoo ana o ka la; a e hiamoe ill me kone kapa, a e hoomaikai mai oia ia oe, a e lilo ia i pono nou imua o Iehova kou Akua.
\b
\q1 
\v 14 Mai alunu oe i ke kanaka hoolimalima ilihune, nele, aole i kekahi o kou poe hoahanau, aole hoi i kekahi o kou poe kanaka e ma kou aina, maloko o kou mau ipuka.
\q1 
\v 15 I kona manawa no, nau e haawi kona uku, aole ke kali ana a napoo ka la; no ka mea, na ilihune ia, a ua manao nui kona naau ma ia mea; malia o kahea aku oia ia Iehova nou, a e lilo ia i hewa nou.
\b
\q1 
\v 16 Mai make na makua no na keiki, aole hoi e make na keiki no na makua: e make no kela kanaka keia kanaka no kona hewa iho.
\b
\q1 
\v 17 Mai hookeekee oe i ka pono o ka malihini, aole hoi i ke keiki makua ole, aole hoi oe e lawe i ke kapa aahu o ka wahinekanemake i uku panai.
\q1 
\v 18 Aka, e hoomanao iho oe he kauwa hooluhi oe ma Aigupita, a na Iehova kou Akua oe i hoopakele ae ia wahi: nolaila, ke kauoha aku nei au ia oe e hana ia mea.
\b
\q1 
\v 19 Aia oki iho oe i kau palaoa ma kau mahinaai, a hoopoina oe i kekahi pua ma ka mahinaai, mai hele hou oe e kii ia mea; na ka malihini no ia, a na ka mea makua ole, a na ka wahinekanemake; i hoopomaikai mai ai o Iehova kou Akua ia oe i na hana a pau a kou mau lima.
\q1 
\v 20 Aia hahau aku oe i kou laau oliva, mai huli hou oe i na lala: na ka malihini no ia, na ka mea makua ole, a na ka wahinekanemake.
\q1 
\v 21 Aia hoiliili oe i na hua waina o kou pawaina, mai ohi oe i ke koena mahope ou: na ka malihini no ia, na ka mea makua ole, a na ka wahinekanemake.
\q1 
\v 22 E hoomanao oe, he kauwa hooluhi oe ma ka aina o Aigupita: nolaila ke kauoha aku nei au ia oe e hana ia mea.
\c 25
\b
\q1 
\v 1 I NA he mea e hakaka ai iwaena o na kanaka, a hele mai lakou ma kahi hookolokolo, i hooponopono ai na lunakanawai ia lakou; alaila e hoapono aku lakou i ka mea i pono, a e hoahewa aku i ka mea i hewa.
\q1 
\v 2 Ina he pono e lilo ka mea i hewa i ka hahauia, e hoomoe ka lunakanawai ia ia malalo, a e hahauia oia imua o kona maka, e like me ke ano o kona hewa, ma ka helu ana.
\q1 
\v 3 Hookahi kanaha ia e hahau ai ia ia, aole keu aku: ina e hahau hou ia ia, a nai ka hahau ana, e lilo auanei kou hoahanau i mea hoowahawahaia i kou maka.
\b
\q1 
\v 4 Mai hoopaa aku oe i ka waha o ka bipi e hehi ana i ka palaoa.
\b
\q1 
\v 5 Ina e noho pu na hoahanau kane, a make kekahi o lakou, aohe ana keiki, mai mare ka wahine a ka mea i make i ka malihini mawaho: na ka hoahanau o kana kane e hele iloko io na la, a e lawe ia ia i wahine nana, a e malama aka i ka oihana o ka hoahanau o kana kane.
\q1 
\v 6 A o ka hanau mua ana e hanau ai, e lawe no ia i ka inoa o kona hoahanau i make, i nalowale ole ai kona inoa mai ka Iseraela aku.
\q1 
\v 7 Ina makemake ole ke kanaka e lawe i ka wahine a kona hoahanau, alaila e pii ka wahine a kona hoahanau ma ka ipaka i na lunakahiko, a e i aku, Ua hoole ka hoahanau o kuu kane e hooku i ka inoa no kona hoahanau iloko o ka Iseraela, aole ia i haliu mai e malama i ka oihana o ka hoahanau o kuu kane.
\q1 
\v 8 Alaila e kahea aku na lunakahiko o kona kulanakauhale ia ia, a e olelo aku ia ia; a i kupaa ia, a e i mai, Aole o'u makemake e lawe ia ia;
\q1 
\v 9 Alaila e hele mai ka wahine a kona hoahanau ia ia imua o na lunakahiko, a e kala ae i kona kamaa mai kona wawae, a e kuha aku i kona maka, me ka olelo aku, Pela e hanaia'ku ai i ke kanaka, i ka mea kukulu ole i ka hale o kona hoahanau.
\q1 
\v 10 A e kapaia kona inoa iloko o ka Iseraela, O ka hale o ka mea i kalaia kona kamaa.
\b
\q1 
\v 11 A i hakaka pu na kanaka, kekahi kanaka a me kona hoahanau, a hookokoke mai ka wahine a kekahi e hoopakele i kana kane i ka lima o ka mea i pepehi mai ia ia, a hoopaa aku ia ia ma kona wahi hilahila:
\q1 
\v 12 E oki ae i kona lima, mai minamina koa maka.
\b
\q1 
\v 13 Mai waiho iloko o kou aa i na mea kaupouna ano lua, i ka mea nui a me ka mea uuku.
\q1 
\v 14 Aole hoi ma kou hale na ana elua, o ka mea nui, a me ka mea uuku.
\q1 
\v 15 E malama oe i ka pouna pono, a me ka pololei, a me ke ana pono a me ka pololei; i loihi ai koa mau la ma ka aina a Iehova kou Akua i haawi mai ai ia oe.
\q1 
\v 16 No ka mea, ua hoowahawahaia e Iehova na mea a pau e hana ana i keia mau mea, a me ka poe a pau e hana ana i ka mea pono ole.
\b
\q1 
\v 17 E hoomanao i ka mea a ka Amaleka i hana mai ai ia oe ma ke ala i ko oakoa hele ana, mai Aigupita mai.
\q1 
\v 18 I ko lakou halawai ana me oe ma ke ala, a pepehi mai ma kou hope i na mea nawaliwali a pau mahope ou ia oe i nawaliwali ai, a i maloeloe ai; aole lakou i makau i ke Akua.
\q1 
\v 19 No ia mea, aia hoomaha mai o Iehova kou Akua ia oe mai kou poe enemi a puni, ma ka aina a Ienova kou Akua i hoolilo mai ai nou, e hokai loa aku oe i ka Amaleka malalo ae o ka lani; mai hoopoina oe.
\c 26
\b
\q1 
\v 1 A IA hiki aku oe ma ka aina a Iehova kou Akua e haawi mai ai nou, a lilo ia nou, a noho iho oe malaila;
\q1 
\v 2 E kii oe i kekahi o na hua mua a pau o ka honua, a o kau ia e lawe no ka aina a Iehova kou Akua i haawi mai ai nou, a e waiho iloko o ka hinai, a e hele aku oe ma kahi a Iehova kou Akua i wae ai e hoopaa i kona inoa malaila.
\q1 
\v 3 A e hele oe i ke kahuna e noho ana ia mau la, a e i aku ia ia, Ke hooia aku nei au ia Iehova kou Akua i keia la, no ka mea, ua hiki mai nei au ma ka aina a Iehova i hoohiki ai i ko kakou mau kupana e haawi mai no kakou.
\q1 
\v 4 A e lawe ke kahuna i ka hinai mai kou lima ae, a e waiho ia imua o ke kuahu o Iehova kou Akua.
\q1 
\v 5 A e hai aku oe me ka olelo aku imua o Iehova kou Akua, He kanaka kuewa kou makuakane no Suria, a iho no ia i Aigupita, a noho mahihini malaila, he poe uuku, a lilo ia malaila i lahuikanaka nui, ikaika, a lehulehu.
\q1 
\v 6 A hana ino mai ko Aigupita ia kakou, a hooluhi mai ia kakou, a haawi mai ia kakou i na hana kaumaha loa.
\q1 
\v 7 A kahea aku kakou ia Iehova ke Akua o ko kakou mau kupuna, hoolohe mai no o Iehova i ko kakou leo, a nana mai ia i ko kakou luhi, a me ka kakou hana, a me ko kakou kaumaha.
\q1 
\v 8 A lawe mai o Iehova ia kakou mai Aigupita mai me ka lima ikaika, a me ka lima kakauha, a me ka mea weliweli nui, a me na hoailona, a me na mea kupanaha.
\q1 
\v 9 A ua lawe mai hoi oia ia kakou ma keia wahi, a ua haawi ia kakou i keia aina, he aina e kahe ana o ka waiu a me ka meli.
\q1 
\v 10 Eia hoi, ua lawe mai nei au, e Iehova, i ka hua mua o ka aina au i haawi mai ai ia'u. A e waiho oe ia mea imua o Iehova kou Akua, a e hoomana aku imua o Iehova kou Akua.
\q1 
\v 11 A e olioli oe i na mea maikai a pau a Iehova kou Akua i haawi mai ai ia oe, a me ko ka hale ou, o oe, a me ka Levi, a me ka malihini iwaena ou.
\b
\q1 
\v 12 Aia hoopau oe i ka hookupu ana i ka hapaumi a pau o kau mea i loaa i ke kolu o ka makahiki, oia ka makahiki hookupu i ka hapaumi; a haawi aku i ka Levi a i ka malihini, a i ka mea makua ole, a me ka wahinekanemake, i ai iho ai lakou ma kou mau ipuka a maona;
\q1 
\v 13 Alaila e olelo aku oe imua o Iehova kou Akua, Ua lawe mai nei au i ka mea i hoolaaia mai ko'u hale mai, a ua haawi aku hoi i ka Levi, a i ka malihini, a i ka mea makua ole, a i ka wahinekanemake, e like me kau mau kauoha a pau au i kanoha mai ai ia'u; aole au i hoohala i kau mau kauoha, aole hoi au i hoopoina;
\q1 
\v 14 Aole au i ai i kekahi o ia mea i kuu makena ana, aole au i lawe i kekahi o ia mea no ka mea haumia, aole hoi au i haawi i kekahi o ia mea no ka mea i make; ua hoolohe no au i ka leo o Iehova ko'u Akua, a ua hana au e like me na mea a pau au i kauoha mai ai ia'u.
\q1 
\v 15 E nana mai oe mai kou wahi hoano, mai ka lani mai, a e hoomaikai mai i kou poe kanaka, i ka Iseraela, a me ka aina au i haawi mai ai no makou, e like me au i hoohiki ai i ko makou mau kupuna, he aina e kahe ana o ka waiu a me ka meli.
\b
\q1 
\v 16 I keia la, ua kauoha mai o Iehova kou Akua ia oe e hana ma keia mau kanawai, a me ua olelo kupaa; e malama hoi oe a e hana ma ia mau mea me kou naau a pau, a me kou uhane a pau.
\q1 
\v 17 I keia la ua hooia aku oe ia Iehova, i Akua nou, a e hele ma kona mau aoao, a e malama i kona mau kanawai, a i kana mau kauoha, a me kana mau olelo kupaa, a e hoolohe i kona leo.
\q1 
\v 18 A ua hooia mai o Iehova ia oe i keia la, he poe kanaka ponoi nona, e like me kana i olelo mai ai ia oe, i malama ai oe i kana mau kauoha a pau:
\q1 
\v 19 A e hookiekie mai oia ia oe maluna o na lahuikanaka a pau ana i hana'i, ma ka hoolea ana, a ma ka inoa, a ma ka hoomaikai; a e lilo oe i poe kanaka hemolele no Iehova, e like me kana i olelo mai ai.
\c 27
\b
\q1 
\v 1 KAUOHA aku la o Mose, a me na lunakahiko o ka Iseraela, i na kanaka, i ka i ana'ku, E malama i na kauoha a pau a'u e kauoha aku nei ia oukou i keia la.
\q1 
\v 2 A i ka la a oukou e hele aku ai ma kela kapa o Ioredane, i ka aina a Iehova kou Akua i haawi mai ai ia oe, e kukulu oe i na pohaku nui, a e hapala ia mau mea i ka puna.
\q1 
\v 3 A e kahakaha iho maluna o ia mau mea i na huaolelo a pau o keia kanawai, aia hiki aku oe ma kela aoao, i komo aku ai oe ma ka aina a Iehova kou. Akua i haawi mai ai ia oe, he aina e kahe ana o ka waiu a me ka meli; e like me ka Iehova ke Akua o kou mau kupaua i olelo mai ai ia oe.
\q1 
\v 4 Aia hiki aku oukou ma kela aoao o Ioredane, e kukulu oukou i keia mau pohaku, a'u e kauoha aku nei ia oukou i keia la, ma ka mauna o Ebala, a e hapala ia mau mea i ka puna.
\q1 
\v 5 A malaila oe e haua'i i kuahu no Iehova kou Akua, i kuahu pohaku: mai kau oe i ka mea hao maluna o ia mau mea.
\q1 
\v 6 E hana oe i ke kuahu no Iehova kou Akua me ka pohaku i kalai ole ia; a maluna ona e kaumaha aku ai oe i na mohaikuni no Iehova kou Akua.
\q1 
\v 7 A e kaumaha oe i na mohaialoha, a e ai iho oe malaila, a e olioli oe imua o Iehova kou Akua.
\q1 
\v 8 A e kahakaha iho oe maluna o na pohaku i na huaolelo a pau o keia kanawai a akaka loa.
\b
\q1 
\v 9 Olelo aku la o Mose a me na kahuna o na Levi, i ka Iseraela a pau, i aku la, E malama, o hoolohe, e ka Iseraela; ua lilo oe i keia la i poe kanaka no Iehova kou Akua.
\q1 
\v 10 No ia mea, e hoolohe oe i ka leo o Iehova kou Akua, a e hana i kana mau kauoha, a me kona mau kanawai, a'u e kauoha aku nei ia oe i keia la.
\b
\q1 
\v 11 A kauoha aku la hoi o Mose i na kanaka ia la, i ka i ana'ku,
\q1 
\v 12 Eia na mea e ku ma ka mauna o Gerizima e hoomaikai aku i na Kanaka, i ko oukou hiki ana'ku i kela kapa o Ioredane: o ka Simeona, o ka Levi, o ka Iuda, o ka Isakara, o ka Iosepa, a me ka Beniamina:
\q1 
\v 13 A eia na mea e ku ana ma ka mauna o Ebala no ka hoino ana: o ka Reubena, o ka Gada, o ka Asera, o ka Zebuluna, o ka Dana, a me ka Napetali.
\b
\q1 
\v 14 A e olelo aku ka Levi, a e i aku i na kanaka a pau o ka Iseraela me ka leo nui,
\b
\q1 
\v 15 E poino ke kanaka, ke hana ia i kii kalaiia a me ke kii i hooheeheeia, he mea hoopailuaia imua o Iehova, ka hana a na lima o ke kahuna hana, a ke waiho iho ia ma kahi malu: a e pane mai na kanaka a pau, e olelo mai, Pela io no.
\b
\q1 
\v 16 E poino ke kanaka ke hoowahawaha i kona makuakane a me kona makuwahine: a o na kanaka a pau e olelo mai, Pela io no.
\b
\q1 
\v 17 E poino ke kanaka ke hoonee aku ia i ka palena aina o kona hoalauna: a o na kanaka a pau e olelo mai, Pela io no.
\b
\q1 
\v 18 E poino ke kanaka ke hoohuli ae i ka makapo iwaho o ke alanui: a o na kanaka a pau e olelo mai, Pela io no.
\b
\q1 
\v 19 E poino ke kanaka ke hookeekee i ka pono o ka malihini, a me ke keiki makua ole, a me ka wahinekanemake: a o na kanaka a pau e olelo mai, Pela io no.
\b
\q1 
\v 20 E poino ke kanaka ke moe me ka wahine a kona makuakane; no ka mea, ua wehe ae ia i ke kapa moe o kona makuakane: a o na kanaka a pau e olelo mai, Pela io no.
\b
\q1 
\v 21 E poino ke kanaka ke moe me kekahi holoholona: a o na kanaka a pau e olelo mai, Pela io no.
\b
\q1 
\v 22 E poino ke kanaka ke moe ia me kona kaikuwahine, ke kaikamahine a kona makuakane, a ke kaikamahine a kona makuwahine: a o na kanaka a pau e olelo mai, Pela io no.
\b
\q1 
\v 23 E poino ke kanaka, ke moe ia me kona makuahonoaiwahine: a o na kanaka a pau e olelo mai, Pela io no.
\b
\q1 
\v 24 E poino ke kanaka ke pepehi malu i kona hoalauna: a o na kanaka a pau e olelo mai, Pela io no.
\b
\q1 
\v 25 E poino ke kanaka ke lawe i ka uku no ka pepehi i ke kanaka hala ole: a o na kanaka a pau e olelo mai, Pela io no.
\b
\q1 
\v 26 E poino ke kanaka ke hoopaa ole i na huaolelo a pau o keia kanawai, e malama aku ia mau mea: a o na kanaka a pau e olelo mai, Pela io no.
\c 28
\b
\q1 
\v 1 A I hoolohe pono oe i ka leo o Iehova kou Akua, e malama, a e hana i kana mau kauoha a pau a'u e kauoha aku nei ia oe i keia la, alaila, na Iehova na kou Akua oe e hookiekie ae maluna o na lahuikanaka a pau o ka honua:
\q1 
\v 2 E ili mai keia mau pomaikai ana maluna iho ou, a e loaa aku oe ia lakou, ke hoolohe aku oe i ka leo o Iehova kou Akua:
\q1 
\v 3 E pomaikai oe ma ke kulanakauhale, e pomaikai hoi oe ma ke kula.
\q1 
\v 4 E pomaikai ka hua o kou kino, a me ka hua o kou aina, a me ka hua o kou holoholona, na keiki a kau mau bipi, a me kau poe hipa.
\q1 
\v 5 E pomaikai kou hinai, a me kou papa kawili ai.
\q1 
\v 6 E pomaikai oe i kou komo ana iloko, e pomaikai hoi oe i kou hele ana iwaho.
\b
\q1 
\v 7 O Iehova ka mea e pepehiia'i kou poe enemi imua ou, ke ku e mai ia oe: ma ka aoao hookahi lakou e hele ku e mai ia oe, a ma na aoao ehiku e puehuia'ku ai imua ou.
\q1 
\v 8 Na Iehova oe e hoopomaikai ma kou mau hale papaa, a me na mea a pau a kou lima e lawe ai; a e hoopomaikai mai oia ia oe ma ka aina a Iehova kou Akua e haawi mai ai ia oe.
\q1 
\v 9 Na Iehova e hookupaa ia oe i poe kanaka laa nona, e like me kana i hoohiki mai ai ia oe, ke malama oe i na kauoha a Iehova kou Akua, ke hele hoi ma kona aoao.
\q1 
\v 10 A e ike na kanaka a pau o ka honua, ua kapaia oe ma ka inoa o Iehova; a e makau mai lakou ia oe.
\q1 
\v 11 E hoolako mai o Iehova ia oe i ka waiwai, i ka hua o kou kino, i ka hua o kou holoholona, a me ka hua o kou aina, ma ka aina a Iehova i hoohiki mai ai i ou mau kupuna e haawi mai ia oe.
\q1 
\v 12 A e wehe mai o Iehova nou i kona waiwai maikai, i ka lani e haawi mai i ka ua ma kou aina i kona raanawa, a e hoopomaikai i na hana a pau a kou lima: e haawi lilo ole aku oe i na lahuikanaka he nui, aole oe e noi wale aku.
\q1 
\v 13 A e hoolilo o Iehova ia oe i poo, aole ka huelo: maluna wale no oe e noho ai, aole hoi oe malalo; ke hoolohe aku oe i na kauoha a Iehova kou Akua a'u e kauoha aku nei ia oe i keia la, e malama, e hana hoi.
\q1 
\v 14 Mai kapae ae oe, mai kekahi huaolelo aku a'u e kauoha aku nei ia oe i keia la, ma ka akau, aole hoi ma ka hema, e hele mamuli o na akua e, e malama ia lakou.
\b
\q1 
\v 15 Aka, i hoolohe ole oe i ka leo o Iehova kou Akua, e malama, a e hana hoi i kana mau kauoha a pan, a me kona mau kanawai a'u e kauoha aku nei ia oe i keia la; alaila e ili mai ai maluna iho ou keia mau poino a pau, a loaa aku oe ia lakou:
\q1 
\v 16 E poino oe ma ke kulanakauhale, e poino hoi oe ma ke kula.
\q1 
\v 17 E poino kou hinai a me kou papa kawili ai.
\q1 
\v 18 E poino ka hua o kou kino, a me ka hua o kou aina, na keiki a kau mau bipi a me kau poe hipa.
\q1 
\v 19 E poino oe i kou komo ana iloko, e poino hoi oe i kou hele ana iwaho.
\b
\q1 
\v 20 Na Iehova e hooili mai maluna iho ou ka poino, ka weliweli, a me ka hoino ma na mea a pau a kou lima e lawe ai e hana, a e lukuia mai oe a make koke oe; no ka hewa o kau hana i haalele mai ai oe ia'u.
\q1 
\v 21 Na Iehova e hoopili mai ke ahulau ia oe, a pau loa oe i ka make ia ia ma ka aina au e hele aku nei a noho.
\q1 
\v 22 A e pepehi mai o Iehova ia oe i ka hokii, a me ke kuni, a me ka li nui, a me ka wela ikaika, a me ka la nui, a me ka huaai malili, a me ka punahelu, a e hahai ia mau mea ia oe a make oe.
\q1 
\v 23 A e lilo auanei kou lani maluna ou i keleawe, a me ka aina malalo ou i hao.
\q1 
\v 24 A e hoolilo o Iehova i ka na o kou aina i one a i lepo: mai ka lani e iho mai ia mea maluna ou, a lukuia oe.
\q1 
\v 25 A e hoolilo o Iehova ia oe i ka pepehiia imua o kou poe enemi: ma ke ala hookahi oe e hele ku e aku ia lakou, a ma na ala ehiku oe e hee aku ai imua o lakou, a e puehu liilii ia oe ma na aupuni a pau o ka honua.
\q1 
\v 26 A e lilo kou heana i mea ai na na manu o ka lewa, a me na holoholona o ka honua, aohe mea e hoomakau aku.
\b
\q1 
\v 27 A e hahau mai o Iehova ia oe, i ka mai hehe o Aigupita, a me ka hikoko, a me ka pehupala, a me ke kakio, ka mea hiki ole ke hoolaia.
\q1 
\v 28 A e hahau mai o Iehova ia oe i ka hehena, a me ka makapo, a me ka pihoihoi o ka naau.
\q1 
\v 29 A e hana aku oe i ka wa awakea e like me ka makapo i hana ai i ka pouli, aole e pomaikai oe ma kou aoao; a e hookaumaha wale ia oe, a e kaili wale ia oe i na la a pau, aohe mea nana oe e hoopakele.
\q1 
\v 30 A e hoopalau oe i ka wahine, a o ke kanaka e e moe ia ia, a e kukulu oe i ka hale, aole nae oe e noho iloko: a e kanu oe i mala waina, aole oe e ohi i kona hua.
\q1 
\v 31 A e kaluaia kau bipikane imua o kou maka, aole oe e ai ia mea: a e lawe wale ia aku kou hoki mai kou alo aku, aole e hoihoiia mai ia oe: a e haawiia'ku kau poe hipa i kou poe enemi, aole ou mea nana e hoopakele.
\q1 
\v 32 A e haawiia'ku kau mau keikikane a me kau mau kaikamahine i na kanaka e, a e haehae wale na maka ou i ka nana aku, a e hoopauia no lakou, a pau ka la, aohe ikaika iloko o kou lima.
\q1 
\v 33 O ka hua o kou aina, a me ka mea a pau au i luhi ai, e pau ia i ka aiia e ka lahuikanaka au i ike ole ai; a e lilo oe i mea hooluhi wale ia, a me ka hookaumahaia i na la a pau;
\q1 
\v 34 A e lilo oe i hehena no na mea i ikeia a kou maka e ike ai.
\q1 
\v 35 A e pepehi mai o Iehova ia oe i ka mai hehe eha ma na kuli, a ma na wawae, ka mea hiki ole ke hoolaia, mai ka poho o kou wawae a hiki i ka piko o kou poo.
\q1 
\v 36 A e lawe aku o Iehova ia oe a me kou alii au e hoonoho ai maluna ou i ka lahuikanaka au i ike ole ai, aole hoi o kou mau makua; a malaila oe e malama ai i na akua e, i ka laau a me ka pohaku.
\q1 
\v 37 A e lilo oe i mea kahahaia, a i mea hooheneheneia, a i mea kuamuamuia mawaena o na lahuikanaka a pau a Iehova e alakai aku ai ia oe.
\b
\q1 
\v 38 A e lawe aku oe i na hua he nui ma ka mahinaai. a he mea uuku kau e ohi mai: no ka mea, e pau ia i ka uhini.
\q1 
\v 39 A e kanu oe i na mala waina, a malama hoi; aole nae oe e inu i ka waina, aole hoi e ohi i ka hua: no ka mea, e pau ia i ka aiia e ka enuhe.
\q1 
\v 40 A ia oe no na laau oliva ma kou mau mokuna a pan, aka, aole oe e kahinu ia oe iho i ka aila: no ka mea, e haule ka hua oliva ou.
\q1 
\v 41 Nau mai no na keikikane a me na kaikamahine, aole nae nou lakou; no ka mea, e alakai pio ia'ku lakou.
\q1 
\v 42 E pau auanei kou mau laau a pau a me ka hua o kou aina i ka uhini.
\q1 
\v 43 A o ka malihini e noho pu ana me oe, e hookiekie loa ia maluna ou, a e hoohaahaa loa ia oe malalo.
\q1 
\v 44 A e haawi lilo ole kela ia oe, aole oe e haawi lilo ole ia ia; a lilo ia i poo, a o oe ka huelo.
\q1 
\v 45 A e hiki mai auanei neia mau mea poino a pau maluna ou, a e hahai mai ia oe, a loaa oe, a make oe, no kou hoolohe ole i ka leo o Iehova kou Akua, e malama i kana mau kauoha a me kona mau kanawai ana i kauoha mai ai ia oe.
\q1 
\v 46 A maluna ou ia mau mea, i hoailona a i mea kupanaha, a maluna hoi o kau poe mamo i ka manawa pau ole.
\q1 
\v 47 I kou malama ole ia Iehova kou Akua me ka olioli, a me ka hauoli o ka naau, no ka nui o na mea a pau;
\q1 
\v 48 No ia mea, e hookauwa auanei oe na kou poe enemi a Iehova e hoouna mai ai e ku e ia oe, me ka pololi, a me ka makewai, a me ka olohelohe, a me ka nele i na mea a pau: a e kau mai ia i ka auamo hao maluna o kou a-i, a e hoopau mai ia ia oe.
\b
\q1 
\v 49 E lawe mai auanei o Iehova i lahuikanaka e ku e ia oe, mai kahi loihi e mai, mai ka palena o ka honua, e like me ka aeto e lele ana; he lahuikanaka, aole oe e lohe i ka lakou olelo;
\q1 
\v 50 He lahuikanaka makakoa, aole e malama mai i ka elemakule, aole hoi e aloha mai i ka mea opiopio:
\q1 
\v 51 A e ai iho no ia i ka hua o kou holoholona, a me ka hua o kou aina, a hoopauia mai oe: aole ia e waiho nau i ka palaoa, aole i ka waina, aole hoi i ka aila, aole i na keiki o kau poe bipi, a me kau poe hipa, a e hoopau mai oia ia oe.
\q1 
\v 52 A e hoopilikia mai oia ia oe ma kou mau ipuka a pau, a hiolo ilalo kou mau pa pohaku kiekie a pau, kahi au i hilinai ai, ma kou aina a pau: a e hoopilikia mai oia ia oe ma kou mau ipuka a pau, ma kou aina a pau a Iehova kou Akua i kaawi mai ai ia oe.
\q1 
\v 53 A e ai auanei oe i ka hua o kou opu iho, i ka io o kau mau keikikane, a me kau mau kaikamahine a Iehova kou Akua i haawi mai ai ia oe, i ke kaua ana a me ka popilikia a kou poe enemi e hoopopilikia mai ai ia oe:
\q1 
\v 54 O ke kanaka palupalu, a maikai ke kino, e makaino aku ia i kona hoahanau, a me ka wahine o kona poli, a me kana mau keiki i koe ana i waiho ai:
\q1 
\v 55 Aole ia e haawi aku i kekahi o lakou i ka io o kana mau keiki ana e ai ai; no ka mea, aole mea i koe i ke kaua, a i ka pilikia a kou poe enemi e hoopilikia mai ai ia oe ma kou mau ipuka a pau.
\q1 
\v 56 A o ka wahine palupalu, a maikai ke kino, ka mea pono ole ia ia ke hehi kona wawae maluna o ka honua no ka maikai, a no ka palupalu, e nana ino aku kona maka i ke kane o kona poli, a me kana keikikane, a me kana kaikamahine,
\q1 
\v 57 A me kona iewi i puka mai iwaena o kona mau wawae, a me na keiki ana i hanau ai: a no ka nele i na mea a pau, e ai malu no oia ia lakou, no ke kaua, a no ka pilikia a kou poe enemi e hoopilikia ai ia oe ma kou mau ipuka.
\b
\q1 
\v 58 Ina paha i ole oe e malama pono i na olelo a pau o keia kanawai i kakauia maloko o keia buke, e makau ana i keia inoa nui weliweli, ia IEHOVA KOU AKUA;
\q1 
\v 59 Alaila e hana kupanaha mai o Iehova i kou mea ino, a me na mea ino o kou hua, i na mea ino nui e mau ana, a me na mai ino e mau ana.
\q1 
\v 60 A e lawe mai hoi o Iehova maluna ou i na mai a pau o Aigupita au i makau ai, a e pili mai ia mau mea ia oe.
\q1 
\v 61 A o na mai a pau, a me na ahulau a pau i kakau ole ia maloko o ka buke o keia kanawai, e kau mai o Iehova ia mau mea maluna ou, a make oe.
\q1 
\v 62 A e waihoia oukou he poe uuku; mamua ua like oukou me na hoku o ka lani ka nui; no ka mea, aole oukou i hoolohe i ka leo o Iehova kou Akua.
\q1 
\v 63 A e like me ka Iehova i olioli ai maluna o oukou e hoopomaikai ia oukou, a e hoonui ia oukou; pela auanei e olioli ai o Iehova maluna o oukou e luku ia oukou, a e hoolilo ia oukou i mea ole: a e laweia'ku oukou mai ka aina aku au e hele aku nei e noho.
\q1 
\v 64 A e hoopuehu aku o Iehova ia oe mawaena o na kanaka a pau mai kela aoao o ka honua, a hiki i keia aoao o ka honua; a malaila oe e malama ai i na akua e, i ka laau a me ka pohaku, au i ike ole ai, aole hoi kou mau makua.
\q1 
\v 65 A iwaena o ia mau lahuikanaka aole e loaa ia oe ka oluolu, aole hoi ka maha no ke kapuwai o kou wawae; a e haawi mai o Iehova ia oe malaila i naau haalulu, a me ka mai e pau ai na maka, a me ka pilihua o ka naau.
\q1 
\v 66 A e kanaluaia kou ola imua ou, a e makau oe i ka po a me ke ao, aohe mea e lana'i kou manao e ola.
\q1 
\v 67 I kakahiaka e olelo iho oe, Ina paha i hiki mai ke ahiahi! a i ke ahiahi e olelo iho oe, Ina paha i hiki mai ke kakahiaka! no ka mea makau a kou naau e makau ai, a no ka mea ikea a kou maka e ike ai.
\q1 
\v 68 A e hoihoi aku o Iehova ia oe ma Aigupita iloko o na moku, ma ke ala a'u i olelo ai ia oe, Aole oe e ike hou aku ia wahi: a malaila e kuaiia'ku ai oukou no ko oukou poe enemi, i poe kauwakane, a i poe kauwawahine, aohe mea nana e kuai mai.
\c 29
\b
\q1 
\v 1 O IA na olelo o ka berita a Iehova i kauoha mai ai ia Mose e hana me na mamo a Iseraela ma ka aina o Moaba, he okoa ka berita ana i hana mai ai me lakou ma Horeba.
\b
\q1 
\v 2 Kahea aku la o Mose i ka Iseraela a pau, i aku la ia lakou, Ua ike oukou i na mea a pau a Iehova i hana'i imua o ko oukou maka ma ka aina o Aigupita ia Parao, a i kana mau kauwa a pau, a me kona aina a pau;
\q1 
\v 3 O na hoao nui a kou maka i ike ai, a me na hoailona, a me kela mau hana mana nui;
\q1 
\v 4 Aka, aole o Iehova i haawi mai ia oukou i naau noonoo, i maka ike, a i pepeiao lohe a hiki i keia la.
\q1 
\v 5 A ua alakai au ia oukou i na makahiki he kanaha ma ka waonahele; aole i weluwelu ko oukou, aahu maluna o oukou, aole hoi i weluwelu na kamaa o oukou ma ko oukou wawae:
\q1 
\v 6 Aole oukou i ai i ka berena, aole hoi oukou i inu i ka waina, a me ka mea ona; i ike ai oukou, Owau no Iehova kou Akua.
\q1 
\v 7 A hiki mai oukou ma keia wahi, o Sihona ke alii o Hesebona, a me Oga ke alii o Basana, hele ku e mai la laua ia kakou i ke kaua, a pepehi aku la kakou ia laua.
\q1 
\v 8 A lawe kakou i ko laua aina, a haawi aku la ia i wahi e noho ai no ka Reubena, a me ka Gada a me ka ohana hapa a Manase.
\b
\q1 
\v 9 E malama hoi oukou i na olelo o keia berita, a e hana aku ia mau mea, i pomaikai ai oukou i na mea a pau a oukou e hana'i.
\b
\q1 
\v 10 Ko ku nei oukou a pau i keia la imua o Iehova ko oukou Akua; o ko oukou poe luna, o ko oukou mau ohana, a me ko oukou lunakahiko, a me ko oukou mau luna o na kanaka a pau o ka Iseraela,
\q1 
\v 11 O ka oukou kamalii, o ka oukou poe wahine, a me kou malihini ma kou wahi i hoomoana'i, mai ka mea kualaau a hiki i ka mea hukiwai ou;
\q1 
\v 12 I mea e hoopaa ai oe i ka berita me Iehova kou Akua a me kona hoohiki a Iehova kou Akua e hoohiki ai me oe i keia la:
\q1 
\v 13 I hookupaa ai oia ia oe i keia la i kanaka nona, a i Akua ia nou, e like me ia i olelo mai ai ia oe, a e like hoi me kana i hoohiki ai i kou mau kupuna, ia Aberahama, a me Isaaka a me Iakoba.
\b
\q1 
\v 14 Aole me oukou wale no ka'u e hana nei i keia berita a me keia hoohiki i keia la;
\q1 
\v 15 Aka, me ka poe e ku pu ana maanei me kakou i keia la imua o Iehova ko kakou Akua, a me ka poe hoi aole maanei me kakou i keia la:
\q1 
\v 16 (No ka mea, ua ike oukou i ko kakou noho ana ma ka aina o Aigupita, a i ko kakou hele ana mawaena o na lahuikanaka a oukou i maalo ae;
\q1 
\v 17 Ua ike hoi oukou i ko lakou mea i hoowahawahaia, a me ko lakou kii hoopailua, i ka laau, i ka pohaku, i ke kala, a me ke gula iwaena o lakou:)
\q1 
\v 18 O noho auanei iwaena o oukou, he kanaka, he wahine paha, a he ohana paha, a he hanauna paha, a huli ae kona naau i keia la mai o Iehova kou kakou Akua aku, a hele e malama i na akua o keia mau lahuikanaka, o kupu mai auanei iwaena o oukou ka laau e hua aua i ka mea make a me ka mea awaawa:
\q1 
\v 19 A i kona lohe ana i na olelo o keia hoino, hoomaikai oia ia ia iho ma kona naau, i ka i ana ae, E malu auanei au, ke hele au ma ka manao ana o kuu naau, e hui aku i ka ona ana me ka makewai ana:
\q1 
\v 20 Aole loa o Iehova e minamina mai ia ia, aka, alaila e hoaaia ka inaina o Iehova a me kona huhu i kela kanaka, a e kauia mai maluna ona na hoino a pau i kakauia maloko o keia buke, a hokae aku o Iehova i kona inoa malalo ae o ka lani.
\q1 
\v 21 A e hookaawale o Iehova ia ia no ka hewa mailoko ae o na hanauna a pau o ka Iseraela, e like me na hoino a pau o ka berita i kakauia maloko o ka buke o keia kanawai:
\b
\q1 
\v 22 No ia mea, e olelo auanei ka hanauna mahope o ka oukou poe keiki e ku mai ana mahope o oukou, a o ka malihini hoi o hele mai ana mai kahi loihi mai, a ike lakou i na mea ino o ia aina, a me na mai a Iehova i kau mai ai maluna ona;
\q1 
\v 23 E lilo ka aina a pau i luaipele a me ka paakai aa, aole i luluia, aole i hua mai, aole i kupu mai kekahi mea uliuli, e like me ka luku ana ia Sodoma a me Gomora, a me Adema a me Zeboima, a Iehova i luku ai no kona inaina, a me kona
\q1 
\v 24 A e olelo mai na lahuikanaka a pau, No ke aha la i hana mai ai o Iehova i keia aina pela? no ke aha la hoi ka wela o keia inaina nui!
\q1 
\v 25 Alaila, e i mai, No ko lakou haalele ana i ka berita a Iehova ke Akua o ko lakou mau kupuna, ana i hana'i me lakou, ia ia i lawe mai ai ia lakou mai ka aina o Aigupita mai:
\q1 
\v 26 A hele aku la lakou, a malama aku i na akua e, a hoomana aku ia lakou, i na akua a lakou i ike ole ai, i na mea ana i hoonoho ole ai no lakou:
\q1 
\v 27 A ua hoaaia ka inaina o Iehova i keia aina, e lawe mai maluna ona i na hoino a pau i kakauia maloko o keia buke:
\q1 
\v 28 A hookuke aku la o Iehova ia lakou mai ko lakou aina aku me ka huhu, a me ka ukiuki, a me ka inaina nui, a hoolei aku la ia lakou ma ka aina e, me ia i keia la.
\b
\q1 
\v 29 No Iehova ko kakou Akua na mea i hunaia: aka, o na mea i hoakakaia mai, no kakou ia, a no ka kakou poe keiki i ka manawa pau ole, i malama ai kakou i na olelo a pau o keia kanawai.
\c 30
\b
\q1 
\v 1 A IA i ka manawa e hiki mai ai maluna ou keia mau mea a pau, ka pomaikai a me ka poino a'u i hoakaka aku ai imua ou, a e hoomanao oe iwaena o na lahuikanaka, kahi a Iehova kou Akua i hookuke aku ai ia oe:
\q1 
\v 2 A hoi hou mai oe ia Iehova kou Akua, a hoolohe i kona leo e like me na mea a pau a'u e kauoha aku nei ia oe i keia la, o oe a me kau mau keiki, me kou naau a pau a me kou uhane a pau;
\q1 
\v 3 Alaila e hoohuli aku o Iehova kou Akua i kou pio ana, a e aloha mai ia oe, a e hoi hou mai ia i ou la, a e hoakoakoa mai ia oe mai na lahuikanaka a pau mai, kahi a Iehova kou Akua i hoopuehu aku ai ia oe.
\q1 
\v 4 Ina i kipakuia kekahi o kou poe ma ka palena o ka lani, e houluulu o Iehova kou Akua ia oe mai laila mai, a e lawe mai ia oe mai laila mai.
\q1 
\v 5 A e lawe mai o Iehova kou Akua ia oe maloko o ka aina a kou poe kupuna i noho ai, a e lilo ia nou; a e hana maikai mai oia ia oe, a e hoonui aku oia ia oe mamua o kou poe kupuna.
\q1 
\v 6 A na Iehova kou Akua e okipoepoe mai kou naau a me ka naau o kou hua, e aloha aku ia Iehova kou Akua me kou naau a pau a me kou uhane a pau, i ola oe.
\q1 
\v 7 A e hooili aku o Iehova kou Akua i keia mau hoino a pau maluna o kou poe enemi, a maluna o ka poe e inaina mai ia oe, ka poe i hoomaau mai ia oe.
\q1 
\v 8 A e hoi hou mai oe, a e hoolohe i ka leo o Iehova, a e hana i kana mau kauoha a pau a'u e kauoha aku nei ia oe i keia la.
\q1 
\v 9 Alaila e hoomahuahua mai o Iehova kou Akua ia oe ma na hana a pau a kou lima, a me ka hua o kou kino, a me ka hua o kau poe holoholona, a me ka hua o kou aina, i mea e maikai ai: no ka mea, e olioli hou mai o Iehova maluna on no ka maikai, e like me kona olioli maluna o kou poe kupuna:
\q1 
\v 10 Ke hoolohe oe i ka leo o Iehova kou Akua, e malama i kana mau kauoha, a me kona mau kanawai, i kakauia ma keia buke o ke kanawai, a ke huli hou ae oe ia Iehova kou Akua, mo kou naau a pau, a me kou uhane a pan.
\b
\q1 
\v 11 No ka mea, o keia kauoha a'u e kauoha aku nei ia oe i keia la, aole ia i hunaia ia oe, aole hoi e loihi aku ia:
\q1 
\v 12 Aole ia ma ka lani, i olelo ae oe, Owai ke pii i ka lani no kakou e lawe mai ia mea no kakou, i hoolohe kakou ia, a i hana hoi?
\q1 
\v 13 Aole hoi ia ma kela aoao o ka moana, i olelo ae oe, Owai ke holo aku ma kela aoao o ka moana no kakou, a e lawe mai ia mea no kakou, i lohe kakou ia, a i hana hoi?
\q1 
\v 14 Aka, ua kokoke loa ka olelo ia oe, ma kou waha, a ma kou naau, i hana aku ai oe ia mea.
\b
\q1 
\v 15 E nana, ua waiho ae nei au imua ou i keia la i ke ola a me ka maikai, i ka make a me ka hewa;
\q1 
\v 16 I ka'u kauoha ana'ku ia oe i keia la e aloha aku ia Iehova kou Akua, e hele ma kona aoao, a e malama i kana mau kauoha, a i kona mau kanawai, a me kana mau olelo kupaa, i ola oe, a i mahuahua oe; a e hoomaikai mai o Iehova kou Akua ia oe ma ka aina au e hele aku nei e noho malaila.
\q1 
\v 17 A ina e huli ae kou naau, i ole oe e hoolohe, a e koiia aku oe, a hoomana aku oe i na akua e, a e malama ia lakou;
\q1 
\v 18 Ke hai aku nei au ia oukou i keia la, e make io no oukou, aole e hooloihi oukou i na la ma ka aina, kahi au e hele aku ma kela kapa o Ioredane, e komo a e noho malaila.
\q1 
\v 19 Ke kahea aku nei au i ka lani a me ka honua e hoike mai no oukou i keia la, ua waiho ae nei au imua ou i ke ola, a me ka make, i ka pomaikai a me ka poino; no ia mea, e koho mai oe i Ke ola, i ola oe a me kou hua.
\q1 
\v 20 I aloha aku hoi oe ia Iehova kou Akua, a i hoolohe oe i kona leo, a hoopili aku oe ia ia; no ka mea, oia kou ola a me ka loihi o kou mau la; i noho ai oe ma ka aina a Iehova i hoohiki ai i ou mau kupuna, ia Aberahama, ia Isaaka a me Iakoba e haawi no lakou.
\c 31
\b
\q1 
\v 1 HELE aku la o Mose a hai aku la i keia mau olelo i ka Iseraela a pau.
\q1 
\v 2 I aku la oia ia lakou, Hookahi o'u haneri makahiki a me ka iwakalua i keia la; aole e hiki hou ia'u ke hele aku iwaho, a me ka hoi mai iloko: ua olelo mai no hoi o Iehova ia'u, Aole oe e hele ma kela aoao o keia Ioredane.
\q1 
\v 3 O Iehova kou Akua, nana no e hele mamua ou, a e luku aku ia i kela mau lahuikanaka mai kou alo aku, a e lilo lakou nou: a o Iosua, oia ke hele mamua ou e like me ka Iehova i olelo mai ai.
\q1 
\v 4 E hana aku o Iehova ia lakou e like me kana i hana aku ai ia Sihona a me Oga, na'lii o ka Amora, a me ka aina o laua ana i luku aku ai.
\q1 
\v 5 A e hoolilo mai o Iehova ia lakou imua o ko oukou maka, a e hana aku oukou ia lakou e like me na kauoha a pau a'u i kauoha aku ai ia oukou.
\q1 
\v 6 E ikaika oukou, a e koa hoi; mai hopohopo oukou, mai makau ia lakou; no ka mea, o Iehova kou Akua, oia ke hele pu me oe; aole ia e kuu aku ia oe, aole hoi e haalele ia oe.
\b
\q1 
\v 7 Hea aku la o Mose ia Iosua, i aku la ia ia imua o ka Iseraela a pau, E ikaika oe, e koa hoi: no ka mea, o oe ke hele pu me keia poe kanaka ma ka aina a Iehova i hoohiki ai i ko lakou mau kupuna e haawi mai no lakou nei; a nau no lakou e hoonoho malaila.
\q1 
\v 8 A o Iehova, oia ke hele imua ou: oia pu kekahi me oe, aole oia e kuu aku, aole hoi e haalele ia oe: mai makau oe, mai hopohopo.
\b
\q1 
\v 9 A kakau iho la o Mose i keia kanawai, a haawi aku la i na kahuna i na mamo a Levi, nana i hali ka pahu berita o Iehova, a i na lunakahiko a pau o ka Iseraela.
\q1 
\v 10 Kauoha aku la o Mose ia lakou, i aku la, I ka pau ana o na makahiki pahiku, ma ka ahaaina o ka makahiki o ke kala ana aku, ma ka ahaaina kauhalelewa,
\q1 
\v 11 Aia hele mai ka Iseraela a pau e hoikeia imua o Iehova kou Akua, ma kahi ana e wae ai, e heluhelu oe i keia kanawai imua o ka Iseraela a pau, i lohe lakou.
\q1 
\v 12 E houluulu i na kanaka, na kane, na wahine, a me na kamalii, a me kou malihini ma kou mau ipuka, i lohe lakou, a i ao lakou, a i makau hoi lakou ia Iehova ko oukou Akua, a i malama a i hana hoi i na olelo a pau o keia kanawai:
\q1 
\v 13 A i lohe hoi ka lakou poe keiki ike ole, a i ao hoi e makau ia Iehova ko oukou Akua i na la a pau o ko oukou ola ana ma ka aina, kahi a oukou e hele aku nei ma kela kapa o Ioredane e noho.
\b
\q1 
\v 14 Olelo mai la o Iehova ia Mose, Aia hoi, ua kokoke nei kou manawa e make ai: e kahea aku oe ia Iosua, a e ku mai olua ma ka halelewa o ke anaina, i kauoha aku ai au ia ia. Hele aku la o Mose laua o Iosua, a ku aku la laua ma ka halelewa o ke anaina.
\q1 
\v 15 Ikea mai la o Iehova ma ka halelewa maloko o ke ao; ku iho la ke kia ao maluna o ka puka o ka halelewa.
\b
\q1 
\v 16 Olelo mai la o Iehova ia Mose, Aia hoi, e hiamoe iho oe me ou poe kupuna; a e ku ae auanei keia poe kanaka iluna, a e moe kolohe lakou mamuli o na akua o na kanaka e ma ka aina a lakou e hele aku nei a noho iwaena o lakou, a e haalele mai lakou ia'u, a e uhai i ka'u berita a'u i kauoha aku ai ia lakou.
\q1 
\v 17 Alaila e hoaaia'ku ko'u inaina ia lakou ia la, a e haalele aku au ia lakou, e huna au i ko'u maka mai o lakou aku, a e pau lakou i ka lukuia, a e loohia lakou e na ino a me na pilikia he nui loa; nolaila, e olelo mai ai lakou ia la, Aole anei i hiki mai keia mau mea ino iluna o kakou, no ka noho ole mai o ko kakou Akua iwaena o kakou?
\q1 
\v 18 He oiaio no, e huna au i ko'u maka ia la, no na ino a pau a lakou e hana mai ai, i ko lakou huliia'na i na akua e.
\q1 
\v 19 No ia hoi, e kakau oukou i keia mele no oukou, a e ao aku ia i na mamo a Iseraela: e haawi aku ia mea i ko lakou waha, i lilo ai keia mele i mea hoike no'u e ku e i na mamo a Iseraela.
\q1 
\v 20 A i ka manawa e lawe aku ai au ia lakou ma ka aina, a'u i hoohiki ai i ko lakou mau kupuna, e kahe ana o ka waiu a me ka meli; a ai iho lakou a maona, a momona; alaila e huli ae lakou i na akua e, a e malama ia lakou, a e hoowahawaha mai ia'u, a e uhai i kuu berita.
\q1 
\v 21 Aia loaa ia lakou na mea ino he nui loa, a me na mea pilikia, alaila lilo keia mele i mea hoike imua o lakou; aole e hoopoinaia ma ka waha o ka lakou mamo: no ka mea, ua ike no au ano i ko lakou manao a lakou e hana aku ai mamua o kuu lawe ana'ku ia lakou ma ka aina a'u i hoohiki ai.
\b
\q1 
\v 22 Kakau iho o Mose i keia mele ia la, a ao aku la ia i na mamo a Iseraela.
\b
\q1 
\v 23 A kauoha aku la oia ia Iosua i ke keiki a Nuna, i aku la, E ikaika oe, e koa hoi; no ka mea, nau no e hookomo na mamo a Iseraela iloko o ka aina a'u i hoohiki ai ia lakou; a owau pu kekahi me oe.
\b
\q1 
\v 24 A pau ae la ka Mose kakau ana i na olelo o keia kanawai iloko o ka buke, a hooki ae la;
\q1 
\v 25 Kauoha aku la o Mose i ka poe Levi, nana i hali ka pahuberita o Iehova, i aku la,
\q1 
\v 26 E lawe i ka buke o keia kanawai, a e waiho oukou ia maloko o ka pahu berita o Iehova ko oukou Akua, i mea hoike ia oe malaila.
\q1 
\v 27 No ka mea, ua ike au i kou kipi ana, a me kou a-i oolea: aia hoi, i ko'u ola pu ana me oukou i keia la, ua kipi oukou ia Iehova; a e oiaio hoi mahope o kuu make ana.
\b
\q1 
\v 28 E hoakoakoa mai oukou io'u nei i na lunakahiko o ko oukou mau hanauna, a me na luna o oukou, i olelo aku ai au iloko o ko lakou pepeiao i keia mau olelo; a kahea aku au i ka lani a me ka honua e hoike mai ia lakou.
\q1 
\v 29 No ka mea, ua ike no au, aia mahope o kuu make ana, e hoohaumia loa oukou ia oukou iho, a e huli ae oukou mai ka aoao aku a'u i kauoha aku ai ia oukou; a e hiki mai ka hewa ia oukou i na la mahope; no ka mea, e hana hewa auanei oukou imua o Iehova, e hoonaukiuki aku ia ia ma ka hana a ko oukou lima.
\b
\q1 
\v 30 A olelo aku o Mose maloko o na pepeiao o ke anainakanaka a pau o ka Iseraela i na huaolelo o keia mele a pau loa.
\c 32
\b
\q1 
\v 1 E HALIU i ka pepeiao, e na lani, na'u e na lani, na'u e oleo aku; E hoolohe mai, e ka honua, i na olelo a kuu waha.
\q1 
\v 2 E haule iho kuu ao ana e like me ka ua, E helelei iho ka'u olelo e like me ka hau; Me ka ua liilii hoi maluna o ka launahele hou, A me ka ua nui maluna o ka weuweu;
\q1 
\v 3 No ka mea, e hai aku au i ka inoa o Iehova, E hoomana aku oukou i ko kakou Akua.
\q1 
\v 4 Oia ka Pohaku, ua hemolele kana hana ana; He pono hoi kona mau aoao a pau: He Akua olelo oiaio, aole ona hewa, He pono, he pololei hoi ia.
\q1 
\v 5 Ua hana ino lakou, aole noho i keiki nana, Oia ko lakou kina: He hanauna ino lakou, a me ka lanwili.
\q1 
\v 6 Pela anei oukou e hoihoi aku ai ia Iehova, E ka poe kanaka hawawa, a me ka naaupo? Aole anei ia o kou Makua, nana oe i kuai? Aole anei ia i hana mai ia oe, a i hookupaa ia oe?
\b
\q1 
\v 7 E hoomanao i na manawa kahiko, E noonoo i na makahiki o na hanauna a pau: E ninau aku i kou makuakane, nana e hoike mai ia oe; I na lunakahiko ou, na lakou e hai mai ia oe.
\q1 
\v 8 I ka manawa a ka Mea kiekie i puunaue ai ka aina no na lahuikanaka, I ka manawa ana i hookaawale ai na keiki a Adamu, Hoike mai ia i na palena no na kanaka, E like me ka nui o na mamo a Iseraela.
\q1 
\v 9 O ke kuleana o Iehova, kona poe kanaka ia; O Iakoba hoi kona hooilina.
\q1 
\v 10 Loaa oia ia ia ma ka aina nahelehele, A ma ka waonahele neoneo e uwo ana; Alakai aku la ia ia mai o a o, ao mai oia ia ia, Malama mai oia ia ia e like me ke kii onohi o kona maka.
\q1 
\v 11 Me he aeto la e hoala ana i ko ka punana, A hoolahalahai maluna o na keiki ana, Hohola i kona mau eheu, a lawe ae la ia lakou, A kaikai aku maluna o kona mau eheu;
\q1 
\v 12 Na Iehova wale no oia i alakai aku, Aole hoi he akua e me ia.
\q1 
\v 13 Hooholoholo ae la oia ia ia maluna o na wahi kiekie o ka honua, I ai iho ia i ka hua o na mahinaai, Hanai mai oia ia ia i ka meli mailoko mai o ka pohaku, I ka aila hoi mailoko mai o ka pohaku paa:
\q1 
\v 14 Me ka bata o ka bipi, a me ka waiu hipa, A me na keikihipa momona, A me na hipakane no Basana, a me na kaokane, A me ka palaoa maikai loa; Inu iho la oe i ke kokohuawaina, i ka waina maikai.
\b
\q1 
\v 15 Aka, a momona o Iesuruna, keehi mai la ia: Ua momona oe, ua puipui, ua puni oe i ka momona: Alaila haalele ia i ke Akua, nana ia i hana, Hoowahawaha hoi i ka Pohaku o kona ola.
\q1 
\v 16 Hoolili aku lakou ia ia ma na akua e, Hoonaukiuki lakou ia ia i na mea haumia.
\q1 
\v 17 Mohai aku lakou na na daimonio, na mea akua ole; Na akua ike ole ia e lakou, Na mea hou, he hou ka puka ana mai, Na mea makau ole ia e na makua o oukou.
\q1 
\v 18 Manao ole iho la oe i ka Pohaku, nana oe i hoohanau, A hoopoina i ke Akua nana oe i hana.
\b
\q1 
\v 19 A ike mai la o Iehova, inaina mai ia, No ka hoonaukiuki mai o na keikikane, a me na kaikamahine ana.
\q1 
\v 20 I iho la ia, E huna au i ko'u maka mai o lakou aku, E ike auanei au i ke ano o ko lakou hope: No ka mea, he hanauna ino lakou, He poe keiki aole he oiaio iloko o lakou.
\q1 
\v 21 Hoolili mai lakou ia'u ma ka mea, aole he Akua, Hoonaukiuki mai lakou ia'u ma ko lakou mau mea lapuwale; A na'u hoi lakou e hoolili aku ma ka mea kanaka ole, E hoonaukiuki aku hoi au ia lakou ma ka lahuikanaka naaupo.
\q1 
\v 22 No ka mea, ua hoaaia ke ahi e kuu inaina, A e enaena ia a hiki ilalo lilo i ka po, A e hoopau ia i ka honua a me kona hua iho, A e puhi ia i ke ahi i na kumu mauna.
\b
\q1 
\v 23 E hoiliili au i na ino maluna iho o lakou: E pana aku au i ka'u mau pua ia lakou.
\q1 
\v 24 E pau auanei lakou i ka pololi, E aiia hoi lakou i ke ahi wela, a me ka make awaawa: O ka niho o na mea hihiu ka'u e hoouna aku ai maluna o lakou, A me na mea make o na nahesa o ka honua.
\q1 
\v 25 O ka pahikaua mawaho, a me ka makau maloko, E luku i ke keikikane, a me ke kaikamahine, I ke keiki waiu, a me ke kanaka poohina.
\q1 
\v 26 I iho la au, E hooauhee aku au ia lakou i na pilikia, E hokai hoi au i ko lakou lono iwaena o kanaka;
\q1 
\v 27 Ina aole au i makau i ka inaina o ka poe enemi, O hana ku e mai ko lakou poe enemi, O olelo mai lakou, Na ko makou lima kiekie, Aole na Iehova i hana keia mau mea a pau,
\b
\q1 
\v 28 No ka mea, he lahuikanaka nele i ka naauao, Aole hoi he ike maloko o lakou.
\q1 
\v 29 Ina, i naauao lakou a i ike lakou i keia, A i manao lakou i ko lakou hope!
\q1 
\v 30 Pehea la e alualu ai kekahi i ke tausani hookahi, A o na mea elua e hoopuehu ai i na tausani he umi, Ke ole i kuai aku ko lakou Pohaku ia lakou, Ke ole hoi i hoolilo aku o Iehova ia lakou?
\q1 
\v 31 O ko lakou pohaku, aole like ia me ko kakou Pohaku, Ma ka hooiaio ana mai o ko kakou poe enemi.
\q1 
\v 32 No ka mea, o ko lakou kumuwaina, he kumuwaina no Sodoma, A no na mala hoi o Gomora: O ka lakou huawaina, he huawaina make, A o na huhuiwaina a lakou, he awaawa ia:
\q1 
\v 33 O ka lakou waina, he mea make o na moolele, A me ka mea make ino o na moonihoawa.
\b
\q1 
\v 34 Aole anei i hunaia keia mea me au, A i hoopaaia iwaena pu me o'u waiwai?
\q1 
\v 35 Ia'u no ka hoopai aku, a me ka hoouku: E hoopahee auanei ko lakou wawae: No ka mea, ua kokoke mai ka la e poino ai lakou, Ua lalelale mai na mea e hiki mai ana maluna o lakou.
\q1 
\v 36 No ka mea, e hoopai auanei o Iehova i kona poe kanaka, A e minamina no ia i kana poe kauwa, Ke ike ia, ua nawaliwali ka lima, Aohe mea i paa, aohe mea i paa ole.
\q1 
\v 37 A e olelo mai ia, Auhea ae nei ko lakou mau akua, Ka pohaku a lakou i hilinai ai,
\q1 
\v 38 Ka mea i ai i ka momona o ka lakou mohai, Ka mea i inu i ka waina o ka lakou mohaiinu? E ku mai lakou e kokua mai ia oukou, A e hoomalu mai ia oukou.
\q1 
\v 39 E nana oukou ano, Owau, Owau no ia, Aohe akua e ae, Owau wale no: Owau ke pepehi, Owau ke hoola; Owau ke hooeha, Owau ke hoola; Aohe mea nana e hoopakele ae mai kuu lima aku.
\q1 
\v 40 No ka mea, ke kaikai nei au i kuu lima ma ka lani, Me ka i iho, He ola mau loa ko'u.
\q1 
\v 41 Ina e hookala au i kuu pahikaua huali, A e lawe kuu lima i ka hooponopono; E hoopai aku au i kuu poe enemi, E hoouku aku au i ka poe e inaina mai ia'u.
\q1 
\v 42 E hooinu au i na pua a u i ke koko a ona, E ai iho kuu pahikaua i ka io; Me ke koko o ka mea i pepehiia, a me ko ka mea i pio, I ke poo hoi o na'lii o ka poe enemi.
\q1 
\v 43 E olioli oukou, e na aina, me kona poe kanaka; No ka mea, e uku auanei no ia i ke koko o kona poe kauwa, A hoopai no ia i kona poe enemi, A e hoola no ia i ka aina o kona poe kanaka.
\b
\q1 
\v 44 Hele mai o Mose a hai aku i na pepeiao o kanaka i na huaolelo a pau o keia mele, oia a me Iosua, ke keiki a Nuna.
\q1 
\v 45 A hoopau ae la o Mose i ka olelo ana aku i keia mau olelo a pau i ka Iseraela a pau.
\q1 
\v 46 I aku la ia ia lakou, E noonoo pono ko oukou naau i na olelo a pau a'u e hoike aku nei ia oukou i keia la; oia ka oukou e kauoha aku ai i na keiki a oukou e malama, e hana hoi i na olelo a pau o keia kanawai.
\q1 
\v 47 Aole keia he mea lapuwale no oukou, no ka mea, o ko oukou ola keia; a ma keia mea e hooloihi ai oukou i na la ma ka aina, kahi a oukou e hele aku nei i kela kapa o Ioredane e noho.
\b
\q1 
\v 48 Olelo mai la o Iehova ia Mose ia la no, i mai la.
\q1 
\v 49 E pii aku oe i keia kuahiwi, i Abarima, ma ka puu o Nebo, ma ka aina o Moaba, e ku pono ana i Ieriko, a e nana i ka aina o Kanaana, a'u e haawi aku nei i wahi e noho ai no na mamo a Iseraela;
\q1 
\v 50 A e make oe ma ke kuahiwi, kahi au e pii aku ai, a e hui pu ia oe me kou poe kanaka, e like me ka make ana o Aarona kou kaikuaana, a hui pu ia oia me kona poe kanaka.
\q1 
\v 51 No ka mea, ua hana hewa olua ia'u iwaena o na mamo a Iseraela ma ka wai o Meriba, ma Kadesa, i ka waonahele o Zina; i ko olua hoano ole mai ia'u mawaena o na mamo a Iseraela.
\q1 
\v 52 E ike no nae oe i ka aina, aka, aole oe e hele aku ilaila, i ka aina a'u e haawi aku nei i na mamo a Iseraela.
\c 33
\b
\q1 
\v 1 EIA ka hoomaikai a Mose, ke kanaka o ke Akua, i hoomaikai aku ai i na mamo a Iseraela mamua o kona make ana.
\q1 
\v 2 I aku la, Mai Sinai mai, i hele mai ai o Iehova,
\q1 A mai Seira mai ia i puka mai ai maluna o lakou.
\q1 Mai ka mauna o Paraua ia i hoomalamalama mai,
\q1 Mawaena mai o na umi tausani haipule oia i hele mai ai;
\q1 Mai kona lima akau aku ke kanawai ahi no lakou.
\q1 
\v 3 I aloha hoi ia i na kanaka:
\q1 Ma kou lima kona poe haipule a pau:
\q1 Ma kou wawae lakou i noho ai;
\q1 E loaa ia lakou kau mau olelo.
\q1 
\v 4 I kauoha mai o Mose ia kakou i ke kanawai,
\q1 Oia ka mea i ili mai ai no ka ahakanaka o Iakoba.
\q1 
\v 5 He alii oia iloko o Iesuruna,
\q1 I ka wa i hoakoakoa pu ai na luna o kanaka,
\q1 A i houluulu ai na ohana o ka Iseraela.
\b
\q1 
\v 6 E ola no o Reubena, aole ia e make;
\q1 Aole hoi e uuku kona poe kanaka.
\b
\q1 
\v 7 Eia ka Iuda; i aku la ia,
\q1 E hoolohe, e Iehova, i ka leo o Iuda,
\q1 A e alakai ia ia i kona poe kanaka; E pono no ia ma kona lima iho,
\q1 A e kokua mai oe ia ia i kona poe enemi.
\b
\q1 
\v 8 I aku la ia no Levi, O kou Tumima a me kou Urima no
\q1 kou mea haipule,
\q1 Ka mea au i hoao ai ma Masa,
\q1 Ka mea au i hakaka ai ma ka wai o Meriba;
\q1 
\v 9 Ka mea i olelo ai i kona makuakane, a me kona makuwahine,
\q1 Aole au i ike ia ia;
\q1 Aole ia i ike i kona mau hoahanau;
\q1 Aole hoi ia i ike i kana mau keiki;
\q1 No ka mea, ua malama lakou i kau olelo;
\q1 Ua malama hoi lakou i kau berita,
\q1 
\v 10 E ao aku lakou i kau olelo kupaa i ka Iakoba,
\q1 A i kou kanawai i ka Iseraela:
\q1 E kau lakou i ka mea ala imua ou,
\q1 A me ka mohai pono maluna o kou kuahu.
\q1 
\v 11 E hoomaikai oe, e Iehova, i kona waiwai,
\q1 E oluolu oe i ka hana a kona lima;
\q1 E hahau oe i na puhaka o ka poe ku e mai ia ia,
\q1 A me ka poe e inaina ia ia, i ku hou ole mai ai lakou.
\b
\q1 
\v 12 I aku la ia no Beniamina, Ka hiwahiwa na Iehova, e noho
\q1 maluhia me ia;
\q1 E hoouhi mai oia ia ia i na la a pau,
\q1 E noho no hoi ia iwaena o kona poohiwi.
\b
\q1 
\v 13 I aku la ia no Iosepa, E hoomaikaiia kona aina e Iehova,
\q1 No na mea maikai o ka lani, no ka hau,
\q1 A no na mea e waiho ana malalo i ka honua,
\q1 
\v 14 No na mea maikai a ka la i hookupu ai,
\q1 No na mea maikai a na mahina i houlu ai.
\q1 
\v 15 No na mea maikai o na mauna kahiko,
\q1 No na mea maikai o na puu pau ole,
\q1 
\v 16 No na mea maikai o ka honua, a me kona mea i piha ai,
\q1 No ka lokomaikai o ka mea i noho ai ma ka laau;
\q1 E hiki mai ia maluna o ke poo o Iosepa,
\q1 A maluna hoi o ka piko poo o ka mea i hookaawaleia e kona
\q1 poe hoahanau.
\q1 
\v 17 Me ka hanau mua o kona poe bipi, pela kona nani,
\q1 O na kiwi o ka bipi hihiu, oia kona mau kiwi;
\q1 Me ia mea e o aku ia i na kanaka ma kahi hookahi, a i na
\q1 mokuna o ka honua:
\q1 Oia na umi tausani o Eperaima, a oia na tausani o Manase.
\b
\q1 
\v 18 Olelo aku la ia no Zebuluna, E olioli oe, e Zebuluna, i
\q1 kou hele ana iwaho:
\q1 O oe hoi, e Isakara, ma kou mau halelewa.
\q1 
\v 19 E kahea aku lakou i na kanaka o ka mauna;
\q1 Malaila e kaumaha aku ai i mohai o ka pono:
\q1 No ka mea, e omo lakou i ka waiwai nui o na moana,
\q1 A me na waiwai i hunaia ma ke one.
\b
\q1 
\v 20 Olelo aku ia no Gada, Pomaikai ka mea e hoomahuahua ana
\q1 ia Gada;
\q1 Like me ka liona kona noho ana,
\q1 A e weluwelu ia ia ka lima a me ke poo.
\q1 
\v 21 Wae iho la ia i ke kuleana maikai nona,
\q1 No ka mea, malaila no ke kuleana o ke alakai i waiho ai;
\q1 A hele aku la ia me na luna o kanaka,
\q1 Hana aku la ia i ka pono o Iehova,
\q1 A i kana olelo kupaa me ka Iseraela.
\b
\q1 
\v 22 Olelo aku la ia no Dana, o Dana, he keiki liona ia,
\q1 E lele mai ia mai Basana mai.
\b
\q1 
\v 23 Olelo aku la ia no Napetali, E hoonuiia oe i ka lokomaikai,
\q1 E hoopihaia oe i ka pomaikai o Iehova,
\q1 E hooliloia nou ke komohana, a me ke kukuluhema.
\b
\q1 
\v 24 Olelo aku la ia no Asera, E hoopomaikaiia o Asera i na
\q1 keiki,
\q1 A e oluolu ia i kona poe hoahanau,
\q1 A e kupenu iho ia i kona wawae i ka aila.
\q1 
\v 25 O ka hao, a me ke keleawe, kou mau kamaa;
\q1 E like me kou mau la, pela kou malu.
\b
\q1 
\v 26 Aohe mea like me ke Akua o Iesuruna,
\q1 E holo ana no ia maluna o ka lani e kokua ia oe,
\q1 A maluna o ke ao me kona nani nui.
\q1 
\v 27 O ke Akua mau loa kou puuhonua,
\q1 A malalo iho na lima mau loa:
\q1 E hookuke aku ia i na enemi imua ou;
\q1 A e i mai, E luku aku ia lakou.
\q1 
\v 28 A e noho maluhia wale no o ka Iseraela:
\q1 O ka luawai o Iakoba ma ka aina palaoa a me ka waina;
\q1 A e hoohelelei iho kona lani i ka hau:
\q1 
\v 29 Pomaikai oe, e ka Iseraela:
\q1 Owai la kou mea like, e na kanaka, i hoolaia e Iehova,
\q1 Oia ka paku nana oe e kokua mai,
\q1 Oia ka pahikaua o kou nani.
\q1 E malimali mai kou poe enemi imua ou,
\q1 A e hele auanei oe maluna o ko lakou wahi kiekie.
\c 34
\b
\q1 
\v 1 PII aku la o Mose mai na papu aku o Moaba ma ka puu o Nebo, maluna pono o Pisega, e ku pono ana i Ieriko; a hoike mai la o Iehova ia ia i ka aina a pau o Gileada a hiki i Dana,
\q1 
\v 2 Me ka aina a pau o ka Napetali, a me ka aina o ka Eperaima, a me ko ka Manase, a me ka aina a pau o ka Iuda, a hiki aku i ke kai ma ke komohana,
\q1 
\v 3 A me ke kukuluhema, a me ka papu o ke awawa o Ieriko, ke kulanakauhale laau pama, a hiki i Zoara.
\q1 
\v 4 Olelo mai la o Iehova ia ia, Eia ka aina a'u i hoohiki aku ai ia Aberahama, ia Isaaka, a me Iakoba, i ka i ana aku, Na'u no ia e haawi aku i kau poe mamo: ua hoike aku au ia i kou mau maka, aka, aole oe e hele aku ilaila.
\b
\q1 
\v 5 A make iho la o Mose ke kauwa a Iehova ilaila, i ka aina o Moaba, e like me ka olelo ana mai a Iehova.
\q1 
\v 6 Nana no ia i kanu ma kekahi awawa ma ka aina o Moaba, e ku pono ana i Betepeora: aka, aohe kanaka i ike i kona wahi i kanuia'i a hiki i keia manawa.
\b
\q1 
\v 7 Hookahi haneri a me ka iwakalua o ko Mose mau makahiki i kona manawa i make ai; aole i powehiwehi kona maka, aole hoi i emi kona ikaika.
\b
\q1 
\v 8 Auwe iho la na mamo a Iseraela ia Mose ma na papu o Moaba i na la he kanakolu; a pau iho la na la o ka uwe ana a me ke kanikau ana ia Mose.
\b
\q1 
\v 9 A o Iosua ke keiki a Nuna, ua piha ia i ka Uhane e naauao ai; no ka mea, ua kau aku o Mose i kona mau lima maluna iho ona: a hoolohe aku la na mamo a Iseraela ia ia, a hana aku la e like me ka Iehova i kauoha mai ai ia Mose.
\b
\q1 
\v 10 Aole i ku mai ke kaula ma ia hope mai iloko o ka Iseraela e like me Mose, ka mea a Iehova i ike mai ai, he maka no he maka;
\q1 
\v 11 I na hoailona, a me na mea kupanaha a Iehova i hoouna mai ai ia ia e hana ma ka aina o Aigupita, ia Parao, i kana mau kauwa a pau, a i kona aina a pau,
\q1 
\v 12 I ka lima ikaika loa, a me ka mea makau nui loa a Mose i hoike aku ai imua o na maka o ka Iseraela a pau. 
