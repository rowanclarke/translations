\q2 \w But|strong="H1571"\w* \w God|strong="H3027"\w* \w will|strong="H1571"\w* \w get|strong="H3027"\w* rid \w of|strong="H3027"\w* \w those|strong="H1931"\w* men, \w too|strong="H1571"\w*.”
\p 
\v 25 \w Then|strong="H1980"\w* \w Balaam|strong="H1109"\w* \w and|strong="H1980"\w* \w Balak|strong="H1111"\w* \w returned|strong="H7725"\w* \w to|strong="H1980"\w* \w their|strong="H7725"\w* homes.
\c 25
\s1 The Israelis worshiped Baal
\p 
\v 1 \w While|strong="H3427"\w* \w the|strong="H2181"\w* Israelis \w were|strong="H3478"\w* camped \w at|strong="H3427"\w* \w a|strong="H3068"\w* \w place|strong="H3427"\w* called Acacia \add Grove\add*, \w some|strong="H5971"\w* \w of|strong="H1323"\w* \w the|strong="H2181"\w* \w men|strong="H5971"\w* caused themselves \w to|strong="H3478"\w* \w become|strong="H2181"\w* unacceptable \w to|strong="H3478"\w* God \w by|strong="H3478"\w* having sex \w with|strong="H3427"\w* \w some|strong="H5971"\w* \w of|strong="H1323"\w* \w the|strong="H2181"\w* \w women|strong="H1323"\w* \w of|strong="H1323"\w* \w the|strong="H2181"\w* \w Moab|strong="H4124"\w* \add people-group who lived in that area\add*.
\v 2 \w Then|strong="H7121"\w* those women \w invited|strong="H7121"\w* \w the|strong="H7121"\w* \w men|strong="H5971"\w* \w to|strong="H7121"\w* \w come|strong="H5971"\w* when \w the|strong="H7121"\w* \w sacrifices|strong="H2077"\w* \w were|strong="H5971"\w* \w being|strong="H5971"\w* offered \w to|strong="H7121"\w* \w their|strong="H7121"\w* gods. \w The|strong="H7121"\w* Israeli \w men|strong="H5971"\w* \add accepted\add*. \w They|strong="H5971"\w* \w went|strong="H5971"\w* \w to|strong="H7121"\w* \w the|strong="H7121"\w* feasts \w with|strong="H5971"\w* \w the|strong="H7121"\w* women \w and|strong="H5971"\w* \w worshiped|strong="H7812"\w* \w the|strong="H7121"\w* gods \w of|strong="H2077"\w* \w the|strong="H7121"\w* Moab people-group.
\v 3 \w By|strong="H3068"\w* doing \w that|strong="H3068"\w*, those Israeli people \w joined|strong="H6775"\w* \w the|strong="H3068"\w* women \w in|strong="H3478"\w* worshiping \w the|strong="H3068"\w* \w god|strong="H3068"\w* \w Baal|strong="H1187"\w* \add add \add*\w who|strong="H3068"\w* \w the|strong="H3068"\w* Moab people-group thought lived \w on|strong="H3068"\w* \w Peor|strong="H1187"\w* Mountain. \w That|strong="H3068"\w* caused \w Yahweh|strong="H3068"\w* \w to|strong="H3478"\w* become \w very|strong="H2734"\w* \w angry|strong="H2734"\w* \w with|strong="H3068"\w* \w his|strong="H3068"\w* people.
\p 
\v 4 \w Yahweh|strong="H3068"\w* said \w this|strong="H3068"\w* \w to|strong="H7725"\w* \w Moses|strong="H4872"\w*/\w me|strong="H7725"\w*: “\w Seize|strong="H3947"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w leaders|strong="H7218"\w* \w of|strong="H3068"\w* \w those|strong="H3605"\w* \w men|strong="H7218"\w* \w who|strong="H3605"\w* \w are|strong="H5971"\w* doing \w this|strong="H3068"\w* \w and|strong="H4872"\w* \w execute|strong="H3363"\w* \w them|strong="H7725"\w* while \w I|strong="H3068"\w* \w am|strong="H3068"\w* watching. \w Do|strong="H3068"\w* \w that|strong="H5971"\w* \w in|strong="H3478"\w* \w the|strong="H3605"\w* daytime. After \w you|strong="H3605"\w* \w do|strong="H3068"\w* \w that|strong="H5971"\w*, \w I|strong="H3068"\w* \w will|strong="H3068"\w* \w no|strong="H3605"\w* longer \w be|strong="H3068"\w* angry \w with|strong="H3068"\w* \w the|strong="H3605"\w* Israeli \w people|strong="H5971"\w*.”
\p 
\v 5 \w So|strong="H4872"\w* \w Moses|strong="H4872"\w*/\w I|strong="H3478"\w* said \w to|strong="H3478"\w* \w the|strong="H4872"\w* other Israeli \w leaders|strong="H8199"\w*, “Each \w of|strong="H8199"\w* \w you|strong="H3478"\w* \w must|strong="H3478"\w* \w execute|strong="H8199"\w* \w your|strong="H2026"\w* \w men|strong="H3478"\w* \w who|strong="H3478"\w* \w have|strong="H3478"\w* \w joined|strong="H6775"\w* \add others\add* \w in|strong="H3478"\w* worshiping \w Baal|strong="H1187"\w*.”
\p 
\v 6 \add But later\add*, \w while|strong="H2009"\w* \w Moses|strong="H4872"\w*/\w I|strong="H2009"\w* \w and|strong="H1121"\w* many [HYP] \w other|strong="H3605"\w* \w people|strong="H1121"\w* \w were|strong="H3478"\w* \w crying|strong="H1058"\w* \w at|strong="H3478"\w* \w the|strong="H3605"\w* \w entrance|strong="H6607"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* Sacred Tent, \w while|strong="H2009"\w* \w they|strong="H1992"\w*/\w we|strong="H3068"\w* \w were|strong="H3478"\w* \w watching|strong="H5869"\w*, \w one|strong="H3605"\w* \w of|strong="H1121"\w* \w the|strong="H3605"\w* Israeli \w men|strong="H1121"\w* \w brought|strong="H7126"\w* \w a|strong="H3068"\w* \w woman|strong="H4084"\w* \w from|strong="H3478"\w* \w the|strong="H3605"\w* Midian people-group into \w his|strong="H3605"\w* tent \add and started to have sex with her\add*.
\v 7 \w When|strong="H7200"\w* \w Phinehas|strong="H6372"\w*, \w who|strong="H3548"\w* \w was|strong="H1121"\w* \w the|strong="H7200"\w* \w grandson|strong="H1121"\w* \w of|strong="H1121"\w* Aaron, \w saw|strong="H7200"\w* \w that|strong="H7200"\w*, \w he|strong="H3027"\w* grabbed \w a|strong="H3068"\w* \w spear|strong="H7420"\w*
\v 8 \w and|strong="H1121"\w* rushed \w into|strong="H5921"\w* \w the|strong="H5921"\w* \w man|strong="H1121"\w*’s \w tent|strong="H6898"\w*. \w He|strong="H8147"\w* \w thrust|strong="H1856"\w* \w the|strong="H5921"\w* spear completely \w through|strong="H1856"\w* \w the|strong="H5921"\w* \w man|strong="H1121"\w*’s body \w and|strong="H1121"\w* \w into|strong="H5921"\w* \w the|strong="H5921"\w* woman’s \w belly|strong="H6897"\w* \add and killed both of them\add*. \w When|strong="H1121"\w* \w he|strong="H8147"\w* \w did|strong="H3478"\w* \w that|strong="H3478"\w*, \w the|strong="H5921"\w* ◄\w plague|strong="H4046"\w*/serious illness► \add that had started to strike the Israelis\add* \w stopped|strong="H6113"\w*.
\v 9 \w But|strong="H1961"\w* 24,000 people \w had|strong="H1961"\w* already \w died|strong="H4191"\w* \add from that plague\add*.
\p 
\v 10 \w Then|strong="H1696"\w* \w Yahweh|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*,
\v 11 “\w Phinehas|strong="H6372"\w* \w has|strong="H3478"\w* caused \w me|strong="H7725"\w* \w to|strong="H7725"\w* \w stop|strong="H3808"\w* \w being|strong="H1121"\w* \w angry|strong="H2534"\w* \w with|strong="H5921"\w* \w the|strong="H5921"\w* Israeli \w people|strong="H1121"\w*, \w by|strong="H5921"\w* \w being|strong="H1121"\w* \w as|strong="H1121"\w* eager \w as|strong="H1121"\w* \w I|strong="H5921"\w* am \add to stop this sinful behavior\add*. \w I|strong="H5921"\w* \w was|strong="H3478"\w* ready \w to|strong="H7725"\w* \w get|strong="H7725"\w* rid \w of|strong="H1121"\w* \w all|strong="H7725"\w* \w the|strong="H5921"\w* Israeli \w people|strong="H1121"\w* \w because|strong="H5921"\w* \w I|strong="H5921"\w* \w was|strong="H3478"\w* extremely \w angry|strong="H2534"\w*, \w but|strong="H3808"\w* \w Phinehas|strong="H6372"\w* \w has|strong="H3478"\w* prevented \w me|strong="H7725"\w* \w from|strong="H7725"\w* doing \w that|strong="H3478"\w*.
\v 12 \w Now|strong="H2005"\w* tell \w him|strong="H5414"\w* \w that|strong="H3651"\w* \w I|strong="H2005"\w* \w am|strong="H2005"\w* \w making|strong="H5414"\w* \w a|strong="H3068"\w* special \w peace|strong="H7965"\w* \w agreement|strong="H1285"\w* \w with|strong="H1285"\w* \w him|strong="H5414"\w*.
\v 13 \w In|strong="H5921"\w* \w this|strong="H3478"\w* \w agreement|strong="H1285"\w*, \w I|strong="H5921"\w* \w am|strong="H1961"\w* promising \w to|strong="H3478"\w* \w give|strong="H1961"\w* \w to|strong="H3478"\w* \w him|strong="H5921"\w* \w and|strong="H1121"\w* \w to|strong="H3478"\w* \w his|strong="H5921"\w* \w descendants|strong="H2233"\w* \w the|strong="H5921"\w* \w right|strong="H3478"\w*/\w authority|strong="H5921"\w* \w to|strong="H3478"\w* \w be|strong="H1961"\w* priests. \w I|strong="H5921"\w* \w am|strong="H1961"\w* doing \w this|strong="H3478"\w* \w because|strong="H5921"\w* \add he showed that\add* \w he|strong="H5921"\w* \w was|strong="H1961"\w* \w very|strong="H7065"\w* eager \w to|strong="H3478"\w* honor \w me|strong="H5921"\w*, \w his|strong="H5921"\w* God, \w by|strong="H5921"\w* stopping \w this|strong="H3478"\w* sinful behavior. \w He|strong="H5921"\w* \w has|strong="H1961"\w* \w caused|strong="H1961"\w* \w the|strong="H5921"\w* Israeli \w people|strong="H1121"\w* \w to|strong="H3478"\w* \w become|strong="H1961"\w* acceptable \w to|strong="H3478"\w* \w me|strong="H5921"\w* \w again|strong="H1961"\w* \w by|strong="H5921"\w* causing \w them|strong="H5921"\w* \w to|strong="H3478"\w* \w be|strong="H1961"\w* \w forgiven|strong="H3722"\w* \w for|strong="H5921"\w* \w their|strong="H5921"\w* sin.”
\p 
\v 14 \w The|strong="H5221"\w* Israeli \w man|strong="H1121"\w* \w who|strong="H1121"\w* \w was|strong="H8034"\w* \w killed|strong="H5221"\w* \w with|strong="H1004"\w* \w the|strong="H5221"\w* \w woman|strong="H4084"\w* \w of|strong="H1121"\w* \w the|strong="H5221"\w* Moab people-group \w was|strong="H8034"\w* \w named|strong="H8034"\w* \w Zimri|strong="H2174"\w*. \w He|strong="H1004"\w* \w was|strong="H8034"\w* \w the|strong="H5221"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Salu|strong="H5543"\w*, \w who|strong="H1121"\w* \w was|strong="H8034"\w* \w the|strong="H5221"\w* \w leader|strong="H5387"\w* \w of|strong="H1121"\w* \w a|strong="H3068"\w* \w family|strong="H1004"\w* \w from|strong="H3478"\w* \w the|strong="H5221"\w* tribe \w of|strong="H1121"\w* \w Simeon|strong="H8099"\w*.
\v 15 \w The|strong="H5221"\w* \w woman|strong="H1323"\w*’s \w name|strong="H8034"\w* \w was|strong="H8034"\w* \w Cozbi|strong="H3579"\w*. \w She|strong="H1931"\w* \w was|strong="H8034"\w* \w the|strong="H5221"\w* \w daughter|strong="H1323"\w* \w of|strong="H1004"\w* \w Zur|strong="H6698"\w*, \w who|strong="H1931"\w* \w was|strong="H8034"\w* \w the|strong="H5221"\w* \w leader|strong="H7218"\w* \w of|strong="H1004"\w* \w one|strong="H1931"\w* \w of|strong="H1004"\w* \w the|strong="H5221"\w* \w clans|strong="H1004"\w* \w of|strong="H1004"\w* \w the|strong="H5221"\w* \w Midian|strong="H4080"\w* people-group.
\p 
\v 16 \w Then|strong="H1696"\w* \w Yahweh|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*,
\v 17 “\add Take your men and\add* \w attack|strong="H5221"\w* \w the|strong="H5221"\w* Midian people-group \w and|strong="H5221"\w* \w kill|strong="H5221"\w* \w them|strong="H5221"\w*.
\v 18 \w They|strong="H1992"\w* \w have|strong="H1697"\w* become \w your|strong="H5921"\w* \w enemies|strong="H6887"\w*, \w because|strong="H3588"\w* \w they|strong="H1992"\w* tricked \w you|strong="H3588"\w* Israeli people \w and|strong="H3117"\w* induced/persuaded many \w of|strong="H3117"\w* \w you|strong="H3588"\w* \w to|strong="H5921"\w* worship Baal, \w and|strong="H3117"\w* \w because|strong="H3588"\w* \add one of your men had sex with\add* \w Cozbi|strong="H3579"\w*, \w who|strong="H1992"\w* \w was|strong="H1697"\w* \w the|strong="H5921"\w* \w daughter|strong="H1323"\w* \w of|strong="H3117"\w* \w a|strong="H3068"\w* \w leader|strong="H5387"\w* \w of|strong="H3117"\w* \w the|strong="H5921"\w* \w Midian|strong="H4080"\w* people-group. \w She|strong="H3588"\w* \w was|strong="H1697"\w* \w killed|strong="H5221"\w* \w at|strong="H5921"\w* \w the|strong="H5921"\w* \w time|strong="H3117"\w* \w the|strong="H5921"\w* \w plague|strong="H4046"\w* \add started because the people sinned\add* \w at|strong="H5921"\w* \w Peor|strong="H6465"\w* \add Mountain\add*.”
\c 26
\s1 The people were counted again
\p 
\v 1 After \w the|strong="H3068"\w* plague \add ended\add*, \w Yahweh|strong="H3068"\w* said \w to|strong="H3068"\w* Eleazar \w and|strong="H1121"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1121"\w*,
\v 2 “\w Count|strong="H8141"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H1121"\w* \w of|strong="H1121"\w* \w Israel|strong="H3478"\w* \add again\add*. Write \w down|strong="H7218"\w* \w the|strong="H3605"\w* names \w of|strong="H1121"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w men|strong="H1121"\w* \w who|strong="H3605"\w* \w are|strong="H1121"\w* \w at|strong="H3478"\w* least 20 \w years|strong="H8141"\w* \w old|strong="H1121"\w* \w who|strong="H3605"\w* \w are|strong="H1121"\w* able \w to|strong="H3318"\w* fight \add in battles\add*, \w along|strong="H5375"\w* \w with|strong="H1004"\w* \w their|strong="H3605"\w* \w family|strong="H1004"\w* names.”
\v 3 \w So|strong="H1696"\w* \w while|strong="H5921"\w* \w the|strong="H5921"\w* Israelis \w were|strong="H3383"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w plains|strong="H6160"\w* \w where|strong="H5921"\w* \w the|strong="H5921"\w* \w Moab|strong="H4124"\w* people-group lived, Eleazar \w and|strong="H4872"\w* \w Moses|strong="H4872"\w*/\w I|strong="H5921"\w* \w told|strong="H1696"\w* \w this|strong="H1696"\w* \w to|strong="H1696"\w* \w the|strong="H5921"\w* Israeli leaders:
\v 4 “Write \w down|strong="H4605"\w* \w the|strong="H3068"\w* names \w of|strong="H1121"\w* \w all|strong="H6680"\w* \w the|strong="H3068"\w* Israeli \w men|strong="H1121"\w* \w who|strong="H3068"\w* \w are|strong="H1121"\w* \w at|strong="H3478"\w* least 20 \w years|strong="H8141"\w* \w old|strong="H1121"\w*, \w as|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* \w commanded|strong="H6680"\w* \w us|strong="H3478"\w*.”
\p \add So they did that\add*, \w and|strong="H1121"\w* \w this|strong="H3068"\w* \w is|strong="H3068"\w* \w a|strong="H3068"\w* record \w of|strong="H1121"\w* \w all|strong="H6680"\w* \w the|strong="H3068"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* Jacob \w who|strong="H3068"\w* \w came|strong="H3318"\w* \w out|strong="H3318"\w* \w of|strong="H1121"\w* \w Egypt|strong="H4714"\w* \add who were still alive\add*.
\li1 
\v 5-7 \add They counted\add* 43,730 men from the tribe of Reuben, Jacob’s oldest son. They were in clans descended from Hanoch, Pallu, Hezron, and Carmi.
\v 8 Pallu’s son was Eliab
\v 9 and his grandsons were Nemuel, Dathan and Abiram. Dathan and Abiram were the leaders who joined with Korah to conspire against Aaron and Moses/me and rebelled against Yahweh.
\li1 
\v 10 But the earth opened up and swallowed them and Korah. Yahweh also sent a fire that burned up 250 men who supported those three men. That was a warning \add to all the Israeli people\add* that they should respect and obey the leaders whom Yahweh had appointed.
\v 11 But the descendants of Korah did not die \add on that day\add*.
\li1 
\v 12-14 The Israeli leaders counted 22,200 men from the tribe of Simeon. They were in clans descended from Nemuel, Jamin, Jakin, Zerah, and Shaul.
\li1 
\v 15-18 They counted 40,500 men from the tribe of Gad. They were in clans descended from Zephon, Haggi, Shuni, Ozni, Eri, Arod, and Areli.
\li1 
\v 19-22 They counted 76,500 men from the tribe of Judah. They were in clans descended from Shelah, Perez, Zerah, Hezron, and Hamul. Judah’s other two sons, Er and Onan, died in Canaan \add without having had any children\add*.
\li1 
\v 23-25 They counted 64,300 men from the tribe of Issachar. They were in clans descended from Tola, Puvah, Jashub, and Shimron.
\li1 
\v 26-27 They counted 60,500 men from the tribe of Zebulun. They were in clans descended from Sered, Elon, and Jahleel.
\li1 
\v 28-34 They counted 52,700 men from the tribe of Manasseh, who was one of the sons of Joseph. They were in clans descended from Machir, from his son Gilead, and from his six grandsons—Jezer, Helek, Asriel, Shechem, Shemida, and Hepher. Hepher’s son Zelophehad did not have any sons, but he had five daughters—Mahlah, Noah, Hoglah, Milcah, and Tirzah.
\li1 
\v 35-37 They counted 32,500 men from the tribe of Ephraim, who was Joseph’s other son. They were in clans descended from Shuthelah, Becher, Tahan, and Shuthelah’s son Eran.
\li1 
\v 38-41 They counted 45,600 men from the tribe of Benjamin. They were in clans descended from Bela, Ashbel, Ahiram, Shephupham, and Hupham, and from Bela’s two sons—Ard and Naaman.
\li1 
\v 42-43 They counted 64,400 men from the tribe of Dan. They were in one clan descended from Shuham.
\li1 
\v 44-47 They counted 53,400 men from the tribe of Asher. They were in clans descended from Imnah, Ishvi, and Beriah, and from Beriah’s two sons—Heber and Malkiel. Asher also had a daughter named Serah.
\li1 
\v 48-50 They counted 45,400 men from the tribe of Naphtali. They were in clans descended from Jahzeel, Guni, Jezer, and Shillem.
\m 
\v 51 \w The|strong="H6485"\w* total \w of|strong="H1121"\w* \w the|strong="H6485"\w* Israeli \w men|strong="H1121"\w* whom \w the|strong="H6485"\w* leaders \w counted|strong="H6485"\w* \w was|strong="H3478"\w* 601,730.
\b
\p 
\v 52 \w Then|strong="H1696"\w* \w Yahweh|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*,
\v 53 “\w Divide|strong="H2505"\w* Canaan \w land|strong="H5159"\w* \w among|strong="H8034"\w* \w the|strong="H8034"\w* tribes. \w Distribute|strong="H2505"\w* \w the|strong="H8034"\w* \w land|strong="H5159"\w* according \w the|strong="H8034"\w* \w number|strong="H4557"\w* \w of|strong="H8034"\w* \w people|strong="H5159"\w* \w in|strong="H8034"\w* each tribe \w that|strong="H4557"\w* \w are|strong="H8034"\w* \w on|strong="H8034"\w* your lists.
\v 54-56 Decide by ◄casting lots/throwing stones which are marked► to determine which group will get which area, but give the largest areas to the groups with the most people.”
\p 
\v 57 \w The|strong="H6485"\w* leaders also \w counted|strong="H6485"\w* \w the|strong="H6485"\w* male \w descendants|strong="H4940"\w* \w of|strong="H4940"\w* \w Levi|strong="H3881"\w*. They \w were|strong="H3881"\w* \w in|strong="H3881"\w* \w clans|strong="H4940"\w* descended \w from|strong="H3881"\w* \w Gershon|strong="H1648"\w*, \w Kohath|strong="H6955"\w*, \w and|strong="H3881"\w* \w Merari|strong="H4847"\w*.
