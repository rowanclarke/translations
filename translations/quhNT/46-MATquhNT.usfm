\id MAT - South Bolivia Quechua NT -Bolivia 2011 (DBL -2013) 
\h SAN MATEO 
\toc1 El Santo Evangelio Segun San Mateo 
\toc2 San Mateo 
\toc3 Mt 
\mt2 EL SANTO EVANGELIO SEGUN 
\mt1 SAN MATEO 
\c 1  
\s1 Jesucristoj ñaupaj tatasnin 
\p  
\v 1 Cay kelkaskaka Jesucristoj ñaupaj tatasninmantamin. Jesuska Abrahammanta jamun Davidmantawan. 
\p  
\v 2 Abrahamka Isaacpa tatan carka. Isaactaj Jacobpa tatan carka. Jacobtaj Judajpata waukesninpatawan tatancu carka.  
\v 3 Judataj Farespa tatan carka, Zarajtawan. Paycunaj mamancuri Tamar carka. Farestaj Esrompa tatan carka. Esromtaj Arampa tatan carka.  
\v 4 Aramtaj Aminadabpa tatan carka. Aminadabtaj Naasonpa tatan carka. Naasontaj Salmonpa tatan carka.  
\v 5 Salmontaj Boozpa tatan carka. Boozpa mamanri Rahab carka. Booztaj Rutwan Obedpa tatasnin carkancu. Obedtaj Isaipa tatan carka.  
\v 6 Isaitaj camachej Davidpa tatan carka. Davidtaj Salomonpa tatan carka. Salomonpa maman ñaupajta Uriaspa warmin carka. 
\p  
\v 7 Salomontaj Roboampa tatan carka. Roboamtaj Abiaspa tatan carka. Abiastaj Asaj tatan carka.  
\v 8 Asataj Josafatpa tatan carka. Josafattaj Jorampa tatan carka. Joramtaj Uziaspa tatan carka.  
\v 9 Uziastaj Jotampa tatan carka. Jotamtaj Acazpa tatan carka. Acaztaj Ezequiaspa tatan carka.  
\v 10 Ezequiastaj Manasespa tatan carka. Manasestaj Amonpa tatan carka. Amontaj Josiaspa tatan carka.  
\v 11 Josiastaj Jeconiaspata waukesninpatawan tatancu carka. Chaypacha Diospa unay runasnin Babiloniaman apaskas carkancu. 
\p  
\v 12 Babiloniaman apaskas carkancu chay khepatataj Jeconiaska Salatielpa tatan carka. Salatieltaj Zorobabelpa tatan carka.  
\v 13 Zorobabeltaj Abiudpa tatan carka. Abiudtaj Eliaquimpa tatan carka. Eliaquimtaj Azorpa tatan carka.  
\v 14 Azortaj Sadocpa tatan carka. Sadoctaj Aquimpa tatan carka. Aquimtaj Eliudpa tatan carka.  
\v 15 Eliudtaj Eleazarpa tatan carka. Eleazartaj Matanpa tatan carka. Matantaj Jacobpa tatan carka.  
\v 16 Jacobtaj, Maríaj kosanpa Joséj tatan carka. Chay Mariamanta Jesuska nacecorka. Payka Diospa ajllaskan Cristo sutichaska carka. 
\p  
\v 17 Ajinapi tucuy miraycunaka Abrahammanta Davidcama chunca tawayoj yupacuncu. Davidmanta Babiloniaman Diospa runasnin apachiskas carkancu chaypachacamataj chunca tawayoj miraycuna carkancu. Babiloniaman apaskas carkancu chaymantapacha Cristoj nacecuynincamataj chunca tawayoj miraycuna carkancu. 
\s1 Jesucristo nacecun 
\p  
\v 18 Cayjinapimin Jesucristoka nacecorka. María, Jesuspa mamanka, mañaskaña carka Josewan casaracunanpaj. Manaraj tanta cashajtincutaj Mariaka wijsalliska riqhurerka Santo Espiritunejta.  
\v 19 Parlaskan Josetaj chekanta ruwaj runa carka. Mana munaspa Mariata p'enkayman riqhurichiyta yuyarka pacayllamanta sakepuyta.  
\v 20 Chay imasmanta mayta yuyashajtintaj, khaway, Señor Dios uj angelta cachamorka. Moskoyninpi Joseman riqhurispa nerka: 
\p —José, camachej Davidpa ayllunmanta canqui. Amaña manchachicuychu parlapayaskayqui Mariata jap'icapuyta. Cay wijsallicuskanka Santo Espiritumantamin cashan.  
\v 21 Mariaka uj khari wawata onkoconka. Paytajmin wiñaspa paypa cajcunanta juchamanta cacharichenka. Chayraycu Jesusta sutichanqui. 
\p  
\v 22 Tucuy cayka ruwacorka Señor Diospa niskan junt'acunanpaj. Chaytaka unay willajninnejta nerka: 
\q1  
\v 23 ¡Khaway! Uj sipas, mana khari rejsej, wijsalliconka. Uj khari wawata onkoconka. Payka Emanuel sutichaska canka. 
\q1 Emanuel niyta munan: Dios nokanchejwan cashan yanapanawanchejpaj. 
\p  
\v 24 Joseka puñuskanmanta rijch'arispa, Señor Diosmanta cachamuska, chay angelpa camachiskanmanjina ruwarka. Ajinapi payka Mariata wasinman pusacaporka runas yachanancupaj warmin caskanta.  
\v 25 Joserí payta mana llanqharkachu curaj wawanta onkocunancama. Wawa nacecojtintaj Jesusta suticharka. 
\c 2  
\s1 Yachaysapacuna Jesusta taripaspa yupaychancu 
\p  
\v 1 Jesuska Judea jallp'a Belén llajtapi nacecorka, Herodes camachishajtin, chay p'unchaycunapi. Chaypacha yachaysapacuna inti llojsimuy caru llajtamanta jamuspa Jerusalén llajtaman chayamorkancu.  
\v 2 Tapucorkancutaj: 
\p —¿Maypitaj cashan israel runasta camachinanpaj nacecoj Wawarí? Ch'ascanta inti llojsimuy ladopi ricuycu. Chayta khatispataj payta yupaychanaycupaj jamuycu, —nispa. 
\p  
\v 3 Chayta uyariytawantaj camachej Herodeska mancharicorka. Jerusalén llajtapi caj tucuy runaspis paywan mancharicullarkancutaj.  
\v 4 Chaymantataj Herodes tantachimorka yupaychana-wasimanta curajcunata, israel yachachejcunatawan. Paycunata taporka: 
\p —¿Maypitaj Diospa ajllaskan Cristo nacecunan tiyan? 
\p  
\v 5 Paycunataj cuticherkancu: 
\p —Judea jallp'a Belén llajtapi naceconka. Ajinata Dios unay willajninta kelkacherka: 
\q1  
\v 6 Kancuna, Judá jallp'a Belén llajtapi tiyacojcunata niyquichej: 
\q1 Judá jallp'api caj curajcunamanta aswan jatunpaj khawaskas canquichej. 
\q1 Kancunamanta uj curaj camachej naceconka. 
\q1 Paytaj, ajllaska israelcunayta michenka. 
\p  
\v 7 Chanta Herodes pacayllamanta yachaysapacunata wajyacherka. Ajinallatataj taporka yachananpaj mayc'ajchus chay ch'asca riqhurimuskanta.  
\v 8 Paycunatataj Belén llajtaman cacharka nispa: 
\p —Riychej. Allintataj yachamuychej chay wawitamanta. Payta tarispataj willawaj cutimuychej. Nokapis rispa payta yupaychamusaj, —nispa. [Chaytari mana cheka sonkowanchu nisharka.]\f + \fr 2:8 \ft Ninayan.\f* 
\p  
\v 9 Yachaysapacunaka camachejpa niskanmanjina riporkancu. Inti llojsimuy, chay ladopi ricuskancu ch'ascaka ñaupakencuta risharka. Jesús casharka, chaycama pusamuspa patannejpi sayacorka. \fig |src="CN01628b.tif" size="span" copy="© 1978 David C. Cook Publishing Co." ref="San Mateo 2.9" \fig* 
\v 10 Yachaysapacunataj chay ch'ascata ricuspa maytapuni cusicorkancu.  
\v 11 Paycuna wasiman yaycuspataj Wawitata ricorkancu maman Mariatawan. Konkoricuspataj Jesusta yupaycharkancu. Apaskancuta quicharispa khapaj capuynincuta payman korkancu. Korita, inciensota, k'apayniyoj mirra jampitawan payta yupaychaspa jaywarkancu.  
\v 12 Chaymantataj moskoynincupi Dios paycunata willarka Herodespaman ama cutinancuta. Chayraycu paycunaka jallp'ancuman waj ñanta cutiporkancu. 
\s1 Egiptoman aykecuncu 
\p  
\v 13 Yachaysapa runas ripuskancuwantaj Dios uj willaj angelta cachamorka. Joseman moskoyninpi riqhurimuspataj nerka: 
\p —Jataricuy. Wawitata, Wawaj mamantawan pusaricuspa Egipto jallp'aman aykecuy. Jakaypi tiyacamuy noka willasunaycama. Herodeska masc'aj rishan Wawitata wañuchinanpaj, —nispa. 
\p  
\v 14 Chay quiquinpachataj José tutapi rijch'arispa jatarerka. Wawitata mamantawan pusariycucuspa Egipto jallp'aman riporka.  
\v 15 Jakaypitaj Herodes wañunancama tiyacamorkancu. Tucuy cayka ruwacorka Diospa niskan junt'acunanpaj. Chaytaka unay willajninnejta nerka: “Egiptomanta llojsimpunanta Wawayta wajyarkani”. 
\s1 Herodes wawasta wañuchin 
\p  
\v 16 Herodeska chay yachaysapacuna anchata asipayaycuskancuta reparaspa mayta phiñacorka. Runasnintataj camacherka tucuy khari wawasta iscay watayojcama wañuchimunancuta. Paycunataj wawacunata wañucherkancu Belén llajtapi tucuy chaynejpipis. Jesuspa ch'ascan riqhurimuskan p'unchaycunata yachaysapacunamanta yachaspa chayta ruwarka.  
\v 17 Ajinapi Diospa niskan junt'aska carka. Pay unay willajnin Jeremiasnejta nerka: 
\q1  
\v 18 Phutiy wakay uyaricun Ramá llajtapi. 
\q1 Raquel wawasninmanta khaparispa wakashan jatun llaquiywan “ay, ay” nispa. 
\q1 Manaña sonkochacunmanñachu wawasnin wañuskas caskancuraycu. 
\p  
\v 19 Herodes wañupojtinrí Dios uj willaj angelta cachamorka. Joseman moskoyninpi riqhurispa Egipto jallp'api  
\v 20 nerkataj: 
\p —Jataricuy. Wawitata mamantawan pusaricuspa ripuy Israel jallp'aman. Wawitata wañuchiyta munajcunaka ñapis wañupuncuña, —nispa. 
\p  
\v 21 Chay quiquinpacha José jataricuspa Wawitata mamantawan pusaricorka Israel jallp'aman.  
\v 22 Arquelao tatan Herodespa cuentanpi Judea jallp'ata camachisharka. Chayta uyarispa Joseka manchachicorka chayman tiyacoj riyta. Moskoyninpi Dios payman willaskanraycutaj Galilea jallp'aman riporka.  
\v 23 Nazaret llajtaman chayaspa chaypi tiyacorka. Ajina ruwacorka Diospa niskan junt'acunanpaj. Unay willajcunanejta nerka Jesús Nazaret llajtayoj sutichaska cananta. 
\c 3  
\s1 Juan willaran 
\p  
\v 1 Chaypacha bautizaj Juanka riqhurerka willaraspa Judea jallp'a ch'innejpi.  
\v 2 Nerkataj: 
\p —Diospa ajllaskan camachinanpaj chayamunña. Chayraycu juchasniyquichejta sakespa payman cutiriychej, —nispa. 
\q1  
\v 3 Cay Juanmanta Diospa unay willajnin Isaías parlarka: 
\q1 Ch'innejpi uj runa khaparishan: 
\q1 “Runas uj jatun camachej jamunanpaj ñanta waquichipunancu tiyan. 
\q1 Ajinallatataj sonkosniyquichejta waquichiychej tucuy atiyniyoj Señor jamunanpaj”. 
\p  
\v 4 Willaraj Juanka llamajina camello millmamanta p'achawan p'achallicorka. Kara chumpiwantaj chumpiska carka. Langostastataj miqhoj lachiwana misq'itawan.  
\v 5 Ashqha runas payta uyarej llojsimoj cancu. Jerusalén llajtamantapis tucuy Judea jallp'amantawan Jordán mayu tucuy chaynejmantawan jamoj cancu.  
\v 6 Paycuna juchasnincuta willashajtincu Juan Jordán mayupi paycunata bautizasharka. [Ajinapi runas ricucherkancu Diosman cutiriskancuta.]\f + \fr 3:6 \ft Ninayan.\f* 
\p  
\v 7 Juanka ashqha fariseo partecunata saduceo partecunatawan bautizacoj jamushaskancuta ricorka. Paycunatataj nerka: 
\p —Kancuna runa wañuchi catarisjina canquichej. Diospa c'ajaj phiñacuyninmanta aykecunayquichejpaj ¿pitaj willasorkachejrí? —nispa.  
\v 8 Diospa phiñacuyninmanta aykecuyta munanquichej chayka, juchasniyquichejta sakeychej. Chaywanpis c'acha ruwaskasniyquichejwan Diosman cutiriskayquichejta ricuchiychej.  
\v 9 Kancunaka Abraham unay tatanchej caskanta nishanquichej. Diospa cheka wawasnin caskayquichejta yuyaspa pantanquichej. Amaña sonkoyquichejpi ajinata jatunchacuychejchu. Imaraycuchus niyquichej Dioska atiyniyojmin cay rumismantapis Abrahampaj cheka wawasninta ruwananpaj.  
\v 10 Hachaka waquichiskaña cashan sach'a saphinmanta c'utunanpaj. Sapa sach'a mana allin pokojtaka runas c'utuspa ninaman wijch'uncu.  
\v 11 Chekatapuni noka yacupi bautizayquichej Diosman cutiriskayquichejta ricuchinapaj. Khepaytarí Diospa ajllaskan Cristo jamonka. Payka aswan curaj atiyniyoj nokamanta niskaka. Mana paypajka [camachinpajjinallapischu cani runalla caskayraycu.]\f + \fr 3:11 \ft Ninayan.\f* Paymin kancunata bautizaspa Santo Espirituta sonkoyquichejman cachamusonkachej Diosllapaj causanayquichejpaj. Ninawantaj bautizasonkachej.  
\v 12 Trigo erata wayrachejka jorc'ata maquinpiña jap'ishan. Erata sumajta pichanka trigota ch'uyachananpaj. Trigota pirwanman jallch'anka. Pajatarí ni jayc'aj wañoj ninaman ruphachenka, —nispa willararka Juan. 
\s1 Jesusta bautizarka 
\p  
\v 13 Chanta Jesuska Galilea jallp'amanta Jordán mayuman jamorka. Chaypitaj Juanwan bautizachicuyta munarka.  
\v 14 Juanrí mana munarkachu bautizayta. Jesusmantaj nerka: 
\p —Nokata astawanpis kanka bautizanawayqui tiyan. Chanta ¿imaraycutaj nokaman jamuwanqui? —nispa. 
\p  
\v 15 Jesusrí payman cuticherka: 
\p —Cunan bautizanawayqueka allillan. Yachanchej Diospa tucuy munayninta ruwananchejpuni caskanta, —nispa. 
\p Chanta Juanka Jesuspa mañaskanta ruwarka.  
\v 16 Jesuska bautizachicuytawan yacumanta llojsiporka. Janaj pachari paypaj quichariska carka. Ricorkataj Diosmanta cachamuska Santo Espirituta palomatajina uraycamojta payman tiyaycucojtapis.  
\v 17 Ajinapitaj Dios janaj pachamanta nimorka: 
\p —Paymin c'ata munaska Wawayka. Paypi mayta cusicuni, —nispa. 
\c 4  
\s1 Supay munarka Jesusta juchallichiyta 
\p  
\v 1 Chanta Santo Espiritoka ch'in lomaman Jesusta pusarka. Chaypitaj supay Satanás imaymanamanta juchallichiyta munarka. 
\p  
\v 2 Jesuska tawa chunca p'unchayta tawa chunca tutatawan mana miqhorkachu Diosta yupaychananpaj. Chaymantataj payka yarkhachicorka.  
\v 3 Chay pantachej supayri Jesusman kayllaycuspa nerka: 
\p —Sichus Diospa cheka Wawan canqui chayka, niy cay rumista t'antaman cutinancuta. 
\p  
\v 4 Jesusrí cutichispa nerka: 
\p —Palabranpi Dios nin: “Mana miqhunallawanchu runaka causan. Manachayrí Diospa tucuy niskanta casuspa causan”, —nispa. 
\p  
\v 5 Chanta supayka Diospa ajllaska llajtan Jerusalenman Jesusta pusarka. Chaypitaj yupaychana-wasi patapi sayaricherka.  
\v 6 Jesusmantaj nerka: 
\p —Diospa Wawan canqui chayka, cay patamanta pampaman phinquiycuy. Imaraycuchus Diospa palabranpi nin: 
\q1 Angelesninta camachenka kanta wakaychasunancupaj. 
\q1 Maquisnincuwantaj kanta jap'isonkancu ama rumisman urmanayquipaj. 
\p  
\v 7 Jesusrí payta c'amerka: 
\p —Dios palabranpi nillantaj: “Ama Señor Diosniyquej atiyninta mana cajpaj mañacuychu”. 
\p  
\v 8 Uj cutitawan supayka Jesusta pusallarkataj. Cunanpeka may jatun orko patamanña chayacherka. Jesusmantaj tucuy cay pachapi caj camachiska jallp'asta, khapaj capuynincutawan ricucherka.  
\v 9 Chaymantataj supayka nerka: 
\p —Tucuy cayta kopuskayqui sichus kan konkoricuspa yupaychawanquiman chayka. 
\p  
\v 10 Chanta Jesuska payman cuticherka. 
\p —Ripuy nokamanta, supay Satanás. Imaraycuchus Dios palabranpi nin: “Señor Diosnillayquita yupaychay. Pay sapallamantaj konkoricuspa casuy”, —nispa. 
\p  
\v 11 Chaymanta supayka Jesusta sakeporka. Yanapaj angelestaj jamuspa Jesusman pisichicuskanta jaywarkancu. 
\s1 Jesús Galileapi ruwanasninta kallarin 
\p  
\v 12 Jesustaj Juan wisk'aska caskanta uyarispa Galilea jallp'aman rerka.  
\v 13 Nazaret llajtamanta llojsispa payka Capernaum llajtaman tiyacoj rerka. Chay llajtaka Galilea kocha cantopi carka. Zabulonwan Neftaliwan jallp'as chaynejpi carkancu.  
\v 14 Chaypi Jesús tiyacorka Diospa unay willajnin Isaías niskanmanjina: 
\q1  
\v 15 Zabulón jallp'api Neftalí jallp'apiwan tiyacojcuna, kancuna tiyacunquichej kochaman rina ñan Jordán mayu chimpapi. 
\q1 Galilea jallp'api tiyacuncu Diosmanta mana yachajcuna. 
\q1  
\v 16 Dioska willarajninta cachamorka wiñay causaymanta mana yachajcunapaj. 
\q1 Chay runaska wiñay wañuyman risharkancu. 
\q1 Paycunataj juchancumanta cachariskas canancupaj sumaj willanasta uyarerkancu. 
\q1 Chaytaj uj c'anchayjina carka tucuypaj. 
\p  
\v 17 Chaymantapachataj Jesús kallarerka willarayta: 
\p —Diospa ajllaskan p'unchayka cunan chayamushanña. Cunan payka munacoj Camachejniyquichej canka. Chayraycu juchasniyquichejta sakespa payman cutiricuychej sumaj willanasnintataj jap'icuychej. 
\s1 Jesús tawa challwirista wajyan 
\p  
\v 18 Jesuska Galilea kocha cantonejta purishaspa ricorka iscay waukesta. Ujnin Simón, Pedro sutiyoj carka, ujnintaj Andrés. Paycuna challwiris caspa jatun ch'ipata kochaman chokaycusharkancu.  
\v 19 Paycunaman Jesús nerkataj: 
\p —Jamuychej nokawan yachacojcunay canayquichejpaj. Kancuna challwiris canquichej. Cunanmantapachataj Diospi jap'icunancupaj runasta nokaman pusamuwanquichej. 
\p  
\v 20 Chay quiquinpacha ch'ipasnincuta sakerpayarkancu. Jesuswan rerkancutaj yachacojcunan canancupaj. 
\p  
\v 21 Uj chhicatawan rispataj Jesuska waj iscay waukestawan ricullarkataj. Paycuna Jacobo Juanwan carkancu. Cusca tatancu Zebedeowan barcopi ch'ipasnincuta t'irisharkancu. Jesús chay waukesta wajyarka yachacojcunan canancupaj.  
\v 22 Chay quiquinpachataj barcota tatancutawan sakerpayaspa kallarerkancu Jesuswan puriyta yachacojcunan canancupaj. 
\s1 Jesús ashqhasta yachachin 
\p  
\v 23 Jesús tucuy Galilea jallp'ata purispa tantacuna-wasisnincupi yachachisharka. Sumaj willanastataj willarasharka Diospa ajllaskan chaypiña caskanta camachinanpaj. Astawanpis runas uqhupi tucuy laya onkoycunata thañichisharka.  
\v 24 Tucuy caru Siria jallp'apipis Jesús atiyniyoj caskanta uyarerkancu. Jesusman apamorkancutaj tucuy laya onkoyniyojcunata: nanayniyojcunata, ñac'arejcunata, supayniyojcunata, t'ucu onkoyniyojcunata, suchustawan. Jesusri tucuynincuta thañicherka.  
\v 25 May ashqha runastaj Jesusta khaticorkancu. Galilea jallp'amanta, Decápolis jallp'amanta, Jerusalén llajtamanta, Judea jallp'amanta, Jordán mayu chimpamantawan paycuna jamorkancu. 
\c 5  
\s1 Cusicuyniyojcuna 
\p  
\v 1 Jesustaj may ashqha runasta ricuspa orkoman wicharerka. Chaypi tiyaycucojtintaj yachacojcunan payman kayllaycorkancu.  
\v 2 Paycunatataj jatuchej yachachinasta yachachisharka: 
\p  
\v 3 —May cusiskas cancu sonkoncupi Diosmanta pisiskas caskancuta khawacojcunaka. Imaraycuchus Dios paycunataka munacuywan camachin. 
\p  
\v 4 ‘May cusiskas cancu jucharaycu llaquicojcunaka. Diosmin paycunataka sonkoncupi callpachaspa yanapanka. 
\p  
\v 5 ‘May cusiskas cancu llamp'u sonkowan Diosta casojcuna. Paycunaka cay pachapi Diospa niskanmanjina jap'enkancu. 
\p  
\v 6 ‘May cusiskas cancu Diospaj cheka causayta munajcunaka. Imaynatachus yarkhachicojcuna miqhunata munancu chayrí ch'aquichicojcuna yacuta munancu ajinata. Munaskancumanjina paycuna sajsaskas cancu. 
\p  
\v 7 ‘May cusiskas cancu Diosmanjina c'acha sonkowan qhuyacojcunaka. Paycunata Dioska qhuyallankataj. 
\p  
\v 8 ‘May cusiskas cancu llimphu sonkowan Diosllapaj causajcunaka. Paycunalla Dioswan cusca wiñaypaj causaconkancu. 
\p  
\v 9 ‘May cusiskas cancu runasta allinyachejcunaka. Paycunalla Diospa cheka wawasnin cankancu, paypa niskanmanjina. 
\p  
\v 10 ‘May cusiskas cancu Diospa ñaupakenpi chekanta causaskancuraycu muchojcunaka. Dios camachishajtin, paywan cusca cankancu. 
\p  
\v 11 ‘May cusiskas canquichej runas llullacuspa sajrata rimasojtiyquichej, muchuchisojtiyquichej khasimanta c'amisojtiyquichejpis, nokata casuwaskayquichejraycu.  
\v 12 Cusicuychej may jatun cusiywan. Imaraycuchus muchuskayquichejmanta Dios janaj pachapi khapajyachisonkachej sonkoyquichejpi.\f + \fr 5:12 \ft Literal: premio.\f* Ajinallatataj Diospa unay willajcunatapis runas mayta muchucherkancu manaraj kancuna cashajtiyquichej. 
\s1 Cusicuyniyoj runaspaj yachachinas 
\p  
\v 13 [‘Runas aycha ama ismuycunanpaj cachita churancu.]\f + \fr 5:13 \ft Ninayan.\f* Ajinallatataj kancunatapis Dios churasorkachej runas sajra causayman ama tucuchiskas canancupaj. Chay cachi lak'ayapunman chayka ¿imaynatataj sumaj cachiman cutirinman? Manaña servinchu, astawanpis wijch'unallapajña purejcuna sarunancupajpis cashan. 
\p  
\v 14 ‘Kancunamin Diosta mana rejsejcunapaj c'anchayjina canquichej. Orko patapi uj llajtaka manapuni pacaskachu.  
\v 15 Nillataj runas c'anchayta jap'ichispa wich'i uraman churancuchu. Manachayrí pataman churancu wasipi tucuy tiyacojcunata c'anchamunanpaj.  
\v 16 Kancunapis ajinallataj c'anchayjina canquichej cay pacha runaspaj. Ñaupakencupi c'acha cajta ruwaspa causacuychej. Ajina cachun paycunaka janaj pachapi tiyacoj Tatayquichej Diosta jatunchanancupaj. 
\s1 Jesús yachachin Diospa camachiskasninmanta 
\p  
\v 17 ‘Ama yuyaychejchu Moisespa camachiskasninta chayrí Diospa unay willajcunanpa yachachiskasnincuta chincachinayta. Mana chaycunata chincachinaypajchu jamuni manachayrí tucuyta chaymanjina junt'anaypaj.  
\v 18 Niyquichej chekatapuni Diospa camachiskasninmantaka ni uj juch'uy niskallanpis chincananta. Atiyniyojllapuni cashan tucuy caj junt'acunancama. Chaymantaraj janaj pacha cay pachapis atinman chincapuyta.  
\v 19 Pichari Diospa camachiskasninmanta ujnillantapis mana casunmanchu chayrí mana casuyta yachachinman chayka, aswan pisipaj khawaska canka, Dios camachin, chaypi. Pichari Diospa camachiskasninta casunman, casuyta yachachinmantaj chayka, Dios camachin, chaypi jatunpaj khawaska canka.  
\v 20 Niyquichej chekatapuni fariseo partemantawan israel yachachejcunamantawan yachachiskas caskancumanjina ruwaspa chekan cayta munaskancuta. Dios camachin, chaymanka mana yaycuyta atenkancuchu. Nitaj kancunapis paycunajina caspa yaycuyta atinquichejchu. Manachayrí Diosta casuspa chekan causayniyoj caspalla Dios camachin, chaymanka yaycunquichej. 
\s1 Phiñacuymanta 
\p  
\v 21 ‘Uyarinquichej Moisés unay tatasninchejta camachiskanta: “Runata ama wañuchinquichu. Wañuchejka wañuchiskanmanta wañuchiskallataj canan tiyan”, nispa. Chayta yachanquichej.  
\v 22 Nokarí niyquichej sapa uj runa-masinpaj phiñaska cajta curajcuna ñac'arichinancuta. Sapa uj runa phiñacuspa runa-masinta “wampu” nejtapis aswan curajcuna juchachankancu. Phiñacuspa runa-masinta “supay apachun” nejpis, uqhu pachaman rinanpajjina cashan. 
\p  
\v 23 ‘Chayraycu Diosta yupaychaj konata\f + \fr 5:23 \f* jaywaspaka sumajta yuyaricuy. Runa-masiyqui kanpaj phiñaska cashaskanta yuyanqui chayka,  
\v 24 chaypi konayquita sakey. Riytaj ñaupajta runa-masiyquiwan allinyacamoj. Chaymanta cutimuspa konayquita Diosman jayway. 
\p  
\v 25 ‘Contrallisojniyqui juchachaj curajman pusashasojtenka ñanllataraj rishaspa uskhayta paywan allinyacuy. Allinyacuy amaña curajman jaywasunanpaj nitaj soldadoman jaywaspa carcelman wisk'achisunanpaj.  
\v 26 Niyqui chekamanta mana allinyacuwaj chayka, carcelmanta manapuni llojsimunquichu tucuy phatasta cutichipunayquicama. 
\s1 Ama khenchachacuychu 
\p  
\v 27 ‘Uyarinquichej Moisés unay tatasninchejta camachiskanta: “Ama khenchachacuychu”.  
\v 28 Nokarí niyquichej warmita munapayaspa khawaj, chay runaka ñapis sonkonpi paywan khenchachacuskantaña.  
\v 29 Chayraycu paña ñawiyqui ricuspa juchaman urmachisunquiman chayka, chayta orkhospa wijch'upuy. Aswan allin canman uj ñawillayqui chincaripunan amataj uqhu pacha ñac'ariyman wijch'uska canayqueka.  
\v 30 Paña maquiyqui juchaman urmachisunquiman chayka, chaytapis qhuchurpacuspa wijch'upuy. Aswan allin canman maquillayqui chincapunan amataj uqhu pacha ñac'ariyman wijch'uska canayqueka. 
\s1 T'akanacuymanta 
\p  
\v 31 ‘Nillajtaj cancu: “Warmiman uj divorcio papel jaywaspa t'akanacuyka aticullan”.  
\v 32 Nokarí niyquichej pichari warminmanta takanacun mana waj khariwan purejtenka, warminta khenchachachiskanta. Chayjina t'akanaska warmiwan casarajpis khenchachacullantaj. 
\s1 Juramentosmanta 
\p  
\v 33 ‘Uyarinquichej Moisés unay tatasninchejta camachiskantapis: “Ama juraychu llullacuspaka. Manachayrí Diospa ñaupakenpi niskayquimanjina ruway”.  
\v 34-35 Nokarí niyquichej: Ama ni imaraycu ni maypi Diospa sutinta okharispa juraychejchu. Imaraycuchus Dioska janaj pachapi cay pachapipis cashan. Nillataj Jerusalén llajtaj sutinta okharispa juraychejchu. Imaraycuchus paypa ajllaska llajtanmin cashan.  
\v 36 Amataj ni ima sutita okharispa juraychejchu. Causayniyquichejka Diospatamin. Imaraycuchus ni uj chujchatapis umayquipi atinquichu yanayachiyta nitaj yurajyachiytaka.  
\v 37 Niskayquichejka junt'anayquichejpaj cachun. Chayman waj palabraswan yapawajchej chayka, supay Satanasmantamin. 
\s1 Chejnicoj runasta munacuna 
\p  
\v 38 ‘Chaywanpis uyarinquichej Moisés unay tatasninchejta camachiskanta: “Ñawiyquita orkhosojmantaka ñawinta orkhollaytaj. Quiruyquita orkhosojmanka quirunta orkhollaytaj”.  
\v 39 Nokarí niyquichej: Ama cutichicuychejchu sajrata ruwasojniyquichejmanka. Pillapis paña lado uyayquipi sajmasunquiman chayka, sakellay llok'e lado uyayquipiwan sajmasunanta.  
\v 40 Pillapis camisayquita khechusunanpaj curajman pusasunquiman chayka, ponchoyquitawan payman kopuy.  
\v 41 Pillapis k'epinta cuscan leguatajina apanayquipaj camachisunquiman chayka, uj leguatajina apapuy.  
\v 42 Pillapis mañacusunquiman chayka, koriy payman. Manucusuyta munajmanpis manurillay. 
\p  
\v 43 ‘Chaywanpis unayka nillajtaj cancu: “Runa-masiyquita munacuy. Chejnisoj runatataj chejniy”.  
\v 44 Nokarí niyquichej munacunayquichej chejnisoj runasta. Sajrata kancunapaj parlajcunaman misq'i palabraswan parlapayariychej. Chejnisojcunaman allin cajta ruwapuychej. Misq'i parlaycunawan parlaychej sajra simiwan kancunapaj parlasojcunaman. Khasillamanta kancunata ñac'arichisojcunapaj sajrata ruwasojcunapajpis Diosmanta mañapuychej.  
\v 45 Chayjinata ruwanayquichej janaj pacha Dios Tatayquichejjina canayquichejpaj. Payka intita c'anchachimun c'acha runaspaj sajra runaspajpis. Parachimuntaj chekan ruwajpaj sajrata ruwajpajpis.  
\v 46 Sichus munacusoj runasllata munacuwajchej chayka, Dios mana nisonkachejchu “walejta ruwanquichej”. Juchasapaspis ruwashallancu ajinataka.  
\v 47 Israel llajta-masisnillayquichejta napaycuwajchej chayka, wajcunamanta niskaka ¿ima astawan allintataj ruwashanquichejrí? ¿manachu quiquillantataj ruwancu Diosta mana rejsejcunapis?  
\v 48 Imaynatachus janaj pacha Dios Tatayquichej munacuywan runaspa allinnincupaj ruwan, kancunapis ajinallatataj ruwaychej, —nerka Jesús. 
\c 6  
\s1 Allin ruwanasmanta yachachinas 
\p  
\v 1 ‘Khawaricuychej c'acha cajta ruwaskayquichejka ama runas jatunchasunallancupajka cachunchu.\f + \fr 6:1 \ft Literal: premiota.\f* Manachayka janaj pacha Dios Tatayquichej uj sumaj konata mana kosonkachejchu.  
\v 2 Chayraycu pisichicojcunaman imallatapis kospaka ama runasman willaspalla koychej. Puraj uya runaspis ajinata ruwancu tantacuna-wasispi plazaspipis runas paycunata jatunchanancupaj. Niyquichej chekatapuni paycunaka ruwaskancumanta tucuyta jap'iskancutaña.  
\v 3 Kanrí pisichicojman kospaka ama pipis koskayquitaka yachachunchu.  
\v 4 Ajinapi ruwaskayqui pacaska canka. Pacaypi ricoj Dios Tatayquitaj kanman ruwaskayquimanjina kosonka. 
\s1 Diosmanta mañacuymanta yachachinas 
\p  
\v 5 ‘Diosmanta mañacuspa ama puraj uyajina caychejchu. Paycunaka tantacuna-wasispi jatun plazaspiwan sayaricuspa Diosmanta mañacuyta munancu runas ricunallancupaj. Niyquichej chekatapuni paycunaka ruwaskancumanta tucuyta jap'iskancutaña.  
\v 6 Kanrí wasiyquiman yaycuspa sapallayqui Diosmanta mañacuy. Puncuyquita wisk'aspataj pacaypi caj Dios Tatayquimanta mañacuy. Pacaypi ricoj Tatayquitaj ruwaskayquimanjina kosonka. 
\p  
\v 7 ‘Diosta mana rejsejcunaka ashqha cutista khasi palabrasllawan Diosmanta mañacuncu. Kancunarí ama paycunajina mañacuychejchu. Paycuna ashqha parlaskancuwan uyariskas cayta yuyancu.  
\v 8 Chayraycu ama paycunajinaka caychejchu. Dios Tatayquichejka pisichicuskayquichejta yachanña manaraj paymanta mañacushajtiyquichej.  
\v 9 Chayraycu kancunaka cayjinallata mañacunayquichej tiyan: 
\q1 Janaj pachapi caj Tataycu, 
\q1 Tucuy runas sutiyquita yupaychachuncu cheka Dios caskayquiraycu. 
\q1  
\v 10 Mayta munaycu tucuyta camachinayquita. Janaj pachapi munayniyqui ruwacushan, ajinallataj cay pachapipis ruwacuchun. 
\q1  
\v 11 Causanaycupaj miqhunaycuta kowaycu cunan p'unchay. 
\q1  
\v 12 Juchasniycuta khechuspa perdonawaycu. 
\q1 Nokaycumanpis juchata ruwajcunata perdonaycu, ajinallatataj. 
\q1  
\v 13 Callpachawaycu jatun llaquiycunapi ama juchallicunaycupaj. 
\q1 Astawanpis wakaychawaycu juchallichiyta munajpa atiyninmanta. 
\q1 Kanka wiñaypaj camachinqui. 
\q1 Tucuy atiyniyoj, may curajpaj, jatunchaskapis canqui. Ajina cachun. 
\p  
\v 14 ‘Kancunaman juchata ruwasojcunata perdonaspa konkapuwajchej chayka, janaj pacha Dios Tatayquichejpis juchasniyquichejta perdonaspa khechusonkachej.  
\v 15 Kancunaman juchata ruwasuskancuta mana konkapuwajchejchu chayrí, Dios Tatayquichejpis nillataj juchasniyquichejta perdonaspa khechupusonkachejchu. 
\s1 Ama puraj uyas caychejchu 
\p  
\v 16 ‘Diosta yupaychanapaj mana miqhunqui chayka, ama puraj uyasjina phutiskaska churacuychejchu. Puraj uyaska uyasnincuta ujjinayachincu runas yachanancupaj mana miqhuskancuta. Noka niyquichej chekatapuni paycunaka jap'inancu carka, chayta jap'iskancutaña.  
\v 17 Kanrí mana miqhuspa Diosta yupaychanayquipaj umayquita ñajch'aycuy, uyayquita mayllacuy, cusiskataj cay.  
\v 18 Ajinapi runas mana miqhuskayquita mana reparankancuchu. Pacaypi caj Dios Tatayquirí yachan. Paytaj pacaypi ricuspa ruwaskayquimanjina kosonka. 
\s1 Khapaj capuyka janaj pachapi 
\p  
\v 19 ‘Cay pachapi khapaj capuycunata amaña chhicata kancunallapaj jallch'acuychejchu. Caypi chaytaka thutas thutancu, carcomi tucuchin, suwaspis yaycuspa suwancu.  
\v 20 Manachayrí tucuyta ruwaychej Diosllata cusichinayquichejpaj. Ajinapi janaj pachapi wiñay khapaj cajta jallch'acunquichej. Jakaypi thutas mana thutancuchu, nitaj carcomi tucuchinchu. Nillataj suwas yaycuspa suwancuchu.  
\v 21 Imaraycuchus maypichá munaska khapajniyquichej cashan chaypipuni yuyayniyquichejpis\f + \fr 6:21 \ft Literal: sonkoyquichejpis.\f* cashan. 
\s1 C'anchay sonkosninchejpaj 
\p  
\v 22 ‘Ñawiyqui c'anchayllawan ricun cuerpopaj. Ajinallatataj sonkoyquipis Diospa c'anchayninwan reparan. Sichus llimphu sonkoyoj canqui chayka, tucuy causayniyqui c'anchayniyojmin.  
\v 23 Sajra sonkoyoj\f + \fr 6:23 \ft Literal: ñawi.\f* canqui, chayrí tucuy causayniyqui lakhapachamin. Chayjina lakhamanta astawanka mana canchu. 
\s1 Ajllaychej Diosta chayrí kolketa 
\p  
\v 24 ‘Ni pi iscay camachejcunata casuyta atinchu. Imaraycuchus ujllata munaconka wajtataj chejniconka. Ujman c'ascaconka wajtataj khesachanka. Cheka Diostawan khapaj capuytawan manapuni casuyta atinquichu. 
\s1 Dios wawasninta wakaychan 
\p  
\v 25 ‘Chayraycu niyquichej amaña anchata llaquicuychejchu miqhunamanta nitaj ujyanamanta causanayquichejpajka. Nitaj llaquicuychejchu cuerpoyquichejmanta imawanchus p'achallicunayquichejtaka. Causayniyquichejka ¿manachu miqhunamantapis astawan sumajmin? Chayrí cuerponchejpis ¿manachu p'achamantapis astawan sumajmin?  
\v 26 Sumajta reparaychej phawaj p'iskosmanta. Paycunaka mana tarpuncuchu nitaj ruthuncuchu. Nitaj pirwasniyojchu cancu miqhunancuta tantanancupaj. Janaj pacha Dios Tatayquichejmin paycunata miqhuchin. Kancunaka p'iskosmanta niskaka ¿manachu Diospajka astawan sumaj canquichej?  
\v 27 Astawan causayta munaspa, llaquicuspapis ¿uj chhicatawan causayta atiwajchejchu? 
\p  
\v 28 ‘¿Imaraycutaj p'achamantapis phuticunquichejrí? Sumajta reparaychej q'ita t'icasmanta, imaynatachus wiñancu. T'icaska mana llanc'ancuchu nitaj phushcancupischu.  
\v 29 Nokarí niyquichej Salomonka may khapaj camachej caskanta. Chaywanpis payka ni cay chhica c'achitu t'icasjinallapis p'achallicorkachu.  
\v 30 Cunan p'unchay koraka pampapi khallallashan. K'ayataj runas hornopi ruphachenkancu. Chaywanpis Dios churan chay korata. Payka kancunamanta may astawanraj yuyan. Chayraycu ¿manachu pay kosonkachej causanayquichejpaj? ¡Paypi jap'icuskayquichejka ancha pisi!  
\v 31 Chayraycu llaquicuspa ama niychejchu: “¿Imatataj miqhusun? ¿Imatataj ujyasun? ¿Imawantaj p'achallicusun?”  
\v 32 Tucuy chaycunallata Diosta mana rejsejcunaka mayta munashancu. Janaj pacha Dios Tatayquichej yachanña tucuy cay imasmanta causanayquichejpaj pisichicuskayquichejtaka.  
\v 33 Kancunarí tucuy atiskayquichejwan llanc'aychej ñaupajta Dios tucuyta camachinanpaj. Ajinallataj Diospa munayninmanjina chekanta causaychej. Chanta payka cay pachapi causanayquichejpaj tucuy imata yapasonkachej.  
\v 34 Chayraycu k'ayamanta yuyaspa ama llaquicuychejchu. K'aya phuticuycunaka k'ayallapaj cachun. 
\c 7  
\s1 Ama juchachaychejchu waj runasta 
\p  
\v 1 ‘Ama waj runata juchachaychejchu mana allinta yachaspaka. Ajinapi kancuna manallataj juchachaskaschu canquichej manacajmantaka.  
\v 2 ‘Imaynatachus runa-masisniyquichejta khawanquichej chayjinallatataj Dios kancunata khawasonkachej. Ima chhicantachus wajcunaman konquichej chay chhicamanjinallataj Dios kancunaman kosonkachej. 
\p  
\v 3 ‘Uj jatun curcujina kanpa jatun pantaskayquita mana reparacuspaka ¿imaynatataj uj ichhu k'opajina hermanoyquej juch'uy pantaskanta khawaranquirí?  
\v 4 Quiquin ñawiyquipitaj jatun curcu cashajtin ¿imaynatataj hermanoyquita atinqui niytarí: “Hermanóy, sakellaway ichhu k'opata ñawiyquimanta orkhosunayta?” nispa.  
\v 5 Puraj uya, chay curcutaraj ñawiyquimanta orkhonqui. Chanta aswan sut'ita ricunqui juch'uy k'opata hermanoyquejpa ñawinmanta orkhonayquipajka. 
\p  
\v 6 ‘Dios kosuskayquichejtaka ama koychejchu phiña sajra alkosjina runasmanka, janch'ojtincu kancunata ama qhanispa tucuchisunancupaj. Nitaj millay qhuchijina causaj runasmanka Dios kosuskayquichejtapis\f + \fr 7:6 \ft Literal: perlas.\f* wijch'uychejchu ama saruycunancupaj mana cajtajina. 
\s1 Diosmanta mañacushaychejpuni 
\p  
\v 7 ‘Diosmanta mañacullaychejpuni, payka kosonkachejtaj. Masc'aychejpuni, Dioska tarichisonkachejtaj. Wajyallaychejpuni\f + \fr 7:7 \ft Literal: tocaychejpuni.\f* Diostaj puncuta kancunaman quicharisonkachej.  
\v 8 Chekamanta mana sakespa mañacojka jap'enkapuni masc'ajtaj tarenkapuni. Mana sakespa wajyajmanpis puncoka quichariconkapuni. 
\p  
\v 9 ‘Astawanpis, wawan t'antata mañacojtin ¿pitaj, kancuna tatasmanta, uj rumita jaywanman?  
\v 10 Chayrí wawan challwata mañacojtin ¿uj cataritachu jaywanman?  
\v 11 Kancuna juchasapa runaslla cashaspapis wawasniyquichejmanka allin imastapuni koyta yachanquichej. May astawanraj janaj pacha Dios Tatayquichejka sumaj imasta konka paymanta mañacojmanka. 
\p  
\v 12 ‘Chayraycu imaynatachá munanquichej runas kancunaman ruwanancuta ajinallatataj kancunapis paycunaman ruwaychej. Palabranpi\f + \fr 7:12 \ft Literal: camachiskas unay willajcunapiwan.\f* Dioska chayta ruwananchejta camachin. 
\s1 Wiñay causayta ajllaychej 
\p  
\v 13-14 ‘Wiñay causayman chayrí wiñay wañuyman kancuna yaycuyta ajllanayquichej tiyan. Imaraycuchus wiñay wañuyman puncoka jatunmin, chayman chayaj ñanpis. Ashqhastaj chaynejta yaycuncu. Wiñay causayman yaycuchej puncurí c'ullcumin, chayman chayanapaj ñanpis c'ullcullataj. Pisistaj Diospa munayninta ruwaspa wiñay causayman yaycuncu. Chayraycu c'ullcu puncunejta yaycuychej. 
\s1 Sach'aka pokoyninpi rejsicun 
\p  
\v 15 ‘Khawacuychej llulla yachachejcunamanta. Chaycunaka pantachisunayquichejpaj jamuncu. Paycunaka ovejaman rijch'acojjinalla cancu, sonkosnincupirí yarkhaska atojcunajina cancu.  
\v 16 Sach'astaka pokoynincumanta rejsinquichej. Ajinallatataj paycunataka ruwaskancumanta atinquichej rejsiyta. Ni jayc'aj uvaska qhishcarara sach'itamanta pallacunchu. Nitaj higoska pallacunchu qhishca sach'asmantapis.  
\v 17 Ajinata tucuy allin sach'aka sumaj pokoyta pokon. Uj mana allin sach'arí mana sumaj pokoyniyojllataj.  
\v 18 Allin sach'aka mana jayataka pokonchu. Nitaj mana allin sach'apis allin misq'itaka pokonchu.  
\v 19 Tucuy mana allinta pokoj sach'ataka runas c'utuncu ninamantaj wijch'uncu.  
\v 20 Chayraycu kancunapis runastaka ruwaskasnincumanta\f + \fr 7:20 \ft Literal: pokoyninmanta.\f* rejsinquichej. 
\s1 Mana tucuychu Diospa wawasnin 
\p  
\v 21 ‘Simillancuwan “Ay, Señorníy, Tatáy”, nejcuna Dios camachin, chayman mana yayconkancuchu. Manachayka janaj pachapi tiyacoj Dios Tataypa munayninta ruwajcunalla paypaman yayconkancu.  
\v 22 Cutimojtiy, chay p'unchay ashqhas niwankancu: “Ay, Señorníy, Tatáy ¿manachu willanasniyquita willararkaycu? ¿Manachu atiyniyquiwan runasmanta supaycunata kharkorkaycu? ¿Manachu ashqha t'ucuna ruwanastapis atiyniyquiwan ruwarkaycu?” nispa.  
\v 23 Chantarí nokataj tucuypa ñaupakencupi paycunaman sut'inchasaj: “Kancunataka ni jayc'aj rejserkayquichejchu. Mana nokajpatachu canquichej. Kancuna, sajrata ruwajcuna ripuychej nokamanta”, nispa. 
\s1 Yuyayniyojcunamanta mana yuyayniyojcunamantawan 
\p  
\v 24 ‘Chayraycu cay niskasniyta uyarispa sumajta casojlla, nokapajka sumaj yuyayniyoj runajina cashan. Payka sinch'i rumi patapi wasichaj runajina cashan.  
\v 25 Paraka sinch'ita jich'acamorka. Mayustaj ashqha yacuwan chayamorkancu. Wayrapis jatun callpawan wayraspa chay wasiman komorka. Wasiri mana urmarkachu sinch'i rumipi wasichaska caskanraycu.  
\v 26 Cay niskasniyta uyarispa tucuy mana casojrí nokapajka mana yuyayniyoj runajina cashan. T'iyupi wasinta wasichaj runajina cashan.  
\v 27 Sinch'ita paraka jich'acamorka. Mayustaj ashqha yacuwan chayamorkancu. Wayrapis may callpawan chay wasiman komorka. Wasitaj manchayta urmarka. 
\p  
\v 28 Jesús cay imasmanta parlayta tucorka. Ashqha runastaj paypa yachachiskanmanta mayta t'ucorkancu.  
\v 29 Imaraycuchus pay Diospa atiyninwan yachachisharka, manataj paycunaj yachachejnincujinallachu. 
\c 8  
\s1 Lepra onkoyniyoj runata Jesús thañichin 
\p  
\v 1 Jesús orkomanta uraycamushajtin ashqha runas paypa khepanta jamusharkancu.  
\v 2 Ajinapitaj uj manchay chimpa chimpa lepra onkoyniyoj runa Jesusman kayllaycorka. Konkoricuspataj payta yupaychananpaj, mañacorka: 
\p —Tucuy atiyniyoj canqui, Señor. Munanqui chayka, llimphuchawaspa atinqui thañichiwayta, —nispa. 
\p  
\v 3 Jesustaj maquinwan payta llanqhaycuspa nerka: 
\p —Munani. Thañiskaña canqui, —nispa. 
\p Chay quiquinpachataj thañiska carka lepra onkoyninmanta.  
\v 4 Jesustaj payta camacherka: 
\p —Uyariway. Ama pimanpis cay imasmanta willanquichu. Manachayrí chekanta riy khawachicamuytaj yupaychana-wasipi ruwanayojwan. Moisespa camachiskanmanjina konatataj jaywamuy. Chay jaywaskayquiwan runas yachankancu thañiska caskayquita. 
\s1 Jesús capitanpa wawanta thañichin 
\p  
\v 5 Jesús Capernaum llajtaman yaycushajtin uj camachej payman jamorka. Payka pachaj romano soldadosta camacherka. Chay camachej Jesusmanta tucuy sonkowan mañacuspa  
\v 6 nerkataj: 
\p —Señor, uywaskay wasiypi suchu onkoywan siriska cashan. Mayta ñac'arishan, —nispa. 
\p  
\v 7 Jesustaj payman nerka: 
\p —Wasiyquiman noka jampej jamusaj, —nispa. 
\p  
\v 8 Cutichispa chay camachej nerka: 
\p —Señor, arí, noka mana wasiyman yaycunayquipajjinachu cani. Astawanka cayllamanta niy, uywaskaytaj thañicaponka.  
\v 9 Nokajtapis cancu curaj camachiwajcuna. Chaywanpis nokajta callancutaj soldadosniy. Paycuna casuwancutaj camachiskayta. Ujta nini: “Riy”. Rintaj. Wajta nini: “Jamuy”. Jamuntaj. Uywaskayta nini: “Cayta ruway”. Ruwallantaj. 
\p  
\v 10 Jesuska ajinata nejta uyarispa t'ucorka. Payta khatejcunata nerkataj: 
\p —Chekatapuni Diospa runasnin uqhupipis nipuni chayjina niskasniyta jap'icoj runataka tarerkanichu.  
\v 11 Astawanpis niyquichej ashqha runas tucuy cay pachamanta jamunancuta. Paycunaka Dios camachin, chaypi cusiywan miqhonkancu cusca jatun tatasninchej —Abrahamwan, Isaacwan Jacobwanpis.  
\v 12 Waquincunarí pantaspa yuyancu Dios camachin, chayman yaycuyta. Paycunaka chaymanta jawapi lakhaman wijch'uskas cankancu. Jakaypitaj khaparispa phutiywan wakankancu. Nanaywan quirusnincuta c'aruconkancu, —nispa. 
\p  
\v 13 Chanta Jesús camachejman nerka: 
\p —Ripullay wasiyquiman. Diospi jap'icuskayquimanjina ruwaska cachun. 
\p Camachejpa runaj uywaskantaj chay niskantawanpacha thañicaporka. 
\s1 Jesús Pedroj suegranta thañichin 
\p  
\v 14 Khepanta Jesús Pedroj wasinman rispa Pedroj warminpa mamanta ricorka. Pay sinch'i k'oñi onkoywan camapi siricusharka.  
\v 15 Jesustaj onkoskaj maquinta llanqharispa k'oñi onkoyninmanta thañicherka. Thañiska warmitaj jataricuspa miqhunata payman jaywarka. 
\s1 Jesús ashqha onkoskasta thañichin 
\p  
\v 16 Ch'isiyaycuytari ashqha supayniyojcunata Jesusman runas pusamorkancu. Paytaj ujta parlaskallanwan chay supaycunata kharkorka. Tucuy onkoskastataj thañicherka.  
\v 17 Ajinapi junt'acorka Diospa willajnin Isaiaspa niskan Jesusmanta: “Payka khechupuwarkanchej onkoyninchejcunata nanayninchejcunatapis”. 
\s1 Jesusta khatejcuna 
\p  
\v 18 Jesustaj ashqha runasta muyuyninpi ricorka. Chayraycu camacherka yachacojcunanta kocha chimpaman rinancuta.  
\v 19 Israel yachachejcunamantataj uj yachaysapa Jesusman kayllaycuspa nerka: 
\p —Yachachiwajníy, kanwan cusca risaj maymanchá rinqui, chayman. 
\p  
\v 20 Jesusri payman cuticherka: 
\p —Atojcuna jusc'usniyoj cancu. Phawashaj p'iskospis thapasniyoj cancu. Noka, Diospa cachamuska Runanpajrí mana canchu umayta samarichinallaypajpis, —nispa. 
\p  
\v 21 Yachachiskasninmanta ujnin caj nillarkataj: 
\p —Señorníy, sakellawayraj tatayta p'ampamunayta, —nispa. 
\p  
\v 22 Jesusrí cuticherka: 
\p —Kanka nokallawanpuni puriy yachacojniy canayquipaj. Wañuskacuna wañuskasnincutaka p'ampamuchuncu. 
\s1 Jesús ch'inyachin wayrata yacutapis 
\p  
\v 23 Chaymanta Jesuska barcoman yaycorka, kocha chimpaman rinancupaj. Yachacojcunan paywan risharkancu.  
\v 24 Ujllata jatun kochapi manchay sinch'i wayrawan yacoka mayta okharicorka. Yacoka callpawan khallacamuspa barcota chincaycuchinayasharkaña. Jesusrí puñucushallarkapuni.  
\v 25 Yachacojcunantaj payman kayllaycamuspa rijch'aricherkancu. Mancharicuspataj, nerkancu: 
\p —¡Señorníy, yanapawaycu! ¡Chincaycunayashanchejña! —nispa. 
\p  
\v 26 Jesustaj paycunaman c'amerka: 
\p —¿Imaraycutaj manchariskas chujchushanquichejrí? ¡Ancha pisita Diospi jap'icunquichej! —nispa. 
\p Chanta payka jataricuspa wayrata kochatawan c'amerka. Chay quiquinpacha wayrapis yacupis payta casuspa c'achata thañicaporkancu.  
\v 27 Paywan rejcunataj maytapuni t'ucuspa ninacusharkancu: 
\p —¿Ima runataj payrí? ¡Wayrapis kochapis payta casuncu! 
\s1 Gadara llajtamanta supayniyojcuna 
\p  
\v 28 Jesuska rispataj kocha chimpaman chayarka. Chayri Gadarenospa jallp'ancu carka. Ajinapitaj iscay supayniyoj runas aya p'ampanasmanta llojsimorkancu. Jesustataj taripaycorkancu. Paycunaka manchay phiñas caskancuraycu ni pipis chay ñannejta purejchu.  
\v 29 Chay supayniyoj runastaj khaparispa nerkancu: 
\p —¡C'ata Diospa Wawan, Jesús, imaman chapucuwanqui! ¿Manaraj ñac'arinaycu cashajtinñachu ñac'arichej jamuwaycu? 
\p  
\v 30 Paycunamanta carunejpitaj ashqha qhuchis miqhusharkancu.  
\v 31 Supaycunataj Jesusta mayta niricusharkancu: 
\p —Cay runasmanta kharkowasajcu chayka, jakay qhuchisman cachawaycu, —nispa. 
\p  
\v 32 Jesustaj paycunata nerka: 
\p —Riychej. 
\p Chanta supaycunaka chay iscay runasmanta llojsispa qhuchisman yaycorkancu. Ajinamanta qhuchis tucuynincu kakamanta kochaman ch'ulticuspa yacupi wañorkancu. 
\p  
\v 33 Qhuchi michejcunari aykecorkancu manchariskas. Llajtaman chayaspataj tucuy imata chay supayniyoj runasmantapis willamorkancu.  
\v 34 Llajtantinmantataj runas Jesuswan tincoj llojsimorkancu. Payta ricuspataj mayta mañacorkancu jallp'ancumanta ripunanta. 
\c 9  
\s1 Jesús uj mana cuyurej runata thañichin 
\p  
\v 1 Jesuska barcoman yaycuspa ujnin kocha chimpaman rerka. Chaymantataj llajtanman chayarka.  
\v 2 Ajinallaman uj mana cuyurej suchu runata siriskata callapunpi payman wantumusharkancu. Jesustaj reparaspa Diospi chekata jap'icuskancuta chay runata nerka: 
\p —Wawáy, ama manchachicuychu. Juchasniyqui khechuskasña cancu, —nispa. 
\p  
\v 3 Waquin yachaysapacuna sonkoncupi nisharkancu: “Cay runaka Dios caskanmanjina parlaspa payta phiñachishan”, nispa.  
\v 4 Jesustaj yuyaskancuta yachaspa nerka: 
\p —¿Imaraycutaj chayjina sajrata sonkoyquichejpi yuyashanquichejrí?  
\v 5 Cay runaman nejtiy “juchasniyqui khechuskaña” nispaka, mana ricunquichejchu chekachus manachus caskantaka. Astawanrí cay mana cuyurej runata jatarichiyman chayka, ricuwajchej.  
\v 6 Noka, Diospa cachaska Runan caspa, cay pachapi atiyniyoj cani juchasta khechunaypaj. Chayta yachanayquichejpaj cay mana cuyurej runata nini: Jataricuy. Callapuyquita okharicapuspa ripuy wasiyquiman. 
\p  
\v 7 Runataj jataricuspa wasinman riporka.  
\v 8 Ashqha runasri chayta ricuspa manchachicorkancu. Diosta yupaycharkancutaj chayjina atiyta runasman koskanmanta. 
\s1 Jesús Mateota wajyan 
\p  
\v 9 Jesuska chaymanta ripuspa Mateo sutiyoj runata ricorka. Mateori vendejcunamanta cobrana wasipi tiyacusharka. Jesustaj payta nerka: 
\p —Yachacojníy cay, —nispa. 
\p Jatarispataj Jesusta khaticorka. 
\p  
\v 10 Ajinaka Jesús yachacojcunanwan Mateoj wasinpi miqhusharka. Chay wasimantaj ashqha impuesto jap'ejcuna, juchasapaspaj khawaska runaswan jamorkancu paycunawan miqhoj.  
\v 11 Chayta ricuspataj fariseo partemanta runas Jesuspa yachacojcunanta taporkancu: 
\p —¿Imaraycutaj yachachisojniyquichejka impuesto jap'ejcunawan juchasapaswan cusca miqhunrí? 
\p  
\v 12 Jesusrí chayta uyarispa nerka: 
\p —Onkoska runaslla medicotaka munancu manataj sano runaska.  
\v 13 Kancunari sumajta yachamuychej Dios cayta niskanta: “Runas qhuyanacunancoka astawan cusichiwan uywa wañuska jaywanasmanta niskaka”. Juchasapasta wajyaj jamorkani paycuna sajra ruwaskasnincuta sakespa Diosman cutirinancupaj. Manataj jamorkanichu chekan cajcunata wajyaj, —nispa. 
\s1 Tapunas ayunomanta 
\p  
\v 14 Chanta Juanpa yachacojcunan Jesusman chimpaycorkancu. Taporkancutaj: 
\p —Nokaycu, fariseocunawan ayunaycu ajllaska p'unchaycunapi yachacuskaycumanjina. Kanpa yachacojcunayquirí ¿imaraycutaj mana ayunancuchu paycunajinata? 
\p  
\v 15 Jesusrí paycunaman cuticherka: 
\p —¿Casamientoman wajyaskacunaka phutiska uyasllachu cancuman casaracoj runa paycunawan cashajtin? Waj p'unchaycuna jamojtincurí paycunamanta casaracoj runa khechuska canka. Chaypacha yachacojcunay phutiywan mana miqhonkancuchu, —nispa. 
\p  
\v 16 Cay quiquinchanawan mosoj yachachiyninmanta parlarka: 
\p —Ni pipis uj mosoj remiendota uj mauc'a p'achaman siraycunmanchu. Chayta ruwanman chayka, mosoj p'achamanta remiendoka k'entispa aswan jatunta lliq'irparinman mauc'a p'achataka.  
\v 17 Manallataj pipis mosoj pokoshaj vinota mauc'a karasman churanchu. Chayta ruwanman chayka, pokoshaj vinoka phatarparichinman mauc'a karastaka. Ajinapitaj karas lliq'iycucunman vinotaj jich'acuspa chincapunman. Chayraycu mosoj vinotaka mosoj karasman churana tiyan. Ajinamanta iscaynincu allin wakaychaskas cancu, —nispa yachacherka Jesús. 
\s1 Jesús thañichin Jairoj wawanta 
\p  
\v 18 Jesús cay imasmanta parlashajtillanraj uj curaj runa payman kayllaycorka. Jesusta yupaychaspataj nerka: 
\p —Tatáy, warmi waway cunallan wañupun. Astawanpis payman maquiyquita churanayquipaj jamuy. Wawayka chaywan causarenka, —nispa. 
\p  
\v 19 Ajinataj Jesuska rerka curaj runawan cusca. Yachacojcunanpis Jesuswan rerkancu. 
\p  
\v 20 Rishajtincutaj uj warmi Jesusman kayllaycorka. Payka chunca iscayniyoj watastaña yawar apay onkoywan carka. Khepanmanta jamuspataj Jesuspa ponchonpa t'icasninta jap'irerka.  
\v 21 Ajinata ruwarka sonkonpi niskanraycu: “P'achallantapis llanqharisaj chayka, thañicapusaj”.  
\v 22 Jesusrí cutiricuspa warmita khawarerka. Nerkataj: 
\p —Cusicuy, mamáy. Diospi jap'icuskayquiraycu thañiska canqui. 
\p Warmeka chaypachita sumajta thañicaporka. 
\p  
\v 23 Jesustaj curaj runaj wasinman chayamuspa p'ampanapaj tocajcunata ricorka. Ashqha ch'ajwashaj runastapis ricuspataj  
\v 24 nerka: 
\p —Ithiricuychej. Imillitaka mana wañuporkachu. Manachayrí puñushallan, —nispa. 
\p Runastaj Jesusta asipayarkancu.  
\v 25 Jesuska paycunata jawaman llojsichispa wasiman yaycorka. Imillitatataj maquinmanta jap'ispa causaricherka.  
\v 26 Chay ruwaskanmantari tucuynejpi runas yacharkancu. 
\s1 Jesús thañichin iscay ciegosta 
\p  
\v 27 Jesús chaymanta ripushajtintaj iscay ciego runas paypa khepanta khaterkancu. Khaparispa nerkancu: 
\p —Diospa ajllaskan Cristo,\f + \fr 9:27 \ft Literal: Davidpa Wawan.\f* qhuyacuwaycu. 
\p  
\v 28 Jesuska wasiman yaycorka. Chaymantataj ciego runaska payman kayllaycorkancu. Jesusri paycunata tapurerka: 
\p —¿Tucuy sonkowanchu creenquichej kancunata thañichiyta atinayta? 
\p Paycunataj cuticherkancu: 
\p —Arí, tucuy atiyniyoj Señor, —nispa. 
\p  
\v 29 Chanta Jesuska ñawisnincuta llanqhaycuspa nerka: 
\p —Diospi jap'icuskayquichejmanjina ricuychej. 
\p  
\v 30 Ciegostaj ricorkancu. Chaymanta Jesús sinch'ita paycunata nerka: 
\p —Ama ni pimanpis willaychejchu, —nispa. 
\p  
\v 31 Paycunarí Jesuspa niskanta mana casorkancuchu. Astawanpis tucuy chay jallp'anejpi Jesusmanta willarkancu. 
\s1 Jesús thañichin uj upa runata 
\p  
\v 32 Paycuna llojsishajtincutaj runas Jesusman supayniyoj uj upa runata pusamorkancu.  
\v 33 Jesusri supayta kharkorka. Chay quiquinpachataj upaka parlarerka. Chaypi caj ashqha runastaj t'ucusharkancu: 
\p —¡Ni jayc'ajpis cayjina imaska Israel jallp'api ricucorkachu! —nispa. 
\p  
\v 34 T'akacoj fariseocunarí nerkancu: 
\p —Chay runaka supaycunaj curajnincoj atiyninwan supaycunata kharkon, —nispa. 
\s1 Jesús munacuywan runasta qhuyan 
\p  
\v 35 Jesuska tucuy llajtasta ranchostawan purerka. Tantacuna-wasisnincupitaj yachachisharka. Willarasharka sumaj willanastapis Diospa ajllaskan cay pachapi caskanta camachinanpaj. Tucuy laya onkoyniyojcunatapis nanayniyojcunatapis thañicherka.  
\v 36 Chanta ashqha runasta ricuspa paycunata may munacuywan qhuyacorka. Jesuspa sonkon nanarka paycunata llaquiywan sayc'uskasta llauchhuyaskastataj ricuspa. Imaraycuchus paycunaka mana michejniyoj ovejasjina carkancu.  
\v 37 Chantataj yachacojcunanman nerka: 
\p —Cheka Diosmanta chincapushaj runaska uj jatun trigo chajrajina cancu. Ashqha trigo cashan ruthunapajjina pokoskaña. Ruthojcunarí pisislla cancu.  
\v 38 Chayraycu tucuy atiyniyoj Diosmanta mañacuychej llanc'ajcunata uskhayta chajranman cachamunanta. Caytaka paymin camachin. 
\c 10  
\s1 Jesús cachasninta ajllan 
\p  
\v 1 Jesustaj chunca iscayniyoj yachacojcunanta payman wajyarka. Chantataj paycunaman atiyta korka. Paycunaka chay atiywan supaycunata kharkonancu carka. Tucuy laya onkoyniyojcunatataj tucuy mana allin caytawanpis thañichinancu carka. 
\p  
\v 2 Jesuspa chunca iscayniyoj cachasnincoj sutisnincoka caycuna cancu: Ñaupaj cajka Simonmin, paytari Pedrota Jesús suticharka, wauken Andreswan, Jacobowan wauken Juanwan. Paycuna iscaynin Zebedeoj wawasnin cancu.  
\v 3 Felipe, Bartolomewan; Tomás, impuesto jap'ej Mateowan; Jacobo, Alfeoj wawan Tadeowan. Payka Lebeo niskapis.  
\v 4 Simón cananista partemanta, Judás Iscariotewan. Payka khepata Jesusta churanacojcunanman jaywaycorka. 
\s1 Jesús ajllaskasninta willarajta cachan 
\p  
\v 5 Chay chunca iscayniyoj ajllaskasninta Jesús cacharka, cayjinata camachispa: 
\p —Ama Samaria llajtasman yaycuychejchu nitaj waj runasmanpis riychejchu.  
\v 6 Manachayrí llajta-masisninchejllaman riychej. Paycunaka Diospa ajllaskan israelcuna ayllumanta chincaska ovejasjina cancu.  
\v 7 Rispataj willaraychej: Cunanka Dios caypiña cashan camachinanpaj.  
\v 8 Onkoskasta thañichiychej. Manchay lepra onkoyniyojcunata llimphuchaspa thañichimuychej. Wañuskacunata causarichimuychej. Runasmanta supaycunata kharkoychej. Tucuy chayta ruwanayquichejpaj atiyta khasillamanta korkayquichej. Chayraycu kancunapis runaspaj chay atiywan khasillamanta ruwamuychej. 
\p  
\v 9 ‘Ñanniyquichejpaj kolketa ama waquichicuychejchu.  
\v 10 Puriyniyquichejpaj ama k'epichacuychejchu imatapis. Nitaj iscay camisasta nitaj ojot'asta nillataj c'aspita purinayquichejpaj apaychejchu. Imaraycuchus llanc'ajcunaman causanancupajka konancupuni tiyan. 
\p  
\v 11 ‘Mayken llajtaman ranchomanpis yaycuspaka tapucuychej maykenchus chaypi c'acha runa caskanta. Ajinapi yachanquichej piwanchus samarinayquichejta. Paypa wasinpitaj caricuychej waj llajtaman rinayquichejcama.  
\v 12 Wasinman yaycuspataj chaypi tiyacojcunata napaycuychej: “Dioswan allinyaska cacuychej”, nispa.  
\v 13 Chaypi tiyacojcuna napaycuskayquichejta jap'icuncuman chayka, Dioswan allinyaskas cankancu. Mana jap'icuncumanchu chayrí, kancunaman cutimpusonkachej. 
\p  
\v 14 ‘Pillapis mana wajyarisunquichejmanchu nitaj niskasniyquichejta uyarinmanchu chayka, paycunata sakerparipuychej. Chaymanta llojsipuspa chaquisniyquichejmanta jallp'ancutapis thalarpariychej. Chaywan runas yachankancu Diosmanta willanasta khesachaskancuta.  
\v 15 Chekata niyquichej: Chay llajtapi tiyacojcunata Dioska astawan ñac'arichenka c'ajaj phiñacuyninwan. Sodoma llajtayojcuna Gomorra llajtayojcunatawanka pisitaraj ñac'arichenka paycunamanta niskaka. 
\s1 Llaquichiycunamanta 
\p  
\v 16 ‘Reparaychej noka cachashayquichej mana michejniyoj ovejastajina sajra atojcunaj chaupincuman. Chayraycu kancunaka sumaj yuyayniyoj llamp'u sonkoyojtaj canayquichej tiyan.  
\v 17 Khawacuychejpuni sajra runasmanta. Imaraycuchus curajcunaman jaywaycusonkachej. Tantacuna-wasisnincupitaj c'aspiswan wajtasonkachej.  
\v 18 Yachacojcunay caskayquichejraycu curajcunaman jatun camachejcunamanpis pusasonkachej. Ajinapi israelcunaman Diosta mana rejsejcunamanpis nokamanta willaranquichej.  
\v 19 Curajcunaman jaywasojtiyquichejka imatachus chayrí imaynatachus ninayquichejmanta yuyaspa ama manchachicuychejchu. Dios chay quiquinpacha sonkoyquichejman churanka imatachus ninayquichejta.  
\v 20 Imaraycuchus mana sapallayquichejchu parlanquichej. Manachayrí Santo Espíritu Tatayquichejmanta kancunanejta parlanka. 
\p  
\v 21 ‘Uj waukeka waukenta jaywayconka wañuchiska cananpaj. Uj tatapis wawanta wañuchiska cananpaj jaywayconka. Wawaspis tatasnincoj contrancupi jataricullankancutaj wañuchichinancupaj.  
\v 22 Nokamanta willaraskayquichejraycu tucuy runas kancunata chejnicusonkachejpuni. Tucucunancama nokapi confiaspallapuni muchojrí wiñay causayniyoj canka.  
\v 23 Uj llajtapi nac'arichisojtiyquichejka waj llajtaman aykecuychej. Noka, Diospa cachaska Runan, niyquichej chekatapuni manaraj tucuy Israel llajtasta rishajtiyquichej cutimunayta. 
\p  
\v 24 ‘Yachacojka mana curajchu yachachejninmantaka. Camachipis mana curajchu camachejmantaka.  
\v 25 Yachacojka yachachejninjinallataj caytawan cusicunanka allinmin. Camachipis camachejninjinallataj cananka allinmin. Noka wasiyojta sutichawarkancu “curaj supay”,\f + \fr 10:25 \ft Literal: Beelzebú.\f* nispa chayka, kancuna wasiypi tiyacojcunallataka aswan sinch'itaraj ñac'arichisonkachej. 
\s1 Runastaka ama manchachicuychejchu 
\p  
\v 26 ‘Runataka ama manchachicuychejchu. Arí, tucuy sumaj khataska cajpis k'ala khataraska canka. Tucuy pacaska cajpis sut'inchaska callankataj.  
\v 27 Lakhapi parlasuskayquichejtaka sut'ita tucuypa ñaupakenpi willaychej. Ningrillayquichejpi willasuskayquichejtapis ashqha runasman khaparispa\f + \fr 10:27 \ft Literal: wasi patamanta.\f* willaraychej.  
\v 28 Cuerpollata wañuchejcunataka ama manchachicuychejchu. Paycunaka wiñay causayta khechusuyta mana atincuchu. Astawanrí Diosta manchachicuychej. Paylla causayta khechuspa uqhu pacha ninaman wijch'uycuchiyta atin. 
\p  
\v 29 ‘¿Manachu runas iscay phichitanca p'isketosta miqhunancupaj vendencu uj phatallapi? Chaywanpis ni ujllapis wañunchu Dios Tatayquichej mana munajtenka.  
\v 30 Umayquichejpi chujchaspis ujmanta uj yupaskas cancu.  
\v 31 Dios Tatayquichej khawashasuskayquichejraycu ama manchachicuychejchu. Kancuna ashqha phichitancasmanta niskapis astawan yuyanarajmin canquichej Diospajka. 
\s1 Jesús curaj camachej caskanta willajcuna 
\p  
\v 32 ‘Pichari runaspa ñaupakencupi sut'ita willan noka paypa camachejnin caskayta chayka, nokapis janaj pacha Dios Tatayman willallasajtaj payka nokaj camachiymin caskanta.  
\v 33 Pichari runasman nokamanta willanman mana camachejninchu caskayta chayka, paymanta nokapis janaj pacha Dios Tatayman willallasajtaj mana camachiychu caskanta. 
\s1 Runas t'akanacuncu Jesusraycu 
\p  
\v 34 ‘Ama yuyaychejchu runas juchallapipuni\f + \fr 10:34 \ft Ninayan.\f* allillanta causacunancupaj jamuskaytaka. Manachayrí juchaj contranpi jamuskayraycu runaska paycunapura sinch'ita t'akanaconkancu.  
\v 35 Nokata casuwaskancuraycu khari wawaka tatanwan t'akanacun. Warmi wawa mamanpa contranpi, khachunapis suegranwan t'akanacun.  
\v 36 Wasinpi tiyacojcunallataj paytaka nokaraycu sinch'ita chejniconkancu. 
\p  
\v 37 ‘Pillapis tatanta chayrí mamanta nokamanta astawan munacojka mana yachacojniy cananpajjinachu cashan. Runa nokata astawan munacunawan tiyan warmi wawanmanta chayrí khari wawanmanta niskaka. Manachayka mana yachacojniy cananpajjinachu cashan.  
\v 38 Runaka munayninta sakespa nokata casunawanpuni tiyan nokaraycu wañunancamapis. Mana casuwanpuni chayrí mana yachacojniy cananpajjinachu cashan.  
\v 39 Causayninta payllapaj wakaychacuyta munajka mana wiñay causayniyojchu canka. Nokata casuwaskanraycu causayninta chincananta sakejka wiñay causayniyoj canka. 
\s1 Jesuspa cachasninta allinta khawapuychej 
\p  
\v 40 ‘Pillapis kancunata wajyacun yachacojcunay caskayquichejraycu, nokatapis wajyacuwan. Pillapis nokata wajyacuwan, camachiwajniy Dios Tataytapis wajyacullantaj.  
\v 41 Diospa willajninta c'achata wajyarejka willaj caskanraycu, willajpa jap'inantajinallataj Diosmanta jap'enka. Chekan ruwaj runata wajyarejka, chekan ruwaj caskanraycu chay ruwajpa jap'inantajinallataj Diosmanta jap'enka.  
\v 42 Yachacojcunay pisipaj khawaskaspuni cashancu. Pichari paycunamanta ujninman uj chhica yacullatapis jaywarinman yachacojniy caskanraycu, chekatapuni payka uj sumaj konata jap'enka Diosmanta, —nispa yachacherka Jesús. 
\c 11  
\s1 Bautizaj Juanpa cachasnin Jesusta tapuncu 
\p  
\v 1 Jesuska chunca iscayniyoj yachacojcunanta ruwanancuta yachacherka. Chayta tucuytawantaj llojserka chay kayllapi llajtasman yachachej willarajtaj. 
\p  
\v 2 Juanrí wisk'aska cashaspa uyarerka Cristoj ruwaskasninmanta. Chayraycu yachacojcunanta Jesusman tapunancupaj cacharka. Ajinapi Jesusta taporkancu: 
\p  
\v 3 —¿Kanchu Diospa niskanmanjina jamoj, Cristoka canqui? chayrí ¿wajtachu suyallasajcupuni? 
\p  
\v 4 Jesusri paycunaman cutichispa nerka: 
\p —Cay uyarishaskayquichejta ricushaskayquichejtawan cutispa Juanman willamuychej.  
\v 5 Ciegos ricushancuña. Suchuspis purishancuña. Lepra onkoyniyoj runaspis thañiskasña cashancu. Lojt'uspis uyarishancuña, wañuska runastaj causarichiskasña cashancu. Sumaj willanasta wajcha runaspis uyarishallancu. \fig |src="CN01723B.TIF" size="span" copy="© 1978 David C. Cook Publishing Co." ref="Mateo 11.5" \fig* 
\v 6 ¡May cusiska mana p'enkacuspa nokapi jap'icojka! 
\p  
\v 7 Juanpa cachamuska yachacojcunan ripushajtincu Jesuska ashqha runasman paymanta parlarka: 
\p —Juan ch'innejpi willarashajtin ¿imatataj khawaj rerkanquichejrí? Ichhu wayrawan c'umuycachachiska ¿chayjinata iscayrayaj runatachu khawamorkanquichej?  
\v 8 Mana ajina cajtinri ¿imata khawajtaj rerkanquichejrí? ¿Uj sumaj c'achitu p'achalliska runata khawajchu rerkanquichej? Reparaychej, ajinata p'achallicojcunaka jatun camachejcunaj wasisnillancupi tiyacuncu.  
\v 9 Chantarí ¿imata khawajpunitaj rerkanquichej? ¿Diosmanta uj willajtachu? Arí, niyquichej payka Diospa unay willajcunanmanta aswan curajmin caskanta.  
\v 10 Dios palabranpi Juanmanta kelkacherka: 
\q1 Willajniyta naupakeyquita cachamushani. 
\q1 Payka runaspa sonkoncuta\f + \fr 11:10 \ft Literal: ñanta.\f* waquichipusonka paycunaman rinayquipaj. 
\p  
\v 11 Nokataj chekatapuni niyquichej: Tucuynin runas uqhupi ni uj runa canchu aswan curaj bautizaj Juanmanta niskaka. Dios camachin, chaypirí aswan pisipaj khawaska cajka aswan curajpunimin Juanmanta niskaka. 
\p  
\v 12 ‘Bautizaj Juan willaraskan p'unchaymantapacha cunancama juchasapa runas Diospa camachisnin cayta mayta callpacushancu. Astawanrí Diospa churanacojninta atiywan atipaspalla paypa camachisnin cayta atincu.  
\v 13 Diospa tucuy unay willajcunanwan Moiseswanka sut'incharkancu Juan jamunancama. Paycunaka Dios tucuyta wiñaypaj camachinanmanta parlarkancu.  
\v 14 Nerkancutaj Juanka willaj Eliasjina jamoj caskanta. Chay sut'inchaskancuta jap'iyta munanquichej chayka, atinquichej.  
\v 15 Ningriyoj cajka, sumajta uyarichun. 
\p  
\v 16 ‘¿Picunamantaj rijch'acuncu cunan p'unchay runas? Plazaspi tiyaska pujllacoj wawasman rijch'acuncu. Uj tantaska wawas waj tantaska wawasta khaparincu:  
\v 17 “Kenata tocaporkaycu tusunayquichejpaj. Kancunarí mana tusorkanquichejchu. Wakanapajjina taquiporkaycu kancunarí mana wakarkanquichejchu”, nispa.  
\v 18 Ajinata Juanpis riqhurimuspa sumaj miqhunasta mana miqhojchu nitaj vinota ujyajchu chaywan Diosta casunanpaj. Runastaj nerkancu: “Supayniyoj chay runaka”, nispa.  
\v 19 Chanta noka, Diospa cachaska Runan, jamorkani, runaswantaj miqhuni. Nokamantataj nincu: “¡Khawaychej! Cay runaka miqhuysapa ujyaysapataj. Juchasapaswan impuesto jap'ejcunawan rejsinaycucun”, nispa. Chaywanpis tucuy cheka yachayniyojka rejsin Diospa yachaynin cheka caskanta. Ruwaskasninwantaj cheka caskanta ricuchin. 
\s1 Diosta mana casojcuna 
\p  
\v 20 Waquin llajtaspi Jesuska astawan ashqha t'ucuna imasta atiyninwan ruwarka. Chaywanpis chaypi tiyacoj runaska juchasnincuta mana sakerkancuchu. Nitaj Diosman cutirerkancuchu. Chayraycu Jesuska chay llajtaspi tiyacojcunata c'amerka: 
\p  
\v 21 —¡Ay, phutiy, ari, kancuna Corazín llajtapi tiyacojcunapajka! ¡Ay, phutiy, ari, kancuna Betsaida llajtapi tiyacojcunapajka! Dios atiyninwan jatun t'ucunasta kancuna uqhupi ruwarka. Tiro llajtayojcuna Sidón llajtayojcunapis ancha sajras carkancu. Chaywanpis paycuna uqhupi chay jatun t'ucunasta Dios ruwanman carka chayka, paycunaka payman unayña cutiricapuncuman carka. Ajinaka llamp'u sonkowan juchallicuskancumanta mayta llaquicuspa sajra ruwaskasnincuta sakepuncuman carka. Chayta ricuchinancupaj luto p'achasnincuta usphatawan umasnincuman jich'acuncuman carka.  
\v 22 Chaywanpis niyquichej: Diospa c'ajaj phiñacuynin p'unchaypiri kancunata astawan ñac'arichisonkachej Tiropi Sidonpi tiyacojcunamanta niskaka.  
\v 23 Capernaum llajtapi tiyacojcuna, kancuna mayta munasharkanquichej janaj pachaman okhariskas jatunpaj khawaskas canayquichejta. Astawanpis kancunaka uqhu pachapi tucuchiskas canquichej manacajpaj khawaskas canayquichejcama. Kancuna uqhupi ruwacuskan ajina ricuchinasllatajchus Sodoma llajtapi ruwacunman carka chayka, cunan p'unchaycama cacushanman carka.  
\v 24 Chaywanpis niyquichej: Dios c'ajaj phiñacuy p'unchaypi kancunata astawan ñac'arichisonkachej Sodoma llajtamanta niskaka, —nerka Jesús. 
\s1 “Nokaman jamuychej samachiskayquichejtaj” 
\p  
\v 25 Chaypacha Jesuska Diosman nerka: 
\p —Yupaychayqui Tatáy, kanka janaj pachata cay pachata camachej canqui. Imaraycuchus cay imasta yachaysapasmanta yuyaysapasmanta pacaycorkanqui. Wawajina llamp'u sonkoyojcunamantaj cay imasta sut'incharkanqui.  
\v 26 Arí, Tatáy, ajina ruwaskayquimanta cusicunqui, —nispa. 
\p  
\v 27 Runasman nillarkataj: 
\p —Dios Tatay tucuy yachayta kowarka. Payllamin noka Wawataka rejsiwan. Noka Wawallanmin Dios Tataytaka rejsini. Pimanchus noka, Wawan, rejsichiyta munani chay runallataj Dios Tataytaka rejsin.  
\v 28 Juchawan tucuy sayc'uchiska cajcuna tucuy llaquiska cajcunapis nokaman jampuwaychej. Nokataj samarichiskayquichej.  
\v 29 Wacas yugota apancu ajinata yachachinasniyta casuychej. Nokamantataj yachacuychej. Llamp'u sonkoyojmin caspa mana jatunchacunichu. Kancunataj nokaman jamuspa sonkoyquichejpi cheka samacuyta tarinquichej.  
\v 30 Imaraycuchus nokata casuyka cusicuymin. Nokapaj llanc'aytaj mana llasachu, —nispa. 
\c 12  
\s1 Samacuna p'unchaymanta 
\p  
\v 1 Chay cuti Jesuska trigo chajra chaupinta risharka. Chayri samacuna p'unchay carka. Yachacojcunantaj yarkhachicuspa trigo umasta muruspa pallasharkancu miqhuyta kallarerkancutaj.  
\v 2 Fariseo partemanta runasri chayta ricuspa Jesusman nerkancu: 
\p —Khawaymá, yachacojcunayqui samacuna p'unchaypi cayjinata llanc'ancu camachiwaskanchejta mana casuspa, —nispa. 
\p  
\v 3 Jesusri paycunaman cuticherka: 
\p —¿Manachu leerkanquichej unay camachej Davidpa ruwaskanta? Paywan runasninpiwan yarkhachicorkancu.  
\v 4 Paytaj yupaychana-wasiman yaycorka. Diosman t'akaska t'antasta miqhorka. Camachiwaskanchejmanjinarí chay t'antataka yupaychana-wasipi ruwanayojcunalla miqhunancu carka. Ni pay nitaj runasninpis miqhunancuchu carka.  
\v 5 Kancuna Moisespa camachiskasninta leerkanquichejcharí. Chaypi Moisés camacherka samacuna p'unchaypi runas mana llanc'anancuta. Yupaychana-wasipi ruwanayojcunarí ruwanallancupuni. Samacuna p'unchaypi ruwaskancumantataj mana juchallicorkancuchu Diosta yupaychanapaj ruwaskancuraycu.  
\v 6 Nokarí niyquichej caypi cashajka yupaychana-wasipi ruwanasmanta niskaka aswan curajmin caskanta.  
\v 7 Dios nin: “Runas qhuyanacunancoka astawan nokata cusichiwan uywa wañuchiska jaywanasmanta niskaka”. Chaytachus reparawajchej chayka, mana juchachawajchejchu allin ruwajcunataka.  
\v 8 Noka, Diospa cachaska Runan, atiyniyoj cani camachinaypaj imatachus ruwanata samacuna p'unchaypipis. 
\s1 Jesús thañichin wañuska maquiyoj runata 
\p  
\v 9 Chaymanta ripuspataj Jesuska tantacunawasincuman yaycorka.  
\v 10 Chaypi carka uj wañuska maquiyoj runa. Runaska imaynallamantapis Jesusta juchachayta munasharkancu. Chayraycu taporkancu: 
\p —Niwaycu, camachiwaskanchejmanjina ¿aticunchu runata thañichiy samacuna p'unchaypi? 
\p  
\v 11 Jesusrí paycunaman cuticherka: 
\p —Samacuna p'unchaypi uj ovejayquichej jatun t'okoman urmaycunman chayka ¿orkhocapuwajchejcharí?  
\v 12 Diospa ñaupakenpi runaka aswan yuyanamin ovejamanta niskaka. Chayraycu samacuna p'unchaypeka allin cajtapuni ruwana, —nispa nerka. 
\p  
\v 13 Chanta wañuskajina maquiyoj runaman nerka: 
\p —Aysariy maquiyquita. 
\p Runataj maquinta aysarerka. Chay maquinri ujnin maquinjina thañiska carka.  
\v 14 Fariseo partecunarí llojsiytawan tantacamorkancu. Jesuspa contranpi parlanacorkancutaj imaynamantapis payta tucuchinancupaj. 
\s1 Jesusmanta Isaiaspa willaraskan 
\p  
\v 15 Jesusrí chay imasta yachaspa chaymanta llojsiporka. Ashqha runas paywan risharkancu. Tucuy paycunatataj thañichisharka.  
\v 16 Paycunataka allinta camacherka: 
\p —Pitaj noka caskaytaka ama pimanpis willanquichejchu, —nispa. 
\p  
\v 17 Ajinapi junt'acorka Diospa unay willajnin Isaiaspa niskan Jesuscristomanta. 
\p Ajinaka Dios nin: 
\q1  
\v 18 Paymin ajllacuska camachiy, sonkoyta cusichin. Paytamin munacuni. 
\q1 Santo Espirituta cachasaj paypa sonkonpi tiyacunanpaj. 
\q1 Paytaj tucuy runasman cheka munayniyta willaranka. 
\q1  
\v 19 Llamp'u sonkowan parlanka. Manataj runaswan khawachicunanpajjinachu willaranka. 
\q1  
\v 20 Mana p'aquenkachu saruska sokosojina runatapis. Nitaj ñac'ayta k'oshñej c'anchanajina runatapis wañuchenkachu. 
\q1 Cheka munayninta junt'anancama chaytaka pay ruwanka. 
\q1  
\v 21 Tucuy runaska juchancumanta cachariskas canancupaj paypi suyankancu. 
\s1 Nincu Jesuspa atiynin supaymanta caskanta 
\p  
\v 22 Chaymantataj Jesusman uj ciegota pusamorkancu. Chay runari supayniyoj upataj carka. Jesustaj payta thañicherka. Ajinapi upa cajka parlaporka, ricorkataj. 
\p  
\v 23 Tucuy chay ashqha runastaj t'ucuspa Jesusmanta nerkancu: 
\p —¿Cay Diospa ajllaskan Cristochu\f + \fr 12:23 \ft Literal: Davidpa Wawan.\f* canman? 
\p  
\v 24 Fariseo partecunarí cayta uyarispa nerkancu: 
\p —Cay runaka curaj supaycunaj curajnincu, Beelzebú atiynillanwan supaycunata kharkon, —nispa. 
\p  
\v 25 Jesusrí yuyashaskancuta yachaspa paycunaman nerka: 
\p —Jatun llajtapi tiyacojcuna paycunapura makanaycucojtincoka tucuchiska canka chay llajtaka. Sapa llajta chayrí wasipis paycunapurallataj makanacojtenka chincaponka.  
\v 26 Curaj supay Satanás supaycunallatataj kharkon chayka, payllataj t'akanacushan. Camachisnillantaj paywan makanacojtincoka tucuconkancu.  
\v 27 Supay Beelzebój atiyninwan supaycunata kharkoskayta ninquichej. Kancunamanta cajcunarí ¿pejpa atiyninwantaj supaycunata kharkoncurí? Chayraycu paycuna pantaskaspuni caskayquichejta ricuchisonkachej.  
\v 28 Nokarí Santo Espíritoj atiyninwan supaycunata kharkoskayka niyta munan Dios kancuna uqhupiña caskanta camachinanpaj. 
\p  
\v 29 ‘Suwayta munajka callpasapaj wasinman yaycunanpajka ñaupajta atipaspa watananraj tiyan. Chanta wasinman yaycuyta atin capuyninta apacapunanpaj. [Nokapis ajinallatataj curaj supayta atipaspa millay supaycunata kharkoni.]\f + \fr 12:29 \ft Ninayan.\f* 
\p  
\v 30 ‘Ajinata mana nokawan cusca Diosman sayacojka contraypi churanacun. Mana nokata yanapawajka ruwanasniyta jarc'awan. 
\p  
\v 31 ‘Chayraycu niyquichej Dios khechuyta atiskanta runaspa tucuy juchancuta payta phiñachiskancutapis. Santo Espíritoj contranpi sajrata parlajtarí Dios mana perdonankachu.  
\v 32 Noka, Diospa cachaska Runanpa contranpi sajrata parlan chayka, parlaskanmanta perdonaskaraj canka. Santo Espíritoj contranta sajrata parlajrí ni jayc'aj perdonaskachu canka, ni cunanpis nitaj khepatapis. 
\s1 Sach'aka pokoyninpi rejsicun 
\p  
\v 33 ‘Yachanchej sach'a sumaj chayka, pokoyninpis sumajllataj. Sach'a mana allinchu chayrí pokoyninpis manallataj allinchu. Arí, sach'ataka pokoyninmantamin rejsinchej. Nokatapis ajinallatataj ruwaskasniymanta atinquichej rejsiwayta.  
\v 34 ¡Kancuna runa wañuchi catarisjina canquichej! Sajra caspa ¿imaynatataj allin cajta parlayta atiwajchejrí? Runaka sonkonpi junt'a cajmanta parlan.  
\v 35 C'acha runaka c'acha imasta parlan sonkonpi c'acha cajta jallch'askanmanta. Sajra runarí sajra cajta parlan sonkonpi sajrata jallch'askanmanta.  
\v 36 Nokarí niyquichej runaska tucuy manacaj niskanmantapis Diosman willacunan tiyan. Chaypi Dios nenka juchayojchus manachus caskancuta.  
\v 37 Niskasniyquimanjina Dios chekan ruwaj runapaj khawasonka. Chayrí sajra niskasniyquimanjina pay juchachasonka, —nispa. 
\s1 Mañancu uj t'ucuna ricuchinata ruwananta 
\p  
\v 38 Chanta waquin yachachejcuna fariseo partecunawan nerkancu: 
\p —Yachachej, Diosmanta cachamuska caskayquita yachanaycupaj uj jatun t'ucunata ruwaspa kanmanta ricuchiwaycu, —nispa. 
\p  
\v 39 Jesusrí cutichispa paycunaman nerka: 
\p —Sajra ruwajcunawan Diosta wasanchajcunawan uj t'ucunapaj ricuchinata mañashancu. Chayka mana ruwaskachu canka. Manachayrí Diospa unay willajnin Jonás ricucherka, chayllataj reparanancupaj cashan.  
\v 40 Jonaska quinsa p'unchay tutatawan jatun challwaj wijsan uqhupi carka. Ajinallataj noka, Diospa cachaska Runanpis, jallp'a uqhupi p'ampaska casaj quinsa p'unchayta quinsa tutatawan.  
\v 41 Diospa c'ajaj phiñacuynin p'unchaypi Nínive llajtapi tiyacojcuna cunan p'unchaycunaj contrancupi willankancu. Paycunatataj juchachankancu. Imaraycuchus Jonaspa willaraskantawan paycunaka juchasnincuta sakespa Diosman cutiricaporkancu. Reparaychejtaj cunan Jonasmanta aswan curaj caj caypi caskanta.  
\v 42 Chay p'unchaypitaj Sabá runasta camachej warmipis cunan p'unchay runaspa contrancupi willaspa paycunata juchachanka. Imaraycuchus payka may caru jallp'manta jamorka Salomonpa yachayninta uyarej. Reparaychejtaj cunanka Salomonmanta aswan curaj caj caypi caskanta. 
\s1 Runaman supay cutimun 
\p  
\v 43 ‘Uj millay supay runamanta llojsispaka ch'aqui pampapi khasilla purin. Samaricuyta masc'aspataj mana tarinchu.  
\v 44 Chanta yuyaspa nin: “Pimantachus llojsimorkani chay runallamantaj cutipusaj”, nispa. Cutimuspa supayka chay runata taripan pichaskata sumaj c'uchunchaskatataj ch'usaj wasitajina.  
\v 45 Chaymantaj supayka rispa paymanta aswan millay kanchis supaycunata pusamun. Chay runaman yaycuspataj paypi tiyacuncu. Ajinapitaj chay runaj khepa caynin aswan sajraman tucun ñaupaj caskanmantaka. Cay p'unchay sajra runaswanpis ajinallataj canka. 
\s1 Jesuspa maman waukesninwan 
\p  
\v 46 Jesús chay ashqha runasman parlashajtinraj, khaway, maman waukesninwan chayamorkancu. Cay jawapi casharkancu paywan parlayta munaspa.  
\v 47 Ajinallapi uj runaka Jesusman willarka: 
\p —Khaway, mamayqui waukesniyquiwan jawapi cashancu. Munashasuncutaj kanwan parlanacuyta, —nispa. 
\p  
\v 48 Jesustaj cutichispa willajman nerka: 
\p —¿Picunataj mamay waukesniy cancumanrí? —nispa. 
\p  
\v 49 Yachacojcunanta maquinwan ricuchispataj nerka: 
\p —Paycuna mamay waukesniypis cancu.  
\v 50 Janaj pacha Dios Tataypa munayninta ruwajmin waukey, panay, mamaypis, —nispa nerka Jesús. 
\c 13  
\s1 Tarpoj runamanta uj quiquinchana 
\p  
\v 1 Chay p'unchay Jesuska wasimanta llojsispa kocha cantoman rerka. Chaypitaj yachachinanpaj tiyaycucorka.  
\v 2 May ashqha runastaj tantaycacamorkancu. Chayraycu payka barcoman yaycuspa chaypi tiyaycucorka. Tucuy chay ashqha runastaj kocha cantopi sayaycucorkancu.  
\v 3 Jesusri quiquinchanaswan ashqha imasmanta paycunaman willarka. Nerkataj: 
\p —Uyariwaychej, uj runa mujuta t'acaj llojserka.  
\v 4 T'acashajtinri waquin mujoska ñan pataman urmarkancu. P'iskostaj jamuytawan pallacaporkancu.  
\v 5 Waquin mujusri pisi jallp'ayoj rumi pataman urmarkancu. Chay mujoska uskhayta p'uturamorkancu pisi jallp'a caskanraycu.  
\v 6 Mana sumaj saphiyoj caskanraycutaj inti ruphamojtin ch'aquiporkancu.  
\v 7 Waquin mujustaj qhishca chaupiman urmarkancu. Qhishcawan cusca wiñaycuytawantaj trigota sip'icaporkancu.  
\v 8 Waquin mujusrí sumaj jallp'aman urmarkancu. Chaypi waquenka uj mujullamanta pachajta pokorka. Waquintaj sojta chuncata, waquintaj quinsa chuncata pokorka.  
\v 9 Ningrisniyoj cajka sumajta uyarichun, —nispa nerka Jesuska. 
\s1 Quiquinchanas ¿imapajtajrí? 
\p  
\v 10 Yachacojcunaka Jesusman kayllaycuspa tapurerkancu: 
\p —¿Imaraycutaj runasman quiquinchanaspa parlanquirí? 
\p  
\v 11 Paytaj paycunaman cutichispa nerka: 
\p —Dios runasninta camachin, chaymanta yachachinaska wajcunapaj pacaska cancu. Cunanrí kancunallaman sut'i ricuchiskas cancu entiendenayquichejpaj.  
\v 12 Niskanta jap'icojmanka Dios astawanraj entiendeyta yanapanka. Ajinapi jap'icojka astawan astawanraj jap'iconka. Mana jap'icojmantarí pisi jap'iska yuyaskanpis khechuska canka.  
\v 13 Chayraycu paycunaman quiquinchanaswan parlani ricushaspapis mana entiendenancupaj uyarishaspapis mana chekata reparanancupajchu.  
\v 14 Ajinapi Isaiaspa sut'inchaskan paycunamanta junt'acun. Dios palabranpi nin: 
\q1 Uyarishaspa chay uyariskayquichejtaka mana entiendenquichejchu. 
\q1 Khawashaspa chay khawashaskayquichejtapis mana reparanquichejchu. 
\q1  
\v 15 Sonkoncu rumiyaycapuskanraycu chay runas palabrayta mana entiendencuchu. 
\q1 Ningrisnincoka manaña allintachu uyarin. 
\q1 Ñawisnincutapis ch'illmiycapuncu ama ricunancupaj. 
\q1 Ningrisnincuwanpis mana uyarincuchu mana munaspa entiendewayta. 
\q1 Chaywanpis sonkoncupi mana reparayta munancuchu. 
\q1 Chayraycu nokaman mana cutiricamuncuchu juchasnincuta khechuspa paycunata thanichinaypaj. 
\p  
\v 16 ‘Kancunarí may cusiskas canquichej ñawisniyquichejwan chaycunata ricuskayquichejraycu ningrisniyquichejwantaj uyariskayquichejraycupis.  
\v 17 Niyquichej chekatapuni kancuna ricushanquichej chayta ashqha unay willajcunawan cheka ruwajcunawan ricuyta mayta munaskancuta. Manataj ricorkancuchu. Uyarishaskayquichejtapis uyariyta mayta munarkancu manataj aterkancuchu. 
\s1 Jesús tarpojmanta quiquinchanata sut'inchan 
\p  
\v 18 ‘Tarpojwan quiquinchaskayta entiendenayquichejpaj uyariwaychej. 
\p  
\v 19 ‘Waquin runas Dios camachin, chaymanta willanasta uyarincu, manataj casuncuchu. Chaycunaka ñan purinaman urmaj mujusjinamin cancu. Supay Satanás jamuspa Diospa niskanta sonkoncumantaka siq'irpayan mana juchamanta cachariska canancupaj. Chay runaska ñanpi t'acaska mujujinamin.  
\v 20 Waquin runaska pisi jallp'ayoj rumi pataman urmaj mujusjina cancu. Diospa niskanta uyarispa cusiywan jap'icuncu.  
\v 21 Chay runaska pisi saphiyoj mujusjinamin. Chayraycu pisi ratullapaj jap'incu. Paycunata llaquiycuna khatirishajtin chayrí Diospa niskanraycu muchojtincu paycunaka chaypacha urmacapuncu.  
\v 22 Waquin runas Diospa niskanta uyarispa cay pacha imasmanta anchata yuyancu. Chayjina runaka munashan ancha khapaj caytaraj. Tucuy chay imastaj payta pantachispa Diospa niskanta sonkonpi mana sakenchu wiñajta. Ajinapi mana pokoyniyoj caspa payka Diosta mana cusichinchu. Chayraycu qhishca chaupiman urmaj mujujina cashan.  
\v 23 Waquin runas Diospa niskanta tucuy sonkowan uyarispa casuncu. Chay runaka sumaj jallp'aman urmaj mujujina cashan. Diosta casuskancuraycutaj payta cusichincu. Ajinapi waquin runas ancha sumajta ruwaspa pachajman pokoj mujujina cancu. Waquinri sumajllata ruwaspa sojta chuncaman pokoj mujujina cancu. Waquintaj quinsa chuncaman pokoj mujujina callancutaj. 
\s1 Cizañamanta trigomantawan uj quiquinchana 
\p  
\v 24 Waj quiquinchanatawan Jesuska yachachisharka. Nerka: 
\p —Dios camachishajtenka sumaj mujuta chajranpi tarpoj runaman rijch'acun.  
\v 25 Tutapi tucuy runas puñushajtintaj uj chejnicojnin jamorka. Millay kora cizaña mujuta trigo tarpuskanman t'acaycarparerka. Chaymantataj riporka.  
\v 26 Trigotaj wiñaspa sunqhachacorka. Chaypacha millay cizaña trigopis riqhurillarkataj.  
\v 27 Tarpojpa camachisninri payman jamuspa nerkancu: “Tatay, “¿manachu sumaj mujullata t'acarkanqui chajrayquipi? ¿Imaynamantataj riqhurin chay millay khorarí?”  
\v 28 Paytaj paycunaman nerka: “Chayka uj chejnicojpa ruwaskan”, nispa. Chanta camachisnin payman nerkancu: “¿Munanquichu khorata siq'iramoj rinaycuta?”  
\v 29 Payri cuticherka: “Amaraj, trigotapis koratawan cusca siq'irashawajchejchá.  
\v 30 Sakellaychej iscaynincuta wiñajta ruthunacama. Ruthushajtincu trigo ruthojcunaman nisaj: Ñaupajta cizañata t'akarkoychej. K'apiy k'apiyllata churarparispa wataychej ruphachinayquichejpaj. Trigotarí pirwayman wakaychaychej”, —nispa. 
\s1 Mostaza mujumanta uj quiquinchana 
\p  
\v 31 Waj quiquinchanatawan Jesús paycunaman yachacherka: 
\p —Imaynatachus chajrapi tarpuska juch'uy muju\f + \fr 13:31 \ft Literal: Israel jallp'api mostaza mujitu.\f* wiñan, ajinallataj cashan Dios runasta camachishajtenka.  
\v 32 Chekatapuni chay mujoka tucuy juch'uy mujusmanta aswan juch'uysitumin. Wiñasparí tucuy koramanta aswan jatunta wiñan sach'itajinaman tucunancama. P'iskospis mallquisninpi thapachacuncu, —nispa. 
\s1 T'anta pokochinamanta uj quiquinchana 
\p  
\v 33 Waj quiquinchanatawan paycunaman yachachispa nerka: 
\p —Dios camachishajtenka, t'anta pokochina levadurajina wiñan. Uj warmi chay pokochinata iscay arrobajina trigo jac'uman churaycorka. Chanta tucuynin masa pokospa okharicamorka, —nispa. 
\s1 Quiquinchanas junt'acunanpaj cancu 
\p  
\v 34 Tucuy chay imasta Jesuska chay ashqha runasman quiquinchanasllawanpuni parlaj. Mana chaywanka mana yachachejchu.  
\v 35 Ajinapi Diospa willajninpa niskan junt'acorka. Dios palabranpi nin: 
\q1 Quiquinchaspa paycunaman parlasaj. 
\q1 Cay pacha ruwacuskanmantapacha mana yachaska imasta paycunaman willasaj. 
\s1 Koramanta quiquinchanata Jesús sut'inchan 
\p  
\v 36 Chanta Jesuska runasta cacharpayaspa wasiman jamporka. Yachacojcunantaj payman kayllaycuspa nerkancu: 
\p —Chay chajrapi cizaña khorawan quiquinchanamanta sut'inchawaycu, 
\p  
\v 37 Payri cuticherka: 
\p —Noka, Diospa cachaska Runan, sumaj mujuta tarpoj cani.  
\v 38 Chajrataj tucuy runas cancu. Sumaj mujutaj Diospa cheka wawasnin cancu. Cizañataj Diosta mana casoj supay Satanaspa wawasnin cancu.  
\v 39 Cizañata t'acaycojtaj chejnicoj supaymin. Cosechari nokaj cutimunay p'unchaymin. Ruthojcunataj Diosmanta cachaska angeles cancu.  
\v 40 Chayraycu imaynatachus cizañata runas tantaycuspa ninaman ruphachincu. Ajinallataj canka cay pacha tucucojtenka.  
\v 41 Noka, Diospa cachaska Runan, angelesniyta cachamusaj. Maypicha camachini, chaymanta orkhonkancu tucuy pantachej, sajrata ruwaj runasta, Diosta mana casojcunatapis.  
\v 42 Paycunata laurashaj uqhu pachaman wijch'uyconkancu. Chaypitaj chay runaska jatun nanaywan manchayta wakankancu, phutiywan quirusnincutapis c'aruconkancu.  
\v 43 Chanta chekanta ruwajcunaka cusiywan riconkancu Diosta janaj pachapi. Chaypitaj Dios Tata atiyninwan tucuyta camachenka. Ningrisniyoj cajka sumajta uyarichuncu. 
\s1 Uj quiquinchana p'ampaska khapaj capuymanta 
\p  
\v 44 ‘Dios runasta camachishajtin uj chajrapi khapaj capuy p'ampaskaman rijch'acun. Chayta taricoj runaka pacaycun. Cusiywan rispataj tucuy capuyninta vendemun chay jallp'atataj ranticapun. 
\s1 Uj quiquinchana sumaj perlamanta 
\p  
\v 45 ‘Dios runasta camachishajtin uj rantej runamanpis rijch'acullantaj. Payka may sumaj perlasta masc'an rantinanpaj.  
\v 46 Aswan sumaj caj perlayojwan tincucuspa: “Cayta ranticuskayqui”, nerka. Chaymanta rerka tucuy capuyninta vendemoj sumaj perlata ranticapunanpaj. 
\s1 Uj quiquinchana challwa jap'ina ch'ipamanta 
\p  
\v 47 ‘Ajinallataj Dios runasta camachishajtin challwa jap'ina jatun ch'ipaman rijch'acun. Runas chay ch'ipata kochaman churancu. Chay ch'ipawan imaymana challwasta jap'incu.  
\v 48 Ch'ipa junt'aycojtintaj kocha cantoman aysancu. Chaypi tiyaycucuspa challwasta ajllancu. Sumajcunata canastasman tantancu. Mana allin cajcunatataj wijch'upuncu.  
\v 49 Ajina canka cutimunay p'unchaycunapeka. Janaj pachamanta angeles jamonkancu t'akanancupaj sajra runasta chekan ruwaj runasmanta.  
\v 50 Chay sajra ruwaj runasta laurashaj uqhu pachaman wijch'uyconkancu. Jakaypiri manchayta wakankancu, phutiywantaj quirusnincuta c'aruconkancu, —nispa nerka Jesús. 
\s1 Mosoj khoyaswan unay khoyaswan 
\p  
\v 51 Jesús yachacojcunata taporka: 
\p —¿Tucuy chayta entienderkanquichejchu? Paycunataj cuticherkancu: 
\p —Arí, yachachiwajníy, entiendeycu, —nispa. 
\p  
\v 52 Jesusri paycunaman nerka: 
\p —Chayraycu Dios camachin, chaymanta sumaj yachachiska runa uj khapaj wasiyojman rijch'acun. Payka jallch'aska khapaj khoyasninmanta orkhomun mosoj khoyasta unay khoyastapis, —nispa. 
\s1 Jesús Nazaretpi 
\p  
\v 53 Chay quiquinchanaswan parlayta tucuytawan Jesuska chaynejmanta llajtanman riporka.  
\v 54 Chayaspa runasta tantacuna-wasincupi yachachisharka. Mayta t'ucuspa runas ninacorkancu: 
\p —Cay runari ¿maypitaj cayjina yachayniyoj tucumorkarí? ¿Imaynapitaj cayjina t'ucuna ruwanasta ruwashanrí?  
\v 55 ¿Manachu cayka carpintero runaj wawan? ¿Manachu mamanpa sutinpis María? ¿Manachu waukesninpis Jacobo, José, Simón, Judaswan cancu?  
\v 56 Panasninpis ¿manachu kayllanchejpi tiyacuncu? Chanta ¿imaynapitaj tucuy cay imasta yachamorkarí? 
\p  
\v 57 Paycunataj phiñacuspa Jesusta mana jap'icorkancuchu. Jesusrí paycunaman nerka: 
\p —Diosmanta uj willajka sumajpaj khawaskapuni cashan waj llajtaspeka. Llajtanpi, wasinpiwan cajcunalla paytaka manamin sumajpajchu khawancu, —nispa. 
\p  
\v 58 Chaypitaj Jesuska pisi t'ucuna ruwanasllata ruwarka paypi mana jap'icuskancuraycu. 
\c 14  
\s1 Bautizaj Juan wañuchiska carka 
\p  
\v 1 Galilea jallp'api camachej Herodeska chay p'unchaycunapi Jesuspa ruwaskasninmanta uyarerka.  
\v 2 Camachisninmanta curajcunamantaj nerka: 
\p —Cay runaka bautizaj Juan wañuyninmanta causarimpuskamin. Chayraycu Diospa atiyninwan t'ucuna ruwanasta ruwashan, —nispa. 
\p  
\v 3-4 Ñaupajpi Herodeska jap'iycucherka Juanta. Wataycuchiytawantaj carcelman wisk'aycucherka, wauken Felipej warminraycu. Ñaupajpi Juanka payta c'amejpuni carka: 
\p —Juchamin waukeyquej warmin Herodiasta warmillicunayqueka, —nispa. 
\p  
\v 5 Chayraycu Herodiaska Juanta wañuchiyta munarka. May ashqha runasmantataj manchachicorka. Paycunaka Diospa willajninpaj Juanta rejserkancu.  
\v 6 Astawanrí Herodespa diachacun chayamorka. Chaypitaj Herodiaspa ususenka wajyaskacunapaj tusorka. Herodesri chaywan mayta cusicorka.  
\v 7 Chayraycu Herodeska Diospa sutinta okharispa nerka warminpa ususinman: 
\p —Imatachá mañacuwaskayquita koskayqui, —nispa. 
\p  
\v 8 Chay sipastaj maman yachaycuchiskanraycu nerka: 
\p —Cunitanpacha chuwapi bautizaj Juanpa umanta koway, —nispa. 
\p  
\v 9 Camachej Herodeska phuticorka. Diospa sutinta okhariskanraycurí paywan cusca tiyacojcunaraycutaj camacherka Juanpa umanta sipasman konancuta.  
\v 10 Chanta soldadosta carcelman cacharka Juanpa umanta khorumunancuta.  
\v 11 Chaymantataj Juanpa umanta uj chuwapi apamorkancu. Sipasmantaj jaywarkancu. Paytaj mamanman aparka. 
\p  
\v 12 Chayta yachaspa Juanpa yachacojcunan jamorkancu. Ayantataj apacaporkancu p'ampamunancupaj. Chay imasmantataj Jesusman willamoj rerkancu. 
\s1 Jesús phishka waranka runasta miqhuchin 
\p  
\v 13 Jesuska chayta uyariytawan yachacocunanwan barcopi riporka ch'innejman sapallancu canancupaj. Riskanta yachaspataj may ashqha runas llajtasmanta chaquillapi khepanta khaterkancu.  
\v 14 Barcomanta llojsispataj Jesuska may ashqha runasta ricorka. Paycunamantari sonkon nanarka. Qhuyacuspataj onkoskasta thañiracherka. 
\p  
\v 15 Ch'isiyaycushajtinña yachacojcunanka Jesusman chimpaycorkancu. Nerkancutaj: 
\p —Inti yaycushanña. Ch'in pacha caynejka. Chayraycu cay ashqha runasta cachapullayña. Ajinapi ranchosman rispa miqhunata ranticamonkancu, —nispa. 
\p  
\v 16 Astawanri Jesuska paycunaman cuticherka: 
\p —Mana paycunaka ripunancuchu tiyan. Kancuna paycunaman miqhunata koychej, —nispa. 
\p  
\v 17 Paycunarí nerkancu: 
\p —Caypeka phishka t'antaswan iscay challwitasllawan tiyapuwaycu. Chaylla, —nispa. 
\p  
\v 18 Jesustaj nerka: 
\p —Chay capususkayquichejta cayman apamuwaychej, —nispa. 
\p  
\v 19 Chay ashqha runastataj camacherka pastopi tiyaricunancuta. Chanta chay phishka t'antasta iscay challwitastawan maquisninpi jap'erka. Janaj pachaman khawarispataj qraciasta korka Diosman. T'antasta challwitastawan partispataj yachacojcunaman jaywarka. Paycunataj chay ashqha runasman jaywaramorkancu.  
\v 20 Tucuynincu miqhorkancu sajsacunancucama. Chay partiskasmanta puchojtaj chunca iscayniyoj canastas junt'araj carka.  
\v 21 Chay miqhojcunaka phishka warankajina kharis carkancu. Warmis wawitaswanpis miqhullarkancutaj. 
\s1 Jesús yacu patata purin 
\p  
\v 22 Chayta ruwaskantawancama Jesuska yachacojcunanta camacherka: 
\p —Barcoman yaycuychej kocha chimpaman ñaupajta rishanayquichejpaj. Nokataj chaycama runasta cacharparipusaj, —nispa. 
\p  
\v 23 Runasta cacharpariytawan Jesuska sapallan orkoman riporka Dios Tatanwan parlaj. Inti yaycuytañari sapallan payka orkopi cacusharka.  
\v 24 Chaycamataj barcoka jallp'amanta carupi uqhu kochapiña carka. Yacutaj kholchokeyaspa barcotaka mayta apaycachasharka sinch'i wayra contrancupi wayramushaskanraycu.  
\v 25 Jesusrí sut'iyamuytaña yacu patata purispa paycunaman kayllaycusharka.  
\v 26 Yachacojcunanka yacu patanta purishajta ricuspa mayta mancharicorkancu “¡Alma!” nispa. Manchaymantataj khaparerkancu.  
\v 27 Khapariskancutawantaj Jesuska paycunaman nerka: 
\p —¡Callpachacuychej! ¡Noka cani! Amaña manchachicuychejchu, —nispa. 
\p  
\v 28 Pedrotaj cutichispa nerka: 
\p —Señorníy, kanchus canqui chayka, niway cay yacu patata kanman jamunayta, —nispa. 
\p  
\v 29 Jesustaj nerka: 
\p —Jamuy, —nispa. 
\p Pedrori barcomanta uraycorka. Yacu patanta purispataj Jesusman risharka.  
\v 30 Wayra sinch'i caskanta ricuspa mancharicorka. Yacuman chincaycushaskanpitaj khaparicorka: 
\p —Señorníy, jap'iriway, —nispa. \fig |src="cn01722B.tif" size="span" copy="© 1978 David C. Cook Publishing Co." ref="Mateo 14.30" \fig* 
\p  
\v 31 Jesustaj maquinwan payta jap'icorka. Nerkataj: 
\p —¡Ancha pisita nokapi jap'icunqui! ¿Imaraycutaj iscayrayarkanquirí? 
\p  
\v 32 Paycuna barcoman yaycojtincutaj manaña wayrarkachu.  
\v 33 Barcopi cajcunarí Jesusman kayllacuspa yupaycharkancu. Nerkancutaj: 
\p —¡Chekamanta kanka Diospa c'ata Wawan canqui! 
\s1 Jesús thañichin onkoskasta Genesaret jallp'api 
\p  
\v 34 Kochata chimpaytawanka Genesaretman chayamorkancu.  
\v 35 Chaypi tiyacoj runas Jesusta rejsiycorkancu. Chaymantataj runas paymanta willamorkancu. Tucuy onkoskacunatataj payman apamorkancu.  
\v 36 Paycunataj Jesusmanta mañacorkancu p'achanpa t'icasnillantapis llanqharinancuta. P'achanta tucuy llanqharejcunataj thañiskas carkancu. 
\c 15  
\s1 Ñaupa tatacunaj yachachiskancu 
\p  
\v 1 Chaymantaka waquin fariseo partecuna yachachejcunawan Jerusalén llajtamanta jamorkancu. Jesustataj taporkancu: 
\p  
\v 2 —¿Imaraycutaj yachacojcunayqui unay curajninchejpa yachachiska ruwanasnincuta p'aquincu? Yachacuskanchejmanjina yachacojcunayqueka maquisnincuta mana mayllacuncuchu miqhunancupajka. ¿Imaraycutaj ajinata ruwancurí? 
\p  
\v 3 Jesustaj cutichispa nerka: 
\p —Unay runasmanta yachacuskallayquichejta casushanquichej. Chanta ¿imaraycutaj kancunapis mana casunquichejchu Diospa camachiskanta?  
\v 4 Imaraycuchus Dioska nerka: “Tatayquita mamayquita jatunpaj khaway. Tatanpaj chayrí mamanpaj sajrata parlajka wañuchiska canan tiyan”, nispa.  
\v 5 Kancunarí yachachinquichej uj runa atillan niyta tataman chayrí mamaman: “Mana atinichu yanapasuyta. Kosunay carka chaytaka Diosmanña korkani”. Chay “korkani” nejka manaña jatunpaj tatanta mamantapis khawanchu.  
\v 6 Chaywanri Diospa camachiskanta p'aquinquichej yachacuskasniyquichejta ruwanayquichejpaj.  
\v 7 ¡Puraj uya runas! Allinta Diospa unay willajnin, Isaiaska, kancunamanta sut'incharka. Kelkaskanpi Dios nin: 
\q1  
\v 8 Cay runacunaka simisnillancuwan yupaychawancu. 
\q1 Sonkoncurí nokamanta carupi cashan. 
\q1  
\v 9 Paycunaka runaj yachachinasnillancuta yachachincu nokamantapis canmanjinata. 
\q1 Ajinapeka yankhalla yupaychawancu. 
\s1 ¿Imataj ch'ichichan runaj sonkontarí? 
\p  
\v 10 Chanta chay ashqha runasta paynejman wajyaspa nerka: 
\p —Sumajta uyariwaychej niskasniyta entiendenayquichejpaj.  
\v 11 Siminnejta yaycoj miqhunaka runaj yuyayninman juchawan mana ch'ichichanchu. Manachayrí runaj sonkonpi sajra yuyaskan siminnejta llojsimun. Chay parlaskanmin runataka ch'ichichaspa juchallichin, —nispa. 
\p  
\v 12 Chanta Jesuspa yachacojcunanka payman kayllaycuspa nerkancu: 
\p —¿Yachanquichu chay fariseo runas niskayquita uyarispa phiñacuywan khesachasuskancuta? 
\p  
\v 13 Payri cuticherka: 
\p —Tucuy yachachinas\f + \fr 15:13 \ft Literal: planta.\f* mana janaj pachapi tiyacoj Dios Tataymanta cajka k'ala tucuchiskas cankancu.  
\v 14 Sakeychej chaycunata munaynincumanjina ruwanancuta. Paycuna ciegosjina cancu Diospa yachachinasninmantaka. Chaywanpis waj ciegosta pusajcunajinataj cancu. Sichus uj ciego ciegollatataj pusanman chayka, iscaynincu cusca t'okoman urmayconkancu, —nispa. 
\p  
\v 15 Pedrori Jesusta nerka: 
\p —Ch'ichichanamanta niskayquita sut'inchawaycu, —nispa. 
\p  
\v 16 Paytaj cuticherka: 
\p —Kancunapis ¿manallatajchus yuyayniyoj canquichej?  
\v 17 ¿Manachu entiendenquichej? runaj miqhuskanka wijsanman yaycuskanta chaymantataj jawaman llojsipun.  
\v 18 Astawanpis runaj sonkon sajrata yuyaskanmanta llojsimoj parlaskanmin runataka juchallichin.  
\v 19 Imaraycuchus runaj sonkonmanta sajra yuyaycuna llojsimun. Chaymanta runata wañuchin, khenchachacun, sajra puriypi causan, suwacun, llullacuytawan willan runa-masinmanta, Diospaj sajrata parlan.  
\v 20 Chaycunamin Diospa ñaupakenpeka jucha cancu. Runaj sonkontataj ch'ichichan. Maquista mana mayllacuspa miqhuyrí manapuni runaj sonkontaka ch'ichichanchu, —nispa. 
\s1 Uj warmi Jesuspi jap'icun 
\p  
\v 21 Jesuska chaymanta llojsipuspa Tiro llajta Sidón llajta chaynejman riporka.  
\v 22 Chaypitaj tiyacoj Canamanta uj warmi. Paytaj Jesusman jamorka. Khaparispataj paymanta mayta mañacorka: 
\p —Tucuy atiyniyoj Señor, Diospa ajllaskan Cristo\f + \fr 15:22 \ft Literal: Davidpa Wawan.\f* canqui. ¡Qhuyacuway nokamanta! Ususiyta supay mayta ñac'arichishan, —nispa. 
\p  
\v 23 Jesusrí warmiman ni uj palabratapis cuticherkachu. Chayraycu yachacojcunanka Jesusman kayllaycuspa mayta mañarkancu: 
\p —Cachapuy chay warmita. Payka khepanchejta khaparispa jamushan, —nispa. 
\p  
\v 24 Jesusri cuticherka: 
\p —Dios Tatayka israel aylluymanta chincaska cajcunallaman cachamuwan. Paycunaka ovejasjina Diospa chekan ñanninmanta pantaporkancu, —nispa. 
\p  
\v 25 Chaywanpis chay warmeka kayllaycuspa Jesusman c'umuycorka yupaychananpaj. Nerkataj: 
\p —¡Señor, yanapariway ari! —nispa. 
\p  
\v 26 Jesusrí cuticherka: 
\p —Wawaspa t'antancuta okharispa alketusman karaycoyka mana allinchu, —nispa. 
\p  
\v 27 Warmiri nillarkataj: 
\p —Arí, Señor, chaywanpis alketuspis miqhuncupuni dueñosnincoj miqhuy t'unasnin mesamanta t'acacojtenka, —nispa. 
\p  
\v 28 Chanta Jesuska payman cutichispa nerka: 
\p —Doña, may sumajta nokapi jap'icunqui. Munaskayquimanjina ruwaska cachun, —nispa. 
\p Chay quiquinpacha ususenka thañicaporka. 
\s1 Jesús ashqhasta thañichin 
\p  
\v 29 Jesuska jakaymanta llojsispa Galilea kocha cantonejman rerka. Orkoman rispataj chaypi tiyaycucorka.  
\v 30 May ashqha runas payman kayllaycorkancu. Paycunataj apamorkancu wist'usta, ciegosta, mana rimarejcunata, ñuc'usta, ashqha waj onkoyniyojcunatawan. Jesuspa ñaupakenman chay onkoskasta churaycorkancu. Payri paycunata thañicherka.  
\v 31 Ajinaka chay ashqha runas mayta t'ucorkancu. Uyarerkancu mana rimarejcuna parlashajta. Ricorkancu ñuc'us thañicojta, suchus purishajta, ciegos ricushajta. Israel runaspa Diosnincutataj jatunchaspa yupaycharkancu. 
\s1 Jesús tawa waranka runasta miqhuchin 
\p  
\v 32 Jesuska yachacojcunanta payman wajyaspa nerka: 
\p —Sonkoy nanawan cay ashqha runasmanta. Quinsa p'unchaytaña nokawan cusca cashancu. Miqhunancupaj manaña ni imapis canchu. Mana miqhuskata cachapuytari mana munanichu, ñanta rishaspapis yarkhaywan llauchhuyapuncuman, —nispa. 
\p  
\v 33 Chanta yachacojcunan nerkancu: 
\p —Cay ch'innejpi cashanchej ¿imaynapitaj ashqha miqhunata tarisunman cay chhica runasta miqhuchinanchejpajrí? 
\p  
\v 34 Jesusri taporka: 
\p —¿Mashqha t'antastaj capusunquichej? 
\p Paycunataj cuticherkancu: 
\p —Kanchis t'antaslla pisi challwitaspiwan, —nispa. 
\p  
\v 35 Chanta Jesuska runasta camacherka pampaman tiyaycucunancuta.  
\v 36 Chay kanchis t'antasta maquisninpi jap'erka challwitastawan. Chaycunamantataj Diosman graciasta korka. Ajinaspa chay t'antasta challwitastawan partispa yachacojcunanman jaywallarkapuni. Paycunataj chay ashqha runasman jaywararkancu.  
\v 37 Tucuynincutaj miqhorkancu sajsacunancucama. Chaywanpis t'unasmanta puchuska kanchis jatun canastas junt'araj carka.  
\v 38 Miqhojcunaka tawa warankajina kharis carkancu. Warmispis wawaspis miqhullarkancutaj.  
\v 39 Ajinata Jesús miqhuchiytawan runasta cacharpayarka. Chaymantataj barcoman yaycuspa Magdala jallp'aman riporka. 
\c 16  
\s1 “Ruwapuwaycu uj jatun t'ucunata” 
\p  
\v 1 Chanta fariseo partemanta saduceo partemantawan cajcuna Jesusman kayllaycamorkancu. Paycunaka imaynallamantapis Jesusta pantachiyta munasharkancu. Chayraycu paymanta mañarkancu uj jatun ruwanata Dios cachamuskanta yachanancupaj.  
\v 2 Jesús cuticherka: 
\p —Kancunaka inti yaycupushajtin ninquichej: “K'ayaka sumaj p'unchay canka, phuyu puca pucata antawaramuskanraycu”.  
\v 3 Tutamantataj ninquichej: “Cunan p'unchayka parankachá yanata phuyumushan”, nispa. Kancunaka phuyusta khawarispa yachanquichej imayna p'unchaychus cananta. Diospa ajllaska Runanmanta ricuchinastarí mana yachanquichejchu reparayta.  
\v 4 Cay sajra ruwajcunawan Diosta wasanchajcunawanka t'ucunapaj uj ricuchinata mañashancu. Diospa willajnin Jonaspa ricuchinalla paycunapaj cashan manataj wajka, —nispa. 
\p Paycunata sakespataj riporka. 
\s1 “Khawacuychej caycunaj t'anta pokochinancumanta” 
\p  
\v 5 Yachacojcunanka barcopi kochaj ujnin chimpaman chayarkancu. Chaypiña paycunaka t'antata mana apacuskancuta yuyaricorkancu. 
\p  
\v 6 Jesusri paycunaman nerka: 
\p —Reparacuychej, sumajtataj khawacuychej fariseocunaj saduceocunaj t'anta pokochinancumanta, —nispa. 
\p  
\v 7 Yachacojcunataj paycuna uqhullapi tapunacusharkancu mana t'antata apacamuskancuraycu chayta parlaskanta. 
\p  
\v 8 Jesusri yuyashaskancuta reparaspa paycunaman nerka: 
\p —¿Imaraycutaj kancuna uqhullayquichejpi tapunacushanquichej t'antata mana apacamuskayquichejmanta? ¡Kancunaka ancha pisita Diospi jap'icunquichej! ¿Manarajchu reparanquichej?  
\v 9 ¿Nitajchu yuyarinquichej miqhuchiskayta phishka t'antasllamanta phishka waranka runasman? ¿Konkapunquichejchu mashqha canastasta chay puchojta junt'achiskayquichejta?  
\v 10 ¿Nitajchu yuyarinquichej kanchis t'antasmanta tawa waranka runasman miqhuchiskaymanta? ¿Mayc'a jatuchej canastasta junt'ataj puchorkarí?  
\v 11 Wakaychacuychej saduceowan fariseowan partecunaj t'anta pok'ochinancumanta nisuskayquichejta ¿imaraycutaj mana entienderkanquichejchu? Mana t'antamantachu parlarkayquichej, —nispa. 
\p  
\v 12 Chantaraj yachacojcunanka entienderkancu Jesuska mana t'anta pokochina levaduramantachu parlaskanta. Manachayrí fariesocunaj saduceocunaj llulla yachachinasnincuwan ama pantachiskas canancuta paycunaman parlaskanta entienderkancu. 
\s1 Pedro Jesusmanta yuyaskanta willan 
\p  
\v 13 Jesuska Filipo jallp'api Cesarea llajta chaynejman chayarka. Chaymantataj yachacojcunanta taporka: 
\p —Noka, Diospa cachaska Runanmanta parlaspa, runaska ¿pi caskaytataj nincurí? 
\p  
\v 14 Paycunataj cuticherkancu: 
\p —Waquin nincu bautizaj Juan causarimpuskanta. Waquintaj nincu Diospa unay willajnin Elías cutimuskanta. Waquinrí nincu Diospa unay willajnin Jeremías chayrí Diospa unay willajcunanmanta uj caskayquita, —nispa. 
\p  
\v 15 Paycunamantaj nerka: 
\p —Kancunari ¿pi caskaytataj ninquichej? —nispa. 
\p  
\v 16 Simón Pedrotaj nerka: 
\p —Kanka wiñay causaj Diospa ajllaska Wawan, Cristo canqui. 
\p  
\v 17 Jesustaj payman cuticherka: 
\p —Kan, Jonaspa wawan Simón, may cusiska canqui. Chekatapuni niskayquitaka mana runallachu sut'inchasorka. Manachayrí janaj pacha Dios Tatay caytaka sut'inchasorka.  
\v 18 Noka nillayquitaj kanka Pedro caskayquita. Chaytaj niyta munan rumi. Ujchaska ajllacuskasniytaj sinch'i rumi patapi wasichaskajina cancu. Uqhu pacha supay Satanás\f + \fr 16:18 \ft Literal: uqhu pacha puncusnin.\f* chayta manapuni atipankachu.  
\v 19 Llavesta koskayqui Dios camachin, chayman runas yaycunancupaj. Cay pachapi imatapis runas ruwanancuta ninqui chayka, janaj pachapipis niskallataj canka. Cay pachapi imatapis runas ama ruwanancuta ninqui chayka, janaj pachapipis ajina niskallataj canka, —nispa. 
\p  
\v 20 Chanta Jesuska yachacojcunanman camacherka amaraj pimanpis willanancuta pay Diospa ajllaskan Cristo caskantaka. 
\s1 Jesús wañuchiska cananmanta sut'inchan 
\p  
\v 21 Chaypachamantapacha Jesuska yachacojcunanman sut'ita willayta kallarerka: 
\p —Jerusalén llajtaman rinaypuni tiyan. Chaypitaj israel curajcuna, yupaychana-wasimanta curajcunawan israel yachachejcunapiwan anchata ñac'arichiwankancu. Paycunaka wañuchiwankancupis. Quinsa p'unchaymantataj causarimpunay tiyan. 
\p  
\v 22 Pedrotaj Jesusta wajnejman pusaspa payta c'amerka: 
\p —Señorníy, amapuni ajina cananpaj, Dios kanta qhuyasuchun. 
\p  
\v 23 Jesusrí Pedroman cutiricuspa nerka: 
\p —Anchuriy nokamanta. ¿Supay Satanásjina juchaman urmachiwaytachu munanqui? Kanka mana Diospa yuyaskanmanjinachu yuyashanqui manachayrí runaj yuyayninmanjinalla, —nispa. 
\p  
\v 24 Chanta Jesuska yachacojcunanman nerka: 
\p —Pichari yachacojniy cayta munajka paypa tucuy munayninta sakepunan tiyan. Chaywanpis nokaraycu pay quiquin muchunan tiyan wañunancama. Nokatataj casunawanpuni tiyan.  
\v 25 Chekatapuni pichari causayninta payllapaj wakaychacuyta munajka mana wiñay causayniyojchu canka. Picharí causayninta cay pachapi chincananta sakejka nokata casuskanraycu chayka, chekatapuni wiñay causayniyoj canka.  
\v 26 Reparaychej: Sichus uj runa tucuy cay pacha capuytapis jap'inman, wiñaypajtaj chincapunman chayka ¿ima allintaj paypaj canmanrí? Yachanchejjina runaka causayninta ranticuyta mana atinchu tucuy cay pacha capuywanpis astawan valorniyoj caskanraycu.  
\v 27 Imaraycuchus noka, Diospa cachaska Runan, cutimusaj Dios Tataypa atiyninwan cachamuska angelesninwan cusca. Chaypachataj sapa ujman ruwaskanmanjina kopusaj.  
\v 28 Niyquichej chekamanta noka camachinaypaj jamusaj. Waquin caypi cashajcunamantari mana wañuspa nokata jamushajta ricuwankancu, —nispa nerka Jesús. 
\c 17  
\s1 Jesús wajjina rijch'acuyniyojman tucupun 
\p  
\v 1 Sojta p'unchaymantataj Jesuska uj jatun orkoman llojserka. Chaymantaj payka pusaricorka Pedrota, Jacobota, wauken Juantawan paycunallata.  
\v 2 Jesuska paycuna ñaupakencupi wajjina rijch'acuyniyojman cutirparerka. Uyanka paycunaman intijina c'ancharerka. P'achanpis c'anchayjina yuraj yurajman cutirparerka.  
\v 3 Ujllata Moiseswan Eliaswan Jesusta parlanacushaj paycunaman riqhurimorkancu.  
\v 4 Ajinapi Pedro Jesusman nerka: 
\p —Señorníy, caypi cacunanchejka sumajmin. Munawaj chayka, caypi quinsa ch'ujllasta ruwasajcu. Ujta kanpaj, ujta Moisespaj, ujtataj Eliaspaj, —nispa. 
\p  
\v 5 Pedro parlashajtillanraj mana yuyaskamanta uj lliphipej phuyu paycunaman uraycamorka. Chay phuyumantataj Dios Tata parlamushajta uyarerkancu: 
\p —Caymin c'ata munaska Wawayka. Paymanta mayta cusicuni. Payta uyariychej, —nispa. 
\p  
\v 6 Yachacojcunanri chayta uyarispa pampacama c'umuycorkancu Jesusta yupaychanancupaj. Maytataj manchachicorkancu.  
\v 7 Chanta Jesús paycunaman kayllaycuspa allinnincupaj llanqharerka. Nerkataj: 
\p —Sayaricuychej. Amaña manchachicuychejchu, —nispa. 
\p  
\v 8 Paycunataj pataman khawarispa Jesusta sapallantaña ricorkancu. 
\p  
\v 9 Orkomanta uraycamushajtincu Jesuska paycunata camacherka: 
\p —Cay ricuskayquichejtaka ama willanquichejchu, noka, Diospa cachaska Runan, wañuymanta causarimunaycama. 
\p  
\v 10 Chanta yachacojcunan payta watorkancu: 
\p —Yachachejcunanchej nincu manaraj Cristo jamushajtin willaj Eliasraj ñaupajta jamunanta. ¿Imaraycutaj ajinata yachachincurí? 
\p  
\v 11 Paycunaman cutichispa Jesuska nerka: 
\p —Chekata yachachincu Elías ñaupajta jamunanta tucuy imata allinyachinanpaj.  
\v 12 Nokarí niyquichej Eliaska jamuskantaña. Runasri jamuskanta mana repararkancuchu. Astawanpis payta munaynincumanjina ñac'aricherkancu. Ajinallataj paycunaka noka, Diospa cachaska Runanta, munaynincumanjina ñac'arichiwankancu. 
\p  
\v 13 Chaymanta yachacojcunaka entienderkancu bautizaj Juanmanta chayta parlaskanta. 
\s1 Jesús uj t'ucu onkoyniyojta thañichin 
\p  
\v 14 Khepanta ashqha runaswan tincorkancu. Uj runataj Jesusman chimpaycuspa konkoricorka.  
\v 15 Nerkataj: 
\p —Señor, wawayta qhuyaripuway ari. Payka t'ucuwan onkoska, anchatataj ñac'arishan. Ashqha cutista ninamanpis yacumanpis urmaycun.  
\v 16 Yachacojcunayquiman payta pusamorkani. Paycunarí mana thañichiyta aterkancuchu. 
\p  
\v 17 Jesús cuticherka: 
\p —¡Ay, Diospi mana jap'icoj, nitaj payta casucoj runas! ¡Mayc'ajcamataj kancunawan casaj! ¡Mayc'ajcamataj kancunata muchuskayquichej! Wawata nokaman pusamuwaychej. 
\p  
\v 18 Jesustaj chay uj supayta c'amispa wawamanta kharkorka. Wawataj chaymantapacha thañicaporka. 
\p  
\v 19 Yachacojcunaka Jesús sapallan cashajtin payman kayllaycorkancu. Taporkancutaj: 
\p —¿Imaraycutaj chay supayta mana kharkoyta aterkaycuchurí? 
\p  
\v 20 Jesustaj paycunaman cuticherka: 
\p —Kancunaka Diospi ancha pisillata jap'icuskayquichejraycu kharkoyta mana aterkanquichejchu. Chekamanta niyquichej. Uj mostaza mujitujina pisillatapis Diospi jap'icuwajchej chayka, atiwajchej camachiyta cay orkota wajnejman okharicunanta. Orkotaj okhariconka. Diospi chekata jap'icojtiyquichejka tucuy aticonka kancunapaj.  
\v 21 Mana miqhuspa Diosmanta tucuy sonko mañacuyllawan chayjina supayka kharkocun. 
\s1 Jesús wañuchiska cananmanta ujtawan sut'inchan 
\p  
\v 22 Yachacojcunan cusca Galilea jallp'api cashajtincu Jesús paycunaman nerka: 
\p —Noka, Diospa cachaska Runan, paypa munayninmanjina chejnicoj runasman jaywaycuska casaj.  
\v 23 Paycunari wañuchiwankancu. Quinsa caj p'unchaypitaj causarimusaj, —nispa. 
\p Chayta uyarispa yachacojcunan mayta phuticorkancu. 
\p  
\v 24 Jesús yachacojcunanwan Capernaum llajtaman chayarkancu. Yupaychana-wasipaj kolke jap'ejcuna kayllaycamorkancu Pedrota tapoj: 
\p —¿Yachachisojniyquichejka yupaychana-wasipaj kolke konata koncharí? 
\p  
\v 25 Cuticherkataj: 
\p —Arí, kon, —nispa. 
\p Chanta Pedro wasiman yaycushajtin Jesuska ñaupajta nerka: 
\p —Simón, ¿imaynataj rijch'acusunqui? ¿Picunataj tasa kolketa chayrí impuestota cay pachapi camachejcunaman konancu canman? ¿Llajtancumanta cajcunachu? chayrí ¿waj llajtayojcunachu? 
\p  
\v 26 Pedrori cuticherka: 
\p —Waj llajtayojcuna, —nispa. 
\p Jesustaj payman nerka: 
\p —Ajinaka llajtayojcunaka mana konancuchu tiyan.  
\v 27 Astawanpis kolke jap'ejcunata ama phiñachinanchejpaj kolketa kosunchej. Kochaman challwata jap'ej riy. Anzuelota yacuman chokaycuy. Ñaupaj caj challwata jap'ispataj yacumanta orkhoy. Chay challwaj siminta quicharispa kolketa tarinqui. Chay kolketa apaspa nokamantawan kanmantawan kolke jap'ejcunaman komuy, —nispa nerka Jesús. 
\c 18  
\s1 ¿Pitaj aswan jatunpaj khawaska canka? 
\p  
\v 1 Ajinata parlashajtillancu yachacojcunaka Jesusman kayllaycuspa taporkancu: 
\p —¿Pitaj aswan curajpaj khawaska cashan Dios tucuyta camachin, chaypi? 
\p  
\v 2 Jesuska uj wawata wajyaspa chaupincupi sayaycucherka.  
\v 3 Nerkataj: 
\p —Chekatapuni niyquichej. Diosman cutirinayquichej tiyan cay wawajinaman tucuspa. Manachayrí Dios camachin, chayman manapuni yaycuyta atinquichejchu.  
\v 4 Chayraycu runaka cay wawajina llamp'u sonkoyojman tucunan tiyan. Ajina llamp'u sonkoyoj cajllata Dios astawan curajpaj khawan pay camachin, chaypi.  
\v 5 Nokapi jap'icuskanraycu cay wawajina llamp'u sonkoyojta “walejta jamunqui”, nejka nokatapis niwan. \fig |src="CN01733B.TIF" size="span" copy="© 1978 David C. Cook Publishing Co." ref="Mateo 18.5" \fig* 
\s1 Juchaman urmachejcunamanta 
\p  
\v 6 ‘Pichari nokapi jap'icojcunamanta pisipaj khawaska cajcunata juchaman urmachinman chayka ¡ay phutiy, ari, chay runapajka! Paypajka aswan allin canman wañupunan uj jatun molino rumiwan cuncanpi warqhuycuska. Chaymantataj runas jatun kochapi may uqhuman chincaycuchiska canan.  
\v 7 ¡Ay, phutiy ari, cay pacha runaspajka juchaman urmachej imas caskanraycu! Chayjina urmachej imaska cananpuni tiyan. Astawanpis ¡ay, jatun phutiy ari, juchaman urmachej runapajka! 
\p  
\v 8 ‘Maquiyquichus chayrí chaquiyquichus juchaman urmachisunquiman chayka, qhuchurpacuspa wijch'uy. Ñuc'upis chayrí ch'ulla chaquiyojpis wiñay causayniyoj canayqueka aswan allinpuni iscaynin maquisniyoj chayrí iscaynin chaquisniyoj uqhu pacha ninaman wiñaypaj wijch'uska canayquimantaka.  
\v 9 Ñawiyquitajchus juchaman urmachisunquiman chayka, orkhorpacuspa kanmanta wijch'uy. Ch'ulla ñawiyojpis wiñay causayniyoj canayqueka aswan allinpuni iscaynin ñawisniyoj uqhu pacha ninaman wijch'uska canayquimantaka. 
\s1 Chincaska ovejamanta uj quiquinchana 
\p  
\v 10 ‘Khawacushaychejpuni wawajina llamp'u sonkoyoj Diospi jap'icojcunata ama pisipaj khawanayquichejta. Chekamanta janaj pachapi Dios Tatayka tucuy [paycunata wakaychashanpuni.]\f + \fr 18:10 \ft Ninayan.\f* 
\v 11 Noka, Diospa cachaska Runanka, jamorkani Diosmanta chincaska runasta masc'aj juchasnincumanta cacharichinaypajtaj. 
\p  
\v 12 ‘¿Imaynataj rijch'asunquichej? Uj runa pachaj ovejasniyoj carka. Ujnin ovejantataj chincachicunman chayka, ¿manachu isk'on chunca isk'onniyojta waj runawan orkopi miqhushajta sakerparinman? Chanta chay chincaska ovejanta masc'amoj rinman.  
\v 13 Chincaska ovejanta taricaponka chayka, chekatapuni niyquichej mayta cusicunanta. Chay uj taricapuskanwan may astawanraj cusiconka chay isk'on chunca isk'onniyoj mana chincaska ovejasninmantaka.  
\v 14 Ajinallataj janaj pacha Dios Tatayquichej pisipaj khawaskacunamanta mana munanchu ni ujllapis wiñaypaj chincapunanta. 
\s1 Hermanoyquita perdonay 
\p  
\v 15 ‘Cristopi hermanoyqui juchallicuspa sonkoyquita nanachinman chayka, riy sapallanpi juchanmanta reparachimuy. Casusunquiman chayka, payta yanapanqui amaña Diosmanta chincapunanpaj.  
\v 16 Mana casucojtinrí riyraj ujta chayri iscaytapis pusaricuspa. Ajinapi iscay chayrí quinsa willajtincu tucuy chay imaska sut'ita yachaconka.  
\v 17 Chay runastapis nillataj casojtinrí Cristopi tantacojcunaman willay. Paycunatapis nillataj casunman chayka, kan payta khaway Diosta mana rejsej uj juchasapapaj.\f + \fr 18:17 \ft Literal: impuestota jap'ej.\f* 
\p  
\v 18 ‘Chekamanta imatachá cay pachapi khawaskayquichejmanjina yuyawajchej juchachanapajjina caskanta chayka, janaj pachapipis juchachaskallataj canka. Imatachá cay pachapi khawaskayquichejmanjina yuyawajchej mana juchachanapajjina caskanta chayka, janaj pachapipis manallataj juchachaskachu canka. 
\p  
\v 19 ‘Chekamanta niyquichej cay pachapi iscay kancunamanta ima jawallapis uj sonkolla yuyawajchej chayka, ruwaska cananta. Chay yuyaskayquichejtataj Diosmanta mañacuwajchej chayka, janaj pacha Dios Tatayka ruwapusonkachej.  
\v 20 Imaraycuchus maypichá iscay chayrí quinsa sutiypi tantacuncu chayka, noka paycunawan cusca cashani, —nispa nerka Jesús. 
\p  
\v 21 Chanta Pedroka Jesusman kayllaycuspa nerka: 
\p —Señorníy, hermanoy contraypi juchallejtenka ¿mayc'a cutitataj perdonasaj? ¿Kanchis cutitacamachu perdonasaj? 
\p  
\v 22 Jesustaj cuticherka: 
\p —Niyqui mana kanchis cuticamallachu perdonanayquita. Manachayrí ashqha cutista juchanta konkapuspa perdonanayquipuni tiyan.\f + \fr 18:22 \ft Literal: kanchis chunca kanchis cutita.\f* 
\s1 Mana perdonayta munaj camachimanta uj quiquinchana 
\p  
\v 23 ‘Dios camachejtin, uj jatun camachejman rijch'acun. Chay camachejka camachisninman manuskan kolketa jap'icapuyta munarka.  
\v 24 Ajinata payka jap'icapuyta kallarisharka. Waranka warankas kolketa manu runatataj paypa ñaupakenman pusamorkancu.  
\v 25 Chay camachirí mana capuskanraycu mana aterkachu kolkenta cutichipuyta. Chayraycu chay jatun camachej camacherka: “Chay manu runa vendeska canan tiyan warminwan wawasninpiwan tucuy capuskanwanpis. Chaywan manunmanta uj pisillatapis jap'isaj”, nispa.  
\v 26 Chanta chay manu camacheka jatun camachejman konkoricorka. Maytataj mañacorka: “Qhuyarillaway. Tucuy manuytaka cutichipullaskayqui”, nispa.  
\v 27 Jatun camachejka manu camachinta mayta qhuyaspa cacharpariporka. Manuntapis perdonaporka.  
\v 28 Llojsiytawancamarí chay camacheka uj camachi-masinwan tincorka. Chay camachi-masenka pisisitulla payman manu carka. Paytataj cuncanmanta sinch'ita jap'ispa k'allpirpanayasharka: “Uskhayta cutichipuway manususkayta”, nispa.  
\v 29 Chanta chay camachi-masenka mayta c'umuycucorka. Nicorkataj: “Qhuyarillaway. Tucuy manuytaka cutichipullaskayqui”, nispa.  
\v 30 Payrí manapuni munarkachu qhuyayta. Manachayrí manunta pusaspa carcelman wisk'aycucherka kopunancama.  
\v 31 Ajinata ruwaskanta ricuspataj camachi-masisninpa sonkon mayta nanarka. Paycunataj tucuy chay ruwaskanta jatun camachejnincuman willamorkancu.  
\v 32 Chanta jatun camachejka wajyachimuspa nerka: “¡Kanka sajra camachi canqui! Mayta nicuwajtiyqui tucuy jakay konawayquita perdonarkayqui qhuyasuspa.  
\v 33 Kanrí camachi-masiyquita ¿manachu qhuyanayqui carka noka kanta qhuyarkayqui ajinata?” nispa nerka.  
\v 34 Jatun camachejka phiñacuspa chay sajra camachinta muchuchejcunaman jaywaycorka. 
\p  
\v 35 ‘Sapa ujniyquichej tucuy sonkowan hermanoyquichejpa juchanta konkapuspa perdonanayquichej tiyan. Manachayrí janaj pacha Dios Tatayka chay sajra camachiwan imaynatachus camachejnin ruwarka ajinallatatajmin kancunawan ruwanka, —nispa nerka Jesús. 
\c 19  
\s1 Jesús yachachin divorciomanta 
\p  
\v 1 Chay imasta parlayta tucuspa Jesús Galilea jallp'amanta riporka. Chaymantataj Judea jallp'aman jamorka Jordán mayu chimpan inti llojsimuynejman.  
\v 2 Paytari may ashqha runas khatimorkancu. Chaypitaj paycunata onkoynincumanta thañicherka. 
\p  
\v 3 Chaypi cashajtin waquin fariseo partecuna Jesusman kayllaycorkancu pantachinancupaj. Nerkancutaj: 
\p —Camachiwaskanchejmanjina ¿uj runa warminta uj imaraycullapis wijch'upuyta atillanchu? 
\p  
\v 4 Jesustaj paycunaman cutichispa nerka: 
\p —Dioska cay pachata ruwaskanmantapacha kharita warmitawan ruwarka. Chayta Diospa palabranpi ¿manachu leerkanquichej?  
\v 5 Nerka: “Chayraycu khareka tatanta mamanta sakenan tiyan warminwan ujchaska cananpaj. Iscaynincutaj ujlla cancu”, nispa.  
\v 6 Ajinaka manaña iscaychu cancu manachayrí ujllamanña tucupuncu. Chayraycu Diospa ujchaskantaka runa ama t'akachunchu, —nispa. 
\p  
\v 7 Fariseo partecunaka payta nincu: 
\p —Moiseska camacherka pillapis warminwan t'akanacojka t'akanacuskancumanta uj divorcio papelta warminman konanta. ¿Imaraycutaj Moisés ajinata camacherkarí? 
\p  
\v 8 Jesustaj paycunaman cutichin: 
\p —Moiseska warmiyquichejmanta t'akacunayquichejta sakellarka mana casuyta munajcuna caskayquichejraycu. Astawanpis Dios runata ruwaskanmantapachaka mana ajinachu carka.  
\v 9 Nokarí niyquichej pillapis warmin mana khenchachacojtin waj warmiwan casaracunman chayka, khenchachacuskanta. T'akaska warmiwan casaracojpis khenchachacullantaj, —nispa. 
\p  
\v 10 Yachacojcunantaj payman nincu: 
\p —Khariwan warminwan ajinata causanan cajtenka mana casaracuylla allenka, —nispa. 
\p  
\v 11 Jesusri nin: 
\p —Mana tucuychu cay niskayta entiendeyta atincu. Manachayrí pichari Dios yanapan, paylla entiendeyta atin.  
\v 12 Waquin khareska nacecuncu mana wawayoj canancupaj. Waquintaj runas mana wawayoj canancupaj ajinaman tucuchincu. Waquinrí mana casaraska causayta ajllancu tucuy atiynincuwan Diosllapaj ruwanancuraycu. Ajinapi causaynincuta churancu Dios tucuyta camachinanpaj. Cay niskayta entiendeyta atejka chaymanjina causachun, —nispa nerka Jesús. 
\s1 Jesús wawaspaj mañapun Diosmanta 
\p  
\v 13 Chanta waquin runas wawitasta Jesusman pusamorkancu. Munarkancu pay maquisninta paycunaman churaspa Diosmanta mañaripunanta. Yachacojcunantaj pusamojcunata c'amerkancu.  
\v 14 Jesusrí nerka: 
\p —Sakeychej wawitasta nokaman jamunancuta. Amañataj paycunata jarc'aychejchu. Imaraycuchus Dios wawitajina cajcunata munacuywan camachin. 
\p  
\v 15 Maquisninta wawitasman churaspataj Diosmanta mañaporka. Chanta chaymanta riporka. 
\s1 Uj khapaj runa Jesusta tapun 
\p  
\v 16 Ajinamanta uj runa Jesusman kayllaycuspa tapurerka: 
\p —C'acha Yachachiwajníy ¿ima allin cajtataj ruwanay tiyan wiñay causayniyoj canaypaj? 
\p  
\v 17 Jesustaj payman cuticherka: 
\p —¿Imaraycutaj allin cajmanta tapuwanquirí? Dios sapallan c'acha cajka. Wiñay causayniyoj cayta munanqui chayka, Diospa camachiskasninta casuy, —nispa nerka. 
\p  
\v 18 Runataj tapun: 
\p —¿Maykencunatajrí? 
\p Jesusri cutichin: 
\p —Runata ama wañuchiychu. Ama khenchachacuychu. Ama suwacuychu. Runamanta ama willaychu llullacuspa.  
\v 19 Mamayquita tatayquita casuy, jatunpaj khaway. Runa-masiyquitapis munacuy kan quiquiyquitajina, —nispa. 
\p  
\v 20 Chay runaka payman cutichin: 
\p —Tucuy chaycunataka junt'ani. ¿Imatawanrajtaj ruwanay tiyanrí? 
\p  
\v 21 Jesustaj payman nin: 
\p —Wiñay causayniyoj canapajjina cayta munanqui chayka, rispa tucuy capuyniyquita vendemuy. Chaymantataj chay kolketa wajcha runasman jaywaramuy. Chaymanta khepata janaj pachapi khapaj capuyniyoj canqui. Chantaka nokawan jamuspa yachacojniy cay, —nispa nerka Jesús. 
\p  
\v 22 Chay runarí chay niskanta uyariytawan may phutiska riporka may khapaj caskanraycu iscayrayaspa. 
\p  
\v 23 Jesusri yachacojcunanman nin: 
\p —Chekamanta uj khapaj runaka ñac'aytapuni janaj pachaman\f + \fr 19:23 \ft Literal: Diospa reinon.\f* yaycuyta atin.  
\v 24 Chaywanpis niyquichej jatun camello uywaraj astawan atiskanta yaycuyta agujaj ningrinmanka khapaj runa janaj pachaman\f + \fr 19:24 \ft Literal: Diospa reinon.\f* yaycunanmantaka, —nispa. 
\p  
\v 25 Yachacojcunantaj chayta uyariytawan t'ucuspa ninacuncu: 
\p —Chanta ¿pitaj wiñay causayniyoj cayta atinmanrí? 
\p  
\v 26 Jesustaj paycunata khawaycuspa nin: 
\p —Runacunapaj cayka mana aticojchu. Diospajrí tucuy aticun. 
\p  
\v 27 Chaymanta Pedroka Jesusman cutichispa nin: 
\p —¡Khaway! Nokaycoka tucuy imata sakespa kanta khatiycu yachacojcunayqui canaycupaj. Chayraycu ¿imatataj jap'isajcurí? 
\p  
\v 28 Jesús paycunaman nin: 
\p —Noka, Diospa cachaska Runan, chekatapuni parlashayquichej. Tucuy imata mosojyachisaj. Chay p'unchaycunapitaj tiyaycucusaj camachinaypaj tucuy atiyniywan. Sapa ujniyquichejtaj uj camachina tiyanapi tiyacunquichej chunca israel ayllusta camachinapaj.  
\v 29 Pichari nokapi jap'icuskanraycu sakejka wasisninta, chayrí hermanosninta, chayrí hermanasninta, chayrí tatanta, chayrí mamanta, chayrí wawasninta, chayrí chajrasninta chayka, wiñay causayniyoj canka. Chaywanpis payka pachaj cutistawan nokaraycu sakeskanmanta jap'icaponka.  
\v 30 Astawanrí may ashqhas cunan jatunpaj khawaskas cajcuna khepata pisipaj khawaskas cankancu. Cunan pisipaj khawaskas cajcunataj khepata jatunpaj khawaskas cankancu. 
\c 20  
\s1 Llanc'ajcunamanta uj quiquinchana 
\p  
\v 1 ‘Dios tucuyta camachejtenka uj sumaj patronjinamin canka. Chay patronka tutamanta llojserka llanc'ajcunata minc'acamoj. Chaymantataj uvas huertanpi llanc'anancupaj camacherka.  
\v 2 Llanc'ajcunawantaj sumajta parlarka uj p'unchay llanc'askancumanta kopunanta. Chaymantataj paycunata huertanpi llanc'ajta cacharka.  
\v 3 Chaupi pakarinjina llojsispa waj llanc'ajcunatawan ricorka. Chay llanc'ajcunaka llanc'ayta masc'ajcunaj tantacunancu chaypi sayacusharkancu.  
\v 4 Patronka paycunata nerkataj: “Kancunapis huertaypi llanc'aychej. Nokataj cajmanjina jornalta pagaskayquichej”, nispa. Llanc'ajcunari rerkancu.  
\v 5 Watejmanta patronka llojsillarkataj chaupi p'unchaytajina. Quiquillantataj llanc'ajcunata pusamorka. Chaymantataj jatun tardetajina ajinata ruwarka.  
\v 6 Ujtawanpis masc'aj llojsillarkataj ch'isiyaytaña. Llanc'ayta masc'ajcunaj tantacunancu, chaypi wajcunatawan tarillarkataj. Paycunatapis nillarkataj: “¿Imaraycutaj tucuy cay p'unchayninta mana llanc'aspa sayacushanquichejrí?”  
\v 7 Paymantaj nerkancu: “Mana pipis minc'awaycuchu llanc'apunaycupaj”, nispa. Payri paycunaman nerka: “Kancunapis huertaypi llanc'aychej”, nispa.  
\v 8 Inti yaycuytataj patronka khawapoj runanman nerka: “Llanc'ajcunata wajyay kolketa paycunaman pagapunayquipaj. Khepa jamojcunaman ñaupajta koy. Chaymantataj ñaupaj jamojcunaman”, nispa.  
\v 9 Ch'isiyayllataña llanc'ajcuna tucuynin p'unchay llanc'askamantajina jap'erkancu.  
\v 10 Tucuy chay p'unchay llanc'ajcunarí yuyarkancu aswan ashqhata jap'inancuta. Astawanpis paycunaka ujcunajinallatataj jap'erkancu.  
\v 11 Chanta chay tucuy p'unchaynintinta llanc'ajcunaka patronpa contranpi thutorkancu  
\v 12 nispa: “Chay ch'isiyayllata jamojcunaka uj horallata llanc'arkancu. Nokaycumanrí paycunamanjinalla pagapuwarkaycoka. Tucuynin p'unchayta manchay ruphaypi muchuspa llanc'arkaycoka”, nispa.  
\v 13 Patrontaj ujnincuman cutichispa nerka: “Causaj-masíy, mana ch'auquiyashayquichu. ¿Manachu parlaskanchejmanjina pagapuyqui?  
\v 14 Pagota jap'iskayquiwan kanka ripuy. Noka munani cay khepa jamojcunaman kancunamanjinallataj koyta.  
\v 15 ¿Manachu atiyman capuyniywan munaskaymanjina ruwaytarí? Chayrí ¿c'acha runa caskaymantachu phiñaska khawashawanqui?”  
\v 16 Ajinatamin khepa cajcunaka ñaupaj cajpi cankancu. Ñaupajpi cajcunataj khepapi cajcuna cankancu. Chekamanta Dioska ashqhasta wajyan. Ajllaska cajcunarí pisislla cancu. 
\s1 Jesús watejmanta sut'inchan wañuchiska cananmanta 
\p  
\v 17 Jesuska Jerusalén llajtaman llojsisharka yachacojcunawan. Chay chunca iscayniyojllata ñanmanta wajnejman pusaspa nerka: 
\p  
\v 18 —Allinta reparaychej Jerusalén llajtaman rishaskanchejta. Chaypitaj noka, Diospa cachaska Runan, yupaychana-wasimanta curajcunaman yachachejcunamanwan jaywaycuska casaj. Paycunataj wañunaypaj juchachawankancu.  
\v 19 Waj llajtayoj runasman jaywaycullawankancutaj. Chanta chay runaska asipayawankancu jasut'iwankancu, chacataycuwankancupis. Nokataj quinsa caj p'unchaypi causarimpusaj. 
\s1 Uj warmi wawasninpaj Jesusmanta mañacun 
\p  
\v 20 Chanta Zebedeoj warmin wawasninwan Jesusman kayllaycorka. Konkoricuspataj nerka: 
\p —Uj imata niricuskayqui, —nispa. 
\p  
\v 21 Paytaj nerka: 
\p —¿Imatataj munanquiri? 
\p Paytaj cuticherka: 
\p —Atiyniyquiwan camachinayquipaj tiyaycuspa churapuway cay iscay wawasniyta, ujnin pañayquipi ujnintaj llok'eyquipi [sumajpaj khawaskas canancupaj.]\f + \fr 20:21 \ft Ninayan.\f* 
\p  
\v 22 Jesusrí cuticherka: 
\p —Kancunaka mana yachanquichejchu imatachus mañaskayquichejta. Manchayta ñac'anay tiyan. Chayka uj jayawan junt'aska copajina. ¿Ñac'ariy wañunaycama nokajina muchuyta atiwajchejchu? 
\p Paycunataj nerkancu: 
\p —Arí, atiycu. 
\p  
\v 23 Jesustaj paycunaman nerka: 
\p —Arí junt'a copata ujyanquichej nokajina. Wañuycama ñac'ariymantaj yaycunquichej nokajina. Nokawan cusca tiyaycucuspa camachinayquichejpajka ujta pañayman ujtataj llok'eyman churayka mana nokamantachu. Manachayrí picunapajchá waquicherka chaycunallata Dios tiyaycuchenka, —nispa. 
\p  
\v 24 Tucuy chayta uyariytawan chunca yachacojcunaka phiñacorkancu chay iscay waukecunapaj.  
\v 25 Jesusrí paycunata wajyaspa nerka: 
\p —Yachanquichejjina llajtasta camachejcunaka chaypi tiyacojcunata llaquichispa camachiskancuta. Llajtapi callpayojcunapis atiynincumanjina tucuy imapi casuchicuncu.  
\v 26 Kancunarí amapuni ajinaka caychejchu. Manachayrí kancuna uqhumanta atiyniyoj cayta munajka tucuy sonkowan yanapasojniyquichej canan tiyan.  
\v 27 Kancuna ughupi curajpaj khawaska cayta munajka casojniyquichej canan tiyan.  
\v 28 Noka, Diospa ajllaskanka, mana runas yanapanawancupajchu jamorkani. Manachayrí noka runasta yanapanaypaj jamorkani. Astawanpis paycunaj wañunancumanta noka wañusaj juchancumanta cacharichinaypaj. Ajinallataj kancunapis canayquichej tiyan. 
\s1 Jesús khawarichin iscay ciegosta 
\p  
\v 29 Jesús yachacojcunanwan Jericó llajtamanta llojsishajtin ashqha runas payta khatisharkancu. 
\p  
\v 30 Ñannejpi iscay ciego runas tiyacusharkancu. Jesús chaynejta puriskanta uyarispataj khaparerkancu: 
\p —¡Diospa ajllaskan,\f + \fr 20:30 \ft Literal: Davidpa Wawan.\f* nokaycuta qhuyacuwaycu! 
\p  
\v 31 Chay ashqha runastaj c'amerkancu: 
\p —Ch'in caychej, —nispa. 
\p Paycunarí aswan sinch'iwan khaparispa nerkancu: 
\p —¡Diospa ajllaskan, nokaycuta qhuyacuwaycu! —nispa. 
\p  
\v 32 Jesús sayaricuspa paycunata wajyarka. Nerkataj: 
\p —¿Imatataj kancunapaj ruwapunayta munashanquichej? 
\p  
\v 33 Paycuna cuticherkancu: 
\p —Señor, ricuyta munaycu. 
\p  
\v 34 Jesusri qhuyacuywan ñawisnincuta llanqharerka. Chay quiquinpacha ricorkancu Jesusta khaterkancutaj. 
\c 21  
\s1 Jesús Jerusalén llajtaman yaycun 
\p  
\v 1 Jesús yachacojcunanwan Jerusalén llajtaman kayllaspa Betfagé ranchoman chayarkancu. Betfageka Olivos niska orko kayllapi carka. Chanta Jesuska iscay yachacojcunata cachaspa,  
\v 2 nerka: 
\p —Riychej chimpa ranchoman. Chaypitaj uj china burrota malton burrowan wataskata tarinquichej. Phascaraspataj cayman khatimuychej.  
\v 3 Mayken tapusunquichejman chayka, niychej: “Señorninchej cay burrosta munan”, nispa. Cunitan cutichisonka. 
\p  
\v 4 Chayka ruwacorka Diospa niskan junt'acunanpaj. Paypa unay willajnin palabranpi nerka: 
\q1  
\v 5 Cay pachapi Diospa llajtan Sionpi tiyacojcunata niychej: 
\q1 “Khawaychej, Camachisojniyquichej jamushan. 
\q1 Payka llamp'u sonkoyoj, malton burropi llok'aska. 
\q1 Chay malton burroka chajnana uywaj uñan”. 
\p  
\v 6 Yachacojcunari rispa Jesuspa niskanmanjina ruwamorkancu.  
\v 7 China burrota malton burrotawan Jesusman khatimorkancu. Ponchosta caronaycorkancu. Jesustaj chay malton burroman llok'arka.  
\v 8 May ashqha runastaj paycunallamanta ponchosta Jesuspa ñanninpi mast'arkancu. Waquinri sach'a ramasta c'utumuspa ñanninpi mast'arkancu.  
\v 9 Chay ashqha runas waquenka Jesuspa ñaupakenta risharkancu, waquintaj khepanta. Khaparisharkancutaj: 
\p —¡Jatunchaska cachun Diospa ajllaskan!\f + \fr 21:9 \ft Literal: Hosanna Davidpa Wawanman.\f* ¡Yupaychaska cachun Diospa cachamuska Runanka! ¡May jatunchaska cachun janaj pachapi caj Dioska! —nispa. 
\p  
\v 10 Jesús Jerusalén llajtaman yaycojtin tucuy chay llajtapi tiyacoj runas mayta jataririspa mayta t'ucorkancu. Tapunacusharkancutaj: 
\p —Cay runa ¿pitaj canman? 
\p  
\v 11 Chay ashqha runasri cutichinacusharkancu: 
\p —Diospa willajnin Jesusmin. Payka Galilea jallp'amanta Nazaret llajtayoj, —nispa. 
\s1 “Waseyka Diosmanta mañacuna wasimin” 
\p  
\v 12 Chanta Jesuska yupaychana-wasinpa pationman yaycorka. Chaypi tucuy vendejcunata rantejcunatawan jawaman kharkorka. Kolke trocajcunaj mesasnincuta tejrararka. Jaywana paloma  
\v 13 vendejcunaj tiyanancutapis tejrarallarkataj. Paycunamantaj nerka: 
\p —Dios palabranpi nin: “Yupaychana-waseyka nokamanta mañacuna wasimin canan tiyan”. Kancunarí pacaymanta suwanayquichejpaj ruwaycacapunquichej, —nispa, Jesús nerka. 
\p  
\v 14 Yupaychana-wasipitaj ciegos, wist'us Jesusman kayllaycorkancu. Jesustaj paycunata thañicherka.  
\v 15 Jesuska chay onkoskasta thañichispaka uj t'ucuna imata ruwarka. Yupaychana-wasipipis wawaska mayta khaparisharkancu: “¡Diospa ajllaskan\f + \fr 21:15 \ft Literal: Davidpa Wawan.\f* jatunchaska cachun!” nispa. Chay imasta uyarispa yupaychana-wasimanta curajcunawan yachachejcunawanka mayta phiñacorkancu.  
\v 16 Jesusmantaj nerkancu: 
\p —¿Uyarinquichu cay wawacunaj nishaskancuta? 
\p Paytaj nerka: 
\p —Arí, kancunari ¿manachu jayc'ajpis Diospa palabranpi cayta leerkanquichej? Nin: 
\q1 Juch'uy wawitasta ñuñoj wawitastawan sumajta yupaychanancuta yuyaycharkanqui. 
\p  
\v 17 Chanta Jesús runasta sakepuspa llajta jawa Betaniaman riporka. Betaniaka Jerusalén kayllapimin. Chaypitaj chay tuta khepacorka. 
\s1 Jesús ch'aquichin uj higo sach'ata 
\p  
\v 18 Tutamanta llajtaman cutimushaspa Jesuska yarkhachicorka.  
\v 19 Ñan kayllapi uj higo sach'ata ricuspataj chimpaycorka. Manataj tarerkachu higostaka, manachayrí laphisllata. Paytaj nerka: 
\p —Ni jayc'ajpis pokoyniyqui cachunchu. 
\p Chaymanta higo sach'aka ch'aquerpariporka.  
\v 20 Yachacojcunanka chayta ricuspa t'ucorkancu. Tapucorkancutaj: 
\p —¿Imaynapitaj chaypachita cay higo sach'aka ch'aquirpariporka? 
\p  
\v 21 Jesuska cutichispa nerka: 
\p —Noka niyquichej chekatapuni mana iscayrayaspa Diospi jap'icuwajchej chayka, higo sach'awan ruwarkani ajinata ruwaytapis atinayquichejta, chaymanta astawanpis. Sichus cay orkota niwajchej: “Caymanta okhariska cay, jatun kochamantaj wijch'uycuska cay” chayka, wijch'uycuska canka.  
\v 22 Imallatapis tucuy sonkowan Diospi jap'icuspapuni mañacuwajchej chayka, chayta pay kosonkachej. 
\s1 “¿Pejpa atiyninwantaj cayta ruwanqui?” 
\p  
\v 23 Yupaychana-wasi patioman yaycuspa Jesús yachachisharka. Ajinapitaj yupaychana-wasimanta curajcunawan israel curajcunapiwan Jesusman kayllaycorkancu. Taporkancutaj: 
\p —¿Pejpa atiyninwantaj cay imasta ruwanqui? ¿Pitaj cay imasta ruwanayquipaj atiyta kosorka? 
\p  
\v 24 Jesustaj paycunaman cuticherka: 
\p —Kancuna uj tapuriynillayman cutichiwaychej. Chanta nokapis cutichiskayquichej ima atiywanchus chay imasta ruwashaskayta.  
\v 25 ¿Pitaj Juanta cachamorka runasta bautizananpaj? ¿Dioschu chayrí runaschu? 
\p Paycunapura unanchaspa ninacusharkancu: 
\p —Dios payta cachamuskanta nisunchej chayka, payka tapuwasunchej: “¿Imaraycutaj payta mana creerkanquichejchu?”  
\v 26 Runaspa atiynincuwan niytarí, manchachicunchej llajtantin phiñacunanta. Imaraycuchus tucuy paycunaka Juanta sumajpaj khawaspa Diospa willajninpaj jap'icuncu, —nispa. 
\p  
\v 27 Chaymantataj Jesusman cutichispa nerkancu: 
\p —Mana yachaycuchu, —nispa. 
\p Paytaj nerka: 
\p —Ni nokapis willaskayquichejchu ima atiywanchus tucuy chayta ruwaskayta. 
\s1 Iscay wawasmanta uj quiquinchana 
\p  
\v 28 Jesús paycunaman parlashaspa nerka: 
\p —¿Imaynataj rich'asunquichej? Uj runa iscay wawasniyoj carka. Curaj cajman kayllaycuspataj nerka: “Wawáy, cunan p'unchay uva huertaypi llanc'amuy”, nispa.  
\v 29 Chay wawanrí cuticherka: “Mana munanichu”, nispa. Khepamanta “mana” niskanmanta phuticorka. Chaymanta llanc'aj rerka.  
\v 30 Uj caj wawawanman tatan kayllaycuytawan quiquillantataj nerka. Chay wawantaj cuticherka: “Ya, tatáy, llanc'amusaj”, nispa. Payrí mana llanc'aj rerkachu.  
\v 31 Chay iscay wawasmanta ¿maykennincutaj tatancoj munayninta ruwarka? —taporka Jesús. 
\p Paycunari cuticherkancu: 
\p —Curaj caj wawan, —nispa. 
\p Jesustaj paycunaman nerka: 
\p —Chekamanta niyquichej manacajpaj khawaska impuesto jap'ejcunaraj khencha warmiswan Diospi jap'icuypi atipasuskayquichejta, pay camachin, chayman yaycunancupaj.  
\v 32 Imaraycuchus bautizaj Juanka willasorkachej chekanta ruwaspa causanayquichejta. Kancunataj payta mana casorkanquichejchu. Impuesto jap'ejcunawan khencha warmiswanrí payta casorkancu. Astawanpis kancunaka Diosman cutiriskancuta ricuspapis Juanta mana uyarerkanquichejchu casunayquichejpaj. 
\s1 Sajra llanc'ajcunamanta uj quiquinchana 
\p  
\v 33 ‘Cay waj quiquinchanayta uyariychej. Carka uj patron. Paytaj uvasta jallp'anpi plantarka. Chaycunatataj perkawan muyucherka. Chaypi uj uva sarunata ch'irwanata ruwacherka uj alto wasitawan khawanapaj. 
\p ‘Chaymantataj chay jallp'anta pokoshajta jap'inancupaj llanc'ajcunaman sakeycorka. Payri caruman riporka.  
\v 34 Uva pallana tiempo kayllamushajtintaj camachisninta llanc'ajcunaman cacharka uvasta jap'inancupaj.  
\v 35 Llanc'ajcunarí camachista jap'iycorkancu. Ajinapi ujninta sinch'ita makaycorkancu. Ujninta wañucherkancu. Ujnintataj rumiswan ch'ankaycorkancu.  
\v 36 Patronka ujtawan waj camachisninta cachallarkataj. Chay ñaupaj cachaskanmanta astawan ashqha camachista cacharkapis. Llanc'ajcunari quiquillantataj paycunata ruwaycorkancu. 
\p  
\v 37 ‘Patronka sonkonpi nerka: “Wawaytaka jatunpaj khawankancupuni”, nispa. Chayraycu tucuy chay khepantaka wawanta llanc'ajcunaman cacharka.  
\v 38 Llanc'ajcunari wawanta ricuytawan paycuna uqhu ninacorkancu: “Cay wawan jallp'ataka tatanmanta jap'enka. Chayraycu chay jap'inan jallp'ata jap'irparisun nokanchejpata cananpaj. Jamuychej payta wañuchinachej”, nispa.  
\v 39 Chaymantataj paycunaka wawanta jap'ispa jallp'a jawaman wijch'orkancu wañucherkancutaj. 
\p  
\v 40 Ajinata niytawan Jesuska paycunata tapurerka: 
\p —Uva jallp'ayoj Señor cutimuspa ¿imanankataj chay llanc'ajcunatarí? 
\p  
\v 41 Paycunataj cuticherkancu: 
\p —Chay sajra runastaka mana qhuyaspa wañurachenka. Jallp'antataj waj llanc'ajcunaman koponka. Uva pokojtincama jap'inanta tiemponpi llanc'ajcunaman chay jallp'anta konka, —nispa. 
\p  
\v 42 Jesusri paycunaman nerka: 
\p —¿Manachu jayc'ajpis Diospa palabranta leerkanquichej? Nin: “Wasichajcuna uj rumita khawaspa wijch'orkancu. Wasita sinch'ita sayachinanpaj chay wijch'uska rumeka aswan sumaj cashan tucuy waj rumismanta niskaka. Chaytaka Señor Dios ruwan, nokanchejpajtaj uj t'ucuna”. 
\p  
\v 43 ‘Chayraycu niyquichej Dios camachin, chayman kancuna Israel llajtayojcuna, mana yaycuyta atinayquichejta. Dios camachin, chayman paypa munayninta ruwajcunalla yayconkancu. Ajinapi waj llajta canka pay camachinanpaj.  
\v 44 Noka, Diospa cachaska Runan, wasi kallarina rumijinamin, cani. Ajinataj chay rumiman urmacoj runaka t'unaska canka. Pimanchari chay rumi urmanka payka ñut'uska canka. 
\p  
\v 45 Yupaychana-wasimanta curajcunawan fariseo partecunawan chay quiquinchanata uyarerkancu. Repararkancutaj paycunawan Jesús chay imasta rijch'anachiskanta.  
\v 46 Chayraycu imaynapipis payta jap'iycuchinancupaj mayta churacorkancu. Ashqha runastarí manchachicorkancu Jesusta Diospa willajninpaj khawaskancuraycu. 
\c 22  
\s1 Uj quiquinchana casamientomanta 
\p  
\v 1 Jesuska watejmanta quiquinchanaswan paycunaman parlarka. Nerka: 
\p  
\v 2 —Dios runasta munacuywan camachin, chayka uj jatun camachejman rijch'acun. Chay camachejka wawanpa casamientonta waquicherka.  
\v 3 Chay casamiento fiestaman wajyaskacunata pusarimoj cachasninta cacharka. Chay wajyaskasrí mana jamuyta munarkancuchu.  
\v 4 Ujtawanpis camachejka waj camachisninta cachallarkataj. Paycunata nerka: “Wajyaskacunaman nimuychej jamullachuncuña casamientoman. Wirayaska bueyesniy uywasniypis ñac'askasña cancu. Miqhuna waquichiskaña cashan. Tucuy ima casamientopaj waquichiskaña”, nispa.  
\v 5 Wajyaskacunarí payta khawarkancu manacajpaj. Waquenka chajrapi llanc'aj riporkancu. Waquinri rantej vendej riporkancu.  
\v 6 Ujcunataj camachisninta jap'ispa sinch'ita ñac'aricherkancu wañucherkancutaj.  
\v 7 Chayta uyariytawan jatun camachejka phiñacorka. Soldadosnintataj cacharka chay runasta wañurachimunancupaj llajtancutapis ninawan ruphaycuchinancupaj.  
\v 8 Chanta jatun camachejka cachasninman nerka: “Casamiento fiestaka waquichiska cashan. Wajyaskacunarí mana jamunancupajjinachu carkancu.  
\v 9 Chayraycu riychej llajta calles, ñancunamanpis. Tucuy tariskayquichej runasta casamientoman wajyamuychej”.  
\v 10 Ajinataj ñancunaman rispa tucuy tariskancuta tantamorkancu allin runasta mana allin runastawan. Casamiento wasiri wajyaskacunawan junt'a carka. 
\p  
\v 11 [‘Camachejtaj wajyaskacunanman sumaj p'achasta korka.]\f + \fr 22:11 \ft Ninayan.\f* Chanta wajyaskacunata khawarimunanpaj casamiento wasiman yaycorka. Chaypitaj mana casamiento p'achayojta uj runata ricorka.  
\v 12 Chay runatataj nerka: “Amigo ¿imaynapitaj cayman mana casamiento p'achawan p'achalliska yaycumorkanquirí?” nispa. Chay runari ni imatapis cutichiyta aterkachu.  
\v 13 Chanta camachejka casamientopi yanapajcunata nerka: “Chay runata chaquisninta maquisninta wataycuspa uqhu pacha lakhaman wijch'uychej. Chaypi phutiywan wakay, quiru c'arcucuypis muchunan canka”.  
\v 14 Imaraycuchus ashqhas wajyaskas cancu. Ajllaska cajcunarí pisis cancu, —nispa nerka Jesús. 
\s1 Impuestosta konamanta 
\p  
\v 15 Chaymanta fariseo partecunaka ripuskancutawan tantacamorkancu. Tantacuynincupitaj yuyarerkancu Jesusta parlaskanpi imaynapipis pantachiyta juchachanancupaj.  
\v 16 Ajinataj fariseoska yachacojcunancutawan Herodesmanta cajcunatawan Jesusman cacharkancu. Cachaskastaj Jesusta nerkancu: 
\p —Yachachej, yachaycu kanka cheka parlaj runa caskayquita. Yachaycutaj yachachiskayquita cheka cajta, Dios munan runas ruwanancutapis. Runata mana rijch'acuynillanmantachu khawanqui manachayrí caskancumanjina. Chayraycu paycunata mana manchachicunquichu.  
\v 17 Cunanri niwaycu: ¿Imaynataj rijch'acusunqui? Nokanchej israelcuna ¿Romano gobiernoman impuesto kolketa konachu manachu? 
\p  
\v 18 Jesusri sajra yuyaynincuta reparaspa paycunaman nerka: 
\p —Kancunaka ancha puraj uyas canquichej. ¿Imaraycutaj nokata pantachiwayta munanquichejrí?  
\v 19 Ricuchiwaychej impuesto kolketa, —nispa. 
\p Paycunataj kolketa jaywarkancu.  
\v 20 Jesustaj paycunata tapurerka: 
\p —Cay kolkepi ¿pejpa uyan pejpa sutintaj cashanrí? 
\p  
\v 21 Paycunataj cuticherkancu: 
\p —Romano curaj camachej Cesarpata, —nispa. 
\p Chaymanta Jesús paycunaman nerka: 
\p —Chayraycu Cesarpata cajtaka payman koychej. Diospata cajtataj Diosman koychej, —nispa. 
\p  
\v 22 Chay tapojcunaka chayta uyarispa mayta t'ucorkancu. Jesusta sakepuspataj riporkancu. 
\s1 Tapuncu causarimpuymanta 
\p  
\v 23 Chay p'unchaypi saduceocuna Jesusman kayllaycorkancu. Paycunaka nej cancu wañuskacuna mana causarimunancuta. Jesustataj tapuycunancupaj nerkancu: 
\p  
\v 24 —Yachachej, Moiseska nerka uj casaraska runa warminwan mana wawayoj wañupunman chayka, chay wañuskaj waukenka viudawan casaranan tiyan wañuskaj sutinpi khari wawa cananpaj.  
\v 25 Cay llajtaycupi kanchis waukes carkancu. Curaj caj waukeri casaraycucorka. Chaymantataj mana wawayoj wañuporka. Ajinapi viudaka wañojpa waukenwan casaracaporka.  
\v 26 Chay iscay caj waukeka wañupullarkataj. Quinsa caj waukewanpis ajinallataj carka. Kanchisnintin waukes casaracuspa wañuporkancu.  
\v 27 Khepanta chay viudapis wañupullarkataj.  
\v 28 Chanta wañuskacuna causarimojtincu chay kanchismanta ¿maykennincoj warmintaj cankarí? Tucuynin waukes chay warmiwanka casararkancu, —nispa. 
\p  
\v 29 Jesusri paycunaman cuticherka: 
\p —Kancunaka mana entiendenquichejchu Diospa palabranta nitaj rejsinquichejchu atiynintapis. Chayraycu ancha pantaskas canquichej.  
\v 30 Imaraycuchus causarimuskancu p'unchaypeka ni kharis nitaj warmis casaraconkancuchu. Manachayrí janaj pachapi angelesjina cancu.  
\v 31 Wañuskacuna causarimunancumantari ¿manachu Diospa niskanta leerkanquichej? Dioska kancunaman nerka:  
\v 32 “Noka cani Abrahampa Diosnin, wawan Isaacpa Diosnin, allchhin Jacobpatapis Diosnintaj”, nispa. Chay runas unay wañupuskancu khepataña Dios chayta nerka. Chayraycu Dioska mana wañuskacunaj Diosnincuchu. Manachayrí causashajcunaj Diosnincu, —nispa. 
\p  
\v 33 Ashqha runaska Jesuspa yachachiskanta uyarispa mayta t'ucorkancu. 
\s1 Curaj camachiskan 
\p  
\v 34 Fariseo partecunaka yachaspa saduceo partecuna Jesusman manaña cutichiyta atiskancuta, tantacorkancu.  
\v 35 Chanta paycunamanta uj yachachejtaj Jesusta parlaskanwan pantachinanpaj tapurerka: 
\p  
\v 36 —Yachachej, Diospa camachiskasninmanta ¿maykentaj aswan curajrí? 
\p  
\v 37 Jesusri cuticherka: 
\p —Señor Diosniyquita munacunayqui tiyan tucuy sonkowan tucuy causayniyquiwan tucuy yuyayniyquiwanpis.  
\v 38 Chaymin Diospa camachiskasninmanta aswan curajtaj ñaupajtajka.  
\v 39 Iscay caj camachiskanpis chay ñaupaj caj quiquillantaj: Runa-masiyquita munacuy kan quiquiyquitajina.  
\v 40 Chay iscaynin camachiskasta chekanta casuspaka Moisespa camachiskantapis unay willajcunaj kelkaskancutapis casunchej, —nispa. 
\s1 “¿Pitaj Cristorí?” 
\p  
\v 41 Fariseo partecuna tantaska cashajtincuraj Jesucristo paycunata  
\v 42 tapurerka: 
\p —Kancuna ¿ima ninquichejtaj noka, Diospa ajllaskanmanta? Unay jatun tatay ¿pi caskantataj ninquichejrí? 
\p Paycunataj cuticherkancu: 
\p Camachej Davidmin unay jatun tatayqueka, —nispa. 
\p  
\v 43 Chanta Jesús paycunaman nerka: 
\p —Camachej Davidka Santo Espirituwan sut'inchaspa ¿imaynapitaj payta Señor Diosníy nerkarí? Ajinata nerka: 
\p  
\v 44 Señorninchej Dios nerka Señorníy Cristoman: 
\q1 “Nokawan cusca tiyaycucuy camachinanchejpaj churanacojcunayquita k'alata atipanaycama”.\f + \fr 22:44 \ft Literal: chaquisniyqui urapi churanaycama.\f* 
\p  
\v 45 ‘Davidka Cristota Señorninta sutichan. Chayraycu ¿imaynatataj Cristoka Davidpa wawallan canmanrí? 
\p  
\v 46 Ni pi ni uj simita cutichiyta aterkachu. Chay p'unchaymantapacha tucuy runas Jesusta uj imata tapuriyta manchachicorkancu. 
\c 23  
\s1 Jesús fariseosta yachachejcunatawan juchachan 
\p  
\v 1 Chanta Jesuska ashqha runasman yachacojcunanmanwan nerka: 
\p  
\v 2 —Israel yachachejcunawan fariseo partecunawanka Moisespa camachiskasninmanjina yachachishaskancuta yuyancu.  
\v 3 Chayraycu Moisespa camachiskasninmanta tucuy nisuskayquichejta casuspa ruwaychej. Paycunaka simillancuwan camachiskasninmanjina ruwasunchej nincu causaynincupitaj wajjinata ruwancu. Kancunarí ama paycunajinaka caychejchu.  
\v 4 Paycunaka yachachinasnincuta llasa k'epistajina waj runaspaj waquichincu. Chaytataj camachincu runasta ruwanancuta k'epistajina k'epirichispa. Paycunarí chay camachiskasnincuta ni casojllapis churacuncuchu. Nitaj runaspa k'episnincuta uj dedowanjinallapis yanapaj churacuncuchu.  
\v 5 Paycuna tucuy imata ruwancu runasman ricuchinallancupaj. Diosta yupaychashaskancuta yuyaspa kelkaska churanasta apaycachacoj cancu. Chaycunatapis jatunyachincu. P'achasnincoj t'icasnintapis jatunyachincu.  
\v 6 Jatun miqhunaspi munancu aswan sumajpaj khawaskacunaj tiyanasnincupi tiyacuyta. Tantacuna-wasispipis curajcunaj tiyanasnincupi tiyacuyta mayta munancu.  
\v 7 Plazaspipis mayta munancu runaswan napaycuchicuyta. Runaswan jatunpaj khawaskas “yachachiwajníy”, nichicuytapis mayta munancu. 
\p  
\v 8 ‘Kancunarí ama jatunpaj khawaska “yachachiwajníy”, nichicuychejchu. Imaraycuchus nokalla, Diospa ajllaskan, Yachachejniyquichejka cani. Tucuy kancunataj Diospajka uj rejlla\f + \fr 23:8 \ft Literal: hermanos.\f* canquichej.  
\v 9 Cay pachapi ni maykenmanpis niychejchu “Tatáy” payta yupaychanayquichejpajka. Imaraycuchus ujllamin kancunaj Tatayquichejka. Payri janaj pachapi tiyacoj Diosmin.  
\v 10 Runaswan amataj “Camachiwajníy” nichicuychejchu. Imaraycuchus nokallamin, Diospa ajllaskan, Camachejniyquichej cani.  
\v 11 Kancuna uqhupi curaj cajka yanapajniyquichej canan tiyan.  
\v 12 Payllamanta jatunchacojka juch'uyyachiska canka. Llamp'u sonkoyoj cajrí jatunchaska canka. 
\p  
\v 13 ‘¡Uj phutiy, ari, kancuna yachachejcunamanta fariseo partecunamantawan! Puraj uyas canquichej. Kancunaka yachachiskasniyquichejwan jarc'ashanquichej runasta ama casunancupaj Diosta camachejnincujina. Imaraycuchus kancuna Diosta mana casunquichejchu. Nitaj casuyta munajcunata sakenquichejchu casunancuta munacoj camachejnincujinaka. 
\p  
\v 14 ‘¡Uj phutiy kancuna yachachejcunamanta fariseo partecunamantawan! Puraj uyas canquichej. Imaraycuchus kancunaka viuda warmicunamanta pisi capuynincuta suwaspajina khechushanquichej. Chayta pacanayquichejpaj Diosmanta anchata mañacunquichej. Chayraycu Dios kancunata astawan sinch'iwan juchachasonkachej. 
\p  
\v 15 ‘¡Uj phutiy kancuna yachachejcunamanta fariseo partecunamantawan! Kancunaka kochanejta jallp'anejtapis muyumushanquichej. Ajinapi uj runallatapis kancunajman tijrayta munanquichej. Tijraskayquichejwan chay runaka iscay cuti astawan juchachaskaraj canka kancunamanta niskaka. Chayraycu uqhu pachaman rinanpajjina chay runaka cashan. 
\p  
\v 16 ‘¡Uj phutiy kancunamanta! Kancunaka ciegos caspapis ujcunata pusaycachayta munanquichej. Diospa niskasninta mana reparaspa yachachishanquichej. Kancunaka ninquichej: “Pillapis yupaychana-wasej sutinta okharicuspa jurajka, niskanta mana junt'an, chaypis allillan. Yupaychana-wasipi korej sutinta okharicuspa jurajrí, niskanta junt'anan tiyan”, nispa.  
\v 17 ¡Kancuna mana yuyayniyojcuna ciegosjina canquichej! ¿Yupaychana-wasi cajtinchu koreka Diosman t'akaska? Chayrí ¿kori cajtinchu yupaychana-waseka Diosman t'akaska? ¿Maykentaj astawan cajrí?  
\v 18 Kancunaka nillanquichejtaj: “Jaywanata churanaj sutinta okharicuspa jurajka, niskanta mana junt'an, chaypis allillan. Chay jaywanaj sutinta okharicuspa jurajrí niskanta junt'ananpuni tiyan”, nispa.  
\v 19 ¡Kancuna mana yuyayniyoj ciegosjina canquichej! ¿Jaywanata churana cajka jaywana cajtinchu Diosman t'akaska? Chayrí ¿jaywanaka jaywanata churana cajtinchu Diosman t'akaska? ¿Maykentaj astawan cajrí?  
\v 20 Reparaychej. Jaywanata churanaj sutinta okharicuspa jurajka tucuy chaypi cajcunaj sutinpiwan juran. Manataj jaywanata churanaj sutillanpichu juran.  
\v 21 Reparaychej yupaychana-wasej sutinta okharicuspa jurajka chaypi tiyacoj Diospa sutinpi juraskanta. Manataj yupaychana-wasej sutillanpichu juran.  
\v 22 Chaywanpis janaj pachaj sutinta okharicuspa jurajka Diospa tiyacunanpa sutinpi juran. Mana chay tiyanaj sutillanpichu juran. Manachayrí Diospa sutinpi juran chaypi tiyacuskanraycu. 
\p  
\v 23 ‘¡Uj phutiy, arí, kancuna yachachejcunapajka fariseo partecunapajwan! Puraj uyas canquichej. Kancunaka yerba buenamanta, anismanta, cominomantapis ujta sapa chuncamanta Diosman koshanquichej. Diospa curaj caj camachiskasnintataj sakeporkanquichej. Chay curaj caj camachiskaska chekan ruway, qhuyacuy, Diospi jap'icuywan cancu. Caycunatamin ruwanayquichej tiyan ama chay ujcunata sakespa.  
\v 24 ¡Kancunaka ciegos caspa ujcunata pusaycachayta munanquichej! Ch'uspita orkhoshanquichej jatun uywa camellotataj okoycunquichej, [yachachinasniyquichejta Diospa camachiskasninmanta aswan curajpaj khawaspa.]\f + \fr 23:24 \ft Ninayan.\f* 
\p  
\v 25 ‘¡Uj phutiy, ari, kancuna yachachejcunamanta fariseo partecunamantawan! ¡Puraj uyas canquichej! Kancunaka vasota chuwatapis jawallanta mayllanquichej. Uqhuntarí sakenquichej mana llimphuchaspa. Ajinallataj chaycunaman rijch'acojlla canquichej. Sonkoyquichej suwaskayquichejwan khapaj cayta munapayaywan junt'a cashan.  
\v 26 ¡Ciegojina fariseo runa! Mana reparanquichu sonkoyqueka millay junt'a cashaskanta. Naupajta sonkoyquita llimphuchacuy. Ajinapi chekan ruwaj canqui. 
\p  
\v 27 ‘¡Uj phutiy, ari, kancuna yachachejcunamanta fariseo partecunamantawan! Puraj uyas canquichej. Aya p'ampanasta runas yurajyachincu ama pipis mana yuyayllamanta chimpananpaj. Chay c'achitu yurajyachiska p'ampanasman rijch'acunquichej. Imayna aya p'ampanas uqhuntaj wañuska runaspa tullusninwan junt'a cancu ajinalla sonkoyquichejka tucuy laya millay cajwan junt'a cancu.  
\v 28 Kancuna runaspa ñaupakellancupi chekan ruwaj runasman tucushanquichej. Kancuna quiquiyquichejrí puraj uyas Diospa niskanta mana casojtaj cashanquichej. 
\p  
\v 29 ‘¡Uj phutiy, ari, kancuna yachachejcunamanta fariseo partecunamantawan! Puraj uyas canquichej. Kancunaka unay wañuska willajcunata yuyarinapaj sepulturasta sayachishanquichej. Unay wañuska chekan ruwajcunapajpis sepulturasnincuta c'achachashanquichej.  
\v 30 Kancunaka nishanquichej ñaupaj tatasninchej willajcunata wañuchiskancuta. Jakay p'unchaycunapi causasunman carka chayka, nokanchej mana tatasninchejjinachu ruwasunman carka.  
\v 31 Chaywanka kancuna quiquiyquichej contrayquichejpi willacushanquichej willajcunata wañuchejcunaj wawasnin caskayquichejta.  
\v 32 ¡Tatasniyquichej ruwarka chaymanjina kancunapis tucunayquichejcama ruwanquichej! 
\p  
\v 33 ‘¡Kancunaka runa wañuchi catarisjina canquichej! ¡Ancha pantachej, catarisjina sajras canquichej! ¡Uqhu pacha lauraypipuni ñac'arinayquichej tiyan!  
\v 34 Chayraycu nokamanta willajcunayta Diosmanta yachayniyojcunatawan yachachejcunatawan cachamuskayquichej. Kancunarí cachamususkayquichejmanta waquinta wañurachinquichej chacatanquichejtaj. Wajcunatataj tantacuna-wasisniyquichejpi sek'onquichej. Chaywanpis paycunata ñac'arichinayquichejpaj llajtamanta llajta khatiycachanquichej.  
\v 35 Ajinapi juchachaskas canquichej tucuy mana juchancumanta wañuchiskas cajcunamanta Abelmanta Berequiaspa wawan Zacariascama. Payta kancunaj tatasniyquichej wañucherkancu yupaychana-wasipi jaywana churana\f + \fr 23:35 \ft Literal: altar.\f* kayllapi.  
\v 36 Niyquichej chekamanta tucuy chay wañuchiskacunamanta cunan p'unchay runas juchachaskas canancuta. 
\s1 Jesús wakan Jerusalenmanta 
\p  
\v 37 ‘¡Mayta phuticuni kancuna Jerusalénpi tiyacojcunamanta! Unaymantapacha Diospa willajcunanta wañuchejcuna canquichej, cachasninta ch'ankajcunapis. Imaynatachus wallpaka chillwisninta phurusnin uraman tantan, ajinallatataj nokapis ashqha cutista kancunata nokaman tantamuyta munarkayquichej. Kancunarí mana munarkanquichejchu.  
\v 38 Chekatapuni Dios kancunaj yupaychana-wasiyquichejta sakerparipun.  
\v 39 Chayraycu niyquichej cunanmantapacha manaña nokata ujtawan ricunayquichejta “Diosmanta cachaska jamojka jatunchaska cachun”, ninayquichejcama, —nispa nerka Jesús. 
\c 24  
\s1 Yupaychana-wasi urmachiska canka 
\p  
\v 1 Jesuska yupaychana-wasimanta llojsiytawan ripusharka. Yachacojcunari payman kayllaycorkancu yupaychana-wasita ricuchispa.  
\v 2 Paytaj paycunaman cutichispa nerka: 
\p —¿Tucuy cay sumachej rumismanta wasista ricushanquichejchu? Chekamanta caycunaka k'alata urmachiskas cankancu. Nitaj uj rumillapis waj rumiwan sayashaj sakeskachu canka. 
\s1 Cay pacha manaraj tucucojtin cay ricuchinas cankancu 
\p  
\v 3 Chanta Jesús Olivos orko patapi tiyaricuskantawan yachacojcunaka sapallancu payman kayllaycorkancu. Taporkancutaj: 
\p —Niwaycu ¿mayc'ajtaj tucuy chayka ruwaconkarí? ¿Ima ricuchinastaj canka cutimunayquimanta cay pachaj tucucunanmantawan? 
\p  
\v 4 Jesustaj paycunaman cuticherka: 
\p —Sumajta khawacuychej ama pantachiskas canayquichejpaj.  
\v 5 Arí, ashqhas llullacuspa sutiypi jamonkancu. Nenkancutaj: “Noka Diospa ajllaskan cani”, nispa. Ashqhasta pantarachenkancu.  
\v 6 Reparaychej: Guerrasmanta waj guerra canayashallaskanmantataj uyarinquichej. Guerrasmanta parlajta uyarispapis ama manchachicuychejchu. Chay imaska canancupuni tiyan. Astawanpis manaraj tucucuyrajchu canka.  
\v 7 Imaraycuchus uj ayllu waj aylloj contranpi okhariconka. Uj llajtayoj runas waj llajtayoj runaspa contranpi makanacunapaj okhariconkancu. Yarkhaycuna onkoycunapis canka. Jallp'apis caynejpi jakaynejpi qharcatitenka.  
\v 8 Tucuy chay imasri onkocoj warmej nanaynin kallarinajina sinch'i canka. Ajinata runas mayta ñac'arenkancu. 
\p  
\v 9 ‘Chaypachamin sinch'i llaquichiskas canayquichejpaj jaywaycusonkachej wañuchisonkachejtaj. Chaywanpis tucuy runas yachacojcunay caskayquichejraycu chejnicusonkachej.  
\v 10 Ajina cajtinmin ashqhas Diospa cheka ñanninmanta urmaponkancu. Waquenka paycunapura ch'atanaconkancu. Waquintaj paycunapura chejninaconkancu.  
\v 11 Ashqha llulla willajcuna riqhurimonkancu. Ashqhastataj pantachenkancu paycunapi creenancupaj.  
\v 12 Sajra causay junt'aycuskanraycutaj runas mana tucuy sonkowan munanaconkancuñachu.  
\v 13 Tucuy chay tucucunancama nokapi sinch'ita jap'icojrí juchamanta cachariska canka.  
\v 14 Dios caypi cashan camachinanpaj, cay sumaj willanasnenka tucuy cay pachapi willaraska canka tucuy runas yachanancupaj. Chanta tucucuyka jamonka. 
\p  
\v 15 ‘Diospa unay willajnin Danielka nerka Dios millachicun, chay thuñispa tucuchej cananta. Chayta leerkanquichej chayka, sumajta reparaychej. Imaraycuchus chay tucuchejta Diosman t'akaska cajpi cashajta ricunquichej.  
\v 16 Chaypacha Judea jallp'api cashajcuna orkosman aykecuychej.  
\v 17 Wasi jawapi\f + \fr 24:17 \ft Literal: patapi.\f* cashajpis ama imata orkhoricojllapis wasinman yaycuchunchu.  
\v 18 Chajrapi runaka wasiman p'achanta okharicoj ama cutichunchu.  
\v 19 ¡Phutiy ari, chay p'unchaycunapi wijsalliska warmispaj, ñuñushaj wawayojcunapajpis!  
\v 20 Kancunari Diosmanta mañacuychej ama para tiempopi aykecunayquichej cananpaj nitaj samacuna p'unchaypi.  
\v 21 Imaraycuchus chay p'unchaycunapi manchay ñac'ariy canka. Cay pachaj kallaricuyninmanta cunancama mana carkachu chayjina ñac'ariyka nitaj jayc'ajpis cankachu.  
\v 22 Chay ñac'ariy tiempota Dios mana pisiyachinman chayka, ni pi causanmanrajchu. Ajllaskasninraycurí Dioska chay ñac'ariy tiempota aswan pisiman pisiyachenka. 
\p  
\v 23 ‘Sitajchus nisunquichejman: ¡Khawaychej caypi Diospa ajllaskan Cristo cashan! chayrí ¡Khawaychej, jakaypi cashan! Chayta ama creeychejchu.  
\v 24 Imaraycuchus mana cheka caj cristo caspalla Cristojina riqhurimonkancu. Llulla willajcunapis riqhurimonkancu. Paycunaka sumachej ricuchinastawan sumachej t'ucunastawan ruwankancu. Aticunman chayka, chaywan Diospa quiquin ajllacuskasnintapis cheka cajmanta pantachinancupaj ruwankancu.  
\v 25 Manaraj chayta ruwacushajtin ñaupajtaña nerkayquichej.  
\v 26 Chayraycu nisunquichejman: “Khawaychej, jakay ch'innejpi Diospa ajllaskan cashan”, nispa chayka, ama chayman riychejchu. Chayrí nisunquichejman: “Diospa ajllaskan cay uqhupi pacaska cashan”, nispa chayka, chaytapis ama creeychejchu.  
\v 27 Allinta yachaychej: Lliujlliojka inti llojsimuynejmanta inti yaycuynejcama c'ancharejtin tucuy runas ricuncu. Ajinallatataj cutimojtiy tucuy runas ricuwankancu.  
\v 28 Maypichá aya cashan, chaymanmin alkamariska tantacuncu. 
\s1 Cristoj cutimuynin 
\p  
\v 29 ‘Chay ñac'ariskanmanta khepanta inteka lakhayaycaponka. Quillapis manaña c'anchamonkachu. Koyllurcunataj janaj pachamanta urmaramonkancu. Cielopi cajcunata Dios cuyuchenka: purichej callpapis pisiyaycaponka.  
\v 30 Chanta noka, Diospa cachaska Runan, jatun ricuchinayta janaj pachapi ricuchisaj. Chaypachatajmin cay pacha tucuy ayllusmanta runaska pechoncuta tacacuspa wakankancu. Ñokataj atiywan may lliphipej c'anchaywantaj jamusaj. Runastaj ajinata janaj pachamanta phuyu patapi cutimushajta ricuwankancu.  
\v 31 Nokataj may sinch'i wakaj pututusniyoj angelesniyta cachamusaj. Paycunataj ajllacuskasniyta tucuy cay pacha kayllamanta carumantapis tantayconkancu.  
\v 32 Cay higo sach'awan quiquinchanamanta yachacuychej. Higo sach'aj ramanka wawaramuspa laphisnin p'uturamun. Ajina cajtintaj yachanquichej k'oñi tiempoka chayamushaskantaña.  
\v 33 Ajinallataj kancunapis tucuy chay willarasuskayquichejta junt'askata ricuspaka yachaychej ñapis noka cutimushaskaytaña.  
\v 34 Niyquichej chekamanta tucuy chayka ruwacunanta manaraj cay p'unchay runas wañurapushajtincu.  
\v 35 Cielopis jallp'apis tucucaponkancu. Cay niskasniyrí mana tucucaponkachu. 
\p  
\v 36 ‘Ima p'unchaychus ima horachus cutimunayta, ni pi yachanchu. Manamin janaj pachamanta cachamuska angelespis yachancuchu nitaj noka, Diospa Wawanpis yachanichu. Dios Tatalla yachan.  
\v 37 Astawanrí imaynachus carka unay runa Noé causashajtin, ajinallataj canka noka, Diospa cachaska Runan, ujtawan riqhurimojtiy.  
\v 38 Unay sinch'i para p'unchaycuna manaraj chayamushajtincu runaska miqhunasta miqhusharkancu. Machasharkancu casaracusharkancutaj. Ajinata causasharkancu Noé jatun barcoman yaycunan p'unchaycama.  
\v 39 Chay runasrí mana reparacorkancuchu sinch'i para tucuy paycunata apacapunancama. Ajinallataj canka noka, Diospa cachaska Runan, cutimunaycama.  
\v 40 Chaypachaka iscay runas chajrapi cankancu. Ujnin caj nokaman pusaska canka ujninri sakeska canka.  
\v 41 Iscay warmis cusca maranpi cutashankancu. Ujnin nokaman pusaska canka. Ujninri sakeska canka. 
\p  
\v 42 ‘Kancunaka manamin yachanquichejchu ima p'unchaychus noka Señorniyquichej cutimunaytaka. Chayraycu waquichiskas caychej.  
\v 43 Sumajta reparaychej. Uj wasiyoj runa ima horatachus wasiman suwa jamunanta yachanman chayka, waquichicunman. Manataj sakenmanchu jusc'uspa wasiman yaycunantaka.  
\v 44 Ajinaka kancunapis waquichiskas caychej. Imaraycuchus ima horatachus mana suyanquichej cutimunayta, chay horata noka, Diospa cachaska Runan, cutimusaj. 
\s1 Quiquinchana sumaj camachimanta sajramantawan 
\p  
\v 45 ‘Parlani uj chekanta junt'aj sumaj yuyayniyoj camachimanta. Patronnenka payta churarka wasinpi camachisninman horasninpi miqhuchinanpaj.  
\v 46 May cusiska chay khawapojka patronnin cutimojtin payta taripan ruwananta ruwashajta.  
\v 47 Chekamanta patronnenka tucuy capuyninta khawapunanpaj chay camachita churanka.  
\v 48 Sajra camachirí sonkonpi ninman: “Patronniyka khepaconkaraj”, nispa.  
\v 49 Kallarintaj camachi-masisninta makaspa apaycachayta. Machajcunawantaj miqhoj ujyaj churacun.  
\v 50 Mana suyaskan p'unchayta, mana yuyaskan horata patronnenka cutimonka.  
\v 51 Camachintataj puraj uyacunawan cuscata sinch'ita nac'arichenka. Chaypitaj quiru c'arucuyta wakanka, —nispa nerka Jesús. 
\c 25  
\s1 Uj quiquinchana chunca sipascunamanta 
\p  
\v 1 ‘Ajinaka Dios wiñaypaj camachin, chaypi llanc'ajcunaka rijch'acuncu chunca sipascunaman. Paycunaka c'anchanasnincuta apaspa casaracoj runata suyaj rerkancu.  
\v 2 Phishka sipascunari yuyayniyoj caspa waquichicorkancu. Phishka sipascunataj mana yuyayniyoj carkancu.  
\v 3 Chay mana yuyayniyoj sipascunari c'anchasnincuta aparkancu, manataj kerosenta yapanancupaj aparkancuchu.  
\v 4 Yuyayniyoj sipascunarí c'anchasnincuta aparkancu. Kerosentataj uj churanapi aparkancu yapanancupaj.  
\v 5 Casaracoj runa runasninwan unayta khepacojtin puñuywan tucuynincu c'aywisharkancu puñurparerkancutaj.  
\v 6 Chaupi tutaña cashajtintaj uj sinch'i khapariy uyaricorka: “¡Casaracoj runa jamushanña! ¡Taripamuychej payta!”  
\v 7 Chanta tucuynin chay sipascuna rijch'arispa jataricorkancu. Chaymantataj c'anchanasnincuta waquicherkancu.  
\v 8 Mana yuyayniyojcunarí nerkancu yuyayniyoj sipascunata: “Kerosenniyquichejmanta koriwaycu. C'anchanasniycu wañupushancuña”, nispa.  
\v 9 Yuyayniyoj sipascunataj cuticherkancu: “Mana. Kosuyquichejman chayka, kancunapajpis nokaycupajpis pisinman. Astawanpis riychej vendejcunajman rantinayquichejpaj”, nispa.  
\v 10 Paycuna rantej rinancucamataj casaracojka runasninwan jamorka. Waquichiska cajcunataj casaracoj runawan runasninwan ima casamiento wasiman yaycorkancu. Chaymantataj puncu wisk'acaporka.  
\v 11 Khepamanta chay waj sipascuna chayamorkancu. Nerkancutaj: “¡Señorníy, Tatáy, puncuta qhicharimuwaycu!” nispa.  
\v 12 Casaracoj runataj cuticherka: “Niyquichej chekamanta mana rejsiyquichejchu”. 
\p  
\v 13 Jesuska runasman nerka: 
\p —Chayraycu kancunapis rijch'ariskas suyaychej. Imaraycuchus mana yachanquichejchu noka, Diospa cachaska Runan, mayc'ajchus cutimunayta. Ima p'unchaychus ima horachus cutimunayta mana yachanquichejchu. 
\s1 Uj quiquinchana patronpa jaywaskan kolkemanta 
\p  
\v 14 ‘Chaywanpis nokaj camachinaypaj cutimunayka rijch'acun uj caruman rej patronman. Chay patronka ripushaspa camachisninta wajyarka. Chaymantataj capuyninta paycunaman jaywaycorka.  
\v 15 Uj camachinman korka phishka warankajina kolketa. Ujmantaj korka iscay warankajina kolketa. Uj cajmantaj korka uj warankajina kolketa. Sapa ujman korka ruwayta atiskancumanjina. Chaymantataj caruman rerka.  
\v 16 Chanta chay phishka warankajina kolketa jap'ejka rerka. Ajinaspataj chay kolketa sumajta purichimorka. Uj phishkatawantaj mirachimorka.  
\v 17 Ajinallataj chay iscay warankatajina kolketa jap'ejpis uj iscaytawan mirachimorka.  
\v 18 Uj warankatajina kolketa jap'ejrí rerka. Ajinaspataj patronninpa kolkenta jallp'aman p'ampaskata pacaycamorka. 
\p  
\v 19 ‘Chay camachicunaj patronnincoka ashqha watasmanta cutimorka. Chaymantataj patronka kolkemanta yachananpaj paycunawan parlarka.  
\v 20 Payman chay phishka warankajina kolketa jap'ejka jamorka. Payri uj phishka waranka kolketawan apamorka. Patronninmantaj nerka: “Señor, phishka warankajina kolketa kowarkanqui. Khawaymá, uj phishkatawan mirachimuni”.  
\v 21 Patronnintaj payta nerka: “Walejpacha, c'acha, junt'aj camachíy. Chay pisi kolkepi sumajta junt'arkanqui. Cunantaj ashqhamanwanraj ruwapunawayquipaj churaskayqui. Chaywanpis nokawan cusca cusicunayquipaj jampuway”, nispa.  
\v 22 Chanta chay iscay warankajina kolketa jap'ejpis kayllaycamuspa nillarkataj: “Señor, iscay warankajina kolketa kowarkanqui. Khawaymá, uj iscay warankatawan mirachimorkani”.  
\v 23 Patronnintaj nerka: “Walejta ruwarkanqui, c'acha, junt'aj camachíy. Chay pisi kolkepi sumajta junt'arkanqui. Cunantaj ashqhamanwanraj ruwapunawayquipaj churaskayqui. Chaywanpis nokawan cusca cusicunayquipaj jampuway”, nispa.  
\v 24 Uj warankajina kolketa jap'ejpis kayllaycamuspa nerka: “Patronníy, rejsiyqui kanka ancha rumi sonko runa caskayquita. Mana tarpuskayquimanta cosechanquipis. Mana kanpata cajtapis jap'inqui.  
\v 25 Chayraycu manchachicorkani. Kolkeyquitataj riytawan sumajta jallp'aman p'ampaskata wakaycharkani. Cayka kolkeyqueka. Jap'icapuy”.  
\v 26 Patronnintaj payman cuticherka: “Khella, sajra camachi. Yacharkanqui mana tarpuskaymanta cosechaj caskayta, mana nokajta cajtapis jap'ej caskayta.  
\v 27 Yachashaspa ¿imaraycutaj kolkeyta mirachejcunaman mana korkanquichu? Cutimuspa miraynintawan kolkeyta jap'icapuyman carka”, nispa.  
\v 28 Chayraycu chaypi cajcunaman nerka: “Cay runamanta kolketa khechuychej. Chay chunca warankajina kolkeyojman kopuychej”, nerka patron.  
\v 29 Imaraycuchus Diospa niskanta jap'icojmanka astawan koska canka. Manataj pisenkachu jayc'ajpis. Mana jap'icojmantarí pisi jap'icuskanpis khechuska canka.  
\v 30 Cay manacaj camachitari jawa lakhaman wijch'umuychej. Chaypi wakaytawan quiru c'arucuytawan ñac'arenka, —nispa nerka Jesús. 
\s1 Tucuy caj runaman Cristo konka ruwaskancumanjina 
\p  
\v 31 Nillarkataj: 
\p —Noka, Diospa cachaska Runanka, atiyniywan cutimusaj tucuy angelesta pusaspa. Chaypacha tiyaycusaj camachinaypaj tucuy atiyniywan.  
\v 32 Tucuy llajtasmanta runastaj ñaupakeypi tantaskas cankancu. Uj michejka ovejasta cabrasmanta t'akan. Ajinallatataj nokapis chekanta ruwaj runasta sajrata ruwaj runasmanta t'akasaj.  
\v 33 Chekanta ruwajcunata pañayman churasaj. Sajrata ruwajcunata llok'eyman churasaj.  
\v 34 Chanta noka, Camachej, pañaypi cajcunata nisaj: “Jampuwaychej, Dios Tataypa sumajpaj khawaskasnin. Cay pacha ruwacuymantapacha nokawan cusca kancuna camachinayquichejpaj waquichiska carka. Chayraycu cunan nokawan cusca camachiychej.  
\v 35 Imaraycuchus yarkhachicojtiy miqhuchiwarkanquichej. Ch'aquichicushajtiy ujyanata kowarkanquichej. Forastero purishajtiypis wajyariwarkanquichej.  
\v 36 P'achamanta pisichicojtiy p'achata kowarkanquichej. Onkoska cashajtiy watucuwarkanquichej. Carcelpi wisk'aska cashajtiy watucoj jamuwarkanquichej”.  
\v 37 Chanta chekata ruwaj runaska cutichiwankancu: “Camachiwajníy, ¿mayc'ajtaj yarkhachicojta ricususpa miqhucherkaycurí? Chayrí ch'aquichicushajtiyqui ¿mayc'ajtaj ujyacherkaycurí?  
\v 38 Forastero purishajta ricususpa ¿mayc'ajtaj wajyarerkaycurí? Chayrí p'achamanta pisichicojta ricususpa ¿mayc'ajtaj p'achallicherkaycurí?  
\v 39 Onkoskata ricucuspa chayrí carcelpi wisk'aska cashajtiyquipis ¿mayc'ajtaj watucoj jamorkaycurí?” nispa.  
\v 40 Noka, Camachejnincutaj, paycunaman cutichisaj: “Chekamanta cay uj pisipaj khawaska hermanoypaj imallatapis ruwaporkanquichej chayka, nokapaj ruwapuwarkanquichej”. 
\p  
\v 41 ‘Noka, Camachejnincoka, chanta nillasajtaj llok'eypi cajcunata: “Kancuna juchachaska cajcuna riychej caymanta. Supay Satanaspaj cachasninpajwan uqhu pachapi wiñaypaj lauraj nina waquichiska cashan. Chayman kancunaka riychej.  
\v 42 Imaraycuchus yarkhachicojtiy miqhunata mana kowarkanquichejchu. Ch'aquiska cashajtiy yacuta mana jaywariwarkanquichejchu.  
\v 43 Forasterojina purishajtiy mana wajyariwarkanquichejchu. P'achamanta pisichicojta ricuwaspa mana p'achallichiwarkanquichejchu. Onkoska cashajtiy, carcelpi wisk'aska cashajtiypis mana watucuwarkanquichejchu”.  
\v 44 Chanta paycunaka cuticherkancu: “Camachiwajníy, ¿mayc'ajtaj yarkhachicojta ricususpa chayrí ch'aquiskata chayrí forastero purishajta, chayrí p'achamanta pisichicojta chayrí onkoskata chayrí carcelpi wisk'askata ricususpapis mana yanaparerkaycuchu?”  
\v 45 Chanta noka, Camachejnincoka, paycunaman cutichisaj: “Pisipaj khawaska cajpaj imallatapis mana ruwaporkanquichejchu chayka, chekamanta nokapajpis mana ruwapuwarkanquichejchu”.  
\v 46 Chayraycu kancunaka wiñay ñac'ariyman riychej. Chekanta ruwaj runasrí wiñay causayniyoj nokawan cankancu. 
\c 26  
\s1 Yuyaychacorkancu Jesusta jap'iycuchiyta wañuchinancupaj 
\p  
\v 1 Jesuska tucuy chay parlayta tucuytawan yachacojcunanman nerka: 
\p  
\v 2 —Yachanquichejjina iscay p'unchaycunamantawanka pascua p'unchaycuna canka. Noka, Diospa cachaska Runantaj, chay p'unchaycunata chacataska canaypaj jaywaycuska casaj, —nispa. 
\p  
\v 3 Chaymantapachataj israel curajcuna\f + \fr 26:3 \ft Literal: yupaychana-wasimanta curajcuna israel curajcunawan.\f* tantacorkancu Caifás sutiyoj curaj camachejpa pationpi.  
\v 4 Paycunataj yuyaychacorkancu llullacuspa Jesusta jap'iycuchiyta, chanta payta wañuchichiyta.  
\v 5 Paycunarí ninacusharkancu: 
\p —Ama jatun p'unchaycunapeka, runas ama ch'ajwanancupaj, —nispa. 
\s1 Uj warmi sumaj k'apajta Jesusman jich'aycun 
\p  
\v 6 Jesuska lepra onkoyniyoj niska Simonpa wasinpi casharka. Chay wasiri Betania llajtapi carka.  
\v 7 Uj warmitaj Jesusman kayllaycorka. Payka nardomanta may c'achitu k'apayniyoj aceitejinata uj c'achitu rumi\f + \fr 26:7 \ft Literal: alabastro.\f* yuritupi junt'ata apamorka. Chay k'apajri ashqha kolkewan rantiska carka. Jesús mesapi tiyacushajtintaj chay warmeka chay c'achitu k'apajta umanman jich'aycuspa jawiycorka.  
\v 8 Yachacojcunaka chayta ricuytawan mayta phiñacorkancu. Taporkancutaj: 
\p —¿Imapajtaj cayjina usuchiska cashanrí?  
\v 9 Cay c'achitu k'apajka ashqha kolkepaj vendecunman carka. Chay kolketaj wajcha runasman koska canman carka, —nispa. 
\p  
\v 10 Jesuska sumajta reparaspa niskancumanta paycunata nerka: 
\p —¿Imaraycutaj cay warmita llaquichishanquichej? Chayta ruwaspaka sumaj cajta nokapaj ruwapuwarka.  
\v 11 Arí, wajcha runaska yanapanayquichejpaj cancupuni. Nokarí mana unaytañachu kancunawan casaj.  
\v 12 Cay warmiri chay c'achitu k'apajwan cuerpoyman jich'aycuwaspaka khepata p'ampacuyniypaj ruwarka.  
\v 13 Niyquichej chekamanta cay sumaj willanaska nokamanta tucuynej cay pachantinpi willarananta. Chay tucuynejpi cay warmej ruwaskanka willaska canka paymanta yuyaricunapaj, —nispa nerka Jesús. 
\s1 Judas Jesusta jaywaycun 
\p  
\v 14 Chanta chunca iscayniyoj yachacojcunamanta ujnin caj rerka yupaychana-wasipi curajcunaman. Payri Judas Iscariote niska carka.  
\v 15 Paycunaman nerkataj: 
\p —Noka Jesusta jaywaycuyquichejman chayka, ¿mashqha kolketataj kowanquichejman? 
\p Paycuna nerkancu: 
\p —Quinsa chunca kolkesta kosajcu, —nispa. Chaytataj payman korkancu.  
\v 16 Judaska chaypacha mantapacha masc'asharka imaynapichus aswan allin canman Jesusta jaywaycunanta. 
\s1 Pascua miqhuna 
\p  
\v 17 Israel runaska jatun p'unchaycunancupi t'antata mana pokochinayojta miqhoj cancu. [Ajinata yuyarej cancu imaynata Dios paycunata enemigosnincumanta cacharichiskanta.]\f + \fr 26:17 \ft Ninayan.\f* Ñaupaj caj p'unchaypitaj yachacojcunanka Jesusman kayllaycorkancu. Taporkancutaj: 
\p —¿Maypitaj waquichipusajcu yuyarina miqhunata miqhunayquipaj? 
\p  
\v 18 Jesustaj nerka: 
\p —Llajtaman riychej. Chaypitaj uj runaman niychej: “Yachachiwajninchej nisunqui: Wañunay p'unchay kayllamushanña. Wasiyquipi yuyarina miqhunata yachacojcunaywan miqhuyta munani”. 
\p  
\v 19 Yachacojcunantaj Jesuspa niskanmanjina ruwarkancu. Ajinataj yuyarina miqhunata miqhunancupaj waquicherkancu. 
\p  
\v 20 Jesuska ch'isiyaycojtinña chunca iscayniyojcunanwan miqhunancupaj tiyaycucorka.  
\v 21 Miqhushaspataj yachacojcunanta nerka: 
\p —Niyquichej chekamanta ujniyquichej kancunamanta nokata chejniwaj runasman jaywaycuwananta, —nispa. 
\p  
\v 22 Yachacojcunantaj ancha llaquiskas ujmanta uj payta taporkancu: 
\p —Señorníy ¿nokachu cayman? 
\p  
\v 23 Paytaj cutichispa nerka: 
\p —Nokawan cusca t'antata chuwaman chhapun, chaymin nokata chejnicojcunaman jaywaycuwanka.  
\v 24 Noka, Diospa cachaska Runanka wañoj rishani paypa palabranpi nokamanta niskanmanjina. ¡May phutiy, ari, nokata jaywaycojpajka! Aswan allin canman carka chay runapajka mana nacecunan. 
\p  
\v 25 Jaywaycoj risharka chay Judaska cuticherka: 
\p —Yachachiwajníy, ¿nokachu cayman? 
\p Jesustaj nerka: 
\p —Arí, kan ninqui, ajinapuni, —nispa. 
\p  
\v 26 Miqhushajtincu Jesuska t'antata maquisninwan jap'erka. Chaymantataj Diosman graciasta korka. T'antata partispataj yachacojcunaman jaywarka. Nerkataj: 
\p —Cayta jap'iychej miqhuychejtaj. Cayka cuerpoy ninacun, —nispa. 
\p  
\v 27 Chanta copata jap'ispa Diosman graciasta korka. Ajinaspataj yachacojcunaman jaywaspa nerka: 
\p —Tucuyniyquichej cay copamanta ujyaychej. \fig |src="cn01804B.tif" size="col" copy="© 1978 David C. Cook Publishing Co." ref="Mateo 26.27" \fig* 
\v 28 Cay ujyanaka yawarniy ninacun. Jich'aska canka Diospa mosoj traton atiyniyoj cananpaj. Chayraycu causayniyta churani ashqha runaspa juchasnincuta wiñaypaj khechunaypaj.  
\v 29 Chekamanta cay uvasmanta ruwaskata manaña ujyasajñachu kancunawan uj p'unchaycama. Chaypacha ujtawan mosojta ujyasaj kancunawan cusca Dios Tatay camachin, chayllapiña, —nispa. 
\s1 Jesús willan Pedro quinsa cutita negananta 
\p  
\v 30 Diosta yupaychanapaj taquiytawantaj Olivos orkoman riporkancu. 
\p  
\v 31 Chanta Jesuska yachacojcunanta nerka: 
\p —Cunan tuta tucuyniyquichej nokata sakerpayawanquichej. Imaraycuchus Diospa palabranpi nin: “Michejta wañuchisaj. Ovejastaj tropamanta ch'erkeraskas cankancu”.  
\v 32 Wañuymanta causarimusparí Galileaman ñaupakeyquichejta risaj. 
\p  
\v 33 Pedrotaj Jesusman cuticherka: 
\p —Tucuynincu kanta sakerpayancuman chayka, nokaka manapuni jayc'ajpis sakerpayaskayquichu, —nispa. 
\p  
\v 34 Jesuska payman nerka: 
\p —Niyqui chekamanta cunan tutapacha manaraj gallo wakashajtin nokata mana rejsiwaskayquita quinsa cutita ninqui. 
\p  
\v 35 Pedrotaj nerka: 
\p —Kanwan cusca wañunay cajtinpis manapuni nisajchu kanta mana rejsisuskaytaka, —nispa. 
\p Tucuynin yachacojcunapis quiquinta nerkancu. 
\s1 Jesús Diosmanta mañacun Getsemanipi 
\p  
\v 36 Chaymanta Jesuska paycunawan Getsemaní huertaman chayamorka. Yachacojcunamantaj nerka: 
\p —Caypi tiyaricuychej noka jakaynejman rispa Diosmanta mañacamunaycama, —nispa. 
\p  
\v 37 Chaymanta Pedrotawan Jacobotawan Juantawanpis pusaricuspataj sinch'ita llaquicaporka maytataj phuticuyta kallarerka.  
\v 38 Chanta paycunaman nerka: 
\p —Manchay llaquiska cani, llaquiywantaj wañunayashaniña. Caypi suyaychej. Nokawan cusca rijch'ariskastaj wakaychacuychej. 
\p  
\v 39 Uj tumpatawan ñaupaspa uyan pampacama c'umuycorka. Diosmanta mañacuspataj nerka: 
\p —Munaska Tatáy, cay ñac'ariypi wañunayka sichus aticun chayka, ama cachunchu. Astawanpis cayka mana nokaj munayniychu cachun. Manachayrí kanpa munayniyqui ruwaska cachun, —nispa. 
\p  
\v 40 Quinsa yachacojcunan casharkancu, chayman cutimuspataj Jesuska paycunata puñushajta tariparka. Chaymanta Pedrota nerka: 
\p —Ajinaka ¿manachu uj ratullatapis nokawan cusca rijch'ariska wakaychacuyta atinquichej?  
\v 41 Sumaj rijch'ariskas wakaychacuychej Diosmanta mañacuychejpuni ama juchaman urmachiskas canayquichejpaj. Chekamanta kancunaka allin cajta ruwayta munanquichej. Caypajrí mana callpayojchu canquichej,\f + \fr 26:41 \ft Literal: Espirituyquichej munan; aychayquichejrí mana atinchu.\f* —nispa. 
\p  
\v 42 Ujtawan rerka Diosmanta mañacuspataj nerka: 
\p —Munaska Tatáy, cay sinch'i ñac'ariypi wañunaypuni cashan chayka, kanpa munayniyqui ruwaska cachun, —nispa. 
\p  
\v 43 Ujtawan cutimuspa paycunata puñushajllatataj tariparka puñuywan atipaskas caskancuraycu.  
\v 44 Paycunata sakespa quinsa cutitaña watejmanta Diosmanta mañaricoj rerka. Chaypipis quiquin palabrasllawantaj ujtawan mañacorka.  
\v 45 Chantaña yachacojcunanman cutimuspa paycunata nerka: 
\p —¿Puñushallanquichejpunichu? Puñucullaychej. Uyariwaychej, horaka chayamunña. Noka, Diospa cachaska Runan, juchasapaspa maquisnincuman jaywaskaña cashani.  
\v 46 Jataricuychej. Jacu ripuna. Khawaychej jaywaycuwajniyka kayllamushanña, —nispa. 
\s1 Jesusta jap'ispa apancu 
\p  
\v 47-48 Jesús parlashajtillanraj Judaska may ashqha runaswan kayllaycamorka. Payka chay chunca iscayniyoj Jesuspa yachacojcunanmanta carka. Chay ashqha runastaj jatuchej t'ujsina cuchilloswan,\f + \fr 26:47-48 \ft Literal: espadaswan.\f* makana c'aspiswantaj jamorkancu cachamuska israel curajcunamanta yupaychana-wasimanta curajcunamantawan. Jaywaycojtaj chay ashqha runasta yachaycucherka: 
\p —Pitachá noka napaycuspa much'aycusaj, chay runata jap'iycuychej, —nispa. 
\p  
\v 49 Judaska Jesusman kayllaytawan payta nerka: 
\p —Allin ch'isi cachun, Yachachiwajníy. 
\p Chaymantataj Jesusta may munacuywanjina much'aycorka.  
\v 50 Jesustaj nerka: 
\p —Amigo, ¿imapajtaj jamunquirí? 
\p Chanta Jesusman kayllaycamuspa payta jap'iycorkancu. 
\p  
\v 51 Ajinapi Jesuswan cajcunamanta ujnin caj jatun cuchillonta\f + \fr 26:51 \ft Literal: espada.\f* siq'iycorka. Yupaychana-wasimanta curajpa camachinta wajtaspa ningrinta c'uturparerka.  
\v 52 Chanta Jesuska chay wajtajta nerka: 
\p —Cuchilloyquita wakaychananman churay. Yachanchej cuchillowan\f + \fr 26:52 \ft Literal: espada.\f* makanacojcunaka cuchillollawantaj wañuchiskas caskancuta.  
\v 53 Noka atiyman Dios Tataymanta mañacuyta. 
\p Paytaj chay ratu janaj pachamanta chunca iscayniyoj waranka warankas angelesta churapuwanman. ¿Cayta manachu reparanqui?  
\v 54 Diospa palabran nin ajina junt'acunan tiyan. Manachayka ¿imaynataj junt'acunan?  
\v 55 Chaypacha Jesuska ashqha runasman nerka: 
\p —¿Uj runa wañuchi suwatajinachu nokata jap'ej jamuwanquichej? ¿Chayraycuchu jatun cuchilloswan\f + \fr 26:55 \ft Literal: espada.\f* makana c'aspiswan jamunquichej? Nokaka sapa p'unchay yupaychana-wasi patiopi yachacherkani. Kancunarí mana jap'iycuwarkanquichejchu.  
\v 56 Tucuy cay ruwacushan Diospa palabranpi unay willajcunan niskancuta junt'acunanpaj, —nispa nerka Jesús. 
\p Chanta tucuynin yachacojcunan payta sakerpayaspa aykecaporkancu. 
\s1 Jesús jatun tantacuypa ñaupakenpi 
\p  
\v 57 Jesusta jap'iycojcunataj Caifaspaman pusariycorkancu. Chay Caifás yupaychana-wasimanta curaj runa carka. Paypa wasinpi tantaskas casharkancu israel yachachejcunawan curajcunawanka.  
\v 58 Pedrorí carullamanta Jesusta khatisharka curajpa pationcama. Chay patiopitaj yanapajcunawan cusca tiyaricorka imaynapichus tucucunanta ricuyta munaspa. 
\p  
\v 59 Tucuy jatun tantacuycunataj Jesusta wañuchiyta munasharkancu. Chayraycu Jesuspa contranpi llulla willajcunata masc'asharkancu.  
\v 60 Ashqha runas jamorkancu llullacuspa willanancupaj. Willaskancurí manataj quiquinpunichu carka. Khepallantaña iscay willajcuna jamorkancu.  
\v 61 Nerkancutaj: 
\p —Cay runa nerka: “Atiyniyoj cani yupaychana-wasita urmachinaypaj, quinsa p'unchaypitaj watejmanta wasichanaypaj”, —nispa. 
\p  
\v 62 Yupaychana-wasimanta curaj runataj sayarimuspa Jesusta nerka: 
\p —Cay runas nisuskancumanta ¿manachu cutichicunqui? 
\p  
\v 63 Jesusri ch'inlla cacorka. Curajtaj payta nerka: 
\p —Causaj Diospa sutinpi camachiyqui: “Sichus kanka Diospa ajllaska Wawan, Cristo, canqui chayka, willawaycu, ari, —nispa. 
\p  
\v 64 Jesustaj payta nerka: 
\p —Arí, niskayquimanjina, Diospa cachaska Runan cani. Cunanmantapachataj curaj atiyniyoj Dioswan cusca camachishajta ricuwanquichej, phuyus chaupipi atiyniywan janaj pachamanta jamushajtapis. 
\p  
\v 65 Chanta curajka may phiñacuskanta ricuchinanpaj p'achasninta lliq'icorka. Nerkataj: 
\p —Cay runaka Diosta cayjinata phiñachiskanta uyarerkanquichejña. Manaña waj willajcuna paymanta willanancuta munanchejchu. 
\p  
\v 66 Curajcunatataj tapurerka: 
\p —Kancunaman ¿imaynataj rijch'asunquichej? 
\p Paycunataj cutichispa nerkancu: 
\p —Cay runaka wañuchiska cananpajjina cashan. 
\p  
\v 67 Chanta Jesusta uyanpi thokaycorkancu. Tacaspataj payta apaycachasharkancu. Waquinrí uyanpi sajmasharkancu.  
\v 68 Nisharkancutaj: 
\p —Diospa ajllaskan Cristo canqui chayka, sut'inchaspa willawaycu ¿pitaj sajmasorka? 
\s1 Pedro nin Jesusta mana rejsiskanta 
\p  
\v 69 Pedrori chaycamaka jawa patiopi tiyacusharka. Ajinapitaj uj wasi camachi imilla payman kayllaycuspa nerka: 
\p —Kanpis chay Galilea llajtayoj Jesuspa masin canqui. 
\p  
\v 70 Pedrorí tucuy chay runaspa ñaupakencupi mananchacuspa nerka: 
\p —Mana yachanichu imatachus parlashanqui, —nispa. 
\p  
\v 71 Pedro puncunejman rishajtin waj camachi imilla payta ricorka. Chaymantataj chaypi caj runasman nerka: 
\p —Cay runaka chay Nazaret llajtayoj Jesuswan purejmin, —nispa. 
\p  
\v 72 Pedrori watejmanta mananchacorka. Diospa sutinta okharicuspataj: 
\p —Mana rejsinichu chay runataka, —nerka. 
\p  
\v 73 Uj chhicamantawan chaypi cajcuna Pedroman kayllaycorkancu. Nerkancutaj: 
\p —Chekamanta kanka Jesuswan purejcunamanta canqui. Parlaynillayquipi sut'i cashanqui. 
\p  
\v 74 Chanta Pedroka kallarerka niyta: 
\p —¡Mana chekata parlani chayka, Dios wañuchiwachun! Chay runataka manapuni rejsinichu. 
\p Chay quiquinpachataj gallo wakarka.  
\v 75 Chaymanta payka Jesuspa niskanta yuyaricorka: “Manaraj gallo wakashajtin quinsa cutita khesachawanqui nokata mana rejsiwaskayquita”. Ajinataj jawaman llojsispa sonko nanajta wakaycorka. 
\c 27  
\s1 Jesusta Pilatoman jaywaycuncu 
\p  
\v 1 P'unchayarpamojtinña yupaychana-wasimanta tucuy curajcunawan israel curajcunawan tantacorkancu. Chay tantacuyka uj yuyayllata Jesuspa contranpi ninacorkancu payta wañuchichinancuta.  
\v 2 Jesustataj wataskata pusaspa camachej Pilatoman jaywaycorkancu. 
\s1 Judas wañupun 
\p  
\v 3 Jaywaycoj Judaska Jesusta juchachaska caskanta ricorka. Chayraycu payka sonkonpi mayta phuticorka. Chaymantataj chay jatun tantacuyman rispa quinsa chunca kolkesta cutiycuchiporka.  
\v 4 Payri nerka: 
\p —Mana juchayoj runata wañunanpaj jaywaycuspa juchallicuni, —nispa. 
\p Paycunataj nerkancu: 
\p —¿Nokaycu ima ruwanaycu tiyanrí? Kanmantachá chayka. 
\p  
\v 5 Judastaj yupaychana-wasiman kolketa wijch'uycaporka. Chaymantataj rispa sipirpayacamorka. 
\p  
\v 6 Yupaychana-wasimanta curajcuna chay kolketa okharispa nerkancu: 
\p —Camachiskanchejmanjina chay kolketa yupaychana-wasipaj mana churayta atinchejchu. Imaraycuchus uj runa wañunanpaj kolke carka, —nispa. 
\p  
\v 7 Chanta parlanacuspa chay kolkewan yuyarkancu c'analleroj jallp'anta rantiyta. Chay jallp'a forasterocuna p'ampacunancupaj canan carka.  
\v 8 Chayraycu chay jallp'aka uj runaj wañuyninwan rantiska sutichaska carka. Cunan p'unchaycama ajina sutichaska cashan.  
\v 9 Ajinapi unay willaj Jeremiaspa niskanka junt'acorka. Payri Diospa palabranpi nerka: “Israelcuna quinsa chunca kolkesta jap'erkancu. Chay kolketa israelcuna uj yuyayman churacuspa korkancu Jesús jaywaska cananpaj.  
\v 10 Chay kolkewantaj uj c'analleroj jallp'anta ranterkancu. Chayka Diospa camachiwaskanmanjinamin”. 
\s1 Pilato Jesusta tapun 
\p  
\v 11 Jesustari camachej Pilatoj ñaupakenman aparkancu. Paytaj Jesusta taporka: 
\p —¿Kanchu israelcunaj camachejnincu canqui? 
\p Jesusri nerka: 
\p —Kan ninqui, ajinamin, —nispa. 
\p  
\v 12 Jatun tantacuy runas mayta Jesuspa contranpi willasharkancu. Payri ni imata cutichicorkachu.  
\v 13 Chayraycu Pilatoka nerka: 
\p —¿Imaymanata kanpa contrayquipi willacushancu? ¿Manachu uyarinqui? 
\p  
\v 14 Jesusri ni uj simitapis payman cuticherkachu. Chayraycu Pilatoka mayta t'ucorka. 
\s1 Pilato juchachan Jesusta wañuchiska cananpaj 
\p  
\v 15 Sapa wata camachejka chay jatun p'unchaycunapi uj wisk'aska runata cacharejpuni caj. Chaymanjinataj mañaskancuta uj wisk'aska runata paycunapaj cacharipunan caj.  
\v 16 Chaypachataj uj mana allinpaj rejsiska runa wisk'aska casharka. Barrabás sutiyoj.  
\v 17 Ashqha runas tantaska cashajtincu Pilatoka nerka: 
\p —¿Maykentataj cacharipuskayquichej? ¿Barrabastachu chayrí Cristo niska Jesustachu? 
\p  
\v 18 Imaraycuchus yacharka israelcuna envidiamanta Jesusta payman jaywaycuskancuta. 
\p  
\v 19 Jesusmanta yuyashajtintaj Pilatoj warmin uj runata cachamorka ninanpaj: “Ama juchachaychu chay chekan runata. Khaway, cunan ch'isi moskoyniypi paynejta sinch'ita muchorkani”. 
\p  
\v 20 Tantacuypi tucuy curajcuna chay runasta yachaycucherkancu. Nerkancutaj: “Barrabasta cacharipunanta mañaychej. Jesustataj wañuchiska cananta niychej”. 
\p  
\v 21 Pilatotaj paycunata taporka: 
\p —Cay iscay runasmanta ¿maykentataj cacharipuskayquichej? 
\p Paycunataj cuticherkancu: 
\p —Barrabasta cacharipuwaycu. 
\p  
\v 22 Pilatori paycunaman nerka: 
\p —Cristo niska, chay Jesusta ¿imanasajtajrí? 
\p Tucuynincu cuticherkancu: 
\p —¡Chacataska cachun payka! 
\p  
\v 23 Pilatotaj nerka: 
\p —¿Imaraycutaj? ¿Ima mana allintataj ruwarkarí? 
\p Paycunataj astawan sinch'iwan khaparerkancu: 
\p —¡Chacataycuy paytaka! 
\p  
\v 24 Pilatoka repararka chay runasta mana ch'in yachiyta atinanta. Astawan astawan ch'ajwa canayashaskanraycutaj yacuta apachimorka. Chaymantataj runaspa ñaupakencupi maquisninta mayllacorka. Nerkataj: 
\p —Cay runaj wañuyninmanta mana juchayojchu cani. Kancuna imanamuychejpis. 
\p  
\v 25 Tucuynincu chay runaska cuticherkancu: 
\p —¡Chay runaj wañuyninmanta nokaycu wawasniy cuwanpacha juchayoj casajcu! 
\p  
\v 26 Chanta Pilatoka Barrabasta cachariporka paycunapaj. Jesustataj jasut'ichispa chay runasman jaywaycorka chacataska cananpaj. 
\p  
\v 27 Chanta camachejpa soldadosnenka Jesusta apaycorkancu camachejpa tiyacuna-wasinman. Chaymantataj paycunaj masisnincu tantaycucorkancu Jesusta muyuycuspa.  
\v 28 Ajinaspataj Jesuspa p'achasninta lluch'orkancu. Chanta camachejtajina puca p'achawan p'achalliycucherkancu.  
\v 29 Pilluta qhishcamanta simp'aspataj Jesuspa umanman churaycorkancu. Asicunancupajtaj paña maquinman camachejmanjina uj sokosta churarkancu. Paypa ñaupakenman konkoricuspa nerkancu: 
\p —¡Viva israelcunaj camachejnincu! 
\p  
\v 30 Payta thokaycorkancu. Paymanta sokosta jap'ispataj umanpi wajtasharkancu.  
\v 31 Payta asipayaytawanka chay puca p'achata lluch'orkancu. Chaymantataj p'achasninta p'achalliycuchipuspa pusarkancu paytaka chacatanapaj. 
\s1 Jesusta chacataycuncu 
\p  
\v 32 Soldados llajtamanta llojsishaspaka uj Cirene llajtayoj runawan tincorkancu. Paypa sutinri Simón carka. Paytataj camacherkancu Jesuspa cruzninta k'epinanta.  
\v 33 Ajinaspa t'ojlu caskan, chay Gólgota lugarman chayarkancu.  
\v 34 Chaypitaj vinota jayak'ewan chajruycuspa payta korkancu ujyananpaj. Jesusri mallirispa mana ujyarkachu. 
\p  
\v 35 Soldadostaj Jesusta chacatarkancu. Chanta suerteta chokarkancu yachanancupaj pipajchus Jesuspa p'achasnin cananta. Ajinapi unay willajpa niskanka Jesusmanta junt'acorka: “Suertesta chokaspa p'achasniyta partinacorkancu”.  
\v 36 Chaypi soldadoska tiyaycucuspa sumajta khawasharkancu.  
\v 37 Jesuspa umanpa patannejpitaj uj kelkaskata churarkancu imamantachus chacataska caskanta willanancupaj. Chaytaj nin: “Caymin Jesuska, israelcunaj camachejnin”. 
\p  
\v 38 Chaypitaj Jesuswan iscay runa wañuchi suwas chacataskas casharkancu. Uj suwaka paypa pañannejpi, uj caj suwataj llok'ennejpi casharka.  
\v 39 Chayninta purejcunataj millayta c'amisharkancu payta. Umancuta qhiwirispa asipayanancupaj  
\v 40 nisharkancu: 
\p —¡Kanka, yupaychana-wasita urmachej, chaymanta quinsa p'unchaypitaj watejmanta sayarkochej, quiquiyquita cacharichicuy! Diospa Wawan canqui chayka, chay cruzmanta uraycamuy, —nispa. 
\p  
\v 41 Ajinallataj yupaychana-wasimanta curajcunawan, israel yachachejcunawan, waj curajcunawan asipayasharkancu Jesusta. Ninacusharkancutaj: 
\p  
\v 42 —Cay runaka wajcunata cacharicherka. Pay quiquinrí nitaj atinchu cacharichicuyta. Israelcunaj camachejnincu canman chayka, cruzmanta uraycamuchun cunitan. Chayta ricuspataj nokaycupis creesajcu pay Camachej caskanta.  
\v 43 Diospi payka atinicorka, “Diospa Wawan cani”, nispa. Chayraycu cunitan payta cruzmanta cacharichichun, sichus chekamanta Dios payta munacun chayka, —nispa. 
\p  
\v 44 Paywan cusca chacataska suwaspis quiquillantataj payta c'amisharkancu. 
\s1 Jesús tucucapun 
\p  
\v 45 Chaupi p'unchaymanta chaupi tardecama tucuy jallp'a lakhayaycorka.  
\v 46 Chaupi tardetajinataj Jesuska sinch'ita khaparicorka: 
\p —¿Elí, Elí lama sabactani? Khapariskan niyta munan: Diosníy, Diosníy, ¿imaraycutaj sakerpariwanquirí? 
\p  
\v 47 Waquin chaypi cajcunamanta chayta uyarispa nerkancu: 
\p —Cayka unay willaj Eliasta wajyacushan, —nispa. 
\p  
\v 48 Chay quiquinpacha ujnincu paycunamanta uskhayta rispa uj esponjata jap'erka. Chayta c'allcu ujyanaman chhaporka. Chaytataj uj sokosman churaspa Jesusman jaywarka ch'onkananpaj.  
\v 49 Waquinrí nisharkancu: 
\p —Suyay. A ver, ricusunchej, Elías jamonkachus payta cruzmanta cacharichej. 
\p  
\v 50 Jesús watejmanta sinch'ita khaparicorka. Causayninta tatanpa maquisninman jaywaycuspataj tucucaporka.  
\v 51 Yupaychana-wasipi warqhuska caj khatanaka patamanta uracama iscayman lliq'icorka. Jallp'ataj qharcatiterka. Rumispis quichacorkancu.  
\v 52 P'ampanas quicharicorkancu. Diospi jap'icuspa wañuska cajcunajta ashqhaspata ayasnincu causarichiskas carkancu.  
\v 53 Paycunaka p'ampanasmanta llojsiporkancu. Jesús causarimuskanmantataj Jerusalén llajtaman jamorkancu. Chaypitaj ashqha runasman riqhurerkancu. 
\p  
\v 54 Romano camachej, soldadosninwan, Jesusta wakaychasharkancu. Paycunataj jallp'a qharcatitishajta chay waj imas ruwacushajtawan ricorkancu. Chayraycu mayta manchachicuspa nisharkancu: 
\p —Chekamanta cay runaka Diospa Wawan carka, —nispa. 
\p  
\v 55 Chaypi casharkancu ashqha warmis caritullamanta khawacamusharkancu. Paycunari Jesusta Galilea jallp'amanta khatimoj carkancu payta yanapanancupaj.  
\v 56 Paycuna uqhu carkancu Magdala llajtayoj María, Jacobojta Josejtawan mamancu, waj Mariapiwan. Chaywanpis Zebedeoj wawasninpa mamancupis paycuna uqhupi carka. 
\s1 Jesusta p'ampancu 
\p  
\v 57 Ch'isiyaycojtinña uj khapaj runa, José sutiyoj, jamorka Arimatea ranchonmanta. Paypis Jesusta khaticojcunamanta carka.  
\v 58 Payka Jesuspa cuerponta mañaj Pilatoman rerka. Chanta Pilatoka camacherka soldadosta Joseman jaywanancuta.  
\v 59 Josetaj cuerponta apacapuspa okharerka. Linomanta uj llimphu awaskawan mayt'orka.  
\v 60 Paypata carka uj mosoj aya p'ampana. Chaytaka pay uj jatun kakapi unayña ruwachicorka. Chayman Jesuspa cuerponta churaycorka. Chaymantataj chay puncuman uj jatun p'alta rumita muyuchispa wisk'aycorka. Ajinaspataj riporka.  
\v 61 Chaypitaj casharkancu María Magdalenawan chay uj caj Mariapiwan. Paycunaka chay p'ampanaj chimpannejpi tiyaycusharkancu. 
\s1 Soldadosta churancu Jesúspa p'ampaskanta wakaychanancupaj 
\p  
\v 62 Israelcunaj samacuna p'unchaynincupaj waquichicunancu caj. Samacuna p'unchaypitaj yupaychana-wasimanta curajcunawan fariseo partepiwan tantaycucorkancu. Chaymantataj Pilatojman rispa  
\v 63 nerkancu: 
\p —Señor, chay pantachej runaka causashaspallaraj, “Wañuskaymanta quinsa p'unchaymanta causarimpusaj”, niskanta yuyaricuycu.  
\v 64 Chayraycu camachiy p'ampananta sumajta wakaychanancuta quinsa p'unchaycamallapis. Yachacojcunanpis cuerponta suwaj jamushancumanchá. Paycunaka suwaytawan runasman nincuman: “Wañuskacunamanta causarimporka”, nispa. Cay pantachiyka chay ñaupaj pantachiymanta aswan mana allinchu canman. 
\p  
\v 65 Pilatoka paycunata nerka: 
\p —Cay soldadosta pusacuychej. Riychej. Atiskayquichejta p'ampananta sumajta wakaychamuychej, —nispa. 
\p  
\v 66 Ajina paycunaka rerkancu. P'ampana rumita sumajta wisk'arkancu ama ni pi t'ojpinanpaj. Soldadostataj wakaychanancupaj churarkancu. \fig |src="cn01848B.tif" size="span" copy="© 1978 David C. Cook Publishing Co." ref="Mateo 27.66" \fig* 
\c 28  
\s1 Jesús causarimpun 
\p  
\v 1 Samacuna p'unchay k'ayantin Domingo p'unchay sut'iyamusharka. Ajinata Magdala llajtayoj Mariawan chay uj caj Mariapiwan sepulturaman khawaj jamorkancu.  
\v 2 Jallp'ataj mayta qharcatiterka. Chayka carka Señor Diosmanta cachamuska uj angel janaj pachamanta uraycamuskanraycu. P'ampanaman kayllaycuspa chay jatun rumita wajnejman muyurparicherka. Chay rumi patapitaj tiyaycucorka.  
\v 3 Rijch'acuynenka lliuj-lliujjina c'ancharisharka. P'achasnintaj rit'ijina yuraj carka.  
\v 4 P'ampanata wakaychajcunataj manchaymanta qharcatitisharkancu wañuskajinataj tucorkancu.  
\v 5 Diosmanta angeltaj chay warmista nerka: 
\p —Amaña manchachicuychejchu. Yachani kancunaka chacataska carka, chay Jesusta masc'ashaskayquichejta.  
\v 6 Payka manaña caypichu imaraycuchus niskanmanjina causarimporka. Jamuychej Jesuspa wañuska cuerpon churaska carka, chayta khawanayquichejpaj.  
\v 7 Yachacojcunanman uskhayta riychej. Willamuychej Jesuska wañuskanmanta causarimpuskantaña. Cunantaj kancunaj ñaupakeyquichejta Galilea jallp'aman rishanña. Jakaypitaj payta ricunquichej. Chayta kancunaman nerkayquichej nimunayquichejpaj, —angel nerka. 
\p  
\v 8 Warmistaj p'ampanamanta uskhay uskhayllata riporkancu. Paycunataj manchay manchaylla jatun cusiywantaj riporkancu. Correrkancutaj yachacojcunanman willaj.  
\v 9 Ajinallapi Jesuska paycunaman riqhurerka. Napaycorkataj: 
\p —Buenos días, mamacuna, —nispa. 
\p Paycunataj Jesusman kayllaycuspa chaquisninta mayta jap'iycorkancu. Ajinaspataj payta yupaycharkancu.  
\v 10 Chanta Jesuska paycunata nerka: 
\p —Amaña manchachicuychejchu. Riychej hermanosniyman willampuwaychej Galileaman rinancuta. Jakaypi tincuwankancu, —nispa. 
\s1 Soldadospa willaskancu 
\p  
\v 11 Chay warmis rishajtincutaj waquin wakaychajcunaka llajtaman jamorkancu. Jamuspataj paycunaka tucuy ima ruwacuskanta yupaychana-wasimanta curajcunaman willarkancu.  
\v 12 Chaycunallataj curajcunapiwan tantaycucuspa wakaychajcunaman kolketa konancupaj yuyaychanacorkancu. Ajinataj ashqha kolketa orkhocuspa wakaychajcunaman lluq'iycorkancu.  
\v 13 Nerkancutaj: 
\p —Niychej curajcunaman: Nokaycu puñuskas cashaskaycuycamaka Jesuspa yachacojcunan tuta jamuskancu. Cuerpontataj suwacapuskancu.  
\v 14 Jatun camachej cayta yachanman chayka, nokaycu paywan parlasajcu kancunapaj allin cananpaj. Kancunaka mana llaquicunayquichejchu canka, —nispa curajcuna nerkancu. 
\p  
\v 15 Ajinataj wakaychajcuna kolketa jap'icorkancu. Yachaycuchiskancumanjinataj nerkancu. Chay parlayta israelcunaka cunancama parlancu. 
\s1 Jesús camachin cachasninta yachachimunancupaj 
\p  
\v 16 Chunca ujniyoj yachacojcunanka Galilea jallp'aman rerkancu. Jesús rinancuta camacherka, chay orkoman rerkancu.  
\v 17 Jesusta ricuytawan yupaycharkancu. Waquinrí iscayrayasharkancu.  
\v 18 Jesustaj paycunaman kayllaycuspa nerka: 
\p —Janaj pachapipis cay pachapipis camachinaypaj Dios Tatay tucuy atiyta kowan.  
\v 19 Chayraycu kancunaka riychej tucuy runasman. Paycunata yachachimuychej yachacojcunay canancupaj. Diospata caskancuta ricuchispa bautizaychej Dios Tataj sutinpi, nokaj, Dios Wawaj sutiypi, Santo Espíritoj sutinpiwan.  
\v 20 Jap'icojcunatataj sumajta yachachimuychej tucuy camachiskayta ruwanancuta. Reparaychej nokaka sapa p'unchay kancunawanpuni casaj cay pacha tucucuycama. Ajina cachun.