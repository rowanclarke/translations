\id PRO - Biblica® Open Ndebele Contemporary Bible 
\h Izaga 
\toc1 Izaga 
\toc2 Izaga 
\toc3 Iza 
\mt1 Izaga 
\c 1  
\ms1 Injongo Lendikimba 
\p  
\v 1 Izaga zikaSolomoni indodana kaDavida, inkosi yako-Israyeli: 
\q1  
\v 2 ukuba abantu bazuze ukuhlakanipha lokuzithiba; 
\q2 ukuba bazwisise amazwi okuqedisisa; 
\q1  
\v 3 ukuba bazuze impilo yokuzithiba lobuqotho, 
\q2 besenza okulungileyo, okufaneleyo lokuqondileyo; 
\q1  
\v 4 ukunika ulwazi kwabayizithutha, 
\q2 ulwazi lokukhetha okuqondileyo kwabatsha 
\q1  
\v 5 ukuthi ohlakaniphileyo alalele engeze ukufunda kwakhe, 
\q2 kuthi obonisisayo azuze izeluleko, 
\q1  
\v 6 ukuba abantu bazwisise izaga lemizekeliso, 
\q2 izitsho lamalibho abahlakaniphileyo. 
\b  
\q1  
\v 7 Ukwesaba \nd uThixo\nd* kuyikuqala kwenhlakanipho, 
\q2 kodwa iziwula ziyakweyisa ukuqedisisa lokuzithiba. 
\ms1 Isandulelo: Isikhuthazo Sokubambelela Elwazini 
\s1 Isixwayiso Ngokukhangwa Yizoni 
\q1  
\v 8 Lalela, ndodana yami, izeluleko zikayihlo 
\q2 njalo ungadeli imfundiso kanyoko. 
\q1  
\v 9 Kuzakuba ngumqhele omuhle ekhanda lakho 
\q2 lomgaxo wokucecisa intamo yakho. 
\b  
\q1  
\v 10 Ndodana yami, aluba izoni zikuhuga, 
\q2 ungaze wavuma. 
\q1  
\v 11 Nxa zisithi, “Woza sihambe; 
\q2 kasicathamele abantu sichithe igazi, 
\q2 kasicwathele omunye umuntu ongelacala; 
\q1  
\v 12 kasibaginye bephila njengengcwaba, 
\q2 sibajwamule njengabawele emgodini; 
\q1  
\v 13 sizazuza impahla ezinhle ezehlukeneyo 
\q2 sigcwalise izindlu zethu ngempango; 
\q1  
\v 14 phathisana lathi 
\q2 ukuze sibelesikhwama sinye” 
\q1  
\v 15 ndodana yami, ungahambi lazo, 
\q2 ungalugxobi olwakho ezindleleni zazo; 
\q1  
\v 16 ngoba ezabo inyawo zigijima ekoneni, 
\q2 bachitha igazi lula. 
\q1  
\v 17 Kakusizi ukuthiya ngembule 
\q2 lithe dandalazi emehlweni ezinyoni! 
\q1  
\v 18 Abantu laba bacathamela ukuchitheka kwelabo igazi; 
\q2 bajuma okwabo ukuphila. 
\q1  
\v 19 Sinjalo isiphetho salabo abadinga inzuzo ngobugebenga; 
\q2 kuyayichitha impilo yalabo abayitholayo. 
\s1 Isixwayiso Ngokufulathela Inhlakanipho 
\q1  
\v 20 Ukuhlakanipha kuyamemeza emgwaqweni, 
\q2 kuphakamisa ilizwi lakho ezinkundleni; 
\q1  
\v 21 kuyanqongoloza lezindleleni okuxokozela khona, 
\q2 kuyatshumayela emasangweni omuzi kuthi: 
\b  
\q1  
\v 22 “Koze kube nini lina zithutha lithanda ubuthutha benu na? 
\q2 Koze kube nini izideleli zikholisa ukudelela 
\q2 leziphukuphuku zizonda ulwazi na? 
\q1  
\v 23 Lalelani ukukhuza kwami liphenduke! 
\q2 Ngizalivulela isifuba sami, 
\q2 ngilivezele imicabango yami. 
\q1  
\v 24 Kodwa ngenxa yokuthi langifulathela ngilibiza, 
\q2 kwangabi khona onginanzayo ngiselula isandla sami, 
\q1  
\v 25 njengoba lala izeluleko zami 
\q2 njalo kalavuma ukukhuza kwami, 
\q1  
\v 26 ngakho lami ngizahleka selihlupheka; 
\q2 ngizaliklolodela nxa lisehlelwa lusizi, 
\q1  
\v 27 nxa usizi lulehlela njengesiphepho; 
\q2 nxa incithakalo ilikhukhula njengesivunguzane, 
\q2 nxa usizi lezinhlupheko ziligabhela. 
\b  
\q1  
\v 28 Lapho-ke bazangibiza kodwa kangiyikusabela; 
\q2 bazangidinga bangangitholi. 
\q1  
\v 29 Ngoba babeluzonda ulwazi 
\q2 kabaze bakhetha ukwesaba \nd uThixo\nd* 
\q1  
\v 30 ngoba kabavumanga iseluleko sami, 
\q2 badelela ukukhuza kwami, 
\q1  
\v 31 bazakudla izithelo zokuhamba kwabo 
\q2 basuthiswe ngezithelo zamacebo abo. 
\q1  
\v 32 Phela ubuhlongandlebe bezithutha buzazibulala, 
\q2 lokungananzi kweziphukuphuku kuzazibhubhisa; 
\q1  
\v 33 kodwa lowo ongilalelayo uzahlala evikelekile ekhululekile, 
\q2 engesabi lutho olungamlimaza.” 
\c 2  
\s1 Imivuzo Emihle Yokuhlakanipha 
\q1  
\v 1 Ndodana yami, nxa usamukela amazwi ami 
\q2 ugcine imilayo yami ngaphakathi kwakho, 
\q1  
\v 2 uvule indlebe yakho izwe ukuhlakanipha 
\q2 unikele inhliziyo yakho ukuthi izwisise, 
\q1  
\v 3 njalo nxa ucela ukuqedisisa 
\q2 ukhalela kakhulu ukuzwisisa, 
\q1  
\v 4 futhi ukudingisisa njengokudinga isiliva 
\q2 ukuphenye njengento eligugu efihliweyo, 
\q1  
\v 5 lapho-ke uzakuzwisisa ukumesaba \nd uThixo\nd* 
\q2 njalo uluzuze ulwazi lukaNkulunkulu. 
\q1  
\v 6 Ngoba \nd uThixo\nd* uyapha ukuhlakanipha, 
\q2 emlonyeni wakhe kuphuma ulwazi lokuqedisisa. 
\q1  
\v 7 Abaqotho ubapha ukunqoba, 
\q2 ulihawu lalabo abahamba bengasoleki, 
\q1  
\v 8 ngoba uyayilinda indlela yabalungileyo 
\q2 avikele ukuhamba kwabathembekileyo bakhe. 
\b  
\q1  
\v 9 Yikho uzazwisisa lokho okulungileyo lokuqondileyo lokufaneleyo 
\q2 zonke izindlela ezinhle. 
\q1  
\v 10 Ngoba ukuhlakanipha kuzangena enhliziyweni yakho, 
\q2 lolwazi lube mnandi emphefumulweni wakho. 
\q1  
\v 11 Ukwazi ukukhetha kuzakuvikela, 
\q2 lokuzwisisa kuzakulinda. 
\b  
\q1  
\v 12 Ukuhlakanipha kuzakusindisa ezindleleni zabantu ababi, 
\q2 abantu abamazwi abolileyo, 
\q1  
\v 13 abatshiya izindlela eziqondileyo, 
\q2 bahambe ngezindlela ezilamathunzi, 
\q1  
\v 14 abathokoza ngokwenza okubi 
\q2 bajabule ngokungcola kokubi, 
\q1  
\v 15 abandlela zabo zitshekile 
\q2 lokuhamba kwabo kakuqondakali. 
\b  
\q1  
\v 16 Kuzakukhulula njalo koyisiphingikazi, 
\q2 lasemfazini olamazwi akhohlisayo, 
\q1  
\v 17 osetshiye indoda yakhe yobutsha bakhe 
\q2 wadela isifungo asenza phambi kukaNkulunkulu. 
\q1  
\v 18 Ngoba indlu yakhe iholela ekufeni 
\q2 lezindlela zakhe zidonsela kwabafileyo. 
\q1  
\v 19 Kakho ongena kuye obuyayo 
\q2 kumbe aphinde azuze izindlela zokuphila. 
\b  
\q1  
\v 20 Ngakho uzahamba ezindleleni zabantu abalungileyo 
\q2 walele emikhondweni yabaqondileyo. 
\q1  
\v 21 Ngoba abaqotho bazahlala elizweni, 
\q2 labangasolekiyo bazasala kulo; 
\q1  
\v 22 kodwa izigangi zizasuswa elizweni, 
\q2 labangathembekanga bazakhutshwa kulo. 
\c 3  
\s1 Eminye Njalo Imivuzo Emihle Yokuhlakanipha 
\q1  
\v 1 Ndodana yami, ungakhohlwa imfundiso yami, 
\q2 kodwa ugcine imilayo yami enhliziyweni yakho, 
\q1  
\v 2 ngoba izakwandisa impilo yakho okweminyaka eminengi, 
\q2 ikuphe ukuthula. 
\b  
\q1  
\v 3 Akungasuki kuwe loba nini uthando lokuthembeka; 
\q2 kubophele entanyeni yakho, 
\q2 ukubhale egwalibeni lenhliziyo yakho. 
\q1  
\v 4 Ngalokho uzathandeka uzuze ibizo elihle 
\q2 emehlweni kaNkulunkulu laphambi kwabantu. 
\b  
\q1  
\v 5 Themba \nd kuThixo\nd* ngenhliziyo yakho yonke, 
\q2 ungathembi ekuzwisiseni kwakho; 
\q1  
\v 6 mvume kuzozonke izindlela zakho, 
\q2 yena uzaqondisa zonke izindlela zakho. 
\b  
\q1  
\v 7 Ungazenzi ohlakaniphileyo ngokubona kwakho; 
\q2 yesaba \nd uThixo\nd* uxwaye okubi. 
\q1  
\v 8 Lokho kuzawuphilisa umzimba wakho 
\q2 kuwaqinise lamathambo akho. 
\b  
\q1  
\v 9 Dumisa \nd uThixo\nd* ngenotho yakho; 
\q2 ngezithelo zakho zokuqala zonke; 
\q1  
\v 10 ngalokho iziphala zakho zizagcwala ziphuphume, 
\q2 lezimbiza zakho zewayini zize zichitheke ngewayini elitsha. 
\b  
\q1  
\v 11 Ndodana yami, ungeyisi ukulaya \nd kukaThixo\nd* 
\q2 njalo ungacaphukeli ukukhuza kwakhe, 
\q1  
\v 12 ngoba \nd uThixo\nd* ulaya labo abathandayo, 
\q2 njengoyise elaya indodana yakhe ayithandayo. 
\b  
\q1  
\v 13 Ubusisiwe umuntu ozuza ukuhlakanipha, 
\q2 umuntu ozuza ukuqedisisa, 
\q1  
\v 14 ngoba khona kulenzuzo eyedlula isiliva 
\q2 lenzuzo eyedlula igolide. 
\q1  
\v 15 Kuligugu elidlula amarubhi; 
\q2 kakukho okuloyisayo okungalinganiswa lakho. 
\q1  
\v 16 Impilo ende isesandleni sakho sokunene; 
\q2 kwesokhohlo kulenotho lodumo. 
\q1  
\v 17 Izindlela zakhe zilokuthokoza, 
\q2 lemikhondo yakhe ilokuthula. 
\q1  
\v 18 Kuyisihlahla sokuphila kulabo abakwamukelayo; 
\q2 labo abakuphathayo bazabusiswa. 
\b  
\q1  
\v 19 Ngokuhlakanipha \nd uThixo\nd* wabeka izisekelo zomhlaba, 
\q2 ngokuqedisisa wamisa izulu endaweni yalo; 
\q1  
\v 20 ngolwazi lwakhe inlwandle zehlukaniswa, 
\q2 lamayezi athontisa amazolo. 
\b  
\q1  
\v 21 Ndodana yami, gogosa ingqondo ehlela ngolwazi, 
\q2 ungayekeli kukucatshele; 
\q1  
\v 22 kuzakuba yikuphila kuwe, 
\q2 kube ngumceciso omuhle entanyeni yakho. 
\q1  
\v 23 Lapho-ke uzahamba ngendlela evikelweyo 
\q2 unyawo lwakho lungakhubeki; 
\q1  
\v 24 nxa ulala kawuyikwesaba; 
\q2 uzalala ubuthongo obumnandi. 
\q1  
\v 25 Ungabi lovalo nxa ujunywa ngumonakalo 
\q2 kumbe yikubhidlika lokho okwehlela ababi, 
\q1  
\v 26 ngoba \nd uThixo\nd* uzakuba lithemba lakho 
\q2 avikele unyawo lwakho emjibileni. 
\b  
\q1  
\v 27 Ungaze wala ukusiza labo abadinga uncedo, 
\q2 wena ulakho ongabasiza ngakho. 
\q1  
\v 28 Ungabokuthi kumakhelwane wakho: 
\q2 “Ubobuya kwesinye isikhathi; ngizakunika kusasa” 
\q2 wena ulalo lololutho. 
\q1  
\v 29 Ungacebi okubi ngomakhelwane wakho, 
\q2 ohlezi lawe ekwethemba. 
\q1  
\v 30 Ungaxabani lomuntu kungelasizatho 
\q2 yena engakonelanga ngalutho. 
\b  
\q1  
\v 31 Ungamhawukeli umuntu othanda ukulwa 
\q2 loba nje ufise lakuphi ukwenza kwakhe, 
\q1  
\v 32 ngoba \nd uThixo\nd* uyamenyanya umuntu oxhwalileyo 
\q2 kodwa oqotho umbeka ekhwapheni lakhe. 
\q1  
\v 33 Isiqalekiso \nd sikaThixo\nd* sehlela endlini yababi, 
\q2 kodwa uyayibusisa indlu yabalungileyo. 
\q1  
\v 34 Uyabahleka usulu abayizideleli ezizithembayo, 
\q2 kodwa abe lomusa kwabathobekileyo. 
\q1  
\v 35 Abahlakaniphileyo baphiwa udumo 
\q2 kodwa abayiziwula ubathela ihlazo. 
\c 4  
\s1 Ukuhlakanipha Kuyinqaba 
\q1  
\v 1 Zwanini, madodana ami, izeluleko zikayihlo; 
\q2 lalelani lizuze ukuqedisisa. 
\q1  
\v 2 Ngilipha izifundo ezipheleleyo; 
\q2 ngakho lingalahli imfundiso yami. 
\q1  
\v 3 Ngathi ngisengumfana emzini kababa, 
\q2 ngisebuthakathaka, ngiyimi ngedwa ingane kamama, 
\q1  
\v 4 wangifundisa ubaba wathi, 
\q2 “Abambe amazwi ami ngenhliziyo yakho yonke; 
\q2 gcina imilayo yami ukuze uphile. 
\q1  
\v 5 Zuza ukuhlakanipha, zuza ukuqedisisa; 
\q2 ungawakhohlwa amazwi ami, kumbe ugudluke kuwo. 
\q1  
\v 6 Ungafulatheli ukuhlakanipha, kuzakuvikela; 
\q2 kuthande, kuzakulinda. 
\q1  
\v 7 Ukuhlakanipha kuyinqaba; ngakho zuza ukuhlakanipha. 
\q2 Zuza ukuqedisisa loba kungathatha konke olakho. 
\q1  
\v 8 Kugogose, kuzakuphakamisa; 
\q2 kugone, kuzakunika udumo. 
\q1  
\v 9 Kuzakwethesa umqhele wamaluba omusa ekhanda lakho 
\q2 kukwethese umqhele wenkazimulo.” 
\b  
\q1  
\v 10 Zwana mntanami, yamukela lokho engikutshoyo, 
\q2 ukuze insuku zokuphila kwakho zibe zinengi. 
\q1  
\v 11 Ngiyakukhokhela endleleni yokuhlakanipha, 
\q2 ngikuqondise ezindleleni eziqondileyo. 
\q1  
\v 12 Nxa uhamba kawuyikuthikaza; 
\q2 nxa ugijima kawuyikukhubeka. 
\q1  
\v 13 Bambelela iziqondiso, ungayekethisi; 
\q2 zigcine kuhle ngoba ziyikuphila kwakho. 
\q1  
\v 14 Ungayingeni indlela yababi 
\q2 njalo ungahambi endleleni yezigangi. 
\q1  
\v 15 Ixwaye, ungahambi ngayo; 
\q2 itshiye uqhubeke ngeyakho indlela. 
\q1  
\v 16 Phela kabalali bengenzanga ukuganga; 
\q2 badela ubuthongo ukuze baqale balimaze omunye umuntu. 
\q1  
\v 17 Badla isinkwa sobubi 
\q2 banathe iwayini lobudlwangudlwangu. 
\b  
\q1  
\v 18 Indlela yabalungileyo injengovivi lokusa, 
\q2 kukhule ukukhanya kwalo kuze kuphelele emini. 
\q1  
\v 19 Kodwa indlela yababi ifana lomnyama omkhulu; 
\q2 kabazi ukuthi kuyini okubakhubayo. 
\b  
\q1  
\v 20 Ndodana yami, zwana lokhu engikutshoyo; 
\q2 lalelisisa amazwi ami. 
\q1  
\v 21 Ungawasusi emehlweni akho, 
\q2 agcine enhliziyweni yakho; 
\q1  
\v 22 ngoba ayikuphila kulabo abawafumanayo; 
\q2 lokuqina komzimba wonke womuntu. 
\q1  
\v 23 Phezu kwakho konke, gcina inhliziyo yakho, 
\q2 ngoba ingumthombo wokuphila kwakho. 
\q1  
\v 24 Lahla izibozi zamazwi emlonyeni wakho; 
\q2 ungakhuphi inkulumo yokuxhwala ezindebeni zakho. 
\q1  
\v 25 Khangelisa amehlo akho nta phambili, 
\q2 uwathi nhlo amehlo akho kulokho okuphambi kwakho. 
\q1  
\v 26 Lungisa izindlela ukuze inyawo zakho zinyathele kuhle, 
\q2 uhambe ngezindlela eziqinileyo kuphela. 
\q1  
\v 27 Ungaphambukeli kwesokunene loba kwesokhohlo; 
\q2 ugcine unyawo lwakho lunganyatheli okubi. 
\c 5  
\s1 Isixwayiso Kwabafebayo 
\q1  
\v 1 Ndodana yami, nanzelela ukuhlakanipha kwami, 
\q2 ulalele kuhle amazwi ami alombono, 
\q1  
\v 2 ukuze uhlale ukwazi ukukhetha okuqondileyo 
\q2 lokuze izindebe zakho zigcine ulwazi. 
\q1  
\v 3 Phela izindebe zesifebekazi zithonta uluju, 
\q2 lenkulumo yaso iyatshelela kulamafutha; 
\q1  
\v 4 kodwa ekucineni iyababa ingathi yinyongo, 
\q2 ibukhali njengenkemba esika nxa zombili. 
\q1  
\v 5 Inyawo zaso zehlela ekufeni; 
\q2 izinyathelo zaso ziqonda nta elibeni. 
\q1  
\v 6 Kasikhathali ukuthi kuphilwa njani; 
\q2 izindlela zaso ziyazombeleza, kodwa kasikuboni lokho. 
\b  
\q1  
\v 7 Ngalokho-ke, madodana ami, ngilalelani; 
\q2 lingaphambuki kulokho engikukhulumayo. 
\q1  
\v 8 Hambani ngendlela ekhatshana kwaso, 
\q2 lingasondeli emnyango wendlu yaso, 
\q1  
\v 9 funa unikele kwabanye amandla akho wonke 
\q2 lobudala bakho kulowo olesihluku, 
\q1  
\v 10 funa abemzini bazitike ngenotho yakho 
\q2 lokusebenza kwakho kunothise umuzi wenye indoda. 
\q1  
\v 11 Ekupheleni kokuphila kwakho uzabubula, 
\q2 lapho inyama yakho lomzimba wakho sekugugile. 
\q1  
\v 12 Uzakuthi, “Uthi ngangikuzonda yini ukulaywa! 
\q2 Inhliziyo yami yayikuzonda njani ukuqondiswa! 
\q1  
\v 13 Ngangingafuni ukulalela abafundisi bami 
\q2 kumbe ukulalela abeluleki bami. 
\q1  
\v 14 Ngacina sengisenkingeni enkulu 
\q2 ngiphakathi kwabantu bakaNkulunkulu.” 
\b  
\q1  
\v 15 Natha amanzi kowakho umgqomo, 
\q2 amanzi agelezayo kowakho umthombo. 
\q1  
\v 16 Kambe imifudlana yakho ingayekelwa 
\q2 igelezela emigwaqweni, 
\q1 lezifula zakho zamanzi 
\q2 zigelezele ezinkundleni zabantu na? 
\q1  
\v 17 Kazibe ngezakho wena wedwa, 
\q2 ungazabelani labafokazana nje. 
\q1  
\v 18 Sengathi ungabusiswa umthombo wakho 
\q2 njalo sengathi ungathokoza ngomfazi wobutsha bakho. 
\q1  
\v 19 Oyimpalakazi ethandekayo, imbabala ebutshelezi 
\q2 amabele akhe sengathi angakusuthisa lanini, nini lanini 
\q2 ukhangwe luthando lwakhe. 
\q1  
\v 20 Kungani ndodana yami, 
\q2 uthunjwa yisifebekazi? 
\q2 Kungani ugona iqolo lomfazi wenye indoda? 
\b  
\q1  
\v 21 Phela izindlela zomuntu zisobala \nd kuThixo\nd*, 
\q2 uyazihlola zonke izindlela zakhe. 
\q1  
\v 22 Izenzo ezimbi zomuntu omubi ziyamthiya; 
\q2 izibopho zesono sakhe zimuthe nko. 
\q1  
\v 23 Uzabhubha ngoba engalayeki, 
\q2 elahlekiswa yibuphukuphuku bakhe. 
\c 6  
\s1 Izixwayiso Ngobuwula 
\q1  
\v 1 Ndodana yami, nxa wenzele umakhelwane wakho isibambiso, 
\q2 nxa libambene izandla ukuba uzamhlawulela imilandu yakhe, 
\q1  
\v 2 aluba usuzihilele ngalokho okutshiloyo, 
\q2 wazibambisa ngamazwi omlomo wakho, 
\q1  
\v 3 lapho-ke yenza lokhu, ndodana yami, ukuzikhulula, 
\q2 njengoba usuwele ezandleni zakhe umakhelwane wakho: 
\q1 Hamba ufike uzehlise; 
\q2 mncengancenge umakhelwane wakho! 
\q1  
\v 4 Ungabuvumeli ubuthongo emehlweni akho, 
\q2 ungavumeli ukuwozela enkopheni zakho. 
\q1  
\v 5 Zikhulule njengempala ezandleni zomzingeli, 
\q2 njengenyoni esifini somthiyi. 
\b  
\q1  
\v 6 Khangela ubunyonyo, wena vila; 
\q2 hlolisisa ukwenza kwabo uhlakaniphe! 
\q1  
\v 7 Kabulamphathi, 
\q2 kabula mkhangeli loba umbusi, 
\q1  
\v 8 kodwa buyaqoqa umphako wabo ehlobo 
\q2 bubuthe ukudla kwabo nxa kuvunwa. 
\b  
\q1  
\v 9 Uzalala khonapho kuze kube nini, vila ndini? 
\q2 Uzavuka nini ebuthongweni bakho? 
\q1  
\v 10 Ukulala okuncane, ukuwozela okuncane, 
\q2 ukugoqa izandla kancane uphumula, 
\q1  
\v 11 ubuyanga buzafika kuwe njengesela 
\q2 lokuswela njengesigebenga. 
\b  
\q1  
\v 12 Isigangi lesixhwali 
\q2 esihamba sikhuluma amanyala, 
\q2  
\v 13 esiqhweba ngelihlo 
\q2 sitshengise ngezinyawo zaso 
\q2 njalo sitshengise ngeminwe yaso, 
\q2  
\v 14 esiceba ububi ngenkohliso enhliziyweni yaso 
\q2 sithanda ukuvusa inkani kokuphela. 
\q1  
\v 15 Ngakho lowo uzawelwa yingozi ngokuphazima; 
\q2 uzabhidlizwa ngokuphangisa 
\q2 kungasekho okungenziwa. 
\b  
\li1  
\v 16 Ziyisithupha izinto \nd uThixo\nd* azizondayo, 
\li2 eziyisikhombisa eziyisinengiso kuye: 
\li3  
\v 17 amehlo atshengisa ukudelela, 
\li3 ulimi oluqamba amanga, 
\li3 izandla ezichitha igazi elingelacala, 
\li3  
\v 18 inhliziyo egaya izibozi, 
\li3 inyawo eziphangisa ukuya ebubini, 
\li3  
\v 19 umfakazi wamanga, okhuluma inkohliso 
\li3 lomuntu oletha ukuxabana kubazalwane. 
\s1 Isixwayiso Ngokuphinga 
\q1  
\v 20 Ndodana yami, gcina imilayo kayihlo 
\q2 ungadeli imfundiso kanyoko. 
\q1  
\v 21 Kubophele enhliziyweni yakho nini lanini; 
\q2 kugqize entanyeni yakho. 
\q1  
\v 22 Nxa uhamba, lezizinto zizakukhokhela; 
\q2 lanxa ulele zizakulinda; 
\q2 uthi uvuka zikukhulumise. 
\q1  
\v 23 Ngoba imilayo le iyisibane, 
\q2 imfundiso le iyikukhanya, 
\q2 leziqondiso zokuzithiba ziyindlela yokuphila, 
\q1  
\v 24 zikuvikela kowesifazane ongaziphathanga, 
\q2 laselimini olumnandi lomfazi ongelambeko. 
\b  
\q1  
\v 25 Ungasuki umfise ngenhliziyo yakho ngenxa yobuhle bakhe 
\q2 kumbe akuhuge ngamehlo akhe. 
\b  
\q1  
\v 26 Ngoba isifebe siyakululazisa ufane lesinkwa, 
\q2 kodwa umfazi womuntu uyayibhidliza impilo yakho uqobo. 
\q1  
\v 27 Kambe umuntu angokhela umlilo emathangazini akhe na 
\q2 zingaze zatsha izigqoko zakhe? 
\q1  
\v 28 Kambe umuntu angahamba phezu kwamalahle 
\q2 inyawo zakhe zingaze zatsha na? 
\q1  
\v 29 Kunjalo kulowo olala lomfazi wenye indoda; 
\q2 kakho omthintayo ongayikujeziswa. 
\b  
\q1  
\v 30 Abantu kabalithuki isela 
\q2 nxa lintshontsha ngoba lifuqwa liphango. 
\q1  
\v 31 Kodwa lingabanjwa lihlawuliswa kasikhombisa, 
\q2 lanxa inhlawulo ilithathela yonke impahla yendlu yalo. 
\q1  
\v 32 Kodwa indoda efebayo kayilangqondo; 
\q2 lowo okwenzayo lokho uyazibulala yena ngokwakhe. 
\q1  
\v 33 Izidutshulo lehlazo kuyisabelo sakhe, 
\q2 ukuyangeka kwakhe kakusoze kwafa kwaphela. 
\b  
\q1  
\v 34 Ngoba ubukhwele bendoda yalowomfazi buyiqubula ulaka, 
\q2 ingabe isaba lozwelo lapho isiphindisela. 
\q1  
\v 35 Kayizukuvuma inhlawulo; 
\q2 kayiyikwamukela isivalamlomo loba singakanani. 
\c 7  
\s1 Isixwayiso Emfazini Oyisifebe 
\q1  
\v 1 Ndodana yami, agcine amazwi ami 
\q2 ulondoloze imilayo yami ngaphakathi kwakho. 
\q1  
\v 2 Gcina imilayo yami ukuze uphile; 
\q2 ulinde imfundiso yami njengegugu lakho elikhulu. 
\q1  
\v 3 Ibophele eminweni yakho; 
\q2 uyilobe enhliziyweni yakho. 
\q1  
\v 4 Tshela ukuhlakanipha uthi, “Ungudadewethu wena,” 
\q2 uthi ukuqedisisa kuyisihlobo sakho; 
\q1  
\v 5 lezizinto zizakuvikela emfazini oyisifebe, 
\q2 lakumkakho ongelambeko ngamazwi akhe adukisayo. 
\b  
\q1  
\v 6 Ngema ewindini lendlu yami 
\q2 ngalunguza ngesikhala. 
\q1  
\v 7 Ngabona phakathi kwabayizithutha, 
\q2 ngananzelela phakathi kwamajaha 
\q2 ngabona ijaha elingelangqondo. 
\q1  
\v 8 Lalisehla ngomgwaqo liseduze lejiko, 
\q2 liqonda endlini yowesifazane 
\q1  
\v 9 ntambama sekunqunda amehlo, 
\q2 umnyama wobusuku usujiya. 
\b  
\q1  
\v 10 Khonokho nje kwaqhamuka owesifazane elihlangabeza 
\q2 egqoke okwesifebe ngoba eqophile. 
\q1  
\v 11 (Umfazi lowo, ngumuntu womsindo uyisiqholo, 
\q2 inyawo zakhe kazihlali phansi; 
\q1  
\v 12 khathesi nangu emgwaqweni, njalo nangu enkundleni, 
\q2 utshobatshoba izindawana zonke.) 
\q1  
\v 13 Wafika waligona lelijaha walanga 
\q2 wakhuluma engelanhloni wathi: 
\b  
\q1  
\v 14 “Ngenzile umnikelo wobudlelwano ngekhaya; 
\q2 lamuhla ngizigcwalisile izifungo zami. 
\q1  
\v 15 Yikho ngilapha ukukuhlangabeza; 
\q2 sengikudinge ngaze ngakuthola! 
\q1  
\v 16 Sengiwendlele umbheda wami 
\q2 ngamalineni eGibhithe awemibalabala. 
\q1  
\v 17 Sengiwuqholile umbheda wami ngemure, 
\q2 ngenhlaba langesinamoni. 
\q1  
\v 18 Woza sizitike ngothando kuze kuse; 
\q2 kasizijabulise ngothando! 
\q1  
\v 19 Indoda yami kayikho ekhaya; 
\q2 ihambile iye khatshana. 
\q1  
\v 20 Ithwele isikhwama sayo sigcwele imali, 
\q2 ngakho kayibuyi kuze kube phakathi kwenyanga.” 
\b  
\q1  
\v 21 Ngamazwi akhe amnandi waledukisa ijaha lelo; 
\q2 walihuga ijaha lelo ngolimi olumnandi. 
\q1  
\v 22 Khonokho nje lahle lamlandela 
\q2 njengenkabi idonselwa ukuyabulawa, 
\q1 njengomziki uzingenisa emjibileni, 
\q2  
\v 23 umtshoko uze uyehlaba isibindi, 
\q1 njengenyoni ithothela ngaphansi kwesifu, 
\q2 ingaboni ukuthi isizingenise ekufeni. 
\b  
\q1  
\v 24 Ngakho-ke madodana ami, ngilalelani; 
\q2 zwanini lokhu engikutshoyo. 
\q1  
\v 25 Lingayivumeli inhliziyo ikhangwe yizindlela zakhe, 
\q2 langabe iphumputhekele emikhubeni yakhe. 
\q1  
\v 26 Banengi labo asebadilizile; 
\q2 izinkubela zakhe zilucaca olwesabekayo. 
\q1  
\v 27 Indlu yakhe ingumgudu oya engcwabeni, 
\q2 iholela phansi ezindongeni zokufa. 
\c 8  
\s1 Ubizo Lokuhlakanipha 
\q1  
\v 1 Ukuhlakanipha kakumemezi yini? 
\q2 Ukuqedisisa kakuphakamisi ilizwi lakho na? 
\q1  
\v 2 Emiqolweni yezindlela, 
\q2 emahlanganweni ezindlela kulapho okujame khona; 
\q1  
\v 3 emasangweni angena phakathi kwedolobho, 
\q2 ezintubeni kuyamemeza kakhulu kusithi: 
\q1  
\v 4 “Ngimemeza lina, madoda; 
\q2 ilizwi lami libiza bonke abantu. 
\q1  
\v 5 Lina eliyizithutha, zuzani ukuqonda; 
\q2 lina ziphukuphuku, zuzani ukuqedisisa. 
\q1  
\v 6 Lalelani ngoba ngilitshela izinto eziqakathekileyo; 
\q2 ngivula izindebe zami ngikhuluma okuqondileyo. 
\q1  
\v 7 Umlomo wami ukhuluma okuliqiniso, 
\q2 ngoba izindebe zami ziyabenyanya ububi. 
\q1  
\v 8 Wonke amazwi omlomo wami aqondile; 
\q2 kalikho lelilodwa elitshekileyo loba elingcolileyo. 
\q1  
\v 9 Kulowo ozwisisayo wonke alungile; 
\q2 akulankohliso kulabo abalolwazi. 
\q1  
\v 10 Khetha iseluleko sami kulesiliva, 
\q2 ulwazi kulegolide elikhethiweyo, 
\q1  
\v 11 ngoba ukuhlakanipha kuligugu okudlula amarubhi, 
\q2 njalo akulanto ongayifisa ezifisweni zakho okulingana lakho. 
\b  
\q1  
\v 12 Mina, kuhlakanipha, ngihlala ndawonye lokuqondisisa; 
\q2 ngilolwazi lokukhetha kuhle. 
\q1  
\v 13 Ukwesaba \nd uThixo\nd* yikuzonda ububi; 
\q2 ngiyakuzonda ukuzazisa lobuqholo, 
\q2 ukuziphatha kubi lenkulumo ebolileyo. 
\q1  
\v 14 Ukweluleka lokwahlulela okuhle kungokwami; 
\q2 ngilokuzwisisa lamandla. 
\q1  
\v 15 Amakhosi abusa ngenxa yami 
\q2 lababusi balakho ukutshaya imithetho elungileyo; 
\q1  
\v 16 amakhosana abusa ngami, 
\q2 lazozonke izikhulu ezibusa emhlabeni. 
\q1  
\v 17 Ngiyabathanda labo abangithandayo, 
\q2 labo abangidingayo bayangithola. 
\q1  
\v 18 Kimi kukhona inotho lodumo, 
\q2 inotho engapheliyo lokuphumelela. 
\q1  
\v 19 Izithelo zami zingcono kulegolide elicengiweyo; 
\q2 okuphuma kimi kwedlula isiliva sekhethelo. 
\q1  
\v 20 Ngihamba ngendlela yokulunga, 
\q2 ngilandela umkhondo wokuqonda, 
\q1  
\v 21 ngiyabela inotho kulabo abangithandayo 
\q2 ngigcwalise iziphala zabo. 
\b  
\q1  
\v 22 \nd UThixo\nd* wangenza ngaba khona 
\q2 ngaqalela konke okukhona, 
\q2 kuqala kokwenza ezinye izinto; 
\q1  
\v 23 ngaba khona ekudabukeni kwezinto, 
\q2 kwasekuqaleni, umhlaba ungakabi khona. 
\q1  
\v 24 Kungakabi lezilwandle, ngasengizelwe, 
\q2 kungakabi khona izihotsha ezigcwele amanzi; 
\q1  
\v 25 izintaba zingakamiswa ensikeni zazo, 
\q2 engakabi khona amaqaqa, ngasengizelwe, 
\q1  
\v 26 \nd uThixo\nd* engakawenzi umhlaba lamaganga, 
\q2 loba lonke uthuli lomhlaba. 
\q1  
\v 27 Ngangikhona \nd uThixo\nd* ehlela kuhle izulu, 
\q2 ephawula kuhle imingcele yomkhathi lolwandle, 
\q1  
\v 28 esenza amayezi emkhathini 
\q2 wazizinzisa inziki zolwandle, 
\q1  
\v 29 ebeka imingcele yolwandle 
\q2 ukuze amanzi angedluli izimiso zakhe, 
\q1 ngesikhathi lapho emisa izisekelo zomhlaba. 
\q2  
\v 30 Ngalesosikhathi ngangingumbumbi eceleni kwakhe. 
\q1 Ngangilenjabulo enkulu insuku ngensuku, 
\q2 ngithokoza ukuba laye kokuphela, 
\q1  
\v 31 ngithokoza ngomhlaba wakhe wonke 
\q2 ngijabuliswa yibukhona babantu. 
\b  
\q1  
\v 32 Ngakho-ke, madodana ami, ngilalelani; 
\q2 babusisekile labo abalondoloza izindlela zami. 
\q1  
\v 33 Lalelani imfundiso yami ukuze lihlakaniphe; 
\q2 lingaqali ukuyidela. 
\q1  
\v 34 Ubusisiwe lowomuntu ongilalelayo, 
\q2 olinda imihla yonke eminyango yami, 
\q2 elindile entubeni yami. 
\q1  
\v 35 Ngoba lowo ongifumanayo uzuza ukuphila 
\q2 emukeliswe ukuthandwa \nd nguThixo\nd*. 
\q1  
\v 36 Kodwa lowo owehlulekayo ukungifumana uyazilimaza; 
\q2 bonke abangizondayo bathanda ukufa.” 
\c 9  
\s1 Ukunxusa Kwenhlakanipho Lokobuwula 
\q1  
\v 1 Ukuhlakanipha sekuzakhele indlu yakho, 
\q2 imisiwe ngezinsika eziyisikhombisa. 
\q1  
\v 2 Isiphekiwe inyama yakho kwalungiswa lewayini; 
\q2 konke sekudekiwe etafuleni. 
\q1  
\v 3 Usewathumile amantombazana, 
\q2 uyanxusa emi ezindaweni eziphakemeyo zedolobho. 
\q2  
\v 4 “Akuthi bonke abayizithutha beze lapha!” 
\q1 Esitsho kulabo abangaqedisisiyo. 
\q2  
\v 5 “Wozani lidle ukudla kwami 
\q2 linathe iwayini esengililungisile. 
\q1  
\v 6 Lahlani izindlela zenu zobuthutha lizaphila; 
\q2 hambani ngendlela yokuzwisisa.” 
\b  
\q1  
\v 7 Lowo oweluleka oklolodayo ubiza inhlamba; 
\q2 okhuza umuntu oxhwalileyo ucina ethethiswa. 
\q1  
\v 8 Ungakhuzi isiqholo ngoba sizakuzonda; 
\q2 khuza ohlakaniphileyo uzakuthanda. 
\q1  
\v 9 Yeluleka umuntu ohlakaniphileyo 
\q2 uzakwandisa ukuhlakanipha kwakhe; 
\q2 fundisa umuntu olungileyo, uzakwengeza ulwazi lwakhe. 
\b  
\q1  
\v 10 Ukumesaba \nd uThixo\nd* kuyikuqala kwenhlakanipho, 
\q2 njalo ulwazi ngaLowo oNgcwele luyikuqedisisa. 
\q1  
\v 11 Ngoba ngami zizakuba zinengi insuku zakho, 
\q2 kwandiswe iminyaka yokuphila kwakho. 
\q1  
\v 12 Nxa uhlakaniphile, ukuhlakanipha kwakho kuzakusiza; 
\q2 aluba uyisiqholo, uzahlupheka wedwa. 
\b  
\q1  
\v 13 Umfazi othiwa nguBuwula ulomsindo; 
\q2 kagobeki njalo kazi lutho. 
\q1  
\v 14 Uthanda ukuhlala emnyango wendlu yakhe, 
\q2 esihlalweni endaweni esesiqongweni sedolobho, 
\q1  
\v 15 abe ehuga labo abedlulayo, 
\q2 abahamba beqonde lapho abaya khona. 
\q2  
\v 16 “Abeze lapha bonke abayizithutha!” 
\q1 Esitsho kulabo abangacabangiyo. 
\q2  
\v 17 “Ulutho lokuntshontshwa lumnandi; 
\q2 ukudla okudlelwa ensitha kuyahlabusa!” 
\q1  
\v 18 Kodwa kabazi ukuthi kuyafiwa, kuleyondawo, 
\q2 ukuthi izethekeli zalowomfazi sezaphelela ekujuleni kwengcwaba. 
\c 10  
\ms1 Izaga ZikaSolomoni 
\p  
\v 1 Izaga zikaSolomoni: 
\q1 Indodana ehlakaniphileyo iletha ukuthokoza kuyise, 
\q2 kodwa indoda eyisiwula iletha ukudabuka kunina. 
\b  
\q1  
\v 2 Inotho ezuzwe ngobuqili kayisizi lutho, 
\q2 kodwa ukulunga kukhulula ekufeni. 
\b  
\q1  
\v 3 \nd UThixo\nd* kayekeli abalungileyo belambile 
\q2 kodwa uyavimbela izinkanuko zezixhwali. 
\b  
\q1  
\v 4 Izandla ezivilaphayo ziletha ubuyanga, 
\q2 kodwa izandla ezikhutheleyo ziletha inotho. 
\b  
\q1  
\v 5 Lowo obutha amabele ngesikhathi sawo yindodana ehlakaniphileyo, 
\q2 kodwa olalayo ngesikhathi sokuvuna yindodana ehlazisayo. 
\b  
\q1  
\v 6 Izibusiso zingumqhele womuntu olungileyo. 
\q2 Kodwa ubudlwangudlwangu bugcwele emlonyeni womubi. 
\b  
\q1  
\v 7 Umkhumbulo ngomuntu olungileyo ubusisekile 
\q2 kodwa ibizo lesigangi lizabola. 
\b  
\q1  
\v 8 Abahlakaniphileyo enhliziyweni bayalalela izeluleko, 
\q2 kodwa isiphukuphuku esivala ngomsindo siyadilika. 
\b  
\q1  
\v 9 Umuntu oqotho uhamba engelakwesaba, 
\q2 kodwa ohamba ngezindlela ezigobileyo uzadaluleka. 
\b  
\q1  
\v 10 Lowo oqwayiza ngomona uletha usizi, 
\q2 lesiphukuphuku esivala ngomsindo siyadilika. 
\b  
\q1  
\v 11 Umlomo womuntu olungileyo ungumthombo wokuphila, 
\q2 kodwa ubudlwangudlwangu bugcwele emlonyeni womubi. 
\b  
\q1  
\v 12 Inzondo idunga ingxabano, 
\q2 kodwa uthando lusibekela bonke ububi. 
\b  
\q1  
\v 13 Ukuhlakanipha kufunyanwa ezindebeni zalowo oqedisisayo; 
\q2 kodwa uswazi lwehla emhlane walowo ongezwayo. 
\b  
\q1  
\v 14 Abantu abahlakaniphileyo bayaluqoqa ulwazi, 
\q2 kodwa umlomo wesiwula ugwegwa ukubhidlika. 
\b  
\q1  
\v 15 Inotho yezikhulu ingumuzi wazo ovikelweyo; 
\q2 kodwa ubuyanga buyikudilika kwabampofu. 
\b  
\q1  
\v 16 Inzuzo yabalungileyo iyabaphilisa, 
\q2 kodwa umholo wababi ubalethela ukujeziswa. 
\b  
\q1  
\v 17 Lowo olalela ukuqondiswa utshengisa indlela yokuphila, 
\q2 kodwa lowo oyala ukwelulekwa wedukisa abanye. 
\b  
\q1  
\v 18 Lowo ofihla inzondo yakhe ulendebe ezilamanga, 
\q2 kuthi lowo onyeyayo yisiwula. 
\b  
\q1  
\v 19 Lapho okwande khona amazwi, isono kasisweleki, 
\q2 kodwa lowo ogcina ulimi lwakhe uhlakaniphile. 
\b  
\q1  
\v 20 Ulimi lomuntu olungileyo luyisiliva esikhethiweyo, 
\q2 kodwa inhliziyo yesigangi kayisilutho. 
\b  
\q1  
\v 21 Izindebe zolungileyo ziphilisa abanengi; 
\q2 kodwa iziwula ziyafa ngokuswela ingqondo. 
\b  
\q1  
\v 22 Isibusiso \nd sikaThixo\nd* siletha inotho, 
\q2 leyonotho ingabi lahlupho. 
\b  
\q1  
\v 23 Isiwula siyajabula ezenzweni zobubi, 
\q2 kodwa umuntu ozwisisayo uthokoza ngokuhlakanipha. 
\b  
\q1  
\v 24 Lokho akwesabayo omubi kuzamfumana; 
\q2 kodwa lokho akuloyisayo olungileyo uzakuphiwa. 
\b  
\q1  
\v 25 Nxa isiphepho sesikhukhule sedlula, 
\q2 ababi sebedlule, kodwa abalungileyo bagxilile lanini. 
\b  
\q1  
\v 26 Njengeviniga emlonyeni, lentuthu emehlweni, 
\q2 unjalo olesidensi kulabo abamthumayo. 
\b  
\q1  
\v 27 Ukumesaba \nd uThixo\nd* kuyengeza ubude bempilo, 
\q2 kodwa iminyaka yababi iyafinyezwa. 
\b  
\q1  
\v 28 Ikusasa yabalungileyo iyikuthokoza, 
\q2 kodwa amathemba ababi aphelela ezeni. 
\b  
\q1  
\v 29 Indlela \nd kaThixo\nd* yisiphephelo sabalungileyo, 
\q2 kodwa iyikubhidlika kwalabo abenza okubi. 
\b  
\q1  
\v 30 Abalungileyo kabasiphuleki, 
\q2 kodwa ababi kabayikusala elizweni. 
\b  
\q1  
\v 31 Umlomo womuntu olungileyo ukhupha inhlakanipho, 
\q2 kodwa ulimi oluxhwalileyo luzaqunywa. 
\b  
\q1  
\v 32 Izindebe zabalungileyo ziyakwazi okufaneleyo, 
\q2 kodwa umlomo wezigangi ukhupha izibozi. 
\b  
\c 11  
\q1  
\v 1 \nd UThixo\nd* uyazenyanya izilinganiso zokudlelezela, 
\q2 kodwa uthokoza ngezilinganiso eziqondileyo. 
\b  
\q1  
\v 2 Nxa kungena ukuzigqaja kungena lokweyisa, 
\q2 kodwa ukuzithoba kuhamba lenhlakanipho. 
\b  
\q1  
\v 3 Ubuqotho kwabaqondileyo buyabakhokhela, 
\q2 kodwa abangathembekanga 
\q2 babulawa yibumenemene babo. 
\b  
\q1  
\v 4 Inotho kayisizi lutho ngosuku lweziphithiphithi 
\q2 kodwa ukulunga kuyaphephisa ekufeni. 
\b  
\q1  
\v 5 Ukulunga kwabangelacala kuqondisa indlela yabo, 
\q2 kodwa ababi bawiswa yibubi babo. 
\b  
\q1  
\v 6 Ukulunga kwabaqondileyo kuyabakhulula, 
\q2 kodwa abangathembekanga 
\q2 bagwenxwa yizinkanuko zabo ezimbi. 
\b  
\q1  
\v 7 Umuntu omubi angafa ithemba lakhe liyaphela; 
\q2 konke abesithi uzakuzuza ngamandla akhe 
\q2 kuphelela ezeni. 
\b  
\q1  
\v 8 Umuntu olungileyo uyakhululwa enkathazweni, 
\q2 kusuke kuyewela komubi. 
\b  
\q1  
\v 9 Ngomlomo wakhe umuntu ongakholwayo uyamchitha umakhelwane, 
\q2 kodwa ngolwazi abalungileyo bayaphepha. 
\b  
\q1  
\v 10 Nxa kuphumelela abalungileyo umuzi uyathokoza; 
\q2 nxa kusifa omubi kuba lokujabula. 
\b  
\q1  
\v 11 Ngokubusiswa ngabalungileyo omubi ubalodumo, 
\q2 kodwa ngomlomo wezigangi uyachitheka. 
\b  
\q1  
\v 12 Umuntu ongelangqondo weyisa umakhelwane wakhe, 
\q2 kodwa umuntu ozwisisayo uthiba ulimi lwakhe. 
\b  
\q1  
\v 13 Onyeyayo wehluleka ukuvala isifuba sakhe, 
\q2 kodwa othembekileyo uyayigcina imfihlo. 
\b  
\q1  
\v 14 Isizwe esingelabukhokheli obuqondileyo siyachitheka, 
\q2 kodwa ngobunengi babeluleki siyanqoba. 
\b  
\q1  
\v 15 Lowo okhuphela omunye umuntu isibambiso uzahlupheka, 
\q2 kodwa owalayo ukupha isibambiso uvikelekile. 
\b  
\q1  
\v 16 Umfazi olomusa uyahlonitshwa, 
\q2 kodwa amadoda alesihluku azuza inotho kuphela. 
\b  
\q1  
\v 17 Umuntu olomusa uyazisiza, 
\q2 kodwa umuntu ololunya uyazilimaza. 
\b  
\q1  
\v 18 Umuntu omubi uhola umvuzo wobuqili, 
\q2 kodwa lowo ohlanyela ukulunga uvuna umvuzo omuhle. 
\b  
\q1  
\v 19 Lowo omiyo ekulungeni uzuza ukuphila, 
\q2 kodwa oxotshana lobubi uya ekufeni. 
\b  
\q1  
\v 20 \nd UThixo\nd* uyabazonda abantu abalenhliziyo embi, 
\q2 kodwa uyathokoza ngalabo abandlela zabo zilungile. 
\b  
\q1  
\v 21 Kodwa yazi lokhu, ababi bazajeziswa 
\q2 kodwa abalungileyo bazahlala bekhululekile. 
\b  
\q1  
\v 22 Njengesongo legolide lifakwe emakhaleni engulube, 
\q2 unjalo umfazi omuhle kodwa ongelambeko. 
\b  
\q1  
\v 23 Izifiso zabalungileyo zizuza okuhle 
\q2 kodwa ithemba lababi liphelela osizini. 
\b  
\q1  
\v 24 Ophayo ngesihle uyazuza okunengi kulakuqala, 
\q2 lowo ogodlayo ungenelwa yibuyanga. 
\b  
\q1  
\v 25 Lowo ophayo uzaphumelela; 
\q2 owonga abanye laye uzakongiwa. 
\b  
\q1  
\v 26 Abantu bayamqalekisa lowo ogodla amabele, 
\q2 kodwa izibusiso zingumqhele walowo ovuma ukuwathengisa. 
\b  
\q1  
\v 27 Lowo odinga ukulunga uzuza umusa, 
\q2 kodwa okubi kwehlela lowo okudingayo. 
\b  
\q1  
\v 28 Othembele enothweni yakhe uzakuwa; 
\q2 kodwa olungileyo uzaphila njengehlamvu eliluhlaza. 
\b  
\q1  
\v 29 Olethela abendlu yakhe uhlupho ilifa lakhe yize, 
\q2 lesihawu sizakuba yinceku yohlakaniphileyo. 
\b  
\q1  
\v 30 Izithelo zolungileyo ziyisihlahla sokuphila, 
\q2 njalo lowo ozuza imiphefumulo uhlakaniphile. 
\b  
\q1  
\v 31 Nxa abalungileyo bezuza ukujeziswa emhlabeni 
\q2 pho kuzakuba njani kwabangakholwayo labayizoni! 
\b  
\c 12  
\q1  
\v 1 Othanda ukuqondiswa uthanda ulwazi, 
\q2 kodwa ozonda ukukhuzwa uyisithutha. 
\b  
\q1  
\v 2 Umuntu olungileyo uthola umusa \nd kuThixo\nd*, 
\q2 kodwa \nd uThixo\nd* uyamlahla owakha amacebo amabi. 
\b  
\q1  
\v 3 Umuntu angazake amiswe yibubi, 
\q2 kodwa olungileyo angeke aquphuke. 
\b  
\q1  
\v 4 Umfazi olesimilo ungumqhele womkakhe, 
\q2 kodwa umfazi oyangisayo unjengokubola kwamathambo akhe. 
\b  
\q1  
\v 5 Izimiso zabalungileyo ziqondile, 
\q2 kodwa izeluleko zababi ziyinkohliso. 
\b  
\q1  
\v 6 Amazwi ababi alindele ukuchitha igazi, 
\q2 kodwa inkulumo yabalungileyo iyabakhulula. 
\b  
\q1  
\v 7 Abantu ababi bayachithwa bangabe besaba khona, 
\q2 kodwa indlu yolungileyo imi izinzile. 
\b  
\q1  
\v 8 Umuntu udunyiswa ngokuhlakanipha kwakhe, 
\q2 kodwa abantu abalengqondo ezimbi bayeyiswa. 
\b  
\q1  
\v 9 Kungcono ukungabi ngubani kodwa ulesisebenzi, 
\q2 kulokuzitshaya ulutho kodwa uswela lokudla. 
\b  
\q1  
\v 10 Umuntu olungileyo uyayinanzelela imfuyo yakhe 
\q2 kodwa okuhle komuntu omubi yilunya. 
\b  
\q1  
\v 11 Lowo osebenza nzima emasimini akhe uzathola ukudla okunengi, 
\q2 kodwa lowo ophika ngezifiso eziyize akalangqondo. 
\b  
\q1  
\v 12 Ababi bahawukela impango yezigangi, 
\q2 kodwa impande yabalungileyo imi iqinile. 
\b  
\q1  
\v 13 Umuntu omubi uthiyeka ngenkulumo yakhe yesono, 
\q2 kodwa umuntu olungileyo uyaphepha enkathazweni. 
\b  
\q1  
\v 14 Umuntu uzuza okuhle ngamazwi omlomo wakhe, 
\q2 umsebenzi wezandla zakhe umnika inzuzo. 
\b  
\q1  
\v 15 Indlela yesiwula ikhanya iqondile kuso, 
\q2 kodwa umuntu ohlakaniphileyo uyalalela izeluleko. 
\b  
\q1  
\v 16 Isiwula siyaphangisa ukuthukuthela, 
\q2 kodwa umuntu olengqondo kananzi loba ethukwa. 
\b  
\q1  
\v 17 Umfakazi oleqiniso upha ubufakazi obuqondileyo, 
\q2 kodwa umfakazi ongathembekanga ukhuluma amanga. 
\b  
\q1  
\v 18 Amazwi okubhuda agwaza njengenkemba, 
\q2 kodwa ulimi lohlakaniphileyo luyelapha. 
\b  
\q1  
\v 19 Izindebe zeqiniso zimi lanini, 
\q2 kodwa ulimi olulamanga luma umzuzwana nje. 
\b  
\q1  
\v 20 Inhliziyo zabaceba ububi zigcwele inkohliso, 
\q2 kodwa kulokuthokoza kwabaletha ukuthula. 
\b  
\q1  
\v 21 Akukho ngozi ewela abalungileyo, 
\q2 kodwa izigangi zikhulelwa zinhlupho. 
\b  
\q1  
\v 22 \nd UThixo\nd* uyazenyanya izindlela ezilamanga, 
\q2 kodwa uyathokoza ngabantu abaleqiniso. 
\b  
\q1  
\v 23 Umuntu olengqondo kazitshengiseli ulwazi lwakhe, 
\q2 kodwa iziwula ziyabutshengisela ubuthutha bazo. 
\b  
\q1  
\v 24 Izandla ezikhutheleyo zizaletha inhlalakahle, 
\q2 kodwa ubuvila budonsela ekugqilazweni. 
\b  
\q1  
\v 25 Inhliziyo ekhathazekileyo iyamcakisa umuntu, 
\q2 kodwa ilizwi elilomusa liyamthokozisa. 
\b  
\q1  
\v 26 Umuntu olungileyo ukhetha abangane ngonanzelelo, 
\q2 kodwa indlela yababi iyabaphumputhekisa. 
\b  
\q1  
\v 27 Umzingeli olivila kazuzi nyama yokosa, 
\q2 kodwa umuntu okhutheleyo uyazibula ngenotho yakhe. 
\b  
\q1  
\v 28 Endleleni yokulunga kulokuphila, 
\q2 kuleyondlela kulokuphila okungapheliyo. 
\b  
\c 13  
\q1  
\v 1 Indodana ehlakaniphileyo iyemukela izeluleko zikayise, 
\q2 kodwa ihlongandlebe kalilaleli nxa likhuzwa. 
\b  
\q1  
\v 2 Umuntu uzuza okuhle ngamazwi omlomo wakhe, 
\q2 kodwa ababi batshisekela udlakela. 
\b  
\q1  
\v 3 Lowo olinda izindebe zakhe ulinda impilo yakhe, 
\q2 kodwa lowo osuka abhede nje uyazibulala. 
\b  
\q1  
\v 4 Ivila liyafisa kodwa lingazuzi lutho, 
\q2 kodwa izifiso zokhutheleyo ziyagcwaliseka. 
\b  
\q1  
\v 5 Abalungileyo bayakuzonda okungamanga, 
\q2 kodwa izigangi ziletha ihlazo lesigcono. 
\b  
\q1  
\v 6 Ukulunga kuyamlinda umuntu oqotho, 
\q2 kodwa ububi buyamchitha oyisoni. 
\b  
\q1  
\v 7 Umuntu angazenza onothileyo, yena engelalutho, 
\q2 omunye azitshaye umyanga, kanti elenotho enengi. 
\b  
\q1  
\v 8 Inotho yomuntu ingahlenga impilo yakhe, 
\q2 kodwa umyanga uvele kasongelwa muntu. 
\b  
\q1  
\v 9 Isibane sabalungileyo sikhanya sithi kla! 
\q2 Kodwa isibane sezigangi siyafiphala ngentuthu. 
\b  
\q1  
\v 10 Ukuziqakisa kukhokhelela engxabanweni, 
\q2 kodwa ukuhlakanipha kufunyanwa kwabemukela ukwelulekwa. 
\b  
\q1  
\v 11 Imali ezuzwe ngobuqili iyanyamalala, 
\q2 kodwa lowo oyizuza ngokuqogelela uyayandisa. 
\b  
\q1  
\v 12 Ithemba eliphuzayo ligulisa inhliziyo, 
\q2 kodwa isifiso esigcwalisiweyo siyisihlahla sokuphila. 
\b  
\q1  
\v 13 Lowo oweyisa izeluleko uzibizela ingozi, 
\q2 kodwa othobela umlayo uzaphiwa umvuzo. 
\b  
\q1  
\v 14 Imfundiso yabahlakaniphileyo ingumthombo wokuphila, 
\q2 iphephisa umuntu emijibileni yokufa. 
\b  
\q1  
\v 15 Ukuzwisisa okuhle kuletha ukuthandeka, 
\q2 kodwa indlela yabakhohlisayo inzima. 
\b  
\q1  
\v 16 Wonke umuntu ohlakaniphileyo wenza konke ngolwazi, 
\q2 kodwa isiwula sitshengisa ubuthutha baso. 
\b  
\q1  
\v 17 Isithunywa esibi siwela phakathi kohlupho, 
\q2 kodwa isithunywa esithembekileyo siletha ukusila. 
\b  
\q1  
\v 18 Ongananzi ukuqondiswa wehlelwa yibuyanga lehlazo, 
\q2 kodwa onanza ukukhuzwa uyadunyiswa. 
\b  
\q1  
\v 19 Simnandi emphefumulweni isifiso singagcwaliseka, 
\q2 kodwa iziwula kazifuni ukutshiya ububi. 
\b  
\q1  
\v 20 Ohamba lezihlakaniphi uyahlakanipha, 
\q2 kodwa othandana leziwula uwela engozini. 
\b  
\q1  
\v 21 Umnyama ulandelana loyisoni, 
\q2 kodwa impumelelo ingumvuzo wabalungileyo. 
\b  
\q1  
\v 22 Umuntu olungileyo utshiyela izizukulwane sakhe ilifa, 
\q2 kodwa inotho yesoni ibekelwa abalungileyo. 
\b  
\q1  
\v 23 Insimu yomyanga ingathela ukudla okunengi, 
\q2 kodwa umona wabalamandla uyayikhukhula. 
\b  
\q1  
\v 24 Lowo ongasebenzisi uswazi uyayizonda indodana yakhe, 
\q2 kodwa lowo oyithandayo unqinekela ukuyiqondisa. 
\b  
\q1  
\v 25 Olungileyo uyadla asuthe ntintinini, 
\q2 kodwa isisu somubi sihlala silambile. 
\b  
\c 14  
\q1  
\v 1 Umfazi ohlakaniphileyo uyakha indlu yakhe, 
\q2 kodwa lowo oyisiwula uyayibhidliza ngezandla zakhe. 
\b  
\q1  
\v 2 Lowo ohamba ngobuqotho uyamesaba \nd uThixo\nd*, 
\q2 kodwa lowo ondlela zakhe zigobile uyameyisa. 
\b  
\q1  
\v 3 Inkulumo yesiwula isikhothisa ngoswazi emhlane, 
\q2 kodwa indebe zalowo ohlakaniphileyo ziyamvikela. 
\b  
\q1  
\v 4 Lapho okungelankabi khona isibaya siyize, 
\q2 kodwa amandla enkabi aletha isivuno esinengi. 
\b  
\q1  
\v 5 Umfakazi oleqiniso kakhohlisi, 
\q2 kodwa umfakazi ongelaqiniso uhutsha amanga. 
\b  
\q1  
\v 6 Oweyisayo uyakudinga ukuhlakanipha kodwa kakutholi, 
\q2 kodwa ulwazi luyazizela koqondisisayo. 
\b  
\q1  
\v 7 Suka emuntwini oyisiwula, 
\q2 ngoba awuyikuthola ulwazi ezindebeni zakhe. 
\b  
\q1  
\v 8 Ukuhlakanipha kwabaqondayo yikuthi bayacabanga ngalokho abakwenzayo, 
\q2 kodwa ubuthutha beziwula buyinkohliso. 
\b  
\q1  
\v 9 Iziwula zikwenza ubuthutha ukuphenduka ezonweni, 
\q2 kodwa abaqotho bafisa ukwenza uxolo. 
\b  
\q1  
\v 10 Inhliziyo leyo laleyo iyakwazi ukudabuka kwayo, 
\q2 njalo kakho ongakwazi ukuthokoza kwayo. 
\b  
\q1  
\v 11 Indlu yomubi izadilizwa, 
\q2 kodwa ithente loqotho lizaphumelela. 
\b  
\q1  
\v 12 Kukhona indlela ebonakala ilungile emuntwini, 
\q2 kodwa isiphetho sayo siyikufa. 
\b  
\q1  
\v 13 Ukuhleba kungabe kufihle ubuhlungu benhliziyo, 
\q2 lokuthokoza kucine sekulusizi. 
\b  
\q1  
\v 14 Abangelakho bazavuzwa ngokubafaneleyo, 
\q2 lomuntu olungileyo laye avuzwe ngokwakhe. 
\b  
\q1  
\v 15 Umuntu oyisithutha ukholwa loba yini, 
\q2 kodwa olengqondo uyakucabangisisa konke akwenzayo. 
\b  
\q1  
\v 16 Umuntu ohlakaniphileyo uyamesaba \nd uThixo\nd*, axwaye okubi, 
\q2 kodwa isiwula siliphikankani kodwa sizizwa sivikelekile. 
\b  
\q1  
\v 17 Umuntu olicaphucaphu wenza izinto zobuthutha, 
\q2 lomuntu oliqili uyazondwa. 
\b  
\q1  
\v 18 Abangazi lutho ilifa labo yibuwula, 
\q2 kodwa abalengqondo betheswa umqhele wolwazi. 
\b  
\q1  
\v 19 Abantu ababi bazilahla phansi phambi kwabalungileyo, 
\q2 lezixhwali ziguqa emasangweni abalungileyo. 
\b  
\q1  
\v 20 Abayanga bahlanyukelwa langabomakhelwane babo, 
\q2 kodwa izinothi zilabangane abanengi. 
\b  
\q1  
\v 21 Lowo oweyisa umakhelwane wenza isono, 
\q2 kodwa ubusisiwe olomusa kwabaswelayo. 
\b  
\q1  
\v 22 Kabalahleki yini abaceba ububi? 
\q2 Kodwa abamisa ukwenza okuhle bafumana uthando lokuthembeka. 
\b  
\q1  
\v 23 Ukusebenza nzima konke kuletha inzuzo, 
\q2 kodwa ukuqina ngomlomo kuthelela ubuyanga. 
\b  
\q1  
\v 24 Inotho yabahlakaniphileyo ingumqhele wabo, 
\q2 kodwa ubuphukuphuku beziwula buzala ubuthutha. 
\b  
\q1  
\v 25 Umfakazi oleqiniso uyabakhulula abantu, 
\q2 kodwa umfakazi wamanga uyakhohlisa. 
\b  
\q1  
\v 26 Lowo owesaba \nd uThixo\nd* ulenqaba eqinileyo, 
\q2 uzakuba yisiphephelo senzalo yakhe. 
\b  
\q1  
\v 27 Ukumesaba \nd uThixo\nd* kungumthombo wokuphila, 
\q2 kuvikela umuntu emijibileni yokufa. 
\b  
\q1  
\v 28 Ubunengi babantu elizweni kuludumo enkosini, 
\q2 kodwa nxa kungelabantu umbusi kasilutho. 
\b  
\q1  
\v 29 Umuntu obekezelayo uyazwisisa kakhulu, 
\q2 kodwa ophanga ukuthukuthela uveza ubuthutha. 
\b  
\q1  
\v 30 Ingqondo elokuthula iletha ukuphila emzimbeni, 
\q2 kodwa umhawu ubolisa amathambo. 
\b  
\q1  
\v 31 Lowo oncindezela abayanga weyisa uMenzi wabo, 
\q2 kodwa olomusa kwabaswelayo udumisa uNkulunkulu. 
\b  
\q1  
\v 32 Nxa kufika ubunzima ababi bayadilika, 
\q2 kodwa abalungileyo balesiphephelo lasekufeni. 
\b  
\q1  
\v 33 Ukuhlakanipha kuzinzile enhliziyweni yabaqedisisayo, 
\q2 kuyaziveza kanye lakwabayiziwula. 
\b  
\q1  
\v 34 Ukulunga kuyasiphakamisa isizwe, 
\q2 kodwa isono silihlazo lakubaphi abantu. 
\b  
\q1  
\v 35 Inkosi iyathokoza ngenceku ehlakaniphileyo, 
\q2 kodwa inceku ehlazisayo iyayithukuthelisa. 
\b  
\c 15  
\q1  
\v 1 Impendulo ethobekileyo iyaludedisa ulaka, 
\q2 kodwa ilizwi elilukhuni livusa ulaka. 
\b  
\q1  
\v 2 Ulimi lomuntu ohlakaniphileyo lukhulisa ulwazi, 
\q2 kodwa umlomo wesiwula uphihlika ubuphukuphuku. 
\b  
\q1  
\v 3 Amehlo \nd kaThixo\nd* asezindaweni zonke, 
\q2 alinde ababi labalungileyo. 
\b  
\q1  
\v 4 Ulimi oluletha ukuphola luyisihlahla sokuphila, 
\q2 kodwa ulimi olukhohlisayo luyawephula umoya. 
\b  
\q1  
\v 5 Isiwula siyakulahla ukulaya kukayise, 
\q2 kodwa owemukela ukuqondiswa uveza ukuhlakanipha. 
\b  
\q1  
\v 6 Indlu yolungileyo igcwele inotho, 
\q2 kodwa inzuzo yababi ibehlisela uhlupho. 
\b  
\q1  
\v 7 Izindlela zabahlakaniphileyo ziyalwandisa ulwazi, 
\q2 kodwa kazenzi njalo inhliziyo zeziwula. 
\b  
\q1  
\v 8 \nd UThixo\nd* uyawenyanya umhlatshelo wababi, 
\q2 kodwa umkhuleko wabaqotho uyamthokozisa. 
\b  
\q1  
\v 9 \nd UThixo\nd* uyayenyanya indlela yababi, 
\q2 kodwa uyabathanda labo abalandela ukulunga. 
\b  
\q1  
\v 10 Ukujeziswa okubuhlungu kumlindele ophambuka endleleni; 
\q2 ozonda ukuqondiswa uzakufa. 
\b  
\q1  
\v 11 UKufa lokuBhujiswa kusobala phambi \nd kukaThixo\nd* 
\q2 kangakanani ke inhliziyo zabantu! 
\b  
\q1  
\v 12 Isideleli siyakuzonda ukuqondiswa; 
\q2 kasibuzi kwabahlakaniphileyo. 
\b  
\q1  
\v 13 Inhliziyo ethokozayo yenza ubuso buchelese, 
\q2 kodwa inhliziyo ebuhlungu yephula umoya. 
\b  
\q1  
\v 14 Inhliziyo eqedisisayo idinga ulwazi, 
\q2 kodwa umlomo wesiwula wongiwa ngobuthutha. 
\b  
\q1  
\v 15 Zonke insuku zabancindezelweyo zilukhuni, 
\q2 kodwa inhliziyo ethokozileyo ihlezi iminza. 
\b  
\q1  
\v 16 Kungcono ukuba lokulutshwana umesaba \nd uThixo\nd* 
\q2 kulokuba lenotho enengi ulenhlupho. 
\b  
\q1  
\v 17 Kungcono ukutsheba ngemibhida lapho okulothando khona, 
\q2 kulokudla inyama enonileyo okugcwele khona inzondo. 
\b  
\q1  
\v 18 Ololaka oluvuthayo ubanga ukuxabana, 
\q2 kodwa umuntu obekezelayo uqeda inkani. 
\b  
\q1  
\v 19 Indlela yevila igcwele ameva, 
\q2 kodwa indlela yomuntu olungileyo ikhamisile. 
\b  
\q1  
\v 20 Indodana ehlakaniphileyo iletha intokozo kuyise, 
\q2 kodwa indoda eyisiwula yeyisa unina. 
\b  
\q1  
\v 21 Ubuthutha bujabulisa umuntu ongelangqondo, 
\q2 kodwa umuntu olokuzwisisa uhamba ngendlela eqondileyo. 
\b  
\q1  
\v 22 Amaqhinga ayehluleka nxa kungelazeluleko, 
\q2 kodwa ayaphumelela ngabeluleki abanengi. 
\b  
\q1  
\v 23 Umuntu uyathokoza ngokupha impendulo eqondileyo 
\q2 yeka kuhle kangakanani ukuzwa ilizwi elifaneleyo! 
\b  
\q1  
\v 24 Indlela yempilo iyimpumelelo kohlakaniphileyo 
\q2 ukuze angalengeli engcwabeni. 
\b  
\q1  
\v 25 \nd UThixo\nd* uyayibhidliza indlu yomuntu oziphakamisayo, 
\q2 kodwa indawo yomfelokazi kayiyikuncitshiswa. 
\b  
\q1  
\v 26 \nd UThixo\nd* uyayizonda imicabango yababi, 
\q2 kodwa leyo eyabalungileyo iyamthabisa. 
\b  
\q1  
\v 27 Indoda eyisihwaba iluhlupho kwabendlu yayo, 
\q2 kodwa lowo ozonda ukufunjathiswa uzaphila. 
\b  
\q1  
\v 28 Olungileyo uyayihlolisisa impendulo engakaphenduli, 
\q2 kodwa umlomo womubi ukhihliza okubi. 
\b  
\q1  
\v 29 \nd UThixo\nd* ukhatshana kwababi, 
\q2 kodwa uyezwa umkhuleko wabalungileyo. 
\b  
\q1  
\v 30 Ubuso obubobothekayo buletha intokozo enhliziyweni, 
\q2 lezindaba ezinhle ziqinisa umzimba. 
\b  
\q1  
\v 31 Lowo olalela ukukhuzwa okumphilisayo, 
\q2 uzahlala kuhle labahlakaniphileyo. 
\b  
\q1  
\v 32 Lowo onganaki ukulaywa uyazeyisa yena ngokwakhe, 
\q2 kodwa onanza iziqondiso uzuza ukuzwisisa. 
\b  
\q1  
\v 33 Ukumesaba \nd uThixo\nd* kufundisa umuntu ukuhlakanipha, 
\q2 njalo ukuzithoba kwandulela udumo. 
\b  
\c 16  
\q1  
\v 1 Umuntu angawabumba amacebo ngenhliziyo yakhe, 
\q2 kodwa \nd uThixo\nd* nguye omupha amazwi okuwachaza. 
\b  
\q1  
\v 2 Umuntu angabona sengathi zonke izindlela zakhe ziqondile, 
\q2 kodwa \nd uThixo\nd* uyazihlolisisa zonke injongo zomuntu. 
\b  
\q1  
\v 3 Nikela \nd kuThixo\nd* konke okwenzayo, 
\q2 kuzaphumelelisa wonke amacebo akho. 
\b  
\q1  
\v 4 \nd UThixo\nd* uzilungisele isiphetho sakho konke 
\q2 kanye lababi usuku lokubhujiswa. 
\b  
\q1  
\v 5 \nd UThixo\nd* uyabazonda bonke abazikhukhumezayo. 
\q2 Ngempela kabayikuphepha ukujeziswa. 
\b  
\q1  
\v 6 Isono siyahlawulelwa ngothando langokwethembeka; 
\q2 ngokwesaba \nd uThixo\nd* umuntu uyaphepha ebubini. 
\b  
\q1  
\v 7 Nxa izindlela zomuntu zimthokozisa \nd uThixo\nd*, 
\q2 uyenza lezitha zakhe zihlalisane laye ngokuthula. 
\b  
\q1  
\v 8 Kungcono ukuzuza okulutshwana ngendlela elungileyo 
\q2 kulokuzuza okunengi ngobuqili. 
\b  
\q1  
\v 9 Umuntu angalungisa indlela yakhe engqondweni yakhe, 
\q2 kodwa \nd uThixo\nd* nguye olawula izinyathelo zakhe. 
\b  
\q1  
\v 10 Izindebe zombusi zikhuluma kungathi lidlozi 
\q2 ngakho umlomo wakhe kawungaphambuli umthetho. 
\b  
\q1  
\v 11 Izilinganiso eziqondileyo zivela \nd kuThixo\nd*; 
\q2 zonke izisindo ezisemgodleni zenziwa nguye. 
\b  
\q1  
\v 12 Amakhosi ayakuzonda ukwenza okubi, 
\q2 ngoba isihlalo sobukhosi sakhelwe phezu kokulunga. 
\b  
\q1  
\v 13 Amakhosi athokoziswa yizindebe ezithembekileyo; 
\q2 ayamazisa umuntu okhuluma iqiniso. 
\b  
\q1  
\v 14 Ulaka lwenkosi luyisithunywa sokufa, 
\q2 kodwa umuntu ohlakaniphileyo uyaluxolisa. 
\b  
\q1  
\v 15 Nxa ubuso benkosi bulentokozo, kukhomba ukuphila; 
\q2 ukuthandwa yiyo kunjengeyezi lezulu entwasa. 
\b  
\q1  
\v 16 Kungcono kangakanani ukuzuza ukuhlakanipha kulegolide, 
\q2 ukukhetha ukuzwisisa kulesiliva! 
\b  
\q1  
\v 17 Umgwaqo womuntu oqotho uceza ububi; 
\q2 lowo onanzelelayo indlela yakhe unanzelela impilo yakhe. 
\b  
\q1  
\v 18 Ukuzigqaja kwandulela ukubhujiswa, 
\q2 umoya omubi ulandelwa yikuwa. 
\b  
\q1  
\v 19 Kungcono umoya othobekileyo lokuhlala kwabancindezelweyo 
\q2 kulokwabelana impango labazigqajayo. 
\b  
\q1  
\v 20 Lowo olalela izeluleko uyaphumelela, 
\q2 njalo ubusisiwe lowo othemba \nd uThixo\nd*. 
\b  
\q1  
\v 21 Abahlakaniphileyo enhliziyweni kuthiwa bayaqedisisa, 
\q2 njalo amazwi amnandi aqinisa izeluleko. 
\b  
\q1  
\v 22 Ukuzwisisa kungumthombo wokuphila kulabo abalakho, 
\q2 kodwa ubuwula buletha isijeziso eziwuleni. 
\b  
\q1  
\v 23 Inhliziyo yomuntu ohlakaniphileyo ikhokhela umlomo wakhe, 
\q2 kanti lezindebe zakhe zikhuthaza izeluleko. 
\b  
\q1  
\v 24 Amazwi amahle alikhekheba loluju, 
\q2 amnandi emphefumulweni njalo ayelapha emathanjeni. 
\b  
\q1  
\v 25 Kukhona indlela ebonakala ilungile emuntwini, 
\q2 kodwa isiphetho sayo siyikufa. 
\b  
\q1  
\v 26 Isisebenzi sifuqwa liphango ukusebenza kakhulu; 
\q2 ukulamba yikho okusikhuthazayo. 
\b  
\q1  
\v 27 Isixhwali siceba ububi, 
\q2 lenkulumo yaso injengomlilo ohaqazayo. 
\b  
\q1  
\v 28 Umuntu ongelangqondo udaza inkani, 
\q2 njalo lomuntu onyeyayo wehlukanisa abangane. 
\b  
\q1  
\v 29 Umuntu wodlakela uhuga umakhelwane wakhe 
\q2 amholele endleleni engalunganga. 
\b  
\q1  
\v 30 Lowo ofica ngelihlo lakhe uceba izibozi; 
\q2 lowo oluma indebe zakhe uqonde ububi. 
\b  
\q1  
\v 31 Inwele ezimhlophe zingumqhele wobukhulu, 
\q2 zizuzwa ngempilo elungileyo. 
\b  
\q1  
\v 32 Ungcono umuntu obekezelayo kuleqhawe, 
\q2 umuntu ozinqandayo ulaka lwakhe kulalowo othumba idolobho. 
\b  
\q1  
\v 33 Inkatho iphoselwa enkundleni, 
\q2 kodwa isinqumo sayo sisemandleni \nd kaThixo\nd*. 
\b  
\c 17  
\q1  
\v 1 Lungcono uqweqwe lwesinkwa umuntu elokuthula 
\q2 kulendlu egcwele amagqibhagqibha okudla 
\q2 kodwa kulengxabano. 
\b  
\q1  
\v 2 Isisebenzi esihlakaniphileyo sizabusa indodana eyangisayo, 
\q2 sizakwabelwa ilifa njengomunye wamadodana. 
\b  
\q1  
\v 3 Isiliva sincibilikiselwa embizeni, 
\q2 imvutho ngeyegolide 
\q2 kodwa \nd uThixo\nd* uhlola inhliziyo. 
\b  
\q1  
\v 4 Umuntu oxhwalileyo uyazilalela izindebe ezimbi; 
\q2 lomqambimanga uyalulalela ulimi olulomona. 
\b  
\q1  
\v 5 Lowo ohleka umyanga weyisa uMenzi wakhe; 
\q2 oklolodayo nxa konakele kayikuphepha isijeziso. 
\b  
\q1  
\v 6 Abazukulu bangumqhele wabalupheleyo, 
\q2 njalo labantwana baziqhenya ngabazali babo. 
\b  
\q1  
\v 7 Izindebe zokutshinga azisifanelanga isiwula 
\q2 zimbi kangakanani ke izindebe zamanga kumbusi! 
\b  
\q1  
\v 8 Isivalamlomo siyintelezi kulowo osinikayo; 
\q2 uyaphumelela kukho konke. 
\b  
\q1  
\v 9 Ofihla ukona komunye uqinisa uthando, 
\q2 kodwa okhuluma ngakho kokuphela 
\q2 wehlukanisa abangane abasekhwapheni. 
\b  
\q1  
\v 10 Ukukhuza kuyamqondisa umuntu olengqondo 
\q2 kulokutshaya isiwula imvimvinya ezilikhulu. 
\b  
\q1  
\v 11 Umuntu omubi udinga ukuhlamuka kuphela; 
\q2 uzathunyelwa inxusa elilesihluku. 
\b  
\q1  
\v 12 Kungcono ukuqondana lebhele 
\q2 elithathelwe imidlwane yalo 
\q2 kulokuhlangana lesiwula ebuthutheni baso. 
\b  
\q1  
\v 13 Nxa umuntu ephindisela okuhle ngobubi, 
\q2 ububi kabusoze basuka endlini yakhe. 
\b  
\q1  
\v 14 Ukusungula inkani kunjengokubhidliza umduli wedamu; 
\q2 ngakho yekela indaba ingakadaleki inkani. 
\b  
\q1  
\v 15 Ukukhulula olecala lokugweba omsulwa 
\q2 \nd uThixo\nd* uyakuzonda kokubili. 
\b  
\q1  
\v 16 Isizani imali esandleni sesiwula, 
\q2 sivele singatshisekeli ukuzuza ukuhlakanipha? 
\b  
\q1  
\v 17 Umngane ulothando ngezikhathi zonke, 
\q2 lomzalwane uzalelwa izikhathi zenhlupheko. 
\b  
\q1  
\v 18 Umuntu ongananzeleliyo uyaziwisela anike isibambiso 
\q2 enceda umakhelwane wakhe. 
\b  
\q1  
\v 19 Lowo othanda inkani uthanda isono; 
\q2 lowo owakha isango eliphakemeyo udinga ukubhidlizwa. 
\b  
\q1  
\v 20 Umuntu olenhliziyo exhwalileyo kaphumeleli; 
\q2 lowo olimi lwakhe luyakhohlisa uwela ekuhluphekeni. 
\b  
\q1  
\v 21 Ukuba lendodana eyisiwula kuthelela usizi; 
\q2 akulakuthokoza kuyise wesiwula. 
\b  
\q1  
\v 22 Inhliziyo ethokozayo ingumuthi omuhle, 
\q2 kodwa umoya owephukileyo womisa amathambo. 
\b  
\q1  
\v 23 Umuntu omubi wamukela isivalamlomo ensitha 
\q2 ukuze ahlanekele indlela yokwahlulela. 
\b  
\q1  
\v 24 Umuntu ohluzisisayo izinto ukhokhelwa yikuhlakanipha, 
\q2 kodwa amehlo esiwula asabalala afike ekucineni komhlaba. 
\b  
\q1  
\v 25 Indodana eyisiwula ithelela uyise 
\q2 usizi lokudabuka kulowo owayizalayo. 
\b  
\q1  
\v 26 Kakukuhle ukujezisa umuntu ongelacala, 
\q2 loba ukufaka uswazi izisebenzi ngenxa yobuqotho bazo. 
\b  
\q1  
\v 27 Umuntu ololwazi ubeka amazwi akhe ngokunanzelela, 
\q2 njalo umuntu oqedisisayo kathukutheli ngokuphangisa. 
\b  
\q1  
\v 28 Lesiwula kuthiwa sihlakaniphile nxa sithule, 
\q2 kuthiwe siyaqedisisa nxa sibamba ulimi lwaso. 
\b  
\c 18  
\q1  
\v 1 Umuntu ongelamusa uzifunela okwakhe; 
\q2 uyazilahla zonke iziqondiso ezinhle. 
\b  
\q1  
\v 2 Isiwula kasikuthakazeleli ukuzwisisa 
\q2 kodwa sithokoza ngokutsho eyaso imibono. 
\b  
\q1  
\v 3 Nxa kufika ububi kufika lokweyisa, 
\q2 njalo ihlazo liza lokudumazeka. 
\b  
\q1  
\v 4 Amazwi omlomo womuntu ayinziki yamanzi, 
\q2 kodwa umthombo wokuhlakanipha ngumfudlana ontuntuzayo. 
\b  
\q1  
\v 5 Kakukuhle ukulungisela ababi 
\q2 loba ukungehluleli kuhle abangelacala. 
\b  
\q1  
\v 6 Izindebe zesiwula zisilethela ingxabano, 
\q2 lomlomo waso unxusa ukutshaywa. 
\b  
\q1  
\v 7 Umlomo wesiwula yiwo osidilizayo, 
\q2 lezindebe zaso zingumjibila womphefumulo waso. 
\b  
\q1  
\v 8 Amazwi omuntu onyeyayo anjengezibiliboco; 
\q2 angena ekujuleni kwenhliziyo yomuntu. 
\b  
\q1  
\v 9 Lowo ovilaphayo emsebenzini wakhe 
\q2 ungumfowabo walowo odilizayo. 
\b  
\q1  
\v 10 Ibizo \nd likaThixo\nd* liyinqaba eqinileyo; 
\q2 abalungileyo babalekela kulo baphephe. 
\b  
\q1  
\v 11 Inotho yezikhulu ingumuzi wazo ovikelweyo; 
\q2 zicabanga ukuthi imiduli yawo ayikhweleki. 
\b  
\q1  
\v 12 Umuntu uyazikhukhumeza ngenhliziyo yakhe, 
\q2 mandulo kokuba awe, 
\q2 ikanti ukuzithoba kwandulela udumo. 
\b  
\q1  
\v 13 Lowo ophendulayo engaqali alalele 
\q2 lobo yibuwula bakhe lehlazo lakhe. 
\b  
\q1  
\v 14 Umphefumulo womuntu uyamqinisa nxa egula, 
\q2 kodwa ngubani ongaphila elomoya owephukileyo na? 
\b  
\q1  
\v 15 Inhliziyo yabaqedisisayo izuza ulwazi; 
\q2 indlebe zabahlakaniphileyo ziyakudinga. 
\b  
\q1  
\v 16 Isipho siyamvulela indlela ophayo 
\q2 azuze ithuba lokubonana labakhulu. 
\b  
\q1  
\v 17 Ecaleni okhuluma kuqala ubonakala enguye olungileyo, 
\q2 kuze kuqhamuke omunye ambuzisise. 
\b  
\q1  
\v 18 Ukwenza inkatho kuyakuqeda ukulwisana, 
\q2 kubehlukanise abaxabanayo. 
\b  
\q1  
\v 19 Umzalwane owonelweyo 
\q2 uba lukhuni kulomuzi ohonqolozelweyo, 
\q2 lezingxabano zinjengamasango enqaba avaliweyo. 
\b  
\q1  
\v 20 Isisu somuntu sigcwaliswa yizithelo zomlomo wakhe; 
\q2 usuthiswa yisivuno sezindebe zakhe. 
\b  
\q1  
\v 21 Ulimi lulamandla okuphila lokufa, 
\q2 njalo labo abaluthandayo bazakudla izithelo zalo. 
\b  
\q1  
\v 22 Lowo ozuza umfazi ufumana okuhle, 
\q2 athole umusa \nd kuThixo\nd*. 
\b  
\q1  
\v 23 Umyanga uyancenga ukuthi axolelwe, 
\q2 kodwa isinothi siphendula ngolaka. 
\b  
\q1  
\v 24 Umuntu olabangane abanengi ucina kubi, 
\q2 kodwa kuba khona umngane othembeka okudlula umfowenu. 
\b  
\c 19  
\q1  
\v 1 Ungcono umyanga ohamba ngobuqotho 
\q2 kulesiwula esilezindebe ezingcolileyo. 
\b  
\q1  
\v 2 Kakulunganga ukutshiseka kodwa ungelalwazi, 
\q2 loba ukuwalazela uze ulahlekelwe yindlela. 
\b  
\q1  
\v 3 Ubuwula bomuntu budiliza impilo yakhe, 
\q2 ikanti inhliziyo yakhe ithukuthelela \nd uThixo\nd*. 
\b  
\q1  
\v 4 Inotho iletha abangane abanengi, 
\q2 kodwa umyanga ufulathelwa ngumngane wakhe weduze. 
\b  
\q1  
\v 5 Umfakazi wamanga uthola isijeziso, 
\q2 lalowo ohutshuza amanga kayikuphunyuka. 
\b  
\q1  
\v 6 Banengi abazincengela ukuthandwa ngumbusi, 
\q2 njalo wonke umuntu ngumngane walowo ophanayo. 
\b  
\q1  
\v 7 Umyanga uhlanyukelwa yizihlobo zakhe zonke, 
\q2 pho abangane bakhe bona bamnina kangakanani! 
\q1 Lanxa ebancenga kangakanani, 
\q2 ngeke esabathola. 
\b  
\q1  
\v 8 Lowo ozuze ukuhlakanipha uthanda umphefumulo wakhe; 
\q2 lowo ogogosa ukuzwisisa uyaphumelela. 
\b  
\q1  
\v 9 Umfakazi wamanga uthola isijeziso, 
\q2 njalo lowo ohutshuza amanga uzabhubha. 
\b  
\q1  
\v 10 Kakusifanelanga isiwula ukuthi sihlale enothweni 
\q2 kubi kangakanani ukuthi isigqili sibuse amakhosana. 
\b  
\q1  
\v 11 Ukuhlakanipha komuntu kumupha isineke; 
\q2 kumupha udumo ukunganaki ukuqalwa. 
\b  
\q1  
\v 12 Ukuthukuthela kwenkosi kunjengokubhonga kwesilwane, 
\q2 kodwa ukuthandwa yiyo kunjengamazolo etshanini. 
\b  
\q1  
\v 13 Indodana eyisiwula iyamchitha uyise, 
\q2 lomfazi olenkani 
\q2 unjengamanzi athonta ephahleni njalonje. 
\b  
\q1  
\v 14 Izindlu lenotho yilifa elizuzwa ebazalini, 
\q2 kodwa umfazi ozwisisayo uvela \nd kuThixo\nd*. 
\b  
\q1  
\v 15 Ubuvila buletha ubuthongo obukhulu, 
\q2 njalo umuntu owehluleka ukuzenwaya uyalamba. 
\b  
\q1  
\v 16 Lowo olalela izeluleko uvikela impilo yakhe, 
\q2 kodwa lowo ozedelelayo uzakufa. 
\b  
\q1  
\v 17 Olomusa kubayanga upha \nd uThixo\nd*, 
\q2 uzamupha umvuzo ngalokho akwenzayo. 
\b  
\q1  
\v 18 Qondisa indodana yakho, ngoba lokho kuzayisiza; 
\q2 ungabi lengxenye yokuyibulala. 
\b  
\q1  
\v 19 Umuntu ololaka oluphuphumayo luyamtshayisa, 
\q2 ungamlamulela, usuzahlala umlamulela njalo. 
\b  
\q1  
\v 20 Lalela ukucetshiswa, wamukele ukuqondiswa, 
\q2 ngoba ekucineni uzahlakanipha. 
\b  
\q1  
\v 21 Inhliziyo yomuntu igcwele amacebo amanengi, 
\q2 kodwa yisimiso \nd sikaThixo\nd* esimayo. 
\b  
\q1  
\v 22 Umuntu uloyisa uthando olungaqamukiyo; 
\q2 kungcono ukuba ngumyanga kulokuba lamanga. 
\b  
\q1  
\v 23 Ukumesaba \nd uThixo\nd* kuholela ekuphileni: 
\q2 olakho uhlala esuthisekile, engathintwa yizinhlupheko. 
\b  
\q1  
\v 24 Ivilavoxo litshonisa isandla salo emganwini, 
\q2 liyehluleke ukubuyisa isandla emlonyeni lidle. 
\b  
\q1  
\v 25 Thela uswazi isideleli, abathobekileyo bazafunda ukuhlakanipha; 
\q2 khuza umuntu oqedisisayo, uzazuza ulwazi. 
\b  
\q1  
\v 26 Lowo ontshontshela uyise, axotshe unina 
\q2 yindodana ethelela inhloni lehlazo. 
\b  
\q1  
\v 27 Nxa uyekela ukulandela izeluleko, ndodana yami, 
\q2 uzalahleka utshiye amazwi okwazi. 
\b  
\q1  
\v 28 Umfakazi oxhwalileyo uyawudelela umthetho, 
\q2 lomlomo womubi uminza ububi. 
\b  
\q1  
\v 29 Izijeziso zilungiselwe izideleli, 
\q2 loswazi ngolwemihlane yeziwula. 
\b  
\c 20  
\q1  
\v 1 Iwayini lenza ukudelela lotshwala buyaxabanisa, 
\q2 okhohliswa yilezi izinto kahlakaniphanga. 
\b  
\q1  
\v 2 Ulaka lwenkosi lunjengokubhonga kwesilwane; 
\q2 lowo oyizondisayo udela impilo yakhe. 
\b  
\q1  
\v 3 Kumupha udumo umuntu ukubalekela ukuxabana, 
\q2 kodwa iziphukuphuku zonke ziphangisa ukuthenga inkani. 
\b  
\q1  
\v 4 Ivila kalilimi ngesikhathi esifaneleyo; 
\q2 kuthi ngesikhathi sokuvuna liswele amabele. 
\b  
\q1  
\v 5 Izifiso zenhliziyo yomuntu zingamanzi azikileyo, 
\q2 kodwa umuntu ozwisisayo uyazifinyelela. 
\b  
\q1  
\v 6 Banengi abathi balothando olungapheliyo, 
\q2 kodwa ngubani ongamthola umuntu othembekileyo na? 
\b  
\q1  
\v 7 Umuntu olungileyo uphila impilo encomekayo; 
\q2 babusisiwe abantwabakhe abamfuzayo. 
\b  
\q1  
\v 8 Inkosi nxa ihlezi esihlalweni sayo isahlulela, 
\q2 iyakuhlungula konke okubi ngamehlo ayo. 
\b  
\q1  
\v 9 Ngubani ongathi, “Ngiyigcinile inhliziyo yami imhlophe; 
\q2 ngihlanzekile kangilasono?” 
\b  
\q1  
\v 10 Izisindo ezitshiyanayo 
\q2 lezilinganiso ezitshiyanayo \nd uThixo\nd* uyakuzonda kokubili. 
\b  
\q1  
\v 11 Lomntwana waziwa ngezenzo zakhe, 
\q2 ngokuthi isimilo sakhe sihle, siqotho. 
\b  
\q1  
\v 12 Indlebe ezizwayo lamehlo abonayo 
\q2 kokubili kwenziwa \nd nguThixo\nd*. 
\b  
\q1  
\v 13 Ungathandani lobuthongo uzakuba ngumyanga, 
\q2 hlala uvukile uzakuba lokudla okunengi. 
\b  
\q1  
\v 14 “Kubi, kubi!” kutsho umthengi; 
\q2 esuka lapho usezincoma ngakuthengileyo. 
\b  
\q1  
\v 15 Likhona igolide lamatshe aligugu amanengi, 
\q2 kodwa izindebe ezikhuluma ulwazi zilivelakancane. 
\b  
\q1  
\v 16 Thatha isembatho salowo owenzela owezizweni isibambiso; 
\q2 sigcine nxa ebambisela owesifazane ongaziphathanga. 
\b  
\q1  
\v 17 Ukudla okuzuzwe ngenkohliso kumnandi emuntwini, 
\q2 kodwa kucina sekungathi udla itshebetshebe. 
\b  
\q1  
\v 18 Nxa usenza amacebo dinga izeluleko; 
\q2 nxa usiyahlasela zuza ukuqondiswa. 
\b  
\q1  
\v 19 Onyeyayo uyehluleka ukugcina imfihlo, 
\q2 ngakho yehlukana lomuntu okhuluma angathuli. 
\b  
\q1  
\v 20 Nxa umuntu ethuka uyise loba unina, 
\q2 isibane sakhe sizacinywa abesemnyameni omubi. 
\b  
\q1  
\v 21 Ilifa elizuzwa lula ekuqaleni 
\q2 alilakubusiswa ekucineni. 
\b  
\q1  
\v 22 Ungabokuthi, “Lami ngizakulungisa ngalokhu ongenze khona!” 
\q2 Yekela, \nd uThixo\nd* nguye ozakusiza. 
\b  
\q1  
\v 23 \nd UThixo\nd* uyazizonda izilinganiso eziguquguqulwayo, 
\q2 njalo kathokoziswa yizikali zokudlelezela. 
\b  
\q1  
\v 24 Izinyathelo zomuntu zikhokhelwa \nd nguThixo\nd*. 
\q2 Pho umuntu angayazi kanjani na indlela yakhe? 
\b  
\q1  
\v 25 Yikuzithiya ukuthembisa ngokuphangisa ukupha ulutho, 
\q2 phambili umuntu aphinde azisole ngalesosifungo. 
\b  
\q1  
\v 26 Inkosi ehlakaniphileyo iyabahlungula ababi; 
\q2 iyabahadla njengelitshe lokuchola. 
\b  
\q1  
\v 27 Isibane \nd sikaThixo\nd* siyawuhlolisisa umphefumulo womuntu; 
\q2 sihlolisisa ekujuleni kwemibilini yakhe. 
\b  
\q1  
\v 28 Uthando lokwethembeka kuyayivikela inkosi; 
\q2 ngothando isihlalo sayo sobukhosi sivikelekile. 
\b  
\q1  
\v 29 Udumo lwamajaha lusemandleni awo, 
\q2 izimvu zekhanda ziyinkazimulo yabadala. 
\b  
\q1  
\v 30 Izidutshulo lamanxeba kugezisa okubi, 
\q2 lezibhaxulo zihlambulula ingaphakathi. 
\b  
\c 21  
\q1  
\v 1 Inhliziyo yenkosi isezandleni \nd zikaThixo\nd*, 
\q2 uyiholela lapho athanda khona njengomsele wamanzi. 
\b  
\q1  
\v 2 Umuntu ubona kungathi zonke izindlela zakhe zilungile, 
\q2 kodwa \nd uThixo\nd* uhlola inhliziyo. 
\b  
\q1  
\v 3 Ukwenza okulungileyo lokufaneleyo 
\q2 kuyathandeka \nd kuThixo\nd* kulomhlatshelo. 
\b  
\q1  
\v 4 Amehlo okuzikhukhumeza lenhliziyo ezigqajayo, 
\q2 okuyikho okukhokhela ababi, konke yizono! 
\b  
\q1  
\v 5 Amalungiselelo abakhutheleyo anika umvuzo 
\q2 njengoba nje amawala eletha ubuyanga. 
\b  
\q1  
\v 6 Inotho ezuzwe ngendlela yamanga 
\q2 iyinkungu ememethekayo lomjibila wokufa. 
\b  
\q1  
\v 7 Ukuhlukuluza kwababi kuzabakhukhula, 
\q2 ngoba bayala ukwenza okulungileyo. 
\b  
\q1  
\v 8 Indlela yomuntu olecala iyathubezela, 
\q2 kodwa ukwenza kongelalo kuqondile. 
\b  
\q1  
\v 9 Kungcono ukuhlala ekhulusini lophahla lwendlu 
\q2 kulokuhlala ndlu yinye lomfazi olomlomo. 
\b  
\q1  
\v 10 Umuntu omubi utshisekela ububi; 
\q2 kalasihawu ngomakhelwane wakhe. 
\b  
\q1  
\v 11 Nxa kujeziswa isideleli isithutha sizuza ukuhlakanipha; 
\q2 nxa ohlakaniphileyo eqondiswa uzuza ulwazi. 
\b  
\q1  
\v 12 Olungileyo uyayinanzelela indlu yesigangi 
\q2 kuthi lesosigangi asibhubhise. 
\b  
\q1  
\v 13 Nxa umuntu egcika indlebe zakhe ukuze angezwa ukukhala kwabayanga, 
\q2 laye uzakuthi esekhala angalalelwa muntu. 
\b  
\q1  
\v 14 Isipho esiphiwa ensitha siyaludedisa ulaka, 
\q2 lesivalamlomo esifihlwe emajazini siyakudedisa ukuthukuthela. 
\b  
\q1  
\v 15 Ukwahlulela kuhle kuthokozisa olungileyo 
\q2 kodwa izigangi kuzitshayisa uvalo. 
\b  
\q1  
\v 16 Umuntu ophambuka endleleni yokuzwisisa 
\q2 ucina esendawonye labafileyo. 
\b  
\q1  
\v 17 Lowo othanda ukuzithokozisa uzakuba ngumyanga; 
\q2 laloba ngubani othanda iwayini lezibondlo ngeke anothe. 
\b  
\q1  
\v 18 Ababi baba ngumhlawulelo wabalungileyo, 
\q2 labangathembekanga bangumhlawulelo wabaqotho. 
\b  
\q1  
\v 19 Kungcono ukuhlala enkangala 
\q2 kulokuhlala lomfazi olenkani lothethayo. 
\b  
\q1  
\v 20 Indlu yohlakaniphileyo igcwele amaqubaquba ezibiliboco lamafutha, 
\q2 kodwa umuntu oyisithutha udla aqede du konke alakho. 
\b  
\q1  
\v 21 Lowo odinga ukulunga lothando 
\q2 uzuza ukuphila, ukuphumelela lodumo. 
\b  
\q1  
\v 22 Umuntu ohlakaniphileyo uhlasela umuzi wabalamandla 
\q2 adilizele phansi inqaba abayithembileyo. 
\b  
\q1  
\v 23 Lowo oqaphela umlomo wakhe lolimi lwakhe 
\q2 uyaziphephisa ezingozini. 
\b  
\q1  
\v 24 Umuntu ozigqajayo loyisiqholo ibizo lakhe ngu “Sideleli,” 
\q2 wenza izinto ngokuziqakisa okukhulu. 
\b  
\q1  
\v 25 Izinkanuko zevila yizo ezililimazayo, 
\q2 ngoba izandla zalo ziyala ukusebenza. 
\q1  
\v 26 Ilanga lonke litshona lifisa okungapheliyo, 
\q2 kodwa abalungileyo bayapha bengagodli. 
\b  
\q1  
\v 27 Umhlatshelo wababi uyisinengiso 
\q2 kambe mubi kangakanani nxa ulethwa ngenhliziyo embi. 
\b  
\q1  
\v 28 Umfakazi wamanga uzabhubha, 
\q2 kuthi lowo omlalelayo uzabhujiswa lanini. 
\b  
\q1  
\v 29 Umuntu omubi utshengisa isibindi samanga, 
\q2 kodwa umuntu oqotho uyananzelela izenzo zakhe. 
\b  
\q1  
\v 30 Akulakuhlakanipha, akulambono, akulacebo 
\q2 okunganqoba \nd uThixo\nd*. 
\b  
\q1  
\v 31 Ibhiza liyalungiselelwa usuku lwempi, 
\q2 kodwa ukunqoba kulawulwa \nd nguThixo\nd*. 
\b  
\c 22  
\q1  
\v 1 Ibizo elihle liyathandeka kulenotho enengi; 
\q2 ukuhlonitshwa kungcono kulesiliva kumbe igolide. 
\b  
\q1  
\v 2 Abanothileyo labayanga bayafanana ngalokhu: 
\q2 \nd UThixo\nd* unguMenzi wabo bonke. 
\b  
\q1  
\v 3 Umuntu olengqondo uthi ebona ingozi acatshe, 
\q2 kodwa isithutha siyaphikelela singena enkathazweni. 
\b  
\q1  
\v 4 Ukuzithoba lokwesaba \nd uThixo\nd* 
\q2 kuletha inotho lodumo lokuphila. 
\b  
\q1  
\v 5 Endleleni yababi kugcwele ameva lemjibila, 
\q2 kodwa onanzelela umphefumulo wakhe unqenqela khatshana. 
\b  
\q1  
\v 6 Fundisa umntwana indlela amele ahambe ngayo, 
\q2 kuzakuthi esemdala kayikuphambuka kuyo. 
\b  
\q1  
\v 7 Abanothileyo babusa abayanga, 
\q2 lalowo owebolekayo uyisichaka salowo omebolekayo. 
\b  
\q1  
\v 8 Lowo ohlanyele ububi uvuna ukuhlupheka, 
\q2 njalo uswazi lolaka lwakhe luzakwephulwa. 
\b  
\q1  
\v 9 Umuntu ophanayo uzabusiswa, 
\q2 ngoba wabela abayanga ukudla kwakhe. 
\b  
\q1  
\v 10 Xotsha isideleli, lenkani ihle iphume; 
\q2 ukuxabana lokuthukana kuyaphela. 
\b  
\q1  
\v 11 Othanda inhliziyo ehlanzekileyo, onkulumo yakhe ipholile 
\q2 uzakuba ngumngane wombusi. 
\b  
\q1  
\v 12 Amehlo \nd kaThixo\nd* ayaluvikela ulwazi 
\q2 kodwa uyawadiliza amazwi abangathembekanga. 
\b  
\q1  
\v 13 Ivilavoxo lithi, “Kulesilwane phandle! 
\q2 Ngizabulawa ezindleleni!” 
\b  
\q1  
\v 14 Umlomo wesifebekazi unjengomgodi otshonayo; 
\q2 lowo othukwe \nd nguThixo\nd* uzawobokela kuwo. 
\b  
\q1  
\v 15 Ubuwula bugxilile enhliziyweni yomntwana, 
\q2 kodwa uswazi lokuqondisa luzabuxotshela khatshana. 
\b  
\q1  
\v 16 Lowo oncindezela abayanga ukuze anothe ngabo, 
\q2 lalowo oncenga abanothileyo ngezipho, 
\q2 bonke bacina sebengabayanga. 
\ms1 Amazwi Angamatshumi Amathathu Ezihlakaniphi 
\s2 Ilizwi Lakuqala 
\q1  
\v 17 Lalela uzwe amazwi ezihlakaniphi; 
\q2 nikela inhliziyo yakho ezifundweni zami, 
\q1  
\v 18 ngoba kuyathokozisa nxa uzigcina enhliziyweni yakho, 
\q2 uzitsho kalula ngezindebe zakho. 
\q1  
\v 19 Ukuze ithemba lakho lihlale \nd kuThixo\nd*, 
\q2 yikho ngikufundisa lamuhla wena ngokwakho. 
\q1  
\v 20 Kangikulobelanga yini izitsho ezingamatshumi amathathu, 
\q2 izitsho zokweluleka lolwazi, 
\q1  
\v 21 ezikufundisa amazwi eqiniso athembekileyo, 
\q2 ukuze ukwazi ukupha impendulo ezilesisindo 
\q2 kulowo okuthumileyo na? 
\b  
\q1  
\v 22 Ungagegeleli abayanga ngoba bengabayanga 
\q2 njalo ungaphoseli abaswelayo entolongweni, 
\q1  
\v 23 ngoba \nd uThixo\nd* uzakuba ngumeli wabo 
\q2 abahlukuluze labo ababahlukuluzayo. 
\b  
\q1  
\v 24 Ungabi ngumngane womuntu ololaka, 
\q2 ungahambi lomuntu ozonda masinyane, 
\q1  
\v 25 funa ufunde izindlela zakhe 
\q2 uzingenise emjibileni. 
\b  
\q1  
\v 26 Ungabi ngumuntu ophanga ukwenza izithembiso 
\q2 kumbe onika isibambiso ngezikwelede; 
\q1  
\v 27 ungayiswela inhlawulo 
\q2 uzakwemukwa noma ngumbheda wakho olala kuwo. 
\b  
\q1  
\v 28 Ungasusi ilitshe lakudala elomngcele 
\q2 elabekwa ngokhokho bakho. 
\b  
\q1  
\v 29 Uyambona umuntu oyingcitshi emsebenzini wakhe na? 
\q2 Uzasebenzela amakhosi; 
\q2 akayikusebenzela abantukazana. 
\b  
\c 23  
\q1  
\v 1 Nxa uhlala phansi usidla lombusi, 
\q2 nanzelela ukuthi kuyini okuphambi kwakho, 
\q1  
\v 2 ungazifaki ingqamu entanyeni 
\q2 nxa uhugwa yibuhwaba. 
\q1  
\v 3 Ungahawukeli izibiliboco zakhe 
\q2 ngoba lokho kudla kuyakhohlisa. 
\b  
\q1  
\v 4 Ungazihlukuluzi uzigugise ngomsebenzi uzama inotho; 
\q2 hlakanipha wazi ukuzikhuza. 
\q1  
\v 5 Ungayibona manje inotho, masinyane isinyamalele, 
\q2 ngoba ngempela izamila impiko 
\q2 iphaphele emkhathini njengengqungqulu. 
\b  
\q1  
\v 6 Ungakudli ukudla komuntu oncitshanayo, 
\q2 ungazihawukeli izibiliboco zakhe; 
\q1  
\v 7 ngoba yena uhlezi ebalisa ngendleko. 
\q2 Angathi kuwe, “Dlana unathe,” 
\q2 kodwa kungasuki enhliziyweni yakhe. 
\q1  
\v 8 Uzakuhlanza okuncane lokho okudlileyo 
\q2 ube udlalise amazwi akho okubonga. 
\q1  
\v 9 Ungakhulumi lesithutha 
\q2 ngoba sizakweyisa inhlakanipho yamazwi akho. 
\b  
\q1  
\v 10 Ungasusi ilitshe lakudala elomngcele 
\q2 loba uzithathele amasimu ezintandane, 
\q1  
\v 11 ngoba uMhlengi wazo ulamandla; 
\q2 uzakuba ngumeli wazo aphikisane lawe. 
\b  
\q1  
\v 12 Nikela inhliziyo yakho ekufundisweni 
\q2 lezindlebe zakho emazwini olwazi. 
\b  
\q1  
\v 13 Ungayekeli ukumlaya umntwana; 
\q2 ukumtshaya ngoswazi akuyikumbulala. 
\q1  
\v 14 Mjezise ngoswazi 
\q2 ukuze uphephise umphefumulo wakhe ekufeni. 
\b  
\q1  
\v 15 Ndodana yami, aluba inhliziyo yakho ihlakaniphile, 
\q2 inhliziyo yami layo izathokoza; 
\q1  
\v 16 ingaphakathi yami izajabula 
\q2 lapho izindebe zakho zikhuluma okulungileyo. 
\q1  
\v 17 Inhliziyo yakho mayingahawukeli izoni, 
\q2 kodwa hlala utshisekela ukwesaba \nd uThixo\nd*. 
\q1  
\v 18 Ngeqiniso lihle ikusasa lakho, 
\q2 lethemba lakho kaliyikucitshwa. 
\b  
\q1  
\v 19 Lalela, ndodana yami, uhlakaniphe, 
\q2 ubeke inhliziyo yakho endleleni elungileyo. 
\q1  
\v 20 Ungahlangani leziminzi zewayini 
\q2 labazitika ngenyama, 
\q1  
\v 21 ngoba izidakwa lezihwaba ziba ngabayanga, 
\q2 ukuwozela kwazo kuzembese amadabudabu. 
\b  
\q1  
\v 22 Lalela uyihlo owakuletha emhlabeni, 
\q2 njalo ungeyisi unyoko nxa eseluphele. 
\q1  
\v 23 Thenga iqiniso ungalithengisi; 
\q2 zuza ukuhlakanipha lokuzikhuza lokuzwisisa. 
\q1  
\v 24 Uyise womuntu olungileyo uyathokoza kakhulu; 
\q2 lowo olendodana ehlakaniphileyo uyathokoza ngayo. 
\q1  
\v 25 Sengathi uyihlo lonyoko bangathokoza; 
\q2 sengathi lowo owakuzalayo angajabula! 
\b  
\q1  
\v 26 Ndodana yami, ngipha inhliziyo yakho, 
\q2 amehlo akho ahlale ezindleleni zami, 
\q1  
\v 27 ngoba isifebe singumgodi otshonayo 
\q2 lomfazi olibele lendlela ungumthombo oyingozi. 
\q1  
\v 28 Uyacathamela njengesigebenga, 
\q2 andise amadoda angathembekanga. 
\b  
\q1  
\v 29 Ngubani ohlaba umkhosi? 
\q2 Ngubani olosizi na? 
\q1 Ngubani otshingayo? 
\q2 Ngubani olensolo na? 
\q1 Ngubani omahluzuhluzu ngeze? 
\q2 Ngubani omehlo abomvu gebhu na? 
\q1  
\v 30 Yilabo abalibala ngewayini, 
\q2 abahamba bedinga inzwisa yewayini elidibanisiweyo. 
\q1  
\v 31 Ungahugwa liwayini ulibona libomvu, 
\q2 nxa likhazimula enkomitshini, 
\q2 lapho lisehla kamnandi! 
\q1  
\v 32 Ekucineni liluma njengenyoka 
\q2 libe lobuhlungu obubulalayo njengenhlangwana. 
\q1  
\v 33 Amehlo akho azabona izinto ezingaqedakaliyo 
\q2 lengqondo yakho icabange izinto ezididayo. 
\q1  
\v 34 Uzakuba njengomuntu ondendayo phakathi kolwandle, 
\q2 olele esiqongweni sensika yomkhumbi. 
\q1  
\v 35 Uzakuthi, “Bangitshayile kodwa kangilimalanga! 
\q2 Bangibethile kodwa kakubuhlungu! 
\q2 Ngizavuka nini bo ngiyodinga obunye utshwala?” 
\b  
\c 24  
\q1  
\v 1 Ungabahawukeli abantu abaxhwalileyo, 
\q2 ungafisi ubungane labo; 
\q1  
\v 2 ngoba ezingqondweni zabo bahlose udlakela, 
\q2 lezindebe zabo zikhuluma ngokuvusa umsindo. 
\b  
\q1  
\v 3 Indlu yakhiwa ngokuhlakanipha, 
\q2 imiswe ngokuzwisisa; 
\q1  
\v 4 amakamelo ayo agcwaliswe ngolwazi, 
\q2 agcwaliswe ngemiceciso yakude eligugu. 
\b  
\q1  
\v 5 Umuntu ohlakaniphileyo ulamandla amakhulu, 
\q2 njalo umuntu ololwazi uyandisa amandla; 
\q1  
\v 6 ukuthi unqobe empini kufunakala izeluleko, 
\q2 lokunqoba kudinga abeluleki abanengi. 
\b  
\q1  
\v 7 Ukuhlakanipha kuphakeme kakhulu koyisiwula; 
\q2 enkundleni kalalutho angalukhuluma. 
\b  
\q1  
\v 8 Lowo oceba ububi 
\q2 uzakwaziwa njengomacebomabi. 
\q1  
\v 9 Amacebo obuwula ayisono, 
\q2 njalo abantu bayasizonda isideleli. 
\b  
\q1  
\v 10 Nxa uthikaza ngezikhathi zenhlupheko, 
\q2 mancinyane kanganani amandla akho! 
\q1  
\v 11 Bahlangule labo abaholelwa ekufeni; 
\q2 banqande labo abadayizela besiya ekubulaweni. 
\q1  
\v 12 Nxa usithi, “Angithi besingazi lutho ngalokhu,” 
\q2 kambe lowo ohlola inhliziyo kakuboni lokho na? 
\q1 Kakwazi lokho yini onguye olinda ukuphila kwakho na? 
\q2 Akayikuvuza ubani lobani ngakwenzileyo na? 
\b  
\q1  
\v 13 Dlana uluju ndodana yami, ngoba lulungile; 
\q2 uluju olujuluka ekhekhebeni lumnandi luyanambitheka. 
\q1  
\v 14 Yazi njalo ukuthi ukuhlakanipha kumnandi emphefumulweni wakho, 
\q2 aluba ukuzuza ikusasa lakho lilethemba elihle, 
\q2 njalo ithemba lakho aliyikudaniswa. 
\b  
\q1  
\v 15 Ungacathameli indlu yomuntu olungileyo njengesigebenga, 
\q2 ungawuhlaseli umuzi wakhe; 
\q1  
\v 16 ngoba loba angaze awe kasikhombisa umuntu olungileyo uyavuka futhi, 
\q2 kodwa ababi babhazalaliswa yizinhlupheko. 
\b  
\q1  
\v 17 Ungathatshiswa yikuwa kwesitha sakho; 
\q2 nxa sikhubeka ungavumeli inhliziyo yakho ithokoze, 
\q1  
\v 18 ngoba \nd uThixo\nd* uzakubona lokho 
\q2 asole abesepholisa ulaka lwakhe kuso isitha. 
\b  
\q1  
\v 19 Ungazikhathazi ngenxa yabantu ababi 
\q2 loba ubahawukele abaxhwalileyo, 
\q1  
\v 20 ngoba umuntu omubi akalalo ithemba lakusasa, 
\q2 njalo isibane sezixhwali sizacinywa. 
\b  
\q1  
\v 21 Yesaba \nd uThixo\nd* lombusi, ndodana yami, 
\q2 ungangenelani labahlamuki, 
\q1  
\v 22 ngoba laba bobabili bazakwehlisa ulaka lubabhubhise, 
\q2 ngoba phela ngubani kambe okwaziyo ukubhubhisa abangakwehlisa? 
\ms1 Amanye Amazwi Ahlakaniphileyo 
\p  
\v 23 La ngamanye amazwi ezihlakaniphi: 
\q1 Ukwahlulela ngobandlululo kakulunganga: 
\q1  
\v 24 Loba ngubani othi kolecala, “Umsulwa,” 
\q2 abantu bonke bazamqalekisa 
\q2 lezizwe zonke zizamhlamukela. 
\q1  
\v 25 Kodwa kuzabalungela labo abamlahlayo olecala, 
\q2 lezibusiso ezinengi zizabehlela. 
\b  
\q1  
\v 26 Impendulo eqotho 
\q2 injengokwangiwa ezindebeni. 
\b  
\q1  
\v 27 Qeda umsebenzi wakho waphandle 
\q2 ulungise lamasimu akho; 
\q2 kuthi-ke usuqedile wakhe indlu yakho. 
\b  
\q1  
\v 28 Ungafakazi ngokubethela umakhelwane kungelamlandu, 
\q2 kumbe usebenzise izindebe zakho ukhohlisa. 
\q1  
\v 29 Ungabokuthi, “Ngizakwenza kuye njengoba enze kimi; 
\q2 ngizahlawulisa ngalokho angenze khona.” 
\b  
\q1  
\v 30 Ngedlula ensimini yevilavoxo, 
\q2 ngedlula esivinini somuntu ongelangqondo; 
\q1  
\v 31 ameva ayesekhula indawo yonke, 
\q2 indawo yonke isithe phethu ukhula, 
\q2 lomduli wamatshe usudilikile. 
\q1  
\v 32 Ngakunanzelela konke engangikubona 
\q2 ngafunda isifundo kulokho engakubonayo: 
\q1  
\v 33 Ukulala okuncane, ukuwozela okuncane, 
\q2 ukugoqa izandla kancane uphumula, 
\q1  
\v 34 ubuyanga buzafika kuwe njengesela 
\q2 lokuswela njengesigebenga. 
\c 25  
\ms1 Ezinye Izaga ZikaSolomoni 
\p  
\v 1 Lezi ngezinye njalo izaga zikaSolomoni, ezabhalwa yizinceku zikaHezekhiya inkosi yakoJuda: 
\q1  
\v 2 Kuyinkazimulo kaNkulunkulu ukufihla indaba; 
\q2 ukuchwayisisa indaba ludumo lwababusi. 
\q1  
\v 3 Njengalokhu izulu liphakeme lomhlaba ujulile, 
\q2 kanjalo imicabango yamakhosi kayifinyelelwa. 
\b  
\q1  
\v 4 Susa amakhafutha ahlangene lesiliva 
\q2 umkhandi athole ukulungisa isitsha sihle; 
\q1  
\v 5 susa abantu ababi phambi kwenkosi, 
\q2 isihlalo sayo sizaqiniswa ngokulunga. 
\b  
\q1  
\v 6 Ungaziphakamisi phambi kwenkosi, 
\q2 ungaziphendleli indawo phakathi kwezikhulu; 
\q1  
\v 7 kuba ngcono ukuthi yona ithi, “Woza uhlale ngapha,” 
\q2 kulokuthi yona ikwehlise phambi kwezikhulu. 
\b  
\q1 Lokho okubonileyo ngawakho amehlo 
\q2  
\v 8 ungaphangisi ukukubika emthethwandaba, 
\q2 ngoba uzathini nxa umakhelwane wakho esekuyangisa? 
\b  
\q1  
\v 9 Nxa ungaya edale lomakhelwane wakho 
\q2 ungahambi usuhlabela imfihlo yenu, 
\q1  
\v 10 funa lowo okuzwayo akuyangise 
\q2 uhlale usungumuntu olebizo elibi. 
\b  
\q1  
\v 11 Ilizwi elikhulunywe ngesikhathi esifaneleyo 
\q2 linjengama-aphula egolide 
\q2 ananyekwe emcepheni wesiliva. 
\q1  
\v 12 Njengecici legolide kumbe umceciso wegolide elicengiweyo 
\q2 kunjalo ukukhuza komuntu ohlakaniphileyo, kolalelayo. 
\b  
\q1  
\v 13 Njengokuqanda kongqwaqwane ngesikhathi sokuvuna 
\q2 sinjalo isithunywa esithembekileyo kwabasithumileyo; 
\q2 sivuselela imiphefumulo yabaphathi baso. 
\q1  
\v 14 Njengamayezi lomoya okungalethi izulu 
\q2 unjalo umuntu ozikhukhumeza ngamandla angelawo. 
\b  
\q1  
\v 15 Ngokubekezela inkosi ingancengwa ize ivume, 
\q2 lolimi oluthambileyo lungalephula ithambo. 
\b  
\q1  
\v 16 Nxa uthole inyosi, dlana okwaneleyo 
\q2 ungedlulisi amalawulo, uzazihlanza. 
\q1  
\v 17 Ungabi ngunsukuzonke endlini kamakhelwane wakho 
\q2 uzacina usumdaka abesekuzonda. 
\b  
\q1  
\v 18 Unjengesagila loba inkemba kumbe umtshoko obukhali 
\q2 umuntu ofakaza amanga ngomakhelwane wakhe. 
\q1  
\v 19 Njengezinyo elibuhlungu loba unyawo olwenyeleyo 
\q2 kunjalo ukweyama emuntwini ongathembekanga 
\q2 ngesikhathi sokuhlupheka. 
\q1  
\v 20 Njengomuntu okhumula ibhatshi mhla kumakhaza, 
\q2 loba njengokuthela iviniga phakathi kwesoda 
\q2 unjalo ohlabelela izingoma emuntwini odabukileyo. 
\b  
\q1  
\v 21 Nxa isitha sakho silambile siphe ukudla sidle; 
\q2 nxa somile siphe amanzi sinathe. 
\q1  
\v 22 Ngokwenza lokho, umokhela amalahle avuthayo ekhanda, 
\q2 njalo \nd uThixo\nd* uzakubusisa. 
\b  
\q1  
\v 23 Njengomoya wasenyakatho uletha izulu, 
\q2 lunjalo ulimi olulobuqili luvusa ulaka. 
\b  
\q1  
\v 24 Kungcono ukuhlala ekhulusini lophahla lwendlu 
\q2 kulokuhlala ndlu yinye lomfazi olomlomo. 
\b  
\q1  
\v 25 Njengamanzi aqandayo emuntwini okhatheleyo, 
\q2 zinjalo izindaba ezimnandi ezivela elizweni elikude. 
\q1  
\v 26 Njengesiziba esidungekileyo loba umthombo ongcolileyo 
\q2 unjalo umuntu olungileyo odedela umuntu omubi. 
\b  
\q1  
\v 27 Kakukuhle ukudla inyosi wedlulise, 
\q2 njalo kakulasithunzi ukuzidingela ukudunyiswa. 
\b  
\q1  
\v 28 Njengedolobho eselidilikelwe ngumthangala walo 
\q2 unjalo umuntu ongazithintiyo. 
\c 26  
\q1  
\v 1 Njengongqwaqwane ehlobo loba izulu ebusika 
\q2 kanjalo udumo alusifanelanga isiwula. 
\q1  
\v 2 Njengentaka ephaphazelayo loba inkonjane entwezayo, 
\q2 sinjalo isiqalekiso esingelasizatho kasinamatheli. 
\q1  
\v 3 Isiswebhu ngesebhiza, amatomu ngakababhemi, 
\q2 loswazi ngolwemihlane yeziwula! 
\q1  
\v 4 Ungabophendula isiwula ngendlela yobuwula baso, 
\q2 funa ubenjengaso wena ngokwakho. 
\q1  
\v 5 Phendula isiwula ngendlela yobuwula baso, 
\q2 sizabona kungathi sihlakaniphile. 
\q1  
\v 6 Njengokuziquma inyawo zakho loba ukunatha itshefu, 
\q2 kunjalo ukuthumela umlayezo ngesiwula. 
\q1  
\v 7 Njengemilenze eqhugezelayo eyomuntu oqhulayo 
\q2 sinjalo isaga emlonyeni wesiwula. 
\q1  
\v 8 Njengokubophela ilitshe esavutheni 
\q2 kunjalo ukupha udumo koyisiwula. 
\q1  
\v 9 Njengogatsha lwameva luphethwe yisidakwa 
\q2 sinjalo isaga emlonyeni wesiwula. 
\q1  
\v 10 Njengomtshoko ociba loba ngubani odlulayo 
\q2 unjalo oqhatsha isiwula loba umuntu ozedlulelayo. 
\q1  
\v 11 Njengenja ebuyela emahlanzweni ayo 
\q2 kanjalo isiwula siyabuphinda ubuthutha baso. 
\q1  
\v 12 Uyambona yini umuntu ozibona engohlakaniphileyo? 
\q2 Kulethemba elingcono ngesiwula kulaye. 
\b  
\q1  
\v 13 Ivilavoxo lithi, “Kulesilwane endleleni, 
\q2 kulesilwane emigwaqweni!” 
\q1  
\v 14 Njengesivalo esitshibilika ngamabhanti aso 
\q2 kanjalo ivila liphenduka embhedeni walo. 
\q1  
\v 15 Ivilavoxo litshonisa isandla salo emganwini; 
\q2 livilaphe ukusa isandla emlonyeni lidle. 
\q1  
\v 16 Ivila lizibona lihlakaniphile kakhulu 
\q2 okwedlula abantu abayisikhombisa abangaphendula ngokuhlakanipha. 
\b  
\q1  
\v 17 Njengomuntu odonsa inja ngendlebe 
\q2 unjalo umuntu othi edlula angenele ingxabano ingesiyakhe. 
\b  
\q1  
\v 18 Njengohlanya luphosa izikhuni zomlilo 
\q2 kumbe imitshoko ebulalayo, 
\q1  
\v 19 injalo indoda ephoxa umakhelwane wayo 
\q2 ibisisithi, “Bengizidlalela nje!” 
\b  
\q1  
\v 20 Nxa kungaselankuni umlilo uyacima; 
\q2 nxa kungaselakunyeya ukuxabana kuyaphela. 
\q1  
\v 21 Njengamalahle avuthayo loba njengenkuni emlilweni, 
\q2 unjalo umuntu othanda ingxabano ekuvuseni inkani. 
\q1  
\v 22 Amazwi omuntu onyeyayo anjengezibiliboco; 
\q2 angena ekujuleni kwenhliziyo yomuntu. 
\b  
\q1  
\v 23 Njengesiliva egcotshwe esitsheni sebumba sikhazimule 
\q2 kunjalo ukuthakazelela kwezindebe zenhliziyo elobubi. 
\q1  
\v 24 Umuntu olenhliziyo embi uvala ngezindebe ezimnandi, 
\q2 kodwa enhliziyweni yakhe ufihle inkohliso. 
\q1  
\v 25 Loba ukukhuluma kwakhe kumnandi, 
\q2 kodwa ungaze wamkholwa, 
\q2 ngoba inhliziyo yakhe igcwele izithuko eziyisikhombisa. 
\q1  
\v 26 Inzondo yakhe angayivala ngobuqili, 
\q2 kodwa ububi bakhe buzavezwa obala ebantwini. 
\q1  
\v 27 Umuntu angagebha umgodi, uzawela kuwo; 
\q2 umuntu angagiqa ilitshe, 
\q2 lizaphenduka ligiqikele phezu kwakhe. 
\q1  
\v 28 Ulimi oluqamba amanga luyabazonda labo olubalimazayo, 
\q2 lomlomo okhohlisayo uletha incithakalo. 
\b  
\c 27  
\q1  
\v 1 Ungazincomi ngelakusasa, 
\q2 ngoba kawukwazi ukuthi liza lithweleni. 
\b  
\q1  
\v 2 Yekela omunye akudumise, hatshi owakho umlomo; 
\q2 akube ngomunye, kungabi ngezakho izindebe. 
\b  
\q1  
\v 3 Ilitshe liyasinda, itshebetshebe ngumthwalo onzima, 
\q2 kodwa ukucatshulwa yisiwula kunzima okudlula kokubili. 
\b  
\q1  
\v 4 Ulaka lulolunya lentukuthelo iyagabha, 
\q2 kambe ngubani ongema phambi komhawu na? 
\b  
\q1  
\v 5 Kungcono ukuthukwa obala 
\q2 kulokuthandwa ngokufihlakeleyo. 
\b  
\q1  
\v 6 Ukulinyazwa ngumngane kakwesabeki, 
\q2 kodwa isitha sikwanga sedlulise amalawulo. 
\b  
\q1  
\v 7 Osuthiyo kathakazeleli uluju oluvela ekhekhebeni, 
\q2 kodwa kolambileyo lokubabayo kunambitheka mnandi. 
\b  
\q1  
\v 8 Njengenyoni elahleka esidlekeni sayo, 
\q2 unjalo umuntu otshiya umuzi wakhe. 
\b  
\q1  
\v 9 Amakha lempepha kuletha intokozo enhliziyweni, 
\q2 lobumnandi bomngane busuka ezelulekweni zakhe eziqinileyo. 
\b  
\q1  
\v 10 Ungadeli umngane wakho lomngane kayihlo, 
\q2 futhi ungayi endlini yomfowenu nxa wehlelwe yizinhlupheko 
\q2 ungcono umakhelwane eduze kolomfowenu okhatshana. 
\b  
\q1  
\v 11 Hlakanipha, ndodana, ulethe intokozo enhliziyweni yami; 
\q2 lapho ngizakwazi ukumphendula ongeyisayo. 
\b  
\q1  
\v 12 Umuntu olengqondo uthi ebona ingozi acatshe, 
\q2 kodwa isithutha siyaphikelela singena enkathazweni. 
\b  
\q1  
\v 13 Thatha isigqoko salowo owenzela owemzini isibambiso; 
\q2 sigcine njengesithembiso aluba esenzela umfazi ongelasimilo. 
\b  
\q1  
\v 14 Uba umuntu evukisa umakhelwane wakhe ngokumnqolonga ekuseni kakhulu, 
\q2 kuzathiwa uyamqalekisa. 
\b  
\q1  
\v 15 Umfazi olenkani 
\q2 unjengamathonsi angapheliyo mhlana kusina; 
\q1  
\v 16 ukumkhuza kufana lokukhuza umoya 
\q2 loba lokubamba okulamagcobo ngesandla. 
\b  
\q1  
\v 17 Njengensimbi ilola insimbi, 
\q2 kanjalo indoda ikhaliphisa enye. 
\b  
\q1  
\v 18 Lowo onakekela isihlahla somkhiwa uzakudla izithelo zawo, 
\q2 kuthi lowo olondoloza umqhatshi wakhe abelodumo. 
\b  
\q1  
\v 19 Njengamanzi etshengisa ubuso bomuntu, 
\q2 kanjalo inhliziyo yomuntu itshengisa ayikho khona. 
\b  
\q1  
\v 20 UKufa leNcithakalo kakusuthi, 
\q2 anjalo lamehlo omuntu. 
\b  
\q1  
\v 21 Isiliva sincibilikiselwa embizeni imvutho ngeyegolide, 
\q2 kodwa abantu bahlolwa ngodumo lwabo. 
\b  
\q1  
\v 22 Ungaze uchole isiwula elitsheni, 
\q2 usichole njengamabele ngembokodo 
\q2 kawusoze ubususe ubuwula baso. 
\b  
\q1  
\v 23 Woba leqiniso ukuthi uhlala usazi kuhle isimo sezifuyo zakho, 
\q2 nanzelela imihlambi yakho; 
\q1  
\v 24 ngoba inotho kayiyikuhlala kokuphela, 
\q2 lomqhele wobukhosi kawuyikuba ngowezizukulwane zonke. 
\q1  
\v 25 Utshani bungaqunywa kuqalise ukuhluma obunye 
\q2 kuthi bonke obusikiweyo ezintabeni sebubuthiwe, 
\q1  
\v 26 amawundlu azakupha uboya bezigqoko, 
\q2 lembuzi zikuphe imali elingana intengo yesiqinti. 
\q1  
\v 27 Uzakuba lochago lwembuzi olunengi 
\q2 olwakho lolwendlu yakho lusuthise lezinceku zakho. 
\b  
\c 28  
\q1  
\v 1 Umuntu omubi uyabaleka loba engaxotshaniswa muntu, 
\q2 kodwa abalungileyo balesibindi njengesilwane. 
\b  
\q1  
\v 2 Nxa ilizwe lihlamuka liba lababusi abanengi, 
\q2 kodwa umuntu ozwisisayo lololwazi ugcina ukuthula. 
\b  
\q1  
\v 3 Umbusi oncindezela abayanga 
\q2 unjengezulu elinengi elikhukhula amabele. 
\b  
\q1  
\v 4 Labo abaphikisa umthetho bakhuthaza izigangi, 
\q2 kodwa labo abawugcinayo bayazenqabela. 
\b  
\q1  
\v 5 Abantu ababi kabakuzwisisi ukwahlulela kuhle, 
\q2 kodwa labo abamdingayo \nd uThixo\nd* bayakuzwisisa kakhulu. 
\b  
\q1  
\v 6 Ungcono umyanga ohamba ngokulunga 
\q2 kulesinothi esilezindlela zokungcola. 
\b  
\q1  
\v 7 Lowo ogcina umthetho yindodana eqedisisayo, 
\q2 kodwa umngane wezixhwali uyangisa uyise. 
\b  
\q1  
\v 8 Lowo owandisa inotho yakhe ngenzaliso 
\q2 uyibuthela omunye ozaba lomusa kubayanga. 
\b  
\q1  
\v 9 Loba ngubani ongawulaleliyo umthetho, 
\q2 lemikhuleko yakhe izakuba yisinengiso. 
\b  
\q1  
\v 10 Lowo oholela olungileyo endleleni embi 
\q2 uzawela emjibileni wakhe, 
\q2 kodwa ongelacala uzakwamukela ilifa elihle. 
\b  
\q1  
\v 11 Umuntu onothileyo angazibona ingathi uhlakaniphile, 
\q2 kodwa umyanga oqedisisayo uhle abone ukuthi kasumuntu. 
\b  
\q1  
\v 12 Nxa olungileyo enqoba kulokujabula okukhulu; 
\q2 kodwa nxa omubi ethatha umbuso abantu bayacatsha. 
\b  
\q1  
\v 13 Lowo ofihla iziphambeko zakhe kayikuphumelela, 
\q2 kodwa lowo ozivumayo azitshiye ufumana umusa. 
\b  
\q1  
\v 14 Ubusisiwe umuntu ohlala emesaba \nd uThixo\nd*, 
\q2 kodwa lowo oyenza lukhuni inhliziyo yakhe uwela enkathazweni. 
\b  
\q1  
\v 15 Njengesilwane esibhongayo loba ibhele elihlaselayo 
\q2 unjalo umuntu omubi nxa ebusa abantu abangelamandla. 
\b  
\q1  
\v 16 Umbusi oncindezelayo wehluleka ukwahlulela kuhle, 
\q2 kodwa lowo ozonda inzuzo yokuganga uzakuba lempilo ende. 
\b  
\q1  
\v 17 Umuntu odliwa ngumzwangedwa wokubulala omunye 
\q2 uzaba ngohlala ebaleka aze ayokufa; 
\q2 akungabi lomuntu omsekelayo. 
\b  
\q1  
\v 18 Lowo ompilo yakhe ingelacala uvikelekile, 
\q2 kodwa ondlela zakhe zixhwalile uzakuwa masinyane. 
\b  
\q1  
\v 19 Lowo osebenza nzima emasimini akhe uzathola ukudla okunengi, 
\q2 kodwa lowo ophika ngezifiso eziyize uzakuba ngumyanga onukayo. 
\b  
\q1  
\v 20 Umuntu othembekileyo uzabusiswa ngokuphumelela, 
\q2 kodwa ogijimela ukunotha kayikuphepha ekujezisweni. 
\b  
\q1  
\v 21 Ukubandlulula abantu kakulunganga 
\q2 ikanti umuntu uyona ukuze azuze ucezu lwesinkwa. 
\b  
\q1  
\v 22 Umuntu oncitshanayo utshisekela ukunotha 
\q2 kodwa kaboni ukuthi unyenyelwa yibuyanga. 
\b  
\q1  
\v 23 Lowo okhuza umuntu uzacina esethandeka 
\q2 kulalowo ololimi olukhohlisayo. 
\b  
\q1  
\v 24 Lowo ontshontshela uyise loba unina 
\q2 athi, “Akusinto embi” 
\q2 ungumngane lomuntu obhidlizayo. 
\b  
\q1  
\v 25 Umuntu olomhawu ubanga ingxabano, 
\q2 kodwa lowo omethembayo \nd uThixo\nd* uzaphumelela. 
\b  
\q1  
\v 26 Lowo ozithembayo yena uyisiwula, 
\q2 kodwa lowo ohamba ngenhlakanipho uvikelekile. 
\b  
\q1  
\v 27 Lowo opha abayanga kayikuswela lutho, 
\q2 kodwa ovala amehlo ingathi kababoni uzuza iziqalekiso ezinengi. 
\b  
\q1  
\v 28 Lapho izigangi zisiba yiziphathamandla abantu bayacatsha; 
\q2 kodwa nxa kusifa izixhwali abalungileyo bayaphumelela. 
\b  
\c 29  
\q1  
\v 1 Umuntu oqinisa intamo phezu kokukhuzwa kanengi 
\q2 uzabhujiswa ngesikhatshana kungabi lokuphepha. 
\b  
\q1  
\v 2 Lapho kuphumelela abalungileyo abantu bayajabula; 
\q2 nxa kubusa izixhwali abantu bayabubula. 
\b  
\q1  
\v 3 Umuntu othanda ukuhlakanipha uletha intokozo kuyise, 
\q2 kodwa ohamba lezifebe utshaphaza inotho yakhe. 
\b  
\q1  
\v 4 Ngokubusa kuhle inkosi iyaliqinisa ilizwe layo, 
\q2 kodwa leyo elihaga lezivalamlomo iyalibhidliza. 
\b  
\q1  
\v 5 Loba ngubani okhohlisa umakhelwane wakhe 
\q2 uzendlalela umambule wokuzithiya. 
\b  
\q1  
\v 6 Umuntu omubi uthiywa yisono sakhe, 
\q2 kodwa umuntu olungileyo angahlabela athokoze. 
\b  
\q1  
\v 7 Olungileyo uyawananza amalungelo abayanga, 
\q2 kodwa ababi kabazidubi ngalokho. 
\b  
\q1  
\v 8 Izideleli zingalidunga idolobho, 
\q2 kodwa abantu abahlakaniphileyo bayaludedisa ulaka. 
\b  
\q1  
\v 9 Nxa umuntu ohlakaniphileyo esiya emthethwandaba lesiwula, 
\q2 isiwula siyatshinga sibhede kube lomsindo. 
\b  
\q1  
\v 10 Abadinga ukuchitha igazi bayamzonda umuntu oqotho 
\q2 njalo badinga ukubulala abalungileyo. 
\b  
\q1  
\v 11 Isiwula siyalukhihliza lonke ulaka lwaso, 
\q2 kodwa umuntu ohlakaniphileyo uyazithiba. 
\b  
\q1  
\v 12 Nxa umbusi elalela amanga, 
\q2 zonke izikhulu zakhe ziba zimbi. 
\b  
\q1  
\v 13 Umyanga lomncindezeli bakanye kulokhu: 
\q2 \nd UThixo\nd* uvula amehlo abo bobabili. 
\b  
\q1  
\v 14 Nxa inkosi isahlulela abayanga kungelabandlululo, 
\q2 isihlalo sayo sobukhosi sizaqina. 
\b  
\q1  
\v 15 Uswazi lokuqondisa lunika ukuhlakanipha, 
\q2 kodwa umntwana oyekelwayo uhlazisa unina. 
\b  
\q1  
\v 16 Nxa ababi bephumelela, lesono laso siyaphumelela, 
\q2 kodwa abalungileyo bazabawisa. 
\b  
\q1  
\v 17 Qondisa indodana yakho, izakupha ukuthula; 
\q2 izaletha injabulo emphefumulweni wakho. 
\b  
\q1  
\v 18 Lapho okungekho khona isambulelo, 
\q2 abantu badela ukuzithiba; 
\q2 kodwa ubusisiwe lowo ogcina umlayo. 
\b  
\q1  
\v 19 Inceku kayiqondiswa ngamazwi nje wodwa, 
\q2 loba izwisisa kayiyikukwenza ekutshelwayo. 
\b  
\q1  
\v 20 Uyambona umuntu owalazela ukukhuluma? 
\q2 Kulethemba elingcono esiwuleni kulaye. 
\b  
\q1  
\v 21 Umuntu ototoza inceku yakhe isakhula, 
\q2 leyonceku izamthwalisa nzima ekucineni. 
\b  
\q1  
\v 22 Umuntu othukuthelayo udala ingxabano, 
\q2 kodwa lowo olicaphucaphu wenza izono ezinengi. 
\b  
\q1  
\v 23 Ukuzigqaja komuntu kuyamehlisa, 
\q2 kodwa umuntu ozehlisayo uzuza udumo. 
\b  
\q1  
\v 24 Osizana lesela uyazizonda yena; 
\q2 usezifungise kulo ngakho ngeke afakaze iqiniso. 
\b  
\q1  
\v 25 Ukwesaba abantu kuba yizithiyo, 
\q2 kodwa lowo othemba \nd uThixo\nd* uzaphepha. 
\b  
\q1  
\v 26 Abanengi bazama ukuzisondeza kumbusi, 
\q2 kodwa ukwahlulela okuhle kuvela \nd kuThixo\nd*. 
\b  
\q1  
\v 27 Abalungileyo bayabenyanya abangathembekanga; 
\q2 abaxhwalileyo bayabenyanya abalungileyo. 
\c 30  
\ms1 Izitsho Zika-Aguri 
\p  
\v 1 Amazwi ka-Aguri indodana kaJakhe, amazwi ahlakaniphileyo: 
\q1 Umuntu lo wathi ku-Ithiyeli: 
\b  
\q1 “Ngikhathele, Oh Nkulunkulu, 
\q2 kodwa ngizophumelela. 
\b  
\q1  
\v 2 Angilalwazi okudlula bonke abantu; 
\q2 angilakho ukuzwisisa komuntu. 
\q1  
\v 3 Angikufundanga ukuhlakanipha 
\q2 njalo kangilalwazi ngaye oNgcwele. 
\q1  
\v 4 Ngubani oseke waya ezulwini waphinda wehla na? 
\q2 Ngubani oseke wafumbatha umoya ngesandla sakhe na? 
\q1 Ngubani oseke wagoqela amanzi ngesigqoko sakhe na? 
\q2 Ngubani omise yonke imikhawulo yomhlaba na? 
\q1 Lingubani ibizo lakhe, lebizo lendodana yakhe? 
\q2 Ngitshela nxa usazi! 
\b  
\b  
\q1  
\v 5 Wonke amazwi kaNkulunkulu akalamposiso; 
\q2 uyisihlangu kulabo abacatsha kuye. 
\q1  
\v 6 Ungengezeleli emazwini akhe, 
\q2 funa akukhuze akwenze umqambimanga. 
\b  
\q1  
\v 7 Zimbili izinto engizicela kuwe, Oh \nd Thixo\nd*; 
\q2 ungangincitshi zona ngingakafi: 
\q1  
\v 8 Susa kimi inkohliso lamanga; 
\q2 ungangiphi ubuyanga loba inotho, 
\q2 kodwa ungiphe kuphela ukudla kwami kwansukuzonke. 
\q1  
\v 9 Phela ngingaba lokunengi kakhulu ngikuphike wena 
\q2 ngithi, ‘Ungubani \nd uThixo\nd*?’ 
\q1 loba ngibengumyanga ngintshontshe; 
\q2 ngalokho ngiliyangise ibizo likaNkulunkulu wami. 
\b  
\q1  
\v 10 Ungahlebi inceku enkosini yayo, 
\q2 ngoba izakuqalekisa ungene enkathazweni. 
\b  
\q1  
\v 11 Bakhona abathuka oyise, 
\q2 abangababusisiyo onina; 
\q1  
\v 12 labo abazibona belungile 
\q2 ikanti kabahlambululwanga emanyaleni abo; 
\q1  
\v 13 labo abamehlo abo ahlezi egcwele ulaka, 
\q2 abakhangela ngokudelela; 
\q1  
\v 14 labo omazinyo abo zinkemba, 
\q2 omihlathi yabo inanyathiselwe izingqamu 
\q1 ukuze baginye abayanga baphele emhlabeni, 
\q2 labaswelayo abaphakathi kwabantu. 
\b  
\q1  
\v 15 Umkhaza ulamadodakazi amabili; 
\q2 ayamemeza athi, ‘Siphe! Siphe!’ 
\b  
\li1 Zintathu izinto ezingasuthiyo, 
\li2 zine ezingakaze zithi, ‘Sekwanele!’: 
\li3  
\v 16 lingcwaba 
\li3 yisisu senyumba, 
\li3 lomhlabathi ongasuthiyo amanzi, 
\li3 lomlilo ongezukufa wathi, ‘Sekwanele!’ 
\b  
\q1  
\v 17 Ilihlo elihleka uyise, 
\q2 elidelela ukulalela unina, 
\q1 lizakotsholwa ngamawabayi asesigodini, 
\q2 lizadliwa ngamanqe. 
\b  
\li1  
\v 18 Kukhona izinto ezintathu ezingimangalisayo kakhulu, 
\li2 ezine engingazizwisisiyo: 
\li3  
\v 19 indlela yengqungqulu emkhathini, 
\li3 umzila wenyoka edwaleni, 
\li3 indlela yomkhumbi olwandle, 
\li3 lendlela yejaha lentombi. 
\b  
\q1  
\v 20 Le yindlela yesiphingikazi: 
\q2 siyadla sesule umlomo waso 
\q2 besesisithi, ‘Angenzanga lutho olubi.’ 
\b  
\li1  
\v 21 Zintathu izinto ezizamazamisa umhlaba, 
\li2 zine ongeke uzithwale: 
\li3  
\v 22 yinceku ebayinkosi, 
\li3 yisiwula esisuthiyo, 
\li3  
\v 23 ngumfazi owendileyo ongathandwayo, 
\li3 lencekukazi ethathela inkosikazi indoda. 
\b  
\li1  
\v 24 Kukhona emhlabeni izinto ezine ezincinyane, 
\li2 ikanti-ke zihlakaniphile kakhulu: 
\li2  
\v 25 Ubunyonyo kabulamandla anganani, 
\li3 kodwa buyabuthelela ukudla kwabo ehlobo; 
\li2  
\v 26 lezimbila ziyizidalwa ezilamandla angatsho lutho, 
\li3 kodwa zenza izikhundla zazo ezingoxweni zamadwala; 
\li2  
\v 27 izintethe kazilankosi, 
\li3 kodwa zihamba ziludibi olwesabekayo; 
\li2  
\v 28 umbankwa ungabanjwa ngesandla, 
\li3 kodwa ungena lasezigodlweni zamakhosi. 
\b  
\li1  
\v 29 Kulezinto ezintathu ezihamba zinqekuza kamnandi, 
\li2 zine ezihamba zibeka kamnandi: 
\li3  
\v 30 yisilwane, esilamandla esabekayo phakathi kwezilo, esingabalekeli lutho; 
\li3  
\v 31 liqhude eliditshazelayo, 
\li3 yimpongo, 
\li3 njalo lenkosi nxa ihanqwe libutho layo. 
\b  
\q1  
\v 32 Nxa ube yisithutha waziphakamisa, 
\q2 kumbe nxa wakhe amacebo okwenza okubi, 
\q2 vala umlomo wakho ngesandla sakho. 
\q1  
\v 33 Ngoba njengokuphehla uchago kudala iphehla, 
\q2 lanjengoba ukugubha amakhala kubanga umungula, 
\q2 kunjalo ukuvusa ulaka kudala ingxabano.” 
\c 31  
\ms1 Izitsho Zenkosi ULemuweli 
\p  
\v 1 Amazwi enkosi uLemuweli, amazwi enhlakanipho awafundiswa ngunina: 
\q1  
\v 2 Oh, ndodana yami! Oh ndodana yethumbu lami! 
\q2 Oh, ndodana yezifungo zami, 
\q1  
\v 3 ungadlalisi amandla akho ebafazini, 
\q2 izifutho zakho kulabo abadiliza amakhosi. 
\b  
\q1  
\v 4 Kakusikho kwamakhosi, bakithi Lemuweli 
\q2 kakusikho kwamakhosi ukunatha iwayini, 
\q2 kakusikho kwababusi ukunxwanela utshwala, 
\q1  
\v 5 funa badakwe bakhohlwe izimiso zomthetho, 
\q2 behluleke ukumisela kuhle abahluphekayo amalungelo abo. 
\q1  
\v 6 Phana utshwala kulabo abavele sebezifele, 
\q2 iwayini kulabo abalosizi olukhulu; 
\q1  
\v 7 kabanathe bakhohlwe ubuyanga babo 
\q2 bakhohlwe nya usizi lwabo. 
\b  
\q1  
\v 8 Bamele labo abehlulekayo ukuzikhulumela, 
\q2 uwamele amalungelo alabo abangelalutho. 
\q1  
\v 9 Khuluma njalo wahlulele ngokulunga; 
\q2 alwele amalungelo abayanga labaswelayo. 
\ms1 Amazwi okuphetha: Umfazi Oncomekayo 
\q1  
\v 10 Ngubani na ongathola umfazi olesimilo? 
\q2 Uligugu elidlula kakhulu amatshe amahle. 
\q1  
\v 11 Indoda yakhe iyamthemba ngokupheleleyo 
\q2 njalo kayisweli lutho oluqakathekileyo. 
\q1  
\v 12 Uyenzela okuhle, hatshi okubi, 
\q2 empilweni yakhe yonke. 
\q1  
\v 13 Uyakhetha kuhle iwulu lesikusha 
\q2 akweluke kuhle ngezandla ezikhutheleyo. 
\q1  
\v 14 Unjengemikhumbi yabathengisi, 
\q2 eletha ukudla okuvela kude. 
\q1  
\v 15 Uvuka ekuseni kusesemnyama; 
\q2 alungisele abomuzi wakhe ukudla 
\q2 abele lezincekukazi zakhe. 
\q1  
\v 16 Uyayihlolisisa insimu mandulo kokuyithenga; 
\q2 ngalokho akuzuzayo uyahlanyela isivini sakhe. 
\q1  
\v 17 Uwubamba ngokukhuthala umsebenzi wakhe; 
\q2 aqinise izingalo zakhe emsebenzini. 
\q1  
\v 18 Uyananzelela ukuthi ukuthengisa kwakhe kulenzuzo, 
\q2 lokuthi isibane sakhe kasicimi ebusuku. 
\q1  
\v 19 Uphatha uluthi lokuphotha ngesandla sakhe 
\q2 abesebamba ngeminwe yakhe isigudugudu sokweluka. 
\q1  
\v 20 Welulela izandla zakhe kubayanga 
\q2 njalo ulezandla ezilula kwabaswelayo. 
\q1  
\v 21 Lapho kukhithika ungqwaqwane, kalakwesaba ngabendlu yakhe; 
\q2 ngoba bonke bagqoke ezibomvu. 
\q1  
\v 22 Wendlala amalembu ombheda wakhe; 
\q2 agqoke ilineni elihle lezigqoko eziyibubende. 
\q1  
\v 23 Indoda yakhe iyahlonitshwa enkundleni 
\q2 lapho efika ihlale khona ndawonye labadala belizwe. 
\q1  
\v 24 Uthunga izigqoko zelineni azithengise, 
\q2 abathengi bemigaxo bayizuza kuye. 
\q1  
\v 25 Wembethe amandla lesithunzi; 
\q2 uyahleka loba kusiza insuku ezimbi. 
\q1  
\v 26 Ukhuluma ngenhlakanipho, 
\q2 lezeluleko eziqondileyo zisolimini lwakhe. 
\q1  
\v 27 Unqinekela ezomuzi wakhe 
\q2 njalo kadli isinkwa sobuvila. 
\q1  
\v 28 Abantwabakhe bayambonga bathi ubusisiwe; 
\q2 lendoda yakhe layo iyamdumisa ithi, 
\q1  
\v 29 “Banengi abafazi abenza izimangaliso zobuhle, 
\q2 kodwa wena uyabedlula bonke.” 
\q1  
\v 30 Ukubukeka kuyakhohlisa, lobuhle buyaphela; 
\q2 kodwa umfazi owesaba \nd uThixo\nd* kadunyiswe. 
\q1  
\v 31 Kaphiwe umvuzo wobuhle abenzayo, 
\q2 imisebenzi yakhe imlethele udumo enkundleni.