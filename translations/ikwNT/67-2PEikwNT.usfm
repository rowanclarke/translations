\id 2PE - Ikwerre
\h 2 Pita
\toc1 Ọkwukwo izi ke Ẹbo Pita gbarụ
\toc2 2 Pita
\toc3 2 Pita
\mt2 Ọkwukwo izi
\mt2 ke Ẹbo
\mt1 Pita
\mt2 gbarụ
\imt1 Nhne gbasịri ọkwukwo izi ka
\im Nye gbarụ ọkwukwo ka mernu ele noobno a nsnị mahịa nụ nye Karaịsi ọbula kwesiri o wu bụdnu ke nọotu ogwnu Chiokike (1:3). Be kwesiri o jikwasi ezi ọka be nyernu be rikne (1:12).
\ip Ọ dọru be aka nụ nsnị gbasịri ele ọwhnurninya aghalaghala, nụ ele ọjo ka bnanam ọgbako Chiokike nooduwhu ele kweru n'ezi ọka. N'anya Chiokike, otu ọbochi nụ lele otu pokwu awha, otu pokwu awha nụ lele otu ọbochi. Chiokike zá noogbu ọkwnu nụ ọbita mkwna a lele kpa ele badnụ neeche. Kọvu Chiokike nwernu ndidi k'agịda kwnornu nụ ọ másịla a nụ otu nye mmehie ọbula joowhu etekne.
\iot Nhne zị n'ọkwukwo izi ka
\io1 Obekwu ikwu nụ okpukpe \ior (1:1,2) \ior*
\io1 Kpa ele sno Nyenwe aị kwesiri o wu bụdnu be \ior (1:3-15) \ior*
\io1 Igwugwu Karaịsi \ior (1:16-21) \ior*
\io1 Ele ọwhnurninya aghalaghala \ior (2:1-22) \ior*
\io1 Nyenwe aị jaavarịri berere \ior (3:1-18) \ior*
\c 1
\p 
\v 1 Mawa, Saịmoni Pita, nye izi nụ nye dazịsni anya Jizọsi Karaịsi, naagbaznenu anụ ọkwukwo izi ka, anụ ele hiteru n'ome mma Chiokike nụ Nye Ọznohia aị Jizọsi Karaịsi kehịa ọkwnata ovu zị okne ọnu ahịa lele ke aị.
\p 
\v 2 Oru nụ udno banụ anụ aba kpa anụ neezne nụ ruwhnu naamahịa Chiokike nụ Jizọsi Nyenwe aị.
\s1 Osukwu ikwu Chiokike
\p 
\v 3 Chiokike jiri iknernema a nyee aị kpakara nhne a pioru a jeeji wuru bụdnu nọotu ogwnu Chiokike, kpa a zị neezne nụ ruwhnu naamahịa nye wam sukwuru aị bna n'igwugwu a nụ ọma mma a.
\v 4 Hite n'igwugwu a nụ ọma mma a, o nyernu aị agịda mkwna zị okne ọnu ahịa, ma hite nụ nhne ele ka, anụ kehịa igwe n'oyiyi ke Chiokike, ma anụ gbanahọru nhne ọjo ke ọwa ka noovuya a.
\p 
\v 5 Kwnornu nụ otu nhne ka, anụ gbalị nọotukwasi n'olu ọkwnata mkpọma anụ, ọma mma, n'olu ọma mma, anụ tụkwasi ọmahia nhne,
\v 6 n'olu ọmahia nhne, anụ tụkwasi badnụ knernụ ẹhni a, n'olu badnụ knernụ ẹhni a, anụ tụkwasi ọsnuta ovu, n'olu ọsnuta ovu, anụ tụkwasi ọtu ogwnu Chiokike.
\v 7 N'olu ọtu ogwnu Chiokike, anụ tụkwasi ọwhnun'anya rụmu nda, n'olu ọwhnun'anya rụmu nda, anụ tụkwasi ọwhnun'anya.
\v 8 Kwnornu nụ ọ bụru nụ anụ nwernu kpakara nhne ka k'agịda, be jeeme anụ bụru ele nọornu ẹrnu ọma, naamị mkpụru dụ ọmahia Nyenwe aị Jizọsi Karaịsi.
\v 9 Kọvu nye nwée nhne ka kpuru isni, ọ whnụ́ nhne zị ikere, o chezume nụ be snụsnamarnu a nụ mmehie ọknani a.
\p 
\v 10 Kam kpayarụ, rụmu nda m, anụ zịri gnarnagnarna n'ome ikwu Chiokike sukwuru anụ, họhia anụ bụru nhne gwuzosiri rikne. Ọ bụru anụ mee kpam, anụ jáadna rịa rịa.
\v 11 Kpam, be jeenye anụ rikne anụ jeeji bna nụ rime ẹli-eze ke zị ọkwnukokwnu ke Nyenwe aị nụ Nye Ọznohia aị Jizọsi Karaịsi.
\p 
\v 12 Kam kpayarụ, me chenwanyannụ anụ kpakara nhne ka ige ọbula, ọ bụ n'ezi nụ anụ magwụ be, anụ gwuzosi rikne n'ezi ọka wam anụ nahịaru.
\v 13 M che m nụ o kwesiri ekwesi o chenwanyanụ anụ be kpa me zị kọriri bụdnu.
\v 14 M magwụ m nụ ige matị m joowopu anọ-ẹhni ka, lele kpa Nyenwe aị Jizọsi Karaịsi kannụ m.
\v 15 M jaagbalị rikne m, whnụ nụ nga me nwụrnu nụ anụ jaazị neechenwanya be.
\s1 Igwugwu Karaịsi
\p 
\v 16 Ọ bụ́o ọtnutnu ruwhere be jiri akọniche tnụ, nga a mernu anụ mahịa ọvuva Nyenwe aị Jizọsi Karaịsi, anya aị lawụru whnụrnu dudugna a.
\v 17 Ọ nahịaru ọson'anya nụ igwugwu n'aka Chiokike Nda, nga akpịri Chiokike jiri okne igwugwu dna, kaa, “Ka bụ Nnwọ m me whnụrnu n'anya, nye nhne a masịri m.”
\v 18 A nụrnu akpịri ka hi n'oligwe dna, nga aị nụ ya zị n'olu rugwu wam zị nsọ.
\p 
\v 19 Be mernu ikwu-ọnu ele ọwhnurninya wam gwuzosi rikne k'agịda, anụ bno nsnị nhne be gbarụ, kwnornu nụ ikwu-ọnu be nụ lele tọnji noonwu nụ hne gbarụ ọchichiri. Ọ jaazị kọriri noonwu tem dụ n'ọbochi Jizọsi jaava, iwhne a joonwu nụ rime mkpọma anụ.
\v 20 Ke kakwo kpakara nhne, anụ mahịa nụ ọ zá nhne ọwhnurninya ọbula be gbarụ n'ọkwukwo nsọ ke badnụ nwernu rikne kọwa risi a hite nụ nhne zị n'echiche a.
\v 21 Kwnornu nụ ọ zá ọwhnurninya ọbula be jiri echiche badnụ vu, kọvu ele badnụ kwuru ikwu-ọnu Chiokike kpa Enine Nsọ noodu be kwu.
\c 2
\s1 Ele zni nhne aghalaghala
\p 
\v 1 Ele ọwhnurninya aghalaghala whụyaru iwhne n'esilawụru ele Izirẹli, lele kpa ele zni nhne aghalaghala jọowhuya iwhne n'esilawụru anụ. Ele ka jeeji aghịgho gwebnanya iznizni ọgha zị ọdo n'ọdo ke noovuya ẹnwu, be gọnahoru Nyenwe be bụ nye gbahịaru be, ele neegweya ọla n'iyi zị ngwa ngwa nụ risi be.
\v 2 Agịda ele badnụ joosno apna ome ọyi be. Kwnornu nụ nhne be neeme, ele badnụ jookwulu apna ezi ọka.
\v 3 Ele zni nhne ka jeeji ọwho-anya kwu nhne be chehịaru nụ mkpọma be, gweru anụ zụ ahịa. Ele ikpe ọmuma be neese be, ọla n'iyi be zá neere anyarna.
\p 
\v 4 Chiokike sị́gbasila ele enine izi ele mernu mmehie, kọvu tụbna be nụ rime bẹkwnu rẹnwu, hne be tụru be ijigba nụ rime ọchichiri neese ọbochi ikpe.
\v 5 Chiokike sị́gbasila ọwa ọknani, kọvu dọhia Noa, nye mernu be badnụ ẹsato, nye neezni izi ọma ome mma, nga o gweyarụ mgba-mini ẹli n'ọwa ele máa Chiokike.
\v 6 Ọ marnụ ẹli Sọdom nụ Gọmora ikpe, gweru bẹkwnu rne be lele rẹtnu, mee be bụru nhne atụ nyee ele joowu bụdnu máa Chiokike.
\v 7 Ọ dọhiaru Lọtu nye mee mma, nye bụdnu zị́la rịchna ke ele noolulu iwu ẹli wam mekparụ ẹhni.
\v 8 Nye mee mma wam wuru n'esilawụru be, whnụ, nụ masị ọka ọjo ke gburu a igbugbu nụ mkpọma.
\v 9 Ọ bụru kpam, Nyenwe aị magwụ kpa o jọodohia ele mee mma nụ rime ọrnurna, nụ kpa ọ jaabịta ele ọjo nụ rime awhnụwhnu dụ n'ọbochi ikpe,
\v 10 ke kakwo, ele noosno nhne rụru ọru ke anọ-ẹhni be, neeledna ele nẹechi ẹchi anya.
\p Be neezni nhne aghalaghala n'anya rikne, ele oknomokno, ele zá nọotu ogwnu nụ ọkaja ele oligwe.
\v 11 Ọ bụbedi ele enine izi ele gbasịri rikne nụ ele nwernu iknernema karụ ele zni nhne aghalaghala ka, nwée rikne gweru kparị bno ele oligwe nhne nụ ruwhnu Nyenwe aị.
\v 12 Kọvu ele badnụ ka nookwulu nhne be ghọ́hiage, be nụ lele anọhia nsnị ịnyo, nhne be keru eke neeme kpa ọ masịri be, be jọonwudne be, gbu be lele anọhia, be la n'iyi.
\p 
\v 13 Be jaanahịa ọgwo ẹrnu nhne ọjo be mernu, ọ nọoso be o mee nhne ọjo n'iwhnehnie. Be bụ nhne iwhnerne n'esilawụru anụ. Nhne zị nụ mkpọma be bụ nhne ọjo kpa be sno anụ neeri wiri nọonwo.
\v 14 Ome ọyi jiri be n'anya, inwe zá nọogwu be nụ mmehie, be nooduwhu mkpọma zá rikne, ele mkpọma be jihịaru n'ọwho-anya nụ ẹrnu ọjo, ele be vụru ọnu.
\v 15 Be ghahieru apna, gharụ apna ziri ezi, snornu apna Balam nnwọ Boso, nye whnụrnu ọgwo ẹrnu nhne ọjo n'anya.
\v 16 Kọvu ịyinya a bigbọru a nụ mmehie a, anọhia kwú ọka, kwuru ọka n'ibiri n'nkọli ke badnụ, chịma ẹra nye ọwhnurninya wam.
\p 
\v 17 Ele badnụ ka nụ lele ọmi nwée mini, lele erumeru ruwhere mini noovugharị, be bịtannu be okne ọchichiri ọkwnukokwnu.
\v 18 Kwnornu nụ ọnu be nookwu okne ọka mpako iwhnirniwhno, be naarnabnahna nụ rime mmehie ele naagbanahọru bụdnu ọjo.
\v 19 Be neekwe be mkwna o nwernu ẹhni be, kọvu be n'iwhuru be bụ ọhi agwa ọjo noovuya ẹnwu. Kwnornu nụ nhne ọbula ke megburu badnụ, nye wam bụ ọhi a.
\v 20 Ọ bụru nụ be gbanahọru nhne noolulu ke ọwa nga be mahịaru Nyenwe aị nụ Nye Ọznohia aị Jizọsi Karaịsi, be knegidne kwno be nụ rime a, o nwegidne be, ọnodi be n'ipne-aznụ jọojobujo karụ nụ ọpanizo.
\v 21 Ọ ka mma nụ be máa apna ome mma karụ nụ be mahịaru a, be dnasnịnu iwu nsọ wam be nyernu be aznụ.
\v 22 Nhne mernu be gesiri nụ elulu wam bụ ezi ọka, “Nkịta nwarnụ rụgburu gbụru lahna nụ nhne ọ nwarnụ,” nụ “Ezni be hnịarnu ẹhni lahnarnụ nụ rime ọroto.”
\c 3
\s1 Ọbochi Nyenwe aị
\p 
\v 1 Ele me whnụrnu n'anya, ka bụ ọkwukwo izi ke ẹbo me naagbanụ anụ, m naakpali echiche ọma nụ rime anụ.
\v 2 Anụ chenwanya ikwu-ọnu ele ọwhnurninya zị nsọ kwuru, ya nụ iwu Nyenwe aị nụ Nye Ọznohia aị nyernu anụ hite n'aka ele izi a.
\p 
\v 3 Anụ mahịa nụ mbọm nụ ele ọkwa emo jaava n'ọbochi ipne-aznụ, neezne izne n'anọ-ẹhni be.
\v 4 Be jaakaa, “Ndaa omezu mkwna ọvuva a? Hite nga ele nda aị nwụrnu ẹnwu, kpakara nhne zị kọriri kpa ọ zị hite nụ okike ọwa.”
\v 5 Be ma ama lewhuru anya n'ige wheru ewhe nụ Chiokike kwuru ọka, oligwe nụ ọwa zịri. O hiri nụ rime mini kehịa ọwa hite nụ mini.
\v 6 Ọ bụ masị hite nụ mini, ke okne mgba-mini ẹli, be jiri lulu ọwa ọknani.
\v 7 Kọvu oligwe nụ ọwa ke zị kịtna bụ ke ọ bịtaru hite n'ikwu-ọnu Chiokike wam, o jeeji bẹkwnu lulu. Ọ bịtaru be kwnornu ọbochi o jeekpe ele máa Chiokike ikpe, lulu be.
\p 
\v 8 Kọvu ele me whnụrnu n'anya, anụ chézu otu nhne ka, otu ọbochi nụ hne Nyenwe aị zị nụ lele otu pokwu awha, otu pokwu awha nụ lele otu ọbochi.
\v 9 Nyenwe aị zá naakpa ndnarna n'omezu mkwna a, lele kpa ele badnụ neeche, kọvu o nwernu ogologo ọsnuta ovu hne anụ zị, kwnornu nụ o píole nye ọbula whu etekne, kọvu ma kpakara badnụ hi nụ mmehie be whụya.
\p 
\v 10 Kọvu ọbochi Nyenwe aị jaava, ọ jọonu lele nye buznu, ele badnụ jáazị neele anya a. Oligwe jeeji okne mkpakpọ gawhe, kpakara nhne zị n'olu jeeji okne bẹkwnu gbaza. Ọwa nụ kpakara ẹrnu be rnụrnu nụ rime a jọowho iwhne.
\p 
\v 11 Kpa a mahịaru nụ kpakara nhne jaagbaza, ndaa kpa a kwesiri o wu bụdnu? A kwesiri o wu bụdnu zị nsọ, ya nụ ọ tụ ogwnu Chiokike.
\v 12 Kpa anụ neele anya ọvuva ọbochi Chiokike,\f + \fr 3:12 \ft Mọbu \fq ọbochi Nyenwe aị jeekpe ọwa nụ oligwe ikpe\f* anụ mee ma ọ va ngwa ngwa, oligwe jaagba bẹkwnu, kpakara nhne zị n'olu jeeji okne okpe bẹkwnu gbaza.
\v 13 Kọvu a neele anya oligwe ikne nụ ọwa ikne, lele kpa o kweru mkwna, ọro ome mma.
\p 
\v 14 Kam kpayarụ, ele me whnụrnu n'anya, hne anụ neele anya nhne ka, anụ gbalị ma anụ zịri snam, ele nwée ọtna ọtna, anụ nụ Chiokike zịri n'udno.
\v 15 Anụ vuru nụ mkpọma nụ ogologo ọsnuta ovu Chiokike bụ ọznohia anụ, lele kpa nnwọ nda aị Pọlu, nye a whnụrnu n'anya gbannụ anụ n'ọkwukwo hite n'akọniche Chiokike nyernu a.
\v 16 Ka bụ nhne o nookwu nụ kpakara ọkwukwo izi a, nga ọ naagba nhne gbasịri nhne ka, o nookwu agịda nhne siri rikne n'ọghohia, ke ele máa nhne nụ ele ovu be zá kwem nọokowahie, lele kpa be neeme nụ nhne berere zị n'ọkwukwo nsọ, ka bụ ma be la n'iyi.
\p 
\v 17 Kọvu anụ, ele me whnụrnu n'anya, anụ magwụ nhne ka, anya dụ anụ ẹli, ma nhne ọjo ke ele noolulu iwu ẹli neezni gharụ o duhie anụ, mee anụ dnahnala n'ogwuzosi rikne anụ.
\v 18 Kọvu anụ zịri nooso oso nụ oru nụ nhne ọmuma ke Nyenwe aị nụ Nye Ọznohia aị Jizọsi Karaịsi. Kpakara igwugwu zịnu a, kịtna, dụ ọkwnukokwnu. Amịm.
