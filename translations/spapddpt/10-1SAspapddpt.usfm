\c 3
\s1 Llamamiento a Samuel
\p 
\v 1 \w El|strong="H1992"\w* joven \w Samuel|strong="H8050"\w* \w ministraba|strong="H8334"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* en \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \w Elí|strong="H5941"\w*. En \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w era|strong="H1961"\w* escasa y \w las|strong="H1992"\w* visiones \w no|strong="H1961"\w* frecuentes.
\p 
\v 2 Por \w ese|strong="H1931"\w* \w tiempo|strong="H3117"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1931"\w* mientras \w Elí|strong="H5941"\w* \w estaba|strong="H1961"\w* \w acostado|strong="H7901"\w* en \w su|strong="H1931"\w* \w aposento|strong="H4725"\w*, \w cuando|strong="H3117"\w* \w sus|strong="H1931"\w* \w ojos|strong="H5869"\w* \w comenzaban|strong="H2490"\w* \w a|strong="H3068"\w* oscurecerse \w de|strong="H5869"\w* modo \w que|strong="H1931"\w* \w no|strong="H3808"\w* \w podía|strong="H3201"\w* \w ver|strong="H7200"\w*,
\v 3 \w antes|strong="H2962"\w* que se \w apagara|strong="H3518"\w* la \w lámpara|strong="H5216"\w* de \nd ʼElohim\nd*, y mientras \w Samuel|strong="H8050"\w* \w estaba|strong="H7901"\w* \w acostado|strong="H7901"\w* en el Tabernáculo de \nd \w Yavé|strong="H3068"\w*\nd*, en el lugar \w donde|strong="H8033"\w* \w estaba|strong="H7901"\w* el Arca de \nd ʼElohim\nd*,
\v 4 \nd \w Yavé|strong="H3068"\w*\nd* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w*.
\p Él respondió: \w Aquí|strong="H2005"\w* estoy.
\v 5 Enseguida \w corrió|strong="H7323"\w* hacia \w Elí|strong="H5941"\w* \w y|strong="H3588"\w* dijo: \w Aquí|strong="H2005"\w* estoy. ¿\w Para|strong="H3588"\w* \w qué|strong="H3588"\w* \w me|strong="H3588"\w* llamaste? \w Y|strong="H3068"\w* \w Elí|strong="H5941"\w* le contestó: \w Yo|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* \w llamé|strong="H7121"\w*. \w Vuelve|strong="H7725"\w* \w y|strong="H3588"\w* \w acuéstate|strong="H7901"\w*. \w Y|strong="H3068"\w* \w él|strong="H3588"\w* \w volvió|strong="H7725"\w* \w y|strong="H3588"\w* \w se|strong="H3808"\w* acostó.
\p 
\v 6 \nd \w Yavé|strong="H3068"\w*\nd* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w*. \w Samuel|strong="H8050"\w* \w se|strong="H3808"\w* \w levantó|strong="H6965"\w*, \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Elí|strong="H5941"\w* \w y|strong="H3588"\w* dijo: \w Aquí|strong="H2005"\w* estoy, ¿\w para|strong="H3588"\w* \w qué|strong="H3588"\w* \w me|strong="H3588"\w* llamaste?
