\id PSA - PMA Paama Language 
\h Sam 
\toc1 Sam keil 
\toc2 Sam 
\mt1 Sam keil  
\c 1  
\s1 Sien onen koakeil ualien one mal  
\q1
\v 1 Sien hel en koakeil:  
\q2 asesein rendemien koa meatin tatisa keil amul asani;  
\q2 armusiltei sakien onen meatin tisa keil,  
\q2 vuo arkapiltei vatal koakeil amumon tohtohien en tounah keil onen Ahi.   
\q1
\v 2 Vuo, keil avotin sien  
\q2 navong along kat mengkatien onen Ahi,  
\q2 meneai ka vongien, amundem usili.   
\q1
\v 3 Keil asuval vatiai koa mul en vali oai,\x + \xo 1:3 \xt Ser 17:8\x*  
\q2 son heite mal en avong teni,  
\q2 ka oute sakras varei vakou.  
\q1 Tounah vasi koa amumoni tahos imok.   
\b  
\q1
\v 4 Ka meatin tatisa keil armukteinek.  
\q2 Keil asuval sume uit koa rotahostei koa eang mul muh lini ran aneite.   
\q1
\v 5 Sakini, Ahi hesan mahien min meatin tatisa keil,  
\q2 irtotei hetal koakeil ualien one tahos.   
\q1
\v 6 Ven koakeil ualien one tahos,  
\q2 Ahi helosil kat keil ka hekur koe keil.  
\q1 Ka koakeil ualien one tisa, amul en sise ten matien.   
\c 5  
\s1 Ahi asuv kur koe koakeil ualien one mal  
\d Asuv houlu \w Deved\w* mutisi  
\q1
\v 1 O Iahova, kisan ralingom en selusien onak,  
\q2 ka kitaengon mahien onak.   
\q1
\v 2 Ahi ka asuv houlu onak,  
\q2 kilong tangien onak ven kovakataun inau.  
\q1 Namul nasan hisien keil onak minuk;   
\q2
\v 3 en visokon, kolong rek.  
\q1 Navong meteiai kistal, namul napeahik,  
\q2 ka nakilea keke kisan heite minau.   
\b  
\q1
\v 4 Keik korvitei Ahi koa kovasik ven sakien keil tatisa,  
\q2 kormaentei meatin tatisa keil avamai venuk.   
\q1
\v 5 Tovuti keil asakras avalomal en metom.  
\q2 Kolele tisa en koakeil koa ualien one romaltei.   
\q1
\v 6 Ku rasilin koakeil amul amumon luvosien.  
\q2 Ahi Asuv, tinom katiat varei ven koakeil ten rea ka vati luvosien keil.   
\b  
\q1
\v 7 Ka ven more envatien onom,  
\q2 nakilea maha en teim som.  
\q1 En Eim Votut onom, navati lat isom,  
\q2 naretengeiril minuk ven ka navouhou minuk.   
\q1
\v 8 Ahi Asuv, meatin houlu mete tisa enau.  
\q1 Kilamu enau en sise ten maluen,  
\q2 kitie sise koa em vati mousili.   
\b  
\q1
\v 9 Koakeil mete tisa enau ka tine vil en rendemien takarien,  
\q2 nasakras maling desien onak val en selusien one.  
\q1 Selusien one suval ahoung,  
\q2 koa leh rendemien onen meatin ka mu vini.\x + \xo 5:9 \xt Rom 3:13\x*   
\q1
\v 10 Ahi ten out nesa, hesan mahien min keil.  
\q2 Tounah tatisa koa avit avoumoni min meatin sav,  
\q2 hehiles hemai ris en keil.  
\q1 Kisila keil iha ranuk ven tisaen keil  
\q2 koa amumoni va katuk,  
\q2 veni keil aviles eisile ranuk.   
\b  
\q1
\v 11 Ka koakeil aro suai enuk en avong takeih, isi keil;  
\q2 ka lises, isau masmasuk.  
\q1 Kisak ven koakeil e vatuk  
\q2 keke meatin tatisa keil anapuruntei keil,  
\q2 hesakini ihat lat isom.   
\q1
\v 12 Ahi Asuv, tokolkatien onom hel en koakeil ualien one tahos;  
\q2 koring koe keil ral min envatien onom suval ousiel koa asuv lingi mul koe rea.   
\c 6  
\s1 Hisien ven kataunien onen Ahi en avong takeih keil  
\d Asuv houlu \w Deved\w* mutisi  
\q1
\v 1 Ahi Asuv, konavuroh kattei inau, konaseltei natal minau.\x + \xo 6:1 \xt Sam 38:1\x*  
\q2 Konatin kattei inau, konasantei mahien minau.   
\q1
\v 2 Ahi Asuv, kisan enmahisien minau ven avek memerau.  
\q2 Kisan keihoen minau ven nasakras moumon etai tounah.   
\q1
\v 3 Demvoen houlu en tinok.  
\q1 ?Ahi Asuv, kisan heite ten hisien onak nengeis?   
\b  
\q1
\v 4 Konalei vinitei inau, Ahi Asuv;  
\q2 kikataunau veni enmahisien onom mariso.   
\q1
\v 5 Meatin hesakras vandem katuk navong hemat.  
\q2 ?Isei kilea vamasmasuk navong mul tuai en avul?   
\b  
\q1
\v 6 Namurang vini inau;  
\q2 en vongien vasi, simetok mul kas oulung mak, sakini memer vasi.   
\q1
\v 7 Nasakras maleilei vatahos veni metok mutetep;  
\q2 namurang houlu veni meatin tatisa keil amul apurunau.   
\b  
\q1
\v 8 Alva soutin ranau, kami keke mimumon tisaen houlu,\x + \xo 6:8 \xt Mat 7:23; Luk 13:27\x*  
\q2 veni Ahi Asuv raengon tangien onak.   
\q1
\v 9 Kei long nau navong napeahi ven kataunien onen;  
\q2 ka kei hesan heite ten hisien onak.   
\q1
\v 10 Meatin keil koa amul apurunau, Ahi hehile lat keil,  
\q2 hesakini, keil imemou, imetau ka ilohosai ranau.   
\c 8  
\s1 Ahi ling tounah vasi ten out netan en hen meatin keil  
\d Asuv houlu \w Deved\w* mutisi  
\q1
\v 1 !Ahi Asuv onomai, isom marite mok en out vasi netan!  
\q2 Muohien ten hetetamenien onom vilelau en out nesa.   
\q1
\v 2 Masmasien heha minuk  
\q2 heka en titiali keil ka tivava keil.\x + \xo 8:2 \xt Mat 21:16\x*  
\q1 Keik koro en out tetahos ran koakeil uvae ral minuk;  
\q2 Koring koe koakeil avit avapurunuk.   
\b  
\q1
\v 3 Navong nales teilang koa komumoni,  
\q2 naseipat nales more avati ka hitu keil koa kolingi en vulie,   
\q1
\v 4 narendem usil meatin enges ten out netan.  
\q2 ?Vensa komundem keil?  
\q2 ?Komul kolei kat keil vensa?\x + \xo 8:4 \xt Siob 7:17-18; Sam 144:3; Hib 2:6-8\x*   
\b  
\q1
\v 5 Keik komumon meatin keil amulin tounah sav keil,  
\q2 kosan keihoen, muohien ka houhouen min keil.  
\q2 Keikos Ahi, kovi hetamen en keil.   
\q1
\v 6 Koling tounah vasi keil koa komumoni en hen meatin keil;\x + \xo 8:6 \xt 1Kor 15:27; Efes 1:22; Hib 2:8\x*  
\q2 korie lat keil avi hetetamen imok mulin tounah vasi ten out netan:   
\q2
\v 7 sipsip ka buluk ka tirendan vasi keil koa amual;   
\q2
\v 8 aman keil koa amuka en teilang,  
\q2 ka mesau keil ka tounah vasi keil emun ten atas.   
\b  
\q1
\v 9 !Ahi Asuv onomai, isom marite mok en out vasi netan!   
\c 9  
\s1 Masmasien va min Ahi veni mul lei rahit usite onen meatin keil ral min maluen  
\d Asuv houlu \w Deved\w* mutisi  
\q1
\v 1 Ahi Asuv, nimasmasuk eli en moulien onak;  
\q2 Nihitehiten mormore tounah keil koa komumoni.   
\q1
\v 2 Nisau hetal min sien venuk;  
\q2 nisau masmasuk, Ahi ten keihoen.   
\b  
\q1
\v 3 Navong kokistal, koakeil amumon rea ral minau alohosai;  
\q2 amusavoi, umot, ka umat.   
\q1
\v 4 Navong kolei revi usite onak,  
\q2 rendemien onom mal ka vi anatin.  
\q1 Kolonge usite onak mal  
\q2 ka komumoni tahos minau.   
\b  
\q1
\v 5 Kosan mahien min koakeil amusil ahi sav,  
\q2 komu rasilin meatin tatisa keil.  
\q2 Meatin etai hermundem kattei mun keil.   
\q1
\v 6 Koakeil uvae ral minau, ivupuol,  
\q2 komuas meteimal keil one vi atan sesuk mul.  
\q2 Ka meatin keil e hevobongen moulien one.   
\b  
\q1
\v 7 Ka Ahi, kei vi asuv houlu ten lises;  
\q2 kei rondan en avet ral keihoen onen keke voumon kot en meatin keil.   
\q1
\v 8 Kei losil kat out netan ral min maluen;  
\q2 lei revi usite onen meatin keil ten kantri vasi keil ral min rendemien koa mal.   
\b  
\q1
\v 9 Ahi Asuv sak ven koakeil meatin sav amumoni keih min keil,  
\q2 kei lei kat revi keil en avong takeih.   
\q1
\v 10 Ahi Asuv, koakeil akileak, indesinuk,  
\q2 kosakras kovalokovein keil navong umai venuk.   
\b  
\q1
\v 11 Rehesau masmas Ahi koa rondan en Hou \w Saeon\w*.  
\q2 Rehehitehiteni en out vasi en out netan asa kei mumoni.   
\q1
\v 12 Ahi mundem kat koakeil akur mahien,  
\q2 en rovobongentei tangien one.  
\q2 Koakeil amum tisa en mesav keil, Ahi hesa kesi min keil.   
\b  
\q1
\v 13 !Ahi Asuv, em hemahis inau li!  
\q2 Kilei kilea mahien onak  
\q2 koa meatin keil mete tisa enau amumoni minau.  
\q1 Kikulat nau ran matien, Asuv onak,   
\q2
\v 14 hesakini nakilea malomal en meten meatin keil ten out Serusalem,  
\q2 ka nihiteni min keil tounah vasi koa sakinau namasmasuk.  
\q1 Nasi nau houlu veni kokur koe moulien onak.   
\b  
\q1
\v 15 Meatin keil koa areingeingenuk umot en avul koa akili onen meatin sav vamot vaha ien;  
\q2 ka ai tetapolis koa alingi, rapus lat keil eris.   
\q1
\v 16 Ahi Asuv, vothot en kei sasen ka mul lei revi usite onen meatin keil.  
\q2 Ka asa koa meatin tatisa amumoni mai iat ris keil.   
\b  
\q1
\v 17 Matien vi keite onen meatin keil amum tisa,  
\q2 ka onen koakeil asesein Ahi.   
\q1
\v 18 Kosa, alei sesein livere keil,  
\q2 ka hermukteinek en avong vasi;  
\q1 keitinesek, koakeil tounah tovuol desien one mai vi heisavos,  
\q2 ka irtotei hemukonek lisenges.   
\b  
\q1
\v 19 !Ahi Asuv, amai! !Konamaentei meatin etai nandem heisav enuk!  
\q2 Kilah ruain koakeil amusil ahi sav keil imai venuk ka kisan mahien min keil.   
\q1
\v 20 Ahi, kumon keil imetaunuk,  
\q2 kisakin keil ilea keke avi meatin enges ten out netan,  
\q2 asakras aval vataveah.   
\c 15  
\s1 Sakien keil koa Ahi en vati  
\d Asuv houlu Deved mutisi  
\q1
\v 1 ?Ahi Asuv, isei heha neim en Eim Votut onom?  
\q2 ?Isei heha netan minuk en Hou \w Saeon\w* koa vi votut?   
\b  
\q1
\v 2 Vati meatin koa long kat Ahi en tounah vasi,  
\q2 koa mumon sakien koa tahos.  
\q1 Selusien onen vi anatin ka mal,   
\q2
\v 3 romumontei hithitusilien vaha kat meatin sav keil.  
\q1 Meatin enek romumtei vatisa min tunali keil,  
\q2 ka rosel kututtei meatin sav keil.   
\q1
\v 4 Kei en rovattei koakeil Ahi sesein keil,  
\q2 ka vouhou min koakeil along kat ren Ahi.  
\q1 Lises, meatin enek mumon asa koa vat kati,  
\q2 ka rovilestei rani.   
\q1
\v 5 Kei maen \w mani\w* min meatin sav keil ka rokurtei teisao eni.  
\q2 Ka en rovattei vakur mani en sise koa valuvos meatin koa romumontei tounah vatisa.  
\b  
\q1 Vati meatin koa mumon sakien keil koa amukonek,  
\q2 lises, moulien onen helomal hekeih.   
\c 16  
\s1 Ahi vi vatte ten moulien ka kur koe ir  
\d Asuv houlu Deved mutisi  
\q1
\v 1 Ahi Asuv, kikur koe inau,  
\q2 namundesinuk konamaentei tounah tisa nasut nau.   
\q1
\v 2 Naviteni minuk keke, “Keik kovi Asuv onak.  
\q2 Tounah vasi tetahos onak ka venuk.”   
\b  
\q1
\v 3 Meatin keil onen Ahi avi votut ka amoreite mok,  
\q2 ek vati mok nito hetal min keil.   
\q1
\v 4 Ka koakeil amusil ahi sav keil  
\q2 aleh mahien mai en keil.  
\q1 Navong keil iha netan min ahi one, nirkapiltei hetal keil;  
\q2 ka nirlah ruai tei hetal min keil navong akur sanien keil one.   
\b  
\q1
\v 5 Ahi Asuv, kosa moulien onak mules en hem;  
\q2 en avong keil koa hemai, namundesinuk kisan tounah natamurei eni.   
\q1
\v 6 Ahi, keik kotahos komulin atan vuo tounah sav keil ten out netan koa nakur kati.  
\q2 Inau nakur kat keik enges.   
\q1
\v 7 Ahi Asuv, namasmasuk ven korie minau asa numoni.  
\q2 Ka, en vongien emun, nalei kilea sise koa mal.   
\q1
\v 8 Ahi Asuv, lises nalinguk mulamun enau;  
\q2 veni koro vesesal, tounah tovuol vasak kulul inau.\x + \xo 16:8 \xt Umen 2:25-28\x*   
\b  
\q1
\v 9 Sakini, nasi nau mok, tinok vilelau en sien,  
\q2 ka metauen tovuol enau,   
\q1
\v 10 veni kokur koe nau ran keihoen ten matien.  
\q1 Lises namum vasi umen koa kosani minau,  
\q2 sakini, konaseseintei nau nihas en out ten matien.\x + \xo 16:10 \xt Umen 13:35\x*   
\b  
\q1
\v 11 Kitie minau sise ten moulien.  
\q1 Nalonge tahos imok ven koro ral minau.  
\q2 Vesesal venuk, sien mul lisenges.   
\c 19  
\s1 Tounah keil en teilang amul arie lat muohien ten hetetamenien onen Ahi  
\d Asuv houlu \w Deved\w* mutisi  
\q1
\v 1 Hitu keil en out nesa amul arie lat muohien ten hetetamenien onen Ahi,  
\q2 ka teilang emun mul vothot en tounah koa kei mumoni.   
\q1
\v 2 Navong meteiai mea roha, mul eris vit usil keihoen onen Ahi va vio … mea ris out mulan;  
\q2 ka avati emun mules vitehiten ileilien onen Ahi Asuv va vio … mea ris.   
\q1
\v 3 Koakeil enek arselustei, ka rea tovuol rovataengoni en keil;   
\q1
\v 4 ka mukos, longlongien keil one usil Ahi karahit out vasi;  
\q2 va rokol meatin vasi keil en out netan.\x + \xo 19:4 \xt Rom 10:18\x*  
\q1 Meteiai en out nesa, Ahi lingi en vulie.   
\q2
\v 5 En visokon vasi, mea ral min sien;  
\q2 kei suval meatin koa tin si ka sak mesei ven lohlohien tai.   
\q1
\v 6 Mea en usite ten teilang ka muloh va en usite sav.  
\q2 Kei sakin out vasi mutin, tounah tovuol vato suai eni.   
\b  
\s1 Mengkatien onen Ahi tahos imok  
\q1
\v 7 Mengkatien onen Ahi Asuv tahos imok,  
\q2 ka sak revi tiner.  
\q1 Hatkatien onen, rokilea rovaling desien orer eni;  
\q2 ka mul san meteisauen min koakeil one tovuol.   
\q1
\v 8 Mengkatien keil onen Iahova mal vasi,  
\q2 ka koakeil along kati, isi keil.  
\q1 Ren Ahi, rolonge rolong kilea,  
\q2 ka san ileilien min ir vasi.   
\q1
\v 9 Kei mal keke rorie lat houhouen orer min Ahi,  
\q2 rehoumoni lisenges.  
\q1 Mengkatien keil koa sani min ir avi anatin;  
\q2 keil amal vasi.   
\q1
\v 10 Keil atahos imok lohlin tounah vasi keil ten out netan,  
\q2 ka kasien teni mulin kasien ten hani.   
\q1
\v 11 Keil aviseinau, meatin toumien onom, en sakien keil koa tahos.  
\q2 Ka koakeil amum usili, akur uite koa tahos imok.   
\b  
\q1
\v 12 Avaseini koanek anatin, komai mesakras mevalei vasin tisaen keil onomai.  
\q2 Sakini, Ahi Asuv, munak namumon tounah tatisa tai nareingeingeni, kilah lati li ranau.   
\q1
\v 13 Ka tisaen keil koa namundem maenis namumoni, kiting koe inau li nanamottei mun eni.  
\q2 Konamaentei tisaen keil enek analamunau en sise koa romaltei.  
\q1 Hesakini, moulien onak kilea vatolas,  
\q2 ka nimaluv ran keihoen ten tisaen.   
\q1
\v 14 Ahi Asuv, komutut inau ka nakilea nito suai enuk.  
\q2 Ek vati mok keke selusien keil onak ka rendemien vasi keil onak, hemal en rendemien onom.   
\c 23  
\s1 Ahi asuv mul losil kat inau  
\d Asuv houlu Deved mutisi  
\q1
\v 1 Ahi Asuv, kei mul losil kat inau  
\q2 suval meatin koa losil kat sipsip keil osen.  
\q1 Tounah vasi koa vakataun moulien onak,  
\q2 kei sani minau.   
\q1
\v 2 Kei kur nau nuva en uteral koa oumunai tahos mul ien,  
\q2 ka mulamunau nuva en out koa oai mekaikai ka mandil.\x + \xo 23:2 \xt Rev 7:17\x*   
\q1
\v 3 Kei san keihoen hau minau  
\q2 ka mulamunau en sise koa mal,  
\q2 suval koa kei vat kati.   
\q1
\v 4 Avaseini munak niha en mari mankoli, nirmetautei,  
\q2 ven keik, Ahi Asuv, komusil inau.  
\q1 Kolei kokoe enau ka koring koe nau.   
\b  
\q1
\v 5 Komumon mari anien tai venau  
\q2 en out koa vativieh keil onak akilea avales inau.  
\q1 Kosan more amaien minau suval koa navi mari meatin tai,  
\q2 ka kovus anien vilelau en pelet koa kosani minau.   
\q1
\v 6 Nakilea keke tahosien ka more envatien onom housil kat inau en avong vasi,  
\q2 ka nito en teim som lisenges.   
\c 24  
\s1 Ahi vi asuv houlu ten muohien  
\d Asuv houlu Deved mutisi  
\q1
\v 1 Out netan ka tounah vasi keil koa amul ien avi onen Ahi;\x + \xo 24:1 \xt 1Kor 10:26\x*  
\q2 koakeil amoul ien, keil avi onen.   
\q1
\v 2 Kei ling kat atan nesa en huinev ten atas;  
\q2 vatte ten out netan, mumoni en anev ten atas.   
\b  
\q1
\v 3 !Anatin! !Ahi Asuv vi Ahi ten keihoen!  
\q2 ?Sakini isei kilea vahina en Hou Saeon onen Ahi Asuv?  
\q2 ?Isei kilea vaha en Eim Votut onen en out enek?   
\q1
\v 4 Koakeil enges sakien ka rendemien one mutolas.\x + \xo 24:4 \xt Mat 5:8\x*  
\q2 Koakeil armusiltei ahi sav ka amusil hatkatien onen lises.   
\q1
\v 5 Koakeil enek, Ahi hetokol kat keil ka houtut keil.  
\q2 En meten koakeil alele tisa en keil, hehitehiteni hehit keil amutolas.   
\q1
\v 6 Vati meatin keil amukonek umai ven Ahi.  
\q2 Akilea avamai en meten Ahi onen \w Siekob\w*.   
\b  
\q1
\v 7 !Sehen metareh!  
\q2 Voiteh ten Eim Votut hetah,  
\q2 veni asuv houlu ten muohien hemai neim.   
\q1
\v 8 ?Isei vi asuv houlu ten muohien?  
\q2 Kei vi Ahi koa kur hetetamenien ka keihoen,  
\q2 koa marite mok en mari rea keil.   
\q1
\v 9 !Les visi! Asuv houlu ten muohien mul mai.  
\q2 !Sehen mari metareh ten taon veni!  
\q2 !Voiteh ten Eim Votut hetah!   
\q1
\v 10 ?Isei vi asuv houlu ten muohien?  
\q2 Iahova, Asuv ten out nesa.  
\q2 !Kei vi asuv houlu ten muohien!   
\c 27  
\s1 Hisien ten masmasien  
\d Asuv houlu Deved mutisi  
\q1
\v 1 Ahi Asuv, kei vi meneai minau ka mutut nau.  
\q2 Sakini, narmetauntei meatin keil.  
\q1 Kei kur koe nau en tounah koa vasut nau.  
\q2 ?Sakini, mametaunsa?   
\b  
\q1
\v 2 Navong meatin tisa keil umai avit avouas nau ka asak visi mamat;  
\q2 Ahi hesakin nau nilikat keil, ka keil ilohosai ka isavoi, keil imotmot varei en sise.   
\q1
\v 3 Avaseini keke vangi meatin tavaeen keil imai ikarahit nau,  
\q2 tinok hermaleileitei.  
\q1 Munak koakeil alele tisa enau amea avit avahu vatal minau,  
\q2 desien onak en Ahi hermottei.   
\b  
\q1
\v 4 Tounah tai, navis Ahi veni;  
\q2 keinges ek vati.  
\q1 Ek vati mok nitos en Eim Votut onen  
\q2 lises en moulien onak.  
\q1 En out enek, metok hel en Ahi onak, en more nan lises,  
\q2 ka nihisi ven kataunien onen.   
\q1
\v 5 En avong takeih, inau nito ven Ahi.  
\q2 Kei kur koe nau en Eim Votut onen  
\q2 ka kur revi nau en out tetahos onen.   
\q1
\v 6 Hesakini, nilohlin koakeil avit avahu vatal minau.  
\q2 Nisan sanien keil min Ahi Asuv hetal min hisohisoen ten sien;  
\q2 nisau mini ka nimasmasi.   
\b  
\q1
\v 7 !Ahi Asuv, kitaengonau navong navisok!  
\q2 !Em hemahis nau li, ka kisan aneite ten hisien keil onak!   
\q1
\v 8 Tinok raengonuk navong kovit, “!Kimai venau!”  
\q2 Sakini, en tinok, numai venuk ka navisuk.   
\q1
\v 9 Konato suaitei ranau.  
\q2 Konavuroh kattei inau, konalei seseintei inau, meatin toumien onom.  
\q1 Ahi koa komutut inau, mulamu, kokataunau;  
\q2 konalokoveintei nau li nanato sasok.   
\q1
\v 10 Vahesa tata onak keilu mama onak lulokoveinau;  
\q2 ka keik, Ahi Asuv, kilei kat revi nau.   
\q1
\v 11 Ahi Asuv, kihiseinau en asa koa em vati moumoni;  
\q2 ka kilamunau en sise koa meatin tisa keil areingeingeni avousil inau eni.   
\q1
\v 12 Konamaentei inau min meatin tisa keil enek.  
\q2 Keil aselus karen inau en luvosien, ka lises avit avouas inau.   
\q1
\v 13 Ka asakras, veni nakilea keke nimoul  
\q2 niles tahosien keil onen Ahi.   
\q1
\v 14 !Kami miheling desien onami en Ahi Asuv!  
\q2 !Mihehati kami hekeih, minandemkotei!  
\q2 Anatin, miheling desien onami eni.   
\c 29  
\s1 Keihoen mul en ren Ahi  
\d Asuv houlu Deved mutisi  
\q1
\v 1 !Angelo keil ten out nesa, mihesan masmasien min Ahi!\x + \xo 29:1 \xt Sam 96:7-9\x*  
\q2 !Mihemasmasi ven muohien ka keihoen onen!   
\q1
\v 2 !Mihemasmas Ahi Asuv koa isen hetetamen imok!  
\q2 !Miheha netan min kei koa votut navong muohien onen hekistal!   
\b  
\q1
\v 3 Ren Ahi musel en mesaiuai ten atas;  
\q2 Ahi ten muohien, selusien onen suval voulul, mai kistal en teilang nesa en atas.   
\q1
\v 4 Ren Ahi keih imok,  
\q2 mul rie lat hetetamenien onen.   
\b  
\q1
\v 5 Ren Ahi suval angu tai koa kilea vakum vul mari vatiai keil,  
\q2 vakum vul vati sida emun.\f + \fr 29:5 \ft Vati sida vi vatiai tai koa mariso mulin vatiai sav keil. Keil ataveah rokol 27 mita ka meatin oulu (7) akilea avahuli kat he vakarahiti.\f*   
\q1
\v 6 Keihoen ten ren mumon atan kulul en hou keil ten out Lebanon ka en Vatihou Hermon.  
\q2 Lukulul suval titan buluk ka luvutahut suval buluk rendan tai.   
\b  
\q1
\v 7 Ren Ahi sakin ahil vil.   
\q1
\v 8 Ren sakin atan kulul en out volvol;  
\q2 en out volvol ten out Kates, atan mul kulul.   
\q1
\v 9 Ren Ahi muh rasilin mari vati ok keil,  
\q2 ka sakin eivorohus, ouai tovuol emun val ien.  
\q1 Ka en Eim Votut onen, meatin keil vasi avisohiso keih avit,  
\q2 “!Isen Ahi vina nesa!”   
\b  
\q1
\v 10 Ahi Asuv vi asuv ten huinev ten atas.  
\q2 !Anatin! Kei vi asuv ten tounah vasi kosa ka lisenges.   
\q1
\v 11 Ahi Asuv san keihoen min meatin keil onen,  
\q2 ka sakin tomat onen mul en moulien one.   
\c 30  
\s1 Ahi asuv mul san kataunien min ir  
\d Asuv houlu \w Deved\w* mutisi ten avong asehen voiteh ten Eim Votut onen Ahi  
\q1
\v 1 Ahi Asuv, namasmasuk veni keik kokataunau.  
\q2 Kormaentei koakeil avahu vatal minau avali nau ka avaselus kutut kat nau.   
\q1
\v 2 Ahi Asuv, napeahik eli ven kataunien onom,  
\q2 ka kosakinau namoul.   
\q1
\v 3 Kokur koe nau ran avul ten matien.  
\q2 Vesesal mamat, ka kosan ris moulien minau.   
\b  
\q1
\v 4 !Kami koa mimusil Ahi Asuv! !Mihesau masmasi!  
\q2 Ahi vi votut, mihendem kat asa koa kei mumoni min kami, ka mihehiten hihuri veni.   
\q1
\v 5 Vurohien onen mul tamureis,  
\q2 ka tahosien onen mul taveah.  
\q1 Avaseini simetomi houe en vongien;  
\q2 en meneai teni, mihelonge hetahos eris.   
\b  
\q1
\v 6 Mulamu, navong nales tahosien en moulien onak,  
\q2 ka navit sasok eni navit, “Tounah hetovuol hesut nau.”   
\q1
\v 7 Ahi Asuv, en avong koanek, kotahos minau,  
\q2 ka koring koe nau suval out tatosuaien.  
\q1 Ka katau suk, koro suai ranau,  
\q2 ka nametau houlu.   
\q1
\v 8 Sakini, navisok, Ahi Asuv.  
\q2 Napeahik ven kataunien onom navit,   
\q1
\v 9 “?Munak nimat, heite teni hehi asa?  
\q2 Heite hetovuol munak nihita en avul.  
\q1 ?Koakeil umatmat, imasmasuk?  
\q2 !Vuo! Asakras avisohiso usil tahosien onom.   
\q1
\v 10 !Sakini, Ahi Asuv, kitaengonau li ka kisan enmahisien minau!  
\q2 !Ahi, navit mahisuk kikataunau!”   
\b  
\q1
\v 11 Ka keik, koviles tangien onak  
\q2 mai vi holien ten sien.  
\q1 Isien onak, kokulati ranau,  
\q2 ka kosakinau numai nalonge tahos.   
\q1
\v 12 Sakini, nirto raengtei,  
\q2 nimasmas isom lises.  
\q1 Ahi Asuv, kovi Ahi onak;  
\q2 nil nihiten hihuri minuk lisenges.   
\c 32  
\s1 Koakeil methos onen Ahi mul en keil avilelau en sien  
\d Asuv houlu Deved mutisi  
\q1
\v 1 Sien hel en koakeil Ahi roleletei mun vatisa en keil ven tisaen one,  
\q2 en koakeil methos onen mul en keil.\x + \xo 32:1 \xt Rom 4:7-8\x*   
\q1
\v 2 Sien hel en koakeil Ahi Asuv roselus kattei keil ven sakkalkalien one,  
\q2 en koakeil luvosien tovuol en keil.   
\b  
\q1
\v 3 Munak narvit lattei sakkalkalien onak,  
\q2 namurang lisenges ka avek mai memerau veni.   
\q1
\v 4 Meneai ka vongien,  
\q2 kosan mahien minau.  
\q1 Keihoen onak vuol ranau varei,  
\q2 suval tilep vuol ka memes navong meteiai mutin keih.   
\b  
\q1
\v 5 Sakini, navit lat tisaen keil onak minuk Ahi.  
\q2 Sakkalkalien keil onak koa namum suai eni, nirmumontei mun.  
\q1 Ka narendemi navit mahit lat tisaen keil onak minuk,  
\q2 ka keik, kokulat keil ranau, ka methos onom hel eris enau.   
\b  
\q1
\v 6 Hesakini, koakeil amusiluk ihis venuk en avong takeih keil.  
\q2 Ka navong mahien hehi houlu hemai hehit vatahin koe keil, hesakras vasut keil.   
\q1
\v 7 Keik kovi out tatokusien onak,  
\q2 kikur koe nau en avong takeih.  
\q1 Nisau masmasuk houlu mok,  
\q2 ven koa koring koe moulien onak.   
\b  
\q1
\v 8 Evus, Ahi Asuv mul viteni vit, “Nihiseinuk en sise koa mal kovousili.  
\q2 Nisan rendemien tahos minuk.   
\q1
\v 9 Sakini konoumontei vatkeih onom nasuval hos tai,  
\q2 koa aling aean tai en ongon vasakini vamah ka voual vamal en sise.”   
\b  
\q1
\v 10 ?Milesi? Meatin keil amum kalkali, mahien hehi houlu hemai en keil,  
\q2 ka koakeil aling desien one en Ahi,  
\q2 envatien onen mul kav koe keil.   
\q1
\v 11 Kami koa mimum mal en meten Ahi, mihelonge hetahos ka mihevut kami.  
\q1 !Kami koa milong kati, mihehisohiso en sien!   
\c 40  
\s1 Masmasien min Ahi ven kataunien keil onen  
\d Asuv houlu \w Deved\w* mutisi  
\q1
\v 1 Navis Ahi Asuv ven kataunien onen ka narosini.  
\q2 Ka kei san ralingen ka raengon tangien onak.   
\q1
\v 2 Navong namot en mari avul tai, kei kulat nau.  
\q2 Navong namarindu en tanmelmel koa matetel, kei leh lat nau.  
\q1 Kei ling nau en out tahos,  
\q2 koa nakilea mato revi ien.   
\q1
\v 3 Ahi Asuv viseinau en souen hau tai,  
\q2 souen koa nakilea mamasmas Ahi orer eni.  
\q1 Koakeil araengon longlongien enek ihouhou min Ahi Asuv,  
\q2 ka keil iling desien one eni.   
\b  
\q1
\v 4 Sien hel en koakeil aling desien one en Ahi Asuv.  
\q2 Keil armusiltei ninin taluvosien keil,  
\q2 ka arkapiltei vatal min koakeil akur keihoen ran nana keil.   
\q1
\v 5 Ahi Asuv onomai, tounah houlu komumoni min komai.  
\q2 !Tounah tovuol vasuvaluk!  
\q1 Keik koling more hatkatien houlu ven komai.  
\q1 Meatin tovuol vahuli lat keil vasi,  
\q2 avi houlu ramat, nasakras mahit lat keil vasi.   
\b  
\q1
\v 6 Sanien keil em rovattei.\x + \xo 40:6 \xt Hib 10:5-7\x*  
\q2 Koseseini varei navong amunit vuseri en out ten sanien votut,  
\q2 vuo uas buluk vuo sipsip keil vasakin methos onom hel en keil.  
\q1 !Vuo! Keik komumon ralingomai mevalong katuk.   
\q2
\v 7 Sakini, mahiteni minuk mahit, “Kolesi, numai ke.  
\q2 Mengkatien keil koa mul en Tus Votut, komumoni venau.   
\q1
\v 8 !Ahi Asuv, ek vati mok mousil hatkatien keil onom!  
\q2 Lises, nihuli kat hihiseien keil onom en moulien onak.”   
\b  
\q1
\v 9 Sakini, en vangi meatin keil ten out Isrel,  
\q2 navit meseini keke kutut komai.  
\q2 Nirmusehtei, niles nihitehiten asa koa komumoni en komai.   
\q1
\v 10 Nirvuli kattei longlongien usil mututien onom.  
\q2 !Vuo! Lisenges, naselus usil leikatien ka kataunien onom min meatin keil.  
\q1 Navong meatin keil onom alah ruai,  
\q2 lises navitehiteni keke rendemien onom mul en komai ka korie lat envatien onom min komai.   
\b  
\q1
\v 11 Ahi Asuv, konakulattei enmahisien onom ranau.  
\q2 Lisenges kiting koe nau ven envatien onom ka leikatien tahos onom enau.   
\q1
\v 12 Tounah tatisa houlu akarahit inau,  
\q2 nasakras mahuli vasi.  
\q1 Tisaen onak keil mea en mesai,  
\q2 ka narlei kileatei mun sise mousili.  
\q1 Nalesi keke tisaen keil onak, navuli keil lohlin hiluk,  
\q2 sakini desien onak mot.   
\q1
\v 13 !Ahi Asuv, kiting koe nau!  
\q2 !Kikataunau li!   
\q1
\v 14 Koakeil avit avouas nau,  
\q2 kilikat rasilin keil ka hesakini keil imemou.  
\q1 Koakeil asi keil ven mahien keil onak,  
\q2 ilohosai ka ulie hetisa.   
\q1
\v 15 Koakeil amul arohtoh enau,  
\q2 itimanin navong huhuen keil one ral minau hemai hehi heisavos.   
\b  
\q1
\v 16 Ka koakeil umai venuk,  
\q2 ilonge hetahos ka sien hel en keil.  
\q1 Ka koakeil kosak koe keil isi keil,  
\q2 keil ihitehiteni lises ka lisenges ihit,  
\q2 “!Isen Ahi Asuv vina nesa!”   
\b  
\q1
\v 17 Ahi Asuv, avek merau ka navi livere enges.  
\q2 Em navobongentei nau li.  
\q1 Keik kovi Ahi onak koa mul kataunau ka kosakinau namaluv ran mahien keil onak.   
\c 42  
\s1 Hisien ten kataunien  
\q1
\v 1 Ahi onak, en moulien onak, maroro kat nau venuk.  
\q2 Anatin, nasuval tirendan tai koa maroro kati ven oai koa kistal en oaisal;   
\q1
\v 2 Ek vatuk houlu mok, Ahi ten moulien.  
\q2 ?Nengeis nimai ka niha netan en metom?   
\q1
\v 3 Meneai ka vongien, namis,  
\q2 ka nasakras maanian.  
\q1 Koakeil alele tisa enau amules avis inau avit, “?Ueee … Ahi onom kave?”   
\b  
\q1
\v 4 Tinok mis houlu navong namundem usil avong mulamu.  
\q2 Mulamu, namul ral min meatin keil koa meva en Eim Votut.  
\q1 Namulamun keil ka mevilelau en sien,  
\q2 memusau ka memasmasuk, Ahi.   
\q1
\v 5 ?Nalonge tisa varei vensa?  
\q2 ?Vensa namundemko mukonek?  
\q1 Ka mukos, naling desien onak enuk, Ahi.  
\q1 Nimasmasuk eris, Ahi onak koa komutut nau.   
\b  
\q1
\v 6 En out koa namul ien kosa, soutin ran out sak, nalonge tisa.  
\q1 Navong namul veah en out Sodan, ka Vatihou Hermon ka Hou Misar,  
\q2 rendemien onak vat eris minuk, Ahi.   
\q1
\v 7 Longmahien onak muas nau,  
\q2 suval mari oai koa mue nesa mot muroh en ahat keil netan.   
\q1
\v 8 En meneai, Ahi hetie lat envatien onen enau,  
\q2 hesakini, nisau masmasi en vongien.  
\q2 Anatin, nihis minuk, Ahi ten moulien onak.   
\b  
\q1
\v 9 Ahi koa ring koe nau, nihisi nihit,  
\q1 “?Vensa em vobongenau?  
\q2 ?Vensa namual ral min mahien ven tounah tatisa keil koa meatin tisa keil amumoni minau?”   
\q1
\v 10 Vativieh keil onak amul aselus karenau ka nalonge navit mamat veni.  
\q2 Lises avis katiat nau avit, “?Ueee … Ahi onom kave?”   
\b  
\q1
\v 11 ?Nalonge tisa varei vensa?  
\q2 ?Vensa namundemko mukonek?  
\q1 Ka mukos, naling desien onak enuk, Ahi.  
\q2 Nimasmasuk eris, Ahi onak koa komutut nau.   
\c 46  
\s1 Ahi ten keihoen mul ven ir  
\q1
\v 1 Ahi vi keihoen ka vi out tatosuaien orer,  
\q2 sak mesei lises vakataun ir en avong takeih keil.   
\q1
\v 2 Sakini, rehermetautei,  
\q2 avaseini munak alu houlul ka vatihou keil imaru iha en huinev ten atas.   
\q1
\v 3 Rehermetautei munak atas hevuvu, helohloh ka hemavul,  
\q2 ka sakin atan ka vatihou keil akulul.   
\b  
\q1
\v 4 En taon onen Ahi, oaisal tai mue luhu eni.  
\q2 Taon enek vi out votut koa Ahi ten out nesa mul ien, ka oaisal enek mul sakin meatin keil en out enek asi keil.   
\q1
\v 5 Ahi varei mul en meteimal enek,  
\q2 sakini asakras avou rasilini.  
\q1 Anatin, en visokon semau, hemai hesan kataunien min koakeil aro ien.   
\q1
\v 6 Ahi hesel hesuval voulul,  
\q2 ka ren hesakin atan hemasil.  
\q1 Hesakini, meatin keil ten out netan isil,  
\q2 ka keihoen onen asuv houlu keil hemerangle.   
\b  
\q1
\v 7 Iahova, asuv houlu ten out nesa, mul ven ir.  
\q2 Ahi onen \w Siekob\w* vi out tatosuaien orer.   
\b  
\q1
\v 8 Mihemai, miheles asa koa Ahi Asuv mumoni.  
\q2 Miheles marmari tounah keil koa mumoni en out netan.   
\q1
\v 9 Huhuen keil ten out netan, kei mumoni evus varei.  
\q2 Kum vulvul hisuput keil ka ai takan keil emun.  
\q2 Ka ai keil tatosuaien, Ahi munit lini.   
\q1
\v 10 Ahi viteni min keil vit, “!Miheha netan ka miheilea keke inau navi Ahi!  
\q2 !Keihoen onen asuv keil ten out netan mules en hek!  
\q2 Ka moulien onen tounah vasi keil ten out netan emun mules en hek.”   
\b  
\q1
\v 11 Iahova, asuv houlu ten out nesa, mul ven ir.  
\q2 Ahi onen Siekob vi out tatosuaien orer.   
\c 47  
\s1 Ahi mul losil kat tounah vasi ten out netan  
\d Natin Korah keil amutisi  
\q1
\v 1 !Meatin vasi keil, miheovasvas hemi en sien!  
\q2 Mihemakul en isen Iahova hetal min masmasien.   
\q1
\v 2 Mihemasmas Iahova koa vi hetetamen mok ka kur keihoen.  
\q2 Kei vi mari asuv houlu koa mul losil kat out vasi netan.   
\q1
\v 3 Kei sakin ir rolohlin meatin sav keil,  
\q2 kei ling kantri sav keil amul en her.   
\q1
\v 4 Atan koa romul ien, kei rie lati hehi orer,  
\q2 ka me-Isrel keil koa kei en vat keil, asi keil veni.   
\b  
\q1
\v 5 Ahi vina nesa en vulin ten keihoen onen,  
\q2 Iahova vina nesa ral min makulien ten sien ka verien ten hon keil.   
\q1
\v 6 !Mihesau masmas Ahi!  
\q2 !Mihehati lat isen asuv houlu orer!   
\q1
\v 7 Ahi vi asuv houlu ten out vasi netan,  
\q2 tahos rehou lati hetal min souen keil.   
\b  
\q1
\v 8 Ahi mul rondan en vulin ten keihoen onen koa votut,  
\q2 kantri keil ten out netan amul en hen.   
\q1
\v 9 Hetetamen keil ten kantri vasi keil umai en out tas  
\q2 ral min meatin keil onen Ahi koa \w Ebraham\w* va netan mini.  
\q1 Keihoen onen Ahi lohlin keihoen onen meatin tavaeen keil onen kantri vasi keil,  
\q2 kei mul losil kat out vasi.   
\c 51  
\s1 Hisien ven enmahisien onen Ahi  
\d \w Sam|lemma="Sam keil"\w* tai onen asuv houlu \w Deved\w* navong \w provet\w* Netan mai veni ka vit lati keke mum tisa ral min Batsiba \bk (2Saml 13:13-17)\bk*  
\q1
\v 1 Ahi, em hemahis nau li,  
\q2 veni envatien mul enuk lises.  
\q1 Ven more enmahisien onom mariso,  
\q2 sahul lin tisaen keil onak.   
\q1
\v 2 Kas lin sakkalkalien keil onak eli,  
\q2 ka kumonau nitolas ran tisaen keil onak.   
\b  
\q1
\v 3 Nalei kilea li tounah koa romaltei en moulien onak,  
\q2 lises namundem kilea saktisaen keil onak.   
\q1
\v 4 Tisaen koa namumoni, namumoni va katuk enges, Ahi;  
\q2 sakien onak eli romaltei en metom.  
\q1 Sakini mal keke kolei revi sakien keil onak,  
\q2 keik komal keke kosan mahien minau.\x + \xo 51:4 \xt Rom 3:4\x*   
\q1
\v 5 Sakkalkalien keil mul tuai eli enau navong avasi nau.  
\q2 Anatin, navong mama onak ro enau, natisaso tuai.   
\b  
\q1
\v 6 Keik em vati li mok makur anatinien en moulien onak,  
\q2 kisien rendemien onak en meteisauen onom.   
\q1
\v 7 Kisahul lin tisaen onak keke nitolas,  
\q2 kikas motein moulien onak eli hemai hoh vis hoh imok.   
\q1
\v 8 Kimaenau nilonge hetahos eris ka nito en sien,  
\q2 ka avaseini mahien koa kosani minau vulvul nau, kimaenau li nimakul en sien eris.   
\q1
\v 9 Konaleletei mun natisa enau,  
\q2 kisahul lin sakkalkalien keil onak.   
\b  
\q1
\v 10 Ahi kum kes moulien onak eli hemai hetolas,  
\q2 kisan rendemien hau minau koa housil katuk lisenges.   
\q1
\v 11 Konasila lattei nau nanaha ranuk,  
\q2 konakulattei ninin onom koa vi votut naha ranau li.   
\q1
\v 12 Kisan risi minau sien koa nakuri mulamu navong komutut nau,  
\q2 ka kumonau li ek hehati malong katuk en tounah vasi.   
\q1
\v 13 Navong kosak revi nau, inau suk, nihisein meatin tatisa keil en mengkatien keil onom,  
\q2 ka keil emun ihiles ka iha ris venuk.   
\b  
\q1
\v 14 Ahi, kutut moulien onak, konamaentei nau li nanamat,  
\q2 ka inau nimakul usil maluen onom hetal min sien.   
\q1
\v 15 Ahi Asuv, kikataunau li maselus,  
\q2 ka nihati lat isom hetal rek.   
\b  
\q2
\v 16 Em rovattei keke nuas buluk vuo sipsip keil ihi sanien votut keil minuk.  
\q2 Munak ninit sanien onak hehat minuk, kirsiktei veni.   
\q1
\v 17 Sanien votut onak koa nisani minuk, Ahi, hehi rendemien tai koa merau.  
\q2 Keik kosakras kovasesein meatin koa tin mah ven tisaen keil onen ka koa viles moulien onen ran keil.   
\b  
\q1
\v 18 Ahi onak, kum kes vieh ten taon ten out \w Serusalem\w*,  
\q2 kitie lat tahosien onom ka kikataun Serusalem koa mul en Hou \w Saeon\w*.   
\q1
\v 19 En avong koanek, kilonge hetahos eris ven sanien votut koa mal,  
\q2 ka en sanien votut keil koa meheniti heha venuk.  
\q1 En avong koanek, mehouas buluk keil ka meheling keil iha en ahor ten sanien votut heha venuk.   
\c 63  
\s1 Sien onen koakeil envatien one mul en Ahi  
\d \w Sam|lemma="Sam keil"\w* tai onen \w Deved\w* navong ro suai ran asuv houlu Sol en out volvol ten out Sudah (1 Sam1 23:14)  
\q1
\v 1 Ahi Asuv, keik kovi Ahi onak, amai kat nau venuk.  
\q2 Maroro kat nau venuk suval koa naro en out memes koa oai tovuol ien.   
\q1
\v 2 Ek vati mahisu minuk en Eim Votut onom,  
\q2 ek vati malei vis keihoen ka muohien onom.   
\q1
\v 3 Envatien onom koa korie lati min komai lisenges,  
\q2 kei tahos imok mulin tounah sav keil en moulien onomai,  
\q2 sakini nihati lat isom.   
\q1
\v 4 En avong vasi en moulien onak, nisan masmasien onak minuk,  
\q2 navong navis, nihati lat hek keilu hehina nesa hehat venuk.   
\q1
\v 5 Neim en tinok, kosakinau nito en tahosien hesuval koa nakan more anien tai ka nalonge tahos,  
\q2 ka nisau en souen keil ten masmasien hehat minuk.   
\q1
\v 6 Navong namul en avet, namundem katuk.  
\q2 Vongien va rokol out mulan, namules namundem usiluk.   
\q1
\v 7 Namundem usiluk veni lises kovi kataunien minau.  
\q2 Nisau hetal masmasien ven koa kokav koe inau suval toahin tai mul kav koe titan keil en apouen.   
\q1
\v 8 Avong vasi, naro kos vesesal venuk, ka hem kur koe inau.   
\b  
\q1
\v 9 Meatin keil koa asak visi avou vini nau,  
\q2 kumon keil iha netan en out ten matien.   
\q1
\v 10 Kisakin keil imatmat en vaeen keil,  
\q2 ka kisakin huli rendan keil imai ian teiai one.   
\q1
\v 11 Inau koa nihi asuv houlu ten out Isrel, nihilelau en sien  
\q2 navong nilesi keke Ahi ling koakeil avavae vatal minau en hek.  
\q1 Koakeil amumon hatkatien en isen Ahi ihati lat isen,  
\q2 ka koakeil amul aliluvos, keil ito raeng.   
\c 65  
\s1 Tounah vasi en out netan amasmas Ahi en souen  
\d Souen tai onen \w Deved\w*  
\q1
\v 1 Ahi onomai, mal keke mevati lat isom en Hou \w Saeon\w*,  
\q2 ka mehehuli kat hatkatien keil koa memumoni ral minuk,   
\q2
\v 2 veni keik komul kosan aneite ten hisien keil onomai.  
\q1 Meatin keil ten out vasi imai venuk,   
\q2
\v 3 veni sakkalkalien keil onomai amuas komai,  
\q2 ka keik kosahul lin tisaen keil onomai ka konaleletei mun natisa en komai.   
\q1
\v 4 Sien hel en koakeil keik kolei kan keil  
\q2 keke umai avato en teahu ten Eim Votut onom.  
\q1 Komai mehelonge hetahos imok en mormore tounah keil onom ten demkatien  
\q2 koa amul en Eim Votut onom.   
\b  
\q1
\v 5 Kosan aneite ten hisien keil onomai navong melohlin meatin sav keil en avong ten rea.  
\q2 En keihoen komutut komai.  
\q1 Meatin keil koa amul rahit out netan ka en usi atas,  
\q2 keil aling desien one enuk.   
\q1
\v 6 Ral min keihoen onom, koling kat vatihou keil,  
\q2 keil arie lat mari keihoen onom.   
\q1
\v 7 Kosakin atas keil amerau,  
\q2 verien ten tahe keil, komumoni va netan.  
\q1 Kosakin koakeil amumon selien,  
\q2 aro raeng.   
\q1
\v 8 Meatin keil ten out vasi en out netan  
\q2 amutimanin ven marmari tounah keil koa komumoni.  
\q1 En keite vasi keil ten out netan,  
\q2 meatin keil amakul en sien venuk.   
\b  
\q1
\v 9 Kolei kat revi atan ka kosan ous musani,  
\q2 kosakin amas mul ien ka tounah vasi amoul tahos ien.  
\q1 Kosakin oai vilelau en poal keil,  
\q2 ka kosakin anien mul moul en out netan.  
\q1 Keik komul komumoni mukok:   
\q1
\v 10 navong meatin keil akah lin out evus,  
\q2 kosan ous musani.  
\q1 Atan koa keih, ous sakini mai memerau,  
\q2 ka tounah vasi akilea avahitehiteh eni.   
\q1
\v 11 Ven tahosien onom, kosan amas min komai.  
\q2 Out vasi kova ien, amas musiluk.   
\q1
\v 12 Kosakin tirendan osomai avilelau en atan onomai,  
\q2 hou keil avilelau en sien.   
\q1
\v 13 Buluk ka sipsip keil osomai avi houlu,  
\q2 ka kosakin ah osomai avilelau en anien.  
\q1 Tounah vasi koa moul alonge tahos ven amas onom,  
\q2 ka amusau masmasuk.   
\c 66  
\s1 Souen ten masmasien ven more leikatien onen Ahi  
\q1
\v 1 !Meatin vasi keil ten out netan,  
\q2 mihemasmas Ahi hetal makulien ten sien!   
\q1
\v 2 Mihesau usil isen koa vi hetetamen,  
\q2 mihesan masmasien mini ven hetetamenien onen.   
\q1
\v 3 Mihehiteni min Ahi mihehit, “!Tounah vasi koa komumoni tahos imok!  
\q2 Keihoen onom marite mok, mul sakin vativieh onom keil amaleilei en metom.   
\q1
\v 4 Koakeil vasi amul en out netan uva netan minuk,  
\q2 keil amusau masmasuk, amusau masmas isom.”   
\b  
\q1
\v 5 Almai ka alles asa Ahi mumoni,  
\q2 mormore tounah keil koa mumoni ven meatin keil ten out netan.   
\q1
\v 6 Kei viles Atas Tahilhili mai vi atan tames,\x + \xo 66:6 \xt Eks 14:21; Sos 3:14-17\x*  
\q2 kei sakin avu orer keil amu koteh Oaisal Sodan en ale.  
\q1 Ekonek rosi ir ven asa kei mumoni.   
\q1
\v 7 En keihoen onen, mul losil kat out netan,  
\q2 mul lei kokoe en kantri keil vasi  
\q2 keke koakeil asesein losilkatien onen, anahati lat sasentei keil.   
\b  
\q1
\v 8 Meatin keil ten out netan, rehemasmas Ahi orer,  
\q2 masmasien orer heha vasin out.   
\q1
\v 9 Kei kur koe moulien orer,  
\q2 romaentei tounah vasut ir.   
\b  
\q1
\v 10 Ahi, keik kosan sakvisien min komai.  
\q1 Suval silva koa ahang kan moteini,\f + \fr 66:10 \ft Suval led, navong aling silva en ahang, mukurle. Tahul teni remal mules, ka silva koa mutolas, amutah lati keke avoumon tounah eni.\f*  
\q2 komotein moulien onomai en sakvisien keil.   
\q1
\v 11 Komaen komai mimot en eitapolis tai,  
\q2 ka koling tounah keil koa meas en eisilomai.   
\q1
\v 12 Komaen koakeil avi vativieh ral komai avitan en komai,  
\q2 e memu koteh ahang ka oai.\f + \fr 66:12 \ft Koanek mul selus usil sakien koa Ahi rie lat kei min keil ka en ahang en Vatihou Senae ka en oai en Atas ak Tahilhili.\f*  
\q1 Ka kosa, komul kolah lat komai meva en out ten amas.   
\b  
\q1
\v 13 Nikur sanien votut hemai en Eim Votut onom ka niniti hehat minuk,  
\q2 nisani minuk asa koa navat kati.   
\q1
\v 14 Asa koa navat kati minuk navong namul en avong tisa,  
\q2 nisani minuk.   
\q1
\v 15 Nikur sipsip keil ka ninit keil en ahor ten sanien venuk,  
\q2 ninit buluk ka nani keil emun hesakin vite hetupan hehat venuk.   
\b  
\q1
\v 16 Kami koa mivouhou min Ahi, almai ka allong nau.  
\q2 Nihitehiteni min kami tounah sa koa kei mumoni minau.   
\q1
\v 17 Navis kataunien mini,  
\q2 ka namasmasi ral min souen keil.   
\q1
\v 18 Munak nihuli kat tisaen keil en moulien onak,  
\q2 Ahi Asuv hesakras valong nau.   
\q1
\v 19 Ka Ahi raengonau varei,  
\q2 kei long hisien onak.   
\q1
\v 20 Namasmas Ahi veni kei roseseintei hisien onak,  
\q2 vuo rokulattei envatien onen koa mul lises ka lisenges ranau.   
\c 67  
\s1 Meatin vasi keil ten out netan ihati lat isen Ahi  
\q1
\v 1 Ahi, kitokol kat komai en enmahisien onom,  
\q2 kiles komai hetal min tahosien onom.   
\q1
\v 2 Kitie lat rendemien onom min meatin keil ten out netan,  
\q2 keke availea sise ten mututien onom.   
\b  
\q1
\v 3 O Ahi, meatin keil ihati latuk.  
\q2 Anatin, meatin vasi keil ihati lat isom.   
\q1
\v 4 Meatin ten kantri vasi keil isi keil ka isau en sien,  
\q2 keil isau veni keik kosan mahien min meatin keil en sakien ten maluen,  
\q2 keik komulamun meatin ten kantri vasi keil en out netan.   
\q1
\v 5 O Ahi, meatin keil ihati latuk.  
\q2 Anatin, meatin vasi keil ihati lat isom.   
\b  
\q1
\v 6 Ahi onomai, komul kosan tokolkatien min komai,  
\q2 komul kosakin amas mul en atan osomai.   
\q1
\v 7 Anatin, tokolkatien onom mul en komai,  
\q2 ka koakeil ten out netan ilesi ka ihouhou minuk.   
\c 70  
\s1 Hisien ten kataunien\f + \fr 70:0 \ft Sam enek vesesal vatte vatas en \xt Sam 40:13-17\ft .\f*  
\d Asuv houlu \w Deved\w* mutisi  
\q1
\v 1 O Ahi, kutut moulien onak eli.  
\q2 O Iahova, kikalah kimai kikataunau.   
\q1
\v 2 Koakeil avit avou vini nau,  
\q2 keik kilikat rasilin keil keke imemou.  
\q1 Koakeil asi keil ven sakvisien keil onak,  
\q2 ilohosai ka ulie hetisa.   
\q1
\v 3 Koakeil amul amumon tohtohien va kat inau,  
\q2 kisakin huhuen keil one ral minau hemai hehi heisavos keke ilohosai en memouen.   
\b  
\q1
\v 4 Ka koakeil umai venuk,  
\q2 isi keil ka ilonge hetahos venuk.  
\q1 Koakeil e vat mututien onom ihitehiteni lises ihit,  
\q2 “!Ahi vi hetetamen imok!”   
\q1
\v 5 O Ahi, avek memerau ka navi livere enges,  
\q2 kikalah kimai venau li.  
\q1 Keik kovi kataunien onak ka korali lat inau lises.  
\q2 O Iahova, konatountei li.   
\c 71  
\s1 Hisien onen meatin koa matu  
\q1
\v 1 O Iahova, numai mato suai enuk,  
\q2 konamaentei vativieh keil onak anali nau ka anasakinau nanamemou.   
\q1
\v 2 Kimai kikataunau ka kiting koe nau ran tounah koa vasut nau,  
\q2 veni keik komal revi.  
\q1 Kitaengon isien onak eli ka kutut inau.   
\q1
\v 3 Keik kihi out tatosuaien onak,  
\q2 koa nakilea mato suai ien.  
\q1 Kisan mengkatien keke mututien onak hemai hekistal  
\q2 veni naling desien onak enuk suval koa naling desien onak en eim tai koa keih imok.   
\b  
\q1
\v 4 O Ahi onak, kikulat nau ran hen koakeil amum kalkali,  
\q2 ran keihoen onen koakeil amum romaltei ka apurun heisav en mesav keil.   
\q1
\v 5 O Ahi Asuv, naling desien onak enuk.  
\q2 O Iahova, nakur anatin enuk navong navi havivi rokol kosa.   
\q1
\v 6 Navarengein moulien onak enuk.  
\q2 Keik koro ral minau en avong avasi inau rokol kosa.  
\q1 Lisenges, nimasmasuk.   
\b  
\q1
\v 7 Kosakin moulien onak suval metai tai koa meatin sav keil alesi ka aleisungeini,  
\q2 veni keik koring koe nau keih.   
\q1
\v 8 En avong vasi, namasmasuk.  
\q2 Navitehiten hetetamenien onom lises.   
\q1
\v 9 Konaso seseintei nau navong nihi ulmatu,  
\q2 konalokoveintei nau navong keihoen onak hetovuol emun.   
\q1
\v 10 Vativieh keil onak avit avou vini nau,  
\q2 keil avit usil inau ka amumon hatkatien va kat inau.   
\q1
\v 11 Aviteni avit, “Ahi lokoveini ka tovuol vakatauni,  
\q2 sakini rovakatau usili ka rovahuli kati.”   
\b  
\q1
\v 12 O Ahi onak, konaltei soutin ranau,  
\q2 kikalah kimai kikataunau li.   
\q1
\v 13 Kisakin koakeil avit avapurun nau,  
\q2 imemou ka ise hetisa.  
\q1 Koakeil uvae kat nau,  
\q2 kisakin keil imemou ka ku vinvini keil.   
\q1
\v 14 Ka inau, niling desien onak enuk,  
\q2 ka nil nimasmasuk hehi houlu vis hehi houlu mok.   
\q1
\v 15 Inau, nil nihit usil umen keil onom koa mal,  
\q2 niselus usil sakien keil ten mututien onom lises,  
\q2 avaseini nasakras mahuli vasi.   
\q1
\v 16 Nimai hetal masmasien ven tounah koa keik, Iahova koa kovi Ahi onomai, komumoni ral min keihoen onom.  
\q2 Nihit usil umen keil koa mal koa keik enges, komumoni.   
\b  
\q1
\v 17 Koviseinau navong navi ehon rokol kosa,  
\q2 ka namules navitehiten mormore tounah koa komumoni.   
\q1
\v 18 Sakini, navong nihi ulmatu ka hiluk hoh,  
\q2 konalokoveintei nau li, Ahi.  
\q1 Kitos hetal minau navong nihitehiten usil keihoen ka hetetamenien onom  
\q2 min titiali keil koa amul, ka min koakeil il imai veah ikatau.   
\b  
\q1
\v 19 Ahi, sakien keil ten maluen onom marite vis marite mok.  
\q2 Komumon marmari tounah keil ka tovuol vasuvaluk.   
\q1
\v 20 Avaseini komaenau navisu en avong takeih ka sakvisien keil,  
\q2 katau eni, kisan ris keihoen minau.  
\q1 Munak namesai vesesal mamat,  
\q2 ka korali lat ris nau ran matien.   
\q1
\v 21 Kisan ris hetetamenien minau heli koa nakuri mulamu.  
\q2 Kisuv lat ris rendemien onak.   
\b  
\q1
\v 22 Nisau masmasuk hetal min kitar onak.  
\q2 O Ahi onak, nimasmasuk veni komusil kat hatkatien keil onom lises.  
\q1 Anatin, hetal min iukalele onak, nisau en souen keil heha minuk,  
\q2 Ahi onen me-Isrel keil, kovi votut imok.   
\q1
\v 23 Nimakul en sien,  
\q2 nisau hetal min moulien vasi onak  
\q2 veni keik komutut nau.   
\q1
\v 24 Nihit usil sakien ten maluen onom lises,  
\q2 veni koakeil avit avapurunau, keik kolikat rasilin keil ka kosakin keil alohosai en memouen.   
\c 84  
\s1 Sien onen koakeil uva netan min Iahova en Eim Votut onen  
\d Natin Korah keil amutisi  
\q1
\v 1 Iahova, asuv houlu ten out nesa,  
\q2 Eim Votut onom vi moreite mok.   
\q1
\v 2 Ek vati mato en out enek.  
\q2 Ek vati mok mato en Eim Votut onen Iahova.  
\q1 Ral min moulien vasi onak,  
\q2 nisau en sien minuk, Ahi koa moul.   
\b  
\q1
\v 3 Tahos imok masuval avervatu keil koa amumon anu ome en Eim Votut onom,  
\q2 keil avise eim onom vahi teim se.  
\q1 Keil aravo kat titae keil vesesal ven ahor onom,  
\q2 O Iahova, asuv houlu ten out nesa,  
\q2 keik kovi asuv houlu onak ka Ahi onak.   
\q1
\v 4 Tokolkatien mul en koakeil aro en Eim onom,  
\q2 veni keil amusau masmasuk lises.   
\b  
\q1
\v 5 Tokolkatien hel en koakeil amundesinuk keke kovasan keihoen min keil,  
\q2 min koakeil aling rendemien one keke avaha avasao en Eim Votut onom en Hou Saeon.   
\q1
\v 6 Navong amual aka vas poal tames ten out Baka,  
\q2 keil ales oai mul memela en ahat keil,  
\q2 ka ous mus rohtoh sien vulioai keil.   
\q1
\v 7 Keil akur keihoen en sise one,  
\q2 hetokol avong keil iles Ahi en out \w Saeon\w*, kei koa vi houlu mulin ahi keil onen meatin sav keil.   
\b  
\q1
\v 8 O Iahova, Ahi ten out nesa, kitaengon hisien onak eli.  
\q2 Ahi onen \w Siekob\w*, kisan ralingom minau.   
\q1
\v 9 O Ahi, kitokol kat asuv houlu onomai koa suval eikokoe onomai.  
\q2 Kilele hetahos min kei koa korie lati.   
\b  
\q1
\v 10 Munak nakilea matos en teahu ten Eim Votut onom avong tas,  
\q2 kei tahos imok mulin avong taosen tai en out sav.  
\q1 Ahi onak, munak mal mahi meatin kuren tanges koa lei kokoe voiteh ten Eim Votut onom,  
\q2 nisi nau mok helin munak mato en amas en eim tavolin onen kei koa mum kalkali.   
\q1
\v 11 Iahova, keik komul koring koe komai ka muohien onom suval meteiai.  
\q2 Kosan tahosien ka houhouen min komai.  
\q1 Keik korseseintei kovasan tounah keil tetahos  
\q2 min koakeil ualien one mutolas.   
\b  
\q1
\v 12 Iahova, asuv houlu ten out nesa,  
\q2 tokolkatien onom hel en koakeil aling desien one enuk.   
\c 85  
\s1 Hisien keke Ahi hesan ris tahosien onen min meatin keil onen  
\d Natin Korah keil amutisi  
\q1
\v 1 Iahova, kosik kovasan tahosien en atan osom.  
\q2 Anatin, kosan ris amas en atan ten out Isrel.   
\q1
\v 2 Komumon methos onom en komai, meatin keil onom koa memum tisa minuk,  
\q2 korleletei mun vatisa en sakkalkalien keil onomai.   
\q1
\v 3 Tinom rovepengtei mun en komai,  
\q2 kihiles vurohien onom heha ran komai.   
\b  
\q1
\v 4 Ahi ten mututien onomai, kiling ris komai en vulumai,  
\q2 ka tinom naattei mun komai.   
\q1
\v 5 ?Ahi, mukave? ?Tinom heat komai lisenges?  
\q2 ?Kitie lat vurohien onom min titamai ka havimai keil?   
\q1
\v 6 Kisan ris tahosien min komai li, meatin keil onom,  
\q2 keke mekilea mevamasmasuk.   
\q1
\v 7 O Iahova, kitie lati min komai envatien onom koa sakras vavus,  
\q2 ka kutut moulien keil onomai.   
\b  
\q1
\v 8 Kami meatin keil mihetaengonau.  
\q2 Inau, nilong kat asa koa Iahova koa vi Ahi hehiteni minau.  
\q1 Kei vat kati keke hesan tomat min meatin keil onen.  
\q2 Ka meatin votut keil onen irmumontei mun unounien one.   
\q1
\v 9 Anatin eli keke kei sak mesei voutut koakeil avouhou mini.  
\q2 Kei hekataun ir keke toralien onen koa hetetamen imok kilea val en atan oser.   
\b  
\q1
\v 10 Ahi hetie lat envatien onen min meatin keil onen  
\q2 ka keil usil kati lisenges.  
\q1 Keil um hemal en meten,  
\q2 ka kei hesan tomat hel ven keil.   
\q1
\v 11 Meatin keil ten out netan iseipat ka usil kat Ahi,  
\q2 ka kei en out nesa hetapehai en keil ka hetali lat keil en maluen onen.   
\q1
\v 12 Anatin keke Iahova houmon amas min ir,  
\q2 hesakin aneite hehi houlu hekistal en atan oser.   
\q1
\v 13 Maluen onen Iahova mulamuni  
\q2 ka mul sak mesein sise onen.   
\c 92  
\s1 Souen ten avong votut onen Ahi  
\q1
\v 1 Tahos imok keke mevasan masmasien vahat minuk, Iahova.  
\q2 Mevati lat isom ral min souen keil, keik koa koro en out nesa.   
\q1
\v 2 En visokon vasi, meselus usil envatien onom,  
\q2 ka vongien vasi, meviteni mun keke komum vasi tounah koa kovat kati.   
\q1
\v 3 Memusau minuk navong mepilei en kitar  
\q2 ka memuas ave venuk.   
\q1
\v 4 Inau nasi nau houlu ven sakien keil onom,  
\q2 veni umen koa komumoni mul sakinau namusau ral min sien.   
\b  
\q1
\v 5 Iahova, umen keil onom avi hetetamen imok,  
\q2 rendemien keil onom mul nesa mok.   
\q1
\v 6 Meatin koa vi unu sakras vailea,  
\q2 ka meatin koa vatin tovuol reingeingen tounah keil ekek varei.   
\q1
\v 7 Avaseini meatin tisa keil avi houlu suval oumunai tatisa keil  
\q2 ka rolesi suval koakeil amum romaltei aro tahosis,  
\q2 hekatau, Ahi helei rahit usite one ka hou lin keil vasi.   
\q1
\v 8 Ka keik, Iahova, isom vi hetetamen imok lisenges.   
\b  
\q1
\v 9 Iahova, mekilea keke koakeil uvae katuk imat.  
\q2 Vativieh keil onom, keil vasi itetasil ka ivuol.   
\q1
\v 10 Iahova, avek keih veni kosan keihoen minau,  
\q2 ka korokol kat inau ral min sien.   
\q1
\v 11 Nalong isien onen vativieh keil onak  
\q2 ka nalei kilea keke keihoen one tovuol emun.   
\b  
\q1
\v 12 Meatin keil koa moulien one mal en metom imoul hesuval vati matou tai,  
\q2 imoul hetaveah hesuval vati avek tai.   
\q1
\v 13 Meatin keil ekek asuval vatiai keil koa aluhi amul vesesal en eim onen Iahova,  
\q2 koa amoul en teahu ten Eim Votut onen Ahi orer.   
\q1
\v 14 Avaseini avi ulmatu tuai, amul veah ason heite en moulien one.  
\q2 Anatin, ales tahosien ka ave keih veah.   
\q1
\v 15 Koanik mul rie lati keke sakien onen Iahova mal revi.  
\q2 Namul naro suai eni, ka tounah tovuol vakalkali eni.   
\c 93  
\s1 Iahova vi asuv houlu orer  
\q1
\v 1 Iahova, keik vi asuv houlu orer.  
\q2 Komusin en keihoen ka hetetamenien.  
\q1 Keik komum revi out netan,  
\q2 ka tounah tovuol kilea vakaikai eni.   
\q1
\v 2 Iahova, tounah vasi keil amul en hem.  
\q2 Ka en avong telamu koa out netan tovuol veah, keik komul tuai.   
\b  
\q1
\v 3 Iahova, navong atas mea ka mavul kat veien, verien teni marite.  
\q2 Navong atas mul mea en mari tahe keil koa amavul kat tounah,  
\q2 suval koa amul avitehiten usil keihoen onom ral min mari ren.   
\q1
\v 4 Iahova, isom hetetamen imok en out nesa.  
\q2 Kokeih imok mulin keihoen ten atas,  
\q2 ka komarite imok mulin marmari tahe keil koa amavul en out ut.   
\q1
\v 5 Mengkatien onom sakras vavuol,  
\q2 ka Eim Votut koa koro ien vi votut vis vi votut imok lisenges.   
\c 95  
\s1 Rehehati lat isen Ahi ka rehelong kati  
\q1
\v 1 !Almai, rovamasmas Iahova!  
\q2 Rehesau min Ahi hetal min sien veni kei mutut moulien orer ka mul lei kokoe en ir.   
\q1
\v 2 Rehemai vesesal veni hetal min masmasien,  
\q2 ka rehesau mini hetal min souen keil ten sien.   
\q1
\v 3 Rehoumoni hemukonek veni Iahova, keihoen onen mariso,  
\q2 ka kei vi asuv houlu koa vi hetetamen imok mulin ahi sav keil.   
\q1
\v 4 Out vasi en out netan amul en hen.  
\q2 Anatin, kei mul losil kat huinev ten atan vina rokol mari vatihou keil nesa vis nesa mok.   
\q1
\v 5 Atas vi onen, veni kei varei mumoni.  
\q2 Ka atan vasi keil vi osen veni hen keilu mumoni.   
\b  
\q1
\v 6 Almai, rovaha netan ka rehemalingling mini.  
\q2 Anatin, rehetetengeiril en meten Iahova koa mumon ir.   
\q1
\v 7 Suval meatin tai koa mul losil kat revi sipsip keil osen,  
\q2 kei vi Ahi orer ka mul losil kat revi ir koa rovi meatin keil onen.\x + \xo 95:7 \xt Hib 3:7-11,15; 4:7\x*  
\b  
\q1 Kosa, mihelong revi asa koa Ahi viteni min kami vit,   
\q1
\v 8 “Minoumontei vatumi nakeih nasuval avu onami keil amumoni en out Meribah,  
\q2 nasuval koa amumoni en avong enek en out volvol ten out Massah.\f + \fr 95:8 \ft Navong maroro kat me-Isrel keil en out volvol, asel kutut kat Mosis avit hesakin oai hekistal avamuni munak Ahi mul veni. Ka navong Mosis muas mari ahat tai, Ahi sakin oai mue rani. Avise out enek en Meribah koa aneite teni vi ‘selkututien’ veni aselus kutut kat Mosis. Ka aling isen tamun vi Massah koa aneite teni vi ‘sakvisien’ veni asak vis Iahova navong avisi avit, “?Iahova mul ven ir vuo romultei?” (\xt Eks 17:1-7; Nam 20:2-13\ft )\f*   
\q1
\v 9 Avu onami keil asak vis inau,  
\q2 avaseini keke alei kilea tounah houlu tuai koa namumoni ven keil.   
\q1
\v 10 Sua hanumau elu (40), keil atisaso en metok,  
\q2 veni tine mul soutin ranau ka e rovattei mun availea mengkatien keil onak.   
\q1
\v 11 Sakini, navuroh kat keil ka navat kati keke  
\q2 asakras avaha en out koa nisakin keil avaseh revi eni.”\x + \xo 95:11 \xt Nam 14:20-23; Dut 1:34-36; 12:9-10; Hib 4:3-5\x*   
\c 96  
\s1 Iahova vi asuv houlu ten tounah vasi  
\q1
\v 1 !Mihesau en souen hau tai heha min Iahova!\x + \xo 96:1 \xt 1Kron 16:23-33\x*  
\q2 !Meatin vasi keil ten out netan, mihesau mini!   
\q1
\v 2 !Mihehati lat Iahova hetal min souen keil!  
\q2 En avong vasi, mihehitehiten more longlongien mihehit kei mul mutut moulien orer.   
\q1
\v 3 Mihehitehiten usil hetetamenien onen heha en out vasi en out netan.  
\q2 Mihehit usil keihoen onen min meatin vasi keil.   
\b  
\q1
\v 4 Iahova tahos imok, ka mal keke rehehati lat isen.  
\q2 Rehehouhou min kei sasen, ka rehermusiltei ahi sav keil.   
\q1
\v 5 Ahi keil onen meatin savsav keil avi heisav enges,  
\q2 ka Iahova koa mumon out nesa, kei vi Ahi anatin.   
\q1
\v 6 Kei vi asuv houlu orer ka muohien ten hetetamenien onen mul ritin karahiti.  
\q2 Eim Votut onen vilelau en keihoen ka tahosien onen.   
\q1
\v 7 Rehemasmas Iahova, meatin vasi keil ten out netan,  
\q2 ven keihoen ka hetetamenien onen.\x + \xo 96:7 \xt Sam 29:1-2\x*   
\q1
\v 8 Rehehati lat isen Ahi hehina nesa,  
\q2 ka rehelah sanien votut keil orer heha en Eim Votut onen.   
\q1
\v 9 Rehetetengeiril en meten Ahi koa vi votut imok.  
\q2 Kami vasi en out netan, mihemaleilei en metauen navong mimai vesesal veni.   
\b  
\q1
\v 10 !Mihehiteni min meatin vasi keil en kantri vasi keil keke Iahova vi asuv houlu!  
\q2 Ahi mul vuli kat revi out netan, ka tounah tovuol vating lati.  
\q2 Ahi helei rahit usite onen meatin vasi keil en sakien koa mal.   
\q1
\v 11 Out netan ka teilang nesa, lusi keilu.  
\q2 Atas ka tounah vasi keil koa amul ien, amakul en masmasien min Ahi.   
\q1
\v 12 Tounah keil vasi koa amoul en out netan, asi keil.  
\q2 Vatiai keil ten eivorohus, amusau ral min sien.   
\q1
\v 13 Tounah vasi keil enek asi keil  
\q2 veni Iahova mul mai keke vahi asuv houlu ten out netan.  
\q1 Ahi mul losil kat revi meatin vasi keil ten out netan,  
\q2 ka helei rahit usite one en sakien ten maluen ka anatinien.   
\c 97  
\s1 More losilkatien onen Iahova  
\q1
\v 1 !Iahova vi asuv houlu!  
\q2 Kami vasi en out netan, mihemakul en sien.  
\q2 Kami koa miro en aelan keil, mihesi kami.   
\q1
\v 2 Kei mul losil kat meatin keil musil sakien koa mal ka mul visein keil musil maluen onen.  
\q2 Mahmah keil koa matetel ka vopoli mul kav koe Ahi suval eisin omon asuv houlu tai.   
\q1
\v 3 Navong mul mai, ahang mulamuni,  
\q2 ka mul kan lin vativieh keil onen en usite vasi keil.   
\q1
\v 4 Kei mumon ahil vil en out vasi en out netan,  
\q2 ka koakeil vasi alesi amaleilei en metauen.   
\q1
\v 5 Navong Iahova koa vi asuv ten tounah vasi keil en out netan mul mai,  
\q2 vatihou keil aretengeiril umai ka avi aet.   
\b  
\q1
\v 6 Tounah keil vasi koa amul en teilang avitehiteni keke Ahi mal vasi  
\q2 ka meatin vasi keil alei kilea hetetamenien onen.   
\q1
\v 7 Koakeil avasi keil ven nana keil one imemou,  
\q2 veni uva netan min nana keil one koa avi heisav enges,  
\q1 Ka tounah vasi koa uva netan min keil vasuval avahi ahi one,  
\q2 keil vasi enek alei kilea hetetamenien onen Iahova ka iha netan mini.   
\b  
\q1
\v 8 O Ahi Asuv, veni komul kolei rahit usite onen meatin keil en sakien koa mal,  
\q2 meatin keil koa aro en Hou \w Saeon\w* alonge tahos,  
\q2 ka koakeil aro en meteimal keil ten out Sudah, asi keil.   
\q1
\v 9 Keik, Iahova, kovi houlu mok mulin tounah vasi keil ten out netan,  
\q2 ka kovi nesa vis nesa mok mulin ahi savsav keil vasi.   
\b  
\q1
\v 10 Iahova, envatien onen mul en koakeil e rovattei tisaen.  
\q2 Kei mul lei kokoe en moulien onen koakeil amusil kati,  
\q2 ka mul mutut moulien one ran hen meatin tisa keil.   
\q1
\v 11 Meneai onen mul ritin en koakeil amal en meten,  
\q2 ka kei mul san sien min koakeil amuto.   
\q1
\v 12 Kami koa mimal, mihesi kami ven Iahova koa vi votut,  
\q2 ka mihesan masmasien mini.   
\c 98  
\s1 Iahova vi asuv houlu ten out netan  
\q1
\v 1 !Mihesau en souen hau tai min Iahova!  
\q2 !Kei mumon tounah keil koa atahos imok!  
\q1 Kei sasen vitan en vativieh keil onen  
\q2 ral min keihoen ka hivotutien onen.   
\q1
\v 2 Iahova rie lati keke keihoen onen mulin teisav keil  
\q2 ka vothot eni keke mul vae en usite onen meatin keil onen keke voutut keil en meten meatin vasi keil ten out netan.   
\q1
\v 3 Kei en rovobongentei vatie lat envatien onen min me-Isrel keil,  
\q2 ka lisenges kei mum vasin hatkatien keil onen.  
\q1 Meatin keil ten out vasi netan alesi  
\q2 mukave keihoen onen Ahi orer mulin teisav keil.   
\b  
\q1
\v 4 Meatin vasi keil ten out netan, mihesau hetal min sien heha min Iahova.  
\q2 Mihemakul en sien ka mihemasmas Ahi hetal min souen keil.   
\q1
\v 5 Mihouas kitar ka mihesau min Iahova,  
\q2 mihemasmasi hetal min souen keil.   
\q1
\v 6 Mihouh amaru ka mihemakul en sien,  
\q2 mihoumoni heha min Iahova koa vi asuv houlu orer.   
\b  
\q1
\v 7 Atas ka tounah vasi keil koa amul ien, amakul en masmasien min Ahi.  
\q2 Out netan ka tounah vasi keil koa amoul ien, amusau mini.   
\q1
\v 8 Oai mul mue en sien min Ahi  
\q2 ka eang en vatihou keil mul muhuh en souen keil.   
\q1
\v 9 Tounah vasi keil enek asi keil  
\q2 veni Iahova mul mai keke vahi asuv houlu ten out netan.  
\q1 Ahi helosil kat revi tounah vasi keil ten out netan,  
\q2 ka helei rahit usite one en sakien ten maluen ka anatinien.   
\c 100  
\s1 Souen ten masmasien  
\q1
\v 1 !Meatin keil ten out netan,  
\q2 mihemakul en sien min Iahova!   
\q1
\v 2 Tinomi hehilelau en sien navong miheha netan mini.  
\q2 Mihemai vesesal veni hetal min souen keil.   
\q1
\v 3 Miheilea keke Iahova vi Ahi.  
\q2 Kei varei mumon ir, ka rovi onen.  
\q1 Ir romul en hen, ka kei mul losil kat revi ir  
\q2 suval meatin tai mul losil kat revi sipsip keil osen.   
\b  
\q1
\v 4 Miheha en Eim Votut onen hetal min masmasien,  
\q2 mihehati lat isen en teahu teni.   
\q1
\v 5 Iahova tahos vis tahos imok.  
\q2 Envatien onen sakras vavus, ka kei mul mum vasin hatkatien keil onen lisenges.   
\c 111  
\s1 Rehehati lat isen Iahova ven tounah keil koa kei mul mumoni  
\q1
\v 1 !Rehehati lat isen Iahova!  
\b  
\q1 Hetal min moulien vasi onak, nil nisan masmasien heha min Iahova.  
\q2 Ka numoni en meten meatin keil onen, en out koakeil amal en meten alah ruai.   
\q1
\v 2 Tounah vasi koa Iahova mumoni tahos imok.  
\q2 Ka koakeil vasi asi keil ven tounah keil enek e vati mok avandem usil aneite teni.   
\q1
\v 3 Umen vasi keil onen Ahi mul rie lati keke kei vi hetetamen imok ka mal keke avouhou mini.  
\q2 Sakien keil onen mal revi mok kosa ka lisenges.   
\b  
\q1
\v 4 Iahova mul sakin meatin keil en out vasi netan avou lat isen veni along usil mormore sakien keil onen.  
\q2 Along kilea keke tahosien ka enmahisien onen marite.   
\q1
\v 5 Kei mul san anien min koakeil avouhou mini.  
\q2 En rovobongentei \w hatkatien takeih\w* onen koa mumoni ral min keil.   
\q1
\v 6 Ahi rie lat keihoen ten umen onen min meatin keil onen.  
\q2 Ka alei kilea eni navong san atan osen meatin keil ten kantri sav keil mai vi ose.   
\b  
\q1
\v 7 Ka tounah vasi koa Iahova mumoni mal ka musil rendemien koa tahos.  
\q2 Mengkatien vasi keil onen, rokilea rovaling desien orer eni.   
\q1
\v 8 Mengkatien keil onen hel lisenges, asakras avavuol.  
\q2 Kei sani min meatin keil keke avousili ral min anatinien ka maluen.   
\q1
\v 9 Ahi mumon meatin keil onen amaluv.  
\q2 Kei mumon hatkatien takeih tai ral min keil koa sakras vamahoi en avong etai,  
\q2 veni Isen vi votut ka hetetamen imok.   
\q1
\v 10 Houhouen min Ahi vi vatte ten meteisauen.\x + \xo 111:10 \xt Siob 28:28; Pro 1:7; 9:10\x*  
\q2 Koakeil amul along kat ren, rendemien one mekaikai revi.  
\q1 Rehesan masmasien heha mini lisenges.   
\c 112  
\s1 Sien mul en koakeil sakien keil one tahos  
\q1
\v 1 !Rehehati lat isen Iahova!  
\b  
\q1 Koakeil avouhou min Iahova ito en sien.  
\q2 Koakeil e vati avousil revi mengkatien keil onen, keil isi keil en avong vasi.   
\q1
\v 2 Titiali keil one imai ihi avat keil ten kantri one.  
\q2 Tokolkatien onen Ahi hel en koakeil akistal ran vatiamal onen koakeil amal en meten.   
\q1
\v 3 Vatiamal onen ihotin tahosien ka tokolkatien,  
\q2 umen one koa amumoni musil sakien ten maluen hel lisenges.   
\b  
\q1
\v 4 Moulien one mul kataun more meatin keil  
\q2 suval laet koa ritin en out koa malikelik.  
\q1 Keil atahos min mesav keil ka arie lat enmahisien min keil,  
\q2 umen keil one mal imok.   
\q1
\v 5 Hetahos min koakeil amumon umen one en sise tai koa mal,  
\q2 ka asa maen tounah one min meatin sav keil ral min rendemien koa tahos.   
\q1
\v 6 Vati meatin keil koa amal imok mukok, avong keil takeih sakras vapurun keil,  
\q2 ka meatin sav keil e rovobongentei sakien tetahos keil one.   
\q1
\v 7 Keil armetautei navong akur longlongien tai koa tisa,  
\q2 veni demkatien one keih ka akilea keke Ahi hehi eikokoe en keil.   
\q1
\v 8 Keil armundemkotei ka armetaun etai tounah,  
\q2 veni akilea keke Ahi hehitan en vativieh keil one.   
\q1
\v 9 En avong vasi keil asan kataunien min koakeil atamurei en tounah,  
\q2 sakien keil one mal lisenges.\x + \xo 112:9 \xt 2Kor 9:9\x*  
\q1 Keihoen mul en he  
\q2 ka meatin keil avouhou min keil.   
\q1
\v 10 Navong meatin tisa keil ales keil,  
\q2 tine kat keil ka mete vilhili kat keil.  
\q1 Ka lingkatien keil onen koakeil atisa hemai hehi heisav enges ka ivupuol.   
\c 113  
\s1 Mihehati lat isen Iahova ven tahosien onen  
\q1
\v 1 !Mihehati lat isen Iahova!  
\q2 Anatin, kami koa mivi meatin toumien keil onen, mihou lat isen.   
\q1
\v 2 Isen Iahova mariso mok,  
\q2 kosa ka lisenges.   
\q1
\v 3 Kami vasi koa miro en out koa meteiai ka ien  
\q2 va rokol kami koa miro en out koa meteiai munu ien,  
\q2 mihemasmas Iahova.   
\q1
\v 4 Avou lat isen Iahova en out vasi en out netan,  
\q2 ka hetetamenien onen vina nesa mok mulin teilang.   
\q1
\v 5 Tounah tovuol vasuval Iahova, Ahi orer,  
\q2 koa mul rondan en out nesa ka losil kat tounah vasi.   
\q1
\v 6 Kei malingling ka lele mita netan  
\q2 keke vales tounah keil koa amul en teilang ka en out netan.   
\q1
\v 7 Kei mul rali lat koakeil tounah one tovuol keke avamemea ran out tatisa koa amul ien.  
\q2 Ka mul kulat keil ran mahien keil one.   
\q1
\v 8 Iahova mul san houhouen min keil suval avi hetetamen.  
\q2 Mul sakin keil arondan revi ral min mari meatin keil.   
\q1
\v 9 Kei mul sakin koakeil avi lumalum asi keil en teim se keil,  
\q2 veni mul maen keil avahi mama onen titiali keil.  
\b  
\q1 !Sakini, mihehati lat isen Iahova!   
\c 115  
\s1 Iahova enges vi Ahi anatin  
\q1
\v 1 Iahova, komai mervinvintei keke mevakur houhouen.  
\q2 Keik enges kovinvin kovakur houhouen,  
\q2 veni, lisenges, komul korie envatien onom min komai ka komumon tounah vasi koa kovat kati.   
\b  
\q1
\v 2 Romaltei keke koakeil areingeingen Ahi avoumon tohtohien en komai avahit,  
\q2 “?Ueee … Ahi onami mul kave?”   
\q1
\v 3 Veni Ahi orer mul en out nesa  
\q2 ka kei mul mumon tounah vasi koa kei en vati voumoni.   
\q1
\v 4 Ka ahi onen mesav keil avi nana keil enges koa amumon keil en silva ka gol,  
\q2 koa amumon keil ral min he enges.\x + \xo 115:4 \xt Sam 135:15-18; Rev 9:20\x*   
\q1
\v 5 Amusah onge mul en ahi keil one, ka asakras avaselus,  
\q2 mete mul, ka asakras avales etai tounah.   
\q1
\v 6 Ralinge mul, ka asakras avalonglong,  
\q2 vulingase mul, ka asakras avamusmus.   
\q1
\v 7 He mul, ka asakras avatokol etai tounah,  
\q2 ale mul, ka asakras avoual.  
\q1 Ahi keil one aro raeng enges  
\q2 veni moulien tovuol en keil.   
\q1
\v 8 Ahi keil one arkurtei keihoen, ka vatte hetas en koakeil aling desien one mul en keil.  
\q2 Ka koakeil akur anatin en keil imai ihi heisav enges.   
\b  
\q1
\v 9 !Ka kami, me-Isrel keil, miheling desien onami en Iahova!  
\q2 Veni kei mul kataun kami ka mul lei kokoe en kami.   
\q1
\v 10 Pris keil onen Ahi, tahos keke miheling demkatien onami en Ahi,  
\q2 veni kei mul kataun kami ka mul lei kokoe en kami.   
\q1
\v 11 Kami vasi koa mivouhou min Iahova, tahos keke kami miheling demkatien onami eni,  
\q2 veni kei mul kataun kami ka mul lei kokoe en kami.   
\q1
\v 12 Iahova mul mundem kat ir ka hetokol kat ir.  
\q2 Anatin, kei hetokol kat me-Isrel keil ka pris keil onen.   
\q1
\v 13 Hetokol kat koakeil vasi avouhou mini,\x + \xo 115:13 \xt Rev 11:18; 19:5\x*  
\q2 hetetamen keil heha hetokol meatin kuren keil emun.   
\b  
\q1
\v 14 Navisi keke Iahova hetokol kat kami hetal min titiali keil onami,  
\q2 heha hetokol titiali keil one.   
\q1
\v 15 Anatin, tokolkatien onen Iahova, koa mumon out nesa ka out netan,  
\q2 hel en moulien onami.   
\b  
\q1
\v 16 Out nesa vi onen Iahova,  
\q2 ka out netan, kei lingi mul en hen meatin keil.   
\q1
\v 17 Koakeil amul en out ten matien aro raeng enges,  
\q2 ka asakras avahou lat isen.   
\q1
\v 18 Ka ir koa romoul veah,  
\q2 rehesau masmasi, kosa ka lisenges.  
\b  
\q1 !Sakini, rehehati lat isen Iahova!   
\c 117  
\s1 Rehemasmas Iahova  
\q1
\v 1 Rehehati lat isen Iahova, meatin vasi keil ten out netan.\x + \xo 117:1 \xt Rom 15:11\x*  
\q2 Mihehou lat isen, kami vasi koa mimul en kantri sav keil.   
\q1
\v 2 Envatien onen min ir mariso,  
\q2 ka lisenges, kei mum vasin hatkatien keil onen.  
\b  
\q1 !Sakini, rehehati lat isen Iahova!   
\c 119  
\s1 Selusien votut onen Ahi tahos imok  
\q1
\v 1 Tokolkatien hel en koakeil ualien one mutolas,  
\q2 koa moulien one musil kat mengkatien keil onen Iahova.   
\q1
\v 2 Tokolkatien hel en koakeil amum musil rendemien koa Ahi viteni  
\q2 ka along kati ral min moulien vasi one.   
\q1
\v 3 Armumontei tounah vatisa,  
\q2 ka amusil kat sise koa kei rie keil avousili.   
\q1
\v 4 Iahova, keik kosan hihiseien keil  
\q2 koa kovit malong kati.   
\q1
\v 5 Ek vati mok keke nirkur tuntei sise onom,  
\q2 ka nilong kat rendemien keil koa koling kati mousili.   
\q1
\v 6 Nilekat revi keke nusil kat mengkatien keil onom.  
\q2 Hemukonek, nirmemoutei en meten mesav keil.   
\q1
\v 7 Navong nalei kilea mukave kolei rahit en usite vasi keil musil rendemien koa mal,  
\q2 namasmasuk ral min rendemien koa mutolas.   
\q1
\v 8 Rendemien vasi keil koa koling kati, inau nusili.  
\q2 Sakini, konalokoveintei nau li.   
\s2 Selkatien heha ven ehon ka atouli hau keil keke usil kat Iahova  
\q1
\v 9 ?Ehon hau ka atouli hau keil ito en moulien tai koa hetolas hemukave?  
\q2 Ilei kokoe eni hetal min selusien keil onom.   
\q1
\v 10 Inau nusiluk en moulien vasi keil onak,  
\q2 konamaentei nau nanaha ran mengkatien keil onom.   
\q1
\v 11 Inau naling suain selusien onom neim en tinok,  
\q2 keke nirmumontei tisaen naha katuk.   
\q1
\v 12 O Iahova, namasmasuk.  
\q2 Kihiseinau en rendemien keil onom koa koling kati.   
\q1
\v 13 Inau namul navit lein  
\q2 tounah koa kolei usili musil rendemien koa mal.   
\q1
\v 14 Nasi nau keke mousil asa koa koviteni  
\q2 suval koa namul nakur tounah keil koa mani teni mariso.   
\q1
\v 15 Hihiseien keil onom mules en rendemien onak keke nindem kilea aneite ten keil,  
\q2 ka nalei kilea en sise koa korie keke komai mevousili.   
\q1
\v 16 Nasi nau ven rendemien keil koa kosani,  
\q2 ka nirmundem maentei selusien keil onom.   
\s2 Tokolkatien onen Iahova hel en koakeil vasi along kat ren  
\q1
\v 17 Inau navi meatin toumien onom.  
\q2 Kumoni hetahos minau keke nakilea mamoul ka malong kat selusien keil onom.   
\q1
\v 18 Sehen metok keke malei revi  
\q2 en more tounah keil koa amul en mengkatien keil onom.   
\q1
\v 19 Inau naro en out netan suval heou tai.  
\q2 Sakini, konaling suaintei mengkatien keil onom ranau.   
\q1
\v 20 En avong vasi, ek vati li mok  
\q2 keke nilea revi en tounah vasi koa mal en rendemien onom.   
\q1
\v 21 Keik kovul kat koakeil akur rendemien ten hetetamenien mul en keil.  
\q2 Sesendaen tai mul en koakeil along ras mengkatien keil onom.   
\q1
\v 22 Koakeil enek amundem maen nau ka amumon tohtohien minau.  
\q2 Kiting koe nau ran keil veni inau namusil kat tounah koa koviteni.   
\q1
\v 23 Avaseini keke hetetamen keil alah ruai keke avalekat sise koa akilea avapurun inau vaka ien,  
\q2 inau, meatin toumien onom, nil nindem usil rendemien keil koa koling kati mousili.   
\q1
\v 24 Inau nasi nau houlu mok ven tounah koa koviteni,  
\q2 veni keil amul arie sise minau keke mousili.   
\s2 Hisien onen meatin koa en vati mok vousil kat selusien keil onen Iahova  
\q1
\v 25 Nalonge tisa houlu ka namundem sesai.  
\q2 Kitali lat nau li hesuval koa kovat kati en selusien onom.   
\q1
\v 26 Navit lein tounah vasi koa namumoni minuk, ka kovit kes selusien onak.  
\q2 Kihiseinau li en rendemien keil onom koa koling kati mousili.   
\q1
\v 27 Kumonau nilea en hihiseien keil onom,  
\q2 ka nindem usil more tounah keil koa komumoni keke nilea aneite teni.   
\q1
\v 28 Nalonge tisa houlu ka tinok mul mis.  
\q2 Kisan ris keihoen minau li hesuval koa kovat kati en selusien onom.   
\q1
\v 29 Kiting koe nau nanahatei en sise koa romaltei.  
\q2 Ka veni kotahos imok, kihiseinau en mengkatien keil onom.   
\q1
\v 30 Inau naling rendemien onak keke nusil sise ten longkatien en moulien onak.  
\q2 Namundem usil hemukave nusil rendemien keil onom koa koling kati mousili.   
\q1
\v 31 O Iahova, inau namusil kat tounah koa koviteni.  
\q2 Sakini, konasakintei nau nanamemoutei en meten mesav keil.   
\q1
\v 32 Navong nalong mengkatien keil onom, nakalah namum musili,  
\q2 veni nakilea keke kisan tei ris ileilien minau heka ien.   
\s2 Hisien onen meatin koa en vati mok vailea revi selusien keil onen Iahova  
\q1
\v 33 O Iahova, kihiseinau en aneite ten rendemien keil onom koa koling kati mousili,  
\q2 ka nilong kati lisenges.   
\q1
\v 34 San ileilien minau ka nusil kat mengkatien keil onom.  
\q2 Anatin, nilong kati hetal min moulien vasi onak.   
\q1
\v 35 Kilamunau en sise ten mengkatien keil onom,  
\q2 veni en sise enek nihotin sien.   
\q1
\v 36 Kihiles moulien onak keke nusil kat tounah koa koviteni,  
\q2 keke nanousiltei sakien ten metenan.   
\q1
\v 37 Kihiles metok ran tounah keil avi heisav enges,  
\q2 ka kisan moulien minau heka en mengkatien keil onom.   
\q1
\v 38 Kisakin selusien onom hemai hehi anatin en moulien onen meatin toumien onom,  
\q2 veni hesakini hehouhou enuk.   
\q1
\v 39 Inau namul nametaun selkututien keil koa vativieh keil onak amumoni vaha kat inau.  
\q2 Sakini, kutut inau li veni tounah koa kolei usili musil rendemien koa mal.   
\q1
\v 40 Ek vati li mok hihiseien keil onom.  
\q2 Veni keik komal imok, kisakin moulien onak hehi heite hau.   
\s2 Selusien keil onen Iahova vi kataunien min koakeil amusili  
\q1
\v 105 Selusien keil onom suval laet koa musil luvat out koa namual ien,  
\q2 ka san meneai minau keke malei kilea revi sise onak.   
\b  
\q1
\v 130 Navong kovit kilea hihiseien keil onom,  
\q2 namundem kilea asa koa mal.  
\q1 Avaseini meatin tai rosukul revitei,  
\q2 selusien onom mul san meteisauen mini.   
\b  
\q1
\v 160 Anatinien vi vatte ten selusien vasi keil onom.  
\q2 Ka tounah vasi koa koviteni musil rendemien koa mal mul lisenges.   
\b  
\q1
\v 165 Tomat mul en moulien onen koakeil vasi envatien one mul en mengkatien keil onom,  
\q2 tounah tovuol vasakin keil avamot.   
\b  
\q1
\v 176 Inau navi meatin toumien onom ka nakur tun sise koa mal suval \w sipsip\w* tai koa vuol.  
\q2 Sakini, kimai li kihotin inau, veni ek rovobongentei mengkatien keil onom.   
\c 121  
\s1 Iahova vi out tatosuaien orer  
\q1
\v 1 Nalele vina nesa en vatihou keil ka navit,  
\q2 “?Kataunien hemai minau heka kave?”   
\q1
\v 2 Nakilea keke kataunien hemai minau heka ven Iahova,  
\q2 kei koa mumon out nesa ka out netan.   
\q1
\v 3 Kei hermaen etai tounah vakula kami,  
\q2 mul ring koe kami ka romatiltei.   
\q1
\v 4 Kei koa mul lei kokoe en me-Isrel keil,  
\q2 rolongtei metalong.   
\q1
\v 5 Iahova vi eikokoe onami.  
\q2 Kei heto en usite matu onami keke tounah hetovuol vapurun kami.   
\q1
\v 6 En meneai, meteiai sakras van vini kami,  
\q2 ka en vongien, avati sakras vapurun kami.   
\b  
\q1
\v 7 Iahova heting koe moulien onami keke tounah keil tatisa napuruntei kami.  
\q2 Kei heav koe kami hetal hen keke tounah sakras vamai vakula kami.   
\q1
\v 8 En ualien keil onami, kei helei kat revi kami en usite vasi keil,  
\q2 kosa ka lisenges.   
\c 135  
\s1 Souen ten masmasien  
\q1
\v 1 !Mihehati lat isen Iahova!  
\q2 Kami koa mivi meatin toumien keil onen, mihemasmasi.   
\q1
\v 2 Kami koa miva netan mini en Eim Votut onen,  
\q2 vuo mimul en teahu teni, mihehou lat isen.   
\q1
\v 3 Mihehati lat isen Iahova veni kei tahos.  
\q2 Mihesau mini veni enmahisien onen mariso.   
\q1
\v 4 Rokilea keke vi anatin veni Iahova rie lat avu orer \w Siekob\w* vahi onen,  
\q2 ka rie lat ir, me-Isrel keil, rovahi onen kati.   
\q1
\v 5 Nakilea keke Iahova vi hetetamen imok,  
\q2 Ahi orer marite mok mulin ahi sav keil.   
\q1
\v 6 En out nesa ka en out netan,  
\q2 Iahova mul sakin tounah vasi mai kistal musil envatien onen.  
\q1 En atas ka en huinev teni,  
\q2 tounah keil koa mul kur out musil rendemien onen.   
\q1
\v 7 Kei sakin mahmah keil amuloh umai ran out keil koa soutin en out netan.  
\q2 Kei mumon ahil vil en avong ten an tisa, ka lah lat eang ran out teni ka sakini muhuh.   
\b  
\q1
\v 8 En kantri ten out \w Isip\w*, vi Ahi koa mu vini moeite vasi keil.  
\q2 Anatin, mu vini moeite onen meatin keil ka onen buluk ka sipsip keil emun.   
\q1
\v 9 En out enek, kei mumon merikel keil ka marmari tounah keil.  
\q2 Kei san mahien min asuv houlu ten out Isip, ka min avat keil onen.   
\q1
\v 10 Vi Ahi koa mu vini meatin keil ten kantri houlu,  
\q2 ka mu vini asuv houlu keil koa akur keihoen.   
\q1
\v 11 Kei mu vini Sihon koa vi asuv houlu ten out Amor,  
\q2 ka Og emun koa vi asuv houlu ten out Basan.  
\q1 Ahi vitan en asuv houlu vasi keil  
\q2 koa aro en atan ten out Kenan.   
\q1
\v 12 Atan koa kulati ran he,  
\q2 kei sani suk min meatin keil onen ten out Isrel keke vahi one.   
\b  
\q1
\v 13 Meatin keil indem kat isen Iahova lisenges.  
\q2 Tounah vasi keil koa kei mumoni, meatin keil ihitehiten usili en avong vasi keil koa hemai veah.   
\q1
\v 14 Ihitehiten usil Iahova veni vi eikokoe onen meatin keil onen,  
\q2 ka mul rei lat enmahisien onen min meatin toumien keil onen.   
\b  
\q1
\v 15 Ahi keil onen meatin keil ten kantri savsav keil avi nana keil enges koa amumon keil en silva ka gol,  
\q2 amumon keil ral min he enges.\x + \xo 135:15 \xt Sam 115:4-8; Rev 9:20\x*   
\q1
\v 16 Amusah onge mul en ahi keil one, ka asakras avaselus,  
\q2 mete mul, ka asakras avales etai tounah.   
\q1
\v 17 Ralinge mul, ka asakras avalonglong;  
\q2 onge mul, ka asakras avaseh.   
\q1
\v 18 Ahi keil one avi heisav enges, ka vatte hetas en koakeil aling desien one mul en keil.  
\q2 Ka koakeil akur anatin en keil emun imai ihi heisav enges.   
\b  
\q1
\v 19 Mihehati lat isen Iahova, me-Isrel keil,  
\q2 pris keil onen Ahi, mihehou lat isen.   
\q1
\v 20 Mihehati lat isen Iahova, kami koa mimum en Eim Votut onen,  
\q2 kami vasi koa mivouhou mini, mihou lat isen.   
\q1
\v 21 Kami koa miro en Hou \w Saeon\w*, mihesan masmasien min Iahova,  
\q2 min kei koa ro en out \w Serusalem\w*.  
\b  
\q1 !Sakini, mihehati lat isen Iahova!   
\c 136  
\s1 Rehemasmas Iahova ven tounah keil koa kei mumoni  
\q1
\v 1 Mihemasmas Iahova veni kei tahos.  
\qr \it Envatien onen hel lisenges.\it*   
\q1
\v 2 Mihemasmas Ahi koa mulin ahi sav keil.  
\qr \it Envatien onen hel lisenges.\it*   
\q1
\v 3 Mihemasmas Ahi Asuv koa mulin asuv sav keil.  
\qr \it Envatien onen hel lisenges. \it*   
\b  
\q1
\v 4 Kei sasen enges mumon mari tounah keil.  
\qr \it Envatien onen hel lisenges.\it*   
\q1
\v 5 Ka en ileilien onen, kei mumon out nesa.\x + \xo 136:5 \xt Sen 1:1\x*  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 6 Kei varei sakin out netan mea ran atas.\x + \xo 136:6 \xt Sen 1:2\x*  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 7 Kei mumon tounah vasi keil koa ritin en teilang.\x + \xo 136:7 \xt Sen 1:16\x*  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 8 Ling meteiai keke valosil kat meneai.  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 9 Ka ling avati ka hitu keil keke avalosil kat vongien.  
\qr \it Envatien onen hel lisenges. \it*   
\b  
\q1
\v 10 Kei varei mu vini moeite keil ten out \w Isip\w*.\x + \xo 136:10 \xt Eks 12:29\x*  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 11 Evus, lah lat me-Isrel keil ran out Isip.\x + \xo 136:11 \xt Eks 12:51\x*  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 12 Kei mumoni mukonek ral min keihoen koa mul en hen.  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 13 Kei sasen mumon \w Atas Tahilhili\w* maseh va en usite elu.\x + \xo 136:13 \xt Eks 14:21-29\x*  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 14 Kei sakin meatin keil onen amual kotehei.  
\qr \it Envatien onen hel lisenges.\it*   
\q1
\v 15 Ka sakin atas enek rein vini asuv houlu ten out Isip ral min meatin tavaeen vasi keil onen.  
\qr \it Envatien onen hel lisenges. \it*   
\b  
\q1
\v 16 Kei mulamun meatin keil onen aka vas out volvol.  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 17 Asuv houlu keil koa akur keihoen, kei vitan en keil vasi.  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 18 Mu vinvini asuv houlu keil koa avi hetetamen.  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 19 Anatin, mu vini asuv houlu Sihon ten out Amor.\x + \xo 136:19 \xt Nam 21:21-30\x*  
\qr \it Envatien onen hel lisenges.\it*   
\q1
\v 20 Ka mumoni vatte tas min asuv houlu Og emun ten out Basan.\x + \xo 136:20 \xt Nam 21:31-35\x*  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 21 Evus, san atan ose min meatin keil onen vahi ose esuk.  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 22 Kei sani min me-Isrel keil koa avi meatin toumien keil onen.  
\qr \it Envatien onen hel lisenges. \it*   
\b  
\q1
\v 23 Kei mundem kat ir navong romul en hen mesav keil.  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 24 Mumon ir romaluv ran hen vativieh keil orer.  
\qr \it Envatien onen hel lisenges. \it*   
\q1
\v 25 Ka mul vengan tounah vasi keil koa amoul en out netan.  
\qr \it Envatien onen hel lisenges. \it*   
\b  
\q1
\v 26 Mihemasmas Ahi ten out nesa.  
\qr \it Envatien onen hel lisenges. \it*   
\c 138  
\s1 Iahova marite mok mulin tounah sav keil  
\d Asuv houlu Deved mutisi  
\q1
\v 1 O Iahova, navati latuk ral min moulien vasi onak.  
\q2 Ka en meten ahi sav keil, nisan masmasien hehat minuk.   
\q1
\v 2 Inau nitetengeiril ka nilele hemal en Eim Votut onom.  
\q2 Nihou lat Isom veni korie lat envatien onom min meatin keil onom ka komum vasin hatkatien keil onom.  
\q1 Anatin, nihati latuk veni korie lati  
\q2 keke Isom ka selusien onom luvi hetetamen imok lumulin tounah sav vasi keil.   
\q1
\v 3 Mal en avong koa naviso vat minuk,  
\q2 keik kolong hisoen onak ka kosan kataunien minau.  
\q1 Kokulat metauen ranau  
\q2 ka kosan keihoen minau.   
\b  
\q1
\v 4 O Iahova, asuv houlu vasi keil ten out netan ihati latuk  
\q2 veni along selusien keil onom.   
\q1
\v 5 Keil isau usil more sakien keil onom,  
\q2 veni keihoen onom, Iahova, marite mok.   
\b  
\q1
\v 6 Avaseini keik, Iahova, koro en out nesa,  
\q2 komul komalingling vita ka kolele tahos en koakeil rendemien one mul netan.  
\q1 Ka min koakeil amul avut sase en keil,  
\q2 kokilea vasin sakien keil one ka koro soutin ran keil.   
\q1
\v 7 Avaseini nales tounah keil takeih amul akarahit inau,  
\q2 nakilea keik komul koring koe inau.  
\q1 Avaseini vativieh keil onak atisa kat inau,  
\q2 keik komumoni keih va kat keil ka komutut inau ran he.   
\q1
\v 8 Tounah keil koa koling kati keke vakur out en moulien onak,  
\q2 komum vasi.  
\q1 O Iahova, konalokoveintei tounah keil koa komul komumoni en moulien onak.  
\q2 Kumoni veni envatien onom mul lisenges.   
\c 139  
\s1 Rehehati lat isen Ahi koa kilea revi sise keil orer  
\d Asuv houlu Deved mutisi  
\q1
\v 1 O Iahova, keik kolei kirisil en asa koa mul en tinok ka kokilea revi inau.   
\q1
\v 2 Kokilea inau navong narondan ka navong namea.  
\q2 Kokilea vasin rendemien keil onak, avaseini koro soutin.   
\q1
\v 3 Kokilea inau navong namual ka navong namuseh.  
\q2 Kokilea revi sakien keil onak.   
\q1
\v 4 Navong narselustei veah,  
\q2 keik, Iahova, kokilea selusien vasi keil onak tuai.   
\b  
\q1
\v 5 Keik kovi vieh koa mul en usite vasi keil onak,  
\q2 ka ral min keihoen onom, koring koe moulien onak.   
\q1
\v 6 Navong namundem usil tounah keil koa komumoni en usite onak,  
\q2 ileilien enek mariso ramat, ka nasakras mailea vasi.   
\b  
\q1
\v 7 ?Munak nihit malohosai ran Ninin onom, nakilea maha en out kave?  
\q2 ?Out kave niha ien koa keik kormultei ien? Out tovuol.   
\q1
\v 8 Munak nimat ka niha en out nesa, keik komul ien tuai.  
\q2 Ka munak niha en out ten matien en huinev ten atan, en out enek emun, inau nilesuk.   
\q1
\v 9 Munak nakilea maka vaha vio … matokol out koa meteiai kistal ien,  
\q2 vuo maha en out koa va munu ien,   
\q1
\v 10 en out keilu enek emun, komul mulamu enau ka komul katau enau.  
\q2 Veni komul ien tuai keke kovakataun inau vatal min keihoen koa mul en hem.   
\b  
\q1
\v 11 Munak namundemi navit mankoli kilea vaav koe inau,  
\q2 vuo nakilea mahiles meneai vamai vahi vongien, nasakras mato suai ranuk.   
\q1
\v 12 Nasakras, veni vongien rovitei mankoli enuk.  
\q2 Anatin, en metom, vongien rovopolitei,  
\q2 ka mankoli suval meneai enges.   
\b  
\q1
\v 13 Vi keik, Ahi, koa komum vasin avek.  
\q2 Navong namul semau en vangen mama onak, keik komumon inau.   
\q1
\v 14 Navong namundem usil sise koa keik komum revi inau ka ien,  
\q2 namutimanin ka navati lat isom.  
\q1 Nakilea revi keke tounah vasi keil koa komumoni  
\q2 tahos vis tahos imok.   
\q1
\v 15 Navong naro suai en vangen mama onak,  
\q2 nasakras mato suai ranuk.  
\q1 Veni navong sik keil amul semau asisur en keil,  
\q2 keik kolei kilea enau tuai.   
\q1
\v 16 Navong avek rovus revitei veah,  
\q2 komul koles inau tuai.  
\q1 Avong keil vasi koa koling kati venau,  
\q2 keik komutis lat keil tuai mul en tus onom mulamu en avong koa avasi inau eni.   
\b  
\q1
\v 17 O Iahova, rendemien keil onom amariso vareis ka nasakras mandem kilea keil vasi.  
\q2 !Keil avi houlu vis avi houlu mok!   
\q1
\v 18 Vahit masak visi mahuli keil,  
\q2 hulien teni vahi houlu mok valin veien vasi keil ten out netan.  
\q1 Munak namatil ka namule eris,  
\q2 nalesi keke namul veah ral minuk.   
\b  
\q1
\v 19 O Ahi, ek vati mok keke ku vini koakeil amum kalkali lises,  
\q2 ka kisakin meatin keil koa e vati avouas inau mamat, iha ranau.   
\q1
\v 20 Meatin keil ekek amul aselus kutut usiluk,  
\q2 ka aselus karen isom.   
\q1
\v 21 O Iahova, tinok tisa va kat koakeil tine tisa katuk,  
\q2 koakeil asesein losilkatien onom, atisaso enges en metok.   
\q1
\v 22 Tinok vepeng va kat keil  
\q2 ka avi vativieh ral minau.   
\b  
\q1
\v 23 O Ahi, kilei kirisil en moulien onak,  
\q2 kisak vis inau ka kilea rendemien keil onak.   
\q1
\v 24 Munak kovotini keke namul namusil sise ten tisaen,  
\q2 kilamun inau en more sise onom koa mul lisenges.   
\c 145  
\s1 Hisien ten masmasien va min Ahi  
\d Asuv houlu Deved mutisi  
\q1
\v 1 Keik kovi Ahi onak ka asuv houlu ten moulien onak.  
\q2 Navouhou minuk ka navati lat isom lisenges.   
\q1
\v 2 En avong vasi, namasmasuk,  
\q2 ka navou lat isom lises ka lisenges.   
\b  
\q1
\v 3 Iahova, keik kovi hetetamen imok, ka mal enges keke masan masmasien vahat minuk.  
\q2 Keik komariso mok ka meatin keil asakras availea vasin keihoen onom.   
\q1
\v 4 Asa koa komumoni ven meatin keil, keil ihitehiteni min titae keil.  
\q2 Anatin, keil iselus usil sakien keil onom koa amariso mok.   
\q1
\v 5 Keil iselus usil muohien ten hetetamenien onom ka sakien keil onom koa amormoreite,  
\q2 ka inau nindem usil more umen keil onom.   
\q1
\v 6 Keil iselus usil mari umen keil onom koa arie lat keihoen onom,  
\q2 ka nihit lat sakien keil onom koa avi hetetamen imok.   
\q1
\v 7 Tahosien onom koa marite houmon keil isi keil ka ihit usili min mesav keil,  
\q2 ka isau usil maluen onom hetal min sien.   
\b  
\q1
\v 8 Iahova, envatien onom mariso ka komul korie lat enmahisien min meatin keil.  
\q2 Keik korvurohtei vakalah, ka kovilelau en envatien.   
\q1
\v 9 Iahova, komumoni tahos min meatin vasi keil,  
\q2 ka korie lat enmahisien min koakeil komumon keil.   
\q1
\v 10 O Iahova, tounah vasi keil koa komumoni isan masmasien hehat minuk.  
\q2 Ka koakeil amusiluk, keil ihati lat isom.   
\q1
\v 11 Keil iselus usil losilkatien onom koa mariso mok,  
\q2 ka ihit usil keihoen onom.   
\q1
\v 12 Keil umoni hemukonek keke meatin vasi keil ilea sakien keil koa mul rie lat keihoen onom.  
\q2 Anatin, keil ilea suk keke losilkatien onom mariso mok.   
\q1
\v 13 Losilkatien onom hel lisenges,  
\q2 ka kihi asuv houlu onen meatin keil heha vio … hervustei.  
\b  
\q1 Iahova, keik komum vasin hatkatien keil onom,  
\q2 ka korie lat envatien onom ka en sakien keil onom.   
\q1
\v 14 Iahova, keik komul kokataun koakeil avotini keih en moulien one,  
\q2 ka korali lat koakeil keihoen one tovuol emun.   
\q1
\v 15 Meten meatin keil amul alele vat venuk keke kovalosil kat keil.  
\q2 Ka komul kosan anien min keil en avong koa mal.   
\q1
\v 16 Tounah vasi koa amoul en out netan,  
\q2 amul akur asa koa e vati ka en hem.   
\b  
\q1
\v 17 Iahova, sakien keil onom mal revi,  
\q2 ka umen keil onom rie lat enmahisien onom.   
\q1
\v 18 Keik komul vesesal ven koakeil avis minuk.  
\q2 Anatin, koro vesesal ven koakeil avis minuk ka en tine.   
\q1
\v 19 Koakeil avouhou minuk, komul kosan asa koa e vati.  
\q2 Keik komul kolong hisoen one ka kumai komutut moulien one.   
\q1
\v 20 Iahova, keik kolei kat revi koakeil e vatuk,  
\q2 ka min koakeil amum tisa, ku lin keil.   
\b  
\q1
\v 21 Iahova, nimasmasuk lisenges.  
\q2 Ka tounah vasi keil ten out netan ihati lat isom lises ka lisenges.   
\c 146  
\s1 Rehehati lat isen Iahova koa mutut moulien orer  
\q1
\v 1 !Rehehati lat isen Iahova!  
\q2 !Inau nihou lat isen!   
\q1
\v 2 Nisan masmasien mini en avong vasi koa namul veah namoul.  
\q2 Anatin, nihati lati hetal min souen keil onak.   
\b  
\q1
\v 3 Minalingtei desien onami en avat keil ten out netan,  
\q2 veni meatin keil enges asakras avoutut moulien onami.   
\q1
\v 4 Navong keil umat, ave va ris vi atan,  
\q2 ka tounah keil koa aling kati keke avoumoni mai rokol keite teni.   
\b  
\q1
\v 5 Ka sien mul en koakeil Ahi onen \w Siekob\w* mul kataun keil,  
\q2 mul en koakeil aling desien one en Iahova, Ahi one.   
\q1
\v 6 Veni kei varei mumon out nesa, out netan, atas, ka tounah vasi keil emun koa amul en keitel.\x + \xo 146:6 \xt Umen 4:24; 14:15\x*  
\q2 Kei mul mum vasin hatkatien keil onen.   
\q1
\v 7 Kei varei mul sakin asa koa mal mai kistal en moulien onen koakeil mesav keil amul apurun keil.  
\q2 Kei mul san anien min koakeil amai kat keil.  
\b  
\q1 Iahova mul maen koakeil amul en hen mesav keil  
\q2 uva amaluv.   
\q1
\v 8 Koakeil mete var,  
\q2 mumon keil alele ris.  
\q1 Iahova mul rali lat koakeil umot uva netan,  
\q2 ka en vat koakeil sakien keil one mal.   
\q1
\v 9 Iahova vi eikokoe onen heou keil,  
\q2 ka mul kataun vatina ka timaru keil.  
\q1 Ka koakeil akalkali,  
\q2 kei mul purun keil.   
\b  
\q1
\v 10 Kami koa miro en Hou \w Saeon\w*, Iahova helosil kat kami lisenges.  
\q2 Anatin, helosil kat revi kami hetal min vatiamal keil onami koa imai ikatau en kami.  
\b  
\q1 !Sakini, rehehati lat isen Iahova!   
\c 148  
\s1 Tounah vasi keil avati lat isen Iahova  
\q1
\v 1 !Rehehati lat isen Iahova!  
\b  
\q1 !Kami koa miro en out nesa  
\q2 mihehati lat isen Iahova!   
\q1
\v 2 Anatin, kami angelo keil, mihehati lati,  
\q2 kami koa mimul mivae en usite onen, mihehou lat isen.   
\b  
\q1
\v 3 Meteiai ka avati, milhehati lati.  
\q2 Hitu keil, mihehou lat isen.   
\q1
\v 4 Tounah keil koa mimul en teilang, mihesakin isen hehina nesa.  
\q2 Mahmah keil, mihetie lat hetetamenien onen.   
\q1
\v 5 Kami vasi, mihehati lat isen Iahova,  
\q2 veni mumon kami vasi ral min ren.   
\q1
\v 6 Anatin, navong kei meng kati, kami miva miro kat en out kati onami,  
\q2 ka misakras mivali hakot keil koa Ahi sani min kami.   
\b  
\q1
\v 7 Kami vasi koa miro en out netan,  
\q2 ral min tounah vasi keil koa amoul en huinev ten atas,  
\q2 mihehati lat isen Iahova.   
\q1
\v 8 Ahil koa vil ka voulul koa musel,  
\q2 ous koa mus ka eang koa muhuh keih,  
\q1 kami vasi koa mimul milong kat ren,  
\q2 mihehati lat isen Iahova.   
\b  
\q1
\v 9 Hou keil ka vatihou keil, mihehati lat isen Ahi,  
\q2 hetal min vatiai keil koa amul en out teim ka koakeil emun amul en eivorohus.   
\q1
\v 10 Buluk ka sipsip keil koa amah ka tirendan keil emun ten eivorohus, mihehou lat isen,  
\q2 hetal min tounah sav keil koa amul akekelau ka amuka.   
\b  
\q1
\v 11 Asuv houlu keil ka meatin savsav keil, mihehouhou min Ahi,  
\q2 hetal min avat keil ka hetetamen sav keil emun ten out netan.   
\q1
\v 12 Meatin hau ka ahin hau keil, mihehati lat isen,  
\q2 hetal min ulmatu ka tovuli keil, ka titi ehon ka atouli keil emun.   
\b  
\q1
\v 13 Tounah vasi keil mihehou lat isen Iahova  
\q2 veni isen enges marite mok mulin eis savsav vasi keil.  
\q1 Anatin, isen vi hetetamen imok en out netan ka en out nesa emun.   
\q1
\v 14 Ahi mul san keihoen min meatin keil onen  
\q2 keke akilea avahati lat isen.  
\q1 Kei mul lei kat revi me-Isrel keil veni envatien onen mul en keil.  
\b  
\q1 !Sakini, rehehati lat isen Iahova!   
\c 149  
\s1 Souen ten masmasien ven tahosien onen Ahi  
\q1
\v 1 !Rehehati lat isen Iahova!  
\b  
\q1 Rehesau min Iahova hetal min souen hau tai.  
\q2 Rehehou lati navong rolah ruai ral min meatin sav keil koa amul amusil kati.   
\q1
\v 2 Me-Isrel keil, mihesi kami ven Ahi koa mumon kami.  
\q2 Mihelonge hetahos, meatin keil koa mimul en Hou \w Saeon\w*, ven Iahova koa vi asuv houlu onami.   
\q1
\v 3 Mihehati lat isen hetal min holien keil,  
\q2 mihemasmasi hetal min ave ka kitar.   
\b  
\q1
\v 4 Mihehati lati veni Iahova si kei ven meatin keil onen  
\q2 ka mul san houhouen min koakeil rendemien one mul netan.  
\q2 Kei mul sakin keil avitan en vativieh keil one.   
\q1
\v 5 Koakeil amusil kat Ahi isi keil  
\q2 navong amulin koakeil amul uvae ral min keil,  
\q2 ka isau hetal min sien navong amuseh.   
\q1
\v 6 Keil ihiso hetal min masmasien ven Ahi one,  
\q2 navong avuli kat naef tahuen keil one.   
\q1
\v 7 Hetal min naef onen meatin keil onen,  
\q2 Ahi helei rahit usite onen meatin savsav keil ten out netan  
\q2 ka hesan mahien min keil.   
\q1
\v 8 Ahi hemaen keil ipar kat alen asuv houlu keil ka avat keil onen vativieh keil one  
\q2 hetal min sen keil takeih.   
\q1
\v 9 Anatin, Ahi hesan mahien min meatin keil ekek  
\q2 hesuval koa vat kati keke voumoni min koakeil amum tisa en meten.  
\q1 Ka hekatau suk eni,  
\q2 Ahi hesan hetetamenien min koakeil amusil kati.  
\b  
\q1 !Sakini, rehehati lat isen Iahova!   
\c 150  
\s1 Rehehati lat isen Iahova  
\q1
\v 1 !Rehehati lat isen Iahova!  
\b  
\q1 Rehehati lat isen Ahi en out nesa,  
\q2 rehou lati en out votut onen.   
\q1
\v 2 Rehehati lati ven tounah keil koa marite koa mul mumoni.  
\q2 Rehehou lati veni isen hetetamen imok.   
\b  
\q1
\v 3 Rehehati lati hetal min amaru keil,  
\q2 ka rehehou lati hetal min kitar ka seka keil emun.   
\q1
\v 4 Rehehati lati ka rehetarum en holien mini,  
\q2 ka rehehou lati hetal min iukalele ka ave emun.   
\q1
\v 5 Rehehati lati hetal bonggo  
\q2 ka rehehou lati hetal min okan koa romuhi en onger.   
\q1
\v 6 Kami vasi koa mimoul  
\q2 mihehou lat isen Iahova.  
\b  
\q1 !Ir vasi, rehehati lat isen Iahova!   