\v 16 \w So|strong="H4191"\w* \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* curses \w me|strong="H4191"\w* [MTY] \w must|strong="H4191"\w* \w be|strong="H4191"\w* \w executed|strong="H4191"\w*. \w All|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5712"\w* \w must|strong="H4191"\w* throw stones \w at|strong="H3068"\w* \w him|strong="H4191"\w*. \w It|strong="H8034"\w* \w does|strong="H3068"\w* \w not|strong="H4191"\w* matter if \w he|strong="H3068"\w* \w is|strong="H3068"\w* \w a|strong="H3068"\w* \w foreigner|strong="H1616"\w* \w or|strong="H3068"\w* \w an|strong="H3068"\w* Israeli citizen; \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* curses \w me|strong="H4191"\w* \w must|strong="H4191"\w* \w be|strong="H4191"\w* \w executed|strong="H4191"\w*.’
\p 
\v 17 “\w Also|strong="H3588"\w*, \w If|strong="H3588"\w* \w anyone|strong="H3605"\w* murders another \w person|strong="H5315"\w*, \w he|strong="H3588"\w* \w must|strong="H4191"\w* \w be|strong="H4191"\w* \w executed|strong="H5221"\w*.
