\p 
\v 1 \w Then|strong="H2009"\w* \w I|strong="H2009"\w* \w turned|strong="H7725"\w* \w to|strong="H7725"\w* \w look|strong="H7200"\w*, \w and|strong="H7725"\w* \w there|strong="H2009"\w* \w was|strong="H4039"\w* \w a|strong="H3068"\w* \w flying|strong="H5774"\w* \w scroll|strong="H4039"\w*!
