\id NEH - Biblica® Open Igbo Contemporary Bible 2020
\h Nehemaya
\toc1 Nehemaya
\toc2 Nehemaya
\toc3 Neh
\mt1 Nehemaya
\c 1
\s1 Ekpere Nehemaya
\p 
\v 1 Nke a bụ okwu Nehemaya nwa Hakalaya:
\b
\b
\p Nʼọnwa Kislev,\f + \fr 1:1 \ft Nke a bụ ọnwa itoolu nʼafọ. \xt Zek 7:1\xt*\f* nke afọ ahụ mere ya iri afọ abụọ nke ọchịchị Ataksekses\f + \fr 1:1 \ft Nke bụ mgbe narị afọ itoolu nʼotu gasịrị site na mgbe ndị mbụ si Babilọn lọghachitara. Ọ bụ na Senchuri nke anọ tupu a mụọ Kraịst. \xt Neh 2:1\xt*\f* mgbe m nọ nʼụlọeze dị na Susa,\f + \fr 1:1 \ft Ọ bụ ụlọeze dị na ndagwurugwu mmiri Taịgris, ebe ndị eze atọ chịrị obodo Peshịa na-ebi nʼoge oke oyi. \xt Est 1:2; Dan 8:2\xt*\f*
\v 2 otu nwanne m nwoke aha ya bụ Hanani,\f + \fr 1:2 \ft Ọ ga-abụ onye nne ji ya na Nehemaya, onye bịara zie ya ozi banyere ọnọdụ Jerusalem. \xt Neh 7:2\xt*\f* na ụfọdụ ndị ọzọ sitere Juda bịara ileta m. Ajụrụ m ha ajụjụ otu ihe si agara ndị Juu ahụ fọdụrụ, ndị si ebe dị iche iche lọta, jụọkwa ha maka Jerusalem.
\p 
\v 3 Ha zara si: “Ndị ahụ niile lọtara\f + \fr 1:3 \ft E kewara alaeze Peshịa mpaghara atọ. Nʼobodo Sameria ka ndị na-achị mpaghara Juda nọ.\f* nọ nʼoke nsogbu na ihere. A kụdara mgbidi Jerusalem; e sukwara ọnụ ụzọ ama ya niile ọkụ.”
\p 
\v 4 Mgbe m nụrụ okwu ndị a, anọdụrụ m ala kwaa nnọọ akwa. Nʼezie, ajụrụ m iri ihe ọbụla ọtụtụ ụbọchị, nʼihi na eji m oge m niile kpee ekpere rịọ Chineke nke eluigwe arịrịọ,
\v 5 si ya:
\pm “Gị, \nd Onyenwe anyị\nd* Chineke nke eluigwe, onye dị ukwu na onye dịkwa egwu; gị onye na-edebe ọgbụgba ndụ ịhụnanya nke ndị ahụ hụrụ ya nʼanya na-edebekwa iwu ya niile. Biko nụrụ arịrịọ m.
\v 6 Leda anya ebere gị ka ị nụrụ arịrịọ mụ bụ ohu gị na-arịọ gị ehihie na nʼabalị. Ana m ekwupụta mmehie anyị bụ ụmụ Izrel, ma nke m na ezinaụlọ nna m mere megide gị.
\v 7 Anyị emela ihe jọrọ njọ megide gị. Anyị edebeghị iwu gị na ụkpụrụ gị nke i nyere ohu gị Mosis.
\pm 
\v 8 “Chetakwa ntụziaka inyere Mosis bụ ohu gị, na-asị, ‘Ọ bụrụ na unu emehie, mụ onwe m ga-achụsa unu nʼetiti mba dị iche iche.
\v 9 Ma ọ bụrụ na unu alaghachikwute m, debe ihe niile m nyere unu nʼiwu, a sikwa na a chụsara unu mee ka unu gbasaa ga nʼakụkụ niile nke ụwa, aga m achịkọta unu mee ka unu laghachi na Jerusalem bụ obodo m họpụtara nye Aha m.’
\pm 
\v 10 “Anyị bụ ndị ohu gị, bụrụkwa ndị i ji aka gị dị ike zọpụta.
\v 11 Biko, Onyenwe anyị, nụrụ ekpere mụ bụ ohu gị, nụrụkwa ekpere ndị ohu gị niile ọ na-atọ ụtọ ịtụ egwu aha gị. Mee ka ihe gara ohu gị nke ọma taa site nʼimere ya ebere nʼihu nwoke a.\f + \fr 1:11 \ft Eze a na-ekwu maka ya nʼebe bụ Ataksekses, \xt Ezr 4:21\xt*\f*”
\p Nʼoge ahụ abụ m onye na-ebu ihe ọṅụṅụ eze.
\c 2
\s1 Nehemaya abịaruo Jerusalem
\p 
\v 1 Nʼọnwa Nisan, nʼiri afọ abụọ nke ọchịchị eze Ataksekses, mgbe e wetaara eze mmanya. E buru m mmanya ahụ bugara ya eze. Ugbu a, o nwebeghị mgbe ọbụla m jirila ihu mgbarụ bịa nʼihu eze.
\v 2 Ya mere, eze jụrụ m, “Gịnị mere ihu gị ji gbaruo mgbe ọ dịghị ọrịa ji gị? Nke a na-egosi naanị na obi jọrọ gị njọ.”
\p Ụjọ tụrụ m nnọọ nke ukwu.
\v 3 Azara m eze sị, “Onyenwe m, ka ọchịchị eze dị ogologo ndụ. Gịnị ga-eme ka obi dị m ụtọ ebe ọ bụ na obodo ahụ e liri nna nna m ha aghọọla mkpọmkpọ ebe, nke a kpọkwara ọnụ ụzọ ama ya niile ọkụ?”
\p 
\v 4 Eze sịrị m, “Ọ bụ gịnị ka ị chọrọ?”
\p Mgbe ahụ ekpere m ekpere nʼobi m nye Chineke,
\v 5 ma zaa eze sị, “Ọ bụrụ na ọ ga-amasị eze, biko, ọ bụrụkwa na ohu gị achọta ihuọma nʼanya gị, ana m arịọ ka ị ziga m Juda, bụ obodo nna nna m ha, ka m gaa wugharịakwa ya.”
\p 
\v 6 Eze sịrị m, ebe nwunye ya nọkwa nʼakụkụ ya, “Ije gị ọ ga-abụ ruo olee mgbe, olee mgbe ị ga-alọghachitekwa?” Ọ masịrị eze i ziga m. Ya mere, enyere m ya oge.
\p 
\v 7 Mgbe ahụ, asịrị m ya, “Ọ bụrụ na ọ ga-amasị eze, aga m achọ ka i nye m akwụkwọ nke m ga-enye ndịisi ọchịchị niile nọ nʼakụkụ ọdịda anyanwụ osimiri Yufretis, ka ha kwere ka m site nʼobodo ha gafee ruo mgbe m ga-eru na Juda.
\v 8 Nyekwa m akwụkwọ ozi m ga-enye Asaf, onye na-elekọta ọhịa eze, ka o nye m osisi nke a ga-eji rụzie ọnụ ụzọ dị nʼakụkụ ụlọnsọ, na nke a ga-eji rụọ mgbidi obodo ahụ, na nke m ga-eji rụọ ụlọ nke aka m.” Eze meere m ihe ndị a niile, nʼihi na aka ebere Chineke dịnyere m.
\v 9 Mgbe m rutere obodo ndị a dị nʼakụkụ ọdịda anyanwụ osimiri Yufretis, enyere m ndịisi ọchịchị niile akwụkwọ ahụ eze dere nye m. Eze dunyere m ndịisi agha na ndị agha na-agba ịnyịnya ka ha chebe m nʼije m.
\p 
\v 10 Ma mgbe Sanbalat,\f + \fr 2:10 \ft Bụ onyeisi ọchịchị na Sameria.\f* onye Horonaim, na Tobaya, onye Amọn bụ onyeisi ọrụ ọchịchị, nụrụ ihe banyere ọbịbịa m, iwe were ha nke ukwuu ịnụ na o nwere onye na-achọ inyere ndị Izrel aka.
\s1 Nehemaya eledo Mgbidi Jerusalem
\p 
\v 11 E rutere m Jerusalem, nọdụkwa ebe ahụ mkpụrụ ụbọchị atọ,
\v 12 eji m abalị pụọ kpọrọ mmadụ ole na ole. O nwebeghị onye ọbụla m gwara ihe Chineke tinyere m nʼobi ime na Jerusalem. Ọ dịghị ịnyịnya ọzọ anyị ji ma ọ bụghị nke ahụ m na-agba.
\p 
\v 13 Nʼabalị a pụrụ m site nʼỌnụ ụzọ ama Ndagwurugwu\f + \fr 2:13 \ft Ọnụ ụzọ ama a dị nʼọdịda anyanwụ nke mgbidi Jerusalem, \xt 2Ih 26:9; Neh 3:13.\xt*\f* ruo nʼisi iyi mmiri Nkịta ọhịa,\f + \fr 2:13 \ft Agwọ, nʼokwu ịma atụ\f* sitekwa nʼebe ahụ ruo nʼỌnụ ụzọ ama ebe ikpofu ahịhịa.\f + \fr 2:13 \ft Ọnụ ụzọ ama dị nʼebe a na-ekpofu ahịhịa, bụ ọnụ ụzọ ndị Juu na-esite mgbe ha na-edupụ ụmụ anụmanụ e ji achụ aja, ị duru ha jeruo Ndagwurugwu nke Ben Hinom. Gụọ akwụkwọ \xt Neh 3:14; 2Ez 23:10\xt*\f* Anyị jegharịrị ịhụ ebe niile mgbidi Jerusalem dara ada, na ọnụ ụzọ ama ya niile nke ọkụ rere.
\v 14 Emesịa, ejeruru m ọnụ ụzọ nke dị nʼebe isi iyi dị, ruokwa nʼọdọ mmiri eze, ma ịnyịnya ibu m enweghị ike isite nʼebe ahụ gafee.
\v 15 Ya mere, ejiri m nʼabalị jeruo ndagwurugwu ahụ, leruo mgbidi ahụ anya. Emesịa, atụgharịrị m lọghachi site nʼọnụ ụzọ Ama ndagwurugwu.
\v 16 Ndịisi obodo amaghị ebe m gara maọbụ ihe m na-eme, nʼihi na agwabeghị m onye Juu ọbụla ihe m bu nʼobi, maọbụ ndị nchụaja, maọbụ ndị a na-asọpụrụ, maọbụ ndị ọchịchị obodo, maọbụ onye ọzọ ọbụla ndị ga-arụ ọrụ ahụ.
\p 
\v 17 Nʼikpeazụ, agwara m ha sị, “Unu maara nke ọma ihe dakwasịrị obodo anyị. Lee otu mgbidi ya si dakasịa, na otu ọnụ ụzọ ama ya si rechapụ ọkụ. Ka anyị wuzienụ mgbidi Jerusalem, si otu a wepụ ihe ihere a dịịrị anyị.”
\v 18 Akọọrọ m ha ọchịchọ ahụ Chineke tinyere m nʼobi na ihe mụ na eze kwuru, na otu o si kwadoo ihe m gwara ya.
\p Ha zara m sị, “Ọ dị mma, ka anyị wugharịanụ mgbidi ahụ.” Ọrụ ahụ bidokwara na-atụfughị oge.
\p 
\v 19 Ma mgbe Sanbalat, onye Horon, na Tobaya, onyeozi ndị Amọn, na Geshem onye Arab, nụrụ ya, ha kwara anyị emo sị, “Gịnị bụ ihe nke a unu na-eme? Ọ bụ eze ka unu na-enupu isi megide?”
\p 
\v 20 Ma azara m ha sị, “Chineke nke eluigwe ga-eme ka ihe gara anyị nke ọma. Anyị onwe anyị bụ ndị ohu ya ga-amalite iwughachi mgbidi a, ma unu onwe unu, unu enweghị oke maọbụ ọnọdụ ziri ezi maọbụ ihe ncheta ọbụla nʼime Jerusalem.”
\c 3
\s1 Ndị wugharịrị mgbidi ahụ
\p 
\v 1 Mgbe ahụ, Eliashib onyeisi nchụaja na ndị nchụaja ibe ya wuru mgbidi ahụ ruo nʼụlọ elu Narị na ụlọ elu Hananel. Ha wukwara Ọnụ Ụzọ ama Atụrụ, kwụba ibo ya, doo ya nsọ.
\v 2 Ndị sitere obodo Jeriko rụkwara ọrụ nʼakụkụ ha. Ma Zakua nwa Imri, rụrụ ọrụ nke ha nʼakụkụ ndị ọrụ si Jeriko.
\b
\p 
\v 3 Ụmụ ndị ikom Hasena wuru Ọnụ Ụzọ ama Azụ, dobe osisi ya, kwụba ọnụ ụzọ ya, kpụọkwa ihe mkpọchi ya niile, na ihe ntụchi ya niile nʼọnọdụ ha.
\v 4 Meremot, nwa Ụraya, nwa Hakoz, rụziri akụkụ mgbidi nke ọzọ. Onye na-eso ya bụ Meshulam, nwa Berekaya, nwa Meshezabel, rụziri mgbidi, onye na-esota ya bụ Zadọk nwa Baana, onye rụzikwara mgbidi.
\v 5 Akụkụ nke ọzọ ka ndị ikom Tekoa rụziri, ma ndị ha a na-asọpụrụ ekweghị ehudata ubu ha nye ọrụ ahụ nʼokpuru ndị nlekọta ha.
\b
\p 
\v 6 Joiada nwa Pasea na Meshulam nwa Besodeia wuru Ọnụ Ụzọ Ama Jeshana. Ha tinyere osisi ya niile, kwụba ibo ọnụ ụzọ ya, ihe mkpọchi ya na ihe ntụchi ya niile nʼọnọdụ ha.
\v 7 Ndị ọzọ rụrụ ọrụ nʼakụkụ ha bụ Melataya, onye Gibiọn, na Jadon onye Meronot, na ndị si Gibiọn na Mizpa. Obodo ndị a dị nʼokpuru onyeisi ọchịchị akụkụ ọdịda anyanwụ Yufretis.
\v 8 Uziel nwa Hahaya, bụ ọkpụ ụzụ ọlaedo, doziri otu akụkụ. Onye na-eso ya bụ Hananaya, otu onye nʼime ndị na-eme mmanụ otite na-esi isi ọma, doziri nke na-esote nke ahụ. Ha doziri Jerusalem ruruo ya na Mgbidi Obosara.
\v 9 Onye na-eso ha bụ Refaya nwa Hua onyeisi ọchịchị otu akụkụ Jerusalem.
\v 10 Onye na-eso ya bụ Jedaya nwa Harumaf, onye rụrụ akụkụ mgbidi ahụ chere ihu nʼụlọ nke aka ya. Onye na-eso ya nʼọrụ a bụ Hatush nwa Hashabneia.
\v 11 Onye ọzọ bụ Malkija nwa Harim, na Hashub nwa Pahat-Moab, ndị wugharịrị ụlọ elu ọkụ, na otu akụkụ mgbidi ahụ.
\v 12 Shalum nwa Halohesh na ụmụ ya ndị inyom meziri akụkụ mgbidi nke na-esota. Ọ bụ onyeisi ọchịchị otu akụkụ Jerusalem nke ọzọ.
\b
\p 
\v 13 Hanun duuru ndị obodo Zanoa wuo Ọnụ Ụzọ Ndagwurugwu. Ha wuziri ya, tinye ibo ya, ihe mkpọchi ya na ihe ntụchi ya niile nʼọnọdụ ha. Ha wuzikwara mpaghara ahụ nke ịdị ogologo ya ruru narị mita ise, ruo nʼọnụ ụzọ ama dị nʼebe a na-ekpofu ahịhịa.
\b
\p 
\v 14 Malkija nwa Rekab, onyeisi ọchịchị ala nke dị Bet-Hakerem gburugburu, bụ onye wuziri ọnụ ụzọ ama dị nʼebe ikpofu ahịhịa. O tinyere ibo ya, ihe mkpọchi ya na ihe ntụchi ya niile nʼọnọdụ ha.
\b
\p 
\v 15 Shalum nwa Kol-Hoze, onyeisi ọchịchị ala dị Mizpa gburugburu, wuziri ọnụ ụzọ ama isi iyi, kpuchie elu ya, tinye ya ibo ọnụ ụzọ ya, ihe mkpọchi na ihe ntụchi ya niile nʼọnọdụ ha. O mezikwara mgbidi ahụ site nʼọdọ mmiri Siloam ruo nʼubi eze a gbara ogige, na ruokwa na nkwasa nrịda dị site nʼobodo Devid ma e site Jerusalem na-apụta.
\v 16 Onye na-eso ya bụ Nehemaya nwa Azbuk, onyeisi ọchịchị ọkara nʼime Bet Zoa.\f + \fr 3:16 \ft Bụ ụlọ obibi ochie ndị nche, nke Devid wuru maka ndị agha na-eche ya nche mgbe ọ bụ eze. \xt 2Sa 23:8-39\xt*\f* O wuziri mgbidi ahụ ruo ncherita ihu ebe ili Devid, ruokwa ọdọ ebe emere maka ichekọta mmiri, na nʼỤlọ ndị Dike nʼagha.
\s1 Ọrụ ndị Livayị rụrụ
\p 
\v 17 Ndị na-eso ya bụ ndị Livayị, ndị nke Rehum nwa Bani na-achịkọta. Onye ọzọ bụ Hashabaya onyeisi ọchịchị ọkara ndị bi na Keila. Ọ rụrụ ọrụ e kenyere ndị ya.
\v 18 Onye ọzọ na-eso ya bụ Binui nwa Henadad onye bụ onyeisi ọchịchị ọkara akụkụ Keila nke ọzọ. O du ndị Keila ibe ya rụọ ọrụ ha ketara.
\v 19 Onye na-eso ya bụ Eza nwa Jeshua onyeisi ọchịchị obodo Mizpa. Ya na ndị otu ya rụziri akụkụ mgbidi ahụ dị na mgbago ebe ụlọ nchịkọta ngwa agha ruo na nkuku ya.
\v 20 Onye ọzọ na-eso ya bụ Baruk, nwa Zabai, onye ji nnọọ ịnụ ọkụ nʼobi rụzie mgbidi ahụ site na nkuku ya ruo nʼọnụ ụzọ e si abata ụlọ Eliashib, bụ onyeisi nchụaja.
\v 21 Onye na-eso ya bụ Meremot nwa Ụraya, nwa Hakoz. Ọ sitere nʼọnụ ụzọ ụlọ Eliashib rụziri ruo na ngwụcha ya.
\s1 Ọrụ ndị nchụaja rụrụ
\p 
\v 22 Ndị nchụaja si nʼakụkụ Jerusalem wuziri akụkụ nke na-esote ya.
\v 23 Isonye ha, Benjamin na Hashub wuziri akụkụ ahụ dị nʼihu ụlọ ha. Azaraya nwa Maaseia, onye bụkwa nwa nwa Ananaya wuziri nke na-esote ya, nke dịkwa nʼakụkụ ụlọ ya.
\v 24 Binui nwa Henadad wuziri akụkụ nke ọzọ, nke sitere nʼihu ụlọ Azaraya ruo na nkuku mgbidi ahụ.
\v 25 Palal nwa Uzai wuziri akụkụ nke na-eso ya site na nkuku mgbidi ahụ ruo nʼụlọ elu dị nʼakụkụ elu elu ụlọeze nʼebe dị nso nʼogige ndị nche. Nke so ya bụ Pedaia nwa Parosh,
\v 26 na ndị na-eje ozi nʼụlọnsọ ahụ bụ ndị bi nʼelu ugwu Ofel, wuziri akụkụ nke na-esote ruo nʼebe dị nʼakụkụ ọwụwa anyanwụ nke Ọnụ Ụzọ Ama Mmiri, ruokwa nʼụlọ elu nche nke ụlọ ukwu ahụ.
\v 27 Ndị ikom Tekoa wuru akụkụ nke ọzọ na-esote ya. Ha sitere nʼebe chere ụlọ elu nche nke ụlọnsọ ukwu ahụ ihu, wuzie mgbidi ahụ ruo na mgbidi dị Ofel nso.
\b
\p 
\v 28 Ụfọdụ ndị nchụaja wuziri akụkụ na-esote, nke dị nʼugwu, site nʼỌnụ Ụzọ Ama Ịnyịnya. Onye ọbụla wuziri mgbidi nke dị nʼihu ụlọ ya.
\v 29 Zadọk nwa Imea wuziri nke na-esota, bu akụkụ mgbidi ahụ chere ihu nʼụlọ ya. Shemaya nwa Shekanaya onye na-eche Ọnụ Ụzọ Ama Ọwụwa Anyanwụ wuziri akụkụ nke na-esota.
\v 30 Hananaya nwa Shelemaya na Hanun nwa Zalaf nke isii, wuziri akụkụ mgbidi nke ọzọ. Meshulam nwa Berekaya wuziri akụkụ mgbidi na-esota, bụkwa nke dị nʼihu ụlọ obibi ya.
\v 31 Malkija ọkpụ ụzụ ọlaedo wuziri akụkụ na-esota ruo nʼụlọ ahụ ndị na-eje ozi nʼụlọnsọ, na ndị na-azụ ahịa na-anọkọ. Ụlọ a dị na ncherita ihu Ọnụ Ụzọ Ama Nnyocha. Malkija sitekwara nʼebe ahụ wuzie mgbidi ahụ ruo nʼọnụụlọ ahụ dị nʼelu nkuku mgbidi ahụ.
\v 32 Ndị ọkpụ ụzụ ọlaedo na ndị ahịa rụchara ọrụ iwuzi akụkụ mgbidi nke fọdụrụ, site nʼetiti ọnụụlọ ahụ dị nʼelu nkuku mgbidi ahụ ruo nʼỌnụ Ụzọ Ama Atụrụ.
\c 4
\s1 Ndị iro
\p 
\v 1 Iwe were Sanbalat nke ukwuu mgbe ọ nụrụ na anyị na-ewuzigharị mgbidi ahụ niile. O were iwe dị ọkụ, ọnụma jukwara ya obi. Ọ chịrị ndị Juu ọchị, kwaakwa ha emo.
\v 2 Nʼihu ndị otu ya na ndịisi agha Sameria, o kwuru si, “Gịnị ka ndị Juu ole na ole a na-adịghị ike na-eme? Ha na-achọ iwugharị mgbidi obodo a? Ha ga-achụ aja? Ha ga-arụcha ọrụ niile nʼotu ụbọchị? Ha ga-esita nʼaja a kụpịasịrị akụpịa mee ka nkume ndị a dị ndụ, ka ọ bụ site na nkume ochie ndị a akpọrọ ọkụ?”
\p 
\v 3 Tobaya onye Amọn, onye nọ ya nʼakụkụ mgbe ahụ, kwukwara okwu sị; “Leenụ ụdị mgbidi ha na-ewu! Ọ bụrụ na nkịta ọhịa arịkwasị ya nʼelu ọ ga-ada!”
\b
\p 
\v 4 Mgbe ahụ, e kpere m ekpere sị, “Chineke, biko nụrụ emo a na-akwa anyị. Ka ịkwa emo ha laghachikwa ha nʼisi; ka a dọtakwa ha nʼagha buru ha jee mba ọzọ.
\v 5 Elefula mmehie ha anya, agbagharakwala ha, nʼihi na ha ledara gị anya, ledakwa anyị anya, bụ ndị na-ewuzi mgbidi gị.”
\b
\p 
\v 6 Ya mere, anyị wuziri mgbidi ahụ ruo mgbe ha niile ruru ọkara nʼịdị elu ya, nʼihi na onye ọbụla wepụtara obi ya ịrụ ọrụ.
\p 
\v 7 Ma mgbe Sanbalat, Tobaya, ndị Arab, ndị Amọn na ndị Ashdọd nụrụ na ọrụ iwuzi mgbidi Jerusalem na-aga nʼihu, nụkwa na-emechichala ebe niile puru epu, iwe were ha nke ukwuu.
\v 8 Ha niile gbara izu ịchịrị ndị agha bịa imegide Jerusalem, ime ka ọgbaaghara dị nʼobodo ahụ.
\v 9 Ma anyị kpere ekpere nye Chineke, kwụbakwa ndị nche iguzogide ha ehihie na abalị.
\p 
\v 10 Mgbe ahụ, ndị Juda bidoro itamu ntamu na-asị, na ike ebidola ịgwụ ndị ọrụ ha, na mkpọmkpọ ihe fọdụrụ ka buru ibu, na naanị anyị apụghị ịrụcha mgbidi ahụ.
\p 
\v 11 Ma nʼotu oge ahụ kwa, ndị iro anyị na-agba izu nʼakụkụ, na-achọ igbu anyị mgbe anyị na-eleghị anya ha maọbụ mara ka ọrụ ahụ kwụsị.
\p 
\v 12 Ndị Juu ndị bi ha nso bịara ọtụtụ mgbe gwa anyị, “Ebe ọbụla unu gbagara, ha ga-ebuso unu agha.”
\p 
\v 13 Nʼihi ya, eguzobere m ndị ụfọdụ nʼebe niile dịkarịsịrị ala nʼazụ mgbidi ahụ, nʼebe niile ghere oghe, e guzobere ha, kpanye ha mma agha, ùbe na ụta nʼaka dịka ezinaụlọ ha si dị.
\v 14 Mgbe m lezichara ihe niile anya, eguzooro m ọtọ sị ndị ahụ a na-asọpụrụ, na ndị ọchịchị niile na ndị ọzọ nʼobodo ahụ, “Unu atụla ha egwu. Chetanụ na Onyenwe anyị, nke dị ukwuu na-eyikwa egwu, ma bukwaaranụ ezinaụlọ unu, ụmụ unu ndị ikom ndị inyom, ndị nwunye unu na ụlọ unu agha.”
\p 
\v 15 Mgbe ndị iro anyị chọpụtara na anyị amatala izu ọjọọ ha, na Chineke emebiekwala atụmatụ ha, anyị onwe anyị laghachiri nʼọrụ anyị nke iwuzi mgbidi ahụ.
\p 
\v 16 Sitekwa nʼoge ahụ gaa nʼihu, anyị kere onwe anyị ụzọ abụọ. Ụfọdụ ndị ji ùbe, ọta na ụta na-anọ na nche mgbe ndị ọzọ na-arụ ọrụ. Ndịisi niile pụtakwara guzo nʼazụ ndị Juda niile ebe ha nọ nʼihu ọrụ ha.
\v 17 Ndị na-edo nkume na ndị ọrụ ọbụla debere ngwa ọgụ ha nʼebe ọ ga-eru ha aka mgbe ọbụla ha na-arụ ọrụ.
\v 18 Ndị ọzọ tinyere mma agha ha nʼukwu ha. Ndị na-egbu opi nọkwa m nʼakụkụ mgbe niile maka ịfụ opi mgbe a chọrọ ya.
\p 
\v 19 Mgbe ahụ, asịrị m ndị niile a na-asọpụrụ, ndị ọchịchị na ndị mmadụ ọzọ ahụ niile, “Ọrụ anyị nwere ịrụ dị ukwuu, gbasapụkwa, anyị anọkọtaghị ọnụ nʼotu ebe, ekewakwara anyị ebe dị iche iche na mgbidi.
\v 20 Ya mere, mgbe ọbụla unu nụrụ ụda opi, gbaranụ ọsọ bịa nʼebe m nọ. Chineke ga-alụkwara anyị ọgụ.”
\p 
\v 21 Ya mere, anyị nọgidere nʼọrụ anyị site nʼìhè mbụ nke ụtụtụ rụọ mgbe kpakpando pụtara. Ọkara nʼime ndị ọrụ jikwa ùbe nọrọ na nche.
\v 22 Agwara m ndịisi ọrụ niile okwu sị ha na onyeisi ọrụ ọbụla na ndị na-enyere ya aka nʼọrụ ga na-anọ na Jerusalem nʼabalị niile. Nʼụzọ dị otu a, ndị ọrụ ga-arụ ọrụ ha nʼoge ihe dị, ma ha ga-anọkwa na nche nʼabalị.
\v 23 Nʼoge ndị a niile, eyipụghị m uwe m yi nʼahụ. O nwekwaghị onye ọbụla ọzọ, maọbụ nwanne m nwoke, maọbụ ndị nche na-eso m onye yipụrụ uwe ya ma onye ukwu ma onye nta. Mma agha anyị na-adịkwa anyị nʼukwu mgbe niile, ọbụladị mgbe anyị chọrọ mmiri.
\c 5
\s1 Nehemaya enyere ndị ogbenye aka
\p 
\v 1 Nʼoge ahụ, ụfọdụ ezinaụlọ bidoro itamu ntamu megide ndị Juu ibe ha.
\v 2 Ụfọdụ na-atamu na-asị, “Anyị na ụmụ anyị dị ukwuu nʼọnụọgụgụ. Ọ bụrụ na anyị ga-eri nri dị ndụ, o kwesikwara ka anyị nwee ike ịzụrụ ọka.”
\p 
\v 3 Ndị ọzọ na-asịkwa, “Anyị agbaala ubi anyị, ubi vaịnị anyị na ụlọ anyị nʼibe ka anyị nweta mkpụrụ ubi nʼoge ụnwụ.”
\p 
\v 4 Ma ndị ọzọkwa na-asị, “Lee na anyị gbazitere ego anyị ji tụọ ụtụ isi eze maka ubi anyị na ubi vaịnị anyị.
\v 5 Nʼagbanyeghị na ọ bụ otu anụ ahụ na ọbara ka anyị na ndị Juu ọzọ nwere, dịka ụmụ ha dị ka ụmụ anyị dịkwa, ma anyị emeela ka ụmụ anyị ndị ikom na ndị inyom bụrụ ndị ohu. Ụfọdụ nʼime ụmụ anyị ndị inyom abụrụlarị ndị ohu, ma anyị enweghị ike nke aka anyị, nʼihi na ndị ọzọ bụ ndị nwezi ala ubi anyị na ubi vaịnị anyị niile.”
\p 
\v 6 Iwe were m nke ukwuu mgbe m nụrụ mkpu akwa ha na mkpesa ndị a.
\v 7 Ya mere, mgbe m chesiri echiche banyere ya, e boro m ndị a na-asọpụrụ na ndị ọchịchị ebubo. A gwara m ha, “Unu na-anara ụmụnna unu ọmụrụnwa ego unu enyere ha.” Ya mere, a kpọrọ m nzukọ ọha mmadụ maka imegide ha.
\v 8 Nʼụbọchị nzukọ ahụ, agwara m ha okwu sị, “Ọtụtụ nʼime anyị na-agbalị nʼụzọ niile ịhụ na anyị zụtaghachiri ụmụnna anyị ndị Juu bu ndị e resiri ndị mba ọzọ. Ma unu nọ nʼebe a na-agbalị ime ha ka ha ghọọ ndị ohu unu. Ruo ole mgbe ka anyị ga-anọgide na-agbapụta ha site nʼọnọdụ ibu ohu?” Ma ha niile ekwughị okwu ọbụla, nʼihi na ha enweghị ihe ha ga-ekwu.
\p 
\v 9 Agwakwara m ha okwu ọzọ sị, “Ihe unu na-eme jọrọ njọ. O kwesighị ka unu tụọ egwu Chineke si otu a gbanarị nkọcha nke ndị iro anyị, bụ ndị mba ọzọ?”
\v 10 Mụ onwe m na ụmụnna m na ndị na-ejere m ozi na-agbazinye ụmụnne anyị ego na ọka. Ma ka anyị kwụsị ịnara ọmụrụnwa.
\v 11 Nyeghachinụ ha ala ubi ha niile ngwangwa, ma ubi vaịnị ha niile, ubi oliv ha niile, ụlọ ha niile na ọmụrụnwa nke unu na-anara ha nke bụ otu ụzọ nʼime narị nke ego, ọka, mmanya ọhụrụ na mmanụ.
\p 
\v 12 Ha sịrị, “Anyị ga-enyeghachi ha. Anyị agakwaghị anara ha ihe ọzọ. Anyị ga-emezu ihe i kwuru.”
\p Mgbe ahụ, akpọkọtara m ndị nchụaja, mee ka ndị ndu na ndịisi ozi ṅụọ iyi imezu nkwa ha.
\v 13 Ayọgharịrị m ọnụ ọnụ uwe mwụda m sị, “Otu a ka Chineke ga-esi yọchapụ site nʼụlọ ha na ihe nweta ha onye ọbụla nke na-agaghị edebezu nkwa a.”
\p Ndị niile zukọrọ kwere sị, “Amen.” Ha tokwara \nd Onyenwe anyị\nd*: Ha niile mekwara ihe ha kwere na nkwa.
\p 
\v 14 Ọzọ, nʼime afọ iri na abụọ ahụ a họpụtara m ị bụ onyeisi ọchịchị na Juda, site nʼiri afọ abụọ nke ịbụ eze Ataksekses ruo nʼafọ iri atọ na abụọ ya, mụ na ụmụnne m esiteghị na nri a na-atụkọrọ onyeisi ọchịchị were ihe oriri ọbụla.
\v 15 Ma ọ bụghị otu a ka o si dị na mbụ, nʼihi na ndịisi ọchịchị niile buru m ụzọ chịa boro ndị ahụ ibu arọ dị ukwuu. Ha na-anakọta site nʼaka onye ọbụla iri mkpụrụ ọlaọcha anọ, tinyere ihe oriri na mmanya ha na-ewebatakwa. Ọbụladị ndị na-enyere ha aka mekpakwara ndị mmadụ ahụ. Ma emeghị m otu a, nʼihi ịtụ egwu Chineke.
\v 16 Kama, anọgidesiri m ike nʼọrụ iwugharị mgbidi ahụ, achịkọtara ndị ikom m niile nʼebe ahụ nʼihi ije ozi a. Ọ dịghịkwa ala anyị zụrụ.
\p 
\v 17 Ma otu ọ dị, ndịisi Juu ọnụọgụgụ ha dị otu narị na iri na ise na-eri nri na tebul m, tinyere ndị na-abịakwute anyị site na mba ndị dị anyị gburugburu.
\v 18 Ihe na-ezu nri a na-eri nʼụlọ m kwa ụbọchị bụ otu ehi na atụrụ isii gbara abụba, na ọtụtụ ọkụkụ,\f + \fr 5:18 \ft Maọbụ, \fqa ụmụ nnụnụ\f* na ụdị mmanya dị iche iche a na-ebubata kwa ụbọchị iri ọbụla. Nʼagbanyeghị nke a, ọ dịghị mgbe ọbụla m nara site nʼaka ha ụtụ ihe oriri nke onye na-achị ala kwesiri inweta, nʼihi na ha onwe ha nọ na mkpa dị ukwuu.
\p 
\v 19 Chineke m biko, echefula ihe m meere ndị a, gọzie m nʼụzọ nke gị.
\c 6
\s1 Izuzu ọjọọ megide Nehemaya
\p 
\v 1 Mgbe a gwara Sanbalat, na Tobaya, na Geshem onye Arab, na ndị iro anyị ndị ọzọ na m ewuzichaala mgbidi ahụ, na ọ dịkwaghị ntipu fọdụrụ na ya, ọ bụ ezie na nʼoge ahụ, etinyebeghị m ibo nʼọnụ ụzọ ama ya niile,
\v 2 Sanbalat na Geshem zitere m ozi a, “Bịa ka anyị zụkọta nʼotu obodo nta nke dị nʼobosara ala Ono.”
\p Ma ha na-achọ ụzọ imerụ m ahụ.
\v 3 Ya mere, azara m ha site nʼaka ndị ozi sị, “Ana m arụ ọrụ dị oke mkpa, agaghị enwe ike ịrịdata. Nʼihi gịnị ka ọrụ a ga-eji kwụsị mgbe m ga-ahapụ ya ịbịa nʼebe ị nọ?”
\v 4 Ha zitere ozi ahụ ugboro anọ, ma enyere m ha otu ọsịsa ahụ ugboro anọ.
\p 
\v 5 Na nke ugboro ise, Sanbalat ziteere m onye na-ejere ya ozi, ya na akwụkwọ ozi nke e mechighị emechi o ji bịa.
\v 6 Nke a bụ ihe e dere nʼime ya;
\pm “Anụla ya na mba niile, Geshem kwukwara otu ihe ahụ, na gị na ndị Juu na-akwado inupu isi. Ọ bụ ya mere i ji na-ewu mgbidi ahụ. Ozi ahụ na-ekwukwa na gị onwe gị na-achọ ịbụ eze ha,
\v 7 na ị họpụtala ndị amụma ndị ga-ekwupụta na Jerusalem na ị bụ eze ndị Juda. Ugbu a, ozi a ga-eru ntị eze, ya mere, bịa ka mụ na gị kparịtaa ụka nʼetiti onwe anyị.”
\p 
\v 8 Ma eziri m ya ozi sị, “O nweghị eziokwu ọbụla dị nʼihe ị na-ekwu, nʼihi na ha bụ ihe i chepụtara nʼobi gị.”
\p 
\v 9 Nzube ha bụ ime ka ụjọ tụọ anyị. Ha na-echekwa sị, “Ha ga-ada mba nʼọrụ a ma hapụkwa ịrụcha ya.”
\p Ma akpọkuru m Chineke sị ya, “Biko gbaa aka m ume.”
\p 
\v 10 Otu ụbọchị, a gara m nʼụlọ Shemaya, nwa Delaya, nwa Mehetabel, onye e mechibidoro ụzọ nʼụlọ ya. Ọ sịrị m, “Ka anyị zukọta nʼụlọ Chineke, nʼime ụlọnsọ, ka anyị mechiekwa ụzọ niile nke ụlọnsọ ahụ, nʼihi na ndị ikom na-abịa igbu gị, e, nʼabalị ka ha na-abịa igbu gị.”
\p 
\v 11 Ma azara m si; “O kwesiri ka mụ onwe m bụ onyeisi ọchịchị gbaa ọsọ? O kwesiri ka mmadụ dịka m\f + \fr 6:11 \ft Ọ bụ naanị ndị nchụaja ka ọ dịrị ịbanye nʼEbe kachasị Nsọ nke ụlọnsọ ukwu ahụ. \xt Ọnụ 18:22\xt*\f* gbaa ọsọ gbaba nʼụlọnsọ Chineke ịzọpụta ndụ ya? Agaghị m aga.”
\v 12 Mgbe ahụ ka o doro m anya na Chineke agwaghị ya okwu ọbụla, kama na ọ bụ Tobaya na Sanbalat zụrụ ya.
\v 13 E goro ya ọrụ ka o yinye m egwu, ka m site na-ime otu a mehie, mgbe ahụ, ha ga-ahụ ihe ha ga-eji nye m aha ọjọọ, kwaa m emo.
\b
\p 
\v 14 “Chineke m, cheta Tobaya na Sanbalat, nʼihi ihe ndị a niile ha mere, chetakwa Noadaya, bụ onye amụma nwanyị, na ndị amụma ndị ọzọ niile fọdụrụ, bụ ndị ahụ chọrọ ime ka m tụọ egwu.”
\v 15 E wuchara mgbidi ahụ nʼụbọchị iri abụọ na ise nke ọnwa Elul, nʼime iri ụbọchị ise na abụọ.
\s1 Ọgwụgwụ ọrụ
\p 
\v 16 Mgbe ndị iro anyị niile nụrụ ya, mba niile ndị nọ anyị gburugburu tụrụ ụjọ, obi jụkwara ha oyi, nʼihi na ha matara na-arụrụ ọrụ a site nʼinyeaka Chineke.
\p 
\v 17 Ọzọ, nʼụbọchị ndị ahụ ndị Juda a na-asọpụrụ na e zigara Tobaya ọtụtụ akwụkwọ ozi, akwụkwọ ozi Tobaya na-erutekwa ha aka.
\v 18 Nʼihi na ọtụtụ ndị Juda ṅụrụ iyi ịnọ ya nʼukwu, nʼihi na ọgọ ya nwoke nʼala Juda bụ Shekanaya nwa Ara. Ọzọkwa, Jehohanan nwa nwoke Tobaya na-alụ nwa nwanyị Meshulam, nwa Berekaya.
\v 19 Ha niile nọgidere na-agwa m otu Tobaya si bụrụ ezigbo mmadụ. Ma ha na-apụkwa gaa kọọrọ ya ihe niile m kwuru. Nʼihi ya Tobaya zitere ọtụtụ akwụkwọ ozi ime ka ụjọ tụọ m.
\c 7
\p 
\v 1 Mgbe e wuzichara mgbidi ahụ, na mgbe m guzobesịrị ibo nʼọnụ ụzọ ya niile nʼọnọdụ ha, họpụtakwa ndị ọbụ abụ na ndị nche, na ndị Livayị.
\v 2 Enyefere m ọrụ ilekọta Jerusalem nʼaka nwanne m nwoke bụ Hanani, ya na Hananaya onye bụ onyeisi ụlọ ukwu ahụ e wusiri ike, nʼihi na ọ bụ nwoke na-ekwu eziokwu, bụrụkwa onye na-atụ egwu Chineke karịa ọtụtụ ndị ọzọ.
\v 3 Agwara m ha, “Na-emeghenụ ọnụ ụzọ ama naanị mgbe chi bọziri nke ọma. Kpọchiekwa ha mgbe ndị nche ka nọ na nche. Họpụtakwanụ ndị bi na Jerusalem ka ha bụrụ ndị nche. Ụfọdụ ga-eche nʼebe a họpụtara ha, ụfọdụ ga-eche nʼakụkụ ụlọ nke aka ha.”
\s1 Ọnụọgụgụ ndị lọtara
\p 
\v 4 Nʼoge a obodo ahụ buru ibu dịkwa mbara, ma ndị bi nʼime ya dị ole na ole nʼọnụọgụgụ, ụlọ ndị dị nʼime ya bụkwa ihe ewugharịbeghị.
\v 5 Ya mere Chineke m tinyere ya nʼobi m ka m chịkọta ndị niile a na-asọpụrụ, ndị ọchịchị, na ndị niile bi nʼobodo, maka idebanye aha nʼakwụkwọ ezinaụlọ nʼezinaụlọ. Achọtara m ebe e depụtara usoro ndị mmadụ niile bụ ụzọ lọta Juda nʼoge gara aga. Nke a bụ ihe m chọpụtara edere nʼime ya:
\b
\li4 
\v 6 Ndị a bụ ndị obodo niile a na-achị achị, bụ ndị sitere na ndọta nʼagha nke Nebukadneza, eze Babilọn, onye dọtara ha nʼagha buru ha laa nʼala ọzọ. Ha lọghachitere na Jerusalem nakwa Juda, onye ọbụla nʼobodo nke aka ya.
\v 7 Ndịisi ha na Zerubabel soo, bụ Jeshua, Nehemaya, Azaraya, Raamaya, Nahamani, Mọdekai, Bilshan, Misperet, Bigvai, Nehum na Baana.
\b
\li4 Ihe ndepụta ọnụọgụgụ ndị ikom Izrel bụ nke a:
\li1 
\v 8 Ndị agbụrụ Parosh, puku abụọ, otu narị na iri asaa na abụọ (2,172),
\li1 
\v 9 nke Shefataya, narị atọ na iri asaa na abụọ (372),
\li1 
\v 10 nke Ara, narị isii na iri ise na abụọ (652),
\li1 
