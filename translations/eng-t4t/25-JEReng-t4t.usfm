\v 9 \w I|strong="H5414"\w* \w will|strong="H5414"\w* \add get rid of them\add*, \w with|strong="H3605"\w* \w the|strong="H3605"\w* result \w that|strong="H3605"\w* people \w in|strong="H4725"\w* \w every|strong="H3605"\w* \w nation|strong="H4467"\w* \w on|strong="H4725"\w* \w the|strong="H3605"\w* earth \w will|strong="H5414"\w* \w be|strong="H5414"\w* \w horrified|strong="H2113"\w*, \w and|strong="H8033"\w* \w will|strong="H5414"\w* hate \w them|strong="H5414"\w* \w because|strong="H3605"\w* \w they|strong="H8033"\w* \w are|strong="H8033"\w* \w evil|strong="H7451"\w* people. \w Wherever|strong="H3605"\w* \w I|strong="H5414"\w* \w scatter|strong="H5080"\w* \w them|strong="H5414"\w*, people \w will|strong="H5414"\w* \w make|strong="H5414"\w* fun \w of|strong="H4725"\w* \w them|strong="H5414"\w*, \w and|strong="H8033"\w* say \w that|strong="H3605"\w* \w they|strong="H8033"\w* \w are|strong="H8033"\w* disgraced, \w and|strong="H8033"\w* \w ridicule|strong="H4912"\w* \w them|strong="H5414"\w*, \w and|strong="H8033"\w* \w curse|strong="H7045"\w* \w them|strong="H5414"\w*.  
