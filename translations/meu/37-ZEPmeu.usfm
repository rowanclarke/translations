\id ZEP .01, Zephaniah 1, Motu, PNG, RTWP 12/92
\h SEFANIA
\toc1 SEFANIA
\toc2 SEFANIA
\mt1 SEFANIA
\c 1
\s1 Iehova ena badu dinana
\p 
\v 1 Iehova ena hereva Sefania enai e kau, Iosia Amon, Iuda pavapavana, ena nega ai. Hari Sefania na Kusi natuna; Kusi na Gedalia natuna, Gedalia na Amaria natuna, Amaria na Hesekia natuna.
\q1 
\v 2 Iehova na e tomu:
\q2 Ḡau iboudiai baina darodia oho vaitani
\q2 tanobada kopina amo.
\q1 
\v 3 Taunimanima bona uda ḡaudia baina darodia oho,
\q2 bona atai manudia bona davara gwarumedia danu.
\q1 Iehova na e tomu:
\q2 Kara dika taudia na baina tahodia dobi,
\q1 taunimanima iboudiai baina negedia daure,
\q2 tanobada kopina amo.
\q1 
\v 4 Lau ese imagu baina toia roro, Iuda ihadikana totona,
\q2 bona Ierusalem inoholaina taudia iboudiai ihadikadia totona.
\q1 Ina gabu amo Baal oreana kwabukwabudia baina negedia daure,
\q2 bona kaivakuku edia hahelaḡa taudia ladadia baina rohodia:
\q1 
\v 5 ruma guhidia ai e igo dihomu guba hisiudia e toma henidia dihomu taudia,
\q2 bona e igo dihomu Iehova ladana ai e gwau hamatamu a Milkom ladana ai danu e gwau hamatamu taudia,\f + \fr 1:5 \ft Kanaan taudia gunadia edia dirava ladadia e hato “Baal”; Asuria taudia ese guba hisiudia e toma henidia diho; Amono taudia edia dirava badana ladana na Milkom.\f*
\q1 
\v 6 bona Iehova igavana amo vada e raka muri,
\q2 Iehova asie tahuamu bona enai asie henanadaimu, taudia.
\b
\q1 
\v 7 Ḡaubada Iehova vairanai asi reḡereḡemui ba noho;
\q2 badina be Iehova ena dina vada eme kahikahi.
\q1 Iehova ese boubou ḡauna vada e hahegaegaea,
\q2 bona e vavea taudia na vada e hahelaḡadia.
\q1 
\v 8 Iehova ese ena boubou ḡauna baine hahelaḡaia dinana ai,
\q2 lau ese heitatao taudia bona hanua pavapavana natuna mamaruanedia baina hadava henidia,
\q2 bona idau bese dabuadia e hahedokilaimu taudia iboudiai danu.
\q1 
\v 9 Una dina ai ruma raka-vareaina e rohoa hanaimu taudia iboudiai,
\q2 bona biagudia edia ruma na daḡedaḡe bona koikoi karadia ai e hahonudiamu taudia iboudiai,
\q2 baina hadava henidia.
\b
\q1 
\v 10 Iehova na e tomu: Una dina ai
\q2 taitai na Gwarume Ikoukouna amo baine dae,
\q1 bona tai lolololo na Hanua Matamatana amo,
\q2 bona rege badana na ororo amo.
\q1 
\v 11 Raro-kaka kourana inoholaina taumui e, a tai lolololo!
\q2 Badina be hoihoi taudia iboudiai na lasihidia;
\q2 \it silver\it* e hahetohoamu taudia iboudiai vada eme henege daure.
\q1 
\v 12 Una negana ai lau ese lamepa baina abi kau,
\q2 Ierusalem ai baina hetahu;
\q1 bena noho-herekwa taudia,
\q2 lalodia ai e tomu
\q1 “Iehova basine hahenamo bona basine hahedika” taudia,
\q2 baina hadava henidia.
\q1 
\v 13 Edia kohu na haida ese bae dadi oho,
\q2 edia ruma na haida ese bae ḡiḡi dobi.
\q1 Ena be ruma bae haginidia,
\q2 to basie noholaidia;
\q1 ena be vine imeadia bae hadodia,
\q2 to anidia ranudia basie inu.
\b
\q1 
\v 14 Iehova ena dina badana vada eme kahikahi,
\q2 e kahira-kahiramu, e mai haraḡamu;
\q1 Iehova ena dina reḡena mamina na idita,
\q2 una dina ai goada-herea tauna baine tai lolololo.
\q1 
\v 15 Una dina na badu dinana,
\q2 hisihisi bona lalo-hekwarahi dinana,
\q1 hahevahu bona hahebua-tari dinana,
\q2 dibura bona ḡabora dinana,
\q1 dagadaga bona dibura masemase dinana,
\q2 
\v 16 kibi reḡena bona hone dinana,
\q1 hanua mai maḡudia bona kohoro ḡaulatalatadia
\q2 ihadikadia dinana.
\b
\q1 
\v 17 Lau ese hisihisi baina mailaia taunimanima latadiai,
\q2 bena bae raka, mata-kepulu taudia na heheto,
\q2 badina be Iehova vada e kara dika henia.
\q1 Raradia bae hebubu nege ḡahu na heto,
\q2 bona hidiodia boromakau taḡena na heto.
\q1 
\v 18 Edia \it silver\it* eiava edia \it gold\it* ese basie hamauridia diba,
\q2 Iehova ena badu dinana ai.
\q1 Ena badu ḡaraḡarana lahina ai,
\q2 tanobada idoinai baine ara oho;
\q1 badina be ia ese tanobada inoholaina taudia iboudiai
\q2 baine ha-oredia taku, baine ha-oredia vaitani
\c 2
\s1 Bese idau-idau ihabua-taridia
\q1 
\v 1 Asi hemarai dibana besena e!
\q2 A hegogo, emui hebou ta bavabia,
\q1 
\v 2 do basie odamui oho
\q2 lai ese uit momona e odaia ohomu na heto
\q1 bona Iehova ena badu ḡaraḡarana na
\q2 latamui ai do basine diho negana ai,
\q1 Iehova ena badu dinana na
\q2 emui ai do basine kau negana ai.
\q1 
\v 3 Umui tano taumui mai manaumui ida,
\q2 ena haheḡani o badinadiamu taumui,
\q2 Iehova ba tahua!
\q1 Kara maoromaoro ba tahua, Ialo-manau ba tahua;
\q2 bena reana ba hehuni diba, Iehova ena badu dinana ai.
\q1 
\v 4 Badina be Gasa baine ḡaḡae,
\q2 bona Askelono baine vahu;
\q1 Asdod taudia na dina tubua ai bae luludia lasi,
\q2 bona Ekron baine heraḡa oho.
\b
\q1 
\v 5 Kone taumui e, Kerete besena e,
\q2 madi, ihabaimui!
\q1 Kanaan e, Filistia tanona e,
\q2 Iehova ena hereva na latamu ai;
\q1 lau ese do baina habuamu tari,
\q2 ela bona inoholaimu tauna ta basine noho.
\q1 
\v 6 Oi danu, kone tanona e,
\q2 rei gabudia ai do ba hahelao:
\q1 mamoe ireḡudia taudia edia rei gabudia,
\q2 bona mamoe seridia edia maḡu.
\q1 
\v 7 Kone tanona na Iuda besena kwabukwabudia ese bae ḡaunaia,
\q2 unuseni ai edia mamoe bae ubudia.
\q1 Hanuaboi bae hekure,
\q2 Askelono rumadia ai.
\q1 Badina be Iehova, edia Dirava, ese baine lalodia,
\q2 bona baine hanamodia lou.
\b
\q1 
\v 8 Moab taudia edia hegonaḡonalai
\q2 bona Amono taudia edia heihi-ihirai
\q2 vada na kamonai.
\q1 Idia ese egu bese taudia vada e gonagonalaidia,
\q2 bona edia tano iabi-ohona vada e herevalaia mai hekokorokudia ida.
\q1 
\v 9 Iehova Sabaota, Israel Diravana, na e tomu:
\q2 Taunabunai, lau na maurimu heḡereḡerena
\q1 Moab na Sodoma heḡereḡerena ai bainela,
\q2 bona Amono taudia na Gomora heḡereḡerena ai bae hahelao,
\q1 ava ḡiniḡini bona laguta tanodia ai baela,
\q2 bae vahu ela bona hanaihanai.
\q1 Egu orea taudia kwabukwabudia ese bae dadihaidia;
\q2 egu bese taudia kwabukwabudia ese bae ḡaunaidia.
\q1 
\v 10 Ahudia unu bae heto, edia hekokoroku davana;
\q2 badina be idia ese Iehova Sabaota ena orea taudia na
\q2 e kirikirilaidiava bona latadiai e heaḡiva.
\q1 
\v 11 Iehova ese baine daḡedaḡe henidia;
\q2 oibe, ia ese tanobada diravadia iboudiai baine hahitolodia;
\q1 bena bese idau-idau edia basileia iboudiai ese
\q2 ia bae toma henia diho,
\q2 ta ta ena gabu ena gabu ai.
\b
\q1 
\v 12 Etiopia taumui e, umui danu;
\q2 egu dare ese baine alamui mamase.
\b
\q1 
\v 13 Bena ia ese imana na mirigini kahana baine toi roro henia,
\q2 Asuria baine habuaia tari;
\q1 Nineve danu baine havahua,
\q2 gabu kaukauna ai baine halaoa, tano ḡaḡaena na heto.
\q1 
\v 14 Nani seridia na ia bogaraginai bae hekure,
\q2 bona uda boromadia idau-idau iboudiai danu;
\q1 bogibada bona migu na
\q2 ena au-tubua lalodiai bae noho;
\q1 baimumu na ena gaba-mauru ai baine mu,
\q2 bona mukou danu ena raka-vareaina ai;
\q2 badina be ena sida audia igovalaidia bae hekoki oho.
\q1 
\v 15 Hekokoroku hanuana binai,
\q2 e nohova mai namona ida;
\q1 sibona e tomava
\q2 “Lau o ina, idauna ta na lasi”.
\q1 Madi, vada e vahu vaitani,
\q2 uda boromadia edia gabu ai vada e hahelao.
\q1 E rakaia hanaimu taudia iboudiai ese
\q2 e si heniamu bona imadia e kahu kuboro-kuboro heniamu.
\c 3
\s1 Ierusalem ihanamo-louna
\q1 
\v 1 Gwau-edeede hanuana, vada e miro hanuana,
\q2 daḡedaḡe hanuana, madi ihabaina!
\q1 
\v 2 Gado ta se kamonaimu,
\q2 sisiba ta se abia daemu,
\q1 Iehova se abidadama heniamu,
\q2 ena Dirava se raka henia kahimu.
\b
\q1 
\v 3 Ena heitatao taudia ia lalonai na
\q2 e ḡoumu leonadia na heheto;
\q1 ena hahemaoro taudia na tano-ḡaḡaena uda-sisiadia,
\q2 ḡau ta basine mia rani.
\q1 
\v 4 Ena peroveta taudia na e gwau edeedemu,
\q2 idia na asi edia heabidadama;
\q1 ena hahelaḡa taudia ese helaḡa ḡaudia e hamirodiamu,
\q2 idia ese taravatu e daḡedaḡe heniamu.
\q1 
\v 5 Ia lalonai Iehova na e kara maoromaoromu,
\q2 kara kerere ta ia ese se karaiamu.
\q1 Daba iboudiai ia ese ena hehamaoro ḡoevaḡoeva e hahedinaraiamu,
\q2 daba matadia ta ta ai ia na se helalo reamu;
\q2 a kara gageva-gageva tauna na asi hemarai dibana.
\b
\q1 
\v 6 Bese idau-idau vada na negedia daure,
\q2 edia maḡu vada eme heḡiḡi dobi;
\q1 edia ariara vada na havahudia,
\q2 bena ta ese se raka-rakalaidiamu;
\q1 edia hanua iboudiai vada e hahevahu,
\q2 asi tauna ta lalodiai; ta ese se noholaidiamu.
\q1 
\v 7 Lau nato “Momokani, ia ese baine gari henigu,
\q2 sisiba baine abia dae;
\q1 lau ese vada na hadibadibalaidia ḡaudia iboudiai na
\q2 ia ese basine lalodia nege”;
\q1 a idia na lalodia e ura dikadikamu
\q2 lebulebu karadia mo bae kara e tomu.
\b
\q1 
\v 8 Iehova na e tomu:
\q2 Taunabunai, lau ba narigu;
\q1 lau baina tore isi, baina hereva hedinarai,
\q2 dinana ba nana.
\q1 badina be lalogu vada na hadaia, bese idau-idau baina gogodia,
\q2 basileia idau-idau danu baina haboudia,
\q1 egu badu na idia latadiai baina bubua dobi totona,
\q2 egu badu ḡaraḡarana idoinai.
\q1 Badina be egu vaḡeḡe baduna lahina ai
\q2 tanobada idoinai baine heara oho.
\b
\q1 
\v 9 Oibe, una negana ai bese idau-idau gadodia baina ha-idaudia,
\q2 gado ḡoeva-daena ai baina halaodia;
\q1 bena idia iboudiai ese Iehova ladana bae hahanea,
\q2 bona ia isiaina bae lao heni mai lalodia tamona ida.
\q1 
\v 10 Etiopia sinavaidia unukahadia amo,
\q2 ela bona gabu daudaudia mirigini kahana ai,
\q2 idia ese herahia ḡaudia na lauegu bae mailai.
\b
\q1 
\v 11 Una dina ai ta ese basine hahemaraimu,
\q2 o daḡedaḡe henigu karadia daidiai;
\q1 badina be una negana ai emu hetataro taudia na
\q2 bogaragimu amo baina abidia oho.
\q1 Bena oi na basio hekokoroku lou,
\q2 egu ororo helaḡana ai.
\q1 
\v 12 Badina be bogaragimu ai bese ta baina hanohoa,
\q2 lalo-manau bona lalo-manada besena.
\q1 Idia ese edia roho-mauri gabuna bae tahua,
\q2 Iehova ladana ai.
\q1 
\v 13 Unu na Israel kwabukwabudia:
\q2 kara dikana ta basie karaia,
\q2 hereva koikoina ta basie gwauraia;
\q1 bona ududia amo
\q2 hereva koikoi basie lasi.
\q1 Badina be idia na bae aniani, bae hekure nege,
\q2 bona ta ese basine hagaridia.
\b
\q1 
\v 14 Siona kekenimu e, ane avabia badabada!
\q2 Israel e, a lolo!
\q1 Ierusalem kekenimu e,
\q2 ba moale, ba heimodai, mai lalomu idoinai!
\q1 
\v 15 Iehova ese ena hahemaoro herevadia na oi latamu amo vada e abia oho;
\q2 ia ese oi inaimu vada e tahodia lasi.
\q1 Iehova, Israel pavapavana, na bogaragimu ai;
\q2 dika garina basio gari lou.
\q1 
\v 16 Una dina ai Ierusalem bae hereva henia, baeto:
\q2 Siona e, basio gari;
\q2 imamu ba ha-aukadia, basio manoka.
\q1 
\v 17 Iehova, emu Dirava, na bogaragimu ai,
\q2 ia na tuari lohiana, kwalimu e henimu;
\q1 ia ese baine moalelaimu mai moale-badana ida,
\q2 ena lalokau ai ia ese baine hamatamatamu;
\q1 ia ese baine heaḡilaimu mai ane lolona ida,
\q2 
\v 18 aria dinana ai na heto.
\q1 Hahedika na oiemu amo baina abia oho,
\q2 una hahedika gwauna basio huaia helaoreana.
\q1 
\v 19 A itaia, una negana ai e daḡedaḡe henimumu taudia iboudiai na
\q2 lau ese davadia baina henidia.
\q1 Ae-hedairike taudia na baina hamauridia,
\q2 bona e hakarohodia taudia na ma baina haboudia;
\q1 edia hemarai na heimodai ai bona hari namo ai baina halaoa,
\q2 tanobada idoinai latanai.
\q1 
\v 20 Una negana ai lau ese emui gabu korikori ai baina hakaumui vareai,
\q2 emui noho ihanamo-louna na matamui amo ba itaia negana ai.
\q1 Oibe, harimui baina habadaia, bona i'imodaimui danu,
\q2 tanobada besedia iboudiai bogaragidiai,
\q1 emui noho ma baina hanamoa lou negana ai.
\q2 Iehova na unu e gwau tomamu. 
