\id HOS  
\h عَننَبِ هٌسٍ 
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ هٌسٍ بّ 
\toc2 عَننَبِ هٌسٍ 
\toc3 هٌس 
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ هٌسٍ بّ 
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ 
\ip عَلَتَلَ نَشَ مَسٍنيِ شْرْشْي تِ عِسِرَيِلَكَيٍ بّ عَننَبِ هٌسٍ سَابُي رَ. عَلَ نُ بَرَ عِسِرَيِلَ سُفَندِ عَ شَ قِندِ عَ شَ حَمَ رَ، عَ شَ لُ عَ شَ نِينِ بُن مَ، عَ شَ لُ عَ شَ يَامَرِ بُن مَ. كْنْ عِسِرَيِلَ مُ تِن نَ رَ. عٍ نَشَ بِرَ عَلَ فبّتّيٍ قْشْ رَ، عٍ قِندِ كُيٍ بَتُي رَ. عَلَ نَشَ شْنْ عٍ مَ عَ حَاشِ رَ، هَن عَ نَتّ تٌنفٌ عَ شَ عٍ لُ كَاقِرِ سَفٌي، عٍ شَ لُ كٌنيِيَ كُي. 
\ip عَننَبِ هٌسٍ نَ مَسٍن نّ عِسِرَيِلَ بّ مِسَالِ ندٍ رَ نَشَن نْمَ قِندِدٍ تّرّننَ رَ وٌن بّ. عَ نَشَ عِسِرَيِلَ شَ وَلِ مَنِيَ لَنفٌيحَ رَ، عَ نَشَن نَبَمَ عَ شَ مْرِ رَ نَشَن نُ بَرَ عَ دْشْ سّرِيّ كِ مَ. عَ نَشّ لَنفٌي فِنّ نَشَن مّيمَ عَ شَ مْرِ قَنيِ رَ، نَشَن بَرَ قٍ قَنيِ مْولِ بِرِن نَبَ عَ بّ عَلَكٌ قُتِ شَ سَبَتِ، نَ فِنّ مْولِ بَرَ قِنسِرِوَلِيَ حَاشِ رَبَ. عِسِرَيِلَ عَ نَ مْولِ رَبَ نّ عَلَ رَ. عَلَ تٌ عٍ سُفَندِ، عَ نُ لَن نّ عٍ شَ لُ عَ سَفٌي، كْنْ عٍ مُ تِن نَ رَ. عٍ بِرَقٍ كُيٍ قْشْ رَ، نَ بَرَ لُ عَلْ يَنقَنتٍيَ لَنفٌي نَشَن نَبَمَ عَ شَ مْرِ قَنيِ رَ. 
\ip نَ بِرِن كُي، عَلَ نُ نْمَ شْنْدٍ عَ شَ حَمَ مَ عَ حَاشِ رَ، عَ قَ عٍ بِرِن سْنتْ عٍ شَ يُنُبِ شَ قٍ رَ. كْنْ يِ كِتَابُي وَ مَ عَ مَسٍنقٍ نّ، عَلَ شَ شَنُنتٍيَ فبٌ عَدَ مَ بّ هَلِ نَ قِندِ يُنُبِتْي رَ. عَلَ مُ تَفَنمَ كِرَ قَنيِ مَسٍنقٍ يُنُبِتْي بّ عَلَكٌ عَ مَن شَ فبِلٍن عَلَ شَ نِينِ بُن مَ. عَ قٍ بِرِن نَبَمَ نّ عَلَكٌ عَدَ مَ شَ كِسِ، عَ شَ لُ كِرَ قَنيِ شْن مَ. 
\ip عَلَ لَايِدِ نَشَن تٌنفٌ عِسِرَيِلَ بّ، عَ شَ عٍ رَفبِلٍن عٍ شَ وَلِ كٌبِ قْشْ رَ، عَ نَ لَايِدِ تٌنفٌمَ نّ وٌن قَن بّ. عَلَ وَ مَ وٌن نَمِنِقٍ سٍنتَنّ شَ يَامَرِ بُن مَ، عَ وَ مَ نّ وٌن شَ لُ عَ شَ دٍنبَيَ كُي كِسِ نُن هّيرِ نَ دّننَشّ. عَلَ شَ وٌن مَلِ تِنقٍ نَ رَ. عَمِنَ. 
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ هٌسٍ بّ 
\c 1  
\s1 عَننَبِ هٌسٍ شَ دٍنبَيَ 
\p  
\v 1 عَلَتَلَ نَشَ مَسٍنيِ تِ بٍيرِ شَ دِ هٌسٍ بّ، يُسِيَ، يٌتَمِ، عَشَسِ، نُن شٍسٍكِيَ مَنفّ شَ وَشَتِيٍ كُي يُدَيَ. يٍرٌبٌوَ مِ نَن نُ نَ عِسِرَيِلَ مَنفّ رَ. 
\p  
\v 2 عَلَتَلَ شَ مَسٍنيِ نَن يَ عَننَبِ هٌسٍ بّ؛ عَلَتَلَ نَشَ عَ قَلَ عَننَبِ هٌسٍ بّ، «سِفَ، عِ سَ لَنفٌي فِنّ ندٍ تٌنفٌ، عَ مَن شَ دِيٍ بَرِ عِ بّ، بَرِ مَ بٍكَيٍ لَنفٌيحَ نَن نَبَمَ عَلَتَلَ رَبّحِنقٍ كُي!»  
\v 3 هٌسٍ نَشَ سِفَ، عَ سَ فٌمٍرِ تٌنفٌ، دِبِلَيِمِ شَ دِ فِنّ. نَ نَشَ تّيفّ، عَ دِ بَرِ عَ بّ.  
\v 4 عَلَتَلَ نَشَ عَ مَسٍن هٌسٍ بّ، «عِ شَ عَ شِلِ سَ يِسِرٍيلِ، عَ فبٍ مُ لُشِ ﭑ شَ يٍهُ شَ دٍنبَيَ حَشَنكَتَ، بَرِ مَ عٍ قَشّ تِ نّ يِسِرٍيلِ. ﭑ عِسِرَيِلَ شَ مَنفّيَ حْنمَ نَ كِ نّ.  
\v 5 نَ لْشْي ﭑ عِسِرَيِلَ شَ فٍرٍ سٌي سّنبّ كَنَمَ نّ يِسِرٍيلِ تَا كُي.» 
\p  
\v 6 فٌمٍرِ مَن نَشَ تّيفّ، عَ دِ فِنّ بَرِ. عَلَتَلَ نَشَ عَ مَسٍن هٌسٍ بّ، «عَ شِلِ سَ ‹مِشِ شْنشِ،› بَرِ مَ ﭑ مُ كِنِكِنِمَ عِسِرَيِلَ مَ، ﭑ مُ عَ شَ يُنُبِ شَقَرِ مَ سْنْن.  
\v 7 كْنْ ﭑ كِنِكِنِمَ نّ يُدَيَ تَن مَ، ﭑ قَ عَ رَكِسِ عَ مَرِفِ عَلَتَلَ سّنبّ رَ. ﭑ مُ عٍ رَكِسِمَ تَنبّ رَ، شَ نَ مُ عَ رَ سَنتِدّفّمَ رَ، فٍرٍ رَ، سٌييٍ رَ، نُن سٌي رَفِيٍ رَ.» 
\p  
\v 8 فٌمٍرِ تٌ «مِشِ شْنشِ» دّ بَ، عَ مَن نَشَ تّيفّ، عَ دِ بَرِ عَ شَ مْرِ هٌسٍ بّ.  
\v 9 عَلَتَلَ نَشَ عَ مَسٍن، «عِ شَ عَ شِلِ سَ ‹ﭑ فبٍ مُ عَ رَ،› بَرِ مَ ﭑ مَ حَمَ مُ وٌ رَ سْنْن، وٌ مَرِفِ مُ ﭑ نَ سْنْن.» 
\c 2  
\s1 عِسِرَيِلَ فبِلٍنقٍ عَلَ مَ 
\q1  
\v 1 عِسِرَيِلَكَيٍ قَمَ نّ وُيَدٍ 
\q1 عَلْ بَا دّ رَ مّيّنيِ، 
\q1 نَشَن مُ نْمَ مَنِيَدٍ، 
\q1 نَشَن مُ نْمَ كْنتِدٍ. 
\q1 سِنفٍ رَ، عَ نُ عَ قَلَمَ عٍ بّ دّننَشّ، 
\q1 «ﭑ مَ حَمَ مُ وٌ رَ،» 
\q1 عَ عَ قَلَمَ نّ عٍ بّ، 
\q1 «عَلَ حِحّ شَ دِيٍ.» 
\q1  
\v 2 يُدَ بْنسْييٍ نُن عِسِرَيِلَ بْنسْييٍ مَلَنمَ نّ، 
\q1 عٍ مَنفّ كٍرٍن سُفَندِ عٍ بِرِن بّ. 
\q1 نَ لْشْي شُنفبٍ عَلَ عٍ رَ مِنِمَ نّ كٌنيِيَ كُي، 
\q1 عَ عٍ رَ سَبَتِ عٍ شْنيِ. 
\b  
\q1  
\v 3 «وٌ شَ عَ قَلَ وٌ تَارَيٍ شَ قٍ رَ، ‹عَلَ شَ حَمَ.› 
\q1 وٌ شَ عَ قَلَ وٌ شُنيَيٍ شَ قٍ رَ، ‹عَلَ شَنُنتٍنيِيٍ.› 
\q1  
\v 4 وٌ شَ وٌ نفَ عِسِرَيِلَ كَلَمُ، 
\q1 بَرِ مَ ﭑ مَ فِنّ مُ عَ رَ، 
\q1 عَ شَ مْرِ مُ ﭑ قَن نَ! 
\q1 عَ شَ عَ شَ لَنفٌيحَ مَشِرِ سٍيٍ بَ عَ يَتَفِ مَ، 
\q1 عَ عَ شَ حّنفّيَ مَشِرِ سٍيٍ بَ عَ شِحّيٍ تَفِ. 
\q1  
\v 5 شَ نَ مُ عَ رَ، ﭑ عِسِرَيِلَ لُمَ عَ رَفٍلِ نَن نَ، 
\q1 عَلْ عَ نُ كِ نَشّ عَ بَرِ لْشْي. 
\q1 ﭑ عٍ شَ بْشِ مَقِندِ مَ نّ فبٍنفبٍرٍنيِ رَ، 
\q1  
\v 6 عَ قِندِ مَ يِرٍ مَشَرٍ نَن نَ. 
\q1 ﭑ عٍ قَشَمَ يٍ شْلِ نَن نَ. 
\q1 ﭑ مُ كِنِكِنِمَ عَ شَ دِيٍ مَ، 
\q1 بَرِ مَ لَنفٌي دِ نَن عٍ رَ. 
\q1  
\v 7 عٍ نفَ عٍ سْتْ لَنفٌيحَ نَن كُي. 
\q1 نَ بَرَ قِندِ يَافِ رَ عٍ بّ. 
\q1 عَ نَشَ عَ قَلَ، ‹ﭑ بِرَ مَ نّ ﭑ حّنفّيٍ قْشْ رَ، 
\q1 نَشٍيٍ دٌنسٍ نُن يٍ سٌمَ ﭑ يِ، 
\q1 نَشٍيٍ دُفِ قِمَ ﭑ مَ، 
\q1 نَشٍيٍ ﭑ كِمَ تُرٍ نُن مِنسٍ رَ.› 
\q1  
\v 8 ﭑ عِ شَ كِرَ قِندِ مَ تُنبٍ كُنسِ رَ نَ نَن مَ، 
\q1 ﭑ عِ رَبِلِن تّتّ رَ، عَلَكٌ عِ نَشَ كِرَ تٌ. 
\q1  
\v 9 عَ سِفَمَ عَ حّنفّيٍ قْشْ رَ، 
\q1 كْنْ عَ مُ عٍ مَسْتْمَ. 
\q1 عَ عٍ قٍنمَ، كْنْ عَ مُ عٍ تٌمَ. 
\q1 عَ عَ قَلَمَ نّ، ‹ﭑ شَ فبِلٍن ﭑ مَ مْرِ شْن، 
\q1 بَرِ مَ حّلّشِنيِ نُ نَ ﭑ بّ مّننِ دَنفِ يَكْسِ رَ.› 
\q1  
\v 10 عَ مُ عَ كٌلٌن قَ قَلَ ﭑ تَن نَن نُ بَلٌي سٌمَ عَ يِ، 
\q1 مّنفِ، تُرٍ، نُن مِنسٍ. 
\q1 ﭑ تَن نَن نُ فبٍتِ نُن شّيمَ قَن سٌمَ عَ يِ، 
\q1 كْنْ عَ نَشَ نَ بِرِن نَوَلِ بَلِ كُيٍ بّ. 
\q1  
\v 11 نَ نَن عَ تٌ ﭑ مَ مّنفِ نَ مْ، ﭑ عَ بَمَ عَ يِ. 
\q1 وّنِ بٌفِ بُندُ تّمُي، ﭑ نَ قَن بَمَ عَ يِ. 
\q1 شُرُ سٍ شَبٍ شَبَ تّمُي، ﭑ مُ تِنمَ عٍ شَ سٍ سْتْ، 
\q1 نَشَن نْمَ قِندِدٍ عٍ شَ دُفِيٍ رَ. 
\q1  
\v 12 يَكْسِ ﭑ شَ عَ رَيَافِ عَ حّنفّيٍ يَ شْرِ، 
\q1 عَلَكٌ مِشِ يٌ نَشَ عَ بَ ﭑ يِ رَ. 
\q1  
\v 13 ﭑ حّلّشِنيِ بِرِن بَمَ نّ عٍ يِ، 
\q1 عَلْ عٍ شَ مَلَبُي لْشْي سَلِ، 
\q1 عٍ شَ كِكٍ نّينّ سَلِ، 
\q1 عَ نُن عٍ شَ سَلِ بِرِن. 
\q1  
\v 14 ﭑ شَ عٍ شَ وّنِ بِلِيٍ، نُن عٍ شَ شْرّ بِلِيٍ كَنَ. 
\q1 عٍ نَشّ عَ نَ قِندِشِ عٍ شَ لَنفٌيحَ سَرٍ نَن نَ. 
\q1 ﭑ نَ سَنسِ بِرِن كَنَمَ نّ، 
\q1 عَ شَ قِندِ وُلَ رَ سُبٍيٍ سَبَتِمَ دّننَشّ. 
\q1  
\v 15 ﭑ عِسِرَيِلَ حَشَنكَتَمَ نّ، 
\q1 بَرِ مَ عَ سّرّشّ بَمَ بَلِ كُيٍ بّ، 
\q1 عَ لُ عَلْ لَنفٌي نَشَن عَ يّتّ مَشِرِ مَ دُفِ قَنيِ رَ، 
\q1 عَ بِرَ عَ حّنفّ قْشْ رَ. 
\q1 نَ كُي عَ نَشَ نّيمُ ﭑ تَن مَ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\b  
\q1  
\v 16 «ﭑ عَ شَنِنمَ فبٍنفبٍرٍنيِ مَ نَ نَن مَ، 
\q1 ﭑ قَ وْيّنيِ حْشُنمّ قَلَ عَ بّ. 
\q1  
\v 17 عَ نَ كٍلِ مّننِ، ﭑ مَن وُرِ بٌفِلَيٍ قِ عَ مَ. 
\q1 عَكٌرِ فُلُنبَ قِندِ مَ نّ شَشِلِسَ رَ عَ بّ، 
\q1 عَ قَ سِفِ سَ عَلْ عَ قٌنِكٍ تّمُي 
\q1 عَلْ عَ مِنِ لْشْي مِسِرَ بْشِ رَ.» 
\b  
\q1  
\v 18 عَلَتَلَ شَ مَسٍنيِ نَن يَ، 
\q1 «نَ لْشْي عِ ﭑ شِلِمَ نّ ‹ﭑ مَ مْرِ.› 
\q1 عِ مُ ﭑ شِلِمَ ‹ﭑ كَنيِ› سْنْن. 
\q1  
\v 19 ﭑ بَلِ كُيٍ شِلِيٍ بَمَ نّ عِ دّ عِ، 
\q1 عَلَكٌ عِ شَ نّيمُ عٍ مَ. 
\q1  
\v 20 نَ لْشْي ﭑ سَاتّ تٌنفٌمَ نّ عٍ بّ، 
\q1 نُن وُلَءِ سُبٍيٍ، شْنِيٍ، عَ نُن بُبُسٍيٍ رَ. 
\q1 ﭑ شَلِ، سَنتِدّفّمَ، نُن فٍرٍ بَمَ نّ عٍ شَ بْشِ مَ، 
\q1 عَلَكٌ عٍ شَ سَبَتِ نَا بْحّسَ كُي. 
\q1  
\v 21 ﭑ عِ قِندِ مَ ﭑ مَ فِنّ نَن نَ 
\q1 تِنشِنيِ، دُفُتّفّحَ، نُن هِننّ كُي. 
\q1 ﭑ مُ مّيمَ عِ رَ عَبَدَن. 
\q1  
\v 22 لَنلَنتٍيَ لُمَ نّ وٌن تَفِ، 
\q1 عِ قَ عَلَتَلَ كٌلٌن.» 
\b  
\q1  
\v 23 عَلَتَلَ شَ مَسٍنيِ نَن يَ. 
\q1 «نَ لْشْي، ﭑ عِ شَ دُبّ سُشُمَ نّ. 
\q1  
\v 24 كٌورٍ تُنّ يٍ رَفٌرٌ مَ نّ بْشِ مَ. 
\q1 بْشِ بَلٌي رَ مِنِمَ نّ وٌ بّ. 
\q1 سَنسِيٍ وّنِ نُن تُرٍ قِمَ نّ وٌ مَ. 
\q1 يِسِرٍيلِ هَيِ بِرِن قَنمَ نّ. 
\q1  
\v 25 ﭑ عِسِرَيِلَ رَ سَبَتِمَ نّ نَ بْشِ مَ ﭑ يّتّ بّ. 
\q1 ﭑ نُ نَشَن مَ ‹مِشِ شْنشِ،› 
\q1 ﭑ كِنِكِنِمَ نّ عَ مَ. 
\q1 ﭑ نُ نَشَن مَ، ‹ﭑ مَ حَمَ مُ عَ رَ،› 
\q1 ﭑ عَ شِلِمَ نّ، ‹ﭑ مَ حَمَ.› 
\q1 عٍ قَن قَمَ ﭑ تَن نَن شِلِدٍ، ‹ﭑ مَرِفِ عَلَ.›» 
\c 3  
\s1 عَلَ شَ شَنُنتٍيَ عِسِرَيِلَ بّ 
\p  
\v 1 عَلَتَلَ نَشَ عَ مَسٍن ﭑ بّ، «عِ مَن شَ عِ شَ فِنّ شَنُ، هَلِ عَ تٌ يّنّ رَبَمَ عَ نُن عَ حّنفّيٍ رَ. نَ لُمَ نّ عَلْ عَلَتَلَ شَ شَنُنتٍيَ عِسِرَيِلَكَيٍ بّ، عٍ تَن نَشٍيٍ بِرَ مَ عَلَ فبّتّيٍ قْشْ رَ، عٍ نُ سّرّشّ بَ عٍ بّ.»  
\v 2 ﭑ نَشَ فبِلٍن نَ فِنّ شَ كٌتٍ دْشْ رَ فبٍتِ كٌلٍ قُ نُن سُولِ رَ، نُن مّنفِ بُسَلِ كٍرٍن نُن عَ تَفِ.  
\v 3 ﭑ نَشَ عَ قَلَ عَ بّ، «عِ شَ عِ رَشَرَ ﭑ شْنيِ. عِ نَشَ لَنفٌيحَ رَبَ سْنْن، عِ نَشَ شّمّ فبّتّ يٌ كٌلٌن قَ. ﭑ قَن لُمَ عِ بّ نَ كِ نّ.» 
\p  
\v 4 وَشَتِ شْننَكُيٍ كُي، عِسِرَيِلَ قَمَ نّ لُدٍ مَنفّ مُ نَ، يَرٍرَتِيٍ، سّرّشّيٍ، كُيٍيٍ، نُن عَلَ مَشْرِن سٍ شَنبِ.  
\v 5 نَ دَنفِ شَنبِ، عِسِرَيِلَكَيٍ فبِلٍنمَ نّ، عٍ قَ عٍ مَرِفِ عَلَتَلَ قٍن، عَ نُن عٍ شَ مَنفّ دَوُدَ. نَ تّمُي، عٍ قَمَ نّ فَاشُدٍ عَلَتَلَ يَ رَ، عٍ مَن لُ عَ شَ هِننّ بُن مَ تّمُي بِرِن. 
\c 4  
\s1 عِسِرَيِلَ شَ تِنشِنتَرٍيَ 
\q1  
\v 1 عِسِرَيِلَكَيٍ، وٌ عَلَتَلَ شَ وْيّنيِ رَ مّ، 
\q1 بَرِ مَ كِيتِ نَ وٌ نُن عَلَتَلَ تَفِ. 
\q1 «نْندِ نُن هِننّ بَرَ حْن وٌ يَ مَ. 
\q1 وٌ مُ ﭑ كٌلٌنشِ عَلَ رَ وٌ شْنيِ سْنْن. 
\q1  
\v 2 دَنكّ مَتِقٍ، وُلٍ، قَشّ تِ، مُحّ، لَنفٌيحَ 
\q1 نَن فبَنسَن فبٌشِ وٌ يِ رَ. 
\q1 قَشّ تِمَ تّمُي بِرِن. 
\q1  
\v 3 وٌ شَ بْشِ قَمَ لُدٍ سُننُنيِ كُي نَ نَن مَ. 
\q1 نَشٍيٍ بِرِن سَبَتِشِ عَ مَ، 
\q1 عٍ قَشَمَ نّ عٍ نُن سُبٍيٍ، شْنِيٍ، نُن يّشّيٍ رَ. 
\q1 عٍ بِرِن قَشَمَ نّ.» 
\b  
\q1  
\v 4 «كْنْ مِشِ يٌ نَشَ كَلَمُي تِ، 
\q1 مِشِ يٌ نَشَ حَمَ رَكِيتِ. 
\q1 وٌ شَ حَمَ نَن وٌ تَن سّرّشّدُبّيٍ كَلَمُمَ. 
\q1  
\v 5 وٌ بِرَ مَ نّ يَنيِ رَ، وٌ بِرَ كْي رَ. 
\q1 هَلِ نَمِحْنمّيٍ، عٍ تَنتَنمَ. 
\q1 ﭑ قَمَ وٌ نفَ عِسِرَيِلَ قَشَدٍ نَ نَن مَ. 
\q1  
\v 6 ﭑ مَ حَمَ نَ قَشَقٍ، عَ كٌلٌنتَرٍيَ مَ. 
\q1 وٌ تٌ بَرَ وٌ مَكُيَ ﭑ كٌلٌنقٍ رَ، 
\q1 ﭑ قَن بَرَ وٌ مَكُيَ ﭑ مَ سّرّشّدُبّحَ رَ. 
\q1 وٌ تٌ بَرَ وٌ مَرِفِ عَلَ شَ سّرِيّ رَبّحِن، 
\q1 ﭑ قَن بَرَ وٌ شَ دِيٍ رَبّحِن. 
\q1  
\v 7 سّرّشّدُبّيٍ وُيَشِ كِ نَشّ، 
\q1 عٍ شَ يُنُبِيٍ قَن وُيَشِ نَ كِ نّ. 
\q1 ﭑ عٍ شَ بِنيّ مَسَرَ مَ يَافِ رَ نَ نَن مَ. 
\q1  
\v 8 عٍ بَلٌمَ ﭑ مَ حَمَ شَ سّرّشّيٍ رَ. 
\q1 نَ كُي، عٍ مَن نٍيٍ رَدِن يّ يُنُبِ رَبَقٍ مَ 
\q1 عٍ تَن يّتّ نَشَن نَبَمَ، 
\q1 عَلَكٌ عٍ مَن شَ سّرّشّ فبّتّيٍ سْتْ. 
\q1  
\v 9 حَمَ يٌ، سّرّشّدُبّيٍ يٌ، 
\q1 ﭑ عٍ بِرِن حَشَنكَتَمَ نّ عٍ شَ يُنُبِيٍ شَ قٍ رَ، 
\q1 ﭑ عٍ سَرٍ رَفبِلٍنمَ نّ عٍ مَ.» 
\b  
\q1  
\v 10 «عٍ عٍ دّفٍمَ نّ، كْنْ عٍ مُ قَمَ لُفَدٍ. 
\q1 عٍ كُيٍيٍ بَتُمَ نّ، كْنْ نٍيٍ مُ عٍ رَفٍينِمَ، 
\q1 بَرِ مَ عٍ بَرَ عَلَتَلَ رَبّحِن. 
\q1  
\v 11 عٍ لَنفٌيحَ رَبَمَ، 
\q1 عٍ بٍيرٍ مْولِ بِرِن مِنمَ. 
\q1 نَ نَن عٍ شَشِلِ كَنَشِ. 
\q1  
\v 12 ﭑ مَ حَمَ مَشْرِنيِ تِمَ كُيٍ مَ. 
\q1 عٍ يَابِ ندٍ سْتْمَ نَ وُرِ شُنتُنيِ رَ. 
\q1 لَنفٌيحَ رَبَقٍ بَرَ لُ عٍ بْحّ كُي. 
\q1 نَ بَرَ عٍ رَلْي، 
\q1 نَ بَرَ عٍ مَكُيَ عَلَ رَ. 
\q1  
\v 13 عٍ سّرّشّ بَمَ فٍيَيٍ قَرِ، 
\q1 مّننِ عٍ سُرَيِ قَن فَنمَ سّرّشّ رَ. 
\q1 عٍ نَ رَبَمَ وُرِ شُنفبٍيٍ بُن مَ، نِينِ فبٌ دّننَشّ. 
\q1 نَ كُي وٌ شَ دِ فِنّيٍ لَنفٌيحَ رَبَمَ، 
\q1 وٌ شَ مَمَدِيٍ قَن بَرَ قِندِ يّنّ رَبَيٍ رَ.» 
\b  
\q1  
\v 14 «ﭑ مُ قَمَ وٌ شَ دِ فِنّيٍ نُن وٌ شَ مَمَدِيٍ حَشَنكَتَدٍ عٍ شَ لَنفٌيحَ شَ قٍ رَ، 
\q1 بَرِ مَ وٌ تَن قَن حّنفّيٍ سُشُمَ. 
\q1 وٌ بِرِن سّرّشّ بَمَ كُيٍيٍ بّ. 
\q1 حَمَ شَشِلِتَرٍ لُمَ نَ فَنتَنيِ كُي. 
\q1  
\v 15 شَ عِسِرَيِلَ بَرَ بِرَ لَنفٌيحَ قْشْ رَ، 
\q1 وٌ تَن يُدَيَكَيٍ، وٌ نَشَ نَ مْولِ رَبَ. 
\q1 وٌ نَشَ سِفَ فِلِفَلِ، وٌ نَشَ تٍ بٍتِ عَوٍنِ. 
\q1 وٌ نَشَ وٌ كَلِ عَلَتَلَ شِلِ رَ مّننِ. 
\q1  
\v 16 شَ عِسِرَيِلَ لُمَ عَلْ نِنفٍ كَلَبَنتٍ، 
\q1 عَلَتَلَ مُ نْمَ عٍ رَبَلٌدٍ عَلْ يّشّي قَنيِيٍ، 
\q1 عٍ نَشٍيٍ دّ مَدٌنمَ قِيلِ شُنفبٍيٍ مَ. 
\q1  
\v 17 عٍقِرَ مِكَيٍ بَرَ كَنكَن كُيٍ مَ. 
\q1 وٌ شَ عٍ لُ نَ. 
\q1  
\v 18 عٍ شَ بٍيرٍ نَ حْن، عٍ شَ لَنفٌيحَ قَن تٌنفٌ. 
\q1 عٍ شَ مَنفّيٍ وَشِ يَافِ نَن تُن شْن مَ. 
\q1  
\v 19 قٌيٍ قَمَ عٍ رَ قَنَقَنَندٍ نَ نَن مَ. 
\q1 عٍ قَمَ نّ يَافِدٍ عٍ شَ سّرّشّيٍ شَ قٍ رَ.» 
\c 5  
\s1 عَلَ عِسِرَيِلَ مَكِيتِقٍ 
\q1  
\v 1 «سّرّشّدُبّيٍ، وٌ يِ رَ مّ. 
\q1 عِسِرَيِلَكَيٍ، وٌ عَ مَتٌ. 
\q1 مَنفّ شَ دٍنبَيَ، وٌ وٌ تُلِ مَتِ. 
\q1 كِيتِ نَ وٌن تَفِ، 
\q1 بَرِ مَ وٌ بَرَ قِندِ فَنتَنيِ رَ مِسِثَ، 
\q1 وٌ بَرَ قِندِ يّلّ رَ تَبٌرٌ فٍيَ قَرِ. 
\q1  
\v 2 وٌ نَ مِشِ نَن تُن مَقَشَقٍ يِ كِ، 
\q1 ﭑ شَ ﭑ يَشَسٍرِ مَسَ وٌ بّ.» 
\b  
\q1  
\v 3 «ﭑ عٍقِرَ مِ كٌلٌن، عِسِرَيِلَ مُ نْشُنشِ ﭑ مَ. 
\q1 عٍقِرَ مِ نَ لَنفٌيحَ رَبَقٍ، عِسِرَيِلَ قَن بَرَ سٌ سّنِيّنتَرٍحَ كُي. 
\q1  
\v 4 عٍ شَ قٍ كٌبِيٍ بَرَ عٍ مَكُيَ عٍ مَرِفِ عَلَ رَ. 
\q1 لَنفٌيحَ شَشِلِ بَرَ لُ عٍ يَ مَ. 
\q1 عٍ مُ عَلَتَلَ كٌلٌن. 
\q1  
\v 5 عِسِرَيِلَ شَ يّتّ عِفبٌيَ نَن عَ نِيَمَ 
\q1 عٍ شَ بِرَ، عٍ نُن عٍقِرَ مِ. 
\q1 يُدَيَ قَن بِرَ مَ نّ عٍ شَ يُنُبِ سَابُي رَ. 
\q1  
\v 6 عٍ شُرُ سٍيٍ شَنِنمَ سّرّشّ رَ، عٍ شَ عَلَتَلَ قٍن، 
\q1 كْنْ عٍ مُ عَ تٌمَ بَرِ مَ عَ مَكُيَ عٍ رَ. 
\q1  
\v 7 عٍ بَرَ عَلَتَلَ يَنقَ، عٍ حّنفّ دِيٍ بَرِ. 
\q1 بٍينُن كِكٍ كٍرٍن، عٍ شَ بْشِ قَمَ نّ كَنَدٍ، عٍ قَ هَلَكِ.» 
\b  
\q1  
\v 8 «وٌ سَرَ قٍ فِبِيَ. وٌ شَ عَ قٍ رَ مَ. 
\q1 وٌ فٍرٍ سْنشْي عِتٍ بٍتِ عَوٍنِ. 
\q1 بُنيَمِنكَيٍ، يَشُييٍ نَ وٌ شَنبِ رَ. 
\q1  
\v 9 عٍقِرَ مِ حَشَنكَتَمَ نّ نَ لْشْي. 
\q1 عِسِرَيِلَ بْنسْي، ﭑ شَ نْندِ مَسٍن وٌ بّ.» 
\b  
\q1  
\v 10 «يُدَيَ كُنتِفِيٍ قَمَ نّ ﭑ مَ شْنّ كٌلٌندٍ، 
\q1 بَرِ مَ عٍ عِقُ بْشِ نَانِنيِيٍ مَ. 
\q1  
\v 11 عٍقِرَ مِكَيٍ قَن قَمَ نّ حَشَنكَتَدٍ، 
\q1 بَرِ مَ عٍ بِرَشِ عٍ يّتّ وَشْنقٍ نَن قْشْ رَ. 
\q1  
\v 12 ﭑ قِندِ مَ سُورِ نَن نَ عٍقِرَ مِ بْنسْي بّ، 
\q1 ﭑ لُ يُدَ بْنسْي بّ عَلْ قِ حَاشِ. 
\q1  
\v 13 عٍقِرَ مِ نُن يُدَيَ عَ كٌلٌن عٍ قُرَشِ. 
\q1 عٍقِرَ مِ سِفَمَ عَسِرِيَ، 
\q1 عَ شّيرَيٍ شّيمَ نَا مَنفّ شُنفبٍ شْن مَ، 
\q1 كْنْ عَ مُ نْمَ وٌ رَيَلَندٍ، 
\q1 عَ مُ نْمَ وٌ شَ قِيٍ بَرِدٍ. 
\q1  
\v 14 ﭑ لُمَ نّ عَلْ يّتّ عٍقِرَ مِ بّ، 
\q1 عَلْ يّتّ يْرّ يُدَيَ بّ. 
\q1 ﭑ نٍيٍ عِبْو مَ نّ، ﭑ سِفَ عٍ رَ، 
\q1 مِشِ يٌ مُ عٍ بَمَ ﭑ يِ. 
\q1  
\v 15 ﭑ شَ فبِلٍن ﭑ شْنيِ، 
\q1 هَن عٍ شَ عٍ شَ يُنُبِ كٌلٌن، عٍ قَ ﭑ قٍن. 
\q1 عٍ قَمَ نّ ﭑ قٍندٍ عٍ شَ تْورّ كُي.» 
\c 6  
\s1 عَلَتَلَ وَشْنقٍ 
\q1  
\v 1 وٌ قَ بٍ، وٌن شَ فبِلٍن عَلَتَلَ مَ! 
\q1 عَ بَرَ وٌن تْورْ، كْنْ يَكْسِ عَ وٌن نَيَلَنمَ نّ. 
\q1 عَ بَرَ وٌن بْنبْ، كْنْ يَكْسِ عَ وٌن مَ قِيٍ مَشِرِ مَ نّ. 
\q1  
\v 2 شِ قِرِن نَ دَنفِ، عَ قَمَ نّ وٌن نَيَلَندٍ، 
\q1 عَ شِ سَشَن ندٍ عَ وٌن نَكٍلِ، وٌن قَ لُ عَ سّيتِ مَ. 
\q1  
\v 3 وٌن شَ عَلَتَلَ قٍن، وٌن شَ عَ كٌلٌن. 
\q1 عَلَ قَقٍ مُ كَنَمَ. 
\q1 لْشْ يٌ لْشْ كُيٍ عِبَمَ، حّمّ بِرِن تُنّ قَمَ. 
\q1 عَلَ قَن مُ تٌندِ مَ قَدٍ وٌن يِرٍ. 
\b  
\q1  
\v 4 «ﭑ مُنسٍ رَبَمَ عِ تَن نَ، عٍقِرَ مِ؟ 
\q1 ﭑ مُنسٍ رَبَمَ عِ رَ، يُدَيَ؟ 
\q1 عِ شَ هِننّ ﭑ مَبِرِ، لُشِ نّ عَلْ شِنِ نَشَن فٌرٌ مَ فّيسّفّ، 
\q1 كْنْ بٍينُن سٌفٍ شَ شْنْ، عَ حْن. 
\q1  
\v 5 ﭑ وٌ فٍرٍ مَ نَمِحْنمّيٍ شَ مَسٍنيِيٍ رَ نَ نَن مَ، 
\q1 ﭑ وٌ قَشَمَ نّ ﭑ مَ مَسٍنيِيٍ رَ. 
\q1 ﭑ مَ كِيتِيٍ قِيشّ عَلْ نَءِيَلَنيِ. 
\q1  
\v 6 هِننّ رَقَن ﭑ مَ دَنفِقٍ سّرّشّ رَ، 
\q1 عَلَ كٌلٌنقٍ دَنفِ سّرّشّ فَن دَاشِيٍ رَ. 
\q1  
\v 7 عٍ بَرَ ﭑ مَ سَاتّ كَنَ، 
\q1 عَلْ عَدَ مَدِيٍ دَرِشِ عَ رَ كِ نَشّ. 
\q1 عٍ بَرَ ﭑ يَنقَ. 
\q1  
\v 8 مِشِ حَاشِ وُيَ فَلَدِ، قَشّتِيٍ بَرَ فبٌ نَا. 
\q1  
\v 9 سّرّشّدُبّيٍ بَفَنمَ مِشِ مَ سِكٍمِ كِرَ شْن مَ عَلْ مُحّتِيٍ. 
\q1 نَ قَشّ تِقٍ، قٍ حَاشِ نَ عَ رَ. 
\q1  
\v 10 ﭑ بَرَ قٍ حَاشِيٍ تٌ عِسِرَيِلَكَيٍ تَفِ؛ 
\q1 عٍقِرَ مِ بَرَ لَنفٌيحَ رَبَ، عِسِرَيِلَ بَرَ نْشْ. 
\q1  
\v 11 يُدَيَ، ﭑ نَ فّ ﭑ مَ حَمَ رَفبِلٍندٍ كٌنيِيَ كُي، 
\q1 ﭑ وٌ قَن حَشَنكَتَمَ نّ.» 
\c 7  
\s1 عٍقِرَ مِ شَ يُنُبِيٍ 
\q1  
\v 1 «ﭑ تٌ وَ عِسِرَيِلَ رَيَلَنقٍ، 
\q1 عٍقِرَ مِ شَ يُنُبِ مَن نَشَ مَكّنّن. 
\q1 سَمَرِ شَ قٍ حَاشِ نَشَ مِنِ كّنّ مَ. 
\q1 نَ يَنقَنتٍيٍ مُحّ تِمَ، عٍ يٍنسٍن يّ يِرٍ بِرِن. 
\q1  
\v 2 عٍ عٍ مَحْشُن ﭑ مُ رَتُشِ عٍ شَ كٌبِحَ مَ، 
\q1 كْنْ ﭑ عٍ شَ وَلِ بِرِن تٌمَ نّ. 
\q1  
\v 3 يِ مِشِ كٌبِيٍ رَقَن مَنفّ مَ، 
\q1 كُنتِفِيٍ تِنمَ عٍ شَ وَلِ رَ. 
\q1  
\v 4 عٍ شَ لَنفٌيحَ فبٌ عَلْ تّ شُنفبٍ، 
\q1 تَامِ فَنيِ نَشَن نَدّشّمَ، 
\q1 عَ قَ وٌلٍن هَن عَ فّ قَرِن نَقَلَدٍ. 
\q1  
\v 5 كُنتِفِيٍ سِيسِمَ نّ مَنفّ شَ شُلُنيِ، 
\q1 مَنفّ قَن تِنشِ نَ قٍ مْولِ رَ. 
\q1  
\v 6 عٍ بْحّ بَرَ تٍ عَلْ تّ شُنفبٍ، 
\q1 عٍ عٍ مَسٌ مَنفّ رَ، عٍ شَ عَ يَنقَ. 
\q1 عٍ نَ قٍ بِرِن شِرِ مَ كْي نَن نَ 
\q1 عَلَكٌ فّيسّفّ عٍ شَ وَلِ حَاشِ شَ كَمَلِ. 
\q1  
\v 7 عٍ بْحّ نَشَ تٍ هَن عٍ كِيتِسَيٍ بِرِن نَبِرَ، 
\q1 عٍ عٍ شَ مَنفّيٍ بِرِن قَشَ. 
\q1 نَ مِشِ مْولِ مُ ﭑ مَ كِيتِ مَمّمَ قٍقٍ مَ. 
\b  
\q1  
\v 8 عٍقِرَ مِ وَ مَ لُقٍ نّ عَلْ سِ فبّتّيٍ، 
\q1 كْنْ عَ لُشِ نّ عَلْ تَامِ نَشَن فَنشِ عَ حَاشِ رَ. 
\q1  
\v 9 سِ فبّتّيٍ عَ سّنبّ كَنَمَ، كْنْ عَ مُ عَ كٌلٌن. 
\q1 عَ قٌرِشِ، كْنْ عَ مُ نَ رَكْرْ سِ. 
\q1  
\v 10 عِسِرَيِلَ عَ يّتّ عِفبٌمَ، عَ مُ فبِلٍن عَ مَرِفِ عَلَتَلَ مَ، 
\q1 عَ مُ بِرَ عَ شَ سّرِيّ قْشْ رَ. 
\q1  
\v 11 عٍقِرَ مِ لُشِ نّ عَلْ فَنبّ شَشِلِتَرٍ. 
\q1 عَ مِسِرَكَيٍ شِلِمَ، عَ سَاتّ تٌنفٌمَ عَسِرِيَكَيٍ بّ. 
\q1  
\v 12 عٍ نَ سِفَ نَا، ﭑ قَمَ نّ ﭑ مَ يّلّ وٌلِدٍ عٍ مَ، 
\q1 عٍ شَ بِرَ عَلْ شْنِ. 
\q1 ﭑ عٍ حَشَنكَتَمَ نّ، عَلْ عَ مَسٍنشِ عٍ بّ عٍ شَ مَلَنيِ كُي كِ نَشّ. 
\q1  
\v 13 حَشَنكَتّ نَ عٍ بّ، بَرِ مَ عٍ بَرَ عٍ فِ ﭑ شُن مَ. 
\q1 فبَلٌي نَ عٍ بّ، بَرِ مَ عٍ بَرَ ﭑ مَتَندِ. 
\q1 ﭑ نُ وَشِ نّ عٍ شُن سَرَقٍ، كْنْ عٍ وُلٍيٍ سَمَ ﭑ شُن مَ. 
\q1  
\v 14 عٍ يَيٍ رَ مِنِمَ عٍ شَ سَدٍ مَ، 
\q1 كْنْ عٍ مُ سُننُنشِ عٍ بْحّ مَ. 
\q1 عٍ عٍ مَلَنمَ عَلَكٌ عٍ شَ دٌنسٍ نُن وّنِ قٍن، 
\q1 كْنْ عٍ عٍ مَكُيَمَ ﭑ تَن نَ. 
\q1  
\v 15 ﭑ تَن نَن عٍ شُرُ، ﭑ تَن نَن سّنبّ قِ عٍ مَ، 
\q1 كْنْ عٍ قِنسِرِوَلِيَ رَبَمَ ﭑ نَ. 
\q1  
\v 16 عٍ مُ عٍ يَ تِمَ كٌورٍ رَ، 
\q1 عٍ يَنقّ تِمَ عَلْ يَنقّ يِلِ. 
\q1 نَ نَن عَ رَ، عٍ كُنتِفِيٍ قَشَمَ سَنتِدّفّمَ رَ، 
\q1 عٍ يَافِ مِسِرَ بْشِ مَ عٍ شَ وْيّنيِ شَ قٍ رَ.» 
\c 8  
\s1 عِسِرَيِلَ شَ كُيٍ بَتُي 
\q1  
\v 1 «وٌ شَ فٍرٍ سَرَ قٍ! 
\q1 يَشُي فٌرٌ مَ نّ عَلَتَلَ شَ بَنشِ مَ عَلْ سّفّ، 
\q1 بَرِ مَ حَمَ بَرَ ﭑ مَ لَايِدِ كَنَ، 
\q1 عٍ نَشَ مُرُتَ ﭑ مَ سّرِيّ مَ. 
\q1  
\v 2 عٍ ﭑ شِلِمَ، 
\q1 ‹مُشُ مَرِفِ عَلَ، مُشُ عِ كٌلٌن، مُشُ تَن، عِسِرَيِلَ.› 
\q1  
\v 3 عِسِرَيِلَ تٌ بَرَ قٍ قَنيِ بّحِن، 
\q1 يَشُي بِرَ مَ نّ عَ قْشْ رَ. 
\q1  
\v 4 عٍ بَرَ مَنفّيٍ تِ ﭑ مَ يَامَرِ مُ نَشَن نَ، 
\q1 عٍ بَرَ كُنتِفِيٍ تِ عٍ مُ ﭑ مَشْرِن. 
\b  
\q1 عٍ بَرَ كُيٍيٍ رَقَلَ عٍ شَ فبٍتِ نُن شّيمَ رَ. 
\q1 نٍيٍ هَلَكِمَ نَ نَن مَ. 
\q1  
\v 5 سَمَرِكَيٍ، وٌ وٌ شَ نِنفٍ كُيٍ وْلّ. 
\q1 ﭑ بَرَ شْنْ وٌ مَ عَ حَاشِ رَ. 
\q1 وٌ وٌ يّتّ مَنْشْمَ يِ قٍ مْولِ رَ هَن مُن تّمُي؟ 
\q1  
\v 6 يِ كُيٍ قَتَنشِ وٌ تَن عِسِرَيِلَ نَن نَ. 
\q1 مِشِ ندٍ نَن عَ رَقَلَشِ، عَلَ مُ عَ رَ! 
\q1 سَمَرِ شَ نِنفٍ كُيٍ قَمَ نّ بُتُشُندٍ. 
\q1  
\v 7 نَشَن حّرّ مَ قٍ حَاشِ كُي، 
\q1 فبَلٌي قَمَ نّ عَ لِدٍ. 
\q1 هَلِ مّنفِ تْنسْي كٍرٍن، عٍ مُ عَ سْتْمَ شّ مَ. 
\q1 سَنسِ نَشَن بُلَمَ، عَ مُ قِندِ مَ بَلٌي رَ. 
\q1 هَلِ ندٍ قِندِ عَ رَ، سِ فبّتّ نَن عَ دٌنمَ. 
\b  
\q1  
\v 8 عٍ بَرَ عِسِرَيِلَ شُن نَكَنَ، 
\q1 عٍ عٍ شَنِن حَمَنّ كٌنيِيَ كُي. 
\q1  
\v 9 عِسِرَيِلَكَيٍ بَرَ سِفَ عَسِرِيَ بْشِ مَ، 
\q1 عَلْ سٌقَلٍ نَشَن لُمَ عَ كٍرٍن. 
\q1  
\v 10 هَلِ عٍ مِشِ نَشٍيٍ سَرَشِ سِيٍ تَفِ عٍ كَنتَقٍ مَ، 
\q1 ﭑ عٍ بِرِن مَلَنمَ نّ، 
\q1 عَلَكٌ عٍ شَ تْورْ مَنفّيٍ شَ كٌتٍ بُن مَ. 
\b  
\q1  
\v 11 عٍقِرَ مِ بَرَ سّرّشّبَدٍيٍ رَوُيَ 
\q1 عَلَكٌ عٍ شَ يُنُبِيٍ شَ شَقَرِ، 
\q1 كْنْ نَ سّرّشّبَدٍيٍ بَرَ عَ نِيَ 
\q1 عٍ شَ يُنُبِيٍ سْتْ. 
\q1  
\v 12 ﭑ بَرَ ﭑ مَ سّرِيّيٍ بِرِن سّبّ، عٍ شَ نَ كٌلٌن، 
\q1 كْنْ عٍ مُ تِدٍ تٌشِ عَ مَ. 
\q1  
\v 13 عٍ سّرّشّيٍ بَمَ ﭑ بّ، عٍ نَ سُبٍ دٌن، 
\q1 كْنْ نَ مُ رَقَن عَلَتَلَ مَ. 
\q1 يَكْسِ، عَلَتَلَ قَمَ نّ عٍ حَشَنكَتَدٍ عٍ شَ يُنُبِيٍ شَ قٍ رَ، 
\q1 عٍ شَ فبِلٍن مِسِرَ بْشِ مَ. 
\q1  
\v 14 عِسِرَيِلَ بَرَ نّيمُ عَلَ مَ، نَشَن عٍ دَاشِ. 
\q1 عٍ نَ مَنفّ بَنشِيٍ تِقٍ. 
\q1 يُدَيَ قَن نَ تَايٍ تِقٍ، نَشٍيٍ سّنبّ فبٌ، 
\q1 كْنْ ﭑ نَ بِرِن فَنمَ نّ تّ رَ.» 
\c 9  
\s1 عِسِرَيِلَ شَ حَشَنكَتّ 
\q1  
\v 1 عِسِرَيِلَ، عِ نَشَ حّلّشِن، 
\q1 عِ نَشَ سّيوَ عَلْ سِ فبّتّيٍ. 
\q1 عِ تٌ عِ مَرِفِ عَلَ بّحِن، عِ بَرَ قِندِ لَنفٌي رَ. 
\q1 لَنفٌي مَسُندِ بَرَ رَقَن عِ مَ، 
\q1 عِ نَشَن سْتْمَ لٌنيِ يِرٍ. 
\q1  
\v 2 وٌ مُ بَلٌي سْتْمَ لٌنيِ يِرٍ، 
\q1 وٌ مُ وّنِ سْتْمَ وّنِ بٌفِ بُندُ سٍ كُي. 
\q1  
\v 3 عٍ مُ لُمَ عَلَتَلَ شَ بْشِ مَ، 
\q1 عٍقِرَ مِ فبِلٍنمَ نّ مِسِرَ، 
\q1 عٍ قَمَ دٌنسٍ هَرَ مُشِيٍ دٌندٍ عَسِرِيَ بْشِ مَ. 
\q1  
\v 4 عٍ مُ سّرّشّ يٍ دَاشِيٍ بَمَ عَلَتَلَ بّ. 
\q1 عٍ شَ سّرّشّيٍ مُ رَقَنمَ عَ مَ، 
\q1 عٍ لُمَ عَلْ حْن يِرٍ تَامِ. 
\q1 نَشٍيٍ نٍيٍ دٌنمَ عٍ قِندِ مَ سّنِيّنتَرٍيٍ نَن نَ. 
\q1 نَ قِندِ مَ دٌنسٍ نَن نَ عٍ بّ، 
\q1 كْنْ عَ مُ قِندِ مَ سّرّشّ رَ عَلَتَلَ بّ عَ شَ هْرْ مْبَنشِ كُي. 
\q1  
\v 5 وٌ مُنسٍ رَبَمَ سَلِ لْشْي عَلَتَلَ يَ عِ؟ 
\b  
\q1  
\v 6 هَلِ عٍ سَ عٍ رَتَنفَ فبَلٌي مَ، 
\q1 مِسِرَكَيٍ قَمَ نّ عٍ قَشَدٍ، عٍ عٍ رَفَتَ نٌقِ. 
\q1 عٍ شَ هَرِفٍ بِرِن لْيمَ نّ، عٍ شْنيِ قِندِ مَ نّ وُلَ رَ. 
\q1  
\v 7 حَشَنكَتّ لْشْييٍ نَ قَقٍ، يُنُبِ سَرٍ رَفبِلٍنمَ تّمُي نَشّ. 
\q1 عِسِرَيِلَ شَ نَ كٌلٌن. 
\q1 عِسِرَيِلَ شَ يُنُبِ فبٌ، 
\q1 نَ نَ عَ رَ عٍ نَمِحْنمّيٍ شْنمَ، 
\q1 عٍ دَشُي شِلِ سَ عٍ شُن مَ. 
\q1  
\v 8 عَلَ نُن نَمِحْنمّيٍ عٍقِرَ مِ كَنتَمَ، 
\q1 كْنْ مِشِيٍ تَن فَنتَنيِ تٍمَ نَمِحْنمّيٍ بّ. 
\q1 عٍ مُ رَقَن مِشِيٍ مَ عَلَ شَ هْرْ مْبَنشِ كُي. 
\b  
\q1  
\v 9 عٍقِرَ مِكَيٍ بَرَ سٌ يَنقَنتٍيَ كُي، 
\q1 عَلْ نَشَن نَبَشِ فِبِيَ. 
\q1 عَلَ مُ نّيمُشِ عٍ شَ يُنُبِ مَ، 
\q1 عَ قَمَ عٍ حَشَنكَتَدٍ نَ نَن مَ. 
\q1  
\v 10 «ﭑ تٌ عِسِرَيِلَ تٌ، 
\q1 عَ نُ قَن عَلْ بٌفِ سٍ نَشَن تٌمَ وُلَ عِ. 
\q1 وٌ بٍنبَيٍ نُ لُشِ نّ عَلْ شْرّ بٌفِ سِنفٍيٍ، 
\q1 كْنْ عٍ نَشَ بِرَ كُيٍ شْنشِ قْشْ رَ 
\q1 نَشَن نُ نَ ثٍيٌرِ. 
\q1  
\v 11 عٍقِرَ مِ شَ بِنيّ سِفَمَ نّ عَلْ شْنِ نَشَن تُفَنمَ. 
\q1 دِ بَرِ مُ نَ، تّيفّ مُ نَ. 
\q1  
\v 12 شَ عَ سَ عَ لِ عٍ نَشَ دِيٍ شُرُ، ﭑ عٍ بِرِن بَمَ نّ عٍ يِ. 
\q1 عٍ قٍ حَاشِ سْتْمَ نّ ﭑ نَ عٍ رَبٌلٌ تّمُي نَشّ. 
\q1  
\v 13 ﭑ بَرَ عٍقِرَ مِ تٌ عَ سَبَتِشِ يِرٍ قَنيِ، عَلْ تِرٍ نَ كِ نَشّ، 
\q1 كْنْ عٍقِرَ مِ شَ دِيٍ سٌمَ نّ قَشّتِيٍ يِ رَ.» 
\b  
\q1  
\v 14 عَلَتَلَ، عَ لَنمَ عِ شَ مُنسٍ رَبَ عٍ بّ؟ 
\q1 عِ شَ فِنّ قُرُشِيٍ قُرِ كَنَ، عِ شَ عٍ شِحّ شَرَ. 
\q1  
\v 15 عٍ حَاشُي بِرِن مَسٍنشِ نّ فِلِفَلِ. 
\q1 مّننِ ﭑ بَرَ عٍ شْن قْلْ عٍ شَ قٍ حَاشِيٍ شَ قٍ رَ. 
\q1 عٍ مُ رَقَنمَ ﭑ مَ سْنْن. 
\q1 عٍ شَ كُنتِفِيٍ قِندِشِ مَتَندِلَيٍ نَن نَ. 
\b  
\q1  
\v 16 «ﭑ بَرَ عٍقِرَ مِ بْنبْ. 
\q1 عَ لُشِ نّ عَلْ سَنسِ نَشَن سَنكٍ بَرَ شَرَ، 
\q1 عَ مُ بٌفِمَ سْنْن. 
\q1 شَ عٍقِرَ مِكَيٍ قَ دِيٍ بَرِ، 
\q1 ﭑ عٍ هَلَكِمَ نّ.» 
\q1  
\v 17 ﭑ مَرِفِ عَلَ قَمَ نّ عٍ رَبّحِندٍ، 
\q1 بَرِ مَ عٍ مُ عٍ تُلِ مَتِشِ عَ رَ. 
\q1 عٍ قِندِ مَ نّ بِيَاسِلَيٍ رَ سِيٍ تَفِ. 
\c 10  
\s1 عِسِرَيِلَ شَ مَكِيتِ 
\q1  
\v 1 عِسِرَيِلَ لُشِ نّ عَلْ سَنسِ بِلِ قَنيِ نَشَن بٌفِمَ عَ قَنيِ رَ. 
\q1 كْنْ عَ شَ بٌفِ تٌ وُيَ، عَ نَشَ سّرّشّبَدٍ قَن رَوُيَ. 
\q1 عَ شَ بْشِ تٌ تٌقَن، عَ نَشَ تْنشُمَ فّمّ تِ كُيٍ بّ. 
\q1  
\v 2 عٍ بْحّ مُ نَ عَلَتَلَ فبَنسَن شَ رَ، 
\q1 نَ نَ عَ رَ عٍ بَرَ يُنُبِ سْتْ. 
\q1 عَلَتَلَ عٍ شَ سّرّشّبَدٍيٍ رَبِرَ مَ نّ، 
\q1 عَ عٍ شَ تْنشُمَ فّمّيٍ كَنَ. 
\q1  
\v 3 يَكْسِ عٍ عَ قَلَمَ، 
\q1 «مَنفّ مُ نَ مُشُ شُن مَ، 
\q1 بَرِ مَ مُشُ مُ فَاشُمَ عَلَتَلَ يَ رَ سْنْن. 
\q1 مَنفّ نْمَ مُنسٍ رَبَدٍ مُشُ بّ؟» 
\q1  
\v 4 عٍ وْيّنمَ، عٍ عٍ كَلِمَ، عٍ سَاتّ تٌنفٌمَ، 
\q1 كْنْ نَ بِرِن قُقَقُ. 
\q1 كِيتِ قَنيِ مُ لُمَ عٍ يِ، 
\q1 عَلْ حٌوفٍ حَاشِ نَشَن بُلَمَ شّ مَ. 
\q1  
\v 5 سَمَرِكَيٍ قَمَ نّ كْنتْقِلِدٍ عٍ شَ نِنفٍ كُيٍيٍ شَ قٍ رَ 
\q1 نَشٍيٍ نَ بٍتِ عَوٍنِ. 
\q1 حَمَ وَ تِمَ، سّرّشّدُبّيٍ قَن سُننُنمَ، 
\q1 بَرِ مَ عٍ حّلّشِنشِ نَشَن نَ، نَ قَمَ نّ بَدٍ عٍ يِ رَ. 
\q1  
\v 6 نَ كُيٍيٍ شَنِنمَ نّ عَسِرِيَ بْشِ مَ، 
\q1 عَ قَ لُ مَنفّ شُنفبٍ مَ. 
\q1 عٍقِرَ مِ يَافِمَ نّ، 
\q1 بِرِن قَمَ نّ يٌدٍ عِسِرَيِلَ شَ كّوَلِ مَ. 
\q1  
\v 7 سَمَرِ نُن عَ مَنفّ شَنِنمَ نّ، 
\q1 عَلْ وُرِ شُنتُنيِ يٍ نَشَن شَنِنمَ. 
\q1  
\v 8 كُيٍ بَتُدٍيٍ نَشٍيٍ نَ بٍتِ عَوٍنِ، عٍ كَنَمَ نّ. 
\q1 نَ سّرّشّبَدٍيٍ، عِسِرَيِلَكَيٍ يُنُبِ رَبَ دّننَشّ، 
\q1 عٍ قِندِ مَ تُنبٍ يِرٍيٍ نَن نَ. 
\q1 عٍ قَمَ نّ عَ قَلَدٍ فٍيَيٍ بّ، 
\q1 «مُشُ مَكٌتٌ، مُشُ رَفَتَ!» 
\b  
\q1  
\v 9 «عِسِرَيِلَ، كَبِ وٌ نَشَ نَ يُنُبِ حَاشِ رَبَ فِبِيَ، 
\q1 وٌ نَ يُنُبِ سْتْقٍ تُن. 
\q1 حَشَنكَتّ قَمَ عٍ لِدٍ فِبِيَ نَ نَن مَ. 
\q1  
\v 10 عَ بَرَ ﭑ كّنّن ﭑ شَ عٍ هَلَكِ. 
\q1 سِيٍ قَمَ نّ عٍ فٍرٍدٍ، عٍ عٍ سُشُ عٍ شَ يُنُبِ فبٍفبٍ شَ قٍ رَ. 
\b  
\q1  
\v 11 عٍقِرَ مِ لُشِ نّ عَلْ نِنفٍ شُرُشِ، وَلِ رَقَن نَشَن مَ. 
\q1 ﭑ قَمَ نّ لُوتِ شِرِدٍ عَ شُنيِ مَ، عَ شَ وَلِ رَبَ ﭑ بّ. 
\q1 يُدَيَ قَن شَ وَلِ، يَشُبَ بْنسْي شَ كٌتٍ شَنِن. 
\q1  
\v 12 وٌ شَ وَلِ تِنشِنشِ رَبَ، 
\q1 عَلَكٌ وٌ شَ قٍ قَنيِ سْتْ. 
\q1 وٌ شَ وَكِلِ نّينّ تٌنفٌ، 
\q1 وٌ شَ عَلَتَلَ قٍن هَن عَ قَ تّمُي وٌ يِرٍ، 
\q1 عَ تِنشِنيِ لُ وٌ بْحّ كُي. 
\q1  
\v 13 كْنْ وٌ تَن مُ تِن نَ وَلِ تِنشِنشِ رَ. 
\q1 وٌ بَرَ قٍ حَاشِ رَبَ. 
\q1 يَنقَنتٍيَ نُن يّتّ عِفبٌحَ بَرَ فبٌ وٌ يِ رَ. 
\q1 وٌ بَرَ لَ وٌ شَ سْورِيٍ سّنبّ رَ، 
\q1  
\v 14 كْنْ عٍ يَ قَمَ عِسٌدٍ، 
\q1 عٍ شَ يِرٍ كَنتَشِيٍ قَمَ نّ كَنَدٍ، 
\q1 عَلْ نَ فٍرٍ لْشْي سَلَمَن شُتُ سْتْ بٍتِ عَرَبٍلِ شُن مَ تّمُي نَشّ. 
\q1 نَ لْشْي فِنّيٍ نُن عٍ شَ دِ بِرِن قَشَ نّ. 
\q1  
\v 15 نَ مْولِ قَمَ نّ بٍتٍلِ لِدٍ 
\q1 عَ شَ يُنُبِيٍ شَ قٍ رَ. 
\q1 سُبَشّ نَ عَ لِ، عِسِرَيِلَ مَنفّ قَشَمَ نّ.» 
\c 11  
\s1 عَلَ شَ كِنِكِنِ 
\q1  
\v 1 «ﭑ عِسِرَيِلَ شَنُ نّ عَ دِ مّدِ تّمُي. 
\q1 ﭑ نَشَ ﭑ مَ دِ شِلِ عَ شَ كٍلِ مِسِرَ بْشِ مَ. 
\q1  
\v 2 كْنْ ﭑ تٌ نُ عٍ شِلِمَ، عٍ نَشَ عٍ مَكُيَ ﭑ نَ، 
\q1 عٍ سّرّشّ بَ بَلِ كُيٍيٍ بّ، عٍ سُرَيِ فَن فّمّ مَسٌلِشِيٍ بّ. 
\q1  
\v 3 ﭑ تَن نَن نُ عٍقِرَ مِ مَلِقٍ عَ شَ حّرّ كُي، 
\q1 كْنْ عٍ مُ عَ كٌلٌنشِ عَ ﭑ تَن نَن نُ مّينِقٍ عٍ مَ. 
\q1  
\v 4 ﭑ نُ نَ عٍ مَبّندُنقٍ مَرَقَنيِ نُن شَنُنتٍيَ رَ. 
\q1 ﭑ تَن نَن عٍ رَ مِنِ كٌنيِيَ كُي، 
\q1 عَلَكٌ عٍ شَ بَلٌ عَ قَنيِ رَ. 
\q1  
\v 5 يَكْسِ، هَلِ عٍ مُ قَ سَ فبِلٍن مِسِرَ بْشِ مَ، 
\q1 عَسِرِيَ نَن نْي سْتْمَ عٍ شُن نَ، 
\q1 بَرِ مَ عٍ بَرَ تٌندِ فبِلٍندٍ ﭑ مَ. 
\q1  
\v 6 نَ نَن عَ رَ سَنتِدّفّمَ قَمَ عٍ شَ تَايٍ لِدٍ، 
\q1 عَ قَ عٍ شْنيِ بِرِن كَنَ. 
\q1 عٍ وَشْنقٍ مُ سْونّيَمَ سْنْن. 
\q1  
\v 7 ﭑ مَ حَمَ بَرَ فبِلٍن ﭑ قْشْ رَ. 
\q1 هَلِ عٍ بِرِن ﭑ شِلِ، ﭑ مُ عٍ شُن نَكٍلِمَ.» 
\b  
\q1  
\v 8 «كْنْ عٍقِرَ مِ، ﭑ شَ عِ رَبّحِن دِ؟ 
\q1 ﭑ شَ عِسِرَيِلَ رَبٌلٌ دِ؟ 
\q1 ﭑ مُ نْمَ قٍ رَبَدٍ عِ رَ 
\q1 عَلْ ﭑ نَشَن نَبَشِ عَدَ مَهَ. 
\q1 ﭑ شَ عِ لُ عَلْ سٍبٌيِمِ؟ 
\q1 تْورّ بَرَ ﭑ بْحّ سُشُ. 
\q1 ﭑ بَرَ كِنِكِنِ وٌ مَ. 
\q1  
\v 9 ﭑ بَرَ ﭑ مَ نَتّ مَسَرَ، 
\q1 ﭑ بْحّ بَرَ شِنبٍلِ. 
\q1 ﭑ بَرَ دِحّ عٍقِرَ مِ مَ، بَرِ مَ عَلَ نَن ﭑ نَ. 
\q1 عَدَ مَ مُ نَ ﭑ تَن نَ. 
\q1 سّنِيّنتْي نَن ﭑ نَ وٌ تَفِ. 
\q1 ﭑ بَرَ ﭑ مَ شْنّ لُ نَ. 
\q1  
\v 10 عٍ قَمَ نّ بِرَدٍ عَلَتَلَ قْشْ رَ. 
\q1 عَلَ نَ عَ شُي رَ مِنِ سّنبّ رَ عَلْ يّتّ مَفَاشُشِ، 
\q1 عٍ قَمَ نّ لُدٍ عَ شَنبِ رَ كٍلِقٍ سٌفٍفٌرٌدٍ مَبِرِ. 
\q1  
\v 11 عٍ كٍلِمَ نّ مِسِرَ بْشِ مَ عَلْ شْنِيٍ، 
\q1 عٍ كٍلِمَ نّ عَسِرِيَ بْشِ مَ عَلْ فَنبّيٍ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\c 12  
\s1 عِسِرَيِلَ شَ يَنقَنتٍيَ 
\q1  
\v 1 «عٍقِرَ مِ وَ مَ ﭑ مَدَشُقٍ. 
\q1 عِسِرَيِلَ وَ مَ ﭑ يَنقَقٍ. 
\q1 يُدَيَ تَن بِرَ مَ نّ عَلَ قْشْ رَ، 
\q1 عَ مُ لَنلَنتٍيَ كَنَ عَلَ سّنِيّنشِ مَبِرِ. 
\q1  
\v 2 عٍقِرَ مِ قٍ قُقَقُ قٍنمَ، 
\q1 عَ بِرَ مَ مِشِيٍ قْشْ رَ نَشٍيٍ نَ قُفٍ رَ. 
\q1 عَ شَ وُلٍيٍ نُن قٍ حَاشِيٍ فبٌ. 
\q1 عَ سَاتّ تٌنفٌمَ عَسِرِيَ بّ، 
\q1 عَ عٌلِوِ تُرٍ قِمَ نّ مِسِرَ مَنفّ مَ. 
\q1  
\v 3 عَلَ يُدَيَكَيٍ مَكِيتِمَ نّ، 
\q1 عَ يَشُبَ بْنسْي حَشَنكَتَمَ نّ، 
\q1 عَ قَ عَ شَ كّوَلِ سَرٍ رَفبِلٍن عَ مَ.» 
\b  
\q1  
\v 4 عٍ نَ عٍ نفَ قُرِ كُي، يَشُبَ نَشَ عَ تَارَ تِنفِلِنيِ سُشُ. 
\q1 عَ تٌ قٌرِ، عٍ نُن عَلَ نَشَ فٍرٍ سٌ. 
\q1  
\v 5 عٍ نُن مَلٍكّ نَشَ فٍرٍ سٌ، عَ شُتُ سْتْ عَ مَ. 
\q1 عَ نَشَ وَ، عَ عَ مَيَندِ عَ شَ هِننّ عَ رَ. 
\q1 يَشُبَ عَ تٌ نّ بٍتٍلِ. 
\q1 عٍ نُن عَلَ وْيّن مّننِ نّ. 
\q1  
\v 6 عَلَتَلَ نَن مَنفّ رَ. 
\q1 شِلِ شُنفبٍ كَنيِ نَن عَلَتَلَ رَ. 
\q1  
\v 7 عِ تَن شَ قَ عِ مَرِفِ عَلَ مَ، 
\q1 عِ نَشَ دُفُتّفّحَ كَنَ، 
\q1 عِ شَ سّرِيّ تِنشِنشِ سُشُ. 
\q1 عِ شَشِلِ تِ عِ مَرِفِ عَلَ رَ تّمُي بِرِن. 
\b  
\q1  
\v 8 يُلّ سِكٍيلِ وُلٍ رَوَلِمَ، عَ مِشِ تْورْ. 
\q1  
\v 9 عٍقِرَ مِ بَرَ عَ قَلَ، 
\q1 «ﭑ بَرَ بَننَ هَن! 
\q1 ﭑ بَرَ نَاقُلِ سْتْ ﭑ يّتّ سّنبّ رَ. 
\q1 ﭑ مُ يُنُبِ يٌ رَبَشِ.» 
\b  
\q1  
\v 10 «ﭑ تَن نَن عِ مَرِفِ عَلَتَلَ رَ، 
\q1 نَشَن عِ رَ مِنِشِ مِسِرَ بْشِ مَ. 
\q1 ﭑ مَن عِ رَدْشْمَ نّ كِرِ بَنشِيٍ كُي، 
\q1 عَلْ وٌن مَ سَلِ تّمُي دَنفِشِيٍ. 
\q1  
\v 11 ﭑ نُ وْيّنمَ نَمِحْنمّيٍ بّ، 
\q1 ﭑ لَامَتُنيِيٍ وُيَشِ سٌ عٍ يِ رَ. 
\q1 ﭑ نُ تَالِيٍ مَسٍنمَ وٌ بّ نَمِحْنمّيٍ سَابُي رَ. 
\q1  
\v 12 فَلَدِكَيٍ لُمَ نّ قٍ حَاشِ رَبَ رَ. 
\q1 نَ قٍ نَ عَ نِيَمَ ﭑ قَمَ عٍ شُن نَكَنَدٍ. 
\q1 عٍ نِنفٍيٍ بَمَ سّرّشّ رَ فِلِفَلِ، 
\q1 كْنْ ﭑ قَمَ نّ عٍ شَ سّرّشّبَدٍيٍ كَنَدٍ، 
\q1 عٍ شَ لُ عَلْ فّمّ مَلَنشِيٍ شّيٍ مَ.» 
\b  
\q1  
\v 13 يَشُبَ نَشَ عَ فِ عَرَ مِ بْشِ مَ. 
\q1 عِسِرَيِلَ نَشَ قِندِ شُرُ سٍيٍ دّ مَدٌنيِ رَ، 
\q1 عَلَكٌ عَ شَ فِنّ ندٍ سْتْ. 
\q1  
\v 14 عَلَتَلَ نَشَ عِسِرَيِلَ رَ مِنِ مِسِرَ بْشِ مَ 
\q1 نَمِحْنمّ ندٍ سَابُي رَ. 
\q1 عَلَتَلَ نَشَ مّينِ عِسِرَيِلَ مَ عَ شَ شّيرَيٍ سَابُي رَ. 
\q1  
\v 15 عٍقِرَ مِ بَرَ عَلَتَلَ رَشْنْ عَ حَاشِ رَ. 
\q1 عٍ مَرِفِ قَمَ نّ عٍ حَشَنكَتَدٍ عٍ شَ قَشّ تِشِيٍ شَ قٍ رَ، 
\q1 عَ قَ عٍ رَيَافِ. 
\c 13  
\s1 عَلَ شَ شْنّ 
\q1  
\v 1 حَمَ نُ فَاشُمَ نّ عٍقِرَ مِ شَ وْيّنيِ يَ رَ، 
\q1 بَرِ مَ مِشِ بِنيّ نَن نُ عَ رَ، 
\q1 كْنْ عَ نَشَ يُنُبِ سْتْ بَلِ كُيٍ بَتُقٍ رَ، عَ قَ قَشَ. 
\q1  
\v 2 يَكْسِ عٍ مَن يُنُبِيٍ نَن نَبَمَ، 
\q1 عٍ كُيٍ رَقَلَمَ فبٍتِ رَ. 
\q1 عٍ كُيٍ يَءِلَنمَ، 
\q1 كْنْ شَبُي وَلِ فبَنسَن نَن عَ رَ. 
\q1 عٍ عَدَ مَدِيٍ بَمَ سّرّشّ رَ، 
\q1 عٍ نِنفٍ كُيٍ سُنبُمَ. 
\q1  
\v 3 نَ نَ عَ نِيَمَ عٍ قَمَ حْندٍ عَلْ كُندَ نَشَن فٌرٌ مَ فّيسّفّ، 
\q1 عَلْ شِنِ نَشَن يٌلٌنمَ فّيسّفّ، 
\q1 عَلْ مَالٍ لَفِ قٌيٍ نَشَن شَنِنمَ قٌيٍ رَ، 
\q1 عَلْ تُورِ نَشَن مِنِمَ كُرِ كُي. 
\b  
\q1  
\v 4 «ﭑ تَن نَن عِ مَرِفِ عَلَتَلَ رَ، 
\q1 نَشَن عِ رَ مِنِشِ مِسِرَ بْشِ مَ. 
\q1 عِ نَشَ عَلَ فبّتّ كٌلٌن قٌ ﭑ تَن. 
\q1 مَرَكِسِمَ مُ نَ عِ بّ بَ ﭑ تَن نَ. 
\q1  
\v 5 ﭑ حّنفِ سَشِ عِ شْن فبٍنفبٍرٍن يِرٍ. 
\q1  
\v 6 عٍ تٌ بَلٌي سْتْ، عٍ نَشَ لُفَ. 
\q1 عٍ تٌ لُفَ، عٍ نَشَ قِندِ يّتّ عِفبٌي رَ. 
\q1 نَ نَن عَ رَ عٍ نّيمُشِ ﭑ مَ. 
\q1  
\v 7 ﭑ لُمَ نّ عٍ بّ عَلْ يّتّ، 
\q1 نَشَن عَ نْشُنمَ كِرَ شْن هَن عَ سُبٍ سْتْ. 
\q1  
\v 8 ﭑ عٍ سُشُمَ نّ عَلْ سُبٍ شَاحّ، نَشَن مَ دِيٍ بَشِ عَ يِ. 
\q1 ﭑ عٍ عِبْو مَ نّ عَلْ يّتّ، نَشَن وُلَءِ سُبٍ قَشَمَ. 
\q1 وُلَ سُبٍيٍ مَن عٍ عِبْو مَ نّ. 
\q1  
\v 9 عِسِرَيِلَ، عِ بَرَ عِ يّتّ كَنَ، 
\q1 بَرِ مَ عِ بَرَ عِ مَلِمَ يَنقَ، نَشَن قِندِ ﭑ تَن نَ. 
\q1  
\v 10 عِ شَ مَنفّ نَ مِندٍن، 
\q1 نَشَن نُ لَنمَ عَ شَ وٌ رَكِسِ؟ 
\q1 عِ شَ كِيتِسَيٍ نَ مِندٍن، 
\q1 عِ نُ وَ مَ نَشٍيٍ شْن عَلَكٌ عِ شَ مَنفّ نُن مَنفّدِيٍ سْتْ؟ 
\q1  
\v 11 ﭑ تٌ شْنْ وٌ مَ، ﭑ بَرَ مَنفّ سٌ وٌ يِ رَ. 
\q1 يَكْسِ ﭑ عَ بَمَ نّ وٌ يِ رَ ﭑ مَ شْنّ كُي. 
\q1  
\v 12 عٍقِرَ مِ شَ قٍ حَاشِ بِرِن سّبّشِ، 
\q1 عَلَ مُ نّيمُمَ عَ شَ يُنُبِيٍ مَ. 
\q1  
\v 13 تْورّ قَمَ نّ عَ لِدٍ، 
\q1 عَلْ فِنّ نَشَن دِ بَرِ مَ. 
\q1 كْنْ دِ شَشِلِتَرٍ نَ عَ رَ. 
\q1 عَ بَرِ تّمُي نَ عَ لِ، عَ مُ تِنمَ مِنِدٍ عَ نفَ تّيفّ.» 
\b  
\q1  
\v 14 «ﭑ شَ عٍ شُن سَرَ عَلِفِيَمَ سّنبّ يِ؟ 
\q1 ﭑ شَ عٍ رَكِسِ سَيَ مَ؟ 
\q1 سَيَ، عِ شَ شْنّ نَ مِندٍن؟ 
\q1 عَلِفِيَمَ، عِ شَ سّنبّ نَ مِندٍن؟ 
\q1 ﭑ مُ كِنِكِنِمَ وٌ مَ قٍوٌ! 
\q1  
\v 15 هَلِ عَ سّنبّ فبٌ عَ نفَشَكٍرٍنيِيٍ تَفِ، 
\q1 عَلَتَلَ قٌيٍ شَرٍ رَقَمَ نّ 
\q1 كٍلِ فبٍنفبٍرٍنيِ سٌفٍتٍدٍ مَبِرِ، 
\q1 عَ قَ شُرٍيٍ نُن كْلْنيِيٍ شْرِدٍ. 
\q1 هَرِفٍ بِرِن بَمَ نّ عَ يِ رَ.» 
\c 14  
\s1 عِسِرَيِلَكَيٍ شَ تُوبِ عَلَتَلَ مَ 
\q1  
\v 1 سَمَرِكَيٍ بَرَ يُنُبِ سْتْ عٍ مَرِفِ عَلَتَلَ مَتَندِقٍ رَ. 
\q1 نَ نَن عَ رَ عٍ قَشَمَ سَنتِدّفّمَ رَ، 
\q1 عٍ شَ دِيْرّيٍ وٌلِمَ نّ بْشِ مَ، 
\q1 عٍ شَ فِنّ قُرُشِيٍ قُرِ رَبْو مَ نّ. 
\q1  
\v 2 عِسِرَيِلَ، فبِلٍن عِ مَرِفِ عَلَتَلَ مَ، 
\q1 بَرِ مَ عِ شَ وَلِ كٌبِ بَرَ عِ رَبِرَ. 
\q1  
\v 3 وٌ تُوبِ عَلَتَلَ مَ، وٌ قَ يِ وْيّن قَنيِ قَلَ عَ بّ، 
\q1 «عِ شَ دِحّ مُشُ شَ يُنُبِيٍ مَ، 
\q1 عِ شَ هِننّ مُشُ رَ. 
\q1 مُشُ شَ تَنتُي بَ سّرّشّ رَ، تُورَيٍ شَ لُ نَ. 
\q1  
\v 4 عَسِرِيَ مُ نْمَ مُشُ رَكِسِدٍ، 
\q1 مُشُ مُ تٍمَ سٌييٍ قَرِ فٍرٍ شِلِ مَ. 
\q1 مُشُ مُ كُيٍيٍ شِلِمَ ‹مُشُ مَرِفِ عَلَ› 
\q1 نَشٍيٍ يَءِلَنشِ مِشِ بّلّشّ رَ. 
\q1 عِ تَن نَن فبَنسَن كِنِكِنِمَ كِرِدِيٍ مَ.» 
\b  
\q1  
\v 5 «ﭑ عٍ شَ يَنقَنتٍيَ يَءِلَنمَ نّ. 
\q1 ﭑ عٍ شَنُمَ نّ قٌنِسِرٍيَ رَ، 
\q1 بَرِ مَ ﭑ مَ شْنّ بَرَ فبِلٍن عٍ قْشْ رَ. 
\q1  
\v 6 ﭑ لُمَ نّ عِسِرَيِلَ بّ عَلْ شِنِ، 
\q1 عٍ تٌقَنمَ نّ عَلْ سَنسِ قُفَشِ. 
\q1 عٍ سَبَتِمَ نّ عَلْ وُرِ بِلِ قَنيِ نَشَن نَ لِبَن. 
\q1  
\v 7 عَ سَلٌنيِ كُيَمَ نّ. 
\q1 عَ تٌقَنمَ نّ عَلْ عٌلِوِ وُرِ، 
\q1 عَ شِرِ قَنيِ رَ مِنِمَ نّ عَلْ وٌندِ نَشَن نَ لِبَن. 
\q1  
\v 8 حَمَ مَن سَبَتِمَ نّ عِسِرَيِلَ بْشِ مَ عَلَ شَ نِينِ بُن مَ. 
\q1 عٍ شَ مّنفِ قَنمَ نّ. 
\q1 عٍ شَ قٍ حْشُنمَ نّ عَلْ وّنِ بٌفِ، 
\q1 عٍ قَ شِلِ قَنيِ سْتْ عَلْ لِبَن شَ وّنِ. 
\q1  
\v 9 عٍقِرَ مِ بْنسْي، مُنسٍ نَ ﭑ نُن كُيٍيٍ تَفِ؟ 
\q1 ﭑ تَن نَن وٌ شَ دُبّ سُشُمَ، 
\q1 ﭑ نَن ﭑ حّنفِ سَمَ نّ وٌ شْن. 
\q1 ﭑ لُمَ نّ وٌ بّ عَلْ وُرِ شِندٍ قَنيِ. 
\q1 وٌ بَلٌي سْتْمَ ﭑ تَن نَن سَابُي رَ.» 
\b  
\q1  
\v 10 لْننِلَ يِ وْيّنيِ كٌلٌنمَ نّ. 
\q1 شَشِلِمَ يِ مَسٍنيِ قَهَامُمَ نّ. 
\q1 عَلَتَلَ شَ كِرَيٍ تِنشِن، 
\q1 تِنشِنتْييٍ حّرّ مَ نٍيٍ نَن شْن، 
\q1 كْنْ مَتَندِلَيٍ دِنكٌنمَ نٍيٍ نَن نَ.