\id 1CH
\h تارىخ-تەزكىرە «1»
\toc1 تارىخ-تەزكىرە «1»
\toc2 تارىخ-تەزكىرە «1»
\toc3 1تار.
\mt1 تارىخ-تەزكىرە «1»
\c 1
\s1 ئادەمئاتىدىن ئىبراھىمغىچە بولغان نەسەبنامە
\r يار. 5‏:1-32؛ 10‏:1-32؛ 11‏:10-26؛ 25‏:1-6
\m 
\v 1 ئادەمئاتا، شېت، ئېنوش،
\v 2 كېنان، ماھالالېل، يارەد،
\v 3 ھانوخ، مەتۇشەلاھ، لەمەخ،
\v 4 نۇھ. نۇھتىن شەم، ھام، يافەتلەر تۆرەلگەن.
\b
\s1 يافەتنىڭ ئەۋلادلىرى
\m 
\v 5 يافەتنىڭ ئوغۇللىرى گومەر، ماگوگ، ماداي، ياۋان، تۇبال، مەشەك ۋە تىراس ئىدى.
\v 6 گومەرنىڭ ئوغۇللىرى ئاشكىناز، دىفات ۋە توگارماھ ئىدى. \f ◼ \fr 1:6 \ft \bd «دىفات»\bd* ــ ياكى «رىفات» («يار.» 3:10نى كۆرۈڭ).\f*
\v 7 ياۋاننىڭ ئوغۇللىرى ئېلىشاھ، تارشىش ئىدى، كىتتىيلار بىلەن رودانىيلار ئۇنىڭ ئەۋلادلىرى ئىدى.
\b
\s1 ھامنىڭ ئەۋلادلىرى
\m 
\v 8 ھامنىڭ ئوغۇللىرى كۇش، مىسىر، پۇت ۋە قانائان ئىدى. \f ◼ \fr 1:8 \ft \bd «مىسىر»\bd* ــ ئىبرانىي تىلىدا «مىزرائىم». \bd «پۇت»\bd* ــ پۇت لىۋىيەلىكلەرنىڭ ئەجدادى بولدى.\f*
\v 9 كۇشنىڭ ئوغۇللىرى سېبا، ھاۋىلاھ، سابتاھ، رائاماھ ۋە سابتىكا ئىدى. رائامانىڭ ئوغلى شېبا ۋە دېدان ئىدى.
\v 10 كۇشتىن يەنە نىمرود تۆرەلگەن؛ ئۇ يەر يۈزىدە ناھايىتى زەبەردەس بىر ئادەم بولۇپ چىقتى.
\v 11 مىسىرنىڭ ئەۋلادلىرى لۇدىيلار، ئانامىيلار، لەھابىيلار، نافتۇھىيلار،
\v 12 پاتروسىيلار، كاسلۇھىيلار (فىلىستىيلەر كاسلۇھىيلاردىن چىققان) ۋە كافتورىيلار ئىدى.
\m 
\v 13 قانائاندىن تۇنجى ئوغۇل زىدون تۆرىلىپ، كېيىن يەنە ھەت تۆرەلگەن.
\v 14 ئۇنىڭ ئەۋلادلىرى يەنە يەبۇسىيلار، ئامورىيلار، گىرگاشىيلار،
\v 15 ھىۋىيلار، ئارقىيلار، سىنىيلار،
\v 16 ئارۋادىيلار، زەمارىيلار ۋە خاماتىيلار ئىدى.
\b
\m 
\v 17 شەمنىڭ ئوغۇللىرى ئېلام، ئاشۇر، ئارفاخشاد، لۇد، ئارام؛ \add ئارامنىڭ ئوغۇللىرى\add* ئۇز، ھۇل، گەتەر، مەشەك ئىدى. \f ◼ \fr 1:17 \ft \bd «ئارامنىڭ ئوغۇللىرى»\bd* ــ «ئارامنىڭ ئوغۇللىرى» دېگەن سۆزلەر بەزى كونا كۆچۈرمىلەردىن يوقاپ كەتكەن. «يار.» 3:10 بىلەن سېلىشتۇرۇڭ.\f*
\v 18 ئارفاخشادتىن شېلاھ تۆرەلدى، شېلاھتىن ئېبەر تۆرەلدى. \f ◼ \fr 1:18 \ft \bd «ئېبەر»\bd* ــ مەنىسى بەلكىم «(دەريادىن) ئۆتكۈچى». «ئىبرانىي» بەلكىم بۇ سۆزدىن چىققان.\f*
\v 19 ئېبەردىن ئىككى ئوغۇل تۆرەلگەن بولۇپ، بىرىنىڭ ئىسمى پەلەگ ئىدى، چۈنكى ئۇ ياشىغان دەۋردە يەر يۈزى بۆلۈنۈپ كەتكەنىدى؛ پەلەگنىڭ ئىنىسىنىڭ ئىسمى يوقتان ئىدى. \f ◼ \fr 1:19 \ft \bd «پەلەگ»\bd* ــ دېگەن سۆزنىڭ تەلەپپۇزى «بۆلۈنۈش»كە يېقىندۇر. «ئۇ ياشىغان دەۋردە يەر يۈزى بۆلۈنۈپ كەتكەنىدى» ــ ئۈچ ئىمكانىيەت بار: (1) بۇ سۆزلەر بابىل مۇنارىدىكى ۋەقەدە، خۇدانىڭ تىلنى بۆلۈشى بىلەن ئەللەرنىمۇ بۆلگەنلىكىنى، شۇنداقلا «يەر يۈزىدىكىلەر بۆلۈنۈپ كەتكەن»لىكىنى كۆرسىتىدۇ؛ (2) يەر-زېمىننىڭ بۆلۈنۈپ كەتكەنلىكىنى كۆرسىتىدۇ («يار.» 9:1 بويىچە يەر-زېمىن ئەسلىدە بىر قۇرۇقلۇق ئىدى، ئاندىن كېيىن چوقۇم مەلۇم ۋاقىتتا ھازىرقى ئاسىيا، ياۋروپا، ئافرىقا، ئامېرىكا قىتئەلىرىگە بۆلۈنۈپ كەتكەن)؛ (3) يۇقىرىدا تىلغا ئېلىنغان ئىككى ئىمكانىيەتنىڭ تەڭ يۈز بەرگەنلىكىنى كۆرسىتىدۇ. بىز شۇ ئاخىرقى ئىمكانىيەتكە مايىلمىز.\f*
\v 20 يوقتاندىن ئالموداد، شەلەف، خازارماۋەت، يېراھ،
\v 21 ھادورام، ئۇزال، دىكلاھ،
\v 22 ئېبال، ئابىمائەل، شېبا، \f ◼ \fr 1:22 \ft \bd «ئېبال»\bd* ــ «يار.» 28:10دە «ئوبال».\f*
\v 23 ئوفىر، ھاۋىلاھ، يوباب تۆرەلدى. بۇلارنىڭ ھەممىسى يوقتاننىڭ ئوغۇللىرى ئىدى.
\b
\s1 ئىبراھىمنىڭ ئەجدادلىرىنىڭ نەسەبنامىسى
\m 
\v 24 شەم، ئارفاخشات، شېلاھ،
\v 25 ئېبەر، پەلەگ، رەئۇ،
\v 26 سېرۇگ، ناھور، تەراھ،
\v 27 ئاندىن ئابرام دۇنياغا كەلدى (ئابرام بولسا ئىبراھىمنىڭ ئۆزى).
\b
\s1 ئىبراھىمنىڭ ئەۋلادلىرى
\r يار. 25‏:12-18
\m 
\v 28 ئىبراھىمنىڭ ئوغۇللىرى ئىسھاق بىلەن ئىسمائىل ئىدى. \f ◼ \fr 1:28 \ft \bd «ئىسمائىل»\bd* ــ ئىبرانىي تىلىدا «ئىشمائىل».\f*
\m 
\v 29 تۆۋەندىكىلەر ئۇلارنىڭ ئەۋلادلىرى: ئىسمائىلنىڭ تۇنجى ئوغلى نېبايوت بولۇپ، قالغانلىرى كېدار، ئادبەئەل، مىبسام،
\v 30 مىشما، دۇماھ، ماسسا، ھاداد، تېما،
\v 31 يەتۇر، نافىش، قەدەماھ؛ بۇلارنىڭ ھەممىسى ئىسمائىلنىڭ ئوغۇللىرى ئىدى.
\m 
\v 32 ئىبراھىمنىڭ توقىلى كەتۇراھدىن تۆرەلگەن ئوغۇللار زىمران، يوقشان، مېدان، مىدىيان، ئىشباك ۋە شۇئاھ ئىدى. يوقشاننىڭ ئوغۇللىرى شېبا بىلەن دېدان ئىدى. \x ◘ \xo 1:32 \xt يار. 25‏:1-6\x*
\v 33 مىدىياننىڭ ئوغۇللىرى ئەفاھ، ئېفەر، ھانوخ، ئابىدا، ئەلدائاھ ئىدى. بۇلارنىڭ ھەممىسى كەتۇراھنىڭ ئەۋلادلىرى.
\b
\m 
\v 34 ئىبراھىمدىن ئىسھاق تۆرەلدى. ئىسھاقنىڭ ئوغۇللىرى ئەساۋ بىلەن ئىسرائىل ئىدى. \f ◼ \fr 1:34 \ft \bd «ئىسرائىل»\bd* ــ تۇنجى ئىسمى ياقۇپ، ئەلۋەتتە.\f*  \x ◘ \xo 1:34 \xt يار. 25‏:24-27؛ 35‏:27-29\x*
\v 35 ئەساۋنىڭ ئوغۇللىرى ئېلىفاز، رېئۇئەل، يەئۇش، يائالام ۋە كوراھ ئىدى.
\v 36 ئېلىفازنىڭ ئوغۇللىرى تېمان، ئومار، زەفى، گاتام، كېناز، تىمنا ۋە ئامالەك ئىدى. \f ◼ \fr 1:36 \ft \bd «زەفى»\bd* ــ ياكى «زەفو» ــ «يار.» 11:36نى كۆرۈڭ. \bd «تىمنا ۋە ئامالەك»\bd* ــ باشقا بىرخىل تەرجىمىسى: «تىمنادىن بولغان ئامالەك». «يار.» 12:36نى كۆرۈڭ.\f*
\v 37 رېئۇئەلنىڭ ئوغۇللىرى ناھات، زەراھ، شامماھ بىلەن مىززاھ ئىدى.
\b
\s1 سېئىرنىڭ ئەۋلادلىرى
\r يار. 36‏:20-30
\m 
\v 38 سېئىرنىڭ ئوغۇللىرى لوتان، شوبال، زىبىئون، ئاناھ، دىشون، ئېزەر ۋە دىشان ئىدى.
\v 39 ھورى بىلەن ھومام لوتاننىڭ ئوغۇللىرى ئىدى (تىمنا لوتاننىڭ سىڭلىسى ئىدى). \f ◼ \fr 1:39 \ft \bd «تىمنا لوتنانىڭ سىڭلىسى»\bd* ــ بۇ «تىمنا» بەلكىم 36-ئايەتتىكى «تىمنا». 36-ئايەتتىكى ئىزاھاتنى كۆرۈڭ.\f*
\v 40 شوبالنىڭ ئوغۇللىرى ئاليان، ماناھات، ئەبال، شەفى بىلەن ئونام ئىدى. زىبىئوننىڭ ئوغۇللىرى ئاياھ بىلەن ئاناھ ئىدى. \f ◼ \fr 1:40 \ft \bd «ئاليان»\bd* ــ ياكى «ئالۋان» ــ «يار.» 23:36نى كۆرۈڭ. \bd «شەفى»\bd* ــ ياكى «شېفو» ــ «يار.» 23:36نى كۆرۈڭ.\f*
\v 41 ئاناھنىڭ ئوغلى دىشون ئىدى. دىشوننىڭ ئوغۇللىرى ھامران، ئەشبان، ئىتران بىلەن كېران ئىدى. \f ◼ \fr 1:41 \ft \bd «ھامران»\bd* ــ «يار.» 23:36دە «ھەمدان».\f*
\v 42 ئېزەرنىڭ ئوغۇللىرى بىلھان، زائاۋان، يائاكان ئىدى. دىشاننىڭ ئوغۇللىرى ئۇز بىلەن ئارران ئىدى. \f ◼ \fr 1:42 \ft \bd «يائاكان»\bd* ــ «يار.» 27:36دە باشقا شەكلىدە «ئاكان» دەپ ئوقۇلىدۇ. \bd «دىشان»\bd* ــ بەزى كونا كۆچۈرمىلەردە «دىشون» تېپىلىدۇ. «دىشان» توغرىدۇر. 38-ئايەتنى ۋە «يار.» 28:36نى كۆرۈڭ.\f*
\b
\s1 ئېدوم پادىشاھلىرى
\r يار. 36‏:31-43
\m 
\v 43 ئىسرائىللارغا ھۆكۈمرانلىق قىلىدىغان پادىشاھ بولمىغان زامانلاردا، ئېدوم زېمىنىغا پادىشاھ بولغانلار مۇنۇ كىشىلەر: بېئورنىڭ ئوغلى بېلا؛ ئۇنىڭ پايتەختى دىنھاباھ دەپ ئاتىلاتتى.
\v 44 بېلا ئۆلگەندىن كېيىن بوزراھلىق زەراھنىڭ ئوغلى يوباب ئۇنىڭ ئورنىغا پادىشاھ بولدى.
\v 45 يوباب ئۆلگەندىن كېيىن تەمانلارنىڭ يۇرتىدىن بولغان ھۇشام ئۇنىڭ ئورنىغا پادىشاھ بولدى.
\v 46 ھۇشام ئۆلگەندىن كېيىن بېدادنىڭ ئوغلى ھاداد ئۇنىڭ ئورنىغا پادىشاھ بولدى؛ ھاداد دېگەن بۇ ئادەم موئاب دالاسىدا مىدىيانلارنى تارمار قىلغان، ئۇنىڭ پايتەختىنىڭ ئىسمى ئاۋىت ئىدى.
\v 47 ھاداد ئۆلگەندىن كېيىن ماسرەكاھلىق ساملاھ ئۇنىڭ ئورنىغا پادىشاھ بولدى.
\v 48 ساملاھ ئۆلگەندىن كېيىن دەريا بويىدىكى رەھوبوتتىن كەلگەن سائۇل ئۇنىڭ ئورنىغا پادىشاھ بولدى. \f ◼ \fr 1:48 \ft \bd «دەريا»\bd* ــ بەلكىم ئەفرات دەرياسىنى كۆرسىتىدۇ.\f*
\v 49 سائۇل ئۆلگەندىن كېيىن ئاكبورنىڭ ئوغلى بائال-ھانان ئۇنىڭ ئورنىغا پادىشاھ بولدى.
\v 50 بائال-ھانان ئۆلگەندىن كېيىن ھاداد ئۇنىڭ ئورنىغا پادىشاھ بولدى. ئۇنىڭ پايتەختىنىڭ ئىسمى پاي ئىدى. ئۇنىڭ ئايالىنىڭ ئىسمى مەھېتابەل بولۇپ، مەي-زاھابنىڭ نەۋرىسى، ماترەدنىڭ قىزى ئىدى. \f ◼ \fr 1:50 \ft \bd «پاي»\bd* ــ ياكى «پائۇ» ــ «يار.» 39:36نى كۆرۈڭ.\f*
\v 51 ئاندىن ھاداد ئۆلدى.
\b
\s1 ئېدومدىكى قەبىلە باشلىقلىرى
\m 
\v 52 ئېدوملۇقلارنىڭ قەبىلە باشلىقلىرى: قەبىلە باشلىقى تىمنا، قەبىلە باشلىقى ئالىيا ، قەبىلە باشلىقى يەتەت، قەبىلە باشلىقى ئوھولىباماھ، قەبىلە باشلىقى ئەلاھ، قەبىلە باشلىقى پىنون، \f ◼ \fr 1:52 \ft \bd «ئېدوملۇقلارنىڭ قەبىلە باشلىقلىرى»\bd* ــ بۇنىڭ ئاۋۋالقى خەۋەرلىرىنى ئوقۇرمەنلەرگە قولايلىق يارىتىش ئۈچۈن ئەنەنىۋىي تەرتىپدىكى 1-ئايەتتىن 2-ئايەتكە كۆچۈرۈپ قويدۇق. \bd «ئالىيا»\bd* ــ ياكى «ئالۋا» ــ «يار.» 40:36نى كۆرۈڭ.\f*
\v 53 قەبىلە باشلىقى كېناز، قەبىلە باشلىقى تېمان، قەبىلە باشلىقى مىبزار،
\v 54 قەبىلە باشلىقى ماگدىيەل، قەبىلە باشلىقى ئىرام؛ بۇلارنىڭ ھەممىسى ئېدومدىكى قەبىلە باشلىقلىرىدۇر.
\b
\b
\c 2
\s1 ئىسرائىل ــ يەنى ياقۇپ ــ ئۇنىڭ ئەۋلادلىرى
\m 
\v 1 ئىسرائىلنىڭ ئوغۇللىرى رۇبەن، شىمېئون، لاۋىي، يەھۇدا، ئىسساكار، زەبۇلۇن،
\v 2 دان، يۈسۈپ، بىنيامىن، نافتالى، گاد ۋە ئاشىردىن ئىبارەت.
\b
\s1 يەھۇدانىڭ ئەۋلادلىرى
\m 
\v 3 يەھۇدانىڭ ئوغلى ئېر، ئونان ۋە شىلاھ ئىدى. بۇ ئۈچەيلەن قانائانلىق شۇيانىڭ قىزىدىن بولغان. يەھۇدانىڭ تۇنجى ئوغلى ئېر پەرۋەردىگارنىڭ نەزىرىدە رەزىل بولغانلىقىدىن پەرۋەردىگار ئۇنىڭ جېنىنى ئالغان.
\v 4 يەھۇداغا كېلىنى تاماردىن پەرەز بىلەن زەراھ تۆرەلگەن. يەھۇدانىڭ جەمئىي بەش ئوغلى بولغان. \f ◼ \fr 2:4 \ft \bd «...ېلىنى تاماردىن... تۆرەلگەن»\bd* ــ مۇشۇ قىزىق ۋەقە «يار.» 38-بابتا خاتىرىلىنىدۇ.\f*
\m 
\v 5 پەرەزنىڭ ئوغۇللىرى ھەزرون بىلەن ھامۇل ئىدى.
\v 6 زەراھنىڭ ئوغۇللىرى زىمرى، ئېتان، ھېمان، كالكول بىلەن دارا قاتارلىق بەش ئىدى.
\m 
\v 7 كارمىنىڭ ئوغلى ئاكار ئىدى. ئاكار بولسا خۇدا لەنەت قىلغان نەرسىنى ئېلىپ، «ئىسرائىلغا بالا-قازا كەلتۈرگۈچى» بولۇپ چىقتى. \f ◼ \fr 2:7 \ft \bd «ئاكار»\bd* ــ ئىبرانىي تىلىدا «ئاۋارە، كۈلپەت، بالا-قازا» دېگەننى بىلدۈرىدۇ. «يەشۇئا» 1:6 ۋە 25:7نى كۆرۈڭ. شۇ يەردە ئاكار «ئاكان» دەپ ئاتىلىدۇ.\f*
\v 8 ئېتاننىڭ ئوغلى ئازارىيا ئىدى.
\b
\s1 ھەزروننىڭ ئەۋلادلىرى
\m 
\v 9 ھەزروندىن تۆرەلگەن ئوغۇللار يەراھمىيەل، رام ۋە كالەب ئىدى. \f ◼ \fr 2:9 \ft \bd «كالەب»\bd* ــ «كالەب» مۇشۇ يەردە «كالۇباي» شەكلىدە. 18-ئايەتنى كۆرۈڭ.\f*
\v 10 ئاممىناداب رامدىن تۆرەلگەن؛ ناھشون ئاممىنادابتىن تۆرەلگەن؛ ناھشون يەھۇدا قەبىلىسىنىڭ باشلىقى بولغان.
\v 11 سالمون ناھشوندىن تۆرەلگەن؛ بوئاز سالموندىن تۆرەلگەن. \f ◼ \fr 2:11 \ft \bd «سالمون»\bd* ــ ياكى «سالما». «رۇت» 21:4نى كۆرۈڭ.\f*
\v 12 ئوبەد بوئازدىن تۆرەلگەن؛ يەسسە ئوبەددىن تۆرەلگەن.
\v 13 يەسسەنىڭ ئوغۇللىرىنىڭ تۇنجىسى ئېلىئاب، ئىككىنچىسى ئابىناداب، ئۈچىنچىسى شىمىيا، \f ◼ \fr 2:13 \ft \bd «شىمىيا»\bd* ــ «1سام.» 13:17دە «شامماھ».\f*
\v 14 تۆتىنچىسى نەتانەل، بەشىنچىسى رادداي،
\v 15 ئالتىنچىسى ئوزەم، يەتتىنچىسى داۋۇت ئىدى.
\v 16 زەرۇئىيا بىلەن ئابىگائىل ئۇلارنىڭ سىڭلىسى ئىدى. زەرۇئىيانىڭ ئابىشاي، يوئاب ۋە ئاساھەل دېگەن ئۈچ ئوغلى بار ئىدى. \f ◼ \fr 2:16 \ft \bd «ئابىشاي»\bd* ــ ياكى «ئابشاي».\f*
\v 17 ئاماسا ئابىگائىلدىن تۆرەلدى؛ ئاماسانىڭ ئاتىسى ئىسمائىللاردىن بولغان يەتەر ئىدى. \f ◼ \fr 2:17 \ft \bd «ئاماسانىڭ ئاتىسى ئىسمائىللاردىن بولغان يەتەر»\bd* ــ «2سام.» 25:17نى كۆرۈڭ. يەتەر (ئىترا) بەلكىم ئەسلىدە ئىسمائىللار ئارىسىدا تۇغۇلغان ياكى تۇرغانىدى.\f*
\b
\s1 كالەبنىڭ ئەۋلادلىرى
\m 
\v 18 كالەب ئازۇباھ (يېرىئوت دەپمۇ ئاتىلىدۇ)تىن ئوغۇل كۆردى؛ \add ئازۇباھتىن\add* بولغان ئوغۇللىرى يەشەر، شوباب ۋە ئاردون ئىدى. \f ◼ \fr 2:18 \ft \bd «كالەب ئازۇباھ (يېرىئوت دەپمۇ ئاتىلىدۇ)دىن ئوغۇل كۆردى»\bd* ــ ياكى «كالەب ئازۇباھدىن ئوغۇل تاپتى، شۇنداقلا يېرىئوتتىن ئوغۇل كۆردى». \bd «ئازۇباھتىن بولغان ئوغۇللىرى يەشەر...»\bd* ــ ئىبرانىي تىلىدا «ئۇنىڭدىن بولغان ئوغۇللىرى يەشەر...».\f*
\v 19 ئازۇباھ ئۆلگەندىن كېيىن كالەب يەنە ئەفراتنى ئالدى؛ ئەفرات ئۇنىڭغا خۇرنى تۇغۇپ بەردى.
\v 20 خۇردىن ئۇرى تۆرەلدى؛ ئۇرىدىن بەزالەل تۆرەلدى.
\m 
\v 21 كېيىن ھەزرون گىلېئادنىڭ ئاتىسى ماكىرنىڭ قىزىنى ئېلىپ بىر ياستۇققا باش قويۇۋىدى (ئۇ ئاتمىش ياشقا كىرگەندە ئۇنى ئالغان)، ئۇنىڭدىن سەگۇب تۆرەلدى.
\m 
\v 22 سەگۇبتىن يائىر تۆرەلدى؛ يائىرنىڭ گىلېئاد زېمىنىدا يىگىرمە ئۈچ شەھىرى بار ئىدى.
\v 23 گەشۇر بىلەن ئارام شۇ يۇرتتىكىلەردىن «يائىرنىڭ يېزا-قىشلاقلىرى»نى، كىناتنى ۋە ئۇنىڭغا قاراشلىق يېزىلار بولۇپ جەمئىي ئاتمىش يېزا-شەھەرنى تارتىۋالدى.
\m يۇقىرىقىلارنىڭ ھەممىسى گىلېئادنىڭ ئاتىسى ماكىرنىڭ ئەۋلادلىرىدۇر.
\m 
\v 24 ھەزرون كالەب-ئەفراتاھدا ئۆلگەندىن كېيىن، ئايالى ئابىياھ ئۇنىڭغا ئاشخورنى تۇغدى؛ ئاشخور تەكوئانىڭ ئاتىسى ئىدى.
\b
\s1 يەراھمىيەلنىڭ ئەۋلادلىرى
\m 
\v 25 ھەزروننىڭ تۇنجى ئوغلى يەراھمىيەلنىڭ ئوغۇللىرى رام، بۇناھ، ئورەن، ئوزەم ۋە ئاخىياھ ئىدى.
\v 26 يەراھمىيەلنىڭ ئاتاراھ دېگەن يەنە بىر ئايالى بار ئىدى، ئۇ ئونامنىڭ ئانىسى ئىدى.
\v 27 يەراھمىيەلنىڭ تۇنجى ئوغلى رامنىڭ ئوغۇللىرى مائاز، يامىن ۋە ئېكەر ئىدى.
\v 28 ئونامنىڭ ئوغۇللىرى شامماي بىلەن يادا ئىدى؛ شامماينىڭ ئوغۇللىرى ناداب بىلەن ئابىشۇر ئىدى.
\v 29 ئابىشۇرنىڭ ئايالىنىڭ ئىسمى ئابىھايىل بولۇپ، ئابىھايىلدىن ئۇنىڭغا ئاھبان بىلەن مولىد تۆرەلدى.
\v 30 نادابنىڭ ئوغۇللىرى سەلەد بىلەن ئاپپايىم ئىدى؛ سەلەد تا ئۆلگۈچە ئوغۇل پەرزەنت كۆرمىگەن.
\v 31 يىشى ئاپپايىمنىڭ ئوغلى؛ شېشان يىشىنىڭ ئوغلى؛ ئاخلاي شېشاننىڭ ئوغلى ئىدى.
\v 32 شامماينىڭ ئىنىسى يادانىڭ ئوغۇللىرى يەتەر بىلەن يوناتان ئىدى؛ يەتەر تاكى ئۆلگۈچە ئوغۇل پەرزەنت كۆرمىگەن.
\v 33 پەلەت بىلەن زازا يوناتاننىڭ ئوغۇللىرى ئىدى. يۇقىرىقىلارنىڭ ھەممىسى يەراھمىيەلنىڭ ئەۋلادلىرىدۇر.
\v 34 شېشان قىز پەرزەنت كۆرۈپ، ئوغۇل پەرزەنت كۆرمىگەنىدى؛ شېشاننىڭ مىسىرلىق يارخا دەيدىغان بىر مالىيى بار ئىدى.
\v 35 شېشان قىزىنى مالىيى يارخاغا خوتۇنلۇققا بەرگەن، ئۇنىڭدىن يارخاغا ئاتتاي تۆرەلگەن.
\v 36 ئاتتايدىن ناتان؛ ناتاندىن زاباد تۆرەلگەن.
\v 37 زابادتىن ئىفلال؛ ئىفلالدىن ئوبەد تۆرەلگەن.
\v 38 ئوبەدتىن يەھۇ؛ يەھۇدىن ئازارىيا تۆرەلگەن.
\v 39 ئازارىيادىن ھەلەز؛ ھەلەزدىن ئەلئاساھ تۆرەلگەن.
\v 40 ئەلئاساھتىن سىسماي؛ سىسمايدىن شاللۇم تۆرەلگەن.
\v 41 شاللۇمدىن يەكامىيا؛ يەكامىيادىن ئەلىشاما تۆرەلگەن.
\b
\s1 كالەبنىڭ باشقا ئەۋلادلىرى
\m 
\v 42 يەراھمىيەلنىڭ ئىنىسى كالەبنىڭ ئوغۇللىرى تۆۋەندىكىلەر: مىشا ئۇنىڭ تۇنجى ئوغلى بولۇپ، زىفنىڭ ئاتىسى ئىدى؛ مارىشاھمۇ ئۇنىڭ ئوغلى بولۇپ، ھېبروننىڭ ئاتىسى ئىدى. \f ◼ \fr 2:42 \ft \bd «مارىشاھمۇ ئۇنىڭ ئوغلى بولۇپ، ھېبروننىڭ ئاتىسى ئىدى»\bd* ــ بۇ ئايەتنىڭ ئىككىنچى قىسمىنى چۈشىنىش تەس، باشقا تەرجىمىلىرى ئۇچرىشى مۇمكىن.\f*
\v 43 ھېبروننىڭ ئوغۇللىرى كوراھ، تاپپۇئاھ، رەكەم ۋە شېما ئىدى.
\v 44 شېمادىن راھام تۆرەلگەن؛ ئۇ يوركېئامنىڭ ئاتىسى ئىدى؛ شامماي رەكەمدىن تۆرەلگەن.
\v 45 مائون شامماينىڭ ئوغلى؛ مائون بەيت-زۇرنىڭ ئاتىسى ئىدى.
\v 46 كالەبنىڭ توقىلى ئەفاھدىن ھاران، موزا ۋە گازەز تۆرەلگەن. ھاراندىن گازەز تۆرەلگەن.
\m 
\v 47 ياخداينىڭ ئوغۇللىرى رەگەم، يوتام، گەشان، پەلەت، ئەفاھ ۋە شائافلار ئىدى.
\v 48 كالەبنىڭ توقىلى مائاكاھدىن شېبەر بىلەن تىرخاناھ تۆرەلگەن؛
\v 49 ئۇنىڭدىن يەنە مادمانناھنىڭ ئاتىسى شائاف، ماكبىنانىڭ ئاتىسى ۋە گىبېئاھنىڭ ئاتىسى شىۋا تۆرەلگەن. ئاكساھ كالەبنىڭ قىزى ئىدى.
\m 
\v 50 يۇقىرىقىلارنىڭ ھەممىسى كالەبنىڭ ئەۋلادلىرى.
\m ئەفراتاھنىڭ تۇنجى ئوغلى خۇرنىڭ ئوغۇللىرى: كىرىئات-يېئارىمنىڭ ئاتىسى شوبال، \f ◼ \fr 2:50 \ft \bd «ئەفراتاھ»\bd* ــ ئىبرانىي تىلىدا «ئەفرات» ئۇنىڭ قىسقارتىلغان شەكلىدۇر. 19-ئايەتنى كۆرۈڭ. \bd «خۇرنىڭ ئوغۇللىرى»\bd* ــ ئىبرانىي تىلىدا «خۇرنىڭ ئوغلى» ــ مۇشۇ يەردە بىرنەچچە ئوغۇللىرىنى ئۆز ئىچىگە ئالىدۇ.\f*
\v 51 بەيت-لەھەمنىڭ ئاتىسى سالما، بەيت-گادەرنىڭ ئاتىسى خارەف ئىدى.
\m 
\v 52 كىرىئات-يېئارىمنىڭ ئاتىسى شوبالنىڭ ئەۋلادلىرى: خاروئەھ ھەمدە ماناخاتلارنىڭ يېرىمى ئىدى. \f ◼ \fr 2:52 \ft \bd «ماناخاتلار»\bd* ــ ياكى «مەنۇخىيلارنىڭ»\f*
\m 
\v 53 كىرىئات-يېئارىم جەمەتلىرىدىكىلەر ئىترىيلەر، پۇتىيلار، شۇماتىيلار، مىشرائىيلار بولۇپ، بۇ جەمەتلەردىن يەنە زوراتىيلار بىلەن ئەشتايولىيلار ئايرىلىپ چىققان.
\v 54 سالمانىڭ ئەۋلادلىرى بەيت-لەھەم بىلەن نىتوفاتلار، ئاتروت-بەيت-يوئابلار، ماناھاتلارنىڭ يېرىم قىسمى، زورىيلار،
\v 55 يابەزدە ئولتۇراقلىشىپ قالغان تەۋرات خەتتاتلىرى، يەنى تىراتىيلار، شىمياتىيلەر بىلەن سۇكاتىيلار ئىدى. بۇلارنىڭ ھەممىسى كېنىيلەر بولۇپ، رەكاب جەمەتىنىڭ بوۋىسى خاماتنىڭ ئەۋلادلىرىدىن ئىدى. \f ◼ \fr 2:55 \ft \bd «تەۋرات خەتتاتلىرى»\bd* ــ بەلكىم خەلقنىڭ خىزمىتىدە بولۇپ تەۋرات كۆچۈرمىلىرىنى يېزىپ چىققۇچىلار ئىدى. \bd «رەكاب جەمەتىنىڭ...»\bd* ــ ياكى «بەيت-رەكابنىڭ...».\f*
\b
\b
\c 3
\s1 داۋۇتنىڭ ئوغۇللىرى
\m 
\v 1 داۋۇتنىڭ ھېبروندا تۇغۇلغان ئوغۇللىرى: تۇنجى ئوغلى ئامنون بولۇپ، يىزرەئەللىك ئاخىنوئامدىن بولغان؛ ئىككىنچى ئوغلى دانىيال كارمەللىك ئابىگائىلدىن بولغان؛
\v 2 ئۈچىنچى ئوغلى ئابشالوم گەشۇرنىڭ پادىشاھى تالماينىڭ قىزى مائاكاھدىن بولغان؛ تۆتىنچى ئوغلى ئادونىيا بولۇپ، ھاگگىتتىن بولغانىدى؛
\v 3 بەشىنچى ئوغلى شەفاتىيا بولۇپ، ئابىتالدىن بولغانىدى؛ ئالتىنچى ئوغلى ئىترىيام بولۇپ، ئۇنىڭ ئايالى ئەگلاھدىن بولغانىدى.
\v 4 بۇ ئالتە ئوغۇل داۋۇتتىن ھېبروندا تۆرەلگەن؛ ئۇ ھېبروندا يەتتە يىل ئالتە ئاي، يېرۇسالېمدا بولسا ئوتتۇز ئۈچ يىل سەلتەنەت قىلغان.
\v 5 يېرۇسالېمدا ئۇنىڭغا ئاممىيەلنىڭ قىزى بات-شۇئادىن بۇ تۆتەيلەن تۆرەلگەن: ئۇلار شىمىيا، شوباب، ناتان ۋە سۇلايمان ئىدى. \f ◼ \fr 3:5 \ft \bd «بات-شۇئا»\bd* ــ ياكى «بات-شېبا» ــ «1سام.» 3:11نى كۆرۈڭ.\f*
\m 
\v 6 يەنە ئىبھار، ئەلىشاما، ئەلىفەلەت، \f ◼ \fr 3:6 \ft \bd «ئەلىشاما»\bd* ــ ياكى «ئەلىشۇئا» ــ 5:14نى كۆرۈڭ. \bd «ئەلىفەلەت»\bd* ــ ياكى «ئەلپەلەت» ــ 5:14نى كۆرۈڭ.\f*
\v 7 نوگاھ، نەفەگ، يافىيا،
\v 8 ئەلىشاما، ئەلىيادا، ئەلىفەلەت قاتارلىق توققۇز ئوغۇل بولغان.
\v 9 بۇلارنىڭ ھەممىسى داۋۇتنىڭ ئوغۇللىرى ئىدى؛ ئۇنىڭدىن باشقا توقاللىرىدىن بولغان ئوغۇللار بار ئىدى؛ تامار ئۇلارنىڭ سىڭلىسى ئىدى.
\b
\s1 سۇلايماننىڭ ئەۋلادلىرى
\m 
\v 10 سۇلايماننىڭ ئوغلى رەھوبوئام، رەھوبوئامنىڭ ئوغلى ئابىيا، ئابىيانىڭ ئوغلى ئاسا، ئاسانىڭ ئوغلى يەھوشافات،
\v 11 يەھوشافاتنىڭ ئوغلى يورام، يورامنىڭ ئوغلى ئاھازىيا، ئاھازىيانىڭ ئوغلى يوئاش، \f ◼ \fr 3:11 \ft \bd «يورام»\bd* ــ بەزى يەرلەردە «يەھورام» دېيىلىدۇ.\f*
\v 12 يوئاشنىڭ ئوغلى ئامازىيا، ئامازىيانىڭ ئوغلى ئازارىيا، ئازارىيانىڭ ئوغلى يوتام،
\v 13 يوتامنىڭ ئوغلى ئاھاز، ئاھازنىڭ ئوغلى ھەزەكىيا، ھەزەكىيانىڭ ئوغلى ماناسسەھ،
\v 14 ماناسسەھنىڭ ئوغلى ئامون، ئاموننىڭ ئوغلى يوسىيا ئىدى.
\v 15 يوسىيانىڭ ئوغۇللىرى: تۇنجى ئوغلى يوھانان، ئىككىنچى ئوغلى يەھوئاكىم، ئۈچىنچى ئوغلى زەدەكىيا، تۆتىنچى ئوغلى شاللۇم ئىدى.
\v 16 يەھوئاكىمنىڭ ئوغۇللىرى: ئوغلى يەكونىياھ بىلەن ئوغلى زەدەكىيا. \f ◼ \fr 3:16 \ft \bd «يەكونىياھ»\bd* ــ باشقا شەكلى «يەھوئاكىن».\f*
\b
\s1 پادىشاھ جەمەتىنىڭ نەسەبنامىسى ــ سۈرگۈن بولغاندىن كېيىن
\m 
\v 17 سۈرگۈن قىلىنغان يەكونىياھنىڭ ئوغۇللىرى: ــ شېئالتىئەل ئۇنىڭ ئوغلى ئىدى؛ \f ◼ \fr 3:17 \ft \bd «شېئالتىئەل»\bd* ــ باشقا شەكلى «سالاتىئەل».\f*
\v 18 يەنە مالقىرام، پەداياھ، شەناززار، يەكامىيا، ھوشاما ۋە نەبادىيا ئىدى.
\m 
\v 19 پەداياھنىڭ ئوغۇللىرى زەرۇببابەل بىلەن شىمەي ئىدى؛ زەرۇببابەلنىڭ پەرزەنتلىرى: ــ مەشۇللام بىلەن ھانانىيا ۋە ئۇلارنىڭ سىڭلىسى شېلومىت ئىدى؛
\v 20 ئۇنىڭ يەنە ھاشۇباھ، ئوھەل، بەرەكىيا، ھاسادىيا، يۇشاب-ھەسەد قاتارلىق بەش ئوغلى بار ئىدى.
\m 
\v 21 ھانانىيانىڭ ئوغۇللىرى پىلاتىيا ۋە يەشايا ئىدى؛ ئۇنىڭ ئەۋلادلىرى يەنە رېفايانىڭ ئوغۇللىرى، ئارناننىڭ ئوغۇللىرى، ئوبادىيانىڭ ئوغۇللىرى ۋە شېكانىيانىڭ ئوغۇللىرى ئىدى.
\v 22 شېكانىيانىڭ ئەۋلادلىرى مۇنۇلار: ئۇنىڭ ئوغلى شېمايا؛ شېمايانىڭ ئوغۇللىرى ھاتتۇش، يىگېئال، بارىيا، نېئارىيا، شافات بولۇپ جەمئىي ئالتە ئىدى. \f ◼ \fr 3:22 \ft \bd «يىگېئال»\bd* ــ ياكى «ئىگال».\f*
\v 23 نېئارىيانىڭ ئوغۇللىرى ئەليويىناي، ھەزەكىيا، ئازرىكام بولۇپ جەمئىي ئۈچ ئىدى.
\v 24 ئەليويىناينىڭ ئوغۇللىرى خوداۋىيا، ئەلىياشىب، پەلايا، ئاككۇب، يوھانان، دېلايا، ئانانى بولۇپ جەمئىي يەتتە ئىدى.
\b
\b
\c 4
\s1 يەھۇدا ئەۋلادلىرىنىڭ تەكرار بايان قىلىنىشى
\m 
\v 1 يەھۇدانىڭ ئوغۇللىرى پەرەز، ھەزرون، كارمى، خۇر ۋە شوبال ئىدى.
\v 2 شوبالنىڭ ئوغلى رېئايادىن جاھات تۆرەلدى؛ جاھاتتىن ئاخۇماي بىلەن لاخاد تۆرەلدى. بۇلار زوراتىي جەمەتىدىن ئىدى.
\v 3 ئېتامنىڭ ئوغۇللىرى يىزرەئەل، ئىشما، ئىدباش ئىدى؛ ئۇلارنىڭ سىڭلىسىنىڭ ئىسمى ھازىلىلپونى ئىدى. \f ◼ \fr 4:3 \ft \bd «ئېتامنىڭ ئوغۇللىرى يىزرەئەل،...»\bd* ــ ياكى «ئېتامنىڭ ئاتىسىدىن بولغان: يىزرەئەل،...» (كۆپ كونا كۆچۈرمىلەردە «ئاتىسى» دېيىلىدۇ). مۇشۇ يەردە بىر قىسىم قەدىمكى تەرجىمە نۇسخىلىرىدىن پايدىلىنىپ «ئوغۇللىرى» دەپ ئالدۇق.\f*
\v 4 گەدورنىڭ ئاتىسى پەنۇئەل؛ خۇشاھنىڭ ئاتىسى ئېزەر ئىدى؛ بۇلارنىڭ ھەممىسى بەيت-لەھەمنىڭ ئاتىسى بولغان ئەفراتاھنىڭ تۇنجى ئوغلى خۇردىن تۆرەلگەن.
\m 
\v 5 تەكوئانىڭ ئاتىسى ئاشخورنىڭ ھېلاھ ۋە نائاراھ دېگەن ئىككى ئايالى بار ئىدى.
\v 6 نائاراھ ئاشخورغا ئاخۇززام، ھەفەر، تەمەنى، ئاخاشتارىنى تۇغۇپ بەردى؛ بۇلارنىڭ ھەممىسى نائاراھنىڭ ئوغۇللىرى.
\v 7 ھېلاھنىڭ ئوغۇللىرى زەرەت، زوھار بىلەن ئەتنان ۋە
\v 8 كوز ئىدى؛ كوزدىن ئانوب، ھاززىبىبا بىلەن خارۇمنىڭ ئوغلى ئاخارھەلنىڭ جەمەتلىرى تۆرەلدى.
\m 
\v 9 يابەز ئۆز قېرىنداشلىرى ئىچىدە ھەممىدىن بەك ھۆرمەتلىك ئىدى، ئانىسى: «تۇغۇتى ئۈستىدە بەك ئازاپلاندىم» دەپ ئۇنىڭغا يابەز دېگەن ئىسىمنى قويغان. \f ◼ \fr 4:9 \ft \bd «يابەز ئۆز قېرىنداشلىرى ئىچىدە... : «تۇغۇتى ئۈستىدە بەك ئازاپلاندىم» دەپ ئۇنىڭغا يابەز دېگەن ئىسىمنى قويغان»\bd* ــ يابەزنىڭ يەھۇدا جەمەتىنىڭ قايسى ئائىلىسىدىن چىققانلىقى توغرۇلۇق باشقا خەۋىرىمىز يوق. كورنىڭ ئائىلىسىدىن بولۇشى مۇمكىن (8-ئايەتنى كۆرۈڭ). ئىبرانىي تىلىدا «ئازاب» ۋە «يابەز» دېگەننىڭ تەلەپپۇزى يېقىن.\f*
\v 10 يابەز ئىسرائىلنىڭ خۇداسىغا نىدا قىلىپ: «مېنى ناھايىتى كۆپ بەرىكەتلىگەن بولساڭ، زېمىنىمنى كېڭەيتسەڭ، قولۇڭ بىلەن مېنى يۆلەپ، بالا-قازادىن ساقلاپ، ماڭا ئازاب-ئوقۇبەتنى كۆرسەتمىگەيسەن!» ــ دەپ تىلىدى. خۇدا ئۇنىڭ تىلىگىنى ئىجابەت ئەيلىدى.
\m 
\v 11 شۇخاھنىڭ ئىنىسى كېلۇبتىن مېخىر تۆرەلگەن؛ مېخىر ئېشتوننىڭ ئاتىسى ئىدى.
\v 12 ئېشتوندىن بەيت-رافا، پاسېئاھ ۋە ئىر-ناھاشنىڭ ئاتىسى تېخىنناھ تۆرەلدى؛ بۇلارنىڭ ھەممىسى رىكاھلىقلار ئىدى. \f ◼ \fr 4:12 \ft \bd «ئىر-ناھاشنىڭ ئاتىسى»\bd* ــ ياكى «ناھاش شەھىرىدىكىلەرنىڭ ئاتىسى».\f*
\m 
\v 13 كېنازنىڭ ئوغلى ئوتنىيەل بىلەن سېرايا ئىدى؛ ئوتنىيەلنىڭ ئوغلى خاتات بىلەن مېئونوتاي ئىدى.
\v 14 مېئونوتايدىن ئوفراھ تۆرەلدى. سېرايادىن «ھۈنەرۋەنلەر جىلغىسى»دىكىلەرنىڭ ئەجدادى بولغان يوئاب تۆرەلدى (ئۇلار ئەسلىدە ھۈنەرۋەنلەر ئىدى). \f ◼ \fr 4:14 \ft \bd «ھۈنەرۋەنلەر جىلغىسى»\bd* ــ ئىبرانىي تىلىدا «گې-خاراشىم».\f*
\v 15 يەفۇننەھنىڭ ئوغلى كالەبنىڭ ئوغۇللىرى ئىرۇ، ئېلاھ بىلەن نائام ئىدى؛ ئېلاھنىڭ ئوغلى كېناز ئىدى.
\v 16 يەھاللىلەلنىڭ ئوغۇللىرى زىف بىلەن زىفاھ، تىرىيا بىلەن ئاسارىيەل ئىدى.
\v 17‏-18 ئەزرانىڭ ئوغۇللىرى: ــ يەتەر، مېرەد، ئېفەر ۋە يالونلار؛ مېرەد پىرەۋننىڭ قىزى بىتىيانى ئالدى؛ ئۇ ھامىلىدار بولۇپ مەرىيەم، شامماي بىلەن ئېشتېموئانىڭ ئاتىسى ئىشباھنى تۇغدى. بۇلار بىتىيادىن بولغان ئوغۇللار. مېرەدنىڭ يەھۇدالاردىن بولغان ئايالى بولسا گەدورنىڭ ئاتىسى يەرەدنى، سوكوھنىڭ ئاتىسى ھەبەر بىلەن زانوئاھنىڭ ئاتىسى يەكۇتىيەلنى تۇغدى.
\m 
\v 19 ناھامنىڭ سىڭلىسى خودىيانىڭ ئايالىدىن گارمىلىق كېئىلاھنىڭ ئاتىسى بىلەن مائاكات جەمەتىدىن بولغان ئېشتېموئانىڭ ئاتىسى تۆرەلگەن.
\m 
\v 20 شىموننىڭ ئوغۇللىرى ئامنون ۋە رىنناھ، بەن-ھانان بىلەن تىلون ئىدى.
\m يىشىنىڭ ئوغۇللىرى زوھەت بىلەن بىن-زوھەت ئىدى.
\m 
\v 21 شېلاھ يەھۇدانىڭ ئوغلى ئىدى؛ ئۇنىڭدىن تۆرەلگەن لېكاھنىڭ ئاتىسى ئېر، مارەشاھنىڭ ئاتىسى لائاداھ ۋە بەيت-ئاشبىيادا ئولتۇراقلاشقان چەكمەن توقۇغۇچىلارنىڭ جەمەتلىرى
\v 22 ۋە يەنە يوكىم، كوزىبالىقلار، يوئاش بىلەن ساراف (بۇلار ئىككىسى موئاب يۇرتىغا ھۆكۈمرانلىق قىلغان) ۋە ياشۇبى-لەھەملەرمۇ بار ئىدى (بۇلارنىڭ ھەممىسى قەدىمكى خاتىرىلەردۇر).
\v 23 بۇلار نېتايىم ۋە گەدەراھدا ئولتۇراقلاشقان بولۇپ، كۇلالچىلار ئىدى؛ ئۇلار شۇ يەردە تۇرۇپ پادىشاھنىڭ خىزمىتىدە بولاتتى.
\b
\s1 شىمېئوننىڭ ئەۋلادلىرى
\m 
\v 24 نەمۇئەل ۋە يامىن، يارىب، زەراھ بىلەن سائۇل شىمېئوننىڭ ئوغۇللىرى ئىدى. \f ◼ \fr 4:24 \ft \bd «نەمۇئەل»\bd* ــ «يار.» 10:46دە «يەمۇئەل».\f*
\v 25 شاللوم سائۇلنىڭ ئوغلى؛ مىبسام شاللومنىڭ ئوغلى، مىشما مىبسامنىڭ ئوغلى ئىدى.
\v 26 مىشمانىڭ ئەۋلادلىرى تۆۋەندىكىلەر: ــ مىشمانىڭ ئوغلى خاممۇئىل؛ خاممۇئىلنىڭ ئوغلى زاككۇر؛ زاككۇرنىڭ ئوغلى شىمەي ئىدى.
\v 27 شىمەينىڭ ئون ئالتە ئوغلى، ئالتە قىزى بار ئىدى؛ ئۇنىڭ ئاكا-ئىنىلىرىنىڭ پەرزەنتى كۆپ بولمىغاچقا، ئۇلارنىڭ ھەرقايسىسىنىڭ جەمەتىنىڭ پەرزەنتلىرى يەھۇدا جەمەتىنىڭكىدەك ئۇنداق كۆپ بولمىغان.
\v 28 ئۇلار بەئەر-شېبا، مولاداھ، ھازار-شۇئال،
\v 29 بىلھاھ، ئېزەم، تولاد،
\v 30 بېتۇئەل، خورماھ، زىكلاگ،
\v 31 بەيت-ماركابوت، ھازار-سۇسىم، بەيت-بىرى ۋە شائارائىمغا ماكانلاشقانىدى. تاكى داۋۇت پادىشاھنىڭ دەۋرىگىچە بۇلارنىڭ ھەممىسى ئۇلارنىڭ شەھەرلىرى ئىدى.
\v 32 ئۇلار ئولتۇراقلاشقان جايلار ئېتام، ئايىن، رىممون، توكەن ۋە ئاشان قاتارلىق بەش شەھەرنىمۇ ئۆز ئىچىگە ئالغان.
\v 33 ۋە بۇ شەھەرلەرنىڭ ئۆپچۈرىسىدىكى بارلىق يېزا-كەنتلەر تاكى بائالغا قەدەر شۇلارغا قارايتتى. بۇلار بولسا ئۇلار ماكانلاشقان جايلار بولۇپ، ئۇلارنىڭ ئۆز نەسەبنامىلىرىمۇ بار ئىدى. \f ◼ \fr 4:33 \ft \bd «بائالغا قەدەر...»\bd* ــ ياكى «بائالاتقا قەدەر...».\f*
\m 
\v 34 \add ئۇلارنىڭ جەمەت باشلىرى\add* مېشوباب، ياملەك، ئامازىيانىڭ ئوغلى يوشاھ،
\v 35 يوئېل، يوسىبىيانىڭ ئوغلى يەھۇ (يوسىبىيا سېرايانىڭ ئوغلى، سېرايا ئاسىئەلنىڭ ئوغلى ئىدى)،
\v 36 ئەليويىناي، يائاكوباھ، يەشوھايا، ئاسايا، ئادىئەل، يەسىمىئەل، بىنايا
\v 37 ۋە شىفىنىڭ ئوغلى زىزالار ئىدى (شىفى ئاللوننىڭ ئوغلى، ئاللون يەدايانىڭ ئوغلى، يەدايا شىمرىنىڭ ئوغلى، شىمرى شېمايانىڭ ئوغلى ئىدى).
\v 38 يۇقىرىدا خاتىرىلەپ ئۆتۈلگەن ئىسىملارنىڭ ھەممىسى ھەرقايسى جەمەت باشلىرى ئىدى؛ بۇلارنىڭ جەمەتلىرىنىڭ ھەممىسى ناھايىتى گۈللەنگەنىدى.
\v 39 ئۇلار قوي پادىلىرىغا ئوتلاق ئىزلەپ تاكى گەدور ئېغىزىغىچە، يەنى جىلغىنىڭ كۈن چىقىش تەرىپىگىچە بارغانىدى.
\v 40 ئۇلار شۇ يەردە ياپيېشىل، ناھايىتى مۇنبەت بىر ئوتلاق تاپقان؛ ئۇ يەر تولىمۇ كەڭ، ھەم تازا ھەم تىنچ ئىدى. ئىلگىرى شۇ يەردە ئولتۇراقلاشقانلار ھامدىكىلەردىن ئىكەن.
\m 
\v 41 يۇقىرىدا تىلغا ئېلىپ ئۆتۈلگەن كىشىلەر يەھۇدانىڭ پادىشاھى ھەزەكىيانىڭ زامانىدا شۇ \add ھامدىكىلەرنىڭ\add* چېدىرلىرىغا ۋە ئۇ يەرلەردە ئولتۇرۇشلۇق مىئونلۇقلارغا ھۇجۇم قىلىپ ئۇلارنى تامامەن يوقاتقانىدى، تاكى بۈگۈنگە قەدەر؛ ئۇلار شۇلارنىڭ يەرلىرىگە ماكانلاشتى، چۈنكى ئۇ يەرلەردە پادىلىرىنى باققۇدەك ئوتلاق بار ئىدى.
\m 
\v 42 شۇ چاغلاردا شىمېئونلاردىن يەنە بەش يۈز كىشى سېئىر تېغىغا قاراپ ماڭدى، ئۇلارنىڭ يولباشچىلىرى يىشىنىڭ ئوغۇللىرى پىلاتىيا، نېئارىيا، رېفايا بىلەن ئۇزرىئەل ئىدى؛
\v 43 ئۇلار قېچىپ تىرىك قالغان ئامالەكلەرنىمۇ ئۆلتۈرۈپ، بۈگۈنگە قەدەر شۇ يەردە ماكانلىشىپ ئۆتۈۋاتىدۇ.
\b
\b
\c 5
\s1 رۇبەننىڭ ئەۋلادلىرى
\m 
\v 1 ئىسرائىلنىڭ تۇنجى ئوغلى رۇبەننىڭ ئوغۇللىرى مۇنۇلار: ــ
\m (رۇبەن گەرچە تۇنجى ئوغۇل بولغىنى بىلەن، لېكىن \add ئاتىسىنىڭ توقىلى بىلەن\add* زىنا قىلغانلىقى ئۈچۈن، ئۇنىڭ چوڭ ئوغۇللۇق ھوقۇقى ئىسرائىلنىڭ ئوغلى بولغان يۈسۈپنىڭ ئوغۇللىرىغا ئۆتكۈزۈۋېتىلگەن. شۇڭا نەسەبنامە بويىچە ئۇ چوڭ ئوغۇل ھېسابلانمايدۇ. \f ◼ \fr 5:1 \ft \bd «(ئاتىسىنىڭ توقىلى بىلەن) زىنا قىلغانلىقى ئۈچۈن...»\bd* ــ ئىبرانىي تىلىدا «ئاتىسىنىڭ ياتقان ئورنىنى بۇلغىغىنى ئۈچۈن...» بىلەن ئىپادىلىنىدۇ. «يار.» 22:35نى كۆرۈڭ.\f*
\v 2 يەھۇدا قېرىنداشلىرى ئىچىدە ئۈستۈنلۈككە ئىگە بولغان بولسىمۇ ۋە ئىدارە قىلغۇچى ئۇنىڭدىن چىققان بولسىمۇ، لېكىن چوڭ ئوغۇللۇق ھوقۇقى يۈسۈپكە تەۋە بولۇپ كەتكەن): ــ \f ◼ \fr 5:2 \ft \bd «ئىدارە قىلغۇچى»\bd* ــ بەلكىم داۋۇت پادىشاھ ۋە ئۇنىڭ ئەۋلادلىرىنى كۆرسىتىدۇ.\f*
\m 
\v 3 ئىسرائىلنىڭ تۇنجىسى رۇبەننىڭ ئوغۇللىرى مۇنۇلار: ــ ھانوخ ۋە پاللۇ، ھەزرون ۋە كارمى.
\m 
\v 4 يوئېلنىڭ ئەۋلادلىرى مۇنۇلار: ــ \add يوئېلنىڭ\add* ئوغلى شېمايا، شېمايانىڭ ئوغلى گوگ، گوگنىڭ ئوغلى شىمەي،
\v 5 شىمەينىڭ ئوغلى مىكاھ، مىكاھنىڭ ئوغلى رېئايا، رېئايانىڭ ئوغلى بائال،
\v 6 بائالنىڭ ئوغلى بەئەراھ؛ بەئەراھ ئاسۇرىيە پادىشاھى تىلگات-پىلنەسەر تەرىپىدىن تۇتقۇن قىلىپ كېتىلگەن. ئۇ چاغدا ئۇ رۇبەن قەبىلىسىنىڭ باشلىقى ئىدى. \f ◼ \fr 5:6 \ft \bd «ئاسۇرىيە»\bd* ــ ئاسۇرىيە ئىبرانىي تىلىدا «ئاشۇر».\f*
\m 
\v 7 ئۇنىڭ ئىنىلىرى نەسەبنامىسىدە خاتىرىلەنگەندەك، جەمەتلىرىنىڭ تارىخى بويىچە يولباشچى بولغان يەئىيەل، زەكەرىيا ۋە بېلا دەپ پۈتۈلگەنىدى
\v 8 (بېلا ئازازنىڭ ئوغلى، ئازاز شېمانىڭ ئوغلى، شېما يوئېلنىڭ ئوغلى ئىدى). يوئېللار ئاروئەردە، نېبو ۋە بائال-مېئونغىچە سوزۇلغان جايلاردا تۇراتتى.
\v 9 ئۇلار يەنە كۈن چىقىشقا قاراپ تاكى ئېفرات دەرياسىنىڭ بۇ تەرىپىدىكى چۆلنىڭ كىرىش ئېغىزىغا قەدەر ئولتۇراقلاشتى؛ چۈنكى ئۇلارنىڭ گىلېئاد يۇرتىدىكى چارۋا ماللىرى كۆپىيىپ كەتكەنىدى.
\v 10 سائۇلنىڭ سەلتەنىتىنىڭ كۈنلىرىدە ئۇلار ھاگارىيلار بىلەن ئۇرۇش قىلىشتى؛ ھاگارىيلار ئۇلارنىڭ قولىدا مەغلۇپ بولغاندىن كېيىن ئۇلار گىلېئادنىڭ كۈن چىقىش تەرىپىدىكى پۈتۈن زېمىندا ھاگارىيلارنىڭ چېدىرلىرىدا ماكانلاشتى.
\b
\s1 گادنىڭ ئەۋلادلىرى
\m 
\v 11 ئۇلارنىڭ ئۇدۇلىدا گادنىڭ ئەۋلادلىرى تاكى سالىكاھغا قەدەر باشان زېمىنىغا ماكانلاشقانىدى.
\v 12 باشاندا ماكانلاشقانلاردىن قەبىلە باشلىقى يوئېل، مۇئاۋىن قەبىلە باشلىقى شافام بار ئىدى؛ يەنە ياناي بىلەن شافاتمۇ بار ئىدى.
\m 
\v 13 ئۇلارنىڭ ئۇرۇق-تۇغقانلىرى جەمەتنامىلەر بويىچە مىكائىل، مەشۇللام، شېبا، يوراي، ياكان، زىيا ۋە ئېبەر بولۇپ، جەمئىي يەتتە ئىدى.
\v 14 يۇقىرىدىكىلەرنىڭ ھەممىسى ئابىھايىلنىڭ ئوغۇللىرى ئىدى. ئابىھايىل خۇرىنىڭ ئوغلى، خۇرى ياروياھنىڭ ئوغلى، ياروياھ گىلېئادنىڭ ئوغلى، گىلېئاد مىكائىلنىڭ ئوغلى، مىكائىل يەشىشاينىڭ ئوغلى، يەشىشاي ياھدونىڭ ئوغلى، ياھدو بۇزنىڭ ئوغلى ئىدى؛
\v 15 گۇنىنىڭ نەۋرىسى، ئابدىئەلنىڭ ئوغلى ئاخى ئۇلارنىڭ جەمەت بېشى ئىدى.
\v 16 ئۇلار گىلېئادقا، باشانغا ۋە باشانغا تەۋە يېزا-كەنتلەرگە، شۇنداقلا پۈتكۈل شارون يايلىقىغا، تاكى تۆت چېتىگىچە ماكانلاشقانىدى.
\v 17 بۇلارنىڭ ھەممىسى يەھۇدا پادىشاھى يوتام ۋە ئىسرائىل پادىشاھى يەروبوئامنىڭ سەلتەنىتىنىڭ كۈنلىرىدە نەسەبنامىلەرگە پۈتۈلگەنىدى.
\m 
\v 18 رۇبەن، گاد قەبىلىلىرىنىڭ ۋە ماناسسەھ يېرىم قەبىلىسىنىڭ باتۇر، قالقان-قىلىچ تۇتالايدىغان، ئوقيا ئاتالايدىغان ھەم جەڭگە ماھىر قىرىق تۆت مىڭ يەتتە يۈز ئاتمىش جەڭگىۋار ئادىمى بار ئىدى.
\v 19 ئۇلار ھاگارىيلار، يەتۇرلار، نافىشلار ۋە نودابلار بىلەن جەڭ قىلغان.
\v 20 ئۇلار جەڭ قىلغاندا مەدەت تېپىپ، ھاگارىيلار ۋە ئۇلار بىلەن ئىتتىپاقداشلارنىڭ ھەممىسى ئۇلارنىڭ قولىغا تاپشۇرۇلغان؛ چۈنكى ئۇلار جەڭ ئۈستىدە خۇداغا نىدا قىلغان؛ ئۇلار ئۇنىڭغا تايانغاچقا، خۇدا ئۇلارنىڭ تىلىگىنى ئىجابەت قىلغان.
\m 
\v 21 ئۇلار يەنە دۈشمەننىڭ چارۋا-ماللىرىنى، جۈملىدىن ئەللىك مىڭ تۆگە، ئىككى يۈز ئەللىك مىڭ قوي، ئىككى مىڭ ئېشىكىنى ئولجا ئالغان ۋە يۈز مىڭ جاننى ئەسىر ئالغان.
\v 22 بۇ ئۇرۇش خۇدانىڭ نىيىتىدىن بولغاچقا، دۈشمەندىن ئۆلگەنلەر ناھايىتى كۆپ بولغان؛ سۈرگۈن قىلىنغۇچە ئۇلار شۇلارنىڭ يېرىنى ئىشغال قىلىپ تۇرغان.
\b
\s1 ماناسسەھنىڭ يېرىم قەبىلىسى
\m 
\v 23 ماناسسەھنىڭ يېرىم قەبىلىسىدىكىلەر باشاندىن بائال-ھەرمون، سېنىر، ھەرمون تېغىغا قەدەر بولغان زېمىندا يېيىلىپ ماكانلاشتى. ئۇلار زور كۆپەيگەن.
\v 24 ئۇلارنىڭ جەمەت باشلىقلىرى ئېفەر، ئىشى، ئەلىيەل، ئازرىئەل، يەرىمىيا، خوداۋىيا ۋە ياھدىيەل ئىدى؛ ئۇلارنىڭ ھەممىسى ناھايىتى باتۇر جەڭچىلەر، مەشھۇر مۆتىۋەرلەر، شۇنداقلا ھەرقايسىسى ئۆز جەمەتىگە جەمەت بېشى ئىدى.
\v 25 ئۇلار ئاتا-بوۋىلىرىنىڭ خۇداسىدىن يۈز ئۆرۈپ، بۇزۇقلۇق قىلىپ خۇدا ئەسلىدە ئۆزلىرى ئالدىدا يوقاتقان شۇ يەردىكى تائىپىلەرنىڭ ئىلاھلىرىغا ئەگىشىپ كەتتى. \f ◼ \fr 5:25 \ft \bd «بۇزۇقلۇق قىلىش»\bd* ــ ئىبرانىي تىلىدا «بۇزۇقلۇق قىلىش» «پاھىشىۋازلىق قىلىش» بىلەن ئىپادىلىنىدۇ. كۆچمە مەنىسى، خۇداغا ۋاپاسىزلىق قىلىپ بۇتلارنىڭ كەينىدىن مېڭىشتىن ئىبارەت. ئۇنىڭ ئۈستىگە بۇ بۇتپەرەسلىككە مۇناسىۋەتلىك «بۇتقا ئاتالغان پاھىشىۋازلىق» دېگەن ھەرىكەتلەرمۇ بار ئىدى.\f*
\v 26 شۇنىڭ بىلەن ئىسرائىلنىڭ خۇداسى ئاسۇرىيە پادىشاھى پۇل (يەنى ئاسۇرىيە پادىشاھى تىلگات-پىلنەسەر)نىڭ روھىنى قوزغىشى بىلەن، ئۇ ئۇلارنى، يەنى رۇبەن قەبىلىسىدىكىلەرنى، گاد قەبىلىسىدىكىلەرنى ۋە ماناسسەھ يېرىم قەبىلىسىدىكىلەرنى خالاھ، خابور ۋە خاراغا ھەم گوزان دەرياسى بويىغا سۈرگۈن قىلىپ ئېلىپ كەتتى؛ ئۇلارنىڭ ئەۋلادلىرى تاكى بۈگۈنگە قەدەر تېخىچە شۇ يەردە ماكانلىشىپ تۇرماقتا.
\b
\b
\c 6
\s1 لاۋىيلارنىڭ، جۈملىدىن باش كاھىنلارنىڭ نەسەبنامىسى
\m 
\v 1 لاۋىينىڭ ئوغۇللىرى گەرشون، كوھات ۋە مەرارى.
\v 2 كوھاتنىڭ ئوغلى ئامرام، يىزھار، ھېبرون ۋە ئۇززىئەل ئىدى.
\v 3 ئامرامنىڭ پەرزەنتلىرى ھارۇن، مۇسا ۋە مەريەم ئىدى. ھارۇننىڭ ئوغلى ناداب، ئابىھۇ، ئەلىئازار ۋە ئىتامار ئىدى. \f ◼ \fr 6:3 \ft \bd «مەريەم»\bd* ــ ئىبرانىي تىلىدا «ماريام».\f*
\m 
\v 4 ئەلىئازاردىن فىنىھاس، فىنىھاستىن ئابىشۇئا،
\v 5 ئابىشۇئادىن بۇككى، بۇككىدىن ئۇززى،
\v 6 ئۇززىدىن زەراھىيا، زەراھىيادىن مېرايوت،
\v 7 مېرايوتتىن ئامارىيا، ئامارىيادىن ئاخىتۇب،
\v 8 ئاخىتۇبتىن زادوك، زادوكتىن ئاخىمائاز،
\v 9 ئاخىمائازدىن ئازارىيا، ئازارىيادىن يوھانان،
\v 10 يوھاناندىن ئازارىيا (بۇ ئازارىيا يېرۇسالېمدا سۇلايمان سالغۇزغان مۇقەددەس ئۆيدە كاھىنلىق خىزمىتىدە بولغان)،
\v 11 ئازارىيادىن ئامارىيا، ئامارىيادىن ئاخىتۇب،
\v 12 ئاخىتۇبتىن زادوك، زادوكتىن شاللۇم،
\v 13 شاللۇمدىن ھىلقىيا، ھىلقىيادىن ئازارىيا،
\v 14 ئازارىيادىن سېرايا، سېرايادىن يەھوزاداك تۆرەلدى؛
\v 15 پەرۋەردىگار نېبوقادنەسارنىڭ ۋاستىسى بىلەن يەھۇدادىكىلەر بىلەن يېرۇسالېمدىكىلەرنى سۈرگۈن قىلىدىغان چاغدا، بۇ يەھوزاداكمۇ سۈرگۈن قىلىنغان.
\b
\s1 لاۋىينىڭ باشقا ئەۋلادلىرى
\m 
\v 16 لاۋىينىڭ ئوغلى گەرشوم، كوھات ۋە مەرارى. \f ◼ \fr 6:16 \ft \bd «گەرشوم»\bd* ــ ياكى «گەرشون».\f*
\m 
\v 17 گەرشومنىڭ ئوغۇللىرىنىڭ ئىسمى لىبنى ۋە شىمەي ئىدى.
\v 18 كوھاتنىڭ ئوغۇللىرى ئامرام، يىزھار، ھېبرون ۋە ئۇززىئەل ئىدى.
\v 19 مەرارىنىڭ ئوغۇللىرى ماھلى ۋە مۇشى ئىدى. بۇلار لاۋىيلارغا مەنسۇپ ھەرقايسى جەمەتلەر ئىچىدىكى ئائىلىلەر ئىدى.
\m 
\v 20 گەرشومنىڭ ئەۋلادلىرى تۆۋەندىكىچە: گەرشومنىڭ ئوغلى لىبنى، لىبنىنىڭ ئوغلى جاھات، جاھاتنىڭ ئوغلى زىمماھ،
\v 21 زىمماھنىڭ ئوغلى يوئاھ، يوئاھنىڭ ئوغلى ئىددو، ئىددونىڭ ئوغلى زەراھ، زەراھنىڭ ئوغلى يىياتىراي ئىدى.
\m 
\v 22 كوھاتنىڭ ئەۋلادلىرى تۆۋەندىكىچە: كوھاتنىڭ ئوغلى ئاممىناداب، ئاممىنادابنىڭ ئوغلى كوراھ، كوراھنىڭ ئوغلى ئاسسىر،
\v 23 ئاسسىرنىڭ ئوغلى ئەلكاناھ، ئەلكاناھنىڭ ئوغلى ئېبىئاساف، ئېبىئاسافنىڭ ئوغلى ئاسسىر،
\v 24 ئاسسىرنىڭ ئوغلى تاھات، تاھاتنىڭ ئوغلى ئۇرىئەل، ئۇرىئەلنىڭ ئوغلى ئۇززىيا، ئۇززىيانىڭ ئوغلى شائۇل ئىدى.
\m 
\v 25 ئەلكاناھنىڭ ئوغۇللىرى ئاماساي ۋە ئاخىموت، \f ◼ \fr 6:25 \ft \bd «ئەلكاناھنىڭ ئوغۇللىرى ئاماساي ۋە ئاخىموت،...»\bd* ــ تۆۋەندىكى ئىزاھاتنى كۆرۈڭ.\f*
\v 26 ئاخىموتنىڭ ئوغلى ئەلكاناھ، ئەلكاناھنىڭ ئوغلى زوفاي، زوفاينىڭ ئوغلى ناھات، \f ◼ \fr 6:26 \ft \bd «ئەلكاناھنىڭ ئوغۇللىرى ئاماساي ۋە ئاخىموت، ئاخىموتنىڭ ئوغلى ئەلكاناھ، ئەلكاناھنىڭ ئوغلى...»\bd* ــ (25-26ئايەتلەردە) ياكى «ئەلكاناھنىڭ ئوغۇللىرى ــ ئۇنىڭ (يەنى ئاخىموتنىڭ) ئوغلى ئەلكاناھ، ئەلكاناھنىڭ ئوغلى...». كونا كۆچۈرمىلەردە نەچچە ۋارىيانت بار.\f*
\v 27 ناھاتنىڭ ئوغلى ئېلىئاب، ئېلىئابنىڭ ئوغلى يەروھام، يەروھامنىڭ ئوغلى ئەلكاناھ ئىدى. \f ◼ \fr 6:27 \ft \bd «يەروھامنىڭ ئوغلى ئەلكاناھ ئىدى...»\bd* ــ گرېك تىلىدىكى تەرجىمىسى (LXX)دە: «ئەلكاناھنىڭ ئوغلى سامۇئىل» دېگەن سۆزلەر مۇشۇ يەردە قوشۇلىدۇ. دەرۋەقە، ئەلكاناھنىڭ ئوغلى سامۇئىل ئىدى («1سام.» 1:1-20نى كۆرۈڭ.\f*
\m 
\v 28 سامۇئىلنىڭ ئوغۇللىرى تۆۋەندىكىچە: تۇنجى ئوغلى يوئېل، ئىككىنچى ئوغلى ئابىيا ئىدى.
\m 
\v 29 مەرارىنىڭ ئەۋلادلىرى تۆۋەندىكىچە: مەرارىنىڭ ئوغلى ماھلى، ماھلىنىڭ ئوغلى لىبنى، لىبنىنىڭ ئوغلى شىمەي، شىمەينىڭ ئوغلى ئۇززا،
\v 30 ئۇززانىڭ ئوغلى شىمىيا، شىمىيانىڭ ئوغلى ھاگگىيا، ھاگگىيانىڭ ئوغلى ئاسايا ئىدى.
\b
\s1 داۋۇت نەغمە-ناۋا ئىشلىرىغا قويغان مەخسۇس ئادەملەر
\m 
\v 31 داۋۇت ئەھدە ساندۇقى ئوبدان ئورۇنلاشتۇرۇلغاندىن كېيىن پەرۋەردىگارنىڭ ئۆيىدە نەغمىچىلىك ئىشلىرىغا مەسئۇل بولۇشقا تۆۋەندىكى كىشىلەرنى قويدى. \f ◼ \fr 6:31 \ft \bd «ئەھدە ساندۇقى ئوبدان ئورۇنلاشتۇرۇلغان...»\bd* ــ ئىبرانىي تىلىدا «ئەھدە ساندۇقى ئاراملىققا قويۇلغان...» دېگەن سۆزلەر بىلەن ئىپادىلىنىدۇ.\f*
\v 32 ئۇلار تاكى سۇلايمان يېرۇسالېمدا پەرۋەردىگارنىڭ ئۆيىنى ياساتقانغا قەدەر، «جامائەت چېدىرى»نىڭ ئالدىدا كۈي ئېيتىش خىزمىتىنى ئۆتەپ كەلدى. ئۇلار ۋەزىپىسىنى بەلگىلەنگەن تەرتىپى بىلەن ئۆتىگەنىدى. \f ◼ \fr 6:32 \ft \bd «جامائەت چېدىرى»\bd* ــ ياكى «ئىبادەت ماكان-چېدىرى». «1پاد.» 4:8نى كۆرۈڭ.\f*
\v 33 تۆۋەندىكىلەر ۋەزىپە ئۆتىگەن ئادەملەر ۋە ئۇلارنىڭ ئەۋلادلىرى: ــ كوھاتنىڭ ئەۋلادلىرى ئىچىدە: ــ نەغمىچى ھېمان بار ئىدى. ھېمان يوئېلنىڭ ئوغلى، يوئېل سامۇئىلنىڭ ئوغلى ئىدى.
\v 34 سامۇئىل ئەلكاناھنىڭ ئوغلى، ئەلكاناھ يەروھامنىڭ ئوغلى، يەروھام ئەلىيەلنىڭ ئوغلى، ئەلىيەل توئاھنىڭ ئوغلى،
\v 35 توئاھ زۇفنىڭ ئوغلى، زۇف ئەلكاناھنىڭ ئوغلى، ئەلكاناھ ماھاتنىڭ ئوغلى، ماھات ئاماساينىڭ ئوغلى،
\v 36 ئاماساي ئەلكاناھنىڭ ئوغلى، ئەلكاناھ يوئېلنىڭ ئوغلى، يوئېل ئازارىيانىڭ ئوغلى، ئازارىيا زەفانىيانىڭ ئوغلى،
\v 37 زەفانىيا تاھاتنىڭ ئوغلى، تاھات ئاسسىرنىڭ ئوغلى، ئاسسىر ئېبىئاسافنىڭ ئوغلى، ئېبىئاساف كوراھنىڭ ئوغلى،
\v 38 كوراھ ئىزھارنىڭ ئوغلى، يىزھار كوھاتنىڭ ئوغلى، كوھات لاۋىينىڭ ئوغلى، لاۋىي ئىسرائىلنىڭ ئوغلى ئىدى.
\v 39 \add ھېماننىڭ\add* ئوڭ تەرىپىدە خىزمەتتە تۇرغان قېرىندىشى ئاساف ئىدى. ئاساف بولسا بەرەكىيانىڭ ئوغلى، بەرەكىيا شىمىيانىڭ ئوغلى،
\v 40 شىمىيا مىكائىلنىڭ ئوغلى، مىكائىل بائاسىيانىڭ ئوغلى، بائاسىيا مالكىيانىڭ ئوغلى، \f ◼ \fr 6:40 \ft \bd «بائاسىيا»\bd* ــ ياكى «مائاسىياھ».\f*
\v 41 مالكىيا ئېتنىنىڭ ئوغلى، ئېتنى زەراھنىڭ ئوغلى، زەراھ ئادايانىڭ ئوغلى،
\v 42 ئادايا ئېتاننىڭ ئوغلى، ئېتان زىمماھنىڭ ئوغلى، زىمماھ شىمەينىڭ ئوغلى،
\v 43 شىمەي جاھاتنىڭ ئوغلى، جاھات گەرشومنىڭ ئوغلى، گەرشوم لاۋىينىڭ ئوغلى ئىدى.
\m 
\v 44 \add ھېمان بىلەن ئاسافنىڭ\add* سول تەرىپىدە خىزمەتتە تۇرغان قېرىنداشلىرى مەرارىنىڭ ئەۋلادلىرىدىن ئېتانلار ئىدى. ئېتان بولسا كىشىنىڭ ئوغلى ئىدى، كىشى ئابدىنىڭ ئوغلى، ئابدى ماللۇقنىڭ ئوغلى،
\v 45 ماللۇق ھاشابىيانىڭ ئوغلى، ھاشابىيا ئامازىيانىڭ ئوغلى، ئامازىيا ھىلقىيانىڭ ئوغلى،
\v 46 ھىلقىيا ئامزىنىڭ ئوغلى، ئامزى بانىنىڭ ئوغلى، بانى شېمەرنىڭ ئوغلى،
\v 47 شېمەر ماھلىنىڭ ئوغلى، ماھلى مۇشىنىڭ ئوغلى، مۇشى مەرارىنىڭ ئوغلى، مەرارى لاۋىينىڭ ئوغلى ئىدى.
\b
\s1 ھارۇن ئەۋلادلىرىنىڭ ۋەزىپىلىرى
\m 
\v 48 ئۇلارنىڭ قالغان لاۋىي قېرىنداشلىرى بولسا ھەممىسى خۇدانىڭ ئۆيى، يەنى ئىبادەت چېدىرىدىكى \add باشقا\add* خىزمەتلەرنى بېجىرىشكە ئاتالغانىدى.
\m 
\v 49 ھارۇن ۋە ئۇنىڭ ئەۋلادلىرى بولسا خۇدانىڭ خىزمەتكارى مۇسانىڭ تاپىلىغىنىدەك كۆيدۈرمە قۇربانلىق سۇنۇلىدىغان قۇربانگاھتا قۇربانلىقلار سۇنۇپ، خۇشبۇيگاھتا خۇشبۇي يېقىپ، مۇقەددەسگاھدىكى بارلىق خىزمەتلەرنى ئادا قىلاتتى، شۇنداقلا ئىسرائىللار ئۈچۈن كەچۈرۈم-كەفارەت ئىشلىرىنى قىلاتتى. \f ◼ \fr 6:49 \ft \bd «مۇقەددەسگاھ»\bd* ــ ياكى «ئەڭ مۇقەددەس جاي». \bd «كەفارەت»\bd* ــ «گۇناھلارنى يېپىش» دېگەن گەپ.\f*
\m 
\v 50 ھارۇننىڭ ئەۋلادلىرى تۆۋەندىكىچە: ھارۇننىڭ ئوغلى ئەلىئازار، ئەلىئازارنىڭ ئوغلى فىنىھاس، فىنىھاسنىڭ ئوغلى ئابىشۇيا،
\v 51 ئابىشۇيانىڭ ئوغلى بۇككى، بۇككىنىڭ ئوغلى ئۇززى، ئۇززىنىڭ ئوغلى زەراھىيا،
\v 52 زەراھىيانىڭ ئوغلى مېرايوت، مېرايوتنىڭ ئوغلى ئامارىيا، ئامارىيانىڭ ئوغلى ئاخىتۇب،
\v 53 ئاخىتۇبنىڭ ئوغلى زادوك، زادوكنىڭ ئوغلى ئاخىمائاز ئىدى.
\b
\s1 ھارۇن ئەۋلادلىرىنىڭ شەھەرلىرى
\m 
\v 54 تۆۋەندىكىلەر ھارۇننىڭ ئەۋلادلىرىنىڭ ئۆز زېمىنى ئىچىدە ماكان تۇتۇپ ئولتۇرغان يەرلىرى: ــ كوھات جەمەتىنىڭ يەرلىرى بولسا (مۇشۇ يەرلەر چەك تاشلاش ئارقىلىق ئۇلارغا تەقسىم قىلىنغان): ــ \f ◼ \fr 6:54 \ft \bd «چەك تاشلانغاندا»\bd* ــ يەشۇئا پەيغەمبەر بولغان ۋاقتىدا، ئىسرائىلنىڭ ھەربىر قەبىلىسى ئىگىلەيدىغان يەرلەر چەك تاشلاش ئارقىلىق بېكىتىلگەنىدى «يەشۇئا» 21-بابنى كۆرۈڭ.\f*
\m 
\v 55 يەھۇدا زېمىنىدىكى ھېبرون ۋە ھېبروننىڭ تۆت ئەتراپىدىكى ئېتىزلىقلىرى ئۇلارغا تەقسىم قىلىنغان
\v 56 (لېكىن بۇ شەھەرنىڭ ئەتراپىدىكى ئوتلۇقلار ۋە شەھەرگە قاراشلىق يېزا-كەنتلەر بولسا يەفۇننەھنىڭ ئوغلى كالەبكە بېرىلدى).
\v 57 ھارۇننىڭ ئەۋلادلىرىغا «پاناھلىق شەھىرى» ھېبرون بېرىلدى؛ بۇنىڭدىن باشقا لىبناھ بىلەن ئۇنىڭغا تەۋە ئېتىزلىقلار، ياتتىر، ئېشتېموئا ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، \f ◼ \fr 6:57 \ft \bd «پاناھلىق شەھىرى»\bd* ــ «چۆل.» 6:35-34نى ۋە شۇ ئايەتلەردىكى ئىزاھاتلارنى كۆرۈڭ.\f*
\v 58 ھىلەن ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، دەبىر ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، \f ◼ \fr 6:58 \ft \bd «ھىلەن»\bd* ــ ياكى «ھىلەز» ياكى «ھولون» («يە.» 15:21).\f*
\v 59 ئاشان ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، بەيت-شەمەش ۋە ئۇنىڭغا تەۋە ئېتىزلىقلارمۇ تەقسىم قىلىنغان؛
\v 60 يەنە بىنيامىن قەبىلىسىدىكى زېمىندىن گېبا ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، ئاللەمەت ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، ئاناتوت ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار بۆلۈپ بېرىلگەن. ئۇلار جەمەتلىرى بويىچە ئېرىشكەن شەھەر جەمئىي ئون ئۈچ بولدى.
\m 
\v 61 كوھاتنىڭ باشقا ئەۋلادلىرىغا بولسا تاشلانغان چەككە چىققىنى بويىچە، ماناسسەھ يېرىم قەبىلىسىنىڭ زېمىنىدىن ئون شەھەر بۆلۈپ بېرىلدى. \f ◼ \fr 6:61 \ft \bd «ماناسسەھ يېرىم قەبىلىسىنىڭ زېمىنىدىن ئون شەھەر بۆلۈپ بېرىلدى»\bd* ــ بەزى كونا كۆچۈرمىلەردە «ماناسسەھ يېرىم قەبىلىسىنىڭ زېمىنىدىن، ئەفرائىم قەبىلىسى (زېمىنى)دىن ۋە دان قەبىلىسى (زېمىنى)دىنمۇ ئون شەھەر بۆلۈپ بېرىلدى» دېيىلىدۇ. -66ئايەتنىمۇ كۆرۈڭ.\f*
\m 
\v 62 گەرشومنىڭ ئەۋلادلىرىغا، جەمەتىگە قاراپ، ئىسساكار قەبىلىسى، ئاشىر قەبىلىسى، نافتالى قەبىلىسى ۋە باشان يۇرتىدىكى ماناسسەھ يېرىم قەبىلىسىنىڭ زېمىنىدىن ئون ئۈچ شەھەر بۆلۈپ بېرىلدى.
\m 
\v 63 مەرارىنىڭ ئەۋلادلىرىغا، جەمەتىگە قاراپ، تاشلانغان چەككە چىققىنى بويىچە، رۇبەن قەبىلىسى، گاد قەبىلىسى ۋە زەبۇلۇن قەبىلىسىدىن ئون ئىككى شەھەر بۆلۈپ بېرىلدى.
\m 
\v 64 ئىسرائىللار شۇنداق قىلىپ بۇ شەھەرلەرنى ۋە ئۇلارغا تەۋە ئېتىزلىقلارنىڭ ھەممىسىنى لاۋىيلارغا بۆلۈپ بەردى.
\v 65 ئۇلار تاشلانغان چەككە چىققىنى بويىچە، يەنە يۇقىرىدا نامى ئاتالغان شەھەرلەرنى يەھۇدا قەبىلىسىدىن، شىمېئون قەبىلىسىدىن ۋە بىنيامىن قەبىلىسىدىن ئېلىپ ئۇلارغا بەردى.
\m 
\v 66 كوھاتنىڭ ئەۋلادلىرىدىن بولغان بەزى جەمەتلەرگە ئەفرائىم قەبىلىسىنىڭ زېمىنى تەۋەسىدىكى شەھەرلەردىن بۆلۈپ بېرىلگەنلىرىمۇ بولدى.
\v 67 ئىسرائىللار ئۇلارغا \add يەنە ئىككى\add* «پاناھلىق شەھىرى»، يەنى ئەفرائىم تاغلىقىغا جايلاشقان شەكەم ۋە ئۇنىڭغا تەۋە ئېتىزلىقلارنى ۋە گەزەر ۋە ئۇنىڭغا تەۋە ئېتىزلىقلارنى بەردى؛
\v 68 يەنە يوكمىيام ۋە ئۇنىڭغا تەۋە ئېتىزلىقلارنى، بەيت-ھورون ۋە ئۇنىڭغا تەۋە ئېتىزلىقلارنى،
\v 69 ئايجالون ۋە ئۇنىڭغا تەۋە ئېتىزلىقلارنى، گات-رىممون ۋە ئۇنىڭغا تەۋە ئېتىزلىقلارنى ئۇلارغا بەردى.
\v 70 \add ئىسرائىللار يەنە\add* ماناسسەھ يېرىم قەبىلىسىدىن ئانېر ۋە ئۇنىڭغا تەۋە ئېتىزلىقلارنى، بىلېئام ۋە ئۇنىڭغا تەۋە ئېتىزلىقلارنى كوھاتنىڭ قالغان جەمەتلىرىگە بەردى.
\m 
\v 71 گەرشومنىڭ ئەۋلادلىرىغا ماناسسەھ يېرىم قەبىلىسىدىكى جەمەتلەرنىڭ زېمىنىدىن باشاندىكى گولان ۋە گولانغا تەۋە ئېتىزلىقلار، ئاشتاروت ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار بېرىلدى؛
\v 72 ئىسساكار قەبىلىسىدىن كەدەش ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، دابىرات ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، \f ◼ \fr 6:72 \ft \bd «دابىرات»\bd* ــ ياكى «دوبرات».\f*
\v 73 راموت ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، ئانەم ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار بېرىلدى؛
\v 74 ئاشىر قەبىلىسىدىن ئۇلارغا ماشال ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، ئابدون ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار،
\v 75 خۇكوك ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، رەھوب ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار بېرىلدى؛
\v 76 نافتالى قەبىلىسىدىن گالىلىيەدىكى كەدەش ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، ھاممون ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، كىرىئاتايىم ۋە ئۇنىڭغا تەۋە ئېتىزلىقلارمۇ بېرىلدى.
\m 
\v 77 مەرارىنىڭ قالغان ئەۋلادلىرىغا بولسا زەبۇلۇن قەبىلىسىدىن رىممونو ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، تابور ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار بېرىلدى؛ \f ◼ \fr 6:77 \ft \bd «مەرارىنىڭ قالغان ئەۋلادلىرىغا بولسا زەبۇلۇن قەبىلىسىدىن رىممونو...»\bd* ــ بەزى كونا كۆچۈرمىلەردە (مەسىلەن، تەۋراتنىڭ گرېك تىلىدىكى تەرجىمىسى LXXدە) مۇشۇ يەردە «مەرارىنىڭ قالغان ئەۋلادلىرىغا بولسا زەبۇلۇن قەبىلىسىدىن يوكنېئام ۋە ئۇنىڭغا تەۋە ئوتلاقلار، كارتاھ ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار ۋە رىممونو.... » دېيىلىدۇ.\f*
\v 78 يەنە رۇبەن قەبىلىسىنىڭكىدىن، ئىئوردان دەرياسىنىڭ ئۇ تەرىپىدىن، يېرىخونىڭ شەرقىي ئۇدۇلىدىكى، يەنى ئىئوردان دەرياسىنىڭ كۈنچىقىش بويىدىكى يەرلەردىن چۆلدىكى بەزەر ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، ياھزاھ ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار،
\v 79 كەدەموت ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، مېفائات ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار بېرىلدى؛
\v 80 گاد قەبىلىسىدىنمۇ بولسا ئۇلارغا گىلېئادتىكى راموت ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، ماھانائىم ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار،
\v 81 ھەشبون ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار، يائازەر ۋە ئۇنىڭغا تەۋە ئېتىزلىقلار بېرىلدى.
\b
\b
\c 7
\s1 ئىسساكارنىڭ ئەۋلادلىرى
\m 
\v 1 ئىسساكارنىڭ ئوغۇللىرى: ــ تولا، پۇئاھ، ياشۇب ۋە شىمرون دېگەن تۆتەيلەن ئىدى.
\v 2 تولانىڭ ئوغۇللىرى: ــ ئۇززى، رېفايا، يېرىيەل، ياھماي، يىبسام ۋە سامۇئىلدىن ئىبارەت، بۇلارنىڭ ھەممىسى جەمەت بېشى ئىدى. داۋۇتنىڭ زامانىدا تولانىڭ ئادەم سانى نەسەبنامىلەردە يىگىرمە ئىككى مىڭ ئالتە يۈز باتۇر جەڭچى دەپ خاتىرىلەنگەن.
\m 
\v 3 ئۇززىنىڭ ئوغلى ئىزراقىيا ئىدى، ئىزراقىيانىڭ ئوغۇللىرى مىكائىل، ئوبادىيا، يوئېل ۋە ئىشىيا ئىدى. بۇ بەشەيلەننىڭ ھەممىسى جەمەت بېشى ئىدى.
\v 4 نەسەبنامىلەر بويىچە ئۇلار بىلەن بىللە ھېسابلانغانلاردىن جەڭگىۋار ئوتتۇز ئالتە مىڭ ئادەم بار ئىدى؛ چۈنكى ئۇلارنىڭ خوتۇن، بالا-چاقىلىرى ناھايىتى كۆپ ئىدى.
\m 
\v 5 بۇلارنىڭ ئىسساكارنىڭ بارلىق جەمەتلىرى ئىچىدىكى باتۇر جەڭچى قېرىنداشلىرى بىلەن قوشۇلۇپ، نەسەب بويىچە تىزىمغا ئېلىنغان جەمئىي سەكسەن يەتتە مىڭ ئادىمى بار ئىدى.
\b
\s1 بىنيامىننىڭ ئەۋلادلىرى
\m 
\v 6 بىنيامىننىڭ بېلا، بەكەر ۋە يەدىيايەل دېگەن ئۈچ ئوغلى بار ئىدى.
\v 7 بېلانىڭ ئېزبون، ئۇززى، ئۇززىئەل، يەرىموت ۋە ئىرى دېگەن بەش ئوغلى بولۇپ، ھەممىسى جەمەت بېشى ئىدى؛ ئۇلارنىڭ نەسەبنامىلىرىگە تىزىمغا ئېلىنغان جەمئىي يىگىرمە ئىككى مىڭ ئوتتۇز تۆت باتۇر جەڭچى بار ئىدى.
\m 
\v 8 بەكەرنىڭ ئوغۇللىرى زېمىراھ، يوئاش، ئەلىئېزەر، ئەليويىناي، ئومرى، يەرەموت، ئابىيا، ئاناتوت ۋە ئالامەت ئىدى. بۇلارنىڭ ھەممىسى بەكەرنىڭ ئوغۇللىرى بولۇپ،
\v 9 جەمەت باشلىرى ئىدى؛ ئۇلارنىڭ نەسەبنامىلىرىگە تىزىمغا ئېلىنغان جەمئىي يىگىرمە مىڭ ئىككى يۈز باتۇر جەڭچى بار ئىدى.
\m 
\v 10 يەدىيايەلنىڭ ئوغلى بىلھان ئىدى؛ بىلھاننىڭ ئوغۇللىرى يەئۇش، بىنيامىن، ئەخۇد، كەنائاناھ، زېتان، تارشىش ۋە ئاخىشاھار ئىدى؛
\v 11 بۇلارنىڭ ھەممىسى يەدىيايەلنىڭ ئەۋلادلىرى، جەمەت باشلىرى ۋە باتۇر جەڭچىلەر ئىدى. ئۇلارنىڭ نەسەبنامىلىرىگە تىزىملانغانلارنىڭ جەڭگە چىقىلايدىغانلىرى جەمئىي ئون يەتتە مىڭ ئىككى يۈز ئىدى.
\v 12 شۇپپىيلار ۋە خۇپپىيلار بولسا يەنە ئىرنىڭ ئەۋلادلىرى ئىدى؛ ھۇشىيلار ئاخەرنىڭ ئەۋلادلىرى ئىدى. \f ◼ \fr 7:12 \ft \bd «ئاخەر»\bd* ــ ياكى «ئاخىرام» («چۆل.» 38:26نى كۆرۈڭ).\f*
\b
\s1 نافتالىنىڭ ئەۋلادلىرى
\m 
\v 13 نافتالىنىڭ ئوغۇللىرى: ياھزىئەل، گۇنى، يەزەر، شاللوم؛ بۇلارنىڭ ھەممىسى بىلھاھنىڭ ئوغۇللىرى ئىدى.
\b
\s1 ماناسسەھنىڭ ئەۋلادلىرى
\m 
\v 14 ماناسسەھنىڭ ئوغۇللىرى: ــ ئۇنىڭ سۇرىيەلىك توقىلىدىن ئاسرىئەل تۆرەلگەن؛ ئۇنىڭدىن يەنە گىلېئادنىڭ ئاتىسى ماكىر تۇغۇلغان.
\v 15 ماكىر شۇپپىيلار ۋە خۇپپىيلار ئارىسىدىنمۇ ئايال ئالغان (ماكىرنىڭ سىڭلىسىنىڭ ئىسمى مائاكاھ ئىدى). ماكىرنىڭ يەنە بىر ئەۋلادىنىڭ ئىسمى زەلوفىھاد ئىدى، زەلوفىھادنىڭ پەقەت بىرنەچچە قىزىلا بولغان. \f ◼ \fr 7:15 \ft \bd «ماكىرنىڭ سىڭلىسى»\bd* ــ ئىبرانىي تىلىدا «ئۇنىڭ سىڭلىسى». \bd «ماكىرنىڭ ئىككىنچى ئەۋلادىنىڭ ئىسمى...»\bd* ــ ئىبرانىي تىلىدا «ئىككىنچىسىنىڭ ئىسمى..» دېيىلىدۇ. پەرزىمىزچە «ئىككىنچىسى» مۇشۇ يەردە «(ئۇنىڭ) يەنە بىر ئەۋلادى» دېگەن مەنىدە.\f*
\m 
\v 16 ماكىرنىڭ ئايالى مائاكاھ ئوغۇل تۇغۇپ، ئۇنىڭغا پەرەش دەپ ئات قويغان؛ پەرەشنىڭ ئىنىسىنىڭ ئىسمى شەرەش ئىدى؛ شەرەشنىڭ ئوغلى ئۇلام ۋە راكەم ئىدى.
\v 17 ئۇلامنىڭ ئوغلى بېدان ئىدى. بۇلارنىڭ ھەممىسى گىلېئادنىڭ ئەۋلادلىرى؛ گىلېئاد ماكىرنىڭ ئوغلى، ماكىر ماناسسەھنىڭ ئوغلى ئىدى.
\m 
\v 18 گىلېئادنىڭ سىڭلىسى ھاممولەكەتتىن ئىشھود، ئابىئېزەر ۋە ماھالاھ تۇغۇلغان. \f ◼ \fr 7:18 \ft \bd «گىلېئادنىڭ سىڭلىسى»\bd* ــ ئىبرانىي تىلىدا «ئۇنىڭ سىڭلىسى».\f*
\v 19 شېمىدانىڭ ئوغۇللىرى ئاخىيان، شەكەم، لىكخى ۋە ئانىئام ئىدى.
\b
\s1 ئەفرائىمنىڭ ئەۋلادلىرى
\m 
\v 20 ئەفرائىمنىڭ ئەۋلادلىرى: ئۇنىڭ ئوغلى شۇتىلاھ، شۇتىلاھنىڭ ئوغلى بەرەد، بەرەدنىڭ ئوغلى تاھات، تاھاتنىڭ ئوغلى ئېلىئاداھ، ئېلىئاداھنىڭ ئوغلى تاھات،
\v 21 تاھاتنىڭ ئوغلى زاباد، زابادنىڭ ئوغلى شۇتىلاھ ئىدى (ئېزەر بىلەن ئېلىئاد گاتلىقلارنىڭ چارۋا ماللىرىنى بۇلاڭ-تالاڭ قىلغىلى چۈشكەندە، شۇ يەرلىك گاتلىقلار تەرىپىدىن ئۆلتۈرۈلگەن.
\v 22 ئۇلارنىڭ ئاتىسى ئەفرائىم بۇ بالىلىرى ئۈچۈن خېلى كۈنلەرگىچە ماتەم تۇتقاچقا، ئۇنىڭ بۇرادەرلىرى ئۇنىڭغا تەسەللى بەرگىلى كەلگەن.
\v 23 ئەفرائىم ئايالى بىلەن بىللە قايتا بىر ياستۇققا باش قويغان. ئايالى ھامىلىدار بولۇپ، بىر ئوغۇل تۇغقان؛ ئەفرائىم ئۇنىڭغا ئائىلەم بالا-قازاغا يولۇقتى دەپ، بېرىياھ دەپ ئىسىم قويغان. \f ◼ \fr 7:23 \ft \bd «بېرىياھ»\bd* ــ بېرىياھنىڭ مەنىسى «بالا-قازا» بىلەن باغلىق.\f*
\v 24 ئۇنىڭ قىزى ئۈستۈن بەيت-ھورون بىلەن تۆۋەن بەيت-ھوروننى ۋە ئۇززەن-شەئەراھنى بىنا قىلغان).
\m 
\v 25 بېرىياھنىڭ ئوغلى رېفاھ بىلەن رەشەف ئىدى؛ رەشەفنىڭ ئوغلى تېلاھ، تېلاھنىڭ ئوغلى تاھان، \f ◼ \fr 7:25 \ft \bd «بېرىياھنىڭ ئوغلى»\bd* ــ ئىبرانىي تىلىدا «ئۇنىڭ ئوغلى». بەزى ئالىملار «ئۇنىڭ» دېگەننى يۇقىرىدىكى شۇتىلاھنى كۆرسىتىدۇ، دەپ قارايدۇ. \bd «بېرىياھنىڭ ئوغلى رېفاھ بىلەن رەشەف ئىدى...»\bd* ــ ياكى «بېرىياھنىڭ ئوغلى رېفاھ ئىدى، رېفاھنىڭ ئوغلى رەشەف ئىدى...».\f*
\v 26 تاھاننىڭ ئوغلى لادان، لاداننىڭ ئوغلى ئاممىھۇد، ئاممىھۇدنىڭ ئوغلى ئەلىشاما،
\v 27 ئەلىشامانىڭ ئوغلى نۇن، نۇننىڭ ئوغلى يەشۇئا ئىدى. \f ◼ \fr 7:27 \ft \bd «يەشۇئا»\bd* ــ بۇ «يەشۇئا» يەشۇئا پەيغەمبەردۇر (مۇشۇ يەردە «يەھوشۇئا» دېيىلىدۇ).\f*
\b
\s1 ئەفرائىملارنىڭ شەھەرلىرى
\m 
\v 28 ئەفرائىملارنىڭ زېمىنى ۋە ماكانلاشقان يەرلىرى بەيت-ئەل ۋە ئۇنىڭغا تەۋە يېزا-كەنتلەر بولۇپ، كۈنچىقىش تەرىپىدە نارائان، كۈنپېتىش تەرىپىدە گەزەر بىلەن ئۇنىڭغا تەۋە يېزا-كەنتلەر؛ شەكەم ۋە ئۇنىڭغا تەۋە يېزا-كەنتلەر، تاكى گازا ۋە ئۇنىڭغا تەۋە يېزا-كەنتلەرگىچە سوزۇلاتتى.
\v 29 ماناسسەھ قەبىلىسىنىڭ زېمىنىغا تۇتاشقان يەنە بەيت-شېئان ۋە ئۇنىڭغا تەۋە يېزا-كەنتلەر؛ تائاناق ۋە ئۇنىڭغا تەۋە يېزا-كەنتلەر؛ مەگىددو ۋە ئۇنىڭغا تەۋە يېزا-كەنتلەر؛ دور ۋە ئۇنىڭغا تەۋە يېزا-كەنتلەرمۇ بار ئىدى. ئىسرائىلنىڭ ئوغلى يۈسۈپنىڭ ئەۋلادلىرى مانا مۇشۇ يەرلەرگە ماكانلاشقانىدى.
\b
\s1 ئاشىرنىڭ ئەۋلادلىرى
\m 
\v 30 ئاشىرنىڭ ئوغۇللىرى: ــ يىمناھ، يىشۋاھ، يىشۋى ۋە بېرىياھ؛ ئۇلارنىڭ سېراھ دېگەن سىڭلىسىمۇ بار ئىدى.
\v 31 بېرىياھنىڭ ئوغلى خەبەر بىلەن مالكىئەل بولۇپ، مالكىئەل بىرزاۋىتنىڭ ئاتىسى ئىدى.
\v 32 خېبەردىن يافلەت، شومەر، خوتام ۋە ئۇلارنىڭ سىڭلىسى شۇيا تۆرەلگەن.
\m 
\v 33 يافلەتنىڭ ئوغۇللىرى پاساق، بىمھال ۋە ئاشۋات؛ بۇلار يافلەتنىڭ ئوغۇللىرى ئىدى.
\v 34 شەمەرنىڭ ئوغۇللىرى ئاخى، روھگاھ، خۇبباھ ۋە ئارام ئىدى. \f ◼ \fr 7:34 \ft \bd «شەمەر»\bd* ــ بۇ شەمەر شۈبھىسىزكى 32-ئايەتتىكى «شومەر»نىڭ ۋارىيانتى. \bd «شەمەرنىڭ ئوغۇللىرى ئاخى، روھگاھ...»\bd* ــ باشقا بىرخىل تەرجىمىسى: «ئۇنىڭ ئىنىسى شەمەرنىڭ ئوغۇللىرى روھگاھ،...».\f*
\v 35 \add شەمەرنىڭ\add* ئىنىسى ھەلەمنىڭ ئوغلى زوفاھ، يىمنا، شەلەش ۋە ئامال ئىدى؛
\v 36 زوفاھنىڭ ئوغلى سۇئاھ، ھارنەفەر، شۇئال، بېرى، ئىمراھ،
\v 37 بېزەر، خود، شامما، شىلشاھ، ئىتران ۋە بەئەراھ ئىدى. \f ◼ \fr 7:37 \ft \bd «ئىتران»\bd* ــ بەلكىم «يەتەر»نىڭ باشقا بىر شەكلى بولۇشى مۇمكىن (38-ئايەتنى كۆرۈڭ).\f*
\v 38 يەتەرنىڭ ئوغۇللىرى يەفۇننەھ، پىسپاھ ۋە ئارا ئىدى.
\v 39 ئۇللانىڭ ئوغۇللىرى ئاراھ، خاننىئەل ۋە رىزىيا ئىدى.
\v 40 بۇلارنىڭ ھەممىسى ئاشىرنىڭ ئەۋلادلىرى بولۇپ، ھەر قايسىسى جەمەت باشلىرى، ئالامەت باتۇر جەڭچىلەر، يولباشچىلار ئىدى؛ ئۇلارنىڭ جەمەتلىرى بويىچە نەسەبنامىگە تىزىملانغاندا، جەڭگە چىقىلايدىغانلىرى جەمئىي يىگىرمە ئالتە مىڭ ئىدى.
\b
\b
\c 8
\s1 بىنيامىننىڭ ئەۋلادلىرى ــ داۋامى
\m 
\v 1 بىنيامىننىڭ تۇنجى ئوغلى بېلا، ئىككىنچى ئوغلى ئاشبەل، ئۈچىنچى ئوغلى ئاخاراھ، \f ◼ \fr 8:1 \ft \bd «بىنيامىننىڭ تۇنجى ئوغلى بېلا، ئىككىنچى ئوغلى ئاشبەل، ئۈچىنچى ئوغلى ئاخاراھ...»\bd* ــ مۇشۇ بابتا بىنيامىننىڭ ئەۋلادلىرىنىڭ نەسەبنامىسى كۆپ يەرلەردە پەقەت بەزى يېزا-كەنتلەر بىلەن باغلانغان ھالدا كۆرۈنىدۇ. سەۋەبى، بىنيامىن قەبىلىسىدىكىلەر ئېغىر گۇناھ سادىر قىلىپ خۇدانىڭ قاتتىق جازاسىغا ئۇچرىغاندىن كېيىن، پۈتكۈل ئىسرائىل ئىچىگە تارىلىپ كەتكەنىدى.\f*
\v 2 تۆتىنچى ئوغلى نوخاھ، بەشىنچى ئوغلى رافا ئىدى.
\v 3 بېلانىڭ ئوغۇللىرى ئاددار، گېرا، ئابىھۇد،
\v 4 ئابىشۇئا، نائامان، ئاخوئاھ،
\v 5 گېرا، شېفۇفان ۋە ھۇرام ئىدى.
\m 
\v 6‏-7 تۆۋەندىكىلەر ئەخۇدنىڭ ئەۋلادلىرى: ــ
\m نائامان، ئاخىياھ ۋە گېرا (ئەسلىدە ئۇلار گېبالىقلارنىڭ جەمەت بېشى ئىدى. گېبالىقلار ماناھاتقا كۆچۈرۈۋېتىلگەنىدى. بۇلارنى كۆچۈرۈۋەتكۈچى بولسا گېرا ئىدى؛ ئۇنىڭدىن ئۇززا بىلەن ئاخىھۇد تۆرەلگەن).
\m 
\v 8 شاھارائىم ھۇشىم بىلەن بائارا دېگەن ئىككى ئايالىنى قويۇۋەتكەندىن كېيىن موئاب دىيارىدا ئوغۇل پەرزەنت كۆرگەن.
\v 9 ئۇنىڭ خودەش دېگەن ئايالىدىن يوباب، زىبىيا، مېشا، مالكام،
\v 10 يەئۇز، شاقىيا، مىرماھ دېگەن ئوغۇللار تۆرەلگەن؛ ئۇنىڭ بۇ ئوغۇللىرىنىڭ ھەممىسى جەمەت بېشى بولغانىدى. \f ◼ \fr 8:10 \ft \bd «شاقىيا»\bd* ــ ياكى «شوبىيا».\f*
\v 11 ھۇشىمدىنمۇ ئۇنىڭغا ئابىتۇب، ئەلپائال دېگەن ئوغۇللار تۆرەلگەن.
\m 
\v 12 ئەلپائالنىڭ ئوغۇللىرى ئېبەر، مىشام ۋە شېمەد (شېمەد ئونو بىلەن لود دېگەن ئىككى شەھەرنى ۋە ئۇلارغا تەۋە يېزا-كەنتلەرنى بىنا قىلغان)، \f ◼ \fr 8:12 \ft \bd «شېمەد»\bd* ــ ياكى «شېمەر».\f*
\v 13 بېرىياھ ۋە شېما ئىدى. ئۇ ئىككىسى ئايجالوندىكىلەر ئىچىدە جەمەت باشلىرى بولۇپ، گات ئاھالىسىنى قوغلىۋەتكەنىدى.
\m 
\v 14 ئاخىيو، شاشاق، يەرەموت،
\v 15 زەبادىيا، ئاراد، ئېدەر،
\v 16 مىكائىل، ئىشپاھ ۋە يوخا بولسا بېرىياھنىڭ ئوغۇللىرى ئىدى.
\m 
\v 17 زەبادىيا، مەشۇللام، ھىزكى، خېبەر،
\v 18 ئىشمېراي، يېزلىيا ۋە يوبابلارنىڭ ھەممىسى ئەلپائالنىڭ ئوغۇللىرى ئىدى.
\m 
\v 19 ياكىم، زىكرى، زابدى،
\v 20 ئەلىيەناي، زىلتاي، ئەلىيەل،
\v 21 ئادايا، بېرايا ۋە شىمراتلار شىمەينىڭ ئوغۇللىرى ئىدى.
\m 
\v 22 ئىشپان، ئېبەر، ئەلىيەل، \f ◼ \fr 8:22 \ft \bd «ئىشپان»\bd* ــ ياكى «ئىشپاھ».\f*
\v 23 ئابدون، زىكرى، ھانان،
\v 24 ھانانىيا، ئېلام، ئانتوتىيا،
\v 25 ئېفدېئاھ ۋە پەنۇئەللەر شاشاقنىڭ ئوغۇللىرى ئىدى.
\m 
\v 26 شامشىراي، شېخارىيا، ئاتالىيا،
\v 27 يائارېشىيا، ئەلىيا ۋە زىكرىلار يەروھامنىڭ ئوغۇللىرى ئىدى.
\m 
\v 28 يۇقىرىقىلارنىڭ ھەممىسى نەسەبنامىلەردە خاتىرىلەنگەن جەمەت بېشى ئىدى؛ بۇلار ھەممىسى مۆتىۋەرلەر بولۇپ، يېرۇسالېمغا ماكانلاشقانىدى.
\b
\m 
\v 29 گىبېئوننىڭ ئاتىسى جەئىيەل گىبېئونغا ماكانلاشقانىدى؛ ئۇنىڭ ئايالىنىڭ ئىسمى مائاكاھ ئىدى. \f ◼ \fr 8:29 \ft \bd «جەئىيەل»\bd* ــ تەۋراتنىڭ گرېك تىلىدىكى تەرجىمىسى (LXX)دە «جىيەل» تېپىلىدۇ.\f*
\v 30 ئۇنىڭ تۇنجى ئوغلى ئابدون، قالغان ئوغۇللىرى زۇر، كىش، بائال، ناداب،
\v 31 گېدور، ئاخىيو، زېكەر ۋە مىكلوت ئىدى؛ \f ◼ \fr 8:31 \ft \bd «مىكلوت»\bd* ــ «مىكلوت» تەۋراتنىڭ گرېك تىلىدىكى تەرجىمىسى (LXX)دىكى بەزى كۆچۈرمىلەردە تېپىلىدۇ. 32-ئايەتنى كۆرۈڭ.\f*
\v 32 مىكلوتتىن شىمېيا تۆرەلگەن. بۇلارمۇ قېرىنداشلىرى بىلەن يېرۇسالېمدا قوشنا ئولتۇرۇشاتتى.
\m 
\v 33 نەردىن كىش تۆرەلگەن؛ كىشتىن سائۇل تۆرەلگەن؛ سائۇلدىن يوناتان، مالكىشۇئا، ئابىناداب ۋە ئېش-بائال تۆرەلگەن.
\v 34 مېرىب-بائال يوناتاننىڭ ئوغلى ئىدى؛ مىكاھ مېرىب-بائالدىن تۆرەلگەن.
\v 35 مىكاھنىڭ ئوغۇللىرى پىتون، مەلەك، تارىيا ۋە ئاھاز ئىدى.
\v 36 ئاھازدىن يەھوئادداھ تۆرەلگەن؛ يەھوئادداھدىن ئالەمەت، ئازماۋەت ۋە زىمرى تۆرەلگەن؛ زىمرىدىن موزا تۆرەلگەن؛
\v 37 موزادىن بىنېئا تۆرەلگەن؛ بىنېئانىڭ ئوغلى رافا، رافانىڭ ئوغلى ئېلىئاساھ، ئېلىئاساھنىڭ ئوغلى ئازەل ئىدى.
\v 38 ئازەلنىڭ ئالتە ئوغلى بار ئىدى، ئۇلارنىڭ ئىسمى ئازرىكام، بوكېرۇ، ئىشمائىل، شېئارىيا، ئوبادىيا ۋە ھانان ئىدى؛ بۇلارنىڭ ھەممىسى ئازەلنىڭ ئوغۇللىرى ئىدى.
\v 39 ئازەلنىڭ ئىنىسى يېشەكنىڭ تۇنجى ئوغلىنىڭ ئىسمى ئۇلام، ئىككىنچى ئوغلىنىڭ ئىسمى يېئۇش، ئۈچىنچى ئوغلىنىڭ ئىسمى ئەلىفەلەت ئىدى.
\v 40 ئۇلامنىڭ ئوغۇللىرىنىڭ ھەممىسى باتۇر جەڭچى، ئوقياچى ئىدى؛ ئۇلارنىڭ ئوغۇللىرى ۋە نەۋرىلىرى ناھايىتى كۆپ بولۇپ، جەمئىي بىر يۈز ئەللىك ئىدى.
\m يۇقىرىقىلارنىڭ ھەممىسى بىنيامىن ئەۋلادلىرىدىن ئىدى.
\b
\b
\c 9
\m 
\v 1 پۈتكۈل ئىسرائىللار نەسەب بويىچە تىزىمغا ئېلىنغانىدى. مانا، ئۇلار «ئىسرائىل پادىشاھلىرىنىڭ خاتىرىسى» دېگەن كىتابقا پۈتۈلگەندۇر.
\b
\s1 بابىلغا سۈرگۈن بولۇشتىن قايتىپ يېرۇسالېمغا ماكانلاشقان ئىسرائىللار
\m 
\v 2 يەھۇدالار بولسا ئاسىيلىق قىلغانلىقىدىن بابىلغا سۈرگۈن قىلىنغان.
\m ھەممىدىن ئاۋۋال قايتىپ كېلىپ ئۆز زېمىنى ۋە ئۆز شەھەرلىرىگە ماكانلاشقانلار بولسا بىر قىسىم ئىسرائىللار، كاھىنلار، لاۋىيلار ۋە ئىبادەتخانا خىزمەتكارلىرى ئىدى. \f ◼ \fr 9:2 \ft \bd «ئىبادەتخانا خىزمەتكارلىرى»\bd* ــ ئىبرانىي تىلىدا «نەتىنىيلار». مەنىسى بەلكىم «بېغىشلانغانلار». ئۇلارنىڭ ئەجدادلىرى بەلكىم «گىبېئونلۇقلار» ئىدى. «يەشۇئا» 27:9نى كۆرۈڭ.\f*
\v 3 يېرۇسالېمغا ماكانلاشقانلار بولسا يەھۇدا قەبىلىسى، بىنيامىن قەبىلىسى، ئەفرائىم قەبىلىسى ۋە ماناسسەھ قەبىلىسىدىن بىر قىسىملىرى ئىدى.
\v 4 ئۇلارنىڭ ئىچىدە يەھۇدانىڭ ئوغلى پەرەزنىڭ ئەۋلادلىرىدىن ئۇتاي بار ئىدى؛ ئۇتاي ئاممىھۇدنىڭ ئوغلى، ئاممىھۇد ئومرىنىڭ ئوغلى، ئومرى ئىمرىنىڭ ئوغلى، ئىمرى بانىنىڭ ئوغلى ئىدى.
\v 5 شىلوھنىڭ ئەۋلادلىرى ئىچىدە ئۇنىڭ تۇنجى ئوغلى ئاسايا ۋە ئۇنىڭ ئوغۇللىرى بار ئىدى.
\v 6 زەراھنىڭ ئەۋلادلىرىدىن يەئۇئېل ۋە ئۇلارنىڭ ئۇرۇق-تۇغقانلىرى بولۇپ جەمئىي ئالتە يۈز توقسان ئادەم بار ئىدى.
\m 
\v 7 بىنيامىننىڭ ئەۋلادلىرى ئىچىدە ھاسسىنۇئاھنىڭ ئەۋرىسى، ھوداۋىيانىڭ نەۋرىسى، مەشۇللامنىڭ ئوغلى ساللۇ بار ئىدى؛
\v 8 يەنە يەروھامنىڭ ئوغلى يىبنىيا، مىكرىنىڭ نەۋرىسى، ئۇززىنىڭ ئوغلى ئېلاھ ۋە ئىبىنىيانىڭ ئەۋرىسى، رېئۇئەلنىڭ نەۋرىسى، شەفاتىيانىڭ ئوغلى مەشۇللام
\v 9 ھەمدە ئۇلارنىڭ ئۇرۇق-تۇغقانلىرى بار ئىدى؛ ئۇلار نەسەبنامىسى بويىچە تىزىملانغاندا جەمئىي توققۇز يۈز ئەللىك ئالتە ئادەم ئىدى. يۇقىرىدا تىلغا ئېلىنغانلار ئۆز جەمەتىگە جەمەت بېشى ئىدى.
\b
\s1 يېرۇسالېمدا تۇرۇشلۇق كاھىنلار
\m 
\v 10 كاھىنلار ئىچىدە يەدايا، يەھويارىب، ياقىن ۋە
\v 11 ئازارىيا بار ئىدى. ئازارىيا خۇدانىڭ ئۆيىنى باشقۇرغۇچى بولۇپ، ھىلقىيانىڭ ئوغلى، ھىلقىيا مەشۇللامنىڭ ئوغلى، مەشۇللام زادوكنىڭ ئوغلى، زادوك مېرايوتنىڭ ئوغلى، مېرايوت ئاخىتۇبنىڭ ئوغلى ئىدى.
\v 12 يەنە مالكىيانىڭ ئەۋرىسى، پاشخۇرنىڭ نەۋرىسى، يەروھامنىڭ ئوغلى ئادايا ھەمدە ئادىيەلنىڭ ئوغلى مائاساي بار ئىدى؛ ئادىيەل ياھزەراھنىڭ ئوغلى، ياھزەراھ مەشۇللامنىڭ ئوغلى، مەشۇللام مەشىللېمىتنىڭ ئوغلى، مەشىللېمىت ئىممەرنىڭ ئوغلى ئىدى.
\v 13 ئۇلارنىڭ قېرىنداشلىرى ھەممىسى جەمەت باشلىرى بولۇپ، جەمئىي بىر مىڭ يەتتە يۈز ئاتمىش ئادەم ئىدى؛ ئۇلارنىڭ ھەممىسى خۇدانىڭ ئۆيىدىكى خىزمەتلەرنى قىلىشقا بېكىتىلگەن ئىقتىدارلىق كىشىلەر ئىدى.
\b
\s1 يېرۇسالېمدا تۇرۇشلۇق لاۋىيلار
\m 
\v 14 لاۋىي قەبىلىسىدىن مەرارىنىڭ ئەۋلادلىرى ئىچىدە ھاشابىيانىڭ ئەۋرىسى، ئازرىكامنىڭ نەۋرىسى، ھاششۇبنىڭ ئوغلى شېمايا بار ئىدى؛
\v 15 يەنە باقباققار، ھەرەش، گالال ۋە ئاسافنىڭ ئەۋرىسى، زىكرىنىڭ نەۋرىسى، مىكانىڭ ئوغلى ماتتانىيا؛
\v 16 يەنە يەدۇتۇننىڭ ئەۋرىسى، گالالنىڭ نەۋرىسى، شېمايانىڭ ئوغلى ئوبادىيا ھەمدە ئەلكاناھنىڭ نەۋرىسى، ئاسانىڭ ئوغلى بەرەكىيا بار ئىدى؛ بۇلارنىڭ ھەممىسى نىتوفاتلىقلارنىڭ يېزا-كەنتلىرىگە ماكانلاشقانىدى.
\b
\s1 لاۋىيلارنىڭ ۋەزىپىلىرى
\m 
\v 17 دەرۋازىۋەنلەر شاللۇم، ئاققۇب، تالمون، ئاخىمان ۋە ئۇلارنىڭ قېرىنداشلىرى ئىدى؛ شاللۇم ئۇلارنىڭ بېشى ئىدى.
\v 18 ئۇلار تاكى ھازىرغىچە شەرق تەرەپتىكى «پادىشاھنىڭ دەرۋازىسى»دا \add دەرۋازىۋەنلىك\add* قىلىپ كەلمەكتە؛ ئۇلار ئىلگىرى لاۋىيلارنىڭ چېدىرگاھىدا دەرۋازىۋەنلىك قىلغانىدى.
\m 
\v 19 كورەنىڭ ئەۋرىسى، ئېبىئاسافنىڭ نەۋرىسى، كوراھنىڭ ئوغلى شاللۇم ھەمدە ئۇنىڭ ئاتىسىنىڭ جەمەتىدىكى قېرىنداشلىرى بولغان كوراھىيلار \add خۇدانىڭ ئۆيىنىڭ\add* خىزمىتىنى باشقۇراتتى، چېدىرنىڭ ئىشىكلىرىنى باقاتتى؛ ئۇلارنىڭ ئاتا-بوۋىلىرى ئەسلىدە پەرۋەردىگارنىڭ چېدىرگاھىنى باشقۇرۇشقا قويۇلغان، \add ئىبادەت\add* چېدىرىنىڭ ئىشىكىنى باققانىدى. \f ◼ \fr 9:19 \ft \bd «چېدىر»\bd* ــ «چېدىر» مۇشۇ يەردە خۇدانىڭ قايتىدىن قۇرۇلغان ئۆيىنى كۆرسىتىشى كېرەك. \bd «پەرۋەردىگارنىڭ چېدىرگاھى»\bd* ــ مۇشۇ يەردە بەلكىم مۇقەددەس ئىبادەت چېدىرىنىڭ ئۆزىنى ئەمەس، بەلكى ئىسرائىللار چۆل-باياۋاندا كېزىپ يۈرگىنىدە «مۇقەددەس چېدىر»نىڭ ئەتراپىدىكى لاۋىي-كاھىنلارنىڭ چېدىرگاھىنى كۆرسىتىشى مۇمكىن.\f*
\v 20 ئىلگىرى ئەلىئازارنىڭ ئوغلى فىنىھاس ئۇلارنىڭ يولباشچىسى بولغان؛ پەرۋەردىگار ئۇنىڭ بىلەن بىللە بولغان.
\v 21 مەشەلەمىيانىڭ ئوغلى زەكەرىيا بولسا جامائەت چېدىرىنىڭ دەرۋازىۋەنى بولغانىدى.
\m 
\v 22 دەرۋازىۋەنلىككە تاللانغان بۇ كىشىلەر جەمئىي ئىككى يۈز ئون ئىككى كىشى ئىدى؛ ئۇلار ئۆز يېزا-كەنتلىرىدە، نەسەبلىرى بويىچە تىزىملانغان (ئەسلىدە داۋۇت ۋە ئالدىن كۆرگۈچى سامۇئىل ئۇلارنى ئامانەت قىلىنغان ۋەزىپىلىرىگە بېكىتكەنىدى.
\v 23 ئۇلار ۋە ئۇلارنىڭ ئەۋلادلىرى پەرۋەردىگارنىڭ ئۆيى، يەنى مۇقەددەس چېدىرنىڭ ئىشىك-دەرۋازىلىرىنى بېقىشقا بېكىتىلگەنىدى). \f ◼ \fr 9:23 \ft \bd «پەرۋەردىگارنىڭ ئۆيى، يەنى مۇقەددەس چېدىر»\bd* ــ مۇشۇ يەردە داۋۇت دەۋرىدىكى «مۇقەددەس چېدىر» ھەمدە شۇنداقلا سۇلايمان قۇرغان كېيىنكى مۇقەددەس ئۆينى كۆرسىتىشى كېرەك.\f*
\m 
\v 24 شەرقىي، غەربىي، شىمالىي ۋە جەنۇبىي ئىشىك-دەرۋازىلىرىدا دەرۋازىۋەنلەر بېكىتىلگەنىدى.
\v 25 ئۇلارنىڭ يېزا-كەنتلەردە ئولتۇرۇشلۇق قېرىنداشلىرى بولسا ھەر يەتتە كۈندە نۆۋەت بويىچە كېلىپ ئۇلار بىلەن بىرگە خىزمەتتە بولاتتى.
\v 26 تۆت دەرۋازىۋەن بېگى لاۋىيلاردىن ئىدى؛ ئۇلارغا تاپشۇرۇلغىنى پەرۋەردىگارنىڭ ئۆيىدىكى ئامبار-خەزىنىلەرنى بېقىش ئىدى.
\v 27 بېقىش مەسئۇلىيىتى ئۇلارنىڭ ئۈستىدە بولغاچقا، ئۇلار كېچىدە پەرۋەردىگارنىڭ ئۆيىنىڭ ئەتراپىدىكى ئورۇنلىرىدا تۇراتتى ھەمدە ھەر كۈنى ئەتىگەندە ئىشىك-دەرۋازىلارنى ئېچىشقا مەسئۇل ئىدى.
\m 
\v 28 ئۇلاردىن بىر قىسمى \add ئىبادەتخانا\add* خىزمىتىدە ئىشلىتىلىدىغان ئەسۋاب-ئۈسكۈنىلەرگە مەسئۇل ئىدى؛ ئۇلار ساناپ ئەپچىقىپ، ساناپ ئەپكىرىپ قوياتتى.
\v 29 ئۇلارنىڭ يەنە بىر قىسمى تاپشۇرۇلغىنى بويىچە قاچا-قۇچىلار ۋە مۇقەددەس جايدىكى بارلىق ئەسۋاب-ئۈسكۈنىلەر، شۇنداقلا ئاق ئۇن، شاراب، زەيتۇن مېيى، مەستىكى ۋە خۇشبۇي بۇيۇملارغا مەسئۇل ئىدى.
\v 30 كاھىنلارنىڭ ئوغۇللىرىدىن بەزىلەر خۇشبۇي بۇيۇملاردىن ئەتىر ياسايتتى.
\v 31 لاۋىيلاردىن ماتتىتىياھ، يەنى كوراھىيلاردىن شاللۇمنىڭ تۇنجى ئوغلىنىڭ ۋەزىپىسى قازان نېنى ئېتىشكە مەسئۇل ئىدى.
\v 32 ئۇلارنىڭ قېرىنداشلىرى، كوھاتنىڭ ئەۋلادلىرى ئىچىدە «تەقدىم نان»غا مەسئۇل بولۇپ، ھەر شابات كۈنى تىزىدىغانغا نانلارنى تەييارلايتتى.
\m 
\v 33 لاۋىيلارنىڭ جەمەت باشلىرى بولغان نەغمىچىلەر ئىبادەتخانىدىكى ئۆيلەردە تۇرۇپ، باشقا خىزمەتلەرنى قىلماي، كېچە-كۈندۈز ئۆز ئىشلىرى بىلەنلا بولاتتى.
\v 34 يۇقىرىدىكى كىشىلەرنىڭ ھەممىسى لاۋىيلار ئىچىدىكى يولباشچىلار بولۇپ، ھەممىسى ئۆز نەسەبى بويىچە جەمەت بېشى ئىدى؛ بۇلارنىڭ ھەممىسى يېرۇسالېمدا تۇراتتى.
\b
\s1 سائۇلنىڭ ئاتا-بوۋىلىرى، جەئىيەلنىڭ ئەۋلادلىرى
\m 
\v 35 گىبېئوننىڭ ئاتىسى يەئىيەل گىبېئونغا ماكانلاشقانىدى. ئۇنىڭ ئايالىنىڭ ئىسمى مائاكاھ ئىدى.
\v 36 ئۇنىڭ تۇنجى ئوغلى ئابدون، قالغان ئوغۇللىرى زۇر، كىش، بائال، نەر، ناداب،
\v 37 گېدور، ئاخىيو، زەكەرىيا ۋە مىكلوت ئىدى.
\v 38 مىكلوتتىن شىمېيام تۆرەلگەن. بۇلارمۇ ئۆزلىرىنىڭ قېرىنداشلىرىنىڭ يېنىدا يېرۇسالېمدا قوشنا ئولتۇرۇشاتتى. \f ◼ \fr 9:38 \ft \bd «شىمېيام»\bd* ــ 32:8دە «شىمېيا».\f*
\m 
\v 39 نەردىن كىش تۆرەلگەن، كىشتىن سائۇل تۆرەلگەن، سائۇلدىن يوناتان، مالكىشۇيا، ئابىناداب ۋە ئېش-بائال تۆرەلگەن.
\v 40 مېرىب-بائال يوناتاننىڭ ئوغلى ئىدى؛ مېرىب-بائالدىن مىكاھ تۆرەلگەن. \f ◼ \fr 9:40 \ft \bd «مېرىب-بائال»\bd* ــ «2سام.» 4:4دە «مەفىبوشەت».\f*
\v 41 مىكاھنىڭ ئوغۇللىرى پىتون، مەلەك، تاھرىيا ۋە ئاھاز ئىدى. \f ◼ \fr 9:41 \ft \bd «تاھرىيا»\bd* ــ 35:8دە «تارىيا».\f*
\v 42 ئاھازدىن ياراھ تۆرەلدى؛ ياراھدىن ئالەمەت، ئازماۋەت ۋە زىمرى تۆرەلگەن. زىمرىدىن موزا تۆرەلگەن؛ \f ◼ \fr 9:42 \ft \bd «ياراھ»\bd* ــ 36:8دە «يەھوئادداھ».\f*
\v 43 موزادىن بىنېئا تۆرەلگەن؛ بىنېئانىڭ ئوغلى رېفايا، رېفايانىڭ ئوغلى ئېلىئاساھ، ئېلىئاساھنىڭ ئوغلى ئازەل ئىدى. \f ◼ \fr 9:43 \ft \bd «رېفايا»\bd* ــ 36:8دە «رافا».\f*
\m 
\v 44 ئازەلنىڭ ئالتە ئوغلى بار ئىدى، ئۇلارنىڭ ئىسمى ئازرىكام، بوكېرۇ، ئىشمائىل، شېئارىيا، ئوبادىيا ۋە ھانان ئىدى؛ بۇلارنىڭ ھەممىسى ئازەلنىڭ ئوغۇللىرى.
\b
\b
\c 10
\s1 سائۇل ۋە ئۇنىڭ ئوغۇللىرىنىڭ قەتل قىلىنىشى
\r 1سام. 31‏:1-13
\m 
\v 1 فىلىستىيلەر ئىسرائىللارغا ھۇجۇم قىلىۋىدى، ئىسرائىللار فىلىستىيلەرنىڭ ئالدىدىن قاچتى، ئۇلار گىلبوئا تېغىدا قىرىپ يوقىتىلدى.
\v 2 فىلىستىيلەر سائۇل بىلەن ئۇنىڭ ئوغۇللىرىنى تاپ بېسىپ قوغلىدى؛ ئۇلار ئاخىرى سائۇلنىڭ ئوغۇللىرىدىن يوناتان، ئابىناداب، مالكى-شۇئالارنى ئۇرۇپ ئۆلتۈردى.
\v 3 سائۇلغا قارشى جەڭ ئىنتايىن شىددەتلىك بولدى؛ ئوقياچىلار سائۇلغا يېتىشىپ ئوقيا ئېتىپ ئۇنى يارىلاندۇردى. \f ◼ \fr 10:3 \ft \bd «ئوقياچىلار سائۇلغا يېتىشىپ ئوقيا ئېتىپ ئۇنى يارىلاندۇردى»\bd* ــ ياكى «ئوقياچىلار سائۇلغا يېتىشىپ، ئۇ ئوقياچىلاردىن ئازابلاندى».\f*
\v 4 ئاندىن سائۇل ياراغ كۆتۈرگۈچىسىگە: قىلىچىڭنى سۇغۇرۇپ مېنى سانجىپ ئۆلتۈرۈۋەتكىن؛ بولمىسا بۇ خەتنىسىزلەر كېلىپ مېنى سانجىپ، مېنى خورلۇققا قويۇشى مۇمكىن، دېدى. لېكىن ياراغ كۆتۈرگۈچىسى ئىنتايىن قورقۇپ كېتىپ، ئۇنىمىدى. شۇنىڭ بىلەن سائۇل قىلىچنى ئېلىپ ئۈستىگە ئۆزىنى تاشلىدى.
\m 
\v 5 ياراغ كۆتۈرگۈچىسى سائۇلنىڭ ئۆلگىنىنى كۆرۈپ، ئۇمۇ ئوخشاشلا ئۆزىنى قىلىچنىڭ ئۈستىگە تاشلاپ ئۇنىڭ بىلەن تەڭ ئۆلدى.
\v 6 شۇنىڭ بىلەن سائۇل، ئۈچ ئوغلى ھەم پۈتۈن ئائىلىسىدىكىلەر شۇ كۈندە بىراقلا ئۆلدى.
\v 7 ئەمدى ۋادىدا تۇرغان ئىسرائىللار ئەسكەرلىرىنىڭ قاچقانلىقىنى ۋە سائۇل بىلەن ئوغۇللىرىنىڭ ئۆلگىنىنى كۆرگىنىدە، ئۇلار شەھەرلىرىنى تاشلاپ قاچتى، فىلىستىيلەر كېلىپ ئۇ جايلاردا ئورۇنلاشتى.
\m 
\v 8 ئەمدى شۇنداق بولدىكى، ئەتىسى فىلىستىيلەر ئۆلتۈرۈلگەنلەرنىڭ كىيىم-كېچەكلىرىنى سالدۇرۇۋالغىلى كەلگەندە گىلبوئا تېغىدا سائۇل بىلەن ئوغۇللىرىنىڭ ئۆلۈك ياتقانلىقىنى كۆردى-دە،
\v 9 كىيىملىرىنى سالدۇرۇپ، كاللىسىنى ۋە ساۋۇت-ياراغلىرىنى ئېلىپ كەتتى ھەمدە بۇلارنى فىلىستىيلەرنىڭ زېمىنىنىڭ ھەممە يەرلىرىگە ئاپىرىپ، ئۆز بۇتلىرىغا ۋە خەلققە خۇش خەۋەر يەتكۈزدى. \f ◼ \fr 10:9 \ft \bd «... كىيىملىرىنى سالدۇرۇپ، كاللىسىنى ۋە ساۋۇت-ياراغلىرىنى ئېلىپ كەتتى ھەمدە بۇلارنى فىلىستىيلەرنىڭ زېمىنىنىڭ ھەممە يەرلىرىگە ئاپىرىپ...»\bd* ــ ياكى «.كىيىملىرىنى سالدۇرۇپ، كاللىسىنى ۋە ساۋۇت-ياراغلىرىنى ئېلىپ كەتتى ھەمدە ئەلچىلەرنى فىلىستىيلەرنىڭ زېمىنىنىڭ ھەممە يەرلىرىگە ئەۋەتىپ، ... خۇش خەۋەر يەتكۈزدى».\f*
\v 10 ئۇلار سائۇلنىڭ ساۋۇت-ياراغلىرىنى ئۇلارنىڭ بۇتخانىسىدا قويۇپ، كاللىسىنى داگون بۇتخانىسىغا ئېسىپ قويدى.
\m 
\v 11 ئەمدى يابەش-گىلېئاددا ئولتۇرغۇچىلار فىلىستىيلەرنىڭ سائۇلغا بارلىق قىلغانلىرىنى ئاڭلىغاندا
\v 12 ئۇلارنىڭ ئىچىدىكى ھەممە باتۇرلار ئاتلىنىپ، سائۇل بىلەن ئوغۇللىرىنىڭ جەسەتلىرىنى ئېلىپ، ئۇلارنى يابەشكە قايتۇرۇپ كېلىپ، يابەشتىكى دۇب دەرىخىنىڭ تۈۋىگە دەپنە قىلدى ۋە يەتتە كۈن روزا تۇتتى.
\m 
\v 13‏-14 شۇنىڭ بىلەن سائۇل پەرۋەردىگارغا قىلغان ۋاپاسىزلىقى ئۈچۈن ئۆلدى؛ ئۇ پەرۋەردىگارنىڭ سۆز-كالامىغا كىرمەي ۋە ھەتتا پەرۋەردىگاردىن يول سورىماي، بەلكى پالچى جىنكەشنىڭ يېنىغا بېرىپ ئۇنىڭدىن يول سورىغانىدى. شۇڭا پەرۋەردىگار ئۇنى ئۆلتۈرۈپ، پادىشاھلىقىنى يەسسەنىڭ ئوغلى داۋۇتقا ئۆتكۈزۈپ بەردى.
\b
\b
\c 11
\s1 داۋۇتنىڭ يەھۇدىيەگە پادىشاھ بولۇشقا مەسىھ قىلىنغانلىقى
\r 2سام. 5‏:1-10
\m 
\v 1 ئۇ چاغدا بارلىق ئىسرائىل جامائىتى ھېبرونغا كېلىپ داۋۇتنىڭ قېشىغا يىغىلىشىپ: «قارىسىلا، بىز ئۆزلىرىنىڭ ئەت-سۆڭەكلىرىدۇرمىز!
\v 2 بۇرۇن سائۇل بىزنىڭ ئۈستىمىزدە سەلتەنەت قىلغاندىمۇ ئىسرائىل خەلقىگە جەڭگە چىقىپ-كىرىشكە يولباشچى بولغان ئۆزلىرى ئىدىلا. ئۆزلىرىنىڭ خۇدالىرى بولغان پەرۋەردىگارمۇ ئۆزلىرىگە: ــ سەن مېنىڭ خەلقىم ئىسرائىلنىڭ پادىچىسى بولۇپ ئۇلارنى باقىسەن ۋە ئىسرائىلنىڭ ئەمىرى بولىسەن، دېگەنىدى» ــ دېدى. \f ◼ \fr 11:2 \ft \bd «جەڭگە چىقىپ-كىرىشكە يولباشچى»\bd* ــ ئىبرانىي تىلىدا «ئىسرائىلنىڭ چىقىشىدا ھەم كىرىشىدە ئۇلارغا باشلىغۇچى ئىدىلا» دېگەنلىك بىلەن ئىپادىلىنىپ، ئىسرائىلنىڭ بارلىق پائالىيەتلىرىنى كۆرسىتىدۇ.\f*
\m 
\v 3 شۇنىڭ بىلەن ئىسرائىل ئاقساقاللىرىنىڭ ھەممىسى ھېبرونغا كېلىپ پادىشاھ داۋۇتنىڭ قېشىغا كېلىشتى؛ داۋۇت ھېبروندا پەرۋەردىگارنىڭ ئالدىدا ئۇلار بىلەن بىر ئەھدە تۈزۈشتى. ئاندىن ئۇلار پەرۋەردىگارنىڭ سامۇئىلنىڭ ۋاستىسى بىلەن ئېيتقىنى بويىچە، داۋۇتنى مەسىھ قىلىپ، ئىسرائىلنى ئىدارە قىلىشقا پادىشاھ قىلىپ تىكلىدى. \x ◘ \xo 11:3 \xt 1سام. 16‏:1، 13؛ 2سام. 5‏:3\x*
\b
\s1 داۋۇتنىڭ يېرۇسالېمنى ئىشغال قىلىشى
\m 
\v 4 داۋۇت بىلەن بارلىق ئىسرائىل خەلقى يېرۇسالېمغا كەلدى (يېرۇسالېم شۇ چاغدا «يەبۇس» دەپ ئاتىلاتتى، زېمىندىكى ئاھالە بولغان يەبۇسىيلار شۇ يەردە تۇراتتى).
\v 5 يەبۇس ئاھالىسى داۋۇتقا: «سەن بۇ يەرگە ھېچقاچان كىرەلمەيسەن!» دېدى. بىراق داۋۇت زىئون دېگەن قورغاننى ئالدى (شۇ يەر «داۋۇتنىڭ شەھىرى» دەپمۇ ئاتىلىدۇ). \f ◼ \fr 11:5 \ft \bd «زىئون دېگەن قورغان»\bd* ــ «زىئون» يېرۇسالېمنىڭ ئىچىدىكى ئېگىزلىك بولۇپ، شۇ يەرگە دائىم قورغان سېلىنىپ تۇراتتى. كېيىن ئىبادەتخانىمۇ زىئوندا قۇرۇلغان.\f*
\v 6 داۋۇت: «كىم ئالدى بىلەن يەبۇسىيلارغا ھۇجۇم قىلسا، شۇ كىشى يولباشچى ۋە سەردار بولىدۇ» دېدى. زەرۇئىيانىڭ ئوغلى يوئاب ئالدى بىلەن ئاتلىنىپ چىقىپ، يولباشچى بولدى.
\v 7 داۋۇت قورغاندا تۇراتتى، شۇڭا كىشىلەر ئۇ قورغاننى «داۋۇت شەھىرى» دەپ ئاتاشتى.
\v 8 داۋۇت شەھەرنى مىللودىن باشلاپ تۆت ئەتراپىدىكى سېپىلىغىچە يېڭىۋاشتىن ياساتتى؛ شەھەرنىڭ قالغان قىسمىنى يوئاب ياساتتى. \f ◼ \fr 11:8 \ft \bd «مىللو»\bd* ــ «پەلەمپەيلىك يەر» دېگەن مەنىدە بولۇشى مۇمكىن.\f*
\v 9 داۋۇت كۈندىن كۈنگە قۇدرەت تاپتى، چۈنكى ساماۋى قوشۇنلارنىڭ سەردارى بولغان پەرۋەردىگار ئۇنىڭ بىلەن بىللە ئىدى.
\b
\s1 داۋۇتنىڭ پالۋانلىرى
\r 2سام. 23‏:8-39
\m 
\v 10 تۆۋەندىكىلەر داۋۇتنىڭ پالۋانلىرى ئىچىدە يولباشچىلار ئىدى؛ ئۇلار پەرۋەردىگارنىڭ ئىسرائىلغا ئېيتقان سۆزى بويىچە پۈتكۈل ئىسرائىل بىلەن بىرلىشىپ، داۋۇتنىڭ پادىشاھلىقىنى مۇستەھكەم قىلىپ، بىرلىكتە ئۇنى پادىشاھ قىلىشقا كۈچىدى.
\m 
\v 11 تۆۋەندىكىلەر داۋۇتنىڭ پالۋانلىرىنىڭ تىزىملىكى بويىچە خاتىرىلەنگەندۇر: ــ
\m ھاكمونىيلاردىن بولغان ياشوبېئام يولباشچىلار ئىچىدە بېشى ئىدى؛ ئۇ نەيزىسىنى پىقىرىتىپ بىر قېتىمدىلا ئۈچ يۈز ئادەمنى ئۆلتۈرگەن. \f ◼ \fr 11:11 \ft \bd «يولباشچىلار ئىچىدە»\bd* ــ بۇ ئىبارىنىڭ باشقا خىل تەرجىمىسى «ئوتتۇزى ئىچىدە»\f*
\v 12 ئۇنىڭدىن قالسا ئاخوخىي دودونىڭ ئوغلى ئەلىئازار بولۇپ، ئۇ «ئۈچ پالۋان»نىڭ بىرى ئىدى؛
\v 13 ئىلگىرى فىلىستىيلەر پاس-داممىمدا جەڭ قىلىشقا يىغىلغاندا، ئۇ داۋۇت بىلەن ئۇ يەردە ئىدى. ئۇ يەردە ئارپا ئۆسۈپ كەتكەن بىر ئېتىزلىق بولۇپ، خەلق فىلىستىيلەرنىڭ ئالدىدىن بەدەر قاچقانىدى؛
\v 14 ئۇلار بولسا ئېتىزلىقنىڭ ئوتتۇرىسىدا تۇرۇۋېلىپ، ھەم ئېتىزلىقنى قوغدىغان، ھەم فىلىستىيلەرنى تارمار قىلغان؛ پەرۋەردىگار ئەنە شۇ يول بىلەن ئۇلارنى غايەت زور غەلىبىگە ئېرىشتۈرگەن. \f ◼ \fr 11:14 \ft \bd «ئۇلار بولسا ئېتىزلىقنىڭ ئوتتۇرىسىدا تۇرۇۋېلىپ،... پەرۋەردىگار ... ئۇلارنى غايەت زور غەلىبىگە ئېرىشتۈرگەن»\bd* ــ مۇشۇ ئايەتتە «ئۇلار» بەلكىم داۋۇت ۋە «ئۈچ پالۋان»نى كۆرسىتىدۇ. «2سام.» 11:12-23دە ئەلىئازارنىڭ ئاۋۋال بۇ جەڭنى باشلىغانلىقى كۆرسىتىلىدۇ.\f*
\m 
\v 15 ئوتتۇز يولباشچى ئىچىدىن \add يەنە\add* ئۈچەيلەن قورام تاشلىقتىكى ئادۇللامنىڭ غارىغا چۈشۈپ داۋۇتنىڭ يېنىغا كەلدى. فىلىستىيلەرنىڭ قوشۇنى بولسا «رەفايىم جىلغىسى»دا بارگاھ قۇرغانىدى.
\v 16 بۇ چاغدا داۋۇت قورغاندا، فىلىستىيلەرنىڭ قاراۋۇلگاھى بەيت-لەھەمدە ئىدى.
\v 17 داۋۇت ئۇسساپ: «ئاھ، بىرسى ماڭا بەيت-لەھەمنىڭ دەرۋازىسىنىڭ يېنىدىكى قۇدۇقتىن سۇ ئەكىلىپ بەرگەن بولسا ياخشى بولاتتى!» دېۋىدى،
\v 18 بۇ ئۈچ پالۋان فىلىستىيلەرنىڭ لەشكەرگاھىدىن بۆسۈپ ئۆتۈپ، بەيت-لەھەمنىڭ دەرۋازىسىنىڭ يېنىدىكى قۇدۇقتىن سۇ تارتتى ۋە داۋۇتقا ئېلىپ كەلدى؛ لېكىن ئۇ ئۇنىڭدىن ئىچكىلى ئۇنىمىدى، بەلكى سۇنى پەرۋەردىگارغا ئاتاپ تۆكۈپ:
\v 19 «خۇدايىم بۇ ئىشنى مەندىن نېرى قىلسۇن! مەن ھاياتىنىڭ خەۋپتە قېلىشىغا قارىمىغان بۇ كىشىلەرنىڭ قېنىنى ئىچسەم قانداق بولىدۇ؟ چۈنكى بۇنى ئۇلار ھاياتىنىڭ خەۋپتە قېلىشىغا قارىماي ئېلىپ كەلگەن!» دېدى. شۇڭا داۋۇت بۇ سۇنى ئىچكىلى ئۇنىمىدى. بۇ ئۈچ پالۋان قىلغان ئىشلار دەل شۇلار ئىدى.
\m 
\v 20 يوئابنىڭ ئىنىسى ئابىشاي ئۈچىنىڭ بېشى ئىدى؛ ئۇ ئۈچ يۈز ئادەم بىلەن قارشىلىشىپ نەيزىسىنى پىقىرىتىپ ئۇلارنى ئۆلتۈردى. شۇنىڭ بىلەن ئۇ بۇ «ئۈچ پالۋان» ئىچىدە نامى چىققانىدى. \f ◼ \fr 11:20 \ft \bd «...شۇنىڭ بىلەن ئۇ بۇ «ئۈچ پالۋان» ئىچىدە نامى چىققانىدى»\bd* ــ بۇ ئايەتنىڭ يەنە بىرنەچچە خىل تەرجىمىسى بار. 21-ئايەتتىكى ئىزاھاتنى كۆرۈڭ.\f*
\v 21 ئۇ مۇشۇ «ئۈچ پالۋان» ئىچىدە ھەممىدىن بەك ھۆرمەتكە سازاۋەر بولغان بولسىمۇ، لېكىن يەنىلا ئاۋۋالقى ئۈچەيلەنگە يەتمەيتتى. \f ◼ \fr 11:21 \ft \bd «شۇنىڭ بىلەن ئۇ بۇ «ئۈچ پالۋان» ئىچىدە نامى چىققانىدى. ئۇ مۇشۇ «ئۈچ پالۋان» ئىچىدە ھەممىدىن بەك ھۆرمەتكە سازاۋەر بولغان بولسىمۇ، لېكىن يەنىلا ئاۋۋالقى ئۈچەيلەنگە يەتمەيتتى»\bd* ــ 20-21-ئايەتنىڭ باشقا بىرخىل تەرجىمىسى: ــ «شۇنىڭ بىلەن ئۇ «ئۈچ پالۋان» بىلەن تەڭ شۆھرەت قازانغان. ئۇ «ئۈچ پالۋان»دىن ئىككى ھەسسىلەپ ھۆرمەتكە ئىگە بولغان ۋە ئۇلارنىڭ بېشى بولغان بولسىمۇ، لېكىن ئۇلاردىن بىرى بولمىدى». ئەمما بىزنىڭچە تەرجىمىمىز «2سام.» 18:23-19گە ماس كېلىدۇ.\f*
\v 22 يەھويادانىڭ ئوغلى بىنايا كابزەئەلدىن بولۇپ، بىر باتۇر پالۋان ئىدى؛ ئۇ كۆپ قالتىس ئىشلارنى قىلغان. ئۇ موئابىي ئارىئەلنىڭ ئىككى ئوغلىنى ئۆلتۈرگەن. يەنە قار ياغقان بىر كۈنى ئازگالغا چۈشۈپ، بىر شىرنى ئۆلتۈرگەنىدى. \f ◼ \fr 11:22 \ft \bd «موئابىي ئارىئەلنىڭ ئىككى ئوغلى»\bd* ــ يەنە بىرخىل تەرجىمىسى: ــ «موئابتىكى ئىككى شىر...» ياكى «موئابتىكى ئىككى شىردەك كىشىنى...».\f*
\v 23 ئۇ يەنە قولىدا باپكارنىڭ ئوقىدەك بىر نەيزىسى بار، بويىنىڭ ئېگىزلىكى بەش گەز كېلىدىغان بىر مىسىرلىقنى قەتل قىلدى؛ ئۇ بىر ھاسا بىلەن ئۇنىڭغا ھۇجۇم قىلىپ، ئۇنىڭ نەيزىسىنى قولىدىن تارتىۋېلىپ ئۆز نەيزىسى بىلەن ئۆلتۈردى. \f ◼ \fr 11:23 \ft \bd «بەش گەز»\bd* ــ ئىككى مېتردىن ئارتۇق (2.2 مېتر).\f*
\v 24 يەھويادانىڭ ئوغلى بىنايا مانا بۇ ئىشلارنى قىلغان. شۇنىڭ بىلەن ئۈچ پالۋان ئىچىدە نام چىقارغانىدى. \f ◼ \fr 11:24 \ft \bd «ئۈچ پالۋان ئىچىدە نام چىقارغانىدى»\bd* ــ ياكى «ئۈچ پالۋان بىلەن تەڭ نام چىقارغانىدى».\f*
\v 25 مانا، ئۇ ھېلىقى ئوتتۇز پالۋاندىنمۇ بەكرەك شۆھرەت قازانغان بولسىمۇ، لېكىن ئالدىنقى ئۈچ پالۋانغا يەتمەيتتى. داۋۇت ئۇنى ئۆزىنىڭ پاسىبان بېگى قىلىپ تەيىنلىگەن.
\m 
\v 26 قوشۇندىكى پالۋانلار بولسا: ــ
\m يوئابنىڭ ئىنىسى ئاساھەل، بەيت-لەھەملىك دودونىڭ ئوغلى ئەلھانان،
\v 27 ھارورلۇق شامموت، پىلونلۇق ھەلەز،
\v 28 تەكوئالىق ئىككەشنىڭ ئوغلى ئىرا، ئاناتوتلۇق ئابىئېزەر،
\v 29 خۇشاتلىق سىببەكاي، ئاخوھلۇق ئىلاي، \f ◼ \fr 11:29 \ft \bd «سىببەكاي»\bd* ــ ياكى «مەببۇناي» («2سام.» 27:23نى كۆرۈڭ).\f*
\v 30 نىتوفاتلىق ماھاراي، نىتوفاتلىق بائاناھنىڭ ئوغلى خەلەب،
\v 31 بىنيامىن ئەۋلادلىرىدىن گىبېئاھلىق رىباينىڭ ئوغلى ئىتتاي، پىراتونلۇق بىنايا،
\v 32 گائاش ۋادىلىرىدىن كەلگەن خۇراي، ئارباتلىق ئابىيەل، \f ◼ \fr 11:32 \ft \bd «خۇراي»\bd* ــ «2سام.» 31:23دە «ھىدداي».\f*
\v 33 باھارۇملۇق ئازماۋەت، شائالبونلۇق ئېلياھبا،
\v 34 گىزونلۇق ھاشەمنىڭ ئوغۇللىرى، ھارارلىق شاگىنىڭ ئوغلى يوناتان، \f ◼ \fr 11:34 \ft \bd «ھاشەمنىڭ ئوغۇللىرى»\bd* ــ ياكى «ياشەننىڭ ئوغۇللىرى». («2سام.» 33:23نى كۆرۈڭ).\f*
\v 35 ھارارلىق ساكارنىڭ ئوغلى ئاھىيام، ئۇرنىڭ ئوغلى ئېلىفال،
\v 36 مەكەراتلىق ھەفەر، پىلونلۇق ئاخىياھ،
\v 37 كارمەللىك ھەزرو، ئەزباينىڭ ئوغلى نائاراي،
\v 38 ناتاننىڭ ئىنىسى يوئېل، ھاگرىنىڭ ئوغلى مىبھار،
\v 39 ئاممونلۇق زەلەك، زەرۇئىيانىڭ ئوغلى يوئابنىڭ ياراغ كۆتۈرگۈچىسى بولغان بەئەروتلۇق ناھاراي،
\v 40 ئىترىلىق ئىرا، ئىترىلىق گارەب،
\v 41 ھىتتىي ئۇرىيا، ئاھلاينىڭ ئوغلى زاباد،
\v 42 رۇبەن قەبىلىسىدىن شىزانىڭ ئوغلى، رۇبەنلەر ئىچىدە يولباشچى بولغان ئادىنا ۋە ئۇنىڭغا ئەگەشكەن ئوتتۇز ئادەم،
\v 43 مائاكاھنىڭ ئوغلى ھانان، مىتنىلىق يوشافات،
\v 44 ئاشتاراتلىق ئۇززىيا، ئاروئەرلىك خوتامنىڭ ئوغلى شاما بىلەن يەئىيەل،
\v 45 شىمرىنىڭ ئوغلى يېدىيايەل بىلەن ئۇنىڭ ئىنىسى تىزىلىق يوخا،
\v 46 ماھاۋىلىق ئەلىيەل، ئەلنائامنىڭ ئوغۇللىرى يەرىباي بىلەن يوشاۋىيا، موئابلىق يىتما، \f ◼ \fr 11:46 \ft \bd «...موئابلىق يىتما»\bd* ــ بۇ تىزىملىكتە بىرنەچچە يەھۇدىي ئەمەسلەر ــ مەسىلەن، ئاممونلۇق زەلەك، ھىتتىي ئۇرىيا ۋە موئابلىق تىمنا بار.\f*
\v 47 ئەلىيەل، ئوبەد ۋە مەزوبالىق يائاسىيەللەردىن ئىبارەت ئىدى.
\b
\b
\c 12
\s1 داۋۇتقا بېقىنغان بىنيامىن پالۋانلىرى
\m 
\v 1 داۋۇت كىشنىڭ ئوغلى سائۇلنىڭ بېسىمى سەۋەبىدىن زىكلاگدا يوشۇرۇنۇپ ياتقان چاغدا مۇنۇ كىشىلەر داۋۇتنىڭ يېنىغا كېلىشتى (ئۇلارنىڭ ھەممىسى داۋۇتقا جەڭ قىلىشتا ياردەم بەرگەن باتۇرلاردىن ئىدى؛
\v 2 ئوقيا بىلەن قوراللانغان بولۇپ، ئوڭ قولى بىلەنمۇ، سول قولى بىلەنمۇ ئوقيا ۋە سالغا ئاتالايتتى؛ ئۇلار سائۇلنىڭ بىنيامىن قەبىلىسىدىن بولغان تۇغقانلىرى ئىدى):
\v 3 ــ ئۇلارنىڭ يولباشچىسى ئاخىئېزەر، ئاندىن قالسا يوئاش بولۇپ، ئىككىسى گىبېئاھلىق شېمائاھنىڭ ئوغلى ئىدى؛ يەنە ئازماۋەتنىڭ ئوغلى يەزىيەل بىلەن پەلەتمۇ؛ يەنە بەراكاھ بىلەن ئاناتوتلۇق يەھۇ،
\v 4 گىبېئونلۇق يىشمايامۇ بار ئىدى. يىشمايا «ئوتتۇز پالۋان» ئىچىدە باتۇر بولۇپ شۇ ئوتتۇزىغا يېتەكچىلىك قىلغۇچى ئىدى؛ يەنە يەرەمىيا، ياھازىيەل، يوھانان ۋە گەدەراتلىق يوزاباد،
\v 5 ئەلۇزاي، يەرىموت، بىئالىيا، شەمارىيا، خارۇفلۇق شەفاتىيا،
\v 6 كوراھلىقلاردىن بولغان ئەلكاناھ، يىسشىيا، ئازارەل، يوئېزەر ۋە ياشوبېئاملار؛
\v 7 يەنە گەدورلۇق يەروھامنىڭ ئوغلى يوئېلاھ بىلەن زەبادىيا بار ئىدى.
\b
\s1 داۋۇتقا بېقىنغان گاد پالۋانلىرى
\m 
\v 8 گاد قەبىلىسىدىن بەزىلەر چۆلدىكى قورغانغا بېرىپ داۋۇتقا بېقىندى. ئۇلارنىڭ ھەممىسى جەڭگە ماھىر، قالقان ۋە نەيزە بىلەن قوراللانغان باتۇر جەڭچىلەر ئىدى؛ ئۇلارنىڭ تۇرقى بەئەينى شىرغا، چاققانلىقى بەئەينى تاغدىكى بۆكەنگە ئوخشايتتى.
\v 9 ئۇلارنىڭ بىرىنچىسى ئېزەر، ئىككىنچىسى ئوبادىيا، ئۈچىنچىسى ئېلىئاب،
\v 10 تۆتىنچىسى مىشمانناھ، بەشىنچىسى يەرەمىيا،
\v 11 ئالتىنچىسى ئاتتاي، يەتتىنچىسى ئەلىيەل،
\v 12 سەككىزىنچىسى يوھانان، توققۇزىنچىسى ئەلزاباد،
\v 13 ئونىنچىسى يەرەمىيا، ئون بىرىنچىسى ماكبانناي ئىدى.
\v 14 بۇلارنىڭ ھەممىسى گاد قەبىلىسىدىن، قوشۇن ئىچىدە سەردارلار ئىدى؛ ئەڭ كىچىكى يۈز لەشكەرگە، ئەڭ چوڭى مىڭ لەشكەرگە يېتەكچى ئىدى. \f ◼ \fr 12:14 \ft \bd «ئەڭ كىچىكى يۈز لەشكەرگە، ئەڭ چوڭى مىڭ لەشكەرگە يېتەكچى ئىدى»\bd* ــ باشقا بىرخىل تەرجىمىسى: «ئەڭ كىچىكى يۈز ئادەمگە، ئەڭ چوڭى مىڭ ئادەمگە يېتىيتتى».\f*
\v 15 بىرىنچى ئايدا، ئىئوردان دەرياسى تېشىپ قىرغاقتىن ئاشقان چاغدا، دەريادىن ئۆتۈپ، شەرققە ۋە غەربكە قارايدىغان بارلىق جىلغىلاردىكىلەرنى تىرىپىرەن قىلىپ قاچۇرغانلار دەل مۇشۇ ئادەملەر ئىدى. \f ◼ \fr 12:15 \ft \bd «بىرىنچى ئاي»\bd* ــ مارت ياكى ئاپرېل.\f*
\b
\s1 داۋۇتقا بېقىنغان بىنيامىنلار ۋە يەھۇدالار
\m 
\v 16 بىنيامىن قەبىلىسى بىلەن يەھۇدا قەبىلىسىدىنمۇ كىشىلەر قورغانغا كېلىپ داۋۇتقا بېقىنغان.
\v 17 داۋۇت چىقىپ ئۇلارنى قارشى ئېلىپ: «ئەگەر سىلەر تىنچلىق نىيىتىدە ماڭا ياردەم بېرىشكە كەلگەن بولساڭلار، سىلەر بىلەن بىر جان بىر دىل بولىمەن، لېكىن قوللىرىمدا ھېچ ناھەقلىق بولمىغان مېنى دۈشمەنلىرىمگە سېتىۋەتمەكچى بولساڭلار، ئاتا-بوۋىلىرىمنىڭ خۇداسى بۇنى نەزىرىگە ئېلىپ ھۆكۈم چىقارغاي!» ــ دېدى.
\m 
\v 18 بۇ چاغدا خۇدانىڭ روھى ھېلىقى ئوتتۇز پالۋاننىڭ يولباشچىسى ئاماسايغا چۈشۈۋىدى، ئۇ:
\m «ئاھ داۋۇت، بىز ساڭا بېقىندۇقمىز؛
\m ئاھ يەسسەنىڭ ئوغلى، بىز سەن بىلەن بىللىدۇرمىز؛
\m ئۆزۈڭگە ئامان-تىنچلىق، ئامان-تىنچلىق بولغاي!
\m ساڭا ياردەم بەرگۈچىلەرگىمۇ ئامان-تىنچلىق بولغاي!
\m چۈنكى سېنىڭ خۇدايىڭ ساڭا مەدەتكاردۇر»
\m شۇنىڭ بىلەن داۋۇت ئۇلارنى ئېلىپ قېلىپ، «زەربىدار ئەترەت باشلىقلىرى» قىلدى. \f ◼ \fr 12:18 \ft \bd «خۇدانىڭ روھى»\bd* ــ مۇشۇ يەردە ئىبرانىي تىلىدا پەقەت «روھ» دېيىلىدۇ.\f*
\b
\s1 داۋۇتقا بېقىنغان ماناسسەھلەر
\m 
\v 19 داۋۇت ئىلگىرى فىلىستىيلەر بىلەن بىرلىكتە سائۇلغا قارشى ئۇرۇشقا ئاتلانغاندا، ماناسسەھ قەبىلىسىدىكى بەزىلەر داۋۇت تەرەپكە ئۆتتى (لېكىن ئۇلار \add فىلىستىيلەرگە\add* ياردەم بەرمىدى، چۈنكى فىلىستىيلەرنىڭ ئەمىرلىرى: «داۋۇت ئۆز غوجىسى سائۇل تەرەپكە ئۆتۈپ كېتىشى مۇمكىن، ئۇنداقتا بېشىمىز كەتمەي قالمايدۇ!» دەپ مەسلىھەتلىشىپ ئۇلارنى قايتۇرۇپ كەتمەكچى بولغانىدى). \f ◼ \fr 12:19 \ft \bd «لېكىن ئۇلار فىلىستىيلەرگە ياردەم بەرمىدى، چۈنكى فىلىستىيلەرنىڭ ئەمىرلىرى: «داۋۇت ئۆز غوجىسى سائۇل تەرەپكە ئۆتۈپ كېتىشى مۇمكىن، ئۇنداقتا بېشىمىز كەتمەي قالمايدۇ!» دەپ مەسلىھەتلىشىپ ئۇلارنى قايتۇرۇپ كەتمەكچى بولغانىدى»\bd* ــ «1سام.» 4:29نى كۆرۈڭ.\f*
\v 20 داۋۇت زىكلاگقا قايتىپ بارغاندا، ماناسسەھ قەبىلىسىدىكى ئادناھ، يوزاباد، يەدىيايەل، مىكائىل، يوزاباد، ئېلىخۇ، زىلتايلار كېلىپ ئۇنىڭغا قوشۇلدى. بۇلارنىڭ ھەممىسى ماناسسەھ قەبىلىسىنىڭ مىڭبېشىلىرى ئىدى.
\v 21 ئۇلار داۋۇت قاراقچىلارغا قارشى جەڭ قىلغاندا ئۇنىڭغا ياردەملەشتى؛ ئۇلارنىڭ ھەممىسى باتۇر پالۋانلار، قوشۇندىكى يولباشچىلار ئىدى. \f ◼ \fr 12:21 \ft \bd «ئۇلار داۋۇت قاراقچىلارغا قارشى جەڭ قىلغاندا ئۇنىڭغا ياردەملەشتى»\bd* ــ كۆزدە تۇتقىنى بەلكىم «1سام.» 30-بابتا خاتىرىلەنگەن ئىشلار؛ شۇ چاغدا داۋۇت ئامالەك قاراقچىلىرىغا ھۇجۇم قىلغان.\f*
\v 22 چۈنكى شۇ كۈنلەردە داۋۇتقا ياردەم بېرىش ئۈچۈن ھەر كۈنى ئادەملەر كېلىپ قوشۇلۇپ، خۇددى خۇدانىڭ قوشۇنىدەك زور بىر قوشۇن بولۇپ كەتكەنىدى.
\b
\s1 داۋۇتقا كېلىپ قوشۇلغان قوشۇنلار
\m 
\v 23 پەرۋەردىگارنىڭ سۆز-كالامى ئەمەلگە ئاشۇرۇلۇپ، سائۇلنىڭ پادىشاھلىقىنى داۋۇتقا ئېلىپ بەرمەكچى بولغان قوراللانغان جەڭچىلەر يولباشچىلىرى بىلەن ھېبرونغا، ئۇنىڭ يېنىغا كەلدى. ئۇلارنىڭ سانى تۆۋەندىكىچە: ــ
\m 
\v 24 يەھۇدالاردىن قالقان ۋە نەيزە بىلەن قوراللانغانلار جەمئىي ئالتە مىڭ سەككىز يۈز كىشى بولۇپ، ھەممىسى جەڭگە تەييارلانغانىدى.
\v 25 شىمېئونلاردىن جەڭگە تەييارلانغان باتۇر جەڭچىلەر جەمئىي يەتتە مىڭ بىر يۈز كىشى،
\v 26 لاۋىيلاردىن جەمئىي تۆت مىڭ ئالتە يۈز كىشى؛
\v 27 يەھويادا ھارۇنلارنىڭ جەمەت بېشى بولۇپ، ئۇنىڭغا ئەگەشكەنلەر جەمئىي ئۈچ مىڭ يەتتە يۈز كىشى ئىدى.
\v 28 يەنە ياش بىر باتۇر جەڭچى زادوك ۋە ئۇنىڭ جەمەتىدىن يىگىرمە ئىككى يولباشچى بار ئىدى.
\v 29 بىنيامىنلاردىن، سائۇلنىڭ ئۇرۇق-تۇغقانلىرىدىنمۇ ئۈچ مىڭ كىشى بار ئىدى؛ شۇ چاغقا قەدەر بۇلارنىڭ كۆپىنچىسى سائۇل جەمەتىنى قوللاپ كەلمەكتە ئىدى.
\m 
\v 30 ئەفرائىملاردىن، ئۆز جەمەتلىرىدە يۈز-ئابروي تاپقان باتۇر ئەزىمەتلەر جەمئىي يىگىرمە مىڭ سەككىز يۈز كىشى ئىدى.
\v 31 ماناسسەھ يېرىم قەبىلىسى ئىچىدە نامى پۈتۈلگەن، داۋۇتنى پادىشاھ قىلىپ تىكلەشكە كەلگەنلەر جەمئىي ئون سەككىز مىڭ كىشى ئىدى.
\v 32 ئىسساكارلاردىن زامان-ۋەزىيەتنى چۈشىنىدىغان، ئىسرائىلنىڭ قانداق قىلىشى كېرەكلىكىنى بىلىدىغان يولباشچىلار جەمئىي ئىككى يۈز كىشى ئىدى؛ ئۇلارنىڭ ھەممە قېرىنداشلىرى ئۇلارنىڭ ئەمرىگە بويسۇناتتى.
\v 33 زەبۇلۇنلاردىن جەڭگە تەييارلانغان، ھەرخىل قورال-ياراغلار بىلەن قوراللانغان، ئالا كۆڭۈللۈك قىلمايدىغان، داۋۇتنىڭ ياردىمىگە كەلگەن جەمئىي ئەللىك مىڭ كىشى ئىدى.
\v 34 نافتالىلاردىن يولباشچى بولغان مىڭ كىشى بار ئىدى؛ ئۇلارغا ئەگىشىپ قولىغا قالقان ۋە نەيزە ئالغانلار جەمئىي ئوتتۇز يەتتە مىڭ كىشىگە يېتەتتى.
\v 35 دانلاردىن جەڭگە تەييارلانغان جەمئىي يىگىرمە سەككىز مىڭ ئالتە يۈز كىشى ئىدى.
\v 36 ئاشىرلاردىن جەڭگە چىقىپ قوشۇن سېپىگە ئاتلىنىشقا تەييار بولغان جەمئىي قىرىق مىڭ كىشى ئىدى.
\v 37 ئىئوردان دەرياسىنىڭ شەرق تەرىپىدىكى رۇبەن قەبىلىسى، گاد قەبىلىسى ۋە ماناسسەھ يېرىم قەبىلىسىدىن قولىغا ھەرخىل قورال-ياراغ ئېلىپ جەڭگە تەييارلانغان جەمئىي بىر يۈز يىگىرمە مىڭ كىشى ئىدى.
\m 
\v 38 يۇقىرىدا تىلغا ئېلىنغان بۇ ئەزىمەتلەرنىڭ ھەربىي يۈرۈشى تەكشى بولۇپ، داۋۇتنى پۈتكۈل ئىسرائىل ئۈستىگە پادىشاھ قىلىپ تىكلەش ئۈچۈن بىر جان بىر دىل بولۇپ، ھېبرونغا كېلىشكەنىدى؛ قالغان ئىسرائىللارمۇ بىر نىيەت بىر مەقسەتتە داۋۇتنى پادىشاھ قىلىپ تىكلىمەكچى بولۇشقانىدى.
\m 
\v 39 ئۇلار شۇ يەردە داۋۇت بىلەن ئۈچ كۈن بىللە يەپ-ئىچىپ غىزالاندى، چۈنكى ئۇلارنىڭ قېرىنداشلىرى ئۇلارغا تەييارلاپ قويۇشقانىدى.
\v 40 ئۇلارنىڭ ئۆپچۈرىسىدىكى خەلقلەر، ھەتتا ئىسساكار، زەبۇلۇن ۋە نافتالىلارنىڭ زېمىنىدىكىلەر ئېشەك، تۆگە، قېچىر ۋە كالىلارغا ئارتىپ ئۇلارغا ناھايىتى كۆپ ئوزۇقلۇق ئېلىپ كەلگەن؛ ئۇلار زور مىقداردا ئۇن، ئەنجۈر پوشكىلى، ئۈزۈم پوشكىلى، شاراب، زەيتۇن مېيى ۋە نۇرغۇن قوي-كالىلارنى يەتكۈزۈپ بېرىشكەنىدى؛ پۈتكۈل ئىسرائىل شاد-خۇراملىققا چۆمگەنىدى.
\b
\b
\c 13
\s1 ئەھدە ساندۇقىنىڭ ئاپىرىلىشىدا بولغان بالايىقازا
\r 2سام. 6‏:1-11
\m 
\v 1 داۋۇت مىڭبېشى، يۈزبېشى ۋە بارلىق يولباشچىلار بىلەن مەسلىھەتلەشتى؛
\v 2 ئاندىن پۈتۈن ئىسرائىل ئاممىسىغا: «ئەگەر سىلەر ماقۇل كۆرسەڭلار، شۇنداقلا بۇ ئىشنى خۇدايىمىز پەرۋەردىگاردىن دەپ بىلسەڭلار، بىز ئىسرائىلنىڭ زېمىنلىرىنىڭ ھەرقايسى جايلىرىغا شۇ يەردە قالغان قېرىنداشلىرىمىزغا ھەمدە ئۇلار بىلەن بىللە شەھەرلەردە ۋە ئېتىزلىقلىرىدا تۇرۇۋاتقان كاھىن ھەم لاۋىيلارغا مۇشۇ يەرگە يىغىلىش توغرۇلۇق ئادەم ئەۋەتەيلى.
\v 3 بىز خۇدايىمىزنىڭ ئەھدە ساندۇقىنى مەشەگە يۆتكەپ كېلەيلى؛ چۈنكى سائۇلنىڭ كۈنلىرىدە ھېچقايسىمىز \add ئەھدە ساندۇقى\add* ئالدىدا خۇدادىن يول سوراپ باقمىدۇق» دېدى.
\v 4 بۇ ئىشنى پۈتۈن ئامما توغرا تاپقاچقا، ھەممەيلەن ماقۇل بولۇشتى.
\m 
\v 5 شۇڭا داۋۇت مىسىرنىڭ شىھور دەرياسىدىن تارتىپ خامات ئېغىزىغىچە بولغان پۈتكۈل ئىسرائىل خەلقىنى چاقىرتىپ كېلىپ، خۇدانىڭ ئەھدە ساندۇقىنى كىرىئات-يېئارىمدىن يۆتكەپ كەلمەكچى بولدى. \f ◼ \fr 13:5 \ft \bd «مىسىرنىڭ شىھور دەرياسىدىن تارتىپ خامات ئېغىزىغىچە»\bd* ــ جەنۇبتىن شىمالغىچە ئىسرائىلنىڭ پۈتكۈل زېمىنىنى كۆرسىتىدۇ.\fp «خامات ئېغىزى» دېگەننىڭ باشقا خىل تەرجىمىسى: «لىبو-خامات».\f*
\v 6 ئاندىن داۋۇت بىلەن پۈتكۈل ئىسرائىل خۇدانىڭ ئەھدە ساندۇقىنى يۆتكەپ كېلىش ئۈچۈن بائالاھقا، يەنى يەھۇداغا تەۋە بولغان كىرىئات-يېئارىمغا كەلدى؛ ئىككى كېرۇبنىڭ ئوتتۇرىسىدا ئولتۇرغۇچى پەرۋەردىگار بۇ ئەھدە ساندۇقى ئۈستىگە ئۆز نامىنى قويغانىدى.
\v 7 ئۇلار خۇدانىڭ ئەھدە ساندۇقىنى ئابىنادابنىڭ ئۆيىدىن ئېلىنغان يېڭى بىر ھارۋىغا قويدى؛ ئۇززاھ بىلەن ئاخىيو ھارۋىنى ھەيدىدى. \f ◼ \fr 13:7 \ft \bd «ئۇلار خۇدانىڭ ئەھدە ساندۇقىنى ئابىنادابنىڭ ئۆيىدىن ئېلىنغان يېڭى بىر ھارۋىغا قويدى»\bd* ــ ياكى «ئۇلار خۇدانىڭ ئەھدە ساندۇقىنى يېڭى بىر ھارۋىغا قويۇپ، ئۇنى ئابىنادابنىڭ ئۆيىدىن ئېلىپ چىقتى».\f*
\v 8 داۋۇت بىلەن بارلىق ئىسرائىل جامائىتى خۇدانىڭ ئالدىدا ھە دەپ نەغمە-ناۋا قىلىپ، چىلتار، تەمبۇر، داپ، جاڭلار ۋە كاناي-سۇنايلار چالاتتى.
\m 
\v 9 لېكىن ئۇلار كىدون خامىنىغا كەلگەندە كالىلار ئالدىغا مۈدۈرەپ كېتىپ يىقىلغاندا ئۇززاھ ئەھدە ساندۇقىنى يۆلىۋالاي دەپ قولىنى ئۇنىڭغا سوزدى.
\v 10 ئۇززاھنىڭ ئەھدە ساندۇقىغا قولى تەگكەنلىكى ئۈچۈن، خۇدا ئۇنىڭغا غەزەپلىنىپ ئۇنى ئۇرۇپ ئۆلتۈردى. شۇنىڭ بىلەن ئۇززاھ شۇ يەردە خۇدانىڭ ئالدىدا ئۆلدى. \f ◼ \fr 13:10 \ft \bd «ئۇززاھنىڭ ئەھدە ساندۇقىغا قولى تەگكەنلىكى ئۈچۈن، خۇدا ئۇنىڭغا غەزەپلىنىپ ئۇنى ئۇرۇپ ئۆلتۈردى»\bd* ــ مۇقەددەس قانۇن بويىچە پەقەت كاھىنلار ئەھدە ساندۇقىغا قول تەگكۈزۈشكە ۋە ئۇنى كۆتۈرۈشكە بولاتتى. ئۇنى كالا ھارۋىسى ئۈستىگە قويۇشقا بولمايتتى. شۇڭا داۋۇت ۋە پۈتكۈل ئىسرائىللار مۇشۇ ئىشتا ئەيىبلىك ئىدى.\f*
\m 
\v 11 لېكىن داۋۇت پەرۋەردىگارنىڭ ئۇززاھنىڭ تېنىنى بۆسكەنلىكىگە ئاچچىقلاندى ۋە ئۇ يەرنى «پەرەز-ئۇززاھ» دەپ ئاتىدى؛ ئۇ يەر تاكى ھازىرغىچە شۇ نام بىلەن ئاتىلىپ كەلمەكتە. \f ◼ \fr 13:11 \ft \bd «پەرەز-ئۇززاھ»\bd* ــ مەنىسى «ئۇززاھغا بۆسۈپ كىرىش».\f*
\v 12 شۇ كۈنى داۋۇت خۇدادىن قورقۇپ: «مەن زادى قانداق قىلىپ خۇدانىڭ ئەھدە ساندۇقىنى بۇ يەرگە يۆتكەپ كېلەلەيمەن؟» دېدى.
\m 
\v 13 شۇڭا داۋۇت ئەھدە ساندۇقىنى ئۆزى تۇرۇۋاتقان «داۋۇت شەھىرى»گە يۆتكەپ كەلمەي، گاتلىق ئوبەد-ئېدومنىڭ ئۆيىگە ئاپىرىپ قويدى.
\v 14 خۇدانىڭ ئەھدە ساندۇقى ئوبەد-ئېدومنىڭ ئۆيىدە ئۈچ ئاي تۇردى؛ پەرۋەردىگار ئوبەد-ئېدومنىڭ ئائىلىسىنى ۋە ئۇنىڭ بارلىق تەئەللۇقاتلىرىنى بەرىكەتلىدى.
\b
\b
\c 14
\s1 تۇر پادىشاھى داۋۇتنىڭ ئوردا سېلىشىغا ياردەملىشىدۇ
\r 1سام. 5‏:11-25
\m 
\v 1 تۇر پادىشاھى ھىرام داۋۇت بىلەن كۆرۈشۈشكە ئەلچىلەرنى، شۇنداقلا ئۇنىڭ ئۈچۈن ئوردا سېلىشقا كېدىر ياغىچى، تاشچى ۋە ياغاچچىلارنى ئەۋەتتى.
\v 2 بۇ چاغدا داۋۇت پەرۋەردىگارنىڭ ئۆزىنى ئىسرائىل ئۈستىگە ھۆكۈمرانلىق قىلىدىغان پادىشاھ بولۇشقا جەزمەن تىكلەيدىغانلىقىنى كۆرۈپ يەتتى؛ چۈنكى پەرۋەردىگار ئۆز خەلقى ئىسرائىل ئۈچۈن ئۇنىڭ پادىشاھلىقىنى گۈللەندۈرگەنىدى.
\b
\s1 داۋۇتنىڭ يېرۇسالېمدا كۆرگەن ئوغۇللىرى
\m 
\v 3 داۋۇت يېرۇسالېمدا يەنە بىرمۇنچە خوتۇن ئالدى ھەمدە يەنە ئوغۇل-قىزلارنى كۆردى.
\v 4 تۆۋەندىكىلەر ئۇنىڭ يېرۇسالېمدا كۆرگەن پەرزەنتلىرىنىڭ ئىسىملىرى: شاممۇيا، شوباب، ناتان، سۇلايمان،
\v 5 ئىبھار، ئەلىشۇيا، ئەلپەلەت،
\v 6 نوگاھ، نەفەگ، يافىيا،
\v 7 ئەلىشاما، بەئەلىيادا ۋە ئەلىفەلەت. \f ◼ \fr 14:7 \ft \bd «بەئەلىيادا»\bd* ــ ياكى «ئەلىيا». «2سام.» 16:5نى كۆرۈڭ.\f*
\b
\s1 داۋۇتنىڭ فىلىستىيلەرنى ئىككى قېتىم يەڭگەنلىكى
\m 
\v 8 داۋۇتنىڭ مەسىھ قىلىنىپ پۈتكۈل ئىسرائىلنىڭ ئۈستىگە پادىشاھ قىلىنغانلىقىنى ئاڭلىغان فىلىستىيلەرنىڭ ھەممىسى داۋۇت بىلەن قارشىلىشىش پۇرسىتىنى ئىزلەپ كەلدى؛ داۋۇت بۇنى ئاڭلاپ ئۇلارغا قارشى جەڭگە ئاتلاندى.
\v 9 فىلىستىيلەر «رەفايىم جىلغىسى»غا بۇلاڭ-تالاڭ قىلغىلى كىردى.
\v 10 داۋۇت خۇدادىن: «مەن فىلىستىيلەرگە قارشى جەڭگە چىقسام بولامدۇ؟ ئۇلارنى مېنىڭ قولۇمغا تاپشۇرامسەن؟» دەپ سورىۋىدى، پەرۋەردىگار ئۇنىڭغا: «جەڭگە چىق، مەن ئۇلارنى سۆزسىز قولۇڭغا تاپشۇرىمەن» دېدى.
\v 11 فىلىستىيلەر بائال-پەرازىمغا ھۇجۇم قىلغىلى كەلگەندە، داۋۇت ئۇلارنى شۇ يەردە مەغلۇپ قىلدى ۋە: «خۇدا مېنىڭ قولۇم ئارقىلىق دۈشمەنلىرىم ئۈستىگە خۇددى كەلكۈن يارنى ئېلىپ كەتكەندەك بۆسۈپ كىردى» دېدى. شۇڭا ئۇ يەر «بائال-پەرازىم» دەپ ئاتالغان. \f ◼ \fr 14:11 \ft \bd «بائال-پەرازىم»\bd* ــ «ئىگەم بۆسۈپ كىردى» دېگەن مەنىدە.\f*
\v 12 فىلىستىيلەر ئۆزلىرىنىڭ بۇتلىرىنى شۇ يەرگە تاشلاپ قاچقانلىقتىن، داۋۇت ئادەملىرىگە ئۇلارنى كۆيدۈرۈۋېتىشنى تاپىلىدى.
\m 
\v 13 فىلىستىيلەر يەنە ھېلىقى جىلغىغا بۇلاڭ-تالاڭ قىلغىلى كىرىۋىدى،
\v 14 داۋۇت يەنە خۇدادىن يول سورىدى. خۇدا ئۇنىڭغا: «ئۇلارنى ئارقىسىدىن قوغلىماي، ئەگىپ ئۆتۈپ، ئۇلارغا ئۈجمىلىكنىڭ ئۇدۇلىدىن ھۇجۇم قىلغىن.
\v 15 سەن ئۈجمە دەرەخلىرىنىڭ ئۈستىدىن ئاياغ تىۋىشىنى ئاڭلىشىڭ بىلەنلا جەڭگە ئاتلان؛ چۈنكى ئۇ چاغدا خۇدا سېنىڭ ئالدىڭدا فىلىستىيلەرنىڭ قوشۇنىغا ھۇجۇمغا چىققان بولىدۇ» دېدى. \f ◼ \fr 14:15 \ft \bd «ئۈجمە دەرەخلىرى»\bd* ــ بۇ بىزنىڭ قىياسىمىز. ئىبرانىي تىلىدا «يىغلىغۇچى دەرەخلەر». زادى قايسى دەرەخ ئىكەنلىكى بىزگە نامەلۇم. باشقا بىر قىياس «خىنە دەرەخلىرى».\f*
\v 16 شۇنىڭ بىلەن داۋۇت خۇدانىڭ دېگىنى بويىچە ئىش تۇتۇپ، فىلىستىيلەرنىڭ قوشۇنىغا گىبېئوندىن گەزەرگىچە قوغلاپ زەربە بەردى.
\v 17 شۇ سەۋەبتىن داۋۇتنىڭ شۆھرىتى بارلىق يۇرت-زېمىنلارغا پۇر كەتتى، پەرۋەردىگار ئۇنىڭ قورقۇنچىنى بارلىق ئەللەرنىڭ ئۈستىگە سالدى.
\b
\b
\c 15
\s1 ئەھدە ساندۇقىنى يۆتكەشنىڭ تەييارلىقى
\m 
\v 1 داۋۇت داۋۇت شەھىرىدە ئۆزىگە ئۆي-ئوردىلار سالدۇردى، ھەم خۇدانىڭ ئەھدە ساندۇقىغا جاي ھازىرلىدى ۋە ئۇنىڭغا چېدىر تىكتۈردى.
\v 2 ئۇ چاغدا داۋۇت: «خۇدانىڭ ئەھدە ساندۇقىنى لاۋىيلاردىن بۆلەك كىشىلەرنىڭ كۆتۈرۈشىگە بولمايدۇ، چۈنكى پەرۋەردىگار ئۇنى كۆتۈرۈشكە ۋە مەڭگۈ ئۆزىنىڭ خىزمىتىدە بولۇشقا شۇلارنى تاللىغانىدى» دېدى.
\v 3 ئاندىن داۋۇت پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى ھازىرلاپ قويغان يەرگە يۆتكەش ئۈچۈن پۈتكۈل ئىسرائىللارنى يېرۇسالېمغا يىغدى.
\v 4 داۋۇت يەنە ھارۇننىڭ ئەۋلادلىرىنى ۋە لاۋىيلارنى يىغدى:
\v 5 كوھاتنىڭ ئەۋلادلىرى جەمەت بېشى بولغان ئۇرىيەل ۋە ئۇنىڭ قېرىنداشلىرى بىر يۈز يىگىرمە كىشى؛
\v 6 مەرارى ئەۋلادلىرىدىن جەمەت بېشى بولغان ئاسايا ۋە ئۇنىڭ قېرىنداشلىرىدىن ئىككى يۈز يىگىرمە كىشى؛
\v 7 گەرشومنىڭ ئەۋلادلىرىدىن جەمەت بېشى بولغان يوئېل ۋە ئۇنىڭ قېرىنداشلىرى بىر يۈز ئوتتۇز كىشى؛
\v 8 ئەلىزافاننىڭ ئەۋلادلىرىدىن جەمەت بېشى بولغان شېمايا ۋە ئۇنىڭ قېرىنداشلىرى ئىككى يۈز كىشى؛
\v 9 ھېبروننىڭ ئەۋلادلىرىدىن جەمەت بېشى بولغان ئەلىيەل ۋە ئۇنىڭ قېرىنداشلىرى سەكسەن كىشى؛
\v 10 ئۇززىيەلنىڭ ئەۋلادلىرىدىن جەمەت بېشى بولغان ئاممىناداب ۋە ئۇنىڭ قېرىنداشلىرى بىر يۈز ئون ئىككى كىشى ئىدى.
\m 
\v 11 داۋۇت كاھىنلاردىن زادوك بىلەن ئابىياتارنى، شۇنىڭدەك لاۋىلىيلاردىن ئۇرىيەل، ئاسايا، يوئېل، شېمايا، ئەلىيەل ۋە ئاممىنادابنى چاقىرتىپ كېلىپ ئۇلارغا:
\v 12 «سىلەر لاۋىي جەمەتىنىڭ باشلىرىسىلەر؛ ئۆزۈڭلارنى ۋە سىلەرنىڭ قېرىنداشلىرىڭلارنى ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى مەن تەييارلاپ قويغان يەرگە كۆتۈرۈپ كېلىش ئۈچۈن پاك قىلىڭلار. \f ◼ \fr 15:12 \ft \bd «ئۆزۈڭلارنى... پاك قىلىڭلار»\bd* ــ ئىبرانىي تىلىدا «ئۆزۈڭلارنى... پاك-مۇقەددەس قىلىڭلار». بۇ «پاك-مۇقەددەسلىك» رەسمىي ئىش بولۇپ، «مىس.» 29-بابتا ۋە «لاۋ.» 7-بابتا كۆرسىتىلگەندەك: (1) ئۆلۈك نەرسىلەرگە تەگمەسلىك؛ (2) تەنلىرىنى يۇيۇش؛ (3) پاكىز كىيىم-كېچەكنى كىيىش؛ (4) ئۆزىنىڭ گۇناھىنى تىلەش ئۈچۈن «گۇناھ قۇربانلىقى سۇنۇش دېگەن تۆت ئىشنى ئۆز ئىچىگە ئېلىشى مۇمكىن ئىدى.\f*
\v 13 چۈنكى ئىلگىرى سىلەر شۇنداق قىلماي، بەلگىلەنگەن تەرتىپ بويىچە ئۇنىڭدىن يول سورىمىغىنىمىزدىن خۇدايىمىز پەرۋەردىگار بىزگە زەربە بەرگەن» دېدى. \f ◼ \fr 15:13 \ft \bd «زەربە بەرگەن»\bd* ــ ئىبرانىي تىلىدا «بۆسۈپ باسقان».\f*
\v 14 شۇنىڭ بىلەن كاھىنلار بىلەن لاۋىيلار ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى كۆتۈرۈپ مېڭىش ئۈچۈن ئۆزلىرىنى پاك قىلدى.
\v 15 لاۋىيلار ئەمدى مۇسانىڭ پەرۋەردىگارنىڭ سۆز-كالامى بىلەن تاپىلىغىنى بويىچە، خۇدانىڭ ئەھدە ساندۇقىنى بالداق بىلەن مۈرىسىگە ئېلىپ كۆتۈردى.
\b
\s1 نەغمە-ناۋاچىلار ھۆرمەت ئەترىتى
\m 
\v 16 داۋۇت يەنە لاۋىيلارنىڭ يولباشچىلىرىغا ئۆزلىرىنىڭ قېرىنداشلىرىدىن نەغمىچىلەرنى تەيىنلەشنى بۇيرۇدى؛ ئۇلار جۈملىدىن تەمبۇر، چىلتار، جاڭلار قاتارلىق ھەرخىل سازلارنى چېلىپ ئاۋازىنى يۇقىرى كۆتۈرۈپ شاد-خۇراملىق ئىچىدە كۈي ئېيتىشقا تەيىنلەندى.
\v 17 شۇڭلاشقا، لاۋىيلار يوئېلنىڭ ئوغلى ھېماننى ۋە ئۇنىڭ جەمەتىدىكى بەرەكىيانىڭ ئوغلى ئاسافنى ھەم ئۇلارنىڭ قېرىنداشلىرىدىن بولغان مەرارىلاردىن كۇشاياھنىڭ ئوغلى ئېتاننى بەلگىلىدى.
\v 18 ئۇلار بىلەن بىرلىكتە يەنە قېرىنداشلىرىدىن زەكەرىيا، بىن، يائازىيەل، شېمىراموت، يەھىيەل، ئۇننى، ئېلىئاب، بىناياھ، مائاسېياھ، ماتتىتىياھ، ئەلىفەلەھ، مېكنىيا ھەم دەرۋازىۋەن ئوبەد-ئېدوم بىلەن يەئىيەلنى ئىككىنچى دەرىجىلىك ئەترەت قىلىپ تەشكىللىدى.
\v 19 نەغمىچى ھېمان، ئاساف ۋە ئېتانلار مىس جڭلار چېلىپ، ياڭراق ئاۋاز چىقىراتتى؛
\v 20 زەكەرىيا، يائازىيەل، شېمىراموت، يەھىيەل، ئۇننى، ئېلىئاب، مائاسېياھ ۋە بىنايالار تەمبۇر چېلىپ «ئالاموت ئۇسلۇبى»دا تەڭكەش قىلاتتى؛ \f ◼ \fr 15:20 \ft \bd «ئالاموت ئۇسلۇبى»\bd* ــ بۇنىڭ مەنىسى بىزگە ئېنىق ئەمەس؛ بەلكىم «(ئايالچە) يۇقىرى ئاۋاز بىلەن» دېگەننى بىلدۈرۈشى مۇمكىن.\f*
\v 21 ماتتىتىياھ، ئەلىفەلەھ، مېكنىيا، ئوبەد-ئېدوم، يەئىيەل ۋە ئازازىيالار چىلتار چېلىپ باشلامچىلىق قىلىپ، «شەمىنىت ئۇسلۇبى»دا تەڭكەش بولاتتى. \f ◼ \fr 15:21 \ft \bd «شەمىنىت ئۇسلۇبى»\bd* ــ بۇنىڭ مەنىسى بىزگە ئېنىق ئەمەس؛ بەلكىم «ئەرەنچە تۆۋەن ئاۋاز بىلەن» دېگەننى بىلدۈرۈشى مۇمكىن.\f*
\v 22 لاۋىيلارنىڭ يولباشچىسى كەنانىيا مۇزىكىغا ناھايىتى پىششىق بولغاچقا، مەخسۇس نەغمە-ناۋاچىلىققا مەسئۇل بولۇپ مۇزىكا ئۆگىتەتتى.
\v 23 بەرەكىيا بىلەن ئەلكاناھ ئەھدە ساندۇقىغا مەسئۇل ئىشىكباقارلار ئىدى.
\v 24 شەبانىيا، يەھوشافات، نەتانەل، ئاماساي، زەكەرىيا، بىنايا ۋە ئەلىئېزەر قاتارلىق كاھىنلار خۇدانىڭ ئەھدە ساندۇقى ئالدىدا كاناي چالاتتى؛ ئوبەد-ئېدوم بىلەن يەھىياھمۇ ئەھدە ساندۇقىغا مەسئۇل ئىشىكباقار قىلىنىپ قويۇلغانىدى. \f ◼ \fr 15:24 \ft \bd «يەھىياھ»\bd* ــ «يەھىياھ» ۋە «جىيەل» دېگەن بىر ئىسىمدۇر.\f*
\b
\s1 ئەھدە ساندۇقى «داۋۇت شەھىرى»گە يۆتكەپ كېلىنىدۇ
\r 1سام. 6‏:16-23
\m 
\v 25 شۇنىڭ بىلەن داۋۇت ئىسرائىل ئاقساقاللىرى ۋە مىڭبېشى قاتارلىقلار بىلەن بىرگە ئوبەد-ئېدومنىڭ ئۆيىدىن خۇشاللىققا چۆمگەن ھالدا پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى كۆتۈرۈپ چىققىلى باردى.
\v 26 ۋە شۇنداق بولدىكى، \add داۋۇتلار\add* خۇدا پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى كۆتۈرۈپ ماڭغان لاۋىيلارغا ياردەم بەرگەنلىكىنى كۆرۈپ، يەتتە بۇقا ۋە يەتتە قوچقار قۇربانلىق قىلدى.
\v 27 داۋۇت ۋە شۇنداقلا ئەھدە ساندۇقىنى كۆتۈرىدىغان لاۋىيلار ھەمدە نەغمىچىلەر ھەم نەغمە-ناۋا بېشى بولغان كەنانىيالارنىڭ ھەممىسى كاناپ لىباس كىيىشكەنىدى؛ داۋۇت ئۇنىڭ ئۈستىگە يەنە كاناپ ئەفود كىيگەنىدى. \f ◼ \fr 15:27 \ft \bd «ئەفود»\bd* ــ ئادەتتە كاھىنلار ئالاھىدە كىيىدىغان پىنجەككە ئوخشاش بىر كىيىم ئىدى («مىس.» 28-بابنى كۆرۈڭ. ئۇنداق كىيىم كىيىۋېلىش ئۆزىنى خۇداغا ئالايىتەن بېغىشلاشنى بىلدۈرەتتى.\f*
\v 28 پۈتكۈل ئىسرائىل خەلقى ئەمدى شۇ تەرىقىدە تەنتەنە قىلىپ، بۇرغا، كاناي، جاڭ-جاڭ، تەمبۇر، چىلتار قاتارلىق تۈرلۈك سازلار بىلەن يۇقىرى ئاۋازدا مۇزىكا چېلىپ، پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى كۆتۈرۈپ كېلىشتى.
\v 29 پەرۋەردىگارنىڭ ئەھدە ساندۇقى داۋۇت شەھىرىگە يېتىپ كەلگەندە سائۇلنىڭ قىزى مىقال پەنجىردىن تۆۋەنگە قاراپ تۇراتتى؛ ئۇ داۋۇتنىڭ سەكرەپ ئويناپ-چېلىپ تەنتەنە قىلىۋاتقىنىنى كۆرۈپ ئىچىدە ئۇنى زاڭلىق قىلدى.
\b
\b
\c 16
\s1 مەدھىيە ئوقۇش، بەخت تىلەش
\m 
\v 1 ئۇلار خۇدانىڭ ئەھدە ساندۇقىنى كۆتۈرۈپ كىرىپ داۋۇت ئۇنىڭغا ھازىرلاپ قويغان چېدىرنىڭ ئوتتۇرىسىغا قويۇپ، ئاندىن خۇدانىڭ ئالدىدا كۆيدۈرمە قۇربانلىق بىلەن ئىناقلىق قۇربانلىقلىرى سۇندى.
\v 2 داۋۇت كۆيدۈرمە قۇربانلىقى بىلەن ئىناقلىق قۇربانلىقلىرى سۇنۇپ بولغاندىن كېيىن پەرۋەردىگارنىڭ نامىدا خەلققە بەخت تىلىدى.
\v 3 ئۇ يەنە ئەر-ئايال دېمەي ئىسرائىللارنىڭ ھەر بىرىگە بىردىن نان، بىردىن خورما پوشكىلى، بىردىن ئۈزۈم پوشكىلى ئۈلەشتۈرۈپ بەردى. \f ◼ \fr 16:3 \ft \bd «بىردىن خورما پوشكىلى»\bd* ــ ياكى «بىر پارچىدىن گۆش».\f*
\b
\s1 لاۋىيلارنىڭ ئەھدە ساندۇقى ئالدىدىكى ۋەزىپىلىرى
\m 
\v 4 داۋۇت بىر قىسىم لاۋىيلارغا پەرۋەردىگارنىڭ ئەھدە ساندۇقى ئالدىدا خىزمەتتە بولۇش، يەنى دۇئا-تىلاۋەت ئوقۇش، ئىسرائىلنىڭ خۇداسى پەرۋەردىگارغا تەشەككۈر-رەھمەت ئېيتىش ۋە كۈي-مۇناجات ئوقۇشنى بۇيرۇدى. \f ◼ \fr 16:4 \ft \bd «دۇئا-تىلاۋەت ئوقۇش»\bd* ــ ياكى «ئەسلەش»، «تەنتەنە قىلىش».\f*
\v 5 ئۇلارنىڭ يولباشچىسى بولسا ئاساف، ئاندىن زەكەرىيا ئىدى؛ باشقىلىرى بولسا يەئىيەل، شېمىراموت، يەھىيەل، ماتتىتىياھ، ئېلىئاب، بىنايا، ئوبەد-ئېدوم ۋە يەئىيەللەر ئىدى. ئۇلار تەمبۇر-چىلتار چېلىشقا قويۇلدى؛ ئاساف بولسا جاڭلارنى چالاتتى.
\v 6 بىنايا بىلەن ياھازىيەلدىن ئىبارەت ئىككى كاھىن خۇدانىڭ ئەھدە ساندۇقى ئالدىدا ھەردائىم كاناي چېلىشقا قويۇلدى.
\b
\s1 داۋۇتنىڭ پەرۋەردىگارغا ھەمدۇسانا ئوقۇغان كۈيى
\m 
\v 7 شۇ كۈنى داۋۇت ئاساف ۋە قېرىنداشلىرىنى پەرۋەردىگارغا تەشەككۈر-رەھمەت ئېيتىشقا بەلگىلەپ ئۇلارغا بىرىنچىدىن مۇنۇ كۈينى تاپشۇردى: ــ
\b
\m 
\v 8 «پەرۋەردىگارغا تەشەككۈر قىلىڭلار،
\m ئۇنىڭ نامىنى چاقىرىپ نىدا قىلىڭلار،
\m ئۇنىڭ قىلغانلىرىنى ئەللەر ئارىسىدا ئايان قىلىڭلار! \x ◘ \xo 16:8 \xt زەب. 105‏:1-15؛ 96‏:1-13؛ 106‏:1، 47، 48\x*
\m 
\v 9 ئۇنىڭغا ناخشىلار ئېيتىپ، ئۇنى كۈيلەڭلار،
\m ئۇنىڭ پۈتكۈل كارامەت مۆجىزىلىرى ئۈستىدە سېغىنىپ ئويلىنىڭلار.
\m 
\v 10 مۇقەددەس نامىدىن پەخىرلىنىپ داڭلاڭلار،
\m پەرۋەردىگارنى ئىزدىگۈچىلەرنىڭ كۆڭلى شادلانسۇن!
\m 
\v 11 پەرۋەردىگارنى ۋە ئۇنىڭ قۇدرىتىنى ئىزدەڭلار،
\m ئۇنىڭ يۈز-ھۇزۇرىنى توختىماي ئىزدەڭلار.
\m 
\v 12 ئۇنىڭ ياراتقان مۆجىزىلىرىنى،
\m كارامەت ئالامەتلىرىنى ھەم ئاغزىدىن چىققان ھۆكۈملىرىنى ئەستە تۇتۇڭلار،
\m 
\v 13 ئى ئۇنىڭ قۇلى ئىسرائىلنىڭ نەسلى،
\m ئۆزى تاللىغانلىرى، ياقۇپنىڭ ئوغۇللىرى!
\m 
\v 14 ئۇ، پەرۋەردىگار ــ خۇدايىمىز،
\m ئۇنىڭ ھۆكۈملىرى پۈتكۈل يەر يۈزىدىدۇر.
\m 
\v 15 ئۇ ئۆزى تۈزگەن ئەھدىنى ئەبەدىي يادىڭلاردا تۇتۇڭلار ــ
\m ــ بۇ ئۇنىڭ مىڭ ئەۋلادقىچە ۋەدىلەشكەن سۆزىدۇر ــ
\m 
\v 16 ئىبراھىم بىلەن تۈزگەن ئەھدىسى،
\m يەنى ئىسھاققا ئىچكەن قەسىمىدۇر.
\m 
\v 17 ئۇ بۇنى ياقۇپقىمۇ نىزام دەپ جەزملەشتۈردى،
\m ئىسرائىلغا ئەبەدىي ئەھدە قىلىپ بېرىپ: ــ \f ◼ \fr 16:17 \ft \bd «ئۇ بۇنى ياقۇپقىمۇ نىزام دەپ جەزملەشتۈردى»\bd* ــ مۇشۇ يەردە «ياقۇپ» ياقۇپنىڭ ئۆزىنى (ئىسرائىل خەلقى ئەمەس) كۆرسىتىدۇ.\f*
\m 
\v 18 «ساڭا قانائان زېمىنىنى بېرىمەن،
\m ئۇنى مىراسىڭ بولغان نېسىۋەڭ قىلىمەن» ــ دېدى.
\m 
\v 19 ئۇ چاغدا سىلەر ئاجىز ئىدىڭلار، ئادىمىڭلار ئاز ھەم ئۇ يەردە مۇساپىر ئىدىڭلار؛
\m 
\v 20 بۇ ئەلدىن ئۇ ئەلگە، بىر قەبىلىدىن يەنە بىر قەبىلىگە كۆچۈپ يۈرگەن.
\m 
\v 21 پەرۋەردىگار ھەرقانداق ئادەمنىڭ ئۇلارنى بوزەك قىلىشىغا يول قويمىدى،
\m ئۇلارنى دەپ پادىشاھلارغىمۇ تەنبىھ بېرىپ: ــ
\m 
\v 22 «مەن مەسىھ قىلغانلارغا تەگمە،
\m پەيغەمبەرلىرىمگە يامان ئىش قىلما!» ــ دېدى.
\m 
\v 23 پۈتۈن جاھان، پەرۋەردىگارنى كۈيلەڭلار،
\m نىجاتىنى ھەر كۈنى ئېلان قىلىڭلار!
\m 
\v 24 ئۇنىڭ جۇلاسىنى ئەللەردە بايان قىلىڭلار،
\m ئۇنىڭ مۆجىزىلىرىنى بارلىق خەلقلەر ئارىسىدا جاكارلاڭلار.
\m 
\v 25 چۈنكى پەرۋەردىگارىمىز ئۇلۇغدۇر،
\m زور ھەمدۇساناغا لايىقتۇر؛
\m ئۇ بارلىق ئىلاھلاردىن ئۈستۈن، ئۇنىڭدىن قورقۇش كېرەكتۇر؛ \f ◼ \fr 16:25 \ft \bd «ئۇنىڭدىن قورقۇش كېرەكتۇر»\bd* ــ ياكى «ئۇ قورقۇنچلۇقتۇر».\f*
\m 
\v 26 چۈنكى بارلىق ئەللەرنىڭ ئىلاھلىرى ــ بۇتلار خالاس،
\m بىراق پەرۋەردىگار ئاسمان-پەلەكنى ياراتقاندۇر.
\m 
\v 27 شانۇ-شەۋكەت ۋە ھەيۋەت ئۇنىڭ ئالدىدا،
\m قۇدرەت ۋە خۇشلۇق ئۇنىڭ جايىدىدۇر.
\m 
\v 28 پەرۋەردىگارغا تەئەللۇقىنى بەرگەيسىلەر، ئى ئەل-قەبىلىلەر،
\m پەرۋەردىگارغا شان-شەرەپ ۋە قۇدرەتنى بەرگەيسىلەر! \f ◼ \fr 16:28 \ft \bd «پەرۋەردىگارغا... قۇدرەتنى بەرگەيسىلەر»\bd* ــ مۇشۇ سۆزلەر بەلكىم شۇنى بىلدۈرىدۇكى، خۇداغا شان-شەرەپ كەلتۈرسەك، مۇشۇ قىلغىنىمىز ئۇنىڭغا بىز ئارقىلىق ئۆزىنىڭ كۈچ-قۇدرىتىنى كۆرسىتىش ئىمكانىيىتىنى يارىتىدۇ.\f*
\m 
\v 29 پەرۋەردىگارنىڭ نامىغا لايىق بولغان شان-شۆھرەتنى ئۇنىڭغا بەرگەيسىلەر؛
\m سوۋغا-سالام ئېلىپ ئۇنىڭ ئالدىغا كىرىڭلار،
\m پەرۋەردىگارغا پاك-مۇقەددەسلىكنىڭ گۈزەللىكىدە سەجدە قىلىڭلار؛ \f ◼ \fr 16:29 \ft \bd «پەرۋەردىگارغا پاك-مۇقەددەسلىكنىڭ گۈزەللىكىدە سەجدە قىلىڭلار»\bd* ــ ياكى «پەرۋەردىگارغا پاك-مۇقەددەس ئېگىنلەر بىلەن سەجدە قىلىڭلار».\f*
\m 
\v 30 پۈتكۈل يەر-يۈزى، ئۇنىڭ ئالدىدا تىترەڭلار!
\m دۇنيا مەزمۇت قىلىنغان، ئۇ تەۋرەنمەس ئەسلا.
\m 
\v 31 ئاسمانلار شادلانسۇن، ۋە يەر-جاھان خۇش بولسۇن،
\m ئەللەر ئارىسىدا ئېلان قىلىنسۇن: ــ
\m «پەرۋەردىگار ھۆكۈم سۈرىدۇ!».
\m 
\v 32 دېڭىز-ئوكيان ۋە ئۇنىڭغا تولغان ھەممە چۇقان سېلىپ جۇش ئۇرسۇن!
\m دالىلار ھەم ئۇلاردىكى ھەممە يايرىسۇن!
\m 
\v 33 ئۇ چاغدا ئورماندىكى پۈتكۈل دەرەخلەر پەرۋەردىگار ئالدىدا ياڭرىتىپ ناخشا ئېيتىدۇ؛
\m چۈنكى مانا، ئۇ پۈتۈن جاھاننى سوراق قىلىشقا كېلىدۇ!
\m 
\v 34 پەرۋەردىگارغا تەشەككۈر ئېيتىڭلار!
\m چۈنكى ئۇ مېھرىباندۇر،
\m ئەبەدىيدۇر ئۇنىڭ مېھىر-مۇھەببىتى.
\m 
\v 35 ۋە: بىزنى قۇتقۇزغىن، ئى نىجاتىمىز بولغان خۇدا!
\m بىزنى \add يېنىڭغا\add* يىغىۋالغايسەن،
\m مۇقەددەس نامىڭغا تەشەككۈر قىلىشقا،
\m يايراپ سېنى مەدھىيىلەشكە،
\m بىزنى ئەللەردىن قۇتقۇزۇپ چىققايسەن! ــ دەڭلار!
\m 
\v 36 ئىسرائىلنىڭ خۇداسى بولغان پەرۋەردىگارغا،
\m ئەزەلدىن تا ئەبەدگىچە تەشەككۈر-مەدھىيە قايتۇرۇلسۇن!
\m پۈتكۈل خەلق «ئامىن!» دېدى ھەمدە پەرۋەردىگارغا ھەمدۇسانا ئوقۇشتى.
\b
\s1 ئىبادەت چېدىرىدىكى باشقا ۋەزىپىلەر
\m 
\v 37 \add داۋۇت\add* شۇ يەردە، يەنى پەرۋەردىگارنىڭ ئەھدە ساندۇقى ئالدىدا ھەر كۈندىكى ۋەزىپىگە مۇۋاپىق، ئەھدە ساندۇقى ئالدىدىكى خىزمەتتە داۋاملىق بولۇشقا ئاساف بىلەن ئۇنىڭ قېرىنداشلىرىنى قالدۇرۇپ قويدى؛
\v 38 ئۇلارنىڭ ئىچىدە ئوبەد-ئېدوم بىلەن ئۇنىڭ قېرىنداشلىرىدىن ئاتمىش سەككىز كىشى بار ئىدى؛ شۇنىڭدەك يەدۇتۇننىڭ ئوغلى ئوبەد-ئېدوم بىلەن خوساھ دەرۋازىۋەنلىككە قويۇلدى.
\v 39 كاھىن زادوك بىلەن ئۇنىڭ كاھىن قېرىنداشلىرى گىبېئون ئېگىزلىكىدىكى پەرۋەردىگارنىڭ چېدىرى ئالدىدا،
\v 40 پەرۋەردىگارنىڭ ئىسرائىلغا تاپىلىغان قانۇن-ئەھكاملىرىدا بارلىق يېزىلغىنى بويىچە، ھەركۈنى ئەتىسى-ئاخشىمى كۆيدۈرمە قۇربانلىق قۇربانگاھى ئۈستىدە پەرۋەردىگارغا ئاتاپ كۆيدۈرمە قۇربانلىقلارنى سۇنۇشقا قويۇلدى.
\v 41 ئۇلار بىلەن بىللە بولغانلار، يەنى ھېمان، يەدۇتۇن ۋە قالغان تاللانغانلار، شۇنداقلا بارلىق ئىسمى تىزىلغانلار پەرۋەردىگارغا تەشەككۈر-رەھمەت ئېيتىشقا قويۇلدى (چۈنكى ئۇنىڭ ئۆزگەرمەس مۇھەببىتى ئەبەدگىچىدۇر!).
\v 42 ھېمان ۋە يەدۇتۇن بولسا نەغمىچىلىككە، جۈملىدىن كاناي، جاڭ-جاڭ ۋە بارلىق مەدھىيە سازلىرىنى چېلىشقا مەسئۇل قىلىندى. يەدۇتۇننىڭ ئوغۇللىرى دەرۋازىغا قاراشقا قويۇلدى.
\v 43 بۇ ئىشلاردىن كېيىن بارلىق خەلق ئۆز ئۆيلىرىگە قايتىشتى؛ داۋۇتمۇ ئۆز ئۆيىدىكىلەرگە بەخت تىلەشكە قايتتى.
\b
\b
\c 17
\s1 داۋۇتنىڭ پەرۋەردىگارغا ئۆي سېلىش نىيىتى
\r 2سام. 7‏:1-15
\m 
\v 1 داۋۇت ئۆز ئۆيىدە تۇرۇۋاتقان چېغىدا، ناتان پەيغەمبەرگە: «قارا، مەن كېدىر ياغىچىدىن ياسالغان ئۆيدە تۇرۇۋاتىمەن، پەرۋەردىگارنىڭ ئەھدە ساندۇقى بولسا چېدىر پەردىلىرى ئاستىدا تۇرۇۋاتىدۇ» دېدى.
\v 2 ناتان داۋۇتقا: «كۆڭلۈڭدە پۈككەنلىرىڭگە ئەمەل قىلغىن؛ چۈنكى خۇدا سەن بىلەن بىللىدۇر» ــ دېدى.
\m 
\v 3 شۇ كۈنى كېچىدە خۇدانىڭ سۆزى ناتانغا كېلىپ مۇنداق دېگەندە: ــ
\v 4 «سەن بېرىپ قۇلۇم داۋۇتقا مۇنداق دېگىن: ــ پەرۋەردىگار مۇنداق دەيدۇ: سەن مەن ئۈچۈن تۇرالغۇ ئۆي سالساڭ بولمايدۇ.
\v 5 چۈنكى مەن ئىسرائىللارنى باشلاپ چىققان كۈندىن تارتىپ بۈگۈنگە قەدەر بىر ئۆيدە تۇرۇپ باقمىغانمەن، پەقەت بۇ چېدىردىن ئۇ چېدىرغا، بىر چېدىرگاھدىن باشقا بىرىگە يۆتكىلىپ يۈردۈم، خالاس.
\v 6 مەن ئىسرائىل خەلقى بىلەن بىللە مەيلى قەيەرگە بارماي، ھېچقاچان ئىسرائىلنىڭ بىرەر ھاكىمىغا، يەنى مېنىڭ خەلقىمنى بېقىشنى تاپىلىغان بىرەرسىگە: نېمىشقا سىلەر ماڭا كېدىر ياغىچىدىن ئۆي سېلىپ بەرمەيسىلەر؟ ــ دېدىممۇ؟
\m 
\v 7 ئەمدى سەن قۇلۇم داۋۇتقا مۇنداق دېگىن: ــ ساماۋى قوشۇنلارنىڭ سەردارى بولغان پەرۋەردىگار ئېيتىدۇكى، مەن سېنى ئەمدى يايلاقلاردىن، قويلارنىڭ ئارقىسىدىن ئېلىپ، خەلقىم ئىسرائىلنىڭ ئۈستىگە ئەمىر بولۇش ئۈچۈن چاقىرتىپ چىقتىم.
\v 8 مەيلى قەيەرگە بارمىغىن، مەن ھامان سېنىڭ بىلەن بىللە بولدۇم ۋە سېنىڭ ئالدىڭدىن بارلىق دۈشمەنلىرىڭنى يوقىتىپ كەلدىم؛ يەر يۈزىدىكى ئۇلۇغلار نام-شۆھرەتكە ئىگە بولغاندەك سېنى نام-شۆھرەتكە سازاۋەر قىلدىم.
\v 9‏-10 مەن خەلقىم بولغان ئىسرائىلغا بىر جاينى بېكىتىپ، ئۇلارنى شۇ يەردە تىكىپ ئۆستۈرىمەن؛ شۇنىڭ بىلەن ئۇلار ئۆز زېمىنىدا تۇرىدىغان، پاراكەندىچىلىككە ئۇچرىمايدىغان بولىدۇ. رەزىللەر دەسلەپتىدىكىدەك ۋە مەن خەلقىم ئىسرائىل ئۈستىگە ھۆكۈمرانلىق قىلىشقا ھاكىملارنى تەيىنلىگەن كۈنلەردىكىدەك، ئۇلارغا قايتىدىن زۇلۇم سالمايدۇ. مەن بارلىق دۈشمەنلىرىڭنى ساڭا بېقىندۈردىمەن. ۋە مەنكى پەرۋەردىگار ساڭا شۇنى ئېيتىپ قويايكى، مەن سېنىڭ ئۈچۈن بىر ئۆينى ياساپ بېرىمەن!
\v 11 سېنىڭ كۈنلىرىڭ توشۇپ، ئاتا-بوۋىلىرىڭنىڭ يېنىغا قايتقان ۋاقتىڭدا سېنىڭ نەسلىڭدىن، يەنى ئوغۇللىرىڭدىن بىرىنى سېنىڭ ئورنۇڭنى باسىدىغان قىلىمەن؛ مەن ئۇنىڭ پادىشاھلىقىنى مۇستەھكەم قىلىمەن.
\v 12 ئۇ ماڭا بىر ئۆي ياسايدۇ، مەن ئۇنىڭ پادىشاھلىق تەختىنى مەڭگۈ مۇستەھكەم قىلىمەن.
\v 13 مەن ئۇنىڭغا ئاتا بولىمەن، ئۇ ماڭا ئوغۇل بولىدۇ؛ مېھىر-شەپقىتىمنى سېنىڭدىن ئاۋۋال ئۆتكەن \add ئىدارە قىلغۇچىدىن\add* جۇدا قىلغىنىمدەك ئۇنىڭدىن ھەرگىز جۇدا قىلمايمەن؛
\v 14 ئۇنى مېنىڭ ئۆيۈمدە ۋە مېنىڭ پادىشاھلىقىمدا مەڭگۈ تۇرغۇزىمەن؛ ئۇنىڭ تەختى مەڭگۈ مەزمۇت بولۇپ تۇرغۇزۇلىدۇ».
\v 15 ناتان بۇ بارلىق سۆزلەر ۋە بارلىق ۋەھىينى ھېچنېمە قالدۇرماي، داۋۇتقا ئېيتىپ بەردى.
\b
\s1 داۋۇتنىڭ دۇئاسى ۋە ھەمدۇساناسى
\r 2سام. 7‏:18-29
\m 
\v 16 شۇنىڭ بىلەن داۋۇت كىرىپ پەرۋەردىگارنىڭ ئالدىدا ئولتۇرۇپ مۇنداق دېدى: «ئى خۇدا پەرۋەردىگار، مەن زادى كىم ئىدىم، مېنىڭ ئۆيۈم نېمە ئىدى، سەن مېنى مۇشۇ دەرىجىگە كۆتۇرگۈدەك؟
\v 17 لېكىن ئى خۇدا پەرۋەردىگار، \add بۇ مەرتىۋىگە كۆتۈرگىنىڭ\add* سېنىڭ نەزىرىڭدە كىچىككىنە بىر ئىش ھېسابلاندى؛ چۈنكى سەن مەن قۇلۇڭنىڭ ئۆيىنىڭ يىراق كەلگۈسى توغرۇلۇق سۆزلىدىڭ ۋە مېنى ئۇلۇغ مەرتىۋىلىك زات دەپ قارىدىڭ، ئى خۇدا پەرۋەردىگار! \f ◼ \fr 17:17 \ft \bd «بۇ مەرتىۋىگە كۆتۈرگىنىڭ»\bd* ــ دېمەك، «سەن مېنى مۇشۇ دەرىجىگە كۆتۇرگەن» دېگەن سۆز (18-ئايەت) ئۇنىڭ پادىشاھ بولغانلىقىنى كۆرسىتىدۇ. لېكىن خۇدا بۇ ئىمتىيازدىن يەنە كۆپ ئىمتىيازلارنى قوشۇپ بەرمەكچى. 9-16-ئايەتلەرنى قايتىدىن كۆرۈڭ. \bd «مېنى ئۇلۇغ مەرتىۋىلىك زات دەپ قارىدىڭ»\bd* ــ باشقا بىرخىل تەرجىمىسى «مېنى يۇقىرىدىكى (شۇ) ئىنساننىڭ قاتارىدا قارىدىڭ». بۇ تەرجىمىسى توغرا بولسا «يۇقىرىدىكى ئىنسان»، يەنى مەسىھ توغرۇلۇق بېشارەت بولىدۇ.\f*
\m 
\v 18 سەن كەمىنەڭ ئۈستىگە چۈشۈرگەن شۇنداق شان-شەرەپ توغرۇلۇق داۋۇت ساڭا نېمە دىيەلىسۇن؟ چۈنكى سەن دەرۋەقە ئۆز قۇلۇڭنى ئۆزۈڭ بىلىسەن.
\v 19 ئاھ پەرۋەردىگار، پېقىر قۇلۇڭ ئۈچۈن ھەمدە ئۆز كۆڭلۈڭدىكى نىيىتىڭ بويىچە بۇ بارلىق ئۇلۇغلۇقنى كۆرسىتىپ، بۇ چوڭ ئىشلارنىڭ ھەممىسىنى ئايان قىلدىڭ.
\v 20 ئاھ پەرۋەردىگار، قۇلىقىمىز تولۇق ئاڭلىغىنى بويىچە ساڭا تەڭ كەلگۈدەك ھېچكىم يوق؛ سېنىڭدىن بۆلەك ھېچبىر ئىلاھ يوقتۇر.
\v 21 دۇنيادا قايسى بىر ئەل خەلقىڭ ئىسرائىلغا تەڭ كېلەلىسۇن؟ ئۇلارنى ئۆزۈڭگە خاس بىردىنبىر خەلق بولۇش ئۈچۈن قۇتۇلدۇرۇشقا باردىڭ ھەمدە مىسىردىن قۇتۇلدۇرۇپ چىققان خەلقىڭ ئالدىدىن يات ئەللەرنى قوغلاپ چىقىرىپ، ئۇلۇغۋار ۋە بەھەيۋەت ئىشلار ئارقىلىق ئۆز نامىڭنى تىكلىدىڭ!
\v 22 سەن خەلقىڭ ئىسرائىلنى مەڭگۈ ئۆزۈڭنىڭ خەلقىڭ قىلدىڭ؛ ئاھ پەرۋەردىگار، سەنمۇ ئۇلارنىڭ خۇداسى بولدۇڭ.
\m 
\v 23 ئاھ پەرۋەردىگار، ئەمدى پېقىر قۇلۇڭ ۋە ئۇنىڭ ئۆيى توغرۇلۇق قىلغان ۋەدەڭ مەڭگۈگە ئەمەل قىلىنسۇن؛ سەن دېگەنلىرىڭ بويىچە ئىشنى ئادا قىلغايسەن!
\v 24 ئامىن، ۋەدەڭ ئەمەل قىلىنسۇن، شۇنداقلا نامىڭ مەڭگۈ ئۇلۇغلانسۇن، كىشىلەر: «ساماۋى قوشۇننىڭ سەردارى پەرۋەردىگار ئىسرائىلنىڭ خۇداسى، ھەقىقەتەن ئىسرائىلغا خۇدادۇر!» دېسۇن؛ ۋە شۇنداق بولۇپ، پېقىر قۇلۇڭ داۋۇتنىڭ ئۆي-جەمەتى سېنىڭ ئالدىڭدا مەزمۇت تۇرغۇزۇلسۇن.
\v 25 ئاھ خۇدايىم، سەن پېقىر قۇلۇڭغا ساڭا ئۆي ياسايمەن، دېگەن ۋەھىي كەلتۈردۈڭ؛ شۇڭا قۇلۇڭ سېنىڭ ئالدىڭدا مۇشۇنداق دۇئا قىلىشقا جۈرئەت قىلدى.
\v 26 ئاھ پەرۋەردىگار، سەن بىردىنبىر خۇدادۇرسەن، سەن پېقىر قۇلۇڭغا مۇشۇنداق ئامەتنى بېرىشنى ۋەدە قىلدىڭ؛
\v 27 ئەمدى پېقىر قۇلۇڭنىڭ ئۆي-جەمەتىگە ئىلتىپات قىلىپ، ئۇنىڭ سېنىڭ ئالدىڭدا مەڭگۈ تۇرۇشىغا ساقلىغايسەن. چۈنكى سەن، ئاھ پەرۋەردىگار، \add پېقىرنىڭ ئۆي-جەمەتىگە\add* ئىلتىپات قىلدىڭ ۋە شۇنىڭ بىلەن ئۇ مەڭگۈگە بەخت-ئىلتىپاتقا نېسىپ بولىدۇ».
\b
\b
\c 18
\s1 داۋۇت فىلىستىي، موئابىي ۋە زوباھلارنى مەغلۇپ قىلىدۇ
\r 2سام. 8‏:1-15
\m 
\v 1 شۇ ئىشتىن كېيىن شۇنداق بولدىكى، داۋۇت فىلىستىيلەرگە ھۇجۇم قىلىپ ئۇلارنى بويسۇندۇرۇپ، ئۇلارنىڭ قولىدىن گاتنى ۋە ئۇنىڭغا تەۋە يېزا-كەنتلەرنى تارتىۋالدى.
\v 2 ئۇ يەنە موئابىيلارغا ھۇجۇم قىلدى؛ موئابىيلار ئۇنىڭغا بېقىنىپ، ئولپان تۆلەيدىغان بولدى.
\m 
\v 3 زوباھنىڭ پادىشاھى ھادادئېزەر ئۆز تەۋەسىنى ئەفرات دەرياسىغىچە كېڭەيتىشكە ئاتلىنىپ چىققاندا، داۋۇت تاكى خاماتقا قەدەر ئۇنىڭغا ھۇجۇم قىلدى.
\v 4 داۋۇت ئۇنىڭ مىڭ جەڭ ھارۋىسىنى ئولجا ئالدى، يەتتە مىڭ ئاتلىق لەشكىرىنى، يىگىرمە مىڭ پىيادە لەشكىرىنى ئەسىر ئالدى. داۋۇت بارلىق جەڭ ھارۋىلىرىنىڭ ئاتلىرىنىڭ پېيىنى قىرقىتىۋېتىپ، پەقەت يۈز ھارۋىغا قوشقىدەك ئاتنىلا ئېلىپ قالدى.
\b
\s1 داۋۇت سۇرىيلەرنى مەغلۇپ قىلىدۇ
\m 
\v 5 دەمەشقتىكى سۇرىيلەر زوباھنىڭ پادىشاھى ھادادئېزەرگە ياردەم بېرىشكە كەلدى؛ داۋۇت سۇرىيلەردىن يىگىرمە ئىككى مىڭ ئەسكەرنى ئۆلتۈردى.
\v 6 داۋۇت سۇرىيەدىكى دەمەشق رايونىغا قاراۋۇل ئەترەتلىرىنى تۇرغۇزۇۋىدى، سۇرىيلەر داۋۇتقا بېقىنىپ، ئۇنىڭغا ئولپان تۆلەيدىغان بولدى. داۋۇت قەيەرگە \add جەڭگە\add* چىقمىسۇن، پەرۋەردىگار ئۇنى قوغداپ تۇردى. \f ◼ \fr 18:6 \ft \bd «پەرۋەردىگار ئۇنى قوغداپ تۇردى»\bd* ــ ياكى «پەرۋەردىگار غەلىبىگە ئېرىشتۈرۈپ تۇردى».\f*
\v 7 داۋۇت ھادادئېزەرنىڭ خىزمەتكارلىرى ئىشلىتىدىغان ئالتۇن قالقانلارنىڭ ھەممىسىنى يېرۇسالېمغا ئېلىپ قايتتى.
\v 8 ئۇ يەنە ھادادئېزەرگە تەۋە تىبھات بىلەن كۇندىن ئىبارەت ئىككى شەھەردىن نۇرغۇن مىس ئولجا ئالدى؛ كېيىنكى زامانلاردا سۇلايمان مۇشۇ مىسلارنى ئىشلىتىپ مىس كۆل، مىس تۈۋرۈكلەر ۋە باشقا بارلىق مىس ئەسۋابلارنى ياساتقان. \f ◼ \fr 18:8 \ft \bd «تىبھات»\bd* ــ ياكى «تەباھ».\f*
\m 
\v 9 خامات پادىشاھى توۋ داۋۇتنىڭ زوباھ پادىشاھى ھادادئېزەرنىڭ پۈتۈن قوشۇنىنى مەغلۇپ قىغانلىقىنى ئاڭلاپ، \f ◼ \fr 18:9 \ft \bd «توۋ»\bd* ــ «2سام.» 9:9دە «توي».\f*
\v 10 ئۆز ئوغلى ھادورامنى داۋۇتقا سالام بېرىپ، ئۇنىڭ ھادادئېزەر بىلەن جەڭ قىلىپ، ئۇنى مەغلۇپ قىلغان غەلىبىسىنى تەبرىكلەشكە ئەۋەتتى. چۈنكى توۋ ئەسلىدە ھادادئېزەر بىلەن دائىم ئۇرۇشۇپ تۇراتتى. ھادورام ھەرخىل ئالتۇن، كۈمۈش، مىس ئەسۋاب-جابدۇقلارنى سوۋغا قىلىپ ئەكەلدى.
\v 11 داۋۇت پادىشاھ بۇ ئەسۋاب-جابدۇقلارنى ھەرقايسى ئەللەردىن، جۈملىدىن ئېدوم، موئاب، ئاممونلاردىن، فىلىستىيلەردىن ۋە ئامالەكلەردىن ئولجا ئالغان ئالتۇن-كۈمۈشلەر بىلەن قوشۇپ ھەممىسىنى پەرۋەردىگارغا بېغىشلىدى.
\b
\s1 داۋۇت ئېدوملارنى مەغلۇپ قىلىدۇ
\m 
\v 12 زەرۇئىيانىڭ ئوغلى ئابىشاي «شور ۋادىسى»دا ئېدومىيلاردىن ئون سەككىز مىڭ ئادەمنى ئۆلتۈردى.
\v 13 داۋۇت ئېدومدا قاراۋۇل ئەترەتلىرىنى تۇرغۇزدى؛ ئېدوملارنىڭ ھەممىسى داۋۇتقا بېقىندى. داۋۇت قەيەرگە جەڭگە چىقمىسۇن، پەرۋەردىگار ئۇنى قوغداپ تۇردى. \f ◼ \fr 18:13 \ft \bd «پەرۋەردىگار ئۇنى قوغداپ تۇردى»\bd* ــ ياكى «پەرۋەردىگار غەلىبىگە ئېرىشتۈرۈپ تۇردى».\f*
\b
\s1 داۋۇتنىڭ مۇھىم خىزمەتكارلىرى
\r 2سام. 8‏:16-18؛ 20‏:23-26
\m 
\v 14 داۋۇت پادىشاھ بولۇپ پۈتۈن ئىسرائىل ئۈستىگە ھۆكۈمرانلىق قىلىپ، بارلىق خەلقىگە ئادالەت ۋە ھەققانىيلىق بىلەن مۇئامىلە قىلدى.
\v 15 زەرۇئىيانىڭ ئوغلى يوئاب قوشۇنغا سەردار، ئاھىلۇدنىڭ ئوغلى يەھوشافات مىرزا،
\v 16 ئاخىتۇبنىڭ ئوغلى زادوك بىلەن ئابىياتارنىڭ ئوغلى ئابىمەلەك \add باش\add* كاھىن، شاۋشا كاتىپ،
\v 17 يەھويادانىڭ ئوغلى بىنايا كەرەتىيلەر بىلەن پەلەتىيلەرنىڭ يولباشچىسى ئىدى؛ داۋۇتنىڭ ئوغۇللىرى ئۇنىڭ يېنىدىكى ئەمەلدارلار بولدى. \f ◼ \fr 18:17 \ft \bd «كەرەتىيلەر بىلەن پەلەتىيلەر»\bd* ــ بەلكىم داۋۇتقا ئالاھىدە مۇھاپىزەتچىلەر ياكى ئالاھىدە زەربىدار ئەسكەرلەر بولۇشى مۇمكىن ئىدى.\f*
\b
\b
\c 19
\s1 داۋۇتنىڭ ئەلچىلىرى ھاقارەتلىنىدۇ
\r 2سام. 10‏:1-19
\m 
\v 1 كېيىنكى ۋاقىتلاردا شۇنداق بولدىكى، ئاممونلارنىڭ پادىشاھى ناھاش ئۆلدى؛ ئوغلى ھانۇن ئورنىغا پادىشاھ بولدى.
\v 2 داۋۇت: «ناھاش ماڭا ئىلتىپات كۆرسەتكىنى ئۈچۈن، ئۇنىڭ ئوغلى ھانۇنغا ئىلتىپات كۆرسىتىمەن» دەپ، ئاتىسىنىڭ پەتىسىگە ئۇنىڭ كۆڭلىنى سوراشقا ھانۇننىڭ يېنىغا ئەلچىلەرنى ئەۋەتتى. داۋۇتنىڭ ئەلچىلىرى ئاممونلارنىڭ زېمىنغا يېتىپ كېلىپ، كۆڭلىنى سورىغىلى ھانۇن بىلەن كۆرۈشمەكچى بولدى.
\v 3 لېكىن ئاممونلارنىڭ ئەمەلدارلىرى ھانۇنغا: «داۋۇتنى راستلا ئاتىلىرىنىڭ ئىززەت-ھۆرمىتىنى قىلىپ سىلىگە كۆڭۈل سورىغىلى ئادەم ئەۋەتىپتۇ، دەپ قاراملا؟ ئۇنىڭ خىزمەتكارلىرىنىڭ ئۆزلىرىنىڭ ئالدىلىرىغا كېلىشى بۇ يەرنى كۈزىتىش، ئاغدۇرمىچىلىق قىلىش، چارلاش ئۈچۈن ئەمەسمىدۇ؟» ــ دېدى.
\v 4 شۇنىڭ بىلەن ھانۇن داۋۇتنىڭ خىزمەتكارلىرىنى تۇتۇپ، ئۇلارنىڭ ساقال-بۇرۇتلىرىنى چۈشۈرگۈزۈۋېتىپ ھەم كىيىملىرىنىڭ بەلدىن تۆۋىنىنى كەستۈرۈۋېتىپ ئاندىن ئۇلارنى قويۇۋەتتى.
\v 5 بەزىلەر كېلىپ داۋۇتقا ئەلچىلەرنىڭ ئەھۋالىنى ئۇقتۇردى؛ ئۇ ئۇلارنى كۈتۈۋېلىشقا ئالدىغا ئادەم ئەۋەتتى، چۈنكى ئۇلار تولىمۇ ئىزا-ئاھانەتتە قالغانىدى. شۇڭا پادىشاھ ئۇلارغا: «ساقال-بۇرۇتىڭلار ئۆسكىچىلىك يېرىخو شەھىرىدە تۇرۇپ ئاندىن يېنىپ كېلىڭلار» دېدى.
\b
\s1 ئاممونلار ئۇرۇشقا تەييارلىنىدۇ
\m 
\v 6 ئاممونلار ئۆزلىرىنىڭ داۋۇتنىڭ نەپرىتىگە ئۇچرىغانلىقىنى بىلدى، ھانۇن ۋە ئاممونلار ئارام-ناھارائىم، ئارام-مائاكاھ ۋە زوباھدىن جەڭ ھارۋىسى ۋە ئاتلىق لەشكەر ياللاشقا ئادەم ئەۋەتىپ مىڭ تالانت كۈمۈش بەردى. \f ◼ \fr 19:6 \ft \bd «ئارام-ناھارائىم»\bd* ــ ياكى «مېسوپوتامىيە». «ئارام» بولسا سۇرىيەنىڭ كونا نامىدۇر. \bd «مىڭ تالانت كۈمۈش»\bd* ــ مىڭ تالانت كۈمۈش 30000 كىلوگرامچە بولۇشى مۇمكىن.\f*
\v 7 ئۇلار ئوتتۇز ئىككى مىڭ جەڭ ھارۋىسى، شۇنداقلا مائاكاھ پادىشاھى بىلەن ئۇنىڭ قوشۇنىنى ياللىۋالدى؛ ئۇلار مەدەبانىڭ ئالدىغا كېلىپ بارگاھ قۇردى. ئاممونلارمۇ جەڭ قىلىش ئۈچۈن ھەرقايسى شەھەرلىرىدىن كېلىپ جەم بولۇشتى.
\v 8 داۋۇت بۇنى ئاڭلاپ يوئاب بىلەن بارلىق ئەسكەر قوشۇنىنى \add ئۇلارنىڭ ئالدىغا\add* چىقاردى.
\v 9 ئاممونلار چىقىپ شەھەر دەرۋازىسىنىڭ ئالدىدا سەپ تۈزۈپ تۇردى؛ جەڭگە ئاتلىنىپ چىققان پادىشاھلارمۇ دالادا ئايرىم سەپ تۈزۈپ تۇرۇشتى.
\b
\s1 سۇرىيلەر بىلەن ئاممونلار مەغلۇپ بولۇپ چېكىنىدۇ
\m 
\v 10 يوئاب ئۆزىنىڭ ئالدى-كەينىدىن ھۇجۇمغا ئۇچرايدىغانلىقىنى كۆرۈپ، پۈتۈن ئىسرائىلدىن بىر قىسىم سەرخىل ئادەملەرنى تاللاپ، سۇرىيلەر بىلەن جەڭ قىلىشقا ئۇلارنى سەپتە تۇرغۇزدى؛
\v 11 ئۇ قالغان ئادەملىرىنى ئىنىسى ئابىشايغا تاپشۇردى، شۇنىڭدەك ئۇلار ئۆزلىرىنى ئاممونلار بىلەن جەڭ قىلىشقا سەپ قىلىپ تەييارلىدى.
\m 
\v 12 يوئاب ئابىشايغا: «ئەگەر سۇرىيلەر ماڭا كۈچلۈك كەلسە، سەن ماڭا ياردەم بەرگەيسەن؛ ئەمما ئاممونلار ساڭا كۈچلۈك كەلسە، مەن بېرىپ ساڭا ياردەم بېرەي.
\v 13 جۈرئەتلىك بولغىن! ئۆز خەلقىمىز ئۈچۈن ۋە خۇدايىمىزنىڭ شەھەرلىرى ئۈچۈن باتۇرلۇق قىلايلى. پەرۋەردىگار ئۆزىگە لايىق كۆرۈنگىنىنى قىلغاي! ــ دېدى.
\b
\s1 داۋۇت سۇرىيلەر بىلەن ئاممونلارنى مەغلۇپ قىلىدۇ
\m 
\v 14 ئەمدى يوئاب ۋە ئۇنىڭ بىلەن بولغان ئادەملەر سۇرىيلەرگە ھۇجۇم قىلغىلى چىقتى؛ سۇرىيلەر ئۇنىڭ ئالدىدىن قاچتى.
\v 15 سۇرىيلەرنىڭ قاچقانلىقىنى كۆرگەن ئاممونلارمۇ يوئابنىڭ ئىنىسى ئابىشاينىڭ ئالدىدىن قېچىپ، شەھەرگە كىرىۋالدى. ئاندىن يوئاب يېرۇسالېمغا قايتىپ كەلدى.
\m 
\v 16 سۇرىيلەر بولسا ئۆزلىرىنىڭ ئىسرائىللارنىڭ ئالدىدا مەغلۇپ بولغىنىنى كۆرگەندە، ئەلچى ئەۋەتىپ، \add ئەفرات\add* دەرياسىنىڭ ئۇ تەرىپىدىكى سۇرىيلەرنى چاقىرتىپ كەلدى. ھادادئېزەرنىڭ قوشۇنىنىڭ سەردارى بولغان شوفاق ئۇلارغا يېتەكچى ئىدى.
\m 
\v 17 بۇنىڭدىن خەۋەر تاپقان داۋۇت پۈتكۈل ئىسرائىل خەلقىنى يىغىپ ئىئوردان دەرياسىدىن ئۆتۈپ، سۇرىيلەرنىڭ يېنىغا كېلىپ ئۇلارغا قارشى سەپ تۈزۈپ تۇردى. داۋۇتنىڭ سەپ تۈزگەنلىكىنى كۆرگەن سۇرىيلەر جەڭگە ئاتلاندى.
\v 18 سۇرىيلەر ئىسرائىللارنىڭ ئالدىدىن قاچتى؛ داۋۇت سۇرىيلەردىن يەتتە مىڭ جەڭ ھارۋىلىقنى ۋە قىرىق مىڭ پىيادە لەشكەرنى ئۆلتۈردى ۋە يەنە سۇرىيلەرنىڭ سەردارى شوفاقنى ئۆلتۈردى. \f ◼ \fr 19:18 \ft \bd «قىرىق مىڭ ىيادە لەشكەر»\bd* ــ ياكى «قىرىق مىڭ ئاتلىق» ــ «2سام.» 18:10نى كۆرۈڭ. ئۇنىڭدا «يەتتە يۈز جەڭ ھارۋىسى» دېيىلىدۇ. پەرقىنىڭ سەۋەبى بەلكىم: (1) قولىمىزدىكى كۆچۈرمىلەردە كۆچۈرگۈچىنىڭ سەۋەنلىكى بولۇشى مۇمكىن؛ (2) ئىككى ئايەتتە خاتىرىلەنگەن سانلارنى ھېسابلاش نۇقتىسى ئوخشىمايدىغان بولۇشى مۇمكىن.\f*
\v 19 ھادادئېزەرنىڭ ئەمەلدارلىرى ئىسرائىل ئالدىدا يېڭىلگىنىنى كۆرگەندە، داۋۇت بىلەن سۈلھ قىلىپ ئۇنىڭغا بېقىندى؛ شۇنىڭدىن كېيىن سۇرىيلەر ئىككىنچى ئاممونىيلارغا ياردەم بېرىشنى خالىمايدىغان بولدى. \f ◼ \fr 19:19 \ft \bd «ھادادئېزەرنىڭ ئەمەلدارلىرى»\bd* ــ ياكى «ھادادئېزەرگە بېقىنغانلار» ــ «2سام.» 19:10نى كۆرۈڭ\f*
\b
\b
\c 20
\s1 يوئابنىڭ ئاممونلارنىڭ پايتەختى رابباھنى ھۇجۇم قىلىپ ئالغانلىقى
\r 2سام. 12‏:26-31
\m 
\v 1 شۇنداق بولدىكى، يېڭى يىلنىڭ بېشىدا، پادىشاھلار جەڭگە ئاتلانغان ۋاقىتتا، يوئاب كۈچلۈك قىسىمنى باشلاپ كېلىپ، ئاممونلارنىڭ يەرلىرىنى ۋەيران قىلىپ، ئاندىن رابباھنى مۇھاسىرىگە ئالدى. ئۇ چاغدا داۋۇت يېرۇسالېمدا تۇرۇۋاتاتتى. يوئاب رابباھغا ھۇجۇم قىلىپ شەھەرنى ۋەيران قىلىپ تاشلىدى. \f ◼ \fr 20:1 \ft \bd «يېڭى يىلنىڭ بېشىدا»\bd* ــ خۇدا يەھۇدىي خەلقىگە تاپشۇرغان كالېندار بويىچە «يېڭى يىل» ئەتىيازدا باشلىناتتى («مىس.» 2:12).\f*
\v 2 داۋۇت ئۇلارنىڭ پادىشاھىنىڭ بېشىدىن تاجنى ئېلىۋىدى (ئالتۇنىنىڭ ئېغىرلىقى بىر تالانت چىقتى، ئۇنىڭغا ياقۇتلار قوندۇرۇلغانىدى)، كىشىلەر بۇ تاجنى داۋۇتنىڭ بېشىغا كىيدۈرۈپ قويدى. داۋۇت شەھەردىن يەنە نۇرغۇن جەڭ غەنىيمەتلىرىنى ئېلىپ كەتتى. \f ◼ \fr 20:2 \ft \bd «داۋۇت ئۇلارنىڭ پادىشاھىنىڭ بېشىدىن تاجنى ئېلىۋىدى»\bd* ــ ياكى «داۋۇت بۇتى مىلكومنىڭ بېشىدىن تاجنى ئېلىۋىدى». \bd «ئېغىرلىقى بىر تالانت»\bd* ــ بىر تالانت بەلكىم 30 كىلوگرام ئىدى.\f*  \x ◘ \xo 20:2 \xt 2سام. 12‏:30\x*
\v 3 ئۇ يەنە شەھەردىكى خەلقنى ئېلىپ چىقىپ ھەرە، جوتۇ ۋە پالتا بىلەن ئىشلەشكە سالدى؛ داۋۇت ئامموننىڭ ھەرقايسى شەھەرلىرىدىكى خەلقلەرنىمۇ شۇنداق ئىشلەتتى؛ ئاندىن داۋۇت كۆپچىلىك بىلەن يېرۇسالېمغا قايتتى.
\b
\s1 داۋۇت فىلىستىيلەرنى ئۈچ قېتىم مەغلۇپ قىلىدۇ. تۆت گىگانتنىڭ قەتل قىلىنىشى
\r 2سام. 21‏:18-22
\m 
\v 4 شۇ ۋەقەدىن كېيىن \add ئىسرائىللار\add* گەزەردە فىلىستىيلەر بىلەن سوقۇشتى؛ ئۇ چاغدا خۇشاتلىق سىببىكاي رەفايىيلاردىن بولغان سىپپاي ئىسىملىك بىرىنى ئۆلتۈرۈۋەتتى، فىلىستىيلەر تىز پۈكتى. \f ◼ \fr 20:4 \ft \bd «رەفايىيلار»\bd* ــ بەلكىم گىگانتلار ئىدى. «2سام.» 16:21-22نى كۆرۈڭ.\f*
\v 5 كېيىنچە \add ئىسرائىللار\add* بىلەن فىلىستىيلەر يەنە سوقۇشتى؛ يائىرنىڭ ئوغلى ئەلھانەن گاتلىق گولىياتنىڭ ئىنىسى لاخمىنى ئۆلتۈردى؛ بۇ ئادەمنىڭ نەيزىسىنىڭ دەستىسى باپكارنىڭ ئوقىدەك توم ئىدى.
\v 6 كېيىنكى ۋاقىتلاردا گاتتا يەنە سوقۇش بولدى؛ ئۇ يەردە ناھايىتى بەستلىك بىر ئادەم بار ئىدى، ئۇنىڭ قولىدىمۇ، پۇتىدىمۇ ئالتىدىن بارماق بولۇپ، جەمئىي يىگىرمە تۆت بارمىقى بار ئىدى؛ ئۇمۇ رەفايىيلاردىن ئىدى. \f ◼ \fr 20:6 \ft \bd «رەفايىيلار»\bd* ــ ئىبرانىي تىلىدا «رافانىڭ نەسلى» دېگەن سۆزلەر بىلەن ئىپادىلىنىدۇ. دېمەك، «رەفايىيلار» رافانىڭ ئەۋلادلىرى.\f*
\v 7 بۇ ئادەم ئىسرائىللارنى تىللىغىلى تۇرۇۋىدى، داۋۇتنىڭ ئاكىسى شىمىيانىڭ ئوغلى يوناتان چىقىپ ئۇنى ئۆلتۈرۈۋەتتى.
\v 8 بۇلار گاتلىق رافانىڭ ئەۋلادلىرى بولۇپ، ھەممىسى داۋۇت ۋە ئۇنىڭ خىزمەتكارلىرىنىڭ قولىدا ئۆلدى.
\b
\b
\c 21
\s1 داۋۇتنىڭ گۇناھى ــ ئۇ ئاھالىنى ساناقتىن ئۆتكۈزىدۇ
\r 2سام. 24‏:1-25
\m 
\v 1 شەيتان ئىسرائىللارغا زەربە بېرىش ئۈچۈن، داۋۇتنى ئىسرائىللارنى ساناقتىن ئۆتكۈزۈشكە ئېزىقتۇردى. \f ◼ \fr 21:1 \ft \bd «شەيتان ئىسرائىللارغا زەربە بېرىش ئۈچۈن، داۋۇتنى ئىسرائىللارنى ساناقتىن ئۆتكۈزۈشكە ئېزىقتۇردى»\bd* ــ «ساناقتىن ئۆتكۈزۈش» دېگەن سۆز ئىسرائىلنىڭ ئەسكىرىي كۈچىنى كۆزدە تۇتىدۇ. 5-ئايەتنى كۆرۈڭ.\fp باشقا بىرخىل تەرجىمىسى «دۈشمەننىڭ ئىسرائىللارغا زەربە بەرمەكچى بولغىنى داۋۇتنى ئىسرائىللارنى ساناقتىن ئۆتكۈزۈشكە ئالدىراتتى» («شەيتان» ۋە «دۈشمەن» ئىبرانىي تىلىدا بىر سۆز بىلەنلا ئىپادىلىنىدۇ). بىزنىڭچە «ئېزىقتۇرىدۇ» ياكى «ئالدىراتتى» دېگەن سۆز بىر روھىي كۈچنىڭ مەۋجۇتلۇقىنى كۆرسىتىدۇ، شۇڭا «شەيتان» دەپ تەرجىمە قىلدۇق. «2سام.» 1:24نىمۇ كۆرۈڭ.\f*
\v 2 شۇڭا داۋۇت يوئابقا ۋە خەلقنىڭ يولباشچىلىرىغا: «سىلەر بەئەر-شېبادىن دانغىچە ئارىلاپ ئىسرائىللارنى ساناقتىن ئۆتكۈزۈپ كېلىپ مېنىڭ بىلەن كۆرۈشۈڭلار، ئۇلارنىڭ سانىنى بىلەي» دېدى. \f ◼ \fr 21:2 \ft \bd «بەئەر-شېبادىن دانغىچە»\bd* ــ «بەئەر-شېبا» ئىسرائىل زېنىمىنىڭ ئەڭ جەنۇبىي چېتىدە، «دان» بولسا ئەڭ شىمالىي چېتىدە ئىدى.\f*
\v 3 لېكىن يوئاب جاۋابەن: ــ«پەرۋەردىگار ئۆز خەلقىنى ھازىر مەيلى قانچىلىك بولسۇن، يۈز ھەسسە ئاشۇرۇۋەتكەي. لېكىن ئى خوجام پادىشاھىم، ئۇلارنىڭ ھەممىسى ئۆزۈڭنىڭ خىزمىتىڭدە تۇرۇۋاتقانلار ئەمەسمۇ؟ خوجام بۇ ئىشنى زادى نېمە دەپ تەلەپ قىلىدۇ؟ خوجام ئىسرائىلنى نېمىشقا گۇناھقا مۇپتىلا قىلىدىلا؟» ــ دېدى. \f ◼ \fr 21:3 \ft \bd «خوجام ئىسرائىلنى نېمىشقا گۇناھقا مۇپتىلا قىلىدىلا؟»\bd* ــ قىزىق يېرى شۇكى، يوئاب ئادەتتە خۇدادىن ئانچە قورقمايدىغان ئادەم بولۇپ، مۇشۇ ۋاقىتلاردا خوجىسىغا قارىغاندا، خۇدانىڭ ئىرادىسىنى ئوبدان بىلەتتى. «خەلقنى ساناقتىن ئۆتكۈزۈش» دېگەن گۇناھ توغرۇلۇق «سامۇئىل»دىكى «قوشۇمچە سۆز»ىمىزدە ئازراق توختىلىمىز.\f*
\m 
\v 4 لېكىن پادىشاھنىڭ سۆزى يوئابنىڭ سۆزىنى بېسىپ چۈشتى؛ شۇڭا يوئاب چىقىپ پۈتۈن ئىسرائىل زېمىنىنى ئارىلاپ يېرۇسالېمغا قايتىپ كەلدى.
\v 5 يوئاب ساناقتىن ئۆتكۈزۈلگەن خەلقنىڭ سانىنى داۋۇتقا مەلۇم قىلدى؛ پۈتۈن ئىسرائىلدا قولىدا قىلىچ كۆتۈرەلەيدىغان ئادەملەر بىر مىليون بىر يۈز مىڭ؛ يەھۇدالاردىن قولىدا قىلىچ كۆتۈرەلەيدىغان ئادەملەر تۆت يۈز يەتمىش مىڭ بولۇپ چىقتى.
\v 6 بىراق لاۋىيلار بىلەن بىنيامىنلارلا ساناققا كىرمىدى؛ چۈنكى پادىشاھنىڭ بۇ بۇيرۇقى يوئابنىڭ نەزىرىدە يىرگىنچلىك ئىدى.
\b
\s1 پەرۋەردىگار جازا چۈشۈرىدۇ
\m 
\v 7 خۇدا بۇ ئىشنى يامان كۆرگەچكە، ئىسرائىللارغا زەربە بەردى. \f ◼ \fr 21:7 \ft \bd «خۇدا بۇ ئىشنى يامان كۆرگەچكە، ئىسرائىللارغا زەربە بەردى»\bd* ــ نېمىشقا خەلقنى ساناقتىن ئۆتكۈزۈش گۇناھ ھېسابلىنىدۇ؟ بۇ توغرۇلۇق «سامۇئىل»دىكى «قوشۇمچە سۆز»ىمىزنى كۆرۈڭ.\f*
\v 8 داۋۇت خۇداغا: «مەن بۇ ئىشنى قىلىپ چوڭ گۇناھ ئۆتكۈزۈپتىمەن؛ ئەمدى مەنكى قۇلۇڭنىڭ بۇ قەبىھلىكىنى كەچۈرۈشىڭنى تىلەيمەن، چۈنكى مەن تولىمۇ ئەخمىقانە ئىش قىپتىمەن» ــ دېدى.
\m 
\v 9 پەرۋەردىگار داۋۇتنىڭ ئالدىن كۆرگۈچىسى بولغان گادقا:
\v 10 سەن بېرىپ داۋۇتقا ئېيتىپ: «پەرۋەردىگار مۇنداق دەيدۇكى، مەن ساڭا ئۈچ بالا-قازانى ئالدىڭدا قويىمەن؛ شۇنىڭدىن بىرىنى تاللىۋال، مەن شۇنى بېشىڭلارغا چۈشۈرىمەن» دېگىن، ــ دېدى.
\m 
\v 11 شۇنىڭ بىلەن گاد داۋۇتنىڭ يېنىغا كېلىپ: «پەرۋەردىگار مۇنداق دەيدۇ:
\v 12 «قېنى تاللىغىن: يا ئۈچ يىل ئاچارچىلىقتا قېلىشتىن، يا ئۈچ ئاي دۈشمەنلەرنىڭ ئالدىدىن قېچىپ، ياۋلىرىڭ تەرىپىدىن قوغلاپ قىلىچلىنىشىدىن ۋە ياكى ئۈچ كۈن پەرۋەردىگارنىڭ قىلىچىنىڭ ئۇرۇشى ــ يەنى ۋابا كېسىلىنىڭ زېمىندا تارقىلىشى، پەرۋەردىگارنىڭ پەرىشتىسىنىڭ ئىسرائىلنىڭ پۈتۈن چېگرىسىنى خاراب قىلىشىدىن بىرىنى تاللىغىن». ئەمدى ئويلىنىپ كۆر، بىر نېمە دېگىن؛ مەن مېنى ئەۋەتكۈچىگە نېمە دەپ جاۋاپ بېرەي؟» دېدى.
\v 13 داۋۇت گادقا: «مەن بەك قاتتىق تەڭلىكتە قالدىم؛ ئەمدى پەرۋەردىگارنىڭ قولىغا چۈشەي دەيمەن، چۈنكى ئۇ تولىمۇ شەپقەتلىكتۇر. پەقەت ئىنسانلارنىڭ قولىغا چۈشمىسەم، دەيمەن» دېدى.
\m 
\v 14 شۇ سەۋەبلىك پەرۋەردىگار ئىسرائىلغا ۋابا تارقاتتى؛ ئىسرائىللاردىن يەتمىش مىڭ ئادەم ئۆلدى.
\v 15 خۇدا يېرۇسالېمنى ۋەيران قىلىپ تاشلاش ئۈچۈن بىر پەرىشتىنى ئەۋەتتى؛ ئۇ ۋەيران قىلىۋاتقاندا، پەرۋەردىگار ئەھۋالنى كۆرۈپ ئۆزى چۈشۈرگەن بۇ بالا-قازادىن پۇشايمان قىلىپ قالدى-دە، ۋەيران قىلغۇچى پەرىشتىگە: «بەس! ئەمدى قولۇڭنى تارت!» دېدى. ئۇ چاغدا پەرۋەردىگارنىڭ پەرىشتىسى يەبۇسىي ئورناننىڭ خامىنىنىڭ يېنىدا تۇراتتى. \f ◼ \fr 21:15 \ft \bd «ئورنان»\bd* ــ ياكى «ئاراۋنا». «2سام.» 16:24نى كۆرۈڭ.\f*
\v 16 داۋۇت بېشىنى كۆتۈرۈپ، پەرۋەردىگارنىڭ پەرىشتىسىنىڭ ئاسمان بىلەن يەرنىڭ ئارىلىقىدا، قولىدىكى غىلاپتىن سۇغۇرغان قىلىچىنى يېرۇسالېمغا تەڭلەپ تۇرغانلىقىنى كۆردى. داۋۇت بىلەن ئاقساقاللارنىڭ ھەممىسى بۆز رەختكە ئورالغان ھالدا يەرگە دۈم يىقىلدى.
\v 17 داۋۇت خۇداغا: «خەلقنىڭ سانىنى ئېلىپ چىقىشنى بۇيرۇغۇچى مەن ئەمەسمۇ؟ گۇناھ قىلىپ بۇ رەزىللىك ئۆتكۈزگۈچى مەندۇرمەن؛ بۇ بىر پادا قويلار بولسا، زادى نېمە قىلدى؟ ئاھ، پەرۋەردىگار خۇدايىم، قولۇڭ ئۆز خەلقىڭگە ئەمەس، بەلكى ماڭا ۋە مېنىڭ جەمەتىمگە چۈشكەي، ۋابانى ئۆز خەلقىڭنىڭ ئۈستىگە چۈشۈرمىگەيسەن!» دېدى.
\b
\s1 داۋۇت قۇربانگاھ سېلىپ قۇربانلىق سۇنىدۇ
\m 
\v 18 پەرۋەردىگارنىڭ پەرىشتىسى گادقا: سەن بېرىپ داۋۇتقا ئېيتقىن، ئۇ يەبۇسىي ئورناننىڭ خامىنىغا چىقىپ پەرۋەردىگارغا بىر قۇربانگاھ سالسۇن، دېۋىدى،
\v 19 داۋۇت گادنىڭ پەرۋەردىگارنىڭ نامىدا ئېيتقىنى بويىچە شۇ يەرگە چىقتى.
\v 20 ئۇ چاغدا ئورنان بۇغداي تېپىۋاتاتتى؛ ئورنان بۇرۇلۇپ پەرىشتىنى كۆرۈپ، ئۆزى تۆت ئوغلى بىلەن مۆكۈۋالغانىدى.
\v 21 داۋۇت ئورناننىڭ يېنىغا كەلگەندە، ئۇ بېشىنى كۆتۈرۈپ داۋۇتنى كۆرۈپ، خاماندىن چىقىپ كەلدى-دە، بېشىنى يەرگە تەگكۈدەك ئېگىپ داۋۇتقا تەزىم قىلدى.
\m 
\v 22 داۋۇت ئورنانغا: «خەلق ئىچىدە تارالغان ۋابانى توسۇپ قېلىش ئۈچۈن، مۇشۇ خاماننى ۋە ئەتراپىدىكى يەرنى ماڭا سېتىپ بەرسەڭ، بۇ يەردە پەرۋەردىگارغا ئاتاپ بىر قۇربانگاھ سالاي دەيمەن. سەن تولۇق باھا قويۇپ بۇ يېرىڭنى ماڭا سېتىپ بەرسەڭ» دېدى.
\m 
\v 23 ــ ئالسىلا، غوجام پادىشاھىمنىڭ قانداق قىلغۇسى كەلسە شۇنداق قىلغاي؛ قارىسىلا، قۇربانلىق قىلىشقا كالىلارنى بېرەي، خامان تېپىدىغان تىرنىلارنى ئوتۇن قىلىپ قالىسىلا، بۇغداينى ئاش ھەدىيەسىگە ئىشلەتسىلە؛ بۇلارنىڭ ھەممىسىنى مەن ئۆزلىرىگە تۇتتۇم، دېدى ئورنان داۋۇتقا.
\m 
\v 24 «ياق»، ــ دېدى داۋۇت ئورنانغا، ــ «قانداقلا بولمىسۇن مەن تولۇق باھاسى بويىچە سېتىۋالىمەن؛ چۈنكى مەن سېنىڭكىنى ئېلىۋېلىپ پەرۋەردىگارغا ئاتىسام بولمايدۇ، بەدەل تۆلىمەي كۆيدۈرمە قۇربانلىقنى ھەرگىز سۇنمايمەن».
\m 
\v 25 شۇنىڭ بىلەن داۋۇت ئالتە يۈز شەكەل ئالتۇننى ئۆلچەپ ئورنانغا بېرىپ ئۇ يەرنى سېتىۋالدى. \f ◼ \fr 21:25 \ft \bd «ئالتە يۈز شەكەل»\bd* ــ 600 شەكەل 7 كىلوگرامچە بولاتتى. «2سام.» 24:24 بويىچە ئۇ «خامان ۋە كالىلار» ئۈچۈن 50 شەكەل كۈمۈش بېرىدۇ. مۇشۇ يەردە ئۇ شۈبھىسىزكى ئورناننىڭ پۈتكۈل «يەر»ىنى سېتىۋالىدۇ.\f*
\m 
\v 26 داۋۇت ئۇ يەرگە پەرۋەردىگارغا ئاتاپ بىر قۇربانگاھ سالدى ۋە كۆيدۈرمە قۇربانلىق ۋە ئىناقلىق قۇربانلىقى سۇنۇپ، پەرۋەردىگارغا نىدا قىلدى؛ پەرۋەردىگار ئۇنىڭ تىلىگىنى قوبۇل كۆرۈپ، جاۋابەن ئاسماندىن كۆيدۈرمە قۇربانلىق قۇربانگاھىغا ئوت چۈشۈردى.
\m 
\v 27 پەرۋەردىگار پەرىشتىسىنى بۇيرۇۋىدى، ئۇ قىلىچىنى قايتىدىن غىلىپىغا سالدى.
\b
\s1 مۇقەددەس ئىبادەتخانا سېلىش ئورنىنى بېكىتىش
\m 
\v 28 ئۇ چاغدا، داۋۇت پەرۋەردىگارنىڭ يەبۇسىيلاردىن بولغان ئورناننىڭ خامىنىدا ئۇنىڭ تىلىكىگە جاۋاب بەرگەنلىكىنى كۆرۈپ، شۇ يەردە قۇربانلىق سۇنۇشقا باشلىدى.
\v 29 ئۇ چاغدا، مۇسا چۆلدە ياساتقان پەرۋەردىگارنىڭ چېدىرى ۋە كۆيدۈرمە قۇربانلىق قۇربانگاھى گىبېئوننىڭ ئېگىزلىكىدە ئىدى؛
\v 30 لېكىن داۋۇت پەرۋەردىگارنىڭ پەرىشتىسىنىڭ قىلىچىدىن قورقۇپ، ئۇ يەرنىڭ ئالدىغا بېرىپ خۇدادىن يول سوراشقا جۈرئەت قىلالمايتتى.
\b
\b
\c 22
\m 
\v 1 شۇڭا داۋۇت: «مانا بۇ پەرۋەردىگار خۇدانىڭ ئۆيى بولىدىغان جاي، مانا بۇ ئىسرائىل ئۈچۈن كۆيدۈرمە قۇربانلىق سۇنىدىغان قۇربانگاھ بولىدۇ» ــ دېدى.
\b
\s1 مۇقەددەس ئىبادەتخانا سالىدىغان ماتېرىياللارنى ھازىرلاش
\m 
\v 2 داۋۇت پەرۋەردىگارنىڭ ئۆيىنى سالدۇرۇش ئۈچۈن ئىسرائىل زېمىنىدىكى يات ئەلدىكىلەرنى يىغىشنى بۇيرۇدى ھەم تاشلارنى ئويۇشقا تاشچىلارنى تەيىنلىدى.
\v 3 ئىشىك-دەرۋازىلارغا ئىشلىتىشكە مىق ۋە گىرە-بالداق ياساش ئۈچۈن نۇرغۇن تۆمۈر تەييارلىدى؛ يەنە نۇرغۇن مىس تەييارلىدىكى، ئۇنىڭ ئېغىرلىقىنى تارازىلاپ بولمايتتى؛ \f ◼ \fr 22:3 \ft \bd «گىرە-بالداق»\bd* ــ ياكى «ئىلمەك-ئىلگەكلەر».\f*
\v 4 ئۇ يەنە سان-ساناقسىز كېدىر ياغىچى تەييارلىدى، چۈنكى زىدونلۇقلار بىلەن تۇرلۇقلار داۋۇتقا نۇرغۇن كېدىر ياغىچى يەتكۈزۈپ بەرگەنىدى.
\v 5 داۋۇت كۆڭلىدە: «ئوغلۇم سۇلايمان تېخى ياش، بىر يۇمران كۆچەت خالاس، پەرۋەردىگارغا سېلىنىدىغان ئۆي ناھايىتى بەھەيۋەت ۋە كاتتا بولۇشى، شان-شۆھرىتى بارلىق يۇرتلارغا يېيىلىشى كېرەك؛ شۇنىڭ بىلەن بۇ ئۆيگە كېتىدىغان ماتېرىياللارنى ھازىرلاپ قويۇشۇم كېرەك» دەپ ئويلىدى. شۇڭا داۋۇت ئۆلۈشتىن ئىلگىرى نۇرغۇن ماتېرىيال ھازىرلاپ قويدى.
\b
\s1 داۋۇت سۇلايمانغا مۇقەددەس ئۆي سېلىشنى ۋەسىيەت قىلىدۇ
\m 
\v 6 داۋۇت ئوغلى سۇلايماننى قىچقىرىپ ئۇنىڭغا ئىسرائىلنىڭ خۇداسى بولغان پەرۋەردىگارغا ئۆي سېلىشنى تاپىلىدى.
\v 7 داۋۇت سۇلايمانغا مۇنداق دېدى: «ئى ئوغلۇم، مەن ئەسلىدە پەرۋەردىگار خۇدايىمنىڭ نامىغا ئاتاپ بىر ئۆي سېلىشنى ئويلىغان،
\v 8 لېكىن پەرۋەردىگارنىڭ سۆزى كېلىپ ماڭا مۇنداق دېگەندە: «سەن نۇرغۇن ئادەمنىڭ قېنىنى تۆكتۈڭ، نۇرغۇن چوڭ جەڭلەرنى قىلدىڭ؛ سېنىڭ مېنىڭ نامىمغا ئاتاپ ئۆي سېلىشىڭغا بولمايدۇ، چۈنكى سەن مېنىڭ ئالدىمدا نۇرغۇن ئادەمنىڭ قېنىنى يەرگە تۆكتۈڭ.
\v 9 قارا، سېنىڭدىن بىر ئوغۇل تۆرۈلىدۇ؛ ئۇ ئارام-تىنچلىق ئادىمى بولىدۇ، مەن ئۇنى ھەر تەرەپتىكى دۈشمەنلىرىدىن ئارام تاپقۇزىمەن؛ ئۇنىڭ ئىسمى دەرۋەقە سۇلايمان ئاتىلىدۇ، ئۇ تەختتىكى كۈنلىرىدە مەن ئىسرائىلغا ئارام-تىنچلىق ۋە ئاسايىشلىق ئاتا قىلىمەن. \f ◼ \fr 22:9 \ft \bd «ئۇنىڭ ئىسمى دەرۋەقە سۇلايمان ئاتىلىدۇ»\bd* ــ «سۇلايمان» دېگەن ئىسىم ئىبرانىي تىلىدىكى «شالوم» (تىنچلىق، خاتىرجەملىك»كە باغلىق (ئەرەب تىلىدا «سالام»).\f*
\v 10 ئۇ مېنىڭ نامىمغا ئاتاپ ئۆي سالىدۇ؛ ئۇ ماڭا ئوغۇل بولىدۇ، مەن ئۇنىڭغا ئاتا بولىمەن؛ مەن ئۇنىڭ ئىسرائىل ئۈستىدىكى پادىشاھلىق تەختىنى مەڭگۈ مەزمۇت قىلىمەن».
\m 
\v 11 ئى ئوغلۇم، ئەمدى پەرۋەردىگار سېنىڭ بىلەن بىللە بولغاي! شۇنىڭ بىلەن يولۇڭ راۋان بولۇپ، ئۇنىڭ سېنىڭ توغرۇلۇق بەرگەن ۋەدىسى بويىچە پەرۋەردىگار خۇدايىڭنىڭ ئۆيىنى سالىسەن.
\v 12 پەرۋەردىگار ساڭا پەم ۋە ئەقىل بەرگەي ۋە ئىسرائىلنى ئىدارە قىلىشقا كۆرسەتمە بەرگەي، سېنى پەرۋەردىگار خۇدايىڭنىڭ مۇقەددەس قانۇنىغا ئەمەل قىلىدىغان قىلغاي.
\v 13 شۇ ۋاقىتتا، پەرۋەردىگار ئىسرائىللار ئۈچۈن مۇساغا تاپشۇرغان بەلگىلىمە-ھۆكۈملەرگە ئەمەل قىلساڭ، يولۇڭ راۋان بولىدۇ. قەيسەر، باتۇر بول! قورقما، ھودۇقۇپمۇ كەتمە. \f ◼ \fr 22:13 \ft \bd «ھودۇقۇپمۇ كەتمە»\bd* ــ ياكى «غەيرەتسىز بولما».\f*
\v 14 قارا، مەن پەرۋەردىگارنىڭ ئۆيى ئۈچۈن جاپا-مۈشەققەتلىرىم ئارقىلىق يۈز مىڭ تالانت ئالتۇن، مىڭ مىڭ تالانت كۈمۈش ۋە ئىنتايىن كۆپ، سان-ساناقسىز مىس، تۆمۈر تەييارلىدىم؛ يەنە ياغاچ ۋە تاش تەييارلىدىم؛ بۇنىڭغا يەنە سەن قوشساڭ بولىدۇ. \f ◼ \fr 22:14 \ft \bd «يۈز مىڭ تالانت ئالتۇن»\bd* ــ ئاز دېگەندە 3000 توننا ئالتۇن. \bd «مىڭ مىڭ تالانت»\bd* ــ ئاز دېگەندە 30000 توننا كۈمۈش.\f*
\v 15 بۇنىڭدىن باشقا سېنىڭدە يەنە تاش كەسكۈچى، تامچى، ياغاچچى ھەم ھەرخىل خىزمەتلەرنى قىلالايدىغان نۇرغۇن ئۇستىلار بار؛
\v 16 ئالتۇن-كۈمۈش، مىس، تۆمۈر بولسا سان-ساناقسىز؛ سەن ئىشقا تۇتۇشۇشقا ئورنۇڭدىن تۇر، پەرۋەردىگارىم سېنىڭ بىلەن بىللە بولغاي!» \f ◼ \fr 22:16 \ft \bd «ئالتۇن-كۈمۈش، مىس، تۆمۈر بولسا سان-ساناقسىز»\bd* ــ ياكى «زەرگەر، مىسكەر، تۆمۈرچىلەر بولسا ساناقسىزدۇر».\f*
\b
\s1 داۋۇت ئەمەلدارلارغا سۇلايماننىڭ ئۆي سېلىشىغا ياردەملىشىشنى ۋەسىيەت قىلىدۇ
\m 
\v 17 داۋۇت يەنە ئىسرائىلدىكى ئەمەلدارلارغا ئوغلى سۇلايمانغا ياردەم بېرىشنى تاپىلاپ:
\v 18 «خۇدايىڭلار بولغان پەرۋەردىگار سىلەر بىلەن بىللە ئەمەسمۇ؟ ھەر ئەتراپىڭلاردا سىلەرگە تىنچ-ئاراملىق بەرگەن ئەمەسمۇ؟ چۈنكى ئۇ بۇ زېمىندىكى ئاھالىنى قولۇمغا تاپشۇردى؛ زېمىن پەرۋەردىگارنىڭ ئالدىدا ۋە خەلقىنىڭ ئالدىدا تىزگىنلەندى.
\v 19 ئەمدى سىلەر پۈتۈن قەلبىڭلار، پۈتۈن جېنىڭلار بىلەن قەتئىي نىيەتكە كېلىپ، خۇدايىڭلار بولغان پەرۋەردىگارنى ئىزلەڭلار؛ پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى ۋە خۇدانىڭ مۇقەددەسخانىسىدىكى قاچا-ئەسۋابلىرىنى ئۇنىڭ نامىغا ئاتاپ سېلىنغان ئۆيىگە ئاپىرىپ قويۇش ئۈچۈن، پەرۋەردىگار خۇدانىڭ مۇقەددەسخانىسىنى سېلىشقا ئورنۇڭلاردىن قوپۇڭلار!» دېدى. \f ◼ \fr 22:19 \ft \bd «ئەمدى سىلەر پۈتۈن قەلبىڭلار، پۈتۈن جېنىڭلار بىلەن قەتئىي نىيەتكە كېلىپ، خۇدايىڭلار بولغان پەرۋەردىگارنى ئىزلەڭلار»\bd* ــ ئىبرانىي تىلىدا «ئەمدى پەرۋەردىگار خۇدايىڭلارنى ئىزلەشكە جان-دىلىڭلارنى چىڭ قىلىڭلار» دېگەن بىلەن ئىپادىلىنىدۇ.\f*
\b
\b
\c 23
\s1 لاۋىيلارنىڭ ۋەزىپىسى ۋە گۇرۇپپىلىنىشى
\m 
\v 1 داۋۇت قېرىپ كۈنلىرى توشاي دەپ قالغاندا، ئوغلى سۇلايماننى ئىسرائىل ئۈستىگە پادىشاھ قىلىپ تىكلىدى.
\v 2 داۋۇت ئىسرائىلدىكى ئەمەلدارلارنى، كاھىنلارنى ۋە لاۋىيلارنى يىغدى.
\v 3 لاۋىيلاردىن ئوتتۇز ياشتىن ئاشقانلارنىڭ ھەممىسى ساناقتىن ئۆتكۈزۈلدى؛ تىزىملانغىنى بويىچە، ئۇلاردىن ئەرلەر جەمئىي ئوتتۇز سەككىز مىڭ كىشى ئىدى.
\v 4 داۋۇت: «بۇلارنىڭ ئىچىدە يىگىرمە تۆت مىڭ كىشى پەرۋەردىگارنىڭ ئۆيىنى باشقۇرۇش خىزمىتىگە، ئالتە مىڭ كىشى ئەمەلدار ۋە سوتچىلىققا،
\v 5 تۆت مىڭ كىشى دەرۋازىۋەنلىككە ۋە يەنە تۆت مىڭ كىشى مەن ياسىغان سازلار بىلەن پەرۋەردىگارغا ھەمدۇسانا ئوقۇش ئىشىغا قويۇلسۇن» ــ دېدى.
\v 6 داۋۇت ئۇلارنى لاۋىينىڭ ئوغلى گەرشون، كوھات ۋە مەرارى جەمەتلىرى بويىچە گۇرۇپپىلارغا بۆلدى: ــ
\m 
\v 7 گەرشونىيلاردىن لادان بىلەن شىمەي بار ئىدى؛
\v 8 لاداننىڭ ئوغلى: تۇنجى ئوغلى يەھىيەل، يەنە زىتام بىلەن يوئېلدىن ئىبارەت ئۈچ كىشى ئىدى؛
\v 9 شىمەينىڭ ئوغلىدىن شېلومىت، ھازىيەل ۋە ھاراندىن ئىبارەت ئۈچ كىشى ئىدى؛ يۇقىرىقىلار لاداننىڭ جەمەت باشلىقلىرى ئىدى.
\v 10 شىمەينىڭ ئوغۇللىرى جاھات، زىنا، يەئۇش ۋە بېرىياھ، بۇ تۆتەيلەننىڭ ھەممىسى شىمەينىڭ ئوغلى ئىدى. \f ◼ \fr 23:10 \ft \bd «زىنا»\bd* ــ 11-ئايەتتە «زىزا».\f*
\v 11 جاھات تۇنجى ئوغۇل، زىزا ئىككىنچى ئوغۇل ئىدى؛ يەئۇش بىلەن بېرىياھنىڭ ئەۋلادلىرى كۆپ بولمىغاچقا، بىر \add جەمەت گۇرۇپپىسى\add* دەپ ھېسابلانغان.
\v 12 كوھاتنىڭ ئوغۇللىرى ئامرام، يىزھار، ھېبرون ۋە ئۇززىيەلدىن ئىبارەت تۆت كىشى ئىدى.
\m 
\v 13 ئامرامنىڭ ئوغلى ھارۇن بىلەن مۇسا ئىدى. ھارۇن بىلەن ئۇنىڭ ئەۋلادلىرى ئەڭ مۇقەددەس بۇيۇملارنى پاكلاش، پەرۋەردىگارنىڭ ئالدىدا مەڭگۈگە \add قۇربانلىقلارنى\add* سۇنۇش، ئۇنىڭ خىزمىتىنى قىلىش، مەڭگۈ ئۇنىڭ نامىدىن بەخت تىلەپ دۇئا بېرىشكە ئايرىلغانىدى. \f ◼ \fr 23:13 \ft \bd «قۇربانلىقلارنى سۇنۇش»\bd* ــ ياكى «خۇشبۇي يېقىش».\f*
\v 14 خۇدانىڭ ئادىمى مۇساغا كەلسەك، ئۇنىڭ ئەۋلادلىرى لاۋىي قەبىلىسىدىن دەپ ھېسابلىنىپ پۈتۈلگەن.
\v 15 مۇسانىڭ ئوغلى گەرشوم بىلەن ئەلىئېزەر ئىدى.
\v 16 گەرشومنىڭ ئوغۇللىرىدىن شەبۇيەل چوڭ ئوغلى ئىدى.
\v 17 ئەلىئېزەرنىڭ ئوغلى رەھابىيا ئىدى؛ ئەلىئېزەرنىڭ باشقا ئوغلى بولمىغان، لېكىن رەھابىيانىڭ ئوغۇللىرى ناھايىتى كۆپ ئىدى. \f ◼ \fr 23:17 \ft \bd «ئەلىئېزەرنىڭ ئوغلى»\bd* ــ ئىبرانىي تىلىدا «ئەلىئېزەرنىڭ ئوغۇللىرى».\f*
\v 18 يىزھارنىڭ تۇنجى ئوغلى شېلومىت ئىدى.
\v 19 ھېبروننىڭ ئوغۇللىرى: تۇنجى ئوغلى يېرىيا، ئىككىنچى ئوغلى ئامارىيا، ئۈچىنچى ئوغلى ياھازىيەل، تۆتىنچى ئوغلى جەكامىيام ئىدى.
\v 20 ئۇززىيەلنىڭ ئوغۇللىرى: تۇنجى ئوغلى مىكاھ، ئىككىنچى ئوغلى يىسشىيا ئىدى.
\m 
\v 21 مەرارىنىڭ ئوغلى ماھلى بىلەن مۇشى ئىدى؛ ماھلىنىڭ ئوغلى ئەلىئازار بىلەن كىش ئىدى.
\v 22 ئەلىئازار ئۆلگەندە ئوغلى يوق، قىزلىرىلا بار ئىدى؛ ئۇلارنىڭ تۇغقانلىرى، يەنى كىشنىڭ ئوغۇللىرى ئۇ قىزلارنى ئەمرىگە ئالدى.
\v 23 مۇشىنىڭ ماھلى، ئېدەر ۋە يەرەموت دېگەن ئۈچلا ئوغلى بار ئىدى.
\m 
\v 24 يۇقىرىقىلارنىڭ ھەممىسى لاۋىينىڭ ئەۋلادلىرى بولۇپ، جەمەتلىرى بويىچە، يەنى جەمەت باشلىرى بويىچە يىگىرمە ياشتىن ئاشقان ئەركەكلەر رويخەتكە ئېلىنغان؛ ئۇلار پەرۋەردىگارنىڭ ئۆيىدىكى ۋەزىپىلەرنى ئۆتەشكە ئىسمىلىرى بويىچە تىزىملانغانىدى.
\m 
\v 25 چۈنكى داۋۇت: «ئىسرائىلنىڭ خۇداسى پەرۋەردىگار ئۆز خەلقىگە ئارام بېرىپ، ئۆزى مەڭگۈ يېرۇسالېمدا ماكان قىلىدۇ؛
\v 26 شۇنىڭ بىلەن لاۋىيلارنىڭ مۇقەددەس چېدىرنى ۋە ئۇنىڭ ئىچىدىكى ھەرقايسى قاچا-ئەسۋابلارنى كۆتۈرۈپ يۈرۈشنىڭ ھاجىتى يوق» دېگەنىدى.
\v 27 شۇڭا داۋۇتنىڭ جان ئۈزۈش ئالدىدىكى ۋەسىيىتى بويىچە، لاۋىيلارنىڭ يىگىرمە ياشتىن يۇقىرىلىرىنىڭ ھەممىسى ساناقتىن ئۆتكۈزۈلگەنىدى.
\v 28 ئۇلارنىڭ ۋەزىپىسى بولسا ھارۇننىڭ ئەۋلادلىرىنىڭ يېنىدا تۇرۇپ، پەرۋەردىگارنىڭ ئۆيىنىڭ ئىشلىرىنى قىلىش ئىدى؛ ئۇلار ھويلا-ئاراملارنى باشقۇرۇش، بارلىق مۇقەددەس بۇيۇملارنى پاكىز تۇتۇش، قىسقىسى، پەرۋەردىگارنىڭ ئۆيىنىڭ خىزمەت ۋەزىپىلىرىنى بېجىرىشكە مەسئۇل ئىدى؛
\v 29 يەنە «تىزىلغان تەقدىم نان»، ئاش ھەدىيە ئۇنلىرى، پېتىر قوتۇرماچلار، قازان نانلىرى ۋە مايلىق نانلارغا، شۇنداقلا ھەرخىل ئۆلچەش ئەسۋابلىرىغا مەسئۇل ئىدى؛
\v 30 ئۇلار يەنە ھەركۈنى ئەتىگەندە ئۆرە تۇرۇپ پەرۋەردىگارغا تەشەككۈر ئېيتىپ ھەمدۇسانا ئوقۇيتتى، ھەركۈنى كەچلىكىمۇ شۇنداق قىلاتتى.
\v 31 يەنە شابات كۈنى، ھەر يېڭى ئايدا، شۇنىڭدەك بېكىتىلگەن ھېيت-بايراملاردا سۇنۇلىدىغان بارلىق كۆيدۈرمە قۇربانلىقلارغا مەسئۇل ئىدى. ئۆزلىرىگە قارىتىلغان بەلگىلىمە بويىچە، ئۇلار دائىم پەرۋەردىگارنىڭ ئالدىغا بېكىتىلىگەن سانى ۋە نۆۋىتى بىلەن خىزمەتتە تۇراتتى. \f ◼ \fr 23:31 \ft \bd «يەنە شابات كۈنى، ھەر يېڭى ئايدا، شۇنىڭدەك بېكىتىلگەن ھېيت-بايراملاردا سۇنۇلىدىغان بارلىق كۆيدۈرمە قۇربانلىقلارغا مەسئۇل ئىدى»\bd* ــ لاۋىيلار ئۆزلىرى قۇربانلىقلارنى سۇنمايتتى، بىراق ئۇلارنى تەييارلاشقا مەسئۇل ئىدى.\f*
\v 32 ئۇلار جامائەت چېدىرىنى ھەم مۇقەددەس جاينى باقاتتى، شۇنداقلا ئۆزلىرىنىڭ پەرۋەردىگارنىڭ ئۆيىدىكى خىزمەتتە بولۇۋاتقان قېرىنداشلىرى، يەنى ھارۇننىڭ ئەۋلادلىرىغا قارايتتى.
\b
\b
\c 24
\s1 داۋۇت كاھىنلارنى نۆۋەت-گۇرۇپپىلارغا بۆلىدۇ
\m 
\v 1 ھارۇن ئەۋلادلىرىنىڭ نۆۋەتچىلىككە بۆلۈنۈشى تۆۋەندىكىچە: ھارۇننىڭ ئوغلى ناداب، ئابىھۇ، ئەلىئازار ۋە ئىتامار.
\v 2 ناداب بىلەن ئابىھۇ ئاتىسىدىن بۇرۇن ئۆلۈپ كەتكەن ھەم پەرزەنت كۆرمىگەنىدى؛ شۇڭا ئەلىئازار بىلەن ئىتامار كاھىنلىقنى تۇتاتتى.
\v 3 داۋۇت ۋە ئەلىئازارنىڭ ئەۋلادلىرىدىن زادوك ۋە ئىتامارنىڭ ئەۋلادلىرىدىن ئاخىمەلەك ئۇلارنىڭ قېرىنداشلىرىنى گۇرۇپپىلارغا بۆلۈپ، ۋەزىپىسى بويىچە ئىشقا قويدى؛
\v 4 ئەلىئازارنىڭ ئەۋلادلىرىدىن جەمەت بېشى بولغانلار ئىتامارنىڭ ئەۋلادلىرىدىن جەمەت بېشى بولغانلاردىن كۆپ ئىكەنلىكىنى بىلىپ، ئۇلارنى شۇنىڭغا ئاساسەن ئايرىپ نۆۋەت-گۇرۇپپىلارغا بۆلدى. ئەلىئازارنىڭ ئەۋلادلىرىدىن جەمەت بېشى بولغانلار ئون ئالتە كىشى ئىدى، ئىتامارنىڭ ئەۋلادلىرىدىن جەمەت بېشى بولغانلار سەككىز كىشى ئىدى؛
\v 5 ئۇلار چەك تاشلاش يولى بىلەن تەڭشەپ نۆۋەت-گۇرۇپپىلارغا بۆلۈندى. شۇنداق قىلىپ مۇقەددەسخانىدىكى ئىشلارغا مەسئۇل بولغانلار ۋە خۇدانىڭ ئالدىدىكى ئىشلارغا مەسئۇل بولغانلار ھەم ئەلىئازارنىڭ ئەۋلادلىرىدىنمۇ ھەم ئىتامارنىڭ ئەۋلادلىرىدىنمۇ بولدى. \f ◼ \fr 24:5 \ft \bd «مۇقەددەسخانىدىكى ئىشلارغا مەسئۇل بولغانلار»\bd* ــ بەلكىم ئىبادەتخانىدىكى ئىشلارنى كۆرسىتىدۇ؛ «خۇدانىڭ ئالدىدىكى ئىشلارغا مەسئۇل بولغانلار» بولسا بەلكىم سوت-سوراق ئىشلىرىغا مەسئۇل ئىدى. ئەلىئازار ۋە ئىتامار دېگەن ئىككى جەمەتتىن ئىككى خىل ۋەزىپىنى ئۈستىگە ئالغانلار بار ئىدى.\f*
\v 6 لاۋىي نەتانەلنىڭ ئوغلى شېمايا كاتىپ بولسا پادىشاھ، ئەمەلدارلار، كاھىن زادوك، ئابىياتارنىڭ ئوغلى ئاخىمەلەك، شۇنداقلا كاھىنلارنىڭ ۋە لاۋىيلارنىڭ جەمەت باشلىقلىرى ئالدىدا ئۇلارنىڭ ئىسمىنى پۈتۈپ قويدى. ئەلىئازارنىڭ ئەۋلادلىرى ئىچىدىن بىر جەمەت تاللاندى، ئاندىن ئىتامارنىڭ ئەۋلادلىرى ئىچىدىنمۇ بىر جەمەت تاللاندى.
\m 
\v 7 بىرىنچى چەك يەھويارىبقا، ئىككىنچى چەك يەداياغا،
\v 8 ئۈچىنچى چەك ھارىمغا، تۆتىنچى چەك سېئورىمغا،
\v 9 بەشىنچى چەك مالكىياغا، ئالتىنچى چەك مىيامىنغا،
\v 10 يەتتىنچى چەك ھاككوزغا، سەككىزىنچى چەك ئابىياغا،
\v 11 توققۇزىنچى چەك يەشۇئاغا، ئونىنچى چەك شېكانىياغا،
\v 12 ئون بىرىنچى چەك ئەلىياشىبقا، ئون ئىككىنچى چەك ياكىمغا،
\v 13 ئون ئۈچىنچى چەك ھۇپپاغا، ئون تۆتىنچى چەك يەشەبىئابقا،
\v 14 ئون بەشىنچى چەك بىلگاھقا، ئون ئالتىنچى چەك ئىممەرگە،
\v 15 ئون يەتتىنچى چەك ھېزىرغا، ئون سەككىزىنچى چەك ھاپپىزەزگە،
\v 16 ئون توققۇزىنچى چەك پىتاھىياغا، يىگىرمىنچى چەك يەھەزكەلگە، \f ◼ \fr 24:16 \ft \bd «يەھەزكەل»\bd* ــ ئەزاكىيال دېگەن ئىسمىنىڭ باشقا بىر شەكلى.\f*
\v 17 يىگىرمە بىرىنچى چەك ياقىنغا، يىگىرمە ئىككىنچى چەك گامۇلغا،
\v 18 يىگىرمە ئۈچىنچى چەك دېلاياغا، يىگىرمە تۆتىنچى چەك مائازىياغا چىقتى.
\v 19 مانا بۇ ئۇلارنىڭ خىزمەت تەرتىپى؛ بۇ ئىسرائىلنىڭ خۇداسى پەرۋەردىگار ئۇلارنىڭ ئاتىسى ھارۇننىڭ ۋاستىسى بىلەن بۇيرۇغان نىزام بويىچە، پەرۋەردىگارنىڭ ئۆيىگە كىرىش نۆۋىتى ئىدى.
\b
\s1 لاۋىينىڭ باشقا ئەۋلادلىرىنىڭ ۋەزىپىسى
\m 
\v 20 لاۋىينىڭ قالغان ئەۋلادلىرى مۇنۇلار: ئامرامنىڭ ئەۋلادلىرىدىن شۇبايەل؛ شۇبايەلنىڭ ئەۋلادلىرى ئىچىدە يەھدېيا بار ئىدى.
\v 21 رەھابىياغا كەلسەك، ئۇنىڭ ئوغۇللىرى، جۈملىدىن تۇنجى ئوغلى يىسشىيا بار ئىدى.
\v 22 يىزھارنىڭ ئوغۇللىرى ئىچىدە شېلوموت؛ شېلوموتنىڭ ئوغۇللىرى ئىچىدە جاھات بار ئىدى.
\v 23 ھېبروننىڭ ئوغۇللىرى: تۇنجى ئوغلى يەرىيا، ئىككىنچىسى ئامارىيا، ئۈچىنچىسى ياھازىيەل، تۆتىنچىسى جەكامىيام ئىدى. \f ◼ \fr 24:23 \ft \bd «ھېبروننىڭ ئوغۇللىرى»\bd* ــ بەزى كونا كۆچۈرمىلەردە پەقەت «ئۇنىڭ ئوغۇللىرى» دېيىلىدۇ. لېكىن 19:23نى كۆرۈڭ.\f*
\v 24 ئۇززىيەلنىڭ ئوغۇللىرى: مىكاھ؛ مىكاھنىڭ ئوغۇللىرىدىن شامىر بار ئىدى.
\v 25 مىكاھنىڭ ئىنىسى يىسشىيا ئىدى؛ يىسشىيانىڭ ئوغۇللىرى ئىچىدە زەكەرىيا بار ئىدى.
\v 26 مەرارىنىڭ ئوغۇللىرى: ماھلى ۋە مۇشى؛ يائازىيانىڭ ئوغلى بېنو ئىدى. \f ◼ \fr 24:26 \ft \bd «مەرارىنىڭ ئوغۇللىرى: ماھلى ۋە مۇشى؛ يائازىيانىڭ ئوغلى بېنو ئىدى»\bd* ــ بۇ ئايەتنىڭ باشقا بىرنەچچە خىل تەرجىمىلىرى بار.\f*
\v 27 مەرارىنىڭ ئوغلى يائازىيادىن بولغان ئەۋلادلىرى بېنو، شوھام، زاككۇر ۋە ئىبرى بار ئىدى.
\v 28 ماھلىنىڭ ئوغلى ئەلىئازار ئىدى؛ ئەلىئازارنىڭ ئوغلى يوق ئىدى.
\v 29 كىشكە كەلسەك، ئۇنىڭ ئوغۇللىرى ئىچىدە يەراھمىيەل بار ئىدى.
\v 30 مۇشىنىڭ ئوغۇللىرى ماھلى، ئېدەر ۋە يەرىموت ئىدى. يۇقىرىقىلارنىڭ ھەممىسى لاۋىينىڭ ئەۋلادلىرى بولۇپ، جەمەتلىرى بويىچە پۈتۈلگەنىدى.
\v 31 ئۇلارمۇ ئۇلارنىڭ قېرىنداشلىرى ھارۇننىڭ ئەۋلادلىرىغا ئوخشاش، داۋۇت پادىشاھ، زادوك، ئاخىمەلەك ۋە شۇنىڭدەك كاھىنلار ۋە لاۋىيلارنىڭ جەمەت باشلىقلىرىنىڭ ئالدىدا چەك تارتتى؛ ھەرقايسى جەمەت باشلىرى ۋە ئۇلارنىڭ تۇغقانلىرىدىن ئەڭ كىچىكلىرىمۇ ئوخشاشلا چەك تارتتى. \f ◼ \fr 24:31 \ft \bd «ئۇلارمۇ ئۇلارنىڭ قېرىنداشلىرى ھارۇننىڭ ئەۋلادلىرىغا ئوخشاش، ... ھەرقايسى جەمەت باشلىرى ۋە ئۇلارنىڭ تۇغقانلىرىدىن ئەڭ كىچىكلىرىمۇ ئوخشاشلا چەك تارتتى»\bd* ــ مۇشۇ قالغان لاۋىيلارنىڭ نېمە ۋەزىپىلىرى بارلىقى مۇشۇ يەردە ئېنىق ئېيتىلمايدۇ.\f*
\b
\b
\c 25
\s1 داۋۇت نەغمىچىلەرنى تەشكىل قىلىدۇ
\m 
\v 1 داۋۇت بىلەن قوشۇننىڭ سەردارلىرى ئاساف، ھېمان ۋە يەدۇتۇنلارنىڭ ئوغۇللىرىغىمۇ ۋەزىپە يۈكلەپ، ئۇلارنى چىلتار، تەمبۇر ۋە جاڭ-جاڭلار چېلىپ، بېشارەت بېرىش خىزمىتىگە قويدى. ئۇلاردىن ۋەزىپىگە قويۇلغانلارنىڭ سانى تۆۋەندىكىچە:
\v 2 ئاسافنىڭ ئوغۇللىرىدىن زاككۇر، يۈسۈپ، نىتانىيا ۋە ئاشارىلاھ بار ئىدى؛ ئاسافنىڭ ئوغۇللىرىنىڭ ھەممىسى ئاسافنىڭ كۆرسەتمىسىگە قارايتتى؛ ئاساف پادىشاھنىڭ كۆرسەتمىسى بويىچە بېشارەت بېرىپ سۆزلەيتتى.
\m 
\v 3 يەدۇتۇنغا كەلگەندە، ئۇنىڭ گەدالىيا، زېرى، يەشايا، شىمەي، ھاشابىيا ۋە ماتتىتىياھ دېگەن ئالتە ئوغلى بولۇپ، ئاتىسى يەدۇتۇننىڭ كۆرسەتمىسىگە قارايتتى. يەدۇتۇن پەرۋەردىگارغا تەشەككۈر ئېيتىپ مەدھىيە ئوقۇش ئۈچۈن چىلتار چېلىپ بېشارەت بېرەتتى. \f ◼ \fr 25:3 \ft \bd «گەدالىيا، زېرى، يەشايا، شىمەي، ھاشابىيا ۋە ماتتىتىياھ»\bd* ــ بەزى كونا كۆچۈرمىلەردە «شىمەي» دېگەن ئىسىم يوقاپ كەتكەن.\f*
\m 
\v 4 ھېماننىڭ بولسا، ئۇنىڭ بۇككىيا، ماتتانىيا، ئۇززىيەل، شەبۇيەل، يەرىموت، ھانانىيا، ھانانى، ئەلىياتا، گىددالتى ۋە رومامتى-ئېزەر، يوشبىكاشا، ماللوتى، ھوتىر ۋە ماخازىئوت دېگەن ئوغۇللىرى بار ئىدى.
\v 5 بۇلارنىڭ ھەممىسى ھېماننىڭ ئوغۇللىرى بولۇپ، خۇداغا بولغان مەدھىيىسىنى ياڭرىتىش ئۈچۈن قويۇلغان (ھېمان بولسا پادىشاھقا خۇدانىڭ سۆز-كالامىنى يەتكۈزىدىغان ئالدىن كۆرگۈچى ئىدى)؛ خۇدا ھېمانغا ئون تۆت ئوغۇل، ئۈچ قىز ئاتا قىلغانىدى. \f ◼ \fr 25:5 \ft \bd «خۇداغا بولغان مەدھىيىسىنى ياڭرىتىش»\bd* ــ ئىبرانىي تىلىدا «مۈڭگۈزنى (ياكى بۇرغىنى) كۆتۈرۈش» دېگەن سۆزلەر بىلەن ئىپادىلىنىدۇ. مۈڭگۈز بولسا ئادەمنىڭ (ياكى خۇدانىڭ) ئۇلۇغلۇقىنى كۆرسىتىدۇ. \bd «خۇدا ھېمانغا ئون تۆت ئوغۇل، ئۈچ قىز ئاتا قىلغانىدى»\bd* ــ ھېماننىڭ قىزلىرىمۇ بۇ مەدھىيە خىزمىتىدە ئىدى.\fp تولۇق ئايەتنىڭ باشقا بىرخىل تەرجىمىسى: «بۇلارنىڭ ھەممىسى ھېماننىڭ ئوغۇللىرى بولۇپ، خۇدانىڭ ھېمانغا بولغان سۆز-كالامى بويىچە ئۇنىڭ ئىززەت-ھۆرمىتىنى كۆتۈرۈش ئۈچۈن ئۇنىڭغا بېرىلگەنىدى (ھېمان بولسا پادىشاھنىڭ ئالدىن كۆرگۈچىسى ئىدى)؛ خۇدا ھېمانغا ئون تۆت ئوغۇل، ئۈچ قىز ئاتا قىلغانىدى».\f*
\v 6 بۇلارنىڭ ھەممىسى ئاتىلىرىنىڭ باشلامچىلىقىدا بولۇپ، پەرۋەردىگارنىڭ ئۆيىدە نەغمە-ناۋا قىلىش ئۈچۈن، جاڭ-جاڭ، تەمبۇر ۋە چىلتار چېلىپ خۇدانىڭ ئۆيىدىكى ۋەزىپىسىنى ئۆتەيتتى. ئاساف، يەدۇتۇن ۋە ھېمان \add بۇ ئىشلاردا\add* پادىشاھنىڭ كۆرسەتمىسىگە قارايتتى. \f ◼ \fr 25:6 \ft \bd «بۇلارنىڭ ھەممىسى ئاتىلىرىنىڭ باشلامچىلىقىدا بولۇپ، ...»\bd* ــ \bd «ئاتىلىرى»\bd* ئاساف، يەدۇتۇن ۋە ھېماندىن ئىبارەت. ئاساف ۋە ھېمانلار ھەربىرى زەبۇردىكى نەچچە كۈيلەرنى يازغان (مەسىلەن 50-، 73-82-كۈي، 88-كۈي. يەدۇتۇن 39-، 62- ۋە 77-كۈيدە تىلغا ئېلىنىدۇ).\f*
\v 7 ئۇلار ۋە ئۇلارنىڭ قېرىنداشلىرىنىڭ سانى جەمئىي ئىككى يۈز سەكسەن سەككىز ئىدى (ئۇلار ھەممىسى پەرۋەردىگارنى مەدھىيىلەش نەغمە-ناۋالىقىدا ئالاھىدە تەربىيە كۆرگەن، كۈي ئېيتىشقا ئۇستا ئىدى).
\v 8 بۇلار چوڭ-كىچىكىگە، ئۇستاز-شاگىرتلىقىغا قارىماي ھەممىسى بىردەك چەك تارتىپ گۇرۇپپىلارغا بۆلۈنگەنىدى.
\b
\s1 يىگىرمە تۆت مەدھىيىلەش گۇرۇپپىسى
\m 
\v 9 بىرىنچى چەك ئاسافنىڭ ئوغلى يۈسۈپكە، ئىككىنچى چەك گەدالىياغا چىقتى؛ ئۇ، ئۇنىڭ ئىنىلىرى ۋە ئوغۇللىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛ \f ◼ \fr 25:9 \ft \bd «ئۇنىڭ ئىنىلىرى»\bd* ــ ياكى «ئۇنىڭ قېرىنداشلىرى». 10-18-ئايەتلەردىكى «ئىنىلىرى»مۇ شۇنداق.\f*
\v 10 ئۈچىنچى چەك زاككۇرغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 11 تۆتىنچى چەك ئىزرىغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛ \f ◼ \fr 25:11 \ft \bd «ئىزرى»\bd* ــ ياكى «زېرى» (3:25نى كۆرۈڭ).\f*
\v 12 بەشىنچى چەك نەتانىياغا چىقتى؛ ئۇ ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 13 ئالتىنچى چەك بۇككىياغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ ئون ئىككى كىشى ئىدى؛
\v 14 يەتتىنچى چەك يەشارىلاھقا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛ \f ◼ \fr 25:14 \ft \bd «يەشارىلاھ»\bd* ــ ياكى «ئاشارىلاھ» (2:25نى كۆرۈڭ).\f*
\v 15 سەككىزىنچى چەك يەشاياغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 16 توققۇزىنچى چەك ماتتانىياغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 17 ئونىنچى چەك شىمەيگە چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 18 ئون بىرىنچى چەك ئازارەلگە چىقتى؛ ئۇ ۋە ئۇنىڭ ئوغۇللىرى، ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛ \f ◼ \fr 25:18 \ft \bd «ئازارەل»\bd* ــ ياكى «ئۇززىيەل» (4:25نى كۆرۈڭ).\f*
\v 19 ئون ئىككىنچى چەك ھاشابىياغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 20 ئون ئۈچىنچى چەك شۇبايەلگە چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 21 ئون تۆتىنچى چەك ماتتىتىياھقا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 22 ئون بەشىنچى چەك يەرىموتقا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 23 ئون ئالتىنچى چەك ھانانىياغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 24 ئون يەتتىنچى چەك يوشبىكاشاغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 25 ئون سەككىزىنچى چەك ھانانىغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 26 ئون توققۇزىنچى چەك ماللوتىغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 27 يىگىرمىنچى چەك ئەلىياتاغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 28 يىگىرمە بىرىنچى چەك ھوتىرغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 29 يىگىرمە ئىككىنچى چەك گىددالتىغا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 30 يىگىرمە ئۈچىنچى چەك ماخازىئوتقا چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى؛
\v 31 يىگىرمە تۆتىنچى چەك رومامتى-ئېزەرگە چىقتى؛ ئۇ، ئۇنىڭ ئوغۇللىرى ۋە ئىنىلىرى بولۇپ جەمئىي ئون ئىككى كىشى ئىدى.
\b
\b
\c 26
\s1 دەرۋازىۋەنلەرنىڭ گۇرۇپپىلىنىشى
\m 
\v 1 دەرۋازىۋەنلەرنىڭ گۇرۇپپىلىنىشى تۆۋەندىكىدەك بولدى: كوراھ جەمەتىدىكىلەردىن ئاسافنىڭ ئەۋلادلىرى ئىچىدە كورەنىڭ ئوغلى مەشەلەمىيا بار ئىدى.
\v 2 مەشەلەمىيانىڭ بىرنەچچە ئوغلى بولۇپ، تۇنجىسى زەكەرىيا، ئىككىنچىسى يەدىيايەل، ئۈچىنچىسى زەبادىيا، تۆتىنچىسى ياتنىيەل،
\v 3 بەشىنچىسى ئېلام، ئالتىنچىسى يەھوھانان، يەتتىنچىسى ئەليويىناي ئىدى.
\v 4 ئوبەد-ئېدومنىڭ ئوغۇللىرى: تۇنجى ئوغلى شېمايا، ئىككىنچىسى يەھوزاباد، ئۈچىنچىسى يوئاھ، تۆتىنچىسى ساكار، بەشىنچىسى نەتانەل،
\v 5 ئالتىنچىسى ئاممىيەل، يەتتىنچىسى ئىسساكار، سەككىزىنچىسى پېئۇلتاي؛ دەرۋەقە خۇدا ئوبەد-ئېدومغا بەخت-سائادەت ئاتا قىلغانىدى.
\v 6 ئۇنىڭ ئوغلى شېمايامۇ بىرنەچچە ئوغۇل پەرزەنت كۆرگەن بولۇپ، ھەممىسى ئاتا جەمەتى ئىچىدە يولباشچى ئىدى، چۈنكى ئۇلار باتۇر ئەزىمەتلەر ئىدى. \f ◼ \fr 26:6 \ft \bd «ئۇلار باتۇر ئەزىمەتلەر ئىدى»\bd* ــ ياكى «ئۇلار باتۇر مۆتىۋەرلەر ئىدى».\f*
\v 7 شېمايانىڭ ئوغۇللىرى: ئوتنى، رېفايەل، ئوبەد ۋە ئەلزاباد ئىدى. ئەلزابادنىڭ ئىنىلىرى ئېلىخۇ بىلەن سەماكىيانىڭ ئىككىسى باتۇر ئىدى.
\v 8 بۇلارنىڭ ھەممىسى ئوبەد-ئېدومنىڭ ئەۋلادلىرى بولۇپ، ئۇلار ۋە ئۇلارنىڭ ئوغۇللىرى، قېرىنداشلىرىنىڭ ھەممىسى \add خۇدانىڭ\add* خىزمىتىدە قولىدىن ئىش كېلىدىغان ئادەملەر ئىدى. ئوبەد-ئېدومنىڭ ئەۋلادى جەمئىي ئاتمىش ئىككى ئادەم ئىدى.
\v 9 مەشەلەمىيانىڭ ئوغۇللىرى ۋە قېرىنداشلىرى بار ئىدى؛ ھەممىسى باتۇر بولۇپ، جەمئىي ئون سەككىز ئادەم ئىدى.
\v 10 مەرارىنىڭ ئەۋلادى بولغان خوساھنىڭ بىرنەچچە ئوغلى بار ئىدى، چوڭ ئوغلى شىمرى (شىمرى ئەسلىدە تۇنجى ئوغۇل بولمىسىمۇ، ئاتىسى ئۇنى چوڭ ئوغۇل قىلىپ تىكلىگەن)،
\v 11 ئىككىنچى ئوغلى ھىلقىيا، ئۈچىنچىسى تەبالىيا، تۆتىنچىسى زەكەرىيا ئىدى. خوساھنىڭ ئوغۇللىرى ۋە قېرىنداشلىرى جەمئىي بولۇپ ئون ئۈچ ئادەم ئىدى.
\m 
\v 12 يۇقىرىقىلارنىڭ ھەممىسى جەمەت باشلىرى بويىچە دەرۋازىۋەنلەرنىڭ گۇرۇپپىلارغا بۆلۈنۈشى ئىدى؛ ئۇلارنىڭ ھەممىسىگە قېرىنداشلىرى بىلەن بىللە پەرۋەردىگارنىڭ ئۆيىدىكى خىزمەت ۋەزىپىسى تاپشۇرۇلغانىدى.
\v 13 ئۇلار، مەيلى چوڭ بولسۇن ياكى كىچىك بولسۇن، ئۆز جەمەتى بويىچە چەك تارتىپ ھەربىر دەرۋازىغا بەلگىلەندى.
\v 14 شەرقىي دەرۋازىدا دەرۋازىۋەنلىك قىلىشقا چەك چىققىنى شەلەمىيا بولدى؛ ئاندىن ئۇلار ئۇنىڭ ئوغلى زەكەرىيا (ئاقىلانە مەسلىھەتچى ئىدى) ئۈچۈن چەك تارتتى؛ ئۇنىڭغا شىمالىي دەرۋازىنىڭ دەرۋازىۋەنلىك چېكى چىقتى.
\v 15 جەنۇبىي دەرۋازىنىڭ چېكى ئوبەد-ئېدومغا چىقتى. ئۇنىڭ ئوغۇللىرى ئامبار-خەزىنىلەرگە مەسئۇل بولدى.
\v 16 شۇپپىم بىلەن خوساھقا غەربىي دەرۋازىنىڭ ۋە شۇنىڭدەك داۋان يولىدىكى شاللەكەت دەرۋازىسىنىڭ چېكى چىقتى؛ دەرۋازىۋەنلەر ياندىشىپ تۇراتتى. \f ◼ \fr 26:16 \ft \bd «دەرۋازىۋەنلەر ياندىشىپ تۇراتتى»\bd* ــ ياكى «دەرۋازىۋەنلەر ئۇدۇلمۇئۇدۇل تۇراتتى».\f*
\v 17 شەرقىي دەرۋازىغا ھەركۈنى ئالتە لاۋىي دەرۋازىۋەن مەسئۇل ئىدى؛ شىمالىي دەرۋازىغا ھەركۈنى تۆت ئادەم، جەنۇبىي دەرۋازىغا ھەركۈنى تۆت ئادەم مەسئۇل ئىدى؛ ئامبار-خەزىنىلەرنىڭ ھەربىرىگە ئىككى ئادەم بىر گۇرۇپپا بولۇپ قارايتتى.
\v 18 غەرب تەرەپتىكى دەھلىزنىڭ ئالدىدىكى يولدا تۆت كىشى، دەھلىزنىڭ ئۆزىدە ئىككى كىشى پاسىبانلىق قىلاتتى.
\v 19 يوقۇرىدىكى كىشىلەر دەرۋازىۋەنلەرنىڭ گۇرۇپپىلىنىشى بولۇپ، كوراھنىڭ ۋە مەرارىنىڭ ئەۋلادلىرىدىن ئىدى.
\b
\s1 مۇقەددەس ئۆينىڭ خەزىنىسىنى باشقۇرىدىغان لاۋىيلار
\m 
\v 20 ئۇلارنىڭ \add باشقا\add* لاۋىي قېرىنداشلىرىدىن خۇدانىڭ ئۆيىدىكى خەزىنىلەرنى ۋە مۇقەددەس دەپ بېغىشلانغان بۇيۇملار خەزىنىسىنى باشقۇرۇشقا ئاخىياھ قويۇلدى. \f ◼ \fr 26:20 \ft \bd «لاۋىي قېرىنداشلىرى»\bd* ــ ياكى «لاۋىيلاردىن بولغان ئاخىياھ».\f*
\v 21 گەرشون جەمەتىدىكى لاداننىڭ ئەۋلادلىرىدىن، گەرشونىي لادان جەمەتىگە يولباشچى بولغىنى: جەھىيەلى ئىدى؛ \f ◼ \fr 26:21 \ft \bd «لادان»\bd* ــ يەنە «لىبنى» دېيىلىدۇ، «جەھىيەلى» يەنە «جەھىيەل» دەپمۇ ئاتىلىدۇ (17:6، 7:23).\f*
\v 22 جەھىيەلىنىڭ ئوغۇللىرى زېتام بىلەن ئۇنىڭ ئىنىسى يوئېل ئىدى؛ ئۇلار پەرۋەردىگارنىڭ ئۆيىدىكى خەزىنىلەرگە مەسئۇل ئىدى.
\m 
\v 23 ئامرام جەمەتى، يىزھار جەمەتى، ھېبرون جەمەتى ۋە ئۇززىيەل جەمەتىدىكىلەرمۇ \add ۋەزىپىگە قويۇلدى\add*:
\v 24 مۇسانىڭ نەۋرىسى، گەرشومنىڭ ئوغلى شىبۇئەل باش خەزىنىچى بولدى.
\v 25 ئۇنىڭ ئەلىئېزەردىن بولغان قېرىنداشلىرى: ئەلىئېزەرنىڭ ئوغلى رەھابىيا، رەھابىيانىڭ ئوغلى يەشايا، يەشايانىڭ ئوغلى يورام، يورامنىڭ ئوغلى زىكرى، زىكرىنىڭ ئوغلى شېلومىت ئىدى.
\v 26 مۇشۇ شېلومىت بىلەن ئۇنىڭ قېرىنداشلىرى مۇقەددەس دەپ بېغىشلانغان بۇيۇملار ساقلىنىدىغان بارلىق خەزىنىلەرنى باشقۇراتتى؛ بۇ بۇيۇملارنى ئەسلىدە داۋۇت پادىشاھ، جەمەت باشلىقلىرى، مىڭبېشىلار، يۈزبېشىلار ۋە قوشۇن سەردارلىرى بېغىشلىغانىدى.
\v 27 ئۇلار جەڭگاھلاردا بۇلاڭ-تالاڭ قىلىپ كەلگەن مال-مۈلۈكلەردىن ۋە ئولجىدىن پەرۋەردىگارنىڭ ئۆيىنى پۇختا قىلىشقا بېغىشلىغانىدى. \f ◼ \fr 26:27 \ft \bd «پۇختا قىلىشقا»\bd* ــ ياكى «رېمونت قىلىشقا».\f*
\v 28 \add بۇلارنىڭ ئىچىدىمۇ\add* ئالدىن كۆرگۈچى سامۇئىل، كىشنىڭ ئوغلى سائۇل، نەرنىڭ ئوغلى ئابنەر ۋە زەرۇئىيانىڭ ئوغلى يوئابلار مۇقەددەس دەپ ئايرىغان نەرسىلەر بار ئىدى؛ بارلىق مۇقەددەس دەپ ئايرىلغان نەرسىلەرنى شېلومىت بىلەن ئۇنىڭ قېرىنداشلىرى باشقۇراتتى.
\b
\s1 مەنسەپكە قويۇلغان ۋە ھاكىم بولغان لاۋىيلار
\m 
\v 29 يىزھار جەمەتىدىن كېنانىيا ۋە ئۇنىڭ ئوغۇللىرى \add مۇقەددەس ئۆينىڭ\add* سىرتىدا ئىسرائىلدا مەنسەپدار ۋە سوتچىلار قىلىپ قويۇلدى.
\m 
\v 30 ھېبرون جەمەتىدىن ھاشابىيا ۋە ئۇنىڭ قېرىنداشلىرى، ھەممىسى باتۇر بولۇپ، ئىئوردان دەرياسىنىڭ غەربىي تەرىپىدە ئىسرائىلدا مەنسەپ تۇتۇپ، پەرۋەردىگارنىڭ خىزمىتىگە ۋە پادىشاھنىڭ ئىشلىرىغا مەسئۇل بولۇشقا قويۇلغان. ئۇلار جەمئىي بىرمىڭ يەتتە يۈز كىشى ئىدى.
\v 31 ھېبرون جەمەتى ئىچىدە، جەمەتنىڭ نەسەبنامىسى بويىچە يەرىيا جەمەت بېشى ئىدى. داۋۇتنىڭ سەلتەنىتىنىڭ قىرىقىنچى يىلى \add نەسەبنامىلەرنى\add* تەكشۈرۈش ئارقىلىق گىلېئادنىڭ يائازەر دېگەن يېرىدە بۇ جەمەتتىنمۇ باتۇر ئەزىمەتلەر تېپىلدى.
\v 32 يەرىيانىڭ قېرىنداشلىرىدىن يەنە جەمئىي بولۇپ ئىككى مىڭ يەتتە يۈز كىشى بار ئىدى؛ ئۇلارنىڭ ھەممىسى باتۇر بولۇپ، شۇ جەمەت باشلىرى ئىدى؛ پادىشاھ داۋۇت ئۇلارنى رۇبەن قەبىلىسى، گاد قەبىلىسى ۋە ماناسسەھ يېرىم قەبىلىسىدىكى خۇداغا ۋە پادىشاھنىڭ خىزمىتىگە دائىر بارلىق ئىشلارنى باشقۇرۇشقا قويدى.
\b
\b
\c 27
\s1 ئىسرائىلنىڭ ھەربىي تەشكىلاتى
\m 
\v 1 تۆۋەندىكىلەر ئىسرائىللار ئىچىدە پادىشاھنىڭ خىزمىتىدە ھەربىي قىسىملارغا مەسئۇل بولغان ھەرقايسى جەمەت باشلىرى، مىڭبېشى، يۈزبېشى ۋە بارلىق مەنسەپدارلار ئىدى. ئۇلار سانىغا قاراپ قىسىملارغا بۆلۈنگەنىدى. ئۇلار ھەر يىلى ئاي بويىچە نۆۋەتلىشىپ تۇراتتى، ھەر قىسىمدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى.
\m 
\v 2 بىرىنچى ئايدىكى بىرىنچى نۆۋەتچى قوشۇنغا زابدىيەلنىڭ ئوغلى ياشوبېئام مەسئۇل بولغان، ئۇنىڭ ئاشۇ قىسمىدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى.
\v 3 ئۇ پەرەز ئەۋلادلىرىدىن بولۇپ، بىرىنچى ئايدىكى ئاشۇ قوشۇن قىسمىنىڭ سەردارلىرىنى باشقۇراتتى.
\v 4 ئىككىنچى ئايدىكى نۆۋەتچى قوشۇنغا مەسئۇل كىشى ئاھوھلۇق دوداي بولۇپ، ئۇنىڭ قوشۇنىنىڭ ئورۇنباسار سەردارى مىكلوت بار ئىدى؛ بۇ قىسىمدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى.
\v 5 ئۈچىنچى ئايدىكى ئۈچىنچى نۆۋەتچى قوشۇننىڭ سەردارى كاھىن يەھويادانىڭ ئوغلى بىنايا ئىدى؛ ئۇ ئۇنىڭ ئاشۇ قوشۇنىغا باش بولۇپ، ئۇنىڭدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى.
\v 6 بۇ بىنايا «ئوتتۇز پالۋان»نىڭ بىرى بولۇپ، ئاشۇ ئوتتۇز ئادەمنى باشقۇراتتى؛ ئۇنىڭ قىسمىدا يەنە ئۇنىڭ ئوغلى ئاممىزاباد بار ئىدى.
\v 7 تۆتىنچى ئايدىكى تۆتىنچى نۆۋەتچى قوشۇننىڭ سەردارى يوئابنىڭ ئىنىسى ئاساھەل ئىدى؛ ئۇنىڭدىن كېيىن ئوغلى زەبادىيا ئۇنىڭ ئورنىنى باستى. ئۇنىڭ قىسمىدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى.
\v 8 بەشىنچى ئايدىكى بەشىنچى نۆۋەتچى قوشۇننىڭ سەردارى ئىزراھلىق شامخۇت ئىدى، ئۇنىڭ قىسمىدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى.
\v 9 ئالتىنچى ئايدىكى ئالتىنچى نۆۋەتچى قوشۇننىڭ سەردارى تەكوئالىق ئىككەشنىڭ ئوغلى ئىرا ئىدى، ئۇنىڭ قىسمىدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى.
\v 10 يەتتىنچى ئايدىكى يەتتىنچى نۆۋەتچى قوشۇننىڭ سەردارى ئەفرائىم ئەۋلادلىرى ئىچىدىكى پىلونلۇق ھەلەز بولۇپ، ئۇنىڭ قىسمىدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى.
\v 11 سەككىزىنچى ئايدىكى سەككىزىنچى نۆۋەتچى قوشۇننىڭ سەردارى زەراھ جەمەتىدىكى خۇشاتلىق سىببىكاي بولۇپ، ئۇنىڭ قىسمىدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى. \f ◼ \fr 27:11 \ft \bd «زەراھ»\bd* ــ ياكى «زارھى».\f*
\v 12 توققۇزىنچى ئايدىكى توققۇزىنچى نۆۋەتچى قوشۇننىڭ سەردارى بىنيامىن قەبىلىسىدىكى ئاناتوتلۇق ئابىئېزەر بولۇپ، ئۇنىڭ قىسمىدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى.
\v 13 ئونىنچى ئايدىكى ئونىنچى نۆۋەتچى قوشۇننىڭ سەردارى زەراھ جەمەتىدىكى نىتوفاتلىق ماھاراي بولۇپ، ئۇنىڭ قىسمىدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى. \f ◼ \fr 27:13 \ft \bd «زەراھ»\bd* ــ ياكى «زارھى».\f*
\v 14 ئون بىرىنچى ئايدىكى ئون بىرىنچى نۆۋەتچى قوشۇننىڭ سەردارى ئەفرائىم قەبىلىسىدىكى پىراتونلۇق بىنايا بولۇپ، ئۇنىڭ قىسمىدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى.
\v 15 ئون ئىككىنچى ئايدىكى ئون ئىككىنچى نۆۋەتچى قوشۇننىڭ سەردارى ئوتنىيەل جەمەتىدىكى نىتوفاتلىق ھەلداي بولۇپ، ئۇنىڭ قىسمىدا يىگىرمە تۆت مىڭ ئادەم بار ئىدى.
\b
\s1 ئىسرائىلنىڭ قەبىلە باشلىقلىرى
\m 
\v 16 ئىسرائىلنىڭ ھەرقايسى قەبىلىلىرىنى ئىدارە قىلىپ كەلگەنلەر تۆۋەندىكىلەر: رۇبەنىيلار ئۈچۈن زىكرىنىڭ ئوغلى ئەلىئېزەر قەبىلە باشلىقى ئىدى؛ شىمېئونىيلار ئۈچۈن قەبىلە باشلىقى مائاكاھنىڭ ئوغلى شەفاتىيا؛
\v 17 لاۋىي قەبىلىسى ئۈچۈن كەمۇئەلنىڭ ئوغلى ھاشابىيا قەبىلە باشلىقى ئىدى؛ ھارۇنىيلار ئۈچۈن جەمەت بېشى زادوك؛
\v 18 يەھۇدا قەبىلىسى ئۈچۈن داۋۇتنىڭ ئاكىسى ئېلىخۇ قەبىلە باشلىقى ئىدى؛ ئىسساكارىيلار ئۈچۈن مىكائىلنىڭ ئوغلى ئومرى قەبىلە باشلىقى ئىدى؛
\v 19 زەبۇلۇنىيلار ئۈچۈن ئوبادىيانىڭ ئوغلى يىشمايا قەبىلە باشلىقى ئىدى؛ نافتالى قەبىلىسى ئۈچۈن ئازرىيەلنىڭ ئوغلى يەرىموت قەبىلە باشلىقى ئىدى؛
\v 20 ئەفرائىمىيلار ئۈچۈن ئازازىيانىڭ ئوغلى ھوشىيا قەبىلە باشلىقى ئىدى؛ ماناسسەھ يېرىم قەبىلىسى ئۈچۈن پىدايانىڭ ئوغلى يوئېل قەبىلە باشلىقى ئىدى؛
\v 21 گىلېئادتا ماكانلاشقان ماناسسەھ يېرىم قەبىلىسى ئۈچۈن زەكەرىيانىڭ ئوغلى ئىددو قەبىلە باشلىقى ئىدى؛ بىنيامىن قەبىلىسى ئۈچۈن ئابنەرنىڭ ئوغلى يائاسىيەل قەبىلە باشلىقى ئىدى؛
\v 22 دان قەبىلىسى ئۈچۈن يەروھامنىڭ ئوغلى ئازارەل قەبىلە باشلىقى ئىدى. يۇقىرىدىكىلەر ئىسرائىل قەبىلىلىرى ئۈچۈن قەبىلە باشلىقى ئىدى.
\m 
\v 23 داۋۇت ئىسرائىللار ئىچىدە يىگىرمە ياشتىن تۆۋەنلەرنى تىزىملىمىغان؛ چۈنكى پەرۋەردىگار ئىسرائىللارنىڭ سانىنى ئاسماندىكى يۇلتۇزدەك كۆپ قىلىمەن دېگەنىدى.
\v 24 زەرۇئىيانىڭ ئوغلى يوئاب سانىنى ئېلىشقا كىرىشكەن، لېكىن تۈگىمىگەن؛ چۈنكى مۇشۇ ئىش ۋەجىدىن \add خۇدانىڭ\add* غەزىپى ئىسرائىللارنىڭ بېشىغا ياغدۇرۇلغان؛ شۇ سەۋەبتىن ئىسرائىللارنىڭ سانى «داۋۇت پادىشاھنىڭ يىلنامىلىرى» دېگەن خاتىرىگە كىرگۈزۈلمىگەن.
\b
\s1 پادىشاھ ئوردىسىدىكى مال-مۈلۈك ۋە ئىش-ئوقەتنى باشقۇرغۇچى ئەمەلدارلار
\m 
\v 25 پادىشاھنىڭ ئامبار-خەزىنىلىرىنى باشقۇرغۇچى ئادىيەلنىڭ ئوغلى ئازماۋەت ئىدى؛ دالا، شەھەر، يېزا-كەنت ۋە مۇنارلاردىكى ئامبار-خەزىنىلەرنى باشقۇرغۇچى ئۇززىيانىڭ ئوغلى يوناتان ئىدى.
\v 26 ئېتىز-ئېرىقلاردا تېرىقچىلىق قىلغۇچىلارنى باشقۇرغۇچى كېلۇبنىڭ ئوغلى ئەزرى ئىدى؛
\v 27 ئۈزۈمزارلىقلارنى باشقۇرغۇچى راماھلىق شىمەي؛ ئۈزۈمزارلىقلاردىكى شاراب ئامبارلىرىنى باشقۇرغۇچى شىفمىلىق زابدى؛
\v 28 شەفەلاھ تۈزلەڭلىكىدىكى زەيتۇن ۋە ئۈجمە دەرەخلىرىنى باشقۇرغۇچى گەدەرلىك بائال-ھانان ئىدى؛ ماي ئامبارلىرىنى باشقۇرغۇچى يوئاش؛ \f ◼ \fr 27:28 \ft \bd «شەفەلاھ تۈزلەڭلىكى»\bd* ــ ئىبرانىي تىلىدا «شەفەلاھ» ــ پەقەت بىرلا تۈزلەڭلىكنى كۆرسىتىدۇ، يېرۇسالېمنىڭ جەنۇبىي تەرىپىگە جايلاشقان.\f*
\v 29 شاروندا بېقىلىدىغان كالا پادىلىرىنى باشقۇرغۇچى شارونلۇق سىتراي؛ جىلغىلاردىكى كالا پادىلىرىنى باشقۇرغۇچى ئادلاينىڭ ئوغلى شافات؛
\v 30 تۆگىلەرنى باشقۇرغۇچى ئىسمائىللاردىن ئوبىل؛ ئېشەكلەرنى باشقۇرغۇچى مىرونوتلۇق يەھدىيا؛
\v 31 قوي پادىلىرىنى باشقۇرغۇچى خاگارلىق يازىز ئىدى. بۇلارنىڭ ھەممىسى داۋۇت پادىشاھنىڭ مال-مۈلكىنى باشقۇرغۇچى ئەمەلدارلار ئىدى.
\b
\s1 داۋۇتنىڭ مۇھىم ئەمەلدارلىرى
\m 
\v 32 داۋۇتنىڭ تاغىسى يوناتان مەسلىھەتچى بولۇپ، دانىشمەن ھەم تەۋرات خەتتاتچىسى ئىدى؛ خاقمونىنىڭ ئوغلى يەھىيەل پادىشاھنىڭ ئوغۇللىرىنىڭ ئۇستازى ئىدى. \f ◼ \fr 27:32 \ft \bd «تەۋرات خەتتاتچىسى»\bd* ــ ياكى «تەۋراتشۇناس» ياكى «كاتىپ».\f*
\v 33 ئاھىتوفەلمۇ پادىشاھنىڭ مەسلىھەتچىسى ئىدى؛ ئاركلىق ھۇشاي پادىشاھنىڭ جان دوستى ئىدى.
\v 34 ئاھىتوفەلدىن كېيىن بىنايانىڭ ئوغلى يەھويادا بىلەن ئابىياتار ئۇنىڭ ئورنىغا مەسلىھەتچى بولدى؛ يوئاب پادىشاھنىڭ قوشۇن سەردارى ئىدى.
\b
\b
\c 28
\s1 داۋۇت مۇقەددەس ئۆي سېلىش ئارزۇسىنى جاكارلايدۇ
\m 
\v 1 داۋۇت ئىسرائىلدىكى بارلىق ئەمەلدارلارنى، ھەرقايسى قەبىلە باشلىقلىرى، نۆۋەتلىشىپ پادىشاھنىڭ خىزمىتىنى قىلىدىغان قوشۇن بېشى، مىڭبېشى، يۈزبېشى، پادىشاھ ۋە شاھزادىلەرنىڭ بارلىق مال-مۈلۈك، چارۋا ماللىرىنى باشقۇرىدىغان ئەمەلدارلارنى، شۇنىڭدەك مەھرەم-غوجىدارلار، پالۋانلار ۋە بارلىق باتۇر جەڭچىلەرنى يېرۇسالېمغا چاقىرتىپ كەلدى. \f ◼ \fr 28:1 \ft \bd «مەھرەم-غوجىدارلار»\bd* ــ ياكى «مەھرەم-ئاغۋاتلار».\f*
\m 
\v 2 پادىشاھ داۋۇت ئورنىدىن تۇرۇپ مۇنداق دېدى:
\m ــ ئى بۇرادەرلىرىم ۋە خەلقىم، گېپىمگە قۇلاق سېلىڭلار: كۆڭلۈمدە پەرۋەردىگارنىڭ ئەھدە ساندۇقى ئۈچۈن بىر ئارامگاھ، خۇدايىمىزنىڭ تەختىپەرىسى بولىدىغان بىر ئۆي سېلىش ئارزۇيۇم بار ئىدى ھەمدە ئۇنى سېلىشقا تەييارلىقمۇ كۆرۈپ قويغانىدىم.
\v 3 لېكىن خۇدا ماڭا: «سەن مېنىڭ نامىمغا ئاتاپ ئۆي سالساڭ بولمايدۇ، چۈنكى سەن جەڭچى، ئادەم ئۆلتۈرۈپ قان تۆككەنسەن» دېدى.
\v 4 ئىسرائىلنىڭ خۇداسى بولغان پەرۋەردىگار ئاتامنىڭ پۈتۈن جەمەتىدىن مېنى ئەبەدىلئەبەد ئىسرائىلغا پادىشاھ بولۇشقا تاللىدى؛ چۈنكى ئۇ يەھۇدانى يولباشچى بولۇشقا تاللىغان؛ ئۇ يەھۇدا جەمەتى ئىچىدە ئاتامنىڭ جەمەتىنى تاللىغان، ئاتامنىڭ ئوغۇللىرى ئىچىدە مەندىن رازى بولۇپ، مېنى پۈتۈن ئىسرائىلغا پادىشاھ قىلىپ تىكلىگەن؛
\v 5 مېنىڭ ئوغۇللىرىم ئىچىدىن (پەرۋەردىگار دەرۋەقە ماڭا كۆپ ئوغۇل ئاتا قىلغان) ئۇ يەنە ئوغلۇم سۇلايماننى پەرۋەردىگارنىڭ پادىشاھلىقىنىڭ تەختىگە ئولتۇرۇپ، ئىسرائىلغا ھۆكۈمران بولۇشقا تاللىدى.
\m 
\v 6 ئۇ ماڭا: «سېنىڭ ئوغلۇڭ سۇلايمان بولسا مېنىڭ ئۆيۈم ۋە ھويلىلىرىمنى سالغۇچى بولىدۇ؛ چۈنكى مەن ئۇنى ئۆزۈمگە ئوغۇل بولۇشقا تاللىدىم، مەنمۇ ئۇنىڭغا ئاتا بولىمەن.
\v 7 ئۇ مېنىڭ ئەمر-بەلگىلىمىلىرىمگە بۈگۈنكىدەك چىڭ تۇرۇپ رىئايە قىلىدىغان بولسا، ئۇنىڭ پادىشاھلىقىنى مەڭگۈ مۇستەھكەم قىلىمەن» دېگەنىدى.
\m 
\v 8 شۇڭا بۈگۈن پەرۋەردىگارنىڭ جامائىتى پۈتكۈل ئىسرائىل خەلقىنىڭ، شۇنداقلا خۇدايىمىزنىڭ ئالدىدا \add شۇنى ئېيتىمەن\add*: ــ بۇ ياخشى يۇرتقا ئىگىدارچىلىق قىلىش ئۈچۈن ۋە كەلگۈسىدە بالىلىرىڭلارغا مەڭگۈلۈك مىراس قىلىپ قالدۇرۇش ئۈچۈن، سىلەر خۇدايىڭلار پەرۋەردىگارنىڭ بارلىق ئەمرلىرىنى ئىزدەپ تۇتۇڭلار.
\m 
\v 9 ــ ئى، سەن ئوغلۇم سۇلايمان، ئاتاڭنىڭ خۇداسى بولغان پەرۋەردىگارنى بىل، ساپ دىل ۋە پىداكارلىق بىلەن ئۇنىڭ خىزمىتىدە بولغىن. چۈنكى پەرۋەردىگار جىمى ئادەمنىڭ كۆڭلىنى كۆزىتىپ تۇرىدۇ، بارلىق ئوي-نىيەتلىرىنى پەرق ئېتىدۇ. سەن ئۇنى ئىزدىسەڭ، ئۇ ئۆزىنى ساڭا تاپقۇزىدۇ؛ ئۇنىڭدىن تېنىپ كەتسەڭ، سېنى مەڭگۈ ئۈزۈپ تاشلايدۇ.
\v 10 ئەمدى سەن كۆڭۈل قويغىن، پەرۋەردىگار مۇقەددەسخانا قىلىش ئۈچۈن بىر ئۆينى سېلىشقا سېنى تاللىدى؛ باتۇر بول، ئۇنى ئادا قىل!».
\b
\s1 داۋۇت مۇقەددەسخانىنىڭ لايىھىسى توغرىسىدا سۇلايمانغا كۆرسىتىدۇ
\m 
\v 11 داۋۇت \add مۇقەددەسگاھنىڭ\add* دەھلىزى، خانىلىرى، خەزىنىلىرى، بالىخانىلىرى، ئىچكى ئۆيلىرى ۋە كەفارەت تەختىدىكى ئۆيىنىڭ لايىھىسىنىڭ ھەممىسىنى ئوغلى سۇلايمانغا تاپشۇردى؛ \f ◼ \fr 28:11 \ft \bd «كەفارەت تەختى»\bd* ــ ياكى «رەھىم تەختى»، «رەھىمگاھ». «مىس.» 17:25-22نى كۆرۈڭ. \bd «كەفارەت تەختىدىكى ئۆيى»\bd* ــ ئىبادەتخانىنىڭ ئەڭ ئىچكىرىدىكى ئۆي بولۇپ، يەنە «ئەڭ مۇقەددەس جاي» دەپ ئاتىلىدۇ.\f*
\v 12 \add خۇدانىڭ\add* روھىدىن تاپشۇرۇۋالغىنى بويىچە ئۇ پەرۋەردىگارنىڭ ئۆيىنىڭ ھويلىلىرى، تۆت ئەتراپىدىكى كىچىك ئۆيلەر، مۇقەددەسخانىدىكى خەزىنلەر، مۇقەددەس دەپ بېغىشلانغان بۇيۇملار قويۇلىدىغان خەزىنىلەرنىڭ لايىھىلىرىنى قالدۇرماي ئۇنىڭغا كۆرسەتتى. \f ◼ \fr 28:12 \ft \bd «خۇدانىڭ روھىدىن تاپشۇرۇۋالغىنى بويىچە...»\bd* ــ ئىبرانىي تىلىدا «روھتىن تاپشۇرۇۋالغىنى بويىچە...». بىزنىڭچە «روھ» مۇشۇ يەردە چوقۇم خۇدانىڭ روھىنى كۆرسىتىدۇ. دېمەك، مۇقەددەسگاھنىڭ بارلىق نۇسخىلىرى ۋە ئىشلىرى خۇدانىڭ كۆرسەتمىلىرى بىلەن بولدى.\f*
\v 13 يەنە كاھىنلار بىلەن لاۋىيلارنىڭ گۇرۇپپىلىنىشى، پەرۋەردىگارنىڭ ئۆيىدىكى ھەرخىل ۋەزىپىلەر، شۇنىڭدەك پەرۋەردىگارنىڭ ئۆيىگە ئېھتىياجلىق بارلىق ئەسۋابلار توغرىسىدىكى بەلگىلىمىلەرنى كۆرسەتتى؛
\v 14 ۋە ھەرخىل ئىشلارغا كېرەكلىك ئالتۇن ئەسۋابلارنى ياسىتىشقا كېتىدىغان ئالتۇن، ھەرخىل ئىشلارغا كېرەكلىك كۈمۈش ئەسۋابلارنى ياسىتىشقا كېتىدىغان كۈمۈش،
\v 15 ئالتۇن چىراغدانلارغا، ئۇلارغا تەۋە ئالتۇن چىراغلارغا، يەنى ھەربىر چىراغدان ۋە چىراغلارغا كېتىدىغان ئالتۇن؛ كۈمۈش چىراغدانلارغا، يەنى ھەربىر چىراغدان ۋە شۇنىڭغا تەۋە چىراغلار ئۈچۈن كېتىدىغان كۈمۈشنى تاپشۇرۇپ بەردى. ئۇ ھەربىر چىراغدانغا ئىشلىتىش ئورنىغا قاراپ كېرەكلىكىنى بەردى؛
\v 16 نان تىزىدىغان ئالتۇن شىرەلەرنى ياسىتىشقا، يەنى ھەربىر شىرە ئۈچۈن كېرەكلىك ئالتۇن بەردى؛ كۈمۈش شىرەلەرنى ياسىتىشقا كېرەكلىك كۈمۈش بەردى؛
\v 17 ۋىلكا-ئىلمەكلەر، تەخسە-پىيالە ۋە چۆگۈنلەرنى ياساشقا، ئالتۇن چىنىلەر، يەنى ھەرخىل چىنىنى ياساشقا كېرەكلىك بولغان ساپ ئالتۇن بەردى؛ كۈمۈش چىنىلەرنى ياساشقا، يەنى ھەربىر چىنە ئۈچۈن كېرەكلىك كۈمۈش بەردى؛
\v 18 خۇشبۇيگاھ ياساشقا كېرەكلىك ئېسىل ئالتۇن بەردى. ئۇ يەنە قاناتلىرىنى كېرىپ پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى يېپىپ تۇرىدىغان ئالتۇن كېرۇبلار قارايدىغان \add كەفارەت\add* تەختىنىڭ نۇسخىسىنى تاپشۇرۇپ بەردى. \f ◼ \fr 28:18 \ft \bd «...خۇشبۇيگاھ ياساشقا كېرەكلىك ئېسىل ئالتۇن بەردى»\bd* ــ بۇ 14-18-ئايەتلەردىكى «بەردى... بەردى.. بەردى» ــ داۋۇت پادىشاھ سۇلايمانغا (1) ھەربىر نەرسە ئۈچۈن قانچىلىك ئالتۇن-كۈمۈش كېرەك بولغانلىقىنى كۆرسەتتى؛ (2) ئەمەلىيەتتە قانچىلىك كېرەك بولسا شۇنى بەردى، دېگەن مەنىدە. بىزنىڭچە ئىككىنچى ۋارىيانت توغرىدۇر. 2:29نى كۆرۈڭ. \bd «كەفارەت تەختى»\bd* ــ باشقا بىرخىل تەرجىمىسى «ھارۋا». لېكىن مۇشۇ يەردە چوقۇم ئەڭ مۇقەددەس جايدىكى رەھىمگاھ (كەفارەت تەختى)نى كۆرسىتىدۇ.\f*
\v 19 «بۇلارنىڭ ھەممىسى، پەرۋەردىگار ئۆز قولىنى ئۈستۈمگە قويغاندا ماڭا كۆرسەتكەن بارلىق نۇسخا-ئەندىزىلەر بولغاچقا، مەن يېزىپ قويدۇم» دېدى داۋۇت.
\b
\s1 داۋۇت سۇلايمانغا داۋاملىق نەسىھەت قىلىدۇ
\m 
\v 20 داۋۇت يەنە ئوغلى سۇلايمانغا: «سەن باتۇر ۋە جاسارەتلىك بول، بۇنى ئادا قىل؛ قورقما، ئالاقزادىمۇ بولۇپ كەتمە؛ چۈنكى پەرۋەردىگار خۇدا، مېنىڭ خۇدايىم سېنىڭ بىلەن بىللە بولىدۇ؛ تاكى پەرۋەردىگارنىڭ ئۆيىدىكى كېيىنكى ئىبادەت خىزمىتى ئۈچۈن تەييارلىق ئىشلىرى تۈگىگەنگە قەدەر ئۇ سەندىن ھېچ ئايرىلمايدۇ ياكى تاشلاپمۇ قويمايدۇ.
\v 21 قارا، خۇدانىڭ ئۆيىدىكى بارلىق خىزمىتىنى بېجىرىدىغان كاھىنلار ۋە لاۋىيلارنىڭ گۇرۇپپىلىرى تەييار تۇرىدۇ؛ سېنىڭ يېنىڭدا ھەرخىل ھۈنەرگە ئۇستا، ھەربىر خىزمەتكە تەييار تۇرغان ھۈنەرۋەنلەرمۇ رازىلىق بىلەن تۇرىدۇ؛ ئۇنىڭ ئۈستىگە ئەمەلدارلار ۋە بارلىق خەلق سېنىڭ ئەمرىڭنى كۈتىدۇ» دېدى.
\b
\b
\c 29
\s1 داۋۇت ۋە خالايىقنىڭ خۇدانىڭ ئۆيى ئۈچۈن بېغىشلىغانلىرى
\m 
\v 1 داۋۇت پۈتكۈل جامائەتكە سۆز قىلىپ مۇنداق دېدى:
\m ــ «خۇدا ئۆزى تاللىغان ئوغلۇم سۇلايمان تېخى ياش، بىر يۇمران كۆچەت، خالاس، بۇ قۇرۇلۇش بولسا تولىمۇ چوڭ؛ چۈنكى بۇ مۇقەددەس ئوردا ئىنسان ئۈچۈن ئەمەس، بەلكى پەرۋەردىگار خۇدا ئۈچۈن ياسىلىدۇ.
\v 2 مەن خۇدايىمنىڭ ئۆيى ئۈچۈن پۈتۈن كۈچۈمنى چىقىرىپ، ئالتۇن بىلەن ياسىلىدىغانلىرىغا ئالتۇن، كۈمۈش بىلەن ياسىلىدىغانلىرىغا كۈمۈش، مىس بىلەن ياسىلىدىغانلىرىغا مىس، تۆمۈر بىلەن ياسىلىدىغانلىرىغا تۆمۈر، ياغاچ بىلەن ياسىلىدىغانلىرىغا ياغاچ تەييارلاپ قويدۇم؛ يەنە ئاق ھېقىق، كۆزلۈك ياقۇت، رەڭلىك تاش ۋە ھەرخىل ئېسىل تاشلارنى، يەنە ناھايىتى كۆپ مەرمەرنى يىغىپ قويدۇم. \f ◼ \fr 29:2 \ft \bd «كۆزلۈك ياقۇت»\bd* ــ ياكى «سۈرمە».\f*
\v 3 مەن خۇدايىمنىڭ ئۆيىدىن سۆيۈنىدىغانلىقىم ئۈچۈن خۇدايىمنىڭ ئۆيىنى سېلىشقا تەييارلىغان بارلىق نەرسىلەردىن باشقا، ئۆزۈمنىڭ تەئەللۇقاتىدىن ئالتۇن-كۈمۈشلەرنى خۇدايىمنىڭ ئۆيىگە ئاتىدىم؛
\v 4 يەنى ئۆينىڭ تاملىرىنى قاپلاش ئۈچۈن ئوفىر ئالتۇنىدىن ئۈچ مىڭ تالانت، ساپ كۈمۈشتىن يەتتە مىڭ تالانت تەقدىم قىلدىم؛ \f ◼ \fr 29:4 \ft \bd «ئوفىر»\bd* ــ ئالتۇن چىقىدىغان داڭلىق جاي. \bd «تالانت»\bd* ــ بىر تالانت 30.6 كىلوگرام بولۇشى مۇمكىن؛ شۇڭا 3000 تالانت ئالتۇن 101 توننا بولىدۇ، 7000 تالانت كۈمۈش 235 توننا بولۇشى مۇمكىن.\f*
\v 5 ئالتۇندىن ياسىلىدىغانلىرىغا ئالتۇن، كۈمۈشتىن ياسىلىدىغانلىرىغا كۈمۈش ۋە ھۈنەرۋەنلەرنىڭ قولى بىلەن ھەرخىل ياسىلىدىغانلىرىغا كېرەك بولغىنىنى تەقدىم قىلدىم. بۈگۈن يەنە كىملەرنىڭ پەرۋەردىگارغا بىرنېمە ئاتىغۇسى بار؟».
\m 
\v 6 شۇنىڭ بىلەن ئىسرائىل قەبىلىلىرىدىكى ھەرقايسى جەمەت باشلىرى، قەبىلە باشلىقلىرى، مىڭبېشى، يۈزبېشى ۋە پادىشاھنىڭ ئىشلىرىغا مەسئۇل بولغان غوجىدارلارمۇ بېغىشلاشقا كىرىشتى.
\v 7 ئۇلار خۇدانىڭ ئۆيىدىكى ئىبادەت خىزمەتلىرى ئۈچۈن بەش مىڭ تالانت ئالتۇن ۋە ئون مىڭ دارىك ئالتۇن، ئون مىڭ تالانت كۈمۈش، ئون سەككىز مىڭ تالانت مىس ۋە بىر يۈز مىڭ تالانت تۆمۈر تەقدىم قىلدى. \f ◼ \fr 29:7 \ft \bd «تالانت... دارىك...»\bd* ــ بىر تالانت 30.6 كىلوگرام بولۇشى مۇمكىن؛ بىر دارىك بەلكىم 8-9 گرام ئىدى. شۇنداق بولغاندا، ئالتۇندىن 168 توننا ھەم 80-90 كىلوگرام، كۈمۈشتىن 336 توننا، مىستىن 606 توننا، تۆمۈردىن 3365 توننا تەقدىم قىلدى.\f*
\v 8 ياقۇتى بارلار ياقۇتنى پەرۋەردىگارنىڭ ئۆيىنىڭ خەزىنىسىگە، يەنى گەرشونىي يەھىيەلنىڭ قولىغا تاپشۇردى.
\v 9 خالايىق كىشىلەرنىڭ مۇنداق ئۆز ئىختىيارلىقى بىلەن تەقدىم قىلغانلىقلىرىدىن خۇشال بولۇپ كېتىشتى؛ چۈنكى ئۇلار چىن قەلبىدىن پەرۋەردىگارغا تەقدىم قىلىشقانىدى. داۋۇتمۇ ئالامەت خۇش بولدى.
\b
\s1 داۋۇت پەرۋەردىگارغا ھەمدۇسانا ئوقۇيدۇ
\m 
\v 10 شۇڭا داۋۇت پۈتكۈل جامائەت ئالدىدا پەرۋەردىگارغا تەشەككۈر-مەدھىيە ئېيتىپ مۇنداق دېدى:
\m ــ «ئاھ پەرۋەردىگار، بوۋىمىز ئىسرائىلنىڭ خۇداسى، سەن ئەبەدىلئەبەدگىچە ھەمدۇساناغا لايىقسەن.
\v 11 ئى پەرۋەردىگار، ئۇلۇغلۇق، كۈچ-قۇدرەت، شان-شەرەپ، شانۇ-شەۋكەت ۋە ھەيۋەت ساڭا مەنسۇپتۇر؛ ئاسماندىكى ۋە يەردىكى بار-يوقى سېنىڭكىدۇر؛ ئى پەرۋەردىگار، پادىشاھلىق سېنىڭكىدۇر، ھەممىدىن ئۈستۈن بولغان ئىدارە قىلغۇچىسەن.
\v 12 دۆلەت بىلەن ئىززەت سېنىڭدىنلا كېلىدۇ، سەن ھەممىگە ھۆكۈمدارسەن. كۈچ بىلەن قۇدرەت سېنىڭ قولۇڭدا؛ ھەركىمنى ئۇلۇغ ۋە قۇدرەتلىك قىلىش پەقەت قولۇڭدىندۇر.
\v 13 ئەمدى، ئاھ خۇدايىمىز، بىز ساڭا تەشەككۈر ئوقۇيمىز، شان-شەرەپلىك نامىڭغا مەدھىيە ئوقۇيمىز!
\m 
\v 14 مانا مۇشۇنداق ئۆزلۈكۈمىزدىن تەقدىم قىلالايدىغان بولغان مەن كىم ئىدىم، خەلقىم نېمە ئىدى؟ چۈنكى بارلىق نەرسە سەندىن كېلىدۇ، بىز پەقەت ئۆز قولۇڭدىن كەلگىنىدىن ئۆزۈڭگە قايتۇردۇق، خالاس!
\v 15 بىز سېنىڭ ئالدىڭدا ياقا يۇرتلۇقلار، بارلىق ئاتا-بوۋىلىرىمىزغا ئوخشاش مۇساپىرمىز، خالاس؛ يەر يۈزىدىكى كۈنلىرىمىز گويا بىر سايە، ئۈمىدسىز ئۆتكۈزۈلىدۇ. \f ◼ \fr 29:15 \ft \bd «يەر يۈزىدىكى كۈنلىرىمىز گويا بىر سايە، ئۈمىدسىز ئۆتكۈزۈلىدۇ»\bd* ــ «ئۈمىدسىز ئۆتكۈزۈلىدۇ» بەلكىم بۇ دۇنياغا بولغان ئۈمىدسىزلىكنى بىلدۈرىدۇ.\f*
\v 16 ئى خۇدايىمىز پەرۋەردىگار، بىز سېنىڭ نامىڭغا ئاتاپ ئۆي سېلىشقا تەييارلاپ يىغقان بۇ بايلىق-دۇنيانىڭ ھەممىسى سېنىڭ قولۇڭدىن كەلگەن، ئەسلى سېنىڭكىدۇر.
\v 17 ئى خۇدايىم، شۇنى بىلىمەنكى، سەن ئىنساننىڭ قەلبىنى سىناپ، دۇرۇسلۇقتىن خۇرسەن بولىسەن؛ مەن بولسام دۇرۇس قەلبىمدىن بۇلارنى ئىختىيارەن تەقدىم قىلدىم؛ ۋە بۇ يەردە ھازىر تۇرغان خەلقىڭنىڭمۇ ساڭا تەقدىم قىلغىنىنى خۇشال-خۇراملىق بىلەن كۆردۈم.
\v 18 ئى پەرۋەردىگار، ئاتا-بوۋىلىرىمىز بولغان ئىبراھىم، ئىسھاق ۋە ئىسرائىلنىڭ خۇداسى، ئۆز خەلقىڭنىڭ كۆڭلىدىكى بۇنداق ئوي-نىيەتنى مەڭگۈ مۇستەھكەم قىلغايسەن، كۆڭلىنى ئۆزۈڭگە تارتقۇزغايسەن!
\v 19 ئوغلۇم سۇلايمانغا سېنىڭ ئەمرلىرىڭ، ئاگاھ-گۇۋاھلىقلىرىڭ ۋە بەلگىلىمىلىرىڭنى تۇتۇپ، ھەممىنى ئادا قىلىپ، مەن ھازىرلاپ قويغانلىرىمنى ئىشلىتىپ ئوردىنى ياساشقا دۇرۇس بىر قەلب بەرگەيسەن».
\b
\s1 جامائەت پەرۋەردىگارغا ئىبادەت قىلىدۇ
\m 
\v 20 داۋۇت پۈتۈن جامائەتكە: «سىلەر خۇدايىڭلار بولغان پەرۋەردىگارغا تەشەككۈر-ھەمدۇسانا ئوقۇپ مەدھىيىلەڭلار!» دېۋىدى، پۈتۈن جامائەت ئاتا-بوۋىلىرىنىڭ خۇداسى بولغان پەرۋەردىگارغا تەشەككۈر-مەدھىيە ئوقۇپ سەجدە قىلدى؛ ئۇلار پەرۋەردىگار ھەم پادىشاھ ئالدىدا باش ئۇردى.
\m 
\v 21 ئەتىسى ئۇلار پەرۋەردىگارغا ئاتاپ قۇربانلىقلار ۋە كۆيدۈرمە قۇربانلىقلارنى كەلتۈردى؛ شۇ كۈنى ئۇلار مىڭ بۇقا، مىڭ قوچقار، مىڭ قوزىنى شاراب ھەدىيەلىرى بىلەن قوشۇپ تەقدىم قىلدى، شۇنداقلا يەنە پۈتۈن ئىسرائىل ئۈچۈن نۇرغۇن قۇربانلىقلارنى تەقدىم قىلدى. \f ◼ \fr 29:21 \ft \bd « ئۇلار پەرۋەردىگارغا ئاتاپ قۇربانلىقلار ... كەلتۈردى»\bd* ــ مۇشۇ يەردە «قۇربانلىقلار» بەلكىم «ئىناقلىق قۇربانلىقلىرى»نى كۆرستىدۇ؛ ھەم سۇنغۇچىنىڭ ئۆزى، ھەمراھلىرى ھەم كاھىنلارمۇ ئۇنىڭدىن بىر قىسمىنى يېيەلەيتتى.\f*
\b
\s1 خەلق سۇلايماننى تەختكە ئولتۇرغۇزۇپ پادىشاھ قىلىدۇ
\m 
\v 22 ئۇلار شۇ كۈنى پەرۋەردىگارنىڭ ئالدىدا ئالامەت خۇشال بولۇپ غىزالاندى. ئۇلار داۋۇتنىڭ ئوغلى سۇلايماننى ئىككىنچى قېتىم پادىشاھ تىكلەش مۇراسىمى ئۆتكۈزدى؛ ئۇنى پەرۋەردىگارنىڭ ئالدىدا شاھ بولۇشقا، زادوكنى كاھىن بولۇشقا مەسىھ قىلدى. \f ◼ \fr 29:22 \ft \bd «ئۇلار... غىزالاندى»\bd* ــ ئىبرانىي تىلىدا «يەپ-ئىچتى». \bd «ئىككىنچى قېتىم پادىشاھ تىكلەش»\bd* ــ بىرىنچى قېتىم 1:23دە خاتىرىلىنىدۇ.\f*
\m 
\v 23 شۇنىڭدىن كېيىن سۇلايمان پەرۋەردىگارغا تەۋە تەختكە ئولتۇرۇپ، ئاتىسى داۋۇتنىڭ ئورنىغا پادىشاھ بولدى ۋە ئىنتايىن راۋاج تاپتى؛ پۈتكۈل ئىسرائىل خەلقى ئۇنىڭغا ئىتائەت قىلدى.
\v 24 بارلىق ئەمەلدارلار، پالۋانلار ۋە شۇنداقلا پادىشاھ داۋۇتنىڭ ئوغۇللىرىنىڭ ھەممىسى سۇلايمانغا بېقىنىپ بويسۇندى.
\v 25 پەرۋەردىگار سۇلايماننى ئىسرائىل خەلقى ئالدىدا ناھايىتى ئۇلۇغ قىلدى؛ ئۇ ئۇنىڭغا ئاتا قىلغان شاھانە ھەيۋەت شۇنداق يۇقىرىكى، ئۇنىڭدىن ئىلگىرى ئۆتكەن ھەرقانداق ئىسرائىل پادىشاھلىرىدا ھېچ بولۇپ باققان ئەمەس.
\b
\s1 داۋۇت ئالەمدىن ئۆتىدۇ
\m 
\v 26 يەسسەنىڭ ئوغلى داۋۇت پۈتۈن ئىسرائىلغا شۇنداق پادىشاھ بولغانىدى.
\v 27 ئۇنىڭ ئىسرائىلغا ھۆكۈمرانلىق قىلغان ۋاقتى جەمئىي قىرىق يىل بولدى؛ ئۇ ھېبروندا يەتتە يىل، يېرۇسالېمدا ئوتتۇز ئۈچ يىل سەلتەنەت قىلدى.
\v 28 ئۇ ئۇزۇن ئۆمۈر، دۆلەت-بايلىق ۋە ئىززەت-ھۆرمەت كۆرۈپ، خېلى كۆپ ياشاپ، ئالەمدىن ئۆتتى؛ ئورنىغا ئۇنىڭ ئوغلى سۇلايمان پادىشاھ بولدى.
\v 29 پادىشاھ داۋۇتنىڭ بارلىق ئىشلىرى، باشتىن ئاخىرىغىچە مانا ئالدىن كۆرگۈچى سامۇئىلنىڭ خاتىرىلىرى، ناتان پەيغەمبەرنىڭ خاتىرىلىرى ۋە ئالدىن كۆرگۈچى گادنىڭ خاتىرىلىرىدە پۈتۈلگەندۇر.
\v 30 ئۇنىڭ سەلتەنىتى، كۆرسەتكەن كۈچ-قۇۋۋىتى، شۇنداقلا ئۇنىڭ، ئىسرائىل ۋە ھەرقايسى دۆلەت-مەملىكەتلەرنىڭ بېشىدىن ئۆتكەن ۋەقەلەرمۇ شۇ خاتىرىلەردە پۈتۈلگەندۇر. 
