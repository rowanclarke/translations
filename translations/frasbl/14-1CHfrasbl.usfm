\p 
\v 50 \w Voici|strong="H1121"\w* \w les|strong="H5414"\w* \w fils|strong="H1121"\w* d'\w Aaron|strong="H1121"\w* : \w Éléazar|strong="H1121"\w*, \w son|strong="H5414"\w* \w fils|strong="H1121"\w* ; Phinées, \w son|strong="H5414"\w* \w fils|strong="H1121"\w* ; Abishua, \w son|strong="H5414"\w* \w fils|strong="H1121"\w* ;
\v 51 Bukki, \w son|strong="H1961"\w* \w fils|strong="H1121"\w* ; Uzzi, \w son|strong="H1961"\w* \w fils|strong="H1121"\w* ; Zerahia, \w son|strong="H1961"\w* \w fils|strong="H1121"\w* ;
\v 52 Meraioth, \w son|strong="H5414"\w* \w fils|strong="H5414"\w* ; Amaria, \w son|strong="H5414"\w* \w fils|strong="H5414"\w* ; Ahitub, \w son|strong="H5414"\w* \w fils|strong="H5414"\w* ;
\v 53 Tsadok, son \w fils|strong="H4054"\w* ; Ahimaaz, son \w fils|strong="H4054"\w*.
\v 54 Voici leurs lieux d'habitation, selon leurs campements dans leurs frontières. Aux \w fils|strong="H4054"\w* d'Aaron, \w des|strong="H4054"\w* familles \w des|strong="H4054"\w* Kehathites, car c'était le premier lot,
\v 55 \w ils|strong="H1121"\w* \w donnèrent|strong="H1121"\w* Hébron, \w dans|strong="H1121"\w* \w le|strong="H1121"\w* \w pays|strong="H1121"\w* \w de|strong="H1121"\w* \w Juda|strong="H1121"\w*, \w et|strong="H1121"\w* \w les|strong="H1121"\w* pâturages \w qui|strong="H1121"\w* l'entourent ;
\v 56 mais \w les|strong="H1121"\w* champs \w de|strong="H1121"\w* \w la|strong="H1121"\w* \w ville|strong="H4294"\w* \w et|strong="H1121"\w* \w ses|strong="H1121"\w* villages, \w ils|strong="H1121"\w* \w les|strong="H1121"\w* \w donnèrent|strong="H1121"\w* \w à|strong="H1121"\w* Caleb, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* Jephunné.
\v 57 On donna aux \w fils|strong="H4294"\w* d'Aaron \w les|strong="H4054"\w* villes \w de|strong="H4294"\w* refuge : Hébron, Libna \w et|strong="H3485"\w* \w ses|strong="H4294"\w* pâturages, Jattir, Eschthemoa \w et|strong="H3485"\w* \w ses|strong="H4294"\w* pâturages,
\v 58 Hilen et ses pâturages, Debir et ses pâturages,
\v 59 Ashan et \w ses|strong="H4294"\w* pâturages, Beth Shemesh et \w ses|strong="H4294"\w* pâturages,
\v 60 et \w de|strong="H4054"\w* la tribu \w de|strong="H4054"\w* Benjamin : Guéba et ses pâturages, Allemeth et ses pâturages, Anathoth et ses pâturages. Toutes leurs villes, dans toutes leurs familles, étaient au nombre \w de|strong="H4054"\w* treize.
\p 
\v 61 Aux \w autres|strong="H4054"\w* \w fils|strong="H4294"\w* \w de|strong="H4294"\w* \w Kehath|strong="H4054"\w*, on donna par le sort, selon \w leurs|strong="H4294"\w* \w familles|strong="H4294"\w*, \w de|strong="H4294"\w* \w la|strong="H4294"\w* \w tribu|strong="H4294"\w*, \w de|strong="H4294"\w* \w la|strong="H4294"\w* \w demi-tribu|strong="H4294"\w*, \w de|strong="H4294"\w* \w la|strong="H4294"\w* moitié \w de|strong="H4294"\w* Manassé, dix villes.
\v 62 \w Aux|strong="H3498"\w* \w fils|strong="H1121"\w* \w de|strong="H1121"\w* Guershom, \w selon|strong="H1121"\w* \w leurs|strong="H1121"\w* \w familles|strong="H1121"\w*, \w de|strong="H1121"\w* \w la|strong="H1121"\w* \w tribu|strong="H4294"\w* d'Issacar, \w de|strong="H1121"\w* \w la|strong="H1121"\w* \w tribu|strong="H4294"\w* d'\w Aser|strong="H1121"\w*, \w de|strong="H1121"\w* \w la|strong="H1121"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Nephtali \w et|strong="H1121"\w* \w de|strong="H1121"\w* \w la|strong="H1121"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Manassé|strong="H1121"\w*, \w en|strong="H1121"\w* \w Basan|strong="H1121"\w*, treize villes.
\v 63 Aux \w fils|strong="H4294"\w* \w de|strong="H4294"\w* Merari, on donna \w par|strong="H4217"\w* \w le|strong="H4057"\w* sort, \w selon|strong="H7205"\w* \w leurs|strong="H4294"\w* \w familles|strong="H4294"\w*, \w de|strong="H4294"\w* \w la|strong="H4294"\w* \w tribu|strong="H4294"\w* \w de|strong="H4294"\w* \w Ruben|strong="H7205"\w*, \w de|strong="H4294"\w* \w la|strong="H4294"\w* \w tribu|strong="H4294"\w* \w de|strong="H4294"\w* \w Gad|strong="H4294"\w* \w et|strong="H7205"\w* \w de|strong="H4294"\w* \w la|strong="H4294"\w* \w tribu|strong="H4294"\w* \w de|strong="H4294"\w* Zabulon, douze villes.
\v 64 \w Les|strong="H4054"\w* enfants d'Israël donnèrent aux Lévites \w les|strong="H4054"\w* villes avec leurs pâturages.
\v 65 Ils donnèrent par tirage \w au|strong="H1410"\w* sort, \w de|strong="H4294"\w* \w la|strong="H4294"\w* \w tribu|strong="H4294"\w* \w des|strong="H4294"\w* \w fils|strong="H4294"\w* \w de|strong="H4294"\w* Juda, \w de|strong="H4294"\w* \w la|strong="H4294"\w* \w tribu|strong="H4294"\w* \w des|strong="H4294"\w* \w fils|strong="H4294"\w* \w de|strong="H4294"\w* \w Siméon|strong="H4294"\w* \w et|strong="H1410"\w* \w de|strong="H4294"\w* \w la|strong="H4294"\w* \w tribu|strong="H4294"\w* \w des|strong="H4294"\w* \w fils|strong="H4294"\w* \w de|strong="H4294"\w* Benjamin, ces villes qui sont mentionnées par leur nom.
\p 
\v 66 Quelques-unes \w des|strong="H4054"\w* familles \w des|strong="H4054"\w* \w fils|strong="H4054"\w* \w de|strong="H4054"\w* \w Kehath|strong="H4054"\w* eurent \w des|strong="H4054"\w* \w villes|strong="H2809"\w* \w de|strong="H4054"\w* leur ressort dans la tribu d'Ephraïm.
\v 67 On leur donna les villes de refuge : Sichem, dans la montagne d'Éphraïm, et ses pâturages ; Guézer et ses pâturages ;
\v 68 Jokmeam et ses pâturages ; Beth Horon et ses pâturages ;
\v 69 Ajalon et ses pâturages ; Gath Rimmon et ses pâturages ;
\v 70 et, de la demi-tribu de Manassé, Aner et ses pâturages, et Bilam et ses pâturages, pour le reste de la famille des fils de Kehath.
\p 
\v 71 On donna aux fils de Guershom, de la famille de la demi-tribu de Manassé, Golan en Basan et ses pâturages, et Ashtaroth et ses pâturages ;
\v 72 et de la tribu d'Issacar, Kedesh et ses pâturages, Daberath et ses pâturages,
\v 73 Ramoth et ses pâturages, et Anem et ses pâturages ;
\v 74 et de la tribu d'Asher, Mashal et ses pâturages, Abdon et ses pâturages,
\v 75 Hukok et ses pâturages, et Rehob et ses pâturages ;
\v 76 et de la tribu de Nephtali, Kedesh en Galilée et ses pâturages, Hammon et ses pâturages, et Kiriathaim et ses pâturages.
\p 
\v 77 Aux autres Lévites, fils de Merari, on donna, de la tribu de Zabulon, Rimmono et ses pâturages, et Tabor et ses pâturages.
\v 78 Au-delà du Jourdain, à Jéricho, sur la rive orientale du Jourdain, on donna, de la tribu de Ruben Bezer dans le désert et ses pâturages, Jahtsa et ses pâturages,
\v 79 Kedemoth et ses pâturages, et Mephaath et ses pâturages ;
\v 80 et de la tribu de Gad, Ramoth en Galaad et ses pâturages, Mahanaïm et ses pâturages,
\v 81 Hesbon et ses pâturages, et Jazer et ses pâturages.
\c 7
\p 
\v 1 \w Des|strong="H1121"\w* \w fils|strong="H1121"\w* d'Issachar : Tola, Puah, Jashub \w et|strong="H1121"\w* Shimron, \w quatre|strong="H1121"\w*.
