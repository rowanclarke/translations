\id AMO - Gamo Full Bible final version
\h Amoxe Tinbite
\toc1 Amoxe Tinbite
\toc2 Amoxe Tinbite
\toc3 Amo
\mt1 Amoxe Tinbite
\imt1 Giddo Qofa
\ip Amoxes tinbite haasaya erateththi deenna; izi tinbite haasayo timirte tamaarbeenna. [7:14] Gido attiin izi pude haan diza kawoteththa garsan diza derezas izi kiita gaththana mala kiitettida wode Amoxey Yuhudan diza Tequhe geetettiza kase izi diza gutayo yeggidi bides. Izi heeppeka dendidi Isra7eele asaas erettida goynoso gidida gede Beetele katama bides. Hayssa ha maxaafazan koyro bolla Amoxey dereza Amatees; hessafe Isra7eele asa harappeka lo7o duussi diza dureta amatees. He dureti dereza bonqqidi baas aylle histti haaranaas isttas gita wolqqay dees. Isttafe daroti goynnanaas hara eeqa Xoossati diikkoka istta naagizay GODAA gididayssa ba wozinan qoppeettes. Amoxey gidikko istti ba nagara gishshas qaxxayettanayssa isttas yootides. «Iita miish ixxite lo7o gididaazi siiqite. Pirda pirdizason pirda tuccofte. Medheteththa GODAY attida Isra7eele deraa izi maarontta aggenna.» [5:15]
\iot Ha Maxaafay Oykkida Kumeththa Qofa
\io1 Dereti ba mooron qaxxayeteth \ior 1:1—3:2\ior*
\io1 Isra7eeleynne Samaariyay dhayana dhays \ior 3:3—6:14\ior*
\io1 Isra7eele qixaate gishshas Amoxey be7ida ichchashu ajjuutata \ior 7:1—9:10\ior*
\io1 Isra7eeles diza lo7o hidota \ior 9:11-15\ior*
\c 1
\p 
\v 1 Ooziyay Yuhuda kawo; hessaththoka Iyo7aasa naa Iyorba7aamey Isra7eele kawo gidi dishin hessika biittay qaaxxanaappe nam7u layththafe sinththan Isra7eele gishshas Tequhen mehe heemmizayta giddofe Amoxey be7idi yootida qaalay hayssafe kaalli dizayssa;\x - \xo 1:1 \xt 2Kawo 15:1-7; 2Taari 26:1-23; 2Kawo 14:23-29\x*
\p 
\v 2 Amoxey,
\q1 «GODAY Xiyooneppe
\q2 ba qaala dhoqqu histti sissees;
\q2 Yerusalaameppe giirees;
\q2 mehey heemettizasoti melana;
\q1 Qarmeloose zuman diza
\q2 cililati shullana» gides.\x - \xo 1:2 \xt Iyu 3:16\x*
\s1 Isra7eele Heeran Diza Dereta Bolla Yaana Pirda
\p 
\v 3 GODAY Aaraames,
\q1 «Damasqo asay zaari zaaridi
\q2 ooththida nagara gishshas
\q2 ta istta qaxxayontta aggike;
\q2 istti Gala7aade asaa
\q2 birata achchara diza kath
\q2 bukkiza lodan bukkida.
\q1 
\v 4 Kawo Azaheele keeththan
\q2 tama yeddana;
\q2 he tamay Kawo Beeni-Hadaade
\q2 miixata maana.
\q1 
\v 5 Damasqo katama pengeta
\q2 ta menththereththana;
\q2 Beeti-Edene dere kawozanne
\q2 Awe zullaan diza asaa
\q2 ta dhayssana;
\q2 Aaraame dere asaykka di7ettidi
\q2 gede Qiire dere baana» gees.\x - \xo 1:3-5 \xt Isa 17:1-3; Er 49:23-27; Zaka 9:1\x*
\p 
\v 6 GODAY Filisxeemes,
\q1 «Gaaza asay zaari zaaridi ooththida
\q2 nagara gishshas
\q2 ta istta qaxxayontta aggike;
\q2 istta dereza ubbaa di7i efidi
\q2 Eedoomes bayzida.\x - \xo 1:6-8 \xt Isa 14:29-31; Er 47:1-7; Hizi 25:15-17; Iyu 3:4-8; Sofo 2:4-7; Zaka 9:5-7\x*
\q1 
\v 7 Izi gimbeta maana mala
\q2 Gaaza miixan tani tama yeddana.
\q1 
\v 8 Asqeloona dere kawozanne
\q2 Ashdoode dere asaa
\q2 ta pitta dhayssana;
\q2 Filisxeemen dizayti
\q2 wuri wurana gakkanaas
\q2 tani ta kushe Aqaroone bolla
\q2 denththana» gees.
\p 
\v 9 GODAY Xirooses, «Xiroose asay
\q2 zaari zaaridi
\q2 ooththida nagaraa gishshas
\q2 ta istta qaxxayontta aggike;
\q2 istti ba ishateththa
\q2 caaqo qaala laallidi
\q2 ba di7ida dereza
\q2 ubbaa Eedoomes bayzida.
\q1 
\v 10 Hessa gishshas tani Xiroose katama
\q2 gimbeta bolla tama yeddana;
\q2 he tamay
\q2 izi miixataka maana» gees.\x - \xo 1:9-10 \xt Isa 23:1-8; Hizi 26:1—28:19; Iyu 3:4-8; Zaka 9:1-4; Mato 11:21-22; Luqa 10:13-14\x*
\q1 
\v 11 GODAY Eedoomes,
\q2 «Eedoome asay
\q2 zaari zaaridi ooththida
\q2 nagara gishshas
\q2 ta istta qaxxayontta aggike;
\q2 istti ba ishata
\q2 Isra7eele naytas
\q2 qadhettontta mashshan gooddida;
\q2 ba hanqo doshisontta eexxidi
\q2 isttas mishettontta
\q2 ubbaa dippi histtida.\x - \xo 1:11-12 \xt Isa 34:5-17; 63:1-6; Er 49:7-22; Hizi 25:12-14; 35:1-15; Ab 14; Mil 1:2-5\x*
\q1 
\v 12 Hessa gishshas tani
\q2 Temaane gimbeta bolla
\q2 tama yeddana;
\q2 he tamay
\q2 Booxira miixataka maana» gees.
\p 
\v 13 GODAY Amoones,
\q2 «Amoone asay zaari zaaridi
\q2 ooththida nagara gishshas
\q2 ta istta qaxxayontta aggike;
\q2 istti dere zawa aassanaas
\q2 Gala7aade dere
\q2 shaara maccassata
\q2 ulo daakkida.\x - \xo 1:13-15 \xt Er 49:1-6; Hizi 21:28-32; 25:1-7; Sofo 2:8-11\x*
\q1 
\v 14 Hessa gishshas Eraaba katama
\q2 gimbeta bolla
\q2 tani tama yeddana;
\q2 he tamay istta miixata maana.
\q2 Hessafe guye ola gallassan
\q2 waasoy darana;
\q2 olazikka gote carko mala
\q2 eesotana.
\q1 
\v 15 Istta kawoynne
\q2 daannati di7ettana» gees.
\c 2
\p 
\v 1 GODAY Mo7aabes,
\q1 «Mo7aabe asay zaari zaaridi
\q2 ooththida nagara gishshas
\q2 ta istta qaxxayontta aggike;
\q2 istti Eedoome kawo meqeththi
\q2 Bidinth gidana gakkanaas xuuggida.\x - \xo 2:1-3 \xt Isa 15:1—16:14; 25:10-12; Er 48:1-47; Hizi 25:8-11; Sofo 2:8-11\x*
\q1 
\v 2 Hessa gishshas tani Mo7aabe bolla
\q2 tama yeddana;
\q2 he tamay Qiriyaate
\q2 miixata maana.
\q2 Olanchchati maggulth,
\q2 waasonne zaye giiris sissishe
\q2 Mo7aabe asaa wodhi wursana.
\q1 
\v 3 Tani istta haariza kawozanne
\q2 daannata ubbaa dhayssana» gees.
\b
\q1 
\v 4 GODAY Yuhuda,
\q1 «Yuhuda asay
\q2 zaari zaaridi
\q2 ooththida nagara gishshas
\q2 ta istta qaxxayontta aggike;
\q2 istti ta woga kadhida;
\q2 ta azazotakka naagontta ixxida;
\q2 kase istta aawati goynnida eeqa
\q2 xoossata kaallidi istti balettida.
\q1 
\v 5 Hessa gishshas tani Yuhuda bolla
\q2 tama yeddana;
\q2 he tamay Yerusalaame
\q2 miixata maana» gees.
\p 
\v 6 GODAY Isra7eeles,
\q1 «Isra7eele asay
\q2 zaari zaaridi ooththida
\q2 nagara gishshas
\q2 ta istta qaxxayontta aggike.
\q2 Xillo asata biras,
\q2 metotidayssa toho
\q2 caammas bayzida.
\q1 
\v 7 Istti manqota gudulla bolla
\q2 genderisidi istta
\q2 hu7e yedhetteettes;
\q2 qohettidaytas geella pirdeettes;
\q2 aawaynne nay
\q2 issi maccassayra laymateettes;
\q2 istti hessaththo ooththi ooththidi
\q2 ta sunth tuniseettes.
\q1 
\v 8 Asappe oyso ekettida
\q2 may7o hiixxidi
\q2 Yarsho yarshizasoza
\q2 garsan aqeettes;
\q2 istti bantta xoossa keeththan
\q2 edasi ekkidi woyne ushshu
\q2 izan uyeettes.
\b
\q1 
\v 9 «Isttas adussateththay
\q2 ziga miththa mala;
\q2 minoteththayka xiidda mala
\q2 gidida Amoore asaa tani
\q2 intte sinththafe dhayssadis;
\q2 ayfontta mala
\q2 xaphoppe shodda diggadis.\x - \xo 2:9 \xt Zaare 3:8-11\x*
\q1 
\v 10 Tani inttes Amoore dere
\q2 biitta immanaas
\q2 inttena Gibxeppe kessadis;
\q2 oyddu tammu layth kumeth
\q2 bazzora kaaleththa
\q2 ehada laatissadis.
\q1 
\v 11 Qasseka tani intte
\q2 attuma nayta garsafe nabeta,
\q2 naateththata giddofe
\q2 naaziraaweta denththadis.
\q2 Isra7eele derezoo!
\q2 Hessi tumu gidennee?» gees.
\p 
\v 12 Xoossay, «Intte gidikko Naaziraaweta
\q2 woyne ushshu ushshideta;
\q2 nabetakka tinbite
\q2 yootontta mala azazideta.
\q1 
\v 13 Be7ite daro kath deexetti
\q2 caanettida gaarey
\q2 garsara diza miish liiqisiza mala
\q2 tanikka inttena liiqisana.
\q1 
\v 14 Pilata asi kessi ekki attenna;
\q2 minoykka ba minoteththan
\q2 maadettenna;
\q2 wolqqamaykka
\q2 ba shemppo ashshenna.
\q1 
\v 15 Wondafe oykkidaadey ba dizason
\q2 minni eqqidi ola zaarenna;
\q2 pilata olanchchayka
\q2 woxxi attenna;
\q2 toganchchayka ba shemppo ashshenna.
\q1 
\v 16 Ola qaratikka he gallas
\q2 gooro kallo baqatana» gees.
\c 3
\s1 Isra7eele Asaa Bolla Gakkana Hanqo
\p 
\v 1 Isra7eele asawu! Gibxeppe kezida Isra7eele asaas inttes GODAY yootida qaala hayssa siyite.
\p 
\v 2 Xoossay,
\q1 «Kumeththa alamen diza dere
\q2 ubbaafe ta inttena xalla dooradis;
\q2 intte ooththiza
\q2 nagara ubbaa gishshas
\q2 ta inttena qaxxayays» gees.
\q1 
\v 3 Nam7u asati oge issife baana giidi
\q2 qachchontta aggiko
\q2 issife baanaas dandayzoo?
\q1 
\v 4 Gaammoy wora giddon
\q2 aykko miza miish
\q2 shankkati demmontta dishe
\q2 coo mela xaaggi erizee?
\q2 Wodalla gaammoy
\q2 aykko miza miish
\q2 demmontta dishe ba dizason
\q2 coo mela ba qaala sissi erizee?
\q1 
\v 5 Yardey woykko gitey bayndason
\q2 coo mela gaden
\q2 kafoy oyketti erizee?
\q2 Woykko diizay issi miishshi bana
\q2 bochchontta dishin
\q2 coo mela piri erizee?
\q1 
\v 6 Katama giddon olas
\q2 zayey punettishin
\q2 babon kokkorontta asi di erizee?
\q2 GODAA sheney baynda dishin
\q2 katama bolla iita miishshi
\q2 gakki erizee?
\q1 
\v 7 GODAY ba xuura ba oosanchcha
\q2 nabetas koyrotti yootontta dishe
\q2 aykkoka ooththenna.
\q1 
\v 8 Gaammoy xaaggiin siyidi
\q2 dagammonttay oonee?
\q2 GODAY ba xuura izas yootiin
\q2 tinbite haasayonttay oonee?
\s1 Samaariya Kundeth
\p 
\v 9 Ashdoodeninne Gibxen diza
\q2 miixatan diza ubbaas,
\q2 «Samaariya zumata bolla shiiqite;
\q2 heen isttan oosettiza
\q2 gene oosonne
\q2 bul7aketizayssa xeellite»
\q2 gi awajjite.
\p 
\v 10 GODAY,
\q1 «Hayti dereti lo7o
\q2 ooso erettenna.
\q2 Makkallaninne
\q2 genen ekkida miishshan
\q2 ba miixa kunththeettes.
\q1 
\v 11 Hessa gishshas intte dere
\q2 morkkey worajjana;
\q2 intte miixata laallidi
\q2 intte keeththaaka bonqqana» gees.
\q1 
\v 12 GODAY,
\q2 «Heenththanchchay
\q2 gaammo doonappe
\q2 dors woththi ekkiza wode
\q2 dorsas nam7u gedata woykko
\q2 duuxa hayththata
\q2 woththi ekkiza mala
\q1 Samaariya biittan ishalon uttida
\q2 Isra7eele asaappe guuththati
\q2 xalla attana» gees.
\p 
\v 13 Salo GODAY,
\q1 «Hekko ane hayssa siyite!
\q2 Yaaqoobe zereththa bolla
\q2 markkattite.
\q1 
\v 14 Istti ooththida nagara gishshas
\q2 tani Isra7eele
\q2 asaa qaxxayiza wode
\q2 Beetelen diza
\q2 yarsho yarshizasohota
\q2 tani laallana;
\q2 yarshizasohota bolla diza
\q2 kaceti meqeretti kundana.\x - \xo 3:14 \xt 2Kawo 23:15\x*
\q1 
\v 15 Istti izan bonenne balgo diza
\q2 keeththata ubbaa
\q2 ta laalla dhayssana;
\q2 danggarsa zaalen
\q2 lo7eththi alleqissida
\q2 keeththati wurikka laalettana;
\q2 gita keeththati
\q2 wurikka dhayana» gees.
\c 4
\p 
\v 1 Dhiikettida Baasaane miizata mala intte asateththa ordisida Samaariya maccassatoo! Hayssa qaala siyite! Intte daaburanchchata kawushsheeta; manqota bollaka godateeta; intte azinata, «Nuus maththosiza ushshu ehite» geeta.
\p 
\v 2 Hessa gishshas GODAY ba geeshshateththan, «Inttes siidhen dafoy aadhdhiin intte baana wodey yaana; inttefe heen biitta bolla attidayti qasse manxakon oyketti biza mole mala oyketti baana.
\p 
\v 3 «Inttefe issoy issoy intte matan diza lukora gooshetti gooshetti kezidi gede Herimoonen yegettana» gi caaqqides.
\s1 Isra7eele Asay Bantta Balappe Simmibeettenna
\p 
\v 4 GODAY, «Isra7eele derezoo!
\q2 Beetele biidi nagara ooththite!
\q2 Gelgelakka biidi
\q2 nagara gujji ooththite!
\q2 gallas gallas
\q2 intte yarsho yarshite!
\q2 heedzdzanththo gallas gallas
\q2 intte asraata immite.
\q1 
\v 5 Intte ooththanaas koyzay
\q2 hessa gidida gishshas
\q2 irshoy izan diza uketh
\q2 galata yarsho shiishshite;
\q2 intte hessa intte shene mala
\q2 shiishshiza gishshas
\q2 izan ceeqettite» gees.
\p 
\v 6 «Inttes doonan baadhana kaththara ta dhayssada intte katamatan ubbaan kosha yeddadis. Intte gidikko haa taakko simmibeekketa.
\v 7 Intte kaththay gakkanaappe buro heedzdzu aginay dishin sinththata ta inttes iray bukkontta mala diggadis; issi kataman bukkishin hara kataman bukkontta mala diggadis; issi gaden bukkishin hankko issaa gaden iray dhayiin melides.
\v 8 Asay haath uyanaas koyishe ha katamappe he katama bides; gido attiin baas gidiza haaththe demmontta aggida gishshas uyidi alanaas dandaybeettenna; intteka taakko simmibeekketa.
\p 
\v 9 «Intte kaththa melissiza harge ta kiittadis; intte intte atakiltenne woyne miththata, balasenne wogara miththata ubbaa booley mides; gido attiin intte haa taakko simmibeekketa» gees.
\p 
\v 10 «Ta kase Gibxe biitta bolla yeddida iita hargeza mala harge intte bolla yeddadis; intte naateththa nayta mashshan hayqqana mala ooththadis; intte paratakka di7ettana mala ta ooththadis; intte dizason hayqqida asa aha xinqqoy intte siidhe tuccides; intte gidikko haa taakko simmibeekketa.
\v 11 Sodoomenne Gamoora kase ta dhayssida mala inttefe darotakka ta dhayssadis; intte attidaytikka tamay mishin attida miththa durca mala gidideta shin intte haa taakko simmibeekketa.\x - \xo 4:11 \xt Medhe 19:24\x*
\q1 
\v 12 «Intteno Isra7eele asatoo
\q2 tanikka intte bolla
\q2 hessaththo ooththana;
\q2 hessa gishshas intte tanara
\q2 intte GODAARA gayttanaas
\q2 ane giigettite!» gees.
\q1 
\v 13 Zumata ooththidaadey
\q2 carkota medhdhidaadey
\q2 ba qoppidayssa asas qonccisizay
\q2 gallassa poo7o
\q2 gede dhuman laammizay
\q2 biitta bolla dhoqqasohon
\q2 hemettizayssa
\q2 sunththay GODAA Salo Xoossa.
\c 5
\s1 Isra7eele Asaa Maareteth
\q1 
\v 1 Isra7eele asawu! Intte gishshas
\q2 ta zilaliza zilas siyite.
\q1 
\v 2 «Geela7oya Isra7eeley kundadus;
\q2 nam7anththo dendanaas
\q2 dandayukku;
\q2 izo maaddi denththanay
\q2 baynda gishshas
\q2 iza barkka ba deren
\q2 kunda attana.»
\p 
\v 3 Ubbaa Haariza GODAY,
\q2 «Isra7eele katama issineyppe
\q2 1,000 olanchchati olas baanashin
\q2 isttafe hayqqontta paxa attanay
\q2 100 asata xalla gidana;
\q2 hara katamappeka 100
\q2 ola asati olas baanashin
\q2 isttafe 10 asi xalla
\q2 simmi yaana» gides.
\p 
\v 4 GODAY Isra7eele asaas,
\q1 «Isra7eele asawu!
\q2 Haa taakko simmite;
\q2 intte hayqqontta de7ana.
\q1 
\v 5 Intte Bersaabehe boopite;
\q2 Beeteley laalettada
\q2 mulera dhayana;
\q2 Gelgelan diza asay di7ettana;
\q2 hessa gishshas Beetele gidiin
\q2 woykko Gelgela boopite» gides.
\q1 
\v 6 Haa Xoossaako simmite;
\q2 histtiko intte shemppora
\q2 paxa de7ana;
\q2 akkay giikko Xoossi
\q2 tama mala
\q2 Isra7eele deraa maana;
\q2 Beetelen dizaytakka
\q2 tamay maana;
\q2 he tama toyssanay
\q2 isttas beettenna.
\b
\q1 
\v 7 Intteno pirda geellasizaytoo!
\q2 Tumakka gede wordon
\q2 laammizayto
\q2 inttes aayye ana!
\q1 
\v 8 Piliyaadise geetettiza laappun
\q2 xoolinttetanne
\q2 Oryoone geetettiza
\q2 issi bolla diza
\q2 xoolintteta medhdhiday
\q2 gallassaa omarsan,
\q2 omarsa gallassan laammizay,
\q2 abba haath azazidi
\q2 biitta bolla gogissizay,\x - \xo 5:8 \xt Iyo 9:9; 38:31\x*
\q2 
\v 9 wolqqamatanne istta miixata
\q2 laalli dhayssizay iza;
\q2 izas sunththayka Xoossa.
\q1 
\v 10 Intte qasse inttena pirdason
\q2 hanqizaade ixxeeta;
\q2 tumu haasayzaadekka kadheeta.
\q1 
\v 11 Manqota un7eththeeta;
\q2 istta wolqqara kath giiriseeta;
\q2 inttes masettida shuchchafe
\q2 keeth keexxideta shin
\q2 he keeththan deekketa.
\q2 Aradda biittan woyne miththa
\q2 tokkideta shin izappe
\q2 agettida woyne ushshu uyekketa.
\q1 
\v 12 Intte qohoy ay mala darokkonne
\q2 intte nagaray ay mala deexokko
\q2 ta erays;
\q2 intte xillo asata un7eththeeta;
\q2 matta7e ekkidi pirdason
\q2 manqotas geella pirdeeta.
\q1 
\v 13 Hessa gishshas he wode
\q2 wodey iita gidida gishshas
\q2 akeekay diza asi co7u gees.
\p 
\v 14 Intte shemppora paxa de7ana mala lo7oppe attiin iita ooththofte; intte hessaththo ooththiko intte gida mala GODAY Salo Xoossay inttenara gidana.
\v 15 Iita miish ixxite; lo7o gididaaz dosite; pirda pirdizason tumu pirda geellasopite. GODAY Salo Xoossay attida Isra7eele asaa maaranaakko oonee erizay?
\p 
\v 16 Hessa gishshas GODAY Salo Xoossay,
\q1 «Oge bollanne dubbushay dizason
\q2 ubbaan waasoynne yeehoy
\q2 siyettana;
\q2 goshshanchchati koyssas
\q2 zilalizayti yeehos xeygettana.
\q1 
\v 17 Woyne miththi tokettizason
\q2 ubbaan yeeho xalla gidana;
\q2 hessika wuri hananay ta intte
\q2 giddora aadhdhiza gishshassa» gees.
\s1 Xoossa Pirda Gallassa
\b
\q1 
\v 18 Intteno GODAA gallas naagizaytoo!
\q2 Inttes aayye ana!
\q2 He gallassay dhumappe attiin
\q2 poo7o gallas gidontta gishshas
\q2 intte ays he gallassa koyeetii?
\q1 
\v 19 He gallassay asi gaammofe attanaas
\q2 qotettishe zardora gaaggiza mala
\q2 woykko kessi ekki baso gelidi
\q2 ba kushen keeththa goda oykkiin
\q2 shooshshi dukkida mala hanana.
\q1 
\v 20 GODAY pirdiza gallassay
\q2 inttes dhumappe attiin
\q2 poo7o gidenna;
\q2 he gallassay izan
\q2 aykko poo7oykka baynda
\q2 girdi gida dhuma gidana.
\b
\q1 
\v 21 «Tani intte layththan
\q2 layththan bonchchiza
\q2 ba7aaleza kadhayssinne ixxays;
\q2 intte goynos shiiqiza shiiqoykka
\q2 tana ufayssenna.
\q1 
\v 22 Taman xuugettiza yarshonne
\q2 kaththa yarsho
\q2 intte taas shiishshikokka
\q2 ta hessa inttefe ekkike;
\q2 dhiikettida intte mehetappe
\q2 intte taas issifeteththa
\q2 yarshos shiishshiko
\q2 ta iza ayfenka xeellike.\x - \xo 5:21-22 \xt Isa 1:11-14\x*
\q1 
\v 23 Intte yexxishe
\q2 ta hayththan kaccofte;
\q2 intte diiththa giiris
\q2 ta siyanaas koykke.
\q1 
\v 24 Gido attiin tumu pirday
\q2 goggiza haaththa mala;
\q2 xilloteththika miccontta
\q2 pultto mala goggo.
\b
\q1 
\v 25 «Isra7eele asawu!
\q2 Tumappe intte oyddu tammu
\q2 layth bazzo biittan diza wode
\q2 tumu yarshonne kaththa xeera
\q2 taas shiishshidetii?\x - \xo 5:25-27 \xt Hawa 7:42-43\x*
\q1 
\v 26 Intte inttes ooththida,
\q2 ‹Kawo Zakute› geetettiza
\q2 eeqa xoossaza;
\q2 qasseka, ‹Kewene› geetettiza
\q2 intte medhdhi kessida xoolintte
\q2 misatiza eeqa xoossata tookkideta.
\m 
\v 27 Tani inttena Damasqofe gede haassa gooddana» gees GODAY Salo Xoossay.
\c 6
\s1 Isra7eele Qaxxayeteth
\p 
\v 1 Xiyoonen badhdhi gi uttidaytoo! Samaariya zuma bolla hirgay baynda dizaytoo! Isra7eele asay maado koyidi intteko yizaytoo! Intteno dere halaqatoo! Inttes aayye ana!
\v 2 Ane intte gede Kalanahe katama biidi xeellite; heeppeka aadhdhidi Hamaate geetetti xeygettiza gita katamayonne duge Filisxeeme katama Geete wodhdhite; istti intte nam7u kawoteththatappe lo7izoo? Istta biittay intte biittafe aakkizee?
\v 3 Intte qasse, «Iita gallassi elle gakkenna» giza qofan intte daannateththan gene ooso eesoseeta.
\v 4 Intte danggarsa zaaleppe oosettida algan ichcheeta; ohala laaqqa ashonne mara asho mishe soofa bolla utti shempeeta.
\v 5 Dawite mala yeththa miish inttes giigsidi bagananinne dumma dumma mazamure yexxizaytoo!
\v 6 Woyne ushshu birillera gidontta otora uyizaytoo! Keehi al7o gidida shitto tiyettizaytoo! Isra7eele deraa bolla gakkida meto gishshas qadhettonttayto inttena aayye ana!
\q1 
\v 7 Hessa gishshas heera asappe
\q2 koyro intte di7ettana;
\q2 he wode intte kase ufayssan
\q2 guppiza gufaynne
\q2 badhdhi gi diza duussi attana.
\p 
\v 8 GODAY Salo Xoossay,
\q1 «Isra7eele asa otoreteththaa
\q2 tani harassettadis;
\q2 istta miixatikka
\q2 tana shuunneettes;
\q2 hessa gishshas tani katamayonne
\q2 izin dizayta ubbaa
\q2 morkkes aaththa immana» giidi
\q2 barkka banan caaqqides.
\p 
\v 9 Issi keeththan tammati attiko he attidaytikka hayqqana.
\v 10 Hayqqidaytappe issaades mata dabbo gididaadeynne moogo woga polizaadey ahaza keeththafe kessi efana; he wode izaadey soon diza issi as xeygidi, «Nenara attida hara asi dizee?» giidi iza oychchana shin izaadey qasse, «Attida asi oonikka deenna» gaana. Oychchizayssika zaaridi, «GODAA nu Xoossa sunth xeyganaas bessontta gishshas co7u ga!» gaana.
\q1 
\v 11 GODAA azazon
\q2 wogga keeththati laalettana;
\q2 guuththa keeththatikka
\q2 laaletti attana.
\q1 
\v 12 Paray shuchcha bolla togettizee?
\q2 Goshshanchchay abba giddon
\q2 boora waaxi goyanaas
\q2 dandayzee?
\q2 Intte gidikko
\q2 pirda marzen laammideta;
\q2 tumakka gede camon shirdeta.
\q1 
\v 13 Intte Lodibaare katama
\q2 xoonida gishshas ufayettideta;\f + \fr 6:13 \ft Lodibaare geetettizayssi katama sunth gidishin Ibraaweta qaalara hada miish guussa.\f*
\q2 «Qarnayme katamayo
\q2 nuni nu wolqqan oykkidos»
\q2 gidi ceeqetteeta.\f + \fr 6:13 \ft Qarnayme geetettizayssi guuththa katama sunththa; Ibraaweta qaalara kacey wolqqa leemiso gidi beettees.\f*
\p 
\v 14 GODAY Salo Xoossay,
\q1 «Isra7eele asawu!
\q2 Tani intte bolla
\q2 hara wolqqama dere denththana;
\q2 hessika pudeha baggafe
\q2 Hamaate pengefe doommidi
\q2 dugeha baggara Arabe
\q2 shoobba gakkanaas inttena
\q2 un7eththana» gees.
\c 7
\s1 Amoxey Ajjuutan Be7ida Boole
\p 
\v 1 GODAY ajjuutan booley yaanayssa tana bessides; hekko kawo kaththi maxetti wuridaappe guye geedora caarida azabba kaththa bolla Xoossi maate booley kezana mala ooththides.
\v 2 Boolezikka biitta bolla diza cilila ubbaa pitti midayssa tani beyada, «Ubbaafe Wolqqama GODAWU! Ne dere qohoza maararkkii! Ne dere Isra7eeles wolqqay baynda gishshas izi hayssa wostti eqetti dandayanee?» ga woossadis.
\p 
\v 3 GODAYKKA isttas mishettidi, «Hayssi ne be7izayssi polettenna» giidi taas yootides.
\s1 Amoxey Ajjuutan Be7ida Pirda Tama
\p 
\v 4 Ubbaafe Wolqqama GODAY tana ajjuuta bessides; GODAY qaxxayanaas tama pirda yeddides; tamazikka wogga gita abbaa miichchidi biitta muus oykkides.
\v 5 He wode tani, «Ubbaafe Wolqqama GODAWU! Hayssa tamaa toyssarkkii! Ne dere Isra7eeles wolqqay baynda gishshas izi hayssa wostti eqetti dandayanee?» ga woossadis.
\p 
\v 6 GODAYKKA isttas mishettidi, «Hayssi ne be7izayssi polettenna» giidi taas yootides.
\s1 Amoxey Ajjuutan Be7ida Tumbe
\p 
\v 7 GODAY tana hara ajjuuta bessides; tumben sitti gi oosettida gimbe achchan Xoossi ba kushen tumbe oykki eqqidayssa beyadis.\f + \fr 7:7 \ft Tumbey gimbe gimbizayti gimbeza sitti histti gimbanaas go7ettiza miish.\f*\fig Gimbe gimbiza tumbe|alt="Builder using plumbline" src="HK00126B.TIF" size="span" ref="7:7"\fig*
\v 8 Izikka, «Amoxe! Hessi ne be7izayssi izi aazee?» gi oychchides. Tanikka, «Tumbeko!» gadis. GODAY zaaridi taas, «Tumben sitti gi oosettontta gimbe mala ta dere Isra7eeley geellattides; hessa gishshas hayssi tumbezi Isra7eele nayta geellateththaa bessiza leemiso; tanikka istta qaxxayontta aggike.
\v 9 Yisaaqinne izas naaza nayti goynniza dhoqqasohoti laalettana; Isra7eele nayti goynnizasohoti laalettana; Iyorba7aame kawoteth tani mulera dhayssana» gides.
\s1 Amoxenne Amasiyaase
\p 
\v 10 Beetele qeese gidida Amasiyaasi Isra7eele kawo Iyorba7aamekko, «Hekko Amoxey Isra7eele asaa giddon uttidi ne bolla asaa denththeththees; hessa mala ooson biitta shiri yeggees.
\v 11 Izikka, ‹Iyorba7aameykka olan hayqqana; Isra7eele derey ba dereppe di7etti baana› gees» gi kiittides.
\p 
\v 12 Amasiyaasi Amoxes, «Nenoo ajjuuta be7izayssoo! Hayssafe denda kichcha; duge Yuhuda biitta baada heen tinbite yootashe nees miza miish demma.
\v 13 Beeteley gidikko kawoy goynnizasonne kawo duussaso gidida gishshas tinbite yootoppa» gides.
\p 
\v 14 Amoxey Amasiyaasas, «Tani wude mehe heemmizaadenne eththa ayfe maxizaade attiin ta hu7es nabe woykko nabe naa gidikke.\f + \fr 7:14 \fqa Eththa ayfe: \ft Eththa ayfe geetettizayssa issi issi bagga gamoththo qaalan boobba ayfe geetettees.\f*
\v 15 Gido attiin GODAY mehe heemmizasohoppe tana xeygidi, ‹Ba! Ta dere Isra7eeles tinbite yoota› giidi azaziday GODAA.
\p 
\v 16 «Ha7ikka GODAY nena gizayssa siya;
\q2 neni tana, ‹Isra7eele asaa bolla
\q2 tinbite yootoppa;
\q2 Yisaaqa zereth gidida Isra7eele
\q2 derezakka sabbakoppa›
\q2 ga diggadasa.
\q1 
\v 17 Hessa gishshas amasiyaasa!
\q2 Ne gishshas GODAY,
\q2 ‹Ne machcheya katama giddon
\q2 layma maccas gidana;
\q2 nees macca naytinne attuma
\q2 naytikka olan hayqqana;
\q2 allagati ne biitta
\q2 wodoron wadhdhi
\q2 gishetti ekkana;
\q2 nenikka allaga biittan hayqqana;
\q2 Isra7eele asay ba biittafe
\q2 di7ettidi allaga
\q2 dere baana› gees» gi yootides.
\c 8
\s1 Amoxey Ajjuutan Be7ida Teeray Kumida Keeshe
\p 
\v 1 Ubbaafe Wolqqama GODAY tana hara ajjuuta bessides; hessika teeray izan kumi diza keeshe.
\v 2 GODAY tana, «Hessi ne be7izayssi aazee?» gi oychchides; tanikka izas, «Teerara diza daachcho beyays» gadis; qasseka Xoossi taas, «Ta dere Isra7eeles wurseththi gakkides; hayssafe guyen tani istta qaxxayontta aggike.
\p 
\v 3 «Istti Xoossa Keeththan sissiza yeththay he wode yeehon laamettana; daro asa ahay awan awanka kundi attana; awanka coo yegetti attana» gees.
\s1 Isra7eele Kundeth
\q1 
\v 4 Intteno metotida asa qohizaytoo!
\q2 Qasse manqota biittafe dhayssana
\q2 koyzaytoo! Hayssa siyite!
\q1 
\v 5 Intte, «Nuni nu kaththa
\q2 bayzana mala
\q2 agina xeeron bonchchiza
\q2 ba7aaley ayde aadhdhaneeshaa!
\q2 Nuni kath giya gelththanaas
\q2 sambataykka nuus ayde
\q2 aadhdhaneeshaa!
\q2 He ba7aaley aadhdhiko
\q2 nuni maka
\q2 miishsha guuththidi
\q2 al7o waagan bayzana;
\q2 qasseka wordo meezaanen
\q2 asaa baleththana.
\q1 
\v 6 Gistte harqqoka muuruta
\q2 gistte waagan bayzana;
\q2 manqota biran, metotidaytakka
\q2 toho caamman shammana» geeta.
\p 
\v 7 Yaaqoobeynne iza zereththati izan ceeqettiza GODAY, «Istti ooththida ooso ubbaa tani balikke.
\v 8 Hayssa geedon biittay buro qaaxxana; biittay bolla dizay wurikka yeekkana; Abbaye shaafay kixxidi guummizayssaththo biitta ubbay qaaththi yoshikuyoshikana» giidi barkka banan caaqqides.
\p 
\v 9 Ubbaafe Wolqqama GODAY, «He wode tani gallassa seetan awa arshe wulsana; gallassa seetan gade dhumisana.
\v 10 Intte layththan layththan bonchchiza ba7aaleza yeehon laammana; intte yexxiza yeththaaka waason laammana; diza pexi issi nay hayqqiin camo yeeho yeekkiza asa mala intte intte hu7e binana buucidi maaqa may7ana mala tani inttena ooththana; he wurseththa gallassay camo gallas gidana.
\m 
\v 11 Hekko tani biitta bolla kosha ehana wodey yaana;
\q2 hessika asay Xoossa qaala
\q2 siyana gafanne
\q2 saamo attiin kaththa gafanne
\q2 haaththa saamo gidenna.
\q1 
\v 12 Derey wuri pudehappe
\q2 dugeha gakkanaas
\q2 arshey mokkizasoppe
\q2 wullizaso gakkanaas
\q2 GODAA qaala kosh
\q2 yaanne haa yeemottanashin
\q2 demmenna.
\m 
\v 13 He wode lo7o geela7otinne
\q2 mino panththati
\q2 saamoppe dendanayssan
\q2 daaburana.
\q1 
\v 14 Samaariya deren, ‹Ashamo›
\q2 geetetta xeygettiza
\q2 eeqa xoossayn caaqqizayti,
\q2 ‹Daane xoossay beyiin›
\q2 woykko, ‹Bersaabehe
\q2 xoossay beyiin›
\q2 gi caaqqizayti wurikka kundana;
\q2 ba kundidasohoppe mulekka
\q2 dendanaas dandayettenna» gees.
\c 9
\s1 Isra7eele Bolla Yaana Pirda
\p 
\v 1 GODAY yarsho yarshizasoza millen eqqi dishin ta beyadis;
\q2 izikka tana,
\q2 «Xoossa Keeththaa yochchay
\q2 qaaxxana gakkanaas
\q2 keeththa qustte
\q2 shoca laalladanne
\q2 asaa bolla kundana mala ooththa;
\q2 hessafekka attidayta
\q2 tani istta mashshara
\q2 wodha dhayssana;
\q2 isttafe oonikka baqatenna;
\q2 baqatikkoka taappe
\q2 kessi ekki attenna.
\q1 
\v 2 Istti duufo bookki gelidaakkoka
\q2 ta kushey
\q2 istta heeppe shoddi haa kessana;
\q2 istti pude salo kezidaakkoka
\q2 tani istta heeppe
\q2 haa duge goochcha woththana.
\q1 
\v 3 Istti pude Qarmeloose zumaa bolla
\q2 kezi qotettidaakkoka
\q2 ta kaaletta baada
\q2 istta heeppe woththana;
\q2 istti duge ciimma abba giddo
\q2 gelidi taappe qotettizaakkoka
\q2 heen istta shooshshi dukkana mala
\q2 ta azazana.
\q1 
\v 4 Istti ba morkketa kushen
\q2 di7etti biikkoka
\q2 heen istti mashshan
\q2 hayqqana mala
\q2 ta azazana;
\q2 tani istta bolla
\q2 ta ayfe lo7os gidontta
\q2 iitas zaarana» gi azazides.
\q1 
\v 5 Ubbaa Haariza GODAY
\q2 izi biittayo bochchees;
\q2 izakka seerawus;
\q2 izin diza ubbay yeekkees;
\q2 Nayle shaafay
\q2 kixxi guummiza mala
\q2 biitta ubbay qaaxxees;
\q2 qasse zaaridi kixa haaththi
\q2 wodhdhiza mala wodhdhana.
\q1 
\v 6 Ba duussaso salo ooththiday,
\q2 salokka sa7appe bollan
\q2 minththiday,
\q2 abba haath azazidi
\q2 biitta bolla gogissizay
\q2 izas sunththay GODAA.
\p 
\v 7 GODAY, «Isra7eele asawu!
\q2 Intte taas
\q2 Tophphiya asa mala gidekketii?
\q2 Tani inttena
\q2 Gibxeppe kessoyssaththo
\q2 Filisxeeme asaa Qarxeeseppe
\q2 qasse Sooriya as
\q2 Qiireppe kessabeekkinaa?
\q1 
\v 8 Tani Ubbaa Haariza GODAY
\q2 gede nagaranchcha
\q2 Isra7eele asaa
\q2 kawoteththaako xeellays;
\q2 ta iza biittafe mulera dhayssana;
\q2 gido attiin Yaaqoobe zereth
\q2 ubbaa dhayssike» gees.
\q1 
\v 9 «Be7ite kath
\q2 zayzaren zayzariza mala
\q2 Isra7eele asaa
\q2 Ayzaabe kawoteththa
\q2 giddon zayzarana mala
\q2 ta azazana;
\q2 gido attiin isttafe issaadeyka
\q2 wora wodhdhi dhayenna.
\q1 
\v 10 ‹Nu bolla aykko iitaykka gakkenna
\q2 woykko nuna bochchenna› giza
\q2 ta dere asaa garsan diza
\q2 nagaranchchati ubbay
\q2 olan hayqqana» gees GODAY.
\s1 Isra7eele Asaa Simo Hidota
\p 
\v 11 «Coo kundi laalettida keeththa mala gidida
\q2 Dawite zereththata kawoteththas
\q2 tani zaara essana wodey yaana;
\q2 tani gimbeza zaara gimbana;
\q2 laalettidayssaka ooraxissana;
\q2 kaseyssaththo zaara ooththana.
\q1 
\v 12 Hessaththoka Eedoome deren
\q2 attidaytanne
\q2 ta sunththan xeygettida dereta
\q2 ubbaa istti laattana»
\q2 gees GODAY.\x - \xo 9:11-12 \xt Hawa 15:16-18\x*
\q1 
\v 13 «Kath maxizayti maxi wursontta
\q2 dishin goshsha wodey gakkees;
\q2 woyne ayfe gum7izaadey
\q2 gum7i giigontta dishin
\q2 woyne puute
\q2 tokkiza wodey gakkees;
\q2 he wode mal7iza lo7o woyne
\q2 ushshi zumaappe pulttana;
\q2 zumbullatappeka goggana.
\q1 
\v 14 Di7etti bida Isra7eele asaa
\q2 haa istta dere zaara ehana;
\q2 laalettida katamata zaari
\q2 keexxidi izan de7ana;
\q2 istti woyne tokkidi
\q2 izappe agettida ushshu uyana;
\q2 dumma dumma ayfiza mith
\q2 tokkidi iza ayfe maana.
\q1 
\v 15 Ta dere Isra7eele asaa
\q2 tani kase istta biittan
\q2 zaarada tokkana;
\q2 tani isttas immida biittafe
\q2 istti nam7anththo dhoqalletti
\q2 dhayettenna»
\q2 gees GODAY salo Xoossay.
