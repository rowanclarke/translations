\v 34 Después \w de|strong="H1121"\w* Ahitofel seguían \w Joiada|strong="H3077"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Benaía|strong="H1141"\w*, y Abiatar.  
\p \w Joab|strong="H3097"\w* \w era|strong="H1121"\w* \w el|strong="H1121"\w* \w general|strong="H8269"\w* del \w ejército|strong="H6635"\w* del \w rey|strong="H4428"\w*.   
\c 28  
\s1 Instrucciones de David para la Casa de \nd Yavé\nd*  
\p
\v 1 \w David|strong="H1732"\w* congregó \w en|strong="H5973"\w* Jerusalén \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*: \w los|strong="H1121"\w* \w jefes|strong="H8269"\w* \w de|strong="H5973"\w* \w tribus|strong="H7626"\w*, \w de|strong="H5973"\w* las divisiones \w que|strong="H1121"\w* servían \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, \w de|strong="H5973"\w* millares y \w de|strong="H5973"\w* centenas, \w los|strong="H1121"\w* administradores \w de|strong="H5973"\w* \w todo|strong="H3605"\w* \w el|strong="H5973"\w* patrimonio y \w hacienda|strong="H7399"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w* y \w de|strong="H5973"\w* sus \w hijos|strong="H1121"\w*, \w junto|strong="H5973"\w* \w con|strong="H5973"\w* \w los|strong="H1121"\w* oficiales y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* guerreros \w valientes|strong="H1368"\w*.   
\p
\v 2 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w se|strong="H5921"\w* puso \w en|strong="H5921"\w* \w pie|strong="H7272"\w* \w y|strong="H5921"\w* dijo: Escúchenme, hermanos míos \w y|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w mío|strong="H5921"\w*. Yo intenté \w edificar|strong="H1129"\w* una \w Casa|strong="H1004"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cual|strong="H5973"\w* reposara \w el|strong="H5921"\w* Arca \w del|strong="H5921"\w* \w Pacto|strong="H1285"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w y|strong="H5921"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w estrado|strong="H1916"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w pies|strong="H7272"\w* \w de|strong="H5921"\w* nuestro \nd ʼElohim\nd*. Preparé todo \w para|strong="H5921"\w* edificarla.  
\v 3 \w Pero|strong="H3588"\w* \nd ʼElohim\nd* \w me|strong="H3588"\w* dijo: \wj \+w No|strong="H3808"\+w* \+w edificarás|strong="H1129"\+w* \+w Casa|strong="H1004"\+w* \+w a|strong="H3068"\+w* mi \+w Nombre|strong="H8034"\+w*, \+w porque|strong="H3588"\+w* eres hombre \+w de|strong="H3588"\+w* \+w guerras|strong="H4421"\+w* \+w y|strong="H3588"\+w* has \+w derramado|strong="H8210"\+w* \+w sangre|strong="H1818"\+w*.\wj*   
\p
\v 4 Sin embargo \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w me|strong="H5921"\w* escogió \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* padre \w para|strong="H5921"\w* ser \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w para|strong="H5921"\w* \w siempre|strong="H5769"\w*. \w Porque|strong="H3588"\w* escogió \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w como|strong="H3588"\w* caudillo, \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w familia|strong="H1004"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* padre. \w De|strong="H5921"\w* \w entre|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* padre \w se|strong="H1961"\w* agradó \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w para|strong="H5921"\w* designarme \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*.   
\p
\v 5 \w De|strong="H5921"\w* \w entre|strong="H5921"\w* \w todos|strong="H3605"\w* \w mis|strong="H5414"\w* \w hijos|strong="H1121"\w* (\w porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w me|strong="H5921"\w* \w dio|strong="H5414"\w* \w muchos|strong="H7227"\w* \w hijos|strong="H1121"\w*), escogió \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* siente \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w del|strong="H5921"\w* \w reino|strong="H4438"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w en|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 6 \w Y|strong="H3068"\w* \w me|strong="H3588"\w* dijo: \wj Tu \+w hijo|strong="H1121"\+w* \+w Salomón|strong="H8010"\+w* \+w edificará|strong="H1129"\+w* \+w mi|strong="H1961"\+w* \+w Casa|strong="H1004"\+w* \+w y|strong="H3588"\+w* mis \+w patios|strong="H2691"\+w*, \+w porque|strong="H3588"\+w* \+w lo|strong="H1931"\+w* escogí \+w como|strong="H3588"\+w* \+w hijo|strong="H1121"\+w*, \+w y|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w le|strong="H1931"\+w* \+w seré|strong="H1961"\+w* padre.\wj*  
\v 7 \wj Si se mantiene \+w firme|strong="H3559"\+w* \+w en|strong="H5704"\+w* cumplir mis \+w Mandamientos|strong="H4687"\+w* \+w y|strong="H5704"\+w* mis Decretos, \+w como|strong="H5704"\+w* \+w hoy|strong="H3117"\+w*, estableceré su \+w reino|strong="H4438"\+w* \+w para|strong="H5704"\+w* \+w siempre|strong="H5769"\+w*.\wj*   
\p
\v 8 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, ante \w los|strong="H1121"\w* \w ojos|strong="H5869"\w* \w de|strong="H5704"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w congregación|strong="H6951"\w* \w de|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w y|strong="H5704"\w* \w a|strong="H3068"\w* oídos \w de|strong="H5704"\w* nuestro \nd ʼElohim\nd*: \w Guarden|strong="H8104"\w* \w y|strong="H5704"\w* observen \w todos|strong="H3605"\w* \w los|strong="H1121"\w* Preceptos \w de|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd*, \w para|strong="H5704"\w* \w que|strong="H6258"\w* \w posean|strong="H3423"\w* \w la|strong="H8104"\w* \w buena|strong="H2896"\w* tierra \w y|strong="H5704"\w* \w la|strong="H8104"\w* dejen \w como|strong="H5704"\w* herencia \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w que|strong="H6258"\w* vengan \w después|strong="H5704"\w* \w de|strong="H5704"\w* ustedes \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.   
\p
\v 9 \w Y|strong="H3068"\w* tú, \w hijo|strong="H1121"\w* mío \w Salomón|strong="H8010"\w*, \w reconoce|strong="H3045"\w* al \nd ʼElohim\nd* \w de|strong="H3588"\w* tu padre \w y|strong="H3588"\w* sírvele \w con|strong="H3588"\w* \w corazón|strong="H3820"\w* \w perfecto|strong="H8003"\w* \w y|strong="H3588"\w* \w ánimo|strong="H5315"\w* \w voluntario|strong="H2655"\w*. \w Porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w escudriña|strong="H1875"\w* \w los|strong="H1121"\w* \w corazones|strong="H3824"\w* \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w y|strong="H3588"\w* \w conoce|strong="H3045"\w* \w toda|strong="H3605"\w* intención \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w pensamientos|strong="H4284"\w*. \w Si|strong="H3588"\w* \w lo|strong="H3605"\w* buscas, \w Él|strong="H3588"\w* \w te|strong="H3588"\w* \w dejará|strong="H5800"\w* hallarlo. \w Si|strong="H3588"\w* \w lo|strong="H3605"\w* abandonas, \w te|strong="H3588"\w* rechazará \w para|strong="H3588"\w* \w siempre|strong="H3605"\w*.  
\v 10 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, considera \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w te|strong="H3588"\w* escogió \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w edifiques|strong="H1129"\w* una \w Casa|strong="H1004"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w Santuario|strong="H4720"\w*. ¡\w Esfuérzate|strong="H2388"\w* \w y|strong="H3588"\w* actúa!   
\p
\v 11 \w David|strong="H1732"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Salomón|strong="H8010"\w* \w el|strong="H1121"\w* diseño del patio, sus edificios, sus almacenes, sus aposentos altos, cámaras \w interiores|strong="H6442"\w* y del Lugar Santísimo,  
\v 12 \w junto|strong="H5973"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* diseño \w de|strong="H5973"\w* \w todas|strong="H3605"\w* las cosas \w que|strong="H1961"\w* \w tenía|strong="H1961"\w* \w en|strong="H5973"\w* mente \w para|strong="H1961"\w* \w los|strong="H3605"\w* \w patios|strong="H2691"\w* \w de|strong="H5973"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H5973"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w todas|strong="H3605"\w* las \w cámaras|strong="H3957"\w* \w alrededor|strong="H5439"\w*, \w los|strong="H3605"\w* tesoros \w de|strong="H5973"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H5973"\w* \nd ʼElohim\nd* y \w los|strong="H3605"\w* tesoros \w de|strong="H5973"\w* \w los|strong="H3605"\w* objetos consagrados,  
\v 13 las secciones de \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* y \w los|strong="H3605"\w* \w levitas|strong="H3881"\w*, para \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* del \w ministerio|strong="H5656"\w* de \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*, y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios del \w ministerio|strong="H5656"\w*.   
\p
\v 14 Dio \w oro|strong="H2091"\w* en \w peso|strong="H4948"\w* \w para|strong="H4948"\w* \w lo|strong="H3605"\w* de \w oro|strong="H2091"\w*, \w para|strong="H4948"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios de \w cada|strong="H3605"\w* servicio, y \w plata|strong="H3701"\w* en \w peso|strong="H4948"\w* \w para|strong="H4948"\w* \w lo|strong="H3605"\w* de \w plata|strong="H3701"\w*, \w para|strong="H4948"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios de \w cada|strong="H3605"\w* servicio,  
\v 15 \w oro|strong="H2091"\w* en \w peso|strong="H4948"\w* \w para|strong="H4948"\w* los candelabros de \w oro|strong="H2091"\w* y sus \w lámparas|strong="H5216"\w*, según el \w peso|strong="H4948"\w* de cada candelabro y sus \w lámparas|strong="H5216"\w*, y \w plata|strong="H3701"\w* en \w peso|strong="H4948"\w* \w para|strong="H4948"\w* los candelabros de \w plata|strong="H3701"\w*, según el \w peso|strong="H4948"\w* de cada candelabro y sus \w lámparas|strong="H5216"\w*, conforme al servicio de cada candelabro.   
\p
\v 16 \w También|strong="H7979"\w* entregó el \w oro|strong="H2091"\w* por \w peso|strong="H4948"\w* necesario \w para|strong="H4948"\w* cada una de las \w mesas|strong="H7979"\w* de los Panes de la Presencia, \w plata|strong="H3701"\w* \w para|strong="H4948"\w* las \w mesas|strong="H7979"\w* de \w plata|strong="H3701"\w*,  
