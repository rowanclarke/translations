\id EZR
\h ئەزرا
\toc1 ئەزرا
\toc2 ئەزرا
\toc3 ئەزرا
\mt1 ئەزرا
\c 1
\s1 پادىشاھ قورەشنىڭ پەرۋەردىگار ئۈچۈن ئىبادەتخانا سېلىشقا يارلىق چۈشۈرۈشى
\r 2تار. 36‏:23،22؛ يەر. 25‏:12؛ 29‏:10؛ دان. 9‏:2
\m 
\v 1 پارس پادىشاھى قورەشنىڭ بىرىنچى يىلى، پەرۋەردىگارنىڭ يەرەمىيانىڭ ئاغزى ئارقىلىق ئېيتقان سۆزى ئەمەلگە ئاشۇرۇلۇپ، پەرۋەردىگارنىڭ پارس پادىشاھى قورەشنىڭ روھىنى قوزغىشى بىلەن پۈتۈن پادىشاھلىقى تەۋەسىدە ئۇ مۇنداق بىر جاكارنامە چىقاردى، شۇنداقلا ئۇنى يازما قىلىپ پۈكۈپ: ــ
\m 
\v 2 «پارس پادىشاھى قورەش مۇنداق دەيدۇ: ــ ئاسمانلارنىڭ خۇداسى پەرۋەردىگار يەر يۈزىدىكى بارلىق پادىشاھلىقلارنىڭ ئىگىدارچىلىقىنى ماڭا بەردى؛ ئۇ شۇنداقلا مېنى يەھۇدا زېمىنىغا جايلاشقان يېرۇسالېمدا ئۆزىگە بىر ئۆي سېلىشقا بۇيرۇدى. \f ◼ \fr 1:2 \ft \bd «يەھۇدا زېمىنى»\bd* ــ كېيىنكى ۋاقىتلاردا «يەھۇدىيە» دېيىلىدۇ.\f*
\v 3 شۇنىڭ ئۈچۈن ئاراڭلاردا خۇدانىڭ خەلقى بولغانلاردىن ھەرقايسىڭلارغا بولسا، ئۇنىڭ خۇداسى \add پەرۋەردىگار\add* ئۇنىڭ بىلەن بىللە بولغاي، ئۇ يەھۇدا زېمىنىدىكى يېرۇسالېمغا چىقسۇن، ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ ئۆيىنى سالسۇن! ئۇ بولسا خۇدادۇر، ماكانى يېرۇسالېمدىدۇر!
\v 4 \add سۈرگۈنلۈكتە\add* قالغان خەلق قەيەرلەردە ماكانلاشقان بولسا، \add ئۇ يېرۇسالېمغا چىقسۇن\add*؛ شۇ يەردىكى ئادەملەر ئۇلارغا ئالتۇن، كۈمۈش، مال-مۈلۈك، چارپايلارنى تەمىنلەپ ياردەم بەرسۇن ۋە شۇنىڭدەك يېرۇسالېمدا جايلاشقان خۇدانىڭ شۇ ئۆيى ئۈچۈن خالىس ھەدىيەلەرنى تەقدىم قىلسۇن» ــ دېدى. \f ◼ \fr 1:4 \ft \bd «قالغان خەلق»\bd* ــ ئىمپېرىيەدە تىرىك قالغان يەھۇدىي خەلقى.\f*
\b
\s1 قايتىشقا تەييارلىنىش
\m 
\v 5 شۇنىڭ بىلەن يەھۇدا ۋە بىنيامىندىكى قەبىلە باشلىقلىرى، كاھىنلار، لاۋىيلار، شۇنداقلا خۇدا تەرىپىدىن روھى قوزغىتىلغان بارلىق خەلق ئورۇنلىرىدىن قوپۇپ يېرۇسالېمدىكى پەرۋەردىگارنىڭ ئۆيىنى \add يېڭىۋاشتىن\add* سېلىشقا بېرىشقا تەييارلاندى.
\v 6 ئەتراپتىكى كىشىلەرنىڭ ھەممىسى كۈمۈش قاچا-قۇچا، ئالتۇن، مال-مۈلۈك، چارپايلار ۋە قىممەت باھالىق بۇيۇملار بىلەن ئۇلارنى قوللاپ قۇۋۋەتلىدى، بۇنىڭدىن باشقا سۇنۇلىدىغان ھەرخىل ئىختىيارىي ھەدىيە-قۇربانلىق سۈپىتىدە ھەرخىل سوۋغاتلارنى تەقدىم قىلدى.
\v 7 پادىشاھ قورەش پەرۋەردىگارنىڭ ئۆيىدىكى قاچا-قۇچىلىرىنىمۇ، يەنى ئىلگىرى نېبوقادنەسار يېرۇسالېمدىن ئەكىلىپ ئۆز ئىلاھىنىڭ بۇتخانىسىغا قويۇپ قويغان قاچا-قۇچىلارنىمۇ ئېلىپ چىقتى. \f ◼ \fr 1:7 \ft \bd «ئىلگىرى نېبوقادنەسار يېرۇسالېمدىن ئەكىلىپ ئۆز ئىلاھىنىڭ بۇتخانىسىغا قويۇپ قويغان قاچا-قۇچىلار»\bd* ــ بۇ ۋەقە «2تار.» 7:36دە تەسۋىرلىنىدۇ.\f*  \x ◘ \xo 1:7 \xt 2پاد. 24‏:13؛ 2تار. 36‏:7\x*
\v 8 پارس پادىشاھى قورەش خەزىنە بېگى مىترەداتنى بۇيرۇپ بۇ قاچا-قۇچىلارنى ئالدۇرۇپ چىقتى؛ مىترەدات شۇلارنى يەھۇدانىڭ ئەمىرى شەشبازارغا سانى بويىچە ساناپ تاپشۇرۇپ بەردى. \x ◘ \xo 1:8 \xt ئەزرا 5‏:14\x*
\v 9 قاچا-قۇچىلارنىڭ سانى مۇنداق: ــ ئالتۇن داس ئوتتۇز، كۈمۈش داس مىڭ، پىچاق يىگىرمە توققۇز، \f ◼ \fr 1:9 \ft \bd «ئالتۇن داس»\bd* ــ ياكى «ئالتۇن پەتنۇس».\f*
\v 10 ئالتۇن پىيالە ئوتتۇز، بىر-بىرىگە ئوخشاش بولغان كۈمۈش پىيالە تۆت يۈز ئون؛ باشقا قاچا-قۇچىلار بىر مىڭ. \f ◼ \fr 1:10 \ft \bd «بىر-بىرىگە ئوخشاش بولغان كۈمۈش پىيالە تۆت يۈز ئون»\bd* ــ ياكى «سۈپىتى تۆۋەنرەك كۈمۈش پىيالە تۆت يۈز ئون» ياكى «ئىككىنچى بىرخىل كۈمۈش ىيالە تۆت يۈز ئون» ياكى «كۈمۈش پىيالە ئىككى مىڭ تۆت يۈز ئون». باشقىچە تەرجىمىلەرمۇ ئۇچرىشى مۇمكىن.\f*
\v 11 بارلىق ئالتۇن-كۈمۈش قاچا-قۇچا، بەش مىڭ تۆت يۈز. سۈرگۈن قىلىنغان خەلق بابىلدىن يېرۇسالېمغا ئېلىپ كېلىنگەن چاغدا، شەشبازار بۇ قاچا-قۇچىلارنىڭ ھەممىسىنى ئېلىپ كەلگەنىدى.
\b
\b
\c 2
\s1 بىرىنچى قېتىم قايتقان يەھۇدالار •••• «نەھ.» 6:7-73نى كۆرۈڭ
\m 
\v 1 تۆۋەندىكىلەر نېبوقادنەسار تەرىپىدىن بابىلغا سۈرگۈن قىلىنغان \add يەھۇدىيە\add* ئۆلكىسىدىكىلەردىن، ئۇلارنىڭ ئەۋلادلىرى قايتىپ كېلىپ، يېرۇسالېم ۋە يەھۇدىيەگە چىقىپ، ھەربىرى ئۆز شەھىرلىرىگە كەتكەنلەر: ــ
\m 
\v 2 ــ ئۇلار زەرۇببابەل، يەشۇئا، نەھەمىيا، سېرايا، رەئىلايا، موردىكاي، بىلشان، مىسپار، بىگۋاي، رەھۇم ۋە بائاناھلار بىلەن بىللە قايتىپ كەلدى. ئەمدى ئىسرائىل خەلقىنىڭ ئىچىدىكى ئەركەكلەرنىڭ سانى تۆۋەندىكىچە: ــ \f ◼ \fr 2:2 \ft \bd «سېرايا»\bd* ــ ياكى «سارايا».\f*
\b
\m 
\v 3 پاروشنىڭ ئەۋلادلىرى ئىككى مىڭ بىر يۈز يەتمىش ئىككى كىشى؛
\v 4 شەفاتىيانىڭ ئەۋلادلىرى ئۈچ يۈز يەتمىش ئىككى كىشى؛
\v 5 ئاراھنىڭ ئەۋلادلىرى يەتتە يۈز يەتمىش بەش كىشى؛
\v 6 پاھات-موئابنىڭ ئەۋلادلىرى، يەنى يەشۇئا بىلەن يوئابنىڭ ئەۋلادلىرى ئىككى مىڭ سەككىز يۈز ئون ئىككى كىشى؛
\v 7 ئېلامنىڭ ئەۋلادلىرى بىر مىڭ ئىككى يۈز ئەللىك تۆت كىشى؛
\v 8 زاتتۇنىڭ ئەۋلادلىرى توققۇز يۈز قىرىق بەش كىشى؛
\v 9 زاككاينىڭ ئەۋلادلىرى يەتتە يۈز ئاتمىش كىشى؛
\v 10 بانىنىڭ ئەۋلادلىرى ئالتە يۈز قىرىق ئىككى كىشى؛
\v 11 بىباينىڭ ئەۋلادلىرى ئالتە يۈز يىگىرمە ئۈچ كىشى؛
\v 12 ئازگادنىڭ ئەۋلادلىرى بىر مىڭ ئىككى يۈز يىگىرمە ئىككى كىشى؛
\v 13 ئادونىكامنىڭ ئەۋلادلىرى ئالتە يۈز ئاتمىش ئالتە كىشى؛
\v 14 بىگۋاينىڭ ئەۋلادلىرى ئىككى مىڭ ئەللىك ئالتە كىشى؛
\v 15 ئادىننىڭ ئەۋلادلىرى تۆت يۈز ئەللىك تۆت كىشى؛
\v 16 ھەزەكىيانىڭ جەمەتىدىن بولغان ئاتېرنىڭ ئەۋلادلىرى توقسان سەككىز كىشى؛
\v 17 بىزاينىڭ ئەۋلادلىرى ئۈچ يۈز يىگىرمە ئۈچ كىشى؛
\v 18 يوراھنىڭ ئەۋلادلىرى بىر يۈز ئون ئىككى كىشى؛
\v 19 ھاشۇمنىڭ ئەۋلادلىرى ئىككى يۈز يىگىرمە ئۈچ كىشى؛
\v 20 گىببارنىڭ ئەۋلادلىرى توقسان بەش كىشى؛
\v 21 بەيت-لەھەملىكلەر بىر يۈز يىگىرمە ئۈچ كىشى؛
\v 22 نىتوفالىقلار ئەللىك ئالتە كىشى؛
\v 23 ئاناتوتلۇقلار بىر يۈز يىگىرمە سەككىز كىشى؛
\v 24 ئازماۋەتلىكلەر قىرىق ئىككى كىشى؛
\v 25 كىرىئات-ئارىملىقلار، كەفىراھلىقلار ۋە بەئەروتلۇقلار بولۇپ جەمئىي يەتتە يۈز قىرىق ئۈچ كىشى؛ \f ◼ \fr 2:25 \ft \bd «كىرىئات-ئارىملىقلار»\bd* ــ ياكى «كىرىئات-يېئارىملىقلار».\f*
\v 26 راماھلىقلار بىلەن گېبالىقلار جەمئىي ئالتە يۈز يىگىرمە بىر كىشى؛
\v 27 مىكماشلىقلار بىر يۈز يىگىرمە ئىككى كىشى؛
\v 28 بەيت-ئەللىكلەر بىلەن ئايىلىقلار جەمئىي ئىككى يۈز يىگىرمە ئۈچ كىشى؛
\v 29 نېبولىقلار ئەللىك ئىككى كىشى؛
\v 30 ماگبىشنىڭ ئەۋلادلىرى بىر يۈز ئەللىك ئالتە كىشى؛
\v 31 ئىككىنچى بىر ئېلامنىڭ ئەۋلادلىرى بىر مىڭ ئىككى يۈز ئەللىك تۆت كىشى؛
\v 32 ھارىمنىڭ ئەۋلادلىرى ئۈچ يۈز يىگىرمە كىشى؛
\v 33 لود، ھادىد ۋە ئونونىڭ ئەۋلادلىرى جەمئىي يەتتە يۈز يىگىرمە بەش كىشى؛ \f ◼ \fr 2:33 \ft \bd «لود، ھادىد ۋە ئونونىڭ ئەۋلادلىرى...»\bd* ــ ياكى «لودلىقلار، ھادىدلىقلار ۋە ئونولۇقلار...».\f*
\v 34 يېرىخولۇقلار ئۈچ يۈز قىرىق بەش كىشى؛
\v 35 سىنائاھنىڭ ئەۋلادلىرى ئۈچ مىڭ ئالتە يۈز ئوتتۇز كىشى.
\b
\s1 قايتىپ كەلگەن كاھىنلار ۋە لاۋىيلار
\m 
\v 36 كاھىنلارنىڭ سانى تۆۋەندىكىچە: ــ يەشۇئا جەمەتىدىكى يەدايانىڭ ئەۋلادلىرى توققۇز يۈز يەتمىش ئۈچ كىشى؛
\v 37 ئىممەرنىڭ ئەۋلادلىرى بىر مىڭ ئەللىك ئىككى كىشى؛
\v 38 پاشخۇرنىڭ ئەۋلادلىرى بىر مىڭ ئىككى يۈز قىرىق يەتتە كىشى؛
\v 39 ھارىمنىڭ ئەۋلادلىرى بىر مىڭ ئون يەتتە كىشى.
\m 
\v 40 لاۋىيلارنىڭ سانى تۆۋەندىكىچە: ــ خوداۋىيانىڭ ئەۋلادلىرىدىن، يەنى يەشۇئا بىلەن كادمىيەلنىڭ ئەۋلادلىرى يەتمىش تۆت كىشى؛
\v 41 غەزەلكەشلەردىن: ــ ئاسافنىڭ ئەۋلادلىرى بىر يۈز يىگىرمە سەككىز كىشى.
\m 
\v 42 دەرۋازىۋەنلەرنىڭ نەسلىدىن: ــ شاللۇمنىڭ ئەۋلادلىرى، ئاتېرنىڭ ئەۋلادلىرى، تالموننىڭ ئەۋلادلىرى، ئاككۇبنىڭ ئەۋلادلىرى، خاتىتانىڭ ئەۋلادلىرى بىلەن شوباينىڭ ئەۋلادلىرى جەمئىي بىر يۈز ئوتتۇز توققۇز كىشى.
\b
\s1 قايتىپ كەلگەن مۇقەددەس جاي ۋە شاھ جەمەتىدىكى خىزمەتكارلار
\m 
\v 43 ئىبادەتخانا خىزمەتكارلىرى تۆۋەندىكىچە: ــ زىخانىڭ ئەۋلادلىرى، خاسۇفانىڭ ئەۋلادلىرى، تاببائوتنىڭ ئەۋلادلىرى، \f ◼ \fr 2:43 \ft \bd «ئىبادەتخانا خىزمەتكارلىرى»\bd* ــ ئىبرانىي تىلىدا «نەتىنىيلار». مەنىسى بەلكىم «بېغىشلانغانلار». ئۇلارنىڭ ئەجدادلىرى بەلكىم «گىبېئونلۇقلار» ئىدى. «يەشۇئا» 27:9نى ۋە «1تار.» 2:9نى كۆرۈڭ.\f*
\v 44 كىروسنىڭ ئەۋلادلىرى، سىياھانىڭ ئەۋلادلىرى، پادوننىڭ ئەۋلادلىرى،
\v 45 لىباناھنىڭ ئەۋلادلىرى، ھاگاباھنىڭ ئەۋلادلىرى، ئاككۇبنىڭ ئەۋلادلىرى،
\v 46 ھاگابنىڭ ئەۋلادلىرى، شاملاينىڭ ئەۋلادلىرى، ھاناننىڭ ئەۋلادلىرى، \f ◼ \fr 2:46 \ft \bd «شاملاي»\bd* ــ ياكى «شالماي».\f*
\v 47 گىددەلنىڭ ئەۋلادلىرى، گاھارنىڭ ئەۋلادلىرى، رېئاياھنىڭ ئەۋلادلىرى،
\v 48 رەزىننىڭ ئەۋلادلىرى، نىكودانىڭ ئەۋلادلىرى، گاززامنىڭ ئەۋلادلىرى،
\v 49 ئۇززانىڭ ئەۋلادلىرى، پاسىيانىڭ ئەۋلادلىرى، بىساينىڭ ئەۋلادلىرى،
\v 50 ئاسناھنىڭ ئەۋلادلىرى، مەئۇنىمنىڭ ئەۋلادلىرى، نەفۇسسىمنىڭ ئەۋلادلىرى،
\v 51 باكبۇكنىڭ ئەۋلادلىرى، خاكۇفانىڭ ئەۋلادلىرى، خارخۇرنىڭ ئەۋلادلىرى،
\v 52 بازلۇتنىڭ ئەۋلادلىرى، مەھىدانىڭ ئەۋلادلىرى، خارشانىڭ ئەۋلادلىرى،
\v 53 باركوسنىڭ ئەۋلادلىرى، سىسېرانىڭ ئەۋلادلىرى، تېماھنىڭ ئەۋلادلىرى،
\v 54 نەزىيانىڭ ئەۋلادلىرى بىلەن خاتىفانىڭ ئەۋلادلىرى.
\m 
\v 55 سۇلايماننىڭ خىزمەتكارلىرىنىڭ ئەۋلادلىرىنىڭ سانى تۆۋەندىكىچە: ــ سوتاينىڭ ئەۋلادلىرى، سوفەرەتنىڭ ئەۋلادلىرى، پىرۇدانىڭ ئەۋلادلىرى،
\v 56 يائالاھنىڭ ئەۋلادلىرى، داركوننىڭ ئەۋلادلىرى، گىددەلنىڭ ئەۋلادلىرى،
\v 57 شەفەتىيانىڭ ئەۋلادلىرى، خاتتىلنىڭ ئەۋلادلىرى، پوقەرەت-ھاززىبائىمنىڭ ئەۋلادلىرى بىلەن ئامىنىڭ ئەۋلادلىرى.
\m 
\v 58 ئىبادەتخانا خىزمەتكارلىرى ۋە سۇلايماننىڭ خىزمەتكارى بولغانلارنىڭ ئەۋلادلىرى جەمئىي ئۈچ يۈز توقسان ئىككى كىشى.
\b
\s1 كېلىپ چىقىشى نائېنىق كىشىلەر •••• «نەھ.» 61:7-65نى كۆرۈڭ
\m 
\v 59 تۆۋەندىكى كىشىلەر تەل-مېلاھ، تەل-خارشا، كېرۇب، ئاددان ۋە ئىممەردىن كەلگەن بولسىمۇ، لېكىن ئۇلار ئۆزلىرىنىڭ ئاتا جەمەتىنىڭ ياكى نەسەبىنىڭ ئىسرائىل ئادىمى ئىكەنلىكىنى ئىسپاتلاپ بېرەلمىدى.
\v 60 بۇلار دېلايانىڭ ئەۋلادلىرى، توبىيانىڭ ئەۋلادلىرى ۋە نىكودانىڭ ئەۋلادلىرى بولۇپ، جەمئىي ئالتە يۈز ئەللىك ئىككى كىشى؛
\v 61 كاھىنلارنىڭ ئەۋلادلىرى ئىچىدە خابايانىڭ ئەۋلادلىرى، كوزنىڭ ئەۋلادلىرى بىلەن بارزىللاينىڭ ئەۋلادلىرى بار ئىدى؛ بارزىللاي گىلېئادلىق بارزىللاينىڭ بىر قىزىنى ئالغاچقا ئۇلارنىڭ ئېتى بىلەن ئاتالغانىدى. \f ◼ \fr 2:61 \ft \bd «كوزنىڭ ئەۋلادلىرى»\bd* ــ ياكى «ھاككوزنىڭ ئەۋلادلىرى».\f*
\v 62 بۇلار جەمەتىنىڭ نەسەبنامىسىنى ئىزدەپ تاپالمىدى؛ شۇڭا ئۇلار «ناپاك» ھېسابلىنىپ كاھىنلىقتىن قالدۇرۇلدى.
\v 63 ۋالىي ئۇلارغا: ــ ئۇرىم ۋە تۇممىمنى كۆتۈرگۈچى كاھىن ئارىمىزدا خىزمەتتە بولغۇچە «ئەڭ مۇقەددەس يىمەكلىكلەر»گە ئېغىز تەگكۈزمەيسىلەر، دېدى. \f ◼ \fr 2:63 \ft \bd «ۋالىي»\bd* ــ ئىبرانىي تىلىدىكى «تىرشاتا» ئەسلىدە پارس تىلى بولۇپ، مەنىسى بەلكىم «جانابلىرى». \bd «ئۇرىم ۋە تۇممىم»\bd* ــ ئالاھىدە بىرخىل تاشلار. ئۇ كاھىن كىيگەن «ئەفود»نىڭ يانچۇقىدا (قوشېندا) تۇرىدۇ. بۇ تاشلار ئارقىلىق ئىسرائىل خەلقى خۇدادىن يول سورىسا بولاتتى. «مىس.» 28:28-30نى كۆرۈڭ. «ئۇرىم ۋە تۇممىمنى كۆتۈرگۈچى كاھىن ئارىمىزدا خىزمەتتە بولغۇچە» ــ مەنىسى بەلكىم: (1) ئۇرىم ۋە تۇممىم بابىلدا سۈرگۈن بولغان ۋاقتىدا يوقاپ كەتكەن بولۇشى مۇمكىن؛ (2) تېپىلغىنى بىلەن ئۇلارغا تەبىر بېرىپ مەنىسىنى چۈشەندۈرىدىغان كاھىن تېخى چىقمىدى.\f*
\b
\s1 قايتىپ كەلگۈچىلەرنىڭ ئومۇمىي سانى •••• «نەھ.» 66:7-69نى كۆرۈڭ
\m 
\v 64 پۈتۈن جامائەت جەمئىي قىرىق ئىككى مىڭ ئۈچ يۈز ئاتمىش كىشى؛
\v 65 بۇنىڭدىن باشقا ئۇلارنىڭ يەنە يەتتە مىڭ ئۈچ يۈز ئوتتۇز يەتتە قۇل-دېدىكى بار ئىدى؛ يەنە ئىككى يۈز ئەر-ئايال غەزەلچىسى بار ئىدى.
\v 66 ئۇلارنىڭ يەتتە يۈز ئوتتۇز ئالتە ئېتى، ئىككى يۈز قىرىق بەش قېچىرى،
\v 67 تۆت يۈز ئوتتۇز بەش تۆگىسى ۋە ئالتە مىڭ يەتتە يۈز يىگىرمە ئېشىكى بار ئىدى.
\b
\s1 مۇقەددەس ئۆي ئۈچۈن تەقدىم قىلىنغان مال-مۈلۈكلەر •••• «نەھ.» 70:7-73نىمۇ كۆرۈڭ
\m 
\v 68 جەمەت كاتتىۋاشلىرىدىن بەزىلىرى يېرۇسالېمغا ۋە پەرۋەردىگارنىڭ ئۆيىگە كەلگەن چاغدا، خۇدانىڭ شۇ ئۆيى ئەسلى ئورنىغا يېڭىۋاشتىن سېلىنىشى ئۈچۈن چىن كۆڭلىدىن سوۋغاتلارنى تەقدىم قىلدى.
\v 69 ئۇلار ئۆزلىرىنىڭ قۇربىغا قاراپ قۇرۇلۇش خەزىنىسىگە ئاتمىش بىر مىڭ دارىك ئالتۇن، بەش مىڭ مىنا كۈمۈش ۋە يۈز قۇر كاھىن تونى تەقدىم قىلدى. \f ◼ \fr 2:69 \ft \bd «دارىك»\bd* ــ ( ياكى «دراخما») ــ مۇشۇ يەردە ئۇ پارس ئىمپېرىيەسىدىكى بىرخىل ئالتۇن تەڭگە؛ مۇشۇ يەردە بۇلارنىڭ جەمئىي قىممىتى بەلكىم 400-500 گرام ئالتۇن ئىدى؛ «مىنا» بىرخىل كۈمۈش تەڭگە، 60 شەكەلگە ياكى «تالانت»تىن ئاتمىشتىن بىرىگە باراۋەر ئىدى. مۇشۇ يەردە كۈمۈشنىڭ جەمئىي ئېغىرلىقى بەلكىم 1800-2700 كىلوگرامچە ئىدى.\f*
\v 70 شۇنىڭدىن كېيىن كاھىنلار، لاۋىيلار ۋە بىر قىسىم خەلق قوشۇلۇپ، غەزەلكەشلەر، دەرۋازىۋەنلەر، ئىبادەتخانا خىزمەتكارلىرى ئۆز شەھەرلىرىگە ماكانلاشتى؛ قالغان ئىسرائىل خەلقىنىڭ ھەممىسى ئۆز شەھەرلىرىگە ماكانلاشتى. \f ◼ \fr 2:70 \ft \bd «شۇنىڭدىن كېيىن كاھىنلار، لاۋىيلار... ئىبادەتخانا خىزمەتكارلىرى ئۆز شەھەرلىرىگە ماكانلاشتى؛ قالغان ئىسرائىل ... ئۆز شەھەرلىرىگە ماكانلاشتى»\bd* ــ بۇ ئايەتنىڭ مەنىسى بەلكىم:\fp (1) كاھىنلار، لاۋىيلار قاتارلىقلار ئۆزىگە يېڭىۋاشتىن تەقسىم قىلىنغان شەھەرلىرىدە ماكان تۇتتى، ياكى يېرۇسالېمدىكى خىزمەتتە بولۇش ئۈچۈن يېرۇسلېمغا يېقىن بولغان، شۇنداقلا ئۇلارغا تەقسىم قىلىنغان شەھەرلەردە ماكانلاشتى؛\fp (2) لاۋىيلاردىن باشقا ئىسرائىللار، يەنى ئون ئىككى قەبىلىدىن قايتىپ كەلگەنلەر \bd ئەسلىدە\bd* ئۆزىگە خاس شەھەرلىرىگە ماكانلاشتى ياكى يېڭىۋاشتىن ئۇلارغا تەقسىم قىلىنغان شەھەرلەردە ماكانلاشتى.\fp كۆپ شەھەر-يېزىلار ۋەيران بولغاچقا، ياكى يات ئەللەرنىڭ ئىگىدارچىلىقى ئاستىدا بولغاچقا، بەلكىم ھەرخىل ئىمكانىيەت تەڭ بولۇشى مۇمكىن ئىدى.\f*
\b
\b
\c 3
\s1 قۇربانگاھنىڭ يېڭىۋاشتىن سېلىنىشى
\m 
\v 1 ئىسرائىل خەلقى ھەرقايسىسى ئۆز شەھەرلىرىدە ماكانلاشقانىدى؛ يەتتىنچى ئايغا كەلگەندە، خەلق بىر ئادەمدەك بولۇپ يېرۇسالېمغا يىغىلدى.
\v 2 يوزاداكنىڭ ئوغلى يەشۇئا بىلەن ئۇنىڭ كاھىن قېرىنداشلىرى، شېئالتىئەلنىڭ ئوغلى زەرۇببابەل ۋە ئۇنىڭ قېرىنداشلىرىنىڭ ھەممىسى ئورۇنلىرىدىن قوپۇپ، خۇدانىڭ ئادىمى مۇسا پۈتكەن قانۇن كىتابىدا پۈتۈلگىنىدەك پەرۋەردىگارغا كۆيدۈرمە قۇربانلىق سۇنۇش ئۈچۈن ئىسرائىلنىڭ خۇداسىنىڭ قۇربانگاھىنى سېلىشقا كىرىشتى. \x ◘ \xo 3:2 \xt قان. 12‏:5، 6\x*
\v 3 گەرچە ئۇلار شۇ يەرلىك خەلقلەردىن قورقسىمۇ، لېكىن قۇربانگاھنى ئەسلىدىكى ئۇلى ئۈستىگە سېلىپ، ئۇنىڭدا پەرۋەردىگارغا ئاتاپ ئەتىگەنلىك ۋە كەچلىك كۆيدۈرمە قۇربانلىق ئۆتكۈزۈشكە كىرىشتى. \x ◘ \xo 3:3 \xt چۆل. 28‏:3\x*
\v 4 ئۇلار يەنە \add مۇقەددەس قانۇندا\add* پۈتۈلگىنى بويىچە «كەپىلەر ھېيتى»نى ئۆتكۈزۈپ، ھەر كۈنى بەلگىلەنگەن تەلەپكە مۇۋاپىق سان بويىچە كۈنلۈك كۆيدۈرمە قۇربانلىقنى سۇنۇشاتتى. \x ◘ \xo 3:4 \xt لاۋ. 23‏:34؛ چۆل. 29‏:12\x*
\v 5 شۇنىڭدىن كېيىن ئۇلار يەنە ھەر كۈنلۈك كۆيدۈرمە قۇربانلىقلار، يېڭى ئاي قۇربانلىقى ۋە پەرۋەردىگارنىڭ بارلىق مۇقەددەس دەپ بېكىتىلگەن ھېيتلىرى ئۈچۈن تەقدىم قىلىنىدىغان كۆيدۈرمە قۇربانلىقلارنى، شۇنىڭدەك ھەربىر كىشىنىڭ كۆڭلىدىن پەرۋەردىگارغا ئاتاپ سۇنىدىغان ئىختىيارىي قۇربانلىقلىرىنى سۇنۇپ تۇراتتى. \x ◘ \xo 3:5 \xt چۆل. 28‏:11-15؛ نەھ. 10‏:34\x*
\v 6 شۇنداق قىلىپ ئۇلار يەتتىنچى ئاينىڭ بىرىنچى كۈنىدىن باشلاپ، كۆيدۈرمە قۇربانلىقلارنى پەرۋەردىگارغا ئاتاپ سۇنۇشقا باشلىدى؛ لېكىن پەرۋەردىگارنىڭ ئۆيىنىڭ ئۇلى تېخى سېلىنمىدى.
\v 7 ئۇلار تاشچىلار بىلەن ياغاچچىلارغا پۇل تاپشۇردى ۋە شۇنداقلا پارس پادىشاھى قورەشنىڭ ئىجازىتى بىلەن زىدونلۇقلار بىلەن تۇرلۇقلارغا كېدىر ياغىچىنى لىۋاندىن \add ئوتتۇرا\add* دېڭىز ئارقىلىق يوپپاغا ئەكەلدۈرۈش ئۈچۈن يىمەك-ئىچمەك ۋە زەيتۇن مېيىنى تەمىنلىدى.
\b
\s1 مۇقەددەس ئىبادەتخانىنىڭ يېڭىۋاشتىن سېلىنىشى
\m 
\v 8 جامائەت يېرۇسالېمدىكى خۇدانىڭ ئۆيىگە كەلگەندىن كېيىن ئىككىنچى يىلى ئىككىنچى ئايدا شېئالتىيەلنىڭ ئوغلى زەرۇببابەل، يوزاداكنىڭ ئوغلى يەشۇئا ۋە ئۇلارنىڭ كاھىن ۋە لاۋىي قېرىنداشلىرىنىڭ قالدىسى، شۇنىڭدەك سۈرگۈنلۈكتىن قايتىپ يېرۇسالېمغا كەلگەنلەرنىڭ ھەممىسى قۇرۇلۇشتا ئىش باشلىدى؛ ئۇلار يەنە يىگىرمە ياشتىن ئاشقان لاۋىيلارنى پەرۋەردىگارنىڭ ئۆيىنى سېلىش قۇرۇلۇشىغا نازارەتچىلىككە قويدى.
\v 9 يەشۇئا ۋە ئۇنىڭ ئوغۇللىرى ھەم قېرىنداشلىرى، كادمىيەل بىلەن ئۇنىڭ ئوغۇللىرى، يەنى يەھۇدانىڭ ئەۋلادلىرى خۇدانىڭ ئۆيىدە ئىشلەيدىغان ئىشچىلارنى نازارەت قىلىشقا بىر نىيەتتە ئاتلاندى؛ ھېنادادنىڭ ئوغۇللىرى، ئۇلارنىڭ ئوغۇللىرىمۇ ۋە قېرىنداش لاۋىيلار ئۇلارغا ياردەملەشتى. \f ◼ \fr 3:9 \ft \bd «يەھۇدانىڭ ئەۋلادلىرى»\bd* ــ «يەھۇدا» مۇشۇ يەردە بەلكىم «خوداۋىيا» دېگەن ئىسىمنىڭ ۋارىئانتى بولۇشى مۇمكىن (40:2نى كۆرۈڭ). \bd «بىر نىيەتتە ئاتلاندى»\bd* ــ ئىبرانىي تىلىدا: «بىر ئادەمدەك بولۇپ ئورنىدىن تۇردى».\f*
\m 
\v 10 تامچىلار پەرۋەردىگارنىڭ ئۆيىگە ئۇل سالىدىغان چاغدا كاھىنلار خاس كىيىملىرىنى كىيىپ، كانايلىرىنى چېلىپ، ئاسافنىڭ ئەۋلادلىرى بولغان لاۋىيلار جاڭ-جاڭ چېلىپ، ھەممىسى قاتار-قاتار سەپ بولۇپ تۇرغۇزۇلدى؛ ئۇلار داۋۇت بەلگىلىگەن كۆرسەتمىلەر بويىچە پەرۋەردىگارغا ھەمدۇسانا ئوقۇشتى.
\v 11 ئۇلار پەرۋەردىگارغا ئاتاپ ئۆزئارا: ــ «پەرۋەردىگار مېھرىباندۇر، ئۇنىڭ ئىسرائىلغا بولغان مېھىر-مۇھەببىتى مەڭگۈلۈكتۇر» دەپ ھەمدۇسانا ۋە رەھمەت-تەشەككۈر ئېيتىشتى. بۇ چاغدا پەرۋەردىگارنىڭ ئۆيىنىڭ ئۇلى سېلىنىپ بولغاچقا، خالايىق پەرۋەردىگارنى مەدھىيىلەپ توۋلاپ تەنتەنە قىلىشتى. \x ◘ \xo 3:11 \xt زەب. 136\x*
\v 12 لېكىن كاھىنلاردىن، لاۋىيلاردىن ۋە جەمەت باشلىقلىرىدىن نۇرغۇنلىرى، يەنى ئەسلىدە ئىلگىرىكى ئۆينى كۆرگەن نۇرغۇن قېرى ئادەملەر كۆز ئالدىدا سېلىنغان بۇ ئۆينىڭ ئۇلىغا قاراپ، ئۈن سېلىپ يىغلاپ كېتىشتى؛ نۇرغۇن باشقا كىشىلەر خۇشال بولۇپ تەنتەنە قىلىپ توۋلاشتى؛ \f ◼ \fr 3:12 \ft \bd «ئۆينى كۆرگەن نۇرغۇن قېرى ئادەملەر ... ئۈن سېلىپ يىغلاپ كېتىشتى»\bd* ــ بەزىلەرنىڭ يىغلىشى خۇشاللىقتىن بولدى؛ بەزىلەرنىڭ «بۇ ئۆي ئەسلىدىكى ئويدەك ھەيۋەتلىك بولمايدىغان بولدى» دەپ ئويلاپ ھەسرەت-قايغۇدىن بولدى («ھاگ.» 3:2نى كۆرۈڭ).\f*
\v 13 ۋە خەلق ھەتتا كىملەرنىڭ تەنتەنە قىلىشىۋاتقانلىقى بىلەن كىملەرنىڭ يىغلاۋاتقانلىقىنى ئايرىۋالالماي قالدى؛ چۈنكى جامائەت تەنتەنە قىلىپ قاتتىق توۋلىشاتتى؛ ۋە بۇ ئاۋاز يىراق-يىراقلارغا ئاڭلىناتتى.
\b
\b
\c 4
\s1 ئۆينى يېڭىۋاشتىن سېلىشنىڭ توسقۇنلۇققا ئۇچرىشى
\m 
\v 1 يەھۇدا ۋە بىنيامىندىكى رەقىبلەر سۈرگۈنلۈكتىن قايتىپ كەلگەنلەر ئىسرائىلنىڭ خۇداسى پەرۋەردىگارغا ئاتاپ ئۆينى يېڭىۋاشتىن سالماقچىكەن، دېگەن گەپنى ئاڭلاپ،
\v 2 زەرۇببابەل ۋە جەمەت باشلىقلىرى بىلەن كۆرۈشۈپ: ــ بىز سىلەر بىلەن بىللە سالايلى؛ چۈنكى بىزمۇ سىلەرگە ئوخشاشلا سىلەرنىڭ خۇدايىڭلارنى ئىزلەپ، بىزنى بۇ يەرگە ئەكەلگەن ئاسۇرىيە پادىشاھى ئېسار-ھاددوننىڭ كۈنلىرىدىن تارتىپ ئۇنىڭغا قۇربانلىق سۇنۇپ كېلىۋاتىمىز، دېيىشتى. \x ◘ \xo 4:2 \xt 2پاد. 17‏:29-41\x*
\v 3 لېكىن زەرۇببابەل، يەشۇئا بىلەن ئىسرائىلنىڭ باشقا جەمەت باشلىقلىرى ئۇلارغا: ــ خۇدايىمىزغا ئۆي سېلىشتا سىلەرنىڭ بىز بىلەن ھېچقانداق ئالاقەڭلار يوق؛ بەلكى پارس پادىشاھى قورەش بىزگە بۇيرۇغاندەك، پەقەت بىز ئۆزىمىزلا ئىسرائىلنىڭ خۇداسى بولغان پەرۋەردىگارغا ئۆي سالىمىز، دېيىشتى. \x ◘ \xo 4:3 \xt ئەزرا 1‏:1، 2، 3\x*
\m 
\v 4 شۇنىڭدىن كېيىن شۇ يەردىكى ئاھالە يەھۇدالارنىڭ قولىنى ئاجىز قىلىپ، ئۇلارنىڭ قۇرۇلۇش قىلىشىغا كاشىلا تۇغدۇرۇپ تۇردى.
\v 5 ئۇلار يەنە پارس پادىشاھى قورەشنىڭ بارلىق كۈنلىرىدىن تاكى پارس پادىشاھى دارىئۇس تەختكە ئولتۇرغان ۋاقىتقىچە، دائىم مەسلىھەتچىلەرنى سېتىۋېلىپ، يەھۇدالار بىلەن قېرىشىپ، قۇرۇلۇش نىشانىنى بۇزۇشقا ئۇرۇنۇپ تۇردى. \f ◼ \fr 4:5 \ft \bd «پارس پادىشاھى دارىئۇس»\bd* ــ مىلادىيەدىن ئىلگىرىكى 522-486-يىللاردا پارس تەختىگە ئولتۇرغان.\f*
\b
\s1 رەقىبلەرنىڭ يەھۇدالار ئۈستىدىن ئەرز قىلىشى
\m 
\v 6 ئاھاشۋېروش تەختكە چىققان دەسلەپكى ۋاقىتلاردا ئۇلار ئۇنىڭغا يەھۇدىيە ۋە يېرۇسالېم ئاھالىسى ئۈستىدىن بىر ئەرزنامە يازدى. \f ◼ \fr 4:6 \ft \bd «ئاھاشۋېروش»\bd* ــ بەزى ئالىملار پارس ئىمپېراتورى بولغان مۇشۇ «ئاھاشۋېروش»نى «كسەركسىس I» نىڭ ئۆزى شۇ (مىلادىيەدىن ئىلگىرىكى 486-464-يىللار)، دەپ قارايدۇ. بىراق ئىسپات باركى، «ئاھاشۋېروش» ياكى «كسەركسىس» دېگەن سۆز ئەسلىدە ئىسىم ئەمەس، بەلكى پارس ئىمپېراتورىنىڭ ئومۇمىي بىر ئۇنۋانى ئىدى. شۇڭا بىز «ئاھاشۋېروش» دەپ ئاتالغان پادىشاھنى كامبىسىس (مىلادىيەدىن ئىلگىرىكى 529-521-يىللار)، دەپ قارايمىز.\f*
\v 7 شۇنىڭدەك ئارتاخشاشتا كۈنلىرىدە بىشلام، مىترىدات، تابەئەل ۋە ئۇلارنىڭ قالغان شېرىكلىرىمۇ پارس پادىشاھى ئارتاخشاشتاغا ئارامىي تىلىدا بىر ئەرز خېتىنى يازدى؛ خەت ئارامىي تىلىدىن تەرجىمە قىلىندى. \f ◼ \fr 4:7 \ft \bd «ئارتاخشاشتا»\bd* ــ «ئارتاخشاشتا» بىلەن «ئارتاكسەركسىس» بىر ئادەمنىڭ نامى بولۇپ، تارىختا ئۇ «ئارتاكسەركسىس» دېگەن (گرېكچە) ئىسمى بىلەن تونۇلغان. بۇ پادىشاھ كامبىسىس ۋە دارىئۇس خىستاسپىس (مىلادىيەدىن ئىلگىرى 522-486-يىللار) ئارىلىقىدا ئۆتكەن بولسا كېرەك. شۇڭا ئۇ: (1) كامبىسىسنى ئۆلتۈرۈپ تەختىنى تارتىۋالغان «سمەردىس» دېگەن جادۇگەرنى (يەتتە ئاي تەختكە ئولتۇرغان) ياكى بولمىسا: (2) كامبىسىس ئىمپېراتور بىلەن بىرلىكتە ھۆكۈمرانلىق قىلغان بىزگە ھازىر نامەلۇم «ئارتاخشاشتا» (ئارتاكسەركسىس») ئىسىملىك باشقا بىرسىنى كۆرسىتىشى مۇمكىن. ئۇ كېيىنكى ئالەمشۇمۇل ئىمپېراتور «ئارتاكسەركسىس» (مىلادىيەدىن ئىلگىرى 486-425-يىللار) بولۇشى مۇمكىن ئەمەس؛ چۈنكى شۇ كىشى 24-ئايەتتە تىلغا ئېلىنغان دارىئۇس ئىمپېراتوردىن \bd كېيىن\bd* ھۆكۈمرانلىق قىلدى.\f*
\m 
\v 8 ۋالىي رەھۇم بىلەن كاتىپ بېگى شىمشاي پادىشاھ ئارتاخشاشتاغا يېرۇسالېم ئۈستىدىن تۆۋەندىكىدەك ئەرزنامە يازدى: ــ \f ◼ \fr 4:8 \ft \bd «...يېرۇسالېم ئۈستىدىن تۆۋەندىكىدەك ئەرزنامە يازدى»\bd* ــ بۇ ئايەتتىن باشلاپ 18:6گىچە «ئەزرا»نىڭ تېكىستى ئارامىي تىلىدا يېزىلغان.\f*
\m 
\v 9 «مەزكۇر مەكتۇپنى يازغانلاردىن، ۋالىي رەھۇم، كاتىپ بېگى شىمشاي ۋە ئۇلارنىڭ باشقا ھەمراھلىرى بولغان سوراقچىلار، مۇپەتتىشلەر، مەنسەپدارلار، كاتىپلار، ئارقىۋىلىقلار، بابىللىقلار، شۇشانلىقلار، يەنى ئېلامىيلار \f ◼ \fr 4:9 \ft \bd «...سوراقچىلار، مۇپەتتىشلەر، مەنسەپدارلار، كاتىپلار...»\bd* ــ ياكى «دىنايلىقلار، ئافارساتقىلىقلار، تارپەللىكلەر، ئارفاسلىقلار،...». \bd «شۇشانلىقلار، يەنى...»\bd* ــ ياكى «سۇسا (شەھىرى)دىكىلەر، يەنى...».\f*
\v 10 ۋە ئۇلۇغ جانابىي ئوسناپپار سامارىيە شەھىرىگە ۋە \add ئەفرات\add* دەرياسىنىڭ مۇشۇ تەرىپىدىكى باشقا يەرلەرگە ئورۇنلاشتۇرغان ئاھالىمۇ بار \f ◼ \fr 4:10 \ft \bd «ئۇلۇغ جانابىي ئوسناپپار»\bd* ــ ئوسناپپار بولسا ئاسۇرىيە ئىمپېراتورى «ئاشۇربانىپال»نىڭ ئارامىي تىلىدىكى نامى. ئۇ مىلادىيەدىن ئىلگىرىكى 669-يىلى ئاتىسى ئېسارھاددوننىڭ تەختىگە ۋارىسلىق قىلدى؛ مىلادىيەدىن ئىلگىرىكى 645-يىللىرى ئەتراپىدا ئۇ ئېلامنىڭ پايتەختى شۇشاننى ئىشغال قىلىپ، ئۇنىڭدىكى پۇقرالاردىن بەزىلەرنى سامارىيەگە، شۇنداقلا ئوتتۇرا شەرقتىكى باشقا يەرلەرگە سۈرگۈن قىلدى. \bd «ئەفرات دەرياسى»\bd* ــ مەشكۇر كىتابتا مۇشۇ يەردىن باشلاپ «دەريا» «ئەفرات دەرياسى»نى كۆرسىتىدۇ؛ «مۇشۇ تەرىپى» ــ غەربىي تەرىپى، ئەلۋەتتە.\f*
\v 11 (مانا بۇ ئۇلارنىڭ پادىشاھقا يازغان خېتىنىڭ كۆچۈرۈلمىسى) ــ ئۆزلىرىنىڭ دەريانىڭ مۇشۇ تەرىپىدىكى خىزمەتكارلىرىدىن پادىشاھ ئالىلىرى ئارتاخشاشتاغا سالام!
\v 12 پادىشاھ ئالىيلىرىگە مەلۇم بولسۇنكى، ئۆزلىرى تەرەپتىن بىز تەرەپكە كەلگەن يەھۇدىيلار يېرۇسالېمغا كېلىشتى؛ ئۇلار ئاشۇ ئاسىي ۋە سېسىق شەھەرنى قۇرۇۋاتىدۇ، ئۇلىنى ياساپ پۈتتۈردى، سېپىلنى ياساپ چىقتى ۋە سېپىلنىڭ ئۇللىرىنى بىر-بىرىگە ئۇلاپ ياساۋاتىدۇ. \f ◼ \fr 4:12 \ft \bd «سېپىلنى ياساپ چىقتى ۋە سېپىلنىڭ ئۇللىرىنى بىر-بىرىگە ئۇلاپ ياساۋاتىدۇ»\bd* ــ مۇشۇ گەپ بىرىنچىدىن ئۆز-ئۆزىگە زىت كېلىدۇ. قانداقسىگە سېپىل ئۇللىرى تېخى «بىر-بىرىگە ئۇلانماي» تۇرۇپ سېپىل ياسىلىپ بولىدۇ؟ 12-ئايەتتە خاتىرىلەنگەن ئۆز بايانلىرىمۇ ئۇلارنىڭ شۇ سۆزىگە رەددىيە بولىدۇ. ئىككىنچىدىن، بۇ سۆزلەر پۈتۈنلەي يالغان. يەھۇدىي خەلقى پەقەت ئىبادەتخانا (قورەش پادىشاھنىڭ ئەسلىدىكى يارلىقى بويىچە) قۇرۇۋاتاتتى. سېپىلنىڭ ئۆزى بولسا، خارابىلىك ئەھۋالدا ئىدى. مەسىلەن «نەھ.» 3:1نى كۆرۈڭ.\f*
\v 13 ئەمدى ئۇلۇغ پادىشاھ ئالىيلىرىگە شۇ مەلۇم بولغايكى، مۇبادا بۇ شەھەر ئوڭلانسا، سېپىل پۈتكۈزۈلسە، ئۇلار باج تاپشۇرمايدىغان، ئولپان تۆلىمەيدىغان ۋە پاراق تاپشۇرمايدىغان بولۇۋالىدۇ، بۇنداق كېتىۋەرسە پادىشاھلارنىڭ خەزىنىسىگە سۆزسىز زىيان بولىدۇ.
\v 14 بىز ئوردىنىڭ تۇزىنى يەپ تۇرۇپ، پادىشاھىمىزنىڭ بۇنداق بىھۆرمەت قىلىنىشىغا قاراپ تۇرۇشىمىزغا قەتئىي توغرا كەلمەيدۇ، شۇ سەۋەبتىن پادىشاھىمىزغا مەلۇم قىلىشقا جۈرئەت قىلدۇق. \f ◼ \fr 4:14 \ft \bd «بۇنداق بىھۆرمەت قىلىنىشىغا...»\bd* ــ ياكى «بۇنداق زىيان تارتىشىغا...».\f*
\v 15 شۇنىڭ ئۈچۈن \add ئالىيلىرىنىڭ\add* ئاتا-بوۋىلىرىنىڭ تارىخنامىسىنى سۈرۈشتە قىلىشلىرىنى تەشەببۇس قىلىمىز؛ سىلى تارىخنامىدىن بۇ شەھەرنىڭ ئەھۋالىنى بىلىپ، ئۇنىڭ پادىشاھلارغىمۇ، ھەرقايسى ئۆلكىلەرگىمۇ زىيان يەتكۈزۈپ كەلگەن ئاسىي بىر شەھەر ئىكەنلىكىنى، قەدىمدىن تارتىپ بۇ شەھەردىكىلەر ئاغدۇرمىچىلىق تېرىغانلىقىنى بىلگەيلا؛ دەل شۇ سەۋەبتىن بۇ شەھەر ۋەيران قىلىنغانىدى.
\v 16 شۇڭا بىز ئالىيلىرىغا شۇنى ئۇقتۇرماقچىمىزكى، ئەگەر بۇ شەھەر قۇرۇلسا، سېپىللىرى پۈتكۈزۈلسە، ئۇنداقتا سىلىنىڭ دەريانىڭ مۇشۇ تەرىپىدىكى يەرلەرگە ھېچقانداق ئىگىدارچىلىقلىرى بولماي قالىدۇ».
\b
\s1 پادىشاھنىڭ ئىش توختىتىلسۇن دەپ يارلىق چۈشۈرۈشى
\m 
\v 17 پادىشاھ مۇنداق جاۋاب يوللىدى: ــ
\m «ۋالىي رەھۇم، كاتىپ بېگى شىمشايغا ۋە سامارىيە ھەم دەريانىڭ شۇ تەرىپىدىكى باشقا يەرلەردە تۇرۇشلۇق ھەمراھلىرىڭلارغا سالام! \f ◼ \fr 4:17 \ft \bd «دەرياسىنىڭ شۇ تەرىپى»\bd* ــ ئەرفات دەرياسىنىڭ غەربىي تەرىپى.\f*
\v 18 سىلەرنىڭ بىزگە يازغان ئەرز خېتىڭلار مېنىڭ ئالدىمدا ئېنىق قىلىپ ئوقۇپ بېرىلدى. \f ◼ \fr 4:18 \ft \bd «ئالدىمدا ئېنىق قىلىپ ئوقۇپ...»\bd* ــ ياكى «ئالدىمدا تەرجىمە قىلىنىپ ئوقۇپ....».\f*
\v 19 تەكشۈرۈپ كۆرۈشنى بۇيرۇۋىدىم، بۇ شەھەرنىڭ دەرۋەقە قەدىمدىن تارتىپ پادىشاھلارغا قارشى چىقىپ ئىسيان قوزغىغان، شەھەردە دائىم ئاسىيلىق-قوزغىلاڭ كۆتۈرۈشتەك ئىشلارنىڭ بولۇپ كەلگەنلىكى مەلۇم بولدى.
\v 20 ئىلگىرىكى ۋاقىتلاردا قۇدرەتلىك پادىشاھلار يېرۇسالېمغا ھۆكۈمرانلىق قىلىپ، دەريانىڭ شۇ تەرىپىدىكى پۈتۈن يەرلەرنى ئىدارە قىلىپ كەلگەن، ئۇلار شۇلارغا بېقىنىپ باج، ئولپان ۋە پارىقىنى تاپشۇرۇپ كەلگەنىكەن.
\v 21 ئەمدى سىلەر بۇيرۇق چۈشۈرۈپ ئۇ خەلقنى ئىشتىن توختىتىڭلار، مەندىن باشقا يارلىق چۈشۈرۈلمىگۈچە، بۇ شەھەرنى يېڭىۋاشتىن قۇرۇپ چىقىشقا بولمايدىغانلىقى ئۇقتۇرۇڭلار.
\v 22 بۇ ئىشنى ئادا قىلماي قېلىشتىن پەخەس بولۇڭلار؛ پادىشاھلارغا زىيان كەلتۈرىدىغان ئاپەت نېمىشقا كۈچىيىۋېرىدىكەن؟».
\m 
\v 23 پادىشاھ ئارتاخشاشتانىڭ يارلىقىنىڭ كۆچۈرۈلمىسى رەھۇمغا، كاتىپ بېگى شىمشاي ھەم ئۇلارنىڭ ھەمراھلىرىغا ئوقۇپ بېرىلىشى بىلەنلا، ئۇلار ئالمان-تالمان يېرۇسالېمدىكى يەھۇدالارنىڭ قېشىغا چىقىپ، ھەربىي كۈچ ئىشلىتىپ، ئۇلارنى ئىشنى توختىتىشقا مەجبۇر قىلدى.
\v 24 شۇنىڭ بىلەن يېرۇسالېمدىكى خۇدانىڭ ئۆيىدىكى ئىشلار توختىدى؛ ئىش تاكى پارس پادىشاھى دارىئۇس تەختكە چىقىپ ئىككىنچى يىلىغىچە توختاغلىق قالدى.
\b
\b
\c 5
\s1 مۇقەددەس ئۆينى يەنە بىر قېتىم يېڭىۋاشتىن سېلىش
\m 
\v 1 بۇ چاغدا پەيغەمبەرلەر، يەنى ھاگاي پەيغەمبەر بىلەن ئىددونىڭ ئوغلى زەكەرىيا پەيغەمبەر يەھۇدىيە ۋە يېرۇسالېمدىكى يەھۇدىيلارغا بېشارەت بېرىشكە باشلىدى؛ ئۇلار ئىسرائىلنىڭ خۇداسىنىڭ نامىدا ئۇلارغا بېشارەت بېرىشتى. \x ◘ \xo 5:1 \xt ھاگ. 1‏:1؛ زەك. 1‏:1\x*
\v 2 شۇنىڭ بىلەن شېئالتىيەلنىڭ ئوغلى زەرۇببابەل ۋە يوزاداكنىڭ ئوغلى يەشۇئا قوپۇپ يېرۇسالېمدىكى خۇدانىڭ ئۆيىنى يېڭىۋاشتىن سېلىشقا باشلىدى؛ خۇدانىڭ پەيغەمبەرلىرى ئۇلار بىلەن بىللە بولۇپ ئۇلارغا ياردەم بەردى.
\m 
\v 3 شۇ چاغدا دەريانىڭ غەرب تەرىپىنىڭ باش ۋالىيسى تاتتىناي بىلەن شېتار-بوزناي ھەم ئۇلارنىڭ ھەمراھلىرى ئۇلارنىڭ يېنىغا كېلىپ: «كىم سىلەرگە بۇ ئۆينى يېڭىۋاشتىن سېلىشقا، بۇ قۇرۇلۇشنى پۈتتۈرۈشكە بۇيرۇق بەردى؟» دەپ سورىدى. \f ◼ \fr 5:3 \ft \bd «بۇ قۇرۇلۇشنى...»\bd* ــ ياكى «بۇ تامنى...».\f*
\v 4 ئۇلار يەنە: «بۇ قۇرۇلۇشقا مەسئۇل بولغۇچىلارنىڭ ئىسمى نېمە؟» دەپ سورىدى.
\v 5 لېكىن خۇدانىڭ نەزىرى يەھۇدا ئاقساقاللىرىنىڭ ئۈستىدە ئىدى، شۇڭا باش ۋالىي قاتارلىقلار پادىشاھ دارىئۇسقا مەلۇم قىلغۇچە، شۇنداقلا ئۇنىڭدىن بۇ ھەقتە بىرەر جاۋاب يارلىق كەلگۈچە ئۇلارنىڭ قۇرۇلۇش ئىشىنى توسمىدى.
\b
\s1 پادىشاھ دارىئۇسقا يەنە بىر ئەرز مەلۇم قىلىنىشى
\m 
\v 6 دەريانىڭ غەرب تەرىپىنىڭ ۋالىيسى تاتتىناي بىلەن شېتار-بوزناي ھەم ئۇلارنىڭ ھەمراھلىرى، يەنى دەريانىڭ غەرب تەرىپىدىكى ئافارساقلىقلار پادىشاھ دارىئۇسقا خەت ئەۋەتتى؛ خەتنىڭ كۆچۈرۈلمىسى مانا تۆۋەندىكىدەك:
\v 7 ئۇلار پادىشاھقا ئەۋەتكەن مەلۇماتتا مۇنداق دېيىلگەن: «دارىئۇس ئالىيلىرىغا چوڭقۇر ئامان-ئېسەنلىك بولغاي!
\v 8 پادىشاھىمىزغا شۇ ئىش يېتىپ مەلۇم بولسۇنكى، بىز يەھۇدىيەگە، ئۇلۇغ خۇدانىڭ ئۆيىگە بېرىپ كۆردۇقكى، شۇ ئۆي يوغان تاشلار بىلەن ياسىلىۋاتىدۇ، تاملىرىغا لىملار ئۆتكۈزۈلۈپ سېلىنماقتا؛ بۇ قۇرۇلۇش تېز سۈرەتتە ئوڭۇشلۇق ئېلىپ بېرىلىۋېتىپتۇ. \f ◼ \fr 5:8 \ft \bd «...تېز سۈرەتتە ئوڭۇشلۇق ئېلىپ بېرىلىۋېتىپتۇ»\bd* ــ ياكى «...ئەستايىدىللىق بىلەن ئوڭۇشلۇق ئېلىپ بېرىلىۋېتىپتۇ».\f*
\v 9 ئاندىن بىز ئۇ يەردىكى ئاقساقاللاردىن: ــ كىم سىلەرگە بۇ ئۆينى سېلىشقا، بۇ قۇرۇلۇشنى پۈتتۈرۈشكە بۇيرۇق بەردى؟ ــ دەپ سورىدۇق.
\v 10 ۋە ئالىيلىرىغا مەلۇم بولسۇن ئۈچۈن ئۇلارنىڭ ئىسىملىرىنى سورىدۇق، شۇنىڭدەك ئۇلارنىڭ باشلىقلىرىنىڭ ئىسمىلىرىنى پۈتۈپ خاتىرىلىمەكچى ئىدۇق.
\v 11 ئۇلار بىزگە: «بىز ئاسمان-زېمىننىڭ خۇداسىنىڭ قۇللىرى، بىز ھازىر بۇنىڭدىن ئۇزۇن يىللار ئىلگىرى سېلىنغان ئۆينى يېڭىۋاشتىن سېلىۋاتىمىز. مۇشۇ ئۆينى ئەسلىدە ئىسرائىلنىڭ ئۇلۇغ بىر پادىشاھى سالدۇرغانىدى.
\v 12 لېكىن ئاتا-بوۋىلىرىمىز ئاسماندىكى خۇدانىڭ غەزىپىنى كەلتۈرۈپ قويغاچقا، خۇدا ئۇلارنى كالدىيەلىك بابىل پادىشاھى نېبوقادنەسارنىڭ قولىغا تاپشۇرغان؛ ئۇ بۇ ئۆينى چاقتۇرۇۋېتىپ، خەلقنى بابىلغا تۇتقۇن قىلىپ ئەكەتكەن. \x ◘ \xo 5:12 \xt 2تار. 36‏:16-21\x*
\v 13 لېكىن بابىل پادىشاھى قورەشنىڭ بىرىنچى يىلى پادىشاھ قورەش خۇدانىڭ بۇ ئۆيىنى يېڭىۋاشتىن سېلىشقا يارلىق چۈشۈرگەن. \x ◘ \xo 5:13 \xt 2تار. 36‏:23،22؛ ئەزرا 1\x*
\v 14 ۋە نېبوقادنەسار يېرۇسالېمدىكى بۇ ئىبادەتخانىدىن ئېلىپ بابىل بۇتخانىسىغا ئاپىرىپ قويغان خۇدانىڭ ئۆيىدىكى ئالتۇن-كۈمۈش قاچا-قۇچىلارنىمۇ پادىشاھ قورەش ئۇلارنى بابىل بۇتخانىسىدىن ئەپچىقتۇرۇپ، شەشبازار ئىسىملىك بىر كىشىگە تاپشۇرغان؛ ئۇ ئۇنى باش ۋالىي قىلىپ تەيىنلىگەنىدى. \x ◘ \xo 5:14 \xt ئەزرا 1‏:8\x*
\v 15 ھەم ئۇنىڭغا: ــ بۇ قاچا-قۇچىلارنى ئېلىپ ئۇلارنى يېرۇسالېمدىكى ئىبادەتخانىغا ئاپىرىپ قويغىن؛ خۇدانىڭ ئۆيى ئەسلى جايىغا يېڭىۋاشتىن سېلىنسۇن، دەپ بۇيرۇغان
\v 16 ئاندىن شۇ شەشبازار دېگەن كىشى كېلىپ، يېرۇسالېمدىكى خۇدانىڭ ئۆيىگە ئۇل سالغان؛ ئەنە شۇ ۋاقىتتىن باشلاپ ھازىرغىچە ياسىلىۋاتىدۇ، تېخى پۈتمىدى» دەپ جاۋاپ بەردى.
\m 
\v 17 ئەمدى ئالىيلىرىغا لايىق كۆرۈنسە، پادىشاھىمىزنىڭ شۇ يەردە، يەنى بابىلدىكى خەزىنىنى ئاختۇرۇپ بېقىشىنى، ئۇ يەردە پادىشاھ قورەشنىڭ يېرۇسالېمدىكى خۇدانىڭ ئۆيىنى يېڭىۋاشتىن سېلىش توغرىسىدا چۈشۈرگەن يارلىقىنىڭ بار-يوقلۇقىنى تەكشۈرۈپ بېقىشىنى سورايمىز ھەم پادىشاھىمىزنىڭ بۇ ئىش توغرىسىدا ئۆز ئىرادىسىنى بىزگە بىلدۈرۈپ قويۇشىنى ئۆتۈنىمىز».
\b
\b
\c 6
\s1 پادىشاھ دارىئۇسنىڭ ئىلگىرىكى پادىشاھنىڭ يارلىقىنى تېپىشى
\m 
\v 1 ئاندىن پادىشاھ دارىئۇس بابىلدىكى دۆلەت-بايلىقلار ساقلانغان «ئارخىپلار ئۆيى»نى تەكشۈرۈپ چىقىشقا يارلىقلارنى چۈشۈردى. \f ◼ \fr 6:1 \ft \bd «ئارخىپلار ئۆيى»\bd* ــ ئارامىي تىلىدا «ئورام ئارخىپلار ئۆيى».\f*
\v 2 مېدىئا ئۆلكىسىدىكى ئاخمېتا قەلئەسىدىن بىر ئورام قەغەز تېپىلدى، ئۇنىڭدا مۇنداق بىر خاتىرە پۈتۈلگەن: \f ◼ \fr 6:2 \ft \bd «ئاخمېتا»\bd* ــ تارىختا بۇ قەلئە ئادەتتە «ئەكباتانا» دېگەن نامى بىلەن تونۇلغان.\f*
\v 3 «پادىشاھ قورەشنىڭ بىرىنچى يىلى، پادىشاھ قورەش يېرۇسالېمدىكى خۇدانىڭ ئۆيىگە دائىر مۇنداق بىر يارلىق چۈشۈرىدۇ: ــ «قۇربانلىق سۇنۇلىدىغان ئورۇن بولۇش ئۈچۈن بۇ ئۆي يېڭىۋاشتىن سېلىنسۇن؛ ئۇلى پۇختا سېلىنسۇن، ئۆينىڭ ئېگىزلىكى ئاتمىش گەز، كەڭلىكى ئاتمىش گەز بولسۇن. \f ◼ \fr 6:3 \ft \bd «ئۆينىڭ ئېگىزلىكى ئاتمىش گەز، كەڭلىكى ئاتمىش گەز...»\bd* ــ مۇقەددەس كىتابتا ئىشلىتىلگەن «گەز» قولنىڭ جەينەكتىن بارماقنىڭ ئۇچىغىچە بولغان ئارىلىقى (تەخمىنەن 45 سانتىمېتر) ئىدى.\f*
\v 4 ئۈچ قەۋەت يوغان تاش، بىر قەۋەت يېڭى ياغاچ بىلەن سېلىنسۇن، بارلىق خىراجەت پادىشاھلىق خەزىنىسىدىن چىقىم قىلىنسۇن.
\v 5 ئەسلىدە نېبوقادنەسار يېرۇسالېمدىكى ئىبادەتخانىدىن ئېلىپ بابىلغا ئاپىرىپ قويغان، خۇدانىڭ ئۆيىدىكى ئالتۇن-كۈمۈش قاچا-قۇچىلارنىڭ ھەممىسى قايتۇرۇپ كېلىنىپ، يېرۇسالېمدىكى ئىبادەتخانىغا قايتىدىن يەتكۈزۈلۈپ، ھەربىرى ئۆز جايىغا قويۇلسۇن؛ ئۇلار خۇدانىڭ ئۆيىگە قويۇلسۇن!».
\b
\s1 پادىشاھنىڭ مۇقەددەس ئۆينى داۋاملىق يېڭىۋاشتىن سېلىشقا بۇيرۇق چۈشۈرۈشى
\m 
\v 6 \add دارىئۇستىن يارلىق چۈشۈرۈلۈپ\add*: «ــ شۇڭا، ئى دەريانىڭ شۇ تەرىپىنىڭ باش ۋالىيسى تاتتىناي ۋە شېتار-بوزناي ھەم سىلەرنىڭ ھەمراھلىرىڭلار، يەنى دەريانىڭ شۇ تەرىپىدىكى ئافارساقلىقلار، ئەمدى سىلەر ئۇ يەردىن نېرى كېتىڭلار! \f ◼ \fr 6:6 \ft \bd «دەريانىڭ شۇ تەرىپى»\bd* ــ ئەفرات دەرياسىنىڭ غەرب تەرىپىنى كۆرسىتىدۇ.\f*
\v 7 خۇدانىڭ ئۆيىنىڭ قۇرۇلۇشى بىلەن كارىڭلار بولمىسۇن؛ يەھۇدىيلارنىڭ باش ۋالىيسى بىلەن يەھۇدىيلارنىڭ ئاقساقاللىرىنىڭ خۇدانىڭ بۇ ئۆيىنى ئەسلىدىكى ئورنىغا سېلىشىغا يول قويۇڭلار.
\m 
\v 8 شۇنىڭدەك مەن خۇدانىڭ بۇ ئۆيىنىڭ سېلىنىشى ئۈچۈن يەھۇدالارنىڭ ئاقساقاللىرى توغرۇلۇق سىلەرگە بۇيرۇق چۈشۈردۇمكى: ــ دەريانىڭ غەرب تەرىپىدىن، پادىشاھلىق خەزىنىسىگە تاپشۇرۇلغان باج كىرىمىدىن سىلەر كېچىكتۈرمەي شۇ ئادەملەرگە تولۇق خىراجەت ئاجرىتىپ بېرىڭلار، قۇرۇلۇش ھېچ توختاپ قالمىسۇن. \f ◼ \fr 6:8 \ft \bd «كېچىكتۈرمەي...»\bd* ــ ياكى «ئەستايىدىللىق بىلەن...».\f*
\v 9 ئۇلارغا نېمە كېرەك بولسا، جۈملىدىن ئاسماندىكى خۇداغا كۆيدۈرمە قۇربانلىق سۇنۇشقا، مەيلى ئەركەك تورپاق بولسۇن، قوچقار ياكى قوزىلار بولسىمۇ، شۇلار بېرىلسۇن؛ يەنە يېرۇسالېمدىكى كاھىنلارنىڭ بەلگىلىگىنى بويىچە بۇغداي، تۇز، شاراب ياكى زەيتۇن مايلار بولسۇن شۇلارنىڭ بىرىمۇ كەم قىلىنماي، ھەر كۈنى تەمىن ئېتىپ تۇرۇلسۇن.
\v 10 شۇنىڭ بىلەن ئۇلار ئاسماندىكى خۇداغا خۇشبۇي قۇربانلىقلارنى كەلتۈرۈپ، پادىشاھقا ۋە پادىشاھنىڭ ئەۋلادلىرىغا ئۇزۇن ئۆمۈر تىلىسۇن. \f ◼ \fr 6:10 \ft \bd «پادىشاھنىڭ ئەۋلادلىرىغا ئۇزۇن ئۆمۈر تىلىسۇن»\bd* ــ ئارامىي تىلىدا «پادىشاھ ۋە ئۇنىڭ ئوغۇللىرىنىڭ ھاياتىنى تىلىسۇن».\f*
\v 11 مەن يەنە بۇيرۇيمەنكى، كىمكى بۇ يارلىقنى ئۆزگەرتسە، شۇ كىشىنىڭ ئۆيىنىڭ بىر تال لىمى سۇغۇرۇۋېلىنىپ تىكلەنگەندىن كېيىن، شۇ كىشى ئۇنىڭغا ئېسىپ مىخلاپ قويۇلسۇن، ئۆيى ئەخلەتخانىغا ئايلاندۇرۇۋېتىلسۇن! \f ◼ \fr 6:11 \ft \bd «ئەخلەتخانىغا ئايلاندۇرۇۋېتىلسۇن!»\bd* ــ ياكى «ھاجەتخانىغا ئايلاندۇرۇۋېتىلسۇن!».\f*
\v 12 ۋە ئۆزىنىڭ نامىنى شۇ يەردە قالدۇرغان خۇدا مۇشۇ يېرۇسالېمدىكى ئۆيىنى ئۆزگەرتىشكە ياكى بۇزۇشقا قول ئۇزارتقان ھەرقانداق پادىشاھ ياكى خەلقنى ھالاك قىلسۇن! مەن دارىئۇس مۇشۇ يارلىقنى چۈشۈردۇم، ئەستايىدىللىق بىلەن بەجا كەلتۈرۈلسۇن!» دېيىلدى.
\b
\s1 ئىبادەتخانىنىڭ پۈتكۈزۈلۈشى
\m 
\v 13 ئاندىن دەريانىڭ غەرب تەرىپىنىڭ باش ۋالىيسى تاتتىناي، شېتار-بوزناي ۋە ئۇلارنىڭ ھەمراھلىرى پادىشاھ دارىئۇسنىڭ ئەۋەتكەن يوليورۇقى بويىچە ئەستايىدىللىق بىلەن شۇ ئىشنى بەجا كەلتۈردى.
\v 14 يەھۇدىيلارنىڭ ئاقساقاللىرى قۇرۇلۇشنى داۋاملاشتۇرۇپ، ھاگاي پەيغەمبەر ۋە ئىددونىڭ ئوغلى زەكەرىيانىڭ بېشارەت بېرىشلىرى بىلەن شۇ ئىشتا روناق تاپتى. ئۇلار ئىسرائىلنىڭ خۇداسىنىڭ ئەمرى بويىچە، شۇنداقلا قورەش، دارىئۇس ۋە ئارتاخشاشتا قاتارلىق پارس پادىشاھلىرىنىڭ ئەمرى بويىچە ئىشلەپ، ئۆينى يېڭىۋاشتىن قۇرۇپ چىقىش ئىشىنى پۈتتۈردى.
\v 15 بۇ ئۆي دارىئۇس پادىشاھى سەلتەنىتىنىڭ ئالتىنچى يىلى، ئادار ئېيىنىڭ ئۈچىنچى كۈنى پۈتكۈزۈلدى.
\b
\s1 ئۆينىڭ خۇداغا ئاتىلىشى
\m 
\v 16 ئىسرائىللار ــ كاھىنلار، لاۋىيلار ۋە قالغان سۈرگۈنلۈكتىن قايتىپ كەلگەن خەلقلەرنىڭ ھەممىسى خۇدانىڭ بۇ ئۆيىنى ئۇنىڭغا ئاتاش مۇراسىمىنى خۇشال-خۇراملىق بىلەن ئۆتكۈزدى.
\v 17 ئۆينى خۇدانىڭ ئۆزىگە ئاتاش مۇراسىمىدا ئۇلار يۈز تورپاق، ئىككى يۈز قوچقار ۋە تۆت يۈز قوزا سۇندى ھەم ئىسرائىل قەبىلىلىرىنىڭ سانى بويىچە بارلىق ئىسرائىل ئۈچۈن گۇناھ قۇربانلىقى سۈپىتىدە ئون ئىككى تېكىنى سۇندى.
\v 18 ئۇلار يەنە يېرۇسالېمدىكى خۇدانىڭ ئىبادەت-خىزمىتىنى ئۆتەشكە، مۇسانىڭ كىتابىدا يېزىلغىنى بويىچە، كاھىنلارنى ئۆز نۆۋىتى بويىچە، لاۋىيلارنى گۇرۇپپىلىرى بويىچە تۇرغۇزدى. \f ◼ \fr 6:18 \ft \bd «مۇسانىڭ كىتابى»\bd* ــ بەلكىم تەۋراتنىڭ 1-، 2-، 3-، 4- ۋە 5-قىسىملىرىنى كۆرسىتىدۇ.\f*  \x ◘ \xo 6:18 \xt چۆل. 3‏:6، 32؛ 8‏:11؛ 1تار. 24‏:1\x*
\b
\s1 ئۆتۈپ كېتىش ھېيتىنىڭ ئۆتكۈزۈلۈشى
\m 
\v 19 بىرىنچى ئاينىڭ ئون تۆتىنچى كۈنى سۈرگۈنلۈكتىن قايتىپ كەلگەنلەر «ئۆتۈپ كېتىش ھېيتى»نى ئۆتكۈزدى. \x ◘ \xo 6:19 \xt مىس. 12‏:1-28؛ لاۋ. 23‏:5؛ چۆل. 28‏:16؛ قان. 16‏:2\x*
\v 20 چۈنكى كاھىنلار ۋە لاۋىيلار بىر نىيەت بىلەن بىرلىكتە پاكلىنىش رەسىملىرىنى ئۆتكۈزۈپ، ھەممىسى پاكلاندى؛ ئاندىن ئۇلار بارلىق سۈرگۈنلۈكتىن قايتىپ كەلگەنلەر ۋە ئۇلارنىڭ قېرىندىشى بولغان كاھىنلار ۋە ھەم ئۆزلىرى ئۈچۈن ئۆتۈپ كېتىش ھېيتىغا ئاتىغان \add قوزىلىرىنى\add* سويدى.
\v 21 سۈرگۈنلۈكتىن \add يېڭىلا\add* قايتىپ كەلگەن ئىسرائىللار ۋە شۇنىڭدەك ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنى ئىزدەپ، ئۆزلىرىنى زېمىندىكى يات ئەللىكلەرنىڭ بۇلغاشلىرىدىن ئايرىپ چىققان بارلىق كىشىلەر قوزا گۆشلىرىنى بىرلىكتە يېيىشتى.
\v 22 ئۇلار پېتىر نان ھېيتىنى خۇشال-خۇراملىق ئىچىدە يەتتە كۈن ئۆتكۈزدى؛ چۈنكى پەرۋەردىگار ئۇلارنى خۇشاللىققا چۆمدۈردى ھەم ئاسۇرىيە پادىشاھىنىڭ كۆڭلىنى ئۇلارغا مايىل قىلىپ، ئۆزىنىڭ ئۆيىنى ــ ئىسرائىلنىڭ خۇداسىنىڭ ئۆيىنى قۇرۇشقا ئۇلارنىڭ قولىنى مۇستەھكەملىدى. \f ◼ \fr 6:22 \ft \bd «ئاسۇرىيە پادىشاھىنىڭ كۆڭلى»\bd* ــ پارس ئىمپېراتورىنى «ئاسۇرىيە پادىشاھى» دەپ ئاتاش قىزىق ئىش. شۈبھىسىزكى، پارس ئىمپېراتورى «بابىل پادىشاھى»، شۇنداقلا «ئاسۇرىيە پادىشاھى» دېگەن ئۇنۋانلارغا ۋارىسلىق قىلغان.\f*
\b
\b
\c 7
\s1 كاھىن ئەزرانىڭ بابىلدىن قايتىپ كېلىشى
\m 
\v 1 شۇ ئىشلاردىن كېيىن پارس پادىشاھى ئارتاخشاشتا سەلتەنەت سۈرگەن مەزگىلدە ئەزرا دېگەن كىشى \add بابىلدىن يېرۇسالېمغا چىقتى\add*. ئۇ سېرايانىڭ ئوغلى، سېرايا ئازارىيانىڭ ئوغلى، ئازارىيا ھىلقىيانىڭ ئوغلى،
\v 2 ھىلقىيا شاللۇمنىڭ ئوغلى، شاللۇم زادوكنىڭ ئوغلى، زادوك ئاخىتۇبنىڭ ئوغلى،
\v 3 ئاخىتۇب ئامارىيانىڭ ئوغلى، ئامارىيا ئازارىيانىڭ ئوغلى، ئازارىيا مېرايوتنىڭ ئوغلى،
\v 4 مېرايوت زەراھىياھنىڭ ئوغلى، زەراھىياھ ئۇززىنىڭ ئوغلى، ئۇززى بۇككىنىڭ ئوغلى،
\v 5 بۇككى ئابىشۇئانىڭ ئوغلى، ئابىشۇئا فىنىھاسنىڭ ئوغلى، فىنىھاس ئەلىئازارنىڭ ئوغلى، ئەلىئازار بولسا باش كاھىن ھارۇننىڭ ئوغلى ئىدى؛
\v 6 ــ ئەزرا دېگەن بۇ كىشى بابىلدىن قايتىپ چىقتى. ئۇ ئىسرائىلنىڭ خۇداسى پەرۋەردىگار مۇساغا نازىل قىلغان تەۋرات قانۇنىغا پىشقان تەۋراتشۇناس ئىدى؛ ئۇنىڭ خۇداسى بولغان پەرۋەردىگارنىڭ قولى ئۇنىڭدا بولغاچقا، ئۇ نېمىنى تەلەپ قىلسا پادىشاھ شۇنى بەرگەنىدى. \f ◼ \fr 7:6 \ft \bd «قايتىپ چىقتى»\bd* ــ مۇقەددەس كىتابتا «يېرۇسالېمغا بېرىش»، ياكى «يېرۇسالېمغا كېلىش» دېگەن سۆز دائىم دېگۈدەك «يېرۇسالېمغا چىقىش» دېگەن ئىبارە بىلەن ئىپادىلىنىدۇ (مەسىلەن، «يەر.» 6:31). \bd «پەرۋەردىگارنىڭ قولى ئۇنىڭدا بولغاچقا...»\bd* ــ تەۋراتتا «پەرۋەردىگارنىڭ قولى ئۇنىڭدا بولغاچقا» دېگەن سۆزلەر كۆپ يەرلەردە ئۇچرايدۇ، ئۇ: «پەرۋەردىگار ئۇنىڭغا مەدەت بەرگەچكە» دېگەن مەنىنى بىلدۈرىدۇ.\f*
\v 7 پادىشاھ ئارتاخشاشتانىڭ يەتتىنچى يىلى بىر قىسىم ئىسرائىللار، كاھىنلار، لاۋىيلار، غەزەلكەشلەر، دەرۋازىۋەنلەر ۋە ئىبادەتخانا خىزمەتكارلىرى ئۇنىڭ بىلەن بىرلىكتە يېرۇسالېمغا قايتىپ چىقتى. \f ◼ \fr 7:7 \ft \bd «ئىبادەتخانا خىزمەتكارلىرى»\bd* ــ ئىبرانىي تىلىدا «نەتىنىيلار». 43:2نى كۆرۈڭ.\f*
\v 8 \add ئەزرا\add* ئەمدى پادىشاھنىڭ سەلتەنىتىنىڭ يەتتىنچى يىلى بەشىنچى ئايدا يېرۇسالېمغا يېتىپ كەلدى.
\v 9 بىرىنچى ئاينىڭ بىرىنچى كۈنى ئۇ بابىلدىن چىقىشقا تەييارلاندى؛ خۇدانىڭ شەپقەتلىك قولى ئۇنىڭدا بولغاچقا، ئۇ بەشىنچى ئاينىڭ بىرىنچى كۈنى يېرۇسالېمغا يېتىپ كەلدى.
\v 10 چۈنكى ئەزرا كۆڭۈل قويۇپ پەرۋەردىگارنىڭ تەۋرات-قانۇنىنى چۈشىنىپ تەھسىل قىلىشقا ھەم ئۇنىڭغا ئەمەل قىلىشقا ۋە شۇنىڭدەك ئىسرائىل ئىچىدە ئۇنىڭدىكى ھۆكۈم-بەلگىلىمىلەرنى ئۆگىتىشكە نىيەت قىلغانىدى.
\b
\s1 پادىشاھ ئارتاخشاشتانىڭ ئەزراغا تاپشۇرغان يارلىق خېتى
\m 
\v 11 مانا بۇ پادىشاھ ئارتاخشاشتا كاھىن ھەم تەۋراتشۇناس ئەزراغا تاپشۇرغان يارلىق خېتىنىڭ كۆچۈرۈلمىسى: ــ (ئەزرا پەرۋەردىگارنىڭ ئەمرلىرىگە ئائىت ئىشلارغا ھەم ئۇنىڭ ئىسرائىللارغا تاپشۇرغان بەلگىلىمىلىرىگە پىشقان تەۋراتشۇناس ئىدى): ــ
\v 12 «مەنكى پادىشاھلارنىڭ پادىشاھى ئارتاخشاشتادىن ئاسمانلاردىكى خۇدانىڭ مۇكەممەل تەۋرات-قانۇنىغا پىشقان تەۋراتشۇناس كاھىن ئەزراغا سالام! \f ◼ \fr 7:12 \ft \bd «خۇدانىڭ مۇكەممەل تەۋرات-قانۇنى»\bd* ــ بۇ ئايەتتىكى «مۇكەممەل» دېگەن سۆزنىڭ باشقا تەرجىمىلەردىكى ئورنى بىزنىڭ تەرجىمىمىزدىكىگە ئوخشاش بولماسلىقى مۇمكىن: ــ مەسىلەن «ئارتاخشاشتادىن... خۇدانىڭ قانۇنىغا \bd مۇكەممەل\bd* تەۋراتشۇناس بولغان كاھىن ئەزراغا...» ياكى «ئارتاخشاشتادىن... ئەزراغا \bd مۇكەممەل\bd* سالام (خاتىرجەملىك) بولغاي».\f*
\v 13 ئەمدى مەن شۇنداق يارلىق چۈشۈرىمەنكى، پادىشاھلىقىمدا تۇرۇۋاتقان ئىسرائىللاردىن، شۇنداقلا ئۇلارنىڭ كاھىن ۋە لاۋىيلىرىدىن كىملەر يېرۇسالېمغا بېرىشنى خالىسا، ھەممىسى سېنىڭ بىلەن بىللە بارسا بولىدۇ.
\v 14 چۈنكى سەن پادىشاھ ۋە ئۇنىڭ يەتتە مەسلىھەتچىسى تەرىپىدىن تەيىنلەنگەن ئىكەنسەن، قولۇڭدىكى خۇدانىڭ قانۇن كىتابىدا ئېيتىلغانلىرى بويىچە، يەھۇدىيە ۋە يېرۇسالېمغا تەكشۈرۈش-ھال سوراشقا ئەۋەتىلگەنسەن.
\v 15 سەن پادىشاھ ۋە ئۇنىڭ مەسلىھەتچىلىرى ئۆز ئىختىيارى بىلەن ئىسرائىلنىڭ خۇداسىغا سۇنغان ئالتۇن-كۈمۈشلەرنى كۆتۈرۈپ بېرىپ ئۇنىڭغا تەقدىم قىل (ئۇنىڭ ماكانى يېرۇسالېمدىدۇر)؛ \x ◘ \xo 7:15 \xt ئەزرا 8‏:25\x*
\v 16 شۇنىڭدەك قولۇڭ پۈتكۈل بابىل ئۆلكىسىدە قانچىلىك ئالتۇن-كۈمۈشلەرنى تاپالىسا، شۇنى خەلق ۋە كاھىنلار يېرۇسالېمدىكى خۇدانىڭ ئۆيىگە تەقدىم قىلىشقا ئۆز ئىختىيارى بىلەن بەرگەن سوۋغاتلارغا قوشۇپ ئاپارغىن.
\v 17 سەن بۇ پۇللارغا ئېھتىياتچانلىق بىلەن قۇربانلىقلار ئۈچۈن تورپاق، قوچقار، قوزا ۋە قوشۇمچە ئاشلىق ھەدىيەلىرى ھەم شاراب ھەدىيەلىرى سېتىۋېلىپ، بۇلارنى يېرۇسالېمدىكى خۇدايىڭلارنىڭ ئۆيىدىكى قۇربانگاھقا سۇنغىن.
\m 
\v 18 قالغان ئالتۇن-كۈمۈشلەرنى سەن ۋە جەمەتىڭدىكىلەرگە قانداق قىلىش مۇۋاپىق كۆرۈنسە، خۇدايىڭلارنىڭ ئىرادىسى بويىچە شۇنداق قىلىڭلار.
\v 19 سېنىڭ خۇدايىڭنىڭ ئۆيىدىكى ئىشلارغا ئىشلىتىشكە ساڭا بەرگەن قاچا-قۇچىلارنى يېرۇسالېمدىكى خۇدانىڭ ئالدىغا قوي.
\v 20 ئەگەر شۇنىڭدەك ساڭا خۇدايىڭنىڭ ئۆيىدىكى قالغان ئىشلارغا چىقىم قىلىدىغانغا نېمە خىراجەت كېرەك بولسا، سەن پادىشاھ خەزىنىسىدىن ئېلىپ ئىشلەتكىن.
\m 
\v 21 شۇنىڭ بىلەن مەنكى پادىشاھ ئارتاخشاشتادىن دەريانىڭ شۇ غەرب تەرىپىدىكى بارلىق خەزىنە بەگلىرىگە شۇنداق بۇيرۇق چۈشۈرىمەنكى، ئاسماندىكى خۇدانىڭ تەۋرات-قانۇنىنىڭ ئالىمى بولغان كاھىن ئەزرا سىلەردىن نېمىنى تەلەپ قىلسا، سىلەر ئەستايىدىللىق بىلەن ئۇنىڭ دېگىنىدەك بېجىرىڭلار.
\v 22 ئۇنىڭ ئالىدىغىنى كۈمۈش يۈز تالانتقىچە، بۇغداي يۈز كورغىچە، شاراب يۈز باتقىچە، زەيتۇن مېيى يۈز باتقىچە بولسۇن، تۇزغا چەك قويۇلمىسۇن. \f ◼ \fr 7:22 \ft \bd «كۈمۈش يۈز تالانتقىچە، بۇغداي يۈز كورغىچە، شاراب يۈز باتقىچە،...»\bd* ــ بىر «تالانت»نىڭ توپتوغرا قانچىلىك ئىكەنلىكى ھازىر بىزگە نامەلۇم، بەلكىم 45 كىلوگرام بولۇشى مۇمكىن؛ شۇڭا 100 تالانت كۈمۈش بەلكىم 4 توننىچە بولاتتى؛ بىر «كور» 220 لىتر، 100 كور بۇغداي 30 توننا، بىر «بات» 22 لىتر، 100 بات 2200 لىتر بولاتتى.\f*
\v 23 ئاسمانلاردىكى خۇدا نېمىنى ئەمر قىلسا، شۇ ئاسمانلاردىكى خۇدانىڭ ئۆيى ئۈچۈن ئەستايىدىللىق بىلەن بېجىرىلسۇن؛ نېمىشقا \add خۇدانىڭ\add* غەزىپىنى پادىشاھ ۋە ئوغۇللىرىنىڭ پادىشاھلىقىغا چۈشۈرگۈدەكمىز؟
\v 24 بىز شۇنىمۇ سىلەرگە مەلۇم قىلىمىزكى، ئومۇمەن كاھىنلار، لاۋىيلار، غەزەلكەشلەر، دەرۋازىۋەنلەر، ئىبادەتخانا خىزمەتكارلىرى ۋە خۇدانىڭ بۇ ئۆيىدە خىزمەت قىلىدىغانلارنىڭ ھېچقايسىسىدىن باج، ئولپان ۋە پاراق ئېلىشقا بولمايدۇ.
\m 
\v 25 ئەمدى سەن ئەي ئەزرا، خۇدايىڭنىڭ سەندە بولغان ھېكمىتىگە ئاساسەن، دەريانىڭ شۇ غەرب تەرىپىدە خۇدايىڭنىڭ تەۋرات-قانۇنىنى بىلگەن، بارلىق خەلقنىڭ دەۋاسىنى سورايدىغان، ئۇلارنى ئىدارە قىلىدىغان سوراقچى ۋە ھاكىملارنى تەيىنلىگىن؛ ۋە تەۋرات-قانۇنىنى بىلمەيدىغانلارغا بولسا، ئۇلارغا بۇلارنى ئۆگىتىڭلار. \f ◼ \fr 7:25 \ft \bd «ئەمدى سەن ئەي ئەزرا، خۇدايىڭنىڭ سەندە بولغان ھېكمىتىگە ئاساسەن...»\bd* ــ ئىبرانىي تىلىدا «ئەمدى سەن قولۇڭدا تۇتقان خۇدايىڭنىڭ ھېكمىتىگە ئاساسەن...».\f*
\v 26 خۇدايىڭنىڭ قانۇنىغا ۋە پادىشاھلىقنىڭ قانۇنىغا رىئايە قىلمايدىغانلار بولسا، ئۇنىڭ ئۈستىدىن ئادالەتلىك بىلەن ھۆكۈم چىقىرىلسۇن؛ ئۇ ئۆلۈمگە، ياكى سۈرگۈنگە ياكى مال-مۈلكىنى مۇسادىرە قىلىشقا ۋە ياكى زىندانغا تاشلاشقا ھۆكۈم قىلىنسۇن».
\b
\s1 ئەزرانىڭ خۇداغا ھەمدۇسانا ئوقۇشلىرى
\m 
\v 27 \add ئەزرا مۇنداق دېدى\add* ــ ئاتا-بوۋىلىرىمىزنىڭ خۇداسى بولغان پەرۋەردىگارغا ھەمدۇسانا بولغاي! چۈنكى ئۇ پادىشاھنىڭ كۆڭلىگە، يېرۇسالېمدىكى پەرۋەردىگارنىڭ ئۆيىنى شۇنداق كۆركەم بېزەش نىيىتىنى سالدى،
\v 28 يەنە مېنى پادىشاھ ۋە مەسلىھەتچىلىرى ئالدىدا ھەم پادىشاھنىڭ مۆھتەرەم ئەمىرلىرى ئالدىدا ئىلتىپاتقا ئېرىشتۈردى. پەرۋەردىگار خۇدايىمنىڭ قولى مەندە بولۇپ، ئۇ مېنى غەيرەتلەندۈرگەچكە، ئۆزۈم بىلەن بىللە \add يېرۇسالېمغا\add* چىقىشقا ئىسرائىللار ئىچىدىن بىرنەچچە مۆتىۋەرلەرنى يىغدىم.
\b
\b
\c 8
\s1 ئەزرا بىلەن بىللە قايتقانلارنىڭ سانى
\m 
\v 1 پادىشاھ ئارتاخشاشتا سەلتەنەت سۈرۈپ تۇرغان ۋاقىتتا، بابىلدىن مېنىڭ بىلەن بىللە قايتقانلارنىڭ ئاتا جەمەت باشلىقلىرى ۋە ئۇلارنىڭ نەسەبنامىلىرى تۆۋەندىكىچە: ــ
\m 
\v 2 فىنىھاسنىڭ ئەۋلادلىرىدىن گەرشون، ئىتامارنىڭ ئەۋلادلىرىدىن دانىيال، داۋۇتنىڭ ئەۋلادلىرىدىن ھاتتۇش،
\v 3 شېكانىيانىڭ ئەۋلادلىرىدىن، يەنى پاروشنىڭ ئەۋلادلىرىدىن زەكەرىيا ۋە ئۇنىڭ بىلەن نەسەبنامىدە تىزىملانغان ئەركەكلەر جەمئىي بىر يۈز ئەللىك كىشى؛ \f ◼ \fr 8:3 \ft \bd «شېكانىيانىڭ ئەۋلادلىرىدىن»\bd* ــ باشقا بىرخىل تەرجىمىسى (2-ئايەت بىلەن بىرلەشتۈرۈلۈپ): «داۋۇتنىڭ ئەۋلادلىرىدىن، ھاتتۇش، يەنى شېكانىيانىڭ ئوغلى، پاروشنىڭ ئەۋلادلىرىدىن... ».\f*
\v 4 پاھات-موئابنىڭ ئەۋلادلىرىدىن زەراھىياھنىڭ ئوغلى ئەليويىناي ۋە ئۇنىڭ بىلەن بىللە قايتقان ئەركەكلەر ئىككى يۈز كىشى؛
\v 5 شېكانىيانىڭ ئەۋلادلىرىدىن بولغان ياھازىيەلنىڭ ئوغلى ۋە ئۇنىڭ بىلەن بىللە قايتقان ئەركەكلەر ئۈچ يۈز كىشى؛ \f ◼ \fr 8:5 \ft \bd «شېكانىيانىڭ ئەۋلادلىرىدىن بولغان ياھازىيەلنىڭ ئوغلى»\bd* ــ كونا گرېكچە تەرجىمىسى (LXX)دە «زاتتۇنىڭ ئەۋلادلىرىدىن ياھازىيەلنىڭ ئوغلى شېكانىيا» دېيىلگەن. بۇ كونا تەرجىمە توغرا بولۇشى مۇمكىن.\f*
\v 6 ئادىننىڭ ئەۋلادلىرىدىن يوناتاننىڭ ئوغلى ئەبەد ۋە ئۇنىڭ بىلەن بىللە قايتقان ئەركەكلەر ئەللىك كىشى؛
\v 7 ئېلامنىڭ ئەۋلادلىرىدىن ئاتالىيانىڭ ئوغلى يەشايا ۋە ئۇنىڭ بىلەن بىللە قايتقان ئەركەكلەر يەتمىش كىشى؛
\v 8 شەفاتىيانىڭ ئەۋلادلىرىدىن مىكائىلنىڭ ئوغلى زەبادىيا ۋە ئۇنىڭ بىلەن بىللە قايتقان ئەركەكلەر سەكسەن كىشى؛
\v 9 يوئابنىڭ ئەۋلادلىرىدىن يەھىيەلنىڭ ئوغلى ئوبادىيا ۋە ئۇنىڭ بىلەن بىللە قايتقان ئەركەكلەر ئىككى يۈز ئون سەككىز كىشى؛
\v 10 شېلومىتنىڭ ئەۋلادلىرىدىن يوسىفىيانىڭ ئوغلى ۋە ئۇنىڭ بىلەن بىللە قايتقان ئەركەكلەر بىر يۈز ئاتمىش كىشى؛ \f ◼ \fr 8:10 \ft \bd «شېلومىتنىڭ ئەۋلادلىرىدىن يوسىفىيانىڭ ئوغلى»\bd* ــ كونا گرېكچە تەرجىمىسى (LXX)دە «بانىنىڭ ئەۋلادلىرىدىن يوسىفىيانىڭ ئوغلى شېلومىت» دېيىلگەن. بۇ كونا تەرجىمە توغرا بولۇشى مۇمكىن.\f*
\v 11 بىباينىڭ ئەۋلادلىرىدىن بىباينىڭ ئوغلى زەكەرىيا ۋە ئۇنىڭ بىلەن بىللە قايتقان ئەركەكلەر يىگىرمە سەككىز كىشى؛
\v 12 ئازگادنىڭ ئەۋلادلىرىدىن ھاككاتاننىڭ ئوغلى يوھانان ۋە ئۇنىڭ بىلەن بىللە قايتقان ئەركەكلەر بىر يۈز ئون كىشى؛
\v 13 ئادونىكامنىڭ ئەۋلادلىرىدىن ئەڭ ئاخىرىدا قايتقانلارنىڭ ئىسىملىرى ئەلىفەلەت، يەئىيەل ۋە شېمايا بولۇپ، ئۇلار بىلەن بىللە قايتقان ئەركەكلەر ئاتمىش كىشى؛ \f ◼ \fr 8:13 \ft \bd «ئادونىكامنىڭ ئەۋلادلىرىدىن ئەڭ ئاخىرىدا قايتقانلار...»\bd* ــ ياكى «ئادونىكامنىڭ ئەۋلادلىرىدىن، يەنى ئەڭ ئاخىرىدا قايتقانلار...»\f*
\v 14 بىگۋاينىڭ ئەۋلادلىرىدىن ئۇتاي بىلەن زاببۇد ۋە ئۇلار بىلەن بىللە قايتقان ئەركەكلەر يەتمىش كىشى.
\b
\s1 لاۋىيلار بىلەن ئىبادەتخانا خىزمەتكارلىرى ــ يەنى «نەتانىيلار» ــ ئۇلارنىڭ چاقىرتىلىشى
\m 
\v 15 ــ مەن ئۇلارنى ئاخاۋاغا ئاقىدىغان دەريانىڭ بويىغا يىغدىم؛ بىز ئۇ يەردە چېدىر تىكىپ ئۈچ كۈن تۇردۇق. خەلقنى ۋە كاھىنلارنى ئارىلاپ قارىسام ئۇ يەردە لاۋىيلار يوق ئىكەن. \f ◼ \fr 8:15 \ft \bd «لاۋىيلار يوق ئىكەن»\bd* ــ كاھىنلار ئۆزلىرى لاۋىيلار، ئەلۋەتتە (پەقەت ھارۇننىڭ ئەۋلادلىرى كاھىن بولىدۇ)؛ مۇشۇ يەردە دېيىلىۋاتقىنى كاھىنلىقتىن باشقا روھىي خىزمەت قىلالايدىغان لاۋىيلارنى كۆرسىتىدۇ.\f*
\v 16 شۇڭا مەن باشلىقلاردىن ئەلىئېزەر، ئارىيەل، شېمايا، ئەلناتان، يارىب، ئەلناتان، ناتان، زەكەرىيا بىلەن مەشۇللاملارنى ۋە ئۇلارغا قوشۇپ ئوقۇمۇشلۇق ئالىملاردىن يوئارىب بىلەن ئەلناتاننى چاقىرتىپ كېلىپ،
\v 17 ئۇلارغا ھاۋالە قىلىپ كاسىفىيا دېگەن يەرگە، ئىددو دېگەن ئاتامان بىلەن كۆرۈشۈشكە ئەۋەتتىم. مەن كاسىفىيا دېگەن يەردە ئىددوغا ۋە ئۇنىڭ ئىبادەتخانا خىزمەتكارلىرى بولغان قېرىنداشلىرىغا دەيدىغان گەپلەرنى ئاغزىغا سېلىپ، ئۇلارنىڭ بۇ يەرگە خۇدايىمىزنىڭ ئۆيى ئۈچۈن خىزمەت قىلىدىغان خىزمەتچىلەرنى بىزگە ئەكېلىشنى ئۆتۈندۇم.
\v 18 خۇدايىمىزنىڭ شاپائەتلىك قولى بىزدە بولغاچقا، ئۇلار بىزگە ئىسرائىلنىڭ ئەۋرىسى، لاۋىينىڭ نەۋرىسى ماھلىنىڭ ئەۋلادلىرى ئىچىدىن ئوقۇمۇشلۇق بىر ئادەمنى، يەنى شەرەبىيانى ۋە ئۇنىڭ ئوغۇللىرى ھەم قېرىنداشلىرى بولۇپ جەمئىي ئون سەككىز كىشىنى باشلاپ كەلدى.
\v 19 ئۇلار يەنە ھاشابىيا ۋە ئۇنىڭ بىلەن بىللە مەرارىنىڭ ئەۋلادلىرىدىن يەشايا ھەم ئۇنىڭ قېرىنداشلىرى ھەم ئۇلارنىڭ ئوغۇللىرى بولۇپ، جەمئىي يىگىرمە كىشىنى،
\v 20 يەنە ئىلگىرى داۋۇت ۋە ئۇنىڭ ئەمىرلىرى لاۋىيلارنىڭ خىزمىتىدە بولۇشقا تەيىنلىگەن «نەتىنىيلار»دىن ئىككى يۈز يىگىرمە كىشىنى باشلاپ كەلدى، بۇلارنىڭ ھەممىسى ئىسىملىرى بىلەن تىزىملاندى. \f ◼ \fr 8:20 \ft \bd «نەتىنىيلار»\bd* ــ ئىبادەتخانا خىزمەتكارلىرى.\f*
\b
\s1 قايتىپ كېلىشكە تەييارلىنىش
\m 
\v 21 شۇ چاغدا ئاخاۋا دەرياسى بويىدا مەن خۇدايىمىزنىڭ ئالدىدا ئۆزۈمىزنى تۆۋەن قىلىپ، ئۆزىمىز ۋە كىچىك بالىلىرىمىز ھەم بارلىق مال-مۈلكىمىز ئۈچۈن خۇدايىمىزدىن ئاق يول تىلەشكە روزا تۇتايلى، دەپ جاكارلىدىم.
\v 22 چۈنكى بىز ئەسلىدە پادىشاھقا: «خۇدايىمىزنىڭ قولى ئۇنى بارلىق ئىزدىگەنلەرنىڭ ئۈستىگە ئىلتىپات كۆرسىتىشكە قويۇلىدۇ؛ لېكىن ئۇنىڭ قۇدرىتى بىلەن غەزىپى ئۆزىنى تاشلىغانلارغا زەربە بېرىشكە تەيياردۇر» دېگەنىدۇق، ئەمدى يەنە ئۇنىڭدىن يولدىكى دۈشمەنلەرگە تاقابىل تۇرۇشقا پىيادە ۋە ئاتلىق لەشكەرلەر تەيىنلەپ بېرىشنى تەلەپ قىلغانلىقىمدىن خىجىل بولۇپ قالدىم.
\v 23 شۇنىڭ بىلەن بىز روزا تۇتۇپ خۇدايىمىزدىن شۇ ئىش توغرۇلۇق ئۆتۈندۇق، ئۇ دۇئايىمىزنى ئىجابەت قىلدى.
\b
\s1 مۇقەددەس ئۆي ئۈچۈن ھەدىيە قىلىنغان سوۋغاتلار
\m 
\v 24 مەن كاھىن باشلىرى ئىچىدىن ئون ئىككى ئادەمنى ۋە شەرەبىيا، ھاشابىيا ۋە ئۇلار بىلەن بىللە بولغان ئاكا-ئۇكىلىرىدىن ئون ئادەمنى تاللاپ،
\v 25 ئۇلارغا ئالتۇن، كۈمۈش ۋە قاچا-قۇچىلارنى، يەنى پادىشاھ، ئۇنىڭ مەسلىھەتچىلىرى، ئەمىرلىرى ۋە شۇنىڭدەك شۇ يەردە تۇرۇۋاتقان بارلىق ئىسرائىللار «كۆيدۈرمە ھەدىيە» سۈپىتىدە خۇدايىمىزنىڭ ئۆيىگە ھەدىيە قىلغان سوۋغاتلارنى تاپشۇردۇم. \x ◘ \xo 8:25 \xt ئەزرا 7‏:14، 15\x*
\v 26 مەن كۈمۈشتىن ئالتە يۈز ئەللىك تالانت، يۈز تالانت ئېغىرلىقتىكى كۈمۈش قاچا-قۇچا، يۈز تالانت ئالتۇننى ئۇلارنىڭ قولىغا ئۆلچەپ تاپشۇردۇم. \f ◼ \fr 8:26 \ft \bd «كۈمۈشتىن ئالتە يۈز ئەللىك تالانت... يۈز تالانت ئالتۇن...»\bd* ــ شۇ دەۋردىكى ئىسرائىللار ئارىسىدا بىر «تالانت»نىڭ توپتوغرا قانچىلىك ئىكەنلىكى بىزگە ئېنىق ئەمەس؛ «كۈمۈشنىڭ تالانتى» بولسا بەلكىم 45 كىلوگرام، «ئالتۇننىڭ تالانتى» بەلكىم 90 كىلوگرام بولۇشى مۇمكىن؛ شۇڭا 650 تالانت كۈمۈش بەلكىم 29 توننىچە بولاتتى، 100 تالانت كۈمۈش 6.5 توننىچە، 100 تالانت ئالتۇن 9 توننىچە بولاتتى.\f*
\v 27 ئۇلارغا تاپشۇرغانلىرىمدىن يەنە ئالتۇن داس يىگىرمە بولۇپ، قىممىتى مىڭ دارىك، سۈپەتلىك ۋە ۋالىلداپ پارقىرايدىغان مىس چوڭ داس ئىككى بولۇپ، ئالتۇندەك قىممەتلىك ئىدى. \f ◼ \fr 8:27 \ft \bd «دارىك»\bd* ــ (ياكى «دراخما») ــ پارس ئىمپېريەسىدىكى بىرخىل ئالتۇن تەڭگە؛ مۇشۇ يەردە بۇ داسلارنىڭ قىممىتى 400-500 كىلوگرام ئالتۇنغا باراۋەر ئىدى.\f*
\v 28 مەن ئۇلارغا: ــ سىلەر پەرۋەردىگارغا مۇقەددەستۇرسىلەر، قاچا-قۇچىلارمۇ مۇقەددەستۇر، ئالتۇن-كۈمۈشلەر ئاتا-بوۋاڭلارنىڭ خۇداسى پەرۋەردىگارغا ئىختىيارىي ھەدىيە قىلىنغان سوۋغاتتۇر.
\v 29 تاكى يېرۇسالېمدىكى پەرۋەردىگارنىڭ ئۆيىدىكى ئامبار-خەزىنىلەرگە يەتكۈزۈپ، كاھىنلار ۋە لاۋىيلارنىڭ باشلىرى ۋە ئىسرائىللارنىڭ قەبىلە-جەمەت باشلىقلىرىنىڭ ئالدىدا تارازىدىن ئۆتكۈزگۈچە بۇلارنى ئوبدان قاراپ قوغداڭلار، دېدىم.
\v 30 شۇنىڭ بىلەن كاھىنلار بىلەن لاۋىيلار يېرۇسالېمدىكى خۇدايىمىزنىڭ ئۆيىگە ئاپىرىدىغان، تارازىدىن ئۆتكۈزۈلگەن شۇ ئالتۇن-كۈمۈش ۋە قاچا-قۇچىلارنى تاپشۇرۇۋالدى.
\b
\s1 يېرۇسالېمغا يېتىپ كېلىش
\m 
\v 31 شۇنىڭ بىلەن بىرىنچى ئاينىڭ ئون ئىككىنچى كۈنى بىز ئاخاۋا دەرياسىنىڭ بويىدىن قوزغىلىپ يېرۇسالېمغا چىقىشقا ماڭدۇق. خۇدايىمىزنىڭ قولى ئۈستىمىزدە بولغاچقا، ئۇ بىزنى دۈشمەنلىرىمىزدىن ۋە يولدا پايلاپ تۇرغان قاراقچىلاردىنمۇ قۇتقۇزدى.
\v 32 بىز يېرۇسالېمغا كېلىپ ئۇ يەردە ئۈچ كۈن تۇردۇق؛
\v 33 تۆتىنچى كۈنى خۇدايىمىزنىڭ ئۆيىدە ئالتۇن-كۈمۈش ۋە قاچا-قۇچىلار تارازىدا ئۆلچىنىپ كاھىن ئۇرىيانىڭ ئوغلى مەرەموتنىڭ قولىغا تاپشۇرۇلدى؛ ئۇنىڭ يېنىدا فىنىھاسنىڭ ئوغلى ئەلىئازار، يەنە لاۋىيلاردىن يەشۇئانىڭ ئوغلى يوزاباد بىلەن بىننۇئىينىڭ ئوغلى نوئادىياھلار بار ئىدى.
\v 34 ھەممە نەرسە سانى بويىچە ۋە ئېغىرلىقى بويىچە ئۆلچەندى ۋە شۇنىڭ بىلەن بىللە ھەربىرىنىڭ ئېغىرلىقى پۈتۈپ قويۇلدى.
\m 
\v 35 شۇ چاغدا ئەسلى ئېلىپ كېتىلگەنلەرنىڭ ئەۋلادلىرى، يەنى سۈرگۈنلۈكتىن قايتقانلار ئىسرائىللارنىڭ خۇداسىغا «كۆيدۈرمە قۇربانلىق» سۈپىتىدە پۈتكۈل ئىسرائىل ئۈچۈن ئون ئىككى تورپاق، توقسان ئالتە قوچقار، يەتمىش يەتتە قوزا سۇندى، يەنە گۇناھ قۇربانلىقى سۈپىتىدە ئون ئىككى تېكە سۇندى؛ بۇلارنىڭ ھەممىسى پەرۋەردىگارغا ئاتالغان كۆيدۈرمە قۇربانلىق ئىدى.
\v 36 ئۇلار پادىشاھنىڭ يارلىق خەتلىرىنى پادىشاھنىڭ ۋالىيلىرىغا ۋە دەريانىڭ بۇ غەرب تەرىپىدىكى ھۆكۈمدارلارغا تاپشۇرۇۋىدى، ئۇلار خەلققە ۋە خۇدانىڭ ئۆيىنىڭ ئىشلىرىغا ئىزچىل ياردەم بەردى.
\b
\b
\c 9
\s1 خەلقنىڭ يات ئەللەرگە ئەگىشىپ ساداقەتسىزلىق قىلىشى ــ ئەزرانىڭ ئىسرائىلنىڭ گۇناھلىرىنى تونۇپ دۇئا قىلىشى
\m 
\v 1 بۇ ئىشلار پۈتكەندىن كېيىن ئەمىرلەر مېنىڭ بىلەن كۆرۈشكىلى يېنىمغا كېلىپ: ــ ئىسرائىللار، كاھىنلار ۋە لاۋىيلار ئۆزلىرىنى مۇشۇ زېمىنلاردىكى تائىپىلەردىن، يەنى ئۇلارنىڭ يىرگىنچلىك ئادەتلىرىدىن ئايرىپ تۇرمىدى، ــ دېمەك، ئۇلار قانائانىيلار، ھىتتىيلار، پەرىززىيلەر، يەبۇسىيلار، ئاممونىيلار، موئابىيلار، مىسىرلىقلار ۋە ئامورىيلارغا ئەگىشىپ ماڭدى.
\v 2 چۈنكى ئۇلار بۇ يات تائىپىلەردىن ئۆزلىرىگە ۋە ئوغۇللىرىغا خوتۇن ئېلىپ بېرىپ، \add خۇداغا\add* خاس مۇقەددەس نەسىلنى مۇشۇ زېمىنلاردىكى تائىپىلەر بىلەن ئارىلاشتۇرۇۋەتتى؛ ئۇنىڭ ئۈستىگە، ئەمىرلەر بىلەن ئەمەلدارلار بۇ ساداقەتسىزلىكنىڭ باشلامچىلىرىدۇر، ــ دېيىشتى.
\m 
\v 3 مەن بۇ ئىشنى ئاڭلاپلا كۆڭلەك بىلەن تونۇمنى يىرتىپ، چاچ-ساقاللىرىمنى يۇلۇپ غەم-قايغۇغا چۈشۈپ ئولتۇرۇپ كەتتىم.
\v 4 ۋە ئىسرائىلنىڭ خۇداسىنىڭ سۆزلىرىدىن قورقۇپ تىترىگەنلەرنىڭ ھەربىرى سۈرگۈنلۈكتىن قايتىپ كەلگەنلەرنىڭ ساداقەتسىزلىكى تۈپەيلىدىن يېنىمغا كەلدى. مەن تاكى كەچلىك قۇربانلىق سۇنۇلغۇچە غەم-قايغۇغا چۆمۈپ ئولتۇردۇم.
\m 
\v 5 كەچلىك قۇربانلىق ۋاقتىدا مەن ئۆزۈمنى تۆۋەن قىلغان ھالەتتىن تۇرۇپ، كۆڭلەك ۋە تونۇم يىرتىق ھالدا خۇدايىم پەرۋەردىگارغا يۈزلىنىپ تىزلىنىپ ئولتۇرۇپ، قوللىرىمنى يېيىپ،
\v 6 دۇئا قىلىپ: ــ «ئاھ خۇدايىم، شەرمەندىلىكتە يۈزۈمنى ساڭا قارىتىشتىن ئىزا تارتماقتىمەن، ئى خۇدايىم؛ چۈنكى قەبىھلىكلىرىمىز تولىلىقىدىن باشلىرىمىزدىن ئاشتى، ئاسىيلىق-ئىتائەتسىزلىكىمىز ئاسمانلارغا تاقاشتى. \x ◘ \xo 9:6 \xt زەب. 38‏:4\x*
\v 7 ئاتا-بوۋىلىرىمىزنىڭ كۈنلىرىدىن تارتىپ بۈگۈنگە قەدەر زور ئىتائەتسىزلىكتە يۈرۈپ كەلدۇق، شۇڭا قەبىھلىكلىرىمىز تۈپەيلىدىن بىز، بىزنىڭ پادىشاھلىرىمىز ۋە كاھىنلىرىمىز خۇددى بۈگۈنكى كۈندىكىدەك ھەرقايسى يۇرتلاردىكى پادىشاھلارنىڭ قولىغا چۈشۈپ، قىلىچقا، سۈرگۈنلۈككە، بۇلاڭ-تالاڭغا، نومۇسقا تاپشۇرۇلدۇق. \f ◼ \fr 9:7 \ft \bd «نومۇسقا تاپشۇرۇلدۇق»\bd* ــ ئىبرانىي تىلىدا «يۈزى چۈشكەنلىكىگە تاپشۇرۇلدۇق».\f*
\m 
\v 8 ئەمدى ھازىر ئازغىنە ۋاقىت خۇدايىمىز كۆزلىرىمىزنى نۇرلاندۇرۇپ، قۇللۇقىمىزدا بىزگە ئازغىنا ئارام بېرىلسۇن دەپ، قېچىپ قۇتۇلغان بىر قالدىنى ساقلاپ قېلىپ، بىزگە ئۆزىنىڭ مۇقەددەس جايىدىن خۇددى قاققان قوزۇقتەك مۇقىم ئورۇن بېرىپ، بىزگە خۇدايىمىز پەرۋەردىگاردىن ئىلتىپات كۆرسىتىلدى. \f ◼ \fr 9:8 \ft \bd «بىزگە ئۆزىنىڭ مۇقەددەس جايىدىن خۇددى قاققان قوزۇقتەك مۇقىم ئورۇن بېرىپ،...»\bd* ــ «يەش.» 20:22-24نى كۆرۈڭ.\f*
\v 9 چۈنكى بىز ھازىر قۇللارمىز؛ ھالبۇكى، خۇدايىمىز مۇشۇ قۇللۇقىمىزدا يەنىلا بىزنى تاشلىۋەتمەي، بەلكى پارس پادىشاھلىرىنىڭ ئالدىدا رەھىمگە ئېرىشتۈرۈپ، خۇدايىمىزنىڭ ئۆيىنى سېلىپ، خارابىلەشكەن جايلىرىنى يېڭىۋاشتىن ئوڭلاشقا بىزنى روھلاندۇردى، شۇنداقلا بىزنى يەھۇدىيە ۋە يېرۇسالېمدا سېپىللىق قىلدى. \f ◼ \fr 9:9 \ft \bd «...بىزنى يەھۇدىيە ۋە يېرۇسالېمدا سېپىللىق قىلدى»\bd* ــ «سېپىللىق» مۇشۇ يەردە ئاساسەن كۆچمە مەنىدە ئىشلىتىلگەن بولسا كېرەك. چۈنكى يېرۇسالېمدىكى سېپىل مۇشۇ ۋاقىتتا تېخى قۇرۇلمىغانىدى («نەھ.» 1-بابنى كۆرۈڭ).\f*
\v 10‏-11 ئى خۇدا، بىز بۇ \add ئىلتىپاتلار\add* ئالدىدا يەنە نېمە دېيەلەيمىز؟ چۈنكى بىز يەنىلا سېنىڭ مۆمىن بەندىلىرىڭ بولغان پەيغەمبەرلەر ئارقىلىق تاپىلغان ئەمرلىرىڭنى تاشلىۋەتتۇق؛ سەن \add ئۇلار ئارقىلىق\add*: «سىلەر كىرىپ مىراس قىلىپ ئىگىلەيدىغان زېمىن بولسا، شۇ زېمىندىكى تائىپىلەرنىڭ نىجىسلىقى بىلەن بۇلغانغان بىر زېمىن؛ چۈنكى ئۇلار تۈرلۈك ناپاكلىقلارنى قىلىپ، يىرگىنچلىك ئادەتلىرى بىلەن بۇ زېمىننى بۇ چەتتىن ئۇ چېتىغىچە تولدۇرۇۋەتتى. \x ◘ \xo 9:10‏-11 \xt لاۋ. 18‏:25، 27؛ قان. 7‏:3\x*
\v 12 شۇڭا سىلەر قىزلىرىڭلارنى ئۇلارنىڭ ئوغۇللىرىغا بەرمەڭلار، ئوغۇللىرىڭلارغا ئۇلارنىڭ قىزلىرىنى ئېلىپ بەرمەڭلار؛ سىلەر كۈچىيىپ، زېمىننىڭ نازۇ-نېمەتلىرىدىن يېيىشكە، زېمىننى ئەبەدىلئەبەد ئەۋلادلىرىڭلارغا مىراس قىلىپ قالدۇرۇش ئۈچۈن مەڭگۈ ئۇلارنىڭ ئامان-تىنچلىقى ياكى مەنپەئىتىنى ھەرگىز ئىزدىمەڭلار» ــ دېگەنىدىڭ.
\v 13 بىزنىڭ رەزىل قىلمىشلىرىمىز ۋە ناھايىتى ئېغىر ئىتائەتسىزلىكىمىز تۈپەيلىدىن بۇ ھەممە بالا-قازا بېشىمىزغا كەلگەنىدى ۋە سەن، ئى خۇدايىمىز، قەبىھلىكلىرىمىزگە تېگىشلىك بولغان جازايىمىزنى يېنىكلىتىپ، بىزگە بۈگۈنكىدەك نىجاتلىق ئىلتىپاتنى كۆرسەتكەن تۇرۇقلۇق، \f ◼ \fr 9:13 \ft \bd «بىزگە بۈگۈنكىدەك نىجات ئىلتىپاتىنى كۆرسەتكەن»\bd* ــ بۇ ئىبارىنىڭ باشقا بىرخىل تەرجىمىسى: «بىزگە بۈگۈنكىدەك قۇتۇلدۇرۇلغان قالدى قالدۇرغان».\f*
\v 14 بىز قانداقمۇ يەنە ئەمرلىرىڭگە خىلاپلىق قىلىپ، بۇنداق يىرگىنچلىك قائىدىلەرنى تۇتقان بۇ تائىپىلەر بىلەن نىكاھلىنىۋېرىمىز؟ مۇبادا شۇنداق قىلىدىغان بولساق، سەن بىزگە غەزەپلىنىپ، بىزگە بىر قالدى ياكى قۇتۇلغۇدەك بىرسىنىمۇ قالدۇرماي يوقاتماي قالامسەن؟
\v 15 ئى ئىسرائىلنىڭ خۇداسى بولغان پەرۋەردىگار، سەن ھەققانىيدۇرسەن! شۇ سەۋەبتىن بىز بۈگۈنكىدەك قۇتۇلۇپ قالغان بىر قالدىمىز. قارا، بىز سېنىڭ ئالدىڭدا ئىتائەتسىزلىكلىرىمىزدە تۇرۇۋاتىمىز، شۇڭا سېنىڭ ئالدىڭدا ھېچقايسىمىز تىك تۇرالماي قالدۇق» ــ دېدىم.
\b
\b
\c 10
\s1 گۇناھىنى تونۇپ، قىلغان دۇئانىڭ نەتىجىسى
\m 
\v 1 ئەزرا دۇئا قىلىپ، گۇناھىنى تونۇپ يىغلاپ خۇدانىڭ ئۆيى ئالدىدا يىقىلىپ دۈم ياتقان چاغدا، ئىسرائىللاردىن ناھايىتى چوڭ بىر جامائەت، ئەر-ئاياللار ۋە بالىلار ئۇنىڭ يېنىغا كېلىپ يىغىلدى؛ كۆپچىلىكمۇ قاتتىق يىغلاپ كېتىشتى.
\v 2 ئېلامنىڭ ئەۋلادلىرىدىن، يەھىيەلنىڭ ئوغلى شېكانىيا ئەزراغا: ــ بىز خۇدايىمىزغا ساداقەتسىزلىك قىلىپ بۇ زېمىندىكى يات تائىپىلەردىن خوتۇن ئاپتۇق. ھالبۇكى، ئىسرائىل ئۈچۈن يەنىلا ئۈمىد بار؛
\v 3 بىز ئەمدى خۇدايىمىز بىلەن ئەھدىلىشەيلى، خوجامنىڭ ۋە خۇدايىمىزنىڭ ئەمرلىرىدىن قورقۇپ تىترىگەنلەرنىڭ نەسىھىتىگە ئاساسەن بۇ خوتۇنلارنى ۋە ئۇلاردىن تۆرەلگەن پەرزەنتلەرنى يولغا سېلىپ قويايلى. ھەممە ئىش تەۋرات قانۇنى بويىچە قىلىنسۇن.
\v 4 تۇر! بۇ ئىش ساڭا باغلىقتۇر، بىز سېنى قوللايمىز؛ جۈرئەتلىك بولۇپ ئىشنى ئادا قىلغىن، ــ دېدى.
\m 
\v 5 شۇنىڭ بىلەن ئەزرا ئورنىدىن قوپۇپ، كاھىنلارنىڭ لاۋىيلارنىڭ ۋە پۈتكۈل ئىسرائىل جامائىتىنىڭ باشلىقلىرىنى شۇ سۆز بويىچە ئىش قىلىمىز، دەپ قەسەم ئىچىشكە ئۈندىدى، ئۇلار قەسەم ئىچتى.
\m 
\v 6 ئاندىن ئەزرا خۇدانىڭ ئۆيى ئالدىدىن قوپۇپ ئەلىياشىبنىڭ ئوغلى يەھوھاناننىڭ ئۆيىگە كىردى؛ ئۇ ئۇ يەرگە كەلگەندە غىزامۇ يېمىدى، سۇمۇ ئىچمىدى، چۈنكى ئۇ سۈرگۈنلۈكتىن قايتىپ كەلگەنلەرنىڭ ساداقەتسىزلىكى ئۈچۈن ئېچىناتتى.
\v 7 شۇنىڭ بىلەن يەھۇدىيە ۋە يېرۇسالېمدا سۈرگۈنلۈكتىن قايتىپ كەلگەنلەرنىڭ ھەممىسىگە جاكارلىنىپ، يېرۇسالېمغا يىغىلىڭلار،
\v 8 ئەمىرلەر ۋە ئاقساقاللارنىڭ نەسىھىتى بويىچە، كىمكى ئۈچ كۈن ئىچىدە يېتىپ كەلمىسە، ئۇنىڭ پۈتۈن مال-مۈلكى مۇسادىرە قىلىنىدۇ، سۈرگۈندىن قايتىپ كەلگەنلەرنىڭ جامائىتىدىنمۇ ئايرىلىدۇ، دەپ، جاكارنامە چىقىرىلدى. \f ◼ \fr 10:8 \ft \bd «ئۇنىڭ پۈتۈن مال-مۈلكى مۇسادىرە قىلىنىدۇ»\bd* ــ مۇشۇ يەردە «مۇسادىرە قىلىنىش» دېگەننىڭ مەنىسى «مۇتلەك خۇداغا ئاتىلىشى كېررەك» («لاۋ.» 28:27).\f*  \x ◘ \xo 10:8 \xt لاۋ. 28:27\x*
\v 9 شۇنىڭ بىلەن يەھۇدا ۋە بىنيامىندىكى بارلىق ئەرلەر ئۈچ كۈنگىچە يېرۇسالېمغا يىغىلىپ بولدى. ئۇ توققۇزىنچى ئاينىڭ يىگىرمىنچى كۈنى ئىدى؛ بارلىق خەلق خۇدانىڭ ئۆيىنىڭ ھويلىسىدىكى مەيدانغا كېلىپ ئولتۇردى، كۆپچىلىك بۇ ئىشتىن قورقاچقا، شۇنىڭدەك قاتتىق ياغقان يامغۇر تۈپەيلىدىن، تىترەپ كېتىشتى.
\v 10 كاھىن ئەزرا ئورنىدىن قوپۇپ ئۇلارغا: ــ سىلەر خۇداغا ساداقەتسىزلىك قىلىپ يات تائىپىلەرنىڭ قىزلىرىنى خوتۇنلۇققا ئېلىپ ئىسرائىللارنىڭ ئىتائەتسىزلىكىنى ئاشۇردۇڭلار.
\v 11 ئەمدى سىلەر ئاتا-بوۋاڭلارنىڭ خۇداسى بولغان پەرۋەردىگار ئالدىدا گۇناھىڭلارنى تونۇپ، ئۇنىڭ نەزىرىدە دۇرۇس بولغاننى قىلىپ، ئۆزۈڭلارنى بۇ زېمىندىكى تائىپىلەردىن ۋە بۇ يات ئەللىك خوتۇنلىرىڭلاردىن ئارىنى ئوچۇق قىلىڭلار، دېدى.
\m 
\v 12 پۈتۈن جامائەت يۇقىرى ئاۋازدا جاۋاپ بېرىپ: ــ ماقۇل، بىز ئۆزلىرىنىڭ شۇ گەپلىرى بويىچە ئىش كۆرىمىز.
\v 13 بىراق ئادەملەر بەك كۆپ، يەنە كېلىپ يامغۇر پەسلى بولغاچقا تالادا تۇرالمايمىز؛ ئۇنىڭ ئۈستىگە بۇ دېگەن بىر-ئىككى كۈندە پۈتىدىغان ئىش ئەمەس، چۈنكى بىزدە بۇ ئىشتا ئىتائەتسىزلىك قىلغانلار ناھايىتى كۆپتۇر! \f ◼ \fr 10:13 \ft \bd «چۈنكى بىزدە بۇ ئىشتا ئىتائەتسىزلىك قىلغانلار ناھايىتى كۆپتۇر!»\bd* ــ باشقا بىر خىل تەرجىمىسى: «چۈنكى بىز بۇ ئىشتا بەك ئېغىر ئىتائەتسىزلىك قىلغانمىز».\f*
\v 14 خۇدانىڭ مۇشۇ ئىش تۈپەيلى كەلگەن قاتتىق غەزىپىنىڭ بىزدىن كەتكۈچە، باشلىقلىرىمىز پۈتكۈل جامائەتكە ۋەكىل بولۇپ پەرۋەردىگارنىڭ ئالدىدا تۇرسۇن؛ بىزنىڭ ھەرقايسى شەھەرلىرىمىزدە يات ئەللەردىن خوتۇن ئالغانلارمۇ بەلگىلەنگەن ۋاقىتتا شۇ شەھەرنىڭ ئاقساقال ۋە ھاكىملىرى بىلەن بىرلىكتە كېلىپ بۇ ئىشنى بىر تەرەپ قىلسۇن، ــ دېدى.
\m 
\v 15 بۇ ئىشقا پەقەت ئاساھەلنىڭ ئوغلى يوناتان بىلەن تىقۋاھنىڭ ئوغلى ياھزىيا قارشى چىقتى، مەشۇللام بىلەن لاۋىي شاببىتاي ئۇلارنى قوللىدى.
\v 16 شۇنىڭ بىلەن سۈرگۈندىن قايتىپ كەلگەنلەر ئەنە شۇنداق قىلدى. كاھىن ئەزرا ۋە ئاتا جەمەتلىرىنىڭ باشلىقلىرى بولغانلار جەمەتى بويىچە بۇ ئىشقا ئايرىلدى؛ ئۇلارنىڭ ھەممىسى ئىسمىلىرى بويىچە تىزىملاندى. ئۇلار ئونىنچى ئاينىڭ بىرىنچى كۈنى بۇ ئىشنى تەكشۈرۈپ بىر تەرەپ قىلىشقا كىرىشتى.
\v 17 ئۇلار يات ئەللىك خوتۇنلارنى ئالغان ئەرلەرنىڭ سورىقىنى بىرىنچى ئاينىڭ بىرىنچى كۈنى تۈگەتتى.
\b
\s1 يات ئەللەردىن خوتۇن ئالغانلارنىڭ تىزىملىكى
\m 
\v 18 كاھىنلارنىڭ ئەۋلادلىرى ئىچىدە يات ئەللىك خوتۇنلارنى ئالغانلاردىن مۇشۇلار چىقتى: ــ يوزاداكنىڭ ئوغلى يەشۇئانىڭ ۋە ئۇنىڭ قېرىنداشلىرىنىڭ ئەۋلادلىرىدىن: ــ مائاسېياھ، ئەلىئېزەر، يارىب، گەدالىيا.
\v 19 ئۇلار خوتۇنلىرىمىزنى يولغا سېلىپ قويىمىز دەپ \add قەسەم قىلىپ\add* قول بېرىشتى ۋە گۇناھى ئۈچۈن ئىتائەتسىزلىك قۇربانلىقى سۈپىتىدە قوي پادىسىدىن بىر قوچقارنى سۇندى.
\v 20 ئىممەرنىڭ ئەۋلادلىرىدىن ھانانى بىلەن زەبادىيا؛
\v 21 ھارىمنىڭ ئەۋلادلىرى ئىچىدە مائاسېياھ، ئېلىياھ، شېمايا، يەھىيەل ۋە ئۇززىيا؛ \f ◼ \fr 10:21 \ft \bd «ئېلىياھ»\bd* ــ بۇ ئىسىم ئەرەب تىلىدا، شۇنداقلا ئۇيغۇر تىلىدا «ئىلىياس» دېيىلىدۇ.\f*
\v 22 پاشخۇرنىڭ ئەۋلادلىرىدىن ئەليويىناي، مائاسېياھ، ئىسمائىل، نەتانەل، يوزاباد ۋە ئەلاساھ.
\m 
\v 23 لاۋىيلار ئىچىدە يوزاباد، شىمەي، كېلايا («كېلىتا»مۇ دېيىلىدۇ)، پىتاھىيا، يەھۇدا بىلەن ئەلىئېزەر؛
\v 24 غەزەلكەشلەر ئىچىدە ئەلىياشىب؛ دەرۋازىۋەنلەر ئىچىدە شاللۇم، تەلەم، ئۇرى.
\m 
\v 25 ئىسرائىللاردىن: ــ پاروشنىڭ ئەۋلادلىرىدىن رامىيا، يىززىيا، مالكىيا، مىيامىن، ئەلىئازار، مالكىيا، بىنايا؛
\v 26 ئېلامنىڭ ئەۋلادلىرىدىن ماتتانىيا، زەكەرىيا، يەھىيەل، ئابدى، يەرىموت بىلەن ئېلىياھ؛
\v 27 زاتتۇنىڭ ئەۋلادلىرىدىن ئەليويىناي، ئەلىياشىب، ماتتانىيا، يەرىموت، زاباد بىلەن ئازىزا؛
\v 28 بىباينىڭ ئەۋلادلىرىدىن يەھوھانان، ھانانىيا، زابباي بىلەن ئاتلاي؛
\v 29 بانىنىڭ ئەۋلادلىرىدىن مەشۇللام، ماللۇق، ئادايا، ياشۇب، شېئال بىلەن راموت؛ \f ◼ \fr 10:29 \ft \bd «راموت»\bd* ــ ياكى «يەرەموت».\f*
\v 30 پاھات-موئابنىڭ ئەۋلادلىرىدىن ئادنا، جىلال، بىنايا، مائاسېياھ، ماتتانىيا، بەزالەل، بىننۇئىي بىلەن ماناسسەھ؛
\v 31 ھارىمنىڭ ئەۋلادلىرىدىن ئەلىئېزەر، يىسشىيا، مالكىيا، شېمايا، شىمېئون،
\v 32 بىنيامىن، ماللۇق ۋە شەمارىيا؛
\v 33 خاشۇمنىڭ ئەۋلادلىرىدىن ماتتىناي، ماتتاتاھ، زاباد، ئەلىفەلەت، يەرەماي، ماناسسەھ ۋە شىمەي؛
\v 34 بانىنىڭ ئەۋلادلىرىدىن ماداي، ئامرام، ئۇئەل،
\v 35 بىنايا، بەدىيا، كېلۇھاي،
\v 36 ۋانىيا، مەرەموت، ئەلىياشىب،
\v 37 ماتتانىياھ، ماتتىناي، يائاسۇ،
\v 38 بانى، بىننۇئىي، شىمەي،
\v 39 شەلەمىيا، ناتان، ئادايا،
\v 40 ماكنادىباي، شاشاي، شاراي،
\v 41 ئازارەل، شەلەمىيا، شەمارىيا،
\v 42 شاللۇم، ئامارىيا، يۈسۈپ؛
\v 43 نېبونىڭ ئەۋلادلىرىدىن يەئىيەل، ماتتىتىياھ، زاباد، زېبىنا، يادداي، يوئېل ۋە بىنايا.
\v 44 بۇلارنىڭ ھەممىسى يات ئەللىك خوتۇنلارنى ئالغانلار ئىدى، ۋە شۇنىڭدەك ئۇلاردىن بەزىلەرنىڭ خوتۇنلىرى پەرزەنتمۇ كۆرگەنىدى. \f ◼ \fr 10:44 \ft \bd «ۋە شۇنىڭدەك ئۇلاردىن بەزىلەرنىڭ خوتۇنلىرى پەرزەنتمۇ كۆرگەنىدى»\bd* ــ باشقا بىر خىل تەرجىمىسى: ــ «... ۋە شۇنىڭ بىلەن ئۇلار خوتۇنلىرىنى ۋە پەرزەنتلىرىنى يولغا سېلىۋەتتى». بۇ ئايەتنىڭ تېكىستتە كەمتۈكلۈك بولۇشى مۇمكىن. شۇڭا مەنىسى ئېنىق ئەمەس.\f*  \fig تەۋرات دەۋرىنىڭ تارىخىنى كۆرسىتىدىغان خەرىتە|src="geographicalsummaryot-uara-01.jpg" size="span" ref="«ئ‍ەزرا» 10"\fig* 
