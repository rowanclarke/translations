\c 2
\s1 El juicio justo de Dios
\p 
\v 1 \w Por|strong="G1722"\w* \w esta|strong="G3588"\w* razón \w eres|strong="G1510"\w* inexcusable, \w tú|strong="G3588"\w* \w que|strong="G3588"\w* \w juzgas|strong="G2919"\w*, \w pues|strong="G1063"\w* \w cuando|strong="G1722"\w* \w juzgas|strong="G2919"\w* \w a|strong="G1722"\w* \w otro|strong="G2087"\w* \w te|strong="G4572"\w* condenas \w a|strong="G1722"\w* \w ti|strong="G4572"\w* mismo, \w porque|strong="G1063"\w* \w lo|strong="G3588"\w* mismo \w haces|strong="G4238"\w* \w tú|strong="G3588"\w* \w que|strong="G3588"\w* \w juzgas|strong="G2919"\w*.
