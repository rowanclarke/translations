\v 23 \w Instead|strong="H5922"\w*, \w you|strong="H1768"\w* \w have|strong="H1768"\w* \w exalted|strong="H7313"\w* \w yourself|strong="H7313"\w* \w against|strong="H5922"\w* \w the|strong="H3606"\w* \w Lord|strong="H4756"\w* \w of|strong="H1005"\w* \w heaven|strong="H8065"\w*. \w You|strong="H1768"\w* brought \w before|strong="H6925"\w* \w you|strong="H1768"\w* \w the|strong="H3606"\w* \w vessels|strong="H3984"\w* \w from|strong="H1768"\w* \w his|strong="H5922"\w* \w temple|strong="H1005"\w*, \w and|strong="H6523"\w* \w you|strong="H1768"\w* \w and|strong="H6523"\w* \w your|strong="H5922"\w* \w nobles|strong="H7261"\w*, together \w with|strong="H5922"\w* \w your|strong="H5922"\w* \w wives|strong="H7695"\w* \w and|strong="H6523"\w* \w concubines|strong="H3904"\w*, \w drank|strong="H8355"\w* \w wine|strong="H2562"\w* \w from|strong="H1768"\w* \w them|strong="H5922"\w*. \w You|strong="H1768"\w* \w praised|strong="H7624"\w* \w the|strong="H3606"\w* gods \w of|strong="H1005"\w* \w silver|strong="H3702"\w*, \w gold|strong="H1722"\w*, \w bronze|strong="H5174"\w*, \w iron|strong="H6523"\w*, wood, \w and|strong="H6523"\w* stone – gods \w that|strong="H1768"\w* \w cannot|strong="H3809"\w* \w see|strong="H2370"\w* \w or|strong="H3809"\w* \w hear|strong="H8086"\w* \w or|strong="H3809"\w* \w comprehend|strong="H3046"\w*! \w But|strong="H1768"\w* \w you|strong="H1768"\w* \w have|strong="H1768"\w* \w not|strong="H3809"\w* \w glorified|strong="H1922"\w* \w the|strong="H3606"\w* God \w who|strong="H1768"\w* \w has|strong="H1768"\w* \w in|strong="H5922"\w* \w his|strong="H5922"\w* control \w your|strong="H5922"\w* very \w breath|strong="H5396"\w* \w and|strong="H6523"\w* \w all|strong="H3606"\w* \w your|strong="H5922"\w* ways!
\v 24 \w Therefore|strong="H4481"\w* \w the|strong="H4481"\w* palm \w of|strong="H4481"\w* \w a|strong="H3068"\w* \w hand|strong="H3028"\w* \w was|strong="H3792"\w* \w sent|strong="H7972"\w* \w from|strong="H4481"\w* \w him|strong="H4481"\w*, \w and|strong="H3792"\w* \w this|strong="H1836"\w* \w writing|strong="H3792"\w* \w was|strong="H3792"\w* inscribed.
