\p 
\v 25 \w David|strong="H1732"\w* dijo al \w mensajero|strong="H4397"\w*: Dirás \w esto|strong="H2088"\w* \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*: \w Que|strong="H3588"\w* \w esto|strong="H2088"\w* \w no|strong="H3588"\w* \w te|strong="H5869"\w* desagrade, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w* devora tanto \w a|strong="H3068"\w* uno \w como|strong="H3588"\w* \w a|strong="H3068"\w* \w otro|strong="H2088"\w*. Refuerza tu ataque contra \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w* \w y|strong="H3588"\w* destrúyela. \w Y|strong="H3068"\w* tú, aliéntalo.
\p 
\v 26 \w Al|strong="H5921"\w* \w oír|strong="H8085"\w* \w la|strong="H5921"\w* esposa \w de|strong="H5921"\w* Urías \w que|strong="H3588"\w* \w su|strong="H3588"\w* esposo \w murió|strong="H4191"\w*, hizo duelo \w por|strong="H5921"\w* \w su|strong="H3588"\w* esposo.
\v 27 \w Cuando|strong="H1961"\w* \w pasó|strong="H5674"\w* \w el|strong="H1121"\w* luto, \w David|strong="H1732"\w* \w mandó|strong="H7971"\w* traerla \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*. Ella \w fue|strong="H1961"\w* su esposa y \w le|strong="H5869"\w* dio un \w hijo|strong="H1121"\w*. Pero \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w David|strong="H1732"\w* \w hizo|strong="H6213"\w* \w fue|strong="H1961"\w* desagradable \w delante|strong="H5869"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\c 12
\s1 Profecía contra David
\p 
\v 1 \nd \w Yavé|strong="H3068"\w*\nd* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Natán \w a|strong="H3068"\w* hablar con \w David|strong="H1732"\w*. Al llegar \w a|strong="H3068"\w* él le dijo: En una \w ciudad|strong="H5892"\w* \w había|strong="H1961"\w* \w dos|strong="H8147"\w* \w hombres|strong="H8147"\w*, uno \w rico|strong="H6223"\w* y uno \w pobre|strong="H7326"\w*.
\v 2 El \w rico|strong="H6223"\w* \w tenía|strong="H1961"\w* numerosos rebaños \w y|strong="H1241"\w* manadas vacunas,
\v 3 \w pero|strong="H3588"\w* \w el|strong="H5973"\w* \w pobre|strong="H7326"\w* \w no|strong="H3588"\w* \w tenía|strong="H1961"\w* \w sino|strong="H3588"\w* una corderita \w que|strong="H3588"\w* \w compró|strong="H7069"\w* \w y|strong="H3588"\w* crió. \w Ella|strong="H3605"\w* \w creció|strong="H1431"\w* \w juntamente|strong="H3162"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w y|strong="H3588"\w* \w con|strong="H5973"\w* sus \w hijos|strong="H1121"\w*. Comía \w de|strong="H3588"\w* \w su|strong="H3588"\w* pan, bebía \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w vaso|strong="H3563"\w*, dormía \w en|strong="H5973"\w* \w su|strong="H3588"\w* \w regazo|strong="H2436"\w* \w y|strong="H3588"\w* \w era|strong="H1961"\w* \w como|strong="H3588"\w* una \w hija|strong="H1323"\w* \w para|strong="H3588"\w* \w él|strong="H5973"\w*.
\p 
\v 4 Pero un viajero llegó al hombre \w rico|strong="H6223"\w*, \w y|strong="H1241"\w* éste \w no|strong="H6213"\w* quiso \w tomar|strong="H3947"\w* de sus \w ovejas|strong="H6629"\w* ni de sus manadas vacunas para guisarlas para \w el|strong="H6213"\w* viajero que le llegó. Más \w bien|strong="H2550"\w* \w tomó|strong="H3947"\w* la corderita de \w aquel|strong="H6213"\w* hombre \w pobre|strong="H7326"\w* \w y|strong="H1241"\w* la guisó para \w el|strong="H6213"\w* hombre que llegó \w a|strong="H3068"\w* \w él|strong="H6213"\w*.
\p 
\v 5 \w Entonces|strong="H3588"\w* \w el|strong="H3588"\w* furor \w de|strong="H3588"\w* \w David|strong="H1732"\w* se encendió muchísimo contra \w aquel|strong="H6213"\w* \w hombre|strong="H1121"\w* \w y|strong="H3588"\w* dijo \w a|strong="H3068"\w* Natán: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w que|strong="H3588"\w* \w el|strong="H3588"\w* \w hombre|strong="H1121"\w* \w que|strong="H3588"\w* \w hizo|strong="H6213"\w* \w tal|strong="H2063"\w* \w cosa|strong="H2063"\w* \w es|strong="H3588"\w* digno \w de|strong="H3588"\w* \w muerte|strong="H4194"\w*!
\v 6 Debe \w pagar|strong="H7999"\w* cuatro veces \w el|strong="H5921"\w* valor \w de|strong="H5921"\w* \w la|strong="H5921"\w* corderita, \w porque|strong="H5921"\w* \w hizo|strong="H6213"\w* \w tal|strong="H2088"\w* \w cosa|strong="H1697"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w tuvo|strong="H6213"\w* compasión.
\p 
\v 7 Entonces Natán dijo \w a|strong="H3068"\w* \w David|strong="H1732"\w*: ¡Tú eres ese hombre! \nd \w Yavé|strong="H3068"\w* ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* dice: \wj Yo \w te|strong="H5921"\w* \w ungí|strong="H4886"\w* \w como|strong="H5921"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w te|strong="H5921"\w* protegí \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w*.\wj*
\v 8 \wj Te \w entregué|strong="H5414"\w* la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* tu \tl ʼadón\tl*, y coloqué en tu \w seno|strong="H2436"\w* las mujeres \w de|strong="H5414"\w* tu \tl ʼadón\tl*. Te \w di|strong="H5414"\w* la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w* y la \w de|strong="H5414"\w* \w Judá|strong="H3063"\w*, y si esto es muy \w poco|strong="H4592"\w*, te añado \w mucho|strong="H4592"\w* \w más|strong="H3254"\w*.\wj*
