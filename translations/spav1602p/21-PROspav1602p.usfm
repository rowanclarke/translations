\v 12 \w Darále|strong="H1580"\w* \w ella|strong="H3605"\w* \w bien|strong="H2896"\w* y \w no|strong="H3808"\w* \w mal|strong="H7451"\w*, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H7451"\w* su \w vida|strong="H2416"\w*.   
