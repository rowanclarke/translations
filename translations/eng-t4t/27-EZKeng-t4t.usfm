\v 17 “\w You|strong="H6440"\w* human, \w when|strong="H1961"\w* \w the|strong="H6440"\w* Israeli \w people|strong="H1121"\w* \w were|strong="H3478"\w* \w living|strong="H3427"\w* \w in|strong="H3427"\w* \w their|strong="H6440"\w* \w own|strong="H1961"\w* \w land|strong="H6440"\w*, \w they|strong="H5921"\w* ◄\w defiled|strong="H2930"\w* \w it|strong="H5921"\w*/\w caused|strong="H1961"\w* \w it|strong="H5921"\w* \w to|strong="H3478"\w* \w become|strong="H1961"\w* unacceptable \w to|strong="H3478"\w* \w me|strong="H6440"\w*► \w by|strong="H5921"\w* \w the|strong="H6440"\w* \w things|strong="H1961"\w* \w that|strong="H3478"\w* \w they|strong="H5921"\w* \w did|strong="H3478"\w*. \w I|strong="H5921"\w* \w considered|strong="H1961"\w* \w that|strong="H3478"\w* \w their|strong="H6440"\w* \w behavior|strong="H1870"\w* \w was|strong="H1961"\w* \add disgusting\add*, \w like|strong="H1961"\w* [SIM] \w the|strong="H6440"\w* rags/cloths \w that|strong="H3478"\w* women \w use|strong="H1961"\w* \w during|strong="H1961"\w* \w their|strong="H6440"\w* monthly \w menstrual|strong="H5079"\w* periods.  
