\v 7 \w Porque|strong="G1063"\w* hemos tenido \w mucho|strong="G4183"\w* \w gozo|strong="G5479"\w* \w y|strong="G2532"\w* \w consuelo|strong="G3874"\w* \w por|strong="G1223"\w* \w tu|strong="G4771"\w* amor, hermano, \w ya|strong="G2532"\w* \w que|strong="G3754"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1909"\w* ti \w los|strong="G3588"\w* corazones \w de|strong="G1909"\w* \w los|strong="G3588"\w* santos han sido animados.   
\p
\v 8 \w Por|strong="G1722"\w* eso, \w aunque|strong="G1722"\w* \w en|strong="G1722"\w* \w Cristo|strong="G5547"\w* \w tengo|strong="G2192"\w* \w mucha|strong="G4183"\w* \w libertad|strong="G3954"\w* \w para|strong="G1722"\w* mandarte \w lo|strong="G3588"\w* \w que|strong="G3588"\w* debes hacer,   
\p
\v 9 prefiero rogarte \w por|strong="G1223"\w* amor. Yo, \w Pablo|strong="G3972"\w*, \w ya|strong="G2532"\w* anciano, \w y|strong="G2532"\w* \w ahora|strong="G3570"\w* \w también|strong="G2532"\w* \w prisionero|strong="G1198"\w* \w de|strong="G1223"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w*,   
\p
