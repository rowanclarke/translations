\id OBA - Guji Bible 
\h Obaadiyaa Raagichaa 
\toc1 Kitaaba Obaadiyaa Raagichaa 
\toc2 Obaadiyaa Raagichaa 
\toc3 Oba. 
\mt1 Kitaaba Obaadiyaa Raagichaa 
\imt1 Seensa 
\ip Kitaab gabaabaan kun dhaloota Kiristoosiitiin dura bara dhibba shanii fi saddeettamii jaatti diigama Yerusaalemiitiin duuba yennaa hin beekkanne keessatti dhaggame; yennaa san Edoomiin kibba gara aduun baatutti dhaggantu, bara dheera'aaf diina Yihuda'aa ta teete, diigama Yerusaalemiititti gammadiisaan, worra Yerusaalem lolu qarqaariisaan qabeenna qachaa Yerusaalemii saamiisatti jirtiiyyu. Edoom diinota Israa'elii dhibii woliin adabbii jaddu'uu fi injifatam akka isii irra dhaqqabu, Obaadiyaan raaga dubbate. 
\iot Haadhoo Dubbi'ii 
\io1 Adabamiisa Edoomii \ior 1-14\ior* 
\io1 Guyyaa Mootii Waan Maraa \ior 15-21\ior* 
\c 1  
\s1 Adabamiisa Edoomii 
\p  
\v 1 Mudhiin Mootiin Waan Maraa Waaqi marroo biyya Edoomii Obaadiya'atti mudhise asiin jala jirti: 
\q1 Ergamaan tokko 
\q2 gara gosa biyya adda addaa ergamee, 
\q1 «Ka'aa! Dhandhee, 
\q2 biyya Edoomii lollaa!» jedhuun 
\q2 ergaa Mootii Waan Maraa irraa dhagganneerra. 
\q1  
\v 2 Ammalle Mootiin Waan Maraa Edoomiin, 
\q1 «Kunoo, gosa biyya adda addaa keessatti 
\q2 akka ati dadhaddu, 
\q2 ijjumaa akka tuffatantu hin godha. 
\q1  
\v 3 Ati ka mana keeti 
\q2 addee ol jette gaara irratti ka ijaarratte, 
\q2 ka holla dhaka'aa keessa leetu, 
\q1 ‹Eentu lafatti gad na buusa?› ka jettu, 
\q2 koora keetittuu si sobe. 
\q1  
\v 4 Ati akka risa'aa gubbaa irra yoo kaatelle, 
\q2 mandhee teeti urjoota oddu'utti, 
\q2 yoo ijaarrattelle, 
\q2 ani achii gad si buusa 
\q1  
\v 5 Hattuun Yookiin saantuun 
\q2 halkaniin mana keeti yoo dhufane, 
\q2 haguma barbaadane qofa fudhatan. 
\q1 Worri midhaan woyni'ii guuratulle, 
\q2 woxoo hin lakkisa. 
\q1 Diinni keeti ammoo 
\q2 ijjuma si hin balleessa. 
\q1  
\v 6 Isin sanyiin Esaawuu\f + \fr 1:6 \fqa Sanyii Esaawuu: \ft Kolbaa Edoomii jedhamuu hin dande'ama.\f* 
\q2 manni keessan soffameera. 
\q2 Karri teessan duudiille saamanteerti. 
\q1  
\v 7 Goliin teeti si sobanee, 
\q2 biyya teeti keessa si ari'ane. 
\q1 Jaaloti teeti worri addatamane 
\q2 dhossa'aan tiyyoo si duratti afanee, 
\q2 ‹Qarummaan isaa meet› jedhane. 
\q1  
\v 8 Guyyaa sanitti Mootiin Waan Maraa: 
\q2 Ani qaroolle Edoom keessaa, 
\q2 worra hubantii qabu 
\q2 gaara Esaawuu irraa hin balleessu. 
\q1  
\v 9 Ee qachaa Temaanii! 
\q2 Loltooti teeti hin bararaqan; 
\q2 worri gaara Esaawuu irra 
\q2 jiranu martinuu hin ijjeefaman. 
\s1 Adabamiisa Edoomii 
\b  
\q1  
\v 10 «Sanyii Obboleessa keeti Yaaqoobii 
\q2 hunnaan waan ijjeetteef, 
\q2 hin qaanotta; 
\q2 haga bara baraalle hin badda. 
\q1  
\v 11 Guyyaa alagaan karra saame, 
\q2 worri ormaa dalleya cassee seenee 
\q2 Yerusaalem irratti hixaa buufate, 
\q2 atille akkuma worra sanii itti teetee, 
\q2 irraa fagaattee dhaabbatte. 
\q1  
\v 12 Guyyaa obboleessi keeti rakkatu 
\q2 isatti qacifatuun, 
\q2 guyyaa badii kolbaa Yihuda'aa, gammaduun, 
\q2 guyyaa gadda isaanii geeraruun 
\q2 si'iif hin malle. 
\q1  
\v 13 Guyyaa badii kolbaa tiyyaa 
\q2 qachaa isaanii seenuun, 
\q2 guyyaa badii isaanii itti qacifatuun, 
\q2 karra isaaniille saamuun 
\q2 si'iif hin malle. 
\q1  
\v 14 Guyyaa gadda isaanii 
\q2 qaxxaamura kara'aa irra dhaabbattee 
\q2 worra baqatanee bayanu qaddee 
\q2 dabarsitee diinotatti kennuun, 
\q2 si'iif hin malle. 
\s1 Mootiin Waan Maraa Gosa Biyya Adda Addaatitti Hin Mura 
\b  
\q1  
\v 15 «Guyyaan ani Mootiin Waan Maraa 
\q2 gosa biyya adda addaa maratti muru dhikaateera; 
\q1 Edoom, akkuma ati nama irratti goote 
\q2 si'i irralle'etti hin godhama; 
\q2 hujiin teeti hantuun mataa keetitti hin deebiti. 
\q1  
\v 16 Akkuma kolbaan tiyya 
\q2 gaara kiyya woyyicha irratti 
\q2 muduunuu rakko'oo unte, 
\q2 gosi biyya adda addaa marti 
\q2 adoo wol irraa hin kutin hin unti; 
\q2 irra caalaalle hin unti; 
\q2 akka hin jirrelle hin teeti. 
\s1 Injifachaa Israa'elii 
\q1  
\v 17 Worri gariin ammoo 
\q2 gaara Xiyoonii irratti hin hafan, 
\q2 gaarri Xiyooniille woyyicha hin te'a; 
\q2 sanyiin Yaaqoobii ammoo 
\q2 worra lafa isaanii 
\q2 isaan irraa fudhate irraa 
\q2 deebifatanee hin fudhatan. 
\q1  
\v 18 Sanyiin Yaaqoobii akka ibiddaa, 
\q2 sanyiin Yoseefiille 
\q2 akka bobe'aa te'anee, 
\q2 sanyii Esaawuu ta akka huuraa 
\q2 gubanee hin fixan; 
\q2 sanyii Esaawuu keessaa ka hafu 
\q2 tokkolle hin jiru. 
\q1  
\v 19 Worri biyya Yihuda'aatiin gara kibbaa jiranu 
\q2 gaara Esaawuu, 
\q2 worri gaara jala jiranu ammoo 
\q2 biyya Filisxeemotaa hin qabatan; 
\q2 isaan Samaariya'aa fi 
\q2 lafa sanyii Efreemii hin qabatan; 
\q2 sanyiin Beniyaaminii ammoo 
\q2 Giil'aad hin qabatan. 
\q1  
\v 20 Loltooti Israa'elii 
\q2 worri booji'amee Kana'aan keessa jiru 
\q2 haga Zaarefa'aatitti hin qabatan; 
\q2 worri Yerusaalemii booji'amee 
\q2 Safaaraad jiru 
\q2 qachoota biyya Yihuda'aa 
\q2 ka gara kibbaa\f + \fr 1:20 \fqa Qachoota kibba Yihuda'aa: \ft Isaan kun qachoota Negebii ti.\f* jiranu hin qabatan. 
\q1  
\v 21 Worri isaan bilisa baasu gaara Xiyoonii irratti 
\q2 ol bayanee gaara Esaawuu hin bulchan; 
\q2 yennaa san mootummaan 
\q2 ta Mootii Waan Maraa hin teeti» jedha.