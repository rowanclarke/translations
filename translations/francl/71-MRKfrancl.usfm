\v 5 \w Jésus|strong="G2424"\w* \w leur|strong="G4314"\w* \w répondit|strong="G3004"\w* : « \w C|strong="G3778"\w*’\w est|strong="G3588"\w* \w à|strong="G4314"\w* \w cause|strong="G4314"\w* \w de|strong="G3588"\w* \w la|strong="G1161"\w* \w dureté|strong="G4641"\w* \w de|strong="G3588"\w* \w votre|strong="G5210"\w* \w cœur|strong="G4641"\w* \w qu|strong="G3588"\w*’\w il|strong="G1161"\w* \w vous|strong="G5210"\w* \w a|strong="G4314"\w* \w donné|strong="G1125"\w* \w cette|strong="G3778"\w* \w loi|strong="G1785"\w*.
\v 6 \w Mais|strong="G1161"\w* \w au|strong="G2532"\w* \w commencement|strong="G2532"\w* \w de|strong="G2532"\w* \w la|strong="G2532"\w* \w création|strong="G2937"\w*, \qt Dieu les fit homme et femme\qt*\x + \xo 10:6 \xt Gen 1,27\x*.
\v 7 \qt À cause de cela, l’homme quittera son père et sa mère, et s’attachera à sa femme\qt*,
\v 8 \qt et les deux ne feront qu’une seule chair\qt*. » \w Ainsi|strong="G2532"\w* \w ils|strong="G2532"\w* \w ne|strong="G2532"\w* \w sont|strong="G3588"\w* \w plus|strong="G2532"\w* \w deux|strong="G1417"\w*, \w mais|strong="G2532"\w* \w ils|strong="G2532"\w* \w sont|strong="G3588"\w* \w une|strong="G2532"\w* \w seule|strong="G1520"\w* \w chair|strong="G4561"\w*.
