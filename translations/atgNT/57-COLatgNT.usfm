\id COL - Okphela 
\h iKolosha 
\toc1 iKolosha 
\toc2 iKolosha 
\toc3 iKolo 
\mt2 Ebe ni iPọlu ọ kẹkẹ ghi ẹgbọ 
\mt1 IKolosha 
\mt2 Eni e miesuọ 
\c 1  
\p  
\v 1 Mhẹmhẹ iPọlu, aghiusomhi na kẹẹ ọyi iJesu iKirisiti ni Ẹshinẹgba ọ zẹ abi o ghọle ọli shi mhi khi, li shi inyọghuo awa iTimoti. 
\p  
\v 2 Mhẹmhẹ mhi kẹkẹ ebe ona ghi ẹgbọ eyi Ẹshinẹgba ni e la ẹoli iKolose, ikhi inyọghuo awa ni e pfuasẹ ni a ri egbe ẹ nga elemhi iKirisiti. 
\p Ẹshinẹgba Ita awa ọ ka li okhale na ẹ, ọ ri opfọmhẹ na ẹ. 
\s1 Iromhi ali ikphẹmhi 
\p  
\v 3 Ẹghẹghẹ kpa anye rọ kphẹmhi na Ẹshinẹgba, Ita iJesu iKirisiti Ọnọmhuẹ ọyawa, ini anye ẹ sọ iromhi na ẹ.  
\v 4 Itobọ khi anye she suọ abi a migha shi irudunga oyi iJesu, ali abi a li nono ingme oyi ẹgbọ eyi Ẹshinẹgba nya.  
\v 5 Emini Ẹshinẹgba ọ rọ shi ekẹ ẹ khẹ ẹ obini iloghie, o rẹ ẹ mhọli irudunga ali inono ona, ikhi emini a she suọ elemhi ungmemhi igẹsikia, ikhi usomhi onete oyi iJesu iKirisiti ni a she gueyẹ ẹ.  
\v 6 Oni usomhi onete ona o she ri umọmhi ẹ lasele, o gbolo fu ẹ shi ọ elemhi agbọ nya, abi o kie kpẹ ẹ li iteva oyẹẹ rọte ogbẹlẹ ni a te lẹsẹ igẹsikia ni o la ukpokpomhi okhale ni Ẹshinẹgba ọ li.  
\v 7 Obọ oyi Epafurasi a te suọ oni okhale oyi Ẹshinẹgba, ọni ọ khi ọtuọghuo elemhi anye, ni ọọ gbe akanya oyi iKirisiti te odẹ igẹsikia ni ọ to ẹloli anye.\f + \fr 1:7 \ft Li zẹ \fq iKolo 4.12; iFilẹ 23\f* 
\v 8 Lọli ọ gbo gueyẹ anye abi oni Ayẹmhẹ ọ li rẹ ẹ mhọli inono na ẹgbọ eyi Ẹshinẹgba. 
\p  
\v 9 Abi anye te lina suọ esọ onete oyi angeli oyẹẹ, anye ẹ tigbe yẹmhẹ iromhi isọsọ-a, ni anye sọ ọ na ẹ. Anye ẹ sọ iromhi, Ẹshinẹgba ọ rọte ilẹsingme ali ilẹsẹ elemhi Ayẹmhẹ-nọ-pfuasẹ kpaghiẹ ẹ obọ, ni a lẹsẹ ọghuẹmhẹ oyọli, ni a riẹlẹ ọli.  
\v 10 Eri anye lina sọ iromhi na ẹ, ni a guẹ ke ngeli abi ẹgbọ eyi Ọnọmhuẹ ẹẹ li, ni a ri egbe ke mu ọli, a ri imọmhi eyi onete iriẹlẹ lasele, a gbolo ẹ lẹsẹ Ẹshinẹgba gbo shi ọ.  
\v 11 Anye gbolo ẹ lema li, ọ ri itoto na ẹ, ni a ke ri ekpabọ eyọli nya gbe akanya, ni a mhọli ukpokpomhi iregbemie ali irabọmudu ali oghẹlẹ.  
\v 12 Ni a ke kphẹmhi na Ẹshinẹgba Ita, ni ọ li rẹ ẹ fu tẹ eni e li mhọli okemhi shi ugu oyi ẹgbọ eyi Ẹshinẹgba, eni e la ákpá, ni ọ rọọ khẹ ẹ.  
\v 13 Ẹshinẹgba ọ she rue awa obọ oyi ekpabọ alo ebili eyi ọkphaghiẹ lasele, o rue awa bhale iloghie oyi omi ọli ni ọ nono.  
\v 14 Obọ oyọli awa te mhọli ipfashekẹ, ni ọ ri olamhẹ topfa awa.\f + \fr 1:14 \ft Li zẹ \fq Ẹfi 1.7\f* 
\s1 IKirisiti ọ fu nẹ nya 
\p  
\v 15 IKirisiti khi irọkhọkhọ ọyi Ẹshinẹgba ni ọgbọ aa ya mẹ ẹloe. Lọli ọ khi ọni ododẹ emini Ẹshinẹgba ọ ma nya.  
\v 16 Irari khi obọ oyọli a te ma emhikpa, ikhi emini e la ukhuli ali ekẹ, ghe eni a mẹ ali eni aa ya mẹ, okekhi ikpẹkhomhi eghiele o, o khi ekpabọ o, o khi ighie o, okekhi ena omhẹsẹ o, lọli ọ ma emhikpa, ọ ma wẹ na egbọli.  
\v 17 Ọ kpẹ la ọ neni a ma emhi nya, lọli ọ zẹ ni emhi nya e rọ kugbe khi oghuo.  
\v 18 Lọli ọ khi ukhomhi oyi idiegbe, ikhi igbaa oyi eni e mie iJesu iKirisiti suọ. Lọli ọ khi igbaekẹle, itobọ khi lọli Ẹshinẹgba ọ kpẹ guise le, ni ọa ke gbo ya ghu ghue, ẹghẹghẹ aghọ ni lọlighuo ọ ri obọ nga emini e la agbọ nya ke mhẹsẹ shi.\f + \fr 1:18 \ft Li zẹ \fq Ẹfi 1.22-23\f* 
\v 19 Irari khi eri o ghọle Ẹshinẹgba ni emini ọ khi nya o la agbọ oyi Omi ọli.  
\v 20 Isheghọ ni ọ mẹ asha rọte obọ oyi ọni Omi ọli nu emhikpa mhuẹ irọ-riẹlẹ, o khi emhi na agbọ ona okekhi ena idane. Ọlia eyọli ni ọ ku abi ọ rọ ghu-a shi ukhomhi apfida ọ rọ riẹlẹ ona.\f + \fr 1:20 \ft Li zẹ \fq Ẹfi 2.16\f* 
\p  
\v 21 Ẹghẹghẹ ni o dọsẹ ni aa rọ kpẹ lẹsẹ Ẹshinẹgba, eri a nuata shi ọli ọ. A khi ebe ọli elemhi udu oyẹẹ, itobọ angeli obe ni a ngeli.  
\v 22 Ama Ẹshinẹgba ọ she rẹ ẹ nu egbọli rọ riẹlẹ. Eghuli oyi iKirisiti ọ rọ rẹ ẹ khi eni e pfuasẹ shi odalo oyọli, ni aa ke mhọli ichimhi, ni á pfue umhaguẹkia.  
\v 23 Ini a da kie la elemhi irudunga oyẹẹ, ni a rọ migha gbagbagba shi ọ, ni aa rọ zẹ ni irudushi ni a mhọli o nighise, ikhi oni a mhọli shi emini Ẹshinẹgba ọ rọ shobọ na ẹ elemhi usomhi onete oyọli. Oni usomhi onete ona ni a she rọ tse abọ khasẹ ọgbọkpa elemhi agbọ ona, lọli a zẹ mhẹ iPọlu shi abi aghiusomhi, mhi rọli ke tse abọ. 
\s1 Ikanya ni iPọlu ọ gbe na igbaa oyi eni e mie iJesu iKirisiti suọ 
\p  
\v 24 Memena, egbe ga a mu mhẹ shi osoli ni mhi mẹ ẹ na ẹ elemhi idiegbe oyẹmhẹ. Eri mhi ri oni osoli ona pfuse ikanya eni e kpọle gbe, abi iKirisiti ọọ mẹ osoli na idiegbe oyọli, ikhi igbaa oyi eni e mie iJesu iKirisiti suọ.  
\v 25 Ẹshinẹgba ọ she rẹmhẹ khi ọni ọọ ga ọyi igbaa oyi eni e mie iJesu iKirisiti suọ oyọli, ni mhi ya tse-abọ oni usomhi oyọli nya yẹ ẹ.  
\v 26 Ona o khi osheli ni ọ kpẹ rọ sheli na ẹgbọ rọte igbaekẹle ramhi ẹghẹghẹ ana. Ama, lọli ọ tigbe khueghie a khasẹ ẹgbọ eyọli ena.  
\v 27 Eri Ẹshinẹgba ọ riẹlẹ ona ni eni ẹgbọ eyọli e lẹsẹ ẹpfue oniẹmhi ni o la oni osheli ona. Oni osheli khi, iKirisiti ni ọ la agbọ oyẹ ẹ, ni ọ rẹ ẹ mhọli irudushọ khi, a ya nu ọli mhọli okemhi shi ufumhi oyi Ẹshinẹgba. 
\p  
\v 28 Lọli o zẹ ni anye rọ ri iKirisiti ẹ tse abọ khasẹ ọgbọkpa. Rọte ẹgbhali ni anye mhọli nya anye te ẹ tse agua ye ọgbọ, anye gbolo ẹ sẹsẹ wẹ ni anye rọ rue wẹ bhale odalo oyi Ẹshinẹgba abi ẹgbọ ni e mhuẹ iwomhẹloe, ni e toma iKirisiti ọ.  
\v 29 Ni a bhale ya ẹ khi ona o zẹ ukhomhi, eri mhi ri ekpabọ eyi iKirisiti nya ni e la mhẹ egbe rọshẹka gbe akanya. 
\c 2  
\p  
\v 1 Mhia nono ni mhi gueyẹ ẹ abi mhi li rọshẹka a kpaghiẹ ẹ ali eni e miesuọ ni e la ẹoli iLaodisha ali ẹgbọẹse ni ẹa mẹ mhẹ ukpẹloe ghue obọ.  
\v 2 Emini o zẹ ni mhi rọ ọ riẹlẹ ona khi ni a rọ ri udu shi wẹ ọ, ali ni e kugbe elemhi inono, ini e mhọli ẹpfue ni o gba pfo ni ilẹsẹ o rọ ọ na ọgbọ. Ẹghẹghẹ aghọ ni e lẹsẹ osheli ni Ẹshinẹgba ọ gba, ni o khi iKirisiti.  
\v 3 Lọlighuo kpe ọ khi okpẹ ni ọọ khueghie ẹpfue-a ni o la ilẹsingme ali ilẹsẹ eyi Ẹshinẹgba. 
\p  
\v 4 Eri mhi gue ona a yẹ ini ọgbọkhọghuo ọ khi ri osẹsẹ ẹgbhọli bhale ya di ẹ, abibi eni osẹsẹ e ririẹ dala esọ ramhi.  
\v 5 Irari khi, ini mhi aa ririẹ nu ẹ la aghọ, ayẹmhẹ oyẹmhẹ o nu ẹ la aghọ. Mhi nono ni mhi bhale ya mẹ ẹ abi a guẹ la kuete, ni irudunga ni a mhọli shi iKirisiti ọ ọa li nighise. 
\p  
\v 6 Aborọkhia khi a she rue iJesu iKirisiti abi Ọnọmhuẹ, a nu ọli ke ngeli kugbe,  
\v 7 à gbelighi mighà, a gbo rọ ma imiesuọ ni a mie iKirisiti suọ, a kie mhọli ọli shi udu khi emini a sẹsẹ ẹ ikhi ingme eyi iKirisiti khi igẹsikia e khi. A kphẹmhi ẹ na Ẹshinẹgba ẹghẹghẹ kpa. 
\p  
\v 8 Khi zẹ ọgbọkhọghuo di ẹ mu lama shi osẹsẹ afuẹ ali eyi ikpamhika. Ikhi osẹsẹ ni e migha nga angeli ali ẹgbhali oyi agbọ, ni ẹa rọte obọ oyi iKirisiti bhale. 
\p  
\v 9 Irari khi emini Ẹshinẹgba ọ khi nya e la idiegbe oyi iKirisiti.  
\v 10 Irari khi a kugbe iKirisiti ọ, a rọ mhọli agbọ ni o gba pfo elemhi ayẹmhẹ. Lọli ọọ kpeda nya elemhi ekpabọ ali omhẹsẹ ali afu nya na elemhi ayẹmhẹ.  
\v 11 Itobọ khi a kugbe iKirisiti ọ, ọ rọ rue ẹ ọghuẹmhẹ idiegbe udu lasele, ẹzẹzẹ abi a liẹ shẹlẹ ọgbọ ẹpfi-a.  
\v 12 Ẹzẹzẹ abi a li ri iKirisiti tọ abi ọ rọ ghua, ni a gbo guise ọli le, ighọ a li pfi ẹ lo elemhi okẹ gbo mu ẹ vule, elemhi ibatizi. A guise ẹ le bhale agbọ irari khi a mhọli irudunga shi ekpabọ oyi Ẹshinẹgba ni ọ rọte eghuli guise iKirisiti le.\f + \fr 2:12 \ft Li zẹ \fq iRom 6.4\f* 
\p  
\v 13 Eri a kpẹ ghu-a shi elemhi ayẹmhẹ ẹghẹghẹ no dọsẹ, irari khi a la agbọ olamhẹ. Ama memena, Ẹshinẹgba ọ she ri iKirisiti rẹ ẹ gbo mhọli agbọ. Ọ ri olamhẹ eyawa nya topfa awa.\f + \fr 2:13 \ft Li zẹ \fq Ẹfi 2.1-5\f* 
\v 14 Abi Ẹshinẹgba ọ rọ shishi ishi ni a zẹ shi awa egbe-a se, ikhi eni e migha zu awa odẹ, ọ rue wẹ awa odẹ-a, ọ ta wẹ ma apfida abi iJesu ọ rọ ghua.\f + \fr 2:14 \ft Li zẹ \fq Ẹfi 2.15\f* 
\v 15 Abi ọ rọ mie iyẹmhẹ ọkphaghiẹ ekpabọ se, ọ rẹ wẹ lasele gboo yẹghẹ-a abi ọ rọ ghu-a shi apfida. 
\p  
\v 16 Irarighọ, khi zẹ ni ọgbọkhọghuo ọ gue ẹ ẹzọ shi emini u wa le ali oni u wa da, ukẹneta ushi imu Uki Onogbọ ali ogbẹlẹ ne pfuasẹ ali Ogbẹlẹ iYẹmhẹa oyi iJu.\f + \fr 2:16 \ft Li zẹ \fq iRom 14.1-6\f* 
\v 17 Enana nya, irọkhọkhọ oyi emini e ya bhale ikpukhokho agbọ e khi, iKirisiti ọ khi ọzukhomhi wẹ nya.  
\v 18 Khi zẹ ni ọgbọkhọghuo ni ọ riẹlẹ iregbe-tiemhie eyi ikpamhika, ni ọọ ga igẹni, ọ di ẹ dobẹ eleli oyẹ-a. Emini ẹgbọ eghọghọ e mẹ e la tọnọ ali udu oyẹwẹ ni imiesuọ o rọli ẹ vuse ike shi isamhi afuẹ.  
\v 19 Ọgbọ ọghọghọ ọa ke kugbe iKirisiti ọ, ni ọ khi Ọzukhomhi oyi oni idiegbe, ikhi igbaa oyi eni e mie iJesu iKirisiti suọ miesuọ. Ẹzẹzẹ abi ukhomhi oyi ọgbọ o liẹ gueyẹ idiegbe abi o liẹ kia, ighọ omhẹsẹ oyi iKirisiti o liẹ mhẹsẹ na ẹgbọ eyọli nya, rẹwẹ gbe akanya kugbe abi idiegbe ọgbọ o tono elamhi ali ikpẹsẹ egbe manọ, khi ọghuo. Ẹghẹghẹ aghọ oni idiegbe nya o fu abi Ẹshinẹgba ọ nono ọli shi.\f + \fr 2:19 \ft Li zẹ \fq Ẹfi 4.16\f* 
\p  
\v 20 Aborọkhia khi u she nu iKirisiti ghua, ni ushi agbọ ọa ke rọ mhẹsẹ nẹ eghọ, elọ o zẹ khi u kie ri egbe ẹ na wẹ, ni u rọ ri ushi eyẹwẹ gbe akanya, ni ẹẹ liẹ,  
\v 21 “Khi mu ona mhọli obọ,” “Khi to ẹlẹmhi oghọ bino,” “Khi ri obọ ti onana?”  
\v 22 Enana nya, emini e ya mele afuẹ-a e khi, ini a rẹwẹ riẹlẹ emini a rẹwẹ ya riẹlẹ se. Irari khi ishi ali omhẹsẹ ni ẹgbọ e mhẹsẹ lọ.  
\v 23 Eri omhẹsẹ eghọghọ e li abinẹ khi ilẹsingme e la ọ, ikhi eni e ri itoto ri ẹgbọ ga ugamhi ikpamhika ali iregbe-tiemhile oyi ikpamhika, ali ina-idiegbe-osoli, ama eni ẹ riẹlẹ ena ẹa rẹwẹ lase olamhẹ le. 
\c 3  
\s1 Angeli ni o ghọle Ẹshinẹgba 
\p  
\v 1 Aborọkhia khi a she rọte eghuli guise ẹ ali iKirisiti le bhale agbọ eghọ, ri udu oyẹ shi emini e la obini iloghie obini iKirisiti ọ shitọ obita Eghiele oyi Ẹshinẹgba.\f + \fr 3:1 \ft Li zẹ \fq Iwolo 110.1\f* 
\v 2 Ri udu oyẹ shi emini e la obini iloghie, khi rọli shi emini e la agbọ ana,  
\v 3 irari khi u she ghua, elemhi iKirisiti u ke la, ni ọ la elemhi Ẹshinẹgba.  
\v 4 Egbegbi agbọ oyẹ, elemhi iKirisiti o la. Ọ kha da feli lasele, yẹyẹ, u li ya nu ọli la akaghọ, u li nu ọli mhọli okemhi shi ufumhi oyọli. 
\p  
\v 5 Irarighọ, zẹ ni ọghuẹmhẹ oyi emhi agbọ ni o kpẹ la agbọ oyẹ o ghua. Enabi itsẹbọ, ali angeli ichimhi, ali isamhi ebe, ali ọghuẹmhẹ ni ẹa ti, ali emhi-itoegbe ni o li khi ikhumhi igaga.  
\v 6 Itobọ enana, elemhi e rọ bi Ẹshinẹgba deba ẹgbọ ni ẹa ya suọ esọ na li.  
\v 7 Ẹẹ, a kpẹ li lina ngeli ẹlẹlẹ, abi a rọ la ifuabọ eyi ẹgbọ eghọghọ.  
\v 8 Ama, memena a zẹ ni emhi eghọghọ nya e lase ẹ egbe le. Emhi nabi elemhi-ibibi, ali ofu imhọli, ali imuegbe ọbe, ali iyesegbe-eva-a, ali ingmemhi iditsẹa, ali itono obọ udu.  
\v 9 A khi ke lono ẹgbhọli khasẹ egbe aborọkhia khi a she gueghie ingeli ali idiegbe onodiọ shi ekẹ eghọ,\f + \fr 3:9 \ft Li zẹ \fq Ẹfi 4.22\f* 
\v 10 ni a shi ri idiegbe enegbọ ku egbe, ni Ẹshinẹgba Ima ọ rọ ya mele onogbọ-a, ni o li abi oyọli. Ini ọ mẹ asha rẹ ẹ mhọli ilẹsẹ oyọli.\f + \fr 3:10 \ft Li zẹ \fq Igbae 1.26; Ẹfi 4.24\f* 
\v 11 Itobọ ona, azọlọmhẹ ọa ke la iteva eni e khi iJu ali ẹgbọ iJẹta, wẹẹ eni a shẹlẹ-a ali eni aa shẹlẹ-a, wẹẹ ẹgbọ eni ẹa fialo-a ali ẹgbọ eni e rọte ifui ishemhi lasele, wẹẹ oghumha ali omi ọgbọ. Ama iKirisiti ọ khi ọni ọ mu egbe ne. 
\p  
\v 12 Irarighọ, abi a rọ da khi eni Ẹshinẹgba ọ zẹ, ni e pfuasẹ ni ọ nono ingme oyẹwẹ eghọ, a ri ilẹlemhi, isomhelemhi, itiegbe-tiemhi, ali ipfọmhẹ ali irobọmudu sọ abi awulu.  
\v 13 A ke ti eni e miesuọ nabi ẹẹ ma egbe. Ini a lue na egbe, a rọ ke topfa egbe ẹ. A rọ topfa abi Ọnọmhuẹ ọ li rọ topfa ẹ.\f + \fr 3:13 \ft Li zẹ \fq Ẹfi 4.32\f*\f + \fr 3:13 \ft Li zẹ \fq Ẹfi 4.2\f* 
\v 14 Emini u gbo rọ ya ma eni ingeli enete ena nya khi, inono ni o gẹnọ eni ingeli ena nya kugbe, elemhi ikugbe ni o gba pfo. 
\p  
\v 15 Zobẹ ni opfọmhẹ oyi iKirisiti o mhọli omhẹsẹ shi udu oyẹ, aborọkhia khi ẹgbọ ni e kugbe elemhi idiegbe oghuo a khi eghọ, àá kphẹmhi.  
\v 16 A zẹ ni ungmemhi oyi Ọnọmhuẹ o la agbọ oyẹ ẹ, abi a liẹ sẹsẹ egbe, ni a ri ilẹsingme ẹ ye egbe ude. A gbo lighọ ke to iwolo ena irudunga, ni a rọte elemhi ayẹmhẹ ẹ to ke lasele. A ri ayẹmhẹ ikphẹmhi ẹ to uwolo kuẹghiẹ Ẹshinẹgba.\f + \fr 3:16 \ft Li zẹ \fq Ẹfi 5.19-20\f* 
\v 17 Emhikpa ni u wa riẹlẹ ni u wa ngme, ri eva oyi iJesu Ọnọmhuẹ riẹlẹ wẹ. U gbolo ri eva oyọli ẹ kphẹmhi na Ẹshinẹgba Ita. 
\s1 Abi eni e miesuọ e li ya ke ngeli 
\p  
\v 18 Ẹẹ ikpotso ni a la ughuẹ, a ri egbe ẹ na ọdọ ẹ pfo, irari khi ina ẹẹ eni e miesuọ e ke li.\f + \fr 3:18 \ft Li zẹ \fq Ẹfi 5.22; 1 iPit 3.1\f* 
\p  
\v 19 Ẹẹ edọ, a nono ingme oyi ughuẹ ẹ, a khi ri obọ ni o toto dọsẹ mu wẹ.\f + \fr 3:19 \ft Li zẹ \fq Ẹfi 5.25; 1 iPit 3.7\f* 
\p  
\v 20 Eniyẹ, a ke suọ esọ na eni e bia ẹ odẹkhodẹ, irari khi onana o ti Ẹshinẹgba ẹloe.\f + \fr 3:20 \ft Li zẹ \fq Ẹfi 6.1\f* 
\p  
\v 21 Ita eniyẹ, a khi riẹlẹ emini e ya ri elemhi bi imi ẹ, irari khi o ya ri egbe pfọ wẹ a.\f + \fr 3:21 \ft Li zẹ \fq Ẹfi 6.4\f* 
\p  
\v 22 Ẹẹ ighumha, a ri ungmemhi oyi ọni ọ mhọli ẹ ni ọ la agbọ ona ke gbe akanya. Ọa khi ini e nu ẹ la aghọ tsẹ a rọ ri ungmemhi oyẹwẹ ya ke gbe akanya ini e ba somhi-elemhi ẹ. Ama ri udu oghuo ke gbe akanya irari khi u mu ekpẹ a na Ọnọmhuẹ.  
\v 23 Emiemini u wa riẹlẹ nya ri ọmuegbe ni o rọte udu oyẹ nya lasele ke riẹlẹ ọli, abinẹ khi Ọnọmhuẹ u gbe akanya a na, ni ọa khi ọgbọ.  
\v 24 Lina ke ngeli abi u rọ da lẹsẹ khi u ya rọte obọ oyi Ọnọmhuẹ mẹ eleli eghọ.  
\v 25 Ẹshinẹgba ọ ya fali ọni ọ li onobe ota, ọa ya gbe ọgbọkhọghuo azẹba.\f + \fr 3:25 \ft Li zẹ \fq iDẹut 10.17; Ẹfi 6.9\f*\f + \fr 3:25 \ft Li zẹ \fq Ẹfi 6.5-8\f* 
\c 4  
\p  
\v 1 Ẹẹ ega, a guẹ ke riẹlẹ deba ighumha eyẹ ẹ abi o ti shi, a ri igẹsikia deba wẹ. Sato khi yẹyẹ u li mhọli Ọga shi iloghie.\f + \fr 4:1 \ft Li zẹ \fq Ẹfi 6.9\f* 
\s1 Emini ọ gbo mhẹsẹ na wẹ 
\p  
\v 2 A lolo ke sọ iromhi, a tọ ẹloe ekẹ, a tsẹ Ẹshinẹgba uwegbe.  
\v 3 A gbo li ke sọ iromhi na anye, ni Ẹshinẹgba ọ khueghie odẹ-a na anye ini anye mẹ asha gue ungmemhi oyọli le. Ikhi ungmemhi onayi osheli oyi iKirisiti, ni o zẹ khi mhi la ọgba ighumha memena.  
\v 4 A lema na mhẹ, ni mhi gue oni usomhi le gboo ni ẹgbọ e suọ li.  
\v 5 Ri ilẹsingme nu ẹgbọ eni ẹa miesuọ ke ngeli. Ẹghẹghẹ ni u mhọli nya, rọli riẹlẹ onete.\f + \fr 4:5 \ft Li zẹ \fq Ẹfi 5.16\f* 
\v 6 Zẹ ni ilẹsingme o la ungmemhi ni u wa ngme, u gbolo ẹ ngme ingmemhi eni ẹẹ ti esọ, ẹghẹghẹ aghọ ni u lẹsẹ emini u ya ke sọ shi ọgbọkpa ingme. 
\s1 Otsẹ ni o kpukhokho 
\p  
\v 7 ITakikọsi ọ ya gue ingme eyẹmhẹ nya yẹ ẹ. Egbegbi inyọghuo ni ọọ gbe akanya oyi Ẹshinẹgba te odẹ igẹsikia, ni mhi nono ingme oyọli ọ khi. Ọni anye ga kugbe ẹẹ ga Ọnọmhuẹ ọ li khi.  
\v 8 Ni a rọ lẹsẹ abi anye li la ọ shi memena mhi rọ ghie ọli ẹ ghi ẹ, ali ni ọ gbo ri udu shi ẹ ọ.\f + \fr 4:8 \ft Li zẹ \fq Ika 20.4; 2 iTimo 4.12; Ẹfi 6.21-22\f* 
\v 9 Lọli ali Onẹsimusi mhi ga ghie ẹ ghi ẹ. Inyọghuo anye ọni ọọ gbe akanya oyi Ẹshinẹgba te odẹ igẹsikia ni anye nono ingme oyọli ọ li khi. Ọnge ẹoli oyẹ ẹ ọ khi. E ya gueyẹ ẹ emini áá mẹ oola nya.\f + \fr 4:9 \ft Li zẹ \fq iFilẹ 10-12\f* 
\p  
\v 10 Arisitakusi ni anye ga la owa ighumha, ọọ tsẹ ẹ. IMaki ni lọli ali iBanabasi e khi inyọghuo, ẹẹ tsẹ ẹ. Ini iMaki ọ bhale a kpe abọ mie ọli abi a li mhẹsẹ ọli na ẹ.\f + \fr 4:10 \ft Li zẹ \fq Ika 19.29; 27.2; iFilẹ 24; Ika 12.12,25; 13.13; 15.37-39\f* 
\v 11 IJesu ni akiseva oyọli o khi iJọsitọsi, ọ liẹ tsẹ ẹ. Eni ẹgbọ aasẹ ena e khi ẹgbọ iJu tsẹ eni e nu mhẹ ẹ gbe akanya iri-ungmemhi oyi Eghiele oyi Ẹshinẹgba ke kia gasẹ. Eri e ga ri egbe ẹ mu mhẹ.  
\v 12 Epafurasi ni ọ khi ọnge ẹoli oyẹ ẹ, ni ọ khi ọni ọọ ga iJesu iKirisiti, ọ li tsẹ ẹ. Ẹghẹghẹ kpa ọ rọ ọ dọ ọgbọ elemhi iromhi isọsọ itobọ oyẹ ẹ, ni a migha gbagbagba, ni a womhẹloe shi elemhi ọghuẹmhẹ oyi Ẹshinẹgba. Ali ni a gbo mhọli ọli shi udu khi Ẹshinẹgba ọ ya riẹlẹ emini ọọ khi lọli ya riẹlẹ.\f + \fr 4:12 \ft Li zẹ \fq iKolo 1.7; iFilẹ 23\f* 
\v 13 Mhi pfi ọtsẹlẹ na li khi ọ ma a gbe akanya egbegbọ itobọ oyẹ ẹ, ali ẹgbọ ni e miesuọ ni e la iLaodisha ali Ẹrapolisi.  
\v 14 ILuku ọmọle anye ni ọ khi idọkita, ali iDẹmasi ẹẹ tsẹ ẹ.\f + \fr 4:14 \ft Li zẹ \fq 2 iTimo 4.10,11; iFilẹ 24\f* 
\v 15 A li nu mhẹ tsẹ eni e miesuọ ni e la iLaodisha, ali iNifa ali igbaa oyi eni e mie iJesu iKirisiti suọ ni e la owa oyọli. 
\p  
\v 16 Ini a zẹ ebe ona se, a zẹ ni a li zẹ ọli yẹ igbaa oyi eni e mie iJesu iKirisiti suọ ni o la ẹoli iLaodisha. Zobẹ ni a li mie ẹgbọ iLaodisha ebe ni mhi kẹkẹ ghi wẹ li zẹ. 
\p  
\v 17 Gueyẹ Achipọsi khi mhiẹ ọli ọ rọshẹka pfuse akanya ni Ọnọmhuẹ ọ rọ nga li obọ gbe pfo.\f + \fr 4:17 \ft Li zẹ \fq iFilẹ 2\f* 
\p  
\v 18 Mhẹmhẹ iPọlu mhi ri ugba ma ebe ga kẹkẹ otsẹ ona ghi ẹ. A khi yele-a khi eri a sọ mhẹ igha. Okhale oyi Ẹshinẹgba o nu ẹ la.