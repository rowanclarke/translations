\q1
\v 3 \w L|strong="H3068"\w*'Assyrie \w ne|strong="H3068"\w* \w peut|strong="H3068"\w* \w nous|strong="H3068"\w* sauver.  
\q2 \w Nous|strong="H3068"\w* \w ne|strong="H3068"\w* \w monterons|strong="H3068"\w* \w plus|strong="H7725"\w* \w sur|strong="H3068"\w* \w des|strong="H3068"\w* chevaux,  
\q2 \w et|strong="H3068"\w* \w nous|strong="H3068"\w* \w ne|strong="H3068"\w* \w dirons|strong="H3068"\w* \w plus|strong="H7725"\w* \w à|strong="H3068"\w* l'ouvrage \w de|strong="H1697"\w* \w nos|strong="H7725"\w* \w mains|strong="H7725"\w* : “\w Nos|strong="H7725"\w* \w dieux|strong="H3068"\w* !”  
\q2 car \w c|strong="H1697"\w*'\w est|strong="H3068"\w* \w en|strong="H3068"\w* \w toi|strong="H3068"\w* \w que|strong="H1697"\w* l'orphelin \w trouve|strong="H3068"\w* \w la|strong="H3068"\w* \w miséricorde|strong="H3068"\w*. »   
\b  
\q1
\v 4 « \w Je|strong="H3068"\w* guérirai \w leur|strong="H3027"\w* égarement.  
\q2 \w Je|strong="H3068"\w* \w les|strong="H3027"\w* aimerai \w de|strong="H3027"\w* \w plein|strong="H5750"\w* gré ;  
\q2 car \w ma|strong="H3467"\w* colère s'\w est|strong="H3027"\w* détournée d'\w eux|strong="H3027"\w*.   
\q1
\v 5 \w Je|strong="H3068"\w* \w serai|strong="H3588"\w* \w comme|strong="H7725"\w* \w la|strong="H7725"\w* \w rosée|strong="H7725"\w* \w pour|strong="H3588"\w* \w Israël|strong="H3588"\w*.  
