\v 55  \w But|strong="H3808"\w* \w if|strong="H1961"\w* \w you|strong="H6440"\w* \w do|strong="H5869"\w* \w not|strong="H3808"\w* \w drive|strong="H3423"\w* \w out|strong="H3423"\w* \w the|strong="H6440"\w* \w inhabitants|strong="H3427"\w* \w of|strong="H3427"\w* \w the|strong="H6440"\w* \w land|strong="H6440"\w* \w before|strong="H6440"\w* \w you|strong="H6440"\w*, \w then|strong="H1961"\w* \w those|strong="H1992"\w* \w whom|strong="H1992"\w* \w you|strong="H6440"\w* allow \w to|strong="H1961"\w* \w remain|strong="H3427"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w irritants|strong="H7899"\w* \w in|strong="H3427"\w* \w your|strong="H5921"\w* \w eyes|strong="H5869"\w* \w and|strong="H5869"\w* \w thorns|strong="H6796"\w* \w in|strong="H3427"\w* \w your|strong="H5921"\w* \w side|strong="H6654"\w*, \w and|strong="H5869"\w* \w will|strong="H1961"\w* \w cause|strong="H6887"\w* \w you|strong="H6440"\w* \w trouble|strong="H6887"\w* \w in|strong="H3427"\w* \w the|strong="H6440"\w* \w land|strong="H6440"\w* \w where|strong="H5921"\w* \w you|strong="H6440"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w living|strong="H3427"\w*.  
