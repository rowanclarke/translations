\id ZEP - Biblica® Open God’s Word in Contemporary Chichewa 2016 
\h ZEFANIYA 
\toc1 Zefaniya 
\toc2 Zefaniya 
\toc3 Zef 
\mt1 Zefaniya 
\c 1  
\p  
\v 1 Yehova anayankhula ndi Zefaniya mwana wa Kusi, mwana wa Gedaliya, mwana wa Amariya, mwana wa Hezekiya pa nthawi ya Yosiya, mwana wa Amoni, mfumu ya Yuda. 
\s1 Yehova Adzaweruza Dziko Lapansi 
\q1  
\v 2 “Ndidzawononga kotheratu zinthu zonse 
\q2 pa dziko lapansi,” 
\q4 akutero Yehova. 
\q1  
\v 3 “Ndidzawononga anthu pamodzi ndi nyama zomwe; 
\q2 ndidzawononga mbalame zamlengalenga 
\q2 ndi nsomba za mʼnyanja. 
\q1 Ndidzawononga anthu oyipa, 
\q2 ndipo ndidzafafaniza mtundu wa anthu pa dziko lonse lapansi,” 
\q4 akutero Yehova. 
\s1 Chenjezo kwa Yuda 
\q1  
\v 4 Ndidzatambasula dzanja langa pa Yuda 
\q2 ndi onse okhala mu Yerusalemu. 
\q1 Ndidzawononga pamalo pano otsalira opembedza Baala, 
\q2 mayina a anthu osapembedza pamodzi ndi ansembe a mafano: 
\q1  
\v 5 amene amagwada pa madenga a nyumba zawo 
\q2 kupembedza zolengedwa zamumlengalenga, 
\q1 amene amagwada ndi kulumbira mʼdzina la Yehova, 
\q2 komanso mʼdzina la Moleki, 
\q1  
\v 6 amene abwerera mʼmbuyo osatsata Yehova, 
\q2 osafunafuna kapena kupempha nzeru kwa Yehova. 
\q1  
\v 7 Khalani chete pamaso pa Ambuye Yehova, 
\q2 chifukwa tsiku la Yehova layandikira. 
\q1 Yehova wakonzekera kupereka nsembe; 
\q2 wapatula iwo amene wawayitana. 
\q1  
\v 8 Pa tsiku la nsembe ya Yehova 
\q2 ndidzalanga akalonga 
\q2 ndi ana aamuna a mfumu 
\q1 ndi onse amene amavala 
\q2 zovala zachilendo. 
\q1  
\v 9 Pa tsiku limenelo ndidzalanga 
\q2 onse amene safuna kuponda pa chiwundo, 
\q1 amene amadzaza nyumba ya ambuye awo 
\q2 ndi chiwawa ndi chinyengo. 
\b  
\q1  
\v 10 “Pa tsiku limenelo,” akutero Yehova, 
\q2 “Kufuwula kwakukulu kudzamveka pa Chipata cha Nsomba, 
\q2 kulira kwa chisoni kuchokera mʼChigawo Chatsopano, 
\q2 ndi phokoso la kugumuka kochokera ku mapiri. 
\q1  
\v 11 Lirani mwachisoni, inu amene mumakhala kumene kuli msika; 
\q2 a malonda anu onse adzapululidwa, 
\q2 ndiponso onse amene ali ndi siliva adzawonongedwa. 
\q1  
\v 12 Pa nthawi imeneyo ndidzafufuzafufuza mu Yerusalemu ndi nyale 
\q2 ndi kulanga onse amene sakulabadira, 
\q2 amene ali ngati vinyo wosakhutchumulidwa, 
\q1 amene amaganiza kuti, ‘Yehova sadzachita chilichonse, 
\q2 chabwino kaya choyipa.’ 
\q1  
\v 13 Chuma chawo chidzafunkhidwa, 
\q2 nyumba zawo zidzagwetsedwa. 
\q1 Adzamanga nyumba, 
\q2 koma osakhalamo; 
\q1 adzadzala minda ya mpesa 
\q2 koma sadzamwako vinyo wake.” 
\s1 Tsiku Lalikulu la Yehova 
\q1  
\v 14 Tsiku lalikulu la Yehova layandikira, 
\q2 layandikira ndipo lifika msanga. 
\q1 Tamverani! Kulira kwa pa tsiku la Yehova kudzakhala kowawa, 
\q2 ngakhale munthu wolimba mtima adzalira kwambiri. 
\q1  
\v 15 Tsiku limenelo lidzakhala la ukali, 
\q2 tsiku losautsa ndi lomvetsa chisoni, 
\q1 tsiku la mavuto ndi la chiwonongeko, 
\q2 tsiku la mdima ndi lachisoni, 
\q2 tsiku la mitambo ndi la mdima wandiweyani. 
\q1  
\v 16 Tsiku loliza lipenga ndi la mfuwu wankhondo, 
\q2 tsiku la kugwa kwa mizinda yotetezedwa 
\q2 ndi nsanja za pa ngodya. 
\q1  
\v 17 Ndidzabweretsa msautso pa anthu 
\q2 ndipo adzayenda ngati anthu osaona, 
\q2 chifukwa achimwira Yehova, 
\q1 magazi awo adzamwazika ngati fumbi 
\q2 ndi mnofu wawo ngati ndowe. 
\q1  
\v 18 Ngakhale siliva wawo kapena golide wawo 
\q2 sadzatha kuwapulumutsa 
\q2 pa tsiku la ukali wa Yehova. 
\q1 Dziko lonse lapansi lidzanyeka 
\q2 mʼmoto wa nsanje yake 
\q1 chifukwa adzakantha modzidzimutsa 
\q2 onse okhala pa dziko lapansi. 
\c 2  
\q1  
\v 1 Sonkhanani pamodzi, sonkhanani pamodzi, 
\q2 inu mtundu wochititsa manyazi, 
\q1  
\v 2 isanafike nthawi yachiweruzo, 
\q2 nthawi yanu isanawuluke ngati mungu, 
\q1 usanakufikeni mkwiyo woopsa wa Yehova, 
\q2 tsiku la ukali wa Yehova lisanafike pa inu. 
\q1  
\v 3 Funafunani Yehova, inu nonse odzichepetsa a mʼdziko, 
\q2 inu amene mumachita zimene amakulamulani. 
\q1 Funafunani chilungamo, funafunani kudzichepetsa; 
\q2 mwina mudzatetezedwa 
\q2 pa tsiku la mkwiyo wa Yehova. 
\s1 Za Afilisti 
\q1  
\v 4 Gaza adzasiyidwa 
\q2 ndipo Asikeloni adzasanduka bwinja. 
\q1 Nthawi yamasana Asidodi adzakhala wopanda anthu 
\q2 ndipo Ekroni adzazulidwa. 
\q1  
\v 5 Tsoka inu okhala mʼmbali mwa nyanja, 
\q2 inu mtundu wa Akereti; 
\q1 mawu a Yehova akutsutsa 
\q2 iwe Kanaani, dziko la Afilisti. 
\q1 “Ndidzakuwononga 
\q2 ndipo palibe amene adzatsale.” 
\b  
\q1  
\v 6 Dziko la mʼmbali mwa nyanja, kumene kumakhala Akereti, 
\q2 lidzakhala malo a abusa ndi la makola a nkhosa. 
\q1  
\v 7 Malowa adzakhala a anthu otsala a nyumba ya Yuda; 
\q2 adzapezako msipu. 
\q1 Nthawi ya madzulo adzagona 
\q2 mʼnyumba za Asikeloni. 
\q1 Yehova Mulungu wawo adzawasamalira; 
\q2 adzabwezeretsa mtendere wawo. 
\s1 Za Mowabu ndi Amoni 
\q1  
\v 8 “Ndamva kunyoza kwa Mowabu 
\q2 ndi chipongwe cha Amoni, 
\q1 amene ananyoza anthu anga 
\q2 ndi kuopseza kuti alanda dziko lawo. 
\q1  
\v 9 Choncho, pali Ine Wamoyo,” 
\q2 akutero Yehova Wamphamvuzonse, Mulungu wa Israeli, 
\q1 “Ndithu, Mowabu adzasanduka ngati Sodomu, 
\q2 Amoni adzasanduka ngati Gomora; 
\q1 malo a zomeramera ndi maenje a mchere, 
\q2 dziko la bwinja mpaka muyaya. 
\q1 Anthu anga otsala adzawafunkha; 
\q2 opulumuka a mtundu wanga adzalandira dziko lawo.” 
\b  
\q1  
\v 10 Ichi ndi chimene adzalandire chifukwa cha kunyada kwawo, 
\q2 chifukwa chonyoza ndi kuchitira chipongwe anthu a Yehova Wamphamvuzonse. 
\q1  
\v 11 Yehova adzawachititsa mantha kwambiri 
\q2 pamene adzawononga milungu yonse ya mʼdzikomo. 
\q1 Ndipo mitundu ya anthu pa dziko lonse idzamulambira, 
\q2 uliwonse ku dziko la kwawo. 
\s1 Za Kusi 
\q1  
\v 12 “Inunso anthu a ku Kusi, 
\q2 mudzaphedwa ndi lupanga.” 
\s1 Za Asiriya 
\q1  
\v 13 Yehova adzatambasulira dzanja lake kumpoto 
\q2 ndi kuwononga Asiriya, 
\q1 kusiya Ninive atawonongekeratu 
\q2 ndi owuma ngati chipululu. 
\q1  
\v 14 Nkhosa ndi ngʼombe zidzagona pansi kumeneko, 
\q2 pamodzi ndi nyama zakuthengo za mtundu uliwonse. 
\q1 Akadzidzi a mʼchipululu ndi akanungu 
\q2 adzakhala pa nsanamira zake. 
\q1 Kulira kwawo kudzamveka mʼmazenera, 
\q2 mʼmakomo mwawo mudzakhala zinyalala zokhazokha, 
\q2 nsanamira za mkungudza zidzakhala poonekera. 
\q1  
\v 15 Umenewu ndiye mzinda wosasamala 
\q2 umene kale unali wotetezedwa. 
\q1 Unkanena kuti mu mtima mwake, 
\q2 “Ine ndine, ndipo palibenso wina wondiposa.” 
\q1 Taonani lero wasanduka bwinja, 
\q2 kokhala nyama zakutchire! 
\q1 Onse owudutsa akuwunyoza 
\q2 ndi kupukusa mitu yawo. 
\c 3  
\s1 Tsogolo la Yerusalemu 
\q1  
\v 1 Tsoka kwa mzinda wa anthu opondereza, 
\q2 owukira ndi odetsedwa! 
\q1  
\v 2 Sumvera aliyense, 
\q2 sulandira chidzudzulo. 
\q1 Sumadalira Yehova, 
\q2 suyandikira pafupi ndi Mulungu wake. 
\q1  
\v 3 Akuluakulu ake ali ngati mikango yobuma, 
\q2 olamulira ake ndi olusa ngati mimbulu ya nthawi ya madzulo, 
\q2 zimene pofika mmawa sizisiya chilichonse. 
\q1  
\v 4 Aneneri ake ndi odzikuza; 
\q2 anthu achinyengo. 
\q1 Ansembe ake amadetsa malo opatulika 
\q2 ndipo amaphwanya lamulo. 
\q1  
\v 5 Yehova amene ali pakati pawo ndi wolungama; 
\q2 Iye salakwa. 
\q1 Tsiku ndi tsiku amaweruza molungama, 
\q2 ndipo tsiku lililonse salephera, 
\q2 komabe ochita zoyipa sachita manyazi nʼkomwe. 
\q1  
\v 6 “Ndachotseratu mitundu ya anthu; 
\q2 ndagwetsa malinga awo. 
\q1 Ndipo sindinasiye ndi mmodzi yemwe mʼmisewu mwawo, 
\q2 popanda aliyense wodutsa. 
\q1 Mizinda yawo yawonongedwa; 
\q2 palibe aliyense adzatsalemo. 
\q1  
\v 7 Ndinati, 
\q2 ‘Ndithudi, anthu a mu mzindawu adzandiopa 
\q2 ndi kumvera kudzudzula kwanga!’ 
\q1 Ndipo sindidzawononga nyumba zawo, 
\q2 kapena kuwalanganso. 
\q1 Koma iwo anali okonzeka 
\q2 kuchita mwachinyengo zinthu zonse zimene amachita. 
\q1  
\v 8 Choncho mundidikire,” akutero Yehova, 
\q2 “chifukwa cha tsiku limene ndidzaperekera umboni. 
\q1 Ndatsimikiza kusonkhanitsa pamodzi mitundu ya anthu, 
\q2 kusonkhanitsa maufumu 
\q1 ndi kutsanulira ukali wanga pa iwo; 
\q2 mkwiyo wanga wonse woopsa. 
\q1 Dziko lonse lidzatenthedwa 
\q2 ndi moto wa mkwiyo wa nsanje yanga. 
\b  
\q1  
\v 9 “Pamenepo ndidzayeretsa milomo ya anthu a mitundu yonse 
\q2 kuti anthu onsewo ayitane dzina la Yehova 
\q2 ndi kumutumikira Iye pamodzi. 
\q1  
\v 10 Kuchokera kutsidya kwa mitsinje ya ku Kusi 
\q2 anthu anga ondipembedza, omwazikana, 
\q2 adzandibweretsera zopereka. 
\q1  
\v 11 Tsiku limenelo simudzachita manyazi 
\q2 chifukwa cha zoyipa zonse munandichitira, 
\q1 popeza ndidzachotsa onse mu mzinda uwu 
\q2 amene amakondwera chifukwa cha kunyada kwawo. 
\q1 Simudzakhalanso odzikuza 
\q2 mʼphiri langa lopatulika. 
\q1  
\v 12 Koma ndidzasiya pakati panu 
\q2 anthu ofatsa ndi odzichepetsa, 
\q2 amene amadalira dzina la Yehova. 
\q1  
\v 13 Aisraeli otsala sadzachitanso zolakwika; 
\q2 sadzayankhulanso zonama, 
\q2 ngakhale chinyengo sichidzatuluka mʼkamwa mwawo. 
\q1 Adzadya ndi kugona 
\q2 ndipo palibe amene adzawachititse mantha.” 
\b  
\q1  
\v 14 Imba, iwe mwana wamkazi wa Ziyoni; 
\q2 fuwula mokweza, iwe Israeli! 
\q1 Sangalala ndi kukondwera ndi mtima wako wonse, 
\q2 iwe mwana wamkazi wa Yerusalemu! 
\q1  
\v 15 Yehova wachotsa chilango chako, 
\q2 wabweza mdani wako. 
\q1 Yehova, Mfumu ya Israeli, ali pakati pako; 
\q2 sudzaopanso chilichonse. 
\q1  
\v 16 Pa tsiku limenelo adzanena kwa Yerusalemu kuti, 
\q2 “Usaope, iwe Ziyoni; 
\q2 usafowoke. 
\q1  
\v 17 Yehova Mulungu wako ali pakati pako, 
\q2 ali ndi mphamvu yopulumutsa. 
\q1 Adzakondwera kwambiri mwa iwe, 
\q2 adzakukhalitsa chete ndi chikondi chake, 
\q2 adzayimba mokondwera chifukwa cha iwe.” 
\b  
\q1  
\v 18 “Ndidzakuchotserani zowawa 
\q2 za pa zikondwerero zoyikika; 
\q2 nʼzolemetsa ndi zochititsa manyazi. 
\q1  
\v 19 Taonani, nthawi imeneyo ndidzathana ndi 
\q2 onse amene anakuponderezani; 
\q1 ndidzapulumutsa olumala 
\q2 ndi kusonkhanitsa amene anamwazika. 
\q1 Ndidzawayamikira ndi kuwachitira ulemu 
\q2 mʼdziko lililonse mmene anachititsidwa manyazi. 
\q1  
\v 20 Pa nthawi imeneyo ndidzakusonkhanitsani; 
\q2 pa nthawi imeneyo ndidzakubweretsani ku mudzi kwanu. 
\q1 Ndidzakuyamikirani ndi kukuchitirani ulemu 
\q2 pakati pa mitundu ya anthu a dziko lapansi 
\q1 pamene ndidzabwezeretsa mtendere wanu 
\q2 inu mukuona,” 
\q4 akutero Yehova.