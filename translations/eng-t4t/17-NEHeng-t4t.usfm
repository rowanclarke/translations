\b  
\pi1
\v 45 \w Also|strong="H1121"\w* 138 temple \w gatekeepers|strong="H7778"\w* \w from|strong="H1121"\w* \w the|strong="H7967"\w* clans \w of|strong="H1121"\w* \w Shallum|strong="H7967"\w*, Ater, \w Talmon|strong="H2929"\w*, \w Akkub|strong="H6126"\w*, \w Hatita|strong="H2410"\w*, \w and|strong="H3967"\w* \w Shobai|strong="H7630"\w* returned.   
\b  
\pi1
\v 46 \w Temple|strong="H5411"\w* workers \w who|strong="H1121"\w* returned \w were|strong="H1121"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* these \w men|strong="H1121"\w*:  
\li2 Ziha, Hasupha, Tabbaoth,   
\li2
