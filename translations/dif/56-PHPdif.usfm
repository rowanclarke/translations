\id PHP
\ide UTF-8
\h Philippalani
\toc1 Pauluni Dakani jaura Philippalani
\toc2 Philippalani
\toc3 Philip
\mt1 Pauluni Dakani jaura Philippalani.
\c 1
\p 
\v 1 Paululu ja Timotheulu, Jesuni Christuni mili, kulikirini pratjanani Christungu Jesungu tana Philippungu ngamai, najinajibanietjani ja marangokijiribamalinietjani jela.
\p 
\v 2 Manjula jurangunto nganaiatimai, ja murla Goda ngaianani Ngaperandru ja Kapara Jesu Christungundru!
\lit (Dakani jaura G. D. 22. Trinitatis.)
\p 
\v 3 Ngato Goda ngakani jurakokala wapaia, jeruntjaia pota ngato jurana ngundrai,
\p 
\v 4 Ja ngani milingeru ngatjinali ngakanali jurangu pratjanandru mankinali ngatjiai,
\p 
\v 5 Jurani jelarinandru ngantjani jauraia, ditji ngoperandru kararielu,
\p 
\v 6 Ja ngato morlalu ngundrai, Nulupini, Nulia ninaia ngankana ngumu jurangu wonina wonti, ninaia bakana mudala nganai Jesuni Christuni ditjielu.
\p 
\v 7 Jenia talku nganai ngakangu, jeruja jurangu pratjanandru ngundrala, ngangau ngato jurana pratjana ngakangu ngarani ngamalkai, ngangau jura dupudupuni ngakanani ja jurajuralkaterini ja morlalu kuranani ngantjani jaurandru, ngakani manjulaia jelalimaninietja nganai.
\p 
\v 8 Ngangau Goda ngakani tinkari ngankanietja nganai, worderu wolkareli ngani nganai jurangu Jesuni Christuni ngarani.
\p 
\v 9 Ja ngani ngatjiai, jurani ngantjana morla ja morla poto pirna pantjinanto ngujamanani ja milkila pantjinani,
\p 
\v 10 Jura wontjananto mina morla ngumu nganai, ngangau jura talku ja madlentji pani nganananto Christuni ditjini,
\p 
\v 11 Talkulaia tandra manamiri, nauja Jesu Christungundru pantjiai Godaia pirnalani ja jurakokanani.
\b
\p 
\v 12 Ngato ngantjai jura ngujamananto, ngatata worajai, worderu pirna ngakani ngamanandru ngantjani jaura marurina warai,
\p 
\v 13 Jeruja dupudupu ngakani Christungundru tinkari pantjina warai julja pungani ja tanangu nguru pratjanani;
\p 
\v 14 Ja ngatata marapujeli Kaparani, ngakani dupudupundru murlali pantjina warai, wontjai, morla pirna ja japangurujeli jaura kaukaubala.
\p 
\v 15 Palpali bakana kirinajinandru ja jatamalinandru; palpali ngumu ngundranali Christungundru kaukaubai.
\p 
\v 16 Tanali Christus kaukaubai mudlawariwarieli wata talku, ngangau tanali ngundrai ketjaketjana kurala ngakani dupudupuni;
\p 
\v 17 Tanalipini ngantjanali, ngangau tana milkila, ngani ninkida ngamala wapaia ngantjani jauraia jurajuralkanandru.
\p 
\v 18 Worderu? Mangini pilki ja pilkini tanali Christus kaukaubanani, tjautjaujeli kara talkujeli kara, nunkangundru ngato mankila wapaia ja mankila nganai,
\p 
\v 19 Ngangau ngani milkila, jenia ngakangu tepia pantjila nganai jurani ngatjinandru, ja Jesuni Christuni Jaolaia jinkinandru.
\p 
\v 20 Worderu ngani jertapateriai ja wolkareli kalkai, ngani panilani nintali pantjila nganai, a‐ai, japanguru pirnali, worderu milingeru jeruja bakana karari, Christus pirna pantjinanto ngakangu palkuni, tepieli kara, narieli kara.
\p 
\v 21 Ngangau tepi ngakangu Christus nganai, ja palina morla manina;
\p 
\v 22 Ngani morla tepi ngamanani palkuni, jeruja ngakangu ngankanaia tandra parai; ja mina ngato kalkalkananto ngato wata kaukaubai.
\p 
\v 23 Pudlalipini ngana jeniai: Ngato ngantjai puntila ja Christungu jela ngamala, jenia morla ngumu nganai;
\p 
\v 24 Windri palkuni ngamana morla ngumu nganai jurangu.
\p 
\v 25 Ja jenia morlalu ngundrana ngani milkila, ngani ngamala nganai jurani morlalu ngundranaia ja mankinaia;
\p 
\v 26 Ngangau jurani jurakokaterina pirna nganananto Christungu Jesungu ngakangu, ngani nakaldra jurangu wokarala tikanani.
\p 
\v 27 Christuni ngantjani jaurani pankinani wirarianau, ngato wokaranani ja jurana najinani kara, worita ngamanani jurangundru ngaranani kara, jura jaola kulnuni terkala wapaia, ja mungara kulnujeli tirila wapaia ngantjani jauraia morlalu ngundranandru;
\p 
\v 28 Ja jura panilani japali pantjinanto talpalandru, jenia tanangu tintaterinaia malka nganai, ja jurangu murlaia malka, ja jenia Godandru;
\p 
\v 29 Ngangau Nulia jurangu manjula jinkina warai Christungundru, wata windri nunkangu morlalu ngundrananto, a‐ai, bakana nunkangundru ketjaketjananto.
\p 
\v 30 Jeruja jura ninapini tirimalina ngamalkai, ninaia jura ngakangu najina wonti, ja karari ngakangundru ngarai.
\c 2
\p 
\v 1 Kurukurubana Christungu, ja ngantjanaia ngankalkana, ja Jaolaia jelaribana, ja ngaraia ngantjana, ja kalumiltjamiltjarina jurangu ngananani,
\p 
\v 2 Jeruja mankini ngakani manamiri ngankanau, jura manukulnuni nganananto, ngantjana kulnuni, mungara kulnuni, ngundrana kulnuni,
\p 
\v 3 Wata mudlawariwarini ja wata jurakokaterinani, a‐ai, waka ngundraterinali,
\p 
\v 4 Kulnujeli nguruni morla pirna ngundrananto muntali.
\lit (Dakani jaura Palma ditjini.)
\p 
\v 5 Jura jeruja ngundranau worderu Jesu Christulu bakana.
\p 
\v 6 Naupini munta Goda jeribaka nganana wonti, ja jenia wata watawatali ngundrana wonti manila Goda jeribaka ngamala,
\p 
\v 7 A‐ai, Nauja munta kala ngankaterina wonti, ja mili jeribaka pantjina wonti, ja kana jeribaka dankana wonti, ja kana mudla jeribaka mankamankana wonti.
\p 
\v 8 Nauja munta waka ngankaterina wonti, ja wodatarana ngamana wonti narielu, kau, kunarkuja narielu.
\p 
\v 9 Jendrangundruja Godali ninaia bakana pirna ngankana wonti, ja ninaia tala kulno jinkina wonti, nauja morla pirna nganai talani warupotuni.
\p 
\v 10 Jesuni talani pantja warupoto buruna ngarinanto pariwilpani ja mitani ja mitani ngarinalu,
\p 
\v 11 Ja tali warupotujeli dikananto: „Jesus Christus Kapara nganai Godaia Ngaperaia pirnalaia.“
\b
\p 
\v 12 Jeruja, kamaneli ngantjalu, worderu jura milingeru pankina warai, wata windri ngani jurangu jela ngamanani, a‐ai, bakana karari morla, ngani worita ngananani, ngankanau jura tepi pantjinanto japali ja ngarranali.
\p 
\v 13 Ngangau Goda nganai, Nulia jurangu ngankai jertapaterina ja ngankana, nunkani ngumulandru.
\p 
\v 14 Pratjana ngankanau buljubulju panieli ja mangangankana panieli,
\p 
\v 15 Jura madlentji pani ja kulikiri Godaia kupa talku pantjinanto nguja kuntikuntini ja tjikatjikani terti, tanangu terti jura pariwilpala praitji jeribaka mitani mintjinanto;
\p 
\v 16 Ja tepia jaura jura ngamalkananto ngakani pirnalaia Christuni ditjini, ngani wata baku mindrinanto ja wata baku ngankananto.
\p 
\v 17 Ja tanali ngana bakana tapani poto ngumu nanganani poto ngumuni, ja juranaia morlalu ngundranaia Priesta ngamalkijiribanani, jeruja ngani mankiai, ja jurangu ngumula ngatjiai.
\p 
\v 18 Jeruja bakana jura mankianau ja ngakangu ngumula ngatjianau.
\p 
\v 19 Ngato kalkai Kapara Jesungu, Timotheus wolja jurangu jinpala, bakana ngani burkanguru pantjinanto, ngato ngaranani, worderu jurangu nganai.
\p 
\v 20 Ngangau ngato wata kulno ngamalkai, nulu ngakangu jela kulnuni ngundrai, nulu ngarali jurana manujeli ngundrai.
\p 
\v 21 Ngangau tanali pratjana tanani poto wontiai, ja wata jenia, mina Christuni Jesuni nganai.
\p 
\v 22 Jura milkila, nauja talku nganai, worderu kupa ngaperani, jeruja nauja ngakangu jela mili nganana warai ngantjani jaurani.
\p 
\v 23 Ngato ngundrai ninaia wolja jinpala, ngato matja ngarana warai mina ngakangu parai.
\p 
\v 24 Ngato morlalu ngundrai Kaparani, ngani bakana munta wolja jurangu wokarala nganai.
\p 
\v 25 Ngato ngundrana warai jenia morla ngumu Epaphroditus, ngatata, ja jelangankanietja, ja jelajuljala, mandra jurani, ja ngakani ngamalkijiribani mili, jurangu jinpala.
\p 
\v 26 Ngangau nauja wolkareli nganana warai jurangu pratjanaia, ja ngaurongauro nganana warai, ngangau jura matja ngarana, nauja muntja parana warai.
\p 
\v 27 Ja kantji nauja muntja parana warai narini kupiri, ja Godali nunkangu kalumiltjamiltjarina warai; ja wata windri nunkangu, a‐ai, bakana ngakangu, ngato wata ngaurongauro kulno ngaurongauro kulnuni ngamalkananto.
\p 
\v 28 Morla nurujeli ngato ninaia jinpana warai, jura ninaia najinani, jura nakaldra mankinanto, ja ngani ngaurongauro kulno morla ngalje ngamalkananto.
\p 
\v 29 Jeruja ninaia Kaparani patanau mankina pirnali, ja jenipara materi pirna ngundranau!
\p 
\v 30 Ngangau nauja Christuni ngankanandru narini karakararina warai, ngangau nulia tepia nunkani waka ngundrana warai, nulia jurani pirini ngakangu poto jinkinanto.
\c 3
\p 
\v 1 Morla, ngatata worajai, Kaparani mankianimai! Ngani wata junkariai jurangu milingeru ninalu dakala, ngangau jenia jurana ngurunguru ngankai.
\p 
\v 2 Kintala worana najianau, ngankanietja madlentji najianau, tjikatjika karuwalila najianau!
\p 
\v 3 Ngangau ngaiana karuwalila nganai, ngaiana Godaia Jaolali wodatarana ngamai, ja Christungu Jesungu jurakokateriai, ja palkundru wata pirna ngundrai,
\p 
\v 4 Ngato bakana palkundru pirna ngundraterinanto. Kulnujeli ngundraterinani, nau palkundru pirna nganai, ngani morla,
\p 
\v 5 Ngani ditji mara wora ja parkulani karuwalila pantjina wonti, Israel mili wolarandru, Benjamini mardundru, Hebräala Hebräalandru, jirijiribani jaurandru Pharisäiala;
\p 
\v 6 Manabakapirnandru mili wolaraia tirikaripaterinietja, talkulandru jirijiribani jaurani madlentji pani.
\p 
\v 7 Mina ngakangu ngumu nganana wonti, jenia ngato Christungundru madlentji ngundrana wonti.
\p 
\v 8 Kau, morlalu ngato warupoto madlentji ngundrai Christuni Jesuni ngakanaia Kaparaia ngujamana pirnandru, nunkangundru ngato jenia pratjana tintana wonti, ja jenia darpani poto ngundrai, ngato Christus maninanto.
\p 
\v 9 Ja Nulia ngana mankamankananto nunkangu, wata talkula ngakani ngamalkanani, ninaia jirijiribani jaurandru, a‐ai, ninaia morlalu ngundranali Christungu, ninaia talkula Godandru, morlalu ngundranaia,
\p 
\v 10 Ninaia ngujamala, ja nunkanaia tepi terkakanaia ngurula, ja nunkanaia ketjaketjanaia jela ngamani, ngani nunkani narini jeribaka pantjinanto,
\p 
\v 11 Ngani jiritjinaia mandurinanto narindru.
\p 
\v 12 Wata ngato ninaia matja patana warai, ja matja talku nganai kara, a ai, ngani nunkangu mindrindiai, ngato ninaia patananto, ngangau bakana Jesu Christujeli ngana patana wonti.
\p 
\v 13 Ngatata worajai, ngato muntali wata ngundrai, ngato ninaia matja patana,
\p 
\v 14 Kulno ngani jatai: Ngani kuritarai mina ngakangu ngadani parai, ja ngani ngutateriai nunkangu, mina ngakangu ngopera parai, ja mindriai malkaia, Godaia karkanaia kalalu ngankani pirnaia mirindru Jesungu Christungu.
\p 
\v 15 Worderuntja matja talku nganai, ngaiana jeruja ngundrananto. Ja jura minakulnuni pilki ngundranani, jeruja Godali jurangu bakana ninaia tinkari ngankala nganai.
\p 
\v 16 Windri ngaiana nunkangu, mina ngaiana matja patana, wirarinanto.
\lit (Dakani jaura G. D. 23. Trinitatis.)
\p 
\v 17 Ngatata worajai, bakana jura ngakani karipaterini pantjianau, ja tanangu najianau, tana jeruja wirariai, worderu jura ngaianingu mudlamalka ngamalkai.
\p 
\v 18 Ngangau marapu wirariai, tanangundru ngani jurangu pota marapu jatana wonti, ja karari jatai milkigildieli, tana Christuni kunarkuja talpala nganai.
\p 
\v 19 Tanani mudani tintaterini nganai, tanani Goda mandra nganai, tanani pirnala tanani ninta nganai, tanali windri mitalani ngundrai.
\p 
\v 20 Ngangau nauta ngura ngaianani nganai pariwilpani, nakanika ngaiana bakana Kulkanipirna kalkai, ninaia Kapara Jesus Christus,
\p 
\v 21 Nulia ngaianani palku karitjimalkala nganai, nunkani pirnalaia palkuni jeribaka nunkani ngankana pirnali, nunkanali Nauja ngurunguru nganai, warupoto nunkangu wodatarana ngankala.
\b
\c 4
\p 
\v 1 Jeruja, ngakani ngatata ngantjalu worajai, ngujangujala worajai, mankini ngakani ja pirapira ngakani, ngurunguru terkanau Kaparani, ngantjalu worajai!
\p 
\v 2 Ngato Evodia kurukurubala wapaia, ja ngato Syntyche kurukurubala wapaia, manukulnuni nganala Kaparani.
\p 
\v 3 Kau, ngani bakana jinkangu ngatjiai, ngakani jelalingankanietja talkujai, pudlangu marangokamai, ngangau pudla ngantjani jaurani tirimalina warai, ngakangu ja Clemengu ja ngakani jelalingankanietjani jela, tanani tala tepia dakani jaurani parai.
\lit (Dakani jaura G. D. 4. Advent.)
\p 
\v 4 Mankianimai Kaparani milingeru, ja nakaldra ngani jatai: Mankianimai!
\p 
\v 5 Malti jurani tinkari pantjinanto kanani warupotuni; Kapara karakara nganai.
\p 
\v 6 Wata manujuli ngundranau, a‐ai, potuni warupotuni ngatjinali ja karkanali ja jurakokanali jurani ngundrani Godani ngujamani pantjinanto.
\p 
\v 7 Ja Godaia murla, nauja morla pirna nganai tjuruni warupotuni, jurani ngara ja ngundrana ngamalkala nganai Christungu Jesungu.
\b
\p 
\v 8 Morla, ngatata worajai, mina morlalu nganai, mina ngumu nganai, mina talku nganai, mina ninta nguru nganai, mina ngalkujeli nganai, mina ngumu nganai ngarala, ngumula kara jurakokana kara ngananani, jenia ngundranau!
\p 
\v 9 Mina jura kiririna warai ja patana warai ja ngarana warai ja najina warai ngakangu, jenia ngankanau! Jeruja murlaia Goda jurangunto nganala nganai.
\p 
\v 10 Ngato pirna mankina warai Kaparani, ngangau jura karari nakaldra kuljarina warai ngana manujeli ngundrala; jura matja ngundrana warai, ja ditjieli jurana ngandrawalkana warai.
\p 
\v 11 Jenia ngani wata jatai, ngangau ngani wangiwangi, a‐ai, ngani kiririna warai murlali nganala worderu ngani ngamai.
\p 
\v 12 Ngato bakana ngujamai wakawaka nganala, ngato bakana ngujamai poto pirna nganala; paruparu ja warupotuni ngani kiri nganai, jerto nganala ja maua nganala, poto pirna nganala ja wangiwangi nganala.
\p 
\v 13 Ngani ngurunguru nganai warupotuni nunkangu, Nulia ngana ngurunguru ngankai.
\p 
\v 14 Jura ngumu ngankana warai, ngangau jura ngakani jeninani ngujangujala ngundrana warai.
\p 
\v 15 Jura bakana munta milkila, Philippala worajai, ngantjani jauraia ngoperandru, ngani Macedoniandru matja puntina, wata mili wolara pilkieli ngakangu jela puntibana warai jinkinandru ja maninandru, windri juralu.
\p 
\v 16 Jura bakana Thessalonichani wata windri pota kulno, a‐ai, pota mandru ngakangu wangiwangini jinpanala.
\p 
\v 17 Wata ngato poto wontiai, a‐ai, windri ngato tandra wontiai, nauja punkai jurani windamanani.
\p 
\v 18 Ngato pratjana manina warai, ja ngato morla ngamalkai. Ngato manamiri ngamalkai, ngato Epaphroditungundru jurani poto maninala, panimani kuli ngumu, poto ngumu pirna, ninaia Godali ngantjai.
\p 
\v 19 Ngakani Godali jurani wangiwangila manamiri ngankala nganai nunkani poto pirnandru pirnalani Christungu Jesungu.
\p 
\v 20 Godani ngaiananani ja Ngaperani pirnala nganaiatimai ngurali! Amen.
\p 
\v 21 Mandurini jaura jinkianau kana kulikirini pratjanani Christungu Jesungu. Mandurini jaura jurangu jinpai ngatatajeli, tana ngakangu jela nganai.
\p 
\v 22 Mandurini jaura kana kulikiri pratjanali jurangu jinpai, pilki tanali Cäsarani pungandru.
\p 
\v 23 Kaparaia Jesuni Christuni manjula jurangu jaolani nganaiatimai! Amen. 
