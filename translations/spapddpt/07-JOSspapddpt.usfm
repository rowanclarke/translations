\v 3 \w Porque|strong="H3588"\w* \w Moisés|strong="H4872"\w* \w dio|strong="H5414"\w* \w heredades|strong="H5159"\w* \w a|strong="H3068"\w* las \w dos|strong="H8147"\w* \w tribus|strong="H4294"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* otra media \w tribu|strong="H4294"\w* \w en|strong="H8432"\w* \w la|strong="H3588"\w* otra \w parte|strong="H2677"\w* \w del|strong="H2677"\w* \w Jordán|strong="H3383"\w*. \w A|strong="H3068"\w* \w los|strong="H3588"\w* \w levitas|strong="H3881"\w* \w no|strong="H3808"\w* les \w dio|strong="H5414"\w* \w herencia|strong="H5159"\w* \w entre|strong="H8432"\w* ellos.  
\v 4 \w Pues|strong="H3588"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w José|strong="H3130"\w* formaron \w dos|strong="H8147"\w* \w tribus|strong="H4294"\w*: \w Manasés|strong="H4519"\w* \w y|strong="H3588"\w* Efraín. \w No|strong="H3808"\w* \w dieron|strong="H5414"\w* porción \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w levitas|strong="H3881"\w*, \w sino|strong="H3588"\w* solo \w ciudades|strong="H5892"\w* \w para|strong="H3588"\w* vivir, \w con|strong="H3588"\w* sus pastizales \w para|strong="H3588"\w* sus \w ganados|strong="H4735"\w* \w y|strong="H3588"\w* sus rebaños.  
