\s1 A tour of Galilee  
\p
\v 23 \w Jesus|strong="G2532"\w* \w went|strong="G2532"\w* \w about|strong="G1722"\w* \w all|strong="G3956"\w* \w Galilee|strong="G1056"\w*, \w teaching|strong="G1321"\w* \w in|strong="G1722"\w* \w their|strong="G2532"\w* \w synagogues|strong="G4864"\w* \w and|strong="G2532"\w* \w proclaiming|strong="G2784"\w* \w the|strong="G1722"\w* \w Gospel|strong="G2098"\w* \w of|strong="G2532"\w* \w the|strong="G1722"\w* Kingdom, \w and|strong="G2532"\w* \w healing|strong="G2323"\w* \w every|strong="G3956"\w* \w disease|strong="G3119"\w* \w and|strong="G2532"\w* \w every|strong="G3956"\w* illness \w among|strong="G1722"\w* \w the|strong="G1722"\w* \w people|strong="G2992"\w*.  
