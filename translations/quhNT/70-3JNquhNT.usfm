\id 3JN - South Bolivia Quechua NT -Bolivia 2011 (DBL -2013) 
\h 3 JUAN 
\toc1 Tercera Carta de San Juan 
\toc2 3 Juan 
\toc3 3 Jn 
\mt2 TERCERA CARTA DEL APOSTOL 
\mt1 SAN JUAN 
\c 1  
\p  
\v 1 Munaska hermano Gayo, chekatapuni munacuspa kelkamuyqui, amigoyqui, Cristoj cachan. 
\p  
\v 2 Munaska hermanóy, Diosmanta mañacuni kanta allillan risunanpaj tucuy imapi allillanpis caricushanayquipaj. Yachani causayniyqui Cristowan allin caskanta.  
\v 3 Mayta cusicorkanitaj Cristopi jap'icojcuna chayamojtincu. Willawarkancu Diospa cheka niskasninta casushaskayquita camachiwaskanchejmanjina causashaskayquitawan.  
\v 4 Tucuy imamanta astawanka cusicuni uyarispa Cristopi wawasniy cheka niskanmanjinapuni causashaskancuta. 
\p  
\v 5 Munaska hermanóy, allinta ruwanqui forastero hermanostapis yanapaspa.  
\v 6 Tantaska hermanosman\f + \fr 1:6 \ft Literal: iglesia.\f* willarkancu munacuywan paycunata yanapaskayquimanta. Diospaj llanc'ajcuna caskancuraycu yanapariy ruwanayquimanjina, paycunata allin rinanpaj.  
\v 7 Jesucristomanta willaranancupaj llojserkancu. Chaywanpis waj llajtayojcunamantaka manapuni imatapis causanancupaj jap'ejchu cancu.  
\v 8 Chayraycu chayjina runastaka yanaparinanchej paycunawan cusca Diospa cheka niskanpi llanc'aj-masis cananchejpaj. 
\p  
\v 9 Cristopi caj tantaska hermanosman cay imasmanta kelkarkani. Diotrefesrí paycuna uqhupi curaj cayta maytapuni munan. Nokaycoj niskaycutataj mana casunchu.  
\v 10 Chayraycu jamuspa tantaska hermanosman sut'inchasaj paypa ruwashaskanmanta. Payka sajra imastapuni nokaycumanta parlashan contraycupi llullacuspa. Ni chayllachu. Wasinman mana wajyarkachu watucoj hermanosta. Chaywanpis wajyacuyta munaj hermanosta jarc'ashan ama wajyanancupaj. Tantacuynincumantataj watucoj hermanosta kharkon. 
\p  
\v 11 Munaska hermanóy, sajrata ruwajcunajinaka ama ruwaychu. Manachayrí chekan ruwajcunajinapuni ruway. Chekan cajta ruwajka Diospa cheka wawanmin. Sajra cajta ruwajrí ni imatapis yachanchu Diosmanta. 
\p  
\v 12 Tucuy runas Demetriomanta sumajta parlancu chekan cajta ruwaskanraycu. Chekatapuni ajinata ruwashan. Nokaycupis paymanta sumajta parlaycu ajinata chekanta ruwashaskanraycu. Yachanquitaj willaskaycoka chekapuni caskanta. 
\p  
\v 13 Ashqha imasraj cashan kanman nisunay. Mana munanichu chayta kelkamusuyta,  
\v 14 pisi p'unchaymanta uyapura parlananchejta suyashaskayraycu. 
\p  
\v 15 Allillanpi cacuy Dioswan runaswanpis. Caypi tiyacoj hermanos napaycamusuncu. Kanri jakaypi caj munaska hermanosninchejta sapa ujta napaycapuway.