\v 14 Te \w dongah|strong="H9999"\w* \w anih|strong="H9909"\w* \w te|strong="H9997"\w* \w a|strong="H9909"\w* \w yuu|strong="H0802"\w* \w Zeresh|strong="H2238"\w* \w neh|strong="H9999"\w* \w a|strong="H9909"\w* \w lungnah|strong="H0157"\w* \w boeih|strong="H3605"\w* loh, “\w Thing|strong="H6086"\w* \w dong|strong="H0520"\w* \w sawmnga|strong="H2572"\w* a \w sang|strong="H1364"\w* \w saii|strong="H6213"\w* \w uh saeh\w* \w lamtah|strong="H9999"\w* \w mincang|strong="H1242"\w* \w ah|strong="H9996"\w* \w manghai|strong="H4428"\w* \w te|strong="H9997"\w* \w dawt|strong="H0559"\w*. Te \w phoeiah|strong="H9999"\w* \w Mordekai|strong="H4782"\w* \w te|strong="H0853"\w* \w a|strong="H9909"\w* \w soah|strong="H5921"\w* \w kuiok|strong="H8518"\w* sak uh saeh. Te \w vaengah|strong="H9999"\w* \w buhkoknah|strong="H4960"\w* \w te|strong="H0413"\w* \w manghai|strong="H4428"\w* \w neh|strong="H5973"\w* \w kohoe|strong="H8056"\w* la \w paan|strong="H0935"\w*,” a \w ti|strong="H0559"\w* nah.  
\p \w Ol|strong="H1697"\w* te \w Haman|strong="H2001"\w* \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w* tah a \w voelphoeng|strong="H3190"\w* pah \w tih|strong="H9999"\w* \w thing|strong="H6086"\w* te a \w saii|strong="H6213"\w*.   
\c 6  
\s1 Mordekai A Thangpom  
\p
\v 1 \w Te|strong="H1931"\w* kah \w khoyin|strong="H3915"\w* \w ah|strong="H9996"\w* tah \w manghai|strong="H4428"\w* te a \w ih|strong="H8142"\w* \w hoelh|strong="H5074"\w*. Te \w dongah|strong="H9999"\w* \w khokhuen|strong="H3117"\w* \w olka|strong="H1697"\w* \w poekkoepnah|strong="H2146"\w* \w cabu|strong="H5612"\w* \w te|strong="H0853"\w* \w loh|strong="H0935"\w* \w hamla|strong="H9997"\w* a \w thui|strong="H0559"\w* pah. Te \w vaengah|strong="H9999"\w* \w manghai|strong="H4428"\w* \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w* aka \w tae|strong="H7121"\w* pah ham khaw \w om|strong="H1961"\w* uh.  
\v 2 Te \w vaengah|strong="H9999"\w* \w cingkhaa|strong="H5592"\w* aka \w tawt|strong="H8104"\w*, \w manghai|strong="H4428"\w* \w imkhoem|strong="H5631"\w* \w rhoi|strong="H8147"\w* \w Bigthan|strong="H0904"\w* \w neh|strong="H9999"\w* \w Teresh|strong="H8657"\w* loh \w manghai|strong="H4428"\w* \w Ahasuerus|strong="H0325"\w* \w kut|strong="H3027"\w* \w hlah|strong="H7971"\w* \w thil|strong="H9996"\w* \w ham|strong="H9997"\w* a \w mae|strong="H1245"\w* rhoi vaengah \w Mordekai|strong="H4782"\w* a \w puen|strong="H5046"\w* pah \w tila|strong="H0834"\w* a \w daek|strong="H3789"\w* \w te|strong="H5921"\w* a \w hmuh|strong="H4672"\w*.  
\v 3 Te \w dongah|strong="H9999"\w* \w manghai|strong="H4428"\w* loh, “\w He|strong="H2088"\w* \w dongah|strong="H5921"\w* \w Mordekai|strong="H4782"\w* \w ham|strong="H9997"\w* \w umponnah|strong="H3366"\w* \w neh|strong="H9999"\w* \w lennah|strong="H1420"\w* \w metlam|strong="H4100"\w* a \w saii|strong="H6213"\w*?” a \w ti|strong="H0559"\w* nah.  
\p Te \w vaengah|strong="H9999"\w* \w amah|strong="H9909"\w* taengah aka \w thotat|strong="H8334"\w* \w manghai|strong="H4428"\w* kah \w tueihyoeih|strong="H5288"\w* rhoek loh, “\w Anih|strong="H9909"\w* \w ham|strong="H5973"\w* \w hno|strong="H1697"\w* pakhat khaw a \w saii|strong="H6213"\w* pah \w moenih|strong="H3808"\w*,” \w a ti uh\w*.   
\p
\v 4 \w Manghai|strong="H4428"\w* loh, “\w Vongup|strong="H2691"\w* \w kah|strong="H9996"\w* te \w unim|strong="H4310"\w*?” a \w ti|strong="H0559"\w* \w vaengah|strong="H9999"\w*, \w Haman|strong="H2001"\w* tah \w thing|strong="H6086"\w* \w dongah|strong="H5921"\w* \w Mordekai|strong="H4782"\w* \w kuiok|strong="H8518"\w* sak \w ham|strong="H9997"\w* a \w tawn|strong="H3559"\w* te \w manghai|strong="H4428"\w* \w taengah|strong="H9997"\w* \w thui|strong="H0559"\w* \w hamla|strong="H9997"\w* \w manghai|strong="H4428"\w* \w im|strong="H1003"\w* kah \w vongup|strong="H2691"\w* \w khuila|strong="H9997"\w* \w lom|strong="H2435"\w* \w kun|strong="H0935"\w*.   
\p
\v 5 Te \w vaengah|strong="H9999"\w* \w manghai|strong="H4428"\w* kah \w tueihyoeih|strong="H5288"\w* rhoek loh \w a|strong="H9909"\w* \w taengah|strong="H0413"\w*, “\w Haman|strong="H2001"\w* \w vongup|strong="H2691"\w* \w ah|strong="H9996"\w* \w pai|strong="H5975"\w* \w ke|strong="H2009"\w*,” a \w ti|strong="H0559"\w* uh.  
\p Te \w dongah|strong="H9999"\w* \w manghai|strong="H4428"\w* loh, “Ha \w kun|strong="H0935"\w* saeh,” a \w ti|strong="H0559"\w* nah.   
\p
\v 6 \w Haman|strong="H2001"\w* a \w kun|strong="H0935"\w* \w van|strong="H9999"\w* \w neh|strong="H9999"\w* \w a|strong="H9909"\w* \w taengah|strong="H9997"\w*, “\w Manghai|strong="H4428"\w* loh \w amah|strong="H9909"\w* kah \w umponah|strong="H3366"\w* \w dongah|strong="H9996"\w* khueh a \w ngaih|strong="H2654"\w* \w hlang|strong="H0376"\w* \w ham|strong="H9996"\w* \w te|strong="H0834"\w* \w manghai|strong="H4428"\w* \w loh balae|strong="H4100"\w* a \w saii|strong="H6213"\w* pa eh?” a \w ti|strong="H0559"\w* nah.  
\p Te \w vaengah|strong="H9999"\w* \w Haman|strong="H2001"\w* loh \w a|strong="H9909"\w* \w lungbuei|strong="H3820"\w* \w ah|strong="H9996"\w*, '\w Manghai|strong="H4428"\w* loh \w kai|strong="H9901"\w* \w lakah|strong="H4480"\w* aka \w hoeikhang|strong="H3148"\w* te \w umponah|strong="H3366"\w* \w saii|strong="H6213"\w* pah \w ham|strong="H9997"\w* \w unim|strong="H4310"\w* a \w ngaih|strong="H2654"\w*?,” a \w ti|strong="H0559"\w*.  
\v 7 Te \w dongah|strong="H9999"\w* \w Haman|strong="H2001"\w* loh \w manghai|strong="H4428"\w* \w taengah|strong="H0413"\w*, “\w Manghai|strong="H4428"\w* loh \w amah|strong="H9909"\w* kah \w umponah|strong="H3366"\w* \w dongah|strong="H9996"\w* khueh a \w ngaih|strong="H2654"\w* \w hlang|strong="H0376"\w* \w te|strong="H0834"\w*,  
\v 8 \w manghai|strong="H4428"\w* \w amah|strong="H9909"\w* pum \w dongkah|strong="H9996"\w* a \w bai|strong="H3847"\w* nawn \w manghai|strong="H4438"\w* \w pueinak|strong="H3830"\w*, \w manghai|strong="H4428"\w* loh \w a|strong="H9909"\w* \w soah|strong="H5921"\w* \w a ngol|strong="H7392"\w* thil \w marhang|strong="H5483"\w*, \w a|strong="H9909"\w* \w lu|strong="H7218"\w* \w dongah|strong="H9996"\w* a \w khuem|strong="H5414"\w* \w manghai|strong="H4438"\w* \w rhuisam|strong="H3904"\w* te \w khuen|strong="H0935"\w* saeh.  
\v 9 Te \w phoeiah|strong="H9999"\w* \w pueinak|strong="H3830"\w* \w neh|strong="H9999"\w* \w marhang|strong="H5483"\w* te \w angrhaeng|strong="H6579"\w* \w manghai|strong="H4428"\w* kah \w mangpa|strong="H8269"\w* rhoek \w lamkah|strong="H4480"\w* \w pakhat|strong="H0376"\w* \w kut|strong="H3027"\w* \w ah|strong="H5921"\w* \w pae|strong="H5414"\w* saeh. Te \w vaengah|strong="H9999"\w* \w manghai|strong="H4428"\w* loh \w amah|strong="H9909"\w* kah \w umponah|strong="H3366"\w* \w dongah|strong="H9996"\w* khueh ham a \w ngaih|strong="H2654"\w* \w hlang|strong="H0376"\w* \w te|strong="H0834"\w* \w bai|strong="H3847"\w* \w sak saeh\w*. Te \w phoeiah|strong="H9999"\w* \w anih|strong="H9909"\w* te \w khopuei|strong="H5892"\w* \w toltung|strong="H7339"\w* \w la|strong="H9996"\w* \w marhang|strong="H5483"\w* \w dongah|strong="H5921"\w* \w ngol|strong="H7392"\w* sak saeh \w lamtah|strong="H9999"\w* \w a|strong="H9909"\w* \w hmai|strong="H6440"\w* \w ah|strong="H9997"\w*, '\w Manghai|strong="H4428"\w* loh \w amah|strong="H9909"\w* kah \w umponah|strong="H3366"\w* \w khuiah|strong="H9996"\w* khueh a \w ngaih|strong="H2654"\w* \w hlang|strong="H0376"\w* \w ham|strong="H9997"\w* tah \w he|strong="H3602"\w* tlam ni a \w saii|strong="H6213"\w*,’ tila \w doek|strong="H7121"\w* saeh,” a \w ti|strong="H0559"\w* nah.   
\p
\v 10 Te \w phoeiah|strong="H9999"\w* \w manghai|strong="H4428"\w* loh \w Haman|strong="H2001"\w* \w te|strong="H9997"\w*, “Na \w thui|strong="H1696"\w* \w bangla|strong="H9995"\w* \w pueinak|strong="H3830"\w* \w neh|strong="H9999"\w* \w marhang|strong="H5483"\w* \w te|strong="H0853"\w* \w tlek|strong="H4116"\w* \w lo|strong="H3947"\w* \w lamtah|strong="H9999"\w* \w manghai|strong="H4428"\w* \w vongka|strong="H8179"\w* \w ah|strong="H9996"\w* aka \w ngol|strong="H3427"\w* \w Judah|strong="H3064"\w* \w Mordekai|strong="H4782"\w* \w ham|strong="H9997"\w* \w saii|strong="H6213"\w* pah. Na \w thui|strong="H1696"\w* \w boeih|strong="H3605"\w* te \w ol|strong="H1697"\w* pakhat khaw \w rhul|strong="H5307"\w* sak \w boeh|strong="H0408"\w*,” a \w ti|strong="H0559"\w* nah.   
\p
\v 11 Te \w dongah|strong="H9999"\w* \w Haman|strong="H2001"\w* loh \w pueinak|strong="H3830"\w* \w neh|strong="H9999"\w* \w marhang|strong="H5483"\w* \w te|strong="H0853"\w* a \w loh|strong="H3947"\w* \w tih|strong="H9999"\w* \w Mordekai|strong="H4782"\w* \w te|strong="H0853"\w* a \w bai|strong="H3847"\w* sak. Te \w phoeiah|strong="H9999"\w* \w anih|strong="H9909"\w* \w khopuei|strong="H5892"\w* \w toltung|strong="H7339"\w* \w la|strong="H9996"\w* a \w ngol|strong="H7392"\w* sak \w tih|strong="H9999"\w* \w a|strong="H9909"\w* \w hmai|strong="H6440"\w* \w ah|strong="H9997"\w*, '\w Manghai|strong="H4428"\w* loh \w amah|strong="H9909"\w* kah \w umponah|strong="H3366"\w* \w khuiah|strong="H9996"\w* khueh a \w ngaih|strong="H2654"\w* \w hlang|strong="H0376"\w* \w ham|strong="H9997"\w* tah \w he|strong="H3602"\w* tlam ni a \w saii|strong="H6213"\w*,’ tila a \w doek|strong="H7121"\w*.   
\p
\v 12 Te \w phoeiah|strong="H9999"\w* \w Mordekai|strong="H4782"\w* te \w manghai|strong="H4428"\w* \w vongka|strong="H8179"\w* \w la|strong="H0413"\w* \w mael|strong="H7725"\w*. \w Tedae|strong="H9999"\w* \w Haman|strong="H2001"\w* tah \w a|strong="H9909"\w* \w im|strong="H1003"\w* \w la|strong="H0413"\w* mael \w paitok|strong="H1765"\w* tih rhahdoe \w cangpoem|strong="H0057"\w* ah a \w lu|strong="H7218"\w* te a \w muei|strong="H2645"\w*.  
\v 13 \w Haman|strong="H2001"\w* loh \w a|strong="H9909"\w* taengah aka \w thoeng|strong="H7136"\w* \w boeih|strong="H3605"\w* \w te|strong="H0853"\w* \w a|strong="H9909"\w* \w yuu|strong="H0802"\w* \w Zeresh|strong="H2238"\w* \w taeng|strong="H9997"\w* \w neh|strong="H9999"\w* \w a|strong="H9909"\w* \w lungnah|strong="H0157"\w* \w boeih|strong="H3605"\w* \w taengah|strong="H9997"\w* a \w thui|strong="H5608"\w*. Te \w vaengah|strong="H9999"\w* \w amah|strong="H9909"\w* \w te|strong="H9997"\w* \w a|strong="H9909"\w* \w hlangcueih|strong="H2450"\w* rhoek \w neh|strong="H9999"\w* \w a|strong="H9909"\w* \w yuu|strong="H0802"\w* \w Zeresh|strong="H2238"\w* loh, “\w Mordekai|strong="H4782"\w* te \w Judah|strong="H3064"\w* \w tiingan|strong="H2233"\w* \w lamkah|strong="H4480"\w* \w koinih|strong="H0518"\w*, \w a|strong="H9909"\w* \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w* \w cungku|strong="H5307"\w* sak \w ham|strong="H9997"\w* na \w tong|strong="H2490"\w* cakhaw \w anih|strong="H9909"\w* \w te|strong="H9997"\w* na \w noeng|strong="H3201"\w* \w mahpawh|strong="H3808"\w*, \w a|strong="H9909"\w* \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w* \w rhep|strong="H3588"\w* na \w cungku|strong="H5307"\w* rhoe na \w cungku|strong="H5307"\w* ni,” a \w ti|strong="H0559"\w* nah.   
\p
\v 14 \w Anih|strong="H9909"\w* \w te|strong="H5973"\w* \w a|strong="H9908"\w* \w thui|strong="H1696"\w* uh \w li|strong="H5750"\w* \w vaengah|strong="H9999"\w* \w manghai|strong="H4428"\w* \w imkhoem|strong="H5631"\w* rhoek ha \w pawk|strong="H5060"\w* uh \w tih|strong="H9999"\w* \w Haman|strong="H2001"\w* \w te|strong="H0853"\w* \w Esther|strong="H0635"\w* kah a \w saii|strong="H6213"\w* \w buhkoknah|strong="H4960"\w* kung \w la|strong="H0413"\w* \w tlek|strong="H0926"\w* a \w khuen|strong="H0935"\w* uh.   
\c 7  
\s1 Haman A Ngawn  
\p
\v 1 \w Manghai|strong="H4428"\w* \w neh|strong="H9999"\w* \w Haman|strong="H2001"\w* te \w manghainu|strong="H4436"\w* \w Esther|strong="H0635"\w* \w neh|strong="H5973"\w* \w ok|strong="H8354"\w* \w hamla|strong="H9997"\w* \w cet|strong="H0935"\w*.  
\v 2 \w Buhkoknah|strong="H4960"\w* a \w hnin|strong="H3117"\w* \w bae|strong="H8145"\w* \w dongkah|strong="H9996"\w* \w misurtui|strong="H3196"\w* a ok \w bal|strong="H1571"\w* \w vaengah|strong="H9996"\w* tah \w manghai|strong="H4428"\w* loh \w Esther|strong="H0635"\w* \w te|strong="H9997"\w*, “\w Manghainu|strong="H4436"\w* \w Esther|strong="H0635"\w* \w nang|strong="H9903"\w* kah \w huithuinah|strong="H7596"\w* te \w menim|strong="H4100"\w*? \w Nang|strong="H9903"\w* \w ham|strong="H9997"\w* \w mpaek|strong="H5414"\w* bitni. \w Na|strong="H9903"\w* \w kueknah|strong="H1246"\w* \w te|strong="H4100"\w* \w ram|strong="H4438"\w* \w rhakthuem|strong="H2677"\w* \w hil|strong="H5704"\w* \w pataeng|strong="H9999"\w* han \w suem|strong="H6213"\w* bitni,” a \w ti|strong="H0559"\w* nah.   
\p
\v 3 \w Esther|strong="H0635"\w* \w manghainu|strong="H4436"\w* loh a \w doo|strong="H6030"\w* \w tih|strong="H9999"\w*, “\w Manghai|strong="H4428"\w* \w nang|strong="H9905"\w* \w mikhmuh|strong="H5869"\w* \w ah|strong="H9996"\w* \w mikdaithen|strong="H2580"\w* ni ka \w hmuh|strong="H4672"\w* \w atah|strong="H0518"\w*, \w manghai|strong="H4428"\w* \w ham|strong="H5921"\w* a \w then|strong="H2896"\w* mak \w atah|strong="H0518"\w* \w ka|strong="H9901"\w* \w huithuinah|strong="H7596"\w* \w bangla|strong="H9996"\w*, \w ka|strong="H9901"\w* \w kueknah|strong="H1246"\w* \w bangla|strong="H9996"\w*, \w kamah|strong="H9901"\w* \w neh|strong="H9999"\w* \w ka|strong="H9901"\w* \w pilnam|strong="H5971"\w* kah \w hinglu|strong="H5315"\w* ham \w kai|strong="H9901"\w* \w taengah|strong="H9997"\w* bet n'\w rhen|strong="H5414"\w* mai.  
\v 4 \w Kamah|strong="H0589"\w* \w khaw|strong="H9999"\w*, \w ka|strong="H9901"\w* \w pilnam|strong="H5971"\w* khaw, \w mitmoeng|strong="H8045"\w* sak \w ham|strong="H9997"\w* neh \w ngawn|strong="H2026"\w* \w ham|strong="H9997"\w* \w khaw|strong="H9999"\w*, \w milh|strong="H0006"\w* sak \w ham|strong="H9997"\w* n'\w yoih|strong="H4376"\w* uh coeng. \w Salnu|strong="H8198"\w*, \w salpa|strong="H5650"\w* \w bangla|strong="H9997"\w* n'\w yoih|strong="H4376"\w* uh. \w Manghai|strong="H4428"\w* kah \w pocinah|strong="H5143"\w* \w ham|strong="H9996"\w* \w rhal|strong="H6862"\w* neh a \w tluk|strong="H7737"\w* \w pawt|strong="H0369"\w* \w dongah|strong="H3588"\w* hil ka \w phah|strong="H2790"\w*,” a \w ti|strong="H0559"\w* nah.   
\p
\v 5 \w Manghai|strong="H4428"\w* \w Ahasuerus|strong="H0325"\w* te \w cal|strong="H0559"\w* \w tih|strong="H9999"\w* \w Esther|strong="H0635"\w* \w manghainu|strong="H4436"\w* \w taengah|strong="H9997"\w*, “\w Anih|strong="H1931"\w* \w te|strong="H2088"\w* \w unim|strong="H4310"\w*? \w Anih|strong="H1931"\w* \w te|strong="H2088"\w* \w melae|strong="H0335"\w*? \w Te|strong="H3651"\w* bang te \w saii|strong="H6213"\w* \w ham|strong="H9997"\w* \w a|strong="H9909"\w* \w lungbuei|strong="H3820"\w* aka \w hah|strong="H4390"\w* te \w unim|strong="H0834"\w*?” a \w ti|strong="H0559"\w* nah.   
\p
\v 6 Te \w vaengah|strong="H9999"\w* \w Esther|strong="H0635"\w* loh, “\w Tekah|strong="H2088"\w* \w hlang|strong="H0376"\w* tah \w rhal|strong="H6862"\w* \w neh|strong="H9999"\w* \w thunkha|strong="H0341"\w* \w boethae|strong="H7451"\w* \w Haman|strong="H2001"\w* ni,” a \w ti|strong="H0559"\w* nah.  
\p Te \w dongah|strong="H9999"\w* \w Haman|strong="H2001"\w* tah \w manghai|strong="H4428"\w* \w neh|strong="H9999"\w* \w manghainu|strong="H4436"\w* \w mikhmuh|strong="H6440"\w* ah \w let|strong="H1204"\w* coeng.  
\v 7 \w Manghai|strong="H4428"\w* khaw \w buhkoknah|strong="H4960"\w* \w misurtui|strong="H3196"\w* kung \w lamloh|strong="H4480"\w* \w a|strong="H9909"\w* \w kosi|strong="H2534"\w* \w neh|strong="H9996"\w* \w thoo|strong="H6965"\w* tih \w impuei|strong="H1055"\w* \w dum|strong="H1593"\w* \w la|strong="H0413"\w* cet. \w Tedae|strong="H9999"\w* \w Haman|strong="H2001"\w* tah \w boethae|strong="H7451"\w* loh \w manghai|strong="H4428"\w* \w taeng|strong="H0854"\w* \w lamkah|strong="H4480"\w* \w amah|strong="H9909"\w* a \w khah|strong="H3615"\w* \w te|strong="H3588"\w* a \w hmuh|strong="H7200"\w* \w dongah|strong="H3588"\w* \w a|strong="H9909"\w* \w hinglu|strong="H5315"\w* \w kongah|strong="H5921"\w* \w manghainu|strong="H4436"\w* \w Esther|strong="H0635"\w* \w te|strong="H4480"\w* \w hloep|strong="H1245"\w* \w ham|strong="H9997"\w* \w pai|strong="H5975"\w* pueng.  
\v 8 Te \w phoeiah|strong="H9999"\w* \w manghai|strong="H4428"\w* te \w impuei|strong="H1055"\w* \w dum|strong="H1593"\w* \w lamloh|strong="H4480"\w* \w buhkoknah|strong="H4960"\w* \w im|strong="H1003"\w* kah \w misurtui|strong="H3196"\w* kung \w la|strong="H0413"\w* \w mael|strong="H7725"\w*. Te \w vaengah|strong="H9999"\w* \w Haman|strong="H2001"\w* te \w Esther|strong="H0635"\w* kah \w a|strong="H9907"\w* \w thingkong|strong="H4296"\w* \w soah|strong="H5921"\w* ana \w bakop|strong="H5307"\w* pah. Te \w dongah|strong="H9999"\w* \w manghai|strong="H4428"\w* loh, “\w Im|strong="H1003"\w* \w khui|strong="H9996"\w* kah \w kamah|strong="H9901"\w* \w taeng|strong="H5973"\w* nawn ah \w manghainu|strong="H4436"\w* \w te|strong="H0853"\w* na \w khoh|strong="H3533"\w* \w ham|strong="H9997"\w* \w bal|strong="H1571"\w* \w a|strong="H9994"\w*?” a \w ti|strong="H0559"\w* nah.  
\p \w Manghai|strong="H4428"\w* \w ka|strong="H6310"\w* \w lamloh|strong="H4480"\w* \w ol|strong="H1697"\w* a \w thoeng|strong="H3318"\w* \w neh|strong="H9999"\w* \w Haman|strong="H2001"\w* \w maelhmai|strong="H6440"\w* khaw a \w thing|strong="H2645"\w* uh coeng.   
\p
\v 9 Te \w vaengah|strong="H9999"\w* \w imkhoem|strong="H5631"\w* rhoek khui \w lamkah|strong="H4480"\w* \w pakhat|strong="H0259"\w* \w Harbona|strong="H2726"\w* loh \w manghai|strong="H4428"\w* \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w*, “\w Haman|strong="H2001"\w* loh \w Mordekai|strong="H4782"\w* \w ham|strong="H9997"\w* \w thing|strong="H6086"\w* a \w saii|strong="H6213"\w* coeng \w ke|strong="H2009"\w*. \w Te|strong="H0834"\w* te \w Haman|strong="H2001"\w* \w im|strong="H1003"\w* \w ah|strong="H9996"\w* \w dong|strong="H0520"\w* \w sawmnga|strong="H2572"\w* a \w sang|strong="H1364"\w* la \w pai|strong="H5975"\w* tih \w manghai|strong="H4428"\w* \w ham|strong="H5921"\w* tah \w hnothen|strong="H2896"\w* la a \w thui|strong="H1696"\w*,” a \w ti|strong="H0559"\w* nah.  
\p Te \w dongah|strong="H9999"\w* \w manghai|strong="H4428"\w* loh, “\w Te|strong="H9909"\w* \w dongah|strong="H5921"\w* te \w amah|strong="H9909"\w* \w kuiok|strong="H8518"\w* sak,” a \w ti|strong="H0559"\w* nah.   
