\v 25 \w Caí|strong="H5307"\w* \w postrado|strong="H5307"\w* \w ante|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w los|strong="H3588"\w* 40 \w días|strong="H3117"\w* \w y|strong="H3588"\w* las 40 \w noches|strong="H3915"\w*. \w Caí|strong="H5307"\w* \w postrado|strong="H5307"\w* \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* dijo \w que|strong="H3588"\w* \w los|strong="H3588"\w* iba \w a|strong="H3068"\w* \w destruir|strong="H8045"\w*,
\v 26 y hablé con \nd \w Yavé|strong="H3068"\w*\nd*: ¡Oh \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd*! \w No|strong="H7843"\w* \w destruyas|strong="H7843"\w* \w a|strong="H3068"\w* tu \w pueblo|strong="H5971"\w*, tu \w heredad|strong="H5159"\w* \w que|strong="H5971"\w* rescataste con tu \w grandeza|strong="H1433"\w*, \w a|strong="H3068"\w* quienes \w sacaste|strong="H3318"\w* \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w* con \w mano|strong="H3027"\w* \w fuerte|strong="H2389"\w*.
\p 
\v 27 \w Acuérdate|strong="H2142"\w* \w de|strong="H5971"\w* tus esclavos, \w de|strong="H5971"\w* Abraham, \w Isaac|strong="H3327"\w* y \w Jacob|strong="H3290"\w*. No \w mires|strong="H6437"\w* la dureza \w de|strong="H5971"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, ni su perversidad, ni su \w pecado|strong="H2403"\w*,
