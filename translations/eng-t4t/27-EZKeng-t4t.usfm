\v 5 \w No|strong="H3808"\w* \w one|strong="H3808"\w* \w pitied|strong="H2550"\w* \w you|strong="H6440"\w* \w or|strong="H3808"\w* \w acted|strong="H6213"\w* \w kindly|strong="H6440"\w* \w toward|strong="H5921"\w* \w you|strong="H6440"\w* \w by|strong="H5921"\w* \w doing|strong="H6213"\w* \w those|strong="H5921"\w* \w things|strong="H3808"\w* \w for|strong="H5921"\w* \w you|strong="H6440"\w*. \w Instead|strong="H3808"\w*, \add it was as though\add* [MET] \w you|strong="H6440"\w* \w were|strong="H3117"\w* \w thrown|strong="H7993"\w* \w into|strong="H5921"\w* \w a|strong="H3068"\w* \w field|strong="H7704"\w*, \w because|strong="H5921"\w* \w on|strong="H5921"\w* \w the|strong="H6440"\w* \w day|strong="H3117"\w* \w that|strong="H3117"\w* \w you|strong="H6440"\w* \w were|strong="H3117"\w* \w born|strong="H3205"\w*, \w you|strong="H6440"\w* \w were|strong="H3117"\w* despised {everyone despised \w you|strong="H6440"\w*}.   
\p
\v 6 \w Then|strong="H5674"\w* \add it was as though\add* [MET] \w I|strong="H5921"\w* \w passed|strong="H5674"\w* \w by|strong="H5921"\w* \w and|strong="H7200"\w* \w saw|strong="H7200"\w* \w you|strong="H5921"\w* lying \w in|strong="H5921"\w* \w your|strong="H5921"\w* own \w blood|strong="H1818"\w* \w and|strong="H7200"\w* kicking. \w And|strong="H7200"\w* \w while|strong="H5921"\w* \w you|strong="H5921"\w* lay \w there|strong="H7200"\w* kicking \w in|strong="H5921"\w* \w your|strong="H5921"\w* own \w blood|strong="H1818"\w*, \w I|strong="H5921"\w* said \w to|strong="H5921"\w* \w you|strong="H5921"\w*, “\w I|strong="H5921"\w* want \w you|strong="H5921"\w* \w to|strong="H5921"\w* remain \w alive|strong="H2421"\w*!”  
