\b  
\m
\v 44 \w These|strong="H8147"\w* \w were|strong="H3478"\w* \w the|strong="H6485"\w* \w men|strong="H3478"\w* \w numbered|strong="H6485"\w* \w by|strong="H3478"\w* \w Moses|strong="H4872"\w* \w and|strong="H4872"\w* Aaron, \w with|strong="H1004"\w* \w the|strong="H6485"\w* assistance \w of|strong="H1004"\w* \w the|strong="H6485"\w* \w twelve|strong="H8147"\w* \w leaders|strong="H5387"\w* \w of|strong="H1004"\w* \w Israel|strong="H3478"\w*, \w each|strong="H8147"\w* \w one|strong="H1961"\w* representing \w his|strong="H3478"\w* \w family|strong="H1004"\w*.  
\v 45 \w So|strong="H1961"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w Israelites|strong="H3478"\w* \w twenty|strong="H6242"\w* \w years|strong="H8141"\w* \w of|strong="H1121"\w* \w age|strong="H1121"\w* \w or|strong="H1121"\w* \w older|strong="H4605"\w* \w who|strong="H3605"\w* could \w serve|strong="H1961"\w* \w in|strong="H8141"\w* \w Israel|strong="H3478"\w*’s \w army|strong="H6635"\w* \w were|strong="H3478"\w* \w counted|strong="H6485"\w* according \w to|strong="H3318"\w* \w their|strong="H3605"\w* \w families|strong="H1004"\w*.  
\v 46 \w And|strong="H3967"\w* \w all|strong="H3605"\w* \w those|strong="H3605"\w* \w counted|strong="H6485"\w* totaled 603,550.   
\s1 The Exemption of the Levites  
\b  
\m
\v 47 \w The|strong="H8432"\w* \w Levites|strong="H3881"\w*, however, \w were|strong="H3881"\w* \w not|strong="H3808"\w* \w numbered|strong="H6485"\w* \w along|strong="H8432"\w* \w with|strong="H6485"\w* \w them|strong="H8432"\w* \w by|strong="H6485"\w* \w the|strong="H8432"\w* \w tribe|strong="H4294"\w* \w of|strong="H4294"\w* \w their|strong="H8432"\w* fathers.  
