\v 4 \w En|strong="H8432"\w* ese entonces \w Jeremías|strong="H3414"\w* entraba y \w salía|strong="H3318"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del \w pueblo|strong="H5971"\w*, \w porque|strong="H3808"\w* \w aún|strong="H3808"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* habían encerrado \w en|strong="H8432"\w* la cárcel.  
\v 5 Entonces \w el|strong="H5921"\w* \w ejército|strong="H2428"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w* había \w salido|strong="H3318"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, \w y|strong="H5921"\w* \w al|strong="H5921"\w* llegar \w la|strong="H5921"\w* \w noticia|strong="H3318"\w* \w a|strong="H3068"\w* \w oídos|strong="H8085"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w caldeos|strong="H3778"\w* \w que|strong="H5921"\w* tenían sitiada \w a|strong="H3068"\w* Jerusalén, \w se|strong="H5921"\w* retiraron \w de|strong="H5921"\w* \w ella|strong="H5921"\w*.   
\p
\v 6 Entonces \w vino|strong="H1961"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* al \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w*:  
\v 7 \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* de \w Israel|strong="H3478"\w* dice: \wj Dirás \+w esto|strong="H3541"\+w* \+w al|strong="H4428"\+w* \+w rey|strong="H4428"\+w* de \+w Judá|strong="H3063"\+w*, quien los \+w envió|strong="H7971"\+w* \+w a|strong="H3068"\+w* \+w Mí|strong="H2009"\+w* para \+w que|strong="H3541"\+w* \+w me|strong="H3541"\+w* consultaran: \+w Mira|strong="H2009"\+w*, el \+w ejército|strong="H2428"\+w* de \+w Faraón|strong="H6547"\+w* \+w que|strong="H3541"\+w* \+w salió|strong="H3318"\+w* \+w a|strong="H3068"\+w* socorrerte regresó \+w a|strong="H3068"\+w* su tierra \+w en|strong="H3318"\+w* \+w Egipto|strong="H4714"\+w*.\wj*  
\v 8 \wj \+w Los|strong="H5921"\+w* \+w caldeos|strong="H3778"\+w* regresarán \+w y|strong="H5921"\+w* atacarán \+w esta|strong="H2063"\+w* \+w ciudad|strong="H5892"\+w*. \+w La|strong="H5921"\+w* tomarán \+w y|strong="H5921"\+w* \+w la|strong="H5921"\+w* incendiarán.\wj*   
\p
\v 9 \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w No|strong="H3808"\+w* \+w se|strong="H5921"\+w* engañen ustedes mismos, \+w al|strong="H5921"\+w* decir: \+w Ciertamente|strong="H3588"\+w* \+w los|strong="H5921"\+w* \+w caldeos|strong="H3778"\+w* \+w se|strong="H5921"\+w* apartarán \+w de|strong="H5921"\+w* \+w nosotros|strong="H5921"\+w*, \+w porque|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w se|strong="H5921"\+w* apartarán.\wj*  
\v 10 \wj \+w Porque|strong="H3588"\+w* \+w aun|strong="H3588"\+w* \+w si|strong="H3588"\+w* ustedes hubieran derrotado \+w a|strong="H3068"\+w* \+w todo|strong="H3605"\+w* \+w el|strong="H3588"\+w* \+w ejército|strong="H2428"\+w* \+w de|strong="H3588"\+w* \+w los|strong="H3605"\+w* \+w caldeos|strong="H3778"\+w* \+w que|strong="H3588"\+w* luchaba contra ustedes, \+w y|strong="H3588"\+w* hubieran dejado hombres \+w heridos|strong="H5221"\+w* \+w entre|strong="H3588"\+w* ustedes, \+w cada|strong="H3605"\+w* uno \+w en|strong="H3588"\+w* \+w su|strong="H3588"\+w* tienda, \+w estos|strong="H2063"\+w* se levantarían \+w y|strong="H3588"\+w* consumirían \+w con|strong="H3588"\+w* fuego \+w esta|strong="H2063"\+w* \+w ciudad|strong="H5892"\+w*.\wj*   
\p
\v 11 \w Aconteció|strong="H1961"\w* \w que|strong="H5921"\w*, \w cuando|strong="H1961"\w* \w el|strong="H5921"\w* \w ejército|strong="H2428"\w* caldeo \w se|strong="H1961"\w* retiró \w de|strong="H5921"\w* Jerusalén \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w del|strong="H5921"\w* \w ejército|strong="H2428"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*,  
\v 12 \w Jeremías|strong="H3414"\w* \w salió|strong="H3318"\w* \w de|strong="H5971"\w* Jerusalén \w hacia|strong="H8033"\w* el territorio \w de|strong="H5971"\w* \w Benjamín|strong="H1144"\w* \w para|strong="H5971"\w* tomar posesión \w de|strong="H5971"\w* una herencia \w entre|strong="H8432"\w* su \w pueblo|strong="H5971"\w*.  
\v 13 Mientras \w él|strong="H1931"\w* \w estaba|strong="H1961"\w* en \w la|strong="H1931"\w* \w puerta|strong="H8179"\w* \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w*, \w estaba|strong="H1961"\w* \w allí|strong="H8033"\w* un capitán \w llamado|strong="H8034"\w* \w Irías|strong="H3376"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Selemías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hananías|strong="H2608"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* apresó al \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* y \w le|strong="H1931"\w* dijo: Te pasas \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w caldeos|strong="H3778"\w*.   
\p
\v 14 \w Jeremías|strong="H3414"\w* respondió: \w Falso|strong="H8267"\w*, \w no|strong="H3808"\w* \w me|strong="H5921"\w* paso \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w caldeos|strong="H3778"\w*.  
\p Pero \w él|strong="H5921"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* quiso \w escuchar|strong="H8085"\w*. Agarró \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w y|strong="H5921"\w* \w lo|strong="H3808"\w* llevó ante \w los|strong="H5921"\w* magistrados.  
\v 15 \w Los|strong="H5921"\w* magistrados \w se|strong="H5921"\w* airaron \w contra|strong="H5921"\w* \w Jeremías|strong="H3414"\w* \w y|strong="H3588"\w* \w lo|strong="H5921"\w* azotaron. \w Lo|strong="H5921"\w* llevaron \w a|strong="H3068"\w* \w la|strong="H5921"\w* cárcel \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w del|strong="H5921"\w* \w escriba|strong="H5608"\w* Jonatán, \w pues|strong="H3588"\w* \w la|strong="H5921"\w* habían convertido \w en|strong="H5921"\w* cárcel.   
\p
\v 16 \w Así|strong="H3588"\w* \w que|strong="H3588"\w* \w Jeremías|strong="H3414"\w* fue llevado \w a|strong="H3068"\w* un calabozo \w en|strong="H3588"\w* una mazmorra,\f + \fr 37:16 \ft Mazmorra: prisión subterránea.\f* \w y|strong="H3588"\w* \w allí|strong="H8033"\w* \w estuvo|strong="H3427"\w* \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*.  
\v 17 El \w rey|strong="H4428"\w* Sedequías \w mandó|strong="H7971"\w* \w a|strong="H3068"\w* buscarlo. Tan pronto como estuvo en su \w casa|strong="H1004"\w*, le \w preguntó|strong="H7592"\w* en secreto: ¿\w Hay|strong="H3426"\w* \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*?  
\p \w Jeremías|strong="H3414"\w* respondió: \w Hay|strong="H3426"\w*. \w Y|strong="H3068"\w* añadió: \wj Serás \+w entregado|strong="H5414"\+w* en \+w mano|strong="H3027"\+w* del \+w rey|strong="H4428"\+w* \+w de|strong="H1697"\+w* Babilonia. \wj*   
\p
