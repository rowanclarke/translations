\id 2TH
\h 2 Itissalunikiyyen 
\toc1 2 Itissalunikiyyen 
\toc2 2 Itissalunikiyyen 
\toc3 2 Ts. 
\mt1 2 Itissalunikiyyen  
\c 1
\s1 Aseǧem ɣar umezwaru d tẓaǧit n uqadi  
\m
\v 1 Bulus d Silwanus d Timutiyu, i tmesmunt n Itissalunikiyyen, tenni iǧan di AREBBI, Babatneɣ, u di Siditneɣ Yasuɛ Lmasiḥ.  
\v 2 Arḍa d řehna zi AREBBI, Babatneɣ, u zi Siditneɣ Yasuɛ Lmasiḥ ad kiwem iřin. \x ◘ \xo 1:2 \xt 1 Kur. 1:3; 1 Ts. 1:1; 1 Bṭ. 1:2. \x*   
\b  
\m
\v 3 Icuwwar ad nqada AREBBI i kenniw řebda, \add a\add* aytma, am mammec ittřiq, minzi l’iman nwem imeqqar aṭṭas, am mammec uřa d tayri n kuř ijjen zzaywem marra i wenni d as yudsen tarenni tmeqqar ktar, \x ◘ \xo 1:3 \xt Afa. 1:15; Fil. 1:3; Kul. 1:3; 1 Ts. 1:2. \x*  
\v 4 ař nettfeyyec xawem di tmesmunin n AREBBI x ssibbet n l’iman nwem d ṣṣbar nwem di marra adarrec nwem d řemḥayem nwem nni teksim. \x ◘ \xo 1:4 \xt 1 Ts. 2:19. \x*  
\v 5 Man aya d lburhan n řḥukm isseggden n AREBBI, aqa tᵉttwaḥasbem tesdaheǧem Tageldit, tenni xef teksim amarret. \f ◼ \fr 1:5 \ft \+fk lburhan\ft  - niɣ: ‘ddalil’.\f*  \x ◘ \xo 1:5 \xt 1 Ts. 2:14; Yah. 6. \x*  
\v 6 U mařa xenni d řḥeqq zzat i AREBBI umi ɣa ixeǧeṣ s řmeḥnet i yinni kenniw iḥeṣṣaren, \x ◘ \xo 1:6 \xt Zak. 2:12. \x*  
\v 7 \add xenni\add* Netta ad kidneɣ isseddar uřa d kenniw inni ittwaḥṣaren, \add wah ad aneɣ isseddar akidwem\add* ɣar usargeb n Siditneɣ Yasuɛ Lmasiḥ zeg ujenna ak-d řɛeskarat n lmalakat nnes, \x ◘ \xo 1:7 \xt 1 Ts. 4:16. \x*  
\v 8 x minni i ɣa intaqem di tmessi itteḥduduqen x yinni war issinen ca AREBBI u x yinni war xsen ad cehden s Řexbar Aṣebḥan n Siditneɣ Yasuɛ Lmasiḥ. \x ◘ \xo 1:8 \xt Rum. 2:8; 2 Bṭ. 3:7. \x*  
\v 9 Minzi ina ad ttwaɛaqben di řḥukm s uhellek i řebda am yaggwejen x wudem n Siditneɣ u x uɛuǧi n jjehd nnes, \x ◘ \xo 1:9 \xt Ica. 2:19. \x*  
\v 10 xmi dd ɣa yas Netta ḥima ad ittwaɛuǧi deg wass nni di marra imqeddasen nnes, u ḥima ad isscen řeɛjayeb nnes s yinni dayes yumnen, minzi tumnem zi cchadet nneɣ i kenniw deg wass nni. \x ◘ \xo 1:10 \xt Řex. 1:11; 1 Ts. 1:10; Asa. 1:7. \x*   
\m
\v 11 S uyenni nkessi awem řmeɛruf řebda, ḥima AREBBI nneɣ ad kenniw yegg ad tesdaheǧem tařaɣit nwem, u \add ḥima\add* ad kenniw iccur s jjehd maḥend ad tiřim twejdem qaɛ i \add tmegga n\add* tcuni u i řexdayem n l’iman,  
\v 12 ḥima ad daywem ittwaɛuǧi Isem n Siditneɣ Yasuɛ, uca uřa d kenniw dayes, ɛlaḥsab arḍa n AREBBI nneɣ d Siditneɣ Yasuɛ Lmasiḥ.   
\b  
\b  
\m  
\c 2
\s1 Bnadem n ddnub  
\m
\v 1 Aqa nᵉttzaweg kenniw, \add a\add* aytma, zi jjihet n twasit n Siditneɣ Yasuɛ Lmasiḥ d wesmuni nneɣ ɣares,  
\v 2 aqa war tᵉttnexřiɛem niɣ tesḥissfem ca deɣya, war iǧi s ijj n wawař niɣ s ca n arruḥ niɣ s ict n tebrat axmi zzayneɣ, \add i iqqaren\add*: “Xzar, ass n Siditneɣ yusa-dd!” \x ◘ \xo 2:2 \xt Irm. 29:8; Mt. 24:4; Afa. 5:6; Kul. 2:18; 1 Yḥ. 4:1. \x*  
\v 3 War ttejji uřa d ijj ad kenniw iɣwa s ca n webrid, minzi \add ass\add* nni war dd-ittis qbeř i dd ɣa yas uɣewweɣ uca ad dd-iban bnadem n ddnub, aqa-t d mmis n tehliket. \f ◼ \fr 2:3 \ft \+fk mmis n tehliket\ft  - niɣ: ‘mmis n řexṣaret’ niɣ ‘mmis n řefna’.\f*  \x ◘ \xo 2:3 \xt Mt. 24:23; 1 Tim. 4:1; 1 Yḥ. 2:18. \x*  
\v 4 Netta ittemɛařa u issɛuǧa ixef nnes x marra min ittwasemman ‘AREBBI’ niɣ ‘aɛbad’, ař ɣa iqqim di Zzawect Tameqqrant n AREBBI amecnaw netta d AREBBI i yeǧa, uca ad isscen i yixef nnes, aqa netta axmi AREBBI. \x ◘ \xo 2:4 \xt Dan. 11:36. \x*   
\m
\v 5 Ma war teɛqiřem ca umi tuɣa ayi kiwem, aqa nniɣ awem-t?  
\v 6 Maca řexxu tiwḍem tessnem min d as ibedden ɛad deg webrid, ḥima ad dd-iban di řweqt nnes.  
\v 7 Ssirr n řmuɛṣiyyet aqa ixeddem \add řexxu\add*. Maca mařa immeksi zi řwesṭ min d as issbedden ɛad deg webrid řexxu,  
\v 8 ad dd-iḍhar bab n řmuɛṣiyyet, wenni ɣa isshellek Siditneɣ Yasuɛ s twarrit n nnefs zeg uqemmum nnes, ad t issebḍeř xmi dd ɣa tban twasit nnes. \x ◘ \xo 2:8 \xt Ayub 4:9; Ica. 11:4. \x*  
\v 9 Maɣar tawasit n \add bab nni n řmuɛṣiyyet\add* ad traḥ \add jmiɛ\add* ak-d řxedmet n cciṭan s marra jjehd d řeɛřamat d lmuɛjizat issxarriqen, \x ◘ \xo 2:9 \xt Aɛwd. 13:2; Yḥ. 8:41; 2 Kur. 4:4; Afa. 2:2; Asa. 13:13. \x*  
\v 10 u s marra řɣecc n řmuɛṣiyyet deg yinni i ɣa ihellken, minzi nitni war qbiřen ca tayri n tidett ḥima ad zzayes afen Tudart. \x ◘ \xo 2:10 \xt 2 Kur. 2:15; 4:3. \x*  
\v 11 S uyenni AREBBI ad ɣarsen dd-issekk min ten ɣa yarr s jjehd ɣar uweddar, ař ɣa yamnen deg uxarriq. \x ◘ \xo 2:11 \xt Rum. 1:24; 1 Tim. 4:1. \x*  
\v 12 Marra inni war yuminen ca di tidett, maca ixsen řmuɛṣiyyet ktar, ad ttwaḥakmen.   
\b  
\m  
\s1 Abeddi imtem di l’iman  
\m
\v 13 Maca icuwwar aneɣ ad nqada AREBBI řebda xawem, \add a\add* awmaten nneɣ, inni xef iɛizz Siditneɣ, aqa AREBBI ixḍar i kenniw zeg umezwaru i Tudart, s tqeddast zi Arruḥ u s l’iman n tidett.  
\v 14 Aqa iřaɣa-dd xawem i man aya s ubarreḥ nneɣ s Řexbar Aṣebḥan, ḥima ad tiřim i uɛuǧi n Siditneɣ Yasuɛ Lmasiḥ.   
\m
\v 15 S uyenni, \add a\add* aytma, beddem nican uca ṭṭfem di tweṣṣa i d awem ittwassřemden zzayneɣ, ma s wawař niɣ s tebrat nneɣ. \x ◘ \xo 2:15 \xt 2 Ts. 3:6. \x*   
\m
\v 16 Maca Netta, Siditneɣ Yasuɛ Lmasiḥ, u AREBBI, Babatneɣ, wenni d aneɣ ixsen d wenni d aneɣ iwcen afewwej ittduman d usitem icnan s arḍa nnes,  
\v 17 ad issfewwej uřawen nwem uca ad kenniw issejhed di marra awař u di marra řxedmet taṣebḥant. \x ◘ \xo 2:17 \xt 1 Ts. 3:13. \x*   
\b  
\b  
\m  
\c 3
\s1 Awařen n Bulus ɣar aneggaru d useǧem  
\m
\v 1 \add A kenniw,\add* awmaten nneɣ, zi ssa d tsawent ksim aneɣ řmeɛruf ḥima Awař n Siditneɣ ad dd-iffeɣ deɣya u ad ittwassɛuǧ, am mammec tuɣa imsar jar awem ɛawed, \x ◘ \xo 3:1 \xt Mt. 9:38; Afa. 6:19; Kul. 4:3. \x*  
\v 2 ḥima ad nettwafekk zeg iwdan war iḥřin, iɛeffanen, minzi l’iman war iǧi ɣar marra. \x ◘ \xo 3:2 \xt Yḥ. 6:44; Rum. 15:31. \x*   
\m
\v 3 Maca SIDI d amtiqqi. Netta ad xawem iḥḍa uca ad kenniw ifekk zeg umɛeffan. \x ◘ \xo 3:3 \xt Yḥ. 17:15; 1 Ts. 5:24. \x*  
\v 4 Maca neccin nettiqq daywem di Siditneɣ, belli min xef nweṣṣa kenniw, aqa tᵉtteggem t uca ad teqqimem tᵉtteggem t.  
\v 5 Ad indeh Siditneɣ uřawen nwem ɣar tayri n AREBBI u ɣar ubarreḥ s Řexbar Aṣebḥan n Lmasiḥ.   
\b  
\m
\v 6 Nweṣṣa kenniw, \add a\add* aytma, deg Yisem n Siditneɣ Yasuɛ Lmasiḥ, ad tḥeyydem i kuř uma i igguren di min war iḥřin, war iǧi ɛlaḥsab tiweṣṣa i zzayneɣ iksi. \x ◘ \xo 3:6 \xt 1 Kur. 5:11; 2 Ts. 2:15; 3:14; Tit. 3:10. \x*  
\v 7 Aqa kenniw tessnem mammec icuwwar ad aneɣ teḍfarem, minzi neccin war nuyur jar awem di min war iḥřin. \x ◘ \xo 3:7 \xt 1 Kur. 11:1; 1 Ts. 1:6, 7; 2 Ts. 2:10. \x*  
\v 8 War necci aɣrum ak-d ḥed baṭeř, maca s řxedmet d tamara tuɣa aneɣ nxeddem ǧiřet d wass, ḥima war dd-nettis nedqeř x ca n ijjen zzaywem. \x ◘ \xo 3:8 \xt Řex. 18:3; 20:34; 1 Kur. 4:12; 2 Kur. 11:9; 12:13; 1 Ts. 2:9. \x*  
\v 9 War iǧi minzi war ɣarneɣ ttesriḥ i man aya, maca ḥima ad negg ixef nneɣ d lmital i ɣa teḍfarem. \x ◘ \xo 3:9 \xt 1 Kur. 4:16; 9:3, 6; 11:1; Fil. 3:17; 1 Ts. 1:6; 2:9. \x*  
\v 10 Minzi řami tuɣa aneɣ neǧa akidwem, aqa nweṣṣa ammu: mařa ḥed war ixs ad ixdem, war ittett ɛawed.  
\v 11 Minzi nesřa aqa din ca jar awem inni igguren di min iɛeffnen, war xeddmen qaɛ, maca tteggen \add mɣir\add* min war isekkwin.  
\v 12 Aqa numur u nziyyar i-ten di Siditneɣ Yasuɛ Lmasiḥ ḥima ad xedmen di řhudnet, ad ccen aɣrum nsen. \x ◘ \xo 3:12 \xt Afa. 4:28; 1 Ts. 4:11. \x*   
\m
\v 13 Maca kenniw, \add a\add* aytma, war ttuḥiřem ca maḥend ad teggem min icnan. \x ◘ \xo 3:13 \xt Gal. 6:9. \x*  
\v 14 Maca mařa ca n ijjen war iṭaɛ i wawařen i yuran di tebrat-a, bḍam xas, war ttxeǧaḍem ca akides, ḥima ad idweř ittseḍḥa, \x ◘ \xo 3:14 \xt Mt. 18:17; 1 Kur. 5:9; 2 Ts. 3:6. \x*  
\v 15 maca war t tᵉttḥessbem d řeɛdu maca nedhem t ɣar webrid am yijj n tawmat.   
\b  
\m
\v 16 Maca Sidi n řehna ad awem iwc řehna i řebda x marra iɣezdisen. Siditneɣ ad yiři akidwem marra. \x ◘ \xo 3:16 \xt Rum. 15:33; 16:20; 1 Kur. 14:33; 2 Kur. 13:11; Fil. 4:9; 1 Ts. 5:23. \x*   
\m
\v 17 Ijj n useǧem s ufus inu. Necc, Bulus, uriɣ aya. Ta d řeɛřamet di marra tibratin inu. Ammu i d uriɣ. \x ◘ \xo 3:17 \xt 1 Kur. 16:21; Kul. 4:18. \x*   
\m
\v 18 Arḍa n Siditneɣ Yasuɛ Lmasiḥ ad akidwem yiři marra, \add a awmaten inu\add*. Amin.   