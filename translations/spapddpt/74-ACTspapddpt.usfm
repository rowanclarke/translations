\v 7 \w Les|strong="G4314"\w* respondió: \wj \+w A|strong="G4314"\+w* ustedes \+w no|strong="G3756"\+w* \+w les|strong="G4314"\+w* corresponde \+w saber|strong="G1097"\+w* \+w los|strong="G3588"\+w* \+w tiempos|strong="G2540"\+w* \+w o|strong="G2228"\+w* \+w las|strong="G3588"\+w* épocas \+w que|strong="G3588"\+w* \+w el|strong="G3588"\+w* \+w Padre|strong="G3962"\+w* estableció \+w en|strong="G1722"\+w* \+w su|strong="G3588"\+w* \+w propia|strong="G2398"\+w* \+w jurisdicción|strong="G1849"\+w*.\wj*  
\v 8 \wj \+w Pero|strong="G2532"\+w* \+w cuando|strong="G1722"\+w* \+w venga|strong="G1904"\+w* \+w el|strong="G3588"\+w* \+w Espíritu|strong="G4151"\+w* Santo \+w sobre|strong="G1909"\+w* ustedes, \+w me|strong="G1473"\+w* serán \+w testigos|strong="G3144"\+w* primero \+w en|strong="G1722"\+w* Jerusalén, \+w toda|strong="G3956"\+w* \+w Judea|strong="G2449"\+w*, \+w Samaria|strong="G4540"\+w* \+w y|strong="G2532"\+w* \+w hasta|strong="G2193"\+w* \+w lo|strong="G3588"\+w* \+w último|strong="G2078"\+w* \+w de|strong="G1722"\+w* \+w la|strong="G3588"\+w* \+w tierra|strong="G1093"\+w*.\wj*   
\p
\v 9 \w Después|strong="G2532"\w* \w de|strong="G3588"\w* \w decir|strong="G3004"\w* \w esto|strong="G3778"\w*, mientras \w ellos|strong="G3588"\w* \w lo|strong="G3588"\w* miraban, fue levantado, \w y|strong="G2532"\w* \w una|strong="G3588"\w* \w nube|strong="G3507"\w* \w lo|strong="G3588"\w* ocultó \w de|strong="G3588"\w* \w sus|strong="G3588"\w* \w ojos|strong="G3788"\w*.   
