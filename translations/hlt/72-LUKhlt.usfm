\c 19  
\s1 Zakkhaeus Taengah Pah  
\p
\v 1 \w Jerikho|strong="G2410"\w* \w te|strong="G3588"\w* a \w kun|strong="G1525"\w* thil tih a \w hil|strong="G1330"\w*.  
\v 2 Te \w vaengah|strong="G2532"\w* \w hlang|strong="G0435"\w* pakhat, a \w ming|strong="G3686"\w* ah \w Zakkhaeus|strong="G2195"\w* la a \w khue|strong="G2564"\w* te \w lawt|strong="G2400"\w* om. \w Anih|strong="G0846"\w* tah \w mangmu|strong="G0754"\w* boei \w neh|strong="G2532"\w* \w kuirhang|strong="G4145"\w* la \w om|strong="G2258"\w*.  
