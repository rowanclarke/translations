\id JAS  
\h SANTIAGO 
\toc1 Si₂ carta a₂ca₂jmo₃ SANTIAGO 
\toc2 SANTIAGO 
\toc3 Stg. 
\mt2 Si₂ carta a₂ca₂jmo₃ 
\mt1 SANTIAGO 
\c 1  
\s1 Jmo₅ Santiago si₂ a₂chein₃ ne₄ dsa₂ 'én₂ i₂tián'₅ tsɨ₁rë₂jan₅₄ uɨ́ng₂ 
\p  
\v 1 Jniá₂ Santiago, lɨ́ng₅ i₂jme₂ti₃ ne₄ Diú₄ quian'₅₄ ne₄ Te₁gui'₅₄ Jesucristo, cuɨ́ng₅ Diú₄ ta₁guia₃-tɨ́n₂ nió'₃ tsɨ₁jon₂ dsa₂ juɨg₂ Israel i₂tián'₅ tsɨ₁rë₂jan₅₄ ta₁caun₂ mɨ₂güɨ́g₃. 
\s1 Juɨ₁lia'₂ jme₁jau'₂ 'í₁ a₂dsɨ₂ŋɨ́₂ dsa₂ 'én₂ 'e₂ niog₅ dsɨ₂ŋɨ́i₂ 
\p  
\v 2 'Nia'₂ rɨn'₅₄ jniog₄, jmo₄ 'nia'₂ 'au'₂ a₂dseng'₃ guë́₄ lɨn₃, jme₁dsɨ₂ŋɨ́'₂ 'nia'₂ ca₂le₃jë́₃ ne₅₄ táu₂ a₂jau'₂ 'í₁ ja₁con'₂ 'nia'₂.  
\v 3 Ia₁ ma₂ŋi'₅₄ bá₄ 'nia'₂ jë₁ma₂ca₂jáu'₃ 'í₁ 'a₂ lia'₂ 'én'₂ 'nia'₂, dsióg₄ lia'₂ ma₂tión'₂ jaun₂ bá₄ 'nia'₂ tiá₂.  
\v 4 La₁ cuɨn₅₄ 'nia'₂ jmɨg₄ a₂le₃'ŋia₅ a₂në₅ ja₁cong'₂, tió'₃ 'au'₂ 'nia'₂ jmo₄, jaun₂ dsi₁nóg'₅ léng'₂ dsa₂ i₂ma₂ca₂can'₅₄, i₂ma₂rë₂'ŋia₅ lia'₂ ŋɨ́'₂ dsi₄, tsá₃ ma₃'e₂ 'nió'₅ quián'₂ 'nia'₂. 
\p  
\v 5 Chi₂jua'₂ chan'₂ 'nia'₂ i₂'nió'₅ le₃ŋɨ́'₂ dsɨ́₅, juɨ₁mɨ₁₂ ja₁con₂ Diú₄, jaun₂ 'éi₂ bá₄ cuë₃. Ia₁ Diú₄ i₂'ua₁ dsɨ́₅ jmo₂₃ qui₂rë₂tɨn₂ ca₂le₃jɨ́n₃, on₃jua'₅₄ a₂të₂jí₂.  
\v 6 La₁ ca₂tɨ́n'₂ 'nia'₂ a₂mɨ́'₁ a₂'éng'₂ të₃dsón'₂ on₃jua'₅₄ a₂'ág'₁ 'nia'₂ caun₂-tɨn₃ 'au'₂; ia₁ juɨ₁lia'₂ dsa₂ i₂'ag₅ caun₂-tɨn₃ dsɨ́₅, lɨ́in₅ juɨ₁lia'₂ lë́₅ jmɨg₂ a₂qui₂ráun₂ ne₄ jmɨ₁ŋí'₄, a₂qui₂jná'₅ can₂ dsí₂ ca₂taun₂ ca₂taun₂.  
\v 7 Dsa₂ i₂lɨ́n₅ le₂jaun₂, tsá₃ juɨ₁dsi₂jiog₅ dsɨ́₅ jua'₅₄ cha₂ a₂gue₃ quió'₅ Te₁gui'₅₄.  
\v 8 Ia₁ juɨ₁lia'₂ dsa₂ i₂'ei₅ tɨn₃ dsɨ́₅ tsá₃ 'e₂ tiá₂ chén'₅ i₂le₂'éi₂ ca₂le₃jë́₃ guë́₄ 'e₂ a₂jmo₂₃, o₃ 'e₂ jág₁ quió'₅ cuë₂₃.  
\v 9 Dsa₂ rɨn'₅₄ jniog₄ i₂te₂ŋé₂, ca₂tɨ́in₂ jmo₃ dsɨ́₅ 'io'₂ jén'₅, ia₁ të₃dsón'₂ bá₄ quein₅ le₃ja₁con₂ Diú₄.  
\v 10 Juɨ₁lia'₂ i₂cha₂ cu₄ guë'₂, ca₂tɨ́in₂ bá₄ jmo₃ 'io'₂ ján₃ ia₁ tsá₃ 'e₂ quein₅ ja₁con₂ Diú₄ quian'₅₄ cú₁. Ia₁ i₂lɨ́n₅ juɨ₁lia'₂ lë́₅ lí₁ nɨ₁nau₂ bá₄ dsa₂ i₂cha₂ cu₄ ia₁ i₂dsɨ₃ŋɨ́₂ bá₄ 'éi₂ juɨ₁la₂ 'ióg₃.  
\v 11 Jë₁ma₂ca₂'ia₂\f + \fr 1:11 \ft Co₂'nió'₄ le₃jua'₅₄, caun₂ cosa a₂tsá₃ 'i₄ jme₂dsí₂, a₂ca₂jmo₃ Diú₄. 'Nio'₂ ja₁ton₅ Salmo 8:3; Romanos 1:25.\f* 'iog₂ dséi₅ 'ŋio₅ lɨn₃ rë₂juɨng₅ bá₄ nɨ₁nau₂, rë₂quein₂, ta'₂ bá₄ lí₁ ján₃, 'én₂ bá₄ 'a₂ lia'₂ jlá'₁ jme₁jniá₂. Le₂në₅ bá₄ lë́₅ quian'₅₄ dsa₂ cha₂ cu₄: qui₂dsɨ₃ŋɨ́i₂ bá₄ të₃ ja₁'no₂₃ cu₄. 
\s1 On₃jua'₅₄ Diú₄ i₂jmo₅ a₂co₂dsɨ₂'én'₅ dsa₂ 
\p  
\v 12 'E₂ guë́₄ dsen₃ dsa₂ i₂tió'₅ jmo₅ juɨn'₂ dsɨ́₅ jë₁ma₂qui₂i₂ŋɨ́i₂ 'e₂ táu₂ i₂ŋɨ́i₂; ia₁ jë₁ma₂ca₂ŋɨi₅ jaun₂, gue₃ ja₁le₃chain₂ dse₃, a₂lë́₅ në₂jag₄ bá₄ caun₂ corona a₂cuë₃ Diú₄ cuë́'₃ ca₂le₃jɨ́n₃ i₂'nio₃ quió'₅.  
\v 13 Chi₂jua'₂ chan₂ i₂lɨn₅₄ qui₂ja₂ bí₂ 'lɨg'₅₄ dsɨ́₅, tsá₃ juɨ₁dsi₂jiog₅ dsɨ́₅ jua'₅₄ Diú₄ i₂jmo₅ a₂dsɨ₂jiog₅ dsɨ́₅ le₂jaun₂; ia₁ 'i₁caun₂ a₂'lɨg'₅₄ tsá₃ quɨ'₅₄ jmɨg₄ jua'₅₄ a₂cáin₂ táu₂ Diú₄, on₃ guë'₂ cáun₂ Diú₄ táu₂ quió'₅ 'i₁jan₂ ia₁jaun₂ jmo₃ dsa₂ a₂'lɨg'₅₄.  
\v 14 Le₂la₂ bá₄ lë́₅: guion₅₄ bá₄ dsa₂ tsɨ₂cuɨin'₂ juɨ₅ ja₁'ɨ́n₅ dsɨ́₅ jmo₃ a₂'lɨg'₅₄, ja₁tiáin'₃ dso₄, lɨ́in₅ në₂jag₄ bá₄ juɨ₁lia'₂ jan₂ i₁ju₁ i₂nág'₅ mɨ₂cu₄.  
\v 15 Ne₄ ja₁'ɨ́n₅ dsɨ́₅ jmo₃ a₂'lɨg'₅₄ në́₃, të₂le₃ ne₄ ja₁ŋó₄ jaun₂ rë₂jniá₂ dso₄ bá₄ ja₁coin₂; jë₁ma₂ca₂'ŋia₅ dso₄ në́₃, rë₃cha₂ 'mú₃. 
\p  
\v 16 'Nia'₂ rɨn'₅₄ jniog₄ i₂'nióg₃, tsá₃ juɨ₁le₂gan'₂ 'nia'₂,  
\v 17 ia₁ ca₂le₃jë́₃ a₂lë́₅ a₂dse₃ lɨn₃ a₂guei₂ jniog₄ já₅ guei'₅₄ quió'₅ Diú₄ Jmei₂ jniog₄ i₂ca₂jmo₃ ca₂le₃jë́₃ si₂ cha₂ guei'₅₄ dsi₂güɨg₂. La₁ ja₁con₂ Diú₄ 'i₁caun₂ tsá₃ 'e₂ jua'₅₄ a₂qui₂rë₂tsɨ́n₃, juɨ₁la₂ qui₂rë₂tsɨ́n₃ si₂ le₁'ág₄ guei'₅₄, 'ag₅ 'en'₂.  
\v 18 Lia'₂ ma₂lë́₅ jaun₂ bá₄ con'₂ lë́₅ ma₂ca₂rë₃'ŋió₃ dsɨ́₅ 'ŋiog₅, ma₂ca₂jmo₃ a₂ma₂ca₂rë₃chóng₃ jniog₄ të₂le₃ quian'₅₄ jág₁ dse₃ a₂tí₅ quió'₅, ia₁jaun₂ léi₂ jniog₄ i₂le₂'uɨg₅₄ juɨ₁lia'₂ caun₂ a₂ca₂rau₂ ca₂le₃jë́₃ a₂ma₂jmo₃ 'éi₂. 
\s1 Juɨ₁lia'₂ jë₁'én₂ dsón'₂ dsa₂ co₂dsau₅ 
\p  
\v 19 Juɨ₁le₂ŋi'₅₄ 'nia'₂ a₂la₂, rɨn'₅₄ jniog₄: le₂jan'₂ le₂jan'₂ 'nia'₂ rë₂jáng'₁ a₂jŋia'₅₄ nág'₁ de'₂, tsá₃ 'nió'₅ jua'₅₄ a₂ma₂të₂chan'₅₄ 'nia'₂ jág₁ a₂ŋag'₅₄ dsɨ₂juɨ₅, on₃ guë'₂ 'nió'₅ tɨn'₃ 'nia'₂ dséng'₂ në₃ cón'₅.  
\v 20 Ia₁ juɨ₁lia'₂ quian'₅₄ a₂dsén₂ dsa₂ tsá₃ lé₂ le₃jmo₃ a₂'ŋio₂ dsɨ́₅ Diú₄.  
\v 21 Jaun₂ lë₃, tí₃ 'nia'₂ ca₂le₃jë́₃ a₂'lɨg'₅₄ a₂lë́₅ dso₄ a₂ŋɨ́₄ 'ŋio₅ cha₂ jmɨg₄ në₃, jmo₄ 'nia'₂ meg'₂ guen₅₄ co₂ŋei'₅₄ jág₁ dse₃ a₂ma₂jnia₄ të₂'au'₂ 'nia'₂; ia₁ jág₁ dse₃ në₅ bá₄ a₂'io₅ juɨ₅bí₂ a₂lió₂ jme₂dsí₂ quián'₂ 'nia'₂. 
\p  
\v 22 La₁ juɨ₁le₂chan'₂ 'nia'₂ lia'₂ con'₂ lë́₅ jág₁, on₃jua'₅₄ rë'₂ a₂jŋia'₅₄ 'nió'₅ nág'₁ 'nia'₂. Ia₁ në₁jua'₂ tsá₃ jme₂tí'₁ 'nia'₂, guion'₅₄ bá₄ 'nia'₂ jme₂gáng'₁.  
\v 23 Ia₁ juɨ₁lia'₂ dsa₂ i₂jŋia'₅₄ të₅ dsɨ́₅ nag₂₃, tsá₃ jmo₂₃ guë'₂ a₂nag₂₃, lɨ́in₅ lia'₂ lɨ́n₅ jan₂ dsa₂ i₂jɨ́n₂ 'ŋiog₅ ne₄ nɨ₁'ɨ₂;  
\v 24 la₁ jë₁ma₂ŋó₅ cau₅ në́₃, dsɨ₂'én₂ bá₄ táng₃ dsɨ́₅ 'a₂ lia'₂ jniái₂.  
\v 25 La₁ 'e₂ guë́₄ dsen₃ dsa₂ i₂tsá₃ dsɨ₂'én₂ dsɨ́₅ 'e₂ nag₂₃ të₂le₃ 'ŋio₅ lɨn₃ guë́₄ tón'₂ juɨ₅ rë₂ jág₅ 'éi'₃ dse₃ a₂lión₂ dsa₂. Ia₁ jme₃gu'₅₄ bá₄ Diú₄ chi₂jua'₂ jmo₅ dsa₂ 'e₂ ta₁ quí'₅ 'éi'₃ jaun₂, caun₂ nau₂ tiá₂ bá₄. 
\p  
\v 26 Chi₂jua'₂ chan₂ i₂lɨn₅₄ lɨ́in₂ 'ŋio₅ lɨn₃ jme₂ti₃ ne₄ Diú₄, la₁ në₁jua'₂ tsá₃ con₂ guë'₂ dsɨ́₅ 'a₂ lia'₂ dsia₂₃ jág₁ në́₃, ján₃ bá₄ guion₅₄ i₂le₂'éi₂ jme₂gain₂₃, ia₁ a₂'éin₂ jaun₂ tsá₃ 'e₂ ta₁ tí₄.  
\v 27 Juɨ₁lia'₂ dsa₂ i₂'én₂ të₃dsón'₂ lia'₂ dsi₂ten₅₄ 'nio₃ Diú₄ Jmei₂ jniog₄, le₂la₂ bá₄ jmo₂₃: a₂jme₂'oin₅₄ chi'₂ 'nág₂ quian'₅₄ 'io₅₄ 'nág₂ në́₃, 'e₂ caun₂ o₂i₁ dsɨ₅ chan₂ 'éi₂, ton'₂ jmo₂₃ 'í₁ a₂tsá₃ jme₃'ŋioi₂₃ quian'₅₄ a₂'lɨg'₅₄ cha₂ mɨ₂güɨ́g₃. 
\c 2  
\p  
\v 1 Rɨn'₅₄ jniog₄, i₂'én₂ le₃quió'₅ Te₁gui'₅₄ Jesucristo i₂jlán'₁ quián₂ jniog₄, tsá₃ ca₂tɨ́n'₂ 'nia'₂ jɨng'₅₄ jma₃quén₅ i₂la₂ i₂ó₃.  
\v 2 Juɨ₁lia'₂ të₃jë₄ tion'₅₄ 'nia'₂ le₁ŋɨg'₂, dsióg₄ jan₂ dsa₂ cha₂ cu₄ i₂'i₄ anillo cu₄nióg₄ gu₂, i₂chén'₅ jlá'₁, la₁ në₁jua'₂ ján₃ guë'₂ të₃jë₄ jaun₂ dsióg₄ jan₂ dsa₂ te₂ŋé₂ i₂chén'₅ 'lɨg'₅₄,  
\v 3 në₁jua'₂ ca₂guen'₅₄ 'nia'₂ rë₂ lɨn₃ i₂qui'₂ tsɨn'₅₄ jlá'₁, në₁jua'₂ ca₂chei'₅₄ 'nia'₂: “Ŋia₅ i₂né₂ ja₁dse₃ la₂”, la₁ i₂te₂ŋé₂ guë'₂ në́₃ juɨg'₅₄ 'nia'₂: “'Ne₂ jó₄ nau₂”, o₃ “ja₁lá₃ i₂né₂ 'uë₃ cau₅ ja₁tióng₂ tag₃”;  
\v 4 në₁jua'₂ le₂në₅ jmo'₂ 'nia'₂, ma₂jɨng'₅₄ jma₃quén₅ rɨ́ng'₂, ma₂qui₂cáun'₂ 'nia'₂ 'í₁, a₂ma₂dsɨ₂jiog₅ 'lɨg'₅₄ 'au'₂.  
\v 5 'Nia'₂ rɨn'₅₄ jniog₄, nei₂ 'nia'₂ a₂la₂: Diú₄ ma₂ca₂quióin'₂ i₂lɨ́n₅ i₂te₂ŋé₂ mɨ₂güɨ́g₃ la₂, ia₁jaun₂ léin₂ dsa₂ jlán'₁ quian'₅₄ a₂'éin₂, ia₁ tɨin₃ ja₁gon₂ Diú₄ ja₁ma₂lë́₅ jág₁ cuë́'₃ ca₂le₃jɨ́n₃ i₂'nio₃ quió'₅.  
\v 6 La₁ 'nia'₂ në́₃ të₂le₃ o₂guí'₃ bá₄ tsɨ́ng'₂ dsa₂ te₂ŋé₂. ¿Ia₁ on₁jua'₅₄ dsa₂ cha₂ cu₄ guë'₂ i₂jmóg'₂ 'ang₂ quián'₂ 'nia'₂, qui₂tsɨin'₂ 'nia'₂ dsɨ₂chei'₂ ne₄ dsɨ₂tan₅₄ në́₃?  
\v 7 ¿On₁jua'₅₄ dsa₂ le₂'éi₂ guë'₂ i₂táun₂ 'lɨg'₅₄ jmá'₅ 'ɨin₂₃ i₂chen₂ jlán'₁, i₂le₃quió'₅ ja₁tén'₄ 'nia'₂? 
\p  
\v 8 Në₁jua'₂ dsɨ₂jó'₃ jme₂tí'₁ 'nia'₂ 'éi'₃ dsen₅₄ lia'₂ con'₂ lë́₅ juá'₂ ne₄ Si₂: “Jme₁'nió₄ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂ juɨ₁lia'₂ 'nióg'₃ 'ŋiag'₂”,\f + \fr 2:8 \ft Levítico 19:18.\f* dse₃ bá₄ në₁jua'₂ jmo'₂ 'nia'₂ le₂jaun₂.  
\v 9 La₁ në₁jua'₂ jɨn'₄ 'nia'₂ jma₃quén₅ i₂la₂ i₂ó₃, 'nau'₂ 'nia'₂ dso₄, ia₁ ma₂të₁dsɨ₅₄ 'Éi'₃ ja₁con'₂ 'nia'₂ guiong'₅₄; ma₂të₁tsɨn'₅₄ 'nia'₂ ma₂le₁cáng'₄ bá₄.  
\v 10 Ia₁ juɨ₁lia'₂ dsa₂ i₂jme₂ti₃ ca₂le₃jë́₃ 'Éi'₃, la₁ në₁jua'₂ ca₂'liain'₂ caun₂ 'éi'₃ tio'₅₄ në́₃, ja₁jaun₂ ca₂rë₃cáin'₂ ca₂le₃jë́₃ bá₄ 'éi'₃ a₂tio'₅₄ ne₄ Si₂ jaun₂.  
\v 11 Ia₁ Diú₄ 'éi₂ bá₄ i₂ca₂juá'₂ jme₁ca₂juá'₂: “Tsá₃ nió'₄ 'nia'₂ jág₁ quian'₅₄ dsa₂ i₂tsá₃ lɨ́n₅ dsɨ₂i₂gog'₂”,\f + \fr 2:11 \ft Éxodo 20:14; Deuteronomio 5:18.\f* ján₃ bá₄ i₂'éi₂ ca₂juá'₂: “Tsá₃ jŋɨ́g'₄ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂.”\f + \fr 2:11 \ft Éxodo 20:13; Deuteronomio 5:17.\f* Jaun₂ le₂në₅ chi₂jua'₂ tsá₃ ca₂táng'₂ guë'₂ dso₄ quian'₅₄ i₂tsá₃ lɨ́n₅ dsɨ₂i₂gog'₂, la₁ në₁jua'₂ ca₂jŋɨ́g'₃ guë'₂ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂ në́₃, ja₁jaun₂ ca₂rë₃cáng'₂ bá₄ ta₁jë₂ 'Éi'₃.  
\v 12 Ca₂tɨ́n'₂ 'nia'₂ jmó'₂ ton'₂ dsiá'₁ juɨ₁lia'₂ dsa₂ i₂në₃ guë́₄ të₃dsɨ₅₄ 'éi'₃ quió'₅ con'₂ lë́₅ 'éi'₃ a₂lió₂.  
\v 13 Ia₁ juɨ₁lia'₂ dsa₂ i₂tsá₃ ca₂dsia₃ ŋéi₂ dsɨ́₅ rɨn'₅₄, ján₃ bá₄ le₂jaun₂ tsá₃ ŋéi₂ dsɨ́₅ Diú₄ dsia₃ ja₁con₂ 'éi₂ jë₁ma₂të́₂ rë₁të₃dsɨ₅₄ 'éi'₃ quió'₅; la₁ juɨ₁lia'₂ i₂ca₂dsia₃ ŋéi₂ dsɨ́₅ rɨn'₅₄, a₂ŋéi₂ dsɨ́₅ jaun₂ bá₄ lí'₂ jë₁ma₂të́₂ rë₁të₃dsɨ₅₄ 'éi'₃ quió'₅. 
\s1 'Nió'₅ le₃jniá₂ a₂'én₂ dsa₂ 
\p  
\v 14 'Nia'₂ rɨn'₅₄ jniog₄, ¿'e₂ bá₄ ta₁ jmo₃ në₁jua'₂ chan₂ i₂juá'₂ ma₂'éin₂, në₁jua'₂ tsá₃ guë'₂ 'e₂ a₂'ua₁ dsɨ́₅ jmo₂₃? ¿Lé₂ le₃jua'₅₄ jniog₄ a₂tɨ́n'₄ dsa₂ le₂'éi₂ quian'₅₄ a₂'éin₂ le₂jaun₂?  
\v 15 Jua'₅₄ mei'₂ guë́₃ chan₂ jan₂ dsa₂ ŋe'₂, o₃ jan₂ dsa₂ mɨ́₂ rɨn'₅₄ jniog₄, 'ɨn₂ tsɨn'₅₄, 'ɨn₂ a₂guë́'₃, 'oin₅₄ ŋɨ₂₃ le₂o₃ jmɨg₄;  
\v 16 në₁jua'₂ chan'₂ 'nia'₂ i₂ca₂chei'₅₄: “Guan'₂ caun₂ dse₃ quiáng'₂”, o₃ “Guan'₂ o₂jme₁dsion'₂”, o₃ “Guan'₂ o₂jme₁tan₅₄ ja₁quiáng'₂”, në₁jua'₂ tsá₃ ca₂cuë'₅₄ guë'₂ 'nia'₂ a₂dsen₅₄ a₂'nió'₅ quió'₅ nɨ₁ŋɨ₁₂, ¿'e₂ bá₄ ta₁ jmo₃ a₂'én'₂ 'nia'₂ le₂në₅?  
\v 17 Le₂në₅ bá₄ lë́₅ quian'₅₄ a₂'én₂ dsa₂: në₁jua'₂ tsá₃ léi₄ qui₂rë₂jniá₁ a₂jmo₅ dsa₂ a₂'ua₁ dsɨ́₅, tsá₃ 'e₂ ta₁ tí₄ a₂'éin₂ jaun₂, lë́₅ caun₂ co₂'nió'₄ a₂'lag₄ bá₄ jaun₂. 
\p  
\v 18 'An₁ chan₂ bá₄ i₂juá'₂ në́₃: “'Én'₂ bá₄ 'ne₂, la₁ jniá₂ guë'₂ jmo₂₃ a₂dse₃.” Jniá₂ juá'₅: 'Ë₄ a₂'éng'₂, on₃jua'₅₄ quian'₅₄ a₂dse₃ a₂jmo'₂, jaun₂ jniá₂ në́₃ jme₁jniag₅ a₂'éng₂ të₂le₃ quian'₅₄ a₂dse₃ a₂jmo₂₃.  
\v 19 'Én'₂ bá₄ 'ne₂ a₂chan₂ jan₂ Diú₄; ¿'e₂ a₂dse₃ jmo'₂ në₁jua'₂ le₂jaun₂? Ján₃ bá₄ le₂në₅ guë'₂ je₂na'₅₄ 'éin₂ a₂chan₂ Diú₄, la₁ jlein₂₃ bá₄.  
\v 20 La₁ 'ne₂ në́₃ dsa₂ co₄, ¿'niog'₂ cuë₅₄ jniá₂ caun₂ léi₄ a₂tsá₃ 'e₂ quen₅ a₂'én₂ dsa₂ në₁jua'₂ tsá₃ 'e₂ a₂dse₃ a₂qui₂rë₂jniá₁ jmo₂₃?  
\v 21 ¿On₁jua'₅₄ ca₂të₁tsɨn'₅₄ rë₂ Abraham ne₄ Diú₄ të₂le₃ quian'₅₄ a₂dse₃ a₂jme₁jme₂jniai₂₃ lia'₂ con'₂ jme₁ca₂jéin'₂ Isaac ja₁ŋi'₅₄ quiáin₅ ne₄ Diú₄ a₂jme₁jŋag'₃ ne₄ ne₄chei₂?  
\v 22 Rë₂ de'₂ quion₂ 'nia'₂ 'í₁ 'a₂ lia'₂ ca₂lë₃ quian'₅₄ Abraham: ja₁jaun₂ ca₂rë₃jniá₂ a₂'éin₂ të₂le₃ quian'₅₄ a₂ca₂jmo₃ jaun₂, ja₁jaun₂ ca₂jáu'₃ 'í₁ ca₂'ŋia₅ a₂'éin₂ të₂le₃ quian'₅₄ a₂ca₂rë₃jniá₂ a₂ca₂jmo₃ jaun₂.  
\v 23 Le₂në₅ bá₄ ca₂rë₃ti₃ a₂juá'₂ ne₄ Si₂ 'ɨin₂₃ Abraham ja₁juá'₂: “Ca₂rë₃'én₂ Abraham ja₁con₂ Diú₄; a₂ca₂rë₃'éin₂ le₂jaun₂ në́₃, ca₂guéi'₂ Diú₄ të₁tsɨin'₅₄ lɨ́in₅ dsa₂ dsen₃.”\f + \fr 2:23 \ft Génesis 15:6; Romanos 4:3-22.\f* Jaun₂ Diú₄ në́₃ ca₂caun₃ ca₂lɨn₃ 'éi₂ a₂mei₅₄ quiáin₅.  
\v 24 Ja₁në₅ bá₄ rë₂jniá₂ jaun₂ në́₃, 'a₂ lia'₂ të₂tsɨn'₅₄ dsa₂ rë₂ ne₄ Diú₄ të₂le₃ quian'₅₄ a₂dse₃ a₂jmo₂₃, on₃jua'₅₄ rë'₂ a₂jŋia'₅₄ 'nió'₅ juá'₂ a₂'éin₂.  
\v 25 Ján₃ bá₄ le₂në₅ ca₂lë₃ quian'₅₄ Rahab i₂jme₁'nag₅ quió'₅;\f + \fr 2:25 \ft 'Nio'₂ ja₁ton₅ Josué 2:1-21; 6:17.\f* ca₂të₁tsɨin'₅₄ rë₂ ne₄ Diú₄ të₂le₃ quian'₅₄ a₂dse₃ a₂ca₂jmo₃: ca₂cuë₃ dsi₂néi₂ quió'₅ ca₂jŋia₃ dsa₂ quián₅ Diú₄, ján₃ guë'₂ ca₂jme₃'oin₅₄ dsa₂ 'éi₂ ca₂'uág'₂ juɨ₅ siá'₂.  
\v 26 Jaun₂ le₂në₅ bá₄ juɨ₁lia'₂ nɨ₁ŋɨ́₅ a₂tsá₃ jme₂dsí₂ 'i₄, lë́₅ caun₂ nɨ₁ŋɨ́₅ 'lag₄, ján₃ bá₄ le₂në₅ lë́₅ a₂'én₂ dsa₂, në₂jag₄ bá₄ 'lag₄ ján₃ në₁jua'₂ tsá₃ rë₂jniá₂ a₂dse₃ a₂jmo₂₃. 
\c 3  
\s1 Juɨ₁lia'₂ le₁tsɨ'₂ dsa₂ 
\p  
\v 1 Rɨn'₅₄ jniog₄, tsá₃ 'nió'₅ jua'₅₄ juɨn₅ i₂lén₂ të₅ jɨn'₄ 'nia'₂, ia₁ ma₂ŋi'₅₄ bá₄ 'nia'₂, 'ŋio₅ guë́₄ bén₂ 'éi'₃ të₃dsɨ₅₄ ja₁con₂ jniog₄ con'₂ lág₅ i₂jme₂tɨ́n₁ rɨn'₅₄.  
\v 2 Ia₁ ca₂le₃jág₃ bá₄ jniog₄ co₂dsɨ₂'éin'₅ ne₄ 'lióng₂ ne₅₄. Në₁jua'₂ chan₂ i₂tsá₃ ma₃dso₄ 'no₅ 'i₁ca₂juɨg₄ ja₁dsia₂₃ jág₁, dsa₂ le₂'éi₂ lɨ́n₅ dsa₂ rë₂'ŋia₅, i₂'io₅ bí₂ ne₄ nɨ₁ŋɨ₁₂ 'ŋiog₅, ta₁jain₂.  
\v 3 Juɨ₁lia'₂ jme₁tó'₅ dsa₂ nɨ₁ŋí₁ mɨ₂'o₄ dsɨ₂cua₁ ia₁jaun₂ jme₃ti₃, lé₂ jéin'₂ dsa₂ ta₁jain₂ 'a₂ juɨ₅ 'nio₃ dsa₂ jiog₃.  
\v 4 Ŋí₂ de'₂ 'nia'₂ ján₃ juɨ₁lia'₂ nɨ₁barco juɨ₁'a₂ guë'₂ lia'₂ ca'₅₄ pa₁ lɨn₃, qui₂'lia'₂ dsí₂ tiá₂, dsa₂ i₂quian₅ në́₃ lé₂ le₃cán₂ 'a₂ juɨ₅ 'nio₃, quian'₅₄ caun₂ timón pí'₁ bá₄.  
\v 5 Le₂në₅ bá₄ lë́₅ quian'₅₄ le₁tsɨ'₂ dsa₂ ján₃; le₁tsɨ'₂ dsa₂ lë́₅ caun₂ nɨ₁ŋɨ́₅ pí'₁ ton₅ nɨ₁ŋɨ₁ dsa₂; 'e₂ bá₄ lɨ́in₂ lé₂ le₃jmo₃ 'lióng₂ jág₁ ca'₅₄. ¡Ŋí₂ de'₂ 'nia'₂ ján₃, 'e₂ guë́₄ pa₁ 'ŋa₁ má'₂ lé₂ le₃dsɨ'₂ quian'₅₄ ca₂mɨ́g₂ si₂ pí'₁! 
\p  
\v 6 Jaun₂ le₁tsɨ'₂ dsa₂ në́₃, lë́₅ co₂'nió'₄ caun₂ si₂ a₂quian'₅₄ quió'₅ dsa₂. A₂lë́₅ co₂'nió'₄ caun₂ mɨ₂güɨ́g₃ 'lɨg'₅₄ a₂ton₅ nɨ₁ŋɨ₁ jniog₄, a₂jmo₅ ta₁ a₂qui₂rë₂'ŋio₅ dsa₂ ta₁jain₂. Quian'₅₄ jág₁ dséi₂ a₂'ŋiog₂ jniog₄, në₂jag₄ bá₄ a₂guí'₂ si₂ le₁tsɨ'₂ jniog₄ juɨ₅ quián₂ të₁lia'₂ chong₂, lë́₅ në₂jag₄ bá₄ si₂ a₂ca₂tɨ́n₂ bí₂ quian'₅₄ tsɨ'₅₄ si₂ a₂já₅ guio₃-juɨ́g₃.  
\v 7 Quɨ'₅₄ jmɨg₄ dsa₂ mɨ₂güɨ́g₃ jme₃'uáin₂ dsɨ́₅ ca₂le₃jë́₃ ne₅₄ já'₂ i₂tsau₂ dsɨ́₅, já'₂ i₂'ɨn₅, já'₂ i₂tsë́'₅ quió'₅, já'₂ i₂chan₂ jmɨ₁ŋí'₄ në́₃,  
\v 8 la₁ 'i₁jan₂ dsa₂ tsá₃ 'ein₂ ma₂tió'₃ jme₃'uáin₂ le₁tsɨ'₂ guioin₅₄. Lë́₅ caun₂ a₂'lɨg'₅₄ a₂tsá₃ tei₄ lé₂ le₃jmo₃, qui₂rë₂can'₂ jág₁ dséi₂ në₂jag₄ bá₄ mɨ́₅ 'lɨg'₅₄ a₂dsan₂ dsa₂.  
\v 9 Quian'₅₄ le₁tsɨ'₂ jniog₄ jme₂juɨ́n'₁ Te₁gui'₅₄ quián₂ i₂lɨ́n₅ Jmei₂ jniog₄, ton'₂ ján₃ guë'₂ 'ɨ́n₅ 'lɨg'₅₄ dsa₂ mɨ₂güɨ́g₃ i₂ma₂ca₂jmó'₂ Diú₄ lia'₂ lë́₅ nió'₄ quió'₅ 'ŋiog₅.  
\v 10 Quian'₅₄ mɨ₂'o₄ jniog₄ la₂, 'uë₂ jág₁ a₂jme₂juɨ́n'₁ Diú₄, ján₃ guë'₂ 'uë₂ jág₁ 'lɨg'₅₄ a₂'ɨ́n₅ dsa₂ rɨn'₅₄. Rɨn'₅₄ jniog₄, tsá₃ dsi₂ten₅₄ le₂në₅.  
\v 11 ¿'A₂ bá₄ lia'₂ chi₂jua'₂ caun₂ o₄tu₁ jmɨg₂ lé₂ le₃'iá₃ jmɨg₂ ráu₂ lia'₂ jmɨg₂ dsi'₃ në́₃?  
\v 12 'Nia'₂ rɨn'₅₄ jniog₄, ¿lé₂ le₃lé₂ jua'₅₄ caun₂ nɨ₁'ma₂ a₂'ag₅ mɨ́g₂ higo, jua'₅₄ a₂jaun₂ 'ag₃ táng₃ mɨ́g₂ aceitunas? O₃, ¿lé₂ le₃lé₂ jua'₅₄ ca₂cho'₅₄ uɨng₂ uvas, a₂jaun₂ 'ag₃ táng₃ mɨ́g₂ higos? Ján₃ bá₄ le₂në₅, 'i₁caun₂ tu₄ jmɨg₂ ja₁'ia₂ jmɨg₂ ŋi'₅₄ tsá₃ lé₂ le₃'iá₃ jmɨg₂ ráu₂ në́₃. 
\s1 Le₂la₂ dsón'₂ bá₄ lë́₅ a₂dse₃ lia'₂ con'₂ dsi₂ten₅₄ le₃ŋɨ́'₂ dsɨ́₅ dsa₂ 
\p  
\v 13 Në₁jua'₂ chan₂ jë₄ quián'₂ 'nia'₂ jan₂ i₂ŋɨ́'₂ dsɨ́₅, juɨ₁jme₂jniai₂₃ juɨ₅ dse₃ 'a₂ lia'₂ ŋɨ₂₃ të₂le₃ quian'₅₄ a₂jmo₃ a₂dse₃, a₂jmo₃ mei'₂ lia'₂ con'₂ lë́₅ ŋɨ́i'₂.  
\v 14 La₁ në₁jua'₂ tion'₅₄ 'nia'₂ jmo'₂ uɨn₅ 'au'₂ cha₂ a₂dsi'₃ të₂'au'₂ 'nia'₂, tiong'₅₄ cha₂ a₂ma₂'ɨ́n₅ 'au'₂ guiong'₅₄; në₁jua'₂ le₂në₅, tsá₃ ca₂tɨ́n'₂ 'nia'₂ jmó'₂ táng'₅, on₃ guë'₂ jmó'₂ të₂jɨ́ng'₁ quian'₅₄ jág₁ tí₅.  
\v 15 Ia₁ a₂ŋɨ́'₂ dsɨ́₅ dsa₂ le₂në₅, on₃jua'₅₄ a₂já₅ guei'₅₄ në₅; quió'₅ mɨ₂güɨ́g₃ bá₄. A₂lë́₂ dsɨ́₅ nɨ₁ŋɨ₁ dsa₂ guioin₅₄, ta₁ quió'₅ je₂na'₅₄ bá₄ në₅.  
\v 16 Ia₁ juɨ₁lia'₂ ja₁tion'₅₄ dsa₂ uɨn₅ dsɨ́₅ quian'₅₄ rɨin'₅₄, ton'₂ co₂tan₅₄ cha₂ a₂ma₂'ɨ́n₅ dsɨ́₅ dsa₂ a₂lí'₂ jmá'₃ guioin₅₄, ja₁le₂jaun₂ tsá₃ 'e₂ dse₃ chí'₅ tion'₅₄ dsa₂, ton'₂ jmo₅-dsáu₅ dsa₂ ca₂le₃jë́₃ ne₅₄ a₂'lɨg'₅₄.  
\v 17 La₁ juɨ₁lia'₂ ja₁ŋɨ́'₂ dsón'₂ dse₃ dsɨ́₅ dsa₂ a₂já₅ guei'₅₄ i₂juɨ́g₃, jë₁le₂'uɨg₅₄ de'₂ chan₂ dsa₂ quian₅ caun₂ juɨ₅ le₁jë́₃; ŋó₅ jaun₂ táng₃ 'no'₂ juɨ₅ ja₁'ag₃ tei₄; 'en₅₄ dsɨ́₅ dsa₂ lɨ́in₅ në́₃; caun₂ dsáu₅ dsɨ́₅ bá₄ 'e₂ caun₂ a₂lë́₂; chain₂ ŋéi₂ dsɨ́₅ dsa₂ mɨ₂güɨ́g₃ rɨin'₅₄; jmo₂₃ jmá'₃ lia'₂ a₂dse₃; ton'₂ tsá₃ 'e₂ qui₂co₂₃ jág₁ quió'₅; ton'₂ tsá₃ jua'₅₄ a₂lë₁co₂jmo₂₃ o₁ne₁ në́₃.  
\v 18 Dsa₂ i₂quɨ́n'₅ bí₂ jne₂₃ a₂'ag₃ tei₄, jaun₂ ro'₂ a₂le₃chain₂ caun₂ juɨ₅ co₂dsau₅. 
\c 4  
\s1 Juɨ₁lia'₂ jme₁tón'₅ dsa₂ 'én₂ jmo₂₃ ján₃ a₂jmo₅ dsa₂ mɨ₂güɨ́g₃ 
\p  
\v 1 ¿'A₂ juɨ₅ já₅ mɨ'₅₄ 'nei₂ a₂cha₂ jɨn'₄ 'nia'₂? ¿On₁jua'₅₄ 'uɨg₅₄ ia₁ a₂'niog'₂ 'nia'₂ le₃chang'₂ o₂'ŋió₃ o₂jŋia₃ 'au'₂, cuë₅ 'nei₂ nɨ₁ŋɨ'₁ 'nia'₂?  
\v 2 Cha₂ a₂'niog'₂ 'nia'₂ juɨ₁lia'₂ a₂tsá₃ cha₂ quiáng'₂. Uɨn₅ 'au'₂ 'nia'₂ lɨ́ng'₅. Ia₁ tsá₃ le₃lén'₂ 'nia'₂ a₂'ɨ́n₅ 'au'₂. Jmo'₂ 'nia'₂ mɨ'₅₄, dsia'₂ 'nia'₂ 'nei₂ në́₃, la₁ tsá₃ cha₂ quián'₂ 'nia'₂ në́₃, ia₁ tsá₃ mɨ'₂.  
\v 3 Juɨ₁lia'₂ jme₁mɨ'₂ guë'₂ 'nia'₂, la₁ tsá₃ ŋɨ'₂ guë'₂ 'nia'₂ 'uɨg₅₄ ia₁ tsá₃ mɨ'₂ 'nia'₂ con'₂ dsi₂ten₅₄, ia₁ a₂jŋia'₅₄ 'niog'₂ 'nia'₂ 'éng'₄ a₂le₃chang'₂ o₂'ŋió₃ o₂jŋia₃ 'au'₂ bá₄.  
\v 4 ¡'E₂ guë́₄ lɨ́n'₅ 'nia'₂ juɨ₁lia'₂ lɨ́n₅ dsa₂ mɨ́₂ i₂tsá₃ jen₅₄ dsɨ₂i₂gu₂, qui₂'no'₂ juɨ₅ dsó₅ quian'₅₄ i₂sián'₂! ¿Tsa₁ ŋi'₅₄ 'nia'₂, juɨ₁lia'₂ dsa₂ i₂jen'₂ dsɨ́₅ quian'₅₄ mɨ₂güɨ́g₃, i₂le₂'éi₂ të₂tsɨn'₅₄ lɨ́in₅ i₂'ŋia₅₄ Diú₄ bá₄? Jaun₂ lë₃, juɨ₁'ein₂ guë́₃ i₂jen'₂ quian'₅₄ mɨ₂güɨ́g₃, i₂'ŋia₅₄ Diú₄ bá₄ 'éi₂.  
\v 5 ¿O₃ bá₄ lɨ́n'₂ 'nia'₂, on₃jua'₅₄ 'e₂ cha₂ jein₅ jág₁ a₂juá'₂ ne₄ Si₂: “Jme₂dsí₂ i₂ma₂cuɨin₃ i₂'en₅₄ jë₄ quián₂ jniog₄, dsí'₅ 'ŋio₅ lɨn₃ ia₁ a₂'nio₃ jniog₄”?\f + \fr 4:5 \ft 'Nio'₂ ja₁ton₅ Éxodo 20:5.\f* 
\v 6 La₁ të₂le₃ 'ŋio₅ guë́₄ bén₂ a₂'ua₁ dsɨ́₅ Diú₄ a₂cuë₂₃ jniog₄; 'uɨg₅₄ jaun₂ juá'₂ ne₄ Si₂: 
\q1 Nau₂ Diú₄ quein₅ ne₄ dsa₂ i₂jmo₅ tán'₅, 
\q2 la₁ jmo₂₃ 'ua₁ dsɨ́₅ ja₁con₂ dsa₂ i₂jmo₅ me'₂.\f + \fr 4:6 \ft Proverbios 3:34.\f* 
\p  
\v 7 Tión'₂ 'nia'₂ o₄gú₃ Diú₄. Tsá₃ lë₁cuɨ́n₅ 'nia'₂ i₂së₃dsen₃, jaun₂ i₂cuɨng₃ bá₄ 'éi₂ ja₁con'₂ 'nia'₂.  
\v 8 Jme₁quián₄ 'nia'₂ të₂le₃ ja₁con₂ Diú₄, jaun₂ bá₄ jme₃quián₃ 'éi₂ ja₁con'₂ 'nia'₂ ján₃. 'Nia'₂ dsa₂ i₂qui₂rë₂cán'₄ dso₄, rang₂ 'nia'₂ gog'₂; jmo₄ 'nia'₂ le₁jë́₃ të₂'au'₂, 'nia'₂ dsa₂ i₂le₁'ág₄ caun₂-tɨn₃ dsɨ́₅.  
\v 9 Tión'₂ 'nia'₂ quian₂ o₂i₁ dsɨ₅, quɨ'₂-'o₄. Ŋág'₄ quián'₂ 'nia'₂, juɨ₁le₂tsɨ́n₃ juɨ₁le₅₄ a₂quɨ'₂-'áu'₂ 'nia'₂; ján₃ guë'₂ le₂në₅ në₁jua'₂ chan'₂ 'nia'₂ i₂'io'₂ jén'₅, jme₁tsɨ́n₄, tión'₂ 'nia'₂ 'lia'₂ 'au'₂.  
\v 10 Jmo₄ 'nia'₂ meg'₂ të₂le₃ ne₄ Te₁gui'₅₄, jaun₂ bá₄ chó'₂ 'éi₂ táng₃. 
\s1 Diú₄ bá₄ i₂ca₂tɨ́n₂ con₂ 'í₁ 
\p  
\v 11 Rɨn'₅₄ jniog₄, tsá₃ 'ɨ́n₅ 'nia'₂ 'lɨg'₅₄ rɨ́ng'₂ le₂jang'₂ le₂jang'₂. Ia₁ juɨ₁lia'₂ i₂'ɨn₅ 'lɨg'₅₄ jan₂ rɨn'₅₄, o₃ ŋɨ₂₃ qui₂con₂ 'í₁, co₂'nió'₄ 'lɨg'₅₄ bá₄ 'ë₅ 'éi₂ 'Éi'₃ quió'₅ Diú₄, ton'₂ jmo₂₃ dsɨ́₅ tsá₃ 'e₂ quen₅ 'Éi'₃. Ia₁ në₁jua'₂ cáun'₂ 'ne₂ 'í₁ ne₄ 'Éi'₃, co₂'nió'₄ bá₄ a₂ma₂jmo'₂ 'au'₂ ján₃ a₂lɨ́ng'₅ jan₂ i₂'io₅ bí₂ con₂ 'í₁ ne₄ 'Éi'₃ 'nió'₄ a₂jme₁ti'₄ 'ŋiag'₂.  
\v 12 Jan₂ tan₅₄ bá₄ i₂chan₂ i₂ca₂tɨ́n₂ cuë₃ 'éi'₃; i₂'éi₂ bá₄ lɨ́n₅ i₂'io₅ bí₂ dsí₃ 'éi'₃, jaun₂ 'ŋiog₅ bá₄ 'éi₂ në́₃ lé₂ le₃lió₂ o₃ 'liog'₃ 'e₂. La₁ ¿i₂'ein₂ bá₄ 'ne₂? ¿'E₂ lë₃ cáun'₂ 'í₁ quió'₅ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂? 
\p  
\v 13 Në₃ në́₃, nei₂ 'nia'₂ a₂la₂, 'nia'₂ i₂jag₄ juá'₂: “Në₃ o₃ 'ióg₃, dsau₅₄ ciudad në₅, o₃ ciudad ó₃; ja₁jaun₂ dsɨ₁ŋag₅₄ caun₂ ŋi₂ dsɨ₁'nág₁ dsɨ₁jmó₁ 'ma'₅₄ jaun₂ léi₂ cu₄.”  
\v 14 La₁ 'i₁ca₂juɨg₄ tsá₃ jaun₂ ŋi'₅₄ 'nia'₂ 'e₂ lé₂ 'ióg₃, dsi₂juɨ₅ ja₁o₁nóg'₅. Ia₁ juɨ₁lia'₂ lë́₅ caun₂ bë'₅₄ jnei₅ tei₂ bá₄ lɨ́n'₅ 'nia'₂, në₃ jniá₂ 'ei₅, në₃ cón'₅ tsá₃ ma₃cha₂ táng₃.  
\v 15 'Nió'₄ a₂jme₁dsiá'₂ 'nia'₂ jág₁ le₂në₅, le₂la₂ bá₄ ca₂tɨ́n'₂ 'nia'₂ dsiá'₁: “Chi₂jua'₂ le₂jaun₂ 'nio₃ Te₁gui'₅₄ le₃chong₂ jniog₄, jaun₂ bá₄ dsɨ₁jmó₁ a₂la₂ a₂ó₃.”  
\v 16 La₁ 'nia'₂ në́₃, tɨng'₂ dsia'₂ jág₁ tá'₅ jmo'₂ 'nia'₂ róng'₂; ca₂le₃jë́₃ a₂dsia₅ dsa₂ jág₁ le₂në₅, 'lɨg'₅₄ bá₄.  
\v 17 Jaun₂ në́₃, dsa₂ i₂ŋi₅ a₂dse₃ a₂lé₂ le₃jmo₃, la₁ në₁jua'₂ tsá₃ ca₂jmo₃ në́₃, dso₄ bá₄ jaun₂ le₃quió'₅ 'éi₂. 
\c 5  
\s1 A₂rë₂'ë́₂ jág₁ ja₁con₂ dsa₂ cha₂ cu₄ 
\p  
\v 1 ¡Nei₂ 'nia'₂ a₂la₂, 'nia'₂ dsa₂ i₂cha₂ cu₄! Quɨ'₂-'o₄, guio'₅₄ 'nia'₂ o₄quió'₄ ca₂le₃jë́₃ ne₅₄ jmɨ₁uɨg₅ a₂dsɨ₃ŋɨ́'₂ 'nia'₂.  
\v 2 Ca₂le₃jë́₃ a₂cha₂ quián'₂ 'nia'₂ ma₂'áu₁, le₂jaun₂ guë'₂ 'mɨ'₂ a₂quɨ́'₂ 'nia'₂ ma₂quí'₅ i₁cá₁.  
\v 3 Cu₄nióg₄ cu₄tiog₂ quián'₂ 'nia'₂ qui₂ma₂'io₂ juɨ́'₅. Já₅ caun₂ jmɨg₄ jáng'₃ léi₄ juɨ́'₅. A₂në₅ bá₄ a₂co₃dsag₅₄ quián'₂ 'nia'₂, a₂dsiá₃ nɨ₁ŋɨ'₁ 'nia'₂ guiong'₅₄, lé₂ në₂jag₄ bá₄ si₂. Ia₁ 'ŋio₅ lɨn₃ qui₂ma₂dsia'₅₄ 'nia'₂ le₁má'₂ ca₂le₃jë́₃ ne₅₄ a₂cha₂ quiáng'₂, jmɨg₄ jë₁ca₂tó'₂ la₂.  
\v 4 ¡Jag₄! 'Lian'₅₄ dsa₂ i₂qui₂ma₂jmo₃ ta₁ ja₁nau₂ quián'₂ 'nia'₂ 'lian'₅₄ dsa₂ a₂tsá₃ ca₂qui'₅₄ 'nia'₂, guió'₅ 'o₂₃; le₂jaun₂ guë'₂ jág₁ quió'₅ guion₅₄ dsa₂ 'éi₂, ma₂dsi₃lé₂ gua₄ Te₁gui'₅₄ Juɨg₅₄ 'Lióg₂.  
\v 5 Ia₁ 'ŋio₅ lɨn₃ dse₃ jlá'₁ ma₂ca₂rë₃chán₃ 'nia'₂ ne₄ gua'₅₄ 'uë₃ la₂, ma₂qui₂ma₂quian'₂ 'nia'₂ o₂'ŋió₃ o₂jŋia₃ dsɨ₅. Ma₂ca₂jme₁'on'₁ 'nia'₂ lia'₂ 'on'₅₄ ca₁juɨ₅; la₁ já₅ jmɨg₄ ja₁dsián'₃ 'nia'₂ juɨ₁lia'₂ dsan₂ ca₁juɨ₅.  
\v 6 'Nia'₂ ma₂qui₂ma₂'liáng'₃ ma₂ca₂jme₁dsiang'₂ dsa₂ i₂tsá₃ 'e₂ rɨn₂; ¿tsa₁ lɨ́n'₂ 'nia'₂ jŋia'₅₄ dsa₂ 'éi₂ mɨ₃ të₃dsɨ₅₄ 'éi'₃ jmɨg₄ jaun₂?\f + \fr 5:6 \ft o₃, “tsá₃ jua'₅₄ a₂jaun₂ tsá₃ ca₂guen₃ 'éi₂.” \f* 
\s1 A₂chan₂ dsa₂ juɨn'₂ dsɨ́₅ lɨ́in₅ caun₂ chi₁jŋia₂₃ a₂jéin'₃ Diú₄ 'e₂ ma₂mɨ₃ 
\p  
\v 7 Jaun₂ në́₃, rɨn'₅₄ jniog₄, jmo₄ 'nia'₂ juɨn'₂ 'au'₂ ca₂lia'₂ ca₂të́₂ jmɨg₄ i₁guan'₂ Te₁gui'₅₄. Juɨ₁lia'₂ jan₂ dsa₂ i₂jmo₅ ta₁ ja₁nau₂ chi₁jŋia₂₃ ráu₃ dse₃ lɨn₃ ta₁ quió'₅, jaun₂ caun₂ jmo₂₃ juɨn'₂ dsɨ́₅ bá₄ chi₁jŋia₂₃ a₂guá₂ le₂'uɨg₅₄ jmɨ́₅ tiá₄, a₂të₅₄ jein₂ jmɨ́₅ në́₃.  
\v 8 Le₂në₅ bá₄ 'nia'₂ ján₃, jmo₄ 'nia'₂ juɨn'₂ 'au'₂, caun₂ 'éi₂ 'nia'₂ 'au'₂, ia₁ ja₂quián₃ bá₄ jmɨg₄ a₂guan'₂ Te₁gui'₅₄.  
\v 9 Rɨn'₅₄ jniog₄, tsá₃ ma₃o₁le₅₄ 'au'₂ 'nia'₂ jua'₅₄ a₂caun₂ qui₁'nɨ́'₄ guë́₄ 'nia'₂ rɨ́ng'₂ le₂jang'₂ le₂jang'₂, ia₁jaun₂ bá₄ tsá₃ të₃dsɨ₅₄ 'éi'₃ ja₁con'₂ 'nia'₂ guiong'₅₄. Ia₁ juë́₄ i₂qui₃dsɨ₅ 'éi'₃ në₂jag₄ i₂ma₂chén'₅ o₄'né₄ bá₄ 'éi₂.  
\v 10 'Nia'₂ rɨn'₅₄ jniog₄, quian₂ 'nia'₂ juɨ₅ juɨ₁lia'₂ juɨ₅ a₂ca₂can₃ dsa₂ i₂ca₂'ë́₂ jág₁ quián₅ Te₁gui'₅₄ ma₂lɨ́g'₂. Ca₂rë₃juɨ́n'₃ dsɨ́₅ ne₄ ca₂le₃jë́₃ jmɨ₁uɨg₅ a₂ca₂i₃ŋɨ́i₂.  
\v 11 Jag₄ jaun₂, jmo₂ jniog₄ dsɨ₅, 'e₂ guë́₄ dsen₃ dsa₂ i₂ca₂nau₂ tiá₂ 'éi₂. Ján₃ bá₄ ŋi'₅₄ 'nia'₂ 'a₂ lia'₂ ca₂rë₃juɨ́n'₃ dsɨ́₅ Job, ca₂nau₂ tiá₂, ton'₂ ŋi'₅₄ bá₄ 'nia'₂ ján₃ 'a₂ lia'₂ ca₂jme₃gu'₅₄ táng₃ Te₁gui'₅₄ quió'₅ 'éi₂ jë₁ca₂tó'₂. Ia₁ le₂në₅ bá₄ jau'₂ 'í₁ i₂'ua₁ dsɨ́₅ lɨn₃ bá₄ Te₁gui'₅₄, ton'₂ ŋéi₂ dsɨ́₅. 
\p  
\v 12 Le₂në₅ bá₄, jmo₄ 'nia'₂ ne₄ ca₂le₃jë́₃, rɨn'₅₄ jniog₄, juɨ₁lia'₂ jme₁dsia'₂ 'nia'₂ jág₁, tsá₃ lë₁'ë₂ 'nia'₂ guei'₅₄ i₂juɨ́g₃, on₃ guë'₂ 'ë₂ 'nia'₂ gua'₅₄ 'uë₃, on₃ guë'₂ 'i₁caun₂ cosa siá'₂ a₂lë₁'ë́'₁ 'nia'₂ jua'₅₄ a₂'ɨ́ng'₄ Diú₄. Jë₁ma₂të́₂ rë₁dsiá'₁ 'nia'₂ jág₁, jua'₅₄ 'nia'₂ “ján₅”, juɨ₁le₂ti₃ bá₄ “ján₅” jaun₂; ján₃ bá₄ le₂në₅ juɨ₁lia'₂ jme₁jua'₂ 'nia'₂ “jan₂'ón₄”, juɨ₁le₂ti₃ bá₄ “jan₂'ón₄” jaun₂, ia₁jaun₂ tsá₃ të₃dsɨ₅₄ 'éi'₃ ja₁con'₂ 'nia'₂. 
\p  
\v 13 Në₁jua'₂ 'ein₂ 'nia'₂ chan₂ o₂i₁ dsɨ₅, juɨ₁chi₂lén'₂ ne₄ Diú₄. Në₁jua'₂ 'ein₂ guë'₂ chan₂ i₂'ei₅ dse₃ dsɨ́₅, juɨ₁'ë₁₂ son₅₄ a₂rë₂juɨn'₂ Diú₄.  
\v 14 Në₁jua'₂ chan₂ 'ein₂ i₂dso'₅₄, ca₂tɨ́in₂ të́'₂ dsa₂ can'₅₄ quián₅ guá'₅,\f + \fr 5:14 \ft griego: presbúteros.\f* ia₁jaun₂ chi₃lén'₂ 'éi₂ Diú₄ ne₄ quió'₅, jaun₂ tsáng₂ no'₅₄ lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ Te₁gui'₅₄.  
\v 15 Ia₁ jë₁chi₂lén'₂ dsa₂ Diú₄ a₂'éin₂ të₃dsón'₂, 'lión₂ dsa₂ dso'₅₄; chó'₂ bá₄ Te₁gui'₅₄. Në₁jua'₂ 'e₂ dso₄ ma₂táin'₂ në́₃, 'én₂ bá₄ dsáu₁.  
\v 16 Jaun₂ lë₃, jme₁jnia₅ 'nia'₂ ne₄ rɨ́ng'₂ 'e₂ ma₂qui₂ma₂'lian'₂ 'nia'₂, ján₃ guë'₂ chi₂len'₄ 'nia'₂ Diú₄ o₄quió'₄ rɨ́ng'₂ le₂jang'₂ le₂jang'₂ ia₁jaun₂ 'lión'₂ 'nia'₂. Ia₁ juɨ₁lia'₂ dsa₂ i₂tión₂ rë₂ ne₄ Diú₄, 'io₅ bí₂ jág₁ quió'₅ 'e₂ caun₂ a₂mɨ₂₃ ne₄ Diú₄.  
\v 17 Elías jme₁lɨ́n₄ jan₂ dsa₂ lia'₂ lág₅ jniog₄; jme₁ca₂mɨ₃ jë₄ chi₂léin'₂ Diú₄ a₂co₂ŋei'₅₄ tsá₃ ma₃téin₃ jmɨ́₅, jaun₂ 'nɨ₅ ŋi₂ të₂ ca₂dsio₄ tsá₃ ma₃jmɨ́₅ ca₂tang₂ ne₄ gua'₅₄ 'uë₃.  
\v 18 Cang₂ jaun₂, ca₂mɨ₃ táng₃ ne₄ Diú₄, jaun₂ ca₂tang₂ táng₃ jmɨ́₅, ca₂rau₂ táng₃ ne₄ gua'₅₄ 'uë₃. 
\p  
\v 19 'Nia'₂ rɨn'₅₄ jniog₄, në₁jua'₂ chan₂ 'nia'₂ i₂dsɨ₂cón'₅ dsɨ́₅ juɨ₅ dsau₅, në₁jua'₂ jan₂ guë'₂ i₂ca₂jéin'₂ táng₃,  
\v 20 dsá₂ 'au'₂ 'nia'₂ jmo₄ a₂la₂: juɨ₁'ein₂ guë́₃ i₂jén'₂ jan₂ dsa₂ i₂rë₂cán'₄ dso₄ juɨ₅ 'lɨg'₅₄ a₂jme₁ma₂ŋó₅, lióin₂ jme₂dsí₂ quió'₅ 'éi₂ ne₄ 'mú₃, jaun₂ le₂në₅ jlë́₂ 'lióng₂ dso₄ dsɨ₂'én₂ në́₃. 
\p Co₂në₅.