\id ZEC - Tarok
\h Nlir aZakariya
\toc3 aZak
\toc2 aZakariya
\toc1 Nlir aZakariya
\mt1 Nlir aZakariya
\c 1
\s1 Awór pa̱ mmá le atak Inan
\p 
\v 1 Ka̱ ashe apye aga ana̱nne ka̱ ìzun iga iparəm va uDariyut ka̱ ya uponzhi uga mbin àPashiya te, uYawe là nnàp uZakariya unəm uga nlà ìchu Inan, uya aBerekiya uka aIddo.
\p 
\v 2 <<UYawe Ká̱ yà ka̱ nlak ìgwak ka̱ apal okəka̱ ɓu byet.
\v 3 Ka̱kul nva̱ ta te, là oza̱ pa̱, uYawe uga nggatək là pa̱, <O le o ɓa atak mi,> <te mi le atak wo kpa.>
\v 4 Kang o yà wa okəka wo omatmat va yang ka̱ nggwong achwang ka̱ onəm oga nlà ìchu Inan ova̱ là oza̱ pa̱, iya̱m va ta̱ uYawe uga nggatək là pa̱, <O ma̱n te o ga̱ɓa̱n o re nnap nnəm mɓá̱ngɓa̱ng ka̱ asa̱l iya̱m inga, nna kang o gwong achwang kà̱ mi ka̱t.>
\v 5 Okəka wo ká̱ onəm oga nlà ìchu Inan ka̱ che ǹyangmata̱ yà? Oza̱ təm ká̱ irirì ghar mbyet ɗò?
\v 6 ká̱ nnà te nkpaktak nnap nla mi ka̱ nɗyang mi nva̱ n nak ózwal mi onəm oga nlà ìchu Inan te, á ɓa fa ka̱ apal ishi okəka wo dakdak wa nva n là pa̱ i ga ǹya oza̱ ka̱t ɗò? Nna chit te, oza̱ re iya̱m iɓá̱ngɓa̱ng oza̱ ɗak. Oza̱ i là pa̱, <I ka̱m amwa iya̱m va̱ chit i ram ka̱ atak aYawe uga nggatək, iya̱m va uza̱ là pa̱ o ga nnənəm á.> >>
\s1 Alár ipəri va uZaka̱riya ya à
\p 
\v 7 Kà̱ nra ìsəm pa̱ iparəm ama̱n pa̱ neɗing ka̱ ashe apye ga gba̱pchi ama̱n pa̱ zəng, ka̱ ashe ìzun iponzhi aDariyut iga iparəm te, uYawe là nnàp uZaka̱riya unəm uga nlà ìchu Inan, uya aBerekiya uka̱ aIddo.
\p 
\v 8 Ka̱ ìzwam ka̱ ashe alár te, n ya unəm ka̱ apal ipəri irəzang sat ka̱ ishimshe oga ikún aMa̱tel va ka̱ ashe aba̱nda̱m. Kang ka̱ nsəsəm te, ipəri irəzang ka̱ iva̱ ɓán pa̱ gà̱r, ka̱ íləfər ka̱ onəm oga nkukwák ka̱ apal oza̱.
\p v
\v 9 Te n ɓəp uma̱leka va̱ ka̱ ǹla nnap ká̱ mi pa̱, <<ANəm ga nzhi mi, oga iza̱ ta̱ yà?>> Te uza̱ na ama̱n á mi pa̱, <<Mi ga nnyám ipipir a ɓu.>>
\p 
\v 10 Te unəm va̱ sat ka̱ ishimshe oga ikún va̱, na ama̱n pa̱, <<Onəm oga ipəri ta̱ te, oma uYawe re pa̱ á ga á sóng apambin á.>>
\p 
\v 11 Te onəm oga ipəri va̱ tong ka̱ ishimshe íkun là uma̱leka aYawe pa̱, <<Í ga í song apambin chit, kang nkpaktak apambin ka̱ njul ka̱ ashe ikángkáng>>.
\p 
\v 12 Te uma̱leka aYawe là pa̱, <<ÁYawe uga nggatək, ìzun chit ìsəm pa̱ ìfangshat ǹyangmata̱ mmaɓu ka̱ nlak ìgwak ka̱ apal aUrushelima ka̱ oga oga ítong aYahudi. Te a ɓur nra pa̱ npəching kang ɓu nyám nrwa ìgwak ɓu oza̱ yà?>>
\v 13 Te uYawe na ama̱n aga sak, ka̱ nrwa ìgwak úmaleka̱ va̱ ka̱ nlà nnàp ka̱ na.
\p 
\v 14 Te uma̱leka va̱ ta là á mi pa̱, <<Là nnap va̱ ta̱ ka̱ ichu pa̱ gbá̱ngbá̱ng na nkpaktak onəm á fe. <UYawe uga nggatək là pa̱, mma̱n mi ka̱ apal aUrushelima ka̱ aɓam aSiyona mak byet.
\v 15 Igwak làk mi byet ka̱ mbín va̱ təm pa̱ shat. Ka̱kul ka̱ ashe nra va̱ na ka̱ ǹya ka̱ nlak ìgwak pa̱ ɗa̱p ka̱ apal ishi onəm mi te, oza̱ nyám idumdùm onəm mi ga watar ǹzam.>
\p 
\v 16 Ka̱kul nva̱ ta te uYawe là pa̱, <<N le chit pa̱ n nyám nrwa ìgwak ka̱ apal ishi aUrushelima . Mí ga mme nzhi mi kà̱ɗi , asang ga mme nzhi i watar ka̱ apal aUrushelima .>>
\p 
\v 17 Umaleka̱ là á mi pa̱, n là kà̱ɗi pa̱, iya̱m va ta̱ uYawe uga nggatək là, <<Oga oga ítong iga aIsa̱rila i ga ǹyə́l kà̱ɗi , i dur i watar ǹzam. UYawe i ga nnyam nrwa ìgwak aSiyona kang i yak aUrushelima i sat ajuwo.>>
\s1 Agbəshi pa̱ neɗing ka̱ onəm oga là pa̱ oneɗing
\p 
\v 18 N dər apal te, n ya oga agbəshi pa̱ neɗing.
\v 19 Te n ɓəp uMa̱leka̱ va̱ ka̱ nlà nnàp ká̱ mi pa̱, <<Oga iza̱ ta̱ yà?>> Te á na ama̱n á mi pa̱, <<Oga agbəshi va ta̱ oma lyangshin aYahudi ka̱ aIsa̱rila ka̱ aUrushelima .>>
\p 
\v 20 Te uYawe nyám onəm oga ala á mi pa̱ oneɗing.
\v 21 Te n ɓəp pa̱, <<Iza̱ ova̱ ta̱ i ɓa nnənəm yà?>> Te uza̱ na ama̱n pa̱, <<Oga agbəshi va ta̱ lyangshin aYahudi pa̱ kang á gha̱p ishi ka̱t. Onəm oga lá va̱ ta̱ ɓa pa̱ na o gbək oga agbəshi à tàk, na o chwan oza̱.
\c 2
\s1 Alár Asang aga mmàl Atak
\p 
\v 1 N dər apal kà̱ɗi te, n ya unəm sat ka̱ asang aga mmàl atak ka̱ awo wò.
\v 2 Te n ɓəp pa̱, <<Ɓu ga che yà?>> Te á ma̱n á mi pa̱, <<Mmami ka̱ ngga mmàl na n dər mbal aUrushelima ka̱ ngwuwang.>>
\p 
\v 3 Á gba̱ng nva̱ng ka̱t te, uma̱leka va̱ ka̱ yà ka̱ nlà nnàp ká̱ mi te, á re atak mi pa̱ na o gwang uma̱leka uro va ka̱ mɓa atətak à.
\v 4 Kang uma̱leka va̱ ta là á na pa̱, <<Chəchir ga ɓu là uyenza̱m va̱ cho ka̱ asang pa̱, <Nggatək onəm ka̱ iya̱m nkang va̱ i ga ǹya ka̱ aUrushelima te mɓwaka̱n ka̱t. Ka̱kul nva̱ ta te, mí chu nggəgang ka̱ aka̱msəlang ka̱t.
\v 5 UYawe là pa̱, Mi yà aka̱msəlang apər va i gang na pa̱ kpaktak,> kang mi təm ka̱ ichumchum mi ka̱ ashishe.>>
\s1 Ma wór Onəm ga ngga Izwal pa̱ uza̱ à le Nzhi
\p 
\v 6 UYawe là pa̱, <<O wong o ching o ɓa, o re mbin ngga mpal ka̱kul n lyangshin wo chit ka̱ ashe mbín pa̱ ɗongɗong.>>
\v 7 Re o ching o ɓa aUrushelima , mmawó va̱ o təm izwal ka̱ ashe mbin aBabel a.
\v 8 UYawe uga nggatək là pa̱, <<Ka̱kul ichumchum mi te, uza̱ re mi ka̱ ǹre ka̱ atak mbín va̱ vyat wo. Uza̱ là pa̱, unəm va pa̱ kpaktak dok wo te, ya uza̱ dok ipir iwu wò.
\v 9 Mi ga nnak awo mi ka̱ apal oza̱, ozwal oza̱ i vyat oza̱ i na idumdùm oza̱.>> Nna chit te, o nyi pa̱ uYawe uga nggatək à re mi.
\p 
\v 10 UYawe là pa̱, <<Ónəm oga aUrushelima , re o shì nnap-nshì ka̱ nchang ìgwak ka̱kul mi ga mɓa ntəm nzəng ká̱ wo.>>
\v 11 Ka̱ ilum va̱ ta te, onəm oga apambin pa̱ makmak i gwang ishi oza̱ ka̱ uYawe, oza̱ i yà onənəm, te uza̱ i təm ka̱ ashe oza̱, kang o nyi pa̱ uYawe uga nggatək à re mi ka̱ atak wo.
\v 12 UYawe i wur iya̱nkúp ka̱ mbin oYahudi va ka̱ ashe mbin nnəna̱n i ya njiwo, kang i yak aUrushelima kà̱ɗi i sat oga ítong wo ìgorgor.
\v 13 Re nkpaktak onəm á má̱ng pa̱ kwák ka̱ mpyal aYawe, ka̱kul uza̱ wong chit ka̱ atak ntəm wò nnəna̱n.
\c 3
\s1 Alár ka̱ apal aNəm ga nshì Iya̱m Awop uChumchum
\p 
\v 1 Te uYawe nyám uJoshuwa, unəm ga mpyal awop uchumchum á mi, ka̱ nsat ka̱ mpyal amaleka̱ aYawe. Ushetan nnyi te, ka̱ nsat ka̱ awo ari amaleka̱ ka̱ nlà inga va uJoshuwa nəm á.
\v 2 Te uYawe là uShetan pa̱, <<Mmami uYawe, n yang ka̱ inga aYoshuwa va̱ ma ɓu ka̱ nləla á. Mmami va̱ n yak aUrushelima te, mmami ka̱ nra̱n ká̱ ɓu aShetan. Unəm va̱ ta̱ wa akun va mmá tutur ka̱ ashe apər asálsál ka̱t ɗò?
\p 
\v 3 Ilukwan aYoshuwa ka̱ yà idakdak kang uza̱ ka̱ yà ka̱ nsat ka̱ mpyal ama̱leka.
\v 4 Te uma̱leka là ovəngva̱ tong ka̱ mpipyal pa̱, <<O zəp oga ìlukwan idakdak va̱ ta.>> Te uza̱ ga̱ɓa̱n là ûJoshuwa pa̱, <<Dər, n yar nnap mɓá̱ngɓa̱ng ɓu a ɓu chit, mi ga nna ílukwan ipipye, inəna̱n a ɓu.>>
\p 
\v 5 Te n là pa̱, <<Oza̱ á chip iya̱m inəna̱n á na ka̱ ishi.>> Te mmá chip iya̱m inəna̱n á na ka̱ ishi kang mmá sham ishàm á na, yà uma̱leka aYawe wa yà sat ka̱ ta.
\p 
\v 6 Te uma̱leka aYawe là nnap-nlà nɗəkɗək ngga nkàm irəng ûJoshuwa pa̱,
\v 7 <<Iya̱m va ta̱ uYawe uga nggatək là, <A yà pa̱ u yar asa̱l mi kang u kpak oga iya̱m va̱ n ɗom te, mi ga nna nkpán nzhi mi a ɓu. Kà̱ɗi te, ɓu kpán nzhi akwali mi kang ɓu yà unəm uga ntar ka̱ nfa ka̱ ishimshe ova̱ tong ta̱.>
\p 
\v 8 << <O gwong achwang ǹyangmata̱ áYoshuwa unəm uga mpyal awop uchumchum ka̱ nkpaktak wo onəm oga mpyal awop. O tong wa iya̱m inəna̱n va i ga mɓa. I gba̱ng nva̱ng ka̱t te, mi ga mɓa ka̱ uzwal mi, uwa Igong á.
\v 9 O dər ipáng va̱ n pak ka̱ mpyal aJoshuwa pa̱ izəng kang ká̱ asa̱l awu pa̱ fangshat. Mi ga nlir iya̱m ka̱ apəpal> kang mi yar nnap mɓá̱ngɓa̱ng onəm oga mbín va̱ ta̱ ka̱ ashe nra pa̱ nzəng.
\p 
\v 10 UYawe uga nggatək là pa̱, << <Ka̱ nra va̱ ta te, ka̱kul ntəm ikángkáng te, nza̱ uzəngtəng wo nggo te, i chál unəm uga ngba̱k nzhi wò pa̱ á ɓa á təm nzəng ka̱ wò ka̱ akum ikún ìba̱ngba̱ng ka̱ ipipyan wò.> >>
\c 4
\s1 Alár ka̱ apal iya̱m i ga ncèr Apitila
\p 
\v 1 Te uma̱leka va̱ ka̱ là nnap ká̱ mi le ɓa yenda̱l mi wa nva mmá yenda̱l unəm ka̱ ìwu ndá.
\v 2 Uza̱ ɓəp mi pa̱, <<Iza̱ u ya yà?>> Te n ma̱n pa̱, <<N ya iya̱m iga ncèr apitila aga azənariya ka̱ asù aga nnak mmì ka̱ apəpal ka̱ oga aPitila pa̱ fangshat gang ka̱ anung asu va̱ ta. Nza̱ aPitila nggo te, ka̱ ídari iga mɓol pa̱ ifangshat va mmì ka̱ ngbat ngga mmá̱l apər i táng ka̱ ashishe.
\v 3 Kang íkun mpyet tong pa̱ iparəm ka̱ ngba̱k iya̱m iga ncèr apitila va̱ ta. Iro ka̱ awo ari, kang iro ka̱ awo apa̱m.>>
\p 
\v 4 Te n ɓəp na pa̱, <<Oga iza̱ ta̱ yà ánəm ga nzhi?>>
\p 
\v 5 Uma̱leka va̱ ta na ama̱n á mi pa̱, <<U nyi iya̱m ta̱ ka̱t ɗò?>> Te n ma̱n pa̱, <<N nyi ka̱t ánəm ga nzhi.>>
\p 
\v 6 Te uza̱ là á mi pa̱, iya̱m va ta̱ uYawe là uZerubabel pa̱, <<Ka̱ ikàm ka̱t, kang ka̱ ngga̱r ka̱t, ka̱ atak aRuhu mi na chwat.
\p 
\v 7 <<Áɓam achumchum, mmaɓu iza̱ ka̱ mpyal aZerubabel yà? Ɓu ga nshìn ɓu məlkən wa mbin. Te uza̱ i nak ipáng iga̱ nka̱r anung nzəng ka̱ nnə́m acú onəm pa̱, <Inan á nak nnap nnəna̱n kà̱, Inan á nak nnap nnəna̱n kà̱.>
\p 
\v 8 Te uYawe là nnap á mi pa̱,
\v 9 <<UZerubabel uwa pak aka̱m nzhi va̱ ta̱ kang uza̱ uwa i ga ngba̱l ka̱ mmime.>> Te o nyi ɗak pa̱ uYawe uga nggatək uwa re mi kà̱ wo.
\p 
\v 10 Onəm va̱ byet nra iya̱m ga mɓan pa̱ ɗa̱p áta̱ te, oza̱ i ga ǹyà ka̱ nchang ìgwak ka̱ nva̱ngva̱ oza̱ i ya asang aga mmàl atak ka̱ awo aZerubabel á. <<Oga apitila aga afangshat va̱ ta̱ te, á sat wa oga iwú aYawe va i dər nkpaktak apambin.>>
\p 
\v 11 Te n ɓəp pa̱, <<Iza̱ ipir oga íkun mpyet iga iparəm va̱ ta̱, ìro ka̱ awo ari kang ìro ka̱ awo apəra̱m ka̱ ngba̱k iya̱m iga ncèr apitila yà?
\v 12 Kà̱ɗi te, iza̱ ipir oga ígong mpyet iga iparəm va̱ ka̱ ngba̱k ídari azənariya aga aparəm va̱ mmì i vàng ka̱ yà?>>
\p 
\v 13 Te uza̱ ɓəp mi pa̱, <<U nyi iya̱m ata̱ ka̱t ɗò?>> Te n ma̱n pa̱, <<N nyi ka̱t ánəm ga nzhi.>>
\p 
\v 14 Te uza̱ là á mi pa̱, <<Ígong iga iparəm ata̱ oma ka̱ɗor onəm gargar pa̱ oparəm va mmá yak pa̱ á nəm inok uNəm uga Nzhi uga nkpaktak apambin.>>
\c 5
\s1 Alár Iya̱m Nlir ka̱ Izər Awa achindərchindər
\p 
\v 1 N wong ka̱ iwu ka̱ apal kà̱ɗi te, n ya nnap-nlà va mmá lir ka̱ apal awá kang mmá chəndər, ka̱ ǹyel ka̱ apaɓur.
\p 
\v 2 Te uma̱leka va̱ ta ɓəp mi pa̱, <<Iza̱ u ya yà?>> Te n là pa̱, <<N ya nlir ngga apal awa nchəndərchəndər, ngwuwang ashar ìsəm pa̱ ishatɗing kang mbəbal ashar pa̱ gba̱pchi ama̱n pa̱ tukun ka̱ ǹyel ka̱ apal.>>
\v 3 Te uza̱ là á mi pa̱ <<Iya̱m nlir nchəndərchəndər ngga awá va̱ ta̱ ka̱ nlà ka̱ ngba̱k nro pa̱, nkpaktak unəm va̱ i nəm ayi te, mí ɓak na i fa, nro là pa̱, unəm va̱ i sóng anung ka̱ akwam te mí ɓak na i fa kpa.>>
\v 4 UYawe uga nggatək là pa̱, <<Mi ga ǹre ǹre ka̱ nvyap ata̱ ka̱ ashe nzhi à nza̱ unəm nggo, uga ayi ka̱ uga nsóng anung ka̱ akwam ka̱ ashe aɗin mi. Iya̱m va̱ ta̱ i fa ka̱t, i təm ka̱ ashe nzhi va̱ ta i chwan oga akun ka̱ oga ipáng va̱ mmá me nzhi ata ka̱ kang.>>
\s1 Alár Achar ka̱ ashe Anàp
\p 
\v 5 Te uma̱leka va̱ ka̱ yà ka̱ nlà nnàp ká̱ mi te, á fa là á mi pa̱, <<Wong ka̱ iwu dər iya̱m va̱ kà̱ ngga nfa.>>
\p 
\v 6 N ɓəp pa̱, <<Iza̱ ta̱ yà?>> Te uza̱ na ama̱n pa̱, <<Nkatəp ngga mmá iya̱m à fa, kang ashishe yə́l ka̱ oga nnap mɓá̱ngɓa̱ng apambin.>>
\p 
\v 7 Ma bol anung aɗəkɗək aga nkatəp va̱ ta te, n ya uchar təm ka̱ ashishe.
\v 8 Uma̱leka là pa̱, <<Uchar va̱ ta̱ sat ka̱ɗor iya̱m iɓá̱ngɓa̱ng.>> Te uza̱ da̱n na tar ka̱ ashe nkatəp va̱ ta kang à gún ka̱ anunung aɗəkɗək va̱.
\p 
\v 9 N wong ka̱ iwu te, n ya ochar pa̱ oparəm fa ka̱ ashe ìlulu, i yel i ɓa. Ayir ka̱ mpyep alyang oza̱. Oza̱ ka̱ alyang wa alyang oga igúlyat. Te oza̱ ɓa yar nkatəp va̱ ta, oza̱ wong ka̱ ɓa ga apaɓur.
\p 
\v 10 Te n ɓəp uma̱leka va̱ ka̱ nlà nnàp ká̱ mi pa̱, <<Oza̱ yar nkatəp va̱ ta̱ i ga ka̱ kà̱ che yà?>>
\p 
\v 11 Uza̱ là á mi pa̱, <<Oza̱ ka̱ ngga ka̱ kà̱ mbin aBabel, atak va̱ oza̱ i ga mme nzhi á na ka̱, kang ka̱ nva̱ngva̱ oza̱ i gba̱l ka̱ mme nzhi va̱ ta te, oza̱ i nak na ka̱ atak nchəcher.
\c 6
\s1 Alár oga Akeke va Ipəri i dap
\p 
\v 1 N wong ka̱ iwu kà̱ɗi te, n ya oga akeke ipəri pa̱ neɗing ka̱ mɓa ka̱ ishimshe oga aɓam acham ɓan pa̱ pa̱rəm.
\v 2 Akeke aga nggəshi te, ipəri írəzang i dap, apəpar te, ipəri íləbər,
\v 3 aga shatɗing te, ipəri íləfər, aga aneɗing te, ipəri va ra̱p írukwang i dap.
\v 4 Te n ɓəp uma̱leka va̱ ka̱ yà ka̱ nlà nnàp ká̱ mi pa̱, <<Iza̱ ta̱ ya, ánəm ga nzhi mi?>>
\p 
\v 5 Te uma̱leka na ama̱n á mi pa̱, <<Oma ta̱ oga ayir ga neɗing aga apaɓur va̱ fa ka̱ atak nnyám ishi oza̱ unəm va̱ ka̱ ichumchum nkpaktak apambin.
\v 6 Akeke va̱ ka̱ oga ipəri íləɓər te, kà̱ ngga asa̱l mpal. Akeke va̱ ka̱ oga ipəri íləfer te, kà̱ ngga asa̱l awu ntar alum. Akeke va̱ ka̱ oga ipəri írukwang nnyi te, kà̱ ngga asa̱l nkwandal.>>
\p 
\v 7 Izər wú oga ipəri ikamkam va̱ ta̱ ka̱ nfa pa̱ o ra nggang ka̱ apambin. Te uma̱leka là oza̱ pa̱, <<O ga o ra nggang ka̱ apambin.>> Te oza̱ ra nggang ka̱ apambin ɗak.
\p 
\v 8 Te uza̱ wór mi pa̱ gbá̱ngba̱ng á là pa̱, <<Dər ovəngva̱ ga asa̱l mpal te, oza̱ nak aRuhu mi chit ka̱ ashe nra ìgwak ka̱ mbin ngga asa̱l mpal.>>
\s1 Atagya iponzhi ka̱kul aYoshuwa
\p 
\v 9 Te uYawe là á mi pa̱,
\v 10 <<Ga nzhi aYosiya uya aZafaniya, na u ka̱m azənariya ka̱ aazurfa ka̱ atak áHeldiya, ka̱ uTopiya, ka̱ uYedaya, oma le ka̱ atak izwal ka̱ aBabel á. Ka̱ nda nzəngtəng va̱ ta te,
\v 11 wa yar azənariya ka̱ aazurfa va̱ ta wa nəm atagya iponzhi ka̱ na u pá ûJoshuwa unəm ga mpyal awop uchumchum, uya aYehoza̱dak ká̱.
\v 12 Te ɓu là á na pa̱, uYawe uga nggatək là pa̱, <Unəm va aɗiɗin pa̱ Igong te, uza̱ i ghak ka̱ atak va̱ uza̱ ka̱, uza̱ i me nzhi ngga ngwop uYawe.
\v 13 Uza̱ i ga mme nzhi ngga ngwop uYawe, kang mi na atak ntəm nchumchum á na, i nəm iponzhi ka̱ apal itok wò. Unəm uga mpyal awop uro uwa i ya i sat ka̱ mbəp itok iponzhiponzhi kang nɗak atak nro i ya ka̱ ishimshe oza̱ ka̱t.>
\v 14 Atagya iponzhi va̱ ta̱ mí nak ka̱ ashe nzhi ngga ngwop uYawe, ka̱kul na á sat iya̱m irəngrəng ûHeldiya, ka̱ uTopiya, ka̱ uYedaya, ka̱ uYosiya, uya aZa̱faniya.
\v 15 Onəm i fa pa̱ gbà̱ngba̱ng i ɓa i me nzhi ngga ngwop uYawe, nna chit te ɓu nyi pa̱ uYawe uga nggatək à re mi ka̱ atak ɓu. Iya̱m va̱ ta iga ǹyə́l a yà pa̱ o gwong achwang ka̱ ichu aYawe, Inan wo á.>>
\c 7
\s1 Nva̱n Nnanda̱r ka̱ Nnyám Nrwa Igwak
\p 
\v 1 UYawe là nnàp uZakariya, ka̱ ashe ìzun iga ineɗing iga iponzhi aDariyut ka̱ apal nra ngga nneɗing ka̱ apye aga afangzəngtəng pa̱,
\v 2 onəm oga aBetel re uShareza chit ka̱ uRegem-Melek nzəng ka̱ onəm pa̱ oza̱ á ga á chál nrwa ìgwak aYawe.
\v 3 Oza̱ á ɓəp onəm oga mpyal awop ka̱ nzhi aYawe uga nggatək, ka̱ onəm oga nlà ìchu Inan pa̱, <<I ga mpyal ka̱ nnyám nlak ìgwak ka̱ atak ndáng ishi yi ka̱ ndəng ngwa ka̱ iya̱m-nrì, ka̱kul nrəng ka̱ nshin nzhi aYawe ka̱ apye aga atukun wa nva̱ ka̱ i nəm ka̱ ízun va̱ watar matmat ɗò?>>
\p 
\v 4 Te uYawe uga nggatək là nnap ká̱ mi pa̱,
\v 5 <<Là nkpaktak onəm oga mbín ka̱ onəm oga mpyal awop pa̱, <Nva̱ o dáng ishi wo ka̱ nrì ka̱ ngwa, kang o nyám nlak ìgwak ka̱ apye aga tukun ka̱ aga afangshat ka̱ ashe ízun ìsəm pa̱ ìfangshat va̱ watar te, ka̱kul mi na ɗò?
\v 6 Kang nva̱ mmawó ka̱ nrì ka̱ ngwa te ka̱kul nchang izər wo ka̱t ɗò?
\v 7 Oga nnap-nlà va ta̱ uYawe ka̱ là ka̱ atak onəm oga nlà ìchu Inan omatmat ka̱ ashe nra va̱ aUrushelima ka̱ ashe idur, kang oga oga ítong va̱ ra gang na, aNegep ka̱ aShefela ka̱ yə́l ka̱ onəm ka̱t ɗò?> >>
\p 
\v 8 Te uYawe là nnap uZakariya kà̱ɗi pa̱,
\v 9 <<Ó nap akwali aga nnandər ka̱ nnyi nnap, ka̱ nnyám nrwa ìgwak owan wo.
\v 10 Kang o mwar ochar okpələng, ka̱ ovan okpələng, ka̱ uɗyanəm, ka̱ onəm oga nkun ka̱t. Kang o mar iya̱m iɓá̱ngɓa̱ng ka̱kul owan wo ka̱ ashe ìgwak ka̱t.>>
\p 
\v 11 ká̱ nnà te, oza̱ yang ka̱ nggwong achwang , oza̱ nyám nkak ishi, kang à zwan achwang pa̱ kang o fe ka̱t.
\v 12 Oza̱ nak igwak oza̱ twat ka̱kul pa̱ kang o fe nnap mpakpak, ka̱t te nnap-nlà aRuhu aYawe uga nggatək va re ǹre ka̱ ka̱ atak onəm oga nlà ìchu Inan omatmat á. Ka̱kul nva̱ ta te, ìgwak làk uYawe uga nggatək pa̱ makmak.
\p 
\v 13 UYawe uga nggatək là pa̱, <<Wa nva n wór oza̱ kang oza̱ yang ka̱ nfife te, wa nnà ta kpa a yà pa̱ oza̱ i wór awór te, mi yang ka̱ nfife.>>
\v 14 Te n lyangshin oza̱ pa̱ kpaktak ka̱ ǹvivyil ga ashe mbín va oza̱ nyi ka̱t. Mbin va̱ oza̱ re te à təm agúng. Unəm uro yà uga ngga ka̱ ǹle ka̱ ashishe ka̱t. Mbin va nnəna̱n te, à təm agúng.
\c 8
\s1 UYawe yar Nsar Nnap nlà ngga Nnap nnəna̱n aUrushelima
\p 
\v 1 Nnap nlà aYawe uga nggatək ɓa atak mi pa̱,
\v 2 <<Mmami ka̱ ìkpar ka̱ apal aSiyona, ìkpar imakmak, ìkpar iga nshì ìgwak.
\p 
\v 3 Mi le aSiyona, mi təm ka̱ ashe aUrushelima , te mí wór aUrushelima pa̱ oga ítong iga nnandər, kang <Aɓam aYawe uga nggatək> nnyi te mí wór pa̱, <Aɓam ayə́ryər.> >>
\p 
\v 4 UYawe uga nggatək là pa̱, <<Onəm gbakgbàk ká̱ ochar dúngdung va̱ i chen ká̱ ídari ka̱kul mmák nra oza̱ te, i ga ntəm ka̱ oga ágəntəng aUrushelima kà̱ɗi .
\v 5 Kang ovanza̱m ká̱ ovan ɓyen i yə́l oga ágəntəng aga oga ítong ata i nəm nsal ka̱ ashishe.
\p 
\v 6 UYawe uga nggatək là pa̱, <<A yà pa̱ á yà iya̱m iga nɗaktak ka̱ atak aɓo onəm ata̱ ka̱ ashe oga nra va̱ ta te, i ga ǹyà iya̱m iga nɗaktak na ka̱ atak mi kpa ɗò?>>
\p 
\v 7 UYawe uga nggatək là pa̱, <<Mmami kà̱ ngga nfa ká̱ onəm mi ka̱ mbín ngga asa̱l awu alum ká̱ ngga asa̱l ntar alum.
\v 8 Kang mi ɓa ká̱ oza̱ i təm ka̱ ashe aUrushelima , oza̱ i yà onəm mi, kang mi yà Inan oza̱ ka̱ ashe nnəm nnandər ká̱ inəna̱n.>>
\p 
\v 9 UYawe uga nggatək là pa̱, <<Igwak akam wo, mmawó va̱ ǹyangmata̱ ka̱ nfe oga nnap-nlà va onəm oga nlà ìchu Inan ka̱ là ka̱ ashe oga nra va̱ cho, ya mmá kà̱ mbang akum mme nzhi aYawe kà̱ɗi .
\v 10 Kang nra va̱ ta ì chu te, amwa yà ka̱kul onəm ká̱ oga iya̱m nkang ka̱t. Unəm va̱ fa agbai ká̱ unəm va̱ tar ashe te, nra ìgwak yà á na ka̱ atak ánəm uga nkpàng na ka̱t, ka̱kul n nak nza̱ unəm nggo yáng uwangwò.
\v 11 Kang ǹyangmata̱ te, mi yà ka̱ nnəm ìɓà̱ng aɓo onəm mi wa nva̱ ka̱ n nəm oza̱ lap ka̱t,>> uYawe uga nggatək à là.
\p 
\v 12 Oza̱ i suk iya̱m oza̱ ka̱ ashe ikángkáng, ìba̱ngba̱ng i ga nna awár, mbin i na iya̱m-nrì, apaɓur i na ìmimyang. Mi nak aɓo onəm mí wur iya̱nkup ká̱ nkpaktak oga iya̱m va̱ ta̱.
\v 13 Á nzhi aYahudi ka̱ ulsa̱rila, ka̱ o yà onəm ovyapvyap ka̱ ashe mbín, mi ga nka̱mshi wo kang mi nak o tong onəm oga nnap nnəna̱n, kang ayər a nəm wo ka̱t, re ìgwak á kam wo.
\p 
\v 14 UYawe uga nggatək là pa̱, <<Wa nva n yar pa̱ mi ɓa ká̱ nɗaktak ka̱ apal wo, nva̱ okəka wo nak ìgwak mi lak te n re ka̱t.
\v 15 Wa nnà ta kpa ka̱ ashe nra ata̱ n yar chit pa̱ mi ga nnəm iya̱m inəna̱n aUrushelima ká̱ nzhi aYahudi, kang ayər a nəm wo ka̱t.
\v 16 ká̱ nnà te, iya̱m va ta̱ nkpak pa̱ o nəm, o là nnandər ńza̱ uwangwo nggo, o nyám nnandər ká̱ nnáp akwali aga nnandər ka̱ ashe nzhi akwali wo, ka̱kul ntəm ikángkáng.
\v 17 Kang o ran iya̱m inga ka̱ apal a nza̱ uwangwo nggo ka̱t, kang o ma̱n nsóng anung ka̱ apal akwam ka̱t. Ka̱kul n yang nkpaktak oga iya̱m va̱ ta̱,>> uYawe à là.
\p 
\v 18 Nnap nlà aYawe uga nggatək ɓa atak mi kà̱ɗi pa̱,
\v 19 <<Oga nnap nnəm ngga ǹyar ndeng ngba̱l ngga apye aga neɗing, ká̱ aga atukun, ká̱ aga afangshat, ká̱ aga agba̱pchi te, oza̱ i yà awalang aga nchang izər ká̱ nchang ìgwak ka̱kul nzhi àYahudi. Ka̱kul nva̱ ta te, o ma̱n nnandər ká̱ ntəm ikángkáng.>>
\p 
\v 20 UYawe uga nggatək là kà̱ɗi pa̱, <<Awalang nna kà̱ mɓa va onəm i fa kà̱ ítong pa̱ ɗongɗong i ɓa aUrushelima .
\v 21 Onəm oga ítong iro i wong i ga íro i là oza̱ pa̱, <Re i ga mpyal aYawe pa̱ kəlak na i chal nnap nnəna̱n aYawe uga nggatək. Mmami kà̱ ngga.>
\v 22 Kang onəm pa̱ makmak ká̱ mbín nkánkám i ɓa ngwop uYawe uga nggatək ka̱ aUrushelima, na o chal nnap nnəna̱nnəna̱n.>>
\p 
\v 23 UYawe uga nggatək là pa̱, <<Ka̱ ashe oga nra va̱ ta te, onəm pa̱ ogba̱pchi ka̱ ashe oga achu oga mbín i kpán unəm oYahudi kà̱ ilùkwan i là pa̱, <Re i ga ká̱ ɓu ka̱kul i fe pa̱, Inan ya yà nzəng ká̱ wo.> >>
\c 9
\s1 AKwali ka̱ apal Okpa Ikum aIsa̱rila
\q1 
\v 1 Nnap nlà aYawe ka̱ apambin aHadərak ka̱ oga ítong aDimaska. Iwu aYawe ka̱ apal nkpaktak onəm, jwakjwak akum ìjili oIsa̱rila.
\v 2 Mí náp akwali mbin aHamat va̱ nak aswari ka̱ aTaya ka̱ aSidon, mí náp akwali aTaya ka̱ aSidon kpa, káp ka̱ nva̱ pa̱ oza̱ ghan pa̱ makmak.
\q1 
\v 3 ATaya me akamsəlang akamkám íshi wò, kang à ɓut aazurfa ka̱ azənariya wa mɓwang ka̱ apal oga asa̱l
\v 4 Kang uYawe i wur ndudur i swang ka̱ ashe ìwá, te mí zhì na ka̱ apər.
\v 5 Onəm oga Askelon i ya te, ayər i nəm oza̱. Oga aGaza te, izər i tán ka̱ oza̱ pa̱ makmak. Oga aEkron i təm ka̱ ashe ìwuswa ka̱kul nnak ìgwak oza̱ i yà atak lakchi. Uponzhi oga aGaza i kú, kang aAskelon i ra agúng.
\v 6 Oɗyanəm i ga ntəm ka̱ ashe aAshdod kang uYawe i ga nkap oFilisti ka̱ nrup ka̱ ishi oza̱.
\v 7 Mi yar izhé iga nchə̀r ka̱ nung oza̱, ka̱ iya̱m iga ajan kà̱ mbagar inyin oza̱. Aɓo onəm va̱ re te, i yà wa akum ìjili ìro ka̱ ashe oga akum ìjili oYahudi. Kang uYawe i ka̱m onəm oga aEkron wa nva̱ uza̱ ka̱m oYebusi á.
\v 8 Te mi təm mi pángchí nzhi mi ka̱ atak onəm oga nlung na, na kang oɗyanəm oro á na idumdùm iro á na lap kat. Ka̱kul n ya mɓək anung onəm mi chit.
\s1 Uponzhi va i ga mɓa
\q1 
\v 9 Ónəm oga aUrushelima o nəm nchang izər pa̱ makmak, o ghám achu pa̱ gbá̱ngbá̱ng ka̱ nchang izər. O dər uponzhi wo kà̱ mɓa atak wo. Uza̱ unəm unəna̱n, unəm uga igwan, uga ǹyen ka̱ ishi, kà̱ nkwák azhaki, uza̱ kà̱ mɓa ka̱ apal ǹya azhaki anunggwan.
\v 10 Mi ga ngwur akeke ìkum ka̱ ashe aEfrayim ka̱ ipəri iga nlung ìkum ka̱ ashe aUrushelima i fa. Mi chwan íjang ìkum kang mi ɓa ka̱ ikángkáng ka̱ ashe nkpaktak apambin. Iponzhiponzhi i gang ìwá pa̱ lat, kang i ɓan ka̱ wang aYufriti i ga i chu nkur apambin.
\s1 Nɗa̱mshi Ntəm Onəm Inan
\p 
\v 11 Mmawo te, ka̱kul nsar nnap nla mi ká̱ wo ngga ngún ka̱ nchə̀r iya̱m ipápà te, mi ga nfən onəm wo va̱ mmá wur izwal ka̱ oza̱ mmá swang oza̱ ka̱ ashe ache ndəng va yà ka̱ ndəng ka̱t a.
\v 12 Ó le akamsəlang wo, mmawó ozwal oga nnak ìgwak ka̱kul ǹya nka̱mshi aYawe. Mmami kà̱ nlà kpa pa̱ mi ga nna imwa a wo idədan ka̱ apal nza̱ mɓək anung wo nggo.
\v 13 Ka̱kul mi wul uYahudi i yà ijang mi, uIsa̱rila i yà iwúwar, kang mi nəm inok ka̱ ovan onunggwan wo mi lung oHelini ka̱. Mi nəm inok ká̱ wo wa ndokchi anəm uga nlung ìkum.
\v 14 Te uYawe i fa ka̱ apal ishi oza̱ ka̱ gbagba apaɓur kang iwúwar i fa wa aməlam. UNəm ga Nzhi uYawe i ɓur agbəshi, uza̱ i ru oza̱ ka̱ ìkum wa nyə̀r ǹvivyil nva fa ka̱ asa̱l nkwandal.
\v 15 UYawe uga nggatək i ká onəm wò kang oza̱ i nəm igwan ka̱ okpa ìkum oza̱ ka̱ nchwalak. Oza̱ i ghám achu wa onəm ova wá ncè i ra̱n ka̱. Oza̱ i yə́l ka̱ nchang ìgwak wa nva̱ ikpáng nchə̀r iya̱m awop i yə́l ka̱ nchə̀r a.
\v 16 Ka̱ nra va̱ ta te, uYawe i ka̱mshi onəm wò wa nva unəm uga nkpak iya̱m nkang i ka̱mshi iya̱m nkang wò le kang iya̱m ngga iro a ya oza̱. Oza̱ i məlam ka̱ ashe mbin aYawe wa ipáng iga mbwai ka̱ izər atagya iponzhi .
\v 17 Ìɓyen ka̱ nza̱m oza̱ i yà wa nsang yà? ka̱kul ìpirkur i nak ovanza̱m i kam, ndəng ìba̱ngba̱ng ǹsámsàm ncángchàng i nak ovan ɓyen i məlam kpa.
\c 10
\s1 UYawe I ga Nnak Ishi ka̱ Onəm wo
\q1 
\v 1 Ó ɓəp iva̱r ka̱ atak aYawe ka̱ ashe arəzàng, ka̱kul uYawe uwa ka̱ ìlulu iva̱r, kang i pə̀ng iva̱r ka̱ ashe iram à ka̱ udanggo. I nak iya̱m nsuk i ɓyen.
\v 2 Ka̱kul oga ichər iga ashe nzhi kà̱ nlà inga, onəm oga iva̱k kà̱ ǹya alár akwam, onəm oga nlár ìzwam kà̱ nlà ìzwam akwam, ka̱ nkàm irəng ilakchi. Ka̱kul nva̱ ta te, onəm mi tong chit wa itám va i ra nggang nzəng ka̱ unəm uga nkpak oza̱ ka̱t, mí nyán ka̱ oza̱.
\v 3 UYawe là pa̱, <<Mmami ka̱ nlak ìgwak pa̱ makmak ka̱kul wo ónəm oga mpyal. Mi ga ntàn wo. Onəm oga aYahudi onəm mi, ka̱kul nva̱ ta te, mmami uYawe uga nggatək, mi nak ishi ka̱ oza̱. Oza̱ i yà ipəri míkankam iga nlung ìkum.
\v 4 ka̱ ashe oYahudi mí ga ǹya ìpang va ji ipáng iga mbang akum nzhi pa̱ chatchat, ka̱ oga akpəjələk akún aga mpak aghal, ka̱ ijang ìkum, ka̱ oponzhi pa̱ chatchat.
\v 5 Oza̱ i yà wa onəm ìkum osaisai, i tòng okpa ìkum oza̱ wa aɓyer ka̱ apal oga asa̱l. Oza̱ i lung ìkum, i nəm igwan ka̱kul mmami uYawe, nna ǹyà nzəng ka̱ oza̱. Oza̱ i nəm igwan ka̱ apal okpa ìkum oza̱ va̱ ka̱ apal ipəri kpa.
\v 6 Mi na ìkàm nzhi aYahudi ka̱ nzhi aIsa̱rila. Mi fa ka̱ ovan oga aIsa̱rila ka̱ atak idumdùm kang mi le ka̱ oza̱ ka̱kul mmami ka̱ nrwa ìgwak ka̱ apal oza̱. Oza̱ i yà wa onəm va ka̱ n yang ka̱ oza̱ yang ka̱t. Mmami uYawe, Inan oza̱, mi fe achal oza̱ fe.
\v 7 Onəm olsa̱rila i ga ǹyà wa onəm oga nlung ìkum osaisai. Oza̱ i yà ka̱ nchang ìgwak wa onəm va wá ndəng ìba̱ngba̱ng ǹsámsàm . Ovan oza̱ i ya te, ìgwak i chàng oza̱ kpa, ka̱kul iya̱m va̱ uYawe nəm oza̱ á.
\v 8 Mi wór oza̱ ka̱ nggapak i ɓut ka̱ nchəng, ka̱kul n ka̱mshi oza̱ chit. Oza̱ i yə́l kà̱ɗi wa nva oza̱ ka̱ yə́l ka̱ mmátmat.
\v 9 Káp ka̱ nva̱ pa̱ n lyangshin oza̱ ka̱ ashe mbín ngbá̱ngbà̱ng, ka̱ nna kpa te, oza̱ i ka̱ng ká̱ mi ka̱t. Kang oza̱ ka̱ ovan oza̱ i lár, i le mbin oza̱.
\v 10 Mi ɓa ka̱ oza̱ ka̱ mbin aMasar, mi vàng ka̱ oza̱ ka̱ mbin aAsiriya, mi ɓut ka̱ mbin oza̱. Mi ɓa ka̱ oza̱ ka̱ aGileyat ka̱ aLebanon har atak iga ǹyə́l oza̱ mbagar i yà ka̱t.
\v 11 ka̱ ashe nra va̱ ta te, oza̱ i wòl asa̱l ka̱ ashe ìwá iga mɓək anung, mi nak oga igúm ndəng i ra ka̱ ishi óza̱, kang oga ndəng awang aNilu i fu kpa. Mi shin nfam oga aAsiriya, kang ichumchum oga aMasar i kùr.
\v 12 Mi nak onəm mí kám ka̱ atak ichumchum mi. Oza̱ i nəm achen i ga atak va oza̱ i ɗom pa̱ o ga ka̱ ashe aɗin mi. Mmami na uYawe, n là.
\c 11
\s1 Mɓək Anung ka̱kul Okpa Ikum Ovan oga Isa̱rila
\q1 
\v 1 Ónəm oga aLebanon ó bol oga anung asa̱l wo, ka̱kul na apər á ri oga ikún asida wo.
\q1 
\v 2 Óga ikún asaipire, ó yə́ng ka̱kul nkpaktak oga ikún asida tàk chit, ka̱kul oga ikún inəna̱n làk chit. Óga ikún ichir iga aBashan, ó yə́ng ka̱kul mmá tàk ikún iga ashe ǹzam ikpá̱rkpà̱r chit ka̱ mbin.
\q1 
\v 3 Ó gwong achwang ka̱ yə́ng onəm oga nkpak iya̱m nkang ka̱kul pa̱ mmá vyap atak nrì iya̱m nkang oza̱ chit. Ó fe nɗum oga ivan ilìr ka̱kul pa̱ mmá chwan oga ikún aUrdun chit.
\s1 Onəm oga nkpak Iya̱mnkang onəna̱n ka̱ oɓá̱ngɓa̱ng
\p 
\v 4 UYawe, Inan mi là á mi pa̱, <<Kpak oga iya̱m nkang va̱ mmá nak chit pa̱ mí ga mpəpa á.>>
\v 5 Onəm va̱ i yáp oza̱ te, i pà oza̱ i ga ka̱ ikángkáng. Kang onəm va̱ i yáp ká̱ oza̱ te, i là pa̱, o ɗəngchi uYawe ka̱kul pa̱ o ya ìdur chit. Onəm va̱ i kpak nnyi te, á yà ka̱ nrwa ìgwak ka̱ apal iya̱m nkang ata̱ ka̱t.
\v 6 UYawe là pa̱, <<Mi yà ka̱ nrwa ìgwak ka̱ apal onəm oga mbín ata̱ lap ka̱t. Mi ga nnak oza̱ i lung izər oza̱, nza̱ unəm nggo i ga nlung unəm uga ngba̱k nzhi wò ka̱ uponzhi ponzhi. Uponzhi ata i ga̱ɓa̱n mbin oza̱ i ta̱l agúng, kang mi ka̱mshi oza̱ ka̱t ka̱ nna.>>
\p 
\v 7 Ka̱kul nva̱ ta te, n kpak iya̱m nkang va mmá nak chit pa̱ mí iga mpəpa, iva mmá ɓək anung oza̱ chit á. N wur idari pa̱ iparəm, n sok aɗin iro pa̱ <<Nnyám nrwa ìgwak.>> Iro nnyi te pa̱, <<Ngwang ishi.>> Kang n kpak iya̱m nkang va̱ ta.
\v 8 N ɓàk onəm oga nkpak iya̱m nkang oga oshatɗing ata̱ ka̱ ashe apye pa̱ zəng ka̱kul n nəm nka̱r ìgwak ka̱ oza̱ ka̱t, kang iya̱m nkang yang mi kpa.
\p 
\v 9 Te n là iya̱m nkang ata̱ pa̱, <<Mi yà ka̱ nkpak wo lap ka̱t. Ivəngva̱ i kú te, re oza̱ á kú. Ivəngva̱ i zhì te oza̱ á zhì. Kang ivəngva̱ i lár te, á ri izhé owan oza̱.>>
\p 
\v 10 N yar idari va̱ n wór pa̱, <<Nnyám nrwa ìgwak>> n chwan, na á nyám pa̱ n ɓəkchi nsar nnap-nlà va̱ chit ka̱ ǹyar nkpaktak mbín.
\v 11 Nkùr ǹyar nsar nnap nla mi na ta̱ ka̱ oza̱. Ovəngva̱ yáp iya̱m nkang kang oza̱ yáp ka̱ te, oza̱ tong kà̱ ndər mi, tə oza̱ nyi ɗak pa̱, uYawe kà̱ nlà nnàp ka̱ oza̱ ka̱ atak iya̱m va̱ mmami kà̱ nnənəm.
\p 
\v 12 Te n là oza̱ pa̱, <<A yà pa̱ o ya məma ká̱ wo pa̱ o mwa mi te, o mwa, a yà pa̱ a mmá ka̱t nnyi te, o kpán o təm ka̱. Te oza̱ kung a aazurfa ìsəm pa̱ ishatɗing oza̱ na mi.
\p 
\v 13 UYawe là á mi pa̱, <<Nak mbwai ata̱ ka̱ ashe amé mbwai va̱ ka̱ nzhi aYawe.>> Mbwai va oza̱ rəng pa̱ a mak kúr mmwa mi kúr. Te n wur a aazurfa ìsəm pa̱ ishatɗing va̱ ta n ga n nak ka̱ ashe amé mbwai ngga nzhi aYawe.
\p 
\v 14 Te n chwan idari míga iparəm va̱ mí wór pa̱ <<Ngwang Ishi.>> Iya̱m ata̱ á nyám mɓəkchi ntəm igənang kà̱ ishimshe oYahudi ka̱ oIsa̱rila.
\p 
\v 15 Te uYawe là á mi pa̱, <<Kà̱ɗi te, yar atak nsat ànəm uga nkpak iya̱m nkang uga mpərək.
\v 16 Ka̱kul mmami ka̱ ngga mɓa ka̱ unəm uga nkpak iya̱m nkang ka̱ ashe mbin ǹyangmata̱, ùva̱ i nakshi ka̱ iya̱m nkang ivəngva̱ lar ka̱t, uza̱ i pángchí ivəngva̱ iɓwakan ka̱t, ivəngva̱ ka̱m aɓang te, uza̱ i byáp oza̱ ka̱t. Uza̱ i na iya̱m-nrì ivəngva̱ mumwal ka̱t. Uza̱ i ri izhé ka̱ ítam imwalmwal, kang i kan oga ifir oza̱ na chwat.
\q1 
\v 17 <<Álak ka̱ unəm uga nkpak iya̱m nkang
\q2 ulakchilakchi uva̱ swang iya̱m nkang chit.
\q1 Re ndokchi á fər ka̱ igugwal ka̱ iwuwu iga awóri,
\q2 awuwo a kú, iwuwu a fo.>>
\c 12
\s1 Mí ka̱mshi aUrushelima ka̱ ashe Nra ngga mɓa
\p 
\v 1 Nnap nlà aYawe ka̱ apal oIsa̱rila. UYawe uwa nàr oga apaɓur, á nəm apambin, kang à nak irirì ka̱ ashe ánəm, á là pa̱,
\v 2 <<Mmami ka̱ ngga nnak aUrushelima i yà wa ndəng ìba̱ngba̱ng ǹsámsàm va ka̱ ashe ìkpáng, nva i yar ishi nkpaktak onəm va̱ ra gang na, a yà pa̱ oza̱ i wá á. Ìkum va̱ i gang aUrushelima ka̱ ashe te, i dok oYahudi kpa.
\v 3 Kà̱ ilum va̱ ta te, mi nak aUrushelima i sat ipáng iɗəkɗək nkpaktak onəm. Ka̱kul nkpaktak onəm oga apambin i gwang ishi pa̱ o lung na. Kang oza̱ i nak aɓang ishi oza̱ na chwat.>>
\v 4 UYawe là pa̱, <<Kà̱ ilum va̱ ta te, mi ləp nza̱ ipəri nggo kà̱ mbin ata i ga ka̱ ntàn izər, kang onəm oga nkukwák nnyi te i zwar.>> Ka̱ nna kpa te, <<Mi nak ishi ka̱ nzhi oYahudi. Ípəri okpa ìkum oza̱ nnyi te, mi nak i fo.
\v 5 Nna chit te, akum oYahudi i là íshi oza̱ pa̱, <Onəm oga aUrushelima ya ìkàm oza̱ ka̱ atak aYawe uga nggatək, Inan oza̱.> >>
\p 
\v 6 <<Kà̱ ilum va̱ ta te, mi nak akum aYahudi i yà wa apər va kà̱ nrì oga akun va mma ɓut pa̱ makmak, ka̱t te wa apər va ka̱ ashe ìram iya̱m-nrì va yál chit. I ri nkpaktak onəm va̱ a ra gang oza̱. I ri pa̱ chatchat kà̱ ngba̱k awo ari ka̱ awo apa̱m. Kang onəm oga ashe aUrushelima jiwo te, i təm ka̱ ikángkáng.>>
\p 
\v 7 UYawe i na igwan ónəm oga mbin aYahudi na mpyal, le kang ichumchum nzhi aDawuda ka̱ iji onəm oga aUrushelima a ji iji onəm oga aYahudi ka̱t.
\v 8 Kà̱ ilum va̱ ta te, uYawe i ká onəm oga aUrushelima ka̱kul na ovəngva̱ ka̱ ashe oza̱ rusokrusok te, oza̱ a kám wa aponzhi uDawuda. Kang onəm oga akum aDawuda nnyi te, i yà wa Inan. Oza̱ i tong wa ama̱leka aYawe va i lə́p mpyal oza̱ a.
\v 9 Kà̱ ilum va̱ ta te, mi fa pa̱ na n shin nkpaktak mbín va̱ fa nlung aUrushelima á.
\s1 Ayə́ng ka̱kul Anəm va mmá ɓək anung á na
\p 
\v 10 <<Te mi nak aruhu aga nnap nnəna̱n, ka̱ aga afar ka̱ apal akum aDawuda, ka̱ onəm oga aUrushelima . Oza̱ i dər mi unəm ùva̱ oza̱ ka̱ kyer ka̱ aɓar. I yə́ng ikú mi pa̱ gənggəng wa ǹyə́ng ikú ayen ùva̱ uwa byet pa̱ uzəng. Oza̱ i yə́ng ka̱ aɗor wa ǹyə́ng ikú ayen ununggwan ugəshi.
\v 11 Kà̱ ilum va̱ ta te, a yə́ng ka̱ ashe aUrushelima i mak byet wa nva mmá ka̱ yə́ng ka̱ aHadad Rimon va ka̱ agbagba aMegadon á.
\v 12-14 Nza̱ akum nggo ka̱ ashe mbin va̱ ta te, i yə́ng ikú oza̱ pa̱ ɗongɗong. Akum ìjili nzhi aDawuda ka̱ nji aNatan, ka̱ nji aLevi, ka̱ nji aShimeyi ka̱ nkpaktak aɓo oga akum va̱ re, i yə́ng pa̱ ɗongɗong. Ochar ka̱ onunggwan oza̱ i təm ikú pa̱ ɗongɗong.
\c 13
\s1 Iwuswa i ya Onəm oga Nla ichu Inan oga Akwam
\p 
\v 1 <<Ka̱ ilum va̱ ta te, mí bol ndəng mɓəlɓəl ka̱kul nnal nkpaktak nnap mɓá̱ngɓa̱ng ka̱ aɓəkət aga nzhi aDawuda ka̱ aji onəm oga ntəm ka̱ ashe aUrushelima .
\p 
\v 2 <<UYawe uga nggatək là pa̱, <<Ìlum va̱ ta i ɓa i chu te, mi dərkən oga aɗin iya̱m ngwop pa̱ kpaktak ka̱ ashe mbin, mí yà ka̱ nrəng oza̱ lap ka̱t. Mi fa ka̱ nkpaktak onəm oga nlà ìchu Inan oga akwam, ka̱ oga aruhu aɓá̱ngɓa̱ng ka̱ ashe mbin va̱ ta.
\v 3 A yà pa̱ unəm uro a ga mpyal ka̱ nlà ichu iga akwam kà̱ɗi te, upupon ka̱ unənang i là á na pa̱, <Nkpak ɓu kú, ka̱kul pa̱ u nap akwam ka̱ ashe aɗin aYawe.> Te upupon ka̱ unənang i kyer na i kú, ka̱kul nnap akwam.
\p 
\v 4 <<Nza̱ unəm nggo uga nlà ìchu Inan uga akwam te, ìwuswa i nəm na kà̱ nlà ichu aləlár. Uza̱ i yà ka̱ mwak ílukwan iga akpap apir iji onəm oga nlà ìchu Inan pa̱ na ô lam atak ka̱ ka̱t.
\v 5 Uza̱ i là pa̱, <Mmami unəm uga nlà ìchu Inan ka̱t, mmami unəm uga ngwap iram, n ɓan ngwap iram ka̱ ivan.>
\v 6 Kang unəm uro a ɓəp na pa̱, <U ya oga aɓang va̱ ta̱ ka̱ che ka̱ ìkwoksok ɓu yà?> Te uza̱ i là pa̱, <N ka̱m aɓang ka̱ nzhi akpa mi.> >>
\s1 Ngba̱l Unəm uga nkpak Iya̱m-nkang AYawe
\q1 
\v 7 UYawe uga nggatək là pa̱,
\q2 <<Á ndokchi , wong na u lung unəm uga nkpak iya̱m nkang mi, ukpa ntəm mi. Gba̱l na ná iya̱m nkang a lyangshin. Te mi ga̱ɓa̱n awo mi ɗak ka̱ apal ivəngva̱ iɓwakan.
\q1 
\v 8 Uparəm ka̱ ashe ashatɗing ka̱ ashe nkpaktak onəm oga mbín va̱ ta i kú. Uzəng ka̱ ashe ashatɗing nnyi te, oma mí re ka̱ irirì ka̱ ashe mbin va̱ ta.
\q1 
\v 9 Onəm va̱ ta, mi nak oza̱ ka̱ ashe apər,
\q2 mi nàl oza̱ wa nva mí nàl azənariya,
\q2 kang mi mal oza̱ wa nva mí mal a aazurfa.
\q1 Oza̱ i wór aɗin mi te,
\q2 mi ma̱n óza̱.
\q1 Mi là pa̱, <Onəm mi ta̱.>
\q2 Kang oza̱ i là pa̱, <UYawe, uwa Inan yi.> >>
\c 14
\s1 UYawe I vàng nnəm Iponzhi
\p 
\v 1 Ìlum iga akwali aYawe i ya ka̱ mɓa, iva mí vyat idur wo, mí kap kà̱ iwu wo, ó yiya.
\p 
\v 2 UYawe i ɓut nkpaktak mbín pa̱ na a lung aUrushelima . Mí ri oga ítong va̱ ta, mí zangtal oga nzhi, mí wur oga iya̱m. Kang mí ra ka̱ ochar oza ka̱ ifan. Mí kap onəm oga oga ítong va̱ ta idonka̱ng pa̱ iparəm, oro i ga izwal kang aɓo oro te, mí re oza̱ ka̱ ashe agúng.
\p 
\v 3 Nna chit te, uYawe i fa i lung oga mbín va̱ ta, wa nva uza̱ ka̱ lung kà̱ nra mmátmat á.
\v 4 Kà̱ ilum va̱ ta te, uza̱ i fa i sat ka̱ apal aɓam mpyet va ka̱ asa̱l nfa alum ka̱ aUrushelima . Kang aɓam ata i kap ka̱ ishimshe, i ɓan ka̱ asa̱l awu alum i ɓa asa̱l ntar alum. Mbagar nchumchum i kap aɓam va̱ ta. Nggba̱k nro i yà ka̱ asa̱l mpal kang nzəngtəng ka̱ asa̱l nkwandal.
\v 5 Te ó chəng ka̱ ashe mbagar oga aɓam ata̱, ó ga ó chu oga ítong aAzal. Ó chəng wa nva̱ okəka wo ka̱ chəng ka̱ walang va̱ mbin yənggət ka̱ ashe nra aponzhi Uza̱ya uga aYahudi á. Ka̱ nva̱ng nva̱ ta te, uYawe, Inan mí vàng ɗak nzəng ka̱ nkpaktak oma̱leka wò.
\p 
\v 6 Kà̱ ilum va̱ ta te, atak i ghan ka̱t, oga iya̱m va̱ i nak atak i ghan te i ghan ka̱t.
\v 7 Awalang va̱ ta i yà pa̱ɗi, uYawe uwa byet nyi asa̱l va̱ i ga ǹyà ka̱. Izwam ka̱ alum i yà ka̱t, ka̱kul ka̱ ka̱ ìzwam te, atak ghanghan nna i yà.
\p 
\v 8 Kà̱ ilum va̱ ta te, ndəng ngga nna irirì i nang i fa ka̱ ashe aUrushelima . Nggba̱k nro i nang i ga Ìwá Mman, ngba̱k nro nnyi te, i nang i ga Ìwá Ichumchum. I nang ká̱ ìzun ká̱ arə̀zang.
\p 
\v 9 Te uYawe uwa byet i yà uponzhi ka̱ apal nkpaktak apambin. Uwa i yà uYawe pa̱ uzəng. Aɗiɗin na byet mí wop.
\p 
\v 10 nkpaktak mbin i sat agbagba, i ɓàn ka̱ aGeba ka̱ asa̱l mpal aYahudi i chu aRimon kà̱ nkwandal aUrushelima . ká̱ nnà te, aUrushelima na i sat i rup iji wa nva ka̱ yà á. I ɓàn ka̱ anung asa̱l aBenjamin i ɓa atak va̱ anung asa̱l mà yà kà̱ matmat á. Te i watar i ɓa i chu nggúlyanggú akamsəlang. I wong ka̱ atak mpángchí atak aga apal nzhi nruprup ngga aHananel i ɓa i chu oga atak nkáng ndəng ìba̱ngba̱ng ǹsámsàm aponzhi.
\v 11 Onəm i təm ka̱ ashe aUrushelima ka̱ ikángkáng ayər i nəm oza̱ ka̱t. Mí shin na lap ka̱t.
\p 
\v 12 UYawe i ga mɓa ka̱ arwa aɓá̱ngɓa̱ng ka̱ apal nkpaktak onəm va̱ lung ìkum ka̱ aUrushelima . Izhé izər oza̱ i mwan ya oma yà ka̱ irirì, íwu oza̱ i mwan ka̱ ashe agùlong, kang aɓələm oza̱ i mwan ka̱ ashe atam kpa.
\v 13 Ka̱ ashe nra va̱ ta te, uYawe i ləp onəm ka̱ ayər aɓá̱ngɓa̱ng ka̱ nzwar, udánggo i kpán awo agənang wò kang i lung na.
\v 14 OYahudi i lung ìkum kpa ka̱ ashe aUrushelima . Oga idur nkpaktak onəm va̱ ra aswari gang oza̱ te, mí wur. Mí wur azənariya ka̱ aazurfa ka̱ ílukwan pa̱ makmak.
\v 15 Apir arwa aɓá̱ngɓa̱ng azəngtəng na kpa i nəm oga ipəri ka̱ azhaki, ka̱ alabitəri, ka̱ nkpaktak oga iya̱m nkang ka̱ ashe apa̱k okpa ìkum.
\p 
\v 16 Kà̱ nkukur te, nkpaktak okpa ìkum aUrushelima va̱ arwa aɓá̱ngɓa̱ng gba̱ng oza̱ ka̱t te, oza̱ i ɓa i ga aUrushelima nza̱ ìzun nggo pa̱ na ó wop unəm va uponzhi , uwa uYawe va ji pa̱ kpaktak á. Oza̱ i ga kpa pa̱ na o nəm Nchàng Izər ngga Nra ka̱ ashe Aghal.
\v 17 Akum va pa̱ kpaktak ka̱ pambin a yang mɓa ngga aUrushelima pa̱ na o wop uPonzhi, uwa uYawe va ji pa̱ kpaktak te, iva̱r i pəng oza̱ ka̱t.
\v 18 A yà pa̱ onəm oga aMasar a ɓa a nəm Nchàng Izər ngga Nra ka̱ ashe Aghal va̱ ta ka̱t te, iva̱r i pəng oza̱ ka̱t na kpa. UYawe i lə̀p oza̱ ka̱ apir arwa aɓá̱ngɓa̱ng va̱ ta kpa.
\v 19 Mpyát nnap va ta̱ i ya mbin aMasar ka̱ mbin va̱ pa̱ kpaktak yang mɓa ngga pa̱ na ó nəm Nchàng Izər ngga Nra ka̱ ashe Aghal á.
\p 
\v 20 Ka̱ ashe nra va̱ ta te, mí lir oga nnap-nlà pa̱, <<INƎNA̱N IJI AYAWE>> ka̱ apal oga iɓa̱ngga̱ng ipəri. Kang ngbət ngga mpə́k iya̱m ka̱ ashe Nzhi Inan Nchumchum, i yà iya̱m igargar wa oga akwano aga atak ǹshì iya̱m awop.
\v 21 Nza̱ ngbət ngga mpə́k iya̱m nggo ka̱ ashe aUrushelima ka̱ aYahudi te, i sat iya̱m igargar inəna̱n, ka̱kul aYawe ùva̱ ji pa̱ kpaktak. Unəm va kpaktak i ɓa ka̱ iya̱m inana iga mpà te, uza̱ i yar ngbət va uza̱ ɗom ka̱kul mpə́k iya̱m wò. Ka̱ ashenra va̱ ta te, mí ya unəm uro i nəm iyáp ka̱ ashe Nzhi Inan Nchumchum lap ka̱t.
