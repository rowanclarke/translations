\v 9 \w But|strong="G1161"\w* \w now|strong="G1161"\w* \w that|strong="G3739"\w* \w you|strong="G3739"\w* \w know|strong="G1097"\w* \w God|strong="G2316"\w*—\w better|strong="G3123"\w*, \w are|strong="G3588"\w* \w known|strong="G1097"\w* \w by|strong="G5259"\w* \w God|strong="G2316"\w*—\w how|strong="G4459"\w* \w can|strong="G4459"\w* \w you|strong="G3739"\w* \w turn|strong="G1994"\w* \w back|strong="G3825"\w* \w to|strong="G2532"\w* \w those|strong="G3588"\w* weak, \w yes|strong="G1161"\w* decidedly inferior, basic \w principles|strong="G4747"\w*, \w to|strong="G2532"\w* \w which|strong="G3739"\w* \w you|strong="G3739"\w* \w wish|strong="G2309"\w* \w to|strong="G2532"\w* \w be|strong="G2532"\w* \w enslaved|strong="G1398"\w* \w all|strong="G2532"\w* \w over|strong="G1909"\w* \w again|strong="G3825"\w*?
