\li1
\v 25 Rehum, Hashabnah, Maaseiah,   
\li1
\v 26 Ahiah, Hanan, Anan,   
\li1
\v 27 Malluch, Harim, and Baanah.   
\s1 The agreement  
\p
\v 28 Then \w the|strong="H1196"\w* rest of \w the|strong="H1196"\w* people also made \w a|strong="H3068"\w* solemn agreement. \w The|strong="H1196"\w* people who did it included priests, temple gatekeepers, singers, \w and|strong="H4409"\w* temple workers. They also included all \w the|strong="H1196"\w* men from other countries who had separated themselves from \w the|strong="H1196"\w* other foreigners living in Israel. These men, along with their wives, their sons \w and|strong="H4409"\w* daughters who were old enough to understand \add what they were doing, were people who wanted to obey God’s laws\add*.  
\v 29 \w They|strong="H5971"\w* \w all|strong="H3605"\w* joined \w with|strong="H3045"\w* \w their|strong="H3605"\w* \w leaders|strong="H7891"\w* \w in|strong="H1121"\w* \w making|strong="H3605"\w* \w this|strong="H3045"\w* solemn agreement. \w They|strong="H5971"\w* agreed \w to|strong="H1121"\w* \w obey|strong="H3045"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w laws|strong="H8451"\w* \w that|strong="H3045"\w* God \w had|strong="H3045"\w* given \w to|strong="H1121"\w* Moses. \w They|strong="H5971"\w* agreed \w to|strong="H1121"\w* \w obey|strong="H3045"\w* \w everything|strong="H3605"\w* \w that|strong="H3045"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3605"\w* God \w had|strong="H3045"\w* commanded, \w and|strong="H1121"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* regulations \w and|strong="H1121"\w* \w instructions|strong="H8451"\w*. \add And this is what they promised to do:\add*   
\pi1
\v 30 “\w We|strong="H6213"\w* \w will|strong="H3068"\w* \w not|strong="H6213"\w* \w allow|strong="H5414"\w* \w our|strong="H3068"\w* daughters \w to|strong="H3212"\w* \w marry|strong="H5921"\w* people \w who|strong="H3605"\w* \w live|strong="H8451"\w* \w in|strong="H5921"\w* \w this|strong="H6213"\w* land \add who do not worship Yahweh\add*, \w and|strong="H4872"\w* \w we|strong="H3068"\w* \w will|strong="H3068"\w* \w not|strong="H6213"\w* \w allow|strong="H5414"\w* \w our|strong="H3068"\w* sons \w to|strong="H3212"\w* \w marry|strong="H5921"\w* \w them|strong="H5414"\w*.   
\pi1
\v 31 “\w If|strong="H1121"\w* \w people|strong="H5971"\w* \w from|strong="H1121"\w* other countries \w who|strong="H5971"\w* live \w in|strong="H1121"\w* \w this|strong="H5414"\w* land \w bring|strong="H3947"\w* \w us|strong="H5414"\w* grain \w or|strong="H3808"\w* other \w things|strong="H3808"\w* \w to|strong="H5414"\w* \w sell|strong="H5414"\w* \w to|strong="H5414"\w* \w us|strong="H5414"\w* \w on|strong="H5414"\w* Sabbath days \w or|strong="H3808"\w* \w any|strong="H5414"\w* other sacred day, \w we|strong="H3068"\w* \w will|strong="H5971"\w* \w not|strong="H3808"\w* \w buy|strong="H3947"\w* \w anything|strong="H3808"\w* \w from|strong="H1121"\w* \w them|strong="H5414"\w*. \w And|strong="H1121"\w* \w in|strong="H1121"\w* \w every|strong="H3947"\w* seventh \w year|strong="H1121"\w*, \w we|strong="H3068"\w* \w will|strong="H5971"\w* \w not|strong="H3808"\w* \w plant|strong="H5414"\w* \w any|strong="H5414"\w* crops, \w and|strong="H1121"\w* \w we|strong="H3068"\w* \w will|strong="H5971"\w* ◄cancel \w all|strong="H5414"\w* debts/declare \w that|strong="H5971"\w* \w people|strong="H5971"\w* \w will|strong="H5971"\w* \w no|strong="H3808"\w* \w longer|strong="H3808"\w* \w have|strong="H5971"\w* \w to|strong="H5414"\w* \w pay|strong="H5414"\w* \w back|strong="H3947"\w* what \w they|strong="H3808"\w* owe \w us|strong="H5414"\w*►.   
\pi1
\v 32 “\w We|strong="H3117"\w* \w also|strong="H3027"\w* promise \w that|strong="H5971"\w* \w every|strong="H3605"\w* \w year|strong="H8141"\w* \w we|strong="H3068"\w* \w will|strong="H5971"\w* pay ◄one-eighth \w of|strong="H3117"\w* \w an|strong="H3947"\w* ounce/4 grams► \w of|strong="H3117"\w* silver \w for|strong="H3027"\w* \w the|strong="H3605"\w* \w work|strong="H3027"\w* \w of|strong="H3117"\w* \w taking|strong="H3947"\w* \w care|strong="H3027"\w* \w of|strong="H3117"\w* \w the|strong="H3605"\w* temple.  
\v 33 \w With|strong="H1004"\w* \w that|strong="H5414"\w* money \w they|strong="H5921"\w* \w can|strong="H5975"\w* buy \w these|strong="H1004"\w* \w things|strong="H4687"\w*: \w The|strong="H5921"\w* sacred bread \add that is placed before God\add*, \w the|strong="H5921"\w* grain \w that|strong="H5414"\w* \w is|strong="H1004"\w* burned \add on the altar\add* \w each|strong="H5414"\w* day, \w the|strong="H5921"\w* lambs \w that|strong="H5414"\w* \w were|strong="H5414"\w* completely burned \add on the altar\add*, \w the|strong="H5921"\w* sacred offerings \w for|strong="H5921"\w* \w the|strong="H5921"\w* Sabbath \w days|strong="H8141"\w* \w and|strong="H1004"\w* \w for|strong="H5921"\w* celebrating \w each|strong="H5414"\w* new moon \w and|strong="H1004"\w* other festivals \w that|strong="H5414"\w* \w God|strong="H5414"\w* told \w us|strong="H5414"\w* \w to|strong="H5921"\w* celebrate, \w and|strong="H1004"\w* other offerings \w that|strong="H5414"\w* \w are|strong="H8141"\w* \w dedicated|strong="H5414"\w* \w to|strong="H5921"\w* \w God|strong="H5414"\w*, \w the|strong="H5921"\w* animals \w to|strong="H5921"\w* \w be|strong="H5414"\w* sacrificed \w to|strong="H5921"\w* atone \w for|strong="H5921"\w* \w the|strong="H5921"\w* sins \w of|strong="H1004"\w* \w the|strong="H5921"\w* Israeli people, \w and|strong="H1004"\w* anything else \w that|strong="H5414"\w* \w is|strong="H1004"\w* needed \w for|strong="H5921"\w* \w the|strong="H5921"\w* \w work|strong="H5656"\w* \w of|strong="H1004"\w* taking \w care|strong="H5921"\w* \w of|strong="H1004"\w* \w the|strong="H5921"\w* \w temple|strong="H1004"\w*.   
\pi1
\v 34 “\w Each|strong="H3605"\w* year \w the|strong="H3605"\w* priests, \w the|strong="H3605"\w* \add other\add* descendants \w of|strong="H1004"\w* Levi \w who|strong="H3605"\w* help \w the|strong="H3605"\w* priests, \w and|strong="H3478"\w* \w the|strong="H3605"\w* rest \w of|strong="H1004"\w* \w us|strong="H5921"\w* \w will|strong="H3478"\w* ◄cast lots/throw marked stones► \w to|strong="H3478"\w* determine \add for that year\add* \w which|strong="H1004"\w* \w clans|strong="H1004"\w* \w will|strong="H3478"\w* provide wood \w to|strong="H3478"\w* burn \w on|strong="H5921"\w* \w the|strong="H3605"\w* altar \w the|strong="H3605"\w* \w sacrifices|strong="H5930"\w* \w that|strong="H3605"\w* \w are|strong="H3478"\w* offered \w to|strong="H3478"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3605"\w* God, \w in|strong="H5921"\w* order \w to|strong="H3478"\w* \w do|strong="H2403"\w* \w what|strong="H5921"\w* \w was|strong="H3478"\w* written \w in|strong="H5921"\w* \w the|strong="H3605"\w* laws \add God gave to Moses\add*.   
\pi1
\v 35 “We \w promise|strong="H3068"\w* \w that|strong="H5971"\w* \w each|strong="H5971"\w* \w year|strong="H8141"\w* \w each|strong="H5971"\w* \w family|strong="H1004"\w* \w will|strong="H3068"\w* \w take|strong="H3881"\w* \w to|strong="H3068"\w* \w the|strong="H5921"\w* \w temple|strong="H1004"\w* \w an|strong="H3068"\w* \w offering|strong="H7133"\w* \w from|strong="H5921"\w* \w the|strong="H5921"\w* first grain \w that|strong="H5971"\w* \w we|strong="H3068"\w* harvest \w and|strong="H3068"\w* \w from|strong="H5921"\w* \w the|strong="H5921"\w* first \w fruit|strong="H6086"\w* \w that|strong="H5971"\w* grows \w on|strong="H5921"\w* \w our|strong="H3068"\w* \w trees|strong="H6086"\w* \add that year\add*.   
\pi1
\v 36 “\w Also|strong="H3068"\w*, \w we|strong="H3068"\w* \w will|strong="H3068"\w* take \w to|strong="H3068"\w* \w the|strong="H3605"\w* priests \w at|strong="H3068"\w* \w the|strong="H3605"\w* \w temple|strong="H1004"\w* \w our|strong="H3068"\w* firstborn sons \w and|strong="H3068"\w* dedicate \w them|strong="H3068"\w* \w to|strong="H3068"\w* \w God|strong="H3068"\w*. \w And|strong="H3068"\w* \w we|strong="H3068"\w* \w will|strong="H3068"\w* \w also|strong="H3068"\w* bring firstborn calves \w and|strong="H3068"\w* lambs \w and|strong="H3068"\w* baby goats \add to be offered as sacrifices\add*. \w That|strong="H3605"\w* \w is|strong="H3068"\w* \w what|strong="H6529"\w* \w is|strong="H3068"\w* written \w in|strong="H8141"\w* \w God|strong="H3068"\w*’s laws \add that we must do\add*.   
\pi1
\v 37 “We \w will|strong="H1004"\w* \w also|strong="H1121"\w* \w take|strong="H1121"\w* \w to|strong="H1121"\w* \w the|strong="H3548"\w* \w priests|strong="H3548"\w* \w at|strong="H1004"\w* \w the|strong="H3548"\w* \w temple|strong="H1004"\w* \w the|strong="H3548"\w* flour made \w from|strong="H1121"\w* \w the|strong="H3548"\w* \w first|strong="H1121"\w* grain \add that we harvest each year\add*, \w and|strong="H1121"\w* our other offerings \w of|strong="H1121"\w* wine, \add olive\add* oil, \w and|strong="H1121"\w* fruit. We \w will|strong="H1004"\w* \w also|strong="H1121"\w* \w take|strong="H1121"\w* \w to|strong="H1121"\w* \w the|strong="H3548"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* Levi \add who help the priests\add* \w the|strong="H3548"\w* tithes/10% \w of|strong="H1121"\w* \add the crops that we grow on\add* our land, because \w they|strong="H3789"\w* \w are|strong="H1121"\w* \w the|strong="H3548"\w* \w ones|strong="H1121"\w* \w who|strong="H3548"\w* collect \w the|strong="H3548"\w* tithes \w in|strong="H1004"\w* all \w the|strong="H3548"\w* villages \w where|strong="H1004"\w* \w we|strong="H3068"\w* work/\w live|strong="H8451"\w*.  
\v 38 \w The|strong="H3605"\w* \w priests|strong="H3548"\w* \w who|strong="H3605"\w* \w are|strong="H1992"\w* descendants \w of|strong="H1004"\w* Aaron \w will|strong="H1004"\w* \w be|strong="H6086"\w* \w with|strong="H1004"\w* \w the|strong="H3605"\w* \add other\add* descendants \w of|strong="H1004"\w* \w Levi|strong="H3881"\w* \w and|strong="H1004"\w* supervise \w them|strong="H1992"\w* \w when|strong="H3881"\w* \w they|strong="H1992"\w* collect \w the|strong="H3605"\w* \w tithes|strong="H4643"\w*. \w Then|strong="H3605"\w* \w the|strong="H3605"\w* descendants \w of|strong="H1004"\w* \w Levi|strong="H3881"\w* must \w take|strong="H6237"\w* 10% \w of|strong="H1004"\w* \w the|strong="H3605"\w* \w things|strong="H3605"\w* \w that|strong="H3605"\w* people \w bring|strong="H3881"\w* \w and|strong="H1004"\w* put \w them|strong="H1992"\w* \w in|strong="H1004"\w* \w the|strong="H3605"\w* storerooms \w in|strong="H1004"\w* \w the|strong="H3605"\w* \w temple|strong="H1004"\w*.  
\v 39 \w The|strong="H5927"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Levi|strong="H3881"\w* \w and|strong="H1121"\w* \add some of\add* \w the|strong="H5927"\w* other Israeli \w people|strong="H1121"\w* \w must|strong="H1121"\w* \w take|strong="H1961"\w* 10% \w of|strong="H1121"\w* \w the|strong="H5927"\w* \w offerings|strong="H5927"\w* \w of|strong="H1121"\w* grain, wine, \w and|strong="H1121"\w* \add olive\add* oil \w to|strong="H5927"\w* \w the|strong="H5927"\w* storerooms \w where|strong="H1004"\w* \w the|strong="H5927"\w* various utensils \w that|strong="H3548"\w* \w are|strong="H1121"\w* \w used|strong="H1961"\w* \w in|strong="H1004"\w* \w the|strong="H5927"\w* \w temple|strong="H1004"\w* \w are|strong="H1121"\w* \w kept|strong="H1961"\w*. \w That|strong="H3548"\w* \w is|strong="H1961"\w* \w the|strong="H5927"\w* \w place|strong="H1004"\w* \w where|strong="H1004"\w* \w the|strong="H5927"\w* \w priests|strong="H3548"\w* \w who|strong="H3548"\w* \w are|strong="H1121"\w* serving \w at|strong="H1004"\w* \w that|strong="H3548"\w* \w time|strong="H1961"\w*, \w the|strong="H5927"\w* \w temple|strong="H1004"\w* guards, \w and|strong="H1121"\w* \w those|strong="H1121"\w* \w who|strong="H3548"\w* sing \w in|strong="H1004"\w* \w the|strong="H5927"\w* \w temple|strong="H1004"\w* choir live.  
\pi1 \add We promise that\add* \w we|strong="H3068"\w* \w will|strong="H1961"\w* \w not|strong="H1961"\w* neglect \add taking care of the temple of our God\add*.”   
\c 11  
\s1 The people who settled in Jerusalem  
\p
\v 1 \w The|strong="H4480"\w* \add Israeli\add* \w leaders|strong="H8269"\w* \add and their families\add* \w settled|strong="H3427"\w* \w in|strong="H3427"\w* \w the|strong="H4480"\w* \w sacred|strong="H6944"\w* \w city|strong="H5892"\w*, \w Jerusalem|strong="H3389"\w*. \w The|strong="H4480"\w* \w other|strong="H7605"\w* \w people|strong="H5971"\w* ◄\w cast|strong="H5307"\w* \w lots|strong="H1486"\w*/\w threw|strong="H5307"\w* marked stones► \w to|strong="H3027"\w* determine \w which|strong="H5971"\w* family \w from|strong="H4480"\w* \w each|strong="H5892"\w* \w ten|strong="H6235"\w* families \w would|strong="H5971"\w* \w live|strong="H3427"\w* \w in|strong="H3427"\w* \w Jerusalem|strong="H3389"\w*. \w The|strong="H4480"\w* \w other|strong="H7605"\w* \w people|strong="H5971"\w* \w continued|strong="H3427"\w* \w to|strong="H3027"\w* \w live|strong="H3427"\w* \w in|strong="H3427"\w* \w the|strong="H4480"\w* \w other|strong="H7605"\w* \w towns|strong="H5892"\w* \w and|strong="H3027"\w* \w cities|strong="H5892"\w* \add in Judea\add*.  
\v 2 \w Those|strong="H3605"\w* \w people|strong="H5971"\w* \add asked God to\add* \w bless|strong="H1288"\w* \w those|strong="H3605"\w* \w who|strong="H3605"\w* \w volunteered|strong="H5068"\w* \w to|strong="H3389"\w* \add be among the 10% who \add* \w moved|strong="H5068"\w* \w to|strong="H3389"\w* \w Jerusalem|strong="H3389"\w*.   
\p
\v 3  \add Some of\add* \w the|strong="H5650"\w* \w priests|strong="H3548"\w*, \add some of\add* \w the|strong="H5650"\w* \add other\add* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Levi|strong="H3881"\w*, \add some of\add* \w the|strong="H5650"\w* \w temple|strong="H5411"\w* workers, \w and|strong="H1121"\w* \w the|strong="H5650"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* King \w Solomon|strong="H8010"\w*’s \w servants|strong="H5650"\w*, \w and|strong="H1121"\w* many \w of|strong="H1121"\w* \w the|strong="H5650"\w* other \w people|strong="H1121"\w* \w lived|strong="H3427"\w* \w on|strong="H3427"\w* \w their|strong="H3427"\w* \w own|strong="H3548"\w* property \w in|strong="H3427"\w* \w the|strong="H5650"\w* \w towns|strong="H5892"\w* \add where their ancestors had lived\add*.  
\v 4 But some \w people|strong="H1121"\w* \w from|strong="H1121"\w* \w the|strong="H3427"\w* tribes \w of|strong="H1121"\w* \w Judah|strong="H3063"\w* \w and|strong="H1121"\w* \w Benjamin|strong="H1144"\w* \add decided to\add* \w live|strong="H3427"\w* \w in|strong="H3427"\w* \w Jerusalem|strong="H3389"\w*. \w One|strong="H1121"\w* \w of|strong="H1121"\w* \w them|strong="H3427"\w* \w from|strong="H1121"\w* \w the|strong="H3427"\w* tribe \w of|strong="H1121"\w* \w Judah|strong="H3063"\w* \w was|strong="H3063"\w* \w Athaiah|strong="H6265"\w*. \w He|strong="H3389"\w* \w was|strong="H3063"\w* \w the|strong="H3427"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Uzziah|strong="H5818"\w*, \w who|strong="H1121"\w* \w was|strong="H3063"\w* \w the|strong="H3427"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Zechariah|strong="H2148"\w*, \w who|strong="H1121"\w* \w was|strong="H3063"\w* \w the|strong="H3427"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Amariah, \w who|strong="H1121"\w* \w was|strong="H3063"\w* \w the|strong="H3427"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Shephatiah|strong="H8203"\w*, \w who|strong="H1121"\w* \w was|strong="H3063"\w* \w the|strong="H3427"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Mahalalel|strong="H4111"\w*, \w who|strong="H1121"\w* \w was|strong="H3063"\w* \w a|strong="H3068"\w* \w descendant|strong="H1121"\w* \w of|strong="H1121"\w* \add Judah’s son\add* \w Perez|strong="H6557"\w*.   
\p
