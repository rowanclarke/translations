\v 29 \w One|strong="H1121"\w* \w day|strong="H4872"\w* \w Moses|strong="H4872"\w*/\w I|strong="H3588"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w his|strong="H5414"\w*/\w my|strong="H5414"\w* brother-in-law \w Hobab|strong="H2246"\w*, \w the|strong="H5921"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Reuel|strong="H7467"\w* \w from|strong="H5265"\w* \w the|strong="H5921"\w* Midian people-group, “\w We|strong="H3588"\w* \w are|strong="H1121"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w way|strong="H3212"\w* \w to|strong="H1696"\w* \w the|strong="H5921"\w* \w place|strong="H4725"\w* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w promised|strong="H1696"\w* \w to|strong="H1696"\w* \w give|strong="H5414"\w* \w to|strong="H1696"\w* \w us|strong="H5414"\w*. \w Come|strong="H3212"\w* \w with|strong="H3068"\w* \w us|strong="H5414"\w*, \w and|strong="H1121"\w* \w we|strong="H3068"\w* \w will|strong="H3068"\w* \w take|strong="H1121"\w* \w good|strong="H2896"\w* \w care|strong="H5921"\w* \w of|strong="H1121"\w* \w you|strong="H5414"\w*, \w because|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* \w promised|strong="H1696"\w* \add to do\add* \w good|strong="H2896"\w* \w things|strong="H2896"\w* \w for|strong="H3588"\w* \w us|strong="H5414"\w* Israeli \w people|strong="H1121"\w*.”
\p 
\v 30 \w But|strong="H3588"\w* Hobab replied, “\w No|strong="H3808"\w*, \w I|strong="H3588"\w* \w will|strong="H3808"\w* \w not|strong="H3808"\w* \w go|strong="H3212"\w* \w with|strong="H3212"\w* \w you|strong="H3588"\w*. \w I|strong="H3588"\w* \w want|strong="H3808"\w* \w to|strong="H3212"\w* return \w to|strong="H3212"\w* \w my|strong="H3588"\w* own land \w and|strong="H3212"\w* \w to|strong="H3212"\w* \w my|strong="H3588"\w* own family.”
\p 
\v 31 \w But|strong="H3588"\w* \w Moses|strong="H3588"\w*/\w I|strong="H3588"\w* \w said|strong="H3651"\w*, “\w Please|strong="H4994"\w* \w do|strong="H5869"\w* \w not|strong="H3045"\w* \w leave|strong="H5800"\w* \w us|strong="H4994"\w*. \w You|strong="H3588"\w* \w know|strong="H3045"\w* \w the|strong="H5921"\w* \w places|strong="H3651"\w* \w where|strong="H5921"\w* \w we|strong="H3068"\w* \w can|strong="H3045"\w* set \w up|strong="H5921"\w* \w our|strong="H5921"\w* \w tents|strong="H2583"\w* \w in|strong="H5921"\w* \w this|strong="H3651"\w* \w desert|strong="H4057"\w*, \w and|strong="H5869"\w* \w you|strong="H3588"\w* \w can|strong="H3045"\w* guide \w us|strong="H4994"\w*.
\v 32 \w Come|strong="H1961"\w* \w with|strong="H5973"\w* \w us|strong="H3588"\w*. \w We|strong="H3588"\w* \w will|strong="H3068"\w* share \w with|strong="H5973"\w* \w you|strong="H3588"\w* \w all|strong="H3212"\w* \w the|strong="H3588"\w* \w good|strong="H2896"\w* \w things|strong="H5973"\w* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* gives \w to|strong="H3212"\w* \w us|strong="H3588"\w*.”
\p 
\v 33 \add So Hobab agreed to go with them\add*. \w The|strong="H6440"\w* Israelis \w left|strong="H5265"\w* Sinai \w Mountain|strong="H2022"\w*, \add which they called\add* \w Yahweh|strong="H3068"\w*’s \w Mountain|strong="H2022"\w*, \w and|strong="H3068"\w* \w they|strong="H3117"\w* walked \w for|strong="H6440"\w* \w three|strong="H7969"\w* \w days|strong="H3117"\w*. \w The|strong="H6440"\w* \add men carrying the\add* sacred chest \w went|strong="H5265"\w* \w in|strong="H3068"\w* \w front|strong="H6440"\w* \w of|strong="H3068"\w* \w the|strong="H6440"\w* other people \w for|strong="H6440"\w* those \w three|strong="H7969"\w* \w days|strong="H3117"\w*, \w and|strong="H3068"\w* \w they|strong="H3117"\w* kept looking \w for|strong="H6440"\w* \w a|strong="H3068"\w* \w place|strong="H4496"\w* \w to|strong="H3068"\w* \w set|strong="H5265"\w* up \w their|strong="H3068"\w* tents.
