\p \w And|strong="G2532"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w midst|strong="G3319"\w* \w of|strong="G2532"\w* \w the|strong="G1722"\w* \w throne|strong="G2362"\w* \w and|strong="G2532"\w* \w around|strong="G2945"\w* \w the|strong="G1722"\w* \w throne|strong="G2362"\w* \w were|strong="G3588"\w* \w four|strong="G5064"\w* \w living|strong="G2226"\w* beings \w full|strong="G1073"\w* \w of|strong="G2532"\w* \w eyes|strong="G3788"\w*, \w front|strong="G1715"\w* \w and|strong="G2532"\w* \w back|strong="G3693"\w*.  
