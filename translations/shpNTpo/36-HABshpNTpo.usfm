\id HAB - Shipibo NT with OT portions -Peru 2011 (DBL -2013) 
\h HABACUC 
\toc1 Jakonma joai kopí, Dioski koshiti Habacucnin yoia 
\toc2 Habacuc 
\toc3 Hab. 
\mt1 HABACUC 
\mt2 Jakonma joai kopí, Dioski koshiti Habacucnin yoia 
\c 1  
\s1 Ati keskáakin ayamakanaitian Habacuc jaskáatima riki iká 
\p  
\v 1 Natora profeta Habacuc Ibon onanmaa joi iki. 
\q1  
\v 2 Ibó, ¿Jawetiankamanki min 
\q1 ninkatamabi mia yokati ea saí iti iki? 
\q1 ¿Jawetiankamanki, nato jakonma 
\q1 jawéki ikai kopí, noa akinni mia 
\q1 joaimabi mia yokákin en mia saí ati iki? 
\q1  
\v 3 ¿Jaweatiki ichabires masá teneti itan ichabires jakonma min ea oinmai? 
\q1 Jakonma masá teneti itan mawakanra ea kateke; 
\q1 jatíbiainra join iananankanai itan jakonmanankanai. 
\q1  
\v 4 Ja esekan yoiai keskára ayamakanai, 
\q1 ati keskáakinra jakonhakin jato benxoaxonyamakanai, 
\q1 joi benxoakinra jakonmabaon jakonbo jatoaresai, 
\q1 itan atikeskabiakin jakon atira wetsaakanai. 
\s1 Ibon kopikin yoia itan jato masá tenemati yoia. 
\q1  
\v 5 Oinkanwe wetsa mainmeabaonra mato kateke; 
\q1 oinnax ratékanwe. 
\q1 Ea riki moa atires, wetsabaon mato yoia maton ikonhatima keská jawékibora en ati iki. 
\q1  
\v 6 Ninkakanwe caldeobora 
\q1 reteanankasbo en jato imai, 
\q1 jabora ramiamis jonibo iki, 
\q1 nato mai rebestanira jatíbitian oken boanbekonkanai, 
\q1 jatona ikenmabi iboanoxon mai biira ikanai. 
\q1  
\v 7 Ja jonibaonra jato ratexon rakéakanai, 
\q1 wetsa esébo ayamakinra jatonabichores jakon shinankanai. 
\q1  
\v 8 Jaton kabayobora leopardobo winoa ishtobo iki, 
\q1 tsoa jonibi jain jaama mananmamea pimis yoinabo bebónbires sinábo riki. 
\q1 Ja kabáyonin peyakax boai 
\q1 jonibora kikinbires icha itan 
\q1 kikinbires ishtobo iki, jato akíra 
\q1 ochokeaxbi jatoki choronkanai, 
\q1 teté namiki paketai 
\q1 keskatira, jatoki choronkanai. 
\q1  
\v 9 Winókinra jatíbi keyokin ras abotankanai; 
\q1 ja bokinra jato rakéabotankanai, 
\q1 ja jato yatankana jonibora 
\q1 aniparo mashi xewinna bebónbires icha ikanai. 
\q1  
\v 10 Apobo itan kikin jakon joni koshibokira shirokanai. 
\q1 Jaton jema katemakin koshi chikékanara osankanai, 
\q1 jan mapétira ja chikékibi 
\q1 mashi keyá tsamankanai, 
\q1 jaskáxonra rátereskin jato yatankana iki. 
\q1  
\v 11 Niweaba koshi keskára winókana iki; 
\q1 jaton koshinbi jato akíra wetsa diossa noa keska yamake ikanai. 
\s1 Jakonma shinanni chexakaati Habacuc jakiribi yoyo iká 
\q1  
\v 12 Ibó ¿Miaki jatíbitianbires 
\q1 jaama iki, miaki jakon 
\q1 itan keyoisma Diosma iki? 
\q1 Miara nokon Ibo itan ea koiranna iki, 
\q1 caldeobo jato koshi menixonra, 
\q1 jabo meranxon atikeskabiakin min noa masá tenemaa iki. 
\q1  
\v 13 Mia kikinshaman jakonma 
\q1 néoma ixonra, jakonma akanai min 
\q1 amaresti atipanyamake, anibires 
\q1 jakonma akanairibira min 
\q1 jakonhaxon jato ointi atipanyamake, 
\q1 ¿Jawe keskákinki retemisbo min 
\q1 oinresai, jaweatiki jakonma jonin 
\q1 ja keskáma jakonbo jato reteaitian 
\q1 min netéxon oinresai? 
\q1  
\v 14 ¿Jaweatiki aniparomea yapabo 
\q1 akai keskáakin min jonibo akai, 
\q1 jan akinti koshioma yoinabo keskáakin? 
\q1  
\v 15 Caldeobaonra wetsa maibo 
\q1 iboakanai, yapa biaibaon yapa 
\q1 bixon iboai keskáakin: 
\q1 miskitinin itan redbaonra bikanai, 
\q1 jaskara jatíbi tsamata oinnaxa kikinbiresi raroai. 
\q1  
\v 16 Jaskákinra yapa biai jonin 
\q1 mishkiti betan jawen redbo rabiai, 
\q1 jainxonra jabo rabikin yoinabo 
\q1 retexonai itan incienso inintibo 
\q1 menoxonai, jabo kopíresa jakon itan icha pitia iki. 
\q1  
\v 17 Jaskáakinki, ¿Caldeobaon jaton redbaon noa biboreskanti iki? 
\q1 ¿Noibayamakin jonibo jato reteboreskanti iki? 
\c 2  
\s1 Jain senenres Ibo Diossen yoia 
\q1  
\v 1 Netékainxonra en ninkatai itan jato koirannai sontáro jawen itinko iká keskára ea iti iki, 
\q1 jaweki Ibon ea yoiai ixonra en ninkáti iki, jakonma shinanni joikin, 
\q1 en yoiaki jawe 
\q1 ea yoiai ixonra en ninkáti iki. 
\q1  
\v 2 Ibonra ea yoia iki: 
\q1 “Ja en mia oinmai mapó tablanin wishawe, 
\q1 ishton yoyo ati itiakin. 
\q1  
\v 3 Nato min oinna jawéki 
\q1 jatian senenti nokotamapari ikaxbira; 
\q1 iamama senenti jake, 
\q1 Ja min oinna basiainbi, miabiribi manáreswe: 
\q1 ja ititianbiribira nokóti jake. 
\q1  
\v 4 Jakonma jonibora rabitaibo iki ixon wishawe, 
\q1 ikaxbi atikeskabiakin senen akaibora, Dioski yoiti ikax jati iki”, akin. 
\s1 Jakonmabo jakonmain nokoti 
\q1  
\v 5 Rabí jonibora, joni koshi itin keenbo iki; 
\q1 ja ikaskin benai tantiyamaira jatíbitian bebon keenboreskanai, 
\q1 ja koshi iká jakonmamis ikenbi. 
\q1 Jaton kexa chopeara jain mawá minti kini keska iki, 
\q1 mawá keskáribi tantiti onanmabora ikanai, 
\q1 jaskara ixonra jaton maibo, jato bichinbotankanai. 
\q1  
\v 6 Ikaxbi jato mai bichinkanabora 
\q1 jatikaxbi jan jato bichinaboki 
\q1 shirokanti iki, jatokira bewakanti iki: 
\q1 “¡Jawe ireskiai panon mato, matonama 
\q1 ikenbi wetsabaon jakon kopí 
\q1 jawékibo biax mato icha jawékia banétabo! 
\q1 ¿Jawetian kamanki mato ribina kopí bixon, 
\q1 icha jakon kopí jawéki tsamani mato jenetai?” 
\q1  
\v 7 Maton shinannamainbira, ja maton ribinabo matoki nokoti iki, 
\q1 jan mato masá tenemaibo matoki pikóxonra, 
\q1 jawebioma 
\q1 mato banékanti iki. 
\q1  
\v 8 Maibotiibi ikábora bianananax, 
\q1 mato akí matoki bechiakekanti iki, 
\q1 jatianra maton jato aká keskáribiakin, 
\q1 maton jawéki keyokin mato bichinkanti iki. 
\q1 Jatíbi eséki ramíkin maton aká kopíra, 
\q1 mato kopíamati iki, ja mainxon 
\q1 jemaboki itan jainoa joniboki 
\q1 bechiakexon maton meskó 
\q1 jakonma aká kopíribira mato kopíamakanti iki. 
\q1  
\v 9 ¡Jawe ireskiai panon mato, 
\q1 yometsokin bia jawékininra 
\q1 maton xobo, maton bochoake, 
\q1 jatíbi jakonmabaon mato akaitian, 
\q1 jan mato xabaatira maton ake! 
\q1  
\v 10 Jaskáxonra maton xobon iká 
\q1 rarebobo maton rabintiake, 
\q1 ja maibotiibi ikábo ras axonra, 
\q1 matonbi jan mato keyoti ake. 
\q1  
\v 11 Ja jema chiké makanbobi itan ja xobo 
\q1 jiwi kanobobira matoki bechiaketax, mato ramiai saí ikanti iki. 
\q1  
\v 12 ¡Jawe ireskiai panon mato, 
\q1 jemabo akinra, esekan yoiaibo ayamaakin, 
\q1 itan atikeskabiakin jaskara ati maton ayamaa iki! 
\q1  
\v 13 Jatíbi atipana Ibon imaara 
\q1 mato teeta, 
\q1 jainoax ja mato teeti paxkinairibi yanka iti iki, 
\q1 jatíbi maton tee akábora chiikan keyokin menoti iki. 
\q1  
\v 14 Jenen aniparo bochoa 
\q1 keskáakinra, Ibo jaskáaxon onanti 
\q1 shinan koshi nato main jatíbiain bochoti iki. 
\q1  
\v 15 ¡Jawe ireskiai panon mato, 
\q1 mato patax ikábora paeya 
\q1 meskoxon jan beyósti rao maton 
\q1 jato xeamai, namanbires 
\q1 shinanmeexon keyokin 
\q1 jaton chopa jopeta oinnoxon! 
\q1  
\v 16 Rabítitianbira, mato rabinresti iki, 
\q1 wetsabo maton aká keskáribiakinra 
\q1 Ibon mato ati iki, 
\q1 mato panaa chopa jopemaxon maton jakina 
\q1 rebichi maton xateama jato oinmai 
\q1 keskára mato ati iki, 
\q1 jatianra rabítitianbi mato namanbires shinanmeeti iki. 
\q1  
\v 17 Líbano manan jaskáati 
\q1 ikenmabi maton jakonma akára 
\q1 matoki bechiaketi iki, jainoa 
\q1 yoinabo reteaxa mato ratéti iki. 
\q1 Ja mainmea jemaboki itan jaínoa 
\q1 joniboki bechiakexon esekan yoiai ayamaketian 
\q1 itan jakonmabires maton 
\q1 jato aká kopíra, matoki jaskara 
\q1 jawékibo nokóti jaki. 
\q1  
\v 18 ¿Ja rabiti jawéki jatonbi aká 
\q1 moa akin senenhakanatonki noa akinti iki? 
\q1 ¿Jawekeskaxonki jan jansotires ixon, 
\q1 ja rabiti jatonbi akátonin noa akinti iki? 
\q1 Ja rabiti jatonbi akára yoyo iti atipanyamake; 
\q1 ¿Jawekeskataxki jan jaskara akaibo ikonhax jatoki koshiti iki? 
\q1  
\v 19 ¡Jawe ireskiaipanon mato, 
\q1 ja rabiti aká jawéki jiwira maton jishtenwe akin akai, 
\q1 ja yoyo iosma makanra maton niwé akin akai! 
\q1 ¿Jabaonki joi bexon noa yoiti atipana? ¡Jawe 
\q1 akamakan, jara oro itan platanin rapoa ikaxbi jiriomabobi iki! 
\q1  
\v 20 Ikaxbi Ibora jawen jakon ani xobonko iki: ¡Jatíbi nato mainmea 
\q1 jonibo já bebonmeax netékanwe! 
\c 3  
\s1 Habacucnin Dios orana 
\p  
\v 1 Nato riki profeta Habacucnin orana. 
\q1  
\v 2 Ibó, jatíbi min aká yoikanai 
\q1 ninkataxa, raketi ea saki ikai. 
\q1 Ani jawéki moatian min akábo, 
\q1 rama noa jaketian noa axonwe, 
\q1 nonribi onannon ixon. 
\q1 Jaskati sináxonbi min noa noibai noa oinmawe. 
\q1  
\v 3 Diossa Temán mainmeax joai; 
\q1 Parán mananmameaxa Jakon Dios joai. 
\q1 Jawen koshi shinanra 
\q1 naikan jatíbiain iki, 
\q1 nato netenxonra jatíbiainxon rabikanai. 
\q1  
\v 4 Pené joekan kateara joai, 
\q1 jawen mekenmameaxa 
\q1 kaná joébo jokonai, 
\q1 jaskáaxonra jawen koshi janbi jonea onantiakin jishtiai. 
\q1  
\v 5 Já joketianra jakonmabires isinbo beai, 
\q1 yoná koshiribira japekáo joai. 
\q1  
\v 6 Já jainbi chankaketianra mai ninwana iki; 
\q1 jato oinnara maibotiibi ikábo raketi saki ikanai; 
\q1 ramanmantian mananbora reokootai, 
\q1 moatian mananbora ras ikai; 
\q1 Dios jan niai baira jatíbitianbires iki. 
\q1  
\v 7 Cusán jonibo jakonma meranbires 
\q1 ikanaira en oinna iki, 
\q1 Madiánhin jaa jonibora raketi senbíkana iki. 
\q1  
\v 8 ¿Ibó, parobokiki mia sinata? 
\q1 ¿Kikínbiresiki aniparoboki mia sinata? 
\q1 ¿Jaskatiki min kabayobaon mia peyaka, 
\q1 janxon min jatoaresai carronki mia naneta? 
\q1  
\v 9 Min kanóti betan jatíbi min piabora 
\q1 moa min benxoa iki. 
\q1 Parobo axonra, jan jene boai taebo min ake. 
\q1  
\v 10 Mia oinnaxa manánbo shakotai; 
\q1 naikanmeaxa oi kextó maannai, 
\q1 aniparo nemín itan anibechonra xóo ikai. 
\q1  
\v 11 Min piabo kikin pené ikax, 
\q1 itan min lanza kikinbires kaná ikai 
\q1 keskati joétaitianra, bari betan oxe jonetax moa pikóyamai. 
\q1  
\v 12 Sinataxa nato main jatíbiain mia niai; 
\q1 kikínbiresi sinataxa maibaon mia jaton penitai. 
\q1  
\v 13 Minra min jonibaon paranan 
\q1 ikín min jato akinna iki, jainxonra 
\q1 ja minbi katota aporibi min akinna iki. 
\q1 Jakonma jonibaon xobora min ras aka iki, 
\q1 jainxonra jan koshia shanka inonbi min jishtiakin pikoa iki. 
\q1  
\v 14 Jaton koshira jawen pianbi min retea iki, 
\q1 niweaba koshi beai keská 
\q1 rabíbeirani kabáyonin bexonra, 
\q1 jonéres jato keyonoxon jan 
\q1 kopímistiomabo jato tsakakana iki. 
\q1  
\v 15 Aniparo kikin jene neminhainra, 
\q1 min kabáyonin jatíbiain mia kaa iki. 
\q1  
\v 16 Jatíbi neskara ninkataxa ea raketa iki. 
\q1 Ea keski ikaitianra, 
\q1 nokon witaxen moa tewanyamaa iki, 
\q1 jatianra jatíbi nokon yora koshi keyota iki. 
\q1 Jaskara ikenbira, noa jan jakonma 
\q1 tenemai, sontárobo Diossen masá 
\q1 tenemai nete nokotai kaman, 
\q1 jakonhaxonres en manati iki. 
\q1  
\v 17 Higo jiwibo bimiamaibi, 
\q1 Uva jiwibo bimiamaibi, 
\q1 olivo jiwibo bimiamaibi; 
\q1 non wainko banaabo jawe tsekati yamakenbi; 
\q1 wakabo, carnerobobi yamakenbira, 
\q1  
\v 18 mia, ea jan jamai iketianra, 
\q1 raroanan jatíbitian en mia rabiti iki. 
\q1  
\v 19 Nokon Ibó minra jakiribi 
\q1 benaakin ea koshi menia iki; 
\q1 chaxon ishto menixon, 
\q1 manan keyáinbo min ea raanara ea jain iká iki.