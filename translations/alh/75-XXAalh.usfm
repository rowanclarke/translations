\b
\q1 Mun.ji-yenu-da Jisas Krais,
\q1 Yiyelya gada jangarl-nayiman nyamba,
\q1 Ala Spirit niba yab-garnu nyambawarr,
\q1 Ala yumarri-yirni, ngayi yagul-yirni.
\b
\q1 Yalbi barda yumbarr neji-gunu
\q1 Guyn-garnu nibinyirru wan.gan niba.
\q1 Jabay jangarl-ngawihya, ngayi yagul-ngarni,
\q1 Guda ngawinya niba yab-garra bendirru.
\b
\q1 Ngayelya gada mun.ji-arrigarnu-da Jisas
\q1 Nurla Jisas Krais yamirni God.
\q1 Nyingaya anmudarningga nyingaya yumarri-ngeni,
\q1 Milarr-nayiman waynma, ala yumarri-ngarni.
\b
