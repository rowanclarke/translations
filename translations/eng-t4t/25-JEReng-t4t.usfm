\s1 Jeremiah was put in a dry well  
\p
\v 1  \add Four officials,\add* \w Shephatiah|strong="H8203"\w* \w the|strong="H3605"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Mattan|strong="H4977"\w*, \w Gedaliah|strong="H1436"\w* \w the|strong="H3605"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Pashhur|strong="H6583"\w*, \w Jehucal|strong="H3116"\w* \w the|strong="H3605"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Shelemiah|strong="H8018"\w*, \w and|strong="H1121"\w* \w Pashhur|strong="H6583"\w* \w the|strong="H3605"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Malkijah|strong="H4441"\w*, \w heard|strong="H8085"\w* \w what|strong="H1697"\w* \w I|strong="H1697"\w* \w had|strong="H1121"\w* \w been|strong="H5971"\w* \w telling|strong="H1696"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w*.  
\v 2  \add I had been telling them\add* \w that|strong="H5315"\w* \w Yahweh|strong="H3068"\w* \w was|strong="H3068"\w* saying, “Everyone \w who|strong="H3068"\w* \w stays|strong="H3427"\w* \w in|strong="H3427"\w* Jerusalem \w will|strong="H3068"\w* \w die|strong="H4191"\w*. \w They|strong="H3068"\w* \w will|strong="H3068"\w* \w be|strong="H1961"\w* \w killed|strong="H4191"\w* \w by|strong="H3068"\w* \add their enemies’\add* \w swords|strong="H2719"\w* \w or|strong="H2719"\w* \w from|strong="H3318"\w* famines \w or|strong="H2719"\w* \w from|strong="H3318"\w* \w diseases|strong="H1698"\w*. \w But|strong="H1961"\w* \w those|strong="H3318"\w* \w who|strong="H3068"\w* \w surrender|strong="H3318"\w* \w to|strong="H3318"\w* \w the|strong="H3541"\w* \w Babylonian|strong="H3778"\w* \w army|strong="H3427"\w*, \w they|strong="H3068"\w* \w will|strong="H3068"\w* \w be|strong="H1961"\w* \w spared|strong="H2421"\w*. \w They|strong="H3068"\w* \w will|strong="H3068"\w* \w not|strong="H1961"\w* \w be|strong="H1961"\w* \w killed|strong="H4191"\w*.  
\v 3 \w Yahweh|strong="H3068"\w* \w also|strong="H3068"\w* \w says|strong="H3541"\w* \w that|strong="H3068"\w* \w the|strong="H5414"\w* \w army|strong="H2428"\w* \w of|strong="H4428"\w* \w the|strong="H5414"\w* \w King|strong="H4428"\w* \w of|strong="H4428"\w* Babylon \w will|strong="H3068"\w* \w certainly|strong="H5414"\w* \w capture|strong="H3920"\w* \w this|strong="H2063"\w* \w city|strong="H5892"\w* [DOU].”   
\p
\v 4 \w So|strong="H3651"\w* \w those|strong="H3605"\w* \w officials|strong="H8269"\w* \add went\add* \w to|strong="H1696"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w and|strong="H4428"\w* \w said|strong="H1696"\w*, “\w This|strong="H2088"\w* \w man|strong="H4191"\w* \add Jeremiah\add* \w should|strong="H3588"\w* \w be|strong="H4191"\w* \w executed|strong="H4191"\w*! \w Because|strong="H3588"\w* \w of|strong="H4428"\w* \w what|strong="H1697"\w* \w he|strong="H1931"\w* \w is|strong="H2088"\w* \w saying|strong="H1697"\w*, \w he|strong="H1931"\w* \w is|strong="H2088"\w* \w discouraging|strong="H7503"\w* \w our|strong="H3605"\w* \w soldiers|strong="H4421"\w* \w who|strong="H3605"\w* \w remain|strong="H7604"\w* \w in|strong="H5921"\w* \w the|strong="H3605"\w* \w city|strong="H5892"\w*. \w He|strong="H1931"\w* \w is|strong="H2088"\w* \w also|strong="H3027"\w* \w discouraging|strong="H7503"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w*. \w He|strong="H1931"\w* \w is|strong="H2088"\w* \w not|strong="H2088"\w* \w saying|strong="H1697"\w* \w things|strong="H1697"\w* \w that|strong="H3588"\w* \w will|strong="H4428"\w* \w help|strong="H5971"\w* \w us|strong="H4994"\w*; \w he|strong="H1931"\w* \w is|strong="H2088"\w* \w saying|strong="H1697"\w* \w things|strong="H1697"\w* \w that|strong="H3588"\w* \w will|strong="H4428"\w* defeat \w us|strong="H4994"\w*.”   
\p
\v 5 \w King|strong="H4428"\w* \w Zedekiah|strong="H6667"\w* \w said|strong="H1697"\w*, “\w All|strong="H1697"\w* \w right|strong="H2009"\w*, \w do|strong="H3201"\w* \w to|strong="H3201"\w* \w him|strong="H3027"\w* \w what|strong="H1697"\w* \w you|strong="H3588"\w* want \w to|strong="H3201"\w*; \w I|strong="H3588"\w* \w do|strong="H3201"\w* \w not|strong="H3201"\w* \w have|strong="H3027"\w* \w the|strong="H3588"\w* \w power|strong="H3027"\w* \w to|strong="H3201"\w* stop \w you|strong="H3588"\w*.”   
\p
\v 6 \w So|strong="H3947"\w* \w those|strong="H1121"\w* \w officials|strong="H3947"\w* \w took|strong="H3947"\w* \w me|strong="H7971"\w* \w from|strong="H1121"\w* \w my|strong="H3947"\w* cell \w and|strong="H1121"\w* lowered \w me|strong="H7971"\w* \w by|strong="H4325"\w* \w ropes|strong="H2256"\w* \w into|strong="H3947"\w* \w a|strong="H3068"\w* well \w in|strong="H1121"\w* \w the|strong="H3588"\w* \w courtyard|strong="H2691"\w*. \w The|strong="H3588"\w* well belonged \w to|strong="H7971"\w* \w Malkijah|strong="H4441"\w*, \w who|strong="H1121"\w* \w was|strong="H1121"\w* \w a|strong="H3068"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w the|strong="H3588"\w* king. There \w was|strong="H1121"\w* \w no|strong="H3947"\w* \w water|strong="H4325"\w* \w in|strong="H1121"\w* \w the|strong="H3588"\w* well, \w but|strong="H3588"\w* there \w was|strong="H1121"\w* \add a lot of\add* \w mud|strong="H2916"\w*, \w so|strong="H3947"\w* \w I|strong="H3588"\w* \w sank|strong="H2883"\w* \add down deep\add* \w into|strong="H3947"\w* \w the|strong="H3588"\w* \w mud|strong="H2916"\w*.   
\p
\v 7 \w But|strong="H3588"\w* \w Ebed-Melech|strong="H5663"\w*, \w a|strong="H3068"\w* \w palace|strong="H1004"\w* \w official|strong="H5631"\w* \w from|strong="H8085"\w* \w Ethiopia|strong="H3569"\w*, \w heard|strong="H8085"\w* \add someone say\add* \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w was|strong="H1931"\w* \w in|strong="H3427"\w* \w the|strong="H8085"\w* well. \add At that time\add* \w the|strong="H8085"\w* \w king|strong="H4428"\w* \w was|strong="H1931"\w* deciding/judging \w people|strong="H3427"\w*’s cases \w at|strong="H3427"\w* \w the|strong="H8085"\w* \w Benjamin|strong="H1144"\w* \w Gate|strong="H8179"\w*.  
\v 8 \w Ebed-Melech|strong="H5663"\w* \w went|strong="H3318"\w* \w out|strong="H3318"\w* \w of|strong="H4428"\w* \w the|strong="H3318"\w* \w palace|strong="H1004"\w* \w and|strong="H4428"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w the|strong="H3318"\w* \w king|strong="H4428"\w*,  
\v 9 “\w Your|strong="H3605"\w* majesty, \w those|strong="H3605"\w* \w men|strong="H3605"\w* \w have|strong="H5030"\w* \w done|strong="H6213"\w* \w a|strong="H3068"\w* \w very|strong="H6213"\w* \w evil|strong="H7489"\w* \w thing|strong="H3588"\w*. \w They|strong="H3588"\w* \w have|strong="H5030"\w* \w put|strong="H4191"\w* \w the|strong="H3605"\w* \w prophet|strong="H5030"\w* \w Jeremiah|strong="H3414"\w* \w in|strong="H6213"\w* \w a|strong="H3068"\w* well. \add Almost\add* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w food|strong="H3899"\w* \w in|strong="H6213"\w* \w the|strong="H3605"\w* \w city|strong="H5892"\w* \w is|strong="H3605"\w* gone, \add so they will not be able to bring him any food\add* \w and|strong="H4428"\w* \w as|strong="H6213"\w* \w a|strong="H3068"\w* result \w he|strong="H3588"\w* \w will|strong="H4428"\w* \w die|strong="H4191"\w* \w from|strong="H6440"\w* \w hunger|strong="H7458"\w*!”   
\p
\v 10 \w So|strong="H4480"\w* \w the|strong="H3947"\w* \w king|strong="H4428"\w* \w told|strong="H6680"\w* \w Ebed-Melech|strong="H5663"\w*, “\w Take|strong="H3947"\w* \w thirty|strong="H7970"\w* \w of|strong="H4428"\w* \w my|strong="H3947"\w* \w men|strong="H3947"\w*/\w soldiers|strong="H5927"\w* \w with|strong="H3027"\w* \w you|strong="H6680"\w*, \w and|strong="H4428"\w* pull \w Jeremiah|strong="H3414"\w* \w out|strong="H4480"\w* \w of|strong="H4428"\w* \w the|strong="H3947"\w* well, \w in|strong="H4428"\w* \w order|strong="H6680"\w* \w that|strong="H4428"\w* \w he|strong="H4480"\w* \w does|strong="H2088"\w* \w not|strong="H2088"\w* \w die|strong="H4191"\w*!”   
\p
\v 11 \w So|strong="H3947"\w* \w Ebed-Melech|strong="H5663"\w* \w took|strong="H3947"\w* thirty \w men|strong="H3947"\w* \w with|strong="H1004"\w* \w him|strong="H7971"\w* \w and|strong="H7971"\w* \w they|strong="H8033"\w* \w went|strong="H4428"\w* \w into|strong="H3027"\w* \w a|strong="H3068"\w* \w room|strong="H1004"\w* \w in|strong="H1004"\w* \w the|strong="H3947"\w* \w palace|strong="H1004"\w* \w below|strong="H8478"\w* \w the|strong="H3947"\w* \w room|strong="H1004"\w* \w where|strong="H8033"\w* \w they|strong="H8033"\w* stored very valuable things. \w There|strong="H8033"\w* \w they|strong="H8033"\w* found \w some|strong="H8033"\w* \w old|strong="H1094"\w* \w rags|strong="H4418"\w* \w and|strong="H7971"\w* discarded clothing. \w They|strong="H8033"\w* \w took|strong="H3947"\w* those things \w and|strong="H7971"\w* \w went|strong="H4428"\w* \w to|strong="H7971"\w* \w the|strong="H3947"\w* well. \w They|strong="H8033"\w* fastened \w them|strong="H7971"\w* \w to|strong="H7971"\w* \w a|strong="H3068"\w* \w rope|strong="H2256"\w* \w and|strong="H7971"\w* lowered \w the|strong="H3947"\w* \w rope|strong="H2256"\w* \w to|strong="H7971"\w* \w me|strong="H7971"\w*.  
\v 12 \w Then|strong="H3651"\w* \w Ebed-Melech|strong="H5663"\w* \w called|strong="H7760"\w* \w down|strong="H7760"\w* \w to|strong="H6213"\w* \w me|strong="H4994"\w*, “\w Put|strong="H7760"\w* \w these|strong="H6213"\w* \w rags|strong="H4418"\w* \w underneath|strong="H8478"\w* \w your|strong="H7760"\w* armpits, \w to|strong="H6213"\w* protect \w you|strong="H6213"\w* \w from|strong="H3027"\w* \add being injured by\add* \w the|strong="H6213"\w* \w ropes|strong="H2256"\w*!” \w So|strong="H3651"\w* \w I|strong="H7760"\w* \w did|strong="H6213"\w* \w that|strong="H3651"\w*.  
\v 13 \w Then|strong="H5927"\w* \w they|strong="H5927"\w* \w pulled|strong="H4900"\w* \w me|strong="H4480"\w* \w out|strong="H4480"\w* \w of|strong="H3427"\w* \w the|strong="H4480"\w* well. \w I|strong="H4480"\w* \add returned\add* \w to|strong="H5927"\w* \w the|strong="H4480"\w* \w courtyard|strong="H2691"\w* \w where|strong="H4480"\w* \w the|strong="H4480"\w* palace guards \w stayed|strong="H3427"\w*, \w and|strong="H5927"\w* \w I|strong="H4480"\w* \w stayed|strong="H3427"\w* \w there|strong="H3427"\w*.   
\s1 Zedekiah questioned Jeremiah  
\p
\v 14  \add One day\add* \w King|strong="H4428"\w* \w Zedekiah|strong="H6667"\w* \w summoned|strong="H3947"\w* \w me|strong="H7971"\w*, \w and|strong="H3068"\w* \w I|strong="H1697"\w* \w was|strong="H3068"\w* \w brought|strong="H3947"\w* \w to|strong="H3068"\w* \w the|strong="H3947"\w* \w king|strong="H4428"\w*, \add who was waiting for me\add* \w at|strong="H3068"\w* \w the|strong="H3947"\w* \w entrance|strong="H3996"\w* \w of|strong="H4428"\w* \w the|strong="H3947"\w* \w temple|strong="H1004"\w*. \w He|strong="H3068"\w* \w said|strong="H1697"\w* \w to|strong="H3068"\w* \w me|strong="H7971"\w*, “\w I|strong="H1697"\w* want \w to|strong="H3068"\w* \w ask|strong="H7592"\w* \w you|strong="H7971"\w* \w something|strong="H1697"\w*. \w I|strong="H1697"\w* want \w you|strong="H7971"\w* \add to answer me truthfully, and\add* \w and|strong="H3068"\w* \w to|strong="H3068"\w* \w not|strong="H3947"\w* \w conceal|strong="H3582"\w* \w anything|strong="H1697"\w*.”   
\p
\v 15 \w I|strong="H3588"\w* replied, “\w If|strong="H3588"\w* \w I|strong="H3588"\w* \w tell|strong="H5046"\w* \w you|strong="H3588"\w* \add the truth\add*, \w you|strong="H3588"\w* \w will|strong="H3808"\w* \add command that I\add* \w be|strong="H4191"\w* \w executed|strong="H4191"\w*. \w And|strong="H8085"\w* \w if|strong="H3588"\w* \w I|strong="H3588"\w* \w give|strong="H3289"\w* \w you|strong="H3588"\w* \add good\add* \w advice|strong="H3289"\w*, \w you|strong="H3588"\w* \w will|strong="H3808"\w* \w not|strong="H3808"\w* \w pay|strong="H8085"\w* \w attention|strong="H8085"\w* \w to|strong="H4191"\w* \w what|strong="H8085"\w* \w I|strong="H3588"\w* say.”   
\p
\v 16 \w But|strong="H4428"\w* \w King|strong="H4428"\w* \w Zedekiah|strong="H6667"\w* \w secretly|strong="H5643"\w* \w promised|strong="H7650"\w* \w me|strong="H5414"\w*, “\add Tell me the truth\add*! \w And|strong="H3068"\w* \w as|strong="H6213"\w* \w surely|strong="H4191"\w* \w as|strong="H6213"\w* \w Yahweh|strong="H3068"\w* \w lives|strong="H5315"\w*, \w I|strong="H5414"\w* \w will|strong="H3068"\w* \w not|strong="H6213"\w* \add cause\add* \w you|strong="H5414"\w* \w to|strong="H4191"\w* \w be|strong="H4191"\w* \w executed|strong="H6213"\w*, \w and|strong="H3068"\w* \w I|strong="H5414"\w* \w will|strong="H3068"\w* \w not|strong="H6213"\w* \w hand|strong="H3027"\w* \w you|strong="H5414"\w* \w over|strong="H3027"\w* \w to|strong="H4191"\w* \w those|strong="H6213"\w* \w who|strong="H3068"\w* \w are|strong="H3027"\w* wanting \w to|strong="H4191"\w* \w kill|strong="H4191"\w* \w you|strong="H5414"\w*.”   
\p
\v 17  \add So\add* \w then|strong="H3318"\w* \w I|strong="H3541"\w* \w said|strong="H3318"\w* \w to|strong="H3318"\w* \w Zedekiah|strong="H6667"\w*, “\w This|strong="H2063"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \w the|strong="H3541"\w* \w Commander|strong="H8269"\w* \w of|strong="H4428"\w* \w the|strong="H3541"\w* \w armies|strong="H6635"\w* \w of|strong="H4428"\w* angels, \w the|strong="H3541"\w* \w God|strong="H3068"\w* whom \add we\add* Israelis \add worship\add*, \w says|strong="H3541"\w*: ‘If \w you|strong="H3808"\w* \w surrender|strong="H3318"\w* \w to|strong="H3318"\w* \w the|strong="H3541"\w* \w officers|strong="H8269"\w* \w of|strong="H4428"\w* \w the|strong="H3541"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* Babylon, \w you|strong="H3808"\w* \w and|strong="H3478"\w* \w your|strong="H3068"\w* \w family|strong="H1004"\w* \w will|strong="H3068"\w* ◄\w be|strong="H3808"\w* \w spared|strong="H2421"\w*/\w not|strong="H3808"\w* \w be|strong="H3808"\w* killed►, \w and|strong="H3478"\w* \w this|strong="H2063"\w* \w city|strong="H5892"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w be|strong="H3808"\w* \w burned|strong="H8313"\w*.  
\v 18 \w But|strong="H3808"\w* if \w you|strong="H5414"\w* \w refuse|strong="H3808"\w* \w to|strong="H3318"\w* \w surrender|strong="H3318"\w* \w to|strong="H3318"\w* \w them|strong="H5414"\w*, \w you|strong="H5414"\w* \w will|strong="H4428"\w* \w not|strong="H3808"\w* \w escape|strong="H4422"\w*. \w And|strong="H4428"\w* \w the|strong="H5414"\w* army \w from|strong="H3318"\w* \w Babylonia|strong="H3778"\w* \w will|strong="H4428"\w* capture \w this|strong="H2063"\w* \w city|strong="H5892"\w* \w and|strong="H4428"\w* \w completely|strong="H8313"\w* \w burn|strong="H8313"\w* \w it|strong="H5414"\w*.’ ”   
\p
\v 19 \w The|strong="H5414"\w* \w king|strong="H4428"\w* replied, “\w But|strong="H4428"\w* \w I|strong="H5414"\w* am \w afraid|strong="H1672"\w* \add to surrender to the soldiers from Babylon\add*, \w because|strong="H6435"\w* \w their|strong="H5414"\w* officers \w may|strong="H4428"\w* \w hand|strong="H3027"\w* \w me|strong="H5414"\w* \w over|strong="H3027"\w* \w to|strong="H5414"\w* \w the|strong="H5414"\w* people \w of|strong="H4428"\w* \w Judah|strong="H3064"\w* \w who|strong="H4428"\w* \w have|strong="H3027"\w* already \w joined|strong="H5307"\w* \w the|strong="H5414"\w* soldiers \w from|strong="H3027"\w* \w Babylonia|strong="H3778"\w*, \w and|strong="H4428"\w* those people \w from|strong="H3027"\w* \w Judah|strong="H3064"\w* \w will|strong="H4428"\w* mistreat \w me|strong="H5414"\w*.”   
\p
\v 20 \w I|strong="H5414"\w* \w replied|strong="H1696"\w*, “If \w you|strong="H5414"\w* \w obey|strong="H8085"\w* \w Yahweh|strong="H3068"\w* \w by|strong="H3068"\w* \w doing|strong="H3190"\w* \w what|strong="H6963"\w* \w I|strong="H5414"\w* \w tell|strong="H1696"\w* \w you|strong="H5414"\w* \w to|strong="H1696"\w* \w do|strong="H3190"\w*, \w they|strong="H3068"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w hand|strong="H5414"\w* \w you|strong="H5414"\w* \w over|strong="H5414"\w* \w to|strong="H1696"\w* \w our|strong="H3068"\w* \w people|strong="H5315"\w*. \w Things|strong="H3808"\w* \w will|strong="H3068"\w* \w go|strong="H3190"\w* \w well|strong="H3190"\w* \w for|strong="H3068"\w* \w you|strong="H5414"\w*, \w and|strong="H3068"\w* \w you|strong="H5414"\w* \w will|strong="H3068"\w* \w remain|strong="H3808"\w* \w alive|strong="H2421"\w*.  
\v 21 \w But|strong="H7200"\w* \w if|strong="H7200"\w* \w you|strong="H7200"\w* \w refuse|strong="H3986"\w* \w to|strong="H3318"\w* \w surrender|strong="H3318"\w*, \w this|strong="H2088"\w* \w is|strong="H3068"\w* \w what|strong="H1697"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* revealed \w to|strong="H3318"\w* \w me|strong="H7200"\w*:  
\v 22 \w All|strong="H3605"\w* \w the|strong="H3605"\w* women \w who|strong="H3605"\w* \w remain|strong="H7604"\w* \w in|strong="H1004"\w* \w your|strong="H3605"\w* \w palace|strong="H1004"\w* \w will|strong="H4428"\w* \w be|strong="H3201"\w* \w brought|strong="H3318"\w* \w out|strong="H3318"\w* \w and|strong="H3063"\w* given \w to|strong="H3318"\w* \w the|strong="H3605"\w* \w officers|strong="H8269"\w* \w of|strong="H4428"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* Babylon. \w Then|strong="H2009"\w* \w those|strong="H3605"\w* women \w will|strong="H4428"\w* say \w to|strong="H3318"\w* \w you|strong="H3605"\w*:  
\q1 ‘\w You|strong="H3605"\w* \w had|strong="H4428"\w* friends whom \add you thought\add* \w you|strong="H3605"\w* \w could|strong="H3201"\w* trust,  
\q2 \w but|strong="H2009"\w* \w they|strong="H2007"\w* \w have|strong="H3063"\w* deceived \w you|strong="H3605"\w* \w and|strong="H3063"\w* caused \w you|strong="H3605"\w* \w to|strong="H3318"\w* \w make|strong="H3201"\w* \w a|strong="H3068"\w* wrong decision.  
\q1 \w Now|strong="H2009"\w* \add it is as though\add* \w you|strong="H3605"\w* \w are|strong="H1004"\w* stuck \w in|strong="H1004"\w* mud,  
