\p
\v 5 Oholah acted \w like|strong="H8478"\w* \w a|strong="H3068"\w* \w prostitute|strong="H2181"\w* \w while|strong="H5921"\w* \w she|strong="H5921"\w* was \add still\add* \w my|strong="H5921"\w* wife. \w She|strong="H5921"\w* desired \w to|strong="H5921"\w* \w have|strong="H7138"\w* sex \w with|strong="H5921"\w* \w those|strong="H5921"\w* \w she|strong="H5921"\w* loved—soldiers \w from|strong="H5921"\w* Assyria.  
\v 6  \add Some of them\add* \w were|strong="H5483"\w* army officers \w and|strong="H8504"\w* commanders. \w They|strong="H3605"\w* \w wore|strong="H3847"\w* \add beautiful\add* \w blue|strong="H8504"\w* \add uniforms. They were\add* \w all|strong="H3605"\w* handsome \w young|strong="H2531"\w* \w men|strong="H3605"\w*. \w Some|strong="H3605"\w* \w of|strong="H3605"\w* \w them|strong="H3847"\w* \w rode|strong="H7392"\w* \w horses|strong="H5483"\w*.  
