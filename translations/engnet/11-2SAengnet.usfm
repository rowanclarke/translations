\v 9  \w When|strong="H3588"\w* \w Joab|strong="H3097"\w* \w saw|strong="H7200"\w* \w that|strong="H3588"\w* \w the|strong="H3605"\w* \w battle|strong="H4421"\w* \w would|strong="H3478"\w* \w be|strong="H1961"\w* fought \w on|strong="H7200"\w* two fronts, \w he|strong="H3588"\w* chose \w some|strong="H3605"\w* \w of|strong="H6440"\w* \w Israel|strong="H3478"\w*’s best \w men|strong="H3605"\w* \w and|strong="H3478"\w* \w deployed|strong="H6186"\w* \w them|strong="H6440"\w* \w against|strong="H7125"\w* \w the|strong="H3605"\w* Arameans.  
