\s1 New relationships  
\p
\v 46 \w But|strong="G1161"\w* \w then|strong="G2532"\w*, \w while|strong="G2980"\w* \w He|strong="G2532"\w* \w was|strong="G3588"\w* \w still|strong="G2089"\w* \w speaking|strong="G2980"\w* \w to|strong="G2532"\w* \w the|strong="G2532"\w* \w crowds|strong="G3793"\w*, \w His|strong="G3708"\w* \w mother|strong="G3384"\w* \w and|strong="G2532"\w* brothers \w stood|strong="G2476"\w* \w outside|strong="G1854"\w*, \w seeking|strong="G2212"\w* \w to|strong="G2532"\w* \w speak|strong="G2980"\w* \w with|strong="G2532"\w* \w Him|strong="G3588"\w*.  
