\v 3 \wj y ordénales: Levanten 12 piedras \+w de|strong="H5973"\+w* \+w aquí|strong="H2088"\+w*, \+w de|strong="H5973"\+w* \+w en|strong="H5973"\+w* \+w medio|strong="H8432"\+w* \+w del|strong="H5973"\+w* \+w Jordán|strong="H3383"\+w*, \+w del|strong="H5973"\+w* lugar donde estuvieron \+w firmes|strong="H3559"\+w* \+w los|strong="H5973"\+w* \+w pies|strong="H7272"\+w* \+w de|strong="H5973"\+w* \+w los|strong="H5973"\+w* \+w sacerdotes|strong="H3548"\+w*. Llévenlas y deposítenlas \+w en|strong="H5973"\+w* \+w el|strong="H5973"\+w* lugar donde posarán \+w esta|strong="H2088"\+w* \+w noche|strong="H3915"\+w*.\wj*   
\p
\v 4 Entonces \w Josué|strong="H3091"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* 12 \w hombres|strong="H8147"\w* \w que|strong="H1121"\w* estableció \w de|strong="H1121"\w* entre \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, uno \w de|strong="H1121"\w* cada \w tribu|strong="H7626"\w*  
\v 5 \w y|strong="H5921"\w* \w les|strong="H5921"\w* dijo: Pasen adelante \w del|strong="H5921"\w* Arca \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd* \w al|strong="H5921"\w* \w medio|strong="H8432"\w* \w del|strong="H5921"\w* \w Jordán|strong="H3383"\w*, \w y|strong="H5921"\w* lleve cada uno \w sobre|strong="H5921"\w* su \w hombro|strong="H7926"\w* una piedra, \w según|strong="H5921"\w* \w el|strong="H5921"\w* \w número|strong="H4557"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w tribus|strong="H7626"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\p
\v 6 \w Esto|strong="H2063"\w* \w será|strong="H1961"\w* señal \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* ustedes \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* sus \w hijos|strong="H1121"\w* les pregunten \w mañana|strong="H4279"\w*: ¿\w Qué|strong="H3588"\w* significan \w estas|strong="H2063"\w* piedras \w para|strong="H4616"\w* ustedes?  
\v 7 les digan: Las \w aguas|strong="H4325"\w* del \w Jordán|strong="H3383"\w* \w fueron|strong="H1961"\w* divididas \w delante|strong="H6440"\w* del Arca del \w Pacto|strong="H1285"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w cuando|strong="H5704"\w* cruzó \w el|strong="H1121"\w* \w Jordán|strong="H3383"\w*. Las \w aguas|strong="H4325"\w* del \w Jordán|strong="H3383"\w* \w fueron|strong="H1961"\w* \w cortadas|strong="H3772"\w*, \w y|strong="H5704"\w* estas piedras \w servirán|strong="H1961"\w* \w como|strong="H1961"\w* \w recuerdo|strong="H2146"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*.   
