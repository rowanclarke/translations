\c 1
\m
\v 1 EN \w el|strong="H1121"\w* \w mes|strong="H2320"\w* \w octavo|strong="H8066"\w*, en \w el|strong="H1121"\w* \w año|strong="H8141"\w* \w segundo|strong="H8147"\w* \w de|strong="H1121"\w* \w Darío|strong="H1867"\w*, \w vino|strong="H1961"\w* la \w palabra|strong="H1697"\w* del \w SEÑOR|strong="H3068"\w* \w a|strong="H3068"\w* \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Berequías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Iddo|strong="H5714"\w* \w el|strong="H1121"\w* \w profeta|strong="H5030"\w*, diciendo:   
\m
\v 2 \w Enojóse|strong="H7107"\w* \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w* \w con|strong="H5921"\w* \w ira|strong="H7110"\w* \w contra|strong="H5921"\w* vuestros padres.   
\m
\v 3 Por lo tanto diles \w a|strong="H3068"\w* ellos: \w Así|strong="H3541"\w* \w ha|strong="H3541"\w* \w dicho|strong="H5002"\w* el \w SEÑOR|strong="H3068"\w* de los \w ejércitos|strong="H6635"\w*: \w Volveos|strong="H7725"\w* \w a|strong="H3068"\w* mí, \w dice|strong="H5002"\w* el \w SEÑOR|strong="H3068"\w* de los ejér­citos, \w y|strong="H3541"\w* yo \w me|strong="H3541"\w* \w volveré|strong="H7725"\w* \w a|strong="H3068"\w* vosotros, \w ha|strong="H3541"\w* \w dicho|strong="H5002"\w* el \w SEÑOR|strong="H3068"\w* de los ejérci­tos.   
\m
\v 4 \w No|strong="H3808"\w* \w seáis|strong="H1961"\w* \w como|strong="H1961"\w* vuestros padres, \w a|strong="H3068"\w* \w los|strong="H1961"\w* cuales dieron voces \w los|strong="H1961"\w* pri­meros \w profetas|strong="H5030"\w*, diciendo: \w Así|strong="H3541"\w* \w ha|strong="H3541"\w* \w dicho|strong="H5002"\w* \w el|strong="H5030"\w* \w SEÑOR|strong="H3068"\w* \w de|strong="H7451"\w* \w los|strong="H1961"\w* \w ejércitos|strong="H6635"\w*: \w Volveos|strong="H7725"\w* \w ahora|strong="H4994"\w* \w de|strong="H7451"\w* vuestros \w malos|strong="H7451"\w* \w caminos|strong="H1870"\w*, \w y|strong="H3541"\w* \add de\add* vuestras \w malas|strong="H7451"\w* \w obras|strong="H4611"\w*: pero \w no|strong="H3808"\w* \w escucharon|strong="H8085"\w*, \w ni|strong="H3808"\w* \w me|strong="H3541"\w* \w atendieron|strong="H7181"\w*, \w dice|strong="H5002"\w* \w el|strong="H5030"\w* \w SEÑOR|strong="H3068"\w*.   
\m
\v 5 Vuestros padres, ¿dónde \add están\add*? y \w los|strong="H1992"\w* \w profetas|strong="H5030"\w* ¿han de \w vivir|strong="H2421"\w* para \w siempre|strong="H5769"\w*?   
\m
\v 6 Pero mis \w palabras|strong="H1697"\w* y mis \w estatutos|strong="H2706"\w* \w que|strong="H3808"\w* \w mandé|strong="H6680"\w* \w a|strong="H3068"\w* mis \w siervos|strong="H5650"\w* los \w profetas|strong="H5030"\w*, ¿\w no|strong="H3808"\w* alcanza­ron \w a|strong="H3068"\w* vuestros padres? \w Y|strong="H3068"\w* \w se|strong="H3808"\w* \w volvieron|strong="H7725"\w* ellos y \w dijeron|strong="H1697"\w*: \w Como|strong="H3651"\w* \w el|strong="H6213"\w* \w SEÑOR|strong="H3068"\w* \w de|strong="H1697"\w* los \w ejércitos|strong="H6635"\w* \w pensó|strong="H2161"\w* tratarnos conforme \w a|strong="H3068"\w* nuestros \w caminos|strong="H1870"\w*, y conforme \w a|strong="H3068"\w* nuestras \w obras|strong="H4611"\w*, \w así|strong="H3651"\w* \w lo|strong="H1697"\w* \w hizo|strong="H6213"\w* con nosotros.   
\m
\v 7 \w A|strong="H3068"\w* \w los|strong="H1121"\w* \w veinticuatro|strong="H6242"\w* del \w mes|strong="H2320"\w* undé­cimo, \w que|strong="H1931"\w* \add es\add* \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w de|strong="H1121"\w* Sebat, en \w el|strong="H1931"\w* \w año|strong="H8141"\w* \w segundo|strong="H8147"\w* \w de|strong="H1121"\w* \w Darío|strong="H1867"\w*, \w vino|strong="H1961"\w* \w la|strong="H1931"\w* pala­bra del \w SEÑOR|strong="H3068"\w* \w a|strong="H3068"\w* \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Berequías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Iddo|strong="H5714"\w* \w el|strong="H1931"\w* profe­ta, diciendo:   
\m
\v 8 \w Vi|strong="H7200"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w*, \w y|strong="H5921"\w* he \w aquí|strong="H2009"\w* un varón \w que|strong="H1931"\w* \w cabalgaba|strong="H7392"\w* \w sobre|strong="H5921"\w* un \w caballo|strong="H5483"\w* bermejo, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w estaba|strong="H5975"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* mirtos \w que|strong="H1931"\w* \add había\add* \w en|strong="H5921"\w* \w la|strong="H1931"\w* hondura; \w y|strong="H5921"\w* detrás \w de|strong="H5921"\w* \w él|strong="H1931"\w* \add había\add* \w caballos|strong="H5483"\w* ber­mejos, overos, \w y|strong="H5921"\w* \w blancos|strong="H3836"\w*.   
\m
\v 9 Entonces \w dije|strong="H1696"\w*: ¿\w Qué|strong="H4100"\w* \add son\add* \w éstos|strong="H1992"\w*, señor mío? \w Y|strong="H3068"\w* díjome \w el|strong="H1992"\w* \w ángel|strong="H4397"\w* \w que|strong="H4100"\w* \w hablaba|strong="H1696"\w* conmigo: Yo te enseñaré \w qué|strong="H4100"\w* \add son\add* \w éstos|strong="H1992"\w*.   
\m
\v 10 \w Y|strong="H3068"\w* aquel varón que \w estaba|strong="H5975"\w* entre los mirtos \w respondió|strong="H6030"\w*, y dijo: Éstos \add son los\add* que el \w SEÑOR|strong="H3068"\w* ha \w enviado|strong="H7971"\w* \w a|strong="H3068"\w* recorrer la tierra.   
\m
\v 11 \w Y|strong="H3068"\w* \w ellos|strong="H3605"\w* \w respondieron|strong="H6030"\w* \w a|strong="H3068"\w* \w aquel|strong="H3605"\w* \w ángel|strong="H4397"\w* del \w SEÑOR|strong="H3068"\w* \w que|strong="H3605"\w* \w estaba|strong="H5975"\w* entre \w los|strong="H3427"\w* mirtos, y dijeron: Hemos recorri­do \w la|strong="H3605"\w* tierra, y he \w aquí|strong="H2009"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tie­rra \w está|strong="H5975"\w* reposada y quieta.   
\m
\v 12 \w Y|strong="H3068"\w* \w respondió|strong="H6030"\w* el \w ángel|strong="H4397"\w* del \w SEÑOR|strong="H3068"\w*, \w y|strong="H5704"\w* dijo: Oh \w SEÑOR|strong="H3068"\w* \w de|strong="H5704"\w* los \w ejércitos|strong="H6635"\w*, ¿\w hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* \w no|strong="H3808"\w* tendrás piedad \w de|strong="H5704"\w* \w Jerusalem|strong="H3389"\w*, \w y|strong="H5704"\w* \w de|strong="H5704"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w*, \w con|strong="H5704"\w* las cuales has estado \w airado|strong="H2194"\w* \w por|strong="H2088"\w* espacio \w de|strong="H5704"\w* \w setenta|strong="H7657"\w* \w años|strong="H8141"\w*?   
\m
\v 13 \w Y|strong="H3068"\w* el \w SEÑOR|strong="H3068"\w* \w respondió|strong="H6030"\w* al \w ángel|strong="H4397"\w* \w que|strong="H1697"\w* \w hablaba|strong="H1696"\w* conmigo, \add con\add* \w buenas|strong="H2896"\w* \w palabras|strong="H1697"\w* \add y\add* \w palabras|strong="H1697"\w* consoladoras.   
\m
\v 14 \w Y|strong="H3068"\w* díjome el \w ángel|strong="H4397"\w* \w que|strong="H3541"\w* \w habla|strong="H1696"\w*­ba conmigo: \w Clama|strong="H7121"\w* \w diciendo|strong="H1696"\w*: \w Así|strong="H3541"\w* \w ha|strong="H3541"\w* \w dicho|strong="H1696"\w* el \w SEÑOR|strong="H3068"\w* de los \w ejércitos|strong="H6635"\w*: \w Celé|strong="H7065"\w* \w a|strong="H3068"\w* \w Jerusalem|strong="H3389"\w* \w y|strong="H3541"\w* \w a|strong="H3068"\w* \w Sión|strong="H6726"\w* \w con|strong="H7065"\w* \w gran|strong="H1419"\w* \w celo|strong="H7068"\w*:   
\m
\v 15 \w Y|strong="H3068"\w* \w con|strong="H5921"\w* \w grande|strong="H1419"\w* \w enojo|strong="H7110"\w* estoy airado \w contra|strong="H5921"\w* \w las|strong="H1992"\w* \w gentes|strong="H1471"\w* \add que están\add* \w reposadas|strong="H7600"\w*; \w porque|strong="H5921"\w* yo estaba eno­jado un \w poco|strong="H4592"\w*, \w y|strong="H5921"\w* \w ellos|strong="H1992"\w* \w ayudaron|strong="H5826"\w* \w para|strong="H5921"\w* \w la|strong="H5921"\w* aflicción.   
\m
\v 16 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w así|strong="H3541"\w* \w dice|strong="H5002"\w* \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*: Yo \w me|strong="H5921"\w* he \w vuelto|strong="H7725"\w* \w a|strong="H3068"\w* \w Jerusalem|strong="H3389"\w* \w con|strong="H5921"\w* \w misericordias|strong="H7356"\w*; \w en|strong="H5921"\w* \w ella|strong="H5921"\w* será \w edificada|strong="H1129"\w* \w mi|strong="H5921"\w* \w casa|strong="H1004"\w*, \w dice|strong="H5002"\w* \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w ejércitos|strong="H6635"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* plomada será tendida \w sobre|strong="H5921"\w* \w Jerusalem|strong="H3389"\w*.   
\m
\v 17 \w Clama|strong="H7121"\w* \w aún|strong="H5750"\w*, diciendo: \w Así|strong="H3541"\w* dice el \w SEÑOR|strong="H3068"\w* \w de|strong="H5750"\w* los \w ejércitos|strong="H6635"\w*: \w Aún|strong="H5750"\w* serán ensanchadas mis \w ciudades|strong="H5892"\w* \w por|strong="H5750"\w* la prosperidad; \w y|strong="H3541"\w* \w aún|strong="H5750"\w* \w consolará|strong="H5162"\w* el \w SEÑOR|strong="H3068"\w* \w a|strong="H3068"\w* \w Sión|strong="H6726"\w*, \w y|strong="H3541"\w* escogerá \w todavía|strong="H5750"\w* \w a|strong="H3068"\w* \w Jerusalem|strong="H3389"\w*.   
\m
\v 18 Después alcé mis ojos, y miré, y he aquí cuatro cuernos.   
\m
\v 19 \w Y|strong="H3068"\w* dije al ángel que hablaba conmigo: ¿Qué \add son\add* éstos? \w Y|strong="H3068"\w* res­pondióme: Éstos \add son\add* los cuernos que aventaron \w a|strong="H3068"\w* Judá, \w a|strong="H3068"\w* Israel, y \w a|strong="H3068"\w* Jerusalem.   
\m
\v 20 Mostróme luego el SEÑOR cuatro carpinteros.   
\m
\v 21 Entonces yo dije: ¿Qué vienen éstos \w a|strong="H3068"\w* hacer? \w Y|strong="H3068"\w* él habló, diciendo: Éstos \add son\add* los cuernos que dispersaron \w a|strong="H3068"\w* Judá, tanto que ninguno alzó su cabeza; mas éstos han venido para hacerlos temblar, para derribar los cuernos de los gentiles, que alzaron \add su\add* cuerno sobre la tierra de Judá para dispersarla.   
\c 2
\m
\v 1 \w ALCÉ|strong="H5375"\w* después \w mis|strong="H5375"\w* \w ojos|strong="H5869"\w*, y \w miré|strong="H7200"\w* y he \w aquí|strong="H2009"\w* un varón que tenía en su mano un cordel \w de|strong="H5869"\w* medir.   
\m
\v 2 \w Y|strong="H3068"\w* díjele: ¿\w A|strong="H3068"\w* dónde vas? \w Y|strong="H3068"\w* él me respondió: \w A|strong="H3068"\w* medir \w a|strong="H3068"\w* \w Jerusalem|strong="H3389"\w*, para ver \w cuánta|strong="H4100"\w* \add es\add* su anchura, y \w cuánta|strong="H4100"\w* su longitud.   
\m
\v 3 \w Y|strong="H3068"\w* he aquí, salía aquel ángel que hablaba conmigo, y otro ángel le salió al encuentro,   
\m
\v 4 \w Y|strong="H3068"\w* díjole: Corre, habla \w a|strong="H3068"\w* este mozo, diciendo: \w Sin|strong="H3808"\w* muros \w será|strong="H3808"\w* habitada Jerusalem \w a|strong="H3068"\w* causa de la multitud de los hombres, y del ganado en medio de ella.   
\m
\v 5 \w Yo|strong="H2009"\w* seré para ella, dice el SEÑOR, muro \w de|strong="H5869"\w* fuego en derredor, y seré \w por|strong="H3027"\w* gloria en \w medio|strong="H3027"\w* \w de|strong="H5869"\w* ella.   
\m
\v 6 Eh, \w eh|strong="H3068"\w*, huid de la tierra del norte, dice el SEÑOR, \w pues|strong="H7200"\w* \w por|strong="H4100"\w* los cuatro vientos del cie­\w lo|strong="H4100"\w* os esparcí, dice el SEÑOR.   
\m
\v 7 Oh Sión, la que moras \add con\add* la hija de Babilonia, escápate.   
\m
\v 8 Porque \w así|strong="H1696"\w* ha \w dicho|strong="H1696"\w* \w el|strong="H3427"\w* SEÑOR de \w los|strong="H3427"\w* ejércitos: \w Después|strong="H3427"\w* de la gloria me enviará \w él|strong="H3427"\w* \w a|strong="H3068"\w* las naciones que os despojaron: porque \w el|strong="H3427"\w* que os toca, toca \w a|strong="H3068"\w* la niña de su ojo.   
\m
\v 9 Porque he aquí yo alzo \w mi|strong="H1961"\w* mano \w sobre|strong="H1961"\w* ellos, \w y|strong="H3519"\w* \w serán|strong="H1961"\w* despo­jo \w a|strong="H3068"\w* sus siervos, \w y|strong="H3519"\w* sabréis \w que|strong="H1961"\w* el \w SEÑOR|strong="H3068"\w* de \w los|strong="H1961"\w* ejércitos me envió.   
\m
\v 10 Canta \w y|strong="H3588"\w* alégrate, hija \w de|strong="H3588"\w* Sión: \w porque|strong="H3588"\w* he aquí vengo, \w y|strong="H3588"\w* moraré \w en|strong="H3588"\w* medio \w de|strong="H3588"\w* ti, ha \w dicho|strong="H5002"\w* \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w*.   
\m
\v 11 \w Y|strong="H3068"\w* muchas naciones se unirán al SEÑOR en aquel día, y serán mi pueblo, y \w moraré|strong="H3427"\w* en medio de ti; y entonces conocerás \w que|strong="H1323"\w* \w el|strong="H3427"\w* SEÑOR de \w los|strong="H3427"\w* ejércitos me ha enviado \w a|strong="H3068"\w* ti.   
\m
\v 12 \w Y|strong="H3068"\w* \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* poseerá \w a|strong="H3068"\w* Judá \w su|strong="H3588"\w* heredad \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra santa, \w y|strong="H3588"\w* escogerá \w aún|strong="H3588"\w* \w a|strong="H3068"\w* Jerusalem.   
\m
\v 13 Calle \w toda|strong="H5921"\w* carne \w delante|strong="H5921"\w* \w del|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*, \w porque|strong="H3588"\w* \w él|strong="H5921"\w* \w se|strong="H3045"\w* ha levan­tado \w de|strong="H5921"\w* \w su|strong="H3588"\w* santa morada.   
\c 3
\m
\v 1 \w Y|strong="H3068"\w* \w MOSTRÓME|strong="H7200"\w* \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w el|strong="H5921"\w* \w gran|strong="H1419"\w* \w sacerdote|strong="H3548"\w*, \w el|strong="H5921"\w* cual \w estaba|strong="H5975"\w* \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w ángel|strong="H4397"\w* \w del|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*; \w y|strong="H5921"\w* Satanás \w estaba|strong="H5975"\w* \w a|strong="H3068"\w* su mano \w derecha|strong="H3225"\w* \w para|strong="H5921"\w* resistirle.   
\m
\v 2 \w Y|strong="H3068"\w* dijo el \w SEÑOR|strong="H3068"\w* \w a|strong="H3068"\w* Satanás: El \w SEÑOR|strong="H3068"\w* te reprenda, oh Satanás; \w Sí|strong="H3808"\w*, el \w SEÑOR|strong="H3068"\w* \w que|strong="H3808"\w* \w ha|strong="H3808"\w* escogido \w a|strong="H3068"\w* \w Jerusalem|strong="H3389"\w*, te reprenda. ¿\w No|strong="H3808"\w* \add es\add* \w éste|strong="H2088"\w* un tizón \w arrebatado|strong="H5337"\w* del incendio?   
\m
\v 3 \w Y|strong="H3068"\w* \w Josué|strong="H3091"\w* \w estaba|strong="H1961"\w* \w vestido|strong="H3847"\w* \w de|strong="H6440"\w* vesti­mentas \w viles|strong="H6674"\w*, y \w estaba|strong="H1961"\w* \w delante|strong="H6440"\w* del \w ángel|strong="H4397"\w*.   
\m
\v 4 \w Y|strong="H3068"\w* \w él|strong="H5921"\w* \w respondió|strong="H6030"\w* \w y|strong="H5921"\w* \w habló|strong="H6030"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w estaban|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w sí|strong="H6440"\w*, diciendo: \w Quitadle|strong="H5493"\w* esas vestimentas \w viles|strong="H6674"\w*. \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* dijo: \w Mira|strong="H7200"\w* \w que|strong="H5921"\w* he hecho \w pasar|strong="H5674"\w* tu \w iniquidad|strong="H5771"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w vestiré|strong="H3847"\w* \w con|strong="H5921"\w* cambio \w de|strong="H5921"\w* ropa.   
\m
\v 5 \w Y|strong="H3068"\w* yo dije: \w Pongan|strong="H7760"\w* \w mitra|strong="H6797"\w* \w limpia|strong="H2889"\w* \w sobre|strong="H5921"\w* su \w cabeza|strong="H7218"\w*. \w Y|strong="H3068"\w* \w pusieron|strong="H7760"\w* una \w mitra|strong="H6797"\w* \w limpia|strong="H2889"\w* \w sobre|strong="H5921"\w* su \w cabeza|strong="H7218"\w*, \w y|strong="H5921"\w* vistiéronle \w de|strong="H5921"\w* ropas. \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w ángel|strong="H4397"\w* \w del|strong="H5921"\w* \w SEÑOR|strong="H3068"\w* \w estaba|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H5975"\w*.   
\m
\v 6 \w Y|strong="H3068"\w* el \w ángel|strong="H4397"\w* del \w SEÑOR|strong="H3068"\w* protes­tó al mismo \w Josué|strong="H3091"\w*, diciendo:   
\m
