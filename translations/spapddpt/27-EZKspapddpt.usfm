\c 47  
\s1 Un río que brota del Santuario  
\p
\v 1 \w Me|strong="H3588"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* llevar \w a|strong="H3068"\w* \w la|strong="H3588"\w* entrada \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w Casa|strong="H1004"\w*. Vi \w agua|strong="H4325"\w* \w que|strong="H3588"\w* \w salía|strong="H3318"\w* \w de|strong="H3588"\w* \w debajo|strong="H8478"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* entrada \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w Casa|strong="H1004"\w* \w hacia|strong="H6440"\w* \w el|strong="H3588"\w* oriente, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* frente \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w Casa|strong="H1004"\w* \w estaba|strong="H2009"\w* \w hacia|strong="H6440"\w* \w el|strong="H3588"\w* oriente. \w El|strong="H3588"\w* \w agua|strong="H4325"\w* \w salía|strong="H3318"\w* \w desde|strong="H6440"\w* \w abajo|strong="H8478"\w*, \w del|strong="H4196"\w* \w lado|strong="H3802"\w* \w derecho|strong="H3233"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w Casa|strong="H1004"\w*, \w al|strong="H8478"\w* sur \w del|strong="H4196"\w* \w altar|strong="H4196"\w*.  
\v 2 \w Luego|strong="H3318"\w* \w me|strong="H4480"\w* llevó \w fuera|strong="H2351"\w* \w de|strong="H4480"\w* la \w puerta|strong="H8179"\w* \w del|strong="H4480"\w* \w norte|strong="H6828"\w* \w a|strong="H3068"\w* dar una \w vuelta|strong="H5437"\w* \w por|strong="H4480"\w* el \w camino|strong="H1870"\w* \w que|strong="H4480"\w* conducía \w hacia|strong="H1870"\w* el oriente. Vi el \w agua|strong="H4325"\w* \w que|strong="H4480"\w* \w salía|strong="H3318"\w* \w por|strong="H4480"\w* el \w lado|strong="H3802"\w* sur.   
\p
\v 3 Cuando \w el|strong="H5674"\w* varón \w salió|strong="H3318"\w* hacia \w el|strong="H5674"\w* oriente con un cordel \w en|strong="H3318"\w* su \w mano|strong="H3027"\w*, \w midió|strong="H4058"\w* 500 metros y me dijo \w que|strong="H4325"\w* \w pasara|strong="H5674"\w* \w por|strong="H3027"\w* \w el|strong="H5674"\w* \w agua|strong="H4325"\w*. \w El|strong="H5674"\w* \w agua|strong="H4325"\w* me llegó hasta los tobillos.  
\v 4 Otra vez \w midió|strong="H4058"\w* 500 metros, y me dijo \w que|strong="H4325"\w* \w pasara|strong="H5674"\w* por \w el|strong="H5674"\w* \w agua|strong="H4325"\w*. \w El|strong="H5674"\w* \w agua|strong="H4325"\w* me llegó hasta las \w rodillas|strong="H1290"\w*. \w Midió|strong="H4058"\w* \w luego|strong="H5674"\w* otros 500 metros, y me dijo \w que|strong="H4325"\w* \w pasara|strong="H5674"\w* por \w el|strong="H5674"\w* \w agua|strong="H4325"\w*. \w El|strong="H5674"\w* \w agua|strong="H4325"\w* me subió hasta la cintura.  
\v 5 \w Midió|strong="H4058"\w* otros 500 metros, \w y|strong="H3588"\w* era un río \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w cual|strong="H3588"\w* \w no|strong="H3808"\w* \w podía|strong="H3201"\w* \w pasar|strong="H5674"\w*. \w El|strong="H3588"\w* \w agua|strong="H4325"\w* creció \w de|strong="H3588"\w* manera \w que|strong="H3588"\w* \w el|strong="H3588"\w* río \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w podía|strong="H3201"\w* \w pasar|strong="H5674"\w* \w sino|strong="H3588"\w* \w a|strong="H3068"\w* nado.   
\p
\v 6 \w Y|strong="H3068"\w* me dijo: ¿\w Viste|strong="H7200"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w hombre|strong="H1121"\w*?  
\p Después me llevó, y me ordenó \w volver|strong="H7725"\w* \w a|strong="H3068"\w* la ribera del río.  
\v 7 Cuando regresé vi \w que|strong="H2088"\w* había muchísimos \w árboles|strong="H6086"\w* en ambos lados de la ribera del río.  
\v 8 Entonces \w me|strong="H5921"\w* dijo: \w Esta|strong="H5921"\w* \w agua|strong="H4325"\w* fluye \w hacia|strong="H5921"\w* \w la|strong="H5921"\w* región \w del|strong="H5921"\w* oriente \w y|strong="H5921"\w* bajará \w al|strong="H5921"\w* Arabá. Cuando \w entre|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w del|strong="H5921"\w* \w agua|strong="H4325"\w* pútrida, \w el|strong="H5921"\w* \w agua|strong="H4325"\w* será sanada.  
\v 9 \w Todo|strong="H3605"\w* \w ser|strong="H5315"\w* \w viviente|strong="H2416"\w* \w que|strong="H3588"\w* nade \w por|strong="H3588"\w* dondequiera \w que|strong="H3588"\w* entren \w estos|strong="H3605"\w* dos ríos, \w vivirá|strong="H2421"\w*. \w Habrá|strong="H1961"\w* muchísimos \w peces|strong="H1710"\w*, \w porque|strong="H3588"\w* esa \w agua|strong="H4325"\w* entró \w allí|strong="H8033"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w todas|strong="H3605"\w* las \w cosas|strong="H7227"\w* \w sean|strong="H1961"\w* sanadas \w y|strong="H3588"\w* \w viva|strong="H2416"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3588"\w* \w entre|strong="H3588"\w* \w en|strong="H3588"\w* \w este|strong="H1961"\w* río.  
\v 10 \w Sucederá|strong="H1961"\w* \w que|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w pescadores|strong="H7227"\w* \w que|strong="H5921"\w* \w estén|strong="H1961"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* río, \w desde|strong="H5704"\w* En-gadi \w hasta|strong="H5704"\w* \w En-eglaim|strong="H5882"\w*, \w les|strong="H5921"\w* \w servirá|strong="H1961"\w* \w de|strong="H5921"\w* lugar \w para|strong="H5704"\w* extender redes. \w Los|strong="H5921"\w* \w peces|strong="H1710"\w* \w serán|strong="H1961"\w* \w de|strong="H5921"\w* \w muchas|strong="H7227"\w* clases, \w tan|strong="H3966"\w* \w numerosos|strong="H7227"\w* \w como|strong="H1961"\w* \w los|strong="H5921"\w* \w peces|strong="H1710"\w* \w del|strong="H5921"\w* \w Mar|strong="H3220"\w* \w Grande|strong="H1419"\w*.  
\v 11 Pero sus pantanos y sus lagunas \w no|strong="H3808"\w* \w se|strong="H3808"\w* sanearán. Serán dejados como \w sal|strong="H4417"\w*.  
\v 12 \w Crecerá|strong="H5927"\w* \w toda|strong="H3605"\w* clase \w de|strong="H4480"\w* \w árboles|strong="H6086"\w* frutales \w en|strong="H5921"\w* \w las|strong="H1992"\w* orillas \w del|strong="H4480"\w* río \w por|strong="H5921"\w* ambos lados. \w Sus|strong="H1992"\w* \w hojas|strong="H5929"\w* \w nunca|strong="H3808"\w* caerán \w ni|strong="H3808"\w* \w faltará|strong="H8552"\w* \w su|strong="H1992"\w* \w fruto|strong="H6529"\w*. \w A|strong="H3068"\w* \w su|strong="H1992"\w* tiempo \w madurará|strong="H1069"\w* \w porque|strong="H3588"\w* \w su|strong="H1992"\w* \w agua|strong="H4325"\w* \w sale|strong="H3318"\w* \w del|strong="H4480"\w* \w Santuario|strong="H4720"\w*. \w Su|strong="H1992"\w* \w fruto|strong="H6529"\w* \w será|strong="H1961"\w* \w para|strong="H5921"\w* comer \w y|strong="H3588"\w* \w sus|strong="H1992"\w* \w hojas|strong="H5929"\w* \w para|strong="H5921"\w* medicina.   
\s1 Los límites de la herencia de Israel  
\p
\v 13 \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd* dice: \wj Éstos son los límites según los cuales repartirán \+w la|strong="H1366"\+w* tierra como herencia entre las \+w doce|strong="H8147"\+w* \+w tribus|strong="H7626"\+w* de \+w Israel|strong="H3478"\+w*. \+w José|strong="H3130"\+w* tendrá \+w dos|strong="H8147"\+w* porciones.\wj*  
\v 14 \wj \+w La|strong="H2063"\+w* \+w heredarán|strong="H5157"\+w* tanto los unos como los otros. Con respecto \+w a|strong="H3068"\+w* ella juré \+w a|strong="H3068"\+w* sus antepasados \+w que|strong="H3027"\+w* se \+w la|strong="H2063"\+w* \+w daría|strong="H5414"\+w*. \+w Por|strong="H3027"\+w* tanto \+w ésta|strong="H2063"\+w* \+w será|strong="H5414"\+w* \+w la|strong="H2063"\+w* tierra \+w de|strong="H5414"\+w* su \+w herencia|strong="H5159"\+w*.\wj*   
\p
\v 15 \wj \+w Éste|strong="H2088"\+w* será el límite \+w de|strong="H4480"\+w* \+w la|strong="H1366"\+w* tierra. \+w Por|strong="H4480"\+w* el \+w lado|strong="H6285"\+w* \+w del|strong="H4480"\+w* \+w norte|strong="H6828"\+w*, \+w desde|strong="H4480"\+w* el \+w Mar|strong="H3220"\+w* \+w Grande|strong="H1419"\+w* \+w por|strong="H4480"\+w* el \+w camino|strong="H1870"\+w* \+w de|strong="H4480"\+w* Hethlón \+w a|strong="H3068"\+w* \+w la|strong="H1366"\+w* entrada \+w de|strong="H4480"\+w* Zedad,\wj*  
\v 16 \wj Hamat, Berota y Sibraim, que está entre el límite de \+w Damasco|strong="H1834"\+w* y el límite de Hamat y Hazar-haticón, que es el límite de Haurán.\wj*  
\v 17 \wj El lindero \+w del|strong="H4480"\+w* \+w norte|strong="H6828"\+w* \+w será|strong="H1961"\+w* \+w desde|strong="H4480"\+w* el \+w mar|strong="H3220"\+w* hasta Hazar-enán \+w en|strong="H4480"\+w* el límite \+w del|strong="H4480"\+w* \+w norte|strong="H6828"\+w* \+w de|strong="H4480"\+w* \+w Damasco|strong="H1834"\+w*, \+w al|strong="H4480"\+w* \+w norte|strong="H6828"\+w* el límite \+w de|strong="H4480"\+w* Hamat. \+w Este|strong="H1961"\+w* \+w es|strong="H1961"\+w* el \+w lado|strong="H6285"\+w* \+w del|strong="H4480"\+w* \+w norte|strong="H6828"\+w*.\wj*  
\v 18 \wj \+w El|strong="H5921"\+w* límite \+w oriental|strong="H6921"\+w* \+w desde|strong="H5921"\+w* \+w entre|strong="H5921"\+w* Haurán \+w y|strong="H5921"\+w* \+w Damasco|strong="H1834"\+w*, \+w y|strong="H5921"\+w* \+w entre|strong="H5921"\+w* \+w Galaad|strong="H1568"\+w* \+w y|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w*, \+w junto|strong="H5921"\+w* \+w al|strong="H5921"\+w* \+w Jordán|strong="H3383"\+w*, \+w desde|strong="H5921"\+w* \+w el|strong="H5921"\+w* lindero norte \+w hasta|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w mar|strong="H3220"\+w* \+w oriental|strong="H6921"\+w*. Este será \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w oriental|strong="H6921"\+w*.\wj*  
\v 19 \wj Del \+w lado|strong="H6285"\+w* norte \+w hacia|strong="H5045"\+w* el sur, \+w desde|strong="H5704"\+w* Tamar \+w hasta|strong="H5704"\+w* las \+w aguas|strong="H4325"\+w* \+w de|strong="H5704"\+w* la rencilla \+w en|strong="H5704"\+w* \+w Cades|strong="H6946"\+w*, \+w hasta|strong="H5704"\+w* el \+w arroyo|strong="H5158"\+w* \+w y|strong="H5704"\+w* el \+w Mar|strong="H3220"\+w* \+w Grande|strong="H1419"\+w*. Éste será el límite \+w por|strong="H5704"\+w* el \+w lado|strong="H6285"\+w* sur.\wj*  
\v 20 \wj El límite \+w occidental|strong="H3220"\+w* será el \+w Mar|strong="H3220"\+w* \+w Grande|strong="H1419"\+w*, \+w desde|strong="H5704"\+w* el lindero sur \+w hasta|strong="H5704"\+w* frente \+w a|strong="H3068"\+w* Hamat. \+w Éste|strong="H2063"\+w* será el \+w lado|strong="H6285"\+w* \+w occidental|strong="H3220"\+w*.\wj*   
\s1 Repartición de la tierra prometida  
\p
\v 21 \wj \+w Así|strong="H2063"\+w* dividirán \+w esta|strong="H2063"\+w* tierra entre ustedes según las \+w tribus|strong="H7626"\+w* de \+w Israel|strong="H3478"\+w*.\wj*  
\v 22 \wj \+w Echarán|strong="H5307"\+w* suertes \+w sobre|strong="H1961"\+w* ella por la \+w herencia|strong="H5159"\+w* \+w entre|strong="H8432"\+w* ustedes y \+w los|strong="H1121"\+w* \+w extranjeros|strong="H1616"\+w* \+w que|strong="H1616"\+w* viven \+w en|strong="H8432"\+w* \+w medio|strong="H8432"\+w* \+w de|strong="H1121"\+w* ustedes y tengan \+w hijos|strong="H1121"\+w*. Ellos les \+w serán|strong="H1961"\+w* \+w como|strong="H1961"\+w* \+w los|strong="H1121"\+w* \+w que|strong="H1616"\+w* nacen \+w entre|strong="H8432"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*. \+w Echarán|strong="H5307"\+w* suertes con ustedes \+w para|strong="H1961"\+w* \+w tener|strong="H1961"\+w* \+w herencia|strong="H5159"\+w* \+w entre|strong="H8432"\+w* las \+w tribus|strong="H7626"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*.\wj*  
\v 23 \wj Le \+w darán|strong="H5414"\+w* al \+w extranjero|strong="H1616"\+w* su \+w herencia|strong="H5159"\+w* en la \+w tribu|strong="H7626"\+w* en la cual viva, \wj*\w dice|strong="H5002"\w* \nd ʼAdonay \+w Yavé|strong="H3068"\+w*.\nd*   
\c 48  
\p
\v 1 \wj Éstos \+w son|strong="H1961"\+w* \+w los|strong="H1961"\+w* \+w nombres|strong="H8034"\+w* de las \+w tribus|strong="H7626"\+w*. \+w Dan|strong="H1835"\+w* \+w tendrá|strong="H1961"\+w* una parte desde el \+w extremo|strong="H7097"\+w* \+w norte|strong="H6828"\+w* \+w por|strong="H1870"\+w* \+w la|strong="H1366"\+w* vía de Hetlón al volver \+w a|strong="H3068"\+w* Hamat, hasta Hazar-enán en \+w los|strong="H1961"\+w* confines de \+w Damasco|strong="H1834"\+w* al \+w norte|strong="H6828"\+w*, \+w hacia|strong="H1870"\+w* Hamat, desde el \+w lado|strong="H6285"\+w* \+w oriental|strong="H6921"\+w* hasta el \+w occidental|strong="H3220"\+w*.\wj*  
\v 2 \wj Aser tendrá una parte \+w junto|strong="H5921"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H5921"\+w* frontera \+w de|strong="H5921"\+w* \+w Dan|strong="H1835"\+w*, \+w desde|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w oriental|strong="H6921"\+w* \+w hasta|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w*.\wj*  
\v 3 \wj Neftalí tendrá una parte \+w junto|strong="H5921"\+w* \+w al|strong="H5921"\+w* límite \+w de|strong="H5921"\+w* Aser, \+w desde|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w oriental|strong="H6921"\+w* \+w hasta|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w*.\wj*  
\v 4 \wj \+w Manasés|strong="H4519"\+w* tendrá una parte \+w junto|strong="H5921"\+w* \+w al|strong="H5921"\+w* límite \+w de|strong="H5921"\+w* Neftalí, \+w desde|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w oriental|strong="H6921"\+w* \+w hasta|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w*.\wj*  
\v 5 \wj Efraín tendrá una parte \+w junto|strong="H5921"\+w* \+w al|strong="H5921"\+w* límite \+w de|strong="H5921"\+w* \+w Manasés|strong="H4519"\+w*, \+w desde|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w oriental|strong="H6921"\+w* \+w hasta|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w*.\wj*  
\v 6 \wj \+w Rubén|strong="H7205"\+w* tendrá una parte \+w junto|strong="H5921"\+w* \+w al|strong="H5921"\+w* límite \+w de|strong="H5921"\+w* Efraín, \+w desde|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w oriental|strong="H6921"\+w* \+w hasta|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w*.\wj*  
\v 7 \wj \+w Judá|strong="H3063"\+w* tendrá una parte \+w junto|strong="H5921"\+w* \+w al|strong="H5921"\+w* límite \+w de|strong="H5921"\+w* \+w Rubén|strong="H7205"\+w*, \+w desde|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w oriental|strong="H6921"\+w* \+w hasta|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w*. \wj*   
\p
\v 8 \wj \+w Junto|strong="H5921"\+w* \+w al|strong="H5921"\+w* límite \+w de|strong="H5921"\+w* \+w Judá|strong="H3063"\+w*, \+w desde|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w oriental|strong="H6921"\+w* \+w hasta|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w*, \+w estará|strong="H1961"\+w* \+w la|strong="H5921"\+w* parcela \+w que|strong="H5921"\+w* reservarán \+w de|strong="H5921"\+w* 12,5 kilómetros \+w de|strong="H5921"\+w* \+w anchura|strong="H7341"\+w*, \+w y|strong="H5921"\+w* \+w de|strong="H5921"\+w* una longitud igual \+w a|strong="H3068"\+w* cualquiera \+w de|strong="H5921"\+w* \+w las|strong="H5921"\+w* otras parcelas, esto \+w es|strong="H1961"\+w*, \+w desde|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w oriental|strong="H6921"\+w* \+w hasta|strong="H5704"\+w* \+w el|strong="H5921"\+w* \+w lado|strong="H6285"\+w* \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w*. \+w El|strong="H5921"\+w* \+w Santuario|strong="H4720"\+w* \+w estará|strong="H1961"\+w* \+w en|strong="H5921"\+w* \+w medio|strong="H8432"\+w* \+w de|strong="H5921"\+w* \+w ella|strong="H5921"\+w*.\wj*   
\p
