\p \w Tedae|strong="H9999"\w* \w hmulung|strong="H1486"\w* a \w naan|strong="H5307"\w* uh \w hatah|strong="H9999"\w* tah \w hmulung|strong="H1486"\w* loh \w Jonah|strong="H3124"\w* a \w tlak|strong="H5307"\w* \w thil|strong="H5921"\w*.  
