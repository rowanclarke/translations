\q1
\v 13 \w I|strong="H1697"\w* \w am|strong="H1961"\w* \w about|strong="H1961"\w* \w to|strong="H3068"\w* test \w my|strong="H3068"\w* people,  
\q2 \w and|strong="H3068"\w* \w the|strong="H3068"\w* kings [MTY] \w of|strong="H3068"\w* Judah \w will|strong="H3068"\w* \w not|strong="H1961"\w* escape \w being|strong="H1961"\w* punished.  
\q2 \w That|strong="H3068"\w* \w is|strong="H3068"\w* \w what|strong="H1697"\w* \w I|strong="H1697"\w*, \w Yahweh|strong="H3068"\w* \w the|strong="H3068"\w* \w Lord|strong="H3068"\w*, \w say|strong="H1697"\w*.   
\q1
\v 14 \w So|strong="H3541"\w*, \w you|strong="H1571"\w* human, \w prophesy|strong="H5012"\w*;  
