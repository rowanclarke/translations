\v 40 \w Then|strong="H7725"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w went|strong="H5674"\w* \w on|strong="H5674"\w* \w to|strong="H7725"\w* Gilgal, \w and|strong="H7725"\w* Chimham \w crossed|strong="H5674"\w* \w over|strong="H5674"\w* \w with|strong="H5971"\w* \w him|strong="H7725"\w*. \w All|strong="H3605"\w* \w the|strong="H3605"\w* \w troops|strong="H5971"\w* \w of|strong="H4428"\w* Judah \w and|strong="H7725"\w* half \w the|strong="H3605"\w* \w troops|strong="H5971"\w* \w of|strong="H4428"\w* \w Israel|strong="H5971"\w* escorted \w the|strong="H3605"\w* \w king|strong="H4428"\w*.
