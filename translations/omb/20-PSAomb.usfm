\id PSA - Havai 
\toc1 Ahi Noi Devet 
\toc2 Ahi 
\toc3 AHI 
\mt1 Ahi 
\c 1  
\q1  
\v 1 Gareana lawe na tangaloi nge hilogo hi 
\q2 dige tea lo tovotovo nora tangaloi esi, 
\q2 me he labe tea lo nora turegi rau esi, 
\q2 siu he toga tea lo herera tangaloi vaivei lolohaga Huqe. 
\q1  
\v 2 Nge mo havusie gena leo noi \nd Huqe\nd* 
\q2 me mo ladolado lolo nona tamwata vataha na rani me lolo bongi. 
\q1  
\v 3 Nge mwere na gai ram rivuana lo mwararai matamata 
\q2 nge hilogo lo tarona mo mwasigi a raune rain soi tea, 
\q1 me nge mo maraga lo gineu doluegi nge mo vaire. 
\b  
\q1  
\v 4 Hate mwere na tangaloi esi 
\q2 mwere na bembei tovu ngere hilogo a langi mo heregi vohoginire. 
\q1  
\v 5 Siu i Huqe vin veveginire tangaloi esi rain vurogi 
\q2 me vin vile wahera tangaloi galegale asi dena bubugiana nora tangaloi vovohoi. 
\b  
\q1  
\v 6 Huri \nd Huqe\nd* u ilo na turegire tangaloi vovohoi, 
\q2 nge a tangaloi esi mo huri na turegi mateana. 
\c 2  
\q1  
\v 1 ?Huri havagi a vanue dolue ram lalangogi huri vena ra vai gineu esi? 
\q2 ?Huri havagi tangaloi a nora lalangogi mo toa vurogi? 
\q1  
\v 2 Ratahigi tau lo ure ram labe ram rarai ve ra qalo mei \nd Huqe\nd*. 
\q2 Ngere ram vile bubugi ram tovotovo asi vovoi \nd Huqe\nd* mena na nona tangaloi vagatai. 
\q1  
\v 3 Ngere ram veve vena, “Ginde da lai vohogi na garovauveu 
\q2 me da tuli vohogi na garo ngere denire.” 
\b  
\q1  
\v 4 Nge mo toga lolo taetae mo mana, 
\q2 me i Huqe mo vaivei lolohaga meire. 
\q1  
\v 5 Siu nge mo veve vohoginire me na nona loloasi, 
\q2 mena nona lolobute mo vaire ram matagu. 
\q1  
\v 6 Siu nau teu na Nongu ratahigi me lui Saeon 
\q2 a Nongu vusi gogona. 
\q1  
\v 7 Ratahigi move, “Neu nain toregi na leo noi \nd Huqe.\nd* 
\q2 Nge mo veve laweau move, 
\q1 ‘Nigo i netungu mwere! 
\q2 Bagataha nam voragi tamamu. 
\q1  
\v 8 Tareve goin hui deni eu, me neu nain bete lawego a nomu vanue, 
\q2 mena nom sinobu vin dadari lo duvin ureure. 
\q1  
\v 9 Goin vei vurivurire, gena ruqi aean 
\q2 me goin momogagi nire mwere na sosovene tano.’” 
\b  
\q1  
\v 10 Siu i gimiu ratahigi nein iloe. 
\q2 Nein leohuri, gimiu tangaloi leogoro talo ure. 
\q1  
\v 11 Go tabana nona \nd Huqe\nd* mena londo mava, 
\q2 rongarea mena matagute. 
\q1  
\v 12 Go lai tabe tabegi na maresu mwera vaiteu 
\q2 mo mero mo vai asisigi nigo huri mo mero u siseri. 
\q1 Gareana lawera hi ramo betubetu lune. 
\c 6  
\d Tomtomuei Ahi. Mena bue gerigeri mena bue gerigeri garo gai welu. Ahi noi Devet. 
\q1  
\v 1 \nd Huqe\nd* lolo nomu lolobute go mese veve vohogi eu sige 
\q2 lolo nom meroana go mese haharau. 
\q1  
\v 2 \nd Huqe\nd* go haharagi na gareana lawe au huri neu nam wiriwiri, 
\q2 \nd Huqe\nd* go vaga vagamwasoi eu huri a hui gu ram rurururu. 
\q1  
\v 3 Me neu gaheau, nam romasi liu. 
\q2 ?Nge nigo \nd Huqe\nd* goin bului eu tagaha? 
\b  
\q1  
\v 4 \nd Huqe\nd* gon tudori gon bului eu. 
\q2 Me lo nom hahagavi vagitue gon vaga vagamwasoi eu. 
\q1  
\v 5 Huri lolo mateana a tangaloi vin lado bibigo tea. 
\q2 ?Me hine lolo qaru vin ware hagegi nigo? 
\b  
\q1  
\v 6 Neu nam wiriwiri gena nongu ngarana; 
\q1 Mena nongu tinengi nam vaga bibilugi na heregu 
\q2 mena qanagu lolo bongi gena nongu tingeni. 
\q1  
\v 7 Mataku mo dodo gena romasi, 
\q2 Me a matagu mo asi gena nongu tavului vuro. 
\b  
\q1  
\v 8 Nen vano den eu gimiu doluegi nem vai gineu rau esi vohogi, 
\q2 huri \nd Huqe\nd* mo rongo na nongu ngarana. 
\q1  
\v 9 A \nd Huqe\nd* nge u rongo na nongu ngarana huri na hahagavi, 
\q2 siu i \nd Huqe\nd* vin duvi na nongu tataro. 
\q1  
\v 10 Nongu tavalui vuro doluegi rain matagu lawuagi, 
\q2 me rain maemae rain toa dori siseri deni eu siu rain maemae. 
\c 23  
\d Ahi noi Devet. 
\q1  
\v 1 A \nd Huqe\nd* nge a nongu leo goro garea, 
\q2 neu nain he mahogi tea. 
\q1  
\v 2 Mo vai eu nam eno lolo ute lombu, 
\q2 me mo tomuegi eu lo mwararai wai matamata. 
\q1  
\v 3 Mo vurugegi na nongu mwasoana, 
\q2 me mo tomuegi eu sulo turegi vovohoiana huri na henana. 
\q1  
\v 4 Hate huri nain dige turu na dodo, 
\q2 a waluwelui asiana nain matagu tea gena gineu esi, 
\q2 huri nigo mei eu; 
\q2 a nom ruqi mena gaitigo ngere a gai turegu. 
\b  
\q1  
\v 5 Gom rarai na hinaga 
\q2 lo nagoi nongu tavului vuro, 
\q1 gom lai gogogi eu 
\q2 me a nongu laha mo horo mwalinglingi. 
\q1  
\v 6 A hogo liu, a nom gareana me nom vaigarea vin huri eu vataha 
\q2 na rani nongu mwasoana 
\q1 me neu nain toga lolo valei \nd Huqe\nd* 
\q2 vagituei. 
\c 30  
\d Ahi noi Devet huri na vai gogonagi na Sara Gogona. 
\q1  
\v 1 Nain tabe hagegi nigo gena roroa, \nd Huqe,\nd* 
\q2 huri gu ragasi eu dena walu, 
\q2 me gohi mesingegi tea ve nongu tavalui vuro ve rain rongarea gieu. 
\q1  
\v 2 Nongu \nd Huqe\nd* Mauri, 
\q2 nam warego huri na buluiana, 
\q2 siu nigo gu vagamwasoi eu. 
\q1  
\v 3 \nd Huqe,\nd* gu ragasi eu dena qarui mateana. 
\q2 Gu dedegi na nongu mwasoana, hi hivo tea lolo walu. 
\b  
\q1  
\v 4 Gimiu nona tangaloi gogona nein galohagi na \nd Huqe,\nd* 
\q2 me nein bete na harigiana lawe na henana u gogona. 
\q1  
\v 5 Huri a nona meroana mo eno mahogi biti, 
\q2 nge a nona leogareagi nigo mo eno tuqaravu, 
\q1 tangiana vin eno lai bongi gategale, 
\q2 nge lolo robongi a rongarea. 
\b  
\q1  
\v 6 Tavohe nongu tutugoro mo eno, nam veve vena, 
\q2 “Neu nain he gilu tea.” 
\q1  
\v 7 O \nd Huqe,\nd* tavohe gom leogareagi eu 
\q2 gom vai na vusigu mo labe siaga; 
\q1 nge tavohe gom hiligi na nagomu 
\q2 nau ruru gena matagute. 
\b  
\q1  
\v 8 O \nd Huqe,\nd* neu nau warego; 
\q2 Lawego Huqe, neu nau ngara huri na hahagavi. 
\q1  
\v 9 ?Hava lalaie nge talehe tare vena neu nau mate? 
\q2 ?Neu nam soi silolo walu siu? 
\q1 ?A qie vin galohagi nigo? 
\q2 ?I nge vin toregi na nom garohuri? 
\q1  
\v 10 O \nd Huqe,\nd* go rongo au me go hagavi eu, 
\q2 me O \nd Huqe,\nd* go vuragi na buluigu. 
\b  
\q1  
\v 11 Nigo gu dori na nongu tangiana silo hawana. 
\q2 Nigo gu lei vohogi na luqegu a luqe asi 
\q2 siu gom luqegi eu gena hahavusiana. 
\q1  
\v 12 Huri ve a lologu na huri ehi lawego, 
\q2 siu neu na mese toga maunegi. 
\q1 Nongu \nd Huqe\nd* Mauri, 
\q2 neu nain ware hagegi nigo tavagi tuei. 
\c 51  
\d A ahi noi Devet. A tomtomuei buegerigeri. I tangaloi leo ligoligogi Natan, u vumai lobena, lo tagugi i Devet u vei na doridori esi mei Batsiba. 
\q1  
\v 1 Huqe Mauri go hagavi eu na huri na nomu vaigarea lawua 
\q2 huri na nongu doridori esi. 
\q1 Lo nomu hahagavi gon lai vohogi 
\q2 na nongu asiana. 
\q1  
\v 2 Gon solo vohogi na nongu asiana doluegi, 
\q2 me go vagahagi eu dena na bugungu doluegi. 
\q1  
\v 3 Ba huri nau ilo na nongu doridori esi mei eu, 
\q2 siu a bugungu mo eno mei eu vataha na tarogi. 
\q1  
\v 4 Siu nigo hogosie nau vagasile vovohigo 
\q2 me nau vei na gineu esi lolo matamu. 
\q1 Tavohe gom lanqa, u vovohoi, 
\q2 me tavohe gom vevegi na tangaloi u vovohoi. 
\q1  
\v 5 A hogo nau vora lolo asiana siu neu 
\q2 a nongu galegale asi lungu tavohe i retahigu mo tinogi eu 
\q1  
\v 6 Gu tarave na hogo lolo loloi tangaloi, 
\q2 me gu huhui eu gena lolorani lolo buloi dimwangogu. 
\b  
\q1  
\v 7 Vagahagi eu gena digugu\f + \fr 51.7 \ft Hisob a rivurivu dam vuie lolo dai. Mo tuliana lo gineu sige tangaloi, mo gogonagi nire me mo solo vohogi bugure.\f* me neu nain mwasara, 
\q2 solo vohogi na nongu asiana me neu nain mevute vin liu na vire hi a wagahiata. 
\q1  
\v 8 Vai eu na rongarea me na havuhevu. 
\q2 Siregi na hui gu momogagi nire ra havuhevu. 
\q1  
\v 9 Vunigi na nagomu dena nongu asiana 
\q2 me go hara vohogi na nongu doridori esi doluegi. 
\b  
\q1  
\v 10 O Huqe Mauri, go vai na lolo lolongu, a dimwango mwasara, 
\q2 me go vai na tanumwe garaqa huire lolo lolongu. 
\q1  
\v 11 Mese tuli vohogi eu denigo, 
\q2 me go mese lai vohogi na nom Tanumwe Gogona deni eu. 
\q1  
\v 12 Gon bete muleagi lawe au a hahavusi na nom vaga mwasoana, 
\q2 me gon bete na nom tanumwei tabetabe na gaiture au. 
\b  
\q1  
\v 13 Siu neu nain huhui na tangaloi esi kena nom leo 
\q2 me ngere rain tudori su lobemu. 
\q1  
\v 14 O Huqe Mauri, Huqe Mauri nigo nongu vagamwasoi, 
\q2 go vagamwasoi eu dena dai, 
\q1 siu neu nain huri na ahi hahavusiana 
\q2 huri na nomu vovohoiana. 
\q1  
\v 15 Huqe, go tagahi na singogu 
\q2 siu a wawagu vin ware hagegi na henamu. 
\q1  
\v 16 Huri nigo gom rahagi na bulengu kankarue nam hogohogo lawego, 
\q2 siu nigo goin hevuhevu tea lo nongu hure bonboni. 
\q1  
\v 17 A hogohogo, O Huqe Mauri, a tanumwegi u mevurivuri 
\q2 me a dimwangona mo hahagavi. 
\q2 O Huqe Mauri, go mese tudori denie. 
\b  
\q1  
\v 18 Go vai na gineu garea lawe na Saeon; mwerehi gom taranie. 
\q2 Go hagovi na qetuqetu goro na Jerusalem. 
\q1  
\v 19 Siu a hogohogo rau vovohoi, 
\q2 a hure bonboni bulugi dodoluegi vin veigo goin hevuhevu, 
\q2 me a bulugi boegi doluegi rain hureana lo nom vonda gogona. 
\c 100  
\d A ahi na veve garea. 
\q1  
\v 1 Galohagi na \nd Huqe,\nd* mena hahavusiana, 
\q2 dali na ure. 
\q1  
\v 2 Galohagi na \nd Huqe,\nd* mena hahavusiana; 
\q2 nein vumai lo nagona mena ahi hahavusiana. 
\q1  
\v 3 Nei ilo huri ve i \nd Huqe,\nd* nge i Huqe Mauri; 
\q1 nge u vei ginde 
\q2 me ginde a nona, 
\q1 ginde nona tangaloi 
\q2 me a nona buri sibsib nge vin leohuri ginde lo tanona. 
\b  
\q1  
\v 4 Ahu turu na nona matai ara mena veve garea, 
\q2 me nen ware roroagi nie lolo sarana. 
\q1 Nen garea hurie 
\q2 me nen vaga roroagi na henana. 
\q1  
\v 5 Huri a \nd Huqe,\nd* nge u garea lawuagi 
\q2 me a nona vaigarea vin eno randu, 
\q1 a nona garohuri vin eno duruhi 
\q2 na babagi doluegi vin tuei.