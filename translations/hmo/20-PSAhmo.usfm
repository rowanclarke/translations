\id PSA PSALM, Hiri Motu Bible, PNG, 5/93 
\h SALAMO 
\toc1 SALAMO 
\toc2 SALAMO 
\mt1 SALAMO  
\c 1  
\s1 Moale korikori  
\q1
\v 1 Inai bamona taudia be idia moale momokani:  
\q1 Idia ese kara dika taudia edia sisiba,  
\q1 bona edia laloa idia abia dae lasi.  
\q1 Idia ese kerere taudia edia kara bamona idia karaia lasi,  
\q1 Bona Dirava idia ura lasi taudia danu,  
\q1 idia noho hebou lasi.   
\q1
\v 2 Ma inai taudia ese,  
\q1 Lohiabada ena Taravatu dekenai idia moale,  
\q1 bona Lohiabada ena Taravatu idia laloa,  
\q1 dina bona hanuaboi ibounai lalonai.   
\q1
\v 3 Ma inai taudia be,  
\q1 sinavai badinai idia hadoa audia bamona,  
\q1 edia huahua atoa neganai,  
\q1 idia ese anina idia atoa bada herea.  
\q1 Edia raurau danu do idia kakoro lasi.  
\q1 Edia gaukara ibounai be ena anina ia vara,  
\q1 bona mai edia kwalimu danu.   
\b  
\q1
\v 4 Kara dika taudia be unai bamona lasi.  
\q1 Idia be uiti ena momoru bamona.  
\q1 Lai ese idia ia hodaia lao.   
\q1
\v 5 Kara dika taudia be Dirava ese,  
\q1 Kota Bada lalonai do ia kota henidia.  
\q1 Kerere idia karaia taudia be,  
\q1 Dirava ena taudia danu do idia noho hebou lasi.   
\q1
\v 6 Kara maoromaoro taudia be,  
\q1 Lohiabada ese ia hakaudia bona ia naridia,  
\q1 to kara dika taudia edia dala,  
\q1 ena dokona be mase momokani.   
\c 2  
\s1 Dirava ese ia abia hidi King  
\q1
\v 1 Badina dahaka bese idauidau ese,  
\q1 tuari daladia idia tahua?  
\q1 Badina dahaka taunimanima edia laloa be kavakava?   
\q1
\v 2 Edia king taudia be tuari totona idia toreisi,  
\q1 bona edia lohia taudia ese idia haboua noho.  
\q1 Idia ura be,  
\q1 Lohiabada bona ia ese ia Abia Hidi Tauna,  
\q1 do idia dagedage henia.   
\q1
\v 3 Idia gwau,  
\q1 “Ita ura lasi Lohiabada,  
\q1 bona iena King henunai do ita noho,  
\q1 Idia ese ita idia guia vadaeni,  
\q1 be ita ese unai guia varodia do ita negea.”   
\b  
\q1
\v 4 Guba dekenai ia noho Dirava ese,  
\q1 idia dekenai do ia kiri.  
\q1 Ia ese edia laloa dekenai do ia hevaseha.   
\q1
\v 5 Ia ese idia do ia gwau henia,  
\q1 mai badu danu.  
\q1 Iena badu mai siahu bada ese do ia hagaridia.   
\q1
\v 6 Do ia gwau,  
\q1 “Siona Ororo ena ataiai dekenai,  
\q1 lauegu ororo helagana dekenai,  
\q1 lauegu King do lau atoa.”   
\b  
\q1
\v 7 King do ia hereva, do ia gwau,  
\q1 “Lau ese Lohiabada ena hereva do lau harorolaia,  
\q1 inai bamona lau dekenai ia gwau,  
\q1 ‘Oi be lauegu natuna,  
\q1 hari dina dekenai oi lau havaraia vadaeni.   
\q1
\v 8 Lau dekenai oi noinoi,  
\q1 vadaeni lau ese bese idauidau ibounai,  
\q1 be oi dekenai do lau henia.  
\q1 Tanobada ibounai oi dekenai do lau henia, oiemu.   
\q1
\v 9 Oi ese idia do oi hamakohia,  
\q1 auri itotohi dekena amo.  
\q1 Uro bamona, idia do oi makohia maragimaragi.’ ”   
\b  
\q1
\v 10 Unai dainai, king taudia e,  
\q1 inai sisiba do umui kamonai:  
\q1 Tanobada ena lohia taudia e, do umui diba.   
\q1
\v 11 Lohiabada do umui tomadiho henia,  
\q1 mai emui gari danu,  
\q1 Mai heudeheude danu Lohiabada do umui hanamoa.   
\q1
\v 12 Dirava ena Natuna do umui kisi henia,  
\q1 do ia badu garina,  
\q1 bona do umui mase haraga garina.  
\q1 Badina be iena badu be ia vara haraga diba.  
\q1 To ia dekenai idia abidadama taudia be idia moale,  
\q1 ia ese ia naridia dainai.   
\c 3  
\s1 Daba guriguri, Davida ena  
\q1
\v 1 Lohiabada e,  
\q1 lau dekenai idia dagedage taudia be momo herea.  
\q1 Lau dekenai idia tuari henia taudia,  
\q1 be idia momo lao noho.   
\q1
\v 2 Idia ese lau idia herevalaia noho.  
\q1 Idia gwau, “Dirava ese ia do ia durua lasi.”   
\b  
\q1
\v 3 To Lohiabada e,  
\q1 oi ese dika dekena amo lau oi gimaia noho.  
\q1 Oi ese kwalimu lau dekenai oi henia noho.  
\q1 Oi ese egu lalona oi hagoadaia lou.   
\q1
\v 4 Lohiabada dekenai durua totona lau boiboi noho,  
\q1 bona iena ororo helagana dekena amo,  
\q1 lau dekenai ia haere henia.   
\b  
\q1
\v 5 Lau hekure, lau mahuta, bona lau noga lou,  
\q1 bona hanuaboi ena negana ibounai,  
\q1 Lohiabada ese lau ia naria noho.   
\q1
\v 6 Taunimanima 1000, 1000 dekenai lau gari lasi.  
\q1 Egu kahana kahana dekena amo,  
\q1 lau dekenai idia tuari henia noho,  
\q1 to lau gari henidia lasi.   
\b  
\q1
\v 7 Lohiabada e, lau dekenai do oi mai.  
\q1 Egu Dirava e, lau do oi hamauria.  
\q1 Lau dekenai idia tuari henia taudia,  
\q1 edia dika davana do oi henia.  
\q1 Do idia manoka lao,  
\q1 vadaeni lau do idia hadikaia diba lasi.   
\q1
\v 8 Lohiabada e, oi sibona ese ai oi hamauria diba.  
\q1 Oi ese oiemu bese taudia oi hanamoa noho.   
\c 4  
\s1 Adorahi guriguri, Davida ena  
\q1
\v 1 Egu Dirava e, oiemu kara be maoromaoro.  
\q1 Oi dekenai lau boiboi neganai,  
\q1 lau dekenai oi haere vadaeni.  
\q1 Dika ese lau ia hadikaia vadaeni neganai,  
\q1 oi ese lau oi durua.  
\q1 Hari danu lau dekenai do oi bogahisihisi henia,  
\q1 egu noinoi mani do oi kamonai.   
\b  
\q1
\v 2 Taunimanima e, egu ladana namona,  
\q1 be do umui hadikaia noho ela bona edena negai?  
\q1 Hereva kavakava do umui ura henia,  
\q1 bona hereva koikoi do umui tahua noho,  
\q1 ela bona edena negai?   
\b  
\q1
\v 3 Do umui laloa,  
\q1 Lohiabada ese kara maoromaoro taudia,  
\q1 be ia abia hidi vadaeni, iena.  
\q1 Bona lau ese lau boiboi henia neganai,  
\q1 ia ese lau dekenai ia kamonai henia.   
\b  
\q1
\v 4 Emui badu ia toreisi neganai,  
\q1 do umui kara dika lasi.  
\q1 Emui mahuta gabunai umui noho neganai,  
\q1 emui lalona do umui tahua,  
\q1 bona badu ena laloa do umui koua.   
\q1
\v 5 Boubou maorodia Lohiabada dekenai do umui henia,  
\q1 bona Lohiabada do umui abidadama henia.   
\b  
\q1
\v 6 Taunimanima momo ese inai bamona idia guriguri noho:  
\q1 “Lohiabada e, daika ese ai do ia hanamoa diba?  
\q1 Oiemu vairana ena diari,  
\q1 be mani ai dekenai do oi hedinaraia.”   
\q1
\v 7 To oi ese moale bada,  
\q1 be lau dekenai oi henia vadaeni,  
\q1 bona egu moale ese,  
\q1 uiti bona uaina momo idia davaria taudia,  
\q1 edia moale ia hereaia momokani.   
\b  
\q1
\v 8 Mai egu maino danu,  
\q1 lau hekure bona lau mahuta noho.  
\q1 Lohiabada e, oi sibona ese lau oi naria,  
\q1 bona dika dekena amo lau oi gimaia noho.   
\c 5  
\s1 Davida ese Lohiabada ia noia, dika dekena amo do ia naria  
\q1
\v 1 Lohiabada e, egu hereva do oi kamonai henia.  
\q1 Egu lalohisihisi ena regena mani do oi laloa.   
\q1
\v 2 Egu King bona egu Dirava e!  
\q1 Durua totona oi dekenai lau taitai,  
\q1 be mani do oi kamonai henia,  
\q1 badina be oi dekenai lau noinoi noho.   
\q1
\v 3 Lohiabada e,  
\q1 daba neganai egu gadona oi kamonai noho.  
\q1 Daba neganai,  
\q1 egu noinoi oiemu vairana dekenai lau atoa,  
\q1 bona oiemu haere lau naria noho.   
\b  
\q1
\v 4 Badina oi be kara dika oi moalelaia lasi,  
\q1 bona oi dekenai dika ta ia noho lasi.   
\q1
\v 5 Hekokoroku taudia,  
\q1 be oiemu vairana dekenai idia gini diba lasi.  
\q1 Kara dika taudia ibounai,  
\q1 be oi ese oi badu henidia noho.   
\q1
\v 6 Koikoi taudia be oi ese oi hadikaia ore noho.  
\q1 Lohiabada ese alaia taudia bona koikoi taudia,  
\q1 ia dagedage henidia noho.   
\b  
\q1
\v 7 To oiemu lalokau bada dainai,  
\q1 lau be oiemu Ruma dekenai lau raka vareai diba.  
\q1 Oiemu Dubu Helaga lalonai,  
\q1 oi dekenai lau tomadiho henia diba.  
\q1 Oi dekenai do lau tomadiho mai mataurai danu.   
\q1
\v 8 Lohiabada e,  
\q1 lau dekenai idia tuari henia taudia be momo herea.  
\q1 Unai dainai oiemu kara maoromaoro dalana,  
\q1 dekenai lau do oi hakaua,  
\q1 bona oiemu dala be egu vairana dekenai,  
\q1 do oi hedinaraia namonamo.   
\b  
\q1
\v 9 Lau dekenai idia dagedage taudia,  
\q1 edia hereva be momokani lasi, abidadama gauna lasi.  
\q1 Idia edia kudouna ena ura be,  
\q1 taunimanima do idia alaia mase.  
\q1 Edia gadona ena hereva be guria gabuna bamona,  
\q1 bona edia malana be manada koikoi.   
\q1
\v 10 Dirava e, edia dika ena davana do oi henia.  
\q1 Mani emu kara edia laloa dikadia ese,  
\q1 edia moru do idia havaraia.  
\q1 Edia kara dika be momo dainai,  
\q1 oiemu vairana dekena amo do oi luludia siri,  
\q1 badina be idia ese oi idia dagedage henia noho.   
\b  
\q1
\v 11 To oi dekenai idia abidadama henia taudia,  
\q1 be do idia moale,  
\q1 do idia moale momokani ela bona hanaihanai.  
\q1 Oi ese oiemu ladana idia ura henia taudia ibounai,  
\q1 bona oi dekenai idia moale taudia,  
\q1 be do oi gimaia noho.   
\q1
\v 12 Badina Lohiabada e,  
\q1 oi ese kara maoromaoro taudia oi hanamoa noho.  
\q1 Oiemu lalokau ese kesi bamona,  
\q1 kara maoromaoro taudia ia gimaia noho.   
\c 6  
\s1 Davida ese dika ia davaria neganai, durua totona Lohiabada ia noinoi  
\q1
\v 1 Lohiabada e, oiemu badu dekena amo,  
\q1 lau do oi gwau henia lasi.  
\q1 Oiemu badu siahu herea dekena amo,  
\q1 lau do oi matakani henia lasi.   
\q1
\v 2 Lohiabada e, mani emu kara,  
\q1 lau dekenai do oi bogahisihisi henia,  
\q1 badina lau be manoka vadaeni.  
\q1 Lohiabada e, mani lau do oi hanamoa,  
\q1 badina be egu turiana idia hisihisi noho,   
\q1
\v 3 egu lauma danu ia hisihisi bada noho.  
\q1 Lohiabada e,  
\q1 oiemu durua totona lau naria noho,  
\q1 do lau naria ela bona edena negai?   
\q1
\v 4 Lohiabada e, oi mai,  
\q1 bona lau do oi hamauria.  
\q1 Oiemu bogahisihisi dainai,  
\q1 mase dekena amo lau do oi veria mauri.   
\q1
\v 5 Badina be ia mase neganai,  
\q1 tau ta ese oi ia laloa diba lasi.  
\q1 Mase taudia edia gabu dekenai,  
\q1 daika ese oi do idia hanamoa?   
\b  
\q1
\v 6 Lalohisihisi dainai lau manoka noho.  
\q1 Hanuaboi ta ta ibounai lalonai,  
\q1 egu geda dekenai lau tai noho, tai noho.  
\q1 Egu mahuta geda be,  
\q1 egu matana ena ranu ese ia hapariparia vadaeni.   
\q1
\v 7 Egu matana be idia diburadibura noho,  
\q1 egu lalohisihisi dainai.  
\q1 Egu matana be idia manoka noho,  
\q1 tau buruka ena matana bamona,  
\q1 badina lau hadikaia gwauraia taudia be momo herea.   
\b  
\q1
\v 8 Kara dika taudia ibounai e,  
\q1 lau dekena amo do umui siri!  
\q1 Badina be Lohiabada ese egu taitai,  
\q1 ena regena ia kamonai vadaeni.   
\q1
\v 9 Lohiabada ese egu noinoi ia kamonai noho.  
\q1 Egu guriguri durua totona ia kamonai henia.   
\q1
\v 10 Lau idia hadikaia gwauraia taudia,  
\q1 be do idia hemarai,  
\q1 bona edia lalodia do idia hekwarahi.  
\q1 Dirava ese idia do ia hagaria,  
\q1 bona lau dekena amo do ia luludia haraga.   
\c 7  
\s1 Kota maoromaoro totona Davida ia noinoi  
\q1
\v 1 Lohiabada e, egu Dirava e,  
\q1 lau ese oi dekenai lau abidadama henia noho.  
\q1 Lau idia lulua noho taudia,  
\q1 dekena amo lau do oi veria mauri,  
\q1 lau do oi hamauria,   
\q1
\v 2 idia be laiona bamona,  
\q1 lau do idia darea garina,  
\q1 bona lau be durua tauna lasi dainai,  
\q1 lau do idia darea maragimaragi garina.   
\b  
\q1
\v 3 Lohiabada e, egu Dirava e,  
\q1 bema kerere lasi tauna ta lau hadikaia,  
\q1 bema lauegu imana dekenai kerere ia noho,   
\q1
\v 4 o bema lau ese,  
\q1 egu turana dekenai kara dika lau karaia,  
\q1 o bema lau dekenai ia tuari tauna,  
\q1 be lau ese ia lau hadikaia kava,   
\q1
\v 5 unai neganai,  
\q1 lau idia tuari henia taudia,  
\q1 be do oi koua lasi,  
\q1 vadaeni idia ese lau do idia lulua mai,  
\q1 bona idia ese lau do idia dogoatao.  
\q1 Idia ese lau do idia gwadaia,  
\q1 lau do idia alaia,  
\q1 bona lau be tano dekenai do lau moru,  
\q1 do lau mase momokani.   
\b  
\q1
\v 6 Lohiabada e,  
\q1 mai badu danu do oi toreisi,  
\q1 lau do idia hamasea gwauraia taudia do oi koua!  
\q1 Lau durua totona do oi toreisi!  
\q1 Kota maoromaoro egu latanai do oi gwauraia.   
\q1
\v 7 Taunimanima ibounai do oi haboua,  
\q1 idia ese oi do idia hagegea,  
\q1 bona oi ese ataiai dekena amo,  
\q1 do oi kota henidia.   
\q1
\v 8 Lohiabada e, oi be bese ibounai,  
\q1 bona taunimanima ibounai edia kota biaguna.  
\q1 Lohiabada e,  
\q1 egu kara maoromaoro hegeregerena,  
\q1 lau do oi kota henia.  
\q1 Oi diba vadaeni lau be kerere lasi.   
\q1
\v 9 Oi be kara maoromaoro Diravana,  
\q1 bona oi ese aiemai laloa,  
\q1 bona aiemai ura oi tahua noho.  
\q1 Kara dika taudia edia dika do oi hadokoa,  
\q1 bona kara maoromaoro taudia dekenai,  
\q1 ahuna namona do oi henia.   
\b  
\q1
\v 10 Dirava, Ataiai Momokani ena Dirava,  
\q1 be egu kesi.  
\q1 Ia dekenai idia kamonai henia taudia,  
\q1 be ia ese ia hamauria noho.   
\q1
\v 11 Dirava be kota biaguna namona,  
\q1 mai ena laloa maoromaoro bona momokani danu.  
\q1 Nega ibounai ia ese,  
\q1 kara dika taudia edia davana ia henia noho.   
\q1
\v 12 Bema tau ta ese,  
\q1 iena lalona ia giroa lasi neganai,  
\q1 Dirava ese iena tuari kaia do ia segea.  
\q1 Iena peva danu do ia veria,  
\q1 do ia karaia hegaegae noho.   
\q1
\v 13 Ia ese iena ala-ala gaudia,  
\q1 be iena imana dekenai ia abia hegaegae,  
\q1 bona iena diba be,  
\q1 lahi gaudia ia halaoa vadaeni.   
\b  
\q1
\v 14 Oi itaia,  
\q1 kara dika tauna ese,  
\q1 dika ia havaraia noho.  
\q1 Ia ese dika karaia totona,  
\q1 ia laloa momo noho.  
\q1 Ia ese kerere do ia karaia,  
\q1 ena dala ia laloa guna.  
\q1 Koikoi daladia danu ia havaraia noho.   
\q1
\v 15 To idau taudia abia totona,  
\q1 ia geia vadaeni guri ena lalonai,  
\q1 be unai dika tauna sibona ese do ia moru diho.   
\q1
\v 16 Unai dekena amo,  
\q1 unai tau ena dika ese,  
\q1 sibona do ia hadikaia.  
\q1 Sibona ena dagedage ese,  
\q1 unai tau ena kwarana dekenai do ia moru.   
\b  
\q1
\v 17 Lohiabada ena kara maoromaoro dainai,  
\q1 ia lau tanikiu henia noho.  
\q1 Lohiabada, Ataiai Momokani Dirava,  
\q1 ena ladana lau hanamoa noho inai.   
\c 8  
\s1 Dirava ena hairai bada, bona taunimanima edia dagi bada  
\q1
\v 1 Lohiabada e, aiemai Lohiabada,  
\q1 tanobada ena kahana ibounai lalonai,  
\q1 oiemu ladana be namo herea.  
\q1 Oiemu hairaina,  
\q1 be guba dekenai oi atoa vadaeni.   
\q1
\v 2 Natudia maragidia,  
\q1 rata idia inua memero,  
\q1 edia uduna dekena amo,  
\q1 oi idia hanamoa noho.  
\q1 Oi be oi goada noho dainai,  
\q1 oi dekenai idia dagedage gwauraia taudia,  
\q1 be mai edia dala lasi.  
\q1 Oi dekenai idia tuari gwauraia taudia,  
\q1 be oi ese oi koua noho.   
\b  
\q1
\v 3 Oiemu guba lau itaia,  
\q1 oi ese oiemu imana dekenai oi karaia.  
\q1 Hua bona hisiu danu be oi ese oi atoa.   
\q1
\v 4 Taunimanima be dahaka,  
\q1 oi ese idia oi laloa noho?  
\q1 Taunimanima be maragi herea,  
\q1 dahaka dainai oi ese oi naridia noho?   
\q1
\v 5 Oi ese taunimanima oi karaia,  
\q1 be aneru sibona ese sisina idia hereaia.  
\q1 Oi ese taunimanima dekenai,  
\q1 hairai bona mataurai oi henia.   
\q1
\v 6 Oiemu imana ese idia karaia gaudia ibounai,  
\q1 be taunimanima dekenai oi henia,  
\q1 do idia biagudia.  
\q1 Gau ibounai be,  
\q1 taunimanima edia aena henunai,  
\q1 oi atodia vadaeni:   
\q1
\v 7 Mamoe bona boromakau ibounai,  
\q1 uda boroma ibounai danu.   
\q1
\v 8 Ataiai manudia,  
\q1 bona davara ena gwarume,  
\q1 bona davara dobu lalonai idia heau gaudia ibounai.   
\q1
\v 9 Lohiabada e, aiemai Lohiabada,  
\q1 tanobada ena kahana ibounai lalonai,  
\q1 oiemu ladana be ia namo herea momokani.   
\c 9  
\s1 Lohiabada do ita tanikiu henia, iena kota maoromaoro karadia dainai  
\q1
\v 1 Lohiabada e, oi do lau hanamoa,  
\q1 mai egu kudouna ibounai danu.  
\q1 Oiemu hoa karadia ibounai,  
\q1 be do lau herevalaia.   
\q1
\v 2 Mai moale bada danu,  
\q1 oi do lau hanamoa noho.  
\q1 Siahu Ibounai Dirava e,  
\q1 oiemu ladana hanamoa totona,  
\q1 ane do lau abia.   
\b  
\q1
\v 3 Oi be oi hedinarai neganai,  
\q1 lau dekenai idia tuari henia taudia,  
\q1 be idia giroa lou.  
\q1 Idia moru kava,  
\q1 bona oiemu vairana dekenai idia mase.   
\q1
\v 4 Lohiabada e,  
\q1 oiemu kota hereva ibounai,  
\q1 be maoromaoro bona momokani,  
\q1 bona oi ese egu kara maoromaoro,  
\q1 be oi hamomokania vadaeni.   
\q1
\v 5 Bese idauidau be,  
\q1 oi ese oi gwau henia vadaeni,  
\q1 bona kara dika taudia be,  
\q1 oi ese oi hadikaia ore vadaeni.  
\q1 Idia edia ladana be,  
\q1 tau ta ese do ia laloa lou lasi.   
\q1
\v 6 Ai dekenai idia tuari henia taudia,  
\q1 be do idia dika, ela bona hanaihanai.  
\q1 Idia boio vadaeni.  
\q1 Oi ese edia hanua ibounai,  
\q1 be oi hadikaia ore vadaeni,  
\q1 bona edia ladana be,  
\q1 taunimanima ese do idia laloa lou lasi.   
\b  
\q1
\v 7 To Lohiabada ena King siahuna,  
\q1 be do ia noho ela bona hanaihanai.  
\q1 Ia ese iena terona ia haginia vadaeni,  
\q1 kota gaukara do ia naria totona.   
\q1
\v 8 Ia ese mai maoromaoro bona momokani danu,  
\q1 tanobada do ia kota henia.  
\q1 Bese idauidau ibounai,  
\q1 be Lohiabada ese do ia kota henia,  
\q1 mai ena laloa maoromaoro danu.   
\q1
\v 9 Tau dikadia ese idia dagedage henia taudia,  
\q1 be Lohiabada ese do ia bogahisihisi henia.  
\q1 Ia be edia heau mauri gabuna momokani,  
\q1 dika ia ginidae neganai.   
\q1
\v 10 Lohiabada e,  
\q1 oiemu ladana idia diba taudia ese,  
\q1 oi do idia abidadama henia.  
\q1 Oi dekenai idia mai taudia,  
\q1 be oi ese idia do oi rakatania lasi,  
\q1 lasi momokani.   
\b  
\q1
\v 11 Lohiabada, Siona dekenai ia noho Dirava,  
\q1 be do umui hanamoa!  
\q1 Iena kara be,  
\q1 bese idauidau edia huanai do umui herevalaia!   
\q1
\v 12 Badina be rara ena davana,  
\q1 ia henia noho ena Dirava ese,  
\q1 hisihisi idia abia noho taudia ia laloa.  
\q1 Edia taitai ia laloaboio lasi,  
\q1 bona idia dekenai hisihisi idia henia taudia,  
\q1 edia kerere davana be Dirava ese do ia henia.   
\b  
\q1
\v 13 Lohiabada e,  
\q1 lau dekenai do oi bogahisihisi henia!  
\q1 Lau idia hadikaia noho taudia dekena amo,  
\q1 lau abia hisihisi mani do oi itaia.  
\q1 Lohiabada e,  
\q1 mase dekena amo lau do oi hamauria.   
\q1
\v 14 Unai neganai, Ierusalema taudia,  
\q1 edia vairanai do lau gini diba,  
\q1 bona oi ese lau oi hamauria kara ibounai,  
\q1 be idia dekenai do lau hamaorolaia.  
\q1 Oi ese lau oi hamauria dainai,  
\q1 do lau moale bada herea momokani.   
\q1
\v 15 Dirava diba lasi taudia ese,  
\q1 guri badana idia geia vadaeni,  
\q1 bona iena lalonai idia moru.  
\q1 Sibodia idia karaia tarapu ese,  
\q1 idia ia abia vadaeni.   
\q1
\v 16 Lohiabada ese sibona ena kara,  
\q1 be ia hedinaraia vadaeni,  
\q1 iena kota maoromaoro dekena amo.  
\q1 Kara dika taudia be edia kara ese,  
\q1 idia ia hadikaia noho.   
\q1
\v 17 Kara dika taudia ibounai,  
\q1 edia dokona be mase.  
\q1 Dirava idia negea taudia ibounai,  
\q1 danu edia dokona be mase.   
\q1
\v 18 Gau lasi taudia,  
\q1 be Dirava ese ia laloaboio lasi.  
\q1 Ogogami taudia edia abidadama,  
\q1 be abidadama kava lasi.  
\q1 Edia abidadama ena anina,  
\q1 be do ia boio ore lasi,  
\q1 to gabeai do ia vara.   
\b  
\q1
\v 19 Lohiabada e, do oi toreisi,  
\q1 taunimanima edia hekokoroku do oi koua!  
\q1 Dirava idia ura henia lasi taudia,  
\q1 be do oi kota henia,  
\q1 bona edia dika davana do oi gwauraia.   
\q1
\v 20 Lohiabada e, idia do oi hagaria,  
\q1 bona idia do oi hadibaia,  
\q1 idia be taunimanima sibona.   
\c 10  
\s1 Kota maoromaoro totona guriguri ta  
\q1
\v 1 Lohiabada e,  
\q1 badina dahaka lau dekena amo,  
\q1 oi be daudau dekenai oi gini noho?  
\q1 Badina dahaka dika negadia lalonai,  
\q1 oi be hunia dekenai oi noho?   
\q1
\v 2 Kara dika taudia be mai hekokoroku danu,  
\q1 idia ese ogogami taudia,  
\q1 idia dagedage henia noho.  
\q1 Unai dika taudia sibodia edia laloa dika,  
\q1 ese idia do ia hadikaia be namo.   
\b  
\q1
\v 3 Tau dikana ese,  
\q1 iena ura dikadia dekenai ia hekokoroku noho.  
\q1 Ma gau ia ura henia momo tauna ese,  
\q1 Lohiabada ia negea,  
\q1 ma Lohiabada dekenai ia hereva dika noho danu.   
\q1
\v 4 Tau dikana ese Lohiabada ia tahua lasi,  
\q1 bona iena hekokoroku dainai,  
\q1 ia laloa Dirava be lasi.   
\q1
\v 5 Kara dika tauna be,  
\q1 iena kara ibounai dekenai ia kwalimu noho,  
\q1 Lohiabada ena kota henia kara be ataiai herea,  
\q1 unai dainai ia laloa lasi Dirava dekenai.  
\q1 Tau dikana dekenai idia tuari henia taudia,  
\q1 be ia ese idia ia kirikirilaia noho.   
\q1
\v 6 Sibona dekenai inai bamona ia laloa:  
\q1 “Gau ta ese lau do ia hamarerea lasi.  
\q1 Lau be nega ta dika do lau davaria lasi.”   
\q1
\v 7 Kara dika tauna ia hereva negadia ibounai,  
\q1 ia ese taunimanima ia hadikaia,  
\q1 ia koikoi,  
\q1 bona hereva dagedage ia gwauraia noho.   
\q1
\v 8 Hanua edia lalonai ia hunia noho,  
\q1 kerere lasi taudia do ia alaia mase totona.  
\q1 Ia ese manoka taudia ia tahua noho,  
\q1 do ia hadikadia totona.   
\q1
\v 9 Iena hunia gabuna lalonai ia naria noho,  
\q1 laiona ese iena guri lalonai,  
\q1 boroma alaia totona ia naria bamona.  
\q1 Ogogami taudia hadikaia totona ia naria noho.  
\q1 Iena tarapu lalonai ia abidia noho,  
\q1 bona gabu ta dekenai ia veridia lao noho.   
\q1
\v 10 Ia ese ia daredia vadaeni taudia,  
\q1 be idia dika vadaeni.  
\q1 Iena goada ena siahu ese,  
\q1 idia ia hadikaia vadaeni.   
\q1
\v 11 Kara dika tauna ese sibona dekenai ia gwau:  
\q1 “Dirava ese egu kara ia laloa lasi,  
\q1 Dirava ese iena matana ia hakapua vadaeni,  
\q1 bona ia ese lau do ia itaia lasi.”   
\b  
\q1
\v 12 Lohiabada e,  
\q1 unai kara dika taudia,  
\q1 edia davana do oi henia.  
\q1 Idia hisihisi henidia noho taudia,  
\q1 be mani do oi durua.   
\q1
\v 13 Kara dika tauna be edena bamona,  
\q1 ia ese Dirava do oi negea diba?  
\q1 Edena bamona do ia gwau,  
\q1 “Dirava ese lau do ia panisia lasi?”   
\q1
\v 14 To Lohiabada e,  
\q1 oi ese gau ibounai oi itaia noho,  
\q1 oi ese hekwarahi bona hisihisi oi itaia noho.  
\q1 Bona oi ese taunimanima durua totona,  
\q1 oi gini hegaegae noho.  
\q1 Manoka taudia ese,  
\q1 oi dekenai idia abidadama noho,  
\q1 badina be oi ese gau lasi taudia,  
\q1 be nega ibounai oi durua momokani vadaeni.   
\q1
\v 15 Kara dika bona kerere taudia,  
\q1 edia siahu mani do oi hamakohia.  
\q1 Edia kerere dainai,  
\q1 edia davana do oi henia,  
\q1 ela bona do idia karaia lou lasi.   
\b  
\q1
\v 16 Lohiabada be do ia King ela bona hanaihanai.  
\q1 Dirava idaudia dekenai idia tomadiho taudia,  
\q1 be Dirava ena tano dekena amo do idia boio.   
\q1
\v 17 Lohiabada e,  
\q1 oi ese manau taudia edia noinoi,  
\q1 be do oi kamonai henia, ani?  
\q1 Oi ese edia lalona do oi hagoadaia,  
\q1 bona edia taitai do oi kamonai.   
\q1
\v 18 Edia tamadia sinadia be lasi natudia,  
\q1 bona idia hisihisi noho taudia,  
\q1 edia tai mani do oi kamonai.  
\q1 Edia kota do oi durua,  
\q1 mai oiemu laloa maoromaoro bona momokani danu.  
\q1 Unai neganai tanobada tauna ta ese,  
\q1 idia hagaria karana ta,  
\q1 be do ia karaia lou lasi.   
\c 11  
\s1 Davida ese Lohiabada ia abidadama henia  
\q1
\v 1 Mauri do lau davaria momokani,  
\q1 badina be Lohiabada lau abidadama henia.  
\q1 Unai dainai,  
\q1 badina dahaka lau umui hamaoroa, umui gwau:  
\q1 “Ororo dekenai do ita heau mauri,  
\q1 manu ia heau bamona!   
\q1
\v 2 Badina umui itaia,  
\q1 kara dika taudia ese,  
\q1 edia peva idia veria noho.  
\q1 Edia diba be varo dekenai idia atoa hegaegae,  
\q1 kara maoromaoro taudia do idia pidia totona.   
\q1
\v 3 Bema mauri ena badina ia makohia noho neganai,  
\q1 kara maoromaoro taudia be dahaka idia karaia diba?”   
\b  
\q1
\v 4 Lohiabada be iena Dubu Helaga lalonai ia noho.  
\q1 Lohiabada ena terona be guba dekenai ia noho.  
\q1 Gabu ibounai dekenai idia noho taunimanima,  
\q1 be Lohiabada ese ia itaia noho,  
\q1 bona edia kara ibounai ia diba.   
\q1
\v 5 Taunimanima namodia bona dikadia edia kara,  
\q1 be Dirava ese ia tahua, maka tamona dekenai.  
\q1 Taravatu utua taudia be,  
\q1 Lohiabada ese ia badu henidia noho.   
\q1
\v 6 Kara dika taudia edia latanai,  
\q1 Dirava ese lahi ena gida mai hururuhururu,  
\q1 bona salipa danu ia siaia diho noho.  
\q1 Ma lai dikadia momokani dekena amo,  
\q1 ia matakani henidia noho.   
\q1
\v 7 Lohiabada be mai ena kara maoromaoro,  
\q1 bona kara namodia ia ura henia noho.  
\q1 Unai bamona idia karaia taudia,  
\q1 be Lohiabada ena vairana dekenai do idia noho.   
\c 12  
\s1 Davida ese durua totona Dirava ia noia  
\q1
\v 1 Lohiabada e, ai dekenai durua oi henia!  
\q1 Badina Dirava lalokau henia tauna,  
\q1 be ta ia noho lasi.  
\q1 Kara maoromaoro mai momokani taudia,  
\q1 be idia boio vadaeni.   
\q1
\v 2 Taunimanima ibounai be,  
\q1 idia ta ta dekenai idia hereva koikoi noho.  
\q1 Idia ese hanamoa koikoi,  
\q1 bona laloa rua dekena amo,  
\q1 sibodia ta ta dekenai idia koia noho.   
\b  
\q1
\v 3 Lohiabada e, hanamoa koikoi taudia,  
\q1 edia hereva do oi hadokoa,  
\q1 bona edia malana dekena amo,  
\q1 hekokoroku hereva idia gwauraia taudia,  
\q1 be do oi koua.   
\q1
\v 4 Badina be idia gwau,  
\q1 “Iseda hereva dekena amo do ita kwalimu.  
\q1 Iseda uduna edia hereva,  
\q1 be ita ese ita biagua noho.  
\q1 Daika ese ita ia koua diba?”   
\q1
\v 5 To Lohiabada be ia gwau,  
\q1 “Ogogami taudia be,  
\q1 haida ese idia dagedage henia noho,  
\q1 bona gau lasi taudia,  
\q1 be hisihisi dainai idia tai noho.  
\q1 Unai dainai lau be do lau toreisi,  
\q1 bona idia ura henia mauri namona gabuna,  
\q1 dekenai idia do lau atoa.”   
\b  
\q1
\v 6 Lohiabada ena gwauhamata,  
\q1 be ita abidadama henia diba.  
\q1 Iena gwauhamata be momokani,  
\q1 siliva ia momokani bamona,  
\q1 lahi dekena amo,  
\q1 idia hagoevaia nega 7 siliva hegeregerena.   
\q1
\v 7 Lohiabada e,  
\q1 oi ese ai do oi gimaia bona naria.  
\q1 Dika taudia dekena amo,  
\q1 ai do oi hamauria,   
\q1
\v 8 badina gabu ibounai dekenai,  
\q1 tau dikadia idia loaloa noho,  
\q1 bona idia ese dika rohoroho gaudia,  
\q1 idia matauraia noho.   
\c 13  
\s1 Davida ese durua totona Dirava ia noia  
\q1
\v 1 Lohiabada e, lau oi laloaboio noho,  
\q1 ia lao bona edena negai?  
\q1 Lau do oi laloaboio noho,  
\q1 ia lao bona hanaihanai, a?  
\q1 Oiemu vairana,  
\q1 be lau dekena amo do oi hunia noho,  
\q1 ia lao bona edena negai?   
\q1
\v 2 Laloa hekwarahi bada ese,  
\q1 lau ia hisihisi henia noho,  
\q1 ia lao bona edena negai?  
\q1 Egu lalona do ia hisihisi noho,  
\q1 dina ibounai, doko lasi, a?  
\q1 Lau ia hadikaia gwauraia tauna,  
\q1 be lau dekena amo do ia kwalimu noho,  
\q1 ela bona edena negai?   
\b  
\q1
\v 3 Lohiabada e, egu Dirava e,  
\q1 lau dekenai do oi laloa,  
\q1 bona egu hereva dekenai do oi haere.  
\q1 Lau dekenai goada do oi henia lou,  
\q1 mase dekena amo lau do oi hamauria.   
\q1
\v 4 Lau ia hadikaia gwauraia tauna,  
\q1 be inai bamona do ia hereva, do ia gwau,  
\q1 “Lau halusia vadaeni.”  
\q1 Unai garina, mani ia do oi koua,  
\q1 vadaeni ia ese egu moru,  
\q1 be do ia moalelaia diba lasi.   
\b  
\q1
\v 5 To lau ese oiemu lalokau momokani,  
\q1 be lau abidadama henia noho,  
\q1 bona oi ese lau do oi hamauria dainai,  
\q1 lau be lau moale noho.   
\q1
\v 6 Lau ese Lohiabada dekenai,  
\q1 ane do lau abia,  
\q1 badina be ia ese,  
\q1 iena hariharibada dekenai,  
\q1 lau ia hanamoa vadaeni.   
\c 14  
\s1 Taunimanima edia kara dika  
\q1
\v 1 Kavakava taudia ese,  
\q1 inai bamona idia laloa, idia gwau,  
\q1 “Dirava be ia noho lasi.”  
\q1 Idia ibounai be dika,  
\q1 kara mirodia idia karaia vadaeni.  
\q1 Kara namo karaia tauna be ta lasi.   
\q1
\v 2 Lohiabada be guba dekena amo,  
\q1 iena matana ia negea,  
\q1 taunimanima edia kara ia itaia.  
\q1 Ia ese aonega taudia ia tahua.  
\q1 Ia dekenai idia tomadiho taudia ia tahua.   
\q1
\v 3 To idia ibounai ese,  
\q1 kara dika idia karaia vadaeni.  
\q1 Idia ibounai be mai edia kerere.  
\q1 Idia ta lasi ese kara namona ia karaia.  
\q1 Lasi bona lasi momokani.   
\b  
\q1
\v 4 Lohiabada ese ia henanadai, ia gwau:  
\q1 “Inai kara dika taudia idia diba lasi, a?  
\q1 Aonega do idia abia diba lasi, a?  
\q1 Idia ese lauegu bese taudia idia ania noho,  
\q1 beredi idia ania bamona.  
\q1 Bona lau dekenai idia guriguri lasi,  
\q1 lasi momokani.”   
\q1
\v 5 To gari bada ese idia do ia dogoatao,  
\q1 badina Dirava be,  
\q1 ia dekenai idia kamonai henia taudia danu ia noho.   
\q1
\v 6 Kara dika taudia ese,  
\q1 manau taudia idia hahemaraia,  
\q1 to Lohiabada ese,  
\q1 unai manau taudia ia naria noho.   
\q1
\v 7 Egu noinoi be inai:  
\q1 Lau ura Israela ena hamauria dalana,  
\q1 be Siona dekena amo do ia mai!  
\q1 Lohiabada ese iena bese taudia edia mauri,  
\q1 be do ia hanamoa lou neganai,  
\q1 Israela taudia be do idia moale bada herea.   
\c 15  
\s1 Edena bamona kara be Dirava ese ia ura ita karaia?  
\q1
\v 1 Lohiabada e,  
\q1 daika be oiemu Dubu Helaga dekenai do ia noho?  
\q1 Edena tauna be Siona,  
\q1 oiemu ororo helagana dekenai,  
\q1 do ia tomadiho diba?   
\q1
\v 2 Tauna be inai:  
\q1 Ia be nega ibounai Dirava ia kamonai henia.  
\q1 Ia ese kara maoromaoro sibona ia karaia,  
\q1 bona iena kudouna dekena amo,  
\q1 hereva momokani ia gwauraia noho,  
\q1 mai laloa maoromaoro danu.   
\q1
\v 3 Ia ese iena hereva dekenai,  
\q1 haida ia hadikaia lasi,  
\q1 bona iena turana dekenai,  
\q1 hadikaia kara ta ia karaia lasi.  
\q1 Bona iena badibadinai ia noho tauna totona,  
\q1 hadikaia hereva ta ia gwauraia lasi.   
\q1
\v 4 Ia ese, Dirava ese ia negea tauna ia ura lasi,  
\q1 to ia ese,  
\q1 Dirava idia gari henia taudia ia hanamoa noho.  
\q1 Sedira ia ese do ia davaria,  
\q1 iena gwauhamata hereva do ia badinaia,  
\q1 be auka herea,  
\q1 to ia be idau lasi,  
\q1 do ia badinaia noho.   
\q1
\v 5 Ia ese iena moni ia heniatorehai lasi,  
\q1 atoa kau davana abia totona.  
\q1 Bona kerere lasi tauna hadikaia totona,  
\q1 taunimanima ese moni idia henia gwauraia neganai,  
\q1 unai tau ese unai moni ia abia dae lasi.  
\b  
\q1 Unai bamona ia karaia tauna,  
\q1 be do ia gini goada noho,  
\q1 gau ta ese ia do ia hadikaia lasi.   
\c 16  
\s1 Dirava dekenai ia abidadama henia tauna ena guriguri  
\q1
\v 1 Dirava e, lau do oi hamauria,  
\q1 badina be lau ese oi lau abidadama henia.   
\q1
\v 2 Oi Lohiabada dekenai lau hereva,  
\q1 lau gwau, “Oi be lauegu Lohiabada.  
\q1 Lau dekenai idia noho gau namodia ibounai,  
\q1 be oi dekena amo idia mai.”   
\q1
\v 3 Lohiabada ena taudia be namo bada herea!  
\q1 Lau be idia danu lau noho neganai,  
\q1 lau be moale bada.   
\q1
\v 4 Dirava idauna murinai idia heau taudia ese,  
\q1 edia hisihisi idia habadaia noho.  
\q1 Edia inuinu boubou gaudia be rara,  
\q1 bona lau ese unai bamona boubou,  
\q1 be do lau karaia lasi.  
\q1 Edia dirava dekenai lau tomadiho henia lasi,  
\q1 ma edia dirava ena ladana lau gwauraia lasi.  
\v 5 Lohiabada e,  
\q1 oi lau abia hidi vadaeni,  
\q1 lau be mai egu dirava idauna ta lasi.  
\q1 Lau dekenai hegeregere lasi gaudia ibounai,  
\q1 be lau dekenai oi henia noho.  
\q1 Ma lau dekenai do idia vara gaudia,  
\q1 be oi ese oi naria noho.   
\q1
\v 6 Oi ese gau namodia momo lau dekenai oi henia.  
\q1 Oi dekena amo egu ahuna be namo bada herea!   
\b  
\q1
\v 7 Lohiabada lau hanamoa noho,  
\q1 badina ia ese lau ia hakaua noho dainai,  
\q1 hanuaboi lalonai laloa maoro ese,  
\q1 egu dala lau dekenai ia hadibaia.   
\q1
\v 8 Nega ibounai lau diba,  
\q1 Lohiabada be lau dekenai ia noho.  
\q1 Ia be lau kahirakahira dainai,  
\q1 gau ta ese lau ia hagaria lasi.   
\q1
\v 9 Unai dainai, egu kudouna ia moale,  
\q1 bona Lohiabada lau tanikiu henia noho.  
\q1 Lauegu tauanina danu ia noho namo,   
\q1
\v 10 badina oi Lohiabada ese,  
\q1 lau oi rakatania lasi.  
\q1 Mase taudia edia gabu dekena amo,  
\q1 oi ese lau oi gimaia noho.  
\q1 Bona oi ese oiemu Helaga Tauna do oi naria,  
\q1 ia ese mase ena bodaga do ia davaria lasi.   
\b  
\q1
\v 11 Mauri dalana be,  
\q1 oi ese lau dekenai oi hedinaraia vadaeni.  
\q1 Oiemu vairana dekenai,  
\q1 lau be mai moale danu lau noho,  
\q1 bona inai moale do ia noho ela bona hanaihanai.   
\c 17  
\s1 Kerere lasi tauna ia guriguri  
\q1
\v 1 Lohiabada e,  
\q1 kota maoromaoro totona lau noinoi inai,  
\q1 mani lau dekenai do oi kamonai.  
\q1 Oiemu durua totona lau noinoi noho,  
\q1 egu taitai mani do oi kamonai,  
\q1 badina inai guriguri lau gwauraia,  
\q1 mai egu laloa maoromaoro bona momokani.   
\q1
\v 2 Oi ese egu kota dekenai,  
\q1 kwalimu lau dekenai do oi henia,  
\q1 badina oiemu laloa bona oiemu kara,  
\q1 be nega ibounai ia maoromaoro.   
\q1
\v 3 Oi ese egu kudouna oi diba.  
\q1 Oi ese hanuaboi neganai,  
\q1 lau dekenai oi vadivadi henia.  
\q1 Oi ese egu lalona oi tahua namonamo vadaeni,  
\q1 bona ura dikana ta,  
\q1 be lau dekenai oi davaria lasi.   
\q1
\v 4 Taunimanima haida ese,  
\q1 hereva dika idia gwauraia noho,  
\q1 to lau be lasi momokani.  
\q1 Lau ese oiemu oda hereva,  
\q1 be lau kamonai henia vadaeni,  
\q1 bona dagedage taudia edia kara lau karaia lasi.   
\q1
\v 5 Lau be nega ibounai,  
\q1 oiemu dala dekenai lau raka,  
\q1 bona nega ta inai dala dekena amo,  
\q1 lau raka siri lasi.   
\b  
\q1
\v 6 Dirava e,  
\q1 oi dekenai lau guriguri noho,  
\q1 badina oi ese lau dekenai oi haere noho.  
\q1 Unai dainai egu hereva mani do oi kamonai.   
\q1
\v 7 Oiemu lalokau momokani,  
\q1 mani do oi hedinaraia,  
\q1 bona ai do oi hamauria.  
\q1 Bema oi be ai dekenai oi noho,  
\q1 ai dekenai idia tuari henia taudia ese,  
\q1 ai do idia hadikaia diba lasi.   
\q1
\v 8 Lohiabada e, lau do oi gimaia,  
\q1 oiemu matana oi gimaia noho bamona.  
\q1 Oiemu hanina edia henunai lau do oi hunia.   
\q1
\v 9 Tau dikadia edia tuari,  
\q1 dekena amo lau do oi gimaia.  
\q1 Lau idia hamasea gwauraia taudia,  
\q1 ese lau idia hagegea noho.   
\q1
\v 10 Idia be mai edia bogahisihisi lasi,  
\q1 bona mai hekokoroku danu idia hereva noho.   
\q1
\v 11 Idia ese lau idia lulua vadaeni,  
\q1 bona hari lau idia hagegea noho.  
\q1 Idia ese lau idia itaia noho,  
\q1 tano dekenai lau do idia veria diho totona.   
\q1
\v 12 Idia be laiona idia hitolo bamona,  
\q1 idia naria noho,  
\q1 lau do idia darea parara totona.   
\q1
\v 13 Lohiabada e, oi mai,  
\q1 lau idia hadikaia gwauraia taudia do oi koua.  
\q1 Oi ese idia do oi halusia!  
\q1 Oiemu tuari kaia dekena amo,  
\q1 unai tau dikadia dekena amo,  
\q1 lau do oi hamauria.   
\q1
\v 14 Lohiabada e, oiemu imana dekena amo,  
\q1 unai taudia do oi koua,  
\q1 bona lau do oi hamauria.  
\q1 Badina inai taudia edia ura gaudia,  
\q1 bona edia ahuna danu,  
\q1 be inai tanobada sibona dekenai idia tahua noho.  
\q1 Oiemu kohu momo dekena amo,  
\q1 unai taudia oi hahonudia vadaeni.  
\q1 Unai dainai idia edia natudia tau be momo herea,  
\q1 bona idia mase neganai,  
\q1 edia natudia be do mai edia kohu momo danu.   
\b  
\q1
\v 15 To lau be kara maoromaoro lau karaia dainai,  
\q1 lau ese oiemu vairana do lau itaia,  
\q1 bona do lau noga neganai,  
\q1 oiemu toana do lau itaia dainai,  
\q1 do lau moale momokani.   
\c 18  
\s1 Lohiabada ese ia hamauria dainai, Davida ese tanikiu henia ane ia abia  
\q1
\v 1 Lohiabada e,  
\q1 oi be egu goada ena badina.  
\q1 Lau ese oi lau lalokau henia noho!   
\q1
\v 2 Lohiabada be egu Nadi Badana.  
\q1 Ia be egu magu, bona egu hamauria Tauna.  
\q1 Egu Dirava be egu kohoro,  
\q1 lau heau mauri gabuna.  
\q1 Ia ese lau ia gimaia noho, kesi bamona.  
\q1 Ia ese lau idia hadikaia gwauraia taudia,  
\q1 edia dala ia koua,  
\q1 vadaeni lau noho namo.   
\q1
\v 3 Lohiabada dekenai lau tai henia,  
\q1 bona lau idia tuari henia taudia dekena amo,  
\q1 Lohiabada ese lau ia hamauria noho.  
\q1 Lohiabada ita hanamoa!   
\b  
\q1
\v 4 Mase ena goada mai gari danu ese,  
\q1 lau ia hagegea noho,  
\q1 bona dika bada be,  
\q1 abata bamona lau ia hagaria bada noho.   
\q1
\v 5 Mase ena goada mai gari danu ese,  
\q1 lau ia hagegea noho,  
\q1 bona guria gabuna be,  
\q1 tarapu bamona lau ia naria hegaegae noho.   
\q1
\v 6 Egu hisihisi bona gari neganai,  
\q1 lau ese Lohiabada lau boiboi henia.  
\q1 Durua totona Lohiabada dekenai lau tai henia.  
\q1 Ia ese iena Dubu lalonai,  
\q1 egu gadona ia kamonai.  
\q1 Durua totona lau boiboi neganai,  
\q1 be Lohiabada ese ia kamonai.   
\q1
\v 7 Unai neganai tanobada be ia marere,  
\q1 ma ia heudeheude.  
\q1 Ororo edia badina nadi,  
\q1 be kahana kahana dekenai idia mareremarere,  
\q1 badina Dirava be ia badu dainai.   
\q1
\v 8 Iena udubaubauna dekena amo,  
\q1 kwalahu ia daekau lao.  
\q1 Lahi ena siahu,  
\q1 be iena uduna dekena amo ia mai,  
\q1 lahi ena hururuhururu bada herea.   
\q1
\v 9 Dirava ese guba ia darea parara,  
\q1 bona ia diho mai.  
\q1 Ori dibura herea be iena aena henunai.   
\q1
\v 10 Kerubi aneru ena latanai ia helai, ia roho lao.  
\q1 Lai ena hanina dekenai ia roho haragaharaga.   
\q1
\v 11 Dibura dekena amo sibona ia koua,  
\q1 ori korema momokani ese,  
\q1 Lohiabada ia koua hagegea.   
\q1
\v 12 Kevaru be iena vairana,  
\q1 dekena amo ia hedinarai mai.  
\q1 Medu, aisi nadi bamona,  
\q1 bona lahi hururuhururu,  
\q1 be ori korema dekena amo,  
\q1 idia mai murimurina dekenai.   
\q1
\v 13 Lohiabada ese guba boiboi dekena amo ia hereva.  
\q1 Ataiai Momokani Diravana ena gadona,  
\q1 be guba dekena amo hereva ia gwauraia.   
\q1
\v 14 Iena diba ia pidia,  
\q1 bona ia dekenai idia dagedage taudia ia luludia.  
\q1 Kevaru dekena amo ia ese idia ia pidia,  
\q1 ia halusidia momokani.   
\q1
\v 15 Lohiabada e,  
\q1 oi dekenai idia dagedage taudia,  
\q1 be oi ese oi gwau henidia neganai,  
\q1 bona oi ese mai badu danu,  
\q1 oi boiboi henidia neganai,  
\q1 davara bada ena ranu ia heau boio,  
\q1 bona ena tano be ia hedinaraia.  
\q1 Vadaeni tanobada ena dobu gabudia,  
\q1 be taunimanima ese idia itaia.   
\b  
\q1
\v 16 Lohiabada ese ataiai dekena amo,  
\q1 lau dekenai iena imana ia atoa,  
\q1 lau ia dogoatao.  
\q1 Ia ese ranu dobu dekena amo lau ia veria mauri.   
\q1
\v 17 Lau dekenai idia tuari henia taudia,  
\q1 edia goada dekena amo lau ia hamauria,  
\q1 bona lau idia dagedage henia taudia,  
\q1 idia ese egu goada idia hereaia taudia,  
\q1 dekena amo, Lohiabada ese lau ia hamauria.   
\q1
\v 18 Hisihisi lau davaria neganai,  
\q1 idia ese lau idia tuari henia,  
\q1 to Lohiabada ese lau ia durua,  
\q1 ia ese lau ia naria.   
\q1
\v 19 Dika bona gari gabuna dekena amo,  
\q1 ia ese lau ia hamauria.  
\q1 Lohiabada ese lau dekenai ia moale dainai,  
\q1 lau ia veria mauri.   
\b  
\q1
\v 20 Lohiabada ese davana namona,  
\q1 be lau dekenai ia henia noho,  
\q1 badina be lau kara maoromaoro noho.  
\q1 Lau be kerere lasi dainai,  
\q1 ia ese lau ia hanamoa noho.   
\q1
\v 21 Lohiabada ena dala ibounai,  
\q1 be lau kamonai henia vadaeni.  
\q1 Egu Dirava dekena amo lau raka siri lasi.   
\q1
\v 22 Iena taravatu ibounai,  
\q1 be lau ese lau naria vadaeni,  
\q1 bona iena oda be lau ese lau utua lasi.   
\q1
\v 23 Ia diba lau be kerere lasi,  
\q1 bona kara dika dekena amo lau raka siri vadaeni.   
\q1
\v 24 Egu kara maoromaoro hegeregerena,  
\q1 Lohiabada ese lau dekenai ahuna namona ia henia,  
\q1 badina ia diba lau be kerere lasi.   
\b  
\q1
\v 25 Lohiabada e,  
\q1 oi ese bogahisihisi tauna dekenai,  
\q1 bogahisihisi oi henia noho,  
\q1 bona kara maoromaoro tauna dekenai,  
\q1 kara maoromaoro oi henia noho.   
\q1
\v 26 Laloa goevagoeva tauna dekenai,  
\q1 oiemu laloa goevagoeva oi hedinaraia noho,  
\q1 to kara gagevagageva tauna dekenai,  
\q1 oiemu kara danu be gagevagageva.   
\q1
\v 27 Badina be manau taudia,  
\q1 hekokoroku lasi taudia,  
\q1 be oi ese oi hamauria noho,  
\q1 to hekokoroku taudia be,  
\q1 oi ese oi hamanaua noho.   
\q1
\v 28 Lohiabada e,  
\q1 oi ese lau dekenai diari oi henia noho.  
\q1 Oi ese egu dibura oi hadiaria noho.   
\q1
\v 29 Oi ese goada lau dekenai oi henia noho,  
\q1 vadaeni lau idia hadikaia gwauraia taudia,  
\q1 be lau tuari henidia noho,  
\q1 bona siahu danu lau dekenai oi henia noho,  
\q1 edia magu do lau hamakohia diba.   
\b  
\q1
\v 30 Dirava ena kara be namo herea momokani.  
\q1 Iena gwauhamata be idia momokani vadaeni.  
\q1 Ia dekenai idia abidadama henia taudia,  
\q1 be Dirava ese idia ia gimaia, kesi bamona.   
\q1
\v 31 Lohiabada sibona be Dirava,  
\q1 bona Dirava sibona be iseda Nadi Badana.   
\q1
\v 32 Dirava ese lau dekenai goada ia henia noho.  
\q1 Ia ese egu raka dalana ia hanamoa noho.   
\q1
\v 33 Lohiabada ese egu aena be,  
\q1 dia ena aena hegeregerena ia halaoa,  
\q1 vadaeni ororo dekenai lau gini goada noho.   
\q1
\v 34 Lohiabada ese egu imana ia hadibaia noho,  
\q1 vadaeni tuari dekenai lau goada,  
\q1 bona lau ese,  
\q1 auri laboralabora peva lau veria diba.   
\q1
\v 35 Lohiabada e, oi ese lau oi gimaia,  
\q1 bona lau oi hamauria noho.  
\q1 Oiemu imana dekena amo lau oi dogoatao.  
\q1 Oiemu naria kara ese,  
\q1 lauegu ladana ia habadaia vadaeni.   
\q1
\v 36 Oi ese lau oi naria dainai,  
\q1 tau dikadia ese lau idia abia mauri lasi,  
\q1 bona lau be nega ta lau moru lasi.   
\b  
\q1
\v 37 Lau dekenai idia tuari henia taudia,  
\q1 be lau lulua noho,  
\q1 bona lau ese idia lau dogoatao.  
\q1 Lau be lau heau noho, doko lasi,  
\q1 ela bona lau ese idia lau hadikaia ore.   
\q1
\v 38 Lau ese idia lau gwadaia,  
\q1 idia moru, idia toreisi lou lasi.  
\q1 Egu vairana dekenai idia hekure noho,  
\q1 idia lusi momokani.   
\q1
\v 39 Lohiabada e, do lau tuari totona,  
\q1 oi ese goada lau dekenai do oi henia noho.  
\q1 Bona kwalimu danu,  
\q1 be lau dekenai do oi henia noho,  
\q1 lau idia tuari henia taudia dekena amo.   
\q1
\v 40 Oiemu durua dainai,  
\q1 lau dekenai idia tuari taudia,  
\q1 be lau dekena amo idia heau,  
\q1 vadaeni lau idia dagedage henia taudia,  
\q1 be lau ese lau alaia ore.   
\q1
\v 41 Idia ese durua totona idia noinoi,  
\q1 to tau ta ese idia ia hamauria lasi.  
\q1 Lohiabada dekenai idia tai,  
\q1 to ia ese idia dekenai ia haere lasi.   
\q1
\v 42 Lau ese idia lau botaia patapata,  
\q1 idia be tano kahu bamona idia lao,  
\q1 vadaeni lai ese idia ia hodaia ore.  
\q1 Ariara dekenai idia noho, kopukopu bamona,  
\q1 lau ese idia do lau moia diho momokani.   
\b  
\q1
\v 43 Taunimanima momo ese,  
\q1 lau idia dagedage henia neganai,  
\q1 oi ese lau oi hamauria,  
\q1 bona bese idauidau edia gunalaia tauna,  
\q1 be oi ese lau oi halaoa.  
\q1 Lau diba lasi taudia ese,  
\q1 egu hesiai gaukara idia karaia noho.   
\q1
\v 44 Idau bese taudia ese,  
\q1 egu vairana dekenai idia tui diho noho.  
\q1 Egu hereva idia kamonai neganai,  
\q1 lau dekenai idia kamonai henia.   
\q1
\v 45 Idau bese taudia edia kudouna,  
\q1 be do idia manoka lao.  
\q1 Idia ese edia hunia gabudia dekena amo,  
\q1 mai gari bada danu do idia raka mai.   
\b  
\q1
\v 46 Lohiabada ia mauri noho!  
\q1 Egu Nadi Badana lau hanamoa noho!  
\q1 Lau ia hamauria Diravana ena ladana,  
\q1 be do ita hanamoa bada!   
\q1
\v 47 Lau dekenai idia tuari taudia dekena amo,  
\q1 Dirava ese kwalimu lau dekenai ia henia noho.  
\q1 Bese idauidau taudia be egu siahu henunai,  
\q1 Dirava ese ia atodia noho.   
\q1
\v 48 Lau dekenai idia dagedage taudia dekena amo,  
\q1 Dirava ese lau ia hamauria noho.  
\q1 Lohiabada e, momokani oi ese,  
\q1 lau idia hadikaia gwauraia taudia,  
\q1 dekena amo lau dekenai kwalimu oi henia,  
\q1 bona dagedage taudia dekena amo lau oi hamauria.   
\q1
\v 49 Inai dainai, Lohiabada e,  
\q1 bese idauidau edia huana dekenai,  
\q1 lau ese oiemu ladana do lau hanamoa.  
\q1 Ane dekena amo oiemu ladana do lau hanamoa.   
\q1
\v 50 Dirava ese kwalimu badana,  
\q1 be iena king dekenai ia henia noho.  
\q1 Ia abia hidi tauna dekenai,  
\q1 Dirava ese iena noho hanaihanai lalokauna ia henia noho.  
\q1 Inai lalokau,  
\q1 be Davida bona iena bese taudia,  
\q1 edia latanai do ia noho,  
\q1 ela bona hanaihanai.   
\c 19  
\s1 Dirava ia karaia gaudia ese iena hairaina idia hedinaraia noho  
\q1
\v 1 Guba ese Dirava ena hairaina ia hedinaraia,  
\q1 bona guba dekenai noho gaudia ese,  
\q1 Dirava ia karaia gaudia idia hedinaraia noho.   
\q1
\v 2 Dina ta ese, ia murinai dinana dekenai,  
\q1 Dirava ia herevalaia noho.  
\q1 Hanuaboi ta ese,  
\q1 ia murinai hanuaboina dekenai,  
\q1 Dirava ena aonega ma ia herevalaia.   
\q1
\v 3 Edia gado ena regena be lasi,  
\q1 bona edia hereva be ita kamonai lasi.   
\q1
\v 4 To idia gwauraia gaudia,  
\q1 be tanobada kahana ibounai dekenai idia lao vadaeni.  
\q1 Edia hereva be tanobada ena gabu ibounai,  
\q1 dekenai idia ginidae vadaeni.  
\q1 Dirava ese guba dekenai,  
\q1 dina ena noho gabuna ia karaia.   
\q1
\v 5 Daba neganai dina ia hedinarai mai,  
\q1 headava matamata tauna,  
\q1 be iena ruma dekena amo ia hedinarai bamona,  
\q1 ma heau helulu goada tauna,  
\q1 be mai moale bada danu ia heau noho bamona.   
\q1
\v 6 Guba ena dokona ta,  
\q1 dekena amo ia daekau noho,  
\q1 vadaeni ia hanaia noho,  
\q1 ela bona guba ena dokona ta.  
\q1 Gau ta be iena siahu dekena amo ia hunia diba lasi.   
\s1 Lohiabada ena Taravatu  
\q1
\v 7 Lohiabada ena Taravatu be ia namo momokani.  
\q1 Ia ese taunimanima edia lauma ia hamauria lou.  
\q1 Lohiabada ena hadibaia hereva be momokani vadaeni.  
\q1 Idia ese aonega lasi taudia dekenai,  
\q1 aonega idia henia.   
\q1
\v 8 Lohiabada ena Taravatu be idia maoromaoro vadaeni.  
\q1 Unai Taravatu idia badinaia taudia ese,  
\q1 moale idia davaria noho.  
\q1 Lohiabada ena oda be diari hegeregerena.  
\q1 Idia ese taunimanima edia laloa idia hadiaria.   
\q1
\v 9 Lohiabada dekenai idia tomadiho taudia,  
\q1 ese kara namona idia karaia noho.  
\q1 Bona inai bamona kara,  
\q1 be nega hanaihanai do ia noho.  
\q1 Lohiabada ena kota henia karana be momokani,  
\q1 bona nega ibounai,  
\q1 Lohiabada ena kota davana be maoromaoro.   
\q1
\v 10 Lohiabada ena hereva ese,  
\q1 golo ena namo idia hereaia.  
\q1 Golo namona momokani idia hereaia.  
\q1 Unai hereva edia mamina namona ese,  
\q1 hani namona ena mamina ia hereaia.  
\q1 Unai dainai do ita ura henidia,  
\q1 be gau badana momokani.   
\q1
\v 11 Lohiabada e, oiemu Taravatu ese,  
\q1 lau, oiemu hesiai tauna dekenai,  
\q1 sisiba namona idia henia.  
\q1 Lau ese idia lau badinaia neganai,  
\q1 noho mauri namona momokani lau davaria.   
\q1
\v 12 To edena tauna ese,  
\q1 sibona ena kerere karadia ia diba?  
\q1 Mani emu kara lauegu kara dika,  
\q1 hunia gaudia, do oi gwauatao.   
\q1
\v 13 Bona lau do oi durua,  
\q1 vadaeni egu hekokoroku dainai,  
\q1 kara dika do lau karaia lasi.  
\q1 Mani lau do oi naria,  
\q1 vadaeni lauegu kara dika ese,  
\q1 lau do idia biagua lasi.  
\q1 Unai neganai lau be kerere lasi,  
\q1 ma kara dika badana ta do lau karaia lasi.   
\b  
\q1
\v 14 Lohiabada e,  
\q1 oi be lauegu Nadi Gini Gabuna,  
\q1 bona egu Hamauria Tauna.  
\q1 Mani lau do oi durua,  
\q1 vadaeni lauegu uduna ena hereva,  
\q1 bona lauegu kudouna ena laloa,  
\q1 be do idia namo, oiemu vairana dekenai.   
\c 20  
\s1 King do ia kwalimu totona Davida ese Dirava ia noia  
\q1
\v 1 Oiemu nega dika bona hisihisi neganai,  
\q1 Lohiabada ese oi dekenai durua do ia henia.  
\q1 Iakobo ena Dirava ese oi do ia gimaia.   
\q1
\v 2 Iena helaga gabuna dekena amo,  
\q1 iena durua do ia siaia mai.  
\q1 Siona Ororo dekena amo,  
\q1 goada oi dekenai do ia henia.   
\q1
\v 3 Oiemu boubou gaudia ibounai do ia laloa,  
\q1 bona oiemu gabua boubou gaudia,  
\q1 be do ia abia dae.   
\q1
\v 4 Oiemu kudouna ena ura,  
\q1 be oi dekenai do ia henia,  
\q1 bona oiemu palani ibounai,  
\q1 edia anina do ia havaraia.   
\q1
\v 5 Oiemu kwalimu dainai,  
\q1 ai be mai moale bada danu do ai boiboi,  
\q1 bona Dirava ena ladana dainai,  
\q1 aiemai pepe do ai abia isi.  
\q1 Lohiabada ese oiemu noinoi ibounai,  
\q1 edia anina be oi dekenai do ia havaraia.   
\b  
\q1
\v 6 Harihari lau diba vadaeni,  
\q1 Lohiabada ese ia abia hidi tauna ia durua noho.  
\q1 Iena gabu helagana dekena amo,  
\q1 egu noinoi ia haere henia noho,  
\q1 bona iena siahu badana dekena amo,  
\q1 kwalimu badadia ia henia noho.   
\q1
\v 7 Taunimanima haida ese tuari totona,  
\q1 kariota idia abidadama henia noho,  
\q1 ma haida ese hosi idia abidadama henia noho.  
\q1 To ai ese Lohiabada,  
\q1 aiemai Dirava ai abidadama henia noho.   
\q1
\v 8 Unai taudia be do idia hekwakwanai,  
\q1 bona do idia moru diho.  
\q1 To ai be do ai toreisi,  
\q1 bona do ai gini goada.   
\b  
\q1
\v 9 Lohiabada e, king do oi hamauria!  
\q1 Oi dekenai ai boiboi neganai,  
\q1 mani ai dekenai do oi haere henia.   
\c 21  
\s1 Ia kwalimu dainai Davida ese Dirava ia hanamoa  
\q1
\v 1 Lohiabada e,  
\q1 oiemu goada dainai,  
\q1 king be ia moale bada noho.  
\q1 Kwalimu oi henia dainai ia moale bada noho.   
\q1
\v 2 Oi ese iena kudouna ena ura oi henia vadaeni.  
\q1 Iena noinoi gauna,  
\q1 be oi ese oi henia vadaeni.   
\q1
\v 3 Oi ese king oi abia dae neganai,  
\q1 hanamoa bada ia dekenai oi henia,  
\q1 bona iena kwarana dekenai korona,  
\q1 golo gauna oi atoa.   
\q1
\v 4 Ia ese oi dekenai mauri ia noia,  
\q1 bona oi ese ia dekenai oi henia.  
\q1 Iena mauri dinadia,  
\q1 be oi ese do oi halataia,  
\q1 ela bona hanaihanai.   
\q1
\v 5 Kwalimu momo ia dekenai oi henia dainai,  
\q1 taunimanima momo ese,  
\q1 king ena ladana idia hanamoa noho.  
\q1 Iena sivarai idia gwauraia loaloa noho,  
\q1 bona iena king siahuna be ia bada noho.   
\q1
\v 6 Momokani, Lohiabada e,  
\q1 oi ese king oi hanamoa bada vadaeni,  
\q1 bona inai hanamoa,  
\q1 be do idia noho ela bona hanaihanai.  
\q1 Oi be ia dekenai oi noho dainai,  
\q1 ia moale bada noho.   
\q1
\v 7 King ese Siahu Ibounai Lohiabada,  
\q1 ia abidadama henia noho.  
\q1 Bona oi Lohiabada,  
\q1 oiemu noho hanaihanai lalokauna dainai,  
\q1 king be do ia gini goada noho.   
\b  
\q1
\v 8 King ese ia dekenai idia tuari taudia ibounai,  
\q1 be do ia abia mauri.  
\q1 Ia dekenai idia dagedage noho taudia,  
\q1 be king ese do ia dogoatao.   
\q1
\v 9 King be do ia hedinarai mai neganai,  
\q1 ia ese unai taudia do ia hadikaia ore,  
\q1 lahi bada ese gau ibounai ia araia ore bamona.  
\b  
\q1 Lohiabada ese mai badu danu idia do ia alaia ore.  
\q1 Lahi ese idia do ia gabua ore.   
\q1
\v 10 Oi ese edia bese taudia,  
\q1 be tanobada dekena amo do oi kokia ore.  
\q1 Idia edia natudia ibounai,  
\q1 be king ese do ia alaia ore.   
\q1
\v 11 King idia hadikaia dalana,  
\q1 be idia tahua noho.  
\q1 Palani dikana ta idia laloa hegaegae noho.  
\q1 To idia hageregere lasi king do idia halusia,   
\q1
\v 12 badina king ese iena peva dekena amo,  
\q1 idia dekenai diba do ia pidia,  
\q1 bona idia be do idia heau boio.   
\b  
\q1
\v 13 Lohiabada e,  
\q1 oiemu goada be ai ese do ai hanamoa!  
\q1 Ai ese ane do ai abia,  
\q1 bona oiemu siahu badana do ai hanamoa momokani!   
\c 22  
\s1 Davida ese lalo hisihisi bada dainai Dirava dekenai ia taitai, unai murinai Dirava hanamoa ane ia abia  
\q1
\v 1 Egu Dirava e, egu Dirava e,  
\q1 badina dahaka lau oi rakatania vadaeni?  
\q1 Badina dahaka oiemu durua,  
\q1 be daudau herea ia noho.  
\q1 Badina dahaka egu taitai,  
\q1 be oi kamonai henia lasi.   
\q1
\v 2 Lauegu Dirava e,  
\q1 dina neganai oi dekenai lau tai,  
\q1 to lau dekenai oi kamonai lasi.  
\q1 Hanuaboi neganai danu,  
\q1 to laga-ani lau davaria lasi.   
\b  
\q1
\v 3 To oi be Helaga Dirava,  
\q1 terona dekenai oi helai.  
\q1 Oi be Israela taudia ese idia hanamoa noho.   
\q1
\v 4 Aiemai sene taudia ese,  
\q1 oi dekenai idia abidadama henia,  
\q1 Oi dekenai idia abidadama,  
\q1 vadaeni oi ese idia oi hamauria.   
\q1
\v 5 Oi dekenai idia taitai,  
\q1 vadaeni mauri idia davaria.  
\q1 Idia ese oi idia abidadama henia,  
\q1 vadaeni idia dika lasi.   
\b  
\q1
\v 6 To lau be biluga sibona,  
\q1 lau be tau lasi.  
\q1 Taunimanima ibounai ese lau idia ura lasi,  
\q1 lau idia negea vadaeni.   
\q1
\v 7 Lau idia itaia taudia ibounai ese,  
\q1 lau dekenai idia kirikiri,  
\q1 Lau dekenai idia hereva dika.  
\q1 Edia malana idia atoa murimuri dekenai,  
\q1 bona edia kwarana idia giroagiroa,   
\q1
\v 8 idia gwau,  
\q1 “Oi ese Lohiabada dekenai oi abidadama,  
\q1 badina dahaka ia ese oi ia hamauria lasi?  
\q1 Bema Lohiabada ese oi ia ura henia neganai,  
\q1 badina dahaka ia ese oi ia durua lasi?”   
\b  
\q1
\v 9 To Lohiabada e,  
\q1 oi ese lauegu sinana ena bogana,  
\q1 dekena amo lau oi abia mai,  
\q1 bona lau be egu sinana ena ratana dekenai neganai,  
\q1 oi ese lau oi naria noho.   
\q1
\v 10 Lauegu vara dinana dekena amo,  
\q1 oi dekenai lau abidadama,  
\q1 bona egu sinana ena bogana dekena amo,  
\q1 oi be lauegu Dirava.   
\q1
\v 11 Lau dekena amo do oi noho daudau lasi,  
\q1 badina nega dikana ia kahirakahira,  
\q1 bona lau be durua tauna ta lasi.   
\b  
\q1
\v 12 Lau idia hadikaia gwauraia taudia momo ese,  
\q1 lau idia hagegea noho.  
\q1 Idia be Basana tano ena boromakau tau dagedagedia bamona.   
\q1
\v 13 Idia ese edia uduna idia kehoa.  
\q1 Idia be laiona hegeregere,  
\q1 mai dagedage danu idia boiboi noho,  
\q1 bona lau idia koria noho.   
\q1
\v 14 Lauegu goada ia ore vadaeni,  
\q1 ranu be tano dekenai idia bubua kava bamona.  
\q1 Lauegu turiana ibounai be idia dika.  
\q1 Lauegu kudouna be kandolo bamona,  
\q1 egu kemena dekenai ia veve ore.   
\q1
\v 15 Lauegu goada be ia kaukau noho, kahu bamona,  
\q1 bona egu malana be egu uduna dekenai ia kamokamo.  
\q1 Mase ena kahu dekenai,  
\q1 oi ese lau oi rakatania vadaeni.   
\q1
\v 16 Kara dika taudia orea ta ese lau idia hagegea.  
\q1 Idia be sisia bamona lau idia koua noho,  
\q1 egu imana bona aena idia koria noho.   
\q1
\v 17 Egu turiana ibounai be idia hedinarai noho.  
\q1 Taunimanima ese lau idia itaia noho,  
\q1 bona lau dekenai idia kirikirilaia.   
\q1
\v 18 Lauegu dabua idia haria noho.  
\q1 Egu dabua be laki dekenai idia haria.   
\b  
\q1
\v 19 To oi, Lohiabada e,  
\q1 lau dekena amo do oi noho daudau lasi.  
\q1 Lauegu goada ena badina e,  
\q1 oi mai haraga, lau do oi durua.   
\q1
\v 20 Tuari kaia dekena amo lau do oi hamauria.  
\q1 Unai sisia edia siahu dekena amo,  
\q1 lauegu mauri do oi hamauria.   
\q1
\v 21 Unai laiona edia uduna dekena amo,  
\q1 lau do oi hamauria.  
\q1 Uda boromakau tau edia doana dekena amo,  
\q1 lau do oi veria mauri.   
\b  
\q1
\v 22 Lauegu bese taudia dekenai,  
\q1 oiemu kara do lau hadibaia.  
\q1 Oiemu ladana be,  
\q1 hebou taudia edia vairanai do lau hanamoa.   
\q1
\v 23 Lohiabada dekenai umui gari taudia e,  
\q1 ia do umui hanamoa.  
\q1 Iakobo ena natuna taudia ibounai e,  
\q1 Lohiabada do umui hanamoa.  
\q1 Israela ena bese taudia ibounai e,  
\q1 Lohiabada do umui matauraia.   
\q1
\v 24 Badina be ia ese hisihisi ia abia noho tauna,  
\q1 dekena amo ia raka siri lasi,  
\q1 to ia laloa noho,  
\q1 bona ia dekenai ia taitai neganai,  
\q1 durua ia henia noho.   
\b  
\q1
\v 25 Hebou badana lalonai,  
\q1 lau ese oi do lau hanamoa,  
\q1 oiemu kara namodia dainai.  
\q1 Oi dekenai idia gari taudia edia vairanai,  
\q1 lauegu gwauhamata ena anina do lau karaia.   
\q1
\v 26 Ogogami taudia be do idia aniani,  
\q1 edia bogana do idia kunu.  
\q1 Lohiabada idia tahua noho taudia ese,  
\q1 iena ladana do idia hanamoa.  
\q1 Namona be idia noho namonamo ela bona hanaihanai!   
\q1
\v 27 Tanobada ena bese ibounai taudia ese,  
\q1 Lohiabada do idia laloa,  
\q1 bona ia dekenai edia lalona do idia giroa.  
\q1 Bese idauidau ibounai edia iduhu ibounai ese,  
\q1 Lohiabada dekenai do idia tomadiho.   
\q1
\v 28 Badina Lohiabada be King,  
\q1 ia be bese ibounai edia Lohia.   
\q1
\v 29 Momokani tanobada ena hekokoroku taudia ibounai,  
\q1 ese Lohiabada dekenai dohore idia tomadiho.  
\q1 Bona mauri idia dogoatao diba lasi taudia ibounai,  
\q1 kahu dekenai idia lao noho taudia unai,  
\q1 ese Lohiabada ena vairanai do idia tui diho.   
\q1
\v 30 Iseda natudia bona tubudia ese,  
\q1 Lohiabada ena hesiai gaukara do idia karaia,  
\q1 bona vairai nega taunimanima dekenai,  
\q1 Lohiabada ena sivarai do idia hadibaia.   
\q1
\v 31 Do idia vara lasi taudia dekenai,  
\q1 inai bamona hereva do idia gwauraia:  
\q1 “Lohiabada ese iena bese taudia ia hamauria.”   
\c 23  
\s1 Lohiabada be iseda naria tauna, mamoe naria tauna bamona  
\q1
\v 1 Lohiabada ese lau ia naria noho,  
\q1 mamoe naria tauna ese,  
\q1 iena mamoe ia naria bamona.  
\q1 Unai dainai gau ta do lau dabu lasi.   
\q1
\v 2 Rei namona gabuna dekenai lau ia hakaua,  
\q1 unuseni lau laga-ani totona.  
\q1 Ranu namona gabuna dekenai danu,  
\q1 ia ese lau ia hakaua noho.   
\q1
\v 3 Lauegu lauma be ia ese ia hagoadaia lou.  
\q1 Kara maoromaoro daladia dekenai,  
\q1 ia ese lau ia hakaua noho,  
\q1 iena gwauhamata hegeregerena.   
\q1
\v 4 Oibe, lau be mase ena dibura koura gabuna,  
\q1 dekenai do lau raka lao,  
\q1 to dika ta dekenai do lau gari lasi,  
\q1 badina be, Lohiabada e,  
\q1 oi be lau danu oi noho.  
\q1 Oiemu mamoe hakaua itotohi,  
\q1 bona oiemu botaia auna ese,  
\q1 lau idia gimaia noho.   
\b  
\q1
\v 5 Lauegu aniani be oi ese oi abia hegaegae noho,  
\q1 lau idia dagedage henia taudia edia vairana dekenai.  
\q1 Oiemu aria dekenai lau oi abia dae,  
\q1 mai mataurai danu.  
\q1 Lauegu kapusi be oi ese oi hahonua noho.   
\q1
\v 6 Momokani, oiemu kara namo bona bogahisihisi,  
\q1 be lau dekenai do idia noho,  
\q1 egu mauri dinadia ibounai lalonai.  
\q1 Bona Lohiabada ena Ruma dekenai do lau noho,  
\q1 ela bona hanaihanai.   
\c 24  
\s1 Dirava be King Badana  
\q1
\v 1 Tanobada bona ia lalonai noho gaudia ibounai,  
\q1 be Lohiabada ena.  
\q1 Tanobada bona ia lalonai noho taunimanima,  
\q1 ibounai be Lohiabada ena.   
\q1
\v 2 Badina be ia sibona ese tanobada ia haginia,  
\q1 tano henunai ia noho ranu dobudia edia latanai.  
\q1 Ia ese tanobada ena badina,  
\q1 be davara ena dobu gabudia dekenai ia atoa.   
\b  
\q1
\v 3 Daika ese Lohiabada ena ororo,  
\q1 dekenai do ia daekau lao?  
\q1 Daika ese iena gabu helagana lalonai do ia gini?   
\q1
\v 4 Kara goevagoeva,  
\q1 bona laloa goevagoeva taudia sibona ese.  
\q1 Dirava koikoi idia tomadiho henia lasi,  
\q1 bona idia gwauhamata koikoi lasi taudia ese.   
\q1
\v 5 Lohiabada ese,  
\q1 unai bamona taudia do ia hanamoa bona hamauria,  
\q1 Lohiabada ese idia do ia gwauraia,  
\q1 idia be kerere lasi.   
\q1
\v 6 Unai bamona taudia ese Dirava idia tahua noho,  
\q1 idia ura Iakobo ena Dirava ena vairanai idia gini.   
\b  
\q1
\v 7 Ikoukou do umui kehoa namonamo,  
\q1 bona idaunegai iduara danu do umui kehoa.  
\q1 Vadaeni King Badana do ia raka vareai.   
\q1
\v 8 Inai King Badana be daika?  
\q1 Ia be Lohiabada, mai ena goada,  
\q1 bona mai ena siahu danu.  
\q1 Ia be Lohiabada,  
\q1 tuari dekenai ia kwalimu noho.   
\q1
\v 9 Ikoukou do umui kehoa namonamo,  
\q1 bona idaunegai iduara danu do umui kehoa bada,  
\q1 vadaeni King Badana be do ia raka vareai.   
\q1
\v 10 Inai King Badana be daika?  
\q1 Siahu Ibounai Lohiabada,  
\q1 ia be King Badana momokani.   
\c 25  
\s1 Davida ese Lohiabada ia noia do ia hakaua bona naria  
\q1
\v 1 Lohiabada e,  
\q1 oi dekenai egu lauma lau abia isi inai.   
\q1
\v 2 Egu Dirava e,  
\q1 oi dekenai lau abidadama henia noho.  
\q1 Lau do oi durua,  
\q1 vadaeni hemarai do lau davaria lasi.  
\q1 Lau do oi durua,  
\q1 vadaeni lau idia hadikaia gwauraia taudia ese,  
\q1 lau do idia kirikirilaia lasi!   
\q1
\v 3 Badina oi dekenai idia abidadama taudia,  
\q1 be do idia moru lasi,  
\q1 to edia abidadama idia rakatania kava taudia,  
\q1 be moru ena hemarai do idia abia.   
\b  
\q1
\v 4 Lohiabada e,  
\q1 oiemu kara lau dekenai do oi hadibaia.  
\q1 Oiemu dala lau dekenai do oi hedinaraia.   
\q1
\v 5 Oiemu hereva momokani ena dala dekenai,  
\q1 lau do oi hakaua,  
\q1 bona inai hereva momokani,  
\q1 be lau dekenai do oi hadibaia.  
\q1 Badina oi be egu Dirava,  
\q1 oi ese lau oi hamauria noho.  
\q1 Nega ibounai oi dekenai lau abidadama henia noho.   
\q1
\v 6 Lohiabada e, oiemu bogahisihisi,  
\q1 bona oiemu noho hanaihanai lalokauna,  
\q1 be do oi laloa noho,  
\q1 badina oi ese idaunegai ia mai bona hari,  
\q1 inai kara taunimanima dekenai oi karaia.   
\q1
\v 7 Lau uhau neganai kara dika lau karaia gaudia,  
\q1 bona egu kerere danu,  
\q1 be mani do oi gwauatao.  
\q1 Lohiabada e,  
\q1 oiemu noho hanaihanai lalokauna dainai,  
\q1 lau dekenai do oi laloa namo,  
\q1 badina oiemu kara be namo.   
\b  
\q1
\v 8 Lohiabada be namo bona maoromaoro.  
\q1 Unai dainai ia ese kara dika taudia dekenai,  
\q1 iena dala ia hadibaia noho.   
\q1
\v 9 Ia ese hekokoroku lasi taudia,  
\q1 be dala maoromaoro dekenai ia hakaudia noho.  
\q1 Ia ese manau taudia dekenai,  
\q1 iena dala ia hadibaia noho.   
\q1
\v 10 Iena taravatu bona iena hadibaia hereva,  
\q1 idia badinaia bona kamonai henia taudia,  
\q1 be Lohiabada ese,  
\q1 mai lalokau bona mai momokani danu,  
\q1 do ia hakaudia lao noho.   
\q1
\v 11 Lohiabada e, oiemu ladana dainai,  
\q1 egu kara dika do oi gwauatao,  
\q1 badina egu kara dika be bada.   
\q1
\v 12 Edena tau ese Lohiabada ia gari henia noho?  
\q1 Lohiabada ese unai tau dekenai,  
\q1 iena raka dala maorona do ia hadibaia.   
\q1
\v 13 Unai tau ese kohu momo do ia abia,  
\q1 bona iena natuna ese,  
\q1 tano do idia abia, edia tano.   
\q1
\v 14 Lohiabada idia gari henia taudia,  
\q1 be Lohiabada ese idia dekenai,  
\q1 iena hunia gaudia ia hadibaia noho.  
\q1 Lohiabada ese danu idia dekenai,  
\q1 iena gwauhamata taravatuna ena anina ia hadibaia noho.   
\q1
\v 15 Nega ibounai,  
\q1 Lohiabada dekenai egu matana lau negea noho,  
\q1 lau do ia durua totona,  
\q1 bona ia ese mase bona gari gaudia dekena amo,  
\q1 lau ia hamauria noho.   
\b  
\q1
\v 16 Lohiabada e,  
\q1 lau dekenai do oi laloa,  
\q1 lau dekenai do oi bogahisihisi,  
\q1 badina lau be sibona lau noho,  
\q1 bona lau manoka noho.   
\q1
\v 17 Lauegu lalohisihisi do oi hadokoa,  
\q1 bona egu hisihisi dekena amo lau do oi hamauria.   
\q1
\v 18 Egu laloa hekwarahi bona egu laloa metau do oi laloa,  
\q1 bona egu kara dika ibounai mani do oi gwauatao.   
\q1
\v 19 Do oi laloa,  
\q1 lau idia hadikaia gwauraia taudia,  
\q1 be idia momo herea,  
\q1 bona edia badu be auka herea lau dekenai.   
\q1
\v 20 Egu mauri do oi gimaia,  
\q1 bona lau do oi hamauria.  
\q1 Lau do oi durua,  
\q1 vadaeni hemarai do lau davaria lasi,  
\q1 badina egu heau mauri gabuna be oi.   
\q1
\v 21 Lohiabada e,  
\q1 egu kara momokani bona kara maoromaoro dainai,  
\q1 lau do oi gimaia,  
\q1 badina oi dekenai lau abidadama noho.   
\b  
\q1
\v 22 Dirava e, edia hisihisi ibounai dekena amo,  
\q1 oiemu bese Israela taudia do oi hamauria.   
\c 26  
\s1 Tau namona ta ena guriguri  
\q1
\v 1 Lohiabada e,  
\q1 lau do oi gwauraia kerere lasi,  
\q1 badina be lau ese kara maoromaoro lau karaia vadaeni,  
\q1 bona lau ese oi dekenai,  
\q1 lau abidadama henia momokani vadaeni.   
\q1
\v 2 Lohiabada e,  
\q1 lau do oi tahua bona tohoa,  
\q1 bona egu kara do oi itaia.  
\q1 Egu ura bona egu laloa danu do oi tahua.   
\q1
\v 3 Badina be oiemu noho hanaihanai lalokauna,  
\q1 be egu vairana dekenai lau itaia noho,  
\q1 bona oi dekenai abidadama henia kara ena dala dekenai,  
\q1 lau raka noho nega ibounai.   
\q1
\v 4 Koikoi taudia danu lau helai noho lasi,  
\q1 bona kara maoromaoro koikoi taudia danu,  
\q1 be lau haboua tamona lasi.   
\q1
\v 5 Kara dika taudia edia hereva hebou,  
\q1 be lau ura lasi momokani,  
\q1 bona kerere taudia dekena amo lau noho siri.   
\q1
\v 6 Lohiabada e,  
\q1 egu imana lau huria noho,  
\q1 egu maoromaoro bona kerere lasi do lau hedinaraia totona,  
\q1 bona oiemu boubou patana lau raka hagegea noho.   
\q1
\v 7 Unai neganai oi hanamoa totona ane lau abia,  
\q1 bona oiemu kara badadia,  
\q1 lau gwauraia hedinarai noho.   
\q1
\v 8 Lohiabada e, oi noho Ruma,  
\q1 be lau ura henia noho.  
\q1 Oiemu hairaina ia noho gabuna,  
\q1 be lau lalokau henia noho.   
\b  
\q1
\v 9 Kara dika taudia danu nega tamona,  
\q1 be egu lauma do oi hadikaia ore lasi.  
\q1 Ala-ala taudia danu be lau do oi hamasea lasi.   
\q1
\v 10 Idia be kara dika idia karaia noho nega ibounai,  
\q1 bona nega ibounai gagevagageva karadia idia karaia noho,  
\q1 moni do idia davaria totona.   
\q1
\v 11 To lau be kara maoromaoro lau karaia noho.  
\q1 Lau dekenai do oi bogahisihisi henia,  
\q1 bona lau do oi hamauria.   
\b  
\q1
\v 12 Lau gini goada noho,  
\q1 bona lau hadikaia totona gauna ta ia noho lasi.  
\q1 Lohiabada e, oiemu bese taudia,  
\q1 edia hebou badana lalonai,  
\q1 lau ese oi do lau hanamoa bada.   
\c 27  
\s1 Dirava hanamoa ena guriguri  
\q1
\v 1 Lohiabada be lauegu diari,  
\q1 ma ia ese lau ia hamauria noho.  
\q1 Daika dekenai do lau gari?  
\q1 Lohiabada ese mase gaudia ibounai dekena amo,  
\q1 lau ia gimaia noho.  
\q1 Daika garina do lau gari?.   
\q1
\v 2 Bema kara dika taudia ese lau idia heatu henia,  
\q1 lau do idia alaia gwauraia,  
\q1 unai neganai do idia hekwakwanai,  
\q1 bona do idia moru diho.   
\q1
\v 3 Sedira tuari taudia momo ese lau do idia hagegea,  
\q1 to lau be lau gari lasi.  
\q1 Bema tuari bada be lau dekenai ia kamokau neganai,  
\q1 lau ese Dirava do lau abidadama henia.   
\q1
\v 4 Gau tamona sibona Lohiabada dekena amo do lau noinoi,  
\q1 unai gau sibona do lau tahua.  
\q1 Lau ura Lohiabada ena Dubu lalonai do lau noho,  
\q1 egu mauri dinadia ibounai.  
\q1 Vadaeni Lohiabada ena namo do lau laloa,  
\q1 bona iena aonega do lau tahua.   
\q1
\v 5 Nega dika be lau dekenai ia ginidae neganai,  
\q1 Lohiabada ese lau do ia durua.  
\q1 Iena Dubu Helaga lalonai lau do ia hunia.  
\q1 Ataiai nadi badana latanai ia ese lau do ia atoa.   
\q1
\v 6 Unai dainai lau idia dagedage henia taudia,  
\q1 be do lau halusidia.  
\q1 Vadaeni Lohiabada ena Dubu Helaga lalonai,  
\q1 boubou do lau henia, mai moale danu,  
\q1 bona ane do lau abia,  
\q1 Lohiabada hanamoa anedia.   
\b  
\q1
\v 7 Lohiabada e,  
\q1 oi dekenai lau boiboi neganai,  
\q1 mani do oi kamonai!  
\q1 Lau dekenai do oi bogahisihisi,  
\q1 lau dekenai do oi haere!   
\q1
\v 8 Oi ese lau oi hamaoroa, oi gwau,  
\q1 “Lau dekenai do oi tomadiho.”  
\q1 Vadaeni lau haere, lau gwau,  
\q1 “Lohiabada e, lau mai inai,   
\q1
\v 9 oiemu vairana lau dekena amo mani oi hunia lasi.”  
\b  
\q1 Lau dekenai do oi badu lasi.  
\q1 Lau, oiemu hesiai tauna, do oi lulua lao lasi.  
\q1 Guna oi ese lau oi durua vadaeni.  
\q1 Lauegu hamauria Diravana e,  
\q1 lau do oi negea lasi,  
\q1 lau do oi rakatania lasi.   
\q1
\v 10 Badina be egu tamana bona sinana,  
\q1 ese lau idia rakatania,  
\q1 to Lohiabada ese lau do ia abia dae.   
\q1
\v 11 Lohiabada e,  
\q1 oiemu kara be lau dekenai do oi hadibaia.  
\q1 Dala maoromaoro dekenai lau do oi hakaua,  
\q1 badina lau idia dagedage henia taudia be momo.   
\q1
\v 12 Lau idia dagedage henia taudia edia siahu henunai,  
\q1 lau do oi rakatania lasi.  
\q1 Idia ese lau hagaria bona hadikaia totona,  
\q1 hereva koikoi idia gwauraia noho.   
\q1
\v 13 Lau diba momokani,  
\q1 lau ese inai mauri lalonai,  
\q1 Lohiabada ena kara namo do lau itaia.   
\b  
\q1
\v 14 Lohiabada dekenai do umui abidadama henia.  
\q1 Do umui laloa goada, daradara lasi.  
\q1 Lohiabada dekenai do umui abidadama henia.   
\c 28  
\s1 Durua totona ena guriguri  
\q1
\v 1 Lohiabada e, egu Nadi Badana,  
\q1 oi dekenai lau boiboi noho.  
\q1 Lau dekena amo oiemu taiana do oi koua lasi.  
\q1 Bema lau dekenai oi haere lasi neganai,  
\q1 lau be mase gabuna dekenai idia diho lao taudia,  
\q1 danu do ai diho lao.   
\q1
\v 2 Durua totona lau noinoi neganai,  
\q1 egu hereva do oi kamonai henia.  
\q1 Bema egu imana lau abia isi,  
\q1 oiemu Duba Helaga ia noho kahana dekenai lau duduia,  
\q1 unai neganai lau dekenai mani do oi laloa.   
\b  
\q1
\v 3 Kara dika taudia danu nega tamona,  
\q1 lau do oi panisia lasi.  
\q1 Kara kerere taudia danu,  
\q1 lau do oi hadikaia ore lasi.  
\q1 Idia ese maino hereva idia gwauraia noho,  
\q1 to edia kudoudia lalonai be badu ia noho.   
\q1
\v 4 Edia kerere ena davana do oi henidia.  
\q1 Edia kara dika hegeregerena,  
\q1 davana idia dekenai do oi henia.  
\q1 Edia dika ibounai dainai do oi matakani henidia,  
\q1 bona edia dika davana korikori do oi henia momokani.   
\q1
\v 5 Idia ese Lohiabada ena gaukara idia matauraia lasi.  
\q1 Lohiabada ena kara badadia idia laloa lasi.  
\q1 Unai dainai ia ese idia do ia veria diho momokani,  
\q1 bona do ia haginidia lou lasi.   
\b  
\q1
\v 6 Lohiabada do ita hanamoa!  
\q1 Ia ese egu noinoi durua totona ia kamonai henia vadaeni.   
\q1
\v 7 Lohiabada be egu goada bona egu kesi.  
\q1 Lau ese ia lau abidadama henia noho.  
\q1 Ia ese lau ia durua noho,  
\q1 bona egu kudouna ia hamoalea noho.  
\q1 Mai moale danu,  
\q1 ane dekena amo Lohiabada do lau hanamoa.   
\b  
\q1
\v 8 Lohiabada ese iena bese taudia ia gimaia noho.  
\q1 Ia ese ia abia hidi king ia naria,  
\q1 bona ia hamauria noho.   
\q1
\v 9 Lohiabada e,  
\q1 oiemu bese taudia do oi hamauria.  
\q1 Oiemu natuna korikori taudia do oi hanamoa.  
\q1 Mamoe naria tauna bamona,  
\q1 oi ese idia do oi naria.  
\q1 Bona nega ibounai, doko lasi,  
\q1 idia do oi naria namonamo noho.   
\c 29  
\s1 Lai dika bada lalonai Dirava ena gadona ia hereva  
\q1
\v 1 Guba ena siahu taudia e,  
\q1 Lohiabada do umui hanamoa.  
\q1 Iena hairaina bona iena siahu do umui hanamoa.   
\q1
\v 2 Lohiabada ena ladana ena hairaina do umui hanamoa.  
\q1 Helaga Bada Lohiabada ia hedinaraia neganai,  
\q1 do umui tomadiho henia.   
\b  
\q1
\v 3 Lohiabada ena gadona,  
\q1 be davara ena latanai idia kamonaia noho.  
\q1 Hairai ena Dirava ese,  
\q1 guba boiboi lalonai ia hereva noho.  
\q1 Lohiabada ena gadona be davara badana ena latanai.   
\q1
\v 4 Lohiabada ena gadona be mai ena siahu.  
\q1 Lohiabada ena gadona be King Badana ena gadona.   
\q1
\v 5 Lohiabada ena gadona ese,  
\q1 sida audia ia makohia noho.  
\q1 Lohiabada ese Lebanona ena sida audia ia makohia noho.   
\q1
\v 6 Ia ese Lebanona ena ororo ia hamarerea,  
\q1 idia be boromakau natudia bamona idia roho noho.  
\q1 Heremona Ororo danu,  
\q1 be Lohiabada ese ia hamarerea,  
\q1 ia be uda boromakau natuna tau bamona ia roho noho.   
\q1
\v 7 Lohiabada ena gadona ese kevaru,  
\q1 lahi bamona ia havaraia noho.   
\q1
\v 8 Lohiabada ena gadona ese,  
\q1 tano kaukau gabudia ia hamarerea noho.  
\q1 Kadesi ena tano kaukau ia hamarerea noho.   
\q1
\v 9 Lohiabada ena gadona ese,  
\q1 dia hahine edia mara ia havaraia noho.  
\q1 Lohiabada ena gadona ese au ena raurau ia hodaia,  
\q1 ia kokidia momokani.  
\q1 Bona iena Dubu Helaga lalonai,  
\q1 taunimanima ibounai idia boiboi,  
\q1 idia gwau, “Lohiabada ita hanamoa!”   
\q1
\v 10 Lohiabada ese ranu dobu abata badana ia biagua noho.  
\q1 Lohiabada be iena terona dekenai ia helai noho,  
\q1 bona do ia King ela bona hanaihanai.   
\q1
\v 11 Lohiabada ese iena bese taudia dekenai goada ia henia noho,  
\q1 bona ia ese iena orea taudia,  
\q1 be maino dekena amo ia hanamodia noho.   
\c 30  
\s1 Davida ese Lohiabada ia tanikiu henia  
\q1
\v 1 Lohiabada e,  
\q1 oi ese lau oi hamauria dainai lau tanikiu henia.  
\q1 Oi ese lau oi durua dainai,  
\q1 lau idia tuari henia taudia,  
\q1 ese lau idia kirikirilaia lasi.   
\q1
\v 2 Lohiabada, egu Dirava e,  
\q1 durua totona oi dekenai lau tai henia,  
\q1 bona oi ese lau oi hanamoa.   
\q1
\v 3 Oi ese guria gabuna dekena amo lau oi veria mauri.  
\q1 Lau be mase taudia edia gabu, kahirakahira lau ginidae,  
\q1 to oi ese lau oi hamauria lou.   
\b  
\q1
\v 4 Lohiabada ena vairanai umui kara maoromaoro taudia e,  
\q1 Lohiabada dekenai ane do umui abia.  
\q1 Iena ladana helagana do umui hanamoa.   
\q1
\v 5 Badina iena badu be ia ore haraga,  
\q1 to iena hanamoa be do ia noho,  
\q1 ela bona mauri ena dokona.  
\q1 Taitai be sedira hanuaboi ena hora ibounai do ia noho,  
\q1 to dabai be moale ma do ia vara lou.   
\b  
\q1
\v 6 Lauegu noho be namo neganai lau hereva, lau gwau,  
\q1 “Lau be nega ta do lau moru diba lasi.”   
\q1
\v 7 Lohiabada e, oi ese lau oi hanamoa neganai,  
\q1 lau gini goada noho,  
\q1 ororo aukana bamona.  
\q1 To oi ese,  
\q1 lau dekena amo oiemu vairana oi hunia neganai,  
\q1 lau be lau gari bada herea.   
\b  
\q1
\v 8 Lohiabada e,  
\q1 lau ese oi dekenai lau tai henia.  
\q1 Durua totona oi dekenai lau noinoi, lau gwau,   
\q1
\v 9 “Mase gabuna dekenai bema lau lao,  
\q1 egu mase ena namo be dahaka?  
\q1 Tano ena kahu ese oi Lohiabada do ia hanamoa diba, a?  
\q1 Tano ena kahu ese,  
\q1 oiemu kara namona do ia gwauraia diba, a?   
\q1
\v 10 Lohiabada e, oi kamonai,  
\q1 bona lau dekenai do oi bogahisihisi henia!  
\q1 Lohiabada e, lau do oi durua!”   
\b  
\q1
\v 11 Lohiabada e, oi ese egu lalohisihisi oi hadokoa vadaeni,  
\q1 bona mavaru mai moale danu dekenai oi halaoa vadaeni.  
\q1 Egu laloa metau oi kokia,  
\q1 bona moale bada be iena gabu dekenai oi atoa vadaeni.   
\q1
\v 12 Unai dainai egu lauma ese,  
\q1 oi do ia hanamoa noho,  
\q1 egu uduna do lau hakapua lasi.  
\q1 Badina Lohiabada e, oi be egu Dirava,  
\q1 bona lau ese oi do lau tanikiu henia noho, ela bona hanaihanai.   
\c 31  
\s1 Dirava dekenai ia abidadama henia tauna ena guriguri  
\q1
\v 1 Lohiabada e, lau ese oi lau abidadama henia noho.  
\q1 Unai dainai lau do oi durua,  
\q1 vadaeni lau idia hadikaia gwauraia taudia,  
\q1 ese lau do idia hamorua lasi.  
\q1 Lohiabada e,  
\q1 oi be kara maoromaoro Diravana.  
\q1 Unai dainai oi ese lau do oi hamauria.   
\q1
\v 2 Lohiabada e,  
\q1 lau dekenai do oi kamonai.  
\q1 Oi mai haraga, lau do oi hamauria!  
\q1 Egu Nadi Badana do oi lao momokani.  
\q1 Egu kohoro danu do oi lao,  
\q1 lau do oi hamauria totona.   
\q1
\v 3 Oi be egu Nadi Badana bona egu kohoro dainai,  
\q1 oi ese lau do oi hakaua, bona gimaia,  
\q1 oiemu gwauhamata hegeregerena.   
\q1
\v 4 Tau haida ese lau abia totona,  
\q1 tarapu idia atoa hegaegae vadaeni.  
\q1 Inai tarapu dekena amo,  
\q1 lau do oi kokia,  
\q1 badina oi be egu hunia gabu aukana.   
\q1
\v 5 Egu lauma be oiemu imana dekenai lau atoa inai.  
\q1 Lohiabada e, oi ese lau do oi hamauria,  
\q1 badina oi be kara momokani ena Dirava.   
\b  
\q1
\v 6 Dirava koikoi edia laulau idia tomadiho henia taudia,  
\q1 be oi ese oi badu henia noho,  
\q1 to lau ese oi lau abidadama henia noho.   
\q1
\v 7 Do lau moale bada,  
\q1 oiemu noho hanaihanai lalokauna dainai do lau moale,  
\q1 badina oi ese egu laloa hekwarahi oi itaia,  
\q1 bona egu lauma ena hisihisi oi diba.   
\q1
\v 8 Oi ese lau idia hadikaia gwauraia taudia,  
\q1 edia siahu henunai lau oi atoa lasi,  
\q1 bona oi ese egu ura dala oi kehoa vadaeni.   
\b  
\q1
\v 9 Lohiabada e, lau dekenai do oi bogahisihisi henia,  
\q1 badina hisihisi ese lau ia abia noho.  
\q1 Taitai ese egu matana ia hadikaia noho.  
\q1 Egu laumana bona tauanina idia dika vadaeni.   
\q1
\v 10 Lalohisihisi dainai egu goada ia ore,  
\q1 bona taitai ese egu mauri ia hakwadogia vadaeni.  
\q1 Egu hisihisi dainai lau manoka lao noho.  
\q1 Egu turiana be idia maragi lao noho.   
\q1
\v 11 Lau idia hadikaia gwauraia taudia ibounai,  
\q1 bona egu badibadinai noho taudia ese,  
\q1 lau idia ura henia lasi,  
\q1 lasi momokani.  
\q1 Egu turana ese lau dekenai idia gari henia noho.  
\q1 Idia ese ariara dekenai lau idia itaia neganai,  
\q1 lau dekena amo idia heau siri.   
\q1
\v 12 Taunimanima ibounai ese lau idia laloaboio vadaeni,  
\q1 mase tauna idia laloaboio bamona.  
\q1 Lau be uro, idia hamakohia gauna ta bamona.   
\q1
\v 13 Lau idia hadikaia gwauraia taudia momo,  
\q1 edia hereva maragi lau kamonai noho.  
\q1 Kahana ibounai dekena amo,  
\q1 idia ese lau idia hagaria gwauraia,  
\q1 vadaeni idia herevahereva noho,  
\q1 lau do idia hadikaia totona.  
\q1 Egu mauri do idia hadokoa dalana,  
\q1 be idia laloa karaia noho.   
\b  
\q1
\v 14 To Lohiabada e,  
\q1 egu abidadama be oi dekenai lau atoa noho.  
\q1 Oi be egu Dirava.   
\q1
\v 15 Nega ibounai egu mauri be oi ese oi naria noho.  
\q1 Lau idia hadikaia gwauraia taudia dekena amo,  
\q1 lau do oi hamauria.  
\q1 Lau idia dagedage henia noho taudia dekena amo,  
\q1 lau do oi hamauria.   
\q1
\v 16 Lau, oiemu hesiai tauna,  
\q1 be mai emu bogahisihisi danu do oi itaia noho.  
\q1 Oiemu noho hanaihanai lalokauna dainai,  
\q1 lau do oi hamauria.   
\q1
\v 17 Lohiabada e, lau ese oi dekenai lau boiboi noho.  
\q1 Mani emu kara lau do oi durua,  
\q1 vadaeni lau idia hadikaia gwauraia taudia ese,  
\q1 lau do idia halusia lasi.  
\q1 Mani emu kara, kara dika taudia do oi hadikaia,  
\q1 vadaeni mai regena ta lasi,  
\q1 mase taudia edia gabu dekenai do idia diho lao.   
\q1
\v 18 Koikoi taudia,  
\q1 be mani emu kara edia hereva do oi koua momokani.  
\q1 Hekokoroku taudia,  
\q1 bona edia hereva dekena amo,  
\q1 kara maoromaoro taudia idia hadikaia noho taudia,  
\q1 mani emu kara edia ududia do oi hakapua momokani.   
\q1
\v 19 Oi dekenai idia gari henia taudia,  
\q1 be oi ese hanamoa bada herea idia dekenai oi henia.  
\q1 Taunimanima ibounai be inai oiemu kara namona idia diba.  
\q1 Bona oi dekenai idia abidadama taudia,  
\q1 be oi ese oi naridia namonamo,  
\q1 inai danu taunimanima idia diba.   
\q1
\v 20 Oi ese oiemu vairana dekenai,  
\q1 mauri gabuna dekenai,  
\q1 inai abidadama taudia oi hunidia noho.  
\q1 Taunimanima edia koikoi karadia dekena amo,  
\q1 oi hunidia noho.  
\q1 Oiemu ruma namona lalonai oi hunidia noho.  
\q1 Idia badu henidia taudia dekena amo oi gimadia noho.   
\b  
\q1
\v 21 Lohiabada do lau hanamoa noho!  
\q1 Badina lau idia alaia gwauraia taudia ese lau idia hagegea,  
\q1 bona lau idia heatu henia neganai,  
\q1 ia ese mai hoa kara danu,  
\q1 iena lalokau be lau dekenai ia hedinaraia vadaeni.   
\q1
\v 22 Lau be lau gari, bona lau laloa,  
\q1 “Lohiabada ese iena vairana dekena amo lau ia lulua vadaeni.”  
\q1 To lau ese durua totona lau tai henia neganai,  
\q1 Lohiabada ese egu noinoi ia kamonai henia.   
\q1
\v 23 Lohiabada dekenai umui abidadama henia taudia ibounai e,  
\q1 Lohiabada do umui lalokau henia.  
\q1 Lohiabada ese abidadama taudia ia gimaia noho,  
\q1 to hekokoroku taudia dekenai,  
\q1 edia kerere davana ia henia noho momokani.   
\q1
\v 24 Lohiabada ena nega namona umui naria noho taudia ibounai e,  
\q1 do umui goada, do umui boga auka.   
\c 32  
\s1 Kara dika gwauraia hedinarai, vadaeni emui dika do idia gwauatao  
\q1
\v 1 Bema Dirava ese tau ta ena kara dika ia gwauatao neganai,  
\q1 unai tau be ia namo.  
\q1 Bema iena kerere be Dirava ese ia gwauatao,  
\q1 unai tau be ia moale.   
\q1
\v 2 Bema Lohiabada ese tau ta kerere totona ia samania lasi,  
\q1 bona unai tau ena lauma lalonai koikoi sisina ia noho lasi,  
\q1 unai tau be mai moale danu.   
\b  
\q1
\v 3 Bema egu kara dika lau gwauraia hedinarai lasi neganai,  
\q1 lauegu tauanina ia maragi lao,  
\q1 dina ibounai lau taitai dainai.   
\q1
\v 4 Badina be dina bona hanuaboi ibounai,  
\q1 oi Lohiabada ese lau oi matakani henia noho.  
\q1 Lauegu goada be ia ore ia lao,  
\q1 siahu neganai ranu be ia kororo lao bamona.   
\q1
\v 5 Unai neganai lauegu kara dika,  
\q1 be oi dekenai lau gwauraia hedinarai.  
\q1 Lauegu kerere lau hunia lasi.  
\q1 Lau gwau, “Lauegu kerere,  
\q1 be Lohiabada ena vairanai do lau gwauraia hedinarai,”  
\q1 vadaeni oi ese lauegu kara dika oi gwauatao.   
\b  
\q1
\v 6 Unai dainai nega dikadia neganai,  
\q1 Dirava ena taudia ese,  
\q1 oi dekenai do idia guriguri be namo.  
\q1 Vadaeni hisihisi be abata bamona do idia toreisi,  
\q1 to oi dekenai idia abidadama taudia dekenai,  
\q1 unai dika do ia ginidae lasi.   
\q1
\v 7 Oi be lauegu hunia gabuna,  
\q1 Oi ese dika dekena amo lau do oi hamauria.  
\q1 Oiemu hamauria dainai ane dekenai oi do lau hanamoa,  
\q1 badina be oi ese lau oi gimaia noho.   
\b  
\q1
\v 8 Lohiabada ia gwau,  
\q1 “Lau ese oiemu raka dalana oi dekenai do lau hadibaia.  
\q1 Lau ese oi do lau hakaua,  
\q1 bona sisiba oi dekenai do lau henia.   
\q1
\v 9 Hosi o doniki edia kara bamona do umui karaia lasi.  
\q1 Idia be mai edia diba lasi,  
\q1 to taunimanima ese edia uduna dekenai auri idia atoa,  
\q1 do idia manada totona,  
\q1 taunimanima edia ura do idia karaia lasi garina.”   
\q1
\v 10 Kara dika taudia edia hisihisi be momo,  
\q1 to Lohiabada dekenai idia abidadama taudia,  
\q1 be Dirava ena lalokau,  
\q1 ia doko lasi lalokauna ese,  
\q1 idia do ia gimaia bona naria noho.   
\b  
\q1
\v 11 Kara maoromaoro taudia e, do umui moale!  
\q1 Lohiabada ena kara dainai do umui moale!  
\q1 Lohiabada umui kamonai henia taudia e,  
\q1 mai moale bada danu do umui boiboi.   
\c 33  
\s1 Dirava hanamoa ane  
\q1
\v 1 Kara namo taudia e,  
\q1 Lohiabada ena vairanai do umui moale bada.  
\q1 Dirava idia kamonai henia taudia ese,  
\q1 ia dekenai idia hanamoa be namo.   
\q1
\v 2 Iukelele miusiki dekenai Lohiabada do umui tanikiu henia,  
\q1 bona ia do umui hanamoa, gita badana,  
\q1 varo 10 gauna dekena amo.   
\q1
\v 3 Ane matamata, Lohiabada hanamoa totona do umui abia.  
\q1 Gita do umui gadaralaia namonamo,  
\q1 miusiki namo herea do umui karaia,  
\q1 bona ane do umui abia mai goada danu.   
\q1
\v 4 Badina be Lohiabada ena hereva be maoromaoro.  
\q1 Iena gaukara ibounai danu,  
\q1 be mai edia momokani danu.   
\q1
\v 5 Lohiabada ese kara maoromaoro,  
\q1 bona kota maorona ia ura henia noho.  
\q1 Lohiabada ena bogahisihisi be tanobada kahana ibounai dekenai.   
\b  
\q1
\v 6 Lohiabada ese iena hereva dekena amo guba ia karaia.  
\q1 Dina, hua bona hisiu,  
\q1 be iena uduna ena hereva dekena amo ia karaia.   
\q1
\v 7 Lohiabada ese davara ena ranu,  
\q1 ia haboua gabu tamona dekenai,  
\q1 hegeregere tau ta ese hodu tamona,  
\q1 be ranu dekenai ia hahonua bamona.  
\q1 Lohiabada ese davara badana ia naria,  
\q1 vadaeni iena gabu korikori dekenai ia noho.   
\q1
\v 8 Tanobada taudia ibounai be Lohiabada dekenai idia gari be namo.  
\q1 Tanobada dekenai noho taudia ibounai ese,  
\q1 Lohiabada idia matauraia be namo.   
\q1
\v 9 Badina be ia hereva sibona,  
\q1 vadaeni inai tanobada ia vara.  
\q1 Ia ese ia oda,  
\q1 vadaeni gau ibounai idia hedinarai.   
\q1
\v 10 Lohiabada ese bese idauidau taudia edia palani ia koua.  
\q1 Ia ese idia karaia gwauraia gaudia ia hadokoa.   
\q1
\v 11 Lohiabada ena palani,  
\q1 be do ia gini goada hanaihanai,  
\q1 bona ia karaia gwauraia gaudia,  
\q1 be hanaihanai do idia noho.   
\b  
\q1
\v 12 Bema bese ta ena Dirava be Lohiabada neganai,  
\q1 unai bese be do ia namo.  
\q1 Lohiabada ese ia abia hidi,  
\q1 iena bese korikori do idia lao taudia be do idia moale!   
\q1
\v 13 Lohiabada ese guba dekena amo iena matana ia negea,  
\q1 taunimanima ibounai ia itaia noho.   
\q1
\v 14 Iena terona dekenai ia helai gabuna dekena amo,  
\q1 Lohiabada ese iena matana ia negea,  
\q1 tanobada taudia ibounai ia itaia noho.   
\q1
\v 15 Ia ese idia ibounai edia laloa ia havaraia,  
\q1 bona edia kara ibounai ia diba.   
\q1
\v 16 King be iena tuari taudia momo dainai ia kwalimu, a?  
\q1 Lasi.  
\q1 Tuari tauna be iena goada sibona dainai ia kwalimu, a?  
\q1 Lasi.   
\q1
\v 17 Tuari hosi ese tuari ena kwalimu do idia havaraia lasi.  
\q1 Edia goada badana ese taunimanima idia hamauria diba lasi.   
\q1
\v 18 To Lohiabada ese ia dekenai idia gari taudia ia itaia noho.  
\q1 Bona Lohiabada ena bogahisihisi idia abidadama henia taudia,  
\q1 be ia ese ia naridia noho.   
\q1
\v 19 Ia ese mase dekena amo ia hamauridia noho,  
\q1 bona hitolo bada neganai,  
\q1 Lohiabada ese idia dekenai mauri ia henia noho.   
\b  
\q1
\v 20 Ita ese Lohiabada ena durua ita naria noho.  
\q1 Ia be iseda durua Tauna bona iseda kesi.   
\q1
\v 21 Lohiabada ena ladana dainai ita moale noho.  
\q1 Iena ladana helagana dekenai ita abidadama henia.   
\q1
\v 22 Lohiabada e,  
\q1 mani emu kara oiemu bogahisihisi,  
\q1 be nega ibounai ai dekenai ia noho,  
\q1 badina ai ese oi dekenai ai naria,  
\q1 bona oi dekenai ai abidadama henia noho.   
\c 34  
\s1 Lohiabada ena kara namo dainai ita hanamoa  
\q1
\v 1 Nega ibounai Lohiabada do lau hanamoa.  
\q1 Ia do lau tanikiu henia ela bona hanaihanai.   
\q1
\v 2 Dirava ena durua lau dekenai lau laloa neganai,  
\q1 ia lau hanamoa bada.  
\q1 Hisihisi idia abia noho taudia ese,  
\q1 inai egu hereva do idia kamonai,  
\q1 vadaeni do idia moale be namo.   
\q1
\v 3 Lau danu Lohiabada do ita hanamoa.  
\q1 Iena ladana do ita hanamoa hebou!   
\b  
\q1
\v 4 Lohiabada dekenai lau guriguri,  
\q1 bona ia ese lau dekenai ia haere.  
\q1 Ia ese egu gari ibounai dekena amo,  
\q1 lau ia hamauria.   
\q1
\v 5 Hisihisi idia abia noho taudia ese,  
\q1 edia matana Lohiabada dekenai idia negea, vadaeni idia moale.  
\q1 Unai dainai edia abidadama do ia dika lasi.   
\q1
\v 6 Lau be durua tauna ta lasi neganai,  
\q1 Lohiabada dekenai lau taitai,  
\q1 vadaeni ia ese lau dekenai ia haere,  
\q1 bona egu hekwarahi ibounai dekena amo lau ia hamauria.   
\q1
\v 7 Lohiabada ena aneru ese,  
\q1 Dirava dekenai idia gari taudia ia naridia noho,  
\q1 bona dika dekena amo ia hamauridia noho.   
\b  
\q1
\v 8 Lohiabada ena kara do umui tahua namonamo,  
\q1 iena dala do umui tohoa namonamo,  
\q1 vadaeni do umui diba momokani,  
\q1 Lohiabada be namo momokani.  
\q1 Lohiabada dekenai idia abidadama taudia ese,  
\q1 moale do idia davaria.   
\q1
\v 9 Lohiabada ena taudia e,  
\q1 ia dekenai do umui gari,  
\q1 badina be ia dekenai idia gari taudia,  
\q1 be gau ta do idia dabu lasi.   
\q1
\v 10 Laiona be mai aniani lasi dainai,  
\q1 nega haida idia hitolo noho,  
\q1 to Lohiabada idia kamonai henia taudia,  
\q1 be gau namona ta idia dabu lasi.   
\b  
\q1
\v 11 Memero bona kekeni e, umui mai,  
\q1 lau dekenai do umui kamonai.  
\q1 Lohiabada dekenai do umui gari dalana do lau hadibaia.   
\q1
\v 12 Edena bamona?  
\q1 Umui ura do umui mauri noho namonamo, a?  
\q1 Umui ura danu emui mauri dinadia do idia momo, a?   
\q1
\v 13 Vadaeni umui emui malana do umui naria,  
\q1 hereva dika do umui gwauraia lasi,  
\q1 bona do umui hereva koikoi lasi.   
\q1
\v 14 Dika do umui rakatania,  
\q1 kara namo do umui karaia.  
\q1 Maino do umui tahua,  
\q1 bona maino kara do umui karaia noho.   
\b  
\q1
\v 15 Lohiabada ese kara maoromaoro taudia ia naria noho.  
\q1 Edia taitai be ia ese ia kamonai henia noho.   
\q1
\v 16 To Lohiabada ese kara dika taudia ia ura henia lasi,  
\q1 bona ia ese idia do ia alaia mase,  
\q1 vadaeni taunimanima ese idia do idia laloa lou lasi.   
\b  
\q1
\v 17 Kara maoromaoro taudia idia boiboi neganai,  
\q1 Lohiabada ese idia dekenai ia kamonai,  
\q1 bona edia hekwarahi ibounai dekena amo ia hamauridia noho.   
\q1
\v 18 Lohiabada be lalohisihisi taudia kahirakahira ia noho,  
\q1 bona ia ese edia lalona ia ore taudia ia hamauria noho.   
\b  
\q1
\v 19 Kara maoromaoro tauna ena hisihisi be momo,  
\q1 to Lohiabada ese unai tau do ia durua,  
\q1 vadaeni unai hisihisi do ia ore.   
\q1
\v 20 Lohiabada ese unai tau do ia naria namonamo,  
\q1 vadaeni iena turiana ibounai do idia namo,  
\q1 ta do idia makohia lasi.   
\b  
\q1
\v 21 Kara dika taudia be dika ese do ia aladia mase,  
\q1 bona bema tau ta ese,  
\q1 kara maoromaoro taudia ia badu henia neganai,  
\q1 unai tau be Lohiabada ese do ia kota henia.   
\q1
\v 22 Lohiabada ese iena hesiai taudia do ia hamauria.  
\q1 Lohiabada dekenai ia abidadama tauna ta be do ia mase lasi.   
\c 35  
\s1 Durua totona ena guriguri  
\q1
\v 1 Lohiabada e,  
\q1 lau dekenai idia heai noho taudia,  
\q1 be oi ese do oi heai henidia,  
\q1 bona lau dekenai idia tuari henia noho taudia,  
\q1 be do oi tuari henidia.   
\q1
\v 2 Oiemu kesi bona oiemu kemena auri dabua do oi abia,  
\q1 do oi toreisi, bona lau do oi durua.   
\q1
\v 3 Lau idia lulua noho,  
\q1 lau dekenai tuari henia totona taudia dekenai,  
\q1 be oiemu io bona oiemu ira do oi abia hegaegae.  
\q1 Lau dekenai mani do oi hereva, do oi gwau,  
\q1 “Lau ese oi do lau hamauria.”   
\b  
\q1
\v 4 Egu mauri idia hadokoa gwauraia taudia do oi halusia,  
\q1 bona idia do oi hahemaraia!  
\q1 Egu mase dalana idia tahua taudia,  
\q1 be do oi hagiroa lou,  
\q1 bona idia dekenai daradara do oi havaraia!   
\q1
\v 5 Idia do oi hadikaia,  
\q1 vadaeni idia be uiti ena momoru,  
\q1 lai ese ia hodaia ore gaudia bamona do idia lao,  
\q1 bona Lohiabada ena aneru ese,  
\q1 idia do ia lulua lao ore.   
\q1
\v 6 Edia raka dala do oi hadikaia,  
\q1 vadaeni do ia dibura momokani,  
\q1 bona mai kopukopu danu.  
\q1 Bona unai neganai Lohiabada ena aneru ese idia do ia alaia ore!   
\q1
\v 7 Badina be lau do idia abia totona,  
\q1 tarapu idia atoa, badina ta lasi,  
\q1 bona guri badana idia geia,  
\q1 lau do idia hamorua totona,  
\q1 badina ta lasi.   
\q1
\v 8 To mase ese, hoa kara bamona, do ia abidia haraga.  
\q1 Idia sibodia edia tarapu lalonai do idia moru,  
\q1 bona unai tarapu lalonai do idia mase!   
\q1
\v 9 Unai neganai Lohiabada dainai do lau moale,  
\q1 bona ia ese lau ia hamauria dainai do lau moale bada.   
\q1
\v 10 Egu kudouna ibounai dekena amo,  
\q1 lau ese Lohiabada do lau hamaoroa, do lau gwau,  
\q1 “Lohiabada e, oi hegeregerena ta ia noho lasi.  
\q1 Oi ese manoka taudia oi durua noho,  
\q1 vadaeni goada taudia ese idia hadikadia diba lasi.  
\q1 Oi ese dagedage taudia dekena amo ogogami taudia oi hamauria noho.”   
\b  
\q1
\v 11 Samania koikoi taudia idia toreisi noho,  
\q1 lau karaia lasi kerere totona,  
\q1 lau idia samania noho.   
\q1
\v 12 Lau ese idia dekenai kara namo lau karaia,  
\q1 to ena davana be lau dekenai kara dika idia karaia,  
\q1 vadaeni egu lauma be ia hisihisi noho.   
\q1
\v 13 Guna unai taudia idia gorere neganai, puse dabua lau atoa,  
\q1 egu lalohisihisi ena toana,  
\q1 bona aniani lau ania lasi.  
\q1 Ma egu kwarana lau atoa diho,  
\q1 idia totona lau guriguri.   
\q1
\v 14 Mai bogahisihisi danu lau guriguri,  
\q1 egu turana o egu tadikakana totona do lau guriguri hegeregerena.  
\q1 Mai lalohisihisi danu egu kwarana lau atoa diho,  
\q1 iena sinana totona ia taitai tauna bamona.  
\q1 Lau loaloa kahana kahana dekenai,  
\q1 lau tai noho, tai noho.   
\q1
\v 15 To lau ese hisihisi lau davaria neganai,  
\q1 idia ibounai idia moale hebou,  
\q1 bona lau do idia hadikaia totona idia haboua.  
\q1 Idau taudia, lau diba lasi taudia,  
\q1 ese lau idia hereva dika henia.  
\q1 Egu ladana hadikaia hereva idia hadokoa lasi.   
\q1
\v 16 Aena ia dika tauna idia kirikirilaia taudia edia kara bamona,  
\q1 idia ese mai badu danu,  
\q1 lau dekenai edia isena idia koria auka masemase.   
\b  
\q1
\v 17 Lohiabada e,  
\q1 edia kara do oi itaia noho sibona ela bona edena negai?  
\q1 Unai tau dikadia edia kara dika dekena amo lau do oi hamauria.  
\q1 Inai laiona dekena amo,  
\q1 lau do oi veria mauri.   
\q1
\v 18 Unai neganai hebou badana lalonai,  
\q1 oi do lau tanikiu henia.  
\q1 Taunimanima momo edia vairana dekenai oi do lau hanamoa bada.   
\q1
\v 19 Lau do oi durua,  
\q1 vadaeni lau idia hadikaia gwauraia taudia,  
\q1 unai koikoi taudia ese,  
\q1 lau do idia kirikirilaia lasi,  
\q1 bona lau idia badu henia kava taudia ese,  
\q1 egu lalohisihisi dekenai do idia hevaseha lasi.   
\q1
\v 20 Badina be maino hereva idia gwauraia lasi,  
\q1 to maino dekenai idia noho taudia namodia,  
\q1 edia latanai be koikoi herevadia idia gwauraia noho.   
\q1
\v 21 Idia ese danu lau idia samania noho,  
\q1 idia boiboi, idia gwau,  
\q1 “Ai ese oiemu kara ai itaia vadaeni.”   
\b  
\q1
\v 22 Lohiabada e, oi ese inai edia kara oi itaia vadaeni.  
\q1 Unai dainai oiemu uduna do oi hakapua lasi.  
\q1 Lohiabada e, gabu daudau dekenai do oi noho lasi!   
\q1
\v 23 Do oi noga,  
\q1 bona kota maoromaoro lau dekenai do oi henia.  
\q1 Egu Dirava, egu Lohiabada e,  
\q1 do oi toreisi, bona egu kara maoromaoro do oi gwauraia.   
\q1
\v 24 Lohiabada e,  
\q1 oi be maoromaoro momokani,  
\q1 unai dainai lau do oi gwauraia kerere lasi!  
\q1 Lau idia hadikaia gwauraia taudia do oi koua,  
\q1 vadaeni lau do idia kirikirilaia lasi.   
\q1
\v 25 Vadaeni idia be inai bamona do idia herevahereva lasi,  
\q1 do idia gwau lasi,  
\q1 “Namo bada herea, iseda ura ita abia vadaeni!  
\q1 Ita ese unai tau ita hadikaia ore vadaeni!”   
\b  
\q1
\v 26 Lohiabada e, mani emu kara,  
\q1 egu hisihisi dekenai idia moale taudia be do oi halusia momokani,  
\q1 bona unai taudia dekenai daradara do oi havaraia momokani.  
\q1 Mani emu kara,  
\q1 idia ese lau idia hereaia idia gwau taudia,  
\q1 be do oi hahemaraia, bona do oi negea momokani.   
\q1
\v 27 To lau idia gwauraia maoro,  
\q1 bona idia ura kota do lau uini taudia,  
\q1 be mani emu kara,  
\q1 mai moale bada danu do idia boiboi,  
\q1 do idia gwauraia lou, gwauraia lou,  
\q1 “Lohiabada be namo bada herea momokani,  
\q1 ia ese iena hesiai tauna ia hanamoa noho,  
\q1 mai ena moale bada danu!”   
\q1
\v 28 Unai neganai lau ese oiemu kara maoromaoro,  
\q1 be do lau gwauraia hedinarai.  
\q1 Dina ena hora ibounai lau ese oi do lau hanamoa noho.   
\c 36  
\s1 Taunimanima edia kara dika  
\q1
\v 1 Kerere ese kara dika tauna dekenai ia hereva henia noho.  
\q1 Iena kudouna lalonai dika ese,  
\q1 unai tau dekenai ia hereva henia noho.  
\q1 Unai tau ese Dirava dekenai ia gari henia lasi momokani.   
\q1
\v 2 Badina unai tau be sibona ia laloa ia be tau namona.  
\q1 Unai dainai ia laloa,  
\q1 Dirava ese iena kara dika do ia itaia lasi,  
\q1 bona ia laloa,  
\q1 Dirava ese unai dika dekenai do ia badu lasi.   
\q1
\v 3 Unai tau ena hereva be dika,  
\q1 bona mai ena koikoi bada danu.  
\q1 Ia ese aonega kara bona kara namo ia hadokoa vadaeni.   
\q1
\v 4 Iena geda dekenai ia hekure neganai,  
\q1 kara dikadia do ia karaia edia dalana ia laloa noho.  
\q1 Kara dika ena dala ia abia hidi vadaeni.  
\q1 Kara kerere dalana dekena amo,  
\q1 be nega ta ia raka siri lasi.   
\s1 Dirava ena kara namona  
\q1
\v 5 Lohiabada e,  
\q1 oiemu noho hanaihanai lalokauna,  
\q1 ia bada herea dainai, ia be guba dekenai ia daekau lao noho.  
\q1 Oiemu kara momokani ese,  
\q1 ori dekenai ia ginidae vadaeni.   
\q1
\v 6 Oiemu kara maoromaoro be ataiai momokani,  
\q1 Dirava ena ororo edia ataiai bamona,  
\q1 bona oiemu kota ena maoromaoro,  
\q1 be davara bada ena dobu bamona.  
\q1 Lohiabada e, taunimanima bona mauri gaudia danu,  
\q1 be oi ese oi naria noho.   
\q1
\v 7 Lohiabada e,  
\q1 oiemu noho hanaihanai lalokauna,  
\q1 be namo herea momokani!  
\q1 Ai ese oiemu hanina henunai ai hunia diba.   
\q1
\v 8 Oi ese aniani bada ai dekenai oi henia,  
\q1 be ai ania noho.  
\q1 Bona oi ese oiemu namo ibounai,  
\q1 sinavai ena ranu bamona ai dekenai oi henia,  
\q1 ai inua noho.   
\q1
\v 9 Badina oi be mauri ibounai ena badina,  
\q1 bona oiemu diari dainai,  
\q1 ai ese diari ai itaia noho.   
\b  
\q1
\v 10 Oiemu lalokau be oi dekenai idia manada taudia dekenai,  
\q1 do oi henia noho,  
\q1 bona kara maoromaoro taudia dekenai,  
\q1 do oi kara namo henia noho.   
\q1
\v 11 Hekokoroku taudia do oi koua,  
\q1 idia ese lau do idia heatu henia lasi.  
\q1 Kara kerere taudia do oi koua,  
\q1 idia ese lau do idia lulua lao lasi.   
\q1
\v 12 Kara dika taudia be idia moru diho momokani vadaeni.  
\q1 Unuseni idia hekure noho,  
\q1 idia toreisi diba lasi.   
\c 37  
\s1 Tau namodia bona tau dikadia dekenai dahaka do ia vara?  
\q1
\v 1 Do umui laloa hekwarahi lasi kara dika taudia dainai.  
\q1 Kara kerere taudia dainai do umui mama lasi.   
\q1
\v 2 Badina be nega daudau lasi lalonai,  
\q1 tau dikadia be do idia dika,  
\q1 rei kaukau ia dika bamona,  
\q1 bona au edia raurau idia kakoro bamona.   
\b  
\q1
\v 3 Lohiabada dekenai do oi abidadama,  
\q1 bona kara namo do oi karaia,  
\q1 vadaeni tano dekenai do oi noho namo,  
\q1 mai maino danu.   
\q1
\v 4 Oiemu moale be Lohiabada dekena amo do oi tahua,  
\q1 vadaeni ia ese,  
\q1 oi ura henia gaudia oi dekenai do ia henia.   
\b  
\q1
\v 5 Oiemu mauri be Lohiabada ena imana dekenai do oi atoa.  
\q1 Ia dekenai do oi abidadama,  
\q1 vadaeni ia ese oi do ia durua.   
\q1
\v 6 Oiemu kara namona be Lohiabada ese do ia hedinaraia,  
\q1 dina ena diari bamona.  
\q1 Ia ese oiemu kara maoromaoro,  
\q1 be taunimanima edia vairanai do ia hedinaraia,  
\q1 dina tubua bamona.   
\b  
\q1
\v 7 Lohiabada ena vairanai do oi laga-ani.  
\q1 Iena vairanai do oi helai,  
\q1 oi naria ela bona ia ese oi do ia durua.  
\q1 Edia gaukara dekena amo, kohu momo idia davaria taudia,  
\q1 be idia dainai do oi mama lasi.  
\q1 Ma palani dikadia idia karaia,  
\q1 bona unai palani ena anina idia davaria taudia,  
\q1 idia totona do oi laloa hekwarahi lasi.   
\b  
\q1
\v 8 Do oi badu lasi, do oi dagedage lasi.  
\q1 Do oi laloa hekwarahi o laloa badu lasi,  
\q1 badina unai bamona laloa ese kara dika ia havaraia noho.   
\q1
\v 9 Badina kara dika taudia be,  
\q1 dika momokani do idia davaria,  
\q1 to Lohiabada idia abidadama henia taudia ese,  
\q1 edia tano dekenai do idia noho, mai namo danu.   
\q1
\v 10 Nega daudau lasi lalonai kara dika taudia do idia ore.  
\q1 Edia gabu do umui tahua,  
\q1 to do umui davaria lasi.   
\q1
\v 11 To manau taudia ese noho gabuna tano do idia abia,  
\q1 do idia helai namonamo, mai moale bona mai maino danu.   
\b  
\q1
\v 12 Kara dika taudia ese,  
\q1 kara maoromaoro taudia hadikaia daladia idia laloa noho,  
\q1 bona idia badu henidia dainai,  
\q1 edia isena idia koria auka masemase.   
\q1
\v 13 To Lohiabada ese,  
\q1 kara dika taudia ia kirikirilaia noho,  
\q1 badina ia diba, dina do ia ginidae,  
\q1 idia be do idia lusi momokani.   
\b  
\q1
\v 14 Kara dika taudia ese edia tuari kaia idia veria,  
\q1 bona edia peva danu idia veria noho,  
\q1 ogogami taudia bona gau lasi taudia do idia pidia totona,  
\q1 bona kara maoromaoro taudia alaia mase totona.   
\q1
\v 15 To edia tuari kaia be,  
\q1 idia sibona edia kudouna dekenai do idia gwadaia,  
\q1 bona edia peva be do idia makohia.   
\b  
\q1
\v 16 Kara maoromaoro tauna be sedira ia be ogogami,  
\q1 to unai ogogami ese,  
\q1 kara dika taudia momo edia kohu bada ia hereaia noho.   
\q1
\v 17 Badina be kara dika taudia edia siahu,  
\q1 be Lohiabada ese do ia haorea,  
\q1 bona Lohiabada ese,  
\q1 kara maoromaoro taudia do ia durua momokani.   
\b  
\q1
\v 18 Lohiabada ese mai edia kerere lasi taudia ia naria noho,  
\q1 bona Dirava ese idia dekenai ia henia gau namodia,  
\q1 be do idia dogoatao ela bona hanaihanai.   
\q1
\v 19 Nega dika neganai,  
\q1 unai bamona taudia be do idia lalohisihisi lasi,  
\q1 bona hitolo bada neganai,  
\q1 idia be mai edia aniani hegeregere.   
\b  
\q1
\v 20 To kara dika taudia be do idia mase ore.  
\q1 Lohiabada dekenai idia dagedage henia taudia,  
\q1 be do idia kwalimu lasi.  
\q1 Idia be rei gabudia dekenai idia noho herahera bamona.  
\q1 Do idia boio haraga,  
\q1 kwalahu ia boio haraga bamona.   
\b  
\q1
\v 21 Kara dika taudia ese idia abiatorehai,  
\q1 to idia henia lou lasi.  
\q1 To kara maoromaoro taudia be,  
\q1 mai hariharibada danu, durua bona moni idia henia.   
\q1
\v 22 Badina be Lohiabada ese ia hanamoa taudia ese,  
\q1 tano dekenai do idia noho,  
\q1 mai noho namo danu.  
\q1 To Lohiabada ese ia hadikaia taudia,  
\q1 be dika momokani do idia davaria.   
\b  
\q1
\v 23 Tau namona ena raka dalana,  
\q1 be Lohiabada ese ia hakaua noho,  
\q1 bona unai tau ena kara ia ura henia dainai,  
\q1 Lohiabada ese do ia naria noho.   
\q1
\v 24 Unai tau be do ia moru,  
\q1 to do ia diho momokani lasi,  
\q1 badina be Lohiabada ese,  
\q1 iena imana dekena amo do ia haginia lou.   
\b  
\q1
\v 25 Gunaguna lau be mero,  
\q1 harihari lau be buruka,  
\q1 to nega ta kara maoromaoro tauna ta be Dirava ese ia rakatania, a?  
\q1 Lasi momokani, nega ta lau itaia lasi.  
\q1 Bona tau namona ena natuna be nega ta idia hitolo, a?  
\q1 O iena natuna ese aniani totona taunimanima idia noia, a?  
\q1 Lasi, nega ta lau itaia lasi.  
\q1 Lasi momokani.   
\q1
\v 26 Kara maoromaoro taudia ese,  
\q1 nega ibounai haida dekenai idia bogahisihisi,  
\q1 bona idia heniatorehai,  
\q1 bona edia natudia ese Dirava ena hanamoa idia davaria.   
\b  
\q1
\v 27 Kara dika do oi rakatania,  
\q1 kara namo do oi karaia,  
\q1 vadaeni tano dekenai do oi noho namo hanaihanai.   
\q1
\v 28 Badina be Lohiabada ese,  
\q1 kara maoromaoro ia ura henia noho.  
\q1 Iena abidadama taudia,  
\q1 be ia ese do ia rakatania lasi.  
\q1 Kara maoromaoro taudia be,  
\q1 Lohiabada ese do ia naridia namonamo ela bona hanaihanai,  
\q1 to kara dika taudia edia natudia ese,  
\q1 dika do idia davaria.   
\q1
\v 29 Kara maoromaoro taudia ese,  
\q1 Dirava ia henidia tano dekenai do idia noho ela bona hanaihanai.   
\b  
\q1
\v 30 Kara maoromaoro tauna be mai ena diba,  
\q1 bona iena hereva be mai aonega danu.  
\q1 Mai maoromaoro bona momokani danu do ia hereva.   
\q1
\v 31 Iena Dirava ena taravatu,  
\q1 be iena kudouna lalonai ia dogoatao noho,  
\q1 bona ia ese Lohiabada ena taravatu ia rakatania lasi momokani.   
\q1
\v 32 Kara dika tauna ese,  
\q1 kara maoromaoro tauna ia itaia noho,  
\q1 bona ia alaia totona dala ia tahua noho.   
\q1
\v 33 To Lohiabada ese kara namo tauna do ia rakatania lasi,  
\q1 vadaeni tau dikana ena siahu henunai do ia noho lasi.  
\q1 Bona Lohiabada ese kara maoromaoro tauna do ia durua,  
\q1 vadaeni kota dekenai idia samania neganai,  
\q1 dika do ia davaria lasi.   
\b  
\q1
\v 34 Lohiabada dekenai do oi naria,  
\q1 iena dala dekenai do oi raka.  
\q1 Unai neganai ia ese oi dekenai ia henia tano,  
\q1 be do oi dogoatao diba,  
\q1 bona Lohiabada ese tau dikadia do ia hadikaia ore neganai,  
\q1 oi ese inai kara do oi itaia.   
\b  
\q1
\v 35 Kara dika tauna ta lau itaia vadaeni,  
\q1 iena noho be namo herea.  
\q1 Ia be ia tubu badabada,  
\q1 Lebanona ena sida audia bamona.   
\q1
\v 36 To gabeai lau raka hanaia,  
\q1 unai tau be ia noho lasi.  
\q1 Lau tahua, to lau davaria lasi.   
\b  
\q1
\v 37 Mai ena kerere lasi tauna do oi laloa.  
\q1 Kara maoromaoro tauna do oi itaia noho.  
\q1 Unai bamona tauna be mai maino danu do ia noho,  
\q1 bona ia ese natuna bona tubuna do ia abia.   
\q1
\v 38 To kara dika tauna,  
\q1 be Lohiabada ese do ia hadikaia ore.  
\q1 Kara dika taudia edia natudia bona tubudia,  
\q1 ese dika do idia davaria.   
\b  
\q1
\v 39 Kara maoromaoro taudia,  
\q1 be Lohiabada ese do ia hamauria,  
\q1 vadaeni hekwarahi o nega dika neganai,  
\q1 Lohiabada dekenai idia lao diba,  
\q1 badina ia be edia mauri davaria gabuna.   
\q1
\v 40 Lohiabada ese tau namodia ia durua noho,  
\q1 bona idia ia veria mauri noho.  
\q1 Lohiabada ese tau dikadia dekena amo tau namodia ia hamauria noho,  
\q1 badina idia ese Lohiabada dekenai idia abidadama henia noho.   
\c 38  
\s1 Hisihisi ia abia noho tauna ena guriguri  
\q1
\v 1 Lohiabada e, oiemu badu dekenai,  
\q1 lau do oi matakani henia lasi.  
\q1 Oiemu badu mai siahu danu dekenai,  
\q1 lau do oi hisihisi henia lasi.   
\q1
\v 2 Badina oi ese oiemu peva ena diba,  
\q1 dekena amo lau oi haberoa vadaeni.  
\q1 Oi ese lau oi botaia,  
\q1 lau moru vadaeni.   
\q1
\v 3 Oiemu badu dainai,  
\q1 lau hisihisi bada noho.  
\q1 Egu kara dika dainai egu tauanina ibounai ia gorere noho.   
\q1
\v 4 Egu kerere bada ese,  
\q1 egu kwarana idia koua vadaeni,  
\q1 abata ese taunimanima ia koua bamona.  
\q1 Egu kerere ena metau be bada herea,  
\q1 lau huaia diba lasi.   
\b  
\q1
\v 5 Egu kara dika bona egu kavakava dainai,  
\q1 egu bero edia bonana ia daekau,  
\q1 idia bodaga dainai.   
\q1
\v 6 Egu kwarana lau atoa diho,  
\q1 bona lau moru diho noho.  
\q1 Dina ena hora ibounai lalonai lau tai noho, tai noho.   
\q1
\v 7 Egu kopina be ia siahu noho,  
\q1 bona egu tauanina be ia goada lasi.   
\q1
\v 8 Lau be lau manoka vadaeni,  
\q1 badina haida ese lau idia botaia patapata.  
\q1 Egu kudouna ia hisihisi noho,  
\q1 bona hisihisi dainai lau tai noho.   
\b  
\q1
\v 9 Lohiabada e, egu ura ibounai oi diba.  
\q1 Egu taitai, be oi dekena amo ia hunia lasi.   
\q1
\v 10 Egu kudouna be ia gaukara haragaharaga noho,  
\q1 egu goada ia ore,  
\q1 bona egu matana ena diari ese,  
\q1 lau ia rakatania vadaeni.   
\q1
\v 11 Egu toto dainai, egu turana bona egu bamona taudia,  
\q1 ese lau idia vadivadi henia lasi.  
\q1 Egu bese taudia danu be lau dekena amo idia noho siri.   
\q1
\v 12 Lau idia alaia gwauraia taudia ese,  
\q1 lau abia totona tarapu idia atoa vadaeni,  
\q1 bona lau idia hadikaia gwauraia taudia ese,  
\q1 hadikaia hereva dekena amo lau idia hagaria noho.  
\q1 Dina ibounai doko lasi, idia ese lau hadikaia totona,  
\q1 dala idia tahua noho.   
\b  
\q1
\v 13 Lau be taia kudima tauna bamona, lau kamonai diba lasi.  
\q1 Lau be hereva diba lasi tauna bamona,  
\q1 egu uduna lau kehoa diba lasi.   
\q1
\v 14 Io, lau be kamonai diba lasi tauna bamona.  
\q1 Lau be lau haere lasi,  
\q1 badina lau be hereva lau kamonai lasi tauna bamona.   
\q1
\v 15 To Lohiabada e, lau ese oi lau abidadama henia noho,  
\q1 bona oi be Lohiabada,  
\q1 lauegu Dirava dainai,  
\q1 oi ese lau do oi haere henia.   
\q1
\v 16 Mani emu kara,  
\q1 lau idia hadikaia gwauraia taudia do oi koua,  
\q1 vadaeni idia ese egu hisihisi do idia kirikirilaia lasi.  
\q1 Egu moru dekenai, mani emu kara do idia hevaseha lasi.   
\b  
\q1
\v 17 Badina lau be kahirakahira lau moru diho noho inai,  
\q1 bona egu hisihisi, be nega ibounai ena mamina lau abia noho.   
\q1
\v 18 Egu kara dika be lau gwauraia hedinarai noho inai,  
\q1 bona egu kerere dekena amo,  
\q1 egu lalona lau giroa inai.   
\q1
\v 19 Lau idia hadikaia gwauraia taudia,  
\q1 be mai edia goada danu.  
\q1 Idia momo ese lau idia badu henia noho,  
\q1 to mai badina ta lasi.   
\q1
\v 20 Lau ese idia dekenai kara namo lau karaia,  
\q1 ena davana be kara dika lau dekenai idia karaia noho.  
\q1 Idia ese lau idia badu henia noho,  
\q1 badina kara maoromaoro lau karaia noho.   
\b  
\q1
\v 21 Lohiabada e,  
\q1 lau do oi rakatania lasi.  
\q1 Egu Dirava e, lau dekena amo do oi siri lasi.   
\q1
\v 22 Lohiabada e,  
\q1 oi be egu hamauria Tauna.  
\q1 Mani do oi mai haraga,  
\q1 lau do oi durua totona.   
\c 39  
\s1 Hisihisi ia abia noho tauna ena hereva  
\q1
\v 1 Lau gwau,  
\q1 “Lau ese egu mauri dalana do lau naria namonamo,  
\q1 bona egu uduna ena hereva danu do lau naria,  
\q1 kara dika do lau karaia lasi totona.  
\q1 Bona tau dikadia be lau kahirakahira idia noho neganai,  
\q1 hereva ta do lau gwauraia lasi.”   
\q1
\v 2 Lau ese regena lasi lau noho,  
\q1 hereva ta lasi.  
\q1 Hereva namona ta danu lau gwauraia lasi.  
\q1 To egu hisihisi be ia bada lao,   
\q1
\v 3 bona egu laloa hekwarahi ia bada lao.  
\q1 Lau laloa momo noho neganai,  
\q1 egu laloa metau ia bada lao,  
\q1 ela bona egu malana dekenai lau hereva, lau gwau:   
\b  
\q1
\v 4 “Lohiabada e,  
\q1 egu mauri dinadia hida do noho?  
\q1 Edena negai do lau mase?  
\q1 Egu mauri ena dokona negana,  
\q1 be mani lau dekenai do oi hedinaraia.   
\q1
\v 5 Lohiabada e, egu mauri dinadia,  
\q1 be kwadogi herea sibona oi ese oi karadia.  
\q1 Oiemu vairana dekenai,  
\q1 egu mauri dinadia be gau ta lasi bamona.  
\q1 Momokani, taunimanima ibounai edia mauri,  
\q1 be hahodi tamona sibona bamona.   
\q1
\v 6 Taunimanima idia loaloa noho,  
\q1 dina ena laulau sibona bamona.  
\q1 Edia hekwarahi bona edia gaukara be anina lasi.  
\q1 Idia ese kohu idia haboua,  
\q1 to idia diba lasi taudia ese unai kohu do idia abia.   
\b  
\q1
\v 7 “Lohiabada e, dahaka gau namona totona do lau naria?  
\q1 Oi sibona Lohiabada e,  
\q1 oi sibona dekenai do lau naria be namo.   
\q1
\v 8 Egu kara dika ibounai dekena amo,  
\q1 lau do oi hamauria,  
\q1 bona kavakava taudia do oi koua,  
\q1 vadaeni idia ese lau do idia kirikirilaia lasi.   
\q1
\v 9 Lau be regena ta lasi do lau noho,  
\q1 egu uduna do lau kehoa lasi,  
\q1 badina be oi ese inai hisihisi oi havaraia.   
\q1
\v 10 Mani emu kara inai matakani,  
\q1 be lau dekena amo do oi kokia,  
\q1 badina oiemu dadabaia dekena amo kahirakahira lau mase.   
\q1
\v 11 Oi ese taunimanima oi gwau henidia,  
\q1 bona oi matakani henidia edia kara dika dainai.  
\q1 Unai neganai edia hairaina ia ore haraga,  
\q1 kaubebe ena hairaina ia ore haraga bamona.  
\q1 Momokani taunimanima ibounai edia mauri,  
\q1 be hahodi tamona sibona bamona.   
\b  
\q1
\v 12 “Lohiabada e,  
\q1 egu guriguri mani do oi kamonai.  
\q1 Egu taitai do oi kamonai henia.  
\q1 Egu matana ranu do oi itaia neganai lau do oi durua.  
\q1 Badina lau be oiemu vadivadi tauna,  
\q1 nega sisina sibona lau noho.  
\q1 Lau be idau tauna bamona,  
\q1 egu sene taudia ibounai hegeregerena.   
\q1
\v 13 Mani emu kara oiemu matakani,  
\q1 be lau dekena amo do oi kokia,  
\q1 vadaeni moale do lau davaria lou.  
\q1 Badina egu mase dinana,  
\q1 be nega daudau lasi lalonai do ia ginidae.”   
\c 40  
\s1 Dirava hanamoa ane  
\q1
\v 1 Lohiabada totona lau naria mai haheauka danu.  
\q1 Ia ese lau dekenai ia bogahisihisi,  
\q1 bona egu taitai ia kamonai.   
\q1
\v 2 Ia ese guri dikana dekena amo lau ia veria mauri.  
\q1 Kopukopu gabuna dekena amo lau ia abia isi.  
\q1 Lauegu aena be nadi badana latanai ia atodia.  
\q1 Lauegu raka be ia ese ia naria namonamo.   
\q1
\v 3 Lohiabada ese ane matamata lau dekenai ia hadibaia.  
\q1 Inai be Dirava hanamoa anena.  
\q1 Taunimanima momo ese inai kara do idia itaia,  
\q1 vadaeni do idia gari,  
\q1 bona Lohiabada dekenai do idia abidadama.   
\b  
\q1
\v 4 Lohiabada ia abidadama henia tauna be namo.  
\q1 Unai bamona tauna ese,  
\q1 hekokoroku taudia ia matauraia lasi,  
\q1 bona ia ese Lohiabada do ia rakatania lasi,  
\q1 dirava koikoi dekenai do ia lao totona.   
\q1
\v 5 Lohiabada e, lauegu Dirava,  
\q1 oiemu durua karadia ai dekenai be momo herea.  
\q1 Tau ta be oiemu kara bamona ia karaia diba lasi.  
\q1 Lau ese oiemu kara,  
\q1 bona oiemu laloa,  
\q1 be taunimanima dekenai lau ura gwauraia,  
\q1 to lau be hegeregere lasi momokani.  
\q1 Badina oiemu kara bona laloa be momo herea,  
\q1 duahia diba lasi.   
\b  
\q1
\v 6 Oi ese vamu alaia boubou gaudia,  
\q1 bona boromakau alaia, bona gabua ore gaudia oi ura lasi.  
\q1 Unai bamona boubou gaudia,  
\q1 kara dika kokia totona oi ura lasi.  
\q1 To oi ese taiana lau dekenai oi henia,  
\q1 vadaeni oi dekenai lau ura kamonai.   
\q1
\v 7 Vadaeni lau gwau,  
\q1 “Lohiabada e, oi itaia, lau mai inai.  
\q1 Oiemu Buka ese lau ia hadibaia dahaka do lau karaia.   
\q1
\v 8 Lauegu Dirava e,  
\q1 lau ura dikadika oiemu ura do lau karaia.  
\q1 Oiemu taravatu be lauegu kudouna lalonai ia noho.”   
\b  
\q1
\v 9 Lohiabada e,  
\q1 lau ese oiemu taudia momo edia vairanai,  
\q1 hamauria sivaraina lau gwauraia hedinarai.  
\q1 Lohiabada e, oi diba vadaeni,  
\q1 lau ese inai Sivarai Namona,  
\q1 be nega ibounai do lau gwauraia.  
\q1 Lauegu udu bibina do lau koua lasi.   
\q1
\v 10 Oi ese lau oi hamauria vadaeni,  
\q1 bona inai Sivarai be lau ese lau hunia lasi.  
\q1 Oiemu abidadama namona bona oiemu durua,  
\q1 be nega ibounai lau ese lau gwauraia hedinarai vadaeni.  
\q1 Oiemu taudia edia hebou badana lalonai,  
\q1 lau ese oiemu lalokau badana,  
\q1 bona oiemu hereva momokani lau hunia lasi.   
\b  
\q1
\v 11 Lohiabada e, oiemu bogahisihisi,  
\q1 be lau dekena amo do oi kokia lasi,  
\q1 vadaeni oiemu lalokau bona oiemu hereva momokani,  
\q1 oi ese oi badinaia noho gaudia,  
\q1 ese lau do idia naria nega ibounai.   
\s1 Davida ese Lohiabada ena durua totona ia noinoi henia  
\q1
\v 12 Dika momo herea be lau dekenai idia ginidae vadaeni,  
\q1 duahia diba lasi.  
\q1 Lauegu kara dika ese unai dika idia havaraia vadaeni.  
\q1 Unai dainai lauegu matana ese,  
\q1 gau idia itaia namonamo lasi.  
\q1 Unai dika be momo herea,  
\q1 lauegu kwarana ena huina edia momo idia hanaia.  
\q1 Lauegu kudouna ia manoka lao noho,  
\q1 bona egu goada ia ore.   
\q1
\v 13 Lohiabada e, mani emu kara lau do oi hamauria.  
\q1 Lohiabada e, lau do oi durua haraga.   
\q1
\v 14 Lauegu mauri hadokoa daladia idia tahua taudia,  
\q1 be do oi hahemaraia, bona laloa daradara do oi henidia.  
\q1 Lau idia hisihisi henia taudia,  
\q1 be mani do oi luludia lou,  
\q1 mai hemarai danu.   
\q1
\v 15 Tau haida ese lau dekenai idia hereva dika,  
\q1 mai hevaseha danu.  
\q1 Mani do oi hagaridia,  
\q1 vadaeni do idia hemarai bada.   
\q1
\v 16 To oi dekenai idia mai taudia ibounai be do oi durua,  
\q1 vadaeni idia ese oiemu moale do idia abia.  
\q1 Lau ura oiemu hamauria idia ura henia taudia ibounai ese,  
\q1 nega ibounai inai bamona do idia hereva:  
\q1 “Lohiabada be namo herea momokani!”   
\b  
\q1
\v 17 Lohiabada e, lau be lau ogogami bona manoka,  
\q1 to oi ese lau oi laloaboio lasi.  
\q1 Oi be lauegu hamauria Tauna bona lauegu Dirava.  
\q1 Lau durua totona do oi mai haraga!   
\c 41  
\s1 Gorere tauna ta ena guriguri  
\q1
\v 1 Ogogami taudia ia laloa tauna be namo.  
\q1 Lohiabada ese ia do ia durua,  
\q1 bema hisihisi ia davaria neganai.   
\q1
\v 2 Lohiabada ese unai tau do ia gimaia,  
\q1 bona iena mauri do ia naria.  
\q1 Lohiabada ese iena tano dekenai unai tau do ia hamoalea.  
\q1 Bona Lohiabada ese unai tau do ia naria,  
\q1 vadaeni ia idia hadikaia gwauraia taudia,  
\q1 edia siahu henunai do ia moru lasi.   
\q1
\v 3 Bona unai tau,  
\q1 ogogami taudia ia laloa tauna, ia gorere neganai,  
\q1 be Lohiabada ese do ia durua.  
\q1 Lohiabada ese unai tau ena gorere,  
\q1 be do ia hanamoa lou momokani.   
\q1
\v 4 Lau ese inai bamona lau gwau,  
\q1 “Lohiabada e,  
\q1 lau dekenai do oi bogahisihisi,  
\q1 bona egu gorere mani do oi hanamoa,  
\q1 badina lau ese oi dekenai lau kara dika vadaeni.”   
\b  
\q1
\v 5 Lau idia hadikaia gwauraia taudia ese,  
\q1 lau totona idia hereva badubadu, idia gwau,  
\q1 “Edena negai do ia mase,  
\q1 bona edena negai iena ladana do ita laloaboio?”   
\q1
\v 6 Lau dekenai idia vadivadi taudia ese,  
\q1 lau idia hanamoa koikoi noho,  
\q1 bona idia ese lau totona,  
\q1 sivarai dikana idia tahua noho,  
\q1 vadaeni murimurinai idia raka lao neganai,  
\q1 lau hadikaia totona, unai sivarai idia gwauraia loaloa.   
\b  
\q1
\v 7 Lau idia badu henia taudia ibounai,  
\q1 ese hereva maragi dekena amo lau idia herevalaia noho.  
\q1 Lau hadikaia dalana idia tahua noho.   
\q1
\v 8 Idia gwau, “Gorere dikana ese ia abia vadaeni.  
\q1 Iena hekure gabuna dekena amo do ia toreisi lou lasi.”   
\q1
\v 9 Egu turana lalokau danu,  
\q1 lau abidadama henia tauna,  
\q1 egu aniani ia ania noho tauna,  
\q1 ia ese danu lau ia hadikaia noho.   
\b  
\q1
\v 10 Lohiabada e, oi ese lau dekenai do oi bogahisihisi.  
\q1 Lau do oi abia isi,  
\q1 vadaeni lau ese unai taudia dekenai davana do lau henia.   
\q1
\v 11 To idia ese lau idia halusia lasi,  
\q1 unai dainai lau diba oi ese lau dekenai oi laloa namo noho.   
\q1
\v 12 Oi ese lau do oi durua,  
\q1 badina be lau ese kara maoromaoro lau karaia noho.  
\q1 Oiemu vairana dekenai,  
\q1 oi ese lau do oi haginia noho, ela bona hanaihanai.   
\b  
\q1
\v 13 Lohiabada, Israela ena Dirava be do ita hanamoa!  
\q1 Ia do ita hanamoa,  
\q1 harihari ia lao bona hanaihanai.  
\q1 Amen bona Amen!   
\c 42  
\s1 Iena gabu korikori dekena amo ia noho daudau tauna ena guriguri  
\q1
\v 1 Dirava e,  
\q1 dia ese sinavai ranu ia ura henia bada bamona,  
\q1 unai bamona lau ese oi lau ura henia noho.   
\q1
\v 2 Dirava e,  
\q1 oi be mauri ena Dirava,  
\q1 bona oi lau ura henia noho,  
\q1 ranu mase neganai, ranu lau ura henia bamona.  
\q1 Dirava e,  
\q1 edena negai oiemu vairana dekenai oi do lau tomadiho?   
\q1
\v 3 Nega ibounai taunimanima ese lau idia nanadaia,  
\q1 idia gwau, “Oiemu Dirava be edeseni ia noho?”  
\q1 Unai dainai dina bona hanuaboi lau taitai noho,  
\q1 vadaeni egu matana ena ranu,  
\q1 be egu aniani gauna nega ibounai.   
\q1
\v 4 Guna neganai,  
\q1 nega namona lau abia dinadia,  
\q1 be lau laloa lou,  
\q1 vadaeni lalohisihisi dainai egu kudouna ia makohia bamona.  
\q1 Guna be taunimanima momo danu lau raka lao,  
\q1 Dirava ena Ruma lalonai lau hakaudia vareai.  
\q1 Ai ese mai moale bada bona boiboi danu,  
\q1 Dirava hanamoa ane ai abia.  
\q1 Unai bamona ai ese Lohiabada ena aria ai karaia.   
\b  
\q1
\v 5 Dirava e,  
\q1 badina dahaka lauegu lalona ia hisihisi bada noho?  
\q1 Badina dahaka lauegu kudouna ia metau noho?  
\q1 Lau ese Dirava do lau abidadama henia,  
\q1 bona iena durua totona do lau naria noho,  
\q1 badina ia be lauegu hamauria Tauna bona egu Dirava.  
\q1 Unai dainai lau ese iena ladana do lau hanamoa lou.   
\q1
\v 6 Egu lauma be egu lalona dekenai ia metau noho.  
\q1 Unai dainai Lohiabada dekenai lau laloa noho.  
\q1 Lau be inai gabudia dekenai lau noho: Ioridane tano, Heremona tano, bona Misara Ororo dekenai.   
\q1
\v 7 Ranu ia dobu gabuna ta ese,  
\q1 ranu dobu gabuna ma ta dekenai ia boiboi noho.  
\q1 Inai be sinavai ese nadi gabuna dekenai ia heau,  
\q1 vadaeni unai sinavai ena ranu be ataiai gabu dekena amo,  
\q1 ia moru diho daudau herea,  
\q1 bona henunai nadi gabuna dekenai ia bamepa, ma ia heau,  
\q1 mai ena regena bada danu.  
\q1 Lohiabada e,  
\q1 oi ese lalohisihisi momo lau dekenai oi siaia,  
\q1 bona hurehure bona abata bamona,  
\q1 inai lalohisihisi ese lau idia koua, lau diho.   
\q1
\v 8 To dina ta ta neganai,  
\q1 Lohiabada ese iena bogahisihisi lau dekenai ia hedinaraia,  
\q1 bona hanuaboi neganai,  
\q1 lau ese ane dekena amo ia lau tanikiu henia.  
\q1 Lau ese Dirava lau hanamoa noho egu guriguri dekena amo,  
\q1 badina ia ese lau dekenai mauri ia henia noho.   
\b  
\q1
\v 9 Dirava ese goada lau dekenai ia henia noho,  
\q1 vadaeni ia dekenai lau hereva, lau gwau,  
\q1 “Badina dahaka lau oi laloaboio vadaeni?  
\q1 Badina dahaka lau idia dagedage henia taudia ese,  
\q1 lau idia hisihisi henia noho,  
\q1 bona oi ese idia oi koua lasi?”   
\q1
\v 10 Nega ibounai idia ese lau dekenai idia hereva dika,  
\q1 idia gwau,  
\q1 “Oiemu Dirava be edeseni ia noho?”  
\q1 Inai bamona hereva be hegeregere io bamona,  
\q1 lau ia gwadaia,  
\q1 bona kahirakahira lau mase.   
\b  
\q1
\v 11 Badina dahaka lauegu lalona ia hisihisi bada noho?  
\q1 Badina dahaka lauegu kudouna ia metau noho?  
\q1 Lau ese Dirava do lau abidadama henia,  
\q1 bona iena durua do lau naria,  
\q1 badina ia be lauegu hamauria Tauna bona lauegu Dirava.  
\q1 Unai dainai lau ese iena ladana do lau hanamoa lou.   
\c 43  
\s1 Iena gabu dekena amo ia noho daudau tauna ena guriguri  
\q1
\v 1 Dirava e, oi idia matauraia lasi bese taudia ese,  
\q1 lau idia hadikaia gwauraia.  
\q1 Mani emu kara lau oi durua,  
\q1 bona edia hereva dika do oi koua.  
\q1 Mani idia dekenai do oi hedinaraia,  
\q1 lau be kara maoromaoro tauna.  
\q1 Unai taudia ese hereva koikoi idia gwauraia,  
\q1 bona edia kara be maoro lasi.  
\q1 Mani oi ese edia imana dekena amo,  
\q1 lau do oi hamauria.   
\q1
\v 2 Oi sibona be lauegu Dirava.  
\q1 Oi dekenai lau lao diba,  
\q1 vadaeni oi ese tau dikadia dekena amo lau oi gimaia momokani.  
\q1 To Lohiabada e,  
\q1 badina dahaka oi ese lau oi laloaboio vadaeni?  
\q1 Badina dahaka lau dekenai idia dagedage taudia ese,  
\q1 lau idia hadikaia,  
\q1 bona lau hisihisi noho?   
\q1
\v 3 Oiemu diari bona oiemu hereva momokani,  
\q1 be mani oi siaia mai,  
\q1 idia ese dala maorona lau dekenai do idia hedinaraia.  
\q1 Vadaeni inai diari ese maoromaoro oiemu ororo helagana,  
\q1 Siona dekenai lau do idia hakaua.  
\q1 Unai be oiemu Dubu Helaga, oi noho gabuna.   
\q1
\v 4 Unai neganai Dirava ena boubou patana dekenai do lau lao,  
\q1 badina oi ese egu moale bona laloa namo oi havaraia noho.  
\q1 Oi be lauegu Dirava momokani.  
\q1 Lau ese gita dekena amo oi do lau hanamoa,  
\q1 mai ane namona dekenai danu.   
\b  
\q1
\v 5 Badina dahaka lauegu lalona ia hisihisi noho?  
\q1 Badina dahaka lauegu kudouna ia metau noho?  
\q1 Lau ese Dirava do lau abidadama henia,  
\q1 bona iena durua totona do lau naria,  
\q1 badina ia be lauegu Dirava.  
\q1 Unai dainai lau ese iena ladana do lau hanamoa lou.   
\c 44  
\s1 Tuari idia lusi dainai, Israela taudia ese durua totona Dirava idia noia  
\q1
\v 1 Dirava e,  
\q1 ai be aiemai taiana dekena amo sivarai ai kamonai.  
\q1 Aiemai tamadia ese ai idia hamaoroa vadaeni.  
\q1 Idia edia nega dekenai dahaka dahaka oi karaia,  
\q1 be ai dekenai idia gwauraia.   
\q1
\v 2 Nega gunadia dekenai oi sibona oiemu imana dekena amo,  
\q1 bese idauidau oi lulua lao ore,  
\q1 bona aiemai tamadia be edia gabu dekenai oi atodia.  
\q1 Oi ese bese idauidau oi hisihisi henidia,  
\q1 to aiemai tamadia be oi ese oi hanamoa bada.   
\q1
\v 3 Aiemai tamadia, oiemu bese ese,  
\q1 edia tuari kaia dekena amo tano idia abia lasi,  
\q1 bona sibodia edia goada dekena amo tano idia abia lasi.  
\q1 To oiemu siahu bona oiemu goada dekena amo idia abia,  
\q1 bona oiemu vairana ena diari dekena amo idia abia.  
\q1 Badina be unai diari dekena amo,  
\q1 oiemu lalokau be idia dekenai oi hedinaraia namo herea.   
\b  
\q1
\v 4 Lohiabada e,  
\q1 oi be egu King bona egu Dirava.  
\q1 Oi ese oiemu bese Iakobo dekenai kwalimu oi henia noho.   
\q1
\v 5 Oiemu durua dainai ai dekenai idia tuari henia taudia,  
\q1 be ai ese ai lulua lao.  
\q1 Oiemu ladana dainai,  
\q1 ai idia hadikaia gwauraia taudia ai moia diho.   
\q1
\v 6 Egu peva dekenai lau abidadama henia lasi.  
\q1 Egu tuari kaia danu ese lau ia hamauria diba lasi.   
\q1
\v 7 To oi ese ai idia tuari henia taudia dekena amo,  
\q1 ai oi hamauria vadaeni,  
\q1 bona ai dekenai idia badu henia taudia,  
\q1 be oi ese oi halusia vadaeni.   
\q1
\v 8 Ai ese nega ibounai oi do ai hanamoa,  
\q1 bona oi do ai tanikiu henia ela bona hanaihanai.   
\q1
\v 9 To oi ese ai oi negea vadaeni,  
\q1 ma oi ese ai oi hahemaraia vadaeni.  
\q1 Oi ese harihari aiemai tuari orea oi gunalaia lasi,  
\q1 guna oi karaia bamona.   
\q1
\v 10 Oi ese ai idia tuari henia taudia oi koua lasi,  
\q1 vadaeni idia ese ai idia lulua lao,  
\q1 bona idia ese aiemai kohu idia abia, edia ura hegeregerena.   
\q1
\v 11 Oi ese idia oi koua lasi,  
\q1 vadaeni idia ese ai idia alaia,  
\q1 mamoe idia alaia bamona.  
\q1 Oi ese bese idauidau taudia edia tano dekenai,  
\q1 ai oi lulua lao,  
\q1 bona ai be idia edia huanai ai noho.   
\q1
\v 12 Oi ese oiemu bese taudia oi hoia lao,  
\q1 davana maragi dekenai oi hoia.  
\q1 Idia be oi dekenai davana maragi gaudia bamona oi hoidia lao.   
\b  
\q1
\v 13 Aiemai badibadinai noho taudia ese,  
\q1 oiemu kara ai dekenai idia itaia,  
\q1 bona ai dekenai idia hevaseha,  
\q1 bona ai idia kirikirilaia noho.   
\q1
\v 14 Oi ese ai oi hadikaia,  
\q1 vadaeni bese idauidau edia huanai aiemai sivarai be dika.  
\q1 Idia ese edia kwaradia kahana kahana dekenai idia giroagiroa,  
\q1 ai dekenai idia ura lasi ena toana.   
\q1
\v 15 Lau be nega ibounai lau hemarai noho.  
\q1 Hemarai ese lau ia koua momokani,   
\q1
\v 16 badina be lau idia badu henia taudia,  
\q1 bona lau idia hadikaia gwauraia taudia ese,  
\q1 lau dekenai idia hereva dika,  
\q1 bona edia badu hereva lau kamonai noho.   
\q1
\v 17 Ai ese oi dekenai ai laloaboio lasi,  
\q1 bona oiemu gwauhamata taravatuna,  
\q1 be ai utua lasi,  
\q1 to inai dika ibounai be ai dekenai idia vara vadaeni.   
\q1
\v 18 Ai ese oi dekenai koikoi karana ta ai karaia lasi,  
\q1 bona ai ese oiemu oda hereva ta ai negea lasi,   
\q1
\v 19 to oi ese ai oi hadikaia,  
\q1 bona uda sisia edia gabu dekenai ai oi rakatania.  
\q1 Dibura masemase ese ai ia koua momokani.   
\b  
\q1
\v 20 Bema oi, aiemai Dirava dekenai,  
\q1 tomadiho henia kara ai rakatania,  
\q1 bona bema dirava idauna ta dekenai ai guriguri henia neganai,   
\q1
\v 21 oi ese inai kerere do oi itaia lasi, a?  
\q1 Badina be oi, Dirava, ese aiemai laloa gaudia,  
\q1 hunia gaudia ibounai oi diba noho.   
\q1
\v 22 To oiemu ladana dainai,  
\q1 nega ibounai idia ese ai idia alaia mase noho.  
\q1 Mamoe idia haboua,  
\q1 do idia alaia totona bamona,  
\q1 idia ese ai idia haboua,  
\q1 bona ai idia alaia noho.   
\b  
\q1
\v 23 Do oi noga!  
\q1 Lohiabada e, badina dahaka oi mahuta noho?  
\q1 Do oi toreisi!  
\q1 Ai do oi negea ela bona hanaihanai, a?   
\q1
\v 24 Badina dahaka ai dekena amo oi hunia noho?  
\q1 Aiemai hekwarahi bona aiemai hisihisi be,  
\q1 badina dahaka oi laloaboio?   
\q1
\v 25 Ai ese tano dekenai ai moru diho.  
\q1 Aiemai tauanidia be tano ena kahu dekenai idia diho noho.   
\q1
\v 26 Do oi toreisi,  
\q1 ai durua totona do oi mai!  
\q1 Oiemu noho hanaihanai lalokauna dainai ai do oi hamauria.   
\c 45  
\s1 King ia headava neganai ena ane  
\q1
\v 1 Hereva namo herea be egu lalona idia hahonua noho,  
\q1 badina lau ese king totona inai ane lau karaia.  
\q1 Egu malana ese ane namona ia abia noho,  
\q1 sivarai torea dekenai ia manada herea tauna ena peni,  
\q1 ese ia karaia bamona.   
\b  
\q1
\v 2 King e, oiemu hairaina ese,  
\q1 taunimanima ibounai edia hairaina ia hereaia noho.  
\q1 Oiemu hereva be hariharibada dekena amo idia honu momokani,  
\q1 badina be Dirava ese,  
\q1 oi do ia hanamoa noho ela bona hanaihanai.   
\q1
\v 3 King mai goadana e,  
\q1 oiemu tuari kaia be gaba gauna dekenai do oi kwatua.  
\q1 Oi be mai hairaina, bona mai oiemu king siahuna danu.   
\q1
\v 4 Oiemu hosi dekenai do oi guia,  
\q1 bona mai king siahuna danu do oi lao, do oi kwalimu.  
\q1 Hereva momokani bona kara maoromaoro gimaia totona,  
\q1 do oi tuari lao.  
\q1 Oiemu goada ese,  
\q1 hoa karadia mai garidia danu do ia hedinaraia.   
\q1
\v 5 Oiemu peva ena diba be mai edia matana,  
\q1 idia ese king idia hadikaia gwauraia taudia,  
\q1 edia kudouna do idia gwadaia.  
\q1 Bese idauidau taudia be oiemu aena henunai do idia moru.   
\q1
\v 6 Oiemu basileia, Dirava ese oi dekenai ia henia basileia,  
\q1 be do ia noho ela bona hanaihanai.  
\q1 Oiemu basileia taudia,  
\q1 be mai kota maoromaoro danu do oi biagua noho.   
\q1
\v 7 Kara maoromaoro oi ura henia noho,  
\q1 bona kara dika oi badu henia noho.  
\q1 Unai dainai Dirava, oiemu Dirava, ese oi ia abia hidi vadaeni,  
\q1 bona ia ese moale bada,  
\q1 be oi dekenai ia henia vadaeni.  
\q1 Inai moale ese king haida edia moale ia hereaia noho.   
\q1
\v 8 Oiemu dabua dekena amo muro bona aloe bona kasia muramura,  
\q1 edia bonana ia daekau noho.  
\q1 Oiemu ruma badana, aivori ese ia hanamoa rumana lalonai,  
\q1 miusiki taudia ese oi do idia hamoalea.   
\q1
\v 9 King haida edia natudia hahine,  
\q1 be oiemu ruma hahine edia huanai idia noho,  
\q1 bona oiemu terona ena idiba kahana dekenai,  
\q1 kwini ia gini noho.  
\q1 Kwini ena herahera be golo namo herea gaudia.   
\b  
\q1
\v 10 King ena headava matamata kekeni e, mani oi laloa,  
\q1 bona egu hereva do oi kamonai.  
\q1 Oiemu bese taudia bona oiemu tamana ena ruma do oi laloaboio,   
\q1
\v 11 vadaeni king ese oiemu hairaina do ia ura henia.  
\q1 Ia be oiemu lohia tauna dainai,  
\q1 ia dekenai do oi kamonai henia.   
\q1
\v 12 Turo taudia ese,  
\q1 oi dekenai harihari gaudia do idia mailaia,  
\q1 bona kohu momo taudia ese,  
\q1 oiemu laloa namo totona, oi dekenai do idia noinoi.   
\q1
\v 13 King ena kekeni be mai hairaina,  
\q1 iena daiutu lalonai ia noho.  
\q1 Iena dabua be golo varo dekena amo idia hatua karaia.   
\q1
\v 14 King ena kekeni ese,  
\q1 dabua namo herea ia karaia noho,  
\q1 be king ena vairana dekenai idia hakaua vareai.  
\q1 Iena durua kekeni taudia danu,  
\q1 be iena murinai idia raka noho,  
\q1 king ena vairanai.   
\q1
\v 15 Mai moale bada danu idia ese,  
\q1 king ena ruma dekenai idia raka vareai noho.   
\b  
\q1
\v 16 Egu king e,  
\q1 oi ese natuna tau momo do oi abia.  
\q1 Idia ese oiemu tamana bona tubuna edia king dagi,  
\q1 be do idia abia,  
\q1 bona tanobada kahana ibounai dekenai,  
\q1 king taudia do oi halaodia.   
\q1
\v 17 Egu ane ese oiemu ladana do ia habadaia momokani,  
\q1 ela bona nega ibounai,  
\q1 bona taunimanima ibounai ese,  
\q1 oi do idia hanamoa ela bona hanaihanai.   
\c 46  
\s1 Dirava be ita dekenai ia noho  
\q1
\v 1 Dirava be iseda heau mauri gabuna,  
\q1 bona ia ese ita dekenai goada ia henia.  
\q1 Iseda nega dika negadia ibounai ita dekenai ia noho,  
\q1 ita do ia durua totona.   
\q1
\v 2 Unai dainai ita be do ita gari lasi, dika ia vara neganai.  
\q1 Tano be sedira do ia mareremarere bada,  
\q1 bona ororo be do idia kokia,  
\q1 davara lalonai do idia moru,  
\q1 to ita be do ita gari lasi.   
\q1
\v 3 Sedira davara ranu be do ia hurehure bada,  
\q1 bona regena bada do ia karaia.  
\q1 Bona unai davara ena hurehure dainai, ororo do idia heudeheude,  
\q1 to ita be do ita gari lasi.   
\q1
\v 4 Dirava ena hanua be Siahu Ibounai Dirava ena gabu helagana.  
\q1 Sinavai badana ta be unai hanua ena huanai ia heau noho.  
\q1 Bona unuseni idia noho taudia ese,  
\q1 unai sinavai idia moalelaia.   
\q1
\v 5 Dirava be unai hanua lalonai ia noho,  
\q1 unai dainai unai hanua be idia makohia diba lasi.  
\q1 Dirava ese daba maragi neganai unai hanua do ia durua.   
\q1
\v 6 Tanobada ena bese taudia idauidau,  
\q1 be idia heai noho bona heatu noho.  
\q1 Bese ta ta edia king bona edia taunimanima idia moru.  
\q1 Dirava be iena guba boiboi dekena amo iena gadona ia abia isi,  
\q1 vadaeni tano be ia veve,  
\q1 ranu bamona ia lao.   
\q1
\v 7 Siahu Ibounai Lohiabada be ita dekenai ia noho.  
\q1 Iakobo ena Dirava be iseda heau mauri gabuna.   
\b  
\q1
\v 8 Umui mai!  
\q1 Lohiabada ena gaukara do umui itaia.  
\q1 Tanobada dekenai hadikaia karadia momo ia karaia vadaeni.   
\q1
\v 9 Tuari be Dirava ese ia hadokoa noho,  
\q1 tanobada kahana ibounai dekenai.  
\q1 Ia ese peva ia makohia noho,  
\q1 bona io be ia ese ia hakwaidua noho.  
\q1 Kariota be ia ese lahi dekenai ia gabua noho.   
\q1
\v 10 Lohiabada be inai bamona ia hereva, ia gwau,  
\q1 “Tuari do umui hadokoa,  
\q1 bona do umui diba momokani lau be Dirava.  
\q1 Bese idauidau ibounai ese lau do idia hanamoa.  
\q1 Tanobada taudia ibounai ese,  
\q1 lau do idia gwauraia King Badana momokani.”   
\b  
\q1
\v 11 Siahu Ibounai Dirava be ita dekenai ia noho.  
\q1 Iakobo ena Dirava be iseda heau mauri gabuna.   
\c 47  
\s1 Dirava be tanobada taudia ibounai edia King Badana  
\q1
\v 1 Bese idauidau taudia ibounai e,  
\q1 mai hanamoa danu emui imana do umui patapataia.  
\q1 Dirava do umui hanamoa,  
\q1 mai ane bona boiboi danu.   
\q1
\v 2 Badina Lohiabada be Siahu Ibounai Dirava,  
\q1 ia be mai garina.  
\q1 Ia be King Badana momokani.  
\q1 Tanobada taudia ibounai,  
\q1 be ia ese ia biagua noho.   
\q1
\v 3 Ia ese ita dekenai kwalimu ia henia,  
\q1 bona bese idauidau be iseda aena henunai ia atodia.  
\q1 Orea idauidau be Lohiabada ese ia hamanadaia,  
\q1 ita henunai ia atodia.   
\q1
\v 4 Dirava ese tano ta ia abia hidi,  
\q1 bona ita dekenai ia henia.  
\q1 Ita be Iakobo ena tubuna,  
\q1 Dirava ese ita ia lalokau henia.  
\q1 Inai tano be iseda tano dainai,  
\q1 iniseni do ita noho, mai moale danu.   
\b  
\q1
\v 5 Dirava be guba dekenai ia daekau lao.  
\q1 Lohiabada ia daekau neganai,  
\q1 taunimanima be mai moale bada danu idia boiboi,  
\q1 bona kibi idia hiriria.   
\q1
\v 6 Dirava do umui hanamoa,  
\q1 ane do umui abia, ia dekenai hanamoa totona.  
\q1 Iseda King Badana do umui hanamoa ane dekenai,   
\q1
\v 7 badina Dirava be tanobada ibounai edia King.  
\q1 Ane dekenai do ita hanamoa!   
\q1
\v 8 Dirava be iena terona helagana dekenai ia helai noho.  
\q1 Ia ese tanobada bese ibounai ia biagua noho.   
\q1
\v 9 Bese idauidau edia lohia taudia idia haboua noho.  
\q1 Idia ese Aberahamo ena Dirava ena bese taudia danu,  
\q1 do idia haboua tamona lao,  
\q1 badina be tanobada taudia edia king ibounai,  
\q1 be Dirava ena henunai idia noho.  
\q1 Ia ese king ibounai bona taunimanima ibounai ia biagua noho.   
\c 48  
\s1 Siona, Dirava ena hanua  
\q1
\v 1 Lohiabada be ia bada,  
\q1 bona taunimanima ese ia do idia hanamoa bada be namo,  
\q1 iseda Dirava ena hanua,  
\q1 iena ororo helagana dekenai.   
\q1
\v 2 Siona, Dirava ena Ororo,  
\q1 be ataiai bona mai ena hairaina danu.  
\q1 King Badana ena hanua ese,  
\q1 tanobada taunimanima ibounai ia hamoalea noho.   
\q1
\v 3 Dirava ese ia hedinaraia vadaeni,  
\q1 ia dekenai noho taudia be do idia mauri,  
\q1 Siona hanua ena kohoro lalonai.   
\b  
\q1
\v 4 King taudia haida idia haboua,  
\q1 bona Siona Ororo tuari henia totona idia mai.   
\q1
\v 5 To idia ese Siona idia itaia neganai idia hoa bada,  
\q1 idia gari bada,  
\q1 bona idia heau boio.   
\q1
\v 6 Unuseni gari bada ese ia abidia,  
\q1 hisihisi bada danu,  
\q1 hahine ese kahirakahira natuna ia havaraia ena hisihisi bamona.   
\q1
\v 7 Lohiabada ese idia ia hadikaia ore,  
\q1 lagatoi be lai guba bada ese ia hadikaia ore bamona.   
\b  
\q1
\v 8 Dirava ena kara sivaraina ita kamonai vadaeni hegeregerena,  
\q1 be hari ita itaia vadaeni danu,  
\q1 iseda Dirava ena hanua lalonai.  
\q1 Siahu Ibounai Lohiabada ese inai hanua do ia naria.  
\q1 Do ia gimaia ela bona hanaihanai.   
\b  
\q1
\v 9 Dirava e,  
\q1 oiemu Dubu Helaga lalonai,  
\q1 ai ese oiemu noho hanaihanai lalokauna ai laloa noho.   
\q1
\v 10 Dirava e,  
\q1 tanobada kahana ibounai dekenai noho taunimanima ese,  
\q1 oiemu ladana idia hanamoa noho.  
\q1 Oiemu sivarai,  
\q1 be gabu ibounai dekenai idia gwauraia loaloa noho.  
\q1 Mai maoromaoro danu oi ese taunimanima oi biagua noho.   
\q1
\v 11 Siona dekenai noho taudia do idia moale!  
\q1 Kota maoromaorona oi karaia noho.  
\q1 Iuda ena hanua ibounai lalonai,  
\q1 edia taunimanima be do idia moale bada!   
\q1
\v 12 Dirava ena taudia e,  
\q1 Siona ena kahana ibounai do umui raka lao,  
\q1 bona iena kohoro ibounai do umui duahia.   
\q1
\v 13 Siona ena magu do umui itaia,  
\q1 bona iena ruma aukadia do umui itaia loaloa.  
\q1 Vadaeni Siona ena namo,  
\q1 be gabeai idia vara uru taudia do umui hamaoroa.   
\q1
\v 14 Inai Dirava be iseda Dirava ela bona hanaihanai.  
\q1 Ia ese nega ibounai doko lasi ita do ia hakaua noho.   
\c 49  
\s1 Tau ta, bema moni bona kohu sibona ia laloa, unai tau be kavakava  
\q1
\v 1 Bese idauidau taudia ibounai e, umui kamonai.  
\q1 Tanobada dekenai noho taudia ibounai e,  
\q1 egu hereva do umui kamonai henia.   
\q1
\v 2 Ladana bada taudia bona ladana maragi taudia,  
\q1 kohu momo taudia bona ogogami taudia danu.  
\q1 Inai hereva do umui kamonai!   
\q1
\v 3 Lauegu uduna ese aonega do ia gwauraia,  
\q1 bona egu kudouna ena laloa ese,  
\q1 diba bada do ia hedinaraia umui dekenai.   
\q1
\v 4 Aonega hereva be do lau laloa,  
\q1 bona edia anina be do lau gwauraia hedinarai,  
\q1 mai gita ena regena danu.   
\b  
\q1
\v 5 Nega dikadia, o dagedage taudia,  
\q1 be lau dekenai idia ginidae neganai lau gari lasi.   
\q1
\v 6 Tau dikadia idia laloa moni ese goada do ia henidia,  
\q1 bona edia kohu momo idia hekokorokulaia,  
\q1 to idia dekenai lau gari lasi.   
\q1
\v 7 Momokani, tau ta ese sibona ena mauri,  
\q1 be moni dekena amo ia hoia diba lasi.  
\q1 Ia be hegeregere lasi,  
\q1 Dirava dekenai moni do ia henia, iena mauri davaria totona.  
\q1 Lasi momokani.   
\q1
\v 8 Badina be iena mauri ena davana be bada herea,  
\q1 bona tau ta ena moni be hegeregere lasi.   
\q1
\v 9 Unai dainai tau ta ese,  
\q1 Dirava ena lalona ia veria diba lasi, iena mauri hadaudaua totona.  
\q1 Ia be dala lasi mase ena bodaga bona guria gabuna,  
\q1 dekena amo do ia heau.   
\b  
\q1
\v 10 Ita ibounai ita itaia noho,  
\q1 aonega taudia danu idia mase noho.  
\q1 Kava taudia bona laloa maragi taudia danu idia mase noho,  
\q1 bona edia kohu bona moni idia rakatania,  
\q1 to tau ma haida ese unai moni idia abia noho.   
\q1
\v 11 Guna idia be mai edia tano momo,  
\q1 to harihari guria gabuna sibona be edia noho gabuna.  
\q1 Unuseni do idia noho ela bona hanaihanai.   
\b  
\q1
\v 12 Tau ta ena ladana bada ese,  
\q1 iena mase ia koua diba lasi.  
\q1 Ia be do ia mase,  
\q1 boroma ia mase bamona.   
\b  
\q1
\v 13 Edia goada dekenai bona edia kohu,  
\q1 dekenai idia abidadama taudia edia mase be unai bamona.  
\q1 Unai taudia edia hereva idia badinaia taudia danu,  
\q1 edia dokona be unai bamona.   
\q1
\v 14 Edia davana be, mamoe bamona idia mase.  
\q1 Mase vadaeni taudia edia gabu dekenai idia lao,  
\q1 bona Mase ese edia naria tauna ia lao.  
\q1 Kara maoromaoro taudia be idia dekena amo do idia kwalimu,  
\q1 to unai dika taudia be mase gabunai,  
\q1 edia tauanina idia bodaga lao noho,  
\q1 bona hari edia ruma namodia be lasi.   
\q1
\v 15 To Dirava ese lau do ia hamauria,  
\q1 bona mase taudia edia gabu ese lau do ia dogoatao diba lasi.   
\b  
\q1
\v 16 Bema tau ta be mai ena kohu bona moni momo,  
\q1 bona iena ruma bona kohu ia habadaia momokani neganai,  
\q1 do oi hoa lasi bona mama henia lasi.   
\q1
\v 17 Badina be do ia mase neganai,  
\q1 gau ta do ia abia lao lasi.  
\q1 Iena ruma bona kohu namona,  
\q1 be ia danu do idia diho lasi.   
\q1
\v 18 Momokani iena mauri dinadia lalonai unai gaudia ia moalelaia.  
\q1 Ia gaukara auka bona gau momo ia abia,  
\q1 bona taunimanima idia gwau,  
\q1 “Ia be tau namona.”   
\q1
\v 19 To ia mase neganai,  
\q1 ia be iena sene taudia danu mase gabuna dekenai do ia haboua,  
\q1 unuseni dina ena diari do ia itaia lou lasi.   
\b  
\q1
\v 20 Tau ta ena ladana bada ese,  
\q1 iena mase ia koua diba lasi.  
\q1 Ia be do ia mase,  
\q1 boroma ia mase bamona.   
\c 50  
\s1 Tomadiho kara korikori  
\q1
\v 1 Siahu Ibounai Dirava,  
\q1 iseda Lohiabada ia hereva vadaeni.  
\q1 Ia ese taunimanima ibounai ia boiria,  
\q1 dina ia daekau kahana gabudia dekena amo,  
\q1 ela bona dina ia diho kahana gabudia danu.  
\q1 Tanobada taudia ibounai ia boiria.   
\q1
\v 2 Dirava be Siona dekenai ia noho.  
\q1 Siona be hairai herea gabuna,  
\q1 bona inai gabu namo herea,  
\q1 dekena amo Dirava ena diari ia hedinaraia noho.   
\q1
\v 3 Iseda Dirava ia mai noho, bona mai regena danu do ia mai.  
\q1 Iena vairana dekenai lahi ena hururuhururu do ia noho,  
\q1 bona lai guba badana ese,  
\q1 Dirava do ia hagegea noho.   
\q1
\v 4 Dirava ese guba ena ataiai dekenai ia boiboi,  
\q1 tanobada danu dekenai ia boiboi.  
\q1 Idia ruaosi be kota lalonai do idia hedinarai,  
\q1 Dirava ese iena orea taudia do ia kota henidia neganai.   
\q1
\v 5 Dirava ia gwau,  
\q1 “Lau dekenai idia abidadama henia taudia,  
\q1 be lau dekenai do umui haboua mai,  
\q1 badina idia ese boubou gauna idia henia,  
\q1 bona lau danu gwauhamata taravatuna idia karaia.”   
\q1
\v 6 Guba ese Dirava ena kara maoromaoro idia gwauraia noho,  
\q1 bona idia gwau ia sibona be kota biaguna badana.   
\b  
\q1
\v 7 “Egu bese taudia e, do umui kamonai,  
\q1 bona do lau hereva.  
\q1 Israela e, lau ese oi do lau samania.  
\q1 Lau be Dirava, emui Dirava.   
\q1
\v 8 Emui boubou gaudia dainai umui lau gwau henia lasi.  
\q1 Emui gabua boubou gaudia,  
\q1 be nega ibounai egu vairana dekenai idia noho.   
\q1
\v 9 Lau ese emui tano ena boromakau,  
\q1 bona emui nanigosi lau ura henia, a?  
\q1 Egu boromakau bona nanigosi idia noho lasi, a?   
\q1
\v 10 Badina uda dekenai noho mauri gaudia ibounai be lauegu,  
\q1 bona egu ororo ibounai dekenai idia noho boromakau,  
\q1 momo herea, duahia diba lasi,  
\q1 danu be lauegu.   
\q1
\v 11 Ataiai manudia ibounai danu be lauegu,  
\q1 bona hanua ena murimurinai idia noho mauri gaudia ibounai danu.   
\q1
\v 12 Bema lau hitolo neganai,  
\q1 lau ese umui lau hamaoroa lasi,  
\q1 badina tanobada mai ena anina ibounai danu be lauegu.   
\q1
\v 13 Boromakau tau edia vamu lau ania noho, a?  
\q1 Nanigosi tau edia rarana lau inua noho, a?  
\q1 Lasi momokani!   
\q1
\v 14 To lau ura momokani gauna be emui tanikiu,  
\q1 emui boubou gauna korikori be unai.  
\q1 Lau, Siahu Ibounai Dirava dekenai umui karaia vadaeni gwauhamata,  
\q1 edia anina ibounai do umui henia haorea.   
\q1
\v 15 Hisihisi bona hekwarahi idia ginidae neganai,  
\q1 lau dekenai do umui boiboi,  
\q1 bona lau ese umui do lau hamauria,  
\q1 vadaeni umui ese lau do umui hanamoa bada.”   
\b  
\q1
\v 16 To kara dika taudia dekenai,  
\q1 Dirava ese inai bamona ia hamaoroa, ia gwau:  
\q1 “Badina dahaka egu taravatu umui gwauraia noho?  
\q1 Badina dahaka egu gwauhamata herevadia be umui herevalaia noho?   
\q1
\v 17 Umui ese egu matakani umui ura lasi,  
\q1 bona egu taravatu umui utua bona umui negea noho.   
\q1
\v 18 Henaoa tauna umui itaia neganai,  
\q1 umui be ia danu umui turana karaia,  
\q1 bona heudahanai taudia danu umui haboua noho.   
\q1
\v 19 Hereva dikadia be nega ibounai umui gwauraia noho,  
\q1 bona emui malana ese,  
\q1 hereva koikoi idia gwauraia noho.   
\q1
\v 20 Umui ese emui tadikakadia umui samania noho.  
\q1 Emui sinadia edia natudia tau umui samania koikoi noho.   
\q1
\v 21 Inai dika ibounai umui karaia vadaeni,  
\q1 bona lau ese hereva ta lau gwauraia lasi.  
\q1 Unai dainai umui laloa lau be umui hegeregerena sibona.  
\q1 To harihari lau ese umui lau gwau henia noho.  
\q1 Lau ese umui lau samania noho momokani.   
\q1
\v 22 Lau umui laloaboio taudia e,  
\q1 egu hereva do umui kamonai,  
\q1 lau ese umui do lau hadikaia ore garina,  
\q1 badina be tau ta ese umui do ia hamauria diba lasi.   
\q1
\v 23 Bema tau ta ese,  
\q1 lau dekenai iena tanikiu ia henia,  
\q1 unai tau ese boubou gauna momokani ia henia unai.  
\q1 Lau ia hanamoa noho boubouna be unai,  
\q1 bona lau dekenai idia kamonai henia taudia ibounai,  
\q1 be lau ese do lau hamauridia.”   
\c 51  
\s1 Iena kara dika do ia gwauatao totona, Davida ese Dirava ia noia  
\q1
\v 1 Dirava e,  
\q1 mani oi bogahisihisi lau dekenai.  
\q1 Oiemu lalokau badana dainai,  
\q1 bona oiemu bogahisihisi bada herea dainai,  
\q1 egu kara dika do oi kokia ore.   
\q1
\v 2 Egu dika mani do oi huria ore,  
\q1 bona egu kerere dekena amo lau do oi hagoevaia.   
\q1
\v 3 Badina be egu kara dika be lau diba momokani.  
\q1 Lauegu kerere be egu vairana dekenai ia noho nega ibounai.   
\q1
\v 4 Lau ese oi sibona dekenai lau kara dika vadaeni.  
\q1 Lau be oiemu vairana dekenai kerere lau karaia.  
\q1 Unai dainai oi ese lau oi kota henia be maoro,  
\q1 bona oi ese egu dika ena davana oi henia danu be maoro.   
\q1
\v 5 Momokani, lau be kara dika lalonai lau vara,  
\q1 bona kara dika lalonai egu sinana ese lau ia havaraia.   
\q1
\v 6 Oiemu ura be,  
\q1 egu kudouna dekenai laloa maoromaoro bona momokani idia noho.  
\q1 Unai dainai, mani emu kara,  
\q1 lauegu lalona be oiemu aonega dekenai do oi hahonua.   
\b  
\q1
\v 7 Lauegu kara dika do oi kokia,  
\q1 vadaeni do lau goeva.  
\q1 Mani oi ese lau do oi huria,  
\q1 vadaeni lau be kurokuro,  
\q1 sinou ena kurokuro do lau hereaia.   
\q1
\v 8 Moale bona laloa namo,  
\q1 lau dekenai mani do oi henia lou.  
\q1 Momokani oi ese lau oi atoa diho vadaeni,  
\q1 bona egu dika ena davana lau dekenai oi henia,  
\q1 to hari lau ura moale do lau davaria lou.   
\q1
\v 9 Mani emu kara,  
\q1 egu kara dika dekenai oiemu matana do oi hakapua,  
\q1 bona egu kerere bada ibounai do oi kokia ore.   
\b  
\q1
\v 10 Dirava e,  
\q1 lauegu kudouna lalonai laloa goevagoeva do oi havaraia,  
\q1 bona lauma matamatana bona maoromaorona,  
\q1 be egu lalona dekenai do oi atoa.   
\q1
\v 11 Oiemu vairana dekena amo lau do oi lulua lao lasi,  
\q1 bona oiemu Lauma Helaga,  
\q1 be lau dekena amo do oi kokia lasi.   
\q1
\v 12 Guna be lau moale bada,  
\q1 oi ese lau oi hamauria dainai.  
\q1 Harihari lau ura inai oiemu hamauria ena moale,  
\q1 be lau dekenai do oi henia lou.  
\q1 Bona ura namodia,  
\q1 bona lauma namona,  
\q1 lau dekenai do oi henia,  
\q1 vadaeni oiemu hereva do lau kamonai henia.   
\b  
\q1
\v 13 Unai neganai lau ese,  
\q1 oiemu dala be kerere taudia dekenai do lau hadibaia.  
\q1 Bona kara dika taudia ese,  
\q1 oi dekenai do idia giroa lou.   
\q1
\v 14 Dirava e,  
\q1 oi be lau oi hamauria Diravana,  
\q1 Rara bubua ena kerere,  
\q1 dekena amo lau do oi hamauria.  
\q1 Unai neganai lau ese ane momo do lau abia,  
\q1 oiemu kara maoromaoro do lau gwauraia totona.   
\q1
\v 15 Lohiabada e,  
\q1 oi ese lau do oi durua,  
\q1 do lau hereva goada,  
\q1 bona oiemu ladana do lau habadaia momokani.   
\q1
\v 16 Oi ese boubou karadia dekenai oi moale lasi.  
\q1 Sedira boromakau do lau alaia,  
\q1 boubou totona do lau gabua,  
\q1 to oi be do oi moalelaia lasi.   
\q1
\v 17 Unai dainai Dirava e,  
\q1 lau ese sibona do lau atoa diho,  
\q1 bona oiemu vairana dekenai do lau manau.  
\q1 Inai bamona kara be lauegu boubou gauna oi dekenai.  
\q1 Lau diba momokani, Dirava e,  
\q1 bema tau ta be iena kara dika dainai ia lalohisihisi momokani,  
\q1 bona ia manau momokani neganai,  
\q1 oi ese ia do oi negea diba lasi.   
\b  
\q1
\v 18 Dirava e,  
\q1 Siona taudia dekenai do oi bogahisihisi,  
\q1 bona oi ese idia do oi durua.  
\q1 Ierusalema hanua ena magu do oi haginia lou.   
\q1
\v 19 Unai neganai oiemu taudia ese,  
\q1 boubou gaudia korikori bona maoromaoro do idia henia,  
\q1 bona do oi moalelaia momokani.  
\q1 Lahi dekenai idia gabua bouboudia bona boromakau tau,  
\q1 be oiemu boubou patana dekenai do ai atoa.   
\c 52  
\s1 Dirava ena kota henia kara bona iena hariharibada  
\q1
\v 1 Goada herea tauna e,  
\q1 badina dahaka oiemu kara dika dekenai oi hekokoroku noho?  
\q1 Oi ese nega ibounai,  
\q1 Dirava ena taudia do oi hadikaia dalana oi tahua noho.   
\q1
\v 2 Hereva koikoi tauna e,  
\q1 oiemu malana be kaia mai matana bamona.  
\q1 bona dika ia havaraia noho.   
\q1
\v 3 Dika be oi ura henia bada,  
\q1 namo oi ura henia maragi.  
\q1 Hereva koikoi oi ura henia bada,  
\q1 hereva momokani oi ura henia maragi.   
\q1
\v 4 Oiemu malana be koikoi gauna momokani.  
\q1 Taunimanima hadikaia hereva ibounai oi ura henia momokani.   
\b  
\q1
\v 5 To Dirava ese oi do ia hadikaia ela bona hanaihanai.  
\q1 Ia ese oi do ia dogoatao,  
\q1 bona oiemu ruma dekena amo oi do ia kokia lao.  
\q1 Ia ese mauri taudia edia gabu dekena amo,  
\q1 oi do ia kokia momokani.   
\q1
\v 6 Kara maoromaoro taudia ese inai kara do idia itaia,  
\q1 bona do idia gari.  
\q1 Idia ese unai dika tauna do idia kirikirilaia,  
\q1 do idia gwau,   
\q1
\v 7 “Inai tau,  
\q1 ia ese iena mauri totona Dirava ia abidadama henia lasi,  
\q1 to ia ese iena kohu momo ia abidadama henia,  
\q1 bona kara dikadia dekena amo mauri namona ia tahua.”   
\b  
\q1
\v 8 To lau be olive auna,  
\q1 Dirava ena Ruma lalonai lau vara noho bamona.  
\q1 Dirava ena noho hanaihanai lalokauna,  
\q1 be do lau abidadama henia noho ela bona hanaihanai.   
\q1
\v 9 Dirava e, oi ese oi karaia vadaeni gaudia dainai,  
\q1 lau ese oi do lau hanamoa ela bona hanaihanai.  
\q1 Oiemu ladana be namo herea momokani.  
\q1 Dirava ena taudia edia vairana dekenai,  
\q1 oiemu kara namona do lau gwauraia hedinarai.   
\c 53  
\s1 Taunimanima edia kara dika  
\q1
\v 1 Kavakava taudia ese inai bamona idia laloa, idia gwau,  
\q1 “Dirava be ia noho lasi.”  
\q1 Idia ibounai be dika,  
\q1 kara mirodia idia karaia vadaeni.  
\q1 Kara namo karaia tauna be ta lasi.   
\q1
\v 2 Lohiabada be guba dekena amo iena matana ia negea,  
\q1 taunimanima edia kara ia itaia noho.  
\q1 Ia ese aonega taudia ia tahua noho.  
\q1 Ia dekenai idia tomadiho taudia danu ia tahua noho.   
\q1
\v 3 To idia ibounai ese kara dika idia karaia vadaeni.  
\q1 Idia ibounai be mai edia kerere.  
\q1 Idia ta lasi ese kara namona ia karaia.  
\q1 Lasi bona lasi momokani.   
\b  
\q1
\v 4 Dirava ese ia henanadai, ia gwau,  
\q1 “Inai kara dika taudia idia diba lasi, a?  
\q1 Aonega do idia abia diba lasi, a?  
\q1 Idia ese egu bese taudia idia ania noho, beredi idia ania bamona,  
\q1 bona lau dekenai idia guriguri lasi, lasi momokani.”   
\q1
\v 5 To gari ese idia do ia dogoatao,  
\q1 gari idauna momokani,  
\q1 nega ta unai bamona ia vara lasi gauna.  
\q1 Badina be Dirava ese,  
\q1 iena bese taudia idia hadikaia gwauraia taudia edia turia,  
\q1 be do ia negedia lao.  
\q1 Dirava ese unai tau dikadia ia ura lasi momokani.  
\q1 Unai dainai Israela ese do ia halusidia momokani.   
\b  
\q1
\v 6 Egu noinoi badana be inai:  
\q1 Lau ura Israela ena hamauria,  
\q1 be Siona dekena amo do ia mai!  
\q1 Dirava ese iena bese taudia edia mauri do ia hanamoa lou neganai,  
\q1 Israela taudia be do idia moale bada herea.   
\c 54  
\s1 Dirava be egu durua Tauna  
\q1
\v 1 Dirava e, oiemu ladana ena siahu dekena amo,  
\q1 lau do oi hamauria.  
\q1 Oiemu goada dekena amo lau do oi gwauraia maoro.   
\q1
\v 2 Dirava e, egu noinoi do oi kamonai.  
\q1 Egu uduna ena hereva do oi laloa.   
\q1
\v 3 Hekokoroku taudia ese lau hadikaia totona idia mai noho.  
\q1 Dagedage taudia ese lau alaia dalana idia tahua noho.  
\q1 Idia be Dirava idia laloa lasi taudia.   
\b  
\q1
\v 4 To Dirava be lauegu durua Tauna.  
\q1 Lohiabada ese egu mauri do ia gimaia.   
\q1
\v 5 Dirava ese lau idia hadikaia gwauraia taudia do ia hadikaia,  
\q1 vadaeni sibodia edia dika ese idia do ia hadikaia.  
\q1 Oi ese idia do oi alaia ore,  
\q1 badina oi be kara momokani Diravana.   
\b  
\q1
\v 6 Lau ese laloa namo boubou gauna,  
\q1 oi dekenai do lau henia.  
\q1 Lohiabada e,  
\q1 oiemu ladana do lau hanamoa, badina oiemu ladana be namo.   
\q1
\v 7 Badina be oi ese egu hisihisi ibounai dekena amo,  
\q1 lau oi hamauria vadaeni,  
\q1 bona lau idia ura hadikaia taudia be tuari idia lusi neganai,  
\q1 lau ese edia moru do lau itaia.   
\c 55  
\s1 Iena turana ese ia koia neganai, Davida ese Dirava dekenai ia guriguri  
\q1
\v 1 Dirava e,  
\q1 egu guriguri do oi kamonai.  
\q1 Egu noinoi do oi negea lasi.   
\q1
\v 2 Lau dekenai do oi kamonai,  
\q1 bona lau dekenai do oi haere.  
\q1 Egu laloa hekwarahi dainai lau manoka vadaeni.   
\q1
\v 3 Lau idia hadikaia gwauraia taudia edia hereva dekenai,  
\q1 lau gari bada herea noho.  
\q1 Kara dika taudia edia dagedage ese,  
\q1 lau idia hadikaia noho.  
\q1 Idia ese lau dekenai hisihisi idia havaraia noho.  
\q1 Idia ese lau idia badu henia noho.   
\q1
\v 4 Egu kudouna be gari dainai ia hisihisi noho.  
\q1 Mase ena gari be egu latanai ia ginidae vadaeni.   
\q1
\v 5 Gari bona heudeheude ese lau ia dogoatao noho.  
\q1 Egu lauma be ia gari bona ia hoa dainai,  
\q1 egu goada ia ore.   
\q1
\v 6 Lau gwau,  
\q1 “Bema lau be mai egu hanina, pune manu bamona,  
\q1 lau be do lau roho lao,  
\q1 bona gabu ta dekenai do lau laga-ani.   
\q1
\v 7 Gabu daudau dekenai do lau roho lao,  
\q1 bona taunimanima idia noho lasi gabuna dekenai do lau noho.   
\q1
\v 8 Do lau roho lao haraga,  
\q1 lai guba, bona medu bada ia diho lasi gabuna do lau tahua.  
\q1 Unuseni do lau noho namonamo.”   
\b  
\q1
\v 9 Lohiabada e, lau dekenai idia kara dika taudia,  
\q1 be mani do oi hadikaia,  
\q1 vadaeni edia herevahereva dekena amo,  
\q1 daradara do idia davaria.  
\q1 Badina be ala-ala bona heatu,  
\q1 be hanua badana lalonai lau itaia noho.   
\q1
\v 10 Dina lalonai bona hanuaboi lalonai danu,  
\q1 dika taudia ese hanua ena magu idia raka hagegea noho.  
\q1 Hanua ena lalonai danu,  
\q1 be kara dikadia bona laloa hekwarahi momo.   
\q1
\v 11 Hanua ena lalonai,  
\q1 be ala-ala bona henaoa karadia momo idia vara noho.  
\q1 Hanua ena ariara dekenai,  
\q1 koikoi karadia bona taunimanima hagaria hereva,  
\q1 be idia vara noho, doko lasi.   
\b  
\q1
\v 12 Bema lau ia hadikaia gwauraia tauna ese,  
\q1 lau ia kirikirilaia neganai,  
\q1 lau ese unai kara dekenai lau haheauka diba.  
\q1 Bema lau ia tuari henia tauna ese,  
\q1 lau dekenai hekokoroku hereva ia gwauraia neganai,  
\q1 lau ese ia dekena amo do lau hunia diba.   
\q1
\v 13 To tauna be oi, lau bamona tauna.  
\q1 Oi be lauegu turana korikori,  
\q1 lau dekenai noho hebou tauna.   
\q1
\v 14 Guna ita herevahereva mai moale danu,  
\q1 bona Dubu Helaga lalonai Dirava ita tomadiho henia hebou.   
\b  
\q1
\v 15 Lau idia hadikaia gwauraia taudia dekenai,  
\q1 mase do ia ginidae haraga be namo.  
\q1 Idia ese do mai mauri danu, mase taudia edia gabu dekenai,  
\q1 do idia diho lao be namo!  
\q1 Badina dika be edia kudoudia lalonai,  
\q1 bona edia rumadia lalonai danu dika ia noho.   
\q1
\v 16 To lau be durua totona,  
\q1 Lohiabada dekenai do lau boiboi henia.  
\q1 Lohiabada ese lau do ia hamauria.   
\q1
\v 17 Adorahi neganai, daba neganai,  
\q1 bona dina tubua neganai,  
\q1 lau ese Lohiabada dekenai lau taitai henia,  
\q1 bona ia ese egu gadona do ia kamonai henia.   
\q1
\v 18 Lohiabada ese lau do ia naria namonamo,  
\q1 vadaeni lau dekenai idia tuari henia taudia momo,  
\q1 do lau tuari henidia murinai,  
\q1 Lohiabada ese,  
\q1 mai mauri danu egu ruma dekenai lau do ia hakaua mai lou.   
\q1
\v 19 Dirava,  
\q1 gunaguna momokani ia mai bona hari ia noho Diravana ese,  
\q1 egu noinoi do ia kamonai.  
\q1 Ia ese lau idia tuari henia taudia do ia halusia,  
\q1 badina be iena taravatu idia kamonai henia lasi,  
\q1 bona idia ese Dirava idia gari henia lasi.   
\b  
\q1
\v 20 Egu turana ese iena gwauhamata ia makohia.  
\q1 Ia ese iena turana ia heatu henia.   
\q1
\v 21 Iena hereva be manadamanada,  
\q1 bata ena manadamanada bamona,  
\q1 to iena kudouna lalonai tuari ia noho.  
\q1 Iena hereva be manokamanoka,  
\q1 olive dehoro ena manokamanoka bamona,  
\q1 to unai hereva be tuari kaia mai matana momokani.   
\b  
\q1
\v 22 Oiemu laloa hekwarahi be Lohiabada dekenai do oi henia,  
\q1 bona ia ese idia dekena amo oi do ia durua.  
\q1 Ia ese kara maoromaoro taudia ia durua noho.  
\q1 Idia be do idia moru lasi,  
\q1 lasi momokani.   
\q1
\v 23 To Lohiabada e,  
\q1 oi ese unai ala-ala bona koikoi taudia do oi siaia diho,  
\q1 henunai momokani guri dekenai do idia lao.  
\q1 Unai bamona dika taudia ese,  
\q1 edia mauri dinadia kahana sibona idia ore neganai,  
\q1 do idia mase,  
\q1 to lau ese oi dekenai do lau abidadama henia noho.   
\c 56  
\s1 Davida ese Dirava ia abidadama henia  
\q1
\v 1 Dirava e,  
\q1 lau dekenai do oi bogahisihisi henia,  
\q1 badina be taunimanima ese lau idia lulua noho.  
\q1 Dina ena nega ibounai,  
\q1 idia ese lau idia tuari henia noho.   
\q1
\v 2 Lau idia hadikaia gwauraia taudia ese lau idia lulua noho.  
\q1 Idia momo herea ese lau idia dagedage henia noho.   
\b  
\q1
\v 3 Siahu Ibounai Lohiabada,  
\q1 lau be lau gari neganai oi dekenai do lau abidadama henia.   
\q1
\v 4 Dirava dekenai lau abidadama henia neganai lau gari lasi.  
\q1 Iena gwauhamata gaudia dainai,  
\q1 lau ese ia lau hanamoa noho.  
\q1 Taunimanima sibona be edena bamona lau idia hadikaia diba?   
\b  
\q1
\v 5 Dina ibounai idia ese egu hereva idia hagagevaia noho.  
\q1 Nega ibounai lau hadikaia dalana idia laloa noho.   
\q1
\v 6 Idia be hunia gabudia dekenai idia haboua noho.  
\q1 Egu kara ibounai idia itaia noho,  
\q1 lau idia alaia totona ena dala idia tahua noho.   
\b  
\q1
\v 7 Dirava e, edia kerere davana do oi henidia.  
\q1 Mai oiemu badu danu unai taudia do oi halusia.   
\q1
\v 8 Lohiabada e, egu laloa hekwarahi oi diba.  
\q1 Egu matana ena ranu be oiemu kavabu dekenai do oi udaia.  
\q1 Oiemu buka lalonai idia torea vadaeni, ani?   
\b  
\q1
\v 9 Oi dekenai lau boiboi dinana dekenai,  
\q1 lau idia badu henia taudia do oi lulua lou.  
\q1 Lau diba inai be momokani,  
\q1 badina Dirava be lau dekenai ia noho.   
\q1
\v 10 Ia be Lohiabada,  
\q1 iena gwauhamata herevadia lau hanamoa Diravana.   
\q1
\v 11 Ia sibona lau abidadama henia,  
\q1 vadaeni do lau gari lasi.  
\q1 Taunimanima sibona be edena bamona lau idia hadikaia diba?   
\b  
\q1
\v 12 Dirava e, oi dekenai lau gwauhamata gauna,  
\q1 ena anina be do lau karaia.  
\q1 Lau ese oi dekenai,  
\q1 egu tanikiu boubou gauna do lau henia,   
\q1
\v 13 badina be oi ese egu lauma,  
\q1 be mase dekena amo oi hamauria vadaeni.  
\q1 Oi ese danu egu aena oi naria,  
\q1 vadaeni lau moru lasi.  
\q1 Unai dainai lau be Dirava ena vairanai lau raka diba,  
\q1 mauri taudia edia diari lalonai.   
\c 57  
\s1 Davida ese durua totona Lohiabada ia noia  
\q1
\v 1 Dirava e, lau dekenai do oi bogahisihisi,  
\q1 lau dekenai do oi bogahisihisi henia,  
\q1 badina be mauri abia totona,  
\q1 oi dekenai egu lauma ia hunia noho gwauraia.  
\q1 Oiemu hanina edia henunai be egu hunia gabuna,  
\q1 ela bona inai nega dika be do ia ore.   
\q1
\v 2 Ataiai Herea Diravana dekenai lau tai henia noho,  
\q1 lau davaria diba lasi gaudia ibounai,  
\q1 ia ese ia henia noho Diravana be unai.   
\q1
\v 3 Ia ese guba dekena amo durua do ia siaia,  
\q1 bona lau do ia hamauria.  
\q1 Ia ese lau idia dagedage henia taudia do ia halusia.  
\q1 Dirava ese iena noho hanaihanai lalokauna,  
\q1 bona iena momokani, lau dekenai do ia hedinarai henia.   
\q1
\v 4 Dagedage taudia ese lau idia hagegea noho.  
\q1 Idia be taunimanima idia ania noho, laiona bamona.  
\q1 Edia isena be io bona diba bamona,  
\q1 bona edia maladia,  
\q1 be tuari kaia mai edia matadia bamona.   
\q1
\v 5 Dirava e, guba lalonai oiemu siahu do oi hedinaraia,  
\q1 bona tanobada ena kahana ibounai dekenai,  
\q1 oiemu hairaina do oi hedinaraia.   
\q1
\v 6 Lau idia hadikaia gwauraia taudia ese,  
\q1 lau do idia abia totona tarapu idia atoa vadaeni.  
\q1 Lau be laloa hekwarahi dainai egu goada ia ore.  
\q1 Egu dala dekenai guri badana idia geia,  
\q1 to idia sibodia unai guri lalonai idia moru.   
\q1
\v 7 Dirava e, egu kudouna lalonai,  
\q1 egu abidadama ia goada momokani.  
\q1 Egu abidadama ia goada momokani oi dekenai.  
\q1 Oi hanamoa totona ane do lau abia,  
\q1 ane namona do lau abia.   
\q1
\v 8 Egu lauma e, do oi noga!  
\q1 Egu gita badana,  
\q1 bona gita maragina e, do umui noga!  
\q1 Lau ese daba rere do lau hanogaia.   
\q1
\v 9 Lohiabada e,  
\q1 bese idauidau edia huanai lau ese oi do lau hanamoa.  
\q1 Taunimanima ibounai edia huanai,  
\q1 lau ese oi hanamoa totona ane do lau abia,   
\q1
\v 10 badina oiemu noho hanaihanai lalokauna be bada herea.  
\q1 Ia daekau lao ela bona guba dekenai.  
\q1 Oiemu hereva oi badinaia momokani kara be bada,  
\q1 bona ia daekau lao ela bona ori dekenai.   
\q1
\v 11 Dirava e,  
\q1 oiemu siahu badana be guba dekenai do oi hedinaraia,  
\q1 bona oiemu hairaina be,  
\q1 tanobada ena kahana ibounai dekenai danu do oi hedinaraia.   
\c 58  
\s1 Davida ese Dirava ia noia, kara dika taudia edia dika davana do ia henidia  
\q1
\v 1 Umui lohia taudia e,  
\q1 umui ese nega ta kota maoromaoro do umui gwauraia, a?  
\q1 Umui ese taunimanima ibounai,  
\q1 be maka tamona dekenai umui kota henidia, a?   
\q1
\v 2 Lasi, to emui lalona dekenai,  
\q1 kerere karadia umui laloa noho.  
\q1 Umui ese dagedage karadia tanobada dekenai umui karaia noho.   
\q1
\v 3 Kara dika taudia be,  
\q1 edia sinadia edia bogana dekena amo idia mai neganai,  
\q1 kerere dalana idia karaia hamatamaia.  
\q1 Edia vara dinadia dekena amo idia kerere vadaeni,  
\q1 koikoi hereva idia gwauraia noho.   
\q1
\v 4 Idia be poisini dekenai idia honu,  
\q1 gaigai ena poisini bamona.  
\q1 Idia be taia kudima gaigaina bamona.  
\q1 Inai gaigai ese iena taiana ia koua noho,   
\q1
\v 5 meamea tauna ena gadona do ia kamonai lasi totona,  
\q1 meamea tauna mai aonega danu,  
\q1 ena gadona do ia kamonai lasi totona.   
\b  
\q1
\v 6 Dirava e,  
\q1 edia isena do oi hamakohia edia ududia dekenai.  
\q1 Lohiabada e,  
\q1 inai laiona edia isena badadia do oi kokia momokani.   
\q1
\v 7 Ia heau lao ranu ia boio haraga bamona,  
\q1 inai laiona danu mani do idia boio haraga.  
\q1 Mani emu kara,  
\q1 oi ese idia do oi moia patapata,  
\q1 ava idia moia patapata bamona.   
\q1
\v 8 Kone ena bisisi be kopukopu lalonai ia diho lao,  
\q1 ia boio bamona,  
\q1 mani emu kara idia ese danu do idia boio.  
\q1 Bona mani emu kara,  
\q1 ia vara dika merona ia mase,  
\q1 bona dina ia itaia lasi bamona,  
\q1 idia danu unai bamona do oi hamasedia.   
\b  
\q1
\v 9 Mamina idia do abia lasi neganai,  
\q1 oi ese idia do oi kokia lao,  
\q1 ava ginigini idia kokia lao hegeregerena.  
\q1 Idia do oi kokia momokani,  
\q1 lai goadana ese ava dikadia ia kokia ore bamona.   
\q1
\v 10 Kara maoromaoro taudia ese,  
\q1 dika taudia edia davana henia idia itaia neganai do idia moale.  
\q1 Idia ese kara dika taudia edia rarana lalonai,  
\q1 edia aena do idia huria.   
\q1
\v 11 Vadaeni taunimanima do idia gwau,  
\q1 “Momokani kara maoromaoro taudia be mai edia davana namona.  
\q1 Momokani tanobada ia kota henia Diravana be ia noho.”   
\c 59  
\s1 Davida ese Dirava ia noia, do ia hamauria  
\q1
\v 1 Egu Dirava e,  
\q1 lau idia hadikaia gwauraia taudia dekena amo lau do oi hamauria.  
\q1 Lau dekenai idia tuari henia noho taudia dekena amo,  
\q1 lau do oi gimaia.   
\q1
\v 2 Kara dika taudia dekena amo lau do oi hamauria.  
\q1 Ala-ala taudia dekena amo lau do oi durua, do lau mauri noho.   
\b  
\q1
\v 3 Oi itaia,  
\q1 idia be lau alaia totona idia hunia noho.  
\q1 Dagedage taudia be lau hadikaia totona idia haboua noho.   
\q1
\v 4 To Lohiabada e,  
\q1 inai be lauegu kara dika o lauegu kerere dainai lasi.  
\q1 Lau be mai egu kerere ta lasi,  
\q1 to idia heau mai, bona lau alaia totona idia hegaegae noho.  
\q1 Do oi noga,  
\q1 lau durua totona do oi mai.  
\q1 Lau do oi itaia!   
\q1
\v 5 Lohiabada, Siahu Ibounai Dirava,  
\q1 Israela ena Dirava,  
\q1 mani do oi toreisi,  
\q1 bona Dirava idia ura lasi taudia edia dika davana do oi henia.  
\q1 Kara dika karaia totona,  
\q1 hunia dekenai idia laloa hebou taudia,  
\q1 be do oi alaia mase,  
\q1 do oi bogahisihisi henidia lasi.   
\b  
\q1
\v 6 Adorahi ibounai idia giroa mai noho,  
\q1 bona sisia bamona idia boiboi noho,  
\q1 hanua lalonai idia raka loaloa neganai.   
\q1
\v 7 Edia uduna dekena amo hereva dika,  
\q1 bona hereva badu idia mai,  
\q1 mumuta bamona.  
\q1 Edia malana be tuari kaia bamona.  
\q1 To idia laloa, idia gwau,  
\q1 “Daika ese ai dekenai ia kamonai diba?”   
\q1
\v 8 To Lohiabada e, oi ese idia dekenai oi kiri noho.  
\q1 Oi ese Dirava ura lasi taudia ibounai dekenai,  
\q1 oi kirikirilaia noho.   
\b  
\q1
\v 9 Lohiabada e,  
\q1 oiemu goada dainai oi dekenai lau abidadama henia noho.  
\q1 Oi be lauegu kohoro,  
\q1 egu hunia gabuna.   
\b  
\q1
\v 10 Egu Dirava ese lau ia lalokau henia noho,  
\q1 bona ia be egu vairana dekenai do ia lao,  
\q1 lau dekenai idia tuari henia taudia ia ese do ia halusia.   
\q1
\v 11 To Lohiabada e,  
\q1 unai lau idia hadikaia gwauraia taudia be do oi alaia lasi,  
\q1 egu bese taudia ese,  
\q1 unai taudia edia matakani do idia laloaboio garina.  
\q1 Mani emu kara oiemu siahu bada dekena amo idia do oi lulua,  
\q1 vadaeni do idia loaloa kava lao, bona do oi hadikadia.  
\q1 Lohiabada e, oi be aiemai gima Tauna, aiemai kesi.   
\q1
\v 12 Edia ududia be dika,  
\q1 edia hereva ibounai be mai kara dika danu.  
\q1 Unai dainai Lohiabada e,  
\q1 sibodia edia hekokoroku dekena amo do oi hadikadia.  
\q1 Badina be idia ese,  
\q1 taunimanima hamasea hereva bona koikoi hereva idia gwauraia noho.   
\q1
\v 13 Oiemu badu dekena amo do oi hadikadia ore.  
\q1 Do oi hadikadia ela bona idia boio momokani.  
\q1 Unai dekena amo,  
\q1 taunimanima do idia diba Dirava ese Israela ia biagua noho.  
\q1 Bona do idia diba danu,  
\q1 Dirava be tanobada ibounai ena biaguna badana.   
\b  
\q1
\v 14 Lau idia hadikaia gwauraia taudia,  
\q1 be adorahi neganai idia giroa mai noho,  
\q1 sisia bamona idia boiboi noho,  
\q1 hanua lalonai idia raka loaloa neganai.   
\q1
\v 15 Idia be sisia bamona aniani idia tahua loaloa,  
\q1 bona bema idia davaria lasi neganai, idia boiboi mai badu danu.   
\q1
\v 16 To lau ese ane dekena amo,  
\q1 oiemu goada do lau hanamoa.  
\q1 Daba ibounai, ane dekena amo,  
\q1 oiemu noho hanaihanai lalokauna do lau hanamoa,  
\q1 badina oi be lauegu kohoro,  
\q1 bona egu heau mauri gabuna,  
\q1 nega dika ia vara neganai.   
\q1
\v 17 Lohiabada e,  
\q1 oi sibona be egu goada ena badina.  
\q1 Oi hanamoa totona ane do lau abia.  
\q1 Oi Dirava be egu kohoro.  
\q1 Oi be lau oi lalokau henia noho Diravana.   
\c 60  
\s1 Davida ese durua totona Dirava ia noia  
\q1
\v 1 Dirava e,  
\q1 oi ese ai oi negea vadaeni,  
\q1 oi ese ai oi halusia vadaeni.  
\q1 Oi ese ai dekenai oi badu vadaeni,  
\q1 to hari mani emu kara ai do oi abia dae lou.   
\q1
\v 2 Oi ese tano oi hamarerea vadaeni,  
\q1 bona oi ese tano oi hapararaia vadaeni.  
\q1 To hari do oi haginia lou,  
\q1 badina be ia goada lasi noho.   
\q1
\v 3 Oi ese oiemu bese taudia oi hisihisi henidia bada vadaeni.  
\q1 Ai ese uaina momo ai inua vadaeni bamona,  
\q1 ai raka kerere noho.   
\b  
\q1
\v 4 Oi ese oi dekenai idia gari taudia dekenai,  
\q1 heau mauri gabuna do oi henia,  
\q1 idia ese unuseni do idia heau lao,  
\q1 peva ena diba idia dika momokani neganai.   
\q1
\v 5 Oiemu goada dekena amo ai do oi hamauria.  
\q1 Aiemai noinoi mani do oi kamonai,  
\q1 vadaeni ai, oi lalokau henia taudia,  
\q1 be oi ese do oi hamauria.   
\b  
\q1
\v 6 Iena gabu helagana dekena amo Dirava ia hereva, ia gwau,  
\q1 “Mai kwalimu danu lau ese Sekema tano do lau hapararaia,  
\q1 bona Sukoto Koura,  
\q1 be egu bese dekenai do lau haria.   
\q1
\v 7 Gileada be egu tano,  
\q1 Manase danu be lauegu.  
\q1 Eparaima be egu tuari kwara gauna,  
\q1 bona Iuda be egu dagi toana auna.   
\q1
\v 8 To lau ese Moaba do lau abia,  
\q1 egu aena huria disi bamona,  
\q1 bona Edoma ena latanai egu tamaka do lau negea lao,  
\q1 lau ese lau biagua ena toana.  
\q1 Pilistia tano danu do lau abia,  
\q1 mai kwalimu ena boiboi danu.”   
\b  
\q1
\v 9 To Dirava e,  
\q1 daika ese hanua mai maguna danu dekenai be lau do ia hakaua vareai?  
\q1 Daika ese Edoma dekenai lau do ia hakaua lao?   
\q1
\v 10 Dirava e,  
\q1 oi ese ai oi negea momokani vadaeni, a?  
\q1 Dirava e,  
\q1 aiemai tuari taudia danu,  
\q1 idia durua totona do oi raka mai lou lasi, a?   
\b  
\q1
\v 11 Dirava e, ai do oi durua,  
\q1 ai idia tuari henia taudia be ai ese do ai halusia totona,  
\q1 badina be taunimanima edia durua be anina lasi.   
\q1
\v 12 Bema Dirava be iseda kahana dekenai ia noho neganai,  
\q1 ita be do ita kwalimu.  
\q1 Dirava ese ita dekenai idia tuari henia taudia do ia halusia.   
\c 61  
\s1 Davida ese Dirava ia noia do ia gimaia  
\q1
\v 1 Dirava e,  
\q1 egu taitai do oi kamonai.  
\q1 Egu guriguri mani do oi abia dae.   
\q1
\v 2 Egu kudouna ena goada ia ore,  
\q1 bona lau be egu gabu korikori dekena amo daudau lau noho.  
\q1 Unai dainai oi dekenai lau boiboi noho inai!  
\q1 Mani emu kara, heau mauri gabu namona,  
\q1 egu goada ia hereaia Nadi Badana dekenai,  
\q1 lau do oi hakaua lao.   
\q1
\v 3 Badina Lohiabada e,  
\q1 oi be egu heau mauri gabuna.  
\q1 Oi be lauegu kohoro,  
\q1 bona oi ese lau idia hadikaia gwauraia taudia oi koua noho.   
\q1
\v 4 Oiemu Ruma lalonai do lau noho ela bona hanaihanai.  
\q1 Lohiabada e,  
\q1 mani emu kara oiemu hanina edia henunai lau do oi hunia,  
\q1 do lau mauri totona.   
\q1
\v 5 Badina be Dirava e,  
\q1 egu gwauhamata be oi ese oi kamonai vadaeni,  
\q1 bona oi ese,  
\q1 oiemu ladana idia matauraia taudia edia davana namona,  
\q1 be lau dekenai oi henia vadaeni.   
\q1
\v 6 Dirava e, king ena mauri lagani do oi halataia.  
\q1 Iena mauri do oi hanamoa,  
\q1 vadaeni lagani momo do ia mauri noho.   
\q1
\v 7 Dirava e,  
\q1 mani emu kara king ese,  
\q1 oiemu vairana dekenai do ia lohia karaia noho.  
\q1 Oi ese oiemu noho hanaihanai lalokauna,  
\q1 bona oiemu momokani dekena amo, king do oi gimaia noho.   
\q1
\v 8 Unai dainai lau ese ane dekenai,  
\q1 oiemu ladana do lau hanamoa,  
\q1 bona dina ta ta ibounai,  
\q1 egu gwauhamata gaudia oi dekenai, be do lau karaia momokani.   
\c 62  
\s1 Davida ese Dirava ia abidadama henia  
\q1
\v 1 Momokani, egu lauma ese,  
\q1 Dirava sibona dekena amo laga-ani ia abia.  
\q1 Egu hamauria dalana be Dirava sibona ese ia karaia noho.   
\q1
\v 2 Ia sibona be egu Nadi Badana,  
\q1 bona egu mauri davaria dalana.  
\q1 Ia be egu kohoro,  
\q1 bona lau be nega ta do lau mareremarere lasi.   
\b  
\q1
\v 3 Umui ibounai ese tau tamona do umui heatu henia noho,  
\q1 ela bona edena negai?  
\q1 Ia be goada lasi, ia makohia vadaeni magu sibona bamona,  
\q1 to umui ese umui heatu henia noho, a?   
\q1
\v 4 Umui ura iena dagi dekena amo do umui doria diho, ani?  
\q1 Bona umui ese hereva koikoi umui gwauraia noho,  
\q1 badina hanamoa hereva ia dekenai umui gwauraia noho,  
\q1 to emui kudouna lalonai umui hadikaia noho.   
\b  
\q1
\v 5 Lau ese Dirava sibona lau abidadama henia noho.  
\q1 Lau ese ia sibona mai abidadama danu lau naria noho,  
\q1 ia ese lau do ia hanamoa totona.   
\q1
\v 6 Dirava sibona be egu Nadi Badana,  
\q1 bona egu mauri davaria dalana.  
\q1 Ia be egu kohoro,  
\q1 bona lau be nega ta do lau mareremarere lasi.   
\q1
\v 7 Egu mauri bona egu kwalimu,  
\q1 be Dirava sibona ese ia henia noho.  
\q1 Ia sibona be egu Nadi Badana momokani,  
\q1 bona egu mauri davaria dalana.   
\b  
\q1
\v 8 Taunimanima e,  
\q1 nega ibounai Dirava do umui abidadama henia.  
\q1 Emui kudouna edia ura gaudia,  
\q1 be ia dekenai do umui hamaoroa,  
\q1 badina Dirava be iseda heau mauri gabuna momokani.   
\b  
\q1
\v 9 Dagi maragi taudia be hahodi ta sibona bamona,  
\q1 ma dagi bada taudia be anina lasi.  
\q1 Metau tohoa sikele dekenai idia be metau lasi momokani.  
\q1 Edia metau,  
\q1 be hahodi tamona ena metau hegeregerena sibona.   
\q1
\v 10 Dagedage karadia dekenai do umui abidadama henia lasi.  
\q1 Henaoa kara danu dekenai do umui hekokoroku lasi.  
\q1 Bema emui kohu idia momo daekau lao neganai,  
\q1 do umui lalokau henidia lasi.   
\b  
\q1
\v 11 Nega ta Dirava ia hereva vadaeni,  
\q1 bona nega rua be inai hereva lau kamonai vadaeni,  
\q1 gauna be inai:  
\q1 Dirava e,  
\q1 oi be mai siahu bada danu.   
\q1
\v 12 Bona Dirava e,  
\q1 oi be mai oiemu lalokau momokani danu.  
\q1 Momokani oi ese,  
\q1 taunimanima ta ta edia gaukara, edia gaukara hegeregerena,  
\q1 edia davana do oi henia.   
\c 63  
\s1 Davida ena guriguri, ia ura Dirava be ia dekenai do ia noho  
\q1
\v 1 Dirava e,  
\q1 oi be lauegu Dirava,  
\q1 lau ese oi lau tahua noho.  
\q1 Lauegu lauma ia ura bada oi dekenai ia noho.  
\q1 Egu tauanina be ia ura momokani oi dekenai ia noho,  
\q1 hegeregere tau ta tano kaukau dekenai ranu ia ura dikadika bamona.   
\q1
\v 2 Lau ura oi do lau itaia, oiemu gabu helaga lalonai.  
\q1 Lau ura oi ese oiemu goada bona oiemu hairaina,  
\q1 be lau dekenai do oi hedinaraia.   
\q1
\v 3 Badina be oiemu bogahisihisi bona oiemu lalokau ese,  
\q1 inai tanobada ena mauri idia hereaia.  
\q1 Unai dainai egu udu bibina ese oi do idia hanamoa bada.   
\q1
\v 4 Egu mauri dinadia ibounai lalonai oi do lau hanamoa.  
\q1 Egu imana do lau abia isi, bona oi dekenai do lau guriguri.   
\q1
\v 5 Egu lauma be do ia noho namo herea,  
\q1 hegeregere tau ta ese,  
\q1 aniani namona ia ania murinai ia boga kunu bamona.  
\q1 Lau ese ane do lau abia,  
\q1 oi do lau hanamoa bada totona.   
\q1
\v 6 Lau be geda dekenai lau hekure neganai,  
\q1 oi dekenai lau laloa noho.  
\q1 Hanuaboi lalonai lau ese oi sibona dekenai lau laloa,   
\q1
\v 7 badina oi ese lau oi durua vadaeni.  
\q1 Lau be oi kahirakahira lau noho,  
\q1 hegeregere kokoroku ena natuna ese,  
\q1 iena sinana ena hanina henunai ia noho bamona,  
\q1 bona ane lau abia, mai moale danu.   
\q1
\v 8 Lau ese oi lau dogoatao noho,  
\q1 bona oiemu imana idibana ese lau ia hagoadaia noho.   
\q1
\v 9 Tau haida ese lau idia alaia dalana idia tahua noho.  
\q1 Unai taudia be mase taudia edia gabu dekenai do idia diho lao.   
\q1
\v 10 Idia be tuari lalonai do idia mase,  
\q1 bona edia tauanina be uda sisia ese do idia ania.   
\b  
\q1
\v 11 To lau, king, ese oi Dirava do lau moalelaia bada.  
\q1 Dirava ena ladana dekenai idia gwauhamata taudia ibounai,  
\q1 ese Lohiabada do idia hanamoa,  
\q1 to koikoi idia gwauraia taudia,  
\q1 be Dirava ese edia uduna do ia koua.   
\c 64  
\s1 Davida ese Dirava ia noia do ia gimaia  
\q1
\v 1 Dirava e,  
\q1 lau be mai laloa hekwarahi danu.  
\q1 Egu noinoi mani do oi kamonai henia.  
\q1 Lau idia hadikaia gwauraia taudia dekenai lau gari noho.  
\q1 Egu mauri mani do oi gimaia.   
\b  
\q1
\v 2 Kara dika taudia ese lau alaia totona dala idia tahua noho,  
\q1 be mani emu kara idia dekena amo lau do oi hunia.   
\q1
\v 3 Idia edia malana,  
\q1 be tuari kaia bamona idia segea noho,  
\q1 bona dagedage herevadia lau dekenai idia pidia,  
\q1 peva dekena amo diba do idia pidia bamona.   
\q1
\v 4 Idia ese hunia gabuna dekena amo,  
\q1 kerere lasi tauna idia pidia noho.  
\q1 Idia ese unai tau idia pidia haraga noho,  
\q1 tau ta ese do ia itaia lasi totona.   
\b  
\q1
\v 5 Idia edia ura dikadia karaia totona,  
\q1 idia sibodia ta ta dekenai idia goada henia noho.  
\q1 Edia tarapu do idia hunia daladia idia herevalaia hebou noho.  
\q1 Idia gwau, “Daika ese ita do ia itaia diba?”   
\q1
\v 6 Idia ese dika do idia karaia ena palani idia karaia noho,  
\q1 bona idia gwau,  
\q1 “Ita ese kerere karana namona momokani ena palani,  
\q1 be ita karaia vadaeni!”  
\q1 Momokani taunimanima edia lalona bona edia kudouna,  
\q1 be mai kerere ena aonega bada danu.   
\b  
\q1
\v 7 To Dirava ese iena diba dekena amo idia do ia pidia,  
\q1 bona idia be bero do idia davaria haraga.   
\q1
\v 8 Badina be edia malana edia dika dainai,  
\q1 idia sibodia ese edia dika do idia havaraia.  
\q1 Bona do idia itadia taudia ibounai ese,  
\q1 edia kwaradia do idia giroagiroa,  
\q1 bona unai dika taudia do idia kirikirilaia.   
\q1
\v 9 Vadaeni taunimanima ibounai do idia gari,  
\q1 bona Dirava ena kara do idia laloa,  
\q1 ma idia ese Dirava ena gaukara do idia gwauraia hedinarai.   
\b  
\q1
\v 10 Kara maoromaoro taudia ese,  
\q1 Lohiabada dainai do idia moale bada,  
\q1 bona idia ese Lohiabada dekenai do idia heau mauri.  
\q1 Kudoudia idia maoromaoro taudia ibounai ese,  
\q1 Lohiabada do idia hanamoa bada.   
\c 65  
\s1 Dirava ita hanamoa bona tanikiu henia  
\q1
\v 1 Dirava e, Siona dekenai do ai lao,  
\q1 ai ese oi do ai hanamoa,  
\q1 bona aiemai gwauhamata edia anina oi dekenai do ai henia,   
\q1
\v 2 badina be oi ese aiemai guriguri oi kamonai.  
\q1 Taunimanima ibounai be oi dekenai do idia mai,   
\q1
\v 3 edia dika do oi gwauatao totona.  
\q1 Aiemai kerere ese ai idia halusia neganai,  
\q1 oi ese unai dika oi gwauatao noho.   
\q1
\v 4 Oi ese oi abia hidi taudia,  
\q1 bona oi ese oiemu gabu helagana dekenai oi mailaidia taudia,  
\q1 be idia moale bada.  
\q1 Inai oiemu Ruma ena lalonai,  
\q1 gau namodia momo idia noho.  
\q1 Unai dainai oiemu Dubu Helaga ai noho neganai,  
\q1 aiemai lalona idia namo momokani.   
\b  
\q1
\v 5 Dirava e,  
\q1 oi sibona ese ai oi hamauria,  
\q1 bona noho namona ai dekenai oi henia.  
\q1 Oi ese aiemai guriguri oi kamonai henia vadaeni.  
\q1 Hoa kara badadia oi ese oi karaia vadaeni,  
\q1 ai do oi hamauria totona.  
\q1 Taunimanima tanobada kahana kahana ibounai dekena amo,  
\q1 ese oi dekenai idia abidadama.  
\q1 Davara daudau herea idia hanaia gabudia taudia danu,  
\q1 ese oi idia abidadama henia noho.   
\q1
\v 6 Oi ese oiemu goada dekena amo ororo, edia gabu dekenai oi haginia.  
\q1 Oiemu siahu bada oi hedinaraia unai.   
\q1
\v 7 Oi ese davara bada ena dika bona hurehure bada,  
\q1 be oi hamanadaia noho.  
\q1 Taunimanima edia huanai tuari,  
\q1 be oi ese oi hadokoa noho.   
\q1
\v 8 Unai dainai tanobada taudia ibounai ese,  
\q1 oiemu hoa karadia dekenai idia gari.  
\q1 Oiemu kara badadia dainai taunimanima ibounai,  
\q1 dina daekau kahana dekena amo,  
\q1 bona dina diho kahana dekena amo,  
\q1 ese mai boiboi danu oi dekenai idia hanamoa,  
\q1 mai edia moale bada herea.   
\b  
\q1
\v 9 Oi ese medu oi siaia noho.  
\q1 Inai kara dekena amo oi hedinaraia,  
\q1 oi ese tanobada oi naria namonamo noho.  
\q1 Oi ese tano oi hanamoa noho,  
\q1 muramura namona ia dekenai oi atoa,  
\q1 vadaeni aniani ia tubu namonamo noho.  
\q1 Dirava e,  
\q1 oi ese sinavai ibounai be ranu dekenai oi hahonua,  
\q1 bona uma ena anina oi atoa noho.   
\q1
\v 10 Oi ese medu momo oi siaia diho,  
\q1 ia ese idia geia hegaegae tanona ia hapariparia momokani,  
\q1 vadaeni ranu be tano lalonai ia noho.  
\q1 Oi ese medu dekena amo tano oi hamanokaia.  
\q1 Unai dainai uma ena aniani avadia idia tubu namonamo diba.   
\q1
\v 11 Oi ese aniani utua negana oi hanamoa noho,  
\q1 anina momo idia haboua.  
\q1 Oi lao gabudia ibounai dekenai aniani namona momo ia noho.   
\q1
\v 12 Rei ia noho gabudia ibounai dekenai,  
\q1 be mamoe bona boromakau momo idia noho,  
\q1 bona ororo gabudia ibounai dekenai uma gabudia momo idia noho.   
\q1
\v 13 Rei gabudia dekenai mamoe momo idia noho,  
\q1 bona koura gabudia dekenai uiti momo idia tubu noho.  
\q1 Unuseni idia noho gaudia ibounai idia moale,  
\q1 mai boiboi, bona mai ane danu.   
\c 66  
\s1 Dirava hanamoa bona tanikiu henia ane ta  
\q1
\v 1 Tanobada taudia ibounai,  
\q1 Dirava dekenai do umui boiboi henia mai moale bada danu.   
\q1
\v 2 Iena ladana hanamoa totona ane do umui abia,  
\q1 ia dekenai hairai bona hanamoa do umui henia.   
\q1
\v 3 Dirava dekenai do umui gwau,  
\q1 “Oiemu kara be mai gari danu gaudia.  
\q1 Oiemu siahu ia bada herea dainai,  
\q1 oi dekenai idia tuari henia taudia,  
\q1 be oiemu vairana dekenai mai gari danu,  
\q1 oiemu siahu henunai sibodia idia atoa.   
\q1
\v 4 Tanobada taudia ibounai ese oi dekenai idia tomadiho henia noho.  
\q1 Oi hanamoa totona ane idia abia noho.  
\q1 Oiemu ladana hanamoa totona ane idia abia noho.”   
\b  
\q1
\v 5 Umui mai,  
\q1 Dirava ena kara do umui itaia.  
\q1 Iena kara taunimanima edia huanai be mai garina karadia.   
\q1
\v 6 Davara be tano kaukauna dekenai ia halaoa.  
\q1 Ma aiemai sene taudia ese aena dekena amo sinavai idia raka hanaia.  
\q1 Unai Dirava ese ia karaia gaudia dainai ita moale bada noho.   
\q1
\v 7 Dirava ese iena siahu dekena amo do ia King hanaihanai.  
\q1 Iena matana ese bese idauidau ibounai idia itaia noho.  
\q1 Dirava e, oi dekenai idia dagedage taudia,  
\q1 be do oi koua,  
\q1 vadaeni do idia hekokoroku lasi.   
\b  
\q1
\v 8 Bese idauidau taudia e,  
\q1 iseda Dirava do umui hanamoa.  
\q1 Ane do umui abia goada,  
\q1 Dirava umui hanamoa badabada, taunimanima do idia kamonai totona.   
\q1
\v 9 Ia ese iseda mauri ia naria vadaeni.  
\q1 Ia ese iseda aena ia naria,  
\q1 vadaeni ita moru lasi.   
\b  
\q1
\v 10 Dirava e,  
\q1 oi ese ai oi tohoa vadaeni.  
\q1 Siliva idia tohoa noho bamona,  
\q1 be oi ese ai oi tohoa vadaeni.   
\q1
\v 11 Tarapu dekena amo oi ese ai oi abia,  
\q1 bona maduna metaudia aiemai dorudia dekenai oi atoa vadaeni.   
\q1
\v 12 Ai dekenai idia tuari taudia,  
\q1 be oi ese oi koua lasi dainai idia ese ai idia hadikaia.  
\q1 Ai be lahi ai raka hanaia,  
\q1 bona ranu danu,  
\q1 to hari be mauri gabuna dekenai oi ese ai oi hakaua mai vadaeni.   
\b  
\q1
\v 13 Lau ese gabua boubou gaudia,  
\q1 be oiemu Dubu Helaga lalonai do lau mailaia,  
\q1 bona oi dekenai lau gwauhamata do lau henia gauna,  
\q1 ena anina do lau karaia.   
\q1
\v 14 Hisihisi lau dekenai ia vara neganai,  
\q1 gwauhamata oi dekenai lau gwauraia gauna,  
\q1 be do lau karaia momokani.   
\q1
\v 15 Ubua gaudia namodia oi dekenai do lau henia,  
\q1 boubou patana dekenai do idia gabudia ore totona.  
\q1 Mamoe tau haida danu do lau gabua ore.  
\q1 Boromakau tau bona nanigosi tau danu,  
\q1 edia kwalahu be guba dekenai do ia daekau lao.   
\b  
\q1
\v 16 Dirava dekenai umui gari taudia ibounai e,  
\q1 umui mai, umui kamonai.  
\q1 Dirava ese lau dekenai ia karaia gaudia,  
\q1 be umui dekenai do lau gwauraia hedinarai.   
\q1
\v 17 Lau ese Dirava dekenai lau boiboi henia,  
\q1 bona ane dekena amo lau hanamoa bada.   
\q1
\v 18 Bema kara dika be egu kudouna dekenai lau hunia neganai,  
\q1 Lohiabada ese egu noinoi do ia kamonai henia lasi.   
\q1
\v 19 To momokani Dirava ese ia kamonai vadaeni.  
\q1 Ia ese egu noinoi hereva ia abia dae vadaeni.   
\q1
\v 20 Dirava do lau hanamoa, badina egu noinoi ia negea lasi.  
\q1 Iena noho hanaihanai lalokauna,  
\q1 be lau dekena amo ia kokia lasi.   
\c 67  
\s1 Dirava hanamoa ane ta  
\q1
\v 1 Dirava e,  
\q1 ai dekenai do oi bogahisihisi,  
\q1 bona oi ese ai do oi hanamoa.  
\q1 Mani ai dekenai do oi laloa,  
\q1 bona ai do oi durua.   
\q1
\v 2 Unai dekena amo tanobada taudia ibounai ese,  
\q1 oiemu dala do idia diba,  
\q1 bona oiemu hamauria kara,  
\q1 be bese ibounai taudia danu do idia diba.   
\b  
\q1
\v 3 Dirava e,  
\q1 lau ura bese ibounai ese oi do idia hanamoa.  
\q1 Lau ura bese idauidau ese oiemu ladana do idia abia isi.   
\q1
\v 4 Bese idauidau taudia ibounai ese,  
\q1 mai moale danu ane idia abia be namo.  
\q1 Badina be oi ese tanobada taudia oi kota henia noho,  
\q1 mai maoromaoro bona momokani danu,  
\q1 bona bese ibounai be oi ese oi hakaua noho.   
\b  
\q1
\v 5 Dirava e, lau ura bese ibounai ese oi do idia hanamoa,  
\q1 bona oiemu ladana idia abia isi.   
\q1
\v 6 Tano ena anina idia vara namonamo, badina be,  
\q1 Dirava, iseda Dirava ese ita ia hanamoa vadaeni.   
\q1
\v 7 Momokani, Dirava ese ita ia hanamoa vadaeni.  
\q1 Tanobada taudia ibounai ese,  
\q1 Dirava do idia matauraia be namo.   
\c 68  
\s1 Dirava be tuari dekenai ia kwalimu  
\q1
\v 1 Dirava be do ia toreisi,  
\q1 ia dekenai idia tuari henia gwauraia taudia do ia lulua ore.  
\q1 Dirava dekenai idia dagedage taudia,  
\q1 be iena vairana dekena amo do idia heau.   
\q1
\v 2 Lai ese kwalahu ia hodaia ore hegeregerena,  
\q1 unai bamona danu Dirava ese idia do ia hodaia ore.  
\q1 Kandolo be lahi ena vairanai ia veve ore bamona,  
\q1 kara dika taudia be unai bamona do idia mase,  
\q1 Dirava ena vairana dekenai,   
\q1
\v 3 to kara maoromaoro taudia be do idia moale,  
\q1 Dirava ena vairana dekenai do idia moale bada.  
\q1 Mai boiboi danu edia moale do idia hedinaraia.   
\b  
\q1
\v 4 Dirava dekenai ane do umui abia,  
\q1 iena ladana be ane dekenai do umui hanamoa.  
\q1 Ori dekenai ia guia noho Diravana,  
\q1 be ane dekenai do umui hanamoa bada.  
\q1 Iena ladana be Lohiabada,  
\q1 bona iena vairana dekenai do umui moale.   
\b  
\q1
\v 5 Dirava, iena noho gabuna helagana dekenai ia noho Diravana,  
\q1 ese ogogami taudia ia naria noho,  
\q1 bona vabu taudia danu ia gimaia noho.   
\q1
\v 6 Dirava ese mai edia turana lasi taudia dekenai,  
\q1 bese taudia ia henidia,  
\q1 bona dibura ruma noho taudia,  
\q1 be dibura dekena amo ia kokia ruhaia,  
\q1 mauri namona idia dekenai ia henia noho.  
\q1 To ia dekenai idia dagedage taudia,  
\q1 be tano kaukau dekenai do idia noho.   
\b  
\q1
\v 7 Dirava e, oiemu bese taudia oi hakaudia neganai,  
\q1 oi ese taunimanima noho lasi tano oi raka hanaia neganai,   
\q1
\v 8 tano be ia mareremarere,  
\q1 bona guba ese medu bada ia siaia diho,  
\q1 Sinai Ororo ena Dirava ia mai noho dainai,  
\q1 Israela ena Dirava ia mai noho dainai.   
\q1
\v 9 Dirava e, momokani oi ese medu bada herea oi siaia diho,  
\q1 bona oiemu tano kaukau oi hanamoa lou.   
\q1
\v 10 Vadaeni oiemu bese taudia be unai tano dekenai,  
\q1 edia noho gabuna idia davaria,  
\q1 bona oiemu hariharibada dainai,  
\q1 ogogami taudia dekenai aniani bona gau oi henidia.   
\b  
\q1
\v 11 Lohiabada ese iena oda ia gwauraia,  
\q1 vadaeni taunimanima momo ese,  
\q1 unai hereva idia gwauraia hedinarai, idia gwau,   
\q1
\v 12 “King taudia bona edia tuari taudia idia heau lao noho!”  
\q1 Ruma dekenai idia noho hahine ese,  
\q1 edia bese tuari taudia ese idia abia kohu idia haria.   
\q1
\v 13 Pune manu laulau gaudia,  
\q1 edia hanina be siliva dekena amo idia koua,  
\q1 bona pune manu hanina edia huina be golo namo herea,  
\q1 ia diaridiari gauna,  
\q1 dekena amo idia koua.  
\q1 To umui haida, badina dahaka tuari dinana dekenai,  
\q1 mamoe edia magu murinai umui hunia?   
\q1
\v 14 Siahu Ibounai Dirava ese,  
\q1 Salamona Ororo dekenai king taudia ia lulua lao ore neganai,  
\q1 ia ese sinou unuseni ia siaia diho.   
\b  
\q1
\v 15 Basana Ororo be ororo badana momokani.  
\q1 Basana Ororo be mai ena dorina momo.   
\q1
\v 16 Dorina momo ena ororo e,  
\q1 badina dahaka mai mama danu,  
\q1 Dirava ia ura do ia noholaia Ororo umui itaia noho?  
\q1 Lohiabada be unuseni do ia noho ela bona hanaihanai.   
\b  
\q1
\v 17 Lohiabada be Sinai Ororo dekena amo,  
\q1 iena helaga gabuna dekenai ia mai,  
\q1 mai ena kariota goadadia momo herea danu.   
\q1
\v 18 Iena ororo badadia dekenai ia daekau lao,  
\q1 bona ia ese ia abia mauri tuari taudia momo ia hakaudia daekau.  
\q1 Dagedage taudia momo dekena amo harihari gaudia ia abia noho.  
\q1 Unai ororo dekenai Lohiabada Dirava be do ia noho.   
\b  
\q1
\v 19 Lohiabada do ita hanamoa.  
\q1 Ia ese dina ibounai iseda maduna metaudia ia huaia noho.  
\q1 Ia ese ita ia hamauria noho.   
\q1
\v 20 Iseda Dirava be taunimanima ia hamauria Diravana.  
\q1 Ia be Lohiabada, iseda Dirava,  
\q1 bona ia ese mase dekena amo ita ia hamauria noho.   
\q1
\v 21 Dirava ese ia dekenai idia dagedage taudia,  
\q1 edia kwaradia do ia hamakohia.  
\q1 Edia kara dika daladia idia karaia noho taudia,  
\q1 be Dirava ese edia kwaradia,  
\q1 mai huidia bada danu do ia hamakohia momokani.   
\q1
\v 22 Lohiabada ia hereva vadaeni, ia gwau,  
\q1 “Oi dekenai idia tuari henia taudia,  
\q1 be Basana dekena amo do lau mailaidia lou.  
\q1 Davara dobu gabudia dekena amo do lau mailaidia lou.   
\q1
\v 23 Vadaeni emui aedia be rara dekena amo do umui hadigua,  
\q1 bona emui sisia ese edia maladia dekena amo,  
\q1 umui idia tuari henia taudia edia rarana do idia ania.   
\b  
\q1
\v 24 Dirava e,  
\q1 mai oiemu hairaina danu oi raka hanaia noho,  
\q1 be ibounai ese oi idia itaia.  
\q1 Egu Dirava, egu King, mai ena orea,  
\q1 be gabu helagana dekenai idia raka vareai noho,  
\q1 mai edia hairaina danu.   
\q1
\v 25 Ane idia abia taudia be orea ena vairana dekenai idia raka noho.  
\q1 Idia edia murinai be miusiki idia gadaralaia noho taudia.  
\q1 Bona idia edia huanai,  
\q1 be kekeni ese tareko idia botaia noho.   
\q1
\v 26 Iena bese taudia edia hebou badana lalonai,  
\q1 Dirava do ita hanamoa.  
\q1 Israela besena taudia ibounai e,  
\q1 Lohiabada do umui hanamoa.   
\q1
\v 27 Beniamina iduhu,  
\q1 iduhu maragina momokani,  
\q1 ese idia ia gunalaia.  
\q1 Idia edia murinai be Iuda iduhu lohia taudia,  
\q1 mai edia orea taudia momo herea.  
\q1 Idia edia murinai be Sebuluno bona Napatali edia lohia taudia.   
\b  
\q1
\v 28 Dirava e, oiemu siahu do oi hedinaraia.  
\q1 Oiemu goada be ai dekenai do oi hedinaraia,  
\q1 gunaguna ai durua totona oi hedinaraia goada bamona.   
\q1
\v 29 Vadaeni oiemu Dubu Helaga Ierusalema dekenai dainai,  
\q1 king taudia ese harihari gaudia oi dekenai do idia mailaia.   
\q1
\v 30 Aigupito, unai siriho dekenai ia noho uda boroma,  
\q1 be do oi gwau henia.  
\q1 Bese idauidau, unai boromakau tau oreadia,  
\q1 mai edia boromakau natudia danu do oi gwau henia,  
\q1 ela bona oi dekenai do idia tomadiho henia,  
\q1 bona edia siliva be oi dekenai do idia henia.  
\q1 Tuari dekenai idia moale bada bese taudia,  
\q1 be do oi lulua lao ore.   
\q1
\v 31 King taudia ese oi dekenai harihari gaudia do idia henia.  
\q1 Aigupito dekena amo auri laboralabora do idia mailaia.  
\q1 Etiopia taudia ese imadia do idia abia isi,  
\q1 bona Dirava dekenai do idia guriguri.   
\b  
\q1
\v 32 Tanobada basileia ibounai e,  
\q1 Dirava hanamoa totona ane do umui abia.  
\q1 Lohiabada dekenai hanamoa ane do umui abia.   
\q1
\v 33 Badina ia be guba dekenai ia guia loaloa noho,  
\q1 gunaguna momokani ia noho guba be unai.  
\q1 Do umui kamonai,  
\q1 Dirava ena gadona be guba dekena amo ia boiboi noho.   
\q1
\v 34 Taunimanima ibounai e,  
\q1 Dirava ena King siahuna do umui gwauraia.  
\q1 Ia be Israela ena King,  
\q1 mai ena siahu danu.  
\q1 Iena siahu danu be guba edia lalonai.   
\q1
\v 35 Dirava be iena helaga gabuna lalonai.  
\q1 Ita ese ia dekenai ita gari bona matauraia be namo.  
\q1 Ia be Israela ena Dirava.  
\q1 Ia ese siahu bona goada,  
\q1 iena bese taudia dekenai ia henia noho.  
\q1 Dirava do ita hanamoa!   
\c 69  
\s1 Davida ese Dirava dekenai ia noinoi, do ia durua totona  
\q1
\v 1 Dirava e, lau do oi veria mauri,  
\q1 badina abata be ia daekau,  
\q1 ia mai bona egu aiona dekenai.   
\q1
\v 2 Lau be lau diho lao kopukopu lalonai,  
\q1 bona egu aena be gini gabuna ta lasi.  
\q1 Lau be ranu dobu lalonai lau noho,  
\q1 bona abata ese kahirakahira lau idia maloa.   
\q1
\v 3 Lau be lau tai dikadika,  
\q1 bona egu gadona be ia kaukau noho.  
\q1 Lauegu matana idia hisihisi bada,  
\q1 oi dekenai lau tahua noho dainai.   
\q1
\v 4 Lau dekenai idia badu henia kava taudia be momo herea.  
\q1 Edia namba be,  
\q1 egu kwarana ena huina edia namba idia hanaia.  
\q1 Lau idia dagedage henia taudia,  
\q1 ese hereva koikoi dekenai lau idia hadikaia noho.  
\q1 Inai taudia be goada herea,  
\q1 bona idia ura lau idia alaia mase.  
\q1 Lau ese idia dekena amo gau ta lau henaoa lasi,  
\q1 to idia ese lau idia samania goada dainai,  
\q1 lau ese egu gau korikori haida idia dekenai lau henia.   
\q1
\v 5 Dirava e, egu kara dika be oi dekena amo lau hunia diba lasi,  
\q1 bona egu kavakava ibounai, be oi diba vadaeni.   
\q1
\v 6 Lohiabada e, oi be Siahu Ibounai Diravana.  
\q1 Mani lau do oi durua,  
\q1 vadaeni oi dekenai idia abidadama taudia,  
\q1 be do idia hemarai lasi lau totona.  
\q1 Israela ena Dirava e, lau do oi durua,  
\q1 vadaeni kara dikana ta do lau karaia lasi.  
\q1 Vadaeni tau dikadia ese, oi dekenai idia tomadiho taudia,  
\q1 be do idia hadikaia lasi hereva dika dekena amo.   
\q1
\v 7 Lau ese oi lau badinaia dainai,  
\q1 haida ese lau dekenai idia hereva dika,  
\q1 bona hemarai ese egu vairana ia koua noho.   
\q1
\v 8 Lauegu tadikaka dekenai lau be idau tauna bamona,  
\q1 bona egu famili dekenai,  
\q1 lau be gabu daudau dekena amo lau mai tauna bamona.   
\q1
\v 9 Oiemu Dubu Helaga lau ura henia dikadika,  
\q1 bona inai ura ese lahi bamona lau ia gabua noho,  
\q1 bona haida ese oi dekenai idia hereva dika neganai,  
\q1 inai hereva ese lau ia hadikaia noho.   
\q1
\v 10 Lau be lau aniani lasi,  
\q1 oiemu vairana dekenai do lau manau totona,  
\q1 to taunimanima be lau dekenai idia hereva dika noho.   
\q1
\v 11 Lau ese mase ena lalohisihisi dabua lau atoa,  
\q1 to taunimanima ese lau idia kirikirilaia noho.   
\q1
\v 12 Hanua ena ariara dekenai idia haboua,  
\q1 bona lau idia herevalaia dika noho.  
\q1 Inua kekero taudia ese,  
\q1 edia ane dekenai lau idia herevalaia noho.   
\q1
\v 13 To Lohiabada e,  
\q1 lau be oi dekenai do lau guriguri noho.  
\q1 Dirava e,  
\q1 oiemu nega namona dekenai lau do oi haere henia.  
\q1 Oiemu lalokau bona bogahisihisi bada dainai,  
\q1 lau dekenai do oi haere,  
\q1 badina be oi ese oi gwauhamata vadaeni lau do oi hamauria,  
\q1 bona oi be oi koikoi diba lasi, lasi momokani.   
\q1
\v 14 Kopukopu dekena amo lau do oi veria mauri.  
\q1 Lau idia dagedage henia taudia,  
\q1 dekena amo lau do oi hamauria,  
\q1 bona ranu dobu dekena amo danu.   
\q1
\v 15 Lau do oi durua,  
\q1 abata ese lau do ia maloa lasi.  
\q1 Lau do oi durua,  
\q1 ranu dobu lalonai do lau mase lasi,  
\q1 o guria gabuna dekenai do lau diho lasi.   
\q1
\v 16 Lohiabada e,  
\q1 lau dekenai do oi haere,  
\q1 badina be oiemu noho hanaihanai lalokauna be ia namo herea.  
\q1 Oiemu bogahisihisi bada herea dainai, lau do oi durua.   
\q1
\v 17 Lau be oiemu hesiai tauna, unai dainai oiemu vairana,  
\q1 be lau dekena amo do oi hunia lasi.  
\q1 Lauegu hisihisi be bada herea,  
\q1 unai dainai lau dekenai do oi haere haraga.   
\q1
\v 18 Lau kahirakahira do oi mai, bona lau do oi hamauria.  
\q1 Lau dekenai idia dagedage taudia dekena amo lau do oi hamauria.   
\b  
\q1
\v 19 Oi diba vadaeni,  
\q1 taunimanima ese lau dekenai idia hereva dika noho,  
\q1 bona oi diba danu lauegu hemarai,  
\q1 bona unai taudia edia hereva koikoi dekena amo,  
\q1 idia ese egu ladana idia hadikaia noho.  
\q1 Lau dekenai idia badu taudia ibounai be oi ese oi itaia noho.   
\q1
\v 20 Inai hereva dika ese egu kudouna idia makohia vadaeni,  
\q1 bona durua ta be lasi dainai lauegu laloa ia ore.  
\q1 Taunimanima edia bogahisihisi be lau tahua, to ta lasi.  
\q1 Hereva namona lau do idia henia taudia lau tahua,  
\q1 to ta lau davaria lasi.   
\q1
\v 21 Lau be hitolo neganai,  
\q1 mase havaraia muramura lau dekenai idia henia.  
\q1 Lau ranu mase neganai,  
\q1 vinega sibona lau dekenai idia henia.   
\b  
\q1
\v 22 Vadaeni, gabeai aniani bada ena aria do idia karaia neganai,  
\q1 lau ura inai aria ese idia do ia hadikaia ore.  
\q1 Bona aria helagana idia karaia neganai,  
\q1 lau ura inai kara ese,  
\q1 idia do ia hamorua momokani.   
\q1
\v 23 Edia matana do oi hakepulua!  
\q1 Edia doruna danu do oi hamanokaia hanaihanai.   
\q1
\v 24 Idia dekenai do oi badu!  
\q1 Oiemu badu mai siahu danu idia edia latanai do oi hadihoa,  
\q1 vadaeni dika do idia davaria.   
\q1
\v 25 Edia kamepa do oi hadikaia,  
\q1 vadaeni edia palai rumadia lalonai,  
\q1 tau ta do ia noho lasi.   
\q1
\v 26 Badina be oi ese oi panisia vadaeni tauna,  
\q1 be idia ese ma idia dagedage henia noho.  
\q1 Bona oi ese oi haberoa tauna,  
\q1 be idia ese ma idia hisihisi henia noho.   
\q1
\v 27 Unai taudia edia kara dika do oi laloa boio lasi,  
\q1 bona oiemu hamauria idia dekenai do oi henia lasi.   
\q1
\v 28 Edia ladana be mauri taudia edia buka,  
\q1 dekena amo do oi kokia,  
\q1 bona edia ladana be,  
\q1 kara maoromaoro taudia edia ladana danu do oi haboua lasi.   
\b  
\q1
\v 29 Lau be mai hisihisi bada bona durua ta lasi,  
\q1 unai dainai egu laloa ia ore.  
\q1 Dirava e, lau ura oi ese lau do oi abia isi,  
\q1 bona lau do oi hamauria.   
\q1
\v 30 Lau ese ane dekena amo Dirava do lau hanamoa.  
\q1 Dirava ena ladana do lau habadaia,  
\q1 bona ia do lau tanikiu henia.   
\q1
\v 31 Inai kara ese Lohiabada do ia hamoalea bada,  
\q1 to boromakau boubouna ese Lohiabada do ia hamoalea maragi.  
\q1 Boromakau tau mai ena doana bona mai ena aena,  
\q1 unai boubou ese Lohiabada do ia hamoalea sisina sibona.   
\q1
\v 32 Inai kara be ogogami taudia do idia itaia neganai,  
\q1 do idia moale.  
\q1 Dirava ena dala idia tahua noho taudia ibounai ese,  
\q1 goada matamata do idia davaria.   
\q1
\v 33 Badina be Lohiabada ese,  
\q1 gau lasi taudia edia noinoi ia kamonai henia noho,  
\q1 bona dibura ruma lalonai idia noho taudia,  
\q1 be ia laloaboio lasi.   
\b  
\q1
\v 34 Guba bona tanobada e, Lohiabada do umui hanamoa.  
\q1 Davara, bona davara dekenai idia noho mauri gaudia ibounai e,  
\q1 Dirava do umui hanamoa.   
\q1
\v 35 Badina be Dirava ese Siona do ia hamauria,  
\q1 bona ia ese Iuda ena hanua ibounai do ia haginia lou.  
\q1 Lohiabada ena bese taudia,  
\q1 be unai gabudia dekenai do idia noho,  
\q1 bona unai tano ibounai do idia abia, edia tano.   
\q1
\v 36 Dirava ena hesiai taudia edia natudia bona tubudia,  
\q1 be unai tano do idia abia,  
\q1 bona Lohiabada ena ladana idia lalokau henia taudia,  
\q1 be unai tano dekenai do idia noho.   
\c 70  
\s1 Davida ese durua totona Dirava ia noia  
\q1
\v 1 Dirava e, mani lau do oi hamauria.  
\q1 Lohiabada e, lau do oi durua haraga.   
\q1
\v 2 Egu mauri hadokoa dalana idia tahua noho taudia dekenai,  
\q1 hemarai bona daradara do oi havaraia.  
\q1 Idia ura lau idia hadikaia ore gwauraia taudia,  
\q1 be do oi siaidia lou mai hemarai bada danu.   
\q1
\v 3 Lau idia hereva dika henia noho taudia idia gwau,  
\q1 “Aha, aha,”  
\q1 Unai taudia be do oi halusidia,  
\q1 mai hemarai bada danu.   
\q1
\v 4 To oi idia tahua noho taudia ibounai, be do oi durua,  
\q1 vadaeni oi dainai do idia moale bada noho.  
\q1 Bona oi ese mauri oi henidia dainai idia tanikiu noho taudia,  
\q1 do oi durua,  
\q1 vadaeni nega ibounai inai bamona do idia gwau,  
\q1 “Dirava be ia bada momokani!”   
\b  
\q1
\v 5 To lau be lau ogogami noho,  
\q1 bona mai egu gau ta lasi danu.  
\q1 Dirava e, lau dekenai do oi mai haraga.  
\q1 Oi be lauegu durua Tauna,  
\q1 bona egu hamauria Tauna danu.  
\q1 Lohiabada e, lau durua totona do oi mai haraga.   
\c 71  
\s1 Tau burukana ta ena guriguri  
\q1
\v 1 Lohiabada e, oi sibona lau abidadama henia noho.  
\q1 Lau do oi durua,  
\q1 vadaeni nega ta hemarai ese lau do ia abia lasi.   
\q1
\v 2 Oi be maoromaoro momokani dainai,  
\q1 oi ese lau do oi durua bona lau do oi hamauria.  
\q1 Lau dekenai do oi kamonai,  
\q1 bona lau do oi hamauria.   
\q1
\v 3 Lau ura oi be egu heau mauri Nadi Badana.  
\q1 Lau ura oi be egu kohoro aukana,  
\q1 vadaeni nega ibounai oi dekenai do lau lao,  
\q1 lau do oi hamauria totona.  
\q1 Badina oi be egu Nadi Badana bona gabu aukana,  
\q1 bona oi ese lau oi gimaia noho.   
\q1
\v 4 Egu Dirava e,  
\q1 kara dika taudia dekena amo lau do oi hamauria.  
\q1 Kara gagevagageva, bona dagedage taudia, edia siahu dekena amo,  
\q1 lau do oi hamauria.   
\b  
\q1
\v 5 Badina be, Lohiabada Dirava e,  
\q1 oi be egu mauri namona abia dalana.  
\q1 Lohiabada e, egu uhau dinadia ia mai bona hari,  
\q1 lau ese oi lau abidadama henia vadaeni.   
\q1
\v 6 Egu vara dinana dekena amo,  
\q1 oi ese lau oi naria noho vadaeni.  
\q1 Egu sinana ena bogana lau rakatania neganai ia mai bona hari,  
\q1 oi ese lau oi gimaia vadaeni.  
\q1 Lau ese nega ibounai oi do lau hanamoa noho.   
\q1
\v 7 Oi ese lau oi gimaia vadaeni dainai,  
\q1 egu mauri ena kara ese,  
\q1 taunimanima momo, be dala maoromaoro dekenai ia hakaudia vadaeni.   
\q1
\v 8 Dina ena nega ibounai, lau ese oi lau hanamoa noho.  
\q1 Oiemu hairaina lau gwauraia hedinarai noho.   
\b  
\q1
\v 9 Lauegu buruka dinadia neganai lau do oi rakatania lasi.  
\q1 Egu goada be ia ore lao neganai,  
\q1 lau dekena amo do oi siri lasi.   
\q1
\v 10 Lau idia hadikaia gwauraia taudia ese,  
\q1 lau idia alaia dalana idia tahua noho.  
\q1 Idia haboua noho,  
\q1 bona lau do idia alaia dalana idia herevalaia noho.   
\q1
\v 11 Idia gwau, “Dirava ese inai tau ia rakatania vadaeni.  
\q1 Do ita lulua, do ita dogoatao,  
\q1 badina be tau ta ese ia do ia hamauria lasi.”   
\q1
\v 12 Dirava e, lau dekena amo do oi noho daudau lasi.  
\q1 Egu Dirava e,  
\q1 lau do oi durua haraga.   
\q1
\v 13 Lau idia heatu henia taudia,  
\q1 be do oi halusia bona hadikaia ore.  
\q1 Lau idia hadikaia gwauraia taudia be do oi hahemaraia momokani.   
\b  
\q1
\v 14 To lau ese oiemu durua lau naria noho,  
\q1 mai egu abidadama danu.  
\q1 Bona oi do lau hanamoa noho,  
\q1 bona inai hanamoa ma do lau habadaia.   
\q1
\v 15 Egu uduna ese oiemu kara maoromaoro do ia herevalaia,  
\q1 bona oiemu hamauria kara danu,  
\q1 be nega ibounai do lau gwauraia hedinarai.  
\q1 To emu namo edia bada lau diba lasi,  
\q1 idia be duahia diba lasi.   
\q1
\v 16 Dirava Lohiabada e, oiemu siahu karadia do lau hanamoa.  
\q1 Oiemu kara maoromaoro,  
\q1 bona oi sibona oi karaia kara namodia, do lau gwauraia.   
\q1
\v 17 Dirava e, lau be mero negana dekena amo,  
\q1 oi ese lau oi hadibaia vadaeni,  
\q1 bona unai negana ia mai bona hari,  
\q1 lau ese oiemu hoa karadia lau gwauraia vadaeni,  
\q1 bona do lau gwauraia noho.   
\q1
\v 18 Momokani hari lau be buruka,  
\q1 bona egu huina idia kurokuro vadaeni.  
\q1 To Dirava e, lau do oi rakatania lasi.  
\q1 Lau ese oiemu siahu lau herevalaia noho neganai,  
\q1 lau dekenai do oi noho,  
\q1 bona oiemu goada be gabeai do idia vara besedia,  
\q1 dekenai do lau gwauraia hedinarai.   
\b  
\q1
\v 19 Dirava e,  
\q1 oiemu kara maoromaoro be idia daekau lao ela bona guba dekenai.  
\q1 Oi ese kara badadia oi karaia vadaeni.  
\q1 Tau ta oi hegeregerena ia noho lasi.   
\q1
\v 20 Oi ese hisihisi dikadia bona laloa hekwarahi dekena amo,  
\q1 lau oi hisihisi henia vadaeni,  
\q1 to oi ese goada be lau dekenai do oi henia lou.  
\q1 Oi ese mase ena guri dekena amo lau do oi hamauria.   
\q1
\v 21 Oi ese egu ladana do oi habadaia momokani,  
\q1 guna bamona lasi,  
\q1 bona egu lalona do oi hagoadaia lou.   
\b  
\q1
\v 22 Lau ese gita badana dekena amo, oi do lau hanamoa.  
\q1 Dirava e,  
\q1 oiemu maoromaoro bona oiemu momokani do lau hanamoa.  
\q1 Israela ena Helaga Diravana e,  
\q1 gita badana dekena amo oi do lau hanamoa.   
\q1
\v 23 Oi do lau hanamoa totona ane lau abia neganai,  
\q1 mai moale danu do lau boiboi.  
\q1 Mai egu laumana bona kudouna ibounai danu,  
\q1 guriguri ane do lau abia,  
\q1 oi ese lau oi hamauria dainai.   
\q1
\v 24 Dina ena nega ibounai,  
\q1 egu malana ese oiemu kara maoromaoro do ia herevalaia,  
\q1 badina be lau idia hadikaia dalana idia tahua taudia,  
\q1 be oi ese idia dekenai hemarai bona daradara oi havaraia vadaeni.   
\c 72  
\s1 Davida ese Dirava ia noia, king Solomona do ia durua  
\q1
\v 1 Dirava e, mani emu kara,  
\q1 king dekenai oiemu kara maoromaoro do oi hadibaia,  
\q1 vadaeni ia ese taunimanima ia kota henia neganai,  
\q1 mai maoromaoro bona momokani danu do ia karaia.   
\b  
\q1
\v 2 Bona do oi durua,  
\q1 ia ese oiemu bese taudia do ia biagua mai ena maoromaoro danu.  
\q1 Ia ese oiemu taudia, hisihisi idia abia noho taudia danu,  
\q1 be do ia naridia, mai ena momokani danu.   
\q1
\v 3 Tano do oi hanamoa,  
\q1 vadaeni taunimanima do idia noho namo,  
\q1 edia gaukara ena anina do idia abia.  
\q1 Kara maoromaoro danu,  
\q1 be taunimanima edia lalona dekenai do oi havaraia.   
\q1
\v 4 King do oi durua, ia ese,  
\q1 ogogami taudia maka tamona dekenai do ia kota henidia,  
\q1 bona ia ese gau lasi taudia edia natudia do ia durua.  
\q1 Ma haida idia dagedage henidia taudia,  
\q1 be king ese idia do ia atoa diho.   
\b  
\q1
\v 5 Lau ura oiemu bese taudia,  
\q1 be oi dekenai do idia tomadiho nega ibounai.  
\q1 Dina bona hua idia do diari noho negadia ibounai,  
\q1 oiemu bese oi dekenai do idia tomadiho.   
\q1
\v 6 Oi ese king do oi durua,  
\q1 vadaeni ia be tau namona do ia lao.  
\q1 Iena kara be medu bamona,  
\q1 uma dekenai ia diho, bona aniani ia tubu namo herea.   
\q1
\v 7 Lau ura king ena mauri dinadia ibounai lalonai,  
\q1 iena bese taudia ese kara maoromaoro do idia karaia,  
\q1 bona edia noho be namo,  
\q1 bona edia gaukara ena anina do idia abia,  
\q1 hua ese iena diari ia henia dinadia ibounai.   
\b  
\q1
\v 8 King ena basileia be mani do ia bada,  
\q1 davara ta dekena amo ela bona ma davara ta,  
\q1 Euperate Sinavai dekena amo ela bona tanobada ena dokona dekenai.   
\q1
\v 9 Etiopia taudia ese king ena vairanai do idia tui diho,  
\q1 bona king dekenai idia dagedage taudia ese,  
\q1 iena vairanai do idia moru diho,  
\q1 edia kwaradia be tano dekenai do idia atoa.   
\q1
\v 10 Tarasisi ena king, bona motumotu edia king ese,  
\q1 edia harihari gaudia be ia dekenai do idia mailaia.  
\q1 Sieba bona Seba edia king danu ese,  
\q1 edia takisi moni do idia mailaia ia dekenai.   
\q1
\v 11 King ibounai be iena vairanai do idia tui diho,  
\q1 bona bese ibounai taudia ese,  
\q1 iena hesiai gaukara do idia karaia.   
\b  
\q1
\v 12 Ogogami taudia be ia dekenai idia boiboi neganai,  
\q1 ia ese do ia durua.  
\q1 Edia gau be lasi, bona edia durua be lasi taudia,  
\q1 be king ese do ia hamauria.   
\q1
\v 13 Ia ese manoka taudia,  
\q1 bona ogogami taudia dekenai do ia bogahisihisi,  
\q1 bona gau lasi taudia be mase dekena amo,  
\q1 ia ese do ia hamauria.   
\q1
\v 14 Bema unai ogogami taudia,  
\q1 be haida ese idia dagedage henia neganai,  
\q1 king ese unai ogogami taudia do ia hamauria.  
\q1 Ia ese edia mauri do ia naria namonamo noho,  
\q1 badina edia mauri be gau namo herea ia dekenai.   
\b  
\q1
\v 15 King ena mauri do ia daudau be namo!  
\q1 Sieba ena golo be king dekenai idia henia be namo.  
\q1 Namona be iena bese taudia ese,  
\q1 king dainai Dirava do idia noia,  
\q1 vadaeni Dirava ese king do ia durua,  
\q1 bona do ia hanamoa, nega ibounai.   
\q1
\v 16 Namona be koni momo herea,  
\q1 be tano dekenai do ia vara namonamo.  
\q1 Namona be ororo gabudia danu dekenai,  
\q1 uiti bona aniani avadia do idia tubu namonamo,  
\q1 Lebanona dekenai idia tubu namonamo bamona.  
\q1 Namona be hanua ibounai dekenai taunimanima momo do idia noho,  
\q1 uma tano dekenai rei momo idia noho bamona.   
\q1
\v 17 Lau ura king ena ladana do idia laloaboio lasi.  
\q1 Lau ura iena sivarai be do ia noho daudau,  
\q1 dina do ia noho daudau bamona.  
\b  
\q1 Ia dainai bese idauidau ibounai ese hanamoa do idia davaria,  
\q1 bona idia ese Dirava do idia noia,  
\q1 ia ese idia do ia hanamoa,  
\q1 king ia hanamoa hegeregerena.   
\b  
\q1
\v 18 Lohiabada, Israela ena Dirava, do ita hanamoa.  
\q1 Ia sibona ese hoa karadia ia karaia noho.   
\q1
\v 19 Lohiabada ena ladana namo herea do ita hanamoa hanaihanai.  
\q1 Iena hairai namona ese tanobada ibounai do ia hahonua.  
\q1 Amen bona Amen.   
\q1
\v 20 Davida Iese ena guriguri be iniseni ia doko.   
\c 73  
\s1 Dirava ese tau dikadia edia kerere davana do ia henia  
\q1
\v 1 Momokani, Dirava ena kara be namo, Israela taudia dekenai.  
\q1 Edia lalona idia goevagoeva taudia dekenai,  
\q1 Dirava ena kara be namo.   
\b  
\q1
\v 2 To egu aena be kahirakahira ia dedi.  
\q1 Lauegu kamonai be ia manoka lao,  
\q1 bona egu abidadama be kahirakahira ia ore.   
\q1
\v 3 Badina be lau itaia,  
\q1 tau dikadia ese moni bona kohu momo idia abia,  
\q1 bona hekokoroku taudia idia kwalimu,  
\q1 vadaeni lau mama henidia.   
\q1
\v 4 Idia be mai edia hisihisi lasi,  
\q1 bona edia tauanina be goada, bona mai edia dika ta lasi.   
\q1
\v 5 Idia be hisihisi lasi, haida bamona lasi,  
\q1 bona gorere idia davaria lasi,  
\q1 taunimanima haida idia davaria bamona.   
\q1
\v 6 Unai dainai hekokoroku idia atoa,  
\q1 ageva idia atoa bamona,  
\q1 bona dagedage idia karaia noho,  
\q1 dabua idia karaia bamona.   
\q1
\v 7 Edia kudouna bona edia laloa dekena amo,  
\q1 dika idia havaraia noho,  
\q1 edia ura dikadia dainai.   
\q1
\v 8 Idia ese tau haida idia kirikirilaia mai hevaseha danu,  
\q1 badu herevadia danu idia gwauraia noho.  
\q1 Idia be hekokoroku,  
\q1 bona dala idia tahua noho,  
\q1 tau haida do idia hadikaia totona.   
\q1
\v 9 Idia ese guba dekenai ia noho Dirava idia hereva dika henia.  
\q1 Mai hekokoroku danu,  
\q1 idia ese taunimanima idia oda henidia.   
\q1
\v 10 Unai dainai Dirava ena taudia haida ese,  
\q1 idia dekenai idia kamonai henia,  
\q1 bona edia hereva kerere idia abidadama henia.   
\q1
\v 11 Unai tau dikadia be inai bamona idia hereva, idia gwau,  
\q1 “Dirava be edena bamona do ia diba?  
\q1 Siahu Ibounai Diravana dekenai be aonega ia noho, a?”   
\q1
\v 12 Tau dikadia edia kara be unai bamona.  
\q1 Idia be mai edia kohu momo,  
\q1 bona nega ibounai kohu ma haida idia abia noho.   
\b  
\q1
\v 13 Lau ese lau kara kava, a?  
\q1 Nega ibounai lauegu lalona lau hagoevaia,  
\q1 bona kara dika ta lau karaia lasi.  
\q1 Inai kara dekena amo namo ta lau davaria, a?   
\q1
\v 14 Badina be dina ibounai lau hisihisi noho,  
\q1 bona daba ibounai, matakani lau davaria noho.   
\q1
\v 15 Bema lau ese,  
\q1 tau dikadia edia hereva bamona hereva lau gwauraia neganai,  
\q1 lau ese oiemu taudia edia mauri do lau hadikaia,  
\q1 bona edia laloa do lau hakererea.   
\q1
\v 16 Lau ese unai tau dikadia edia kara bona kwalimu,  
\q1 dekenai lau laloa momo,  
\q1 to ia auka dainai,  
\q1 lau be hegeregere lasi laloa maoro do lau davaria,   
\q1
\v 17 ela bona Dirava ena Dubu Helaga dekenai lau vareai lao.  
\q1 Unai neganai tau dikadia edia dokona lau diba.   
\b  
\q1
\v 18 Momokani oi ese dedidedi gabudia dekenai idia do oi atoa,  
\q1 bona mase gabuna dekenai idia do oi hamorua.   
\q1
\v 19 Oi ese do oi hamasedia haraga,  
\q1 bona inai mase be do ia dika momokani.   
\q1
\v 20 Idia be hegeregere tau ta ia nihi,  
\q1 bona dabai ia noga neganai nihi be ia ore kava.  
\q1 Lohiabada e, do oi toreisi neganai,  
\q1 unai taudia be do idia boio momokani.   
\q1
\v 21 Lohiabada e, lauegu laloa be dika momokani neganai,  
\q1 bona lalohisihisi ena mamina lau abia momokani neganai,   
\q1
\v 22 lauegu laloa be kavakava,  
\q1 boroma edia laloa bamona oiemu vairana dekenai,  
\q1 bona oiemu dala ena diba lau davaria diba lasi.   
\b  
\q1
\v 23 To lau be nega ibounai oi kahirakahira lau noho,  
\q1 bona oi ese egu imana oi dogoatao noho.   
\q1
\v 24 Oi ese oiemu sisiba dekena amo lau oi hakaua noho.  
\q1 Dokona neganai oi ese lau do oi abia dae,  
\q1 guba ena hairai dekenai.   
\q1
\v 25 Guba dekenai dahaka do lau davaria?  
\q1 Oi sibona, ani?  
\q1 Unai dainai tanobada dekenai,  
\q1 gau ta lau ura henia lasi, oi sibona.   
\q1
\v 26 Egu tauanina bona egu lalona be sedira do idia manoka,  
\q1 to Dirava be lauegu goada.  
\q1 Bema Dirava be lau dekenai ia noho neganai,  
\q1 lau be hegeregere momokani ela bona hanaihanai.   
\b  
\q1
\v 27 Dirava e, oi idia rakatania taudia,  
\q1 be momokani do idia mase ore.  
\q1 Bona oi dekenai idia abidadama,  
\q1 to edia abidadama idia rakatania taudia, be oi ese do oi hamasedia.   
\q1
\v 28 To lau be Dirava badibadinai lau noho.  
\q1 Inai be namo herea momokani.  
\q1 Siahu Ibounai Lohiabada e,  
\q1 oi be lauegu magu momokani.  
\q1 Hari lau ura oiemu kara ibounai do lau gwauraia hedinarai.   
\c 74  
\s1 Idau bese taudia ese Israela idia hadikaia dainai, Dirava dekenai tau ta ia noinoi  
\q1
\v 1 Dirava e,  
\q1 badina dahaka oi ese inai bamona ai oi rakatania vadaeni?  
\q1 Oi ese oiemu bese taudia do oi badu henia noho,  
\q1 ela bona edena negai?   
\q1
\v 2 Oiemu orea, idaunegai oi abia hidi,  
\q1 oi sibona oiemu bese,  
\q1 be mani do oi laloatao.  
\q1 Oi ese hesiai mai guia danu dekena amo inai bese oi hamauria,  
\q1 oiemu bese korikori do oi halaoa totona.  
\q1 Siona Ororo, guna oi noho gabuna, mani do oi laloa.   
\b  
\q1
\v 3 Ai idia tuari henia taudia ese,  
\q1 idia hadikaia ore vadaeni gaudia be do oi raka hanaia.  
\q1 Idia ese Dubu Helaga lalonai idia noho kohu ibounai,  
\q1 be idia hadikaia ore.   
\q1
\v 4 Oi dekenai idia tuari henia taudia ese,  
\q1 oiemu Dubu Helaga lalonai idia boiboi bada vadaeni,  
\q1 idia kwalimu dainai.  
\q1 Idia edia pepe be Dubu Helaga lalonai idia atoa,  
\q1 edia kwalimu toana.   
\q1
\v 5 Idia edia kara be au utua taudia bamona,  
\q1 edia ira dekena amo au idia utua diho bamona.   
\q1
\v 6 Idia ese Dubu Helaga ena au namodia,  
\q1 koroa vadaeni gaudia,  
\q1 be edia ira bona hama dekena amo idia hamakohia.   
\q1
\v 7 Oiemu Dubu Helaga idia hadikaia,  
\q1 bona idia gabua ore.  
\q1 Oiemu ladana ia noho gabuna be idia hamiroa vadaeni.   
\q1
\v 8 Idia ese sibodia ta ta dekenai idia hereva, idia gwau,  
\q1 “Ita ese idia do ita halusia momokani.”  
\q1 Idia ese Dirava ena helaga gabudia ibounai idia gabua ore,  
\q1 tano ena kahana ibounai dekenai.   
\b  
\q1
\v 9 Aiemai toa helagadia be idia boio vadaeni.  
\q1 Aiemai peroveta tauna ta be lasi,  
\q1 bona inai nega dika ena daudau be tau ta ia diba lasi.   
\q1
\v 10 Dirava e, oi dekenai idia tuari henia taudia ese,  
\q1 oi dekenai do idia kirikiri ela bona edena negai?  
\q1 Idia ese oiemu ladana do idia hadikaia hanaihanai, a?   
\q1
\v 11 Badina dahaka ai durua totona kara ta oi karaia lasi?  
\q1 Badina dahaka oiemu imana,  
\q1 be oiemu dabua lalonai oi hunia noho?   
\b  
\q1
\v 12 To Dirava e, idaunegai ia mai bona hari oi be aiemai King.  
\q1 Oi ese nega momo ai oi hamauria vadaeni.   
\q1
\v 13 Oiemu siahu bona goada dekena amo davara oi hapararaia,  
\q1 bona davara ena gwarume badadia momokani edia kwaradia,  
\q1 be oi ese oi hamakohia.   
\q1
\v 14 Oi ese unai huala badana,  
\q1 ladana Leviatano ena kwarana momo oi hamakohia,  
\q1 bona iena tauanina,  
\q1 be tano kaukau idia noho taudia dekenai oi henia, edia aniani.   
\q1
\v 15 Oi ese tano oi hapararaia,  
\q1 ranu do ia lohilohi, bona do ia heau lao totona,  
\q1 bona nega daudau idia heau vadaeni sinavai,  
\q1 be oi ese oi hakaukaua.   
\q1
\v 16 Oi ese dina bona hanuaboi oi karaia.  
\q1 Oi ese dina bona hua,  
\q1 be edia gabu dekenai oi atodia.   
\q1
\v 17 Oi ese tano edia hetoa ibounai oi karaia.  
\q1 Oi ese lahara ena nega, bona laurabada ena nega danu oi karaia.   
\b  
\q1
\v 18 To Lohiabada e, oi dekenai idia tuari noho taudia ese,  
\q1 oi dekenai idia kirikiri be mani do oi laloa.  
\q1 Oi dekenai idia gari lasi bese taudia ese,  
\q1 oiemu ladana idia hadikaia noho.   
\q1
\v 19 Mani emu kara, oiemu bese taudia do oi rakatania lasi.  
\q1 Dagedage taudia ese ai idia hadikaia noho,  
\q1 be do oi laloaboio lasi.   
\q1
\v 20 Oiemu gwauhamata taravatuna,  
\q1 ai danu oi karaia gauna do oi laloatao noho.  
\q1 Badina be inai tano ena dibura gabudia ibounai dekenai,  
\q1 dagedage karadia idia vara noho.   
\q1
\v 21 Idia dagedage henidia vadaeni taudia mani do oi durua,  
\q1 hemarai do idia abia lasi.  
\q1 Do oi durudia,  
\q1 vadaeni ogogami taudia bona mai edia gau lasi taudia,  
\q1 ese oiemu ladana do idia hanamoa.   
\q1
\v 22 Dirava e, oi toreisi,  
\q1 oiemu kara maoromaoro dainai, unai tau dikadia do oi kota henidia.  
\q1 Dina ena nega ibounai oi dekenai idia matauraia lasi,  
\q1 bona oi dekenai idia kiri taudia be do oi laloatao.   
\q1
\v 23 Oi dekenai idia tuari henia taudia edia boiboi,  
\q1 be do oi laloaboio lasi.  
\q1 Oi dekenai idia dagedage taudia edia regena,  
\q1 be nega ibounai idia karaia noho.   
\c 75  
\s1 Dirava be Kota Biaguna Badana  
\q1
\v 1 Dirava e,  
\q1 ai ese oi dekenai tanikiu ai henia noho,  
\q1 oi dekenai ai hanamoa noho.  
\q1 Oiemu ladana badana ai gwauraia hedinarai noho.  
\q1 Ai ese oiemu hoa karadia ai herevalaia noho.   
\b  
\q1
\v 2 Dirava ia gwau,  
\q1 “Lau ese kota henia dinana lau gwauraia vadaeni,  
\q1 bona unai dina do ia ginidae neganai,  
\q1 lau ese mai maoromaoro danu kota hereva do lau gwauraia.   
\q1
\v 3 Tanobada bona ia dekenai noho taudia be do idia heudeheude,  
\q1 to lau ese tanobada ena badina nadidia do lau hagoadaia noho.   
\q1
\v 4 Lau ese hekokoroku taudia lau hamaoroa noho, lau gwau,  
\q1 ‘Do umui hekokoroku lou lasi.’  
\q1 Bona kara dika taudia lau hamaoroa noho, lau gwau,  
\q1 ‘Do umui dagedage lasi.   
\q1
\v 5 Guba taudia dekenai do umui dagedage lasi.  
\q1 Emui hekokoroku do umui hadokoa.’ ”   
\b  
\q1
\v 6 Dina daekau kahana,  
\q1 dina diho kahana, o tano kaukau,  
\q1 o tanobada ena kahana ta ese,  
\q1 tau ta ena mauri ia hanamoa diba, a?  
\q1 Lasi momokani!   
\q1
\v 7 Dirava sibona be Kota Biaguna momokani.  
\q1 Ia sibona ese tau ta ia atoa diho noho,  
\q1 ma ia ese tau ta ia abia isi noho.   
\q1
\v 8 Badina be Lohiabada ese,  
\q1 kapusi ta iena imana dekenai ia dogoatao noho.  
\q1 Unai kapusi lalonai,  
\q1 be Lohiabada ena badu ena uaina aukana ia noho.  
\q1 Ia ese uaina ia bubua noho,  
\q1 bona tanobada ena kara dika taudia ibounai ese do idia inua ore.   
\b  
\q1
\v 9 To lau ese Dirava do lau hanamoa ela bona hanaihanai.  
\q1 Iakobo ena Dirava hanamoa anedia,  
\q1 be do lau abia nega ibounai.   
\q1
\v 10 Kara dika taudia ibounai edia siahu bona goada,  
\q1 be Dirava ese do ia hamakohia.  
\q1 To kara maoromaoro taudia edia siahu bona edia goada,  
\q1 be Dirava ese do ia habadaia.   
\c 76  
\s1 Israela ena Dirava ena ladana be bada  
\q1
\v 1 Iuda dekenai noho taudia be Dirava idia diba.  
\q1 Dirava ena ladana be bada Israela dekenai.   
\q1
\v 2 Iena noho gabuna be Ierusalema dekenai.  
\q1 Siona Ororo dekenai iena Ruma ia haginia vadaeni.   
\q1
\v 3 Unuseni ia ese ia dekenai idia tuari henia taudia,  
\q1 edia peva bona diba ia hamakohia.  
\q1 Edia kesi bona tuari kaia,  
\q1 edia tuari gaudia ibounai danu,  
\q1 be Dirava ese ia makohia.   
\b  
\q1
\v 4 Dirava e, oi be namo herea momokani.  
\q1 Oiemu hairaina ese,  
\q1 noho hanaihanai ororo edia hairaina ia hereaia noho.   
\q1
\v 5 Goada taudia ese edia tuari dekena amo idia abia kohu,  
\q1 be haida ese idia abia,  
\q1 bona unai goada taudia,  
\q1 be mase ena mahuta ese ia abidia vadaeni.  
\q1 Idia edia siahu be anina lasi, bona edia goada be ia ore vadaeni.   
\q1
\v 6 Iakobo ena Dirava e,  
\q1 oi ese oi gwau henidia neganai,  
\q1 hosi mai edia guia taudia danu idia mase ore.   
\q1
\v 7 To taunimanima ibounai ese oi idia gari henia noho.  
\q1 Oi be oi badu momokani neganai,  
\q1 daika ese oiemu vairana dekenai do ia gini diba?   
\q1
\v 8 Guba dekena amo oiemu kota hereva oi gwauraia,  
\q1 vadaeni tanobada taudia be idia gari bada,  
\q1 bona mai regena ta lasi oiemu vairana dekenai idia gini noho.   
\q1
\v 9 Unai neganai Dirava ia toreisi,  
\q1 kota hereva do ia gwauraia totona,  
\q1 bona tanobada dekenai idia hisihisi noho taudia ibounai,  
\q1 be do ia hamauria totona.   
\q1
\v 10 Momokani taunimanima edia badu ese oi ia hanamoa noho,  
\q1 bona oiemu badu ia ore murinai do mauri noho taudia ese,  
\q1 oi do idia tomadiho henia.   
\b  
\q1
\v 11 Emui Dirava, Lohiabada, dekenai gwauhamata do umui henia,  
\q1 bona gwauhamata ena anina do umui karaia.  
\q1 Dirava umui hagegea noho taudia ibounai ese,  
\q1 ia dekenai harihari gaudia do umui henia be namo,  
\q1 badina ia dekenai taunimanima idia gari noho.   
\q1
\v 12 Dirava ese,  
\q1 lohia taudia edia hekokoroku bona dagedage ia hadokoa noho,  
\q1 bona tanobada ena king taudia ese,  
\q1 Dirava dekenai idia gari henia noho.   
\c 77  
\s1 Dirava ese Israela ia durua dainai ia ese lauegu hisihisi do ia hanamoa  
\q1
\v 1 Dirava dekenai lau tai,  
\q1 ia ese lau do ia durua totona.  
\q1 Dirava dekenai lau tai,  
\q1 mai boiboi danu,  
\q1 bona ia ese lau dekenai ia kamonai.   
\q1
\v 2 Egu hekwarahi neganai lau ese Lohiabada dekenai lau guriguri.  
\q1 Hanuaboi ena hora ibounai,  
\q1 lau ese egu imana lau abia isi, lau guriguri noho,  
\q1 egu lauma ese laga-ani ia ura lasi.   
\q1
\v 3 Dirava e,  
\q1 oi lau laloa neganai lalohisihisi dainai lau hahodi haraga lasi.  
\q1 Egu hisihisi lau laloa noho neganai,  
\q1 egu lauma be goada ia davaria lasi.   
\q1
\v 4 Dirava e,  
\q1 oi ese egu mahuta dalana oi koua.  
\q1 Egu laloa hekwarahi be bada dainai lau hereva diba lasi.   
\q1
\v 5 Dina gunadia lau laloa,  
\q1 bona lagani, idia ore gaudia,  
\q1 be lau laloatao.   
\q1
\v 6 Hanuaboi neganai egu lalona lau tahua.  
\q1 Lau laloa namonamo,  
\q1 bona egu lauma lau tahua.   
\b  
\q1
\v 7 Lau sibona dekenai lau nanadaia, lau gwau,  
\q1 “Lohiabada ese nega ibounai ita do ia negea noho, a?  
\q1 Ia ese nega ta ma,  
\q1 be ita dekenai do ia laloa namo lou, a?   
\q1
\v 8 Iena noho hanaihanai lalokauna,  
\q1 be ita dekena amo ia hadokoa, a?  
\q1 Iena gwauhamata be ia gini noho lasi, a?   
\q1
\v 9 Dirava ese iena bogahisihisi ia laloaboio vadaeni, a?  
\q1 Iena badu ese iena lalokau ena gabu ia abia vadaeni, a?”   
\b  
\q1
\v 10 Unai neganai lau gwau,  
\q1 “Egu lalohisihisi ena anina korikori be inai:  
\q1 Dirava ena siahu be ia ore vadaeni, a?”   
\q1
\v 11 To Lohiabada e,  
\q1 lau ese oiemu kara do lau laloa noho.  
\q1 Oiemu hoa karadia gunadia do lau laloa lou.   
\q1
\v 12 Oiemu gaukara ibounai do lau laloa noho,  
\q1 bona oiemu siahu karadia danu do lau laloa.   
\b  
\q1
\v 13 Dirava e, oiemu kara ibounai be helaga.  
\q1 Edena dirava ena goada be oiemu goada hegeregerena?   
\q1
\v 14 Hoa karadia ia karaia diba Diravana be oi.  
\q1 Oi ese oiemu siahu,  
\q1 be bese idauidau edia huanai oi hedinaraia vadaeni.   
\q1
\v 15 Oiemu siahu dekena amo oiemu bese taudia oi hamauria.  
\q1 Idia be Iakobo bona Iosepa edia bese taudia.   
\b  
\q1
\v 16 Dirava e,  
\q1 ranu gabudia ese oi idia itaia neganai idia gari,  
\q1 bona davara dobu gabudia idia heudeheude.   
\q1
\v 17 Ori ese medu idia siaia diho.  
\q1 Guba danu ia boiboi,  
\q1 bona oiemu kevaru be kahana ibounai dekena amo ia diari.   
\q1
\v 18 Oi ese guba ena boiboi oi havaraia haraga koehirihiri lalonai,  
\q1 bona kevaru ese tanobada ia hadiaria.  
\q1 Tanobada ia mareremarere bona ia heudeheude.   
\q1
\v 19 Oi ese davara ena hurehure edia huana dekenai oi raka.  
\q1 Oi ese davara dobu oi raka hanaia,  
\q1 to oiemu aena gabudia,  
\q1 be tau ta ese ia itaia lasi.   
\q1
\v 20 Oi ese mamoe naria tauna bamona oiemu bese taudia oi hakaua.  
\q1 Mose bona Arona edia imadia dekena amo,  
\q1 oi ese oiemu bese taudia oi hakaua.   
\c 78  
\s1 Dirava ese iena bese Israela ia durua  
\q1
\v 1 Egu bese taudia e, egu hadibaia hereva do umui kamonai.  
\q1 Egu uduna ena hereva do umui kamonai.   
\q1
\v 2 Aonega herevadia do lau gwauraia,  
\q1 bona sene taudia edia hunia herevadia edia anina,  
\q1 be do lau gwauraia hedinarai.   
\q1
\v 3 Ai ese ai kamonai bona diba,  
\q1 aiemai tamadia ese ai dekenai idia hamaoroa gaudia,  
\q1 be do lau gwauraia.   
\q1
\v 4 Aiemai natudia dekena amo inai sivarai ai hunia lasi,  
\q1 to Lohiabada ena siahu karadia bona iena hoa karadia,  
\q1 be gabeai idia vara bese taudia dekenai do ai hamaoroa.   
\q1
\v 5 Dirava ese Israela taudia dekenai taravatu ia henia,  
\q1 bona oda danu,  
\q1 be Iakobo ena bese taudia dekenai ia henia.  
\q1 Ia ese iseda sene taudia ia hamaoroa,  
\q1 iena taravatu be edia natudia dekenai do idia hadibaia.   
\q1
\v 6 Unai dekena amo gabeai do idia vara bese taudia ese,  
\q1 inai taravatu do idia diba,  
\q1 bona idia ese edia natudia dekenai ma do idia hadibaia.   
\q1
\v 7 Bona unai dala dekenai,  
\q1 edia natudia ese Dirava do idia abidadama henia,  
\q1 bona iena kara do idia laloaboio lasi,  
\q1 to iena taravatu do idia kamonai henia nega ibounai.   
\q1
\v 8 Unai dekena amo danu edia tamadia,  
\q1 unai laloa auka bona kamonai lasi taudia,  
\q1 edia kara hegeregerena do idia karaia lasi.  
\q1 Unai edia tamadia edia abidadama be goada momokani lasi,  
\q1 bona idia ese Dirava idia badinaia momokani lasi.   
\b  
\q1
\v 9 Eparaima taudia, be mai edia peva bona diba edia imadia dekenai,  
\q1 to idia be tuari dinana dekenai idia heau lou.   
\q1
\v 10 Idia ese Dirava ena gwauhamata idia badinaia lasi,  
\q1 bona iena taravatu kamonai henia kara idia negea.   
\q1
\v 11 Dirava ena kara be idia laloaboio,  
\q1 bona iena hoa karadia ia hedinaraia gaudia danu,  
\q1 be idia laloaboio.   
\q1
\v 12 Edia sene taudia be,  
\q1 edia matadia dekenai unai hoa karadia idia itaia,  
\q1 Aigupito tano dekenai bona Soana tano palaka dekenai danu.   
\q1
\v 13 Dirava ese danu davara ia hapararaia,  
\q1 bona idia ese idia raka hanaia.  
\q1 Ia ese ranu ia haginia, magu ruaosi bamona.   
\q1
\v 14 Dina dekenai ia ese ori korema dekena amo ia hakaudia,  
\q1 bona hanuaboi ena nega ibounai,  
\q1 be lahi ena diari dekena amo ia hakaudia.   
\q1
\v 15 Taunimanima idia noho lasi tano dekenai,  
\q1 Dirava ese nadi ia hapararaia,  
\q1 bona inua ranu be idia dekenai ia henia,  
\q1 dobu gabudia dekena amo.   
\q1
\v 16 Dirava ese danu nadi dekena amo ranu ia mailaia.  
\q1 Inai ranu be ia heau lao, sinavai bamona.   
\b  
\q1
\v 17 To idia ese edia kara dika Dirava dekenai idia karaia noho.  
\q1 Tano kaukau dekenai,  
\q1 Ataiai Herea Dirava dekenai idia dagedage henia.   
\q1
\v 18 Idia ese Dirava idia tohoa.  
\q1 Idia ese idia ura aniani be Dirava dekena amo idia gwauraia.   
\q1
\v 19 Idia ese Dirava idia hereva dika henia, idia gwau,  
\q1 “Dirava ese tano kaukau dekenai,  
\q1 aniani patana ia abia hegaegae diba, a?”   
\q1
\v 20 Idia gwau, “Momokani, nadi ia botaia neganai,  
\q1 ranu ia bubua diho bada herea,  
\q1 to Dirava ese aniani do ia henia diba,  
\q1 bona iena bese taudia dekenai vamu do ia henia diba, a?”   
\q1
\v 21 Lohiabada ese edia hereva badubadu ia kamonai neganai ia badu.  
\q1 Ia ese iena bese taudia lahi dekena amo ia hadikadia.  
\q1 Iena badu be Israela taudia dekenai ia bada lao,   
\q1
\v 22 badina idia ese ia dekenai idia abidadama henia lasi,  
\q1 bona idia ese Dirava ena hamauria siahuna idia hamomokania lasi.   
\q1
\v 23 To Dirava ese guba ataiai dekenai ia hereva henia,  
\q1 ia ese guba ena iduara ia kehoa.   
\q1
\v 24 Bona ia ese mana aniani,  
\q1 be guba dekena amo ia siaia diho.  
\q1 Ia ese guba ena aniani iena bese taudia dekenai ia henia,  
\q1 do idia ania totona.   
\q1
\v 25 Vadaeni idia ese aneru ena aniani idia ania.  
\q1 Bona Dirava ese aniani bada ia siaia,  
\q1 edia ura hegeregerena momokani.   
\q1
\v 26 Dirava ese danu,  
\q1 dina ia daekau kahana dekena amo lai ia havaraia,  
\q1 bona iena siahu dekena amo,  
\q1 diho kahana dekena amo ma lai ta ia havaraia,   
\q1
\v 27 bona iena bese taudia dekenai roho manudia ia siaia diho,  
\q1 momo herea, kone ena miri bamona.   
\q1
\v 28 Edia kamepa ena huana dekenai idia moru diho,  
\q1 edia noho palai rumadia idia hagegea.   
\q1
\v 29 Unai dainai taunimanima idia aniani,  
\q1 bona edia bogadia idia kunu.  
\q1 Dirava ese idia ura gaudia ia henidia.   
\q1
\v 30 To idia ura dikadika aniani idia do ania noho neganai,  
\q1 aniani be do ududia edia lalonai,   
\q1
\v 31 be Dirava ese idia dekenai ia badu,  
\q1 bona edia goada herea taudia be ia ese ia alaia mase.  
\q1 Israela ena eregabe taudia,  
\q1 tau namo hereadia be Lohiabada ese ia hamasea.   
\b  
\q1
\v 32 Inai matakani be Dirava ese ia henidia,  
\q1 to idia be idia kara dika noho.  
\q1 Hoa karadia momo Dirava ese ia karaia,  
\q1 to idia ese ia dekenai idia abidadama henia lasi.   
\q1
\v 33 Unai dainai ia ese edia mauri ia hadokoa,  
\q1 hahodi tamona bamona.  
\q1 Edia mauri lagani,  
\q1 mai gari bada danu ia haorea haraga momokani.   
\q1
\v 34 Dirava ese idia haida ia alaia mase neganai,  
\q1 oredia ese ia dekenai idia giroa lou.  
\q1 Idia ese edia lalona idia giroa,  
\q1 bona ia dekenai idia giroa momokani.   
\q1
\v 35 Idia laloa lou,  
\q1 Dirava be idia edia Nadi Badana.  
\q1 Bona idia laloa lou,  
\q1 Siahu Ibounai Dirava be edia hamauria Tauna.   
\b  
\q1
\v 36 To edia hereva ibounai be koikoi sibona.  
\q1 Idia ese Dirava idia hanamoa koikoi.   
\q1
\v 37 Idia be Dirava dekenai idia giroa momokani lasi,  
\q1 bona edia gwauhamata ena anina ia dekenai idia karaia lasi.   
\q1
\v 38 To Dirava ese,  
\q1 iena bese taudia dekenai ia bogahisihisi henia.  
\q1 Idia edia kara dika ia gwauatao,  
\q1 bona ia ese idia ia hadikaia ore lasi.  
\q1 Nega momo ia ese iena badu ia hakerua,  
\q1 bona iena badu ena siahu momokani ia havaraia lasi.   
\q1
\v 39 Ia laloatao, idia be taunimanima sibona.  
\q1 Idia be lai bamona,  
\q1 nega tamona sibona ia toa,  
\q1 bona ia toa lou lasi.   
\b  
\q1
\v 40 Nega momo, taunimanima idia noho lasi tano dekenai,  
\q1 iena bese taudia ese Dirava idia kamonai henia lasi,  
\q1 mai dagedage danu.  
\q1 Io, nega momo tano kaukau dekenai,  
\q1 idia ese Dirava ena lalona idia hisihisi henia.   
\q1
\v 41 Dirava ena bogahisihisi idia tohoa lou, tohoa lou,  
\q1 bona idia ese Israela edia Helaga Dirava idia habadua.   
\q1
\v 42 Iena siahu bada herea be idia laloaboio.  
\q1 Dirava ese dagedage taudia dekena amo ia hamauridia dinana,  
\q1 be idia ese idia laloaboio.   
\q1
\v 43 Unai dina dekenai,  
\q1 Dirava ese Aigupito dekenai kara badadia ia karaia,  
\q1 bona hoa karadia danu Soana tano palaka dekenai ia karaia.   
\q1
\v 44 Aigupito edia sinavai be rara dekenai ia halaoa,  
\q1 bona Aigupito taudia,  
\q1 be sinavai edia ranu idia inua diba lasi.   
\q1
\v 45 Dirava ese lao momo herea idia edia huanai ia siaia,  
\q1 bona idia hisihisi henidia.  
\q1 Paroparo danu be ia ese ia siaia, edia tano idia hadikaia.   
\q1
\v 46 Dirava ese danu kwadi momo herea ia siaia,  
\q1 edia uma edia anina idia ania ore.   
\q1
\v 47 Edia vain huahua be medu,  
\q1 aisi nadi bamona, dekena amo ia hadikaia ore,  
\q1 bona edia fig audia be keru dekena amo idia mase ore.   
\q1
\v 48 Edia boromakau be medu,  
\q1 aisi nadi bamona, dekena amo ia aladia ore,  
\q1 bona edia mamoe danu,  
\q1 be kevaru dekena amo ia aladia ore.   
\q1
\v 49 Ia ese iena badu bona iena dagedage,  
\q1 be idia edia latanai ia bubua diho.  
\q1 Ia ese idia ia hisihisi henidia momokani.  
\q1 Iena mase havaraia aneru orea ta idia dekenai ia siaia.   
\q1
\v 50 Iena badu be ia ese ia hakerua lasi.  
\q1 Mase dekena amo ia hamauridia lasi.  
\q1 To ia ese hanaia gorere dikana dekena amo ia aladia mase.   
\q1
\v 51 Aigupito taudia edia vara guna natudia tau ibounai,  
\q1 be Dirava ese ia aladia mase,  
\q1 Hamo bese ena vara guna natudia tau ibounai.   
\q1
\v 52 Unai neganai Dirava ese iena bese taudia ia hakaua mai,  
\q1 mamoe naria tauna ese iena mamoe ia hakaua bamona.  
\q1 Ia ese taunimanima idia noho lasi tano kaukau dekenai,  
\q1 ia hakaudia, idia raka hanaia.   
\q1
\v 53 Dala namona dekenai ia hakaudia,  
\q1 vadaeni idia gari lasi.  
\q1 To idia dekenai idia tuari henia taudia,  
\q1 be Dirava ese davara ena lalonai ia hamasedia.   
\q1
\v 54 Dirava ese iena bese taudia ia hakaua,  
\q1 ela bona iena tano helagana dekenai idia ginidae.  
\q1 Unai ororo be ia sibona ese,  
\q1 tuari ena kwalimu dekena amo ia abia guna vadaeni.   
\q1
\v 55 Iena bese taudia idia raka hanaia neganai,  
\q1 unai tano noho taudia be Dirava ese ia luludia ore,  
\q1 bona edia tano be Israela iduhu ta ta edia huanai ia haria.  
\q1 Edia ruma be Israela taudia dekenai ia henia.   
\b  
\q1
\v 56 To Israela taudia ese Siahu Ibounai Dirava idia tohoa,  
\q1 bona idia kamonai henia lasi.  
\q1 Idia ese iena taravatu idia utua.   
\q1
\v 57 Mai hekokoroku danu Dirava ena hereva idia utua,  
\q1 edia tamadia hegeregerena.  
\q1 Idia edia kara be gagevagageva, peva gagevagagevana bamona.   
\q1
\v 58 Idia ese dirava koikoidia dekenai boubou patadia idia haginia,  
\q1 ma unai dainai Dirava ia badu.  
\q1 Bona idia ese idia koroa kaivakuku gaudia dekena amo,  
\q1 Dirava idia habadua.   
\q1
\v 59 Inai bamona idia karaia,  
\q1 be Dirava ese ia itaia neganai, ia badu mai siahu danu.  
\q1 Unai dainai ia ese Israela taudia ia negea momokani.   
\q1
\v 60 Vadaeni Dirava ese iena Palai Dubu,  
\q1 Silo dekenai ia noho gauna ia rakatania.  
\q1 Unai Silo Palai Dubu,  
\q1 be taunimanima edia huanai Dirava ia noho guna gauna.   
\q1
\v 61 Bona Dirava ese,  
\q1 Israela taudia dekenai idia tuari henia taudia ia koua lasi,  
\q1 unai dainai idia ese Taravatu Maua idia abia.  
\q1 Inai Taravatu Maua,  
\q1 be Dirava ena siahu bona iena hairaina ena toana.   
\q1
\v 62 Io, Dirava ese iena bese korikori taudia dekenai ia badu,  
\q1 bona idia dekenai idia tuari henia taudia ia koua lasi,  
\q1 unai dainai Israela taudia momo idia mase.   
\q1
\v 63 Tuari dekenai Israela uhau taudia momo idia mase,  
\q1 bona edia kekeni be mai edia headava dalana lasi,  
\q1 uhau taudia lasi dainai.   
\q1
\v 64 Unai idau bese tuari taudia ese,  
\q1 Israela hahelagaia taudia idia alaia mase,  
\q1 bona edia vabu idia taravatua,  
\q1 edia tau totona do idia taitai lasi.   
\b  
\q1
\v 65 Vadaeni Lohiabada be mahuta dekena amo ia noga,  
\q1 goada tauna uaina ia inua dainai ia boiboi bamona.   
\q1
\v 66 Ia ese ia dekenai idia tuari henia taudia ia tuari henidia,  
\q1 ia ese idia ia lulua ore.  
\q1 Ia luludia ore, ia halusidia momokani,  
\q1 mai edia hemarai danu.   
\q1
\v 67 To ia ese Iosepa ena bese taudia ia ura lasi, ia negea,  
\q1 bona Eparaima iduhu danu ia abia hidi lasi.   
\q1
\v 68 To ia ese Iuda iduhu ia abia hidi, sibona ena,  
\q1 bona Siona Ororo,  
\q1 ia ura henia bada gabuna,  
\q1 danu ia abia hidi.   
\q1
\v 69 Unuseni iena Dubu Helaga ia haginia, iena ruma,  
\q1 guba dekenai ia noho ena toana bamona.  
\q1 Ia ese inai Dubu Helaga ia haginia goada,  
\q1 do ia noho hanaihanai totona,  
\q1 tanobada ena goada bamona.   
\q1
\v 70 Bona Dirava ese iena hesiai tauna Davida ia abia hidi.  
\q1 Ia ese mamoe edia magudia dekena amo Davida ia abia.   
\q1
\v 71 Unuseni Davida ese mamoe naria gaukara ia karaia.  
\q1 Bona Dirava ese Israela taudia edia king dagi,  
\q1 be Davida dekenai ia henia.  
\q1 Vadaeni Davida be Dirava ena bese taudia, iena mamoe,  
\q1 edia naria tauna ia lao.   
\q1
\v 72 Davida ese idia ia naria namonamo,  
\q1 mai laloa maoromaoro, bona lalokau korikori danu.  
\q1 Bona mai aonega momokani danu,  
\q1 Davida ese Israela taudia ia hakaudia.   
\c 79  
\s1 Ierusalema idia hadikaia murinai, tau ta ese ia guriguri, mai ena lalohisihisi danu  
\q1
\v 1 Dirava e,  
\q1 idau bese taudia ese oiemu tano idia tuari henia vadaeni.  
\q1 Oiemu Dubu Helaga idia hamiroa vadaeni.  
\q1 Ierusalema idia hadikaia momokani.   
\q1
\v 2 Oiemu bese taudia edia mase tauanidia,  
\q1 be ataiai manudia dekenai idia henia vadaeni, idia ania totona,  
\q1 bona oiemu hesiai taudia edia hidiona,  
\q1 be uda boromadia edia aniani totona idia negea vadaeni.   
\q1
\v 3 Oiemu bese taudia edia rarana,  
\q1 be Ierusalema ena kahana ibounai dekenai idia bubua vadaeni,  
\q1 ranu hegeregerena,  
\q1 bona mase taudia guria totona tau ta ia noho lasi.   
\q1
\v 4 Ai idia hagegea noho idau bese taudia,  
\q1 ese ai idia hereva dika henia noho.  
\q1 Ai dekenai idia kirikiri,  
\q1 bona ai dekenai idia hevaseha noho.   
\b  
\q1
\v 5 Lohiabada e,  
\q1 oi ese ai do oi badu henia noho,  
\q1 ela bona edena negai?  
\q1 Oiemu badu be lahi bamona,  
\q1 ai do ia gabua noho hanaihanai, a?   
\q1
\v 6 Mani emu kara idau bese taudia,  
\q1 oi idia tomadiho henia lasi besedia,  
\q1 edia latanai oiemu badu do oi atoa.  
\q1 Oi dekenai idia guriguri henia lasi taudia edia latanai,  
\q1 be oiemu badu do oi bubua.   
\q1
\v 7 Badina be idia ese,  
\q1 Iakobo ena bese taudia idia ania ore,  
\q1 bona Iakobo ena noho gabuna idia hadikaia ore.   
\q1
\v 8 Aiemai sene taudia edia kara dika ena davana,  
\q1 be mani emu kara ai dekenai do oi henia lasi.  
\q1 Oiemu bogahisihisi, mani emu kara,  
\q1 be ai dekenai do oi henia haraga,  
\q1 badina ai be ai dika momokani vadaeni.   
\b  
\q1
\v 9 Dirava e, mani ai do oi durua,  
\q1 ai do oi hamauria.  
\q1 Oiemu ladana ena hairaina dainai,  
\q1 ai do oi hamauria, bona aiemai kara dika do oi gwauatao.   
\q1
\v 10 Badina dahaka idau bese taudia,  
\q1 be inai bamona idia hereva diba, idia gwau,  
\q1 “Edia Dirava be edeseni?”  
\q1 Mani emu kara,  
\q1 oiemu hesiai taudia idia alaia noho idau bese taudia,  
\q1 edia kerere davana do oi henia.  
\q1 Aiemai vairana dekenai,  
\q1 oiemu hesiai taudia edia rarana ena davana mani do oi henia.   
\q1
\v 11 Idia guia vadaeni taudia edia taitai mani do oi kamonai,  
\q1 bona oiemu siahu badana dekena amo,  
\q1 kota dainai mase totona idia naria noho taudia,  
\q1 mani do oi hamauridia.   
\b  
\q1
\v 12 Lohiabada badana e,  
\q1 unai idau bese taudia ese oi dekenai idia hereva dika.  
\q1 Edia dika davana be nega 7 idia dekenai do oi henia lou.   
\q1
\v 13 Unai neganai, ai, oiemu bese taudia, oiemu mamoe,  
\q1 ese oi do ai hanamoa hanaihanai.  
\q1 Ai ese uru ta ela bona ma uru ta, oi do ai hanamoa,  
\q1 bona oi do ai tanikiu henia noho.   
\c 80  
\s1 Israela taudia be Dirava idia noia, ia ese Israela do ia haginia lou  
\q1
\v 1 Israela ena Naria Tauna e,  
\q1 do oi kamonai.  
\q1 Oi ese Israela taudia oi hakaua noho,  
\q1 mamoe naria tauna ese iena mamoe ia hakaua bamona.  
\q1 Aiemai noinoi mani do oi kamonai.  
\q1 Oi be oiemu terona dekenai oi helai noho,  
\q1 aneru edia ataiai dekenai.   
\q1
\v 2 Eparaima, Beniamina bona Manase iduhu dekenai do oi hedinarai,  
\q1 bona oiemu goada do oi hedinaraia.  
\q1 Ai hamauria totona do oi mai.   
\q1
\v 3 Dirava e, ai do oi abia dae lou!  
\q1 Ai dekenai do oi bogahisihisi,  
\q1 bona ai do oi durua,  
\q1 vadaeni mauri do ai abia.   
\b  
\q1
\v 4 Siahu Ibounai Diravana e,  
\q1 oiemu bese taudia edia guriguri dekenai,  
\q1 be do oi badu ela bona edena negai?   
\q1
\v 5 Oi ese aiemai taitai oi havaraia,  
\q1 bona aiemai matana ranu,  
\q1 be aniani bona inuinu gauna hegeregerena ai dekenai.   
\q1
\v 6 Oi ese idau bese taudia oi koua lasi,  
\q1 vadaeni idia ese tuari idia karaia noho,  
\q1 aiemai tano do idia abia totona,  
\q1 bona ai dekenai idia tuari taudia ese,  
\q1 ai dekenai idia hereva dika henia noho.   
\b  
\q1
\v 7 Siahu Ibounai Dirava e,  
\q1 ai do oi abia dae lou!  
\q1 Ai dekenai do oi bogahisihisi,  
\q1 bona ai do oi durua,  
\q1 vadaeni mauri do ai davaria!   
\b  
\q1
\v 8 Gunaguna oi ese vain ta Aigupito dekena amo oi mailaia,  
\q1 bona idau bese taudia be inai tano dekena amo oi lulua.  
\q1 Vadaeni inai vain be oi ese inai edia tano dekenai oi hadoa.   
\q1
\v 9 Tano oi geia hegaegae, vadaeni vain oi hadoa.  
\q1 Iena ramuna be idia diho dobu,  
\q1 bona vain ese tano ibounai ia koua.   
\q1
\v 10 Inai vain ese danu,  
\q1 ororo gabudia be iena kerumakeruma dekena amo ia koua.  
\q1 Iena rigi be bada,  
\q1 idia ese sida audia badadia edia rigi idia koua.   
\q1
\v 11 Inai vain ena rigina be lata herea idia lao,  
\q1 ela bona davara badana,  
\q1 ma ela bona Euperate Sinavai dekenai.   
\q1
\v 12 To badina dahaka oi ese vain uma ena magu oi makohia?  
\q1 Harihari raka hanaia taudia ibounai ese,  
\q1 vain ena huahua idia henaoa noho,   
\q1
\v 13 bona uda boroma ese vain auna idia makohia noho.  
\q1 Uda ena mauri gaudia ibounai be vain ese ia ubudia noho.   
\q1
\v 14 Siahu Ibounai Dirava e, mani emu kara ai dekenai do oi laloa.  
\q1 Oi be guba dekenai oi noho,  
\q1 mani oiemu matana ese ai do idia itaia.  
\q1 Mani oi diho mai,  
\q1 oiemu bese do oi hamauria.   
\q1
\v 15 Mani oi mai, inai vain, oi ese oi hadoa gauna do oi hamauria.  
\q1 Inai vain matamatana,  
\q1 oi ese oi hagoadaia herea gauna mani do oi durua.   
\b  
\q1
\v 16 Ai idia tuari henia taudia ese,  
\q1 inai vain be lahi dekenai idia gabua, bona idia utua diho.  
\q1 Mani idia dekenai do oi badu,  
\q1 bona oi ese idia do oi hadikaia ore.   
\q1
\v 17 Oi ese ai oi abia hidi vadaeni, oiemu bese korikori.  
\q1 Oi ese ai oi habadaia, bona oi ese ai oi hagoadaia momokani.  
\q1 Mani emu kara ai do oi naria,  
\q1 bona ai do oi durua.   
\q1
\v 18 Unai bamona oi karaia neganai,  
\q1 ai ese oi do ai rakatania lou lasi.  
\q1 Mauri ai dekenai do oi henia,  
\q1 vadaeni ai ese oiemu ladana do ai hanamoa bada.   
\b  
\q1
\v 19 Lohiabada e,  
\q1 Siahu Ibounai Diravana e, oi ese ai do oi hakaua lou.  
\q1 Ai dekenai oiemu bogahisihisi do oi hedinaraia,  
\q1 oi ese ai do oi hamauria.   
\c 81  
\s1 Dirava ese Israela ia sisiba henia  
\q1
\v 1 Dirava, iseda goada ena badina,  
\q1 ia hanamoa totona ane do ita abia,  
\q1 mai moale bona mai boiboi danu.  
\q1 Iakobo ena Dirava hanamoa totona ane do ita abia!   
\q1
\v 2 Ane ena tiuni do umui hamatamaia,  
\q1 bona tareko do umui botaia.  
\q1 Miusiki namona gita badadia bona gita maragidia dekenai,  
\q1 do umui gadaralaia.   
\b  
\q1
\v 3 Hua matamata bona hua ia bada ena aria totona,  
\q1 kibi do umui hiriria.   
\q1
\v 4 Inai be Israela taudia edia taravatu,  
\q1 Iakobo ena Dirava ese ita dekenai ia henia.   
\q1
\v 5 Gunaguna Dirava ese Aigupito ia tuari henia neganai,  
\q1 ia ese inai taravatu Israela taudia dekenai ia henia.   
\q1
\v 6 Lau ese gadona ta lau kamonai,  
\q1 to lau diba lasi daika ena.  
\q1 Ia ese inai bamona ia hereva, ia gwau,  
\q1 “Lau ese maduna metauna emui pagana dekena amo lau kokia,  
\q1 biriki nadi bosea umui huaia gaukara dekena amo,  
\q1 lau ese emui imana lau ruhaia,  
\q1 vadaeni bosea be tano dekenai umui atodia.   
\q1
\v 7 Hisihisi umui abia neganai lau dekenai umui boiboi,  
\q1 bona lau ese umui lau hamauria.  
\q1 Lau be guba ia boiboi ena hunia gabuna dekena amo,  
\q1 umui emui noinoi lau kamonai henia.  
\q1 Ma unai neganai danu Meriba ena ranu gabudia dekenai,  
\q1 umui emui abidadama lau tohoa.   
\b  
\q1
\v 8 “Egu bese taudia e, umui kamonai:  
\q1 Lau ura umui do lau sisiba henia.  
\q1 Israela taudia e, lau ura bada egu hereva do umui kamonai.   
\q1
\v 9 Umui ese idau bese taudia edia dirava koikoidia,  
\q1 do umui tomadiho henia lasi.  
\q1 Umui ese dirava idauna ta do umui badinaia lasi.   
\q1
\v 10 Lau sibona be Lohiabada, emui Dirava.  
\q1 Aigupito dekena amo umui lau hakaua mai.  
\q1 Umui ese emui uduna do umui kehoa,  
\q1 bona lau ese umui do lau ubua.   
\b  
\q1
\v 11 “To egu bese taudia ese lau dekenai idia kamonai lasi.  
\q1 Israela taudia ese lau idia kamonai henia lasi.   
\q1
\v 12 Unai dainai lau ese idia lau negea,  
\q1 idia sibona edia hekokoroku daladia do idia raka noho,  
\q1 bona idia sibona edia ura karadia do idia karaia.   
\b  
\q1
\v 13 “Egu ura bada be,  
\q1 egu bese taudia ese lau dekenai do idia kamonai,  
\q1 bona Israela taudia ese lau idia kamonai henia neganai,   
\q1
\v 14 lau ese idia dekenai idia tuari henia taudia,  
\q1 do lau halusia haraga.  
\q1 Idia ese idia tuari henia taudia,  
\q1 be lau danu ese do lau tuari henia,   
\q1
\v 15 bona lau dekenai idia badu taudia,  
\q1 be egu vairana dekenai do idia tomadiho.  
\q1 Ma edia matakani be do ia noho ela bona hanaihanai.   
\q1
\v 16 To uiti namo herea dekena amo umui do lau ubua,  
\q1 bona hani namona,  
\q1 nadi badana dekena amo gauna,  
\q1 umui dekenai do lau henia,  
\q1 do umui boga kunu.”   
\c 82  
\s1 Dirava be King Badana momokani, ta ese ia hereaia lasi  
\q1
\v 1 Dirava ese guba ena kota hebou gabuna lalonai,  
\q1 iena gabu dekenai ia gini noho.  
\q1 Guba ena lohia taudia idia haboua,  
\q1 bona Dirava ese iena kota hereva ia gwauraia noho.   
\b  
\q1
\v 2 Ia gwau,  
\q1 “Umui ese kota hereva do umui hagagevaia noho ela bona edena negai?  
\q1 Umui ese kara dika taudia do umui durua noho ela bona edena negai?   
\q1
\v 3 Umui ese manoka taudia,  
\q1 bona edia tamadia sinadia be lasi maragidia do umui durua.  
\q1 Ogogami, bona dagedage taudia ese idia hisihisi henidia taudia,  
\q1 edia dala maorona, be kota dekenai do umui gwauraia.   
\q1
\v 4 Goada lasi taudia bona mai edia gau lasi taudia,  
\q1 be do umui hamauria,  
\q1 bona tau dikadia dekena amo do umui veridia mauri.   
\b  
\q1
\v 5 To umui be gau ta umui diba lasi,  
\q1 umui be gau ta ena anina umui davaria lasi.  
\q1 Umui be dibura dekenai umui loaloa kava noho.  
\q1 Unai dainai taunimanima ese,  
\q1 kara maoromaoro dalana idia badinaia lasi.   
\b  
\q1
\v 6 “Lau gwau, ‘Umui be dirava.  
\q1 Umui ibounai be Siahu Ibounai Dirava ena natuna.’   
\q1
\v 7 To umui ibounai be taunimanima hegeregerena do umui mase.  
\q1 Emui mauri be do idia ore,  
\q1 king ena natuna ena mauri do ia ore hegeregerena.”   
\b  
\q1
\v 8 Dirava e, do oi toreisi,  
\q1 tanobada do oi kota henia,  
\q1 badina tanobada ena bese ibounai,  
\q1 be oi sibona ese oi biagua noho.   
\c 83  
\s1 Guriguri ta, Israela dekenai idia tuari henia taudia be Dirava ese do ia halusia  
\q1
\v 1 Dirava e, do oi laga-ani lasi.  
\q1 Dirava e, oiemu hereva do oi koua lasi,  
\q1 bona do oi helai kava lasi.   
\q1
\v 2 Oi itaia, oi dekenai idia tuari henia gwauraia taudia,  
\q1 ese tuari totona idia toreisi noho.  
\q1 Oi idia badu henia taudia be idia dagedage noho.   
\q1
\v 3 Oiemu bese taudia hadikaia totona,  
\q1 idia ese dala idia tahua noho.  
\q1 Oi ese oi naria noho taudia hadikaia totona,  
\q1 inai tau dikadia ese idia haboua noho.   
\q1
\v 4 Idia ese inai bamona idia hereva noho, idia gwau,  
\q1 “Umui mai, unai bese do ita hadikaia ore,  
\q1 vadaeni Israela ena ladana be,  
\q1 taunimanima ese do idia laloaboio ela bona hanaihanai.”   
\b  
\q1
\v 5 Idia ese mai laloa tamona edia palani idia karaia,  
\q1 bona oi hadikaia totona,  
\q1 idia ese ta ta ibounai dekenai gwauhamata idia henia.   
\q1
\v 6 Unai besedia be inai:  
\q1 Edoma bona Isamaela bese taudia ibounai,  
\q1 bona Moaba taudia,  
\q1 bona Hagara bese taudia danu,   
\q1
\v 7 Gebala, bona Amono bona Amaleka,  
\q1 bona Pilistia, bona Turo taudia danu.   
\q1
\v 8 Asuria danu be idia danu ia haboua vadaeni.  
\q1 Idia be Lota ena bese taudia idia durua noho.   
\b  
\q1
\v 9 Midiana taudia dekenai oi karaia hegeregerena,  
\q1 be Asuria taudia dekenai danu do oi karaia.  
\q1 Sisera bona Iabina dekenai,  
\q1 Kisona Sinavai dekenai oi karaia hegeregerena,  
\q1 unai Asuria taudia mani do oi halusia.   
\q1
\v 10 Ene Doro dekenai oi ese idia oi hadikaia ore,  
\q1 bona edia mase tauanidia be tano dekenai idia bodaga lao.   
\q1
\v 11 Asuria ena tuari biagudia,  
\q1 be Oreba bona Sebe hegeregerena do oi halaoa.  
\q1 Idia edia lohia taudia ibounai do oi halusia,  
\q1 Sebaha bona Salamuna oi halusia bamona.   
\q1
\v 12 Unai taudia idia gwau,  
\q1 “Dirava ena rei gabudia be do ita abia, iseda tano.”   
\b  
\q1
\v 13 Egu Dirava e,  
\q1 tano ena kahu bamona,  
\q1 unai taudia do oi negea kahana kahana dekenai,  
\q1 uiti ena momoru be lai ese ia hodaia ore,  
\q1 unai hegeregerena do oi siaidia lao ore.   
\q1
\v 14 Lahi ese uda ia gabua ore bamona,  
\q1 bona lahi ena hururu ese,  
\q1 ororo edia uda gabudia ia gabua ore bamona,   
\q1
\v 15 oiemu lai badana dekena amo idia do oi lulua.  
\q1 Bona oiemu lai guba badana dekena amo idia do oi hagaria.   
\q1
\v 16 Lohiabada e,  
\q1 hemarai dekena amo edia vairadia do oi koua.  
\q1 Unai bamona do oi karaia,  
\q1 taunimanima ese oiemu ladana do idia tahua totona.   
\b  
\q1
\v 17 Lau ura idia be do idia hemarai,  
\q1 bona do idia gari noho ela bona hanaihanai.  
\q1 Oi ese idia do oi alaia mase,  
\q1 mai edia hemarai danu.   
\q1
\v 18 Lau ura inai bamona do oi karaia,  
\q1 vadaeni idia be do idia diba oiemu ladana be Iehova.  
\q1 Bona oi sibona,  
\q1 Ataiai Momokani Diravana,  
\q1 ese tanobada oi biagua noho.   
\c 84  
\s1 Tau ta ese Dirava ena Dubu Helaga ia ura henia bada  
\q1
\v 1 Siahu Ibounai Dirava e,  
\q1 lau ese oiemu Dubu Helaga lau ura henia bada!   
\q1
\v 2 Lau ura bada unuseni do lau noho.  
\q1 Egu lalona ibounai ese,  
\q1 Lohiabada ena Dubu Helaga ia ura henia noho.  
\q1 Egu tauanina bona egu kudouna dekena amo,  
\q1 Mauri Diravana dekenai ane lau abia noho,  
\q1 mai moale ena boiboi danu.   
\b  
\q1
\v 3 Siahu Ibounai Dirava e, oi be lauegu King bona lauegu Dirava.  
\q1 Manu maragidia ese edia ruma,  
\q1 be oiemu boubou patana ena badinai idia karaia.  
\q1 Unuseni edia natudia idia naria noho.   
\q1
\v 4 Oiemu Dubu Helaga lalonai idia noho taudia,  
\q1 be mai moale bada danu.  
\q1 Idia ese oi hanamoa totona,  
\q1 ane idia abia noho nega ibounai,   
\b  
\q1
\v 5 Edia goada oi dekena amo idia abia taudia,  
\q1 be mai edia moale danu.  
\q1 Idia ura bada idia raka lao Siona Ororo dekenai,  
\q1 bona mai moale danu idia lao.   
\q1
\v 6 Baka Koura gabuna idia raka hanaia neganai,  
\q1 ranu lohilohi gabudia idia davaria.  
\q1 Medu be daba neganai ia diho,  
\q1 bona unai ranu gabudia be ranu ese ia hahonua.   
\q1
\v 7 Unai taudia idia raka noho neganai,  
\q1 edia goada be ia bada lao noho,  
\q1 ela bona idia ta ta ese Dirava,  
\q1 be Siona Ororo dekenai do idia itaia.   
\b  
\q1
\v 8 Siahu Ibounai Dirava e,  
\q1 lauegu guriguri do oi kamonai.  
\q1 Iakobo ena Dirava e,  
\q1 lau dekenai do oi kamonai.   
\q1
\v 9 Dirava e, aiemai king do oi hanamoa.  
\q1 Oi sibona ese oi abia hidi king,  
\q1 be do oi laloa namo henia.   
\b  
\q1
\v 10 Lohiabada e,  
\q1 bema dina tamona sibona Dubu Helaga lalonai lau noho,  
\q1 unai dina ese,  
\q1 dina 1000 idau gabu dekenai ia hereaia noho.  
\q1 Momokani, lauegu Dirava ena Ruma ena iduara badinai,  
\q1 do lau gini be namo herea,  
\q1 to kara kerere taudia edia ruma lalonai lau noho be dika.   
\q1
\v 11 Badina be Lohiabada ese ita ia gimaia noho.  
\q1 Ia be iseda King, mai ena hairaina danu.  
\q1 Ia ese bogahisihisi bona mataurai,  
\q1 be ai dekenai ia henia noho.  
\q1 Bema tau ta ese kara maoromaoro ia karaia neganai,  
\q1 Lohiabada ese gau namona ta unai tau dekena amo do ia koua lasi.   
\q1
\v 12 Siahu Ibounai Diravana e,  
\q1 oi dekenai idia abidadama taudia ibounai,  
\q1 be do idia moale bada noho.   
\c 85  
\s1 Tau ta ia guriguri, Dirava ese Israela do ia hanamoa totona  
\q1
\v 1 Lohiabada e,  
\q1 oi ese oiemu tano dekenai oi bogahisihisi henia vadaeni.  
\q1 Oi ese Israela ena noho oi hanamoa lou vadaeni.   
\q1
\v 2 Oi ese oiemu bese taudia edia kara dika oi gwauatao vadaeni,  
\q1 bona edia kerere oi laloaboio vadaeni.   
\q1
\v 3 Guna ai dekenai oi badu,  
\q1 to hari oiemu badu oi hakerua vadaeni.  
\q1 Oiemu badu mai siahu bada,  
\q1 be oi ese oi hadokoa vadaeni.   
\b  
\q1
\v 4 Dirava e, aiemai Hamauria Tauna,  
\q1 mani emu kara ai do oi haginia lou,  
\q1 bona mani do oi badu lou lasi ai dekenai.   
\q1
\v 5 Ai dekenai do oi badu ela bona hanaihanai, a?  
\q1 Oiemu badu be nega ta do ia doko lasi, a?   
\q1
\v 6 Goada ai dekenai do oi henia lou,  
\q1 bona ai, oiemu bese taudia ese oi do ai hanamoa.   
\q1
\v 7 Lohiabada e, oiemu noho hanaihanai lalokauna,  
\q1 be ai dekenai do oi hedinaraia,  
\q1 bona oiemu hamauria ena durua be ai dekenai do oi henia.   
\b  
\q1
\v 8 Lohiabada Dirava ena hereva lau kamonai noho.  
\q1 Ia gwau ia ese maino be ai dekenai,  
\q1 iena bese korikori taudia dekenai, do ia henia,  
\q1 bema ai ese guna ai karaia kavakava karadia,  
\q1 be do ai karaia lou lasi.   
\q1
\v 9 Momokani, ia ese ia dekenai idia gari taudia ia hamauria noho.  
\q1 Ia ese ai do ia hamauria,  
\q1 bona ai danu do ia noho,  
\q1 aiemai tano lalonai.   
\q1
\v 10 Unai neganai Israela taudia ese,  
\q1 ta ta ibounai dekenai do idia lalokau henia,  
\q1 bona kara namodia be idia ta ta dekenai do idia karaia,  
\q1 vadaeni idia ibounai be,  
\q1 kara maoromaoro bona maino dekenai do idia noho hebou.   
\q1
\v 11 Lohiabada dekenai abidadama kara,  
\q1 be Israela tano dekenai do ia tubu,  
\q1 bona Dirava, guba dekenai ia noho,  
\q1 ese kara maoromaoro, emai bese edia huanai do ia havaraia.   
\q1
\v 12 Momokani, Lohiabada ese gau namodia ai dekenai do ia henia.  
\q1 Aiemai noho do ia hanamoa,  
\q1 bona aiemai tano ese ena anina do ia havaraia bada herea.   
\q1
\v 13 Lohiabada ese taunimanima do ia durua,  
\q1 bona kara maoromaoro taudia do ia halaodia,  
\q1 bona inai kara ese,  
\q1 Lohiabada ena mai dalana do ia karaia hegaegae.   
\c 86  
\s1 Davida ese durua totona Dirava ia noia  
\q1
\v 1 Lohiabada e,  
\q1 egu noinoi do oi kamonai,  
\q1 lau dekenai do oi haere,  
\q1 badina lau be manoka, bona tau ta ese lau ia durua lasi.   
\q1
\v 2 Mase dekena amo lau do oi hamauria,  
\q1 badina lau ese oi lau badinaia noho, mai momokani danu.  
\q1 Mani emu kara, lau do oi hamauria,  
\q1 badina lau be oiemu hesiai tauna,  
\q1 bona lau ese oi lau abidadama henia noho.   
\q1
\v 3 Oi be egu Dirava.  
\q1 Mani emu kara lau dekenai do oi bogahisihisi henia,  
\q1 badina dina ena nega ibounai,  
\q1 lau ese oi dekenai lau tai henia noho.   
\q1
\v 4 Lohiabada e, lau,  
\q1 oiemu hesiai tauna, egu lauma mani do oi hamoalea,  
\q1 badina be egu lauma ese oi ia tahua noho.   
\b  
\q1
\v 5 Lohiabada e,  
\q1 oi be mai oiemu bogahisihisi,  
\q1 bona kara dika oi gwauatao noho.  
\q1 Oi dekenai idia guriguri noho taudia dekenai,  
\q1 oiemu noho hanaihanai lalokauna oi henia noho.   
\q1
\v 6 Lohiabada e,  
\q1 egu guriguri mani do oi kamonai.  
\q1 Oiemu durua totona lau noinoi inai.  
\q1 Mani emu kara egu noinoi do oi abia dae.   
\q1
\v 7 Egu hekwarahi neganai, lau ese oi dekenai lau tai henia noho,  
\q1 badina oi ese lau dekenai oi haere henia noho.   
\q1
\v 8 Lohiabada e,  
\q1 dirava ta oi hegeregerena be lasi momokani.  
\q1 Idia ta ese oiemu kara hegeregerena idia karaia diba lasi.   
\q1
\v 9 Lohiabada e, oi ese oi karaia besedia ibounai be do idia mai,  
\q1 oiemu vairana dekenai do idia tomadiho.  
\q1 Oiemu ladana be idia ese idia hanamoa bona matauraia,   
\q1
\v 10 badina oi be bada,  
\q1 bona oi ese hoa karadia oi karaia noho.  
\q1 Oi sibona be Dirava.   
\b  
\q1
\v 11 Lohiabada e, oiemu dala lau dekenai do oi hadibaia,  
\q1 bona lau be oiemu momokani lalonai do lau raka.  
\q1 Lauegu lalona do oi hatamonaia momokani,  
\q1 vadaeni lau ese oiemu ladana do lau matauraia bona gari henia.   
\q1
\v 12 Lohiabada Dirava e,  
\q1 lau ese oi do lau hanamoa,  
\q1 mai egu kudouna ibounai danu.  
\q1 Lau ese oiemu ladana,  
\q1 be do lau hanamoa bada ela bona hanaihanai,   
\q1
\v 13 badina oiemu lalokau lau dekenai be bada herea.  
\q1 Oi ese mase taudia edia guri dobu gabuna dekena amo,  
\q1 egu lauma oi hamauria vadaeni.   
\b  
\q1
\v 14 Dirava e,  
\q1 hekokoroku taudia ese lau idia tuari henia noho.  
\q1 Dagedage taudia ese egu mauri hadokoa dalana idia tahua noho.  
\q1 Unai taudia ese oi dekenai idia laloa lasi.   
\q1
\v 15 To Lohiabada e,  
\q1 oi be bogahisihisi bona hariharibada Diravana.  
\q1 Oiemu badu be haraga lasi,  
\q1 to oiemu lalokau bona maoromaoro be bada herea momokani.   
\q1
\v 16 Lau dekenai do oi laloa,  
\q1 bona lau dekenai do oi bogahisihisi henia.  
\q1 Lau do oi hagoadaia,  
\q1 bona lau do oi hamauria.  
\q1 Badina be lau ese oiemu hesiai gaukara lau karaia noho,  
\q1 egu sinana ese ia karaia guna bamona.   
\q1
\v 17 Oiemu kara namona ena toana ta,  
\q1 be lau dekenai do oi hedinaraia,  
\q1 vadaeni lau idia hadikaia gwauraia taudia ese do idia itaia,  
\q1 bona do idia hemarai.  
\q1 Badina be, Lohiabada e,  
\q1 do idia itaia, oi ese lau oi durua vadaeni,  
\q1 bona oi ese lau oi hagoadaia vadaeni.   
\c 87  
\s1 Ierusalema hanua idia hanamoa  
\q1
\v 1 Lohiabada ese iena hanua,  
\q1 be ororo helagana dekenai ia haginia.   
\q1
\v 2 Lohiabada ese Israela ena gabu ibounai ia ura henia noho,  
\q1 to ia ese Ierusalema hanua ia ura henia bada momokani.   
\q1
\v 3 Dirava ena hanua dekenai noho taudia e, do umui kamonai.  
\q1 Dirava ese emui hanua ena hairaina ia herevalaia noho.   
\q1
\v 4 Dirava be inai bamona ia hereva, ia gwau,  
\q1 “Dohore egu hereva idia kamonai henia bese taudia lau duahia neganai,  
\q1 Aigupito bona Babulonia danu do lau haboua.  
\q1 Ma danu do lau gwau, Pilistia bona Turo bona Etiopia taudia,  
\q1 be Ierusalema noho taudia danu do lau haboua.”   
\b  
\q1
\v 5 Ma Dirava ese Siona do idia herevalaia,  
\q1 do ia gwau,  
\q1 “Siona be bese idauidau ibounai taudia edia gabuna.”  
\q1 Badina be Siahu Ibounai Diravana ese,  
\q1 Ierusalema do ia haginia bona hagoadaia.   
\q1
\v 6 Lohiabada ese bese momo taudia edia ladana do ia torea,  
\q1 bona ia ese Ierusalema noho taudia danu do ia haboudia,  
\q1 badina do ia gwau, “Idia be Siona dekenai idia vara.”   
\q1
\v 7 Unai neganai Ierusalema noho taudia do idia mavaru mai ane danu.  
\q1 Do idia gwau,  
\q1 “Ierusalema e, ai be oiemu taudia korikori,  
\q1 bona oi be hanamoa ibounai ena badina.”   
\c 88  
\s1 Tau ta ese Dirava dekenai ia tai, do ia durua totona  
\q1
\v 1 Lohiabada, lau oi hamauria noho Diravana e,  
\q1 dina lalonai oi dekenai lau boiboi noho,  
\q1 lau do oi durua totona.  
\q1 Hanuaboi lalonai danu oi dekenai lau tai henia noho.   
\q1
\v 2 Egu guriguri mani do oi kamonai.  
\q1 Oiemu durua lau noia neganai,  
\q1 mani lau dekenai do oi kamonai henia.   
\b  
\q1
\v 3 Badina be egu lauma be mai ena hekwarahi bada,  
\q1 bona egu mauri,  
\q1 be mase gabuna dekenai kahirakahira do ia vareai lao.   
\q1
\v 4 Kahirakahira do idia mase taudia, be lau danu idia haboua tamona,  
\q1 mase gabuna dekenai do ai diho hebou totona,  
\q1 bona egu goada be ia ore vadaeni.   
\q1
\v 5 Mase taudia edia huanai lau idia rakatania vadaeni.  
\q1 Lau be idia alaia vadaeni tauna bamona,  
\q1 mase ena guri dekenai lau noho.  
\q1 Lau be, oi ese oi laloaboio momokani vadaeni tauna bamona,  
\q1 lau be, oi ese do oi durua lou lasi tauna bamona.   
\b  
\q1
\v 6 Oi ese mase guria gabuna dobu herea dekenai,  
\q1 lau oi atoa vadaeni,  
\q1 dibura masemase bona dobu masemase gabuna dekenai.   
\q1
\v 7 Oiemu badu be metau herea lauegu latanai.  
\q1 Oiemu hurehure ibounai ese lau idia koua momokani.   
\q1
\v 8 Oi ese egu turana taudia oi hamaoroa,  
\q1 vadaeni idia ese lau idia rakatania.  
\q1 Oi ese lau oi hadikaia dainai,  
\q1 idia dekenai lau be gari gauna bamona.  
\q1 Lau be hegeregere dibura dekenai lau noho,  
\q1 bona lau heau mauri diba lasi.   
\q1
\v 9 Egu lalohisihisi dainai,  
\q1 egu matana ese gau idia itaia namonamo lasi.  
\q1 Lohiabada e, dina ibounai oi dekenai lau boiboi noho.  
\q1 Egu imana be oi dekenai lau abia isi noho.   
\q1
\v 10 Hoa karadia,  
\q1 be mase taudia edia vairanai oi karaia noho, a?  
\q1 O sedira mase taudia edia laulaudia,  
\q1 ese oi hanamoa totona idia toreisi noho, a?   
\q1
\v 11 Mase guria gabuna dekenai,  
\q1 be oiemu lalokau idia gwauraia noho, a?  
\q1 O dobu masemase gabuna dekenai,  
\q1 oiemu gwauhamata hamomokania karadia idia gwauraia noho, a?   
\q1
\v 12 Dibura sibona ia noho gabuna dekenai,  
\q1 oiemu hoa karadia idia diba, a?  
\q1 Idia laloaboio vadaeni mase taudia idia noho gabuna,  
\q1 unuseni be oiemu kara namodia do idia laloa, a?   
\b  
\q1
\v 13 To Lohiabada e,  
\q1 lau ese oiemu durua totona lau tai henia noho.  
\q1 Daba neganai egu noinoi be oi dekenai lau gwauraia noho.   
\q1
\v 14 Lohiabada e, badina dahaka lau oi negea noho?  
\q1 Badina dahaka oiemu vairana be lau dekena amo oi hunia noho?   
\q1
\v 15 Lau be mero negana dekena amo, mai hisihisi danu lau noho,  
\q1 bona kahirakahira lau mase.  
\q1 Oiemu matakani ese lau ia hagaria, vadaeni lau be dika,  
\q1 bona durua do lau abia dalana be lasi.   
\q1
\v 16 Oiemu badu ese lau ia koua momokani vadaeni,  
\q1 bona oiemu gari karadia ese,  
\q1 lau idia hadikaia ore.   
\q1
\v 17 Abata ranu bamona,  
\q1 idia ese lau idia koua hagegea dina ena hora ibounai lalonai.  
\q1 Idia ese lau idia koua momokani vadaeni.   
\q1
\v 18 Oi ese egu turana bona egu lalokau taudia danu,  
\q1 be lau dekena amo oi atodia siri,  
\q1 bona dibura sibona be egu turana tamona bamona.   
\c 89  
\s1 Nega dika be edia tano dekenai ia vara neganai inai ane idia abia  
\q1
\v 1 Lohiabada e,  
\q1 oiemu lalokau bada dainai ane do lau abia nega ibounai.  
\q1 Lau ese oiemu maoromaoro bona momokani do lau gwauraia hanaihanai.   
\q1
\v 2 Lau diba oiemu lalokau,  
\q1 be do ia noho ela bona hanaihanai.  
\q1 Oiemu kara be maoromaoro bona momokani, do ia idau lasi.  
\q1 Ia be ia noho goada nega ibounai,  
\q1 guba ia noho goada bamona.   
\q1
\v 3 Oi ese oi gwau vadaeni,  
\q1 “Lau ese lau abia hidi tauna danu gwauhamata taravatuna ai karaia.  
\q1 Egu hesiai tauna Davida dekenai lau gwauhamata, lau gwau,   
\q1
\v 4 ‘Oiemu natuna bona tubuna ta,  
\q1 be nega ibounai do ia king.  
\q1 Lau ese oiemu king siahuna,  
\q1 be do lau haginia ela bona hanaihanai.’ ”   
\b  
\q1
\v 5 Lohiabada e,  
\q1 guba noho aneru taudia ese,  
\q1 oiemu hoa karadia be ane dekenai do idia hanamoa.  
\q1 Idia ese oiemu maoromaoro bona momokani dainai ane idia abia,  
\q1 oiemu ladana hanamoa totona.   
\q1
\v 6 Badina be Lohiabada e,  
\q1 guba dekenai, daika be oi hegeregere?  
\q1 Edena aneru be Lohiabada hegeregerena?   
\q1
\v 7 Aneru badadia edia hebou lalonai,  
\q1 idia ibounai be oi dekenai idia gari noho,  
\q1 bona aneru ibounai, oi Lohiabada idia hagegea aneru ibounai ese,  
\q1 oi idia gari henia noho.   
\b  
\q1
\v 8 Lohiabada, Siahu Ibounai Dirava e,  
\q1 daika ena siahu be oiemu siahu hegeregere?  
\q1 Oiemu kara ibounai dekenai oiemu gwauhamata bona oiemu hereva,  
\q1 be oi badinaia noho.   
\q1
\v 9 Lohiabada e, oi ese davara badana oi biagua noho.  
\q1 Oi ese davara ena hurehure bada oi hamanadaia noho.   
\q1
\v 10 Oi ese Aigupito oi hamakohia,  
\q1 bona oi hadikaia ore,  
\q1 bona oiemu goada badana dekena amo,  
\q1 oi dekenai idia tuari taudia oi halusia.   
\q1
\v 11 Guba be oiemu, tano danu be oiemu.  
\q1 Tanobada bona ia lalonai gaudia ibounai be oi ese oi karaia.   
\q1
\v 12 Mirigini kahana bona diho kahana be oi ese oi karaia.  
\q1 Taboro Ororo bona Heremona Ororo ese,  
\q1 oiemu ladana idia hanamoa noho,  
\q1 mai edia moale anedia danu.   
\q1
\v 13 Momokani, oiemu siahu be bada herea,  
\q1 bona oiemu goada be bada momokani.   
\q1
\v 14 Oiemu basileia be kara maoromaoro bona kota maorona,  
\q1 dekenai ia gini noho.  
\q1 Oi ese oiemu basileia taudia oi lalokau henia,  
\q1 bona mai maoromaoro bona momokani danu oi durudia noho.  
\q1 Oiemu kara be namo nega ibounai, oi haidaua lasi.   
\b  
\q1
\v 15 Ane dekena amo oi idia tomadiho henia taudia,  
\q1 be mai edia moale momokani danu.  
\q1 Lohiabada e,  
\q1 idia be oiemu bogahisihisi ena diari lalonai idia mauri noho.   
\q1
\v 16 Oi dainai idia be dina ibounai idia moale bada noho,  
\q1 bona oiemu kara namo dainai oi idia hanamoa noho.   
\q1
\v 17 Oi ese ai dekenai kwalimu bada oi henia noho.  
\q1 Oiemu lalokau bona bogahisihisi dainai,  
\q1 tuari lalonai kwalimu ai dekenai oi henia noho.   
\q1
\v 18 Lohiabada e, oi ese aiemai king oi abia hidi vadaeni.  
\q1 Oi, Israela ena Dirava Helagana ese,  
\q1 aiemai king be ai dekenai oi henia vadaeni.   
\s1 Dirava ena gwauhamata Davida dekenai  
\q1
\v 19 Gunaguna momokani neganai,  
\q1 oi ese oiemu hesiai taudia korikori dekenai nihi oi siaia,  
\q1 bona idia dekenai oi hamaoroa, oi gwau,  
\q1 “Lau ese tuari tauna namona ta lau abia hidi vadaeni,  
\q1 bona lau ese king dagi ia dekenai lau henia.  
\q1 Lau ese hanua taudia edia huanai ia lau abia hidi,  
\q1 ia be king.   
\q1
\v 20 Lau ese lauegu hesiai tauna Davida lau abia hidi,  
\q1 bona king ena dagi lalonai lau hasiahua,  
\q1 dehoro helagana dekena amo.   
\q1
\v 21 Lauegu goada be nega ibounai ia dekenai do ia noho.  
\q1 Lauegu siahu ese do ia hagoadaia.   
\q1
\v 22 Ia dekenai do idia tuari taudia ese ia do idia halusia diba lasi,  
\q1 bona kara dika taudia ese ia dekena amo do idia kwalimu diba lasi.   
\q1
\v 23 Ia dekenai idia dagedage taudia,  
\q1 be lau ese do lau hadikaia ore,  
\q1 bona ia idia badu henia taudia,  
\q1 be do lau alaia mase.   
\q1
\v 24 Lau ese ia do lau lalokau henia,  
\q1 bona ia do lau durua momokani.  
\q1 Do ia tuari negadia ibounai kwalimu do lau henia.   
\q1
\v 25 Iena basileia be do lau habadaia,  
\q1 bona iena tano be davara badana dekena amo,  
\q1 ela bona Euperate Sinavai.   
\q1
\v 26 Ia ese lau dekenai do ia gwau,  
\q1 ‘Oi be lauegu Tamana bona lauegu Dirava.  
\q1 Oi be egu Nadi Badana, lau oi hamauria noho Diravana.’   
\q1
\v 27 Lau Lohiabada ese egu vara guna natuna ia do lau halaoa,  
\q1 bona ia be king badana momokani do ia lao,  
\q1 king ibounai ia ese do ai hereaia.   
\q1
\v 28 Egu bogahisihisi ia dekenai do lau henia nega ibounai,  
\q1 bona egu gwauhamata taravatuna ia danu be do ia noho,  
\q1 ela bona hanaihanai.   
\q1
\v 29 Iena natuna bona tubuna ese,  
\q1 king dagi do idia dogoatao noho ela bona hanaihanai.  
\q1 Iena king siahuna be nega ibounai do ia noho,  
\q1 guba do ia noho dinadia hegeregere.   
\b  
\q1
\v 30 “To bema iena natuna o tubuna ese egu taravatu idia utua,  
\q1 bona egu oda hegeregere idia noho lasi,   
\q1
\v 31 o bema egu hadibaia hereva idia badinaia lasi,  
\q1 bona egu taravatu idia kamonai henia lasi neganai,   
\q1
\v 32 lau ese idia do lau panisia,  
\q1 bona edia kerere davana do lau henia, hisihisi dekena amo.   
\q1
\v 33 To lau ese egu lalokau Davida dekenai do lau hadokoa lasi,  
\q1 bona egu gwauhamata ia dekenai do lau makohia lasi.   
\q1
\v 34 Egu gwauhamata taravatuna Davida dekenai,  
\q1 be do lau utua lasi momokani.  
\q1 Lauegu hereva ta do lau haidaua lasi, lasi momokani.   
\b  
\q1
\v 35 “Lauegu ladana helagana dekena amo lau gwauhamata vadaeni,  
\q1 lau gwau, ‘Davida be do lau koia lasi.   
\q1
\v 36 Davida ena tubuna be do idia vara noho hanaihanai,  
\q1 do idia doko lasi,  
\q1 bona Davida ena basileia be do lau naria noho,  
\q1 ela bona dina ena noho dinadia ibounai.   
\q1
\v 37 Davida ena king siahuna be do ia gini hanaihanai,  
\q1 hua be guba dekenai ia noho hegeregerena,  
\q1 bona hua ese taunimanima dekenai do ia hedinaraia,  
\q1 lauegu hereva be momokani.’ ”   
\s1 Tuari taudia ese, edia king idia halusia dainai, idia taitai noho  
\q1
\v 38 To harihari oi ese oi abia hidi king tauna,  
\q1 be oi badu henia noho.  
\q1 Oi ese ia oi rakatania,  
\q1 bona ia oi negea vadaeni.   
\q1
\v 39 Oiemu gwauhamata taravatuna, oiemu hesiai tauna danu oi karaia gauna,  
\q1 be oi ese oi makohia vadaeni.  
\q1 Bona iena king toana, korona,  
\q1 be oi ese oi negea vadaeni kopukopu dekenai.   
\q1
\v 40 Oi ese iena hanua badana ena magu oi veria diho vadaeni,  
\q1 bona magu ena gabu aukana danu,  
\q1 be oi ese oi hamakohia ore.   
\q1
\v 41 Raka hanaia taudia ibounai ese king ena kohu idia henaoa noho,  
\q1 bona iena badibadinai idia noho taudia ese,  
\q1 ia dekenai idia kirikiri noho.   
\q1
\v 42 Oi ese king Davida dekenai idia tuari henia taudia,  
\q1 dekenai kwalimu oi henidia,  
\q1 vadaeni oi ese idia ibounai oi hamoalea vadaeni.   
\q1
\v 43 Oi ese king ena tuari kaia oi hadikaia, ia be matana lasi,  
\q1 bona iena tuari taudia dekenai goada oi henidia lasi.   
\q1
\v 44 Oi ese iena king siahuna ia dekena amo oi kokia,  
\q1 bona iena helai gauna, terona,  
\q1 be oi ese tano dekenai oi negea diho vadaeni.   
\q1
\v 45 King oi durua lasi dainai,  
\q1 iena buruka dinadia idia ginidae haraga.  
\q1 Oi ese oi hahemaraia vadaeni.   
\s1 Dirava idia noia, do ia hamauridia  
\q1
\v 46 Lohiabada e, oi sibona do oi hunia noho ela bona edena negai?  
\q1 Ela bona hanaihanai a?  
\q1 Oiemu badu do ia siahu, lahi bamona, ela bona edena negai?   
\q1
\v 47 Lohiabada e, mani oi laloa,  
\q1 aiemai mauri dinadia be daudau lasi.  
\q1 Oi ese ai oi karaia, madi, ai be goada lasi do ai noho daudau,  
\q1 ai be mase do ai davaria haraga.   
\q1
\v 48 Edena tau ese iena mauri ia halataia diba?  
\q1 Daika ese guria gabuna ena siahu dekena amo ia heau mauri diba?   
\q1
\v 49 Lohiabada e, oiemu lalokau badana,  
\q1 guna ia noho lalokauna,  
\q1 be edeseni ia noho hari?  
\q1 Oi ese Davida dekenai guna oi karaia gwauhamatana be edeseni?   
\q1
\v 50 Lohiabada e,  
\q1 lau be oiemu hesiai tauna,  
\q1 lau dekenai mani oi laloa.  
\q1 Taunimanima idia hereva dika lau dekenai.  
\q1 Dirava diba lasi taudia ese,  
\q1 lau hadikaia totona badu hereva idia gwauraia noho.   
\q1
\v 51 Lohiabada e,  
\q1 oi dekenai idia tuari gwauraia taudia ese,  
\q1 oi abia hidi king idia hereva dika henia noho.  
\q1 Oiemu abia hidi king ia lao gabudia ibounai dekenai,  
\q1 unai taudia ese ia dekenai idia hereva dika henia noho.   
\b  
\q1
\v 52 Ita ese Lohiabada do ita hanamoa ela bona hanaihanai. Amen bona Amen.   
\c 90  
\s1 Dirava ena kara, bona taunimanima edia kara  
\q1
\v 1 Lohiabada e,  
\q1 oi sibona be aiemai noho gabuna,  
\q1 gunaguna ia mai bona harihari.   
\q1
\v 2 Oi be nega ibounai, hanaihanai, Dirava oi noho,  
\q1 idaunegai bona gabeai danu.  
\q1 Ororo do oi karaia lasi neganai,  
\q1 tanobada bona motumotu oi do karaia lasi neganai,  
\q1 oi be unai bamona,  
\q1 bona unai bamona do oi noho ela bona hanaihanai.   
\b  
\q1
\v 3 Oi ese taunimanima oi hamasea,  
\q1 bona oi ese kahu dekenai idia oi halaoa lou.  
\q1 Bona oi ese oi hereva, oi gwau,  
\q1 “Umui be kahu ena taudia,  
\q1 do umui mase, bona kahu dekenai umui giroa lou.”   
\q1
\v 4 Lagani 1000 oiemu vairana dekenai be dina tamona sibona bamona.  
\q1 Idia ore haraga, varani bamona.  
\q1 Idia ore lao, hanuaboi ena hora tamona bamona.   
\q1
\v 5 Oi ese taunimanima oi kokia lao,  
\q1 abata ese ia kokidia lao bamona,  
\q1 vadaeni idia mase.  
\q1 Taunimanima be nega kwadogina sibona idia noho, nihi bamona.  
\q1 Idia be hegeregere ava,  
\q1 daba neganai idia tubu matamata bamona,   
\q1
\v 6 bona idia bada lao,  
\q1 herahera idia atoa,  
\q1 to adorahi neganai idia kakoro bona idia mase.   
\b  
\q1
\v 7 Oiemu badu ese ai ia hadikaia ore.  
\q1 Oiemu dagedage ese ai ia hagaria dikadika.   
\q1
\v 8 Oi ese aiemai kara dika oi itaia noho,  
\q1 bona hunia dekenai ai kara dika neganai,  
\q1 oi ese oiemu vairana dekenai oi atodia,  
\q1 bona oi dekenai idia hedinarai namonamo.   
\q1
\v 9 Oiemu badu ese aiemai tanobada maurina ia hakwadogia noho.  
\q1 Momokani, aiemai mauri ia doko haraga, hahodi tamona bamona.   
\q1
\v 10 Aiemai mauri lagani be 70 sibona.  
\q1 Bema ai be goada neganai sedira lagani 80 do ai abia,  
\q1 to inai lagani ibounai lalonai,  
\q1 hekwarahi bona lalohisihisi ai abia noho.  
\q1 Aiemai mauri be idia ore haraga, vadaeni ai boio.   
\b  
\q1
\v 11 Oiemu badu ena siahu momokani ena mamina be daika ia diba?  
\q1 Oiemu dagedage bada ena gari be daika ia diba namonamo?   
\q1
\v 12 Aiemai mauri ena kwadogi mani ai dekenai do oi hadibaia,  
\q1 bona unai dekena amo aonega do ai davaria.   
\b  
\q1
\v 13 Oiemu badu be do ia noho ela bona edena negai?  
\q1 Mani emu kara, ai, oiemu hesiai taudia dekenai do oi bogahisihisi.   
\q1
\v 14 Daba daba ibounai oiemu lalokau badana dekena amo,  
\q1 ai do oi hahonua,  
\q1 vadaeni aiemai mauri dinadia ibounai lalonai,  
\q1 mai moale danu do ai noho.   
\q1
\v 15 Guna oi ese lalohisihisi ai dekenai oi henia.  
\q1 Vadaeni harihari mani emu kara,  
\q1 inai lalohisihisi ena bada hegeregere,  
\q1 moale do oi henia ai dekenai.  
\q1 Momokani lagani momo aiemai noho be dika,  
\q1 to harihari ai do oi hamoalea,  
\q1 unai lagani dikadia edia daudau hegeregerena.   
\q1
\v 16 Oiemu kara badadia be ai,  
\q1 oiemu hesiai taudia dekenai do oi hedinaraia,  
\q1 bona oiemu siahu bada mai hairaina danu,  
\q1 be aiemai tubudia dekenai do oi hedinaraia.   
\b  
\q1
\v 17 Lohiabada e, oi be aiemai Dirava.  
\q1 Ai ura oiemu bogahisihisi bona hanamoa,  
\q1 be ai dekenai do idia noho,  
\q1 vadaeni aiemai kara ibounai lalonai,  
\q1 aiemai gaukara ena anina do ai davaria, kwalimu danu do ai abia!   
\c 91  
\s1 Dirava be iseda Naria Tauna  
\q1
\v 1 Bema tau ta ese Ataiai Momokani Lohiabada dekenai ia lao,  
\q1 Lohiabada ese mase dekena amo do ia naria totona,  
\q1 bona bema unai tau be,  
\q1 Siahu Ibounai Dirava kahirakahira ia noho neganai.  
\q1 Dirava ese do ia naria bona durua.   
\q1
\v 2 Unai tau ese Dirava dekenai do ia hereva, do ia gwau,  
\q1 “Lohiabada e, oi be egu gima Tauna bona egu naria Tauna,  
\q1 Oi be egu Dirava, oi dekenai lau abidadama noho.”   
\b  
\q1
\v 3 Momokani Dirava ese oi do ia durua,  
\q1 bona hunia dekenai idia noho dika gaudia,  
\q1 be hegeregere lasi oi do idia hadikaia,  
\q1 bona gorere dikadia, mase gaudia,  
\q1 be hegeregere lasi oiemu mauri do idia abia.   
\q1
\v 4 Lohiabada ese iena hanina dekena amo oi do ia koua,  
\q1 vadaeni iena naria dainai oi be do oi mauri.  
\q1 Iena kara be maoromaoro bona momokani dainai,  
\q1 iena gima kara bona naria kara be momokani.   
\q1
\v 5 Hanuaboi neganai idia mai dika gaudia, be do oi gari henia lasi,  
\q1 bona dina neganai karaharaga idia ginidae gau dikadia danu,  
\q1 be do oi gari henidia lasi.   
\q1
\v 6 Dibura neganai idia vara gorere dikadia danu,  
\q1 be hegeregere lasi oi do idia hagaria.  
\q1 Dina neganai idia toreisi haraga dika badadia dekenai danu,  
\q1 be do oi gari lasi.   
\b  
\q1
\v 7 Sedira oi kahirakahira be taunimanima 1000 idia mase,  
\q1 bona oiemu imana idibana kahana dekenai,  
\q1 sedira taunimanima 10,000 idia mase,  
\q1 to unai dika be do oi davaria lasi.   
\q1
\v 8 Oi ese Dirava ena kara do oi itaia:  
\q1 Ia ese tau dikadia edia kerere davana do ia henia momokani,  
\q1 be do oi itaia.   
\b  
\q1
\v 9  Bema egu naria Tauna,  
\q1 Siahu Ibounai Diravana,  
\q1 be oiemu gima Tauna, oiemu kohoro oi halaoa,   
\q1
\v 10 unai neganai dika ta ese oi dekenai do ia kamokau lasi.  
\q1 Oi do ia hadikaia gauna ta,  
\q1 be oiemu ruma dekenai do ia ginidae lasi.   
\q1
\v 11 Dirava ese iena aneru oi dekenai do ia siaia,  
\q1 idia ese oi do idia naria, oiemu loaloa gabudia ibounai dekenai.   
\q1
\v 12 Idia ese edia imana dekena amo oi do idia dogoatao,  
\q1 vadaeni oiemu aena be nadi dekenai bero do idia davaria lasi.   
\q1
\v 13 Oi ese laiona bona gaigai, bona laiona dagedagedia,  
\q1 bona gaigai badadia danu, do oi moia diho.   
\b  
\q1
\v 14 Dirava ia gwau, “Lau idia lalokau henia taudia,  
\q1 be lau ese do lau hamauria.  
\q1 Bona lau idia diba,  
\q1 bona edia Lohiabada dekenai lau idia abia dae taudia,  
\q1 be do lau naridia namonamo.   
\q1
\v 15 Bema idia ese lau idia boiboi henia neganai,  
\q1 lau ese idia dekenai do lau haere.  
\q1 Hisihisi idia davaria neganai,  
\q1 lau ese idia dekenai do lau noho.  
\q1 Lau ese idia do lau hamauria,  
\q1 bona taunimanima edia mataurai idia dekenai do lau henia.   
\q1
\v 16 Lau ese mauri daudau idia dekenai do lau henia,  
\q1 edia davana namona.  
\q1 Lau ese idia do lau hamauria momokani.”   
\c 92  
\s1 Dirava hanamoa totona ane ta  
\q1
\v 1 Lohiabada e,  
\q1 oi be Ataiai Momokani Diravana,  
\q1 ai tanikiu henia be namo.  
\q1 Ane dekena amo oiemu ladana do ai abia isi be namo.   
\q1
\v 2 Daba ibounai neganai,  
\q1 oiemu noho hanaihanai lalokauna do ai gwauraia.  
\q1 Hanuaboi ibounai neganai danu,  
\q1 oiemu kara momokanidia do ai gwauraia.   
\q1
\v 3 Gita badadia bona miusiki gaudia haida dekena amo,  
\q1 oiemu ladana do ai hanamoa.   
\b  
\q1
\v 4 Badina be, Lohiabada e,  
\q1 oi ese oi karaia kara badadia ese lau idia hamoalea.  
\q1 Oiemu gaukara badadia dainai,  
\q1 mai moale bada danu ane lau abia noho.   
\q1
\v 5 Lohiabada e,  
\q1 oi ese oi karaia gaukara be bada herea momokani,  
\q1 bona oiemu laloa be dobu herea momokani.   
\q1
\v 6 Mai ena lalona lasi tauna be do ia diba lasi,  
\q1 kavakava tauna danu ese,  
\q1 inai gau ena anina ia davaria diba lasi:   
\q1
\v 7 Kara dika taudia be do idia tubu daekau,  
\q1 ava idia tubu daekau bamona.  
\q1 Bona kerere idia karaia taudia,  
\q1 be kohu momo bona noho namo idia abia diba,  
\q1 to oi ese idia do oi hadikaia ore.   
\b  
\q1
\v 8 Badina oi, Lohiabada,  
\q1 be King Badana do oi noho ela bona hanaihanai.   
\b  
\q1
\v 9 Lohiabada e, ai diba oi dekenai idia tuari henia taudia,  
\q1 be do idia mase,  
\q1 bona kara dika taudia ibounai be oi ese do oi halusia.   
\q1
\v 10 Oi ese lau dekenai goada oi henia vadaeni,  
\q1 uda boromakau tau ena goada hegeregerena.  
\q1 Oi ese lau oi hanamoa,  
\q1 vadaeni moale lau davaria.   
\q1
\v 11 Lau itaia vadaeni, lau idia hadikaia gwauraia taudia,  
\q1 be oi ese oi halusia vadaeni,  
\q1 bona lau kamonai vadaeni danu,  
\q1 lau dekenai idia kara dika taudia, edia taitai.   
\b  
\q1
\v 12 Kara maoromaoro taudia,  
\q1 be do idia tubu daekau namo herea momokani,  
\q1 huahua namodia ia atoa au namona bamona.  
\q1 Do idia tubu daekau,  
\q1 Lebanona sida auna ia tubu hegeregerena.   
\q1
\v 13 Kara maoromaoro taudia,  
\q1 be Lohiabada ena Ruma dekenai idia hadoa audia bamona.  
\q1 Iseda Dirava ena Ruma lalonai,  
\q1 be do idia tubu daekau namo herea momokani.   
\q1
\v 14 Idia buruka momokani neganai,  
\q1 idia ese huahua do idia atoa noho.  
\q1 Idia be nega ibounai idia goada noho,  
\q1 au raurau matamata idia atoa,  
\q1 bona idia be do idia kakoro diba lasi.   
\q1
\v 15 Inai edia kara ese ia hedinaraia noho, Lohiabada be ia maoromaoro.  
\q1 Lohiabada be egu Nadi Badana,  
\q1 bona iena lalonai be kara dika ta ia noho lasi.   
\c 93  
\s1 Dirava be King  
\q1
\v 1 Lohiabada be King.  
\q1 Ia be mai ena ladana bada momokani.  
\q1 Ia be mai ena goada badana.  
\q1 Ia ese inai tanobada ia karaia goada,  
\q1 bona haida ese idia hamarerea diba lasi.   
\q1
\v 2 Lohiabada e,  
\q1 gabu ibounai, taunimanima ibounai, bona gau ibounai,  
\q1 be idia do vara lasi neganai, oi be oi noho.  
\q1 Oi be oi noho hanaihanai,  
\q1 bona oi be do oi King ela bona hanaihanai.   
\b  
\q1
\v 3 Lohiabada e,  
\q1 davara bada ena dobu gabudia ese edia gadodia idia habadaia.  
\q1 Edia gadodia idia habadaia, bona idia boiboi bada noho,   
\q1
\v 4 Lohiabada e, oi be guba ena King momokani,  
\q1 bona oiemu siahu ese davara bada ena boiboi ia hereaia.  
\q1 Ma oiemu goada ese davara ena hurehure bada ia hereaia.   
\b  
\q1
\v 5 Lohiabada e, oiemu taravatu be idia noho hanaihanai.  
\q1 Momokani, oiemu Dubu Helaga be helaga momokani,  
\q1 ela bona hanaihanai.   
\c 94  
\s1 Dirava be taunimanima ibounai edia Kota Biaguna  
\q1
\v 1 Lohiabada e, oi be dika ena davana oi henia Diravana.  
\q1 Dika davana henia Diravana e,  
\q1 oiemu diari do oi hedinaraia.   
\q1
\v 2 Tanobada oi kota henia Diravana e, do oi toreisi,  
\q1 hekokoroku taudia edia dika davana do oi henia.   
\q1
\v 3 Lohiabada e, kara dika taudia ese,  
\q1 edia kara dikadia dekenai do idia moale noho, a?  
\q1 Dika taudia do idia moale bada noho ela bona edena negai?   
\b  
\q1
\v 4 Inai kara dika taudia ibounai ese,  
\q1 mai hekokoroku danu edia dika idia herevalaia,  
\q1 be do idia hekokoroku noho ela bona edena negai?   
\q1
\v 5 Lohiabada e,  
\q1 idia ese oiemu bese taudia idia moia diho noho.  
\q1 Idia ese oiemu bese korikori taudia idia dagedage henia noho.   
\q1
\v 6 Idia ese vabu bona tamana sinana lasi maragidia idia alaia noho,  
\q1 bona aiemai tano dekenai noho idau taudia idia alaia mase noho.   
\q1
\v 7 Idia gwau, “Lohiabada ese iseda kara ia itaia lasi,  
\q1 Iakobo ena Dirava ese iseda kara ia laloa lasi.”   
\b  
\q1
\v 8 Egu bese taudia e,  
\q1 badina dahaka inai bamona umui be umui kavakava noho?  
\q1 Kavakava taudia e, edena negai aonega do umui davaria?   
\q1
\v 9 Dirava ese iseda taiana ia karaia,  
\q1 be Dirava ese ia kamonai diba lasi, a?  
\q1 Dirava ese iseda matana ia karaia,  
\q1 be Dirava ese ia itaia diba lasi, a?   
\q1
\v 10 Dirava ese bese idauidau ibounai ia biagua noho,  
\q1 be ia ese edia dika davana do ia henia lasi, a?  
\q1 Dirava be taunimanima ibounai edia hadibaia Tauna,  
\q1 vadaeni ia be aonega lasi, a?   
\q1
\v 11 Lohiabada ese taunimanima ibounai edia laloa ia diba.  
\q1 Ia diba edia laloa be anina lasi.   
\b  
\q1
\v 12 Lohiabada e, bema tau ta oi matakani henia neganai,  
\q1 unai tau be do ia namo.  
\q1 Oiemu taravatu ia dekenai oi hadibaia tauna danu,  
\q1 be do ia namo, badina be,   
\q1
\v 13 iena hekwarahi dekena amo oi ese laga-ani oi henia noho.  
\q1 To nega do ia ginidae, kara dika taudia hadikaia ore totona,  
\q1 oi Dirava ese mase ena guri do oi geia.   
\b  
\q1
\v 14 Badina be Lohiabada ese iena bese taudia do ia rakatania lasi.  
\q1 Iena abia hidi besena do ia rakatania lasi.   
\q1
\v 15 Badina kota biagudia ese mai maoromaoro bona momokani sibona,  
\q1 kota hereva do idia gwauraia,  
\q1 bona kara maoromaoro taudia ibounai ese,  
\q1 inai kota maoromaorona do idia durua.   
\b  
\q1
\v 16 Daika ese do ia toreisi, lau do ia durua,  
\q1 vadaeni kara dika taudia do ita koua?  
\q1 Daika do ia toreisi, lauegu kahana dekenai do ia gini,  
\q1 vadaeni kerere taudia do ita koua?   
\q1
\v 17 Bema Lohiabada ese lau ia durua lasi neganai,  
\q1 lau be mai regerege lasi danu,  
\q1 mase ena guri lalonai karaharaga do lau lao.   
\q1
\v 18 Lau gwau, “Lau be lau moru noho.”  
\q1 Unai neganai Lohiabada e,  
\q1 oiemu lalokau bada ese lau ia abia isi lou.   
\q1
\v 19 Egu lalona ia hekwarahi momo neganai,  
\q1 oi ese lau oi hagoadaia,  
\q1 bona egu lauma oi hamoalea noho.   
\b  
\q1
\v 20 Lohia dikadia be oi danu idia gaukara hebou diba, a?  
\q1 Lasi momokani!  
\q1 Idia ese taravatu idia atoa, inai taravatu ia gwau,  
\q1 taunimanima ese kara dika idia karaia be namo.   
\q1
\v 21 Ma inai lohia dikadia ese,  
\q1 tau namodia hadikaia totona idia laloa hebou noho,  
\q1 bona kerere lasi taudia edia latanai,  
\q1 kota hereva be mase idia gwauraia noho.   
\q1
\v 22 To Lohiabada be lauegu kohoro,  
\q1 iena goada ese lau ia naria noho.  
\q1 Egu Dirava ese lau ia gimaia noho.   
\q1
\v 23 Dirava ese unai tau dikadia edia kerere davana,  
\q1 be do ia henidia.  
\q1 Edia dika dainai do ia hadikadia ore.  
\q1 Lohiabada, iseda Dirava, ese idia do ia hadikaia ore momokani.   
\c 95  
\s1 Dirava hanamoa ena ane  
\q1
\v 1 Umui mai! Lohiabada hanamoa totona, ane do ita abia.  
\q1 Mai moale ena boiboi danu,  
\q1 ita ia hamauria Nadi Badana do ita hanamoa!   
\q1
\v 2 Lohiabada ena vairanai do ita haboua mai.  
\q1 Ia hanamoa totona ane do ita abia, mai moale bada danu.   
\b  
\q1
\v 3 Badina ia sibona be Dirava mai siahu badana.  
\q1 Ia be King goadana,  
\q1 bona dirava ibounai be ia ese ia hereaia.   
\q1
\v 4 Ia ese tanobada ibounai ia biagua noho.  
\q1 Tano lalonai idia noho guri dobudia bona nadi kohua badadia,  
\q1 bona ororo badadia momokani danu,  
\q1 be Lohiabada ena imana lalonai idia noho.   
\q1
\v 5 Lohiabada ese davara, ia ese ia karaia gauna ia biagua noho,  
\q1 tano gabudia ibounai danu ia ese ia biagua noho.  
\q1 Ia ese unai gabudia danu ia karadia.   
\b  
\q1
\v 6 Umui mai, iseda kwarana do ita atoa diho,  
\q1 Lohiabada do ita tomadiho henia.  
\q1 Lohiabada ena vairanai do ita tui diho.  
\q1 Ia ese ita ia karaia vadaeni.   
\q1
\v 7 Ia be iseda Dirava.  
\q1 Ia ese ita ia naria namonamo,  
\q1 ita be iena mamoe bamona,  
\q1 bona ia ese ita dekenai aniani ia henia noho.  
\b  
\q1 Hari dina iena hereva do umui kamonai.   
\q1
\v 8 Lohiabada ia gwau, “Oiemu lalona do oi ha-aukaia lasi,  
\q1 oiemu sene taudia idia karaia bamona Meriba dekenai,  
\q1 bona Masa ena taunimanima noho lasi gabuna dekenai danu.   
\q1
\v 9 Unuseni idia ese lau idia dibagania,  
\q1 lau dekenai idia abidadama lasi.  
\q1 Idia ese lauegu kara badadia,  
\q1 idia dekenai lau karaia gaudia idia itaia,  
\q1 to lau dekenai idia abidadama lasi.   
\q1
\v 10 Lagani 40 lalonai unai taudia ese lau idia habadua.  
\q1 Lau gwau,  
\q1 ‘Idia be abidadama diba lasi, idia be hekokoroku momokani,  
\q1 bona egu hereva idia ura lasi idia kamonai henia.’   
\q1
\v 11 Unai dainai lau be badu, bona lau hereva, lau gwau,  
\q1 ‘Momokani, umui be tano namona dekenai do umui vareai lasi.  
\q1 Lau ura unai gabu dekenai laga-ani umui do lau henia,  
\q1 to umui be hegeregere lasi.’ ”   
\c 96  
\s1 Dirava be King Badana momokani  
\q1
\v 1 Lohiabada dekenai ane matamatana do umui abia.  
\q1 Tanobada dekenai noho taudia ibounai e,  
\q1 Lohiabada dekenai ane do umui abia.   
\q1
\v 2 Lohiabada dekenai ane do umui abia.  
\q1 Iena ladana do umui abia isi!  
\q1 Ia ese ita ia hamauria vadaeni!  
\q1 Dina ibounai lalonai inai sivarai namona,  
\q1 be taunimanima dekenai do ita gwauraia.   
\q1
\v 3 Lohiabada ena hairaina be bese idauidau ibounai dekenai,  
\q1 do umui gwauraia hedinarai.  
\q1 Iena kara badadia be idia ibounai dekenai do umui hadibaia.   
\b  
\q1
\v 4 Lohiabada be mai ena ladana badana,  
\q1 inai ladana badana do ita abia isi noho be namo.  
\q1 Ita ese taunimanima edia dirava idauidau do ita gari henia lasi.  
\q1 Lohiabada sibona do ita gari henia bona matauraia.   
\q1
\v 5 Badina be tanobada bese idauidau edia dirava,  
\q1 be dirava koikoi gaudia sibona.  
\q1 To Lohiabada ese guba bona guba noho gaudia ia karaia vadaeni.   
\q1
\v 6 Lohiabada be mai ena hairaina,  
\q1 bona mai King Badana ena siahu danu.  
\q1 Iena Dubu Helaga lalonai,  
\q1 iena siahu bona hairaina idia hedinarai noho.   
\q1
\v 7 Tanobada ena bese taudia ibounai e,  
\q1 Lohiabada do umui hanamoa.  
\q1 Iena hairaina bona iena goada badana do umui hanamoa.   
\q1
\v 8 Lohiabada ena ladana badana do umui abia isi,  
\q1 bona boubou gauna do umui mailaia,  
\q1 iena Dubu Helaga dekenai do umui henia.   
\q1
\v 9 Umui ese mai dabua namodia danu,  
\q1 Lohiabada do umui tomadiho henia.  
\q1 Iena vairana dekenai do umui tui diho mai gari danu.   
\b  
\q1
\v 10 Bese idauidau dekenai inai bamona do umui hereva,  
\q1 do umui gwau, “Lohiabada be King!  
\q1 Ia ese tanobada ia karaia goada,  
\q1 bona tanobada do ia noho namonamo, do ia marere diba lasi.  
\q1 Gabeai Lohiabada ese taunimanima ibounai do ia kota henia.  
\q1 Iena kota be maoromaoro,  
\q1 taunimanima be idauidau, badadia bona maragidia,  
\q1 to maka tamona dekenai do ia kota henidia.”   
\q1
\v 11 Guba bona tanobada e, do umui moale!  
\q1 Davara e, oi bona oi dekenai idia noho gaudia ibounai ese,  
\q1 do umui toreisi, do umui boiboi.   
\q1
\v 12 Uma gabudia ibounai e,  
\q1 umui, bona umui dekenai idia noho aniani gaudia ibounai ese,  
\q1 Lohiabada dainai do umui moale.  
\q1 Iena vairana dekenai,  
\q1 uda dekenai idia noho audia ibounai ese,  
\q1 mai moale danu ane do idia abia.   
\q1
\v 13 Badina be, Lohiabada be do ia mai,  
\q1 tanobada taudia do ia kota henia.  
\q1 Ia ese tanobada taudia,  
\q1 mai maoromaoro bona momokani danu do ia kota henidia.  
\q1 Maka tamona dekenai do ia kota henidia.   
\c 97  
\s1 Dirava be King Badana, ta ia hegeregerena be lasi  
\q1
\v 1 Lohiabada be King! Tanobada, do oi moale!  
\q1 Bona umui davara ena motumotu ibounai do umui moale bada!   
\q1
\v 2 Ori bona dibura ese,  
\q1 Lohiabada ena noho gabuna idia hunia noho.  
\q1 Lohiabada ese taunimanima,  
\q1 be mai maoromaoro bona momokani danu ia biagudia noho.   
\q1
\v 3 Lahi be Lohiabada ena vairana dekenai ia daekau lao noho,  
\q1 bona ia dekenai idia tuari henia taudia,  
\q1 idia hagegea noho taudia,  
\q1 be unai lahi ese ia gabudia ore noho.   
\q1
\v 4 Lohiabada ena kevaru ese tanobada ia hadiaria noho.  
\q1 Tanobada taudia idia itaia neganai idia heudeheude noho.   
\q1
\v 5 Ororo be kandolo bamona idia veve noho,  
\q1 Lohiabada ena vairana dekenai,  
\q1 badina ia be tanobada ena kahana ibounai ena Lohia Badana.   
\q1
\v 6 Guba ese Lohiabada ena kara maoromaoro ia gwauraia hedinarai noho.  
\q1 Bese idauidau ibounai ese iena hairaina idia itaia noho.   
\b  
\q1
\v 7 Kaivakuku idia tomadiho henia taudia ibounai be do idia hemarai,  
\q1 badina dirava ibounai,  
\q1 be Lohiabada ena vairana dekenai do idia tomadiho.   
\b  
\q1
\v 8 Lohiabada e,  
\q1 Siona dekenai noho taudia bona Iuda hanua taudia,  
\q1 be oiemu kota hereva maoromaorodia dainai idia moale bada noho.   
\q1
\v 9 Badina Lohiabada e, oi be Ataiai Momokani Diravana,  
\q1 tanobada kahana ibounai edia latanai.  
\q1 Oi ese dirava ibounai oi hereaia noho momokani.   
\b  
\q1
\v 10 Lohiabada ese kara dika idia ura henia lasi taudia,  
\q1 ia lalokau henidia noho.  
\q1 Ia ese iena bese taudia, ia idia abidadama henia taudia,  
\q1 edia mauri ia gimaia noho,  
\q1 bona kara dika taudia edia siahu dekena amo,  
\q1 ia ese iena taudia ia hamauria noho.   
\q1
\v 11 Kara maoromaoro taudia dekenai,  
\q1 Dirava ese diari ia henia noho,  
\q1 bona taunimanima namodia dekenai,  
\q1 ia ese iena moale ia henia noho.   
\q1
\v 12 Kara maoromaoro taudia ibounai e,  
\q1 Lohiabada ese ia karaia vadaeni karadia dainai do umui moale!  
\q1 Dirava helagana ena kara do umui laloatao,  
\q1 bona do umui tanikiu henia.   
\c 98  
\s1 Dirava be tanobada ena biaguna  
\q1
\v 1 Lohiabada hanamoa totona ane matamata do umui abia.  
\q1 Ia ese hoa karadia ia karaia vadaeni.  
\q1 Ia sibona ena siahu bona iena goada helagana dekena amo,  
\q1 kwalimu ia abia vadaeni, iena.   
\q1
\v 2 Lohiabada ese iena kwalimu ia gwauraia vadaeni.  
\q1 Ia ese Israela ia hamauria neganai,  
\q1 iena siahu ia hedinaraia momokani bese idauidau dekenai.   
\q1
\v 3 Lohiabada ese Israela taudia dekenai iena gwauhamata ia hamomokania.  
\q1 Ia ese Israela taudia ia lalokau henia noho,  
\q1 bona ia ese idia ia rakatania lasi.  
\q1 Tanobada bese idauidau ibounai ese,  
\q1 iseda Dirava ena kwalimu idia itaia vadaeni.   
\b  
\q1
\v 4 Tanobada taudia ibounai e,  
\q1 mai moale bada danu ane do umui abia Lohiabada dekenai!  
\q1 Mai moale danu Lohiabada do umui hanamoa,  
\q1 mai boiboi, bona mai ane abia danu.   
\q1
\v 5 Lohiabada do umui hanamoa ane dekenai!  
\q1 Gita badadia dekenai miusiki do umui gadaralaia.   
\q1
\v 6 Kibi badadia bona kibi maragidia do umui hiriria.  
\q1 Regena mai moale danu, iseda King, Lohiabada,  
\q1 hanamoa totona do umui karaia.   
\q1
\v 7 Davara e, oi bona oiemu lalonai gwarume gaudia ibounai e,  
\q1 do umui boiboi bada herea.  
\q1 Bona tanobada, oi bona oi dekenai idia noho taudia ibounai e,  
\q1 ane do umui abia goada herea.   
\q1
\v 8 Sinavai ibounai e, emui imana do umui patapataia,  
\q1 bona ororo ibounai e,  
\q1 umui ese ane do umui abia hebou mai moale danu,  
\q1 Lohiabada ena vairana dekenai.   
\q1
\v 9 Badina Lohiabada be ia mai noho,  
\q1 tanobada do ia biagua momokani totona.  
\q1 Ia ese tanobada do ia kota henia mai maoromaoro danu,  
\q1 bona tanobada ena bese idauidau edia ahuna korikori,  
\q1 idia dekenai do ia henia.   
\c 99  
\s1 Dirava be King Badana momokani  
\q1
\v 1 Lohiabada be King!  
\q1 Tanobada ena bese idauidau idia heudeheude noho.  
\q1 Lohiabada be iena terona dekenai ia helai noho, kerubi edia huanai.  
\q1 Tanobada ia mareremarere noho.   
\q1
\v 2 Lohiabada be Siona lalonai, bona iena siahu be bada herea,  
\q1 ma Lohiabada ese bese idauidau ia biagua noho.   
\q1
\v 3 Taunimanima ibounai ese,  
\q1 Lohiabada ena ladana badana bona mai garina, be do idia hanamoa.  
\q1 Lohiabada be helaga!   
\b  
\q1
\v 4 Siahu Bada ena King e,  
\q1 oi ese kota maoromaorona oi ura henia noho.  
\q1 Oi ese taunimanima edia ahuna korikori,  
\q1 be idia dekenai oi henia noho.  
\q1 Oi ese kota maoromaoro Israela dekenai oi haginia vadaeni.  
\q1 Oi ese kara maoromaoro bona kara namona oi karaia noho.   
\b  
\q1
\v 5 Lohiabada, iseda Dirava do umui hanamoa.  
\q1 Iena terona ena vairana dekenai do umui tomadiho henia.  
\q1 Lohiabada be helaga!   
\q1
\v 6 Mose bona Arona ruaosi be iena hahelagaia taudia.  
\q1 Samuela danu be Lohiabada ena ladana ia gwauraia tauna ta.  
\q1 Idia ese Lohiabada dekenai idia boiboi,  
\q1 bona ia ese idia dekenai ia haere.   
\q1
\v 7 Ori badana dekena amo ia ese idia dekenai ia hereva.  
\q1 Idia ese iena oda idia badinaia,  
\q1 bona ia henidia taravatu danu idia badinaia.   
\b  
\q1
\v 8 Lohiabada e, aiemai Dirava, oi ese idia dekenai oi haere.  
\q1 Oiemu bese taudia dekenai, oi be dika gwauatao Diravana,  
\q1 to oi be edia dika davana henia Diravana danu.   
\b  
\q1
\v 9 Lohiabada, iseda Dirava do umui hanamoa.  
\q1 Iena ororo helagana dekenai do umui tomadiho,  
\q1 badina be Lohiabada, iseda Dirava, be helaga.   
\c 100  
\s1 Lohiabada ena ladana abia isi ena ane  
\q1
\v 1 Tanobada taudia ibounai e,  
\q1 umui ese Lohiabada hanamoa totona ane do umui abia!   
\q1
\v 2 Lohiabada do umui tomadiho henia,  
\q1 mai emui moale danu.  
\q1 Lohiabada ena vairana dekenai umui mai, mai moale anedia danu.   
\q1
\v 3 Do umui diba momokani, Lohiabada sibona be Dirava.  
\q1 Ia sibona ese ita ia karaia, bona ita be iena.  
\q1 Ita be iena bese taudia,  
\q1 ita be iena mamoe, ia ubua gaudia.   
\b  
\q1
\v 4 Lohiabada ena Dubu Helaga lalonai do ita raka vareai,  
\q1 mai tanikiu danu.  
\q1 Iena Ruma lalonai Lohiabada ena ladana do ita abia isi,  
\q1 Lohiabada do ita tanikiu henia.  
\q1 Iena ladana do ita hanamoa bada,   
\q1
\v 5 badina be Lohiabada ena kara be namo.  
\q1 Iena lalokau bona bogahisihisi,  
\q1 be do idia noho ela bona hanaihanai.  
\q1 Ia ese iena hereva bona iena kara,  
\q1 be do ia haidaua lasi ela bona hanaihanai.   
\c 101  
\s1 King ena gwauhamata  
\q1
\v 1 Lohiabada e, ane ta lau abia inai,  
\q1 abidadama kara bona kota maoromaoro kara lau herevalaia inai.  
\q1 Lohiabada e,  
\q1 oi dekenai inai ane lau abia,  
\q1 oi do lau hanamoa totona.   
\q1
\v 2 Lau ese kara maoromaoro dalana sibona do lau badinaia.  
\q1 Lohiabada e,  
\q1 edena negai lau dekenai do oi mai?  
\b  
\q1 Egu ruma dekenai do lau noho namonamo, mai egu kerere ta lasi.   
\q1
\v 3 Lau ese kara dika ta do lau ura henia lasi, lasi momokani.  
\b  
\q1 Dirava idia ura lasi taudia edia kara,  
\q1 be lau ura lasi momokani.  
\q1 Idia danu do lau noho lasi, lasi momokani.   
\q1
\v 4 Lau ese koikoi karadia do lau karaia lasi,  
\q1 bona kara dika ta do lau laloa lasi momokani.   
\b  
\q1
\v 5 Bema tau ta ese ma tau ta hunia dekenai ia samania neganai,  
\q1 lau ese unai samania hereva ia gwauraia tauna,  
\q1 be do lau alaia mase.  
\q1 Lau ese hekokoroku taudia danu do lau noho lasi.   
\b  
\q1
\v 6 Dirava idia abidadama henia taudia,  
\q1 be be mai laloa namo danu do lau abia dae.  
\q1 Idia be lau dekenai do idia noho.  
\q1 Kerere lasi taudia sibona,  
\q1 be lauegu hesiai gaukara do idia karaia.   
\b  
\q1
\v 7 Koikoi karadia idia karaia noho taudia,  
\q1 be egu ruma dekenai do idia noho lasi.  
\q1 Koikoi hereva ia gwauraia noho tauna ta,  
\q1 be egu vairana dekenai do ia gini noho lasi.   
\b  
\q1
\v 8 Dina ta ta dekena amo, lau ese kara dika taudia ibounai,  
\q1 be inai tano dekenai do lau alaia mase.  
\q1 Dika taudia ibounai be,  
\q1 Dirava ena hanua dekena amo do lau lulua ore.   
\c 102  
\s1 Mai ena hisihisi eregabe tauna ta ena guriguri  
\q1
\v 1 Lohiabada e, egu guriguri do oi kamonai.  
\q1 Lau do oi durua totona,  
\q1 egu noinoi mani do oi kamonai henia.   
\q1
\v 2 Egu hisihisi dinana dekenai,  
\q1 oiemu vairana be lau dekena amo mani do oi hunia lasi.  
\q1 Egu hereva mani do oi kamonai,  
\q1 bona lau boiboi neganai,  
\q1 mani emu kara lau dekenai do oi haere haraga.   
\b  
\q1
\v 3 Badina be egu mauri dinadia be idia ore haraga,  
\q1 kwalahu ia ore haraga bamona,  
\q1 bona egu kopina be ia siahu bada,  
\q1 lahi ese ia gabua noho bamona.   
\q1
\v 4 Egu kudouna be ia manoka,  
\q1 taunimanima ese idia moia patapata rei bamona.  
\q1 Lau be aniani ania lau ura lasi.   
\q1
\v 5 Mai boiboi danu lau tai noho,  
\q1 bona egu tauanina be ia maragi lao noho.   
\q1
\v 6 Lau be manu ta,  
\q1 tano kaukau dekenai sibona ia noho gauna bamona.  
\q1 Lau be baimumu manu bamona,  
\q1 ia dika vadaeni taunimanima noho lasi gabuna dekenai lau noho.   
\q1
\v 7 Mahuta patana dekenai lau hekure noho,  
\q1 to lau noga noho ela bona dabai.  
\q1 Lau be ruma ena guhi dekenai sibona ia noho manu bamona.   
\q1
\v 8 Dina bona hanuaboi,  
\q1 lau idia hadikaia gwauraia taudia ese lau idia kirikirilaia noho.  
\q1 Lau idia kirikirilaia taudia ese,  
\q1 egu ladana be hadikaia gauna idia halaoa noho.   
\q1
\v 9 Badina lau ese aniani totona lahi ena kahu lau ania noho,  
\q1 bona egu matana ena ranu,  
\q1 be egu inua ranu kapusi lalonai ia diho, lau inua noho.   
\q1
\v 10 Inai be oiemu badu bona dagedage dainai,  
\q1 badina be oi ese lau oi abia isi,  
\q1 bona lau oi negea siri vadaeni.   
\q1
\v 11 Egu mauri dinadia be nega kwadogina sibona,  
\q1 hegeregere dina be adorahi neganai ia diho bamona.  
\q1 Lau be rei ia kakoro haraga bamona.   
\b  
\q1
\v 12 To Lohiabada e, oi be King, ia lao bona hanaihanai.  
\q1 Gabeai do idia vara bese ibounai taudia ese,  
\q1 oiemu ladana do idia laloa noho.   
\q1
\v 13 Oi be do oi toreisi, Siona do oi bogahisihisi henia.  
\q1 Nega ia ginidae vadaeni,  
\q1 oi ese Siona dekenai do oi laloa namo henia.  
\q1 Oi gwauraia guna ena nega ia ginidae vadaeni.   
\q1
\v 14 Badina be oiemu hesiai taudia ese,  
\q1 Siona ena nadi ibounai idia ura henia noho,  
\q1 bona Siona ena tano kahuna idia lalokau henia noho.   
\q1
\v 15 Bese idauidau ese Lohiabada ena ladana do idia gari henia.  
\q1 Tanobada ena king taudia ibounai ese,  
\q1 oiemu hairaina do idia matauraia.   
\q1
\v 16 Badina be Lohiabada ese Siona do ia haginia lou,  
\q1 bona ia ese iena siahu badana do ia hedinaraia.   
\q1
\v 17 Ia ese iena bese ena ogogami taudia edia guriguri,  
\q1 be do ia kamonai,  
\q1 bona edia noinoi do ia laloa.   
\b  
\q1
\v 18 Inai kara, Lohiabada ese ia karaia vadaeni gaudia,  
\q1 be do umui torea,  
\q1 gabeai do idia vara bese taudia do idia diba totona,  
\q1 bona idia do vara lasi taudia ese,  
\q1 unai neganai Lohiabada do idia hanamoa.   
\q1
\v 19 Lohiabada ese iena gabu helagana dekena amo,  
\q1 iena matana ia negea.  
\q1 Guba dekena amo Lohiabada ese tanobada ia itaia.   
\q1
\v 20 Dibura ruma dekenai idia noho taudia edia taitai ia kamonai,  
\q1 bona kota hereva ia gwau do idia mase taudia,  
\q1 be Lohiabada ese dibura dekena amo ia kokia ruhaia.   
\q1
\v 21 Unai dainai Lohiabada ena ladana,  
\q1 be Siona taudia ese do idia abia isi,  
\q1 bona Ierusalema dekenai Lohiabada do idia hanamoa.   
\q1
\v 22 Unai neganai bese idauidau bona basileia idauidau,  
\q1 be do idia haboua,  
\q1 idia ese Lohiabada do idia tomadiho henia.   
\b  
\q1
\v 23 Lau be uhau sibona neganai,  
\q1 Lohiabada ese egu goada ia hamaragia.  
\q1 Ia ese egu mauri dinadia ia hakwadogia,  
\q1 vadaeni do lau mauri daudau lasi.   
\q1
\v 24 Unai dainai lau gwau:  
\q1 Egu Dirava e, oi noho hanaihanai.  
\q1 Mani emu kara egu mauri dinadia do oi utua haraga lasi!  
\q1 Lau be buruka lasi,  
\q1 lau be do uhau sibona!   
\q1
\v 25 Oi ese gunaguna tanobada oi karaia,  
\q1 bona oiemu imana dekena amo guba danu oi karaia.   
\q1
\v 26 Idia be do idia ore,  
\q1 to oi be do oi noho.  
\q1 Idia be do idia dika lao,  
\q1 dabua idia dika lao bamona.  
\q1 Bona oi ese idia do oi negea,  
\q1 dabua gunadia idia negea bamona,  
\q1 ma do idia boio momokani.   
\q1
\v 27 To Lohiabada e,  
\q1 oi be do oi idau lasi,  
\q1 bona oiemu mauri lagani do idia doko lasi.   
\q1
\v 28 Ai, oiemu hesiai taudia,  
\q1 aiemai natudia be oi ese do oi naridia dainai,  
\q1 do idia noho namonamo,  
\q1 bona edia bese taudia danu,  
\q1 be oiemu vairana dekenai do idia noho namonamo nega ibounai.   
\c 103  
\s1 Dirava ena lalokau  
\q1
\v 1 Lauegu lauma e,  
\q1 Lohiabada do oi hanamoa.  
\q1 Lauegu lalona e,  
\q1 Lohiabada ena ladana helagana do oi hanamoa.   
\q1
\v 2 Lauegu lauma e,  
\q1 Lohiabada do oi hanamoa.  
\q1 Iena hariharibada ibounai do oi laloaboio lasi.   
\b  
\q1
\v 3 Ia ese egu kara dika ibounai ia gwauatao noho.  
\q1 Ia ese egu gorere ibounai dekena amo lau ia hamauria noho.   
\q1
\v 4 Lauegu mauri be mase ena guri dekena amo,  
\q1 Lohiabada ese ia hamauria noho.  
\q1 Ia ese lalokau bona bogahisihisi lau dekenai ia henia noho.   
\q1
\v 5 Lauegu mauri be gau namodia dekena amo ia ubua noho.  
\q1 Unai dainai egu eregabe be ia matamata lou,  
\q1 ugava manu ena goada bamona.   
\q1
\v 6 Dagedage taudia ese idia hadikaia taudia,  
\q1 be Dirava ese ia durudia noho,  
\q1 bona mai kara maoromaoro bona laloa maoromaoro danu,  
\q1 ia ese edia kota do ia karaia.   
\q1
\v 7 Lohiabada ese iena dala Mose dekenai ia hadibaia,  
\q1 bona iena kara danu,  
\q1 be Lohiabada ese Israela taudia dekenai ia hedinaraia.   
\q1
\v 8 Lohiabada be mai ena bogahisihisi, bona mai ena hariharibada.  
\q1 Ia ese iena badu ia hakerua noho.  
\q1 Iena lalokau bona bogahisihisi be bada herea.   
\q1
\v 9 Ia ese ita do ia gwau henia hanaihanai lasi.  
\q1 Iena badu be hanaihanai do ia noho lasi.   
\q1
\v 10 Iseda kara dika ena bada hegeregerena davana ia henia lasi.  
\q1 Ita ese kara dika momo ita karaia vadaeni,  
\q1 bona Dirava ese kerere davana bada herea ia henia diba,  
\q1 to unai bamona ia karaia lasi.   
\q1
\v 11 Dirava ese ia dekenai idia gari taudia,  
\q1 be ia lalokau henia momokani.  
\q1 Iena lalokau idia dekenai be bada herea,  
\q1 hegeregere guba be tanobada ena ataiai daudau herea ia noho bamona.   
\q1
\v 12 Dina ia daekau kahana,  
\q1 bona dina ia diho kahana be daudau herea.  
\q1 Unai daudauna hegeregerena be Dirava ese,  
\q1 iseda kara dika ita dekena amo ia kokidia lao vadaeni.   
\q1
\v 13 Tamana taudia be edia natuna dekenai idia bogahisihisi noho.  
\q1 Inai bamona danu Lohiabada ese,  
\q1 ia dekenai idia gari taudia ia bogahisihisi henidia noho.   
\q1
\v 14 Dirava ia diba,  
\q1 ita be tanobada ena kahu dekena amo ita ia karaia.  
\q1 Bona ita dekenai ia laloa noho, ita be kahu sibona.   
\q1
\v 15 Iseda mauri tanobada dekenai be kwadogi momokani,  
\q1 rei bamona.  
\q1 Ita be au ena herahera bamona nega sisina sibona ita noho,  
\q1 vadaeni ita mase.   
\q1
\v 16 Lai ese unai herahera ia hodaia lao,  
\q1 vadaeni ia boio,  
\q1 bona taunimanima idia itaia lou lasi.   
\q1
\v 17 To Lohiabada idia gari henia taudia,  
\q1 be Lohiabada ese do ia bogahisihisi henidia hanaihanai,  
\q1 bona ia dekenai idia gari taudia edia natudia bona tubudia,  
\q1 be Lohiabada ese do ia hanamodia momokani.   
\q1
\v 18 Bona bema Lohiabada ena gwauhamata taravatuna,  
\q1 be idia badinaia bona matauraia,  
\q1 bona iena taravatu ibounai bema idia kamonai henia,  
\q1 mai edia momokani danu,  
\q1 ia ese idia do ia gwauraia maoromaoro taudia.   
\b  
\q1
\v 19 Lohiabada be guba ena King momokani,  
\q1 bona ia be taunimanima, aneru, bona gau ibounai edia biaguna.   
\b  
\q1
\v 20 Lohiabada ena aneru ibounai e,  
\q1 umui be mai emui goada badana.  
\q1 Umui ese Lohiabada ena hereva umui badinaia noho,  
\q1 bona emui taiana umui kehoa noho Lohiabada ena hereva dekenai.  
\q1 Lohiabada ena ladana do umui hanamoa bada.   
\q1
\v 21 Lohiabada ena hesiai taudia,  
\q1 guba dekenai umui noho, bona Lohiabada ena ura umui karaia noho.  
\q1 Umui ese Lohiabada ena ladana do umui abia isi.   
\q1
\v 22 Lohiabada ese ia karaia gaudia ibounai,  
\q1 ia ese ia biagua gabu ibounai dekenai umui noho,  
\q1 Lohiabada ena ladana do umui hanamoa bada.  
\q1 Egu lauma e,  
\q1 Lohiabada do oi hanamoa bada!   
\c 104  
\s1 Dirava ese gau ibounai ia karaia. Ita ese ia do ita hanamoa  
\q1
\v 1 Lauegu lauma e,  
\q1 Lohiabada do oi hanamoa.  
\q1 Lohiabada e, oi be lauegu Dirava,  
\q1 oiemu siahu be bada herea momokani.  
\q1 Oi be King hereadaena,  
\q1 oiemu hairaina be namo herea momokani.   
\q1
\v 2 Oi sibona dekenai diari oi atoa, dabua bamona.  
\q1 Oi ese guba bona hisiu oi karaia,  
\q1 tau ta ese palai ruma ia haginia bamona,   
\q1
\v 3 bona oi ese oiemu ruma,  
\q1 be ranu ena latanai oi haginia, guba dekenai.  
\q1 Ori be oiemu kariota bamona,  
\q1 bona lai ese oi ia hodaia, oi heau lao.   
\q1
\v 4 Oi ese lai oi siaia lao,  
\q1 idia ese oiemu hesiai gaukara idia karaia noho.  
\q1 Kevaru danu ese oiemu gaukara ia karaia noho.   
\b  
\q1
\v 5 Oi ese inai tanobada oi karaia goada,  
\q1 ena gabu korikori dekenai,  
\q1 bona inai tanobada ia goada noho,  
\q1 ia marere sisina diba lasi, lasi momokani.   
\q1
\v 6 Oi ese davara oi karaia,  
\q1 ia ese tano ia koua noho.  
\q1 Ena ranu ese danu ororo ibounai ia koua.   
\q1
\v 7 Oi ese unai ranu oi gwau henia neganai,  
\q1 ia heau lou, ia giroa lou.  
\q1 Davara bona ranu ese,  
\q1 oiemu oda mai boiboi danu idia kamonai neganai,  
\q1 idia heau lou momokani.   
\q1
\v 8 Ranu ese ororo ibounai idia rakatania,  
\q1 bona koura gabudia dekenai idia diho lao.  
\q1 Oi ese maka oi atoa unai ranu do ia noho totona.   
\q1
\v 9 Oi ese maka oi atoa,  
\q1 vadaeni ranu ese unai maka do ia hanaia diba lasi,  
\q1 vadaeni unai tano do ia koua lou diba lasi.   
\q1
\v 10 Oi ese koura gabudia dekenai,  
\q1 guri dekena amo ranu oi abia daekau,  
\q1 bona sinavai oi siaia,  
\q1 idia ese ororo edia huanai dekenai idia heau lao.   
\q1
\v 11 Uda boroma idauidau ese unai ranu idia inua noho,  
\q1 bona uda doniki danu ese idia inua,  
\q1 vadaeni edia ranu mase ia ore.   
\q1
\v 12 Ataiai dekenai idia roho manudia edia ruma,  
\q1 be unai sinavai badinai audia lalonai idia karaia.  
\q1 Idia be unai gabudia lalonai idia helai,  
\q1 ane idia abia noho.   
\q1
\v 13 Lohiabada e, oiemu gabu, guba dekenai oi noho.  
\q1 Oi ese medu oi siaia diho, ororo edia latanai ia moru,  
\q1 bona tano be oiemu hanamoa gaudia dekenai ia honu.   
\q1
\v 14 Oi ese rei oi hatubua,  
\q1 boromakau do idia ania totona.  
\q1 Oi dainai, ai taunimanima ese,  
\q1 aniani avadia idauidau ai hadoa diba, aiemai aniani totona:   
\q1
\v 15 Ai ese vain ai hadoa diba,  
\q1 bona uaina ai karaia,  
\q1 aiemai lalona do idia moale totona.  
\q1 Bona ai ese olive ai havaraia diba,  
\q1 olive ena dehoro ese aiemai kopina do ia hanamoa totona.  
\q1 Bona oi dainai ai ese uiti uhena ai hadoa diba,  
\q1 bona uiti dekena amo beredi ai karaia,  
\q1 aiemai tauanina do idia goada totona.   
\q1
\v 16 Lebanona ena sida audia idia noho gabuna dekenai,  
\q1 be medu momo ia diho.  
\q1 Inai audia be Lohiabada sibona ena,  
\q1 ia ese idia ia hadoa.   
\q1
\v 17 Unai sida audia lalonai,  
\q1 ataiai manudia ese edia ruma idia karaia.  
\q1 To aiona lata manudia,  
\q1 be au idauidau lalonai edia ruma idia karaia.   
\q1
\v 18 Uda nanigosi be ororo badadia lalonai idia noho,  
\q1 bona magani ese,  
\q1 ororo ena nadi badadia henunai idia hunia noho.   
\b  
\q1
\v 19 Lohiabada e,  
\q1 oi ese hua oi karaia,  
\q1 bona ia ese aiemai lagani ena hua ta ta ibounai ia makaia noho.  
\q1 Bona dina danu oi karaia,  
\q1 ia be ena diho negana ia diba.   
\q1
\v 20 Oi ese dibura oi karaia vadaeni,  
\q1 hanuaboi ena nega be unai.  
\q1 Uda boroma idauidau be hanuaboi lalonai idia raka loaloa noho.   
\q1
\v 21 Laiona be idia labana neganai idia boiboi noho.  
\q1 Idia ese Dirava ia henia aniani idia tahua noho.   
\q1
\v 22 Dina ia daekau neganai,  
\q1 idia ese edia noho gabudia dekenai idia giroa lou, idia hekure.   
\q1
\v 23 Bona taunimanima idia toreisi,  
\q1 edia gaukara idia karaia noho, ela bona dina ia diho.   
\b  
\q1
\v 24 Lohiabada e, oi ese gau ibounai oi karaia vadaeni.  
\q1 Mai oiemu aonega bada danu idia ibounai oi karaia.  
\q1 Inai oi ese oi karaia gaudia ibounai ese,  
\q1 inai tanobada idia hahonua momokani.   
\q1
\v 25 Davara be ia bada herea momokani,  
\q1 bona mauri gaudia momo,  
\q1 badadia bona maragidia,  
\q1 be davara lalonai idia noho,  
\q1 duahia diba lasi.   
\q1
\v 26 Sisima idauidau ese davara dekenai idia heau noho,  
\q1 bona dagedage gauna badana momokani,  
\q1 ladana Leviatano be davara lalonai ia gadara noho.  
\q1 Oi ese gunaguna unai dagedage gauna badana oi karaia.   
\q1
\v 27 Idia ibounai be oi dekenai idia naria noho,  
\q1 badina oi ese edia aniani oi henia.  
\q1 Idia hitolo neganai aniani oi henidia.   
\q1
\v 28 Oi ese aniani idia dekenai oi henia, bona idia ania.  
\q1 Oi sibona ese oi henia,  
\q1 bona edia bogana idia kunu.   
\q1
\v 29 Bema oi ese idia dekena amo oi raka siri sisina,  
\q1 unai neganai idia be idia gari.  
\q1 Bona bema oi ese edia lagana oi hadokoa neganai,  
\q1 idia be idia mase,  
\q1 bona kahu dekenai ma idia giroa lou,  
\q1 kahu ma idia do oi halaoa lou.   
\q1
\v 30 To bema laga oi henidia neganai,  
\q1 idia be mauri idia davaria.  
\q1 Oi ese gau ibounai oi karaia matamata diba tanobada dekenai.   
\b  
\q1
\v 31 Lau ura Lohiabada ena ladana bada bona iena hairaina,  
\q1 be hanaihanai do ia noho!  
\q1 Lau ura ia ese ia karaia vadaeni gaudia dainai,  
\q1 be do ia moale.   
\q1
\v 32 Lohiabada ese tano ia itaia neganai,  
\q1 unai tano be ia heudeheude.  
\q1 Ia ese ororo dekenai iena imana ia atoa neganai,  
\q1 kwalahu be unai ororo dekenai ia daekau.   
\b  
\q1
\v 33 Lauegu mauri dinadia idia do noho neganai,  
\q1 lau ese Lohiabada dekenai ane do lau abia.  
\q1 Lau ese ane dekenai Lohiabada do lau hanamoa noho,  
\q1 ela bona lau mase.   
\q1
\v 34 Lau ura egu ane dekenai Lohiabada do ia moale,  
\q1 badina be egu moale, be ia dekena amo lau abia vadaeni.   
\q1
\v 35 Lohiabada e,  
\q1 oi ese kara dika taudia tanobada dekena amo do oi lulua,  
\q1 do oi hadikadia ore.  
\q1 Kara kerere taudia do oi haorea momokani.  
\b  
\q1 Lauegu lauma e,  
\q1 Lohiabada do oi hanamoa bada,  
\q1 Lohiabada do oi hanamoa.   
\c 105  
\s1 Dirava, bona iena bese taudia  
\q1
\v 1 Lohiabada do ita tanikiu henia,  
\q1 bona iena ladana badana do ita gwauraia hedinarai.  
\q1 Tanobada ena bese idauidau ibounai dekenai,  
\q1 Lohiabada ena kara badadia do ita hamaoroa.   
\q1
\v 2 Ane do ita abia,  
\q1 bona Lohiabada ena ladana do ita abia isi.  
\q1 Iena kara badadia bona namodia,  
\q1 ia ese ia karaia gaudia do ita gwauraia hedinarai.   
\q1
\v 3 Ita be Lohiabada ena, unai dainai do ita moale bada noho.  
\q1 Lohiabada idia tahua taudia edia lalona be do idia moale.   
\q1
\v 4 Durua totona Lohiabada dekenai ita lao be namo,  
\q1 bona Lohiabada kahirakahira do ita noho nega ibounai be namo.   
\q1
\v 5-6 Umui be Aberahamo, Lohiabada ena hesiai tauna ena tubuna.  
\q1 Umui be Iakobo, Lohiabada ese ia abia hidi tauna,  
\q1 ena tubuna taudia danu.  
\q1 Dirava ese ia karaia kara badadia do umui laloa,  
\q1 bona tau dikadia edia kerere davana be Dirava ese ia henia,  
\q1 be unai danu do umui laloa.   
\b  
\q1
\v 7 Lohiabada be iseda Dirava.  
\q1 Iena taravatu be inai tanobada taudia ibounai totona,  
\q1 ia ese ia karadia.   
\q1
\v 8 Lohiabada ese ia karaia gwauhamata taravatuna,  
\q1 be hanaihanai do ia badinaia.  
\q1 Iena gwauhamata danu be do ia laloa noho uru ibounai 1000.   
\q1
\v 9 Aberahamo danu Lohiabada ese ia karaia gwauhamata taravatuna,  
\q1 be ia ese do ia badinaia,  
\q1 Isako dekenai ia karaia gwauhamata danu do ia hamomokania.   
\q1
\v 10 Lohiabada ese Iakobo danu gwauhamata taravatuna ia karaia.  
\q1 Inai be ia noho hanaihanai gauna.  
\q1 Ia ese inai gwauhamata taravatuna Israela ena bese danu ia karaia,  
\q1 bona inai be do ia doko diba lasi gauna.   
\q1
\v 11 Lohiabada ese Iakobo dekenai ia hereva inai bamona:  
\q1 “Lau ese Kanana tano oi dekenai do lau henia,  
\q1 bona inai tano be oi bona oiemu tubuna ese do umui biagua.”   
\b  
\q1
\v 12 Dirava ena bese taudia be momo lasi,  
\q1 bona idia be idau taudia bamona Kanana dekenai idia noho.   
\q1
\v 13 Tano dekenai idia noho namonamo lasi,  
\q1 to tano kahana dekena amo idia loaloa, ela bona tano kahana dekenai.  
\q1 King ta ena tano dekenai nega sisina idia noho,  
\q1 vadaeni ma idia toreisi,  
\q1 king ma ta ena tano dekenai idia lao.   
\q1
\v 14 To Lohiabada ese Israela besena ia naria,  
\q1 dagedage bona dika momokani dekena amo ia ese ia gimadia.  
\q1 Bona Lohiabada ese king haida ia sisiba henidia,  
\q1 Israela taudia do idia hadikaia lasi totona.   
\q1
\v 15 Lohiabada ia gwau,  
\q1 “Lau ese lau abia hidi bese taudia,  
\q1 be do umui hisihisi henidia lasi.  
\q1 Lauegu peroveta taudia do umui hadikaia lasi.”   
\q1
\v 16 Lohiabada ese hitolo bada edia tano dekenai ia havaraia.  
\q1 Edia aniani ibounai idia dekena amo ia kokia.   
\q1
\v 17 To Lohiabada ese Iosepa ia siaia guna,  
\q1 Aigupito dekenai ia noho guna.  
\q1 Idia hoia, hesiai tauna mai guia danu idia halaoa.   
\q1
\v 18 Iena aena be seini dekena amo idia kwatua,  
\q1 unai be mai hisihisi,  
\q1 bona iena aiona dekenai auri dekena amo idia guia.   
\q1
\v 19 Unai bamona ia noho,  
\q1 ela bona ia ese ia gwauraia guna hereva be idia vara.  
\q1 Lohiabada ena hereva ese,  
\q1 ia hedinaraia Iosepa ena hereva be maoro.   
\q1
\v 20 Unai neganai Aigupito ena king ese,  
\q1 dibura ruma dekena amo Iosepa ia ruhaia.  
\q1 Unai idau bese ena king ese,  
\q1 Iosepa ena hisihisi dibura ruma lalonai ia haorea.   
\q1
\v 21 King ese Iosepa dekenai gaukara badana ia henia,  
\q1 ia ese iena gavamani ena gunalaia tauna ia halaoa.  
\q1 Vadaeni Iosepa be Aigupito ena gavana badana ia lao.   
\q1
\v 22 Ia ese king ena opesa taudia ia biagua,  
\q1 bona ia ese,  
\q1 king idia sisiba henia taudia ia hadibaia dahaka do idia gwau.   
\b  
\q1
\v 23 Gabeai Iakobo be Aigupito dekenai ia lao,  
\q1 Aigupito dekenai ia noho.   
\q1
\v 24 Lohiabada ese,  
\q1 natuna bona tubuna momo herea Iakobo dekenai ia henia,  
\q1 bona idia edia goada ese,  
\q1 idia dagedage henidia taudia edia goada ia hereaia.   
\q1
\v 25 Vadaeni Lohiabada ese Aigupito taudia edia laloa ia haidaua.  
\q1 Idia ese Israela taudia idia badu henia,  
\q1 bona idia ese edia hesiai taudia, Israela taudia,  
\q1 idia koia noho.   
\q1
\v 26 Lohiabada ese Mose ia siaia,  
\q1 Arona danu, ia abia hidi tauna, be Lohiabada ese ia siaia.   
\q1
\v 27 Idia ese Dirava ena kara badadia idia karaia,  
\q1 Aigupito dekenai hoa karadia idia karaia.   
\q1
\v 28 Dirava ese Aigupito dekenai dibura ia siaia,  
\q1 tano ibounai ia dibura.  
\q1 To Aigupito taudia ese iena oda hereva idia kamonai henia lasi.   
\q1
\v 29 Aigupito taudia edia ranu gabudia,  
\q1 be rara dekenai Dirava ese ia halaoa,  
\q1 bona edia gwarume ibounai idia mase.   
\q1
\v 30 Edia tano be Lohiabada ese paroparo dekena amo ia hahonua.  
\q1 Edia king ena ruma dekenai danu paroparo idia noho.   
\q1
\v 31 Dirava ese ia oda,  
\q1 vadaeni lao momo idia mai,  
\q1 bona nemo momo danu ese edia tano ibounai idia hahonua.   
\q1
\v 32 Dirava ese medu momokani ia siaia diho lasi,  
\q1 to aisi nadi bamona ia siaia diho,  
\q1 bona kevaru danu Aigupito tano dekenai ia havaraia.   
\q1
\v 33 Aigupito taudia edia vain audia,  
\q1 bona edia fig audia Dirava ese ia hadikaia ore,  
\q1 bona au ibounai danu ia hamakohia ore.   
\q1
\v 34 Lohiabada ia hereva sibona,  
\q1 vadaeni kwadi momo herea idia hedinarai.  
\q1 Idia be momo herea, duahia diba lasi.   
\q1
\v 35 Kwadi ese tano ena ava bona au edia raudia idia ania ore.  
\q1 Uiti bona koni ibounai danu idia ania ore.   
\q1
\v 36 Bona Dirava ese Aigupito edia famili ibounai,  
\q1 edia vara guna natuna tau ia alaia mase.   
\b  
\q1
\v 37 Unai neganai Dirava ese Israela taudia ibounai,  
\q1 be Aigupito dekena amo ia hakaua.  
\q1 Idia ese siliva bona golo idia huaia mai,  
\q1 bona idia ibounai be mai edia mauri namo,  
\q1 bona mai edia goada danu.   
\q1
\v 38 Aigupito taudia be Israela taudia dainai idia gari.  
\q1 Vadaeni Israela taudia idia toreisi, idia raka siri neganai,  
\q1 Aigupito taudia idia moale.   
\q1
\v 39 Dirava ese iena bese taudia,  
\q1 be ori dekena amo ia koudia,  
\q1 bona hanuaboi lalonai ia ese lahi badana ia atoa,  
\q1 diari do idia abia totona.   
\q1
\v 40 Idia be aniani totona idia noinoi,  
\q1 vadaeni Dirava ese kibi manudia ia siaia diho,  
\q1 bona aniani momo be guba dekena amo ia siaia, ia henidia.   
\q1
\v 41 Nadi badana be Dirava ese ia kehoa,  
\q1 bona ranu be ia heau lao.  
\q1 Tano kaukau dekenai ia heau, sinavai bamona.   
\q1
\v 42 Badina be Dirava ese iena gwauhamata helagana ia laloa noho,  
\q1 iena hesiai tauna Aberahamo dekenai ia henia gauna.   
\q1
\v 43 Unai bamona be Dirava ese,  
\q1 iena abia hidi bese taudia ia hakaudia mai.  
\q1 Idia ese mai ane bona mai moale bada danu idia raka lao.   
\q1
\v 44 Bese idauidau edia tano be Dirava ese ia henidia,  
\q1 vadaeni idia ese unai bese taudia edia tano ena anina,  
\q1 be idia abia.   
\q1
\v 45 Lohiabada ese unai bamona ia karaia,  
\q1 Israela taudia ese iena oda hereva ibounai,  
\q1 bona iena taravatu ibounai,  
\q1 do idia kamonai henia totona.  
\q1 Lohiabada do ita hanamoa bada!   
\c 106  
\s1 Lohiabada ese iena bese taudia ia naria namonamo  
\q1
\v 1 Lohiabada do umui hanamoa!  
\q1 Lohiabada do umui tanikiu henia, badina ia be namo.  
\q1 Iena lalokau bona bogahisihisi do idia noho ela bona hanaihanai.   
\q1
\v 2 Daika ese Lohiabada ena siahu karadia ia herevalaia diba?  
\q1 Daika ese Lohiabada do ia hanamoa haorea momokani diba?   
\q1
\v 3 Mai edia laloa maoromaoro bona edia momokani taudia be namo.  
\q1 Nega ibounai kara maoromaoro idia karaia taudia danu be namo.   
\q1
\v 4 Lohiabada e, oiemu orea taudia do oi hanamoa neganai,  
\q1 lau danu do oi laloa.  
\q1 Oiemu bese taudia oi hamauria neganai,  
\q1 lau danu do oi durua.   
\q1
\v 5 Unai neganai lau ese,  
\q1 oiemu abia hidi taudia edia noho namo do lau itaia,  
\q1 bona edia moale be do lau moalelaia.  
\q1 Ai be do ai moale,  
\q1 badina ai be oiemu bese korikori taudia.   
\b  
\q1
\v 6 Ai ese ai kara dika, aiemai tamadia idia kara dika bamona.  
\q1 Ai ese ai kara kerere,  
\q1 bona dika ai karaia vadaeni.   
\q1
\v 7 Aiemai sene taudia be Aigupito dekenai idia noho neganai,  
\q1 idia ese oiemu hoa karadia idia laloa lasi.  
\q1 Oiemu lalokau nega momo oi hedinaraia, to idia laloatao lasi.  
\q1 Bona idia ese Siahu Ibounai Dirava dekenai idia dagedage,  
\q1 Davara Kakakaka dekenai.   
\q1
\v 8 To iena gwauhamata dainai, ia ese idia ia hamauria,  
\q1 iena siahu badana do ia hedinaraia totona.   
\q1
\v 9 Davara Kakakaka be ia ese ia gwau henia,  
\q1 vadaeni ia kaukau lao.  
\q1 Ia ese dobu gabuna dekena amo iena bese ia hakaudia,  
\q1 tano kaukau dekena amo do ia hakaudia hegeregerena.   
\q1
\v 10 Unai kara dekena amo Dirava ese Israela taudia ia hamauria,  
\q1 idia badu henidia taudia dekena amo.  
\q1 Idia hadikaia ore gwauraia taudia dekena amo,  
\q1 Dirava ese ia hakaudia mauri.   
\q1
\v 11 Davara ese Israela idia badu henia taudia ia koua momokani,  
\q1 bona idia ta ia heau mauri lasi.   
\q1
\v 12 Unai neganai,  
\q1 Israela taudia ese Lohiabada ena gwauhamata idia hamomokania,  
\q1 bona ia hanamoa totona ane idia abia.   
\b  
\q1
\v 13 To idia ese Lohiabada ena kara idia laloaboio haraga.  
\q1 Iena sisiba kamonai totona idia naria lasi.   
\q1
\v 14 Tano kaukau dekenai Israela taudia idia ura kava, ura kava noho,  
\q1 bona unuseni idia ese Dirava idia tohoa.   
\q1
\v 15 Vadaeni ia ese edia ura gauna ia henidia,  
\q1 to gorere dikana ia siaia,  
\q1 idia edia tauanidia ia hadikaia.   
\b  
\q1
\v 16 Idia edia kamepa dekenai idia ese Mose bona Arona,  
\q1 Lohiabada ena helaga taudia idia mama henia.   
\q1
\v 17 Unai neganai tano ese iena uduna ia kehoa,  
\q1 guri badana ia vara,  
\q1 bona Datana be unai guri lalonai ia moru,  
\q1 tano ese ia koua, ia mase.  
\q1 Inai guri ese Abirama ena orea taudia danu ia hadonoa,  
\q1 ibounai be tano ese ia koudia, idia mase.   
\q1
\v 18 Lahi danu be edia orea taudia edia latanai ia diho,  
\q1 bona unai tau dikadia ia gabudia ore.   
\b  
\q1
\v 19 Sinai Ororo dekenai Israela taudia ese,  
\q1 boromakau ena natuna ena laulauna idia karaia.  
\q1 Idia ese unai golo kaivakuku dekenai idia tomadiho henia.   
\q1
\v 20 Idia ese Dirava ena hairaina idia rakatania,  
\q1 bona boromakau tau,  
\q1 rei ia ania gauna ena laulau,  
\q1 be Dirava ena gabu dekenai idia atoa.   
\q1
\v 21 Idia ese Dirava,  
\q1 edia hamauria Diravana,  
\q1 Aigupito dekenai kara badadia ia karaia Diravana idia laloaboio.   
\q1
\v 22 Ia ese Hamo ena tano dekenai hoa karadia ia karaia,  
\q1 bona Davara Kakakaka ena isena dekenai,  
\q1 gari bada karadia ia karaia, ani?   
\q1
\v 23 Vadaeni Dirava ia gwau iena bese taudia do ia hadikaia ore,  
\q1 to ia ese ia abia hidi tauna Mose,  
\q1 be unai bese taudia bona Dirava edia huanai ia gini.  
\q1 Mose ese Dirava ena badu ia hakerua,  
\q1 ia ese iena bese taudia do ia alaia ore garina.   
\b  
\q1
\v 24 Unai murinai idia ese,  
\q1 Dirava ia herevalaia tano namona idia ura lasi.  
\q1 Idia ese Dirava ena gwauhamata idia abidadama henia lasi.   
\q1
\v 25 Edia palai rumadia dekenai idia hereva badubadu,  
\q1 bona Lohiabada ena hereva idia kamonai henia lasi.   
\q1
\v 26 Unai dainai ia ese sisiba metauna idia dekenai ia henia.  
\q1 Ia gwau tano kaukau dekenai ia ese idia do ia hamasea,   
\q1
\v 27 bona ia ese edia natudia,  
\q1 be bese idauidau edia huanai do ia luludia lao,  
\q1 vadaeni idau bese taudia edia tanodia dekenai do idia mase.   
\b  
\q1
\v 28 Bona Peoro dekenai,  
\q1 Dirava ena bese taudia ese Bala dirava idia tomadiho henia,  
\q1 unai mauri lasi dirava dekenai idia henia boubou vamu idia ania.   
\q1
\v 29 Inai kara dekena amo idia ese Lohiabada idia habadua,  
\q1 vadaeni hanaia gorere dikana be idia dekenai ia vara.   
\q1
\v 30 To Pineha ese ia toreisi,  
\q1 bona kerere taudia edia dika davana ia henia,  
\q1 vadaeni unai gorere dikana be Dirava ese ia hadokoa.   
\q1
\v 31 Unai negana ia mai bona hari,  
\q1 Pineha ena kara ai gwauraia be maoromaoro.  
\q1 Bona gabeai do idia vara taunimanima danu ese,  
\q1 Pineha ena kara maoromaoro do idia herevalaia noho,  
\q1 ela bona nega ibounai.   
\b  
\q1
\v 32 Meriba ranu gabudia dekenai,  
\q1 Israela taudia ese Lohiabada idia habadua,  
\q1 bona Mose ese hisihisi ia davaria idia dainai.   
\q1
\v 33 Badina be idia ese Mose ena lauma idia habadua,  
\q1 bona unai dainai ia ese hereva maoromaoro ia gwauraia lasi.   
\b  
\q1
\v 34 Lohiabada ese Israela taudia ia oda henidia,  
\q1 idau bese taudia do idia alaia mase,  
\q1 to idia ese idia karaia lasi.   
\q1
\v 35 Bona idia ese unai idau bese taudia danu idia headava hanai,  
\q1 vadaeni unai idau bese taudia edia mauri dala dikadia,  
\q1 be Israela taudia idia abia dae.   
\q1
\v 36 Ma Dirava ena bese taudia ese,  
\q1 unai taudia edia kaivakuku idia tomadiho henia,  
\q1 bona inai kara ese Dirava ia habadua, vadaeni ia hadikadia.   
\q1
\v 37 Idia ese edia natudia tau bona hahine,  
\q1 be boubou gaudia totona lauma dikadia dekenai idia henia.   
\q1
\v 38 Idia ese Kanana taudia edia kaivakuku dekenai boubou idia henia.  
\q1 Unai bamona idia karaia neganai,  
\q1 edia natudia tau bona natudia hahine idia alaia mase,  
\q1 edia boubou gaudia totona.  
\q1 Kerere lasi taudia edia rarana idia habubua.  
\q1 Inai rara ese tano ibounai ia hadikaia.   
\q1
\v 39 Inai karadia dekena amo Israela taudia be idia miro lao,  
\q1 bona idia ese edia abidadama Dirava dekenai idia makohia.   
\b  
\q1
\v 40 Unai dainai Lohiabada ese,  
\q1 iena bese taudia ia badu henidia momokani.  
\q1 Ia ese idia ia ura henia lasi.   
\q1
\v 41 Ia ese bese idauidau taudia edia siahu henunai ia atodia.  
\q1 Vadaeni Israela dekenai idia tuari henia taudia ese,  
\q1 Israela taudia idia biagua.   
\q1
\v 42 Unai idau bese taudia ese Israela taudia idia dagedage henia,  
\q1 bona edia siahu henunai Israela taudia idia noho momokani,  
\q1 mai guia danu.   
\q1
\v 43 Nega momo Lohiabada ese,  
\q1 iena bese taudia ia durua bona ia hamauria,  
\q1 to idia ese ia dekenai idia kamonai henia lasi,  
\q1 bona edia kara dika ese idia ia hadikaia.   
\b  
\q1
\v 44 To Lohiabada ese edia taitai ia kamonai neganai,  
\q1 ia ese edia hisihisi ia laloa,   
\q1
\v 45 bona idia dekenai ia karaia gwauhamata taravatuna ia laloatao.  
\q1 Iena bogahisihisi bada herea dainai edia dika ia gwauatao.   
\q1
\v 46 Ia ese idia dagedage henidia taudia edia lalodia dekenai,  
\q1 bogahisihisi kara ia havaraia,  
\q1 vadaeni unai Israela taudia idia guia vadaeni taudia ese,  
\q1 Israela taudia dekenai idia bogahisihisi henia.   
\b  
\q1
\v 47 Lohiabada, aiemai Dirava e,  
\q1 mani ai do oi hamauria.  
\q1 Bese idauidau edia huanai dekena amo ai do oi haboua,  
\q1 vadaeni ai ese oiemu ladana helagana do ai hanamoa,  
\q1 mai tanikiu momokani danu.   
\q1
\v 48 Lohiabada, Israela ena Dirava, do umui hanamoa.  
\q1 Hari inai dina dekena amo ela bona hanaihanai,  
\q1 taunimanima ibounai be do idia gwau,  
\q1 “Amen.”  
\q1 Lohiabada do umui hanamoa!   
\c 107  
\s1 Lohiabada ena kara namodia do ita hanamoa  
\q1
\v 1 “Lohiabada do umui hanamoa, badina ia be namo.  
\q1 Iena bogahisihisi bona lalokau be hanaihanai do idia noho.”   
\q1
\v 2 Lohiabada ese umui ia hamauria taudia ibounai e,  
\q1 unai bamona hanamoa hereva do umui gwauraia lou, gwauraia lou,  
\q1 badina umui dekenai idia dagedage taudia dekena amo,  
\q1 Lohiabada ese umui ia hamauria vadaeni.   
\q1
\v 3 Lohiabada ese idau bese taudia edia tano dekena amo,  
\q1 umui ia mailaia vadaeni,  
\q1 laurabada dekena amo bona lahara dekena amo,  
\q1 mirigini dekena amo, bona diho kahana dekena amo.   
\b  
\q1
\v 4 Haida be taunimanima idia noho lasi tano dekenai idia loaloa,  
\q1 bona hanua ta idia davaria lasi do idia noholaia totona.   
\q1
\v 5 Idia be mai hitolo bona mai ranu mase danu,  
\q1 bona idia laloa idia be dika vadaeni.   
\q1
\v 6 To edia hisihisi lalonai Lohiabada dekenai idia noinoi,  
\q1 bona edia hisihisi dekena amo ia ese ia hamauridia.   
\q1
\v 7 Lohiabada ese dala maoromaoro dekena amo idia ia hakaua,  
\q1 vadaeni idia noholaia diba hanua ta dekenai ia hakaudia.   
\q1
\v 8 Idia ese Lohiabada do idia tanikiu henia be namo,  
\q1 iena lalokau badana dainai.  
\q1 badina be ia ese kara namodia momokani idia dekenai ia karaia.   
\q1
\v 9 Ranu mase taudia be Lohiabada ese ranu ia henidia noho,  
\q1 bona hitolo taudia,  
\q1 be Lohiabada ese aniani ia henidia noho, idia bogakunu.   
\b  
\q1
\v 10 Haida be diari lasi lalonai idia noho,  
\q1 dibura gabuna dekenai.  
\q1 Idia be dibura noho taudia,  
\q1 mai edia hisihisi, seini dekenai idia guidia dainai.   
\q1
\v 11 Unai bamona idia noho,  
\q1 badina be idia ese Siahu Ibounai Dirava ena hereva,  
\q1 be idia kamonai henia lasi,  
\q1 bona iena hadibaia hereva idia ura lasi idia badinaia.   
\q1
\v 12 Idia be gaukara auka herea momokani dainai idia manoka vadaeni,  
\q1 bona edia goada ia ore dainai tano dekenai idia moru,  
\q1 to tau ta ese ia durudia lasi.   
\q1
\v 13 Idia edia hisihisi lalonai,  
\q1 idia ese Lohiabada dekenai idia boiboi,  
\q1 bona ia ese edia hisihisi dekena amo idia ia hamauria.   
\q1
\v 14 Lohiabada ese edia diari lasi gabuna,  
\q1 bona edia dibura gabuna dekena amo ia abidia mai.  
\q1 Ia ese edia seini ia hamakohia maragimaragi.   
\q1
\v 15 Vadaeni idia ese Lohiabada do idia hanamoa be namo,  
\q1 iena lalokau badana dainai.  
\q1 Iena hoa karadia bona kara namodia, idia totona ia karaia dainai,  
\q1 Lohiabada do idia tanikiu henia be namo.   
\q1
\v 16 Auri labora dekena amo idia karaia iduara,  
\q1 be Lohiabada ese ia hamakohia.  
\q1 Ia ese dibura ruma edia magu auridia ia makohia maragimaragi.   
\b  
\q1
\v 17 Unai taudia haida ese,  
\q1 sibodia edia kara dika dainai gorere idia abia.  
\q1 Idia ese kerere idia karaia dainai hisihisi idia davaria.   
\q1
\v 18 Idia ese aniani idia ura lasi,  
\q1 unai dainai kahirakahira idia mase.   
\q1
\v 19 To idia edia hisihisi lalonai,  
\q1 idia ese Lohiabada dekenai idia boiboi,  
\q1 bona ia ese edia hisihisi dekena amo idia ia hamauria.   
\q1
\v 20 Lohiabada ese oda ia gwauraia,  
\q1 vadaeni edia gorere idia ore.  
\q1 Ia ese mase ena guri dekena amo idia ia hamauria.   
\q1
\v 21 Idia ese Lohiabada do idia tanikiu henia be namo,  
\q1 iena lalokau badana dainai.  
\q1 Iena kara badadia bona namodia,  
\q1 idia dekenai ia karaia gaudia dainai,  
\q1 Lohiabada do idia hanamoa be namo.   
\q1
\v 22 Boubou gaudia dekena amo,  
\q1 Lohiabada do idia tanikiu henia be namo.  
\q1 Mai ane bona mai moale danu,  
\q1 taunimanima dekenai Lohiabada ena kara namodia do idia gwauraia, be namo.   
\b  
\q1
\v 23 Idia haida be lagatoi dekenai,  
\q1 davara badana idia heau hanaia.  
\q1 Idia edia lagatoi dekena amo,  
\q1 hoihoi gaukara idia karaia moni davana.   
\q1
\v 24 Idia ese Lohiabada ena siahu karadia idia itaia.  
\q1 Davara badana dekenai,  
\q1 Lohiabada ese ia karaia gau badadia idia itaia momokani.   
\q1
\v 25 Badina be Lohiabada ese ia hereva,  
\q1 vadaeni lai badana ia toreisi,  
\q1 davara ena hurehure be bada herea idia lao.   
\q1
\v 26 Hurehure be guba dekenai idia daekau,  
\q1 bona dobu gabudia dekenai idia diho,  
\q1 bona kuru taudia idia hekwarahi bada dainai edia haheauka ia ore.   
\q1
\v 27 Idia edia matana idia giroagiroa,  
\q1 bona idia raka mai hekwarahi danu, kekero taudia bamona.  
\q1 Edia gari dainai edia laloa be ia ore.   
\q1
\v 28 Vadaeni edia hekwarahi lalonai Lohiabada dekenai idia taitai,  
\q1 bona ia ese edia hisihisi dekena amo idia ia hamauria.   
\q1
\v 29 Lohiabada ese lai ia gwauatao,  
\q1 vadaeni lai ia doko,  
\q1 bona davara ena hurehure idia diho.   
\q1
\v 30 Unai neganai kuru taudia idia moale, laga-ani idia davaria dainai,  
\q1 bona Lohiabada ese edia ura gabuna,  
\q1 hurehure lasi gabuna dekenai ia hakaudia vareai.   
\q1
\v 31 Lohiabada dekenai edia tanikiu idia henia be namo,  
\q1 ia ese iena lalokau bona bogahisihisi bona hoa karadia,  
\q1 taunimanima dekenai ia hedinaraia dainai.   
\q1
\v 32 Namona be edia guriguri hebou dekenai ia do idia hanamoa bada,  
\q1 bona hanua tau badadia edia hebou dekenai danu,  
\q1 idia ese Lohiabada do idia tanikiu henia be namo.   
\b  
\q1
\v 33 Lohiabada ese sinavai be tano kaukau dekenai ia halaoa,  
\q1 bona ranu lohilohi gabudia be ia ese ia koua,  
\q1 ranu lasi gabudia idia lao.   
\q1
\v 34 Lohiabada ese tano mai ena anina,  
\q1 be tano anina lasi gabuna dekenai ia halaoa.  
\q1 Unai bamona ia karaia,  
\q1 be unai gabu taudia edia kara dika dainai.   
\q1
\v 35 Bona tano kaukau gabuna, be gohu namona Lohiabada ese ia halaoa.  
\q1 Tano kaukau be ranu lohilohi gabuna dekenai danu ia halaoa.   
\q1
\v 36 Lohiabada ese unai gabudia dekenai,  
\q1 hitolo taudia ia atoa, idia noholaia,  
\q1 vadaeni idia ese hanua ta idia haginia, unuseni idia noho.   
\q1
\v 37 Unai taudia ese uma idia karaia,  
\q1 bona vain umadia danu idia karaia,  
\q1 vadaeni tano ena anina bada idia davaria.   
\q1
\v 38 Lohiabada ese ia hanamodia dainai,  
\q1 unai taudia be bese badana momokani idia lao,  
\q1 bona edia boromakau bona mamoe idia momo herea lao danu.   
\b  
\q1
\v 39 Gabeai dagedage, o hekwarahi, o hisihisi idia dekenai ia vara,  
\q1 vadaeni idia momo idia mase ore, orea maragina idia lao.   
\q1
\v 40 Unai neganai Lohiabada ese,  
\q1 lohia taudia edia hekokoruku ia hadokoa momokani.  
\q1 Unai lohia taudia ia siaidia lao,  
\q1 taunimanima noho lasi tano dekenai do idia loaloa.   
\q1
\v 41 To ogogami taudia edia hisihisi dekena amo,  
\q1 Lohiabada ese ia durudia,  
\q1 bona idia dekenai natuna bona tubuna momo ia henia,  
\q1 mamoe edia orea badana bamona.   
\q1
\v 42 Kara maoromaoro taudia ese inai kara idia itaia,  
\q1 vadaeni idia moale.  
\q1 to dika taudia be idia hereva lasi, edia uduna idia koua sibona.   
\b  
\q1
\v 43 Daika be mai ena aonega?  
\q1 Ia ese inai karadia do ia laloa.  
\q1 Namona be umui ese Lohiabada ena lalokau badana,  
\q1 noho hanaihanai lalokauna,  
\q1 be taunimanima dekenai do umui gwauraia hedinarai.   
\c 108  
\s1 Davida ese Dirava ia noia do ia durua  
\q1
\v 1 Dirava e,  
\q1 egu kudouna lalonai,  
\q1 egu abidadama ia goada momokani.  
\q1 Egu abidadama ia goada momokani oi dekenai.  
\q1 Oi hanamoa totona ane do lau abia,  
\q1 ane namona do lau abia.  
\q1 Egu lauma e, do oi noga!   
\q1
\v 2 Egu gita badana bona gita maragina e, do umui noga!  
\q1 Lau ese daba rere do lau hanogaia.   
\q1
\v 3 Lohiabada e,  
\q1 bese idauidau edia huanai lau ese oi do lau hanamoa.  
\q1 Taunimanima ibounai edia huanai,  
\q1 lau ese oi hanamoa totona ane do lau abia.   
\q1
\v 4 Badina oiemu noho hanaihanai lalokauna be bada herea,  
\q1 ia daekau lao ela bona guba dekenai.  
\q1 Oiemu hereva oi badinaia momokani kara be bada,  
\q1 ia daekau lao ela bona ori dekenai.   
\b  
\q1
\v 5 Dirava e,  
\q1 oiemu siahu badana be guba dekenai do oi hedinaraia,  
\q1 bona oiemu hairaina be,  
\q1 tanobada ena kahana ibounai dekenai danu do oi hedinaraia.   
\q1
\v 6 Oiemu goada dekena amo ai do oi hamauria.  
\q1 Aiemai noinoi mani do oi kamonai,  
\q1 vadaeni ai, oi ese oi lalokau henia taudia, do oi hamauria.   
\b  
\q1
\v 7 Iena helaga gabuna dekena amo Dirava ia hereva, ia gwau,  
\q1 “Mai kwalimu danu lau ese Sekema tano do lau hapararaia,  
\q1 bona Sukoto Koura,  
\q1 be egu bese taudia edia huanai do lau haria.   
\q1
\v 8 Gileada be egu tano,  
\q1 Manase danu be lauegu.  
\q1 Eparaima be egu tuari kwara gauna,  
\q1 bona Iuda be egu King dagi ena toana auna.   
\q1
\v 9 To lau ese Moaba do lau abia, egu aena huria disi bamona,  
\q1 bona lau ese Edoma ena latanai egu tamaka do lau negea lao,  
\q1 lau ese lau biagua ena toana.  
\q1 Pilistia tano danu do lau abia,  
\q1 mai kwalimu ena boiboi danu.   
\b  
\q1
\v 10 To Dirava e, daika ese hanua mai maguna danu dekenai,  
\q1 be lau do ia hakaua vareai?  
\q1 Daika ese Edoma dekenai lau do ia hakaua lao?   
\q1
\v 11 Dirava e, oi ese ai oi negea momokani vadaeni, a?  
\q1 Dirava e, aiemai tuari taudia danu,  
\q1 idia durua totona, do oi raka mai lou lasi, a?   
\b  
\q1
\v 12 Dirava e, ai do oi durua,  
\q1 ai dekenai idia tuari henia taudia,  
\q1 be ai ese do ai halusia,  
\q1 badina be taunimanima edia durua be anina lasi.   
\q1
\v 13 Bema Dirava be iseda kahana dekenai ia noho neganai,  
\q1 ita be do ita kwalimu.  
\q1 Dirava ese ita dekenai idia tuari henia taudia do ia halusia.   
\c 109  
\s1 Davida ia noinoi Dirava ese dika taudia edia davana do ia henia  
\q1
\v 1 Dirava e, oi lau hanamoa noho,  
\q1 egu guriguri mani do oi haere henia.   
\q1
\v 2 Badina be dika bona koikoi taudia ese,  
\q1 lau hadikaia totona hereva dika idia gwauraia noho.  
\q1 Lau dekenai samania koikoi hereva idia gwauraia noho.   
\q1
\v 3 Badu hereva dekena amo lau idia koua hagegea vadaeni,  
\q1 bona lau dekenai idia heai noho,  
\q1 to mai badina lasi.   
\q1
\v 4 Idia dekenai lau turana karaia,  
\q1 to idia ese lau idia badu henia noho.  
\q1 To lau ese idia totona lau guriguri vadaeni.   
\q1
\v 5 Lau dekenai idia kara dika, egu kara namo ena davana,  
\q1 bona idia ese lau idia hadikaia noho,  
\q1 egu lalokau ena davana.   
\b  
\q1
\v 6 Kara dika kota biaguna ta mani do oi abia hidi,  
\q1 ia ese lau ia hadikaia noho tauna do ia hadikaia.  
\q1 Ia dekenai ia badu momokani tauna ta do oi haginia,  
\q1 ia ese lau ia hadikaia tauna do ia samania.   
\q1
\v 7 Idia kota henia neganai,  
\q1 mani iena kerere do oi hamomokania.  
\q1 Iena guriguri danu mani be kara dikana do oi halaoa.   
\q1
\v 8 Mani emu kara unai tau ena mauri do ia ore haraga,  
\q1 bona tau ta ese iena dagi do ia abia.   
\q1
\v 9 Lau ura inai tau be do ia mase,  
\q1 bona iena natuna be mai edia tamana lasi.  
\q1 Lau ura iena adavana be vabu do ia lao.   
\q1
\v 10 Lau ura iena natuna be ruma lasi,  
\q1 vadaeni do idia loaloa kava,  
\q1 aniani totona do idia noinoi noho.  
\q1 Bona edia noho gabu dikana dekena amo,  
\q1 taunimanima ese do idia luludia ore.   
\q1
\v 11 Lau ura inai lau ia hadikaia noho tauna,  
\q1 be ia dekenai ia heniatorehai tauna ese,  
\q1 iena kohu ibounai do ia abia kava,  
\q1 bona idau taudia ese,  
\q1 iena gaukara ena anina do idia henaoa ore.   
\q1
\v 12 Lau ura tau ta ese ia dekenai do ia bogahisihisi lasi,  
\q1 bona ia mase murinai,  
\q1 lau ura iena natuna be tau ta ese do ia naridia lasi.   
\q1
\v 13 Lau ura iena bese taudia,  
\q1 ia dekena amo idia vara taudia,  
\q1 be do idia mase,  
\q1 bona gabeai do idia vara bese taudia ese,  
\q1 iena ladana be do idia laloaboio.   
\q1
\v 14 Lau ura Lohiabada ese,  
\q1 iena sene taudia edia dika do ia laloatao,  
\q1 bona iena sinana ena kara dika,  
\q1 be Lohiabada ese do ia gwauatao lasi.   
\q1
\v 15 Lau ura edia kara dika be Lohiabada do ia laloatao noho,  
\q1 to lau ura taunimanima ese,  
\q1 unai tau do idia laloaboio momokani.   
\b  
\q1
\v 16 Unai lau ia hadikaia gwauraia tauna ese,  
\q1 nega ta bogahisihisi kara ta ia karaia lasi.  
\q1 Ia ese ogogami taudia,  
\q1 bona gau lasi taudia,  
\q1 bona haida ese idia durua lasi taudia,  
\q1 ia dagedage henia bona ia aladia mase.   
\q1
\v 17 Guna ia ese taunimanima hadikaia hereva ia ura bada gwauraia,  
\q1 unai dainai harihari,  
\q1 namona be ia sibona ese dika do ia davaria!  
\q1 Guna ia ura lasi hanamoa hereva ta do ia gwauraia.  
\q1 Mani emu kara, tau ta ese do ia hanamoa lasi!   
\q1
\v 18 Nega ibounai ia ese,  
\q1 taunimanima hadikaia hereva ia gwauraia lou, gwauraia lou,  
\q1 dabua ia atoa lou, atoa lou bamona.  
\q1 Mani emu kara iena hadikaia hereva,  
\q1 be ia sibona dekenai do oi siaia lou,  
\q1 iena tauanina lalonai do idia vareai, ranu bamona,  
\q1 bona iena turiana dekenai do idia vareai, digara bamona.   
\q1
\v 19 Bona lau ura inai hadikaia hereva ese,  
\q1 unai tau do idia koua, dabua bamona.  
\q1 Nega ibounai iena bogana do idia hagegea, gaba gauna bamona.   
\b  
\q1
\v 20 Lohiabada e, lau idia hadikaia gwauraia taudia,  
\q1 be unai bamona edia dika davana do oi henia.  
\q1 Lau idia samania noho taudia edia dika davana,  
\q1 be do oi henidia.   
\q1
\v 21 To Lohiabada, egu Dirava e,  
\q1 oiemu gwauhamata hegeregerena lau do oi durua,  
\q1 bona oiemu lalokau ena namo dainai lau do oi hamauria.   
\b  
\q1
\v 22 Lau be lau ogogami noho, bona mai egu gau lasi.  
\q1 Egu lalona ia hisihisi bada noho.   
\q1
\v 23 Adorahi ena dina laulauna ia boio haraga bamona,  
\q1 lau danu lau boio noho.  
\q1 Lai bada ese kwadi ta ia kokia haraga bamona,  
\q1 lau be do idia kokia haraga.   
\q1
\v 24 Egu tuina be ia manoka vadaeni, aniani lau ania lasi dainai.  
\q1 Egu tauanina be ia maragi lao noho.   
\q1
\v 25 Taunimanima ese lau idia itaia neganai,  
\q1 edia kwaradia idia giroagiroa, lau idia kirikirilaia noho.   
\b  
\q1
\v 26 Lohiabada e, egu Dirava,  
\q1 oiemu bogahisihisi dainai lau do oi hamauria.   
\q1
\v 27 Lau idia hadikaia noho taudia do oi hadibaia,  
\q1 oi be lau oi hamauria noho Diravana.   
\q1
\v 28 Idia ese edia hereva dekenai lau idia hadikaia,  
\q1 to oi ese lau do oi hanamoa.  
\q1 Lau idia dagedage henia taudia mani do oi halusia,  
\q1 vadaeni lau, oiemu hesiai tauna,  
\q1 be do lau moale.   
\q1
\v 29 Lau idia samania noho taudia be do oi koua,  
\q1 vadaeni hemarai do idia davaria momokani.  
\q1 Inai hemarai be dabua bamona do idia karaia.   
\b  
\q1
\v 30 Egu uduna dekena amo, Lohiabada do lau hanamoa.  
\q1 Taunimanima momo edia huanai, Lohiabada do lau hanamoa,   
\q1
\v 31 badina be ia ese ogogami taudia ia gimaia noho,  
\q1 bona haida ese,  
\q1 unai ogogami taudia do idia alaia gwauraia neganai,  
\q1 Lohiabada ese ia hamauridia noho.   
\c 110  
\s1 Lohiabada ese iena King ia abia hidi  
\q1
\v 1 Lohiabada ese egu Lohiabada dekenai ia hamaoroa, ia gwau,  
\q1 “Lauegu idiba kahana dekenai do oi helai,  
\q1 ela bona oi dekenai idia tuari henia taudia,  
\q1 be oiemu aena atoa gauna dohore lau halaoa.”   
\b  
\q1
\v 2 Siona dekena amo Lohiabada ese,  
\q1 oiemu King siahuna do ia habadaia,  
\q1 Lohiabada ese oi ia hamaoroa, ia gwau,  
\q1 “Oi dekenai idia tuari henia taudia do oi biagua.”   
\q1
\v 3 Oi ese oi dekenai idia dagedage taudia,  
\q1 be do oi tuari henidia dinana dekenai,  
\q1 oiemu orea taudia ese oi dekenai do idia haboua,  
\q1 bona mai edia ura kwalimu danu oi do idia durua.  
\q1 Daba maragi neganai paripari ia hedinarai bamona,  
\q1 oiemu durua taudia be oi dekenai do idia haboua,  
\q1 ororo helagana dekenai.   
\b  
\q1
\v 4 Lohiabada ese gwauhamata metau momokani ia karaia vadaeni,  
\q1 bona do ia haidaua lasi, ia gwau,  
\q1 “Oi be hahelagaia tauna, Melekisedeka hegeregerena do oi lao,  
\q1 bona inai dagi do oi dogoatao ela bona hanaihanai.”   
\q1
\v 5 Lohiabada be oiemu imana idibana kahana dekenai,  
\q1 ia ese oi ia hagoadaia noho.  
\q1 Iena badu dinana dekenai,  
\q1 ia ese king taudia do ia halusia.   
\q1
\v 6 Ia ese bese idauidau taudia do ia kota henia,  
\q1 bona edia gabu be mase tauanina dekena amo do ia hahonua.  
\q1 Ia ese tanobada kahanakahana ibounai dekenai,  
\q1 king taudia do ia halusia.   
\q1
\v 7 King ese dala badinai ia noho sinavai maragina dekenai,  
\q1 ranu do ia inua,  
\q1 vadaeni goada do ia abia,  
\q1 bona tuari lalonai do ia kwalimu.   
\c 111  
\s1 Lohiabada do ita hanamoa  
\q1
\v 1 Lohiabada do umui hanamoa.  
\q1 Iena kara maoromaoro taudia edia hebou badana lalonai,  
\q1 lau ese Lohiabada do lau hanamoa, mai egu kudouna ibounai danu.   
\b  
\q1
\v 2 Lohiabada ena kara be badadia momokani.  
\q1 Iena kara idia moalelaia taudia ese,  
\q1 unai kara edia anina idia tahua noho.   
\q1
\v 3 Lohiabada ena kara be mai edia hairaina,  
\q1 bona idia ese iena King siahuna idia hedinaraia.  
\q1 Lohiabada ena kara maoromaoro,  
\q1 be do ia noho ela bona hanaihanai.   
\q1
\v 4 Iena hoa karadia ia karaia vadaeni,  
\q1 taunimanima ese unai kara do idia laloatao totona.  
\q1 Lohiabada be mai ena hariharibada bona mai ena bogahisihisi.   
\q1
\v 5 Ia dekenai idia gari taudia dekenai,  
\q1 be Lohiabada ese edia aniani ia henia.  
\q1 Iena gwauhamata taravatuna be,  
\q1 ia ese ia laloa noho nega ibounai, doko lasi.   
\q1
\v 6 Ia ese bese idauidau taudia edia tano,  
\q1 be iena bese taudia dekenai ia henia.  
\q1 Unai kara dekena amo,  
\q1 ia ese iena bese taudia dekenai,  
\q1 iena siahu ena bada ia hedinaraia vadaeni.   
\q1
\v 7 Lohiabada ena kara ibounai,  
\q1 be mai momokani bona mai maoromaoro danu.  
\q1 Iena taravatu ibounai ita abidadama henia diba.   
\q1
\v 8 Idia be do idia gini noho ela bona hanaihanai.  
\q1 Dirava ese mai ena laloa maoromaoro bona momokani danu,  
\q1 inai taravatu ia karaia.   
\q1
\v 9 Lohiabada ese iena bese taudia ia hoia lou,  
\q1 bona ia ese idia danu gwauhamata taravatuna ia karaia.  
\q1 Inai gwauhamata taravatuna do ia noho ela bona hanaihanai.  
\q1 Lohiabada ena ladana be helaga,  
\q1 bona mai garina danu.   
\q1
\v 10 Lohiabada gari henia kara be aonega hamatamaia ena dala.  
\q1 Lohiabada ena hereva idia badinaia taudia ibounai ese,  
\q1 diba namona idia abia noho.  
\q1 Lohiabada do ita hanamoa noho ela bona hanaihanai.   
\c 112  
\s1 Tau namona ena moale  
\q1
\v 1 Lohiabada do umui hanamoa.  
\b  
\q1 Lohiabada dekenai ia gari tauna be namo.  
\q1 Lohiabada ena taravatu ia moalelaia noho tauna danu be namo.   
\b  
\q1
\v 2 Inai bamona tau namona ena natuna,  
\q1 be do idia goada edia tano lalonai.  
\q1 Iena bese taudia,  
\q1 gabeai do idia vara taudia,  
\q1 ese Dirava ena hanamoa do idia davaria.   
\q1
\v 3 Iena famili taudia,  
\q1 be do mai edia moni bona kohu momo,  
\q1 bona iena kara maoromaoro,  
\q1 be do ia noho ela bona hanaihanai.   
\q1
\v 4 Momokani dibura ia noho,  
\q1 to tau namona durua totona diari be ia diari noho,  
\q1 vadaeni ia be mai ena hariharibada,  
\q1 bona mai ena bogahisihisi,  
\q1 bona mai ena kara maoromaoro danu.   
\q1
\v 5 Haida dekenai harihari gaudia ia henia,  
\q1 bona mai laloa namona danu haida dekenai ia heniatorehai.  
\q1 Iena gaukara be, mai ena maoromaoro danu ia karaia.  
\q1 Unai bamona tauna be do ia moale noho.   
\q1
\v 6 Tau namona be nega ta do idia hamorua lasi.  
\q1 Taunimanima ese ia do idia laloatao hanaihanai.   
\q1
\v 7 Dika bada ia vara ena sivarai ia kamonai neganai,  
\q1 unai tau be do ia gari lasi,  
\q1 badina ia ese Lohiabada dekenai ia abidadama henia goada noho.   
\q1
\v 8 Ia be ia laloa hekwarahi lasi,  
\q1 bona ia gari lasi,  
\q1 badina ia diba momokani,  
\q1 ia idia hadikaia gwauraia taudia be,  
\q1 ia ese mai kwalimu danu edia moru do ia itaia.   
\q1
\v 9 Mai edia gau lasi taudia dekenai,  
\q1 harihari gaudia ia henia vadaeni.  
\q1 Iena kara maoromaoro be do ia noho ela bona hanaihanai.  
\q1 Ia ese siahu bona goada do ia abia,  
\q1 bona taunimanima ese ia do idia matauraia.   
\b  
\q1
\v 10 Kara dika taudia ese inai iena goada idia itaia noho,  
\q1 bona idia badu noho.  
\q1 Idia ese unai tau namona do idia badu henia,  
\q1 bona do idia boio momokani.  
\q1 Kara dika tauna ena ura gauna ena anina, be do ia vara lasi.   
\c 113  
\s1 Lohiabada ena siahu bona iena namo  
\q1
\v 1 Lohiabada do umui hanamoa.  
\b  
\q1 Lohiabada ena hesiai taudia e,  
\q1 Lohiabada ena ladana do umui hanamoa.   
\q1
\v 2 Lohiabada ena ladana do ita hanamoa noho,  
\q1 hari ela bona hanaihanai.   
\q1
\v 3 Dina daekau kahana ela bona dina diho kahana dekenai,  
\q1 Lohiabada ena ladana do ita hanamoa be namo.   
\b  
\q1
\v 4 Lohiabada be ataiai, bese ibounai be ia ese ia biagua noho.  
\q1 Iena hairaina be guba ena ataiai danu ia noho.   
\q1
\v 5 Daika be Lohiabada iseda Dirava hegeregerena?  
\q1 Lohiabada be guba ena ataiai ia helai noho,   
\q1
\v 6 to ia ese iena kwarana ia atoa diho,  
\q1 iena matana ia negea, guba bona tanobada ia itaia noho.   
\b  
\q1
\v 7 Ia ese ogogami taudia,  
\q1 be tano ena kahu dekena amo ia abia isi noho,  
\q1 bona mai edia gau lasi taudia,  
\q1 be edia hisihisi dekena amo durua ia henidia noho.   
\q1
\v 8 Lohiabada ese unai ogogami taudia ia abia isi noho,  
\q1 bona ia ese iena bese taudia edia gunalaia taudia dagi,  
\q1 be idia dekenai ia henia noho.   
\q1
\v 9 Lohiabada ese natuna ia havaraia diba lasi hahine dekenai,  
\q1 noho gabuna ia henia noho.  
\q1 Ia ese unai hahine ia hanamoa noho,  
\q1 vadaeni memero bona kekeni momo ia havaraia,  
\q1 bona inai hahine be do ia moale bada noho.  
\b  
\q1 Lohiabada do umui hanamoa!   
\c 114  
\s1 Pasova ena ane  
\q1
\v 1 Israela taudia be Aigupito idia rakatania.  
\q1 Iakobo ena besena,  
\q1 be gado idau taudia edia tano idia rakatania.   
\q1
\v 2 Unai neganai Iuda be Lohiabada ena helaga taudia,  
\q1 bona Israela danu be Lohiabada ena basileia korikori.   
\q1
\v 3 Davara Kakakaka ese gau ta ia itaia, vadaeni ia heau!  
\q1 Ioridane Sinavai ese iena ranu ena heau ia hadokoa,  
\q1 ena ranu ia gini noho!   
\q1
\v 4 Ororo badadia be nanigosi bamona idia roho lao, roho lao noho!  
\q1 Bona ororo maragidia,  
\q1 be mamoe natudia bamona idia roho lao, roho lao noho!   
\b  
\q1
\v 5 Davara e,  
\q1 dahaka ia vara, vadaeni oi heau?  
\q1 Bona Ioridane Sinavai e,  
\q1 badina dahaka oiemu ranu ena heau oi hadokoa?   
\q1
\v 6 Ororo badadia e,  
\q1 badina dahaka nanigosi bamona umui roho lao?  
\q1 Ororo maragidia e,  
\q1 badina dahaka mamoe natudia bamona umui roho lao?   
\b  
\q1
\v 7 Tanobada e,  
\q1 Lohiabada ena vairanai do oi heudeheude,  
\q1 Iakobo ena Dirava ena vairanai.   
\q1
\v 8 Ia ese nadi badana be ranu gabuna ia halaoa,  
\q1 bona ia ese ororo ena nadi be ranu ia lohilohi gabuna ia halaoa.   
\c 115  
\s1 Lohiabada sibona be Dirava momokani  
\q1
\v 1 Lohiabada e,  
\q1 oi dekenai hairai bada ia noho,  
\q1 momokani, oi dekenai hairai bada ia noho,  
\q1 ai dekenai be lasi.  
\q1 Badina oiemu lalokau bona bogahisihisi be bada,  
\q1 bona oiemu gwauhamata badinaia kara be momokani.   
\b  
\q1
\v 2 Badina dahaka idau bese taudia ese ai idia nanadaia,  
\q1 idia gwau,  
\q1 “Umui emui Dirava be edeseni ia noho?”   
\q1
\v 3 Iseda Dirava be guba dekenai ia noho.  
\q1 Bema ia ura kara ta ia karaia,  
\q1 unai kara sibona do ia karaia.   
\q1
\v 4 Unai idau bese taudia edia dirava,  
\q1 be siliva bona golo dekenai idia karaia,  
\q1 idia sibona edia imana dekenai idia karaia gaudia.   
\q1
\v 5 Unai dirava koikoidia be mai edia uduna,  
\q1 to idia hereva diba lasi,  
\q1 bona mai edia matana,  
\q1 to idia itaia diba lasi.   
\q1
\v 6 Idia be mai edia taiana,  
\q1 to idia kamonai diba lasi,  
\q1 bona mai edia udu baubauna,  
\q1 to bonana idia kamonai diba lasi.   
\q1
\v 7 Idia be mai edia imana,  
\q1 to gau ta idia dogoatao diba lasi,  
\q1 bona mai edia aena,  
\q1 to idia raka diba lasi.  
\q1 Regerege ta idia karaia diba lasi.   
\q1
\v 8 Unai bamona dirava koikoi idia karaia taudia be dika.  
\q1 Namona be idia karaia gaudia hegeregere do idia lao.  
\q1 Bona unai dirava koikoi idia abidadama henia taudia danu,  
\q1 namona be do idia dika,  
\q1 unai dirava koikoi hegeregere.   
\b  
\q1
\v 9 Umui Israela taudia ibounai e,  
\q1 Lohiabada dekenai do umui abidadama henia.  
\q1 Ia ese umui ia durua noho,  
\q1 ma ia ese umui ia naria noho.   
\q1
\v 10 Umui Dirava ena hahelagaia taudia e,  
\q1 Lohiabada do umui abidadama henia.  
\q1 Ia ese umui ia durua noho,  
\q1 ia ese umui ia naria noho.   
\q1
\v 11 Dirava garina umui gari taudia ibounai e,  
\q1 Lohiabada do umui abidadama henia.  
\q1 Ia ese umui ia durua noho,  
\q1 ia ese umui ia naria noho.   
\b  
\q1
\v 12 Lohiabada ese nega ibounai ita ia laloa noho,  
\q1 bona ia ese ita do ia hanamoa.  
\q1 Ia ese Israela bese taudia,  
\q1 bona Dirava ena hahelagaia taudia do ia hanamoa.   
\q1
\v 13 Lohiabada ese ia dekenai idia matauraia taudia ibounai,  
\q1 be do ia hanamoa,  
\q1 ladana bada bona ladana maragi taudia danu.   
\b  
\q1
\v 14 Lau ura Lohiabada ese natudia momo umui dekenai do ia henia,  
\q1 bona emui natudia dekenai danu.   
\q1
\v 15 Lohiabada ese guba bona tanobada ia karaia vadaeni.  
\q1 Lau ura ia ese umui do ia hanamoa.   
\b  
\q1
\v 16 Guba be Lohiabada sibona ese ia biagua noho,  
\q1 to tanobada be Lohiabada ese taunimanima dekenai ia henia.   
\q1
\v 17 Mase taudia be mase taudia edia gabu dekenai idia lao noho.  
\q1 Idia ese Lohiabada ena ladana idia hanamoa diba lasi.   
\q1
\v 18 To ita be ita mauri noho dainai Lohiabada do ita tanikiu henia.  
\b  
\q1 Lohiabada ena ladana do ita hanamoa!   
\c 116  
\s1 Dirava ese tau ta ia hamauria, vadaeni ia tanikiu henia  
\q1
\v 1 Lohiabada ese egu guriguri bona egu noinoi ia kamonai noho,  
\q1 unai dainai ia dekenai lau lalokau henia.   
\q1
\v 2 Lau be Lohiabada dekenai lau boiboi negadia ibounai,  
\q1 ia ese lau dekenai ia kamonai.   
\b  
\q1
\v 3 Mase ese lau ia guia,  
\q1 varo badana ese lau ia guia bamona.  
\q1 Mase ena guria gabuna ena gari bada ese lau ia dogoatao.  
\q1 Gari bona laloa hekwarahi ese lau ia dogoatao momokani.   
\q1
\v 4 Unai neganai Lohiabada dekenai lau boiboi, lau gwau,  
\q1 “Lohiabada e,  
\q1 oi dekenai lau noinoi inai,  
\q1 mani lau oi hamauria.”   
\b  
\q1
\v 5 Lohiabada be mai ena hariharibada,  
\q1 bona mai ena kara maoromaoro danu.  
\q1 Iseda Dirava be mai ena bogahisihisi.   
\q1
\v 6 Lohiabada ese sibodia idia naria diba lasi taudia ia naria noho.  
\q1 Mase be lau kahirakahira ia noho neganai,  
\q1 Lohiabada ese lau ia hamauria.   
\b  
\q1
\v 7 Hari egu lauma ese laga-ani ia abia lou,  
\q1 badina Lohiabada ese iena durua,  
\q1 be lau dekenai ia henia vadaeni.   
\b  
\q1
\v 8 Lohiabada e, oi ese mase dekena amo lau oi hamauria,  
\q1 bona egu matana ena ranu oi dahua ore vadaeni.  
\q1 Ma oi ese lau oi durua dainai, do lau moru lasi.   
\q1
\v 9 Unai dainai lau be Lohiabada ena vairanai do lau raka,  
\q1 egu mauri dinadia ibounai lalonai.   
\q1
\v 10 Hisihisi bada herea lau dekenai ia vara neganai,  
\q1 lau ese egu abidadama Dirava dekenai lau rakatania lasi,  
\q1 lau dogoatao noho.   
\q1
\v 11 Bona gari bada ese lau ia hagaria neganai, lau gwau,  
\q1 “Tau ta lau abidadama henia diba lasi.”  
\q1 To unai neganai danu lau ese Dirava lau abidadama henia.   
\b  
\q1
\v 12 Lohiabada dekenai dahaka do lau henia,  
\q1 iena hariharibada ibounai lau dekenai ena davana?   
\q1
\v 13 Lau ese uaina ena kapusi ta, Lohiabada dekenai do lau henia,  
\q1 Ia ese lau ia hamauria dainai,  
\q1 lau ese Lohiabada do lau hanamoa.   
\q1
\v 14 Egu gwauhamata ena anina do lau karaia,  
\q1 Lohiabada dekenai do lau henia,  
\q1 iena bese taudia ibounai edia hebou lalonai,  
\q1 idia edia vairana dekenai.   
\b  
\q1
\v 15 Lohiabada ese iena orea taudia ta ta ibounai,  
\q1 be ia lalokau henidia bada herea momokani.  
\q1 Unai dainai, bema idia ta ia mase neganai,  
\q1 Lohiabada ese ia laloa bada noho.   
\q1
\v 16 Lohiabada e, lau be oiemu hesiai tauna.  
\q1 Lau ese oiemu gaukara lau karaia noho,  
\q1 egu sinana ese guna ia karaia bamona.  
\q1 Oi ese mase ena seini dekena amo lau oi ruhaia.   
\b  
\q1
\v 17 Egu boubou gauna Lohiabada dekenai,  
\q1 be egu tanikiu ia dekenai,  
\q1 bona iena ladana dekenai do lau guriguri.   
\q1
\v 18 Egu gwauhamata ena anina be Lohiabada dekenai do lau henia,  
\q1 iena orea taudia edia vairanai.   
\q1
\v 19 Lohiabada e, oiemu Dubu Helaga, Ierusalema dekenai,  
\q1 oi dekenai lau gwauhamata vadaeni gauna do lau henia.  
\b  
\q1 Lohiabada do ita hanamoa!   
\c 117  
\s1 Lohiabada ena ladana hanamoa ane ta  
\q1
\v 1 Bese idauidau ibounai e,  
\q1 Lohiabada do umui hanamoa.  
\q1 Taunimanima ibounai e, Lohiabada ena ladana do umui abia isi,   
\q1
\v 2 badina iena lalokau ita dekenai be ia bada herea.  
\q1 Lohiabada ese iena hereva ia badinaia noho nega ibounai,  
\q1 bona ia ese ita do ia rakatania lasi, ela bona hanaihanai.  
\b  
\q1 Lohiabada do umui hanamoa!   
\c 118  
\s1 Kwalimu idia abia dainai Dirava idia tanikiu henia  
\q1
\v 1 Lohiabada do ita tanikiu henia,  
\q1 badina ita dekenai kara namo ia karaia.  
\q1 Iena lalokau bona bogahisihisi be do idia noho hanaihanai.   
\b  
\q1
\v 2 Israela taudia inai bamona do idia hereva be namo:  
\q1 “Lohiabada ena lalokau bona bogahisihisi do idia noho hanaihanai.”   
\q1
\v 3 Dirava ena hahelagaia taudia be namo do idia gwau:  
\q1 “Lohiabada ena lalokau bona bogahisihisi do idia noho hanaihanai.”   
\q1
\v 4 Lohiabada dekenai idia gari taudia ibounai namo do idia gwau:  
\q1 “Lohiabada ena lalokau bona bogahisihisi do idia noho hanaihanai.”   
\b  
\q1
\v 5 Egu hisihisi lalonai, lau be Lohiabada dekenai lau boiboi,  
\q1 vadaeni ia ese lau dekenai ia haere henia,  
\q1 bona unai hisihisi be ia ese ia kokia.   
\q1
\v 6 Lohiabada be lau dekenai ia noho, vadaeni lau gari lasi.  
\q1 Taunimanima be edena bamona lau do idia hadikaia diba?   
\q1
\v 7 Lohiabada sibona ese lau ia durua noho.  
\q1 Unai dainai lau idia hadikaia gwauraia taudia do lau itaia,  
\q1 be Lohiabada ese do ia halusidia.   
\q1
\v 8 Namona be Lohiabada dekenai do ita abidadama henia,  
\q1 to taunimanima dekenai do ita abidadama henia lasi.   
\q1
\v 9 Namona be Lohiabada dekenai do ita abidadama henia,  
\q1 to tanobada gunalaia taudia dekenai do ita abidadama henia lasi.   
\b  
\q1
\v 10 Tuari totona idau bese taudia ese lau idia hagegea,  
\q1 to Lohiabada ena ladana dekenai lau ese idia lau halusia.   
\q1
\v 11 Lau idia hagegea, kahana kahana ibounai dekena amo,  
\q1 to Lohiabada ena siahu dekenai lau ese idia lau halusia.   
\q1
\v 12 Idia ese nanigo bamona lau idia hagegea,  
\q1 to idia mase haraga,  
\q1 kurukuru kakoro dekenai lahi ia mase haraga bamona.  
\q1 Lohiabada ena siahu dekena amo lau ese idia lau halusia.   
\b  
\q1
\v 13 Idia ese lau idia tuari henia goadagoada,  
\q1 bona kahirakahira lau moru,  
\q1 to Lohiabada ese lau ia durua.   
\q1
\v 14 Lohiabada be egu goada bona egu ane.  
\q1 Ia ese lau ia hamauria vadaeni.   
\b  
\q1
\v 15 Kamonai!  
\q1 Dirava ena bese taudia ese,  
\q1 edia palai rumadia lalonai,  
\q1 idia boiboi noho mai moale danu, idia kwalimu dainai,  
\q1 idia gwau,  
\q1 “Lohiabada ena goada badana ese inai kara ia karaia!   
\q1
\v 16 Lohiabada ena siahu ese kwalimu ita dekenai ia henia!  
\q1 Tuari lalonai iena imana idibana be goada momokani!”   
\b  
\q1
\v 17 Lau be do lau mase lasi,  
\q1 do lau mauri noho,  
\q1 bona Lohiabada ena kara do lau gwauraia noho.   
\q1
\v 18 Lohiabada ese lau ia panisia vadaeni, matakani auka dekena amo,  
\q1 to ia ese mase dekenai lau ia negea lasi.   
\b  
\q1
\v 19 Dubu Helaga ena iduara lau totona do umui kehoa,  
\q1 vadaeni do lau raka vareai,  
\q1 Lohiabada do lau tanikiu henia!   
\q1
\v 20 Inai iduara be Lohiabada ena,  
\q1 kara maoromaoro taudia sibona idia raka vareai diba.   
\q1
\v 21 Lohiabada e, oi ese egu guriguri oi kamonai vadaeni,  
\q1 bona oi ese kwalimu lau dekenai oi henia.  
\q1 Unai dainai oiemu ladana lau abia isi inai.   
\b  
\q1
\v 22 Inai nadi,  
\q1 ruma haginia taudia ese idia ura henia lasi,  
\q1 to hari ia be ruma ena kona nadi badana momokani ia gini noho.   
\q1
\v 23 Inai be Lohiabada ena kara,  
\q1 ita itaia noho,  
\q1 bona ita hoa noho.   
\q1
\v 24 Lohiabada ese inai dina,  
\q1 iena kwalimu dinana ia karaia vadaeni.  
\q1 Inai dina ita hanamoa,  
\q1 bona ita moalelaia be namo.   
\b  
\q1
\v 25 Lohiabada e,  
\q1 oi dekenai ai noinoi noho,  
\q1 mani ai do oi hamauria.  
\q1 Lohiabada e,  
\q1 mani emu kara kwalimu ai dekenai do oi henia.   
\q1
\v 26 Dirava ese, Lohiabada ena ladana dainai ia mai noho tauna,  
\q1 be do ia hanamoa.  
\q1 Lohiabada ena Dubu Helaga lalonai,  
\q1 ai ese umui ai hanamoa noho.   
\q1
\v 27 Lohiabada sibona be Dirava momokani.  
\q1 Ia ese iena laloa diari ita dekenai ia henia vadaeni.  
\q1 Au edia rigi bona herahera danu do umui dogoatao,  
\q1 bona boubou patana do umui raka hagegea lao.   
\q1
\v 28 Oi be egu Dirava, bona lau ura tanikiu henia oi dekenai.  
\q1 Oi be egu Dirava, bona lau ura oiemu ladana do lau abia isi.   
\q1
\v 29 Lohiabada do umui tanikiu henia momokani,  
\q1 badina ia be namo momokani.  
\q1 Iena lalokau bona bogahisihisi do idia noho ela bona hanaihanai.   
\c 119  
\s1 Lohiabada ena taravatu  
\q1
\v 1 Mai edia kerere lasi dekenai idia noho taudia,  
\q1 bona Lohiabada ena taravatu hegeregerena idia noho taudia,  
\q1 be do idia moale noho.   
\q1
\v 2 Dirava ena hadibaia hereva idia kamonai henia momokani taudia,  
\q1 bona mai edia kudouna ibounai Lohiabada idia tahua taudia,  
\q1 be do idia moale noho.   
\q1
\v 3 Idia be kara dika idia karaia lasi,  
\q1 to Lohiabada ena dala dekenai idia raka noho.   
\q1
\v 4 Lohiabada e,  
\q1 oi ese hadibaia hereva ai dekenai oi henia,  
\q1 bona oi gwau,  
\q1 ai ese unai oiemu hadibaia hereva,  
\q1 be do ai kamonai henia momokani.   
\q1
\v 5 Lau ura bada oiemu hereva do lau badinaia,  
\q1 mai maoromaoro bona momokani danu, nega ibounai.   
\q1
\v 6 Bema oiemu taravatu ibounai sibona lau laloa noho neganai,  
\q1 tau ta ese lau do ia hahemaraia diba lasi.   
\q1
\v 7 Oiemu taravatu maoromaorodia lau tahua bona lau diba neganai,  
\q1 lau ese oi do lau hanamoa,  
\q1 mai egu laloa maoromaoro danu.   
\q1
\v 8 Lau ura oiemu taravatu do lau badinaia namonamo.  
\q1 Unai neganai oi ese lau do oi rakatania lasi.   
\s1 Lohiabada ena taravatu badinaia kara  
\q1
\v 9 Uhau tauna be edena bamona mai goevagoeva danu do ia noho?  
\q1 Ia ese oiemu taravatu do ia kamonai henia.   
\q1
\v 10 Lohiabada e,  
\q1 mai egu kudouna ibounai danu lau ese oi lau tahua noho.  
\q1 Mani lau do oi durua,  
\q1 vadaeni oiemu hadibaia hereva do lau rakatania lasi.   
\q1
\v 11 Oiemu hereva be egu kudouna lalonai lau hunia noho,  
\q1 oi dekenai do lau kara dika lasi totona.   
\q1
\v 12 Lohiabada e, lau ese oi lau hanamoa noho.  
\q1 Oiemu taravatu lau dekenai do oi hadibaia.   
\q1
\v 13 Egu uduna dekena amo oiemu taravatu,  
\q1 ai dekenai oi henia gaudia,  
\q1 be taunimanima dekenai lau gwauraia hedinarai noho.   
\q1
\v 14 Oiemu hadibaia hereva edia dala lau moalelaia bada noho,  
\q1 to kohu bona moni dekenai lau moale bada lasi.   
\q1
\v 15 Oiemu hadibaia hereva edia anina lau laloa namonamo noho.  
\q1 Oiemu oda hereva edia anina lau tahua noho.   
\q1
\v 16 Oiemu taravatu lau moalelaia noho,  
\q1 bona oiemu oda hereva be do lau laloaboio lasi.   
\s1 Lohiabada ena taravatu ese moale ia havaraia  
\q1
\v 17 Lohiabada e,  
\q1 lau dekenai kara namo do oi karaia,  
\q1 badina lau be oiemu hesiai tauna.  
\q1 Unai neganai lau be do lau mauri noho,  
\q1 bona oiemu hadibaia hereva do lau kamonai henia.   
\q1
\v 18 Lauegu matana do oi kehoa,  
\q1 vadaeni oiemu taravatu dekenai hoa gaudia do lau itaia namonamo.   
\q1
\v 19 Lau be nega daudau lasi inai tanobada dekenai do lau noho,  
\q1 unai dainai oiemu taravatu lau dekena amo do oi hunia lasi.   
\q1
\v 20 Egu kudouna ia hisihisi noho, badina be,  
\q1 nega ibounai lau ura dikadika oiemu taravatu ena kara maoromaoro.   
\q1
\v 21 Oi ese hekokoroku taudia oi gwau henia noho,  
\q1 dika momokani do idia davaria,  
\q1 badina be oiemu taravatu idia rakatania taudia ese,  
\q1 dika do idia davaria.   
\q1
\v 22 Idia ese lau dekenai idia hereva dika,  
\q1 bona lau dekenai idia kirikiri noho,  
\q1 badina be oiemu taravatu lau badinaia noho.  
\q1 Mani emu kara inai edia kara do oi koua.   
\q1
\v 23 Lohia taudia ese lau hadikaia totona idia haboua noho,  
\q1 to lau ese oiemu hadibaia hereva do lau tahua noho.   
\q1
\v 24 Oiemu hadibaia hereva ese lau idia hamoalea noho.  
\q1 Idia ese lau idia hakaua noho.   
\s1 Hisihisi neganai lau ese Lohiabada ena taravatu lau badinaia noho  
\q1
\v 25 Lau moru diho,  
\q1 bona egu vairana be tano ena kahu lalonai.  
\q1 Lohiabada e,  
\q1 oiemu gwauhamata hegeregerena lau do oi hamauria.   
\q1
\v 26 Egu kara ibounai oi dekenai lau gwauraia hedinarai,  
\q1 bona oi ese lau oi haere henia.  
\q1 Oiemu hadibaia hereva mani lau dekenai do oi hadibaia.   
\q1
\v 27 Oiemu taravatu edia anina mani lau dekenai do oi hadibaia,  
\q1 vadaeni oiemu hoa karadia do lau laloa.   
\q1
\v 28 Egu lalohisihisi ese egu goada ia haorea.  
\q1 Mani lau do oi hagoadaia, oiemu gwauhamata hegeregerena.   
\q1
\v 29 Lau do oi naria,  
\q1 vadaeni koikoi karadia do lau karaia lasi.  
\q1 Mani emu kara oiemu hariharibada dainai,  
\q1 oiemu taravatu lau dekenai do oi hadibaia.   
\q1
\v 30 Lau ese abidadama ena dala lau abia hidi vadaeni,  
\q1 bona oiemu taravatu,  
\q1 be egu kudouna dekenai lau laloa noho, laloa noho.   
\q1
\v 31 Lohiabada e,  
\q1 oiemu hadibaia hereva lau badinaia noho.  
\q1 Mani lau do oi durua,  
\q1 vadaeni hemarai do lau davaria lasi.   
\q1
\v 32 Oi ese egu lalona do oi hadiaria dainai,  
\q1 lau ese oiemu oda hereva,  
\q1 be do lau kamonai henia, mai egu laloa haraga danu.   
\s1 Aonega totona lau noinoi  
\q1
\v 33 Lohiabada e, oiemu taravatu edia anina,  
\q1 be mani lau dekenai do oi hadibaia,  
\q1 bona lau ese nega ibounai idia do lau kamonai henia.   
\q1
\v 34 Egu lalona do oi kehoa,  
\q1 bona lau ese oiemu taravatu do lau badinaia.  
\q1 Lau ese mai egu kudouna ibounai danu,  
\q1 oiemu taravatu do lau naria.   
\q1
\v 35 Oiemu oda hereva edia dala dekenai lau do oi hakaua lao,  
\q1 badina be unai dala dekenai moale lau davaria noho.   
\q1
\v 36 Egu kudouna do oi hamanadaia,  
\q1 vadaeni do lau ura oiemu taravatu do lau kamonai henia.  
\q1 Bona unai neganai lau ese kohu bona moni do lau laloa momo lasi.   
\q1
\v 37 Mani lau do oi durua,  
\q1 lau ese anina lasi gaudia do lau tahua lasi,  
\q1 to oiemu dala dekenai lau raka dainai,  
\q1 egu mauri do oi hamatamataia.   
\q1
\v 38 Lau, oiemu hesiai tauna dekenai,  
\q1 mani oiemu gwauhamata do oi hamomokania.  
\q1 Inai gwauhamata be,  
\q1 oi dekenai idia gari taudia ibounai dekenai oi henia noho.   
\q1
\v 39 Lau ese hereva dika dekenai lau gari noho.  
\q1 Mani emu kara lau do oi durua,  
\q1 vadaeni inai hereva dikadia ese lau do idia hadikaia lasi,  
\q1 badina oiemu kota hereva be namo momokani!   
\q1
\v 40 Lau ese oiemu hadibaia hereva lau ura momokani do lau badinaia.  
\q1 Mauri matamata lau dekenai do oi henia,  
\q1 badina oiemu kara be maoromaoro.   
\s1 Lohiabada ena taravatu dekenai abidadama kara  
\q1
\v 41 Lohiabada e,  
\q1 oiemu noho hanaihanai lalokauna lau dekenai do oi hedinaraia,  
\q1 bona lau do oi hamauria,  
\q1 oiemu gwauhamata hegeregerena.   
\q1
\v 42 Unai neganai lau ese lau idia hereva dika henia taudia,  
\q1 be do lau haere henia diba,  
\q1 badina be lau ese oiemu hereva lau abidadama henia noho.   
\q1
\v 43 Mani lau do oi durua,  
\q1 vadaeni nega ibounai hereva momokani do lau gwauraia,  
\q1 badina be oiemu kota hereva lau abidadama henia noho.   
\q1
\v 44 Lau ese nega ibounai oiemu taravatu do lau kamonai henia noho,  
\q1 ela bona hanaihanai.   
\q1
\v 45 Lau ese oiemu hadibaia hereva lau tahua momokani dainai,  
\q1 gau ta ese egu dala do ia koua diba lasi, lasi momokani.   
\q1
\v 46 Oiemu taravatu be king taudia dekenai do lau gwauraia,  
\q1 bona inai kara dekenai lau be do lau hemarai lasi.   
\q1
\v 47 Oiemu oda hereva lau kamonai henia noho,  
\q1 mai egu moale bada danu,  
\q1 badina be oiemu oda lau ura henia noho.   
\q1
\v 48 Oiemu oda hereva be lau ese lau matauraia,  
\q1 bona lau ura henia danu.  
\q1 Oiemu hadibaia hereva be do lau laloa noho.   
\s1 Lohiabada ena taravatu be hereva momokani  
\q1
\v 49 Lohiabada e,  
\q1 lau, oiemu hesiai tauna dekenai oi henia gwauhamata,  
\q1 be mani do oi laloatao.  
\q1 Inai gwauhamata lau abidadama henia dainai,  
\q1 egu lalona ia moale.   
\q1
\v 50 Hisihisi ese lau ia abia neganai goada lau davaria lou,  
\q1 badina oiemu gwauhamata ese,  
\q1 mauri matamata lau dekenai ia henia.   
\q1
\v 51 Hekokoroku taudia be,  
\q1 nega ibounai lau dekenai idia hereva dika henia,  
\q1 to lau ese oiemu taravatu lau rakatania lasi.   
\q1
\v 52 Lohiabada e, oiemu oda hereva gunadia lau laloatao,  
\q1 bona idia ese lau idia hagoadaia.   
\q1
\v 53 Lau ese dika taudia lau itaia,  
\q1 idia ese oiemu taravatu idia utua noho.  
\q1 Unai lau itaia neganai egu lalona ia badu momokani.   
\q1
\v 54 Edena gabu, edena gabu dekenai lau noho,  
\q1 oiemu taravatu be egu ane edia anina.   
\q1
\v 55 Lohiabada e,  
\q1 hanuaboi lalonai lau ese oi lau laloatao noho,  
\q1 bona oiemu taravatu lau laloa noho.   
\q1
\v 56 Lau ese oiemu oda hereva lau badinaia noho,  
\q1 bona inai kara ese lau ia hamoalea momokani.   
\s1 Lohiabada ena taravatu ura henia kara  
\q1
\v 57 Lohiabada e, oi sibona lau ura henia noho.  
\q1 Lau ese lau gwauhamata vadaeni,  
\q1 oiemu taravatu do lau kamonai henia.   
\q1
\v 58 Mai egu kudouna ibounai danu oi dekenai lau noinoi inai,  
\q1 lau do oi hanamoa.  
\q1 Lau do oi bogahisihisi henia, oiemu gwauhamata hegeregerena.   
\q1
\v 59 Lau ese egu mauri ena dala lau tahua,  
\q1 bona lau laloa momo vadaeni,  
\q1 bona unai negadia ibounai,  
\q1 oiemu hadibaia hereva dekenai lau giroa lou.   
\q1
\v 60 Lau naria kava lasi,  
\q1 to karaharaga oiemu oda hereva lau kamonai henia.   
\q1
\v 61 Kara dika taudia ese lau idia veria toho,  
\q1 edia kara be lau danu do lau karaia totona.  
\q1 To lau ese oiemu taravatu lau laloaboio lasi.   
\q1
\v 62 Hanuaboi momokani neganai lau toreisi noho,  
\q1 oi do lau hanamoa totona,  
\q1 badina oi ese kota hereva maoromaoro oi gwauraia noho.   
\q1
\v 63 Oi dekenai idia gari taudia,  
\q1 bona oiemu taravatu idia badinaia taudia ibounai be egu turana taudia.   
\q1
\v 64 Lohiabada e,  
\q1 tanobada be oiemu noho hanaihanai lalokauna dekenai ia honu noho.  
\q1 Oiemu taravatu lau dekenai mani do oi hadibaia.   
\s1 Lohiabada ena taravatu ese ita ia durua noho  
\q1
\v 65 Lohiabada e,  
\q1 lau, oiemu hesiai tauna dekenai kara namo oi karaia vadaeni.  
\q1 Oi ese oiemu gwauhamata oi hamomokania vadaeni.   
\q1
\v 66 Aonega bona lalona kehoa be lau dekenai do oi hadibaia,  
\q1 badina be oiemu taravatu lau abidadama henia noho.   
\q1
\v 67 Matakani ena hisihisi lau do abia lasi neganai,  
\q1 lau ese oiemu dala dekena amo lau raka siri,  
\q1 to harihari oiemu hereva lau kamonai henia noho.   
\q1
\v 68 Oi be namo,  
\q1 bona oiemu kara danu be namo.  
\q1 Oiemu taravatu mani lau dekenai do oi hadibaia.   
\q1
\v 69 Hekokoroku taudia ese,  
\q1 hereva koikoi dekena amo lau idia hadikaia noho,  
\q1 to lau ese oiemu hadibaia hereva lau kamonai henia,  
\q1 mai egu kudouna ibounai danu.   
\q1
\v 70 Inai taudia edia kudoudia be auka,  
\q1 bona mai edia lalona kehoa lasi,  
\q1 to lau ese oiemu taravatu lau moalelaia noho.   
\q1
\v 71 Oiemu matakani ena hisihisi lau abia,  
\q1 be lau dekenai ia namo bada,  
\q1 badina be unai matakani dainai oiemu taravatu lau tahua,  
\q1 bona ena namo lau davaria.   
\q1
\v 72 Oiemu uduna hereva ena taravatu be namo herea lau dekenai.  
\q1 Golo bona siliva momo herea,  
\q1 be oiemu taravatu ese ia hereaia momokani.   
\s1 Lohiabada ena taravatu ena maoromaoro bona momokani  
\q1
\v 73 Lohiabada e, oiemu imana ese lau idia karaia,  
\q1 bona oi ese lau oi naria noho.  
\q1 Mani emu kara lalona kehoa lau dekenai do oi henia,  
\q1 vadaeni oiemu taravatu edia anina do lau davaria.   
\q1
\v 74 Vadaeni oi dekenai idia gari noho taudia ese,  
\q1 lau idia itaia neganai do idia moale,  
\q1 badina be oiemu hereva lau abidadama henia noho momokani.   
\q1
\v 75 Lohiabada e, lau diba oiemu taravatu be maoromaoro.  
\q1 Bona lau diba oi ura lau do oi hamaoromaoroa dainai,  
\q1 oi ese matakani ena hisihisi lau dekenai oi siaia,  
\q1 badina oiemu taudia oi naria kara,  
\q1 be mai maoromaoro, bona momokani danu,  
\q1 bona nega ibounai oiemu kara be idau lasi.   
\q1
\v 76 Mani emu kara oiemu noho hanaihanai lalokauna dekena amo,  
\q1 lau do oi hagoadaia,  
\q1 badina be lau, oiemu hesiai tauna dekenai,  
\q1 oi ese unai bamona oi gwauhamata vadaeni.   
\q1
\v 77 Lau dekenai oiemu bogahisihisi do oi henia,  
\q1 vadaeni do lau mauri noho,  
\q1 badina be oiemu taravatu dekenai lau moale noho.   
\q1
\v 78 Hekokoroku taudia ese lau idia samania koikoi noho.  
\q1 Mani emu kara oi ese idia do oi koua,  
\q1 vadaeni do idia hemarai momokani.  
\q1 To lau ese oiemu hadibaia hereva do lau laloa noho.   
\q1
\v 79 Dirava dekenai idia gari,  
\q1 bona oiemu taravatu ena anina idia diba taudia,  
\q1 be mani lau dekenai do idia mai.   
\q1
\v 80 Lohiabada e,  
\q1 mani emu kara lau do oi durua,  
\q1 oiemu taravatu do lau naria namonamo momokani, kerere ta lasi,  
\q1 vadaeni hemarai be do lau abia diba lasi.   
\s1 Dirava ese lau do ia hamauria totona lau guriguri  
\q1
\v 81 Lohiabada e,  
\q1 egu lauma ese oiemu hamauria ia ura henia bada herea noho,  
\q1 bona egu goada be ia ore momokani.  
\q1 To lau ese oiemu hereva lau abidadama henia noho.   
\q1
\v 82 Oiemu gwauhamata lau naria noho dainai,  
\q1 egu matana idia manoka lao noho,  
\q1 bona lau tai noho, lau gwau,  
\q1 “Edena negai oi ese lau do oi durua?”   
\q1
\v 83 Lau be dika vadaeni,  
\q1 uaina udaia nanigosi kopina,  
\q1 ia makohia dainai idia negea ore gauna bamona,  
\q1 to lau ese oiemu taravatu lau laloaboio lasi.   
\q1
\v 84 Lohiabada e, lau, oiemu hesiai tauna,  
\q1 be do lau naria noho ela bona edena negai?  
\q1 Edena negai lau idia dagedage henia taudia edia dika davana,  
\q1 be do oi henia?   
\q1
\v 85 Hekokoroku taudia,  
\q1 oiemu taravatu idia kamonai henia lasi taudia,  
\q1 ese hunia dekenai lau hadikaia totona dalana idia karaia noho.   
\q1
\v 86 Lohiabada e,  
\q1 oiemu taravatu ibounai be ai abidadama henia diba.  
\q1 Mani lau do oi durua,  
\q1 badina tau haida ese,  
\q1 lau hadikaia totona hereva koikoi idia gwauraia noho.   
\q1
\v 87 Idia ese kahirakahira lau idia alaia,  
\q1 to lau ese oiemu taravatu lau rakatania lasi.   
\q1
\v 88 Oiemu noho hanaihanai lalokauna dainai,  
\q1 mani lau do oi naria namonamo.  
\q1 Unai neganai lau ese oiemu taravatu do lau kamonai henia.   
\s1 Lohiabada ena taravatu dekenai abidadama henia kara  
\q1
\v 89 Lohiabada e,  
\q1 oiemu hereva be do ia noho ela bona hanaihanai.  
\q1 Ia be guba dekenai ia gini goada noho.   
\q1
\v 90 Oiemu hereva be mai maoromaoro bona momokani danu oi badinaia,  
\q1 bona do oi badinaia noho ela bona hanaihanai.  
\q1 Oi ese tanobada oi karaia, bona ia gini goada noho.   
\q1
\v 91 Oi sibona oi hereva,  
\q1 vadaeni gau ibounai idia noho, ia mai bona hari danu,  
\q1 badina be gau ibounai bona taunimanima ibounai ese,  
\q1 oiemu gaukara idia karaia noho.   
\q1
\v 92 Bema oiemu taravatu lau moalelaia lasi neganai,  
\q1 egu hisihisi ese lau do ia hamasea momokani.   
\q1
\v 93 Lau ese oiemu taravatu do lau rakatania lasi,  
\q1 badina idia dekena amo oi ese lau oi hamauria.   
\q1
\v 94 Lohiabada e, lau be oiemu,  
\q1 mani lau do oi hamauria,  
\q1 badina lau ese oiemu hadibaia hereva lau tahua namonamo vadaeni.   
\q1
\v 95 Kara dika taudia be hunia dekenai lau idia naria noho,  
\q1 lau do idia alaia gwauraia,  
\q1 to lau ese oiemu oda hereva lau laloa noho.   
\q1
\v 96 Lau be hari lau diba, tanobada dekenai ia noho gauna ta,  
\q1 be ia namo momokani diba lasi,  
\q1 to oiemu taravatu sibona be ia namo herea momokani.   
\s1 Tau ta ese Dirava ena taravatu ia ura henia momokani  
\q1
\v 97 Lohiabada e,  
\q1 oiemu taravatu lau ura henia.  
\q1 Dina ena hora ibounai lalonai,  
\q1 oiemu taravatu lau laloa noho.   
\q1
\v 98 Oiemu taravatu be lau dekenai ia noho nega ibounai,  
\q1 bona ia ese aonega lau dekenai ia henia noho.  
\q1 Inai aonega ese,  
\q1 lau dekenai idia tuari taudia edia aonega ia hereaia.   
\q1
\v 99 Lauegu diba ese,  
\q1 egu hadibaia taudia ibounai edia diba ia hereaia noho,  
\q1 badina be lau ese Dirava ena hadibaia hereva lau laloa noho,  
\q1 ma lau laloa noho.   
\q1
\v 100 Bona egu aonega ese tau buruka edia aonega ia hereaia noho,  
\q1 badina be oi Dirava, oiemu oda hereva lau badinaia noho.   
\q1
\v 101 Lau ese kara dikadia dekena amo lau raka siri noho,  
\q1 badina be lau ura Dirava ena hereva do lau kamonai henia.   
\q1
\v 102 Lohiabada e,  
\q1 oiemu hadibaia hereva dekena amo lau raka siri lasi,  
\q1 badina be oi sibona ese,  
\q1 oiemu hereva lau dekenai oi hadibaia noho.   
\q1
\v 103 Lauegu uduna dekenai hani ena mamina be namo momokani,  
\q1 to Dirava e,  
\q1 oiemu hereva ena mamina ese hani ena mamina ia hereaia noho.   
\q1
\v 104 Lohiabada e,  
\q1 oiemu taravatu ese ura namodia lau dekenai ia henia noho.  
\q1 Unai dainai kara dikadia ibounai lau ura henia lasi.   
\s1 Dirava ena taravatu dekena amo diari ita abia  
\q1
\v 105 Lohiabada e,  
\q1 oiemu hereva be lamepa bamona,  
\q1 lau ia hakaua noho, vadaeni lau raka maoromaoro diba.  
\q1 Oiemu hereva be diari,  
\q1 ia ese egu dala ia hadiaria noho.   
\q1
\v 106 Lau ese lau gwauhamata vadaeni,  
\q1 oiemu hadibaia hereva maoromaorona do lau badinaia,  
\q1 vadaeni inai gwauhamata do lau makohia lasi momokani.   
\q1
\v 107 Lohiabada e,  
\q1 egu hisihisi be dika momokani.  
\q1 Oiemu gwauhamata hegeregerena oi ese lau do oi hamauria.   
\q1
\v 108 Lohiabada e, lau be oi dekenai lau guriguri,  
\q1 bona oi dekenai lau tanikiu henia.  
\q1 Lauegu tanikiu mani oi abia dae,  
\q1 bona oiemu oda hereva lau dekenai do oi hadibaia.   
\q1
\v 109 Nega ibounai mase be kahirakahira lau dekenai,  
\q1 to lau ese oiemu taravatu hereva lau laloaboio lasi.   
\q1
\v 110 Kara dika taudia ese tarapu idia atoa,  
\q1 lau do idia hadikaia totona,  
\q1 to lau ese oiemu hadibaia hereva lau rakatania lasi.   
\q1
\v 111 Oiemu oda hereva be nega ibounai lau dogoatao noho,  
\q1 badina inai hereva be egu kudouna ena moale gauna.   
\q1
\v 112 Lau ese lau gwauhamata vadaeni,  
\q1 oiemu taravatu do lau kamonai henia noho,  
\q1 ela bona do lau mase.   
\s1 Lohiabada ena taravatu ese iseda mauri ia naria noho diba  
\q1
\v 113 Lohiabada e,  
\q1 oiemu murina dekenai idia raka koikoi taudia,  
\q1 be lau ura henidia lasi,  
\q1 to lau ese oiemu taravatu lau ura henia noho.   
\q1
\v 114 Oi sibona ese egu mauri oi naria bona gimaia noho.  
\q1 Lau ese oiemu hereva lau hamomokania,  
\q1 bona lau abidadama henia noho.   
\q1
\v 115 Umui kara dika taudia e,  
\q1 lau dekena amo do umui raka siri,  
\q1 badina lau ese Dirava ena taravatu lau ura badinaia.   
\q1
\v 116 Lohiabada e, oi gwauhamata vadaeni,  
\q1 goada lau dekenai do oi henia.  
\q1 Inai goada do oi henia,  
\q1 vadaeni do lau mauri noho.   
\q1
\v 117 Lohiabada e,  
\q1 oi ese lau do oi dogoatao,  
\q1 vadaeni mauri do lau abia,  
\q1 bona lau ese oiemu oda hereva do lau badinaia nega ibounai.   
\q1
\v 118 Oiemu taravatu idia kamonai henia lasi taudia,  
\q1 be oi ese oi negea.  
\q1 Idia edia koikoi karadia be anina lasi.   
\q1
\v 119 Oi ese kara dika taudia oi laloa be momoru sibona.  
\q1 Unai dainai lau ese oiemu hadibaia hereva lau ura henia noho.   
\q1
\v 120 Lohiabada e, oi garina lau gari noho.  
\q1 Oiemu kota henia karadia lau laloa neganai, lau gari.   
\s1 Lohiabada ena taravatu kamonai henia kara  
\q1
\v 121 Lau ese kara maoromaoro bona kara namo lau karaia vadaeni,  
\q1 unai dainai mani emu kara lau do oi naria,  
\q1 lau idia alaia gwauraia taudia ese lau do idia hadikaia lasi.   
\q1
\v 122 Lau, oiemu hesiai tauna,  
\q1 egu mauri mani do oi hamauria.  
\q1 Lau do oi naria,  
\q1 vadaeni hekokoroku taudia ese lau do idia hisihisi henia lasi.   
\q1
\v 123 Egu matana idia dibura-dibura,  
\q1 oiemu hamauria lau tahua dainai,  
\q1 bona oiemu gwauhamata maoromaorona lau naria noho dainai.   
\q1
\v 124 Oiemu noho hanaihanai lalokauna hegeregerena,  
\q1 mani lau do oi durua,  
\q1 bona oiemu taravatu ena anina lau dekenai do oi hadibaia.   
\q1
\v 125 Lau be oiemu hesiai tauna dainai,  
\q1 lau dekenai oiemu aonega do oi henia,  
\q1 vadaeni oiemu hadibaia hereva be do lau diba.   
\q1
\v 126 Lohiabada e,  
\q1 taunimanima ese oiemu taravatu idia utua noho.  
\q1 Edia kerere davana do oi henia ena nega ia ginidae vadaeni.   
\q1
\v 127 Oiemu oda hereva lau lalokau henia bada,  
\q1 to golo lau ura henia sisina.  
\q1 Io, oiemu oda edia namo ese golo namo herea ia hereaia.   
\q1
\v 128 Unai dainai oiemu oda ibounai lau gwauraia be maoro.  
\q1 Dala koikoi ibounai be lau ura lasi momokani.   
\s1 Tau ta ia ura Dirava ena taravatu do ia kamonai henia momokani  
\q1
\v 129 Lohiabada e,  
\q1 oiemu hadibaia hereva be namo herea momokani.  
\q1 Unai dainai mai egu kudouna ibounai danu,  
\q1 idia dekenai lau kamonai henia noho.   
\q1
\v 130 Oiemu hereva hadibaia kara ese diari ia havaraia noho,  
\q1 bona oiemu hereva dekena amo,  
\q1 diba lasi taudia ese aonega idia davaria.   
\q1
\v 131 Lohiabada e, oiemu hereva lau ura henia dikadika noho.  
\q1 Unai dainai egu kudouna ia toreisi,  
\q1 oiemu hereva do lau badinaia totona.   
\q1
\v 132 Lau dekenai do oi laloa,  
\q1 bona lau dekenai do oi bogahisihisi henia,  
\q1 badina oi ese inai bamona oi karaia noho,  
\q1 oi idia lalokau henia taudia ibounai dekenai.   
\q1
\v 133 Oiemu gwauhamata hegeregere, lau do oi naria,  
\q1 vadaeni kara dika dekenai do lau moru lasi.  
\q1 Oi durua lau,  
\q1 vadaeni dika ese lau do ia halusia lasi.   
\q1
\v 134 Tau haida ese lau idia hadikaia gwauraia noho.  
\q1 Idia dekena amo lau do oi hamauria.  
\q1 Unai neganai lau ese oiemu oda hereva,  
\q1 be do lau kamonai henia diba.   
\q1
\v 135 Lohiabada e,  
\q1 mani lau kahirakahira do oi noho.  
\q1 Oiemu taravatu lau dekenai do oi hadibaia,  
\q1 bona oi ese lau do oi hanamoa.   
\q1
\v 136 Lauegu matana ena ranu be sinavai ranu bamona ia diho,  
\q1 badina be taunimanima momo ese,  
\q1 oiemu taravatu idia kamonai henia lasi noho.   
\s1 Lohiabada ena taravatu be maoromaoro  
\q1
\v 137 Lohiabada e, oiemu kara be maoromaoro bona momokani,  
\q1 bona oiemu taravatu danu be maoromaoro bona momokani.   
\q1
\v 138 Oi ese oi atoa taravatu ibounai,  
\q1 be namo bona maoromaoro.   
\q1
\v 139 Lau idia hadikaia gwauraia taudia ese,  
\q1 oiemu taravatu idia laloa lasi.  
\q1 Unai dainai egu lalona ia badu,  
\q1 lahi ena siahu bamona.   
\q1
\v 140 Oiemu gwauhamata ibounai be mai momokani danu,  
\q1 bona lau, oiemu hesiai tauna ese, idia lau ura henia noho.   
\q1
\v 141 Lau be anina lasi tauna,  
\q1 bona taunimanima ese lau idia hereva dika henia,  
\q1 to oiemu taravatu hereva,  
\q1 be lau ese lau rakatania lasi.   
\q1
\v 142 Oiemu kara maoromaoro be do ia noho hanaihanai,  
\q1 bona oiemu taravatu be nega ibounai do ia momokani.   
\q1
\v 143 Hisihisi bona laloa hekwarahi momo ese lau idia hadikaia noho,  
\q1 to oiemu taravatu ese lau idia hamoalea noho.   
\q1
\v 144 Oiemu hadibaia hereva be nega ibounai idia maoromaoro.  
\q1 Mani emu kara oiemu hereva dekena amo,  
\q1 diba bona aonega lau dekenai do oi henia,  
\q1 vadaeni mauri do lau davaria.   
\s1 Dirava ena hamauria totona guriguri ta  
\q1
\v 145 Lohiabada e,  
\q1 mai egu kudouna ibounai danu oi dekenai lau boiboi.  
\q1 Lau dekenai mani do oi haere,  
\q1 bona lau ese oiemu taravatu do lau kamonai henia.   
\q1
\v 146 Lohiabada e,  
\q1 oi dekenai lau boiboi noho,  
\q1 be mani lau do oi hamauria,  
\q1 vadaeni oiemu hadibaia hereva do lau badinaia.   
\q1
\v 147 Daba rere do lasi neganai,  
\q1 oiemu durua totona oi dekenai lau tai henia.  
\q1 Oiemu hereva dekenai lau abidadama henia noho.   
\q1
\v 148 Hanuaboi ena nega ibounai lalonai lau noga noho,  
\q1 lau mahuta lasi,  
\q1 badina oiemu hadibaia hereva lau laloa noho.   
\q1
\v 149 Oiemu lalokau be ia noho hanaihanai dainai,  
\q1 Lohiabada e, mani lau do oi kamonai henia.  
\q1 Oiemu bogahisihisi mani do oi hedinaraia,  
\q1 bona egu mauri do oi hamauria.   
\q1
\v 150 Lau dekenai idia badu henia,  
\q1 bona lau dekenai idia dagedage henia taudia,  
\q1 be lau dekenai kahirakahira idia raka mai noho.  
\q1 Idia ese oiemu taravatu idia badinaia lasi momokani.   
\q1
\v 151 To oi Lohiabada, oi be lau kahirakahira oi noho,  
\q1 bona oiemu taravatu ibounai be momokani.   
\q1
\v 152 Nega daudau ia lao vadaeni,  
\q1 lau ese oiemu hadibaia hereva lau tahua bona lau diba.  
\q1 Oi ese idia oi haginia, bona do idia noho hanaihanai.   
\s1 Durua totona guriguri ta  
\q1
\v 153 Lohiabada e,  
\q1 egu hisihisi do oi itaia,  
\q1 bona lau do oi hamauria,  
\q1 badina be oiemu taravatu lau laloaboio lasi.   
\q1
\v 154 Taunimanima edia vairana dekenai,  
\q1 egu hereva mani do oi durua,  
\q1 bona lau do oi hamauria.  
\q1 Lau dekenai mauri do oi henia, oiemu gwauhamata hegeregerena.   
\q1
\v 155 Kara dika taudia,  
\q1 be oiemu hamauria do idia davaria lasi,  
\q1 badina oiemu taravatu idia kamonai henia lasi.   
\q1
\v 156 To Lohiabada e, oiemu bogahisihisi be bada herea.  
\q1 Oiemu bogahisihisi mani do oi hedinaraia,  
\q1 bona lau do oi hamauria.   
\q1
\v 157 Lau idia hadikaia bona dagedage henia gwauraia taudia be momo,  
\q1 to oiemu taravatu badinaia kara dekena amo lau raka siri lasi.   
\q1
\v 158 Edia abidadama idia rakatania taudia lau itaia neganai,  
\q1 lau ura henidia lasi momokani,  
\q1 badina be oiemu taravatu idia kamonai henia lasi.   
\q1
\v 159 Lohiabada e, do oi laloa,  
\q1 lau ese oiemu hadibaia hereva lau ura henia bada noho.  
\q1 Oiemu lalokau be ia idau diba lasi dainai,  
\q1 mani lau do oi hamauria.   
\q1
\v 160 Oiemu hereva ibounai edia anina be momokani,  
\q1 bona oiemu kota hereva ibounai be maoromaoro,  
\q1 ela bona hanaihanai.   
\s1 Lohiabada ena taravatu ura henia momokani kara  
\q1
\v 161 Lohia taudia ese lau idia dagedage henia noho,  
\q1 badina ta lasi,  
\q1 to oiemu taravatu lau matauraia noho.   
\q1
\v 162 Oiemu gwauhamata dainai lau be moale bada.  
\q1 Egu moale be moni bada ia davaria tauna ena moale hegeregerena.   
\q1
\v 163 Lau ese koikoi lau ura henia lasi momokani,  
\q1 mai egu badu danu,  
\q1 to oiemu taravatu lau lalokau henia noho.   
\q1
\v 164 Dina ta ta lalonai,  
\q1 nega 7 lau ese oiemu ladana lau hanamoa noho,  
\q1 oiemu kota maoromaoro dainai.   
\q1
\v 165 Lohiabada e,  
\q1 oiemu taravatu idia ura henia noho taudia ese,  
\q1 maino namo herea idia abia noho,  
\q1 bona gau ta ese do ia hamorudia diba lasi.   
\q1
\v 166 Lohiabada e,  
\q1 oiemu hamauria totona oi dekenai lau naria noho,  
\q1 mai egu abidadama danu,  
\q1 bona oiemu oda lau badinaia noho.   
\q1
\v 167 Oiemu hadibaia hereva lau kamonai henia noho,  
\q1 badina mai egu kudouna ibounai idia lau lalokau henia bada noho.   
\q1
\v 168 Oiemu oda bona oiemu hadibaia hereva lau kamonai henia noho,  
\q1 badina be oi ese egu kara ibounai oi itaia noho.   
\s1 Durua totona ena guriguri  
\q1
\v 169 Lohiabada e,  
\q1 mani egu taitai oi dekenai do oi abia dae.  
\q1 Laloa kehoa lau dekenai do oi henia,  
\q1 oiemu gwauhamata hegeregerena.   
\q1
\v 170 Egu noinoi mani do oi kamonai henia,  
\q1 bona lau do oi hamauria,  
\q1 oiemu gwauhamata hegeregerena.   
\q1
\v 171 Lau ese oi do lau hanamoa noho hanaihanai,  
\q1 badina be oi ese oiemu taravatu lau dekenai oi hadibaia noho.   
\q1
\v 172 Oiemu taravatu dainai ane do lau abia,  
\q1 badina be oiemu oda herevadia be maoromaoro.   
\q1
\v 173 Mani lau durua totona do oi noho hegaegae nega ibounai,  
\q1 badina oiemu taravatu edia dala dekenai lau raka noho.   
\q1
\v 174 Lohiabada e,  
\q1 oiemu hamauria ena durua totona oi dekenai lau laloa noho,  
\q1 mai egu lalokau bada danu.  
\q1 Oiemu taravatu dekena amo moale lau davaria noho.   
\q1
\v 175 Lau dekenai mauri do oi henia,  
\q1 oi do lau hanamoa noho diba totona.  
\q1 Oiemu hadibaia hereva dekena amo lau do oi durua.   
\q1
\v 176 Lau be lau loaloa kava noho,  
\q1 ia boio vadaeni mamoe bamona.  
\q1 Unai dainai mani emu kara lau,  
\q1 oiemu hesiai tauna, do oi tahua,  
\q1 badina be oiemu taravatu lau laloaboio lasi.   
\c 120  
\s1 Idau tano dekenai ia noho tauna ena guriguri  
\q1
\v 1 Egu lalona ia hisihisi neganai,  
\q1 lau ese Lohiabada dekenai lau tai henia,  
\q1 bona ia ese lau dekenai ia haere henia.   
\q1
\v 2 Lau gwau,  
\q1 “Lohiabada e,  
\q1 koikoi taudia dekena amo,  
\q1 bona samania koikoi taudia dekena amo lau do oi hamauria.”   
\b  
\q1
\v 3 Koikoi tauna e, Lohiabada ese oi dekenai dahaka do ia karaia?  
\q1 Oiemu kerere davana be edena dala dekenai do ia henia?   
\q1
\v 4 Ia ese tuari tauna ena diba mai edia matana,  
\q1 dekena amo oi do ia pidia,  
\q1 bona ia ese lahi gidadia,  
\q1 siahu herea gaudia oiemu latanai do ia bubua.   
\b  
\q1
\v 5 Lau be umui dika taudia emui huanai lau noho,  
\q1 bona egu noho be dika,  
\q1 Meseka o Kedara dekenai lau noho ena dika bamona.   
\q1
\v 6 Maino idia ura henia lasi taudia edia huanai,  
\q1 be lau noho nega daudau momokani.   
\q1
\v 7 Lau be maino lau ura,  
\q1 to lau be inai bamona lau hereva neganai,  
\q1 idia be tuari idia ura.   
\c 121  
\s1 Lohiabada be iseda naria bona gimaia tauna  
\q1
\v 1 Lau ese ororo dekenai egu matana do lau negea,  
\q1 to lau do ia durua tauna be edeseni do lau davaria?   
\q1
\v 2 Lohiabada be egu durua Tauna.  
\q1 Ia ese guba bona tanobada ia karaia.   
\b  
\q1
\v 3 Lohiabada ese oi do ia dogoatao,  
\q1 vadaeni oiemu aena do ia dedi lasi.  
\q1 Ia ese oi do ia naria,  
\q1 ia be ia mahuta lasi.   
\q1
\v 4 Kamonai!  
\q1 Lohiabada ese Israela ia naria noho.  
\q1 Ia be nega ta ia mahuta lasi,  
\q1 lasi momokani.   
\b  
\q1
\v 5 Lohiabada ese oi do ia gimaia.  
\q1 Ia be oiemu badibadinai ia noho,  
\q1 oi ia naria noho.   
\q1
\v 6 Dina neganai, dina ena siahu ese oi do ia hagorerea lasi,  
\q1 bona hanuaboi neganai hua ese oi do ia hadikaia lasi.   
\q1
\v 7 Lohiabada ese dika ibounai dekena amo oi ia naria noho.  
\q1 Ia ese oiemu mauri do ia gimaia.   
\q1
\v 8 Oiemu ruma oi rakatania neganai,  
\q1 Lohiabada ese oi do ia naria,  
\q1 bona oi giroa mai neganai danu,  
\q1 ia ese oi do ia gimaia,  
\q1 harihari ia lao bona hanaihanai.   
\c 122  
\s1 Ierusalema idia hanamoa ane  
\q1
\v 1 Lau dekenai idia hereva, idia gwau,  
\q1 “Lohiabada ena Ruma dekenai do ita lao.”  
\q1 Inai bamona idia hereva neganai,  
\q1 lau be mai moale bada danu.   
\b  
\q1
\v 2 Vadaeni harihari ita be Ierusalema dekenai ita noho,  
\q1 Ierusalema ena magu ikoukou edia lalonai ita gini noho.   
\b  
\q1
\v 3 Ierusalema be idia ese idia haginia lou, hanua badana.  
\q1 Iena toana be namo,  
\q1 badina be idia haginia namonamo vadaeni.   
\q1
\v 4 Israela ena iduhu taudia ibounai be iniseni idia mai noho.  
\q1 Lohiabada do idia tanikiu henia totona,  
\q1 iena oda hereva gunana hegeregerena.   
\q1
\v 5 Inai Ierusalema dekenai be Israela ena king taudia ese,  
\q1 edia bese taudia idia kota henia.   
\b  
\q1
\v 6 Ierusalema ena maino totona do umui guriguri.  
\q1 Lau ura Ierusalema idia ura henia taudia,  
\q1 be do idia noho mai maino danu.   
\q1
\v 7 Lau ura maino be Ierusalema ena magu lalonai do ia noho,  
\q1 bona lau ura Ierusalema ena kohoro lalonai,  
\q1 taunimanima ese mauri do idia davaria.   
\q1
\v 8 Lau ese egu turana bona egu varavara lau laloa noho,  
\q1 bona Ierusalema dekenai lau hereva, lau gwau,  
\q1 “Maino be oiemu lalona dekenai do ia noho be namo.”   
\q1
\v 9 Lau be Lohiabada, iseda Dirava ena Ruma lau laloa noho.  
\q1 Unai dainai Dirava lau noia noho,  
\q1 ia ese Ierusalema do ia hanamoa bada.   
\c 123  
\s1 Bogahisihisi totona guriguri ta  
\q1
\v 1 Lohiabada e, egu matana be oi dekenai lau negea noho.  
\q1 Oi be guba dekenai oi helai noho,  
\q1 guba ena King.   
\q1
\v 2 Hesiai tauna ese iena biaguna ia abidadama henia noho,  
\q1 bona hesiai kekeni ese,  
\q1 iena biaguna hahine ia abidadama henia noho hegeregerena,  
\q1 ai ese unai bamona oi dekenai do ai abidadama henia noho,  
\q1 ela bona oi ese ai dekenai oi bogahisihisi henia.   
\q1
\v 3 Lohiabada e, ai dekenai do oi bogahisihisi,  
\q1 badina be taunimanima ese ai idia kirikirilaia bada vadaeni.   
\q1
\v 4 Nega daudau herea,  
\q1 be noho kava bona mai edia hekwarahi lasi taudia ese,  
\q1 ai idia hevaseha henia,  
\q1 bona hekokoroku taudia be mai dagedage danu,  
\q1 ai dekenai idia hereva dika vadaeni.   
\c 124  
\s1 Dirava be iena bese taudia edia Hamauria Tauna  
\q1
\v 1 Bema Lohiabada ese ita ia durua lasi neganai,  
\q1 ita be edena bamona do ita karaia?  
\q1 Israela taudia ese inai henanadai idia haere henia be namo.   
\q1
\v 2 Ita dekenai idia dagedage taudia ese ita idia tuari henia,  
\q1 bona bema Lohiabada ese ita ia durua lasi neganai,   
\q1
\v 3 unai dagedage taudia ese ita do idia hadikaia ore,  
\q1 idia edia badu mai siahu bada dekena amo.   
\q1
\v 4 Unai neganai abata ese ita do ia abia lao,  
\q1 bona ranu bada ese ita do ia koua momokani.   
\q1
\v 5 Hurehure badana ese ita do ia koua,  
\q1 vadaeni ita be do ita mase ore,  
\q1 to inai bamona ia vara lasi.   
\b  
\q1
\v 6 Ita ese Lohiabada do ita tanikiu henia be namo,  
\q1 Ia ese ita idia hadikaia gwauraia taudia ia koua.   
\q1
\v 7 Ita ese idia dekena amo ita heau mauri,  
\q1 manu ese labana tauna ena tarapu dekena amo ia heau mauri bamona.  
\q1 Tarapu ia makohia vadaeni,  
\q1 bona ita heau mauri vadaeni.   
\q1
\v 8 Lohiabada ese ita ia durua noho.  
\q1 Ia ese guba bona tanobada ia karaia.   
\c 125  
\s1 Dirava ese iena bese taudia dekenai noho mauri namona ia henia  
\q1
\v 1 Lohiabada idia abidadama henia taudia be Siona Ororo bamona.  
\q1 Inai Ororo be ia marere diba lasi,  
\q1 ia be do ia gini goada noho hanaihanai.   
\q1
\v 2 Ororo ese Ierusalema idia koua hagegea noho hegeregerena,  
\q1 Lohiabada ese iena bese taudia unai bamona ia koua hagegea noho,  
\q1 hari inai neganai, ia lao bona hanaihanai.   
\b  
\q1
\v 3 Kara dika taudia ese nega ibounai,  
\q1 Dirava ena bese taudia edia tano do idia biagua lasi,  
\q1 badina bema unai bamona neganai,  
\q1 sedira Dirava ena bese taudia danu ese kara dika do idia karaia.   
\b  
\q1
\v 4 Lohiabada e,  
\q1 kara namo taudia do oi hanamoa.  
\q1 Oiemu taravatu idia kamonai henia noho taudia do oi hanamoa.   
\q1
\v 5 To oi ese kara dika taudia edia dika davana oi henia neganai,  
\q1 mani emu kara,  
\q1 oiemu dala idia rakatania taudia danu edia dika davana do oi henia.  
\b  
\q1 Israela dekenai maino ia noho, be namo!   
\c 126  
\s1 Israela taudia ese Dirava idia noia do ia hamauridia  
\q1
\v 1 Lohiabada ese ita ia abia mai lou Siona dekenai neganai,  
\q1 ita be nihi ita abia noho taudia bamona.   
\q1
\v 2 Unai neganai ita kiri bada,  
\q1 bona mai moale bada danu ane ita abia!  
\q1 Bona idau bese taudia ese ita idia herevalaia, idia gwau,  
\q1 “Lohiabada ese kara badadia idia totona ia karaia vadaeni.”   
\q1
\v 3 Momokani!  
\q1 Ia ese kara badadia momokani ita totona ia karaia.  
\q1 Unai dainai ita be mai moale bada danu.   
\b  
\q1
\v 4 Lohiabada e, mani emu kara,  
\q1 ai do oi hakaua lou aiemai tano dekenai.  
\q1 Ai do oi mailaia lou,  
\q1 medu ese sinavai kaukau dekenai ranu ia mailaia lou bamona.   
\q1
\v 5 Idia hadohado neganai,  
\q1 madi edia matana ena ranu ia diho taudia,  
\q1 be gabeai mai edia moale danu,  
\q1 anina do idia gogoa.   
\q1
\v 6 Io, momokani,  
\q1 uhe idia abia lao neganai idia tai noho taudia,  
\q1 be mai moale danu do idia giroa mai,  
\q1 bona anina idia mailaia neganai ane do idia abia.   
\c 127  
\s1 Dirava ena kara namo ita dekenai dainai iena ladana do ita hanamoa  
\q1
\v 1 Bema Lohiabada ese ruma ia haginia lasi neganai,  
\q1 unai ruma idia haginia taudia idia hekwarahi kava noho.  
\q1 Bema Lohiabada ese hanua ta ia naria lasi neganai,  
\q1 hanua gimaia taudia ese idia gimaia kava.   
\q1
\v 2 Ita ese daba maragi neganai ita toreisi,  
\q1 bona ita gaukara auka ela bona hanuaboi momokani,  
\q1 moni bona aniani gaudia do ita davaria totona.  
\q1 To inai bamona ita karaia kava,  
\q1 badina be Lohiabada ese ia lalokau henidia taudia dekenai,  
\q1 aniani bona kohu ia henidia,  
\q1 bona idia mahuta namonamo.   
\b  
\q1
\v 3 Kamonai!  
\q1 Iseda natudia be Dirava ena harihari gauna ita dekenai.  
\q1 Dirava ese ita dekenai ia henidia,  
\q1 bona idia ese ita idia hanamoa noho.   
\q1
\v 4 Eregabe tauna ena natuna taudia be,  
\q1 tuari tauna ena imana dekenai peva ena diba bamona.   
\q1
\v 5 Bema tau ta be mai ena natuna momo, ia be do ia moale.  
\q1 Idia ese ia do idia durua, vadaeni do ia kwalimu,  
\q1 bona inai tau idia hadikaia gwauraia taudia idia kota henia neganai,  
\q1 ia be kota do ia lusi lasi.   
\c 128  
\s1 Lohiabada kamonai henia kara ena davana namona  
\q1
\v 1 Lohiabada dekenai idia gari noho taudia ibounai be namo,  
\q1 badina iena dala dekenai idia raka noho.   
\b  
\q1
\v 2 Oiemu gaukara ena davana do oi davaria.  
\q1 Do oi moale, bona oiemu noho do ia namo.   
\q1
\v 3 Oiemu ruma dekenai oiemu adavana,  
\q1 be vain auna mai ena huahua momo bamona.  
\q1 Oiemu natuna memero be olive au matamatadia bamona,  
\q1 oiemu aniani patana do idia helai hagegea noho.   
\q1
\v 4 Momokani, tau ta bema Lohiabada ia kamonai henia neganai,  
\q1 ia ese hanamoa inai bamona do ia davaria.   
\b  
\q1
\v 5 Siona dekena amo Lohiabada ese oi do ia hanamoa!  
\q1 Bona oiemu mauri dinadia ibounai lalonai, do oi itaia,  
\q1 Ierusalema ena noho be namo herea.   
\q1
\v 6 Lau ura oiemu mauri dinadia be momo,  
\q1 vadaeni oiemu tubuna do oi itadia!  
\b  
\q1 Israela dekenai maino ia noho, be namo!   
\c 129  
\s1 Israela dekenai idia tuari henia taudia be Dirava ese do ia hadikaia  
\q1
\v 1 Israela e, ai dekenai oiemu sivarai do oi hadibaia,  
\q1 oi dekenai idia tuari henia taudia ese,  
\q1 nega daudau oi idia hadikaia vadaeni.  
\q1 Oi be mero neganai ia mai bona harihari,  
\q1 unai bamona idia karaia.   
\q1
\v 2 Israela ese ia haere, ia gwau,  
\q1 “Io, lau be mero neganai ia mai bona hari,  
\q1 lau idia hadikaia gwauraia taudia ese,  
\q1 lau idia dagedage henia dikadika,  
\q1 to idia ese lau idia halusia lasi.   
\q1
\v 3 Idia ese lau idia kwadia,  
\q1 kwadi gauna ese egu doruna ena kopina ia utua dobu.  
\q1 Egu doruna ena berona toana,  
\q1 be uma gabuna ena dadaira latadia momo bamona.   
\q1
\v 4 To Lohiabada ena kara be maoromaoro.  
\q1 Ia ese hesiai mai guia danu edia seini,  
\q1 dekena amo lau ia kokia ruhaia vadaeni.”   
\b  
\q1
\v 5 Lau ura Siona idia badu henia taudia ibounai,  
\q1 be tuari dekenai do idia lusi,  
\q1 bona mai hemarai danu do idia heau lou.   
\q1
\v 6 Namona idia be ruma ena guhi dekenai idia tubu rei bamona,  
\q1 do idia huahua lasi neganai do idia kaukau.   
\q1
\v 7 Rei utua tauna ese,  
\q1 unai rei be iena imana dekenai do ia abia lasi,  
\q1 bona rei guia tauna,  
\q1 be iena kemena dekenai do ia haboua lasi.   
\q1
\v 8 Vadaeni raka hanaia taudia ese,  
\q1 inai taudia do idia herevalaia lasi, do idia gwau lasi,  
\q1 “Lohiabada ese umui do ia hanamoa!  
\q1 Lohiabada ena ladana dainai ai ese umui ai hanamoa noho!”   
\c 130  
\s1 Tau ta ese Dirava ia noia, do ia durua  
\q1
\v 1 Lohiabada e, egu lalona ia metau momokani dainai,  
\q1 oi dekenai lau tai noho!   
\q1
\v 2 Lohiabada e,  
\q1 egu taitai mani do oi kamonai!  
\q1 Durua totona lau noinoi noho,  
\q1 be mani do oi kamonai!   
\b  
\q1
\v 3 Bema oi ese aiemai kara dika ibounai oi duahia neganai,  
\q1 daika ese oiemu kota lalonai ia kwalimu diba?   
\q1
\v 4 To oi ese aiemai dika oi gwauatao noho,  
\q1 unai dainai ai ese oi dekenai ai gari henia be namo.   
\b  
\q1
\v 5 Lau ura dikadika Lohiabada ese lau do ia durua,  
\q1 bona iena hereva lau abidadama henia noho.   
\q1
\v 6 Lau ese Lohiabada totona lau naria noho,  
\q1 lau ura bada ia ese lau do ia durua.  
\q1 Bona inai Lohiabada dekenai lau naria kara ese,  
\q1 hanua idia gimaia taudia edia naria kara ia hereaia noho,  
\q1 idia ese daba rere totona idia naria neganai.   
\b  
\q1
\v 7 Israela taudia e,  
\q1 Lohiabada do umui abidadama henia,  
\q1 badina iena lalokau bona bogahisihisi idia noho hanaihanai,  
\q1 bona nega ibounai ia ura taunimanima do ia hamauridia.   
\q1
\v 8 Lohiabada ese iena bese, Israela taudia,  
\q1 edia kara dika ibounai dekena amo do ia hamauridia.   
\c 131  
\s1 Abidadama tauna ta ena guriguri  
\q1
\v 1 Lohiabada e, egu hekokoroku be lau rakatania vadaeni.  
\q1 Egu ladana lau habadaia karana be lau hadokoa vadaeni.  
\q1 Gau bada herea, bona hoa gaudia,  
\q1 egu aonega idia hanaia gaudia dekenai lau laloa lasi.   
\q1
\v 2 Lasi momokani, to lauegu lauma be lau ese lau hamanaua,  
\q1 bona lau hamanadaia,  
\q1 mero maragina be sinana ena kemena dekenai ia manau noho bamona.  
\q1 Egu lauma be unai bamona ia manau noho.   
\b  
\q1
\v 3 Israela taudia e,  
\q1 umui ese Lohiabada do umui abidadama henia,  
\q1 hari inai negana dekena amo ia lao bona hanaihanai.   
\c 132  
\s1 Dubu Helaga do ita hanamoa  
\q1
\v 1 Lohiabada e,  
\q1 Davida do oi laloaboio lasi.  
\q1 Hisihisi momo be ia ese ia abia,  
\q1 mai haheauka danu, mani do oi laloa.   
\b  
\q1
\v 2 Ia ese oi Lohiabada dekenai ia gwauhamata.  
\q1 Iakobo ena Dirava dekenai ia gwauhamata,   
\q1
\v 3 ia gwau: “Lauegu ruma lalonai do lau raka vareai lasi,  
\q1 egu mahuta patana dekenai do lau hekure lasi,   
\q1
\v 4 ma egu matana do lau koua lasi,   
\q1
\v 5 ela bona Lohiabada ena gabu ta do lau abia hegaegae,  
\q1 Iakobo ena Siahu Ibounai Dirava ena noho gabuna ta be unai.”   
\b  
\q1
\v 6 Betelehema dekenai sivarai ita kamonai,  
\q1 Lohiabada ena Taravatu Maua ena herevana ita kamonai,  
\q1 bona ita ese Iara ena uma gabuna dekenai ita davaria.   
\q1
\v 7 Vadaeni ita gwau,  
\q1 “Lohiabada ena Ruma dekenai do ita lao.  
\q1 Iena terona ena vairana dekenai do ita tomadiho be namo.”   
\q1
\v 8 Lohiabada e, do oi toreisi,  
\q1 oiemu laga-ani gabuna dekenai do oi mai,  
\q1 bona oi ese oiemu Taravatu Maua do oi mailaia.  
\q1 Inai Maua be oiemu siahu ena toana.   
\q1
\v 9 Oiemu hahelagaia taudia ese,  
\q1 kara maoromaoro sibona nega ibounai do idia karaia be namo.  
\q1 Bona oiemu bese taudia,  
\q1 be mai moale bada danu do idia boiboi be namo.   
\b  
\q1
\v 10 Oi ese oiemu hesiai tauna Davida dekenai oi gwauhamata vadaeni.  
\q1 Lohiabada e,  
\q1 oi ese oi abia hidi king do oi rakatania lasi.   
\b  
\q1
\v 11 Oi ese gwauhamata metauna Davida dekenai oi karaia vadaeni,  
\q1 bona inai gwauhamata be do oi utua lasi.  
\q1 Oi gwau,  
\q1 “Lau ese oiemu natuna ta dekenai king dagi do lau henia,  
\q1 bona ia ese oiemu gabu dekenai king siahuna do ia abia.   
\q1
\v 12 Bema oiemu natuna tau ese,  
\q1 egu gwauhamata taravatuna idia badinaia,  
\q1 bona idia dekenai lau henia taravatu do idia kamonai henia neganai,  
\q1 idia edia natudia danu ese,  
\q1 oiemu king dagina do idia abia noho, nega hanaihanai.”   
\b  
\q1
\v 13 Lohiabada ese Siona ia abia hidi vadaeni.  
\q1 Ia ura Siona be iena hanua do ia halaoa.   
\q1
\v 14 Ia gwau,  
\q1 “Inai hanua dekenai do lau noho ela bona hanaihanai,  
\q1 badina be inai gabu lau ura henia momokani.   
\q1
\v 15 Lau ese gau ibounai Siona dekenai do lau atoa,  
\q1 iena taudia edia ura gaudia ibounai.  
\q1 Bona iena ogogami taudia dekenai,  
\q1 aniani momo do lau henia,  
\q1 idia boga kunu totona.   
\q1
\v 16 Lau ese Siona ena hahelagaia taudia do lau hanamoa,  
\q1 edia kara ibounai dekenai.  
\q1 Idia ese hamauria hereva do idia harorolaia,  
\q1 bona Siona ena taudia ese ane do idia abia,  
\q1 mai edia moale danu.   
\b  
\q1
\v 17 “Siona dekenai Davida ena tubuna ta,  
\q1 be king badana momokani do lau halaoa.  
\q1 Siona dekenai, lau ese lau abia hidi king ena king siahuna,  
\q1 be do ia noho ela bona hanaihanai.   
\q1
\v 18 Ia do idia hadikaia gwauraia taudia be do lau hahemaraidia,  
\q1 to iena basileia taudia be do idia noho,  
\q1 mai namo bona mai goada danu.”   
\c 133  
\s1 Dirava ena taudia ese idia ta ta dekenai idia lalokau henia  
\q1
\v 1 Bema Dirava ena taudia do idia noho hebou,  
\q1 mai edia laloa tamona neganai,  
\q1 unai kara be namo, bona mai ena moale danu.   
\q1
\v 2 Unai be dehoro namo herea,  
\q1 Arona ena kwarana dekenai idia bubua bamona,  
\q1 Arona ena auki huina dekenai ia bubua diho noho,  
\q1 iena kouti dabua ena aiona gabuna dekenai danu.   
\q1
\v 3 Unai lalokau hebou,  
\q1 be Heremona Ororo ena hanuaboi ranu bamona.  
\q1 Inai hanuaboi ranu,  
\q1 be Siona Ororo ena latanai danu ia moru noho.  
\q1 Inai gabu dekenai be Lohiabada ese ia gwauhamata vadaeni,  
\q1 iena hanamoa do ia atoa.  
\q1 Iena hanamoa be inai: Mauri hanaihanai.   
\c 134  
\s1 Dirava do ita hanamoa  
\q1
\v 1 Umui Lohiabada ena hesiai gaukara karaia noho taudia ibounai e,  
\q1 umui mai,  
\q1 Lohiabada do umui hanamoa.  
\q1 Umui be hanuaboi neganai iena Dubu Helaga lalonai umui gini noho.   
\q1
\v 2 Dubu Helaga lalonai emui imana do umui abia isi,  
\q1 do umui guriguri,  
\q1 bona Lohiabada do umui hanamoa.   
\q1
\v 3 Lohiabada, guba bona tanobada ia karaia ena Dirava,  
\q1 ese Siona dekena amo umui do ia hanamoa!   
\c 135  
\s1 Dirava hanamoa ane ta  
\q1
\v 1 Dirava do umui hanamoa!  
\q1 Lohiabada ena gaukara umui karaia taudia e,  
\q1 Lohiabada ena ladana do umui hanamoa.   
\q1
\v 2 Lohiabada ena Ruma helagana lalonai umui gini noho,  
\q1 iseda Dirava ena Dubu Helaga lalonai.   
\b  
\q1
\v 3 Lohiabada do umui hanamoa,  
\q1 badina Lohiabada be ia namo.  
\q1 Ane dekenai iena ladana do umui hanamoa,  
\q1 badina ia be mai ena bogahisihisi.   
\q1
\v 4 Badina be Lohiabada ese Iakobo ia abia hidi vadaeni,  
\q1 ia sibona ena.  
\q1 Israela taudia ia abia hidi,  
\q1 iena bese korikori.   
\b  
\q1
\v 5 Lau diba Lohiabada be ia bada.  
\q1 Ia ese dirava ibounai ia hereaia momokani.   
\q1
\v 6 Badina Lohiabada ese sibona ena ura ia karaia noho,  
\q1 guba dekenai bona tanobada dekenai danu,  
\q1 davara dekenai bona davara ena dobu gabudia danu.   
\q1
\v 7 Ia ese tanobada ena kahana ibounai dekenai,  
\q1 medu ena ori ia havaraia noho.  
\q1 Ia ese iena medu ia siaia neganai,  
\q1 kevaru danu ia havaraia noho.  
\q1 Bona lai danu ia mailaia,  
\q1 ia haboua gabuna, guba dekena amo.   
\b  
\q1
\v 8 Aigupito dekenai Lohiabada ese vara guna natudia ia alaia mase,  
\q1 taunimanima edia vara guna natudia,  
\q1 bona edia ubua gaudia edia vara guna natudia danu.   
\q1
\v 9 Aigupito dekenai Lohiabada ese,  
\q1 hoa karadia bona toa karadia ia karaia,  
\q1 Aigupito ena king,  
\q1 bona iena hesiai taudia ibounai do ia hadikaia totona.   
\q1
\v 10 Lohiabada ese bese momo ia hadikaia ore,  
\q1 bona ia ese, mai edia siahu bada king taudia ia alaia mase:   
\q1
\v 11 Sihona, Amoro taudia edia king, Oga, Basana tano ena king,  
\q1 bona Kanana taudia edia king ibounai.   
\q1
\v 12 Inai king edia tano,  
\q1 be Lohiabada ese iena bese taudia dekenai ia henia.  
\q1 Israela besena dekenai edia tano ia henia.   
\b  
\q1
\v 13 Lohiabada e,  
\q1 oiemu ladana be taunimanima ese do idia gwauraia hanaihanai,  
\q1 bona gabeai do idia vara bese taudia ese oi do idia laloatao.   
\q1
\v 14 Lohiabada ese iena bese taudia do ia gwauraidia maoro.  
\q1 Ia ese iena hesiai taudia dekenai do ia bogahisihisi henia.   
\b  
\q1
\v 15 Bese idauidau edia dirava,  
\q1 be siliva bona golo dekena amo idia karaia noho.  
\q1 Taunimanima ese edia imadia dekena amo dirava idia karadia noho.   
\q1
\v 16 Idia be mai ududia,  
\q1 to idia hereva diba lasi.  
\q1 Idia be mai edia matadia,  
\q1 to idia itaia diba lasi.   
\q1
\v 17 Idia be mai taiadia,  
\q1 to idia kamonai diba lasi.  
\q1 Idia hahodi diba lasi danu.   
\q1
\v 18 Lau ura inai kaivakuku idia karaia,  
\q1 bona idia dekenai idia abidadama henia taudia ibounai,  
\q1 be unai kaivakuku hegeregerena, Lohiabada ese idia do ia halaoa.   
\b  
\q1
\v 19 Israela taudia e,  
\q1 Lohiabada do umui hanamoa.  
\q1 Arona ena iduhu taudia ibounai e,  
\q1 Lohiabada do umui hanamoa.   
\q1
\v 20 Umui Levi taudia e,  
\q1 Lohiabada do umui hanamoa.  
\q1 Lohiabada dekenai umui gari henia taudia ibounai e,  
\q1 ia do umui hanamoa.   
\q1
\v 21 Siona dekenai umui noho taudia e, Lohiabada do umui hanamoa.  
\q1 Inai be Ierusalema, Lohiabada ena noho gabuna momokani.  
\b  
\q1 Lohiabada do umui hanamoa!   
\c 136  
\s1 Dirava tanikiu henia ane ta  
\q1
\v 1 Lohiabada do ita tanikiu henia,  
\q1 badina ia be namo.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 2 Ia be dirava ibounai ia hereaia Diravana,  
\q1 bona do ita tanikiu henia.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 3 Ia be lohia ibounai ia hereaia Lohiana,  
\q1 bona do ita tanikiu henia.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 4 Lohiabada sibona ese hoa kara badadia ia karaia noho.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 5 Iena aonega dekena amo guba ia karaia.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 6 Ia ese tanobada be davara ena latanai ia haginia.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 7 Dina, hua bona hisiu, be ia ese ia karaia.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 8 Dina ena diari ese dina ia biagua noho.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 9 Hua bona hisiu ese hanuaboi idia biagua noho.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\b  
\q1
\v 10 Aigupito dekenai vara guna natudia ia alaia mase Diravana,  
\q1 be do ita tanikiu henia,  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 11 Ia ese Aigupito dekena amo Israela taudia ia hakaua mai.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 12 Iena imana mai ena goada, bona mai ena siahu bada dekena amo.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\b  
\q1
\v 13 Ia ese Davara Kakakaka ia hapararaia.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 14 Ia ese davara ena huanai iena bese taudia ia hakaudia mauri.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 15 To ia ese Aigupito ena king bona iena tuari orea,  
\q1 be Davara Kakakaka dekenai ia aladia mase.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\b  
\q1
\v 16 Lohiabada ese iena bese taudia,  
\q1 tano kaukau dekenai ia hakaudia hanaia.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 17 Ia ese, mai edia siahu bada king taudia ia alaia mase.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 18 Ia ese mai edia sivarai badadia king taudia ia alaia mase.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 19 Sihona, Amoro taudia edia king.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 20 Oga, Basana taudia edia king.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 21 Edia tano be iena bese taudia dekenai ia henia.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 22 Inai tano be Israela, iena hesiai tauna dekenai ia henia.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 23 Tuari ita lusi neganai Lohiabada ese ita ia laloaboio lasi.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 24 Ita idia hadikaia gwauraia taudia dekena amo,  
\q1 Dirava ese ita ia hamauria.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\q1
\v 25 Ia ese mauri gaudia ibounai dekenai aniani ia henia noho.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\b  
\q1
\v 26 Guba ena Dirava do ita tanikiu henia be namo.  
\q1 Iena lalokau bona bogahisihisi do idia noho hanaihanai.   
\c 137  
\s1 Israela taudia be Babulonia dekenai idia lalohisihisi ena ane  
\q1
\v 1 Babulonia ena sinavai badibadinai ai helai,  
\q1 bona unuseni Siona ai laloa neganai ai tai.   
\q1
\v 2 Sinavai badinai idia gini noho audia edia rigi dekenai,  
\q1 aiemai gita ai taua dae.   
\q1
\v 3 Ai idia abia mauri taudia ese,  
\q1 ai idia oda henia ane do ai abia,  
\q1 idia do ai hamoalea totona.  
\q1 Idia gwau,  
\q1 “Siona ena ane ta do umui abia.”   
\b  
\q1
\v 4 To idau tano dekenai,  
\q1 Lohiabada ena ane be edena bamona do ai abia diba?   
\q1
\v 5 Ierusalema e, bema lau ese oi lau laloaboio neganai,  
\q1 namona be egu imana do ia dika,  
\q1 vadaeni gita do lau botaia lou diba lasi.   
\q1
\v 6 Bema oi lau laloaboio neganai,  
\q1 bona oi be egu moale gauna momokani do lau halaoa lasi neganai,  
\q1 namona be egu malana do ia dika,  
\q1 vadaeni ane do lau abia lou lasi.   
\b  
\q1
\v 7 Lohiabada e,  
\q1 Edoma taudia edia kara mani oi laloa noho,  
\q1 Ierusalema idia tuari henia, bona idia abia neganai,  
\q1 edia hereva mani oi laloa lou, idia gwau,  
\q1 “Ierusalema hanua do ita makohia, do ia diho momokani.”   
\b  
\q1
\v 8 Babulonia e, kamonai!  
\q1 Oi be do idia hadikaia ore momokani.  
\q1 Ai dekenai kara dika oi karaia vadaeni,  
\q1 ena davana oi dekenai do ia karaia tauna be do ia moale,   
\q1
\v 9 bona oiemu natuna maragidia do ia abia,  
\q1 nadi badana dekenai do ia negedia diho, ia hamasedia ore,  
\q1 unai tauna be do ia moale.   
\c 138  
\s1 Dirava do ita tanikiu henia  
\q1
\v 1 Lohiabada e,  
\q1 mai egu kudouna ibounai danu lau ese oi do lau tanikiu henia,  
\q1 ma idau dirava edia vairana dekenai,  
\q1 oi do lau hanamoa egu ane dekena amo.   
\q1
\v 2 Oiemu Dubu Helaga ena vairana dekenai do lau tui diho,  
\q1 bona oiemu ladana do lau hanamoa,  
\q1 oiemu noho hanaihanai lalokauna,  
\q1 bona oiemu abidadama kara ai dekenai dainai.  
\q1 Badina be oi ese oi hedinaraia vadaeni,  
\q1 oiemu ladana bona oiemu hereva be namo herea,  
\q1 idia ese gau ibounai edia namo idia hereaia noho.   
\q1
\v 3 Lau ese oi dekenai lau boiboi neganai,  
\q1 egu noinoi oi kamonai henia,  
\q1 bona oiemu goada dekena amo lau oi hagoadaia momokani vadaeni.   
\b  
\q1
\v 4 Lohiabada e,  
\q1 tanobada ena king ibounai ese oi do idia hanamoa,  
\q1 badina be oiemu gwauhamata hereva idia kamonai vadaeni.   
\q1
\v 5 Lohiabada ena kara badadia do idia hanamoa, edia ane dekenai,  
\q1 badina be oi Lohiabada, oiemu hairaina be bada herea.   
\b  
\q1
\v 6 Lohiabada e,  
\q1 oi be ataiai momokani oi noho,  
\q1 to oi ese manau taudia oi laloa noho,  
\q1 bona hekokoroku taudia ese,  
\q1 oi dekena amo idia hunia diba lasi.   
\q1
\v 7 Hekwarahi bona hisihisi momo lau dekenai idia vara neganai,  
\q1 oi ese egu mauri oi naria noho.  
\q1 Lau idia hadikaia gwauraia taudia,  
\q1 be oi ese edia badu oi koua noho,  
\q1 bona oiemu siahu dekena amo lau oi hamauria noho.   
\q1
\v 8 Lohiabada e,  
\q1 lau diba oi ese lau dekenai oi gwauhamata gaudia ibounai,  
\q1 be do oi karaia momokani.  
\q1 Lohiabada e,  
\q1 oiemu lalokau bona bogahisihisi do idia noho hanaihanai.  
\q1 Oi ese oi hamatamaia vadaeni gaukara,  
\q1 be mani do oi rakatania lasi.   
\c 139  
\s1 Dirava ese ita ia diba momokani, bona ia ese ita ia naria noho  
\q1
\v 1 Lohiabada e,  
\q1 oi ese egu lalona oi tahua vadaeni,  
\q1 lau oi diba momokani vadaeni.   
\q1
\v 2 Egu kara ibounai oi diba vadaeni.  
\q1 Oi be daudau herea dekena amo egu laloa ibounai oi diba.   
\q1
\v 3 Oi ese egu gaukara, bona egu laga-ani oi itaia namonamo noho.  
\q1 Lauegu kara ibounai oi diba.   
\q1
\v 4 Do lau hereva lasi neganai,  
\q1 oi ese egu hereva be oi diba guna vadaeni.   
\b  
\q1
\v 5 Oi ese egu kahana kahana dekenai oi noho.  
\q1 Oiemu siahu dekena amo lau oi naria noho.   
\q1
\v 6 Oiemu diba egu kara dekenai be ia bada herea momokani.  
\q1 Inai bamona diba be lau davaria diba lasi.   
\b  
\q1
\v 7 Oiemu Lauma dekena amo edeseni do lau lao diba?  
\q1 Oiemu vairana dekena amo edena bamona do lau heau boio?   
\q1
\v 8 Guba dekenai bema lau daekau gwauraia, oi be unuseni oi noho.  
\q1 Mase taudia edia gabu dekenai bema lau hekure gwauraia,  
\q1 oi be unuseni oi noho danu.   
\q1
\v 9 Bema dina ia daekau kahana dekenai lau roho lao neganai,  
\q1 o dina ia diho kahana,  
\q1 ena daudau momokani gabuna dekenai lau noho neganai,   
\q1
\v 10 oi be unuseni oi noho, lau do oi hakaua totona,  
\q1 bona lau do oi durua totona.   
\b  
\q1
\v 11 Sedira lau ese dibura do lau noia, ia ese lau do ia hunia,  
\q1 o diari do lau noia,  
\q1 lau ia hagegea noho diari, be do ia dibura,   
\q1
\v 12 to dibura be ia dibura lasi oi dekenai,  
\q1 bona oi dekenai hanuaboi be ia diari, dina bamona.  
\q1 Dibura bona diari ruaosi be idia hegeregere oi dekenai.   
\b  
\q1
\v 13 Oi ese egu tauanina ena kahana ibounai oi karaia.  
\q1 Lauegu sinana ena bogana dekenai lau oi atoa vadaeni.   
\q1
\v 14 Oi lau tanikiu henia,  
\q1 badina mai hoa danu lau oi karaia.  
\q1 Oiemu kara ibounai be mai hoa bona gari danu.  
\q1 Lauegu kudouna dekenai,  
\q1 inai bamona lau diba momokani.   
\q1
\v 15 Lauegu turiana be,  
\q1 egu sinana ena bogana lalonai idia vara hamatamaia noho neganai,  
\q1 lau be unai hunia gabuna dekenai lau noho neganai,  
\q1 oi be oi diba lau be unuseni.   
\q1
\v 16 Lau be do lau vara lasi neganai,  
\q1 oi ese lau oi itaia.  
\q1 Lau be do lau vara lasi neganai,  
\q1 oi ese egu mauri dinadia oi torea vadaeni oiemu buka dekenai,  
\q1 unai dinadia be do idia hamatamaia lasi neganai.   
\b  
\q1
\v 17 Dirava e,  
\q1 oiemu laloa be lau dekenai idia dobu bona namo herea momokani.  
\q1 Oiemu laloa be momo herea momokani.   
\q1
\v 18 Bema idia lau duahia neganai,  
\q1 idia be kone miri idia momo herea bamona.  
\q1 Lau noga neganai,  
\q1 lau be oi danu lau do noho.   
\b  
\q1
\v 19 Dirava e,  
\q1 lau ura be kara dika taudia oi ese oi alaia mase!  
\q1 Lau ura dagedage taudia ese lau do idia rakatania!   
\q1
\v 20 Idia ese oi idia hereva dika henia.  
\q1 Oiemu ladana hadikaia hereva idia gwauraia noho.   
\q1
\v 21 Lohiabada e,  
\q1 oi dekenai idia badu noho taudia,  
\q1 be lau ese lau badu henidia noho!  
\q1 Oi dekenai idia dagedage henia taudia be lau ura henidia lasi.   
\q1
\v 22 Lau ese lau badu henidia momokani,  
\q1 bona lau laloa idia be lau idia tuari henia taudia bamona.   
\b  
\q1
\v 23 Dirava e,  
\q1 egu kudouna do oi tahua,  
\q1 ena dala ibounai do oi diba.  
\q1 Egu lalona danu do oi tohoa,  
\q1 bona egu laloa gaudia do oi davaria.   
\q1
\v 24 Do oi itaia, bema egu lalona dekenai dika ta ia noho,  
\q1 bona noho hanaihanai dalana dekenai mani lau do oi hakaua.   
\c 140  
\s1 Dirava ese do ia gimaia totona Davida ia noia  
\q1
\v 1 Lohiabada e,  
\q1 kara dika taudia dekena amo lau do oi hamauria.  
\q1 Dagedage taudia dekena amo lau do oi naria.   
\q1
\v 2 Idia ese nega ibounai,  
\q1 kara dika karaia daladia idia laloa noho,  
\q1 bona nega ibounai heai idia havaraia noho.   
\q1
\v 3 Edia maladia be mai matadia,  
\q1 gaigai edia isena bamona,  
\q1 bona edia bibina dekenai,  
\q1 be koria gaigai ena mase muramurana ia noho.   
\b  
\q1
\v 4 Lohiabada e,  
\q1 kara dika taudia dekena amo lau do oi gimaia.  
\q1 Dagedage taudia dekena amo lau do oi naria.  
\q1 Idia ese lau do idia hadikaia dalana idia tahua noho.   
\q1
\v 5 Hekokoroku taudia ese tarapu ta idia hunia vadaeni,  
\q1 lau do idia abia totona.  
\q1 Dika taudia ese edia reke ena varo idia karaia hegaegae,  
\q1 bona egu raka dala dekenai inai tarapu idia atoa vadaeni,  
\q1 lau do idia dogoatao totona.   
\b  
\q1
\v 6 Lau ese Lohiabada lau hamaoroa,  
\q1 lau gwau,  
\q1 “Oi be lauegu Dirava.”  
\q1 Lohiabada e, lau do oi durua!  
\q1 Egu boiboi mani do oi kamonai!   
\q1
\v 7 Lohiabada e, oi be egu Dirava,  
\q1 oi be egu hamauria Tauna goadana.  
\q1 Oi ese tuari lalonai lau oi naria vadaeni.   
\q1
\v 8 Lohiabada e, kara dika taudia edia ura do oi henia lasi.  
\q1 Edia palani dikana do oi durua lasi.   
\b  
\q1
\v 9 Lau idia hadikaia gwauraia taudia dekenai,  
\q1 kwalimu do oi henia lasi.  
\q1 Lau dekenai idia hereva dika vadaeni,  
\q1 lau do idia haorea totona.  
\q1 To inai dika, lau dekenai do idia karaia gwauraia gauna,  
\q1 be idia sibodia dekenai do oi havaraia,  
\q1 inai dika ese idia do ia hadikaia momokani.   
\q1
\v 10 Lahi gidadia be edia kwaradia edia latanai do oi hamorua,  
\q1 bona guri badana lalonai idia do oi negea diho,  
\q1 vadaeni unai guri dekena amo do idia toreisi lou lasi.   
\q1
\v 11 Taunimanima idia samania koikoi taudia dekenai,  
\q1 kwalimu do oi henia lasi.  
\q1 Bona dagedage taudia dekenai dika do oi havaraia,  
\q1 vadaeni oi ese idia do oi haorea momokani.   
\b  
\q1
\v 12 Lohiabada e,  
\q1 lau diba ogogami taudia,  
\q1 bona gau lasi taudia,  
\q1 be tau dikadia ese idia dagedage henidia neganai,  
\q1 oi ese mai maoromaoro danu,  
\q1 unai hisihisi abia taudia oi durua noho.   
\q1
\v 13 Momokani,  
\q1 kara maoromaoro taudia ese oiemu ladana do idia hanamoa.  
\q1 Kara maoromaoro taudia be oiemu vairana dekenai do idia noho.   
\c 141  
\s1 Adorahi ena guriguri ta  
\q1
\v 1 Lohiabada e,  
\q1 oi dekenai lau noinoi noho,  
\q1 lau do oi durua haraga.  
\q1 Oi dekenai lau boiboi noho,  
\q1 mani lau dekenai do oi kamonai.   
\q1
\v 2 Lau ura egu guriguri do oi abia dae,  
\q1 bona ena mamina oi dekenai be namo,  
\q1 muramura mai bonana namona bamona.  
\q1 Bona lau ura egu imana lau abia isi kara ena namo,  
\q1 be adorahi boubouna ena namo hegeregerena, oiemu vairana dekenai.   
\b  
\q1
\v 3 Lohiabada e, egu uduna do oi gimaia,  
\q1 egu bibina ena hereva do oi biagua.   
\q1
\v 4 Lau do oi durua,  
\q1 vadaeni do lau ura lasi kara dika do lau karaia,  
\q1 bona lau do oi naria,  
\q1 vadaeni kara dika taudia danu do lau haboua lasi,  
\q1 kara dika karaia totona.  
\q1 Edia aniani pata dekena amo lau do oi hakaua siri.   
\b  
\q1
\v 5 Tau namona ese,  
\q1 iena bogahisihisi dekena amo, lau do ia dadabaia,  
\q1 o lau dekenai do ia gwau henia, be namo.  
\q1 To lau ese kara dika taudia danu do lau turana karaia lasi,  
\q1 badina be nega ibounai,  
\q1 edia kara dika koua totona lau guriguri noho.   
\q1
\v 6 Unai dika taudia be tau haida ese do idia dogoatao,  
\q1 bona nadi hagahaga gabuna dekena amo do idia negea diho,  
\q1 do idia mase.  
\q1 Unai neganai taunimanima do idia diba,  
\q1 Lohiabada ena hereva be momokani.   
\q1
\v 7 Edia turiadia be tau haida ese,  
\q1 guria gabuna ena isena kahirakahira do idia negea.  
\q1 Edia toana be hegeregere tau ese au ta ia siria,  
\q1 ia utua maragimaragi, bona unai gaudia ia negea kava bamona.   
\b  
\q1
\v 8 To Dirava Lohiabada e,  
\q1 lau be oi dekenai lau abidadama noho.  
\q1 Oi ese lau oi naria namonamo noho,  
\q1 vadaeni lau mauri noho.  
\q1 Mase dekena amo lau do oi gimaia noho.   
\q1
\v 9 Lau do idia abia totona,  
\q1 tarapu, idia atoa hegaegae gaudia,  
\q1 dekena amo mani lau do oi hamauria.  
\q1 Kara dika taudia edia tarapu dekena amo lau do oi gimaia.   
\q1
\v 10 Kara dika taudia mani do oi hadikaia,  
\q1 vadaeni idia sibodia idia karaia tarapu ese idia do ia abia,  
\q1 to lau ese do lau heau mauri.   
\c 142  
\s1 Davida ese durua totona Lohiabada ia noia  
\q1
\v 1 Durua totona lau ese Lohiabada dekenai lau boiboi.  
\q1 Ia dekenai lau noinoi goada,  
\q1 lau do ia durua totona.   
\q1
\v 2 Egu lalohisihisi bona hekwarahi gaudia,  
\q1 be iena vairana dekenai lau gwauraia noho.   
\b  
\q1
\v 3 Egu lalona ia metau momokani,  
\q1 bona lau laloa be dika do lau davaria neganai,  
\q1 Lohiabada be ia diba edena kara ese egu dala do ia hanamoa.  
\q1 Lau raka noho dalana dekenai,  
\q1 lau idia hadikaia gwauraia taudia ese tarapu idia hunia vadaeni.   
\q1
\v 4 Lau dekenai durua totona tauna ta lau tahua,  
\q1 to egu durua tauna ta lau davaria lasi.  
\q1 Lau do ia gimaia tauna ta be lasi,  
\q1 bona tau ta ese egu mauri ia laloa lasi.   
\b  
\q1
\v 5 Lohiabada e, oi dekenai lau tai henia noho.  
\q1 Lau gwau,  
\q1 “Lohiabada e, oi sibona ese lau oi naria noho.  
\q1 Egu mauri dinadia ibounai lalonai,  
\q1 lau ura oi sibona lau dekenai do oi noho.   
\q1
\v 6 Egu noinoi mani do oi kamonai,  
\q1 badina be egu lalona ia hisihisi,  
\q1 ia dika momokani, mai gari danu.  
\q1 Lau idia lulua noho taudia dekena amo lau do oi hamauria,  
\q1 badina idia edia goada ese,  
\q1 egu goada idia hereaia momokani.   
\q1
\v 7 Lohiabada e,  
\q1 egu dibura ruma dekena amo lau do oi kokia ruhaia.  
\q1 Unai neganai oiemu bese taudia edia hebou lalonai,  
\q1 lau ese oiemu ladana do lau hanamoa,  
\q1 oiemu kara namo lau dekenai dainai.”   
\c 143  
\s1 Davida ese durua totona Lohiabada ia noia  
\q1
\v 1 Lohiabada e,  
\q1 egu guriguri do oi kamonai!  
\q1 Oiemu kara maoromaoro dainai,  
\q1 egu noinoi do oi kamonai henia.  
\q1 Oiemu abidadama bona kara momokanidia dainai,  
\q1 egu noinoi do oi haere henia.   
\q1
\v 2 Lau, oiemu hesiai tauna do oi kota henia lasi,  
\q1 badina be idia mauri noho taudia ibounai edia huanai,  
\q1 ta be ia maoromaoro lasi oiemu vairana dekenai.   
\b  
\q1
\v 3 Lau ia hadikaia gwauraia tauna ese lau ia lulua,  
\q1 bona ia ese lau ia halusia momokani vadaeni.  
\q1 Ia ese dibura ruma lalonai lau ia koua vadaeni,  
\q1 bona egu noho be idaunegai idia mase vadaeni taudia bamona.   
\q1
\v 4 Unai dainai egu lalona ia metau dainai,  
\q1 lau ese laloa dika lau davaria vadaeni.  
\q1 Egu lalona ia hisihisi, dika momokani, mai gari danu.   
\b  
\q1
\v 5 Dina gunadia lau laloa noho.  
\q1 Oiemu kara gunadia ibounai lau laloa noho.  
\q1 Oiemu imana edia kara badadia ibounai lau laloatao noho.   
\q1
\v 6 Unai neganai egu imana lau abia isi,  
\q1 oi dekenai lau guriguri.  
\q1 Egu lauma be oi totona ia ranu mase,  
\q1 tano kaukau be medu totona ia ranu mase bamona.   
\b  
\q1
\v 7 Lohiabada e,  
\q1 lau dekenai do oi haere haraga,  
\q1 badina be egu lauma ia manoka momokani, mase bamona.  
\q1 Oiemu vairana be lau dekena amo do oi hunia lasi.  
\q1 Bema unai bamona oi karaia,  
\q1 lau be mase gabuna idia lao noho taudia danu do ai diho lao.   
\q1
\v 8 Lohiabada e, lau ese oi lau abidadama henia noho.  
\q1 Unai dainai daba ibounai lau do oi durua,  
\q1 vadaeni oiemu noho hanaihanai lalokauna do lau laloa noho.  
\q1 Guriguri dekena amo egu lauma oi dekenai lau abia isi noho.  
\q1 Unai dainai egu lao dala namona,  
\q1 mani lau dekenai do oi hedinaraia.   
\q1
\v 9 Lohiabada e,  
\q1 lau idia hadikaia gwauraia taudia dekena amo lau do oi hamauria,  
\q1 badina oi sibona be egu hunia gabuna.   
\q1
\v 10 Oi be lauegu Dirava.  
\q1 Unai dainai oiemu ura ena kara,  
\q1 be lau dekenai mani do oi hadibaia.  
\q1 Lau ura oiemu Lauma ese lau do ia hakaua,  
\q1 vadaeni dala namona,  
\q1 bona mai maurina dekenai do lau raka.   
\b  
\q1
\v 11 Lohiabada e,  
\q1 oiemu gwauhamata hegeregerena lau do oi hamauria.  
\q1 Oiemu kara maoromaoro dainai,  
\q1 egu hisihisi dekena amo lau do oi hanamoa lou.   
\q1
\v 12 Oiemu noho hanaihanai lalokauna dainai,  
\q1 lau idia hadikaia gwauraia taudia do oi alaia ore,  
\q1 bona lau dekenai idia dagedage noho taudia do oi hadikaia ore,  
\q1 badina lau be oiemu hesiai tauna.   
\c 144  
\s1 Davida ena kwalimu dainai ia ese Dirava ia hanamoa  
\q1
\v 1 Lohiabada lau hanamoa noho,  
\q1 badina ia be egu Nadi Badana.  
\q1 Ia ese tuari totona egu imana ia hadibaia noho,  
\q1 bona heatu totona,  
\q1 ia ese egu ima kwakikwakina ia hadibaia noho.   
\q1
\v 2 Ia ese lau ia lalokau henia noho,  
\q1 bona ia be egu hunia gabu namona.  
\q1 Ia be egu kohoro,  
\q1 bona ia be egu hamauria Tauna.  
\q1 Egu mauri do ia naria totona,  
\q1 lau ese ia lau abidadama henia noho.  
\q1 Bona ia ese bese idauidau taudia,  
\q1 be egu siahu henunai ia atoa.   
\b  
\q1
\v 3 Lohiabada e,  
\q1 ai taunimanima be dahaka,  
\q1 oi ese oi laloa noho ai dekenai?  
\q1 Ai be gau ta lasi bamona,  
\q1 anina lasi, to edena bamona oi ese ai oi naria noho?   
\q1
\v 4 Ai taunimanima be hahodi tamona sibona bamona,  
\q1 bona aiemai mauri dinadia be daudau lasi,  
\q1 dina ena laulau ia hanaia haraga bamona.   
\b  
\q1
\v 5 Lohiabada e,  
\q1 namona be oi ese guba do oi kehoa,  
\q1 bona do oi diho mai.  
\q1 Oiemu imana be ororo dekenai do oi atoa,  
\q1 vadaeni kwalahu badana do ia vara.   
\q1
\v 6 Kevaru do oi siaia mai,  
\q1 oi dekenai idia tuari henia taudia do oi lulua lao.  
\q1 Oiemu diba be idia dekenai do oi pidia, bona do oi halusidia.   
\q1
\v 7 Lau hamauria totona,  
\q1 oiemu imana be ataiai dekena amo do oi atoa diho,  
\q1 bona ranu dobu dekena amo lau do oi veria mauri.  
\q1 Idau bese taudia edia siahu dekena amo danu,  
\q1 lau do oi hamauria.   
\q1
\v 8 Edia ududia ese hereva momokani idia gwauraia lasi.  
\q1 Idia ese Dirava dekenai idia gwauhamata henia noho,  
\q1 idia gwau edia hereva be momokani,  
\q1 to gauna be koikoi sibona.   
\b  
\q1
\v 9 Dirava e,  
\q1 lau ese ane matamatana oi dekenai do lau abia.  
\q1 Varo ibounai 10 gita dekena amo,  
\q1 oi dekenai miusiki do lau gadaralaia.   
\q1
\v 10 Oi ese king taudia oi durua,  
\q1 vadaeni tuari dekenai idia kwalimu.  
\q1 Oi ese lau, oiemu hesiai tauna Davida oi hamauria noho.   
\b  
\q1
\v 11 Tuari ena dagedage dekena amo lau do oi hamauria,  
\q1 bona idau bese taudia edia siahu dekena amo,  
\q1 lau do oi veria mauri.  
\q1 Edia ududia ese hereva momokani idia gwauraia lasi.  
\q1 Idia ese Dirava dekenai idia gwauhamata henia noho,  
\q1 idia gwau edia hereva be momokani,  
\q1 to gauna be koikoi sibona.   
\b  
\q1
\v 12 Lohiabada e,  
\q1 ai ura aiemai natudia tau be maragidia dekena amo,  
\q1 do idia tubu daekau mai goada danu,  
\q1 au badadia idia tubu bamona.  
\q1 Bona ai ura aiemai natudia hahine,  
\q1 be hegeregere du namodia bamona,  
\q1 king ena ruma ena kona ta ta dekenai haginia gaudia,  
\q1 toana namo gaudia.   
\q1
\v 13 Ai ura aiemai aniani sitoa rumadia be do idia honu momokani,  
\q1 aniani gaudia idauidau dekena amo.  
\q1 Ai ura aiemai mamoe ese,  
\q1 natudia momo do idia havaraia,  
\q1 bona aiemai rei gabudia,  
\q1 be mamoe dekenai idia honu momokani.   
\q1
\v 14 Ai ura danu aiemai boromakau,  
\q1 be natudia momo do idia havaraia,  
\q1 bona edia natudia ta do ia vara dika lasi, o do ia mase lasi.  
\q1 Ai ura danu aiemai hanua edia ariara dekenai,  
\q1 lalohisihisi ena taitai do ia vara lasi.   
\b  
\q1
\v 15 Inai bamona hanamoa idia davaria bese taudia,  
\q1 be do idia moale noho.  
\q1 Edia Dirava be Lohiabada, ena bese taudia be idia moale noho.   
\c 145  
\s1 Dirava hanamoa ane  
\q1
\v 1 Lauegu Dirava bona lauegu King,  
\q1 oi do lau hanamoa noho,  
\q1 bona oiemu ladana badana do lau abia isi noho,  
\q1 ela bona hanaihanai.   
\q1
\v 2 Dina ibounai lau ese oi do lau tanikiu henia,  
\q1 ma oi do lau hanamoa ela bona hanaihanai.   
\b  
\q1
\v 3 Lohiabada ena ladana be bada herea,  
\q1 bona ita ese iena ladana do ita abia isi.  
\q1 Iena kara badadia do ita tahua diba lasi,  
\q1 iseda laloa be kwadogi dainai.   
\q1
\v 4 Lohiabada e,  
\q1 oiemu kara badadia be inai nega taudia,  
\q1 bona gabeai negadia taudia danu ese do idia hanamoa.  
\q1 Idia ese oiemu kara badadia ibounai do idia gwauraia noho.   
\q1
\v 5 Idia ese oiemu hairaina bona oiemu king siahuna,  
\q1 do idia herevalaia,  
\q1 bona lau ese oiemu hoa karadia do lau laloa noho.   
\q1
\v 6 Taunimanima ese oiemu kara badadia do idia herevalaia,  
\q1 bona lau ese oiemu ladana ena bada do lau gwauraia.   
\q1
\v 7 Ma idia ese oiemu kara namodia ena sivarai do idia gwauraia,  
\q1 bona oiemu bogahisihisi, be edia ane dekenai do idia herevalaia.   
\b  
\q1
\v 8 Lohiabada be mai ena lalokau bona mai ena bogahisihisi.  
\q1 Ia be badu haraga lasi,  
\q1 bona ia ese ita ia lalokau henia nega ibounai.   
\q1
\v 9 Lohiabada ena kara be namo,  
\q1 taunimanima ibounai dekenai.  
\q1 Ia karaia gaudia ibounai dekenai iena bogahisihisi ia henia.   
\q1
\v 10 Lohiabada e, oi ese oi karaia gaudia ibounai ese,  
\q1 oiemu ladana do idia abia isi,  
\q1 bona oiemu bese taudia ese oi do idia hanamoa bada.   
\q1
\v 11 Idia ese oiemu King siahuna ena hairaina do idia herevalaia,  
\q1 bona oiemu goada badana do idia gwauraia.   
\q1
\v 12 Vadaeni taunimanima ibounai ese,  
\q1 oiemu kara badadia ena sivarai do idia diba.  
\q1 Oiemu basileia ena goada bona hairaina danu do idia diba.   
\q1
\v 13 Oiemu King siahuna be do ia noho hanaihanai.  
\q1 bona oiemu King dagi be do ia doko diba lasi.  
\q1 Lohiabada ena gwauhamata be ia ese ia badinaia noho,  
\q1 bona iena kara ibounai be namo.   
\q1
\v 14 Hisihisi idia abia noho taudia,  
\q1 be Lohiabada ese ia durua noho,  
\q1 bona dagedage taudia ese tau haida idia hahisia neganai,  
\q1 Lohiabada ese unai hisihisi taudia ia abia isi noho.   
\q1
\v 15 Lohiabada e,  
\q1 idia mauri noho gaudia ibounai ese oi dekenai idia itaia noho,  
\q1 badina oi ese edia aniani oi henidia noho, idia hitolo neganai.   
\q1
\v 16 Oi ese aniani hegeregere oi henidia,  
\q1 bona idia boga kunu noho.   
\b  
\q1
\v 17 Lohiabada ena kara ibounai be maoromaoro,  
\q1 bona ia ese taunimanima ibounai dekenai ia bogahisihisi henia noho.   
\q1
\v 18 Lohiabada be ia dekenai idia boiboi taudia dekenai ia noho.  
\q1 Idia boiboi henia mai edia momokani danu taudia dekenai,  
\q1 Lohiabada be idia kahirakahira ia noho.   
\q1
\v 19 Ia dekenai idia gari taudia dekenai,  
\q1 idia ura henia gaudia ia henia noho.  
\q1 Edia taitai ia kamonai,  
\q1 bona ia ese idia ia hamauria noho.   
\q1
\v 20 Ia idia lalokau henia taudia,  
\q1 be Lohiabada ese ia naridia namonamo,  
\q1 to ia ese kara dika taudia do ia hadikaia ore.   
\b  
\q1
\v 21 Lau ese nega ibounai Lohiabada do lau hanamoa.  
\q1 Namona be taunimanima ibounai ese,  
\q1 iena ladana helagana do idia hanamoa ela bona hanaihanai.   
\c 146  
\s1 Dirava be Hamauria Tauna  
\q1
\v 1 Lohiabada do umui hanamoa!  
\q1 Egu lauma e,  
\q1 Lohiabada do oi hanamoa!   
\q1
\v 2 Egu mauri dinadia ibounai lalonai,  
\q1 lau ese Lohiabada do lau hanamoa.  
\q1 Ane dekenai,  
\q1 Lohiabada do lau hanamoa egu mauri dinadia ibounai lalonai.   
\b  
\q1
\v 3 King taudia do umui abidadama henia lasi,  
\q1 badina taunimanima ese umui do idia hamauria diba lasi.   
\q1
\v 4 Idia mase neganai tano ena kahu dekenai idia giroa lou.  
\q1 Edia mase dina dekenai,  
\q1 idia ura do idia karaia gaudia be do idia doko.   
\b  
\q1
\v 5 Iakobo ena Dirava ese ia durua noho taudia,  
\q1 be idia moale noho.   
\q1
\v 6 Lohiabada ese guba bona tanobada bona davara,  
\q1 bona idia lalonai gaudia ibounai ia karaia.  
\q1 Lohiabada ena abidadama kara bona ena momokani kara,  
\q1 be do ia karaia noho hanaihanai.   
\q1
\v 7 Haida ese idia hadikaia taudia,  
\q1 be Lohiabada ese kota dekenai ia durudia noho,  
\q1 bona ogogami taudia dekenai aniani ia henia noho.  
\q1 Lohiabada ese dibura ruma taudia ia kokia ruhaia noho.   
\q1
\v 8 Lohiabada ese matakepulu taudia edia matadia ia kehoa noho.  
\q1 Idia moru vadaeni taudia be Lohiabada ese ia abia isi noho.  
\q1 Iena kara maoromaoro taudia ia lalokau henidia noho.   
\q1
\v 9 Lohiabada ese,  
\q1 iseda tano dekenai idia noho idau bese taudia ia gimaia noho.  
\q1 Lohiabada ese,  
\q1 vabu bona tamana sinana lasi maragidia ia naria noho,  
\q1 to kara dika taudia edia dala ia hadikaia noho.   
\q1
\v 10 Lohiabada be King do ia noho, ela bona hanaihanai.  
\q1 Siona taudia e,  
\q1 Lohiabada be emui Dirava do ia noho,  
\q1 ela bona nega ibounai.  
\b  
\q1 Lohiabada do umui hanamoa!   
\c 147  
\s1 Siahu Ibounai Dirava do ita hanamoa  
\q1
\v 1 Lohiabada do umui hanamoa!  
\b  
\q1 Ane dekenai Dirava do ita hanamoa be namo.  
\q1 Lohiabada do ita hanamoa be kara namona bona kara maorona.   
\b  
\q1
\v 2 Lohiabada ese Ierusalema ia haginia lou noho.  
\q1 Israela taudia be guna mai guia danu idia noho,  
\q1 idau bese taudia edia gabu dekenai,  
\q1 to Lohiabada ese hari ia mailaidia lou noho.   
\q1
\v 3 Edia kudoudia idia makohia taudia,  
\q1 be Lohiabada ese ia hagoadaia lou noho,  
\q1 bona edia bero ia kumia noho.   
\b  
\q1
\v 4 Lohiabada ese hisiu edia namba ia gwauraia vadaeni,  
\q1 bona ia ese idia ibounai edia ladana ia atoa.   
\q1
\v 5 Iseda Lohiabada be bada, bona mai siahu danu.  
\q1 Iena aonega be mai ena hetoana lasi.   
\q1
\v 6 Lohiabada ese manau taudia ia abia isi noho,  
\q1 to kara dika taudia be tano dekenai ia negedia diho noho.   
\b  
\q1
\v 7 Mai ane danu Lohiabada do umui tanikiu henia.  
\q1 Gita dekena amo,  
\q1 iseda Dirava hanamoa totona miusiki do umui gadaralaia.   
\q1
\v 8 Guba dekenai ori momo ia atodia noho,  
\q1 bona tano hanamoa totona medu ia havaraia noho.  
\q1 Ororo dekenai rei ia hatubua noho.   
\q1
\v 9 Boroma idauidau dekenai aniani ia henia noho,  
\q1 bona galo manudia idia boiboi neganai,  
\q1 aniani idia dekenai ia siaia noho.   
\b  
\q1
\v 10 Hosi ena goada be Dirava ese ia moalelaia lasi,  
\q1 bona tau ena aena danu ia moalelaia lasi.   
\q1
\v 11 To Lohiabada ese,  
\q1 ia dekenai idia gari henia taudia ia moalelaia noho.  
\q1 Iena noho hanaihanai lalokauna dainai,  
\q1 ia idia abidadama henia taudia,  
\q1 be Lohiabada ese ia moalelaia noho.   
\b  
\q1
\v 12 Ierusalema taudia e,  
\q1 Lohiabada do umui hanamoa bada.  
\q1 Siona taudia e,  
\q1 emui Dirava do umui hanamoa.   
\q1
\v 13 Ia ese Ierusalema ena magu iduara auridia ia hagoadaia noho,  
\q1 bona ia ese Ierusalema idia noho taudia ia hanamoa noho.   
\q1
\v 14 Emui tano hetoadia dekenai Dirava ese maino ia karaia noho,  
\q1 bona uiti namo herea emui uma dekenai ia hatubua noho.  
\q1 Unai dekena amo umui boga kunu noho.   
\b  
\q1
\v 15 Tanobada dekenai oda ia siaia lao,  
\q1 bona iena hereva gauna be idia karaia haraga noho.   
\q1
\v 16 Ia ese sinou ia siaia,  
\q1 tano ia koua noho, bilankesi bamona,  
\q1 bona ia ese hanuaboi ranu ia hakerua, aisi bamona ia lao.  
\q1 Bona unai aisi ia negea kava,  
\q1 tano ena kahu bamona.   
\q1
\v 17 Medu, aisi bamona gauna,  
\q1 be tano dekenai ia siaia diho noho, aisi nadi bamona,  
\q1 bona iena lai ena keru dekenai daika ia gini diba?   
\q1
\v 18 Ia ese iena oda hereva ia siaia,  
\q1 vadaeni aisi ia veve noho.  
\q1 Ia ese lai ia havaraia,  
\q1 vadaeni ranu ia heau diho noho.   
\b  
\q1
\v 19 Iena hereva be Iakobo dekenai ia hedinaraia vadaeni.  
\q1 Iena taravatu bona iena oda,  
\q1 be Israela dekenai ia henia vadaeni.   
\q1
\v 20 Bese haida dekenai unai bamona ia karaia lasi.  
\q1 Unai idau bese taudia ese iena taravatu idia diba lasi.  
\b  
\q1 Lohiabada do umui hanamoa!   
\c 148  
\s1 Tanobada bona guba dekenai idia noho gaudia ibounai ese Dirava idia hanamoa be namo  
\q1
\v 1 Lohiabada ena ladana do umui hanamoa!  
\q1 Guba dekenai, ataiai dekenai umui noho taudia ibounai e,  
\q1 Lohiabada do umui hanamoa.   
\q1
\v 2 Lohiabada ena aneru ibounai e,  
\q1 Lohiabada ena ladana do umui abia isi,  
\q1 Lohiabada ena tuari taudia,  
\q1 guba dekenai umui noho,  
\q1 Lohiabada ena ladana do umui abia isi.   
\q1
\v 3 Dina bona hua e,  
\q1 Lohiabada do umui hanamoa.  
\q1 Hisiu mai emui diaridiari e,  
\q1 Lohiabada do umui hanamoa.   
\q1
\v 4 Guba ataiai momokani,  
\q1 Lohiabada ena ladana do umui abia isi.  
\q1 Guba ena ataiai dekenai ia noho ranu e,  
\q1 Lohiabada ena ladana do umui hanamoa.   
\q1
\v 5 Inai gaudia ibounai ese Lohiabada ena ladana idia abia isi be namo,  
\q1 badina Lohiabada ese ia oda dainai, idia be idia vara.   
\q1
\v 6 Lohiabada ena hereva dekena amo,  
\q1 ia ese edia gabu korikori dekenai idia ia atoa,  
\q1 idia noho hanaihanai.  
\q1 Lohiabada ese noho hanaihanai taravatu ia atoa,  
\q1 ta ese ia koua diba lasi gauna.   
\b  
\q1
\v 7 Tanobada dekenai noho gaudia ese Lohiabada do idia hanamoa.  
\q1 Davara dekenai idia noho mauri gaudia badadia,  
\q1 dobu momokani gabudia dekenai gaudia ibounai danu.   
\q1
\v 8 Kevaru bona aisi ena medu, sinou bona ori,  
\q1 lai goadadia,  
\q1 iena oda idia kamonai henia gaudia ibounai,  
\q1 ese Lohiabada do idia hanamoa.   
\q1
\v 9 Ororo badadia bona maragidia ibounai,  
\q1 huahua audia bona sida audia ibounai.   
\q1
\v 10 Uda boroma ibounai,  
\q1 bona boromakau ibounai,  
\q1 gaigai bona huala gaudia,  
\q1 bona ataiai manudia ibounai,  
\q1 Lohiabada ena ladana do umui hanamoa.   
\q1
\v 11 King ibounai,  
\q1 bona bese ibounai,  
\q1 king ena natuna taudia,  
\q1 bona lohia taudia idauidau ibounai.   
\q1
\v 12 Ulato bona uhau,  
\q1 buruka taudia,  
\q1 bona natuna maragidia danu,   
\q1
\v 13 namona be idia ibounai ese,  
\q1 Lohiabada ena ladana do idia hanamoa bada!  
\q1 Iena ladana badana ese,  
\q1 taunimanima ibounai edia ladana badana ia hereaia noho.  
\q1 Iena hairaina be ataiai momokani,  
\q1 ia ese tanobada bona guba ia hereaia noho.   
\q1
\v 14 Lohiabada ese Israela taudia ia lalokau henia momokani,  
\q1 vadaeni ia ese idia ia hagoadaia momokani.  
\q1 Unai dainai iena bese taudia ese iena ladana idia abia isi noho.  
\b  
\q1 Lohiabada ena ladana do umui hanamoa!   
\c 149  
\s1 Dirava hanamoa ane ta  
\q1
\v 1 Lohiabada do umui hanamoa!  
\b  
\q1 Lohiabada dekenai ane matamatana do umui abia.  
\q1 Lohiabada idia abidadama henia taudia edia hebou dekenai,  
\q1 ia do umui hanamoa.   
\b  
\q1
\v 2 Israela taudia ese, idia ia karaia Diravana do idia moalelaia.  
\q1 Siona taudia ese edia King do idia moalelaia be namo.   
\q1
\v 3 Iena ladana do idia hanamoa mai edia mavaru danu.  
\q1 Tareko bona gita ena regena dekena amo,  
\q1 Lohiabada do idia hanamoa,   
\q1
\v 4 badina be Lohiabada ese,  
\q1 iena bese taudia ia moalelaia noho momokani.  
\q1 Ia ese manau taudia dekenai kwalimu ia henia noho.   
\q1
\v 5 Dirava ena taudia ese,  
\q1 edia kwalimu dainai do idia moale noho be namo.  
\q1 Hanuaboi ena hora ibounai lalonai,  
\q1 ane do idia abia be namo.   
\b  
\q1
\v 6 Namona be mai boiboi bada danu Dirava do idia hanamoa.  
\q1 Bona matadia rua tuari kaia,  
\q1 be edia imadia dekenai do idia dogoatao noho,   
\q1
\v 7 idia ese bese idauidau do idia halusia totona,  
\q1 ma bese idauidau taudia do idia matakani henia totona.   
\q1
\v 8 Unai bese king taudia be auri dekena amo do idia guia,  
\q1 bona edia lohia taudia be auri seini dekena amo do idia guia.   
\q1
\v 9 Io, iena bese taudia dekena amo,  
\q1 Dirava ese ia gwauraia vadaeni kerere davana,  
\q1 be unai bese idauidau dekenai do ia henia.  
\q1 Dirava idia abidadama henia taudia ibounai,  
\q1 be inai bamona do idia kwalimu.  
\b  
\q1 Lohiabada do umui hanamoa!   
\c 150  
\s1 Lohiabada do ita hanamoa  
\q1
\v 1 Lohiabada do umui hanamoa!  
\b  
\q1 Iena Dubu Helaga lalonai Dirava do umui hanamoa!  
\q1 Guba, iena siahu bada herea gabuna dekenai danu,  
\q1 be Lohiabada do umui hanamoa!   
\q1
\v 2 Ia ese kara badadia ia karaia dainai do umui hanamoa.  
\q1 Iena siahu bada herea momokani do umui hanamoa.   
\q1
\v 3 Kibi ena regena dekena amo do umui hanamoa.  
\q1 Gita badadia bona maragidia dekena amo ia do umui hanamoa.   
\q1
\v 4 Gaba bona mavaru dekena amo,  
\q1 gita bona ivilikou dekena amo, Lohiabada do umui hanamoa.   
\q1
\v 5 Botaia auri ena regena dekena amo ia do umui hanamoa.  
\q1 Auri do umui botaia goadagoada,  
\q1 bona Lohiabada ena ladana do umui abia isi.   
\b  
\q1
\v 6 Umui mauri noho gaudia ibounai e,  
\q1 Lohiabada ena ladana do umui hanamoa!  
\b  
\q1 Lohiabada do umui hanamoa!   