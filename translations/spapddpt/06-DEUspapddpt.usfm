\v 20 \w que|strong="H3588"\w* ames \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, escuches \w su|strong="H1931"\w* \w voz|strong="H6963"\w* \w y|strong="H3588"\w* seas fiel \w a|strong="H3068"\w* \w Él|strong="H1931"\w*. \w Porque|strong="H3588"\w* \w Él|strong="H1931"\w* \w es|strong="H1931"\w* tu \w vida|strong="H2416"\w* \w y|strong="H3588"\w* \w la|strong="H1931"\w* prolongación \w de|strong="H5921"\w* tus \w días|strong="H3117"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w vivas|strong="H2416"\w* \w en|strong="H5921"\w* \w la|strong="H1931"\w* tierra \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w juró|strong="H7650"\w* \w dar|strong="H5414"\w* \w a|strong="H3068"\w* tus antepasados, Abraham, \w Isaac|strong="H3327"\w* \w y|strong="H3588"\w* \w Jacob|strong="H3290"\w*.
\c 31
\s1 Últimas disposiciones de Moisés
\p 
\v 1 \w Así|strong="H1696"\w* \w que|strong="H1697"\w* \w Moisés|strong="H4872"\w* \w fue|strong="H3212"\w* y \w habló|strong="H1696"\w* estas \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*:
\v 2 \w Hoy|strong="H3117"\w* tengo 120 \w años|strong="H8141"\w*. \w Ya|strong="H3068"\w* \w no|strong="H3808"\w* \w puedo|strong="H3201"\w* \w salir|strong="H3318"\w* \w ni|strong="H3808"\w* entrar \w más|strong="H5750"\w*. \w Además|strong="H5750"\w* \nd \w Yavé|strong="H3068"\w*\nd* me dijo: \wj Tú \w no|strong="H3808"\w* \w pasarás|strong="H5674"\w* \w este|strong="H2088"\w* \w Jordán|strong="H3383"\w*.\wj*
\p 
\v 3 \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w pasará|strong="H5674"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti. \w Él|strong="H1931"\w* \w destruirá|strong="H8045"\w* estas \w naciones|strong="H1471"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti, y tú las heredarás. \w Josué|strong="H3091"\w* también \w pasará|strong="H5674"\w* al frente \w de|strong="H6440"\w* ti, \w como|strong="H1931"\w* \w dijo|strong="H1696"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
