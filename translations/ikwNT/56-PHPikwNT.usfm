\id PHP - Ikwerre 
\h Ele Filipaị 
\toc1 Ọkwukwo izi Pọlu gbaznennu Ele Filipaị 
\toc2 Ele Filipaị 
\toc3 Fil 
\mt2 Ọkwukwo izi Pọlu 
\mt2 gbaznennu 
\mt1 Ele Filipaị 
\imt1 Nhne gbasịri ọkwukwo izi ka 
\im Pọlu gbarụ ọkwukwo izi ka nga ọ zị n'ikelu nọotunu ọgbako Chiokike ke zị nụ Filipaị mmamma kwnornu nkesi nụ okpukpe be. Ọgbako Chiokike ke zị nụ Filipaị bụ ọgbako mbọm Pọlu miteru n'ẹli ele Iropu. Ọ kannụ ele Karaịsi zị nụ Filipaị nụ be kwesiri ọ ta awhnụwhnu lele kpa Karaịsi tarụ, nụ kpa Pọlu naata awhnụwhnu ige wam. Ọ bụru kpam, ele Filipaị gweru a lele ngọzi be nahịaru hite n'ọkwnata mkpọma be nwernu nụ Karaịsi. 
\ip Agwna ele zị nụ Filipaị nookwu nụ ele badnụ kwesiri ọ bịta Iwu Mozizi, ọ bụ́o kpam, nụ be nwée ọznohia. Pọlu kanụ be neeze ele nụ lele nkịta (3:2-11). Snarnịma nụ ovu ọso n'ọnu jihịaru ọkwukwo izi ka, kwnornu nụ Pọlu mụhiaru kpa o gweru ọnodi ọbula ọ whnụrnu ẹhni a mee nhne bụru ọma. Ovu sọru a n'ọnu k'agịda kpa o chenwanyarnụ ovu ọma ọgbako Chiokike zị nụ Filipaị gesiri a. Pọlu kaa nụ ele ke Chiokike kwesiri o wu n'udno, neeche echiche lele kpa Karaịsi neeche. 
\iot Nhne zị n'ọkwukwo izi ka 
\io1 Obekwu ikwu nụ okpukpe \ior (1:1-11) \ior* 
\io1 Nhne bụdnu bụnu Pọlu \ior (1:12-30) \ior* 
\io1 Nhne atụ ke Karaịsi \ior (2:1-18)\ior* 
\io1 Nhne gbasịri Timoti nụ Epafroditusi \ior (2:19-30) \ior* 
\io1 Ele Chiokike nabnanyarnụ \ior (3:1---4:9) \ior* 
\io1 Pọlu nọotnu ele Filipaị mmamma \ior (4:10-20) \ior* 
\io1 Obekwu ikwu ipne-aznụ \ior (4:21-23) \ior* 
\c 1  
\p  
\v 1 Pọlu nụ Timoti, ele izi Jizọsi Karaịsi, naagbaznenu kpakara rụmu Chiokike ke zị nụ Karaịsi Jizọsi ele wu nụ Filipaị, be nụ ele neelekọta be, nụ ele ẹrnu ọkwukwo.  
\v 2 Oru nụ udno ke hi n'aka Chiokike Nda aị nụ Nyenwe aị Jizọsi Karaịsi dazịnu anụ. 
\s1 Okpukpe nụ ọtu mmamma 
\p  
\v 3 M nọotunu Chiokike mmamma ige ọbula me chenwanyarnụ anụ.  
\v 4 M ji m snarnịma neekpenu kpakara anụ okpukpe ige ọbula  
\v 5 kwnornu nụ me nụ anụ bụ ele ẹrnu n'izi ọma hite n'ọbochi mbọm tem dụ kịtna.  
\v 6 M kwnatarụ m ovu nụ ka, nụ nye wam ke panịzoru ẹrnu ọma nụ rime anụ, jọornuzu ẹrnu wam tem dụ n'ọbochi Karaịsi Jizọsi jaava. 
\p  
\v 7 O kwesiri me vuru nhne ka nụ mkpọma gbasịri anụ, hne anụ zị nụ ovu m, ma m zị m n'ikelu, ma m zị naagbanụ izi ọma akebne, mọbu naakwnagidne a, kpakara anụ neekehịa igwe n'oru Chiokike nyernu m.  
\v 8 Chiokike bụ nye akebne m, kpa ọ nọogwnu m ọ whnụ anụ anya hite n'ọwhnun'anya Karaịsi Jizọsi. 
\p  
\v 9 Ka bụ okpukpe m, ma ọwhnun'anya anụ n'ẹhni ibne anụ naaba aba, hite nhne ọmuma nụ ọghohia,  
\v 10 ma anụ nwernu rikne ọ mahịa nhne ke kakwo mma, ma anụ zịri snam, nwée ọtna tem dụ n'ọbochi Karaịsi jaava.  
\v 11 Mkpụru ke ome mma ke hi nụ Jizọsi Karaịsi va jihịa nụ rime anụ, ma igwugwu nụ ọznarni bụru ke Chiokike. 
\s1 Ikelu Pọlu mernu izi ọma  //  gbasa 
\p  
\v 12 Rụmu nda m, m pioru ma anụ mahịa nụ nhne ọbula ke dnakwasịri m, mernu izi ọma gbasa.  
\v 13 Kpakara ele nse zị n'ọro eze nụ kpakara ele berere mahịaru nụ m zị m n'ikelu kwnornu Karaịsi.  
\v 14 Ikelu be tụru m mernu ele kakwo n'esilawụru rụmu nda aị nụ Nyenwe aị nwe ọnu rikne o kwu ikwu-ọnu Chiokike n'ovu siri rikne, be nwée ogwnu. 
\p  
\v 15 Ọ bụ n'ezi nụ agwna be nọokpo okwo izi ọma n'ọwho-anya nụ omegidne, kọvu ele berere nọokpo okwo izi ọma Karaịsi kwnornu ovu ọma.  
\v 16 Ele ipne-aznụ neeme kpam n'ọwhnun'anya, kwnornu nụ be magwụ nụ m zị m hna kwnornu izi ọma.  
\v 17 Ele ke mbọm nọokpo okwo Karaịsi kwnornu nhne be jeerihịa nụ rime a, ọ bụ́o n'ezi ọka, ma be mee nhne joogbu m igbugbu kpa me zị n'ikelu.  
\v 18 Kịni mee? Ma be kpọru okwo izi ọma n'ezi ọka mọbu n'aghịgho, nhne zị mkpa bụ be nọokpo okwo Karaịsi. Ka bụ risi nhne me kwno nọonwudna. 
\p M jaazịkoriri nọonwudna.  
\v 19 M maam nụ kpa anụ neekpenu m okpukpe, hite n'oyi aka ke Enine Jizọsi Karaịsi, kpakara nhne dnakwasịri m jọoburu nhne jeeme m whụya n'ikelu.  
\v 20 Ka bụ nụ olile anya m siri rikne, nụ iwhnerne jọ́otu m n'apna ọbula, kọvu m jeenwe ovu siri rikne ma kịtna ma ige ọbula nụ be jeegwelizọ Karaịsi olu n'ẹhni m, hite nụ bụdnu mọbu n'ẹnwu.  
\v 21 Kwnornu nụ kpa me zị bụdnu, m bụ m ke Karaịsi, me nwụ, ọ bụ mbnarna.  
\v 22 Ọ bụru me zịri bụdnu n'anọ-ẹhni, ọ jọoburu ẹrnu ke jaamị mkpụru. Ndaa ke me jeegweru? M máam ke ka mma.  
\v 23 Nhne lawụru ka zị nọodoka m, ọ nọogwnu m me la ma me nụ Karaịsi dazịri, bụ ke kakwo mma.  
\v 24 Kọvu ọ zị mkpa me dazịri bụdnu kwnornu anụ.  
\v 25 Ka dnornu m anya, m magwụ m nụ m jaadazịri, me nụ anụ jaazịgidne, ma anụ so oso, nwe snarnịma n'ọkwnata ovu anụ.  
\v 26 Ka bụ me nụ anụ zịri, ovu ọso n'ọnu anụ nụ rime Karaịsi jaazị agịda kwnornu m. 
\p  
\v 27 Nhne nụ nhne ọbula mene, anụ wu bụdnu ke kwesiri izi ọma Karaịsi. Me va ọ whnụ anụ mọbu m váge m, mọbu m nụrnu m nhne gbasịri anụ hne me zị, m jaamahịa nụ anụ gwuzosiri rikne n'otu enine, nọolu ọgwnu lele otu badnụ kwnornu ọkwnata ovu ke izi ọma.  
\v 28 Anụ kwé ele neemegidne anụ kpasị anụ ogwnu n'apna ọbula. Ka jọobu nhne jeegesi be nụ Chiokike joolulu be, kọvu Chiokike jọoznohia anụ.  
\v 29 Kwnornu nụ Chiokike nyernu anụ oghere, ọ bụ́o o kweru nụ Karaịsi kpọi, kọvu ọ tanụ a awhnụwhnu.  
\v 30 Me nụ anụ nọolu otu ọgwnu. Anụ whnụrnu kpa me lụru ọgwnu wam n'ige wheru ewhe, kịtna anụ nọonu nụ m zị kọriri m naagba ọtna. 
\c 2  
\s1 Badnụ ogwedna ẹhni a ẹli 
\p  
\v 1 Ọ bụru nụ ọgba inwe zịnu aị nụ Karaịsi, ọ bụru nụ ọsnuta mkpọma hite n'ọwhnun'anya a, ọ bụru nụ omekọrita zị n'Enine Nsọ, ọ bụru nụ ovu ọma ọbula nụ obirizi,  
\v 2 anụ mee ma ovu ọso n'ọnu m zu ozu, anụ nwe otu echiche, otu ọwhnun'anya, anụ zịri n'otu enine nụ echiche.  
\v 3 Ọ zá nye ọbula mee nhne kwnornu nhne o jeenwehịa mọbu ovu ọjo, kọvu hite nụ badnụ ogwedna ẹhni ẹli, nye ọbula kweru nụ nye berere ka a mma.  
\v 4 Ọ zá nye ọbula ke lebna anya nụ nhne ke a kpọi, kọvu nụ nhne gbasịri ele berere. 
\p  
\v 5 Nye ọbula nwe ovu ke Karaịsi Jizọsi. 
\q1  
\v 6 Nye, ọ bụ n'ezi nụ ọ bụ Chiokike 
\q2 méne a lele nhne anya rikne nụ ya nụ Chiokike hna. 
\q1  
\v 7 Ọ sịgbasiri kpakara nhne o nwernu, 
\q2 o gweru ọnodi ke nnwọ izi, 
\q2 be mee a lele badnụ etekne. 
\q1  
\v 8 Ọ whụya iwhne lele badnụ etekne, 
\q2 o gwedna ẹhni a ẹli, 
\q1 o bno nsnị dụ n'ẹnwu, 
\q2 bụ ẹnwu ke olu ọgba. 
\q1  
\v 9 Kam kpayarụ, Chiokike jiri gwelizọ a olu kakwo kpakara nhne, 
\q2 nyega a rẹwhna ke kakwo kpakara rẹwhna, 
\q1  
\v 10 ke bụ nụ rẹwhna Jizọsi kpakara mpnerne ọchi joogbu, 
\q2 nhne ke zị n'oligwe, ma n'ọwa, ma nụ mkpururu ọwa, 
\q1  
\v 11 kpakara riro jookwuhịa nụ Jizọsi Karaịsi bụ Nyenwe aị, 
\q2 ma be nyee Chiokike Nda igwugwu. 
\s1 Noonwu lele mbọ 
\p  
\v 12 Kam kpayarụ, ele me whnụrnu n'anya, anụ noobno nsnị lele kpa anụ neeme, ọ bụ́o nụ ruwhnu m kpọi, ke kakwo, nga me zị́la ndụndu. Anụ gweru ogwnu nụ ọznu biri biri rnụhia ọznohia anụ.  
\v 13 Kwnornu nụ ọ bụ Chiokike nye nọornu ẹrnu nụ rime anụ, nye neeme anụ kweru hite nụ mkpọma anụ, neeme nhne lele kpa echiche a jiri zị. 
\p  
\v 14 Kpa anụ neeme kpakara nhne, anụ gweme ọtamu nụ agịrigo,  
\v 15 ma anụ bụru ele nwée ọtna, ele zị snam, rụmu Chiokike ele nwée ọru nụ rime ebiri ele ọjo ka hịri aghị, hne anụ noonwu lele mbọ n'ọwa.  
\v 16 Anụ jikwaru ikwu-ọnu ke bụdnu ka aka rikne, ma m gweru m anụ mee oknomokno n'ọbochi Karaịsi, ke jeegesi nụ m gbáge m ẹso etekne, mọbu ọ dọgbu ẹhni m n'ẹrnu bụ́o nhne etekne.  
\v 17 Ọ bụbedi nụ be jọowusi ọvnarna bụdnu m lele arịohna manya n'omezu arịohna, lele kpa ẹrnu ọkwnata ovu anụ bụ arịohna anụ kwannụ Chiokike, ovu nọoso m n'ọnu, m sno m anụ nọonwudna.  
\v 18 Anụ n'iwhuru anụ snornu m nwe ovu ọso n'ọnu nụ ọnwudna. 
\s1 Nhne gbasịri Timoti  //  nụ Epafroditusi 
\p  
\v 19 M neele anya nụ Nyenwe aị jeekwe me ziyanu anụ Timoti ige matị, ma ovu sọ m n'ọnu nga me jọonu izi gbasịri anụ.  
\v 20 M nwée m nye berere nụ lele ya, nye nhne gbasịri anụ neemetụ nụ mkpọma n'ezi.  
\v 21 Kwnornu nụ nye ọbula neele anya nụ nhne ke a, ọ bụ́o ke Karaịsi Jizọsi.  
\v 22 Kọvu anụ magwụ nụ Timoti gesiri ẹhni a lele nnwọ nụ nda a, o znenu m izi, snornu m rnụ ẹrnu izi ọma.  
\v 23 M neele anya nụ m jeeziya a ige matị kpa nhne jaaganụ hna me zị.  
\v 24 M kwnatarụ m Chiokike ovu nụ me n'iwhuru m jaava whnụ anụ ige matị. 
\p  
\v 25 Kọvu m whnụrnu m nụ ọ bụru ọma me zihnahie Epafroditusi, nnwọ nda m, nụ nye ẹrnu nụ nye ọgwnu ibne m, nye bụ masị nye izi anụ, nye anụ ziyannu m o lebna anya nụ mkpa naakpa m.  
\v 26 Ọ nọogwnusi a rikne ọ whnụ anụ anya, kwnornu nụ anụ nụrnu nụ ọ rịaru ẹhni igbugbu.  
\v 27 N'ezi, ọ rịaru ẹhni igbugbu, ọ gwnarnụ matị ọ nwụ. Kọvu Chiokike dọnnu a obirizi, ọ bụ́o ya kpọi, kọvu ma me, ọ zị me nwe nhne igbugbu n'olu nhne igbugbu.  
\v 28 Kam kpayarụ, ovu nọoso m n'ọnu k'agịda o ziya a. Nga anụ jọowhnu a, ovu jọoso anụ n'ọnu, mkpọma jáala m mini berere.  
\v 29 Anụ gweru okne ovu ọso n'ọnu nabnanya a nụ rẹwhna Nyenwe aị, anụ sọ ele nụ lele ya anya k'agịda.  
\v 30 Kwnornu nụ ọ gwnarnụ matị ọ nwụ nụ ẹrnu Karaịsi. O gweruru bụdnu a n'aka a nọornu ẹrnu kpa anụ nwée rikne rnụ. 
\c 3  
\s1 Ezi ome mma 
\p  
\v 1 N'ipne-aznụ, rụmu nda m, anụ nwụdna ọnwudna nụ Nyenwe aị. Ọ zá noogbu m igbugbu ọ gbanụ anụ otu nhne ka berere, ka bụ ma ọ bụnu anụ ọma. 
\p  
\v 2 Anụ neezeru ẹhni anụ kwnornu rụmu nkịta, ele arụru-ẹli wam, ele noogbuja anọ-ẹhni.  
\v 3 Kwnornu nụ aị ele be kparụ nka n'ezi, bụ ele neekpenu Chiokike hite n'Enine a, ele ji Karaịsi Jizọsi naanya risi, ele zá nọotukwasi anọ-ẹhni mkpọma. 
\p  
\v 4 Ọ bụ n'ezi nụ m nwernu m nhne nụ lele ka me ji nọotukwasi mkpọma. Ọ bụru nụ badnụ ọbula nwernu nhne o jiri tụkwasi mkpọma n'anọ-ẹhni, m nwernu m karụkwo.  
\v 5 Be kparụ m nka nga me gbarụ n'ọbochi ẹsato, nye Izirẹli, nye avnụrnu Bẹnjamini, m bụ m nye Hiburu n'ezi. Nụ nhne gbasịri iwu, m bụ m nye Farisi,  
\v 6 nye nwernu bẹkwnu nụ mkpọma, naakpakna ọgbako Chiokike ẹhni. Nụ nhne gbasịri ome mma ke hi n'iwu, m nwée m ọtna. 
\p  
\v 7 Kọvu kpakara nhne ke bnannụ m iru, bụ nhne me gwnụrnu nụ nhne etekne kwnornu Karaịsi.  
\v 8 Owe! M gwnụrnu m kpakara nhne lele nhne etekne ma m mahịa m nhne ke kakwo bụ ọ mahịa Karaịsi Jizọsi Nyenwe m, nye me kwnornu nụ a whu mwhu kpakara nhne. M gwnụrnu m be lele nhne bnána nụ nhne ma m rihịa m Karaịsi nụ iru,  
\v 9 ma me nụ ya bụru otu, hne me nwée ome mma ke aka m ke hiri n'iwu, kọvu ome mma ke hiri n'ọkwnata ovu nụ Karaịsi, ka bụ ome mma ke hi n'aka Chiokike hite n'ọkwnata ovu.  
\v 10 M pioru m ọ mahịa Karaịsi nụ iknernema olizọ n'ẹnwu a, ma m kehịa m igwe n'awhnụwhnu a, nụ lele ya n'ẹnwu a,  
\v 11 ọ bụru nụ o jeekwe omume, ma m dụ m n'olizọ n'ẹnwu ke ele nwụrnu ọnwu. 
\s1 Ọgbazne nụ ruwhnu 
\p  
\v 12 Ka zá neegesi nụ m nwehịala m kpakara nhne ka, mọbu nụ m dụla m ozu ozu. Kọvu m naagbalị ma m nwudne m nhne wam, ke bụ nhne Karaịsi kwno nwudne m.  
\v 13 Rụmu nda aị, m zá m nọogwnu ẹhni m nụ m ji m a n'aka. Kọvu ka bụ nhne me neeme, m neechezu kpakara nhne ke zị m n'aznụ, nọodosni aka m nụ nhne ke zị m nụ ruwhnu.  
\v 14 M naagbalị neezne nụ ruwhnu, ma m gbahịa m nhne n'ẹso, ke bụ nhne Chiokike kwno sukwu m zne oligwe kwnornu Karaịsi Jizọsi. 
\p  
\v 15 Kam kpayarụ, kpakara aị ele sozuru lele ele Karaịsi nwernu mkpọma ka. Ọ bụru nụ nye ọbula n'esilawụru anụ rị nhne zị ichne, Chiokike jeeme a o dno anụ anya nkarị nkarị.  
\v 16 Ngwa ma a yisi ẹhni jikwaru kpakara nhne a nwernu nkarị. 
\p  
\v 17 Rụmu nda m, anụ snornu ele sno nhne atụ m, anụ hnata ele noowu bụdnu lele kpa a znirni anụ ama.  
\v 18 Lele kpa me kannụ anụ agịda ige, kpa me ji anya-mini ẹkwna naakanụ anụ kịtna, agịda ele badnụ noowu bụdnu lele ele irno ke ọgba Karaịsi.  
\v 19 Okwukwo bụdnu be bụ mwhu, chi be bụ rụwho be, nhne iwhnerne bụ igwugwu be. Kpakara mkpọma be tụkwasiri nụ nhne zị n'ọwa.  
\v 20 Kọvu a bụ rụmu oligwe. A zị neese Nye Ọznohia aị ke jeehi n'oligwe va, nye bụ Karaịsi Jizọsi.  
\v 21 O jeegweru iknernema wam o jiri megbu kpakara nhne, bịta be nụ mkpururu ọchi a, gbanwo anọ-ẹhni aị ka ke nwée rikne, mee a ọ nụ lele ke a n'igwugwu. 
\c 4  
\p  
\v 1 Rụmu nda m, anụ bụ ele me whnụrnu n'anya, ele ọ nọogwnu m ọ whnụ anya, anụ bụ ovu ọso n'ọnu m nụ ọgwo ẹrnu m. Anụ gwuzosi rikne nụ Nyenwe aị, ele me whnụrnu n'anya. 
\s1 Ezni 
\p  
\v 2 M naarịasno Udia nụ Sintike, be ziri n'udno, kwnornu nụ anụ ele ke Nyenwe aị.  
\v 3 M naarịasno masị ị, nye ẹrnu ibne m, yinu ele rinya ka aka ma be zịri n'udno. Kwnornu nụ be sno m dọgbu ẹhni be n'ẹrnu ọkpo okwo izi ọma, be nụ Kịlementi nụ ele ẹrnu ibne m ele berere, ele be gbarụ rẹwhna be n'ọkwukwo ke bụdnu. 
\p  
\v 4 Anụ nwụdna ọnwudna nụ Nyenwe aị ige ọbula. M kwu kwno a berere, anụ nwụdna ọnwudna.  
\v 5 Anụ mee ma kpakara ele badnụ mahịa ovu ọma anụ. Nyenwe aị zị ndụndu.  
\v 6 Mkpọma lá anụ mini kwnornu nhne ọbula, kọvu anụ gweru okpukpe nụ ọtu mmamma chete kpakara nhne naakpa anụ nụ ruwhnu Chiokike.  
\v 7 Udno Chiokike ke kakwo kpakara ọghohia chekwata ovu anụ nụ echiche anụ nụ rime Karaịsi Jizọsi. 
\p  
\v 8 N'ipne-aznụ, rụmu nda aị, anụ naarị ọriri nhne bụ ezi ọka, nhne ọbula bụ nhne nwernu igwugwu, nhne ọbula ke bụru ọma, nhne ọbula ke zị rịchna, nhne ọbula ke be whnụrnu n'anya, nhne ọbula ke nwernu ọtnutnu ọma, ọ bụru nhne ọbula ke ka mma, ke kwesiri ọznarni.  
\v 9 Kpakara nhne anụ mụhiaru, ke anụ nahịaru nụ ke anụ nụrnu n'ọnu m, mọbu ke anụ whnụrnu nụ rime m, anụ neeme be. Chiokike ke udno jaadazịnu anụ. 
\s1 Pọlu tụnu ele Filipaị  //  mmamma 
\p  
\v 10 M nọonwudna ọnwudna nụ Nyenwe aị kwnornu nụ anụ gwnaknernụ ẹrnu anụ ke gbasịri m. Nhne gbasịri m neemetụ anụ nụ mkpọma, kọvu anụ nwée oghere o gesi a.  
\v 11 M zá m nookwu ka kwnornu nụ mkpa naakpa m, kọvu nụ m maam kpa ọ dazịri nụ rụwho ojiji n'ọnodi ọbula me whnụrnu ẹhni m.  
\v 12 M magwụ m kpa ọ zị nụ mkpa, m magwụ m kpa ọ zị nụ ige me nwejiri nhne. M mụhiaru m nhne tugwaru otugwa ke rụwho ojiji n'ọnodi ọbula, mọbu agwnụ wiri mọbu nụ rụwho jiri eji, o nwernu agịda nhne mọbu lele nye nhne kọgwu.  
\v 13 M jeemeli kpakara nhne hite nye wam ke neeme m gbasị rikne. 
\p  
\v 14 Ọ bụru ọma nụ anụ snornu m kehịa igwe n'awhnụwhnu m.  
\v 15 N'ezi, okwolem anụ ele Filipaị bụ ele yinnu m aka nga me panịzoru neezni izi ọma. Nga me hi nụ Masidonia nọowhuya, ọ zá ọgbako Chiokike ọbula ke snornu m nụ nhne gbasịri okesi nụ ọnahoru nhne, okwolem anụ.  
\v 16 Ọ bụbedi nga me zị nụ Tẹsalonika, anụ gweyanụ m nkesi ige ọbula me zị nụ mkpa.  
\v 17 Ka zá neegesi nụ m noopio nkesi, kọvu m noopio nhne jeeme anụ nwehịa nhne bụru ọma.  
\v 18 M nahịaru m kpakara nhne anụ ziyaru, tụkwasi kwno n'olu a. Anụ gweyannụ m kpakara nhne ke zị m mkpa, ke me nahịaru m n'aka Epafroditusi. Kpakara be bụ nhne nwernu ẹknarna ọma, arịohna ke nọoso Chiokike ovu n'ọnu ke ọ nahọru.  
\v 19 Chiokike m jeenye anụ kpakara nhne ke zị anụ mkpa, hite n'agịda ẹkwnu a ke zị igwugwu nụ Karaịsi Jizọsi. 
\p  
\v 20 Chiokike Nda aị nwe igwugwu dụ ọkwnukokwnu. Amịm. 
\s1 Obekwu ipne-aznụ 
\p  
\v 21 Anụ bekwu kpakara ele ke Chiokike ke zị nụ Karaịsi Jizọsi. Rụmu nda ele me nụ be zị neebekwu anụ.  
\v 22 Kpakara ele Chiokike zị nsọ neebekwu anụ, ke kakwo ele zị n'ezi-nụ-ọro Siza. 
\p  
\v 23 Oru ke Nyenwe aị Jizọsi Karaịsi dazịnu enine anụ. Amịm.