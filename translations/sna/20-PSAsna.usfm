\id PSA - Biblica® Open Shona Contemporary Bible 2017
\h MAPISAREMA
\toc1 MAPISAREMA
\toc1 Mapisarema
\toc2 Mapisarema
\toc3 Mapi
\mt1 MAPISAREMA
\c 1
\ms1 BHUKU 1
\mr Mapisarema 1–41
\cl Pisarema 1
\q1 
\v 1 Akaropafadzwa munhu
\q2 asingafambi panorangana vakaipa,
\q1 asingamiri panzira yavatadzi,
\q2 asingagari pachigaro chavadadi.
\q1 
\v 2 Asi anofarira murayiro waJehovha,
\q2 uye anofungisisa murayiro wake masikati nousiku.
\q1 
\v 3 Akafanana nomuti wakasimwa pahova dzemvura,
\q2 unobereka michero yawo nenguva yawo,
\q1 uye mashizha awo haasvavi.
\q2 Chinhu chipi nechipi chaanoita chinoendeka.
\b
\q1 
\v 4 Vakaipa havana kudaro!
\q2 Vakafanana nehundi
\q2 inopepereswa nemhepo.
\q1 
\v 5 Naizvozvo vakaipa havangamiri pakutongwa,
\q2 kana vatadzi paungano yavakarurama.
\b
\q1 
\v 6 Nokuti Jehovha anotarira nzira yavakarurama,
\q2 asi nzira yavakaipa ichaparadzwa.
\c 2
\cl Pisarema 2
\q1 
\v 1 Ndudzi dzinoitireiko bope?
\q2 Uye vanhu vanofungireiko zvisina maturo?
\q1 
\v 2 Madzimambo enyika azvigadzirira
\q2 uye vabati vanoungana pamwe chete
\q1 kuti vazorwa naJehovha,
\q2 uye kuti vazorwisa Muzodziwa Wake.
\q1 
\v 3 Vanoti, “Ngatidamburei ngetani dzavo,
\q2 tigorasa mabote avo.”
\b
\q1 
\v 4 Iye agere pachigaro choushe chokudenga anoseka;
\q2 Ishe anovadadira.
\q1 
\v 5 Ipapo anovatuka mukutsamwa kwake
\q2 uye anovavhundutsa muhasha dzake, achiti,
\q1 
\v 6 “Ndakagadza Mambo wangu
\q2 paZioni, gomo rangu dzvene.”
\p 
\v 7 Ndichaparidza chirevo chaJehovha, ndichiti:
\q1 Iye akati kwandiri, “Ndiwe Mwanakomana wangu;
\q2 nhasi ndava Baba vako.
\q1 
\v 8 Kumbira kwandiri,
\q2 uye ndichaita kuti ndudzi dzive nhaka yako,
\q2 migumo yenyika ive yako.
\q1 
\v 9 Uchavatonga netsvimbo yesimbi;
\q2 uchavaputsa kuita zvimedu zvimedu sehari.”
\b
\q1 
\v 10 Naizvozvo, imi madzimambo, ngwarai;
\q2 munyeverwe, imi vabati venyika.
\q1 
\v 11 Shumirai Jehovha nokutya,
\q2 uye mufare nokudedera.
\q1 
\v 12 Tsvodai Mwanakomana, kuti arege kutsamwa
\q2 mukazoparadzwa munzira yenyu,
\q1 nokuti hasha dzake dzingakurumidza kumuka.
\q2 Vakaropafadzwa vose vanovanda maari.
\c 3
\cl Pisarema 3
\d Pisarema raDhavhidhi. Panguva yaakatiza Abhusaromu mwanakomana wake.
\q1 
\v 1 Haiwa Jehovha, vadzivisi vangu vakawanda sei!
\q2 Vakawanda sei vanondimukira!
\q1 
\v 2 Vazhinji vanoti kwandiri,
\q2 “Mwari haangamudzikinuri.” \qs Sera \qs*
\b
\q1 
\v 3 Asi imi Jehovha, muri nhoo yakandipoteredza;
\q2 munoisa rukudzo pandiri uye munosimudza musoro wangu.
\q1 
\v 4 Kuna Jehovha ndinodana nenzwi guru,
\q2 uye anondipindura ari pagomo rake dzvene. \qs Sera \qs*
\b
\q1 
\v 5 Ndinovata pasi ndigokotsira;
\q2 ndinomukazve, nokuti Jehovha anonditsigira.
\q1 
\v 6 Handizotyi makumi ezviuru
\q2 vakandikomba kuti vandirwise.
\b
\q1 
\v 7 Simukai, imi Jehovha!
\q2 Ndirwirei, imi Mwari wangu!
\q1 Rovai vavengi vangu vose pashaya;
\q2 gurai meno avakaipa.
\b
\q1 
\v 8 Rusununguko runobva kuna Jehovha.
\q2 Maropafadzo enyu ngaave pamusoro pavanhu venyu. \qs Sera \qs*
\c 4
\cl Pisarema 4
\d Kumutungamiri wenziyo nemitengeranwa. Pisarema raDhavhidhi.
\q1 
\v 1 Ndipindurei pandinodana kwamuri,
\q2 imi Mwari wangu makarurama.
\q1 Ndisunungurei pakutambudzika kwangu;
\q2 ndinzwirei ngoni uye munzwe munyengetero wangu.
\b
\q1 
\v 2 Nhai imi vanhu, muchashandura kukudzwa kwangu kukava chinyadziso kusvikira riniko?
\q2 Muchada kutsauswa nokutsvaka vamwari venhema kusvikira riniko? \qs Sera \qs*
\q1 
\v 3 Zivai kuti Jehovha akazvitsaurira vanomuda;
\q2 Jehovha achandinzwa pandinodana kwaari.
\b
\q1 
\v 4 Pakutsamwa kwenyu, regai kutadza;
\q2 pamunenge muri pamibhedha yenyu,
\q2 nzverai mwoyo yenyu uye munyarare. \qs Sera \qs*
\q1 
\v 5 Ipai zvibayiro zvakarurama
\q2 uye muvimbe naJehovha.
\b
\q1 
\v 6 Vazhinji vanobvunza vachiti, “Ndianiko angatiratidza chakanaka?”
\q2 Chiedza chechiso chenyu ngachipenye pamusoro pedu, imi Jehovha.
\q1 
\v 7 Makazadza mwoyo wangu nomufaro mukuru
\q2 kupfuura zviyo zvavo newaini yavo itsva yakawanda.
\b
\q1 
\v 8 Ndichavata pasi ndigokotsira norugare,
\q2 nokuti imi moga, Jehovha,
\q2 munoita kuti ndigare pakasimba.
\c 5
\cl Pisarema 5
\d Kumutungamiri wokuimba. Nenyere. Pisarema raDhavhidhi.
\q1 
\v 1 Rerekerai nzeve yenyu kumashoko angu, imi Jehovha.
\q2 Rangarirai chikumbiro changu.
\q1 
\v 2 Teererai inzwi rokuchema kwangu,
\q2 Mambo wangu naMwari wangu,
\q2 nokuti ndinonyengetera kwamuri.
\b
\q1 
\v 3 Mangwanani, munonzwa inzwi rangu, imi Jehovha;
\q2 mangwanani ndinoisa zvikumbiro zvangu pamberi penyu
\q2 uye ndichimirira netariro.
\b
\q1 
\v 4 Imi hamusi Mwari anofarira zvakaipa;
\q2 munhu akaipa haangagari nemi.
\q1 
\v 5 Munhu anozvikudza haangamiri pamberi penyu;
\q2 munovenga vose vanoita zvakaipa.
\q1 
\v 6 Munoparadza vose vanoreva nhema;
\q2 vanoteura ropa navanhu vanonyengera,
\q2 Jehovha anovasema.
\b
\q1 
\v 7 Asi ini, nenyasha dzenyu huru,
\q2 ndichapinda mumba menyu;
\q1 norukudzo, ndichakotamira pasi pamberi penyu,
\q2 ndakatarira kutemberi yenyu tsvene.
\q1 
\v 8 Nditungamirirei, imi Jehovha,
\q2 mukururama kwenyu nokuda kwavavengi vangu,
\q2 ruramisai nzira yenyu pamberi pangu.
\b
\q1 
\v 9 Hakuna shoko rinobva mumuromo mavo ringavimbwa naro;
\q2 mwoyo yavo izere nokuparadza.
\q1 Huro dzavo iguva rakashama;
\q2 vanotaura zvinonyengera norurimi rwavo.
\q1 
\v 10 Haiwa Mwari, vapei mhosva!
\q2 Ngavawisirwe pasi nerangano dzavo.
\q1 Vabvisei nokuda kwezvivi zvavo zvizhinji,
\q2 nokuti vakakumukirai.
\b
\q1 
\v 11 Asi vose vanovanda mamuri ngavafare;
\q2 ngavagare vachiimba nomufaro.
\q1 Tambanudzirai pamusoro pavo kudzivirira kwenyu,
\q2 kuitira kuti vaya vanoda zita renyu vafare mamuri.
\q1 
\v 12 Nokuti zvirokwazvo, imi Jehovha, munoropafadza vakarurama;
\q2 munovakomberedza nenyasha dzenyu sokunge nenhoo.
\c 6
\cl Pisarema 6
\d Kumutungamiri wokuimba nemitengeranwa. Nesheminiti. Pisarema raDhavhidhi.
\q1 
\v 1 Haiwa Jehovha, regai kundirayira mukutsamwa kwenyu,
\q2 kana kundiranga muhasha dzenyu.
\q1 
\v 2 Ndinzwirei ngoni, Jehovha, nokuti ndava kuziya;
\q2 haiwa Jehovha, ndiporesei, nokuti mapfupa angu ava kurwadza.
\q1 
\v 3 Mweya wangu uri kurwadziwa.
\q2 Haiwa Jehovha, kusvikira riniko, kusvikira riniko?
\b
\q1 
\v 4 Dzokai, imi Jehovha, mugondirwira;
\q2 ndiponesei nokuda kworudo rwenyu rusingaperi.
\q1 
\v 5 Hakuna anokurangarirai kana afa.
\q2 Ndiani anokurumbidzai kubva muguva?
\b
\q1 
\v 6 Ndaneta nokugomera;
\q2 ndinonyorovesa mubhedha wangu nemisodzi ndichichema usiku hwose,
\q2 ndinonyorovesa uvato hwangu nemisodzi.
\q1 
\v 7 Meso angu aneta nokuchema;
\q2 haachaoni nokuda kwavavengi vangu vose.
\b
\q1 
\v 8 Ibvai pandiri, imi mose munoita zvakaipa,
\q2 nokuti Jehovha anzwa kuchema kwangu.
\q1 
\v 9 Jehovha anzwa kukumbira kwangu nyasha;
\q2 Jehovha anogamuchira munyengetero wangu.
\q1 
\v 10 Vavengi vangu vose vachanyadziswa uye vachavhundutswa;
\q2 vachadzokera shure pakarepo mukunyadziswa.
\c 7
\cl Pisarema 7
\d Rwiyo rwaDhavhidhi, rwaakaimbira Jehovha pamusoro paKushi, muBhenjamini.
\q1 
\v 1 Haiwa Jehovha, Mwari wangu, ndinovanda mamuri;
\q2 ndiponesei uye mundirwire pane vose vanondidzinganisa,
\q1 
\v 2 kuti varege kundibvambura seshumba
\q2 nokundibvambura-bvambura pasina anondinunura.
\b
\q1 
\v 3 Haiwa Jehovha, Mwari wangu,
\q2 kana ndichinge ndakaita izvi uye ndine mhosva pamaoko angu,
\q1 
\v 4 kana ndakaita zvakaipa kuno uya akanga ane rugare neni
\q2 kana kupamba muvengi wangu pasina mhaka,
\q1 
\v 5 ipapo muvengi wangu ngaandidzinganise andibate;
\q2 ngaatsike-tsike upenyu hwangu muvhu
\q2 uye andivatise muguruva.
\b
\q1 
\v 6 Simukai, imi Jehovha pakutsamwa kwenyu;
\q2 simukai murwise hasha dzavavengi vangu.
\q2 Simukai, Mwari wangu; rayirai kururamisira.
\q1 
\v 7 Marudzi akaungana ngaaungane akakupoteredzai.
\q2 Vatongei imi muri kumusoro;
\q2 
\v 8 Jehovha ngaatonge marudzi.
\q1 Nditongei, imi Jehovha, zvakafanira kururama kwangu,
\q2 zvakafanira kukwaniswa kwangu, imi Wokumusoro-soro.
\q1 
\v 9 Haiwa, Mwari akarurama,
\q2 iyemi munonzvera ndangariro nomwoyo,
\q1 gumisai kuita nesimba kwavakaipa
\q2 mugoita kuti vakarurama vagare zvakanaka.
\b
\q1 
\v 10 Nhoo yangu ndimi Mwari Wokumusoro-soro,
\q2 iye anoponesa vane mwoyo yakarurama.
\q1 
\v 11 Mwari ndiye mutongi akarurama,
\q2 iye Mwari anoratidza hasha dzake zuva nezuva.
\q1 
\v 12 Kana munhu asingatendeuki,
\q2 iye acharodza munondo wake;
\q2 achakunga uta hwake agogadzirira.
\q1 
\v 13 Agadzirira zvombo zvake zvinouraya;
\q2 anozvigadzirira miseve yake inopisa.
\b
\q1 
\v 14 Iye ane mimba yezvakaipa
\q2 akatakura mimba yokutambudzika achabereka nhema.
\q1 
\v 15 Uyo anochera gomba,
\q2 akaridzikisa achawira mugomba raachera.
\q1 
\v 16 Zvakashata zvake zvichadzokera pamusoro wake;
\q2 uye kumanikidza kwake kuchauya pamusoro wake.
\b
\q1 
\v 17 Ndichatenda Jehovha nokuda kwokururama kwake,
\q2 uye ndichaimbira zita raJehovha Wokumusoro-soro nziyo dzokurumbidza.
\c 8
\cl Pisarema 8
\d Kumutungamiri wokuimba negititi. Pisarema raDhavhidhi.
\q1 
\v 1 Haiwa Jehovha, Ishe wedu,
\q2 zita renyu rakaisvonaka sei panyika yose!
\b
\q1 Makaisa kubwinya kwenyu
\q2 kudenga kumusoro.
\q1 
\v 2 Pamiromo yavana navacheche
\q2 makaisa rumbidzo
\q1 nokuda kwavavengi venyu,
\q2 kuti munyaradze muvengi nomutsivi.
\b
\q1 
\v 3 Kana ndichifunga nezvamatenga enyu,
\q2 iro basa reminwe yenyu,
\q1 mwedzi nenyeredzi,
\q2 zvamakarongedza panzvimbo yazvo,
\q1 
\v 4 munhu chiiko zvamunomufunga,
\q2 kana mwanakomana womunhu zvamune hanya naye?
\q1 
\v 5 Makamuita muduku zvishoma pana Mwari,
\q2 uye mukamushongedza korona yokubwinya nokukudzwa.
\b
\q1 
\v 6 Makamuita mutongi pamusoro pebasa ramaoko enyu;
\q2 mukaisa zvinhu zvose pasi petsoka dzake:
\q1 
\v 7 makwai ose nemombe,
\q2 nemhuka dzesango,
\q1 
\v 8 neshiri dzedenga,
\q2 nehove dzegungwa,
\q2 zvose zvinofamba munzira dzomugungwa.
\b
\q1 
\v 9 Haiwa Jehovha, Ishe wedu,
\q2 zita renyu rakaisvonaka sei panyika yose!
\c 9
\cl Pisarema 9
\d Kumutungamiri wokuimba namaimbiro o“Kufa kwoMwanakomana.” Pisarema raDhavhidhi.
\q1 
\v 1 Ndichakurumbidzai, imi Jehovha, nomwoyo wangu wose;
\q2 ndichataura pamusoro pezvishamiso zvenyu zvose.
\q1 
\v 2 Ndichafara nokufarisisa mamuri;
\q2 ndichaimbira zita renyu nziyo dzokurumbidza, imi Wokumusoro-soro.
\b
\q1 
\v 3 Vavengi vangu vanodzokera shure;
\q2 vanogumburwa uye vanoparara pamberi penyu.
\q1 
\v 4 Nokuti makatsigira kodzero yangu nenyaya yangu;
\q2 makagara pachigaro chenyu choushe, muchitonga zvakarurama kwazvo.
\q1 
\v 5 Makatuka ndudzi mukaparadza vakaipa;
\q2 makadzima zita ravo nokusingaperi.
\q1 
\v 6 Kuparadzwa kusina magumo kwakakunda muvengi,
\q2 makadzura maguta avo;
\q2 kunyange chiyeuchidzo chavo chakaparara.
\b
\q1 
\v 7 Jehovha anotonga nokusingaperi;
\q2 akasimbisa chigaro chake choushe kuti atonge.
\q1 
\v 8 Achatonga nyika nokururama;
\q2 achatonga marudzi nokururamisira.
\q1 
\v 9 Jehovha ndiye nhare yavakamanikidzwa,
\q2 nhare yakasimba panguva yokutambudzika.
\q1 
\v 10 Vanoziva zita renyu vachavimba nemi,
\q2 nokuti imi, Jehovha hamuna kumbosiya avo vanokutsvakai.
\b
\q1 
\v 11 Imbirai Jehovha nziyo dzokurumbidza,
\q2 iye agere pachigaro choushe muZioni; paridzai zvaakaita pakati pendudzi.
\q1 
\v 12 Nokuti iye anotsiva ropa anorangarira;
\q2 haashayiri hanya kuchema kwavanotambudzwa.
\b
\q1 
\v 13 Haiwa Jehovha, onai kuti vavengi vangu vanonditambudza sei!
\q2 Ndinzwirei ngoni mundisimudze pamasuo orufu,
\q1 
\v 14 kuti ndiparidze kurumbidzwa kwenyu
\q2 mumasuo oMwanasikana weZioni,
\q2 uye ndigofara muruponeso rwenyu.
\b
\q1 
\v 15 Ndudzi dzakawira mugomba radzakachera;
\q2 tsoka dzavo dzakabatwa nemimbure yavakaviga.
\q1 
\v 16 Jehovha anozivikanwa nokururamisira kwake;
\q2 vakaipa vakateyiwa namabasa amaoko avo. \qs Higayoni. Sera \qs*
\q1 
\v 17 Vakaipa vanodzokera kuguva,
\q2 idzo ndudzi dzose dzinokanganwa Mwari.
\q1 
\v 18 Asi vanoshayiwa havangagari vachikanganwikwa,
\q2 uye tariro yavanotambudzwa haingaparari.
\b
\q1 
\v 19 Simukai, Jehovha, munhu ngaarege kukunda;
\q2 ndudzi ngadzitongwe pamberi penyu.
\q1 
\v 20 Varovei nokutyisa, imi Jehovha;
\q2 ndudzi ngadzizive kuti vanongova vanhu zvavo. \qs Sera \qs*
\c 10
\cl Pisarema 10
\q1 
\v 1 Munomirireiko kure, imi Jehovha?
\q2 Munozvivanzireiko panguva yokutambudzika?
\b
\q1 
\v 2 Pakuzvikudza kwake munhu akaipa anovhima vasina simba,
\q2 vanobatwa namano okufunga kwake.
\q1 
\v 3 Anozvirumbidza pamusoro pezvinopangwa nomwoyo wake;
\q2 anoropafadza vanokara uye anozvidza Jehovha.
\q1 
\v 4 Pakuzvikudza kwake akaipa haamutsvaki;
\q2 mundangariro dzake dzose hamuna nzvimbo yaMwari.
\q1 
\v 5 Nzira dzake dzinobudirira nguva dzose;
\q2 anozvikudza uye mirayiro yenyu iri kure naye;
\q2 anodadira vavengi vake vose.
\q1 
\v 6 Anoti pakufunga kwake, “Hakuna chichandizungunusa;
\q2 ndichagara ndakafara uye handingatongotambudziki.”
\b
\q1 
\v 7 Muromo wake uzere nokutuka, kureva nhema, uye nokutyisidzira;
\q2 matambudziko nezvakaipa zviri pasi porurimi rwake.
\q1 
\v 8 Anovandira ari pedyo nemisha;
\q2 pakuvandira uku anouraya vasina mhosva,
\q2 ari panzvimbo yakavanzika anotarira vaachaparadza.
\q1 
\v 9 Anovandira seshumba iri panzvimbo yayo;
\q2 anovandira kuti abate vasina anovabatsira;
\q2 anobata vasina anobatsira uye anovakweva achienda navo mumumbure wake.
\q1 
\v 10 Vabatwa vake anovapwanya, vanowa;
\q2 vanowira pasi pesimba rake.
\q1 
\v 11 Anoti mumwoyo make, “Mwari akanganwa;
\q2 akafukidza chiso chake uye haazoonizve.”
\b
\q1 
\v 12 Simukai, imi Jehovha! Simudzai ruoko rwenyu, imi Mwari.
\q2 Regai kukanganwa vanomanikidzwa.
\q1 
\v 13 Munhu akaipa anozvidzireiko Mwari?
\q2 Seiko achiti mumwoyo make,
\q2 “Haazondibvunzi?”
\q1 
\v 14 Asi imi, iyemi Mwari, munoona kutambudzika nokusuwa;
\q2 munokutarisisa kuti mukupedze.
\q1 Asina simba anozviisa kwamuri;
\q2 muri mubatsiri wenherera.
\q1 
\v 15 Vhunai ruoko rweakaipa nerwomunhu akaipa;
\q2 ngaazvidavirire pazvakaipa zvake
\q2 zvakanga zvisingazoonekwi.
\b
\q1 
\v 16 Jehovha ndiye Mambo nokusingaperi-peri;
\q2 ndudzi dzichaparara munyika yake.
\q1 
\v 17 Munonzwa henyu, imi Jehovha, zvishuvo zvavanotambura;
\q2 munovakurudzira, uye munoteerera kuchema kwavo,
\q1 
\v 18 muchiruramisira nherera nevakamanikidzwa,
\q2 kuti munhu wenyika, arege kuramba achingovhundutsa.
\c 11
\cl Pisarema 11
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Ndinovanda muna Jehovha.
\q2 Mungareva seiko kwandiri muchiti,
\q2 “Tizira kugomo rako seshiri.
\q1 
\v 2 Nokuti tarira, vakaipa vanowembura uta hwavo;
\q2 vanogadzirira miseve yavo parukungiso,
\q1 kuti vapfure vari murima,
\q2 uyo akarurama pamwoyo.
\q1 
\v 3 Kana nheyo dzaparadzwa,
\q2 akarurama angaiteiko?”
\b
\q1 
\v 4 Jehovha ari mutemberi yake tsvene;
\q2 Jehovha ari pachigaro chake choushe chokudenga.
\q1 Anocherechedza vanakomana vavanhu;
\q2 meso ake anovaedza.
\q1 
\v 5 Jehovha anoedza vakarurama,
\q2 asi vakaipa navanoda zvechisimba
\q2 mweya wake unovavenga.
\q1 
\v 6 Pane vakaipa anonayisa
\q2 mazimbe omoto nesafuri inopfuta;
\q2 mhepo inopisa ndiwo uchava mugove wavo.
\b
\q1 
\v 7 Nokuti Jehovha akarurama,
\q2 anoda kururamisira;
\q2 vanhu vakarurama vachaona chiso chake.
\c 12
\cl Pisarema 12
\d Kumutungamiri wokuimba. Nesheminiti. Pisarema raDhavhidhi.
\q1 
\v 1 Batsirai, imi Jehovha, nokuti vanoda Mwari hapachina;
\q2 vakatendeka vapera pakati pavanhu.
\q1 
\v 2 Mumwe nomumwe anorevera wokwake nhema;
\q2 miromo yavo inobata kumeso nokutaura zvinonyengera.
\b
\q1 
\v 3 Jehovha ngaagure miromo yose inobata kumeso,
\q2 norurimi rumwe norumwe runozvikudza
\q1 
\v 4 ruchiti, “Tichakunda nendimi dzedu;
\q2 miromo ndeyedu, tenzi wedu ndiani?”
\b
\q1 
\v 5 “Nokuda kwokumanikidzwa kwavasina simba
\q2 nokugomera kwavarombo,
\q1 ndichasimuka zvino,” ndizvo zvinotaura Jehovha.
\q2 “Ndichavadzivirira kuna avo vanovaparadza.”
\q1 
\v 6 Uye mashoko aJehovha haana chaangapomerwa,
\q2 sesirivha yakacheneswa muchoto chevhu,
\q2 yakanatswa kanomwe.
\b
\q1 
\v 7 Imi Jehovha, muchatichengeta murugare
\q2 uye muchatidzivirira kubva kuvanhu vakadai nokusingaperi.
\q1 
\v 8 Vakaipa vanofamba-famba vakasununguka
\q2 kana zvakashata zvichikudzwa pakati pavanhu.
\c 13
\cl Pisarema 13
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Kusvikira riniko, nhai Jehovha? Muchandikanganwa nokusingaperi here?
\q2 Muchasvika riniko makandivanzira chiso chenyu?
\q1 
\v 2 Ndichaita mutsimba nepfungwa dzangu kusvikira riniko,
\q2 uye ndine shungu mumwoyo mangu zuva rimwe nerimwe?
\q2 Muvengi wangu achandikurira kusvikira riniko?
\b
\q1 
\v 3 Tarirai kwandiri mugondipindura, imi Jehovha Mwari wangu.
\q2 Vhenekerai meso angu, kana kuti ndichafa ndakarara;
\q1 
\v 4 muvengi wangu achati, “Ndamukurira ndamukunda,”
\q2 uye vadzivisi vangu vachapembera kana ndawa.
\b
\q1 
\v 5 Asi ini ndinovimba norudo rwenyu rusingaperi;
\q2 mwoyo wangu unofarira ruponeso rwenyu.
\q1 
\v 6 Ndichaimbira Jehovha,
\q2 nokuti akandinakira.
\c 14
\cl Pisarema 14
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Benzi rinoti mumwoyo maro,
\q2 “Hakuna Mwari.”
\q1 Vakaora, mabasa avo akashata;
\q2 hakuna anoita zvakanaka.
\b
\q1 
\v 2 Jehovha ari kudenga anotarira pasi
\q2 pamusoro pavanakomana vavanhu,
\q1 kuti aone kana aripo anonzwisisa,
\q2 naani zvake anotsvaka Mwari.
\q1 
\v 3 Vose vakatsauka,
\q2 vose pamwe chete vakasvibiswa;
\q1 hakuna anoita zvakanaka,
\q2 kunyange nomumwe.
\b
\q1 
\v 4 Ko, vaiti vezvakaipa havadzidziwo here,
\q2 ivo vanodya vanhu vangu savanhu vanodya chingwa,
\q2 uye vasingadani kuna Jehovha?
\q1 
\v 5 Pavari ipapo, vakazara nokutya,
\q2 nokuti Mwari ari paungano yavakarurama.
\q1 
\v 6 Imi vaiti vezvakaipa, munokanganisa urongwa hwavarombo,
\q2 asi Jehovha ndiye utiziro hwavo.
\b
\q1 
\v 7 Haiwa, dai ruponeso rwaIsraeri rwaibuda muZioni!
\q2 Kana Jehovha achidzosazve nhaka yavanhu vake,
\q2 Jakobho ngaapembere uye Israeri ngaafare.
\c 15
\cl Pisarema 15
\d Pisarema raDhavhidhi.
\q1 
\v 1 Jehovha, ndiani angagara munzvimbo yenyu tsvene?
\q2 Ndiani angagara pagomo renyu dzvene?
\b
\q1 
\v 2 Iye anofamba asina chaanopomerwa uye
\q2 anoita zvakarurama,
\q1 anotaura chokwadi zvichibva pamwoyo wake,
\q2 
\v 3 uye asina makuhwa parurimi rwake,
\q1 asingaitiri wokwake zvakaipa
\q2 uye asingatuki waagere naye,
\q1 
\v 4 anozvidza munhu akaipa
\q2 asi anokudza vaya vanotya Jehovha,
\q1 anochengeta mhiko yake
\q2 kunyange kana zvichirwadza,
\q1 
\v 5 anokweretesa mari yake asingarevi mhindu
\q2 uye asingagamuchiri fufuro pamusoro pousina mhosva.
\b
\q1 Munhu anoita izvi
\q2 haangatongozungunuswi.
\c 16
\cl Pisarema 16
\d Mikitami raDhavhidhi.
\q1 
\v 1 Ndichengetedzei, imi Mwari,
\q2 nokuti ndinovanda mamuri.
\b
\q1 
\v 2 Ndakati kuna Jehovha, “Ndimi Ishe wangu;
\q2 kunze kwenyu handina chinhu chakanaka.”
\q1 
\v 3 Kana vari vatsvene vari panyika,
\q2 ndivo vakaisvonaka vandinofarira chose.
\q1 
\v 4 Kuchema kuchawedzerwa,
\q2 kwaavo vanomhanyira vamwe vamwari.
\q1 Handichazodiri zvipiriso zvavo zveropa
\q2 zvinodururwa kana kuisa mazita avo pamiromo yangu.
\b
\q1 
\v 5 Jehovha, makandigovera mugove wangu nomukombe wangu;
\q2 mukaita kuti mugove wangu uchengetedzeke.
\q1 
\v 6 Ndakayererwa miganhu panzvimbo yakanaka;
\q2 zvirokwazvo ndine nhaka inofadza.
\b
\q1 
\v 7 Ndicharumbidza Jehovha, anondipa zano;
\q2 kunyange usiku mwoyo wangu unondirayira.
\q1 
\v 8 Ndakaisa Jehovha pamberi pangu nguva dzose.
\q2 Nokuti ari kurudyi rwangu,
\q2 handingatongozungunuswi.
\b
\q1 
\v 9 Naizvozvo mwoyo wangu unofara uye rurimi rwangu runopururudza;
\q2 muviri wanguwo uchazorora zvakanaka,
\q1 
\v 10 nokuti imi hamuzondisiyi muguva,
\q2 kana kurega Mutsvene wenyu achiona kuora.
\q1 
\v 11 Makandizivisa nzira youpenyu;
\q2 muchandizadza nomufaro uri pamberi penyu,
\q2 nezvinofadza zvisingaperi muruoko rwenyu rworudyi.
\c 17
\cl Pisarema 17
\d Munyengetero waDhavhidhi.
\q1 
\v 1 Inzwai, imi Jehovha, mukumbiro wangu wakarurama;
\q2 inzwai kuchema kwangu.
\q1 Rerekerai nzeve yenyu kumunyengetero wangu,
\q2 usingabvi pamiromo inonyengera.
\q1 
\v 2 Kururamiswa kwangu ngakubve kwamuri;
\q2 meso enyu ngaaone zvakarurama.
\b
\q1 
\v 3 Kunyange mukaedza mwoyo wangu uye mukandiongorora usiku,
\q2 kunyange mukandiedza, hamungawani chinhu;
\q2 ndakazvisunga kuti muromo wangu urege kutadza.
\q1 
\v 4 Kana ari mabasa avanhu,
\q2 neshoko remiromo yenyu,
\q1 ndakanzvenga nzira
\q2 dzouyo anoita nechisimba.
\q1 
\v 5 Nhambwe dzangu dzakarambira panzira dzenyu;
\q2 tsoka dzangu hadzina kutedzemuka.
\b
\q1 
\v 6 Haiwa Mwari, ndinodana kwamuri, nokuti muchandipindura;
\q2 rerekerai nzeve yenyu kwandiri, munzwe munyengetero wangu.
\q1 
\v 7 Ratidzai kushamisa kworudo rwenyu rukuru,
\q2 imi munoponesa noruoko rwenyu rworudyi,
\q2 avo vanovanda vavengi vavo mamuri.
\q1 
\v 8 Ndichengetei semboni yeziso renyu;
\q2 ndivanzei pasi pomumvuri wamapapiro enyu,
\q1 
\v 9 kubva kuno wakaipa anondirwisa,
\q2 kubva kuvavengi vangu, vanoda kundiuraya, vakandikomberedza.
\b
\q1 
\v 10 Vanodzivira mwoyo yavo yakavangarara,
\q2 uye miromo yavo inotaura nokuzvikudza.
\q1 
\v 11 Vakandironda, zvino vandikomba,
\q2 vanocherechedza nameso avo kuti vandiwisire pasi.
\q1 
\v 12 Vakaita seshumba ine nzara yechokudya,
\q2 seshumba huru yakavandira pakavanda.
\b
\q1 
\v 13 Haiwa, Jehovha, simukai, mirai pamberi pavo,
\q2 vawisirei pasi; ndirwirei nomunondo wenyu pano wakaipa.
\q1 
\v 14 Haiwa, Jehovha, ndiponesei noruoko rwenyu kubva kuvanhu vakadai,
\q2 kubva kuvanhu venyika ino vano mubayiro uri muupenyu huno.
\b
\q1 Munopedza nzara yaavo vamunoda;
\q1 vanakomana vavo vane zvakawanda,
\q2 uye vanounganidzira vana vavo pfuma.
\q1 
\v 15 Zvino ini mukururama, ndichaona chiso chenyu;
\q2 pandinomuka, ndichagutswa nokuona mufananidzo wenyu.
\c 18
\cl Pisarema 18
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi muranda waJehovha. Akaimbira Jehovha mashoko orwiyo urwu paakarwirwa naJehovha kubva mumaoko avavengi vake vose nomuruoko rwaSauro. Akati:
\q1 
\v 1 Ndinokudai, imi Jehovha, simba rangu.
\b
\q1 
\v 2 Jehovha ndiye dombo rangu, nhare yangu, murwiri wangu;
\q2 Mwari wangu ndiye dombo rangu, wandinovanda maari.
\q2 Ndiye nhoo yangu norunyanga rworuponeso rwangu, shongwe yangu.
\q1 
\v 3 Ndinodana kuna Jehovha, iye akafanira kurumbidzwa,
\q2 uye ndinoponeswa kubva kuvavengi vangu.
\b
\q1 
\v 4 Mabote orufu akandipinganidza;
\q2 mvura zhinji inoparadza yakandifukidza.
\q1 
\v 5 Mabote eguva akandimonera;
\q2 misungo yorufu yakanangana neni.
\q1 
\v 6 Pakutambudzika kwangu ndakadana kuna Jehovha;
\q2 ndakadana kuna Mwari wangu kuti ndibatsirwe.
\q1 Akanzwa inzwi rangu ari mutemberi yake;
\q2 kuchema kwangu kwakasvika pamberi pake munzeve dzake.
\b
\q1 
\v 7 Nyika yakadedera ikadengenyeka,
\q2 uye nheyo dzamakomo dzakazunguzika;
\q1 
\v 8 Utsi hwakakwira huchibva mumhino dzake;
\q2 moto unoparadza wakabuda mumuromo make,
\q2 mazimbe anopisa akabuda mauri achipfuta.
\q1 
\v 9 Akatsemura matenga akauya pasi;
\q2 makore erima akanga ari pasi petsoka dzake.
\q1 
\v 10 Akatasva makerubhi akabhururuka;
\q2 akabhururuka pamapapiro emhepo.
\q1 
\v 11 Akaita rima chifukidzo chake, denga rake rakamupoteredza,
\q2 iwo makore matema emvura okudenga.
\q1 
\v 12 Nokupenya kwaibva pamberi pake, makore akabuda akafamba,
\q2 nechimvuramabwe nokupenya kwemheni.
\q1 
\v 13 Jehovha akatinhira kudenga;
\q2 inzwi roWokumusoro-soro rikanzwika.
\q1 
\v 14 Akapfura miseve yake akaparadzira vavengi vake,
\q2 kupenya kukuru kwemheni kukavavhundutsa.
\q1 
\v 15 Mipata yegungwa yakaiswa pachena,
\q2 uye nheyo dzenyika dzakaiswa pachena
\q1 pakutuka kwenyu, imi Jehovha,
\q2 nokufema kwemhino dzenyu.
\b
\q1 
\v 16 Akadzika pasi achibva kumusoro akanditora;
\q2 akandibudisa pamvura zhinji yakadzika.
\q1 
\v 17 Akandinunura kubva kuvavengi vangu vane simba,
\q2 kubva kuvadzivisi vangu, vakanga vakasimba zvikuru kwandiri.
\q1 
\v 18 Vakandinanga pazuva renjodzi yangu,
\q2 asi Jehovha akanga ari mutsigiri wangu.
\q1 
\v 19 Akandibudisa akandiisa panzvimbo yakafarikana;
\q2 akandinunura nokuti akanga achindifarira.
\b
\q1 
\v 20 Jehovha akandiitira zvakafanira kururama kwangu;
\q2 nokuchena kwamaoko angu.
\q1 
\v 21 Nokuti ndakachengeta nzira dzaJehovha;
\q2 handina kuita zvakaipa nokubva pana Mwari wangu.
\q1 
\v 22 Mirayiro yake yose iri pamberi pangu;
\q2 handina kutsauka pazvirevo zvake.
\q1 
\v 23 Ndakanga ndisina chandingapomerwa pamberi pake,
\q2 uye ndakazvichengeta kuti ndigare kure nechivi.
\q1 
\v 24 Jehovha akandipa mubayiro zvakaringana nokururama kwangu,
\q2 zvakaringana nokuchena kwamaoko angu pamberi pake.
\b
\q1 
\v 25 Kuna vakatendeka munoratidza kutendeka kwenyu,
\q2 kuna vasina chavangapomerwa munoratidza kusapomerwa kwenyu,
\q1 
\v 26 kuna vakachena munoratidza kuchena kwenyu,
\q2 asi kuna vakatsauka munoratidza hasha dzenyu.
\q1 
\v 27 Munoponesa vanozvininipisa,
\q2 asi muchideredza vane meso anozvikudza.
\q1 
\v 28 Imi, iyemi Jehovha, munoita kuti mwenje wangu urambe uchipfuta;
\q2 Mwari wangu anoshandura rima rangu richiva chiedza.
\q1 
\v 29 Norubatsiro rwenyu ndichaenda kundorwa hondo;
\q2 naMwari wangu ndinogona kukwira rusvingo.
\b
\q1 
\v 30 Kana ari Mwari, nzira yake yakakwana;
\q2 shoko raJehovha harina charingapomerwa.
\q1 Ndiye nhoo
\q2 yavose vanovanda maari.
\q1 
\v 31 Nokuti ndianiko Mwari kunze kwaJehovha?
\q2 Uye ndianiko Dombo kunze kwaMwari wedu?
\q1 
\v 32 NdiMwari anondishongedza nesimba
\q2 uye anokwanisa nzira yangu.
\q1 
\v 33 Anoita kuti tsoka dzangu dzive setsoka dzenondo;
\q2 anoita kuti ndigone kumira pakakwirira.
\q1 
\v 34 Anodzidzisa maoko angu kurwa;
\q2 maoko angu anowembura uta hwendarira.
\q1 
\v 35 Munondipa nhoo yenyu yokukunda,
\q2 uye ruoko rwenyu rworudyi runonditsigira;
\q2 munokotama pasi kuti mundiite mukuru.
\q1 
\v 36 Munondiitira nzira yakapamhama pasi pangu,
\q2 kuitira kuti zvitsitsinho zvangu zvirege kutedzemuka.
\b
\q1 
\v 37 Ndakatevera vavengi vangu ndikavabata;
\q2 handina kudzokera shure kusvikira vaparadzwa.
\q1 
\v 38 Ndakavapwanya kuti vakoniwe kusimuka;
\q2 vakawira pasi petsoka dzangu.
\q1 
\v 39 Makandishongedza nesimba rokurwa;
\q2 makaita kuti vadzivisi vangu vapfugame patsoka dzangu.
\q1 
\v 40 Makaita kuti vavengi vangu vatize,
\q2 uye ndakaparadza vavengi vangu.
\q1 
\v 41 Vakachemera kubatsirwa, asi hakuna akavaponesa,
\q2 kunyange kuna Jehovha, asi haana kuvapindura.
\q1 
\v 42 Ndakavapura vakatsetseka seguruva ratakurwa nemhepo;
\q2 ndakavadururira pasi sedope renzira dzomumusha.
\b
\q1 
\v 43 Makandirwira pakurwisa kwavanhu;
\q2 makandiita musoro wendudzi;
\q2 vanhu vandakanga ndisingazivi vava varanda vangu.
\q1 
\v 44 Pavanongondinzwa, vanonditeerera;
\q2 vatorwa vanokotama pamberi pangu.
\q1 
\v 45 Vose vanoora mwoyo;
\q1 vanouya vachibva panhare dzavo vachidedera.
\b
\q1 
\v 46 Jehovha mupenyu! Dombo rangu ngarirumbidzwe!
\q2 Ngaakudzwe Mwari Muponesi wangu!
\q1 
\v 47 Ndiye Mwari anonditsivira,
\q2 anoisa ndudzi pasi pangu,
\q2 
\v 48 anondiponesa pavavengi vangu.
\q1 Makandisimudzira pamusoro pavavengi vangu.
\q2 Makandinunura kubva kuvanhu vechisimba.
\q1 
\v 49 Naizvozvo ndichakurumbidzai pakati pendudzi, imi Jehovha;
\q2 ndichaimbira zita renyu nziyo dzokurumbidza.
\q1 
\v 50 Anopa mambo wake kukunda kukuru;
\q2 anoratidza unyoro hwake husingaperi kumuzodziwa wake,
\q2 kuna Dhavhidhi nokuvana vake nokusingaperi.
\c 19
\cl Pisarema 19
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Matenga anotaura kubwinya kwaMwari;
\q2 matenga anoparidza mabasa amaoko ake.
\q1 
\v 2 Zuva nezuva anotaura;
\q2 usiku nousiku anoratidza zivo.
\q1 
\v 3 Hakuna mutauro kana rurimi
\q2 rusinganzwi inzwi ravo.
\q1 
\v 4 Inzwi razvo rinosvika panyika yose,
\q2 mashoko azvo kumagumo apasi.
\b
\q1 Mumatenga imomo, akadzika tende rezuva,
\q2 
\v 5 rakaita sechikomba chinobuda mumba,
\q2 seshasha inopemberera kumhanya nhangemutange.
\q1 
\v 6 Rinobuda kuno rumwe rutivi rwedenga
\q2 richitenderera kusvikira kuno rumwe rutivi;
\q2 hakuna chinhu chakavanzika kubva pakupisa kwaro.
\b
\q1 
\v 7 Murayiro waJehovha wakakwana,
\q2 unomutsiridza mweya.
\q1 Zvirevo zvaJehovha zvakavimbika,
\q2 zvinopa njere kuna vasina mano.
\q1 
\v 8 Zvirevo zvaJehovha zvakarurama,
\q2 zvinopa mufaro kumwoyo.
\q1 Murayiro waJehovha unopenya,
\q2 unopa chiedza kumaziso.
\q1 
\v 9 Kutya Jehovha kwakanaka,
\q2 kunogara nokusingaperi.
\q1 Zvakatongwa naJehovha ndezvechokwadi
\q2 uye zvose zvakarurama.
\q1 
\v 10 Zvinokosha kupfuura goridhe,
\q2 kupfuura goridhe rakanatswa;
\q1 zvinotapira kupfuura uchi,
\q2 kupinda uchi hwabva muzinga.
\q1 
\v 11 Muranda wenyu anoyambirwa nazvo;
\q2 pakuzvichengeta pano mubayiro mukuru.
\b
\q1 
\v 12 Ndianiko angaziva kukanganisa kwake?
\q2 Ndikanganwirei mhosva dzangu dzakavanzika.
\q1 
\v 13 Dzorai muranda wenyu kubva pakutadza nobwoni;
\q2 ngazvirege kuva nesimba pamusoro pangu.
\q1 Ipapo handizovi nemhosva,
\q2 ndisina mhaka yokudarika kukuru.
\b
\q1 
\v 14 Mashoko omuromo wangu nokurangarira kwomwoyo wangu
\q2 ngazvifadze pamberi penyu,
\q2 imi Jehovha, Dombo rangu noMudzikinuri wangu.
\c 20
\cl Pisarema 20
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Jehovha ngaakupindure paunotambudzika;
\q2 zita raMwari waJakobho ngarikudzivirire.
\q1 
\v 2 Ngaakutumire rubatsiro runobva panzvimbo tsvene,
\q2 uye akupe rutsigiro runobva kuZioni.
\q1 
\v 3 Ngaarangarire zvibayiro zvako zvose
\q2 uye agogamuchira zvibayiro zvako zvinopiswa. \qs Sera \qs*
\q1 
\v 4 Ngaakupe zvinodikanwa nomwoyo wako,
\q2 uye aite kuti urongwa hwako hwose hubudirire.
\q1 
\v 5 Tichadanidzira nomufaro pakukunda kwako,
\q2 uye tichasimudza mireza yedu muzita raMwari wedu.
\b
\q1 Jehovha ngaakupe zvose zvawakakumbira.
\b
\q1 
\v 6 Zvino ndava kuziva kuti Jehovha anoponesa muzodziwa wake;
\q2 anomupindura ari kudenga rake dzvene,
\q2 nesimba rokuponesa kworuoko rwake rworudyi.
\q1 
\v 7 Vamwe vanovimba nengoro, vamwe namabhiza,
\q2 asi isu tinovimba nezita raJehovha Mwari wedu.
\q1 
\v 8 Vanowisirwa pasi namabvi avo vagowa,
\q2 asi isu tinosimuka tigomira takasimba.
\b
\q1 
\v 9 Haiwa Jehovha, ponesai mambo!
\q2 Tipindurei patinodana!
\c 21
\cl Pisarema 21
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Haiwa Jehovha, mambo anofara musimba renyu.
\q2 Mufaro wake mukuru sei pakukunda kwamunomupa!
\b
\q1 
\v 2 Makamupa zvinodikanwa nomwoyo wake,
\q2 uye hamuna kumunyima zvaikumbirwa nomuromo wake. \qs Sera \qs*
\q1 
\v 3 Makamugamuchira nemikomborero yakapfuma,
\q2 uye makadzika pamusoro pake korona yegoridhe yakachena.
\q1 
\v 4 Akakukumbirai upenyu, mukamupa mazuva
\q2 mazhinji, nokusingaperi-peri.
\q1 
\v 5 Kubudikidza nokukunda kwamakamupa,
\q2 kukudzwa kwake kukuru; makaisa pamusoro pake kubwinya nokukudzwa.
\q1 
\v 6 Zvirokwazvo makamupa maropafadzo anogara nokusingaperi,
\q2 mukamufadza nomufaro pamberi penyu.
\q1 
\v 7 Nokuti mambo anovimba naJehovha;
\q2 nokuda kworudo rusingaperi rwoWokumusoro-soro,
\q2 iye haangazungunuswi.
\b
\q1 
\v 8 Ruoko rwenyu ruchabata vavengi venyu vose;
\q1 ruoko rwenyu rworudyi ruchabata vavengi venyu.
\q1 
\v 9 Panguva yokuonekwa kwenyu
\q2 muchavaita sevira romoto.
\q1 Jehovha achavamedza nehasha dzake,
\q2 uye moto wake uchavaparadza.
\q1 
\v 10 Muchaparadza zvizvarwa zvavo kubva panyika,
\q2 vana vavo kubva pakati pavanhu.
\q1 
\v 11 Kunyange vachirangana zvakaipa pamusoro penyu
\q2 nokufunga mano akaipa, havangagoni kubudirira;
\q1 
\v 12 nokuti muchaita kuti vafuratire,
\q2 pamuchavananga nouta hwakawemburwa.
\b
\q1 
\v 13 Simudzirwai, imi Jehovha, musimba renyu;
\q2 tichaimba uye ticharumbidza simba renyu.
\c 22
\cl Pisarema 22
\d Kumutungamiri wokuimba. Namaimbirwo e“Nondo yamangwanani.” Pisarema raDhavhidhi.
\q1 
\v 1 Mwari wangu, Mwari wangu, mandisiyireiko?
\q2 Sei muri kure zvakadai nokundiponesa,
\q2 kure zvakadai namashoko okugomera kwangu?
\q1 
\v 2 Haiwa Mwari wangu, ndinodanidzira masikati,
\q2 asi hamundipinduri, nousiku, uye handinyarari.
\b
\q1 
\v 3 Asi imi makagadzwa saIye Mutsvene;
\q2 ndimi rumbidzo yaIsraeri.
\q1 
\v 4 Madzibaba edu akavimba nemi;
\q2 vakavimba, uye mukavarwira.
\q1 
\v 5 Vakachema kwamuri, vakaponeswa;
\q2 vakavimba nemi uye havana kunyadziswa.
\b
\q1 
\v 6 Asi ini ndiri honye kwete munhu,
\q2 ndinozvidzwa navanhu uye ndinoshorwa namarudzi.
\q1 
\v 7 Vose vanondiona vanondiseka;
\q2 vanoshamisa miromo yavo vachindituka, vachidzungudza misoro yavo vachiti,
\q1 
\v 8 “Anovimba naJehovha;
\q2 Jehovha ngaamununure.
\q1 Ngaamuponese,
\q2 sezvo achimufarira.”
\b
\q1 
\v 9 Asi ndimi makandibudisa mudumbu;
\q2 mukaita kuti ndivimbe nemi
\q2 ndichiri pachipfuva chamai vangu.
\q1 
\v 10 Kubva pakuzvarwa kwangu, ndakaiswa kwamuri;
\q2 kubva mudumbu ramai vangu, makanga muchingova Mwari wangu.
\b
\q1 
\v 11 Regai kuva kure neni,
\q2 nokuti dambudziko riri pedyo
\q2 uye hakuna angabatsira.
\b
\q1 
\v 12 Hando zhinji dzakandikomba;
\q2 hando dzine simba dzeBhashani dzakandipoteredza.
\q1 
\v 13 Shumba dzinoomba dzichibvambura nyama,
\q2 dzinondishamira miromo yadzo.
\q1 
\v 14 Ndadururwa semvura,
\q2 uye mapfupa angu ose abva asvodogoka.
\q1 Mwoyo wangu washanduka ukava namo;
\q2 wanyungudika mukati mangu.
\q1 
\v 15 Simba rangu raoma sechaenga,
\q2 uye rurimi rwangu runonamatira kumusoro kwomuromo wangu;
\q2 munondiradzika muguruva rorufu.
\q1 
\v 16 Imbwa dzakandikomba;
\q2 boka ravanhu vakaipa rakandipoteredza,
\q2 vakabvoora maoko angu netsoka dzangu.
\q1 
\v 17 Ndinokwanisa kuverenga mapfupa angu ose;
\q2 vanhu vanondinanʼanidza uye vanofarira kutambudzika kwangu.
\q1 
\v 18 Vanogovana nguo dzangu pakati pavo
\q2 uye vanokanda mijenya nokuda kwenguo yangu.
\b
\q1 
\v 19 Asi imi, Jehovha, regai kuva kure neni;
\q2 imi simba rangu, kurumidzai kundibatsira.
\q1 
\v 20 Rwirai upenyu hwangu pamunondo,
\q2 ihwo upenyu hwangu hunokosha, kubva pasimba rembwa.
\q1 
\v 21 Ndinunurei pamuromo weshumba;
\q2 ndiponesei panyanga dzenyati.
\b
\q1 
\v 22 Ndichaparidza zita renyu kuhama dzangu;
\q2 ndichakurumbidzai paungano.
\q1 
\v 23 Imi munotya Jehovha, murumbidzei!
\q2 Imi mose zvizvarwa zvaJakobho, mukudzei!
\q2 Mutyei, imi mose zvizvarwa zvaIsraeri!
\q1 
\v 24 Nokuti haana kuzvidza kana kusema
\q2 chibayiro chaiye akatambudzwa;
\q1 haana kumuvanzira chiso chake,
\q2 asi akanzwa kuchemera kwake rubatsiro.
\b
\q1 
\v 25 Kwamuri ndiko kunobva dingindira rerumbidzo yangu paungano huru;
\q2 ndichazadzisa mhiko dzangu pamberi pavanokutyai.
\q1 
\v 26 Varombo vachadya uye vagoguta;
\q2 vanotsvaka Jehovha vachamurumbidza,
\q2 mwoyo yenyu ngairarame nokusingaperi!
\b
\q1 
\v 27 Migumo yose yenyika
\q2 icharangarira igodzokera kuna Jehovha,
\q1 uye mhuri dzendudzi dzose
\q2 dzichapfugama pamberi pake,
\q1 
\v 28 nokuti ushe ndohwaJehovha
\q2 uye anotonga pamusoro pendudzi.
\b
\q1 
\v 29 Vapfumi vose venyika vachadya
\q2 uye vachamunamata; vose vanoburukira muguruva vachapfugama pamberi pake,
\q2 navose vasingagoni kuzviraramisa.
\q1 
\v 30 Vana vake vachamushumira;
\q2 zvizvarwa zvinotevera zvichaudzwa nezvaIshe.
\q1 
\v 31 Vachaparidza kururama kwake
\q2 kuvanhu vasati vaberekwa,
\q2 nokuti akazviita.
\c 23
\cl Pisarema 23
\d Pisarema raDhavhidhi.
\q1 
\v 1 Jehovha ndiye mufudzi wangu, hapana chandingashayiwa.
\q2 
\v 2 Anondivatisa pamafuro manyoro,
\q1 anondisesedza pamvura inozorodza,
\q2 
\v 3 anoponesa mweya wangu.
\q1 Anondifambisa panzira dzokururama
\q2 nokuda kwezita rake.
\q1 
\v 4 Kunyange ndikafamba nomumupata womumvuri worufu,
\q2 handingatyi zvakaipa,
\q1 nokuti imi muneni;
\q1 tsvimbo yenyu nomudonzvo
\q2 wenyu zvinondinyaradza.
\b
\q1 
\v 5 Munondigadzirira tafura
\q2 pamberi pavavengi vangu.
\q1 Munozodza musoro wangu namafuta;
\q2 mukombe wangu unopfachukira.
\q1 
\v 6 Zvirokwazvo kunaka kwenyu norudo rwenyu zvichanditevera,
\q2 mazuva ose oupenyu hwangu,
\q1 uye ndichagara mumba maJehovha
\q2 nokusingaperi.
\c 24
\cl Pisarema 24
\d Pisarema raDhavhidhi.
\q1 
\v 1 Nyika ndeyaJehovha, nezvose zviri mairi,
\q2 nyika, navose vanogaramo;
\q1 
\v 2 nokuti akaiteya pamusoro pamakungwa
\q2 uye akaisimbisa pamusoro pemvura zhinji.
\b
\q1 
\v 3 Ndianiko angakwira pachikomo chaJehovha?
\q2 Ndianiko angamira panzvimbo yake tsvene?
\q1 
\v 4 Uyo ana maoko akachena nomwoyo wakanaka,
\q2 asingasimudziri mwoyo wake kuzvifananidzo,
\q2 kana kupika nhema.
\b
\q1 
\v 5 Iye achagamuchira makomborero anobva kuna Jehovha
\q2 nokururamiswa kunobva kuna Mwari woruponeso rwake.
\q1 
\v 6 Ivava ndivo rudzi rwaavo vanomutsvaka,
\q2 ivo vanotsvaka chiso chenyu, imi Mwari waJakobho. \qs Sera \qs*
\b
\q1 
\v 7 Simudzai misoro yenyu, imi masuo;
\q2 muisimudze, imi makonhi akare,
\q2 kuti Mambo wokubwinya apinde.
\q1 
\v 8 Ndianiko uyu Mambo wokubwinya?
\q2 Ndiye Jehovha ane simba noumhare,
\q2 Jehovha ane simba pakurwa.
\q1 
\v 9 Simudzai misoro yenyu, imi masuo;
\q2 muasimudze, imi makonhi akare,
\q2 kuti Mambo wokubwinya apinde.
\q1 
\v 10 Ndianiko, uyu Mambo wokubwinya?
\q2 Jehovha Wamasimba Ose,
\q2 ndiye Mambo wokubwinya. \qs Sera \qs*
\c 25
\cl Pisarema 25
\d Pisarema raDhavhidhi.
\q1 
\v 1 Jehovha, ndinosimudzira mwoyo wangu kwamuri;
\q2 
\v 2 haiwa Mwari wangu, ndinovimba nemi.
\b
\q1 Musandirega ndichinyadziswa,
\q2 uye musarega vavengi vangu vachindikunda.
\q1 
\v 3 Hapana munhu ane tariro mamuri
\q2 achanyadziswa,
\q1 asi vachanyadziswa
\q2 avo vanonyengera pasina chikonzero.
\b
\q1 
\v 4 Ndiratidzei nzira dzenyu, imi Jehovha,
\q2 ndidzidzisei nzira dzenyu;
\q1 
\v 5 nditungamirirei muzvokwadi yenyu mugondidzidzisa,
\q2 nokuti ndimi Mwari Muponesi wangu,
\q2 uye tariro yangu iri pamuri zuva rose.
\q1 
\v 6 Rangarirai, imi Jehovha, ngoni dzenyu huru norudo,
\q2 nokuti zvakabvira kare.
\q1 
\v 7 Regai kurangarira zvivi zvouduku hwangu,
\q2 nenzira dzangu dzandaikumukirai nadzo;
\q1 ndirangarirei nokuda kworudo rwenyu,
\q2 nokuti makanaka, imi Jehovha.
\b
\q1 
\v 8 Jehovha akanaka uye akarurama;
\q2 naizvozvo anodzidzisa vatadzi nzira dzake.
\q1 
\v 9 Anotungamirira vanozvininipisa mune zvakarurama,
\q2 uye anovadzidzisa nzira yake.
\q1 
\v 10 Nzira dzose dzaJehovha ndedzorudo nokutendeka,
\q2 kuna avo vanochengeta zvirevo zvesungano yake.
\q1 
\v 11 Nokuda kwezita renyu, imi Jehovha,
\q2 kanganwirai chakaipa changu, kunyange chiri chikuru.
\b
\q1 
\v 12 Ndiani, zvino, munhu anotya Jehovha?
\q2 Achamudzidzisa nzira yaakasarudzirwa.
\q1 
\v 13 Achararama upenyu hwake mukubudirira,
\q2 uye zvizvarwa zvake zvichagara nhaka yenyika.
\q1 
\v 14 Jehovha anogara pakati pavanomutya;
\q2 anozivisa sungano yake kwavari.
\q1 
\v 15 Meso angu anoramba achitarira kuna Jehovha,
\q2 nokuti ndiye chete anosunungura tsoka dzangu pamusungo.
\b
\q1 
\v 16 Dzokerai kwandiri uye mundinzwire nyasha,
\q2 nokuti ndiri ndoga uye ndinotambudzika.
\q1 
\v 17 Matambudziko omwoyo wangu awanda;
\q2 ndisunungurei pakurwadziwa kwangu.
\q1 
\v 18 Tarirai kutambudzika kwangu nenhamo yangu,
\q2 mugobvisa zvivi zvangu zvose.
\q1 
\v 19 Tarirai kuwanda kwaita vavengi vangu,
\q2 uye kuti vanondivenga zvakakura sei!
\b
\q1 
\v 20 Rindai upenyu hwangu mugondinunura;
\q2 ndirege kunyadziswa,
\q2 nokuti ndinovanda mamuri.
\q1 
\v 21 Kusanyengera nokururama ngazvindichengete,
\q2 nokuti tariro yangu iri mamuri.
\b
\q1 
\v 22 Dzikinurai Israeri, imi Mwari,
\q2 kuti vabve mumatambudziko avo ose!
\c 26
\cl Pisarema 26
\d Pisarema raDhavhidhi.
\q1 
\v 1 Nditongerei, imi Jehovha,
\q2 nokuti ndakararama upenyu
\q1 husina chahungapomerwa;
\q2 ndakavimba naJehovha ndisingazungunuki.
\q1 
\v 2 Ndiedzei, imi Jehovha, ndinzverei,
\q2 nzverai mwoyo wangu nendangariro dzangu;
\q1 
\v 3 nokuti rudo rwenyu rwuri pamberi pangu nguva dzose,
\q2 uye ndinogara ndichifamba muzvokwadi yenyu.
\b
\q1 
\v 4 Handigari navanhu vanonyengera,
\q2 kana kufambidzana navanyengeri;
\q1 
\v 5 ndinovenga ungano yavaiti vezvakaipa,
\q2 uye ndinoramba kugara navakaipa.
\q1 
\v 6 Ndinoshamba maoko angu ndisina mhaka,
\q2 uye ndinofamba-famba paaritari yenyu, imi Jehovha,
\q1 
\v 7 ndichiparidza rumbidzo yenyu nenzwi guru,
\q2 uye ndichireva zvamabasa enyu ose anoshamisa.
\q1 
\v 8 Ndinoda imba yamunogara, imi Jehovha,
\q2 nzvimbo inogara kubwinya kwenyu.
\b
\q1 
\v 9 Regai kubatanidza mweya wangu navatadzi,
\q2 noupenyu hwangu navanoteura ropa,
\q1 
\v 10 vana maoko akabata zvakaipa,
\q2 vazere nefufuro mumaoko avo orudyi.
\q1 
\v 11 Asi ini ndinogara upenyu husina chahungapomerwa;
\q2 ndidzikinurei uye mundinzwire ngoni.
\b
\q1 
\v 12 Tsoka dzangu dzimire pakati chechetere;
\q2 ndicharumbidza Jehovha paungano huru.
\c 27
\cl Pisarema 27
\d Pisarema raDhavhidhi.
\q1 
\v 1 Jehovha ndiye chiedza changu noruponeso rwangu,
\q2 ndichagotya aniko?
\q1 Jehovha ndiye nhare youpenyu hwangu,
\q2 ndianiko wandingatya?
\b
\q1 
\v 2 Vanhu vakaipa pavakauya kwandiri
\q2 kuzodya nyama yangu,
\q1 vavengi navadzivisi vangu pavanondirwisa,
\q2 vanogumburwa ndokuwa.
\q1 
\v 3 Kunyange hondo ikandikomba,
\q2 mwoyo wangu haungazotyi;
\q1 kunyange hondo ikamuka kuzondirwisa,
\q2 ipapo ndichavimba naJehovha.
\b
\q1 
\v 4 Chinhu chimwe chete chandinokumbira kuna Jehovha,
\q2 ndicho chandinotsvaka:
\q1 kuti ndigare mumba maJehovha
\q2 mazuva ose oupenyu hwangu,
\q1 kuti nditarire kunaka kwaJehovha
\q2 uye ndimutsvake mutemberi yake.
\q1 
\v 5 Nokuti zuva rokutambudzika
\q2 achandichengeta zvakanaka munzvimbo yaanogara;
\q1 achandiviga mudumba retabhenakeri yake,
\q2 agondikwidza pamusoro pedombo.
\b
\q1 
\v 6 Ipapo musoro wangu uchasimudzirwa
\q2 pamusoro pavavengi vakandipoteredza;
\q1 ndichamubayira zvibayiro patabhenakeri yake nomufaro mukuru;
\q2 ndichaimba ndigoimbira Jehovha nziyo.
\b
\q1 
\v 7 Inzwai inzwi rangu kana ndichidana, imi Jehovha;
\q2 ndinzwirei ngoni mugondipindura.
\q1 
\v 8 Mwoyo wangu unoti kwandiri, “Tsvaka chiso chake!”
\q2 Chiso chenyu, Jehovha, ndichachitsvaka.
\q1 
\v 9 Regai kundivanzira chiso chenyu,
\q2 musadzinga muranda wenyu mukutsamwa;
\q2 makanga muri mubatsiri wangu.
\q1 Regai kundiramba kana kundisiya,
\q2 imi Mwari Muponesi wangu.
\q1 
\v 10 Kunyange baba vangu namai vangu vakandisiya,
\q2 Jehovha achandigamuchira.
\q1 
\v 11 Ndidzidzisei nzira yenyu, imi Jehovha;
\q2 ndisesedzei munzira yakarurama
\q2 nokuda kwavamanikidzi vangu.
\q1 
\v 12 Regai kundisundira kuzvido zvavavengi vangu,
\q2 nokuti zvapupu zvenhema zvinondimukira,
\q2 vachifemedzeka nehasha.
\b
\q1 
\v 13 Ndichine chokwadi neizvi zvokuti:
\q2 ndichaona kunaka kwaJehovha
\q2 munyika yavapenyu.
\q1 
\v 14 Rindira Jehovha;
\q2 iva nesimba,
\q2 utsunge mwoyo ugomirira Jehovha.
\c 28
\cl Pisarema 28
\d Pisarema raDhavhidhi.
\q1 
\v 1 Ndinodana kwamuri, imi Jehovha Dombo rangu;
\q2 musandinyararira.
\q1 Nokuti kana mukaramba munyerere,
\q2 ini ndichaita savaya vakaburukira kugomba.
\q1 
\v 2 Inzwai kuchemera ngoni kwangu,
\q2 sezvo ndichichemera rubatsiro kwamuri,
\q1 sezvo ndichisimudza maoko angu
\q2 ndakatarira kuNzvimbo yenyu Tsvene-tsvene.
\b
\q1 
\v 3 Musandikwekweredzera kure pamwe chete navakaipa,
\q2 naavo vanoita zvakaipa,
\q1 vanotaura rugare navavakidzani vavo
\q2 asi vakaviga zvakaipa mumwoyo yavo.
\q1 
\v 4 Vatsivei pamabasa avo
\q2 napabasa ravo rakaipa,
\q1 vatsivei pane zvakaitwa namaoko avo;
\q2 mugodzosera pamusoro pavo zvakavafanira.
\b
\q1 
\v 5 Sezvo vasina hanya namabasa aJehovha
\q2 uye nezvakaitwa namaoko ake,
\q1 achavaputsira pasi
\q2 akasavavakazve.
\b
\q1 
\v 6 Jehovha ngaarumbidzwe,
\q2 nokuti akanzwa kuchemera kwangu ngoni.
\q1 
\v 7 Jehovha ndiye simba rangu nenhoo yangu;
\q2 mwoyo wangu unovimba naye, uye ndinobatsirwa.
\q1 Mwoyo wangu unokwakuka nomufaro
\q2 uye ndichamuvonga nenziyo.
\b
\q1 
\v 8 Jehovha ndiye simba ravanhu vake,
\q2 nhare yoruponeso yomuzodziwa wake.
\q1 
\v 9 Ponesai vanhu venyu uye muropafadze nhaka yenyu;
\q2 ivai mufudzi wavo uye muvatakure nokusingaperi.
\c 29
\cl Pisarema 29
\d Pisarema raDhavhidhi.
\q1 
\v 1 Ipai kuna Jehovha, imi mune simba
\q2 ipai kuna Jehovha rukudzo nesimba.
\q1 
\v 2 Ipai kuna Jehovha rukudzo rwakafanira zita rake;
\q2 namatai Jehovha mukubwinya kwoutsvene hwake.
\b
\q1 
\v 3 Inzwi raJehovha riri pamusoro pemvura zhinji.
\q2 Mwari wokubwinya anotinhira,
\q2 Jehovha anotinhira ari pamusoro pemvura zhinji.
\q1 
\v 4 Inzwi raJehovha rine simba;
\q2 inzwi raJehovha rinokudzwa.
\q1 
\v 5 Inzwi raJehovha rinovhuna misidhari,
\q2 Jehovha anovhuna-vhuna misidhari yeRebhanoni.
\q1 
\v 6 Anoita kuti Rebhanoni ikwakuke semhuru,
\q2 neSirioni senzombe yenyati.
\q1 
\v 7 Inzwi raJehovha rinorova
\q2 nokuvaima kwemheni.
\q1 
\v 8 Inzwi raJehovha rinozungunusa gwenga;
\q2 Jehovha anozungunusa Gwenga reKadheshi.
\q1 
\v 9 Inzwi raJehovha rinomonyorora miouki
\q2 uye rinosvuura sango rigosara rati hwe-e.
\q1 Uye mutemberi yake zvose zvinodana zvichiti, “Kubwinya!”
\b
\q1 
\v 10 Jehovha anogara pachigaro choushe chamafashamu emvura;
\q2 Jehovha anogara ari Mambo nokusingaperi.
\q1 
\v 11 Jehovha anopa simba kuvanhu vake;
\q2 Jehovha anoropafadza vanhu vake norugare.
\c 30
\cl Pisarema 30
\d Pisarema. Rwiyo rwokukumikidza temberi. Pisarema raDhavhidhi.
\q1 
\v 1 Ndichakukudzai imi Jehovha,
\q2 nokuti makandisimudza kubva pakadzika,
\q2 uye hamuna kutendera vavengi vangu kuti vafare pamusoro pangu.
\q1 
\v 2 Haiwa Jehovha Mwari wangu, ndakachemera rubatsiro kwamuri
\q2 uye mukandiporesa.
\q1 
\v 3 Haiwa Jehovha, makandibudisa muguva;
\q2 mukandirwira kuti ndirege kupinda mugomba.
\b
\q1 
\v 4 Imbirai Jehovha, imi vatsvene vake;
\q2 rumbidzai zita rake dzvene.
\q1 
\v 5 Nokuti kutsamwa kwake ndokwenguva duku,
\q2 asi nyasha dzake ndedzoupenyu hwose;
\q1 kuchema kungangovapo usiku.
\q2 Asi mufaro unouya mangwanani.
\b
\q1 
\v 6 Pandakanzwa kugadzikana, ndakati,
\q2 “Handingatongozungunuswi.”
\q1 
\v 7 Haiwa Jehovha, pamakandinzwira tsitsi,
\q2 makaita kuti gomo rangu rimire rakasimba;
\q1 asi pamakavanza chiso chenyu,
\q2 ini ndakavhunduka.
\b
\q1 
\v 8 Ndakadana kwamuri, imi Jehovha;
\q2 ndakachemera nyasha kuna Jehovha ndichiti,
\q1 
\v 9 “Chiiko chinowanikwa pakuparadzwa kwangu,
\q2 napakupinda kwangu mugomba?
\q1 Ko, guruva richakurumbidzai here?
\q2 Richaparidza kutendeka kwenyu here?
\q1 
\v 10 Inzwai, imi Jehovha, mundinzwire ngoni;
\q2 imi Jehovha, ivai mubatsiri wangu.”
\b
\q1 
\v 11 Imi makashandura kuungudza kwangu kukava kutamba;
\q2 makabvisa nguo dzangu dzamasaga mukandishongedza nomufaro,
\q1 
\v 12 kuti mwoyo wangu ukuimbirei ugorega kunyarara.
\q2 Haiwa Jehovha Mwari wangu, ndichakuvongai nokusingaperi.
\c 31
\cl Pisarema 31
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Ndinovanda mamuri, imi Jehovha;
\q2 itai kuti ndisatombonyadziswa;
\q2 ndirwirei mukururama kwenyu.
\q1 
\v 2 Rerekerai nzeve yenyu kwandiri,
\q2 kurumidzai kundinunura;
\q1 ivai dombo rangu rokuvanda,
\q2 nhare yakasimba inondiponesa.
\q1 
\v 3 Sezvo murimi dombo rangu nenhare yangu,
\q2 nditungamirirei uye mundisesedze nokuda kwezita renyu.
\q1 
\v 4 Ndisunungurei pamusungo wandakadzikirwa,
\q2 nokuti imi muri utiziro hwangu.
\q1 
\v 5 Ndinoisa mweya wangu mumaoko enyu;
\q2 ndidzikinurei, imi Jehovha, Mwari wechokwadi.
\b
\q1 
\v 6 Ndinovenga vanonamatira kuzvifananidzo zvisina maturo;
\q2 ndinovimba naJehovha.
\q1 
\v 7 Ndichafara nokufarisisa murudo rwenyu,
\q2 nokuti makaona kutambudzika kwangu
\q2 mukaziva kurwadziwa kwomwoyo wangu.
\q1 
\v 8 Hamuna kundiisa kumuvengi,
\q2 asi makamisa tsoka dzangu panzvimbo yakafarikana.
\b
\q1 
\v 9 Haiwa Jehovha, ndinzwirei ngoni nokuti ndine nhamo;
\q2 meso angu aneta nokuchema,
\q2 mwoyo wangu nomuviri wangu zvarwadziwa.
\q1 
\v 10 Upenyu hwangu hwopera nokurwadziwa,
\q2 uye namakore angu nokugomera;
\q1 simba rangu rapera nokuda kwokutambudzika kwangu,
\q2 uye mapfupa angu arukutika.
\q1 
\v 11 Nokuda kwavavengi vangu,
\q2 ndava chinhu chinovengwa navavakidzani vangu;
\q1 ndava chinhu chinotyisa kushamwari dzangu;
\q2 vanondiona munzira dzomumisha vanonditiza.
\q1 
\v 12 Ndakanganwikwa navo sendakafa;
\q2 ndafanana nehari yakaputsika,
\q1 
\v 13 nokuti ndinonzwa guhwa ravazhinji;
\q2 kumativi ose kune zvinotyisa;
\q1 vanorangana pamusoro pangu
\q2 uye vanoronga kundiuraya.
\b
\q1 
\v 14 Asi ndinovimba nemi, imi Jehovha;
\q2 ndinoti, “Ndimi Mwari wangu.”
\q1 
\v 15 Nguva dzangu dziri mumaoko enyu;
\q2 ndirwirei kuvavengi vangu
\q2 nokuna avo vanonditeverera.
\q1 
\v 16 Chiso chenyu ngachipenye pamusoro pomuranda wenyu;
\q2 ndiponesei norudo rwenyu rusingaperi.
\q1 
\v 17 Haiwa Jehovha, itai kuti ndisanyadziswa,
\q2 nokuti ndakadana kwamuri;
\q1 asi vakaipa ngavanyadziswe
\q2 uye vavate vakati mwiro muguva.
\q1 
\v 18 Miromo yavo inoreva nhema ngainyaradzwe,
\q2 nokuti vanotaura namanyawi
\q2 nokuzvikudza pamusoro pavakarurama.
\b
\q1 
\v 19 Haiwa, kunaka kwenyu kukuru sei,
\q2 kwamakachengetera vaya vanokutyai,
\q1 kwamunoisa pamberi pavanhu,
\q2 pamusoro paivo vanovanda mamuri.
\q1 
\v 20 Mukudzivirira kwokuvapo kwenyu munovavanza
\q2 kubva parangano dzavanhu;
\q1 munovachengeta zvakanaka pamunogara
\q2 kubva pandimi dzinopomera.
\b
\q1 
\v 21 Jehovha ngaarumbidzwe,
\q2 nokuti akaratidza rudo rwake runoshamisa
\q2 kwandiri pandakanga ndiri muguta rakakombwa.
\q1 
\v 22 Mukuvhunduka kwangu, ndakati,
\q2 “Ndabviswa pamberi penyu!”
\q1 Asi makanzwa kuchemera nyasha kwangu
\q2 pandakadanidzira kwamuri ndichida rubatsiro.
\b
\q1 
\v 23 Idai Jehovha, imi vatsvene mose!
\q2 Jehovha anochengetedza vakatendeka,
\q2 asi anotsiva zvizere vanozvikudza.
\q1 
\v 24 Simbai uye mutsunge mwoyo,
\q2 imi mose munorindira Jehovha.
\c 32
\cl Pisarema 32
\d Pisarema raDhavhidhi neMasikiri.
\q1 
\v 1 Akaropafadzwa uyo
\q2 akakanganwirwa kudarika kwake,
\q2 akafukidzirwa zvivi zvake.
\q1 
\v 2 Akaropafadzwa munhu
\q2 asingaverengerwi zvivi zvake naJehovha,
\q2 uye asina kunyengera mumwoyo make.
\b
\q1 
\v 3 Pandakanyarara,
\q2 mapfupa angu akarukutika nokuda
\q2 kwokugomera kwangu zuva rose.
\q1 
\v 4 Nokuti masikati nousiku
\q2 ruoko rwenyu rwakanga ruchirema pamusoro pangu;
\q1 simba rangu rakasvetwa
\q2 sezvinoita kupisa kwechirimo. \qs Sera \qs*
\b
\q1 
\v 5 Ipapo ndakazivisa chivi changu kwamuri
\q2 uye handina kuvanza chakaipa changu.
\q1 Ndakati, “Ndichareurura kudarika kwangu kuna Jehovha,”
\q2 uye makandiregerera mhosva yechivi changu. \qs Sera \qs*
\b
\q1 
\v 6 Naizvozvo vose vanoda Mwari ngavanyengetere kwamuri
\q2 muchiri kuwanikwa;
\q1 zvirokwazvo mvura zhinji ine simba painokwira,
\q2 haingasviki kwavari.
\q1 
\v 7 Ndimi nzvimbo yangu yokuvanda;
\q2 muchandidzivirira panhamo
\q2 uye muchandipoteredza nenziyo dzorusununguko. \qs Sera \qs*
\b
\q1 
\v 8 Ndichakurairidza uye ndichakudzidzisa nzira yaunofanira kufamba nayo;
\q2 ndichakupa zano uye ndichakurinda.
\q1 
\v 9 Rega kuva sebhiza kana senyurusi,
\q2 zvisinganzwisisi asi zvinofanira kupingudzwa
\q1 nomukaro kana namatomu,
\q2 kana kuti hazvingauyi kwauri.
\q1 
\v 10 Wakaipa ana matambudziko mazhinji,
\q2 asi rudo rusingaperi rwaJehovha
\q2 runopoteredza munhu anovimba naye.
\b
\q1 
\v 11 Farai muna Jehovha uye mufarisise, imi vakarurama;
\q2 imbai, imi mose makarurama pamwoyo!
\c 33
\cl Pisarema 33
\q1 
\v 1 Imbirai Jehovha, mufarisise, imi vakarurama;
\q2 zvakanaka kuti vakarurama vamurumbidze.
\q1 
\v 2 Rumbidzai Jehovha nembira;
\q2 muimbirei nziyo nomutengeranwa une hungiso gumi.
\q1 
\v 3 Muimbirei rwiyo rutsva;
\q2 muridze zvakanaka, mugopururudza nomufaro.
\b
\q1 
\v 4 Nokuti shoko raJehovha rakarurama uye nderechokwadi;
\q2 iye akatendeka pane zvose zvaanoita.
\q1 
\v 5 Jehovha anoda kururama nokururamisira;
\q2 nyika izere norudo rwake rusingaperi.
\b
\q1 
\v 6 Kudenga denga kwakaitwa neshoko raJehovha,
\q2 hondo dzenyeredzi dzaikoko, nokufema kwomuromo wake.
\q1 
\v 7 Anounganidza mvura zhinji yegungwa muzvirongo;
\q2 anoisa kwakadzika mumatura.
\q1 
\v 8 Nyika yose ngaitye Jehovha;
\q2 marudzi ose enyika ngaamuremekedze.
\q1 
\v 9 Nokuti iye akataura, zvikaitika;
\q2 akarayira, zvikamira zvakasimba.
\b
\q1 
\v 10 Jehovha anokonesa urongwa hwendudzi;
\q2 anopinganidza mifungo yendudzi.
\q1 
\v 11 Asi urongwa hwaJehovha hunomira hwakasimba nokusingaperi,
\q2 nendangariro dzomwoyo wake kusvikira kuzvizvarwa zvose.
\b
\q1 
\v 12 Rwakaropafadzwa rudzi rwakaita Jehovha Mwari warwo,
\q2 vanhu vaakasarudza kuti vave nhaka yake.
\q1 
\v 13 Jehovha anotarira pasi ari kudenga
\q2 uye anoona marudzi ose avanhu;
\q1 
\v 14 ari pachigaro chake anotarira
\q2 vose vagere panyika,
\q1 
\v 15 iye anoumba mwoyo yavanhu vose,
\q2 anofungisisa zvose zvavanoita.
\b
\q1 
\v 16 Hapana mambo anoponeswa nokukura kwehondo yake;
\q2 hapana murwi anopunyuka nokuda kwesimba rake guru.
\q1 
\v 17 Bhiza itariro isina maturo pakurwirwa;
\q2 harigoni kuponesa kunyange rine simba guru.
\q1 
\v 18 Asi meso aJehovha ari pamusoro paavo vanomutya,
\q2 napamusoro paavo vakaisa tariro yavo murudo rwake rusingaperi,
\q1 
\v 19 kuti avarwire parufu
\q2 nokuvararamisa panzara.
\b
\q1 
\v 20 Tinomirira Jehovha netariro;
\q2 ndiye mubatsiri wedu nenhoo yedu.
\q1 
\v 21 Mwoyo yedu inofara maari,
\q2 nokuti tinovimba nezita rake dzvene.
\q1 
\v 22 Rudo rwenyu rusingaperi ngarugare pamusoro pedu, imi Jehovha,
\q2 kunyange sezvatakaisa tariro yedu mamuri.
\c 34
\cl Pisarema 34
\d Pisarema raDhavhidhi. Paakaita seanopenga pamberi paAbhimereki; uyo akamudzinga, iye akaenda hake.
\q1 
\v 1 Ndinorumbidza Jehovha nguva dzose;
\q2 kurumbidzwa kwake kucharamba kuri pamiromo yangu.
\q1 
\v 2 Mwoyo wangu uchazvirumbidza muna Jehovha;
\q2 vanotambudzika ngavanzwe vafare.
\q1 
\v 3 Kudzai Jehovha pamwe chete neni;
\q2 ngatikudzei zita rake pamwe chete.
\b
\q1 
\v 4 Ndakachema kuna Jehovha akandipindura;
\q2 akandisunungura pakutya kwangu kwose.
\q1 
\v 5 Vanotarira kwaari vanopenya;
\q2 zviso zvavo hazvingambofukidzwi nenyadzi.
\q1 
\v 6 Murombo uyu akadana, uye Jehovha akamunzwa;
\q2 akamuponesa pakutambudzika kwake kwose.
\q1 
\v 7 Mutumwa waJehovha anokomberedza avo vanomutya,
\q2 uye anovasunungura.
\b
\q1 
\v 8 Ravirai henyu muone kuti Jehovha akanaka;
\q2 akaropafadzwa munhu anovanda maari.
\q1 
\v 9 Ityai Jehovha, imi vatsvene vake,
\q2 nokuti vanomutya havana chavanoshayiwa.
\q1 
\v 10 Shumba dzinopera simba uye dzinofa nenzara,
\q2 asi avo vanotsvaka Jehovha havashayiwi chinhu chakanaka.
\b
\q1 
\v 11 Uyai, vana vangu, nditeererei;
\q2 ndichakudzidzisai kutya Jehovha.
\q1 
\v 12 Ani naani wenyu anoda upenyu,
\q2 uye uchida kuona mazuva akawanda,
\q1 
\v 13 dzora rurimi rwako pane zvakaipa
\q2 nemiromo yako pakureva nhema.
\q1 
\v 14 Ibva pane zvakaipa ugoita zvakanaka;
\q2 tsvaka rugare uye urutevere.
\b
\q1 
\v 15 Meso aJehovha ari pamusoro pavakarurama
\q2 uye nzeve dzake dzinonzwa kuchema kwavo;
\q1 
\v 16 chiso chaJehovha chinovenga avo vanoita zvakaipa,
\q2 kuti abvise chiyeuchidzo chavo panyika.
\b
\q1 
\v 17 Vakarurama vanodanidzira, uye Jehovha anovanzwa;
\q2 anovarwira pakutambudzika kwavo kwose.
\q1 
\v 18 Jehovha ari pedyo navane mwoyo yakaputsika
\q2 uye anoponesa avo vakapwanyika pamweya.
\b
\q1 
\v 19 Akarurama angava namatambudziko mazhinji,
\q2 asi Jehovha anomurwira paari ose;
\q1 
\v 20 anochengetedza mapfupa ake ose,
\q2 hakuna nerimwe rawo richavhunika.
\b
\q1 
\v 21 Zvakaipa zvichauraya vakaipa;
\q2 vavengi vavakarurama vachapiwa mhosva.
\q1 
\v 22 Jehovha anodzikinura varanda vake;
\q2 hapana kana mumwe anovanda maari achapiwa mhosva.
\c 35
\cl Pisarema 35
\d Pisarema raDhavhidhi.
\q1 
\v 1 Haiwa Jehovha, kakavadzanai navanokakavadzana neni;
\q2 rwisai avo vanondirwisa.
\q1 
\v 2 Torai nhoo huru neduku;
\q2 simukai, uye uyai mundibatsire.
\q1 
\v 3 Vheyesai pfumo guru nepfumo diki
\q2 murwise avo vanonditevera.
\q1 Muti kumweya wangu,
\q2 “Ndini ruponeso rwako.”
\b
\q1 
\v 4 Vanotsvaka kundiuraya
\q2 ngavazvidzwe uye vanyadziswe;
\q1 vanorangana kuparadzwa kwangu
\q2 ngavadzoserwe shure vachitya.
\q1 
\v 5 Ngavaite sehundi pamberi pemhepo,
\q2 mutumwa waJehovha achivasundira kure;
\q1 
\v 6 nzira yavo ngaisvibe uye itsvedze,
\q2 mutumwa waJehovha achivateverera.
\b
\q1 
\v 7 Sezvo vakandivanzira mimbure yavo ndisina mhosva,
\q2 uye vakandicherera gomba ndisina mhosva,
\q1 
\v 8 kuparadzwa ngakuvawire pakarepo,
\q2 mumbure wavakavanza ngauvapinge ivo,
\q2 ngavawire mugomba ravo vaparare.
\q1 
\v 9 Ipapo mweya wangu uchafara muna Jehovha,
\q2 uye uchafarira ruponeso rwake.
\q1 
\v 10 Zvandiri zvose zvichadanidzira zvichiti:
\q2 “Ndianiko akaita semi, Jehovha?
\q1 Munonunura varombo kubva
\q2 kuna avo vane simba kupinda ravo.”
\b
\q1 
\v 11 Zvapupu zvino utsinye zvinouya mberi;
\q2 zvinondibvunza pamusoro pezvinhu zvandisingazivi.
\q1 
\v 12 Vanotsiva zvakanaka zvangu nezvakaipa,
\q2 uye vanosiya mweya wangu uchidzungaira.
\q1 
\v 13 Asi pavairwara, ndakafuka nguo dzamasaga
\q2 ndikazvininipisa nokutsanya.
\q1 Munyengetero wangu pawakadzokera kwandiri usina mhinduro,
\q2 
\v 14 ndakafamba-famba ndichichema
\q2 kunge ndinochemera shamwari yangu kana hama yangu.
\q1 Ndakakotamisa musoro wangu ndichichema,
\q2 sokunge ndinochema mai vangu.
\q1 
\v 15 Asi pandakagumburwa, vakaungana vachifara;
\q2 varwi vakaungana kuzondirwisa ndisingazivi.
\q2 Vakandireva vasingaregi.
\q1 
\v 16 Savanhu vasina Mwari vakandiseka muruvengo rwavo;
\q2 vakandirumanyira meno avo.
\q1 
\v 17 Haiwa Jehovha, muchasvika riniko makangotarira?
\q2 Nunurai upenyu hwangu kubva pakuparadza kwavo,
\q2 noupenyu hwangu hunokosha kubva pashumba idzi.
\q1 
\v 18 Ndichakuvongai paungano huru;
\q2 ndichakurumbidzai pakati pavanhu vazhinji.
\b
\q1 
\v 19 Ngavarege kufara pamusoro pangu
\q2 avo vanondivenga ndisina mhosva;
\q1 vanondivenga ndisina mhosva
\q2 ngavarege kuchonyerana meso avo mukundivenga.
\q1 
\v 20 Havatauri norugare,
\q2 asi vanofunga kupomera mhosva
\q2 pamusoro pavanogara norunyararo munyika.
\q1 
\v 21 Vanondishamira miromo yavo vachiti,
\q2 “Hekani waro! Hekani waro! Tazviona nameso edu.”
\b
\q1 
\v 22 Haiwa Jehovha, mazviona izvi; regai kunyarara.
\q2 Regai kuva kure neni, imi Ishe.
\q1 
\v 23 Mukai uye simukai mundirwire!
\q2 Ndirwirei, Mwari wangu naIshe wangu.
\q1 
\v 24 Ndiruramisirei mukururama kwenyu, imi Jehovha Mwari wangu;
\q2 musarega vachifara pamusoro pangu.
\q1 
\v 25 Musarega vachifunga mumwoyo mavo vachiti, “Hekani waro,
\q2 ndizvo zvatanga tichida!” kana kuti vati, “Tamumedza chose.”
\b
\q1 
\v 26 Vose vanofarira kutambudzika kwangu
\q2 ngavanyadziswe uye vanyonganiswe;
\q1 vose vanozvisimudzira pamusoro pangu
\q2 ngavafukidzwe nenyadzi nokuzvidzwa.
\q1 
\v 27 Vose vanofarira kururamisirwa kwangu
\q2 ngavapembere nomufaro nokufarisisa;
\q1 ngavarambe vachiti, “Jehovha ngaakudzwe,
\q2 iye anofarira kugara zvakanaka kwavaranda vake.”
\b
\q1 
\v 28 Rurimi rwangu ruchataura zvokururama kwenyu,
\q2 uye nezvokurumbidzwa kwenyu zuva rose.
\c 36
\cl Pisarema 36
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi muranda waJehovha.
\q1 
\v 1 Shoko riri mumwoyo mangu
\q2 pamusoro pokutadza kweakaipa rinoti:
\q1 Hakuna kutya Mwari
\q2 pamberi pake.
\b
\q1 
\v 2 Pamaonero ake anozvirumbidza, nokuti anozvibata kumeso kwazvo pakuona kwake,
\q2 zvokuti anotadza kuona kana kuvenga chivi chake.
\q1 
\v 3 Mashoko omuromo wake akaipa uye anonyengera;
\q2 haachisiri munhu akachenjera kana anoita zvakanaka.
\q1 
\v 4 Kunyange panhoo yake anofunga zvakaipa;
\q2 anozvifambisa panzira yezvakaipa
\q2 uye haarambi chakaipa.
\b
\q1 
\v 5 Rudo rwenyu, imi Jehovha, runosvika kudenga denga,
\q2 kutendeka kwenyu kunosvika kumakore.
\q1 
\v 6 Kururama kwenyu kwakaita segomo guru guru,
\q2 kururamisira kwenyu sepakadzika dzika.
\q1 Haiwa Jehovha, imi munochengetedza zvose munhu nemhuka.
\q2 
\v 7 Haiwa rudo rwenyu rusingatongoperi runokosha sei!
\q1 Vose vakuru navaduku pakati pavanhu
\q2 vanovanda mumumvuri wamapapiro enyu.
\q1 
\v 8 Vanogutswa nezvakawanda zvomumba menyu;
\q2 munovanwisa kubva parwizi rwenyu runofadza.
\q1 
\v 9 Nokuti kwamuri ndiko kune chitubu choupenyu;
\q2 muchiedza chenyu tinoona chiedza.
\b
\q1 
\v 10 Rambai muchiitira rudo kuna avo vanokuzivai,
\q2 uye kururama kwenyu kuna vane mwoyo yakarurama.
\q1 
\v 11 Rutsoka rwounozvikudza ngarurege kusvika kwandiri,
\q2 kunyange ruoko rweakaipa ngarurege kundidzingira kure.
\q1 
\v 12 Tarirai vaiti vezvakaipa kuti vawa sei,
\q2 vakandwa pasi, havagoni kumuka.
\c 37
\cl Pisarema 37
\d Pisarema raDhavhidhi.
\q1 
\v 1 Usava neshungu nokuda kwavanhu vakaipa,
\q2 uye usaitira godo avo vanoita zvakaipa;
\q1 
\v 2 nokuti souswa vachaoma nokukurumidza,
\q2 somuriwo wakasvibira vachakurumidza kuoma.
\b
\q1 
\v 3 Vimba naJehovha uite zvakanaka;
\q2 gara panyika ufarikane pamafuro manyoro.
\q1 
\v 4 Farikana muna Jehovha,
\q2 uye iye achakupa zvinodikanwa nomwoyo wako.
\b
\q1 
\v 5 Isa nzira yako kuna Jehovha;
\q2 uvimbe naye uye iye achaita izvi;
\q1 
\v 6 achaita kuti kururama kwako kupenye samambakwedza,
\q2 nokururamisirwa kwako sezuva ramasikati.
\b
\q1 
\v 7 Nyarara pamberi paJehovha, umurindire unyerere;
\q2 usava neshungu kana vanhu vachibudirira panzira dzavo,
\q2 pavanoita mano avo akaipa avakaronga.
\b
\q1 
\v 8 Rega kutsamwa, uzvidzore pahasha;
\q2 usava neshungu zvinokutungamirira mune zvakaipa.
\q1 
\v 9 Nokuti vasakarurama vachagurwa,
\q2 asi avo vanomirira Jehovha vachagara nhaka yenyika.
\b
\q1 
\v 10 Chinguva chiduku duku, vakaipa havachazovapozve;
\q2 kunyange ukavatsvaka, havazowanikwi.
\q1 
\v 11 Asi vanyoro vachagara nhaka yenyika,
\q2 uye vachafarikana norugare rukuru.
\b
\q1 
\v 12 Vakaipa vanofungira vakarurama mano akaipa,
\q2 uye vanovarumanyira meno avo.
\q1 
\v 13 Asi Ishe anoseka vakaipa
\q2 nokuti anoziva kuti zuva ravo riri kuuya.
\b
\q1 
\v 14 Vakaipa vanovhomora munondo
\q2 uye vanowembura uta
\q1 kuti vawisire pasi varombo navanoshayiwa,
\q2 kuti vauraye avo vane nzira dzakarurama.
\q1 
\v 15 Asi minondo yavo ichabaya mwoyo yavo pachavo,
\q2 uye uta hwavo huchavhunika.
\b
\q1 
\v 16 Zvishoma zvowakarurama zviri nani
\q2 kupinda pfuma yavakaipa vazhinji;
\q1 
\v 17 nokuti simba ravakaipa richavhuniwa,
\q2 asi Jehovha anotsigira vakarurama.
\b
\q1 
\v 18 Mazuva avakarurama anozivikanwa naJehovha,
\q2 uye nhaka yavo ichagara nokusingaperi.
\q1 
\v 19 Panguva yamatambudziko, havanganyadziswi;
\q2 mumazuva enzara ivo vachava nezvakawanda.
\b
\q1 
\v 20 Asi vakaipa vachaparara:
\q2 vavengi vaJehovha vachafanana norunako rweminda,
\q2 vachanyangarika soutsi.
\b
\q1 
\v 21 Vakaipa vanokwereta uye havadzori,
\q2 asi vakarurama vanopa zvakawanda;
\q1 
\v 22 avo vanoropafadzwa naJehovha vachagara nhaka yenyika,
\q2 asi avo vaanotuka vachaparadzwa.
\b
\q1 
\v 23 Kana Jehovha achifarira nzira yomunhu,
\q2 anosimbisa mafambiro ake;
\q1 
\v 24 kunyange akagumburwa, haangawi,
\q2 nokuti Jehovha anomutsigira noruoko rwake.
\b
\q1 
\v 25 Ndakanga ndiri muduku uye zvino ndakwegura,
\q2 asi handina kumboona vakarurama vachiraswa,
\q2 kana vana vavo vachipemha chingwa.
\q1 
\v 26 Vanogara vachingopa vamwe, uye vachikweretesa pasina muripo;
\q2 vana vavo vacharopafadzwa.
\b
\q1 
\v 27 Dzoka pane zvakaipa ugoita zvakanaka;
\q2 ipapo uchagara panyika nokusingaperi.
\q1 
\v 28 Nokuti Jehovha anoda vanoruramisira
\q2 uye haangazosiyi vanhu vake vakatendeka.
\b
\q1 Vachadzivirirwa nokusingaperi;
\q2 asi vana vowakaipa vachaparadzwa;
\q1 
\v 29 vakarurama vachagara nhaka yenyika
\q2 uye vachagara mairi nokusingaperi.
\b
\q1 
\v 30 Muromo womunhu akarurama unotaura uchenjeri,
\q2 uye rurimi rwake runotaura kururamisira.
\q1 
\v 31 Murayiro waMwari wake uri pamwoyo wake;
\q2 tsoka dzake hadzitedzemuki.
\b
\q1 
\v 32 Vakaipa vanovandira vakarurama,
\q2 vachitsvaka upenyu hwavo chaihwo;
\q1 
\v 33 asi Jehovha haangavasiyi vari musimba ravo,
\q2 kana kuvarega vachipomerwa kana vamira pakutongwa.
\b
\q1 
\v 34 Rindira Jehovha,
\q2 uye uchengete nzira yake.
\q1 Achakusimudzira kuti ugare nhaka yenyika;
\q2 kana vakaipa voparadzwa, iwe uchazviona.
\b
\q1 
\v 35 Ndakaona munhu akaipa uye ano utsinye
\q2 achibudirira somuti wakasvibira pavhu romunyika yawo,
\q1 
\v 36 asi nokukurumidza akapfuura uye akasazovapozve;
\q2 kunyange ndakamutsvaka, haana kuzowanikwa.
\b
\q1 
\v 37 Cherechedza asina mhosva, ongorora akarurama;
\q2 ane ramangwana rakanaka munhu worugare.
\q1 
\v 38 Asi vatadzi vose vachaparadzwa;
\q2 ramangwana rowakaipa richagurwa.
\b
\q1 
\v 39 Ruponeso rwavakarurama runobva kuna Jehovha;
\q2 ndiye nhare yavo panguva yamatambudziko.
\q1 
\v 40 Jehovha anovabatsira uye anovanunura;
\q2 anovanunura kubva kuna vakaipa uye anovaponesa,
\q2 nokuti vanovanda maari.
\c 38
\cl Pisarema 38
\d Pisarema raDhavhidhi. Chikumbiro.
\q1 
\v 1 Haiwa Jehovha, musandirayira mukutsamwa kwenyu kana
\q2 kundiranga muhasha dzenyu.
\q1 
\v 2 Nokuti miseve yenyu yandibaya,
\q2 uye ruoko rwenyu rwawira pamusoro pangu.
\q1 
\v 3 Mumuviri mangu hamuchina utano nokuda kwehasha dzenyu;
\q2 mapfupa angu apera simba nokuda kwechivi changu.
\q1 
\v 4 Mhosva yangu yandiremera
\q2 somutoro unorema kwazvo kuutakura.
\b
\q1 
\v 5 Maronda angu aora uye anosemesa
\q2 nokuda kwoupenzi hwokutadza kwangu.
\q1 
\v 6 Ndakotamiswa uye ndaderedzwa kwazvo;
\q2 ndinofamba ndichichema zuva rose.
\q1 
\v 7 Musana wangu wazara nokupisa kunorwadza;
\q2 muviri wangu hauchina utano.
\q1 
\v 8 Ndarukutika uye ndapwanyika chose;
\q2 ndiri kugomera nokurwadza kwomwoyo.
\b
\q1 
\v 9 Haiwa Ishe, zvose zvandinoshuva zviri pachena pamberi penyu,
\q2 kugomera kwangu hakuna kuvanzika kwamuri.
\q1 
\v 10 Hana yangu inorova, simba rangu rapera;
\q2 kunyange nechiedza chabva pameso angu.
\q1 
\v 11 Shamwari dzangu navafambidzani vondinzvenga nokuda kwamaronda angu;
\q2 vavakidzani vangu vanogara kure neni.
\q1 
\v 12 Avo vanotsvaka kundiuraya vanonditeya nemisungo yavo,
\q2 avo vanoda kundikuvadza vanotaura nezvokuparadzwa kwangu;
\q2 zuva rose vanorangana zvounyengeri.
\b
\q1 
\v 13 Ini ndafanana nematsi, isinganzwi,
\q2 sembeveve, isingagoni kushamisa muromo wayo;
\q1 
\v 14 ndava somunhu asinganzwi,
\q2 ano muromo usingapinduri.
\q1 
\v 15 Haiwa Jehovha, ndakakumirirai;
\q2 muchapindura, imi Ishe Mwari wangu.
\q1 
\v 16 Nokuti ndakati, “Musavarega vachifarira kutambudzika kwangu
\q2 kana kuzvisimudzira pamusoro pangu, rutsoka rwangu parunotedzemuka.”
\b
\q1 
\v 17 Nokuti ndava pedyo nokuwa,
\q2 uye kurwadziwa kwangu kunogara neni.
\q1 
\v 18 Ndinoreurura chivi changu;
\q2 chivi changu chinonditambudza.
\q1 
\v 19 Vavengi vangu vane simba vazhinji;
\q2 vanondivenga ndisina mhosva vakawanda.
\q1 
\v 20 Ivavo vanotsiva zvakanaka zvangu nezvakaipa,
\q2 vanondireva pandinotevera zvakanaka.
\b
\q1 
\v 21 Haiwa Jehovha, regai kundisiya;
\q2 regai kuva kure neni, imi Mwari wangu.
\q1 
\v 22 Haiwa Ishe Muponesi wangu,
\q2 kurumidzai kuuya kuzondibatsira.
\c 39
\cl Pisarema 39
\d Kumutungamiri wokuimba. Kuna Jedhutuni. Pisarema raDhavhidhi.
\q1 
\v 1 Ndakati, “Ndichangwarira nzira dzangu
\q2 nokuchengeta rurimi rwangu pachivi;
\q1 ndichaisa matomu pamuromo wangu
\q2 kana vakaipa vari pamberi pangu.”
\q1 
\v 2 Asi pandakanga ndinyerere uye ndakadzikama,
\q2 ndisingatauri kana chakanaka zvacho,
\q2 kurwadziwa kwangu kwakawedzerwa.
\q1 
\v 3 Mwoyo wangu wakapisa mukati mangu,
\q2 uye pandakafungisisa, moto ukapisa;
\q2 ipapo ndakataura norurimi rwangu ndikati:
\b
\q1 
\v 4 “Ndiratidzei, imi Jehovha, magumo oupenyu hwangu
\q2 nokuwanda kwamazuva angu;
\q2 ndizivisei kupfuura kwoupenyu hwangu.
\q1 
\v 5 Makaita mazuva angu soupamhi hwechanza changu;
\q2 kuwanda kwamakore angu kwakaita sechinhu chisipo pamberi penyu.
\q2 Upenyu hwomunhu mumwe nomumwe mweya bedzi.
\q1 
\v 6 Munhu anongori mumvuri zvaanofamba-famba hake:
\q2 anofamba nomufaro mukuru, asi zvinongova pasina;
\q2 anounganidza pfuma, asingazivi achazoitora.
\b
\q1 
\v 7 “Asi zvino, Ishe, ndakamirireiko?
\q2 Tariro yangu iri mamuri.
\q1 
\v 8 Ndiponesei pakudarika kwangu kwose;
\q2 regai kundiita chiseko chamapenzi.
\q1 
\v 9 Ndakanga ndinyerere; handina kushamisa muromo wangu,
\q2 nokuti ndimi makaita izvi.
\q1 
\v 10 Bvisai shamhu yenyu kwandiri;
\q2 ndakundwa nokurova kworuoko rwenyu.
\q1 
\v 11 Munorayira uye munoranga vanhu nokuda kwezvivi zvavo,
\q2 munoparadza pfuma yavo sechipfukuto,
\q2 munhu mumwe nomumwe mweya zvawo. \qs Sera \qs*
\b
\q1 
\v 12 “Inzwai munyengetero wangu, imi Jehovha,
\q2 rerekerai nzeve yenyu pandinochemera rubatsiro;
\q2 regai kuva matsi pakuchema kwangu.
\q1 Nokuti ndigere nemi somutorwa,
\q2 somweni, sezvakanga zvakaita madzibaba angu ose.
\q1 
\v 13 Ringirai kure neni, kuti ndimbofarazve
\q2 ndisati ndabva uye ndisisipo.”
\c 40
\cl Pisarema 40
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Ndakamirira Jehovha nomwoyo murefu;
\q2 iye akatendeukira kwandiri akanzwa kuchema kwangu.
\q1 
\v 2 Akandibudisa mugomba rakadzika,
\q2 kunze kwamatope netsvina;
\q1 akamisa tsoka dzangu padombo
\q2 akandipa nzvimbo yakasimba kuti ndimirepo.
\q1 
\v 3 Akaisa rwiyo rutsva mumuromo mangu,
\q2 rwiyo rwokurumbidza Mwari wedu.
\q1 Vazhinji vachaona, uye vachatya
\q2 uye vachaisa ruvimbo rwavo muna Jehovha.
\b
\q1 
\v 4 Akaropafadzwa munhu
\q2 akaita Jehovha ruvimbo rwake,
\q1 asingatariri kuna vanozvikudza,
\q2 kuna avo vanotsaukira kuna vamwari venhema.
\q1 
\v 5 Haiwa Jehovha, Mwari wangu,
\q2 zvizhinji zvishamiso zvamakaita.
\q1 Zvinhu zvamakatitongera hakuna
\q2 angazvirondedzera kwamuri;
\q1 dai ndingataura nokureva pamusoro pazvo,
\q2 zvaizowandisa kuzvizivisa.
\b
\q1 
\v 6 Hamuna kufarira zvibayiro nezvipo,
\q2 asi nzeve dzangu makadziboora;
\q1 zvibayiro zvinopiswa nezvipiriso
\q2 zvezvivi hamuna kuzvireva.
\q1 
\v 7 Ipapo ndakati, “Ndiri pano hangu,
\q2 ndauya, zvakanyorwa mubhuku pamusoro pangu.
\q1 
\v 8 Ndinofarira kuita kuda kwenyu, imi Mwari wangu;
\q2 murayiro wenyu uri mukati momwoyo wangu.”
\b
\q1 
\v 9 Ndinoparidza kururama paungano huru;
\q2 handidziviri miromo yangu,
\q2 sokuziva kwenyu, imi Jehovha.
\q1 
\v 10 Handivanzi kururama kwenyu mumwoyo mangu;
\q2 ndinotaura nezvokutendeka kwenyu noruponeso rwenyu.
\q1 Handivanzi rudo rwenyu nechokwadi chenyu
\q2 paungano huru.
\b
\q1 
\v 11 Regai kundinyima ngoni dzenyu, imi Jehovha;
\q2 rudo rwenyu nechokwadi chenyu ngazvindidzivirire nguva dzose.
\q1 
\v 12 Nokuti matambudziko asingaverengeki akandikomberedza;
\q2 zvivi zvangu zvakandibata, uye handigoni kuona.
\q1 Zvakawanda kupfuura bvudzi romumusoro mangu,
\q2 uye mwoyo wangu waneta mukati mangu.
\b
\q1 
\v 13 Haiwa Jehovha, kundiponesa ngakukufadzei;
\q2 haiwa Jehovha, kurumidzai kundibatsira.
\q1 
\v 14 Vose vanotsvaka kutora upenyu hwangu
\q2 ngavanyadziswe uye vanyonganiswe;
\q1 vose vanoda kuparadzwa kwangu
\q2 ngavadzoserwe shure vanyadziswe.
\q1 
\v 15 Avo vose vanoti kwandiri, “Hekani waro! Hekani waro!”
\q2 ngavavhundutswe nokuda kwenyadzi dzavo.
\q1 
\v 16 Asi vose vanokutsvakai
\q2 ngavafare uye vafarisise mamuri;
\q1 avo vanoda ruponeso rwenyu ngavarambe vachiti,
\q2 “Jehovha ngaakudzwe!”
\b
\q1 
\v 17 Asi ndiri murombo nomushayiwi;
\q2 dai Ishe vandifungawo.
\q1 Ndimi mubatsiri wangu nomununuri wangu;
\q2 haiwa Mwari wangu, musanonoka henyu.
\c 41
\cl Pisarema 41
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Akaropafadzwa uyo ane hanya navasina simba;
\q2 Jehovha anomurwira panguva dzokutambudzika.
\q1 
\v 2 Jehovha achamudzivirira uye achachengetedza upenyu hwake;
\q2 achamuropafadza panyika
\q2 uye haangamuisi kuchido chavavengi vake.
\q1 
\v 3 Jehovha achamuraramisa panhoo yake yourwere
\q2 uye achamuponesa panhoo yake yourwere.
\b
\q1 
\v 4 Ini ndakati, “Haiwa Jehovha, ndinzwirei ngoni;
\q2 ndiporesei, nokuti ndakakutadzirai.”
\q1 
\v 5 Vavengi vangu vachindigodora vanoti,
\q2 “Achafa riniko uye zita rake rigoparara?”
\q1 
\v 6 Kana mumwe achiuya kuzondiona,
\q2 anotaura zvenhema, mwoyo uchiunganidza makuhwa;
\q2 ipapo anobuda ondozviparadzira kumwe.
\b
\q1 
\v 7 Vavengi vangu vose vanoita zevezeve pamwe chete pamusoro pangu;
\q2 vanondifungira zvakaipisisa, vachiti,
\q1 
\v 8 “Chirwere chakaipa chakamubata,
\q2 haachambomukizve panzvimbo paakarara.”
\q1 
\v 9 Kunyange neshamwari yangu yapedyo yandaivimba nayo,
\q2 yandaigovana zvokudya nayo,
\q2 yandisimudzira chitsitsinho chayo.
\b
\q1 
\v 10 Asi imi, iyemi Jehovha, mune tsitsi neni,
\q2 ndisimudzei, kuti ndivatsive.
\q1 
\v 11 Ndinoziva kuti munofadzwa neni,
\q2 nokuti muvengi wangu haandikundi.
\q1 
\v 12 Munonditsigira pakutendeka kwangu,
\q2 uye munondiisa pamberi penyu nokusingaperi.
\b
\b
\q1 
\v 13 Kurumbidzwa ngakuve kuna Jehovha, Mwari waIsraeri,
\q2 kubva pakusingaperi kusvikira nokusingaperi.
\qc Ameni naAmeni.
\c 42
\ms1 BHUKU 2
\mr Mapisarema 42–72
\cl Pisarema 42
\d Kumutungamiri wokuimba. Rwiyo rweMasikiri rwaVanakomana vaKora.
\q1 
\v 1 Senondo inodokwairira hova dzemvura,
\q2 saizvozvo mweya wangu unodokwairirai, imi Mwari.
\q1 
\v 2 Mweya wangu une nyota kuna Mwari, nyota yaMwari mupenyu.
\q2 Ndingaenda riniko kundosangana naMwari?
\q1 
\v 3 Misodzi yangu yanga iri zvokudya zvangu
\q2 masikati nousiku,
\q1 asi zuva rose vanhu vanoti kwandiri,
\q2 “Mwari wako aripiko?”
\q1 
\v 4 Ndinorangarira zvinhu izvi
\q2 pandinodurura mweya wangu,
\q1 mafambiro andaiita navazhinji
\q2 ndichitungamirira mudungwe wavanhu kuimba yaMwari,
\q1 nokupembera nomufaro uye nokuvonga
\q2 pakati pavazhinji pamutambo.
\b
\q1 
\v 5 Wakasuwireiko, nhai mweya wangu?
\q2 Unotambudzwa neiko mukati mangu?
\q1 Isa tariro yako muna Mwari,
\q2 nokuti ndichamurumbidzazve,
\q2 Muponesi wangu naMwari wangu.
\b
\q1 
\v 6 Mweya wangu wakaneta mukati mangu;
\q2 naizvozvo ndichakurangarirai
\q1 ndiri kunyika yeJorodhani,
\q2 pamatunhu akakwirira eHeremoni, kubva paGomo reMizari.
\q1 
\v 7 Pakadzika panodana pakadzika
\q2 mukutinhira kwamapopopo emvura;
\q1 mafungu enyu ose namafashamu
\q2 akapfuura napamusoro pangu.
\b
\q1 
\v 8 Masikati, Jehovha anorayira rudo rwake,
\q2 pausiku rwiyo rwake runeni,
\q2 munyengetero kuna Mwari woupenyu hwangu.
\b
\q1 
\v 9 Ndinoti kuna Mwari Dombo rangu,
\q2 “Mandikanganwireiko?
\q1 Ndinofambireiko ndichichema
\q2 ndakadzvinyirirwa nomuvengi?”
\q1 
\v 10 Mapfupa angu atambura nokurwadza kworufu,
\q2 sezvo vavengi vangu vachindizvidza
\q1 zuva rose vachiti kwandiri,
\q2 “Mwari wako aripiko?”
\b
\q1 
\v 11 Wakasuwireiko, nhai mweya wangu?
\q2 Unotambudzwa neiko mukati mangu?
\q1 Isa tariro yako muna Mwari,
\q2 nokuti ndichamurumbidzazve.
\q2 Muponesi wangu naMwari wangu.
\c 43
\cl Pisarema 43
\q1 
\v 1 Ndiruramisirei, imi Mwari,
\q2 uye mundireverere mhaka yangu parudzi rusina Mwari;
\q2 ndinunurei pavanhu vanonyengera nevakaipa.
\q1 
\v 2 Ndimi Mwari nhare yangu.
\q2 Mandirambireiko?
\q1 Ndinofambireiko pose ndichichema
\q2 ndichidzvinyirirwa navavengi?
\q1 
\v 3 Tumirai chiedza chenyu nechokwadi chenyu,
\q2 ngazvinditungamirire;
\q1 ngazvindisvitse kugomo renyu dzvene,
\q2 kunzvimbo yamunogara.
\q1 
\v 4 Ipapo ndichaenda kuaritari yaMwari,
\q2 kuna Mwari, iye mufaro wangu nomudikani wangu.
\q1 Ndichakurumbidzai nembira,
\q2 imi Mwari, Mwari wangu.
\b
\q1 
\v 5 Wakasuwireiko, nhai mweya wangu?
\q2 Unotambudzwa neiko mukati mangu?
\q1 Isa tariro yako muna Mwari,
\q2 nokuti ndichamurumbidzazve,
\q2 Muponesi wangu naMwari wangu.
\c 44
\cl Pisarema 44
\d Kumutungamiri wokuimba waVanakomana vaKora. Masikiri.
\q1 
\v 1 Haiwa Mwari, takanzwa nenzeve dzedu;
\q2 madzibaba edu akatiudza
\q1 zvamakaita pamazuva avo,
\q2 pamazuva ekare.
\q1 
\v 2 Noruoko rwenyu makadzinga ndudzi
\q2 uye mukasima madzibaba edu;
\q1 makapwanya marudzi
\q2 mukaita kuti madzibaba edu abudirire.
\q1 
\v 3 Havana kuzviwanira nyika nomunondo wavo,
\q2 uye ruoko rwavo haruna kuvakundisa;
\q1 rwakanga rwuri ruoko rwenyu rworudyi, irwo ruoko rwenyu,
\q2 nokupenya kwechiso chenyu, nokuti imi makavada.
\b
\q1 
\v 4 Ndimi Mambo wangu naMwari wangu,
\q2 anorayira kukunda kwaJakobho.
\q1 
\v 5 Kubudikidza nemi, tinosunda vavengi vedu shure;
\q2 kubudikidza nezita renyu, tinotsika vavengi vedu netsoka dzedu.
\q1 
\v 6 Handivimbi nouta hwangu,
\q2 munondo wangu haundivigiri kukunda;
\q1 
\v 7 asi imi munotipa kukunda pamusoro pavavengi vedu,
\q2 munonyadzisa vadzivisi vedu.
\q1 
\v 8 Tinozvirumbidza muna Mwari zuva rose,
\q2 uye ticharumbidza zita renyu nokusingaperi. \qs Sera \qs*
\b
\q1 
\v 9 Asi zvino matiramba uye matininipisa;
\q2 hamuchabudi nehondo dzedu.
\q1 
\v 10 Makaita kuti tidududze pamberi pavavengi vedu,
\q2 uye vadzivisi vedu vakatipamba.
\q1 
\v 11 Makatiramwira kumudyi samakwai
\q2 uye makatiparadzira pakati pendudzi.
\q1 
\v 12 Makatengesa vanhu venyu pasina,
\q2 hamuna kuwana kana chinhu pakuvatengesa.
\b
\q1 
\v 13 Makatiita chiseko kuvavakidzani vedu,
\q2 chinozvidzwa nechinosekwa chaavo vakatipoteredza.
\q1 
\v 14 Makatiita tsumo pakati pendudzi;
\q2 vanhu vanotidzungudzira misoro.
\q1 
\v 15 Kunyadziswa kwangu kuri pamberi pangu zuva rose,
\q2 uye chiso changu chafukidzwa nenyadzi
\q1 
\v 16 pakuseka kwaavo vanondizvidza nokundirwisa,
\q2 nokuda kwomuvengi, agarira kutsiva.
\b
\q1 
\v 17 Zvose izvi zvakaitika kwatiri
\q2 kunyange takanga tisina kukukanganwai,
\q2 kana kuva vasina kutendeka kusungano yenyu.
\q1 
\v 18 Mwoyo yedu yakanga isati yafuratira;
\q2 tsoka dzedu dzakanga dzisati dzatsauka panzira yenyu.
\q1 
\v 19 Asi makatipwanya mukatiita nzvimbo yamakava
\q2 uye mukatifukidza nerima guru.
\b
\q1 
\v 20 Dai takanga takanganwa zita raMwari wedu,
\q2 kana kutambanudzira maoko edu kuna mwari wavatorwa,
\q1 
\v 21 Mwari haaizviziva here,
\q2 sezvo achiziva zvakavanzika zvomwoyo?
\q1 
\v 22 Asi nokuda kwenyu takatarisana norufu zuva rose;
\q2 tinotorwa samakwai anobayiwa.
\b
\q1 
\v 23 Mukai, imi Ishe! Munovatireiko?
\q2 Zvisimudzei! Regai kutiramba nokusingaperi.
\q1 
\v 24 Ko, munovanzirei chiso chenyu
\q2 muchikanganwa kutambudzika nokudzvinyirirwa kwedu?
\b
\q1 
\v 25 Takawisirwa muguruva;
\q2 miviri yedu inonamatira pavhu.
\q1 
\v 26 Simukai mutibatsire;
\q2 tidzikinurei nokuda kworudo rwenyu rusingaperi.
\c 45
\cl Pisarema 45
\d Kumutungamiri wokuimba waVanakomana vaKora. Masikiri nomuimbirwo wa“Maruva aMahapa.” Rwiyo rwoMuchato.
\q1 
\v 1 Mwoyo wangu unobvongodzwa nedingindira rakanaka,
\q2 pandinodetembera mambo ndima dzangu;
\q2 rurimi rwangu chinyoreso chomunyori anogona.
\b
\q1 
\v 2 Imi makanakisisa pavanhu vose
\q2 uye miromo yenyu yakazadzwa nenyasha,
\q2 sezvo Mwari akakuropafadzai nokusingaperi.
\b
\q1 
\v 3 Sungai munondo wenyu parutivi, imi wamasimba,
\q2 zvishongedzei nokubwinya noumambo.
\q1 
\v 4 Paumambo hwenyu kwirai mukunde kwazvo,
\q2 makamirira chokwadi, kuzvininipisa nokururama;
\q2 ruoko rwenyu rworudyi ngaruratidze mabasa enyu anotyisa.
\q1 
\v 5 Miseve yenyu inopinza ngaibaye mwoyo yavavengi vamambo;
\q2 ndudzi ngadziputsikire pasi petsoka dzenyu.
\q1 
\v 6 Chigaro chenyu, imi Mwari, chichagara nokusingaperi-peri;
\q2 tsvimbo yokururamisira ichava tsvimbo youmambo hwenyu.
\q1 
\v 7 Imi munoda kururama uye munovenga zvakaipa;
\q2 naizvozvo Mwari, Mwari wenyu, akakuisai pamusoro peshamwari dzenyu
\q2 nokukuzodzai namafuta omufaro.
\q1 
\v 8 Nguo dzenyu dzose dzinonhuwirira mura, arosi nekasia,
\q2 zvinobva kumizinda yamadzimambo yakashongedzwa nenyanga dzenzou,
\q2 kurira kwehungiso kunokufadzai.
\q1 
\v 9 Vanasikana vamadzimambo vari pakati pavakadzi vanokudzwa;
\q2 kuruoko rwenyu rworudyi kuno mwenga akashongedzwa negoridhe reOfiri.
\b
\q1 
\v 10 Teerera, iwe mwanasikana, rangarira,
\q2 uye urereke nzeve yako: Kanganwa vanhu vako neimba yababa vako.
\q1 
\v 11 Mambo ayevedzwa norunako rwako;
\q2 mukudze, nokuti ndiye Ishe wako.
\q1 
\v 12 Mwanasikana weTire achauya nechipo,
\q2 vanhu vakapfuma vachatsvaka nyasha kwauri.
\b
\q1 
\v 13 Mwanasikana wamambo akanaka kwazvo mukati meimba yake; nguo yake yakarukirirwa negoridhe.
\q1 
\v 14 Akapfeka nguo dzakashongedzwa achaperekedzwa kuna mambo;
\q2 shamwari dzake idzo mhandara dzinomutevera
\q2 uye vanouyiswa kwamuri.
\q1 
\v 15 Vanoperekedzwa vachapinda nomufaro nokufarisisa;
\q2 vanopinda mumuzinda wamambo.
\b
\q1 
\v 16 Vanakomana venyu vachatsiva nzvimbo yamadzibaba enyu;
\q2 muchavaita machinda munyika yose.
\q1 
\v 17 Ndichaita kuti kurangarirwa kwenyu kurambe kuripo, kusvikira kuzvizvarwa zvose;
\q2 naizvozvo ndudzi dzichakurumbidzai nokusingaperi-peri.
\c 46
\cl Pisarema 46
\d Kumutungamiri wokuimba waVanakomana vaKora. Namaimbirwo earamoti. Rwiyo.
\q1 
\v 1 Mwari ndiye utiziro hwedu nesimba redu,
\q2 ndiye mubatsiri anogara aripo panguva yokutambudzika.
\q1 
\v 2 Naizvozvo hatizotyi, kunyange nyika ikashanduka,
\q2 uye makomo akawira mukatikati megungwa,
\q1 
\v 3 kunyange mvura yaro ikatinhira uye ikapupuma furo,
\q2 uye makomo akadengenyeswa namafungu aro. \qs Sera \qs*
\b
\q1 
\v 4 Pane rwizi rwuripo rune hova dzinofadza guta raMwari,
\q2 nzvimbo tsvene yeWokumusoro-soro.
\q1 
\v 5 Mwari ari mukati maro, haringawiri pasi;
\q2 Mwari acharibatsira panguva yemambakwedza.
\q1 
\v 6 Ndudzi dzinoita bope, umambo hunoondomoka;
\q2 anotaura nenzwi guru, nyika yonyongodeka.
\b
\q1 
\v 7 Jehovha Wamasimba Ose anesu;
\q2 Mwari waJakobho ndiye nhare yedu. \qs Sera \qs*
\b
\q1 
\v 8 Uyai muone mabasa aJehovha,
\q2 kuparadza kwaakaita panyika.
\q1 
\v 9 Anoita kuti hondo dzigume kusvikira kumagumo enyika;
\q2 anovhuna uta uye anovhuna-vhuna mapfumo,
\q2 anopisa nhoo nomoto.
\q1 
\v 10 “Mirai, muzive kuti ndini Mwari;
\q2 ndichakudzwa pakati pendudzi,
\q2 ndichasimudzirwa panyika.”
\b
\q1 
\v 11 Jehovha Wamasimba Ose anesu;
\q2 Mwari waJakobho ndiye nhare yedu. \qs Sera \qs*
\c 47
\cl Pisarema 47
\d Kumutungamiri wokuimba waVanakomana vaKora. Pisarema.
\q1 
\v 1 Uchirai maoko, imi vanhu vose;
\q2 pururudzai kuna Mwari nokudanidzira kwomufaro.
\b
\q1 
\v 2 Jehovha Wokumusoro-soro anotyisa sei,
\q2 iye Mambo mukuru pamusoro penyika yose!
\q1 
\v 3 Akaisa ndudzi dzavanhu pasi pedu,
\q2 marudzi pasi petsoka dzedu.
\q1 
\v 4 Akatitsaurira nhaka yedu,
\q2 iyo pfuma yaJakobho, waakada. \qs Sera \qs*
\b
\q1 
\v 5 Mwari akwidza kumusoro pakati pokudanidzira kwomufaro,
\q2 Jehovha pakati pokurira kwehwamanda.
\q1 
\v 6 Imbirai Mwari nziyo dzokurumbidza, murumbidzei nenziyo.
\q2 Imbirai Mambo wedu nziyo dzokurumbidza, murumbidzei nenziyo.
\b
\q1 
\v 7 Nokuti Mwari ndiye Mambo wenyika yose;
\q2 muimbirei pisarema rokurumbidza.
\q1 
\v 8 Mwari anotonga pamusoro pendudzi dzose;
\q2 Mwari agere pamusoro pechigaro chake chitsvene.
\q1 
\v 9 Makurukota amarudzi aungana
\q2 savanhu vaMwari waAbhurahama,
\q1 nokuti madzimambo enyika ndeaMwari;
\q2 iye anokudzwa zvikuru kwazvo.
\c 48
\cl Pisarema 48
\d Rwiyo. Pisarema raVanakomana vaKora.
\q1 
\v 1 Jehovha mukuru, uye anofanira kurumbidzwa kwazvo,
\q2 muguta raMwari wedu, mugomo rake dzvene.
\b
\q1 
\v 2 Rakanaka pakukwirira kwaro, mufaro wenyika yose.
\q2 Sokumusoro-soro kweZafoni,
\q1 ndizvo zvakaita Gomo reZioni,
\q2 guta raMambo Mukuru.
\q1 
\v 3 Mwari ari munhare dzaro;
\q2 akazviratidza kwariri kuti ndiye nharirire yaro.
\b
\q1 
\v 4 Madzimambo akati abatanidza mauto,
\q2 vakati vafamba pamwe chete kundorwa,
\q1 
\v 5 vakariona vakashamiswa;
\q2 vakatiza nokutya.
\q1 
\v 6 Vakabatwa nokudedera ipapo,
\q2 nokurwadziwa sekwomukadzi osununguka.
\q1 
\v 7 Makavaparadza sezvakaitwa zvikepe zveTashishi,
\q2 zvakaputswa-putswa nemhepo yokumabvazuva.
\b
\q1 
\v 8 Sezvatakanzwa, ndizvo zvataona,
\q2 muguta raJehovha Wamasimba Ose,
\q1 muguta raMwari wedu:
\q2 Mwari anorisimbisa nokusingaperi. \qs Sera \qs*
\b
\q1 
\v 9 Tiri mukati metemberi yenyu, imi Mwari,
\q2 tinofungisisa nezvorudo rwenyu rusingaperi.
\q1 
\v 10 Sezvakaita zita renyu, imi Mwari,
\q2 kurumbidzwa kwenyu kunosvika kumagumo enyika;
\q2 ruoko rwenyu rworudyi ruzere nokururama.
\q1 
\v 11 Gomo reZioni rinofarisisa,
\q2 misha yeJudha inofara
\q2 nokuda kwokutonga kwenyu.
\b
\q1 
\v 12 Famba-fambai muZioni, ripoteredzei,
\q2 verengai shongwe dzaro,
\q1 
\v 13 fungisisai zvakanaka nezvamasvingo aro,
\q2 cherechedzai nhare dzaro,
\q2 kuti mugotaura nezvazvo kuchizvarwa chinotevera.
\b
\q1 
\v 14 Nokuti Mwari uyu ndiye Mwari wedu nokusingaperi-peri;
\q2 iye achava muperekedzi wedu kusvikira kumagumo.
\c 49
\cl Pisarema 49
\d Kumutungamiri wokuimba, waVanakomana vaKora. Pisarema.
\q1 
\v 1 Inzwai izvi, imi vanhu mose;
\q2 teererai imi mose mugere panyika,
\q1 
\v 2 vapasi navapamusoro,
\q2 vapfumi navarombo pamwe chete.
\q1 
\v 3 Muromo wangu uchataura nouchenjeri;
\q2 kutaura kunobva pamwoyo wangu kuchapa kunzwisisa.
\q1 
\v 4 Ndicharerekera nzeve yangu kuchirahwe;
\q2 nembira ndichadudzira shoko rangu rakavanzika.
\b
\q1 
\v 5 Ndinotyireiko kana mazuva akaipa achiuya,
\q2 kana vanyengeri vakaipa vandikomberedza,
\q1 
\v 6 vaya vanovimba nepfuma yavo
\q2 vanozvikudza nepfuma yavo zhinji?
\q1 
\v 7 Hakuna munhu angadzikinura upenyu hwomumwe
\q2 kana kupa Mwari rudzikinuro rwake,
\q1 
\v 8 rudzikinuro rwoupenyu runokosha,
\q2 hakuna muripo unoringana nahwo,
\q1 
\v 9 kuti ararame nokusingaperi
\q2 uye kuti asaona kuora.
\b
\q1 
\v 10 Nokuti vose vanogona kuona kuti vanhu vakachenjera vanofa;
\q2 mapenzi navasina pfungwa zvimwe chetezvo vanofa,
\q2 uye vanosiyira vamwe pfuma yavo.
\q1 
\v 11 Marinda avo achagara ari dzimba dzavo nokusingaperi,
\q2 nougaro hwavo kusvikira kuzvizvarwa zvisingaperi,
\q2 kunyange vakanga vakapa nyika mazita avo.
\b
\q1 
\v 12 Asi munhu, kunyange ane pfuma yake, haagari;
\q2 akafanana nemhuka dzinofa.
\b
\q1 
\v 13 Ndiwo magumo aivavo vanovimba nezvavanoita,
\q2 namagumo avateveri vavo, vanotenda zvavanotaura. \qs Sera \qs*
\q1 
\v 14 Samakwai vakatarirwa kuenda kuguva,
\q2 uye rufu ruchavadya.
\q1 Vakarurama vachavatonga mangwanani;
\q2 chimiro chavo chichaora murinda,
\q2 kure nedzimba dzavo dzoumambo.
\q1 
\v 15 Asi Mwari achadzikinura upenyu hwangu kubva muguva,
\q2 zvirokwazvo achanditora iye. \qs Sera \qs*
\b
\q1 
\v 16 Usanyanya kutya kana munhu apfuma,
\q2 kana kubwinya kweimba yake kwawedzerwa;
\q1 
\v 17 nokuti haana chaachatora paanofa;
\q2 kubwinya kwake hakungaburukiri naye murinda.
\q1 
\v 18 Kunyange paairarama aizviti akaropafadzwa,
\q2 uye vanhu vachirumbidza munhu paanobudirira,
\q1 
\v 19 achabatana norudzi rwamadzibaba ake,
\q2 vasingazoonizve chiedza choupenyu.
\b
\q1 
\v 20 Munhu ane pfuma zhinji asinganzwisisi
\q2 akaita semhuka dzinofa.
\c 50
\cl Pisarema 50
\d Pisarema raAsafi.
\q1 
\v 1 Iye Wamasimba, Mwari, Jehovha,
\q2 anotaura uye anodana nyika
\q2 kubva pakubuda kwezuva kusvikira kwarinovirira.
\q1 
\v 2 Kubva kuZioni, rakakwana parunako,
\q2 Mwari anopenya.
\q1 
\v 3 Mwari wedu anouya uye haanganyarari;
\q2 moto unoparadza pamberi pake,
\q2 uye dutu rine hasha rakamupoteredza.
\q1 
\v 4 Anodana matenga kumusoro,
\q2 uye nenyika, kuti atonge vanhu vake achiti:
\q1 
\v 5 “Ndiunganidzirei vatsvene vangu,
\q2 vakaita sungano neni nechibayiro.”
\q1 
\v 6 Uye matenga anoparidza kururama kwake,
\q2 nokuti Mwari amene ndiye mutongi. \qs Sera \qs*
\b
\q1 
\v 7 “Inzwai, imi vanhu vangu, uye ndichataura,
\q2 imi Israeri, uye ndichapupura pamusoro penyu:
\q2 Ndini Mwari, Mwari wenyu.
\q1 
\v 8 Handikutukei nokuda kwezvibayiro zvenyu,
\q2 kana zvipiriso zvenyu zvinopiswa, zvinogara zviri pamberi pangu.
\q1 
\v 9 Handisi kuda hando inobva mudanga rako,
\q2 kana mbudzi inobva muzvirugu zvako,
\q1 
\v 10 nokuti mhuka dzose dzesango ndedzangu,
\q2 nemombe pamakomo chiuru.
\q1 
\v 11 Ndinoziva shiri dzose dziri mumakomo,
\q2 uye zvisikwa zvose zvesango ndezvangu.
\q1 
\v 12 Kana dai ndaiva nenzara, handaikuudza iwe,
\q2 nokuti nyika ndeyangu, nezvose zviri mairi.
\q1 
\v 13 Ko, ndinodya nyama yehando
\q2 kana kunwa ropa rembudzi here?
\b
\q1 
\v 14 “Bayirai zvibayiro zvokuvonga kuna Mwari,
\q2 zadzisai zvamakapikira Wokumusoro-soro,
\q1 
\v 15 uye mudane kwandiri pazuva rokutambudzika;
\q2 ndichakurwirai, uye imi muchandikudza.”
\p 
\v 16 Asi kuna vakaipa, Mwari anoti:
\q1 “Ko, une mvumo ipiko iwe yokuti ududzire mutemo wangu,
\q2 kana kuisa sungano yangu pamiromo yako?
\q1 
\v 17 Unovenga kurayira kwangu,
\q2 uye unorasira mashoko angu shure kwako.
\q1 
\v 18 Paunoona mbavha, unowadzana nayo;
\q2 unogoverana nemhombwe mugove wako.
\q1 
\v 19 Unoshandisa muromo wako kuita zvakaipa,
\q2 uye unorovedza rurimi rwako kukunyengera.
\q1 
\v 20 Unogara uchipomera hama yako
\q2 uye unoitira mwanakomana wamai vako makuhwa.
\q1 
\v 21 Zvinhu izvi wakazviita ini ndikaramba ndinyerere;
\q2 wakafunga kuti ndakafanana newe.
\q1 Asi ndichakutsiura
\q2 uye ndichaisa mhosva iyi pamberi pako.
\b
\q1 
\v 22 “Fungai izvi, imi vanokanganwa Mwari,
\q2 kuti ndirege kukubvambura-bvamburai mukashaya angakununurai:
\q1 
\v 23 Munhu anobayira chibayiro chokuvonga ndiye anondikudza,
\q2 uye anogadzira nzira
\q2 kuitira kuti ndimuratidze ruponeso rwaMwari.”
\c 51
\cl Pisarema 51
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi. Panguva yakauya muprofita Natani kwaari shure kwokuita upombwe kwaDhavhidhi naBhatishebha.
\q1 
\v 1 Ndinzwirei tsitsi, imi Mwari,
\q2 nokuda kworudo rwenyu rusingaperi;
\q1 dzimai kudarika kwangu
\q2 nokuda kwengoni dzenyu huru.
\q1 
\v 2 Shambidzai zvakaipa zvangu zvose
\q2 uye mundinatse kubva pachivi changu.
\b
\q1 
\v 3 Nokuti ndinoziva kudarika kwangu,
\q2 uye chivi changu chinogara chiri pamberi pangu.
\q1 
\v 4 Ndakakutadzirai imi, iyemi moga
\q2 nokuita chinhu chakaipa pamberi penyu,
\q1 kuti munzi makarurama pamunotaura
\q2 uye musapomerwa mhosva pakutonga kwenyu.
\q1 
\v 5 Zvirokwazvo ndakanga ndiri mutadzi pandakaberekwa,
\q2 ndiri mutadzi kubva pandakaumbwa mudumbu ramai vangu.
\q1 
\v 6 Zvirokwazvo imi munoda chokwadi pakati pomwoyo;
\q2 munondidzidzisa uchenjeri panzvimbo yomukatikati.
\b
\q1 
\v 7 Ndinatsei nehisopi, ipapo ndichachena;
\q2 ndishambidzei, ipapo ndichachena sechando.
\q1 
\v 8 Ndiitei kuti ndinzwe mufaro nokufarisisa;
\q2 itai kuti mapfupa amakapwanya afare.
\q1 
\v 9 Vanzai chiso chenyu pazvivi zvangu
\q2 uye mudzime zvakaipa zvangu zvose.
\b
\q1 
\v 10 Sikai mukati mangu mwoyo wakachena, imi Mwari,
\q2 uye muvandudze mweya wakarurama mukati mangu.
\q1 
\v 11 Regai kundirasa pamberi penyu
\q2 kana kubvisa Mweya wenyu Mutsvene kwandiri.
\q1 
\v 12 Dzoreraizve kwandiri mufaro woruponeso rwenyu,
\q2 uye mundipe mweya unoda, kuti undiraramise.
\b
\q1 
\v 13 Ipapo ndichadzidzisa vadariki nzira dzenyu,
\q2 uye vatadzi vachatendeukira kwamuri.
\q1 
\v 14 Ndiponesei pamhosva yeropa, imi Mwari,
\q2 iyemi Mwari anondiponesa,
\q2 ipapo rurimi rwangu ruchaimba zvokururama kwenyu.
\q1 
\v 15 Haiwa Ishe, zarurai miromo yangu,
\q2 ipapo muromo wangu uchaparidza rumbidzo yenyu.
\q1 
\v 16 Hamufariri chibayiro, ndingadai ndakuvigirai,
\q2 imi hamufariri zvipiriso zvinopiswa.
\q1 
\v 17 Zvibayiro zvaMwari mweya wakaputsika;
\q2 mwoyo wakaputsika nowakapwanyika,
\q2 imi Mwari hamuzoushori.
\b
\q1 
\v 18 Pamufaro wenyu wakanaka, itai kuti Zioni ribudirire;
\q2 muvake masvingo eJerusarema.
\q1 
\v 19 Ipapo pachava nezvibayiro zvakarurama,
\q2 zvipiriso zvinopiswa zvakazara zvinokufadzai;
\q2 ipapo hando dzichabayirwa paaritari yenyu.
\c 52
\cl Pisarema 52
\d Kumutungamiri wokuimba. Rwiyo rweMasikiri rwaDhavhidhi. Dhoegi muEdhomu paakanga aenda kuna Sauro akamuudza kuti: “Dhavhidhi aenda kumba kwaAhimereki.”
\q1 
\v 1 Ko, unozvikudzirei pane zvakaipa, iwe murume wesimba?
\q2 Unozvikudzirei zuva rose,
\q2 iyewe unonyadzisa pamberi paMwari?
\q1 
\v 2 Rurimi rwako runofarira zvokuparadza;
\q2 rwakaita sechisvo chakarodzwa,
\q2 iyewe unogara uchingonyengera.
\q1 
\v 3 Unoda zvakaipa pachinzvimbo chezvakanaka,
\q2 kureva nhema pachinzvimbo chokutaura chokwadi. \qs Sera \qs*
\q1 
\v 4 Unoda shoko rimwe nerimwe rinoparadza,
\q2 iwe rurimi runonyengera!
\b
\q1 
\v 5 Zvirokwazvo Mwari achakuburutsira kukuparadzwa kusingaperi:
\q2 Achakubvuta agokubvisa mutende rako;
\q2 achakudzura kubva munyika yavapenyu. \qs Sera \qs*
\q1 
\v 6 Vakarurama vachazviona uye vachatya;
\q2 vachamuseka vachiti,
\q1 
\v 7 “Houno zvino munhu asina kuita Mwari nhare yake,
\q2 asi aivimba nepfuma yake zhinji,
\q2 uye aisimba nokuparadza vamwe!”
\b
\q1 
\v 8 Asi ini ndakaita somuti
\q2 womuorivhi unokura zvakanaka mumba maMwari;
\q1 ndinovimba norudo rusingaperi rwaMwari,
\q2 nokusingaperi-peri.
\q1 
\v 9 Ndichakurumbidzai, nokusingaperi nokuda kwezvamakaita;
\q2 ndichavimba nezita renyu, nokuti zita renyu rakanaka.
\q2 Ndichakurumbidzai pamberi pavatsvene venyu.
\c 53
\cl Pisarema 53
\d Kumutungamiri wokuimba. Namaimbirwo eMaharati. Rwiyo rweMasikiri rwaDhavhidhi.
\q1 
\v 1 Benzi rinoti mumwoyo maro,
\q2 “Mwari hakuna.”
\q1 Vakaora, uye nzira dzavo dzakaipa;
\q2 hakuna anoita zvakanaka.
\b
\q1 
\v 2 Mwari anotarira ari kudenga,
\q2 pavanakomana vavanhu,
\q1 kuti aone kana aripo anonzwisisa,
\q2 kana aripo anotsvaka Mwari.
\q1 
\v 3 Mumwe nomumwe wavo akadzokera shure,
\q2 vakava vakaora pamwe chete;
\q1 hakuna anoita zvakanaka,
\q2 kunyange nomumwe.
\b
\q1 
\v 4 Ko, vaiti vezvakaipa havangadzidzi here,
\q2 vaya vanodya vanhu vangu savanhu vanodya chingwa,
\q2 uye vasingadani kuna Mwari?
\q1 
\v 5 Havo, vakazadzwa nokutya,
\q2 ipo pasina chavangatya.
\q1 Mwari akaparadzira mapfupa avanhu vaikurwisa;
\q2 makavanyadzisa, nokuti Mwari akavazvidza.
\b
\q1 
\v 6 Haiwa, dai ruponeso rwaIsraeri rwabuda kubva muZioni;
\q2 Mwari paachadzosera nhaka yavanhu vake;
\q2 Jakobho ngaafarisise uye Israeri ngaafarisise!
\c 54
\cl Pisarema 54
\d Kumutungamiri wokuimba nemitengeranwa ine hungiso. Rwiyo rweMasikiri rwaDhavhidhi. VaZefati pavakaenda kuna Sauro kundoti, “Ko, Dhavhidhi haana kuvanda pakati pedu here?”
\q1 
\v 1 Ndiponesei, imi Mwari, nezita renyu;
\q2 ndiruramisirei nesimba renyu.
\q1 
\v 2 Inzwai munyengetero wangu, imi Mwari;
\q2 teererai kumashoko omuromo wangu.
\b
\q1 
\v 3 Vatorwa vanondirwisa;
\q2 vanhu vane utsinye vanotsvaka upenyu hwangu,
\q2 vanhu vasingazivi Mwari. \qs Sera \qs*
\b
\q1 
\v 4 Zvirokwazvo Mwari ndiye mubatsiri wangu;
\q2 ishe ndiye anonditsigira.
\b
\q1 
\v 5 Zvakaipa ngazvimonere pane avo vanondireva;
\q2 muvaparadze pakutendeka kwenyu.
\b
\q1 
\v 6 Ndichakubayirai chipiriso chokungopa;
\q2 ndicharumbidza zita renyu, imi Jehovha,
\q2 nokuti rakanaka.
\q1 
\v 7 Nokuti akandirwira pamatambudziko angu ose,
\q2 uye mukukunda, meso angu akatarisa vavengi vangu.
\c 55
\cl Pisarema 55
\d Kumutungamiri wokuimba nemitengeranwa ine hungiso. Rwiyo rweMasikiri rwaDhavhidhi.
\q1 
\v 1 Rerekerai nzeve yenyu kumunyengetero wangu, imi Mwari;
\q2 regai kushaya hanya nokukumbira kwangu;
\q2 
\v 2 ndinzwei, uye ndipindureiwo.
\q1 Pfungwa dzangu dzinondinetsa uye ndiri kushushikana,
\q2 
\v 3 pandinonzwa inzwi romuvengi wangu,
\q1 pandinodzvokorwa navakaipa; nokuti vanodururira matambudziko pamusoro pangu,
\q2 uye vanondituka mukutsamwa kwavo.
\b
\q1 
\v 4 Mwoyo wangu unorwadziwa mukati mangu;
\q2 kutyisa kworufu kunondiwira.
\q1 
\v 5 Kutya nokudedera zvakandibata;
\q2 kutya kukuru kwakandifukidza.
\q1 
\v 6 Ini ndakati, “Haiwa, dai ndina mapapiro enjiva!
\q2 Ndaibhururukira kure ndikandozorora hangu,
\q1 
\v 7 ndaitizira kure kwazvo,
\q2 ndikandogara mugwenga; \qs Sera \qs*
\q1 
\v 8 ndaikurumidza kundovanda panzvimbo yangu,
\q2 kure nemafungu nedutu.”
\b
\q1 
\v 9 Nyonganisai vakaipa, imi Ishe, kanganisai mutauro wavo,
\q2 nokuti ndinoona mhirizhonga nokurwa muguta.
\q1 
\v 10 Masikati nousiku vanopoterera masvingo aro chinyararire;
\q2 utsinye nokumanikidza zviri mukati maro.
\q1 
\v 11 Masimba okuparadza azere muguta;
\q2 kutyisidzira nenhema hazvibvi munzira dzaro.
\b
\q1 
\v 12 Dai ndatukwa nomuvengi,
\q2 ndaigona kushinga hangu;
\q1 dai muvengi aindimukira,
\q2 ndaigona kumuvanda hangu.
\q1 
\v 13 Asi ndiwe, munhu akaita seni,
\q2 mumwe wangu, shamwari yangu yapedyo,
\q1 
\v 14 yandaimbofarira kuwadzana nayo
\q2 pataifamba navazhinji mumba maMwari.
\b
\q1 
\v 15 Rufu ngaruwane vavengi vangu vasingafungiri;
\q2 ngavaburukire muguva vari vapenyu,
\q2 nokuti kuipa kwakawana pokugara pakati pavo.
\b
\q1 
\v 16 Asi ini ndinodana kuna Mwari,
\q2 uye Jehovha anondiponesa.
\q1 
\v 17 Madekwana, mangwanani namasikati
\q2 ndinochema mukushushikana,
\q2 uye iye anonzwa inzwi rangu.
\q1 
\v 18 Anondidzikinura ndisina kukuvara
\q2 kubva pahondo inondirwisa,
\q2 kunyange zvazvo vazhinji vachindipikisa.
\q1 
\v 19 Mwari, agere pachigaro choushe nokusingaperi,
\q2 achavanzwa agovaninipisa, \qs Sera \qs*
\q1 ivo vanhu vasingamboshanduri nzira dzavo,
\q2 uye vasingatyi Mwari.
\b
\q1 
\v 20 Mumwe wangu anorova shamwari dzake;
\q2 anoputsa sungano yake.
\q1 
\v 21 Mutauro wake unotsvedzerera samafuta,
\q2 asi kurwa kuri mumwoyo make;
\q1 mashoko ake anopfavisa kukunda mafuta,
\q2 asi minondo yakavhomorwa.
\b
\q1 
\v 22 Kanda kufunganya kwako pana Jehovha
\q2 uye iye achakusimbisa;
\q2 haazombotenderi vakarurama kuti vawire pasi.
\q1 
\v 23 Asi imi, iyemi Mwari, muchaburutsira vakaipa pasi
\q2 mugomba rokuora;
\q1 vanhu vanokarira ropa navanyengeri
\q2 havangararami hafu yamazuva avo.
\b
\q1 Asi kana ndirini, ndinovimba nemi.
\c 56
\cl Pisarema 56
\d Kumutungamiri wokuimba. Namaririro e“Njiva paMiouki iri kure.” Pisarema raDhavhidhi. Rwiyo rweMikitami. Paakabatwa navaFiristia paGati.
\q1 
\v 1 Ndinzwirei ngoni, imi Mwari, nokuti vanhu vanondidzinganisa nehasha;
\q2 zuva rose vanorwa neni.
\q1 
\v 2 Vavengi vangu vanondidzinganisa zuva rose;
\q2 vazhinji vanorwa neni mukuzvikudza kwavo.
\b
\q1 
\v 3 Pandinenge ndotya,
\q2 ndichavimba nemi.
\q1 
\v 4 Muna Mwari, iye ane shoko randinorumbidza,
\q2 muna Mwari ndinovimba; handichazotyi.
\q2 Ko, munhu anofa angandiitei?
\b
\q1 
\v 5 Zuva rose vanomonyorora mashoko angu;
\q2 vanogara vachirangana kundikuvadza.
\q1 
\v 6 Vanorangana, vanovandira,
\q2 vanocherechedza mafambiro angu,
\q2 vachishuva kundiuraya.
\b
\q1 
\v 7 Ngavasapunyuka savasina mhaka;
\q2 koromorerai ndudzi pasi mukutsamwa kwenyu imi Mwari.
\q1 
\v 8 Nyorai kuchema kwangu;
\q2 isai misodzi yangu parugwaro rwenyu,
\q2 ko, hazvina kuiswa muzvinyorwa zvenyu here?
\b
\q1 
\v 9 Ipapo vavengi vangu vachadzokera shure
\q2 pandinodanidzira kuti ndibatsirwe.
\q2 Nechinhu ichi, ndichaziva kuti Mwari ari kurutivi rwangu.
\q1 
\v 10 Muna Mwari, iye ane shoko randinorumbidza,
\q2 muna Jehovha, ane shoko randinorumbidza,
\q1 
\v 11 muna Mwari ndinovimba; handichazotyi chinhu.
\q2 Ko, munhu angandiitei?
\b
\q1 
\v 12 Ndinosungwa nemhiko kwamuri, imi Mwari;
\q2 ndichakuvigirai zvipo zvangu zvokuvonga.
\q1 
\v 13 Nokuti makandirwira parufu,
\q2 uye netsoka dzangu pakugumburwa,
\q1 kuti ndifambe pamberi penyu
\q2 muchiedza choupenyu.
\c 57
\cl Pisarema 57
\d Kumutungamiri wokuimba namaimbiro okuti, “Musaparadza.” Pisarema raDhavhidhi. Rwiyo rweMikitami. Paakatiza kubva kuna Sauro akapinda mubako.
\q1 
\v 1 Ndinzwirei ngoni, imi Mwari, ndinzwirei ngoni,
\q2 nokuti mweya wangu unovanda mamuri.
\q1 Ndichavanda mumumvuri wamapapiro enyu,
\q2 kusvikira njodzi yapfuura.
\b
\q1 
\v 2 Ndinodanidzira kuna Mwari Wokumusoro-soro,
\q2 kuna Mwari anozadzisa chinangwa chake kwandiri.
\q1 
\v 3 Anotuma kubva kudenga agondiponesa,
\q2 achituka vaya vanondidzingirira nehasha; \qs Sera \qs*
\q2 Mwari anotumira rudo rwake nokutendeka kwake.
\b
\q1 
\v 4 Ndiri pakati peshumba;
\q2 ndinovata pakati pemhuka dzinokara,
\q1 ivo vanhu vane meno amapfumo nemiseve,
\q2 vane ndimi dzinopinza seminondo.
\b
\q1 
\v 5 Kudzwai, imi Mwari, pamusoro pamatenga;
\q2 kubwinya kwenyu ngakuve pamusoro penyika yose. \qs Sera \qs*
\b
\q1 
\v 6 Vanowaririra tsoka dzangu mimbure,
\q2 ndakakotamiswa pasi nenhamo.
\q1 Vakachera gomba panzira yangu,
\q2 asi vakawiramo vamene. \qs Sera \qs*
\b
\q1 
\v 7 Mwoyo wangu wakasimba, Mwari wangu,
\q2 mwoyo wangu wakasimba;
\q2 ndichaimba uye ndichaimba rwiyo.
\q1 
\v 8 Chimuka iwe mweya wangu!
\q2 Mukai imi mutengeranwa nembira!
\q2 Ini ndichamutsa mambakwedza.
\b
\q1 
\v 9 Ndichakurumbidzai imi, iyemi Ishe, pakati pendudzi;
\q2 ndichakuimbirai pakati pamarudzi.
\q1 
\v 10 Nokuti rudo rwenyu rukuru, runosvika kudenga denga;
\q2 kutendeka kwenyu kunosvika kumusoro.
\b
\q1 
\v 11 Kudzwai, imi Mwari, pamusoro pamatenga;
\q2 kubwinya kwenyu ngakuve pamusoro penyika yose.
\c 58
\cl Pisarema 58
\d Kumutungamiri wokuimba namaimbiro okuti, “Musaparadza.” Pisarema raDhavhidhi. Rwiyo rweMikitami.
\q1 
\v 1 Ko, imi vatongi munotaura mukururama here?
\q2 Munotonga pakati pavanhu nokururamisira here?
\q1 
\v 2 Kwete, munofunga kusaruramisira mumwoyo menyu,
\q2 uye maoko enyu anomanikidza panyika.
\b
\q1 
\v 3 Kunyange kubvira pakuberekwa, vakaipa vanofamba mukutsauka;
\q2 kubva mudumbu ramai, vakaipa uye vanoreva nhema.
\q1 
\v 4 Uturu hwavo hwakaita souturu hwenyoka,
\q2 vakafanana nemhakure yadzivira nzeve dzayo,
\q1 
\v 5 isingateereri maimbiro enʼanga
\q2 kunyange zvazvo achiimba nouchenjeri hukuru.
\b
\q1 
\v 6 Vhunai mazino mumiromo yavo, imi Mwari;
\q2 bvisai, imi Jehovha, mazino marefu eshumba!
\q1 
\v 7 Ngavatsakatike semvura yapera kuerera;
\q2 pavanowembura uta, miseve yavo ngaigomare.
\q1 
\v 8 Vafanane nehozhwa inonyakatika painofamba,
\q2 kufanana negavamwedzi, ngavarege kuona zuva.
\b
\q1 
\v 9 Hari dzenyu dzisati dzanzwa kupisa kweminzwa pamoto,
\q2 ingava minyoro kana yakaoma, vakaipa vachakukurwa.
\q1 
\v 10 Vakarurama vachafara pavachatsivirwa,
\q2 pavachashambidza tsoka dzavo muropa ravakaipa.
\q1 
\v 11 Ipapo vanhu vachati,
\q2 “Zvirokwazvo vakarurama vachiri kungowana mubayiro;
\q2 zvirokwazvo Mwari ariko anotonga nyika.”
\c 59
\cl Pisarema 59
\d Kumutungamiri wokuimba namaimbiro anoti, “Musaparadza.” Pisarema raDhavhidhi. Rwiyo rweMikitami. Sauro paakanga atuma varume kundorinda imba yaDhavhidhi kuti amuuraye.
\q1 
\v 1 Ndirwirei pavavengi vangu, imi Mwari;
\q2 Ndidzivirirei kubva kuna avo vanondimukira.
\q1 
\v 2 Ndirwirei pavaiti vezvakaipa,
\q2 uye mundiponese pavanhu vanokarira kuteura ropa.
\b
\q1 
\v 3 Tarirai kundivandira kwavakaita!
\q2 Vanhu vanotyisa vanondirangana
\q2 pasina mhosva yandapara kana chivi, nhai Jehovha.
\q1 
\v 4 Handina chandakakanganisa, asi ivo vagadzirira kundirwisa.
\q2 Simukai mundibatsire; tarirai dambudziko rangu!
\q1 
\v 5 Haiwa Jehovha, Mwari Wamasimba Ose, Mwari waIsraeri,
\q2 mukai murange ndudzi dzose;
\q2 musanzwira ngoni vakaipa navapanduki. \qs Sera \qs*
\b
\q1 
\v 6 Vanodzoka madekwana,
\q2 vachihonʼa sembwa,
\q2 uye vachinyahwaira muguta.
\q1 
\v 7 Onai zvavanorutsa mumiromo yavo:
\q2 vanorutsa minondo kubva pamiromo yavo,
\q2 uye vanoti, “Ndiani angatinzwa?”
\q1 
\v 8 Asi imi, iyemi Jehovha, munovaseka;
\q2 munodadira ndudzi dzose.
\b
\q1 
\v 9 Haiwa imi simba rangu, ndinokurindirai;
\q2 imi, iyemi Mwari, ndimi nhare yangu,
\v 10 Mwari anondida
\b
\q1 achanditungamirira
\q2 uye achanditendera kuti ndifare pamusoro pavanondireva.
\q1 
\v 11 Asi musavauraya, imi Ishe nhoo yedu,
\q2 zvimwe vanhu vangu vangakanganwa.
\q1 Musimba renyu itai kuti vadzungaire,
\q2 uye muvaderedze.
\q1 
\v 12 Nokuda kwezvivi zvemiromo yavo,
\q2 nokuda kwamashoko emiromo yavo,
\q2 ngavabatwe pakuzvikudza kwavo.
\q1 Nokuda kwokutuka nenhema dzavanotaura,
\q2 
\v 13 vaparadzei nehasha dzenyu,
\q2 vaparadzei kusvikira vapera.
\q1 Ipapo zvichazivikanwa kumigumo yenyika
\q2 kuti Mwari anotonga pamusoro paJakobho. \qs Sera \qs*
\b
\q1 
\v 14 Vanodzoka madekwana,
\q2 vachihonʼa sembwa,
\q2 uye vachinyahwaira muguta.
\q1 
\v 15 Vanodzungaira vachitsvaka zvokudya,
\q2 uye vanohuhudza kana vasina kuguta.
\q1 
\v 16 Asi ini ndichaimba nezvesimba renyu,
\q2 ndichaimba nezvorudo rwenyu mangwanani;
\q1 nokuti imi muri nhare yangu,
\q2 utiziro hwangu panguva dzokutambudzika.
\b
\q1 
\v 17 Haiwa imi simba rangu, ndinokuimbirai nziyo dzokukurumbidzai;
\q2 imi, Mwari, ndimi nhare yangu, Mwari anondida.
\c 60
\cl Pisarema 60
\d Kumutungamiri wokuimba namaimbirwo e“Ruva reMahapa reSungano.” Rwiyo rweMikitami rwaDhavhidhi. Rwokudzidzisa. Paakarwa neAramu Naharaimu neAramu Zobha, uye panguva yakadzoka Joabhu akaparadza zviuru gumi nezviviri zvavaEdhomu muMupata woMunyu.
\q1 
\v 1 Makatiramba, imi Mwari, uye mukatirwisa;
\q2 makanga makatsamwa, zvino tidzorei henyu!
\q1 
\v 2 Makazungunusa nyika mukaitsemura napakati;
\q2 gadzirai henyu mitswe yayo, nokuti iri kudengenyeka.
\q1 
\v 3 Makaratidza vanhu venyu nguva dzakaoma;
\q2 makatipa waini inotidzedzeresa.
\b
\q1 
\v 4 Asi kuna vanokutyai, makasimudza mureza
\q2 kuti urege kupfaranyurwa neuta. \qs Sera \qs*
\b
\q1 
\v 5 Tiponesei uye tibatsirei noruoko rwenyu rworudyi,
\q2 kuti avo vamunoda varwirwe.
\q1 
\v 6 Mwari akataura ari muimba yake tsvene achiti:
\q2 “Ndichaganhura Shekemu nesimba
\q2 uye ndichayera Mupata weSukoti.
\q1 
\v 7 Gireadhi nderangu, uye Manase ndowangu;
\q2 Efuremu inguwani yangu yakasimba,
\q2 Judha itsvimbo yangu.
\q1 
\v 8 Moabhu ndiwo mudziyo wangu wokushambira,
\q2 pamusoro paEdhomu ndipo pandinokanda shangu yangu;
\q2 pamusoro paFiristia ndinopururudza mukukunda.”
\b
\q1 
\v 9 Ndianiko achandiisa kuguta rakakomberedzwa?
\q2 Ndianiko achanditungamirira kuenda kuEdhomu?
\q1 
\v 10 Hamusimi, iyemi Mwari, iyemi makatiramba here,
\q2 uye mukarega kubuda nehondo dzedu?
\q1 
\v 11 Tibatsirei pavavengi vedu,
\q2 nokuti rubatsiro rwavanhu haruna maturo.
\q1 
\v 12 NaMwari wedu, tichakunda,
\q2 uye achatsikira vavengi vedu pasi.
\c 61
\cl Pisarema 61
\d Kumutungamiri wokuimba, nomutengeranwa une hungiso. Pisarema raDhavhidhi.
\q1 
\v 1 Inzwai kuchema kwangu, imi Mwari;
\q2 rerekerai nzeve yenyu kumunyengetero wangu.
\b
\q1 
\v 2 Kubva kumigumo yenyika, ndinodanidzira kwamuri,
\q2 ndinodana sezvo mwoyo wangu woziya;
\q2 nditungamirirei kudombo rakakwirira kundipfuura.
\q1 
\v 3 Nokuti imi makanga muri utiziro hwangu,
\q2 shongwe yakasimba pamusoro pavavengi vangu.
\b
\q1 
\v 4 Ndinopanga kugara mutende renyu nokusingaperi,
\q2 uye nokuvanda mumumvuri wamapapiro enyu. \qs Sera \qs*
\q1 
\v 5 Nokuti makanzwa mhiko dzangu, imi Mwari;
\q2 makandipa nhaka yaavo vanotya zita renyu.
\b
\q1 
\v 6 Wedzerai mazuva oupenyu hwamambo,
\q2 makore ake kumarudzi namarudzi.
\q1 
\v 7 Ngaagare pachigaro choushe pamberi paMwari nokusingaperi;
\q2 gadzai rudo nokutendeka kwenyu kuti zvimudzivirire.
\b
\q1 
\v 8 Ipapo ndichagara ndichirumbidza zita renyu nenziyo,
\q2 uye ndichazadzisa mhiko dzangu zuva nezuva.
\c 62
\cl Pisarema 62
\d Kumutungamiri wokuimba. Kuna Jedhutuni. Pisarema raDhavhidhi.
\q1 
\v 1 Mweya wangu unozorora muna Mwari oga;
\q2 ruponeso rwangu runobva kwaari.
\q1 
\v 2 Iye oga ndiye dombo rangu noruponeso rwangu;
\q2 ndiye nhare yangu, handingambozungunuswi.
\b
\q1 
\v 3 Muchasvika kupiko muchingorova munhu?
\q2 Ko, imi mose muchamukanda pasi here,
\q2 iyeyu rusvingo rwakarereka, noruzhowa rwuri kuwa?
\q1 
\v 4 Vanofunga kwazvo zvokumuwisira
\q2 pasi kubva panzvimbo yake yakakwirira;
\q2 vanofarira nhema.
\q1 Vanoropafadza nemiromo yavo,
\q2 Asi vachituka mumwoyo yavo. \qs Sera \qs*
\b
\q1 
\v 5 Iwe mweya wangu, zviwanire zororo muna Mwari oga;
\q2 tariro yangu inobva kwaari.
\q1 
\v 6 Ndiye oga dombo rangu noruponeso rwangu;
\q2 ndiye nhare yangu, handingazungunuswi.
\q1 
\v 7 Ruponeso rwangu nokukudzwa kwangu zvinobva kuna Mwari;
\q2 ndiye dombo rangu guru, noutiziro hwangu.
\q1 
\v 8 Vimbai naye nguva dzose, imi vanhu;
\q2 dururai mwoyo yenyu kwaari,
\q2 nokuti Mwari ndiye utiziro hwedu. \qs Sera \qs*
\b
\q1 
\v 9 Vanhu vasina maturo vanongova mweya zvawo,
\q2 asi vanokudzwa inhema bedzi;
\q1 kana vakayerwa havaremi, havasi chinhu;
\q2 vose pamwe chete vanongova mweya.
\q1 
\v 10 Regai kuvimba noupambi
\q2 kana kuzvikudza nezvinhu zvokuba;
\q1 kunyange pfuma yenyu ichiwanda,
\q2 regai kuisa mwoyo yenyu pairi.
\b
\q1 
\v 11 Chinhu chimwe chakataurwa naMwari,
\q2 zvinhu zviviri zvandakanzwa:
\q1 Kuti imi, iyemi Mwari, mune simba,
\q2 
\v 12 uye kuti imi, iyemi Ishe, mune rudo.
\q1 Zvirokwazvo muchapa mubayiro kumunhu mumwe nomumwe
\q2 maererano nezvaakaita.
\c 63
\cl Pisarema 63
\d Pisarema raDhavhidhi paakanga ari murenje reJudha.
\q1 
\v 1 Haiwa Mwari, ndimi Mwari wangu,
\q2 ndinokutsvakai nomwoyo wose;
\q1 mwoyo wangu une nyota kwamuri,
\q2 muviri wangu unokupangai,
\q1 munyika yakaoma
\q2 uye yasakara isina mvura.
\b
\q1 
\v 2 Ndakakuonai munzvimbo yenyu tsvene,
\q2 uye ndikaona simba renyu nokubwinya kwenyu.
\q1 
\v 3 Nokuti rudo rwenyu runokunda upenyu,
\q2 miromo yangu ichakurumbidzai.
\q1 
\v 4 Ndichakurumbidzai ndichiri mupenyu,
\q2 uye ndichasimudza maoko angu muzita renyu.
\q1 
\v 5 Mweya wangu uchagutswa kunge wadya zvakakora kwazvo;
\q2 muromo wangu uchakurumbidzai nemiromo inofara kwazvo.
\b
\q1 
\v 6 Ndinokurangarirai ndiri pamubhedha wangu;
\q2 ndinokufungai panguva dzose dzousiku.
\q1 
\v 7 Nokuti muri mubatsiri wangu,
\q2 ndinoimba ndiri mumumvuri wamapapiro enyu.
\q1 
\v 8 Mweya wangu unonamatira kwamuri;
\q2 ruoko rwenyu rworudyi runonditsigira.
\b
\q1 
\v 9 Vanotsvaka upenyu hwangu vachaparadzwa;
\q2 vachaburukira kwakadzika kwepasi.
\q1 
\v 10 Vachaiswa kumunondo
\q2 vagova zvokudya zvamakava.
\b
\q1 
\v 11 Asi mambo achafara muna Mwari;
\q2 vose vanopika nezita raMwari vachamurumbidza,
\q2 asi miromo yavanoreva nhema ichafumbirwa.
\c 64
\cl Pisarema 64
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Ndinzweiwo, imi Mwari, pandinotaura chichemo changu;
\q2 dzivirirai upenyu hwangu pakutyisidzira kwavavengi.
\q1 
\v 2 Ndivanzei pakurangana kwavakaipa,
\q2 ndibve pazhowezhowe yeungano yavaiti vezvakaipa.
\b
\q1 
\v 3 Vanorodza ndimi dzavo seminondo,
\q2 uye vanonanga namashoko avo semiseve inouraya.
\q1 
\v 4 Vanopfura vari pakavanda munhu asina mhosva;
\q2 vanomupfura pakarepo, vasingatyi.
\b
\q1 
\v 5 Vanokurudzira mumwe nomumwe wavo pakufunga zvakaipa,
\q2 vanotaura pamusoro pokuteya misungo yavo, uye vanoti,
\q2 “Ndianiko achaiona?”
\q1 
\v 6 Vanorangana kusaruramisira vachiti,
\q2 “Tafunga zano rakakwana!”
\q2 Zvirokwazvo mwoyo nomurangariro womunhu zvinonyengera.
\b
\q1 
\v 7 Asi Mwari achavapfura nemiseve;
\q2 pakarepo vachawira pasi.
\q1 
\v 8 Achaita kuti ndimi dzavo dzivashandukire,
\q2 uye achavaisa pakuparadzwa;
\q2 vose vanovaona vachavadzungudzira misoro vachivaseka.
\b
\q1 
\v 9 Marudzi ose avanhu achatya;
\q2 achaparidza mabasa aMwari,
\q2 uye achafungisisa zvaakaita.
\q1 
\v 10 Vakarurama ngavafare muna Jehovha
\q2 uye vavande maari;
\q2 vose vakarurama mumwoyo ngavamurumbidze!
\c 65
\cl Pisarema 65
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi. Rwiyo.
\q1 
\v 1 Kurumbidzwa kwakakumirirai, imi Mwari, muZioni;
\q2 kwamuri mhiko dzedu dzichazadziswa.
\q1 
\v 2 Haiwa, imi munonzwa munyengetero,
\q2 vanhu vose vachauya kwamuri.
\q1 
\v 3 Patakanga takafukidzwa nezvivi,
\q2 makakanganwira kudarika kwedu.
\q1 
\v 4 Vakaropafadzwa avo vamunosarudza
\q2 navamunoswededza pedyo kuti vagare pavanze dzenyu!
\q1 Takagutswa nezvinhu zvakanaka zveimba yenyu,
\q2 zvetemberi yenyu tsvene.
\b
\q1 
\v 5 Munotipindura namabasa okururama anotyisa,
\q2 imi Mwari Muponesi wedu,
\q1 tariro yemigumo yepasi pose
\q2 namakungwa ari kure kure,
\q1 
\v 6 iyemi makaumba makomo nesimba renyu,
\q2 makazvishongedza nesimba,
\q1 
\v 7 iyemi makanyaradza kutinhira kwamakungwa,
\q2 iko kutinhira kwamafungu aro,
\q2 nokupopota kwendudzi.
\q1 
\v 8 Vanogara kure kure vanotya zvishamiso zvenyu;
\q2 uko kunobuda mambakwedza uye madekwana achipera,
\q2 munodanidzira nziyo dzomufaro.
\b
\q1 
\v 9 Mune hanya nenyika uye munoidiridza;
\q2 munoipfumisa kwazvo.
\q1 Hova dzaMwari dzizere nemvura
\q2 kuti dzivigire vanhu zviyo,
\q2 nokuti saizvozvo ndimi makazvirayira.
\q1 
\v 10 Munozadza mihoronga yacho nemvura,
\q2 uye munoenzanisa mihomba yacho;
\q1 munoinyorovesa nemvura inopfunha
\q2 munoropafadza zvibereko zvayo.
\q1 
\v 11 Munoshongedza gore nekorona yezvakawanda zvenyu,
\q2 uye ngoro dzenyu dzinopfachukira nezvakawanda.
\q1 
\v 12 Uswa hwomurenje hwopfachukira;
\q2 zvikomo zvakafukidzwa nomufaro.
\q1 
\v 13 Mafuro azara namapoka emakwai,
\q2 uye mipata yafukidzwa nezviyo;
\q2 zvinodanidzira nomufaro uye zvinoimba.
\c 66
\cl Pisarema 66
\d Kumutungamiri wokuimba. Rwiyo. Pisarema.
\q1 
\v 1 Danidzirai nomufaro kuna Mwari, imi nyika yose!
\q2 
\v 2 Imbirai mukurumbira wezita rake;
\q2 murumbidze zvikuru kukudzwa kwake!
\q1 
\v 3 Muti kuna Mwari, “Mabasa enyu anotyisa sei!
\q2 Simba renyu iguru zvokuti vavengi venyu
\q2 vanodedera pamberi penyu.
\q1 
\v 4 Nyika yose inokukotamirai;
\q2 vanokuimbirai nziyo dzokurumbidza,
\q2 vanoimba nziyo dzokurumbidza zita renyu.” \qs Sera\qs*
\b
\q1 
\v 5 Uyai muone zvaitwa naMwari,
\q2 mabasa ake anotyisa sei pakati pavanhu!
\q1 
\v 6 Akashandura gungwa rikava nyika yakaoma,
\q2 vakafamba nomumvura zhinji netsoka dzavo,
\q2 uyai, ngatifarei maari.
\q1 
\v 7 Anotonga nokusingaperi nesimba rake,
\q2 meso ake anocherechedza ndudzi,
\q2 vanomumukira ngavarege kumisidzana naye. \qs Sera \qs*
\b
\q1 
\v 8 Rumbidzai Mwari wedu, imi vanhu,
\q2 inzwi rokurumbidzwa kwake ngarinzwike;
\q1 
\v 9 iye akachengetedza upenyu hwedu
\q2 netsoka dzedu kuti dzirege kutedzemuka.
\q1 
\v 10 Nokuti imi, iyemi Mwari, makatiedza;
\q2 mukatinatsa sesirivha.
\q1 
\v 11 Makatipinza mutorongo
\q2 mukatitakudza mitoro pamisana yedu.
\q1 
\v 12 Makabvumira vanhu kukwira pamisoro yedu;
\q2 takapinda mumoto nomumvura,
\q2 asi makatiisa kunzvimbo ine zvakawanda.
\b
\q1 
\v 13 Ndichauya nezvibayiro zvinopiswa kutemberi yenyu,
\q2 ndigozadzisa mhiko dzangu kwamuri,
\q1 
\v 14 mhiko dzandakavimbisa nemiromo yangu,
\q2 uye muromo wangu wakataura pandakanga ndiri munhamo.
\q1 
\v 15 Ndichakubayirai mhuka dzakakora
\q2 nechipiriso chamakondobwe;
\q2 ndichabayirawo hando nembudzi. \qs Sera \qs*
\b
\q1 
\v 16 Uyai munzwe, imi mose munotya Mwari;
\q2 ndikuudzei zvaakandiitira.
\q1 
\v 17 Ndakachema kwaari nomuromo wangu; rumbidzo yake yaiva parurimi rwangu.
\q1 
\v 18 Dai ndakanga ndaviga chivi mumwoyo mangu,
\q2 Ishe aidai asina kundinzwa;
\q1 
\v 19 asi zvirokwazvo Mwari akateerera
\q2 akanzwa inzwi rangu mumunyengetero.
\q1 
\v 20 Mwari ngaarumbidzwe,
\q2 iye asina kuramba munyengetero wangu.
\q2 Kana kudzivisa rudo rwake kwandiri!
\c 67
\cl Pisarema 67
\d Kumutungamiri wokuimba nemitengeranwa ine hungiso. Pisarema. Rwiyo.
\q1 
\v 1 Mwari ngaatinzwire tsitsi atiropafadze,
\q2 uye apenyese chiso chake pamusoro pedu, \qs Sera \qs*
\q1 
\v 2 kuti nzira dzenyu dzizivikanwe panyika,
\q2 ruponeso rwenyu pakati pendudzi dzose.
\b
\q1 
\v 3 Marudzi ngaakurumbidzei, imi Mwari;
\q2 marudzi ose ngaakurumbidzei.
\q1 
\v 4 Ndudzi ngadzifare uye dziimbe nomufaro,
\q2 nokuti munotonga marudzi nokururamisira,
\q2 uye munotungamirira ndudzi dzenyika. \qs Sera \qs*
\q1 
\v 5 Marudzi ngaakurumbidzei, imi Mwari;
\q2 marudzi ose ngaakurumbidzei.
\b
\q1 
\v 6 Ipapo nyika ichabereka mukohwo wayo,
\q2 uye Mwari, Mwari wedu, achatiropafadza.
\q1 
\v 7 Mwari achatiropafadza,
\q2 uye migumo yose yepasi ichamutya.
\c 68
\cl Pisarema 68
\d Mutungamiri mukuru wokuimba. Pisarema raDhavhidhi. Rwiyo.
\q1 
\v 1 Mwari ngaasimuke, vavengi vake ngavaparadzirwe;
\q2 vavengi vake ngavatize pamberi pake.
\q1 
\v 2 Sokupeperetswa kunoitwa utsi nemhepo,
\q2 saizvozvo vapeperetsei;
\q1 sokunyauka kunoita namo pamberi pomoto,
\q2 vakaipa ngavaparare pamberi paMwari.
\q1 
\v 3 Asi vakarurama ngavafare,
\q2 vafarisise pamberi paMwari;
\q2 ngavafare vapembere.
\b
\q1 
\v 4 Imbirai Mwari, imbirai zita rake nziyo dzokurumbidza,
\q2 murumbidzei zvikuru iye anofamba pamusoro pamakore,
\q1 zita rake ndiJehovha,
\q2 uye farai pamberi pake.
\q1 
\v 5 Baba venherera, mudziviriri wechirikadzi,
\q2 ndiye Mwari ari paugaro hwake utsvene.
\q1 
\v 6 Vakanga vari voga Mwari akavagarisa mumhuri,
\q2 anosesedza vasungwa vachiimba;
\q2 asi mhandu dzinogara panyika yatsva nezuva.
\b
\q1 
\v 7 Pamakatungamirira vanhu venyu, imi Mwari,
\q2 pamakafamba napakati perenje, \qs Sera \qs*
\q1 
\v 8 nyika yakazungunuka,
\q2 matenga akadurura mvura, pamberi paMwari,
\q1 iye weSinai, pamberi paMwari,
\q2 iye Mwari waIsraeri.
\q1 
\v 9 Imi Mwari, makanayisa mvura zhinji;
\q2 mukaita kuti nhaka yenyu yakaneta ifefeterwe.
\q1 
\v 10 Vanhu venyu vakagaramo,
\q2 uye imi Mwari, kubva pane, zvakawanda zvenyu, makariritira varombo.
\b
\q1 
\v 11 Ishe akataura shoko,
\q2 vanhu vakaparidza shoko vaiva vazhinji kwazvo:
\q1 
\v 12 “Madzimambo navarwi vakakurumidza kutiza;
\q2 mumisasa, vanhu vakagovana zvakapambwa.
\q1 
\v 13 Kunyange pamunenge makavata pakati pemoto yemisasa,
\q2 mapapiro enjiva yangu akafukidzwa nesirivha,
\q2 minhenga yayo negoridhe rinovaima.”
\q1 
\v 14 Wamasimba Ose paakaparadzira madzimambo munyika,
\q2 zvakanga zvakaita sechando chawira pamusoro peZarimoni.
\b
\q1 
\v 15 Makomo eBhashani makomo oushe;
\q2 makomo eBhashani akati twi.
\q1 
\v 16 Munotaririreiko negodo, imi makomo akati twi,
\q2 pagomo rakasarudzwa naMwari kuti atongepo,
\q2 pachagarwa naJehovha pachake nokusingaperi?
\q1 
\v 17 Ngoro dzaMwari dzinosvika makumi ezviuru
\q2 nezviuru zvezviuru;
\q2 Ishe akasvika panzvimbo yake tsvene achibva kuSinai.
\q1 
\v 18 Pamakakwira kumusoro,
\q2 makatungamirira vatapwa mumudungwe wenyu;
\q2 mukagamuchira zvipo zvaibva kuvanhu,
\q1 kunyange zvaibva kuna vakapanduka,
\q2 kuti imi, iyemi Jehovha Mwari, mugarepo.
\b
\q1 
\v 19 Ishe ngaarumbidzwe, Mwari Muponesi wedu,
\q2 anotakura mitoro yedu zuva nezuva. \qs Sera \qs*
\q1 
\v 20 Mwari wedu ndiMwari anoponesa;
\q2 kupunyuka parufu kunobva kuna Ishe Jehovha.
\b
\q1 
\v 21 Zvirokwazvo Mwari achapwanya misoro yavavengi vake,
\q2 panhongonya dzine vhudzi dzaavo vanorambira muzvivi zvavo.
\q1 
\v 22 Ishe anoti, “Ndichavabvisa kubva kuBhashani;
\q2 ndichavabudisa kubva kwakadzika kwegungwa,
\q1 
\v 23 kuti unyike tsoka dzako muropa ravavengi vako,
\q2 ndimi dzembwa dzako dzichiwanawo mugove wadzo.”
\b
\q1 
\v 24 Mudungwe wenyu wakaonekwa, imi Mwari,
\q2 mudungwe waMwari wangu naMambo achipinda munzvimbo tsvene.
\q1 
\v 25 Mberi kuna vaimbi, vachiteverwa navaridzi vemitengeranwa;
\q2 pamwe chete navarandakadzi vachiridza matambureni.
\q1 
\v 26 Rumbidzai Mwari paungano huru;
\q2 rumbidzai Mwari pagungano raIsraeri.
\q1 
\v 27 Tarirai, rudzi ruduku rwaBhenjamini runovatungamirira,
\q2 hawo machinda mazhinji aJudha,
\q2 uye hawo machinda aZebhuruni neaNafutari.
\b
\q1 
\v 28 Danai simba renyu, imi Mwari;
\q2 tiratidzei simba renyu, imi Mwari, sezvamakaita kare.
\q1 
\v 29 Nokuda kwetemberi yenyu paJerusarema,
\q2 madzimambo achakuvigirai zvipo.
\q1 
\v 30 Tukai mhuka dziri pakati petsanga,
\q2 mapoka ehando ari pakati pemhuru dzendudzi.
\q1 Ngavauye nesirivha, vakazvininipisa.
\q2 Paradzirai ndudzi dzinofarira kurwa.
\q1 
\v 31 Nhume dzichabva kuIjipiti;
\q2 Etiopia ichazviisa pasi paMwari.
\b
\q1 
\v 32 Imbirai Mwari, imi ushe hwepasi,
\q2 rumbidzai Ishe nenziyo, \qs Sera \qs*
\q1 
\v 33 kuna iye anotasva matenga akare kumusoro,
\q2 iye anobudisa inzwi rake, inzwi rine simba.
\q1 
\v 34 Paridzai simba raMwari,
\q2 iye ano ushe huri pamusoro peIsraeri,
\q2 ane simba riri kudenga denga.
\q1 
\v 35 Munotyisa imi Mwari, muri panzvimbo yenyu tsvene;
\q2 Mwari waIsraeri anopa ushe nesimba kuvanhu vake.
\b
\q1 Mwari ngaarumbidzwe!
\c 69
\cl Pisarema 69
\d Kumutungamiri wokuimba namaimbirwo a“Maruva eMahapa.” Pisarema raDhavhidhi.
\q1 
\v 1 Ndiponesei, imi Mwari,
\q2 nokuti mvura zhinji yakwira kusvikira pamutsipa wangu.
\q1 
\v 2 Ndinonyura munhope yakadzika,
\q1 pasina pangatsika makumbo angu.
\q1 Ndapinda mumvura yakadzika;
\q2 ndafukidzwa namafashamu.
\q1 
\v 3 Ndaneta nokuridza mhere yokuti ndibatsirwe;
\q2 huro dzangu dzaoma,
\q1 meso angu aneta
\q2 nokumirira Mwari wangu.
\q1 
\v 4 Vanondivenga ndisina mhosva vakawanda
\q2 kupfuura bvudzi romusoro wangu;
\q1 vanondivenga ndisina mhosva vazhinji, avo vanotsvaka kundiparadza. Ndinomanikidzwa kudzosera zvandisina kuba.
\b
\q1 
\v 5 Munoziva upenzi hwangu, imi Mwari;
\q2 mhaka yangu haina kuvanzika kwamuri.
\b
\q1 
\v 6 Vaya vane tariro mamuri
\q2 ngavarege kunyadziswa nokuda kwangu,
\q2 haiwa Ishe, Jehovha Wamasimba Ose;
\q1 vanokutsvakai
\q2 ngavarege kunyadziswa nokuda kwangu,
\q2 haiwa Mwari waIsraeri.
\q1 
\v 7 Nokuti ndinotsunga kusekwa hangu nokuda kwenyu,
\q2 uye nyadzi dzafukidza chiso changu.
\q1 
\v 8 Ndiri mutorwa kuhama dzangu,
\q2 nomweni kuvanakomana vamai vangu;
\q1 
\v 9 nokuti kushingairira imba yenyu kwandipedza,
\q2 uye kutuka kwaavo vanokutukai kunowira pamusoro pangu.
\q1 
\v 10 Pandinochema uye ndichitsanya,
\q2 ndinofanira kushinga pakusekwa;
\q1 
\v 11 pandinofuka nguo dzamasaga,
\q2 vanhu vanondiita shumo.
\q1 
\v 12 Vaya vanogara pasuo vanondiseka,
\q2 uye ndiri rwiyo rwezvidhakwa.
\b
\q1 
\v 13 Asi ndinonyengetera kwamuri, imi Mwari,
\q2 panguva inokufadzai;
\q1 murudo rwenyu rukuru, imi Mwari,
\q2 ndipindurei noruponeso rwenyu rwechokwadi.
\q1 
\v 14 Ndinunurei mumatope,
\q2 musandirega ndichinyura;
\q1 ndirwirei kuna vanondivenga,
\q2 napamvura zhinji yakadzika.
\q1 
\v 15 Musatendera mvura yamafashamu kuti indifukidze,
\q2 kana kwakadzika kuti kundimedze
\q2 kana kuti gomba rizarure muromo waro pamusoro pangu.
\b
\q1 
\v 16 Ndipindurei, imi Jehovha, zvichibva pakunaka kworudo rwenyu;
\q2 dzokerai henyu kwandiri nokuda kwetsitsi dzenyu huru.
\q1 
\v 17 Regai kuvanzira muranda wenyu chiso chenyu;
\q2 ndipindurei nokukurumidza, nokuti ndava mudambudziko.
\q1 
\v 18 Swederai pedyo mundinunure;
\q2 ndidzikinurei nokuda kwavavengi vangu.
\b
\q1 
\v 19 Munoziva kusekwa kwangu, kunyadziswa nokusakudzwa kwangu;
\q2 vavengi vangu vose vari pamberi penyu.
\q1 
\v 20 Kusekwa kwaputsa mwoyo wangu,
\q2 uye kwandisiya ndisisina chingandibatsira;
\q1 Ndakatsvaka vangandinzwira ngoni, asi ndakavashaya,
\q2 vangandinyaradza, asi ndakavashayazve.
\q1 
\v 21 Vakaisa nduru mune zvokudya zvangu,
\q2 uye vakandipa vhiniga pandaiva nenyota.
\b
\q1 
\v 22 Tafura yagadzirwa pamberi pavo ngaive musungo;
\q2 ngaive shamhu yokuranga neriva.
\q1 
\v 23 Meso avo ngaapofumadzwe kuti varege kuona,
\q2 uye misana yavo iminame nokusingaperi.
\q1 
\v 24 Dururirai hasha dzenyu pamusoro pavo;
\q2 kutsamwa kwenyu kunotyisa ngakuvakurire.
\q1 
\v 25 Nzvimbo yavo ngaisiyiwe;
\q2 ngaparege kuva nomunhu anogara mumatende avo.
\q1 
\v 26 Nokuti vanotambudza vaya vamakarova,
\q2 uye vanotaura pamusoro pokurwadziwa kwavakakuvadzwa nemi.
\q1 
\v 27 Vapei mhosva pamusoro pemhosva;
\q2 ngavarege kuva nomugove woruponeso rwenyu.
\q1 
\v 28 Ngavadzimwe mubhuku roupenyu,
\q2 uye varege kuverengwa pamwe chete navakarurama.
\b
\q1 
\v 29 Ndiri pakurwadziwa nenhamo;
\q2 ruponeso rwenyu imi Mwari, ngarundidzivirire.
\b
\q1 
\v 30 Ndicharumbidza zita raMwari norwiyo,
\q2 uye ndichamukudza nokuvonga.
\q1 
\v 31 Izvi zvichafadza Jehovha kukunda nzombe,
\q2 kupfuura hando nenyanga dzayo, namahwanda ayo.
\q1 
\v 32 Varombo vachazviona uye vachafara,
\q2 imi vanotsvaka Mwari, mwoyo yenyu ngairarame!
\q1 
\v 33 Jehovha anonzwa vanoshayiwa
\q2 uye haashori vanhu vake vakatapwa.
\b
\q1 
\v 34 Denga nenyika ngazvimurumbidze,
\q2 makungwa nezvose zvinofamba, imomo,
\q1 
\v 35 nokuti Mwari achaponesa Zioni
\q2 agovakazve maguta aJudha.
\q1 Ipapo vanhu vachagarako, vagoritora;
\q2 
\v 36 Vana vavaranda vake vacharipiwa senhaka,
\q2 uye avo vanoda zita rake vachagara ikoko.
\c 70
\cl Pisarema 70
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi. Chikumbiro.
\q1 
\v 1 Kurumidzai kundiponesa, imi Mwari;
\q2 Haiwa Jehovha kurumidzai kuuya mundibatsire.
\b
\q1 
\v 2 Vanotsvaka upenyu hwangu
\q2 ngavanyadziswe uye vakanganiswe;
\q1 vose vanofarira kuparara kwangu
\q2 ngavadzorwe shure vanyare.
\q1 
\v 3 Vanoti kwandiri, “Hekani waro! Hekani waro!”
\q2 ngavadzorerwe shure nokuda kwenyadzi dzavo.
\q1 
\v 4 Asi vose vanokutsvakai
\q2 ngavafare nokufarisisa mamuri;
\q1 vanoda ruponeso rwenyu ngavagare vachiti,
\q2 “Mwari ngaakudzwe!”
\b
\q1 
\v 5 Asi ndiri murombo nomushayiwi;
\q2 uyai nokukurumidza kwandiri, imi Mwari.
\q1 Imi muri mubatsiri wangu nomurwiri wangu;
\q2 Haiwa Jehovha, musanonoka.
\c 71
\cl Pisarema 71
\q1 
\v 1 Ndinovanda mamuri, imi Jehovha;
\q2 ngandirege kutongonyadziswa.
\q1 
\v 2 Ndinunurei uye mundirwire mukururama kwenyu;
\q2 rerekerai nzeve yenyu kwandiri uye mundiponese.
\q1 
\v 3 Ivai bako rangu rokuvanda kwandingaramba ndichienda;
\q2 rayirai kuti ndiponeswe, nokuti ndimi dombo rangu nenhare yangu.
\q1 
\v 4 Haiwa Mwari wangu, ndirwirei, paruoko rwowakaipa,
\q2 pakubatwa navanhu vakaipa uye vane utsinye.
\b
\q1 
\v 5 Nokuti muri tariro yangu, imi Ishe Jehovha,
\q2 ndakavimba nemi kubva pauduku hwangu.
\q1 
\v 6 Ndakazendamira pamuri kubva pakuberekwa kwangu;
\q2 ndimi makandibudisa mudumbu ramai vangu.
\q2 Ndicharamba ndichikurumbidzai.
\q1 
\v 7 Ndava sechishamiso kuvazhinji,
\q2 asi imi muri utiziro hwangu hwakasimba.
\q1 
\v 8 Muromo wangu uzere nerumbidzo yenyu,
\q2 ndinoparidza kubwinya kwenyu zuva rose.
\b
\q1 
\v 9 Regai kundirasa pandinenge ndakwegura;
\q2 musandisiya kana simba rangu rapera.
\q1 
\v 10 Nokuti vavengi vangu vanotaura zvakaipa pamusoro pangu;
\q2 avo vakamirira kundiuraya vanorangana pamwe chete.
\q1 
\v 11 Vanoti, “Mwari amusiya;
\q2 muteverei mumubate,
\q2 nokuti hakuna achamununura.”
\q1 
\v 12 Regai kuva kure neni, imi Mwari;
\q2 uyai nokukurumidza, imi Mwari wangu, mundibatsire.
\q1 
\v 13 Vapomeri vangu ngavaparare vanyadziswe;
\q2 vaya vanoda kundikuvadza
\q2 ngavafukidzwe nokusekwa nokunyadziswa.
\b
\q1 
\v 14 Asi kana ndirini, ndichagara ndine tariro;
\q2 ndicharamba ndichikurumbidzai zvakanyanya.
\b
\q1 
\v 15 Muromo wangu uchareva zvokururama kwenyu,
\q2 nezvoruponeso rwenyu zuva rose,
\q2 kunyange ndisingazivi chiyero charwo.
\q1 
\v 16 Ndichauya ndichiparidza mabasa enyu makuru, imi Ishe Jehovha;
\q2 ndichaparidza kururama kwenyu, iyemi moga.
\q1 
\v 17 Kubva pauduku hwangu, imi Mwari, makandidzidzisa,
\q2 nanhasi uno ndinoparidza mabasa enyu anoshamisa.
\q1 
\v 18 Kunyange pandinenge ndakwegura uye bvudzi rachena,
\q2 musandisiya, imi Mwari,
\q1 kusvikira ndaparidza simba renyu kurudzi runotevera,
\q2 nesimba renyu kuna vose vari kuzouya.
\b
\q1 
\v 19 Kururama kwenyu kunosvika kudenga kumusoro, imi Mwari,
\q2 iyemi makaita zvinhu zvikuru.
\q2 Haiwa Mwari, ndiani akafanana nemi?
\q1 
\v 20 Kunyange imi makandiratidza matambudziko mazhinji uye anorwadza,
\q2 muchadzosa upenyu hwangu zvakare;
\q1 kubva kwakadzika kwepasi
\q2 muchandibudisazve.
\q1 
\v 21 Muchawedzera kukudzwa kwangu,
\q2 uye muchandinyaradzazve.
\b
\q1 
\v 22 Ndichakurumbidzai nembira
\q2 nokuda kwokutendeka kwenyu, imi Mwari wangu;
\q1 ndichakurumbidzai nenziyo nomutengeranwa,
\q2 imi Mutsvene woga waIsraeri.
\q1 
\v 23 Miromo yangu ichadanidzira nomufaro
\q2 pandinokurumbidzai nenziyo,
\q2 iyeni, wamakadzikinura.
\q1 
\v 24 Rurimi rwangu ruchataura nezvamabasa enyu akarurama
\q2 zuva rose,
\q1 nokuti avo vaida kundikuvadza
\q2 vanyadziswa uye vakanganiswa.
\c 72
\cl Pisarema 72
\d Pisarema raSoromoni.
\q1 
\v 1 Shongedzai Mambo nokururamisira kwenyu, imi Mwari,
\q2 mwanakomana wamambo nokururama kwenyu.
\q1 
\v 2 Achatonga vanhu venyu nokururama,
\q2 navanonetswa venyu nokururamisira.
\q1 
\v 3 Makomo achavigira vanhu kubudirira,
\q2 nezvikomo, chibereko chokururama.
\q1 
\v 4 Achadzivirira vanonetswa pakati pavanhu,
\q2 uye achaponesa vana vavanoshayiwa;
\q2 achapwanya mudzvinyiriri.
\b
\q1 
\v 5 Achashinga sokuvapo kwezuva, sokuvapo kwomwedzi,
\q2 kusvikira kumarudzi ose anotevera,
\q1 
\v 6 achafanana nemvura inonaya pamunda une uswa hwakachekererwa,
\q2 seguti rinonyorovesa nyika.
\q1 
\v 7 Pamazuva ake vakarurama vachakura zvakanaka;
\q2 kubudirira kuchawanda kusvikira mwedzi waguma.
\b
\q1 
\v 8 Achatonga kubva kugungwa kusvikira kugungwa,
\q2 uye kubva paRwizi kusvikira kumagumo enyika.
\q1 
\v 9 Marudzi omugwenga achapfugama pamberi pake,
\q2 uye vavengi vake vachananzva guruva.
\q1 
\v 10 Madzimambo eTashishi navari kumahombekombe ari kure
\q2 vachamuvigira mutero;
\q1 madzimambo eShebha neSebha
\q2 vachamupa zvipo.
\q1 
\v 11 Madzimambo ose achamupfugamira
\q2 uye ndudzi dzose dzichamushandira.
\b
\q1 
\v 12 Nokuti acharwira vanoshayiwa vanodanidzira;
\q2 vanonetswa vasina anovabatsira.
\q1 
\v 13 Achanzwira ngoni vasina simba navanoshayiwa,
\q2 uye achaponesa vanoshayiwa kubva parufu.
\q1 
\v 14 Achavanunura pakudzvinyirirwa nokuitirwa zvinhu nechisimba,
\q2 nokuti ropa ravo rinokosha pamberi pake.
\b
\q1 
\v 15 Iye ngaararame upenyu hurefu!
\q2 Goridhe rinobva kuShebha ngaripiwe kwaari.
\q1 Vanhu ngavarambe vachimunyengeterera
\q2 uye vamuropafadze zuva rose.
\q1 
\v 16 Zviyo ngazviwande munyika yose;
\q2 ngazvizengaire pamusoro pezvikomo.
\q1 Zvibereko zvazvo ngazvikure zvakanaka seRebhanoni;
\q2 ngazvibukire sebundo romusango.
\b
\q1 
\v 17 Zita rake ngarigare nokusingaperi;
\q2 ngarirambe riripo sokuvapo kwezuva.
\b
\q1 Ndudzi dzose dzicharopafadzwa kubudikidza naye,
\q2 uye vachamuti, ano mufaro.
\b
\b
\q1 
\v 18 Jehovha Mwari ngaarumbidzwe, Mwari waIsraeri,
\q2 iye oga anoita mabasa anoshamisa.
\q1 
\v 19 Zita rake rinobwinya ngarirumbidzwe nokusingaperi;
\q2 nyika yose ngaizadzwe nokubwinya kwake.
\qc Ameni naAmeni.
\b
\b
\q1 
\v 20 Ndipo panoperera minyengetero yaDhavhidhi, mwanakomana waJese.
\c 73
\ms1 BHUKU 3
\mr Mapisarema 73–89
\cl Pisarema 73
\d Pisarema raAsafi.
\q1 
\v 1 Zvirokwazvo Mwari akanaka kuna Israeri,
\q2 kuna avo vakachena pamwoyo.
\b
\q1 
\v 2 Asi kana ndirini, tsoka dzangu dzakapotsa dzatsvedza;
\q2 ndakasara paduku kupunzika.
\q1 
\v 3 Nokuti ndakaitira shanje vanozvikudza,
\q2 pandakaona kubudirira kwavakaipa.
\b
\q1 
\v 4 Havatambudziki;
\q2 miviri yavo ino utano uye vakasimba.
\q1 
\v 5 Vakasununguka pamitoro inowanikwa muvanhu;
\q2 havatambudzwi nezvinotambudza vanhu.
\q1 
\v 6 Naizvozvo kuzvikudza ndiko ruketani rwemitsipa yavo;
\q2 vanozvishongedza nechisimba.
\q1 
\v 7 Mumwoyo yavo makasindimara munobuda chitadzo;
\q2 mifungo yakaipa yendangariro dzavo haina magumo.
\q1 
\v 8 Vanoseka, uye vanotaura noutsinye mukuzvikudza kwavo,
\q2 vanoti vachadzvinyirira vamwe.
\q1 
\v 9 Miromo yavo inoti denga nderavo,
\q2 uye ndimi dzavo dzinotora nyika.
\q1 
\v 10 Naizvozvo vanhu vavo vanodzokera kwavari,
\q2 uye vanonwa mvura yakawanda.
\q1 
\v 11 Vanoti, “Mwari angazviziva sei?
\q2 Ko, Wokumusoro-soro ane ruzivo here?”
\b
\q1 
\v 12 Ndizvo zvakaita vakaipa,
\q2 havana hanya nguva dzose, vanowedzera pfuma yavo.
\b
\q1 
\v 13 Zvirokwazvo ndakanatsa mwoyo wangu, asi pasina;
\q2 ndakashamba maoko angu ndisina mhosva, asi pasina.
\q1 
\v 14 Zuva rose ndanga ndichitambudzwa;
\q2 ndinorangwa mangwanani ose.
\b
\q1 
\v 15 Dai ndakanga ndati, “Ndichataura zvakadai,”
\q2 ndingadai ndakapandukira vana venyu.
\q1 
\v 16 Pandakaedza kunzwisisa izvi zvose,
\q2 zvakandiremera kwazvo
\q1 
\v 17 kusvikira ndapinda munzvimbo tsvene yaMwari;
\q2 ipapo ndikazonzwisisa magumo avo.
\b
\q1 
\v 18 Zvirokwazvo makavaisa munzira inotsvedza;
\q2 makavakanda pasi kuti vaparare.
\q1 
\v 19 Haiwa, vanoparadzwa kamwe kamwe,
\q2 vanopedzwa chose nezvinotyisa!
\q1 
\v 20 Sezvakaita kurota panopepuka munhu,
\q2 saizvozvo pamunomuka, imi Ishe,
\q2 muchavashora savanhu vanorotomoka.
\b
\q1 
\v 21 Mwoyo wangu pawakachema
\q2 uye mweya wangu ukashungurudzika,
\q1 
\v 22 ndakanga ndava benzi uye ndisingazivi;
\q2 ndakanga ndava mhuka inotyisa pamberi penyu.
\b
\q1 
\v 23 Kunyange zvakadaro ndinogara nemi nguva dzose;
\q2 munondibata noruoko rwenyu rworudyi.
\q1 
\v 24 Munondisesedza nezano renyu,
\q2 uye pashure muchazonditora mondipinza mukubwinya kwenyu.
\q1 
\v 25 Ndianiko wandinaye kudenga kana musirimi?
\q2 Uye nyika haina chandinoshuva kunze kwenyu.
\q1 
\v 26 Nyama yangu nomwoyo wangu zvingapera hazvo,
\q2 asi Mwari isimba romwoyo wangu
\q2 nomugove wangu nokusingaperi.
\b
\q1 
\v 27 Avo vari kure nemi vachaparara;
\q2 munoparadza vose vasina kutendeka kwamuri.
\q1 
\v 28 Asi kana ndirini, zvakanaka kuva pedyo naMwari.
\q2 Ndakaita Ishe Jehovha utiziro hwangu;
\q2 ndichataura zvamabasa enyu ose.
\c 74
\cl Pisarema 74
\d Masikiri raAsafi.
\q1 
\v 1 Haiwa Mwari, makatirambireiko nokusingaperi?
\q2 Kutsamwa kwenyu kwapfungairireiko pamusoro pamakwai anofudzwa nemi?
\q1 
\v 2 Rangarirai vanhu vamakatenga kare,
\q2 rudzi rwenhaka yenyu, ivo vamakadzikinura,
\q2 Gomo reZioni, pamaigara.
\q1 
\v 3 Dzorai nhambwe dzenyu mutarise matongo asingaperi,
\q2 kuparadza ikoku kwose kwakauya nomuvengi pamusoro penzvimbo yenyu tsvene.
\b
\q1 
\v 4 Vavengi venyu vakaomba panzvimbo yamakasangana nesu;
\q2 vakamisa mireza yavo sechiratidzo.
\q1 
\v 5 Vakaita savanhu vanosimudza matemo
\q2 kuti vateme dondo remiti.
\q1 
\v 6 Vakaputsa zvose zvakavezwa
\q2 namatemo avo nembezo.
\q1 
\v 7 Vakapisira pasi nzvimbo yenyu tsvene;
\q2 vakamhura ugaro hweZita renyu.
\q1 
\v 8 Vakati mumwoyo yavo, “Tichavaputsa zvachose!”
\q2 Vakapisa nzvimbo dzose dzokunamatira Mwari munyika.
\q1 
\v 9 Hatichaoni zviratidzo zvinoshamisa;
\q2 hakuna muprofita akasara,
\q2 pakati pedu hapana munhu anoziva kuti zvicharamba zvakadaro kusvikira rini.
\b
\q1 
\v 10 Haiwa Mwari, muvengi acharamba achikushorai kusvikira riniko?
\q2 Ko, muvengi acharamba achimhura zita renyu nokusingaperi here?
\q1 
\v 11 Munodzoserereiko ruoko rwenyu shure, irwo ruoko rwenyu rworudyi?
\q2 Rubvisei pamupendero wenguo yenyu muvaparadze!
\b
\q1 
\v 12 Asi imi, iyemi Mwari, ndimi mambo wangu kubva nakare;
\q2 imi munouyisa ruponeso panyika.
\q1 
\v 13 Ndimi makaganhura gungwa napakati nesimba renyu;
\q2 makaputsa misoro yechikara chomumvura.
\q1 
\v 14 Ndimi makapwanya misoro yaRevhiatani,
\q2 mukamuita chokudya chezvisikwa zvomugwenga.
\q1 
\v 15 Ndimi makazarura zvitubu nehova;
\q2 mukapwisa nzizi dzaigara dzichierera.
\q1 
\v 16 Zuva nderenyu, uye usiku ndohwenyuwo;
\q2 makasimbisa zuva nomwedzi.
\q1 
\v 17 Ndimi makatara miganhu yose yenyika;
\q2 mukaita zvose zhizha nechando.
\b
\q1 
\v 18 Rangarirai kuti muvengi akakushorai sei, imi Jehovha,
\q2 uye kuti mapenzi akamhura sei zita renyu.
\q1 
\v 19 Regai kuisa upenyu hwenjiva yenyu kumhuka dzesango;
\q2 regai kukanganwa nokusingaperi upenyu hwavanhu venyu vanonetswa.
\q1 
\v 20 Ivai nehanya nesungano yenyu,
\q2 nokuti mweya wokurwisana wazadza nzvimbo dzerima munyika.
\q1 
\v 21 Musarega vakadzvinyirirwa vachidududza shure nenyadzi;
\q2 varombo navanoshayiwa ngavarumbidze zita renyu.
\b
\q1 
\v 22 Simukai, imi Mwari, mutsigire mhaka yenyu;
\q2 rangarirai kuti mapenzi anokushorai sei zuva rose.
\q1 
\v 23 Regai kushayira hanya ruzha rwavadzivisi venyu,
\q2 bope ravavengi venyu, rinoramba richikwira.
\c 75
\cl Pisarema 75
\d Kumutungamiri wokuimba namaimbiro okuti, “Regai kuparadza.” Pisarema raAsafi. Rwiyo.
\q1 
\v 1 Tinokuvongai, imi Mwari, tinokuvongai,
\q2 nokuti Zita renyu riri pedyo;
\q2 vanhu vanotaura nezvamabasa enyu anoshamisa.
\b
\q1 
\v 2 Imi munoti, “Ndinosarudza nguva yakatarwa;
\q2 ndini ndinotonga zvakarurama.
\q1 
\v 3 Panozununguka nyika yose navanhu vayo,
\q2 ini ndini ndinobata mbiru dzayo zvakasimba. \qs Sera \qs*
\q1 
\v 4 Kuna vanozvikudza ndinoti, ‘Regai kuzvikudzazve,’
\q2 uye kuna vakaipa, ndinoti, ‘Regai kusimudza nyanga dzenyu.
\q1 
\v 5 Regai kusimudzira nyanga dzenyu kudenga;
\q2 regai kutaura nemitsipa mikukutu.’ ”
\b
\q1 
\v 6 Hakuna munhu anobva kumabvazuva kana kumavirira,
\q2 kana anobva kugwenga angasimudzira munhu.
\q1 
\v 7 Asi Mwari ndiye anotonga:
\q2 Anoderedza mumwe, achisimudzira mumwe.
\q1 
\v 8 Muruoko rwaJehovha mune mukombe
\q2 uzere newaini inopupuma, yakavhenganiswa nezvinonhuhwira;
\q1 anoidururira pasi, uye vakaipa vose vapanyika
\q2 vanoinwa kusvikira pamasese ayo.
\b
\q1 
\v 9 Kana ndirini, ndichaparidza izvi nokusingaperi;
\q2 ndichaimbira Mwari waJakobho rwiyo rwokurumbidza.
\q1 
\v 10 Ndichagura nyanga dzavakaipa vose,
\q2 asi nyanga dzavakarurama dzichasimudzirwa kumusoro.
\c 76
\cl Pisarema 76
\d Kumutungamiri wokuimba nomutengeranwa une hungiso. Pisarema raAsafi. Rwiyo.
\q1 
\v 1 Mwari anozivikanwa muJudha;
\q2 zita rake iguru muIsraeri.
\q1 
\v 2 Tende rake riri muSaremu,
\q2 ugaro hwake paZioni.
\q1 
\v 3 Ndipo paakavhuna miseve inovaima,
\q2 nhoo neminondo, izvo zvombo zvokurwa. \qs Sera \qs*
\b
\q1 
\v 4 Imi makashongedzwa nechiedza,
\q2 kupfuura makomo akapfuma nemhuka.
\q1 
\v 5 Varume vakashinga vakavata pasi vapambwa,
\q2 vakavata hope dzavo dzokupedzisira;
\q1 hakuna mumwe wavarwi
\q2 angasimudza maoko ake.
\q1 
\v 6 Pakutuka kwenyu, imi Mwari waJakobho,
\q2 zvose bhiza nengoro zvinovata zvakati mwiro.
\q1 
\v 7 Imi moga ndimi munofanira kutyiwa.
\q2 Mukatsamwa, ndianiko angamira pamberi penyu?
\q1 
\v 8 Muri kudenga makazivisa kutonga kwenyu,
\q2 uye nyika yakatya ikanyarara,
\q1 
\v 9 haiwa Mwari, pamakasimuka kuti mutonge,
\q2 kuti muponese vanonetswa vose venyika. \qs Sera \qs*
\q1 
\v 10 Zvirokwazvo hasha dzenyu pamusoro pavanhu dzinokuvigirai kurumbidzwa,
\q2 uye vanosara pahasha dzenyu vachadziviswa.
\b
\q1 
\v 11 Itai mhiko kuna Jehovha Mwari wenyu mugodzizadzisa;
\q2 nyika dzose dzakakupoteredzai
\q2 ngadzivigire zvipo kuna Iye anofanira kutyiwa.
\q1 
\v 12 Anoputsa mweya yavatongi;
\q2 anotyiwa namadzimambo enyika.
\c 77
\cl Pisarema 77
\d Kumutungamiri wokuimba. Kuna Jedhutuni. Pisarema raAsafi.
\q1 
\v 1 Ndakadanidzira kuna Mwari kuti andibatsire;
\q2 ndakadana kuna Mwari kuti andinzwe.
\q1 
\v 2 Pandakanga ndiri pakutambudzika, ndakatsvaka Ishe;
\q2 panguva yousiku ndakatambanudza maoko angu asinganeti,
\q2 uye mweya wangu wakaramba kunyaradzwa.
\b
\q1 
\v 3 Haiwa Mwari, ndakakurangarirai, uye ndikagomera;
\q2 ndakafungisisa, mweya wangu ukaziya. \qs Sera \qs*
\q1 
\v 4 Makakonesa meso angu kutsinzina;
\q2 ndakatambudzika zvokuti ndakatadza kutaura.
\q1 
\v 5 Ndakarangarira mazuva ekare,
\q2 makore ekare kare;
\q1 
\v 6 ndakarangarira nziyo dzangu panguva yousiku.
\q2 Mwoyo wangu wakafungisisa uye mweya wangu wakabvunza ukati,
\b
\q1 
\v 7 “Ko, Ishe acharamba nokusingaperi here?
\q2 Haachazombonzwiri ngonizve here?
\q1 
\v 8 Ko, rudo rwake rusingaperi rwakabva nokusingaperi here?
\q2 Chipikirwa chake chakakona nokusingaperi here? \qs Sera \qs*
\q1 
\v 9 Ko, Mwari akanganwa kuva nenyasha here?
\q2 Mukutsamwa kwake haachaitira tsiye dzake nyoro here?”
\b
\q1 
\v 10 Ipapo ndakafunga ndikati, “Ndichakumbira hangu pane izvozvi:
\q2 makore oruoko rworudyi reWokumusoro-soro.”
\q1 
\v 11 Ndicharangarira mabasa aJehovha;
\q2 hongu, ndicharangarira zvishamiso zvenyu zvakare kare.
\q1 
\v 12 Ndichafungisisa pamusoro pamabasa enyu ose,
\q2 uye ndicharangarira mabasa enyu makuru.
\b
\q1 
\v 13 Haiwa Mwari, nzira dzenyu itsvene.
\q2 Ndoupiko mwari mukuru saMwari wedu?
\q1 
\v 14 Muri Mwari anoita zvishamiso;
\q2 munoratidza simba renyu pakati pavanhu.
\q1 
\v 15 Noruoko rwenyu rune simba,
\q2 makadzikinura vanhu venyu, izvo zvizvarwa zvaJakobho naJosefa. \qs Sera \qs*
\b
\q1 
\v 16 Mvura zhinji yakakuonai, imi Mwari,
\q2 mvura zhinji yakakuonai ikatya;
\q2 kwakadzika chaiko kwakabvunda.
\q1 
\v 17 Makore akadurura mvura,
\q2 kumatenga kwakaunga nokutinhira;
\q2 miseve yenyu yakapenya kuno nokoko.
\q1 
\v 18 Kutinhira kwenyu kwakanzwika muchamupupuri,
\q2 kupenya kwenyu kwakavhenekera nyika;
\q2 nyika yakadedera ikadengenyeka.
\q1 
\v 19 Gwara renyu rakapinda nomugungwa,
\q2 nzira yenyu ikapinda nomumvura zhinji zhinji,
\q2 kunyange zvazvo tsoka dzenyu dzakanga dzisingaonekwi.
\b
\q1 
\v 20 Makatungamirira vanhu venyu seboka ramakwai
\q2 noruoko rwaMozisi naAroni.
\c 78
\cl Pisarema 78
\d Masikiri raAsafi.
\q1 
\v 1 Haiwa vanhu vangu, inzwai kudzidzisa kwangu;
\q2 teererai mashoko omuromo wangu.
\q1 
\v 2 Ndichashamisa muromo wangu nditaure nomufananidzo,
\q2 ndichataura zvinhu zvakavanzika, zvinhu zvakare kare,
\q1 
\v 3 zvatakanzwa nezvatakaziva,
\q2 zvatakaudzwa namadzibaba edu.
\q1 
\v 4 Hatingazozvivanziri vana vavo;
\q2 tichaudza rudzi runotevera
\q1 mabasa angarumbidzwa aJehovha,
\q2 simba rake, nezvishamiso zvaakaita.
\q1 
\v 5 Akatema zvirevo zvaJakobho
\q2 akasimbisa murayiro muIsraeri,
\q1 waakarayira madzitateguru edu
\q2 kuti vadzidzise vana vavo,
\q1 
\v 6 kuti rudzi runotevera ruzvizive,
\q2 kunyange vana vachazoberekwa,
\q2 naivo vagozoudzawo vana vavo.
\q1 
\v 7 Ipapo vachavimba naMwari wavo
\q2 uye havangazokanganwi mabasa ake
\q2 asi vachazochengeta mirayiro yake.
\q1 
\v 8 Havazofanani namadzitateguru avo,
\q2 rudzi rwakanga rwakasindimara uye rwaimumukira,
\q1 mwoyo yavo yakanga isingateereri Mwari,
\q2 mweya yavo yakanga isina kutendeka kwaari.
\b
\q1 
\v 9 Vanhu vokwaEfuremu, kunyange vakanga vakapakata uta,
\q2 vakadzokera shure pazuva rokurwa;
\q1 
\v 10 havana kuchengeta sungano yaMwari,
\q2 uye vakaramba kufamba maererano nomurayiro wake.
\q1 
\v 11 Vakakanganwa zvaakaita,
\q2 zvishamiso zvaakavaratidza.
\q1 
\v 12 Akaita zviratidzo pamberi pamadzibaba avo
\q2 munyika yeIjipiti, mudunhu reZoani.
\q1 
\v 13 Akapamura gungwa akavayambutsa napakati;
\q2 akaita kuti mvura imire yakasimba sorusvingo.
\q1 
\v 14 Akavatungamirira negore masikati,
\q2 uye nechiedza chomoto usiku hwose.
\q1 
\v 15 Akapamura ruware mugwenga
\q2 akavapa mvura yakawanda seyamakungwa;
\q1 
\v 16 akabudisa hova dzemvura paruware
\q2 akaita kuti iyerere seyenzizi.
\b
\q1 
\v 17 Asi vakaramba vachingomutadzira,
\q2 vachimukira Wokumusoro-soro mugwenga.
\q1 
\v 18 Vakaedza Mwari nobwoni
\q2 vachimugombedzera kuti avape zvokudya zvavaipanga.
\q1 
\v 19 Vakapopotera Mwari, vachiti,
\q2 “Ko, Mwari angawadzira tafura mugwenga here?
\q1 
\v 20 Paakarova dombo, mvura yakatubuka,
\q2 uye hova dzakayerera mvura zhinji.
\q1 Asi angagona kutipawo zvokudya here?
\q2 Angavigira vanhu vake nyama here?”
\q1 
\v 21 Jehovha akati avanzwa, akatsamwa zvikuru kwazvo;
\q2 moto wake ukaveserwa Jakobho,
\q2 uye hasha dzake dzikamukira Israeri,
\q1 
\v 22 nokuti havana kutenda muna Mwari
\q2 kana kuvimba nokurwira kwake.
\q1 
\v 23 Asi akarayira matenga kumusoro
\q2 akazarura makonhi okumatenga;
\q1 
\v 24 akanayisa mana kuti vanhu vadye,
\q2 akavapa zviyo zvokudenga.
\q1 
\v 25 Vanhu vakadya chingwa chavatumwa;
\q2 akavatumira zvokudya zvose zvavaigona kudya.
\q1 
\v 26 Akazarura mhepo yokumabvazuva kubva kudenga,
\q2 uye akafambisa mhepo yakabva zasi nesimba rake.
\q1 
\v 27 Akavanayisira nyama pamusoro pavo seguruva,
\q2 shiri dzinobhururuka dzakaita sejecha rokumhenderekedzo yegungwa.
\q1 
\v 28 Akaita kuti dziburukire mumisasa yavo,
\q2 dzakapoteredza matende avo ose.
\q1 
\v 29 Vakadya kusvikira vaguta kwazvo,
\q2 nokuti akanga avapa zvavakanga vachipanga.
\q1 
\v 30 Asi vasati vafuratira chokudya chavaikarira,
\q2 kunyange pachakanga chichiri pamiromo yavo,
\q1 
\v 31 kutsamwa kwaMwari kwakavamukira;
\q2 akauraya vakanga vakanyanya kusimba pakati pavo,
\q2 akaparadza majaya eIsraeri.
\b
\q1 
\v 32 Kunyange zvakadaro, vakaramba vachingotadza;
\q2 kunyange zvazvo zviratidzo zvake izvi zvaivapo, havana kutenda.
\q1 
\v 33 Saka akagumisa mazuva avo nezvisina maturo,
\q2 uye makore avo mukutya.
\q1 
\v 34 Pose pavaiurayiwa naMwari, ndipo pavaimutsvaka;
\q2 vaishingairira kudzokerazve kwaari.
\q1 
\v 35 Vakarangarira kuti Mwari ndiye Dombo ravo,
\q2 kuti Mwari Wokumusoro-soro ndiye Mudzikinuri wavo.
\q1 
\v 36 Asizve vaingomubata kumeso nemiromo yavo,
\q2 vachimurevera nhema nendimi dzavo;
\q1 
\v 37 mwoyo yavo yakanga isina kutendeka kwaari,
\q2 vakanga vasina kutendeka pasungano yake.
\q1 
\v 38 Kunyange zvakadaro
\q2 iye akavanzwira tsitsi;
\q2 akavakanganwira kuipa kwavo akasavaparadza.
\q1 Nguva nenguva akadzora kutsamwa kwake,
\q2 uye haana kumutsa hasha dzake dzose.
\q1 
\v 39 Akarangarira kuti ivo vaingova nyama bedzi,
\q2 mhepo inopfuura isingadzoki.
\b
\q1 
\v 40 Vakamumukira mugwenga kazhinji sei,
\q2 uye vakamuitisa shungu murenje!
\q1 
\v 41 Vakaedza Mwari vamuedzazve;
\q2 vakagumbusa Iye Mutsvene waIsraeri.
\q1 
\v 42 Havana kurangarira simba rake,
\q2 zuva raakavadzikinura kubva pamudzvinyiriri,
\q1 
\v 43 zuva raakaratidza zviratidzo zvake zvinoshamisa muIjipiti,
\q2 zvishamiso zvake mudunhu reZoani.
\q1 
\v 44 Akashandura nzizi dzavo dzikava ropa;
\q2 havana kugona kunwa muhova dzavo.
\q1 
\v 45 Akavatumira mapupira enhunzi dzikavaparadza,
\q2 uye matatya akavaparadza zvikuru.
\q1 
\v 46 Akapa zviyo zvavo kumagutaguta
\q2 nezvibereko zvavo kumhashu.
\q1 
\v 47 Akaparadza mazambiringa avo nechimvuramabwe,
\q1 uye namaonde emionde yavo nechando.
\q1 
\v 48 Mombe dzavo akadziisa kuchimvuramabwe,
\q2 nezvipfuwo zvavo kukurova kwemheni.
\q1 
\v 49 Akaregedzera kutsamwa kwake kukuru pamusoro pavo,
\q2 hasha dzake, shungu dzake noukasha hwake,
\q2 boka ravatumwa vokuparadza.
\q1 
\v 50 Akagadzira nzira yokutsamwa kwake;
\q2 haana kuponesa mweya yavo parufu asi akavaisa kudenda.
\q1 
\v 51 Akauraya matangwe ose eIjipiti,
\q2 chibereko chokutanga chomurume pamatende aHamu.
\q1 
\v 52 Asi akabudisa vanhu vake seboka ramakwai;
\q2 akavatungamirira samakwai nomugwenga.
\q1 
\v 53 Akavafambisa norugare,
\q2 asi gungwa rakamedza vavengi vavo.
\q1 
\v 54 Saizvozvo akavasvitsa kumuganhu wenyika yake tsvene,
\q2 kunyika yamakomo yaakatora noruoko rwake rworudyi.
\q1 
\v 55 Akadzinga ndudzi mberi kwavo,
\q2 akagovera nyika yavo kwavari senhaka;
\q2 akagarisa rudzi rwaIsraeri mudzimba dzavo.
\b
\q1 
\v 56 Asi vakaedza Mwari
\q2 uye vakamukira Wokumusoro-soro;
\q2 vakasachengeta zvirevo zvake.
\q1 
\v 57 Vakanga vasingazvirereki uye vasina kutendeka samadzibaba avo,
\q2 vasingavimbiki souta hunonyengera.
\q1 
\v 58 Vakamutsamwisa nenzvimbo dzavo dzakakwirira;
\q2 vakamutsa godo rake nokuda kwezvifananidzo zvavo.
\q1 
\v 59 Mwari akati avanzwa akatsamwa zvikuru kwazvo;
\q2 akaramba Israeri zvachose.
\q1 
\v 60 Akasiya tabhenakeri yeShiro,
\q2 iyo tende yaakanga amisa pakati pavanhu.
\q1 
\v 61 Akaendesa areka yesimba rake kuutapwa,
\q2 kubwinya kwake mumaoko omuvengi.
\q1 
\v 62 Akaisa vanhu vake kumunondo;
\q2 akatsamwira nhaka yake zvikuru kwazvo.
\q1 
\v 63 Moto wakaparadza majaya avo,
\q2 uye varandakadzi vavo vakashayiwa nziyo dzesvitsa;
\q1 
\v 64 vaprista vavo vakanga vaiswa kumunondo,
\q2 uye chirikadzi dzavo hadzina kugona kuchema.
\b
\q1 
\v 65 Ipapo Ishe akamuka somunhu anga akakotsira,
\q2 somunhu amuka pakubatwa newaini.
\q1 
\v 66 Akarova vavengi vake vakadzokera shure;
\q2 akavanyadzisa nokusingaperi.
\q1 
\v 67 Ipapo akaramba matende aJosefa,
\q2 haana kusarudza rudzi rwaEfuremu;
\q1 
\v 68 asi akasarudza rudzi rwaJudha,
\q2 Gomo reZioni, raakada.
\q1 
\v 69 Akavaka nzvimbo yake tsvene senhare yakakwirira,
\q2 senyika yaakasimbisa nokusingaperi.
\q1 
\v 70 Akasarudza Dhavhidhi muranda wake,
\q2 akamutora kumatanga amakwai;
\q1 
\v 71 akamubvisa pakufudza makwai
\q2 kuti ave mufudzi wavanhu vake Jakobho,
\q2 vaIsraeri nhaka yake.
\q1 
\v 72 Uye Dhavhidhi akavafudza nokururama kwomwoyo;
\q2 akavatungamirira namaoko ouchenjeri.
\c 79
\cl Pisarema 79
\d Pisarema raAsafi.
\q1 
\v 1 Haiwa Mwari, ndudzi dzapinda panhaka yenyu;
\q2 vakasvibisa temberi yenyu tsvene,
\q2 Jerusarema varideredza rikava marara.
\q1 
\v 2 Vakapa mitumbi yavaranda venyu
\q2 sezvokudya zveshiri dzedenga,
\q2 nyama yavatsvene venyu kuzvikara zvenyika.
\q1 
\v 3 Vakateura ropa kunge mvura
\q2 paJerusarema rose,
\q2 uye hakuna munhu anoviga zvitunha.
\q1 
\v 4 Tiri chinhu chinoshorwa navatigere navo,
\q2 chinosekwa nechinozvidzwa kuna avo vakatipoteredza.
\b
\q1 
\v 5 Haiwa Jehovha, mucharamba makatitsamwira nokusingaperi kusvikira riniko?
\q2 Godo renyu richapisa somoto kusvikira riniko?
\q1 
\v 6 Dururirai hasha dzenyu pamusoro pendudzi dzisingakuzive,
\q2 napaushe husingadani kuzita renyu;
\q1 
\v 7 nokuti vakapedza Jakobho
\q2 uye vakaparadza nyika yokwake.
\q1 
\v 8 Regai kuverengera pamusoro pedu zvivi zvamadzibaba;
\q2 tsitsi dzenyu ngadzikurumidze kuuya kuzosangana nesu,
\q2 nokuti tiri pakutambudzika.
\b
\q1 
\v 9 Tibatsirei, imi Mwari Muponesi wedu,
\q2 nokuda kwokukudzwa kwezita renyu;
\q1 tirwirei mutiregerere zvivi zvedu
\q2 nokuda kwezita renyu.
\q1 
\v 10 Ndudzi dzichataurireiko dzichiti,
\q2 “Mwari wavo aripi?”
\q1 Zivisai pakati pendudzi, pamberi pedu,
\q2 kuti munotsiva ropa ravaranda venyu rakateurwa.
\q1 
\v 11 Kugomera kwavasungwa ngakusvike pamberi penyu;
\q2 nesimba roruoko rwenyu
\q2 chengetedzai avo vakatongerwa rufu.
\b
\q1 
\v 12 Mutsive kanomwe pamabvi avavakidzani vedu,
\q2 kutuka kwavakaita zita renyu, imi Ishe.
\q1 
\v 13 Ipapo vanhu venyu, makwai amafuro enyu,
\q2 vachakurumbidzai nokusingaperi;
\q1 kubva kune chimwe chizvarwa kusvikira kune chimwe chizvarwa,
\q2 ticharondedzera nezvokurumbidzwa kwenyu.
\c 80
\cl Pisarema 80
\d Kumutungamiri wokuimba nomuimbiro wa “Maruva amahapa eSungano.” Pisarema raAsafi.
\q1 
\v 1 Tinzwei, imi Mufudzi weIsraeri,
\q2 imi makatungamirira Josefa seboka ramakwai;
\q1 iyemi munogara pachigaro choushe pakati pamakerubhi, penyai
\q2 
\v 2 pamberi paEfuremu, Bhenjamini naManase.
\q1 Mutsai simba renyu;
\q2 uyai mutiponese.
\b
\q1 
\v 3 Tidzorei, imi Mwari,
\q2 penyesai chiso chenyu pamusoro pedu,
\q2 kuti tiponeswe.
\b
\q1 
\v 4 Haiwa Jehovha Mwari Wamasimba Ose,
\q2 kutsamwa kwenyu kucharamba kuchipisa
\q2 pamusoro peminyengetero yavanhu venyu kusvikira riniko?
\q1 
\v 5 Makavapa chingwa chemisodzi kuti vadye;
\q2 makaita kuti vanwe misodzi yakawanda.
\q1 
\v 6 Makatiita mavambo enharo kuna vatigere navo,
\q2 uye vavengi vedu vanotiseka.
\b
\q1 
\v 7 Tidzorei, imi Mwari Wamasimba Ose;
\q2 penyesai chiso chenyu pamusoro pedu,
\q2 kuti tiponeswe.
\b
\q1 
\v 8 Makabudisa muzambiringa kubva muIjipiti;
\q2 makadzinga ndudzi mukaudyara.
\q1 
\v 9 Makaukurira nzvimbo,
\q2 uye ukava nemidzi ukazadza nyika.
\q1 
\v 10 Makomo akanga akafukidzwa nomumvuri wawo,
\q2 nemisidhari mikuru namatavi awo.
\q1 
\v 11 Wakatandavadza matavi awo kusvikira kuGungwa,
\q2 namabukira awo kusvikira kuRwizi.
\b
\q1 
\v 12 Seiko makaputsa masvingo awo
\q2 kuti vose vanopfuura napo vanonge mazambiringa awo?
\q1 
\v 13 Nguruve dzinobva musango dzinouparadza,
\q2 uye zvisikwa zvesango zvinoudya.
\q1 
\v 14 Dzokerai kwatiri, imi Mwari Wamasimba Ose!
\q2 Tarirai muri kudenga muone!
\q1 Rindai muzambiringa uyu,
\q2 
\v 15 iwo mudzi wakasimwa noruoko rwenyu rworudyi,
\q2 mwanakomana wamakazvirerera.
\b
\q1 
\v 16 Muzambiringa wenyu watemerwa pasi, wapiswa nomoto;
\q2 pakutuka kwenyu, vanhu venyu vanofa.
\q1 
\v 17 Ruoko rwenyu rworudyi ngarugare pamusoro pomunhu ari kurudyi kwenyu,
\q2 mwanakomana womunhu wamakazvirerera.
\q1 
\v 18 Ipapo hatingazobvi kwamuri;
\q2 timutsiridzei, tigodana kuzita renyu.
\b
\q1 
\v 19 Tidzorei, imi Mwari Wamasimba Ose;
\q2 penyesai chiso chenyu pamusoro pedu,
\q2 kuti tiponeswe.
\c 81
\cl Pisarema 81
\d Kumutungamiri wokuimba. Namaimbirwo egititi. Pisarema raAsafi.
\q1 
\v 1 Imbirai Mwari nomufaro iye simba redu;
\q2 danidzirai kuna Mwari waJakobho!
\q1 
\v 2 Vambai rwiyo, muridze tambureni,
\q2 ridzai mbira dzinonakidza nomutengeranwa.
\b
\q1 
\v 3 Ridzai runyanga rwehwai paKugara kwoMwedzi,
\q2 uye pakuchena kwomwedzi, pazuva roMutambo wedu;
\q1 
\v 4 ichi ndicho chirevo chaIsraeri,
\q2 chakatarwa naMwari waJakobho.
\q1 
\v 5 Akachisimbisa somutemo wakanyorwa waJosefa
\q2 panguva yaakandorwa neIjipiti,
\q2 uko kwatakanzwa mutauro watakanga tisinganzwisisi.
\b
\q1 
\v 6 Iye anoti, “Ndakabvisa mutoro pamapfudzi avo;
\q2 maoko avo akasunungurwa padengu.
\q1 
\v 7 Pakutambudzika kwako wakadana ini ndikakununura,
\q2 ndakakupindura ndiri mugore rokutinhira;
\q2 ndakakuedza pamvura zhinji yeMeribha. \qs Sera \qs*
\b
\q1 
\v 8 “Inzwai, imi vanhu vangu, uye ndichakuyambirai,
\q2 kana mukada chete kunditeerera, imi Israeri!
\q1 
\v 9 Pakati penyu ngaparege kuva namwari wavatorwa,
\q2 musapfugamira mwari wokumwe.
\q1 
\v 10 Ndini Jehovha Mwari wako,
\q2 akakubudisa kubva munyika yeIjipiti.
\q2 Shamisa muromo wako kwazvo, ndigouzadza.
\b
\q1 
\v 11 “Asi vanhu vangu havana kuda kundinzwa,
\q2 Israeri haana kuda kuzviisa pasi pangu.
\q1 
\v 12 Saka ndakavaregera paukukutu hwemwoyo yavo,
\q2 kuti vatevere mano avo.
\b
\q1 
\v 13 “Kana vanhu vangu vakada kunditeerera,
\q2 kana Israeri akada kutevera nzira dzangu,
\q1 
\v 14 ndaikurumidza kukunda sei vavengi
\q2 vavo nokurova vavengi vavo noruoko rwangu!
\q1 
\v 15 Vaya vanovenga Jehovha vachatya pamberi pake,
\q2 uye kurangwa kwavo kuchagara nokusingaperi.
\q1 
\v 16 Asi imi muchagutswa nezviyo zvakaisvonaka;
\q2 uye ndichakugutsai nouchi hunobva padombo.”
\c 82
\cl Pisarema 82
\d Pisarema raAsafi.
\q1 
\v 1 Mwari anogara paungano huru;
\q2 anotonga pakati pa“vamwari” achiti,
\b
\q1 
\v 2 “Muchasvika riniko muchirwira vasakarurama
\q2 uye muchisanangura vanhu vakaipa? \qs Sera \qs*
\q1 
\v 3 Tongai mhaka dzavasina simba nenherera;
\q2 chengetedzai kodzero dzavarombo navakadzvinyirirwa.
\q1 
\v 4 Nunurai vasina simba navanoshayiwa;
\q2 varwirei paruoko rwowakaipa.
\b
\q1 
\v 5 “Havana chavanoziva, havana chavanonzwisisa.
\q2 Vanongofamba-famba murima;
\q2 nheyo dzose dzenyika dzinozungunuswa.
\b
\q1 
\v 6 “Ndakati, ‘Muri vamwari;
\q2 imi mose muri vanakomana veWokumusoro-soro.’
\q1 
\v 7 Asi muchafa savanhuwo zvavo;
\q2 muchawa savatongi vose.”
\b
\q1 
\v 8 Simukai, imi Mwari, mutonge nyika,
\q2 nokuti ndudzi dzose inhaka yenyu.
\c 83
\cl Pisarema 83
\d Rwiyo. Pisarema raAsafi.
\q1 
\v 1 Haiwa Mwari, regai kunyarara;
\q2 musanyarara, imi Mwari, musati mwiro.
\q1 
\v 2 Tarirai kumutswa kwaitwa vavengi venyu,
\q2 namasimudziro avaita misoro yavo.
\q1 
\v 3 Vakarangana nounyengeri pamusoro pavanhu venyu;
\q2 vanorangana pamusoro paavo vamunochengeta zvakanaka.
\q1 
\v 4 Ivo vanoti, “Uyai, ngativaparadzei sorudzi,
\q2 kuti zita raIsraeri rirove.”
\b
\q1 
\v 5 Vanorangana pamwe chete nomwoyo mumwe chete;
\q2 vanoita sungano yokuzorwa nemi,
\q1 
\v 6 matende eEdhomu nevaIshumaeri,
\q2 neMoabhu navaHagari,
\q1 
\v 7 Gebha, Amoni neAmareki,
\q2 Firistia, navanhu veTire.
\q1 
\v 8 Kunyange neAsiria yabatana
\q2 navo kuti vasimbise zvizvarwa zvaRoti. \qs Sera \qs*
\b
\q1 
\v 9 Muvaitire sezvamakaitira vaMidhia,
\q2 sezvamakaita kuna Sisera naJabhini paRwizi Kishoni,
\q1 
\v 10 ivo vakafira paEndori
\q2 uye vakava sendove pamusoro pevhu.
\q1 
\v 11 Muite makurukota avo saOrebhu naZibhi,
\q2 machinda avo ose saZebha naZarumuna,
\q1 
\v 12 ivo vakati, “Handei tindotora
\q2 mafuro aMwari.”
\b
\q1 
\v 13 Haiwa Mwari wangu, vaitei sendira,
\q2 sehundi inodzingwa nemhepo.
\q1 
\v 14 Somoto unopisa sango
\q2 kana moto unoririma mugomo,
\q1 
\v 15 saka vateverei nedutu renyu
\q2 mugovavhundutsa nokutinhira wenyu.
\q1 
\v 16 Fukidzai zviso zvavo nenyadzi
\q2 kuti vanhu vagotsvaka zita renyu, imi Jehovha.
\b
\q1 
\v 17 Ngavarambe vachinyadziswa
\q2 uye vavhundutswe; ngavafire munyadzi dzavo.
\q1 
\v 18 Ngavazive kuti imi, mune zita rinonzi Jehovha,
\q2 ndimi moga Wokumusoro-soro ari pamusoro penyika yose.
\c 84
\cl Pisarema 84
\d Kumutungamiri wokuimba namaimbirwo egititi. Pisarema ravanakomana vaKora.
\q1 
\v 1 Ugaro hwenyu hwakanaka sei,
\q2 imi Jehovha Wamasimba Ose!
\q1 
\v 2 Mweya wangu unopanga,
\q2 uye unotoziya, nokuda kwezvivanze zvaJehovha;
\q1 mwoyo wangu nenyama yangu
\q2 zvinodana kuna Mwari mupenyu.
\b
\q1 
\v 3 Kunyange shiri diki yakazviwanira imba,
\q2 nenyenganyenga yakazviwanirawo
\q2 dendere kwaingachochonyera vana vayo,
\q1 iyo nzvimbo iri pedyo nearitari yenyu,
\q2 imi Jehovha Wamasimba Ose, Mambo wangu naMwari wangu.
\q1 
\v 4 Vakaropafadzwa avo vanogara mumba menyu;
\q2 vanogara vachikurumbidzai. \qs Sera \qs*
\b
\q1 
\v 5 Vakaropafadzwa avo vane simba ravo mamuri,
\q2 vakaisa mwoyo yavo parwendo rweZioni.
\q1 
\v 6 Pavanopfuura nomuMupata weBhaka,
\q2 vanouita nzvimbo yamatsime;
\q2 mvura yomuzhizha inouzadzawo namadziva.
\q1 
\v 7 Vanowedzera simba pasimba,
\q2 kusvikira mumwe nomumwe wavo amira pamberi paMwari muZioni.
\b
\q1 
\v 8 Inzwai munyengetero wangu, imi Jehovha Mwari Wamasimba Ose;
\q2 rerekerai nzeve yenyu kwandiri, imi Mwari waJakobho. \qs Sera \qs*
\q1 
\v 9 Haiwa Mwari, tariraiwo nhoo yedu;
\q2 ringirai nenyasha dzenyu pamuzodziwa wenyu.
\b
\q1 
\v 10 Zviri nani kuva pavazhe dzenyu kwezuva rimwe chete,
\q2 kupfuura mazuva zviuru ndiri kumwe;
\q1 ndingada zvangu kuva murindi womukova weimba yaMwari
\q2 wangu kukunda kugara mumatende avakaipa.
\q1 
\v 11 Nokuti Jehovha Mwari ndiye zuva nenhoo;
\q2 Jehovha anopa nyasha nokukudzwa;
\q1 hapana chinhu chakanaka chaanganyima
\q2 avo vanofamba zvakarurama.
\b
\q1 
\v 12 Haiwa Jehovha Wamasimba Ose,
\q2 akaropafadzwa munhu anovimba nemi.
\c 85
\cl Pisarema 85
\d Kumutungamiri wokuimba waVanakomana vaKora. Pisarema.
\q1 
\v 1 Makanzwira nyasha nyika yenyu, imi Jehovha;
\q2 makadzosera Jakobho nhaka yake.
\q1 
\v 2 Makakanganwira kutadza kwavanhu venyu,
\q2 uye mukafukidza zvivi zvavo zvose. \qs Sera \qs*
\q1 
\v 3 Makaisa parutivi hasha dzenyu dzose,
\q2 mukadzoka pakutsamwa kwenyu kunotyisa.
\b
\q1 
\v 4 Tidzoreizve, imi Mwari Muponesi wedu,
\q2 mugoisa kure nemi kusafara kwenyu pamusoro pedu.
\q1 
\v 5 Mucharamba makatitsamwira nokusingaperi here?
\q2 Mucharega kutsamwa kwenyu kuripo kusvikira kuzvizvarwa zvose here?
\q1 
\v 6 Ko, hamungatimutsiridzizve here,
\q2 kuti vanhu venyu vagofara mamuri?
\q1 
\v 7 Tiratidzei ngoni dzenyu, imi Jehovha,
\q2 mugotipawo ruponeso rwenyu.
\b
\q1 
\v 8 Ndichateerera zvichataurwa naJehovha Mwari;
\q2 anovimbisa rugare kuvanhu vake, vatsvene vake,
\q2 asi ngavasadzokerazve kuupenzi.
\q1 
\v 9 Chokwadi, ruponeso rwake rwuri pedyo navanomutya,
\q2 kuti kubwinya kwake kugogara munyika yedu.
\b
\q1 
\v 10 Rudo nokutendeka zvinosangana pamwe chete;
\q2 kururama norugare zvinosvetana.
\q1 
\v 11 Kutendeka kunomera panyika,
\q2 kururama kunotarira pasi kuri kudenga.
\q1 
\v 12 Chokwadi, Jehovha achapa zvinhu zvakanaka,
\q2 uye nyika yedu ichabereka mukoho wayo.
\q1 
\v 13 Kururama kuchamutungamirira,
\q2 uye kuchamugadzirira nzira yetsoka dzake.
\c 86
\cl Pisarema 86
\d Munyengetero waDhavhidhi.
\q1 
\v 1 Inzwai, imi Jehovha, mundipindure,
\q2 nokuti ndiri murombo uye ndinoshayiwa.
\q1 
\v 2 Chengetai upenyu hwangu, nokuti ndakazvipa kwamuri.
\q2 Muri Mwari wangu;
\q2 ponesai muranda wenyu anovimba nemi.
\q1 
\v 3 Ndinzwirei ngoni, imi Ishe,
\q2 nokuti ndinodana kwamuri zuva rose.
\q1 
\v 4 Vigirai muranda wenyu mufaro,
\q2 nokuti kwamuri, imi Ishe,
\q2 ndinosimudzira mweya wangu.
\b
\q1 
\v 5 Imi munokanganwira uye makanaka, imi Ishe,
\q2 muzere norudo kuna vose vanodana kwamuri.
\q1 
\v 6 Inzwai munyengetero wangu, imi Jehovha;
\q2 inzwai kuchemera kwangu ngoni dzenyu.
\q1 
\v 7 Ndichadana kwamuri pazuva rokutambudzika kwangu,
\q2 nokuti muchandipindura.
\b
\q1 
\v 8 Haiwa Ishe, hakuna akafanana nemi pakati pavamwari;
\q2 hakuna mabasa akaita seenyu.
\q1 
\v 9 Ndudzi dzose dzamakaita dzichauya
\q2 kuzonamata pamberi penyu, imi Ishe;
\q2 dzicharumbidza zita renyu.
\q1 
\v 10 Nokuti imi muri mukuru uye munoita zvinhu zvinoshamisa;
\q2 imi moga ndimi Mwari.
\b
\q1 
\v 11 Haiwa Jehovha, ndidzidzisei nzira yenyu,
\q2 uye ndichafamba muzvokwadi yenyu;
\q1 ndipei mwoyo mumwe,
\q2 kuti ndigotya zita renyu.
\q1 
\v 12 Ndichakurumbidzai, imi Ishe Mwari wangu, nomwoyo wangu wose;
\q2 ndicharumbidza zita renyu nokusingaperi.
\q1 
\v 13 Nokuti rudo rwenyu rukuru kwandiri;
\q2 makandirwira paguva rakadzika.
\b
\q1 
\v 14 Haiwa Mwari, vanozvikudza vari kundirwisa;
\q2 boka ravanhu vane utsinye rinotsvaka upenyu hwangu,
\q2 vanhu vasina hanya nemi.
\q1 
\v 15 Asi, imi Ishe, mune tsitsi uye muri Mwari ane nyasha,
\q2 anononoka kutsamwa, azere norudo nokutendeka.
\q1 
\v 16 Dzokerai kwandiri mundinzwire ngoni;
\q2 ipai simba renyu kumuranda wenyu,
\q2 uye muponese mwanakomana womurandakadzi wenyu.
\q1 
\v 17 Ndipei chiratidzo chokunaka kwenyu,
\q2 kuti vavengi vangu vazvione vagonyadziswa,
\q2 nokuti imi Jehovha makandibatsira uye mukandinyaradza.
\c 87
\cl Pisarema 87
\d Zvavanakomana vaKora. Pisarema. Rwiyo.
\q1 
\v 1 Akateya nheyo dzake pagomo dzvene;
\q2 
\v 2 Jehovha anoda masuo eZioni
\q2 kupfuura pose panogara Jakobho.
\q1 
\v 3 Zvinhu zvakaisvonaka zvinotaurwa pamusoro pako,
\q2 iwe guta raMwari: \qs Sera \qs*
\q1 
\v 4 “Ndichanyora nezvaRahabhi neBhabhironi
\q2 pakati pavanondiziva,
\q1 neFiristiawo neTire, pamwe chete neEtiopia,
\q2 uye vachati, ‘Uyu akaberekerwa muZioni.’ ”
\b
\q1 
\v 5 Zvirokwazvo, pamusoro peZioni vachati,
\q2 “Uyu nowoyo vakaberekerwamo,
\q2 uye Wokumusoro-soro pachake acharisimbisa.”
\q1 
\v 6 Jehovha achanyora panonyorwa mazita amarudzi,
\q1 kuti, “Uyu akaberekerwa muZioni.” \qs Sera \qs*
\q1 
\v 7 Pavanoimba, vachaimba vachiti,
\q2 “Matsime angu ose ari mamuri.”
\c 88
\cl Pisarema 88
\d Rwiyo. Pisarema ravanakomana vaKora. Kumutungamiri wokuimba namaimbirwo emaharati reanoti. Masikiri raHemani muEzrahi.
\q1 
\v 1 Haiwa Jehovha, Mwari anondiponesa,
\q2 ndakachema masikati nousiku pamberi penyu.
\q1 
\v 2 Munyengetero wangu ngausvike pamberi penyu;
\q2 rerekerai nzeve yenyu kukuchema kwangu.
\b
\q1 
\v 3 Nokuti mweya wangu uzere nokutambudzika,
\q2 uye upenyu hwangu hwaswedera pedyo neguva.
\q1 
\v 4 Ndinoverengwa pakati paavo vakaburukira kugomba;
\q2 ndava somunhu asina simba.
\q1 
\v 5 Ndakatsaurwa pamwe chete navakafa,
\q2 savakaurayiwa vavete muguva,
\q1 vamusingacharangaririzve,
\q2 vakagurwa kubva pakuchengeta kwenyu.
\b
\q1 
\v 6 Makandiisa mugomba rakadzika dzika,
\q2 murima guru makadzika dzika.
\q1 
\v 7 Hasha dzenyu dzinorema kwazvo pamusoro pangu,
\q2 makandifukidza namafungu enyu ose. \qs Sera \qs*
\q1 
\v 8 Makanditorera shamwari dzangu dzapedyo,
\q2 uye mukandiita chinhu chinonyangadza.
\q1 Ndakapfigirwa uye handingatongopunyuki;
\q2 
\v 9 meso angu asviba neshungu.
\b
\q1 Ndinodana kwamuri, imi Jehovha, mazuva ose;
\q2 ndinotambanudzira maoko angu kwamuri.
\q1 
\v 10 Ko, munoratidza zvishamiso zvenyu kuna vakafa here?
\q2 Ko, vakafa vanomuka vachikurumbidzai here? \qs Sera \qs*
\q1 
\v 11 Ko, rudo rwenyu runoparidzwa muguva,
\q2 nokutendeka kwenyu mukuparadzwa here?
\q1 
\v 12 Ko, zvishamiso zvenyu zvinozivikanwa munzvimbo yerima,
\q2 kana mabasa akarurama enyu munyika yokukanganwa here?
\b
\q1 
\v 13 Asi ndinochemera rubatsiro kwamuri, imi Jehovha;
\q2 mangwanani, munyengetero wangu unosvika pamberi penyu.
\q1 
\v 14 Seiko, imi Jehovha, muchindiramba
\q2 uye muchindivanzira chiso chenyu?
\b
\q1 
\v 15 Kubvira pauduku hwangu, ndakatambudzika zvokutosvika pedyo norufu;
\q2 ndatambudzika nokutyisa kwenyu uye handisisina tariro.
\q1 
\v 16 Hasha dzenyu dzakapfuura napamusoro pangu;
\q2 kutyisa kwenyu kwandiparadza.
\q1 
\v 17 Zuva rose zvakandipoteredza samafashamu;
\q2 ndakaputirwa nazvo chose.
\q1 
\v 18 Makanditorera shamwari dzangu navadikani vangu;
\q2 rima ndiyo shamwari yangu iri pedyo.
\c 89
\cl Pisarema 89
\d Masikiri raEtani muEzirahi.
\q1 
\v 1 Ndichaimba nezvorudo rukuru rwaJehovha nokusingaperi;
\q2 ndichazivisa kutendeka kwenyu nomuromo wangu kuzvizvarwa zvose.
\q1 
\v 2 Ndichaparidza kuti rudo rwenyu runomira rwakasimba nokusingaperi,
\q2 uye kuti muchasimbisa kutendeka kwenyu kudenga chaiko.
\b
\q1 
\v 3 Imi makati, “Ndakaita sungano nomusanangurwa wangu,
\q2 ndakapika kuna Dhavhidhi muranda wangu, ndichiti,
\q1 
\v 4 ‘Ndichasimbisa imba yako nokusingaperi,
\q2 uye ndichasimbisa chigaro chako choushe kuzvizvarwa zvose.’ ” \qs Sera \qs*
\b
\q1 
\v 5 Matenga anorumbidza zvishamiso zvenyu, imi Jehovha,
\q2 kutendeka kwenyuwo muungano yavatsvene.
\q1 
\v 6 Nokuti ndianiko kudenga kumusoro angaenzaniswa naJehovha?
\q2 Ndianiko akaita saJehovha pakati pezvisikwa zvokudenga?
\q1 
\v 7 Mwari anotyiwa zvikuru paungano yavatsvene;
\q2 iye anotyisa kwazvo kupfuura vose vakamupoteredza.
\q1 
\v 8 Haiwa Jehovha Mwari Wamasimba Ose, ndianiko akaita semi?
\q2 Mune simba, imi Jehovha, uye kutendeka kwenyu kunokupoteredzai.
\b
\q1 
\v 9 Munotonga pamusoro pokusunda kwegungwa;
\q2 mafungu aro paanosimuka, munoanyaradza.
\q1 
\v 10 Makapwanya Rahabhi somumwe wavakaurayiwa;
\q2 makaparadzira vavengi venyu noruoko rwenyu rune simba.
\q1 
\v 11 Matenga ndeenyu, nenyika ndeyenyuwo;
\q2 makavamba nyika nezvose zviri mairi.
\q1 
\v 12 Ndimi makasika kumusoro nezasi;
\q2 Tabhori neHerimoni zvinoimbira zita renyu nomufaro.
\q1 
\v 13 Ruoko rwenyu rune simba;
\q2 chanza chenyu chakasimba, ruoko rwenyu rworudyi rwakasimudzwa.
\b
\q1 
\v 14 Kururama nokururamisira ndidzo nheyo dzechigaro chenyu choushe;
\q2 rudo nokutendeka zvinokutungamirirai.
\q1 
\v 15 Vakaropafadzwa avo vakadzidza kukurumbidzai,
\q2 vanofamba muchiedza pamberi penyu, imi Jehovha.
\q1 
\v 16 Vanofara muzita renyu zuva rose;
\q2 vanofara mukururama kwenyu.
\q1 
\v 17 Nokuti imi ndimi kubwinya nesimba ravo,
\q2 uye nenyasha dzenyu munosimudzira runyanga rwedu.
\q1 
\v 18 Zvirokwazvo, nhoo yedu ndeyaJehovha,
\q2 mambo wedu, iye Mutsvene oga waIsraeri.
\b
\q1 
\v 19 Ipapo makataura muchiratidzo,
\q2 mukati, kuvanhu venyu vakatendeka:
\q1 “Ndakaisa simba pamusoro pemhare;
\q2 ndakasimudzira jaya pakati pavanhu.
\q1 
\v 20 Ndakawana Dhavhidhi muranda wangu;
\q2 ndakamuzodza namafuta matsvene.
\q1 
\v 21 Ruoko rwangu ruchamutsigira;
\q2 zvirokwazvo chanza changu chichamusimbisa.
\q1 
\v 22 Hakuna muvengi achamuripisa mutero;
\q2 hakuna munhu akaipa achamudzvinyirira.
\q1 
\v 23 Ndichapwanya vavengi vake pamberi pake,
\q2 uye ndicharovera pasi vadzivisi vake.
\q1 
\v 24 Rudo rwangu rwakatendeka ruchava naye,
\q2 uye runyanga rwake ruchasimudzirwa muzita rangu.
\q1 
\v 25 Ndichaisa ruoko rwake pamusoro pegungwa,
\q2 ruoko rwake rworudyi pamusoro penzizi.
\q1 
\v 26 Iye achadana kwandiri, achiti, ‘Ndimi Baba vangu,
\q2 Mwari wangu, Dombo noMuponesi wangu.’
\q1 
\v 27 Ndichamugadzawo kuti ave dangwe rangu,
\q2 iye anokudzwa zvikuru pamadzimambo enyika.
\q1 
\v 28 Ndichachengetedza rudo rwangu kwaari nokusingaperi,
\q2 uye sungano yangu naye haitongoperi.
\q1 
\v 29 Ndichasimbisa imba yake nokusingaperi,
\q2 uye nechigaro chake choushe chero matenga achingovapo.
\b
\q1 
\v 30 “Kana vana vake vakasiya murayiro wangu,
\q2 uye vakasatevera zvandakatema,
\q1 
\v 31 kana vakazvidza mitemo yangu,
\q2 uye vakakoniwa kuchengeta mirayiro yangu,
\q1 
\v 32 ndicharanga chivi chavo neshamhu,
\q2 uye kuipa kwavo nokurova kukuru;
\q1 
\v 33 asi handizobvisi rudo rwangu kwavari,
\q2 kana kuzombopandukira kutendeka kwangu.
\q1 
\v 34 Handizozvidzi sungano yangu
\q2 kana kushandura zvakarehwa nemiromo yangu.
\q1 
\v 35 Kamwe chete, ndakapika noutsvene hwangu,
\q2 uye handingarevi nhema kuna Dhavhidhi,
\q1 
\v 36 kuti imba yake icharamba iripo nokusingaperi
\q2 uye chigaro chake choushe chichagara pamberi pangu sezuva;
\q1 
\v 37 chichasimbiswa nokusingaperi somwedzi,
\q2 chapupu chakatendeka chiri kudenga.” \qs Sera \qs*
\b
\q1 
\v 38 Asi imi makaramba, makavenga,
\q2 makatsamwira kwazvo muzodziwa wenyu.
\q1 
\v 39 Makaparadza sungano yomuranda wenyu
\q2 uye mukasvibisa korona yake muguruva.
\q1 
\v 40 Makaputsa masvingo ake ose
\q2 mukaita nhare dzake matongo.
\q1 
\v 41 Vose vanopfuura napo vanomupamba;
\q2 ava chiseko chavavakidzani vake.
\q1 
\v 42 Makasimudzira ruoko rworudyi rwavavengi vake;
\q2 makaita kuti vavengi vake vose vafare.
\q1 
\v 43 Makadzosera shure munondo wake unopinza,
\q2 uye hamuna kumutsigira pakurwa.
\q1 
\v 44 Makagumisa kubwinya kwake,
\q2 mukawisira pasi chigaro chake choushe.
\q1 
\v 45 Makatapudza mazuva oujaya hwake;
\q2 makamufukidza nejasi renyadzi. \qs Sera \qs*
\b
\q1 
\v 46 Haiwa Jehovha kusvikira riniko? Muchazvivanza nokusingaperi here?
\q2 Hasha dzenyu dzichapisa somoto kusvikira riniko?
\q1 
\v 47 Rangarirai kuti upenyu hwangu hunopfuura sei.
\q2 Nokuti makasikira vanhu vose zvisina maturo!
\q1 
\v 48 Ko, munhu ndoupi angararama akasaona rufu,
\q2 kana angazviponesa pasimba reguva? \qs Sera \qs*
\q1 
\v 49 Haiwa Ishe, rudo rwenyu rukuru rwekare rwuripiko,
\q2 irwo rwamakapika nokutendeka kwenyu kuna Dhavhidhi?
\q1 
\v 50 Rangarirai, Ishe kuti muranda wenyu aisekwa sei,
\q2 kuti ndaitakura sei muchipfuva changu kutuka kwendudzi dzose,
\q1 
\v 51 kutuka uko vavengi venyu vaikusekai nako, imi Jehovha,
\q2 pavaiseka nhambwe imwe neimwe yomuzodziwa wenyu.
\b
\q1 
\v 52 Jehovha ngaarumbidzwe nokusingaperi!
\qc Ameni naAmeni.
\c 90
\ms1 BHUKU 4
\mr Mapisarema 90–106
\cl Pisarema 90
\d Munyengetero waMozisi munhu waMwari.
\q1 
\v 1 Jehovha, imi makava ugaro hwedu
\q2 kuzvizvarwa zvose.
\q1 
\v 2 Makomo asati azvarwa
\q2 uye musati mabudisa nyika nepasi rose,
\q2 kubva pakusingaperi kusvikira pakusingaperi muri Mwari.
\b
\q1 
\v 3 Munodzosera vanhu kuguruva zvakare, muchiti,
\q2 “Dzokerai kuguruva, imi vanakomana vavanhu.”
\q1 
\v 4 Nokuti pamberi penyu makore chiuru
\q2 akangofanana nezuva richangopfuura,
\q2 kana senguva yokurinda usiku.
\q1 
\v 5 Munokukura vanhu pakuvata kworufu;
\q2 vakaita sebundo idzva ramangwanani,
\q1 
\v 6 kunyange richimera riri idzva mangwanani,
\q2 nenguva yamadekwana rinenge raoma uye rasvava.
\b
\q1 
\v 7 Tapera nokutsamwa kwenyu
\q2 uye tinovhundutswa nehasha dzenyu.
\q1 
\v 8 Makaisa zvakaipa zvedu pamberi penyu,
\q2 makaisa zvivi zvedu zvakavanzika muchiedza chokuvapo kwenyu.
\q1 
\v 9 Mazuva edu ose anopfuura napasi pehasha dzenyu;
\q2 tinopedza makore edu nokuchema.
\q1 
\v 10 Uwandu hwamazuva edu hunosvika makore makumi manomwe,
\q2 kana makumi masere, kana tiine simba;
\q1 kunyange zvakadaro uwandu hwawo hunongova nhamo nokusuwa,
\q2 nokuti anokurumidza kupfuura, uye isu tobhururuka toenda.
\b
\q1 
\v 11 Ndianiko anoziva simba rokutsamwa kwenyu?
\q2 Nokuti hasha dzenyu dzakakura sokutyiwa kwakakufanirai imi.
\q1 
\v 12 Tidzidzisei kuverenga mazuva edu zvakanaka,
\q2 kuti tiwane mwoyo wouchenjeri.
\b
\q1 
\v 13 Dzokai, imi Jehovha! Zvichadaro kusvikira riniko?
\q2 Ivai netsitsi pamusoro pavaranda venyu.
\q1 
\v 14 Tigutsei mangwanani norudo rwenyu rusingaperi,
\q2 kuti tigoimba nomufaro tigofara mazuva edu ose.
\q1 
\v 15 Tifadzei zvinoenzana namazuva amakatitambudza,
\q2 samakore mazhinji atakaona nhamo.
\q1 
\v 16 Mabasa enyu ngaaratidzwe kuvaranda venyu,
\q2 nokubwinya kwenyu kuvana vavo.
\b
\q1 
\v 17 Nyasha dzaIshe Mwari wedu ngadzive pamusoro pedu;
\q2 tisimbisirei mabasa amaoko edu, hongu,
\q2 simbisai basa ramaoko edu.
\c 91
\cl Pisarema 91
\q1 
\v 1 Uyo anogara panzvimbo yokuvanda yeWokumusoro-soro
\q2 achazorora mumumvuri weWamasimba Ose.
\q1 
\v 2 Ndichati pamusoro paJehovha, “Ndiye utiziro hwangu nenhare yangu,
\q2 Mwari wangu, wandinovimba naye.”
\b
\q1 
\v 3 Zvirokwazvo achakuponesa parugombe rwomuteyi
\q2 napadenda rinouraya.
\q1 
\v 4 Achakufukidza neminhenga yake,
\q2 uye uchawana utiziro pasi pamapapiro ake;
\q2 kutendeka kwake kuchava nhoo yako norusvingo rwako.
\q1 
\v 5 Haungatyiswi nokuvhundutsa kwousiku,
\q2 kana museve unopfurwa masikati,
\q1 
\v 6 kana hosha inofamba murima,
\q2 kana denda rinoparadza masikati.
\q1 
\v 7 Chiuru chingawa parutivi rwako,
\q2 zviuru gumi kurudyi pako,
\q2 asi hazvingaswederi kwauri.
\q1 
\v 8 Uchangozviona nameso ako chete,
\q2 uye uchaona kurangwa kwavakaipa.
\b
\q1 
\v 9 Kana ukaita Wokumusoro-soro ugaro hwako,
\q2 kunyange Jehovha, iye utiziro hwangu,
\q1 
\v 10 ipapo hapana chakaipa chichakuwira,
\q2 hakuna njodzi ichasvika patende rako.
\q1 
\v 11 Nokuti acharayira vatumwa vake pamusoro pako,
\q2 kuti vakuchengete panzira dzako dzose;
\q1 
\v 12 vachakusimudza mumaoko avo,
\q2 kuti rutsoka rwako rurege kugumburwa padombo.
\q1 
\v 13 Uchatsika pamusoro peshumba napamusoro pechiva;
\q2 uchatsika-tsika shumba huru nenyoka.
\b
\q1 
\v 14 “Nokuti anondida,” ndizvo zvinotaura Jehovha, “neni ndichamununura;
\q2 ndichamudzivirira, nokuti anoziva zita rangu.
\q1 
\v 15 Achadana kwandiri, uye ndichamupindura;
\q2 ndichava naye pakutambudzika,
\q2 ndichamurwira uye ndichamukudza.
\q1 
\v 16 Ndichamugutsa noupenyu hurefu,
\q2 uye ndichamuratidza ruponeso rwangu.”
\c 92
\cl Pisarema 92
\d Pisarema. Rwiyo rweSabata.
\q1 
\v 1 Zvakanaka kurumbidza Jehovha
\q2 nokuimbira zita renyu nziyo, imi Wokumusoro-soro,
\q1 
\v 2 kuparidza rudo rwenyu mangwanani
\q2 nokutendeka kwenyu usiku,
\q1 
\v 3 nechiridzwa chine hungiso
\q2 gumi namaririro akanaka embira.
\b
\q1 
\v 4 Nokuti munondifadza namabasa enyu, imi Jehovha;
\q2 ndinoimba nomufaro nokuda kwamabasa amaoko enyu.
\q1 
\v 5 Haiwa Jehovha, mabasa enyu makuru seiko,
\q2 ndangariro dzenyu dzakadzika sei!
\q1 
\v 6 Munhu asina njere haazivi,
\q2 mapenzi haanzwisisi,
\q1 
\v 7 kuti kunyange vakaipa vachimera souswa,
\q2 uye vaiti vezvakaipa vose vachikura,
\q1 vachaparadzwa nokusingaperi.
\b
\q1 
\v 8 Asi imi, iyemi Jehovha, munosimudzirwa nokusingaperi.
\b
\q1 
\v 9 Nokuti zvirokwazvo vavengi venyu, imi Jehovha,
\q2 zvirokwazvo vavengi venyu vachaparadzwa;
\q2 vaiti vezvakaipa vose vachaparadzirwa.
\q1 
\v 10 Makasimudzira runyanga rwangu sorwenyati;
\q2 mafuta akaisvonaka akadururirwa pamusoro pangu.
\q1 
\v 11 Meso angu akaona kukundwa kwavadzivisi vangu;
\q2 nzeve dzangu dzakanzwa kuparadzwa kwavavengi vangu vakaipa.
\b
\q1 
\v 12 Vakarurama vachakura kwazvo somuchindwe,
\q2 vachakura somusidhari weRebhanoni;
\q1 
\v 13 wakadyarwa muimba yaJehovha,
\q2 vachakura kwazvo muvanze dzaMwari wedu.
\q1 
\v 14 Vacharamba vachibereka zvibereko pakukwegura kwavo,
\q2 vachagara vari vanyoro uye vari vatsva.
\q1 
\v 15 Vachaparidza kuti, “Jehovha akarurama;
\q2 ndiye Dombo rangu, uye maari hamuna chakaipa.”
\c 93
\cl Pisarema 93
\q1 
\v 1 Jehovha anobata ushe, akashongedzwa noumambo;
\q2 Jehovha akashongedzwa noumambo uye akafukidzwa nesimba.
\q2 Nyika yakateyiwa zvakasimba; haingazungunuswi.
\q1 
\v 2 Chigaro chenyu choushe chakasimbiswa kare kare;
\q2 imi muripo nokusingaperi.
\b
\q1 
\v 3 Haiwa Jehovha, makungwa akasimudza,
\q2 makungwa akasimudza manzwi awo;
\q2 makungwa akasimudza mafungu anotinhira.
\q1 
\v 4 Mukuru kukunda kutinhira wemvura zhinji,
\q2 mukuru kukunda mafungu egungwa,
\q2 Jehovha ari kumusoro ndiye mukuru.
\b
\q1 
\v 5 Zvamakatema hazvishanduki;
\q2 utsvene hunofukidza imba yenyu imi Jehovha,
\q2 kwamazuva asingaperi.
\c 94
\cl Pisarema 94
\q1 
\v 1 Haiwa Jehovha, imi Mwari anotsiva,
\q2 haiwa Mwari iyemi munotsiva, penyai.
\q1 
\v 2 Simukai, imi Mutongi wenyika;
\q2 tsivai vanozvikudza zvakavafanira.
\q1 
\v 3 Haiwa Jehovha, vakaipa vachasvika riniko,
\q2 vachasvika riniko vakaipa vachingofara?
\b
\q1 
\v 4 Vanodurura mashoko okuzvikudza;
\q2 vose vanoita zvakaipa vazere nokuzvirumbidza.
\q1 
\v 5 Vanopwanya vanhu venyu, imi Jehovha,
\q2 vanodzvinyirira nhaka yenyu.
\q1 
\v 6 Vanouraya chirikadzi nomweni;
\q2 vanoponda nherera.
\q1 
\v 7 Vanoti, “Jehovha haaoni;
\q2 Mwari waJakobho haana hanya.”
\b
\q1 
\v 8 Nzwisisai, imi vasina njere pakati pavanhu;
\q2 imi mapenzi, muchava vakachenjera riniko?
\q1 
\v 9 Ko, iye akasima nzeve, haanganzwi here?
\q2 Iye akaumba ziso haangaoni here?
\q1 
\v 10 Ko, iye anoranga ndudzi haangarangi here?
\q2 Anodzidzisa vanhu angashayiwa zivo here?
\q1 
\v 11 Jehovha anoziva mirangariro yavanhu;
\q2 anoziva kuti haina maturo.
\b
\q1 
\v 12 Akaropafadzwa munhu anorangwa nemi, iyemi Jehovha,
\q2 munhu wamunodzidzisa pamurayiro wenyu;
\q1 
\v 13 munomuzorodza pamazuva enhamo,
\q2 kusvikira akaipa achererwa gomba.
\q1 
\v 14 Nokuti Jehovha haangarambi vanhu vake;
\q2 haangambosiyi nhaka yake.
\q1 
\v 15 Kururamisira kuchawanikwa nokuda kwevakarurama,
\q2 uye vose vakarurama pamwoyo vachakutevera.
\b
\q1 
\v 16 Ndianiko achandirwira pane vakaipa?
\q2 Ndianiko achandibatsira pavaiti vezvakaipa?
\q1 
\v 17 Dai Jehovha asina kundibatsira,
\q2 ndingadai ndakakurumidza kugara parunyararo rworufu.
\q1 
\v 18 Pandakati, “Rutsoka rwangu rwotedzemuka,”
\q2 rudo rwenyu, imi Jehovha, rwakanditsigira.
\q1 
\v 19 Pandakava nokufunganya kukuru mandiri,
\q2 kunyaradza kwenyu kwakandivigira mufaro kumweya wangu.
\b
\q1 
\v 20 Ko, chigaro choushe chino uori chingashamwaridzana nemi here,
\q2 icho chinouyisa kutambudzika muzvirevo zvacho?
\q1 
\v 21 Vanobatana pamwe chete kuti varwise vakarurama,
\q2 vachipomera mhosva yorufu kuna vasina mhosva.
\q1 
\v 22 Asi Jehovha ndiye ava nhare yangu,
\q2 uye Mwari wangu ndiye dombo randinotizira.
\q1 
\v 23 Achavatsiva nokuda kwezvivi zvavo,
\q2 uye achavaparadza nokuda kwezvakaipa zvavo;
\q2 Jehovha Mwari wedu achavaparadza.
\c 95
\cl Pisarema 95
\q1 
\v 1 Uyai, tiimbire Jehovha nomufaro;
\q2 ngatidanidzirei kuDombo roruponeso rwedu.
\q1 
\v 2 Ngatisvikei pamberi pake nokuvonga
\q2 uye timukudze nenziyo.
\b
\q1 
\v 3 Nokuti Jehovha ndiye Mwari mukuru,
\q2 Mambo mukuru pamusoro pavamwari vose.
\q1 
\v 4 Nzvimbo dzakadzika dzapanyika dziri muruoko rwake,
\q2 uye misoro yamakomo ndeyake.
\q1 
\v 5 Gungwa nderake, nokuti ndiye akariita,
\q2 uye maoko ake akaumba nyika yakaoma.
\b
\q1 
\v 6 Uyai tikotame, tinamate,
\q2 ngatipfugamei pamberi paJehovha Muiti wedu;
\q1 
\v 7 nokuti ndiye Mwari wedu,
\q2 uye isu tiri vanhu vanofudzwa naye,
\q2 makwai anochengetwa naye.
\b
\q1 Nhasi kana muchinzwa inzwi rake,
\q2 
\v 8 musaomesa mwoyo yenyu sezvamakaita paMeribha,
\q2 sezvamakaita pazuva riya paMasa mugwenga,
\q1 
\v 9 pandakaedzwa namadzibaba enyu
\q2 kunyange vakanga vaona zvandakanga ndaita.
\q1 
\v 10 Ndakatsamwira rudzi urwu kwamakore makumi mana;
\q2 ndakati, “Ava vanhu vane mwoyo yakatsauka,
\q2 uye havana kuziva nzira dzangu.”
\q1 
\v 11 Saka ndakapika pakutsamwa kwangu ndikati,
\q2 “Havangazombopindi pazororo rangu.”
\c 96
\cl Pisarema 96
\q1 
\v 1 Imbirai Jehovha rwiyo rutsva;
\q2 imbirai Jehovha, nyika yose.
\q1 
\v 2 Imbirai Jehovha, rumbidzai zita rake;
\q2 paridzai ruponeso rwake zuva nezuva.
\q1 
\v 3 Paridzai kubwinya kwake pakati pendudzi,
\q2 namabasa ake anoshamisa pakati pamarudzi.
\b
\q1 
\v 4 Nokuti Jehovha mukuru uye anofanira kurumbidzwa,
\q2 iye anofanira kutyiwa pamusoro pavamwari vose.
\q1 
\v 5 Nokuti vamwari vose vendudzi zvifananidzo,
\q2 asi Jehovha akaita matenga.
\q1 
\v 6 Kubwinya noumambo zviri pamberi pake;
\q2 simba nokubwinya zviri munzvimbo yake tsvene.
\b
\q1 
\v 7 Remekedzai Jehovha, imi ndudzi dzose,
\q2 ipai rukudzo nesimba kuna Jehovha.
\q1 
\v 8 Ipai kuna Jehovha rukudzo rwakafanira zita rake;
\q2 uyai nechipiriso mugopinda pavanze dzake.
\q1 
\v 9 Namatai Jehovha mukubwinya kwoutsvene hwake;
\q2 dederai pamberi pake, imi nyika dzose.
\b
\q1 
\v 10 Muti pakati pendudzi, “Jehovha ndiye anobata ushe.”
\q2 Nyika yakanyatsosimbiswa, haingazungunuswi;
\q2 uye achatonga marudzi nokururama.
\q1 
\v 11 Kudenga denga ngakufare, nyika ngaifarisise;
\q2 gungwa ngaritinhire, nezvose zviri mariri;
\q2 
\v 12 masango ngaafare, nezvose zviri maari.
\q1 Ipapo miti yose yesango ichaimba nomufaro;
\q2 
\v 13 ichaimba pamberi paJehovha, nokuti anouya,
\q2 anouya kuzotonga nyika.
\q1 Achatonga nyika nokururama,
\q2 uye vanhu nechokwadi chake.
\c 97
\cl Pisarema 97
\q1 
\v 1 Jehovha anobata ushe, nyika ngaifare;
\q2 zviwi zviri kure ngazvifare.
\b
\q1 
\v 2 Makore nerima guru zvakamukomberedza;
\q2 kururama nokururamisira ndidzo nheyo dzechigaro chake choushe.
\q1 
\v 3 Moto unoenda mberi kwake
\q2 uchipisa vavengi vake kumativi ose.
\q1 
\v 4 Mheni yake inovhenekera pasi;
\q2 nyika inozviona igodedera.
\q1 
\v 5 Makomo anonyungudika senamo pamberi paJehovha,
\q2 pamberi paIshe wenyika yose.
\q1 
\v 6 Kudenga denga kunoparidza kururama kwake,
\q2 uye vanhu vose vanoona kubwinya kwake.
\b
\q1 
\v 7 Vose vanonamata zvifananidzo vanonyadziswa,
\q2 avo vanozvirumbidza nezvifananidzo,
\q2 munamatei, imi vamwari vose!
\b
\q1 
\v 8 Zioni rinonzwa rigofara uye misha yeJudha inofara nokuda kwezvamakatonga, imi Jehovha.
\q1 
\v 9 Nokuti imi, iyemi Jehovha, ndimi Wokumusoro-soro pasi pose;
\q2 makasimudzirwa kupfuura vamwari vose.
\b
\q1 
\v 10 Vanoda Jehovha ngavavenge zvakaipa,
\q2 nokuti anorinda upenyu kwavanhu vake vakatendeka
\q2 uye anovarwira muruoko rwowakaipa.
\q1 
\v 11 Chiedza chinovhenekera pamusoro pavakarurama,
\q2 nomufaro pamusoro pavane mwoyo yakarurama.
\q1 
\v 12 Farai muna Jehovha, imi vakarurama,
\q2 uye mukudze zita rake dzvene.
\c 98
\cl Pisarema 98
\d Pisarema.
\q1 
\v 1 Imbirai Jehovha rwiyo rutsva,
\q2 nokuti akaita zvinhu zvinoshamisa;
\q1 ruoko rwake rworudyi nechanza chake
\q2 chitsvene zvakamukundisa.
\q1 
\v 2 Jehovha akazivisa ruponeso rwake
\q2 uye akaratidza kururama kwake kundudzi,
\q1 
\v 3 Akarangarira rudo rwake
\q2 nokutendeka kwake kuimba yaIsraeri;
\q1 migumo yose yenyika yakaona
\q2 ruponeso rwaMwari wedu.
\b
\q1 
\v 4 Danidzirai nomufaro kuna Jehovha, imi nyika yose,
\q2 imbai nziyo mupembere nomufaro;
\q1 
\v 5 imbirai Jehovha nembira,
\q2 nembira nenzwi rokuimba,
\q1 
\v 6 nehwamanda nokurira kworunyanga rwegondobwe,
\q2 danidzirai nomufaro pamberi paJehovha, iye Mambo.
\b
\q1 
\v 7 Gungwa ngaritinhire, nezvose zviri mariri,
\q2 nenyika, navose vanogaramo.
\q1 
\v 8 Nzizi ngadziuchire maoko adzo,
\q2 makomo ngaaimbe pamwe chete nomufaro;
\q1 
\v 9 ngaaimbe pamberi paJehovha,
\q2 nokuti anouya kuzotonga nyika.
\q1 Achatonga nyika zvakarurama
\q2 navanhu nokururamisira.
\c 99
\cl Pisarema 99
\q1 
\v 1 Jehovha anobata ushe,
\q2 ndudzi ngadzidedere;
\q1 anogara pachigaro choushe chiri pakati pamakerubhi,
\q2 nyika ngaizungunuke.
\q1 
\v 2 Jehovha mukuru paZioni;
\q2 iye akasimudzirwa pamusoro pendudzi dzose.
\q1 
\v 3 Ngavarumbidze zita renyu guru rinotyisa,
\q2 iye mutsvene.
\b
\q1 
\v 4 Mambo mukuru, anoda kururamisira,
\q2 imi makasimbisa kururama;
\q1 muna Jakobho makaita
\q2 kururamisira nokururama.
\q1 
\v 5 Kudzai Jehovha Mwari wedu
\q2 nokunamata pachitsiko chetsoka dzake;
\q2 iye mutsvene.
\b
\q1 
\v 6 Mozisi naAroni vakanga vari pakati pavaprista vake,
\q2 Samueri akanga ari pakati paavo
\q1 vaidana kuzita rake,
\q2 vakadana kuna Jehovha akavapindura.
\q1 
\v 7 Akataura kwavari ari mushongwe yegore;
\q2 vakachengeta zvaakatema nemitemo yaakavapa.
\b
\q1 
\v 8 Haiwa Jehovha Mwari wedu,
\q2 imi makavapindura;
\q1 makanga muri Mwari anokanganwira kuna Israeri,
\q2 kunyange makavaranga pane zvavakaita.
\q1 
\v 9 Kudzai Jehovha Mwari wedu
\q2 mumunamate pagomo rake dzvene,
\q2 nokuti Jehovha Mwari wedu ndiye mutsvene.
\c 100
\cl Pisarema 100
\d Pisarema rokuvonga.
\q1 
\v 1 Danidzirai nomufaro kuna Jehovha, imi nyika dzose.
\q2 
\v 2 Shumirai Jehovha nomufaro;
\q2 uyai pamberi pake nenziyo dzomufaro.
\q1 
\v 3 Zivai kuti Jehovha ndiye Mwari.
\q2 Ndiye akatisika, uye tiri vake;
\q2 tiri vanhu vake, namakwai anofudzwa naye.
\b
\q1 
\v 4 Pindai pamasuo ake nokuvonga
\q2 nomuvanze dzake nokurumbidza;
\q2 chimuvongai uye murumbidze zita rake.
\q1 
\v 5 Nokuti Jehovha akanaka uye rudo rwake runogara nokusingaperi;
\q2 kutendeka kwake kunoramba kuripo kuzvizvarwa zvose.
\c 101
\cl Pisarema 101
\d Pisarema raDhavhidhi.
\q1 
\v 1 Ndichaimba nezvorudo rwenyu nokururamisira kwenyu;
\q2 kwamuri, imi Jehovha, ndichaimba nziyo dzokurumbidza.
\q1 
\v 2 Ndichangwarira kurarama upenyu husina chahungapomerwa.
\q2 Muchauya riniko kwandiri?
\b
\q1 Ndichafamba mumba mangu
\q2 nomwoyo usina chaungapomerwa.
\q1 
\v 3 Handingaisi chinhu chakaipa
\q2 pamberi pangu.
\b
\q1 Ndinovenga mabasa avanhu vasingatendi;
\q2 haanganamatiri kwandiri.
\q1 
\v 4 Vanhu vane mwoyo yakatsauka vachava kure neni;
\q2 handichazovi nechokuita nechakaipa.
\b
\q1 
\v 5 Ani naani anoitira muvakidzani wake makuhwa pakavanda,
\q2 iyeye ndiye wandichaita kuti anyarare;
\q1 ani naani ane meso anozvikudza nomwoyo unozvikudza,
\q2 iyeye handingamuregi akadaro.
\b
\q1 
\v 6 Meso angu achava pamusoro pavakatendeka vari munyika,
\q2 kuti vagare neni;
\q1 iye ane mafambiro asina chaangapomerwa,
\q2 achandishumira.
\b
\q1 
\v 7 Hakuna munhu anonyengera
\q2 achagara mumba mangu;
\q1 hakuna munhu anotaura nhema
\q2 achamira pamberi pangu.
\b
\q1 
\v 8 Mangwanani oga oga ndichaita kuti
\q2 vakaipa vose vari panyika vanyarare;
\q1 ndichauraya vaiti vezvakaipa vose,
\q2 vabve muguta raJehovha.
\c 102
\cl Pisarema 102
\d Munyengetero womunhu anotambudzika. Paanenge aziya uye odurura kuchema kwake pamberi paJehovha.
\q1 
\v 1 Inzwai munyengetero wangu, imi Jehovha;
\q2 kuchemera kwangu rubatsiro ngakusvike kwamuri.
\q1 
\v 2 Regai kundivanzira chiso chenyu
\q2 pandinenge ndichitambudzika.
\q1 Rerekerai nzeve yenyu kwandiri;
\q2 pandinokudanai, ndipindurei nokukurumidza.
\b
\q1 
\v 3 Nokuti mazuva angu anopera soutsi;
\q2 mapfupa angu anopisa samazimbe anopfuta.
\q1 
\v 4 Mwoyo wangu warohwa uye waoma souswa;
\q2 ndinokanganwa kudya zvokudya zvangu.
\q1 
\v 5 Nokuda kwokugomera kwangu
\q2 kukuru ndaonda zvokuti ganda rangu ranamatira pamapfupa.
\q1 
\v 6 Ndafanana nezizi romugwenga,
\q2 sezizi riri pakati pamatongo.
\q1 
\v 7 Ndinovata ndakasvinura,
\q2 ndava seshiri iri yoga pamusoro pedenga remba.
\q1 
\v 8 Zuva rose vavengi vangu vanondishungurudza;
\q2 avo vanondipengera vanoshandisa zita rangu sechituko.
\q1 
\v 9 Nokuti ndinodya madota sechokudya changu,
\q2 uye ndinovhenganisa zvokunwa zvangu nemisodzi,
\q1 
\v 10 nokuda kwehasha dzenyu huru,
\q2 nokuti makandisimudza mukandikanda parutivi.
\q1 
\v 11 Mazuva angu akaita somumvuri wamadekwana;
\q2 ndinosvava souswa.
\b
\q1 
\v 12 Asi imi, iyemi Jehovha, munogara pachigaro choushe nokusingaperi;
\q2 mukurumbira wenyu uripo kusvikira kuzvizvarwa zvose.
\q1 
\v 13 Imi muchasimuka mugonzwira Zioni tsitsi,
\q2 nokuti ndiyo nguva yokurinzwira nyasha;
\q2 nguva yakatarwa yasvika.
\q1 
\v 14 Nokuti matombo aro anokosha kuvaranda venyu;
\q2 guruva raro chairo rinovaendesa kugomba.
\q1 
\v 15 Ndudzi dzichatya zita raJehovha,
\q2 madzimambo ose enyika achatya kubwinya kwenyu.
\q1 
\v 16 Nokuti Jehovha achavakazve Zioni,
\q2 agozviratidza pakubwinya kwake.
\q1 
\v 17 Achadavira minyengetero yavanotambura;
\q2 haangazvidzi chikumbiro chavo.
\b
\q1 
\v 18 Izvi ngazvinyorerwe zvizvarwa zvamangwana,
\q2 kuti vanhu vasati vasikwa vagorumbidza Jehovha vachiti,
\q1 
\v 19 “Jehovha akatarira pasi ari panzvimbo yake tsvene yakakwirira,
\q2 ari kudenga akacherechedza pasi,
\q1 
\v 20 kuti anzwe kugomera kwavasungwa
\q2 agosunungura avo vakatongerwa rufu.”
\q1 
\v 21 Saka zita raJehovha richaparidzwa muZioni,
\q2 nokurumbidzwa kwake muJerusarema,
\q1 
\v 22 panoungana marudzi noushe
\q2 kuti vanamate Jehovha.
\b
\q1 
\v 23 Panguva youpenyu hwangu akatapudza simba rangu;
\q2 akaita kuti mazuva angu ave mashoma.
\q1 
\v 24 Saka ndakati,
\q2 “Regai kundibvisa, imi Mwari wangu, pakati pamazuva angu;
\q2 makore enyu anoramba aripo kusvikira kuzvizvarwa zvose.
\q1 
\v 25 Pamavambo makateya nheyo dzenyika,
\q2 uye matenga ibasa basa ramaoko enyu.
\q1 
\v 26 Izvo zvichaparara, asi imi munogara muripo;
\q2 zvose zvichasakara senguo. Senguo muchavabvisa uye vacharaswa.
\q1 
\v 27 Asi imi mucharamba makadaro,
\q2 uye makore enyu haatongogumi.
\q1 
\v 28 Vana vavaranda venyu vachagara pamberi penyu;
\q2 zvizvarwa zvavo zvichasimbiswa pamberi penyu.”
\c 103
\cl Pisarema 103
\d Pisarema raDhavhidhi.
\q1 
\v 1 Rumbidza Jehovha, iwe mweya wangu;
\q2 zvose zviri mukati mangu, ngazvirumbidze zita rake dzvene.
\q1 
\v 2 Rumbidza Jehovha, iwe mweya wangu,
\q2 uye urege kukanganwa mikomborero yake yose,
\q1 
\v 3 iye anokanganwira zvivi zvako zvose,
\q2 uye anoporesa kurwara kwako kwose,
\q1 
\v 4 anodzikinura upenyu hwako kubva pagomba,
\q2 uye anokushongedza korona yorudo netsitsi,
\q1 
\v 5 anogutsa zvido zvako nezvinhu zvakanaka,
\q2 kuti uduku hwako huvandudzwe sohwegondo.
\b
\q1 
\v 6 Jehovha anoita zvakarurama,
\q2 uye anoruramisira vose vakadzvinyirirwa.
\b
\q1 
\v 7 Akazivisa nzira dzake kuna Mozisi,
\q2 namabasa ake kuvanhu veIsraeri:
\q1 
\v 8 Jehovha ane tsitsi nenyasha,
\q2 anononoka kutsamwa, azere norudo.
\q1 
\v 9 Haangarambi achipomera mhosva,
\q2 uye haangarambi akatsamwa nokusingaperi;
\q1 
\v 10 haatiitiri sezvakafanira zvivi zvedu,
\q2 kana kutipa mubayiro sezvakafanira zvakaipa zvedu.
\q1 
\v 11 Nokuti sokukwirira kwaakaita kudenga kumusoro kwenyika,
\q2 ndizvo zvakaita kukura kworudo rwake kuna vanomutya;
\q1 
\v 12 sokuva kure kwamabvazuva namavirira,
\q2 saizvozvo akabvisa kudarika kwedu kwatiri.
\q1 
\v 13 Sokunzwira tsitsi kunoita baba vana vavo,
\q2 saizvozvo Jehovha ane tsitsi pamusoro pavanomutya;
\q1 
\v 14 nokuti anoziva kuti takaumbwa sei,
\q2 anorangarira kuti tiri guruva.
\q1 
\v 15 Kana ari munhu zvake, mazuva ake akaita souswa,
\q2 anokura seruva resango;
\q1 
\v 16 mhepo inorova napamusoro paro onei raenda,
\q2 uye nzvimbo yaranga riri haicharirangaririzve.
\q1 
\v 17 Asi kubva pakusingaperi kusvikira pakusingaperi,
\q2 rudo rwaJehovha rwuri pane avo vanomutya,
\q2 nokururama kwake kuvana vavana vavo,
\q1 
\v 18 naavo vanochengeta sungano yake
\q2 uye vanorangarira kuita zvaakatema.
\b
\q1 
\v 19 Jehovha akasimbisa chigaro chake choushe kudenga,
\q2 uye ushe hwake hunotonga zvinhu zvose.
\b
\q1 
\v 20 Rumbidzai Jehovha, imi vatumwa vake,
\q2 nemi vane simba vanoita zvaakarayira,
\q2 vanoteerera shoko rake.
\q1 
\v 21 Rumbidzai Jehovha, imi hondo dzose dzokudenga,
\q2 imi varanda vake vanoita kuda kwake.
\q1 
\v 22 Rumbidzai Jehovha, imi mabasa ake ose
\q2 kwose kwose kuno umambo hwake.
\b
\q1 Rumbidza Jehovha, mweya wangu.
\c 104
\cl Pisarema 104
\q1 
\v 1 Rumbidza Jehovha, mweya wangu.
\b
\q1 Haiwa Jehovha Mwari wangu, muri mukuru kwazvo; makashongedzwa nokubwinya noumambo.
\q1 
\v 2 Iye anozviputira muchiedza seanozviputira nenguo;
\q2 anotatamura matenga kunge tende
\q2 
\v 3 uye anogadzika matanda edzimba dzake dzapamusoro pamusoro pemvura yadzo zhinji.
\q1 Anoita makore ngoro dzake,
\q2 uye anokwira pamapapiro emhepo.
\q1 
\v 4 Anoita mhepo nhume dzake,
\q2 namazhenje omoto varanda vake.
\b
\q1 
\v 5 Akamisa nyika pamusoro penheyo dzayo;
\q2 haingatongozungunuswi.
\q1 
\v 6 Makaifukidza nokwakadzika somunofukidza nenguo;
\q2 mvura zhinji yakamira pamusoro pamakomo.
\q1 
\v 7 Asi pakutsiura kwenyu mvura zhinji yakatiza,
\q2 pakunzwa kutinhira wenyu yakatiza;
\q1 
\v 8 yakayerera napamusoro pamakomo,
\q2 ikadzika nomumipata,
\q2 ichienda kunzvimbo yamakairayira.
\q1 
\v 9 Makatara muganhu waisingadariki;
\q2 haichazombofukidzizve nyika.
\b
\q1 
\v 10 Anoita kuti matsime adire mvura mumipata;
\q2 inoyerera napakati pamakomo.
\q1 
\v 11 Anonwisa mhuka dzose dzesango mvura;
\q2 mbizi dzinopedza nyota yadzo.
\q1 
\v 12 Shiri dzedenga dzinovaka matendere adzo pedyo nemvura;
\q2 dzinorira dziri pakati pamatavi.
\q1 
\v 13 Anodiridza makomo ari padzimba dzake dzapamusoro;
\q2 nyika inogutswa nezvibereko zvebasa rake.
\q1 
\v 14 Anomeresa uswa hwemombe,
\q2 nembeu kuti vanhu vasakure,
\q2 achibudisa zvokudya kubva pasi:
\q1 
\v 15 iyo waini inofadza mwoyo womunhu,
\q2 namafuta anopenyesa chiso chake,
\q2 nechingwa chinosimbisa mwoyo wake.
\q1 
\v 16 Miti yaJehovha inodiridzwa zvakanaka,
\q2 iyo misidhari yeRebhanoni yaakasima.
\q1 
\v 17 Shiri dzinoruka matendere adzo ipapo;
\q2 dambiramurove rakaita imba yaro mumiti yomupaini.
\q1 
\v 18 Makomo marefu ndeengururu;
\q2 mapako ndiwo utiziro hwembira.
\b
\q1 
\v 19 Mwedzi unotara nguva,
\q2 uye zuva rinoziva nguva yokuvira kwaro.
\q1 
\v 20 Munouyisa rima, usiku hugovapo,
\q2 uye zvikara zvose zvesango zvinobuda kundovhima.
\q1 
\v 21 Shumba dzinoomba dzichitsvaka nyama,
\q2 uye dzinotsvaka zvokudya zvadzo kubva kuna Mwari.
\q1 
\v 22 Kana zuva robuda, idzo dzinoenda kure;
\q2 dzinodzokera dzondovata mumapako adzo.
\q1 
\v 23 Ipapo munhu anobuda oenda kubasa rake,
\q2 kumushando wake kusvikira madekwana.
\b
\q1 
\v 24 Haiwa Jehovha, mabasa enyu manganiko!
\q2 Makaaita ose nenjere;
\q2 nyika izere nezvisikwa zvenyu.
\q1 
\v 25 Hero gungwa, rakakura uye rakapamhama,
\q2 rine zvisikwa zvisingagoni kuverengwa,
\q2 zvipenyu zvikuru nezviduku.
\q1 
\v 26 Hezvo zvikepe zvinofamba-famba, nengwena,
\q2 yamakaumba kuti itambemo.
\b
\q1 
\v 27 Zvose izvi zvinotarira kwamuri
\q2 kuti muzvipe zvokudya zvazvo nenguva yakafanira.
\q1 
\v 28 Pamunozvipa, zvinozviunganidza;
\q2 pamunozarura ruoko rwenyu, izvo zvinogutswa nezvinhu zvakanaka.
\q1 
\v 29 Pamunovanza chiso chenyu,
\q2 izvo zvinovhundutswa;
\q1 pamunozvitorera mweya,
\q2 izvo zvinofa uye zvinodzokera kuguruva.
\q1 
\v 30 Pamunotuma Mweya wenyu,
\q2 izvo zvinosikwa,
\q2 uye munovandudza chiso chenyika.
\b
\q1 
\v 31 Kubwinya kwaJehovha ngakugare nokusingaperi;
\q2 Jehovha ngaafare nebasa rake,
\q1 
\v 32 iye anotarira nyika, yobva yabvunda,
\q2 iye anobata makomo obva apwititika utsi.
\b
\q1 
\v 33 Ndichaimbira Jehovha upenyu hwangu hwose;
\q2 ndichaimbira Mwari wangu nziyo dzokurumbidza ndichiri mupenyu.
\q1 
\v 34 Kurangarira kwangu ngakumufadze,
\q2 pandinofara muna Jehovha.
\q1 
\v 35 Asi vatadzi ngavaparadzwe panyika,
\q2 uye vakaipa ngavarege kuzovapozve.
\b
\q1 Rumbidza Jehovha, mweya wangu.
\b
\q1 Rumbidzai Jehovha.
\c 105
\cl Pisarema 105
\q1 
\v 1 Vongai Jehovha, danai kuzita rake;
\q2 zivisai zvaakaita pakati pendudzi.
\q1 
\v 2 Muimbirei, muimbirei nziyo dzokurumbidza;
\q2 rondedzerai mabasa ake ose anoshamisa.
\q1 
\v 3 Ngarikudzwe zita rake dzvene;
\q2 mwoyo yavanotsvaka Jehovha ngaifare.
\q1 
\v 4 Tarirai kuna Jehovha nokusimba rake;
\q2 tsvakai chiso chake nguva dzose.
\b
\q1 
\v 5 Rangarirai zvishamiso zvaakaita,
\q2 mabasa ake, nezvaakatonga zvaakareva,
\q1 
\v 6 imi vana vaAbhurahama muranda wake,
\q2 haiwa vanakomana vaJakobho, vasanangurwa vake.
\q1 
\v 7 Ndiye Jehovha Mwari wedu;
\q2 kutonga kwake kuri munyika yose.
\b
\q1 
\v 8 Anorangarira sungano yake nokusingaperi,
\q2 iro shoko raakarayira, kuchiuru chezvizvarwa,
\q1 
\v 9 sungano yaakaita naAbhurahama,
\q2 mhiko yaakapika kuna Isaka.
\q1 
\v 10 Akaisimbisa kuna Jakobho somutemo,
\q2 nokuna Israeri sesungano isingaperi achiti,
\q1 
\v 11 “Ndichapa nyika yeKenani kwauri
\q2 somugove wenhaka yako.”
\b
\q1 
\v 12 Pavaiva vashoma pakuwanda,
\q2 zvirokwazvo vari vashoma, uye vari vaeni mairi,
\q1 
\v 13 vakadzungaira vachibva kuno rumwe rudzi kusvikira kuno rumwe rudzi.
\q2 Kubva kuno humwe ushe vachienda kuno humwe.
\q1 
\v 14 Haana kutendera munhu kuvadzvinyirira;
\q2 akatuka madzimambo nokuda kwavo achiti,
\q1 
\v 15 “Musabata vazodziwa vangu;
\q2 musaitira vaprofita vangu zvakaipa.”
\b
\q1 
\v 16 Akadana nzara panyika
\q2 ikaparadza zvose zvaiuyisa zvokudya;
\q1 
\v 17 uye akatuma munhu pamberi pavo,
\q2 iye Josefa, akatengeswa senhapwa.
\q1 
\v 18 Vakakuvadza tsoka dzake nezvisungo
\q2 mutsipa wake ukaiswa mumatare esimbi,
\q1 
\v 19 kusvikira zvaakareva zvazadziswa,
\q2 kusvikira shoko raJehovha raratidza kutendeka kwake.
\q1 
\v 20 Mambo akatuma shoko kuti asunungurwe,
\q2 vatongi vavanhu vakamuregedza.
\q1 
\v 21 Akamuita tenzi weimba yake,
\q2 nomutongi wepfuma yake yose,
\q1 
\v 22 kuti arayire machinda ake sezvaaida
\q2 uye adzidzise vakuru vake njere.
\b
\q1 
\v 23 Ipapo Israeri akapinda muIjipiti;
\q2 Jakobho akagara somweni munyika yaHamu.
\q1 
\v 24 Jehovha akawanza vanhu vake chose;
\q2 akavaita vazhinji kwazvo kupinda vavengi vavo,
\q1 
\v 25 avo vaakashandura mwoyo yavo kuti ivenge vanhu vake,
\q2 kuti varangane pamusoro pavaranda vake.
\q1 
\v 26 Akatuma Mozisi muranda wake,
\q2 naAroni, waakanga asarudza.
\q1 
\v 27 Vakaita zviratidzo zvinoshamisa pakati pavo,
\q2 izvo zvishamiso zvake munyika yaHamu.
\q1 
\v 28 Akatumira rima akaita kuti nyika ive murima,
\q2 nokuti havana kumukira shoko rake here?
\q1 
\v 29 Akashandura mvura yavo zhinji ikava ropa,
\q2 zvikaita kuti hove dzavo dzife.
\q1 
\v 30 Nyika yavo yakazara namatatya,
\q2 akapinda mudzimba dzamadzimambo avo.
\q1 
\v 31 Akataura mapupira enhunzi akauya,
\q2 nenda munyika yavo yose.
\q1 
\v 32 Akashandura mvura yavo ikava chimvuramabwe,
\q2 nemheni munyika yavo yose;
\q1 
\v 33 akarova mizambiringa yavo nemionde yavo,
\q2 akaparadza miti yomunyika yavo.
\q1 
\v 34 Akataura, mhashu dzikauya,
\q2 namagutaguta asingaverengeki;
\q1 
\v 35 zvakadya miriwo minyoro yose munyika yavo,
\q2 zvikadya zvibereko zvevhu ravo.
\q1 
\v 36 Ipapo akarova matangwe munyika yavo,
\q2 zvibereko zvokutanga zvesimba roujaya hwavo.
\b
\q1 
\v 37 Akabudisa Israeri akaremerwa nesirivha negoridhe,
\q2 kwakanga kusina akagumburwa pakati pamarudzi avo.
\q1 
\v 38 Ijipiti yakafara pavakabva,
\q2 nokuti kutya vaIsraeri kwakanga kwavabata.
\q1 
\v 39 Akatatamura gore rikava chifukidzo,
\q2 uye moto kuti uvhenekere usiku.
\q1 
\v 40 Vakakumbira, iye akavauyisira zvihuta, uye akavagutsa nechingwa chakabva kudenga.
\q1 
\v 41 Akazarura dombo, mvura ikatubuka;
\q2 ikayerera mugwenga sorwizi.
\b
\q1 
\v 42 Nokuti akarangarira mhiko yake tsvene
\q2 yaakapa Abhurahama muranda wake.
\q1 
\v 43 Akabudisa vanhu vake nomufaro,
\q2 vasanangurwa vake nokupembera kwomufaro;
\q1 
\v 44 akavapa nyika dzendudzi,
\q2 vakagara nhaka yakanga yatamburirwa navamwe,
\q1 
\v 45 kuti vachengete zvaakatema
\q2 uye vacherechedze mirayiro yake.
\b
\q1 Rumbidzai Jehovha.
\c 106
\cl Pisarema 106
\q1 
\v 1 Rumbidzai Jehovha.
\b
\q1 Vongai Jehovha, nokuti akanaka;
\q2 nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 2 Ndianiko angaparidza mabasa aJehovha esimba,
\q2 kana kureva kurumbidzwa kwake kwose?
\q1 
\v 3 Vakaropafadzwa vanochengeta kururamisira,
\q2 vanogara vachiita zvakarurama.
\q1 
\v 4 Ndirangarirei, imi Jehovha, pamunoratidza nyasha kuvanhu venyu,
\q2 pamunovaponesa, mundibatsirewo,
\q1 
\v 5 kuti ndifadzwe nokubudirira kwavasanangurwa venyu,
\q2 kuti ndigovane pamufaro wavanhu venyu,
\q2 uye ndibatane nenhaka yenyu pakurumbidza.
\b
\q1 
\v 6 Takatadza, sezvakaita madzibaba edu;
\q2 takaita zvakaipa uye takaita mabasa akaipa.
\q1 
\v 7 Madzibaba edu paakanga ari muIjipiti,
\q2 havana kumbofunga nezvezvishamiso zvenyu;
\q1 havana kurangarira tsitsi dzenyu zhinji,
\q2 asi vakakumukirai pagungwa, iro Gungwa Dzvuku.
\q1 
\v 8 Kunyange zvakadaro akavaponesa nokuda kwezita rake,
\q2 kuti simba rake guru rizivikanwe.
\q1 
\v 9 Akarayira Gungwa Dzvuku iro rikapwa;
\q2 uye akavafambisa napakadzika sevanopfuura nomugwenga.
\q1 
\v 10 Akavaponesa kubva muruoko rwomuvengi;
\q2 akavadzikinura kubva muruoko rwomuvengi.
\q1 
\v 11 Mvura zhinji yakafukidza vadzivisi vavo;
\q2 hakuna mumwe wavo akapona.
\q1 
\v 12 Ipapo vakatenda vimbiso dzake
\q2 vakaimba vachimurumbidza.
\b
\q1 
\v 13 Asi vakakurumidza kukanganwa zvaakanga aita,
\q2 uye vakasamirira kurayira kwake.
\q1 
\v 14 Havana kuzvidzora pakukara kwavo mugwenga;
\q2 vakaedza Mwari murenje.
\q1 
\v 15 Saka akavapa zvavakakumbira,
\q2 asi akatuma chirwere chinopedza muviri pamusoro pavo.
\b
\q1 
\v 16 Vakaitira Mozisi godo mumusasa,
\q2 naAroni, akanga akatsaurirwa kuna Jehovha.
\q1 
\v 17 Nyika yakazaruka ikamedza Dhatani;
\q2 ikaviga boka raAbhiramu.
\q1 
\v 18 Moto wakapfuta pakati pavateveri vavo;
\q2 murazvo ukaparadza vakaipa.
\b
\q1 
\v 19 Vakaumba mhuru paHorebhi,
\q2 vakanamata chifananidzo chakaumbwa.
\q1 
\v 20 Vakatsinhanisa kubwinya kwavo
\q2 nomufananidzo wehando, inodya uswa.
\q1 
\v 21 Vakakanganwa Mwari akavaponesa,
\q2 uyo akanga aita zvinhu zvikuru muIjipiti,
\q1 
\v 22 mabasa anoshamisa munyika yaHamu
\q2 namabasa anotyisa paGungwa Dzvuku.
\q1 
\v 23 Saka akati, achavaparadza,
\q2 dai Mozisi, musanangurwa wake,
\q1 asina kumira pamberi pake kuti
\q2 adzore hasha dzake pakuvaparadza.
\b
\q1 
\v 24 Ipapo vakazvidza nyika inofadza;
\q2 havana kutenda zvaakavimbisa.
\q1 
\v 25 Vakanyunyuta vari mumatende
\q2 avo vakasateerera Jehovha.
\q1 
\v 26 Saka akapika akasimudza ruoko rwake
\q2 kuti achavaparadza murenje,
\q1 
\v 27 achaparadza zvizvarwa zvavo pakati pendudzi,
\q2 agovaparadzira munyika dzose.
\b
\q1 
\v 28 Vakazvibatanidza pamwe chete naBhaari wePeori,
\q2 uye vakadya zvibayiro zvakabayirwa vamwari vakafa.
\q1 
\v 29 Vakatsamwisa Jehovha namabasa avo akaipa,
\q2 uye denda rikavapo pakati pavo.
\q1 
\v 30 Asi Finehasi akasimuka,
\q2 akaita zvakarurama, denda rikaguma.
\q1 
\v 31 Izvozvo zvakanzi kwaari kururama
\q2 kusvikira kuzvizvarwa nezvizvarwa nokusingaperi.
\b
\q1 
\v 32 Vakatsamwisa Jehovha pamvura zhinji yeMeribha,
\q2 uye Mozisi akaoneswa nhamo nokuda kwavo;
\q1 
\v 33 nokuti vakamukira Mweya waMwari,
\q2 Mozisi akataura nehasha nomuromo wake.
\b
\q1 
\v 34 Havana kuparadza marudzi
\q2 sokurayirwa kwavakaitwa naJehovha,
\q1 
\v 35 asi vakavhengana nendudzi,
\q2 vakatora tsika dzavo.
\q1 
\v 36 Vakanamata zvifananidzo zvavo,
\q2 izvo zvakazova musungo kwavari.
\q1 
\v 37 Vakabayira vanakomana vavo
\q2 navanasikana vavo kumadhimoni.
\q1 
\v 38 Vakateura ropa risina mhosva,
\q2 iro ropa ravanakomana vavo neravanasikana vavo,
\q1 vavakabayira kuzvifananidzo zveKenani,
\q2 nyika ikasvibiswa neropa ravo.
\q1 
\v 39 Vakazvisvibisa nezvavakaita;
\q2 vakazviitisa ufeve namabasa avo.
\b
\q1 
\v 40 Naizvozvo Jehovha akatsamwira vanhu vake,
\q2 akasema nhaka yake.
\q1 
\v 41 Akavaisa mumaoko endudzi,
\q2 uye vakatongwa navavengi vavo.
\q1 
\v 42 Vavengi vavo vakavadzvinyirira,
\q2 uye vakavaisa pasi pesimba ravo.
\q1 
\v 43 Akavarwira kakawanda,
\q2 asi ivo vakanga vakarerekera pakumumukira
\q2 vakaparadzwa muchivi chavo.
\b
\q1 
\v 44 Asi akatarisa kutambudzika kwavo
\q2 paakanzwa kuchema kwavo;
\q1 
\v 45 akarangarira sungano yake nokuda kwavo,
\q2 uye akazvidemba nokuda kworudo rwake rukuru.
\q1 
\v 46 Akaita kuti vanzwirwe
\q2 tsitsi navose vakavatapa.
\b
\q1 
\v 47 Tiponesei, imi Jehovha Mwari wedu,
\q2 uye mutiunganidze kubva kundudzi,
\q1 kuti tigovonga zita renyu dzvene.
\q2 Tigofara mukurumbidzwa kwenyu.
\b
\b
\q1 
\v 48 Jehovha ngaarumbidzwe, iye Mwari waIsraeri,
\q2 kubva pakusingaperi kusvikira pakusingaperi.
\q1 Vanhu vose ngavati, “Ameni!”
\b
\q1 Rumbidzai Jehovha.
\c 107
\ms1 BHUKU 5
\mr Mapisarema 107–150
\cl Pisarema 107
\q1 
\v 1 Vongai Jehovha, nokuti akanaka;
\q2 rudo rwake runogara nokusingaperi.
\q1 
\v 2 Vakadzikinurwa naJehovha ngavadaro,
\q1 vaakadzikinura muruoko rwomuvengi,
\q1 
\v 3 avo vaakaunganidza kubva panyika dzose,
\q2 kubva kumabvazuva nokumavirira, nokumusoro nezasi.
\b
\q1 
\v 4 Vamwe vakadzungaira murenje nomugwenga,
\q2 vachishayiwa nzira yokuenda kuguta kwavangagara.
\q1 
\v 5 Vakava nenzara nenyota,
\q2 uye upenyu hwavo hwakanga hwoparara.
\q1 
\v 6 Ipapo vakachema kuna Jehovha pakutambudzika kwavo,
\q2 akavarwira pakutambura kwavo.
\q1 
\v 7 Akavafambisa nenzira yakarurama
\q2 kuenda kuguta ravaizogara.
\q1 
\v 8 Vanhu ngavavonge Jehovha nokuda kworudo rwake rusingaperi,
\q1 uye nokuda kwamabasa anoshamisa aakavaitira,
\q1 
\v 9 nokuti anogutsa vane nyota,
\q2 uye vane nzara anovazadza nezvakanaka.
\b
\q1 
\v 10 Vamwe vakagara murima nokusurikirwa kwakadzama,
\q2 vari vasungwa vanotambudzika muzvisungo zvamatare,
\q1 
\v 11 nokuti vakanga vamukira mashoko aMwari
\q2 uye vakazvidza kurayira kweWokumusoro-soro.
\q1 
\v 12 Saka akaita kuti vashande zvinorwadza;
\q2 vakagumburwa, uye pakanga pasina anovabatsira.
\q1 
\v 13 Ipapo vakachema kuna Jehovha pakutambudzika kwavo,
\q2 uye akavaponesa pakutambura kwavo.
\q1 
\v 14 Akavabudisa murima nomukusviba kwakadzika dzika,
\q2 uye akadambura ngetani dzavo.
\q1 
\v 15 Vanhu ngavavonge Jehovha nokuda kworudo rwake rusingaperi,
\q2 uye namabasa ake anoshamisa aakavaitira,
\q1 
\v 16 nokuti anopwanya masuo endarira,
\q2 uye akagura mazariro esimbi.
\b
\q1 
\v 17 Vamwe vakava mapenzi nokuda kwenzira dzavo dzokumukira,
\q2 uye vakatambudzwa kwazvo nokuda kwezvakaipa zvavo.
\q1 
\v 18 Vakasema zvokudya zvose,
\q2 uye vakaswedera pamasuo orufu.
\q1 
\v 19 Ipapo vakachema kuna Jehovha pakutambudzika kwavo,
\q2 uye akavaponesa pakutambura kwavo.
\q1 
\v 20 Akatuma shoko rake uye akavaporesa;
\q2 akavanunura kubva paguva.
\q1 
\v 21 Vanhu ngavavonge Jehovha nokuda kworudo rwake rusingaperi,
\q2 uye namabasa ake anoshamisa aakavaitira.
\q1 
\v 22 Ngavabayire zvibayiro zvokuvonga,
\q2 uye vareve zvamabasa ake nenziyo dzomufaro.
\b
\q1 
\v 23 Vamwe vakafamba rwendo pagungwa nezvikepe;
\q2 vakanga vari vashambadziri pamvura zhinji.
\q1 
\v 24 Vakaona mabasa aJehovha,
\q2 mabasa ake anoshamisa pakadzika.
\q1 
\v 25 Nokuti akataura uye akamutsa dutu
\q2 rikasimudza mafungu.
\q1 
\v 26 Vakaenda kumusoro kumatenga vakaendawo pasi kwakadzika;
\q2 mukutambudzika kwavo kushinga kwavo kwakanyongodeka.
\q1 
\v 27 Vakandeya vakadzedzereka savanhu vadhakwa; vakasvika pakupererwa namazano.
\q1 
\v 28 Ipapo vakachema kuna Jehovha pakutambudzika kwavo,
\q2 uye akavabudisa pakutambura kwavo.
\q1 
\v 29 Akanyaradza dutu remhepo nezevezeve;
\q2 mafungu egungwa akanyarara kuti mwiro.
\q1 
\v 30 Vakafara parakadzikama,
\q2 uye akavatungamirira kwakachengetedzeka kwavaida.
\q1 
\v 31 Vanhu ngavavonge Jehovha nokuda kworudo rwake rusingaperi,
\q2 uye namabasa ake anoshamisa aakaitira vanhu.
\q1 
\v 32 Ngavamukudze paungano yavanhu,
\q2 uye vamurumbidze pagungano ramakurukota.
\b
\q1 
\v 33 Akashandura nzizi dzikava gwenga,
\q2 hova dzinoerera dzikava nyika ine nyota,
\q1 
\v 34 uye nyika yezvibereko ikava gwenga romunyu,
\q2 nokuda kwezvakaipa zvavaigaramo.
\q1 
\v 35 Akashandura gwenga rikava madziva emvura,
\q2 nenyika yakaoma ikava zvitubu zvinoerera;
\q1 
\v 36 ndipo paakagarisa vane nzara,
\q2 uye vakavaka guta ravangagara.
\q1 
\v 37 Vakadyara minda, uye vakasima minda yemizambiringa,
\q2 ikabereka mukohwo wakanaka;
\q1 
\v 38 akavaropafadza, uye akavawanza zvikuru,
\q2 uye haana kutendera zvipfuwo zvavo kuparara.
\b
\q1 
\v 39 Ipapo vakava vashoma, uye vakaninipiswa vakadzvinyirirwa,
\q2 nenjodzi uye nokusuwa;
\q1 
\v 40 iye anodurura kuzvidzwa pamusoro pamakurukota,
\q2 akaita kuti vadzungaire musango risina nzira.
\q1 
\v 41 Akasimudza vanoshayiwa kubva mukutambudzika kwavo,
\q2 uye akawedzera mhuri dzavo samapoka amakwai.
\q1 
\v 42 Vakarurama vanozviona vagofara,
\q2 asi vakaipa vose vanodzivirwa miromo yavo.
\b
\q1 
\v 43 Ani naani akachenjera ngaachengete zvinhu izvi,
\q2 uye arangarire rudo rukuru rwaJehovha.
\c 108
\cl Pisarema 108
\d Rwiyo. Pisarema raDhavhidhi.
\q1 
\v 1 Mwoyo wangu wakasimba, Mwari imi;
\q2 ndichaimba uye ndichaimba zvakanaka nomwoyo wangu wose.
\q1 
\v 2 Muka iwe mutengeranwa nembira!
\q2 Ndichamutsa mambakwedza.
\q1 
\v 3 Haiwa Jehovha ndichakurumbidzai pakati pendudzi; ndichaimba nezvenyu pakati pamarudzi.
\q2 Kutendeka kwenyu kunosvika kumatenga.
\q1 
\v 4 Nokuti rudo rwenyu rukuru,
\q2 kupfuura kudenga denga;
\q1 
\v 5 Kudzwai, imi Mwari, kumusoro kwokudenga,
\q2 uye kurumbidzwa kwenyu ngakuve pamusoro penyika yose.
\b
\q1 
\v 6 Tiponesei uye mutibatsire noruoko rwenyu rworudyi,
\q2 kuti vamunoda varwirwe.
\q1 
\v 7 Mwari akataura ari panzvimbo yake tsvene achiti,
\q2 “Pakukunda kwangu ndichaganhura Shekemu,
\q2 uye ndigoyera Mupata weSukoti.
\q1 
\v 8 Gireadhi ndeyangu, Manase ndowangu;
\q2 Efuremu inguwani yangu,
\q2 Judha itsvimbo yangu.
\q1 
\v 9 Moabhu ndiwo mudziyo wangu wokugezera,
\q2 pamusoro paEdhomu ndichapotsera shangu dzangu;
\q2 pamusoro paFiristia ndichapembera mukukunda.”
\b
\q1 
\v 10 Ndianiko achandiuyisa muguta rakakomberedzwa namasvingo?
\q2 Ndianiko achanditungamirira kuEdhomu?
\q1 
\v 11 Ko, hamusimi here, imi Mwari, iyemi makatiramba
\q2 uye mukasazobudazve kuenda nehondo dzedu?
\q1 
\v 12 Tibatsirei pamuvengi wedu,
\q2 nokuti rubatsiro rwomunhu haruna maturo.
\q1 
\v 13 Tichapiwa kukunda naMwari,
\q2 uye achatsika-tsika vavengi vedu.
\c 109
\cl Pisarema 109
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Haiwa Mwari, imi wandinorumbidza,
\q2 regai kunyarara,
\q1 
\v 2 nokuti vanhu vakaipa vanonyengera vakandishamira miromo yavo;
\q2 vakataura nhema pamusoro pangu nendimi dzavo.
\q1 
\v 3 Vakandikomba namashoko okuvenga;
\q2 vanorwa neni pasina mhosva.
\q1 
\v 4 Pachinzvimbo choushamwari hwangu navo, vanondipa mhosva,
\q2 asi ini ndiri munhu wokunyengetera.
\q1 
\v 5 Vanonditsivira zvakaipa pane zvakanaka,
\q2 uye vanondivengera ushamwari hwangu.
\b
\q1 
\v 6 Tumai munhu akaipa kuti apikisane naye;
\q2 mupomeri ngaamire kuruoko rwake rworudyi.
\q1 
\v 7 Paanotongwa, ngaawanikwe ane mhosva,
\q2 uye minyengetero yake ngaimupe mhaka.
\q1 
\v 8 Mazuva ake ngaave mashoma;
\q2 mumwe ngaatore nzvimbo youkuru hwake.
\q1 
\v 9 Vana vake ngavave nherera,
\q2 uye mukadzi wake ave chirikadzi.
\q1 
\v 10 Vana vake ngavave vapemhi vanodzungaira;
\q2 ngavadzingwe vabve mumatongo emisha yavo.
\q1 
\v 11 Waakakwereta ngaatore zvose zvaanazvo;
\q2 vatorwa ngavapambe zvose zvaakashandira.
\q1 
\v 12 Ngakurege kuva neanomunzwira ngoni
\q2 kana kunzwira tsitsi nherera dzake.
\q1 
\v 13 Zvizvarwa zvake ngazvirove,
\q2 mazita avo adzimwe parudzi runotevera.
\q1 
\v 14 Mhosva yamadzibaba ake ngairangarirwe pamberi paJehovha;
\q2 chivi chamai vake ngachirege kumbodzimwa.
\q1 
\v 15 Zvivi zvavo ngazvirambe zviri pamberi paJehovha,
\q2 kuti aparadze chirangaridzo chavo panyika.
\b
\q1 
\v 16 Nokuti haana kumbofunga kuita zvakanaka,
\q2 asi akavhima varombo kusvika parufu,
\q2 vanoshayiwa navane mwoyo yakaputsika.
\q1 
\v 17 Aifarira kutaura chituko, ngachichiuya pamusoro pake;
\q2 iye asina kufadzwa nokuropafadza, ngakuve kure naye.
\q1 
\v 18 Aifuka kutuka senguo yake;
\q2 zvakapinda mumuviri wake semvura,
\q2 nomumapfupa ake samafuta.
\q1 
\v 19 Ngazvive sejasi rakamonerwa paari,
\q2 sebhanhire rakasungirirwa paari nokusingaperi.
\q1 
\v 20 Uyu ngauve muripo waJehovha kuvapomeri vangu,
\q2 kuna avo vanotaura zvakaipa pamusoro pangu.
\b
\q1 
\v 21 Asi imi, Ishe Jehovha,
\q2 ndiitirei zvakanaka nokuda kwezita renyu;
\q2 ndirwirei, kubudikidza nokunaka kworudo rwenyu.
\q1 
\v 22 Nokuti ndiri murombo uye ndinoshayiwa,
\q2 uye mwoyo wangu wakuvara mukati mangu.
\q1 
\v 23 Ndinopera somumvuri wamadekwana;
\q2 ndinozunzwa semhashu.
\q1 
\v 24 Mabvi angu apera simba nokutsanya;
\q2 muviri wangu waonda uye ndaonda kwazvo.
\q1 
\v 25 Ndiri chinhu chinosekwa navapomeri vangu;
\q2 pavanondiona, vanodzungudza misoro yavo.
\b
\q1 
\v 26 Ndibatsirei, imi Jehovha Mwari wangu;
\q2 ndiponesei zvakafanira rudo rwenyu.
\q1 
\v 27 Ngavazive kuti ndirwo ruoko rwenyu,
\q2 kuti imi, iyemi Jehovha, makazviita.
\q1 
\v 28 Ivo vangatuka havo, asi imi mucharopafadza;
\q2 vachanyadziswa pavanorwisa,
\q2 asi muranda wenyu achafara.
\q1 
\v 29 Vapomeri vangu vachafukidzwa nenyadzi,
\q1 uye vachaputirwa nokunyara sokunge nejasi.
\b
\q1 
\v 30 Ndicharumbidza Jehovha nomuromo wangu zvikuru;
\q2 paungano huru, ndichamurumbidza.
\q1 
\v 31 Nokuti anomira kuruoko rworudyi rwouyo anoshayiwa,
\q2 kuti amuponese pane avo vanomupomera mhosva.
\c 110
\cl Pisarema 110
\d Pisarema raDhavhidhi
\q1 
\v 1 Jehovha akati kuna She wangu,
\q2 “Gara kuruoko rwangu rworudyi,
\q1 kusvikira ndaita vavengi vako
\q2 chitsiko chetsoka dzako.”
\b
\q1 
\v 2 Jehovha achatambanudza tsvimbo yesimba rako kubva muZioni;
\q2 uchatonga pakati pavavengi vako.
\q1 
\v 3 Mauto ako achazvipira
\q2 pazuva rako rehondo.
\q1 Wapfekedzwa nguo youshe, utsvene,
\q2 kubva pachizvaro chamambakwedza
\q2 uchagamuchira dova roujaya hwako.
\b
\q1 
\v 4 Jehovha akapika,
\q2 uye haangashanduki, achiti,
\q1 “Iwe uri muprista nokusingaperi,
\q2 worudzi rwaMerikizedheki.”
\b
\q1 
\v 5 Jehovha ari kuruoko rwako rworudyi;
\q2 achaparadza madzimambo pazuva rehasha dzake.
\q1 
\v 6 Achatonga ndudzi, achiunganidza vakafa,
\q2 uye achiparadza vatongi venyika yose.
\q1 
\v 7 Achanwa parukova rwuri parutivi penzira;
\q2 naizvozvo achasimudza musoro wake.
\c 111
\cl Pisarema 111
\q1 
\v 1 Rumbidzai Jehovha.
\b
\q1 Ndicharumbidza Jehovha nomwoyo wangu wose,
\q2 padare ravakarurama nepagungano.
\b
\q1 
\v 2 Mabasa aJehovha makuru;
\q2 anorangarirwa navose vanofara maari.
\q1 
\v 3 Mabasa ake ndeokukudzwa noumambo,
\q2 uye kururama kwake kunogara nokusingaperi.
\q1 
\v 4 Akaita kuti zvishamiso zvake zvirangarirwe;
\q2 Jehovha ane nyasha nengoni.
\q1 
\v 5 Anopa zvokudya kuna avo vanomutya;
\q2 anorangarira sungano yake nokusingaperi.
\q1 
\v 6 Akaratidza vanhu vake simba ramabasa ake,
\q2 achivapa nyika dzedzimwe ndudzi.
\q1 
\v 7 Mabasa amaoko ake akatendeka uye akarurama,
\q2 mitemo yake yose yakavimbika.
\q1 
\v 8 Yakasimba kusvika nokusingaperi-peri,
\q2 yakaitwa mukutendeka nokururama.
\q1 
\v 9 Akapa dzikinuro kuvanhu vake;
\q2 akasimbisa sungano yake nokusingaperi,
\q2 zita rake idzvene uye rinotyisa.
\b
\q1 
\v 10 Kutya Jehovha ndiwo mavambo enjere;
\q2 vose vanotevera mitemo yake vanonzwisisa.
\q2 Kurumbidzwa ndokwake nokusingaperi.
\c 112
\cl Pisarema 112
\q1 
\v 1 Rumbidzai Jehovha.
\b
\q1 Akaropafadzwa munhu anotya Jehovha,
\q2 anofarira mirayiro yake zvikuru.
\b
\q1 
\v 2 Vana vake vachava nesimba panyika;
\q2 zvizvarwa zvavakarurama zvicharopafadzwa.
\q1 
\v 3 Pfuma nezvakawanda zviri mumba make,
\q2 uye kururama kwake kunogara nokusingaperi.
\q1 
\v 4 Kunyange murima akarurama anobudirwa nechiedza,
\q2 iye munhu ane nyasha nengoni uye akarurama.
\q1 
\v 5 Zvakanaka zvinouya kumunhu anopa zvizhinji
\q2 uye anokweretesa pachena, anofambisa nzira dzake nokururamisira.
\q1 
\v 6 Zvirokwazvo, haangatongozungunuswi;
\q2 munhu akarurama acharangarirwa nokusingaperi.
\q1 
\v 7 Haangatyi mashoko akaipa;
\q2 mwoyo wake wakasimba, anovimba naJehovha.
\q1 
\v 8 Mwoyo wake wakachengetedzeka, haangatyi chinhu;
\q2 pakupedzisira achatarira nokukunda kuvavengi vake.
\q1 
\v 9 Akaparadzira zvipo zvake kuvarombo,
\q2 kururama kwake kunogara nokusingaperi;
\q2 runyanga rwake ruchasimudzwa mudenga mukukudzwa.
\b
\q1 
\v 10 Akaipa achazviona uye acharwadziwa,
\q2 acharumanya meno ake uye achaonda;
\q2 kushuva kwowakaipa kuchava pasina.
\c 113
\cl Pisarema 113
\q1 
\v 1 Rumbidzai Jehovha.
\b
\q1 Rumbidzai, imi varanda vaJehovha,
\q2 rumbidzai zita raJehovha.
\q1 
\v 2 Zita raJehovha ngarirumbidzwe,
\q2 kubva zvino kusvikira narini.
\q1 
\v 3 Kubva pakubuda kwezuva kusvikira pakuvira kwaro,
\q2 zita raJehovha rinofanira kurumbidzwa.
\b
\q1 
\v 4 Jehovha anosimudzirwa pamusoro pendudzi dzose;
\q2 kubwinya kwake kuri pamusoro pamatenga.
\q1 
\v 5 Ndianiko akaita saJehovha Mwari wedu,
\q2 iye anogara pachigaro choushe chokumusoro-soro,
\q1 
\v 6 anokotamira pasi kuti aone
\q2 zviri kudenga napanyika?
\b
\q1 
\v 7 Anosimudza murombo kubva muguruva,
\q2 uye anosimudza vanoshayiwa kubva padurunhuru ramadota;
\q1 
\v 8 anovagadza namachinda,
\q2 namachinda avanhu vavo.
\q1 
\v 9 Anogarisa mukadzi asingabereki mumba make,
\q2 samai vavana vanofara.
\b
\q1 Rumbidzai Jehovha.
\c 114
\cl Pisarema 114
\q1 
\v 1 Israeri akati abuda muIjipiti,
\q2 imba yaJakobho ichibva kurudzi runo mutauro wokumwe,
\q1 
\v 2 Judha akava imba tsvene yaMwari,
\q2 Israeri ushe hwake.
\b
\q1 
\v 3 Gungwa rakazviona rikatiza,
\q2 Jorodhani rwakadzokera shure;
\q1 
\v 4 makomo akakwakuka samakondobwe,
\q2 zvikomo samakwayana.
\b
\q1 
\v 5 Haiwa gungwa, wakatizeiko,
\q2 iwe Jorodhani zvawakadzokera shure,
\q1 
\v 6 imi makomo zvamakakwakuka samakondobwe,
\q2 nemi zvikomo, samakwayana?
\b
\q1 
\v 7 Dedera, iwe nyika pamberi paShe,
\q2 pamberi paMwari waJakobho,
\q1 
\v 8 akashandura dombo rikava dziva,
\q2 dombo rakaoma rikava matsime emvura.
\c 115
\cl Pisarema 115
\q1 
\v 1 Kwete kwatiri, Jehovha, kwete kwatiri,
\q2 asi kukudzwa ngakupiwe kuzita renyu,
\q2 nokuda kworudo rwenyu nokutendeka kwenyu.
\b
\q1 
\v 2 Sei ndudzi dzichiti,
\q2 “Mwari wavo aripiko?”
\q1 
\v 3 Mwari wedu ari kudenga;
\q2 anoita zvose zvinomufadza.
\q1 
\v 4 Asi zvifananidzo zvavo isirivha negoridhe,
\q2 zvakaitwa namaoko avanhu.
\q1 
\v 5 Zvine miromo, asi hazvigoni kutaura,
\q2 zvina meso, asi hazvigoni kuona;
\q1 
\v 6 zvine nzeve, asi hazvigoni kunzwa mhino,
\q2 asi hazvigoni kunhuhwidza;
\q1 
\v 7 zvina maoko, asi hazvigoni kubata,
\q2 tsoka, asi hazvigoni kufamba;
\q2 uye hazvitauri napahuro pazvo.
\q1 
\v 8 Vanozviita vachafanana nazvo,
\q2 navose vanovimba nazvo.
\b
\q1 
\v 9 Haiwa imba yaIsraeri, vimbai naJehovha,
\q2 ndiye mubatsiri wavo nenhoo yavo.
\q1 
\v 10 Imi imba yaAroni, vimbai naJehovha,
\q2 ndiye mubatsiri wavo nenhoo yavo.
\q1 
\v 11 Imi vanomutya, vimbai naJehovha,
\q2 ndiye mubatsiri wavo nenhoo yavo.
\b
\q1 
\v 12 Jehovha anotirangarira uye achatiropafadza:
\q2 Acharopafadza imba yaIsraeri, acharopafadza imba yaAroni,
\q1 
\v 13 acharopafadza vanotya Jehovha,
\q2 vaduku navakuru zvakafanana.
\b
\q1 
\v 14 Jehovha ngaakuwanzei,
\q2 mose iwe navana vako.
\q1 
\v 15 Jehovha ngaakuropafadze,
\q2 iye muiti wedenga napasi.
\b
\q1 
\v 16 Kudenga denga kumusoro ndokwaJehovha,
\q2 asi nyika akaipa kuvanhu.
\q1 
\v 17 Vakafa havasivo vanorumbidza Jehovha,
\q2 avo vanoburukira kwakanyarara;
\q1 
\v 18 asi tisu tinokudza Jehovha,
\q2 kubva zvino kusvikira narini.
\b
\q1 Rumbidzai Jehovha.
\c 116
\cl Pisarema 116
\q1 
\v 1 Ndinoda Jehovha, nokuti akanzwa inzwi rangu;
\q2 akandinzwira tsitsi pakuchema kwangu.
\q1 
\v 2 Nokuti akarerekera nzeve yake kwandiri,
\q2 ndichadana kwaari mazuva ose oupenyu hwangu.
\b
\q1 
\v 3 Misungo yorufu yakandipinganidza,
\q2 kurwadza kweguva kwakauya pamusoro pangu;
\q2 ndakakundwa nenhamo nokusuwa.
\q1 
\v 4 Ipapo ndakadana kuzita raJehovha ndikati,
\q2 “Haiwa Jehovha, ndiponesei!”
\b
\q1 
\v 5 Jehovha ane nyasha uye akarurama;
\q2 Mwari wedu azere netsitsi.
\q1 
\v 6 Jehovha anodzivirira vakatendeka pamwoyo;
\q2 pandakanga ndiri pakushayiwa kukuru, iye akandiponesa.
\b
\q1 
\v 7 Haiwa mweya wangu, chizorora zvakare,
\q2 nokuti Jehovha akakuitira zvakanaka.
\b
\q1 
\v 8 Nokuti imi, iyemi Jehovha, makarwira mweya wangu parufu,
\q2 meso angu pamisodzi,
\q2 uye makumbo angu pakugumburwa,
\q1 
\v 9 kuti ndifambe pamberi paJehovha
\q2 munyika yavapenyu.
\q1 
\v 10 Ndakatenda; naizvozvo ndakati,
\q2 “Ndiri kutambudzika kwazvo.”
\q1 
\v 11 Uye pakuvhunduka kwangu ndakati,
\q2 “Vanhu vose vanoreva nhema.”
\b
\q1 
\v 12 Ndingaripira seiko Jehovha
\q2 pamusoro pokunaka kwake kwose kwandiri?
\q1 
\v 13 Ndichasimudza mukombe woruponeso
\q2 ndigodana kuzita raJehovha.
\q1 
\v 14 Ndichazadzisa mhiko dzangu kuna Jehovha,
\q2 pamberi pavanhu vake vose.
\b
\q1 
\v 15 Chinhu chinokosha pamberi paJehovha
\q2 ndirwo rufu rwavatsvene vake.
\q1 
\v 16 Haiwa Jehovha, zvirokwazvo ndiri muranda wenyu;
\q2 ndiri muranda wenyu, mwanakomana womurandakadzi wenyu;
\q2 makandisunungura pangetani dzangu.
\b
\q1 
\v 17 Ndichabayira chipo chokuvonga kwamuri,
\q2 uye ndichadana kuzita raJehovha.
\q1 
\v 18 Ndichazadzisa mhiko dzangu kuna Jehovha,
\q2 pamberi pavanhu vake vose,
\q1 
\v 19 pavanze dzeimba yaJehovha,
\q2 mukati mako, iwe Jerusarema.
\b
\q1 Rumbidzai Jehovha.
\c 117
\cl Pisarema 117
\q1 
\v 1 Rumbidzai Jehovha, imi ndudzi dzose;
\q2 Mukudzei, imi marudzi ose.
\q1 
\v 2 Nokuti rudo rwake kwatiri rukuru,
\q2 uye kutendeka kwaJehovha kunogara nokusingaperi.
\b
\q1 Rumbidzai Jehovha.
\c 118
\cl Pisarema 118
\q1 
\v 1 Vongai Jehovha, nokuti akanaka;
\q2 rudo rwake runogara nokusingaperi.
\b
\q1 
\v 2 Israeri ngaati,
\q2 “Rudo rwake runogara nokusingaperi.”
\q1 
\v 3 Imba yaAroni ngaiti,
\q2 “Rudo rwake runogara nokusingaperi.”
\q1 
\v 4 Avo vanotya Jehovha ngavati,
\q2 “Rudo rwake runogara nokusingaperi.”
\b
\q1 
\v 5 Mukurwadziwa kwangu ndakadana kuna Jehovha,
\q2 uye akandipindura nokundisunungura.
\q1 
\v 6 Jehovha aneni; handingatyi.
\q2 Munhu angandiiteiko?
\q1 
\v 7 Jehovha aneni; ndiye mubatsiri wangu.
\q2 Ndichatarira vavengi vangu nokukunda.
\b
\q1 
\v 8 Zviri nani kutizira kuna Jehovha
\q2 pano kuvimba nomunhu.
\q1 
\v 9 Zviri nani kutizira kuna Jehovha
\q2 pano kuvimba namachinda.
\b
\q1 
\v 10 Ndudzi dzose dzakandikomba,
\q2 asi ndakavaparadza muzita raJehovha.
\q1 
\v 11 Vakandikomba pamativi ose,
\q2 asi ndakavaparadza muzita raJehovha.
\q1 
\v 12 Vakandimomotera senyuchi,
\q2 asi vakakurumidza kufa seminzwa inotsva,
\q2 ndakavaparadza muzita raJehovha.
\b
\q1 
\v 13 Ndakasundidzirwa shure uye ndikada kuwa,
\q2 asi Jehovha akandibatsira.
\q1 
\v 14 Jehovha ndiye simba rangu norwiyo rwangu;
\q2 ndiye ava ruponeso rwangu.
\b
\q1 
\v 15 Kupembera kwomufaro nokukunda
\q2 kunonzwika mumatende avakarurama kuchiti:
\q1 “Ruoko rworudyi rwaJehovha rwakaita zvinhu zvikuru!
\q2 
\v 16 Ruoko rworudyi rwaJehovha rwakasimudzirwa kumusoro;
\q2 ruoko rworudyi rwaJehovha rwakaita zvinhu zvikuru!”
\b
\q1 
\v 17 Handingafi asi ndichararama,
\q2 uye ndichaparidza zvakaitwa naJehovha.
\q1 
\v 18 Jehovha akandiranga kwazvo,
\q2 asi haana kundiisa kurufu.
\b
\q1 
\v 19 Ndizarurireiwo masuo okururama;
\q2 ndichapinda ndigovonga Jehovha.
\q1 
\v 20 Iri ndiro suo raJehovha
\q2 panopinda navakarurama.
\q1 
\v 21 Ndichakuvongai, nokuti makandipindura;
\q2 makava ruponeso rwangu.
\b
\q1 
\v 22 Dombo rakarambwa navavaki
\q2 ndiro rakazova musoro wekona;
\q1 
\v 23 Jehovha akaita izvi,
\q2 uye zvinoshamisa pamberi pedu.
\q1 
\v 24 Iri ndiro zuva rakaitwa naJehovha;
\q2 ngatifarei kwazvo tifarisise mariri.
\b
\q1 
\v 25 Haiwa Jehovha, tiponesei;
\q2 haiwa Jehovha, tipeiwo kubudirira.
\q1 
\v 26 Akaropafadzwa uyo anouya muzita raJehovha.
\q2 Tiri mumba maJehovha tinokuropafadzai.
\q1 
\v 27 Jehovha ndiye Mwari,
\q2 uye akaita kuti chiedza chake chivhenekere pamusoro pedu.
\q1 Namatavi muruoko, pinda mumudungwe
\q2 ubatane navamwe vari kuenda kunyanga dzearitari.
\b
\q1 
\v 28 Imi muri Mwari wangu, uye ndichakuvongai;
\q2 ndimi Mwari wangu, uye ndichakukudzai.
\b
\q1 
\v 29 Vongai Jehovha, nokuti akanaka;
\q2 rudo rwake runogara nokusingaperi.
\c 119
\cl Pisarema 119
\qa Arefi
\q1 
\v 1 Vakaropafadzwa avo vane nzira isina chaingapomerwa,
\q2 vanofamba mumurayiro waJehovha.
\q1 
\v 2 Vakaropafadzwa avo vanochengeta zvaakatema,
\q2 vanomutsvaka nomwoyo wavo wose.
\q1 
\v 3 Havaiti chinhu chakaipa;
\q2 vanofamba munzira yake.
\q1 
\v 4 Imi makaisa zvirevo
\q2 zvinofanira kuteererwa.
\q1 
\v 5 Haiwa, dai nzira dzangu dzakasimba
\q2 pakuteerera zvirevo zvenyu!
\q1 
\v 6 Ipapo handaizonyadziswa pandinorangarira mirayiro yenyu.
\q1 
\v 7 Ndichakurumbidzai nomwoyo wakarurama,
\q2 sezvo ndichidzidza mirayiro yenyu yakarurama.
\q1 
\v 8 Ndichateerera mitemo yenyu;
\q2 regai kundirasa zvachose.
\qa Bheti
\q1 
\v 9 Ko, jaya ringanatsa nzira yaro nei?
\q2 Nokurarama sezvinoreva shoko renyu.
\q1 
\v 10 Ndinokutsvakai nomwoyo wangu wose;
\q2 musandirega ndichitsauka pamirayiro yenyu.
\q1 
\v 11 Shoko renyu ndakariviga mumwoyo mangu,
\q2 kuti ndirege kukutadzirai.
\q1 
\v 12 Imi munofanira kukudzwa, Jehovha;
\q2 ndidzidzisei mitemo yenyu.
\q1 
\v 13 Nemiromo yangu ndichataurazve
\q2 mirayiro yose inobva pamuromo wenyu.
\q1 
\v 14 Ndinofarira kutevera zvirevo zvenyu,
\q2 somunhu anofarira pfuma huru.
\q1 
\v 15 Ndinofungisisa zvirevo zvenyu,
\q2 uye ndinorangarira nzira dzenyu.
\q1 
\v 16 Ndinofarira mitemo yenyu;
\q2 handingakanganwi shoko renyu.
\qa Gimeri
\q1 
\v 17 Itirai muranda wenyu zvakanaka, ndigorarama;
\q2 ndichateerera shoko renyu.
\q1 
\v 18 Ndisvinudzei meso angu kuti ndione.
\q2 Zvinhu zvinoshamisa zviri pamurayiro wenyu.
\q1 
\v 19 Ndiri mutorwa panyika;
\q2 regai kundivanzira mirayiro yenyu.
\q1 
\v 20 Mweya wangu wapedzwa nokushuva
\q2 mitemo yenyu nguva dzose.
\q1 
\v 21 Munotsiura vanozvikudza, avo vakatukwa,
\q2 uye vanotsauka kubva pamirayiro yenyu.
\q1 
\v 22 Bvisai kwandiri kushorwa nokuzvidzwa,
\q2 nokuti ndinochengeta zvirevo zvenyu.
\q1 
\v 23 Kunyange vatongi vachigara pamwe chete vachindireva,
\q2 muranda wenyu achafungisisa mitemo yenyu.
\q1 
\v 24 Ndinofadzwa nezvirevo zvenyu;
\q2 ndizvo zvinondipanga mazano.
\qa Dhareti
\q1 
\v 25 Ndakaradzikwa pasi muguruva;
\q2 chengetedzai upenyu hwangu sezvinoreva shoko renyu.
\q1 
\v 26 Ndakarevazve nzira dzangu imi mukandipindura;
\q2 ndidzidzisei mitemo yenyu.
\q1 
\v 27 Itai kuti ndinzwisise zvirevo zvenyu;
\q2 ipapo ndichafungisisa pamusoro pezvishamiso zvenyu.
\q1 
\v 28 Mweya wangu waziya nokusuwa;
\q2 ndisimbisei sezvinoreva shoko renyu.
\q1 
\v 29 Ndibvisei panzira dzokunyengera;
\q2 ndinzwirei nyasha kubudikidza nomurayiro wenyu.
\q1 
\v 30 Ndakasarudza nzira yechokwadi;
\q2 ndakaisa mwoyo wangu pamurayiro wenyu.
\q1 
\v 31 Haiwa Jehovha, ini ndichabatirira pazvirevo zvenyu;
\q2 musandirega ndichinyadziswa.
\q1 
\v 32 Ndinomhanya munzira yomurayiro wenyu,
\q2 nokuti makasunungura mwoyo wangu.
\qa He
\q1 
\v 33 Ndidzidzisei, imi Jehovha, kutevera mitemo yenyu;
\q2 ipapo ndichaichengeta kusvikira kumagumo.
\q1 
\v 34 Ndipei kunzwisisa, ndigochengeta murayiro wenyu
\q2 uye ndigouteerera nomwoyo wangu wose.
\q1 
\v 35 Nditungamirirei munzira yemirayiro yenyu,
\q2 nokuti imomo ndinowana mufaro.
\q1 
\v 36 Dzorerai mwoyo wangu pane zvamakatema
\q2 kwete pakuchiva kwenyama.
\q1 
\v 37 Dzorai meso angu pazvinhu zvisina maturo;
\q2 chengetedzai upenyu hwangu sezvinoreva shoko renyu.
\q1 
\v 38 Zadzisai zvamakapikira muranda wenyu,
\q2 kuti mugotyiwa.
\q1 
\v 39 Bvisai kunyadziswa kwandaitya,
\q2 nokuti mitemo yenyu yakanaka.
\q1 
\v 40 Ndinoshuva zvirevo zvenyu sei!
\q2 Chengetedzai upenyu hwangu mukururama kwenyu.
\qa Wawu
\q1 
\v 41 Rudo rwenyu rusingaperi ngaruuye kwandiri,
\q2 Jehovha, noruponeso rwenyu sezvamakavimbisa;
\q1 
\v 42 ipapo ndichapindura vanondishora,
\q2 nokuti ndinovimba neshoko renyu.
\q1 
\v 43 Regai kubvisa shoko rechokwadi pamuromo pangu,
\q2 nokuti ndakaisa tariro yangu mumurayiro wenyu.
\q1 
\v 44 Ndichagara ndichiteerera murayiro wenyu,
\q2 nokusingaperi-peri.
\q1 
\v 45 Ndichafamba-famba ndakasununguka,
\q2 nokuti ndakatsvaka zvirevo zvenyu.
\q1 
\v 46 Ndichataura zvamakatema pamberi pamadzimambo,
\q2 uye handinganyadziswi,
\q1 
\v 47 nokuti ndinofarira mirayiro yenyu
\q2 nokuti ndinoida.
\q1 
\v 48 Ndinosimudzira maoko angu
\q2 kumirayiro yenyu yandinoda, uye ndinofungisisa zvirevo zvenyu.
\qa Zayini
\q1 
\v 49 Rangarirai shoko renyu kumuranda wenyu,
\q2 nokuti makandipa tariro.
\q1 
\v 50 Zvinondinyaradza pakutambura kwangu ndezvizvi:
\q2 Vimbiso yenyu inochengetedza upenyu hwangu.
\q1 
\v 51 Vanozvikudza vanondiseka vasingaregi,
\q2 asi ini handitsauki pamurayiro wenyu.
\q1 
\v 52 Ndinorangarira mirayiro yenyu yekare, imi Jehovha,
\q2 uye ndinonyaradzwa mairi.
\q1 
\v 53 Shungu dzinondibata nokuda kwavakaipa,
\q2 vakasiya murayiro wenyu.
\q1 
\v 54 Mitemo yenyu ndiro dingindira rorwiyo rwangu
\q2 pose pandinogara.
\q1 
\v 55 Haiwa, Jehovha, ndinorangarira zita renyu usiku,
\q2 uye ndichachengeta murayiro wenyu.
\q1 
\v 56 Aya ndiwo anga ari maitiro angu:
\q2 Ndinoteerera zvirevo zvenyu.
\qa Heti
\q1 
\v 57 Haiwa, Jehovha, ndimi mugove wangu;
\q2 ndakavimbisa kuteerera mashoko enyu.
\q1 
\v 58 Ndakatsvaka chiso chenyu nomwoyo wangu wose;
\q2 ndinzwirei nyasha sezvamakavimbisa.
\q1 
\v 59 Ndakacherechedza nzira dzangu
\q2 ndikadzorera tsoka dzangu kune zvamakatema.
\q1 
\v 60 Ndichakurumidza uye handinganonoki
\q2 kuteerera mirayiro yenyu.
\q1 
\v 61 Kunyange vakaipa vakandisunga namabote,
\q2 handizokanganwi murayiro wenyu.
\q1 
\v 62 Ndinomuka pakati pousiku ndichikuvongai
\q2 nokuda kwemirayiro yenyu yakarurama.
\q1 
\v 63 Ndiri shamwari yavose vanokutyai,
\q2 nokuna vose vanotevera zvirevo zvenyu.
\q1 
\v 64 Haiwa Jehovha, nyika izere norudo rwenyu,
\q2 ndidzidzisei zvirevo zvenyu.
\qa Teti
\q1 
\v 65 Makaitira muranda wenyu zvakanaka,
\q2 imi Jehovha, sezvakafanira shoko renyu.
\q1 
\v 66 Ndidzidzisei zivo nokutonga kwakanaka,
\q2 nokuti ndakatenda mirayiro yenyu.
\q1 
\v 67 Pandakanga ndisati ndatambudzika,
\q2 ndakatsauka, asi zvino ndinoteerera shoko renyu.
\q1 
\v 68 Imi makanaka, uye munoita zvakanaka;
\q2 ndidzidzisei mitemo yenyu.
\q1 
\v 69 Kunyange vanozvikudza vakandipomera nhema,
\q2 ndinochengeta zvamakatema nomwoyo wangu wose.
\q1 
\v 70 Mwoyo yavo yakasindimara uye hainzwisisi,
\q2 asi ndinofarira murayiro wenyu.
\q1 
\v 71 Zvakanga zvakanaka kuti nditambudzike,
\q2 kuitira kuti ndigodzidza mitemo yenyu.
\q1 
\v 72 Murayiro unobva pamuromo wenyu unokosha kwandiri,
\q2 kupfuura zviuru zvezvimedu zvesirivha negoridhe.
\qa Yodhi
\q1 
\v 73 Maoko enyu akandisika uye akandiumba;
\q2 ndipei kunzwisisa kuti ndigodzidza mirayiro yenyu.
\q1 
\v 74 Avo vanokutyai ngavafare pavanondiona,
\q2 nokuti ndakaisa tariro yangu pashoko renyu.
\q1 
\v 75 Haiwa Jehovha, ndinoziva kuti mirayiro yenyu yakarurama,
\q2 uye kuti makanditambudza mukutendeka kwenyu.
\q1 
\v 76 Rudo rwenyu rusingaperi ngarutinyaradze,
\q2 maererano nechivimbiso chenyu kumuranda wenyu.
\q1 
\v 77 Tsitsi dzenyu ngadziuye kwandiri kuti ndirarame,
\q2 nokuti murayiro wenyu ndiwo mufaro wangu.
\q1 
\v 78 Vanozvikudza ngavanyadziswe pakundikanganisira ndisina mhaka,
\q2 asi ini ndichafungisisa zvirevo zvenyu.
\q1 
\v 79 Vanokutyai ngavadzokere kwandiri,
\q2 ivo vanonzwisisa zvamakatema.
\q1 
\v 80 Mwoyo wangu ngaushaye chaungapomerwa pamitemo yenyu,
\q2 kuti ndirege kunyadziswa.
\qa Kafi
\q1 
\v 81 Mweya wangu unoziya nokuda kwekushuva ruponeso rwenyu,
\q2 asi ndakaisa tariro yangu pashoko renyu.
\q1 
\v 82 Meso angu aneta nokutsvaga chivimbiso chenyu;
\q2 ndinoti, “Muchandinyaradza riniko?”
\q1 
\v 83 Kunyange ndakaita sehomwe yewaini ndiri muutsi,
\q2 handikanganwi mitemo yenyu.
\q1 
\v 84 Muranda wenyu acharindira kusvikira riniko?
\q2 Mucharanga vatambudzi vangu riniko?
\q1 
\v 85 Vanozvikudza vakandicherera makomba,
\q2 zvinopesana nomurayiro wenyu.
\q1 
\v 86 Mirayiro yenyu yose yakavimbika, ndibatsirei,
\q2 nokuti vanhu vanonditambudza ndisina mhaka.
\q1 
\v 87 Vakanga voda kundibvisa panyika,
\q2 asi handina kusiya zvamakatema.
\q1 
\v 88 Chengetedzai upenyu hwangu zvakafanira rudo rwenyu,
\q2 uye ini ndichateerera zvirevo zvomuromo wenyu.
\qa Ramedhi
\q1 
\v 89 Haiwa Jehovha, shoko renyu rinogara nokusingaperi;
\q2 rinomira rakasimba kudenga denga.
\q1 
\v 90 Kutendeka kwenyu kunoramba kuripo kusvikira kuzvizvarwa zvose;
\q2 makasimbisa nyika uye inogara nokusingaperi.
\q1 
\v 91 Mirayiro yenyu iripo kusvikira iye nhasi,
\q2 nokuti zvinhu zvose zvinokushumirai.
\q1 
\v 92 Dai murayiro wenyu wanga usiri mufaro wangu,
\q2 ndingadai ndakafira mumatambudziko angu.
\q1 
\v 93 Handichazokanganwi zvamakatema,
\q2 nokuti nazvo makachengetedza upenyu hwangu.
\q1 
\v 94 Ndiponesei, nokuti ndiri wenyu;
\q2 ndakatsvaka zvamakatema.
\q1 
\v 95 Vakaipa vakarindira kundiparadza,
\q2 asi ini ndichafunga zvirevo zvenyu.
\q1 
\v 96 Ndinoona kuguma kwezvose zvakakwana,
\q2 asi mirayiro yenyu haina magumo.
\qa Memu
\q1 
\v 97 Haiwa, ndinoda murayiro wenyu sei!
\q2 Ndinoufungisisa zuva rose.
\q1 
\v 98 Mirayiro yenyu inoita kuti ndive akachenjera kupfuura vavengi vangu,
\q2 nokuti inogara neni nguva dzose.
\q1 
\v 99 Ndinonzwisisa zvakawanda kupfuura vadzidzisi vangu,
\q2 nokuti ndinofungisisa pamusoro pezvamakatema.
\q1 
\v 100 Ndinonzwisisa zvikuru kupfuura vakuru,
\q2 nokuti ndinoteerera zvirevo zvenyu.
\q1 
\v 101 Ndakadzora tsoka dzangu panzira
\q2 dzose dzakaipa kuti nditeerere shoko renyu.
\q1 
\v 102 Handina kubva pamirayiro yenyu,
\q2 nokuti imi pachenyu makandidzidzisa.
\q1 
\v 103 Mashoko enyu anotapira seiko pakuaravira,
\q2 anotapira kukunda uchi mumukanwa mangu!
\q1 
\v 104 Ndinowana kunzwisisa kubva pazvirevo zvenyu;
\q2 naizvozvo ndinovenga nzira dzose dzakaipa.
\qa Nuni
\q1 
\v 105 Shoko renyu ndiwo mwenje wetsoka dzangu,
\q2 nechiedza chenzira yangu.
\q1 
\v 106 Ndakaita mhiko ndikaisimbisa,
\q2 kuti ndichatevera mirayiro yenyu yakarurama.
\q1 
\v 107 Ndakatambudzika kwazvo;
\q2 chengetedzai upenyu hwangu, imi Jehovha, zvakafanira shoko renyu.
\q1 
\v 108 Haiwa Jehovha, gamuchirai henyu kurumbidza kwomuromo wangu,
\q2 mugondidzidzisa mirayiro yenyu.
\q1 
\v 109 Kunyange ndichiramba ndakabata upenyu hwangu mumaoko angu,
\q2 handizokanganwi murayiro wenyu.
\q1 
\v 110 Vakaipa vakanditeya nomusungo,
\q2 asi handina kutsauka pazvirevo zvenyu.
\q1 
\v 111 Zvirevo zvenyu inhaka yangu nokusingaperi;
\q2 ndizvo mufaro womwoyo wangu.
\q1 
\v 112 Mwoyo wangu wakagarira kuchengeta zvirevo zvenyu,
\q2 kusvikira kumagumo.
\qa Sameki
\q1 
\v 113 Ndinovenga vanhu vane mwoyo miviri,
\q2 asi ndinoda murayiro wenyu.
\q1 
\v 114 Imi muri utiziro hwangu nenhoo yangu;
\q2 ndakaisa tariro yangu pashoko renyu.
\q1 
\v 115 Ibvai kwandiri, imi vaiti vezvakaipa,
\q2 kuti ndichengete mirayiro yaMwari wangu!
\q1 
\v 116 Nditsigirei sezvamakavimbisa, ipapo ndichararama;
\q2 musarega tariro yangu ichidzimwa.
\q1 
\v 117 Nditsigirei, ipapo ndicharwirwa;
\q2 ndicharamba ndine hanya nemitemo yenyu.
\q1 
\v 118 Munoramba vose vanotsauka pamitemo yenyu,
\q2 nokuti kunyengera kwavo hakuna maturo.
\q1 
\v 119 Vakaipa vose venyika munovaita sengura;
\q2 naizvozvo ndinoda zvamakatema.
\q1 
\v 120 Nyama yangu inodedera nokuda kwokukutyai;
\q2 ndinomira ndichitya mirayiro yenyu.
\qa Ayini
\q1 
\v 121 Ndakaita zvakarurama nokururamisira;
\q2 musandisiya mumaoko avadzvinyiriri vangu.
\q1 
\v 122 Itai kuti muranda wenyu agare zvakanaka;
\q2 musarega vanozvikudza vachimudzvinyirira.
\q1 
\v 123 Meso angu aneta nokutsvaka ruponeso rwenyu,
\q2 ndichitsvaga vimbiso yenyu yakarurama.
\q1 
\v 124 Itirai muranda wenyu zvinoringana norudo rwenyu,
\q2 uye ndidzidzisei mitemo yenyu.
\q1 
\v 125 Ndiri muranda wenyu;
\q2 ndipeiwo kunzvera kuti ndigonzwisisa zvamakatema.
\q1 
\v 126 Haiwa Jehovha, inguva yenyu yokubata;
\q2 murayiro wenyu uri kuputswa.
\q1 
\v 127 Nokuti ndinoda mirayiro yenyu kupfuura goridhe,
\q2 kupfuura goridhe rakanatswa,
\q1 
\v 128 uye nokuti ndinoti zvirevo zvenyu zvose zvakarurama,
\q2 ndinovenga nzira dzose dzakaipa.
\qa Pe
\q1 
\v 129 Zvirevo zvenyu zvinoshamisa;
\q2 naizvozvo ndinozviteerera.
\q1 
\v 130 Kuzarurwa kweshoko renyu kunopa chiedza;
\q2 kunopa kunzwisisa kuna vasina mano.
\q1 
\v 131 Ndinoshamisa muromo wangu ndigodokwaira,
\q2 ndichishuva mirayiro yenyu.
\q1 
\v 132 Dzokerai kwandiri mugondinzwira ngoni,
\q2 sezvamunogara muchiita kuna avo vanoda zita renyu.
\q1 
\v 133 Rayirai nhambwe dzetsoka dzangu zviri maererano neshoko renyu;
\q2 chivi ngachirege kunditonga.
\q1 
\v 134 Ndidzikinurei pakudzvinyirira kwavanhu,
\q2 kuti ndigoteerera zvirevo zvenyu.
\q1 
\v 135 Chiso chenyu ngachipenye pamusoro pomuranda wenyu,
\q2 uye ndidzidzisei mitemo yenyu.
\q1 
\v 136 Hova dzemisodzi dzinoerera dzichibva mumeso angu,
\q2 nokuti murayiro wenyu hausi kuteererwa.
\qa Tsadhe
\q1 
\v 137 Haiwa Jehovha, imi makarurama,
\q2 uye mirayiro yenyu yakarurama.
\q1 
\v 138 Zvirevo zvenyu zvamakadzika zvakarurama;
\q2 zvakavimbika kwazvo.
\q1 
\v 139 Kushingaira kwangu kunondipedza,
\q2 nokuti vavengi vangu havana hanya namashoko enyu.
\q1 
\v 140 Vimbiso dzenyu dzakaedzwa chose,
\q2 uye muranda wenyu anodzida.
\q1 
\v 141 Kunyange ndakaderedzwa uye ndichizvidzwa hangu,
\q2 handikanganwi zvirevo zvenyu.
\q1 
\v 142 Kururama kwenyu kunogara nokusingaperi,
\q2 uye murayiro wenyu ndowezvokwadi.
\q1 
\v 143 Nhamo namatambudziko zviri pamusoro pangu,
\q2 asi mirayiro yenyu ndiwo mufaro wangu.
\q1 
\v 144 Zvirevo zvenyu zvinogara zvakarurama;
\q2 ndipeiwo kunzwisisa kuti ndirarame.
\qa Kofi
\q1 
\v 145 Ndinodana nomwoyo wangu wose; haiwa Jehovha ndipindureiwo,
\q2 uye ndichateerera mitemo yenyu.
\q1 
\v 146 Ndinodanidzira kwamuri,
\q2 ndiponesei uye ndichachengeta zvamakatema.
\q1 
\v 147 Ndinomuka mambakwedza asati asvika ndigochemera kubatsirwa;
\q2 ndakaisa tariro yangu pashoko renyu.
\q1 
\v 148 Meso angu anogara akasvinura panguva dzose dzousiku,
\q2 kuti ndifungisise pamusoro pevimbiso dzenyu.
\q1 
\v 149 Inzwai inzwi rangu sezvakafanira rudo rwenyu;
\q2 haiwa Jehovha, chengetedzai upenyu hwangu zviri maererano nemirayiro yenyu.
\q1 
\v 150 Vanoita mano akaipa vari pedyo,
\q2 asi vari kure nomurayiro wenyu.
\q1 
\v 151 Asi imi muri pedyo, Jehovha,
\q2 uye mirayiro yenyu yose ndeyezvokwadi.
\q1 
\v 152 Ndakadzidza pane zvamakatema kare,
\q2 kuti makazvisimbisa kuti zvigare nokusingaperi.
\qa Reshi
\q1 
\v 153 Tarirai kutambudzika kwangu mugondirwira,
\q2 nokuti handina kukanganwa murayiro wenyu.
\q1 
\v 154 Miririrai mhosva yangu uye mundidzikinure;
\q2 chengetedzai upenyu hwangu maererano nevimbiso yenyu.
\q1 
\v 155 Ruponeso rwuri kure navakaipa,
\q2 nokuti havatsvaki mitemo yenyu.
\q1 
\v 156 Haiwa Jehovha, tsitsi dzenyu ihuru;
\q2 chengetedzai upenyu hwangu maererano nemirayiro yenyu.
\q1 
\v 157 Vavengi vangu navanonditambudza vazhinji,
\q2 asi handina kutsauka pane zvamakatema.
\q1 
\v 158 Ndinotarira kuna vasingatendi ndichisema,
\q2 nokuti havateereri shoko renyu.
\q1 
\v 159 Tarirai madiro andinoita zvirevo zvenyu;
\q2 haiwa Jehovha, chengetedzai upenyu hwangu, maererano norudo rwenyu.
\q1 
\v 160 Mashoko enyu ose ndeechokwadi;
\q2 mirayiro yenyu yose yakarurama ndeyokusingaperi.
\qa Sini neShini
\q1 
\v 161 Vatongi vanonditambudza ndisina mhaka,
\q2 asi mwoyo wangu unodedera pashoko renyu.
\q1 
\v 162 Ndinofarira vimbiso yenyu
\q2 kufanana nouyo anowana zvakapambwa zvizhinji.
\q1 
\v 163 Ndinovenga uye ndinosema nhema,
\q2 asi ndinoda murayiro wenyu.
\q1 
\v 164 Ndinokurumbidzai kanomwe pazuva,
\q2 nokuda kwemirayiro yenyu yakarurama.
\q1 
\v 165 Vanoda murayiro wenyu vano rugare rukuru,
\q2 uye hakuna chingavagumbusa.
\q1 
\v 166 Haiwa Jehovha, ndakamirira ruponeso rwenyu,
\q2 uye ndinotevera mirayiro yenyu.
\q1 
\v 167 Ndinoteerera zvirevo zvenyu,
\q2 nokuti ndinozvida zvikuru.
\q1 
\v 168 Ndinoteerera zvirevo zvenyu nezvamakatema,
\q2 nokuti nzira dzangu dzose dzinozivikanwa nemi.
\qa Tawu
\q1 
\v 169 Dai kuchema kwangu kwasvika pamberi penyu, imi Jehovha;
\q2 ndipeiwo kunzwisisa maererano neshoko renyu.
\q1 
\v 170 Kukumbira kwangu dai kwasvika pamberi penyu;
\q2 ndirwirei maererano nevimbiso yenyu.
\q1 
\v 171 Miromo yangu dai yafashukira nerumbidzo,
\q2 nokuti munondidzidzisa mitemo yenyu.
\q1 
\v 172 Rurimi rwangu dai rwaimba nezveshoko renyu,
\q2 nokuti mirayiro yenyu yose yakarurama.
\q1 
\v 173 Ruoko rwenyu dai rwagadzirira kundibatsira,
\q2 nokuti ndakasarudza zvirevo zvenyu.
\q1 
\v 174 Haiwa Jehovha, ndinoshuva ruponeso rwenyu,
\q2 uye murayiro wenyu ndiwo mufaro wangu.
\q1 
\v 175 Regai ndirarame kuti ndigokurumbidzai,
\q2 uye dai mirayiro yenyu yandibatsira.
\q1 
\v 176 Ndakatsauka segwai rakarasika.
\q2 Tsvakai muranda wenyu,
\q2 nokuti handina kukanganwa mirayiro yenyu.
\c 120
\cl Pisarema 120
\d Rwiyo rworwendo.
\q1 
\v 1 Ndinodana kuna Jehovha mukutambudzika kwangu,
\q2 uye anondipindura.
\q1 
\v 2 Haiwa Jehovha, ndiponesei pamiromo inoreva nhema,
\q2 nendimi dzinonyengera.
\b
\q1 
\v 3 Achaiteiko kwauri,
\q2 uye chimwe chiiko kunze kwezvizvi, iwe rurimi runonyengera?
\q1 
\v 4 Achakuranga nemiseve yakapinza yemhare,
\q2 namazimbe anopfuta omuti womurara.
\b
\q1 
\v 5 Ndine nhamo ini ndinogara muMesheki,
\q2 kuti ndinogara pakati pamatende eKedhari!
\q1 
\v 6 Ndakagara nguva refu
\q2 pakati pavanovenga rugare.
\q1 
\v 7 Ndiri munhu worugare;
\q2 asi pandinotaura, ivo ndevehondo.
\c 121
\cl Pisarema 121
\d Rwiyo rworwendo.
\q1 
\v 1 Ndinosimudzira meso angu kumakomo,
\q2 kubatsirwa kwangu kunobvepiko?
\q1 
\v 2 Rubatsiro rwangu runobva kuna Jehovha,
\q2 muiti wokudenga napasi.
\b
\q1 
\v 3 Haangatenderi rutsoka rwako kuti rutedzemuke,
\q2 muchengeti wako haangakotsiri;
\q1 
\v 4 zvirokwazvo, muchengeti waIsraeri
\q2 haangakotsiri kana kuvata.
\b
\q1 
\v 5 Jehovha anokurinda,
\q2 Jehovha ndiye mumvuri wako kuruoko rwako rworudyi;
\q1 
\v 6 zuva haringakubayi masikati,
\q2 kana mwedzi usiku.
\b
\q1 
\v 7 Jehovha achakuchengeta pane zvose zvinokuvadza,
\q2 iye acharinda upenyu hwako;
\q1 
\v 8 Jehovha achakurinda pakubuda kwako napakupinda kwako,
\q2 kubva zvino uye nokusingaperi.
\c 122
\cl Pisarema 122
\d Rwiyo rworwendo rwaDhavhidhi.
\q1 
\v 1 Ndakafara pavakati kwandiri,
\q2 “Handei kumba yaJehovha.”
\q1 
\v 2 Tsoka dzedu dzimire
\q2 mukati mamasuo ako, iwe Jerusarema.
\b
\q1 
\v 3 Jerusarema rakavakwa seguta
\q2 rakapakata kwazvo.
\q1 
\v 4 Ndiko kunokwira marudzi,
\q2 iwo marudzi aJehovha,
\q1 kundorumbidza zita raJehovha
\q2 maererano nezvakatemerwa Israeri.
\q1 
\v 5 Zvigaro zvokutonga zvimire ikoko,
\q2 zvigaro zvoushe zveimba yaDhavhidhi.
\b
\q1 
\v 6 Nyengetererai rugare rweJerusarema:
\q2 “Vanokuda dai vagara zvakanaka.
\q1 
\v 7 Dai mukati mamasvingo ako maita rugare,
\q2 nokuchengetedzeka mukati menhare dzako.”
\q1 
\v 8 Nokuda kwehama neshamwari dzangu,
\q2 ndichati, “Rugare ngaruve mukati mako.”
\q1 
\v 9 Nokuda kweimba yaJehovha Mwari wedu,
\q2 ndichatsvaka kubudirira kwako.
\c 123
\cl Pisarema 123
\d Rwiyo rworwendo.
\q1 
\v 1 Ndinosimudzira meso angu kwamuri,
\q2 kunemi mune chigaro choushe kudenga.
\q1 
\v 2 Sokutarira kunoita meso evaranda kuna vatenzi vavo,
\q2 sezvinoita meso omurandakadzi achitarira ruoko rwatenzikadzi wake,
\q1 saizvozvo meso edu anotarira kuna Jehovha Mwari wedu,
\q2 kusvikira atinzwira ngoni.
\b
\q1 
\v 3 Tinzwirei ngoni, imi Jehovha, tinzwirei ngoni,
\q2 nokuti takatsunga pakuzvidzwa kwakawanda.
\q1 
\v 4 Takatsunga zvikuru pakumhurwa kunobva kuna vanozvikudza,
\q2 nokuzvidzwa kuzhinji kunobva kuna vanozvikudza.
\c 124
\cl Pisarema 124
\d Rwiyo rworwendo rwaDhavhidhi.
\q1 
\v 1 Israeri ngaati
\q2 dai Jehovha akanga asiri kurutivi kwedu,
\q1 
\v 2 dai Jehovha akanga asiri kurutivi kwedu
\q2 patakarwiswa navanhu,
\q1 
\v 3 apo kutsamwa kwavo kwakatimukira,
\q2 vangadai vakatimedza tiri vapenyu;
\q1 
\v 4 mafashamu angadai akatifukidza,
\q2 mvura zhinji ingadai yakatikukura,
\q1 
\v 5 mvura zhinji ine hasha
\q2 ingadai yakatirasira kure.
\b
\q1 
\v 6 Jehovha ngaarumbidzwe,
\q2 asina kutendera kuti tibvamburwe nameno avo.
\q1 
\v 7 Tapunyuka seshiri yabva parugombe rwomuteyi;
\q2 rugombe rwadamburwa uye tapunyuka.
\q1 
\v 8 Kubatsirwa kwedu kuri muzita raJehovha,
\q2 Muiti wedenga nenyika.
\c 125
\cl Pisarema 125
\d Rwiyo rworwendo.
\q1 
\v 1 Vanovimba naJehovha vakafanana neGomo reZioni,
\q2 risingazungunuswi asi rinogara nokusingaperi.
\q1 
\v 2 Sokupoteredzwa kwakaitwa Jerusarema namakomo,
\q2 saizvozvo Jehovha anopoteredza vanhu vake
\q2 kubva zvino nokusingaperi.
\b
\q1 
\v 3 Tsvimbo yavasakarurama haingagari
\q2 pamusoro penyika yakagoverwa vakarurama,
\q1 nokuti ipapo vakarurama vangazotambanudzira
\q2 maoko avo kuita zvakaipa.
\b
\q1 
\v 4 Haiwa Jehovha, itirai zvakanaka, kuna avo vakanaka,
\q2 kuna avo vane mwoyo yakarurama.
\q1 
\v 5 Asi avo vanotsaukira kunzira dzakaminama,
\q2 Jehovha achavaparadza pamwe chete navaiti vezvakaipa.
\b
\q1 Rugare ngaruve pana Israeri.
\c 126
\cl Pisarema 126
\d Rwiyo rworwendo.
\q1 
\v 1 Jehovha paakadzosa vatapwa kuZioni,
\q2 takanga tava savanhu vairota.
\q1 
\v 2 Miromo yedu yakanga izere nokuseka,
\q2 ndimi dzedu dzizere nenziyo dzomufaro.
\q1 Ipapo zvakanzi pakati pendudzi,
\q2 “Jehovha akavaitira zvinhu zvikuru.”
\q1 
\v 3 Jehovha atiitira zvinhu zvikuru,
\q2 uye tazara nomufaro.
\b
\q1 
\v 4 Tidzorereizve nhaka yedu, imi Jehovha,
\q2 sehova dzeNegevhi.
\q1 
\v 5 Avo vanodyara nemisodzi
\q2 vachakohwa nenziyo dzomufaro.
\q1 
\v 6 Uyo anobuda achichema,
\q2 akatakura mbeu yokudyara,
\q1 achadzoka nenziyo dzomufaro,
\q2 akatakura zvisote.
\c 127
\cl Pisarema 127
\d Rwiyo rworwendo rwaSoromoni.
\q1 
\v 1 Kana Jehovha asingavaki imba,
\q2 vavaki vayo vanoshandira pasina.
\q1 Kana Jehovha asingachengeti guta,
\q2 varindi vanomira vakarinda pasina.
\q1 
\v 2 Hazvina maturo kumuka mangwanani
\q2 nokunonoka kuvata,
\q1 uchitambudzikira zvokudya,
\q2 nokuti anopa hope kuna vaanoda.
\b
\q1 
\v 3 Vanakomana inhaka inobva kuna Jehovha,
\q2 vana mubayiro unobva kwaari.
\q1 
\v 4 Semiseve mumaoko emhare
\q2 ndizvo zvakaita vanakomana voujaya.
\q1 
\v 5 Akaropafadzwa murume
\q2 ane goba rizere navo.
\q1 Havanganyadziswi
\q2 pavanokakavadzana navavengi vavo pasuo.
\c 128
\cl Pisarema 128
\d Rwiyo rworwendo.
\q1 
\v 1 Vakaropafadzwa vose vanotya Jehovha,
\q2 vanofamba munzira dzake.
\q1 
\v 2 Uchadya chibereko chokushanda kwako;
\q2 maropafadzo nokubudirira zvichava zvako.
\q1 
\v 3 Mukadzi wako achava somuzambiringa unobereka,
\q2 pakati peimba yako;
\q1 vanakomana vako vachaita samabukira omuorivhi,
\q2 vakakomberedza tafura yako.
\q1 
\v 4 Ndizvo zvakaita munhu akaropafadzwa,
\q2 anotya Jehovha.
\b
\q1 
\v 5 Jehovha ngaakuropafadzei kubva kuZioni,
\q2 mazuva ose oupenyu hwenyu;
\q1 muone henyu kubudirira kweJerusarema,
\q2 
\v 6 uye murarame kuti muone vana vavana venyu.
\b
\q1 Rugare ngaruve pana Israeri.
\c 129
\cl Pisarema 129
\d Rwiyo rworwendo.
\q1 
\v 1 Vakandidzvinyirira zvikuru kubva pauduku hwangu,
\q2 Israeri ngaati,
\q1 
\v 2 “Vakandidzvinyirira zvikuru kubva pauduku hwangu,
\q2 asi havana kundikunda.
\q1 
\v 3 Varimi vakarima musana wangu
\q2 vakaita miforo yavo mirefu.”
\q1 
\v 4 Asi Jehovha akarurama,
\q2 akandisunungura pamabote avakaipa.
\b
\q1 
\v 5 Vose vanovenga Zioni
\q2 ngavadzorerwe shure nenyadzi.
\q1 
\v 6 Ngavaite souswa pamusoro pedenga remba,
\q2 hunooma husati hwakura;
\q1 
\v 7 mukohwi haangazadzi maoko ake nahwo,
\q2 uye anounganidza haangazadzi maoko ake.
\q1 
\v 8 Vanopfuura nepo ngavarege kuti,
\q2 “Maropafadzo aJehovha ngaave pamusoro pako;
\q2 tinokuropafadza muzita raJehovha.”
\c 130
\cl Pisarema 130
\d Rwiyo rworwendo.
\q1 
\v 1 Ndinodanidzira kwamuri Jehovha,
\q2 ndiri pakadzika;
\q1 
\v 2 haiwa Jehovha, inzwai inzwi rangu.
\q2 Nzeve dzenyu ngadzinzwe kuchemera kwangu ngoni.
\b
\q1 
\v 3 Dai imi, iyemi Jehovha, maironda zvakaipa zvomunhu,
\q2 haiwa Jehovha, ndianiko aimira?
\q1 
\v 4 Asi kwamuri kune kukanganwira;
\q2 naizvozvo imi munotyiwa.
\b
\q1 
\v 5 Ndinomirira Jehovha, mweya wangu unomirira,
\q2 uye tariro yangu iri mushoko rake.
\q1 
\v 6 Mweya wangu unorindira Ishe
\q2 kupfuura varindi
\q2 vanomirira rungwanani.
\b
\q1 
\v 7 Haiwa Israeri, isa tariro yako muna Jehovha,
\q2 nokuti Jehovha ane rudo rusingaperi
\q2 uye kwaari kune dzikinuro izere.
\q1 
\v 8 Iye pachake achadzikinura Israeri
\q2 kubva pazvivi zvavo zvose.
\c 131
\cl Pisarema 131
\d Rwiyo rworwendo rwaDhavhidhi.
\q1 
\v 1 Haiwa Jehovha, mwoyo wangu hauzvikudzi,
\q2 meso angu haana manyawi;
\q1 handina hanya nezvinhu zvikuru
\q2 kana zvinhu zvinonyanya kushamisa.
\q1 
\v 2 Asi ndakadzikamisa uye ndakanyaradza mweya wangu;
\q2 somwana akarumurwa namai vake,
\q2 somwana akarumurwa, ndizvo zvakaita mweya wangu mandiri.
\b
\q1 
\v 3 Haiwa Israeri, isai tariro yenyu pana Jehovha,
\q2 kubva zvino nokusingaperi.
\c 132
\cl Pisarema 132
\d Rwiyo rworwendo.
\q1 
\v 1 Haiwa Jehovha, rangarirai Dhavhidhi
\q2 namatambudziko ake ose aakasangana nawo.
\q1 
\v 2 Akapika mhiko kuna Jehovha,
\q2 akaita mhiko kuna Wamasimba waJakobho achiti,
\q1 
\v 3 “Handingapindi mumba mangu
\q2 kana kuenda kundovata pamubhedha wangu,
\q1 
\v 4 handingatenderi hope mumaziso angu,
\q2 kana kutsumwaira mumeso angu,
\q1 
\v 5 kusvikira ndawana nzvimbo yaJehovha,
\q2 nzvimbo yokugara yoWamasimba waJakobho.”
\b
\q1 
\v 6 Takazvinzwa muEfurata,
\q2 takasangana nazvo muminda yeJaari tikati,
\q1 
\v 7 “Ngatiendei kunzvimbo yake yokugara;
\q2 ngatinamatei pachitsiko chetsoka dzake,
\q1 
\v 8 haiwa Jehovha, simukai muuye kunzvimbo yenyu yokuzorora,
\q2 imi neareka yesimba renyu.
\q1 
\v 9 Vaprista venyu dai vafukidzwa nokururama;
\q2 dai vatsvene venyu vaimba nomufaro.”
\b
\q1 
\v 10 Nokuda kwaDhavhidhi muranda wenyu,
\q2 musaramba muzodziwa wenyu.
\b
\q1 
\v 11 Jehovha akapika mhiko kuna Dhavhidhi,
\q2 mhiko yechokwadi yaasingagoni kushandura achiti,
\q1 “Mumwe wechizvarwa chako
\q2 ndichamugadza pachigaro chako choushe,
\q1 
\v 12 kana vanakomana vako vakachengeta sungano yangu
\q2 nezvandakatema zvandakavadzidzisa,
\q1 ipapo vanakomana vavo
\q2 vachagara pachigaro chako choushe nokusingaperi-peri.”
\b
\q1 
\v 13 Nokuti Jehovha akasarudza Zioni,
\q2 akarida kuti huve ugaro hwake achiti,
\q1 
\v 14 “Iyi ndiyo nzvimbo yangu yokuzorora nokusingaperi-peri;
\q2 ipapa ndipo pandichagara samambo, nokuti ndakapada,
\q1 
\v 15 ndichariropafadza nezvakawanda;
\q2 ndichagutsa varombo varo nezvokudya.
\q1 
\v 16 Ndichafukidza vaprista varo noruponeso,
\q2 uye vatsvene varo vachagara vachiimba nomufaro.
\b
\q1 
\v 17 “Pano ndipo pandichameresa nyanga yaDhavhidhi,
\q2 uye ndichatungidza mwenje womuzodziwa wangu.
\q1 
\v 18 Ndichafukidza vavengi vake nenyadzi,
\q2 asi korona yake ichabwinya kwazvo.”
\c 133
\cl Pisarema 133
\d Rwiyo rworwendo rwaDhavhidhi.
\q1 
\v 1 Zvakanaka uye zvinofadza sei
\q2 kana hama dzichigara pamwe chete mukubatana!
\q1 
\v 2 Zvakafanana namafuta anokosha adururirwa pamusoro,
\q2 anoerera kundebvu,
\q1 anoerera kundebvu dzaAroni,
\q2 anoburukira kusvikira pamipendero yenguo dzake.
\q1 
\v 3 Zvinoita sokuti dova reHerimoni
\q2 riri kuwira pamusoro peGomo reZioni.
\q1 Nokuti ndipo pakaiswa kuropafadza kwaJehovha,
\q2 ihwo upenyu husingaperi-peri.
\c 134
\cl Pisarema 134
\d Rwiyo rworwendo.
\q1 
\v 1 Rumbidzai Jehovha, imi varanda vose vaJehovha,
\q2 vanoshumira usiku muimba yaJehovha.
\q1 
\v 2 Simudzai maoko enyu munzvimbo tsvene,
\q2 murumbidze Jehovha.
\b
\q1 
\v 3 Dai Jehovha, iye Muiti wedenga napasi,
\q2 akuropafadzai kubva paZioni.
\c 135
\cl Pisarema 135
\q1 
\v 1 Rumbidzai Jehovha.
\b
\q1 Rumbidzai zita raJehovha;
\q2 murumbidzei, imi varanda vaJehovha,
\q1 
\v 2 imi munoshumira muimba yaJehovha,
\q2 muvanze dzeimba yaMwari wedu.
\b
\q1 
\v 3 Rumbidzai Jehovha, nokuti Jehovha akanaka;
\q2 imbirai zita rake nziyo dzokurumbidza, nokuti ndizvo zvakanaka.
\q1 
\v 4 Nokuti Jehovha akasarudza Jakobho kuti ave wake,
\q2 naIsraeri kuti ave pfuma yake.
\b
\q1 
\v 5 Ndinoziva kuti Jehovha mukuru,
\q2 uye kuti Ishe wedu mukuru kupfuura vamwari vose.
\q1 
\v 6 Jehovha anoita zvose zvinomufadza,
\q2 kudenga napasi,
\q2 nomumakungwa napakadzika pose.
\q1 
\v 7 Anoita kuti makore akwire kubva kumagumo enyika;
\q2 anotumira mheni nemvura,
\q2 uye anobudisa mhepo kubva mumatura ake.
\b
\q1 
\v 8 Ndiye akaparadza matangwe eIjipiti,
\q2 matangwe avanhu neemhuka.
\q1 
\v 9 Akatumira zviratidzo nezvishamiso zvake mukati mako,
\q2 iwe Ijipiti, pamusoro paFaro navaranda vake vose.
\q1 
\v 10 Akaparadza ndudzi dzakawanda
\q2 uye akauraya madzimambo ane simba,
\q1 
\v 11 Sihoni mambo weAmori,
\q2 Ogi mambo weBhashani
\q2 namadzimambo ose eKenani,
\q1 
\v 12 akapa nyika yavo kuti ive nhaka,
\q2 nhaka yavanhu vake Israeri.
\b
\q1 
\v 13 Haiwa Jehovha, zita renyu rinogara nokusingaperi,
\q2 mukurumbira wenyu, imi Jehovha, kuzvizvarwa zvose.
\q1 
\v 14 Nokuti Jehovha achapupurira vanhu vake
\q2 uye achava nenyasha pamusoro pavaranda vake.
\b
\q1 
\v 15 Zvifananidzo zvendudzi isirivha negoridhe,
\q2 zvakaitwa namaoko avanhu.
\q1 
\v 16 Zvine miromo, asi hazvigoni kutaura,
\q2 zvina meso, asi hazvigoni kuona;
\q1 
\v 17 nenzeve, asi hazvigoni kunzwa,
\q2 uye hamuna kufema mumuromo mazvo.
\q1 
\v 18 Vaya vanozviita vachafanana nazvo,
\q2 saizvozvowo, naivo vanovimba nazvo.
\b
\q1 
\v 19 Haiwa imi imba yaIsraeri, rumbidzai Jehovha;
\q2 haiwa imba yaAroni, rumbidzai Jehovha;
\q1 
\v 20 Haiwa imi imba yaRevhi, rumbidzai Jehovha;
\q2 imi vanomutya, rumbidzai Jehovha.
\q1 
\v 21 Jehovha ngaarumbidzwe kubva kuZioni,
\q2 iye agere muJerusarema.
\b
\q1 Rumbidzai Jehovha.
\c 136
\cl Pisarema 136
\q1 
\v 1 Vongai Jehovha, nokuti akanaka:
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 2 Vongai Mwari wavamwari:
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 3 Vongai Ishe wamadzishe:
\qr Nokuti rudo rwake runogara nokusingaperi.
\b
\q1 
\v 4 iye oga anoita zvishamiso zvikuru,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 5 iye akaita matenga nokunzwisisa kwake,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 6 iye akatambanudza nyika pamusoro pemvura zhinji,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 7 iye akaita zviedza zvikuru,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 8 zuva kuti ribate ushe masikati,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 9 mwedzi nenyeredzi kuti zvibate ushe usiku;
\qr Nokuti rudo rwake runogara nokusingaperi.
\b
\q1 
\v 10 iye akarova matangwe eIjipiti,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 11 uye akabudisa Israeri kubva pakati pavo,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 12 noruoko rune simba uye noruoko rwakatambanudzwa,
\qr Nokuti rudo rwake runogara nokusingaperi.
\b
\q1 
\v 13 iye akaparadzanisa Gungwa Dzvuku napakati,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 14 uye akayambutsa Israeri napakati paro,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 15 asi akakukura Faro nehondo yake muGungwa Dzvuku;
\qr Nokuti rudo rwake runogara nokusingaperi.
\b
\q1 
\v 16 iye akatungamirira vanhu vake nomugwenga,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 17 akarova madzimambo makuru,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 18 uye akauraya madzimambo ane simba,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 19 Sihoni mambo wavaAmori,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 20 naOgi mambo weBhashani,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 21 akavapa nyika yavo senhaka,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 22 nhaka kumuranda wake Israeri.
\qr Nokuti rudo rwake runogara nokusingaperi.
\b
\q1 
\v 23 Iye akatirangarira pakudzikisirwa kwedu,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 24 uye akatisunungura kubva pavavengi vedu,
\qr Nokuti rudo rwake runogara nokusingaperi.
\q1 
\v 25 uye anopa zvokudya kuzvisikwa zvose.
\qr Nokuti rudo rwake runogara nokusingaperi.
\b
\q1 
\v 26 Vongai Mwari wokudenga,
\qr Nokuti rudo rwake runogara nokusingaperi.
\c 137
\cl Pisarema 137
\q1 
\v 1 Panzizi dzeBhabhironi takagarapo tikachema,
\q2 patakarangarira Zioni.
\q1 
\v 2 Pamikonachando apo
\q2 ndipo patakaturika mbira dzedu,
\q1 
\v 3 nokuti ipapo avo vakatitapa vakatikumbira nziyo,
\q2 vatambudzi vedu vakatigombedzera kuti tiimbe nziyo dzomufaro, vakati,
\q2 “Tiimbirei rumwe rwiyo rweZioni!”
\b
\q1 
\v 4 Tingaimba seiko nziyo dzaJehovha
\q2 tiri munyika yokumwe?
\q1 
\v 5 Kana ndikakukanganwa, iwe Jerusarema,
\q2 ruoko rwangu rworudyi ngarukanganwe umhizha hwarwo.
\q1 
\v 6 Rurimi rwangu ngarunamatire kumusoro kwomuromo wangu,
\q2 kana ndikasakurangarira iwe,
\q1 kana ndisingafungi Jerusarema,
\q2 iwo mufaro wangu wapamusoro-soro.
\b
\q1 
\v 7 Haiwa Jehovha, rangarirai henyu zvakaitwa navaEdhomu,
\q2 pazuva rakawa Jerusarema.
\q1 Vakati, “Rikoromorei! Rikoromorei
\q2 kusvikira panheyo dzaro!”
\b
\q1 
\v 8 Haiwa Mwanasikana weBhabhironi, watongerwa kuparadzwa,
\q2 achafara munhu uyo achatsiva
\q2 kwauri zvawakaita kwatiri,
\q1 
\v 9 iye achatora pwere dzako
\q2 agodzirovera pamatombo.
\c 138
\cl Pisarema 138
\d Pisarema raDhavhidhi.
\q1 
\v 1 Ndichakurumbidzai, imi Jehovha, nomwoyo wangu wose;
\q2 ndichaimba nziyo dzokukurumbidzai pamberi pa“vamwari.”
\q1 
\v 2 Ndichakotamira pasi ndakatarisa kutemberi yenyu tsvene,
\q2 uye ndicharumbidza zita renyu
\q2 nokuda kworudo rwenyu nokutendeka kwenyu,
\q1 nokuti makakudza zita renyu
\q2 neshoko renyu pamusoro pezvinhu zvose.
\q1 
\v 3 Pandakadana, imi makandipindura;
\q2 makandishingisa nomwoyo wakasimba.
\b
\q1 
\v 4 Madzimambo ose enyika ngaakurumbidzei, imi Jehovha,
\q2 pavanonzwa mashoko omuromo wenyu.
\q1 
\v 5 Ngavaimbe pamusoro penzira dzaJehovha, nokuti kubwinya kwaJehovha kukuru.
\b
\q1 
\v 6 Kunyange Jehovha ari kumusoro, anoona vanozvininipisa,
\q2 asi vanozvikudza anovaziva vari kure.
\q1 
\v 7 Kunyange ndikafamba pakati penhamo,
\q2 munochengetedza upenyu hwangu;
\q1 munotambanudza ruoko rwenyu pamusoro pehasha dzavavengi vangu,
\q2 munondiponesa noruoko rwenyu rworudyi.
\q1 
\v 8 Jehovha achazadzisa zvirongwa zvake neni;
\q2 rudo rwenyu, imi Jehovha, runogara nokusingaperi,
\q2 musasiya mabasa amaoko enyu.
\c 139
\cl Pisarema 139
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Haiwa Jehovha, makandinzvera
\q2 uye munondiziva.
\q1 
\v 2 Munoziva nguva yandinogara neyandinosimuka;
\q2 munonzwisisa pfungwa dzangu muri kure.
\q1 
\v 3 Munonzvera kubuda kwangu nokuvata kwangu pasi;
\q2 munoziva nzira dzangu dzose.
\q1 
\v 4 Shoko risati rava parurimi rwangu,
\q2 tarirai, imi Jehovha, munoriziva rose.
\b
\q1 
\v 5 Munondikomberedza shure nemberi;
\q2 makaisa ruoko rwenyu pamusoro pangu.
\q1 
\v 6 Kuziva kwakadai kunondishamisa,
\q2 kwakanyanya kukwirira zvokuti handingasvikiri.
\b
\q1 
\v 7 Ndingaendepiko kuti ndibve paMweya wenyu?
\q2 Ndingatizirepiko kuti ndibve pamberi penyu?
\q1 
\v 8 Kana ndikakwira kumatenga, imi muriko;
\q2 kana ndikawarira mubhedha wangu kwakadzika, imi muriko.
\q1 
\v 9 Kana ndikasimuka namapapiro amambakwedza,
\q2 kana ndikandogara kumagumo egungwa,
\q1 
\v 10 kunyange ipapo ruoko rwenyu runondisesedza,
\q2 ruoko rwenyu rworudyi runondimbundikira.
\b
\q1 
\v 11 Kana ndikati, “Zvirokwazvo rima richandivanza,
\q2 uye chiedza chinondikomberedza chichava usiku kwandiri,”
\q1 
\v 12 kunyange rima haringavi rima kwamuri;
\q2 usiku huchapenya samasikati,
\q2 nokuti rima rakaita sechiedza kwamuri.
\b
\q1 
\v 13 Nokuti imi makasika zvomukatikati mangu;
\q2 makandiruka ndiri mudumbu ramai vangu.
\q1 
\v 14 Ndinokurumbidzai nokuti ndakaitwa nomutoo unotyisa uye unoshamisa;
\q2 mabasa enyu anoshamisa,
\q2 ndinonyatsozviziva kwazvo.
\q1 
\v 15 Mapfupa angu akanga asina kuvanzika kwamuri,
\q2 pandakanga ndaiswa munzvimbo yakavanda.
\q1 Pandakarukwa ndiri pakadzika penyika,
\q2 
\v 16 meso enyu akaona muviri usati waumbwa.
\q1 Mazuva ose andakarongerwa
\q2 akanga akanyorwa mubhuku renyu,
\q2 rimwe rawo risati ravapo.
\b
\q1 
\v 17 Mirangariro yenyu inokosha sei kwandiri, imi Mwari!
\q2 Yakakura sei pakuverengwa kwayo!
\q1 
\v 18 Dai ndaiverenga,
\q2 ingadai yaikunda tsanga dzejecha pakuwanda.
\q1 Pandinopepuka,
\q2 ndinenge ndinemi.
\b
\q1 
\v 19 Dai mukangouraya vakaipa, imi Mwari!
\q2 Endai kure neni, imi vanhu vokuteura ropa!
\q1 
\v 20 Ivo vanotaura nemi nomurangariro wakaipa;
\q2 vadzivisi venyu vanoshandisa zita renyu zvakaipa.
\q1 
\v 21 Ko, ini handivengi vanokuvengai here, imi Jehovha,
\q2 nokusema vaya vanokumukirai?
\q1 
\v 22 Handina chimwe chinhu asi kuvavenga ivo;
\q2 ndinovati vavengi vangu.
\b
\q1 
\v 23 Ndinzverei, imi Mwari, mugoziva mwoyo wangu;
\q2 ndiedzei mugoziva kushuva kwendangariro dzangu.
\q1 
\v 24 Muone kana musina nzira yakaipa mandiri,
\q2 mugondifambisa munzira isingaperi.
\c 140
\cl Pisarema 140
\d Kumutungamiri wokuimba. Pisarema raDhavhidhi.
\q1 
\v 1 Ndirwirei, imi Jehovha, pavanhu vakaipa;
\q2 ndidzivirirei pavanhu vanoita nechisimba.
\q1 
\v 2 Ivo vanofunga urongwa hwakaipa mumwoyo yavo,
\q2 uye vanomutsa hondo mazuva ose.
\q1 
\v 3 Vanorodza ndimi dzavo kuti dzipinze sedzenyoka;
\q2 uturu hwenyoka yechiva huri pamiromo yavo. \qs Sera \qs*
\b
\q1 
\v 4 Ndichengetei, imi Jehovha, kubva mumaoko avakaipa;
\q2 ndidzivirirei pavanhu vanoita nechisimba
\q2 vanoronga kupinga tsoka dzangu.
\q1 
\v 5 Vanhu vanozvikudza vakandivanzira misungo;
\q2 vakatambanudza mabote emimbure yavo
\q2 uye vakateya ugombe munzira yandinofamba nayo. \qs Sera \qs*
\b
\q1 
\v 6 Haiwa Jehovha, ndinoti kwamuri, “Ndimi Mwari wangu.”
\q2 Haiwa Jehovha, inzwai kuchemera nyasha kwangu.
\q1 
\v 7 Haiwa Ishe Jehovha, imi mudzikinuri wangu ane simba,
\q2 anofukidza musoro wangu pazuva rehondo,
\q1 
\v 8 regai kupa vakaipa zvavanoda, imi Jehovha;
\q2 musarega urongwa hwavo huchibudirira,
\q2 kuti varege kuzvikudza. \qs Sera \qs*
\b
\q1 
\v 9 Misoro yaavo vakandipoteredza
\q2 ngaifukidzwe nenhamo yakaparwa nemiromo yavo.
\q1 
\v 10 Mazimbe anopfuta ngaawire pamusoro pavo;
\q2 ngavakandwe mumoto,
\q2 mumakomba amatope, vasambomukazve.
\q1 
\v 11 Vane makuhwa ngavarege kusimbiswa panyika;
\q2 njodzi ngaivhime vanhu vanoita zvinhu nechisimba.
\b
\q1 
\v 12 Ndinoziva kuti Jehovha akachengetera varombo kururamisirwa kwavo,
\q2 uye anotsigira vanoshayiwa pamhaka dzavo.
\q1 
\v 13 Zvirokwazvo vakarurama vacharumbidza zita renyu,
\q2 uye vakarurama vachagara pamberi penyu.
\c 141
\cl Pisarema 141
\d Pisarema raDhavhidhi.
\q1 
\v 1 Haiwa Jehovha, ndinodana kwamuri; kurumidzai kuuya kwandiri.
\q2 Inzwai inzwi rangu pandinodana kwamuri.
\q1 
\v 2 Munyengetero wangu ngauiswe pamberi penyu sezvinonhuhwira;
\q2 kusimudzwa kwamaoko angu ngakuite sechibayiro chamadekwana.
\b
\q1 
\v 3 Isai murindi pamuromo wangu, imi Jehovha;
\q2 chengetai mukova wemiromo yangu.
\q1 
\v 4 Mwoyo wangu ngaurege kukweverwa kune zvakaipa,
\q2 kuti ndiitewo mabasa akaipa
\q1 navanhu vanoita zvakaipa;
\q2 ngandirege kudya zvinozipa zvavo.
\b
\q1 
\v 5 Akarurama ngaandirove, ndidzo tsitsi;
\q2 ngaanditsiure, ndiwo mafuta pamusoro wangu.
\q2 Musoro wangu hauzorambi izvozvo.
\b
\q1 Asi munyengetero wangu unorwisa mabasa avaiti vezvakaipa nguva dzose.
\q2 
\v 6 Vatongi vavo vachakandwa kumawere,
\q2 uye vakaipa vachadzidza kuti mashoko angu akanga akanaka kwazvo.
\q1 
\v 7 Ivo vachati, “Sezvinoita anorima achiparura pasi,
\q2 saizvozvo mapfupa edu akaparadzirwa pamuromo weguva.”
\b
\q1 
\v 8 Asi meso angu anotarira kwamuri, imi Ishe Jehovha;
\q2 ndinotizira kwamuri, regai kundiisa kurufu.
\q1 
\v 9 Ndichengetei pamisungo yavakanditeya nayo,
\q2 napaugombe hwakadzikwa navaiti vezvakaipa.
\q1 
\v 10 Vakaipa ngavawire mumimbure yavo,
\q2 ini ndichipfuura napo norugare.
\c 142
\cl Pisarema 142
\d Masikiri raDhavhidhi. Paakanga ari mubako. Munyengetero.
\q1 
\v 1 Ndinodanidzira nenzwi guru kuna Jehovha;
\q2 ndinosimudzira inzwi rangu kuna Jehovha, kuti andinzwire nyasha.
\q1 
\v 2 Ndinodurura kugununʼuna kwangu pamberi pake;
\q2 ndinotaura nhamo dzangu pamberi pake.
\b
\q1 
\v 3 Mweya wangu paunoziya mandiri,
\q2 imi ndimi munoziva nzira yangu.
\q1 Munzira mandinofamba,
\q2 vanhu vakandivanzira misungo.
\q1 
\v 4 Tarirai kurudyi rwangu mugoona;
\q2 hakuna ane hanya neni.
\q1 Handina utiziro;
\q2 hakuna ane hanya noupenyu hwangu.
\b
\q1 
\v 5 Ndinochema kwamuri, imi Jehovha; ndinoti,
\q2 “Ndimi utiziro hwangu,
\q2 nomugove wangu munyika yavapenyu.”
\q1 
\v 6 Teererai kuchema kwangu,
\q2 nokuti ndiri pakushayiwa kukuru;
\q1 ndinunurei kuna avo vanondidzinganisa,
\q2 nokuti vanondikurira simba.
\q1 
\v 7 Ndibudisei mutorongo,
\q2 kuti ndirumbidze zita renyu.
\b
\q1 Ipapo vakarurama vachandipoteredza
\q2 nokuda kwokunaka kwenyu kwandiri.
\c 143
\cl Pisarema 143
\d Pisarema raDhavhidhi.
\q1 
\v 1 Haiwa Jehovha, inzwai munyengetero wangu,
\q2 ndinzwirei ngoni pakuchema kwangu;
\q1 uyai mundisunungure nokutendeka
\q2 uye nokururama kwenyu.
\q1 
\v 2 Musauyisa muranda wenyu mukutongwa,
\q2 nokuti hakuna mupenyu akarurama pamberi penyu.
\b
\q1 
\v 3 Muvengi anondidzinganisa,
\q2 anondirovera pasi;
\q1 anondiita kuti ndigare murima
\q2 savaya vakafa kare.
\q1 
\v 4 Saizvozvo mweya wangu unoziya mukati mangu;
\q2 mwoyo wangu unovhundutswa mukati mangu.
\b
\q1 
\v 5 Ndinorangarira mazuva akare kare;
\q2 ndinofungisisa pamusoro pamabasa enyu ose,
\q2 uye ndinofunga zvakaitwa namaoko enyu.
\q1 
\v 6 Ndinotambanudzira maoko angu kwamuri;
\q2 mweya wangu unokushuvai senyika yakaoma. \qs Sera\qs*
\b
\q1 
\v 7 Haiwa Jehovha, kurumidzai kundipindura;
\q2 mweya wangu woziya.
\q1 Regai kundivanzira chiso chenyu
\q2 nokuti ndingazova savaya vakaburukira mugomba.
\q1 
\v 8 Mangwanani ngaandivigire shoko rorudo rwenyu rusingaperi,
\q2 nokuti ndinovimba nemi.
\q1 Ndiratidzei nzira yandinofanira kufamba nayo,
\q2 nokuti ndinosimudzira mweya wangu kwamuri.
\q1 
\v 9 Ndinunurei kubva kuvavengi vangu, imi Jehovha,
\q2 nokuti ndinozvivanza mamuri.
\q1 
\v 10 Ndidzidzisei kuita kuda kwenyu,
\q2 nokuti muri Mwari wangu;
\q1 mweya wenyu wakanaka
\q2 ngaunditungamirire panzira yakati chechetere.
\b
\q1 
\v 11 Haiwa Jehovha, chengetedzai upenyu hwangu nokuda kwezita renyu;
\q2 ndibudisei panhamo, mukururama kwenyu.
\q1 
\v 12 Nyaradzai vavengi vangu, murudo rwenyu rusingaperi;
\q2 paradzai vavengi vangu vose,
\q2 nokuti ndiri muranda wenyu.
\c 144
\cl Pisarema 144
\d Pisarema raDhavhidhi.
\q1 
\v 1 Jehovha Dombo rangu ngaarumbidzwe,
\q2 iye anodzidzisa
\q2 maoko angu kurwa.
\q1 
\v 2 Ndiye Mwari anondida uye nhare yangu,
\q2 shongwe yangu nomudzikinuri wangu,
\q1 nenhoo yangu uye ndinovanda maari,
\q2 iye anoisa marudzi pasi pangu.
\b
\q1 
\v 3 Haiwa Jehovha, munhu chiiko zvamune hanya naye?
\q2 Kana mwanakomana womunhu zvamunomufunga?
\q1 
\v 4 Munhu akafanana nomweya wokufema;
\q2 mazuva ake akaita somumvuri unopfuura.
\b
\q1 
\v 5 Zarurai matenga enyu, imi Jehovha, uye muburuke;
\q2 batai makomo, kuti apfungaire utsi.
\q1 
\v 6 Tumirai mheni mugoparadzira vavengi;
\q2 pfurai miseve yenyu mugovapedza.
\q1 
\v 7 Tambanudzai ruoko rwenyu kubva kumusoro;
\q2 ndirwirei uye mundinunure
\q1 kubva pamvura zhinji ine simba,
\q2 kubva mumaoko avatorwa
\q1 
\v 8 vane miromo izere nenhema,
\q2 maoko avo orudyi anonyengera.
\b
\q1 
\v 9 Haiwa Mwari, ndichakuimbirai rwiyo rutsva;
\q2 ndichakuimbirai nziyo dzokurumbidza nomutengeranwa une hungiso gumi,
\q1 
\v 10 iye anopa kukunda kumadzimambo,
\q2 anorwira muranda wake Dhavhidhi kubva pamunondo unouraya.
\b
\q1 
\v 11 Ndirwirei uye mundinunure
\q2 kubva pamaoko avatorwa,
\q1 vane miromo izere nenhema,
\q2 vane maoko orudyi anonyengera.
\b
\q1 
\v 12 Ipapo vanakomana vedu pauduku
\q2 hwavo vachava semiti yakakura zvakanaka,
\q1 uye vanasikana vedu vachava sembiru dzakavezwa
\q2 kuti dzishongedze muzinda wamambo.
\q1 
\v 13 Matura edu achazadzwa
\q2 nemhando dzose dzezviyo.
\q1 Makwai edu achawanda nezviuru,
\q2 nezviuru gumi mumafuro edu;
\q2 
\v 14 nzombe dzedu dzichatakura mitoro inorema.
\q1 Hapachazova nokuputswa kwamasvingo,
\q2 hapachazova nokuenda kuutapwa,
\q2 hapachazova nokuchema nenhamo, munzira dzedu dzomumisha.
\b
\q1 
\v 15 Vakaropafadzwa vanhu avo vachaitirwa saizvozvi;
\q2 vakaropafadzwa vanhu avo vana Jehovha Mwari wavo.
\c 145
\cl Pisarema 145
\d Pisarema rokurumbidza, raDhavhidhi.
\q1 
\v 1 Ndichakukudzai, Mwari wangu Mambo;
\q2 ndicharumbidza zita renyu nokusingaperi-peri.
\q1 
\v 2 Ndichakurumbidzai mazuva ose,
\q2 uye ndichakudza zita renyu nokusingaperi-peri.
\b
\q1 
\v 3 Jehovha mukuru uye akafanira kurumbidzwa;
\q2 ukuru hwake hahunganzverwi nomunhu.
\q1 
\v 4 Rumwe rudzi rucharumbidza mabasa enyu kuno rumwe;
\q2 vachareva zvamabasa enyu esimba.
\q1 
\v 5 Vachataura nezvokunaka kwokubwinya kwoumambo hwenyu,
\q2 uye ndichafungisisa pamusoro pemabasa enyu anoshamisa.
\q1 
\v 6 Vanhu vachataura nezvesimba ramabasa enyu anotyisa,
\q2 uye ndichaparidza mabasa enyu makuru.
\q1 
\v 7 Vachapemberera kuwanda kwokunaka kwenyu,
\q2 uye vachaimba nomufaro pamusoro pokururama kwenyu.
\b
\q1 
\v 8 Jehovha ane nyasha uye ane tsitsi,
\q2 anononoka kutsamwa uye azere norudo.
\q1 
\v 9 Jehovha akanaka kuna vose;
\q2 uye ane nyasha pamusoro pezvose zvaakaita.
\q1 
\v 10 Zvose zvamakaita zvichakurumbidzai, imi Jehovha;
\q2 vatsvene venyu vachakukudzai.
\q1 
\v 11 Vachataura nezvokubwinya kwoumambo hwenyu,
\q2 uye vachataura nezvesimba renyu,
\q1 
\v 12 kuitira kuti vanhu vose vazive nezvamabasa enyu makuru,
\q2 nokunaka kwokubwinya kwoumambo hwenyu.
\q1 
\v 13 Umambo hwenyu umambo hwokusingaperi,
\q2 uye ushe hwenyu hunogara kusvikira kuzvizvarwa zvose.
\b
\q1 Jehovha akatendeka pavimbiso dzake dzose,
\q2 uye ane rudo kuzvinhu zvose zvaakaita.
\q1 
\v 14 Jehovha anotsigira vose vanowa,
\q2 uye anosimudza vose vakakotamiswa pasi.
\q1 
\v 15 Meso avose anotarira kwamuri,
\q2 uye munovapa zvokudya zvavo nenguva yakafanira.
\q1 
\v 16 Munozarura ruoko rwenyu, uye munogutsa zvisikwa zvipenyu zvose nezvazvinoda.
\b
\q1 
\v 17 Jehovha akarurama panzira dzake dzose, uye ane rudo kuzvinhu zvose zvaakaita.
\q1 
\v 18 Jehovha ari pedyo navose vanodana kwaari, kuna vose vanodana kwaari muchokwadi.
\q1 
\v 19 Anozadzisa zvido zvaavo vanomutya;
\q2 anonzwa kuchema kwavo uye anovaponesa.
\q1 
\v 20 Jehovha anochengeta vose vanomuda,
\q2 asi achaparadza vakaipa vose.
\b
\q1 
\v 21 Muromo wangu uchataura kurumbidzwa kwaJehovha.
\q2 Zvisikwa zvose ngazvirumbidze zita rake dzvene
\q2 nokusingaperi-peri.
\c 146
\cl Pisarema 146
\q1 
\v 1 Rumbidza Jehovha.
\b
\q1 Rumbidza Jehovha, iwe mweya wangu.
\b
\q1 
\v 2 Ndicharumbidza Jehovha mazuva ose oupenyu hwangu;
\q2 ndichaimbira Mwari wangu nziyo dzokurumbidza ndichiri mupenyu.
\b
\q1 
\v 3 Regai kuvimba namachinda,
\q2 navanhu vanofa, vasingagoni kuponesa.
\q1 
\v 4 Mweya yavo painoenda, ivo vanodzokera kuvhu;
\q2 pazuva racho iroro urongwa hwavo hunova pasina.
\b
\q1 
\v 5 Akaropafadzwa munhu uyo ano mubatsiri wake Mwari waJakobho,
\q2 tariro yake iri muna Jehovha Mwari wake,
\q1 
\v 6 Muiti wedenga nenyika,
\q2 gungwa uye nezvose zviri mariri, iye Jehovha,
\q2 anogara akatendeka nokusingaperi.
\q1 
\v 7 Anomiririra zvinodiwa nevakadzvinyirirwa,
\q2 uye anopa zvokudya vane nzara.
\q1 Jehovha anosunungura vasungwa.
\q2 
\v 8 Jehovha anosvinudza mapofu,
\q1 Jehovha anosimudza avo vakakotamiswa pasi,
\q2 Jehovha anoda vakarurama.
\q1 
\v 9 Jehovha anorinda vatorwa
\q2 uye anoriritira nherera nechirikadzi,
\q2 asi anokonesa nzira dzavakaipa.
\b
\q1 
\v 10 Jehovha anotonga nokusingaperi,
\q2 Mwari wako, iwe Zioni, kuzvizvarwa zvose.
\b
\q1 Rumbidza Jehovha.
\c 147
\cl Pisarema 147
\q1 
\v 1 Rumbidzai Jehovha.
\b
\q1 Zvakanaka sei kuimbira Mwari wedu nziyo dzokurumbidza,
\q2 zvinofadza uye zvakafanira sei kumurumbidza!
\b
\q1 
\v 2 Jehovha anovaka Jerusarema;
\q2 anounganidza vakadzingwa vaIsraeri.
\q1 
\v 3 Anoporesa vane mwoyo yakaputsika,
\q2 uye anosunga maronda avo.
\b
\q1 
\v 4 Anotara kuwanda kwenyeredzi,
\q2 anodana imwe neimwe nezita rayo.
\q1 
\v 5 Ishe wedu mukuru uye ane simba guru;
\q2 kunzwisisa kwake hakuperi.
\q1 
\v 6 Jehovha anotsigira vanozvininipisa,
\q2 asi anowisira pasi vakaipa.
\b
\q1 
\v 7 Imbirai Jehovha nokuvonga;
\q2 muimbire Mwari wedu nziyo dzokurumbidza nembira.
\q1 
\v 8 Anofukidza denga namakore;
\q2 anopa nyika mvura,
\q2 uye anomeresa uswa pazvikomo.
\q1 
\v 9 Anopa mombe zvokudya
\q2 navana vamakunguo pavanochema.
\b
\q1 
\v 10 Mufaro wake hausi musimba rebhiza,
\q2 uye mufaro wake hausi pamakumbo omunhu;
\q1 
\v 11 Jehovha anofadzwa naavo vanomutya,
\q2 vanoisa tariro yavo parudo rwake rusingaperi.
\b
\q1 
\v 12 Kudza Jehovha, iwe Jerusarema;
\q2 rumbidza Mwari wako, iwe Zioni,
\q1 
\v 13 nokuti anosimbisa mazariro amasuo ako,
\q2 uye anoropafadza vanhu vako vari mauri.
\q1 
\v 14 Anopa rugare pamiganhu yako,
\q2 uye anokugutsa nezviyo zvakaisvonaka.
\b
\q1 
\v 15 Anotuma murayiro wake kunyika;
\q2 shoko rake rinomhanya kwazvo.
\q1 
\v 16 Anowarira chando samakushe amakwai,
\q2 uye anoparadzira chando samadota.
\q1 
\v 17 Anokanda chimvuramabwe pasi sezvimedu.
\q2 Ndianiko angamira kana chando chake charova?
\q1 
\v 18 Anotuma shoko rake rigozvinyungudisa;
\q2 anomutsa mhepo yake, mvura zhinji igoerera.
\b
\q1 
\v 19 Akazarurira Jakobho shoko rake,
\q2 mirayiro yake nezvirevo zvake kuna Israeri.
\q1 
\v 20 Haana kumboita izvi kuno rumwe rudzi;
\q2 havazivi mirayiro yake.
\b
\q1 Rumbidzai Jehovha.
\c 148
\cl Pisarema 148
\q1 
\v 1 Rumbidzai Jehovha.
\b
\q1 Rumbidzai Jehovha kubva kumatenga,
\q2 murumbidzei panzvimbo dzokumusoro-soro.
\q1 
\v 2 Murumbidzei, imi vatumwa vake vose,
\q2 murumbidzei, imi hondo dzake dzose dzokudenga.
\q1 
\v 3 Murumbidzei, imi zuva nomwedzi,
\q2 murumbidzei, imi nyeredzi dzose dzinopenya.
\q1 
\v 4 Murumbidzei, imi matenga ari kumusoro-soro,
\q2 nemi mvura zhinji iri pamusoro pamatenga.
\q1 
\v 5 Ngazvirumbidze zita raJehovha,
\q2 nokuti akarayira, izvo zvikasikwa.
\q1 
\v 6 Akazviisa panzvimbo yazvo nokusingaperi-peri,
\q2 akapa chirevo chisingazombopfuuri.
\b
\q1 
\v 7 Rumbidzai Jehovha imi nyika,
\q2 imi zvisikwa zvikuru zvegungwa nokwakadzika kwenyanza,
\q1 
\v 8 nemi mheni nechimvuramabwe, chando namakore,
\q2 dutu remhepo rinoita zvaakareva,
\q1 
\v 9 imi makomo nemi zvikomo zvose,
\q2 miti inobereka nemisidhari yose,
\q1 
\v 10 mhuka dzesango nemombe dzose,
\q2 zvisikwa zvidiki neshiri dzinobhururuka,
\q1 
\v 11 Madzimambo enyika nendudzi dzose,
\q2 imi machinda nemi vatongi vose panyika,
\q1 
\v 12 majaya nemhandara,
\q2 vatana navana.
\b
\q1 
\v 13 Ngavarumbidze zita raJehovha,
\q2 nokuti zita rake iye oga iguru;
\q2 kubwinya kwake kuri pamusoro penyika namatenga.
\q1 
\v 14 Akasimudzira vanhu vake runyanga,
\q2 iyo rumbidzo yavatsvene vake vose,
\q2 yaIsraeri, vanhu vari pedyo nomwoyo wake.
\b
\q1 Rumbidzai Jehovha.
\c 149
\cl Pisarema 149
\q1 
\v 1 Rumbidzai Jehovha.
\b
\q1 Imbirai Jehovha rwiyo rutsva,
\q2 rumbidzo yake paungano yavatsvene.
\b
\q1 
\v 2 Israeri ngavafarire Muiti wavo;
\q2 vanhu veZioni ngavafarire Mambo wavo.
\q1 
\v 3 Ngavarumbidze zita rake vachitamba,
\q2 uye vamuridzire nziyo namatambureni nembira.
\q1 
\v 4 Nokuti Jehovha anofarira vanhu vake;
\q2 vanozvininipisa anovashongedza korona noruponeso.
\q1 
\v 5 Vatsvene ngavafare nokukudzwa kwake,
\q2 uye vaimbe nomufaro vari pamibhedha yavo.
\b
\q1 
\v 6 Kurumbidzwa kwaMwari ngakuve pamiromo yavo,
\q2 nomunondo unocheka kwose, mumaoko avo,
\q1 
\v 7 kuti vatsive pamusoro pendudzi,
\q2 uye varange marudzi avanhu,
\q1 
\v 8 vasunge madzimambo avo nengetani,
\q2 namakurukota avo nezvisungo zvamatare,
\q1 
\v 9 kuti vaite zvavakatongwa nazvo,
\q2 zvakanyorwa pamusoro pavo.
\q2 Ndiko kukudzwa kwavatsvene vose.
\b
\q1 Rumbidzai Jehovha.
\c 150
\cl Pisarema 150
\q1 
\v 1 Rumbidzai Jehovha.
\b
\q1 Rumbidzai Mwari munzvimbo yake tsvene;
\q2 murumbidzei mumatenga esimba rake.
\q1 
\v 2 Murumbidzei nokuda kwamabasa ake esimba;
\q2 murumbidzei nokuda kwoukuru hwake hunokunda zvose.
\q1 
\v 3 Murumbidzei nenzwi rehwamanda,
\q2 murumbidzei nembira nomutengeranwa.
\q1 
\v 4 Murumbidzei nematambureni muchitamba,
\q2 murumbidzei norudimbwa nenyere.
\q1 
\v 5 Murumbidzei namakandira anorira,
\q2 murumbidzei namakandira anorira kwazvo.
\b
\q1 
\v 6 Zvinhu zvose zvinofema, ngazvirumbidze Jehovha.
\b
\q1 Rumbidzai Jehovha.
