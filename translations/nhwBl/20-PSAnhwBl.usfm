\id PSA  
\h SALMOS 
\toc1 Salmos 
\toc2 SALMOS 
\toc3 Sal. 
\mt1 Salmos 
\c 1  
\s1 Tlajtlacolchihuani huan catli itztoque xitlahuaque iixpa Toteco 
\q1  
\v 1 Paqui nopa masehuali catli amo quitlacaquilía inincamanal amo cuajcualme, 
\q1 niyon amo quintoquilía tlajtlacolchihuani. 
\q1 Niyon amo mohuica ininhuaya catli ica paquij TOTECO. 
\q1  
\v 2 Nopa masehuali quipantía hueyi paquilistli pampa quichijtinemi catli quiijtohuaj itlanahuatilhua TOTECO, 
\q1 huan ipan nopa tlanahuatilme monejnehuilijtinemi tonaya huan tlayohua. 
\q1  
\v 3 Nopa masehuali itztoc quen se cuahuitl catli moscaltía nechca atentli, 
\q1 huan temaca itlajca quema ipohual huan amo quema xihuiyo tepehui. 
\q1 Nochi catli quichihua quisa cuali. 
\q1  
\v 4 Pero amo quej nopa ica masehualme catli amo cuajcualme, 
\q1 pampa inijuanti itztoque quen tlasoli catli quihuica ajacatl. 
\q1  
\v 5 Yeca quema TOTECO tetlajtolsencahuas, 
\q1 nopa amo cuajcualme amo huelise quiijiyohuise, 
\q1 pampa yaya tlahuel chicahuac quintlatzacuiltis. 
\q1 Quena, ipan nopa tonal tlajtlacolchihuani ayacmo huelis mocahuase ininhuaya masehualme catli itztoque xitlahuaque iixpa. 
\q1  
\v 6 Pampa TOTECO quimati nopa ojtli catli ipan nemij masehualme catli itztoque xitlahuaque, 
\q1 pero masehualme catli quichihuaj catli amo cuali, 
\q1 polihuise. 
\c 2  
\s1 Quema tlanahuatis Icone TOTECO 
\q1  
\v 1 Se huihuiyotl para tlanahuatiani huan ininmasehualhua catli amo quiiximatij TOTECO ma motlananaca iixpa. 
\q1 San tlapic quisencahuase catli fiero quichihuase. 
\q1  
\v 2 Tlanahuatiani huan tlayacanca tequitini ipan tlaltipactli mosisinise, 
\q1 huan mocamanalhuise tlaque huelis quichihuilise TOTECO huan nopa Tlanahuatijquetl Catli Yaya Quitlapejpenijtoc. 
\q1  
\v 3 Tlahuejchihuase huan moijilhuise: 
\q1 “Ma timoquixtilica nopa tepos cadena catli ica techilpitoc. 
\q1 Ma timomanahuica para ayacmo huelis technahuatis TOTECO.” 
\q1  
\v 4 Pero Toteco catli itztoc nepa ilhuicac huan quinahuatía nochi, 
\q1 san quinhuetzquilis. 
\q1 Quena, san ininca paquis, 
\q1 pampa iixpa ya amo tleno ipati catli inijuanti quipilsencahuase. 
\q1  
\v 5 Teipa quema quiyolaxitise TOTECO, 
\q1 melahuac quinixcoilhuis. 
\q1 Huan ica miyac cualantli quinmajmatis huan quiijtos: 
\q1  
\v 6 “Ya nijtlalijtoc notlanahuatijca para tlanahuatis ipan altepetl Jerusalén. 
\q1 Yaya mosehuis ipan isiya yejyectzi nepa ipan notepe tlatzejtzeloltic catli itoca Sion.” 
\q1  
\v 7 Huan catli TOTECO quitlapejpenijtoc para itlanahuatijca quiijtos: 
\q1 Nitlayolmelahuas catli TOTECO nechilhuijtoc huan ya ni catli quiijto: 
\q1 “Ta tiTlanahuatijquetl, tiNocone. 
\q1 Ama nitlayolmelahua tlamiyacapa para na nimoTata. 
\q1  
\v 8 Techtlajtlani huan nimitzmacas nochi tlalme huan ininmasehualhua para moaxcahua. 
\q1 Quena, tijselis hasta nochi tlaltipactli para moaxca. 
\q1  
\v 9 Xiquinnahuati chicahuac quen se tlanahuatijquetl catli tlanahuatía ica tepostli imaco para ica tetlatzacuiltis. 
\q1 Quena, xiquinomiyopojpostequi mosisinijca masehualme quen elisquíaj soqui chachapalme.” 
\q1 (Quej nopa TOTECO quitequimacac itlanahuatijca ma quichihua.) 
\q1  
\v 10 Yeca, antlanahuatiani huan antequitini ipan tlaltipactli, 
\q1 ximotlalnamictica huan ximomocuitlahuica ica catli anquichihuaj. 
\q1 Ama xijtlacaquilica catli nimechilhuía quema noja anhuelij. 
\q1  
\v 11 Xijtequipanoca TOTECO pero nojquiya xiquimacasica huan xijtlepanitaca pampa anmomacaj cuenta ajqueya ya. 
\q1 Xijhueyichihuaca TOTECO ica paquilistli huan xiquimacasica anquichihuase catli amo quinamiqui. 
\q1  
\v 12 Ximotlancuaquetzaca iixpa Icone TOTECO ica majmajtli huan xijtzoponica. 
\q1 Sintla amo, antlatocmiquise pampa nimantzi cualani. 
\q1 Pero nelía paquij masehualme catli motemachíaj ipan ya para ma quinpalehui. 
\c 3  
\s1 Se netlatlajtili para Toteco Dios ma quipalehui 
\q1  
\v 1 TOTECO, nelía momiyaquilíaj nocualancaitacahua. 
\q1 Quena, nelmiyaqui motlananaj para nechhuilanase. 
\q1  
\v 2 Miyaqui quiijtohuaj para ta amo quema techpalehuis. 
\q1  
\v 3 Pero TOTECO, ta techyahualohua para techmanahuis. 
\q1 Ta catli techhueyitlalía huan san ta catli tihueli techyolchicahua. 
\q1  
\v 4 Chicahuac nimitztzajtzili, TOTECO, 
\q1 para techpalehuis. 
\q1 Huan ta technanquili hasta campa tionitztoc nepa ipan motepe catli tlatzejtzeloltic. 
\q1  
\v 5 Yeca nimotejqui huan cuali nicochqui. 
\q1 Huan quema niisac, 
\q1 amo tleno nopantitoya pampa ta, TOTECO, techmocuitlahuía. 
\q1  
\v 6 Ama ayacmo nechmajmatise masque majtlactli mil nocualancaitacahua nechyahualose para nechhuilanase. 
\q1  
\v 7 Ximotlanana, TOTECO. 
\q1 Techmaquixti, ta tinoTeco Dios. 
\q1 Chicahuac xiquinmaquili nochi nocualancaitacahua ipan iniixayac. 
\q1 Xiquintlanpojpostequi nopa mosisinijca masehualme, 
\q1 para tlamis nochi ininchicahualis huan amo tleno huelis nechchihuilise. 
\q1  
\v 8 San ta, TOTECO, hueli titemaquixtía. 
\q1 Hueyi paquilistli quipiyaj nochi momasehualhua. 
\c 4  
\s1 Monequi timotemachise ipan Toteco Dios 
\q1  
\v 1 Toteco Dios, ta techchijtoc nixitlahuac moixpa, 
\q1 Se favor technanquili quema nimitznojnotza. 
\q1 Ta catli nochipa techpalehuía quema nitlaijiyohuía, 
\q1 ama sempa techtlasojtla huan xijcaqui quema nimotlatlajtía. 
\b  
\q1  
\v 2 Huan Toteco quinanquilía. 
\q1 “Anmasehualme, xijtlacaquilica ya ni: 
\q1 ¿Hasta quema tlamis para annoca paquise na, 
\q1 catli más quinamiqui nijselis tlatlepanitacayotl? 
\q1 ¿Hasta quema noja anquinhueyichihuase tlaixcopincayome catli amo neli ya Dios? 
\q1 ¿Hasta quema noja anmocahuase ma anmechcajcayahuaca?” 
\q1  
\v 3 Anmasehualme, xijmatica ya ni. 
\q1 TOTECO techiyocatlalijtoc para tiiaxcahua nochi tojuanti catli techcojtoc. 
\q1 Huan yaya nechtlacaquilía quema nijnojnotza huan nechchihuilía catli nijtlajtlanía. 
\q1  
\v 4 Masque anhuihuipicaj ica cualantli, 
\q1 amo xitlajtlacolchihuaca. 
\q1 Quema anmotectose ipan amotlapech huan amo tleno molinía, 
\q1 ximonejnehuilica catli eltoc ipan amoyolo. 
\q1  
\v 5 Xijchihuaca catli quinequi TOTECO huan ya nopa elis quen anquimacasquíaj se tlacajcahualistli catli quipactía. 
\q1 Quena, ximotemachica ipan ya. 
\b  
\q1  
\v 6 Miyac quiijtohuaj: 
\q1 “Amo aqui huelis techpalehuis.” 
\q1 Pero ta tihueli, TOTECO. 
\q1 Techcualita huan techtiochihua. 
\q1  
\v 7 Ta tijtlalijtoc ipan noyolo más paquilistli, 
\q1 huan amo quen catli quipiyaj masehualme catli quipixcaj miyac trigo, 
\q1 o quipiyaj miyac xocomecatl iayo. 
\q1  
\v 8 Yeca na nimotecas ica paquilistli ipan noyolo huan ica cuali nicochis, 
\q1 pampa nijmati san ta, TOTECO, techmanahuía huan amo aqui huelis tlen nechchihuilis. 
\c 5  
\s1 Mojmostla cualca David motlatlajti 
\q1  
\v 1 TOTECO, xijtlacaquili nocamanal. 
\q1 Techchihuili cuenta quema nitlaayijhuía. 
\q1  
\v 2 Ta tinoTeco Dios catli tiitztoc tinotlanahuatijca, techtlacaquili quema nimitztlajtlanía techpalehui, 
\q1 pampa amo aqui seyoc nijtlajtlanía. 
\q1 San nimotlatlajtía moca ta. 
\q1  
\v 3 Sese ijnaloc nelcualca nimitzpohuilía catli nechpano, TOTECO. 
\q1 Mojmostla nimitztlajtlanía catli monequi, 
\q1 huan san nimochiya para technanquilis. 
\q1  
\v 4 Ta tiToteco Dios catli amo mitzpactía catli amo cuali. 
\q1 Yeca amo tiquincahuilía amo cuajcualme ma itztoca mohuaya. 
\q1  
\v 5 Catli mohueyimatij amo hueli moquetzase moixpa. 
\q1 Tiquincualancaita nochi catli quichihuaj catli amo cuali. 
\q1  
\v 6 Tiquintzontlamiltía masehualme catli istlacatij. 
\q1 Quena, TOTECO, amo tijnequi tiquinitas catli tlacajcayahuaj huan temictíaj. 
\q1  
\v 7 Pero na, pampa hueyi motlaicnelijcayo, 
\q1 huelis nicalaquis mochaj. 
\q1 Quena, huelis nimitzhueyichihuas ipan motlatzejtzeloltijca tiopa, 
\q1 pampa nimitztlepanita huan nimajmahui para nimitzixpanos. 
\q1  
\v 8 TOTECO, techyacana quen nohuaya timocajtoc tijchihuas, 
\q1 pampa itztoque nocualancaitacahua. 
\q1 Technextili moojhui catli xitlahuac. 
\q1  
\v 9 Nocualancaitacahua amo quema quiijtohuaj catli melahuac. 
\q1 Amo aqui hueli motemachía ipan inincamanal. 
\q1 Ipan ininyolo san quinequij tetzontlamiltise. 
\q1 Inincamac eltoc fiero quen quema quitlapohuaj se mijca ostotl. 
\q1 Tecamanalhuíaj ica camanali catli yejyectzi san para tlacajcayahuase. 
\q1  
\v 10 Xiquintlatzacuilti, noTeco Dios. 
\q1 Xiquinmasilti ica catli amo cuali moilhuijtoque quinchihuilise sequinoc. 
\q1 Xiquinhuejcamajcahua pampa miyac inintlajtlacolhua. 
\q1 Quena, xiquinhuejcamajcahua pampa mohuejcachijtoque tlen ta. 
\q1  
\v 11 Pero ma paquica nochi catli motemachíaj ipan ta para xiquinpalehui. 
\q1 Nochipa ma huicaca ica paquilistli pampa ta tiquinmanahuía. 
\q1 Catli mitzicnelíaj paquij ipan ta. 
\q1  
\v 12 Pampa ta, TOTECO, tiquintiochihua catli quichihuaj catli xitlahuac moixpa. 
\q1 Motlaicnelijcayo quinyahualohua quen se tepos tzajcayotl catli quinmocuitlahuía. 
\c 6  
\s1 Quenicatza ma timotlatlajtica quema timotequipachohuaj 
\q1  
\v 1 TOTECO, amo techajhua quema ticualani. 
\q1 Amo techtlatzacuilti quema tlahuel ticualantoc. 
\q1  
\v 2 Techtlasojtla, pampa nimococohua. 
\q1 TOTECO, techchicahua, pampa tlahuel nechcocohua nochi notlacayo. 
\q1  
\v 3 Nihuihuipica ica majmajtli huan amo nijmati tlaque nijchihuas. 
\q1 Huan ta TOTECO, ¿hasta quema tihualas para techtlananas? 
\q1  
\v 4 Xihuala, TOTECO, techmanahuiqui para amo nimiquis. 
\q1 Techmaquixti pampa tlahuel techicnelía. 
\q1  
\v 5 Amo aqui catli mictoc huelis mitzelnamiquis. 
\q1 ¿Ajqueya huelis mitzhueyichihuas sintla mictoc huan ya quitlalpachojtoque? 
\q1  
\v 6 Ya tlanqui nofuerza ica choquistli. 
\q1 Sesen yohuali nichoca miyac hasta nijtlamixolonía notzonteto. 
\q1  
\v 7 Nichocatoc miyac hasta nechcocohua noixteyol huan ayacmo hueli nitlachiya. 
\q1 Quena, nichoca quema nimoilhuía catli nocualancaitacahua nechchihuilijtoque. 
\b  
\q1  
\v 8 Techtlalcahuica, tlajtlacolchijca masehualme, 
\q1 pampa TOTECO quicactoc quen nichoca. 
\q1  
\v 9 Yaya quicactoc catli nijtlajtlanijtoc, 
\q1 huan quiselijtoc nonetlatlajtilis. 
\b  
\q1  
\v 10 Nochi nocualancaitacahua mopinahuase huan huetzise. 
\q1 Ica se tlatoctzi TOTECO quincuepas ica pinahualistli. 
\c 7  
\s1 TOTECO tetlajtolsencahua xitlahuac 
\q1  
\v 1 TOTECO, ta catli tinoDios, 
\q1 ipan ta nimotemachía para techmanahuis. 
\q1 Techmaquixti ininmaco nochi catli nechtoquilijtinemij. 
\q1  
\v 2 Nocualancaitacahua itztoque quen tecuanime huan sintla ta amo techmanahuis, 
\q1 nechcocototzase huan amo aqui nechmaquixtis. 
\q1  
\v 3 TOTECO, sintla nelía nijhuicasquía tlajtlacoli, 
\q1 quinamiqui ma nechcualancaitaca. 
\q1  
\v 4 Sintla nijcuepilijtosquía ica catli amo cuali se nohuampox catli cuali itztoya nohuaya, 
\q1 huajca quena. 
\q1  
\v 5 Sintla quej nopa nijchijtosquía, 
\q1 huajca ma nechtepotztoca nocualancaitaca. 
\q1 Ma nechajsiti huan ma nechhuahuatatza, 
\q1 huan ma nechpinahualti, 
\q1 pero amo aqui quej nopa nijchihuilijtoc. 
\q1  
\v 6 Ximotlanana, TOTECO, ica cualantli. 
\q1 Xicualani miyac ica nocualancaitacahua quen inijuanti nechcualancaitaj. 
\q1 Ximoquetza tlajco campa tojuanti, 
\q1 huan xiquinfuerzajhui ma nechchihuilica catli xitlahuac. 
\q1  
\v 7 Se tonal masehualme tlen nochi tlalme mitzyahualojtose, 
\q1 huan ta tiquintlajtolsencahuas campa timosehuijtoc ipan mosiya yejyectzi nepa ilhuicac. 
\q1  
\v 8 Quena, TOTECO tiquintlajtolsencahuas nochi masehualme ipan nochi tlalme. 
\q1 Huajca nojquiya techtlajtolsencahua na, TOTECO, ica catli cuali nijchijtinentoc. 
\q1 Ta catli más tihueyi, 
\q1 technextijtoc iniixpa nochi masehualme para amo nijpiya tlajtlacoli. 
\q1  
\v 9 Ta, tiToteco Dios, catli titetlajtolsencahua xitlahuac. 
\q1 Xijtlachili inintlalnamiquilis masehualme huan xijyejyeco catli quipiyaj ipan ininyolo. 
\q1 Xijtlamilti catli quichihuaj nopa amo cuajcualme, 
\q1 pero techchihua tielise titemachme tojuanti catli timonejnemiltíaj cuali moixpa. 
\b  
\q1  
\v 10 Toteco Dios nechyahualohua para nechmanahuis. 
\q1 Quinmaquixtía catli quipiyaj ininyolo xitlahuac iixpa. 
\q1  
\v 11 Toteco Dios yaya se juez catli tetlajtolsencahua xitlahuac. 
\q1 Mojmostla cualani ica amo cuajcualme. 
\q1  
\v 12 Sintla se masehuali amo moyolcuepas, 
\q1 Toteco Dios quitentis imachete para quitzontlamiltis. 
\q1 Huan quicualtlalis icuahuitol catli ica quimictis. 
\q1  
\v 13 Ya quicualtlalijtoc itlahuilanca teposhua huan quinhualica imaco para temictis. 
\q1 Quipixtoc miyac cuatlamintli catli lementoque para tetzontlamiltis sintla amo moyolcuepaj. 
\q1  
\v 14 Se masehuali catli amo cuali san quinequi tecocos, 
\q1 huan san moilhuía catli fiero hueli quichihuas huan teipa icamaco quisa san istlacatili. 
\q1  
\v 15 Se catli quichihua se ostotl para quimasiltis seyoc, 
\q1 teipa ya huetzis campa tlaxajqui. 
\q1  
\v 16 Quej nopa nojquiya ica catli fiero se masehuali quinchihuilía sequinoc, 
\q1 teipa mocuepas ipan ya. 
\q1  
\v 17 Pero na nijtlascamatis TOTECO pampa yaya xitlahuac. 
\q1 Nihuicas tiohuicatl para nijhueyichihuas TOTECO, Yaya Catli Más Hueyi. 
\c 8  
\s1 Masehualme huan ihueyitilis Toteco Dios 
\q1  
\v 1 ¡TOTECO, ta Catli Tijpiya Nochi Tlanahuatili! 
\q1 Mohueyitilis quitemitía nochi tlaltipactli. 
\q1 Huan motlatlanex quionpano ilhuicactli. 
\q1 Nochi quimatij ta tlahuel tihueyi. 
\q1  
\v 2 Tiquinnextilijtoc coneme huan pilconetzitzi catli noja chichij ma mitzpaquilismacaca. 
\q1 Mocualancaitacahua quiitase huan momacase cuenta para tlahuel pano hueyi mochicahualis huan yeca ayacmo molinise. 
\q1  
\v 3 Quema niquita ilhuicactli catli tijsencajqui, 
\q1 huan nopa metztli huan sitlalime catli tiquinchijchijqui, 
\q1  
\v 4 nimoyolilhuía: 
\q1 ¿Ajqueya tojuanti timasehualme para ta timocuatotonía huan timoilhuía tlen tojuanti? 
\q1 Nelquentzi topati timasehualme para ta techmocuitlahuis. 
\q1  
\v 5 Techchijtoc timasehualme más tihuejhueyi moixpa que nochi sequinoc. 
\q1 Techmacatoc tohueyitilis moixpa huan tijsencajtoc para nochi catli tijchijtoc ma techtlepanitaca. 
\q1 San ta, TOTECO, tieltoc más tihueyi huan techtlani ica mohueyitilis. 
\q1  
\v 6 Techmacatoc timasehualme tlanahuatili ica nochi tlapiyalme catli tiquinchijtoc. 
\q1 Quena, techmacatoc timasehualme para ma tijpiyaca tequiticayotl ica nochi tlamantli. 
\q1  
\v 7 Tiquinnahuatíaj nochi borregojme, huacaxme huan nochi tecuanime catli mosisiníaj. 
\q1  
\v 8 Tijpiyaj tequiticayotl ica nochi tlamantli totome huan michime, huan ica nochi catli itztoque ipan hueyi atl. 
\q1  
\v 9 ¡TOTECO, ta Catli Tijpiya Nochi Tlanahuatili! 
\q1 Nochi masehualme campa hueli ipan nochi tlaltipactli quimatij ta tlahuel tihueyi. 
\c 9  
\s1 Timitzpaquilismacase Toteco Dios por nochi catli cuajcualtzi tijchijtoc 
\q1  
\v 1 Nimitzpaquilismacas, TOTECO, ica nochi noyolo. 
\q1 Nitepohuilis nochi catli cuali tijchijtoc. 
\q1  
\v 2 Nijpiya hueyi paquilistli por ta, 
\q1 huan yeca nihuicas huan nimitzpaquilismacas, Toteco, ta Catli Más tiHueyi. 
\q1  
\v 3 Nocualancaitacahua cholojtehuase. 
\q1 Huetzise mictoque moixpa. 
\q1  
\v 4 Pampa ta tiquinpannextilijtoc masehualme para niitztoc xitlahuac moixpa. 
\q1 Titenextilijtoc para nijchijtoc catli cuali. 
\q1 Timosehuijtoc ipan mosiya catli yejyectzi huan titetlajtolsencahua xitlahuac. 
\q1  
\v 5 Tiquinajhuas nochi masehualme ipan nochi tlalme catli amo mitzneltocaj. 
\q1 Tiquintzontlamiltis nochi inijuanti catli amo cuajcualme. 
\q1 Tiquinixpolos inintoca para nochipa. 
\q1  
\v 6 Nocualancaitacahua miquise, 
\q1 huan ininhuaya polihuise nochi inialtepehua. 
\q1 Pampa ta tiquintlamitlasosolhuilis huan amo tleno mocahuas. 
\q1 Amo aqui quinelnamiquis. 
\b  
\q1  
\v 7 Pero TOTECO tlanahuatis para nochipa. 
\q1 Yaya mosehuía ipan isiya catli yejyectzi nepa ilhuicac huan tetlajtolsencahua. 
\q1 Catli yaya quichihua, ya nopa xitlahuac. 
\q1  
\v 8 Toteco quintlajtolsencahuas xitlahuac nochi tlalme ipan tlaltipactli huan ininmasehualhua. 
\q1 Yaya quintlatzacuiltis sese inijuanti quen quinamiqui por nopa tlajtlacoli catli quichijtoque. 
\q1  
\v 9 Nochi catli pilteicneltzitzi huelis motemachise ipan TOTECO huan yaya quinmocuitlahuis. 
\q1 Huelis motlatise ipan ya quema tlaijiyohuíaj. 
\b  
\q1  
\v 10 Quena, TOTECO, nochi catli mitziximatij motemachise ipan ta para tiquinpalehuis, 
\q1 pampa amo quema tiquintlahuelcahuas catli mitztemohuaj. 
\b  
\q1  
\v 11 Xihuicaca huan xijpaquilismacaca TOTECO, 
\q1 catli mosehuía ipan isiya yejyectzi nepa ipan Jerusalén huan nochi quinahuatía. 
\q1 Xiquinpohuilica nochi masehualme ipan tlaltipactli catli yaya quichijtoc. 
\q1  
\v 12 TOTECO quintzontlamiltis catli temictíaj pampa quej nopa quinamiqui quincuepilis. 
\q1 Quinelnamiqui catli motequipachohuaj, 
\q1 quintlacaquilía quema masehualme catli tlaijiyohuíaj quitzajtzilíaj para ma quinpalehui. 
\b  
\q1  
\v 13 Techtlasojtla, TOTECO. 
\q1 Xiquita quen nitlaijiyohuía ica catli nechchihuilíaj inijuanti catli amo quinequij nechitase. 
\q1 Techmanahui pampa quinequij nechmictise, 
\q1  
\v 14 huan na nimitzpaquilismacas iniixpa nochi masehualme. 
\q1 Niquinpohuilis nochi catli mosentilíaj ipan altepetl Jerusalén catli techchihuilijtoc. 
\q1 Nelía nipaquis pampa techmaquixtijtos. 
\b  
\q1  
\v 15 Mosisinijca masehualme tlen nochi tlalme huetzise ipan nopa ostotl catli inijuanti quichijque. 
\q1 Quitlatijtoque se tlaquetztli para ma masica sequinoc, 
\q1 pero inijuanti icxicuatacanise. 
\q1  
\v 16 TOTECO quichijtoc para nochi ma quimatica para yaya xitlahuac tetlajtolsencahua. 
\q1 Yaya quichihua para ma huetzica ipan tlaquetztli catli ica ininmax quisencajtoque. 
\q1  
\v 17 Nochi amo cuajcualme yase mictla. 
\q1 Quena, nepa ajsitij nochi masehualme catli amo quielnamiquij Toteco Dios. 
\q1  
\v 18 Pero Toteco amo quinelcahuas catli teicneltzitzi. 
\q1 Yaya nochipa quinmacas catli quichiyaj para quiselise. 
\b  
\q1  
\v 19 Ximotlanana, TOTECO. 
\q1 Amo xiquincahuili masehualme más ma quipiyaca chicahualistli. 
\q1 Xiquintlajtolsencahua huan xiquintlatzacuilti nochi masehualme catli amo mitziximatij. 
\q1  
\v 20 Xijchihua ma majmahuica, TOTECO. 
\q1 Ma momacaca cuenta nochi masehualme ipan nochi tlalme para inijuanti san panoni. 
\c 10  
\s1 Se netlatlajtili para quitlajtlanis TOTECO ma quipalehuiqui 
\q1  
\v 1 TOTECO, ¿para tlen huejca tiitztoc huan timotlatía quema na nijpiya tequipacholi? 
\q1  
\v 2 ¡Xiquita, TOTECO! 
\q1 Amo cuajcualme tlahuel mohueyimatij huan quintepotztocatinemij catli teicneltzitzi para quincocose. 
\q1 Ma masica ipan nopa tlaquetztli catli inijuanti quisencajtoque para sequinoc. 
\q1  
\v 3 Nopa amo cuajcualme mohueyimatij ica nochi catli fiero quinequij quichihuase. 
\q1 Huan masehualme catli quinequij san inijuanti quipiyase nochi tlamantli, 
\q1 quintelchihuaj nochi sequinoc hasta ta, TOTECO, mitztelchihuaj nojquiya. 
\q1  
\v 4 Nopa amo cuajcualme nel mohueyimatij huan amo mitztemohuaj, Toteco Dios. 
\q1 Amo quema mitzelnamiquij pampa moilhuíaj amo tiaqui para tiquintlatzintoquilis tlaque quichihuaj. 
\q1  
\v 5 Ama quisa cuali nochi catli amo cuajcualme quichihuaj, 
\q1 huan yeca san mohueyimatij, 
\q1 huan motlanahuatilhua amo quinchihuilíaj cuenta. 
\q1 San quinhuetzquilíaj nochi inincualancaitacahua. 
\q1  
\v 6 Huan moilhuíaj: 
\q1 “Amo quema topantis se tlenijqui. 
\q1 Nochipa tipactose huan amo quema techajsis tequipacholi.” 
\q1  
\v 7 ¡Xitlacaqui, TOTECO! 
\q1 Quema camanaltij masehualme catli amo cuajcualme, 
\q1 san quisa tlatelchihuali, istlacatili huan nochi catli ica tlacajcayahua. 
\q1 ¡Xiquita, TOTECO! 
\q1 Nochipa tlacajcayahuaj huan quinyolcocohuaj sequinoc para ma quipiyaca tequipacholi. 
\q1  
\v 8 Motlatíaj nechca pilaltepetzitzi para teojchiyase, 
\q1 huan quema amo aqui quinita, 
\q1 quimictíaj se catli amo tleno quichijtoc. 
\q1 Quinichtacachiyaj catli teicneltzitzi huan quinmictíaj san pampa quinequij. 
\q1  
\v 9 Quen se tecuani catli motlatijtoc campa tlacoyontoc, 
\q1 masehualme catli fiero inintlalnamiquilis san quichixtoque para quipantise se catli amo quipiya fuerza para huetzise ipani. 
\q1 Teipa quihuahuatatzase nopa teicneltzi campa amo aqui huelis quipalehuis. 
\q1  
\v 10 Catli quinitzquijque quipiyaj miyac chicahualistli. 
\q1 Yeca catli teicneltzitzi nimantzi huetzij iniixpa. 
\q1  
\v 11 Nopa amo cuajcualme moilhuíaj: 
\q1 “Toteco Dios amo quielnamiqui catli tijchihuaj. 
\q1 Yaya moixtzactoc huan amo quema quiita tleno.” 
\q1  
\v 12 Ximotlanana, TOTECO Dios, ximomatlanana. 
\q1 Amo xiquinelcahua catli teicneltzitzi huan catli amo quipiyaj chicahualistli. 
\q1  
\v 13 Amo xiquincahuili amo cuajcualme ma mitzhuetzquilica. 
\q1 Amo xiquincahuili ma moilhuica para ta amo tiquintlatzacuiltis. 
\q1  
\v 14 Toteco Dios, tiquitztoc catli quichijtinemij. 
\q1 Timomacatoc cuenta sesen tlamantli catli amo cuali catli inijuanti quisencahuaj. 
\q1 Xiquinsencahuili nopa tlatzacuiltili catli quinamiqui. 
\q1 Catli teicneltzitzi san motemachiyaj ipan ta para xiquinmanahui. 
\q1 Ta tiinintlapalehuijca nochi catli icnotzitzi. 
\q1  
\v 15 Xiquinmapostequi nopa masehualme catli amo cuajcualme. 
\q1 Xiquintlatzacuilti por nochi catli fiero quichijtoque. 
\q1 Xiquintlaxtlahui ica sesen tlamantli catli quichijtoque. 
\q1 Amo xiquelcahua niyon se. 
\q1  
\v 16 TOTECO, ta tiTlanahuatijquetl catli titlanahuatis para nochipa huan amo quema tlamis. 
\q1 Tiquintzontlamiltis ipan motlal nochi masehualme catli amo mitziximatij, 
\q1 inijuanti san polihuise. 
\q1  
\v 17 TOTECO, ta tiquintlacaquilía catli mitztlajtlaníaj teicneltzitzi. 
\q1 Tiquinfuerzajmaca huan tiquinpalehuía. 
\q1 Tiquinchihuilía cuenta quema mitztzajtzilíaj. 
\q1  
\v 18 Ta tiquinmanahuía icnotzitzi huan catli tlaijiyohuíaj. 
\q1 Quej nopa, masehualme catli san tlasencahualme ica soquitl ayacmo huelis quintemajmatise. 
\c 11  
\s1 Ma timotemachica ipan Toteco para techpalehuis 
\q1  
\v 1 Amo techilhui: 
\q1 “Ximochololti cuatitla huan ximomanahuiti quen se tototl.” 
\q1 Amo monequi nicholos pampa na nimotemachijtoc ipan TOTECO. 
\q1  
\v 2 Nochi quiijtohuaj: 
\q1 “Xiquita, nopa masehualme catli mosisiníaj quicualtlalíaj cuahuitoli huan cuatlamintli, 
\q1 huan onmotlatijtoque para quinmaquilise masehualme catli itztoque xitlahuaque.” 
\q1 Masque quej nopa quiijtohuaj, amo melahuac. 
\q1  
\v 3 Masque quiijtohuaj: 
\q1 “Ayacmo oncas leyes huan amo aqui tlanahuatis xitlahuac, 
\q1 huan huajca monequi masehualme catli cuali ininyolo ma choloca pampa amo aqui huelis quinmanahuis”, amo neli inincamanal. 
\q1  
\v 4 TOTECO noja itztoc ipan itiopa catli tlatzejtzeloltic nepa ilhuicac. 
\q1 Quena, yaya mosehuijtoc ipan isiya yejyectzi huan noja tlanahuatía. 
\q1 Quiita nochi catli quichihuaj masehualme. 
\q1 Quitlajtlachilía sese inemilis. 
\q1  
\v 5 TOTECO quinyejyecohua catli quichihuaj catli cuali, 
\q1 pero masehualme catli amo cuajcualme huan catli quinpactía mosisiníaj, amo quinequi quinitas. 
\q1  
\v 6 TOTECO quichihuas ma huetzi tlicoli catli xahuantoc ininpani catli quichihuaj catli amo cuali. 
\q1 Quena, quintitlanilis azufre catli lementoc para ma huetzi ininpani, 
\q1 huan quintlatis ica se ajacatl catli tlahuel totonic. 
\q1  
\v 7 TOTECO, yaya nelcuali. 
\q1 Quinicnelía catli nemij xitlahuac. 
\q1 Huan masehualme catli xitlahuac ininyolo quiixitase, 
\q1 huan quimatise para Toteco quicualita catli quichihuaj. 
\c 12  
\s1 Techpalehui, TOTECO 
\q1  
\v 1 Techpalehui, TOTECO, 
\q1 pampa ayacmo aqui catli nelía mitzneltoquilía. 
\q1 Ayacmo aquime masehualme catli quiijtohuaj catli melahuac. 
\q1  
\v 2 Se ica seyoc moistlacahuíaj. 
\q1 Quipiyaj ome iniixayac quen nojquiya quipatlaj inincamanal. 
\b  
\q1  
\v 3 TOTECO quintzontlamiltis nochi catli quipiyaj ome iniixayac huan catli mohueyimatij quema camanaltij. 
\q1  
\v 4 Quintzontlamiltis catli quiijtohuaj: 
\q1 “San ica tocamanal titlatlanise. 
\q1 Sintla tijnequij tiistlacatise, 
\q1 tojuanti tijmatij. 
\q1 Amo aqui huelis technahuatis.” 
\q1  
\v 5 Pero quej ni quiijtojtoc TOTECO: 
\q1 “Inijuanti catli teicneltzitzi huan catli amo quipiyaj fuerza nechtzajtzilíaj por nopa fiero masehualme catli quintlaijiyohuiltíaj. 
\q1 Yeca ama nimotlananas para niquinpalehuis. 
\q1 Niquinmaquixtis ininmaco catli quincualancaitaj.” 
\q1  
\v 6 Nelía temachtli catli quiijtohua TOTECO. 
\q1 Icamanal senquistoc melahuac. 
\q1 Quena, eltoc quen se cuali plata catli quinelicxitijtoque, 
\q1 huan quipajpactoque miyac hueltas hasta senquistoc cuali. 
\b  
\q1  
\v 7 TOTECO, ta techmocuitlahuía. 
\q1 Techmanahuis para nochipa ica masehualme catli amo cuajcualme quen ama itztoque. 
\q1  
\v 8 Quena, masque mosisinijca masehualme mooquichmajtinemij campa hueli huan nochi masehualme san quipatiitaj catli amo cuali, 
\q1 Ta techmocuitlahuía. 
\c 13  
\s1 Se netlatlajtili para quitlajtlanis itlapalehuil TOTECO 
\q1  
\v 1 TOTECO, ¿hasta quema techelcajtos? 
\q1 ¿Ayacmo quema techelnamiquis? 
\q1 Nijmati techcuanetlatilía quema nimitztemohua. 
\q1  
\v 2 ¿Hasta quema nijpiyas tequipacholi ipan noyolo huan noyoltzi tlaijiyohuijtinemis? 
\q1 ¿Hasta quema nocualancaitaca noja nechtlanis? 
\q1  
\v 3 Techtlachili huan technanquili, TOTECO. 
\q1 ¡NoTeco Dios! 
\q1 Techmaca tlahuili para nitlachiyas ipan ni tzintlayohuilotl huan amo nimiquis. 
\q1  
\v 4 Amo xijcahuili nocualancaitaca ma quiijto nechtlanqui. 
\q1 Amo techcahuili ma nihuetzi para ma amo noca huetzcaca inijuanti catli nechcualancaitaj. 
\q1  
\v 5 Na nimotemachijtoc ipan moteicnelijcayo catli huejcahua para nochipa. 
\q1 Nipaqui ipan noyolo pampa techmaquixtijtoc. 
\q1  
\v 6 Nihuicas para ta, TOTECO, 
\q1 pampa miyac catli cuali techchihuilijtoc. 
\c 14  
\s1 Se huihuiyotl catli quichihuaj tlajtlacolchijca masehualme 
\q1  
\v 1 Nelía huihuitic nopa masehuali catli moilhuía amo aqui Dios. 
\q1 Nochi catli quej nopa quiijtohuaj mocuapolojtoque huan amo cuajcualme. 
\q1 Nochi inijuanti monenpolojtoque huan ayacmo quichihuaj catli cuali. 
\q1  
\v 2 TOTECO hualtlachixtoc tlen ilhuicac para quiitas sintla huelis quipantis se masehuali catli nelía tlalnamiqui, 
\q1 se catli quitemohua huan quichihuasnequi ipaquilis. 
\q1  
\v 3 Pero amo aqui. 
\q1 Nochi masehualme mocuapolojtoque ipan se ojtli catli amo cuali. 
\q1 Nochi monenpolojtoque. 
\q1 Amo aqui quichihua catli cuali. 
\q1 ¡Niyon se! 
\q1  
\v 4 Nopa tlajtlacolchijca masehualme amo quema tlamachilise, 
\q1 pampa amo quema quielnamiquij TOTECO. 
\q1 San quintzontlamiltíaj nomasehualhua quen se masehuali quitlamicua se pantzi. 
\q1  
\v 5 Pero teipa nochi nopa tlajtlacolchijca masehualme huihuipicase ica majmajtli, 
\q1 pampa Toteco Dios amo itztoc ininhuaya. 
\q1 San itztoc ininhuaya catli itztoque xitlahuaque iixpa. 
\q1  
\v 6 TOTECO quinmanahuía teicneltzitzi pampa motemachíaj ipan ya quema tlajtlacolchijca masehualme quintlaijiyohuiltíaj. 
\q1  
\v 7 Tojuanti tinelpaquisquíaj sintla ya ajsisquía nopa tonali, 
\q1 quema Totemaquixtijca hualas tlen tepetl Sion para quinmaquixtis israelitame. 
\q1 Ma huala nopa tonali quema TOTECO quinhualicas imasehualhua tlen campa hueli inincualancaitacahua quinhuicatoque para tetequipanose. 
\q1 Ipan nopa tonali mopaquilismacase nochi israelitame. 
\q1 Quena, inijuanti catli iteipan ixhuihua Jacob tlahuel paquise. 
\c 15  
\s1 Nopa masehualme catli itztotij ipan itepe tlatzejtzeloltic Toteco Dios 
\q1  
\v 1 TOTECO, ¿ajqueya huelis calaquis ipan mochaj campa ta timocahua ipan motepe catli tlatzejtzeloltic? 
\q1 ¿Ajqueya huelis mocahuas nepa para tijmocuitlahuis? 
\q1  
\v 2 San calaquis ya catli amo aqui huelis quitelhuis ica niyon se tlamantli. 
\q1 Quena, san yaya catli quichihua catli cuali. 
\q1 Huelis yas san catli quiijtohua catli melahuac ica nochi iyolo, 
\q1  
\v 3 huan amo tetlaijilhuía. 
\q1 Itztotij nepa catli amo quimahuispolohua catli itztoc icalnechca, 
\q1 huan catli amo quinequi quinyolcocos sequinoc. 
\q1  
\v 4 Nepa calaquis catli quihuejcamajcahua nochi catli fiero, 
\q1 huan quinicnelía catli mitztlepanitaj huan quiimacasij mitzixpanose. 
\q1 TOTECO, ipan mochaj itztose catli quitlamichihuaj catli mocajtoque quichihuase masque nelohui huan quincocohua para quichihuase. 
\q1  
\v 5 Nepa calaquise catli quentzi tlainamaj quema tetlanejtíaj tomi, 
\q1 huan amo quinistlacahuíaj catli amo tlaixpanotoque, 
\q1 masque sequinoc quintencahuilíaj tomi para ma istlacatica. 
\q1 Quena, inijuanti catli quichihuaj ni cuali tlamantli amo aqui hueli quintlanis, 
\q1 pampa ta tiquinmocuitlahuis. 
\c 16  
\s1 Toteco catli cuali techmacas 
\q1  
\v 1 Techmocuitlahui, Toteco Dios, 
\q1 pampa ipan ta nimotemachijtoc para techmanahuis. 
\q1  
\v 2 TOTECO, na nimitzilhuijtoc: 
\q1 “Ta tinoTeco huan amo aqui seyoc catli huelis nechpalehuis.” 
\q1  
\v 3 Niquinicnelía inijuanti catli mitzneltoquilíaj catli itztoque ipan nopa tlali. 
\q1 Inijuanti catli nelía yejyectzitzi ininyolo. 
\q1  
\v 4 Pero mojmostla más motequipachose masehualme catli quintoquilíaj sequinoc inintlaixcopincayohua. 
\q1 Na amo quema nijtencahuasquía se tlacajcahualistli iniixpa inintotiotzitzi, 
\q1 niyon amo quema niquintocaxtisquía. 
\q1  
\v 5 San ta, TOTECO, nimitzpixtoc, 
\q1 yeca ayacmo tleno nijtemos. 
\q1 Ta techmaca nochi notlacualis huan noa catli nechmonequilía para niitztos. 
\q1 Nonemilis huan nochi catli nijpixtoc eltoc momaco huan nijmati nelía temachtli. 
\q1  
\v 6 Nopa mecatl catli ica techtlatamachihuili campa nijselijtoc huetzqui campa nelía cuali tlali. 
\q1 Nelía tlayejyectzi campa techmacatoc. 
\q1  
\v 7 Nimitzhueyichihuas, TOTECO, 
\q1 pampa techconsejomaca. 
\q1 Tlajco yohual techmaca motlalnamiquilis huan technextilía ipan noyolo tlaque monequi nijchihuas. 
\q1  
\v 8 Nochipa nimoilhuía tlen ta, TOTECO, 
\q1 huan pampa tiitztoc nonechca, amo tleno nopantis. 
\q1  
\v 9 Yeca ipan noyolo nelía nijpiya paquilistli. 
\q1 Nochi notlacayo motemachijtoc ipan ta. 
\q1  
\v 10 Pampa amo tijcahuas notlacayo ipan ostotl, 
\q1 niyon amo tijcahuas ma palani itlacayo Yaya Catli Tlatzejtzeloltic. 
\q1  
\v 11 Technextilis catlique ojtli quipiya nemilistli. 
\q1 Nijpiyas hueyi paquilistli nepa campa ta tiitztoc. 
\q1 Quena, oncas hueyi paquili para nochipa nepa campa monejmac. 
\c 17  
\s1 Se netlatlajtili catli quitlajtlanía TOTECO ma quimanahuis 
\q1  
\v 1 Techtlacaquili, TOTECO, 
\q1 pampa nimitznojnotza. 
\q1 Nijchijtoc catli xitlahuac, 
\q1 huan amo niistlacati. 
\q1 Techtlacaquili catli nimitztlajtlanía huan techpalehui. 
\q1  
\v 2 Techtlajtolsencahua iniixpa nochi masehualme. 
\q1 Xiquinnextili para amo tleno nijchijtoc, 
\q1 pampa nochipa tijmati catli xitlahuac. 
\q1  
\v 3 Masque tijhualtlachilía noyolo ica yohuali huan techyejyecojtoc, 
\q1 amo tleno amo cuali tijpantijtoc. 
\q1 Amo niquijtojtoc catli amo monequi, 
\q1  
\v 4 quen quichihuaj ne sequinoc. 
\q1 Na nimoiyocatlalijtoc tlen nopa iniojhui catli amo cuajcualme. 
\q1 Nijchijtoc senquistoc quen quiijtohua motlanahuatil. 
\q1  
\v 5 Nijtoquilijtoc moojhui huan amo nihuetztoc ipan tlajtlacoli. 
\q1  
\v 6 Nimitznojnotza, noTeco Dios, pampa nijmati technanquilis. 
\q1 Techtlacaquili huan techchihuili cuenta. 
\q1  
\v 7 Technextili moteicnelijcayo catli yejyectzi. 
\q1 Taya tiquinmaquixtía ica mochicahualis catli motemachiyaj ipan ta. 
\q1  
\v 8 Techmocuitlahui quen se quimocuitlahuía iixsitlal. 
\q1 Quen se piyo quintlatía ipilconehua ieltlapaltzala, 
\q1 nojquiya quej nopa techmocuitlahui. 
\q1  
\v 9 Techtlati tlen nopa amo cuajcualme catli nechyahualojtoque para nechmictise. 
\q1  
\v 10 Nelía mocualnequij huan quema camanaltij, 
\q1 san mohueyimatij. 
\q1  
\v 11 Nechtoquilijtinemij campa ninentinemi huan san quichiyaj nopa tlatoctzi quema huelise nechtlahuisose tlalchi. 
\q1  
\v 12 Inijuanti itztoque quen tecuanime catli tlahuel mayanaj huan quinequij tecuase, 
\q1 huan motlatijtoque ostoijtic para quema se masehuali panos. 
\q1  
\v 13 Ximotlanana, TOTECO, 
\q1 xiquinnamiquiti. 
\q1 Xiquinchihualti ma motlancuaquetzaca moixpa. 
\q1 Ica momachete, techmanahui tlen nopa amo cuajcualme. 
\q1  
\v 14 Ica mochicahualis, TOTECO, 
\q1 techmaquixti ininmaco inijuanti catli san quipiyaj catli eltoc ipan ni tlaltipactli. 
\q1 Tijmiyaquilijtoc catli iniaxca nica. 
\q1 Nojquiya xiquinmaca miyac tlatzacuiltili hasta mocahuas para ininconehua. 
\q1  
\v 15 Pero na niitztoc xitlahuac moixpa, 
\q1 huan se tonal nimitzitas, TOTECO, 
\q1 huan yeca nipaqui. 
\q1 Se tonal quema niisas nijpiyas nochi catli nijtemojtinentoc, 
\q1 pampa niitztos monechca huan ica paquilistli timoixtlachilise. 
\c 18  
\s1 David quitlascamati TOTECO pampa tlatlantoc 
\q1  
\v 1 Nimitzicnelía, TOTECO. 
\q1 Na niitztoc momaco. 
\q1  
\v 2 TOTECO, mopan ta nimotlatía pampa temachtli techmaquixtis. 
\q1 Techyahualohua para amo huelis nechajsise nocualancaitacahua. 
\q1 Taya tinotlamanahuijca. 
\q1 Ipan ta, noTeco Dios, nimotlatía, 
\q1 pampa na niitztoc momaco. 
\q1 Quena, san ipan ta nimotemachía. 
\q1 Ta techyahualohua para techmocuitlahuía. 
\q1 Taya tieli quen se huejcapantic tepancali catli cuali huan temachtli. 
\q1 Ica ta mochicahualis nitlatlanis. 
\b  
\q1  
\v 3 San monequi nijnotzas TOTECO catli quinamiqui para nijhueyichihuas, 
\q1 huan yaya nechmanahuis ininmaco nochi nocualancaitacahua. 
\q1  
\v 4 Eltoya quen nechpixtoya imaco miquilistli. 
\q1 Nochi catli fiero catli onca ipan ni tlaltipactli nechtlanisnequiyaya. 
\q1  
\v 5 Nopa mijca ostotl nechtlaquechilijtoya hasta ayacmo nijpixqui fuerza. 
\q1 San se quentzi más huan nimiquisquía. 
\q1  
\v 6 Pero quema más nimotequipachohuayaya, 
\q1 nijnotzqui TOTECO. 
\q1 Nijtlajtlani ma nechpalehui noTeco Dios. 
\q1 Huan yaya nechtlacaquili hasta nepa ipan ilhuicac. 
\q1 Quena, quichihuili cuenta catli niquilhui. 
\q1  
\v 7 Huajca chicahuac mojmolini tlali hasta momajmatijque nochi tepeme. 
\q1 Moojolinijque nopa tepeme hasta campa ontlatzquitoque, 
\q1 huan mohuihuixojque pampa Toteco Dios cualanqui. 
\q1  
\v 8 Elqui quen quisayaya poctli ipan iyacatzol, 
\q1 huan ipan icamac quisayaya se tlitl catli nochi quitlamitlatiyaya, 
\q1 huan nochi quisosolohuayaya. 
\q1 Quena, quimajcahuayaya tlicoli xaxahuacatoc pampa nelcualanqui. 
\q1  
\v 9 Pampa Toteco Dios quitlapo nopa cortina tlen ilhuicac, 
\q1 huan temoc para nechpalehuis. 
\q1 Nejnentihualayaya ipan miyac mixtli catli nelyayahuic. 
\q1  
\v 10 Toteco Dios tlejcoc ipan ieltlapal se querubín tequihua, 
\q1 huan patlantihualajqui ipan ajacatl. 
\q1  
\v 11 Yaya motzajqui ica tzintlayohuilotl, 
\q1 huan atl quiyahualo para amo aqui quiitasquía. 
\q1  
\v 12 Tlapetlanilotl quiyacantihualajqui quema ajsiyaya yaya catli tlahuel cahuani. 
\q1 Huan nojquiya huetzqui tesihuitl huan tlicoli xaxahuacatoc. 
\q1  
\v 13 TOTECO quichijqui ma quicaquica itoscac quen se tlatomonilotl catli quisqui ilhuicac. 
\q1 Quena, Toteco Catli Más Hueyi tlahuejchijqui. 
\q1 ¡Tlahuel miyac tesihuitl huan tlicoli xaxahuacatoc huetzqui! 
\q1  
\v 14 Quimajcajqui cuatlamintli ma quinajsi nochi nocualancaitacahua, 
\q1 huan inijuanti cholojtejque. 
\q1 TOTECO quinhuitejqui ica hueyi tlapetlanilotl huan quintzontlamilti. 
\q1  
\v 15 Quema TOTECO tlailpitzqui, 
\q1 nochi nopa atl ipan hueyi atl san sejco momanqui hasta nesqui nochi nopa tlali catli mocahua atzintla campa más tlahuejcatla. 
\q1 Ica icamanal TOTECO mopannexti itzinpehualtil tlaltipactli, pampa yaya cualanqui. 
\q1  
\v 16 Huan TOTECO quimelajqui imax hasta campa más huejcatla, 
\q1 huan nechquixti tlen nopa hueyi atl. 
\q1  
\v 17 Nechmaquixti ininmaco nocualancaitacahua catli quipixque huejhueyi chicahualistli. 
\q1 Quena, nechmanahui tlen nocualancaitacahua catli más quipixque chicahualistli que na. 
\q1  
\v 18 Inijuanti motlalijque noca na quema amo nijpixqui fuerza, 
\q1 pero TOTECO nechtlananqui. 
\q1  
\v 19 Nechquixti huan nechsehui campa amo mahuilili. 
\q1 Nechmanahui pampa nechicnelía. 
\q1  
\v 20 TOTECO nechmacatoc catli quinamiqui pampa nijchijtoc catli xitlahuac. 
\q1 Nechtlaxtlahuijtoc pampa cuali nonemilis. 
\q1  
\v 21 Nijtoquilijtoc iojhui TOTECO huan amo nimoiyocacajtoc tlen ya. 
\q1  
\v 22 Niquelnamictoc nochi icamanal huan amo quema nijcajtejtoc itlanahuatil. 
\q1  
\v 23 Xitlahuac niitztoc iixpa. 
\q1 Nimoiyocatlalijtoc tlen nochi catli fiero. 
\q1  
\v 24 Huan TOTECO nechtlaxtlahuijtoc quen quinamiqui ica catli cuali nijchijtoc, 
\q1 pampa quinpantijtoc cuali nonemilis iixpa. 
\b  
\q1  
\v 25 TOTECO, tiquinicnelía huan tiitztoc temachtli ica catli teicnelíaj huan catli temachme. 
\q1 Tiitztoc cuali ica catli quihuejcacahua tlajtlacoli. 
\q1  
\v 26 Tiquintiochihua catli tetiochihuaj, 
\q1 pero tetic timotlalía ica inijuanti catli mosisiníaj. 
\q1  
\v 27 Tiquinmaquixtía catli moicnonequij, 
\q1 pero tiquinpinahualtía catli mohueyimatij. 
\q1  
\v 28 TOTECO, ta catli tinoDios, 
\q1 ta techmaca tlahuili. 
\q1 Ta tijcueptoc nopa tzintlayohuilotl campa niitztoc ica tlahuili. 
\q1  
\v 29 Ica mochicahualis, noTeco Dios, 
\q1 niquinhuilanas nocualancaitacahua, 
\q1 huan niquixcopanos nopa tepamitl catli ica quitzactoque inialtepe. 
\b  
\q1  
\v 30 Iojhui Toteco Dios nelía xitlahuac. 
\q1 Huan icamanal catli quitencahua, 
\q1 cuali para ipan timotemachise. 
\q1 TOTECO quinmanahuía nochi catli ipan ya motemachíaj. 
\q1  
\v 31 Amo cana aqui seyoc Dios quen TOTECO. 
\q1 Amo aqui seyoc catli huelis ipan timotemachise huan techmanahuis. 
\q1  
\v 32 Toteco Dios nechmaca chicahualistli, 
\q1 huan nechchihualtía ma ninejnemi xitlahuac. 
\q1  
\v 33 Yaya nechfuerzajmaca para amo ma nihuetzi. 
\q1 Noicxihua mochihuaj temachtli quen iicxihua se chivo quema moquetzaj campa tlahuejcapa huan tlaxixitlaca. 
\q1  
\v 34 Toteco Dios nechmachtía tlaque ma nijchihuas quema onca tlahuilanalistli. 
\q1 Nechfuerzajmaca para cuali ma niquitzqui nopa tetic tepos huitoli catli quichijtoque ica bronce. 
\b  
\q1  
\v 35 Toteco Dios, ta techmanahuía huan techmaquixtía. 
\q1 Techitzquía ica monejmac. 
\q1 Ica mohueyi teicnelijcayo techhueyichijtoc. 
\q1  
\v 36 Tijchijtoc noojhui más patlahuac para amo ma nihuetzis. 
\q1  
\v 37 Niquintepotztocac nocualancaitacahua huan niquinajsito. 
\q1 Huan amo nimocuepqui hasta quema niquintzontlamiltijtoya. 
\q1  
\v 38 Niquinhuejhuelo huan ayacmo quema motlananase. 
\q1 Huetzque noicxitla. 
\q1  
\v 39 Toteco Dios, ta techfuerzajmacac ipan nopa tlahuilanalistli huan tijchijqui para nocualancaitacahua ma motlancuaquetzaquij noixpa. 
\q1  
\v 40 Miyaqui moicancuepque para cholojtehuase huan quej nopa huelqui niquintzontlamilti. 
\b  
\q1  
\v 41 Inijuanti tetzajtzilijque ma quinpalehuica, 
\q1 pero amo aqui huelqui quinpalehui. 
\q1 Quinotzque TOTECO, 
\q1 pero yaya amo quinnanquili. 
\q1  
\v 42 Quen se quitisi tlalcuanextli huan quihuica ajacatl, 
\q1 na quej nopa niquinchijqui. 
\q1 Huan ininpan nimoquejquetzqui quen soquitl ipan ojtli. 
\q1  
\v 43 TOTECO nechmanahuijtoc tlen nopa sequinoc altepetl ehuani catli mosisiníaj huan quinequiyayaj nechhuilanase. 
\q1 Yaya nechchijtoc ma nieli niinintlayacanca masehualme catli campa hueli ehuani. 
\q1 Masehualme catli amo niquiniximatiyaya hualahuij para nechtequipanose. 
\q1  
\v 44 Quema quicaquij nocamanal, 
\q1 inijuanti nechneltoquilíaj. 
\q1 Sequinoc altepetl ehuani huihuipicaj noixtla. 
\q1  
\v 45 Nochi motemacaj noixpa huan huihuipicatiyohuij quema quisaj campa motlatijtoque. 
\q1  
\v 46 Itztoc TOTECO. 
\q1 Nijpaquilismacas yaya catli nechmocuitlahuía. 
\q1 Ma tijhueyitlalica Toteco Dios, 
\q1 notemaquixtijca. 
\q1  
\v 47 Yaya nopa Dios catli quincuepilía ica catli fiero inijuanti catli nechcocojtoque. 
\q1 Quintlalijtoc masehualme ipan miyac tlali nomaco para ma niquinnahuati. 
\q1  
\v 48 Yaya nechmanahuía tlen nocualancaitacahua huan nechhueyitlalía iniixpa catli nechcualancaitaj. 
\b  
\q1 TOTECO, ta techmaquixtijtoc ininmaco nopa tlahuilanca masehualme, 
\q1  
\v 49 yeca nitepohuilis tlen ta campa hueli. 
\q1 Nihuicas huan nijhueyitlalis motoca. 
\q1  
\v 50 Miyac hueltas tijchijtoc para ma nitlatlani, na niDavid, 
\q1 ninopa tlanahuatijquetl catli techtlapejpenijtoc. 
\q1 Tijpiya hueyi moyolo ica na catli techtlalijtoc ma nitlanahuati. 
\q1 Quena, hueyi moyolo nohuaya huan tijpiyas hueyi moyolo para nochipa ica noixhuihua. 
\c 19  
\s1 Ihueyitilis Toteco monextía ipan nochi catli quichijtoc 
\q1  
\v 1 Ilhuicactli tepohuilía ihueyitilis Toteco Dios. 
\q1 Tlanemijya technextilía catli onpano yejyectzi yaya hueli quisencahua. 
\q1  
\v 2 Quena, tonali huan yohuali ilhuicactli quisenhuiquilía tepohuilía para tlahuel hueyi itlalnamiquilis. 
\q1  
\v 3 Masque amo tleno caquisti huan amo tijcaquij niyon se camanali, 
\q1 nochi masehualme campa hueli quiitaj iyejyejca ilhuicactli huan quimachilíaj catli techpohuilía. 
\q1  
\v 4 Eltoc quen ilhuicactli quipiya itoscac catli ajsi hasta campa ontlantoc tlaltipactli, 
\q1 huan teyolmelahua para itztoc Toteco Dios. 
\q1 Ipan ilhuicactli yaya quiquetzqui ichaj tonati. 
\q1  
\v 5 Huan tonati quisa mojmostla huan yohui ipan iojhui ica paquilistli quen se telpocatl quisa ipan ichaj para mosihuajtiti. 
\q1 Quena, nopa tonati mochihua quen se motlalojquetl catli paqui motlalohua pampa quimati quintlanis ne sequinoc. 
\q1  
\v 6 Tonati quisa ilhuicactli inacastla huan quimaca huelta hasta ne seyoc inacastla. 
\q1 Amo aqui huelis motlatis para amo quitonalmictis. 
\q1  
\v 7 Ileyes TOTECO eltoc senquistoc cuali, 
\q1 huan temaca yancuic nemilistli. 
\q1 Huelis timotemachise ipan icamanal, 
\q1 pampa ya nopa quichihua ma tlalnamiqui se masehuali catli moicnonequi. 
\q1  
\v 8 Itlanahuatilhua TOTECO eltoc melahuac huan xitlahuac. 
\q1 Quinmaca paquilistli masehualme ipan ininyolo. 
\q1 Quena, sesen tlamantli catli TOTECO techilhuijtoc ma tijchihuaca eltoc quen se tlahuili catli chicahuac. 
\q1 Techtlahuilía toojhui para tiquitase. 
\q1  
\v 9 Senquistoc cuali para ma tijtlepanitaca TOTECO huan ma tiquimacasica para tiquixpanose. 
\q1 Elis cuali para nochipa. 
\q1 Catli TOTECO quiijtojtoc para ma tijchihuaca, 
\q1 ya nopa melahuac. 
\q1 Quena, ya nopa temachtli. 
\q1  
\v 10 Noja más nijpatiita que oro. 
\q1 Quena, noja más cuali que miyac oro catli senquistoc cuali. 
\q1 Quema se masehuali quiselía Icamanal Toteco ipan iyolo, 
\q1 eltoc más tzopelic que se sayolnectli catli yancuic quipatzcatoque. 
\q1  
\v 11 Nopa tlanahuatilme nechmacaj tlalnamiquilistli, na niitequipanojca, 
\q1 para amo ma nitlajtlacolchihua. 
\q1 Catli quintoquilía itlanahuatilhua TOTECO hueyi quitlanis. 
\b  
\q1  
\v 12 Amo aqui huelis momacas cuenta tlen itlaixpanolhua sesen huelta quema quichihua catli amo cuali. 
\q1 TOTECO, techtlapojpolhui notlajtlacolhua catli amo nijmatiyaya sintla nijchijtoya. 
\q1  
\v 13 Huan techpalehui para amo nimohueyimatis, 
\q1 huan amo quema ma nitlajtlacolchihuas ica nopaquilis. 
\q1 ¡Amo! Amo xijcahua tlajtlacoli ma nechnahuati. 
\q1 Quen nopa nielis se masehuali catli amo aqui huelis nechtelhuis ica niyon se tlamantli. 
\q1 Huan niitztos nitlatzejtzeloltic. 
\q1  
\v 14 Ma mitzpacti catli niquijtohua huan catli nimoilhuía, TOTECO, 
\q1 ta tinotlamanahuijca huan tinotemaquixtijca. 
\c 20  
\s1 David quitlajtlanía Toteco ma quipalehui quintlanis icualancaitacahua 
\q1  
\v 1 Ma TOTECO mitztlacaquili quema timotequipachohua. 
\q1 Ma mitzmanahui nopa Dios catli huejcajya quimanahui Jacob. 
\q1  
\v 2 Hasta campa yaya itztoc ipan ichaj, 
\q1 ma quititlani tlapalehuili catli quisa tlen altepetl Jerusalén. 
\q1  
\v 3 Ma quielnamiqui nochi motlacajcahualis catli tijmacatoc. 
\q1 Ma moilhui tlen nopa tlacajcahualistli catli tijtlati iixpa huan catli yaya quiseli ica paquilistli. 
\q1  
\v 4 Ma mitzmacas nopa catli moyolo quinequi. 
\q1 Ma quichihua ma quisa cuali nochi catli timoilhuijtoc tijchihuas. 
\q1  
\v 5 Quej nopa tojuanti titzajtzise ica paquilistli pampa ta titlatlantoc, 
\q1 huan tijtlananase banderas ica itoca Toteco Dios pampa mitzpalehuijtoc. 
\q1 Quena, TOTECO ma mitzmaca nochi catli tijtlajtlanijtoc. 
\q1  
\v 6 Cuali nijmati para TOTECO nechmaquixtía niitlanahuatijca catli nechtlapejpenijtoc. 
\q1 Hasta tlen nepa ilhuicac campa nelía tlatzejtzeloltic nechhualpalehuijtoc, 
\q1 huan nechchihua ma nitlatlani ica ichicahualis. 
\q1  
\v 7 Masehualme ipan sequinoc tlalme motemachíaj ipan inincarros huan inincahuayohua para momaquixtise quema onca tlahuilancayotl. 
\q1 Pero tojuanti timotemachíaj ipan TOTECO toDios. 
\q1  
\v 8 Inijuanti tlaijiyohuise huan huetzise, 
\q1 pero tojuanti timotlananase huan noja tijpiyase fuerza. 
\b  
\q1  
\v 9 Toteco Dios, xijchihuas ma nitlatlani, 
\q1 na nimotlanahuatijca. 
\q1 Technanquili quema timitznojnotzaj. 
\c 21  
\s1 Se huicatl pampa tlatlantoya 
\q1  
\v 1 ¡TOTECO! Na nitlanahuatijquetl, 
\q1 nipaqui pampa techfuerzajmacatoc. 
\q1 Nelía nipaqui pampa tijchijtoc ma nitlatlani. 
\q1  
\v 2 Techmacatoc catli noyolo quinequiyaya. 
\q1 Quena, techmactili catli nimitztlajtlaniyaya. 
\q1  
\v 3 Techsehui nitlanahuatijquetl ica hueyi tlatiochihualistli, huan techicpahuiltijtoc se corona catli senquistoc oro. 
\q1  
\v 4 Nimitztlajtlani techcahuili ma huejcahuas niitztos, 
\q1 huan nelía techmacatoc se nemilistli catli huejcahuas para nochipa. 
\q1  
\v 5 Techpalehuijtoc ma nitlatlani miyac ica mohueyi chicahualis. 
\q1 Huan yeca por ta, nochi nechhueyitlepanitaj, 
\q1 na nitlanahuatijquetl, huan nechhueyitlalíaj. 
\q1  
\v 6 Techtiochijtoc ica catli huejcahuas para nochipa, 
\q1 huan nelhueyi nopa paquilistli catli nijpiya pampa timocahua nohuaya. 
\q1  
\v 7 Na nitlanahuatijquetl nimotemachía ipan ta, TOTECO. 
\q1 Quena, nimotemachía ipan mohueyi teicnelilis ta Catli Más tiHueyi, 
\q1 yeca amo aqui huelis nechtlanis. 
\q1  
\v 8 TOTECO, ica mochicahualis tiquinajsiti nochi mocualancaitacahua. 
\q1 Ica monejmac tiquinitzquis nochi catli mitzcualancaitaj. 
\q1  
\v 9 Quema timonextis, inijuanti tlatlase moixpa quen itztosquíaj ipan se horno catli xahuantoc. 
\q1 TOTECO, quema tiquintlajtolsencahuas, 
\q1 mocualancayo quintlamitlatis. 
\q1  
\v 10 Tiquintzontlamiltis hasta ininconehua huan iniixhuihua. 
\q1  
\v 11 Masque masehualme catli amo cuajcualme mitzcualancaitaj huan quisencahuaj catli amo cuali mitzchihuilise, 
\q1 amo quisas cuali catli moilhuijtoque. 
\q1  
\v 12 Inijuanti moicancuepase para cholojtehuase quema quiitase para tiquinmelactlachilis ica mocuahuitol tlasencahuali para tiquinhuilanas. 
\q1  
\v 13 Timitzhueyimatij, TOTECO, 
\q1 pampa hueyi mochicahualis. 
\q1 Huan timitzhueyichihuase ica huicatl pampa nelía tijpiya nochi chicahualistli. 
\c 22  
\s1 Se tlacatl quitzajtzilía Toteco huan teipa quipaquilismaca 
\q1  
\v 1 ¡NoTeco Dios! ¡NoTeco Dios! 
\q1 ¿Para tlen techtlahuelcajtoc? 
\q1 ¿Para tlen timohuejcachijtoc huan amo tihualajtoc para techmanahuiqui? 
\q1 Amo tijtlacaquilía quema nitlatzajtzilía. 
\q1  
\v 2 NoTeco, tonali yohuali amo nimosiyajquetza nimitznotza, 
\q1 pero amo technanquilía. 
\q1  
\v 3 Huan masque quej nopa eltoc, 
\q1 ta quejipa titlatzejtzeloltic. 
\q1 Nochi tohuejcapan tatahua tiisraelitame mitzyahualojque huan mitzhueyichijque. 
\q1  
\v 4 Totatahua mochixque ipan ta. 
\q1 Quena, motemachijque mopan ta huan ta tiquinmanahui. 
\q1  
\v 5 Mitznojnotzque quema tlaijiyohuiyayaj huan tiquinmaquixti. 
\q1 Mopan ta motemachijque huan amo tiquinpinahualti. 
\q1  
\v 6 Pero na nimomati quen se pilocuiltzi huan amo nise masehuali. 
\q1 Sequin san nechhuetzquilíaj huan sequinoc nechcualancaitaj. 
\q1  
\v 7 Nochi catli nechitaj san noca paquij, 
\q1 huan tlancuitzihuij huan motzonojolinía, 
\q1  
\v 8 huan quiijtohuaj: 
\q1 “Yaya catli motemachía ipan TOTECO, 
\q1 huajca ma tiquitaca sintla quimaquixtis. 
\q1 Sintla nelía quiicnelía, 
\q1 ma quimanahuiqui.” 
\m Quej nopa quiijtohuaj masehualme. 
\q1  
\v 9 Pero TOTECO, na nijmati para techpalehuijtoc. 
\q1 Techquixti iijtico nonana. 
\q1 Techmocuitlahuijtoc hasta tlen quema noja nichichiyaya. 
\q1  
\v 10 Huan quema nitlacatqui ya ipa nimotemachijtoc ipan ta. 
\q1 Nochi tonali tieltihualajtoc tinoTeco Dios. 
\q1  
\v 11 Amo techtlalcahui san pampa hualajtoc ni tequipacholi huan amo aqui seyoc catli hueli nechpalehuis. 
\q1  
\v 12 Miyaqui nocualancaitacahua nechyahualojtoque quen torojme catli mosisiníaj. 
\q1 Quena, nesij quen nopa huejhueyi torojme catli itztoque ipan tlali Basán. 
\q1  
\v 13 Nanalcaj quen tecuanime catli mosisiníaj. 
\q1 Camachalohuaj huan nechmelactlachilíaj. 
\q1  
\v 14 Na nimomati quen atl catli mopatzcatoc huan campa hueli toyajtoc. 
\q1 Nochi noomiyo lelecuecatoc. 
\q1 Noyolo eltoc quen cera catli atiya. 
\q1  
\v 15 Tlantoc nochi nochicahualis. 
\q1 Nijpiya nocamac huactoc quen se chachapal tepalcatl, 
\q1 huan nonenepil tlatzquitoc ica nocamacholec. 
\q1 Techtlalijtoc campa tlahuactoc huan campa onca miquilistli. 
\q1  
\v 16 Masehualme catli amo cuajcualme nechyahualojtoque quen chichime. 
\q1 Quicocoyotztoque nomax huan noicxihua. 
\q1  
\v 17 Hasta huelis nijpohuas noomiyohua, 
\q1 pampa sesen nechcocohua. 
\q1 Nocualancaitacahua nechsentlachilijtoque huan san noca paquij. 
\q1  
\v 18 Momajmacaj catli nimoquentiyaya. 
\q1 Quena, mahuiltíaj ica piltetzitzi para quiitase ajqueya quitocaros sesen noyoyohua. 
\q1  
\v 19 Pero ta, TOTECO, amo techtlalcahui, 
\q1 pampa na niitztoc momaco. 
\q1 Xihuala nimantzi techpalehuiqui. 
\q1  
\v 20 Techmanahui tlen ininmachete ni mosisinijca masehualme catli itztoque quen chichime. 
\q1 Amo xiquincahuili ma nechmictica. 
\q1  
\v 21 Eltoc quen niitztoc inincamaco tecuanime, 
\q1 huajca techmaquixti. Nopa masehualme itztoque quen torojme, 
\q1 amo ma nechtompojhuica. 
\q1  
\v 22 Huan na niquinpohuilis noicnihua tlen ta, TOTECO, 
\q1 huan quema oncas tlasentililistli, 
\q1 nimitzhueyichihuas iniixtla nochi. 
\q1  
\v 23 TOTECO, tojuanti catli timitztlepanitaj huan tiquimacasij timitzixpanose timitzpaquilismacaj. 
\q1 Nochi tiiteipan ixhuihua Israel, 
\q1 timitzhueyichihuaj. 
\q1 Quena, timitzhueyimatij nochi tiisraelitame. 
\q1  
\v 24 Pampa amo techelcajtoc quema titlaijiyohuíaj, 
\q1 niyon amo techhuejcamajcajtoc. 
\q1 Amo neli techcuanetlatilía. 
\q1 ¡Amo! Ta techtlacaquilía quema timitztlajtlaníaj techpalehuiqui. 
\q1  
\v 25 Huajca, TOTECO, ipan nopa hueyi tlasentililistli nimitzpaquilismacas iniixtla nochi momasehualhua, 
\q1 pampa ta titemachtli. 
\q1 Iniixpa catli mitztlepanitaj huan quiimacasij mitzixpanose, 
\q1 na nijchihuas catli nimitztencahuilijtoc para nijchihuas. 
\b  
\q1  
\v 26 Huajca nochi catli teicneltzitzi tlacuase huan ixhuise. 
\q1 Nochi catli quitemohuaj TOTECO quipantise huan quipaquilismacase. 
\q1 Quena, paquise para nochipa. 
\q1  
\v 27 Masehualme ipan nochi tlalme campa hueli ipan tlaltipactli motepotztocase huan quielnamiquise TOTECO. 
\q1 Inijuanti pehuase quihueyimatise huan motlancuaquetzase iixpa. 
\q1  
\v 28 Pampa TOTECO, yaya nopa tlanahuatijquetl catli quinahuatía nochi tlalme. 
\q1  
\v 29 Nochi catli quipiyaj tomi huan nochi catli teicneltzitzi ipan ni tlaltipactli motlancuaquetzase iixpa. 
\q1 Quena, nochi tlaltipac ehuani catli teipa miquise, quihueyimatise. 
\q1  
\v 30 Nojquiya noteipan ixhuihua quihueyimatise TOTECO huan tepohuilise tlen ya nochi ininnemilis. 
\q1  
\v 31 Quema toteipan ixhuihua tlacajtiyase, 
\q1 tepohuilise para xitlahuac TOTECO huan nochi nopa huejhueyi tlamantli catli techchihuilijtoc. 
\c 23  
\s1 TOTECO nechmocuitlahuía 
\q1  
\v 1 Quen se tlamocuitlahuijquetl quinmocuitlahuía pilborregojtzitzi, 
\q1 TOTECO nechmocuitlahuía. 
\q1 Huan yeca amo tleno nechpolohua. 
\q1  
\v 2 Yaya nechsiyajquetza campa onca yejyectzi sacatl catli xoxohuic. 
\q1 Nechhuica campa mantoc cuali atl catli amo mahuilili. 
\q1  
\v 3 Quema ayacmo hueli nimotlanana, 
\q1 nechmaca yancuic chicahualistli. 
\q1 Yaya nechyacana ipan ojtli xitlahuac para nijchijtinemis catli cuali, 
\q1 huan quej nopa nochi quihueyitlalise. 
\b  
\q1  
\v 4 Masque ninemis ipan tzintlayohuilotl nechca miquilistli, 
\q1 amo tleno niquimacasis, pampa ta, TOTECO, 
\q1 tiitztoc nohuaya. 
\q1 Ica mocuatopil techmanahuía ica catli amo cuali. 
\q1 Huan ica mocuachijcol catli huehueyac techtilana quema seyoc ojtli nijtoquilisnequi. 
\q1  
\v 5 Techsencahuilía se cuali tlacualistli iniixpa nocualancaitacahua. 
\q1 Ica aceite techpajtía campa nimococojtoc. 
\q1 Techtiochijtoc hasta mocahua. 
\q1  
\v 6 Nijmati para ta, TOTECO, techyacanas nochi nonemilis ica motlaicnelijcayo, 
\q1 pampa tijpiya hueyi moyolo nohuaya. 
\q1 Huan teipa nimocahuas mohuaya ipan mochaj nepa ilhuicac para nochipa. 
\c 24  
\s1 Nopa hueyi tlanahuatijquetl ipan nochi tlaltipactli huan ilhuicactli 
\q1  
\v 1 TOTECO iaxca ni tlaltipactli huan nochi catli eltoc ipani. 
\q1 Senquistoc nochi catli itztoque ipan ilhuicactli huan tlaltipactli iaxca. 
\q1  
\v 2 Pampa yaya quitlatzquilti cuali huan quiquetzqui ni tlaltipactli tlatzintla ipan nopa atl catli tlahuel huejcatla. 
\q1  
\v 3 ¿Ajqueya huelis tlejcos ipan itepe TOTECO? 
\q1 ¿Ajqueya huelis itztos ipan icaltiopa catli tlatzejtzeloltic? 
\q1  
\v 4 Huelis itztose nepa san catli quipiyaj ininmax huan ininyolo tlapajpactli iixpa, 
\q1 pampa yaya quintlapojpolhuijtoc inintlajtlacolhua. 
\q1 San yase nepa catli amo quihueyichihuaj se tlaixcopincayotl huan catli amo istlacatij quema quitestigojquetzaj TOTECO. 
\q1  
\v 5 Quena, quinmaquixtis TOTECO, 
\q1 huan quintiochihuas huan quiijtos para inijuanti itztoque cuali iixpa. 
\q1  
\v 6 Catli quej nopa quitemohuaj Toteco Dios, 
\q1 huelise moquetzase iixpa huan quihueyichihuase Toteco Dios catli Jacob huejcajya quitoquili. 
\q1  
\v 7 Ma motlapoca cuali nopa huejhueyi caltemitl catli ipa eltoya huan nochipa eltos ipan altepetl Sion, 
\q1 pampa calaquiqui nopa hueyi tlanahuatijquetl catli quinahuatía nochi tlaltipactli huan ilhuicac. 
\q1  
\v 8 ¿Ta tijmati ajqueya nopa hueyi tlanahuatijquetl catli quinahuatía nochi ilhuicactli huan tlaltipactli? 
\q1 Yaya TOTECO catli tlahuel quipiya chicahualistli huan amo tleno quiimacasi. 
\q1 Yaya TOTECO catli tlatlantinemi ipan nochi tlahuilancayotl. 
\q1  
\v 9 Ma motlapoca cuali nopa caltemitl catli ipa eltoya ipan altepetl Sion, 
\q1 huan calaquis nopa hueyi tlanahuatijquetl catli quinahuatía nochi tlaltipactli huan ilhuicactli. 
\q1  
\v 10 ¿Ta tijmati ajqueya nopa hueyi tlanahuatijquetl catli quinahuatía nochi tlaltipactli huan ilhuicactli? 
\q1 Yaya TOTECO. 
\q1 Yaya nopa hueyi tlanahuatijquetl catli quinahuatía nochi tlaltipactli huan ilhuicactli. 
\c 25  
\s1 David quinejqui quimatis nopa ojtli catli más xitlahuac 
\q1  
\v 1 Mopan ta, TOTECO, nimotlatlajtía ica nochi noyoltzi. 
\q1  
\v 2 Mopan ta, noTeco Dios, nimotemachía. 
\q1 Amo techcahua para ma nimopinahualti. 
\q1 Amo xiquincahuili nocualancaitacahua ma nechhuetzquilica. 
\q1  
\v 3 Amo quema mopinahualtijtoc se catli ipan ta motemachijtoc. 
\q1 Ma mopinahuase inijuanti catli nimantzi quinequij mitzixpanose. 
\q1  
\v 4 TOTECO, technextili moojhui. 
\q1 Quena, technextili nopa pilojtzi campa tijnequi ma ninejnemi. 
\q1  
\v 5 Techyacana ipan moojhui catli xitlahuac huan techmachti, 
\q1 pampa ta tinoTeco Dios huan tinotemaquixtijca. 
\q1 Mopan ta nimotemachía ipan tlen hueli hora. 
\q1  
\v 6 TOTECO, xiquelnamiqui moteicnelilis catli tijpixtoc para nochipa, 
\q1 catli hasta tlen huejcajya titenextilijtoc, 
\q1 huan yeca techtlasojtla. 
\q1  
\v 7 Amo xiquelnamiqui notlajtlacolhua catli nijchijqui quema nitelpocatixtoya. 
\q1 Xiquelcahua quema nimotlepanitayaya moixpa. 
\q1 TOTECO, techelnamiqui ica motlaicnelilis pampa hueyi moyolo nohuaya. 
\q1  
\v 8 TOTECO, ta nelía ticuali huan tixitlahuac. 
\q1 Yeca tiquinnextilía tlajtlacolchihuani nopa cuali ojtli catli ipan ma nejnemise. 
\q1  
\v 9 Tiquinyacana catli moicnonequij ipan nopa ojtli catli más xitlahuac. 
\q1 Quena, tiquinmachtía inijuanti catli quitemohuaj tlaque mopaquilis. 
\q1  
\v 10 Quema se masehuali quitoquilía motlanahuatil, TOTECO, 
\q1 nochi ojtli catli ipan tijhuica quinextilía motlaicnelilis, 
\q1 huan quinextilía para ta tiitztoc tixitlahuac. 
\q1  
\v 11 ¡TOTECO! Techtlapojpolhui notlajtlacol masque nelía hueyi. 
\q1 Techtlapojpolhui pampa quej nopa tiquijtojtoc tijchihuas. 
\q1  
\v 12 TOTECO, ica masehualme catli quiimacasij mitzixpanose, 
\q1 tiquinnextilis nopa cuali ojtli catli tijtlapejpenijtoc para inijuanti. 
\q1  
\v 13 Tiquintiochihuas miyac, 
\q1 huan ininconehua quiselise nopa tlali catli tiquinmacas. 
\q1  
\v 14 TOTECO tiquinpohuilía catli eltoc ipan moyolo inijuanti catli mitztlepanitaj huan quiimacasij mitzixpanose. 
\q1 Quena, tiquinnextilía nochi catli ininhuaya timocajtoc masehualme. 
\q1  
\v 15 Nochipa nimitztemohua TOTECO, 
\q1 huan nijchiya para techpalehuiqui, 
\q1 pampa san ta tihuelis techmanahuis tlen ni tlaquetztli. 
\q1  
\v 16 Techtlachili, TOTECO, 
\q1 huan xijpiya hueyi moyolo noca na, 
\q1 pampa niitztoc noseli huan nimoyoltequipachohua. 
\q1  
\v 17 Nimoyoltequipachohua ica tlahuel miyac tlamantli catli ohui. 
\q1 Techmanahui tlen nopa tequipacholi. 
\q1  
\v 18 Xijtlachili nopa tequipacholi catli nechcuatetzopa huan nechtlaijiyohuiltía. 
\q1 Huan techtlapojpolhui nochi notlajtlacolhua. 
\q1  
\v 19 Xiquita quesqui nocualancaitacahua niquinpiya huan quenicatza tlahuel nechcualancaitaj. 
\q1  
\v 20 Techmocuitlahui huan techmaquixti para amo nechcocose. 
\q1 Amo xijcahua ma nechpinahualtica, 
\q1 pampa ipan ta nimotemachijtoc. 
\q1  
\v 21 Techmanahui pampa nitemachtli huan nijchihua catli xitlahuac, 
\q1 huan nimotemachijtoc ipan ta. 
\q1  
\v 22 NoTeco Dios, techmaquixti tiisraelitame tlen nochi totequipachol, 
\q1 pampa timomasehualhua. 
\c 26  
\s1 Nopa nemilistli catli tlahuel tlapajpactli 
\q1  
\v 1 TOTECO, techtlajtolsencahua. 
\q1 Xiteyolmelahua para amo tleno catli fiero nijchijtoc. 
\q1 Nimotemachijtoc san ipan ta huan amo quema nimoilhuijtoc nimitzcahuas. 
\q1  
\v 2 Techyoltlachili, TOTECO, 
\q1 huan techyejyeco. 
\q1 Xijtlachili cuali noyolo huan notlalnamiquilis catli más noyolijtic eltoc. 
\q1  
\v 3 Pampa na nijpatiita motlaicnelilis, huan nochipa nijtoquilía mocamanal catli melahuac. 
\q1  
\v 4 Amo quema ninejnentoc ininhuaya masehualme catli tlacajcayahuaj, 
\q1 niyon amo nimohuicatoc ininhuaya catli quipiyaj ome iniixayac. 
\q1  
\v 5 Nijcualancaita inintlasentililis amo cuajcualme. 
\q1 Amo quema nimosentilijtoc ininhuaya catli fiero quichihuaj. 
\q1  
\v 6 Tlapajpactli nomax tlen nochi tlajtlacoli, 
\q1 huan san quej nopa nimonechcahuis motlaixpa, TOTECO. 
\q1  
\v 7 Nepa nihuicas huicatl para nimitzhueyitlalis huan niteyolmelahuas nochi catli yejyectzi catli ta tijchijtoc. 
\q1  
\v 8 Tlahuel niquicnelía mochaj campa tiitztoc, TOTECO, 
\q1 campa monextía motlatlanex. 
\q1  
\v 9 Amo techchihuili quen tiquinchihuilía tlajtlacolchihuani huan temictiani. 
\q1  
\v 10 Inijuanti quisencahuaj quenicatza huelis tetlacuijcuilise. 
\q1 Quipiyaj ininmax temitoc ica tomi catli tlaichtaca tlainantoque. 
\q1  
\v 11 Pero na ninemi xitlahuac. 
\q1 Xijpiya hueyi moyolo noca na, 
\q1 huan techmaquixti. 
\q1  
\v 12 TOTECO, nimitzhueyichihua tlamiyacapa. 
\q1 Ica ta, cuali niijcatoc, 
\q1 huan amo techcahuilijtoc ma nihuetzi. 
\c 27  
\s1 TOTECO nechtlahuilía huan nechmaquixtía 
\q1  
\v 1 TOTECO nechtlahuilía huan nechmaquixtía. 
\q1 ¿Ajqueya ma niquimacasis? 
\q1 TOTECO yaya nochicahualis, 
\q1 huan na niitztoc imaco. 
\q1 Amo aqui niquimacasis. 
\q1  
\v 2 Quema amo cuajcualme quinequise nechhuilanase huan quinequise nechmictise, 
\q1 motepotlamise huan huetzise. 
\q1  
\v 3 Masque nochi isoldados se hueyi tlali motlananase noixpa, 
\q1 amo niyolmajmahuis. 
\q1 Masque nechhuilanase, 
\q1 na nimotemachijtos ipan TOTECO pampa yaya itztoc nohuaya. 
\q1  
\v 4 San se tlamantli nijtlajtlanijtoc TOTECO. 
\q1 San se tlamantli nijnequi. 
\q1 Nijnequi niitztos ipan ichaj TOTECO nochi tonali. 
\q1 Nijnequi nijhueyichihuas nepa huan nimopaquilismacas ica nochi ihueyitilis huan itlatlanex. 
\q1 Quena, ipan ichaj nijtemos catli ya ipaquilis. 
\q1  
\v 5 Quema ajsis tonali catli amo cuali, 
\q1 TOTECO nechmocuitlahuis. 
\q1 Nechtlatis ipan icaltiopa campa más tlatzejtzeloltic, 
\q1 huan teipa nechquetzas ipan se hueyi tetl para nechhueyitlalis. 
\q1  
\v 6 Quena, nechhueyitlalis iniixpa nocualancaitacahua. 
\q1 Yeca na nijtencahuas tlacajcahualistli ipan icaltiopa, 
\q1 huan nicuatzajtzis ica paquilistli. 
\q1 Nihuicas huan nitlatzotzonas para nijpaquilismacas TOTECO. 
\b  
\q1  
\v 7 TOTECO, techtlacaquili pampa nimitznojnotza. 
\q1 Xijpiya hueyi moyolo noca na, 
\q1 huan technanquili. 
\q1  
\v 8 TOTECO, quema techilhuía: 
\q1 “Techcamanalhuiqui”, 
\q1 na nimitznanquilía: 
\q1 “Nimitzcamanalhuiti”. 
\q1  
\v 9 ¡Amo techcuanetlatili! 
\q1 ¡Amo techhuejcamajcahua pampa ticualantoc nohuaya! 
\q1 San ta catli techpalehuía, 
\q1 noTeco Dios, ta catli tinotemaquixtijca. 
\q1 Amo techiyocacahua, niyon amo techcajtehua noseltzi. 
\q1  
\v 10 Masque notata huan nonana nechtlahuelcahuase, 
\q1 TOTECO, ta nochipa techmocuitlahuis. 
\q1  
\v 11 TOTECO, technextili catli tijnequi ma nijchihua. 
\q1 Techyacana san ipan nopa ojtli cuali campa tijnequi ma ninejnemi, 
\q1 pampa nocualancaitacahua nechyahualohuaj. 
\q1  
\v 12 Amo techtemactili ininmaco quen inijuanti quinequij, 
\q1 pampa noca na motlanantoque masehualme catli istlacatij huan san quimatij catli más fiero nechchihuilise. 
\b  
\q1  
\v 13 Pero na cuali nijmati TOTECO nechmanahuis, 
\q1 huan sempa niquitas quenicatza cuali iyolo nohuaya ipan ni tlaltipactli campa niitztoc. 
\q1  
\v 14 Ximochiya ipan TOTECO. 
\q1 Ximotemaca huan ximoyolchicahua huan amo ximomajmati. 
\q1 Quena, ximotemachi ipan TOTECO. 
\c 28  
\s1 Toteco quitlacaquilía quema timotlatlajtíaj 
\q1  
\v 1 TOTECO, tinotlamanahuijca. 
\q1 San ipan ta nimotlatía. 
\q1 Ta catli nimitztzajtzilía techpalehuiqui. 
\q1 Amo ximotlahuelnequi para technanquilis, 
\q1 pampa sintla amo technanquilis, 
\q1 san nimotemacas para ma nechmictica. 
\q1  
\v 2 Xijcaqui nocamanal quema nimitztlajtlanía tlapalehuili. 
\q1 Techchihuili cuenta quema nimomatlananas huan nijmelactlachilis mocaltiopa catli tlahuel tlatzejtzeloltic. 
\q1  
\v 3 Amo techtlatzacuilti ininhuaya masehualme catli amo cuajcualme catli san quichihuaj catli amo monequi. 
\q1 Inijuanti camanaltij yejyectzi ica sequinoc, 
\q1 pero quipiyaj nochi catli amo cuali ipan ininyolo. 
\q1  
\v 4 Xiquincuepili nochi catli amo cuali quichijtoque ica catli amo cuali nojquiya. 
\q1 Xiquintlaxtlahui ica catli fiero san se quen fiero quinchihuilijtoque sequinoc. 
\q1  
\v 5 TOTECO, inijuanti amo quichihuilíaj cuenta nochi catli tijchijtoc, 
\q1 huajca tiquintzontlamiltis huan amo quema tiquintlananas sempa. 
\q1  
\v 6 TOTECO, nimitzpaquilismacas pampa tijtlacaquilijtoc catli nimitztlajtlanijtoc. 
\q1  
\v 7 TOTECO, yaya nochicahualis huan notlamanahuijca ica nochi catli mahuilili. 
\q1 Ipan ya nimoneltemachijtoc huan nechpalehuijtoc, 
\q1 yeca ipan noyolo nijpiya miyac paquilistli. 
\q1 Nihuicas huan nimitztlascamatis, TOTECO. 
\q1  
\v 8 TOTECO, ta tiquinpixtoc momaco nochi momasehualhua. 
\q1 Yeca san ipan ta motemachía motlanahuatijca catli tijtlapejpenijtoc. 
\q1  
\v 9 Xijmaquixti moaltepe, TOTECO. 
\q1 Huan xiquintiochihua inijuanti catli moaxcahua. 
\q1 Techmocuitlahui quen se quinmocuitlahuía ipilborregojhua. 
\q1 Techhuica momaco para nochipa. 
\c 29  
\s1 Se huicatl tlen ihueyitilis TOTECO 
\q1  
\v 1 Xijhueyichihuaca TOTECO, 
\q1 amojuanti anitequihuajcahua. 
\q1 Xijhueyichihuaca TOTECO catli quipiya hueyi ichicahualis huan itlatlanex. 
\q1  
\v 2 Xijhueyichihuaca TOTECO por ihueyitilis, 
\q1 pampa ya nopa quinamiqui para yaya catli tlahuel hueyi. 
\q1 Xijhueyichihuatij TOTECO catli itztoc campa tlahuel tlayejyectzi huan tlatzejtzeloltic. 
\q1  
\v 3 Quema TOTECO camanalti, 
\q1 caquisti quen tlatomonilotl catli chicahuac ipan hueyi atl. 
\q1 Itoscac Toteco Dios catli itztoc ipan ilhuicac caquisti quen tlatomoni ipan ilhuicac tlahuel chicahuac. 
\q1 Quena, TOTECO itoscac monanquilía iixpa nopa hueyi atl ica nochi ihueyitilis. 
\q1  
\v 4 Itoscac TOTECO quipiya chicahualistli. 
\q1 Quena, itoscac quipiya tlahuel miyac chicahualistli. 
\q1  
\v 5 Itoscac tlahuel temajmati huan quema TOTECO camanalti, 
\q1 quichihua para ma ixtzayanica tiocuame. 
\q1 Quena, Toteco quintlapana nochi tiocuame ipan tlali Líbano. 
\q1  
\v 6 Quichihua ma huihuipicaca nochi cuatitlamitl ipan tlalme Líbano huan Sirión. 
\q1 Quinchihualtía nopa cuame ma molinica quen piltorojtzitzi huan pilhuacaxtzitzi catli huitontehuaj. 
\q1  
\v 7 Quema TOTECO camanalti, 
\q1 quimajcahua tlilelemectli. 
\q1  
\v 8 Quema TOTECO camanalti, 
\q1 huihuipica nochi huactoc tlali. 
\q1 Quena, hasta quichihua para ma huihuipica nopa huactoc tlali Cades. 
\q1  
\v 9 Quema TOTECO quiijtohua para oncas tlatomonilotl, 
\q1 huajca quichihua ma ixtzayanica nopa ahua cuame huan quicahua tlapepestic ipan cuatitlamitl. 
\q1 Ipan ichaj nepa ilhuicac nochi quihueyichihuaj huan quiijtohuaj: “Tlahuel onpano yejyectzi mohueyitilis.” 
\q1  
\v 10 TOTECO tlanahuatiyaya quema oncac nopa tlahuel miyac atl catli momanqui ipan nochi tlaltipactli. 
\q1 Huan TOTECO noja tlanahuatía huan tlanahuatis para nochipa. 
\q1  
\v 11 TOTECO quinmaca chicahualistli nochi imasehualhua. 
\q1 Quena, TOTECO quintiochihua huan quinmaca tlasejseltili ipan ininyolo. 
\c 30  
\s1 Se huicatl para quitlascamati TOTECO 
\q1  
\v 1 TOTECO, nimitzhueyitlalía pampa techtlananqui tlen más tlatzintla. 
\q1 Amo tiquincahuilijtoc nocualancaitacahua ma noca paquica. 
\q1  
\v 2 TOTECO, nimitztlajtlani motlapalehuil para techchicahua quema nimococohuayaya, 
\q1 huan ta techchicajqui. 
\q1  
\v 3 TOTECO, techmanahui quema niitztoya para nimiquis. 
\q1 Techmacac nonemilis sempa, 
\q1 huan yeca amo niitztoc ostoijtic. 
\q1  
\v 4 TOTECO, nochi moaxcahua ma huicaca tiohuicatl moixpa. 
\q1 Ma mitzhueyichihuaca ta catli titlatzejtzeloltic. 
\q1  
\v 5 TOTECO, quema ticualani, 
\q1 san huejcahua se tlatoctzi, 
\q1 pero ipan nochi tonemilis technextilía para tijpiya hueyi moyolo tohuaya. 
\q1 Masque tojuanti quemantic tichocaj ica tlayohua, 
\q1 ica ijnaloc tijpiyaj paquilistli ipan ta. 
\q1  
\v 6 Quema cuali niitztoya huan amo tleno nechpolohuayaya, 
\q1 nimoilhui amo aqui huelis nechtlanis. 
\q1  
\v 7 TOTECO, ica motlaicnelilis techquetztoya cuali quen se hueyi tepetl catli amo aqui hueli quiolinis. 
\q1 Pero teipa, techcuanetlatili huan nimajmajcamiquiyaya. 
\q1  
\v 8 Huan nimitznotzqui, TOTECO. 
\q1 Nimitztzajtzili para techtlasojtla. 
\q1  
\v 9 Pampa, TOTECO, sintla techcahuilisquía ma nimiqui, 
\q1 tlaque tijtlanisquía. 
\q1 Ayacmo huelisquía nimitzhueyichihuasquía iniixpa nohuampoyohua. 
\q1 Toteco, sintla nimiquis, nimocuepas tlali, 
\q1 huan tlali amo huelis mitzhueyichihuas. ¿Amo que? 
\q1 ¿Atlac mijcatzitzi huelise tepohuilise para ta nelía titemachtli? 
\q1  
\v 10 Huajca, TOTECO, techtlacaquili huan xijpiya hueyi moyolo nohuaya. 
\q1 TOTECO, ta xieli tinotlapalehuijca. 
\q1  
\v 11 Techtlacaquilijtoc huan techquixtilijtoc nopa tequipacholi. 
\q1 Techmacatoc hueyi paquilistli. 
\q1 Techquixtilijtoc nopa yoyomitl catli nimoquentijtoya pampa nimotequipachohuayaya. 
\q1 Huan techquentijtoc se cuali yoyomitl catli tenextilía para nijpiya paquilistli. 
\q1  
\v 12 Yeca TOTECO, amo hueli nimocamatzacuas. 
\q1 Nimitzhueyichihuas ica tiohuicatl huan nochipa nimitztlascamatis. 
\c 31  
\s1 Ma timotemachica miyac ipan Toteco 
\q1  
\v 1 TOTECO, ipan ta nimotemachijtoc. 
\q1 Amo quema xiquincahuili sequinoc ma nechpinahualtica. 
\q1 Techmanahui ta catli nochipa tijchihua catli xitlahuac. 
\q1  
\v 2 TOTECO, ximoechcapano para techtlacaquilis. 
\q1 Techmanahuiqui nimantzi. 
\q1 Techcahuili ma nimotlati mopan ta. 
\q1 Na niitztos momaco para techmanahuis. 
\q1  
\v 3 Ipan ta nimotemachía para techpalehuis. 
\q1 Quena, ipan ta niitztoc ica temachili. 
\q1 Techyacantinemi para nochi ma mitzhueyitlalica más. 
\q1  
\v 4 Ta tinotlamocuitlahuijca, 
\q1 techmaquixti tlen ni tlaquetztli catli nocualancaitacahua quitlatijtoque ipan noojhui para nechmasiltise. 
\q1  
\v 5 Nimitzmactilía notonal momaco. 
\q1 Techmanahui, TOTECO, ta tinopa Dios catli titemachtli. 
\q1  
\v 6 Niquincualancaita nochi catli quinhueyichihuaj teteyome, 
\q1 pampa teteyome amo tleno hueli quichihuaj. 
\q1 Pero na nimotemachijtoc ipan ta, TOTECO. 
\q1  
\v 7 Nijpiya miyac paquilistli pampa techicnelía. 
\q1 Ta tiquitztoc nochi notequipachol, 
\q1 tiquiximajtoc nochi catli nopantitoc. 
\q1  
\v 8 Amo techtemactili ininmaco nocualancaitacahua. 
\q1 ¡Amo! Campa techquetzqui tlacualca huan temachtli. 
\s1 David tlaijiyohuiyaya ica cocolistli huan ica icualancaitacahua 
\q1  
\v 9 TOTECO, techtlasojtla pampa niitztoc ipan tequipacholi. 
\q1 Nisenchocatoc hasta nijmati tlantiyohuij noixteyolhua. 
\q1 Ipan noyolo huan notlacayo nijmati nitlamitlaijiyohuijtoc ica tequipacholi. 
\q1  
\v 10 Ni tlacuajcualoli nechtzontlamiltía pampa san tequipacholi nijmati. 
\q1 Sesen xihuitl catli pano san nitlaayijhuía. 
\q1 Ya tlantinemi nochicahualis por notlajtlacolhua hasta ya nitlacayohuactinemi. 
\q1  
\v 11 Nocualancaitacahua huan hasta nocalnechcahua nechijiyaj. 
\q1 Catli nechiximatij nechimacasij. 
\q1 Catli nechitaj ojtipa nechtlalcahuíaj. 
\q1  
\v 12 Nochi masehualme nechelcajtoque quen ya nimictosquía. 
\q1 Nechtlahuelcajtoque quen se chachapal tepalcatl ipan tlasoli. 
\q1  
\v 13 Nijcaqui quenicatza nocualancaitacahua nechistlacahuíaj. 
\q1 Yeca nechitzquitoc se hueyi majmajtli huan nechmajmatía. 
\q1 Inijuanti san sejco moijilhuíaj quenicatza huelise nechmictise. 
\q1  
\v 14 Pero TOTECO, na nimotemachía ipan ta huan niquijtohua: “¡Taya tinoDios!” 
\q1  
\v 15 Sesen tonali catli niitztoc momaco eltoc. 
\q1 Techmanahui ininmaco nocualancaitacahua catli nechtlaijiyohuiltijtinemij. 
\q1  
\v 16 TOTECO, ma monextis moteicnelijcayo ipan moixayac quema techtlachilía na, 
\q1 nimotequipanojca. 
\q1 Techmaquixti pampa ta techsenicnelijtoc. 
\q1  
\v 17 TOTECO, na nimitztemojtoc. 
\q1 Amo xiquincahuili para ma nechpinahualtica. 
\q1 Xiquinpinahualti masehualme catli amo cuajcualme. 
\q1 Quena, inijuanti mocamatzacuase quema tiquintzontlamiltis. 
\q1  
\v 18 TOTECO, ayacmo molinis ininnenepil inijuanti catli istlacatij quema ya mictose. 
\q1 Ayacmo itztose inijuanti catli mohueyimatij quema camanaltij para techtlaijilhuise tojuanti catli tinemij xitlahuac moixpa. 
\q1 Quena, xiquinmicti catli mohueyitlalíaj huan techmahuispolohuaj. 
\q1  
\v 19 Pero ta, nelía hueyi moyolo ica inijuanti catli mitztlepanitaj huan tiquinmocuitlahuía. 
\q1 Nelía cuali motlaicnelilis catli ticajoctoc para tojuanti catli timotemachijtoque ipan ta, 
\q1 tojuanti catli tlamiyacapa titematiltijtoque para san ta tihueli techmanahuis. 
\q1  
\v 20 TOTECO, ta techtlatía campa ichtacatzi tojuanti catli timitztlepanitaj, 
\q1 huan nepa ta timocahua tohuaya. 
\q1 Yeca fiero masehualme amo huelij techajsise ica catli quisencajtoque. 
\q1 Quena, momaco techtlatía huan amo aqui catli techmahuispolohua hueli techajsis. 
\q1  
\v 21 Nimitztlascamati, TOTECO, 
\q1 pampa tijchijqui huejhueyi tlamantli para technextilis moteicnelijcayo. 
\q1 Ica temachili techyahualojtoc para techmanahuis tlen nocualancaitacahua. 
\q1  
\v 22 TOTECO, nimoilhuijtiquisqui para techtlahuelcajtoya. 
\q1 ¡Pero amo neli! 
\q1 Tijcajqui quema nimitztzajtzili techpalehuiqui, huan technanquili. 
\b  
\q1  
\v 23 Nochi amojuanti catli aniaxcahua TOTECO, 
\q1 xiquicnelica pampa yaya quinmocuitlahuía catli itztoque temachme. 
\q1 Pero ica masehualme catli mohueyimatij, 
\q1 TOTECO quintlaxtlahuía hasta ica itlanca nochi catli amo cuali quichijtoque. 
\q1  
\v 24 Nochi amojuanti catli anmotemachíaj ipan TOTECO, 
\q1 xipaquica huan ximotemacaca. 
\c 32  
\s1 Nelía paqui nopa masehuali catli TOTECO quitlapojpolhuijtoc 
\q1  
\v 1 Nelía paqui nopa masehuali catli TOTECO quitlapojpolhuijtoc itlajtlacolhua huan quiixpolojtoc nochi itlaixpanolhua. 
\q1  
\v 2 Quipiya paquilistli catli ya quipohuilijtoc TOTECO itlajtlacolhua, 
\q1 huan ayacmo quitlajtlacoltía ica niyon se tlamantli. 
\q1 Ipan iyolo ayacmo mocajcayahua quen amo tleno quichijtoc. 
\q1  
\v 3 Quema ayamo nijpohuilijtoya TOTECO quen nitlajtlacolchijtoya, 
\q1 semilhuitl nitlaayijhuiyaya hasta nijmatqui para tlantoya nochicahualis. 
\q1  
\v 4 Techtlatzacuiltiyaya tonaya huan tlayohua. 
\q1 Techtlatzacuilti hasta nijmatiyaya nicuahuaquiyaya quen soquiatl huaqui quema chicahuac tlatotoniya. 
\q1  
\v 5 Pero teipa nimitzpohuili nochi notlajtlacolhua huan niyon se amo nijtlati. 
\q1 Nimotemacac nimitzpohuilis nochi notlaixpanolhua huan ta, TOTECO, nochi techtlapojpolhui, 
\q1 huan techquixtili nopa tlaeticayotl. 
\q1  
\v 6 Monequi para nochi catli moaxcahua mitztemose quema itztoque ipan tequipacholi. 
\q1 Monequi motemachise ipan ta, 
\q1 huan masque tequipacholi momiyaquilis quen se atlajtli catli chicahuac mixcuepa, 
\q1 amo quinajsis. 
\q1  
\v 7 TOTECO, ipan ta nimotemachía quema onca tequipacholi, 
\q1 huan ta techmocuitlahuía. 
\q1 Tijchijtoc para sequinoc ma nechyahualoca, 
\q1 huan inijuanti huicaj chicahuac para mitzhueyichihuase pampa techmanahuijtoc. 
\b  
\q1  
\v 8 TOTECO quiijtohua: 
\q1 “Na nimitztlalnamictis huan nimitznextilis nopa ojtli catli más cuali, 
\q1 catli monequi ipan timonejnemiltis. 
\q1 Na nimitzconsejomacas huan nimitztlachilijtos. 
\q1  
\v 9 Amo ximochihua quen se cahuayo, 
\q1 o se mula catli amo quipiya tlalnamiquilistli, 
\q1 catli monequi tijtlalilis se tepos camachali ica se mecatl huan tijtilanas para ma mitzneltocas.” 
\b  
\q1  
\v 10 Amo cuajcualme quipantise miyac tlaijiyohuilistli, 
\q1 pero tojuanti catli timotemachíaj ipan TOTECO, 
\q1 yaya techyahualohua ica itlaicnelilis. 
\q1  
\v 11 Xipaquica ipan TOTECO, 
\q1 amojuanti catli anitztoque xitlahuaque iixpa. 
\q1 Amojuanti catli anquineltoquilíaj, 
\q1 xitzajtzica ica paquilistli por catli TOTECO quichijtoc. 
\c 33  
\s1 Se huicatl para quihueyichihuase TOTECO 
\q1  
\v 1 Xihuicaca ica paquilistli para TOTECO amojuanti catli anitztoque xitlahuac iixpa. 
\q1 Nelía yejyectzi para nochi tojuanti catli tijchijtinemij catli cuali ma tijhueyichihuaca. 
\q1  
\v 2 Xitlatzotzonaca ica arpa para xijhueyichihuaca, TOTECO. 
\q1 Xihuicaca iixpa huan xijpaquilismacaca ica tlatzotzonali catli nesi quen guitarra. 
\q1  
\v 3 Xijsencahuaca se huicatl catli yancuic, 
\q1 huan xijhuicatica TOTECO. 
\q1 Xitlatzotzonaca cuali, 
\q1 huan xitzajtzica ica paquilistli. 
\q1  
\v 4 Pampa nelía xitlahuac nochi catli quiijtohua TOTECO. 
\q1 Nochi catli quichihua tenextilía para temachtli. 
\q1  
\v 5 TOTECO quipactía nochi catli xitlahuac huan catli melahuac. 
\q1 Nochi catli itztoque ipan tlaltipactli quiselíaj itlaicnelilis TOTECO. 
\q1  
\v 6 TOTECO tlanahuati ma onca ilhuicactli huan mochijqui. 
\q1 San camanaltic huan mochijqui metztli, tonati huan nochi sitlalime. 
\q1  
\v 7 Yaya quisansejcotili nochi atl catli eltoc ipan hueyi atl. 
\q1 Quiajojqui nopa atl campa más tlahuejcatla. 
\q1  
\v 8 Nochi antlaltipac ehuani xijhueyitlepanitaca TOTECO. 
\q1 Quena, nochi catli anitztoque ipan ni tlaltipactli xiquimacasica. 
\q1  
\v 9 Pampa nochi catli yaya quiijto, 
\q1 ya nopa mochijqui. 
\q1 Huan catli yaya tlanahuati ma eli, 
\q1 ya nopa monexti. 
\q1  
\v 10 TOTECO quinsosolhuilía inintlalnamiquilis masehualme ipan campa hueli tlalme para amo ma quichihuaca catli fiero moilhuijtoque. 
\q1 San tlailpitzas huan quincuapolos tlalme para amo huelise quichihuase catli fiero quisencajtoque quichihuase. 
\q1  
\v 11 Pero catli TOTECO moilhuijtoc quichihuas amo quema mopatlas. 
\q1 Catli ya quinequi, 
\q1 ya nopa elis para nochipa. 
\q1  
\v 12 Paquij masehualme ipan nopa tlali catli motemachíaj ipan TOTECO. 
\q1 Quena, nelía paquij nopa masehualme catli TOTECO quintlapejpenijtoc para iaxcahua. 
\q1  
\v 13 TOTECO catli itztoc nepa ilhuicac techhualtlachilijtoc nochi timasehualme. 
\q1  
\v 14 Hasta nepa ipan ilhuicac TOTECO techtlachilijtoc catli tiitztoque ipan ni tlaltipactli. 
\q1  
\v 15 Yaya TOTECO catli techyolchijchijqui nochi titlaltipac ehuani huan techtlachilía nochi catli tijchijtinemij. 
\q1  
\v 16 Se hueyi tlanahuatijquetl amo tlatlani pampa quinpiya miyac isoldados. 
\q1 Niyon se soldado catli motemaca amo tlatlani pampa quipiya miyac fuerza. 
\q1  
\v 17 Amo ximotemachi ipan se cahuayo para mitzmanahuis masque nelía tetic. 
\q1 San ica ifuerza amo hueli temanahuía. 
\q1  
\v 18 Pero TOTECO, quena, yaya nochipa techtlachilijtoc tojuanti catli tiquimacasij tiquixpanose. 
\q1 Techmocuitlahuía catli timochiyaj ipan itlaicnelilis. 
\q1  
\v 19 Techmanahuía quema tiitztoque nechca miquilistli. 
\q1 Huan techtlamacas quema oncas mayantli para noja ma tiitztoca. 
\q1  
\v 20 Tojuanti ipan toyoltzi timotemachíaj ipan TOTECO. 
\q1 Yaya techpalehuía huan techmanahuía ica catli amo cuali. 
\q1  
\v 21 Yeca ma tiyolpaquica ipan TOTECO, 
\q1 pampa timoneltemachijtoque ipan yaya catli nelía tlatzejtzeloltic. 
\b  
\q1  
\v 22 TOTECO, xijpiya moyolo tohuaya, 
\q1 pampa san ipan ta timochiyaj. 
\c 34  
\s1 TOTECO techmocuitlahuía huan techmanahuía 
\q1  
\v 1 Nijtlascamatis TOTECO tlatoctzitzi huan nochipa nijsenpaquilismacatos. 
\q1  
\v 2 Nijhueyitlalis huan niquinilhuis nochi masehualme catli yaya nechchihuilijtoc. 
\q1 Inijuanti catli teicneltzitzi quicaquise huan paquise. 
\q1  
\v 3 Ma tijhueyichihuaca huan ma tijhueyitlalica TOTECO san sejco. 
\q1  
\v 4 Nijtzajtzili TOTECO ma nechpalehuiqui, 
\q1 huan yaya nechtlacaquili huan nechmanahui tlen nochi catli nechmajmatiyaya. 
\q1  
\v 5 Sequinoc catli motemachíaj ipan Toteco ixcahuanij ica paquilistli nojquiya, 
\q1 por catli yaya quinchihuilijtoc. 
\q1 Amo quema pinahuase. 
\q1  
\v 6 Masque nipilteicneltzi, 
\q1 nijtzajtzili TOTECO, 
\q1 huan yaya nechmaquixti ica nochi tlamantli catli nechtequipachohuayaya. 
\q1  
\v 7 Itequihua TOTECO quinmocuitlahuía nochi catli quiimacasij TOTECO, 
\q1 huan yaya quinmanahuía. 
\q1  
\v 8 Xijyejyecoca TOTECO huan anquiitase para melahuac cuali iyolo tohuaya. 
\q1 Hueyi paquilistli quipiyaj nochi masehualme catli ipan ya motemachíaj. 
\q1  
\v 9 Nochi amojuanti catli aniaxcahua TOTECO, xiquimacasica, 
\q1 pampa nochi catli quitlepanitaj amo tleno quinpolohua. 
\q1  
\v 10 Nopa tecuanime catli más quipiyaj chicahualistli quemantic mayantinemij huan amo quipantíaj catli quicuase, 
\q1 pero masehualme catli quitemohuaj TOTECO quipiyase nochi catli cuali. 
\q1  
\v 11 Xihualaca noconehua, huan techtlacaquilica, 
\q1 huan nimechmachtis quenicatza monequi anquitlepanitase TOTECO, 
\q1 huan anquiimacasise anquiixpanose. 
\q1  
\v 12 ¿Tijnequi tiitztos ica yejyectzi? 
\q1 ¿Tijnequi tihuejcahuas ipan ni tlaltipactli, 
\q1 huan tiquitas catli cuali? 
\q1  
\v 13 Monequi xijmocuitlahuis monenepil para amo tiquinmahuispolos sequinoc ica istlacatili. 
\q1  
\v 14 Ximoiyocatlali ica catli amo cuali, 
\q1 huan xijchihua san catli xitlahuac. 
\q1 Xijchihuaca catli anhuelij para ma oncas tlasejseltili ininhuaya nochi masehualme. 
\q1 Quena, ya nopa xijtemoca ica nochi amoyolo. 
\q1  
\v 15 TOTECO quintlachilía catli nemij xitlahuac iixpa, 
\q1 huan san quichiya para quinmacas catli quitlajtlanise. 
\q1  
\v 16 Pero TOTECO sencualantoc ica inijuanti catli quichihuaj catli fiero. 
\q1 Quintzontlamiltis para ma ayacmo aqui quinelnamiquis ipan ni tlaltipactli. 
\q1  
\v 17 Quema masehualme catli itztoque xitlahuaque iixpa TOTECO quitzajtzilíaj, 
\q1 yaya quintlacaquilía. 
\q1 Huan quinmanahuía tlen nochi inincuesolhua. 
\q1  
\v 18 TOTECO itztoc ininnechca masehualme catli motequipachohuaj. 
\q1 Huan quinmaquixtía catli motequipachohuaj ica inintlajtlacolhua. 
\q1  
\v 19 Se masehuali catli itztoc xitlahuac iixpa TOTECO quipiya miyac tequipacholi, 
\q1 pero TOTECO quimanahuía ica nochi catli ipanti. 
\q1  
\v 20 Pampa TOTECO quimocuitlahuía para amo postequis niyon se iomiyo. 
\q1  
\v 21 Se masehuali catli fiero inemilis miquis por nopa tlamantli fiero catli quichihua. 
\q1 Quena, TOTECO quintlalilis tlatzacuiltili catli quicualancaitaj catli cuali. 
\q1  
\v 22 TOTECO quinmaquixtía itequipanojcahua. 
\q1 Quena, quintlapojpolhuía imasehualhua catli motemachíaj ipan ya. 
\c 35  
\s1 Se netlatlajtili para TOTECO ma quimaquixti ininmaco icualancaitacahua 
\q1  
\v 1 TOTECO, xiquincamaijixnamiqui catli noca cualanij. 
\q1 Xiquinhuilana catli quinequij nechhuilanase. 
\q1  
\v 2 Xijcui nochi motlahuilanca teposhua, 
\q1 huan ximotlanana para techmanahuiqui. 
\q1  
\v 3 Xijquixti mohacha catli ica titlahuilana, 
\q1 huan xiquinojtzacua catli nechtepotztocatihualahuij. 
\q1 Huan techilhui: 
\q1 “Na nimitzmaquixtis.” 
\b  
\q1  
\v 4 Ma mopinahuaca huan ma mocuapoloca catli nechtemohuaj para nechmictise. 
\q1 Ma mocuepaca ininchaj ica pinahualistli catli quinequij nechchihuilise catli fiero. 
\q1  
\v 5 Quen se ajacatl quihuica tlasoli, 
\q1 itequihua TOTECO ma quintojtocatiyas catli nechcualancaitaj. 
\q1  
\v 6 Ma onca tzintlayohuilotl ipan iniojhui. 
\q1 Ma tlaxixitlacas campa nemij para ma huetzica, 
\q1 huan itequihua Toteco ma quintepotztocatiyas para quinmictis. 
\q1  
\v 7 Pampa masque amo tleno nijchijtoya, 
\q1 quitlalijque se tlaquetztli para nechmasiltise. 
\q1 Quixajque se ostotl para ipan ma nihuetzi. 
\q1  
\v 8 Ma quintlatocajsi se hueyi tequipacholi. 
\q1 Ma masica ipan nopa tlaquetztli catli inijuanti quitlalijque huan ma motzontlamiltica. 
\q1  
\v 9 Huajca quena, na nipaquis ipan TOTECO. 
\q1 Nijpiyas paquilistli pampa TOTECO nechmaquixtijtos. 
\q1  
\v 10 Ica nochi noyolo niquijtos: 
\q1 “Amo aqui seyoc quen ta, TOTECO. 
\q1 Tiquinmocuitlahuía catli amo quipiyaj fuerza para masehualme catli tetique amo huelis quinajsise. 
\q1 Quena, tiquinmanahuía catli teicneltzitzi huan catli amo quipiyaj catli quinmonequilía. 
\q1 Tiquinmanahuía ininmaco catli quinequij quintlacuijcuilise.” 
\q1  
\v 11 Motlananaj masehualme catli amo cuajcualme huan nechcualancaitaj. 
\q1 Inijuanti tlatestigojquetzaj catli amo neli, 
\q1 huan nechtlaijilhuíaj ica tlamantli catli amo nijmati. 
\q1  
\v 12 Nechtlaxtlahuíaj ica catli amo cuali, 
\q1 masque nelcuali niquinchihuilijtoc. 
\q1 San quinequij nechtequipacholmacase. 
\q1  
\v 13 Pero quema inijuanti mococojque, 
\q1 nimotequipacho ininhuaya huan nimoyoyonti ica nopa fiero yoyomitl para nochi quimatise nimotequipachohuayaya ininhuaya. 
\q1 Hasta nimosajqui por inijuanti para nijtlajtlanis TOTECO ma quinchicahua. 
\q1 Pero TOTECO amo quicajqui catli niquilhui. 
\q1  
\v 14 Nimotequipachojtinemiyaya quen se tlamantli fiero ipantitosquía se nohuampox o se noicni. 
\q1 Nimotequipacho huan nichocatinemiyaya quen mictosquía nonana. 
\q1  
\v 15 Pero quema na nechajsic tequipacholi, inijuanti pajque. 
\q1 Quema nimotepotlami huan nihuetzqui, 
\q1 inijuanti mosentilijque huan nechhuetzquilijque. 
\q1 Masehualme catli amo cuajcualme huan catli nechiximatiyayaj nechejelnamiquiyayaj huan nechmaquiliyayaj masque amo tleno nijchijtoya. 
\q1  
\v 16 Quen masehualme catli amo cuajcualme quihuetzquilíaj tlen hueli, 
\q1 inijuanti noca pajque huan motlancochhuehuechotzque noixpa ica cualantli. 
\b  
\q1  
\v 17 TOTECO, ¿hasta quema noja san tijtlachilijtos nochi ni tlamantli? 
\q1 Techmanahui para amo nechmictise, 
\q1 pampa san setzi nonemilis. 
\q1 Techmaquixti tlen ni masehualme catli mochihuaj quen tecuanime catli quinequij nechhuejhuelose. 
\q1  
\v 18 Huan nimitztlascamatis tlamiyacapa ipan tlasentilistli. 
\q1 Iniixpa nochi nopa miyaqui momasehualhua nimitzpaquilismacas. 
\q1  
\v 19 Amo xiquincahuili nocualancaitacahua catli istlacatij ma noca paquica. 
\q1 Amo xiquincahuili catli nechcualancaitaj ma moixijcopilica ica paquilistli noixpa pampa nimotequipachohua. 
\q1  
\v 20 Inijuanti amo tenotzaj ica cuali. 
\q1 San moilhuíaj quenicatza huelis quincajcayahuase masehualme catli itztoque ica yejyectzi ipan ni tlali. 
\q1  
\v 21 Nechtlaijilhuíaj huan quiijtohuaj: 
\q1 “¡Xiquitaca tijnelitztoque catli fiero quichijqui!” 
\b  
\q1  
\v 22 TOTECO, ta tiquitztoc catli quichihuaj. 
\q1 Amo san xiitzto huan amo tleno tijchihuas. 
\q1 ¡Amo techtlahuelcahua! 
\q1  
\v 23 Ximotlanana huan techchihuili catli xitlahuac huan melahuac. 
\q1 Quena, TOTECO, xiisihui huan techmanahuiqui. 
\q1  
\v 24 TinoTeco Dios, ta catli ipa titetlajtolsencahua xitlahuac, 
\q1 xitenextili para amo tleno nijchijtoc. 
\q1 Amo xiquincahuili nocualancaitacahua ma noca huetzcaca. 
\q1  
\v 25 Ma amo nopanti catli inijuanti quinequij. 
\q1 Ma amo quiijtoca nechixpolojtoque. 
\q1 Amo xiquincahuili ma moilhuica para inijuanti nechtlantoque. 
\q1  
\v 26 Xijchihua para inijuanti catli noca paquij por notequipachol ma mocuapoloca huan ma ayacmo quimatica tlaque quichihuase. 
\q1 Quena, xijcahua para inijuanti catli moilhuíaj para más huejhueyi que na ma mopinahualtica huan ayacmo aqui ma quintlepanitas. 
\q1  
\v 27 Pero ma huicaca ica paquilistli inijuanti catli nechpalehuíaj. 
\q1 Ma paquica inijuanti catli quiitaj para nijchihua catli xitlahuac. 
\q1 Huan nochipa ma quiijtoca: 
\q1 “Nelía hueyi TOTECO catli quipactía quipalehuis David, 
\q1 pampa yaya quitequipanohua.” 
\q1  
\v 28 Quena, xijtlacaquili catli nimitztlajtlanía, 
\q1 huan teipa nitepohuilis para nelía xitlahuac catli tijchihua. 
\q1 Quena, semilhuitl nimitzpaquilismacas. 
\c 36  
\s1 Inintlajtlacol masehualme huan iteicnelilis TOTECO 
\q1  
\v 1 Nijpixtoc ipan noyolo catli nijnequi niteyolmelahuas tlen inintlajtlacol amo cuajcualme. 
\q1 Amo cuajcualme quielcahuaj Toteco Dios huan amo quiimacasij. 
\q1  
\v 2 Mohueyimatij ica ininseltzi hasta moilhuíaj yaya amo hueli quichihuas cuenta nochi catli fiero quichijtinemij, 
\q1 huan yeca amo quintlatzacuiltis. 
\q1  
\v 3 Quisa inincamaco senquistoc catli fiero huan catli amo melahuac. 
\q1 Quipolojtoque inintlalnamiquilis, 
\q1 huan ayacmo quichihuaj catli cuali. 
\q1  
\v 4 Quema motecaj ipan inintlapech para cochise, 
\q1 san quisencahuaj tlaque tlajtlacoli quichihuase. 
\q1 Moneltlatzquilijtoque ipan iniojhui catli fiero huan san catli amo cuali quinequij. 
\b  
\q1  
\v 5 TOTECO, motlasojtlacayo quinajsi nochi masehualme huan onajsi hasta ilhuicac huan hasta campa mixtli. 
\q1 Nelía titemachtli. 
\q1  
\v 6 Tiitztoc tlahuel tixitlahuac huan amo quema timopatla. 
\q1 Tiitztoc temachtli quen nopa huejhueyi tepeme campa tlahuel tlahuejcapa. 
\q1 Nelxitlahuac titetlajtolsencahua, 
\q1 huan amo hueli tijmachilíaj motlanejnehuilis, 
\q1 pampa eltoc quen nopa hueyi atl catli onpano huejcatla. 
\q1 ¡TOTECO! Ta san se tiquinmocuitlahuía quen masehualme huan tecuanime. 
\q1  
\v 7 Toteco Dios, nelía yejyectzi moteicnelilis catli amo quema techcahua. 
\q1 Yeca masehualme catli quipiyaj tlanahuatili huan catli teicneltzitzi monechcahuíaj campa ta para xiquinmanahui. 
\q1 Quena, mochihuaj quen pilpiyotzitzi catli calaquij ieltlapaltzala ininnana. 
\q1  
\v 8 Masehualme catli mitztemohuaj ixhuij cuali ica nopa tlatiochihualistli catli tiquinmaca nepa mochaj. 
\q1 Eltoc quen se hueyi tlacualistli catli techtencahuilía toixpa. 
\q1 Techcahuilía ma tiatlica ipan nopa atlajtli catli temaca ajhuiyac atl. 
\q1 Quena, nochi catli tijtlajtlaníaj techmaca. 
\q1  
\v 9 Pampa ta techmaca nemilistli nochi catli tiitztoque, 
\q1 huan pampa techmaca tlahuili, tojuanti tihuelij titlachiyaj. 
\q1  
\v 10 Nimitztlajtlanía para mojmostla techicneli tojuanti catli timitziximatij. 
\q1 Nochipa techchihuilía catli xitlahuac nochi tojuanti catli ipan toyolo tijnequij tijchihuase catli cuali. 
\q1  
\v 11 Amo xijcahua para ma nopan moquejquetzaca inijuanti catli mohueyimatij. 
\q1 Niyon amo xiquincahuili ma nechtojtocaca amo cuajcualme. 
\b  
\q1  
\v 12 Se tonal niquijtos: 
\q1 “¡Xiquitaca quenicatza ama huetztoque nochi tlajtlacolchijca masehualme catli mosisiníaj! 
\q1 Toteco Dios quintlahuisojtoc para ayacmo huelise motlananase.” 
\c 37  
\s1 Iniojhui cuajcualme huan amo cuajcualme 
\q1  
\v 1 Amo ximotequipacho ica amo cuajcualme. 
\q1 Niyon amo xiquixtoca catli quipiyaj masehualme catli quichihuaj catli amo monequi. 
\q1  
\v 2 Pampa nimantzi huetzise quen cuapachtli quema quitzontequij. 
\q1 Huan polihuise quen xihuitl catli huaqui. 
\q1  
\v 3 Ximotemachi ipan TOTECO huan xijchihua catli cuali. 
\q1 Quen nopa tipajcaitztos ipan motlal huan amo tleno mitzpolos. 
\q1  
\v 4 Ximohuampoxchihua ihuaya TOTECO, 
\q1 huan yaya mitzmacas catli moyolo quinequi. 
\q1  
\v 5 Xijcahuili TOTECO ma mitznextili campa tinemis. 
\q1 Ximotemachi ipan ya, huan yaya quichihuas. 
\q1  
\v 6 Quipannextis catli xitlahuac tijchihua. 
\q1 Quena, quichihuas para nochi ma quiitaca motlalnamiquilis quen nochi quiitaj quema tlahuía tonati ipan tlajcotona. 
\q1  
\v 7 Xijpiya moyolo quema tiitztoc iixpa TOTECO. 
\q1 Amo ximolini. 
\q1 Xijchiya para yaya quichihuas catli monequi. 
\q1 Amo xicualani ininhuaya catli quipiyaj nochi catli quinequij ama. 
\q1 Amo xiquinchihuili cuenta inijuanti catli quichijtinemij sesen tlamantli catli fiero quisencajtoque. 
\q1  
\v 8 Amo ximocualancamaca. 
\q1 Xijtlalcahui cualantli, 
\q1 pampa cualantli noja más hueyi mochihuas huan mitzcocos. 
\q1  
\v 9 TOTECO quintzontlamiltis catli mosisiníaj, 
\q1 pero catli motemachíaj ipan ya quintiochihuas huan moaxcatise nopa tlali. 
\q1  
\v 10 Ayacmo huejcahuas noja itztose amo cuajcualme, 
\q1 teipa masque titlachiyas campa itztoyaj, 
\q1 amo quema sempa tiquinpantis. 
\q1  
\v 11 Pero masehualme catli moicnonequij iixpa Toteco itztose ipan nopa cuali tlali huan tlahuel paquise, 
\q1 pampa yaya quintiochihuas hasta mocahuas. 
\q1  
\v 12 Masehualme catli quicualancaitaj Toteco mosenilhuijtoque tlaque fiero tlamantli huelis quinchihuilise inijuanti catli xitlahuac nemij. 
\q1 Quintlachilíaj ica cualantli huan motlanhuehuechotzaj iniixpa. 
\q1  
\v 13 Pero Toteco quinhuetzquilía nopa masehualme, 
\q1 pampa quimati para monechcahuía nopa hora quema quintzontlamiltis. 
\q1  
\v 14 Masehualme catli quicualancaitaj Toteco quicopinaj ininmachete para quintlahuisolise catli teicneltzitzi. 
\q1 Quihuitolohuaj inincuahuitol huan quinmelactlachilíaj catli moicnonequij iixpa Toteco. 
\q1 Quena, quinchiyaj para quinmictise catli xitlahuac monejnemiltíaj. 
\q1  
\v 15 Pero catli inijuanti ininmachete calaquis ipan ininyolo, 
\q1 huan inincuahuitolhua pojpostequis huan cuechtic elis. 
\q1  
\v 16 Más cuali nopa quentzi catli quipiya se cuali masehuali huan amo quen imiyaca nochi tlamantli pajpatiyo catli quipiyaj tlajtlacolchihuani. 
\q1  
\v 17 Pampa TOTECO quinquixtilis ininchicahualis catli amo itztoque tlapajpacme iixpa, 
\q1 pero quinfuerzajmacas catli monejnemiltíaj cuali iixpa. 
\q1  
\v 18 Mojmostla TOTECO quitlachilía catli quichihuaj masehualme catli itztoque xitlahuaque iixpa, 
\q1 huan nopa tlali catli quinmacas para iniaxca huejcahuas para nochipa. 
\q1  
\v 19 Quema ajsis tonali catli amo cuali, 
\q1 quinmocuitlahuis para amo más tlaijiyohuise. 
\q1 Quema oncas mayantli, quinmacas catli quicuase hasta mocahuas. 
\q1  
\v 20 Pero amo cuajcualme miquise. 
\q1 Quena, quen huaquij nopa yejyectzitzi xochime sacapetlapani huan ayacmo nesi ininyejca, 
\q1 nojquiya polihuise icualancaitacahua TOTECO. 
\q1 Quena, polihuise quen poctli catli quisa huan ayacmo nesi. 
\q1  
\v 21 Se masehuali catli amo cuali iyolo motlanehui se tlamantli huan ayacmo quicuepa. 
\q1 Pero masehualme catli cuajcualme quipiyaj hueyi ininyolo huan temacaj hasta mocahua. 
\q1  
\v 22 Catli TOTECO quintiochihua quiselise nopa tlali catli yaya quinmacas, 
\q1 pero catli TOTECO quintelchihua quintzontlamiltis. 
\q1  
\v 23 TOTECO quichihua ma eli temachtli sesen paso ipan inemilis se cuali masehuali, 
\q1 huan nopa masehuali paqui miyac pampa nemi cuali. 
\q1  
\v 24 Masque huetzis nopa cuali masehuali, amo mocahuas nepa huetztoc, 
\q1 pampa TOTECO quitlananas ica imax. 
\q1  
\v 25 Na nojquiya nitelpocatixtoya huan ama ya nihuehuentzi, 
\q1 pero amo quema niquitac TOTECO quitlahuelcahua se masehuali catli itztoc xitlahuac iixpa. 
\q1 Niyon iconehua se cuali masehuali amo niquinitztoc sintla motlaejehuíaj para ica panose. 
\q1  
\v 26 Mojmostla se cuali masehuali quintlasojtla sequinoc huan quintlanejtía catli monequi. 
\q1 Iconehua se cuali tlacatl tepalehuíaj. 
\q1  
\v 27 Huajca sintla tijnequi tiitztos para nochipa, 
\q1 xijtlalcahui tlajtlacoli huan xijchihua san catli cuali. 
\q1  
\v 28 Pampa TOTECO quipactía catli xitlahuac huan amo quema quinhuejcamajcahuas iaxcahua catli itztoque temachme. 
\q1 ¡Amo! Techmocuitlahuis para nochipa. 
\q1 Pero quintzontlamiltis nochi masehualme catli amo cuajcualme, 
\q1 huan amo quincahuilis niyon se iniixhui. 
\q1  
\v 29 Masehualme catli itztoque xitlahuaque iixpa TOTECO moaxcatise nopa tlali catli yaya quinmacas, 
\q1 huan nepa itztose para nochipa. 
\q1  
\v 30 Se masehuali catli itztoc cuali iixpa Toteco camanalti ica tlalnamiquilistli huan quiijtohua catli xitlahuac. 
\q1  
\v 31 Quipiya Icamanal Toteco Dios ipan iyolo, 
\q1 huan yeca amo huetzis ipan tlajtlacoli. 
\q1  
\v 32 Masehualme catli quicualancaitaj Toteco Dios quintlachilíaj masehualme catli monejnemiltíaj xitlahuac. 
\q1 Quitemohuaj quenicatza huelis quintelhuise para ma quinmictica. 
\q1  
\v 33 Pero TOTECO amo quincahuas para cuali masehualme ma mocahuaca ininmaco inincualancaitacahua. 
\q1 Quema ajsise iixpa se juez, 
\q1 amo quincahuas ma quintlatzacuiltica catli cuajcualme ica se tlamantli catli amo quichijtoque. 
\q1  
\v 34 Ximotemachi ipan TOTECO huan xijchihua catli yaya quinequi, 
\q1 pampa yaya mitzhuejcapantlalis huan mitzmacas nopa tlali. 
\q1 Huan tiquitas quen quintzontlamiltis catli quinpactía tlajtlacolchihuase. 
\q1  
\v 35 Pampa na niquinitztoc masehualme catli quicualancaitaj Toteco, 
\q1 inijuanti mohueyimatij huan temajmatíaj. 
\q1 Pampa quipiyaj chicahualistli quen se cuahuitl hueyi huan xajcaltic. 
\q1  
\v 36 Pero panoc se ome tonal tlantiyajque huan ayacmo niquinitac campa itztoyaj. 
\q1 Huan masque niquintemo, ayacmo niquinpanti. 
\q1  
\v 37 Pero xijtlachili quen monejnemiltía se masehuali catli itztoc xitlahuac iixpa TOTECO, 
\q1 yaya catli amo aqui hueli quitelhuis. 
\q1 Nopa masehuali quipiyas tlasejseltili huan itztos ica yejyectzi para nochipa. 
\q1  
\v 38 Pero TOTECO ica se huelta quintlamitzontlamiltis inijuanti catli amo quitlepanitaj. 
\q1 Huan amo quicajtehuase niyon se iniixhui. 
\q1  
\v 39 TOTECO quinmaquixtía catli itztoque xitlahuaque iixpa. 
\q1 Quinfuerzajmaca quema huala tlaohuijcayotl. 
\q1  
\v 40 TOTECO quinpalehuía huan quinmanahuía catli cuajcualme. 
\q1 Quinmanahuía ininmaco masehualme catli quicualancaitaj huan quinmaquixtía, 
\q1 pampa inijuanti mochixtoque ipan ya. 
\c 38  
\s1 Inetlatlajtil David quema tlajtlacolchijtoya 
\q1  
\v 1 TOTECO, amo techtlaijiyohuilti quema ticualani. 
\q1 Huan amo techtlatzacuilti ica mohueyi cualancayo. 
\q1  
\v 2 Miyac nechcocohua catli amo cuali nijchijtoc. 
\q1 Eltoc quen nochi mocuatlaminhua calactoc ipan na. 
\q1 Quena, eltoc quen techajsitoc, 
\q1 pampa nijmati ticualani nohuaya. 
\q1  
\v 3 Huan pampa ticualani por notlajtlacol, 
\q1 nijmati quen nochi notlacayo mococohua. 
\q1 Niyon se noomiyo amo cuali eltoc. 
\q1  
\v 4 Nochi notlajtlacolhua nopan huetztoc. 
\q1 Eltoc quen nimisahuisquía campa miyac atl. 
\q1 Notlajtlacolhua eltoc quen se tlamamali tlahuel etic catli amo hueli niquijiyohuía. 
\q1  
\v 5 Palani notlacayo pampa nijchijqui se huihuiyotl. 
\q1 Mijyotíaj nococohua. 
\q1  
\v 6 Nicuitlapanhuitoltic huan amo hueli nijtlanana notzonteco. 
\q1 Semilhuitl nichocatinemi por catli nijchijtoc. 
\q1  
\v 7 Nochi notlacayo tliquisa. 
\q1 Huan ya tlantinemi nochicahualis por notlajtlacol. 
\q1  
\v 8 Nimomati quen nitlatejtejtzontli. 
\q1 Niyon quentzi fuerza amo nijpiya. 
\q1 Nelía nitlaayijhuía ipan noyolo. 
\q1  
\v 9 NoTeco, ta tijmati quen nijnequi sempa niitztos cuali moixpa. 
\q1 Nochi catli nimoilhuía tlanemijya nesi moixpa. 
\q1 Amo tleno hueli nimitztlatilía. 
\q1  
\v 10 Noyolo nelhuihuipica, 
\q1 huan ya tlantinemi nochicahualis. 
\q1 Ayacmo hueli nitlachiya cuali. 
\q1  
\v 11 Nonelhuampoyohua huan noteiximatcahua san nechhuejcaitaj, pampa quiijiyaj nococohua. 
\q1  
\v 12 Inijuanti catli quinequij nechmictise quisencahuaj tlaquetztli para nechmasiltise. 
\q1 Catli quinequij nechcocose tlatoctzitzi nechilhuíaj quenicatza nechtzontlamiltise. 
\q1 Semilhuitl quitemolíaj quenicatza nechcajcayahuase. 
\q1  
\v 13 Pero na nimochihua quen amo nijcaqui catli quiijtohuaj. 
\q1 Nimochihua quen se ninono huan amo nijtlapohua nocamac para niquinnanquilis. 
\q1  
\v 14 Quena, na nimochihua quen amo nijcaqui inincamanal, 
\q1 huan amo tleno niquijtohua para ica nimomanahuis. 
\q1  
\v 15 Pampa san ipan ta nimochiya, TOTECO, tinoDios. 
\q1 Na nijcajtoc momaco para xiquinnanquili huan techmanahui. 
\q1  
\v 16 San nimitztlajtlanía para amo xiquincahuili ma noca huetzcaca. 
\q1 Amo xiquincahuili ma mohueyitlalica noixpa pampa nihuetzqui. 
\q1  
\v 17 Nijmati nimiquis pampa tlacuajcualoli amo nechcahua niyon se tlatoctzi. 
\q1  
\v 18 TOTECO, nijnequi nimitzpannextilis nochi notlajtlacolhua, 
\q1 pampa nelía nimotequipachohua ica catli nijchijtoc. 
\q1  
\v 19 Nocualancaitacahua momiyaquilijtoque huan moyoltetilijtoque. 
\q1 Miyac nechcualancaitaj, masque amo tleno niquinchihuilijtoc. 
\q1  
\v 20 Masque catli cuali niquinchihuilijtoc, nechcuepilijtoque ica catli fiero. 
\q1 Nechcualancaitaj pampa nijtoquilía catli cuali. 
\q1  
\v 21 NoTeco Dios, amo techcajtehua noseli. 
\q1 Amo ximoiyocatlali ica na. 
\q1  
\v 22 ¡Toteco! Xihuala nimantzi techpalehuiqui, ta tinotemaquixtijca. 
\c 39  
\s1 Amo huejcahuas tonemilis 
\q1  
\v 1 Nimoilhuijtoya para nimomocuitlahuisquía miyac para amo nijchihuasquía catli amo cuali. 
\q1 Niquijtojtoya para nijmocuitlahuisquía nonenepil huan nocamanal para amo nitlajtlacolchihuas ica catli niquijtohua. 
\q1 Quena, amo tleno niquijtos quema niitztos iniixpa amo cuajcualme. 
\q1  
\v 2 Huajca nimochijqui quen se ninono. 
\q1 Amo tleno niquijtohuayaya, 
\q1 niyon catli cuali, niyon catli amo cuali. 
\q1 Huan pampa nicajoctoya nochi catli nijmatiyaya ipan noyolo, 
\q1 noja más nitlaijiyohuiyaya. 
\q1  
\v 3 Hasta nijmatiyaya quen noyolo tlatlayaya. 
\q1 Huan quema san ya nopa nimosenilhuijtoya, 
\q1 nijmatiyaya quen se tlitl lemeniyaya ipan noyolo. 
\q1 Huajca ayacmo niquijiyohui huan nicamanaltic chicahuac, 
\q1 huan niquilhui TOTECO: 
\q1  
\v 4 “TOTECO, technextili quesqui tonali niitztos huan quema nimiquis. 
\q1 Nijmati nelquentzi tonali niyoltos nica. 
\q1  
\v 5 Techmacatoc se nemilistli catli nelquentzi xihuitl. 
\q1 Huan nochi xihuitl catli niyoltos elis san se tlatoctzi moixpa, 
\q1 pampa ta nochipa tiitztoc. 
\q1 Nochi masehualme polijtehuaj nimantzi san quen ixpolihui iniijiyo quema tlaijiyotilanaj. 
\q1  
\v 6 Nochi masehualme panotehuaj quen se ecahuilotl. 
\q1 San tlapic nochi inintequi. 
\q1 Masque quimiyaquilíaj tlamantli catli ipati, 
\q1 amo quimatij ajqueya iaxca elis teipa. 
\q1  
\v 7 Huajca, noTeco, amo tleno onca catli ipan huelis nimotemachis. 
\q1 Nimochiyas san ipan ta. 
\q1  
\v 8 Techmaquixti tlen notlajtlacolhua. 
\q1 Amo xiquincahuili masehualme catli huihuitique ma noca paquica ica catli nijchijtoc. 
\q1  
\v 9 Nimocamatzacuas moixpa huan ayacmo nimolinis ica catli nopanti, pampa ta techtlatzacuiltía. 
\q1  
\v 10 Pero noTeco, ayacmo techtlatzacuilti. 
\q1 Nijmati nimiquis pampa techpanajsitoc. 
\q1  
\v 11 Quema se masehuali tlajtlacolchihua, ta tijtlatzacuiltía. 
\q1 Nopa tlamantli catli más quiicnelía, 
\q1 tiquixpolihuiltía quen mejtolime quitlamicualoltíaj se yoyomitl. 
\q1 Niyon se masehuali amo quipiya chicahualistli. 
\q1 Nochi itztoque san quen se ajacatl catli ica se tlatoctzi panotehuaj. 
\q1  
\v 12 NoTeco, xijtlacaquili quema nimotlatlajtis. 
\q1 Techtlacaquili quema nimitztzajtzilía. 
\q1 Amo san xitlachixto quema nimochoquilía, techpalehuiqui. 
\q1 Quen nochi nohuejcapan tatahua, san niitztos nica se tlatoctzi. 
\q1 Quen niehuasquía seyoc altepetl huan san nipanosquía, 
\q1 amo nihuejcahuas nica. 
\q1  
\v 13 Ayacmo techtlatzacuilti. 
\q1 Techcahuili sempa ma nijpiyas fuerza huan se quentzi paquilistli pampa se tonal nimiquis huan ayacmo niitztos nica.” 
\c 40  
\s1 David quipaquilismaca TOTECO pampa quimanahui 
\q1  
\v 1 Nijpixqui noyolo huan nimochixqui para TOTECO ma nechpalehuiqui. 
\q1 Huan yaya, quena, moechcapano huan nechtlacaquili quema nijnojnotzayaya. 
\q1  
\v 2 TOTECO nechtlananqui quema nijmatiyaya niitztoya ipan se ostotl campa mahuilili. 
\q1 Eltoya quen nimisahuijtinemiyaya ipan soqui atoli catli huejcatla, 
\q1 huan ayacmo nijmatiyaya tlaque nijchihuas. 
\q1 Pero TOTECO nechmaquixti tlen nopa tequipacholi. 
\q1 Quena, nechquetzqui ipan se hueyi tetl campa temachtli. 
\q1 Huan teipa nechyacanqui ipan se cuali ojtli. 
\q1  
\v 3 Huan teipa noTeco Dios nechmacac se huicatl yancuic, 
\q1 se huicatl catli ica ma nijpaquilismacas. 
\q1 Miyac catli quicaquise nochi catli TOTECO nechchihuilijtoc, motemachise ipan ya. 
\q1  
\v 4 Paqui nopa masehuali catli motemachía ipan TOTECO. 
\q1 Huan amo motemachía ipan catli mohueyimatij, 
\q1 niyon ininpan catli quinhueyichihuaj teteyome. 
\b  
\q1  
\v 5 TOTECO noDios, ta techchihuilijtoc miyac tlamantli catli huejhueyi. 
\q1 Amo aqui quiaxilis mohueyi chicahualis. 
\q1 Ta nochipa techpixtoc ipan motlalnamiquilis. 
\q1 Quena, tlahuel miyac tlamantli catli yejyectzi tijsencajtoc techchihuilis. 
\q1 Sintla nijnequisquía niteyolmelahuas sesen tlamantli catli techchihuilijtoc, 
\q1 amo nihuelisquía. 
\q1 Pampa nochi catli cuali techchihuilijtoc onpano catli hueli nijpohua. 
\q1  
\v 6 Ya nijmati nopa catli más tijnequi para timasehualme ma timitzmacaca. 
\q1 Amo hueyi ipati moixpa nopa tlapiyalme huan sequinoc tlamantli tlacajcahualistli catli masehualme mitzmacaj. 
\q1 Amo hueyi ipati moixpa nopa tlacajcahualistli catli tijtlatíaj moixpa por totlajtlacolhua. 
\q1 Techtlapolijtoc notlalnamiquilis para hueli nijmachilía catli más tijnequi tlen tojuanti. 
\q1 Tijnequi ma timotemacaca ipan ta. 
\q1 Ya nopa, quena, hueyi ipati moixpa. 
\q1  
\v 7 Yeca nimitzilhuijtoc: 
\q1 “Nica niitztoc. 
\q1 Ya nihuala quen ijcuilijtoc nijchihuasquía ipan mocamanal. 
\q1  
\v 8 ¡NoTeco Dios! 
\q1 Nechpactía nijchihuas mopaquilis, 
\q1 huan motlamachtil nijhuica ipan noyolo.” 
\q1  
\v 9 Tlamiyacapa iniixpa momasehualhua niteyolmelajtoc para ta, TOTECO, 
\q1 tiquinchihua masehualme xitlahuaque moixpa. 
\q1 Cuali tijmati para amo san nicajoctoc catli nijmati. 
\q1  
\v 10 Amo nijtlatijtoc nopa cuali camanali ipan noyolo para amo aqui niquilhuis. 
\q1 Nochi masehualme niquinyolmelahua para ta tiquinmaquixtis. 
\q1 Nochipa nitematiltis para ta nelía titemachtli huan titepalehuía. 
\q1 Nepa tlamiyacapa nitepohuilis para titetlasojtla huan amo timoyolpatla. 
\q1  
\v 11 TOTECO, nijmati amo quema tijcahuas techtlasojtlas. 
\q1 Nimochiya ipan moteicnelijcayo, 
\q1 pampa ta nochipa techmocuitlahuis. 
\q1  
\v 12 Miyac tequipacholi nijpiya campa hueli. 
\q1 Amo hueli nijpohua nochi. 
\q1 Notlajtlacolhua nechtlantoc huan nichoca hasta amo hueli nitlachiya. 
\q1 Notlajtlacolhua nelmiyac hasta quipano imiyaca notzoncal. 
\q1 Tlantinemi noyolo huan nochicahualis. 
\q1  
\v 13 TOTECO, techmanahuiqui. 
\q1 Quena TOTECO, ximoisihuilti huan techpalehuiqui. 
\q1  
\v 14 Ma mopinahualtica huan ma mocuapoloca catli quinequij nechtzontlamiltise. 
\q1 Xiquintojtocatinemi catli nechcualancaitaj huan tlahuel xiquinpinahualti. 
\q1  
\v 15 Nochi catli noca paquij ma huetzica. 
\q1 Xiquincuepa san ininmax. 
\q1  
\v 16 Pero ma paquise miyac nochi catli mitztemohuaj. 
\q1 Quena, paquij catli mitzicnelíaj pampa tiquinmaquixtijtoc. 
\q1 Nochipa quiijtohuaj: 
\q1 “Nelía hueyi TOTECO.” 
\q1  
\v 17 Masque nimotequipachojtoc huan nechpolohua catli nechmonequilía, 
\q1 nijmati para ta TOTECO techelnamiqui. 
\q1 Ta tinoTeco Dios, techpalehuis huan techmanahuis. 
\q1 NoTeco Dios, amo xihuejcahua quema nimitznotza. 
\q1 Nimantzi techpalehuiqui. 
\c 41  
\s1 David catli mococohua quitlajtlanía Toteco ma quichicahua 
\q1  
\v 1 Paqui nopa masehuali catli motequipachohua pampa quinicnelía catli teicneltzitzi, 
\q1 pampa TOTECO quipalehuis quema hualas tlaohuijcayotl. 
\q1  
\v 2 TOTECO quimocuitlahuis para amo aqui quimictis. 
\q1 Huan TOTECO quitiochihuas tlamiyacapa ipan tlali Israel. 
\q1 Yaya amo quicajtehuas, 
\q1 niyon amo quicahuas ininmaco icualancaitacahua para ma quichihuilica catli quinequise. 
\q1  
\v 3 Quema huetztos ipan tlaijiyohuilistli, 
\q1 TOTECO quitlananas ipan itlapech huan quiijcuinilis nopa cocolistli. 
\q1  
\v 4 Na niquilhui TOTECO: 
\q1 “TOTECO, na nitlajtlacolchijtoc moca ta. 
\q1 Techtlasojtla huan techchicahua.” 
\q1  
\v 5 Nocualancaitacahua quinequij ma nechajsi catli fiero. 
\q1 Noca camanaltij huan quinequij ma nimiqui huan ayacmo aqui nechelnamiquis. 
\q1  
\v 6 Quema nechpaxalohuaj, mochihuaj quen nohuampoyohua, 
\q1 pero amo nelía catli quiijtohuaj. 
\q1 Quema itztoque nohuaya san quitlacaquilíaj tlaque onca para huelis quipatlase ica catli más fiero, 
\q1 huan teipa quisase huan teyolmelajtinemise tlen na. 
\q1  
\v 7 Quena, nocualancaitacahua mosentilíaj huan noca camanaltij. 
\q1 Tepohuilíaj para ayacmo onca pajtli para na huan nimantzi nimiquis. 
\q1  
\v 8 Quiijtohuaj: 
\q1 “Nopa cocolistli catli yaya quipixtoc nelfiero. 
\q1 Ayacmo motlananas tlen itlapech pampa nimantzi miquis.” 
\q1 Quej nopa quiijtohuaj tlen na. 
\q1  
\v 9 Nojquiya nechcajtejtoc catli eliyaya nonelhuampox. 
\q1 Yaya catli ipan nimotemachiyaya huan catli tlacuayaya nohuaya, ama nechtlahuelcajtoc. 
\q1  
\v 10 Pero ta TOTECO, techtlasojtla. 
\q1 Techtlanana tlen notlapech huan niquincuepilis quen nechchihuilijtoque. 
\q1  
\v 11 Nijmati techicnelía pampa amo tiquincahuilijtoc nocualancaitacahua ma nechtlanica. 
\q1  
\v 12 Techpalehui pampa nijchihua catli xitlahuac huan techmacatoc tequiticayotl ma niitzto nepa moixpa para nochipa. 
\b  
\q1  
\v 13 Ma tijhueyichihuaca TOTECO, 
\q1 yaya catli iTeco tohuejcapan tata, Israel. 
\q1 Quena, ma tijhueyichihuaca ama huan nochipa. Quej nopa ma eli. 
\c 42  
\s1 Israelitame catli quinhuicatoque seyoc tlali quielnamiquij inintlal 
\q1  
\v 1 Quen se masatl catli tlahuel amiqui quitemojtinemi se atlajtli para atlis, 
\q1 quej nopa na nimitzyoltemohua, noTeco Dios. 
\q1  
\v 2 Quena, quen se catli tlahuel amiqui, 
\q1 na ipan noyolo nimitznequi Toteco, 
\q1 ta catli nelnelía tiitztoc. 
\q1 ¿Hasta quema huelis niyas huan nimonextis moixpa? 
\q1  
\v 3 Yohuali huan tonali nichoca huan amo nitlacua. 
\q1 Nocualancaitacahua tlatoctzitzi nechtlatzintoquilíaj: 
\q1 “¿Canque itztoc moDios? 
\q1 ¿Para tlen amo mitzpalehuía?” 
\q1 Quen nopa nechilhuíaj. 
\b  
\q1  
\v 4 Quema niquelnamiqui quen eliyaya achtihuiya nepa ipan notlal, eltoc quen atiya noyolo. 
\q1 Niyohuiyaya ininhuaya miyaqui masehualme hasta ichaj Toteco Dios. 
\q1 Na niquinyacanayaya nochime hasta ichaj ipan nopa hueyi ilhuitl. 
\q1 Titzajtzitiyohuiyayaj ica paquilistli, 
\q1 huan tijtlascamatiyayaj Toteco Dios pampa para ya tiilhuichihuayayaj. 
\q1  
\v 5 Huajca nimoilhuía: 
\q1 “Amo monequi nimotequipachos. 
\q1 Na nimotemachijtoc ipan noTeco Dios, 
\q1 huan sempa nijpaquilismacas, 
\q1 pampa yaya noDios huan notemaquixtijca.” 
\b  
\q1  
\v 6 Pero noTeco, nelía nimotequipachohua nica campa niitztoc ipan ni tlali catli huejca. 
\q1 Yeca nimitzelnamiquis, 
\q1 huan niquelnamiquis quen tijpixqui hueyi moyolo tohuaya catli tiehuaj ipan motlal. 
\q1 Niquelnamiqui nopa tlali yejyectzi catli pehua campa motlalohua nopa atlajtli Jordán, 
\q1 huan ontlami hasta campa motlanantoc nopa tepeme Hermón huan Mizar. 
\q1  
\v 7 Ama ta techtitlanilijtoc tequipacholi catli nechijiyomictía. 
\q1 Quena, miyac tequipacholi nechajsitoc quen imiyaca atl catli huetzi tlen tepeixco hasta ipan na. 
\q1 Caquisti quen miyac atl catli tlacomontoc, 
\q1 huan nochi nopa atl panotoc ipan na. 
\b  
\q1  
\v 8 Pero ica ijnaloc TOTECO nechtitlanilis itlaicnelilis. 
\q1 Huan ica tlayohua yaya nechmacas se huicatl para nijhueyichihuas, 
\q1 huan nimotlatlajtía ica ya. 
\q1 Quena, nijnojnotza NoTeco catli mojmostla nechmaca nemilistli. 
\q1  
\v 9 Niquilhuis Toteco Dios: 
\q1 “Ipan ta nimotlatía huan amo aqui hueli nechajsis. 
\q1 ¿Para tlen techelcajtoc? 
\q1 Na san nimotequipachojtinemi, 
\q1 pampa nocualancaitacahua nechtlaijiyohuiltíaj. 
\q1  
\v 10 Catli nocualancaitacahua nechchihuilíaj nechcocohua hasta ajsi ipan noomiyohua, 
\q1 pampa nechtlaijilhuíaj huan nechtlatzintoquilíaj tlatoctzitzi: 
\q1 ‘¿Canque itztoc moDios? 
\q1 ¿Para tlen amo mitzpalehuía?’ ” 
\q1  
\v 11 Pero amo monequi nimocuesihuilmacas, 
\q1 niyon nimotequipachos. 
\q1 Na nimotemachijtoc ipan noTeco Dios, 
\q1 huan teipa sempa nijpaquilismacas pampa yaya noDios huan noTemaquixtijca. 
\c 43  
\s1 Se netlatlajtili catli quitlajtlanía Toteco ma quincuepa ipan inintlal 
\q1  
\v 1 NoTeco Dios, techtlajtolsencahua xitlahuac huan xitenextili para amo tleno nijchijtoc. 
\q1 Techmanahui tlen ni istlacatica masehualme huan amo cuajcualme catli nechtelhuíaj. 
\q1  
\v 2 Pampa san ta tinoTeco huan tinoDios huan notlamanahuijca na. 
\q1 ¿Para tlen techtlahuelcajtoc? 
\q1 Nimotequipachojtinemi huan más nechtlaijiyohuiltíaj nocualancaitacahua, 
\q1 huan amo tleno tijchihua. 
\q1  
\v 3 Toteco Dios, techyacana ica motlahuil huan technextili catli melahuac. 
\q1 Quej nopa, quena, huelis nimocuepas motlal huan campa motepe catli tlatzejtzeloltic campa ta tiitztoc ipan mocaltiopa. 
\q1  
\v 4 Quena, noTeco Dios, nicalaquis huan niajsiti hasta motlaixpa campa masehualme mitzhueyichihuaj. 
\q1 Nepa nimitzpaquilismacas ica arpa, ta catli techmaca paquilistli, 
\q1 pampa ta tinoTeco Dios. 
\q1  
\v 5 San tlapic nimotequipachos. 
\q1 Na nimotemachijtoc ipan ta, noTeco Dios, huan sempa nimitzpaquilismacas, 
\q1 pampa, ta tinoDios, huan tinotemaquixtijca. 
\c 44  
\s1 Se tlacatl quitlajtlanía Toteco ma quimocuitlahuis 
\q1  
\v 1 Toteco Dios, tijcactoque tlaque techpohuilijtoque tohuejcapan tatahua tlen ta, 
\q1 huan nochi nopa tlamantli catli tiquinchihuili huejcajya. 
\q1  
\v 2 Quena, Toteco Dios, ica mohueyi chicahualis ta tiquintojtocac nopa fiero masehualme catli quinhueyichihuayayaj teteyome ipan nopa tlali, 
\q1 huan nopa tlali tiquinmacac totatahua. 
\q1 Quena, tiquintlatzacuilti ne sequinoc huan tiquinpalehui tohuejcapan tatahua para ma momiyaquilica, 
\q1 huan ma moaxcatica. 
\q1  
\v 3 Tohuejcapan tatahua amo quitlanque nopa tlali ica ininmachete, niyon ica ininchicahualis. 
\q1 Tlatlanque ica nopa hueyi chicahualistli catli ta tijpiya ipan monejmac, 
\q1 huan pampa hueyi moyolo ininhuaya, 
\q1 huan achi más tiquinicnelía. 
\q1  
\v 4 Ta tinotlanahuatijca huan tinoTeco Dios. 
\q1 Ta tiquinmanahuía huan tijchihua ma tlatlanica momasehualhua. 
\q1  
\v 5 Quena, ica motlapalehuil tiquintlanise tocualancaitacahua. 
\q1 Huan ica mochicahualis ininpan timoquejquetzase catli techhuilanaj. 
\q1  
\v 6 Pampa amo timotemachíaj ipan tocuahuitol huan tomachete para ma techmanahuica huan titlatlanise. 
\q1  
\v 7 Eltoc ta, Toteco, catli tijchihua ma tiquintlanica tocualancaitacahua. 
\q1 Ta tiquinpinahualtijtoc nochi catli techcualancaitaj. 
\q1  
\v 8 Mojmostla timitzpaquilismacase tinoTeco Dios. 
\q1 Huan timitzhueyichihuase ica huicatl para nochipa. 
\q1  
\v 9 Pero amantzi eltoc quen techtlahuelcajtoc huan techpinahualtijtoc. 
\q1 Niyon ayacmo tinemi ininhuaya tosoldados quema tiontlahuilanaj. 
\q1  
\v 10 Tijchijqui ma ticholoca iniixpa tocualancaitacahua. 
\q1 Quena, inijuanti catli techcualancaitaj techtlachtequilíaj huan quihuicaj nochi catli quinequij. 
\q1  
\v 11 Techtemactilijtoc quen tipilborregojtzitzi catli san quichiyaj para quinhuicase campa quinmictise. 
\q1 Huan techsemantoc campa hueli ipan sequinoc tlalme campa quinhueyichihuaj teteyome. 
\q1  
\v 12 Technemacatoc timomasehualhua ica nelquentzi quen amo tleno topati elisquía. 
\q1  
\v 13 Nochi masehualme ipan nopa tlalme catli itztoque tonechca quiitaque catli techchihuilijtoc. 
\q1 Yeca techtlaijilhuíaj huan toca paquij. 
\q1  
\v 14 Tijchijtoc para inijuanti catli quinhueyichihuaj tlaixcopincayome ma toca huetzcaca. 
\q1 Nochi quema techitaj, motzonojoliníaj. 
\q1  
\v 15 Mojmostla toixpa eltoc nopa pinahualistli hasta tijnequisquíaj timoixtzacuase, 
\q1  
\v 16 pampa techtlaijilhuíaj huan techhuetzquilíaj nopa motlacuepilijca masehualme. 
\q1 Quena, techpinahualtíaj tocualancaitacahua. 
\q1  
\v 17 Nochi ni tlamantli topantitoc, 
\q1 masque amo timitzelcajtoque, 
\q1 niyon amo timoiyocacajtoque tlen nopa camanal sencahuali catli tijchijqui ininhuaya tohuejcapan tatahua. 
\q1  
\v 18 Amo timoiyocatlalijtoque tlen ta, 
\q1 niyon amo tijcajtejtoque moojhui. 
\q1  
\v 19 Pero techtlahuelcajtoc campa amo aqui itztoc, 
\q1 campa san itztoque tlapiyalme catli mosisiníaj. 
\q1 Techcajtoc ipan se tzintlayohuilotl catli eltoc quen miquilistli. 
\q1  
\v 20 Toteco Dios, sintla timitzelcajtosquíaj, 
\q1 o tijhueyichijtosquíaj se totlaixcopincayo, 
\q1  
\v 21 ta tijmajtosquía, 
\q1 pampa ta tijmati nochi catli ichtacatzi eltoc ipan yolojtli. 
\q1 Pero amo tijchijtoque, Toteco. 
\q1  
\v 22 Pero masque amo tleno tijchijtoque, 
\q1 por ta tiitztoque nechca miquilistli. 
\q1 Techchihuaj quen tipilborregojtzitzi catli san quichiyaj ajqueya quinmictis pampa timoaxcahua. 
\q1  
\v 23 ¡Toteco ximotlanana! 
\q1 ¡Amo xicochi! 
\q1 Amo ximoiyocatlali tlen tojuanti para nochipa. 
\q1  
\v 24 ¿Para tlen timoixtlatía? 
\q1 Eltoc quen tiquelcajtoc para tojuanti titlaijiyohuíaj huan miyac techcualancaitaj. 
\q1  
\v 25 Techtlahuisojtoque hasta tlalchi. 
\q1 Toixayac mocahua ipan tlaltejpoctli huan amo hueli timotlananase. 
\q1  
\v 26 ¡Ximotlanana, Toteco! 
\q1 Techpalehuiqui. 
\q1 Techmaquixti pampa tlahuel techicnelía. 
\c 45  
\s1 Se huicatl para ma huicaca quema nopa tlanahuatijquetl mosihuajtía 
\q1  
\v 1 Notlalnamiquilis temitoc ica camanali catli yejyectzitzi. 
\q1 Niquijcuilos ni huicatl para ma tijhuicatica totlanahuatijca. 
\q1 Tlahuel nijnequi nitepohuilis ni huicatl catli nijsencajtoc, huan ya ni quiijtohua: 
\q1  
\v 2 Ta más tiyejyectzi tlen nochi sequinoc telpocame, 
\q1 huan yejyectzi catli tiquijtohua, 
\q1 pampa Toteco Dios mitztiochijtoc para nochipa. 
\q1  
\v 3 Ximocualtlalili momachete para titlahuilanas, 
\q1 ta catli nelía amo timajmahui. 
\q1 Nelía tinesi tiyejyectzi pampa ta titlanahuatijquetl catli más hueyi. 
\q1  
\v 4 Xicahuayojtlejco huan xitlatlaniti ica nochi mohueyitilis. 
\q1 Ta tiquinmanahuía catli teicneltzitzi huan catli quichihuaj catli melahuac. 
\q1 Titetlajtolsencahua xitlahuac. 
\q1 Nelía huejhueyi tlamantli tijchihua. 
\q1  
\v 5 Tlatentili nopa cuatlamintli catli tijhuica, 
\q1 huan quinajsis ininyoltipa mocualancaitacahua quema tiquinmelactlachilis, 
\q1 huan tiquinmajcahuilis. 
\q1 Ma huetzica moicxitla nochime tlen campa hueli tlalme campa quintlepanitaj teteyome. 
\q1  
\v 6 Toteco Dios, titlanahuatis para nochipa huan amo quema tlamis. 
\q1 Quena, motlanahuatilis elis senquistoc xitlahuac. 
\q1  
\v 7 Tiquicnelía catli melahuac huan tijcualancaita catli amo cuali. 
\q1 Yeca Toteco Dios, yaya catli moTeco mitztequitlalijtoc titlanahuatijquetl, 
\q1 huan mitzmacatoc más paquilistli huan más tlatlepanitacayotl, 
\q1 que nochi sequinoc tlanahuatiani. 
\q1  
\v 8 Nochi moyoyo mijyotía ica nopa tlaajhuiyacayotl mirra, áloe huan canela. 
\q1 Huan mitzpaquilismacaj ica tlatzotzonali nepa ipan mochaj campa quiyejyectlalijtoque nochi tlapepecholi ica tlamantli catli tlahuel yejyectzitzi huan pajpatiyo. 
\q1  
\v 9 Iniichpocahua sequinoc tlanahuatiani quipiyaj nopa hueyi tlatlepanitacayotl para mitztequipanose. 
\q1 Huan ica monejmac mosehuijtoc nopa ichpoca tlanahuatijquetl catli elis mosihua catli quiyectlalijtoque ica oro catli onca tlali Ofir. 
\b  
\q1  
\v 10 Xijtlacaquili ichpocatl. 
\q1 Quena, xijtlacaquili cuali, nocone, 
\q1 catli nimitzilhuis: 
\q1 “Ayacmo xiquintoquili motatahua, 
\q1 moicnihua huan nochi catli timomajtoya tijchihua. 
\q1  
\v 11 Nopa tlanahuatijquetl tlahuel mitzcualita, 
\q1 huan nelía paqui ica moyejyejca. 
\q1 Huajca monequi tijneltoquilis pampa ama ya moTeco. 
\q1  
\v 12 Hualase mitzpaxaloquij iichpocahua nopa tlanahuatijquetl tlen altepetl Tiro. 
\q1 Quena, catli más tominpixtoque ipan nopa altepetl hualase huan mitztlanemactiquij. 
\q1 Ya ni quichihuase pampa quinequise ximohuampoxchihua ininhuaya.” 
\b  
\q1  
\v 13 Nopa ichpoca monamictijquetl mocualtlalía ipan ichaj ica catli más yejyectzi. 
\q1 Yaya iichpoca se tlanahuatijquetl huan ama mocuilis ne tlanahuatijquetl catli hueyi. 
\q1 Onpano yejyectzi nopa ichpocatl ica iyoyo catli nelcuajcualtzi catli tlajtzontli ica oro. 
\q1  
\v 14 Quena, yejyectzi quiyoyontijtoque ica iyoyo tlajtzontli huan ama quihuicase iixpa nopa tlanahuatijquetl catli ihuaya monamictis. 
\q1 Itepotzco yase iichpocapoyohua catli quinnotztoc. 
\q1  
\v 15 Ica hueyi paquilistli calactiyohuij ipan nopa hueyi cali campa ichaj nopa tlanahuatijquetl. 
\b  
\q1  
\v 16 Tlanahuatijquetl, se tonal tiquinpiyas moconehua, 
\q1 huan tiquinmacas tequiticayotl para tlanahuatise quen mohuejcapan tatahua mitzmacaque. 
\q1 Quena, teipa tiquinpiyas motelpocahua catli mitzpalehuise. 
\q1 Huan tijchihuas ma tlanahuatica hasta campa hueli techaj ipan nochi motlal. 
\q1  
\v 17 Huan na ica ni huicatl catli niquijcuilojtoc para ta, 
\q1 Toteco Dios, quichihuas para masehualme ma mitzelnamiquise sesen xihuitl catli panotiyas. 
\q1 Quena, masehualme ipan tlen hueli tlali camanaltise para nochipa tlen nopa huejhueyi tlamantli catli ta tijchijqui. 
\c 46  
\s1 Tiitztoque imaco Toteco Dios 
\q1  
\v 1 Toteco Dios ya totlamanahuijca huan tochicahualis. 
\q1 Nimantzi techpalehuía quema onca tlaohuijcayotl. 
\q1  
\v 2 Yeca amo timajmahuise masque ni tlaltipactli tlamisosolihuis, 
\q1 huan masque misahuise tepeme hasta itzintla nopa hueyi atl. 
\q1  
\v 3 Ma tlacomonijto nopa hueyi atl huan ma posoni miyac. 
\q1 Ma mojmolinica tepeme, pero amo nechmajmatis. 
\q1  
\v 4 Oncas se atlajtli catli quinmacas paquilistli inijuanti catli itztose ipan ialtepe Toteco. 
\q1 Huan nepa campa más tlatzejtzeloltic itztoc Toteco Catli Más Hueyi. 
\q1  
\v 5 Toteco Dios mocahua ipan nopa altepetl, 
\q1 huan amo aqui huelis quisosolos. 
\q1 Quema hualase icualancaitacahua, 
\q1 Toteco Dios amo huejcahuas, nimantzi quipalehuis ialtepe. 
\q1  
\v 6 Masque tlahuejchihuaj masehualme ipan campa hueli tlalme catli amo quiiximatij Toteco, 
\q1 huan masque tlanahuatiani huan ininmasehualhua tzajtzij ica cualantli, 
\q1 amo tleno hueli quichihuase. 
\q1 Quema Toteco Dios camanaltis, 
\q1 quicaquise itoscac catli caquisti quen tlatomoni, 
\q1 huan inijuanti motlancuaquetzase iixpa ica majmajtli. 
\q1 Huan ica icamanal ni tlaltipactli atiyas. 
\q1  
\v 7 TOTECO Catli Quinyacana Itequihuajcahua Ma Tlatlanitij itztoc tohuaya. 
\q1 Yaya catli techmocuitlahuía ama, 
\q1 yaya iTeco tohuejcapan tata Jacob catli huejcajya itztoya. 
\q1  
\v 8 Xihualaca xiquitaquij nochi nopa huejhueyi tlamantli catli TOTECO quichijtoc. 
\q1 Quitlamisosolojtoc tlaltipactli huan ama tlatzitzicatoc mocajqui. 
\q1  
\v 9 Yaya quiquetza nochi tlahuilancayotl hasta campa ontlantoc nochi tlaltipactli. 
\q1 Quipostectoc nochi cuahuitoli huan quisosolo nochi tlamantli para ica tlahuilanase masehualme. 
\q1 Huan quintlatijtoc nochi tlahuilanca carros. 
\q1  
\v 10 Huan yaya quiijtohua: 
\q1 “Ayacmo ximolinica. 
\q1 Ximomacaca cuenta para na niamoTeco Dios. 
\q1 Na niquinnahuatía nochi masehualme ipan campa hueli tlali. 
\q1 Nochi catli itztoque ipan ni tlaltipactli nechhueyitlalise.” 
\q1  
\v 11 Itztoc tohuaya TOTECO Catli Quinyacana Itequihuajcahua Ma Tlatlanitij. 
\q1 Yaya catli iTeco tohuejcapan tata Jacob catli huejcajya itztoya, yaya catli techmocuitlahuía ama. 
\c 47  
\s1 Toteco Dios yaya nopa Tlanahuatijquetl tlen nochi ni tlaltipactli 
\q1  
\v 1 Nochi anmasehualme ximomatlajtlaxcaloca. 
\q1 Xijpaquilismacaca Toteco Dios huan xihuicaca chicahuac. 
\q1  
\v 2 Pampa TOTECO yaya catli más hueyi huan temajmati. 
\q1 Yaya nopa hueyi tlanahuatijquetl catli quinahuatía nochi ni tlaltipactli. 
\q1  
\v 3 Quintzontlamilti pilaltepetzitzi toixpa huan quitlalijtoc nochi tlalme tomaco para tiquinnahuatise. 
\q1 Yeca tojuanti tlahuel tipaquij. 
\q1  
\v 4 Yaya quitlapejpenijtoc ni tlali para techaxcatis. 
\q1 Techmaca catli más cuali pampa techicnelía tojuanti tiimasehualhua. 
\q1  
\v 5 Toteco Dios tlejcotoc campa tlanahuatía. 
\q1 Nochi tzajtziyayaj ica paquilistli huan tlapitzayayaj ica tlapitzali quema TOTECO calaquiyaya. 
\q1  
\v 6 Xihuicaca tiohuicatl para ma tijpaquilismacaca Toteco Dios. 
\q1 Xijhuicatica pampa yaya totlanahuatijca. 
\q1  
\v 7 Toteco Dios, yaya nopa tlanahuatijquetl catli quinahuatía nochi ni tlaltipactli. 
\q1 Xijcualtlalica se huicatl catli yejyectzi huan xijhuicatica. 
\q1  
\v 8 Toteco Dios mosehuijtoc ipan isiya tlatzejtzeloltic, 
\q1 huan tlanahuatía ipan nochi tlalme. 
\q1  
\v 9 Nopa huejhueyi masehualme catli quipiyaj tlanahuatili ipan campa hueli tlali ipan ni tlaltipactli mosansejcotilíaj tohuaya. 
\q1 Quinequij para ma san sejco tijhueyichihuase Toteco Dios, 
\q1 yaya catli iTeco Abraham catli huejcajya itztoya. 
\q1  
\v 10 Iaxca ya nochi tlanahuatiani huan ininsoldados campa hueli ipan tlaltipactli, 
\q1 huan inijuanti quihueyitlepanitaj. 
\c 48  
\s1 Sion, ialtepe TOTECO 
\q1  
\v 1 ¡Tlahuel hueyi TOTECO! 
\q1 Quena, quinamiqui para tijpaquilismacase Toteco Dios catli itztoc ipan ialtepe huan ipan itepe catli tlatzejtzeloltic. 
\q1  
\v 2 Nelía yejyectzi nopa tepetl Sion huan ijcatoc tlahuejcapa ipan nopa altepetl. 
\q1 Nopona mosehuía Jerusalén, ialtepe Toteco Dios, 
\q1 nopa hueyi tlanahuatijquetl. 
\q1  
\v 3 Toteco Dios iseltzi itztoc ipan nopa huejcapantic cali campa monequi moquetzas catli tlachixtoc para quimanahuis altepetl Jerusalén. 
\q1 Tenextilijtoc para yaya catli quimanahuía huan quimocuitlahuía. 
\q1  
\v 4 Tlanahuatiani tlen campa hueli itztoque ipan ni tlaltipactli mosentilijque para san sejco quihuilanase nopa altepetl. 
\q1  
\v 5 Pero quema quiitaj ajqueya quimocuitlahuía nopa altepetl huan para nelía hueyi ichicahualis, 
\q1 momajmatíaj. 
\q1 Huan nimantzi cholojtehuaj huan mocuepaj campa hualajtoque. 
\q1  
\v 6 Quena, quinitzquía se majmajtli huan nelía tlaijiyohuíaj, 
\q1 quen se sihuatl quema conepiya, 
\q1  
\v 7 o quen se ajacatl chicahuac catli quinsosolohua nopa huejhueyi barcos catli hualahuij tlali Tarsis. 
\q1  
\v 8 Ipa tijcactoque quenicatza TOTECO quimocuitlahuía ialtepe, 
\q1 huan ama tiquitztoque. 
\q1 Quena, nopona itztoc TOTECO Catli Quinyacana Itequihuajcahua Ma Tlahuilanatij. 
\q1 Quitlalijtoc para ialtepe Jerusalén ma huejcahuas para nochipa. 
\b  
\q1  
\v 9 Toteco Dios, quema tiitztoque ipan motiopa, 
\q1 tiquelnamiquij huan timonejnehuilíaj quenicatza techicnelía. 
\q1  
\v 10 Toteco, campa hueli masehualme mitzpaquilismacaj, 
\q1 pampa quicactoque quenicatza mohueyitilis. 
\q1 Quicactoque hasta campa ontlami tlaltipactli. 
\q1 Huan quimatij para ica mohueyi chicahualis titetlajtolsencahua xitlahuac. 
\q1  
\v 11 Huajca ma paquica nopa masehualme ipan tepetl Sion. 
\q1 Ma huitonica ica paquilistli nochi catli ehuaj ipan altepeme tlen tlali Judá pampa cuali huan xitlahuac titetlajtolsencahua. 
\q1  
\v 12 Nochi amojuanti catli animasehualhua Toteco Dios, 
\q1 xiyaca xijyahualotij nopa altepetl Jerusalén, 
\q1 huan xijpohuaca quesqui tepancali huejhueyi quipiya campa soldados tlamocuitlahuíaj. 
\q1  
\v 13 Xijtlachilitij nopa hueyi ichaj nopa tlanahuatijquetl, 
\q1 huan ximomacaca cuenta quenicatza tlatzajtzactoque huan quiyectlalijtoque, 
\q1 para quej nopa huelis anquinpohuilijtiyase amoteipan ixhuihua. 
\q1  
\v 14 Pampa ni Toteco Dios, yaya elis toDios para nochipa, 
\q1 huan amo quema tlamis ichicahualis. 
\q1 Yaya techyacanas mojmostla hasta más nepa quema ya timictose. 
\c 49  
\s1 Quichihuaj se huihuiyotl catli motemachíaj ipan inintomi 
\q1  
\v 1 Cuali xijtlacaquilica ya ni, 
\q1 amojuanti catli campa hueli anitztoque ipan ni tlaltipactli. 
\q1  
\v 2 Nocamanal elis para nochime. 
\q1 Elis para catli tominpixtoque huan para catli teicneltzitzi. 
\q1 Elis para catli quipiyaj tequiticayotl huan para catli amo quipiyaj tequiticayotl. 
\q1 Huajca xijtlacaquilica. 
\q1  
\v 3 Nicamanaltis ica tlalnamiquilistli. 
\q1 Nimechpohuilis nochi catli nimonejnehuilijtoc ipan noyolo. 
\q1  
\v 4 Achtihui nimechilhuis se tlatzintoquili catli totlalnamijca huejcapan tatahua quiijtojque, 
\q1 huan nitlatzotzonas ica se arpa huan nihuicas para nimechmatiltis tlaque quinequi quiijtos: 
\q1  
\v 5 ¿Para tlen monequi nimomajmatis quema hualas tlaohuijcayotl, 
\q1 huan quema nopa tlajtlacolchijca masehualme catli nechcualancaitaj hualase nechyahualoquij? 
\q1  
\v 6 Inijuanti motemachiyaj ipan inintomi, 
\q1 huan mohueyimatij pampa quipiyaj miyac tlamantli catli pajpatiyo. 
\q1  
\v 7 Pero niyon se tlen inijuanti amo huelis momaquixtis tlen itlajtlacolhua, 
\q1 niyon amo huelis quimaquixtise se iniicni. 
\q1 Amo aqui huelis quitlaxtlahuis Toteco Dios para ma quimaquixtis. 
\q1  
\v 8 Pampa tonemilis eltoc se tlamantli catli miyac ipati. 
\q1 Amo onca niyon se tomi ipan nochi tlaltipactli catli ica huelis moixtlahuas. 
\q1  
\v 9 ¡Amo! Amo aqui huelis quicohuas inemilis para itztos para nochipa huan para amo quema miquis. 
\q1  
\v 10 Nochi masehualme miquise. 
\q1 Catli tlalnamiquij huan catli mohueyimatij, 
\q1 huan nojquiya nochi catli huihuitique, 
\q1 san se ininpantis. 
\q1 Mictehuaj huan quicajtehuaj nochi catli pajpatiyo quipiyayayaj. 
\q1 Huan sequinoc moaxcatise. 
\q1  
\v 11 Inijuanti moilhuíaj itztose para nochipa, 
\q1 yeca quicualtlalíaj ininchajchaj huan quitlalíaj inintoca ipan inintlal, 
\q1 quen elisquía iniaxca para nochipa. 
\q1  
\v 12 Pero se masehuali amo huejcahuas masque nelía tominpixtoc, 
\q1 pampa nojquiya miqui san se quen se cuatitlan tlapiyali. 
\q1  
\v 13 Nochi masehualme catli motemachijtoque san ipan ininseltzitzi, 
\q1 quipantise miquilistli. 
\q1 Huan nojquiya miquise nopa masehualme catli quintoquilíaj huan quihueyitlalíaj inincamanal. 
\q1  
\v 14 Nopa masehualme miquise quen miquij borregojme. 
\q1 Quena, miquilistli quinchiya nochime. 
\q1 Pero se tonal nopa masehualme catli itztoque xitlahuaque iixpa Toteco Dios quinnahuatise masehualme catli amo cuajcualme. 
\q1 Quej nopa elis quema ya palantose inintlacayohua nopa masehualme ostoijtic. 
\q1 Huajca quena, ipan nopa tonali nopa tominpiyani quicajtejtose huejca ininchajchaj catli yejyectzitzi. 
\q1  
\v 15 Pero Toteco Dios nechmaquixtis tlen ichicahualis miquilistli huan nechhuicas ihuaya. 
\q1  
\v 16 Amo ximotequipacho sintla se masehuali moricojchihua, 
\q1 huan mojmostla más quiyecchijchihua ichaj. 
\q1  
\v 17 Pampa quema miquis amo tleno huelis quihuicas. 
\q1 ¡Amo! Quema quitemohuise itlacayo ostoijtic, 
\q1 niyon quentzi catli yejyectzi quipixqui amo huelis yas ihuaya. 
\q1  
\v 18 Masque se masehuali itztos ica paquilistli quema noja yoltoc, 
\q1 huan sequinoc quitlepanitase pampa moricojchijtoc, 
\q1  
\v 19 ajsis se tonal quema miquis quen ihuejcapan tatahua, 
\q1 huan ayacmo quema quiitas tlahuili. 
\q1  
\v 20 Se masehuali catli moricojchijtoc, 
\q1 pero amo quielnamiqui para amo huejcahuas inemilis ipan ni tlaltipactli, 
\q1 mictehuas san se quen se cuatitlan tlapiyali. 
\c 50  
\s1 Toteco Dios techilhuía quenicatza ma tijhueyichihuaca 
\q1  
\v 1 Yaya TOTECO Catli Más Quipiya Chicahualistli que nochi catli quintocaxtíaj dioses, 
\q1 quinnotztoc nochi masehualme catli itztoque campa hueli ipan ni tlaltipactli. 
\q1 Quinnotza catli itztoque hasta campa hualquisa tonati huan hasta campa oncalaqui. 
\q1  
\v 2 Toteco Dios ica iyejyejca petlani huan tlahuía tlen Sion, 
\q1 nopa tepetl campa ijcatoc icaltiopa catli senquistoc yejyectzi. 
\q1  
\v 3 Toteco Dios hualas ica chicahualistli, 
\q1 huan iixpa hualas se hueyi tlitl catli quisosolojtihualas nochi catli quipantis. 
\q1 Tlatomonilotl huan tlapetlanilotl quiyahualohua. 
\q1  
\v 4 Toteco Dios quinnotza nochi catli itztoque ipan ilhuicactli huan ipan tlaltipactli, 
\q1 para ma quihualtlachilica quenicatza quintlajtolsencahuas imasehualhua. 
\q1 Quiijtohua: 
\q1  
\v 5 “Xiquinsentilica nomasehualhua catli moiyocacajtoque noca na. 
\q1 Quena, ma hualaca nochi inijuanti catli quichijtoque camanal sencahuali nohuaya, 
\q1 quema nechmacaque tlacajcahualistli huan quiijtojque para nechtoquilisquíaj.” 
\q1  
\v 6 Nochi ilhuicactli tepohuilía para Toteco Dios itztoc xitlahuac. 
\q1 Huan para yaya nopa juez catli tetlajtolsencahuas. 
\b  
\q1  
\v 7 “Xijtlacaquilica nochi annomasehualhua, 
\q1 xijcaquica nochi catli niquijtos. 
\q1 Nimechtelhuis tlamiyacapa ica nochi tlamantli catli anquichijtoque, 
\q1 pampa na niDios huan niamoTeco. 
\q1  
\v 8 Amo nimechajhuas pampa amo antechmacaj tlacajcahualistli, 
\q1 niyon pampa amo anquinmictíaj tlapiyalme huan anquintlatíaj noixpa, 
\q1 pampa quena, ya nopa anquichihuaj. 
\q1  
\v 9 Pero amo ya nopa catli nijnequi. 
\q1 Para na amo monequi techmacaca tlacajcahualistli, 
\q1 quen becerros huan oquich chivojme catli hualahuij amopotrero. 
\q1  
\v 10 Pampa na noaxcahua nochi tlapiyalme ipan cuatitlamitl huan nochi huacaxme catli campa hueli tlacuajtinemij ipan senquistoc nochi tlachiquilme. 
\q1  
\v 11 Niquiniximati nochi totome campa hueli huan nochi tlapiyalme catli nemij cuatitla, pampa noaxcahua. 
\q1  
\v 12 Sintla nimayanasquía, amo nimechtlajtlanisquía techtlamacaca, 
\q1 pampa ni tlaltipactli huan nochi catli eltoc ipani noaxca. 
\q1  
\v 13 ¿Anmoilhuíaj nimotlamaca ica torojme ininnacayo, 
\q1 huan niquiji inieso oquich chivojme? 
\q1 ¡Amo! 
\q1  
\v 14 Nijnequi techtlascamatilica ica nochi catli nimechchihuilía huan ya nopa niquitas quen se tlacajcahualistli. 
\q1 Xijtlamichihuaca nochi catli anquiijtojtoque para anquichihuase. 
\q1  
\v 15 Huan technojnotzaca quema anmotequipachohuaj, 
\q1 huan na nimechmanahuis huan amojuanti antechnextilise miyac tlatlepanitacayotl.” 
\q1  
\v 16 Pero Toteco quinilhuía masehualme catli amo cuajcualme: 
\q1 “Amo anquipiyaj tequiticayotl para ancamanaltise tlen nopa camanal sencahuali, 
\q1 catli quiijtohua catli nimechmacas, 
\q1 niyon amo hueli antepohuilise notlanahuatilhua. 
\q1  
\v 17 Pampa amo anquicaquij quema nimechtlacahualtía, 
\q1 niyon amo anquichihuilíaj cuenta nocamanal. 
\q1  
\v 18 Quema anquiitaj se tlachtejquetl, 
\q1 anmohuampoxchihuaj ihuaya, 
\q1 huan nojquiya anmohuicaj ininhuaya catli quichijtinemij tlen hueli ica catli amo ininnamic. 
\q1  
\v 19 San campa hueli anquicalaquijtinemij amonenepil para anquiijtose catli fiero. 
\q1 Nimantzi anistlacatij. 
\q1  
\v 20 Anmosehuíaj huan anquitelhuíaj se catli amonelicni. 
\q1 Quena, yaya catli nojquiya icone amonana huan san sejco anmoscaltijque, 
\q1 anquitlaijilhuíaj. 
\q1  
\v 21 Nochi ya ni anquichijtoque, 
\q1 huan na amo tleno niquijtojtoc. 
\q1 Huajca anmoilhuijtoque para na nieli san se quen amojuanti. 
\q1 Pero ama nimechixcoilhuis nochi catli anquichijtoque, 
\q1 huan nimechpannextilis nochi. 
\q1  
\v 22 Xijtlacaquilica ya ni, 
\q1 amojuanti catli antechelcahuaj na, niamoTeco Dios. 
\q1 Sintla amo antechelnamiquij, 
\q1 nimechhuejhuelos huan amo aqui itztos catli huelis anmechmanahuis nomaco. 
\q1  
\v 23 Pero quema antechtlascamatij ica nochi catli nimechchihuilía, 
\q1 eltoc quen se tlacajcahualistli catli nechnextilía antechtlepanitaj. 
\q1 Huan nopa masehuali catli monejnehuilía campa mocuapolojtoc, 
\q1 huan mocuepa ipan noojhui catli xitlahuac, 
\q1 na nijmaquixtis.” 
\c 51  
\s1 Se netlatlajtili para Toteco ma quitlapojpolhui 
\q1  
\v 1 ¡Ta, tinoTeco Dios catli techicnelía, 
\q1 nimitztlajtlanía xijpiya hueyi moyolo ica na! 
\q1 ¡Techtlasojtla ta catli tijpiya miyac motlaicnelilis huan techtlapojpolhui nochi notlaixpanolhua! 
\q1  
\v 2 ¡Techpajpaca huan techquixtili ni notlajtlacol para sempa nielis nitlapajpactic! 
\q1  
\v 3 Pampa ya nimomacac cuenta para nelía nitlajtlacolchijtoc moixpa. 
\q1 Huan san ya nopa nimosenilhuijtoc nochipa. 
\q1  
\v 4 San ica ta nitlajtlacolchijtoc. 
\q1 Quena, san ica ta nijchijtoc ni hueyi tlajtlacoli catli ta amo tijnequi tiquitas. 
\q1 Ta tiquitac nochi catli nijchijqui huan xitlahuac techtlajtolsencajtoc. 
\q1  
\v 5 Pero na ipa nitlajtlacolchijquetl hasta quema nitlacatqui. 
\q1 Quena, ipa nitlajtlacolchijca masehuali hasta quema pejqui nimoscaltía iijtico nonana. 
\q1  
\v 6 Ta tijnequi se masehuali ma mitztlepanita ipan iyolo; 
\q1 tijnequi ma tijchihuaca san catli melahuac. 
\q1 Techchihua na ma nijmati motlalnamiquilis hasta campa más tlatzintla ipan noyoltipa. 
\q1  
\v 7 Xiquijtzelo nopani nopa estli catli tetlapajpacchihua, 
\q1 huan quej nopa nimocahuas nitlapajpactic. 
\q1 Quena, techpajpaca, huan nimocahuas onpano nichipahuac moixpa. 
\q1  
\v 8 Huan teipa quema ya techtlatzacuiltijtos, 
\q1 xijchihuas para sempa ma niyolpaqui. 
\q1 Huan elis quen sempa moyancuilise noomiyohua catli tijtlatixchijtoc. 
\q1  
\v 9 Amo xijsenhuiquili xijtlachilijto notlajtlacolhua. 
\q1 Xiquixpolo tlen moixtla nochi catli amo cuali nijchijtoc. 
\q1  
\v 10 NoTeco Dios, xijchihua para noyolo ma eli yancuic huan tlapajpactic. 
\q1 Xijchihua para ma nimonejnehuilis san ipan tlamantli catli cuali, 
\q1 huan para ma nijnequis nijchihuas san catli xitlahuac. 
\q1  
\v 11 Amo techiyocacahua tlen ta moixtla, 
\q1 niyon amo techquixtili moTonaltzi catli tlatzejtzeloltic. 
\q1  
\v 12 Xijchihua para sempa ma nijmati nopa paquilistli catli nijpixqui pampa ta techmaquixti. 
\q1 Ica moTonaltzi techchihua para nochipa ma nijnequis nimitztlepanitas. 
\q1  
\v 13 Huan huajca niquinnextilis moojhui sequinoc tlajtlacolchihuani catli tlaixpanotoque quen na. 
\q1 Huan tlajtlacolchihuani moyolcuepase huan hualase campa ta. 
\q1  
\v 14 Toteco Dios, ta catli techmaquixtía, 
\q1 techmanahui tlen ni tlaeticayotl catli nijpiya pampa nitemicti. 
\q1 Huan huajca nihuicas tiohuicatl para niteyolmelahuas para ta tijchihua catli senquistoc xitlahuac. 
\q1  
\v 15 Toteco, xijchihua para sempa ma nihuica, 
\q1 huan nitepohuilis nochi catli techchihuilijtoc huan na nimitzpaquilismacas. 
\q1  
\v 16 Pampa ta amo tijnequi ma nimitzmacas tlacajcahualistli para techtlapojpolhuis. 
\q1 Sintla quej nopa elisquía, 
\q1 huajca ica paquilistli nijchihuasquía. 
\q1 Pero amo mitzpactía ma niquintlali tlapiyalme ipan tlaixpamitl para niquintlatis moixpa, 
\q1 quen se tlacajcahualistli tlatlatili. 
\q1  
\v 17 Ta tijnequi ma nimoyolcoco, 
\q1 huan ma nimotequipacho ica nochi catli amo cuali nijchijtoc, 
\q1 huan ma nimoyolcuepa. 
\q1 Quena, nopa masehuali catli moechcapantlalía huan moyolcuepa, 
\q1 ta tinoTeco Dios, temachtli tijtlacaquilía huan amo tijhuejcamajcahua. 
\q1  
\v 18 Huan, Toteco, amo xijtlatzacuilti altepetl Sion por notlajtlacolhua. 
\q1 Ta xiquinpalehui momasehualhua huan xijmocuitlahui moaltepe Jerusalén. 
\q1  
\v 19 Huan quema noyolo ya eltos xitlahuac moixpa, 
\q1 tipaquis ica catli cuali nijchihuas. 
\q1 Huan tijselis nochi tlacajcahualistli quema niquinhuicas torojme para niquinmictis, 
\q1 huan nimitzmacas ipan motlaixpa. 
\c 52  
\s1 Toteco tetlasojtla huan tetlajtolsencahua 
\q1  
\v 1 ¡Xijtlacaquili ta catli timoilhuía para tlahuel tihueyi! 
\q1 ¿Para tlen timohueyimati ica catli fiero tiquinchihuili imasehualhua Toteco Dios? 
\q1 Toteco Dios quipixtoc itlaicnelilis para nochipa. 
\q1  
\v 2 Pero ta nochipa timonejnehuilía san catli fiero tiquinchihuilis sequinoc. 
\q1 Huan nochi istlacatili catli quisa mocamaco eli quen se cuchillo catli tlahuel tlatequi. 
\q1  
\v 3 Achi más mitzpactía tijchihuas tlen fiero huan amo catli cuali. 
\q1 Huan nojquiya achi más mitzpactía istlacatili huan amo catli melahuac. 
\q1  
\v 4 Mitzpactía titeistlacahuis. 
\q1 Huan mitzpactía tiquijtos camanali catli tecocohua. 
\q1 ¡Tiistlacatica tlacatl! 
\q1  
\v 5 Yeca Toteco Dios mitztzontlamiltis para nochipa. 
\q1 Mitzhuahuatatzas para mitzquixtis tlen mochaj, 
\q1 huan ayacmo tiitztos ipan ni tlaltipactli campa itztoque masehualme. 
\q1  
\v 6 Nochi masehualme catli quitlepanitaj Toteco, 
\q1 quiitase catli yaya quichihuilis nopa fiero masehuali, 
\q1 huan momajmatise. 
\q1 Huajca inijuanti quihuetzquilise huan quiijtose: 
\q1  
\v 7 “Xiquitaca catli ipantic ne masehuali catli amo quitlepanita Toteco Dios. 
\q1 San motemachi ipan itomi huan nochi tlamantli pajpatiyo catli yaya quipiya, 
\q1 huan quichijtinenqui catli amo cuali.” 
\q1  
\v 8 Pero na cuali niijcatoc quen se olivo cuahuitl, 
\q1 huan Toteco nechyahualohua para nechmocuitlahuis. 
\q1 Na nimotemachía ipan Toteco para yaya ma nechtlasojtla nochipa. 
\b  
\q1  
\v 9 NoTeco Dios, na nochipa nimitztlascamatis por nochi nopa cuali tlamantli catli tijchijtoc. 
\q1 Huan san ipan ta nimochiyas para techtlasojtlas, 
\q1 pampa nochi quimatij para ta nelía tijpiya hueyi moyolo ica catli moaxcahua. 
\c 53  
\s1 Masehualme catli huihuitique 
\q1  
\v 1 San se masehuali catli tlahuel huihuitic moilhuisquía ipan iyolo para amo onca Dios. 
\q1 ¿Para tlen quej nopa quiijtosquía? 
\q1 Eltoc pampa iyolo tlahuel fiero huan san quichihua catli amo cuali. 
\q1 Amo aqui se masehuali catli quichihua catli nelxitlahuac. 
\q1  
\v 2 Toteco Dios hasta nepa ilhuicac quinhualtlachilía masehualme, 
\q1 para quiitas sintla onca se catli nelía quitemohua huan quichihua catli cuali. 
\q1  
\v 3 ¡Pero amo! 
\q1 Nochi masehualme mocueptoque ipan tlajtlacolotl. 
\q1 Quena, nochi tlajtlacolchijtoque huan moijtlacojtoque. 
\q1 Amo aqui quichihua catli senquistoc cuali, 
\q1 niyon se. 
\q1  
\v 4 ¿Atlac amo quipiyaj inintlalnamiquilis nopa tlajtlacolchijca masehualme? 
\q1 Inijuanti quintzontlamiltíaj momasehualhua quen elisquíaj pantzi catli quicuaj huan amo quinequij quitemose Toteco Dios. 
\q1  
\v 5 Pero ajsis tonali quema Toteco Dios quinpinahualtis huan quintlatzacuiltis nopa masehualme. 
\q1 Quena, quintzontlamiltis huan inintlacayohua mocahuase tepejtoque campa hueli. 
\q1 Amo aqui quintlalpachos pampa yaya quintlahuelcajtoc. 
\q1  
\v 6 ¡Cuali elisquía sintla Toteco hualasquía tlen altepetl Jerusalén huan quinmaquixtis nochi israelitame! 
\q1 Israelitame san huelis itztose ica paquilistli quema Toteco Dios quichihuas para inijuanti catli imasehualhua ma tlatlanica. 
\c 54  
\s1 Se netlatlajtili para Toteco ma quimanahui tlen icualancaitacahua 
\q1  
\v 1 ¡NoTeco Dios, xihuala techmaquixtiqui pampa nochi quimatij ta tihueyi! 
\q1 ¡Techmanahuiqui ica mohueyi chicahualis! 
\q1  
\v 2 Techtlacaquili quema nimotlatlajtía ica ta. 
\q1 Quena, xijtlacaquili catli nimitzpohuilía, 
\q1  
\v 3 pampa tlahuilanca masehualme motlanantoque ica na. 
\q1 Quena, masehualme catli amo quema mitzelnamiquij nechtemohuaj para nechmictise. 
\b  
\q1  
\v 4 Pero Toteco Dios nochipa nechpalehuía, 
\q1 huan amo quincahuilis ma nechmictica. 
\q1  
\v 5 Toteco quincuepilis nocualancaitacahua nochi nopa tlamantli amo cuali catli inijuanti quisencajtoque nechchihuilise. 
\b  
\q1 Quena, TOTECO, ta catli nelía titemachtli, xijchihua senquistoc quen techtencahuilijtoc, 
\q1 huan xiquintzontlamilti nochi nocualancaitacahua. 
\q1  
\v 6 Ica paquilistli nimitzmacas notlacajcahualis. 
\q1 Nimitzhueyimatis pampa ta nelía ticuali, 
\q1  
\v 7 pampa ta techmanahuijtoc tlen nochi tlaohuijcayotl, 
\q1 huan niquitztoc quenicatza tiquintlantoc nochi nocualancaitacahua. 
\c 55  
\s1 Se netlatlajtili tlen se masehuali catli quicajcayajqui ihuampox 
\q1  
\v 1 NoTeco Dios, techtlacaquili quema nimotlatlajtía ica ta. 
\q1 Amo ximotlati quema nimitztzajtzilía. 
\q1  
\v 2 Techtlacaquili huan technanquili, 
\q1 pampa tlahuel nimotequipachohua huan nichoca pampa nitlaijiyohuía. 
\q1  
\v 3 Nocualancaitacahua nechtzajtzilíaj chicahuac huan quinequij nechmictise. 
\q1 Tlahuel nechcualancaitaj huan ica nochi inincualancayo nechtepotztocatihualahuij para nechtzontlamiltise. 
\q1  
\v 4 Nelía nechcocohua noyolo pampa nechitzquía se hueyi majmajtli. 
\q1  
\v 5 Quena, tlahuel nimajmahui huan nihuihuipica. 
\q1  
\v 6 ¡Cuali elisquía sintla nijpiyasquía noeltlapal quen quipiya se paloma para huelisquía nipatlantehuasquía huan nimosiyajquetzati! 
\q1  
\v 7 Quena, nicholosquía hasta nepa campa huactoc tlalme catli mopantíaj huejca huan nepa nimocahuasquía. 
\q1  
\v 8 Nimoisihuiltisquía para nicholos huan nimotlatis tlen nochi ni tlaijiyohuilistli catli hualajtoc nopani. 
\q1 Eltoc quen se hueyi ajacatl hualajtoc catli tlamitlasosolohua. 
\q1  
\v 9 Toteco, xiquintzontlamilti nocualancaitacahua. 
\q1 Xijchihua ma mocuapoloca inijuanti ininseltzitzi quema camanaltij. 
\q1 Na niquitztoc para nochi tlahuilanaj campa hueli ipan ni moaltepe. 
\q1  
\v 10 Tlayohua huan tonaya masque itztoque catli quiyahualojtinemij ni altepetl ipan itepa para quimocuitlahuise tlen tocualancaitacahua, 
\q1 inijuanti catli nica ehuani ininseltzitzi mohuilanaj se ica seyoc ipan ni altepetl. 
\q1  
\v 11 Tlatlajco nopa altepetl quichihuaj miyac tlamantli catli amo cuali, 
\q1 huan amo onca tlatlepanitacayotl. 
\q1 Ipan tianquis huan campa hueli momictíaj, 
\q1 tlachtequij huan tlacajcayahuaj. 
\q1  
\v 12 Amo elqui se nocualancaitaca catli nechcajcayajqui, 
\q1 pampa sintla quej nopa eltosquía, huajca niquijiyohuijtosquía. 
\q1 O hueltosquía nimotlatis huan nicholos. 
\q1  
\v 13 Pero elqui se catli nemiyaya nohuaya, 
\q1 se catli nechyacanayaya huan catli nonelhuampox. 
\q1  
\v 14 Quena, elqui yaya catli sentic timopohuiliyayaj nopa tlamantli catli tijpixtoyaj ipan toyolo, 
\q1 huan yejyectzi timocamanalhuiyayaj quema san sejco tiyohuiyayaj ipan mochaj, Toteco Dios. 
\q1  
\v 15 Ma tlatocmiquica nochi nocualancaitacahua huan ma yaca hasta mictla quema noja yoltoque, 
\q1 pampa ipan ininchaj huan ipan ininyolo san onca tlajtlacolotl. 
\b  
\q1  
\v 16 Pero na san nijtzajtzilis Toteco Dios para ma nechmaquixti. 
\q1 Huan quena, temachtli yaya nechmaquixtis. 
\q1  
\v 17 Na nimotlatlajtis ica ijnaloc, ica tlajco tona huan ica tiotlac. 
\q1 Huan yaya nechtlacaquilis huan nechnanquilis. 
\q1  
\v 18 Ipan tlahuilancayotl yaya nechmanahuis, 
\q1 masque tlahuel miyac nocualancaitacahua nechhuilanase chicahuac. 
\q1  
\v 19 Toteco Dios catli ipa itztoc huan tlanahuatijtoc hasta tlen huejcajya, 
\q1 yaya nechtlacaquilis huan quintzontlamiltis. 
\q1 Pampa nocualancaitacahua amo quipatlaj ininnemilis catli fiero, 
\q1 niyon amo quitlepanitaj itlanahuatil. 
\q1  
\v 20 Nopa masehualme catli amo cuajcualme momatlananaj para quinhuilanaj hasta ininhuampoyohua. 
\q1 Quiixpanoj nopa camanali catli quichihuaj ininhuaya sequinoc. 
\q1  
\v 21 Quitequihuíaj camanali catli nelyejyectzi huan yamanic quen mantequilla, 
\q1 pero ipan ininyolo san moilhuíaj quenicatza tlahuilanase. 
\q1 Nochi catli quiijtohuaj eltoc alaxtic quen aceite, 
\q1 pero ichtacatzi teyolcocohuaj ica camanali quen quema timotzontequis ica machete. 
\b  
\q1  
\v 22 Nochi motequipachol xijcahua imaco TOTECO huan yaya mitzmacas temachili. 
\q1 TOTECO amo quicahuas ma huetzi se catli quitlepanita. 
\b  
\q1  
\v 23 Pero ta tinoTeco Dios, 
\q1 tiquintitlanis nocualancaitacahua ipan nopa ostotl catli tlahuel huejcatla. 
\q1 Nopa temictiani huan istlacatini amo itztose niyon tlajco tlen ininnemilis, 
\q1 pampa amo huejcahuase itztose ipan ni tlaltipactli. 
\q1 Pero na nochipa nimotemachis ipan ta para techmaquixtis. 
\c 56  
\s1 David motlatlajtía ica Toteco 
\q1  
\v 1 NoTeco Dios, techtlasojtla, 
\q1 pampa nocualancaitacahua semilhuitl nechtepotztocatinemij. 
\q1 Nochi se tonal nechtlaijiyohuiltíaj. 
\q1  
\v 2 Nochi se tonal nechcuatetzopaj huan noca paquij. 
\q1 Tlahuel miyaqui itztoque catli quinequij nechtlamiltise. 
\q1  
\v 3 Pero quema nijmati nimajmahui, na nimotemachía ipan ta. 
\b  
\q1  
\v 4 Nijhueyichihua Toteco Dios huan nimotemachía ipan ya para nechmanahuis quen techtlajtolcahuilijtoc quichihuas ipan icamanal. 
\q1 Huajca pampa nimotemachía ipan ya, 
\q1 ¿tlaque huelis nechchihuilis se masehuali? 
\q1  
\v 5 Tlatoctzitzi quipatlaj nocamanal huan san moilhuíaj quenicatza huelis nechchihuilise catli amo cuali. 
\q1  
\v 6 Mosentilíaj huan quisencahuaj tlaque nechchihuilise. 
\q1 Teipa motlatíaj ojteno huan nechchiyaj ma nipano para nechmictise. 
\b  
\q1  
\v 7 Toteco Dios, xijtlachili nochi inintlaixpanolhua huan xiquintlatzacuilti. 
\q1 Ica mohueyi cualancayo, xiquintlahuiso hasta tlalchi. 
\q1  
\v 8 Ta techitztoc quesqui hueltas nimochololtijtoc huan nimochoquilijtoc. 
\q1 Nochi noixayo tijsentilijtoc huan ticajoctoc ipan se frasco. 
\q1 Huan ipan molibro tiquijcuilojtoc quesqui imiyaca. 
\q1  
\v 9 NoTeco Dios, quema nimitztzajtzilía para techpalehui, 
\q1 nochi nocualancaitacahua nimantzi cholohuaj. 
\q1 Quej nopa eli pampa cuali nijmati para ta tiitztoc nohuaya para techpalehuis. 
\b  
\q1  
\v 10 Na nimotemachía ipan Toteco Dios. 
\q1 Quena, nimopaquilismacas ipan TOTECO icamanal, 
\q1 por nochi catli nechtlajtolcahuilijtoc nechchihuilis. 
\q1  
\v 11 Quena, nimotemachía ipan Toteco Dios huan amo nimajmahui. 
\q1 ¿Tlaque huelis nechchihuilis se masehuali? 
\b  
\q1  
\v 12 NoTeco Dios, nochi catli nimitztlajtolcahuilijtoc, nijtlamichihuas. 
\q1 Nimitztlascamatilis ica tiohuicatl pampa techpalehuijtoc miyac. 
\q1  
\v 13 Ta Toteco Dios techmanahuijtoc para amo nimiquis, 
\q1 huan amo techcahuilijtoc ma nihuetzi ipan tlamantli catli amo cuali. 
\q1 Yeca ama noja hueli ninentinemis moixpa nica ipan ni tlaltipactli ica masehualme catli itztoque. 
\c 57  
\s1 Se netlatlajtili para Toteco ma quipalehui 
\q1  
\v 1 Techtlasojtla, noTeco Dios, xijnexti motlaicnelilis noca na, 
\q1 pampa san ipan ta nimotemachía para techmanahui. 
\q1 Quen se pilpiyotzi motlatía ieltlapaltzala inana, 
\q1 na nojquiya nimotlatía ipan ta hasta panos ni hueyi tlaohuijcayotl catli eltoc quen se hueyi ajacatl. 
\b  
\q1  
\v 2 Nijtzajtzilis Toteco Dios Catli Más Hueyi. 
\q1 Quena, nijnojnotzas Toteco Dios catli nochipa nechpalehuía ipan nochi tlamantli. 
\q1  
\v 3 Tlen ilhuicac nechtitlanilía itlapalehuil para nechmaquixtis. 
\q1 Yaya nechchololtis ininmaco nocualancaitacahua catli ica miyac cualantli nechtepotztocatinemij, 
\q1 huan quinequij nechtzontlamiltise. 
\q1 Pampa yaya Toteco Dios temachtli huan tlahuel nechicnelía. 
\q1  
\v 4 Nechyahualojtoque masehualme catli mosisiníaj quen tecuanime. 
\q1 Inincamanal eltoc quen tlitl catli quisa inincamaco. 
\q1 Inintlancoch tlajtlatequi quen cuatlamintli huan ininnenepil tlatequi quen machete. 
\b  
\q1  
\v 5 NoTeco Dios, nochi ma mitzhueyichihuaca ipan nochi ilhuicactli. 
\q1 Mohueyitilis ma quitemiti ni tlaltipactli. 
\q1  
\v 6 Nocualancaitacahua quitlalijtoque se tlaquetztli para ma nimasi, 
\q1 yeca tlahuel nimajmahui. 
\q1 Nojquiya quichijque se ostotl ipan ojtli para ma nimoostohui, 
\q1 pero xiquita inijuanti huetzque nopona. 
\q1  
\v 7 NoTeco Dios, ipan noyolo nipaqui huan nijpiya tlasehuilistli. 
\q1 Huan yeca nimocualtlalijtoc para nihuicas huan nijsencahuas tiohuicatl para ta. 
\q1  
\v 8 Na nimocualtlalía para nijtzotzonas noarpa huan noguitarra. 
\q1 Cualca niisa para nimitztlatzotzonilis. 
\q1  
\v 9 Na nimitztlascamatis iniixpa masehualme pampa ta, Toteco, techchihuilijtoc miyac tlamantli catli yejyectzi. 
\q1 Huan nihuicas para nimitzhueyimatis iniixpa masehualme tlen nochi tlalme. 
\q1  
\v 10 Motlaicnelijcayo nelhueyi quen ipatlajca ilhuicactli huan huejcapantic hasta quionpano mixtli. 
\q1 Ta tlahuel titemachtli. 
\q1  
\v 11 Toteco Dios, nochi ma mitzhueyichihuaca ipan nochi ilhuicactli. 
\q1 Mohueyitilis ma quitemiti ni tlaltipactli. 
\c 58  
\s1 Se netlatlajtili para Toteco ma quintlatzacuilti catli amo tlatlepanitaj 
\q1  
\v 1 ¡Amojuanti anmasehualme catli anquipiyaj tequiticayotl para antetlajtolsencahuaj! 
\q1 ¿Atlac nelía xitlahuac anquintlajtolsencahuaj masehualme? 
\q1  
\v 2 ¡Amo! San anmoilhuíaj catli fiero huelis anquichihuase. 
\q1 Anquichijtoque para noja más ma onca tlahuilancayotl ipan amotlal. 
\q1  
\v 3 Nopa masehualme catli amo quitlepanitaj Toteco pejque moiyocacahuaj hasta quema tlacatque. 
\q1 Huan ipa istlacatij hasta quema pejque huelij camanaltij. 
\q1  
\v 4 Inijuanti tencocoque quen cohuame catli temictíaj ica inintencococa. 
\q1 Huan itztoque quen nopa cohuame catli momatij quincaquij inintoscac inintecohua, 
\q1 pero ayacmo quinequij quinneltocase. 
\q1  
\v 5 Monacastzacuaj huan ayacmo quichihuilíaj cuenta, 
\q1 masque ininteco quintlatzotzonilíaj yejyectzi para ma quinneltoquilica. 
\q1 Huan nimantzi tetzacaníaj. 
\q1 Quej nopa itztoque ni fiero masehualme. 
\b  
\q1  
\v 6 NoTeco Dios, xiquintlamiltili ininchicahualis. 
\q1 Quena, xiquinquixtili ininchicahualis nopa masehualme catli mosisiníaj, 
\q1 quen tiquinquixtilisquía inintlancoch huan inintlacuajcuayo nopa tecuanime. 
\q1  
\v 7 Ma ixpolihuica quen ixpolihui nopa atl catli toyahui ipan huactoc tlali. 
\q1 Huan nopa tepostli catli quipixtoque ininmaco para ica tlahuilanaj, 
\q1 ma eli quen amo tleno ipati. 
\q1  
\v 8 Ma elica quen nopa cuachololojtli catli atiya quema noja nentinemi. 
\q1 O ma elica quen se pilconetzi catli tlacatqui mictoc huan catli amo quema quiitac tlatlanextli. 
\b  
\q1  
\v 9 Toteco Dios quinixpolihuiltis catli huehuentzitzi huan catli telpocame. 
\q1 Quintzontlamiltis nelnimantzi quen se chachapali catli nimantzi totoniya ica nopa tlitl catli lementoc ica huitzcuahuitl. 
\q1  
\v 10 Pero catli itztoque xitlahuaque iixpa Toteco, 
\q1 paquise quema quiitase para Toteco ya momacueptoc ica nopa masehualme catli amo tleno quitlepanitaj, 
\q1 huan moicxipajpacase ica inieso nopa masehualme. 
\q1  
\v 11 Huan huajca nochi masehualme quiijtose: 
\q1 “Nelía quiselíaj se cuali tlaxtlahuili nopa masehualme catli itztoque xitlahuaque, 
\q1 pampa melahuac itztoc se Dios catli tetlajtolsencahua xitlahuac ipan ni tlaltipactli.” 
\c 59  
\s1 Se netlatlajtili para Toteco ma quimanahui David 
\q1  
\v 1 ¡NoTeco Dios, techmanahui ininmaco nocualancaitacahua! 
\q1 ¡Techmocuitlahui tlen inijuanti catli hualajtoque para nechtzontlamiltise! 
\q1  
\v 2 ¡Techmanahui ininmaco tlajtlacolchijca masehualme, 
\q1 inijuanti catli temictíaj! 
\q1  
\v 3 Nechpijpiyaj para quiitase quenicatza nechmictise. 
\q1 Masehualme catli quipiyaj chicahualistli nechchixtoque yahualtic. 
\q1 Pero amo pampa niquinchihuilijtoc se tlamantli catli amo cuali 
\q1 o pampa niquinixpanotoc. 
\q1  
\v 4 ¡Amo! Amo tleno catli fiero niquinchihuilijtoc, 
\q1 pero inijuanti mocualtlalíaj para nechmictise. 
\q1 ¡TOTECO, xiisa! 
\q1 ¡Xihuala techpalehuiqui! 
\q1  
\v 5 TOTECO, Ta Catli Tijpiya Nochi Chicahualistli, 
\q1 ta catli titoDios tiisraelitame, 
\q1 ximotlanana huan xiquintlatzacuilti nopa tlalme campa itztoque masehualme catli amo israelitame, 
\q1 pampa techyahualojtoque. 
\q1 Amo xiquintlapojpolhui nopa masehualme catli mosisiníaj huan nimantzi tlaixpanoj. 
\q1  
\v 6 Mojmostla ica tlapoyahui hualahuij para quitlachilise quenicatza huelis techtlanise. 
\q1 Tzajtzitinemij quen chichime catli quiyahualojtinemij ni altepetl. 
\q1  
\v 7 Nijcaqui camanaltij fiero hasta camaposonij, 
\q1 huan mitztelchihuaj Toteco, 
\q1 pampa inijuanti quiijtohuaj: 
\q1 “Amo aqui techcaqui.” 
\q1  
\v 8 Pero ta TOTECO, san xiquinhuetzquili, 
\q1 huan xiquinpinahualti ni masehualme tlen sequinoc tlalme catli nechyahualohuaj. 
\q1  
\v 9 NoTeco Dios, pampa nocualancaitacahua quipiyaj chicahualistli, ipan ta nimotemachis, 
\q1 pampa ta catli techmanahuía. 
\q1  
\v 10 NoTeco Dios, ta nochipa techicnelijtoc miyac, 
\q1 yeca nijmati para temachtli techyacantiyas. 
\q1 Tijchihuas ma niquitas catli tlahuel nijnectoc ma ininpanti nocualancaitacahua. 
\q1  
\v 11 NoTeco, ta catli techmanahuía, 
\q1 amo xiquinmicti nimantzi ni nocualancaitacahua, 
\q1 pampa huelis ni nomasehualhua nimantzi quielcahuase catli ininpantis nopa mosisinijca masehualme. 
\q1 Más cuali san xiquinsemana ica mohueyi chicahualis huan xiquinechcapantlali. 
\q1  
\v 12 Quena, xiquintlatzacuilti pampa nochi inijuanti tlahuel istlacatij, mohueyimatij huan tlatelchihuaj. 
\q1  
\v 13 Xiquintzontlamilti ica mohueyi cualancayo, 
\q1 huan xiquintlamiixpolihuilti. 
\q1 Huan quej nopa nochi masehualme quimatise para ta, Toteco Dios, 
\q1 titlanahuatía ipan tlali Israel, 
\q1 huan ipan nochi tlaltipactli. 
\q1  
\v 14 Nocualancaitacahua mocuepaj ica tiotlac huan tzajtzij quen chichime, 
\q1 huan quiyahualojtinemij ni altepetl. 
\q1  
\v 15 Nentinemij campa hueli para quitemojtinemise inintlacualis. 
\q1 Huan quema amo ixhuise, 
\q1 tzajtzij seyohual quen chichime. 
\q1  
\v 16 Pero na sesen ijnaloc nihuicas ica nopa chicahualistli catli techmaca. 
\q1 Huan nimitzhueyimatis pampa techtlasojtla miyac. 
\q1 San ta techmanahuía huan san ipan ta nimotemachía, 
\q1 quema huala tlaohuijcayotl. 
\q1  
\v 17 Toteco Dios, momaco ta niitztoc temachtli, 
\q1 yeca nimitzhueyimatis huan nihuicas para ta, 
\q1 pampa san ta techmocuitlahuía huan techicnelía. 
\c 60  
\s1 Se netlatlajtili para Toteco ma quimanahui David 
\q1  
\v 1 Toteco Dios, ta techhuejcamajcajtoc huan ayacmo tijmatij tlaque monequi tijchihuase. 
\q1 Ticualantoc ica tojuanti huan techtlahuelcajtoc. 
\q1 Ama timitztlajtlaníaj para sempa ximoyoltlali tohuaya huan sempa techfuerzajmaca. 
\q1  
\v 2 Ni tlali tijchijqui ma huihuipica ica majmajtli. 
\q1 Tlahuel tijtlaijiyohuiltijtoc. 
\q1 Huajca ama, noTeco Dios, sempa xijcualtlali totlal catli tlamitlatlapacatoc. 
\q1  
\v 3 Tijchijtoc para tojuanti timomasehualhua ma tijpanoca huejhueyi tlaijiyohuilistli. 
\q1 Huan ica ni tlaijiyohuilistli techchijtoc ma timomimilojtinemica quen elisquía tiihuintitoque. 
\q1  
\v 4 Pero ama techmacatoc nochi tojuanti catli timitzimacasij huan timitztlepanitaj se bandera campa timosentilise. 
\q1 Huan quena, nochi tojuanti catli tijchihuaj catli melahuac timosentilise nopona, 
\q1 para timomanahuise quema tocualancaitacahua techmajcahuilise cuatlamintli. 
\q1  
\v 5 Technanquili huan techmanahui nochi tojuanti catli techicnelía. 
\q1 Xijtequihui mohueyi chicahualis para techmanahuis. 
\b  
\q1  
\v 6 Toteco Dios, yaya catli itztoc ipan ichaj nepa ilhuicac quiijtojtoc: 
\q1 “Ica paquilistli nijxelos tlali Siquem, 
\q1 huan nijtamachihuas nopa tlamayamitl catli itoca Sucot, 
\q1 para nijmacas aqui nijnequis pampa nopa tlalme noaxcahua. 
\q1  
\v 7 Huan nopa tlali Galaad huan Manasés nojquiya noaxcahua. 
\q1 Ipan tlali Efraín hualase nosoldadojhua catli nechmanahuise quen notzontzajca, 
\q1 huan ipan tlali Judá hualase notlanahuatijcahua. 
\q1  
\v 8 Catli itztose ipan tlali Moab elise notequipanojcahua catli teicneltzitzi. 
\q1 Catli itztoque ipan tlali Edom nechtequipanose. 
\q1 Huan nitlahuejchihuas chicahuac quema ya niquintlantos nopa filisteos.” 
\m Quej nopa quiijtohua Toteco. 
\b  
\q1  
\v 9 ¿Ajqueya nechchihuas ma nicalaqui ipan nopa altepeme catli moyahualtzactoque ica tepamitl ipan tlali Edom? 
\q1 ¿Ajqueya nechchihuas ma niquintlani sintla amo ta? 
\q1  
\v 10 San ta techyacanas ipan tlahuilancayotl, noTeco Dios. 
\q1 Amo techtlahuelcahua. 
\q1 Sintla ta amo tiyas ihuaya tosoldados para tlahuilanase, Toteco, 
\q1 amo aqui techpalehuis. 
\q1  
\v 11 Quena, Toteco Dios, techpalehui para tiquintlanise tocualancaitacahua, 
\q1 pampa inintlapalehuil masehualme, amo tleno ipati. 
\b  
\q1  
\v 12 Ica itlapalehuil Toteco Dios tijchihuase huejhueyi tlamantli. 
\q1 Yaya iseltzi quintzontlamiltis nochi tocualancaitacahua. 
\c 61  
\s1 David quinequi itztos ipan itiopa Toteco 
\q1  
\v 1 NoTeco Dios, techtlacaquili quema nimitztzajtzilía. 
\q1 Xijtlacaquili nonetlatlajtil. 
\q1  
\v 2 Masque niitztosquía campa hueli o hasta campa ontlantoc tlaltipactli, 
\q1 na nimitztzajtzilisquía para nimitztlajtlanis motlapalehuil. 
\q1 Quema nimajmahui o nimotequipachohua, 
\q1 techyacana huan techtlatía ipan se huejcapantic tetl, 
\q1 campa amo tleno huelis nechajsis. 
\q1  
\v 3 Pampa san ipan ta nimotemachía para amo tleno nopantis. 
\q1 Ta tiitztoc quen se huejcapantic cali catli nechmanahuía, 
\q1 para amo huelis nechajsise nocualancaitacahua. 
\q1  
\v 4 Nijnequi niitztos para nochipa ipan motiopa para techmocuitlahuis. 
\q1 Nopona niitztos temachtli quen se pilpiyotzi catli mocahua ieltlapaltzala inana. 
\q1  
\v 5 Ta tinoTeco Dios, tijcactoc catli nimitztlajtolcahuilijtoc para nijchihuas. 
\q1 Huan techmacatoc nopa tlatiochihualistli catli ticajoctoc para tiquinmacas masehualme catli mitzimacasij huan mitztlepanitaj. 
\q1  
\v 6 Xijchihuas para na nitlanahuatijquetl ma niitzto miyac xihuitl, 
\q1 huan para nonemilis ma eli yejyectzi. 
\q1  
\v 7 Techcahuili ma nitlanahuatis moixpa para nochipa. 
\q1 Techmanahui huan techmocuitlahui ica motlaicnelijcayo. 
\q1  
\v 8 Quej nopa nimitzhuicatis huan nimitzpaquilismacas mojmostla. 
\q1 Quena, sesen tonal nijtlamichihuas catli nimitztencahuilijtoc para nijchihuas para ta. 
\c 62  
\s1 David motemachi san ipan Toteco 
\q1  
\v 1 Na san ipan Toteco Dios nimochiya para yaya ma nechmanahui, 
\q1 pampa san ya hueli temaquixtía. 
\q1  
\v 2 Nimotlatía ipan ya para amo tleno nechajsis. 
\q1 San yaya nechmaquixtía huan nechmocuitlahuía quema huala tlaohuijcayotl. 
\q1 Amo tleno hueli nechpanos. 
\q1  
\v 3 Pero ¿hasta quema tlamis nocualancaitacahua nechhuilanase? 
\q1 Ayacmo nijpiya más chicahualistli quen tlanahuatijquetl ipan notlanahuatilis. 
\q1 Nocualancaitacahua quisencahuaj quenicatza huelis nechtlahuisose. 
\q1 Nechitaj quen se tlapepecholi o tepamitl catli quinequi huetzis. 
\q1  
\v 4 Quena, san moilhuíaj san sejco quenicatza huelis nechtzontlamiltise. 
\q1 Quinpactía quitlacaquilise istlacatili huan tlacajcayahualistli. 
\q1 Ica inincamac nechcamanalhuíaj yejyectzi, 
\q1 pero ipan ininyolo nechtelchihuaj. 
\q1  
\v 5 Pero na san nimochiya ipan Toteco Dios, 
\q1 san nimochiya para yaya ma nechmanahui, 
\q1 pampa san ya hueli temaquixtía. 
\q1  
\v 6 Nimotlatía ipan ya para amo tleno nechajsis. 
\q1 San yaya nechmaquixtía huan nechmocuitlahuía quema huala tlaohuijcayotl, 
\q1 yeca san ipan ya nimotemachía. 
\q1  
\v 7 San Toteco Dios hueli nechmaquixtis huan sempa nechhueyitlalis iniixpa sequinoc. 
\q1 Yaya nechtlatía huan nechfuerzajmaca. 
\q1 Nechmocuitlahuía para amo ma nechajsi catli fiero. 
\q1  
\v 8 ¡Annomasehualhua, nochipa ximotemachica ipan Toteco Dios! 
\q1 Xijpohuilica nochi catli eltoc ipan amoyolo, 
\q1 pampa san yaya hueli techmocuitlahuis ica catli amo cuali. 
\q1  
\v 9 Amo tleno nelía ininpati masehualme iixpa Toteco, 
\q1 masque catli tominpiyaj o catli teicneltzitzi. 
\q1 Sintla se quintlalisquía ipan balanza para quintamachihuas sintla etique quen se tlamantli catli tlahuel ipati, 
\q1 momacas cuenta para melahuac amo etique pampa masehualme itztoque san quen ajacatl. 
\q1  
\v 10 Masehualme, amo ximoilhuica para antlahuilanase para anquitlanise más tomi. 
\q1 Amo ximoilhuica para antlachtequise para anmoricojchihuase. 
\q1 Huan sintla anmochihuase rico, 
\q1 amo ximohueyimatica, niyon amo ximotemachica ipan amotomi. 
\q1  
\v 11 Nijmati ya ni, pampa miyac hueltas Toteco Dios nechilhuijtoc: 
\q1 san yaya quipiya nochi chicahualistli. 
\b  
\q1  
\v 12 San ta, Toteco, titeicnelía mojmostla. 
\q1 Huan tiquintlaxtlahuía sesen masehuali quen quinamiqui ica catli quichijtoque. 
\c 63  
\s1 Nijtemohua noTeco 
\q1  
\v 1 ¡Toteco Dios, ta tinoDios! 
\q1 ¡Nelía tlahuel nimitztemohua! 
\q1 ¡Quen se masehuali catli tlahuel amiqui ipan huactoc tlali campa amo onca atl, 
\q1 na ica nochi noyolo huan ica nochi noalma nijnequi nimitzpantis! 
\q1  
\v 2 Nijnequi niquitas mochicahualis huan mohueyitilis quen niquitac ipan motiopa. 
\q1  
\v 3 Pampa motlaicnelijcayo más hueyi ipati huan amo nonemilis. 
\q1 ¡Tlahuel nimitzhueyimati! 
\q1  
\v 4 Huan nochi tonali quema noja niitztos, nimitztiochihuas. 
\q1 Huan moixpa nimomatlananas huan nimotlatlajtis ica ta. 
\q1  
\v 5 Huan huajca, quena, nijmatis quen elisquía ya niixhuic ica se tlacualistli catli ajhuiyac. 
\q1 Huan nimitzhueyimatis ica miyac paquilistli. 
\q1  
\v 6 Nochi yohuali quema nimoteca ipan notlapech huan amo hueli nicochi, 
\q1 nimoilhuía tlen ta. 
\q1 Quena, nimonejnehuilía tlen ta sesen hora. 
\q1  
\v 7 Nimoilhuía quenicatza techpalehuijtoc huan yeca sesen yohuali tlahuel nipaqui. 
\q1 Quen se piyo quintlatía iconehua ieltlapaltzala, 
\q1 quej nopa ta techtlatía na para amo tleno nechajsis. 
\q1  
\v 8 Nimotlatzquilijtoc ipan ta pampa san ta techmocuitlahuía ica mohueyi chicahualis. 
\q1  
\v 9 Nochi catli quinequij nechmictise yase mictla. 
\q1  
\v 10 Pampa ya eltoc tlasencahuali para miquise, 
\q1 huan para sequinoc quintzontlamiltise ica machete. 
\q1 Huan inintlacayohua elis tlacualistli para nopa tepechichime. 
\q1  
\v 11 Pero na nitlanahuatijquetl nimopaquilismacas ipan ta, Toteco Dios. 
\q1 Huan nojquiya paquise nochi sequinoc catli senquistoc motemachíaj ipan ta. 
\q1 Pero nochi catli istlacatij, 
\q1 ta, Toteco, tiquincamatzacuas. 
\c 64  
\s1 Se netlatlajtili para Toteco ma quimocuitlahui 
\q1  
\v 1 NoTeco Dios, xijtlachili notequipachol. 
\q1 ¡Xijmanahui nonemilis tlen nocualancaitacahua catli quinequij nechmictise! 
\q1  
\v 2 Techtlati tlen ni amo cuajcualme catli ichtacatzi quisencahuaj para nechchihuilise catli fiero. 
\q1  
\v 3 Nochi inincamanal ajsi ipan noyolo, 
\q1 huan tlahuel nechcocohua quen elisquía se cuatlamintli. 
\q1  
\v 4 Inijuanti amo majmahuij para nechtlatzacuiltise. 
\q1 Motlatíaj campa amo aqui hueli quinita, 
\q1 huan quinmajcahuilíaj cuatlamintli masehualme catli amo tleno quichijtoque. 
\q1 Niyon quentzi amo majmahuij ica catli fiero quichihuaj. 
\q1  
\v 5 Se ica seyoc mofuerzajmacaj para quichihuase más catli fiero. 
\q1 Ichtacatzi mosentilíaj para quitlalise tlaquetztli. 
\q1 Huan quiijtohuaj: “Nica tijtlalise ni tlaquetztli campa amo aqui huelis quiitas.” 
\q1  
\v 6 Ica miyac cuidado quisencahuaj quenicatza quichihuase para temictise. 
\q1 Ica yolic quitemolíaj quenicatza quichihuase catli fiero quisencajtoque quichihuase para ma cualquisa. 
\q1 Iyolo huan itlalnamiquilis se masehuali tlahuel quimati quisencahuas catli fiero para quichihuas. 
\b  
\q1  
\v 7 Pero Toteco Dios yaya iseltzi quintlamicocos. 
\q1 Elis quen quinmajcahuilis cuatlamintli quema amo quichiyaj, 
\q1 huan nimantzi quintlanis. 
\q1  
\v 8 Quena, huetzise huan motzontlamiltise, 
\q1 por nopa camanali catli quiijtojtoque. 
\q1 Huan nochi catli quinitase momajmatise. 
\q1  
\v 9 Huajca nochi masehualme quitlepanitase Toteco Dios huan quiimacasise quiixpanose. 
\q1 Tepohuilise nochi catli yaya quichijtoc. 
\q1 Huan huajca quimachilise para san ya quichihua huejhueyi tlamantli. 
\q1  
\v 10 Huan nochi masehualme catli itztoque xitlahuaque quipaquilismacase TOTECO, 
\q1 huan más motemachise ipan ya huan quihueyimatise. 
\c 65  
\s1 David quihueyimati Toteco 
\q1  
\v 1 Toteco Dios, san ta quinamiqui ma timitzhueyimatica, 
\q1 ta catli tiitztoc ipan altepetl Jerusalén. 
\q1 Huan quinamiqui ma timitzmacaca nochi catli timitztlajtolcahuilijtoque timitzmacase. 
\q1  
\v 2 Ta technanquilía quema timotlatlajtíaj huan techmaca catli timitztlajtlaníaj, 
\q1 huajca nochi masehualme ipan tlaltipactli ma hualaca campa ta. 
\q1  
\v 3 Masque toyolo temitoc ica tlajtlacoli huan techtlantoc, 
\q1 ta techtlapojpolhuía nochi totlaixpanolis. 
\q1  
\v 4 ¡Nelía tipaquij miyac tojuanti catli techtlapejpenijtoc para ma tihualaca, 
\q1 huan ma tiitztoquij mohuaya ipan motiopa catli tlatzejtzeloltic! 
\q1 ¡Ta techmacas hueyi paquilistli huan nochi catli cuali catli onca nopona! 
\q1  
\v 5 Quema timitztlajtlaníaj se tlamantli, 
\q1 ta technanquilía ica huejhueyi tlamantli. 
\q1 Toteco Dios, nochi masehualme ipan tlaltipactli motemachíaj ipan ta. 
\q1 Quena, masque itztoque hasta campa ontlantoc hueyi atl, 
\q1 nochi motemachíaj para ta tiquinpalehuis. 
\q1  
\v 6 Ta ica mohueyi chicahualis tiquinchijchijqui nopa tepeme huan tiquintlatzquilti campa eltoc. 
\q1  
\v 7 Ta tijseseltía nopa hueyi atl quema mosisinía. 
\q1 Huan tiquinyoltlalía masehualme campa hueli quema quinequij mohuilanase. 
\q1  
\v 8 ¡Yeca nochi masehualme catli itztoque hasta campa ontlantoc tlaltipactli, 
\q1 mitztlepanitaj huan mitzimacasij para mitzixpanose quema quiitaj nopa huejhueyi tlamantli catli tijchihua! 
\q1 Tijchihua para masehualme ma paquica tlen quema tlanesi huan hasta quema tlayohuiya. 
\q1  
\v 9 Ta ticatequía ni tlaltipactli para ma tlaelilti. 
\q1 Nopa hueyame catli ta moaxca amo quema huaquij. 
\q1 Ta tijcualtlalía ni tlali para momasehualhua ma quitocaca ininxinach, 
\q1 huan teipa tijchihua para ma onca se hueyi pixquistli. 
\q1  
\v 10 Ta tijxolonía ica miyac atl nopa surcos ipan mila. 
\q1 Tijchihua ma huetzi atl para ma yamaniya nopa tlali huan ma poxoni nopa tlaltojtolomitl. 
\q1 Huan tijchihua para ma ixhua nochi tlamantli tlatoctli ipan nochi tlaltipactli. 
\q1  
\v 11 Teipa sesen xihuitl tijtlamiltía ica se pixquistli catli nelía yejyectzi. 
\q1 Huan nopa mixtli tijchihua para tlaquiyahuiltía miyac. 
\q1  
\v 12 Onca sacatl ipan huactoc tlali, 
\q1 huan campa tlaixtemolis moscaltíaj cuajcuali xihuitl, 
\q1 huan temacaj ininxochiyo. 
\q1 Nesi quen moscaltíaj ica miyac paquilistli. 
\q1  
\v 13 Ta tijchijtoc para nochi potreros ma temica ica borregojme para quicuase nopa sacatl. 
\q1 Huan ipan nochi nopa tlamayamitl motlanantoc trigo mili. 
\q1 Eltoc quen nochi catli ta tijchijtoc ipan tlaltipactli tzajtzij ica paquilistli huan huicaj. 
\c 66  
\s1 Se huicatl para quitlascamatis Toteco 
\q1  
\v 1 ¡Nochi anmasehualme ipan tlaltipactli, 
\q1 xihuicaca ica paquilistli para Toteco Dios! 
\q1  
\v 2 ¡Xihuicaca tiohuicatl catli tepohuilía para tlahuel hueyi ya! 
\q1 ¡Xijhueyimatica por nochi catli quichijtoc! 
\q1  
\v 3 Xiquilhuica Toteco Dios: 
\q1 “¡Nelía yejyectzi huan tetzatic nochi catli tijchijtoc! 
\q1 ¡Tlahuel hueyi mochicahualis! 
\q1 Yeca nochi mocualancaitacahua motemactilíaj ica ta pampa tlahuel temajmati catli tijchihua. 
\q1  
\v 4 Nochi masehualme ipan tlaltipactli mitzhueyichihuase. 
\q1 Inijuanti huicase para mitzhueyimatise, 
\q1 huan tepohuilise tlen mohueyitilis.” 
\q1  
\v 5 Xihualaca huan xiquitaquij nochi nopa huejhueyi tlamantli catli Toteco Dios quichijtoc. 
\q1 ¡Quinchihuilijtoc masehualme huejhueyi tiochicahual nextili! 
\q1  
\v 6 Quihuatzqui nopa atl huan tlatlajco nopa hueyi atl quitlapo se ojtli huactoc campa panoque tohuejcapan tatahua. 
\q1 ¡Nochi israelitame quipixque se hueyi paquilistli ipan nopa tonal! 
\q1  
\v 7 Toteco ica ichicahualis tlanahuatía para nochipa. 
\q1 Yaya quitlachilía sesen tlamantli catli masehualme quichihuaj ipan nochi tlalme ipan tlaltipactli. 
\q1 Catli amo quitlepanitaj huan catli mohueyimatij, 
\q1 yaya quinechcapantlalis. 
\q1  
\v 8 Nochi anmasehualme xijtlascamatica Toteco Dios huan xijhueyimatica, 
\q1 por nochi catli quichijtoc, 
\q1  
\v 9 pampa sesen tojuanti tonemilis eltoc imaco. 
\q1 Quena, yaya techmocuitlahuijtoc huan techyacantoc xitlahuac ipan toojhui. 
\b  
\q1  
\v 10 Pampa ta, tiToteco Dios, techyejyecojtoc huan techtlapajpacchijtoc, 
\q1 quen nopa tepos plata catli quimoloníaj ipan tlitl catli tlahuel totonic, 
\q1 para san mocahuas catli senquistoc cuali. 
\q1  
\v 11 Ta techmasilti ipan momatla huan tijtlali tocuitlapa tlamamali catli tlahuel etic. 
\q1  
\v 12 Tijchijqui ma cahuayojnemica topani catli ehuaj sequinoc tlalme. 
\q1 Tipanoque ipan atl huan ipan tlitl. 
\q1 Pero ama techtiochijtoc huan techmacatoc nochi catli cuali. 
\q1  
\v 13 Ama nihualajtoc ipan motiopa para nimitzmacas tlacajcahualistli tlatlatili. 
\q1 Huan quej nopa nijtlamichihuas catli nimitztlajtolcahuilijtoc para nijchihuas. 
\q1  
\v 14 Pampa quema niitztoya ipan tlaohuijcayotl, nimitztlajtolcahuili ica nocamac, 
\q1 para nimitzmacas miyac tlacajcahualistli. 
\q1  
\v 15 Yeca ama nimitzhualiquilía ni oquich borregojme, chivojme huan becerros catli tomahuaque. 
\q1 Huan ininpocyo tlejcos hasta ajsis moixpa. 
\b  
\q1  
\v 16 Nochi amojuanti catli anquitlepanitaj Toteco Dios huan anquiimacasij anquiixpanose, 
\q1 xihualaca xijtlacaquiliquij, 
\q1 huan nimechpohuilis nochi catli yaya nechchihuilijtoc. 
\q1  
\v 17 Chicahuac na nijtzajtzili para ma nechpalehui, 
\q1 huan quema nijcamanalhuiyaya, nijhueyimatiyaya. 
\q1  
\v 18 Pero sintla na amo niquilhuijtosquía Toteco notlajtlacolhua para ma nechtlapojpolhui, 
\q1 huajca amo nechtlacaquilijtosquía. 
\q1  
\v 19 Pero pampa niquilhui Toteco Dios ma nechtlapojpolhui, 
\q1 yaya nechtlacaquili huan quichijqui catli niquilhui. 
\q1  
\v 20 Xijpaquilismacaca Toteco Dios, 
\q1 pampa yaya nechtlacaquili huan amo quihuejcamajcajqui nocamanal quema nimotlatlajti. 
\q1 Nechtlasojtlac huan nechicneli. 
\c 67  
\s1 Se huicatl para quitlascamatis Toteco 
\q1  
\v 1 Toteco Dios, xijpiya hueyi moyolo ica tojuanti huan techtiochihua. 
\q1 Ma petlani moixayac pampa tipaqui ica tojuanti quema techhualtlachilía hasta tlen nepa ilhuicac. 
\q1  
\v 2 Nochi masehualme ipan tlaltipactli ma quiiximatica moojhui. 
\q1 Masehualme ipan nochi tlalme ma quimatica para ta titemaquixtía. 
\q1  
\v 3 NoTeco Dios, ma mitzpaquilismacaca nochi masehualme ipan tlaltipactli. 
\q1 Quena, nochi masehualme ma mitzhueyimatica. 
\q1  
\v 4 ¡Ma paquica nochi masehualme ipan nochi tlalme huan ma huicaca pampa ta, tiinintlanahuatijca! 
\q1 Ta tiquintlajtolsencahuas quen quinamiqui, 
\q1 huan nochi tlalme tiquinyacanas xitlahuac. 
\q1  
\v 5 ¡NoTeco Dios, ma mitzpaquilismacaca nochi ipan tlaltipactli! 
\q1 ¡Quena, nochi masehualme ma mitzhueyimatica! 
\q1  
\v 6 Ni tlali temacatoc miyac pixquistli, pampa ta, Toteco Dios, 
\q1 catli titoDios tojuanti, tlahuel techtiochijtoc. 
\q1  
\v 7 Quena, noja más techtiochihuas, Toteco Dios, 
\q1 huan masehualme campa hueli ipan ni tlaltipactli mitztlepanitase huan mitzimacasise mitzixpanose. 
\c 68  
\s1 Toteco Dios tlatlantoc 
\q1  
\v 1 ¡Ximotlanana, Toteco Dios, huan xiquinsemana nochi mocualancaitacahua! 
\q1 Xiquinchihua ma choloca tlen moixtla nochi catli amo mitzcualitaj. 
\q1  
\v 2 Xiquinixpolo quen poctli ixpolihui ipan ajacatl. 
\q1 Xiquintlamilti quen nopa cera catli atiya ipan tlitl. 
\q1 Quej nopa ma ininpanti moixpa nochi amo cuajcualme. 
\b  
\q1  
\v 3 Pero nochi masehualme catli itztoque xitlahuaque ma paquica iixpa Toteco Dios huan ma huitonica ica paquilistli. 
\q1  
\v 4 Xijhuicatica Toteco huan xijpaquilismacaca. 
\q1 Xijhueyitlalica yaya catli nejnemi iixco mixtli, 
\q1 yaya catli itoca TOTECO. 
\q1 Xipaquica miyac iixpa ya. 
\q1  
\v 5 Toteco Dios yaya inintata catli icnotzitzi. 
\q1 Yaya quinchihuilía catli xitlahuac nopa cahual toahuihua, 
\q1 pampa yaya tlatzejtzeloltic. 
\q1  
\v 6 Toteco Dios quinmaca ininchampoyohua catli itztoque ininseltzitzi. 
\q1 Huan quinchololtía catli quintzactoque. 
\q1 Pero catli motlepanitaj quintitlanilía mayantli huan tlaijiyohuilistli. 
\b  
\q1  
\v 7 NoTeco Dios, quema tiquinyacantiyajqui momasehualhua tlen tlali Egipto 
\q1 huan tiquinhuicac ipan nopa huactoc tlali, 
\q1  
\v 8 nopa tlali mojmolini huan huetzqui atl tlen ilhuicactli moixpa. 
\q1 Nopa tepetl Sinaí mojmolini moixpa ta catli titoTeco tiisraelitame. 
\q1  
\v 9 Toteco Dios, ta tijchijqui ma huetzi miyac atl ipan ni tlali catli tiquinmacac momasehualhua. 
\q1 Quena, ica nopa atl tiquinfuerzajmacac catli moaxcahua quema tlahuel siyajtoyaj 
\q1  
\v 10 Yeca momasehualhua mocajque nica ipan ni tlali. 
\q1 Huan ta ica motlaicnelijcayo tiquinmacac nopa teicneltzitzi nochi catli monequiyaya para ica mopanoltise. 
\b  
\q1  
\v 11 Toteco quiijto para ya tlatlantoya, 
\q1 huan miyac masehualme tzajtzique chicahuac para tepohuilise catli panotoc. 
\q1 Quiijtojque: 
\q1  
\v 12 “Cholojtejque nopa soldados catli hualajtoyaj para techtzontlamiltise.” 
\q1 Quena, ama nopa israelita sihuame momajmacaj nochi tlamantli catli quicajtejque nopa soldados. 
\q1  
\v 13 Xiquitaca, masque quinmocuitlahuiyayaj borregojme, 
\q1 ama nopa sihuame hasta petlanij ica oro huan plata. 
\q1 Nochi inintlacayo quitlamitzactoque ica tlamantzitzi catli yejyectzitzi quen se paloma quitlamitzacua itlacayo ica ieltlapal. 
\q1  
\v 14 Toteco Dios Catli Quipiya Nochi Chicahualistli quinsemanqui icualancaitacahua quen nopa setl catli huetzi ipan tepetl Salmón. 
\q1  
\v 15 Nochi nopa tepeme catli huejcapantique catli mopantíaj ipan tlali Basán iaxcahua Toteco huan nelía yejyectzi inintzonatipa, 
\q1  
\v 16 pero ma amo mochicoitas ica nopa Tepetl Sion catli TOTECO quitlapejpenijtoc para ipan itztos para nochipa. 
\q1  
\v 17 Toteco Dios quisqui ipan tepetl Sinaí ica millones icuacarros huan itequihuajcahua. 
\q1 Yaya yajqui ipan itiopa catli tlatzejtzeloltic ipan tepetl Sion. 
\q1  
\v 18 Quema Toteco tlejcoc ilhuicac campa más huejcapa, 
\q1 quichihuayaya quen se tlatlanquetl catli mocuepa ipan se tlahuilancayotl, 
\q1 huan quinhuicac ilpitoque nopa masehualme catli quintlantoya para iaxcahua. 
\q1 Huan nopa tonal Toteco quiseli nemactli tlen nochi masehualme, 
\q1 hasta nojquiya masehualme catli amo quinejque quitlepanitase. 
\q1 Huan ama TOTECO temachtli itztos ica tojuanti. 
\q1  
\v 19 Ma tijpaquilismacaca Toteco, 
\q1 pampa yaya mojmostla techmaca itlatiochihualis. 
\q1 Yaya Toteco catli techpalehuía huan techmaquixtía. 
\q1  
\v 20 Toteco Dios, yaya catli techchololtía ininmaco tocualancaitacahua. 
\q1 Huan yaya Toteco catli techmanahuía para amo timiquise. 
\q1  
\v 21 Temachtli Toteco quintzontlamiltis nochi icualancaitacahua, 
\q1 pampa inijuanti tlahuel yoltetique huan amo quinequij quicahuase inintlajtlacolhua. 
\q1  
\v 22 Toteco quinilhuijtoc imasehualhua: 
\q1 “Na niquinhualicas nochi amocualancaitacahua. 
\q1 Niquincuiti masque motlatijtose ipan nopa huejcapantic tepetl catli itoca Basán, 
\q1 o masque motlatijtose hasta tlatzintla tlen nopa hueyi atl. 
\q1  
\v 23 Niquinhualicas pampa monequi nochi anquintzontlamiltise. 
\q1 Inieso quixolonise amoicxihua huan amochichihua quipipitzose.” 
\b  
\q1  
\v 24 NoTeco Dios, tinotlanahuatijca, 
\q1 niquinita miyac masehualme mitztoquilíaj para yase ipan motiopa. 
\q1  
\v 25 Inijuanti catli huicaj tlayacantiyohuij. 
\q1 Tlatlajco yohuij nopa ichpocame catli quitzilinijtiyohuij panderos. 
\q1 Tlatepotzco yohuij catli tlatzotzonaj. 
\q1  
\v 26 Huan quej ni huicaj: 
\q1 “Nochi anisraelitame, xijhueyimatica Toteco Dios. 
\q1 Xijpaquilismacaca Toteco catli techmacatoc nemilistli nochi tojuanti.” 
\q1  
\v 27 Tlayacantiyohuij iixhuihua Benjamín. 
\q1 Huan tlatepotzco hualahuij nopa tlayacanani huan huehue tlacame tlen iixhuihua Judá, 
\q1 huan nopa tlayacanani catli iixhuihua Zabulón huan Neftalí. 
\q1  
\v 28 Toteco Dios, ica mohueyi chicahualis xijchihua nochi catli techilhuijtoc. 
\q1 Quena, xijnexti mohueyi chicahualis para sequinoc ma quiitaca nopa huejhueyi tlamantli catli ta techchihuilijtoc. 
\q1  
\v 29 Nopa tlanahuatiani tlen nochi tlalme quihualicaj iniofrendas ipan motiopa catli eltoc ipan altepetl Jerusalén. 
\q1  
\v 30 Toteco Dios, xiquinajhua tocualancaitacahua. 
\q1 Xiquinechcapantlali nopa tlacame catli mosisiníaj quen torojme, 
\q1 huan xiquinchihua ma motemactilica ica ta. 
\q1 Ma mitzhualiquilica inintepos plata quen se nemactli. 
\q1 Xiquinsemana nopa mosisinijca masehualme catli tlahuel quinpactía tlahuilanase. 
\q1  
\v 31 Nopa Egipto ehuani quinhualicase inintelpocahua huan nochi tlamantli ininteposhua catli yejyectzitzi huan pajpatiyo. 
\q1 Huan nopa Etiopía ehuani momatlananase moixpa para mitzhueyichihuase. 
\b  
\q1  
\v 32 Nochi antlanahuatiani ipan nochi ni tlaltipactli, 
\q1 xijhuicatica Toteco Dios. 
\q1 Xihuicaca huan xijpaquilismacaca Toteco. 
\q1  
\v 33 Yaya catli nentinemi ipan nopa ilhuicactli catli hasta huejcajya eltoc. 
\q1 Xijcaquica itoscac catli chicahuac caquisti quen quema tlatomoni. 
\q1  
\v 34 Xiquinpohuilica nochi masehualme quenicatza hueyi ichicahualis Toteco Dios. 
\q1 Huan itlatlanex ajsi ipan nochi israelitame. 
\q1 Quena, nelía tlahuel hueyi ichicahualis nepa ilhuicac. 
\b  
\q1  
\v 35 Ma tijhueyitlepanitaca Toteco Dios pampa temajmati ihueyitilis nopona ipan itiopa. 
\q1 ToDios tiisraelitame quinmaca tetili huan chicahualistli nochi imasehualhua. 
\q1 ¡Ma tijpaquilismacaca Toteco Dios! 
\c 69  
\s1 David quinotza Toteco ma quipalehuiqui 
\q1  
\v 1 NoTeco Dios, techmaquixti, 
\q1 pampa ni tlaohuijcayotl tlahuel mochijtoc hueyi hasta nijmachilía nimiquis. 
\q1 Eltoc quen atl catli nechatzonpolihuiltisnequi, 
\q1 huan ya ajsic hasta noquechtla. 
\q1  
\v 2 Eltoc quen nimasitoc ipan soquitl catli huejcatla huan amo hueli niquisa. 
\q1 O quen nechyahualosquía tlahuel miyac atl huan huejcatla. 
\q1  
\v 3 Tlahuel nichocatoc hasta nisiyajtoc. 
\q1 Nimitztzajtzilijtoc, Toteco Dios, hasta nechcocohua noquechtla huan ayacmo hueli nicamanalti. 
\q1 Nochi noixteyol samajtoc ica choquistli. 
\q1 Ya niixcuatqui pampa campa hueli nitlachixtoc para niquitas sintla tihuala, Toteco Dios, para techpalehuis. 
\q1  
\v 4 Tlahuel miyaqui nopa masehualme catli nechcualancaitaj masque amo tleno niquinchihuilijtoc. 
\q1 Nelía quipiyaj miyac chicahualistli nocualancaitacahua catli quinequij nechmictise. 
\q1 Pero na amo niquinixpanotoc. 
\q1 Quinequij nechtlatzacuiltise ica se tlamantli catli amo nijchijtoc. 
\q1  
\v 5 NoTeco Dios, ta tijmati para nelía nihuihuitic, 
\q1 huan tiquiximati nochi notlajtlacolhua. 
\q1  
\v 6 TOTECO, ta tiDios Catli Tijpiya Nochi Chicahualistli, 
\q1 amo xiquincahuili ma huetzica ipan tlajtlacoli por na notlajtlacol, 
\q1 nopa masehualme catli motemachíaj ipan ta. 
\q1 Ta catli titoTeco tiisraelitame, 
\q1 amo xiquincahuili ma mopinahuaca sequinoc israelitame ica catli nijchijtoc na. 
\q1  
\v 7 Pampa nimitzicnelía, niquijiyohuijtoc pinahualistli, 
\q1 huan nechhuetzquilijtoque hasta amo nijmatqui tlaque nijchihuasquía. 
\q1  
\v 8 Hasta noicnihua nechchihuaj quen amo nechiximatij huan nechitaj, 
\q1 quen se niseyoc altepetl ejquetl. 
\q1  
\v 9 Quena, niquicnelía motiopa ica nochi noyolo masque ica ya nopa monequi nimiquis. 
\q1 Huan catli mitztlaijilhuíaj ta, 
\q1 nojquiya nechtlaijilhuíaj na pampa nimitztequipanohua. 
\q1  
\v 10 ¡Quena, tlahuel nechhuetzquilíaj huan nechpinajtíaj, 
\q1 quema nichoca huan nimosahua iixpa Toteco! 
\q1  
\v 11 ¡Tlahuel fiero camanaltij tlen na quema nimoquentía yoyomitl catli sosoltic para nijnextis nimotequipachohua por notlajtlacolhua! 
\q1  
\v 12 Nopa tlayacanca tequitini catli mosehuíaj ipuertajteno altepetl, 
\q1 noca motlahuetzquiltíaj. 
\q1 Huan nopa ihuintini noca huicatinemij. 
\q1  
\v 13 Pero TOTECO na nijsenhuiquilía nimitztemohua huan nimotlatlajtía ipan ta, 
\q1 pampa nijmati ajsis tonali para techtlacaquilis. 
\q1 Toteco Dios, ica mohueyi tlaicnelilis technanquili, 
\q1 pampa ta nochipa techicnelijtoc. 
\q1 Huajca technanquili quema nimotlatlajtía huan techmanahui. 
\q1  
\v 14 Techquixti tlen ni soquitl catli huejcatla campa nimasitoc. 
\q1 Amo techcahuili para niatzonpolihuis. 
\q1 Techmanahui ininmaco catli nechcualancaitaj. 
\q1 Techquixti tlen ni hueyi atl catli nechyahualojtoc. 
\q1  
\v 15 Amo xijcahuili ma nechtlaijiyohuilti ni miyac atl catli ajsitoc, 
\q1 niyon amo xijcahuili nopa atl ma nechtolo. 
\q1 Techmanahui para amo nimasis ipan nopa ostotl catli tlahuel huejcatla. 
\q1  
\v 16 TOTECO, technanquili quema nimitztzajtzilía pampa ta nelía ticuali. 
\q1 Ta techicnelía miyac huan tijpiya hueyi moyolo ica na. 
\q1  
\v 17 ¡Amo ximotlati quema nimitztemohua pampa tlahuel nitlaijiyohuía! 
\q1 Ximoisihuilti, xihuala huan techmaquixtiqui. 
\q1  
\v 18 Xihuala, noTeco Dios huan techmanahuiqui. 
\q1 Techmaquixti ininmaco nocualancaitacahua. 
\q1  
\v 19 Ta tijmati quenicatza camanaltij fiero tlen na huan quenicatza nechpinahualtijtoque. 
\q1 Quichijtoque para ayacmo aqui ma nechtlepanita. 
\q1 Ta tiquiniximati nochi nocualancaitacahua huan tijmati tlaque quiijtojtoque sesen inijuanti. 
\q1  
\v 20 Inijuanti tlahuel nechyolcocojtoque huan nechtequipacholmacatoque. 
\q1 Nijtemojtoc ajqueya nechtlasojtlasquía huan nechyoltlalisquía, 
\q1 pero niyon se amo nijpanti. 
\q1  
\v 21 Quema nimayanayaya nechmacaque pajtli catli temictía para notlacualis. 
\q1 Huan quema niamiquiyaya nechmacaque ma niquiji vinagre. 
\q1  
\v 22 Nopa paquilistli catli inijuanti quipiyaj ma mocuepa tequipacholi. 
\q1 Huan nopa tlasehuilistli catli quipiyaj ica ininhuampoyohua, 
\q1 ma mocuepa cualancayotl. 
\q1  
\v 23 Ma huala ininpani tzintlayohuilotl huan ma huihuipicaca pampa ayacmo quipiyase más fuerza. 
\q1 Ma elica popoyotzitzi huan ma tlami nochi ininchicahualis. 
\q1  
\v 24 Xiquinnextili mohueyi cualancayo huan xiquintzontlamilti. 
\q1  
\v 25 Ipan inintequicalhua ma mocahua tlasosoltic, 
\q1 huan ipan ininchajchaj ma tlatzitzicato. 
\q1 Ayacmo aqui ma itzto. 
\q1  
\v 26 Pampa inijuanti más quitlaijiyohuiltíaj catli ta tijcocojtoc, 
\q1 huan quipinajtíaj catli ta tijtequipacholmacatoc. 
\q1  
\v 27 Xiquijcuilo nochi inintlajtlacolhua huan amo xiquintlapojpolhui. 
\q1  
\v 28 ¡Xiquixpolo inintoca ipan moama campa eltoc inintoca inijuanti catli yoltoque! 
\q1 ¡Ma amo quipiyaca tlasehuilistli quen quipiyaj nopa masehualme catli itztoque xitlahuaque moixpa! 
\q1  
\v 29 Pero na catli nitlaijiyohuía huan niteicneltzi, 
\q1 techmaquixti huan techtlanana. 
\q1 Quena, Toteco Dios, techtlali campa ta tiquitas quinamiqui. 
\b  
\q1  
\v 30 Huan huajca nihuicas huan nijpaquilismacas Toteco Dios. 
\q1 Quena, nijhueyimatis huan nijtlascamatis. 
\q1  
\v 31 Huan TOTECO achi más quipactis ya nopa, 
\q1 huan amo quen sintla nijmacasquía se toro o se becerro catli tlacuacuajhuía huan quipiya iistihua. 
\q1  
\v 32 Inijuanti catli teicneltzitzi quiitase Toteco Dios quema quinmacas itlapalehuil, 
\q1 huan yeca tlahuel paquise. 
\q1 Huan nochi catli quitemohuaj Toteco Dios itztose ica paquilistli. 
\q1  
\v 33 Pampa TOTECO quintlacaquilía catli teicneltzitzi, 
\q1 huan amo quintlahuelcahua inijuanti catli itztoque ipan tlatzactli. 
\q1  
\v 34 ¡Xijpaquilismacaca TOTECO nochi amojuanti catli anitztoque ipan ilhuicactli huan tlaltipactli! 
\q1 ¡Ma quihueyichihuaca nochi catli itztoque ipan hueyi atl! 
\q1  
\v 35 Pampa Toteco Dios quimaquixtis ialtepe, Jerusalén, 
\q1 huan sempa quincualtlalis nopa altepeme ipan tlali Judá. 
\q1 Huan imasehualhua mochantise nopona huan moaxcatise nopa tlali. 
\q1  
\v 36 Huan teipa ininconehua nojquiya moaxcatise nopa tlali. 
\q1 Huan nochi catli quitequipanohuaj huan quiicnelíaj Toteco itztose nopona temachme. 
\c 70  
\s1 Se netlatlajtili para Toteco ma quipalehuiqui 
\q1  
\v 1 ¡NoTeco Dios, xihuala techmanahuiqui ininmaco nocualancaitacahua! 
\q1 ¡Quena, ximoisihuilti, Toteco Dios! 
\q1 ¡Xihuala techpalehuiqui! 
\q1  
\v 2 Inijuanti nentinemij notepotzco huan paquij quema nechtlaijiyohuiltíaj. 
\q1 Yeca nimitztlajtlanía xiquinpinahualti, 
\q1 huan xiquincuepalti para ayacmo ma nechchihuilica catli fiero. 
\q1  
\v 3 Xiquincuepa ica pinahualistli huan ayacmo xiquincahuili ma nechpinajtica. 
\q1  
\v 4 Pero nochi masehualme catli mitztemohuaj, 
\q1 xiquinmaca miyac paquilistli. 
\q1 Nochi catli paquij pampa tiquinmaquixtijtoc, ma quiijtoca: 
\q1 “Ma tijhueyitlalica Toteco Dios.” 
\q1  
\v 5 Pero na catli tlahuel nitlaijiyohuía, 
\q1 nimitztlajtlanía xihuala nimantzi huan techmanahuiqui, 
\q1 pampa san ta hueli techpalehuis huan techmaquixtis. 
\q1 ¡NoTeco Dios, amo xihuejcahua! 
\c 71  
\s1 Netlatlajtili tlen se huehue tlacatl catli itztoc xitlahuac iixpa Toteco 
\q1  
\v 1 ¡TOTECO, na san ipan ta nimotemachijtoc! 
\q1 ¡Amo quema techpinahualti! 
\q1  
\v 2 ¡Techmanahui tlen nocualancaitacahua, 
\q1 pampa ta tixitlahuac! 
\q1 ¡Techchololti ininmaco! 
\q1 Ximohuijtzoma quentzi para techtlacaquilis huan techmaquixti. 
\q1  
\v 3 Nochipa san nimotlatijtoc huan nimotemachijtoc ipan ta para amo nechajsise nocualancaitacahua. 
\q1 Nijmati para ta titlanahuatijtoc ma nechmaquixtica pampa san ipan ta huelis nimomanahuis. 
\q1  
\v 4 NoTeco Dios, techmanahui ininmaco ni mosisinijca tlacame huan temictiani. 
\q1  
\v 5 TOTECO, ta catli titoTeco, san ipan ta nimotlatzquilijtoc, 
\q1 huan san ipan ta nimotemachijtoc hasta tlen quema niconetzi. 
\q1 Huan quej nopa nitelpocatixqui. 
\q1  
\v 6 Ta nochipa tiitztoc nohuaya hasta quema noja niitztoya iijtico nonana. 
\q1 Quena, tlen iijtico nonana ta techquixti huan nochipa techpalehuijtoc. 
\q1 ¡Yeca tlahuel nijnequi nimitzpaquilismacas para nochipa! 
\q1  
\v 7 Miyac san nechsentlachilíaj pampa quiitaj quenicatza techmocuitlahuía. 
\q1  
\v 8 Semilhuitl nimitzpaquilismacas huan nimitzhueyimatis por nochi catli techchihuilijtoc. 
\q1  
\v 9 Amo techtlahuelcahua ama quema ya nihuehuentzi huan ayacmo nijpiya fuerza. 
\q1  
\v 10 Pampa nocualancaitacahua nechejelnamiquij, 
\q1 huan san sejco mosentilijque ininhuaya sequinoc catli quinequij nechmictise. 
\q1  
\v 11 Huan quiijtohuaj: 
\q1 “¡Ma tijtepotztocaca para tiquitzquise pampa iDios ya quitlahuelcajtoc, 
\q1 huan amo aqui huelis quimanahuis!” 
\q1  
\v 12 ¡Toteco Dios, amo ximohuejcachihua tlen na! 
\q1 ¡NoTeco, xihuala nimantzi techpalehuiqui! 
\q1  
\v 13 Xiquinpinahualti huan xiquintzontlamilti nopa nocualancaitacahua catli quinequij nechchihuilise catli fiero. 
\q1 Quena, ma ayacmo quimatica tlaque quichihuase. 
\q1  
\v 14 Pero na más nimotemachis mopan ta para techpalehuis. 
\q1 Huan noja más nimitzpaquilismacas. 
\q1  
\v 15 Nochi masehualme niquinilhuis para san ta ticuali huan niquinpohuilis quenicatza techmanahuijtoc, 
\q1 huan techmocuitlahuijtoc mojmostla. 
\q1 Amo hueli nijpohuas quesqui huelta techmanahuijtoc ica catli amo cuali pampa tlahuel miyac. 
\q1  
\v 16 Nochi tonali ninejnemi ica nopa chicahualistli catli techmaca, TOTECO, ta catli tinoDios. 
\q1 Huan nochi masehualme niquinilhuía para san ta tixitlahuac huan ticuali. 
\q1  
\v 17 ¡Toteco Dios, ta techpalehuijtoc hasta quema noja nieliyaya niconetzi! 
\q1 Hasta ama noja niquinpohuilijtinemi sequinoc tlen nopa huejhueyi tlamantli catli tijchijtoc. 
\q1  
\v 18 ¡Toteco Dios, ama quema ya nihuehuentzi huan nitzonchipahuac, 
\q1 amo techtlahuelcahua! 
\q1 Noja techmaca nemilistli para niquinpohuilis tlen mohueyi chicahualis ni masehualme catli itztoque ama huan catli teipa tlacatise. 
\q1  
\v 19 Toteco Dios, mochicahualis huan catli xitlahuac tijchihua onajsi hasta ilhuicac. 
\q1 Ta tijchijtoc huejhueyi tlamantli. 
\q1 Amo onca seyoc Dios quen ta. 
\q1  
\v 20 Ta techcahuilijtoc ma nijpano huejhueyi tlaohuijcayotl huan tequipacholi. 
\q1 Pero nijmati para teipa, sempa techtlananas tlen campa nopa ostotl, 
\q1 huan tijchihuas ma nimoyolcui. 
\q1 Huan sempa nijpiyas nemilistli. 
\q1  
\v 21 Huan huajca achi más techhueyitlalis huan sempa techyoltlalis. 
\q1  
\v 22 Huan na nimitzpaquilismacas ica tlatzotzonali tlen arpa huan guitarra. 
\q1 NoTeco Dios, nihuicas tiohuicatl catli tepohuilía para tijchihua nochi catli tiquijtohua. 
\q1 Ta titoTeco tiisraelitame huan titlatzejtzeloltic huan nelía titemachtli. 
\q1  
\v 23 Ica paquilistli nitzajtzis huan nihuicas para niteilhuis quenicatza techmaquixtijtoc. 
\q1  
\v 24 Semilhuitl nitepohuilis para ta tijchihua catli xitlahuac, 
\q1 pampa nochi catli quinequiyayaj nechmictise tiquinpinahualti huan tiquinechcapantlali. 
\c 72  
\s1 Itlanahuatilis nopa tlanahuatijquetl catli itztoc xitlahuac iixpa Toteco 
\q1  
\v 1 NoTeco Dios, techmaca motlamachtil huan techpalehui na catli nitlanahuatijquetl, 
\q1 para ma nitetlajtolsencahua xitlahuac quen ta titetlajtolsencahua. 
\q1 Huan xijpalehui nocone para ma monejnemilti xitlahuac teipa. 
\q1  
\v 2 Xijpalehui para ma quintlajtolsencahuas xitlahuac nochi momasehualhua, 
\q1 huan catli teicneltzitzi nojquiya. 
\q1  
\v 3 Xijchihua para nochime ipan ni tlali ma paquica pampa nopa tlanahuatijquetl quichihua catli xitlahuac, 
\q1 hasta eltoc quen nochi cuame catli onca ipan tepeme huan ipan tlachiquilme nojquiya paquij huan temacaj cuali inintlajca. 
\q1  
\v 4 Yaya quinmanahuis catli itztoque ipan tequipacholi huan catli amo tleno quipiyaj. 
\q1 Nojquiya ma quintlatzacuilti nopa masehualme catli tetlaijiyohuiltíaj. 
\q1  
\v 5 Huan catli teicneltzitzi huan amo tleno quipiyaj mitzimacasise mitzixpanose nochi tonali quema noja eltos tonati huan metztli. 
\q1 ¡Quena, ma mitzhueyimatica para nochipa! 
\q1  
\v 6 Huan nochi altepeme ipan itlanahuatilis nocone ma eli yejyectzi huan temachtli, 
\q1 quen nopa atl catli huetzi para ma chamanica cuame, 
\q1 o quen nopa ajhuachtli catli quixolonía nopa tlali. 
\q1  
\v 7 Huan nochi masehualme catli itztoque xitlahuaque huan cuajcualme, 
\q1 ma itztoca ica yejyectzi quema yaya tlanahuatis. 
\q1 Quema yaya tlanahuatis, oncas miyac tlasehuilistli hasta itlamiya tonali. 
\q1  
\v 8 Itlanahuatilis nocone ma ajsi hasta campa pehua huan hasta campa ontlami nopa hueyi atl. 
\q1 Ma ajsi tlen campa nopa hueyi atl Eufrates hasta campa ontlantoc tlaltipactli. 
\q1  
\v 9 Nochi masehualme catli itztose ipan huactoc tlali mohuijtzomase iixpa, 
\q1 huan icualancaitacahua motlancuaquetzase iixpa hasta quipipitzose tlaltejpoctli. 
\q1  
\v 10 Nochi nopa tlanahuatiani catli itztoque itejteno nopa hueyi atl catli itoca Mediterráneo, 
\q1 huan nopa tlanahuatiani tlen tlali Tarsis huan nopa tlanahuatiani tlen tlali Sabá huan Seba quihualiquilise miyac nemactli. 
\q1  
\v 11 ¡Quena, nochi tlanahuatiani tlen campa hueli tlalme quitlanemactise! 
\q1 ¡Huan nochi inijuanti motlancuaquetzase iixpa huan quitequipanose! 
\q1  
\v 12 Yaya quinmanahuis nopa teicneltzitzi huan catli amo tleno quipiyaj quema quitlajtlanise tlapalehuili. 
\q1 Pampa inijuanti amo quipiyaj ajqueya quinpalehuis. 
\q1  
\v 13 Yaya quintlasojtlas catli amo quipiyaj chicahualistli huan catli teicneltzitzi, 
\q1 huan quinmanahuis. 
\q1  
\v 14 Quinmanahuis para amo quintlaijiyohuiltise huan para amo quinhuilanase. 
\q1 Pampa quiitas para ininnemilis tlahuel miyac ipati iixpa. 
\q1  
\v 15 Huan quema noja itztos nopa tlanahuatijquetl, 
\q1 quimacase miyac oro catli onca ipan tlali Sabá. 
\q1 Huan imasehualhua quisenhuiquilijtose motlatlajtijtose ica Toteco huan mojmostla quitlascamatise. 
\q1  
\v 16 Ma oncas miyac trigo ipan nochi nopa tlali, 
\q1 huan hasta nopa cuame catli onca ipan tepeme ma temacase inintlajca quen temacaj nopa cuame catli onca ipan tlali Líbano. 
\q1 Huan ma onca miyac masehualme ipan altepeme, 
\q1 quen imiyaca nopa xihuime catli onca ipan cuatitlamitl. 
\q1  
\v 17 Nochime ma quihueyimatica nopa tlanahuatijquetl para nochipa, 
\q1 huan itequiticayo ma huejcahua quen huejcahuas tonati. 
\q1 Nochi ma quiselica tlatiochihualistli por ya. 
\q1 Huan masehualme ipan nochi tlalme ma quipaquilismacaca, 
\q1 huan ma quiijtoca para Toteco quintiochijtoc. 
\q1  
\v 18 Ma tijhueyichihuaca TOTECO Dios catli toDios tiisraelitame, 
\q1 pampa san yaya hueli quichihua huejhueyi tlamantli. 
\q1  
\v 19 Nochipa ma tijpaquilismacaca Toteco. 
\q1 ¡Nochi tlaltipactli ma temi ica ihueyitilis! 
\q1 ¡Ma quej nopa eli! 
\q1  
\v 20 Nica tlami motlatlajtía David, icone Isaí. 
\c 73  
\s1 Itlaicnelilis Toteco Dios 
\q1  
\v 1 Toteco Dios nelía cuali iyolo ica israelitame. 
\q1 Quena, quinicnelía nochi catli quipiyaj tlapajpactic ininyolo. 
\q1  
\v 2 San quentzi polihuiyaya para nihuetztosquía. 
\q1 Noicxihua xitlaniyaya huan nechcatitoya para nimomimilos tlatepexico. 
\q1  
\v 3 Quej nopa nielqui pampa amo niquijiyohui para amo niquixtocas quema niquitac quenicatza tlapijpiyayayaj nopa masehualme catli mohueyimatij huan catli tlaixpanoj. 
\q1  
\v 4 Itztoque cuali ipan nochi ininnemilis, 
\q1 huan amo mococohuaj. 
\q1  
\v 5 Amo quinajsi tlaohuijcayotl niyon tequipacholi, 
\q1 quen sequinoc quipiyaj. 
\q1  
\v 6 Yeca quema mohueyimatij, quiitaj para yejyectzi quen se costli catli tlachijchihuali ica piltetzitzi catli pajpatiyo. 
\q1 Huan quema quichihuaj catli amo cuali, 
\q1 quiitaj quen ininyoyo catli yejyectzi. 
\q1  
\v 7 Nopa tlaixpanoca masehualme ya quiijquisas iniixteyol pampa tlahuel motomajtoque, 
\q1 huan ya quipixtoque nochi catli ininyolo quinequij. 
\q1  
\v 8 Inijuanti san quihuetzquilíaj Toteco huan quintemajmatíaj imasehualhua. 
\q1 Mohueyimatij quema camanaltij. 
\q1  
\v 9 Fiero quitlaijilhuíaj Toteco Dios catli itztoc ipan ilhuicactli. 
\q1 Huan quintelchihuaj catli itztoque ipan ni tlaltipactli. 
\q1  
\v 10 Yeca Toteco Dios quinhualicas sempa nochi imasehualhua ipan ni inialtepe, 
\q1 huan quipiyase miyac atl nochi inijuanti. 
\q1  
\v 11 Huan quiijtose: 
\q1 “¿Atlac Toteco quimatis tlaque pano? 
\q1 ¿Atlac Yaya Catli Más Hueyi quichihuilía cuenta catli pano nica?” 
\q1  
\v 12 Xiquitaca, ni masehualme catli amo tleno quineltocaj amo tleno ininpati. 
\q1 Quipiyaj se yejyectzi nemilistli huan tlatoctzitzi quimiyaquilíaj más inintomi. 
\q1  
\v 13 ¡Amo tleno nechpalehuía para nijpiya noyolo tlapajpactli, 
\q1 huan san tlapic nimocuatotonía para amo nijchihuas tlajtlacoli! 
\q1  
\v 14 Pampa nochi se tonal nechtlatzacuiltíaj huan nechtlaijiyohuiltíaj sesen ijnaloc. 
\b  
\q1  
\v 15 Sintla nicamanaltitosquía quen inijuanti, 
\q1 huajca niquincajcayajtosquía nochi momasehualhua. 
\q1  
\v 16 Quema nijnejqui nijmachili para tlen itztoque cuali nopa masehualme catli quicualancaitaj Toteco, 
\q1 elqui tlahuel ohui para nijmachilis. 
\b  
\q1  
\v 17 Pero se tonal nicalajqui ipan motiopa, Toteco Dios, para nimonejnehuilis tlen nopa tlamantli, 
\q1 huan huajca nijmachili tlaque quinchiya. 
\q1  
\v 18 Tiquintlalijtoc ipan se ojtli catli tlahuel alaxtic. 
\q1 Quema tiquincuatopehuas, 
\q1 huajca nimantzi huetzise ipan se hueyi ostotl huan nopona tzontlamise. 
\q1  
\v 19 Quena, ica se tlatoctzi tlamis nochi ininpaquilis. 
\q1 Huan itztose ipan majmajtli para nochipa. 
\q1  
\v 20 ¡Nochi ininnemilis eltoc quen se temictli! 
\q1 Quena, quen quema se cochtoc huan isatiquisas, 
\q1 Toteco, quej nopa quema timotlananas huan tiquinhuejcamajcahuas. 
\q1  
\v 21 Quema niquitac ya ni, 
\q1 nelía tlahuel nicualanqui huan hasta nechcocohuayaya noyolo. 
\q1  
\v 22 Pampa niquitac para tlahuel nihuihuitic nieltoya. 
\q1 ¡Hasta ninesiyaya moixpa quen se nitlapiyali catli amo quipiya itlalnamiquilis! 
\q1  
\v 23 Pero masque ya ni nopantic, nochipa niitztoc mohuaya ta, Toteco, 
\q1 huan techitzquijtoc ipan nomanejmac. 
\q1  
\v 24 Huan nijmati para motlamachtil quisenhuiquilis nechyacanas ipan nochi nonemilis. 
\q1 Huan teipa, quema nimiquis, 
\q1 techselis nepa mochaj campa tlayejyectzi. 
\q1  
\v 25 Amo aqui seyoc nijpiya nepa ilhuicac. 
\q1 ¡San ta, tinoTeco Dios! 
\q1 ¡Huan san ta nimitznequi ipan ni tlaltipactli huan amo aqui más! 
\b  
\q1  
\v 26 Quemantic nimococohua huan nimotequipachohua. 
\q1 ¡Pero Toteco Dios yaya mocahua para nochipa! 
\q1 Yaya quifuerzajmaca noyolo huan san yaya noaxca para nochipa. 
\q1  
\v 27 Pero Toteco quintzontlamiltis nochi catli amo quinequij quihueyichihuase. 
\q1 Quena, yaya quintzontlamiltía nochi catli quitlahuelcahuaj. 
\q1  
\v 28 Pero na achi más nimonechcahuis campa Toteco Dios, 
\q1 pampa ya nopa catli más cuali para na. 
\q1 San ipan TOTECO nimotemachijtoc pampa yaya noTeco. 
\q1 Huan niquinpohuilis nochime nochi nopa yejyectzi tlamantli catli yaya nechchihuilía. 
\c 74  
\s1 Quema tocualancaitacahua hualahuij, ma tijtemoca Toteco 
\q1  
\v 1 Toteco Dios, ¿para tlen techtlahuelcajtoc para nochipa? 
\q1 ¿Para tlen tlahuel ticualani ica tojuanti catli tiitztoque quen timopilborregojhua? 
\q1  
\v 2 Xiquelnamiqui para tojuanti timomasehualhua catli timocohui huejcajya quema titetequipanohuayayaj san tlapic. 
\q1 Quena, techtlapejpeni para techchihuas timoaxcahua. 
\q1 Nojquiya tijtlapejpeni nopa altepetl Jerusalén para tijchihuas quen elisquía mochaj ipan ni tlaltipactli. 
\q1  
\v 3 Xihuala xiquitaqui quen quitlamisosolojtoque nopa altepetl, 
\q1 huan xijtlachili quenicatza tocualancaitacahua quisosolojtoque motiopa. 
\q1  
\v 4 Nopona tzajtzique mocualancaitacahua ica paquilistli quema tlasosolojque. 
\q1 Teipa san techhuetzquilijque huan quinquetzque ininteteyohua para quinextise ya techtlantoyaj. 
\q1  
\v 5 Hualajque ica ininhachas huan huejhueyi martillos hasta nesiyaya quen cuajcuahuini tlatlajco cuatitlamitl. 
\q1  
\v 6 Huan ama ica ininteposhua quitlapanque huan quisosolojtoque nochi tlamantli catli ica tlayejyecchijtoyaj motiopa. 
\q1  
\v 7 Quena, motiopa quitlatijque, 
\q1 huan quimahuispolojque moixpa nopa catli quihuicayaya motoca, 
\q1 huan quitlahuisojque tlalchi. 
\q1  
\v 8 Huan quiijtojque ipan ininyolo: 
\q1 “Ma tijtlamisosoloca nochi catli onca ipan ni tlali.” 
\q1 Huan yajque campa hueli huan quitlatijque nochi israelita tiopame, 
\q1 campa timosentiliyayaj para timitzhueyichihuase, Toteco Dios. 
\q1  
\v 9 Ayacmo onca niyon se tlamantli catli quinextía para timomasehualhua. 
\q1 Ayacmo onca tlajtol pannextiani. 
\q1 Ayacmo aqui huelis techilhuis hasta quema tlamis nochi ya ni. 
\q1  
\v 10 Toteco Dios, ¿hasta quema tlamis mitzmahuispolohuaj mocualancaitacahua? 
\q1 ¿Atlac amo quema tiquintlatzacuiltis? 
\q1  
\v 11 ¿Para tlen tihuejcahua para techpalehuis? 
\q1 ¿Para tlen amo tijnextía mohueyi chicahualis huan techpalehuía? 
\q1  
\v 12 Hasta tlen huejcajya Toteco Dios itztoya notlanahuatijca. 
\q1 Yaya nechpalehuijtoc ipan ni tlaltipactli huan campa hueli campa niyajtoc. 
\q1  
\v 13 Ica mochicahualis tijxelo hueyi atl. 
\q1 Huan tiquintzontlamilti huejhueyi tlapiyalme catli temajmatijque catli itztoyaj ipan atl. 
\q1  
\v 14 Tijtzonxamani nopa hueyi tlapiyali catli itoca leviatán, 
\q1 huan inacayo tiquinmacac ma quicuaca nopa tecuanime catli itztoyaj ipan huactoc tlali. 
\q1  
\v 15 Tijchijqui ma meya atl ipan huejhueyi amelme huan para hueyame ma quipiyaca atl. 
\q1 Nojquiya tiquinhuatzqui hueyame catli amo quema huactoyaj. 
\q1  
\v 16 Ta moaxca tonali huan yohuali. 
\q1 Ta tijchijchijqui metztli huan tonati. 
\q1  
\v 17 Ta tijtamachijqui hasta canque tlamis tlaltipactli. 
\q1 Nojquiya ta tijchihua ma tlatotoniya huan ma tlaseseya. 
\q1  
\v 18 TOTECO, xiquita quenicatza mitzmahuispolohuaj mocualancaitacahua, 
\q1 huan quenicatza mitztlaijilhuíaj nopa masehualme catli mohueyimatij. 
\q1  
\v 19 ¡TOTECO, amo techtlahuelcahua! 
\q1 Xijmanahui mopaloma imaco nopa cuajtli. 
\q1 Quena, xiquinmanahui momasehualhua ininmaco nopa masehualme catli itztoque quen tecuanime. 
\q1  
\v 20 ¡Xiquelnamiqui nopa camanal sencahuali catli tijchijtoc tohuaya! 
\q1 Pampa ni tlali temitoc ica tzintlayohuilotl huan ica masehualme catli mosisiníaj. 
\q1  
\v 21 Amo xijcahua para tlatoctzitzi ma techmahuispoloca tojuanti catli tijpanotoque miyac tlaohuijcayotl. 
\q1 Xiquinpalehui catli teicneltzitzi huan amo tleno quipiyaj para huelis mitzpaquilismacase. 
\q1  
\v 22 Toteco Dios, ximotlanana huan ximomanahui ica catli quiijtohuaj mocualancaitacahua. 
\q1 Xiquelnamiqui nochi nopa camanali catli ica mitztlaijilhuijtoque nochi se tonal. 
\q1  
\v 23 Amo xiquelcahua quenicatza mitztelchijtoque mocualancaitacahua, 
\q1 pampa inijuanti noja más mitztlaijilhuíaj. 
\c 75  
\s1 Toteco quinechcapantlalis sequin huan quinhueyitlalis sequinoc 
\q1  
\v 1 ¡Timitztlascamatij, Toteco Dios, pampa tiitztoc tonechca! 
\q1 Pampa masehualme tepohuilíaj nochi huejhueyi tetzatl catli tijchijtoc. 
\q1  
\v 2 Huan Toteco Dios quiijtohua: 
\q1 “Quena, quema ya nimocualtlalijtos, na niquixquetzas se tonal. 
\q1 ¡Huan niquintlatzacuiltis quen quinamiqui nochi nopa tlaixpanoca masehualme! 
\q1  
\v 3 Masque ni tlaltipactli mojmolinis huan nochi masehualme huihuipicase, 
\q1 itlaquetzalhua amo huetzise pampa na niquinquetztoc cuali ipan ininlugar.” 
\q1  
\v 4 Niquinilhui masehualme catli mohueyimatij ma amo mohuihuinequica. 
\q1 Huan niquinilhui tlaixpanoca masehualme ma amo mohueyimatica. 
\q1  
\v 5 Niquinilhuijtoc catli quipiyaj chicahualistli ma amo tetlamiijilhuica. 
\q1 Huan quema ancamanaltij, amo ximoyacaquetzaca para anmohueyimatise. 
\q1  
\v 6 Pampa san Toteco hueli tehueyitlalía. 
\q1 Amo aqui catli huala tlen campa hualquisa tonati, o ica campa oncalaqui, 
\q1 o campa huactoc tlali huelis quihueyitlalis se masehuali. ¡Amo! 
\q1  
\v 7 San Toteco Dios itztoc Juez. 
\q1 San yaya nopa tetlajtolsencajquetl catli hueli tehueyitlalía huan temaca chicahualistli. 
\q1 Huan sequin masehualme quinhueyitlalía huan sequin quinechcapantlalía. 
\q1  
\v 8 Toteco quipixtoc imaco se caxitl catli temitoc ica huino catli nelía cococ. 
\q1 Huan ya nopa eltoc nopa tlatzacuiltili catli quintitlanilis tlaixpanoca masehualme ipan ni tlaltipactli. 
\q1 Huan monequis quiijise hasta quitlamise ica nochi itetejtzo. 
\q1  
\v 9 Pero na para nochipa nitepohuilis nochi catli quichijtoc Toteco Dios, 
\q1 yaya catli iTeco Jacob. 
\q1  
\v 10 Yaya quiijtohua: “Na nijtlamiltis ininchicahualis nopa fiero masehualme, 
\q1 pero catli itztoque xitlahuaque noja niquinmacas más chicahualistli.” 
\c 76  
\s1 Se huicatl catli huicaque quema ya tlatlanque 
\q1  
\v 1 Ipan tlali Judá huan hasta nochi tlali Israel nochi masehualme quiiximatij Toteco Dios para nelía hueyi. 
\q1  
\v 2 Itiopa eltoc ipan altepetl Jerusalén. 
\q1 Quena, ipan tepetl Sion moquetza ichaj. 
\q1  
\v 3 Nopona quipojpostejqui nochi tlamantli ininteposhua tocualancaitacahua. 
\q1  
\v 4 ¡Nopa tepeme catli eltoque tlen huejcajya amo quipiyaj ininyejyejca quen tepetl Sion quipiya! 
\q1  
\v 5 Nopa tocualancaitacahua catli más quipiyayayaj chicahualistli, 
\q1 quintlamitlacuijcuilijque. 
\q1 Toixpa tepejtoque mictoque. 
\q1 Niyon se tlen inijuanti ayacmo hueli quitlananas imax para techhuilanas. 
\b  
\q1  
\v 6 Quema ta tiToteco, catli tiiDios Jacob, tiquinajhuac nopa cahuayojme huan catli tlejcotoyaj ininpani, 
\q1 nochi huetzque hasta tlalchi. 
\q1  
\v 7 ¡Yeca nochi quiitaj para tlahuel titemajmati! 
\q1 Huan amo aqui huelis quiijiyohuis ijcatos moixpa quema tlahuel ticualantoc. 
\q1  
\v 8 Hasta nepa ilhuicac titlayolmelahua para titetlatzacuiltis. 
\q1 Huan ni tlaltipactli majmahui huan amo molinía moixpa, 
\q1  
\v 9 quema timotlananqui, Toteco Dios, 
\q1 para tiquintlatzacuiltis catli quichihuaj catli amo cuali, 
\q1 huan para tiquinmanahuis nochi catli moechcapanohuaj ipan ni tlaltipactli. 
\q1  
\v 10 Ta tijtequihuía inincualancayo masehualme para sequinoc ma mitzhueyimatica. 
\q1 Huan tijtequihuis para más monextis moyejyejca. 
\b  
\q1  
\v 11 Xijchihuaca nochi catli anquitlajtolcahuilijtoque TOTECO para anquichihuase. 
\q1 Sesen ma quihualica nopa tlamantli catli quitencahuilijtoc para quimacas Toteco Dios. 
\q1 Monequi ma tijhueyitlepanitaca huan ma tiquimacasica, 
\q1  
\v 12 pampa yaya quintlamiltilía ininnemilis nopa huejhueyi tlayacanani. 
\q1 Quichihuas para nochi tlanahuatiani ipan tlaltipactli ma quiimacasica. 
\c 77  
\s1 Monejnehuili David tlen catli Toteco quichijqui huejcajya 
\q1  
\v 1 Chicahuac nijtzajtzilía Toteco Dios para ma nechpalehui. 
\q1 Quena, nijnojnotza pampa nijnequi ma nechtlacaquilis. 
\q1  
\v 2 Quema nechajsic miyac tlaijiyohuilistli nimantzi nijtemo noTeco. 
\q1 Seyohual nimomatlanantoya huan nimotlatlajtiyaya, 
\q1 huan amo nijcahuili niyon se tlatoctzi. 
\q1 Amo nipaquis hasta yaya monextis huan nechcaquis. 
\q1  
\v 3 Nimonejnehuilía tlen Toteco Dios huan niyolpitzahuía huan nichoca. 
\q1 Nimotequipachohua pampa tlami nochicahualis, 
\q1 yeca tlahuel nijnequi ma nechpalehui. 
\b  
\q1  
\v 4 Toteco, ta amo techcahuili ma nicochis. 
\q1 Amo nechcahuilía nimotlatlajtis pampa tlahuel hueyi ni notequipachol. 
\q1  
\v 5 Tlatoctzitzi nimonejnehuilía tlen nopa yejyectzi tonali huan xihuime catli panoque huejcajya. 
\q1  
\v 6 Niquelnamiqui sesen tlayohua quema nihuicayaya ica paquilistli. 
\q1 Quena, nimotlajtlachilía huan niquita para ama nochi tlamantli tlahuel mopatlatoc. 
\b  
\q1  
\v 7 ¿Huelis Toteco nechtlahuelcajtoc para nochipa? 
\q1 ¿Huelis ayacmo quema nechpalehuis? 
\q1  
\v 8 ¿Huelis ya tlanqui itlaicnelilis ica na? 
\q1 ¿Huelis ya tlanqui catli achtihuiya techtlajtolcahuili techmacas? 
\q1  
\v 9 ¿Huelis Toteco Dios ya quielcajqui para monequi nechchihuilis catli cuali na catli niitztoc ipan tequipacholi? 
\q1 ¿Huelis tlahuel cualantoc huan yeca ayacmo quinequi nechtlasojtlas? 
\q1  
\v 10 Huan ipan nohueyi tequipachol nimoilhui: 
\q1 “Toteco Catli Más Hueyi mopatlatoc. 
\q1 Achtihui niitztoya inejmac huan nechtiochihuayaya miyac, 
\q1 pero ama nechcualancaita. 
\q1  
\v 11 Más cuali niquelnamiquis nochi nopa huejhueyi tiochicahual nextili catli TOTECO nechchihuili huejcajya.” 
\q1  
\v 12 Quena, mojmostla nimoilhuis tlen nopa huejhueyi tlamantli para nochipa. 
\q1 Amo hueli nijcahuas nimonejnehuilis tlen yaya quichijtoc. 
\b  
\q1  
\v 13 ¡NoTeco Dios, nelía tlatzejtzeloltic nochi moojhui! 
\q1 Amo aqui seyoc dios catli más quipiya chicahualistli que ta, titoTeco. 
\q1  
\v 14 ¡Ta tiDios catli tijchihua huejhueyi tiochicahual nextili huan miyac tlamantli catli masehualme quisentlachilíaj! 
\q1 Huan hasta ama quejipa tijnextía mohueyi chicahualis. 
\q1  
\v 15 Ica mohueyi chicahualis techmanahui, 
\q1 timomasehualhua catli tiiconehua Jacob huan José. 
\q1  
\v 16 Toteco Dios, nopa hueyi atl catli itoca Chichiltic momajmati quema mitzitac. 
\q1 Huan huihuipicac hasta tlatzintla campa más huejcatla. 
\q1  
\v 17 Nopa mixtli quichijqui ma tlaquiyahui chicahuac. 
\q1 Huan tlatomonqui nepa ilhuicac. 
\q1 Huan nojquiya tlapetlanqui tlen se lado hasta seyoc. 
\q1  
\v 18 Caquistic tlatomonilotl ipan nopa hueyi ajcomalacatl. 
\q1 Huan nopa tlapetlancayotl quitlahuili nochi tlaltipactli, 
\q1 huan ni tlaltipactli huihuipicac. 
\q1  
\v 19 Tijchijqui se ojtli quema tiquixcotonqui nopa hueyi atl, 
\q1 pero amo aqui quipanti campa tijquetztiyajqui moicxihua. 
\q1  
\v 20 Huan ipan ni ojtli tiquinyacanqui momasehualhua quen eltosquíaj pilborregojtzitzi ininmaco Moisés huan Aarón. 
\c 78  
\s1 Catli huejcajya panoc ipan tlali Israel 
\q1  
\v 1 Nomasehualhua, xijtlacaquilica notlamachtil huan nochi catli niquijtohua, 
\q1  
\v 2 pampa nimechnextilis tlamantli catli amo aqui más quimati catli panoc huejcaya. 
\q1  
\v 3 Tlamantli catli tijcactoque huan tijmajtoque pampa totatahua techpohuilijque. 
\q1  
\v 4 Quena, nimechmatiltis para anhuelise anquinpohuilise amoconehua nochi nopa yejyectzitzi huan huejhueyi tlamantli, 
\q1 catli TOTECO quichijqui ica ihueyi chicahualis. 
\q1  
\v 5 Toteco Dios quimacac miyac tlanahuatilme Jacob ipan tlali Israel para ma monejnemiltica xitlahuac, 
\q1 huan quinnahuati tohuejcapan tatahua ma quinnextilica ininconehua, 
\q1  
\v 6 huan iniixhuihua catli tlacatise teipa. 
\q1 Huan quej nopa nochi masehualme quiniximatise itlanahuatilhua Toteco. 
\q1  
\v 7 Yeca hasta ama miyac masehualme quintlepanitaj itlanahuatilhua Toteco Dios, 
\q1 huan motemachíaj ipan ya para quinmocuitlahuis. 
\q1 Huan amo ma quielcahuaca nochi nopa huejhueyi tlamantli catli quichijtoc Toteco. 
\q1 Monequi ma quitoquilijtinemica nochi itlanahuatilhua. 
\q1  
\v 8 Pampa amo quinamiqui para elise quen ininhuejcapan tatahua catli moyoltetilijque huan amo tlatlepanitaque. 
\q1 Inijuanti amo elque temachme ica Toteco Dios, 
\q1 niyon amo quimactilijque ininyolo, niyon ininnemilis. 
\q1  
\v 9 Nopa masehualme tlen tlali Efraín mocuepatoj huan cholojque ipan nopa tonali quema yohuiyayaj tlahuilanatij. 
\q1 Quena, cholojque masque quipiyayayaj miyac tepostli para tlahuilanase. 
\q1  
\v 10 Amo quintlepanitaque itlanahuatilhua Toteco Dios, 
\q1 huan amo quinejque nejnemise ipan iojhui. 
\q1  
\v 11 Quielcajque nochi tlamantli catli yaya hueli quichihua. 
\q1 Amo quielnamijque nopa yejyectzi tiochicahual nextili catli quichijqui Toteco. 
\q1  
\v 12 Quena, Toteco Dios quichijqui miyac tlamantli iniixpa ininhuejcapan tatahua ipan tlali Egipto campa itoca Zoán. 
\q1  
\v 13 Quitlajcoxelo nopa hueyi atl huan quichijqui ma panoca. 
\q1 Ipan ome lados nopa atl moquetzqui quen tepamitl. 
\q1  
\v 14 Ica tonaya quinyacanqui ica se mixtli para quinecahuilis, 
\q1 huan ica tlayohua ica se mixtli catli tlahuiyaya quen tlitl. 
\q1  
\v 15 Ipan huactoc tlali quitlapo nopa hueyi tetl huan quisqui miyac atl para atlique hasta aixhuique. 
\q1  
\v 16 ¡Quena, ipan tetl quisqui miyac atl catli motlalo quen se hueyatl! 
\q1  
\v 17 Pero inijuanti quisenhuiquilijque amo quitlepanitaque. 
\q1 Huan nepa campa huactoc tlali tlajtlacolchijque ica Toteco Catli Más Hueyi. 
\q1  
\v 18 Pampa quiyejyecojque Toteco Dios huan quitlajtlanijque tlacualistli catli ininyolo quinequiyaya. 
\q1  
\v 19 Hasta cualanque ica Toteco huan quiijtojque: 
\q1 “¿Atlac Toteco Dios huelis techtlamacas ipan ni huactoc tlali? 
\q1  
\v 20 Xiquitaca, Toteco Dios quitlapo nopa hueyi tetl huan quisqui miyac atl quen eltosquía se hueyatl hasta atzonpoli tlali, 
\q1 pero ¿atlac nojquiya hueli techmacas tlacualistli? 
\q1 ¿Huelis techtlamacas tiimasehualhua ica nacatl?” 
\q1  
\v 21 Huan quema TOTECO quicajqui ni tlamantli, tlahuel cualanqui. 
\q1 Huan ipan icualancayo quisqui tlitl ica israelitame, inijuanti catli iixhuihua Israel, 
\q1  
\v 22 pampa inijuanti amo quineltocaque Toteco Dios, 
\q1 niyon amo motemachijque ipan ya para quipiya chicahualistli para quinmaquixtis. 
\q1  
\v 23 Pero masque quej nopa quichijque, 
\q1 Toteco Dios quinahuati nopa mixtli huan quitlapo ilhuicactli. 
\q1  
\v 24 Huan quichijqui ma huetzi nopa tlacualistli catli itoca maná para ma quicuaca quen quema huetzi atl. 
\q1 Quinmacac tlacualistli catli hualajqui tlen ilhuicac. 
\q1  
\v 25 Masehualme quicuajque catli elqui inintlacualis itequihuajcahua Toteco. 
\q1 Quena, quintlamacac hasta cuali ixhuique huan hasta mocajqui nopa tlacualistli. 
\q1  
\v 26 Ica ihueyi chicahualis quihualicac nopa ajacatl catli huala campa hualquisa tonati huan catli huala ica tlani para ma tlaajaca campa ilhuicactli. 
\q1  
\v 27 Quichijqui ma hualaca miyaqui totome quen imiyaca tlaltejpoctli. 
\q1 Quena, hualajque totome quen mixtli huan quen imiyaca xali catli onca iteno hueyatl. 
\q1  
\v 28 Huan Toteco quichijqui para nopa totome ma huetzica tlatlajco campa quichijtoyaj ininyoyoncal. 
\q1  
\v 29 Huan nopa masehualme tlacuajque hasta ixhuique. 
\q1 Toteco quinmacac nacatl quen ininyolo quinequiyaya. 
\q1  
\v 30 Pero quema sanoc tlantoyaj tlacuaj, 
\q1 huan hasta noja quipixtoyaj nacatl ipan inincamac, 
\q1  
\v 31 Toteco Dios motlananqui ica ihueyi cualancayo, 
\q1 huan quintzontlamilti nochi nopa telpocame catli más tlapejpenilme ipan tlali Israel. 
\q1  
\v 32 Pero masque Toteco quinchihuili ya nopa, 
\q1 nopa masehualme quisenhuiquilijque tlajtlacolchijque, 
\q1 huan amo quineltocaque nopa huejhueyi tiochicahual nextili catli yaya quichijqui iniixpa. 
\q1  
\v 33 Yeca Toteco quintlaijiyohuilti ipan nochi ininnemilis huan quintzontlamilti san ica se tlatoctzi. 
\q1  
\v 34 Pero teipa, quema ya quintzontlamiltijtoya sequin, 
\q1 huajca quena, ne sequinoc quitemojque Toteco Dios. 
\q1 ¡Quena, nimantzi mocuepque huan quitoquilijque! 
\q1  
\v 35 Huan quielnamijque para yaya Toteco Dios catli quinmocuitlahuiyaya para amo quinajsis catli amo cuali. 
\q1 Huan quielnamijque para Toteco Catli Más Hueyi san yaya inintemaquixtijca. 
\q1  
\v 36 Pero nopa israelitame amo quitoquiliyayaj ica nochi ininyolo. 
\q1 ¡Amo! Quitoquiliyayaj san ica inincamac. 
\q1  
\v 37 Pampa ininyolo eltoya huejca tlen Toteco. 
\q1 Huan amo quichihuayayaj catli quitlajtolcahuilijtoyaj Toteco para quichihuase. 
\q1  
\v 38 Pero Toteco quipixqui hueyi iyolo ica inijuanti. 
\q1 Quintlapojpolhuiyaya inintlajtlacolhua huan amo quintzontlamiltiyaya. 
\q1 Miyac huelta quiquetzqui icualancayo para amo quintlatzacuiltis. 
\q1  
\v 39 Pampa Toteco quielnamijqui para inijuanti san elque masehualme catli ininnemilis ixpolihui san ica se tlatoctzi, 
\q1 huan amo quema mocuepasquíaj sempa. 
\q1  
\v 40 Nepa ipan huactoc tlali, 
\q1 tlahuel miyac huelta amo tlatlepanitaque ica Toteco Dios huan quiyolcocojque. 
\q1  
\v 41 Tlatoctzitzi quiyejyecojque, 
\q1 huan ica ya nopa quichihualtiyayaj para Toteco ma quintzontlamilti. 
\q1 Niyon amo quicahuilijque para Toteco ma quintiochihua, 
\q1 yaya catli ininDios israelitame huan catli Tlatzejtzeloltic. 
\q1  
\v 42 Quielcajque ihueyi chicahualis huan iteicnelijcayo. 
\q1 Huan quielcajque quenicatza quinmanahui ininmaco inincualancaitacahua. 
\q1  
\v 43 Quielcajque quenicatza Toteco quititlanqui tlatzacuiltili ipan tlali Tanis huan ipan tlali Egipto. 
\q1  
\v 44 Quielcajque quenicatza quicuepqui estli nopa atl huan ayacmo aqui huelqui quiijic. 
\q1  
\v 45 Quielcajque quenicatza quintitlanqui tlahuel miyac sayolime hasta quitemitijque nopa tlali. 
\q1 Quielcajque quenicatza nopa temasolime quitemitijque nopa tlali Egipto. 
\q1  
\v 46 Toteco quintitlanqui ocuilime huan chapolime para ma quicuaca inintlatochui huan ininpixquilis. 
\q1  
\v 47 Ica tesihuitl quintzontlamilti ininxocomecamil huan ininhigueramil. 
\q1  
\v 48 Ininhuacaxhua mijque ipan potrero pampa Toteco Dios quinmajcahuili tesihuitl catli tlahuel huejhueyi. 
\q1 Huan ininborregojhua mijque ica tlapetlancayotl. 
\q1  
\v 49 Quena, Toteco tlahuel cualanqui ica inijuanti, 
\q1 huan yeca quintitlanili tlacuajcualocayotl huan tlaohuijcayotl. 
\q1 Huan quintitlanili se pamitl tlen itequihuajcahua Toteco catli tetzontlamiltíaj. 
\q1  
\v 50 Cualanqui nelchicahuac huan amo quimanahui niyon se Egipto ejquetl. 
\q1 San quintitlanili tlatzacuiltili huan huejhueyi cocolistli. 
\q1  
\v 51 Teipa Toteco quinmicti nopa achtihui ehuani ipan sesen familia tlen tlali Egipto. 
\q1 Quena, quinmicti catli elqui iniachtihui fuerza quema pejque quinpiyaj coneme. 
\q1  
\v 52 Pero quinquixti imasehualhua quen elisquíaj pilborregojtzitzi, 
\q1 huan quinyacanqui ica yejyectzi ipan nopa huactoc tlali. 
\q1  
\v 53 Quinyacanqui ica miyac temachili para ma amo majmahuica. 
\q1 Pero nopa hueyi atl quinatzonpolihuilti inincualancaitacahua. 
\q1  
\v 54 Huan quinhuicac hasta campa inepa nopa tlali catli tlatzejtzeloltic. 
\q1 Nopa tlali catli quipiya miyac tepeme catli Toteco quintlanili para inijuanti. 
\q1  
\v 55 Iniixpa quintojtocac nopa masehualme catli itztoyaj ipan nopa tlali. 
\q1 Teipa quitamachijqui huan quinmajmacac nopa huejhueyi familias tlen israelitame para iniaxca. 
\q1 Huan nopona quincajqui ma itztoca. 
\q1  
\v 56 Pero masque quinchihuili ya nopa, 
\q1 inijuanti quisenhuiquilijque quiyejyecohuaj huan quicualancamacaj Toteco Catli Más Hueyi. 
\q1 Huan amo quinejque quitlepanitase icamanal. 
\q1  
\v 57 Yeca mocuepque para amo calaquise ipan nopa tlali tlatencahuali huan quicamaijixnamijque san se quen inintatahua quichijque. 
\q1 Huan quen se cuatlamintli catli huijcoltic amo yohui xitlahuac quema quimajcahuaj, 
\q1 inijuanti nojquiya amo yajque xitlahuac para quichihuase ipaquilis Toteco. 
\q1  
\v 58 Quicualancamacaque Toteco pampa mochijchihuilijque teteyome huan tlaixpamitl para quinhueyichihuase ininteteyohua. 
\q1  
\v 59 Pero quema Toteco Dios quiitac ya ni, 
\q1 tlahuel cualanqui huan pejqui quincualancaita. 
\q1  
\v 60 Huan quitlahuelcajqui itiopa catli eltoya ipan altepetl Silo, 
\q1 nopa yoyon cali campa ipan itztoya catli quichijtoya nopona ininhuaya imasehualhua. 
\q1  
\v 61 Huan Toteco quincahuili inincualancaitacahua ma quihuicaca icaxa catli quinpixtoya itlanahuatilhua. 
\q1 Elqui quen quincuilijque ininchicahualis huan ininyejyejca. 
\q1  
\v 62 Nojquiya quintemactili imasehualhua ininmaco inincualancaitacahua para ma quinmictica ica machete, 
\q1 pampa yaya tlahuel cualantoya ininhuaya. 
\q1  
\v 63 Inintelpocahua quintlatijque, 
\q1 huan iniichpocahua quintzontlamiltijque, 
\q1 niyon amo quiaxilijque para monamictise huan huicase ipan nenamictili. 
\q1  
\v 64 Quintzontlamiltijque nopa totajtzitzi ica machete huan ininsihuajhua nojquiya mijque nimantzi, 
\q1 niyon amo quinchoquilijque ininhuehuejhua. 
\q1  
\v 65 Huajca Toteco motlananqui quen quema se acajya cochi huan mehua, 
\q1 o quen se tetica tlacatl catli tlahuel tzajtzi chicahuac pampa ihuintitoc. 
\q1  
\v 66 Huan Toteco quinichtacahui quinhuilanqui icualancaitacahua. 
\q1 Quena, quinhuejcamajcajqui huan quintitlanqui ipan se lugar campa quipanose pinahualistli para nochipa. 
\q1  
\v 67 Pero Toteco quintlahuelcajqui nopa huejhueyi familias catli hualajqui tlen José huan Efraín. 
\q1  
\v 68 San quintlapejpeni ihueyi familia Judá, 
\q1 huan nopa tepetl Sion catli yaya tlahuel quiicneliyaya. 
\q1  
\v 69 Huan nopona quichijchijqui itiopa catli yejyectzi huan temachtli, 
\q1 huan catli huejcahuasquía para nochipa quen huejcahua ilhuicactli huan tlaltipactli. 
\q1  
\v 70 Quitlapejpeni itequipanojca, David, 
\q1 quema quinmocuitlahuiyaya borregojme, 
\q1  
\v 71 quema yohuiyaya inintepotzco nopa tenan borregojme catli quinpiyayayaj ininconehua, 
\q1 huan quinhualicayaya para ma quinmocuitlahui. 
\q1 Huan Toteco quichijqui David ma quinyacana imasehualhua, 
\q1 nopa israelitame catli quintlapejpenijtoya para iaxcahua. 
\q1  
\v 72 Huan quena, David quinmocuitlahui imasehualhua Toteco ica nochi ichicahualis huan ica nochi iyolo. 
\c 79  
\s1 Tequipacholi pampa masehualme quisosolojque Jerusalén 
\q1  
\v 1 ¡NoTeco Dios, masehualme tlen sequinoc tlalme hualajque huan moaxcatijque motlal! 
\q1 Motiopa quiijtlacojque huan altepetl Jerusalén quitlamisosolojtoque. 
\q1  
\v 2 Nochi inintlacayo momasehualhua quinmajcajtoque para ma quincuaca totome. 
\q1 Hasta quinmajcajtoque ininnacayo mototajtzitzi, 
\q1 nopa tlatzejtzeloltijca tlacame catli moquetzque moixpa, 
\q1 para ma quincuaca tecuanime. 
\q1  
\v 3 Quena, tocualancaitacahua quintzontlamiltijque nochi nopa masehualme ipan altepetl Jerusalén. 
\q1 Huan inieso catli toyajqui motlalo quen hueyatl, 
\q1 huan amo mocajqui niyon se para quintlalpachos. 
\q1  
\v 4 Huan ama nochi tlalme catli techyahualojtoque techpinajtíaj huan techhuetzquilíaj. 
\q1  
\v 5 Toteco Dios, ¿hasta quema tlamis ticualantos ica tojuanti? 
\q1 ¿Huelis para nochipa mocualancayo eltos quen tlitl? 
\q1  
\v 6 Xijtitlani mohueyi cualancayo ipan nopa tlalme campa amo mitziximatij, 
\q1 huan ipan altepeme campa amo aqui mitzhueyimati, 
\q1 pero amo xijtitlani ipan tojuanti. 
\q1  
\v 7 Pampa inijuanti quintzontlamiltijque nochi moisraelita masehualhua huan quinsosolojque nochi calme. 
\q1  
\v 8 ¡Amo xiquelnamiqui huan techtlatzacuilti por inintlajtlacolhua tohuejcapan tatahua, 
\q1 catli inijuanti quichijque huejcajya! 
\q1 Más cuali nimantzi techtlasojtla pampa ayacmo tijpiyaj fuerza. 
\q1  
\v 9 Toteco Dios, titotemaquixtijca, techpalehui, 
\q1 para quej nopa nochi mitzhueyitlepanitase. 
\q1 ¡Techmaquixti huan techtlapojpolhui totlajtlacolhua ica mohueyi tlaicnelilis! 
\q1  
\v 10 Pampa sintla amo techpalehuis, 
\q1 huajca nopa masehualme catli amo mitzneltocaj quiijtose: 
\q1 “¿Canque itztoc ininTeco Dios?” 
\q1 Huajca xiquintlatzacuilti, Toteco, iniixpa nochime, pampa quinmictijque momasehualhua. 
\q1  
\v 11 Xijtlacaquili inintequipachol nopa masehualme catli tzactoque, 
\q1 huan ica mohueyitilis huan mohueyi chicahualis, 
\q1 xiquinmanahui catli quinixquetztoque para quinmictise. 
\q1 Xiquinmaquixti para nochi ma quiitaca mohueyi chicahualis. 
\q1  
\v 12 TOTECO, xiquincuepili chicome huelta catli mitzchihuilijque quema mitzpinahualtijque nopa tlalme catli san mitzhuetzquilíaj. 
\q1  
\v 13 Huan huajca tojuanti, timomasehualhua catli tiitztoque quen timoborregojhua, 
\q1 timitzhueyichihuase para nochi tonali huan timitzpaquilismacase ica huicatl para nochipa. 
\c 80  
\s1 Netlatlajtili para Toteco ma quicualtlali tlali Israel huan imasehualhua 
\q1  
\v 1 ¡Ta catli tiinintlamocuitlahuijca israelitame huan techyacana quen tielisquíaj timoborregojhua, 
\q1 techtlacaquili! 
\q1 Ta catli timosehuijtoc tlatlajco nopa querubines tequihuajme, 
\q1 ximohuijtzoma quentzi huan techtlacaquili quema timotlatlajtíaj. 
\q1 Xijnexti mohueyi chicahualis huan mohueyitilis catli petlani. 
\q1  
\v 2 Xijchihua para nochi tiisraelitame, 
\q1 hasta nojquiya iniixhuihua Efraín, Benjamín huan Manasés, 
\q1 ma tiquitaca quenicatza timotlananas huan techmanahuis ica mohueyi chicahualis. 
\q1  
\v 3 Toteco Dios, techchihua ma timocuepaca ica ta. 
\q1 Techtlachili ica se moixayac catli senpactoc. 
\q1 Techicneli huan techmaquixti. 
\q1  
\v 4 TOTECO, ta tiDios Catli Tijpiya Nochi Chicahualistli, 
\q1 ¿hasta quema tlamis ticualantoc ica tojuanti huan amo tijtlacaquilis quema timotlatlajtíaj? 
\q1  
\v 5 Techmacatoc ma tijcuaca pantzi ica choquistli, huan ma tiquijica toixayo. 
\q1  
\v 6 Tijcajtoc ma techpinahualtica nopa tlalme catli techyahualohuaj huan ma techhuetzquilica tocualancaitacahua. 
\q1  
\v 7 Toteco Dios, ta tiDios Catli Tijpiya Nochi Chicahualistli, xijchihua ma timocuepaca ica ta. 
\q1 Techtlachili ica moixayac catli senpactoc. 
\q1 Techicneli huan techmaquixti. 
\q1  
\v 8 Techhualicac tlen tlali Egipto quen tieltosquíaj se xocomeca tzontli catli selic. 
\q1 Tiquintojtocac nopa sequinoc masehualme catli amo mitziximatque huan nopona techtojqui. 
\q1  
\v 9 Tijcualtlali nopa tlali huan elque quen tijpixque miyac tonelhuayohua. 
\q1 Huan tijtemitijque nopa tlali. 
\q1  
\v 10 Nopa tepeme tiquintlamitzajque ica toecahuil. 
\q1 Huan tielque quen tiocuame catli huejcapantique catli moaxcahua, Toteco. 
\q1  
\v 11 Tichamanque huan moscaltijque tomacuayohua. 
\q1 Huan toecahuil tiisraelitame ajsic hasta campa nopa hueyi atl catli itoca Mediterráneo huan hasta campa nopa hueyatl Eufrates. 
\q1  
\v 12 Huajca ¿para tlen ayacmo techmocuitlahuía? 
\q1 Eltoc quen tijtlamisosolo itepanyo moxocomecamil huan tijcahua ma quitlamicuaca nochi ojtipanyani. 
\q1  
\v 13 Inijuanti itztoque quen cuapitzome catli hualahuij huan tlapoxoníaj yahualtic tlen tojuanti, 
\q1 huan eltoc quen nopa tecuanime ya techtlamicuaj. 
\q1  
\v 14 Yeca Toteco Dios Catli Tijpiya Nochi Chicahualistli timitztlajtlaníaj, 
\q1 ximocuepa huan techtiochihua. 
\q1 Techhualtlachili tlen nopona ilhuicac, 
\q1 ximomaca cuenta quenicatza tiitztoque huan xijmocuitlahui ni moxocomecamil. 
\q1  
\v 15 Quena, xijmocuitlahui catli ta tijtojqui huan nopa ichamanca catli cuali tijtlatzquiltijtoc. 
\q1  
\v 16 Pampa tocualancaitacahua techhuejhuelojtoque huan techtlatijtoque. 
\q1 ¡Xiquintzontlamilti ica mohueyi cualancayo! 
\q1  
\v 17 Xijmaca chicahualistli nopa telpocatl catli tiquicnelía huan tijtlapejpenijtoc para tlanahuatis. 
\q1  
\v 18 Quej nopa ayacmo quema timitztlahuelcahuase. 
\q1 Techmaca yancuic nemilistli huan sempa timitznotzase huan timotlatlajtise moixpa ta. 
\q1  
\v 19 Techchihua ma timocuepaca sempa ica ta, TOTECO, 
\q1 ta tiDios Catli Tijpiya Nochi Chicahualistli. 
\q1 Sempa techtlachili ica se moixayac catli senpactoc. 
\q1 San ica ta motlapalehuil timomaquixtise tlen tocualancaitacahua. 
\c 81  
\s1 Toteco quipiya hueyi iyolo ica nopa tlaixpanoca israelitame 
\q1  
\v 1 ¡Xihuicaca ica paquilistli para Toteco Dios, 
\q1 pampa yaya techpixtoc imaco! 
\q1 ¡Ma tijpaquilismacaca! 
\q1 ¡Ma tihuicaca para Toteco Dios yaya catli iTeco Jacob! 
\q1  
\v 2 Ma tihuicaca huan ma tijtzijtzilinica pandero. 
\q1 Nojquiya ma tijtzotzonaca nopa arpa huan guitarra. 
\q1  
\v 3 Ma tijpitzaca tlapitzali quema yancuic metztli, 
\q1 quema temitoc metztli, 
\q1 huan ipan sequinoc tonalme quema tiilhuichihuaj, 
\q1  
\v 4 pampa Toteco Dios catli eli iTeco tohuejcapan tata Israel techmacatoc nopa tonalme para ma tipaquica miyac. 
\q1 Huan nojquiya eltoc ijcuilijtoc ipan itlanahuatilhua para ma tijchihuaca. 
\q1  
\v 5 Huan techmacac para ma tiquelnamiquica catli quichijqui ica José, 
\q1 huan quenicatza mohuilanqui ininhuaya nopa masehualme tlen tlali Egipto, 
\q1 campa titetequipanojque san tlapic. 
\q1 Nijcajqui camanaltic se catli amo niquiximatqui huan quiijto: 
\q1  
\v 6 “Ama nimechquixtilis nopa tlamamali catli anquihuicaj amoajcolpa, 
\q1 huan ayacmo anquitlananase ica amomax tlamantli catli tlahuel etic.” 
\q1  
\v 7 Nojquiya quiijto: 
\q1 “Amojuanti antechtzajtzilijque quema anitztoyaj ipan tlaohuijcayotl huan na nimechmaquixti. 
\q1 Nimechnanquili hasta tlen nepa tepetl Sion campa motlatía nopa tlatomonilotl. 
\q1 Nojquiya ipan tlali Meriba nimechyejyecoli amotlaneltoquilis quema anmotequipachohuayayaj pampa amo oncayaya atl. 
\q1  
\v 8 Yeca annoisraelita masehualhua, 
\q1 techtlacaquilica quema chicahuac nimechtlacahualtía. 
\q1  
\v 9 Amo quema xijhueyichihuaca seyoc catli quitocaxtíaj ‘dios’. 
\q1 Niyon amo xiquinpiyaca tlaixcopincayome ipan amocalijtic. 
\q1  
\v 10 Pampa elqui na, niamoTECO huan amoDios, 
\q1 catli nimechquixti ipan tlali Egipto. 
\q1 Xijtlapoca amocamac huan anquiitase sintla amo nimechixhuitis. 
\q1 Quena, anquiselise nochi tlamantli tlatiochihualistli catli anmechpolohua. 
\q1  
\v 11 ¡Pero amo! Nomasehualhua amo quinejque nechtlacaquilise. 
\q1 Israelitame amo quinejque ma niitzto tlatlajco inijuanti. 
\q1  
\v 12 Yeca niquintlahuelcajqui para ma huihuitiyaca huan ma elica quen popoyotzitzi. 
\q1 Huan niquincahuili ma quichihuaca catli inijuanti quinequiyayaj. 
\q1  
\v 13 Pero sintla noisraelita masehualhua nechtlacaquilijtosquíaj huan quitoquilijtosquíaj noojhui, 
\q1  
\v 14 huajca na san ipan se tlatoctzi niquinechcapantlalijtosquía inincualancaitacahua huan niquintzontlamiltijtosquía.” 
\b  
\q1  
\v 15 Quena, nochi catli quicualancaitaj TOTECO, 
\q1 nimantzi moechcapanojtosquíaj iixpa. 
\q1 Huan itztosquíaj ipan tlatzacuiltili para nochipa. 
\q1  
\v 16 Pero Toteco Dios anmechtlamacasquía ica tlacualistli catli más cuali. 
\q1 Huan anmechmacasquía sayolnectli huan nochi catli más anquinequij para anmechixhuitisquía. 
\c 82  
\s1 Toteco quinajhuac nopa jueces catli amo tetlajtolsencahuaj xitlahuac 
\q1  
\v 1 Toteco Dios itztoc ipan se hueyi tlasentilistli nepa ilhuicac. 
\q1 Huan nopona tlayolmelahua quenicatza quintlatzacuiltis nopa jueces huan quinilhuía: 
\q1  
\v 2 “¿Hasta quema tlamis antlacajcayahuaj quema antetlajtolsencahuaj? 
\q1 ¿Hasta quema tlamis anquinchicoicnelise amo cuajcualme catli fiero quichihuaj? 
\q1  
\v 3 Xiquintenpalehuica catli ayamo quipiyaj tetili huan catli icnotzitzi. 
\q1 Xiquintlajtolsencahuaca catli tlaijiyohuíaj huan catli amo tleno quipiyaj. 
\q1  
\v 4 Xiquinmaquixtica catli ayacmo quipiyaj chicahualistli huan quinpolohua catli quinmonequilía. 
\q1 Quena, xiquinmanahuica ininmaco nopa masehualme catli amo aqui quitlepanitaj. 
\q1  
\v 5 Amojuanti catli anquintlaijiyohuiltíaj amo tleno anquimatij huan amo tleno anquimachilíaj. 
\q1 Annemij ipan tzintlayohuilotl huan nochi itzinpehualtil tlaltipactli huihuipica. 
\q1  
\v 6 Quena, na nimechtocaxtijtoc ‘andioses’ huan ‘annoconehua niDios Catli Más Hueyi’, 
\q1  
\v 7 pero quema hualas miquilistli, nimantzi anmiquise pampa amojuanti san anmasehualme. 
\q1 Amopantis quen ipanti aqui hueli masehuali catli quipiya tequiticayotl, 
\q1 pampa nochi miquise.” 
\q1 Quej nopa quiijto Toteco. 
\b  
\q1  
\v 8 ¡Toteco Dios, ximotlanana huan xijtlajtolsencahua ni tlaltipactli, 
\q1 pampa nochi moaxca! 
\q1 Nochi tlalme huan tlanahuatiani eltoque momaco. 
\c 83  
\s1 Toteco, xiquintlatzacuilti catli quicualancaitaj Israel 
\q1  
\v 1 ¡Toteco Dios, amo san xitlacacto, 
\q1 niyon amo san xitlachixto quema timotlatlajtíaj! 
\q1 Monequi technanquili huan techmanahui, 
\q1  
\v 2 pampa mocualancaitacahua tlahuejchihuaj hasta quen nanalcaj huan mohueyimatij ica ta. 
\q1  
\v 3 Inijuanti tlahuel quimatij quenicatza quitlalise tlaquetztli ica momasehualhua. 
\q1 Huan quisencahuaj quenicatza quichihuase para quinmictise catli tiquintlapejpenijtoc. 
\q1  
\v 4 Huan quiijtohuaj: 
\q1 “Ma tiyaca tiquinixpolotij nochi nopa israelitame para ayacmo ma elica se tlali ica imasehualhua. 
\q1 Huan ayacmo aqui quielnamiquis itoca Israel.” 
\q1  
\v 5 Ya nopa catli quisencajque san sejco quema mosentilijque para mocamanalhuise. 
\q1 Quena, san sejco quichijque se camanali para fiero mitzchihuilise. 
\q1  
\v 6 Nopa masehualme elque iixhuihua Edom, Ismael, Agar huan Moab. 
\q1  
\v 7 Nojquiya inijuanti hualajque tlen nopa tlalme Gebal, Amón, Amalec, Filistea huan Tiro. 
\q1  
\v 8 Huan nopa masehualme tlen tlali Asiria nojquiya mosansejcotilijque ininhuaya. 
\q1 Nojquiya iixhuihua Lot. 
\q1  
\v 9 Xiquinchihuili san se quen tiquinchihuili tlali Madián ehuani, 
\q1 o quen tijchihuili Sísara huan Jabín ehuani ipan hueyatl Cisón. 
\q1  
\v 10 O xiquinchihuili quen tijchijqui ica mocualancaitacahua ipan tlali Endor. 
\q1 Inijuanti inintlacayohua mocajque tepejtoque tlalchi huan elque quen abono para tlali. 
\q1  
\v 11 Xijchihua para nopa tlacame catli tlahuel tejtetique ma miquica quen Oreb huan Zeeb quinmictijque. 
\q1 Huan nojquiya xijchihua para inintlayacancahua ma miquica quen nopa tlanahuatiani Zeba huan Zalmuna. 
\q1  
\v 12 Pampa inijuanti quiijtojque: 
\q1 “Ma timoaxcatica nopa tlali catli iaxca Dios.” 
\q1  
\v 13 NoTeco Dios, xiquinsemana ica moijiyo quen inijuanti elisquíaj tlaltejpoctli, 
\q1 o quen tlasoli catli quihuica ajacatl, 
\q1  
\v 14 o quen se hueyi tlitl catli quitlamitlatía ipan se cuatitlamitl. 
\q1  
\v 15 Xiquintojtoca ica huejhueyi tlitl, ica tlatomonilotl, 
\q1 huan ica huejhueyi ajcomalacatl. 
\q1  
\v 16 TOTECO, xiquinpinahualti nochi hasta mitziximatise ta huan mohueyi chicahualis. 
\q1  
\v 17 Ayacmo ma quimatica tlaque quichihuase. 
\q1 Ma mopinahualtica huan ma huetzica ipan majmajtli. 
\q1  
\v 18 Quena, xiquinchihuili ya nopa hasta quimachilise para san ta tiTOTECO, 
\q1 huan para ta tiDios Catli Más Hueyi huan para san ta tijnahuatía nochi tlaltipactli. 
\c 84  
\s1 Masehualme tlahuel quinejque itztose ipan itiopa Toteco 
\q1  
\v 1 TOTECO, ta tiDios Catli Tijpiya Nochi Chicahualistli, 
\q1 tlahuel yejyectzi motiopa. 
\q1  
\v 2 Nelía tlahuel nijnequi nicalaquis ipan icalixpa nopa tiopamitl, 
\q1 para nimonechcahuis huan nihuicas ica nochi noyolo para ta, Toteco Dios, catli tiitztoc. 
\q1  
\v 3 TOTECO, ta tiDios Catli Tijpiya Nochi Chicahualistli, 
\q1 Ta tinotlanahuatijca huan tinoTeco. 
\q1 Campa motlaixpa ipan mochaj nochi quipantíaj ininchaj, 
\q1 hasta nopa cochome huan toctoctzitzi catli nopona motepasoltíaj, 
\q1 para nopona quintlacatiltíaj ininconehua. 
\q1  
\v 4 ¡Nelía paquij nopa masehualme catli itztoque ipan motiopa huan quisenhuiquilíaj mitzpaquilismacaj! 
\q1  
\v 5 Cuali ininpanti nopa masehualme catli itztoque momaco, Toteco, 
\q1 huan quitoquilíaj moojhui huan yohuij Jerusalén para mitzhueyimatise. 
\q1  
\v 6 Quema panose campa ohui huan ipan nopa tlamayamitl tlen Choquistli, 
\q1 quicuepase para elis quen se yejyectzi ameli catli temitos ica atl quema tlaquiyahui, 
\q1 pampa nopona quipantise miyac tlatiochihualistli, 
\q1  
\v 7 Huan quej nopa nejnentiyase mojmostla ica más chicahualistli, 
\q1 huan ajsise ipan Jerusalén para nopona monextise moixpa, Toteco. 
\q1  
\v 8 TOTECO Dios, ta tiDios Catli Tijpiya Nochi Chicahualistli, techtlacaquili quema nimotlatlajtía. 
\q1 Quena, techtlacaquili ta tiiTeco Israel. 
\q1  
\v 9 Toteco, ta catli techmanahuía. 
\q1 Xijcualita huan xijtiochihua nopa tlanahuatijquetl catli ticaltijtoc para tlanahuatis ipan Israel. 
\q1  
\v 10 Achi más cuali ma niyolto se tonal huan ma niitzto ipan motiopa, Toteco, 
\q1 huan amo niyoltos se mil tonali huan san ninentinemis campa hueli. 
\q1 Quena, achi más cuali nimoquetzasquía campa ipuerta motiopa, Toteco, 
\q1 huan amo niitztos ipan se hueyi cali campa onca tlajtlacoli. 
\q1  
\v 11 Pampa ta, Toteco Dios, techtlahuilía huan techmanahuía. 
\q1 Ta techicnelía huan techhueyitlalía. 
\q1 Huan nochi catli monejnemiltíaj xitlahuac ipan moojhui, 
\q1 ta tiquinmacas nochi tlamantli cuajcuali catli inijuanti quinequij. 
\q1  
\v 12 Toteco Dios, ta tiDios Catli Tijpiya Nochi Chicahualistli, 
\q1 nelía paquij nopa masehualme catli motemachíaj ipan ta para tiquinmocuitlahuis. 
\c 85  
\s1 Netlatlajtili para Toteco ma quintlasojtla nopa israelitame 
\q1  
\v 1 TOTECO, ta techtitlanilijtoc miyac tlatiochihualistli catli yejyectzitzi ipan ni tlali, 
\q1 pampa sempa tiquinhualicac nica iixhuihua Jacob catli itztoyaj ipan sequinoc tlalme, 
\q1  
\v 2 Tiquinquixtili inintlaixpanolhua nochi momasehualhua. 
\q1 Quena, tiquixtlalpacho nochi inintlajtlacolhua. 
\q1  
\v 3 Timoyoltlali tohuaya huan ayacmo tlahuel ticualantoc. 
\q1  
\v 4 NoTeco Dios, ta catli titemaquixtía, 
\q1 ama xijchihua para sempa ma timitzicnelica para ayacmo quema techajsis mohueyi cualancayo. 
\q1  
\v 5 ¿O huelis tijsenhuiquilis ticualantos tohuaya para nochipa? 
\q1 ¿O huelis tijhueyilis mohueyi cualancayo para nochi xihuitl? 
\q1  
\v 6 Toteco Dios, sempa techtlanana, 
\q1 huan tojuanti timomasehualhua sempa timopaquilismacase ipan ta. 
\q1  
\v 7 TOTECO, technextili mohueyi tlaicnelilis, 
\q1 huan techmaquixti. 
\b  
\q1  
\v 8 Na nijtlacaquilijtoc nochi catli quiijtohua TOTECO Dios, 
\q1 pampa yaya quincamanalhuis itlatzejtzeloltijca masehualhua catli quintlapejpenijtoc. 
\q1 Huan catli quiijtos quinmacas tlasehuilistli ipan ininyolo, 
\q1 para inijuanti ma ayacmo mocuepaca ipan nopa ojtli catli huihuitic campa nemiyayaj ipan tlajtlacoli. 
\q1  
\v 9 Melahuac Toteco Dios itztoc nechca para quinmaquixtis masehualme catli quitlepanitaj huan quiimacasij quiixpanose. 
\q1 Se tonal ihueyitilis Toteco quitemitis totlal. 
\q1  
\v 10 Campa hueli mopantise tlaicnelijcayotl huan catli melahuac. 
\q1 Campa hueli nochi quimatise para quichihuase nochi catli xitlahuac huan quej nopa oncas tlasehuilistli campa hueli. 
\q1  
\v 11 Catli melahuac elis campa hueli ipan tlaltipactli, 
\q1 huan yaya catli senquistoc xitlahuac hualtlachixtos tlen nepa ilhuicac huan paquis ica catli quiitas. 
\q1  
\v 12 Quena, TOTECO quititlanis itlatiochihual ipan ni totlal, 
\q1 huan nochi totlatochui temacas itlajca. 
\q1  
\v 13 Campa hueli yas Toteco oncas catli melahuac, 
\q1 huan nochipa iojhui elis xitlahuac. 
\c 86  
\s1 Netlatlajtili para Toteco ma quipalehui 
\q1  
\v 1 TOTECO, ximohuijtzoma quentzi huan techtlacaquili quema nimotlatlajtía. 
\q1 Technanquili pampa niteicneltzi huan niitztoc ipan tequipacholi huan tlaohuijcayotl. 
\q1  
\v 2 NoTeco Dios, techmanahui pampa na nijchihua campica para nijchihuas catli quiijtohuaj motlanahuatilhua. 
\q1 Techmaquixti pampa na nimitztequipanohua huan san ipan ta nimotemachía para techmocuitlahuis. 
\q1  
\v 3 TOTECO, xijpiya hueyi moyolo ica na pampa nochi se tonal nimitztzajtzilijtoc, 
\q1 huan ipan ta nimochiya para techpalehuis. 
\q1  
\v 4 Toteco, techmaca paquilistli pampa na san ta nimitzhueyichihua. 
\q1  
\v 5 Toteco, ta nelía ticuali huan timoquetztoc timocualtlalijtoc para titetlapojpolhuis. 
\q1 Tiquinicnelía huan nimantzi tiquintlasojtla nochi catli mitztlajtlaníaj motlapalehuil. 
\q1  
\v 6 TOTECO, techtlacaquili quema nimotlatlajtía. 
\q1 Quena, techtlacaquili quema nimitztzajtzilía. 
\q1  
\v 7 Nimitztzajtzilis ipan nopa tonali quema nechajsis tlaohuijcayotl, 
\q1 pampa san ta technanquilía huan techpalehuía. 
\q1  
\v 8 Ipan nochi sequinoc catli quintocaxtíaj “dioses”, 
\q1 amo onca seyoc quen ta, Toteco. 
\q1 Huan amo aqui hueli quichihua huejhueyi tlamantli quen ta tijchihua. 
\q1  
\v 9 Elqui ta catli tiquinchijchijqui nochi tlalme ica ininmasehualhua. 
\q1 Yeca hualase huan mitzhueyichihuase, Toteco. 
\q1 Huan mitzhueyitlalise ta catli titlatzejtzeloltic, 
\q1  
\v 10 pampa ta tlahuel tihueyi huan tijchihua huejhueyi tlamantli. 
\q1 ¡San ta nelía tiDios! 
\q1  
\v 11 TOTECO, technextili moojhui huan nijtoquilis pampa san ya nopa temachtli. 
\q1 Xijchihua para noyolo ma mitzhueyitlepanita, 
\q1 huan ma quiimacasis mitzixpanos nochi nonemilis. 
\q1  
\v 12 TOTECO Dios, nimitzpaquilismacas ica nochi noyolo huan nimitzhueyitlalis para nochipa, 
\q1  
\v 13 pampa tlahuel hueyi motlaicnelilis noca na, 
\q1 huan amo quema tlami. 
\q1 Ta techmanahuijtoc para amo niyas mictla campa tlanahuatía miquilistli. 
\q1  
\v 14 Toteco Dios, miyac masehualme catli mohueyimatij huan catli mosisiníaj motlanantoque para nechhuilanase. 
\q1 Huan miyac tlahuilanca masehualme huan tlaixpanoni quinequij nechmictise, 
\q1 huan amo monejnehuilíaj tlen ta. 
\q1  
\v 15 Pero ta Toteco nelía titetlasojtla huan hueyi moyolo. 
\q1 Amo nimantzi ticualani. 
\q1 San ta titeicnelía huan san ta timelahuac. 
\q1  
\v 16 Techtlachili ica miyac tlaicnelijcayotl huan techmaca chicahualistli na nimotequipanojca. 
\q1 Huan xijmanahui icone mosihua tequipanojca. 
\q1  
\v 17 Xijnexti se tlanextili para ta techcualita. 
\q1 Quej nopa quiitase nocualancaitacahua, 
\q1 huan mopinahuase pampa momacase cuenta para ta, TOTECO, 
\q1 tlahuel techpalehuía huan techyoltlalía. 
\c 87  
\s1 Nelía elis se hueyi paquilistli para catli ehuaj altepetl Jerusalén 
\q1  
\v 1 Altepetl Jerusalén eltoc ipan nopa tepetl tlatzejtzeloltic catli iaxca Toteco. 
\q1  
\v 2 Huan TOTECO quiicnelía Jerusalén achi más que nopa sequinoc pilaltepetzitzi ipan tlali Israel. 
\q1  
\v 3 Quena, Jerusalén eltoc ialtepe Toteco Dios, 
\q1 huan quema masehualme quielnamiquij, 
\q1 camanaltij nelyejyectzi tlen nopa altepetl. 
\q1  
\v 4 Quema tlatlajco nohuampoyohua niquintocaxtía nopa tlalme catli inintoca Egipto, Babilonia, Filistea, Tiro huan Etiopía, 
\q1 itztos se catli mohueyimatis pampa tlacatqui ipan se tlen nopa tlalme. 
\q1  
\v 5 Pero ajsis tonali quema masehualme quiselise más hueyi tlatlepanitacayotl pampa tlacatque ipan altepetl Jerusalén, 
\q1 pampa Toteco Catli Más Hueyi quitiochihuas ni altepetl. 
\q1  
\v 6 Huan TOTECO quiijcuilos inintoca nochi catli itztoque ipan nopa altepetl. 
\q1 Huan nochi catli tlacatque nopona quintlalilis se tlanextili campa ijcuilijtos inintoca. 
\q1  
\v 7 Huan quema ilhuichihuase inijuanti, huicase ica paquilistli huan quiijtose: 
\q1 “Nochi noyolo nijtlalijtoc ipan Jerusalén.” 
\c 88  
\s1 Netlatlajtili para Toteco ma quinmanahui imaco miquilistli 
\q1  
\v 1 TOTECO, ta catli tinoDios huan tinotemaquixtijca. 
\q1 Tonali huan yohuali nimitztzajtzilijtoc para techpalehui. 
\q1  
\v 2 Techtlacaquili quema nimotlatlajtía huan quema nimitztzajtzilía, 
\q1  
\v 3 pampa nijmati nisiyajtoc ica nochi catli amo cuali hasta nijmati ya nechcatitoc para nimiquis. 
\q1  
\v 4 Miyac quiijtohuaj para ya tlantinemi nonemilis huan para ayacmo nijpiya chicahualistli. 
\q1  
\v 5 Masehualme nechtlahuelcajtoque para ma nimiqui. 
\q1 Niitztoc quen se catli ya mijqui ipan tlahuilancayotl huan nochi quielcahuaj sintla itztoya. 
\q1 Huan eltoc quen ta techelcajqui huan ayacmo techmocuitlahuía. 
\q1  
\v 6 Ta techmajcajtoc ipan nopa ostotl catli más huejcatla campa onca tzintlayohuilotl catli más yayahuic. 
\q1  
\v 7 Mocualancayo nechtlaijiyohuiltía chicahuac huan tlatoctzitzi nechtlatzintlanhuetziltía más. 
\q1  
\v 8 Tijchijtoc para noteiximatcahua ma nechtlahuelcahuaca huan ma nechijiyaca. 
\q1 Eltoc quen niitztoc ipan se tlatzactli huan amo hueli niquisa. 
\q1  
\v 9 Ayacmo hueli nitlachiya pampa tlahuel nimochoquilijtoc. 
\q1 Mojmostla nimitztlajtlanía motlapalehuil, 
\q1 huan nimomatlanana quema nimotlatlajtía ica ta, TOTECO, para techtlasojtla. 
\q1  
\v 10 Pero nijmachilía para, quena, nimiquis nimantzi, 
\q1 huan ¿tlaque ipati elis para na nopa tiochicahual nextili catli tijchihuas quema ya nimictoc? 
\q1 ¡Amo tleno! ¿Atlac nihuelis nimitzpaquilismacas quema ya nimictos? 
\q1  
\v 11 Se mijcatzi catli ya quitlalpachojtoque amo huelis tepohuilis para tijpiya hueyi tlaicnelili. 
\q1 Amo huelis tepohuilis para titemachtli. 
\q1  
\v 12 Nepa campa tzintlayohua amo huelise tepohuilise nopa huejhueyi tiochicahual nextili catli tijchihua. 
\q1 Mijcatzitzi itztoque ipan se tlali campa ayacmo tleno quielnamiquij, 
\q1 huan amo huelis mitzelnamiquise para san ta tixitlahuac. 
\q1  
\v 13 Pero na nimitztzajtzilijtoc ta TOTECO, 
\q1 huan sesen ijnaloc nochi catli niquijtohua quema nimotlatlajtía ica ta ajsi hasta moixtla. 
\q1  
\v 14 TOTECO, ¿para tlen tijhuejcamajcajtoc nonemilis? 
\q1 ¿Para tlen tiquijcuinía moixayac huan titlachiya ipan seyoc lado? 
\q1  
\v 15 Na niitztoc ipan tlaijiyohuili huan tequipacholi hasta quema noja niitztoya nitelpocatl. 
\q1 Majmajtli huan miquilistli catli ta techtitlanilijtoc nechtoquilijtinemi, 
\q1 huan ama ayacmo nihueli más niquijiyohuía. 
\q1  
\v 16 Miyac huelta hualajtoc nopan na mohueyi cualancayo, 
\q1 huan nopa majmajtli catli techtitlanilijtoc tlahuel nechtlaijiyohuiltía. 
\q1  
\v 17 Quena, nochi nopa tlamantli nechyahualojtoc quen atl. 
\q1  
\v 18 Nochi catli niquinicnelía huan catli itztoyaj nohuampoyohua tiquinchijtoc ma nechtlahuelcahuaca, 
\q1 ayacmo nechchihuilíaj cuenta. 
\q1 Huan noteiximatcahua tiquintlalijtoc ipan tzintlayohuilotl. 
\c 89  
\s1 Nopa camanal sencahuali catli Toteco quichijqui ihuaya David 
\q1  
\v 1 Nimitzhuicatis, TOTECO, para nochipa pampa tlahuel hueyi moyolo ica na. 
\q1 Quena, nochi telpocame huan huehuentzitzi niquinpohuilis para ta nelía titemachtli. 
\q1  
\v 2 Na niquijto: “Ta titetlasojtlas para nochipa. 
\q1 Huan nochipa tiitztos titemachtli san quen para nochipa huejcahuas ilhuicac campa tiitztoc.” 
\q1  
\v 3 Ta tiquijtojtoc para tijchijqui se camanal sencahuali ica motequipanojca David catli tijtlapejpenijtoc. 
\q1 Titlatestigojquetzqui catli tijchihuilis. 
\q1  
\v 4 Tiquilhui para se iixhui mosehuis ipan isiya campa yaya tlanahuatía, 
\q1 huan nopona tlanahuatis para nochipa. 
\q1  
\v 5 TOTECO, catli itztoque ipan ilhuicac mitzpaquilismacaj por nochi nopa tiochicahual nextili catli tijchihua. 
\q1 Huan miyac millones motequihuajcahua mitzhueyimatise pampa titemachtli. 
\q1  
\v 6 Pampa ipan nochi ilhuicac amo aqui seyoc catli san se quen ta, Toteco Dios. 
\q1 Huan niyon se tequihuajquetl amo quipiya chicahualistli catli quiaxilía catli tijpiya ta, Toteco. 
\q1  
\v 7 Toteco Dios, ta nelía tihueyi huan titemajmati. 
\q1 Nochi motlatzejtzeloltijca tequihuajcahua mitztlepanitaj. 
\q1 Quena, nochi catli mitzyahualojtoque, majmahuij quema moquetzaj moixpa. 
\q1  
\v 8 TOTECO, ta tiDios Catli Tijpiya Nochi Chicahualistli, 
\q1 ¿ajqueya seyoc tlahuel quipiya chicahualistli quen ta? 
\q1 ¡Amo aqui seyoc! San ta TOTECO tlahuel tijpiya chicahualistli. 
\q1 San ta nelía titemachtli. 
\q1  
\v 9 San ta tihueli tijnahuatía nopa hueyi atl quema mosisinía huan mocoxonía chicahuac. 
\q1 Tijtlacahualtía huan quichihua catli tiquilhuía. 
\q1  
\v 10 Ta tijtzontlamilti nopa catli temajmatiyaya ipan hueyi atl. 
\q1 Ica mohueyi chicahualis tiquinsemanqui mocualancaitacahua. 
\q1  
\v 11 Ta moaxca ilhuicactli, tlaltipactli huan nochi catli onca, 
\q1 pampa nochi tijchijchijqui ta. 
\q1  
\v 12 Tijchijchijqui nopa norte huan sur. 
\q1 Nopa tepeme Tabor huan Hermón paquij pampa ta tiquinchijchijqui. 
\q1  
\v 13 Moajcol tlahuel quipiya chicahualistli. 
\q1 Huan monejmac quipiya tetili huan miyac yajatili para tlatlanis. 
\q1  
\v 14 Motlanahuatilis motlatzquilijtoc ipan ome tlamantli: 
\q1 Titetlajtolsencahua xitlahuac huan tijchihua catli cuali. 
\q1 Titeicnelía huan tiquijtohua catli melahuac. 
\q1  
\v 15 Nelía paquij nopa masehualme catli quicaquij nopa tlapitzali catli quinnotza ma mitzhueyichihuaca, TOTECO. 
\q1 Inijuanti nemise nelía monechca huan ta tiquintlahuilis. 
\q1  
\v 16 Semilhuitl mopaquilismacase ipan ta pampa tlahuel tihueyi huan tixitlahuac. 
\q1  
\v 17 Pampa san ta tijpiya mohueyitilis huan tiquinfuerzajmaca. 
\q1 Timasehualme tijpiyaj chicahualistli pampa ta techpalehuía. 
\q1  
\v 18 Quena, Toteco Dios, ta catli titlatzejtzeloltic techmocuitlahuía tojuanti ipan tlali Israel. 
\q1 Ta titotlanahuatijca. 
\q1  
\v 19 Ipan se tlanextili tijcamanalhui motlatzejtzeloltijca tlajtol pannextijca huan tiquilhui: 
\q1 “Tlen nochi masehualme nijtlapejpenijtoc se yejyectzi telpocatl catli tlahuel motemaca, 
\q1 huan nijtequitlali ma eli tlanahuatijquetl para na. 
\q1  
\v 20 Quena, nijpantijtoc notequipanojca David huan nicaltijtoc ica nopa aceite catli ica niteiyocatlalía para ma nechtequipanoca. 
\q1  
\v 21 Nijchihuas ma eli temachtli huan nijmacas chicahualistli. 
\q1  
\v 22 Amo quiechcapantlalise icualancaitacahua, 
\q1 niyon amo quitlanise tlaixpanoca masehualme. 
\q1  
\v 23 Iixpa niquintzontlamiltis icualancaitacahua huan nochi catli quicualancaitaj. 
\q1  
\v 24 Na catli nitemachtli nijmocuitlahuis huan nijtiochihuas tlatoctzitzi, 
\q1 huan tlahuel miyac niquicnelis. 
\q1 Ica na notlapalehuil yaya elis tlahuel hueyi. 
\q1  
\v 25 Na nijchihuas para itlanahuatilis pehuas campa hueyatl Eufrates, 
\q1 huan tlamis hasta campa hueyi atl catli itoca Mediterráneo. 
\q1  
\v 26 Huan yaya nechtzajtzilis huan nechilhuis: 
\q1 ‘¡Ta tinoTata, ta tinoTeco Dios! 
\q1 Ta catli techmaquixtía huan techtlatía para amo tleno nechajsis.’ 
\q1  
\v 27 Na niquitas nopa tlanahuatijquetl quen noachtihui cone. 
\q1 Nijchihuas para yaya ma eli nopa tlanahuatijquetl catli más hueyi ipan nochi tlaltipactli. 
\q1  
\v 28 Niquicnelis para nochipa huan para nochipa nijchihuilis catli cuali. 
\q1 Huan nopa camanal sencahuali catli nijchijtoc ihuaya, amo quema tlamis. 
\q1  
\v 29 Na nijtequimacas se iixhui para ma tlanahuatis campa yaya tlanahuatiyaya. 
\q1 Itlanahuatilis huejcahuas para nochipa quen huejcahuas ilhuicactli. 
\q1  
\v 30 Pero sintla iconehua quitlahuelcahuase noley huan amo monejnemiltise quen quiijtohua notlamachtil, 
\q1  
\v 31 o sintla quiixpanose catli niquinnahuatijtoc ma quichihuaca ipan ininnemilis huan amo quintlepanitase notlanahuatilhua, 
\q1  
\v 32 huajca niquintlatzacuiltis pampa ya nopa quinextis para amo nechneltocatoque huan tlajtlacolchihuaj. 
\q1  
\v 33 Pero amo nijcahuas niquinicnelis, 
\q1 niyon amo nijtlamiltis nopa camanali catli nijchijtoc ininhuaya. 
\q1  
\v 34 Amo niquelcahuas catli ica nimocajtoc David huan amo nijpatlas nocamanal. 
\q1  
\v 35 Pampa na nitlatestigojquetzqui para nijchihuilis David nochi catli nijtlajtolcahuilijtoc. 
\q1 Huan na niDios catli nitlatzejtzeloltic amo hueli niistlacatis. 
\q1  
\v 36 Iixhui mosehuis huan tlanahuatis para nochipa campa ya mosehui. 
\q1 Itlanahuatilis huejcahuas san quen imiyaca tonali tlahuijtos tonati. 
\q1  
\v 37 Quena, itlanahuatilis tlahuel huejcahuas quen huejcahuas metztli, 
\q1 o quen huejcahuas nochi catli eltoc ipan ilhuicac catli eltoque quen notestigos.” 
\m Quena, quej nopa tiquijto, Toteco. 
\q1  
\v 38 ¿Huajca para tlen techtlahuelcahua huan techhuejcamajcahua? 
\q1 ¿Para tlen tlahuel ticualani ica yaya catli tijtlapejpenijtoc para elis tlanahuatijquetl? 
\q1  
\v 39 ¿Atlac tijsosolojtoc nopa camanali catli tijchijqui ihuaya? 
\q1 Pampa eltoc quen tijtlahuiso icorona hasta tlalchi. 
\q1  
\v 40 Tijcahuili tocualancaitacahua ma quihuelonica nopa tepamitl catli yahualtic quitzacuayaya toaltepe. 
\q1 Huan quitlamisosolojque nopa calme catli huejcapantique campa timomanahuiyayaj. 
\q1  
\v 41 Nochi catli panoj nopona quiichtequij catli inijuanti quinequij. 
\q1 Huan nopa masehualme catli itztoque tonechca san techhuetzquilíaj. 
\q1  
\v 42 Tiquinfuerzajmacatoc tocualancaitacahua, 
\q1 huan tiquinchijtoc ma paquica pampa techtlantoque. 
\q1  
\v 43 Tijquixtili itlatequiyo tomachete catli ica titlahuilanayayaj, 
\q1 huan amo tijnejqui techpalehuis para ma titlatlanica. 
\q1  
\v 44 Techquixtili noyejyejca huan tijtlahuisojtoc hasta tlalchi notlanahuatilis. 
\q1  
\v 45 Techchijtoc ma nitlatochuehuejtiya huan techpinahualtijtoc iniixpa nochi masehualme. 
\q1  
\v 46 TOTECO, ¿hasta quema tlamis ticualantos? 
\q1 ¿Hasta quema noja timotlatijtos tlen tojuanti? 
\q1 ¿Atlac para nochipa mohueyi cualancayo eltos quen tlitl? 
\q1  
\v 47 ¡Toteco, xiquelnamiqui para tonemilis amo huejcahuas ipan ni tlaltipactli! 
\q1 ¿Atlac amo tleno ipati nopa nemilistli catli tiquinmacatoc nochi masehualme? 
\q1  
\v 48 Niyon se masehuali amo huelis itztos para nochipa. ¡Nochi miquise! 
\q1 ¿Ajqueya huelis quimanahuis inemilis imaco miquilistli? 
\q1  
\v 49 NoTeco Dios, ¿canque eltoc motlaicnelilis tlen huejcaya? 
\q1 ¿Para tlen ayacmo tijpiya hueyi moyolo ica tojuanti? 
\q1 Ta tiToteco catli titemachtli, tijtlajtolcahuili David para melahuac amo quema techtlahuelcahuas. 
\q1  
\v 50 TOTECO, xijtlachili quenicatza nochi masehualme techcualancaitaj tojuanti timomasehualhua. 
\q1  
\v 51 Mocualancaitacahua quipinahualtíaj yaya catli tijtlapejpenijtoc para elis tlanahuatijquetl. 
\b  
\q1  
\v 52 Ma tijpaquilismacaca TOTECO para nochipa. 
\q1 Quej nopa ma eli. 
\c 90  
\s1 Masehualme amo huejcahuaj 
\q1  
\v 1 Toteco, ta nochipa techmocuitlahuijtinentoc, 
\q1 hasta tlen ipejya nochi xihuitl huan para nochi tonali. 
\q1  
\v 2 Hasta quema ayamo tiquinchijchihuayaya tepeme huan tlaltipactli, ta ipa tiitztoc. 
\q1 Pampa ta, tiToteco Dios, amo quema tijpixqui mopejya, 
\q1 huan amo quema tijpiyas motlamiya. 
\q1  
\v 3 Ta tijchihua para nochi masehualme ma mocuepaca tlali. 
\q1 Quena, ticamanalti huan tiquijtohua: 
\q1 “Ximiquica anmasehualme.” 
\q1  
\v 4 Pampa mil xihuitl ta tiquita quen se tonal catli panoc yalohua, 
\q1 o quen elisquía se eyi hora quema se tlamocuitlahuiyaya tlayohua. 
\q1  
\v 5 Tonemilis motlalojti quen atl catli hualtemo chicahuac ipan se atlajtli. 
\q1 Huan ica se tlatoctzi tiixpolijtehuaj quen se temictli. 
\q1 Nojquiya tiitztoque quen se xihui cuahuitl. 
\q1  
\v 6 Ica ijnaloc moscaltía huan cahuani, 
\q1 huan ica tiotlac quitzontequij huan huaqui. 
\q1  
\v 7 Pampa ica mohueyi cualancayo techtlaijiyohuiltía huan techtzontlamiltía. 
\q1  
\v 8 Totlajtlacolhua huan totlaixpanolhua tlanemijya nestoc moixpa. 
\q1  
\v 9 Yeca nochi tonali huan nochi xihuitl tijpanoj huejhueyi tlaohuijcayotl, 
\q1 catli ta techtitlanilía ica mohueyi cualancayo. 
\q1  
\v 10 San techcahuilía timasehualme ma tiitztoca setenta xihuitl. 
\q1 Huan catli quentzi más tejtetique san tiquincahuilía ma itztoca ochenta xihuitl. 
\q1 Pero ipan nochi nopa xihuitl san tijpanoj tlaohuijcayotl huan tequipacholi, 
\q1 pampa nochi nopa xihuitl san panotiquisa huan tojuanti san tiixpolijtehuaj. 
\q1  
\v 11 ¿Ajqueya quimachilía nochi catli tihuelis tijchihuas quema ticualani? 
\q1 ¿Ajqueya tlen tojuanti mitzimacasi quen quinamiqui? 
\q1  
\v 12 Amo miyac tonali tijpiyaj, 
\q1 huajca technextili quenicatza ma tijchihuaca para amo timotonalpolose, 
\q1 huan para ma tijpiyaca tlalnamiquilistli ipan toyolo nochi tonali. 
\q1  
\v 13 TOTECO, xihuala huan techtiochihua. 
\q1 ¿Hasta quema tlamis ticualantos? 
\q1 Techtlasojtla tojuanti timotequipanojcahua. 
\q1  
\v 14 Mojmostla ica ijnaloc technextili motlaicnelilis, 
\q1 huan nochi tonemilis timitzhuicatise huan tiyolpactose. 
\q1  
\v 15 Toteco, techmaca paquilistli quen ipatlaca nopa tlaohuijcayotl catli tijpanoque. 
\q1 Huan techcahuili ma tiitztoca ica yejyectzi para miyac xihuitl, 
\q1 quen imiyaca nopa xihuitl quema tijpanoque tlamantli catli fiero. 
\q1  
\v 16 Xijchihua para sempa ma tiquitaca nopa huejhueyi tiochicahual nextili catli tijchihua. 
\q1 Huan toconehua ma quiitaca nochi nopa yejyectzitzi tlamantli san se quen tijchihuayaya achtihuiya. 
\q1  
\v 17 TOTECO, ta titoDios, 
\q1 techtlahuilía ica motlatlanex huan technextilía para techcualita. 
\q1 Techpalehui para nochi catli tijchihuase ma cualquisas huan ma huejcahuas. 
\q1 Quena, Toteco, ma cualquisa nochi catli tomax quichihuas pampa ta techfuerzajmaca. 
\c 91  
\s1 Ma timotlatzquilijtoca ipan Toteco 
\q1  
\v 1 Catli motlatzquilijtoc ipan Toteco Dios Catli Más Hueyi itztos temachtli imaco, 
\q1 pampa mocahuas ica Toteco Catli Quipiya Nochi Chicahualistli. 
\q1  
\v 2 Huan na niquijtos tlen TOTECO para yaya nechmocuitlahuía ica ihueyi chicahualis. 
\q1 Yaya noTeco Dios huan san ipan ya nimotemachía. 
\q1  
\v 3 Pampa san yaya hueli mitzmanahuis tlen nochi tlaquetztli catli sequinoc quintlatise para mitzmasiltise. 
\q1 Mitzmocuitlahuis para amo mitzajsis nopa cocolistli catli tetzontlamiltía. 
\q1  
\v 4 Quen se tenampillo quintlatía ipilconehua ieltlapaltzala, 
\q1 Toteco quej nopa nojquiya mitzmocuitlahuía. 
\q1 Temachtli mitzchihuilis nochi catli mitztlajtolcahuilijtoc, 
\q1 pampa timotemachijtoc ipan ya para mitzmanahuis. 
\q1  
\v 5 Huajca ama ayacmo ximajmahui ica tlayohua, 
\q1 niyon amo xiquimacasi catli hueli panos ipan tonaya. 
\q1  
\v 6 Amo xiquimacasi nopa tlaijiyohuilistli catli huala ipan tzintlayohuilotl, 
\q1 niyon nopa miquilistli catli ajsi ica tlajcotona. 
\q1  
\v 7 Masque monechca miquise mil o majtlactli mil masehualme, 
\q1 pero ta amo mitzajsis. 
\q1  
\v 8 Ica moixteyol tiquitas quenicatza quiselise tlatzacuiltili nopa tlaixpanoca tlacame. 
\q1  
\v 9 Sintla timotemachijtoc ipan TOTECO para mitzmocuitlahuis, 
\q1 huan timochiya ipan Toteco Catli Más Hueyi para mitzpalehuis, 
\q1  
\v 10 huajca amo mitzajsis niyon se tlamantli catli amo cuali, 
\q1 niyon amo quiajsis mochaj. 
\q1  
\v 11 Pampa Toteco quintitlanis itequihuajcahua para ma mitzmocuitlahuica, 
\q1 huan mitzmocuitlahuijtinemise campa hueli ta tiyas. 
\q1  
\v 12 Huan itequihuajcahua mitztlananase ica ininmax para amo timotepotlamis ipan ojtli. 
\q1  
\v 13 Niyon amo timajmahuis masque tijquetzas moicxi ipan se león o se cohuatl catli temictía. 
\q1 Quena, amo tleno mopantis masque timoquejquetzas ininpani. 
\q1  
\v 14 Pampa Toteco Dios quiijtohua: 
\q1 “Na nijmanahuis pampa nechicnelía. 
\q1 Nijhueyitlalis pampa motemachía ipan na. 
\q1  
\v 15 Quema nechtzajtzilis, na nijnanquilis. 
\q1 Nojquiya niitztos ihuaya quema quipiyas tequipacholi. 
\q1 Nijmanahuis huan nijhueyitlalis. 
\q1  
\v 16 Nijchihuas ma itzto tlahuel miyac xihuitl huan nijmaquixtis.” 
\c 92  
\s1 Xijpaquilismacaca Toteco 
\q1  
\v 1 Nelía cuali para timitzhueyichihuase, TOTECO, 
\q1 ta nopa Dios Catli Más tiHueyi. 
\q1 Cuali ma timitzpaquilismacaca ica huicatl. 
\q1  
\v 2 Ica ijnaloc ma titepohuilica motlaicnelilis pampa hueyi moyolo, 
\q1 huan ica tlapoyahui ma tipaquica miyac pampa nelía titemachtli. 
\q1  
\v 3 Ma tihuicaca huan ma titlatzotzonaca ica nopa tlatzotzonali catli itoca arpa, guitarra huan lira. 
\q1  
\v 4 NoTeco Dios, ta nelía techchihuilijtoc miyac tlamantli catli cuali, 
\q1 huan techchijtoc ma nipaqui. 
\q1 Yeca nihuica ica miyac paquilistli. 
\q1  
\v 5 ¡TOTECO, ta tijchihua huejhueyi tiochicahual nextili! 
\q1 ¡Huan motlalnamiquilis amo aqui hueli quimachilía! 
\q1  
\v 6 Nopa masehualme catli huihuitique amo quimatij niyon amo quimachilíaj. 
\q1  
\v 7 Masehualme catli fiero ininnemilis motlananaj huan mohueyichihuaj ica tlamantli catli amo cuali, 
\q1 pero amo quimatij para teipa quintzontlamiltise huan ayacmo quema motlananase. 
\q1  
\v 8 Pero ta tiTOTECO, mitzhueyitlalijtose para nochipa pampa ta tiDios Catli Más Hueyi. 
\q1  
\v 9 Xiquita nica itztoque mocualancaitacahua pero nojquiya nica tiquintzontlamis. 
\q1 Quena, TOTECO, nochi masehualme catli quichihuaj catli amo cuali, ta tiquinsemanas. 
\q1  
\v 10 Pero techmacas na chicahualistli quen se toro catli nemi cuatitla. 
\q1 Huan sempa techaltis ica moaceite catli temaca yancuic chicahualistli. 
\q1  
\v 11 Niquitas quenicatza tiquintzontlamis nocualancaitacahua. 
\q1 Huan nijcaquis quenicatza quintzontlamise nopa tlaixpanoca tlacame catli motlanantoque ica na. 
\b  
\q1  
\v 12 Pero catli itztoque xitlahuaque iixpa Toteco quipiyase chicahualistli. 
\q1 Inijuanti yejyectzitzi quen ixochiyo apachi cuahuitl. 
\q1 Mohueyichihuase quen nopa tiocuame catli onca ipan tlali Líbano. 
\q1  
\v 13 Masehualme catli cuajcualme quipiyase chicahualistli quen cuame catli quintoctoque ipan ichaj TOTECO, 
\q1 huan Toteco Dios yaya quinmocuitlahuis. 
\q1  
\v 14 Huan quema nopa cuajcualme huehuejtiyase, noja quipiyase fuerza. 
\q1 Itztose quen cuame catli temacase inintlajca, 
\q1 huan nochipa xoxohuixtose. 
\q1  
\v 15 Huan ya nopa quinextis para TOTECO catli nechmocuitlahuía quichihua catli melahuac. 
\q1 Nochipa yaya xitlahuac tetlajtolsencahua. 
\c 93  
\s1 Toteco tlahuel hueyi 
\q1  
\v 1 ¡TOTECO tlanahuatía! 
\q1 Yaya tlahuel hueyi hasta quipiya itlatlanex catli onpano yejyectzi. 
\q1 Quitlatzquilti nelcuali ni tlaltipactli, 
\q1 huan amo hueli mojmolinis tlen itlatzinpehualtil. 
\b  
\q1  
\v 2 Nochipa hasta tlen huejcajya ta tijpixtoc tlanahuatili, 
\q1 huan nochi catli itztoque ipan motlanahuatilis mocahuaj temachme. 
\q1 San ta tiitztoc para nochipa. 
\q1  
\v 3 TOTECO, nopa hueyame caquisti para mitzpaquilismacaj quema mocoxoníaj. 
\q1  
\v 4 Pero ta, TOTECO, catli tiitztoc hasta huejcapa tijpiya más chicahualistli, 
\q1 huan amo quen nopa atl catli mocoxonía ipan nochi huejhueyi atl ipan tlaltipactli. 
\q1  
\v 5 Motlanahuatilhua amo quema mopatlaj. 
\q1 TOTECO, para nochi xihuitl huan para nochi tonali motequiticayo eltoc senquistoc tlatzejtzeloltic. 
\c 94  
\s1 Netlatlajtili para Toteco ma quincuepili tocualancaitacahua 
\q1  
\v 1 TOTECO, ximonexti. 
\q1 Ta tiDios catli tijpiya motequi para tiquincuepilis catli amo cuali techchihuilijtoque tocualancaitacahua. 
\q1  
\v 2 Ximotlanana huan xijtlatzacuilti ni tlali. 
\q1 Nochi catli mohueyimatij xiquintlatzacuilti quen quinamiqui. 
\q1  
\v 3 TOTECO, ¿hasta quema tlamis tlatlanise huan mopaquilismacase nopa masehualme catli amo aqui quitlepanitaj? 
\q1  
\v 4 ¿Hasta quema tlamis tetlaijilhuise huan mohueyimatise nopa tlajtlacolchijca masehualme? 
\q1  
\v 5 TOTECO, inijuanti tlahuel quintlaijiyohuiltíaj huan quintequipacholmacaj momasehualhua catli tiquinicnelía. 
\q1  
\v 6 Inijuanti quinmictíaj cahual toahuihua catli ehuani ipan sequinoc altepeme huan catli icnotzitzi. 
\q1  
\v 7 Huan quiijtohuaj para ta, TOTECO, amo tiquita, 
\q1 niyon amo timomaca cuenta. 
\q1 Quej nopa quiijtohuaj tlen ta catli tiiTeco tohuejcapan tata Jacob. 
\b  
\q1  
\v 8 Amojuanti catli anhuihuitique ipan ni masehualme, xijmachilica. 
\q1 ¿Hasta quema anquitequihuise amotlalnamiquilis para antlamachilise? 
\q1  
\v 9 Toteco quisencajqui tonacashua, 
\q1 huajca ¿anmoilhuíaj para amo quicaquis catli anquiijtohuaj? 
\q1 Yaya quichijchijqui toixteyol, 
\q1 huan ¿anmoilhuíaj para amo quiitas catli anquichihuaj? 
\q1  
\v 10 Yaya quintlatzacuiltía masehualme ipan nochi tlalme, 
\q1 ¿anmoilhuíaj amo anmechtlatzacuiltis nojquiya? 
\q1 Yaya quimati nochi catli pano, 
\q1 huan ¿anmoilhuíaj amo quimati tlaque anquichihuaj? 
\q1  
\v 11 TOTECO quiiximati inintlalnamiquilis masehualme huan quimati para san moilhuíaj tlamantli catli amo cuali. 
\b  
\q1  
\v 12 Pero cuali ininpanti nopa masehualme catli ta, TOTECO, 
\q1 tiquintlatzacuiltis para tiquintlalnamictis. 
\q1 Ya nopa quinpalehuía para quitoquilise moojhui, 
\q1 huan para monejnemiltise xitlahuac ipan motlanahuatilhua. 
\b  
\q1  
\v 13 Huan para itztose ica paquilistli quema ajsis nopa tonali catli fiero. 
\q1 Pero nopa masehualme catli amo quitlepanitaj TOTECO mochihuilíaj se ostotl para ipan momasiltise huan motzontlamiltise. 
\q1  
\v 14 Pampa TOTECO amo quintlahuelcahuas imasehualhua pampa inijuanti iaxcahua. 
\q1  
\v 15 Se tonal Toteco tetlajtolsencahuas xitlahuac, 
\q1 huan nochi catli itztoque ica ininnemilis xitlahuac, 
\q1 inijuanti paquise miyac. 
\q1  
\v 16 ¿Ajqueya nechmanahuis ininmaco nopa mosisinijca masehualme? 
\q1 ¿Ajqueya nechmocuitlahuis tlen nopa tlaixpanoca masehualme? 
\q1  
\v 17 Sintla Toteco amo nechpalehuijtosquía, 
\q1 huajca noyoltzi ya eltosquía campa tlatzitzicatoc pampa ya nimictosquía. 
\q1  
\v 18 Na nitzajtzic huan niquijto: 
\q1 “TOTECO, xixitlaca noicxihua.” 
\q1 Huan yaya nechtlasojtlac huan nechmaquixti. 
\b  
\q1  
\v 19 NoTeco, quema san nimonejnehuilía tlen miyac tequipacholi huan san ya nopa nijmati, 
\q1 ta techyoltlalía. 
\q1 Techchihua ma nimotemachi ipan ta huan techmaca paquilistli. 
\q1  
\v 20 Se tlanahuatijquetl catli amo quichihua catli xitlahuac, 
\q1 amo tijcahuas para mosentilis ica ta. 
\q1 Niyon amo itztoc mohuaya catli quichihua se tlanahuatili catli amo xitlahuac. 
\b  
\q1  
\v 21 Pero tlanahuatiani quej nopa mosentilíaj huan mocamanalhuíaj para quenicatza quimictise se catli amo tleno quichijtoc, 
\q1 o se catli cuali monejnemiltía. 
\q1  
\v 22 Pero TOTECO yaya nechmocuitlahuía pampa tlahuel miyac chicahualistli quipiya. 
\q1 Ipan noTeco Dios nimotlatía huan amo tleno huelis nechajsis pampa yaya nechmanahuía. 
\q1  
\v 23 Huan Toteco Dios quichijtoc para ma huetzi ininpani nopa mosisinijca masehualme nochi nopa tlamantli catli amo cuali quichijtoque. 
\q1 Yaya quintzontlamiltis senquistoc quen quisencajtoyaj quinchihuilise sequinoc. 
\q1 Quena, TOTECO toDios yaya quintzontlamiltis. 
\c 95  
\s1 Se huicatl para tijpaquilismacase huan tijhueyichihuase Toteco 
\q1  
\v 1 ¡Xihualaca, ma tihuicaca para TOTECO! 
\q1 Quena, ma tihuicaca ica paquilistli para tijhueyimatise Toteco catli techmaquixtía huan techtlatía para amo tleno techajsis. 
\q1  
\v 2 Ma tiyaca iixpa Toteco para tijtlascamatise ica nochi toyolo. 
\q1 Ma tijpaquilismacaca ica huicatl. 
\q1  
\v 3 Pampa TOTECO yaya se Dios Catli Tlahuel Hueyi. 
\q1 Yaya nopa Hueyi Tlanahuatijquetl huan amo quen nochi sequinoc totiotzitzi catli masehualme quinhueyichihuaj. 
\q1  
\v 4 Imaco eltoc nochi nopa ostotl catli más huejcatla huan nopa tepeme catli más huejcapantique. 
\q1 Nochi iaxca ya. 
\q1  
\v 5 Yaya iaxca nopa hueyi atl huan tlaltipactli, 
\q1 pampa yaya quichijchijqui. 
\q1  
\v 6 Xihualaca, ma tijhueyichihuaca huan ma timoixtlapachoca hasta tlalchi iixpa TOTECO, 
\q1 yaya catli techchijchijqui. 
\q1  
\v 7 Pampa yaya toDios huan tojuanti tiimasehualhua. 
\q1 Tiitztoque quen tiiborregojhua catli yaya quinmocuitlahuía. 
\q1 Achi cuali sintla anquitoscacaquise Toteco. 
\b  
\q1  
\v 8 (Toteco quiijtohua:) 
\q1 “Amo ximoyoltetilica quen israelitame quichijque huejcajya ipan nopa huactoc tlali catli itoca Meriba huan Masah. 
\q1  
\v 9 Nopona amohuejcapan tatahua nechyejyecojque para quiitase tlaque nijchihuasquía. 
\q1 Huan quichijque ya ni masque ipa ya quiitztoyaj nopa huejhueyi tiochicahual nextili catli na nijchijtoya iniixpa. 
\q1  
\v 10 Para cuarenta xihuitl nicualantoya ininhuaya, 
\q1 pampa ininyolo huan inintlalnamiquilis eltoya huejca tlen na. 
\q1 Huan hasta ama amo moselijtoque quitoquilise notlanahuatilhua. 
\q1  
\v 11 Yeca ica nohueyi cualancayo nitlatestigojquetzqui para amo quema calaquise campa nijsencajtoya ma mosiyajquetzaca.” 
\c 96  
\s1 Huicatl para tijpaquilismacase Toteco 
\q1  
\v 1 Nochi catli anitztoque ipan tlaltipactli, 
\q1 xihuicaca para TOTECO. 
\q1 Quena, xihuicaca se huicatl yancuic. 
\q1  
\v 2 Ma tijhuicatica TOTECO por nochi catli quichijtoc. 
\q1 Ma tijpaquilismacaca huan ma tijtlascamatica por nochi catli techchihuilijtoc. 
\q1 Huan mojmostla ma titepohuilica para yaya temaquixtía. 
\q1  
\v 3 Ipan nochi tlaltipactli ma titepohuilica ihueyitilis huan nochi tlamantli yejyectzi catli quichijtoc. 
\q1 Huan nochi masehualme ma tiquinpohuilica nopa huejhueyi tlamantli catli yaya quichihua. 
\q1  
\v 4 Pampa TOTECO nelía tlahuel hueyi huan quinamiqui ma tijhueyimatica. 
\q1 San yaya nelía temajmati huan ne sequinoc catli masehualme quintocaxtíaj dioses, amo. 
\q1  
\v 5 Pampa nochi nopa dioses catli quinhueyichihuaj ipan sequinoc tlalme, 
\q1 amo tleno ininpati. 
\q1 Inijuanti san elij teteyome catli masehualme quinchijchijtoque. 
\q1 Pero TOTECO yaya quichijchijqui ilhuicactli. 
\q1  
\v 6 Campa itztoc Toteco senquistoc onca itlatlanex huan temitoc ica ihueyitilis. 
\q1 Huan ipan itiopa onca ichicahualis huan iyejyejca. 
\q1  
\v 7 Nochi anmasehualme tlen nochi tlaltipactli, 
\q1 xitepohuilica para san TOTECO quipiya chicahualistli huan san yaya hueyi. 
\q1  
\v 8 Xijtlepanitaca TOTECO quen quinamiqui. 
\q1 Xijhualiquilica tlacajcahualistli huan xiyaca icalixpa itiopa. 
\q1  
\v 9 Xihualaca huan xijhueyichihuaca TOTECO. 
\q1 Quena, xijhueyichihuaca ica se amonemilis catli yejyectzi huan tlatzejtzeloltic. 
\q1 Huan nochi tlaltipactli ma huihuipica iixpa. 
\q1  
\v 10 Xiquinpohuilica nochi tlalme para Toteco tlanahuatía. 
\q1 Tlaltipactli quitlalijtoc cuali huan amo quema mijcuinis campa quitlatzquiltijtoc. 
\q1 Huan Toteco Dios xitlahuac quintlajtolsencahuas nochi altepeme. 
\q1  
\v 11 ¡Ma paqui ilhuicactli huan nochi tlaltipactli! 
\q1 ¡Nochi huejhueyi atl ma mocoxonica iixpa Toteco ica paquilistli! 
\q1  
\v 12 ¡Ma paqui nopa cuatitlamitl huan nochi catli onca, 
\q1 pampa nochi cuame quinextíaj para Toteco tlahuel hueyi! 
\q1 Quena, ma tzajtzica nopa cuame para quipaquilismacase iixpa TOTECO, 
\q1  
\v 13 pampa yaya huala. 
\q1 Quena, yaya hualas para quitlajtolsencahuas catli itztoque ipan ni tlaltipactli. 
\q1 Quena, quintlajtolsencahuas masehualme ipan nochi altepeme quen quinamiqui. 
\q1 Quena, quema tetlajtolsencahuas, 
\q1 nochi quimatise para quichihua catli melahuac. 
\c 97  
\s1 Toteco nochi quinahuatía 
\q1  
\v 1 ¡Nochi tlaltipactli ma paqui pampa TOTECO tlanahuatía! 
\q1 Huan nochi nopa pilaltepetzitzi catli mopantíaj tlatlajco hueyi atl, 
\q1 xiquinilhuica nojquiya ma paquica. 
\q1  
\v 2 Mixtli huan tzintlayohuilotl quiyahualojtoc Toteco. 
\q1 Huan itlanahuatilis pejtoc ipan catli melahuac huan catli xitlahuac. 
\q1  
\v 3 Iixpa tlayacanti se tlitl catli quintzontlamiltía icualancaitacahua. 
\q1  
\v 4 Nopa tlapetlanilotl catli yaya quititlani quitlahuilía nochi tlaltipactli. 
\q1 Huan ni tlaltipactli huihuipica quema quiita. 
\q1  
\v 5 Nochi tepeme atiyaj quen cera iixpa TOTECO catli iaxca nochi tlaltipactli. 
\q1  
\v 6 Ilhuicactli tlayolmelahua para Toteco xitlahuac tetlajtolsencahua. 
\q1 Huan nochi tlaltipactli quiita ihueyitilis. 
\q1  
\v 7 Ma mopinahuaca nochi catli quinhueyichihuaj teteyome, 
\q1 huan nochi catli mohueyimatij ica inintlaixcopincayohua catli amo tleno ininpati. 
\q1 Nochi sequinoc amojuanti catli masehualme anmechtocaxtía “andioses” ximotlancuaquetzaca iixpa Toteco. 
\b  
\q1  
\v 8 TOTECO, nopa altepetl Jerusalén huan nochi altepeme ipan tlali Judá quipiyaj paquilistli ica motlamachtil. 
\q1  
\v 9 Pampa ta, tiTOTECO, tijnahuatía nochi tlaltipactli, 
\q1 huan más tihueyi que nochi sequinoc dioses. 
\q1  
\v 10 TOTECO quinicnelía nochi catli quicualancaitaj catli amo cuali. 
\q1 Quinmocuitlahuía imasehualhua huan quinchololtía ininmaco tlaixpanoca masehualme. 
\q1  
\v 11 Catli xitlahuac ininnemilis nemi ipan itlahuil Toteco, 
\q1 huan catli cuali ininyolo quipantíaj paquilistli. 
\q1  
\v 12 Xipaquica ipan TOTECO nochi amojuanti catli anitztoque xitlahuac iixpa. 
\q1 Xijhueyichihuaca huan nochipa xiquelnamictoca para Toteco yaya senquistoc tlatzejtzeloltic. 
\c 98  
\s1 Ma tijpaquilismacaca Toteco pampa yaya xitlahuac tetlajtolsencahua 
\q1  
\v 1 Ma tihuicaca para TOTECO se huicatl yancuic, 
\q1 pampa yaya quichijtoc nochi nopa huejhueyi tiochicahual nextili. 
\q1 Yaya ya tlatlantoc ica ihueyi chicahualis huan ica imax catli tlatzejtzeloltic. 
\q1  
\v 2 TOTECO quipannextijtoc ipan nochi tlaltipactli para san yaya temaquixtía. 
\q1 Quinextijtoc iniixtla sequinoc tlalme para xitlahuac tetlajtolsencahua. 
\q1  
\v 3 Yaya quielnamictoc catli techtencahuilijtoc pampa techicneli tojuanti tiisraelitame. 
\q1 Huan ama ipan nochi tlaltipactli quiitztoque quenicatza Toteco Dios techmaquixtijtoc tiimasehualhua. 
\q1  
\v 4 Yeca ipan nochi tlaltipactli xijpaquilismacaca TOTECO huan xihuicaca ica miyac paquilistli. 
\q1  
\v 5 Xijhuicatica TOTECO. 
\q1 Xijhueyimatica huan xitlatzotzonaca ica arpa. 
\q1  
\v 6 Xijpitzaca nochi tlamantli tlapitzali huan xihuicaca ica yejyectzi iixpa TOTECO, 
\q1 yaya catli Tlanahuatijquetl. 
\q1  
\v 7 ¡Ma mojmolini chicahuac tlen ihuexca nopa hueyi atl huan ma quipaquilismaca Toteco! 
\q1 Nochi tlaltipactli huan catli itztoque ipani ma tzajtzica huan ma quiijtoca: 
\q1 “Tijhueyitlalise Toteco.” 
\q1  
\v 8 Nopa hueyame ma paquica, 
\q1 huan masehualme ma momatlatzinica, 
\q1 huan nochi tepeme ma huicaca ica paquilistli 
\q1  
\v 9 iixpa TOTECO, 
\q1 pampa yaya huala para quintlajtolsencahuaqui xitlahuac nochi masehualme catli itztoque ipan ni tlaltipactli. 
\c 99  
\s1 Toteco yaya tlatzejtzeloltic 
\q1  
\v 1 ¡TOTECO tlanahuatía! 
\q1 Nochi masehualme ipan nochi tlalme ma huihuipicaca ica majmajtli. 
\q1 Isiya campa mosehuía para tlanahuatis quipiya más tlanahuatili huan eltoc más huejcapa que nopa querubines tequihuajme. 
\q1 Nochi catli onca huan nochi catli itztoque ipan tlaltipactli, 
\q1 ma moyolpitzahuilica. 
\q1  
\v 2 Ipan Tepetl Sion nochi quimatij para TOTECO nelía hueyi. 
\q1 Yaya más hueyi tlen nochi sequinoc tlanahuatiani ipan tlaltipactli. 
\q1  
\v 3 Nochi ma quihueyichihuaca Toteco, yaya catli hueyi huan temajmati. 
\q1 San ya nelía tlatzejtzeloltic. 
\q1  
\v 4 Toteco yaya se tlanahuatijquetl catli quipiya nochi chicahualistli, 
\q1 huan quipactía tetlajtolsencahuas xitlahuac. 
\q1 Nochi catli quichihua senquistoc cuali. 
\q1 Yaya quinchihuilijtoc catli xitlahuac nochi israelitame. 
\q1  
\v 5 ¡Ma tijhueyitlalica TOTECO, yaya toDios, 
\q1 yaya catli tlatzejtzeloltic! 
\q1 Ma timotlancuaquetzaca huan ma timoixtlapachoca hasta tlalchi iicxitla, 
\q1 pampa san yaya tlatzejtzeloltic. 
\q1  
\v 6 Quema nopa totajtzitzi Moisés huan Aarón, huan nopa tlajtol pannextijquetl Samuel, 
\q1 quitzajtziliyayaj TOTECO para quitlajtlanise itlapalehuil, 
\q1 yaya quinnanquiliyaya. 
\q1  
\v 7 Toteco quincamanalhui ipan se mixtli, 
\q1 huan inijuanti quichijque nochi catli quiijto icamanal huan itlanahuatilhua. 
\q1 Quena, inijuanti quichijque nochi catli quinilhui ma quichihuaca. 
\b  
\q1  
\v 8 Quena, TOTECO, ta titoDios, ta tiquinnanquili. 
\q1 Ta tieli se Dios catli tiquintlapojpolhuía inintlajtlacolhua masehualme. 
\q1 Pero nojquiya tiquintlatzacuiltía quema quichihuayayaj tlamantli catli amo cuali. 
\b  
\q1  
\v 9 Ma tijhueyitlalica TOTECO huan ma tijhueyichihuaca. 
\q1 Ma timotlancuaixtlapachoca iixtla ipan nopa tepetl tlatzejtzeloltic catli itoca Sion. 
\c 100  
\s1 Ma tijtlascamatica Toteco 
\q1  
\v 1 Xihuicaca ica paquilistli para TOTECO, 
\q1 nochi anmasehualme catli anitztoque ipan ni tlaltipactli. 
\q1  
\v 2 Xijtequipanoca TOTECO ica paquilistli. 
\q1 Huan quema anhualahuij iixpa, xihuicatihualaca. 
\q1  
\v 3 Xijmatica cuali para TOTECO, yaya Toteco Dios. 
\q1 Yaya techchijchijqui. 
\q1 Amo timochijchijtoque tojuanti. 
\q1 Tojuanti tiimasehualhua huan tiitztoque quen tiiborregojhua catli techpixtoc ipan ipotrero para techmocuitlahuis. 
\q1  
\v 4 Quema ticalaquij ipan itiopa, ma tijtlascamatica miyac. 
\q1 Huan quema tinemij icalixpa, ma tihuicaca. 
\q1 Quena, ma tijtlascamatica huan ma tijpaquilismacaca. 
\q1  
\v 5 Pampa TOTECO yaya nelía cuali. 
\q1 Nochipa teicnelía huan tetlasojtla. 
\q1 Yaya itztos temachtli para nochipa ica nochi masehualme catli tlacajtihualahuij. 
\c 101  
\s1 Toteco, tijnequij tiitztose tixitlahuaque 
\q1  
\v 1 Na nijnequi nihuicas para ta, 
\q1 TOTECO, pampa ta techicnelía huan techchihuilía catli xitlahuac. 
\q1 Quena, nimitzpaquilismacas ica huicatl. 
\q1  
\v 2 Nijnequi xitlahuac nimonejnemiltis ipan moojhui, 
\q1 huan quema tihualas techitaqui, 
\q1 amo techpantilis niyon se tlamantli catli amo cuali. 
\q1 Nojquiya nimonejnemiltis xitlahuac ipan nochaj. 
\q1  
\v 3 Amo nijnequi tlamantli catli nenpolihui huan catli amo tleno ipati. 
\q1 Amo nijchihuas tlamantli catli amo xitlahuac. 
\q1  
\v 4 Nijhuejcamajcahuas nochi tlalnamiquilistli catli nechchihuasquía ma nijchihua catli fiero. 
\q1 Amo nijnechcahuis tlamantli catli amo cuali. 
\q1  
\v 5 Amo niquijiyohuis catli quiichtacaejelnamiqui ihuampox. 
\q1 Huan amo aqui nijcahuilis ma mohueyimati huan moyacaquetzas. 
\q1  
\v 6 Niquinmocuitlahuis nopa masehualme catli temachme ipan notlal, 
\q1 huan niquinnotzas para ma itztoca nohuaya ipan nochaj. 
\q1 Huan san catli nelía monejnemiltíaj xitlahuac, 
\q1 niquincahuilis ma nechtequipanoca. 
\q1  
\v 7 Pero amo niquincahuilis ma itztoca ipan nochaj catli tlacajcayahuaj huan istlacatij. 
\q1  
\v 8 Mojmostla ica ijnaloc niquintzontlamiltis nochi catli amo tleno quitlepanitaj. 
\q1 Huan quej nopa niquintlamiltis nochi catli quichihuaj catli fiero ipan ialtepe TOTECO. 
\c 102  
\s1 Inetlatlajtil se catli motequipachohua 
\q1  
\v 1 ¡TOTECO, techtlacaquili quema nimotlatlajtía! 
\q1 Xijchihua cuenta nocamanal quema nimitztzajtzilía para techpalehui. 
\q1  
\v 2 Amo ximohuejcatlali tlen na ipan nopa hora quema nitlaijiyohuía. 
\q1 ¡Ximohuijtzoma para techtlacaquilis huan nimantzi technanquili quema nimitznotza! 
\q1  
\v 3 Pampa mojmostla nonemilis tlantiya quen poctli. 
\q1 Huan noomiyohua nijmachilía quen tlatlasquía. 
\q1  
\v 4 Tlahuel nimococohua ipan noyolo. 
\q1 Ayacmo nijpiya chicahualistli. 
\q1 Niitztoc quen se xihuitl catli pilintoc. 
\q1 Ayacmo nimayana huan niquelcahua para nitlacuas. 
\q1  
\v 5 Huan pampa tlahuel nitlaayijhuijtoc, 
\q1 tlamicuahuaqui nocuetlaxo ipan noomiyo. 
\q1  
\v 6 Nijmati quen nielisquía nopa tzopilotl catli nemi ipan nopa tlali campa amo tleno eli, 
\q1 o quen cuamojmojtli catli iseltzi itztoc ipan huactoc tlali. 
\q1  
\v 7 Nochi yohuali ayacmo nicochi. 
\q1 Niitztoc quen nopa tototl catli nemi iseltzi huan mosehuía itzonatipa se cali. 
\q1  
\v 8 Nocualancaitacahua mojmostla nechpinajtíaj huan nechtelchihuaj. 
\q1  
\v 9 Ayacmo nijcua pantzi. 
\q1 Ama nijcua cuanextli huan catli niquiji momanelohua ica noixayo, 
\q1  
\v 10 pampa tlahuel ticualantoc ica na. 
\q1 Ama techtlanantoc huan teipa techhuejcamajcajtoc. 
\q1  
\v 11 Nonemilis panoti chicahuac quen tlayohuilotl. 
\q1 Huan notlacayo pilinti quen xihuitl. 
\q1  
\v 12 Pero ta TOTECO, tiitztos para nochipa, 
\q1 huan nochi catli tlacajtiyase para nochipa mitzelnamictose. 
\q1  
\v 13 Na nijmati para ta timotlananas huan tihualas para tijtlasojtlaqui altepetl Jerusalén. 
\q1 Huan ama ya ajsic tonali para tijtlasojtlas huan tijpalehuis quen tijtlajtolcajtoc. 
\q1  
\v 14 Pampa momasehualhua tlahuel quinicnelíaj nopa teme tlen itepa Jerusalén, 
\q1 huan hasta quitlasojtlaj nopa tlaltejpoctli catli onca ipan icalles ni altepetl pampa nochi moaxca ta. 
\b  
\q1  
\v 15 Huajca nochi tlalme huan inintlanahuatijcahua ma huihuipicaca iixpa TOTECO. 
\q1 Quena, huihuipicase quema quiitase ihueyitilis. 
\q1  
\v 16 Pampa TOTECO sempa quicualtlalis altepetl Jerusalén. 
\q1 Huan nopona yaya monextis ica nochi ihueyitilis. 
\q1  
\v 17 Yaya quintlacaquilis nopa teicneltzitzi quema motlatlajtise, 
\q1 pampa yaya nochipa mochixtoc para quintlacaquilis huan quinmacas catli quitlajtlaníaj. 
\q1  
\v 18 Niquijcuilohua ya ni para nochi catli tlacajtiyase teipa ma nojquiya quihueyichihuase TOTECO por nochi catli quichijtoc. 
\q1  
\v 19 Pampa TOTECO quihualtlachili tlaltipactli tlen nepa ilhuicac campa eltoc itiopa, 
\q1 Quena, tlen ilhuicac quitlachili catli onca ipan tlaltipactli. 
\q1  
\v 20 Huan quintlacaquili quema tlaayijhuiyayaj imasehualhua catli tetequipanohuayayaj ipan sequinoc tlalme. 
\q1 Huan quinmanahui imaco miquilistli. 
\q1  
\v 21 Huajca miyac masehualme sempa hualase ipan altepetl Jerusalén para quipaquilismacase TOTECO. 
\q1 Quena, quipaquilismacase ipan nochi ni altepetl. 
\q1  
\v 22 Huan miyac tlanahuatiani tlen ni tlaltipactli hualase para quitequipanose huan quihueyichihuase TOTECO. 
\q1  
\v 23 Yaya nechquixtili nochicahualis quema noja polihuiyaya tlajco para nimiquis, 
\q1 huan nonemilis quichijqui más cototzi. 
\q1  
\v 24 Pero nijtzajtzili huan niquilhui: 
\q1 “NoTeco Dios, ta tiitztoc para nochipa. 
\q1 Amo techcahuili nimiquis quema noja nechpolohua tlajco imiyaca tonali para niitztos. 
\q1  
\v 25 Hasta ipejya tonali ta tijtlali itzinpehualtil ni tlaltipactli, 
\q1 huan ica momax tijsencajqui ilhuicactli. 
\q1  
\v 26 Masque nochi catli tijsencajqui se tonali tlamis, 
\q1 ta tiitztos para nochipa. 
\q1 Quena, nochi catli tijchijtoc sosolihuise quen se yoyomitl, 
\q1 huan ta tiquinpatlas quen se tlacatl mopatla huan moquentía se iyoyo catli yancuic, 
\q1 huan nopa catli sosoltic quitlahuisohua. 
\q1  
\v 27 Pero ta amo quema tihuehuejtiyas. 
\q1 Nochipa san se tiitztos. 
\q1 Tiitztos para nochipa huan monemilis amo quema tlamis. 
\q1  
\v 28 Pero tojuanti catli timotequipanojcahua, 
\q1 hasta toixhuihua, itztose ica temachili, 
\q1 huan hasta iniixhuihua catli tlacajtiyase itztose cuali moixpa.” 
\c 103  
\s1 Ma tijpaquilismacaca Toteco por nochi itlatiochihual catli techmacatoc 
\q1  
\v 1 Ica nochi noyolo nijpaquilismacas TOTECO yaya catli tlatzejtzeloltic. 
\q1  
\v 2 Quena, nijpaquilismacas TOTECO ica nochi noyolo, 
\q1 huan amo niquelcahuas nopa huejhueyi tlamantli catli nechchihuilijtoc. 
\q1  
\v 3 Yaya nechtlapojpolhuía nochi notlajtlacolhua. 
\q1 Huan nechchicahua quema nimococohua. 
\q1  
\v 4 Nechchololtía imaco miquilistli. 
\q1 Nechyahualohua ica itlaicnelijcayo huan ica nochi nopa tlamantli catli nechchihuilía, 
\q1 pampa nechtlasojtla. 
\q1  
\v 5 Quitemitía nonemilis ica tlamantli catli cuali. 
\q1 Huan mojmostla más nijpiya chicahualistli hasta nijpiya tetili quen se hueyi cuajtli. 
\q1  
\v 6 TOTECO quinchihuilía catli cuali huan quintlajtolsencahua xitlahuac nochi masehualme catli tlaijiyohuíaj ininmaco sequinoc. 
\q1  
\v 7 Toteco quinextili Moisés quenicatza eltoc, 
\q1 huan quinnextili iisraelita masehualhua nopa huejhueyi tlamantli catli quichihua ica ihueyi chicahualis. 
\q1  
\v 8 TOTECO tetlasojtla miyac huan quipiya hueyi iyolo. 
\q1 Yaya tlahuel huejcahua para pehuas cualanis. 
\q1 Amo quema tlami itlaicnelijcayo. 
\q1  
\v 9 Amo techtlaijilhuía tlatoctzitzi, 
\q1 niyon amo huejcahua cualantoc. 
\q1  
\v 10 Yaya amo techtlatzacuiltijtoc quen quinamiqui, 
\q1 por nochi totlajtlacolhua, 
\q1  
\v 11 pampa yaya quipiya nelhueyi iyolo ica nochi catli quiimacasij huan quitlepanitaj. 
\q1 Quena, itlaicnelijcayo nelhueyi quen ihuexca ilhuicactli. 
\q1  
\v 12 Toteco techquixtili totlajtlacolhua huan quitlali huejca tlen tojuanti. 
\q1 Quena, quitlali quen ihuejcaca campa hualquisa tonati huan hasta campa oncalaqui. 
\q1  
\v 13 Quen se tetata quintlasojtla iconehua, 
\q1 quej nopa TOTECO quintlasojtla catli quiimacasij huan quitlepanitaj. 
\q1  
\v 14 Pampa Toteco quimati para tojuanti san tielij tlaltejpoctli, 
\q1  
\v 15 huan tonemilis san panotiquisa huan amo huejcahua. 
\q1 Tonemilis eltoc quen se xihuitl o quen se xochitl. 
\q1  
\v 16 Quema quiilpitza ajacatl, 
\q1 ixpolihui tonemilis huan ayacmo aqui hueli quimati sintla nelía tiitztoyaj. 
\q1  
\v 17 Pero TOTECO mojmostla quinicnelía nochi catli quiimacasij huan quitlepanitaj. 
\q1 Huan quinchihuilis catli xitlahuac nochi masehualme catli itztoque ama huan nojquiya ininconehua catli tlacajtiyase teipa. 
\q1  
\v 18 Quena, yaya quinchihuilis catli cuali inijuanti catli quichihuaj catli ica mocajtoque quichihuase, 
\q1 huan inijuanti catli quichihuaj catli quiijtohuaj itlanahuatilhua. 
\q1  
\v 19 TOTECO quitlalijtoc isiya nepa ilhuicac huan nopona mosehuía para tlanahuatis. 
\q1 Yaya quipiya tlanahuatili ica nochi catli onca. 
\q1  
\v 20 Xijpaquilismacaca TOTECO nochi amojuanti anitequihuajcahua catli tlahuel antejtetique. 
\q1 Quena, amojuanti catli anquitlacaquilíaj catli anmechnahuatía huan nimantzi anquichihuaj, 
\q1 xijpaquilismacaca. 
\q1  
\v 21 Quena, xijhueyimatica TOTECO nochi amojuanti anitequihuajcahua catli anitztoque quen isoldados. 
\q1 Xijhueyimatica amojuanti catli anquitequipanohuaj huan anquichihuaj catli yaya quinequi. 
\q1  
\v 22 ¡Nochi masehualme huan nochi tlamantli catli mopantíaj campa hueli ipan nochi itlanahuatilis, 
\q1 nochi ma quipaquilismacaca TOTECO! 
\q1 Na nojquiya tlahuel nijpaquilismaca. 
\c 104  
\s1 Toteco quimocuitlahuía catli quisencajtoc 
\q1  
\v 1 ¡Na nimitzpaquilismacas, TOTECO! 
\q1 ¡TOTECO Dios, nelía tihueyi! 
\q1 Campa ta timocahua nochi tlayejyectzi huan cuajcualtzi. 
\q1  
\v 2 Mitzyahualohua tlahuili catli onpano yejyectzi. 
\q1 Ta tijpatlajqui nopa ilhuicactli quen se masehuali quipatlajtosquía se yoyomitl. 
\q1  
\v 3 Eltoc quen quema timochanti, 
\q1 tijtlali nopa cuatetomitl ipan atl catli huejcapa, 
\q1 huan tijsencajqui nopa mixtli para elisquía mocarros. 
\q1 Ta tihueli tinejnemi san ajacatipa. 
\q1  
\v 4 Tiquintequihuía motequihuajcahua quen motlatitlanilhua huan tiquinchihua ma elica quen tlilelemectli. 
\q1  
\v 5 Ta cuali tijtlatzquilti ni tlaltipactli para ma amo mijcuinis tlen campa eltoc. 
\q1  
\v 6 Tijchijqui ma huala miyac atl catli quiixtzajqui ni tlaltipactli quen elisquía iyoyo. 
\q1 Quena, tijchijqui atl ma tlejco hasta ajsic ipan nochi tepeme. 
\q1  
\v 7 Pero quema ta ticamanaltic huan ticajhuac nopa atl, 
\q1 nopa atl motlalojtejqui huan mosansejcotilito ipan nopa hueyi atl pampa ta titlahuejchijqui. 
\q1  
\v 8 Tlejcoque tepeme huan nopa tlamayame temoque ipan ininlugar campa ta titlanahuati ma mosehuica. 
\q1  
\v 9 Teipa tiquintlalili ininnepa nopa huejhueyi atl para ayacmo quema ma quiixtzacuaca tlali. 
\q1  
\v 10 Ta tijchijqui atl ma motlalo ipan atlajtli campa tepeme, 
\q1 huan ma temotihuala hasta quitemitía campa más tlatzintla nopa tlamayame campa hueli. 
\q1  
\v 11 Ica nopa atl tiquinamaca nochi tlapiyalme para ma atlica. 
\q1 Ipan nopa atlajtli aixhuij nopa burrojme catli nemij cuatitla. 
\q1  
\v 12 Nopa totome quichihuaj inintepasol iteno nopa atlajtli, 
\q1 huan huicaj quema itztoque ipan ininmacuayo nopa cuame. 
\q1  
\v 13 Ta tijchihua ma huetzi atl ipan tepeme, 
\q1 huan tijchihua ma tlaelilti nopa tlali. 
\q1  
\v 14 Quena, ta Toteco tijchihua ma moscalti sacatl para ma tlacuaca tlapiyalme. 
\q1 Huan tijchihua ma onca quilitl, 
\q1 cuatlajcayotl huan cuayolotl catli masehualme quitocaj para ma ica mopanoltica. 
\q1  
\v 15 Nojquiya tiquinmaca xocomecatl iayo para ma ica yolpactoca, 
\q1 huan aceite para ma mopoloca ipan iniixayac, 
\q1 huan nojquiya tiquinmaca tlacualistli para ma quipiyaca fuerza. 
\q1  
\v 16 Ica nopa atl moscaltíaj nopa tiocuame catli ta, TOTECO, 
\q1 tijtojqui ipan tlali Líbano. 
\q1 Nopa cuame tlahuel huejcapantique huan quipiyaj miyac ininxochiyo. 
\q1  
\v 17 Ipan nopa cuame motepasoltíaj nochi tlamantli totome. 
\q1 Huan ipan nopa ciprés cuahuitl motepasoltía nopa tototl catli itoca cigüeña. 
\q1  
\v 18 Inintzonatipa nopa huejhueyi tepeme onca sacatl para nopa chivojme catli nemij cuatitla. 
\q1 Huan campa cocoyocatoc nopa teme, mochantijtoque nopa cuatochime. 
\q1  
\v 19 Toteco, ta tijchijqui metztli para quinextis ipan tlaque metztli itztoque masehualme. 
\q1 Huan nopa tonati tijchijqui para tenextilis sesen tonal. 
\q1  
\v 20 Ta tijtitlani nopa tzintlayohuilotl huan mochihua yohuali, 
\q1 huan quema tlayohua, quisaj nochi tecuanime catli itztoque ipan cuatitlamitl. 
\q1  
\v 21 Nopa leones catli noja conetzitzi nanalcaj pampa mayanaj. 
\q1 Huan quitemohuaj nopa tlacualistli catli ta, Toteco Dios, tiquinmacas. 
\q1  
\v 22 Quema quisas tonati sempa onmotlatíaj ipan iniosto. 
\q1  
\v 23 Huan masehualme quisaj para tequipanotij, 
\q1 huan tequitij chicahuac hasta tiotlac. 
\q1  
\v 24 ¡TOTECO, nelía tijchijtoc miyac tlamantli! 
\q1 Huan nochi tlamantli tijsencajtoc ica miyac tlalnamiquilistli. 
\q1 Nejmaxtic tlaltipactli temitoc ica miyac tlamantli yejyectzitzi catli ta tijchijtoc. 
\q1  
\v 25 Xiquitaca nopa hueyi atl catli tlahuel patlahuac huan hueyi. 
\q1 Nopona itztoque miyac tlamantli tlapiyalme tziquitetzitzi huan huejhueyi. 
\q1  
\v 26 Nopona nejnemij nopa huejhueyi barcos, 
\q1 huan nopona itztoc nopa hueyi tlapiyali itoca leviatán catli temajmati catli ta tijchijqui para ma mahuilti ipan hueyi atl. 
\q1  
\v 27 Nochi ni tlapiyalme mochiyaj ipan ta para xiquintlamaca quema monequi. 
\q1  
\v 28 Huan quema tiquinmaca inintlacualis, 
\q1 inijuanti quiselíaj. 
\q1 Ta timomatlapohua ica motlaicnelilis huan tiquintlamaca hasta ixhuij ica tlen más cuali. 
\q1  
\v 29 Pero sintla tiquintlahuelcahua, inijuanti motequipachohuaj. 
\q1 Huan sintla tiquinquixtilía ininnemilis, miquij huan mocuepaj tlaltejpoctli. 
\q1  
\v 30 Huan quema ta tijtitlani moTonaltzi catli temaca nemilistli, 
\q1 tlacatij sempayano para sempa ma momiyaquilica huan tlacualnesis ipan ni tlaltipactli. 
\b  
\q1  
\v 31 ¡Ma tijhueyitlalica TOTECO pampa ihueyitilis amo quema tlamis! 
\q1 ¡Ma quipanti paquilistli TOTECO ipan nochi catli quichijtoc! 
\q1  
\v 32 Quema Toteco quitlachilía tlaltipactli, ni tlaltipactli huihuipica. 
\q1 Huan quema quinpanajsi tepeme, inijuanti lemenij. 
\q1  
\v 33 Nijhuicatis TOTECO nochi tonali catli niitztos ipan ni tlali. 
\q1 Quena, nijpaquilismacas Toteco Dios ica tiohuicatl hasta tlamis nitlaijiyotilanas. 
\q1  
\v 34 Ma quipacti TOTECO nochi catli nimonejnehuilía tlen ya, 
\q1 huan na nimopaquilismaca ipan ya. 
\q1  
\v 35 Ma miquica nochi catli quinpactía tlajtlacolchihuaj ipan ni tlaltipactli. 
\q1 Quena, ma ayacmo itztoca catli amo quinequij quitlepanitase TOTECO. 
\q1 Pero na nijpaquilismacas ica nochi noyolo. 
\q1 ¡Paquilistli! 
\c 105  
\s1 Nopa huejhueyi tlamantli catli Toteco quinchihuili israelitame 
\q1  
\v 1 Xijtlascamatica TOTECO por nochi nopa huejhueyi tlamantli catli yaya quichihua. 
\q1 Xitepohuilica ipan nochi tlaltipactli catli yaya quichijtoc. 
\q1  
\v 2 ¡Xijhuicatica! 
\q1 Quena, xijhuicatica tiohuicatl. 
\q1 Xitlacamanalhuica tlen nopa huejhueyi tiochicahual nextili catli yaya quichijtoc. 
\q1  
\v 3 ¡Ximopaquilismacaca ipan Toteco! 
\q1 ¡Quena, xipaquica nochi amojuanti catli anquihueyichihuaj TOTECO! 
\q1  
\v 4 Xijtemoca TOTECO huan ichicahualis. 
\q1 Quena, nochipa xijtemoca para anquiiximatise más. 
\q1  
\v 5 Xiquelnamiquica nopa tiochicahual nextili catli yaya quichijqui por amojuanti. 
\q1 Xiquelnamiquica itlamachtil huan catli yaya quiijtojtoc. 
\q1  
\v 6 Aniixhuihua Abraham catli itequipanojca Toteco, 
\q1 huan amojuanti aniconehua Jacob catli Toteco quitlapejpeni, 
\q1 xiquelnamiquica. 
\q1  
\v 7 Yaya TOTECO huan yaya toDios. 
\q1 Catli yaya tlanahuatijtoc para mochihuas, ya nopa monextía ipan nochi tlaltipactli. 
\q1  
\v 8 Yaya amo quema quielcahuas nopa camanal sencahuali catli quichijqui, 
\q1 masque tlacajtiyase masehualme huan ininconehua huan mil hueltas tlacatise ininteipan ixhuihua, 
\q1 yaya amo quielcahuas. 
\q1  
\v 9 Noja eltoc nopa camanal sencahuali catli quichijqui ica Abraham huan Isaac. 
\q1  
\v 10 Teipa quiompahui nopa camanal sencahuali ica Jacob para ma pano ica nochi israelitame, 
\q1 huan elis para inijuanti para nochipa. 
\q1  
\v 11 Huan Toteco quiijto: 
\q1 “Na nimechmacas nopa tlali Canaán para elis amoaxca para nochipa.” 
\q1  
\v 12 Quinilhui ya ni quema inijuanti noja ayamo eliyayaj miyaqui, 
\q1 huan san itztoyaj quen paxalohuani ipan tlali Canaán. 
\q1  
\v 13 Teipa san panotinenque tlen se tlali hasta seyoc tlali, 
\q1 huan tlen se tlanahuatilistli hasta seyoc tlanahuatilistli. 
\q1  
\v 14 Pero ipan nochi nopa tlamantli Toteco amo quincahuili ma quinajsi se tlamantli catli amo cuali. 
\q1 Huan tlanahuatiani catli quichijque campica para quinchihuilise catli fiero, 
\q1 Toteco quintlatzacuilti. 
\q1  
\v 15 Toteco Dios quinilhui: 
\q1 “Amo xiquincuatotonica nomasehualhua catli niquintlapejpenijtoc, 
\q1 niyon amo tleno xiquinchihuilica notlajtol pannextijcahua.” 
\q1  
\v 16 Toteco quititlanqui se hueyi mayantli ipan tlali Canaán, 
\q1 huan quinquixtili nochi tlamantli tlacualistli catli ica mopanoltiyayaj. 
\q1  
\v 17 Pero teipa Toteco quititlanqui se tlacatl ma quintlayacancuili para quinmanahuis imasehualhua tlen nopa mayantli. 
\q1 Quena, elqui José catli quinamacatoyaj para ma tequipanoti san tlapic ipan tlali Egipto. 
\q1  
\v 18 Huan nepa ipan tlatzactli quimetzcocojque quema quimetzilpijque ica tepos cadena, 
\q1 huan quiilpilijque se tepostli ipan iquechtla. 
\q1  
\v 19 Nopona itztoya José hasta ajsic nopa tonali catli TOTECO quiixquetztoya. 
\q1 Quena, Toteco quiyejyeco José para quiitas sintla cuali elqui ipan iyolo. 
\q1  
\v 20 Huajca Faraón catli eliyaya hueyi tlanahuatijquetl, tlanahuati ma quiquixtica. 
\q1 Huan quicajqui ma yohui majcajtoc. 
\q1  
\v 21 Teipa nopa tlanahuatijquetl quitlali ma quinyacana nochi itequipanojcahua, 
\q1 huan ma quimocuitlahui nochi catli quipixtoya. 
\q1  
\v 22 Mocajqui ipan ya imax para quintlatzacuiltis itequipanojcahua catli más hueyi, 
\q1 huan para ma quintlalnamicti catli huehuentzitzi. 
\q1  
\v 23 Teipa Israel ajsico ipan tlali Egipto, 
\q1 huan itztoya nopona ihuaya iconehua ipan tlali Cam. 
\q1  
\v 24 Huan Toteco tlahuel quinmiyaquili iixhuihua Jacob, 
\q1 huan quipixque más chicahualistli, 
\q1 huan amo quen inincualancaitacahua catli quinnahuatiyayaj. 
\q1  
\v 25 Teipa Toteco quinyolpatlac nopa egiptome, 
\q1 huan quinchijqui ma quincualancaitaca nopa israelitame. 
\q1 Quena, quincualancaitaque huan quinchihualtijque ma tetequipanoca san tlapic. 
\q1  
\v 26 Pero teipa Toteco quititlanqui itequipanojca, Moisés, 
\q1 huan Aarón catli yaya quintlapejpenijtoya. 
\q1  
\v 27 Huan inijuanti quichijque huejhueyi tlanextilijcayotl huan tiochicahual nextili ipan tlali Egipto. 
\q1  
\v 28 Quena, Toteco quititlanqui tzintlayohuilotl ipan nochi nopa tlali, 
\q1 pampa amo quichihuilijque cuenta itlanahuatil para ma quincahuaca imasehualhua ma yaca majcajtoque. 
\q1  
\v 29 Teipa quicuepqui estli nochi atl catli oncayaya ipan nopa tlali. 
\q1 Huan nopa michime mijque. 
\q1  
\v 30 Teipa quintitlanqui tlahuel miyac temasolime ipan nochi nopa tlali, 
\q1 huan calajque hasta ipan nopa cuarto campa cochqui nopa tlanahuatijquetl. 
\q1  
\v 31 Teipa quema Moisés camanaltic, 
\q1 hualajque miyac sayolime. 
\q1 Huan atime quitlapachocoj nopa tlali. 
\q1  
\v 32 Nojquiya quintitlanili huejhueyi tesihuitl huan amo atl. 
\q1 Huan tlapetlaniyaya campa hueli ipan nochi nopa tlali. 
\q1  
\v 33 Huan nopa tesihuitl quinenpolo nochi xocomeca mili, huan higuera cuame, 
\q1 huan quitlami pojpostejqui nopa huejhueyi cuame. 
\q1  
\v 34 Teipa Toteco camanaltic huan ajsicoj tlahuel miyac chapolime, 
\q1 hasta amo aqui hueliyaya quinpohua. 
\q1  
\v 35 Huan quicuajque nochi tlamantli xihuime catli oncayaya ipan nopa tlali, 
\q1 huan nojquiya quitlamicuajque nochi tlamantli pixquistli. 
\q1  
\v 36 Teipa quinmicti nopa coneme catli achtihui tlacatque ipan sesen familia tlen tlali Egipto. 
\q1 Quinmicti masque nopa tetajme tlahuel paquiyayaj huan motlepanitayayaj por nopa iniachtihui cone. 
\q1  
\v 37 Huan Toteco quinquixti imasehualhua ica temachili, 
\q1 huan quihuicaque miyac oro huan plata. 
\q1 Huan ipan nopa tonali amo mococo niyon se imasehual Toteco. 
\q1  
\v 38 Huajca nopa egiptome nelía pajque quema quisque nopa israelitame, 
\q1 pampa nochi inijuanti tlahuel quinimacasiyayaj. 
\q1  
\v 39 Toteco quipatlajqui inintzonatipa se mixtli para quinecahuilis huan amo quintlatis tonati. 
\q1 Huan ica tlayohua quitlaliyaya se tlilelemectli inintzonatipa para ma quintlahuili. 
\q1  
\v 40 Quitlajtlanijque ma quinmaca nacatl para quicuase, 
\q1 huan quintitlanili solime. 
\q1 Nojquiya quinmacac nopa tlacualistli catli itoca “maná” catli huetzqui tlen ilhuicac para ica ma ixhuica. 
\q1  
\v 41 Toteco quitlapo se tetl huan quisqui atl hasta mochijqui quen se hueyatl, 
\q1 catli motlalo ipan nopa huactoc tlali campa amo tleno eliyaya. 
\q1  
\v 42 Pampa yaya quielnamijqui catli ica mocajtoya itequipanojca Abraham. 
\q1  
\v 43 Huajca ica miyac paquilistli Toteco Dios quinquixti imasehualhua catli quintlapejpenijtoc ipan tlali Egipto. 
\q1  
\v 44 Huan quinmacac imasehualhua nopa tlalme catli elque iniaxca masehualme catli amo israelitame. 
\q1 Huan moaxcatijque ica nochi nopa pixquistli catli nopona oncayaya. 
\q1 Quicuajque cuatlactli catli sequinoc quitoctoyaj. 
\q1  
\v 45 Nochi ya ni quichijqui para ma quichijtinemica catli quinilhuijtoya huan ma quintoquilijtinemica itlanahuatilhua. 
\q1 ¡Paquilistli! 
\c 106  
\s1 Ininyolteticayo israelitame 
\q1  
\v 1 ¡Paquilistli! 
\q1 ¡Ma tijtlascamatica TOTECO pampa yaya nelía cuali iyolo huan itlaicnelijcayo amo quema tlamis ica tojuanti! 
\q1  
\v 2 ¿Ajqueya huelis quitlamiijcuilos nopa yejyectzitzi tiochicahual nextili catli TOTECO quichihua? 
\q1 ¿Ajqueya huelis tepohuilis nochi catli quichijtoc Toteco? 
\q1  
\v 3 Quipiyaj paquilistli nopa masehualme catli nochipa quichijtinemij catli cuali huan catli xitlahuac. 
\b  
\q1  
\v 4 TOTECO, techelnamiquis na quema tiquintiochihuas huan tiquinmaquixtis momasehualhua. 
\q1  
\v 5 Techcahuili ma niquitas catli yejyectzi tiquinchihuilis momasehualhua catli tiquintlapejpenijtoc. 
\q1 Xijcahuili para nojquiya ma nipaquis ininhuaya. 
\q1 Xijcahua ma nimopaquilismacas ica inijuanti catli moaxcahua. 
\b  
\q1  
\v 6 Tojuanti nojquiya titlajtlacolchijtoque san se quen tohuejcapan tatahua. 
\q1 Titlaixpanoque huan tijchijtoque catli fiero. 
\q1  
\v 7 Tohuejcapan tatahua amo quimachilijque nopa huejhueyi tiochicahual nextili catli Toteco quichijqui ipan tlali Egipto. 
\q1 Niyon amo quielnamijque para quipixqui hueyi iyolo ininhuaya. 
\q1 Inijuanti moyoltetilijque ica Toteco nepa campa nopa hueyi atl catli itoca Chichiltic. 
\q1  
\v 8 Pero Toteco quinmaquixti para ma quitlepanitaca, 
\q1 huan tenextili ihueyi chicahualis ipan nochi tlaltipactli. 
\q1  
\v 9 Quiajhuac nopa hueyi atl catli itoca Chichiltic huan quinahuati ma motlajcoxelo. 
\q1 Huan quej nopa quitlapo se ojtli huactoc quen elisquía huactoc tlali, 
\q1 huan quinchihualti tohuejcapan tatahua ma ipan panoca. 
\q1  
\v 10 Quej nopa quinmaquixti huan quinchololti ininmaco inincualancaitacahua. 
\q1  
\v 11 Huan nopa atl quinatzonpolihuilti inincualancaitacahua hasta amo mocajqui niyon se catli amo mijqui. 
\q1  
\v 12 Huan huajca tohuejcapan tatahua quineltocaque icamanal catli Toteco quinilhuijtoya. 
\q1 Huan teipa huicaque huan quipaquilismacaque. 
\q1  
\v 13 Pero sempa nimantzi quielcajque nochi catli Toteco quichijtoya. 
\q1 Huan amo mochixque para Toteco ma quinmaca consejos. 
\q1  
\v 14 ¡Amo! Nepa ipan huactoc tlali quiyejyecojque Toteco Dios ica catli tlahuel quinequiyayaj ma quinmaca. 
\q1 Quena, quifuerzajhuijque ma quinmaca nopa tlacualistli catli inijuanti quinequiyayaj. 
\q1  
\v 15 Huajca Toteco quinmacac catli quitlajtlanijque, 
\q1 pero nojquiya quintitlanili cocolistli catli ica mijque miyac nopa masehualme. 
\q1  
\v 16 Huan nopona campa quiquejquetztoyaj ininyoyoncal, 
\q1 quichicoitaque Moisés, 
\q1 huan quichicoitaque Aarón catli TOTECO quiiyocatlalijtoya para ma eli itotajtzi. 
\q1  
\v 17 Huajca motlapo tlali huan quintolo Datán, Abiram huan nochi catli quintoquiliyayaj. 
\q1  
\v 18 Huan Toteco quititlanqui tlitl tlen ilhuicac, 
\q1 huan quintlamitlati nopa tlaixpanoca tlacame. 
\q1  
\v 19 Nepa ipan tepetl Horeb mochihuilijque se becerro tlen oro huan ya nopa quihueyichijque. 
\q1  
\v 20 Quitlahuelcajque Toteco huan ihueyi chicahualis, 
\q1 huan pejque quihueyimatij se becerro tlen oro, 
\q1 iixcopinca se tlapiyali catli quicua xihuitl. 
\q1  
\v 21 Huan quej nopa quielcajque ininTeco Dios catli quinmaquixtijtoya, 
\q1 yaya catli quichijtoya huejhueyi tlamantli ipan tlali Egipto, 
\q1  
\v 22 huan ipan nopa hueyi atl catli itoca Chichiltic. 
\q1  
\v 23 Huajca Toteco quiijto para quintzontlamiltisquía, 
\q1 pero Moisés catli Toteco quitlapejpenijtoya motlajcoquetzqui, 
\q1 huan quitlajtlani Toteco para amo ma quintzontlamilti ica ihueyi cualancayo. 
\q1  
\v 24 Teipa nopa israelitame amo quinejque calaquise ipan nopa tlali catli nelía cuali, 
\q1 pampa amo quineltocaque para Toteco quinmocuitlahuisquía. 
\q1  
\v 25 Huan ipan ininchajchaj pejque quiejelnamiquij TOTECO huan amo quitlacaquilijque catli quinilhuiyaya ma quichihuaca. 
\q1  
\v 26 Yeca Toteco Dios momatlananqui huan tlatestigojquetzqui para quintzontlamiltisquía ipan nopa huactoc tlali. 
\q1  
\v 27 Quiijto para ininconehua quinsemanasquía huan quintitlanisquía, 
\q1 ipan sequinoc tlalme para ma itztotij quen sequinoc altepetl ehuani. 
\q1  
\v 28 Nojquiya ipan tlali Peor tohuejcapan tatahua mosansejcotilijque ininhuaya catli quihueyichihuayayaj Baal, 
\q1 huan hasta quinmacaque tlacajcahualistli mijcatzitzi. 
\q1  
\v 29 Huan ica ya ni quicualancamacaque Toteco. 
\q1 Yeca Toteco quititlanqui se hueyi cocolistli ininpani huan miyac mijque. 
\q1  
\v 30 Huan Finees moneltlali huan motlananqui, 
\q1 huan quinmicti nopa masehualme catli ica inintlajtlacolhua quichijtoyaj ma huala nopa cocolistli. 
\q1 Huan ica ya nopa moquetzqui nopa cocolistli. 
\q1  
\v 31 Huan ni cuali tlamantli quichijqui para Finees ma quielnamictoca para nochipa quen se tlacatl catli cuali. 
\q1  
\v 32 Nojquiya campa atl Meriba, 
\q1 nopa israelitame quicualancamacaque Toteco. 
\q1 Quena, por inijuanti, Toteco cualanqui ica Moisés. 
\q1  
\v 33 Pampa quichijque ma cualani Moisés, 
\q1 huan ma camanaltitiquisa ica catli amo monequiyaya. 
\q1  
\v 34 Huan nojquiya nopa israelitame amo quintzontlamiltijque nochi nopa altepeme, 
\q1 ipan nopa tlalme catli TOTECO quinnahuatijtoya ma quisosoloca. 
\q1  
\v 35 San achi más mosansejcotilijque ininhuaya catli amo quitlepanitayayaj Toteco, 
\q1 huan nojquiya quichijque catli inijuanti momajtoyaj quichihuaj. 
\q1  
\v 36 Quinhueyimatque ininteteyohua, 
\q1 huan mohuejcatlalijque tlen Toteco, 
\q1 huan ica ya nopa mopolojque. 
\q1  
\v 37 Hasta quinmictijque ininconehua quen se tlacajcahualistli para iajacahua Amocualtlacatl. 
\q1  
\v 38 Huan pampa quinmictijque ininconehua catli amo tleno quichijtoyaj para quinmacase nopa teteyome tlen tlali Canaán, 
\q1 quinenpolojque nopa tlali ica inieso. 
\q1  
\v 39 Huan inijuanti nojquiya monenpolojque ica nochi tlamantli fiero catli quichijque. 
\q1 Pampa quema quinhueyichihuayayaj teteyome, 
\q1 Toteco Dios quinitayaya quen elisquía momecatiyayaj ica seyoc catli amo ininnamic. 
\q1  
\v 40 Yeca TOTECO tlahuel cualanqui ica imasehualhua, 
\q1 huan ayacmo quinejqui quinitas. 
\q1  
\v 41 Huan quintemactili ininmaco inincualancaitacahua catli ehuayayaj ipan nopa tlalme catli amo quitlepanitayayaj Toteco, 
\q1 para nopa masehualme ma quinnahuatica. 
\q1  
\v 42 Huan quena, inincualancaitacahua quintlaijiyohuiltijque 
\q1 huan tlahuel quincocojque pampa itztoyaj ininmaco. 
\q1  
\v 43 Miyac huelta Toteco quinmanahui, 
\q1 pero inijuanti quisenhuiquiliyayaj moyoltetilíaj ica ya. 
\q1 Yeca teipa quicahuili ma motzontlamiltica por inintlajtlacolhua. 
\q1  
\v 44 Pero masque ya nopa quichihuayayaj, 
\q1 Toteco quintlacaquiliyaya quema quitzajtziliyayaj, 
\q1 huan quinpalehuiyaya quema masehualme quintlaijiyohuiltiyayaj. 
\q1  
\v 45 Quena, quielnamiquiyaya nochi catli quintlajtolcahuilijtoya para quinchihuilis. 
\q1 Yeca quintlasojtlac huan moyolcuepqui pampa tlahuel quinicneliyaya. 
\q1  
\v 46 Huan hasta quichijqui para inincualancaitacahua catli quintlaijiyohuiltiyayaj, 
\q1 ma nojquiya quintlasojtlaca. 
\b  
\q1  
\v 47 ¡TOTECO Dios, techmaquixti tlen tocualancaitacahua! 
\q1 Sempa techsentili tlen campa hueli tlalme para tihuelise timitztlascamatise ta catli titlatzejtzeloltic, 
\q1 huan para huelis tipaquise huan timitzhueyimatise. 
\b  
\q1  
\v 48 Ma tijpaquilismacaca TOTECO Dios para nochipa, 
\q1 yaya catli toTeco tiisraelitame. 
\q1 Nochi imasehualhua ma quiijtoca: 
\q1 “¡Quej nopa ma eli! ¡Paquilistli!” 
\c 107  
\s1 Toteco quinmanahuía masehualme 
\q1  
\v 1 ¡Xijtlascamatica TOTECO pampa yaya nelía cuali! 
\q1 ¡Itlaicnelilis amo quema tlamis! 
\q1  
\v 2 Nochi amojuanti catli TOTECO anmechmanahuijtoc, xitepohuilica. 
\q1 Quena, xitepohuilica para yaya anmechmaquixtijtoc ininmaco amocualancaitacahua. 
\q1  
\v 3 Yaya ya quinsentilijtoc nochi nopa masehualme catli itztoyaj campa hueli ipan tlaltipactli. 
\q1 Quinsentili catli itztoyaj ica ajco, ica tlani, 
\q1 ica campa hualquisa tonati huan ica campa calaqui. 
\q1  
\v 4 Sequin nentinenque ipan huactoc tlali, 
\q1 niyon amo quipiyayayaj ininchaj, 
\q1 niyon amo quipixque se altepetl para ipan itztose. 
\q1  
\v 5 Amictinemiyayaj huan mayantinemiyayaj, 
\q1 hasta quimachiliyayaj para miquisquíaj pampa ayacmo quipiyayayaj chicahualistli. 
\q1  
\v 6 Huajca quitzajtzilijque TOTECO para ma quinpalehui, 
\q1 huan yaya quinpalehui. 
\q1  
\v 7 Quinyacanqui xitlahuac ipan se ojtli catli temachtli. 
\q1 Huan quinhuicac ipan se altepetl para nopona ma itztotij. 
\q1  
\v 8 Xijhueyimatica TOTECO pampa yaya tlahuel tetlasojtla, 
\q1 huan quichihua huejhueyi tlamantli catli nochi quisentlachilíaj. 
\q1  
\v 9 Pampa Toteco quitlamaca catli teicneltzi huan mayantinemi. 
\q1 Quiaixhuitis catli amictinemi. 
\q1  
\v 10 Sequin inijuanti itztoyaj ipan tzintlayohuilotl ipan tlatzactli huan nechca para miquisquíaj. 
\q1 Itztoyaj ilpitoque ica tepos cadenas. 
\q1  
\v 11 Ya nopa ininpantic pampa inijuanti moyoltetilijque ica catli TOTECO quinnahuatijtoya, 
\q1 huan amo quitlacaquilijque Toteco Catli Más Hueyi. 
\q1  
\v 12 Yeca Toteco quincajqui ma tlaijiyohuica ipan nopa tequitl catli tlahuel teticayo. 
\q1 Quena, huetzque huan amo aqui quinpalehui para sempa motlananase. 
\q1  
\v 13 Huajca quema ayacmo quimatiyayaj tlaque quichihuase ica nopa tlaijiyohuilistli, 
\q1 quitzajtzilijque TOTECO, 
\q1 huan yaya quinmanahui tlen nopa tlaijiyohuilistli 
\q1  
\v 14 Quinquixti ipan nopa tzintlayohuilotl huan quinmanahui para amo miquise. 
\q1 Huan quicotonqui nopa tepos cadena catli ica quinilpijtoyaj. 
\q1  
\v 15 Xijhueyimatica TOTECO pampa yaya tlahuel tetlasojtla huan quichihua huejhueyi tlamantli catli ica masehualme san quisentlachilíaj. 
\q1  
\v 16 Pampa yaya quitlapanqui nopa puertas tlen bronce ipan tlatzacme, 
\q1 huan quihuejhuelo nopa teposme catli ica quitzacuayayaj nopa puertas. 
\q1  
\v 17 Sequin masehualme tlahuel mohualiquilijque tlaohuijcayotl, 
\q1 pampa moyoltetilijque ica Toteco huan quiixpanoque. 
\q1  
\v 18 Huan ipan nopa tlaijiyohuilistli ayacmo mayanayayaj por inincocolis huan pampa itztoyaj nechca para miquise. 
\q1  
\v 19 Pero quema ayacmo quimatiyayaj tlaque quichihuase ica nopa tlaijiyohuilistli, 
\q1 quitzajtzilijque TOTECO huan yaya quinmanahui. 
\q1  
\v 20 Toteco camanaltic huan mochicajque. 
\q1 Huan quej nopa quinmaquixti para amo miquise. 
\q1  
\v 21 Xijhueyimatica TOTECO pampa yaya tlahuel tetlasojtla huan quichihua huejhueyi tlamantli catli nochi quisentlachilíaj. 
\q1  
\v 22 Xijpaquilismacaca Toteco huan yaya quiitas quen elisquía se tlacajcahualistli. 
\q1 Huan xihuicaca huan xitepohuilica nochi catli yaya quichijtoc. 
\q1  
\v 23 Nopa masehualme catli nemij ica ininbarcos ipan hueyi atl, 
\q1 huan yohuij ipan nochi tlaltipactli para tlanemacase huan tlacohuase, 
\q1  
\v 24 nojquiya quiitztoque nopa yejyectzitzi tlamantli catli TOTECO quichijtoc ipan atl. 
\q1  
\v 25 Quiitztoque quema TOTECO camanaltic huan quichijqui ma motlanana se ajacatl catli chicahuac, 
\q1 huan quitlananqui nopa atl. 
\q1  
\v 26 Nopa barcos motlananayayaj huan sempa atzintla huetziyayaj. 
\q1 Huan nopa masehualme catli itztoyaj ipan nopa barcos pejque huihuipicaj huan majmahuij. 
\q1  
\v 27 Inijuanti huihuipicaque huan momimilojque quen ihuintini, 
\q1 huan ayacmo quimatque tlaque quichihuase. 
\q1  
\v 28 Huajca quema itztoyaj ipan tlaohuijcayotl, 
\q1 quitzajtzilijque TOTECO, 
\q1 huan yaya quinmaquixti tlen catli quintequipacholmacayaya. 
\q1  
\v 29 Quema tlaquiyahuiyaya huan tlaajacayaya chicahuac, 
\q1 yaya quitlacahualti nopa hueyi atl para ma ayacmo molini, 
\q1 huan mochijqui icamanal. 
\q1  
\v 30 Huan inijuanti pajque miyac quema quiitaque ya moquetzqui nopa atl. 
\q1 Huan quej nopa Toteco quinyacanqui ica yejyectzi hasta nopa ateno campa monequi ajsise ica ininbarcos. 
\q1  
\v 31 Ma quihueyimatica TOTECO pampa yaya tlahuel tetlasojtla, 
\q1 huan quichihua huejhueyi tlamantli catli nochi quisentlachilíaj. 
\q1  
\v 32 Ma quipaquilismacaca Toteco tlamiyacapa iniixpa nochi masehualme huan iniixpa nopa huehue tlacame catli tlayacanaj ipan nopa tlali. 
\q1  
\v 33 Toteco quinhuatztoc hueyame huan quinchijtoc quen huactoc tlali. 
\q1 Nojquiya hueli quinhuatza campa meya atl. 
\q1  
\v 34 Nopa cuali tlali catli tlahuel tlaeliltía quichijtoc ma ayacmo tlaelilti. 
\q1 Huan ya ni quichijqui por inintlajtlacolhua nopa masehualme catli itztoyaj nopona. 
\q1  
\v 35 Pero nojquiya nopa huactoc tlali campa amo tleno eli quichijqui ma tlaelilti. 
\q1 Nojquiya quichijqui ma quipiya miyac atl catli meya campa hueli. 
\q1  
\v 36 Huan quinhuicac nopa masehualme catli mayantinemiyayaj para ma itztoca nopona, 
\q1 huan ma quichihuaca inialtepe. 
\q1  
\v 37 Nojquiya quichijqui para ma tocaca ipan mila, 
\q1 huan ma quichihuaca xocomeca mili, 
\q1 huan ma quipixcaca tlahuel miyac inintlajca. 
\q1  
\v 38 TOTECO tlahuel quintiochijqui. 
\q1 Nojquiya momiyaquilijque huan quinpixque miyac ininhuacaxhua. 
\q1  
\v 39 Teipa pejqui caxani ininmiyaca nopa masehualme, 
\q1 huan nochi mocajque teicneltzitzi, 
\q1 pampa quinajsic tlaohuijcayotl, 
\q1 tequipacholi huan tlaijiyohuilistli. 
\q1  
\v 40 Huan yaya quinechcapantlali nopa tlayacanani catli mohueyimatiyayaj, 
\q1 huan quinchijqui ma mocuapoloca campa amo oncac ojtli huan amo quimatque campa yohuiyayaj. 
\q1  
\v 41 Pero yaya quinmanahui nopa teicneltzitzi. 
\q1 Quinmiyaquili ininconehua quen elisquíaj pilborregojtzitzi hasta mochijque onpanoc miyac. 
\q1  
\v 42 Ma quiitaca nochi catli quichijtoc TOTECO nochi catli nemij xitlahuac iixpa, 
\q1 huan ma paquica. 
\q1 Pero nochi nopa fiero masehualme ma mocamatzacuaca. 
\q1  
\v 43 Masehualme catli tlalnamiquini quimachilise nochi ni tlamantli catli Toteco quichijtoc, 
\q1 huan quiajocuise ipan ininyolo. 
\q1 Inijuanti monejnehuilise quenicatza TOTECO quintlasojtlatihualajtoc imasehualhua. 
\c 108  
\s1 David quitlajtlani Toteco para itlapalehuil 
\q1  
\v 1 ¡NoTeco Dios, noyolo mocualtlalijtoc para nimitzhueyimatis! 
\q1 Nipaquis huan nihuicas tiohuicatl moixpa ica nochi noyolo. 
\q1  
\v 2 ¡Quena, na nihuicas huan nitlatzotzonas ipan noguitarra huan noarpa! 
\q1 Ica paquilistli na nihuicas ijnaltzi quema ayamo tlanesi. 
\q1  
\v 3 Nimitzpaquilismacas, TOTECO, 
\q1 campa hueli iniixpa masehualme tlen nochi altepeme, 
\q1 huan nimitzhueyimatis iniixpa masehualme tlen nochi tlalme. 
\q1  
\v 4 Pampa ta tlahuel titemachtli huan onpano miyac motlaicnelijcayo, 
\q1 hasta quionajsi ihuejcapanca ilhuicactli. 
\q1  
\v 5 Ma nochi mitzhueyimatica nepa ilhuicac, Toteco Dios. 
\q1 Huan ipan nochi tlaltipactli ma quisentlachilica masehualme mohueyitilis. 
\q1  
\v 6 Xijtlacaquili quenicatza mitztzajtzilíaj moconehua catli tiquinicnelía. 
\q1 Xihuala ica miyac chicahualistli huan techmanahuiqui. 
\b  
\q1  
\v 7 Toteco Dios camanaltic ipan itiopa huan quiijto: 
\q1 “Ica paquilistli nijxelos tlali Siquem huan nopa tlamayamitl catli itoca Sucot. 
\q1  
\v 8 Pampa na noaxca tlali Galaad huan Manasés. 
\q1 Nosoldados hualase ipan tlali Efraín. 
\q1 Huan notlanahuatijcahua hualase ipan tlali Judá. 
\q1  
\v 9 Pero catli itztoque ipan tlali Moab huan Edom nechtequipanose, 
\q1 huan nitzajtzis ica paquilistli quema niquintlantos nopa filisteos.” 
\q1  
\v 10 ¿Ajqueya nechmacas chicahualistli para niquintlanis nopa altepeme catli moyahualtzactoque ica tepamitl? 
\q1 ¿Ajqueya nechyacanas para nicalaquis ipan tlali Edom? 
\b  
\q1  
\v 11 ¿Amo elis ta, tiToteco Dios, catli techyacanas? 
\q1 Techyacana huan xiya ica nosoldados para titlahuilanatij pampa amo aqui seyoc para techpalehuis, Toteco. 
\q1  
\v 12 Techpalehui para tiquintlanise tocualancaitacahua pampa san motlapalehuil ipati. 
\q1 Amo ipati masque miyac masehualme techpalehuisquíaj sintla ta, amo. 
\q1  
\v 13 Pero ica ta motlapalehuil tijchihuase huejhueyi tlamantli. 
\q1 Pampa san por ta ipan hueli timoquejquetzase tocualancaitacahua. 
\c 109  
\s1 David motlatlajti para Toteco ma quintlatzacuilti icualancaitacahua 
\q1  
\v 1 NoTeco Dios catli nimitzhueyitlalía, 
\q1 technanquili quema nimotlatlajtía ica ta, 
\q1 amo san xitlacacto. 
\q1  
\v 2 Pampa nopa tlajtlacolchijca masehualme nechejelnamiquij huan nechistlacahuíaj. 
\q1  
\v 3 Inijuanti nechcualancaitaj huan nechyahualohuaj para nechilhuise camanali catli amo monequi. 
\q1 Nechhuilanaj masque amo tleno niquinchihuilijtoc. 
\q1  
\v 4 Na niquinicnelía huan nimotlatlajtía para tiquintiochihuas. 
\q1 Pero masque ya nopa nijchihua, 
\q1 noja más quichihuaj campica para nechtzontlamiltise. 
\q1  
\v 5 Na niquinchihuilía catli cuali, 
\q1 pero inijuanti nechtlaxtlahuíaj ica catli amo cuali. 
\q1 Masque niquinicnelía, inijuanti nechcualancaitaj. 
\b  
\q1  
\v 6 NoTeco, xiquintlali imaco se catli fiero. 
\q1 Se catli quimati tetlatelhuía ma quinhuica iixpa se juez catli fiero para ma quintlajtolsencahua. 
\q1  
\v 7 Huan quema ya quintlajtolsencajtose, xijchihua para nochi quimatise para quihuicaj tlajtlacoli. 
\q1 Huan quema motlatlajtíaj, xiquita quen elisquía tlajtlacolchihuaj. 
\q1  
\v 8 Nimitztlajtlanía para inemilis nocualancaitaca ma amo huejcahua ipan ni tlaltipactli. 
\q1 Huan seyoc tlacatl ma quichihua nopa tequitl catli yaya quichihuayaya. 
\q1  
\v 9 Iconehua ma mocahuaca icnotzitzi huan isihua ma mocahua cahuali. 
\q1  
\v 10 Iconehua ma monejnencaquixtica huan ma motlaejehuijtinemica. 
\q1 Ma quitemoca tlacualistli huejca tlen ininchaj catli ya tlamisosolijtoc. 
\q1  
\v 11 Ma quitlamitlacuijcuilica catli quitlatlanejtiyayaj, 
\q1 huan catli seyoc tlali ehuani ma quiquixtilica nochi catli quitlantoc ica itequi. 
\q1  
\v 12 Amo aqui ma quipalehui ica niyon se tlamantli huan amo aqui ma quintlasojtla iconehua catli icnotzitzi. 
\q1  
\v 13 Ma miquica nochi iconehua. 
\q1 Ma tlamiixpolihuica huan ayacmo aqui ma quinelnamiqui inintoca. 
\q1  
\v 14 TOTECO, amo xiquelcahua nochi inintlajtlacolhua itatahua huan inanahua. 
\q1 Huan amo xiquintlapojpolhui. 
\q1  
\v 15 Ma mocahua inintlajtlacolhua moixpa, TOTECO, 
\q1 pero ayacmo aqui ma quinelnamiqui nopa masehualme ipan ni tlaltipactli. 
\q1  
\v 16 Pampa inijuanti amo quinejque quipalehuise ininhuampox. 
\q1 Nojquiya quintojtocaque catli teicneltzitzi huan quinmictijque catli motequipachohuayayaj. 
\q1  
\v 17 Quinpactiyaya quintelchihuase ininhuampox. 
\q1 Huajca ama ta nojquiya xiquintelchihua. 
\q1 Amo quema quintiochijque sequinoc, 
\q1 huajca ama nojquiya amo xiquintiochihua. 
\q1  
\v 18 Nopa tlatelchihualistli tlahuel quinpactía pampa eltoc ipan nochi catli quichihuaj. 
\q1 Tlatelchihuaj mojmostla quen mojmostla moquentíaj ininyoyo, 
\q1 o quiijij atl o quicuaj se tlacualistli catli ajhuiyac. 
\q1  
\v 19 Huajca ama ipani ma huetzi nopa tlatelchihualistli, 
\q1 quen elisquía se yoyomitl catli quinpantzacuas o quen inintzinquechilpica. 
\b  
\q1  
\v 20 Quej nopa, TOTECO, xiquintlaxtlahui nopa nocualancaitacahua catli nechistlacahuíaj, 
\q1 huan catli quinequij nechmictise. 
\q1  
\v 21 Pero TOTECO, ta catli tinoTeco, 
\q1 techita na quen elisquía nimocone catli nijhuica motzonquisca. 
\q1 Yeca techchololti imaco nocualancaitaca pampa ta titemachtli huan tinelcuali. 
\q1  
\v 22 Na nitlaijiyohuía huan tlahuel monequi motlapalehuil, 
\q1 Tlahuel nechcocohua noyolo. 
\q1  
\v 23 Niyajtinemi para nimiquis huan nitlaijiyohuía quen se chapoli catli quitlahuiso se masehuali. 
\q1  
\v 24 Notlancuaco ayacmo quipiya chicahualistli pampa tlahuel nimosajtoc. 
\q1 Huan notlacayo ayacmo nacayo. 
\q1  
\v 25 Nochi masehualme ipan tlaltipactli nechhuetzquilíaj. 
\q1 Yeca nochi catli nechitaj quiojoliníaj inintzonteco huan nechpinajtíaj. 
\q1  
\v 26 ¡TOTECO Dios, techpalehui! 
\q1 ¡Techmaquixti pampa ta tlahuel titetlasojtla! 
\q1  
\v 27 Techmaquixti tlamiyacapa, 
\q1 para nochi ma quimatica para ta catli tijchijtoc, TOTECO. 
\q1  
\v 28 Huan teipa sintla nechtelchihuaj, amo tleno, 
\q1 pampa ta techtiochihuas. 
\q1 Sintla motlananase ica na, 
\q1 mopinahuase, 
\q1 huan na nijsenhuiquilis nimopaquilismacas, 
\q1 pampa na nimotequipanojca. 
\q1  
\v 29 Ma mopinahualtica tlamiyacapa inijuanti catli nechistlacahuíaj. 
\q1 Quena, xiquinpinahualti. 
\b  
\q1  
\v 30 Pero na tlatoctzitzi nijtlascamatis TOTECO, 
\q1 huan nijpaquilismacas iniixpa nochi masehualme. 
\q1  
\v 31 Pampa yaya itztoc ininhuaya catli teicneltzitzi para quinmanahuis ininmaco inincualancaitacahua. 
\c 110  
\s1 Toteco quimaca tlanahuatili nopa tlanahuatijquetl 
\q1  
\v 1 TOTECO quiilhui nohueyiTeco: 
\q1 “Ximosehui nica ica nonejmac hasta nimitzmactilis mocualancaitacahua para xiquinnahuati.” 
\q1  
\v 2 TOTECO quichihuas para titlanahuatis tlen altepetl Jerusalén, 
\q1 huan tiquinnahuatis mocualancaitacahua catli campa hueli itztoque. 
\q1  
\v 3 Huan ipan nopa tonali quema titlahuilanas huan monextis mochicahualis, 
\q1 momasehualhua hualase campa ta huan mitztlajtlanise caquihuili para tlahuilanase para ta ica miyac paquilistli. 
\q1 Moyoyontijtose ica ininyoyo catli tlatzejtzeloltic para mitztequipanose, 
\q1 huan ta tijpiyas yancuic chicahualistli mojmostla, 
\q1 quen huetzi nopa yancuic ajhuachtli ica ijnaloc. 
\q1  
\v 4 TOTECO tlatestigojquetzqui huan amo moyolpatlas ica catli quiijtojtoc quichihuas. 
\q1 Quena, yaya quiijtojtoc para ta tielis titotajtzi para nochipa quen Melquisedec. 
\q1  
\v 5 Toteco itztoc campa monejmac para mitzmocuitlahuis. 
\q1 Ipan nopa tonali quema yaya tlahuel cualanis, 
\q1 quintzontlamiltis miyac tlanahuatiani. 
\q1  
\v 6 Quintlatzacuiltis miyac masehualme ipan nochi tlalme, 
\q1 huan quintemitis nopa tlalme ica mijcatzitzi. 
\q1 Miyac masehualme quintzonxamanis ipan miyac tlalme. 
\q1  
\v 7 Pero ipan ojtli yaya atlis ipan miyac atlajme, 
\q1 huan nopa atl quifuerzajmacas huan quiseseltis. 
\c 111  
\s1 Toteco quinmocuitlahuía imasehualhua 
\q1  
\v 1 ¡Paquilistli! 
\q1 Ica nochi noyolo nijnequi nijtlascamatis TOTECO, 
\q1 campa mosentilíaj masehualme catli itztoque xitlahuaque. 
\q1  
\v 2 Huejhueyi tlamantli quichijtoc TOTECO. 
\q1 Nochi catli quiicnelíaj ma monejnehuilica tlen nochi ni tlamantli catli quichijtoc. 
\q1  
\v 3 Pampa tlahuel yejyectzi nochi nopa huejhueyi tlatiochicahual nextili catli quichihua. 
\q1 Huan technextilía ihueyitilis huan para yaya nochipa quichihua catli xitlahuac. 
\q1  
\v 4 TOTECO quichijtoc huejhueyi tlamantli catli amo huelis tiquelcahuase. 
\q1 Quichijtoc tlamantli catli technextilía para techicnelía huan para yaya quipiya hueyi iyolo ica tojuanti. 
\q1  
\v 5 Yaya quinmaca tlacualistli nochi catli motemachíaj ipan ya. 
\q1 Huan amo quema quielcahuas catli techtlajtolcahuilijtoc techchihuilis. 
\q1  
\v 6 Toteco quinextijtoc ihueyi chicahualis ica imasehualhua pampa yaya quinmacac nopa tlali Israel, 
\q1 masque achtihuiya eliyaya iniaxca sequinoc tlamantli masehualme. 
\q1  
\v 7 Nochi catli Toteco quichihua eltoc senquistoc xitlahuac huan cuali. 
\q1 Huan nochi itlanahuatilhua nelía temachtli. 
\q1  
\v 8 Para nochipa technextilía catli melahuac huan catli xitlahuac, 
\q1 huan monequi tijchihuase catli melahuac huan tiquinneltocase. 
\q1  
\v 9 TOTECO ya tlaxtlajtoc nochi para quinmanahuis imasehualhua. 
\q1 Huan quinilhuijtoc imasehualhua para quichihuas nochi catli quintencajqui ipan nopa camanal sencahuali. 
\q1 ¡Toteco nelía tlatzejtzeloltic huan temajmati! 
\q1  
\v 10 Para tipehuase tijpiyase tlalnamiquilistli, 
\q1 achtihui monequi tiquimacasise huan tijtlepanitase Toteco Dios. 
\q1 Mochihuaj nelía tlalnamiquini nopa masehualme catli quintlepanitaj itlanahuatilhua. 
\q1 Ma tijpaquilismacaca para nochipa. 
\c 112  
\s1 Toteco quinhueyitlalía catli quihueyitlepanitaj 
\q1  
\v 1 ¡Miyac paquilistli quipiya nopa masehuali catli quiimacasi TOTECO! 
\q1 Quena, nochi catli quinpactía quichijtinemise catli quiijtohuaj itlanahuatilhua Toteco tlahuel paquij. 
\q1  
\v 2 Iniixhuihua ni masehualme quipantise tlatlepanitacayotl campa hueli, 
\q1 Pampa Toteco quintiochihua hasta iixhuihua se catli monejnemiltía xitlahuac iixpa. 
\q1  
\v 3 Ipan ichaj se masehuali catli quintlepanita itlanahuatilhua Toteco, 
\q1 mopantis ica miyac tlamantli catli cuali huan patiyo. 
\q1 pampa yaya quichihua catli xitlahuac huan cuali, 
\q1 amo quema quielcahuase. 
\q1  
\v 4 Ni masehuali itztoc quen se tlahuili catli tlahuía ipan tzintlayohuilotl. 
\q1 Yaya tetlasojtla huan teicnelía huan techihuilía catli xitlahuac. 
\q1  
\v 5 Se tlacatl catli cuali iyolo tetlasojtla huan tetlatlanejtía catli quipiya. 
\q1 Nochi catli quichihua quisa cuali, 
\q1 huan quiyacana xitlahuac nochi tlamantli catli eltoc imaco. 
\q1  
\v 6 Se tlacatl catli quej ni quichihua, 
\q1 amo huetzis quema hualas tlaohuijcayotl. 
\q1 Masehualme catli cuajcualme quielnamiquise para nochipa. 
\q1  
\v 7 Yaya amo majmahui masque quiyolmelahuaj tlen se camanali catli temajmatía, 
\q1 pampa yaya senquistoc motemachijtoc ipan TOTECO para quimocuitlahuis. 
\q1  
\v 8 Yaya quipiya temachili ipan iyolo huan amo majmahui. 
\q1 San motemacas huan mohuilanas chicahuac ica icualancaitacahua. 
\q1  
\v 9 Yaya quinpalehuía miyac catli teicneltzitzi huan amo tleno quipiyaj. 
\q1 Por nochi nopa tlamantli cuali catli quichihua, 
\q1 amo quema quielcahuase masehualme. 
\q1 Nochi quicualitase huan quitlepanitase. 
\q1  
\v 10 Quema nopa fiero masehualme quiitase ni cuali tlacatl huan quenicatza masehualme quitlepanitaj, 
\q1 cualanise chicahuac hasta tlanhuehuechocase pampa quichicoitase. 
\q1 Pero teipa san quisase ipan pinahualistli pampa momacase cuenta para ayacmo tleno hueli quichihuase. 
\c 113  
\s1 Toteco quitlanana se catli teicneltzi 
\q1  
\v 1 ¡Xijpaquilismacaca TOTECO! 
\q1 ¡Quena, nochi amojuanti catli anitequipanojcahua TOTECO, xijhueyimatica! 
\q1  
\v 2 Ma tijhueyimatica TOTECO ama huan para nochipa. 
\q1  
\v 3 Quena, nochi masehualme tlen campa hualquisa tonati hasta campa oncalaqui ma quihueyimatica TOTECO. 
\q1  
\v 4 TOTECO quipiya tlanahuatili ica nochi catli itztoque ipan nochi tlalme. 
\q1 Huan ihueyitilis conpano ilhuicactli. 
\q1  
\v 5 ¿Ajqueya seyoc más hueyi quen TOTECO toDios catli mosehuía nepa huejcapa para tlanahuatis? 
\q1  
\v 6 Tlatzintla tlen ya eltoc ilhuicactli huan tlaltipactli. 
\q1 Huan yaya mohuijtzoma para tlachiyas ipan ni tlaltipactli. 
\q1  
\v 7 Huan quitlanana nopa teicneltzi catli eltoc quen masitoc ipan soquitl catli huejcatla. 
\q1 Huan catli huetztoc campa quitepehuaj tlasoli quitlanana huan quisehuía campa cuali. 
\q1  
\v 8 Quena, quitlanana huan quisehuía ininhuaya huejhueyi tlacame 
\q1 catli quinyacanaj ialtepe ehuani. 
\q1  
\v 9 Yaya quichihua para nopa sihuatl catli amo quema conepixqui 
\q1 ma quinpiya iconehua huan ichaj. 
\q1 Quena, quichihua ma eli se tenantli catli senpactoc. 
\q1 ¡Paquilistli! 
\c 114  
\s1 Catli Toteco quinchihuili nopa israelitame ipan tlali Egipto 
\q1  
\v 1 Huejcajya quema nopa israelitame quisque ipan tlali Egipto, 
\q1 campa nopa masehualme camanaltij seyoc camanali, 
\q1  
\v 2 hualajque huan quichijque itiopa Toteco ipan tlali Judá para nopona ma mocahua ininhuaya, 
\q1 huan nochi tlali Israel eltoya itlal campa nojquiya yaya tlanahuati. 
\q1  
\v 3 Quema nopa Hueyi Atl Chichiltic quinitac hualahuij nopa israelitame, 
\q1 nimantzi moisihuilti huan motlapo para ma panoca campa tlahuactoc. 
\q1 Nojquiya nopa atemitl Jordán motlapo para ma panoca. 
\q1  
\v 4 Nochi paquiyayaj hasta elqui quen nopa tepeme tzicuinque ica paquilistli quen chivojme, 
\q1 huan nopa tlaixtemolis tzicuinque quen pilborregojtzitzi. 
\q1  
\v 5 ¿Tlaque panoc ica nopa Hueyi Atl Chichiltic? 
\q1 ¿Para tlen motlajcoxelo? 
\q1 Huan nopa atemitl Jordán, ¿para tlen moquetzqui? 
\q1  
\v 6 Huan nopa tepeme, ¿para tlen tzicuinque quen chivojme? 
\q1 Huan nochi tlaixtemolistli, 
\q1 ¿para tlen tzicuinque quen pilborregojtzitzi? 
\q1 Elqui pampa nochi tlahuel quitlepanitaj Toteco. 
\q1  
\v 7 Nochi tlaltipactli huihuipica iixpa TOTECO, 
\q1 yaya catli iTeco Jacob, 
\q1  
\v 8 pampa yaya quichijqui para ipan nopa tetl ma meya atl. 
\q1 Quena, yaya quiquixti atl ipan nopa tetl huan mochijqui quen se hueyatl. 
\c 115  
\s1 Toteco huan teteyome 
\q1  
\v 1 ¡TOTECO, amo techhueyitlali tojuanti! 
\q1 ¡Ximohueyitlali ta! 
\q1 Xijchihua para nochi ma mitzpaquilismacaca pampa ta tlahuel titetlasojtla huan tijchihua catli nelía melahuac. 
\q1  
\v 2 Amo xiquincahuili para nopa masehualme ipan sequinoc tlalme ma quiijtoca: 
\q1 “¿Canque itztoc ininDios?” 
\q1  
\v 3 Ta toTeco Dios, tiitztoc nepa ilhuicac, 
\q1 huan nochi catli tijnequi tijchihuas, ta tijchihua. 
\q1  
\v 4 Pero nopa masehualme quinitaj quen inintecohua nopa teteyome catli quinchijchijtoque ica oro huan plata. 
\q1  
\v 5 Quipiyaj inincamac, pero amo camanaltij. 
\q1 Quipiyaj iniixteyolhua, pero amo tlachiyaj. 
\q1  
\v 6 Quipiyaj ininnacas, pero amo tlacaquij. 
\q1 Quipiyaj ininyacatzol, pero amo tlaijiyotilanaj. 
\q1  
\v 7 Quipiyaj ininmax, pero amo hueli quiitzquíaj niyon se tlamantli. 
\q1 Quipiyaj ininmetz, pero amo nejnemij. 
\q1 Amo huelij camanaltij. 
\q1  
\v 8 Huan nochi masehualme catli quinchijchijtoque nopa totiotzitzi nelía huihuitique quen nopa teteyome, 
\q1 huan nojquiya san se huihuitique catli quinhueyichihuaj. 
\b  
\q1  
\v 9 ¡Anisraelitame, ximotemachica ipan TOTECO, 
\q1 pampa san yaya anmechpalehuía huan anmechmanahuía 
\q1 tlen nochi tlamantli catli amo cuali! 
\q1  
\v 10 Antotajtzitzi catli aniixhuihua Aarón huan aniaxcahua TOTECO, 
\q1 ximotemachica ipan ya, 
\q1 pampa san yaya anmechpalehuía huan anmechmanahuía tlen nochi tlamantli catli amo cuali. 
\q1  
\v 11 Nochi amojuanti catli anquiimacasij huan anquitlepanitaj TOTECO ximotemachica ipan ya, 
\q1 pampa san yaya anmechpalehuía huan anmechmanahuía tlen nochi tlamantli catli amo cuali. 
\q1  
\v 12 TOTECO tlatoctzitzi techelnamiqui huan yeca temachtli techtiochihuas. 
\q1 Techtiochihuas tiiisraelita masehualhua. 
\q1 Quintiochihuas nopa totajtzitzi catli iixhuihua Aarón. 
\q1  
\v 13 Quena, Toteco quintiochihuas nochi catli quiimacasij huan quitlepanitaj. 
\q1 Quintiochihuas catli huejhueyi huan catli tziquitetzitzi. 
\q1  
\v 14 Tlahuel miyac TOTECO ma anmechtiochihuas amojuanti huan amoconehua. 
\q1  
\v 15 Quena, TOTECO catli quichijqui ilhuicactli huan tlaltipactli, 
\q1 yaya catli anmechtiochihuas. 
\q1  
\v 16 Nochi ilhuicactli iaxca TOTECO, 
\q1 pero ni tlaltipactli quinmacatoc masehualme. 
\q1  
\v 17 Catli mictoque amo huicaj huan quihueyimatij TOTECO. 
\q1 Inijuanti ayacmo hueli moliníaj. 
\q1  
\v 18 Pero tojuanti, quena, tojuanti tijhueyimatise TOTECO ama huan para nochipa. 
\q1 ¡Xijhueyimatica TOTECO! 
\q1 ¡Paquilistli! 
\c 116  
\s1 Tlascamatili pampa Toteco quimanahui tlen miquilistli 
\q1  
\v 1 Nelía niquicnelía TOTECO pampa yaya nechtlacaquilía quema nimotlatlajtía huan nechnanquilía. 
\q1  
\v 2 Huan pampa mohuijtzoma huan nechnanquilía, 
\q1 nimotlatlajtis ica ya nochi tonali quema niyoltos. 
\q1  
\v 3 Nechyahualojtoya miquilistli. 
\q1 Nijmachiliyaya quen niitztosquía ipan ostotl, 
\q1 pampa nechajsic miyac cuesoli huan tequipacholi. 
\q1  
\v 4 Huajca nijtzajtzili TOTECO huan niquilhui: 
\q1 “TOTECO, techmanahui.” 
\q1  
\v 5 ¡TOTECO nelía cuali iyolo! 
\q1 ¡Yaya senquistoc xitlahuac! 
\q1 ¡Toteco tlahuel tetlasojtla! 
\q1  
\v 6 TOTECO quinmocuitlahuía catli moechcapanohuaj huan itztoque quen coneme. 
\q1 Na ya nimictinemiyaya huan yaya nechmanahui. 
\q1  
\v 7 Ama huelis nimosiyajquetzas pampa TOTECO nechchihuilijtoc catli cuali. 
\q1  
\v 8 Nechmanahuijtoc imaco miquilistli, 
\q1 quihuatztoc noixayo huan nechpalehuijtoc para ma amo nihuetzi ipan tlajtlacoli. 
\q1  
\v 9 Ipan ni tlaltipactli campa itztoque masehualme, 
\q1 nimonejnemiltis xitlahuac iixpa TOTECO. 
\q1  
\v 10 Na nijneltocayaya Toteco huajca niquijto: 
\q1 “Nitlaijiyohuía miyac, Toteco.” 
\q1  
\v 11 Huan quema ayacmo nijmatiyaya tlaque nijchihuas, niquijto: 
\q1 “Nochi masehualme san istlacatij.” 
\q1  
\v 12 Huan ama ya niitztoc cuali. 
\q1 ¿Quenicatza huelis nijtlaxtlahuis TOTECO por nochi catli nechchihuilijtoc? 
\q1  
\v 13 Nijhualiquilis xocomecatl iayo quen se tlacajcahualistli, 
\q1 huan nijhueyimatis TOTECO pampa nechmaquixtijtoc. 
\q1  
\v 14 Tlamiyacapa nijhualiquilis TOTECO nopa tlacajcahualistli catli nijtlajtolcahuili nijmacas. 
\q1  
\v 15 TOTECO quiita para tlahuel ipati ininnemilis imasehualhua catli quinicnelía, 
\q1 huan amo quincahuilía miquise san quej hueli. 
\b  
\q1  
\v 16 TOTECO, na nimotequipanojca, 
\q1 quena, niicone se nonana catli nojquiya mitztequipano. 
\q1 Huan techmanahuijtoc tlen campa niilpitoya. 
\q1  
\v 17 Nimitzpaquilismacas huan nimitztlascamatis huan ta tiquitas quen elisquía se tlacajcahualistli. 
\b  
\q1  
\v 18 Tlamiyacapa nijhualiquilis TOTECO nopa tlacajcahualistli catli nijtlajtolcahuili nijmacas. 
\q1  
\v 19 Quena, nijmacas TOTECO nopona ipan icalixpa ichaj catli eltoc ipan altepetl Jerusalén. 
\q1 ¡Paquilistli! 
\c 117  
\s1 Ma tijhueyichihuaca Toteco 
\q1  
\v 1 Xijpaquilismacaca TOTECO nochi anmasehualme ipan nochi tlalme, 
\q1 xijhueyimatica nochi amojuanti ipan nochi altepeme. 
\q1  
\v 2 Pampa yaya techicnelía ica se hueyi tlaicnelijcayotl catli amo quema tlamis. 
\q1 Yaya temachtli huan elis temachtli para nochipa. 
\q1 ¡Paquilistli! 
\c 118  
\s1 Ma tijtlascamatica Toteco 
\q1  
\v 1 ¡Xijpaquilismacaca TOTECO pampa yaya nelía cuali! 
\q1 Itlaicnelijcayo amo quema tlamis. 
\q1  
\v 2 Nochi anisraelitame xijhueyimatica Toteco huan xiquijtoca: 
\q1 “Itlaicnelijcayo Toteco amo quema tlamis.” 
\q1  
\v 3 Nochi antotajtzitzi catli aniixhuihua Aarón nojquiya xiquijtoca: 
\q1 “TOTECO itlaicnelijcayo amo quema tlamis.” 
\q1  
\v 4 Nochi amojuanti catli anquitlepanitaj TOTECO xiquijtoca: 
\q1 “TOTECO itlaicnelijcayo amo quema tlamis.” 
\q1  
\v 5 Quema nimotequipachohuayaya, 
\q1 nijtzajtzili TOTECO, 
\q1 huan yaya nechnanquili huan nechmanahui. 
\q1  
\v 6 TOTECO itztoc nohuaya para nechpalehuis, 
\q1 yeca ayacmo nimajmahui, 
\q1 niyon amo niquimacasi catli huelis nechchihuilise masehualme. 
\q1  
\v 7 TOTECO itztoc nonechca. 
\q1 Yaya nechpalehuis. 
\q1 ¡Huan temachtli niquitas catli nijnequi ma ininpanti nocualancaitacahua! 
\q1  
\v 8 Más cuali nimotemachis ipan TOTECO huan amo ipan se tlacatl. 
\q1  
\v 9 Más cuali nimomanahuis ipan TOTECO huan amo ipan se hueyi tlanahuatijquetl. 
\q1  
\v 10 Masque nochi masehualme tlen nochi tlalme ma nechyahualoca para nechhuilanase, 
\q1 na niquintzontlamiltis ica ichicahualis TOTECO. 
\q1  
\v 11 Quena, masque nechyahualose huan nechhuilanase, 
\q1 pero na niquintlanis pampa nijhuica itequiticayo TOTECO. 
\q1  
\v 12 Nocualancaitacahua hualajque nopani quen sayolime, 
\q1 huan cualanque chicahuac quen tlitl catli quitlatía nochi huitztli. 
\q1 Pero na niquintzontlamilti ica itequiticayo TOTECO. 
\q1  
\v 13 Nocualancaitacahua quichijque campica para nechmictise, 
\q1 pero TOTECO yaya nechpalehui. 
\q1  
\v 14 TOTECO nechpixtoc imaco, 
\q1 huan yeca nihuica para ya pampa nechchijtoc ma nitlatlani. 
\q1  
\v 15 Ipan ininchajchaj catli monejnemiltíaj xitlahuac iixpa TOTECO tlahuejchihuaj huan huicaj ica paquilistli, 
\q1 pampa TOTECO quinmaquixtía huan quichihua huejhueyi tlamantli. 
\q1  
\v 16 Ichicahualis TOTECO nelía hueyi huan quichihua huejhueyi tlamantli. 
\q1  
\v 17 Amo nimiquis. 
\q1 Pero niitztos para nitepohuilis nochi catli TOTECO quichijtoc. 
\q1  
\v 18 Toteco nechtlatzacuilti chicahuac, 
\q1 pero amo nechtemactili para ma nimiqui. 
\q1  
\v 19 Xijtlapoca ipuertajyo itiopa TOTECO, 
\q1 pampa nijnequi nicalaquis para nijtlascamatis TOTECO. 
\q1  
\v 20 Ipan ni puerta calaquij para yohuij hasta iixpa TOTECO, 
\q1 huan nopona calaquise nochi catli tlatzejtzeloltique iixpa. 
\q1  
\v 21 Nijhueyimatis noTeco Dios, huan nijtlascamatilis miyac, 
\q1 pampa nechtlacaquili huan nechmaquixti tlen nocualancaitacahua. 
\q1  
\v 22 Calchihuani quihuejcamajcajque se hueyi tetl catli amo quinejque quitequihuise, 
\q1 pero ama nopa hueyi tetl eltoc catli más monequi para yas calnacastla huan ipan quiquetzase nopa cali. 
\q1  
\v 23 Nochi ya ni quichijtoc TOTECO huan yejyectzi nesi. 
\q1  
\v 24 Inin nopa tonali catli TOTECO quichijqui. 
\q1 Ma tipactoca ipan ni tonali. 
\q1  
\v 25 Nijtlajtlanía TOTECO ama ma techmaquixti tojuanti tlen tocualancaitacahua. 
\q1 Techpalehui ama para titlatlanise. 
\b  
\q1  
\v 26 ¡Ma TOTECO mitztiochihua ta catli tihuala ica itequiticayo [118:26 O ica itoca.]! 
\q1 Timitztiochihuaj hasta campa ichaj TOTECO. 
\b  
\q1  
\v 27 TOTECO yaya Dios, huan yaya techtlahuilía. 
\q1 Nijhualiquilis notlacajcahualis huan nijtlalis ipan itlaixpa para nijmacas. 
\q1  
\v 28 Pampa yaya noTeco Dios, yeca nijtlascamati huan nijhueyimati. 
\q1  
\v 29 ¡Xijtlascamatica TOTECO pampa yaya nelía cuali! 
\q1 Itlaicnelijcayo amo quema tlamis. 
\c 119  
\s1 Toteco itlanahuatilhua nelía cuali 
\q1  
\v 1 Nelía paquij nochi catli monejnemiltíaj xitlahuac, 
\q1 huan catli senquistoc quichijtinemij catli quiijtohua iley TOTECO. 
\q1  
\v 2 Paquij nopa masehualme catli quitemohuaj TOTECO ica nochi ininyolo huan quichijtinemij catli yaya quiijtohua. 
\q1  
\v 3 Pampa inijuanti amo quichihuaj catli amo cuali. 
\q1 Monejnemiltíaj senquistoc ipan iojhui TOTECO. 
\q1  
\v 4 Ta techmacatoc motlanahuatilhua para ma tijchihuaca catli quiijtohuaj. 
\q1  
\v 5 ¡Tlahuel nijnequisquía nijchijtinemis senquistoc catli techyolmelajtoc ma tijchihuaca! 
\q1  
\v 6 Quej nopa amo nimopinahuasquía sintla niquinchijtinemis nochi motlanahuatilhua. 
\q1  
\v 7 Na nimitztlascamatis ica nochi noyolo quema ya nijmachilis nochi motlamachtilhua catli xitlahuac. 
\q1  
\v 8 Na nijchihuas nochi catli techyolmelajtoc ma tijchihuaca ipan tonemilis. 
\q1 Yeca amo techtlahuelcahua. 
\b  
\q1  
\v 9 ¿Tlaque monequi quichihuas se telpocatl para itztos tlapajpactic moixpa, TOTECO? 
\q1 Monequi quipohuas mocamanal huan quichihuas catli quiijtohua. 
\q1  
\v 10 Na ica nochi noyolo nimitztemojtoc, Toteco. 
\q1 Amo techcahuili nimoiyocacahuas tlen motlanahuatilhua. 
\q1  
\v 11 Ipan noyolo nicajoctoc nochi catli tiquijtojtoc, 
\q1 para amo nitlajtlacolchihuas ica ta. 
\q1  
\v 12 TOTECO, ta catli nochi mitzhueyimatij, 
\q1 technextili quenicatza nijchihuas nochi catli techyolmelajtoc. 
\q1  
\v 13 Na nitepohuilijtoc nochi motlamachtilhua catli ta techmacatoc. 
\q1  
\v 14 Más nimopaquilismacatoc pampa ninemi ipan moojhui huan nijchihua catli ta tiquijtojtoc, 
\q1 huan amo ipan ricojyotl. 
\q1  
\v 15 Nimonejnehuilis tlen motlanahuatilhua huan ninemis ipan nopa ojtli campa quiijtohuaj ma ninejnemi. 
\q1  
\v 16 Nimopaquilismacas ica catli techyolmelajtoc, 
\q1 huan amo quema niquelcahuas mocamanal. 
\q1  
\v 17 Na nimotequipanojca, techchihuili catli cuali. 
\q1 Techcahuili ma niitzto miyac tonali para nijsenhuiquilis nijtlepanitas mocamanal. 
\q1  
\v 18 Techixtlapo para niquitas nopa huejhueyi tlamachtilistli catli quipiya moley. 
\q1  
\v 19 Na san nipaxalohua ipan ni tlaltipactli. 
\q1 Amo xijtlati motlanahuatilhua tlen na pampa monequi ma nechyacana. 
\q1  
\v 20 Ipan noyolo tlahuel nijnequi nijchihuas nochi catli xitlahuac quen quiijtohua motlamachtil. 
\q1  
\v 21 Ta tiquinajhua nopa tlaixpanoca masehualme catli mohueyimatij. 
\q1 Inijuanti itztoque quen tlatelchihualme pampa quinhuejcamajcahuaj motlanahuatilhua. 
\q1  
\v 22 Amo xiquincahuili ma nechpinahualtica pampa na nijtlepanita nochi catli ta tiquijtohua. 
\q1  
\v 23 Hasta nopa huejhueyi tlacame catli quipiyaj tequiticayotl mosehuijque para nechejelnamiquise, 
\q1 pero na nimotequipanojca, 
\q1 senquistoc nimonejnehuilía tlen nochi catli ta techyolmelajtoc. 
\q1  
\v 24 Pampa motlajtol nechtlahuilía huan nechconsejomaca. 
\q1  
\v 25 Nelía nimotequipachohua hasta nihuetztoc ipan tlaltejpoctli. 
\q1 Xijyancuili nonemilis ica mocamanal. 
\q1  
\v 26 Na nimitzpohuili nochi catli nijsencajtoc nijchihuas huan ta techtlacaquili. 
\q1 Ama technextili quenicatza nijchihuas nochi catli techyolmelajtoc. 
\q1  
\v 27 Techchihua ma nijmachili nopa ojtli catli ipan ninemis para niquintoquilis nochi motlanahuatilhua. 
\q1 Huan na nimonejnehuilis ipan nochi nopa huejhueyi tlamantli catli tijchihua. 
\q1  
\v 28 Nichoca pampa tlahuel nitlaijiyohuía. 
\q1 Techyolchicahua ica mocamanal. 
\q1  
\v 29 Techpalehui mojmostla para amo niistlacatis. 
\q1 Huan pampa techicnelía, techpalehui ma nijmati nochi moley. 
\q1  
\v 30 Na nijtlapejpenijtoc nopa ojtli catli melahuac, 
\q1 huan san nimoilhuía tlen motlamachtil. 
\q1  
\v 31 Na nimotlatzquilijtoc ipan motlajtol huan nijchihuas catli quiijtohua. 
\q1 ¡TOTECO, amo techcahuili nihuetzis ipan pinahualistli! 
\q1  
\v 32 Sintla techmacas noyolo catli cuali moixpa, 
\q1 huajca na achi más nijchijtinemis catli quiijtohuaj motlanahuatilhua. 
\q1  
\v 33 TOTECO, technextili quenicatza nijchihuas nochi catli techyolmelajtoc. 
\q1 Huan nijchijtinemis nochi tonali hasta nimiquis. 
\q1  
\v 34 Techmaca tlalnamiquilistli huan nijchijtinemis nochi catli quiijtohua moley. 
\q1 Quena, nijchijtinemis ica nochi noyolo. 
\q1  
\v 35 Techyacana ipan nopa ojtli catli technextilíaj motlanahuatilhua, 
\q1 pampa san ya nopa nijnequi nijchihuas. 
\q1  
\v 36 Xijchihua para más ma nijnequi motlajtol huan amo tomi. 
\q1  
\v 37 Techhuejcatlali tlen nochi tlamantli catli amo cuali para amo niquixtocas. 
\q1 Más cuali tlatoctzitzi techyolchicahuas para senquistoc ninemis ipan moojhui. 
\q1  
\v 38 Techmatilti na, nimotequipanojca, para temachtli techmacas catli techtlajtolcahuilijtoc, 
\q1 pampa san ta nimitzimacasi huan nimitztlepanita. 
\q1  
\v 39 Amo techcahuili ma niquinimacasi catli nechpinahualtíaj pampa nimitztlepanita, 
\q1 pampa motlamachtil senquistoc cuali huan xitlahuac. 
\q1  
\v 40 TOTECO, na tlahuel nijnequi nijchihuas catli quiijtohuaj motlanahuatilhua. 
\q1 Xijyancuili nonemilis pampa ta senquistoc tixitlahuac. 
\q1  
\v 41 TOTECO, techtlasojtla huan techmaquixti tlen nocualancaitacahua, 
\q1 san quen tiquijtojtoc tijchihuas. 
\q1  
\v 42 Quej nopa huelis niquinnanquilis inijuanti catli nechpinahualtíaj, 
\q1 huan niquinmatiltis para san nimotemachía ipan mocamanal. 
\q1  
\v 43 Amo techquixtili mocamanal catli melahuac huan amo techcahuili ma niquelcahua, 
\q1 pampa san ipan motlamachtil na nimotemachía. 
\q1  
\v 44 Na nijtlepanitas moley mojmostla. 
\q1 Quena, para nochipa nijtlepanitas moley huan amo quema tlamis. 
\q1  
\v 45 Ninemis nimajcajtoc pampa niquintemohua motlanahuatilhua para nijchihuas catli quiijtohuaj. 
\q1  
\v 46 Na niquinpohuilis motlajtol tlanahuatiani, 
\q1 huan amo nimopinahuas. 
\q1  
\v 47 Na nimopaquilismacas ipan motlanahuatilhua pampa tlahuel niquinicnelía. 
\q1  
\v 48 Nimomatlananas para nijnextis notlatlepanitacayo por motlanahuatilhua, 
\q1 huan san nimonejnehuilijtinemis tlen nochi catli techyolmelajtoc ma tijchihuaca ipan tonemilis. 
\q1  
\v 49 Amo quema xiquelcahua catli techtlajtolcahuilijtoc techchihuilis na, nimotequipanojca, 
\q1 pampa san ya nopa nijchixtoc. 
\q1  
\v 50 Catli techtencahuilijtoc techchihuilis nechyoltlalía quema nimopantía ipan tlaijiyohuilistli. 
\q1 Quena, nochi catli tiquijtojtoc nechmaca yancuic chicahualistli ipan nonemilis. 
\q1  
\v 51 Nopa masehualme catli mohueyimatij nechpinajtíaj pampa nimitztlepanita, Toteco, 
\q1 pero masque ya nopa, na amo nimohuejcatlalis tlen moley. 
\q1  
\v 52 TOTECO, na niquelnamiqui motlamachtil catli huejcajya techmacac. 
\q1 Huan motlamachtil nochipa nechyoltlalía. 
\q1  
\v 53 Nelía tlahuel nicualani ica nopa tlaixpanoca masehualme catli quitlahuelcahuaj moley. 
\q1  
\v 54 Nochi catli techyolmelajtoc nechhualiquilijtoc paquilistli, 
\q1 huan nechchijtoc ma nihuica campa hueli campa niitztinentoc quen niseyoc tlali ejquetl. 
\q1  
\v 55 Ica tlayohua nimitzelnamiqui, TOTECO, 
\q1 huan nijnequi nijchihuas catli quiijtohua moley. 
\q1  
\v 56 Nijseli tlahuel miyac tlatiochihualistli pampa nijchijqui catli quiijtohuaj motlanahuatilhua. 
\q1  
\v 57 ¡TOTECO, san ta tinoaxca! 
\q1 Na niquijtojtoc para nijtlepanitas catli quiijtohua mocamanal. 
\q1  
\v 58 Ica nochi noyolo nijnequi motlatiochihualis. 
\q1 Techtlasojtla senquistoc quen techtlajtolcahuilijtoc para tijchihuas. 
\q1  
\v 59 Nimotlachili quenicatza nimonejnemilti 
\q1 huan nimantzi nimocuepqui para nijchihuas catli quiijtohua motlajtol. 
\q1  
\v 60 Quena, nimoisihuiltía para nijchihuas catli quiijtohuaj motlanahuatilhua. 
\q1  
\v 61 Miyac tlaixpanoca masehualme nechyahualojtoque para nojquiya ma nitlajtlacolchihua ininhuaya, 
\q1 pero na amo niquelcajtoc moley. 
\q1  
\v 62 Tlajco yohual nimehua para nimitztlascamatis por motlamachtil catli senquistoc xitlahuac. 
\q1  
\v 63 Na niquinita quen nohuampoyohua nochi catli mitzimacasij huan mitztlepanitaj, 
\q1 huan nochi catli quichihuaj catli quiijtohuaj motlanahuatilhua. 
\q1  
\v 64 ¡TOTECO, nochi tlaltipactli temitoc ica motlaicnelijcayo! 
\q1 Technextili nochi catli techyolmelajtoc ma nijchihua ipan nonemilis. 
\q1  
\v 65 ¡TOTECO, tlahuel techchihuilijtoc catli cuali na, nimotequipanojca! 
\q1 Techtiochijtoc senquistoc quen tiquijtojtoc para tijchihuas. 
\q1  
\v 66 NoTeco, techchihua ma nijmachili catli cuali huan techmaca tlalnamiquilistli, 
\q1 pampa na niquinneltocatoc motlanahuatilhua. 
\q1  
\v 67 Achtihuiya quema ayamo techechcapantlalijtoya para techtlatzacuiltis, 
\q1 san nimocuapolojtinenqui. 
\q1 Pero ama senquistoc nijchihua catli quiijtohua mocamanal. 
\q1  
\v 68 Ta nelía ticuali huan tijchihua san catli cuali. 
\q1 Huajca techmachti quenicatza ma nijchihua catli techyolmelajtoc para nijchihuas. 
\q1  
\v 69 Nopa masehualme catli mohueyimatij nechistlacahuijtoque, 
\q1 pero na ica nochi noyolo nijchijtinemis catli quiijtohuaj motlanahuatilhua. 
\q1  
\v 70 Inijuanti huihuitique huan tzactoc inintlalnamiquilis, 
\q1 pero na nochipa nimopaquilismaca ipan moley. 
\q1  
\v 71 Nelía cuali para techechcapantlali, 
\q1 pampa technextili para ma nijchihua nochi catli techyolmelajtoc ma tijchihuaca ipan tonemilis. 
\q1  
\v 72 Para na más ipati moleyes huan amo millones tlen oro huan plata. 
\q1  
\v 73 TOTECO, ta ica momax tijsencajqui notlacayo. 
\q1 Huajca ama techpalehui ma niquinmachili motlanahuatilhua huan niquintzontecomatis. 
\q1  
\v 74 Nochi catli mitztlepanitaj huan motemachíaj ipan ta, 
\q1 paquise quema nechitase, 
\q1 pampa na nimotemachía ipan mocamanal. 
\q1  
\v 75 TOTECO, na nijmati para motlamachtil senquistoc xitlahuac. 
\q1 Huan nopa tlatzacuiltili catli techmacatoc nojquiya xitlahuac, 
\q1 huan nechhualiquilis tlamantli catli cuali. 
\q1  
\v 76 Huajca ama techyoltlali ica moteicnelijcayo, 
\q1 senquistoc quen techilhuijtoc na, nimotequipanojca, para tijchihuas. 
\q1  
\v 77 Techyahualo ica motlaicnelijcayo para ma niyolto, 
\q1 pampa san ipan moley nijpantía paquilistli. 
\q1  
\v 78 Ma huetzica ipan pinahualistli nopa masehualme catli mohueyimatij, 
\q1 pampa tlahuel nechcocojtoque ica iniistlacaticayo. 
\q1 Pero na san nimonejnehuilijtinemis catli quiijtohuaj motlanahuatilhua. 
\q1  
\v 79 Ma sempa mosentilica nohuaya nopa masehualme catli mitzimacasij huan mitztlepanitaj, 
\q1 huan catli quiiximatij motlajtol. 
\q1  
\v 80 Xijchihua para noyolo ma monejnemilti xitlahuac ipan nochi catli techyolmelajtoc. 
\q1 Huan quej nopa amo quema nimopinahualtis. 
\q1  
\v 81 Na nitlapolosnequi pampa nijchiya para techmaquixtis tlen nocualancaitacahua, 
\q1 pampa nimotemachijtoc ipan catli tiquijtojtoc para techchihuilis. 
\q1  
\v 82 Noixteyolhua siyahuij pampa quinequij quiitase ma pano nochi catli techtlajtolcahuilijtoc para tijchihuas. 
\q1 ¿Hasta quema techyoltlalis ica motlapalehuil? 
\q1  
\v 83 Ya nihuehuentzi huan nitzocoyolijtoc quen se cuetlax bolsa catli quitlalijtoque campa poctli, 
\q1 pero amo niquelcajtoc catli techyolmelajtoc. 
\q1  
\v 84 ¿Quesqui tonali monequi nijchiyas para tiquintlatzacuiltis catli nechtoquilijtinemij? 
\q1  
\v 85 Nopa masehualme catli mohueyimatij huan catli quicualancaitaj moleyes quichijtoque se hueyi ostotl para ma nimasi. 
\q1  
\v 86 Techpalehui, pampa motlanahuatilhua senquistoc xitlahuac, 
\q1 huan nechtepotztocatinemij masque amo tleno nijchijtoc. 
\q1  
\v 87 San quentzi nechixpolihuiltíaj, 
\q1 pero na amo niquinixpanotoc motlanahuatilhua niyon amo niquincajtoc. 
\q1  
\v 88 Pampa hueyi moyolo, techcahuili ma niitzto. 
\q1 Huan quej nopa nijsenhuiquilis nijchihuas catli quiijtohua motlajtol. 
\q1  
\v 89 TOTECO, mocamanal eltos temachtli para nochipa nepa ilhuicac. 
\q1  
\v 90 Mojmostla ta titemachtli huan tiitztos temachtli ica nochi catli tlacajtiyase para nochipa. 
\q1 Cuali ta tijtlatzquilti ni tlali huan quej nopa eltoc. 
\q1  
\v 91 Nochi tlamantli mocahua campa tiquinnahuati ma eltoca hasta ama ni tonal. 
\q1 Quena, nochi tlamantli catli tijchijqui mitzneltocaj huan mitztequipanohuaj. 
\q1  
\v 92 Sintla amo nimopaquilismacatosquía ipan moley, 
\q1 huajca ya nimictosquía ica tequipacholi. 
\q1  
\v 93 Amo quema niquinelcahuas motlanahuatilhua, 
\q1 pampa ica motlanahuatilhua techmacatoc yancuic chicahualistli. 
\q1  
\v 94 Na nimoaxca, techmaquixti pampa nochipa nijchijtinentoc catli quiijtohuaj motlanahuatilhua. 
\q1  
\v 95 Masque nopa tlaixpanoca tlacame motlatise ipan ojtli para nechtzontlamiltise, 
\q1 na san nimonejnehuilijtos tlen motlajtol. 
\q1  
\v 96 Nochi tlamantli catli más cuajcualtzi niquitztoc canque ontlami, 
\q1 pero motlanahuatilhua, amo quipiyaj inintlamiya. 
\q1  
\v 97 ¡Tlahuel niquicnelía moley! 
\q1 San tlen ya nimonejnehuilijtinemi semilhuitl. 
\q1  
\v 98 Motlanahuatilhua nechchijtoque más nitlalnamiqui que nocualancaitacahua. 
\q1 Pampa motlanahuatilhua nechyacantiyohuij mojmostla. 
\q1  
\v 99 Quena, achi más nitlalnamiqui hasta niquintlani inijuanti catli notlamachtijcahua, 
\q1 pampa na nimonejnehuilijtinemi tlen motlajtol. 
\q1  
\v 100 Na más nijmachilía que nopa huehue tlacame, 
\q1 pampa nijchihua catli quiijtohuaj motlanahuatilhua. 
\q1  
\v 101 Amo quema nijnectoc nijtoquilis se ojtli catli amo cuali, 
\q1 pampa senquistoc nijnequi nijchihuas catli quiijtohua mocamanal. 
\q1  
\v 102 Amo nimohuejcatlalijtoc tlen motlamachtil, 
\q1 pampa ta technextilía quenicatza ma nimonejnemilti. 
\q1  
\v 103 Nijmati nelía ajhuiyac mocamanal. 
\q1 Achi más tzopelic nijmati que sayolnectli. 
\q1  
\v 104 Motlanahuatilhua nechmacaj tlalnamiquilistli. 
\q1 Yeca amo nijnequi niquitas niyon se tlamantli istlacatili. 
\q1  
\v 105 Mocamanal eltoc quen se tlahuili catli quitlahuilía noojhui campa ninejnemi para amo nimotepotlamis. 
\q1  
\v 106 Se huelta nitlatestigojquetzqui, 
\q1 huan ama sempa nitlatestigojquetzas para nijchihuas catli quiijtohuaj motlamachtilhua pampa nelía xitlahuac. 
\q1  
\v 107 TOTECO, nechcatitoc para nimiquis ininmaco nocualancaitacahua. 
\q1 Techmaca yancuic chicahualistli quen tiquijtojtoc para tijchihuas. 
\q1  
\v 108 TOTECO, nimitztlajtlanía xijseli nopa tlascamatili catli nimitzmaca quen se tlacajcahualistli. 
\q1 Huan technextili motlamachtil. 
\q1  
\v 109 Mojmostla nimopantía campa mahuilili para nonemilis, 
\q1 pero amo niquelcajtoc moley. 
\q1  
\v 110 Nopa tlaixpanoca masehualme quitlalíaj tlaquetztli para ma nimasi huan nihuetzis ipan tlajtlacoli, 
\q1 pero na amo nimoiyocanequis tlen motlanahuatil. 
\q1  
\v 111 Na san nimoaxcatijtoc motlajtol, 
\q1 pampa san ipan motlajtol nijpantía paquilistli. 
\q1  
\v 112 Ica nochi noyolo nijchihuas catli quiijtohuaj motlanahuatilhua nochipa hasta nimiquis. 
\q1  
\v 113 Amo nijnequi niquinitas masehualme catli quichihuaj ome iniixayac. 
\q1 Pero na niquicnelía moley. 
\q1  
\v 114 Ipan ta nimotlatía para amo nechcocose nocualancaitacahua huan ipan ta nimomanahuía. 
\q1 Pampa nimotemachía san ipan mocamanal. 
\q1  
\v 115 Ma nechtlalcahuica nopa masehualme catli fiero inintlalnamiquilis. 
\q1 Ma amo nechcuatotonica pampa na nijnequi nijchihuas catli quiijtohuaj motlanahuatilhua, Toteco Dios. 
\q1  
\v 116 Huajca noTeco, techmaca yancuic fuerza senquistoc quen techtlajtolcahuili. 
\q1 Huan quej nopa sequinoc amo quema huelis quiijtose para san tlapic nijpixqui nechiyalistli ipan ta. 
\q1  
\v 117 Techfuerzajmaca para nimomaquixtis ininmaco nocualancaitacahua, 
\q1 huan nochipa nijpiyas paquilistli para nijchihuas catli techyolmelajtoc. 
\q1  
\v 118 Ta tiquinhuejcamajcajtoc nochi catli quitlahuelcahuaj catli techyolmelajtoc. 
\q1 Inijuanti quiijtohuaj tlalnamiquij, pero amo neli, san mocajcayahuaj. 
\q1  
\v 119 Nochi masehualme catli quinpactía tlajtlacolchihuaj ipan ni tlaltipactli tiquinita quen itetejtzo tepostli catli mocahua quema tijmolonía para tijtlapajpacchihuas. 
\q1 Pero na niquicnelía huan nijtlepanita motlajtol. 
\q1  
\v 120 Nochi notlacayo huihuipica pampa mitzimacasi huan mitztlepanita, Toteco. 
\q1 Huan nojquiya niquimacasi motlatzacuiltil, 
\q1 huan yeca amo nijnequi nimitzixpanos. 
\q1  
\v 121 Na nijchijtoc catli xitlahuac huan catli melahuac moixpa. 
\q1 Amo techtlahuelcahua ininmaco nocualancaitacahua, 
\q1  
\v 122 Xitlatestigojquetza para techtiochihuas na, nimotequipanojca. 
\q1 Amo xiquincahuili ma nechtlaijiyohuiltica nopa masehualme catli mohueyimatij. 
\q1  
\v 123 Campa hueli nitlachixtoc pampa nijchixtoc techmaquixtiqui tlen nocualancaitacahua, 
\q1 hasta siyajtoque noixteyolhua. 
\q1 Nijchixtoc techmanahui senquistoc quen tiquijtojtoc para tijchihuas. 
\q1  
\v 124 TOTECO, ipan motlaicnelijcayo techchihuili catli cuali na, nimotequipanojca. 
\q1 Technextili quenicatza nijchihuas catli techyolmelajtoc ma tijchihuaca. 
\q1  
\v 125 Na nimotequipanojca, techmaca tlalnamiquilistli, 
\q1 para niquiximatis motlajtol. 
\q1  
\v 126 TOTECO, ya ajsic hora para timonextis huan tijchihuas catli tiquita para cuali. 
\q1 Pampa ni tlaixpanoca masehualme ayacmo quitlepanitaj moley. 
\q1  
\v 127 Pero na más niquinicnelía motlanahuatilhua huan amo quen oro catli senquistoc cuali. 
\q1  
\v 128 Pampa nochi motlanahuatilhua nelía xitlahuac. 
\q1 Yeca amo nijnequi niquitas niyon se tlamantli istlacatili. 
\q1  
\v 129 Motlajtol nelía yejyectzi, TOTECO, 
\q1 yeca nijtoquilijtinemi ica nochi noalma. 
\q1  
\v 130 Quema quiixtomaj mocamanal, 
\q1 techtlahuilía huan techtlalnamictía nochi timasehualme, 
\q1 hasta nojquiya masehualme catli san quentzi quimachilíaj. 
\q1  
\v 131 Yeca tlahuel nijnequi niquiximatis más catli quiijtohuaj motlanahuatilhua, 
\q1 huan ya nopa nijtemohua. 
\q1  
\v 132 Techtlachili huan techtlasojtla, 
\q1 quen timomajtoc tiquinchihuilía catli mitzicnelíaj. 
\q1  
\v 133 Techyacana ipan se cuali ojtli ica mocamanal para amo nechtlanis niyon se tlaixpanoli. 
\q1  
\v 134 Techmanahui tlen nopa tlacame catli mosisiníaj huan quinequij nechtlaijiyohuiltise. 
\q1 Huan quej nopa nijchihuas catli quiijtohuaj motlanahuatilhua. 
\q1  
\v 135 Ma monexti moteicnelijcayo ipan moixayac quema techtlachilía na, nimotequipanojca, 
\q1 huan techmachti nochi catli techyolmelajtoc para ma tijchihuaca. 
\q1  
\v 136 Tlahuel nichoca pampa miyac masehualme amo quitlepanitaj moley. 
\q1  
\v 137 TOTECO, ta nelía tixitlahuac huan nochi tlatzacuiltili catli titemaca nojquiya xitlahuac. 
\q1  
\v 138 Nochi motlajtol xitlahuac huan temachtli para ipan ma timotemachica. 
\q1  
\v 139 Nelía nimotequipachohua huan nicualani, 
\q1 pampa nocualancaitacahua amo quitlepanitztoque catli ta tiquijtojtoc. 
\q1  
\v 140 Nochi moley nijyejyecojtoc huan niquitztoc para nelía tlatzejtzeloltic. 
\q1 Yeca niquicnelía. 
\q1  
\v 141 Nelía niteicneltzi huan miyac amo quinequij nechitase, 
\q1 pero na amo niquinelcajtoc motlanahuatilhua. 
\q1  
\v 142 Ta tijchihua catli xitlahuac para nochipa huan moley senquistoc melahuac. 
\q1  
\v 143 Ipan na huetztoc tequipacholi huan tlaijiyohuilistli, 
\q1 pero motlanahuatilhua san ya nopa nechyolchicahuaj. 
\q1  
\v 144 Motlajtol nochipa xitlahuac. 
\q1 Techmaca tlalnamiquilistli para nijmachilis huan quej nopa huelis niitztos. 
\q1  
\v 145 Ica nochi noyolo nimitztzajtzilía. 
\q1 Technanquili noTeco, huan nijchihuas catli techyolmelajtoc. 
\q1  
\v 146 Na nimitztzajtzilía huan nimitzilhuía: 
\q1 “Techmaquixti tlen nocualancaitacahua”, 
\q1 huan nijchihuas catli quiijtohua motlajtol. 
\q1  
\v 147 Nimehua ica ijnaloc quema ayamo quisa tonati, 
\q1 huan nimitztzajtzilía, TOTECO, pampa san ipan mocamanal nimotemachía. 
\q1  
\v 148 Ica tlayohua amo nicochi pampa san nimonejnehuilía tlen nochi catli tiquijtojtoc techchihuilis. 
\q1  
\v 149 Techtlacaquili pampa titetlasojtla, TOTECO. 
\q1 Techmaca yancuic chicahualistli quen quiijtohua motlamachtil para tijchihuas. 
\q1  
\v 150 Nechca hualahuij nopa tlacame catli mosisiníaj huan nechtepotztocatinemij. 
\q1 Inijuanti mohuejcatlalijtoque tlen moley. 
\q1  
\v 151 Pero ta tinoTeco tiitztoc nonechca. 
\q1 Nochi motlanahuatilhua senquistoc melahuac. 
\q1  
\v 152 Hasta quema niitztoya nitziquitetzi niquiximatqui motlajtol, 
\q1 huan nijmatqui para motlajtol amo quema mopatlas para nochipa. 
\q1  
\v 153 Xijtlachili notlaijiyohuilis huan techmanahui, 
\q1 pampa amo niquelcajtoc moley. 
\q1  
\v 154 Quena, techtenpalehui huan techmanahui quen techtlajtolcahuilijtoc para tijchihuas. 
\q1  
\v 155 Amo tiquinmaquixtis nopa masehualme catli amo mitztlepanitaj. 
\q1 pampa inijuanti amo quichihuilíaj cuenta catli techyolmelajtoc. 
\q1  
\v 156 TOTECO, ta tlahuel techtlasojtla. 
\q1 Techmaca yancuic chicahualistli quen quiijtohua motlamachtil para tijchihuas. 
\q1  
\v 157 Miyac nocualancaitacahua nechtepotztocatinemij huan quichihuaj campica para ma nimitzixpano, 
\q1 pero na amo nijcajtoc motlajtol. 
\q1  
\v 158 Na niquincualancaita nopa tlacajcayahuani, 
\q1 pampa inijuanti amo quichihuaj catli quiijtohua mocamanal. 
\q1  
\v 159 Xiquita TOTECO, na tlahuel niquinicnelía motlanahuatilhua. 
\q1 Techmaca yancuic chicahualistli pampa ta nelía ticuali, 
\q1 huan hueyi moyolo. 
\q1  
\v 160 Nochi mocamanal senquistoc melahuac. 
\q1 Quena, nochi motlamachtil senquistoc xitlahuac huan huejcahuas para nochipa. 
\q1  
\v 161 Tlacame catli quipiyaj tequiticayotl nemij notepotzco para nechcocose masque amo tleno niquinchihuilijtoc, 
\q1 pero ipan noyolo san niquimacasi para niquixpanos mocamanal. 
\q1  
\v 162 Na nimopaquilismaca ipan mocamanal quen se catli paqui miyac quema quipantijtoc catli tlahuel patiyo. 
\q1  
\v 163 Nijcualancaita nochi tlamantli istlacatili, 
\q1 pero niquicnelía miyac moley. 
\q1  
\v 164 Nimitzhueyimati chicome huelta ipan se tonal, 
\q1 huan nimitztlascamati pampa xitlahuac motlamachtil. 
\q1  
\v 165 Nochi catli quiicnelíaj moley quipiyaj miyac tlasehuilistli ipan ininyolo, 
\q1 huan amo huetzise ipan tlajtlacoli. 
\q1  
\v 166 TOTECO, tlahuel nimochixtoc para techmaquixtis 
\q1 huan yeca niquintlepanita motlanahuatilhua. 
\q1  
\v 167 Na nijneltoca motlajtol huan niquicnelía ica nochi noyolo. 
\q1  
\v 168 Na nijchihua catli quiijtohuaj motlanahuatilhua huan motlajtol, 
\q1 pampa ta tiquiximati nochi catli nijchihua. 
\q1  
\v 169 TOTECO, xijtlacaquili catli nimitztlajtlanía, 
\q1 techmaca tlalnamiquilistli senquistoc quen tiquijtojtoc para tijchihuas. 
\q1  
\v 170 Xijtlacaquili catli nimitztlajtlanía quema nimotlatlajtía, 
\q1 huan techmanahui quen tiquijtojtoc techchihuilis. 
\q1  
\v 171 Na nimitzpaquilismacas, 
\q1 pampa ta technextilijtoc quenicatza nijchihuas nochi catli techyolmelajtoc ma tijchihuaca. 
\q1  
\v 172 Nitepohuilis nochi catli tiquijtojtoc, 
\q1 pampa nochi motlanahuatilhua senquistoc xitlahuac. 
\q1  
\v 173 Ximocualtlali para techmanahuis, 
\q1 pampa na nijtlapejpenijtoc nijchihuas catli quiijtohuaj motlanahuatilhua. 
\q1  
\v 174 TOTECO, nijnequi techmaquixtiqui, 
\q1 pampa na san nimopaquilismaca ica moley. 
\q1  
\v 175 Techcahuili ma noja niitztos para nimitzhueyimatis. 
\q1 Xijcahuili para motlamachtil ma nechpalehui. 
\q1  
\v 176 Na nimocuapolojtoc quen se pilborregojtzi, 
\q1 yeca xihuala para techtemoqui, 
\q1 pampa na amo niquelcajtoc para niquintlepanitas motlanahuatilhua. 
\c 120  
\s1 Netlatlajtili para Toteco ma quimanahui tlen nopa istlacatini 
\q1  
\v 1 Quema niitztoya ipan tlaijiyohuilistli, 
\q1 nijtzajtzili TOTECO huan yaya nechnanquili. 
\q1 Niquilhui: 
\q1  
\v 2 “TOTECO, techmanahui ininmaco nopa masehualme, 
\q1 catli nechistlacahuíaj huan nechejelnamiquij.” 
\q1  
\v 3 Ma moilhuica nopa istlacatini tlaque elis catli ininpantis por iniistlacaticayo. 
\q1  
\v 4 Quintlamicocoyotzase ica cuatlamintli huan quintlatise ipan tlicoli. 
\q1  
\v 5 Nelía niteicneltzi na catli niitztoc ininhuaya ni masehualme tlen tlali Mesec huan Cedar. 
\q1 Nelía nitlaijiyohuía tlatlajco inijuanti, 
\q1 pampa niyon se inijuanti amo mitztlepanita, Toteco. 
\q1  
\v 6 Ya nisiyajqui para niitztoc ininhuaya ni masehualme catli amo quinequij ma onca tlasehuilistli. 
\q1  
\v 7 Quema niquincamanalhuía quenicatza hueli tiitztose ica tlasehuilistli, 
\q1 inijuanti quisencahuaj quenicatza tlahuilanase. 
\c 121  
\s1 Toteco yaya mitzmocuitlahuis 
\q1  
\v 1 Quema nijtlanana noixayac, 
\q1 huan nitlachiyas ipan nopa tepeme, nimoilhuía: 
\q1 ¿Canque huala notlapalehuil? 
\q1  
\v 2 Notlapalehuil huala tlen TOTECO, 
\q1 yaya catli quichijchijqui ilhuicactli huan tlaltipactli. 
\q1  
\v 3 Yaya amo quema mitzcahuilis para timotepotlamis o tihuetzis. 
\q1 Yaya mitzmocuitlahuis huan amo monequi cochis. 
\q1  
\v 4 Quena, TOTECO catli quinmocuitlahuía israelitame amo ixijcopi, 
\q1 niyon amo cochi. 
\q1  
\v 5 TOTECO yaya mitzmocuitlahuía. 
\q1 Yaya itztoc monechca para mitzmanahuis. 
\q1  
\v 6 Yaya mitzmocuitlahuía tonaya huan tlayohua. 
\q1  
\v 7 TOTECO mitzmocuitlahuis para amo mitzajsis niyon se tlamantli catli amo cuali. 
\q1 Quena, yaya quimocuitlahuis monemilis. 
\q1  
\v 8 TOTECO yaya mitzmocuitlahuis campa hueli tiyas o tihualas, 
\q1 ama huan para nochipa. 
\c 122  
\s1 Netlatlajtili para ma onca tlasehuilistli ipan altepetl Jerusalén 
\q1  
\v 1 Na nipajqui quema nechilhuijque: 
\q1 “Ma tiyacajya ichaj TOTECO.” 
\q1  
\v 2 Pero ama ya tiitztoque nica ipan altepetl Jerusalén. 
\q1 Quena, ya ticalactoque campa ipuertas ipan itepa. 
\q1  
\v 3 Jerusalén quisencajtoque para nopona nochi ma mosentilica. 
\q1  
\v 4 Nochi imasehualhua TOTECO tlen catli hueli hueyi familia tlen israelitame hualahuij nica sesen xihuitl, 
\q1 para quitlascamatise huan quipaquilismacase Toteco senquistoc quen quiijtohua itlajtol. 
\q1  
\v 5 Pampa nopona mosehuía para tetlajtolsencahuas nopa tlanahuatijquetl catli iixhui David. 
\q1  
\v 6 Ximotlatlajtica ica TOTECO para ma onca tlasehuilistli ipan altepetl Jerusalén. 
\q1 Xijtiochihua Jerusalén ica ni camanali: 
\q1  
\v 7 “Ma itztoca cuali nochi catli quiicnelíaj ni altepetl Jerusalén. 
\q1 Ma onca tlasehuilistli ica calijtic nopa tepamitl catli quiyahualohua. 
\q1 Ma itztoca ica paquilistli ipan nochi tequicalme.” 
\q1  
\v 8 Pampa niquinicnelía noicnihua huan nohuampoyohua catli itztoque nica, niquijtohua: 
\q1 “Ma quipiya tlasehuilistli ni altepetl. 
\q1  
\v 9 Pampa niquicnelía ichaj TOTECO catli mocahua nica, 
\q1 ma onca tlasehuilistli ipan ni altepetl.” 
\c 123  
\s1 Netlatlajtili para Toteco ma quitlasojtla 
\q1  
\v 1 Na nijtlananas noixayac para nimitztlachilis ta, TOTECO, 
\q1 catli timosehuijtoc ipan ilhuicac. 
\q1  
\v 2 Tojuanti timitztlachilíaj ta, 
\q1 TOTECO toDios, para ma techtlasojtla san se quen se tequipanojquetl quitlachilía iteco, 
\q1 o quen se sihua tequipanojquetl quitlachilía iteco isihua para ma quichihuili catli cuali. 
\q1  
\v 3 TOTECO, techtlasojtla. 
\q1 Quena, xijpiya hueyi moyolo tohuaya. 
\q1  
\v 4 Ya tisiyajtoque ica nopa masehualme catli techitaj quen amo tleno topati. 
\q1 Inijuanti catli mohueyimatij huan catli ricos tlahuel techpinajtíaj, 
\q1 hasta ya techyolajsic. 
\c 124  
\s1 David quihueyimatqui Toteco pampa quimanahui tlen icualancaitacahua 
\q1  
\v 1 Nochi israelitame ma quiijtoca tlaque tijchijtosquíaj sintla TOTECO amo itztosquía tohuaya huan amo techpalehuijtosquía. 
\q1  
\v 2 Sintla TOTECO amo itztosquía tohuaya quema nopa tlacame motlananque para techhuilanase, 
\q1  
\v 3 techtolojtosquíaj tiyoltoque huan techtzontlamiltijtosquíaj ica ininhueyi cualancayo. 
\q1  
\v 4 Inijuanti techhuahuatatztosquíaj quen atl tlatilana, 
\q1 huan huajca eltosquía quen hueyatl panotosquía ipan tojuanti. 
\q1  
\v 5 Quena, eltosquía quen panotosquía miyac atl catli tetetztic, 
\q1 catli tehuahuatatztosquía huan titzontlantosquíaj. 
\q1  
\v 6 Ma tijtlascamatica TOTECO pampa amo quincahuili ma techcococa. 
\q1  
\v 7 Quen se tototl cholohua tlen se tlaquetztli, 
\q1 quej nopa nojquiya Toteco techchololti ininmaco tocualancaitacahua, 
\q1 catli quinequiyayaj techmasiltise. 
\q1 Nopa lazo cotonqui huan tojuanti timocajque timajcajtoque. 
\q1  
\v 8 Tojuanti totlapalehuil huala tlen TOTECO, 
\q1 catli quichijchijqui ilhuicactli huan tlaltipactli. 
\c 125  
\s1 Toteco quinmocuitlahuía imasehualhua 
\q1  
\v 1 Masehualme catli motemachíaj ipan TOTECO itztoque neltemachme, 
\q1 quen nopa tepetl Sion catli amo mojmolinía, 
\q1 huan ijcatoc cuali para nochipa. 
\q1  
\v 2 Quen Jerusalén quiyahualojtoque miyac tepeme para quimanahuise, 
\q1 quej nopa nojquiya TOTECO quinyahualojtoc imasehualhua huan quinmanahuía. 
\q1  
\v 3 Toteco amo quincahuilis ma tlanahuatica masehualme catli fiero inintlalnamiquilis, 
\q1 pampa huelis imasehualhua catli itztoque xitlahuaque nojquiya pehuasquíaj quichihuasquíaj tlamantli catli amo cuali. 
\b  
\q1  
\v 4 TOTECO, xiquinchihuili catli cuali masehualme catli cuajcualme, 
\q1 huan catli xitlahuac ininyolo moixpa. 
\q1  
\v 5 Pero nopa masehualme catli moiyocatlalíaj ica tlamantli catli amo cuali xiquinhuica campa tiquintlatzacuiltis. 
\q1 Huan ma onca paquilistli huan tlasehuilistli ipan tlali Israel. 
\c 126  
\s1 Toteco quicualtlalis itlal 
\q1  
\v 1 Quema TOTECO sempa quinhualicase ipan Jerusalén nochi imasehualhua catli tetequipanohuaj ipan sequinoc tlalme, 
\q1 elis quen tijtemiquij. 
\q1  
\v 2 ¡Nelía tihuetzcase huan tihuicase ica paquilistli! 
\q1 Huan nopa masehualme tlen sequinoc tlalme quiijtose: 
\q1 “¡Dios quichijtoc huejhueyi tlamantli para nopa israelitame!” 
\q1  
\v 3 Quena, nelía melahuac TOTECO techchihuilis huejhueyi tlamantli. 
\q1 ¡Ma tipaquica! 
\b  
\q1  
\v 4 TOTECO, sempa techmacas tlamantli catli cuali quen tijpixtoyaj achtihuiya. 
\q1 Quena, quen nopa hueyame catli ajsi ipan nopa huactoc tlali huan quiyancuilía, 
\q1 quej nopa xijyancuili tonemilis, TOTECO. 
\q1  
\v 5 Catli tocaj ica choquistli, ica paquilistli pixcase. 
\q1  
\v 6 Quena, masque chocatiyase quema quitoctiyase ininxinach, 
\q1 pero quema pixcatij huicatihualase ica paquilistli pampa ya quihualicase catli quipixcatose. 
\c 127  
\s1 Nochi catli cuali huala tlen Toteco 
\q1  
\v 1 Sintla TOTECO amo quitlanana se cali catli masehualme quichihuasnequij, 
\q1 san tlapic inintequi catli nopona tequitij. 
\q1 Sintla TOTECO amo quimocuitlahuía se altepetl, 
\q1 san tlapic inintequi nopa masehualme catli nopona tlamocuitlahuíaj. 
\q1  
\v 2 San tlapic anmehuase cualca para antequitise chicahuac huan amo anmosiyajquetzase hasta tlajco yohual. 
\q1 San tlapic para ica miyac tequipacholi anquitemojtinemise amotlacualis huan san ya nopa anquimatise. 
\q1 Pampa Toteco Dios quinequi ximotemachica ipan ya huan xicochica cuali. 
\q1 Yaya quinmacas nochi catli quinicnelía nochi catli monequi. 
\q1  
\v 3 Toconehua itztoque se nemactli tlen TOTECO. 
\q1 Quena, catli tlacatij tlen totlacayo eltoc quen se tlatlancayotl. 
\q1  
\v 4 Nopa coneme catli se quinpiya quema noja se telpoca tlacatl, 
\q1 itztoque quen miyac cuatlamintli catli quintequihuía se soldado para ica momanahuis ipan tlahuilancayotl. 
\q1  
\v 5 Cuali ipanti se tlacatl catli quinpiya miyac iconehua. 
\q1 Nopa tlacatl amo mopinahuas sintla icualancaitacahua quitelhuíaj iixpa se juez, 
\q1 pampa nochi quitlepanitase catli quinpiyas para ica momanahuis. 
\c 128  
\s1 Cuali ipanti nopa masehuali catli quitlepanita Toteco 
\q1  
\v 1 Nelía paqui nopa masehuali catli quiimacasi huan quitlepanita TOTECO. 
\q1 Quena, paqui catli nemi xitlahuac ipan iojhui. 
\q1  
\v 2 Quiselis itlaxtlahuil pampa tequiti cuali. 
\q1 Yaya paquis miyac huan nochi catli quichihuas quisas cuali. 
\q1  
\v 3 Isihua paquis ipan ichaj. 
\q1 Yaya elis quen se cuali xocomeca tzontli catli achi más quimocuitlahuíaj huan catli temaca miyac itlajca. 
\q1 Quinpiyas miyac ininconehua catli mosehuise campa imesa huan quipiyase miyac chicahualistli. 
\q1 Quena, itztose quen olivo cuame catli nelía cuali. 
\q1  
\v 4 Quej nopa TOTECO quitiochihuas nopa tlacatl catli quiimacasi huan quitlepanita. 
\q1  
\v 5 TOTECO quitiochihuas tlen altepetl Sion. 
\q1 Quicahuilis para quiitas para nochi eltoc cuali ipan Jerusalén nochi tonali tlen inemilis. 
\q1  
\v 6 Quicahuilis para itztos hasta quinitas iixhuihua. 
\q1 ¡Toteco quimacas tlasehuilistli nopa tlali Israel! 
\c 129  
\s1 Ma huetzica catli quincualancaitaj israelitame huan altepetl Jerusalén 
\q1  
\v 1 Nochi israelitame hueli quiijtose para hasta quema pejqui itztose israelitame, 
\q1 huan pejqui timochihuaj se altepetl tlen san se toeso timasehualme, 
\q1 tocualancaitacahua techtepotztocatinentoque. 
\q1  
\v 2 Techcuesolmacatoque hasta quema tiisraelita masehualme tionpejque timoscaltíaj quen se telpocatl. 
\q1 Pero amo quema hueltoque techtzontlamiltíaj. 
\q1  
\v 3 Tocuitlapa techtlamicocojque quema techmaquiliyayaj hasta huejcajya. 
\q1  
\v 4 Pero TOTECO yaya nelía xitlahuac, 
\q1 quicotonqui nopa tepos cadenas catli ica techtatacatzohuayayaj nopa masehualme catli amo quitlepanitaj TOTECO. 
\q1  
\v 5 Ma huetzica ipan se hueyi pinahualistli nochi catli quicualancaitaj altepetl Jerusalén. 
\q1  
\v 6 Ma elica quen nopa xihuitl catli nimantzi pilini huan huaqui pampa ixhuatoc ipan tlali catli amo huejcatla. 
\q1  
\v 7 Quena, ma elica quen nopa xihuitl catli amo aqui quimehua, 
\q1 niyon amo aqui quipixca itlajca pampa amo tleno ipati. 
\q1  
\v 8 Nimitztlajtlanía para niyon se catli pano nopa fiero masehualme ma amo quintiochihuaca. 
\q1 Amo aqui ma quiijto: 
\q1 “Ma TOTECO anmechtiochihua.” 
\q1 Niyon ma amo quiijtoca: 
\q1 “Tojuanti timechtiochihuaj ica itequiticayo TOTECO.” 
\c 130  
\s1 Ximotemachica ipan Toteco para anmechmanahuis 
\q1  
\v 1 TOTECO, quema nimopantía ipan se hueyi tlaohuijcayotl, 
\q1 na nimitztzajtzilía para techtitlanilis motlapalehuil. 
\q1  
\v 2 Toteco, techtlacaquili quema nimitznojnotza. 
\q1 Techchihuili cuenta catli nimitztlajtlanía huan techpalehui. 
\q1  
\v 3 TOTECO, sintla tiquelnamiquisquía nochi totlajtlacolhua, 
\q1 amo aqui huelisquía moquetzas moixpa. 
\q1  
\v 4 Pero ta nelía titetlapojpolhuía, 
\q1 para nochi masehualme ma mitztlepanitaca. 
\q1  
\v 5 Na nimochiya ipan ta, TOTECO, para techpalehuis, 
\q1 Quena, ica nochi noyolo nimotemachía ipan nopa catli techtlajtolcahuilijtoc ipan mocamanal. 
\q1  
\v 6 Ipan noalma senquistoc nitlachixtoc para ta, TOTECO, xitequiti. 
\q1 Nitlachixtoc para techpalehuis, 
\q1 quen nopa tlamocuitlahuiani quichiyaj ma tlanesi. 
\q1 Quena, más nitlachixtoc huan amo quen tlamocuitlahuiani catli tlahuel quinequij ma tlanesi. 
\b  
\q1  
\v 7 Nochi anisraelitame, ximotemachica ipan TOTECO, 
\q1 pampa san yaya quipiya hueyi iyolo huan san yaya temaquixtía tlatoctzitzi. 
\q1  
\v 8 Yaya quinmaquixtis israelitame tlen nochi inintlajtlacolhua. 
\c 131  
\s1 Ximotemachica ipan Toteco 
\q1  
\v 1 TOTECO, na amo nimohueyimati, 
\q1 niyon amo nimotlepanita. 
\q1 Na amo nimoilhuía para achi más nicuali, 
\q1 niyon amo nimoilhuía para más nijmati que sequinoc. 
\q1  
\v 2 Na amo nimolinía iixpa Toteco. 
\q1 Nimochijtoc quen se piloquichpiltzi catli sanoc quicajtoc chichi huan mosehuía imetzco inana. 
\q1 Quena, ayacmo tleno nimitztlajtlanijtoc. 
\q1  
\v 3 Huajca anisraelitame tlen ama huan para nochipa, 
\q1 san ximotemachica ipan TOTECO. 
\c 132  
\s1 Netlatlajtili para Toteco ma quitiochihua nopa tiopamitl 
\q1  
\v 1 TOTECO, xiquelnamiqui David huan quenicatza tlaijiyohui. 
\q1  
\v 2 Xiquelnamiqui quenicatza David tlatestigojquetzqui ica ta, TOTECO, 
\q1 catli tiiTeco Jacob, Catli Tijpiya Nochi Chicahualistli. 
\q1  
\v 3 Quiijto: 
\q1 “Amo nicalaquis nocalijtic, 
\q1 niyon amo nimotecas ipan notlapech para nicochis. 
\q1  
\v 4 Amo niixijcopis, niyon amo nicochis niyon se tlatoctzi, 
\q1  
\v 5 hasta nijpantis se lugar campa huelis nijchihuas ichaj TOTECO para ipan ma mocahua, 
\q1 yaya catli iTeco Jacob, Catli Quipiya Nochi Chicahualistli.” 
\b  
\q1  
\v 6 Tijcajque camanaltij ipan tlali Efrata para icaxa TOTECO eltoya nopona, 
\q1 huan teipa tijpantijque huejca tlen altepeme ipan cuatitlamitl. 
\q1  
\v 7 Huajca ama ma tiyaca ipan itiopa Toteco. 
\q1 Ma tiyase timotlancuaquetzatij iixpa para tijhueyichihuase. 
\b  
\q1  
\v 8 TOTECO, ximotlanana huan xicalaqui ipan nopa tiopamitl campa eltoc mocaxa, 
\q1 catli quiixnextía mochicahualis. 
\q1  
\v 9 Nopa totajtzitzi catli tiquintlapejpenijtoc ma moquentica ininyoyo chipahuac catli quinixnextía para tlatzejtzeloltique, 
\q1 huan nochi masehualme catli tiquiniyocatlalijtoc ma tzajtzica ica paquilistli. 
\q1  
\v 10 NoTeco, pampa tiquicnelía motequipanojca David, 
\q1 amo ximoicancuepa tlen nopa tlanahuatijquetl catli ta tijtlapejpeni, 
\q1 para quinnahuatis momasehualhua. 
\q1  
\v 11 Pampa ta, TOTECO, tijtlajtolcahuili David, 
\q1 huan amo quema tiquelcahua tijchihua catli tijtlajtolcahua. 
\q1 Huan ta tiquilhui para teipa tiquintlalis iixhuihua ipan isiya para tlanahuatise. 
\q1  
\v 12 Huan sintla iixhuihua quichihuase catli quiijtohua nopa camanal sencahuali catli tijchijqui ica David huan sintla quitlepanitase motlajtol, 
\q1 huajca inijuanti nojquiya mosehuise ipan isiya para tlanahuatise para nochipa. 
\q1  
\v 13 Pampa ta TOTECO, tijtlapejpenijtoc altepetl Jerusalén para tiitztos nopona. 
\q1  
\v 14 Tiquijto: 
\q1 “Ya ni elis nochaj campa niitztos para nochipa. 
\q1 Nopona nimocahuas pampa ya nopa catli nijnequi. 
\q1  
\v 15 Nijtiochihuas ni altepetl miyac huan niquintlamacas imasehualhua catli teicneltzitzi. 
\q1  
\v 16 Niquinmaquixtis itotajtzitzi tlen nochi catli quinequij quincocose, 
\q1 huan itlatzejtzeloltijca masehualhua tzajtzise ica paquilistli. 
\q1  
\v 17 Nopa chicahualistli catli David quipixqui sempa nijchihuas para monextis ipan icone, 
\q1 huan yaya catli nicaltijtoc para nijtequimacas quen tlanahuatijquetl elis quen se tlahuili para imasehualhua. 
\q1  
\v 18 Icualancaitacahua niquintlahuisos ipan se hueyi pinahualistli, 
\q1 pero yaya catli tlanahuatijquetl tlanahuatis cuali huan monextis nochi ihueyitilis.” 
\c 133  
\s1 Nelía yejyectzi nesi quema timosentilíaj ininhuaya toicnihua 
\q1  
\v 1 Xiquitaca, nelía cuali huan yejyectzi nesi para icnime ma mocahuaca sentic ica san se ininyolo. 
\q1  
\v 2 Quema san se ininyolo masehualme, eltoc yejyectzi quen nopa aceite catli quitequilijque Aarón ipan itzonteco, 
\q1 huan temoc ipan itentzo huan yajqui hasta iteno iyoyo. 
\q1  
\v 3 Eltoc yejyectzi huan nesi quen nopa ajhuachtli catli huetzi ipan tepetl Hermón huan moxixitohua ipan tepetl Sion. 
\q1 Pampa campa itztoque sentic ica san se ininyolo masehualme, 
\q1 TOTECO nopona quititlani tlatiochihualistli huan nemilistli para nochipa. 
\c 134  
\s1 Ma quitlascamatica Toteco sesen tiotlac 
\q1  
\v 1 Ama xijhueyimatica TOTECO, 
\q1 nochi amojuanti anitequipanojcahua. 
\q1 Xijhueyimatica nochi amojuanti catli sesen tlayohua antlamocuitlahuíaj ipan ichaj. 
\q1  
\v 2 Ximomatlananaca huan xijtlascamatica TOTECO. 
\q1  
\v 3 Ma anmechtiochihua TOTECO tlen nopona ipan altepetl Sion, 
\q1 Quena, ma anmechtiochihua Toteco catli quichijchijqui ilhuicactli huan tlaltipactli. 
\c 135  
\s1 Toteco nelía hueyi, pero teteyome amo tleno ininpati 
\q1  
\v 1 ¡Xijpaquilismacaca TOTECO! 
\q1 Quena, xijpaquilismacaca nochi amojuanti anitequipanojcahua. 
\q1  
\v 2 Xijpaquilismacaca nochi amojuanti catli anitztoque ipan ichaj TOTECO huan catli annentinemij icalixpa. 
\q1  
\v 3 Xijpaquilismacaca TOTECO pampa yaya nelía cuali. 
\q1 Xijhuicatica ica tiohuicatl pampa yaya hueyi iyolo. 
\q1  
\v 4 Pampa TOTECO quitlapejpenijtoc Jacob para quiicnelis. 
\q1 Quintlapejpeni nochi iixhuihua ma elica iaxcahua. 
\q1  
\v 5 Na nijmati para TOTECO tlahuel hueyi. 
\q1 Nijmati para yaya tlahuel más hueyi que nochi catli quintocaxtíaj “dioses”. 
\q1  
\v 6 TOTECO quichihua nochi catli quinequi quichihuas ipan ilhuicactli, tlaltipactli, 
\q1 huan ipan hueyi atl huan campa más huejcatla. 
\q1  
\v 7 Quichihua para ipan nochi tlaltipactli ma motlanana mixtli, 
\q1 huan nojquiya quititlani tlapetlanilotl huan quichihua ma tlaquiyahui. 
\q1 Yaya quinahuatía ma quisa nopa ajacatl campa moajoctoc. 
\q1  
\v 8 Quichijqui ma miqui nopa achtihui ejquetl ipan sesen familia tlen tlali Egipto, 
\q1 huan nopa achtihui ejquetl tlen inintlapiyalhua. 
\q1  
\v 9 Quichijqui huejhueyi tiochicahual nextili ipan tlali Egipto iixpa Faraón huan itequipanojcahua. 
\q1  
\v 10 Quintzontlamilti miyac masehualme ipan miyac tlalme. 
\q1 Quinmicti tlanahuatiani catli quipiyayayaj miyac chicahualistli. 
\q1  
\v 11 Quimicti Sehón catli eliyaya inintlanahuatijca nopa amorreos. 
\q1 Nojquiya quimicti Og tlanahuatijquetl tlen tlali Basán huan nochi nopa tlanahuatiani ipan tlali Canaán. 
\q1  
\v 12 Huan nochi nopa tlali catli quinahuatiyayaj nopa tlanahuatiani quincuili, 
\q1 huan quinmacac nopa tlalme nopa israelitame quen elisquía se tlamantli catli inintata quincahuilijtejqui. 
\b  
\q1  
\v 13 TOTECO, masehualme mitzelnamictose para nochipa. 
\q1 Nochi masehualme catli tlacajtiyase mitziximajtose para tlahuel tihueyi. 
\b  
\q1  
\v 14 Pampa TOTECO quintlajtolsencahuas xitlahuac nochi imasehualhua, 
\q1 huan yaya quintlasojtlas itequipanojcahua. 
\q1  
\v 15 Nopa masehualme catli itztoque ipan tlalme catli amo quiiximatij Toteco, 
\q1 quinhueyichihuaj teteyome tlen oro huan plata catli quinchijchijtoque ica ininmax. 
\q1  
\v 16 Nopa teteyome quipiyaj inincamac, pero amo camanaltij, 
\q1 quipiyaj iniixteyol, pero amo tlachiyaj. 
\q1  
\v 17 Quipiyaj ininnacas, pero amo tlacaquij, 
\q1 huan nojquiya amo hueli tlaijiyotilanaj. 
\q1  
\v 18 Nopa masehualme catli quinchijchihuaj nopa teteyome nelía huihuitique, 
\q1 san se quen nopa teteyome, 
\q1 huan san se huihuitique catli ininpan motemachíaj. 
\b  
\q1  
\v 19 ¡Anisraelitame, xijpaquilismacaca, TOTECO! 
\q1 Amojuanti antotajtzitzi catli aniixhuihua Aarón, xijpaquilismacaca TOTECO. 
\q1  
\v 20 Aniixhuihua Leví, xijpaquilismacaca TOTECO. 
\q1 Huan nochi amojuanti catli anquiimacasij huan anquitlepanitaj TOTECO, 
\q1 xijpaquilismacaca. 
\q1  
\v 21 Nochi masehualme ipan altepetl Jerusalén ma quipaquilismacaca TOTECO pampa yaya itztoc nica ipan altepetl Jerusalén. 
\q1 ¡Paquilistli! 
\c 136  
\s1 Ma tijtlascamatica Toteco 
\q1  
\v 1 Xijtlascamatica TOTECO pampa yaya nelía cuali, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 2 Xijtlascamatica Toteco Dios catli más hueyi tlen nochi sequinoc “dioses”, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 3 Xijtlascamatica Toteco Dios catli ininTeco nochi tecojme, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 4 Xijtlascamatica TOTECO pampa san ya hueli quichihua huejhueyi tlamantli, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 5 Xijtlascamatica yaya catli quichijchijqui ilhuicactli ica miyac tlalnamiquilistli, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 6 Xijtlascamatica yaya catli quitlali ni tlali ipani atl, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 7 Xijtlascamatica yaya catli quinchijchijqui nopa tlahuilme catli onca nepa ilhuicac, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 8 Quichijchijqui nopa tonati para ma tlahui tonaya, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 9 Huan quichijchijqui metztli huan sitlalime para ma tlahuica tlayohua, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 10 Xijtlascamatica TOTECO catli quintzontlamilti nopa achtihui ehuani tlen tlali Egipto, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 11 Xijtlascamatica catli quinquixti israelitame ipan inintlal nopa egiptome, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 12 Quena, quinquixti ica ihueyi chicahualis huan ica inejmac quinpalehui, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 13 Xijtlascamatica yaya catli quixelo nopa Hueyi Atl Chichiltic para ma panoca imasehualhua, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 14 Huan quinpanolti nopa israelitame ipan tlali huactoc tlatlajco nopa hueyi atl, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 15 Pero quinatzonpolihuilti Faraón huan isoldados ipan nopa hueyi atl, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 16 Xijtlascamatica Toteco catli quinyacanqui imasehualhua ipan nopa huactoc tlali, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 17 Xijtlascamatica yaya catli quinmanahui imasehualhua ininmaco tlanahuatiani catli quipixque miyac chicahualistli, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 18 Yaya quintzontlamilti huejhueyi tlanahuatiani catli tlahuel quipiyayayaj chicahualistli, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 19 Quitzontlamilti Sehón, inintlanahuatijca nopa amorreos, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 20 Nojquiya quimicti Og, tlanahuatijquetl tlen tlali Basán, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 21 Huan inintlal nopa tlanahuatiani, 
\q1 Toteco quinmacac imasehualhua quen se tlamantli catli inintata quincahuilijtejqui, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 22 Quena, quimacac itequipanojca Israel para ma moaxcati nopa tlali para nochipa, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 23 Yaya catli techelnamijqui tiisraelitame quema ayacmo tijpiyayayaj chicahualistli, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 24 Yaya techmanahui ininmaco tocualancaitacahua, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 25 Yaya quinmaca tlacualistli nochi tlamantli catli yoltoque, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\q1  
\v 26 Xijtlascamatica Toteco Dios catli quinahuatía ilhuicactli, 
\q1 pampa itlaicnelijcayo amo quema tlami. 
\c 137  
\s1 Inintequipachol israelitame catli itztoque ipan tlali Babilonia 
\q1  
\v 1 Ipan tlali Babilonia timosehuiyayaj iteno atemitl, 
\q1 huan timochoquiliyayaj, 
\q1 pampa tiquelnamiquiyayaj altepetl Jerusalén, 
\q1 huan quenicatza onpano cuali elqui. 
\q1  
\v 2 Tiquintlahuelcajtoyaj toarpas huan tiquincuapilojtoyaj ipan ininmacuayo nopa cuame. 
\q1  
\v 3 Amo hueliyaya tihuicaj. 
\q1 Pero inijuanti catli techhualicatoyaj ica fuerza ipan inintlal, 
\q1 techilhuijque ma tihuicaca ica paquilistli nopa yejyectzitzi huicatl catli tihuicayayaj quema tiitztoyaj ipan altepetl Jerusalén. 
\q1  
\v 4 Pero amo tihuelque. 
\q1 Amo hueli tihuicase se huicatl para Toteco ipan seyoc tlali ica masehualme catli amo tiquiniximatij. 
\q1  
\v 5 Sintla niquelcahuasquía altepetl Jerusalén, 
\q1 ma quipolo ichicahualis nonejmac, 
\q1 huan ma ayacmo huelis quitzotzonas nopa arpa. 
\q1  
\v 6 Sintla ayacmo niquicnelisquía Jerusalén catli techpaquilismaca, 
\q1 xijcahua nonenepil ma tlatzqui ipan nocamachal para ayacmo nihuicas. 
\b  
\q1  
\v 7 TOTECO, amo xiquelcahua catli nopa tlali Edom ehuani quiijtojque, 
\q1 quema nopa soldados tlen tlali Babilonia quisosolohuayayaj altepetl Jerusalén. 
\q1 Inijuanti quiijtohuayayaj: 
\q1 “Xijsosoloca nopa altepetl hasta campa tlatzquitoc.” 
\b  
\q1  
\v 8 Teicneltzi ni tlali Babilonia, 
\q1 pampa nojquiya quisosolose. 
\q1 Nelía paquis nopa tlacatl catli quitlamisosolos huan quintzontlamiltis imasehualhua. 
\q1  
\v 9 ¡Tlahuel paquis nopa tlacatl catli quinitzquis coneme tlen Babilonia huan quinxaxamatzas ipan tetl, 
\q1 por catli fiero quichijtoque inintatahua ipan altepetl Jerusalén! 
\c 138  
\s1 Tlascamatili por itlapalehuil Toteco 
\q1  
\v 1 Ica nochi noyolo nimitztlascamatis, TOTECO, 
\q1 huan nihuicas para ta iniixpa nopa motequihuajcahua. 
\q1  
\v 2 Nimotlancuaquetza iixmelac motiopa catli tlatzejtzeloltic, 
\q1 huan nimitztlascamatis pampa nelía titetlasojtla huan titemachtli. 
\q1 Nochi catli techtlajtolcahuilijtoc para tijchihuas, 
\q1 tijtlamichihuas pampa mocamanal nelía temachtli quen ta titemachtli. 
\q1  
\v 3 Quema nimitztzajtzilía, 
\q1 ta technanquilía huan techfuerzajmaca. 
\q1  
\v 4 TOTECO, nochi tlanahuatiani catli itztoque ipan ni tlaltipactli mitztlascamatise, 
\q1 pampa nochi inijuanti quicaquise catli tijtlajtolcajtoc. 
\b  
\q1  
\v 5 Quena, huicase por nochi nopa huejhueyi tlamantli catli quichijtoc TOTECO, 
\q1 pampa ihueyitilis nelhueyi. 
\q1  
\v 6 Masque TOTECO tlahuel hueyi, 
\q1 yaya quintlacaquilía catli moechcapanohuaj. 
\q1 Pero catli mohueyimatij, 
\q1 monequi moquetzase huejca tlen Toteco, 
\q1 pampa yaya amo quinequi quinitas. 
\b  
\q1  
\v 7 Sintla niitztoc ipan tlaijiyohuilistli, ta TOTECO, 
\q1 techmanahuía huan techmaquixtía. 
\q1 Huan quema nechhuilanaj nocualancaitacahua, 
\q1 ta tijxitlahua momax huan techmaquixtía ica mohueyi chicahualis. 
\q1  
\v 8 TOTECO, ta tijchihuas nochi catli timoilhuijtoc para tijchihuas ipan na nonemilis. 
\q1 Pampa nopa tlaicnelijcayotl catli tijpiya ica na, TOTECO, 
\q1 amo quema tlami. 
\q1 Amo techtlahuelcahua pampa ta techchijchijqui. 
\c 139  
\s1 Toteco itztoc campa hueli 
\q1  
\v 1 TOTECO, ta techyoltlachilijtoc huan tijmati nochi tlen na. 
\q1  
\v 2 Ta cuali tijmati sintla nimosehuía o nimoquetza. 
\q1 Huan quema niitztoc huejca, 
\q1 ta tijmati tlaque nijpixtoc ipan notlalnamiquilis. 
\q1  
\v 3 Ta technextilía nopa ojtli catli monequi nijtoquilis, 
\q1 huan techilhuía canque nicalaquis huan canque nimosiyajquetzas. 
\q1 Sesen tlatoctzi ta tijmati canque niitztoc. 
\q1  
\v 4 Ta TOTECO, tijmati tlaque niquijtos hasta quema ayamo nicamanalti. 
\q1  
\v 5 Ta techyahualojtoc pampa tiya ica noixpa huan ica noica, 
\q1 huan tijtlalía momax ipan na para techtiochihuas. 
\q1  
\v 6 Nochi ni tlamantli catli ta tijmati nelía yejyectzi, 
\q1 huan ohui para nijneltocas. 
\q1  
\v 7 Amo cana hueli nimotlatis tlen moTonaltzi. 
\q1 Amo cana huelis nimotlatis huan amo tiitztos nopona. 
\q1  
\v 8 Sintla nitlejcos hasta ilhuicac para nimotlatis, 
\q1 ta nopona tiitztoc. 
\q1 Huan sintla niyasquía ipan nopa hueyi ostotl campa itztoque mijcatzitzi, 
\q1 ta nepa tiitztoc. 
\q1  
\v 9 Sintla nijpiyasquía noeltlapal huan nipatlanisquía, 
\q1 huan niquixcotonasquía nopa hueyi atl, 
\q1  
\v 10 hasta nepa techyacanasquía ica mohueyi chicahualis. 
\q1  
\v 11 Sintla nijchihuasquía campica para nimotlatis ipan tzintlayohuilotl, 
\q1 nopa tzintlayohuilotl mocuepasquía tlahuili yahualtic tlen na, 
\q1 pampa ta tiitztos nopona. 
\q1  
\v 12 Pampa niyon nopa tzintlayohuilotl amo hueli techtlatis moixpa, Toteco. 
\q1 Pampa para ta nopa yohuali tlahuía quen elisquía tonaya. 
\q1 Nopa tzintlayohuilotl huan tlahuili ta tiquita san se. 
\q1  
\v 13 Ta tijsencajqui sesen tlamantli catli onca iijtic notlacayo. 
\q1 Huan tijmotzquilti sesen tlamantli catli nijpiya, 
\q1 quema niitztoya iijtico nonana. 
\q1  
\v 14 Nimitztlascamati pampa techsencajqui ma nieli se tlamantli catli nelía cuajcualtzi. 
\q1 Quena, nopa tequitl catli tijchijqui quema techsencajqui onpano yejyectzi. 
\q1 San nijsentlachilía para nimoilhuis nochi catli tijchijtoc ipan notlacayo. 
\q1  
\v 15 Ta tijtlachiliyaya quema na nipejqui nimoscaltía nopona nel nimotlatijtoya tlen nochi sequinoc ipan iijtico nonana. 
\q1 Quema amo aqui más quitlachiliyaya, 
\q1 ta techchijchijqui ica mohueyi yajatil, 
\q1 quen se catli cuali quimati tlaxinepalohua. 
\q1  
\v 16 Ta techitac quema ayamo nitlacatiyaya. 
\q1 Huan quema ayamo nitlaijiyotilanayaya, tiquixquetzqui quesqui tonali niitztosquía. 
\q1 Huan sesen tonal catli niitztosquía huan tlaque nopantis, 
\q1 ta tiquijcuilo ipan molibro. 
\q1  
\v 17 Toteco Dios, nelía yejyectzi quema nimomaca cuenta para ta tijsenhuiquilía timonejnehuilía tlen na. 
\q1  
\v 18 Hasta amo hueli nijpohua quesqui huelta timonejnehuilía tlen na ipan se tonali. 
\q1 Huan ica ijnaloc quema niisa, 
\q1 ta noja timonejnehuilijtoc tlen na. 
\q1  
\v 19 Toteco Dios, nelía elisquía cuali sintla tiquintzontlamiltisquía nochi masehualme catli amo mitztlepanitaj. 
\q1 Xijchihua ma nechtlalcahuica nopa temictiani, 
\q1  
\v 20 pampa inijuanti mitztlaijilhuíaj, 
\q1 huan san quiahuilmatij motoca. 
\q1  
\v 21 TOTECO, ¿atlac amo quinamiqui para niquincualancaitas inijuanti catli mitzcualancaitaj? 
\q1 ¿Atlac amo quinamiqui nicualanis ica mocualancaitacahua? 
\q1  
\v 22 Quena, tlahuel niquincualancaita, 
\q1 pampa niquinita quen nojquiya elisquíaj nocualancaitacahua na. 
\q1  
\v 23 NoTeco Dios, xijtlachili noyolo huan xiquita nochi catli eltoc nopona. 
\q1 Huan xijyejyeco notlalnamiquilis para tiquitas sintla xitlahuac catli nimoilhuía. 
\q1  
\v 24 Technextili sintla onca ipan notlanejnehuilis se tlalnamiquilistli catli amo mitzpactía, 
\q1 huan techyacantiya ipan nopa ojtli catli tehuica campa onca nemilistli para nochipa. 
\c 140  
\s1 TOTECO, techmanahui ininmaco amo cuajcualme 
\q1  
\v 1 TOTECO, techmanahui ininmaco nopa tlaixpanoca masehualme. 
\q1 Techmocuitlahui para tlahuilanca tlacame amo huelis nechcocose. 
\q1  
\v 2 Inijuanti nochi se tonal quisencahuaj quenicatza quichihuase tlamantli catli amo cuali. 
\q1 Tlatoctzitzi quinequij quipehualtise cualantli. 
\q1  
\v 3 Inincamanal tecocohua quen itencococa se cohuatl o se colotl. 
\q1  
\v 4 TOTECO, techmocuitlahui para amo nihuetzis ininmaco masehualme catli amo cuajcualme, 
\q1 huan catli tetlaijilhuíaj, 
\q1 pampa inijuanti moilhuijtoque quenicatza nechhuihuiitase. 
\q1  
\v 5 Nopa masehualme catli mohueyimatij quitlalijtoque se tlaquetztli para ma nimasi. 
\q1 Quitlalijtoque se lazo para ica nechcuapilose para ma nimohuisos ajacatipa. 
\q1 Nechchiyaj ica se matlatl para nechmasiltise. 
\q1  
\v 6 Na nimitzilhuijtoc, TOTECO, para ta tinoDios. 
\q1 Techtlacaquili quema nimitztzajtzilía. 
\q1  
\v 7 Ta tiTOTECO Dios, tinotemaquixtijca, 
\q1 ta tijpiya nochi chicahualistli para techmaquixtis. 
\q1 Ta techmocuitlahuía quema onca tlahuilancayotl. 
\q1  
\v 8 TOTECO, amo xiquincahua ma tlatlanica nopa masehualme catli amo mitztlepanitaj. 
\q1 Amo xiquinpalehui para ma quisa cuali catli quinequij quichihuase para ma amo mohueyimatica. 
\q1  
\v 9 Xijchihua para nochi tlamantli catli moilhuijtoque quichihuase ma huetzi ininpani. 
\q1 Ma tzontlamica senquistoc quen quisencajtoyaj nechtzontlamiltise na. 
\q1  
\v 10 Ipan inintzonteco ma huetzi tlicoli, 
\q1 o xiquinmajcahua ipan tlitl, 
\q1 o ipan ostotl catli tlahuel huejcatla campa ayacmo huelise quisase. 
\q1  
\v 11 Amo xiquincahuili ma tlatlanica ipan totlal nopa masehualme catli quinpactía istlacatise. 
\q1 Más cuali nimantzi xiquintlatzacuilti. 
\q1  
\v 12 Pero na cuali nijmati para ta, TOTECO, 
\q1 tiquinpalehuis nopa teicneltzitzi catli inijuanti quintepotztocatinemij. 
\q1 Ta tiquinpalehuis catli teicneltzitzi para ma quisa cuali para inijuanti quen quinamiqui. 
\q1  
\v 13 Huan masehualme catli itztoque xitlahuaque mitztlascamatise, 
\q1 pampa quimatij para temachtli itztotij moixpa. 
\c 141  
\s1 Netlatlajtili para Toteco ma quimanahui 
\q1  
\v 1 TOTECO, na nimitznotza. 
\q1 Ximoisihuilti techpalehuiqui. 
\q1 Techtlacaquili quema nimotlatlajtía ica ta. 
\q1  
\v 2 Xijseli nonetlatlajtilis quen elisquía copali catli quitlatíaj moixpa, 
\q1 huan quema nimomatlanana para nimitzhueyimati, 
\q1 xiquita quen se tlacajcahualistli catli nimitzmactilía ica tiotlac. 
\q1  
\v 3 TOTECO, techmocuitlahui para ma amo nicamanalti quej hueli. 
\q1 Techpalehui para nimocamatzacuas. 
\q1  
\v 4 Amo techcahuili nijnequis tlamantli catli amo cuali. 
\q1 Amo techcahuili ma niquinpalehuis tlaixpanoca masehualme ica catli quichihuaj. 
\q1 Ma amo niquixtoca nijcuas nopa cuali tlamantli catli quipiyaj. 
\q1  
\v 5 Quema monequi se nechtlalnamictis, 
\q1 xijchihua para catli monejnemiltíaj xitlahuac moixpa ma nechtlatzacuiltica. 
\q1 Ya nopa niquitasquía quen se tlamantli cuali catli nechchihuilíaj. 
\q1 Sintla masehualme catli cuajcualme nechtlacahualtise, 
\q1 elis quen se pajtli para na. 
\q1 Amo techcahuili para nijhuejcamajcahuas inon. 
\q1 Pero na tlatoctzitzi nimotlatlajtía para ma quiselica tlatzacuiltili tlaixpanoca masehualme. 
\q1  
\v 6 Quema nijchihuas para mocuamimilose inintlayacanca ipan tepeixco, 
\q1 quicaquise nocamanal huan quipantise para nelcuali. 
\q1  
\v 7 Nopa fiero masehualme quiselise tlatzacuiltili huan iniomiyohua quitepehuase ipan campa hueli tlali. 
\q1  
\v 8 TOTECO, ta catli titoTeco, na san nimitzchiya para techpalehuis. 
\q1 Ipan ta nimotemachía para techmocuitlahuis. 
\q1 Amo xiquincahuili ma nechmictica. 
\q1  
\v 9 Techpalehui para amo nimasis ipan nopa tlaquetztli catli quitlalijtoque nopa fiero masehualme. 
\q1  
\v 10 Xijchihua para nopa amo cuajcualme ininseltzitzi ma momasiltica ica nopa tlaquetztli catli quisencajtoque para sequinoc. 
\q1 Pero na ma nipano nimajcajtoc huan amo tleno ma nopanti. 
\c 142  
\s1 David tlajtlanqui tlapalehuili quema itztoya ipan tlaohuijcayotl 
\q1  
\v 1 Chicahuac nijtzajtzilis TOTECO huan nijtlajtlanis ma nechtlasojtla. 
\q1  
\v 2 Iixpa ya nijpohuilía nochi catli nechtequipacholmaca. 
\q1  
\v 3 Quema eltoc quen nimisahuía ipan tlaohuijcayotl, 
\q1 huan ayacmo nijmati tlaque nijchihuas, nijnojnotza. 
\q1 San ya quimati tlaque ojtli monequi nijtoquilis para nimomanahuis tlen nopa tlaquetztli, 
\q1 catli quitlalijtoque nocualancaitacahua. 
\q1 Quena, campa hueli quitlatijtoque tlaquetztli ipan noojhui. 
\q1  
\v 4 Nijtlachili campa hueli huan niquitac. 
\q1 Amo aqui monejnehuilía tlen na. 
\q1 Amo aqui quinequi nechpalehuis. 
\q1 Amo aqui nechmocuitlahuía, niyon amo aqui quichihuilía cuenta nonemilis. 
\b  
\q1  
\v 5 Huajca na nimitztzajtzili, TOTECO, huan nimitzilhui: 
\q1 “TOTECO, san ipan ta nimotemachía para techmocuitlahuis. 
\q1 San ta hueli techmanahuis para amo tleno nopantis. 
\q1  
\v 6 Xijtlacaquili catli nimitztlajtlanía, 
\q1 pampa tlahuel nechtlaijiyohuiltíaj masehualme. 
\q1 Techmanahui ininmaco catli nechtepotztocatinemij, 
\q1 pampa inijuanti achi más quipiyaj chicahualistli que na. 
\q1  
\v 7 Techquixti ipan ni tlatzactli campa niitztoc para nihuelis nimitztlascamatis. 
\q1 Huan huajca nopa masehualme catli itztoque xitlahuaque, 
\q1 nechyahualose huan paquise pampa tijpiyas hueyi moyolo nohuaya para nochipa.” 
\c 143  
\s1 Netlatlajtili para Toteco ma quimanahui huan ma quiyacana 
\q1  
\v 1 ¡TOTECO, xijtlacaquili catli nimotlatlajtía ica ta! 
\q1 Technanquili pampa ta titemachtli huan san catli cuali tijchihua. 
\q1  
\v 2 Amo ximochihua quen se juez huan techtlajtolsencahua, 
\q1 pampa moixpa ta amo aqui se masehuali catli itztoc xitlahuac. 
\q1  
\v 3 Nocualancaitacahua nechtepotztocatoque huan nechitzquijque. 
\q1 Nechtlahuisojque huan nechchihualtíaj ma niitzto ipan tzintlayohuilotl quen catli ya mictoque. 
\q1  
\v 4 Nelía senquistoc nimoyoltequipachohua, 
\q1 hasta ayacmo nijmati tlaque nijchihuas. 
\q1  
\v 5 Niquelnamiqui quenicatza eltoya ipan nopa tonali catli panoc. 
\q1 Nimonejnehuilía tlen nochi huejhueyi tlamantli catli tijchijqui. 
\q1  
\v 6 Yeca nimomatlanana moixpa huan nimitztemohua. 
\q1 Ipan noyolo tlahuel nimitznequi quen se tlali catli huactoc quinequi atl. 
\q1  
\v 7 TOTECO, nimantzi technanquili pampa tlahuel nitlaijiyohuía ipan noyolo. 
\q1 Amo ximoicancuepa tlen na para amo nimiquis. 
\q1  
\v 8 Ica ijnaloc, technextili motlaicnelijcayo, 
\q1 pampa ipan ta nimotemachijtoc para techmocuitlahuis. 
\q1 Technextili nopa ojtli catli monequi nijtoquilis, 
\q1 pampa san ta nimitzilhuía catli eltoc ipan noyolo. 
\q1  
\v 9 TOTECO, techmanahui tlen nocualancaitacahua, 
\q1 pampa ipan ta nimotemachía para amo tleno nopantis. 
\q1  
\v 10 Techmachti ma nijchihua catli ta tijnequi pampa ta tinoTeco Dios. 
\q1 MoTonaltzi ma nechyacana campa cuali nopa ojtli. 
\q1  
\v 11 TOTECO, techmaquixti para ma monextis mohueyitilis. 
\q1 Techquixti tlen ni tlaijiyohuilistli pampa ta tijchihua catli xitlahuac. 
\q1  
\v 12 Pampa ta techicnelía, xiquinhuejhuelo nochi nocualancaitacahua. 
\q1 Xiquintzontlamilti nochi catli quinequij nechchihuilise catli amo cuali, 
\q1 pampa nimotequipanojca. 
\c 144  
\s1 Netlatlajtili para Toteco ma quipalehui para tlatlanis 
\q1  
\v 1 Ma nochi quipaquilismacaca TOTECO catli nechtlatíaj para amo nechajsise nocualancaitacahua. 
\q1 Yaya nechyacana huan nechnextilía quenicatza nitlahuilanas. 
\q1  
\v 2 Yaya nechtlasojtla huan yaya nechpixtoc campa temachtli. 
\q1 Yaya nechpixtoc imaco huan nechchololtis tlen nocualancaitacahua. 
\q1 Yaya notlamanahuijca huan ipan ya nimotemachijtoc. 
\q1 Yaya quintlalijtoc nomaco miyac tlalme ica ininmasehualhua para ma niquinnahuatis. 
\b  
\q1  
\v 3 TOTECO, ¿tlaque topati timasehualme para toca timocuatotonía? 
\q1 ¿Tlaque topati para tlahuel ta techpatiita? 
\q1  
\v 4 Pampa tonemilis san panotehua quen se ajacatl huan quen se ecahuilotl. 
\q1  
\v 5 TOTECO, xijcuelpacho nopa ilhuicactli huan xitemo techpaxaloqui. 
\q1 Sintla tiquinpanajsis nopa tepeme, popocase. 
\q1  
\v 6 Xijtitlani tlapetlanilotl quen elisquía cuatlamintli, 
\q1 huan xiquinsemana nochi mocualancaitacahua huan amo quimatise tlaque quichihuase. 
\q1  
\v 7 Hasta tlen nepa ilhuicac xijxitlahua momax huan techmaquixti. 
\q1 Techchololti ininmaco ni nocualancaitacahua catli sequinoc tlalme ehuaj huan tlahuel quipiyaj chicahualistli. 
\q1 Na nijmati quen nimisahuisquía ipan se atl catli tlahuel huejcatla. 
\q1  
\v 8 Inijuanti san quinpactía istlacatise. 
\q1 Tlatestigojquetzaj para quiijtose catli melahuac, 
\q1 huan nimantzi istlacatij. 
\q1  
\v 9 NoTeco Dios, na nihuicas huicatl catli yancuic, 
\q1 huan nitlatzotzonas ipan noarpa catli quipiya majtlactli cuerdas. 
\q1  
\v 10 Pampa ta catli tiquinchihua ma tlatlanica tlanahuatiani. 
\q1 Ta catli techmaquixti na nimotequipanojca, David, para ma amo nechmictica ica machete. 
\q1  
\v 11 Nojquiya techmaquixti huan techmanahui ininmaco nocualancaitacahua, 
\q1 pampa inijuanti san teistlacahuíaj huan tlacajcayahuaj. 
\q1  
\v 12 Xijchihua para totelpocahua ma elica tejtetique huan huejcapantique quen cuame catli yejyectzi moscaltíaj. 
\q1 Huan toichpocahua ma elica yejyectzitzi, 
\q1 quen nopa tlaquetzalme catli quinyejyecchijtoque, 
\q1 huan quinquetztoque ipan ininchajchaj tlanahuatiani. 
\q1  
\v 13 Xijchihua para tocoxtalhua ma temica ica miyac tlamantli pixquistli. 
\q1 Huan toborregojhua ma momiyaquilica hasta ma mochihuaca miles huan millones ipan topotrero. 
\q1  
\v 14 Xijchihua totorojhua ma quipiyaca miyac chicahualistli para tequitise. 
\q1 Amo xijcahuili niyon se tocualancaitaca ma quiyahualo totepa. 
\q1 Techmaca san tlasehuilistli campa hueli. 
\q1 Amo xijcahuili para niyon se tlen tomasehualhua monequi tetzajtzilis para tlapalehuili pampa quipanti catli fiero ipan tocalles. 
\q1  
\v 15 Quena, nelía paquij nopa masehualme ipan se altepetl catli quej ni eltoc, 
\q1 huan amo quipiya catli fiero. 
\q1 Quena, nelía paquij cuali masehualme catli quipiyaj TOTECO para ininDios, 
\q1 huan ipan ya motemachíaj. 
\c 145  
\s1 Toteco nelía cuali huan quipiya nochi chicahualistli 
\q1  
\v 1 Nochi nonemilis huan para nochipa nimitzhueyimatis tinoTeco huan tinotlanahuatijca. 
\q1  
\v 2 Mojmostla nimitzhueyichihuas. 
\q1 Quena, ama huan para nochipa nimitzpaquilismacas. 
\q1  
\v 3 Nelía tihueyi, TOTECO, huan quinamiqui ma timitzhueyimatica nochi timasehualme. 
\q1 Amo aqui quitlamimachilía nochi mohueyitilis. 
\q1  
\v 4 Nochi coneme catli moscaltijtiyase quielnamiquise catli tijchihua, 
\q1 huan tepohuilise nopa tlamantli catli tijchijtihualajtoc ica mohueyi chicahualis. 
\q1  
\v 5 Na san nimonejnehuilis tlen moyejyejca huan mohueyitilis, 
\q1 huan nopa tlatlanextli catli mitzyahualohua. 
\q1 Nimoilhuis tlen nopa huejhueyi tiochicahual nextili catli tijchijtoc. 
\q1  
\v 6 Masehualme camanaltise tlen nopa huejhueyi tlamantli catli tijchijtoc. 
\q1 Huan na nitepohuilis tlen mohueyitilis. 
\q1  
\v 7 Nochi masehualme ipan tlaltipactli camanaltise para nelía ticuali huan hueyi moyolo. 
\q1 Quiijtose para tijchihua san catli xitlahuac. 
\q1  
\v 8 TOTECO, hueyi moyolo huan tlahuel titetlasojtla. 
\q1 Amo nimantzi ticualani huan titeicnelía miyac. 
\q1  
\v 9 TOTECO ta cuali moyolo ica nochi masehualme huan motlaicnelijcayo monextía ipan sesen tlamantli catli tijsencajtoc. 
\q1  
\v 10 TOTECO, nochi tojuanti catli ta techchijchijtoc timitztlascamatij. 
\q1 Quena, nochi tojuanti catli timitztoquilíaj timitzpaquilismacase. 
\q1  
\v 11 Tojuanti sentic timocamanalhuise tlen ihueyitilis motlanahuatilis campa ta titlanahuatía, 
\q1 huan ticamanaltise quenicatza tijpiya hueyi chicahualistli. 
\q1  
\v 12 Titepohuilise tlen nopa huejhueyi tiochicahual nextili catli tijchijtoc, 
\q1 huan tlen moyejyejca huan tlen ihueyitilis motlanahuatilis campa ta titlanahuatía. 
\q1  
\v 13 Pampa motlanahuatilis amo quema tlamis. 
\q1 Ta tijpiyas tlanahuatili ica nochi masehualme catli tlacajtiyase para nochipa. 
\q1  
\v 14 Ta TOTECO tiquintlanana nochi catli huetzij, 
\q1 huan tiquinfuerzajmaca catli itztoque ipan tequipacholi. 
\q1  
\v 15 Nochi masehualme ipan tlaltipactli mitztemohuaj, 
\q1 huan mitzchiyaj para xiquinpalehui. 
\q1 Ta tiquinmaca inintlacualis quen quinmonequilijtihuala. 
\q1  
\v 16 Ta ica momax tiquintiochihua nochi catli yoltoque, 
\q1 pampa tiquinmaca catli quicuase huan catli quiijise. 
\b  
\q1  
\v 17 TOTECO quichihua san catli xitlahuac, 
\q1 huan quinextía para hueyi iyolo ipan nochi catli quichihua. 
\q1  
\v 18 TOTECO itztoc ininnechca nochi catli quinotzaj. 
\q1 Quena, itztoc ininnechca nochi catli quitemohuaj ica nochi ininyolo. 
\q1  
\v 19 Yaya quinmaca catli quinequij nochi masehualme catli quiimacasij huan quitlepanitaj. 
\q1 Quintlacaquilía quema quitzajtzilíaj ma quinpalehui huan quinmaquixtía tlen catli amo cuali. 
\q1  
\v 20 TOTECO quinmocuitlahuía nochi catli quiicnelíaj, 
\q1 pero nochi catli amo quitlepanitaj, 
\q1 Toteco quintzontlamiltis. 
\q1  
\v 21 Nijpaquilismacas TOTECO ica nocamac. 
\q1 Nochi masehualme catli itztoque campa hueli quipaquilismacase para nochipa huan amo quema tlamis. 
\c 146  
\s1 San ma timotemachica ipan Toteco 
\q1  
\v 1 Na nijhueyimatis TOTECO ica nochi noyolo. 
\q1  
\v 2 Nochi tonali ipan nonemilis nijpaquilismacas TOTECO. 
\q1 Nihuicas tiohuicatl para noTeco Dios hasta nimiquis. 
\q1  
\v 3 Amo ximotemachica ipan huejhueyi tlacame catli quipiyaj tequiticayotl, 
\q1 niyon ipan se tlen hueli tlacatl pampa niyon se masehuali amo huelis mitzmaquixtis. 
\q1  
\v 4 Pampa se tonal miquise nochi masehualme huan mocuepase tlali. 
\q1 Quena, tlamis iniijiyo huan ininnemilis, 
\q1 huan ica se tlatoctzi tlamis nochi catli moilhuijtoyaj quichihuase. 
\q1  
\v 5 Pero nelía paqui nopa masehuali catli quipixtoc quen itlapalehuijca yaya catli iTeco Jacob, 
\q1 huan san ipan TOTECO iDios motemachía para quimocuitlahuis. 
\q1  
\v 6 Yaya catli quichijchijqui ilhuicactli, 
\q1 tlaltipactli, hueyi atl huan nochi catli itztoque nopona. 
\q1 Yaya catli quichihua nochi catli quitlajtolcajtoc para quichihuas. 
\q1  
\v 7 TOTECO quinchihuilía catli xitlahuac nochi teicneltzitzi catli sequinoc quintlaijiyohuiltíaj. 
\q1 Huan quintlamaca catli mayanaj. 
\q1 Quinchihua ma yaca majcajtoque catli tzactoque masque amo tleno quichijtoque. 
\q1  
\v 8 TOTECO quintlachiyaltía popoyotzitzi. 
\q1 Quintlanana catli nechca itztoque para huetzise. 
\q1 Huan quinicnelía catli monejnemiltíaj xitlahuac iixpa. 
\q1  
\v 9 TOTECO quinmocuitlahuía nopa seyoc tlali ehuani. 
\q1 Yaya quinmocuitlahuía catli icnotzitzi huan catli cahual toahuihua. 
\q1 Pero yaya quisosolohua catli quisencahuaj masehualme catli amo quitlepanitaj. 
\q1  
\v 10 TOTECO tlanahuatis para nochipa. 
\q1 Amojuanti ipan altepetl Jerusalén, 
\q1 amoTeco Dios elis nopa Tlanahuatijquetl, 
\q1 catli quinnahuatis nochi masehualme catli tlacajtiyase para nochipa. 
\q1 ¡Paquilistli! 
\c 147  
\s1 Ma tijpaquilismacaca Toteco pampa quipalehuijtoc altepetl Jerusalén 
\q1  
\v 1 Xijpaquilismacaca TOTECO pampa nelía cuali para tihuicase tiohuicatl para ya. 
\q1 ¡Nelía yejyectzi huan quinamiqui! 
\q1  
\v 2 TOTECO sempa quicualtlalis altepetl Jerusalén, 
\q1 huan quinsentilis nopa israelitame catli quinsemanqui, 
\q1 huan itztoque ipan sequinoc tlalme quen seyoc tlali ehuani. 
\q1  
\v 3 Yaya quinyolchicahua catli quipiyaj yoltequipacholi huan quinpajtía campa mococojtoque. 
\q1  
\v 4 Yaya quimati quesqui imiyaca sitlalime onca huan sesen quintocaxtlalijtoc. 
\q1  
\v 5 Toteco nelía hueyi huan quipiya miyac chicahualistli. 
\q1 Itlalnamiquilis amo aqui hueli quitlamimachilía. 
\q1  
\v 6 TOTECO quinhueyitlalía catli moechcapanohuaj, 
\q1 pero nochi amo cuajcualme quintlahuisos tlalchi. 
\q1  
\v 7 Xihuicaca para anquitlascamatise TOTECO. 
\q1 Xihuicaca por nochi catli quichijtoc toDios huan xitlatzotzonaca ica arpa. 
\q1  
\v 8 Toteco yaya quitzacua nepa ilhuicactli ica mixtli. 
\q1 Yaya quichihua ma huetzi atl ipan tlaltipactli. 
\q1 Quichihua ma moscalti xihuitl ipan cuatitlamitl. 
\q1  
\v 9 Yaya quintlamaca nopa tecuanime catli nemij cuatitla. 
\q1 Ininpilconehua nopa cacalotl quintlamaca, 
\q1 quema pehuaj chocaj pampa mayanaj. 
\q1  
\v 10 Quema Toteco quiita se cahuayo catli motlalohua chicahuac, 
\q1 o quema quiita se tlacatl catli quipiya miyac fuerza, 
\q1 amo quipantía miyac paquilistli ipan ininchicahualis. 
\q1  
\v 11 Pero TOTECO quipantía miyac paquilistli ipan masehualme catli quitlepanitaj. 
\q1 Quipantía miyac paquilistli ipan catli mochiyaj ipan ya iteicnelilis. 
\q1  
\v 12 Nochi amojuanti ipan ni altepetl Jerusalén, 
\q1 xijhueyimatica TOTECO. 
\q1 Quena, nochi catli itztoque ipan tepetl Sion, 
\q1 xijpaquilismaca amoDios. 
\q1  
\v 13 Pampa yaya cuali quitzactoc ipuertas amoaltepe para amo hueli quitlapos niyon se amocualancaitaca. 
\q1 Huan yaya tlahuel quintiochijtoc amoconehua. 
\q1  
\v 14 Yaya quititlanis tlasehuilistli ipan nochi amotlal, 
\q1 huan anmechmacas trigo catli más cuali para ica ximopanoltica. 
\q1  
\v 15 Yaya quintitlanis itlanahuatilhua ipan nochi tlaltipactli. 
\q1 Huan quema yaya camanaltis, 
\q1 icamanal nimantzi ajsis hasta campa hueli techaj. 
\q1  
\v 16 Yaya quichihuas ma huetzi sitlal setl catli chipahuac quen nextli. 
\q1 Huan quisemanas setl iixpa tlali hasta campa hueli. 
\q1  
\v 17 ¿Ajqueya hueli quiijiyohuis nopa tlasesecayotl? 
\q1  
\v 18 Pero teipa yaya quinahuatis ma huala tlatotonilotl huan atiyas nopa setl. 
\q1 Quichihuas ma pehua tlaajacas huan nopa atl catli mochijqui setl ipan atlajtli sempa motlalos. 
\q1  
\v 19 Yaya quinmacac israelitame itlanahuatilhua, 
\q1 huan quinilhuijtoc nochi catli cuali ma quichihuaca ipan inialtepe, 
\q1 para tetlajtolsencahuase xitlahuac. 
\q1  
\v 20 TOTECO amo quinchihuilijtoc ni tlamantli masehualme ipan sequinoc tlalme. 
\q1 Inijuanti ayamo quiiximatij itlanahuatilhua, pero tojuanti, quena. 
\q1 ¡Paquilistli! 
\c 148  
\s1 Ma quihueyimatica Toteco nochi tlamantli catli yaya quisencajtoc 
\q1  
\v 1 ¡Ma quipaquilismacaca TOTECO nochime catli itztoque ipan ilhuicactli! 
\q1 Quena, tlen ajacatipa xijpaquilismacaca TOTECO. 
\q1  
\v 2 Nochi amojuanti anitequihuajcahua, 
\q1 xijpaquilismacaca TOTECO. 
\q1 Quena, xijpaquilismacaca nochi amojuanti catli anquitequipanohuaj nepa ilhuicac. 
\q1  
\v 3 Ma quipaquilismacaca tonati huan metztli. 
\q1 Ma quipaquilismacaca nochi nopa sitlalime catli yejyectzi tlahuíaj. 
\q1  
\v 4 Ma quipaquilismacaca nopa ilhuicactli catli eltoc más huejcapa, 
\q1 huan nopa apoctli catli mopantía ajacatipa. 
\q1  
\v 5 Xijpaquilismacaca TOTECO pampa yaya camanaltic huan mochijqui catli ama onca. 
\q1  
\v 6 Yaya quinchijqui para eltose para nochipa, 
\q1 huan quichijqui se tlanahuatili catli ica amo quema moyolcuepas. 
\q1  
\v 7 Ma quipaquilismacaca TOTECO nochi catli itztoque ipan ni tlaltipactli. 
\q1 Ma quipaquilismacaca nopa huejhueyi tlapiyalme catli itztoque tlatzintla hueyi atl. 
\q1  
\v 8 Ma quipaquilismacaca nopa tlitl, tesihuitl, setl, apoctli, 
\q1 huan nopa ajacatl catli quichihuaj ipaquilis. 
\q1  
\v 9 Ma quipaquilismacaca nochi tepeme, tlachiquilme, 
\q1 huan nochi cuame catli temacaj inintlajca huan nochi tiocuame. 
\q1  
\v 10 Ma quipaquilismacaca TOTECO nochi tlamantli tlapiyalme, 
\q1 huan nochi tecuanime, cohuame, huan totome. 
\q1  
\v 11 Ma quipaquilismacaca nochi tlanahuatiani catli itztoque ipan tlaltipactli, 
\q1 huan nochi jueces, 
\q1 huan nochi masehualme ipan nochi tlalme. 
\q1  
\v 12 Ma quipaquilismacaca telpocame, ichpocame, huehuentzitzi huan coneme. 
\q1  
\v 13 Ma quipaquilismacaca TOTECO pampa san yaya quinamiqui tijhueyimatise. 
\q1 Ihueyitilis nelhueyi hasta quipano ilhuicactli huan tlaltipactli. 
\q1  
\v 14 Yaya quinfuerzajmacatoc imasehualhua. 
\q1 Ma quipaquilismacaca TOTECO nochi itlatzejtzeloltijca masehualhua, 
\q1 nochi tojuanti catli tiisraelitame catli yaya techiyocatlalijtoc para ma tiitztoca más inechca. 
\q1 ¡Xijpaquilismacaca TOTECO! 
\c 149  
\s1 Nochime ma quipaquilismacaca Toteco 
\q1  
\v 1 Xijpaquilismacaca TOTECO. 
\q1 Xihuicaca para TOTECO se huicatl yancuic. 
\q1 Nochi amojuanti animasehualhua, 
\q1 xijhuicatica Toteco por nochi catli quichijtoc. 
\q1  
\v 2 Anisraelitame, ximopaquilismacaca ipan Toteco pampa yaya anmechchijchijqui. 
\q1 Anmasehualme ipan altepetl Jerusalén, 
\q1 ximopaquilismacaca ipan amotlanahuatijca. 
\q1  
\v 3 Xijpaquilismacaca TOTECO ica mijtotilistli. 
\q1 Huan xihuicaca ica pandero huan ica arpa. 
\q1  
\v 4 Pampa Toteco quipantía paquilistli ipan imasehualhua, 
\q1 huan quinmaquixtía catli moechcapanohuaj iixpa. 
\q1  
\v 5 Nochi catli iaxcahua TOTECO ma paquica pampa yaya tlahuel hueyi ihueyitilis. 
\q1 Huan hasta quema ya motectoque ipan inintlapech noja ma quihuicatica. 
\q1  
\v 6 Ma quihueyitlalica TOTECO nochi imasehualhua. 
\q1 Quipixtoc ipan imax se machete catli oncac tlatequi, 
\q1  
\v 7 para ica quincuepilis nopa sequinoc tlalme catli quinchihuilijque catli amo cuali, 
\q1 huan para ica quintlatzacuiltis. 
\q1  
\v 8 Ma quinilpica inintlanahuatijcahua huan inintlayacancahua ica tepos cadena, 
\q1  
\v 9 para quiselise nopa tlatzacuiltili catli ya eltoc tlasencahuali. 
\q1 Huan ica ni TOTECO quinhueyitlalis nochi itlatzejtzeloltijca masehualhua. 
\q1 ¡Ma nochi quipaquilismacaca TOTECO! 
\c 150  
\s1 Xijpaquilismacaca Toteco ica miyac tlamantli tepos tlatzotzonali 
\q1  
\v 1 ¡Xijpaquilismacaca TOTECO! 
\q1 Xijpaquilismacaca TOTECO ipan itiopa. 
\q1 Xijpaquilismacaca nepa ipan ilhuicac catli yaya quichijchijqui ica ihueyi chicahualis. 
\q1  
\v 2 Xijpaquilismacaca por nochi nopa huejhueyi tlamantli catli yaya quichihua. 
\q1 Xijpaquilismacaca pampa tlahuel hueyi ichicahualis. 
\q1  
\v 3 Xijpaquilismacaca ica tlapitzali, 
\q1 Xijpaquilismacaca ica guitarra huan ica arpa. 
\q1  
\v 4 Xijpaquilismacaca ica panderos huan ximijtotica. 
\q1 Xijpaquilismacaca ica nochi tlamantli tlatzotzonali catli quipiyaj cuerdas, 
\q1 huan ica acatlapitzali. 
\q1  
\v 5 Xijpaquilismacaca ica platillos catli yejyectzi tzilinij. 
\q1  
\v 6 Nochi catli yoltoque ma quipaquilismacaca TOTECO. 
\q1 ¡Xijpaquilismacaca!