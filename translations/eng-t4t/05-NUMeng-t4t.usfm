\p 
\v 19 ‘\w The|strong="H5921"\w* meat \w from|strong="H4480"\w* \w the|strong="H5921"\w* ram’s \w shoulder|strong="H2220"\w* \w must|strong="H3947"\w* \w be|strong="H5414"\w* \w boiled|strong="H1311"\w*. \w After|strong="H4480"\w* \w it|strong="H5414"\w* \w is|strong="H2220"\w* cooked, \w the|strong="H5921"\w* \w priest|strong="H3548"\w* \w will|strong="H5414"\w* \w take|strong="H3947"\w* \w it|strong="H5414"\w* \w along|strong="H5921"\w* \w with|strong="H5921"\w* \w one|strong="H4480"\w* \w of|strong="H4480"\w* \w the|strong="H5921"\w* \w loaves|strong="H2471"\w* \w of|strong="H4480"\w* \w bread|strong="H4682"\w* \w and|strong="H3548"\w* \w one|strong="H4480"\w* \w wafer|strong="H7550"\w* \w which|strong="H3548"\w* \w has|strong="H3548"\w* been brushed \w with|strong="H5921"\w* \add olive\add* oil, \w and|strong="H3548"\w* \w he|strong="H4480"\w* \w will|strong="H5414"\w* \w put|strong="H5414"\w* \w them|strong="H5414"\w* \w in|strong="H5921"\w* \w your|strong="H5414"\w* \w hands|strong="H3709"\w*.
\v 20 \w Then|strong="H5130"\w* \w the|strong="H6440"\w* \w priest|strong="H3548"\w* \w will|strong="H3068"\w* \add take them back and\add* \w lift|strong="H3068"\w* \w them|strong="H5921"\w* \w up|strong="H5921"\w* high \w to|strong="H3068"\w* dedicate \w them|strong="H5921"\w* \w to|strong="H3068"\w* \w me|strong="H6440"\w*. \w They|strong="H3068"\w* \w now|strong="H5921"\w* belong \w to|strong="H3068"\w* \w the|strong="H6440"\w* \w priest|strong="H3548"\w*, \w and|strong="H3068"\w* \w he|strong="H1931"\w* \w is|strong="H3068"\w* permitted \w to|strong="H3068"\w* eat some \w of|strong="H3068"\w* \w the|strong="H6440"\w* meat \w from|strong="H6440"\w* \w the|strong="H6440"\w* ram’s \w shoulder|strong="H7785"\w* \w and|strong="H3068"\w* \w from|strong="H6440"\w* \w its|strong="H5921"\w* ribs \w and|strong="H3068"\w* \w from|strong="H6440"\w* \w one|strong="H1931"\w* \w of|strong="H3068"\w* \w its|strong="H5921"\w* thighs, \w because|strong="H5921"\w* \w that|strong="H1931"\w* meat \w is|strong="H3068"\w* \w his|strong="H3068"\w* share \w of|strong="H3068"\w* \w the|strong="H6440"\w* sacrifice. \w After|strong="H5921"\w* \w that|strong="H1931"\w*, \w you|strong="H6440"\w* \w will|strong="H3068"\w* \w no|strong="H8354"\w* longer \w be|strong="H3068"\w* \w a|strong="H3068"\w* Nazir-man, \w and|strong="H3068"\w* \w you|strong="H6440"\w* \w will|strong="H3068"\w* \w again|strong="H6440"\w* \w be|strong="H3068"\w* permitted \w to|strong="H3068"\w* \w drink|strong="H8354"\w* \w wine|strong="H3196"\w*.
\p 
\v 21 ‘\w Those|strong="H5921"\w* \w are|strong="H3027"\w* \w the|strong="H5921"\w* regulations \w about|strong="H5921"\w* \w the|strong="H5921"\w* \w offerings|strong="H5088"\w* \w that|strong="H3068"\w* Nazir-men solemnly \w promise|strong="H3068"\w* \w to|strong="H3068"\w* \w bring|strong="H6213"\w* \w to|strong="H3068"\w* \w me|strong="H5921"\w* \w to|strong="H3068"\w* \w end|strong="H6310"\w* \w their|strong="H3068"\w* \w time|strong="H5921"\w* \w of|strong="H3068"\w* \w being|strong="H3068"\w* \w dedicated|strong="H5145"\w* \w to|strong="H3068"\w* \w me|strong="H5921"\w*. \w They|strong="H3651"\w* must \w bring|strong="H6213"\w* \w these|strong="H2063"\w* \w offerings|strong="H5088"\w*, \w but|strong="H3651"\w* \w if|strong="H3651"\w* \w they|strong="H3651"\w* want \w to|strong="H3068"\w*, \w they|strong="H3651"\w* \w may|strong="H3068"\w* \w bring|strong="H6213"\w* additional \w offerings|strong="H5088"\w*. \w And|strong="H3068"\w* \w they|strong="H3651"\w* must \w do|strong="H6213"\w* everything \w that|strong="H3068"\w* \w they|strong="H3651"\w* solemnly \w promised|strong="H5087"\w* \w to|strong="H3068"\w* \w do|strong="H6213"\w* \w when|strong="H6213"\w* \w they|strong="H3651"\w* \w dedicated|strong="H5145"\w* \w themselves|strong="H6213"\w* \w to|strong="H3068"\w* \w me|strong="H5921"\w*.’”
\s1 The blessing for the people
\p 
\v 22 \w Yahweh|strong="H3068"\w* \w also|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*,
