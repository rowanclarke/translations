\id HAB - Guajajara Bible -Brazil 2007 (DBL 2013)
\h AMAKUK
\toc1 Amakuk
\toc2 Habacuque
\toc3 Hc
\mt1 AMAKUK
\c 1
\p 
\v 1 Tupàn umume'u ma'e Amakuk pe ipuahu zàwenugar hexak kar pà izupe a'e.
\s1 Amakuk ize'eze'eg awer a'e
\q1 
\v 2 O Tupàn Tuweharupi Wiko Ma'e.
\q1 Tuweharupi aze'eg newe urepytywà àwàm henoz pà newe.
\q1 Aipo nereinu kwaw heze'eg.
\q1 Màràn mehe urepytywà putar nehe. — Puruzuka haw, a'e newe tuweharupi.
\q1 Màràzàwe na'urepyro kwaw pe nehe.
\q1 
\v 3 Màràzàwe tuwe erexak kar ikatu 'ym ma'e tetea'u ihewe.
\q1 Màràzàwe tuwe nerezekaiw kwaw ikatu 'ym ma'e iapo haw rehe.
\q1 Ma'emumaw paw umàmàn wà heywyr. Puruzuka haw umàmàn wà heywyr no.
\q1 Taw nànàn teko uzeàmàtyry'ym wà. Heta zeàmàtyry'ymaw ywy nànàn.
\q1 
\v 4 A'e rupi ni amo teko nuweruzar kwaw neze'eg wà.
\q1 Ikatu haw nuweityk pixik kwaw ikatu 'ymaw.
\q1 Ikatu 'ym ma'e ikàg wera'u ikatu ma'e wanuwi wà.
\q1 Umuaiw ikatu haw wà.
\s1 Tupàn uwazar Amakuk ize'eg izupe
\q1 
\v 5 Tupàn Tuweharupi Wiko Ma'e uze'eg wemiaihu wanupe.
\q1 — Peme'e teko ywy peiwyr huwake har wanehe nehe. Pepytuhegatu pezemukuhem wanexak mehe nehe no.
\q1 Ta'e napezeruzar kwaw heremiapo ràm
\q1 ko 'ar rehe har rehe nehe xe.
\q1 Aze mo amo umume'u peme wà, nezewe rehe we napezeruzar iwer mo waze'eg rehe.
\q1 
\v 6 Amuryryw kar Mawiron pe har wanereko ihe wà kury.
\q1 Teko puruzuka ma'e romo wanekon wà. Upuraraw kar ma'erahy amo teko wanupe wà.
\q1 Wyzài 'ar mehe iporomono wer zauxiapekwer wanehe ywy nànàn wà,
\q1 amo teko waiwy ipyro pà uzeupe wà.
\b
\q1 
\v 7 Teko ywy nànànar ukyze katu wanuwi wà. Ukyze katu wera'u wanuwi wà.
\q1 Weruzar kar uze'eg teko paw wanupe wà. Uzapo kar ma'e amo wanupe uze'eg rupi katete wà.
\q1 
\v 8 Waneimaw kawaru uzàn wera'u zàwàruhu ereopar her ma'e wanuwi wà.
\q1 Hehaite wera'u awarahu ywyxiguhu pe har wanuwi wà.
\q1 Zauxiapekwer kawaru ku'az har ur waiko weimaw waku'az wà.
\q1 Uzàn wà waiko muite wi wà.
\q1 Na'arewahy wiràhu u'ar wemiar rehe.
\q1 Na'arewahy zauxiapekwer ur wiràhu ài wà.
\q1 
\v 9 Zauxiapekwer ur waiko wà.
\q1 Ipuruzuka wer wàmàtyry'ymar wanehe na'arewahy wà.
\q1 Wanur mehe umuhàmuhàz kyze haw oho waiko wà.
\q1 Heta tetea'u wanemipyhyk kwer wà.
\q1 Waneta haw nuzawy kwaw ywyxiguhu yryhu izywyr har waneta haw wà.
\q1 
\v 10 Zauxiapekwer Mawiron pe har uze'eg urywahyahy tuwihawete wanehe wà.
\q1 Uze'eg zemueteahy amogwer tuwihaw wanehe wà no.
\q1 Upuka tàpuzuhutàtà rehe wà.
\q1 Uzapo uzeupir àwàm tawhu pàrirogaw rehe har wà. Wixe tawhu pupe ipyro pà wà.
\q1 
\v 11 A'e re oho wi uzenataromo amo tawhu pe wà no. Nuzawy kwaw ywytu kwe rupi ukwaw ma'e wà.
\q1 Numuwete katu kwaw amo tupàn wà. Xo ukàgaw zo umuwete katu wà.
\s1 Amakuk uze'eze'eg wi no
\q1 
\v 12 O Tupàn Tuweharupi Wiko Ma'e. Tuweharupi ereikuwe ne.
\q1 O hezar ikatuahy ma'e. Neremàno pixik kwaw nehe.
\q1 Ereiko urepyro har romo. O Tupàn Tuweharupi Wiko Ma'e.
\q1 Erexarexak Mawiron pe har ne wà.
\q1 Eremono nekàgaw wanupe. A'e rupi upuner urerehe uzepykaw rehe wà nehe.
\q1 
\v 13 Màràzàwe tuwe nerezuka kwaw a'e teko ne wà. Hemu'em teko wanupe wazuka pà wà. Iaiw ma'e romo wanekon wà.
\q1 Nereha ikatuahy. Màràzàwe tuwe ereme'e agwer iaiw ma'e rehe.
\q1 Aze erexak teko ikatu 'ym ma'e iapo mehe wà, erekwahy wanehe ne.
\q1 A'e rupi apuranu nerehe kury. Mawiron pe har uzuka amo teko uzewi ikatu wera'u ma'e wà.
\q1 Màràzàwe tuwe nereze'eg kwaw wazuka mehe ne.
\q1 
\v 14 Màràzàwe tuwe erereko teko pira zàwe ne wà.
\q1 Nuzawy kwaw ma'ea'yr uzehe uzekaiw 'ym ma'e wà.
\b
\q1 
\v 15 Mawiron pe har upyhyk amo teko wà.
\q1 Wapyhykaw nuzawy kwaw ipira pyhykaw wanupe.
\q1 Upurupyhyk upina pupe ukyhapari pupe wà.
\q1 Wenuhem 'y wi katu pe wà.
\q1 Hurywete Mawiron a'e pe wà. — Ikatuahy aipo pa, i'i uzeupeupe wà.
\q1 
\v 16 Wakyhapari nuzawy kwaw tupàn a'ua'u wanupe wà. Uzuka ma'ea'yr wanenataromo wà.
\q1 Omono imono pyr upina pe wà no.
\q1 Ta'e a'e ma'e umuigo kar pira pyhykar hemetarer katu ma'e romo a'e wà xe.
\q1 A'e rupi heta tetea'u wanemi'u ràm wanupe.
\q1 
\v 17 Aipo Mawiron pe har nupytu'u pixik kwaw amo teko wàmàtyry'ym ire wà nehe.
\q1 Aipo uzuka wiwi putar teko wà nehe, wapuhareko 'ym pà wà nehe.
\c 2
\s1 Tupàn uwazar wi Amakuk ize'eg izupe no
\p 
\v 1 Azeupir putar heràpuz aiha katu ma'e rehe heme'e haw pe ihe nehe. Àro putar Tupàn ze'eg àwàm ihe nehe. Ma'in putar hepuranu haw iwazar pà nehe. Azeapyaka katu putar nehe.
\q1 
\v 2 Na'e Tupàn Tuweharupi Wiko Ma'e uze'eg wà ihewe. Nezewe ize'eg awer.
\b
\q1 — Erexak putar ma'e nepuahu zàwenugar nehe.
\q1 Emuapyk a'e neremixak kwer ywyrapewa'i rehe nehe. Emuapyk katu newe ma'e heremixak kar ràm nehe.
\q1 Nezewe mehe wyzài teko upuner imugeta haw rehe wà nehe.
\q1 
\v 3 A'e ma'e neremixak ràm 'ar
\q1 nuhem kwaw a'e rihi.
\q1 Uhem putar azeharomoete nehe. Uzeapo putar nehe.
\q1 I'ar katu uhem etea'i kury.
\q1 A'e rupi — Kwa, iàrew tetea'u tur àwàm, aze ere izupe nehe, eàro nehe.
\q1 Ta'e a'e ma'e uzeapo putar i'ar kateteahy rehe a'e nehe xe.
\q1 
\v 4 Nezewe heze'eg newe heremimume'u ràm xe kury.
\q1 — Ikatu 'ym ma'e waneko haw na'ikatuahy kwaw.
\q1 Ikatu ma'e iapo har wikuwe putar wà nehe, ta'e uzeruzar tuwe Tupàn rehe wà xe.
\s1 Mawiron pe har wanehe uzepyk àwàm
\p 
\v 5 Azeharomoete teko wanemetarer hemu'em uzar pe. Na'ikatu kwaw wiko wera'u ma'e waneko haw. Nupaw kwaw temetarer iputar haw. — Aputar we amo ihe, i'i uzeupeupe tuweharupi wà. Tuweharupi umàno ma'e kwer waneta haw uputar amo umàno ma'e kwer wà. Nezewegatete a'e teko uputar amo temetarer tuweharupi wà.
\v 6 Teko heityk pyrer a'e wà, uze'eg zemueteahy Mawiron pe har wanehe wà. Uze'eg urywahyahy wanehe wà no. Nezewe uze'eg wanupe wà. — Pezeapo hemetarer katu ma'e romo amo teko wama'e ipyro pà. Pezemumikahy nehe. Aze penewer amo temetarer rehe amo pe, pemekuzar kar penewer haw amo ae pe. Màràn kwarahy pemumaw putar agwer ma'e iapo pà nehe, i'i wanupe wà.
\p 
\v 7 Pe Mawiron pe har pe. Na'arewahy peiko putar unewer ma'e romo nehe. Na'e wemetarer imur arer uze'eg putar peme wà nehe. — Pemekuzar putar penewer haw temetarer imemyr inuromo nehe, i'i putar peme wà nehe. Peàmàtyry'ym putar a'e wà nehe. Pekyze putar wanuwi nehe. Weraha putar pema'e paw pewi a'e wà nehe.
\v 8 Pemunar tetea'u ywy rehe har wama'e rehe. Na'arewahy uzapo putar nezewegatete haw peme a'e wà nehe no. Pemekuzar putar pemunar awer nehe, pepuruzuka awer nehe no. Peityk tawhu tetea'u wanehe har wama'e paw heraha pà. Pemekuzar putar penemiapo kwer nehe kury.
\p 
\v 9 Pezemumikahy nehe, Mawiron puruzuka ma'e. Pemynehem penàpuz amogwer wama'e penemiraha kwer pupe. — Zaiko hemetarer katu ma'e romo kury. A'e rupi nuzeapo kwaw ikatu 'ym ma'e zanewe nehe. Zapuner zazepyro haw rehe zaneàmàtyry'ymar wanuwi nehe, peze zepe peiko.
\v 10 Penemiapo kwer werur maranugar haw peànàm wanupe. Pezuka teko tetea'u pe wà. A'e rupi pemàno putar nehe kury.
\v 11 Te ita penàpuz ywyok rehe har a'e wà, te ywyra penàpuz izita a'e wà no, uhapukaz pekutyr peaiw paw imume'u pà wà.
\p 
\v 12 Pezemumikahy nehe. Ta'e pezapo tawhu peneko haw puruzuka haw i'aromo xe, purehe imunar haw i'aromo no xe.
\v 13 Pemuma'erekoahy e kar teko penemipyhyk kwer paw pe wà. Uzapo tàpuz tetea'u peme wà. Uzapo tawhu peme wà no. Nezewe rehe we tata wapy putar wanemiapo kwer nehe. Ukaz paw putar nehe. Tupàn Tuweharupi Wiko Ma'e ikàg wera'u ma'e wiko a'e ma'e iapo àràm romo a'e.
\v 14 Yryhu tynehem 'y pupe. Nezewegatete ywy tynehem putar Tupàn ikàgaw ikwaw paw pupe nehe, ipuràg eteahy haw ikwaw paw pupe nehe no.
\p 
\v 15 Ezemumikahy nehe. Emono muhàg win inuromo har nerehe we har pe nehe. Uka'u putar nehe. Wenuhem putar wemyhar. Teko paw wexak putar ima'e 'ym mehe wà nehe.
\v 16 Ne ae ereityk putar nezemuawate katu kar haw nehe. Maranugar haw nepyk putar nehe. Tupàn ikwahy haw nuzawy kwaw kanek por. U'u kar putar ipor newe nehe. Ereka'u putar ne nehe no. Teko nuze'egatu kwaw nerehe wà nehe. — Iaiw ma'e, i'i putar newe wà nehe.
\v 17 Eremonohok ywyra ywytyr apyr Irimano rehe har ne. A'e rupi amo nemumaw putar nehe kury. Erezuka ma'ea'yr tetea'u wà. A'e rupi ko 'ar rehe erekyze putar ma'ea'yr wanuwi nehe no. Agwer ma'e uzeapo putar wà nehe, ta'e erezapo ikatu 'ym ma'e tetea'u teko ywy nànànar wanupe xe. Ta'e erezuka ywy nànànar tetea'u ne wà xe.
\p 
\v 18 Aipo tupàn ua'u hagapaw ikàg a'e. Nan. Awa uzapo a'e hagapaw opo pupe. Xo purupe temu'emaw romo zo hekon a'e. Nupuner kwaw uze'egaw rehe. Màràzàwe tuwe amo teko uzeruzar amo ma'e wemiapo kwer rehe.
\v 19 — Eme'e ty, aze ere hagapaw pe nehe, erezemumikahy putar nehe. — Epu'àm ty, aze ere izupe, erezemumikahy putar nehe. Aipo tupàn a'ua'u hagapaw upuner amo ze'eg herur haw rehe purupe. Nupuner kwaw. Iapo har uzàpewàn tupàn ua'u or pupe a'e, parat pupe a'e no. Nezewe rehe we nuikuwe pixik kwaw nehe.
\p 
\v 20 Tupàn Tuweharupi Wiko Ma'e wiko wàpuzuhu ikatuahy ma'e pupe. Tuwe teko paw upytu'u uze'eg ire henataromo wà nehe.
\c 3
\s1 Amakuk uze'eg Tupàn pe kury
\q1 
\v 1 Tupàn ze'eg imume'u har Amakuk her ma'e uze'eg putar Tupàn pe kury. Na'aw ize'eg awer xe kury.
\q1 
\v 2 — O Tupàn Tuweharupi Wiko Ma'e. Teko umume'u neremiapo kwer ihewe wà.
\q1 Akyze katu teko ihe kury.
\q1 Kwehe mehe erezapo purumupytuhegatu kar haw. Ezapo wi agwer ma'e ko 'ar rehe nehe kury.
\q1 Nezewe mehe urupuner putar hexakaw rehe ure nehe no.
\q1 Erekwahy iko ne.
\q1 Nezewe rehe we urepuhareko pe nehe.
\q1 
\v 3 Tupàn ur iko Enom ywy wi. Tupàn Ikatuahy Ma'e ur iko Pàrà ywytyr wi. Ikàgaw uhyape katu ma'e upyk ywak a'e. Ywy rehe har paw umume'u ikatu haw wà.
\b
\q1 
\v 4 Heny katu tatainy ài.
\q1 Tatainy uhyape katu ipo rehe.
\q1 Ma'e pe teko uzeàmim putar ikàgaw wi wà. A'e ipo rehe uzeàmim ikàgaw a'e.
\q1 
\v 5 Ma'erahy ipuraraw paw oho waiko henataromo wà.
\q1 Ma'eahy haw puruzuka ma'e ur waiko haikweromo wà.
\q1 
\v 6 Aze upytu'u, ywy uryryryryz a'e.
\q1 Ume'e teko ywy nànànar wanehe. Ukyze katu a'e teko a'e mehe wà.
\q1 Ywytyr kwehe arer otohotohog wà.
\q1 Ywytyruhu kwehe arer u'au'ar wà.
\q1 Izypy mehe arer we Tupàn wata a'e ywytyruhu rehe.
\q1 
\v 7 Aexak teko Kuxà ywy rehe har wazeputupytupykahy mehe ihe wà.
\q1 Aexak teko Minià ywy rehe har wakyze katu mehe ihe wà no.
\b
\q1 
\v 8 Aipo erekwahy yrykawhu wanupe, Tupàn Tuweharupi Wiko Ma'e.
\q1 Aipo erekwahy yryhu wanupe.
\q1 Aipo a'e rupi erezur nereimaw kawaru waku'az wà.
\q1 Aipo a'e rupi erezur neàmàtyry'ymar waneityk arer romo ywyramawa pupe.
\q1 
\v 9 Erepyhyk newyrapar.
\q1 Erezemuàgà'ym neru'yw imomor àwàm rehe.
\q1 Ereywykàz ywy 'y tetea'u uwyryk ma'e pupe.
\q1 
\v 10 Ywytyruhu nerexak wà. Na'e uryryryryz wà.
\q1 U'ar amo 'y tyapu ma'e ywak wi.
\q1 'Y ywy iwype har okororo wà.
\q1 'Ykotok aiha katu ma'e upu'àm wà.
\q1 
\v 11 Kwarahy a'e, zahy a'e no, upytu'u uhyape katu re wà,
\q1 neru'yw heny katu haw hexak mehe wà,
\q1 nepurukutukaw heny katu haw hexak mehe wà.
\q1 
\v 12 Nekwahy mehe ereata ywy nànàn.
\q1 Nekwahy mehe erepyrog teko ywy nànànar wanehe.
\q1 
\v 13 Erehem eho nereko haw wi neremiaihu wapyro pà,
\q1 tuwihawete neremixak kwer ipyro pà no.
\q1 Erekutuk ikatu 'ym ma'e wanuwihawete.
\q1 Eremumaw hehe we har zauxiapekwer paw wà no.
\q1 
\v 14 Ur ywytuàiw àmàn inuromo har ài ureàmàtyry'ym pà wà.
\q1 Erezuka zauxiapekwer wanuwihaw neru'yw pupe wanur mehe wà.
\q1 Wiko wera'u urewi wà, a'e rupi ipuruzuka wer urerehe wà.
\q1 Ikàg ma'e uzuka hemetarer 'ym ma'e, muite amogwer teko wanuwi ikwaw kar 'ym pà wanupe. Nezewe a'e zauxiapekwer ipuruzuka wer urerehe wà.
\q1 
\v 15 Ereapyk nereimaw kawaru waku'az ne, yryhu rehe neata pà ne.
\q1 Ykotok hehaite ma'e rehe ereata.
\q1 
\v 16 A'e ma'e henu mehe hepytuhegatu ihe.
\q1 Hereme uryryryryz hekyze mehe ihe.
\q1 Hekàgaw uhem ihewi.
\q1 Napuner kwaw hepy rehe hepu'àmaw rehe kury.
\q1 Nezewe rehe we àro putar Tupàn 'ar hezemumik 'ym pà nehe.
\q1 A'e 'ar mehe uzepyk putar ureàmàtyry'ymar wanehe nehe.
\q1 
\v 17 Aze pi 'yw na'i'a kwaw nehe,
\q1 aze uwà 'yw na'i'a kwaw nehe,
\q1 aze naheta kwaw uri ipo'o pyràm nehe,
\q1 Aze naheta kwaw arozràn ipo'o pyràm nehe,
\q1 aze naheta kwaw àràpuhàràn ka'api'i pe wà nehe,
\q1 aze naheta kwaw tapi'ak pari pupe wà nehe,
\q1 
\v 18 Nezewe rehe we amume'u putar Tupàn Tuweharupi Wiko Ma'e ikatu haw izupe nehe.
\q1 Herurywete putar Tupàn hepyro har rehe nehe.
\q1 
\v 19 Tupàn Tuweharupi Wiko Ma'e hezar wiko hekàgaw romo.
\q1 Hemuata katu kar arapuha ka'a pe har hehaite ma'e ài hemuigo kar pà.
\q1 Hereraha putar ywytyruhu rehe nehe.
\q1 Ikatuahy putar hereko àwàm a'e pe nehe.
\p Upaw kwez kury. 
