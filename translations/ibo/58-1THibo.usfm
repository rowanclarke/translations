\id 1TH - Biblica® Open Igbo Contemporary Bible 2020
\h 1 Ndị Tesalonaịka
\toc1 1 Ndị Tesalonaịka
\toc2 1 Ndị Tesalonaịka
\toc3 1Te
\mt1 1 Ndị Tesalonaịka
\c 1
\p 
\v 1 Akwụkwọ ozi a si nʼaka Pọl, Saịlas\f + \fr 1:1 \ft Nʼasụsụ Griik \fqa Silvenọs \ft bụ otu ọzọ e si akpọ \fq Saịlas.\f* na Timoti.
\b
\p Na-abịara nzukọ dị na Tesalonaịka, ndị e jikọtara ha na Chineke Nna, na Onyenwe anyị Jisọs Kraịst.
\b
\p Ka amara na udo dịrị unu.
\b
\s1 Inye ekele nʼihi okwukwe ndị Tesalonaịka
\p 
\v 2 Anyị na-ekele Chineke ekele mgbe niile, na-echetakwa unu nʼekpere anyị.
\v 3 Mgbe niile ka anyị na-echeta nʼekpere nye Chineke bụ Nna, ihe gbasara ọrụ unu nke sitere nʼokwukwe, ya na ịrụsị ọrụ ike unu nke sitere nʼịhụnanya, na iguzosi ike unu nke sitere nʼolileanya unu nwere nʼOnyenwe anyị Jisọs Kraịst.
\p 
\v 4 Ụmụnna anyị, anyị maara na Chineke hụrụ unu nʼanya nke ukwuu, họpụta unu.
\v 5 Nʼihi na ọbụghị naanị nke okwu ọnụ ka oziọma anyị rutere unu, kama ọ bụkwa nʼike, na nʼime Mmụọ Nsọ nakwa mmetụta nke dị omimi. Unu maara ụdị ndụ\f + \fr 1:5 \ft Ụdị mmadụ anyị bụ nʼetiti unu\f* anyị biri nʼetiti unu nʼihi unu.
\v 6 Nke a mere unu ji bụrụ ndị na-eṅomi anyị na Onyenwe anyị. Nʼihi na unu jiri ọṅụ nke Mmụọ Nsọ na-enye nabata oziọma ahụ, nʼagbanyeghị ọtụtụ ahụhụ dị ukwuu nke o wetaara unu.
\v 7 Nʼụzọ dị otu a, unu ghọrọ ihe ilere anya nye ndị niile kwere ekwe nọ na Masidonia na Akaịa.\f + \fr 1:7 \ft Akaịa bụkwa Griis.\f*
\v 8 Ugbu a, e sitela na ndụ unu mee ka oziọma Onyenwe anyị gbasaa gabiga Masidonia na Akaịa. Nʼihi na a na-anụ ihe banyere okwukwe unu nwere na Chineke nʼebe niile. Ya mere, ọ dịkwaghị mkpa ka anyị kwuo ihe banyere ya.
\v 9 Nʼihi na ha onwe ha na-ebu ụzọ gwa anyị ihe banyere nnabata unu nabatara anyị, na otu unu si site nʼikpere arụsị tụgharịa, bido ife Chineke dị ndụ, onye bụkwa ezi Chineke,
\v 10 na i chere Ọkpara ya onye ga-esi nʼeluigwe, onye o sitere na ndị nwụrụ anwụ kulite, Jisọs, onye na-anapụta anyị nʼiwe nke na-abịa.
\c 2
\s1 Ọrụ Pọl rụrụ na Tesalonaịka
\p 
\v 1 Unu onwe unu maara, ụmụnna, na ọbịbịa anyị bịakwutere unu abụghị ihe lara nʼiyi.
\v 2 Anyị tara ahụhụ na mbụ e mekwara anyị ihe ihere na Filipai dịka unu maara, ma site nʼinyeaka Chineke anyị nwere obi ike ịgwa unu oziọma ya, ọ bụladị mgbe a na-eguzogide anyị nʼebe ọ dị ukwuu.
\v 3 Nʼihi na arịrịọ anyị na-arịọ unu esiteghị na njehie pụta maọbụ nʼọchịchọ nke na-adịghị ọcha ma ọ bụkwanụ nʼaghụghọ.
\v 4 Nʼaka nke ọzọ, anyị na-ekwu okwu dị ka ndị ozi Chineke nwapụtara, ndị o tinyere ọrụ oziọma a nʼaka na ntụkwasị obi idebe. Anyị adịghị agbalị ime ihe ga-atọ mmadụ ụtọ, kama anyị chọrọ ime ihe ga-atọ Chineke ụtọ, bụ onye na-enyocha echiche obi anyị.
\v 5 Ọ dịghị mgbe ọbụla, dị ka unu maara, anyị kwuru okwu nrafu maọbụ were ụzọ aghụghọ zoo anya ukwu anyị nwere. Chineke bụ onye akaebe anyị.
\v 6 Ọ dịghị mgbe anyị chọrọ ka ndị mmadụ ọbụla maọbụ unu, maọbụ ndị ọzọ, too anyị.
\v 7 Ọ bụ ezie, dị ka ndị ozi Kraịst, anyị gara abụ ibu arụ nye unu.
\p Kama, anyị biri nʼetiti unu site nʼịdị nwayọọ dị ka ndị bụ nne na-azụ ụmụntakịrị ha, na-elekọta ha.
\v 8 Nʼihi na anyị hụrụ unu nʼanya nke ukwuu ruo na ọ bụghị naanị na anyị kwusaara unu oziọma Chineke kama anyị nyekwara unu ndụ anyị. Nʼihi na unu dị anyị nʼobi nke ukwu.
\v 9 Nʼezie ụmụnna m, amaara m na unu ga-echeta otu anyị si rụọ ọrụ hụjuokwa anya nʼetiti unu. Anyị na-arụ ọrụ ehihie na abalị ịhụ na anyị rụtara ego ga-ezuru anyị, nʼihi na anyị achọghị ịbụ oke ibu nye onye ọbụla mgbe anyị na-ezisara unu oziọma Chineke.
\v 10 Unu onwe unu bụkwa ndị akaebe dị ka Chineke si bụrụ onye akaebe, na mmekọrịta anyị na unu bụ ndị kwere ekwe, bụ nwekọrịta dị ọcha na nke ezi omume, na nke ịta ụta ọbụla na-adịghị na ya.
\v 11 Nʼihi na anyị mesoro onye ọbụla nʼime unu dị ka nna si emeso ụmụ nke ya,
\v 12 na-agba unu ume, na-akasị unu obi, na-akwagidekwa unu na unu kwesiri ibi ndụ kwesiri ụmụ Chineke, onye kpọbatara unu nʼime alaeze ya na ebube ya.
\p 
\v 13 Nʼihi nke a, anyị ga-aga nʼihu na-ekele Chineke na-esepụghị aka, nʼihi na mgbe unu nabatara okwu Chineke, bụ nke unu nụrụ nʼọnụ anyị, unu anabataghị ya dị ka okwu mmadụ, kama otu ọ dịkwa nʼeziokwu, ya bụ okwu Chineke, nke na-arụsikwa\f + \fr 2:13 \ft Okwu a na-arụsị ọrụ ike site nʼịgbanwe ndụ ndị mmadụ.\f* ọrụ ike nʼime unu bụ ndị kweere ya.
\v 14 Unu onwe unu, ụmụnna m, ghọọnụ ndị na-eṅomi nzukọ nke Chineke nʼime Kraịst Jisọs, ndị nọ na Judịa. Nʼihi na unu onwe unu hụkwara otu ụdị ahụhụ ahụ nʼaka ndị ala unu, dị ka ha onwe ha hụrụ nʼaka ndị Juu.
\v 15 Ndị gburu ndị amụma, gbukwaa Onyenwe anyị Jisọs. Ugbu a ha na-akpagbukwa anyị na-achụpụ anyị. Ha na-emegide Chineke na mmadụ niile
\v 16 site nʼigbochi anyị izisara ndị mba ọzọ oziọma ka a ghara ịzọpụta ha. Ha na-esite nʼụzọ dị otu a na-eme ka iko mmehie ha na-eju. Ma ikpe Chineke adakwasịlarị ha.
\s1 Nzube Pọl
\p 
\v 17 Otu ọ dị, ụmụnna anyị, mgbe anyị si nʼetiti unu pụọ, nọọ nwa oge nta, ọnọdụ a mere anyị ndị na-enweghị nne na nna (maọbụ na-anụ ahụ ọ bụghị nʼime mmụọ), nʼihi otu unu si gụọ anyị agụụ, anyị gbalịrị ihu unu.
\v 18 Anyị gbalịsịrị ike ịbịakwute unu, karịsịa, mụ onwe m bụ Pọl gbalịrị, gbalịa ịbịa, ma ekwensu gbochiri anyị.
\v 19 Nʼihi na olee ihe bụ olileanya anyị, maọbụ ọṅụ anyị, maọbụ okpueze anyị, nke anyị ga-eji nyaa isi mgbe a ga-eme ka anyị niile guzo nʼihu Onyenwe anyị Jisọs Kraịst, mgbe ọ ga-abịa? Ọ bụ na ọ bụghị unu onwe unu?
\v 20 Nʼezie, unu onwe unu bụ ọṅụ na otuto anyị.
\c 3
\p 
\v 1 Ya mere, mgbe anyị na-apụghị ịnagide ya gaa nʼihu, anyị kpebiri ịnọ naanị anyị nʼAtens.
\v 2 Anyị zipụrụ Timoti, onye bụ nwanna anyị, onye anyị na ya so na-arụrụ Chineke ọrụ site nʼịkwusa oziọma Kraịst, ka ọ bịakwute unu, kasịe unu obi, meekwa ka unu guzosie ike nʼokwukwe unu.
\v 3 Ka unu hapụ ịda mba nʼihi mkpagbu ndị a a na-akpagbu unu. Ma ana m eche na unu onwe unu maara na nke a ga-abụ ihe nketa anyị.
\v 4 Nʼihi na mgbe anyị na unu nọ, anyị buru ụzọ gbaara unu ama na ihe ndị a aghaghị ịbịakwasị unu. Ugbu a, ihe niile emezuola dị ka unu matakwara.
\v 5 Nʼihi nke a, mgbe m hụrụ na m apụghị ịnagide ihe ndị ahụ, eziri m ozi, ka a chọpụta maka okwukwe unu. Nʼihi na ụjọ m bụ ma eleghị anya o nweela ụzọ onye ọnwụnwa ọjọọ ahụ si nwaa unu ọnwụnwa nʼoge a, mee ka ndọgbu niile anyị dọgburu onwe anyị nʼọrụ nʼetiti unu bụrụ ihe lara nʼiyi.
\s1 Ozi agbamume Timoti ji lọta
\p 
\v 6 Ma ugbu a, Timoti esitela nʼebe unu nọ lọghachikwute anyị. O wetara oziọma banyere okwukwe unu na ịhụnanya unu. O mekwara ka anyị mata na unu na-enwe ezi ncheta banyere anyị mgbe niile, na ọ na-agụsị unu agụụ ike ịhụ anyị anya, dị ka o si agụkwa anyị ịhụ unu anya.
\v 7 Nʼihi nke a, ụmụnna anyị, anyị abụrụla ndị a gbara ume nke ukwuu, ọ bụladị nʼime mkpagbu niile nke anyị nọ nʼime ya, nʼihi iguzosi ike nke unu guzoro nʼokwukwe unu.
\v 8 Ugbu a anyị ga-adị ndụ, ma ọ bụrụ na unu eguzosie ike nʼime Onyenwe anyị.
\v 9 Olee ụdị ekele anyị pụrụ ikele Chineke nʼihi akụkọ nyere anyị ọṅụ nʼihu Chineke anyị nʼihi unu.
\v 10 Ehihie na abalị niile, anyị na-arịọ ka anyị hụ unu ihu na ihu, ka anyị nwee ike tinyezuo ihe fọdụrụ nʼokwukwe unu.
\p 
\v 11 Ugbu a, ka Chineke Nna anyị na Onyenwe anyị Jisọs Kraịst megheere anyị ụzọ ịbịakwute unu.
\v 12 Ka Onyenwe anyị meekwa ka unu baa ụba, ka unu babiga ụba oke nʼịhụnanya unu nwere nye ibe unu, na ndị ọzọkwa, dị ka ịhụnanya anyị si dị ukwuu nʼebe unu nọ.
\v 13 Ka ọ mee ka obi unu guzosie ike nʼịdị nsọ, na-enweghị ịta ụta ọbụla, nʼihu Chineke na Nna anyị, nʼọbịbịa nke Onyenwe anyị Jisọs ya na ndị nsọ ya niile.
\c 4
\s1 Ibi ndụ na-atọ Chineke ụtọ
\p 
\v 1 Nʼikpeazụ, ụmụnna anyị, anyị na-arịọ ma na-akwagidekwa unu nʼime Onyenwe anyị Jisọs, dị ka unu mụtara site nʼaka anyị otu unu kwesiri isi bie ndụ, nakwa ime ihe ga-atọ Chineke ụtọ. Unu na-eme nke a karịa.
\v 2 Nʼihi na unu maara ụdị ndụmọdụ ahụ sị nʼaka Onyenwe anyị Jisọs nke anyị nyere unu.
\p 
\v 3 Nʼihi na nke a bụ ọchịchọ Chineke, bụ ị dị nsọ unu. Ka unu wezuga onwe unu site na ịkwa iko,
\v 4 ka onye ọbụla nʼime unu mata ido ahụ nke onwe ya nʼugwu na nʼịdị nsọ.
\v 5 Ọ bụghị nʼụzọ imejupụta ọchịchọ ọjọọ nke anụ ahụ dị ka ndị mba ọzọ na-amaghị Chineke.
\v 6 Ka onye ọbụla ghara imegbu maọbụ ịghọgbu nwanna ya nʼokwu a. Nʼihi na Onyenwe anyị ga-ata onye na-eme ihe dị otu a ahụhụ, dị ka anyị gwara unu na mbụ, na-adọsikwa unu aka na ntị ike.
\v 7 Nʼihi na ọkpụkpọ Chineke kpọrọ anyị abụghị ka anyị na-ebi ndụ adịghị ọcha kama ọ chọrọ ka anyị dịrị nsọ.
\v 8 Ya mere, onye ọbụla nke jụrụ ịnara ntụziaka a, ọ bụghị mmadụ ka ọ jụrụ, kama ọ bụ Chineke onye na-enye unu Mmụọ Nsọ ya.
\p 
\v 9 Ugbu a, ihe gbasara ịhụnanya nke kwesiri ịdị nʼetiti ụmụnna, o kwesighị ka anyị gwa unu ihe ọzọ banyere ya. Nʼihi na unu onwe unu bụ ndị Chineke kuziri ka unu nwee ịhụnanya nʼebe ibe unu nọ.
\v 10 Ma nʼezie, unu na-ahụ ụmụnna anyị niile bi na Masidonia nʼanya. Ma anyị na-arịọsịkwa unu arịrịọ ike sị unu na-ahụkwa ha nʼanya karịa ka unu hụrụ ha ugbu a.
\v 11 Nweenụ agụụ ibi ndụ nwayọọ, na-arụkwanụ ọrụ dịịrị unu. Jirikwanụ aka unu na-arụ ọrụ dịka anyị gwara unu,
\v 12 nke a ga-eme ka ndụ unu na-ebi kwa ụbọchị wetara unu nsọpụrụ nʼebe ndị na-ekweghị ekwe nọ, meekwa ka unu ghara i dabere nʼonye ọbụla.
\s1 Ọbịbịa nke Onyenwe anyị
\p 
\v 13 Ụmụnna m, anyị chọrọ ka unu mata ihe banyere ndị otu anyị ndị dara nʼụra ọnwụ, ya ewutela unu dịka o si ewute ndị ọzọ ndị na-enweghị olileanya.
\v 14 Nʼihi na ebe ọ bụ na anyị kweere na Jisọs nwụrụ ma sitekwa nʼọnwụ bilie, nʼotu aka ahụ, anyị kwenyekwara na site na Jisọs, Chineke ga-akpọlite ndị niile nwụrụ anwụ.
\v 15 Nʼihi na okwu nke Onyenwe anyị nke anyị na-akụziri unu bụ nke a, na anyị ndị dị ndụ ruo ọbịbịa Onyenwe anyị agaghị ebu ndị dara nʼụra ọnwụ ụzọ.
\v 16 Nʼihi na Onyenwe anyị nʼonwe ya ga-esi nʼeluigwe rịdata, ọ ga-ewere olu ike kpọọ oku, werekwa olu nke onyeisi ndị mmụọ ozi na ụda opi ike nke Chineke. Mgbe ahụ ndị niile nwụrụ nʼime Kraịst ga-ebu ụzọ bilie.
\v 17 Mgbe ahụ, anyị onwe anyị, ndị dị ndụ, ndị fọdụrụ nʼụwa, ka a ga-eweli anyị na ha elu nʼime igwe ojii, ịga izute Onyenwe anyị na mbara eluigwe, ebe anyị na Onyenwe anyị ga-anọ ruo mgbe ebighị ebi.
\v 18 Ya mere, werenụ okwu ndị a, na-agba onwe unu ume mgbe niile.
\c 5
\s1 Ịnọ na nche
\p 
\v 1 Ugbu a, ụmụnna, banyere oge na mgbe ihe ndị a ga-emezu. Echeghị m na ọ dị mkpa i degara unu akwụkwọ.
\v 2 Dị ka unu maara nke ọma na ụbọchị Onyenwe anyị ga-abịa dị ka onye ohi si abịa nʼabalị.
\v 3 Mgbe ha ga na-asị udo, na nchekwa dị, mgbe ahụ, na mberede, mbibi ga-abịakwasị ha dị ka ihe mgbu sị adakwasị nwanyị ime na-eme, nke ga-eme ka onye ọbụla ghara inwe ike ịgbapụ.
\p 
\v 4 Ma unu onwe unu, ụmụnna, anọghị nʼọchịchịrị, nke ụbọchị ahụ ga-abịakwasị unu na mberede dịka onye ohi.
\v 5 Unu niile bụ ụmụ nke ìhè na ụmụ nke ehihie, anyị abụkwaghị nke ọchịchịrị maọbụ nke abalị.
\v 6 Nʼihi nke a, ka anyị ghara ịdị na-arahụ ụra dị ka ndị ọzọ, kama ka anyị mụrụ anya ka anya dokwaa anyị.
\v 7 Nʼihi na abalị bụ mgbe ndị na-arahụ ụra ji arahụ ụra. Ọ bụkwa nʼabalị ka ndị mmanya na-egbu na-aṅụbiga mmanya oke.
\v 8 Ma ebe anyị niile bụ ndị nke ihe, ka anyị bụrụ ndị anya doro, ndị yi okwukwe na ịhụnanya dịka ihe ikpuchi obi, yikwasịkwa olileanya nke nzọpụta dị ka okpu igwe.
\v 9 Nʼihi na Chineke akwadebeghị ikpe ọmụma na egwu nye anyị. Kama ka anyị nweta nzọpụta site nʼokwukwe anyị nwere nʼOnyenwe anyị Jisọs Kraịst.
\v 10 Ọ nwụrụ nʼihi anyị ka ọ bụrụ, ma anyị dị ndụ ma anyị nwụrụ anwụ, anyị ga-esoro ya dịrị ndụ.
\v 11 Ya mere, na-akasịrịtanụ onwe unu obi. Na-emekwanụ ihe ọbụla ga-ewuli ibe unu elu dị ka unu si eme.
\s1 Ndụmọdụ ikpeazụ
\p 
\v 12 Anyị na-arịọsị unu ike, ụmụnna, ka unu na-asọpụrụ ndị niile na-adọgbu onwe ha nʼọrụ nʼihi unu, ndị ahụ na-elekọta unu nʼime ọrụ Onyenwe anyị, na ndị ahụ na-adụ unu ọdụ.
\v 13 Ka unu na-akwanyere ha ugwu site nʼịhụnanya nʼihi ụdị ọrụ ha na-arụ. Ka unu na mmadụ ibe unu birikwa nʼudo.
\v 14 Ma ugbu a, anyị na-arịọ unu, ụmụnna, na-adụnụ ndị na-anọ nkịtị ọdụ, na-agbanụ ndị dara mba ume, nyerenụ ndị na-adịghị ike aka, nwekwanụ ndidi nʼebe ha niile nọ.
\v 15 Ka onye ọbụla ghara inyeghachi mmadụ ibe ya ihe ọjọọ nʼọnọdụ ihe ọjọọ. Kama gbalịsienụ ike ime ezi ihe nʼebe ibe unu nọ na nʼebe mmadụ niile nọ.
\p 
\v 16 Na-aṅụrịnụ ọṅụ oge niile.
\v 17 Na-ekpenụ ekpere oge niile na-esepụghị aka.
\v 18 Na-enyenụ ekele mgbe niile banyere ihe niile, nʼihi na nke a bụ ọchịchọ Chineke banyere unu ndị bụ nke Kraịst Jisọs.
\p 
\v 19 Unu emenyụla ọkụ Mmụọ Nsọ.
\v 20 Ọzọ unu eledala okwu ndị amụma anya.
\v 21 Kama na-anwalenụ ihe niile ma na-ejidesikwanụ ihe niile dị mma aka ike.
\v 22 Wezuganụ onwe unu nʼihe ọjọọ niile.
\p 
\v 23 Ka Chineke ya onwe ya, bụ Chineke nke udo, doo unu nsọ nʼụzọ niile. Ka e debezuo mmụọ unu na mkpụrụobi unu na anụ ahụ unu nsọ, na-enweghị ntụpọ ọbụla ruo ụbọchị ọbịbịa Onyenwe anyị Jisọs Kraịst.
\v 24 Onye ahụ kpọrọ unu ga-emezu ihe ndị a, nʼihi na ọ bụ onye kwesiri ntụkwasị obi.
\b
\b
\p 
\v 25 Biko ụmụnna, na-ekperenụ anyị ekpere.
\b
\p 
\v 26 Werenụ isurita ọnụ dị nsọ na-ekele ụmụnna anyị dum.
\b
\p 
\v 27 Iwu m na-enye unu site nʼaha Onyenwe anyị bụ ka unu gụpụta akwụkwọ a nʼihu ụmụnna niile.
\b
\p 
\v 28 Ka amara Onyenwe anyị Jisọs Kraịst dịnyere unu niile.
