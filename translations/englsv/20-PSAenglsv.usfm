\v 12 \w For|strong="H3808"\w* an enemy \w does|strong="H3808"\w* \w not|strong="H3808"\w* reproach \w me|strong="H3808"\w*, \w or|strong="H3808"\w* \w I|strong="H3808"\w* bear [\w it|strong="H7130"\w*], || \w He|strong="H3808"\w* \w who|strong="H3808"\w* \w is|strong="H7130"\w* hating \w me|strong="H3808"\w* || Has \w not|strong="H3808"\w* magnified \w himself|strong="H3808"\w* against \w me|strong="H3808"\w*, || \w Or|strong="H3808"\w* \w I|strong="H3808"\w* hide \w from|strong="H4185"\w* \w him|strong="H7130"\w*.
